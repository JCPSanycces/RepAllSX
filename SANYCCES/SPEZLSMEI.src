#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZLSMEI
# Description : Específico Pantalla emergente para medición e instalación
# Module      : Ventas
# Version     : 1
# Created by  : Jose Luis Chiva
# Company     : Sanycces
# Created date: 18/06/2026
############################################################################

$ACTION

#If GUSER="SN070" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"          : Gosub DEBUT
  When "TITRE"          : Gosub TITRE_
  When "OK"             : Gosub OK
  When "FIN"            : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Raz [M:ZLSMEI0]ZNUMLIN
Return

##############################################################
$TITRE_
  TIT = ""
Return

##############################################################
$OK
  If dim(GNUMLIN) > 0 Then : GNUMLIN = [M:ZLSMEI0]ZNUMLIN : Endif
Return

##############################################################
$FIN
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Número de línea' (pantalla ZLSMEI0) 18/06/2026 11:28:26 (SN070)
######################################################################################
Subprog AM_ZNUMLIN(VALEUR)
Variable Decimal VALEUR
  If !find(VALEUR,GLINASOC) Then
    Call ERREUR("Número de línea no permitido") From GESECRAN
    mkstat=2
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
