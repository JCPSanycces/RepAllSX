######################################################################################
## Botón 14 - Informar medición en asociados (pantalla SQH2) 17/06/2026 15:06:53 (SN070)
######################################################################################
# 2026-00053
Subprog B14_NBLIG
Local   Integer LINT,LCON,LSTAT
Global  Integer GNUMLIN,GLINASOC(1..)
Global  Char    GL1LLE(250)(5)
Local   Char    PABRFIC(250),PTEXTE(250),LCODE(250),LMAILVENDE(250)
Local   Integer XXOK
Local   Char    XCHAMPLIEN(50) : XCHAMPLIEN = 'YYYY'
Global  Char    YYYY(50) : YYYY = "SQH"
Local   Clbfile WWCLOB

  # buscar los números de línea válidos para este presupuesto (sólo las líneas con variantes de EC)
  If !clalev([F:ZSQD0]) Then : Local File SQUOTED   [F:ZSQD0] : Endif
  If !clalev([F:ZITM0]) Then : Local File ITMMASTER [F:ZITM0] : Endif
  [L]LCON = 1
  Filter [F:ZSQD0] Where SQHNUM = [M:SQH0]SQHNUM
  For [F:ZSQD0]
    If [F:ZSQD0]LINTYP = 9 Then
      [V]GLINASOC([L]LCON) = [F:ZSQD0]SQDLIN
      [L]LCON += 1
    Elsif [F:ZSQD0]LINTYP = 1 Then
      Read [F:ZITM0]ITM0 = [F:ZSQD0]ITMREF
      If !fstat Then
        If [F:ZITM0]TSICOD = '001' Then
          [V]GLINASOC([L]LCON) = [F:ZSQD0]SQDLIN
          [L]LCON += 1
        Endif
      Endif
    Endif
  Next
  Filter [F:ZSQD0]

  # llama a la ventana emergente
  Call SAISIE_LIB(LINT,GL1LLE,"OZLSMEI","SPEZLSMEI","OBJZON") From GSAISIE

  If [V]GNUMLIN = 0 Then : End : Endif

  # rellena los campos de la medición en las variantes de las estructuras comerciales
  If !clalev([F:ZSQD1]) Then : Local File SQUOTED [F:ZSQD1] : Endif
  If !clalev([F:ZSQD2]) Then : Local File SQUOTED [F:ZSQD2] : Endif
  If !clalev([F:ZSQD3]) Then : Local File SQUOTED [F:ZSQD3] : Endif
  If !clalev([F:ZTXC1]) Then : Local File TEXCLOB [F:ZTXC1] : Endif
  If !clalev([F:ZTXC2]) Then : Local File TEXCLOB [F:ZTXC2] : Endif
  Read [F:ZSQD1]SQD0 = [M:SQH0]SQHNUM;[M:SQH2]SQDLIN(nolign-1)
  If !fstat Then

    # texto línea
    # la línea de medición sí que tiene texto línea
    If [F:ZSQD1]SQDTEX <> "" Then
      Read [F:ZSQD3]SQD0 = [M:SQH0]SQHNUM;[V]GNUMLIN
      If !fstat Then
        # la línea de la mampara ya tiene texto línea
        If [F:ZSQD3]SQDTEX <> "" Then
          # código de la línea de medición
          Read [F:ZTXC1]TXC0 = [F:ZSQD1]SQDTEX
          # código de la línea de mampara
          Read [F:ZTXC2]TXC0 = [F:ZSQD3]SQDTEX
          If !fstat Then
            # copia el texto de la medición sobre el texto de la mampara
            # lo hago así para reaprovechar el código y no generar uno nuevo
            [L]LCODE = [F:ZSQD3]SQDTEX
            [F:ZTXC2]TEXTE = [F:ZTXC1]TEXTE
            If !adxlog Then : Trbegin [F:ZTXC2] : Endif
            Rewrite [F:ZTXC2]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
        # la línea de la mampara no tiene texto línea
        Else
          Read [F:ZTXC1]TXC0 = [F:ZSQD1]SQDTEX
          If !fstat Then
            # crea el registro en la tabla TEXCLOB
            Local Mask ACLOB [M:ACL]
            Setlob [L]WWCLOB With [F:ZTXC1]TEXTE
            [M:ACL]CLOB = [L]WWCLOB
            Call CRE_CLOB_ACL([L]XCHAMPLIEN,[L]XXOK) From TRTX3TEX
            Close Local Mask [M:ACL]
            [L]LCODE = [V]YYYY
          Endif
        Endif
      Endif
    # la línea de medición no tiene texto línea (o se ha borrado)
    Else
      # busca la línea de la mampara
      Read [F:ZSQD3]SQD0 = [M:SQH0]SQHNUM;[V]GNUMLIN
      If !fstat Then
        # esa línea de la mampara sí que tiene texto línea
        If [F:ZSQD3]SQDTEX <> "" Then
          # borra el texto línea de la mampara
          Call SUP_CLOB([F:ZSQD3]SQDTEX,[L]LSTAT) From TRTX3TEX
          If [L]LSTAT Then
            [L]LCODE = ""
          Endif
        Endif
      Endif
    Endif

    # correo vendedor
    [L]LMAILVENDE = [F:ZSQD1]ZMAILVENDE

    # escribe la información de la medición en la tabla de líneas de presupuesto
    Read [F:ZSQD2]SQD0 = [F:SQH]SQHNUM;[V]GNUMLIN
    If !fstat Then
      [F:ZSQD2]SQDTEX     = [L]LCODE
      [F:ZSQD2]ZMAILVENDE = [L]LMAILVENDE
      If !adxlog Then : Trbegin [F:ZSQD2] : Endif
      Rewrite [F:ZSQD2]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Endif

  # limpia variables y tablas
  If dim([V]GNUMLIN)  > 0 Then : Kill [V]GNUMLIN  : Endif
  If dim([V]GLINASOC) > 0 Then : Kill [V]GLINASOC : Endif
  If dim([V]YYYY)     > 0 Then : Kill [V]YYYY     : Endif
  Close Local File [ZSQD0],[ZSQD1],[ZSQD2],[ZSQD3],[ZITM0],[ZTXC1],[ZTXC2]
End

######################################################################################
## Después de modificar el campo 'Control de montaje' (pantalla SQH2) 18/06/2026 15:39:14 (SN070)
######################################################################################
# 2026-00053.ini
Subprog AM_ZCTRLMONTAJE(VALEUR)
Variable Integer VALEUR

Local Integer LCON

  For [L]LCON = nolign To [M:SQH2]NBLIG-1
    If [M:SQH2]LINTYP([L]LCON) = 8 Then
      Actzo [M:SQH2]ZCTRLMONTAJE([L]LCON)
      [M:SQH2]ZCTRLMONTAJE([L]LCON) = VALEUR
      Affzo [M:SQH2]ZCTRLMONTAJE([L]LCON)
      [M:SQH2]UPDFLG([L]LCON) = VALEUR
      Affzo [M:SQH2]UPDFLG([L]LCON)
    Else
      Break
    Endif
  Next

End

######################################################################################
## Después de modificar el campo 'Control de medición' (pantalla SQH2) 29/06/2026 15:43:31 (SN070)
######################################################################################
# 2026-00053.ini
Subprog AM_ZCTRLMEDIC(VALEUR)
Variable Integer VALEUR

Local Integer LCON

  For [L]LCON = nolign To [M:SQH2]NBLIG-1
    If [M:SQH2]LINTYP([L]LCON) = 8 Then
      Actzo [M:SQH2]ZCTRLMEDIC([L]LCON)
      [M:SQH2]ZCTRLMEDIC([L]LCON) = VALEUR
      Affzo [M:SQH2]ZCTRLMEDIC([L]LCON)
      [M:SQH2]UPDFLG([L]LCON) = VALEUR
      Affzo [M:SQH2]UPDFLG([L]LCON)
    Else
      Break
    Endif
  Next

End
