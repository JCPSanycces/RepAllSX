######################################################################################
## DespuÈs de modificar el campo 'Imprimir texto lÌnea' (pantalla BPABPC) 11/05/2026 13:18:57 (SN070)
######################################################################################
# 2026-00029
Subprog AM_XZIMPTXLIN(VALEUR)
Variable Integer VALEUR
  [M]ZIMPTXLIN([M]XNUMLIG) = VALEUR
  [M]FLMOD([M]XNUMLIG) = 1
  Gosub INIT_FLMODFONC From SUBBPA
End

######################################################################################
## Antes de entrada a la lÌnea (pantalla BPABPC) 11/05/2026 13:39:04 (SN070)
######################################################################################
Subprog AS_NBADR
# 2026-00029.ini
  [M]XZIMPTXLIN = [M]ZIMPTXLIN(nolign-1)
  Affzo [M]XZIMPTXLIN
# 2026-00029.fin
End

