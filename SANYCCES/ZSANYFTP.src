Local Char    SERVER(100)     : SERVER    = '1.f2m4u4davdwtw.dev.ent.magento.cloud'
Local Char    PORT(100)       : PORT      = '2221'
Local Char    USER(100)       : USER      = 'f2m4u4davdwtw_stg_remote'
Local Char    PWD(100)        : PWD       = 'P9tXf7h1ww1EtC9'
Local Char    FTPFOLDER(100)  : FTPFOLDER = ''
Local Char    LPATH(100)      : LPATH     = filpath('B2B\FTP','','')
Local Char    LPATHDES(100)   : LPATHDES  = filpath('B2B\FTP\ENVIADOS','','')
Local Char    LINDEX(100)     : LINDEX    = 'prueba1'
Local Char    LFORMATO(10)    : LFORMATO  = 'csv'
Local Integer RESULT

Call SFTPPUTMOV_B2B(SERVER,PORT,USER,PWD,FTPFOLDER,LPATH,LPATHDES,LINDEX,LFORMATO,RESULT)
End

##########################################################################################################
Subprog SFTPPUTMOV_B2B(SERVER,PORT,USER,PWD,FTPFOLDER,LPATH,LPATHDES,LINDEX,LFORMATO,RESULT)
Value     Char    SERVER()          # dirección del servidor ftp
Value     Char    PORT()            # puerto ftp
Value     Char    USER()            # usuario
Value     Char    PWD()             # contraseńa
Value     Char    FTPFOLDER()       # carpeta destino en el servidor ftp
Value     Char    LPATH()           # carpeta origen en el servidor local
Value     Char    LPATHDES()        # carpeta de enviados en el servidor local
Value     Char    LINDEX()          # índice de referencia para el envío
Value     Char    LFORMATO()        # formato del fichero
Variable  Integer RESULT            # resultado del proceso

Local     Integer I
Local     Integer STAT
Local     Char    LFILES(GDIMFIC)(1..)
Local     Char    FILELIST(GDIMFIC)(1..)
Local     Char    ORDRE(250)
Local     Char    LFILENAME(250)

  RESULT = -1

#Check if destination directory exists and creates it if not
  STAT = filinfo (LPATHDES,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATHDES+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution
  If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : End : Endif
#  If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : End : Endif

  Sleep 5

#Check the files to upload
  ORDRE = "dir /b /a-d-s-h "+LPATH+"\"+LINDEX+"."+LFORMATO+" 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RESULT,LFILES) From ORDSYS

  If RESULT > 0
    For I = 1 To RESULT

      LFILENAME = LFILES(I)

#Create the command file to upload the files
      Openo filpath(LPATHDES,"FtpPut","bat",nomap)
      adxifs = ';'
      adxirs = chr$(13) + chr$(10)
      adxium = 50

      Wrseq '"C:\WinSCP\WinSCP.com" /log="' + LPATHDES + '\PutLog.txt" /ini=nul /command "option batch continue" "option confirm off" "open sftp://' + USER + ':' + PWD  + '@' + SERVER +
&           ':' + PORT + ' -hostkey=""ssh-rsa 3072 69AIZg4NZcsJeet8bmpp9EZ/QCrD8rJHsCm2ce5q49k"""' +
&           ' "cd ' + FTPFOLDER + '" "put ' + LPATH + '\' + left$(LFILENAME,len(LFILENAME)-4) + '.*" "exit" "/log=' + LPATHDES + '\PutLog.txt"'

      Openo

      System CHAINE = filpath(LPATHDES,"FtpPut","bat")

#Clean the script files
      If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : RESULT = -2 : End : Endif
#      If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : RESULT = -2 : End : Endif

#Move de uploaded files
      ORDRE = "MOVE "+LPATH+"\"+left$(LFILENAME,len(LFILENAME)-4)+".* "+LPATHDES
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILENAME) From ORDSYS

    Next
  Endif

End

##########################################################################################################
Subprog FTPPUTMOV_B2B_WASABI(LBUCKET,LREGION,LPATH,LPATHDES,LINDEX,LFORMATO,LBASEURL,RESULT)
Value     Char    LBUCKET()         # nombre del bucket en Wasabi (ej: facturasany)
Value     Char    LREGION()         # región del bucket (ej: eu-west-2)
Value     Char    LPATH()           # carpeta origen en el servidor local
Value     Char    LPATHDES()        # carpeta de enviados en el servidor local
Value     Char    LINDEX()          # índice de referencia para el envío (patrón nombre fichero)
Value     Char    LFORMATO()        # formato del fichero (ej: pdf)
Value     Char    LBASEURL()        # subcarpeta destino dentro del bucket (ej: facturas)
Variable  Integer RESULT            # resultado del proceso

Local     Integer I
Local     Integer STAT
Local     Char    LFILES(GDIMFIC)(1..)
Local     Char    FILELIST(GDIMFIC)(1..)
Local     Char    ORDRE(250)
Local     Char    LFILENAME(250)
Local     Char    LOBJECT(250)      # clave del objeto dentro del bucket
Local     Char    LURL(250)         # URL pública resultante

  RESULT = -1

#Check if destination directory exists and creates it if not
  STAT = filinfo (LPATHDES,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATHDES+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution
  If Delfile (filpath(LPATHDES,"WasabiPut",'bat')) = -27 : End : Endif
#  If Delfile (filpath(LPATHDES,"WasabiLog",'txt')) = -27 : End : Endif

  Sleep 5

#Check the files to upload
  ORDRE = "dir /b /a-d-s-h "+LPATH+"\"+LINDEX+"."+LFORMATO+" 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RESULT,LFILES) From ORDSYS

  If RESULT > 0
    For I = 1 To RESULT

      LFILENAME = LFILES(I)

      # Construir la clave del objeto en el bucket y la URL pública
      # La URL es determinista: no necesitamos esperar respuesta del script
      If LBASEURL <> "" Then
        LOBJECT = LBASEURL + "/" + LFILENAME
      Else
        LOBJECT = LFILENAME
      Endif
      LURL    = "https://s3." + LREGION + ".wasabisys.com/" + LBUCKET + "/" + LOBJECT

      #Create the command file to upload the files to Wasabi
      Openo filpath(LPATHDES,"WasabiPut","bat",nomap)
      adxifs = ';'
      adxirs = chr$(13) + chr$(10)
      adxium = 50

      Wrseq '@echo off'
      Wrseq 'if not exist ' + chr$(34) + LPATH + '\' + LFILENAME + chr$(34) + ' ('
      Wrseq '    echo ERROR: Fichero no encontrado >> ' + chr$(34) + LPATHDES + '\WasabiLog.txt' + chr$(34)
      Wrseq '    exit /b 1'
      Wrseq ')'
      Wrseq '"C:\Python311\python.exe" "C:\SageScripts\upload_wasabi.py" '
&         + chr$(34) + LPATH + '\' + LFILENAME + chr$(34) + ' '
&         + chr$(34) + LBUCKET                 + chr$(34) + ' '
&         + chr$(34) + LOBJECT                 + chr$(34)
&         + ' >> ' + chr$(34) + LPATHDES + '\WasabiLog.txt' + chr$(34) + ' 2>&1'
      Wrseq 'exit /b %ERRORLEVEL%'

      Openo

#      # Execute the bat
      System CHAINE = filpath(LPATHDES, "WasabiPut", "bat")

#Clean the script files
      If Delfile (filpath(LPATHDES,"WasabiPut",'bat')) = -27 : RESULT = -2 : End : Endif
#      If Delfile (filpath(LPATHDES,"WasabiLog",'txt')) = -27 : RESULT = -2 : End : Endif

#Move de uploaded files
      ORDRE = "MOVE "+LPATH+"\"+left$(LFILENAME,len(LFILENAME)-4)+".* "+LPATHDES
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILENAME) From ORDSYS

    Next
  Endif

End

##########################################################################################################
Subprog FTPPUTMOV (SERVER,USER,PWD,FTPFOLDER,LPATH,LPATHDES,RESULT)
Value     Char    SERVER()
Value     Char    USER()
Value     Char    PWD()
Value     Char    FTPFOLDER()
Value     Char    LPATH()
Value     Char    LPATHDES()
Variable  Integer RESULT

Local     Char    NL(2)
Local     Integer I
Local     Integer STAT
Local     Char    LFILES(GDIMFIC)(1..)
Local     Char    FILELIST(GDIMFIC)(1..)
Local     Char    ORDRE(250)

  RESULT  = -1
  NL      = chr$(13)+chr$(10)

#Check if destination directory exists and creates it if not
  STAT = filinfo (LPATHDES,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATHDES+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution
  If Delfile (filpath(LPATHDES,"FtpPut",'bat'))       = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"FtpPutOrder",'txt'))  = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"PutLog",'txt'))       = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"FileCount",'txt'))    = -27 : End : Endif

#Check the files to upload
  ORDRE = "dir /b /a-d-s-h "+LPATH+" 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RESULT,LFILES) From ORDSYS

  If RESULT > 0
#Create the command file to upload the files
    Openo filpath(LPATHDES,"FtpPut","bat"), 0             Using [FOUT]
    Wrseq "ftp -i -n -s:"+LPATHDES+"\FtpPutOrder.txt"+NL  Using [FOUT]
    Openo                                                 Using [FOUT]
    Openo filpath(LPATHDES,"FtpPutOrder","txt"), 0        Using [FOUT]
    Wrseq "open "+SERVER+NL+
&         "user "+USER+" "+NL+
&         PWD+NL+
&         "quote pasv"+NL+
&         "cd /"+FTPFOLDER+NL+
&         "lcd "+LPATH+NL+
&         "ls"+NL+
&         "mput *.*"+NL+
&         "quit"+NL                                       Using [FOUT]
    Openo                                                 Using [FOUT]

  #Execute the previous script
    ORDRE = LPATHDES+"\FtpPut.bat > "+LPATHDES+"\PutLog.txt 2>&1"
    Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

#Clean the script files
    If Delfile (filpath(LPATHDES,"FtpPut",'bat'))       = -27 : RESULT = -2 : End : Endif
    If Delfile (filpath(LPATHDES,"FtpPutOrder",'txt'))  = -27 : RESULT = -2 : End : Endif
    If Delfile (filpath(LPATHDES,"PutLog",'txt'))       = -27 : RESULT = -2 : End : Endif
    If Delfile (filpath(LPATHDES,"FileCount",'txt'))    = -27               : End : Endif

#Move de uploaded files
    ORDRE = "MOVE "+LPATH+"\*.* "+LPATHDES
    Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

  Endif

End
