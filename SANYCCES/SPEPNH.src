######################################################################################
## DespuÚs de modificar el campo 'Motivo devoluciˇn' (pantalla PNH1) 22/05/2026 08:39:51 (SN070)
######################################################################################
Subprog AM_RTNREN(VALEUR)
Variable Char    VALEUR()
# 2026-00032.ini
  If [F:ADI]NUMTAB<>6051 | [F:ADI]CODE<>VALEUR
    Read [ADI] CODE=6051;VALEUR : If fstat Raz [F:ADI] : Endif
  Endif
  If !clalev([F:AXX])  Local File ATEXTRA [AXX] : Endif
  Read [AXX] AXX0="ATABDIV";"LNGDES";[M:PNH1]LAN;"6051";VALEUR
  If fstat
    Read [AXX] AXX0="ATABDIV";"SHODES";[M:PNH1]LAN;"6051";VALEUR
    If fstat
      Read [AXX] AXX0="ATABDIV";"LNGDES";GLANGUE;"6051";VALEUR
      If fstat
        Read [AXX] AXX0="ATABDIV";"SHODES";GLANGUE;"6051";VALEUR
      Endif
    Endif
  Endif
  If !fstat  [M:PNH1]RTNDES(nolign-1)=[F:AXX]TEXTE : Endif
# 2026-00032.fin
End


