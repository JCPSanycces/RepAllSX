$ACTION

#If GUSER="SN070" Then : Call ECR_TRACE(ACTION,0) From GESECRAN : Endif
Case ACTION
  When "IMPORT"        : Gosub IMPORT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$IMPORT
# ZB2B.ini
  [M:ZIB2B]ZB2BCONFIGUR = [F:ITM]ZB2BCONFIGUR
  Affzo [M:ZIB2B]ZB2BCONFIGUR

  [M:ZIB2B]ZB2BSETATRIB = [F:ITM]ZB2BSETATRIB
  Affzo [M:ZIB2B]ZB2BSETATRIB
# ZB2B.fin
Return

