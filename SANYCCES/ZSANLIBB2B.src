#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
#**
#* devuelve la información del pedido para el B2B
#*
#* @param PCLIMGT         > identificador de cliente B2B
#* @param PDATEINI        > fecha inicial para filtro
#* @param PDATEDEB        > fecha final para filtro
#* @param PNUMPAG         > número de página
#* @param PPEDIDO         > número de pedido
#* @param PFECHA          > fecha de pedido
#* @param PESTADO         > estado del pedido
#* @param PFECHAULTENT    > fecha de la última entrega
#* @param PFECHAPREVISTA  > fecha prevista de entrega
#* @param PIMPORTEAI      > importe del pedido antes de impuestos
#* @param PIMPORTEII      > importe del pedido impuestos incluidos
#* @param PCONDPAGO       > condición de pago del pedido
#* @param PELEMFACT       > elementos de facturación
#* @param PREFERENCIA     > referencia
#* @param PPEDIDOMAGENTO  > número de pedido en Magento
#* @param PNUMLINEAS      > número de líneas totales en el pedido
#* @param PTOTALPAGS      > número total de páginas
#* @param PTOTALPEDIDOS   > número total de pedidos
#* @param PMAXPAGINA      > número de pedidos por página
#*!
Subprog GET_SOHINFO(PCLIMGT,PDATEINI,PDATEDEB,
&                   PNUMPAG,PPEDIDO,PFECHA,PESTADO,PFECHAULTENT,PFECHAPREVISTA,PIMPORTEAI,PIMPORTEII,PCONDPAGO,PELEMFACT,PREFERENCIA,
&                   PPEDIDOMAGENTO,PNUMLINEAS,PTOTALPAGS,PTOTALPEDIDOS,PMAXPAGINA)
# parámetros de entrada
Value     Char    PCLIMGT()
Value     Char    PDATEINI()
Value     Char    PDATEDEB()
# parámetros de salida - cabecera
Variable  Integer PNUMPAG()
Variable  Char    PPEDIDO()(1..50)
Variable  Char    PFECHA()(1..50)
Variable  Char    PESTADO()(1..50)
Variable  Char    PFECHAULTENT()(1..50)
Variable  Char    PFECHAPREVISTA()(1..50)
Variable  Decimal PIMPORTEAI(1..50)
Variable  Decimal PIMPORTEII(1..50)
Variable  Char    PCONDPAGO()(1..50)
Variable  Char    PELEMFACT()(1..50)
Variable  Char    PREFERENCIA()(1..50)
Variable  Char    PPEDIDOMAGENTO()(1..50)
Variable  Integer PNUMLINEAS(1..50)
Variable  Integer PTOTALPAGS()
Variable  Integer PTOTALPEDIDOS()
Variable  Integer PMAXPAGINA()
# variables locales
Local     Char    LCRIT(250) : [L]LCRIT = "1=1"
Local     Integer I,J,K,LCONTROL
Local     Date    LFINI,LFFIN
Local     Integer LMAX : [L]LMAX = val(func AFNC.PARAM("ZPAGCABB2B",nomap))
Local     Integer LREGINI,LREGFIN

  If [L]LMAX = 0 Then : [L]LMAX = 50 : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # cliente
  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  Filter [F:ZBPC] Where ZUSUARIOB2B = PCLIMGT
  Read   [F:ZBPC] First
  If !fstat Then
    [L]LCRIT += " and CLIENTE_SAGE = '" + [F:ZBPC]BPCNUM + "'"
  Else
    GSTATUS   = 0
    Call ERREUR("Error en el cliente") From GESECRAN
    End
  Endif
  Filter [F:ZBPC]

  # fecha inicio
  If PDATEINI <> "" Then
    Call VALIDA_FECHA(PDATEINI,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de inicio") From GESECRAN
      End
    Endif
    If PDATEINI <> "" Then
      LFINI = gdat$(val(mid$(PDATEINI,1,2)),val(mid$(PDATEINI,4,2)),val(mid$(PDATEINI,7,4)))
      [L]LCRIT += " and FECHAPEDIDO >= ["  + format$(GFMD,LFINI) + "]"
    Endif
  Endif

  # fecha fin
  If PDATEDEB <> "" Then
    Call VALIDA_FECHA(PDATEDEB,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de fin") From GESECRAN
      End
    Endif
    If PDATEDEB <> "" Then
      LFFIN = gdat$(val(mid$(PDATEDEB,1,2)),val(mid$(PDATEDEB,4,2)),val(mid$(PDATEDEB,7,4)))
      [L]LCRIT += " and FECHAPEDIDO <= ["  + format$(GFMD,LFFIN) + "]"
    Endif
  Endif

  If PNUMPAG = 0 Then
    PNUMPAG = 1
  Endif

  [L]LREGINI = ((PNUMPAG - 1) * [L]LMAX) + 1
  [L]LREGFIN = PNUMPAG * [L]LMAX

  [L]I += 1
  [L]J += 1
  [L]K  = [L]LREGINI
  If !clalev([F:ZVSH]) Then : Local File ZVSOHB2B [F:ZVSH] : Endif
  If !clalev([F:ZSOQ]) Then : Local File SORDERQ  [F:ZSOQ] : Endif
  Filter [F:ZVSH] Where evalue([L]LCRIT) Order By PEDIDO Desc
  # número total de pedidos
  PTOTALPEDIDOS = rowcount([F:ZVSH])
  # tamańo de página
  PMAXPAGINA    = [L]LMAX
  # número total de páginas
  PTOTALPAGS    = fix(PTOTALPEDIDOS / PMAXPAGINA)
  If mod(rowcount([F:ZVSH]),[L]LMAX) > 0 Then : PTOTALPAGS += 1 : Endif
  For [F:ZVSH]
    If [L]J < [L]K Then
      [L]J += 1
    Else
      If [L]LREGINI <= [L]LREGFIN
        PPEDIDO(I)          = vireblc([F:ZVSH]PEDIDO,2)
        If [F:ZVSH]FECHAPEDIDO <> [0/0/0] Then
          PFECHA(I)         = num$(format$(GFMD,[F:ZVSH]FECHAPEDIDO))
        Else
          PFECHA(I)         = ""
        Endif
        PESTADO(I)          = vireblc([F:ZVSH]ESTADOPEDIDO,2)
        If [F:ZVSH]FECHAULTENTR <> [0/0/0] Then
          PFECHAULTENT(I)   = num$(format$(GFMD,[F:ZVSH]FECHAULTENTR))
        Else
          PFECHAULTENT(I)   = ""
        Endif
        If [F:ZVSH]FECHAPREVEXP <> [0/0/0] Then
          PFECHAPREVISTA(I) = num$(format$(GFMD,[F:ZVSH]FECHAPREVEXP))
        Else
          PFECHAPREVISTA(I) = ""
        Endif
        PCONDPAGO(I)        = vireblc([F:ZVSH]COND_PAGO,2)
        PELEMFACT(I)        = vireblc([F:ZVSH]ELEM_FACT,2)
        PREFERENCIA(I)      = vireblc([F:ZVSH]REFERENCIA,2)
        PPEDIDOMAGENTO(I)   = vireblc([F:ZVSH]PEDIDO_MGT,2)
        PIMPORTEAI(I)       = [F:ZVSH]IMPORTEAI
        PIMPORTEII(I)       = [F:ZVSH]IMPORTEII
        Filter [F:ZSOQ] Where SOHNUM = [F:ZVSH]PEDIDO
        PNUMLINEAS(I)       = rowcount([F:ZSOQ])
        Filter [F:ZSOQ]
        [L]LREGINI += 1
        [L]I       += 1
      Else
        Break
      Endif
    Endif
  Next
  Filter [F:ZVSH]

  If GSTATUS = 1
    Call MESSAGE("Número de registros:"-num$(I-1)) From GESECRAN
  Endif

End

########################################################################
#**
#* devuelve la información de líneas de pedido para el B2B
#*
#* @param PPEDIDO         > número de pedido
#* @param PNUMPAG         > número de página
#* @param PFECHA          > fecha de pedido
#* @param PESTADO         > estado del pedido
#* @param PFECHAULTENT    > fecha de la última entrega
#* @param PTIMPORTEAI     > importe total antes de impuestos
#* @param PTIMPORTEII     > importe total impuestos incluidos
#* @param PCLIMGT         > cliente Magento
#* @param PCONDPAGO       > condición de pago del pedido
#* @param PELEMFACT       > elementos de facturación
#* @param PREFERENCIA     > referencia
#* @param PPEDIDOMAGENTO  > número de pedido en Magento
#* @param PTOTALPAGS      > número total de páginas
#* @param PTOTALLINEAS    > número total de líneas de pedido
#* @param PMAXPAGINA      > número de líneas por página
#* @param PLINEA          > línea de pedido
#* @param PARTICULO       > código de artículo
#* @param PDESARTICULO    > descripción de artículo
#* @param PCTDPEDIDA      > cantidad pedida
#* @param PCTDSERVIDA     > cantidad servida
#* @param PCTDPENDIENTE   > cantidad pendiente
#* @param PTRACKING       > número de tracking
#* @param PFECHAPREVISTA  > fecha prevista de entrega
#* @param PLPRECIOBRUTO   > precio bruto de la línea
#* @param PDTO1           > descuento 1
#* @param PDTO2           > descuento 2
#* @param PDTO3           > descuento 3
#* @param PLPRECIONETO    > precio neto de la línea
#* @param PLIMPORTEAI     > importe de la línea antes de impuestos
#* @param PLIMPORTEII     > importe de la línea impuestos incluidos
#*!
Subprog GET_SODINFO(PPEDIDO,
&                   PNUMPAG,PFECHA,PESTADO,PFECHAULTENT,PTIMPORTEAI,PTIMPORTEII,PCLIMGT,PCONDPAGO,PELEMFACT,PREFERENCIA,PPEDIDOMAGENTO,PTOTALPAGS,PTOTALLINEAS,PMAXPAGINA,
&                   PLINEA,PARTICULO,PDESARTICULO,PCTDPEDIDA,PCTDSERVIDA,PCTDPENDIENTE,PTRACKING,PFECHAPREVISTA,
&                   PLPRECIOBRUTO,PDTO1,PDTO2,PDTO3,PLPRECIONETO,PLIMPORTEAI,PLIMPORTEII)
# parámetros de entrada
Value     Char    PPEDIDO()
# parámetros de salida - cabecera
Variable  Integer PNUMPAG()
Variable  Char    PFECHA()
Variable  Char    PESTADO()
Variable  Char    PFECHAULTENT()
Variable  Decimal PTIMPORTEAI()
Variable  Decimal PTIMPORTEII()
Variable  Char    PCLIMGT()
Variable  Char    PCONDPAGO()
Variable  Char    PELEMFACT()
Variable  Char    PREFERENCIA()
Variable  Char    PPEDIDOMAGENTO()
Variable  Integer PTOTALPAGS()
Variable  Integer PTOTALLINEAS()
Variable  Integer PMAXPAGINA()
# parámetros de salida - líneas
Variable  Integer PLINEA(1..500)
Variable  Char    PARTICULO()(1..500)
Variable  Char    PDESARTICULO()(1..500)
Variable  Decimal PCTDPEDIDA(1..500)
Variable  Decimal PCTDSERVIDA(1..500)
Variable  Decimal PCTDPENDIENTE(1..500)
Variable  Char    PTRACKING()(1..500)
Variable  Char    PFECHAPREVISTA()(1..500)
Variable  Decimal PLPRECIOBRUTO(1..500)
Variable  Decimal PDTO1(1..500)
Variable  Decimal PDTO2(1..500)
Variable  Decimal PDTO3(1..500)
Variable  Decimal PLPRECIONETO(1..500)
Variable  Decimal PLIMPORTEAI(1..500)
Variable  Decimal PLIMPORTEII(1..500)
# variables locales
Local     Char    LCRIT(250) : [L]LCRIT = "1=1"
Local     Integer I,J,K,LCONTROL
Local     Date    LFINI,LFFIN
Local     Integer LMAX : [L]LMAX = val(func AFNC.PARAM("ZPAGLINB2B",nomap))
Local     Integer LREGINI,LREGFIN

  If [L]LMAX = 0 Then : [L]LMAX = 500 : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # pedido
  If PPEDIDO <> "" Then
    If !clalev([F:ZVSH]) Then : Local File ZVSOHB2B   [F:ZVSH] : Endif
    If !clalev([F:ZVBB]) Then : Local File ZVBPCB2BGR [F:ZVBB] : Endif
    Filter [F:ZVSH] Where PEDIDO = PPEDIDO
    Read   [F:ZVSH] First
    If !fstat Then
      [L]LCRIT += " and PEDIDO='" + vireblc([F:ZVSH]PEDIDO,2) + "'"
      PFECHA      = num$(format$(GFMD,[F:ZVSH]FECHAPEDIDO))
      PESTADO = vireblc([F:ZVSH]ESTADOPEDIDO,2)
      If [F:ZVSH]FECHAULTENTR <> [0/0/0] Then
        PFECHAULTENT  = num$(format$(GFMD,[F:ZVSH]FECHAULTENTR))
      Endif
      PTIMPORTEAI   = [F:ZVSH]IMPORTEAI
      PTIMPORTEII   = [F:ZVSH]IMPORTEII
      PCONDPAGO     = vireblc([F:ZVSH]COND_PAGO,2)
      PELEMFACT     = vireblc([F:ZVSH]ELEM_FACT,2)
      PREFERENCIA   = vireblc([F:ZVSH]REFERENCIA,2)
      PPEDIDOMAGENTO= vireblc([F:ZVSH]PEDIDO_MGT,2)
      Filter [F:ZVBB] Where BPCNUM = [F:ZVSH]CLIENTE_SAGE
      Read [F:ZVBB] First
      If !fstat Then
        PCLIMGT = vireblc([F:ZVBB]EMAIL,2)
      Endif
      Filter [F:ZVBB]
    Else
      GSTATUS   = 0
      Call ERREUR("Error en el pedido") From GESECRAN
      End
    Endif
  Else
    GSTATUS   = 0
    Call ERREUR("Error en el pedido") From GESECRAN
    End
  Endif
  Filter [F:ZVSH]

  If PNUMPAG = 0 Then
    PNUMPAG = 1
  Endif

  [L]LREGINI = ((PNUMPAG - 1) * [L]LMAX) + 1
  [L]LREGFIN = PNUMPAG * [L]LMAX

  [L]I += 1
  [L]J += 1
  [L]K  = [L]LREGINI
  If !clalev([F:ZVSD]) Then : Local File ZVSODB2B [F:ZVSD] : Endif
  Filter [F:ZVSD] Where evalue([L]LCRIT) Order By LINEA
  # número total de líneas de pedido
  PTOTALLINEAS  = rowcount([F:ZVSD])
  # tamańo de página
  PMAXPAGINA    = [L]LMAX
  # número total de páginas
  PTOTALPAGS    = fix(PTOTALLINEAS / PMAXPAGINA)
  If mod(rowcount([F:ZVSD]),[L]LMAX) > 0 Then : PTOTALPAGS += 1 : Endif
  For [F:ZVSD]
    If [L]J < [L]K Then
      [L]J += 1
    Else
      If [L]LREGINI <= [L]LREGFIN
        PLINEA(I)           = [F:ZVSD]LINEA
        PARTICULO(I)        = vireblc([F:ZVSD]ARTICULO,2)
        PDESARTICULO(I)     = vireblc([F:ZVSD]DESCRIPCION,2)
        PCTDPEDIDA(I)       = [F:ZVSD]CANTIDAD
        PCTDSERVIDA(I)      = [F:ZVSD]CTDEXPEDIDA
        PCTDPENDIENTE(I)    = [F:ZVSD]CTDPENDIENTE
        PLPRECIOBRUTO(I)    = [F:ZVSD]PRECIOBRUTO
        PDTO1(I)            = [F:ZVSD]DESCUENTO1
        PDTO2(I)            = [F:ZVSD]DESCUENTO2
        PDTO3(I)            = [F:ZVSD]DESCUENTO3
        PLPRECIONETO(I)     = [F:ZVSD]PRECIONETO
        PLIMPORTEAI(I)      = [F:ZVSD]IMPORTEAI * [F:ZVSD]CANTIDAD
        PLIMPORTEII(I)      = [F:ZVSD]IMPORTEII * [F:ZVSD]CANTIDAD
        PTRACKING(I)        = vireblc([F:ZVSD]NUMEXPED,2)
        If [F:ZVSD]FECHAPREVEXP <> [0/0/0] Then
          PFECHAPREVISTA(I) = num$(format$(GFMD,[F:ZVSD]FECHAPREVEXP))
        Else
          PFECHAPREVISTA(I) = ""
        Endif
        [L]LREGINI += 1
        [L]I       += 1
      Else
        Break
      Endif
    Endif
  Next
  Filter [F:ZVSD]

  If GSTATUS = 1
    Call MESSAGE("Número de registros:"-num$(I-1)) From GESECRAN
  Endif

End

########################################################################
#**
#* devuelve la información de la entrega para el B2B
#*
#* @param PCLIMGT         > identificador de cliente B2B
#* @param PDATEINI        > fecha inicial para filtro
#* @param PDATEDEB        > fecha final para filtro
#* @param PNUMPAG         > número de página
#* @param PTOTALPAGS      > número total de páginas
#* @param PTOTALENTREGAS  > número total de entregas
#* @param PMAXPAGINA      > número de entregas por página
#* @param PENTREGA        > número de entrega
#* @param PFECHA          > fecha de entrega
#* @param PPEDIDO         > número de pedido
#* @param PIMPORTEAI      > importe antes de impuestos
#* @param PIMPORTEII      > importe impuestos incluidos
#* @param PCONDPAGO       > condición de pago
#* @param PELEMFACT       > elementos de facturación
#* @param PDOCPREP        > documento de preparación
#* @param PTRACKING       > tracking
#* @param PNUMLINEAS      > número de líneas totales en la entrega
#* @param PLINKPDF        > link de descarga
#*!
Subprog GET_SDHINFO(PCLIMGT,PDATEINI,PDATEDEB,
&                   PNUMPAG,PTOTALPAGS,PTOTALENTREGAS,PMAXPAGINA,
&                   PENTREGA,PFECHA,PPEDIDO,PIMPORTEAI,PIMPORTEII,PCONDPAGO,PELEMFACT,PDOCPREP,PTRACKING,PNUMLINEAS,PLINKPDF)
# parámetros de entrada
Value     Char    PCLIMGT()
Value     Char    PDATEINI()
Value     Char    PDATEDEB()
# parámetros de salida - cabecera
Variable  Integer PNUMPAG()
Variable  Integer PTOTALPAGS()
Variable  Integer PTOTALENTREGAS()
Variable  Integer PMAXPAGINA()
Variable  Char    PENTREGA()(1..50)
Variable  Char    PFECHA()(1..50)
Variable  Char    PPEDIDO()(1..50)
Variable  Decimal PIMPORTEAI(1..50)
Variable  Decimal PIMPORTEII(1..50)
Variable  Char    PCONDPAGO()(1..50)
Variable  Char    PELEMFACT()(1..50)
Variable  Char    PDOCPREP()(1..50)
Variable  Char    PTRACKING()(1..50)
Variable  Integer PNUMLINEAS(1..50)
Variable  Char    PLINKPDF()(1..50)
# variables locales
Local     Char    LCRIT(250) : [L]LCRIT = "1=1"
Local     Integer I,J,K,LCONTROL
Local     Date    LFINI,LFFIN
Local     Integer LMAX : [L]LMAX = val(func AFNC.PARAM("ZPAGCABB2B",nomap))
Local     Integer LREGINI,LREGFIN

  If [L]LMAX = 0 Then : [L]LMAX = 50 : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # cliente
  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  Filter [F:ZBPC] Where ZUSUARIOB2B = PCLIMGT
  Read   [F:ZBPC] First
  If !fstat Then
    [L]LCRIT += " and CLIENTE_SAGE='" + vireblc([F:ZBPC]BPCNUM,2) + "'"
  Else
    GSTATUS   = 0
    Call ERREUR("Error en el cliente") From GESECRAN
    End
  Endif
  Filter [F:ZBPC]

  # fecha inicio
  If PDATEINI <> ""
    Call VALIDA_FECHA(PDATEINI,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de inicio") From GESECRAN
    Endif
    If PDATEINI <> "" Then
      LFINI = gdat$(val(mid$(PDATEINI,1,2)),val(mid$(PDATEINI,4,2)),val(mid$(PDATEINI,7,4)))
      [L]LCRIT += " and FECHA>=["  + format$(GFMD,LFINI) + "]"
    Endif
  Endif

  # fecha fin
  If PDATEDEB <> ""
    Call VALIDA_FECHA(PDATEDEB,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de fin") From GESECRAN
    Endif
    If PDATEDEB <> "" Then
      LFFIN = gdat$(val(mid$(PDATEDEB,1,2)),val(mid$(PDATEDEB,4,2)),val(mid$(PDATEDEB,7,4)))
      [L]LCRIT += " and FECHA<=["  + format$(GFMD,LFFIN) + "]"
    Endif
  Endif

  If PNUMPAG = 0 Then
    PNUMPAG = 1
  Endif

  [L]LREGINI = ((PNUMPAG - 1) * [L]LMAX) + 1
  [L]LREGFIN = PNUMPAG * [L]LMAX

  [L]I += 1
  [L]J += 1
  [L]K  = [L]LREGINI
  If !clalev([F:ZVSH]) Then : Local File ZVSDHB2B   [F:ZVSH] : Endif
  If !clalev([F:ZSDD]) Then : Local File SDELIVERYD [F:ZSDD] : Endif
  Filter [F:ZVSH] Where evalue([L]LCRIT) Order By ENTREGA Desc
  # número total de entregas
  PTOTALENTREGAS  = rowcount([F:ZVSH])
  # tamańo de página
  PMAXPAGINA      = [L]LMAX
  # número total de páginas
  PTOTALPAGS      = fix(PTOTALENTREGAS / PMAXPAGINA)
  If mod(rowcount([F:ZVSH]),[L]LMAX) > 0 Then : PTOTALPAGS += 1 : Endif
  For [F:ZVSH]
    If [L]J < [L]K Then
      [L]J += 1
    Else
      If [L]LREGINI <= [L]LREGFIN
        PENTREGA(I)         = vireblc([F:ZVSH]ENTREGA,2)
        If [F:ZVSH]FECHA <> [0/0/0] Then
          PFECHA(I)         = num$(format$(GFMD,[F:ZVSH]FECHA))
        Else
          PFECHA(I)         = ""
        Endif
        PPEDIDO(I)          = vireblc([F:ZVSH]PEDIDO,2)
        PIMPORTEAI(I)       = [F:ZVSH]IMPORTEAI
        PIMPORTEII(I)       = [F:ZVSH]IMPORTEII
        Filter [F:ZSDD] Where SDHNUM = vireblc([F:ZVSH]ENTREGA,2)
        PNUMLINEAS(I)       = rowcount([F:ZSDD])
        PCONDPAGO(I)        = vireblc([F:ZVSH]COND_PAGO,2)
        PELEMFACT(I)        = vireblc([F:ZVSH]ELEM_FACT,2)
        PDOCPREP(I)         = vireblc([F:ZVSH]DOC_PREP,2)
        PTRACKING(I)        = vireblc([F:ZVSH]TRACKING,2)
        PLINKPDF(I)         = vireblc([F:ZVSH]LINKPDF,2)
        Filter [F:ZSDD]
        [L]LREGINI += 1
        [L]I       += 1
      Else
        Break
      Endif
    Endif
  Next
  Filter [F:ZVSH]

  If GSTATUS = 1
    Call MESSAGE("Número de registros:"-num$(I-1)) From GESECRAN
  Endif

End

########################################################################
#**
#* devuelve la información de líneas de entrega para el B2B
#*
#* @param PENTREGA        > número de entrega
#* @param PNUMPAG         > número de la página
#* @param PFECHA          > fecha de entrega
#* @param PTIMPORTEAI     > importe total antes de impuestos
#* @param PTIMPORTEII     > importe total impuestos incluidos
#* @param PCLIMGT         > cliente magento
#* @param PCONDPAGO       > condición de pago
#* @param PELEMFACT       > elementos de facturación
#* @param PDOCPREP        > documento de preparación
#* @param PTRACKING       > número de tracking
#* @param PTOTALPAGS      > número total de páginas
#* @param PTOTALLINEAS    > número total de líneas de entrega
#* @param PMAXPAGINA      > número de líneas por página
#* @param PLINEA          > línea de entrega
#* @param PARTICULO       > artículo
#* @param PDESARTICULO    > descripción de artículo
#* @param PPEDIDO         > número de pedido
#* @param PLINEAPEDIDO    > línea de pedido
#* @param PCANTIDAD       > cantidad entregada
#* @param PLPRECIOBRUTO   > precio bruto de la línea
#* @param PDTO1           > descuento 1
#* @param PDTO2           > descuento 2
#* @param PDTO3           > descuento 3
#* @param PLPRECIONETO    > precio neto de la línea
#* @param PLIMPORTEAI     > importe de la línea antes de impuestos
#* @param PLIMPORTEII     > importe de la línea impuestos incluidos
#*!
Subprog GET_SDDINFO(PENTREGA,PNUMPAG,PFECHA,PTIMPORTEAI,PTIMPORTEII,PCLIMGT,PCONDPAGO,PELEMFACT,PDOCPREP,PTRACKING,PTOTALPAGS,PTOTALLINEAS,PMAXPAGINA,
&                   PLINEA,PARTICULO,PDESARTICULO,PPEDIDO,PLINEAPEDIDO,PCANTIDAD,
&                   PLPRECIOBRUTO,PDTO1,PDTO2,PDTO3,PLPRECIONETO,PLIMPORTEAI,PLIMPORTEII)
# parámetros de salida - cabecera
Variable  Char    PENTREGA()
Variable  Integer PNUMPAG()
Variable  Char    PFECHA()
Variable  Decimal PTIMPORTEAI()
Variable  Decimal PTIMPORTEII()
Variable  Char    PCLIMGT()
Variable  Char    PCONDPAGO()
Variable  Char    PELEMFACT()
Variable  Char    PDOCPREP()
Variable  Char    PTRACKING()
Variable  Integer PTOTALPAGS()
Variable  Integer PTOTALLINEAS()
Variable  Integer PMAXPAGINA()
# parámetros de salida - líneas
Variable  Integer PLINEA(1..500)
Variable  Char    PARTICULO()(1..500)
Variable  Char    PDESARTICULO()(1..500)
Variable  Char    PPEDIDO()(1..500)
Variable  Integer PLINEAPEDIDO(1..500)
Variable  Decimal PCANTIDAD(1..500)
Variable  Decimal PLPRECIOBRUTO(1..500)
Variable  Decimal PDTO1(1..500)
Variable  Decimal PDTO2(1..500)
Variable  Decimal PDTO3(1..500)
Variable  Decimal PLPRECIONETO(1..500)
Variable  Decimal PLIMPORTEAI(1..500)
Variable  Decimal PLIMPORTEII(1..500)
# variables locales
Local     Char    LCRIT(250) : [L]LCRIT = "1=1"
Local     Integer I,J,K,LCONTROL
Local     Date    LFINI,LFFIN
Local     Integer LMAX : [L]LMAX = val(func AFNC.PARAM("ZPAGLINB2B",nomap))
Local     Integer LREGINI,LREGFIN

  If [L]LMAX = 0 Then : [L]LMAX = 500 : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # entrega
  If PENTREGA <> "" Then
    If !clalev([F:ZSDH]) Then : Local File SDELIVERY  [F:ZSDH] : Endif
    If !clalev([F:ZVSH]) Then : Local File ZVSDHB2B   [F:ZVSH] : Endif
    If !clalev([F:ZVBB]) Then : Local File ZVBPCB2BGR [F:ZVBB] : Endif
#    Read [F:ZSDH]SDH0 = PENTREGA
    Filter [F:ZVSH] Where ENTREGA = vireblc(PENTREGA,2)
    Read [F:ZVSH] First
    If !fstat Then
      [L]LCRIT += " and ENTREGA='" + vireblc([F:ZVSH]ENTREGA,2) + "'"
      If [F:ZVSH]FECHA <> [0/0/0] Then
        PFECHA      = num$(format$(GFMD,[F:ZVSH]FECHA))
      Endif
      PTIMPORTEAI   = [F:ZVSH]IMPORTEAI
      PTIMPORTEII   = [F:ZVSH]IMPORTEII
      PCONDPAGO     = vireblc([F:ZVSH]COND_PAGO,2)
      PELEMFACT     = vireblc([F:ZVSH]ELEM_FACT,2)
      PDOCPREP      = vireblc([F:ZVSH]DOC_PREP,2)
      PTRACKING     = vireblc([F:ZVSH]TRACKING,2)
      Filter [F:ZVBB] Where BPCNUM = [F:ZSDH]BPCORD
      Read [F:ZVBB] First
      If !fstat Then
        PCLIMGT = vireblc([F:ZVBB]EMAIL,2)
      Endif
      Filter [F:ZVBB]
    Else
      GSTATUS   = 0
      Call ERREUR("Error en la entrega") From GESECRAN
      End
    Endif
  Else
    GSTATUS   = 0
    Call ERREUR("Error en la entrega") From GESECRAN
    End
  Endif

  If PNUMPAG = 0 Then
    PNUMPAG = 1
  Endif

  [L]LREGINI = ((PNUMPAG - 1) * [L]LMAX) + 1
  [L]LREGFIN = PNUMPAG * [L]LMAX

  [L]I += 1
  [L]J += 1
  [L]K  = [L]LREGINI
  If !clalev([F:ZVSD]) Then : Local File ZVSDDB2B [F:ZVSD] : Endif
  Filter [F:ZVSD] Where evalue([L]LCRIT) Order By LINEA
  # número total de líneas de entrega
  PTOTALLINEAS  = rowcount([F:ZVSD])
  # tamańo de página
  PMAXPAGINA    = [L]LMAX
  # número total de páginas
  PTOTALPAGS    = fix(PTOTALLINEAS / PMAXPAGINA)
  If mod(rowcount([F:ZVSD]),[L]LMAX) > 0 Then : PTOTALPAGS += 1 : Endif
  For [F:ZVSD]
    If [L]J < [L]K Then
      [L]J += 1
    Else
      If [L]LREGINI <= [L]LREGFIN
        PLINEA(I)           = [F:ZVSD]LINEA
        PARTICULO(I)        = vireblc([F:ZVSD]ARTICULO,2)
        PDESARTICULO(I)     = vireblc([F:ZVSD]DESCRIPCION,2)
        PPEDIDO(I)          = vireblc([F:ZVSD]PEDIDO,2)
        PLINEAPEDIDO(I)     = [F:ZVSD]LINEA_PEDIDO
        PCANTIDAD(I)        = [F:ZVSD]CANTIDAD
        PLPRECIOBRUTO(I)    = [F:ZVSD]PRECIOBRUTO
        PDTO1(I)            = [F:ZVSD]DESCUENTO1
        PDTO2(I)            = [F:ZVSD]DESCUENTO2
        PDTO3(I)            = [F:ZVSD]DESCUENTO3
        PLPRECIONETO(I)     = [F:ZVSD]PRECIONETO
        PLIMPORTEAI(I)      = [F:ZVSD]IMPORTEAI
        PLIMPORTEII(I)      = [F:ZVSD]IMPORTEII
        [L]LREGINI += 1
        [L]I       += 1
      Else
        Break
      Endif
    Endif
  Next
  Filter [F:ZVSD]

  If GSTATUS = 1
    Call MESSAGE("Número de registros:"-num$(I-1)) From GESECRAN
  Endif

End

########################################################################
#**
#* devuelve la información de las facturas para el B2B
#*
#* @param PCLIMGT         > identificador de cliente B2B
#* @param PDATEINI        > fecha inicial para filtro
#* @param PDATEDEB        > fecha final para filtro
#* @param PNUMPAG         > número de página
#* @param PTOTALPAGS      > número total de páginas
#* @param PTOTALFACTURAS  > número total de facturas
#* @param PMAXPAGINA      > número de facturas por página
#* @param PFACTURA        > número de factura
#* @param PFECHA          > fecha de factura
#* @param PREFERENCIA     > referencia en la factura
#* @param PDIVISA         > divisa
#* @param PIMPORTE        > importe
#* @param PCONDPAGO       > condición de pago
#* @param PLINKPDF        > link de descarga
#*!
Subprog GET_SIHINFO(PCLIMGT,PDATEINI,PDATEDEB,
&                   PNUMPAG,PTOTALPAGS,PTOTALFACTURAS,PMAXPAGINA,
&                   PFACTURA,PFECHA,PREFERENCIA,PDIVISA,PIMPORTE,PCONDPAGO,PLINKPDF)
# parámetros de entrada
Value     Char    PCLIMGT()
Value     Char    PDATEINI()
Value     Char    PDATEDEB()
# parámetros de salida
Variable  Integer PNUMPAG()
Variable  Integer PTOTALPAGS()
Variable  Integer PTOTALFACTURAS()
Variable  Integer PMAXPAGINA()
Variable  Char    PFACTURA()(1..50)
Variable  Char    PFECHA()(1..50)
Variable  Char    PREFERENCIA()(1..50)
Variable  Char    PDIVISA()(1..50)
Variable  Decimal PIMPORTE(1..50)
Variable  Char    PCONDPAGO()(1..50)
Variable  Char    PLINKPDF()(1..50)
# variables locales
Local     Char    LCRIT(250) : [L]LCRIT = "TIPOFAC=1 AND ESTADOFAC=3"
Local     Integer I,J,K,LCONTROL
Local     Date    LFINI,LFFIN
Local     Integer LMAX : [L]LMAX = val(func AFNC.PARAM("ZPAGCABB2B",nomap))
Local     Integer LREGINI,LREGFIN

  If [L]LMAX = 0 Then : [L]LMAX = 50 : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # cliente
  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  Filter [F:ZBPC] Where ZUSUARIOB2B = vireblc(PCLIMGT,2)
  Read   [F:ZBPC] First
  If !fstat Then
    [L]LCRIT += " and CLIENTE_SAGE='" + vireblc([F:ZBPC]BPCNUM,2) + "'"
  Else
    GSTATUS   = 0
    Call ERREUR("Error en el cliente") From GESECRAN
    End
  Endif
  Filter [F:ZBPC]

  # fecha inicio
  If PDATEINI <> "" Then
    Call VALIDA_FECHA(PDATEINI,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de inicio") From GESECRAN
    Endif
    If PDATEINI <> "" Then
      LFINI = gdat$(val(mid$(PDATEINI,1,2)),val(mid$(PDATEINI,4,2)),val(mid$(PDATEINI,7,4)))
      [L]LCRIT += " and FECHA>=["  + format$(GFMD,LFINI) + "]"
    Endif
  Endif

  # fecha fin
  If PDATEDEB <> "" Then
    Call VALIDA_FECHA(PDATEDEB,[L]LCONTROL) From ZSANLIB01
    If [L]LCONTROL = 0 Then
      GSTATUS   = 0
      Call ERREUR("Error en la fecha de fin") From GESECRAN
    Endif
    If PDATEDEB <> "" Then
      LFFIN = gdat$(val(mid$(PDATEDEB,1,2)),val(mid$(PDATEDEB,4,2)),val(mid$(PDATEDEB,7,4)))
      [L]LCRIT += " and FECHA<=["  + format$(GFMD,LFFIN) + "]"
    Endif
  Endif

  If PNUMPAG = 0 Then
    PNUMPAG = 1
  Endif

  [L]LREGINI = ((PNUMPAG - 1) * [L]LMAX) + 1
  [L]LREGFIN = PNUMPAG * [L]LMAX

  [L]I += 1
  [L]J += 1
  [L]K  = [L]LREGINI
  If !clalev([F:ZVFV]) Then : Local File ZVFACTURAB2B [F:ZVFV] : Endif
  Filter [F:ZVFV] Where evalue([L]LCRIT) Order By FACTURA Desc
  # número total de facturas
  PTOTALFACTURAS  = rowcount([F:ZVFV])
  # tamańo de página
  PMAXPAGINA      = [L]LMAX
  # número total de páginas
  PTOTALPAGS      = fix(PTOTALFACTURAS / PMAXPAGINA)
  If mod(rowcount([F:ZVFV]),[L]LMAX) > 0 Then : PTOTALPAGS += 1 : Endif
  For [F:ZVFV]
    If [L]J < [L]K Then
      [L]J += 1
    Else
      If [L]LREGINI <= [L]LREGFIN
        PFACTURA(I)         = vireblc([F:ZVFV]FACTURA,2)
        If [F:ZVFV]FECHA <> [0/0/0] Then
          PFECHA(I)         = num$(format$(GFMD,[F:ZVFV]FECHA))
        Else
          PFECHA(I)         = ""
        Endif
        PREFERENCIA(I)      = vireblc([F:ZVFV]REFERENCIA,2)
        PDIVISA(I)          = vireblc([F:ZVFV]DIVISA,2)
        PIMPORTE(I)         = [F:ZVFV]IMPORTE
        PCONDPAGO(I)        = vireblc([F:ZVFV]DPAGO,2)
        PLINKPDF(I)         = vireblc([F:ZVFV]ZURLPDFB2B,2)
        [L]LREGINI += 1
        [L]I       += 1
      Else
        Break
      Endif
    Endif
  Next
  Filter [F:ZVFV]

  If GSTATUS = 1
    Call MESSAGE("Número de registros:"-num$(I-1)) From GESECRAN
  Endif

End

########################################################################
#**
#* creación de pedidos en Sage desde Magento
#*
#* @param PSOHNUM       > número de pedido (en blanco)
#* @param PBPCORD       > código de cliente
#* @param PBPCNAM       > razón social
#* @param PBPAADD       > dirección
#* @param PORDDAT       > fecha del pedido
#* @param PCUSORDREF    > referencia
#* @param PZSOHNUMB2B   > número de pedido Magento
#* @param PZTEXTO1B2B   > texto adicional
#* @param PITMREF       > artículo
#* @param PEC           > estructura comercial
#* @param PVERSIONEC    > versión estructura comercial
#* @param PQTY          > cantidad
#* @param PZATTFILEB2B  > nombre del fichero adjunto a la línea
#* @param PYRAL         > acabados/ral
#* @param PZALTO        > alto
#* @param PZANCHO       > ancho
#* @param PZLARGO       > largo
#* @param PYCOMENCLI    > comentarios de cliente
#*!
Subprog PUT_SOH(PSOHNUM,PBPCORD,PBPCNAM,PBPAADD,PORDDAT,PCUSORDREF,PZSOHNUMB2B,PZTEXTO1B2B,
&               PITMREF,PEC,PVERSIONEC,PQTY,PZATTFILEB2B,PYRAL,PZALTO,PZANCHO,PZLARGO,PYCOMENCLI)
# parámetros de cabecera
Variable  Char    PSOHNUM()
Value     Char    PBPCORD(),PBPCNAM(),PBPAADD(),PCUSORDREF()
Value     Char    PZSOHNUMB2B(),PZTEXTO1B2B()
Value     Date    PORDDAT()
# parámetros de línea
Value     Char    PITMREF()(1..200),PEC()(1..200),PVERSIONEC()(1..200),PZATTFILEB2B()(1..200),PYRAL()(1..200),PYCOMENCLI()(1..200)
Value     Decimal PZALTO(1..200),PZANCHO(1..200),PZLARGO(1..200)
Value     Integer PQTY(1..200)
# variables locales
Local     Integer LCON,I,J,K,M,N
Local     Char    LDIRIMPORT(250)       : [L]LDIRIMPORT = filpath("B2B\SOH","","")
Local     Char    LFILE_W(200)          : [L]LFILE_W    = PZSOHNUMB2B
Local     Char    LFECHA(10), LHORA(10) : Raz [L]LFECHA, [L]LHORA
Local     Char    LATTFILE(250)         : Raz [L]LATTFILE
Global    Char    GZSOHNUMB2B(250)      : Raz [V]GZSOHNUMB2B
Global    Integer GZCTRLB2B(250)        : [V]GZCTRLB2B  = 1
Local     Integer WFMI,WALLTYP
Local     Char    LERRORB2B(250)
Local     Char    LBPCNAM0(250),LBPINAM0(250),LBPAINV(25)

  If !clalev([F:ZBPC0]) Then : Local File BPCUSTOMER  [F:ZBPC0] : Endif
  If !clalev([F:ZBPA0]) Then : Local File BPADDRESS   [F:ZBPA0] : Endif
  If !clalev([F:ZSOH0]) Then : Local File SORDER      [F:ZSOH0] : Endif
  If !clalev([F:ZITM0]) Then : Local File ITMMASTER   [F:ZITM0] : Endif
  If !clalev([F:ZBOD0]) Then : Local File BOMD        [F:ZBOD0] : Endif
  If !clalev([F:ZBOD1]) Then : Local File BOMD        [F:ZBOD1] : Endif

  If !clalev([F:ZSB20]) Then : Local File ZSOHB2B     [F:ZSB20] : Endif
  If !clalev([F:ZSB21]) Then : Local File ZSOHB2B     [F:ZSB21] : Endif

  # Inicializamos con estado OK
  GSTATUS  = 1
  GMESSAGE = ""

  # verifica el número de pedido Magento
  Filter [F:ZSOH0] Where ZSOHNUMB2B = PZSOHNUMB2B
  Read   [F:ZSOH0] First
  If !fstat Then
    GSTATUS = 0
    [L]LERRORB2B = "El pedido"-PZSOHNUMB2B-"ya existe en el sistema"
#    Gosub SEND_WORKFLOW_ERROR
    Call ERREUR("El pedido"-PZSOHNUMB2B-"ya existe en el sistema") From GESECRAN
    End
  Endif
  Filter [F:ZSOH0]

  # verifica el cliente
  If PBPCORD = "" Then
    GSTATUS = 0
    [L]LERRORB2B = "Error en el cliente"-PBPCORD
#    Gosub SEND_WORKFLOW_ERROR
    Call ERREUR("Error en el cliente"-PBPCORD) From GESECRAN
    End
  Else
    Read [F:ZBPC0]BPC0 = PBPCORD
    If fstat Then
      GSTATUS = 0
      [L]LERRORB2B = "Error en el cliente"-PBPCORD
#      Gosub SEND_WORKFLOW_ERROR
      Call ERREUR("Error en el cliente"-PBPCORD) From GESECRAN
      End
    Else
      [L]LBPCNAM0 = vireblc([F:ZBPC0]BPCNAM,2)
      [L]LBPINAM0 = vireblc([F:ZBPC0]BPCNAM,2)
      [L]LBPAINV  = vireblc([F:ZBPC0]BPAINV,2)
    Endif
  Endif

  # verifica la dirección de entrega del pedido
  If PBPAADD = "" Then
    GSTATUS = 0
    [L]LERRORB2B = "Error en la dirección de entrega"
#    Gosub SEND_WORKFLOW_ERROR
    Call ERREUR("Error en la dirección de entrega") From GESECRAN
    End
  Else
    Read [F:ZBPA0]BPA0 = 1;PBPCORD;PBPAADD
    If fstat Then
      GSTATUS = 0
      [L]LERRORB2B = "Error en la dirección de entrega"
#      Gosub SEND_WORKFLOW_ERROR
      Call ERREUR("Error en la dirección de entrega") From GESECRAN
      End
    Endif
  Endif

  # elimina registros con el mismo número de pedido
  If !adxlog Then : Trbegin [F:ZSB20] : Endif
  Delete [F:ZSB20] Where ZSOHNUMB2B = PZSOHNUMB2B
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # elimina registros de más de un ańo
  If !adxlog Then : Trbegin [F:ZSB20] : Endif
  Delete [F:ZSB20] Where CREDATTIM <= date$-365
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # averigua la cantidad de pedidos que se pretenden importar
  For I=1 To maxtab(PITMREF)
    If PITMREF(I) <> "" Then
      Read [F:ZITM0]ITM0 = PITMREF
      If !fstat and [F:ZITM0]ITMSTA = 1 Then
        [L]LCON +=1
      Else
        GSTATUS = 0
        [L]LERRORB2B = "El artículo"-PITMREF-"no existe en el sistema"
#        Gosub SEND_WORKFLOW_ERROR
        Call ERREUR("El artículo"-PITMREF-"no existe en el sistema") From GESECRAN
        End
      Endif
    Endif
  Next

  For J = 1 To [L]LCON

    # ańadir los parámetros del web service en una tabla intermedia
    [F:ZSB20]ZSOHNUMB2B   = PZSOHNUMB2B
    [F:ZSB20]ZSOHLINB2B   = J
    [F:ZSB20]ZBPCORD      = PBPCORD
    [F:ZSB20]ZBPCNAM      = PBPCNAM
    [F:ZSB20]ZBPAADD      = PBPAADD
    [F:ZSB20]ZORDDAT      = PORDDAT
    [F:ZSB20]ZCUSORDREF   = PCUSORDREF
    [F:ZSB20]ZTEXTO1B2B   = PZTEXTO1B2B
    [F:ZSB20]ZITMREF      = PITMREF(J)
    [F:ZSB20]ZEC          = PEC(J)
    [F:ZSB20]ZVERSIONEC   = PVERSIONEC(J)
    [F:ZSB20]ZQTY         = PQTY(J)
    [F:ZSB20]ZATTFILEB2B  = PZATTFILEB2B(J)
    [F:ZSB20]YRAL         = PYRAL(J)
    [F:ZSB20]ZALTO        = PZALTO(J)
    [F:ZSB20]ZANCHO       = PZANCHO(J)
    [F:ZSB20]ZLARGO       = PZLARGO(J)
    [F:ZSB20]YCOMENCLI    = PYCOMENCLI(J)
    # identifica el tipo de línea para cada registro
    If PEC(J) <> "" Then
      Filter [F:ZBOD0] Where BOMALTTYP = 1 and CPNITMREF = "T_"+vireblc(PITMREF(J),2)
      Read   [F:ZBOD0] First
      If !fstat Then
        If [F:ZBOD0]CPNTYP = 3 Then
          [F:ZSB20]ZLINTYP = 9
        Else
          [F:ZSB20]ZLINTYP = 8
        Endif
      Else
        Filter [F:ZBOD0] Where BOMALTTYP = 1 and CPNITMREF = vireblc(PITMREF(J),2)
        Read   [F:ZBOD0] First
        If !fstat Then
          If [F:ZBOD0]CPNTYP = 3 Then
            [F:ZSB20]ZLINTYP = 9
          Else
            [F:ZSB20]ZLINTYP = 8
          Endif
        Endif
      Endif
      Filter [F:ZBOD0]
    Else
      [F:ZSB20]ZLINTYP = 1
    Endif
    If !adxlog Then : Trbegin [F:ZSB20] : Endif
    Write [F:ZSB20]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next

  # generación del fichero e importación para la creación del pedido
  Filter [F:ZSB21] Where ZSOHNUMB2B = PZSOHNUMB2B Order By ZSOHLINB2B Asc
  Read   [F:ZSB21] First
  If !fstat Then

    [L]LFECHA = vireblc(num$(date$),4) : [L]LFECHA = mid$([L]LFECHA,1,2)+mid$([L]LFECHA,4,2)+mid$([L]LFECHA,7,4)
    [L]LHORA  = vireblc(num$(time$),4) : [L]LHORA  = mid$([L]LHORA,1,2)+mid$([L]LHORA,4,2)+mid$([L]LHORA,7,2)

    [L]LDIRIMPORT += "\"
    [L]LFILE_W     = [L]LDIRIMPORT + [L]LFILE_W + "_" + [L]LFECHA + [L]LHORA + ".txt"

    # borramos el fichero si existe...
    If filinfo([L]LFILE_W, 7) > 0 Then
      System "ae_rm " + [L]LFILE_W
    Endif

    # abrir el fichero para escritura
    Gosub OPEN_FILE_W

    # obtiene los datos de la dirección de pedido
    Gosub GET_BPCDIR

    # obtiene los datos de la dirección de facturación
    Gosub GET_BPIDIR

    # cabecera
    Wrseq "E" + ";" + "11" + ";" + "SON" + ";" + vireblc([F:ZSB21]ZBPCORD,2) + ";" + vireblc([F:ZSB21]ZBPCNAM,2) + ";" + vireblc([F:ZSB21]ZBPAADD,2) + ";" +
&         vireblc(ctrans(num$([F:ZSB21]ZORDDAT),'/',''),2) + ";" + vireblc([F:ZSB21]ZCUSORDREF,2) + ";" + "11" + ";" + "EUR" + ";" +
&         vireblc([F:ZSB21]ZSOHNUMB2B,2) + ";" + vireblc([F:ZSB21]ZTEXTO1B2B,2) + ";" +
&         [L]LBPCNAM0 + ";" + [L]LBPAORD + ";" + [L]LBPCADDLIG0 + ";" + [L]LBPCADDLIG1 + ";" + [L]LBPCADDLIG2 + ";" + [L]LBPCPOSCOD + ";" +
&         [L]LBPCCTY + ";" + [L]LBPCSAT + ";" + [L]LBPCCRY + ";" + [L]LBPCCRYNAM + ";" +
&         [L]LBPINAM0 + ";" + [L]LBPAINV + ";" + [L]LBPIADDLIG0 + ";" + [L]LBPIADDLIG1 + ";" + [L]LBPIADDLIG2 + ";" + [L]LBPIPOSCOD + ";" +
&         [L]LBPICTY + ";" + [L]LBPISAT + ";" + [L]LBPICRY + ";" + [L]LBPICRYNAM + ";" + [L]LBPIEECNUM
&         Using [ZIMP_W]

    [L]K        = 0
    [L]M        = 1
    [L]N        = 0
    [L]WFMI     = 0
    # líneas
    For [F:ZSB21]

      # calcula el tipo de asignación
      [L]WALLTYP  = 1
      Call ALIFMI([F:ZSB21]ZITMREF,"11",WFMI) From TRTVENCDE
      If find([L]WFMI,3,5) Then [L]WALLTYP = 2 Endif

      # el artículo es el compuesto de una estructura comercial
      If [F:ZSB21]ZLINTYP = 9 Then
        [L]K += 1 + [L]M
        [L]M  = 0
        # busca primero por T_
        Filter [F:ZBOD1] Where BOMALTTYP = 1 and CPNITMREF = "T_"+vireblc([F:ZSB21]ZITMREF,2)
        Read   [F:ZBOD1] First
        If !fstat Then
          [L]K += 1
          [L]N += 1
          Wrseq "L" + ";" + vireblc([F:ZBOD1]ITMREF,2) + ";" + num$([F:ZSB21]ZQTY) + ";" + num$(6) + ";" +
&               num$(0) + ";" + num$(0) + ";" + "" + ";" + num$(1) + ";" + [F:ZSB21]YRAL + ";" + num$([F:ZSB21]ZALTO) + ";" + num$([F:ZSB21]ZANCHO) + ";" +
&               num$([F:ZSB21]ZLARGO) + ";" + [F:ZSB21]YCOMENCLI
&               Using [ZIMP_W]
        # si no, busca por el código exacto
        Else
          Filter [F:ZBOD1] Where BOMALTTYP = 1 and CPNITMREF = vireblc([F:ZSB21]ZITMREF,2)
          Read   [F:ZBOD1] First
          If !fstat Then
            [L]K += 1
            [L]N += 1
            Wrseq "L" + ";" + vireblc([F:ZBOD1]ITMREF,2) + ";" + num$([F:ZSB21]ZQTY) + ";" + num$(6) + ";" +
&                 num$(0) + ";" + num$(0) + ";" + "" + ";" + num$(1) + ";" + [F:ZSB21]YRAL + ";" + num$([F:ZSB21]ZALTO) + ";" + num$([F:ZSB21]ZANCHO) + ";" +
&                 num$([F:ZSB21]ZLARGO) + ";" + [F:ZSB21]YCOMENCLI
&                 Using [ZIMP_W]
          Endif
        Endif
        Filter [F:ZBOD1]
        [L]N += 1
        Wrseq "L" + ";" + vireblc([F:ZSB21]ZITMREF,2) + ";" + num$([F:ZSB21]ZQTY) + ";" + num$([F:ZSB21]ZLINTYP) + ";" +
&             num$(0) + ";" + num$(0) + ";" + vireblc([F:ZSB21]ZATTFILEB2B,2) + ";" + num$(5) + ";" + [F:ZSB21]YRAL + ";" + num$([F:ZSB21]ZALTO) + ";" +
&             num$([F:ZSB21]ZANCHO) + ";" + num$([F:ZSB21]ZLARGO) + ";" + [F:ZSB21]YCOMENCLI
&             Using [ZIMP_W]
      Endif
      # el artículo es un componente de la estructura comercial
      If [F:ZSB21]ZLINTYP = 8 Then
        [L]M += 1
        [L]N += 1
        Wrseq "L" + ";" + vireblc([F:ZSB21]ZITMREF,2) + ";" + num$([F:ZSB21]ZQTY) + ";" + num$([F:ZSB21]ZLINTYP) + ";" +
&             num$(2) + ";" + num$(([L]K-1) * 1000) + ";" + "" + ";" + num$(1) + ";" + [F:ZSB21]YRAL + ";" + num$([F:ZSB21]ZALTO) + ";" +
&             num$([F:ZSB21]ZANCHO) + ";" + num$([F:ZSB21]ZLARGO) + ";" + [F:ZSB21]YCOMENCLI
&             Using [ZIMP_W]
      Endif
      # el artículo es un artículo normal o una estructura de producción
      If find([F:ZSB21]ZLINTYP,1,2) Then
        [L]K += 1
        [L]N += 1
        Wrseq "L" + ";" + vireblc([F:ZSB21]ZITMREF,2) + ";" + num$([F:ZSB21]ZQTY) + ";" + num$(1) + ";" +
&             num$(0) + ";" + num$(0) + ";" + vireblc([F:ZSB21]ZATTFILEB2B,2) + ";" + num$(1) + ";" + [F:ZSB21]YRAL + ";" + num$([F:ZSB21]ZALTO) + ";" +
&             num$([F:ZSB21]ZANCHO) + ";" + num$([F:ZSB21]ZLARGO) + ";" + [F:ZSB21]YCOMENCLI
&             Using [ZIMP_W]
      Endif

    Next
    Filter [F:ZSB21]


#    # el artículo es el compuesto de una estructura comercial
#    If PLINTYP(J) = 9 Then
#      [L]K += 1 + [L]M
#      [L]M  = 0
#      Filter [F:ZBOD0] Where CPNITMREF = vireblc(PITMREF(J),2)
#      Read   [F:ZBOD0] First
#      If !fstat Then
#        [L]K += 1
#        [L]N += 1
#        Wrseq "L" + ";" + vireblc([F:ZBOD0]ITMREF,2) + ";" + num$(PQTY(J)) + ";" + num$(6) + ";" +
#&             num$(0) + ";" + num$(0) + ";" + "" + ";" + num$(1) + ";" + PYRAL(J) + ";" + num$(PZALTO) + ";" + num$(PZANCHO) + ";" +
#&             num$(PZLARGO) + ";" + PYCOMENCLI
#&             Using [ZIMP_W]
#      Endif
#      Filter [F:ZBOD0]
#      [L]N += 1
#      Wrseq "L" + ";" + vireblc(PITMREF(J),2) + ";" + num$(PQTY(J)) + ";" + num$(PLINTYP(J)) + ";" +
#&           num$(0) + ";" + num$(0) + ";" + vireblc([L]PZATTFILEB2B(J),2) + ";" + num$(5) + ";" + PYRAL(J) + ";" + num$(PZALTO) + ";" +
#&           num$(PZANCHO) + ";" + num$(PZLARGO) + ";" + PYCOMENCLI
#&           Using [ZIMP_W]
#    Endif
#    # el artículo es un componente de la estructura comercial
#    If PLINTYP(J) = 8 Then
#      [L]M += 1
#      [L]N += 1
#      Wrseq "L" + ";" + vireblc(PITMREF(J),2) + ";" + num$(PQTY(J)) + ";" + num$(PLINTYP(J)) + ";" +
#&           num$(2) + ";" + num$(([L]K-1) * 1000) + ";" + "" + ";" + num$(1) + ";" + PYRAL(J) + ";" + num$(PZALTO) + ";" +
#&           num$(PZANCHO) + ";" + num$(PZLARGO) + ";" + PYCOMENCLI
#&           Using [ZIMP_W]
#    Endif
#    # el artículo es un artículo normal o una estructura de producción
#    If find(PLINTYP(J),1,2) Then
#      [L]K += 1
#      [L]N += 1
#      Wrseq "L" + ";" + vireblc(PITMREF(J),2) + ";" + vireblc(PSAU(J),2) + ";" + num$(PQTY(J)) + ";" + vireblc(PDSHIDAT(J),2) + ";" + num$(1) + ";" +
#&           num$(0) + ";" + num$(0) + ";" + vireblc([L]PZATTFILEB2B(J),2) + ";" + num$(1) + ";" + PYRAL(J) + ";" + num$(PZALTO) + ";" + num$(PZANCHO) + ";" + num$(PZLARGO) + ";" + PYCOMENCLI
#&           Using [ZIMP_W]
#    Endif


    Gosub CLOSE_FILE_W

    # lanza la creación del pedido de venta
    Local Integer LRTN
    Local Char    LCTR(250)
    Local Integer LNER

    If !GWEBSERV
      Call IMP_MODEL("read","ZWSSOHB2B",LFILE_W,LRTN,LCTR,LNER) From ZSANLIB01
    Else
      # desactivo web service porque no rellena correctamente Origen artículo y Tipo asignación
      GWEBSERV=0
      Call IMP_MODEL("no read","ZWSSOHB2B",LFILE_W,LRTN,LCTR,LNER) From ZSANLIB01
      # lo vuelvo a activar para que funcione con normalidad
      GWEBSERV=1
    Endif

    # importación correcta
    If [L]LRTN = 0 Then
      If GZSOHNUMB2B <> "" Then
        [L]PSOHNUM  = GZSOHNUMB2B
        GMESSAGE    = "Se ha creado el pedido"-GZSOHNUMB2B
      Endif
    Else
      GSTATUS       = 0
      [L]LERRORB2B  = "Error"-num$([L]LNER)-"al generar el pedido. Revisar la traza"-[L]LCTR
#      Gosub SEND_WORKFLOW_ERROR
      GMESSAGE      = "Error"-num$([L]LNER)-"al generar el pedido. Revisar la traza"-[L]LCTR
    Endif

  Endif

  Kill [V]GZCTRLB2B

End

########################################################
$OPEN_FILE_W
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE_W Using [ZIMP_W]
Return

########################################################
$CLOSE_FILE_W
  Openo Using [ZIMP_W]
Return

########################################################
$SEND_WORKFLOW_ERROR
Global Char     GCORREOZES(100),GASUNTOZES(250)
Global Clbfile  GTEXTOZES(1)

  [V]GCORREOZES = "itsoporte@sanycces.es"
  [V]GASUNTOZES = "B2B: Error en la generación del pedido" - PZSOHNUMB2B
  [V]GTEXTOZES  = "Hola,"+chr$(10)+chr$(13)+chr$(10)+chr$(13)
  [V]GTEXTOZES += "Se ha producido un error durante la creación del pedido de Magento número"-PZSOHNUMB2B+"."+chr$(10)+chr$(13)+chr$(10)+chr$(13)
  [V]GTEXTOZES += [L]LERRORB2B+"."
  Call WORKFLOW(1,"ZES","","INFO1") From AWRK
Return

########################################################
# dirección de pedido (defecto del cliente)
$GET_BPCDIR
Local Char LBPAORD(250),LBPCADDLIG0(250),LBPCADDLIG1(250),LBPCADDLIG2(250),LBPCPOSCOD(250)
Local Char LBPCCTY(250),LBPCSAT(250),LBPCCRY(250),LBPCCRYNAM(250)
  If !clalev([F:ZBPA1]) Then : Local File BPADDRESS [F:ZBPA1] : Endif
  Filter [F:ZBPA1] Where BPATYP = 1 and BPANUM = PBPCORD and BPAADDFLG = 2
  Read   [F:ZBPA1] First
  If !fstat Then
    LBPAORD     = vireblc([F:ZBPA1]BPAADD,2)
    LBPCADDLIG0 = vireblc([F:ZBPA1]BPAADDLIG(0),2)
    LBPCADDLIG1 = vireblc([F:ZBPA1]BPAADDLIG(1),2)
    LBPCADDLIG2 = vireblc([F:ZBPA1]BPAADDLIG(2),2)
    LBPCPOSCOD  = vireblc([F:ZBPA1]POSCOD,2)
    LBPCCTY     = vireblc([F:ZBPA1]CTY,2)
    LBPCSAT     = vireblc([F:ZBPA1]SAT,2)
    LBPCCRY     = vireblc([F:ZBPA1]CRY,2)
    LBPCCRYNAM  = vireblc([F:ZBPA1]CRYNAM,2)
  Endif
  Filter [F:ZBPA1]
  Close Local File [ZBPA1]
Return

########################################################
# dirección de facturación (pestańa Financieras en ficha del cliente)
$GET_BPIDIR
Local Char LBPIADDLIG0(250),LBPIADDLIG1(250),LBPIADDLIG2(250),LBPIPOSCOD(250)
Local Char LBPICTY(250),LBPISAT(250),LBPICRY(250),LBPICRYNAM(250),LBPIEECNUM(250)
  If !clalev([F:ZBPA2]) Then : Local File BPADDRESS [F:ZBPA2] : Endif
  If !clalev([F:ZBPR2]) Then : Local File BPARTNER  [F:ZBPR2] : Endif
  Read [F:ZBPA2]BPA0 = 1;PBPCORD;LBPAINV
  If !fstat Then
    LBPIADDLIG0 = vireblc([F:ZBPA2]BPAADDLIG(0),2)
    LBPIADDLIG1 = vireblc([F:ZBPA2]BPAADDLIG(1),2)
    LBPIADDLIG2 = vireblc([F:ZBPA2]BPAADDLIG(2),2)
    LBPIPOSCOD  = vireblc([F:ZBPA2]POSCOD,2)
    LBPICTY     = vireblc([F:ZBPA2]CTY,2)
    LBPISAT     = vireblc([F:ZBPA2]SAT,2)
    LBPICRY     = vireblc([F:ZBPA2]CRY,2)
    LBPICRYNAM  = vireblc([F:ZBPA2]CRYNAM,2)
  Endif
  Read [F:ZBPR2]BPR0 = PBPCORD
  If !fstat Then
    [L]LBPIEECNUM = [F:ZBPR2]EECNUM
  Endif
  Close Local File [ZBPA2]
Return
