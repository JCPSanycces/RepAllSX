#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZENVENTMAS
# Description : Específico para generación de PDF y envío de entregas por mail
# Module      : Ventas
# Version     : 1
# Created by  : Jose Luis Chiva
# Company     : Sanycces
# Created date: 04/06/2026
############################################################################

Gosub INIT
Gosub OK
Gosub EXEC
Gosub FIN
End

$ACTION

#If GUSER="SN070" Then : Infbox ACTION : Endif
Case ACTION
  When "INIT"           : Gosub INIT
  When "OK"             : Gosub OK
  When "EXEC"           : Gosub EXEC
  When "FIN"            : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$INIT
# variables locales
Local   Date    LFECHADIA
Local   Char    LCRIT1(250),LCRIT2(250)
Local   Char    TBPAR(20)(1..17)
Local   Char    TBVAL(20)(1..17)
Local   Char    LFILE(200)
# variables globales
Global  Char    GNUMENTB2B(50)
Global  Char    GPATHENTB2B(50)
Global  Char    GASUNTOZEE(250),GCORREOZEE(250)
Global  Clbfile GTEXTOZEE(2),GADJUNTOSZEE(2),GNUMENTREGAS(1)

  Raz TBPAR, TBVAL

  [V]GPATHENTB2B = filpath("","","") + "\ZENV\SDH\"

  [L]LFECHADIA  = gdat$(val(mid$(date$,7,2)),val(mid$(date$,5,2)),val(mid$(date$,1,4)))

  If !clalev([F:ZVBS]) Then : Local File ZVBPCDESDH   [F:ZVBS] : Endif
  If !clalev([F:ZSDH]) Then : Local File SDELIVERY    [F:ZSDH] : Endif

Return

##############################################################
$OK
Return

##############################################################
$EXEC
  Gosub IMPRIME_ENTREGA
Return

##############################################################
$FIN
  Close Local File [ZVBS],[ZSDH]
  If dim([V]GNUMEBTB2B)   > 0 Then : Kill [V]GNUMENTB2B   : Endif
  If dim([V]GPATHENTB2B)  > 0 Then : Kill [V]GPATHENTB2B  : Endif
  If dim([V]GCORREOZEE)   > 0 Then : Kill [V]GCORREOZEE   : Endif
  If dim([V]GASUNTOZEE)   > 0 Then : Kill [V]GASUNTOZEE   : Endif
  If dim([V]GTEXTOZEE)    > 0 Then : Kill [V]GTEXTOZEE    : Endif
  If dim([V]GADJUNTOSZEE) > 0 Then : Kill [V]GADJUNTOSZEE : Endif
  If dim([V]GNUMENTREGAS) > 0 Then : Kill [V]GNUMENTREGAS : Endif
  FIN=1
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$IMPRIME_ENTREGA
Local Integer I

  # entregas del día de proceso
  [L]LCRIT1 = "DLVDAT=[" + format$(GFMD,[L]LFECHADIA) + "]"
  # cliente con envío de entrega activado
  [L]LCRIT1 -= "AND ZMAILENT=2"
  Filter [F:ZVBS] Where evalue ([L]LCRIT1)
  For [F:ZVBS]

    Raz [ZSDH],[V]GADJUNTOSZEE,[V]GNUMENTB2B,[V]GCORREOZEE,[V]GASUNTOZEE,[V]GTEXTOZEE,I
    # entregas del día de proceso
    [L]LCRIT2 = "DLVDAT=[" + format$(GFMD,[L]LFECHADIA) + "]"
    # entrega validada
    [L]LCRIT2 -= "AND CFMFLG=2"
    # cliente con entregas del día y con el envío activado
    [L]LCRIT2 -= "AND BPCORD='" + [F:ZVBS]BPCORD + "'"
    Filter [F:ZSDH] Where evalue([L]LCRIT2)
    For [F:ZSDH]

      [V]GNUMENTB2B = [F:ZSDH]SDHNUM

      # parámetros de la entrega
      TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:ZSDH]STOFCY
      TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:ZSDH]STOFCY
      TBPAR(3)  = "livraisondeb"    : TBVAL(3)  = [F:ZSDH]SDHNUM
      TBPAR(4)  = "livraisonfin"    : TBVAL(4)  = [F:ZSDH]SDHNUM
      TBPAR(5)  = "clientdeb"       : TBVAL(5)  = [F:ZSDH]BPCORD
      TBPAR(6)  = "clientfin"       : TBVAL(6)  = [F:ZSDH]BPCORD
      TBPAR(7)  = "datedeb"         : TBVAL(7)  = [F:ZSDH]DLVDAT
      TBPAR(8)  = "datefin"         : TBVAL(8)  = [F:ZSDH]DLVDAT
      TBPAR(9)  = "typedeb"         : TBVAL(9)  = num$([F:ZSDH]SDHTYP)
      TBPAR(10) = "typefin"         : TBVAL(10) = num$([F:ZSDH]SDHTYP)
      TBPAR(11) = "categlivdeb"     : TBVAL(11) = num$([F:ZSDH]SDHCAT)
      TBPAR(12) = "categlivfin"     : TBVAL(12) = num$([F:ZSDH]SDHCAT)
      TBPAR(13) = "valdeb"          : TBVAL(13) = num$([F:ZSDH]CFMFLG)
      TBPAR(14) = "valfin"          : TBVAL(14) = num$([F:ZSDH]CFMFLG)
      TBPAR(15) = "facdeb"          : TBVAL(15) = num$([F:ZSDH]INVFLG)
      TBPAR(16) = "facfin"          : TBVAL(16) = num$([F:ZSDH]INVFLG)
      TBPAR(17) = "codimp"          : TBVAL(17) = num$([F:ZSDH]PRNNDE)

      If GSERVEUR Then
        Call ECR_TRACE("["+num$(datetime$)+"] - Generado el PDF de la entrega"-[F:ZSDH]SDHNUM,0) From GESECRAN
      Endif

      # lanza el informe
      Call ETAT("Z-ENTVEN-B2B","FILE","SPA",0,"",TBPAR,TBVAL) From AIMP3

      I += 1

      If I = 1 Then
        [V]GADJUNTOSZEE   = GPATHENTB2B + GNUMENTB2B + ".pdf"
        [V]GNUMENTREGAS   = chr$(9)+"-"-[F:ZSDH]SDHNUM
      Else
        [V]GADJUNTOSZEE  += ";"+GPATHENTB2B + GNUMENTB2B + ".pdf"
        [V]GNUMENTREGAS  += chr$(10)+chr$(13)+chr$(9)+"-"-[F:ZSDH]SDHNUM
      Endif

      Sleep 5

    Next

    Filter [F:ZSDH]

    Sleep 15

    [V]GCORREOZEE = func GET_CORREO([F:ZVBS]BPCORD)
    [V]GCORREOZEE = "jl.chiva@sanycces.es"
    If [V]GADJUNTOSZEE <> "" and [V]GCORREOZEE <> "" Then
      [V]GASUNTOZEE = "Sanycces: Entregas generadas"
      [V]GTEXTOZEE  = "Hola,"+chr$(10)+chr$(13)+chr$(10)+chr$(13)
      [V]GTEXTOZEE += "te escribimos para confirmarte que se han generado el/los siguiente/s albarán/es adjunto/s a este correo:"+chr$(10)+chr$(13)
      [V]GTEXTOZEE += [V]GNUMENTREGAS
      [V]GTEXTOZEE += chr$(10)+chr$(13)+chr$(10)+chr$(13)+chr$(10)+chr$(13)+"ˇGracias por confiar en nosotros!"
      Call WORKFLOW(1,"ZEE","","INFO1") From AWRK
    Endif

  Next

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
Funprog GET_CORREO(PBPCORD)
Value Char PBPCORD

Local Clbfile LRET

  If !clalev([F:ZBPA]) Then : Local File BPADDRESS  [F:ZBPA] : Endif
  Filter [F:ZBPA] Where BPATYP = 1 and BPANUM = PBPCORD and BPAADDFLG = 2
  Read   [F:ZBPA] First
  If !fstat Then
    [L]LRET = [F:ZBPA]WEB
  Endif
  Filter [F:ZBPA]
  Close Local File [ZBPA]

End LRET
