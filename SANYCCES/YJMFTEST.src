#<AdxTL>@(#)0.0.0.0 $Revision$
  If !clalev([SOQ]) : Local File SORDERQ [SOQ] : Endif
  If !clalev([SOH]) : Local File SORDER [SOH] : Endif
  If !clalev([SOP])  Then : Local File SORDERP  [SOP]  : Endif
  If clalev([M:ORDK])=0 Local Mask ORDK [ORDK] Endif
  Call MAJ_SOQ (3,"PDV112619361",1000,1000,"UN",1.0,1.0) From STKPREPA
  Infbox(num$(GOK))
  Close Local File [SOQ]
  Close Local File [SOH]
  Close Local File [SOP]
  Close Local Mask [M:ORDK]
End
