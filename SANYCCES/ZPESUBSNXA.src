############################################################################
# 2026-00133 - Filtros en la generaciˇn de inventario
############################################################################

$ACTION

#If GUSER="SN070" Then : Infbox ACTION : Endif
Case ACTION
  When "AFTREASTO"          : Gosub AFTREASTO
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$AFTREASTO
# 2026-00133.ini
  If [M:SNU1]ZSOLOESTADOA = 2 Then
    If [F:STO]STA<>'A' Then
      GPE=1
    Endif
  Endif
  If [M:SNU1]ZSINNUMCONT = 2 Then
    If [F:STO]LPNNUM<>'' Then
      GPE=1
    Endif
  Endif
# 2026-00133.fin
Return

##############################################################
######################    ETIQUETAS    #######################
