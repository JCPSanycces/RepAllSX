##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Control en el campo Orden del bloque Accesorios A (pantalla ZACCB2B1) 28/04/2026 14:25:51 (SN070)
######################################################################################
Subprog C_ZITMORDACCA(VALEUR)
Variable Decimal VALEUR
  Call UNICITE(VALEUR,[M:ZCB1]ZITMORDACCA(0..[M:ZCB1]NBACCA-1)) From OBJDIV
End

######################################################################################
## Control en el campo Orden del bloque Accesorios B (pantalla ZACCB2B2) 28/04/2026 14:25:51 (SN070)
######################################################################################
Subprog C_ZITMORDACCB(VALEUR)
Variable Decimal VALEUR
  Call UNICITE(VALEUR,[M:ZCB2]ZITMORDACCB(0..[M:ZCB2]NBACCB-1)) From OBJDIV
End

######################################################################################
## Control en el campo Orden del bloque Relacionados (pantalla ZACCB2B3) 28/04/2026 14:25:51 (SN070)
######################################################################################
Subprog C_ZITMORDREL(VALEUR)
Variable Decimal VALEUR
  Call UNICITE(VALEUR,[M:ZCB3]ZITMORDREL(0..[M:ZCB3]NBREL-1)) From OBJDIV
End

######################################################################################
## Control en el campo Orden del bloque Venta mejorada (pantalla ZACCB2B4) 28/04/2026 14:25:51 (SN070)
