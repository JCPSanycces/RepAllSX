Return

##############################################################
# muestra la tabla de adjuntos
$SHOW_ADJUNTOS
Local Integer LCONAD

  Effzo [M:ZCB6]
  Raz [M:ZCB6]NBADJ
  If !clalev([F:ZAC6]) Then : Local File ZB2BITMACC06 [F:ZAC6] : Endif
  Filter [F:ZAC6] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC6]
    [M:ZCB6]ZITMCODADJ([L]LCONAD)   = [F:ZAC6]ZITMACCESORI
    [M:ZCB6]ZITMDESADJ([L]LCONAD)   = [F:ZAC6]ZITMACCDES
    [M:ZCB6]ZITMORDADJ([L]LCONAD)   = [F:ZAC6]ZITMACCESORO
    [L]LCONAD += 1
  Next
  Filter [F:ZAC6]
  [M:ZCB6]NBADJ = [L]LCONAD
  Close Local File [ZAC6]
Return

##############################################################
# rellena la tabla de accesorios A
$UPD_ACCESORIOSA
Local Integer LCONA

  If !clalev([F:ZAC1]) Then : Local File ZB2BITMACC01 [F:ZAC1] : Endif
  If !adxlog Then : Trbegin [F:ZAC1] : Endif
  Delete [F:ZAC1] Where ZITM = [M:ZCB0]ZITM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  For [L]LCONAA = 0 To [M:ZCB1]NBACCA - 1
    [F:ZAC1]ZITM          = [M:ZCB0]ZITM
    [F:ZAC1]ZITMACCESORI  = [M:ZCB1]ZITMCODACCA([L]LCONAA)
    [F:ZAC1]ZITMACCDES    = [M:ZCB1]ZITMDESACCA([L]LCONAA)
    [F:ZAC1]ZITMACCESORO  = [M:ZCB1]ZITMORDACCA([L]LCONAA)
    If !adxlog Then : Trbegin [F:ZAC1] : Endif
    Write [F:ZAC1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next

  Close Local File [ZAC1]
Return

##############################################################
# rellena la tabla de accesorios B
