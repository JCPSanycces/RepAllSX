#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZACCB2B
# Description : Específico Accesorios B2B
# Module      : Producción
# Version     : 1
# Created by  : Jose Luis Chiva
# Company     : Sanycces
# Created date: 27/04/2026
############################################################################

$ACTION

#If GUSER="SN070" Then : Infbox ACTION : Endif
Case ACTION
  When "LIENS"                : Gosub LIENS
  When "SEL_TABLE"            : Gosub SEL_TABLE
  When "VERF_TABLE"           : Gosub VERF_TABLE
  When "APRES_CRE"            : Gosub APRES_CRE
  When "APRES_MOD"            : Gosub APRES_MOD
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$LIENS
  Gosub SHOW_ACCESORIOSA
  Gosub SHOW_ACCESORIOSB
  Gosub SHOW_RELACIONADOS
  Gosub SHOW_VTAMEJORADA
  Gosub SHOW_VTACRUZADA
  Gosub SHOW_ADJUNTOS
  Affzo [M:ZCB0]
Return

##############################################################
$SEL_TABLE
  Case TABLE
      When Default            : Gosub SEL_ZSELACCB2B
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "ZSELACCB2B"         : Gosub VERF_ZSELACCB2B   # artículos (cabecera)
    When "ZSELACCABB"         : Gosub VERF_ZSELACCABB   # accesorios A
    When "ZSELACCBBB"         : Gosub VERF_ZSELACCBBB   # accesorios B
    When "ZSELRELABB"         : Gosub VERF_ZSELRELABB   # relacionados
    When "ZSELVMEJBB"         : Gosub VERF_ZSELVMEJBB   # venta mejorada
    When "ZSELVCRUBB"         : Gosub VERF_ZSELVCRUBB   # venta cruzada
    When "ZSELADJUBB"         : Gosub VERF_ZSELADJUBB   # adjuntos
  Endcase
Return

##############################################################
$APRES_CRE
  Gosub UPD_ACCESORIOSA
  Gosub UPD_ACCESORIOSB
  Gosub UPD_RELACIONADOS
  Gosub UPD_VTAMEJORADA
  Gosub UPD_VTACRUZADA
  Gosub UPD_ADJUNTOS
Return

##############################################################
$APRES_MOD
  Gosub UPD_ACCESORIOSA
  Gosub UPD_ACCESORIOSB
  Gosub UPD_RELACIONADOS
  Gosub UPD_VTAMEJORADA
  Gosub UPD_VTACRUZADA
  Gosub UPD_ADJUNTOS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# selección artículo en la cabecera
$SEL_ZSELACCB2B
  If !clalev([F:ZVA0]) Then : Local File ZVITMACB2B [F:ZVA0] : Endif
  Filter [F:ZVA0] Where ZITM <> [M:ZCB0]ZITM

  TIT(0) = "Vinculados"

  ORDRE = "ZITM"
  START = "ZITM"
  SENS  = 1
  DEFPAGE = 5

  SIZCOL = 600
  SIZLIG = 150

  Default File [F:ZVA0]

  CRITERE = "1=1"
  GSELFAC = 1
  NBCOL = 0
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]ZITM"       : TIT(NBCOL) = "Artículo"
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]ZITMDES"    : TIT(NBCOL) = "Descripción"
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]FAM_EST1"   : TIT(NBCOL) = "Fam. sup."
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]FAM_EST1_D" : TIT(NBCOL) = "Fam. sup. desc."
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]FAM_EST2"   : TIT(NBCOL) = "Familia"
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]FAM_EST2_D" : TIT(NBCOL) = "Familia desc."
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]SERIE"      : TIT(NBCOL) = "Serie"
  NBCOL +=1 : COL(NBCOL) = "[F:ZVA0]PADRE"      : TIT(NBCOL) = "Padre"
Return

##############################################################
# selección artículo en la cabecera
$VERF_ZSELACCB2B
  [M:ZCB0]ZITMDES     = [F:ZVA0]ZITMDES
  [M:ZCB0]FAM_EST1    = [F:ZVA0]FAM_EST1
  [M:ZCB0]FAM_EST1_D  = [F:ZVA0]FAM_EST1_D
  [M:ZCB0]FAM_EST2    = [F:ZVA0]FAM_EST2
  [M:ZCB0]FAM_EST2_D  = [F:ZVA0]FAM_EST2_D
  [M:ZCB0]SERIE       = [F:ZVA0]SERIE
  [M:ZCB0]PADRE       = [F:ZVA0]PADRE
  Affzo [M:ZCB0]5
Return

##############################################################
# selección accesorios A
$VERF_ZSELACCABB
  [M:ZCB1]ZITMCODACCA(nolign-1) = [F:ZVA0]ZITM
  [M:ZCB1]ZITMDESACCA(nolign-1) = [F:ZVA0]ZITMDES
  [M:ZCB1]ZITMORDACCA(nolign-1) = nolign
  Affzo [M:ZCB1]5
Return

##############################################################
# selección accesorios B
$VERF_ZSELACCBBB
  [M:ZCB2]ZITMCODACCB(nolign-1) = [F:ZVA0]ZITM
  [M:ZCB2]ZITMDESACCB(nolign-1) = [F:ZVA0]ZITMDES
  [M:ZCB2]ZITMORDACCB(nolign-1) = nolign
  Affzo [M:ZCB2]5
Return

##############################################################
# selección relacionados
$VERF_ZSELRELABB
  [M:ZCB3]ZITMCODREL(nolign-1)  = [F:ZVA0]ZITM
  [M:ZCB3]ZITMDESREL(nolign-1)  = [F:ZVA0]ZITMDES
  [M:ZCB3]ZITMORDREL(nolign-1)  = nolign
  Affzo [M:ZCB3]5
Return

##############################################################
# selección venta mejorada
$VERF_ZSELVMEJBB
  [M:ZCB4]ZITMCODVMEJ(nolign-1) = [F:ZVA0]ZITM
  [M:ZCB4]ZITMDESVMEJ(nolign-1) = [F:ZVA0]ZITMDES
  [M:ZCB4]ZITMORDVMEJ(nolign-1) = nolign
  Affzo [M:ZCB4]5
Return

##############################################################
# selección venta cruzada
$VERF_ZSELVCRUBB
  [M:ZCB5]ZITMCODVCRU(nolign-1) = [F:ZVA0]ZITM
  [M:ZCB5]ZITMDESVCRU(nolign-1) = [F:ZVA0]ZITMDES
  [M:ZCB5]ZITMORDVCRU(nolign-1) = nolign
  Affzo [M:ZCB5]5
Return

##############################################################
# selección adjuntos
$VERF_ZSELADJUBB
  [M:ZCB6]ZITMCODADJ(nolign-1)  = [F:ZVA0]ZITM
  [M:ZCB6]ZITMDESADJ(nolign-1)  = [F:ZVA0]ZITMDES
  [M:ZCB6]ZITMORDADJ(nolign-1)  = nolign
  Affzo [M:ZCB6]5
Return

##############################################################
# muestra la tabla de accesorios A
$SHOW_ACCESORIOSA
Local Integer LCONAA

  Effzo [M:ZCB1]
  Raz [M:ZCB1]NBACCA
  If !clalev([F:ZAC1]) Then : Local File ZB2BITMACC01 [F:ZAC1] : Endif
  Filter [F:ZAC1] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC1]
    [M:ZCB1]ZITMCODACCA([L]LCONAA)  = [F:ZAC1]ZITMACCESORI
    [M:ZCB1]ZITMDESACCA([L]LCONAA)  = [F:ZAC1]ZITMACCDES
    [M:ZCB1]ZITMORDACCA([L]LCONAA)  = [F:ZAC1]ZITMACCESORO
    [L]LCONAA += 1
  Next
  Filter [F:ZAC1]
  [M:ZCB1]NBACCA = [L]LCONAA
  Close Local File [ZAC1]
Return

##############################################################
# muestra la tabla de accesorios B
$SHOW_ACCESORIOSB
Local Integer LCONAB

  Effzo [M:ZCB2]
  Raz [M:ZCB2]NBACCB
  If !clalev([F:ZAC2]) Then : Local File ZB2BITMACC02 [F:ZAC2] : Endif
  Filter [F:ZAC2] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC2]
    [M:ZCB2]ZITMCODACCB([L]LCONAB)  = [F:ZAC2]ZITMACCESORI
    [M:ZCB2]ZITMDESACCB([L]LCONAB)  = [F:ZAC2]ZITMACCDES
    [M:ZCB2]ZITMORDACCB([L]LCONAB)  = [F:ZAC2]ZITMACCESORO
    [L]LCONAB += 1
  Next
  Filter [F:ZAC2]
  [M:ZCB2]NBACCB = [L]LCONAB
  Close Local File [ZAC2]
Return

##############################################################
# muestra la tabla de relacionados
$SHOW_RELACIONADOS
Local Integer LCONRE

  Effzo [M:ZCB3]
  Raz [M:ZCB3]NBREL
  If !clalev([F:ZAC3]) Then : Local File ZB2BITMACC03 [F:ZAC3] : Endif
  Filter [F:ZAC3] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC3]
    [M:ZCB3]ZITMCODREL([L]LCONRE)   = [F:ZAC3]ZITMACCESORI
    [M:ZCB3]ZITMDESREL([L]LCONRE)   = [F:ZAC3]ZITMACCDES
    [M:ZCB3]ZITMORDREL([L]LCONRE)   = [F:ZAC3]ZITMACCESORO
    [L]LCONRE += 1
  Next
  Filter [F:ZAC3]
  [M:ZCB3]NBREL = [L]LCONRE
  Close Local File [ZAC3]
Return

##############################################################
# muestra la tabla de venta mejorada
$SHOW_VTAMEJORADA
Local Integer LCONVM

  Effzo [M:ZCB4]
  Raz [M:ZCB4]NBVMEJ
  If !clalev([F:ZAC4]) Then : Local File ZB2BITMACC04 [F:ZAC4] : Endif
  Filter [F:ZAC4] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC4]
    [M:ZCB4]ZITMCODVMEJ([L]LCONVM)  = [F:ZAC4]ZITMACCESORI
    [M:ZCB4]ZITMDESVMEJ([L]LCONVM)  = [F:ZAC4]ZITMACCDES
    [M:ZCB4]ZITMORDVMEJ([L]LCONVM)  = [F:ZAC4]ZITMACCESORO
    [L]LCONVM += 1
  Next
  Filter [F:ZAC4]
  [M:ZCB4]NBVMEJ = [L]LCONVM
  Close Local File [ZAC4]
Return

##############################################################
# muestra la tabla de venta cruzada
$SHOW_VTACRUZADA
Local Integer LCONVC

  Effzo [M:ZCB5]
  Raz [M:ZCB5]NBVCRU
  If !clalev([F:ZAC5]) Then : Local File ZB2BITMACC05 [F:ZAC5] : Endif
  Filter [F:ZAC5] Where ZITM = [M:ZCB0]ZITM Order By ZITMACCESORO
  For [F:ZAC5]
    [M:ZCB5]ZITMCODVCRU([L]LCONVC)  = [F:ZAC5]ZITMACCESORI
    [M:ZCB5]ZITMDESVCRU([L]LCONVC)  = [F:ZAC5]ZITMACCDES
    [M:ZCB5]ZITMORDVCRU([L]LCONVC)  = [F:ZAC5]ZITMACCESORO
    [L]LCONVC += 1
  Next
  Filter [F:ZAC5]
