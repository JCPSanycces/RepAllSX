######################################################################################
## Después de modificar el campo 'Artículo' (pantalla ZACCB2B0) 29/04/2026 13:47:37 (SN070)
######################################################################################
Subprog AM_ZITM(VALEUR)
Variable Char    VALEUR()
  VALEUR = toupper(VALEUR)
  If !clalev([F:ZVA0]) Then : Local File ZVITMACB2B [F:ZVA0] : Endif
  Filter [F:ZVA0] Where ZITM = VALEUR
  Read [F:ZVA0] First
  If fstat Then
    Call ERREUR("El artículo lo existe") From GESECRAN
    mkstat=2
  Else
    [M:ZCB0]ZITMDES     = [F:ZVA0]ZITMDES
    [M:ZCB0]FAM_EST1    = [F:ZVA0]FAM_EST1
    [M:ZCB0]FAM_EST1_D  = [F:ZVA0]FAM_EST1_D
    [M:ZCB0]FAM_EST2    = [F:ZVA0]FAM_EST2
    [M:ZCB0]FAM_EST2_D  = [F:ZVA0]FAM_EST2_D
    [M:ZCB0]SERIE       = [F:ZVA0]SERIE
    [M:ZCB0]PADRE       = [F:ZVA0]PADRE
    Affzo [M:ZCB0]5
  Endif
  Close Local File [ZVA0]
End

######################################################################################
## Después de modificar el campo 'Accesorio' (pantalla ZACCB2B1) 29/04/2026 14:06:02 (SN070)
######################################################################################
Subprog AM_ZITMCODACCA(VALEUR)
Variable Char    VALEUR()
  VALEUR = toupper(VALEUR)
  If !clalev([F:ZVA0]) Then : Local File ZVITMACB2B [F:ZVA0] : Endif
  Filter [F:ZVA0] Where ZITM = VALEUR
  Read [F:ZVA0] First
  If fstat Then
