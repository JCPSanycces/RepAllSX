    [F:ZAC2]ZITMACCESORI  = [M:ZCB2]ZITMCODACCB([L]LCONAB)
    [F:ZAC2]ZITMACCDES    = [M:ZCB2]ZITMDESACCB([L]LCONAB)
    [F:ZAC2]ZITMACCESORO  = [M:ZCB2]ZITMORDACCB([L]LCONAB)
