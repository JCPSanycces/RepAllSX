#<AdxTL>@(#)0.0.0.0 $Revision$
  # Batch para enviar mail a clientes con aviso de que se ha enviado su mercancía

  Local Char LFECHA(12) : LFECHA = num$(date$) # Fecha de hoy
  Local Char LREQ(250)
  Local Integer PRES
  Local Char PMESS(250)

  If !clalev([YSTPD]) : Local File STOPRED [YSTPD] : Endif
  If !clalev([YSOH])  : Local File SORDER  [YSOH]  : Endif

  LREQ(0) = "SELECT DISTINCT VCRNUM_0 FROM " + nomap + ".YTRKENVIOS WHERE YNUMSOL_0 <> '' AND YFECHA_0 = '" + [L]LFECHA + "'"

  For (Char COD_PREPARACION) From "5" Sql LREQ As [YSQL]
    Filter [YSTPD] Where PRHNUM = COD_PREPARACION
    Read [YSTPD] First
    If !fstat
      Read [YSOH]SOH0 = [YSTPD]ORINUM
      If !fstat
        If [YSOH]YMAILTRACK = 2 and [YSOH]YMAIL <> '' Then
          Call ENVIO_TRACKING_CLIENTE(COD_PREPARACION, PRES, PMESS) From YINTTRANS
        Endif
      Endif
    Endif
  Next

  Close Local File [YSTPD]
  Close Local File [YSOH]
End
