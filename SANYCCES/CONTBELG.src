Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

End

###############################################################
##  Valeur par dÈfaut du no d'immatriculation sociale       ###
