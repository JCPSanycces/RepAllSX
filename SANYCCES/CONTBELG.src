##################################################################################################

##########################################################
##  ContrÙle du RIB (Bank account number )             ###
##########################################################
Subprog RIB(RIB,SPSTAT)
Variable Char    RIB()
Variable Integer SPSTAT

SPSTAT=0

If RIB="" : Goto F_RIB
Elsif len(RIB) <> 12 : SPSTAT=2 : Goto F_RIB
Endif

#MAE, bg 76605
#If  mod(val(left$(RIB,10)),97) = 0 & val(right$(RIB,11)) <> 97
If  mod(val(left$(RIB,10)),97) = 0
  If val(right$(RIB,11)) <> 97
    SPSTAT=1
  Endif
#Fin MAE
Elsif mod(val(left$(RIB,10)),97) <> val(right$(RIB,11))
 SPSTAT=1
Endif

$F_RIB
End


##########################################################
##  ContrÙle du SIRET (NIF number   )                  ###
##########################################################
Subprog SIRET(SIRET,SITE,SPSTAT)
Variable Char    SIRET()
Value    Char    SITE
Variable Integer SPSTAT

SPSTAT=0

$F_SIRET
End


##########################################################
##  ContrÙle Nr TVA (VAT identification )              ###
##########################################################
Subprog TVA(TVA,SPSTAT)
Variable Char    TVA()
Variable Integer SPSTAT

SPSTAT=0

If TVA="" End Endif
# 2026-00001.ini
#If mid$(TVA,3,1) <> "0"
#   SPSTAT=2 : Goto F_TVA
#Endif
If mid$(TVA,3,1) <> "0" and mid$(TVA,3,1) <> "1"
   SPSTAT=2 : Goto F_TVA
Else
  Goto F_TVA
Endif
# 2026-00001.fin

Local Char NUMTVA(15)
NUMTVA=right$(TVA,4)
If NUMTVA="" : End
Elsif len(NUMTVA) <> 9 : SPSTAT=2 : Goto F_TVA
Endif

If    mod(val(left$(NUMTVA,7)),97) = 0 & val(right$(NUMTVA,8)) <> 97
 SPSTAT=1
Elsif 97-mod(val(left$(NUMTVA,7)),97) <> val(right$(NUMTVA,8))
 SPSTAT=1
Endif

$F_TVA
End


######################################################
##  ContrÙle du no d'immatriculation sociale       ###
######################################################
Subprog SS(NOSS,ETR,SEX,DNAISS,DEPT,COMNNO,SPSTAT)
Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

End

######################################################
