## Etiqueta ańadida por el supervisor (pantalla YSOH5) 20/02/2026 11:47:39 (NUN21)
######################################################################################
#  @11@ - JMF - 20-02-2026 - Controlar cambio concertación - INI
Subprog AM_YCONCERTA(VALEUR)
  Variable Integer VALEUR

  If [M:SOH2]BPTNUM = "NA000008"
    If VALEUR = 1
      [M:SOH2]YSERVDEF = 'Y'
    Else
      [M:SOH2]YSERVDEF = 'A'
    Endif
    Affzo [M:SOH2]YSERVDEF
  Endif
End
