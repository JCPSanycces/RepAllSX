######################################################################################
## Después de modificar el campo 'Control de montaje' (pantalla SOH4) 29/06/2026 15:49:22 (SN070)
######################################################################################
# 2026-00053.ini
Subprog AM_ZCTRLMONTAJE(VALEUR)
Variable Integer VALEUR

Local Integer LCON

  For [L]LCON = nolign To [M:SOH4]NBLIG-1
    If [M:SOH4]LINTYP([L]LCON) = 8 Then
      Actzo [M:SOH4]ZCTRLMONTAJE([L]LCON)
      [M:SOH4]ZCTRLMONTAJE([L]LCON) = VALEUR
      Affzo [M:SOH4]ZCTRLMONTAJE([L]LCON)
    Else
      Break
    Endif
  Next

End

