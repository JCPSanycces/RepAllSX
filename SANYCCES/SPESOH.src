######################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()
# Traigo los valores de la pantalla Sanycces de la dirección de entrega
If !clalev([PP1]) : Local File BPDLVCUST [PP1] : Endif
If !clalev([PP2]) : Local File BPADDRESS [PP2] : Endif
If !clalev([YTRA]) : Local File YTRAN [YTRA] : Endif

Read [PP1]BPD0 = [M:SOH0]BPCORD;VALEUR
If fstat = 0
  [M:YSOH5]YCONCERTA = [PP1]YCONCERTA
  [M:YSOH5]YCONTACTO = [PP1]YCONTACTO
  [M:YSOH5]YOBSERVA  = [PP1]YOBSERVA
  Affzo [M:YSOH5]YCONCERTA
  Affzo [M:YSOH5]YCONTACTO
  Affzo [M:YSOH5]YOBSERVA
Endif

Read [PP2]BPA0 = 1;[M:SOH0]BPCORD;VALEUR
If fstat = 0
  [M:YSOH5]YTELEFONO = [PP2]TEL(0)
  [M:YSOH5]YMAIL     = [PP2]WEB(3)
  # Actualizamos los datos del transportista asociado a la nueva dirección.
  Read [YTRA]YTRAN0 = [M:SOH2]BPTNUM
  If !fstat
    [M:SOH2]YSERVDEF = [YTRA]YSERVDEF
    [M:SOH2]YTERMDEF = [YTRA]YTERMDEF
    Affzo [M:SOH2]YSERVDEF
    Affzo [M:SOH2]YTERMDEF
  Endif
Endif

Close Local File [PP1]
Close Local File [PP2]

#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - INI
  If !clalev([YTRA]): Local File YTRAN [YTRA]  : Endif
  If !clalev([YBPD]): Local File BPDLVCUST [YBPD]  : Endif
  If !clalev([YSER]) : Local File YTRASERV [YSER]  : Endif

  Read [YBPD]BPD0 = [M:SOH0]BPCORD;VALEUR
    If !fstat and [YBPD]YCONCERTA = 2 and [M:SOH2]BPTNUM = 'NA000008'
      Read [YSER]YTRAN0 = [M:SOH2]BPTNUM;'A'
        If !fstat
          [M:SOH2]YSERVDEF = [YSER]YCODSERV
          [M:SOH2]YTERMDEF = ''
          Affzo [M:SOH2]YSERVDEF,YTERMDEF
        Endif
    Endif
#  Call AM_BPTNUM([M:SOH2]BPTNUM)
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - FIN
End


######################################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()
# Lanzo STD
Call AM_BPCORD(VALEUR) From SUBSOH

# Traigo los valores de la pantalla Sanycces de la dirección de entrega
If !clalev([PP1]) : Local File BPDLVCUST [PP1] : Endif
If !clalev([PP2]) : Local File BPADDRESS [PP2] : Endif
If !clalev([YTRA]) : Local File YTRAN [YTRA] : Endif

Read [PP1]BPD0 = VALEUR;[M:SOH1]BPAADD
If fstat = 0
  [M:YSOH5]YCONCERTA = [PP1]YCONCERTA
  [M:YSOH5]YCONTACTO = [PP1]YCONTACTO
  [M:YSOH5]YOBSERVA  = [PP1]YOBSERVA
  Affzo [M:YSOH5]YCONCERTA
  Affzo [M:YSOH5]YCONTACTO
  Affzo [M:YSOH5]YOBSERVA
Endif


Read [PP2]BPA0 = 1;VALEUR;[M:SOH1]BPAADD
If fstat = 0
  [M:YSOH5]YTELEFONO = [PP2]TEL(0)
  [M:YSOH5]YMAIL     = [PP2]WEB(3)
  Affzo [M:YSOH5]YTELEFONO
  Affzo [M:YSOH5]YMAIL
  # Actualizamos los datos del transportista asociado a la nueva dirección.
  Read [YTRA]YTRAN0 = [M:SOH2]BPTNUM
  If !fstat
    [M:SOH2]YSERVDEF = [YTRA]YSERVDEF
    [M:SOH2]YTERMDEF = [YTRA]YTERMDEF
    Affzo [M:SOH2]YSERVDEF
    Affzo [M:SOH2]YTERMDEF
  Endif
Endif

Close Local File [PP1]
Close Local File [PP2]
Close Local File [YTRA]

#  @12@ - JMF - 23-02-2026 - Inicializar campo YMAILTRACK (envío mail tracking Sí/No) - INI
  If !clalev([YBPC]) : Local File BPCUSTOMER [YBPC] : Endif

  Read [YBPC]BPC0 = VALEUR
  If !fstat
    [M:YSOH5]YMAILTRACK = [YBPC]YMAILTRACK
    Affzo [M:YSOH5]YMAILTRACK
  Endif

  Close Local File [YBPC]
#  @12@ - JMF - 23-02-2026 - Inicializar campo YMAILTRACK (envío mail tracking Sí/No) - FIN

# Bloqueo STD
GPE = 1
# @01@ - JLP - INI
# COMPROBAMOS LA PLANTA DE VENTA DESPUES DE LA SELECCION DEL CLIENTE
# PARA QUE NO MODIFIQUE LA PLANTA EXP
  If [M:SOH0]SALFCY = '13'
    [M:SOH2]STOFCY = '13'
    Affzo [M:SOH2]STOFCY
  Else
    If [M:SOH0]SALFCY= '11'
      [M:SOH2]STOFCY = '11'
      Affzo [M:SOH2]STOFCY
    Endif
  Endif
# @01@ - JLP - FIN

#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - INI
  Call AM_BPTNUM([M:SOH2]BPTNUM)
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - FIN
End

