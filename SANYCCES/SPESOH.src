##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# 2026-00006
$UPD_KITS_REPORT


Local Integer LCONPRI,LCONSEC,LLINEAPADRE
Local Char    LITMPADRE(50),LDTOPADRE(50)

  If !clalev([F:ZSOQ0]) Then : Local File SORDERQ [F:ZSOQ0] : Endif
  If !clalev([F:ZSOP0]) Then : Local File SORDERP [F:ZSOP0] : Endif
  If !clalev([F:ZSOQ1]) Then : Local File SORDERQ [F:ZSOQ1] : Endif
  If !clalev([F:ZSOP1]) Then : Local File SORDERP [F:ZSOP1] : Endif

  For [L]LCONPRI=0 To [M:SOH4]NBLIG-1
    Raz LITMPADRE,LDTOPADRE
    If [M:SOH4]LINTYP([L]LCONPRI) = 9 Then
      If [M:SOH4]TSICOD1([L]LCONPRI) = '001' Then
        [L]LLINEAPADRE  = [M:SOH4]SOPLIN([L]LCONPRI)
        [L]LITMPADRE    = [M:SOH4]ITMREF([L]LCONPRI)
        If [M:SOH4]DISCRGVAL1([L]LCONPRI) <> 0 Then
          [L]LDTOPADRE    = num$([M:SOH4]DISCRGVAL1([L]LCONPRI))
        Endif
        If [M:SOH4]DISCRGVAL2([L]LCONPRI) <> 0 Then
          If [L]LDTOPADRE = '' Then
            [L]LDTOPADRE    = num$([M:SOH4]DISCRGVAL2([L]LCONPRI))
          Else
            [L]LDTOPADRE   += '+' + num$([M:SOH4]DISCRGVAL2([L]LCONPRI))
          Endif
        Endif
        If [M:SOH4]DISCRGVAL3([L]LCONPRI) <> 0 Then
          If [L]LDTOPADRE = '' Then
            [L]LDTOPADRE    = num$([M:SOH4]DISCRGVAL3([L]LCONPRI))
          Else
            [L]LDTOPADRE   += '+' + num$([M:SOH4]DISCRGVAL3([L]LCONPRI))
          Endif
        Endif
        Read [F:ZSOQ0]SOQ0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN([L]LCONPRI);[M:SOH4]SOPLIN([L]LCONPRI)
        Read [F:ZSOP0]SOP0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN([L]LCONPRI);[M:SOH4]SOPLIN([L]LCONPRI)
        [F:ZSOQ0]ZVAREST     = num$([L]LLINEAPADRE) + [L]LITMPADRE
        [F:ZSOQ0]ZVARESTDTO  = [L]LDTOPADRE
        [F:ZSOP0]ZVAREST     = num$([L]LLINEAPADRE) + [L]LITMPADRE
        [F:ZSOP0]ZVARESTDTO  = [L]LDTOPADRE
        If !adxlog Then : Trbegin [F:ZSOQ0] : Endif
        Rewrite [F:ZSOQ0]
        Rewrite [F:ZSOP0]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        [L]LCONPRI += 1
        While [M:SOH4]LINTYP([L]LCONPRI) = 8
          Read [F:ZSOQ1]SOQ0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN([L]LCONPRI);[M:SOH4]SOPLIN([L]LCONPRI)
          Read [F:ZSOP1]SOP0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN([L]LCONPRI);[M:SOH4]SOPLIN([L]LCONPRI)
          [F:ZSOQ1]ZVAREST     = num$([L]LLINEAPADRE) + [L]LITMPADRE
          [F:ZSOQ1]ZVARESTDTO  = [L]LDTOPADRE
          [F:ZSOP1]ZVAREST     = num$([L]LLINEAPADRE) + [L]LITMPADRE
          [F:ZSOP1]ZVARESTDTO  = [L]LDTOPADRE
          If !adxlog Then : Trbegin [F:ZSOQ1] : Endif
          Rewrite [F:ZSOQ1]
          Rewrite [F:ZSOP1]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
          [L]LCONPRI += 1
        Wend
      Endif
    Endif
  Next

  Close Local File [ZSOQ0],[ZSOP0],[ZSOQ1],[ZSOP1]

Return

##############################################################
# 2026-00066
# cuando se cambia la fecha de expedición de alguna línea que está en un contenedor
# también se tiene que cambiar a todas las demás líneas que están en el mismo contenedor
# y, además, se actualiza la fecha de entrega prevista
$UPD_FECHAEXP_CONT
Local Integer LNUMLINF,LNUMLINM,LNOL
Local Date    LFECHAMOD : [L]LFECHAMOD = VALEUR

  If !clalev([F:ZYTM0]) Then : Local File YITMTECNICO [F:ZYTM0] : Endif
  If !clalev([F:ZVAP0]) Then : Local File YAPPLPNSTO3 [F:ZVAP0] : Endif

  Filter [F:ZVAP0] Where ZSOHNUM = [M:SOH0]SOHNUM and LPNNUM = [M:SOH4]ZCONTPREP(nolign-1)
  Read [F:ZVAP0] First
  If !fstat Then
    Read [F:ZYTM0]YITT0 = [M:SOH4]ITMREF(nolign-1)
    If !fstat and [F:ZYTM0]PREPICKING = 2 Then
      Call MESSAGE("Se actualizará la fecha al resto de líneas que están en el mismo contenedor de prepicking.\Para separar fechas de expecición, contactar con el responsable") From GESECRAN
      For [F:ZVAP0]
        [L]LNUMLINF = [F:ZVAP0]ZLINEA1000
        [L]LNOL = nolign
        For [L]LNUMLINM = 0 To [M:SOH4]NBLIG - 1
          nolign = [L]LNUMLINM+1
          If [M:SOH4]SOPLIN([L]LNUMLINM) <> [M:SOH4]SOPLIN([L]LNOL-1) Then
            If [M:SOH4]SOPLIN([L]LNUMLINM)  = [L]LNUMLINF Then
              [M:SOH4]DSHIDAT([L]LNUMLINM)  = [L]LFECHAMOD
              Affzo [M:SOH4]DSHIDAT([L]LNUMLINM)
              Call AM_DSHIDAT([L]LFECHAMOD) From SUBSOH
              Break
            Endif
          Endif
        Next
        nolign = [L]LNOL
      Next
    Endif
  Endif
  Filter [F:ZVAP0]
  Close Local File [ZVAP0]
Return

##############################################################
# 2026-00066
# cuando se cambia la 'Ctd. pedida' o 'Ctd. a asignar', sólo permite que sea
# la que viene indicada en el contenedor. Además se cambia también la otra.
# cambia 'Ctd. pedida' -> actualiza 'Ctd. a asigna' y viceversa
$UPD_CANTIDAD_CONT
  If !clalev([F:ZYTM0]) Then : Local File YITMTECNICO [F:ZYTM0] : Endif
  Read [F:ZYTM0]YITT0 = [M:SOH4]ITMREF(nolign-1)
  If !fstat and [F:ZYTM0]PREPICKING = 2 Then
    Local Integer LNUMLINF
    Local Decimal LQTY : [L]LQTY = VALEUR
    If !clalev([F:ZVAP0]) Then : Local File YAPPLPNSTO3 [F:ZVAP0] : Endif
    Filter [F:ZVAP0] Where ZSOHNUM = [M:SOH0]SOHNUM and ITMREF = [M:SOH4]ITMREF(nolign-1)
    For [F:ZVAP0]
      [L]LNUMLINF = [F:ZVAP0]ZLINEA1000
      If [M:SOH4]SOPLIN(nolign-1) = [L]LNUMLINF Then
        If [L]LQTY > [F:ZVAP0]QTYCAJAS Then
          Call ERREUR("La cantidad no puede ser diferente a"-num$([F:ZVAP0]QTYCAJAS)-
&                     "unidades del contenedor de prepicking\Para reducir cantidad contactar con el responsable") From GESECRAN
          mkstat=2
        Else
          [M:SOH4]QTY(nolign-1) = [L]LQTY
          Affzo [M:SOH4]QTY(nolign-1)
          [M:SOH4]WALLQTY(nolign-1) = [L]LQTY
          Affzo [M:SOH4]WALLQTY(nolign-1)
          Call AM_QTY_SPE([L]LQTY)
          Call AP_QTY([L]LQTY) From SUBSOH
          Call AV_WALLQTY([L]LQTY) From SUBSOH
          Call AS_WALLQTY([L]LQTY) From SUBSOH
          Call AP_WALLQTY([L]LQTY) From SUBSOH
          Call AM_WALLQTY_SPE([L]LQTY)
          Break
        Endif
      Endif
    Next
    Filter [F:ZVAP0]
    Close Local File [ZVAP0]
  Endif
Return

# --------------------------------------------------------------------------------
# Affichage des champs suite ŕ la recherche tarif
# --------------------------------------------------------------------------------
$AFF_RECH_TAR
  Gosub AFF_RECH_TAR From SUBSOH1
Return

