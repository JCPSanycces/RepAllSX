#-- C.A. --> ZVE06 - EDI importacion de pedidos SERES  - JAP <10/2022>
#--
# NUN05.11052023 - Bloqueo de la línea de pedido si la línea está en un documento de prepración
#  @01@ -SCD - 14/06/2024 - Ajuste para resetear campos YAPPWIP y YUSUARIOWIP (PrePicking)
#  @02@ - JLP - 05-09-2024 - Ańadir mensaje al crear un pedido cuya forma de pago sea (E03)
#  @03@ - EQM - 10-09-2024 - Modificar cálculo fecha expedición, se suma nuevo campo art/planta
#  @04@ - EQM - 02-10-2024 - Ańadimos nombre usuario WIP
#  @05@ - JLP - 17-10-2024 - NO PERMITIR A USUARIOS CREAR ENTREGAS Y DOC PREPA DESDE PDV
#  @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada
#  @07@ - JLP - 10-06-2025 - Bloqueo en las lineas que son asociadas y Bloqueos asociados en PDV
#  @09@ - SCD - 23/04/2025 - Desarrollo CONFIGURADOR (YCONFIG - YSA08)
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista
#  @11@ - JMF - 20-02-2026 - Controlar cambio concertación
#  @12@ - JMF - 23-02-2026 - Inicializar campo YMAILTRACK (envío mail tracking Sí/No)
#  @13@ - JMF - 26-02-2026 - Si el pedido tiene marcada 'Concertación = Sí', los campos teléfono, contacto y mail son obligatorios
# 26002 - JCP.05032026 - Imprimir la descripción modificada para el artículo VTAMUESTRAS
# 2026-00006 - JCP.25032026.Mamparas - Reports Ventas - Variantes Estructuras
# 2026-00007 - JCP.27032026.Servicio de trasportista
# 2026-00010 - JCP.02042026.Control en pedidos con transportista Dachser o MRW
# ZB2B - JCP.05052026.Tienda online B2B
# XVT28052026 - EMISIÓN AUTOMÁTICA DE ANTICIPOS
# 2026-00039 - JCP.15062026.No arrastra bien los precios de componentes de EC cuando se han manipulado líneas
# 2026-00066 - JCP.06072026.Acotar ediciones de líneas de pedido que están en contenedor
#####################################################################################################

$ACTION

Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "INICRE"      : Gosub INICRE
  When "VERIF_CRE"   : Gosub VERIF_CRE   #  @01@ -SCD - 14/06/2024 - INI
  When "VERIF_MOD"   : Gosub VERIF_MOD
  When "CREATION"    : Gosub CREATION #--ZVE06
  When "LIENS_LIG"   : Gosub LIENS_LIG
  When "LIENS"       : Gosub LIENS #  @04@ - EQM
  When "AVANTBOUT"   : Gosub AVANTBOUT
  When "SETBOUT"     : Gosub SETBOUT #  @02@ - JLP - 05-09-2024 - Ańadir mensaje al crear un pedido cuya forma de pago sea (E03)
  When "FIN_PICK"    : Gosub FIN_PICK   #  @03@ - EQM
  When "APRES_MOD"   : Gosub APRES_MOD #  @09@ - SCD - 23/04/2025 - Desarrollo CONFIGURADOR (YCONFIG - YSA08)
  When "APRES_MODIF"   : Gosub APRES_MODIF #  @09@ - SCD - 23/04/2025 - Desarrollo CONFIGURADOR (YCONFIG - YSA08)
  When "APRES_CRE"   : Gosub APRES_CRE #  @09@ - SCD - 23/04/2025 - Desarrollo CONFIGURADOR (YCONFIG - YSA08)
  When "INIMOD"      : Gosub INIMOD #  @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada
  When "STYLE"       : Gosub STYLE  #  @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada
Endcase
Return

#####################################################################
$OUVRE
# 2026-00039.ini
Global Decimal GNETPRI,GREPCOE
# 2026-00039.fin
Return

#  @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada - INI
$STYLE
  For I = 0 To [M:SOH4]NBLIG-1
     Chgstl [M:SOH4]DSHIDAT(I) With ""
     Affzo [M:SOH4]DSHIDAT(I)
  Next

# @07@ - JLP - 16-04-2025 - Bloqueos asociados en PDV - INI
  Call BLOQ_CAMPOS From YBLOQPDV
# @07@ - JLP - 16-04-2025 - Bloqueos asociados en PDV - FIN

Return
#  @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada - FIN

#  @02@ - JLP - 05-09-2024 - Ańadir mensaje al crear un pedido cuya forma de pago sea (E03) - INI
$SETBOUT
Case BOUT
  When 'C'
    If ([M:SOH3]PTE = 'E03')
       Local Integer OKCAN : OKCAN = 2:# Ok
       Call AVERTIR("Pedido con forma de pago anticipada. Por favor desasigne y emita anticipo.", OKCAN) From GESECRAN
    Endif
  Endcase
#  @02@ - JLP - 05-09-2024 - Ańadir mensaje al crear un pedido cuya forma de pago sea (E03) - FIN

# @05@ - JLP - 17-10-2024 - NO PERMITIR A USUARIOS CREAR ENTREGAS Y DOC PREPA DESDE PDV - INI
Local Char YUSUARIOS(250)
YUSUARIOS = 'SN007,SN010,SN011,SN013,SN014,SN015,SN016,SN028,SN029,SN031,NUN28'
   If instr(0, YUSUARIOS ,GUSER) > 0
    Call VIREBOUT(CHAINE, "2") From GOBJET # BOTON ENTREGAS
    Call VIREBOUT(CHAINE, "6") From GOBJET # BOTON PREPARACIÓN
  Endif
#  @05@ - JLP - 17-10-2024 - No permitir a usuarios crear entregas y doc prepa desde PDV - FIN

# ZB2B.ini
  If dim(GZCTRLB2B) < 0 Then
    Grizo  [M:SOH0]ZSOHNUMB2B
    Chgfmt [M:SOH0]ZTEXTO1B2B   With "-K:10"
    Chgfmt [M:SOH4]ZATTFILEB2B  With "-K:10"
  Endif
# ZB2B.fin

Return


#######################################################
$AVANTBOUT
# No permito contramarcas si el estado del pedido no es autorizado
Case BOUT
  When "L,M"
    If ([M:SOH1]CDTSTA > 1)
      Errbox "El estado de crédito del pedido no permite la contramarca"
      GERR = 1
    Endif
  When "5"
    # 2026-00066.ini
    Local Integer L
      # Si la línea está en un contenedor...
      If !clalev([F:ZVAP0]) Then : Local File YAPPLPNSTO3 [F:ZVAP0] : Endif
      For L=0 To [M:SOH4]NBLIG-1
        Filter [F:ZVAP0] Where ZSOHNUM = [M:SOH0]SOHNUM and ZLINEA1000 = [M:SOH4]SOPLIN(L)
        Read [F:ZVAP0] First
        If !fstat Then
          # mostramos el error
          Call ERREUR("Hay alguna línea en un contenedor de prepicking.\No es posible saldar sin vaciar el contenedor.\Contactar con el responsable.") From GESECRAN
          # seńalizamos error al sistema
          OK    = 0     # indica estado de error/fallo
          GOK   = 0     # aborta la transacción si estuviera abierta
          GPE   = 1     # inhibe el estándar de la etiqueta AVANTBOUT actual
          FIN   = 1     # ordenamos finalizar el proceso
          GERR  = 1
          Break
        Endif
      Next
      Close Local File [ZVAP0]
    # 2026-00066.fin
Endcase
Return

# @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada - INI
$INIMOD
  Gosub CONTROL_FECHA_EXP
Return

$CONTROL_FECHA_EXP
  If !clalev([YSOHQ]): Local File SORDERQ [YSOHQ]  : Endif

    For I = 0 To [M:SOH4]NBLIG-1
       Read [YSOHQ]SOQ0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN(I);[M:SOH4]SOPLIN(I)
          If !fstat
             If (func SPEYBPICK.FECH_BLOQ([M:SOH0]SALFCY,[M:SOH4]ITMREF(I),[YSOHQ]SHIDAT)) = 1
                  If [M:SOH4]DSHIDAT(I) <> [YSOHQ]SHIDAT
                    Errbox "Fecha de expedición bloqueada para "-(func GET_FAM_DES([M:SOH4]ITMREF(I)))-", póngase con el responsable de esta sección de prepicking"
                    Chgstl [M:SOH4]DSHIDAT(I) With "AERROR"
                    GOK = 0
                  Endif
             Else
                  If (func SPEYBPICK.FECH_BLOQ([M:SOH0]SALFCY,[M:SOH4]ITMREF(I),[M:SOH4]DSHIDAT(I))) = 1
                    Errbox "Fecha de expedición bloqueada para "-(func GET_FAM_DES([M:SOH4]ITMREF(I)))-", póngase con el responsable de esta sección de prepicking"
                    Chgstl [M:SOH4]DSHIDAT(I) With "AERROR"
                    GOK = 0
                  Endif
             Endif
          Elsif (func SPEYBPICK.FECH_BLOQ([M:SOH0]SALFCY,[M:SOH4]ITMREF(I),[M:SOH4]DSHIDAT(I))) = 1
                Errbox "Fecha de expedición bloqueada para "-(func GET_FAM_DES([M:SOH4]ITMREF(I)))-", póngase con el responsable de esta sección de prepicking"
                Chgstl [M:SOH4]DSHIDAT(I) With "AERROR"
                GOK = 0
          Endif
    Next
Return
# @06@ - JLP - 24-10-2024 - Bloqueo de modificación de fechas de expedicion la familia la tiene bloqueada - FIN


$VERIF_CRE
  #  @01@ -SCD - 14/06/2024 - INI
  Gosub ACTION From SUBSOH
  [M:YSOH5]YAPPWIP = 1
  [M:YSOH5]YUSUARIOWIP = ''
  Affzo [M:YSOH5]YAPPWIP, YUSUARIOWIP
  GPE = 1
  #  @01@ -SCD - 14/06/2024 - FIN

# 2026-00007.ini
  If GNAVIG(GPILNAV-1) = "GESSQH" and [M:SOH2]BPTNUM <> "" Then
    If !clalev([F:YTRAN0]) Then : Local File YTRAN [F:YTRAN0] : Endif
    Read [F:YTRAN0]YTRAN0 = [M:SOH2]BPTNUM
    If !fstat Then
      [M:SOH2]YSERVDEF  = [F:YTRAN0]YSERVDEF
      [M:SOH2]YTERMDEF  = [F:YTRAN0]YTERMDEF
      Affzo [M:SOH2]YSERVDEF
      Affzo [M:SOH2]YTERMDEF
    Endif
    Close Local File [YTRAN0]
  Endif
# 2026-00007.fin

# 2026-00010.ini
  If [M:SOH2]BPTNUM = "NA000008" Then
    If [M:SOH2]YSERVDEF = "" and [M:SOH2]YTERMDEF = "" Then
      OK=0
      Call ERREUR("Para el transportista NA000008 se deben informar los campos 'Servicio' y 'Término'") From GESECRAN
      Return
    Endif
  Endif
  If [M:SOH2]BPTNUM = "NA002854" Then
    If [M:SOH2]YSERVDEF = "" Then
      Call ERREUR("Para el transportista NA002854 se debe informar el campo 'Servicio'") From GESECRAN
      OK=0
      Return
    Endif
  Endif
# 2026-00010.fin
Return

#######################################################
$VERIF_MOD
# 2026-00010.ini
  If [M:SOH2]BPTNUM = "NA000008" Then
    If [M:SOH2]YSERVDEF = "" or [M:SOH2]YTERMDEF = "" Then
      OK=0
      Call ERREUR("Para el transportista NA000008 se deben informar los campos 'Servicio' y 'Término'") From GESECRAN
      zonsui = "[M:SOH2]YSERVDEF"
      Return
    Endif
  Endif
  If [M:SOH2]BPTNUM = "NA002854" Then
    If [M:SOH2]YSERVDEF = "" Then
      Call ERREUR("Para el transportista NA002854 se debe informar el campo 'Servicio'") From GESECRAN
      zonsui = "[M:SOH2]YSERVDEF"
      OK=0
      Return
    Endif
  Endif
# 2026-00010.fin
Return

#######################################################
#  @09@ - SCD - 23/04/2025 - INI
$APRES_MOD
  Gosub RECALCULA_TOTALES

# 2026-00006.ini
  Gosub UPD_KITS_REPORT
