######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SOH2) 12/02/2026 08:30:03 (NUN28)
######################################################################################
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - INI
Subprog AM_BPTNUM(VALEUR)
Variable Char    VALEUR()

  If !clalev([YTRA]): Local File YTRAN [YTRA]  : Endif
  If !clalev([YBPD]): Local File BPDLVCUST [YBPD]  : Endif
  If !clalev([YSER]) : Local File YTRASERV [YSER]  : Endif

  Read [YBPD]BPD0 = [M:SOH0]BPCORD;[M:SOH1]BPAADD
  If !fstat and [YBPD]YCONCERTA = 2 and VALEUR = 'NA000008'
    [M:SOH2]YSERVDEF = 'A'
    [M:SOH2]YTERMDEF = '031'
    Affzo [M:SOH2]YSERVDEF,YTERMDEF
  Else
    Read [YTRA]YTRAN0 = VALEUR
    If !fstat
      [M:SOH2]YSERVDEF = [YTRA]YSERVDEF
      [M:SOH2]YTERMDEF = [YTRA]YTERMDEF
      Affzo [M:SOH2]YSERVDEF,YTERMDEF
    Else
      [M:SOH2]YSERVDEF = ''
      [M:SOH2]YTERMDEF = ''
      Affzo [M:SOH2]YSERVDEF,YTERMDEF
    Endif
  Endif
End
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - FIN
######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SOH2) 13/02/2026 09:06:41 (NUN28)
######################################################################################
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - INI
Subprog C_YSERVDEF(VALEUR)
Variable Char    VALEUR()
  If !clalev([YSER]) : Local File YTRASERV [YSER]  : Endif
  Read [YSER]YTRAN0 = [M:SOH2]BPTNUM;VALEUR
    If fstat and VALEUR <> ''
      Errbox "Este servicio no existe para este transportista: "-[M:SOH2]BPTNUM
      mkstat = 2
    Endif
End
######################################################################################
Subprog C_YTERMDEF(VALEUR)
Variable Char    VALEUR()
  If !clalev([YTER]) : Local File YTERMSERV [YTER] : Endif
  Read [YTER]YTERSV0 = [M:SOH2]BPTNUM;VALEUR
    If fstat and VALEUR <> ''
      Errbox "Este termino no existe para este transportista: "-[M:SOH2]BPTNUM
      mkstat = 2
    Endif
End
#  @10@ - JLP - 10-02-2026 - Ańadir el campo servicio y termino del transportista - FIN
