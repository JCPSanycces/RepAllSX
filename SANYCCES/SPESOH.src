## Etiqueta ańadida por el supervisor (pantalla YSOH5) 26/02/2026 15:13:39 (NUN21)
######################################################################################
Subprog C_YCONTACTO(VALEUR)
  Variable Char    VALEUR()

  If [M:YSOH5]YCONCERTA = 2 and VALEUR = ''
    Infbox ("Para pedidos con Concertación, es obligatorio indicar el Contacto")
    mkstat = 2
  Endif
End

Subprog C_YTELEFONO(VALEUR)
  Variable Char    VALEUR()

  If [M:YSOH5]YCONCERTA = 2 and VALEUR = ''
    Infbox ("Para pedidos con Concertación, es obligatorio indicar el Teléfono")
    mkstat = 2
  Endif
End

Subprog C_YMAIL(VALEUR)
  Variable Char    VALEUR()
  If [M:YSOH5]YCONCERTA = 2 and VALEUR = ''
    Infbox ("Para pedidos con Concertación, es obligatorio indicar el Mail")
    mkstat = 2
  Endif
End
