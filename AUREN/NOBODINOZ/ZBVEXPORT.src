&         'pcb', 'phantom_item', 'fixed_qty', 'update_ts'
&         Using [CSV]

      FLAG = 1
    Endif

    Wrseq [F:ZBOM]WAREHOUSE_CO, [F:ZBOM]PARENT_PART,  [F:ZBOM]PART_CODE,    [F:ZBOM]QTY,          [F:ZBOM]PART_UNIT_ME,
&         [F:ZBOM]PCB,          [F:ZBOM]PHANTOM_ITEM, [F:ZBOM]FIXED_QTY,    [F:ZBOM]UPDATE_TS
