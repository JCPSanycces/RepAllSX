#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## FUNCIÓN EXPORTACIÓN FICHEROS PARA BEVOLTA                                                            ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 08/06/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
##########################################################################################################
## Lista ficheros a exportar:     Vista para exportación:                                               ##
## - Inventories                  ZBVINVENTORI        [ZINV]                                            ##
## - Orders                       ZBVORDERS           [ZORD]                                            ##
## - Part_Types                   ZBVPARTTYPES        [ZPTY]                                            ##
## - Parts                        ZBVPARTS            [ZPAR]                                            ##
## - Single_level_boms            ZBVBOMS             [ZBOM]                                            ##
## - sku_locations                ZBVSKULOCATI        [ZLOC]                                            ##
## - Suppliers                    ZBVSUPPLIERS        [ZSUP]                                            ##
## - Transactions                 ZBVTRANSACTI        [ZTRA]                                            ##
## - WorkShops                    ZBVWORKSHOPS        [ZWOR]                                            ##
##########################################################################################################
#06.371.615 AMG.22/07/2022 SKU MAL ENVIADOS
#################################################


$ACTION
Case ACTION
  When "INIT"     : Gosub INIT
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(250)
  Local Char LPATH(250)
  Local Char LPATHP(250)
  Local Integer STAT
  Local Integer FLAG

  Local Char FECHOREJEC(15)
  Local Char NOMFIC_ZINV(250)
  Local Char NOMFIC_ZORD(250)
  Local Char NOMFIC_ZPTY(250)
  Local Char NOMFIC_ZPAR(250)
  Local Char NOMFIC_ZBOM(250)
  Local Char NOMFIC_ZLOC(250)
  Local Char NOMFIC_ZSUP(250)
  Local Char NOMFIC_ZTRA(250)
  Local Char NOMFIC_ZWOR(250)

  Local Integer     TIPEXP          #Tipo exportación completa/Parcial -> 1=Parcial, 2=Completa
  Local Char        ULTEXP(30)      #Fecha última exportación anterior fichero
  Local Char        NEWULTEXP(30)   #Nueva fecha exportación

  adxifs=";"
  adxirs=chr$(10)
  adxium=0

  #Check if local directory exists and creates it if not
  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  LPATH=DIRAPL+"\FTP\BEVOLTA\EXPORT"
  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

  LPATHP=DIRAPL+"\FTP\BEVOLTA\EXPORT\PROCESADOS"

  NEWULTEXP=    format$("YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", datetime$)

  #Definicion nombres de fichero a generar
  FECHOREJEC=   format$("YYYYMMDD[_]hhmmss",date$)
  NOMFIC_ZINV=  "INVENTORIES_"          + FECHOREJEC
  NOMFIC_ZORD=  "ORDERS_"               + FECHOREJEC
  NOMFIC_ZPTY=  "PART_TYPES_"           + FECHOREJEC
  NOMFIC_ZPAR=  "PARTS_"                + FECHOREJEC
  NOMFIC_ZBOM=  "SINGLE_LEVEL_BOMS_"    + FECHOREJEC
  NOMFIC_ZLOC=  "SKU_LOCATIONS_"        + FECHOREJEC
  NOMFIC_ZSUP=  "SUPPLIERS_"            + FECHOREJEC
  NOMFIC_ZTRA=  "TRANSACTIONS_"         + FECHOREJEC
  NOMFIC_ZWOR=  "WORKSHOPS_"            + FECHOREJEC

  ## Apertura vistas de los datos a exportar
  If clalev([F:ZINV])<=0  :   Local File ZBVINVENTORI [ZINV]  :   Endif
  If clalev([F:ZORD])<=0  :   Local File ZBVORDERS    [ZORD]  :   Endif
  If clalev([F:ZPTY])<=0  :   Local File ZBVPARTTYPES [ZPTY]  :   Endif
  If clalev([F:ZPAR])<=0  :   Local File ZBVPARTS     [ZPAR]  :   Endif
  If clalev([F:ZBOM])<=0  :   Local File ZBVBOMS      [ZBOM]  :   Endif
  If clalev([F:ZLOC])<=0  :   Local File ZBVSKULOCATI [ZLOC]  :   Endif
  If clalev([F:ZSUP])<=0  :   Local File ZBVSUPPLIERS [ZSUP]  :   Endif
  If clalev([F:ZTRA])<=0  :   Local File ZBVTRANSACTI [ZTRA]  :   Endif
  If clalev([F:ZWOR])<=0  :   Local File ZBVWORKSHOPS [ZWOR]  :   Endif

Return

$EXEC

  ## Generar ficheros en folder local
  Gosub INVENTORIES
  Gosub ORDERS
  Gosub PART_TYPES
  Gosub PARTS
  Gosub SINGLE_LEVEL_BOMS
  Gosub SKU_LOCATIONS
  Gosub SUPPLIERS
  Gosub TRANSACTIONS
  Gosub WORKSHOPS

# Subida de ficheros al FTP y mueve fiheros subidos a directorio de copia
  Call ECR_TRACE("Subiendo ficheros", 0) From GESECRAN
  STAT = 0
  Call FTPPUTMOV("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","Export_SAGEX3",LPATH,LPATHP,STAT) From ZAURFTP

  If STAT >= 0
    Call ECR_TRACE("Ficheros subidos: " +num$(STAT), 0) From GESECRAN
  Else
    Call ECR_TRACE("Error en la subida de ficheros. Error: " +num$(STAT), 1) From GESECRAN
  Endif

#Proceso terminado
  Call ECR_TRACE("Proceso terminado " + format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$), 0) From GESECRAN

Return

$TERMINE

Return

###########################################
##             INVENTORIES               ##
###########################################
$INVENTORIES

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando fichero INVENTORIES...",0) From GESECRAN

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  Call TIPO_EXPORTACION('INVENTORIES', TIPEXP, ULTEXP)

  FLAG = 0

  ## Lectura datos y escritura del fichero
  If TIPEXP=1
    Filter [ZINV] Where UPDATE_TS >= ULTEXP
  Endif
  For [ZINV]

    If FLAG=0 Then

      Openo filpath(LPATH+"\",NOMFIC_ZINV,"csv"), 0 Using [CSV]

      #Inserción registro títulos fichero
      Wrseq 'part_code', 'warehouse_code', 'delivery_workshop_code', 'supplier_code', 'workshop_code',
&         'acq_code', 'lead_time', 'min_order_qty', 'order_multiple', 'inventory_unit_price',
&         'sales_unit_price', 'planner', 'buyer', 'tags', 'update_ts'
&         Using [CSV]

      FLAG = 1
    Endif


    Wrseq [F:ZINV]PART_CODE,    [F:ZINV]WAREHOUSE_CO, [F:ZINV]DELIVERY_WOR, [F:ZINV]SUPPLIER_COD, [F:ZINV]WORKSHOP_COD,
&         [F:ZINV]ACQ_CODE,     [F:ZINV]LEAD_TIME,    [F:ZINV]MIN_ORDER_QT, [F:ZINV]ORDER_MULTIP, [F:ZINV]INVENTORY_UN,
&         [F:ZINV]SALES_UNIT_P, [F:ZINV]PLANNER,      [F:ZINV]BUYER,        [F:ZINV]TAGS,         [F:ZINV]UPDATE_TS
&         Using [CSV]

  Next

  ## Cierre fichero
  Openo Using [CSV]

  Call UPD_EXPORTACION('INVENTORIES', NEWULTEXP)
  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZINV + ".csv generado",0) From GESECRAN

Return

###########################################
##                ORDERS                 ##
###########################################
$ORDERS

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando fichero ORDERS...",0) From GESECRAN

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
