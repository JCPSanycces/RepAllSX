      #Inserción registro títulos fichero
      Wrseq 'code', 'description', 'unit_measure', 'part_type_code', 'tags', 'update_ts'
&         Using [CSV]

      FLAG = 1
    Endif

#06.371.615.INI
#    Wrseq [F:ZPAR]CODE,         [F:ZPAR]DESCRIPTION,  [F:ZPAR]UNIT_MEASURE, [F:ZPAR]PART_TYPE_CO, [F:ZPAR]TAGS,
#&         [F:ZPAR]UPDATE_TS
#&         Using [CSV]
    Wrseq [F:ZPAR]CODE,         [F:ZPAR]DESCRIPTION,  [F:ZPAR]UNIT_MEASURE, [F:ZPAR]PART_TYPE_CO, [F:ZPAR]TAGS +[F:ZPAR]TAGS1,
&         [F:ZPAR]UPDATE_TS
&         Using [CSV]
#06.371.615.FIN


  Next

  ## Cierre fichero
  Openo Using [CSV]

  Call UPD_EXPORTACION('PARTS', NEWULTEXP)
  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZPAR + ".csv generado",0) From GESECRAN

Return

###########################################
