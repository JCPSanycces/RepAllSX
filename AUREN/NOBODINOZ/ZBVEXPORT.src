&         [F:ZTRA]ON_HAND_AFTE, [F:ZTRA]INVENTORY_UN, [F:ZTRA]ORDER_TYPE,   [F:ZTRA]ORDER_NUM,      [F:ZTRA]ORDER_LINE,
