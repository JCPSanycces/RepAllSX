  Endif
  For [ZORD]

    If FLAG=0 Then

      Openo filpath(LPATH+"\",NOMFIC_ZORD,"csv"), 0 Using [CSV]

      #Inserción registro títulos fichero
      Wrseq 'part_code', 'warehouse_code', 'delivery_workshop_code', 'supplier_code', 'workshop_code',
&         'due_date', 'qty', 'status', 'priority', 'order_type',
&         'order_num', 'order_line', 'volta_order_num', 'volta_order_line', 'vendor_code', 'update_ts'
&         Using [CSV]

      FLAG = 1
    Endif

    Wrseq [F:ZORD]PART_CODE,    [F:ZORD]WAREHOUSE_CO, [F:ZORD]DELIVERY_WOR, [F:ZORD]SUPPLIER_COD, [F:ZORD]WORKSHOP_COD,
&         [F:ZORD]DUE_DATE,     [F:ZORD]QTY,          [F:ZORD]STAT,         [F:ZORD]PRIORITY,     [F:ZORD]ORDER_TYPE,
&         [F:ZORD]ORDER_NUM,    [F:ZORD]ORDER_LINE,   [F:ZORD]VOLTA_NUM,    [F:ZORD]VOLTA_LINE,   [F:ZORD]VENDOR_CODE,
&         [F:ZORD]UPDATE_TS
&         Using [CSV]

  Next

  ## Cierre fichero
  Openo Using [CSV]

  Call UPD_EXPORTACION('ORDERS', NEWULTEXP)
  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZORD + ".csv generado",0) From GESECRAN

Return

###########################################
##            PART_TYPES                 ##
###########################################
$PART_TYPES

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando fichero PART_TYPES...",0) From GESECRAN

