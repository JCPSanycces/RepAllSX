#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################################################
## FUNCIÓN EXPORTACIÓN FICHEROS COCKPIT_SALES BEVOLTA                                                   ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 14/07/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
##########################################################################################################
## Lista ficheros a exportar:     Vista para exportación:                                               ##
## - Inventories                  ZCOCKPITSALE        [ZCPS]                                                 ##
##########################################################################################################
#6.188.260 - CLIENTS AND PRODUCTS COKPIT


$ACTION
Case ACTION
  When "INIT"     : Gosub INIT
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(250)
  Local Char LPATH(250)
  Local Char LPATHP(250)
  Local Integer STAT
  Local Integer FLAG

  Local Char FECHOREJEC(15)
  Local Char NOMFIC_ZSAL(250)
  #6.188.260>
  Local Char NOMFIC_ZCP_PROD(250)
  Local Char NOMFIC_ZCP_CLI(250)
  #6.188.260<

  Local Integer     TIPEXP          #Tipo exportación completa/Parcial -> 1=Parcial, 2=Completa
  Local Char        ULTEXP(30)      #Fecha última exportación anterior fichero
  Local Char        NEWULTEXP(30)   #Nueva fecha exportación

  adxifs=";"
  adxirs=chr$(10)
  adxium=0

  #Check if local directory exists and creates it if not
  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  LPATH=DIRAPL+"\FTP\BEVOLTA\COCKPIT"
  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

  LPATHP=DIRAPL+"\FTP\BEVOLTA\COCKPIT\PROCESADOS"

  NEWULTEXP=    format$("YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", datetime$)

  #Definicion nombres de fichero a generar
  FECHOREJEC=   format$("YYYYMMDD[_]hhmmss",date$)
  NOMFIC_ZSAL=  "COCKPIT_SALES_"        + FECHOREJEC
  #6.188.260>
  NOMFIC_ZCP_PROD =  "PRODUCTS_COCKPIT_SALES_"        + FECHOREJEC
  NOMFIC_ZCP_CLI  =  "CLIENTS_COCKPIT_SALES_"         + FECHOREJEC
  #6.188.260<

  ## Apertura vistas de los datos a exportar
  If clalev([F:ZCPS])<=0  :   Local File ZCOCKPITSALE [F:ZCPS]  :   Endif
  #6.188.260>
  If clalev([F:ZCP])<=0  :   Local File ZCOCKPITPROD [F:ZCP]  :   Endif
  If clalev([F:ZCC])<=0  :   Local File ZCOCKPITCLI  [F:ZCC]  :   Endif
  #6.188.260<
Return

$EXEC

  ## Generar ficheros en folder local
  Gosub COCKPIT_SALES
  #6.188.260>
  Gosub COCKPIT_PRODUCTS
  Gosub COCKPIT_CLI
  #6.188.260<

# Subida de ficheros al FTP y mueve fiheros subidos a directorio de copia
  Call ECR_TRACE("Subiendo ficheros", 0) From GESECRAN
  STAT = 0
  Call FTPPUTMOV("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","Export_SAGEX3",LPATH,LPATHP,STAT) From ZAURFTP

  If STAT >= 0
    Call ECR_TRACE("Ficheros subidos: " +num$(STAT), 0) From GESECRAN
  Else
    Call ECR_TRACE("Error en la subida de ficheros. Error: " +num$(STAT), 1) From GESECRAN
  Endif

#Proceso terminado
  Call ECR_TRACE("Proceso terminado " + format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$), 0) From GESECRAN

Return

$TERMINE

Return

###########################################
##             COCKPIT_SALES             ##
###########################################
$COCKPIT_SALES

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando fichero COCKPIT_SALES...",0) From GESECRAN

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  Call TIPO_EXPORTACION('COCKPIT', TIPEXP, ULTEXP)

  FLAG = 0

  ## Lectura datos y escritura del fichero
  If TIPEXP=1
    Filter [ZCPS] Where ZCREATED >= ULTEXP
  Endif
  For [ZCPS]

    If FLAG=0 Then

      Openo filpath(LPATH+"\",NOMFIC_ZSAL,"csv"), 0 Using [CSV]

      #Inserción registro títulos fichero
      Wrseq 'transaction_ts', 'year_transaction_ts', 'month_transaction_ts', 'day_transaction_ts', 'part_code', 'Descrip','family_1','family_2','family_3','product','pattern','size','color',
& 'collection','unit_cost_std','unit_cost_std','wholsale_price_std','customer_name','customer_code','warehouse_code','transaction_type','sales_qty','order_type','order_num','order_line',
& 'transaction_ref_interne','transaction_ref_externe','country','sales_amount','budget','sales_margin','sales_rep','corner','origin','secteur','company_type','client_budget','inactive_account',
& 'potential','tariff_classification','sku_lifecycle','custom_text_1','custom_text_2','custom_text_3','custom_nb_1','custom_nb_2','custom_nb_3','custom_ts_1','custom_ts_2','custom_ts_3','created_at'
& Using [CSV]

      FLAG = 1
    Endif

    Wrseq [ZCPS]ZTRANSACTION, [ZCPS]ZYEAR, [ZCPS]ZMONTH, [ZCPS]ZDAY, [ZCPS]ZPARTCODE,[ZCPS]ZDESCRIPT,[ZCPS]ZFAM1,[ZCPS]ZFAM2,[ZCPS]ZFAM3,[ZCPS]ZPRODUCT,[ZCPS]ZPATTERN, [ZCPS]ZSIZE, [ZCPS]ZCOLOR, [ZCPS
& ]ZCOLLECTION , [ZCPS]ZUNITCOST,[ZCPS]ZREALPRICE, [ZCPS]ZWHOLSALE, [ZCPS]ZCUSTNAME, [ZCPS]ZCUSTCODE , [ZCPS]ZWAREHOUSE,[ZCPS]ZTRANSTYPE, [ZCPS]ZSALESQTY, [ZCPS]ZORDERTYPE, [ZCPS]ZORDERNUM , [ZCPS]
& ZORDERLINE,[ZCPS]ZTRANSREFINT, [ZCPS]ZTRANSREFEXT, [ZCPS]ZCOUNTRY, [ZCPS]ZSALESAMOUNT , [ZCPS]ZBUDGET,[ZCPS]ZSALESMARGIN, [ZCPS]ZSALESREP, [ZCPS]ZCORNER, [ZCPS]ZORIGEN , [ZCPS]ZSECTOR,[ZCPS]ZCOMPANY
& ,
& [ZCPS]ZCLIENTBUD, [ZCPS]ZINACTIVEACC, [ZCPS]ZPOTENTIAL , [ZCPS]ZTARIFFCLASS,[ZCPS]ZSKULIFE, [ZCPS]ZCUSTOMTEXT1, [ZCPS]ZCUSTOMTEXT2, [ZCPS]ZCUSTOMTEXT3 , [ZCPS]ZCUSTOMNB1,[ZCPS]ZCUSTOMNB2, [ZCPS]
& ZCUSTOMNB3, [ZCPS]ZCUSTOMTS1, [ZCPS]ZCUSTOMTS2 , [ZCPS]ZCUSTOMTS3, [ZCPS]ZCREATED Using [CSV]

  Next

  ## Cierre fichero
  Openo Using [CSV]

  Call UPD_EXPORTACION('COCKPIT', NEWULTEXP)
  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZSAL + ".csv generado",0) From GESECRAN

Return
#6.188.260>
