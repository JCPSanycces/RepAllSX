& ]CUSREFDES , [ZCP]CFGFLDALP1,[ZCP]CFGFLDALP2, [ZCP]CFGFDES, [ZCP]EANCOD, [ZCP]ZCODGS1 , [ZCP]TSICOD1,[ZCP]TSICOD1DES, [ZCP]TSICOD2, [ZCP]TSICOD2DES, [ZCP]TSICOD3 , [ZCP]
& TSICOD3DES,[ZCP]TSICOD4, [ZCP]TSICOD4DES, [ZCP]TSICOD5, [ZCP]TSICOD5DES , [ZCP]ZOUTSHE,[ZCP]ZOUTSHEDES, [ZCP]ZLINING, [ZCP]ZLININGDES, [ZCP]ZFILLING , [ZCP]ZFILLINGDES,[ZCP]ZACCESS
