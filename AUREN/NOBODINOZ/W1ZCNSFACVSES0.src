#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
# Gestión de la máscara ZCNSFACVSES0

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [20/01/2023]
A_HEURE = "10:02:59"
A_USER  = "ADMIN"
A_STAMP = "20230120100259"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ZCNSFACVSES0 [ZCFVE0]
Gosub HORODAT
Local Inpbox "ZCNSFACVSES0" From GFONCTION At A_STAMP With A_WINDPREV Mask [ZCFVE0] As [SIM_]
Grizo [ZCFVE0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ZCFVE0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=5
Return

$ON_ZINIFACDAT
Onevent INIT_AREA Call D_ZINIFACDAT(zc) From W1ZCNSFACVSES0
Onevent CONTROL Call C_ZINIFACDAT(zc) From W1ZCNSFACVSES0
Onevent BEFORE_AREA Gosub AV_ZINIFACDAT From W1ZCNSFACVSES0
Return

$AV_ZINIFACDAT
Chgfmt [M]ZINIFACDAT(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog D_ZINIFACDAT(VALEUR)
Variable Date    VALEUR
If varinit([M]ZINIFACDAT,indice)=0
 VALEUR = gdat$(1,month(date$),year(date$))
Endif
Gosub _AFF
End

Subprog C_ZINIFACDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ZINIFACDAT" : GZNUM = 100640 : Endif
Gosub _AFF
End

