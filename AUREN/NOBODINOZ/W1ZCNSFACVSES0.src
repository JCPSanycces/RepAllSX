$ON_ZINIITM
Onevent CONTROL Call C_ZINIITM(zc) From W1ZCNSFACVSES0
Onevent BEFORE_INPUT Call AS_ZINIITM(zc) From W1ZCNSFACVSES0
Return

Subprog IB_ZINIITM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action IBPRDINF
 Call IBPRDINF(VALEUR) From PRDINFLIB
Endif
Gosub _AFF
End

Subprog AS_ZINIITM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(2061,GBOUT1) From OBJDIV
Call TEXTE(12837,GBOUT13) From OBJDIV
Call TEXTE(41059,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_ZINIITM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_ZINIITM(zc) From W1ZCNSFACVSES0
Onkey 170 Titled GBOUT13 Call B13_ZINIITM(zc) From W1ZCNSFACVSES0
Onkey   2 Titled GBOUTS Call S_ZINIITM(zc) From W1ZCNSFACVSES0
Onkey 144 Titled GBOUTP Call P_ZINIITM(zc) From W1ZCNSFACVSES0
Onkey 146 Titled GBOUTA Call SA_ZINIITM(zc) From W1ZCNSFACVSES0
Gosub _AFF
End

Subprog C_ZINIITM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ITMCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ITMCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"ITMCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ZINIITM" : GZNUM = 100637 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ITM","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ZINIITM" : GZNUM = 100637 : Endif
Endif
Gosub _AFF
End

Subprog S_ZINIITM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ITM"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ZINIITM(VALEUR)
Variable Char    VALEUR()
Call OBJET("ITM",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B13_ZINIITM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PRDINFA
 Call PRDINF(VALEUR) From PRDINFLIB
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_ZINIITM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ITM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ZINIITM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ITM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

