Onevent BEFORE_INPUT Call AS_ZINIWRH(zc) From W1ZCNSFACVSES0
Return

Subprog AS_ZINIWRH(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(41059,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ZINIWRH(zc) From W1ZCNSFACVSES0
Onkey 144 Titled GBOUTP Call P_ZINIWRH(zc) From W1ZCNSFACVSES0
Onkey 146 Titled GBOUTA Call SA_ZINIWRH(zc) From W1ZCNSFACVSES0
Gosub _AFF
End

Subprog C_ZINIWRH(VALEUR)
Variable Char    VALEUR()
## Action WRHCTL
Infbox "1:"-VALEUR
Call WRHCTL(VALEUR,"","") From STKWRH
Infbox "2:"-VALEUR
If mkstat : GERR = 1 : GZONE = "ZINIWRH" : GZNUM = 100638 : Endif
Infbox "3:"-VALEUR
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("WRH","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ZINIWRH" : GZNUM = 100638 : Endif
Endif
Gosub _AFF
End

Subprog S_ZINIWRH(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action WRHSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "WRHSEL"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"WRHSEL","STKWRH","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_ZINIWRH(VALEUR)
