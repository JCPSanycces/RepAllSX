#<AdxTL>@(#)0.0.0.0 $Revision$ 
#PUNTO ENTRADA
#  -  BEFWRIITM: Forzar calculo código EAN y GS1 al crear artículo por configurador

$ACTION
Case ACTION
  When "BEFWRIITM"     :   Gosub BEFWRIITM
Endcase
Return

$BEFWRIITM

 Local Integer   STAT, I, DC, WSUM, WNUM
 Local Char      WEANCOD(20)
 Local Char      WCODGS1(20)

 # Código GS1 en ZCODGS1 y EANCOD si categoria FG
 If [F:ITM]ZCODGS1="" & [F:ITM]ZARTGEN<>2 & [F:ITM]STOMGTCOD=2 & [F:ITM]TCLCOD="FG"
    Call NUMERO("NBGS1", GFCYDEF(9), datesyst,"",WCODGS1, STAT) From SUBANM
    If STAT = 0
      # Cálculo dígito control
      WSUM=0
      For I=1 To 12 Step 2
        WNUM=val(mid$(WCODGS1,I,1))
        WSUM+=(WNUM*1)
      Next I

      For I=2 To 12 Step 2
        WNUM=val(mid$(WCODGS1,I,1))
        WSUM+=(WNUM*3)
      Next I

      DC = 10-(mod(WSUM,10))
      If DC>=10  :  DC=0  :  Endif

      [F:ITM]ZCODGS1 = WCODGS1+num$(DC)
      [F:ITM]EANCOD = WCODGS1+num$(DC)
      Return
    Endif
 Endif

 ## Código de barras interno EANCOD si no categoria FG
 If [F:ITM]EANCOD="" & [F:ITM]ZARTGEN<>2 & [F:ITM]STOMGTCOD=2
    Call NUMERO("NBEAN", GFCYDEF(9), datesyst,"",WEANCOD, STAT) From SUBANM
    If STAT = 0
      [F:ITM]EANCOD = WEANCOD
    Endif
 Endif

Return

