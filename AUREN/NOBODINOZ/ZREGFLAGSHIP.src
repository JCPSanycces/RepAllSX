#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZREGFLASHIP
# Description : Registro entrada/salida de stock por tienda (Flag Ship)
# Version     : 1
# Created by  : Jose Luis Chiva
# Company     : Auren Espańa
# Created date: 24/11/2022
# Reference   : 06.404.009
############################################################################

#If GUSER="ADEV" Then
  Gosub INIT
  Gosub EXEC
#Endif
End

##############################################################
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##############################################################
$INIT
#Declaración de variables
Local   Char    LFICHEROIMP(GDIMFIC)
Local   Char    DIRAPL(GDIMFIC)
Local   Char    DIRZFS(GDIMFIC)
Local   Char    DIRPRO(GDIMFIC)
Local   Char    DIRERR(GDIMFIC)
Local   Char    DIRTMP(GDIMFIC)
Local   Char    ORDRE(GDIMFIC)
Local   Char    FILNAME(GDIMFIC)
Local   Char    LFILETXTSMR(GDIMFIC)
Local   Char    LFILETXTSMO(GDIMFIC)
Local   Char    FILELIST(GDIMFIC)(1..100)
Local   Integer A
Local   Integer STAT
Local   Integer RES
Local   Integer LECOK
Local   Char    LCODPROV(50),LNOMPROV(250),LCODTIENDA(50),LNOMTIENDA(250),LCODDPTO(50),LCODMERCADO(50),LNOMMERCADO(250),LCODFAMILIA(50),LREDACCION(250)
Local   Char    LPRODNOPROV(50),LEAN(50),LARTICULOUG(50),LCODARTICULO(50),LETIDIFF1(50),LREFDIFF1(50),LETIDIFF2(50),LREFDIFF2(50),LUNIDAD(50)
Local   Char    LCHECK(50),LDESCRIPCION(250),LEXTRA(5)
Local   Char    LPROCESOINI(50),LPROCESOFIN(50),LTICKETINI(50),LTICKETFIN(50)
Local   Char    LQTYVENTA(50),LIMPORTEAI(50),LIMPORTEII(50),LQTYSTOCK(50),LCHECKPVP(50),LDIF(50),LVALORTT(50)
Local   Char    LIPTDAT(15) : LIPTDAT = left$(num$(date$),2)+mid$(num$(date$),4,2)+mid$(num$(date$),7,4)
Local   Char    LCORREO(100),LASUNTO(250)
Local   Clbfile LTEXTO(3)
Local   Integer LERRGENSM
Local   Char    LFECHA(250),LHORA(250),LFILE2(250)

  # tratamiento ficheros
  LFICHEROIMP='VTE_MAG_TICK*'

  DIRAPL      = filpath("","","")                                                # Obtenemos ruta del folder
  DIRZFS      = DIRAPL+"\ZFLAGSHIP\RSTOCK"
  DIRPRO      = DIRZFS+"\Procesados"
  DIRERR      = DIRZFS+"\Error"
  DIRTMP      = DIRAPL+"\ZFLAGSHIP\tmp"
  LCORREO     = "fenella.bingham@nobodinoz.com"
  LTEXTO      = "Hola,"

  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  RES = filinfo (DIRERR,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRERR+'"',"",STAT) From ORDSYS : Endif

  If !clalev([F:ZFS0]) Then : Local File ZFLAGSHIPIMP [F:ZFS0] : Endif
  If !clalev([F:ZFS1]) Then : Local File ZFLAGSHIPIMP [F:ZFS1] : Endif
  If !clalev([F:ZFS2]) Then : Local File ZFLAGSHIPIMP [F:ZFS2] : Endif
  If !clalev([F:BPA0]) Then : Local File BPADDRESS    [F:BPA0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:BPA1]) Then : Local File BPADDRESS    [F:BPA1] : Endif
  If !clalev([F:ITM1]) Then : Local File ITMMASTER    [F:ITM1] : Endif
  If !clalev([F:ITF1]) Then : Local File ITMFACILIT   [F:ITF1] : Endif
  If !clalev([F:BPA2]) Then : Local File BPADDRESS    [F:BPA2] : Endif
  If !clalev([F:ITM2]) Then : Local File ITMMASTER    [F:ITM2] : Endif
  If !clalev([F:ITF2]) Then : Local File ITMFACILIT   [F:ITF2] : Endif
Return

##############################################################
$EXEC

  ORDRE = "dir /b "+DIRZFS+"\"+LFICHEROIMP+".csv 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If !GSERVEUR Then
    Call OUVRE_TRACE ("Imp. Flag ship") From LECFIC
  Endif

  For A=1 To RES
    LFECHA      = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,9,2)
    LHORA       = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,4)
    LFILETXTSMR = DIRTMP+"\ZSMRFS_"+LFECHA+"_"+LHORA+".txt"
    LFILETXTSMO = DIRTMP+"\ZSMOFS_"+LFECHA+"_"+LHORA+".txt"
    FILNAME     = DIRZFS+"\"+left$(FILELIST(A),len(FILELIST(A))-4)
    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
    Call ECR_TRACE('Proceso fichero'-FILELIST(A),0) From GESECRAN
    Gosub ABRE_FICHERO_ORI
    Gosub RELLENA_TABLA
    Gosub CIERRA_FICHERO_ORI
    If LERRGENSM Then
      Call ENVIA_ERROR_DATOS(LCORREO,LASUNTO,LTEXTO)
    Else
      # genera entradas varias
      Gosub GENERA_SMR
      # genera salidas varias
      Gosub GENERA_SMO
    Endif
  Next ####
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  If dim(GCORREO)   > 0 Then : Kill GCORREO   : Endif
  If dim(GASUNTO)   > 0 Then : Kill GASUNTO   : Endif
  If dim(GTEXTO)    > 0 Then : Kill GTEXTO    : Endif
Return

##############################################################
$ABRE_FICHERO_ORI
  Openi FILNAME+".csv", 0         Using [FIN]                       # Received file with orders
  Iomode adxifs ";"               Using [FIN]                       # Separador de campo ";"
  Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro CR + LF
  Iomode adxium 0                 Using [FIN]                       # UTF-8 file
Return

##############################################################
$CIERRA_FICHERO_ORI
  Openi Using [FIN]
Return

##############################################################
$RELLENA_TABLA
    LECOK = 1
    Raz LERRGENSM
    Execsql From "5" Sql "Truncate table" - nomap + ".ZFLAGSHIPIMP"
    Repeat
      # lee el archivo
      Rdseq LCODPROV,LNOMPROV,LPROCESOINI,LPROCESOFIN,LCODTIENDA,LNOMTIENDA,LCODDPTO,LCODMERCADO,LNOMMERCADO,LCODFAMILIA,LREDACCION,
&           LPRODNOPROV,LEAN,LARTICULOUG,LCODARTICULO,LETIDIFF1,LREFDIFF1,LETIDIFF2,LREFDIFF2,LQTYVENTA,LIMPORTEAI,LIMPORTEII,
&           LQTYSTOCK,LTICKETINI,LTICKETFIN,LUNIDAD,LCHECKPVP,LCHECK,LDIF,LVALORTT,LDESCRIPCION,LEXTRA
&           Using [FIN]
      If !fstat Then
        Filter  [F:BPA0] Where BPATYP = 1 and BPANUM = '001' and ZCODTIENDA = LCODTIENDA
        Read [F:BPA0] First
        If fstat Then
          LECOK     = 0
          LERRGENSM = 1
          LASUNTO   = "Error en el fichero"-FILELIST(A)
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"No se han generado movimientos porque no se ha podido identificar el almacén para la tienda"-LCODTIENDA
          Gosub CIERRA_FICHERO_ORI
          If filinfo(FILNAME+".csv", 7) > 0 Then
            Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero con errores
          Endif
          Call ECR_TRACE("Error en los datos del fichero"-FILELIST(A)+"\No se ha podido identificar el almacén para la tienda"-LCODTIENDA,1) From GESECRAN
        Endif
        Filter  [F:BPA0]
        Filter  [F:ITM0] Where EANCOD = LPRODNOPROV and EANCOD <> ''
        Read [F:ITM0] First
        If fstat Then
          LECOK     = 0
          LERRGENSM = 1
          LASUNTO   = "Error en el fichero"-FILELIST(A)
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"No se han generado movimientos porque no se ha podido identificar el artículo con código EAN"-LPRODNOPROV
          Gosub CIERRA_FICHERO_ORI
          If filinfo(FILNAME+".csv", 7) > 0 Then
            Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero con errores
          Endif
          Call ECR_TRACE("Error en los datos del fichero"-FILELIST(A)+"\No se ha podido identificar el artículo con código EAN"-LPRODNOPROV,1) From GESECRAN
        Endif
        If !LERRGENSM Then
          [F:ZFS0]ZID           = getUuid
          [F:ZFS0]ZCODPROV      = vireblc(LCODPROV,2)
          [F:ZFS0]ZNOMPROV      = vireblc(LNOMPROV,2)
          [F:ZFS0]ZPROCESOINI   = gdat$(val(mid$(vireblc(LPROCESOINI,2),1,2)),val(mid$(vireblc(LPROCESOINI,2),4,2)),val(mid$(vireblc(LPROCESOINI,2),7,4)))
          [F:ZFS0]ZPROCESOFIN   = gdat$(val(mid$(vireblc(LPROCESOFIN,2),1,2)),val(mid$(vireblc(LPROCESOFIN,2),4,2)),val(mid$(vireblc(LPROCESOFIN,2),7,4)))
          [F:ZFS0]ZCODTIENDA    = vireblc(LCODTIENDA,2)
          [F:ZFS0]ZNOMTIENDA    = vireblc(LNOMTIENDA,2)
          [F:ZFS0]ZCODDPTO      = vireblc(LCODDPTO,2)
          [F:ZFS0]ZCODMERCADO   = vireblc(LCODMERCADO,2)
          [F:ZFS0]ZNOMMERCADO   = vireblc(LNOMMERCADO,2)
          [F:ZFS0]ZCODFAMILIA   = vireblc(LCODFAMILIA,2)
          [F:ZFS0]ZREDACCION    = vireblc(LREDACCION,2)
          [F:ZFS0]ZPRODNOPROV   = vireblc(LPRODNOPROV,2)
          [F:ZFS0]ZEAN          = vireblc(LEAN,2)
          [F:ZFS0]ZARTICULOUG   = vireblc(LARTICULOUG,2)
          [F:ZFS0]ZCODARTICULO  = vireblc(LCODARTICULO,2)
          [F:ZFS0]ZETIDIFF1     = vireblc(LETIDIFF1,2)
          [F:ZFS0]ZREFDIFF1     = vireblc(LREFDIFF1,2)
          [F:ZFS0]ZETIDIFF2     = vireblc(LETIDIFF2,2)
          [F:ZFS0]ZREFDIFF2     = vireblc(LREFDIFF2,2)
          [F:ZFS0]ZQTYVENTA     = val(vireblc(ctrans(LQTYVENTA,",","."),2))
          [F:ZFS0]ZIMPORTEAI    = val(vireblc(ctrans(LIMPORTEAI,",","."),2))
          [F:ZFS0]ZIMPORTEII    = val(vireblc(ctrans(LIMPORTEII,",","."),2))
          [F:ZFS0]ZQTYSTOCK     = val(vireblc(ctrans(LQTYSTOCK,",","."),2))
          [F:ZFS0]ZTICKETINI    = gdat$(val(mid$(vireblc(LTICKETINI,2),1,2)),val(mid$(vireblc(LTICKETINI,2),4,2)),val(mid$(vireblc(LTICKETINI,2),7,4)))
          [F:ZFS0]ZTICKETFIN    = gdat$(val(mid$(vireblc(LTICKETFIN,2),1,2)),val(mid$(vireblc(LTICKETFIN,2),4,2)),val(mid$(vireblc(LTICKETFIN,2),7,4)))
          [F:ZFS0]ZUNIDAD       = vireblc(LUNIDAD,2)
          [F:ZFS0]ZCHECKPVP     = val(vireblc(ctrans(LCHECKPVP,",","."),2))
          If vireblc(LCHECK,2) = "VERDADERO" Then
            [F:ZFS0]ZCHECK = 2
          Else
            [F:ZFS0]ZCHECK = 1
          Endif
          [F:ZFS0]ZDIF          = val(ctrans(vireblc(ctrans(LDIF,",","."),2),"€",""))
          [F:ZFS0]ZVALORTT      = val(ctrans(vireblc(ctrans(LVALORTT,",","."),2),"€",""))
          [F:ZFS0]ZDESCRIPCION  = vireblc(LDESCRIPCION,2)
          Trbegin [F:ZFS0]
          Write   [F:ZFS0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Else
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"Por favor, solucione la incidencia en el fichero"-FILELIST(A)-"y vuelva a procesarlo."+chr$(13)+chr$(10)
        Endif
      Else
        LECOK = 0
      Endif
    Until LECOK = 0
Return

##############################################################
$ABRE_FICHERO_IMP_SMR
  # borramos el fichero si existe...
  If GSERVEUR Then
    If filinfo(LFILETXTSMR, 7) > 0 Then
      System "ae_rm " + LFILETXTSMR
    Endif
  Endif
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILETXTSMR Using [ZIMPSMR]
Return

##############################################################
$CIERRA_FICHERO_IMP_SMR
  Openi Using [ZIMPSMR]
Return

##############################################################
$ABRE_FICHERO_IMP_SMO
  # borramos el fichero si existe...
  If GSERVEUR Then
    If filinfo(LFILETXTSMO, 7) > 0 Then
      System "ae_rm " + LFILETXTSMO
    Endif
  Endif
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILETXTSMO Using [ZIMPSMO]
Return

##############################################################
$CIERRA_FICHERO_IMP_SMO
  Openi Using [ZIMPSMO]
Return

##############################################################
$GENERA_SMR
  # crea fichero import
  Filter [F:ZFS1] Where ZQTYVENTA < 0 and ZPRODNOPROV <> 'UGFAMILLE'
  If rowcount([F:ZFS1]) > 0 Then
    Gosub ABRE_FICHERO_IMP_SMR
    Wrseq "E" + ";" + "19" + ";" + "" + ";" + "001" + ";" + LIPTDAT + ";" + "FLS" + ";" + "FLS" + ";" + FILELIST(A)   Using [ZIMPSMR]
    For [ZFS1]
      Filter  [F:BPA1] Where BPATYP = 1 and BPANUM = '001' and ZCODTIENDA = [F:ZFS1]ZCODTIENDA : Read [F:BPA1] First
      Filter  [F:ITM1] Where EANCOD = [F:ZFS1]ZPRODNOPROV : Read [F:ITM1] First
      Read    [F:ITF1]ITF0 = [F:ITM1]ITMREF;"001"
      Wrseq "L" + ";" + [F:ITM1]ITMREF + ";" + [F:ITF1]PCU + ";" + num$(abs([F:ZFS1]ZQTYVENTA))                                         Using [ZIMPSMR]
      Wrseq "S" + ";" + [F:ITF1]PCU + ";" + num$(abs([F:ZFS1]ZQTYVENTA)) + ";" + [F:BPA1]ZWRHE + ";" + [F:BPA1]ZWRHE + ";" + "A"        Using [ZIMPSMR]
    Next
    Filter [F:ZFS1]
    Gosub CIERRA_FICHERO_IMP_SMR

    # lanza import
    mkstat = 0 : fstat = 0 : GERRTRACE = 0
    Call IMPORTSIL ("ZSMRFS",LFILETXTSMR)From GIMPOBJ

    # gestiona import
    If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
      If filinfo(FILNAME+".csv", 7) > 0 Then
        Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero .err con errores en la importación
      Endif
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE("Error en la importación",1) From GESECRAN
      LASUNTO   = "Error en la importación del fichero"-FILELIST(A)
      LTEXTO    += chr$(13)+chr$(10)+"Se ha producido un error durante la generación de una entrada de stock en el fichero"-FILELIST(A)
      Call ENVIA_ERROR_IMPORT(LCORREO,LASUNTO,LTEXTO)
    Else
      If filinfo(FILNAME+".csv",7) > 0 Then
        Call MOVE(FILNAME+".csv",DIRPRO,STAT) From ORDSYS                                # mueve el fichero xml a la carpeta de procesados
      Endif
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE("Importación correcta",0) From GESECRAN
    Endif
  Else
    Return
  Endif
Return

##############################################################
$GENERA_SMO
  # crea fichero import
  Filter [F:ZFS2] Where ZQTYVENTA > 0 and ZPRODNOPROV <> 'UGFAMILLE'
  If rowcount([F:ZFS2]) > 0 Then
    Gosub ABRE_FICHERO_IMP_SMO
    Wrseq "E" + ";" + "20" + ";" + "" + ";" + "001" + ";" + LIPTDAT + ";" + "FLS" + ";" + "FLS" + ";" + FILELIST(A)   Using [ZIMPSMO]
    For [ZFS2]
      Filter  [F:BPA2] Where BPATYP = 1 and BPANUM = '001' and ZCODTIENDA = [F:ZFS2]ZCODTIENDA : Read [F:BPA2] First
      Filter  [F:ITM2] Where EANCOD = [F:ZFS2]ZPRODNOPROV : Read [F:ITM2] First
      Read    [F:ITF2]ITF0 = [F:ITM2]ITMREF;"001"
      Wrseq "L" + ";" + [F:ITM2]ITMREF + ";" + [F:ITF2]PCU + ";" + num$(abs([F:ZFS2]ZQTYVENTA))                                         Using [ZIMPSMO]
      Wrseq "S" + ";" + [F:ITF2]PCU + ";" + num$([F:ZFS2]ZQTYVENTA*-1) + ";" + [F:BPA2]ZWRHE + ";" + [F:BPA2]ZWRHE + ";" + "A"          Using [ZIMPSMO]
    Next
    Filter [F:ZFS2]
    Gosub CIERRA_FICHERO_IMP_SMO

    # lanza import
    mkstat = 0 : fstat = 0 : GERRTRACE = 0
    Call IMPORTSIL ("ZSMOFS",LFILETXTSMO)From GIMPOBJ

    # gestiona import
    If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
      If filinfo(FILNAME+".csv", 7) > 0 Then
        Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero .err con errores en la importación
      Endif
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE("Error en la importación",1) From GESECRAN
      LASUNTO   = "Error en la importación del fichero"-FILELIST(A)
      LTEXTO    += chr$(13)+chr$(10)+"Se ha producido un error durante la generación de una salida de stock en el fichero"-FILELIST(A)
      Call ENVIA_ERROR_IMPORT(LCORREO,LASUNTO,LTEXTO)
    Else
      If filinfo(FILNAME+".csv",7) > 0 Then
        Call MOVE(FILNAME+".csv",DIRPRO,STAT) From ORDSYS                                  # mueve el fichero xml a la carpeta de procesados
      Endif
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE("Importación correcta",0) From GESECRAN
    Endif
  Else
    Return
  Endif
Return

##############################################################
Subprog ENVIA_ERROR_DATOS(PCORREO,PASUNTO,PTEXTO)
Value Char PCORREO,PASUNTO,PTEXTO
  # lanza un workflow para avisar de que la importación ha fallado
  Global Char GCORREO(250),GASUNTO(250),GTEXTO(250)
  GCORREO   = PCORREO
  GASUNTO   = PASUNTO
  GTEXTO    = PTEXTO
  Call WORKFLOW (1,"ZED","",GUSER) From AWRK
End

##############################################################
Subprog ENVIA_ERROR_IMPORT(PCORREO,PASUNTO,PTEXTO)
Value Char PCORREO,PASUNTO,PTEXTO
  # lanza un workflow para avisar de que la importación ha fallado
  Global Char GCORREO(250),GASUNTO(250),GTEXTO(250)
  GCORREO   = PCORREO
  GASUNTO   = PASUNTO
  GTEXTO    = PTEXTO
  Call WORKFLOW (1,"ZEI","",GUSER) From AWRK
End
