#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Modificación de prioridad en clientes

If !clalev([F:ZBPC1]) : Local File BPCUSTOMER    [F:ZBPC1] : Endif
If !clalev([F:ZBPD1]) : Local File BPDLVCUST     [F:ZBPD1] : Endif
If !clalev([F:ZSOH1]) : Local File SORDER        [F:ZSOH1] : Endif
If !clalev([F:ZSOQ1]) : Local File SORDERQ       [F:ZSOQ1] : Endif
If !clalev([F:ZBPD1]) : Local File BPDLVCUST     [F:ZBPD1] : Endif
Local Integer ZCONT : Raz ZCONT

For [F:ZBPC1]BPC0 Where TSCCOD(2) ='002'
   For [F:ZBPD1]BPD0 Where BPCNUM = [F:ZBPC1]BPCNUM
      [F:ZBPD1]DLVPIO = 3
      Rewrite [F:ZBPD1]
      ZCONT+=1
   Next
Next
Infbox "REGISTROS MODIFICADOS"-num$(ZCONT )

#Mdificaciones en pedidos abiertos
Raz ZCONT
For [F:ZBPC1]BPC0 Where TSCCOD(2) ='002' or TSCCOD(2) ='003'
    For [F:ZSOH1]SOH0 Where ORDSTA = 1 and BPCORD = [F:ZBPC1]BPCNUM
        Read [F:ZBPD1]BPD0 =  [F:ZBPC1]BPCNUM;[F:ZSOH1]BPAADD
        If !fstat Then
            [F:ZSOH1]DLVPIO =  [F:ZBPD1]DLVPIO
            Rewrite [F:ZSOH1]
            ZCONT+=1
            For [F:ZSOQ1]SOQ0 Where SOHNUM = [F:ZSOH1]SOHNUM
                [F:ZSOQ1]DLVPIO =  [F:ZBPD1]DLVPIO
                Rewrite [F:ZSOQ1]
            Next
        Endif
    Next
Next
Infbox "PEDIDOS MODIFICADOS"-num$(ZCONT )
End
