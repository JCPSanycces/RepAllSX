#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZREGFACABOFS
# Description : Registro facturas/abonos venta mensual (Flag Ship)
# Version     : 1
# Created by  : Jose Luis Chiva
# Company     : Auren Espańa
# Created date: 10/01/2023
# Reference   : 06.404.010
############################################################################

#If GUSER="ADEV" Then
  Gosub INIT
  Gosub EXEC
#Endif
End

##############################################################
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##############################################################
$INIT
#Declaración de variables
Local   Char    LFICHEROIMP(GDIMFIC)
Local   Char    DIRAPL(GDIMFIC)
Local   Char    DIRZFS(GDIMFIC)
Local   Char    DIRPRO(GDIMFIC)
Local   Char    DIRERR(GDIMFIC)
Local   Char    DIRTMP(GDIMFIC)
Local   Char    ORDRE(GDIMFIC)
Local   Char    FILNAME(GDIMFIC)
Local   Char    LFILETXTSIH(GDIMFIC)
Local   Char    FILELIST(GDIMFIC)(1..100)
Local   Integer A
Local   Integer STAT
Local   Integer RES
Local   Integer LECOK
Local   Char    LFECHACREA(50),LMES(10),LANYO(10),LCODPROV(100),LSITUAFAM(10),LCODFAMILIA(50),LCODSUBFAM(250),LDESSUBFAM(100),LCODGRUPO(50)
Local   Char    LDESGRUPO(100),LCODDPTO(50),LDESDPTO(100),LCODALMACEN(50),LTIPOSITIO(10),LNUMPEDIDO(100),LTIPOFACTURA(10),LDESTIPOFAC(100),LORIGENFAC(50)
Local   Char    LDESORIFAC(250),LCODCUR(10),LDESCUR(50),LPORCOMISION(15),LFECHACREFAC(50),LCODPROD(100),LDESPROD(250),LREFPROV(50),LCODART(100),LDESART(250)
Local   Char    LEAN(100),LQTYVENTA(100),LIMPORTEII(100),LIMPORTEAI(100),LIMPORTEVTA(100),LTIPOIVA(100),LUNIDAD(100),LDESCLIENTE(250)
Local   Char    LA(250),LB(250),LC(250),LD(250),LE(250),LF(250),LG(250),LH(250),LI(250),LJ(250),LK(250),LL(250),LM(250),LZN(250),LO(250),LP(250),LQ(250)
Local   Char    LR(250),LS(250),LT(250),LU(250),LV(250),LW(250),LX(250),LY(250),LZ(250)
Local   Char    LAA(250),LAB(250),LAC(250),LAD(250),LAE(250),LAG(250),LAH(250),LAI(250),LAJ(250),LAK(250),LAL(250)
Local   Char    LAM(250),LAN(250),LAO(250),LAP(250),LAQ(250),LAR(250),LAS(250),LAT(250),LAU(250),LAV(250)
Local   Char    LEXTRA(5)
Local   Char    LCLIENTESIH(100),LCLIENTESOH(100)
Local   Char    LIPTDAT(15) : LIPTDAT = left$(num$(date$),2)+mid$(num$(date$),4,2)+mid$(num$(date$),7,4)
Local   Char    LCORREO(100),LASUNTO(250)
Local   Clbfile LTEXTO(3)
Local   Integer LCLASEFACTURA
Local   Char    LFACTURATYP(50)
Local   Decimal LPRECIO,LDTOCLIENTE
Local   Char    LWRH(250),LITMREF(100)
Local   Integer LERRGENSM
Local   Char    LFECHA(250),LHORA(250),LFILE2(250)

  # tratamiento ficheros
  LFICHEROIMP='CFF_COMM*'

  DIRAPL      = filpath("","","")                                                # Obtenemos ruta del folder
  DIRZFS      = DIRAPL+"\ZFLAGSHIP\FACTURAS"
  DIRPRO      = DIRZFS+"\Procesados"
  DIRERR      = DIRZFS+"\Error"
  DIRTMP      = DIRAPL+"\ZFLAGSHIP\tmp"
  LCORREO     = "fenella.bingham@nobodinoz.com"
#  LCORREO     = "joseluis.chiva@auren.es;abraham.medina@auren.es"
  LTEXTO      = "Hola,"

  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  RES = filinfo (DIRERR,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRERR+'"',"",STAT) From ORDSYS : Endif

  If !clalev([F:ZFS0]) Then : Local File ZFLAGSHIPFAC [F:ZFS0] : Endif
  If !clalev([F:ZFS1]) Then : Local File ZFLAGSHIPFAC [F:ZFS1] : Endif
  If !clalev([F:ZVF0]) Then : Local File ZVREGFACFS   [F:ZVF0] : Endif
  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER   [F:BPC0] : Endif
  If !clalev([F:BPA0]) Then : Local File BPADDRESS    [F:BPA0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
Return

##############################################################
$EXEC

  ORDRE = "dir /b "+DIRZFS+"\"+LFICHEROIMP+".csv 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If !GSERVEUR Then
    Call OUVRE_TRACE ("Imp. Facturas/Abonos Flag ship") From LECFIC
  Endif

  For A=1 To RES
    LFECHA      = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,9,2)
    LHORA       = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,4)
    LFILETXTSIH = DIRTMP+"\ZFACFS_"+LFECHA+"_"+LHORA+".txt"
    FILNAME     = DIRZFS+"\"+left$(FILELIST(A),len(FILELIST(A))-4)
    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
    Call ECR_TRACE('Proceso fichero'-FILELIST(A),0) From GESECRAN
    Gosub ABRE_FICHERO_ORI
    Gosub RELLENA_TABLA
    Gosub CIERRA_FICHERO_ORI
    If LERRGENSM Then
      Call ENVIA_ERROR_DATOS(LCORREO,LASUNTO,LTEXTO)
    Else
      # factura
      Gosub GENERA_SIH
    Endif
  Next
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  If dim(GCORREO)   > 0 Then : Kill GCORREO   : Endif
  If dim(GASUNTO)   > 0 Then : Kill GASUNTO   : Endif
  If dim(GTEXTO)    > 0 Then : Kill GTEXTO    : Endif
Return

##############################################################
$ABRE_FICHERO_ORI
  Openi FILNAME+".csv", 0         Using [FIN]                       # Received file with orders
  Iomode adxifs ";"               Using [FIN]                       # Separador de campo ";"
  Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro CR + LF
  Iomode adxium 0                 Using [FIN]                       # UTF-8 file
Return

##############################################################
$CIERRA_FICHERO_ORI
  Openi Using [FIN]
Return

##############################################################
$RELLENA_TABLA
  LECOK = 1
  Raz LERRGENSM
  Execsql From "5" Sql "Truncate table" - nomap + ".ZFLAGSHIPFAC"
  Rdseq LA,LB,LC,LD,LE,LF,LG,LH,LI,LJ,LK,LL,LM,LZN,LO,LP,LQ,LR,LS,LT,LU,LV,LW,LX,LY,LZ,
&       LAA,LAB,LAC,LAD,LAE,LAG,LAH,LAI,LAJ,LAK,LAL,LAM,LAN,LAO,LAP,LAQ,LAR,LAS,LAT,LAU,LAV,LEXTRA      Using [FIN]
  If !fstat Then
    Repeat
      Raz LFECHACREA,LMES,LANYO,LCODPROV,LSITUAFAM,LCODFAMILIA,LCODSUBFAM,LDESSUBFAM,LCODGRUPO,LDESGRUPO,LCODDPTO,LDESDPTO,LCODALMACEN,
&         LTIPOSITIO,LNUMPEDIDO,LTIPOFACTURA,LDESTIPOFAC,LORIGENFAC,LDESORIFAC,LCODCUR,LDESCUR,LPORCOMISION,LFECHACREFAC,LCODPROD,LDESPROD,LREFPROV,
&         LCODART,LDESART,LEAN,LQTYVENTA,LIMPORTEII,LIMPORTEAI,LIMPORTEVTA,LTIPOIVA,LUNIDAD,LAJ,LDESCLIENTE,LAL,LAM,LAN,LAO,LAP,LAQ,LAR,
&         LAS,LAT,LEXTRA,LCLIENTESIH,LCLIENTESOH,LITMREF
      # lee el archivo
      Rdseq LFECHACREA,LMES,LANYO,LCODPROV,LSITUAFAM,LCODFAMILIA,LCODSUBFAM,LDESSUBFAM,LCODGRUPO,LDESGRUPO,LCODDPTO,LDESDPTO,LCODALMACEN,
&           LTIPOSITIO,LNUMPEDIDO,LTIPOFACTURA,LDESTIPOFAC,LORIGENFAC,LDESORIFAC,LCODCUR,LDESCUR,LPORCOMISION,LFECHACREFAC,LCODPROD,LDESPROD,LREFPROV,
&           LCODART,LDESART,LEAN,LQTYVENTA,LIMPORTEII,LIMPORTEAI,LIMPORTEVTA,LTIPOIVA,LUNIDAD,LAJ,LDESCLIENTE,LAL,LAM,LAN,LAO,LAP,LAQ,LAR,
&           LAS,LAT,LEXTRA    Using [FIN]
      If !fstat Then
        # control de existencia de cliente
        Filter  [F:BPC0] Where BPCSHO = left$(LDESCLIENTE,10) and BPCSHO <> ''
        Read [F:BPC0] First
        If fstat Then
          LECOK     = 0
          LERRGENSM = 1
          LASUNTO   = "Error en el fichero"-FILELIST(A)
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"La factura no se ha generado porque no se ha encontrado el cliente"-LDESCLIENTE+"."
          Gosub CIERRA_FICHERO_ORI
          If filinfo(FILNAME+".csv", 7) > 0 Then
            Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero con errores
          Endif
          Call ECR_TRACE("Error en los datos del fichero"-FILELIST(A)+"\No se ha encontrado el cliente"-LDESCLIENTE,1) From GESECRAN
        Else
          LCLIENTESIH = [F:BPC0]BPCNUM
          LCLIENTESOH = [F:BPC0]BPCINV
          LDTOCLIENTE = [F:BPC0]INVDTAAMT(1)
        Endif
        Filter  [F:BPC0]
        # control de la existencia de artículo
        If LREFPROV <> 'UGFAMILLE' Then
          Filter  [F:ITM0] Where EANCOD = LREFPROV and EANCOD <> ''
          Read [F:ITM0] First
          If fstat Then
            LECOK     = 0
            LERRGENSM = 1
            LASUNTO   = "Error en el fichero"-FILELIST(A)
            LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"La factura no se ha generado porque no se ha podido identificar el artículo con código EAN"-LREFPROV+"."
            Gosub CIERRA_FICHERO_ORI
            If filinfo(FILNAME+".csv", 7) > 0 Then
              Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero con errores
            Endif
            Call ECR_TRACE("Error en los datos del fichero"-FILELIST(A)+"\No se ha podido identificar el artículo con código EAN"-LREFPROV,1) From GESECRAN
          Else
            LITMREF   = [F:ITM0]ITMREF
          Endif
        Else
          LITMREF     = 'DDDDDDDDD'
        Endif
        # control de la cantidad
        If val(LQTYVENTA) < 0 Then
          LECOK     = 0
          LERRGENSM = 1
          LASUNTO   = "Error en el fichero"-FILELIST(A)
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"La factura no se ha generado porque existe una línea para el artículo"-LREFPROV-"con cantidad negativa."
          Gosub CIERRA_FICHERO_ORI
          If filinfo(FILNAME+".csv", 7) > 0 Then
            Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero con errores
          Endif
          Call ECR_TRACE("Error en los datos del fichero"-FILELIST(A)+"\Imposible crear una línea de factura con cantidad inferior a 0",1) From GESECRAN
        Endif
        If !LERRGENSM Then
          [F:ZFS0]ZID           = getUuid
          [F:ZFS0]ZFECHACREA    = gdat$(val(mid$(vireblc(LFECHACREA,2),1,2)),val(mid$(vireblc(LFECHACREA,2),4,2)),val(mid$(vireblc(LFECHACREA,2),7,4)))
          [F:ZFS0]ZMES          = val(vireblc(LMES,2))
          [F:ZFS0]ZANYO         = val(vireblc(LANYO,2))
          [F:ZFS0]ZCODPROV      = vireblc(LCODPROV,2)
          [F:ZFS0]ZSITUAFAM     = val(vireblc(LSITUAFAM,2))
          [F:ZFS0]ZCODFAMILIA   = vireblc(LCODFAMILIA,2)
          [F:ZFS0]ZCODSUBFAM    = vireblc(LCODSUBFAM,2)
          [F:ZFS0]ZDESSUBFAM    = vireblc(LDESSUBFAM,2)
          [F:ZFS0]ZCODGRUPO     = vireblc(LCODGRUPO,2)
          [F:ZFS0]ZDESGRUPO     = vireblc(LDESGRUPO,2)
          [F:ZFS0]ZCODDPTO      = vireblc(LCODDPTO,2)
          [F:ZFS0]ZDESDPTO      = vireblc(LDESDPTO,2)
          [F:ZFS0]ZCODALMACEN   = vireblc(LCODALMACEN,2)
          [F:ZFS0]ZTIPOSITIO    = vireblc(LTIPOSITIO,2)
          [F:ZFS0]ZNUMPEDIDO    = vireblc(LNUMPEDIDO,2)
          [F:ZFS0]ZTIPOFACTURA  = vireblc(LTIPOFACTURA,2)
          [F:ZFS0]ZDESTIPOFAC   = vireblc(LDESTIPOFAC,2)
          [F:ZFS0]ZORIGENFAC    = vireblc(LORIGENFAC,2)
          [F:ZFS0]ZDESORIFAC    = vireblc(LDESORIFAC,2)
          [F:ZFS0]ZCODCUR       = vireblc(LCODCUR,2)
          [F:ZFS0]ZDESCUR       = vireblc(LDESCUR,2)
          [F:ZFS0]ZPORCOMISION  = val(vireblc(ctrans(LPORCOMISION,",","."),2))
          [F:ZFS0]ZFECHACREFAC  = gdat$(val(mid$(vireblc(LFECHACREFAC,2),1,2)),val(mid$(vireblc(LFECHACREFAC,2),4,2)),val(mid$(vireblc(LFECHACREFAC,2),7,4)))
          [F:ZFS0]ZCODPROD      = vireblc(LCODPROD,2)
          [F:ZFS0]ZDESPROD      = vireblc(LDESPROD,2)
          [F:ZFS0]ZREFPROV      = vireblc(LREFPROV,2)
          [F:ZFS0]ZITMREF       = vireblc(LITMREF,2)
          [F:ZFS0]ZCODART       = vireblc(LCODART,2)
          [F:ZFS0]ZDESART       = vireblc(LDESART,2)
          [F:ZFS0]ZEAN          = vireblc(LEAN,2)
          [F:ZFS0]ZQTYVENTA     = val(vireblc(ctrans(LQTYVENTA,".",""),2))
          [F:ZFS0]ZIMPORTEII    = val(vireblc(ctrans(LIMPORTEII,".",""),2))
          [F:ZFS0]ZIMPORTEAI    = val(vireblc(ctrans(LIMPORTEAI,".",""),2))
          [F:ZFS0]ZIMPORTEVTA   = val(vireblc(ctrans(LIMPORTEVTA,",","."),2))
          [F:ZFS0]ZTIPOIVA      = vireblc(LTIPOIVA,2)
          [F:ZFS0]ZUNIDAD       = vireblc(LUNIDAD,2)
          [F:ZFS0]ZDESCLIENTE   = vireblc(LDESCLIENTE,2)
          [F:ZFS0]ZCLIENTESIH   = vireblc(LCLIENTESIH,2)
          [F:ZFS0]ZCLIENTESOH   = vireblc(LCLIENTESOH,2)
          [F:ZFS0]ZDTOCLIENTE   = LDTOCLIENTE
          Trbegin [F:ZFS0]
          Write   [F:ZFS0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Else
          LTEXTO    += chr$(13)+chr$(10)+chr$(13)+chr$(10)+"Por favor, solucione la incidencia en el fichero"-FILELIST(A)-"y vuelva a procesarlo."+chr$(13)+chr$(10)
        Endif
      Else
        LECOK = 0
      Endif
    Until LECOK = 0
  Endif
Return

##############################################################
$ABRE_FICHERO_IMP_SIH
  # borramos el fichero si existe...
  If GSERVEUR Then
    If filinfo(LFILETXTSIH, 7) > 0 Then
      System "ae_rm " + LFILETXTSIH
    Endif
  Endif
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILETXTSIH Using [ZIMPSIH]
Return

##############################################################
$CIERRA_FICHERO_IMP_SIH
  Openi Using [ZIMPSIH]
Return

##############################################################
$GENERA_SIH
  # crea fichero import
  Filter [F:ZVF0]
  If rowcount([F:ZVF0]) > 0 Then
    For [F:ZVF0]
      Gosub ABRE_FICHERO_IMP_SIH
      Case [F:ZVF0]ZTIPOFACTURA
        When 'CFF'  Then LCLASEFACTURA = 1 : LFACTURATYP = 'INV10'
        When 'CAF'  Then LCLASEFACTURA = 2 : LFACTURATYP = 'CNC10'
      Endcase
      Wrseq "V" + ";" + "090" + ";" + num$(LCLASEFACTURA) + ";" + LFACTURATYP + ";" + "1" + ";" +
&           [F:ZVF0]ZCLIENTESIH + ";" + [F:ZVF0]ZCLIENTESOH + ";" + "EUR" + ";" + LIPTDAT + ";" + FILELIST(A)                                                         Using [ZIMPSIH]
      Filter [F:ZFS1] Where ZTIPOFACTURA = [F:ZVF0]ZTIPOFACTURA and ZCLIENTESIH = [F:ZVF0]ZCLIENTESIH
      For [ZFS1]
        LPRECIO = [F:ZFS1]ZIMPORTEII / 100000
        LPRECIO = ar2((LPRECIO * 100) / (100 - [F:ZFS1]ZDTOCLIENTE))
        Filter [F:BPA0] Where BPATYP = 3 and BPANUM = '001' and ZCODTIENDA = [F:ZFS1]ZCODALMACEN
        Read   [F:BPA0] First
        Wrseq "D" + ";" + [F:ZFS1]ZITMREF + ";" + num$(abs([F:ZFS1]ZQTYVENTA)) + ";" + num$(abs(LPRECIO)) + ";" + [F:BPA0]ZWRHE + ";" +
&             num$(ar2([F:ZFS1]ZQTYVENTA * LPRECIO))                                                                                      Using [ZIMPSIH]
        Filter [F:BPA0]
      Next #ZFS1
      Filter [F:ZFS1]
      Gosub CIERRA_FICHERO_IMP_SIH

      # lanza import
      mkstat = 0 : fstat = 0 : GERRTRACE = 0
      Call IMPORTSIL ("ZSIHFS",LFILETXTSIH)From GIMPOBJ

      # gestiona import
      If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
        If filinfo(FILNAME+".csv", 7) > 0 Then
          Call MOVE(FILNAME+".csv",DIRERR,STAT) From ORDSYS                           # mueve el fichero .err con errores en la importación
        Endif
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call ECR_TRACE("Error en la importación",1) From GESECRAN
        LASUNTO   = "Error en la importación del fichero"-FILELIST(A)
        LTEXTO    += chr$(13)+chr$(10)+"Se ha producido un error durante la generación de la factura/abono en el fichero"-FILELIST(A)
        Call ENVIA_ERROR_IMPORT(LCORREO,LASUNTO,LTEXTO)
      Else
        If filinfo(FILNAME+".csv",7) > 0 Then
          Call MOVE(FILNAME+".csv",DIRPRO,STAT) From ORDSYS                                # mueve el fichero xml a la carpeta de procesados
        Endif
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call ECR_TRACE("Importación correcta",0) From GESECRAN
      Endif
    Next  #ZVF0
  Else
    Return
  Endif
  Filter [F:ZVF0]
Return

##############################################################
Subprog ENVIA_ERROR_DATOS(PCORREO,PASUNTO,PTEXTO)
Value Char    PCORREO,PASUNTO
Value Clbfile PTEXTO
  # lanza un workflow para avisar de que la importación ha fallado
  Global Char GCORREO(250),GASUNTO(250),GTEXTO(250)
  GCORREO   = PCORREO
  GASUNTO   = PASUNTO
  GTEXTO    = PTEXTO
  Call WORKFLOW (1,"ZED","",GUSER) From AWRK
End

##############################################################
Subprog ENVIA_ERROR_IMPORT(PCORREO,PASUNTO,PTEXTO)
Value Char    PCORREO,PASUNTO
Value Clbfile PTEXTO
  # lanza un workflow para avisar de que la importación ha fallado
  Global Char GCORREO(250),GASUNTO(250),GTEXTO(250)
  GCORREO   = PCORREO
  GASUNTO   = PASUNTO
  GTEXTO    = PTEXTO
  Call WORKFLOW (1,"ZEI","",GUSER) From AWRK
End
