 [M:ZCASGM]ZPRIMURG   = 2
 [M:ZCASGM]ZEPARAUT   = 2
 [M:ZCASGM]ZEPLINCOM  = 2
 [M:ZCASGM]ZEPPEDCOM  = 2
 Affzo [M:ZCASGM]
 ACTION=""
Return
################################################################
$OK
  [M:ZASGM0] = [M:ZCASGM]
  [M:ZASGM1] = [M:ZCASGM]
  Affzo [M:ZASGM0]
Return
