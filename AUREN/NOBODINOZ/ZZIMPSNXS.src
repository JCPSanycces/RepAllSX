#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "RAZCRE"     : Gosub RAZCRE
 When "OUVRE"      : Gosub OUVRE
 When "VALID"      : Gosub VALID
 When "SAIMSK"     : Gosub SAIMSK
 When Default
Endcase
Return
#######################################################################################
$OUVRE
  Global Char     GSTK_ACTION(20)
  Global Integer  GSTK_ERRLIS                       : # Flag erreur liste   (pour ne pas la valider)
  Global Integer  GSTK_NBCUN                         : # Nbre enregistrement CUNSESSION lu
  Global Integer  GSTK_NBCUL                         : # Nbre enregistrement CUNLISTE   lu
  Global Integer  GSTK_NBCUD                         : # Nbre enregistrement CUNLISDET  lu
  Global Integer  GSTK_NBCUDMAJ                      : # Nbre enregistrement CUNLISDET  maj total
  Global Integer  GSTK_NBCUDCUD                      : # Nbre enregistrement CUNLISDET existant maj
  Global Integer  GSTK_NBCUDSTK                      : # Nbre enregistrement CUNLISDET cree sur STOCK existant
  Global Integer  GSTK_NBCUDNEW                      : # Nbre enregistrement CUNLISDET crťť sur STOCK inexistant
  Global Integer  GSTK_NBCUDNUL                      : # Nbre enregistrement CUNLISDET sans maj
  Global Integer  GSTK_NUMCUD                        : # Nį du CUNLISDET importť par session/liste
  Global Integer  GSTK_LISVAL                        : # Nombre de listes validťes
  Global Integer  GSTK_TRACE
  Global Integer  GSTK_ERRSSS
Return
#######################################################################################
$SAIMSK
Return
#######################################################################################
$VALID
Return
