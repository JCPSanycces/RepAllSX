     When 52
 # La version saisie est differentre de celle du lot
Call ECR_TRACE(mess(395,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
     When 53
# pas de version en cours !
Call ECR_TRACE(mess(406,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
     When 54
 # La version saisie est superieure ŕ celle de  article site
Call ECR_TRACE(mess(396,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
     When 55
 # Version mineure inexistante !
Call ECR_TRACE(mess(434,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
     When 56
 # Version majeure ou mineure incorrecte !
Call ECR_TRACE(mess(420,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
     When 57
 # Version majeure non active !
Call ECR_TRACE(mess(397,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD2]ITMREF-","-[M:SNL1]LOT (nolign-1)-","-[M:SNL1]ECCVALMAJ (nolign-1),1) From GESECRAN
#                                                       # hcb 71276 fin
#                                                                                         # hcb 71659 deb
     When 58
 # Import d'inventaire interdit sur une session en multi-comptages
Call ECR_TRACE(mess(441,184,1)-" : "-[M:SNU0]CUNSSSNUM,0) From GESECRAN
#
#                                                                                 # hcb 110327 deb
     When 59
# CUNSERDET : Séquence ŕ zéro ou inexistant
Call ECR_TRACE(mess(456,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 60
# CUNSERDET : N°de serie globale debut ŕ zero ou inexistant
