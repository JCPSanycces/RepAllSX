# numéro de série inexistant
Call ECR_TRACE(mess(43,196,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 66
# numéro de série sorti par une autre piece
Call ECR_TRACE(mess(37,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 67
# numero de série alloué par une autre piece
Call ECR_TRACE(mess(443,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 68
# erreur sur incrémentation des numeroes de series
Call ECR_TRACE(mess(476,197,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 69
# Le nb de no série ne correspond pas ŕ la qté ŕ traiter
Call ECR_TRACE(mess(246,199,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 70
# Suite discontinue des n° de série
Call ECR_TRACE(mess(35,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
     When 71
# CUNLISDET : Séquence ŕ zéro ou inexistant
Call ECR_TRACE(mess(461,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
     When 72
# CUNSERDET : Serseq <> serseq de CUNLISDET
Call ECR_TRACE(mess(462,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
     When 73
# numero de série lié ŕ une autre ligne de stock
Call ECR_TRACE(mess(447,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
     When 74
# Quantité ligne de stock différente du nombre de série
Call ECR_TRACE(mess(491,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:STO]ITMREF-","-mess(50,196,1)-","-num$([F:STO]STOCOU),1) From GESECRAN
Raz GSTK_NBCSD
#                                                                                 # hcb 110327 fin
#                                                                            # hcb x3-68149 deb
     When 75
# Contenant inexistant
Call ECR_TRACE(mess(524,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LPNNUM,1) From GESECRAN
Raz GSTK_NBCSD

     When 76
 # le contenant n'est pas sur le site
Call ECR_TRACE(mess(530,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LPNNUM,1) From GESECRAN
Raz GSTK_NBCSD
     When 77
 # le contenant n'est pas sur le dépot
Call ECR_TRACE(mess(529,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LPNNUM,1) From GESECRAN
Raz GSTK_NBCSD
     When 78
 # L'emplacement saisi ne correspond pas ŕ l'emplacement du no de contenant
Call ECR_TRACE(mess(523,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LPNNUM,1) From GESECRAN
Raz GSTK_NBCSD
     When 79
 # le contenant n'est pas actif
Call ECR_TRACE(mess(528,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LPNNUM,1) From GESECRAN
Raz GSTK_NBCSD
#                                                                                 # hcb x3-68149 fin
                                                                                        # hcb 71659 fin
Endcase

# pour écrire l enregistrement dans le fichier .ERR
GOK = 0

Return


#                                                                                            # hcb 110327 deb
##############################################################################################
# Chargement de l ecran detail inventaire serie SNLSEREW                        CHARG_SNLSW  #
##############################################################################################
$CHARG_SNLSW
Local    Integer J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer ISNLSW
Raz [M:SNLSW1]
ISNLSW = [M:SNLSW]NBLIG
If ISNLSW =  GCOD_INV
   GOK=0
   Return
Endif

#   si pas SERSEQ on importe pas
If !find("[F:CSD]SERSEQ(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 59
   Gosub ECR_ERREUR
   Return
Endif

#   si SERSEQ = 0
If find("[F:CSD]SERSEQ(0)",[M:AOE2]ZONMSK1)
   If [F:CSD]SERSEQ = 0
      WIMPORT_ERR   = 59
      Gosub ECR_ERREUR
      Return
   Endif
Endif
#   si SERSEQ de CUNLISDET <> CUBSERDET
If GSERSEQ <> [F:CSD]SERSEQ
   WIMPORT_ERR   = 72
   Gosub ECR_ERREUR
   Return
Endif

#   si pas SERDEB on importe pas
If !find("[F:CSD]SERDEB(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 60                # N°de serie globale debut ŕ zero ou pas importée
   Gosub ECR_ERREUR
   Return
Endif

#   si SERDEB = 0
If find("[F:CSD]SERDEB(0)",[M:AOE2]ZONMSK1)
   If [F:CSD]SERDEB = ""
      WIMPORT_ERR = 60             # N°de serie globale debut ŕ zero ou pas importée
      Gosub ECR_ERREUR
      Return
   Endif
Endif
#   si on n'importe pas QTY
If !find("[F:CSD]QTY(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 61                # Qty de serie globale ŕ zero ou pas importée
   Gosub ECR_ERREUR
   Return
Endif

#   si QTY = 0
If find("[F:CSD]QTY(0)",[M:AOE2]ZONMSK1)
   If [F:CSD]QTY  = 0
      WIMPORT_ERR = 61             # Qty de serie globale ŕ zero ou pas importée
      Gosub ECR_ERREUR
      Return
   Endif
Endif

nolign = ISNLSW + 1
GTOTSERIE     += [F:CSD]QTY
If GTOTSERIE   > abs(GQTYSTUDEV)
   WIMPORT_ERR = 69             # Le nb de no série ne correspond pas ŕ la qté ŕ traiter
   Gosub ECR_ERREUR
   Return
Endif
[M:SNLSW]QTY     (nolign-1)   = [F:CSD]QTY
[M:SNLSW]SERSEQ  (nolign-1)   = [F:CSD]SERSEQ
[M:SNLSW]SERNUM  (nolign-1)   = [F:CSD]SERDEB
[M:SNLSW]ITMREF  (nolign-1)   = [F:CUD2]ITMREF
[M:SNLSW]STOCOU  (nolign-1)   = [F:CUD]STOCOU

If GQTYSTUDEV < 0
   [M:SNLS]ECART              = "S"
   [M:SNLSW]ECART (nolign-1)  = "S"
Else
   [M:SNLS]ECART              = "E"
   [M:SNLSW]ECART (nolign-1)  = "E"
Endif

[M:SNLS]ITMREF  = [F:CUD2]ITMREF
[M:SNLS]STOCOU  = [F:CUD]STOCOU
If [F:CSD]QTY   = 1
   [M:SNLSW]SERNUMF (nolign-1) = [F:CSD]SERDEB
   WNUMFIN                     = [F:CSD]SERDEB
   Gosub CTR_SERNUM From TRTSNLSERE
   If WIMPORT_ERR <> 0
      Gosub ECR_ERREUR
      Return
   Endif
Else
   # alimentation du no série fin
   WNBSERIE = [F:CSD]QTY
   WNUMDEB  = [F:CSD]SERDEB
   For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          Gosub CTR_SERNUM From TRTSNLSERE
          If WIMPORT_ERR <> 0
             Break
          Else
             WNUMDEB  = WNUMFIN
          Endif
       Else
          WIMPORT_ERR = 68    # erreur sur incrémentation des numeroes de series
          Break
       Endif
   Next J
   If WIMPORT_ERR <> 0
      Gosub ECR_ERREUR
      Return
   Endif
   [M:SNLSW]SERNUMF(nolign-1) = WNUMFIN
Endif

If ISNLSW > 1
   [M:SNLSW1] = [M:SNLSW]
   # Vérification que les plages de no série sont bien croissantes
   # donc qu il ni a pas plusieurs fois les memes numéros
   Sorta [M:SNLSW1]NBLIG [M:SNLSW1]NBLIG Order By [M:SNLSW1]SERNUM([S]indice)
   For Y=1 To [M:SNLSW1]NBLIG-1
       If [M:SNLSW1]SERNUM(Y) <= [M:SNLSW1]SERNUMF(Y-1)
          WIMPORT_ERR = 70             # Suite discontinue des n° de série
          Break
       Endif
   Next Y
   If WIMPORT_ERR <> 0
      Gosub ECR_ERREUR
      Return
   Endif
Endif

GSTK_NBCSD    += 1
ISNLSW        += 1
[M:SNLSW]NBLIG = ISNLSW
Return
#                                                                                            # hcb 110327 end

