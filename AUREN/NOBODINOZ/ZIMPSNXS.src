#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################
# IMPSNXS : Import spécifique des inventaires stock             Henri Combet Novembre 2004   #
#--------------------------------------------------------------------------------------------#
# L'import des inventaires de stock est un import spécifique                                 #
##############################################################################################

$ACTION
Case [L]ACTION
     When "IMP_COMPILE"   : Gosub IMP_COMPILE
     When "IMP_TRTSUP"    : Gosub IMP_TRTSUP
     When "IMP_ZONE"      : Gosub IMP_ZONE
     When "AP_IMPORT"     : Gosub AP_IMPORT
     When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

##############################################################################################
# Début de la génération du traitement WWIxxxxxx, appelé par le SUBIMPOBJ       IMP_COMPILE  #
##############################################################################################
$IMP_COMPILE
Return

##############################################################################################
# Fin de la génération du traitement WWIxxxxxx, appelé par le SUBIMPOBJ          IMP_TRTSUP  #
##############################################################################################
$IMP_TRTSUP
Return

##############################################################################################
# Aprčs chargement de la classe [F] effectué par le WWIxxxxxx                     AP_IMPORT  #
##############################################################################################
$AP_IMPORT
#FPH>
If IMPFIC = "CUD"
  If !clalev([F:ZITM])  :   Local File ITMMASTER[ZITM]  : Endif
  Filter [ZITM] Where EANCOD=[F:CUD]ITMREF
  Read [ZITM] First
  If !fstat
    [F:CUD]ITMREF=[ZITM]ITMREF
  Endif
  Filter [ZITM]
Endif
Return
#FPH<
##############################################################################################
# Début import, étiquette appelée directement depuis le SUBIMPOBJ                     OUVRE  #
##############################################################################################
$OUVRE
GABREV="SNX" : GFLAG=""
#-----
[L]ACTION="OUVRE"   : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSNX
If !clalev([M:SNL0])  Local Mask SNL0      [SNL0]  : Endif
If !clalev([M:SNL1])  Local Mask SNL1      [SNL1]  : Endif
If !clalev([M:SIW])   Local Mask STOINVW   [SIW]   : Endif

If !clalev([F:CUN2])  Local File CUNSESSION [CUN2] : Endif
If !clalev([F:CUL2])  Local File CUNLISTE   [CUL2] : Endif
If !clalev([F:CUL3])  Local File CUNLISTE   [CUL3] : Endif
If !clalev([F:CUD2])  Local File CUNLISDET  [CUD2] : Endif
If !clalev([F:ACV])   Local File ACTIV      [ACV]  : Endif
If !clalev([F:STC])   Local File STOLOC     [STC]  : Endif
If !clalev([F:TUN])   Local File TABUNIT    [TUN]  : Endif
If !clalev([F:STS])   Local File STOSER     [STS]  : Endif
If !clalev([F:SLF])   Local File STOLOTFCY  [SLF]  : Endif
#                                                                             # hcb 110327 deb
If !clalev([F:CSD])    Local File CUNSERDET [CSD]   : Endif
If !clalev([M:SNLS])   Local Mask SNLSERE   [SNLS]  : Endif
If !clalev([M:SNLSW])  Local Mask SNLSEREW  [SNLSW] : Endif
If !clalev([M:SNLSW1]) Local Mask SNLSEREW  [SNLSW1]: Endif
If !clalev([F:LPN])    Local File LPN       [LPN]   : Endif             # hcb x3-68149
If !clalev([F:CUD1])   Local File CUNLISDET [CUD1]  : Endif             # hcb x3-68149
If !clalev([M:SNL1W])  Local Mask SNL1W     [SNL1W] : Endif             # hcb X3-68149

#                                                                             # hcb 110327 deb

If GWRHACT = 2
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif

#lecture code activite nombre de lignes par liste d inventaire
Global Integer GCOD_INV
Read [ACV]CODACT="INV"
If !fstat
   GCOD_INV =[F:ACV]DIME
Endif


If !clalev([F:SRT])  Local File STKTRS [SRT] : Endif
GABREV="SNX" : GFLAG=""
#----- Sélection de la transaction d'un bordereau d inventaire---#
# lecture de la premiere transaction inventaire pour recuperer TRSFAM et ENTCOD lors
#               de la validation des listes ...
Read [SRT] SRT0=6;GFLAG
If fstat
  Filter [SRT] Where SRTTYP=6 & ENAFLG=2
  Read [SRT] First
  Filter [SRT]
  If fstat
    If GTRACE<>""
      Call ECR_TRACE(mess(114,192,1),1) From GESECRAN
    Endif
    OK=0 : Return
  Endif
  GFLAG   = [F:SRT]SRTNUM
  GSNLNUM = [F:SRT]SRTNUM       # hcb 50197
  [F:SRT]IPTDATCOD = 3
Endif

#---------------------------------------------------------------#
# Controle de la vraisemblance du parametrage                   #
#   Rubriques obligatoires :                                    #
#     STOFCY : pour recherche dans le STOCK                     #
#     CUNSESSION :                                              #
#     ARTICLE ou LOC                                            #
#     ITMLISNUM : cela permet de savoir si nouvelle ligne       #
#                                                               #
#---------------------------------------------------------------#

Gosub FLD_MODELE From TRTX3IMP
#   si on n'importe pas le n° de session
If !find("[F:CUN]CUNSSSNUM(0)",[M:AOE2]ZONMSK1)
  #----- Paramčtrage erroné ! -----#
  OK=0 : GERR=1 : GMESSAGE=mess(214,133,1)-" : "-"(CUNSSSNUM)"-mess(4,65,1) : Return
Endif
#   si on n'importe pas le STOFCY
If !find("[F:CUN]STOFCY(0)",[M:AOE2]ZONMSK1) &
&  !find("[F:CUL]STOFCY(0)",[M:AOE2]ZONMSK1) &
&  !find("[F:CUD]STOFCY(0)",[M:AOE2]ZONMSK1)
  #----- Paramčtrage erroné ! -----#
  OK=0 : GERR=1 : GMESSAGE=mess(214,133,1)-" : "-"(STOFCY)"-mess(4,65,1) : Return
Endif
# controle parametrage du cunlisdet

#   si on n'importe pas l article et pas l emplacement
If !find("[F:CUD]ITMREF(0)",[M:AOE2]ZONMSK1) &
&  !find("[F:CUD]LOC(0)",[M:AOE2]ZONMSK1)
  #----- Paramčtrage erroné ! -----#
  OK=0 : GERR=1 : GMESSAGE=mess(214,133,1)-" : "-"(ITMREF/LOC)"-mess(4,65,1) : Return
Endif
#   si on n'importe pas les quantites comptées et stk nul
If !find("[F:CUD]QTYPCUNEW(0)",[M:AOE2]ZONMSK1) &
&  !find("[F:CUD]QTYSTUNEW(0)",[M:AOE2]ZONMSK1) &
&  !find("[F:CUD]ZERSTOFLG(0)",[M:AOE2]ZONMSK1)
  #----- Paramčtrage erroné ! -----#
  OK=0 : GERR=1 : GMESSAGE=mess(214,133,1)-" : "-"(QTYPCUNEW/QTYSTUNEW/ZERSTOFLG)"-mess(4,65,1) : Return
Endif
#   si on n'importe itmlisnum
If !find("[F:CUD]ITMLISNUM(0)",[M:AOE2]ZONMSK1)
  #----- Paramčtrage erroné ! -----#
  OK=0 : GERR=1 : GMESSAGE=mess(214,133,1)-" : "-"(ITMLISNUM)"-mess(4,65,1) : Return
Endif

#----- Variables locales -----#
Local  Integer  J, K
Local  Char     SYMBOL2(30)
#----- Globales ŕ definir pour import inventaire -----#

Global Char     GSTK_ACTION(20)                    : # Nom de l'action  ????????

Global Libelle  GSTK_TRACE      : GSTK_TRACE =1    : # Trace détaillée si =2
Global Char     GSTK_MESS(100)                     : # Message pour trace
Global Char     GSTK_PGM(GLONADC)                  : # Traitement pour trace
Global Char     GSTK_ACT(30)                       : # Action pour trace

Global Char     GSTK_CUNSSSNUM(GLONVCR)            : # Numéro de session
Global Char     GSTK_CUNLISNUM(GLONVCR)            : # Numéro de liste
Global Libelle  GSTK_CUNLISSTA                     : # Indicateur validation
Global Libelle  GSTK_CUNSESSION                    : # Indicateur existance session importée
Global Libelle  GSTK_CUNLISTE                      : # Indicateur existance liste   importée
Global Char     GSTK_STOFCY                        : # Site de stockage

Global Integer  GSTK_ERRLIS                        : # Flag erreur liste   (pour ne pas la valider)
Global Integer  GSTK_ERRSSS                        : # Flag erreur Session (pour ne pas la valider)
Global Integer  GSTK_TYPIMP                        : # Flag Type inventaire  (1 = complet)

Global Integer  GSTK_NBCUN                         : # Nbre enregistrement CUNSESSION lu
Global Integer  GSTK_NBCUL                         : # Nbre enregistrement CUNLISTE   lu
Global Integer  GSTK_NBCUD                         : # Nbre enregistrement CUNLISDET  lu
Global Integer  GSTK_NBCUDMAJ                      : # Nbre enregistrement CUNLISDET  maj total
Global Integer  GSTK_NBCUDCUD                      : # Nbre enregistrement CUNLISDET existant maj
Global Integer  GSTK_NBCUDSTK                      : # Nbre enregistrement CUNLISDET cree sur STOCK existant
Global Integer  GSTK_NBCUDNEW                      : # Nbre enregistrement CUNLISDET créé sur STOCK inexistant
Global Integer  GSTK_NBCUDNUL                      : # Nbre enregistrement CUNLISDET sans maj
Global Integer  GSTK_NUMCUD                        : # N° du CUNLISDET importé par session/liste
Global Integer  GSTK_LISVAL                        : # Nombre de listes validées
#                                                                                    # hcb 110327 deb
Global Integer  GSTK_NBCSD                         : # Nbre enregistrement CUNSERDET importé d'un CUD
Global Integer  GSTK_NBCSDTOT                      : # Nbre enregistrement CUNSERDET importé total
Global Decimal  GQTYSTUDEV                         : # Ecart calculée si article et en série global
Global Integer  GTOTSERIE                          : # Nombre de serie globale pour un CUNLISDET
Global Integer  GSERSEQ                            : # SERSEQ du CUNLISDET
Raz GSTK_NBCSD
Raz GSTK_NBCSDTOT
#                                                                                    # hcb 110327 end

Raz  GSTK_ERRLIS
Raz  GSTK_ERRSSS
Raz  GSTK_NBCUN
Raz  GSTK_NBCUL
Raz  GSTK_NBCUD
Raz  GSTK_NBCUDMAJ
Raz  GSTK_NBCUDCUD
Raz  GSTK_NBCUDSTK
Raz  GSTK_NBCUDNEW
Raz  GSTK_NBCUDNUL
Raz  GSTK_NUMCUD
Raz  GSTK_TYPIMP
#-----
Return

##############################################################################################
# Nouveau document ŕ importer appelé directement depuis le traitement généré WWIxxxxx RAZCRE #
##############################################################################################
$RAZCRE
GREP="C"
Raz [M:SNU0], [M:SNU1], [M:SNU2], [M:SNL0] , [M:SNL1] , [M:SNLS] , [M:SNLSW]    # hcb 110327
Raz GSTK_CUNSSSNUM, GSTK_CUNLISNUM, GSTK_CUNLISSTA
[L]ACTION="RAZCRE"   : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSNX
Return

##############################################################################################
# Chargement masques écrans, appelé directement depuis le traitement généré WWIxxxxx SAIMSK  #
##############################################################################################
$SAIMSK

#------------------------------------------------------------------------------#
# traitement détail CUNSESSION                                  CUNSESSION CUN #
#------------------------------------------------------------------------------#

Case IMPFIC
  When "CUN"
    GSTK_NBCUN += 1
    Raz GSTK_TYPIMP
    Raz GSTK_ERRSSS

    Default File [CUN]
    [F:CUN2  ] = [F:CUN]
# initialisation flag existance session ŕ oui (=0)
    GSTK_CUNSESSION = 0
    Raz GSTK_STOFCY
    Raz GSTK_CUNSSSNUM
    If find("[F:CUN]STOFCY(0)",[M:AOE2]ZONMSK1) & [F:CUN2]STOFCY <> ""
       GSTK_STOFCY = [F:CUN2]STOFCY
    Endif

#**********************************************************
# import d un inventaire deja existant  (CUNSESSION <> "")
#**********************************************************
    If [F:CUN2]CUNSSSNUM<>""
       [M:SNU0]CUNSSSNUM = [F:CUN2]CUNSSSNUM
       GSTK_CUNSSSNUM    = [M:SNU0]CUNSSSNUM
       Look [CUN] CUN0=[M:SNU0]CUNSSSNUM
       If !fstat
          GREP=""
          Read [CUN] CUN0=[M:SNU0]CUNSSSNUM
          If !fstat
             [M:SNU0]=[F:CUN] : [M:SNU1]=[F:CUN] : [M:SNU2]=[F:CUN]
             If [F:CUN]CUNSSSSTA > 2
                 WIMPORT_ERR = 29
                 Gosub ECR_ERREUR
# initialisation flag  session validéé  (=2)
                 GSTK_CUNSESSION = 2
             Endif
#                                                                                         # hcb 71659 deb
             If [F:CUN]MULCTGFLG = 2
                 WIMPORT_ERR = 58           # Import d'inventaire interdit sur une session en multi-comptages
                 Gosub ECR_ERREUR
                 GSTK_CUNSESSION = 2
             Endif
#                                                                                         # hcb 71659 fin
          Else
# initialisation flag existance session ŕ non (=1)
             GSTK_CUNSESSION = 1
# session inexistante
             WIMPORT_ERR = 30
             Gosub ECR_ERREUR
          Endif
       Else
# initialisation flag existance session ŕ non (=1)
          GSTK_CUNSESSION = 1
# session inexistante
          WIMPORT_ERR = 30
          Gosub ECR_ERREUR
       Endif
#**********************************************************
# import creation d inventaire  (CUNSESSION = "")
#**********************************************************
    #----- Ecran entęte -----#
    Else

# initialisation flag existance session ŕ non (=1)
       GSTK_CUNSESSION = 1
       GREP            ="C"

       Default Mask [SNU0]

       [M:SNU0]            = [F:CUN2]
       [M:SNU0]CUNSSSSTA   = 1   # en création

       Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
       Call SAIMSK("SNX","IMP_ZONE","SUBIMPOBJ") From W0SNU0
       If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
       Setmode
       If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
      #----- Ecran paramčtres -----#
       Default Mask [SNU1]
       [M:SNU1]              = [F:CUN2]
      # Valeurs par défaut si pas importée
      If [M:SNU1]MAXLIG      = 0 | [M:SNU1]MAXLIG  > GCOD_INV
         [M:SNU1]MAXLIG      = GCOD_INV
      Endif
      If [M:SNU1]CUNSSSTYP   = 0      # Type inventaire : Article par defaut
         [M:SNU1]CUNSSSTYP   = 1
      Endif
      If [M:SNU1]CUNSRTCOD   = 0
         [M:SNU1]CUNSRTCOD   = 1      # Tri inventaire :  Article / emplacement par defaut
      Endif
      If [M:SNU1]PRCLIG      = 0      # % ligne : 100 par défaut
         [M:SNU1]PRCLIG      = 100
      Endif
      If [F:CUN]CUNLASFLG    = 0
         [F:CUN]CUNLASFLG    = 1   # global ŕ non
      Endif
      If [F:CUN]CUNLASFLG >  2
         [F:CUN]CUNLASFLG    = 1   # global ŕ non
      Endif
      If [F:CUN]MULCTGFLG =  0
         [F:CUN]MULCTGFLG    = 1   # Multi-comptage ŕ non                                 # hcb 71659
      Endif
      If [F:CUN]MULCTGFLG >  2
         [F:CUN]MULCTGFLG    = 1   # Multi-comptage ŕ non                                 # hcb 71659
      Endif
      If GWRHACT = 2
         If [M:SNU1]CUNSSSTYP   = 2      # Type inventaire : emplacement
            [M:SNU1]CUNITMWRH   = 1
         Endif
         If [M:SNU1]CUNITMWRH   = 2      # Type inventaire : Article depot
            [M:SNU1]MULLISFLG   = 1
         Endif
      Endif

# rubriques "non importables"

      [M:SNU1]CUNSSSMOD      = 1      # choix traitement ŕ 1 : Manuel
      If dim([M:SNU1]LOCPOS) > 0
         [M:SNU1]LOCPOS  = 10
      Endif
      [M:SNU1]CUNNULSTK      = 1      # Articles sans stock ŕ non
      [M:SNU1]MULLISFLG      = 1      # Multi-listes ŕ non
      [M:SNU1]ITMNBR         = 9999   # Nombre d article
      [M:SNU1]CUNSSSDAT      = date$
      [M:SNU1]ABCCLSA        = 2
      [M:SNU1]ABCCLSB        = 2
      [M:SNU1]ABCCLSC        = 2
      [M:SNU1]ABCCLSD        = 2

       Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
       Call SAIMSK("SNX","IMP_ZONE","SUBIMPOBJ") From W0SNU1
       If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
       Setmode
       If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
      #----- Ecran sélections -----#
      # seul les bornes articles et emplacement sont prises en comptes ....

       Default Mask [SNU2]
       Raz [M:SNU2]
# si import complet article prise en compte des bornes articles si présentes
       If [M:SNU1]CUNLASFLG   = 2
          [M:SNU1]CUNSSSTYP   = 1                         # type inventaire = 1
          If find("[F:CUN]ITMREFSTR(0)",[M:AOE2]ZONMSK1)
             [M:SNU2]ITMREFSTR = [F:CUN2]ITMREFSTR
          Endif
          If find("[F:CUN]ITMREFEND(0)",[M:AOE2]ZONMSK1)
             [M:SNU2]ITMREFEND = [F:CUN2]ITMREFEND
          Endif
       Endif
# si import complet emplacement prise en compte des bornes emplacements si présentes
       If [M:SNU1]CUNSSSTYP   = 2
          [M:SNU1]CUNLASFLG   = 1                        # Partiel
          [M:SNU1]MULLISFLG   = 1
          If find("[F:CUN]LOCSTR(0)",[M:AOE2]ZONMSK1)
             If dim([M:SNU2]LOCSTR) > 0
               [M:SNU2]LOCSTR = [F:CUN2]LOCSTR
             Endif
          Endif
          If find("[F:CUN]LOCEND(0)",[M:AOE2]ZONMSK1)
             If dim([M:SNU2]LOCEND) > 0
                [M:SNU2]LOCEND = [F:CUN2]LOCEND
             Endif
          Endif
       Endif
# si import complet article-dépot prise compte des bornes dépots et articles si présentes
       If dim([M:SNU1]CUNITMWRH) >0 & [M:SNU1]CUNITMWRH = 2
          If find("[F:CUN]WRHSTR(0)",[M:AOE2]ZONMSK1)
             If dim([M:SNU2]WRHSTR) > 0
               [M:SNU2]WRHSTR = [F:CUN2]WRHSTR
             Endif
          Endif
          If find("[F:CUN]WRHEND(0)",[M:AOE2]ZONMSK1)
             If dim([M:SNU2]WRHEND) > 0
                [M:SNU2]WRHEND = [F:CUN2]WRHEND
             Endif
          Endif
          If find("[F:CUN]ITMREFSTR(0)",[M:AOE2]ZONMSK1)
             [M:SNU2]ITMREFSTR = [F:CUN2]ITMREFSTR
          Endif
          If find("[F:CUN]ITMREFEND(0)",[M:AOE2]ZONMSK1)
             [M:SNU2]ITMREFEND = [F:CUN2]ITMREFEND
          Endif
       Endif

       Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
       Call SAIMSK("SNX","IMP_ZONE","SUBIMPOBJ") From W0SNU2
       If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
       Setmode
       If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
      #----- Traitement champs invisibles -----#
      #----- Création de la session d'inventaire -----#
       Gosub CREATION_CUN
       If GOK<1 mkstat=1 : GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
    Endif

#------------------------------------------------------------------------------#
# traitement détail CUNLISTE                                      CUNLISTE CUL #
#------------------------------------------------------------------------------#

  When "CUL"
    Raz [M:SNLSW]                                             # hcb 110327
    GSTK_NBCUL += 1
# si la session importée existe on traite les enregistrements CUL associés
    If  GSTK_CUNSESSION = 0
        [F:CUL2]        = [F:CUL]
        If [M:SNL1]NBLIG<>0
           Gosub IMPORT_DETAIL
        Endif
        If [M:SNU0]CUNSSSNUM = "" & [F:CUL2]CUNSSSNUM <> ""
           Read [CUN] CUN0=[F:CUL2]CUNSSSNUM
           If fstat  mkstat=1 : GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
           [M:SNU0]=[F:CUN] : [M:SNU1]=[F:CUN] : [M:SNU2]=[F:CUN]
           [M:SNL0]=[F:CUN]
           If [F:CUN]CUNSSSSTA > 2
              WIMPORT_ERR = 29
              Gosub ECR_ERREUR
# initialisation flag  session validéé  (=2)
              GSTK_CUNSESSION = 2
           Endif

        Endif
        GSTK_CUNSSSNUM = [M:SNU0]CUNSSSNUM
        GSTK_STOFCY    = [M:SNU0]STOFCY
        If [F:CUL2]CUNLISNUM <> ""
            GSTK_CUNLISNUM = [F:CUL2]CUNLISNUM
        Endif
        Raz  GSTK_ERRLIS

        If [F:CUL2]STOFCY <> ""
           If [F:CUL2]STOFCY <> GSTK_STOFCY
              GSTK_STOFCY    =  [F:CUL2]STOFCY
           Endif
        Endif
# si type d import = complet  on ne lit pas la liste ...

        If GSTK_TYPIMP <> 1
           Read [CUL] CUL0=[M:SNU0]CUNSSSNUM;GSTK_CUNLISNUM
           If fstat  Raz [F:CUL] : Endif
           [M:SNL0]          = [F:CUL]
           [M:SNL0]WRHCUL    = [F:CUL]WRH
# c est la date de creation des enregistrements bidon stojou
#          [M:SNL0]IPTDAT    = [F:CUL]CREDAT   # hcb 63845
           [M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845
           If [M:SNL0]IPTDAT = [0/0/0]
              [M:SNL0]IPTDAT = date$
           Endif
           [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # hcb 63845
        Endif
        If [F:CUL2]CUNLISSTA = 5
           GSTK_CUNLISSTA=[F:CUL2]CUNLISSTA
        Else
           GSTK_CUNLISSTA=1
        Endif
    Endif

#------------------------------------------------------------------------------#
# traitement détail CUNLISDET                                    CUNLISDET CUD #
#------------------------------------------------------------------------------#

  When "CUD"
    Local Decimal LSTOCOU      # hcb 31997


    GSTK_NBCUD += 1
# si type d import = complet initialisation de gstk_cunlisnum car la liste est cree au moment de l import
#    If GSTK_TYPIMP = 1
#       Raz GSTK_CUNLISNUM
#    Endif

# si la session importée existe on traite les enregistrements CUD associés
    If  GSTK_CUNSESSION = 0
        [F:CUD2]        = [F:CUD]
# Raz flag ajout de ligne d inventaire  (géré par MOD_INV)
        Raz GAJOUINV
# Raz flag ouverture fenętre saisie des inventaires (ecran SNL1)
# gouvinv = 4 clic droit sur fin tableau (ajout d un article)
        Raz GOUVINV

        If [M:SNL1]NBLIG<>0 & (([F:CUD2]CUNSSSNUM<>"" & [F:CUD2]CUNSSSNUM<>[M:SNU0]CUNSSSNUM) |
&                           ([F:CUD2]CUNLISNUM<>"" & [F:CUD2]CUNLISNUM<>GSTK_CUNLISNUM))
           Raz GSTK_NUMCUD
           Raz GSTK_ERRLIS
           Gosub IMPORT_DETAIL
        Endif
        GSTK_NUMCUD += 1
        If [F:CUD2]CUNLISNUM    <> ""
           If [F:CUD2]CUNLISNUM <> GSTK_CUNLISNUM
              GSTK_CUNLISNUM    =  [F:CUD2]CUNLISNUM
              Read [CUL] CUL0=GSTK_CUNSSSNUM;GSTK_CUNLISNUM
              If fstat  Raz [F:CUL] : Endif
              [M:SNL0]=[F:CUL]
              [M:SNL0]WRHCUL    = [F:CUL]WRH
# c est la date de creation des enregistrements bidon stojou
#             [M:SNL0]IPTDAT    = [F:CUL]CREDAT   # hcb 63845
              [M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845

              If [M:SNL0]IPTDAT = [0/0/0]
                 [M:SNL0]IPTDAT = date$
              Endif
              [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # hcb 63845
# si rupture CUL dans les enregistrements CUD on ne valide pas
# le flag validation doit etre parametre dans les enregistremnts CUL
              GSTK_CUNLISSTA    =1
           Endif
        Endif
        If [F:CUD2]STOFCY       <> ""
            If [F:CUD2]STOFCY   <> GSTK_STOFCY
               GSTK_STOFCY      =  [F:CUD2]STOFCY
            Endif
        Endif
        Gosub COHERENCE_CUD
        If WIMPORT_ERR   = 0
           GSTK_CUNSSSNUM=[M:SNU0]CUNSSSNUM
# si import d une ligne existante on charge directement
           If [F:CUD2]ITMLISNUM<>0
              Read [CUD]CUD0=GSTK_CUNSSSNUM;GSTK_CUNLISNUM;[F:CUD2]ITMLISNUM
              If fstat
                 WIMPORT_ERR = 18
                 Gosub ECR_ERREUR
                 Return
              Endif
# si le détail est abandonné ou validé on ne peux pas le modifier
              If [F:CUD]CUNLISSTA > 2
                 WIMPORT_ERR = 28
                 Gosub ECR_ERREUR
                 Return
              Endif


# lecture de la ligne de stock pour recuperer l alloué
              Raz [F:STO]                      # hcb 91097
              If [F:CUD]STOCOU <> 0            # hcb 41793
                 Read [STO]STO0=GSTK_STOFCY;[F:CUD]STOCOU
                 If fstat
                    Raz [F:STO]
                    LSTOCOU = [F:CUD]STOCOU    # hcb 31997
                    WIMPORT_ERR = 7
                    Gosub ECR_ERREUR
                    Return
                 Endif                         # hcb 41793
              Endif
              If [F:ITM]ITMREF  <>[F:CUD2]ITMREF
                 Read [ITM] ITM0= [F:CUD2]ITMREF
                 If fstat
                    WIMPORT_ERR = 14
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif
              If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>GSTK_STOFCY
                 Read [ITF]ITF0=[F:ITM]ITMREF;GSTK_STOFCY
                 If fstat
                    WIMPORT_ERR = 15
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif
              If GWRHACT = 2 & dim([M:SNU1]CUNITMWRH) >0 & [M:SNU1]CUNITMWRH = 2
                 Read [ITW]ITW0=[F:CUD2]ITMREF;[F:CUD2]WRH
                 If fstat
                    WIMPORT_ERR = 36
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif

              Gosub CHARG_SNL1
           Else
      #---- Recherche de la ligne stock correspondante  -----#
              Raz [F:CUD]
              If [F:ITM]ITMREF  <>[F:CUD2]ITMREF
                 Read [ITM] ITM0= [F:CUD2]ITMREF
                 If fstat
                    WIMPORT_ERR = 14
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif
              If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>GSTK_STOFCY
                 Read [ITF]ITF0=[F:ITM]ITMREF;GSTK_STOFCY
                 If fstat
                    WIMPORT_ERR = 15
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif
      #------ l article doit etre en gestion stock

              If [F:ITF]STOMGTCOD < 2
                  WIMPORT_ERR = 16
                  Gosub ECR_ERREUR
                  Return
              Endif
              If GWRHACT = 2 & dim([M:SNU1]CUNITMWRH) >0 & [M:SNU1]CUNITMWRH = 2
                 Read [ITW]ITW0=[F:CUD2]ITMREF;[F:CUD2]WRH
                 If fstat
                    WIMPORT_ERR = 36
                    Gosub ECR_ERREUR
                    Return
                 Endif
              Endif
      #------ recherche de la ligne de stock ou ligne cunlisdet
              Gosub RECH_STOCK
              If WIMPORT_ERR = 0
                 Gosub CHARG_SNL1
              Endif
           Endif
        Endif
    Endif
#                                                                              # hcb 110327 deb
#------------------------------------------------------------------------------#
# traitement détail CUNSERDET                                    CUNSERDET CSD #
#------------------------------------------------------------------------------#

  When "CSD"
    If GQTYSTUDEV <> 0
       Gosub CHARG_SNLSW
    Endif
#                                                                              # hcb 110327 end

Endcase
Return


##############################################################################################
# Equivalent ŕ la saisie d'un champ fiche                                          IMP_ZONE  #
##############################################################################################
# IMPFIC : Abréviation du fichier                                                            #
# IMPMSK : Nom de l'écran en cours                                                           #
# IMPZON : Nom du champ en cours                                                             #
# IMPMOD : Déclenche l'Aprčs_modif                                                           #
# OK     : Conditionne IMP_ZONE standard                                                     #
##############################################################################################
$IMP_ZONE
If GREP="A"  Return : Endif
If dim([L]WTST_CHAMP)<1  Local Libelle  WTST_CHAMP : Endif
Case IMPFIC
  When "CUN"
    Case IMPMSK
      When "SNU0"
        If find("[F:CUN]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
           If evalue("[M:SNU0]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:CUN]"+IMPZON)
              Assign "[M:SNU0]"+IMPZON+"("+num$(indice)+")" With evalue("[F:CUN]"+IMPZON)
              IMPMOD=1
           Endif
          OK=0
        Endif
      When "SNU1"
        If find("[F:CUN]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
           If evalue("[M:SNU1]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:CUN]"+IMPZON)
              Assign "[M:SNU1]"+IMPZON+"("+num$(indice)+")" With evalue("[F:CUN]"+IMPZON)
              IMPMOD=1
           Endif
           OK=0
        Endif
      When "SNU2"
        If find("[F:CUN]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
           If evalue("[M:SNU2]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:CUN]"+IMPZON)
              Assign "[M:SNU2]"+IMPZON+"("+num$(indice)+")" With evalue("[F:CUN]"+IMPZON)
              IMPMOD=1
           Endif
           OK=0
        Endif
    Endcase
  When "CUL"
  When "CUD"
Endcase
Return

##############################################################################################
# Rupture session, appelé directement depuis le SUBIMPOBJ                             VALID  #
# import du detail , validation session                                                      #
##############################################################################################
$VALID
Gosub IMPORT_DETAIL
#----- Validation de la session inventaire si demandé si pas erreur et si import complet
If GSTK_CUNLISSTA=5 & GSTK_TYPIMP = 1 & GSTK_ERRSSS <> 2
   WIMPORT_ERR = 32
   Gosub ECR_ERREUR
#   Gosub TRT_VALIDSESSION          : # pour le moment je refuse (hcb) d activer la validation
Endif
Return
##############################################################################################
# Rupture liste                                                               IMPORT_DETAIL  #
# Validation de la liste                                                                     #
##############################################################################################
$IMPORT_DETAIL

#----- Mŕj ou création du détail inventaire -----#
If [M:SNL1]NBLIG<>0
  [M:SNL1]CUNLISNUM = [M:SNL0]CUNLISNUM # Issue X3-158744 - 2019-10-28 by MAE : affectation du CUNLISNUM
   Gosub MOD_INV From STKINV
# si ajout de lignes il faut renumeroter la liste et mettre ŕ jour le nombre de ligne de la liste
   If GAJOUINV = 1
      Gosub RENUM_CUD From STKINV
# creer les enregistrement bidons
      Gosub TRT_ECRSTJBID From IMPSNXS
   Endif

#----- Validation du détail inventaire si demandé si pas erreur si pas import complet
   If GSTK_CUNLISSTA=5 & GSTK_TYPIMP = 0 & GSTK_ERRLIS <> 2
      Gosub  TRT_VALIDLISTE
   Endif
Endif

Raz [M:SNL1]
Raz [M:SNL0]
Raz [M:SIW]
Raz [M:SNLSW]                                             # hcb 110327
Raz [M:SNL1W]                                   # hcb x3-68149
Raz GAJOUINV
Raz GOUVINV

Return

##############################################################################################
# Fin import                                                                      IMP_FERME  #
##############################################################################################
$IMP_FERME

[L]ACTION="FERME"       : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSNX
If dim(GSTK_MESS)>0  Kill GSTK_MESS,  GSTK_PGM,    GSTK_ACT    : Endif
If GIMPORT               # hcb 89223
   Call ECR_TRACE("****************************************************************************",0) From GESECRAN
   #   Recapitulatifs
   Call ECR_TRACE("*** "-mess(3,380,1)-" ***",0) From GESECRAN
   Call ECR_TRACE("****************************************************************************",0) From GESECRAN
   # nombre enregistrement CUNSESSION importé
   Call ECR_TRACE(mess(179,184,1)-" : "-num$(GSTK_NBCUN),0)    From GESECRAN
   # nombre enregistrement CUNLISTE importé
   Call ECR_TRACE(mess(180,184,1)-" : "-num$(GSTK_NBCUL),0)    From GESECRAN
   # Nombre d 'enregistrements CUNLISDET ŕ importer total
   Call ECR_TRACE(mess(181,184,1)-" : "-num$(GSTK_NBCUD),0)    From GESECRAN
   # nombre enregistrement CUNLISDET importe sans maj
   Call ECR_TRACE(mess(182,184,1)-" : "-num$(GSTK_NBCUDNUL),0) From GESECRAN
   # nombre enregistrement CUNLISDET maj total
   Call ECR_TRACE(mess(183,184,1)-" : "-num$(GSTK_NBCUDMAJ),0) From GESECRAN
   # nombre enregistrement CUNLISDET existant maj
   Call ECR_TRACE(mess(184,184,1)-" : "-num$(GSTK_NBCUDCUD),0) From GESECRAN
   # nombre enregistrement CUNLISDET cree sur STOCK inexistant
   Call ECR_TRACE(mess(185,184,1)-" : "-num$(GSTK_NBCUDSTK),0) From GESECRAN
   # nombre enregistrement CUNLISDET créee sur STOCK inexistant
   Call ECR_TRACE(mess(186,184,1)-" : "-num$(GSTK_NBCUDNEW),0) From GESECRAN
   # nombre enregistrement CUNSERDET importé                                              # hcb 110327
   Call ECR_TRACE(mess(459,184,1)-" : "-num$(GSTK_NBCSDTOT+GSTK_NBCSD),0) From GESECRAN   # hcb 110327
   # nombre de listes validées
   Call ECR_TRACE(mess(199,184,1)-" : "-num$(GSTK_LISVAL),0) From GESECRAN
   Call ECR_TRACE("****************************************************************************",0) From GESECRAN
Endif                    # hcb 89223

Kill GSTK_ACTION,   GSTK_TRACE,    GSTK_NBCUN,    GSTK_NBCUL
Kill GSTK_NBCUD,    GSTK_NBCUDMAJ, GSTK_NBCUDCUD, GSTK_NBCUDSTK, GSTK_NBCUDNEW, GSTK_NBCUDNUL
Kill GSTK_ERRLIS,   GSTK_ERRSSS,   GSTK_NUMCUD,   GSTK_LISVAL
Return

##############################################################################################
# Création de la session d'inventaire                                          CREATION_CUN  #
##############################################################################################
$CREATION_CUN
If GREP=""  Return : Endif
[L]OK=1 : Raz GERREUR
#-----
[L]ACTION="VERIF_CRE"  : Gosub ACTION From GOBJSUB
If ![L]OK  GOK=0 : Goto FIN_GENSNX : Endif
Call DEBTRANS From GLOCK
#-----
$TR_GENSNX
GOK=1
Trbegin [CUN]
  Raz [F:CUN]
  [F:CUN]=[M:SNU0]
  [F:CUN]=[M:SNU1]
  [F:CUN]=[M:SNU2]
  Default File [CUN]
  [L]ACTION="INICRE"   : Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENSNX  Elsif !GOK  Goto AB_GENSNX : Endif
  [F:CUN]CREUSR=GUSER
  [F:CUN]CREDAT=date$
  [F:CUN]CUNNULSTK      = 1   # Articles sans stock ŕ non
# dans le cas d un import de creation d inventaire partiel on cree dans la foulée une liste
# on met donc le flag statut ŕ 2 : "a compter"
  If [F:CUN]CUNLASFLG <> 2 & [F:CUN]CUNSSSTYP <> 2
     [F:CUN]CUNSSSSTA = 2
  Endif
  Write [CUN]
  If fstat  GOK=0 : Call FSTA("CUN") From GLOCK : Goto AB_GENSNX : Endif
  [L]ACTION="CREATION" : Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENSNX  Elsif !GOK  Goto AB_GENSNX : Endif
Case GREP

  When "C" : Call TRACE( 0,mess(14,721,1)-[F:CUN]CUNSSSNUM)  From SUBIMPOBJ  : # Création session inventaire
Endcase

[M:SNU0]=[F:CUN]
[M:SNU1]=[F:CUN]
[M:SNU2]=[F:CUN]
GSTK_CUNSSSNUM  = [F:CUN]CUNSSSNUM
# initialisation flag existance session ŕ oui (=0)
GSTK_CUNSESSION = 0

If GREP="C"
   [L]ACTION="APRES_CRE" : Gosub ACTION From GOBJSUB
Elsif GREP="A"
   Unlock=[L]SYMBOL2
  [L]ACTION="AP_ANNULE" : Gosub ACTION From GOBJSUB
Endif

# apres avoir cree la session il faut creer les listes
# si CUNSSSTYP = 2 : import complet emplacementes CUNLISTE et CUNLISDET sont crées suivant le contenu
#                    du parametrage de l indentificateur cunsession
#                    puis les CUNLISDET seront mis ŕ jour avec le contenu  de l indentificateur
#                    cunlisdet imorté
# si CUNLASFLG = 2 : import complet article les CUNLISTE et CUNLISDET sont crées suivant le contenu
#                    du parametrage de l indentificateur cunsession
#                    puis les CUNLISDET seront mis ŕ jour avec le contenu  de l indentificateur
#                    cunlisdet imorté
# si CUNITMWRH = 2 : import complet article-depot les CUNLISTE et CUNLISDET sont crées suivant le contenu
#                    du parametrage de l indentificateur cunsession
#                    puis les CUNLISDET seront mis ŕ jour avec le contenu  de l indentificateur
#                    cunlisdet imorté
# autre cas : import partiel : on cree une CUNLISTE  sans CUNLISDET . les CUNLISDET seront crées
#             avec le contenu  de l indentificateur cunlisdet imorté
#
If [M:SNU1]CUNLASFLG = 2 |  [M:SNU1]CUNSSSTYP  = 2 |(dim([M:SNU1]CUNITMWRH) > 0 & [M:SNU1]CUNITMWRH = 2)
   GSTK_TYPIMP = 1
   Call ACT_GENSNU From SUBSNXA
   If GOK<0  Goto ROLL_GENSNX  Elsif !GOK  Goto AB_GENSNX : Endif     # hcb 43817
   Filter [CUL] Where [F:CUL]CUNSSSNUM = GSTK_CUNSSSNUM Order By Key CUL0
   For [CUL]
# alimentation SNL0
       [M:SNL0]          = [F:CUL]
# Création Liste inventaire
       Call TRACE( 0,mess(7,721,1)-GSTK_CUNSSSNUM-[F:CUL]CUNLISNUM-" : "-num$([F:CUL]NBRLIG)-mess(7,105,1))  From SUBIMPOBJ
   Next
# c est la date de creation des enregistrements bidon stojou
#  [M:SNL0]IPTDAT    = [F:CUL]CREDAT   # hcb 63845
   [M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845
   If [M:SNL0]IPTDAT = [0/0/0]
      [M:SNL0]IPTDAT = date$
   Endif
   [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # hcb 63845
   Raz GSTK_CUNLISNUM
Else

# creation d une liste si import de creation d inventaire partiel
   GSTK_TYPIMP = 0
   Raz [M:SIW]
# Création du numéro de liste
   [M:SIW]CUNLISDAT      = date$                  # hcb 86430
   If GSTKCPTMAN(06)<>2 | [M:SIW]CUNLISNUM = ""
      Call NUM_INV(GSTK_STOFCY,[M:SIW]CUNLISDAT,[M:SIW]CUNLISNUM) From SUBSNXA
      If  [M:SIW]CUNLISNUM = ""
          GOK = 0 :
          GERR = 1
          GMESSAGE= GSTKCPT(6)-":"-mess(104,117,1)
      Endif
   Endif
   [M:SIW]STOFCY       = GSTK_STOFCY
   [M:SIW]CUNSSSNUM    = GSTK_CUNSSSNUM
   [M:SNU0]CUNSSSDES   = [F:CUN]CUNSSSDES
   [M:SIW]NBLIG        = 0
   [M:SIW]CUNLISDAT    = date$
   Gosub CRE_CUL From STKINV
   If GOK<0  Goto ROLL_GENSNX  Elsif !GOK  Goto AB_GENSNX : Endif     # hcb 43817
# alimentation SNL0
   [M:SNL0]          = [F:CUL]
# c est la date de creation des enregistrements bidon stojou
#  [M:SNL0]IPTDAT    = [F:CUL]CREDAT   # hcb 63845
   [M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845
   If [M:SNL0]IPTDAT = [0/0/0]
      [M:SNL0]IPTDAT = date$
   Endif
   [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # hcb 63845
   GSTK_CUNLISNUM    = [F:CUL]CUNLISNUM

   Call TRACE( 0,mess(7,721,1)-GSTK_CUNSSSNUM-[F:CUL]CUNLISNUM)  From SUBIMPOBJ  : # Création Liste inventaire
Endif

Commit

Goto FIN_GENSNX
#-----
$ROLL_GENSNX
Rollback
Call ROLL From GLOCK
If GROLL
   If GREP="C"
      [L]ACTION="AB_CREATION" : Gosub ACTION From GOBJSUB : Goto FIN_GENSNX
   Elsif GREP="A"
      Unlock=[L]SYMBOL2
   Endif
   Goto FIN_GENSNX
Else
   Goto TR_GENSNX
Endif
#-----
$AB_GENSNX
Rollback
If GREP="C"
   [L]ACTION="AB_CREATION" : Gosub ACTION From GOBJSUB : Goto FIN_GENSNX
Elsif GREP="A"
   Unlock=[L]SYMBOL2
Endif
#-----
$FIN_GENSNX
Return

##############################################################################################
# validation liste                                                            TRT_VALIDLISTE #
##############################################################################################
$TRT_VALIDLISTE
Local Char LFILTRE(115)
Local Char CRITER1(100)
Local Char LCUL
Local Decimal I

If [F:CUL]CUNLISNUM <> [M:SNL1]CUNLISNUM | [F:CUL]CUNSSSNUM <> [M:SNL1]CUNSSSNUM
   Read [CUL] CUL0=[M:SNL1]CUNSSSNUM;[M:SNL1]CUNLISNUM
   If fstat
      WIMPORT_ERR = 31
      Gosub ECR_ERREUR
      Return
   Endif
Endif
[M:SNL0]STOFCY = GSTK_STOFCY
#[M:SNL0]IPTDAT   = [F:CUL]CREDAT   # hcb 63845
[M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845
[M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT  # hcb 63845

CRITER1 = "1=1"
# filtre :
#       site , session , liste , detail compté
LFILTRE = "[F:CUD]STOFCY=GSTK_STOFCY & [F:CUD]CUNSSSNUM=[M:SNL1]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNL1]CUNLISNUM"

Call TRT_VALIDATION(LFILTRE,CRITER1,0,LCUL,[M:SNL1]CUNSSSNUM,[M:SNL1]CUNLISNUM) From STKINV

Return

##############################################################################################
# validation session                                                        TRT_VALIDSESSION #
##############################################################################################
$TRT_VALIDSESSION
Local Char LFILTRE(115)
Local Char CRITER1(100)
Local Char LCUL
Local Decimal I

Filter [CUL] Where [F:CUL]CUNSSSNUM = GSTK_CUNSSSNUM
&                 & [F:CUL]CUNLISSTA < 5
&                   Order By Key CUL0

For [CUL]
    [M:SNL0]STOFCY = GSTK_STOFCY
#   [M:SNL0]IPTDAT    = [F:CUL]CREDAT   # hcb 63845
    [M:SNL0]IPTDAT    = [F:CUL]IPTDAT   # hcb 63845
    [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT  # hcb 63845
    CRITER1 = "1=1"
# filtre :
#       site , session , liste , detail compté
    LFILTRE = "[F:CUD]STOFCY=GSTK_STOFCY & [F:CUD]CUNSSSNUM=GSTK_CUNSSSNUM & [F:CUD]CUNLISNUM=[F:CUL]CUNLISNUM"

    Call TRT_VALIDATION(LFILTRE,CRITER1,0,LCUL,GSTK_CUNSSSNUM,[F:CUL]CUNLISNUM) From STKINV
Next

Filter [CUL]

Return

##############################################################################################
# Chargement de l ecran detail inventaire SNL1                                   CHARG_SNL1  #
##############################################################################################
$CHARG_SNL1
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Decimal  WQTE
Local    Char     WPCU(3)
Local    Integer  WMODIF
Local    Char     WLOC(GLONLOC)
Local    Integer  WLTI

If !dim(ISNL) > 0
   Local Integer ISNL
Endif
ISNL = [M:SNL1]NBLIG
If ISNL =  GCOD_INV
   GOK=0
   Return
Endif

# si pas de quantite comptée ni de stock nul  on ne charge pas
Raz WMODIF
If find("[F:CUD]QTYPCUNEW(0)",[M:AOE2]ZONMSK1)
   If [F:CUD2]QTYPCUNEW <> 0
         WMODIF = 3
   Endif
Endif
If find("[F:CUD]QTYSTUNEW(0)",[M:AOE2]ZONMSK1)
   If [F:CUD2]QTYSTUNEW <> 0
         WMODIF = 3
   Endif
Endif
If find("[F:CUD]ZERSTOFLG(0)",[M:AOE2]ZONMSK1)
   If [F:CUD2]ZERSTOFLG =  2
         WMODIF = 2
   Endif
Endif
# si pas de quantite comptée ni de stock nul  on ne charge pas
If WMODIF = 0
   GSTK_NBCUDNUL += 1
   WIMPORT_ERR = 19
   Gosub ECR_ERREUR
   Return
Endif

# si nouvelle ligne , si pas de stock , si pas de quantite comptée on ne charge pas
If [F:CUD2]ITMLISNUM = 0
     If [F:STO]STOCOU = 0
        If WMODIF <> 3
           GSTK_NBCUDNUL += 1
           WIMPORT_ERR = 20
           Gosub ECR_ERREUR
           Return
        Endif
     Endif
Endif

nolign = ISNL + 1
If [F:CUD2]ITMLISNUM<>0
   [M:SNL1] = [F:CUD]
   # cas maj import ligne CUD sans stock
   If [F:STO]STOCOU = 0                                  # hcb 68491
      [M:SNL1] = [F:CUD2]                                # hcb 68491
      [M:SNL1]ITMREF_IMP (nolign-1) = [F:CUD2]ITMREF     # hcb 68491
      [M:SNL1]OWNER      (nolign-1) = [F:CUD]OWNER       # hcb 106486
      Gosub INI_STOLOT                                   # hcb 68491
   Endif                                                 # hcb 68491
   If [M:SNL1]CUNSSSNUM = ""
      [M:SNL1]CUNSSSNUM = GSTK_CUNSSSNUM
   Endif
   If [M:SNL1]CUNLISNUM = ""
      [M:SNL1]CUNLISNUM = GSTK_CUNLISNUM
   Endif
   If [M:SNL1]STOFCY    = ""
      [M:SNL1]STOFCY    = GSTK_STOFCY
   Endif
# sur un detail existant seul QTYPCUNEW QTYSTUNEW et ZERSTOFLG peuvent etre importés
   [M:SNL1]QTYPCUNEW    (nolign-1) = [F:CUD2]QTYPCUNEW
   [M:SNL1]QTYSTUNEW    (nolign-1) = [F:CUD2]QTYSTUNEW
   [M:SNL1]ZERSTOFLG    (nolign-1) = [F:CUD2]ZERSTOFLG
# sur un detail existant il faut initialiser ITMLISNUMS et MODFLG et recuperer l alloué
   [M:SNL1]ITMLISNUMS   (nolign-1) = [F:CUD2]ITMLISNUM
   [M:SNL1]MODFLG       (nolign-1) = 2
   [M:SNL1]CUMALLQTY    (nolign-1) = [F:STO]CUMALLQTY

Else
   [M:SNL1] = [F:CUD2]
   If [M:SNL1]CUNSSSNUM = ""
      [M:SNL1]CUNSSSNUM = GSTK_CUNSSSNUM
   Endif
   If [M:SNL1]CUNLISNUM = ""
      [M:SNL1]CUNLISNUM = GSTK_CUNLISNUM
   Endif
   If [M:SNL1]STOFCY    = ""
      [M:SNL1]STOFCY    = GSTK_STOFCY
   Endif

# si on a trouvé une ligne stock on charge ses éléments
   If [F:STO]STOCOU <> 0
      If dim([M:SNL1]LOC) > 0
         [M:SNL1]LOC    (nolign-1) = [F:STO]LOC
      Endif
      If dim([M:SNL1]LOT) > 0
         [M:SNL1]LOT    (nolign-1) = [F:STO]LOT
      Endif
      If dim([M:SNL1]SLO) > 0
         [M:SNL1]SLO    (nolign-1) = [F:STO]SLO
      Endif
#                                                       # hcb 71276 deb
      If dim([M:SNL1]ECCVALMAJ) > 0
         [M:SNL1]ECCVALMAJ (nolign-1) = [F:STO]ECCVALMAJ
      Endif
#                                                       # hcb 71276 fin

#                                                       # hcb 68149 deb
      If dim([M:SNL1]LPNNUM) > 0
         [M:SNL1]LPNNUM (nolign-1) = [F:STO]LPNNUM
      Endif
#                                                       # hcb 68149 fin
      If dim([M:SNL1]SERNUM) > 0
         [M:SNL1]SERNUM (nolign-1) = [F:STO]SERNUM
      Endif
      If dim([M:SNL1]PALNUM) > 0
         [M:SNL1]PALNUM (nolign-1) = [F:STO]PALNUM
      Endif
      If dim([M:SNL1]CTRNUM) > 0
         [M:SNL1]CTRNUM (nolign-1) = [F:STO]CTRNUM
      Endif
      If dim([M:SNL1]STOFLD1) > 0
         [M:SNL1]STOFLD1 (nolign-1) = [F:STO]STOFLD1
      Endif
      If dim([M:SNL1]STOFLD2) > 0
         [M:SNL1]STOFLD2 (nolign-1) = [F:STO]STOFLD2
      Endif
      [M:SNL1]PCU       (nolign-1) = [F:STO]PCU
      [M:SNL1]STA       (nolign-1) = [F:STO]STA
      [M:SNL1]QTYPCU    (nolign-1) = [F:STO]QTYPCU
      [M:SNL1]PCUSTUCOE (nolign-1) = [F:STO]PCUSTUCOE
      [M:SNL1]QTYSTU    (nolign-1) = [F:STO]QTYSTU
      [M:SNL1]STOCOU    (nolign-1) = [F:STO]STOCOU
      [M:SNL1]QLYCTLDEM (nolign-1) = [F:STO]QLYCTLDEM
      [M:SNL1]OWNER     (nolign-1) = [F:STO]OWNER
      [M:SNL1]CUMALLQTY (nolign-1) = [F:STO]CUMALLQTY
      If dim([M:SNL1]WRH) > 0
         [M:SNL1]WRH    (nolign-1) = [F:STO]WRH
      Endif

   Else
      If find([F:ITM]SERMGTCOD,2,3) & [F:CUD2]SERNUM <> ""             # hcb 110327
         Read [STS]STS0=[F:CUD2]ITMREF;[F:CUD2]SERNUM
         If fstat = 0
            WIMPORT_ERR = 26
            Gosub ECR_ERREUR
            Return
         Endif
      Endif
# si on a pas trouvé de ligne stock on initialise les éléments STOLOT (on peux creer dans ce cas un LOT)
# - elements peremption  (on peut importer la date de reference si date$)
      Gosub INI_STOLOT      # hcb 68491
   Endif

   [M:SNL1]LINFLG(nolign-1)   = 1
   [M:SNL1]ABCCLS_IMP(nolign-1)    = [F:ITF]ABCCLS
   [M:SNL1]ITMREF_IMP(nolign-1)    = [F:CUD2]ITMREF
   [M:SNL1]PRIORD    (nolign-1)    = [F:CUD2]PRIORD     # hcb 75176
   [M:SNL1]IPTDAT_IMP(nolign-1)    = [M:SNL0]IPTDAT
   [M:SNL1]LOTMGT_IMP(nolign-1)    = [F:ITM]LOTMGTCOD
   If [M:SNL1]PCUSTUCOE (nolign-1) = 0
      [M:SNL1]PCUSTUCOE (nolign-1) = 1
   Endif
# controle article depot
   If GWRHACT = 2 & dim([M:SNU1]CUNITMWRH) >0 & [M:SNU1]CUNITMWRH = 2
      Raz WLOC
      If dim([M:SNL1]LOC) > 0
         WLOC =  [M:SNL1]LOC    (nolign-1)
      Endif
      Read  [STC]STC0=GSTK_STOFCY;WLOC
      If fstat
         WIMPORT_ERR = 37                 # emplacement non cree sur le site
         Gosub ECR_ERREUR
         Return
# L'emplacement n'appartient pas au dépôt
      Elsif [F:STC]WRH<>[M:SNL1]WRH    (nolign-1)
         WIMPORT_ERR = 38                 # Emplacement n appartenant pas au depot
         Gosub ECR_ERREUR
         Return
      Elsif [M:SNL0]WRHCUL<>[M:SNL1]WRH    (nolign-1)
         WIMPORT_ERR = 39                 # Emplacement n appartenant pas ŕ la liste
         Gosub ECR_ERREUR
         Return
      Endif
   Endif

Endif
# si stock nul alors quantites comptées = 0
If [M:SNL1]ZERSTOFLG (nolign-1) = 2
   [M:SNL1]QTYPCUNEW (nolign-1) = 0
   [M:SNL1]QTYSTUNEW (nolign-1) = 0
Else
   If  [M:SNL1]QTYSTUNEW (nolign-1) <> 0
       WQTE = [M:SNL1]QTYSTUNEW (nolign-1)
       WPCU = [F:ITM]STU
       Gosub NBR_DECIMALE
       If WDEC > [F:TUN]UOMDEC      # hcb 36952
            WIMPORT_ERR = 33
            Gosub ECR_ERREUR
            Return
       Endif
       If [F:ITM]STU <> [M:SNL1]PCU(nolign-1)
          [M:SNL1]QTYPCUNEW (nolign-1) = [M:SNL1]QTYSTUNEW (nolign-1)/ [M:SNL1]PCUSTUCOE(nolign-1)
          Call QTEARR( [M:SNL1]QTYPCUNEW(nolign-1),[M:SNL1]PCU(nolign-1)) From TRTDIV
          WQTE = [M:SNL1]QTYPCUNEW (nolign-1)
          WPCU = [M:SNL1]PCU(nolign-1)
          Gosub NBR_DECIMALE
              If WDEC > [F:TUN]UOMDEC      # hcb 36952
              WIMPORT_ERR = 34
              Gosub ECR_ERREUR
              Return
          Endif
       Else
          [M:SNL1]QTYPCUNEW (nolign-1) = [M:SNL1]QTYSTUNEW (nolign-1)
       Endif
   Else
       WQTE = [M:SNL1]QTYPCUNEW (nolign-1)
       WPCU = [M:SNL1]PCU(nolign-1)
       Gosub NBR_DECIMALE
       If WDEC > [F:TUN]UOMDEC      # hcb 36952
            WIMPORT_ERR = 34
            Gosub ECR_ERREUR
            Return
       Endif
       [M:SNL1]QTYSTUNEW (nolign-1) = [M:SNL1]QTYPCUNEW (nolign-1) * [M:SNL1]PCUSTUCOE(nolign-1)
       Call QTEARR( [M:SNL1]QTYSTUNEW(nolign-1),[F:ITM]STU) From TRTDIV
       WQTE = [M:SNL1]QTYSTUNEW (nolign-1)
       WPCU = [F:ITM]STU
       Gosub NBR_DECIMALE
       If WDEC > [F:TUN]UOMDEC      # hcb 36952
            WIMPORT_ERR = 33
            Gosub ECR_ERREUR
            Return
       Endif
   Endif
Endif
# Controle alloué
If  [M:SNL1]CUMALLQTY(nolign-1) > [M:SNL1]QTYSTUNEW (nolign-1)
    WIMPORT_ERR = 27
    Gosub ECR_ERREUR
    GOK = 1                   # hcb 121241
    Return
Endif
#                                                                                  # hcb 110327 deb
Raz GQTYSTUDEV
If [F:ITM]SERMGTCOD = 4
   If [M:SNL1]SERSEQ(nolign-1) = 0
      WIMPORT_ERR = 71
      Gosub ECR_ERREUR
      Return
   Endif
   GSERSEQ     = [M:SNL1]SERSEQ   (nolign-1)
   If [M:SNL1]QTYSTUNEW(nolign-1) <> [M:SNL1]QTYSTU(nolign-1)
      GQTYSTUDEV  = [M:SNL1]QTYSTUNEW(nolign-1)-[M:SNL1]QTYSTU(nolign-1)
      GSTK_NBCSDTOT += GSTK_NBCSD
      Raz GSTK_NBCSD
      Raz [M:SNLS]
      Raz GTOTSERIE
   Endif
Endif
#                                                                                  # hcb 110327 deb

If [F:CUD2]ITMLISNUM<>0
   GSTK_NBCUDCUD += 1
Else
   If [F:STO]STOCOU <> 0
      GSTK_NBCUDSTK += 1
   Else
      GSTK_NBCUDNEW += 1
   Endif
Endif
GSTK_NBCUDMAJ += 1

ISNL += 1
[M:SNL1]NBLIG = ISNL
Return

##############################################################################################
# Recherche ligne de stock correspondante                                        RECH_STOCK  #
##############################################################################################
$RECH_STOCK

Local Char    LFCY(GLONFCY)
Local Char    LITM(GLONITM)
Local Char    LLOT(GLONLOT)
Local Char    LSLO(GLONSLO)
Local Char    LPAL(GLONPAL)
Local Char    LCTR(GLONCTR)
Local Char    LSTA
Local Char    LLOC(GLONEMP)
Local Char    LPCU
Local Decimal LCOE
Local Char    LSER(GLONSER)
Local Char    LQLY
Local Char    LOWN
Local Char    LSF1(GLONSF1)
Local Char    LSF2(GLONSF2)
Local Decimal LSTOCOU
Local Char    LLPN(GLONLPN)      # hcb  X3-68149
If GWRHACT = 2
   Local Char LWRH(GLONWRH)
   Raz LWRH
Endif
If !dim(WIMPORT_ERR) > 0
   Local Integer WIMPORT_ERR
Endif
# hcb X3-68149  Ajout LLPN
Raz LFCY,LITM,LLOT,LSLO,LPAL,LCTR,LSTA,LLOC,LPCU,LCOE,LSER,LQLY,LOWN,LSF1,LSF2,LLPN
Raz LSTOCOU
Raz WIMPORT_ERR
Raz [F:STO]

# controle de la presence et valeur des rubriques et chargement des zones de recherche suivant le contexte
Gosub TRT_RUBRIQUE

If WIMPORT_ERR <> 0
   Return
Endif

# si type import n est pas de type complet alors on fait la recherche sur le fichier stock
If GSTK_TYPIMP <> 1
# hcb  X3-68149  Ajout LPN
   LSTOCOU = func STKLIB.CLESTOFUN(LFCY,LITM,LLOT,LSLO,LPAL,LCTR,LSTA,LLOC,
&                                  LPCU,LCOE,LSER,LQLY,LOWN,LSF1,LSF2,"STO",LLPN)
   If LSTOCOU
# la ligne stock trouvée ne doit pas etre deja en inventaire
      If [F:STO]CUNLISNUM <> ""
         WIMPORT_ERR = 6
         Gosub ECR_ERREUR
         Raz [F:STO]
         Return
      Else
         Read [STO]STO0=LFCY;LSTOCOU
         If fstat
            Raz [F:STO]
            WIMPORT_ERR = 7
            Gosub ECR_ERREUR
            Return
         Endif
#                                                        # hcb 110327 deb
         If [F:ITM]SERMGTCOD = 4
            Local Char    LMSK
            Local Integer  WRET
            LMSK = "SIW"
            Raz WRET
            Gosub VERIF_DESYNCHRO From STKINV1
            If WRET<>0
               WIMPORT_ERR = 74
               Gosub ECR_ERREUR
               Return
            Endif
         Endif
#                                                        # hcb 110327 fin
      Endif
   Endif
Else
# si type import est de type complet alors on fait la recherche sur le fichier cunlisdet
  Raz [F:CUD]
# hcb  X3-68149  Ajout LPN
  Columns [CUD] (CUNLISNUM, ITMLISNUM)
  Filter  [CUD] Where STOFCY    = LFCY
&                   & CUNSSSNUM = GSTK_CUNSSSNUM
&                   & ITMREF    = LITM
&                   & SERNUM    = LSER
&                   & LOT       = LLOT
&                   & SLO       = LSLO
&                   & PALNUM    = LPAL
&                   & CTRNUM    = LCTR
&                   & STA       = LSTA
&                   & LPNNUM    = LLPN
&                   & LOC       = LLOC
&                   & PCU       = LPCU
&                   & PCUSTUCOE = LCOE
&                   & QLYCTLDEM = LQLY
&                   & OWNER     = LOWN
&                   & STOFLD1   = LSF1
&                   & STOFLD2   = LSF2
  For [CUD]CUD3
    [F:CUD2]ITMLISNUM = [F:CUD]ITMLISNUM
    Break
  Next
  Filter  [CUD]
  Columns [CUD]
  If [F:CUD]ITMLISNUM <> 0
     If  GSTK_CUNLISNUM  =  ""
         GSTK_CUNLISNUM  =  [F:CUD]CUNLISNUM
     Endif
     If  GSTK_CUNLISNUM  <> [F:CUD]CUNLISNUM
         GSTK_CUNLISNUM  =  [F:CUD]CUNLISNUM
         Gosub IMPORT_DETAIL
         [M:SNL0]IPTDAT    = date$
         [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # hcb 63845
     Endif
     Read [CUD]CUD0=GSTK_CUNSSSNUM;GSTK_CUNLISNUM;[F:CUD2]ITMLISNUM
     If fstat
        WIMPORT_ERR = 18
        Gosub ECR_ERREUR
        Return
     Endif
# si le détail est abandonné ou validé on ne peux pas le modifier
     If [F:CUD]CUNLISSTA > 2
        WIMPORT_ERR = 28
        Gosub ECR_ERREUR
        Return
     Endif
  Endif
Endif

Return

##############################################################################################
# TRT_ECRSTJBID                                         Ecriture enregistrement STOJOU bidon #
##############################################################################################
$TRT_ECRSTJBID

Local Char    WITMREF(GLONITM)
Local Integer WRET
Local Char    WLIS             # hcb 140205 27888
Raz WLIS
Raz WITMREF
Raz WRET
Filter [CUD] Where STOFCY    = GSTK_STOFCY         &
&                  CUNSSSNUM = GSTK_CUNSSSNUM      &
&                  CUNLISNUM = GSTK_CUNLISNUM      &
&                  LINFLG    = 1
&            Order By Key CUD3
For [CUD]
  If WITMREF <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM  # hcb 140205 27888
     WITMREF =  [F:CUD]ITMREF
     WLIS    =  [F:CUD]CUNLISNUM                           # hcb 140205 27888
     Gosub ECR_ECRSTJBID
  Endif
Next
Filter [CUD]

Return

##############################################################################################
# ECR_ECRSTJBID  recherche et ecriture le cas echeant de l enregistrement bidon ECR_ECRSTJBID#
##############################################################################################
$ECR_ECRSTJBID

If !clalev([F:STJ])   Local File STOJOU     [STJ] : Endif
Columns [STJ] (MVTSEQ)
Filter [STJ] Where STOFCY   = GSTK_STOFCY
&            & UPDCOD       = 2
&            & ITMREF       = [F:CUD]ITMREF
&            & IPTDAT       = [M:SNL0]IPTDAT
&            & MVTIND       = 0
&            & VCRTYP       = 9
&            & VCRNUM       = GSTK_CUNLISNUM
&            & VCRNUMORI    = GSTK_CUNSSSNUM
&            & REGFLG       = 2
Read [STJ] STJ0 First
Filter  [STJ]
Columns [STJ]
If fstat
   If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
   If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
   If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
   Raz [F:STJ]
   [F:STJ]STOFCY    = GSTK_STOFCY
   [F:STJ]OWNER     = GSTK_STOFCY
   [F:STJ]UPDCOD    = 2
   [F:STJ]REGFLG    = 2
   [F:STJ]ITMREF    = [F:CUD]ITMREF
   [F:STJ]VCRTYP    = 9
   [F:STJ]VCRNUM    = GSTK_CUNLISNUM
   [F:STJ]VCRNUMORI = GSTK_CUNSSSNUM
   [F:STJ]IPTDAT    = [M:SNL0]IPTDAT
   If [F:ITM]ITMREF<>[F:CUD]ITMREF
      Read [ITM]ITM0=[F:CUD]ITMREF
      If fstat
         Raz [F:ITM]
      Endif
   Endif
   #----- Création du mouvement de stock -----#
   Call ECRSTJ(0,WRET) From STKLIB
   If WRET <> 0
      WIMPORT_ERR = 21
      Gosub ECR_ERREUR
   Endif
Endif
Return

##############################################################################################
# Controle des rubriques suivant le contexte :(dans le cas d un nouveau détail) TRT_RUBRIQUE #
#    controle de la presence et de la valeur des rubriques                                   #
#    chargement des zones de recherche                                                       #
##############################################################################################
$TRT_RUBRIQUE
Local  Shortint WRET
Raz WRET
#-------------------------------------------------------------------#
# rubriques obligatoires  : STOFCY , ITMREF , STA , PCU             #
#-------------------------------------------------------------------#
$RUB_OBLIGATOIRE

If GSTK_STOFCY = ""
   If !find("[F:CUD]STOFCY(0)",[M:AOE2]ZONMSK1)
      WIMPORT_ERR = 8
      Gosub ECR_ERREUR
      Goto  RUB_PCUSTUCOE
   Else
      If [F:CUD2]STOFCY = ""
         WIMPORT_ERR = 9
         Gosub ECR_ERREUR
         Goto  RUB_PCUSTUCOE
      Else
         LFCY = [F:CUD2]STOFCY
      Endif
   Endif
Else
   LFCY = GSTK_STOFCY
Endif

If !find("[F:CUD]ITMREF(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 8
   Gosub ECR_ERREUR
   Goto  RUB_PCUSTUCOE
Else
   If [F:CUD2]ITMREF = ""
      WIMPORT_ERR = 9
      Gosub ECR_ERREUR
      Goto  RUB_PCUSTUCOE
   Else
      LITM = [F:CUD2]ITMREF
   Endif
Endif
If !find("[F:CUD]STA(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 8
   Gosub ECR_ERREUR
   Goto  RUB_PCUSTUCOE
Else
   If [F:CUD2]STA = ""
      WIMPORT_ERR = 9
      Gosub ECR_ERREUR
      Goto  RUB_PCUSTUCOE
   Else
# controle existance Statut  A Q R
        Call STKCTRSTA([F:CUD2]STA,"A*,Q*,R*",0,1,0,WRET) From STKACT
        If WRET <> 0
           WIMPORT_ERR = 22
           Gosub ECR_ERREUR
           Goto  RUB_PCUSTUCOE
        Else
           LSTA = [F:CUD2]STA
        Endif
   Endif
Endif
If !find("[F:CUD]PCU(0)",[M:AOE2]ZONMSK1)
   WIMPORT_ERR = 8
   Gosub ECR_ERREUR
   Goto  RUB_PCUSTUCOE
Else
   If [F:CUD2]PCU = ""
      WIMPORT_ERR = 9
      Gosub ECR_ERREUR
      Goto  RUB_PCUSTUCOE
   Else
      If [F:TUN]UOM<>[F:CUD2]PCU
         Read [TUN] TUN0=[F:CUD2]PCU
         If fstat
            WIMPORT_ERR = 23
            Gosub ECR_ERREUR
            Goto  RUB_PCUSTUCOE
         Endif
      Endif
      LPCU = [F:CUD2]PCU
      LCOE = 1
   Endif
Endif

#-------------------------------------------------------------------#
# rubrique PCUSTUCOE obligatoire si PCU <> STU de l article         #
#-------------------------------------------------------------------#
$RUB_PCUSTUCOE
If [F:CUD2]PCU <> ""
   If [F:CUD2]PCU <> [F:ITM]STU
      If !find("[F:CUD]PCUSTUCOE(0)",[M:AOE2]ZONMSK1)
         WIMPORT_ERR = 10
         Gosub ECR_ERREUR
         Goto  RUB_ARTICLE
         Return
      Else
         If [F:CUD2]PCUSTUCOE = 0
            WIMPORT_ERR = 11
            Gosub ECR_ERREUR
            Goto  RUB_ARTICLE
         Else
            LCOE = [F:CUD2]PCUSTUCOE
         Endif
      Endif
   Else
     [F:CUD2]PCUSTUCOE = 1
   Endif
Else
   [F:CUD2]PCU       = [F:ITM]STU
   [F:CUD2]PCUSTUCOE = 1
Endif

#-------------------------------------------------------------------#
# rubriques LOT , SLO , SERIE , LOC  obligatoires suivant l article #
#-------------------------------------------------------------------#
$RUB_ARTICLE
If find("[F:CUD]LOT(0)",[M:AOE2]ZONMSK1)
   LLOT = [F:CUD2]LOT
Endif
If find("[F:CUD]SLO(0)",[M:AOE2]ZONMSK1)
   LSLO = [F:CUD2]SLO
Endif
If find("[F:CUD]SERNUM(0)",[M:AOE2]ZONMSK1)
   LSER = [F:CUD2]SERNUM
Endif
If find("[F:CUD]LOC(0)",[M:AOE2]ZONMSK1)
   LLOC = [F:CUD2]LOC
Endif

If [F:ITM]LOTMGTCOD >1
   If !find("[F:CUD]LOT(0)",[M:AOE2]ZONMSK1)
      WIMPORT_ERR = 12
      Gosub ECR_ERREUR
      Goto  FIN_TRT_RUBRIQUE
   Else
      If [F:ITM]LOTMGTCOD > 2
         If [F:CUD2]LOT = ""
             WIMPORT_ERR = 13
             Gosub ECR_ERREUR
             Goto  FIN_TRT_RUBRIQUE
         Endif
      Endif
      LLOT = [F:CUD2]LOT
   Endif
Endif

If [F:ITM]LOTMGTCOD >3
   If  !find("[F:CUD]SLO(0)",[M:AOE2]ZONMSK1)
       WIMPORT_ERR = 12
       Gosub ECR_ERREUR
       Goto  FIN_TRT_RUBRIQUE
   Else
      If [F:CUD2]SLO = ""
         WIMPORT_ERR = 13
         Gosub ECR_ERREUR
         Goto  FIN_TRT_RUBRIQUE
      Else
         LSLO = [F:CUD2]SLO
      Endif
   Endif
Endif
If find([F:ITM]SERMGTCOD,2,3)                             # hcb 110327
   If !find("[F:CUD]SERNUM(0)",[M:AOE2]ZONMSK1)
      WIMPORT_ERR = 12
      Gosub ECR_ERREUR
      Goto  FIN_TRT_RUBRIQUE
   Else
      If [F:ITM]SERMGTCOD = 3        # hcb 62419
         If [F:CUD2]SERNUM = ""
            WIMPORT_ERR = 13
            Gosub ECR_ERREUR
            Goto  FIN_TRT_RUBRIQUE
         Else
            If find("[F:CUD]QTYPCUNEW(0)",[M:AOE2]ZONMSK1)
               If [F:CUD2]QTYPCUNEW  > 1
                  WIMPORT_ERR = 25
                  Gosub ECR_ERREUR
                  Goto  FIN_TRT_RUBRIQUE
               Endif
            Endif
            If find("[F:CUD]QTYSTUNEW(0)",[M:AOE2]ZONMSK1)
               If [F:CUD2]QTYSTUNEW  > 1
                  WIMPORT_ERR = 25
                  Gosub ECR_ERREUR
                  Goto  FIN_TRT_RUBRIQUE
               Endif
            Endif
            If find("[F:CUD]PCU(0)",[M:AOE2]ZONMSK1)
               If [F:CUD2]PCU  <> [F:ITM]STU
                  WIMPORT_ERR = 25
                  Gosub ECR_ERREUR
                  Goto  FIN_TRT_RUBRIQUE
               Endif
            Endif
            LSER = [F:CUD2]SERNUM
         Endif
      Endif                          # hcb 62419
   Endif
Endif

#                                                       # hcb x3-68149 deb

If [F:ITF]LPNMGTCOD = 2
   If find("[F:CUD]LPNNUM(0)",[M:AOE2]ZONMSK1) & [F:CUD2]LPNNUM <> ""
      If [F:CUD2]LPNNUM <> [F:LPN]LPNNUM
         Read [LPN]LPN0=[F:CUD2]LPNNUM
         If fstat
            WIMPORT_ERR = 75
            Gosub ECR_ERREUR
            Goto  FIN_TRT_RUBRIQUE
         Endif
      Endif
      If [F:LPN]STOFCY<>LFCY
         WIMPORT_ERR = 76             # le contenant n'est pas sur le site
         Gosub ECR_ERREUR
         Goto  FIN_TRT_RUBRIQUE
      Endif
      If [F:LPN]WRH <> "" & [F:LPN]WRH<>[F:CUD2]WRH
         WIMPORT_ERR = 77             # le contenant n'est pas sur le dépot
         Gosub ECR_ERREUR
         Goto  FIN_TRT_RUBRIQUE
      Endif
      If [F:LPN]ENAFLG <> 2
         WIMPORT_ERR = 79             # le contenant n'est pas actif
         Gosub ECR_ERREUR
         Goto  FIN_TRT_RUBRIQUE
      Endif
# si l'emplacement n est pas importé : récupération de l'emplacement du LPN
      If [F:CUD2]LOC  = ""
         [F:CUD2]LOC  =    [F:LPN]LOC
      Else
# l'emplacement importé doit etre identique ŕ celui du LPN
         If [F:LPN]LOC <> "" & [F:LPN]LOC <> [F:CUD2]LOC
            WIMPORT_ERR = 78             # L' emplacement saisi ne correspond pas ŕ l'emplacement du no de contenant
            Gosub ECR_ERREUR
            Goto  FIN_TRT_RUBRIQUE
         Endif
      Endif
      LLPN = [F:CUD2]LPNNUM
   Endif
Endif
#                                                       # hcb x3-68149 fin

If [F:ITF]LOCMGTCOD>1
   If !find("[F:CUD]LOC(0)",[M:AOE2]ZONMSK1)
      WIMPORT_ERR = 12
      Gosub ECR_ERREUR
      Goto  FIN_TRT_RUBRIQUE
   Else
      If [F:CUD2]LOC = ""
         WIMPORT_ERR = 13
         Gosub ECR_ERREUR
         Goto  FIN_TRT_RUBRIQUE
      Else
         If [F:CUD2]LOC<>[F:STC]LOC
             Read [F:STC]STC0=GSTK_STOFCY;[F:CUD2]LOC
             If fstat
                WIMPORT_ERR = 24
                Gosub ECR_ERREUR
                Goto  FIN_TRT_RUBRIQUE
             Endif
         Endif
         LLOC = [F:CUD2]LOC
      Endif
   Endif
Endif

#                                                       # hcb 71276 deb
If [F:ITM]ECCSTO > 2 & dim([F:CUD2]ECCVALMAJ) > 0
   If [F:CUD2]ECCVALMAJ  <> "" &  [F:CUD2]ECCVALMIN = ""
      WIMPORT_ERR = 56
      Gosub ECR_ERREUR
      Goto  FIN_TRT_RUBRIQUE
    Endif
   If [F:CUD2]ECCVALMAJ  =  "" &  [F:CUD2]ECCVALMIN <> ""
      WIMPORT_ERR = 56
      Gosub ECR_ERREUR
      Goto  FIN_TRT_RUBRIQUE
   Endif
Endif
#                                                       # hcb 71276 fin

#---- rubriques facultatives : PALNUM CTRNUM QLYCTLDEM OWNER STOFLD1 STOFLD2
If find("[F:CUD]PALNUM(0)",[M:AOE2]ZONMSK1)
   LPAL = [F:CUD2]PALNUM
Endif
If find("[F:CUD]CTRNUM(0)",[M:AOE2]ZONMSK1)
   LCTR = [F:CUD2]CTRNUM
Endif
If find("[F:CUD]QLYCTLDEM(0)",[M:AOE2]ZONMSK1)
   LQLY = [F:CUD2]QLYCTLDEM
Endif
If find("[F:CUD]OWNER(0)",[M:AOE2]ZONMSK1)
   LOWN = [F:CUD2]OWNER
Else
   LOWN = LFCY
Endif
If find("[F:CUD]STOFLD1(0)",[M:AOE2]ZONMSK1)
   LSF1 = [F:CUD2]STOFLD1
Endif
If find("[F:CUD]STOFLD2(0)",[M:AOE2]ZONMSK1)
   LSF2 = [F:CUD2]STOFLD2
Endif
#--- Issue X3-53322
If find("[F:CUD]LPNNUM(0)",[M:AOE2]ZONMSK1)
   LLPN = [F:CUD2]LPNNUM
Endif
#---
$FIN_TRT_RUBRIQUE

Return

##############################################################################################
# Controle coherence contenu du fichier import CUNLISDET                      COHERENCE_CUD  #
##############################################################################################
$COHERENCE_CUD

If !dim(WIMPORT_ERR) > 0
   Local Integer WIMPORT_ERR
Endif

WIMPORT_ERR = 0

# si session inexistante ---->  erreur
If [M:SNU0]CUNSSSNUM="" | ([F:CUD2]CUNSSSNUM<>"" & [F:CUD2]CUNSSSNUM<>[M:SNU0]CUNSSSNUM)
   Read [CUN] CUN0=[F:CUD2]CUNSSSNUM
   If fstat
      WIMPORT_ERR = 1
      Gosub ECR_ERREUR
      Return
   Else
      [M:SNU0]=[F:CUN] : [M:SNU1]=[F:CUN] : [M:SNU2]=[F:CUN]
      If [F:CUN]CUNSSSSTA > 2
         WIMPORT_ERR = 29
         Gosub ECR_ERREUR
# initialisation flag  session validéé  (=2)
         GSTK_CUNSESSION = 2
      Endif
   Endif
Endif
# si liste inexistante ---->  erreur (lecture si pas type import complet ..)
If GSTK_TYPIMP <> 1
   If [F:CUL]CUNSSSNUM<>[M:SNU0]CUNSSSNUM | [F:CUL]CUNLISNUM<>GSTK_CUNLISNUM
      Read [CUL] CUL0=[M:SNU0]CUNSSSNUM;GSTK_CUNLISNUM
      If fstat
         WIMPORT_ERR = 2
         Gosub ECR_ERREUR
         Return
      Else
        [M:SNU0] = [F:CUL]
      Endif
   Endif
Endif
# si qte compte UC <> 0 et stock nul = oui ---->  erreur
If find("[F:CUD]QTYPCUNEW(0)",[M:AOE2]ZONMSK1)
   If find("[F:CUD]ZERSTOFLG(0)",[M:AOE2]ZONMSK1)
      If [F:CUD2]QTYPCUNEW <> 0 & [F:CUD2]ZERSTOFLG <> 1
         WIMPORT_ERR = 3
         Gosub ECR_ERREUR
         Return
      Endif
   Else
      [F:CUD2]ZERSTOFLG = 1
   Endif
Endif
# si qte compte US <> 0 et stock nul = oui ---->  erreur
If find("[F:CUD]QTYSTUNEW(0)",[M:AOE2]ZONMSK1)
   If find("[F:CUD]ZERSTOFLG(0)",[M:AOE2]ZONMSK1)
      If [F:CUD2]QTYSTUNEW <> 0 & [F:CUD2]ZERSTOFLG <> 1
         WIMPORT_ERR = 4
         Gosub ECR_ERREUR
         Return
      Endif
   Else
      [F:CUD2]ZERSTOFLG = 1
   Endif
Endif
# si rang <> 0 et liste = ""  ---->  erreur
If find("[F:CUD]ITMLISNUM(0)",[M:AOE2]ZONMSK1)
   If find("[F:CUD]CUNLISNUM(0)",[M:AOE2]ZONMSK1)
      If [F:CUD2]ITMLISNUM <> 0 & [F:CUD2]CUNLISNUM = ""
         WIMPORT_ERR = 5
         Gosub ECR_ERREUR
         Return
      Endif
   Endif
Endif
Return

##############################################################################################
# Calcul nombre decimale                                                       NBR_DECIMALE  #
##############################################################################################
$NBR_DECIMALE
Local Integer WDEC

If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If [F:TUN]UOM <> WPCU
   Read [TUN]TUN0 = WPCU
Endif

WQTE = WQTE - int(WQTE)
WDEC = 0
While WQTE <> int(WQTE)
      WQTE *= 10
      WDEC += 1
Wend

Return



##############################################################################################
# initialisation STOLOT                                                           INI_STOLOT #   # hcb 68491
##############################################################################################
$INI_STOLOT

If [F:ITM]EXYMGTCOD<2
   Raz [M:SNL1]REFPER  (nolign-1)
   Raz [M:SNL1]SHL     (nolign-1)
   [M:SNL1]SHLDAT      (nolign-1) = [31/12/2999]
   [M:SNL1]DLUDAT      (nolign-1) = [31/12/2999]
   [M:SNL1]NEWLTIDAT   (nolign-1) = [31/12/2999]
Else
   If [M:SNL1]REFPER   (nolign-1) = [0/0/0]
      [M:SNL1]REFPER   (nolign-1) = date$
   Endif
   If [M:SNL1]SHL      (nolign-1) = 0
      [M:SNL1]SHL      (nolign-1) = [F:ITM]SHL
   Endif
   If [M:SNL1]SHLUOM   (nolign-1) = 0
      [M:SNL1]SHLUOM   (nolign-1) = [F:ITM]SHLUOM
   Endif
   If [M:SNL1]SHLLTI   (nolign-1) = 0
      [M:SNL1]SHLLTI   (nolign-1) = [F:ITF]SHLLTI
   Endif
   If [M:SNL1]SHLLTIUOM(nolign-1) = 0
      [M:SNL1]SHLLTIUOM(nolign-1) = [F:ITF]SHLLTIUOM
   Endif
   If [M:SNL1]DLU      (nolign-1) = 0
      [M:SNL1]DLU      (nolign-1) = [F:ITF]DLU
   Endif
   If [M:SNL1]SHLDAT   (nolign-1) = [0/0/0]
      Call CALPER([F:ITM]EXYMGTCOD,[M:SNL1]REFPER(nolign-1),[M:SNL1]SHL(nolign-1),[M:SNL1]SHLUOM(nolign-1),"",WPER) From STKLIB
      [M:SNL1]SHLDAT   (nolign-1) = WPER
   Endif
   If [M:SNL1]DLUDAT   (nolign-1) = [0/0/0]
      Call CALDLU([F:ITM]EXYMGTCOD,[M:SNL1]REFPER(nolign-1),[M:SNL1]SHLDAT(nolign-1),[M:SNL1]DLU(nolign-1),"",WPER,WLTI) From STKLIB
      [M:SNL1]DLUDAT   (nolign-1) = WPER
   Endif
   If [M:SNL1]NEWLTIDAT(nolign-1) = [0/0/0]
      Call CALLTI([F:ITM]EXYMGTCOD,[M:SNL1]REFPER(nolign-1),[M:SNL1]SHLLTI(nolign-1),[M:SNL1]SHLLTIUOM(nolign-1),"",WPER) From STKLIB
      [M:SNL1]NEWLTIDAT(nolign-1) = WPER
  Endif
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
  If [M:SNL1]NEWLTIDAT(nolign-1) <> [31/12/2999]
     If [M:SNL1]NEWLTIDAT(nolign-1)  > [M:SNL1]DLUDAT   (nolign-1)
        [M:SNL1]NEWLTIDAT(nolign-1)  = [M:SNL1]DLUDAT   (nolign-1)
     Endif
  Endif
Endif

# - element titre (on peut importer le titre sinon on prend celui par defaut (ITM))
If [F:ITF]STOMGTCOD < 3
   [M:SNL1]POT(nolign-1) = 100
Else
   If [M:SNL1]POT (nolign-1) = 0
      [M:SNL1]POT (nolign-1) = [F:ITM]DEFPOT
   Endif
Endif

#                                                       # hcb 71276 deb
If [F:ITM]ECCSTO > 1 & dim([M:SNL1]ECCVALMAJ) > 0
   Call STKINIECC([F:CUD2]ITMREF,[M:SNL1]LOT (nolign-1),"SNL1",2,2,nolign-1,2,[M:SNL1]ECCVALMAJ(nolign-1),"ECCVALMAJ","ECCVALMIN","","",1,"") From STKACT
   Call STKCTRECC([F:CUD2]ITMREF,[M:SNL1]ECCVALMAJ(nolign-1),[M:SNL1]ECCVALMIN(nolign-1),[M:SNL1]LOT (nolign-1),2) From STKACT
   If dim(GIMPORT_ERR) > 0
      WIMPORT_ERR = GIMPORT_ERR
   Endif
Endif
#                                                       # hcb 71276 fin



Return



##############################################################################################
# Trace détaillée si GSTK_TRACE=2                                           TRACE_DETAILLEE  #
##############################################################################################
$TRACE_DETAILLEE

If GSTK_TRACE<>2  Return : Endif
If GSTK_PGM=""
   If find(GSTK_ACT,"Trbegin","Commit","Rollback")
      GSTK_MESS="---"-mess(5,126,1)-GSTK_ACT
   Else
      GSTK_MESS=GSTK_ACT
   Endif
Else
   If GSTK_ACT="AP_IMPORT"
      GSTK_ACT+="("+[M:AOE1]FLGFIL([L]SEPNUM-1)+")"
   Endif
   GSTK_MESS=mess(27,115,1)-GSTK_ACT+space$(22-len(GSTK_ACT))+"From "-GSTK_PGM
Endif
Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
Return

##############################################################################################
# Ecriture dans la trace des erreurs                                             ECR_ERREUR  #
##############################################################################################
$ECR_ERREUR
# flag erreur ŕ oui pour ne pas valider la liste
GSTK_ERRLIS = 2
# flag erreur ŕ oui pour ne pas valider la session (import complet)
GSTK_ERRSSS = 2

Case WIMPORT_ERR
     When 1
# session inexistante
Call ECR_TRACE(mess(167,184,1)-" : "-[F:CUD2]CUNSSSNUM,1) From GESECRAN
     When 2
# liste inexistante
Call ECR_TRACE(mess(168,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM,1) From GESECRAN
     When 3
# qte compte UC <> 0 et stock nul = oui
Call ECR_TRACE(mess(170,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 4
# qte compte US <> 0 et stock nul = oui
Call ECR_TRACE(mess(171,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 5
# liste absente
Call ECR_TRACE(mess(169,184,1)-" : "-GSTK_CUNSSSNUM-","-num$([F:CUD2]ITMLISNUM),1) From GESECRAN
     When 6
# ligne de stock en inventaire
Call ECR_TRACE(mess(126,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-num$([F:STO]STOCOU),1) From GESECRAN
     When 7
# Erreur d acces sur le fichier STOCK
Call ECR_TRACE(mess(12,100,1)-" : "-"STOCK"-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-num$(LSTOCOU),1) From GESECRAN
     When 8
# Rubriques : STOFCY,ITMREF,STA,PCU absente(s) ; obligatoires pour rechercher la ligne de stock
Call ECR_TRACE(mess(172,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 9
# Rubriques : STOFCY,ITMREF,STA,PCU non renseignée(s) obligatoires rechercher la ligne de stock
Call ECR_TRACE(mess(173,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 10
# rubriques PCUSTUCOE absente  obligatoire si PCU <> STU de l article
Call ECR_TRACE(mess(174,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 11
# rubriques PCUSTUCOE non renseignée obligatoire si PCU <> STU de l article
Call ECR_TRACE(mess(175,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 12
# rubriques LOT , SLO , SERIE , LOC  obligatoires suivant l article
Call ECR_TRACE(mess(176,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 13
# rubriques LOT , SLO , SERIE , LOC  obligatoires suivant l article
Call ECR_TRACE(mess(177,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 14
# Article inexistant
Call ECR_TRACE(mess(212,199,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
     When 15
# Article site inexistant
Call ECR_TRACE(mess(139,197,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-GSTK_STOFCY,1) From GESECRAN
     When 16
# Article non géré en stock
Call ECR_TRACE(mess(137,194,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
     When 17
# Erreur d ecriture sur le fichier STOLOT
Call ECR_TRACE(mess(13,100,1)-" : "-"STOLOT"-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:STL]ITMREF-","-[F:STL]LOT-","-[F:STL]SLO,1) From GESECRAN
     When 18
# Enregistremet CUNLISDET inexistant
Call ECR_TRACE(mess(188,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-num$([F:CUD2]ITMLISNUM),1) From GESECRAN
     When 19
# Import nul  : pas de quantités comptés ni stock nul !
Call ECR_TRACE(mess(189,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
# Import nul  : pas de quantités comptés sur CUNLISDET inexistant !
Call ECR_TRACE(mess(190,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 21
# erreur ecriture enregistrement bidon STOJOU
Call ECR_TRACE(mess(191,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[F:CUD]ITMREF,1) From GESECRAN
     When 22
# Statut de stock non autorisé
Call ECR_TRACE(mess(255,199,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]STA,1) From GESECRAN
     When 23
# L'unité de conditionnement n'a pas été trouvée
Call ECR_TRACE(mess(74,194,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]PCU,1) From GESECRAN
     When 24
# Emplacement inexistant
Call ECR_TRACE(mess(125,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]LOC,1) From GESECRAN
     When 25
# Rubriques QTYPCUNEW, QTYSTUNEW, PCU incorrecte(s) : article géré en série !
Call ECR_TRACE(mess(192,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
     When 26
# Numéro de série existe déja pour cet article
Call ECR_TRACE(mess(3,187,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-[F:CUD2]SERNUM,1) From GESECRAN
     When 27
# La quantité allouée  est supérieure ŕ la quantité comptée
Call ECR_TRACE(mess(193,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-num$([F:STO]STOCOU),1) From GESECRAN
GOK = 0    # 36953
     When 28
# Import interdit :  le détail est abandonné ou déjŕ validé !
Call ECR_TRACE(mess(195,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-num$([F:CUD]ITMLISNUM ),1) From GESECRAN
     When 29
# Import interdit :  La session est close !
Call ECR_TRACE(mess(196,184,1)-" : "-[F:CUN]CUNSSSNUM,1) From GESECRAN
     When 30
# Session inexistante !
Call ECR_TRACE(mess(167,184,1)-" : "-[M:SNU0]CUNSSSNUM,1) From GESECRAN
     When 31
# Validation impossible : erreur lecture CUNLISTE !
Call ECR_TRACE(mess(197,184,1)-" : "-[M:SNL1]CUNSSSNUM-","-[M:SNL1]CUNLISNUM,1) From GESECRAN
     When 32
# Validation interdite en import de création d inventaire complet !
Call ECR_TRACE(mess(200,184,1)-" : "-GSTK_CUNSSSNUM,1) From GESECRAN
     When 33
# Nombre de décimales incorrecte sur la quantité US comptée !
Call ECR_TRACE(mess(204,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 34
# Nombre de décimales incorrecte sur la quantité UC comptée !
Call ECR_TRACE(mess(205,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD),1) From GESECRAN
     When 35
# Erreur d ecriture sur le fichier STOLOTFCY
