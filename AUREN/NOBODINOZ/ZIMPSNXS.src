Raz GSTK_NBCSD
#
     When 61
# CUNSERDET Quantité série globale ŕ zéro ou inexistant
Call ECR_TRACE(mess(458,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 62
# Numero de série déja ŕ inventorier
Call ECR_TRACE(mess(653,199,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 63
# numéro de série existe déja pour cette ligne de stock
Call ECR_TRACE(mess(223,187,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
#
     When 64
# numéro de série existe déja pour cet article
Call ECR_TRACE(mess(3,187,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-num$(GSTK_NUMCUD)-","-[F:CUD2]ITMREF-","-WNUMFIN,1) From GESECRAN
Raz GSTK_NBCSD
