     When 39
# Emplacement n appartenant pas ŕ la liste
Call ECR_TRACE(mess(347,184,1)-" : "-GSTK_CUNSSSNUM-","-GSTK_CUNLISNUM-","-[M:SNL0]WRHCUL-","-[M:SNL1]WRH(nolign-1),1) From GESECRAN

#                                                       # hcb 71276 deb
     When 50
