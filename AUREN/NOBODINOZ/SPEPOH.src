#<AdxTL>@(#)0.0.0.0 $Revision$ 


$ACTION
Case ACTION
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When Default
Endcase
Return

#######################################################################

$SEL_TABLE
  Case COUZON
    When "ZLOC"    : Gosub SEL_LOC
  Endcase
Return
#######################################################################

$SEL_LOC
  OBJET = "LOC"
  CRITERE(1) += "LOCCAT=4 & STOFCY ='"+[F:POH]POHFCY+"'"
  START = "LOC"
Return

