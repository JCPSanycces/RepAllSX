#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
#
# TRTSTOALLA  Traitement complémentaire du TRTSTOALL ŕ disposition
#             des fonctions appelant la fenętre d'allocations manuelles
#             Il permet de gérer l'interaction avec la fonction origine
#
#             La mise ŕ jour de ce traitement est ŕ la charge du développeur
#             de la fonction origine.
#             La reconnaissance de celle-ci est effectuée avec l'abréviation
#             du masque (LABR) passé en paramčtre ŕ l'action SAISTOALL
#
#########################################################################

#########################################################################
# Chargement du masque STOALL [ALL] Bloc 1 et 2
#
#     Alimenter : VCRNUM       Numéro pičce
#                 VCRLIN       Numéro ligne pičce
#                 VCRSEQ       Numéro séquence pičce
#                 PCU          Unité pičce (conditionnement)
#                 STU          Unité stock
#                 PCUSTUCOE    Coef UC-US
#                 BPCORD       Client ou tiers
#                              ŕ alimenter si :
#                              - Commande
#                              - OF ou EO (allocation matičre sous-traitance)
#                 BPAADD       Adresse livraison
#                              ŕ alimenter si :
#                              - Commande
#                              - OF ou EO (allocation matičre sous-traitance)
#                 RETQTY       Quantité du besoin (UA)
#                 OLDALLQTY    Quantité déjŕ allouée (UA)
#                 SHTQTY       Quantité en rupture (UA)
#                 QTYTOALL     Quantité ŕ allouée (UA)
#                 ALLTYP       Type allocation (M.450)
#                 RETDAT       Date du besoin
#                 DLVDAT       Date de livraison
#                 PECPLFLOC    Prise en compte emp attente de rangement (M.1)
#                              Normalement, mettre ŕ 2
#                 PECSCOLOC    Prise en compte emp sous-traitant (M.1)
#                              Mettre ŕ 2 si :
#                              - OF ou EO (allocation matičre sous-traitance)
#                 STOLOC       Emplacement poste de charge
#                              ŕ renseigner si OF
#                 XLOT         Lot du filtre allocation (exclusif)
#                 XLOC         Emplacement du filtre allocation (exclusif)
#                 XSTA         Statuts du filtre allocation
#                 GLOALLQTY    Quantité déjŕ allouée en global
#                              ŕ alimenter si allocation d'une ligne (cde ou OF)
#                              déjŕ allouée en global et si l'on souhaite
#                              détailler ce global : permet un calcul correct
#                              du stock disponible
#                              Attention ŕ faire un Raz dans le cas contraire
#                 PECOWNER     Filtre propriétaire du stock
#                              ŕ renseigner si allocation du stock d'un tiers :
#                              - OF (alloc matičre sous-traitance chez le s-traitant)
#                              - Retour réception sous-traitance (sauf intra-société)
#                 XWRH         Dépôt de la ligne de document
#                 #--- TS 106217
#                 WECCVALMAJ   Version de la ligne de doocument
#
# Variables globales
#
#     Si commande - alimenter GTYPLIG     = 1 si composant de kit
#                                         = 2 si ligne de contremarque
#                 - alimenter GPRET       = 1 si commande de pręt

#     Si appel depuis fonction allocation par article
#                 - alimenter GRERBPC     = 2 si conso réservations clients
#                 _ alimenter GDIAGENSHT  = 2 si générations des ruptures
#
#########################################################################
$CHARG_PARAM
#--- Issue X3-4501 : ajout écran PJTA1 pour PJM Task
Case LABR
 When "SOH4"  : Gosub CHARGE_STOALL From SUBSOH1
 When "SOQ1"  : Gosub CHARGE_STOALL From SUBSOQ
 When "SAL2"  : Gosub CHARGE_STOALL From FUNMANALL
 When "SHT2"  : Gosub CHARGE_STOALL From CNSSHTSTD
 When "MFG2"  : Gosub CHARGE_STOALL From MFGLIBM
 When "MFGB"  : Gosub CHARGE_STOALL From FUNGBENCH
 When "MFGD"  : Gosub CHARGE_STOALL From FUNDBENCH
 When "MLB"   : Gosub CHARGE_STOALL From FUNMLINK
 When "SCO2"  : Gosub CHARGE_STOALL From SCOLIBM
 When "PJTA1" : Gosub CHARGE_STOALL From SUBPJTA
Endcase

Return

#########################################################################
# Contrôle avant enregistrement
# Si contrôle non OK, mettre FOK=0 pour ne pas enregister
#########################################################################
$AVANT_ENR
#--- Issue X3-4501 : ajout écran PJTA1 pour PJM Task
Case LABR
 When "SOH4"  : Gosub AVANT_STOALL From SUBSOH1
 When "SOQ1"  : Gosub AVANT_STOALL From SUBSOQ
 When "SAL2"  : Gosub AVANT_STOALL From FUNMANALL
 When "SHT2"  : Gosub AVANT_STOALL From CNSSHTSTD
 When "MFG2"  : Gosub AVANT_STOALL From MFGLIBM
 When "MFGB"  : Gosub AVANT_STOALL From FUNGBENCH
 When "MFGD"  : Gosub AVANT_STOALL From FUNDBENCH
 When "MLB"   : Gosub AVANT_STOALL From FUNMLINK
 When "SCO2"  : Gosub AVANT_STOALL From SCOLIBM
 When "PJTA1" : Gosub AVANT_STOALL From SUBPJTA
 When Default
Endcase

Return

#########################################################################
# Mise ŕ jour complémentaires aprčs enregistrement
# Si problčme mettre GOK=0 pour annuler l'enregistrement
#------------------------------------------------------------------------
# WALLQTY contient la quantité allouée
# WSHTQTY contient la quantité en rupture
# WCSOQTY contient la quantité consommée sur les réservations clients
#########################################################################
$APRES_ENR
# Issue 103404 - 2015-03-10 by JUSYN : Additional "MFGD" because missing from FUNDBENCH
#--- Issue X3-4501 : ajout écran PJTA1 pour PJM Task
Case LABR
 When "SOH4"  : Gosub APRES_STOALL From SUBSOH1
 When "SOQ1"  : Gosub APRES_STOALL From SUBSOQ
 When "SAL2"  : Gosub APRES_STOALL From FUNMANALL
 When "SHT2"  : Gosub APRES_STOALL From CNSSHTSTD
 When "MFG2"  : Gosub APRES_STOALL From MFGLIBM
 When "MFGB"  : Gosub APRES_STOALL From FUNGBENCH
 When "MFGD"  : Gosub APRES_STOALL From FUNDBENCH
 When "MLB"   : Gosub APRES_STOALL From FUNMLINK
 When "SCO2"  : Gosub APRES_STOALL From SCOLIBM
 When "PJTA1" : Gosub APRES_STOALL From SUBPJTA
 When Default
Endcase

Return

