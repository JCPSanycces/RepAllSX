#<AdxTL>@(#)0.0.0.0 $Revision$
Call  CRE_ACT_BOM ("D16LOSANGELES","")
End

Subprog CRE_ACT_BOM (ZP_AGINI,ZPAGFIN)
  Value Char ZP_AGINI
  Value Char ZPAGFIN
  If !clalev([F:ZITM1]) : Local File ITMMASTER [F:ZITM1] : Endif
  If !clalev([F:ZITM2]) : Local File ITMMASTER [F:ZITM2] : Endif
  If !clalev([F:ZBOH1]) : Local File BOM       [F:ZBOH1] : Endif
  If !clalev([F:ZBOH2]) : Local File BOM       [F:ZBOH2] : Endif
  If !clalev([F:ZBOD1]) : Local File BOMD      [F:ZBOD1] : Endif
  If !clalev([F:ZBOD2]) : Local File BOMD      [F:ZBOD2] : Endif
  If !clalev([F:ZCD1])  : Local File ZCOLDEP    [F:ZCD1] : Endif
  If !clalev([F:ZTBOH1]): Local File TMPBOM   [F:ZTBOH1] : Endif
  If !clalev([F:ZTBOD]) : Local File TMPBOMD  [F:ZTBOD1] : Endif
  Local Char CRITERE(250),ZERROR(250)
  Local Integer ZPERMISO,ZBORRAR : ZBORRAR = 1

  If (ZP_AGINI<>"" and ZPAGFIN <>"") Then
     CRITERE = "ZARTGEN = 2 & ITMREF >='"+ ZP_AGINI + "and ITMREF <='"+ ZPAGFIN + "'"
  Else
     CRITERE = "ZARTGEN = 2 & ITMREF ='"+ ZP_AGINI +"'"
  Endif

  For  [F:ZITM1]ITM0 Where evalue (CRITERE)
     Read  [F:ZBOH1]BOH0 = [F:ZITM1]ITMREF;1;3
     If !fstat Then
        For  [F:ZITM2]ITM0 Where  CFGFLDALP1 = [F:ZITM1]CFGFLDALP1 #and ZARTGEN <> 2
          ZBORRAR = 1
          Read  [F:ZBOH1]BOH0 = [F:ZITM2]ITMREF;1;3
          If !fstat Then
            Infbox [F:ZITM2]ITMREF -"tiene BOM. Se actualiza.Elimina y crea"
#            Trbegin [F:ZBOD1]  #CUIDADO IGUAL NO ES POR ARTICULO
#              Delete [F:ZBOD1] Where ITMREF = [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT and BOMALTTYP =  [F:ZBOH1]BOMALTTYP
#            Commit
#            Trbegin [F:ZBOH1]
#              Delete [F:ZBOH1] Where ITMREF = [F:ZITM2]ITMREF
#            Commit
            ZBORRAR = 2
            Gosub CREAR_BOM
          Else
            Infbox [F:ZITM2]ITMREF -"no tiene BOM. Se crea"
            Gosub CREAR_BOM
          Endif
        Next
     Else
      Infbox "Aviso.El artículo principal"- [F:ZITM1]ITMREF - "no tiene BOM"
     Endif
  Next

End

###########################################################################
$CREAR_BOM
 #Crear
 ZPERMISO = func PERMISO_CREAR([F:ZITM2]ITMREF,ZERROR)
 If ZPERMISO = 2 Then
     Read  [F:ZBOH1]BOH0 = [F:ZITM1]ITMREF;1;3
     If ZBORRAR = 2 Then

        #[F:ZTBOH1] = [F:ZBOH1]

        For [F:ZBOD2]BOD0  Where ITMREF =  [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP
          #[F:ZTBOD2] = [F:ZBOD2]
        Next

#            Trbegin [F:ZBOD1]  #CUIDADO IGUAL NO ES POR ARTICULO
#              Delete [F:ZBOD1] Where ITMREF = [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT and BOMALTTYP =  [F:ZBOH1]BOMALTTYP
#            Commit
#            Trbegin [F:ZBOH2]
#              Delete [F:ZBOH2] Where ITMREF = [F:ZITM2]ITMREF
#            Commit

     Endif

     Infbox "Asignar a componente"- [F:ZITM2]ITMREF-"valores de cabecera"-[F:ZITM1]ITMREF
    # [F:ZBOH2]       =  [F:ZBOH1]
    # [F:ZBOH2]ITMREF =  [F:ZITM2]ITMREF
     Infbox "Asignar a líneas de "- [F:ZITM2]ITMREF-"valores AG"-[F:ZITM1]ITMREF
     For [F:ZBOD2]BOD0  Where ITMREF =  [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP

    #    [F:ZBOD2]           =  [F:ZBOD1]
    #    [F:ZBOD2]CPNITMREF  =  [F:ZBOD1]CPNITMREF
        If [F:ZBOD1]ZCOLDEP <> "" Then
          Infbox "Campo CD vacío"
          [F:ZBOD2]ZCOLDEP = 0
           Read [F:ZCD1]ZCD0 = [F:ZBOD1]ZCOLDEP;[F:ZITM1]CFGFLDALP2;[F:ZITM1]CFGFLDALP3;[F:ZITM1]ITMREF
           If !fstat Then
              [F:ZBOD2]CPNITMREF = [F:ZCD1]ZARTICULO
#           Else
#              If  [F:ZBOD2]CPNTYP <> 7 Then
#                 Infbox "Error.El componente línea de material"-[F:ZBOD2]CPNITMREF-"no tiene registro en color dependece para el AG"-[F:ZITM1]ITMREF
#              Else
#                 Infbox "Error.El componente línea de servicio"-[F:ZBOD2]CPNITMREF-"no tiene registro en color dependece para el AG"-[F:ZITM1]ITMREF
#              Endif
#
          Endif
        Endif
     Next
     Infbox "ESCRIBE DATOS"
 Else
   Infbox ZERROR
 Endif

Return

####################################################################################################
# Comprueba que todas las líneas de BOMD con valor en CD tengan resgistro asociado en ZCOLDEP
# Parámetro : ZP_ITMREF -> Artículo de l a BOM
# Devuelve  : ZRES      -> 1. Si no todos los registros con valor en CD tienen registros en ZCOLDEP
#                       -> 2. Si todos los registros con valor en CD tienen registros en ZCOLDEP
####################################################################################################
Funprog PERMISO_CREAR(ZP_ITMREF,ZERROR)
  Value Char ZP_ITMREF
  Variable Char ZERROR
  Local Integer ZRES : ZRES = 2
  If !clalev([F:ZCD2])  : Local File ZCOLDEP    [F:ZCD2] : Endif
  If !clalev([F:ZBOH3]) : Local File BOM       [F:ZBOH3] : Endif
  If !clalev([F:ZBOD3]) : Local File BOMD      [F:ZBOD3] : Endif
  If !clalev([F:ZCD2])  : Local File ZCOLDEP    [F:ZCD2] : Endif
  If !clalev([F:ZITM3]) : Local File ITMMASTER [F:ZITM3] : Endif

  Read  [F:ZBOH3]BOH0 =ZP_ITMREF;1;3
  For [F:ZBOD3]BOD0  Where ITMREF =  ZP_ITMREF and BOMALT = [F:ZBOH3]BOMALT  and BOMALTTYP = [F:ZBOH3]BOMALTTYP and ZCOLDEP <> ""
     Read [F:ZITM3]ITM0 = ZP_ITMREF
     Read [F:ZCD2]ZCD0 = [F:ZBOD3]ZCOLDEP;[F:ZITM3]CFGFLDALP2;[F:ZITM3]CFGFLDALP3;[F:ZITM3]ITMREF
     If fstat Then
        ZRES = 1
        If  [F:ZBOD3]CPNTYP <> 7 Then
           ZERROR = "Error.El componente línea de material"-[F:ZBOD3]CPNITMREF-"no tiene registro en color dependece para el AG"-[F:ZITM3]ITMREF
        Else
           ZERROR = "Error.El componente línea de servicio"-[F:ZBOD3]CPNITMREF-"no tiene registro en color dependece para el AG"-[F:ZITM3]ITMREF
        Endif
     Endif
  Next
End ZRES

