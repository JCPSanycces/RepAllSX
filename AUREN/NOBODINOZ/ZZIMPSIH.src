#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "AP_IMPORT"     : Gosub AP_IMPORT
Endcase
Return


$AP_IMPORT
If IMPFIC = "SID"
  If !clalev([F:ZITM])  :   Local File ITMMASTER[ZITM]  : Endif
  Filter [ZITM] Where EANCOD=[F:SID]ITMREF
  Read [ZITM] First
  If !fstat
    [F:SID]ITMREF=[ZITM]ITMREF
  Endif
  Filter [ZITM]
Endif
Return

