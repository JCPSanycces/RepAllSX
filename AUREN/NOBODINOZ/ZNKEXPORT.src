#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################################################
## FUNCIÓN EXPORTACIÓN FICHERO SALIDA (ENTREGA VENTA) PARA NAEKO                                        ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 12/06/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
##########################################################################################################
## Se genera un fichero por cada ENTREGA DE VENTA que se envia a NAEKO para la gestión de expediciones  ##
## Por cada fichero de entrega gestionado, se cambia estado ZSTANAEKO en ENTREGA a 3 (SOLICITADA)       ##
##                                                                                                      ##
##    SALIDAS     Vista ZNKSALIDAS       [ZSAL]                                                         ##
##                                                                                                      ##
##########################################################################################################
#FPH - 001- 26/08/2020 - Al cambiar el estado Naeko "En preparación" se acutaliza las fechas de expedición y entrega

$ACTION
Case ACTION
  When "INIT"     : Gosub INIT
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(250)
  Local Char LPATH(250)
  Local Char LPATHP(250)
  Local Integer STAT

  Local Char FECHOREJEC(15)
  Local Char NOMFIC_ZSAL(250)
  Local Char NUMSAL(30)

  adxifs=chr$(9)                # Separador de campo Tabulador
  adxirs=chr$(13)+chr$(10)      # Separador de registro
  adxium=50                     # ASCII file

  #Check if local directory exists and creates it if not
  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  LPATH=DIRAPL+"\FTP\NAEKO\SALIDAS"
  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

  LPATHP=DIRAPL+"\FTP\NAEKO\SALIDAS\PROCESADOS"

  ## Apertura vista de los datos a exportar
  If clalev([F:ZSAL])<=0    :   Local File ZNKSALIDAS   [ZSAL]  :   Endif
  If clalev([F:ZSDH])<=0    :   Local File SDELIVERY    [ZSDH]  :   Endif
  #001>
  If clalev([F:ZSDH2])<=0    :   Local File SDELIVERY  [ZSDH2]  :   Endif
  If clalev([F:ZSDD])<=0     :   Local File SDELIVERYD  [ZSDD]  :   Endif
  If clalev([F:BPD])<=0      :   Local File BPDLVCUST  [F:BPD]  :   Endif
  Local Date ZDLVDAT :Raz ZDLVDAT
  #001<

Return

$EXEC

  ## Generar ficheros en folder local y actualización estado envío NAEKO
  Gosub SALIDAS

# Subida de ficheros al FTP y mueve fiheros subidos a directorio de copia
  Call ECR_TRACE("Subiendo ficheros", 0) From GESECRAN
  STAT = 0
  Call FTPPUTMOV("ftp.naeko.es","Nobodinoz","357Nz69+","Salidas",LPATH,LPATHP,STAT) From ZAURFTP

  If STAT >= 0
    Call ECR_TRACE("Ficheros subidos: " +num$(STAT), 0) From GESECRAN
  Else
    Call ECR_TRACE("Error en la subida de ficheros. Error: " +num$(STAT), 1) From GESECRAN
  Endif

#Proceso terminado
  Call ECR_TRACE("Proceso terminado " + format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$), 0) From GESECRAN

Return

$TERMINE

Return

###########################################
##             SALIDAS                   ##
###########################################
$SALIDAS

  FECHOREJEC= format$("YYYYMMDD[_]hhmmss",date$)

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando ficheros SALIDAS ...",0) From GESECRAN

  ## Lectura datos y escritura del fichero
  NUMSAL=""
  Filter [ZSAL] Where SDHNUM<>"" Order By SDHNUM
  For [ZSAL]

    If [F:ZSAL]SDHNUM <> NUMSAL

      #Cierre del fichero anterior y actualización estado entrega
      If NUMSAL<>""
        Gosub CIERRE_ENTREGA
      Endif

      #Apertura nuevo fichero y escritura títulos de campos
      NOMFIC_ZSAL=  [F:ZSAL]SDHNUM + "_" + FECHOREJEC
      Openo filpath(LPATH+"\",NOMFIC_ZSAL,"txt"), 0 Using [TXT]

      Wrseq   "Tipo de documento", "Num Documento", "Fecha", "Código Cliente", "Razón social", "Dirección 1",
&             "Dirección 2", "Provincia", "Código Postal", "Población", "País", "Teléfono", "Comentario",
&             "Cantidad", "Artículo", "Transportista", "e-mail", "Referencia externa"
&             Using [TXT]

      # NUMSAL = numero entrega en proceso
      NUMSAL=[F:ZSAL]SDHNUM

    Endif

    #Escritura línea entrega
    Wrseq   [F:ZSAL]SDHTYP, [F:ZSAL]SDHNUM, [F:ZSAL]SHIDAT, [F:ZSAL]BPCORD, [F:ZSAL]BPDNAM, [F:ZSAL]BPAADDLIG1,
&           [F:ZSAL]BPAADDLIG2, [F:ZSAL]BPDSAT, [F:ZSAL]BPDPOSCOD, [F:ZSAL]BPDCTY, [F:ZSAL]BPDCRY, [F:ZSAL]TEL,
&           [F:ZSAL]TEXTE, [F:ZSAL]QTY, [F:ZSAL]EANCOD, [F:ZSAL]BPTNUM, [F:ZSAL]WEB, [F:ZSAL]ZORDREF
&           Using [TXT]


  Next
  Filter [ZSAL]

  #Cierre del último fichero y actualización estado entrega
  If NUMSAL<>""
    Gosub CIERRE_ENTREGA
  Endif

Return

########################################################
##  SALIDAS -> Cierre fichero y actualización estado  ##
########################################################
$CIERRE_ENTREGA

  If NUMSAL<>""
    Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZSAL + ".txt generado",0) From GESECRAN
    Openo Using [TXT]
    Update [F:ZSDH] Where SDHNUM="DEL"+NUMSAL With ZSTANAEKO=3
    #001>
    Read  [F:ZSDH2]SDH0 = "DEL"+NUMSAL

    Update [F:ZSDH] Where SDHNUM="DEL"+NUMSAL With SHIDAT = date$
    Call CALC_DLVDAT(date$,[F:ZSDH2]DAYLTI,[F:ZSDH2]BPAADD,[F:ZSDH2]BPCORD,0,0,ZDLVDAT) From TRTVENDAT
    Update [F:ZSDH] Where SDHNUM="DEL"+NUMSAL With DLVDAT = ZDLVDAT
    Update [F:ZSDD] Where SDHNUM="DEL"+NUMSAL With SHIDAT = date$
    #001<
  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
