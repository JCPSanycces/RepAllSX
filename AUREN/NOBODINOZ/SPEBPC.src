######################################################################################
## AUREN Controles específicos CLIENTES
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
## AUREN Plazo entrega por defecto = 5 días
######################################################################################
Subprog C_XDAYLTI(VALEUR)
Variable Decimal VALEUR
  If VALEUR=0
    VALEUR=5
    Affzo [M]XDAYLTI
  Endif
End
