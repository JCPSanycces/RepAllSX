#FPH Auren 19/06/2020 - 026/024 - Actualización descripciones artículos

# Gestión de la máscara ITM1 (Especifico)

######################################################################################
## AUREN: Creación EANCOD interno y GS1
######################################################################################
$ACTION
Case ACTION
 When "INICRE"   :   Gosub INICRE
 When "INIMOD"   :   Gosub INIMOD
 #026/024+
 When "LIENS"     : Gosub LIENS
 When "APRES_MOD" : Gosub APRES_MOD
 #026/024-
 When Default
Endcase
Return
######################################################################################
#026/024+
$LIENS
   [M:ITM0]ZDES = [F:ITM]ITMDES1
   Affzo [M:ITM0]ZDES
Return
######################################################################################

$APRES_MOD
  If (([M:ITM0]DES1AXX <> [M:ITM0]ZDES) and [F:ITM]ZARTGEN = 2) Then
    Call ACTUALIZA_DESC()
  Endif
Return
#026/024-
######################################################################################

$INICRE
 Gosub ZBARCOD
Return

$INIMOD
 Gosub ZBARCOD
Return

######################################################################################
$ZBARCOD
 Local Integer   STAT, J, I, DC, WSUM, WNUM
 Local Char      WEANCOD(20)
 Local Char      WCODGS1(20)

 # Código GS1 en ZCODGS1 y EANCOD si categoria FG

###AMG.STR AŃADIMOS NUEVO FILTRO, SI EL ARTÍCULO ES KIT TAMBIEN SE GENERA EAN Y GS1
# If [M:ITM1]ZCODGS1="" & [M:ITM1]EANCOD="" & [M:ITM0]ZARTGEN<>2 & [M:ITM2]STOMGTCOD=2 & [M:ITM0]TCLCOD="FG"
If [M:ITM1]ZCODGS1="" & [M:ITM1]EANCOD="" & [M:ITM0]ZARTGEN<>2 & ([M:ITM2]STOMGTCOD=2 | [M:ITS]ITMTYP=3) & [M:ITM0]TCLCOD="FG"
###AMG.END
    Call NUMERO("NBGS1", GFCYDEF(9), datesyst,"",WCODGS1, STAT) From SUBANM
    If STAT = 0
      # Cálculo dígito control
      WSUM=0
      For I=1 To 12 Step 2
        WNUM=val(mid$(WCODGS1,I,1))
        WSUM+=(WNUM*1)
      Next I

      For I=2 To 12 Step 2
        WNUM=val(mid$(WCODGS1,I,1))
        WSUM+=(WNUM*3)
      Next I

      DC = 10-(mod(WSUM,10))
      If DC>=10  :  DC=0  :  Endif

      [M:ITM1]ZCODGS1 = WCODGS1+num$(DC)
      [F:ITM]ZCODGS1 = WCODGS1+num$(DC)

      If [M:ITM1]EANCOD=""
         [M:ITM1]EANCOD = WCODGS1+num$(DC)
         [F:ITM]EANCOD = WCODGS1+num$(DC)
      Endif

      Affzo [M:ITM1]ZCODGS1
      Affzo [M:ITM1]EANCOD

      Return

    Else
       GOK=0  :  Return
    Endif
 Endif

 ## Código de barras interno EANCOD si no categoria FG
 ###AMG.STR AŃADIMOS NUEVO FILTRO, SI EL ARTÍCULO ES KIT TAMBIEN SE GENERA EAN Y GS1
 #If [M:ITM1]EANCOD="" & [M:ITM0]ZARTGEN<>2 & [M:ITM2]STOMGTCOD=2
  If [M:ITM1]EANCOD="" & [M:ITM0]ZARTGEN<>2 & ([M:ITM2]STOMGTCOD=2 | [M:ITS]ITMTYP=3)
 ###AMG.END
    Call NUMERO("NBEAN", GFCYDEF(9), datesyst,"",WEANCOD, STAT) From SUBANM
    If STAT = 0
      [M:ITM1]EANCOD = WEANCOD
      [F:ITM]EANCOD = WEANCOD
      Affzo [M:ITM1]EANCOD
    Else
       GOK=0  :  Return
    Endif
 Endif

Return
######################################################################################
Subprog C_EANCOD(VALEUR)
Variable Char    VALEUR()
End
######################################################################################
Subprog C_ZCODGS1(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
#026/024+
Subprog ACTUALIZA_DESC()
  If !clalev([F:ZITM1]) : Local File ITMMASTER   [F:ZITM1] : Endif
  If !clalev([F:ZBOH1]) : Local File BOM         [F:ZBOH1] : Endif
  If !clalev([F:ZAXX1]) : Local File ATEXTRA     [F:ZAXX1] : Endif

  Local Char ZCAD(250) : Raz ZCAD

  Filter [F:ZITM1] Where ZARTGEN <> 2 and CFGFLDALP1 = [F:ITM]ITMREF
  Read [F:ZITM1]ITM0 First
  For [F:ZITM1]ITM0
    #Tabla artículos
    [F:ZITM1]ITMDES2   = [F:ITM]ITMDES1
    [F:ZITM1]ITMDES1   = [F:ITM]ITMDES1-[F:ZITM1]ITMDES3
    [F:ZITM1]UPDUSR    = GUSER
    [F:ZITM1]UPDDAT    = date$
    [F:ZITM1]UPDDATTIM = time$
    Rewrite [F:ZITM1]
    #Descripción1
    Read [F:ZAXX1]AXX0 = "ITMMASTER";"DES1AXX";"SPA";[F:ZITM1]ITMREF;""
    [F:ZAXX1]TEXTE     = [F:ZITM1]ITMDES1
    [F:ZAXX1]UPDUSR    = GUSER
    [F:ZAXX1]UPDDAT    = date$
    [F:ZAXX1]UPDDATTIM = time$
    Rewrite [F:ZAXX1]
    #Descripción2
    Read [F:ZAXX1]AXX0 = "ITMMASTER";"DES2AXX";"SPA";[F:ZITM1]ITMREF;""
    [F:ZAXX1]TEXTE     = [F:ITM]ITMDES1
    [F:ZAXX1]UPDUSR    = GUSER
    [F:ZAXX1]UPDDAT    = date$
    [F:ZAXX1]UPDDATTIM = time$
    Rewrite [F:ZAXX1]

    #Modificar descripción BOM
    Read [F:ZBOH1]BOH0 = [F:ZITM1]ITMREF;1;3
    If !fstat Then
       Read [F:ZAXX1]AXX0 = "BOM";"BOMDESAXX";"SPA";[F:ZITM1]ITMREF+"~"+num$([F:ZBOH1]BOMALT);num$([F:ZBOH1]BOMALTTYP)
       [F:ZAXX1]TEXTE  = [F:ZITM1]ITMDES1
       Rewrite [F:ZAXX1]
    Endif
  Next
  Filter [F:ZITM1]
End

#026/024-
