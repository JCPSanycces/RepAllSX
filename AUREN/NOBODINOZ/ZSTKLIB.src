#<AdxTL>@(#)0.0.0.0 $Revision$ 
#002 Modificaciones 22/03/2021
####################################################################
#                              VARIABLES
#ZDISP -> Stock disponible real
#ZDISPTEMP -> Disponible contando con reserva
#ZASIGSTD  -> Asignación realizada por el estándar
####################################################################

$ACTION

Case ACTION
  When "BEFREWSTO"     :   Gosub BEFREWSTO

Endcase
Return

#  When "BEFWRISTA"     :   Gosub BEFWRISTA
#  When "BEFREWITV"     :   Gosub BEFREWITV
###############################################################################

$BEFREWSTO

  Global Decimal ZDISP
 # Infbox "BEFREWSTO"
  #Necesario calcular el disponible en este EP, en BEFWRISTA ya tiene el valor asignado
  ZDISP     = func ZDISPONIBLE([F:STO]STOFCY,[F:STO]LOC,[F:STO]ITMREF)

Return


################################################################################
$BEFWRISTA
 If !clalev([F:ZITF1]) : Local File ITMFACILIT [F:ZITF1] : Endif
 If !clalev([F:ZSTA1]) : Local File STOALL     [F:ZSTA1] : Endif
 If !clalev([F:ZSTA2]) : Local File STOALL     [F:ZSTA2] : Endif
 If !clalev([F:ZSTO1]) : Local File STOCK      [F:ZSTO1] : Endif
 If !clalev([F:ZSOH1]) : Local File SORDER     [F:ZSOH1] : Endif
 If !clalev([F:ZSOQ1]) : Local File SORDERQ    [F:ZSOQ1] : Endif
 If !clalev([F:ZITV4]) : Local File ITMMVT     [F:ZITV4] : Endif

 Local Char ZLOC(10) : Raz ZLOC
 Local Decimal ZDISPTEMP : Raz ZDISPTEMP
 Global Decimal ZASIGSTD : Raz ZASIGSTD

 Read [F:ZSOH1]SOH0 = [F:STA]VCRNUM
 Read [F:ZSOQ1]SOQ0 = [F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRLIN
 Read [F:ZITF1]ITF0 = [F:STA]ITMREF;[F:ZSOH1]STOFCY

 If [F:STO]LOC <> "" Then
   ZLOC = [F:STO]LOC
 Endif
 If [F:STA]LOC <> "" Then
   ZLOC = [F:STA]LOC
 Endif
#Infbox "BEFWRISTA"-num$([F:STA]ALLTYP)
## ZDISP no siempre inicializada
 If dim(ZDISP)<>1 Then
    ZDISP = func ZDISPONIBLE([F:STA]STOFCY,ZLOC,[F:STA]ITMREF)
 Endif

 If ([F:ZSOH1]SOHTYP ="ORD20" or  [F:ZSOH1]SOHTYP ="ORD21") and [F:ZSOH1]STOFCY="900" and  ZLOC ="098" Then

 Else
    ZDISPTEMP = ZDISP-[F:ZITF1]ZRESERVB2C
    If ZDISPTEMP <0 Then
       ZDISPTEMP = 0
    Endif


    If [F:STA]QTYSTUACT > 0 and [F:ZITF1]ZRESERVB2C > 0 and [F:STA]ALLTYP = 2 Then

       ZASIGSTD   = [F:STA]QTYSTU
       If ZDISPTEMP <  [F:STA]QTYSTU Then

           ZPEND             = [F:ZSOQ1]QTY-[F:ZSOQ1]DLVQTY-[F:ZSOQ1]ODLQTY
           [F:STA]QTYSTU    -= ZASIGSTD-ZDISPTEMP
           [F:STA]QTYSTUACT -= ZASIGSTD-ZDISPTEMP
            Read [F:ZSTO1]STO0 = [F:STA]STOFCY;[F:STA]STOCOU
            If !fstat Then
              If ZDISPTEMP = 0 Then
#                [F:ZSTO1]CUMALLQTY -= ([F:STO]CUMALLQTY - ZASIGSTD)
#                [F:ZSTO1]CUMALLQTA -= ([F:STO]CUMALLQTY - ZASIGSTD)
              Else
                [F:ZSTO1]CUMALLQTY -= ZASIGSTD-ZDISPTEMP
                [F:ZSTO1]CUMALLQTA -= ZASIGSTD-ZDISPTEMP
              Endif
              Rewrite [F:ZSTO1]
            Endif

           #Se genera ruptura. Caso que existe stock real pero con unidades reservadas
           #002>
           #If ZDISPTEMP < ZASIGSTD and ZPEND <= ZASIGSTD Then
           If ZDISPTEMP < ZASIGSTD and ZPEND <= ZASIGSTD  Then
           #002<
             Raz [F:ZSTA2]
             [F:ZSTA2]          = [F:STA]
             [F:ZSTA2]STOCOU    = 0
             [F:ZSTA2]ALLTYP    = 4
             [F:ZSTA2]SEQ       = [F:STA]SEQ-1
             [F:ZSTA2]QTYSTU    = 0
             [F:ZSTA2]QTYSTUACT = ZASIGSTD-ZDISPTEMP
             [F:ZSTA2]LOC       = [F:STO]LOC
             Write [F:ZSTA2]
           Endif

       Endif


    Endif
    #2
    #Ruptura estándar en base a stock real
    #ZPEND  = [F:SOQ]QTY-[F:SOQ]DLVQTY-[F:SOQ]ODLQTY
    ZPEND  = [F:ZSOQ1]QTY-[F:ZSOQ1]DLVQTY-[F:ZSOQ1]ODLQTY

   # If [F:STA]QTYSTUACT > 0 and [F:ZITF1]ZRESERVB2C > 0 and [F:STA]ALLTYP = 4 and [F:STA]QTYSTUACT < (ZPEND-ZDISPTEMP)   Then
   If   [F:ZITF1]ZRESERVB2C > 0 and [F:STA]ALLTYP = 4 and [F:STA]QTYSTUACT < (ZPEND-ZDISPTEMP)   Then
           #ASIGANCIÓN SIN MODIFICACIÓN DE CANTIDAD PEDIDA

            #CONDICION PARA QUE ENTRE DESDE DESPECÍFICO, NO ESTA ABIERTA, NI DEJEA ABRIR [F:SOQ]
            If [F:ZSOQ1]QTY = [F:SOQ]QTY or GFONCTION="GESZASIG" Then
              #001> Caso segunda asignación
              If ZDISPTEMP = 0 Then
                   #001>
                   Read [F:ZITV4]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY

                   [F:STA]QTYSTUACT =  (ZPEND) - [F:SOQ]ALLQTY

                   Filter [F:ZSTO1] Where STOFCY = [F:STA]STOFCY and ITMREF=[F:STA]ITMREF and LOC = ZLOC
                   Read [F:ZSTO1]STO0 First
                   If !fstat Then
                     [F:ZSTO1]CUMALLQTY -= ZDISP
                     [F:ZSTO1]CUMALLQTA -= ZDISP
                     Rewrite [F:ZSTO1]
                     Filter [F:ZSTA2] Where ALLTYP= 2 and STOCOU = [F:ZSTO1]STOCOU and STOFCY = [F:STA]STOFCY and VCRNUM=[F:STA]VCRNUM and VCRLIN =[F:STA]VCRLIN and ITMREF=[F:STA]ITMREF
                     Read [F:ZSTA2]STA0 First
                     If !fstat Then
                       [F:ZSTA2]QTYSTU    = [F:SOQ]ALLQTY
                       [F:ZSTA2]QTYSTUACT = [F:SOQ]ALLQTY
                       Rewrite  [F:ZSTA2]
                     Endif
                     Filter [F:ZSTA2]
                   Endif

               #001<
              Else
               #Asignaciones pedido 15/04/21
               If [F:ZSOQ1]ALLQTY > 0 Then
                 If GFONCTION="GESZASIG" Then
                   If [F:STA]QTYSTUACT <= (ZPEND-ZDISPTEMP) Then
                      [F:STA]QTYSTUACT = (ZPEND-ZDISPTEMP)
                   Else
                     [F:STA]QTYSTUACT += ZDISP-ZDISPTEMP
                   Endif
                 Else
                   #19/04/2021
                    Filter [F:ZSTA2] Where ALLTYP= 2 and STOFCY = [F:STA]STOFCY and VCRNUM=[F:STA]VCRNUM and VCRLIN =[F:STA]VCRLIN and ITMREF=[F:STA]ITMREF
                    Read [F:ZSTA2]STA0 First
                    If !fstat Then
                        If [F:STA]QTYSTUACT <= (ZPEND-ZDISPTEMP) Then
                          [F:STA]QTYSTUACT = (ZPEND-ZDISPTEMP-[F:ZSOQ1]ALLQTY)
                        Else
                          [F:STA]QTYSTUACT +=ZDISP-ZDISPTEMP
                        Endif
                    Endif
                    Filter [F:ZSTA2]
                 Endif
               Else #[F:ZSOQ1]ALLQTY<> 0
                 [F:STA]QTYSTUACT = ZPEND-ZDISPTEMP
               Endif

                   Filter [F:ZSTO1] Where STOFCY = [F:STA]STOFCY and ITMREF=[F:STA]ITMREF and LOC = ZLOC
                   Read [F:ZSTO1]STO0 First
                   If !fstat Then
                      Local Integer ZFLAG: Raz ZFLAG
                      #Modificar asignación
                      Filter [F:ZSTA2] Where ALLTYP= 2 and STOCOU = [F:ZSTO1]STOCOU and STOFCY = [F:STA]STOFCY and VCRNUM=[F:STA]VCRNUM and VCRLIN =[F:STA]VCRLIN and ITMREF=[F:STA]ITMREF
                      Read [F:ZSTA2]STA0 First
                      If !fstat Then
                        ZFLAG = 1
#                       [F:ZSTA2]QTYSTU    = [F:SOQ]ALLQTY
#                       [F:ZSTA2]QTYSTUACT = [F:SOQ]ALLQTY
                        #If ZASIGSTD <> 0 Then
                          [F:ZSTA2]QTYSTU    = (ZPEND - [F:STA]QTYSTUACT)
                          [F:ZSTA2]QTYSTUACT = (ZPEND - [F:STA]QTYSTUACT)
                          Rewrite  [F:ZSTA2]
                        #Endif
                      Endif
                      Filter [F:ZSTA2]

                      #Asignaciones pedido 15/04/21
                      If [F:ZSOQ1]ALLQTY > 0 Then
                      #Modifiación 16/04/2021
                        If GFONCTION="GESZASIG" Then
#                          [F:ZSTO1]CUMALLQTY -= ZDISPTEMP
#                          [F:ZSTO1]CUMALLQTA -= ZDISPTEMP
                        Else #error ya se ha hecho operacion en stock
                         If (ZFLAG = 0) or  [F:ZSTA2]QTYSTU > ZDISPTEMP   Then
                          [F:ZSTO1]CUMALLQTY -= ZDISPTEMP
                          [F:ZSTO1]CUMALLQTA -= ZDISPTEMP
                         Endif
                        Endif
                      Endif

                      Rewrite [F:ZSTO1]
                     #Modificar asignación comentado 19/04/2021
#                     Filter [F:ZSTA2] Where ALLTYP= 2 and STOCOU = [F:ZSTO1]STOCOU and STOFCY = [F:STA]STOFCY and VCRNUM=[F:STA]VCRNUM and VCRLIN =[F:STA]VCRLIN and ITMREF=[F:STA]ITMREF
#                     Read [F:ZSTA2]STA0 First
#                     If !fstat Then
##                       [F:ZSTA2]QTYSTU    = [F:SOQ]ALLQTY
##                       [F:ZSTA2]QTYSTUACT = [F:SOQ]ALLQTY
#                       [F:ZSTA2]QTYSTU    = ZPEND - [F:STA]QTYSTUACT
#                       [F:ZSTA2]QTYSTUACT = ZPEND - [F:STA]QTYSTUACT
#                       Rewrite  [F:ZSTA2]
#                     Endif
#                     Filter [F:ZSTA2]
                   Endif
              Endif
              #[F:STA]QTYSTUACT = ZPEND-[F:SOQ]ALLQTY
              #001<
             Else
                 #calclo de ZPEND necesario para modificación de cantidad en pedido
                 ZPEND = [F:SOQ]QTY-[F:SOQ]DLVQTY-[F:SOQ]ODLQTY
                 [F:STA]QTYSTUACT =  (ZPEND) - [F:SOQ]ALLQTY

                 Filter [F:ZSTO1] Where STOFCY = [F:STA]STOFCY and ITMREF=[F:STA]ITMREF and LOC = ZLOC
                 Read [F:ZSTO1]STO0 First
                 If !fstat Then

                   [F:ZSTO1]CUMALLQTY = [F:ITV]PHYALL
                   [F:ZSTO1]CUMALLQTA = [F:ITV]PHYALL
                   Rewrite [F:ZSTO1]
                   Filter [F:ZSTA2] Where ALLTYP= 2 and STOCOU = [F:ZSTO1]STOCOU and STOFCY = [F:STA]STOFCY and VCRNUM=[F:STA]VCRNUM and VCRLIN =[F:STA]VCRLIN and ITMREF=[F:STA]ITMREF
                   Read [F:ZSTA2]STA0 First
                   If !fstat Then
                     [F:ZSTA2]QTYSTU    = [F:SOQ]ALLQTY
                     [F:ZSTA2]QTYSTUACT = [F:SOQ]ALLQTY
                     Rewrite  [F:ZSTA2]
                   Endif
                   Filter [F:ZSTA2]
                 Endif
             Endif
    Endif
 Endif

Return
###########################################################

$BEFREWITV
  If !clalev([F:ZSOH2]) : Local File SORDER     [F:ZSOH2] : Endif
  If !clalev([F:ZSOQ2]) : Local File SORDERQ    [F:ZSOQ2] : Endif
  If !clalev([F:ZITF3]) : Local File ITMFACILIT [F:ZITF3] : Endif
  If !clalev([F:ZITV3]) : Local File ITMMVT     [F:ZITV3] : Endif

  Local Decimal ZDISPTEMP,ZPEND : Raz ZDISPTEMP,ZPEND

  Read [F:ZITV3]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY

  #Al crear pedido escribe en movimiento desde pedidos y entradas varias. Se excluyen
  #001>

  If dim(ZDISP)<=0
    Global Decimal ZDISP
    ZDISP =[F:ITV]AVCBASQTY-[F:ITV]PHYALL
  Endif

  #If ([F:ITV]PHYALL > [F:ZITV3]PHYALL) and dim(ZDISP)>0 Then
  #or (dim([F:STA]ALLTYP)>0 and [F:ITV]PHYALL = [F:ZITV3]PHYALL)   para el caso de asignación pedido si no hay asignación pero si ruptura
  If ([F:ITV]PHYALL > [F:ZITV3]PHYALL)  or (dim([F:STA]ALLTYP)>0 and [F:ITV]PHYALL = [F:ZITV3]PHYALL)   Then
  #001<
      If [F:SOH]SOHNUM <> "" Then
        Read [F:ZSOH2]SOH0 = [F:SOH]SOHNUM
        Read [F:ZSOQ2]SOQ0 = [F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
      Else
        Read [F:ZSOH2]SOH0 = [F:STA]VCRNUM
        Read [F:ZSOQ2]SOQ0 = [F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRLIN
      Endif


        If [F:STO]LOC <> "" Then
           ZLOC = [F:STO]LOC
        Endif
        If [F:STA]LOC <> "" Then
          ZLOC = [F:STA]LOC
        Endif

    #002>
      Read [F:ZITF3]ITF0 = [F:ITV]ITMREF;[F:ZSOH2]STOFCY
      If ([F:ZSOH2]SOHTYP ="ORD20" or  [F:ZSOH2]SOHTYP ="ORD21") and [F:ZSOH2]STOFCY="900" and  [F:ZITF3]DEFLOCTYP(0) ="098" Then
    #002<
      Else
      Infbox "BEFREWITV"-num$([F:STA]ALLTYP)
          #002>
          #Read [F:ZITF3]ITF0 = [F:ITV]ITMREF;[F:ZSOH2]STOFCY
          #002<
          ZDISPTEMP = ZDISP-[F:ZITF3]ZRESERVB2C
          If ZDISPTEMP <0 Then
            ZDISPTEMP = 0
          Endif

          #ASIGANCIÓN SIN MODIFICACIÓN DE CANTIDAD PEDIDA
          #002>
          #If [F:ZSOQ2]QTY = [F:SOQ]QTY Then
          #Se modifica condición, si no el estándar no entra en ningun caso qty
#Infbox "BEFREWITV"-num$([F:STA]ALLTYP)
          If ([F:ZSOQ2]QTY = [F:SOQ]QTY) or ([F:SOH]SOHNUM ="" and [F:SOQ]QTY = 0)  Then
          #002<

              If [F:ZSOQ2]QTYSTU > 0 and [F:ZITF3]ZRESERVB2C > 0  and dim(ZDISP)>0 and [F:STA]ALLTYP = 2 Then
                   ZPEND     = [F:ZSOQ2]QTY-[F:ZSOQ2]DLVQTY-[F:ZSOQ2]ODLQTY
#condición para específico 16/04/2021
                 #If (GFONCTION="GESZASIG" and  ZASIGSTD > ZDISPTEMP)  Then
                  If (GFONCTION="GESZASIG") Then
                    #If ZASIGSTD < ZDISPTEMP and ZASIGSTD = [F:STA]QTYSTUACT   Then
                    If [F:STA]QTYSTU < =ZDISPTEMP Then #and ZASIGSTD = [F:STA]QTYSTUACT   Then
                       If [F:STA]QTYSTU = ZDISPTEMP Then
                         [F:ITV]PHYALL -=  ([F:ITV]PHYALL-[F:STA]QTYSTU)#81-3=78
                         [F:ITV]DETSHT +=  (ZASIGSTD-ZDISPTEMP) #A esta cantidada se acumula despues la ruptura estándar
                       Endif
                       If [F:STA]QTYSTU < ZDISPTEMP Then
                          [F:ITV]DETSHT +=  (ZDISP-ZDISPTEMP) #A esta cantidada se acumula despues la ruptura estándar
                       Endif
#
                    Endif
                    #segunda condicion 13/04/2021
                    ZASIGSTD = [F:STA]QTYSTU
                    If ZASIGSTD > ZDISPTEMP  Then

                        [F:ITV]PHYALL -=  ZDISP-ZDISPTEMP
                        [F:ITV]DETSHT +=  (ZDISP-ZDISPTEMP)#A esta cantidada se acumula despues la ruptura estándar

                    Endif
                 Else


                      If dim(ZASIGSTD)> 0 Then
                         If ZDISPTEMP <  ZASIGSTD Then
                              [F:ITV]PHYALL -=  ZASIGSTD-ZDISPTEMP
                              [F:ITV]DETSHT +=  ZASIGSTD-ZDISPTEMP #A esta cantidada se acumula despues la ruptura estándar
                         Endif
                         #desde asignación solo ruptura condicion función 16/04/2021
                         If  ZASIGSTD = 0 and GFONCTION<>"GESZASIG" Then
                              [F:ITV]PHYALL -=  ZDISPTEMP
                              [F:ITV]DETSHT +=  ZDISPTEMP
                         Endif
                      Else #Caso asignación pedido
                         If ZDISPTEMP < [F:STA]QTYSTUACT Then
                            [F:ITV]PHYALL -=  (ZDISPTEMP)
                            [F:ITV]DETSHT +=  (ZDISPTEMP) #A esta cantidada se acumula despues la ruptura estándar
                         Endif
                      Endif
                 Endif

              Endif
              #Modificación 19/04/2021
#              If [F:ZSOQ2]QTYSTU > 0 and [F:ZITF3]ZRESERVB2C > 0 and  dim(ZDISP)>0 and [F:STA]ALLTYP = 4 Then
#                 If ZDISPTEMP >  0 Then
#                     [F:ITV]PHYALL +=  ZDISPTEMP
#                     [F:ITV]DETSHT +=  (ZPEND-([F:ZSOQ2]ALLQTY+ZDISPTEMP))
#                 Endif
#              Endif
          Else
          #ASIGANCIÓN CON MODIFICACIÓN DE CANTIDAD PEDIDA
              If [F:SOQ]QTYSTU > 0 and [F:ZITF3]ZRESERVB2C > 0  and [F:STA]QTYSTUACT>0 and dim(ZDISP)>0 and [F:STA]ALLTYP = 2 Then
                 ZPEND  = [F:SOQ]QTY-[F:SOQ]DLVQTY-[F:SOQ]ODLQTY
                 If ZDISPTEMP < [F:STA]QTYSTUACT Then
                    [F:ITV]PHYALL =   [F:ZITV3]PHYALL
                    [F:ITV]DETSHT +=  (ZPEND - [F:SOQ]ALLQTY)
                    Global Decimal ZMOV :Raz ZMOV
                    #Se guarda para usarlo en el EP de pedidos
                    ZMOV =  [F:ITV]DETSHT
                 Endif
             Endif
          Endif
       Endif
   Endif
Return
###########################################################
###########################################################

Funprog ZDISPONIBLE(P_STOFCY,P_LOC,P_ITMREF)
  Value Char P_STOFCY,P_LOC,P_ITMREF

  Local Integer ZRES : Raz ZRES

  If !clalev([F:ZSTO3]) : Local File STOCK     [F:ZSTO3] : Endif

  For [F:ZSTO3]STO0 Where STOFCY = P_STOFCY and LOC = P_LOC and LOCCAT = 1 and STA ='A' and ITMREF = P_ITMREF
       ZRES += [F:ZSTO3]QTYSTU-[F:ZSTO3]CUMALLQTA
  Next

End ZRES
