##########################################################################################################
# 06.330.273 - JC.30032022.Comprueba si existe la entrega antes de actualizar
##########################################################################################################

$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I

  Local Char SDHNUM(15)                         #Num. entrega
  Local Char ZSTANAEKO(1)                       #Estado entrega
  Local Char ZZGROWEI(15)                       #Peso
  Local Char ZZVOLUM(15)                        #Vol·men
  Local Char ZZNUMBOX(15)                       #Cajas
  Local Char PACNBR(15)                         #Bultos
  Local Char DPEDAT(8)                          #Fecha salida
  Local Char ETD(7)                             #Hora salida
  Local Char HEADER(250)(1..)

  Call ECR_TRACE("Iniciando importaci¾n Expediciones Naeko",0) From GESECRAN

  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Naeko\Expediciones"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

Return

$EXEC

  #Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  #Call FTPGETDEL("ftp.naeko.es","Nobodinoz","357Nz69+","Expediciones",DIRFTP,RES) From ZAURFTP

  #If RES < 0

  #  Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN

  #Else

  #  Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN

  #Endif

#Process the dodnloaded files

  #CAMBIO 26/11/2020 SOLO IMPORTAR .PRO
  #ORDRE = "dir /b "+DIRFTP+"\*.csv 2>nul"
  ORDRE = "dir /b "+DIRFTP+"\*.pro 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros",0) From GESECRAN

    For I = 1 To RES

      FILNAME = DIRFTP+"\"+left$(FILELIST(I),len(FILELIST(I))-4)

      #Openi FILNAME+".csv", 0 Using [FIN]

      #Iomode adxifs "" Using [FIN]                                      # Separador de campo nulo para primera lĒnea
      #Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro
      #Iomode adxium 50 Using [FIN]                                      # ASCII file
      #Rdseq HEADER Using [FIN]                                          # Drop header

      #Iomode adxifs ";" Using [FIN]                                     # Separador de campo ";"
      #Rdseq SDHNUM,ZSTANAEKO,ZZGROWEI,ZZVOLUM,ZZNUMBOX,PACNBR,DPEDAT,ETD Using [FIN]

      #SDHNUM = "DEL"+ctrans(SDHNUM,chr$(34),"")                          #Remove the " IN THE RECIVIED Field and ADD DEL PREFIX
      #ETD = ctrans(ETD,chr$(34),"")                                      #Remove the " in the recivied field

      #Openo FILNAME+".pro", 0 Using [FOUT]

      #Iomode adxifs ";" Using [FOUT]
      #Iomode adxirs chr$(13)+chr$(10) Using [FOUT]
      #Iomode adxium 0 Using [FOUT]

      #Wrseq SDHNUM,ZSTANAEKO,ZZGROWEI,ZZVOLUM,ZZNUMBOX,PACNBR,DPEDAT,ETD Using [FOUT]

      #Openi  Using [FIN]
      #Openo  Using [FOUT]

###############################################################################################
#AUREN 05-11-2021 INICIO COMENTAMOS IMPORSIL PARA EVITAR ERROR QUE SE PRODUCE CUANDO HAY ELEMENTO KIT EN ENTREGA
#      Call IMPORTSIL("ZNKSDH",FILNAME+".pro") From GIMPOBJ
#LEEMOS FICHERO .PRO

#      ORDRE = "MOVE "+FILNAME+".pro "+DIRPRO
#      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
#      ORDRE = "MOVE "+FILNAME+".csv "+DIRPRO
#      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
#      ORDRE = "MOVE "+FILNAME+".pro.err "+DIRPRO
#      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

Call ECR_TRACE("Inicializando variables ",0) From GESECRAN

Gosub VARIABLES
NAMEFIC=left$(FILELIST(I),len(FILELIST(I))-4)
# 06.330.273.ini
#ZRUTA=filpath(DIRFTP,NAMEFIC,"pro") #Escritura
ZRUTA=DIRFTP+"\"+FILELIST(I)
# 06.330.273.fin

    Openi ZRUTA      Using [FOUT]
    adxifs =  ";"                                             # Field separator
    adxirs =  chr$(13)+chr$(10)                                       # Register separator CR+LF
    adxium = 50

Gosub ACTUALIZA
Openi Using [FOUT]

Call ECR_TRACE("Moviendo ficheros al servidor ",0) From GESECRAN

      ORDRE = "MOVE "+FILNAME+".pro "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      ORDRE = "MOVE "+FILNAME+".csv "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      ORDRE = "MOVE "+FILNAME+".pro.err "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS


    Next I

####AUREN FIN 5-11-2021
########################################################################################################################

  Call ECR_TRACE("Fin del procesado de ficheros. Ficheros procesados: "+num$(RES),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End


####AUREN 05-11-2021 INICIO
#######################################################################################
$ACTUALIZA
  Repeat

    Rdseq  VSDHNUM,VZSTANAEKO,VZZGROWEI,VZZVOLUM,VZZNUMBOX,VPACNBR,VDPEDAT,VETD Using [FOUT]
     Call ECR_TRACE("Iniciando actualizaci¾n de la entrega: "+VSDHNUM,0) From GESECRAN
        If VSDHNUM<>"" Then
# 06.330.273.ini
          Filter [F:ZSDH] Where SDHNUM = VSDHNUM
          Read [F:ZSDH] First
          If fstat <> 0 Then
            Filter [F:ZSDH]
            Call ECR_TRACE("*****ERROR: La entrega "+VSDHNUM+" no existe en el sistema",1) From GESECRAN
          Else
# 06.330.273.fin
            #si nos pasan un 0 por fecha
            If VDPEDAT="0"
              VDPEDAT='1753-01-01'
            Endif

                Update [F:ZSDH] Where SDHNUM = VSDHNUM With ZSTANAEKO = VZSTANAEKO, ZZGROWEI= val(ctrans(VZZGROWEI,",",".")),ZZVOLUM= val(ctrans(VZZVOLUM,",","."))
&         ,ZZNUMBOX= val(ctrans(VZZNUMBOX,",",".")),PACNBR=val(ctrans(VPACNBR,",",".")),DPEDAT=VDPEDAT,ETD=VETD

                If !fstat
                 Call ECR_TRACE("Actualizada la entrega "+VSDHNUM,0) From GESECRAN
                Else
                 Call ECR_TRACE("No se pudo realizar la actualizaci¾n de la entrega "+VSDHNUM+" . Error: "+num$(RES),1) From GESECRAN
                Endif
          Endif                                                           # 06.330.273.new
        Endif
  Until fstat<>0
Return

$VARIABLES
  Local Char ZRUTA(250),NAMEFIC(250)
  Local Char VSDHNUM(250),VZSTANAEKO(250),VZZGROWEI(250),VZZVOLUM(250),VZZNUMBOX(250),VPACNBR(250),VDPEDAT(250),VETD(250)
  If !clalev([F:ZSDH]) : Local File SDELIVERY   [F:ZSDH] : Endif
Return
####AUREN FIN 05-11-2021
