#<AdxTL>@(#)0.0.0.0 $Revision$
Call CREAR_BOM(ZP_ITMREF,3)

Subprog CREAR_BOM(ZP_ITMREF,ZP_BOMALTTYP)
  Value Char ZP_ITMREF
  Value Integer ZP_BOMALTTYP
  Local Char ZRUTA(250)
  If !clalev([F:ZBOH4]) : Local File BOM       [F:ZBOH4] : Endif
  If !clalev([F:ZBOD4]) : Local File BOMD      [F:ZBOD4] : Endif
  Filter [F:ZBOH4] Where ITMREF = ZP_ITMREF and BOMALTTYP = ZP_BOMALTTYP
  Read [F:ZBOH4]BOH0 First
  #Ruta fichero
  ZRUTA = filpath("IMPORT", "ZBOMS_"+GUSER+"_"+format$("D:YYMMDD",date$)+ctrans(time$,":",""),"txt")
  #Crear el fichero
  Openo ZRUTA Using [ZBOM]
  Iomode adxium 0 Using [ZBOM] #Codificación UTF8
  Iomode adxifs "|;" Using [ZBOM] #Separador de campos
  Iomode adxirs chr$(13)+chr$(10) Using [ZBOM] #Separador de registros

  Wrseq "E" ; Using [ZBOM]
  Wrseq [F:ZBOH4]ITMREF ; Using [ZBOM]
  Wrseq [F:ZBOH4]BOMALT  ; Using [ZBOM]
  Wrseq [F:ZBOH4]USESTA ; Using [ZBOM]
  Wrseq [F:ZBOH4]BASQTY ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "" ; Using [ZBOM]
  Wrseq "L"; Using [ZBOM]
  For [F:ZBOD4]BOD0  Where ITMREF =ZP_ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP
  Next

#  Wrseq [F:ZSDD]ITMREF ; Using [ZSDH] #Artículo
#  Wrseq [F:ZSDD]ITMDES ; Using [ZSDH] #Descripción
#  Wrseq [F:ZSDD]SAU ; Using [ZSDH] #Unidad venta
#  Wrseq num$([F:ZSDD]QTY) Using [ZSDH] #Cantidad entregada
#  #Cerrar el fichero
#  Openo Using [ZSDH]
#  #Abrir la traza de importación
#  Call OUVRE_TRACE("Importación de entregas") From LECFIC
#  #Evita que salgan mensajes (opcional)
#  GSILENCE = 1
#  #Llamar al modelo de importación
#  Call IMPORTSIL("ZMODELO", ZRUTA) From GIMPOBJ
#  #Reactiva los mensajes (opcional)
#  GSILENCE = 0
#  #Cerrar y leer la traza en caso de error
#  Call FERME_TRACE From LECFIC
#  If GERRTRACE <> 0
#  Call LEC_TRACE From LECFIC
#Endif

