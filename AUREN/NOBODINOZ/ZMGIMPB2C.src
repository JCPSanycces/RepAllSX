#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################################################
## PROGRAM ZMGIMPB2C: IMPORTACION PEDIDOS B2C MAGENTO                                                   ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 12/06/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 00.000.000                                                                    ##
## OBJETIVO: DESCARGA VIA FTP LOS FICGEROS DE PEDIDOS B2  PARA SER IMPORTADOS EN SAGE X3, ADECUANDO     ##
##           EL FORMATO DEL FICHERO                                                                     ##
##########################################################################################################
#001- FPH - 6.108.378 - VENTA B2C / CLIENTE _ problema en dirección de ENTREGA
#002- FPH - 6.226.958 - NUEVA NORMATIVA IVA EN B2C
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I
  Local Integer NUMLINES

  Local Char LIN(6)                             #Line Code

  Local Char BCGCOD(5)                          #Client category
  Local Char LAN(3)                             #Client language
  Local Char CLIENT(15)                         #Client Code
  Local Char CNAME(35)                          #Client Name
  Local Char ADDRESS(50)                        #Client Address
#002<
  Local Char ACCCOD(10)                         #Código contable
  Local Char VACBPR(5)                          #Reg. impuesto
#002>
  Local Char POSTCODE(10)                       #Client Postal Code
  Local Char CITY(15)                           #Client City
  Local Char SAT(35)                            #Client Province
  Local Char COUNTRY(2)                         #Client Country Code
  Local Char MAIL(80)                           #Client email
  Local Char UNDEFINED(0)
  Local Char CPERSON(1)                         #Client person or company
  Local Char TEL(20)                            #Client telephone
  Local Char CARRIER(15)                        #Client carrier
  Local Char CUPON(15)                          #Cupon reference
  Local Char DISCOUNT(15)                       #Sale discount

  Local Char SHOP(3)                            #Shop code
  Local Char ORDERNUM(!5)                       #Order number
  Local Char ORDERDATE(19)                      #Order date and time
  Local Char SKU(13)                            #Item SKU
  Local Char QTY(10)                            #Quantity
  Local Char PRICE(10)                          #Price
  Local Char CLIENTORDER(15)                    #Client code
  Local Char DELCOST(10)                        #Delivery cost
  Local Char TAXES(1)                           #Taxes Y or N
  Local Char DELDATE(10)                        #Delivery Date
  Local Char VOID1(1)                           #Empty field 1
  Local Char VOID2(1)                           #Empty field 2
  Local Char VOID3(1)                           #Empty field 3
  Local Char VOID4(1)                           #Empty field 4
  #001>
  Local Char  ZDIR1(50),ZDIR2(50) :Raz ZDIR1,ZDIR2
  #001<

  Call ECR_TRACE("Iniciando importación Pedidos B2C Magento",0) From GESECRAN

  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Magento\PedidosB2C"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  ORDRE = "MOVE *.pro "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
  ORDRE = "MOVE *.err "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

Return

$EXEC

  Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  Call FTPGETDEL("178.255.225.113","ftp_nobo7importerp","nataiFovoo7Een3g","pedidos_base",DIRFTP,RES) From ZAURFTP

  If RES < 0

    Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN

  Else

    Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN

  Endif

  #Process the dodnloaded files

  ORDRE = "dir /b "+DIRFTP+"\*.txt 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros",0) From GESECRAN

    For I = 1 To RES

      FILNAME = DIRFTP+"\"+left$(FILELIST(I),len(FILELIST(I))-4)

      Openi FILNAME+".txt", 0 Using [FIN]                               # Received file with customers and orders
      Iomode adxifs chr$(9) Using [FIN]                                 # Separador de campo tab
      Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro CR+LF
      Iomode adxium 0 Using [FIN]                                       # UTF-8 file

      Openo FILNAME+"BP.pro", 0 Using [FBPO]                            # File for custeers import
      Iomode adxifs ";" Using [FBPO]                                    # Separador de campo ";"
      Iomode adxirs chr$(13)+chr$(10) Using [FBPO]                      # Separador de registro CR + LF
      Iomode adxium 0 Using [FBPO]                                      # UTF-8 file

      Openo FILNAME+"SO.pro", 0 Using [FSOO]                            # File for orders import
      Iomode adxifs ";" Using [FSOO]                                    # Separador de campo ";"
      Iomode adxirs chr$(13)+chr$(10) Using [FSOO]                      # Separador de registro CR + LF
      Iomode adxium 0 Using [FSOO]                                      # UTF-8 file

      #Get the customer line
      Rdseq LIN,CLIENT,CNAME,ADDRESS,POSTCODE,CITY,SAT,COUNTRY,MAIL,UNDEFINED,CPERSON,TEL,CARRIER,CUPON,DISCOUNT Using [FIN]
      Rdseq UNDEFINED Using [FIN]

      If fstat <> 0

        Openi Using [FIN]
        Openo Using [FBPO]
        Openo Using [FSOO]
        Call ECR_TRACE("Error en el formato de fichero "+LFILES(I)+". Fin de fichero inesperado",1) From GESECRAN

      Elsif LIN <> "CLIC1"

        Openi Using [FIN]
        Openo Using [FBPO]
        Openo Using [FSOO]
        Call ECR_TRACE("Error en el formato de fichero "+LFILES(I)+". Línea tipo cliente no encontrada",1) From GESECRAN

      Else

        NUMLINES = 0

        #Get the orders lines

        Rdseq LIN,SHOP,ORDERNUM,ORDERDATE,SKU,QTY,PRICE,CLIENTORDER,DELCOST,TAXES,DELDATE,VOID1,VOID2,VOID3,VOID4 Using [FIN]
        Rdseq UNDEFINED Using [FIN]

        While fstat <> 1

          If LIN <> "PEDC1"

            Call ECR_TRACE("Error en el formato de fichero "+LFILES(I)+". Línea tipo pedido no encontrada",1) From GESECRAN
            Break

          Endif

          NUMLINES+=1
          LAN = "BRI"

          DELDATE =  left$(DELDATE,4)+mid$(DELDATE,6,2)+mid$(DELDATE,9,2)

          If NUMLINES = 1

#002<
#            If TAXES = "N" : BCGCOD = "B2CEX" : Else
#
#              Case COUNTRY
#                When "ES" : BCGCOD = "B2CES" : LAN = "SPA"
#                When "FR" : BCGCOD = "B2CFR" : LAN = "FRA"
#                When Default : BCGCOD = "B2CCE"
#              Endcase
#
#            Endif
            Call CAT_CLIENTE(COUNTRY,BCGCOD,LAN,ACCCOD,VACBPR)
#002>

            If CPERSON = "Y" : CPERSON = "2" : Else CPERSON ="1" : Endif

            DISCOUNT = ctrans(DISCOUNT,"-","")
            ORDERDATE = left$(ORDERDATE,4)+mid$(ORDERDATE,6,2)+mid$(ORDERDATE,9,2)
            #001>
            Call ZDIVCAD(ADDRESS,ZDIR1,ZDIR2)
            #001<
#002<
            Wrseq "B",BCGCOD,CLIENT,CNAME,"GEN","GEN",ACCCOD,VACBPR,COUNTRY,"EUR",LAN,CPERSON Using [FBPO]
#002>
            #001>
            #Wrseq "A","GEN","Genérica",ADDRESS,POSTCODE,CITY,SAT,COUNTRY,TEL,MAIL Using [FBPO]
            Wrseq "A","GEN","Genérica",ZDIR1,ZDIR2,POSTCODE,CITY,SAT,COUNTRY,TEL,MAIL Using [FBPO]
            #001<

            #Wrseq "D","GEN",CARRIER Using [FBPO]
            ####AMG.STR 07072021 modificacion para ańadir la razon social client entrega
            Wrseq "D","GEN",CARRIER,CNAME Using [FBPO]
            ###AMG.END

            Wrseq "E","100","ORD20","ORD20-"+ORDERNUM,CLIENT,ORDERDATE,DELDATE,CUPON,DELCOST,DISCOUNT,"900" Using [FSOO]

          Endif

          Wrseq "L",SKU,QTY,QTY,DELDATE,PRICE Using [FSOO]

          Rdseq LIN,SHOP,ORDERNUM,ORDERDATE,SKU,QTY,PRICE,CLIENTORDER,DELCOST,TAXES,DELDATE,VOID1,VOID2,VOID3,VOID4 Using [FIN]
          Rdseq UNDEFINED Using [FIN]

        Wend

        Call ECR_TRACE("Tratado el pedido "+ORDERNUM+" del cliente: "+CLIENT+" con lineas: "+num$(NUMLINES),0) From GESECRAN

        Openo Using [FBPO]
        Openo Using [FSOO]
        Openi Using [FIN]

        Call IMPORTSIL("ZBPCMGTO",FILNAME+"BP.pro") From GIMPOBJ
        Call IMPORTSIL("ZSOHMGTOC",FILNAME+"SO.pro") From GIMPOBJ

        ORDRE = "MOVE "+FILNAME+".txt "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"BP.pro "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"BP.pro.err "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"SO.pro "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"SO.pro.err "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

      Endif

    Next I

  Call ECR_TRACE("Fin del procesado de ficheros. Ficheros procesados: "+num$(I-1),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End

####################################################################
#001>
Subprog ZDIVCAD(P_CAD,ZDIR1,ZDIR2)
Value Char P_CAD
Variable Char ZDIR1,ZDIR2

Local Char CARACTER(1)
Local Integer ZPOS:ZPOS = 30

If len(P_CAD)>30 Then

  If mid$(P_CAD,31,1) <>" " Then  #Caso mas de 30 caracteres y posición 30 distinta de blanco

     CARACTER = mid$(P_CAD,30,1)

     #While CARACTER <> " "   #AMG.STR BUG cuando entraba en este bucle terminaba con ZPOS -1, fallaba funcion mid$ 12-07-2021
     While CARACTER <> " " and ZPOS > 0
       CARACTER = mid$(P_CAD, ZPOS, 1)
       ZPOS-=1
     Wend

     ZDIR1 = mid$(P_CAD,1,ZPOS)
     ZDIR2 = vireblc(mid$(P_CAD,ZPOS+1,len(P_CAD)),0)
  Else
      ZDIR1 = mid$(P_CAD,1,ZPOS)
      ZDIR2 = mid$(P_CAD,ZPOS+1,len(P_CAD))
  Endif
Else
     ZDIR1 = P_CAD
Endif
End
#001<

#002>
Subprog CAT_CLIENTE(ZCOUNTRY,CAT,ZLAN,ZACCCOD,ZVACBPR)
Value Char ZCOUNTRY
Variable Char CAT,ZLAN,ZACCCOD,ZVACBPR
Raz CAT,ZLAN
If !clalev([F:ZBCG]) Then : Local File BPCCATEG[ZBCG] : Endif
Read [F:ZBCG]BCG0 = "B2C"+ZCOUNTRY
If !fstat
  CAT = [F:ZBCG]BCGCOD
  ZLAN = [F:ZBCG]LAN
  ZACCCOD = [F:ZBCG]ACCCOD
  ZVACBPR = [F:ZBCG]VACBPR
Else
  CAT = "B2CEX"
  ZLAN = "BRI"
  ZACCCOD = "EXP"
  ZVACBPR = "EXP"
Endif

End
#002<
