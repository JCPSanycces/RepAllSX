#<AdxTL>@(#)0.0.0.0 $Revision$ 
#FPH Auren 19/06/2020 - 026/024 - Actualización descripciones artículos

$ACTION
Case ACTION
 When "EXEC" Gosub EXEC
 When Default
Endcase
Return
################################################
$EXEC
  If !clalev([F:ZTCT1]) : Local File TABCTL    [F:ZTCT1] : Endif
  If !clalev([F:ZITM1]) : Local File ITMMASTER [F:ZITM1] : Endif
  If !clalev([F:ZAXX1]) : Local File ATEXTRA   [F:ZAXX1] : Endif
  If !clalev([F:ZBOH1]) : Local File BOM       [F:ZBOH1] : Endif

  Local Integer I, YN : YN = 1

  Call OUINON("¿Desea actualizar las descripciones?",YN) From GESECRAN
  If YN = 2 Then
     Filter [F:ZITM1] Where ZARTGEN <> 2 and CFGFLDALP2 = PARAM(1)
     Read [F:ZITM1]ITM0 First
     For [F:ZITM1]ITM0
       Filter [F:ZTCT1]  Where TCT =  PARAM(1) and ALPCOD = [F:ZITM1]CFGFLDALP3
       Read [F:ZTCT1]TCT0 First
       If !fstat Then
         [F:ZITM1]ITMDES1   = [F:ZITM1]ITMDES2-[F:ZTCT1]DESCOD
         [F:ZITM1]ITMDES3   = [F:ZTCT1]DESCOD
         [F:ZITM1]UPDUSR    = GUSER
         [F:ZITM1]UPDDAT    = date$
         [F:ZITM1]UPDDATTIM = time$
         Rewrite [F:ZITM1]
       Endif
       #Descripción1
       Read [F:ZAXX1]AXX0 = "ITMMASTER";"DES1AXX";"SPA";[F:ZITM1]ITMREF;""
       [F:ZAXX1]TEXTE     =  [F:ZITM1]ITMDES2-[F:ZTCT1]DESCOD
       Rewrite [F:ZAXX1]
       #Descripción3
       Read [F:ZAXX1]AXX0 = "ITMMASTER";"DES3AXX";"SPA";[F:ZITM1]ITMREF;""
       [F:ZAXX1]TEXTE     = [F:ZTCT1]DESCOD
       [F:ZAXX1]UPDUSR    = GUSER
       [F:ZAXX1]UPDDAT    = date$
       [F:ZAXX1]UPDDATTIM = time$
       Rewrite [F:ZAXX1]
       Filter [F:ZITM1]
       Filter [F:ZTCT1]
       #Modificar descripción BOM
       Read [F:ZBOH1]BOH0 = [F:ZITM1]ITMREF;1;3
       If !fstat Then
         Read [F:ZAXX1]AXX0 = "BOM";"BOMDESAXX";"SPA";[F:ZITM1]ITMREF+"~"+num$([F:ZBOH1]BOMALT);num$([F:ZBOH1]BOMALTTYP)
         [F:ZAXX1]TEXTE     = [F:ZITM1]ITMDES1
         [F:ZAXX1]UPDUSR    = GUSER
         [F:ZAXX1]UPDDAT    = date$
         [F:ZAXX1]UPDDATTIM = time$
         Rewrite [F:ZAXX1]
       Endif
     Next
  Endif
Return

