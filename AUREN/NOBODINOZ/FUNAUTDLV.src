Variable Char    VALEUR()
GSOCIETE=VALEUR
Raz [M]STOFCY
End

# 75115 : V7 : Extension of Digital Signature : New field delivery type
######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# --> Chargement globales référenciels, comptes et sections de la société
If GFCY<>VALEUR : GFCY=VALEUR : Gosub CHARG_PARAM Endif

If [M]FLGSDHNOR=2 [M]SDHTYPNOR=GSDHTYPNOR Endif
If dim(GSDHTYPLND)>0 & [M]FLGSDHLND=2
  [M]SDHTYPLND=GSDHTYPLND
Endif
Affzo [M]7
End
# 75115 : V7 : Extension of Digital Signature : New field delivery type
######################################################################################
Subprog AM_FLGSDHNOR(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  Raz [M]SDHTYPNOR : Diszo [M]SDHTYPNOR
Else
  [M]SDHTYPNOR=GSDHTYPNOR : Actzo [M]SDHTYPNOR
Endif
Affzo [M]7
#Affzo [M]SDHTYPNOR : Affzo [M]ZSDHTYPNOR
End
# 75115 : V7 : Extension of Digital Signature : New field delivery type
######################################################################################
Subprog AM_FLGSDHLND(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  Raz [M]SDHTYPLND : Diszo [M]SDHTYPLND
Else
  If dim(GSDHTYPLND)>0 [M]SDHTYPLND=GSDHTYPLND Endif
  Actzo [M]SDHTYPLND
Endif
Affzo [M]SDHTYPLND : Affzo [M]ZSDHTYPLND
End
######################################################################################
# 75115


######################################################################################
#--------------------------------------------------------------------------#
# Chargement des paramčtres avec GFCY = Site de la livraison               #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramčtres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)

# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# --- Si changement société -----#
If GSOC_UPDFLG
    # --- Chargement indicateur Numérotation Argentine -----#
    If func AFNC.ACTIV("KAG")
        Call PARAML(GFCY,"ARGNUM",PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
        GLOCARGNUM=val(PARAM2)
        If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
    Else
        Raz GLOCARGNUM
    Endif
    # --- Utilisation systeme de taxe
    Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
#    If func AFNC.ACTIV("KUS")  # 106867.so
#        Call PARAM(GFCY,"USATAX",PARAM2) From ADOVAL
#        GLOCUSATAX=val(PARAM2)
#        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#    Else
#      Raz GLOCUSATAX
#    Endif  # 106867.eo

    # FGR 05/12/2011 : X3SUIVI71065
    GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)

    # 75115 : V7 : Extension of Digital Signature : New field delivery type
    # --> Recherche Types de livraison utilisateur
    Call PARAML(GFCY,"SDHTYPNOR",GSDHTYPNOR) From ADOVAL
    If dim(GSDHTYPLND)>0
      Call PARAML(GFCY,"SDHTYPLND",GSDHTYPLND) From ADOVAL
    Endif
    # 75115
Endif

Return
