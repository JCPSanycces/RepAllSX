#<AdxTL>@(#)0.0.0.0 $Revision$ 
#########################################################################
#                                                                       #
#     LIVRAISONS AUTOMATIQUES                                           #
#                                                                       #
#     - Traitement        : FUNAUTDLV                                   #
#     - Action e_commerce : TRTAUTDLV  (Traitement standard)            #
#                                                                       #
#########################################################################
# Issue X3-38515 - 20171025 by LD : Incorrect error messages in Order delivery function

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT_TRTAUTDLV
 When "INIT"        : Gosub INIT_TRTAUTDLV
 When "DEBUT"       : Gosub DEBUT_TRTAUTDLV         : # 75115
 When "BOUTON"      : Gosub BOUT_TRTAUTDLV          : # 75115
 When "OK"          : Gosub OK_TRTAUTDLV            : # 75115
 When "END"         : GOK=0 :FIN=1
 When "CONTROLE"    : Gosub CONTROLE_TRTAUTDLV
 When "EXEC"        : Gosub EXEC_TRTAUTDLV
 When "TERMINE"     : Gosub TERMINE_TRTAUTDLV
 When "SORTIE"      : Gosub SORTIE :# SR 09.11 Demande 75817
 When Default
Endcase
Return
#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTAUTDLV
Local Integer I

GORDCAT = 4

Local Char    STRNUM(GLONVCR), ENDNUM(GLONVCR)         : # BL début et fin

# SR 09.11 Demande 75817
Gosub POINT_SEQDLVSPL From TRTX3

#----- Ouverture des tables et déclaration des variables pour les états -----#
Gosub INIT_ETAT From TRTX3ETA
#-----

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SAD1 [DIA]

Raz [M:DIA]

[M]STOFCY=GFCYDEF(7)
# 75115 : V7 : Extension of Digital Signature : New field delivery type
# --> Chargement globales référenciels, comptes et sections de la société
Raz GSOC_ACTIVE : GFCY=GFCYDEF(7) : Gosub CHARG_PARAM
[M]FLGSDHNOR=2
[M]SDHTYPNOR=GSDHTYPNOR
#If func AFNC.ACTIV("LND")<>0 & dim(GSDHTYPLND)>0
If func AFNC.ACTIV("LND")<>0
    [M]FLGSDHLND=1
    #[M]SDHTYPLND=GSDHTYPLND
Endif
# 75115

[M]TYPPRO=1
[M]SHIDAT=date$
[M]DRNFLG=1
[M]DRN=0

Call LECMEMO ("STD","[M:DIA]","vl1") From GMEMO

# Positionner le flag si saisie des paramčtres depuis la gestion des abonnements
[M]ABT=1
If GFONCTION1="GESABA" [M]ABT=2 Endif

Return
#########################################################################
$DEBUT_TRTAUTDLV
# 75115 : V7 : Extension of Digital Signature : New field delivery type
# Si Code activité LND (Gestion des pręts) inactif, désactivation des champs FLGSDHLND et SDHTYPLND
If func AFNC.ACTIV("LND")=0
  Chgfmt [M:DIA]FLGSDHLND With "-LA1:4X"
  Chgfmt [M:DIA]SDHTYPLND With "-K:"+num$(GLONTSD)+"X"
  If dim([M:DIA]ZSDHTYPLND)>0
    Chgfmt [M:DIA]ZSDHTYPLND With "-K:"+num$(type([M:DIA]ZSDHTYPLND)-10)+"X"
    Raz [M:DIA]ZSDHTYPLND
  Endif
  Raz [M:DIA]FLGSDHLND, [M:DIA]SDHTYPLND
Else
  Diszo [M]SDHTYPLND
Endif
# 75115
Affzo [DIA]1-99
Return

#########################################################################
$OK_TRTAUTDLV
# 75115 : V7 : Extension of Digital Signature : New field delivery type
If [M]FLGSDHNOR<>2 & [M]FLGSDHLND<>2
    GERR=1 : GMESSAGE=mess(363,192,1) : FIN=0 : Return
Endif
# 75115
GOK=1
Return
#########################################################################
$BOUT_TRTAUTDLV
# 75115 : V7 : Extension of Digital Signature : New field delivery type
Case BOUT
    When "R"  : # Rappel Memo
                # --> Chargement globales référenciels, comptes et sections de la société
                If GFCY<>[M:DIA]STOFCY : GFCY=[M:DIA]STOFCY : Gosub CHARG_PARAM Endif
    When Default
Endcase
# 75115
Return
#########################################################################
$CONTROLE_TRTAUTDLV
If GOK < 1  FIN=1 Else TMP=1  Endif

If GACTION="AFRQTPAR"
    If [M:DIA]NPRFLG=2 & [M:DIA]NPRSRV=""
        GERR=1 : GMESSAGE="zzz" : SAI=1
    Endif
Endif

# Sup. fichier travail si interruption traitement antérieur dans la męme session
Gosub DEL_SWD
If GOK<1 FIN=1 Endif

Return

#########################################################################
$EXEC_TRTAUTDLV

Global Integer GLIVSPE

# --> Réalimentation GSOCIETE,GFINRSP,GLOCALDEV
#Call GETDEV([M]STOFCY) From DEVSUB
# Chargement globales référenciels, comptes et sections de la société
Raz GSOC_ACTIVE : GFCY=[M]STOFCY : Gosub CHARG_PARAM

# --- Localisation argentine : Pour la numérotation, recherche du type de document lié aux livraisons
If GLOCARGNUM Gosub REC_ARGNUM_TYPDOC From TRTVENLIV : If GERR=1 Return Endif : Endif

# --> Récupération de paramčtres vente nécessaires au recalcul de l'état crédit lors de la sélection des cdes
# Ces paramčtres st au niveau soc donc pas besoin de SALFCY
# On évite GLOBVAR qui est trop long, les autres paramčtres seront lus lors du trt de la cde
Local Char    PARAMETRE(10)
Global Libelle GOSTCTL   : # Niveau de contrôle d'en-cours
Call PARAML([M]STOFCY,"OSTCTL",PARAMETRE) From ADOVAL
GOSTCTL   = val(PARAMETRE)
Global Libelle GOSTDRAFT : # Mnt portefeuille dans en-cours
Call PARAML([M]STOFCY,"OSTDRAFT",PARAMETRE) From ADOVAL
GOSTDRAFT = val(PARAMETRE)
Global Libelle GOSTORD   : # Carnet cde dans total en-cours
Call PARAML([M]STOFCY,"OSTORD",PARAMETRE) From ADOVAL
GOSTORD   = val(PARAMETRE)
Global Libelle GOSTLND   : # Pręt dans total en-cours
Call PARAML([M]STOFCY,"OSTLND",PARAMETRE) From ADOVAL
GOSTLND   = val(PARAMETRE)

Global Char    GTRSLIV(30) : # Transaction livraison vente
Call PARAML([M]STOFCY,"TRSLIV",GTRSLIV) From ADOVAL
Global Char    GTRSLND(30) : # Transaction pręt vente
Call PARAML([M]STOFCY,"TRSLND",GTRSLND) From ADOVAL

Local Integer WGENKIT
Local Decimal WQTY, WQTYSTU, WSAUSTUCOE, WSOQQTY, WQTYARR
Local Decimal WQTYCPE, WQTYSTUCPE, WQTYCPS, WQTYSTUCPS, WCOECPE, WQTYDLVCPE
Local Decimal LQTYOK, LQTYKO
Local Integer LRET, LTRSTYP
Local Char    LTRSCOD(GLONADI), WSAU(GLONUOM)
Local Char SWPJTMSG(80)  # FGR 15/12/2011 : X3SUIVI71065

# Ouverture des masques de travail pour les stocks
If !clalev([M:ALP])  Local Mask ALLPAR     [ALP]   Endif
If !clalev([M:SOW])  Local Mask STOSORW    [SOW]   Endif

# Ouverture + reservations pour repartition elts facturation a la ligne
Gosub OUV_DSPLIN From TRTVENFACC

If !GSERVEUR
# Ouverture de la trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SAD1","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# Bornage de la date de prise en compte des commandes si la requęte est abonnée
# Si date expédition non renseignée, on force la date du jour
If [M:DIA]SHIDAT = [0/0/0] & [M:DIA]ABT=2 [M:DIA]SHIDAT = date$ : Endif

#-- Extraction commandes ou préparations
If [M:DIA]TYPPRO=1 Gosub SEL_COMMANDE Endif
#If [M:DIA]TYPPRO=2 Gosub SEL_PREPA Endif
If GOK<1 Goto EXEC_FIN Endif

# Point d'entrée aprčs constitution du fichier de travail
GPOINT="AUTDLVWRK" : Gosub ENTREE From EXEFNC

# Récupération de la transaction de livraison
Gosub RECH_TRSVEN
# Il n'y en a pas
If OK=1 Goto EXEC_FIN Endif

# Génération des livraisons ŕ partir du fichier de travail
Gosub TRTSWD

# --> fin de traitement
$EXEC_FIN
# --> déverrouillage de toutes les commandes
For [SWD]
    SYMBOLE = "SOH"+[F:SWD]SOHNUM
    Unlock = SYMBOLE
    # VPO 04/05/09 54858 lock cde ouverte
    SYMBOLE = "SOC"+num$([F:SWD]SOPLIN)+"\"+[F:SWD]SOHNUM
    Unlock = SYMBOLE
Next
Filter [SWD]

# --> suppression enreg. fichier travail
Gosub DEL_SWD

Return

#########################################################################
#########################################################################
$TERMINE_TRTAUTDLV

If NBLIV
  #----- Bon de préparation -----#
  If [M:DIA]NPRFLG=2 & [M:DIA]NPRNAM<>"" & [M:DIA]NPRDEN<>""
    Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]NPRDEN) From TRTX3ETA
  Endif
  #----- Bon de livraison -----#
  If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
    Call PRINT_ETAT (2,WARP_NUMREQ,[M:DIA]NDEDEN) From TRTX3ETA
  Endif
Endif

If !GSERVEUR
# --> fermeture trace
    If !NBCDE
      Call ECR_TRACE(mess(39,192,1),0) From GESECRAN
    Endif

    Call FERME_TRACE From LECFIC

# --> aucune commande ŕ traiter ou lecture trace
    If !NBCDE
       GERR=2 : GMESSAGE=mess(39,192,1)
    Endif
    TRA=1
Endif

# Si présence module Support Client et validation des livraisons, impression
If GMODU(12)=2 & [M:DIA]CFMFLG = 2
   Call PRINTFLYER(2,STRNUM,ENDNUM,LRET) From TRTMACRULE
   If LRET GERR=2 : GMESSAGE=mess(LRET,182,1) Endif
Endif

Return

# SR 09.11 Demande 75817
#########################################################################
$SORTIE
If dim(GSTEP3)>0          Kill GSTEP3  : Endif
#--CPO 88651 On va utiliser l'écran SFITRFA dont les dimensions sont paramčtrables
If func AFNC.ACTIV("SFIAT")>0
  # FGR 21/03/2014 : X3SUIVI94636 : dans ce cas il n'est pas local
  #If clalev([M:SFIT])>0 Close Local Mask [M:SFIT] Endif
  If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif
Endif
#--/
Return

#-----------------------------------------------------------------------#
# Ouvertures des tables                                                 #
#-----------------------------------------------------------------------#
$OUVRE
Local Integer  OK, STAT
Local Integer  NUMESPION
Local Char     CRITERE(250), CRITDET(250)
Local Char     TIT(50), SYMBOLE(50), SYMBOLE2(50)
Local Char     LCPT(3), LNUM
Local Integer  NBCDE, NBLIV, NBPOSTE
Local Integer  CDTSTA, LIN, I, WSDHACV, WSOHLIN, WSDHLIN, WLIN, LINFLG, WTRBEGIN
Local Decimal  WDLRNOT, WDLRATI, WMNT
Local Shortint WFLGLIV, WFLGLND, WDME
Local Char     WBPDNAM(GLONNAM), WSOHNUM
Local Char     WMESS(120)
Local Char     W81908MSGA(120)  # FGR 20/02/2014 : X3SUIVI81908
Local Char     W81908MSGB(120)  # FGR 20/02/2014 : X3SUIVI81908
Local Integer  WRUP, WCPE_SOQSTA
Local Integer  WRET

Raz NBCDE, WFLGLIV, WFLGLND

If clalev([F:SOH]) = 0 Local File SORDER      [SOH] : Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ] : Endif
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP] : Endif
If clalev([F:SOC]) = 0 Local File SORDERC     [SOC] : Endif
If clalev([F:SOQ1])= 0 Local File SORDERQ     [SOQ1]: Endif
If clalev([F:SOP1])= 0 Local File SORDERP     [SOP1]: Endif
If clalev([F:SDH]) = 0 Local File SDELIVERY   [SDH] : Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD  [SDD] : Endif
If clalev([F:SVF]) = 0 Local File SVCRFOOT    [SVF] : Endif
If clalev([F:SVV]) = 0 Local File SVCRVAT     [SVV] : Endif

If clalev([F:SWD]) = 0 Local File SWRKDLV     [SWD] : Endif
If clalev([F:SWD1])= 0 Local File SWRKDLV     [SWD1]: Endif
If clalev([F:SWD2])= 0 Local File SWRKDLV     [SWD2]: Endif
If clalev([F:SWD3])= 0 Local File SWRKDLV     [SWD3]: Endif

If clalev([F:MVC]) = 0 Local File BPCUSTMVT   [MVC] : Endif
If clalev([F:LCM]) = 0 Local File LASTCUSMVT  [LCM] : Endif

If clalev([F:REP]) = 0 Local File SALESREP    [REP] : Endif
If clalev([F:BPT]) = 0 Local File BPCARRIER   [BPT] : Endif

If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM] : Endif
If clalev([F:ITS]) = 0 Local File ITMSALES    [ITS] : Endif
If clalev([F:ITU]) = 0 Local File ITMBPC      [ITU] : Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF] : Endif

If clalev([F:TMD]) = 0 Local File TABMODELIV  [TMD] : Endif
If clalev([F:FCY]) = 0 Local File FACILITY    [FCY] : Endif
If clalev([F:SPK]) = 0 Local File SPRICLINK   [SPK] : Endif
If clalev([F:ACV]) = 0 Local File ACTIV       [ACV] : Endif

If clalev([F:CAL]) = 0 Local File CPTANALIN   [CAL] : Endif
If clalev([F:CAL1])= 0 Local File CPTANALIN   [CAL1] : Endif

If clalev([F:BPR]) = 0 Local File BPARTNER    [BPR] : Endif
If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [BPC] : Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST   [BPD] : Endif

If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

If clalev([F:GCM]) = 0 Local File GACM        [GCM] : Endif
#FQ 69370 GACTSAD conditionne uniquement le stockage de l'adresse sur le document
#If GACTSAD=2 If clalev([F:BPA])=0 Local File BPADDRESS [BPA] : Endif : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS   [BPA] : Endif
#fin FQ 69370

# 75115 : V7 : Extension of Digital Signature : New field delivery type
If clalev([F:TSD]) = 0 Local File TABSDHTYP   [TSD] : Endif

If clalev([F:CPY]) = 0 : Local File COMPANY   [CPY] : Endif   # 106867.n

# v6 affectations
Gosub OPEN_MTO From MTOLINKLIB

TIT = mess(22,191,1)  : # Livraisons automatiques

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

Local Integer  WCDTUNL
#------------------------------------------------------------#
# Chargement flag déblocage crédit autorisé                  #
#------------------------------------------------------------#
Local Char WPARAM(10)
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif

#If func AFNC.ACTIV("MUL") GPLISTC="néant" Endif
GPLISTC="néant"
# Contrôle existence de la structure tarif
Call CTLSTRUCT(1,STAT) From TRTPRICE
If STAT<>0 : Return : Endif
# Alimentation des variables nécessaires ŕ la recherche tarif
Call TARIFCHGT(5) From TRTPRICE
# Récupération de la structure des frais/remises
Call COLREM ("C",1,"") From TRTPRICE
# Récupération des types de frais/remises, des no éléments facturation
Call TYPREM(1,"") From TRTPRICE
Global Char     GPNTITMREF     : # Composé

#--CPO 88651 On va utiliser l'écran SFITRFA dont les dimensions sont paramčtrables
If func AFNC.ACTIV("SFIAT")>0
  # FGR 21/03/2014 : X3SUIVI94636 : dans ce cas il n'est pas local
  #If clalev([M:SFIT])>0 Close Local Mask [M:SFIT] Endif
  If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif
  Local Mask SFITRFA [M:SFIT]
Endif
#--/

Return

#-----------------------------------------------------------------------#
# Effacement fichier de travail si interruption                         #
#-----------------------------------------------------------------------#
$DEL_SWD

Call DEBTRANS From GLOCK
Trbegin [SWD]
GOK = 1
Delete [SWD] Where PRONUM=adxuid(1)
If fstat
   GOK= 0 : Call RSTA("SWD",num$(adxuid(1))) From GLOCK : Goto AB_STD
Endif
Commit
Return

#-----------------------------------------------------------------------#
# Sélection des commandes                                               #
#-----------------------------------------------------------------------#
$SEL_COMMANDE
Local Integer WCRITBPC, WCRITSOH
Local Integer WIS_SOH_SKIPPED_SET_UNLOCK # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
Raz WCRITBPC, WCRITSOH
# Critčres de saisie
CRITERE = "1=1"

# Bug 85620 : Suppression du filtre site expé sur l'entęte cde
# Pour les commandes ouvertes le site d'expédition n'est pas renseigné sur l'entęte
##-- 81908 FUNAUTDLV Pb de filtre site d'expédition --#
#If [M:DIA]STOFCY<> ""
#   CRITERE -= '& STOFCY ="'+[M:DIA]STOFCY+'"'
#Endif
# Bug 85620

# -------------------------------------
# FGR 20/02/2014 : X3SUIVI91908 (début)
If [M:DIA]CPY <> "" Then
  CRITERE -= '& CPY ="' + [M:DIA]CPY + '"'
  WCRITSOH=1
Endif
# FGR 20/02/2014 : X3SUIVI91908 (fin)
# -------------------------------------

If [M:DIA]SOHNUMDEB <> ""
   CRITERE -= '& SOHNUM >="'+[M:DIA]SOHNUMDEB+'"'
   WCRITSOH=1
Endif
If [M:DIA]SOHNUMFIN <> ""
   CRITERE -= '& SOHNUM <="'+[M:DIA]SOHNUMFIN+'"'
   WCRITSOH=1
Endif
If [M:DIA]BPCORDDEB <> ""
   CRITERE -= '& BPCORD >="'+[M:DIA]BPCORDDEB+'"'
   WCRITBPC=1
Endif
If [M:DIA]BPCORDFIN <> ""
   CRITERE -= '& BPCORD <="'+[M:DIA]BPCORDFIN+'"'
   WCRITBPC=1
Endif
# Critčres supplémentaires
CRITERE -= "& HLDSTA <2"                  :# order holds
CRITERE -= "& ORDSTA <> 2"                :# état cde     <> soldée
CRITERE -= "& DLVSTA <> 3"                :# état liv     <> livrée

# 75115 : V7 : Extension of Digital Signature : New field delivery type
#CRITERE -= "& SOHCAT <> 3"                :# cat  cde     <> fact directe
If [M:DIA]FLGSDHNOR=2 & [M:DIA]FLGSDHLND=2 :# cat  cde     <> fact directe
   CRITERE -= '& SOHCAT<>3'
Elsif [M:DIA]FLGSDHNOR=2                   :# cat  cde     = normale ou commande ouverte
   CRITERE -= '& (SOHCAT=1 | SOHCAT=4)'
Else                                       :# cat  cde     = pręt
   CRITERE -= '& SOHCAT=2 '
Endif
# 75115

#CRITERE -= "& ALLSTA <> 1"                :# état alloc   <> non allouée
CRITERE -= "& APPFLG > 2"                 :# état signature cde : signée

# X3-119756 : Management of draft sales orders / X3-81821 : Hide draft SO - Exclusion from the transformation document mass processes (LD 12/21/18)
# Draft sales orders have to be excluded
CRITERE -= '& DRAFTSTATUS=0'
# X3-119756 : Management of draft sales orders / X3-81821 : Hide draft SO - Exclusion from the transformation document mass processes (LD 12/21/18)

#---------------------------------------------------------------------#
# Point d'entree ajout filtres supplémentaires                        #
#---------------------------------------------------------------------#
Local Char    FILSUPENT(250), FILSUPDET(250)
Local Integer WSWDKEYD                                                : # bug 22378
FILSUPENT="1=1"
FILSUPDET="1=1"

Raz GLIVSPE
GPOINT="AUTDLVFIL" : Gosub ENTREE From EXEFNC

# ACA - On ajoute dans le tableau [L]GRUNOM les numeros des élements
# dont la regle de regroupement est ŕ "Non si différent", pour ce document
Gosub OPEN_SFI From TRTX3CPY

Local Integer RCNTDFI : RCNTDFI= nbrecord([F:SFI])
#FQ 66266 - pour éviter le cas ou la SFOOTINV n'a pas d'enregistrements (et j'ai prévu plus large)
If RCNTDFI<=5 : RCNTDFI = 10 : Endif
Local Integer GRUNON([L]RCNTDFI), I1, I2, PDESVCR
# Issue X3-218911 - 20201021 by LD
Local Libelle BRDRUL([L]RCNTDFI)
# End issue X3-218911 - 20201021 by LD
PDESVCR=2
I2=0
Read [SFI]First
While fstat=0
    I1=find([L]PDESVCR, [F:SFI]DESVCR(0..dim([F:SFI]DESVCR)-1))
    If I1>0 & [F:SFI]GRUFLG(I1-1) = 2
        [L]GRUNON(I2)=[F:SFI]SFINUM
        # Issue X3-218911 - 20201021 by LD
        # Split rule
        [L]BRDRUL(I2)=[F:SFI]BRDRUL(I1-1)
        # End issue X3-218911 - 20201021 by LD
        I2+=1
    Endif
    #--CPO 91785 Eviter le cas oů il y a un autre F par défaut...
    #Read Next
    Read [F:SFI] Next
    #--/
Wend

If WCRITBPC=1 | WCRITSOH=0
    For [SOH]SOH3 Where (evalue(CRITERE) & evalue (FILSUPENT))
       # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
       # Reason explained for the following code changing :
       # In SEL_ENTCOMPL there is a call to SDCDTSTA from TRTVENCDT (in wich it is done a Readlock/Rewrite of SOH)
       # As the Readlock/Rewrite updates the updtick, we should test the Lock SYMBOLE before call the SEL_ENTCOMPL
       # /Reason explained
       WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_ANO
       #--Lock order header
       OK=2
       # Lock fichier entęte commande
       SYMBOLE = "SOH"+[F:SOH]SOHNUM
       Lock = SYMBOLE
       If fstat
         # modification en cours sur un autre poste
         Call ECR_TRACE("$SORDER"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
         OK=1
       Endif
       # Issue X3-135097 - 2019-05-27 by ANKUL
       Gosub VERIF_ESIGN
       # Issue X3-135097 - 2019-05-27 by ANKUL : end
       If OK=2
       # End issue 113387
         Gosub SEL_ENTCOMPL
         # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
         If OK=1 : WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_AYES : Endif
         # End issue 113387

         # Issue X3-38515
         # Le contrôle d'en-cours ne doit ętre fait et affiché que si la cde a des lignes entrant ds la sélection des lignes ŕ livrer
         # Credit control has to be done and displayed only if the order has lines to deliver according to the criteria
         #Gosub ECR_TRACE_BPC_BLOQUE # FGR 01/10/2014 : X3SUIVI102899 : On ne passe pas dans $CHARGEFIC dans ce cas lŕ
         # End issue X3-38515

         # Sélection sur détail et écriture dans SWRKDLV
         If OK = 2 : Gosub SEL_DETAIL : Endif

       # Issue 11338 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
       # Now, if an error is raised while selecting order lines, the header has to be unlocked
         If WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_AYES
           SYMBOLE = "SOH"+[F:SOH]SOHNUM
           Unlock = SYMBOLE
         Endif
       Endif
       # End issue 113387
    Next
Else
    For [SOH]SOH4 Where (evalue(CRITERE) & evalue (FILSUPENT))
       # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
       # Reason explained for the following code changing :
       # In SEL_ENTCOMPL there is a call to SDCDTSTA from TRTVENCDT (in wich it is done a Readlock/Rewrite of SOH)
       # As the Readlock/Rewrite updates the updtick, we should test the Lock SYMBOLE before call the SEL_ENTCOMPL
       # /Reason explained
       WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_ANO
       #--Lock order header
       OK=2
       # Lock fichier entęte commande
       SYMBOLE = "SOH"+[F:SOH]SOHNUM
       Lock = SYMBOLE
       If fstat
         # modification en cours sur un autre poste
         Call ECR_TRACE("$SORDER"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
         OK=1
       Endif
       If OK=2
       # Issue X3-135097 - 2019-05-27 by ANKUL
       Gosub VERIF_ESIGN
       # Issue X3-135097 - 2019-05-27 by ANKUL : end
       # End issue 113387
         Gosub SEL_ENTCOMPL
         # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
         If OK=1 : WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_AYES : Endif
         # End issue 113387

         # Issue X3-38515
         # Le contrôle d'en-cours ne doit ętre fait et affiché que si la cde a des lignes entrant ds la sélection des lignes ŕ livrer
         # Credit control has to be done and displayed only if the order has lines to deliver according to the criteria
         #Gosub ECR_TRACE_BPC_BLOQUE # FGR 01/10/2014 : X3SUIVI102899 : On ne passe pas dans $CHARGEFIC dans ce cas lŕ
         # End issue X3-38515

         # Sélection sur détail et écriture dans SWRKDLV
         If OK = 2 : Gosub SEL_DETAIL : Endif
       # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
       # Now, if an error is raised while selecting order lines, the header has to be unlocked
         If WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_AYES
           SYMBOLE = "SOH"+[F:SOH]SOHNUM
           Unlock = SYMBOLE
         Endif
       Endif
       # End issue 113387
    Next
Endif
# Issue X3-218911
GPE=1
# End Issue X3-218911
Return

#-----------------------------------------------------------------------#
# Sélection des lignes de commande                                      #
#-----------------------------------------------------------------------#
$SEL_DETAIL
Local Integer WEXIST_SELECTED_ORDER_LINE # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order

# Issue X3-38515
Local Integer WCHKCDTSTA
# End issue X3-38515

# Critčres de saisie
CRITDET = "1=1"
If [M:DIA]STOFCY<> ""
   CRITDET -= '& STOFCY ="'+[M:DIA]STOFCY+'"'
Endif
If [M:DIA]SHIDAT <> [0/0/0]
   CRITDET -= "& SHIDAT<=[" +format$(GFMD,[M:DIA]SHIDAT)+ "]"
Endif
If [M:DIA]DRNFLG = 2
   CRITDET -= "& DRN=" +num$([M:DIA]DRN)
Endif
If [M:DIA]BPTNUMDEB <> ""
   CRITDET -= '& BPTNUM>="'+[M:DIA]BPTNUMDEB+'"'
Endif
If [M:DIA]BPTNUMFIN <> ""
   CRITDET -= '& BPTNUM<="'+[M:DIA]BPTNUMFIN+'"'
Endif
# Critčres supplémentaires
CRITDET -= '& SOHNUM="'+[F:SOH]SOHNUM+'"'              :# no cde
CRITDET -= "& SOQSTA<>3"                               :# ligne non soldée
CRITDET -= "& DEMSTA=1"                                :# status ordre ferme
#--- Issue 112531 by TS
CRITDET -= '& DLVFLG=2'
#---

CRITDET -= "& LPRQTYSTU=0 & OPRQTYSTU=0 & PREQTYSTU=0" :# ligne non préparée

# Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
#--this flag tell us if at least one order line is compatible and taken into account in SWD
WEXIST_SELECTED_ORDER_LINE = [V]CST_ANO
# End issue 113387

# Issue X3-38515
WCHKCDTSTA=[V]CST_ANO
CDTSTA=0
# End issue X3-38515

For [SOQ]SOQ0 Hint Key SOQ0 Where (evalue(CRITDET) & evalue (FILSUPDET))
   # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
   # Reason explained for the following code changing :
   # In SET_DETCOMPL there is a call to SDCDTSTA from TRTVENCDT (in wich it is done a Readlock/Rewrite of SOH)
   # As the Readlock/Rewrite updates the updtick, we should test the Lock SYMBOLE before call the SEL_DETCOMPL
   # /Reason explained
   # End issue 113387
   Gosub SEL_DETCOMPL

   If OK = 2
      # VPO 04/05/09 54858 lock cde ouverte
      If [F:SOH]SOHCAT<>4
          # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
          #--Done in SEL_COMMANDE
          ## Lock fichier entęte commande
          #SYMBOLE = "SOH"+[F:SOH]SOHNUM
          #Lock = SYMBOLE
          #If fstat
          #   # modification en cours sur un autre poste
          #   Call ECR_TRACE("$SORDER"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
          #   OK=1
          #Endif
          # End issue 113387
      Else
          # Lock fichier commande ouverte
          SYMBOLE = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOQ]SOHNUM
          Lock = SYMBOLE
          If fstat
             # modification en cours sur un autre poste
             Call ECR_TRACE("$SORDERC"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(10,100,1),1) From GESECRAN
             OK=1
          Endif
      Endif
      #VPO 03/07/09 52087
      #Erreur le lock sur l'entęte donc
      # --> il faut virer du fichier de travail les autres lignes de cette cde
      If OK=1
          Gosub VIRE_CDE
          # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
          #--as all lines concerning the present order are deleted from SWD, the flag has to be reset
          WEXIST_SELECTED_ORDER_LINE = [V]CST_ANO
          # End issue 113387
          Break
      Endif

   #--- TS le 04.01.05 --- Bug 27518
   # Ligne non livrable et livraison de commande entičre
   # --> il faut virer du fichier de travail les autres lignes de cette cde
   Elsif [F:SOH]DME=3
      Gosub VIRE_CDE
      # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
      #--as all lines concerning the present order are deleted from SWD, the flag has to be reset
      WEXIST_SELECTED_ORDER_LINE = [V]CST_ANO
      # End issue 113387
      Break
   #--------------------------------
   Endif

   Gosub ECR_TRACE_BPC_BLOQUE # FGR 01/10/2014 : X3SUIVI102899 : On ne passe pas dans $CHARGEFIC dans ce cas lŕ

   If OK=2
     Gosub CHARGEFIC
     # Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
     # As the line has been taken into account in SWD, the flag can be set to AYES
     If GOK>0
       WEXIST_SELECTED_ORDER_LINE = [V]CST_AYES
     Endif
     # End issue 113387
   Endif
Next
Call PJT_WRITE_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065

# Issue 113387 - 2016-01-29 by CPO : Sales orders : obsolete record when changing a sales order
If WEXIST_SELECTED_ORDER_LINE <> [V]CST_AYES
  WIS_SOH_SKIPPED_SET_UNLOCK = [V]CST_AYES
Endif
# End issue 113387

Return

$ECR_TRACE_BPC_BLOQUE
  # FGR 01/10/2014 : X3SUIVI102899 (début) : On ne passe pas dans $CHARGEFIC dans ce cas lŕ
  If W81908MSGA <> "" Then
    Call ECR_TRACE(W81908MSGA,0) From GESECRAN
    Call ECR_TRACE("         "+W81908MSGB,1) From GESECRAN
    # Issue X3-38515
    Raz W81908MSGA
    Raz W81908MSGB
    # End issue X3-38515
  Endif
  # FGR 01/10/2014 : X3SUIVI102899 (fin)
Return

$VIRE_CDE
      Trbegin [SWD]
      For [SWD]SWD1 Where PRONUM=adxuid(1) & SOHNUM=[F:SOH]SOHNUM
         Delete [SWD]
      Next
      Commit
      # VPO 04/05/09 54858 lock cde ouverte
      If [F:SOH]SOHCAT<>4
          #VPO 27/04/09 54733 pb si 2 sessions
          #SYMBOLE = "SOH" + [F:SWD]SOHNUM
          SYMBOLE = "SOH" + [F:SOH]SOHNUM
          Unlock = SYMBOLE
      Else
          SYMBOLE = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOQ]SOHNUM
          Unlock = SYMBOLE
      Endif
Return
#-----------------------------------------------------------------------#
# Sélections complémentaires pour commandes                             #
#-----------------------------------------------------------------------#
$SEL_ENTCOMPL
  OK = 2
  Raz W81908MSGA  # FGR 20/02/2014 : X3SUIVI81908
  Raz W81908MSGB  # FGR 20/02/2014 : X3SUIVI81908

Local Char    PARAMETRE(10)
Global Libelle GLINBPD
Call PARAML([F:SOH]SALFCY,"LINBPD",PARAMETRE) From ADOVAL
GLINBPD = val(PARAMETRE)
Global Libelle GLOKORD
Call PARAML([F:SOH]SALFCY,"LOKORD",PARAMETRE) From ADOVAL
GLOKORD = val(PARAMETRE)

If [F:SOH]BPDNAM(0) <> ""
    WBPDNAM=[F:SOH]BPDNAM(0)
Else
    If [F:BPD]BPCNUM<>[F:SOH]BPCORD | [F:BPD]BPAADD<>[F:SOH]BPAADD
        Read [BPD]BPD0 = [F:SOH]BPCORD; [F:SOH]BPAADD
        If fstat Raz [F:BPD] : Endif
    Endif
    WBPDNAM=[F:BPD]BPDNAM
Endif

# Sélection sur client livré si non géré ŕ la ligne
If [M:DIA]BPAADDDEB <> "" & GLINBPD = 1 & [F:SOH]SOHCAT <> 4 & [F:SOH]BPCORD = [M:DIA]BPCORDDEB
   If [F:SOH]BPAADD < [M:DIA]BPAADDDEB : OK = 1 : Return : Endif
Endif
If [M:DIA]BPAADDFIN <> "" & GLINBPD = 1 & [F:SOH]SOHCAT <> 4 & [F:SOH]BPCORD = [M:DIA]BPCORDFIN
   If [F:SOH]BPAADD > [M:DIA]BPAADDFIN : OK = 1 : Return : Endif
Endif

# Pour forcer la livraison des commandes non allouées ou en rupture
# GLIVSPE est ŕ positionner ŕ 1 ou 2 dans le point d'entrée AUTDLVFIL
If dim(GLIVSPE)>0 & find(GLIVSPE,1,2)
   Goto SEL_ENTCOMPL_SUI
Endif

# Sélection cde totalement allouée si pas de liv partielle autorisée
# --> Si livraison commande complčte, la cde doit ętre totalement allouée
If [F:SOH]DME=3 & [F:SOH]ALLSTA <> 3 & [F:SOH]ALLLINNBR <> 0 : OK=1 : Return : Endif
# Sélection cde non allouée si au moins 1 article n'est pas gérés en stock
If [F:SOH]ALLSTA = 1 & [F:SOH]ALLLINNBR = [F:SOH]LINNBR : OK=1 : Return : Endif

$SEL_ENTCOMPL_SUI

# Issue X3-38515
# Le contrôle d'en-cours ne doit ętre fait et affiché que si la cde a des lignes entrant ds la sélection des lignes ŕ livrer
# Credit control has to be done and displayed only if the order has lines to deliver according to the criteria
#If [F:SOH]SOHCAT=4 Return Endif : # Bug 67648
#Gosub CTL_CDTSTA                : # Bug 67648
# End issue X3-38515

Return


# Bug 67648
#-----------------------------------------------------------------------#
# Contrôle état crédit commande courante                                #
#-----------------------------------------------------------------------#
$CTL_CDTSTA
  # Contrôle état crédit commande courante

  # Issue X3-38515
  # Le recherche de l'état crédit ne doit se faire que sur la 1čre ligne
  #Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,"",[F:SOH]ORDDAT,[F:SOH]UNL, 2, CDTSTA,WMNT,WMNT) From TRTVENCDT
  If WCHKCDTSTA=[V]CST_ANO | CDTSTA=0
      Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,"",[F:SOH]ORDDAT,[F:SOH]UNL, 2, CDTSTA,WMNT,WMNT) From TRTVENCDT
      WCHKCDTSTA=[V]CST_AYES
  Else
      If CDTSTA=3 & WCDTUNL = 2 Return Endif
      If CDTSTA <> 1
        OK=1
        Return
      Endif
  Endif
  # End issue X3-38515

  # Acompte non versé, mais pas de blocage
  If CDTSTA=4 & GLOKORD<>2 CDTSTA=1 Endif
  # Si dépassement en-cours mais pas de blocage on continue
  If CDTSTA=3 & WCDTUNL = 2 Return Endif
  If CDTSTA <> 1
    OK=1
    WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(99,197,1)-":"-[F:SOH]BPCORD-WBPDNAM
    # FGR 20/02/2014 : X3SUIVI81908 (début) : déplacé parce que lŕ on n'est pas encore sur de prendre la commande
    #Call ECR_TRACE(WMESS,0) From GESECRAN
    W81908MSGA = WMESS
    # FGR 20/02/2014 : X3SUIVI81908 (fin)
    Raz WMESS
    If CDTSTA = 2 Then
      WMESS = mess(100,197,1)
    Elsif CDTSTA = 3 Then
      # FGR 10/03/2015 : X3SUIVI23273 (début)
      #WMESS = mess(101,197,1)
      If !([F:SOH]BETFCY = 2 & [F:SOH]BETCPY <> 2) or GCTLBETFCY = 2 Then
        WMESS = mess(101,197,1)
      Endif
      # FGR 10/03/2015 : X3SUIVI23273 (fin)
    Elsif CDTSTA = 5 Then
      WMESS = mess(5,2092,1)
    Elsif GLOKORD = 2 Then
      WMESS = mess(102,197,1)
    Endif
    # FGR 20/02/2014 : X3SUIVI81908 (début) : déplacé parce que lŕ on n'est pas encore sur de prendre la commande
    #If WMESS <> "" Call ECR_TRACE("         "+WMESS,1) From GESECRAN Endif
    If WMESS <> "" Then
      W81908MSGB = WMESS
    Endif
    # FGR 20/02/2014 : X3SUIVI81908 (fin)
    Return
  Endif
Return
# Bug 67648

#-----------------------------------------------------------------------#
# Sélection complémentaires pour lignes de commandes                    #
#-----------------------------------------------------------------------#
$SEL_DETCOMPL
OK = 2
Raz WQTY, WQTYSTU
# Client livré
If [M:DIA]BPAADDDEB <> "" & [F:SOQ]BPCORD = [M:DIA]BPCORDDEB
   If [F:SOQ]BPAADD < [M:DIA]BPAADDDEB : OK = 1 : Return :  Endif
Endif
If [M:DIA]BPAADDFIN <> "" & [F:SOQ]BPCORD = [M:DIA]BPCORDFIN
   If [F:SOQ]BPAADD > [M:DIA]BPAADDFIN : OK = 1 : Return :  Endif
Endif

# FGR 01/12/2011 : X3SUIVI71065 (début)
If func TRTPJT.IS_PJT_AVAILABLE([F:SOQ]PJT, "[M:SDH1]DPJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SOQ]PJT, SWPJTMSG) From TRTPJT
  Raz GMESSAGE
  OK = 1
  Return
Endif
# FGR 01/12/2011 : X3SUIVI71065 (fin)

# Lecture détail cde prix ou ligne cde ouverte
Raz [F:SOP], [F:SOC]
If [F:SOH]SOHCAT <> 4
   Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
   If fstat : OK=1 : Return : Endif
   WSAUSTUCOE = [F:SOP]SAUSTUCOE
   WSAU       = [F:SOP]SAU
Else
   Read [SOC]SOC0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN
   If fstat : OK=1 : Return : Endif
   WSAUSTUCOE = [F:SOC]SAUSTUCOE
   WSAU       = [F:SOC]SAU
Endif
If WSAUSTUCOE=0 WSAUSTUCOE=1 Endif

# Lecture article maitre
Read [ITM]ITM0 = [F:SOQ]ITMREF
If fstat : OK=1 : Return : Endif

# Si ligne gérée en contremarque, la commande d'achat doit avoir été générée
If [F:SOH]SOHCAT <> 4 & [F:SOQ]FMI > 1  & [F:SOQ]FMI < 4 & [F:SOQ]FMINUM = ""
   OK=1 : Return
Endif

# Si ligne gérée avec un ordre de production, l'OF doit avoir été généré
If [F:SOH]SOHCAT <> 4 & [F:SOQ]FMI = 5 & [F:SOQ]FMINUM = ""
   OK=1 : Return
Endif

# Si ligne de contrat de service
If [F:SOH]SOHCAT <> 4 & [F:SOP]CONNUM <> ""
   OK=1 : Return
Endif

# Issue X3-38515
# La cde a des lignes entrant ds la sélection des lignes ŕ livrer, donc on peut faire le contrôle d'en-cours
# The order has lines to deliver according to the criteria, so we can do the credit control
## Bug 67648
#If [F:SOH]SOHCAT = 4
#   Gosub CTL_CDTSTA
#   If OK=1 Return Endif
#Endif
## Bug 67648
Gosub CTL_CDTSTA
If OK=1 Return Endif
# End issue X3-38515

# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début) : seulement pour les factures
  If func AFNC.ACTIV("ECC") Then
    Call CTLECCVAL([F:SOQ]ECCVALMAJ, [F:SOQ]STOFCY, [F:SOQ]ITMREF, 4, "", [M:DIA]SHIDAT, LRET) From STKSOR
    If LRET >= 1 Then
      Call ECR_TRACE(mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1,0) From GESECRAN
      Call ECR_TRACE(GMESSAGE - "(" + [F:SOQ]ECCVALMAJ + ")",0) From GESECRAN
      Raz GMESSAGE
      OK = 1
      Return
    Endif
    #
    SVMESSAGE = GMESSAGE
    Call STKCTRECC([F:SOQ]ITMREF, [F:SOQ]ECCVALMAJ, [F:SOQ]ECCVALMIN, "", 4) From STKACT
    If mkstat Then
      Call ECR_TRACE(mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1,0) From GESECRAN
      Call ECR_TRACE(GMESSAGE - "(" + [F:SOQ]ECCVALMIN + ")",0) From GESECRAN
      Raz GMESSAGE
      OK = 1
      Return
    Endif
  Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------

# Pour rajouter des filtres sur les enregistrements ŕ traiter
GPOINT="AUTDLVSEL" : Gosub ENTREE From EXEFNC

# Pour forcer la livraison des commandes non allouées
# GLIVSPE est ŕ positionner ŕ 1 dans le point d'entrée AUTDLVFIL
If GLIVSPE=1
   WQTY    = [F:SOQ]QTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY-[F:SOQ]LPRQTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY
   WQTYSTU = [F:SOQ]QTYSTU-[F:SOQ]ODLQTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
   Return
Endif

# Pour forcer la livraison des ruptures
# GLIVSPE est ŕ positionner ŕ 2 dans le point d'entrée AUTDLVFIL
If GLIVSPE=2
   If [F:SOQ]STOMGTCOD>1
      WQTY    = [F:SOQ]ALLQTY+[F:SOQ]SHTQTY
      WQTYSTU = [F:SOQ]ALLQTYSTU+[F:SOQ]SHTQTYSTU
   Elsif [F:SOQ]TDLQTY<>0
      WQTY    = [F:SOQ]TDLQTY
      WQTYSTU = [F:SOQ]TDLQTYSTU
   Else
      WQTY    = [F:SOQ]QTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY-[F:SOQ]LPRQTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY
      WQTYSTU = [F:SOQ]QTYSTU-[F:SOQ]ODLQTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
   Endif
   Return
Endif

#---------------------------------------
# Détermination de la quantité livrable
#---------------------------------------
If [F:SOH]SOHCAT=2
   LTRSTYP=17
   LTRSCOD=[M:DIA]TRSCODLND
Else
   LTRSTYP=4
   LTRSCOD=[M:DIA]TRSCODLIV
Endif
# Si ligne de commande normale ou de nomenclature
If [F:SOH]SOHCAT=4 | !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
   # Article géré en stock et allocation détaillée
   If [F:SOQ]STOMGTCOD<>1
      # Pas de quantité allouée, rien ŕ livrer
      If [F:SOQ]ALLQTY<=0
         OK=1 : Return
      Endif
      # Si allocation détaillée
      If [F:SOQ]ALLTYP=2
         If WRUP=1
            WQTY    = [F:SOQ]ALLQTY
            WQTYSTU = [F:SOQ]ALLQTYSTU
         Else
            # Détermination de la qté livrable ŕ partir de la qté allouée cde
            Call CTLALL([F:SOQ]STOFCY,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,
&                       LTRSTYP,LTRSCOD,[F:SOQ]STA,1,LQTYOK,LQTYKO,LRET) From STKALL
            # Erreur ou pas de quantité allouée sortable
            If LRET<>0 | LQTYOK=0
               GMESSAGE=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(14,195,1)-":"-[F:SOQ]ITMREF-"   "-mess(156,191,1)
               Call ECR_TRACE(GMESSAGE,1) From GESECRAN
               Raz GMESSAGE
               OK=1 : Return
            Else
               WQTYSTU = LQTYOK
               WQTY    = WQTYSTU/WSAUSTUCOE
            Endif
         Endif
      # Sinon si allocation globale
      Else
         WQTY    = [F:SOQ]ALLQTY
         WQTYSTU = [F:SOQ]ALLQTYSTU
      Endif
      # Test livraison ligne complčte
      If [F:SOH]DME=2 & WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY+[F:SOQ]LPRQTY+[F:SOQ]OPRQTY+[F:SOQ]PREQTY < [F:SOQ]QTY
         Raz WQTY, WQTYSTU
         OK=1 : Return
      Endif
   Elsif [F:SOQ]TDLQTY<>0
      WQTY    = [F:SOQ]TDLQTY
      WQTYSTU = [F:SOQ]TDLQTYSTU
   Else
      WQTY    = [F:SOQ]QTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY-[F:SOQ]LPRQTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY
      WQTYSTU = [F:SOQ]QTYSTU-[F:SOQ]ODLQTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
   Endif

   #---------------------------------------------
   # TS : réajustement qté en unité vente entičre
   #---------------------------------------------
   If WSAU<>[F:ITM]STU
      Call CTRQTYPCU(WSAU,WSAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
      If WQTYARR<>WQTYSTU
         WQTYSTU = WQTYARR
         WQTY    = WQTYSTU/WSAUSTUCOE
      Endif
   Endif
   #---------------------------------------------

# Si ligne de kit (composé ou composant)
Else
   # Composé de kit/sous-traité
   If find([F:SOP]LINTYP,2,10)
      WGENKIT=1
      # Composé géré en stock
      If [F:SOQ]STOMGTCOD<>1
         # Si allocation détaillée
         If [F:SOQ]ALLTYP=2
            # Détermination de la qté livrable ŕ partir de la qté allouée cde
            Call CTLALL([F:SOQ]STOFCY,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,
&                       LTRSTYP,LTRSCOD,[F:SOQ]STA,1,LQTYOK,LQTYKO,LRET) From STKALL
            # Erreur ou pas de quantité allouée sortable
            If LRET<>0 | LQTYOK=0
               GMESSAGE=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(14,195,1)-":"-[F:SOQ]ITMREF-"   "-mess(156,191,1)
               Call ECR_TRACE(GMESSAGE,1) From GESECRAN
               Raz GMESSAGE
               Raz WQTY, WQTYSTU
            Else
               WQTYSTU = LQTYOK
               WQTY    = WQTYSTU/WSAUSTUCOE
            Endif
         # Sinon si allocation globale
         Else
            Gosub ALI_GENALP
            Raz LRET
            # Appel algorithme en simulation pour déterminer la qté livrable
            Call GENSTOSORW("",1,0,0,"",LRET) From STKSOR
            # Si erreur ou pas de qté allouée sortable
            If LRET<>0 | [M:ALP]ALLQTY=0
               Raz WQTY, WQTYSTU
            Else
               WQTYSTU = [M:ALP]ALLQTY
               WQTY    = WQTYSTU/WSAUSTUCOE
            Endif
         Endif
      Else
         WQTY    = [F:SOQ]ALLQTY
         WQTYSTU = [F:SOQ]ALLQTYSTU
      Endif

      #--- Bug 71007
      # Si livraison ligne complčte et qte livrable < qté restant ŕ livrer
      If [F:SOH]DME=2 & WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY+[F:SOQ]LPRQTY+[F:SOQ]OPRQTY+[F:SOQ]PREQTY < [F:SOQ]QTY
         Raz WQTY, WQTYSTU
      Endif
      #---

      # Rien ŕ livrer au niveau composé --> on arręte
      If WQTYSTU<=0
         Raz WGENKIT : OK=1
      # Boucle sur les composants pour savoir si le kit/sous-traité est livrable
      Else
         WQTYCPE    = WQTY
         WQTYSTUCPE = WQTYSTU
         WQTYDLVCPE = WQTYCPE+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
         For [SOP1]SOP0 Where SOHNUM=[F:SOP]SOHNUM & SOPLIN>[F:SOP]SOPLIN
            If find([F:SOP1]LINTYP,3,4,5,11,12,13)
               Read [SOQ1]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
               If !fstat
                  # Si composant géré en stock et pas de qté allouée
                  # Le kit n'est pas livrable
                  If [F:SOQ1]STOMGTCOD<>1
                     If [F:SOQ1]ALLQTY<=0
                        Raz WGENKIT : OK=1 : Break
                     # Calcul de la nouvelle qté composé livrable
                     # Si allocation détaillée
                     Elsif [F:SOQ]ALLTYP=2
                        # Calcul de la qté ŕ traiter du composant en UV et en US
                        WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
                        # Cas d'une livraison d'une nomenclature de sous-traitance avec un service forfaitaire
                        # Si livraison partielle, le service forfaitaire est également livré partiellement
                        # Sur la derničre livraison, il faut vérifier que le service est complčtement livré (pb d'arrondi)
                        If [F:SOP1]LINTYP=13 & WQTYDLVCPE=WQTYCPE
                           If  WQTYCPS+[F:SOQ1]ODLQTY+[F:SOQ1]DLVQTY<>[F:SOQ1]QTY
                               WQTYCPS=[F:SOQ1]QTY-[F:SOQ1]ODLQTY-[F:SOQ1]DLVQTY
                           Endif
                        Endif
                        WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
                        Call QTEARR (WQTYSTUCPS,[F:SOP1]STU) From TRTDIV
                        # Lecture article composant
                        Read [ITM]ITM0 = [F:SOQ1]ITMREF
                        If fstat : Raz WGENKIT : OK=1 : Break : Endif
                        # Détermination de la qté livrable ŕ partir de la qté allouée cde
                        Call CTLALL([F:SOQ1]STOFCY,2,[F:SOQ1]SOHNUM,[F:SOQ1]SOPLIN,[F:SOQ1]SOQSEQ,
&                                   LTRSTYP,LTRSCOD,[F:SOQ1]STA,1,LQTYOK,LQTYKO,LRET) From STKALL
                        # Erreur ou pas de quantité allouée sortable
                        If LRET<>0 | LQTYOK=0
                           GMESSAGE=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(14,195,1)-":"-[F:SOQ]ITMREF-"   "-mess(156,191,1)
                           Call ECR_TRACE(GMESSAGE,1) From GESECRAN
                           Raz GMESSAGE, WGENKIT
                           OK=1 : Break
                        Else
                           WQTYSTU = LQTYOK
                           WQTY    = WQTYSTU/[F:SOP1]SAUSTUCOE
                        Endif
                     # Sinon si allocation globale
                     Else
                        # Calcul de la qté ŕ traiter du composant en UV et en US
                        WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
                        # Cas d'une livraison d'une nomenclature de sous-traitance avec un service forfaitaire
                        # Si livraison partielle, le service forfaitaire est également livré partiellement
                        # Sur la derničre livraison, il faut vérifier que le service est complčtement livré (pb d'arrondi)
                        If [F:SOP1]LINTYP=13 & WQTYDLVCPE=WQTYCPE
                           If  WQTYCPS+[F:SOQ1]ODLQTY+[F:SOQ1]DLVQTY<>[F:SOQ1]QTY
                               WQTYCPS=[F:SOQ1]QTY-[F:SOQ1]ODLQTY-[F:SOQ1]DLVQTY
                           Endif
                        Endif
                        WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
                        Call QTEARR (WQTYSTUCPS,[F:SOP1]STU) From TRTDIV
                        Gosub ALI_GENALP1
                        Raz LRET
                        # Appel algorithme en simulation pour déterminer la qté livrable
                        Call GENSTOSORW("",1,0,0,"",LRET) From STKSOR
                        # Si erreur ou pas de qté allouée sortable
                        If LRET<>0 | [M:ALP]ALLQTY=0
                           Raz WQTY, WQTYSTU
                        Else
                           WQTYSTU = [M:ALP]ALLQTY
                           WQTY    = WQTYSTU/WSAUSTUCOE
                        Endif
                     Endif

                     #--- Bug 71007
                     # Si livraison ligne complčte et qté sortable < qté ŕ sortir
                     If [F:SOH]DME=2 & WQTY<WQTYCPS
                       Raz WQTY, WQTYSTU
                       Raz WGENKIT : OK=1 : Break
                     Endif
                     #---

                     # La qté sortable du composant est < ŕ la qté ŕ traiter
                     # Recalcul nouvelle qté composée ŕ traiter
                     If WQTYSTU < WQTYSTUCPS
                        WQTYCPS    = WQTY
                        WQTYSTUCPS = WQTYSTU
                        # La qté ŕ livrer du cpsa doit ętre un multiple du rapport cpsé/cpsa
                        WQTYCPS    = WQTYCPS-mod(WQTYCPS,[F:SOQ1]QTY/[F:SOQ]QTY)
                        WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
                        Call QTEARR(WQTYSTUCPS,[F:SOP1]STU) From TRTDIV
                        # Recalcul de la nouvelle qté ŕ livrer du composé
                        WQTYCPE    = WQTYCPS*([F:SOQ]QTY/[F:SOQ1]QTY)
                        WQTYSTUCPE = WQTYCPE*[F:SOP]SAUSTUCOE
                        Call QTEARR(WQTYSTUCPE,[F:SOP]STU) From TRTDIV
                        WQTYDLVCPE = WQTYCPE+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
                     Endif
                  Endif
               Else
                  Raz WGENKIT : OK=1 : Break
               Endif
            # Fin de la boucle sur les composants
            Else
               Break
            Endif
         Next
         # Recalcul de la quantité ŕ livrer du composé (en UV cde)
         If WGENKIT=1
            WQTY    = WQTYCPE
            WQTYSTU = WQTYSTUCPE
            WQTYDLVCPE = WQTYCPE+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
         Endif
         # Relecture article maitre
         Read [ITM]ITM0 = [F:SOQ1]ITMREF
         If fstat : OK=1 : Return : Endif
      Endif
      #---------------------------------------------
      # TS : réajustement qté en unité vente entičre
      #---------------------------------------------
      If WSAU<>[F:ITM]STU
         Call CTRQTYPCU(WSAU,WSAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
         If WQTYARR<>WQTYSTU
            WQTYSTU = WQTYARR
            WQTY    = WQTYSTU/WSAUSTUCOE
         Endif
      Endif
      #---------------------------------------------
      Return

   # Composant de kit/sous-traité (on le prend ou non selon WGENKIT)
   Elsif find([F:SOP]LINTYP,3,4,5,11,12,13)
      If WGENKIT<>1 OK=1 Endif
      Return
   Endif
Endif

Return

#-----------------------------------------------------------------------#
# Alimentation des paramčtres dans [M:ALP] pour éxécution GENSTOSORW    #
#-----------------------------------------------------------------------#
$ALI_GENALP
[M:ALP]TRSTYP    = LTRSTYP
[M:ALP]TRSCOD    = LTRSCOD
[M:ALP]VCRTYP    = 4
[M:ALP]STOFCY    = [F:SOQ]STOFCY
[M:ALP]ITMREF    = [F:SOQ]ITMREF
# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ALP]ECCVALMAJ    = [F:SOQ]ECCVALMAJ
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ALP]QTY       = [F:SOQ]ALLQTYSTU
[M:ALP]TYPQTY    = 2
[M:ALP]BESDAT    = [F:SOQ]SHIDAT
[M:ALP]DLVDAT    = [F:SOQ]DEMDLVDAT
[M:ALP]ALLDAT    = [0/0/0]
[M:ALP]STOLOC    = ""
[M:ALP]PECINTLOC = 2
[M:ALP]PECSCOLOC = 1
[M:ALP]PECPLFLOC = 2
[M:ALP]PECCUNLOK = 1
[M:ALP]FILSTO    = ""
[M:ALP]LOT       = [F:SOQ]LOT
[M:ALP]LOC       = [F:SOQ]LOC
[M:ALP]STA       = [F:SOQ]STA
[M:ALP]WRH       = ""
If [F:SOH]SOHCAT=4
   [M:ALP]PCU       = [F:SOC]SAU
   [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
Else
   [M:ALP]PCU       = [F:SOP]SAU
   [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
Endif
Raz [M:ALP]ALLQTY
# Si allocation globale, on passe la qté déjŕ allouée en global
If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ]ALLQTYSTU Endif

Return

#-----------------------------------------------------------------------#
# Alimentation des paramčtres dans [M:ALP] pour éxécution GENSTOSORW    #
#              pour les lignes de composants                            #
#-----------------------------------------------------------------------#
$ALI_GENALP1
[M:ALP]TRSTYP    = LTRSTYP
[M:ALP]TRSCOD    = LTRSCOD
[M:ALP]VCRTYP    = 4
[M:ALP]STOFCY    = [F:SOQ1]STOFCY
[M:ALP]ITMREF    = [F:SOQ1]ITMREF
# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ALP]QTY       = [F:SOQ1]ALLQTYSTU
[M:ALP]TYPQTY    = 2
[M:ALP]BESDAT    = [F:SOQ1]SHIDAT
[M:ALP]DLVDAT    = [F:SOQ1]DEMDLVDAT
[M:ALP]ALLDAT    = [0/0/0]
[M:ALP]STOLOC    = ""
[M:ALP]PECINTLOC = 2
[M:ALP]PECSCOLOC = 1
[M:ALP]PECPLFLOC = 2
[M:ALP]PECCUNLOK = 1
[M:ALP]FILSTO    = ""
[M:ALP]LOT       = [F:SOQ1]LOT
[M:ALP]LOC       = [F:SOQ1]LOC
[M:ALP]STA       = [F:SOQ1]STA
[M:ALP]WRH       = ""
[M:ALP]PCU       = [F:SOP1]SAU
[M:ALP]PCUSTUCOE = [F:SOP1]SAUSTUCOE
Raz [M:ALP]ALLQTY
# Si allocation globale, on passe la qté déjŕ allouée en global
If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ1]ALLQTYSTU Endif

Return

#-----------------------------------------------------------------------#
# Chargement dans le fichier de travail                                 #
#-----------------------------------------------------------------------#
$CHARGEFIC
Call DEBTRANS From GLOCK
$CHGFIC
GOK=1
Trbegin [SWD]

# FGR 01/10/2014 : X3SUIVI102899 (début) : On ne passe pas dans $CHARGEFIC dans ce cas lŕ
## FGR 20/02/2014 : X3SUIVI81908 (début)
#If W81908MSGA <> "" Then
#  Call ECR_TRACE(W81908MSGA,0) From GESECRAN
#  Call ECR_TRACE("         "+W81908MSGB,1) From GESECRAN
#Endif
## FGR 20/02/2014 : X3SUIVI81908 (fin)
# FGR 01/10/2014 : X3SUIVI102899 (fin)

# Lecture entęte commande
Read [SOH]SOH0 Curr
If    fstat=1 : GOK=-1 : GLOCK="$SORDER"+[F:SOH]SOHNUM : Goto ROL_CHGFIC
Elsif fstat   : GOK=0  : Call RSTA("SOH",[F:SOH]SOHNUM ) From GLOCK : Goto AB_STD
Endif

# Lecture détail cde qte
Read [SOQ]SOQ0 Curr
If    fstat=1 : GOK=-1 : GLOCK="$SORDERQ"+[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ) : Goto ROL_CHGFIC
Elsif fstat   : GOK=0  : Call RSTA("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK : Goto AB_STD
Endif

Raz [F:SWD]
[F:SWD] = [F:SOH]
[F:SWD] = [F:SOQ]
[F:SWD]PRONUM   = adxuid(1)

# --- Dans SWDKEY separateurs ~ uniquement sur quelques champs car clé <= 128
[F:SWD]SWDKEY   = [F:SOQ]STOFCY
[F:SWD]SWDKEY  += "~"+[F:SOH]SALFCY                                   : # bug 22378
[F:SWD]SWDKEY  += "~"+num$([F:SOH]SOHCAT)                             : # bug 22378
[F:SWD]SWDKEY  += "~"+[F:SOQ]BPCORD                                   : # bug 22378
[F:SWD]SWDKEY  += "~"+[F:SOQ]BPAADD                                   : # bug 22378
[F:SWD]SWDKEY  += "~"+num$([F:SOH]ODL)                                : # bug 48597
[F:SWD]SWDKEY  += "~"+[F:SOH]BPCINV                                   : # bug 22378
# bug 46101 : La rčgle de gestion "livraison commande complčte" est prioritaire ŕ la rupture sur date d'expédition
If [M:DIA]RUPDAT = 2 & [F:SOH]DME<>3
   [F:SWD]SWDKEY  += "~"+format$("D:DDMMYYYY",[F:SOQ]SHIDAT)          : # bug 22378
Endif
[F:SWD]SWDKEY  += [F:SOH]CUR
[F:SWD]SWDKEY  += num$([F:SOH]PRITYP)

# 75115 : V7 : Extension of Digital Signature : New field delivery type
# Ajout du critčre sur le type de livraison
If [F:SOH]SDHTYP<>""
  [F:SWD]SWDKEY  += [F:SOH]SDHTYP
Elsif find([F:SOH]SOHCAT,1,4)
  [F:SWD]SWDKEY  += [M:DIA]SDHTYPNOR
Elsif [F:SOH]SOHCAT=2
  [F:SWD]SWDKEY  += [M:DIA]SDHTYPLND
Endif
# 75115
# --- SWDKEY rempli ŕ 74 caractčres (sur 80)

[F:SWD]SWDKEY  += [F:SOQ]BPTNUM

[F:SWD]SWDDATA  = [F:SOH]BPCPYR
[F:SWD]SWDDATA += "~"+[F:SOH]BPCGRU                                   : # bug 22378
[F:SWD]SWDDATA += "~"+toupper(vireblc([F:SOH]BPDNAM(0),4))            : # bug 22378
[F:SWD]SWDDATA += "~"+toupper(vireblc([F:SOH]BPINAM(0),4))            : # bug 22378
[F:SWD]SWDDATA += "~"+[F:SOH]PTE                                      : # bug 22378
[F:SWD]SWDDATA += "~"+num$([F:SOH]BETFCY)                             : # bug 22378
[F:SWD]SWDDATA += "~"+num$([F:SOH]BETCPY)                             : # bug 22378
[F:SWD]SWDDATA += "~"+[F:SOH]ORIFCY                                   : # bug 22378
[F:SWD]SWDDATA += "~"+format$("D:DDMMYYYY",[F:SOH]LNDRTNDAT)          : # bug 22378
[F:SWD]SWDDATA += "~"+[F:SOH]DEP                                      : # bug 22378
[F:SWD]SWDDATA += "~"+num$([F:SOH]IME)                                : # bug 22378
[F:SWD]SWDDATA += "~"+[F:SOQ]MDL                                      : # bug 22378
If [F:SOH]SOHCAT=4
    [F:SWD]SWDDATA += "~"+[F:SOC]VACBPR                               : # bug 22378
    [F:SWD]SWDDATA += "~"+[F:SOC]BPIEECNUM                            : # bug 22378
    [F:SWD]SWDDATA += "~"+[F:SOC]EECICT                               : # bug 22378
    [F:SWD]SWDDATA += "~"+num$([F:SOC]EECLOC)                         : # bug 22378
Else
    [F:SWD]SWDDATA += "~"+[F:SOH]VACBPR                               : # bug 22378
    [F:SWD]SWDDATA += "~"+[F:SOH]BPIEECNUM                            : # bug 22378
    [F:SWD]SWDDATA += "~"+num$([F:SOH]EECLOC)                         : # bug 22378
Endif
[F:SWD]SWDDATA += "~"+[F:SOH]PLISTC                                   : # bug 22378
#--------------------------------------
# FGR 05/12/2011 : X3SUIVI71065 (début)
# 1°) Ca n'est plus le PJT de l'entęte qui compte
#[F:SWD]SWDKEY  += [F:SOH]PJT
If GPJTSNGDOC = G_OUI Then
  # Si le PJT est unique par pičce il est discriminant : on le prend
  [F:SWD]SWDDATA += "~"+[F:SOH]PJT
Else
  # Sinon, il n'est pas discriminant : on l'ignore
  [F:SWD]SWDDATA += "~"
Endif
# FGR 05/12/2011 : X3SUIVI71065 (fin)
#--------------------------------------

[F:SWD]SWDDATA2  = toupper(vireblc([F:SOH]BPDADDLIG(0),4))            : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPDPOSCOD,4))               : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPDCTY,4))                  : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPDSAT,4))                  : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPIADDLIG(0),4))            : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPIPOSCOD,4))               : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPICTY,4))                  : # bug 22378
[F:SWD]SWDDATA2 += toupper(vireblc([F:SOH]BPISAT,4))                  : # bug 22378
# --- SWDDATA2 rempli au maximum ŕ 270 caractčres
# ACA - Gestion de GRUFLG
Local Integer I, J : I=0
# Gosub OPEN_SFI From TRTX3CPY
# For I = 0 To dim([F:SOH]INVDTA)-1
#     Read [F:SFI]SFI0 = [F:SOH]INVDTA(I)
#     J=find(2, [F:SFI]DESVCR(0..dim([F:SFI]DESVCR)-1))
#     If J>0 & [F:SFI]GRUFLG(J-1) = 2 : # Non si différence
#         [F:SWD]SWDDATA2 += "~" + vireblc( num$( [F:SOH]INVDTAAMT(I) ) ,4 )
#     Endif
# Next I

# ACA - Utilise le tableau GRUNON chargé dans SEL_COMMANDE pour savoir
# quels éléments ajouter au filtre
While [L]GRUNON(I)>0 and I<RCNTDFI-1
    J=find([L]GRUNON(I), [F:SOH]INVDTA)
    If J>0
      #--CPO 107663
      # Issue X3-218911 - 20201021 by LD
      #If [F:SOH]DLVSTA>1
      # The elt is Grouping "No if different"
      # If the elt is Split "1rst delivery" and the sales order is delivered (partially or totally)
      # the elt is already taken into account in the 1rst delivery so amount to consider now is 0
      # (in the other case of Split, consider the amount elt)
      If [L]BRDRUL(I)=2 & [F:SOH]DLVSTA>1
      # End issue X3-218911 - 20201021 by LD
        [F:SWD]SWDDATA2 += "~" + "0"
      Else
      #--/
        [F:SWD]SWDDATA2 += "~" + vireblc( num$( [F:SOH]INVDTAAMT(J-1) ) ,4 )
      Endif
    Endif
    I+=1
Wend

# ACA - Codes adresses client commande et facture
[F:SWD]SWDDATA2 += [F:SOH]BPAORD
[F:SWD]SWDDATA2 += [F:SOH]BPAINV
# --- SWDDATA2 dépasse les 250 caractčres maxi

# LTA - Sage sales tax USA
If func AFNC.ACTIV("LTA")
  [F:SWD]SWDDATA2 +="~"+[F:SOH]SSTENTCOD
Endif

# Chargement qté ŕ livrer dans (SWD]
# WQTY     = qté ŕ livrer en UV
# WQTYSTU  = qté ŕ livrer en US
Raz [F:SWD]QTY, [F:SWD]QTYSTU
# Si ligne de commande normale ou de nomenclature
If [F:SOH]SOHCAT=4 | !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
   [F:SWD]QTY    = WQTY
   [F:SWD]QTYSTU = WQTYSTU
# Si composé kit/sous-traité
Elsif find([F:SOP]LINTYP,2,10)
   [F:SWD]QTY    = WQTY
   [F:SWD]QTYSTU = WQTYSTU
   # Stockage qté livré et cdé composé pour calcul qté composant
   WQTYCPE       = WQTY
   WSOQQTY       = [F:SOQ]QTY
   WQTYDLVCPE    = WQTYCPE+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
# Si composant kit/sous-traité
Elsif find([F:SOP]LINTYP,3,4,5,11,12,13)
   If WSOQQTY<>0
       [F:SWD]QTY=WQTYCPE*([F:SOQ]QTY/WSOQQTY)
   Else
       [F:SWD]QTY=0
   Endif
   # Cas d'une livraison d'une nomenclature de sous-traitance avec un service forfaitaire
   # Si livraison partielle, le service forfaitaire est également livré partiellement
   # Sur la derničre livraison, il faut vérifier que le service est complčtement livré (pb d'arrondi)
   If [F:SOP]LINTYP=13 & WQTYDLVCPE=WSOQQTY
       If  [F:SWD]QTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>[F:SOQ]QTY
           [F:SWD]QTY=[F:SOQ]QTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY
       Endif
   Endif
   [F:SWD]QTYSTU = [F:SWD]QTY*[F:SOP]SAUSTUCOE
   Call QTEARR ([F:SWD]QTYSTU,[F:SOP]STU) From TRTDIV
Endif

# Pour rajouter des conditions de regroupements
GPOINT="AUTDLVREG" : Gosub ENTREE From EXEFNC

# Attribution des SWDKEYD
If [F:SWD]SWDDATA<>""                                                                         : # bug 22378
   # Filter [SWD3] Where PRONUM=[F:SWD]PRONUM & SWDKEY=[F:SWD]SWDKEY & SWDDATA=[F:SWD]SWDDATA   : # bug 22378
   Filter [SWD3] Where PRONUM=[F:SWD]PRONUM & SWDKEY=[F:SWD]SWDKEY & SWDDATA=[F:SWD]SWDDATA & SWDDATA2=[F:SWD]SWDDATA2
   Read [SWD3] First                                                                          : # bug 22378
   If fstat                                                                                   : # bug 22378
      WSWDKEYD += 1                                                                           : # bug 22378
      [F:SWD]SWDKEYD=WSWDKEYD                                                                 : # bug 22378
     Else                                                                                     : # bug 22378
      [F:SWD]SWDKEYD=[F:SWD3]SWDKEYD                                                          : # bug 22378
   Endif                                                                                      : # bug 22378
   Filter [SWD3]                                                                              : # bug 22378
Endif                                                                                         : # bug 22378

Write [SWD]
If fstat
   GOK=0 : Call FSTA("SWD") From GLOCK : Goto AB_STD
Endif
NBCDE += 1

If [F:SOH]SOHCAT = 2 WFLGLND = 1
Else                 WFLGLIV = 1 : Endif

Commit
# Issue X3-218911
GPE=1
# End Issue X3-218911
Return

#-----------------------------------------------------------------------#
# Recherche de la transaction de livraison                              #
#-----------------------------------------------------------------------#
$RECH_TRSVEN
Local Char    WTRS

OK=2
If !clalev ([F:SLT]) : Local File SALTRS  [SLT] : Endif
# Il y a des livraisons normales ŕ traiter
If WFLGLIV = 1
   WTRS=GTRSLIV
   If WTRS <> ""
      Read [SLT]SLT0=4;WTRS
      If fstat WTRS="" Endif
   Endif
   # Aucune transaction paramétrée ou elle n'existe plus
   If WTRS = ""
      # X3-1152 : Non invoiceable deliveries
#     Filter [SLT] Where STRTYP=4 & ENAFLG=2 & find(DLVTYP,1,5)
      Filter [SLT] Where STRTYP=4 & ENAFLG=2 & find(DLVTYP,1,4)
      # X3-1152 : Non invoiceable deliveries
      Read [SLT]SLT0 First
      If fstat
         Call ECR_TRACE(mess(287,192,1),1) From GESECRAN : OK=1 : Return
      Endif
      Filter [SLT]
   Endif
   [M:DIA]TRSFAMLIV = [F:SLT]TRSFAM
   [M:DIA]TRSCODLIV = [F:SLT]TRSCOD
   [M:DIA]ENTCODLIV = [F:SLT]ENTCOD
   #[M:DIA]CCEDEFLIV = [F:SLT]CCEDEF
Endif
# Il y a des livraisons de pręt ŕ traiter
If WFLGLND = 1
   WTRS=GTRSLND
   If WTRS <> ""
      Read [SLT]SLT0=4; WTRS
      If fstat WTRS="" Endif
   Endif
   # Aucune transaction paramétrée ou elle n'existe plus
   If WTRS = ""
      # X3-1152 : Non invoiceable deliveries
#     Filter [SLT] Where STRTYP=4 & ENAFLG =2 & find(DLVTYP,2,5)
      Filter [SLT] Where STRTYP=4 & ENAFLG =2 & find(DLVTYP,2,4)
      # X3-1152 : Non invoiceable deliveries
      Read [SLT]SLT0 First
      If fstat
         Call ECR_TRACE(mess(288,192,1),1) From GESECRAN : OK=1 : Return
      Endif
      Filter [SLT]
   Endif
   [M:DIA]TRSFAMLND = [F:SLT]TRSFAM
   [M:DIA]TRSCODLND = [F:SLT]TRSCOD
   [M:DIA]ENTCODLND = [F:SLT]ENTCOD
   #[M:DIA]CCEDEFLND = [F:SLT]CCEDEF
Endif
# FGR 20/11/2009 : X3SUIVI48897 : Point d'entrée permettant de choisir la transaction de livraison
GPOINT="AUTTRSVEN" : Gosub ENTREE From EXEFNC
Return

#-----------------------------------------------------------------------#
# Traitement du fichier de travail : génération des livraisons          #
#-----------------------------------------------------------------------#
$TRTSWD

# Récup nb lignes livraison autorisées par le code activité
WSDHACV=0
Read [ACV] CODACT = "SDH"
If !fstat : WSDHACV = [F:ACV]DIME : Endif
If WSDHACV = 0
   GOK = 0 : Call ECR_TRACE(mess(136,199,1),1) From GESECRAN : Return
Endif

GOK      = 0
WTRBEGIN = 0
Raz [F:SWD1]

# -------------------------------------------------------- #
# Ouverture des masques livraison pour la valorisation TTC #
# -------------------------------------------------------- #
Local Mask SDH0 [SDH0] : Raz [M:SDH0]
Local Mask SDH1 [SDH1] : Raz [M:SDH1]
Local Mask SDH2 [SDH2] : Raz [M:SDH2]
Local Mask SDH3 [SDH3] : Raz [M:SDH3]
Local Mask SIHV [SIHV] : Raz [M:SIHV]

Local Char SVGGREP # Issue 109784 - 2015-08-06 by CPO

Local Char SFIT_OBJ : SFIT_OBJ="SDH"
#--CPO 106895
#Gosub INIT_SFIT From SUBSFIT
Local Char CPOSVGGREP(type(GREP)-10)
CPOSVGGREP=GREP
GREP="C"
Gosub INIT_SFIT From SUBSFIT
GREP=CPOSVGGREP
#--/
#--- Bug 22275 --- TS le 29.04.04 -------------------------
# Pb de taille de clé suite aux corrections 19067 et 20251
#----------------------------------------------------------
#Filter [SWD] Where PRONUM=adxuid(1)
#&            Order By Key CLE=SWDKEY;SWDDATA;SWDDATA2;SOHNUM;SOPLIN;SOQSEQ
#Filter [SWD] Where PRONUM=adxuid(1) Order By Key SWD0                   : # bug 22378
Filter [SWD] Where PRONUM=adxuid(1)
&            Order By Key CLE=PRONUM;SWDKEY;SWDKEYD;SOHNUM;SOPLIN;SOQSEQ : # bug 22378

For [SWD]
    # --------> Cde en Livraison cde complčte et abandon de la txn suite ŕ pb sur une ligne : Pas de trt des autres lignes
    If GOK<1 & WDME=3 & WSOHNUM=[F:SWD]SOHNUM Goto NXTTRT Endif

    # --------> débranchement sur détail     ------------------------------
    If   [F:SWD1]SWDKEY   = [F:SWD]SWDKEY
&      & [F:SWD1]SWDDATA  = [F:SWD]SWDDATA
&      & [F:SWD1]SWDDATA2 = [F:SWD]SWDDATA2
&      & [F:SWD1]SOHNUM   = [F:SWD]SOHNUM  Goto  DETAIL
    Endif
    # --------> fin commande précédente  --------------------------
    If   [F:SWD1]SOHNUM  <> "" :          If GOK=1 & WSOHLIN>0
                                             Gosub SOH_FIN
                                             If GOK<1 : Goto NXTTRT : Endif
                                          Endif
    Endif

    # --------> vérif nb lignes disponibles sur livraison pour 1 nouvelle cde
    Gosub VERIF_LIN

    # --------> debut commande sur 1 męme livraison -------------------
# bug 48597 : Ajout test flg des 2 cdes
    If   [F:SWD1]SWDKEY   = [F:SWD]SWDKEY
&      & [F:SWD1]SWDDATA  = [F:SWD]SWDDATA
&      & [F:SWD1]SWDDATA2 = [F:SWD]SWDDATA2
&      & [F:SWD1]ODL<>2 & [F:SWD]ODL<>2 & [F:SWD1]IME<>2 & [F:SWD1]IME<>3
&      & LINFLG = 1
&      & [F:SWD1]SOHNUM <> ""
#&      & [F:SWD1]ODL<>2 & [F:SWD1]IME<>2 & [F:SWD1]IME<>3
                                          If GOK=1 & WSDHLIN>0
                                             Gosub SOH_DEB
                                             If GOK<1 : Goto NXTTRT : Endif
                                          Endif
                                          Goto  DETAIL
    Endif

    # --------> fin livr. précédente / début suivante -----------------
    If   [F:SWD1]SOHNUM <> "" :           If GOK=1 & WSDHLIN>0
                                             Gosub TRT_ENTETE_FIN
                                             If GOK=1
                                                 Gosub TRT_VALID
                                             Endif
                                          Endif
    Endif
    Gosub TRT_ENTETE_DEB
    If    GOK<1 Goto NXTTRT Endif

    #--CPO 106895
    #Call NEW_SFIT ( "F","SDH",[F:SDH]CUR,[F:SDH]BPCINV,[F:SDH]BPCORD,[F:SDH]DLVDAT ) From SUBSFIT
    CPOSVGGREP=GREP
    GREP="C"
    Call NEW_SFIT ( "F","SDH",[F:SDH]CUR,[F:SDH]BPCINV,[F:SDH]BPCORD,[F:SDH]DLVDAT ) From SUBSFIT
    GREP=CPOSVGGREP
    #--/

    Goto  DETAIL

    # --------> traitement du détail     ------------------------------
    $DETAIL

    If GOK=1
       Gosub TRT_DETAIL
       If GOK<1 | [F:SDD]QTYSTU=0
          Goto NXTTRT
       Endif
       [F:SWD1]=[F:SWD]
    Endif
    $NXTTRT
    If GOK<1 & WDME=3 Raz [F:SWD1] Endif
Next

If GOK = 1
   If WSDHLIN>0
      If WSOHLIN>0
         Gosub SOH_FIN       : If    GOK<1 : Return : Endif
      Endif
      Gosub TRT_ENTETE_FIN   : If    GOK<1 : Return : Endif
      Gosub TRT_VALID
   Else
      Commit
   Endif
Endif

Return

#-----------------------------------------------------------------------#
# Traitement de l'entęte livraison                                      #
#-----------------------------------------------------------------------#
$TRT_ENTETE_DEB

Call DEBTRANS From GLOCK
$TRTENT
If WTRBEGIN=0
   GOK=1
   Trbegin [SOH],[SOQ],[SDH],[SDD],[MVC],[LCM],[SWD1]

   Call ECR_TRACE(mess(598,197,1),0)From GESECRAN
Endif
WTRBEGIN = 1
Raz LIN, WSDHLIN, WSOHLIN
Raz WDLRNOT, WDLRATI

# Lecture entęte commande
Readlock [SOH]SOH0 = [F:SWD]SOHNUM
If  fstat=1
    GOK=-1 : GLOCK="$SORDER"+[F:SWD]SOHNUM: Goto ROL_TRT
Elsif fstat
    GOK=0 : Call RSTA("SOH",[F:SWD]SOHNUM) From GLOCK : Goto AB_STD
Endif

WDME=[F:SOH]DME : WSOHNUM=[F:SOH]SOHNUM

# Lecture détail cde qte
Readlock [SOQ]SOQ0 = [F:SWD]SOHNUM; [F:SWD]SOPLIN; [F:SWD]SOQSEQ
If  fstat=1
    GOK=-1 : GLOCK="$SORDERQ"+[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)-num$([F:SWD]SOQSEQ): Goto ROL_TRT
Elsif fstat
    GOK=0 : Call RSTA("SOQ",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)-num$([F:SWD]SOQSEQ)) From GLOCK : Goto AB_STD
Endif

# Lecture détail cde prix
If [F:SOH]SOHCAT = 4
   Read [SOC]SOC0=[F:SWD]SOHNUM;[F:SWD]SOPLIN
   If fstat
      GOK=0 : Call RSTA("SOC",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)) From GLOCK  : Goto AB_STD
   Endif
Endif

# Lecture client livré
Read [BPD]BPD0 = [F:SWD]BPCORD; [F:SWD]BPAADD
If  fstat
    GOK=0 : Call RSTA("BPD",[F:SWD]BPCORD-[F:SWD]BPAADD) From GLOCK : Goto AB_STD
Endif

# Lecture client facture
Read [BPC]BPC0 = [F:SWD]BPCINV
If  fstat
    GOK=0 : Call RSTA("BPC",[F:SWD]BPCINV) From GLOCK : Goto AB_STD
Endif

# Lecture tiers
Read [BPR]BPR0 = [F:SWD]BPCINV
If  fstat
    GOK=0 : Call RSTA("BPR",[F:SWD]BPCINV) From GLOCK : Goto AB_STD
Endif

# Lecture transporteur
Read [BPT]BPT0 = [F:SOQ]BPTNUM
If  fstat : Raz [F:BPT] : Endif

# Lecture mode de livraison
Read [TMD]TMD0 = [F:SWD]MDL
If  fstat : Raz [F:TMD] : Endif

# Lecture article maitre
Read [ITM]ITM0 = [F:SOQ]ITMREF
If  fstat
    GOK=0 : Call RSTA("ITM",[F:SOQ]ITMREF) From GLOCK : Goto AB_STD
Endif

# 75115 : V7 : Extension of Digital Signature : New field delivery type
# Lecture type de livraison
Local Integer WERR
Local Char    WSDHTYP(GLONTSD)
If [F:SOH]SDHTYP<>""
  WSDHTYP=[F:SOH]SDHTYP
Elsif [F:SOH]SOHCAT=2
  WSDHTYP=[M:DIA]SDHTYPLND
Else
  WSDHTYP=[M:DIA]SDHTYPNOR
Endif
Call LEC_TSD_LEG(GCURLEG,WSDHTYP,WERR) From TRTLECLEG
If WERR GOK=0 : Call RSTA("TSD", WSDHTYP) From GLOCK : Goto AB_STD Endif
# 75115

# Alimentation GSOCIETE,GFINRSP,GLOCALDEV
#Call GETDEV([F:SOH]SALFCY) From DEVSUB
# Chargement globales référenciels, comptes et sections de la société
If GFCY<>[F:SOH]SALFCY GFCY=[F:SOH]SALFCY : Gosub CHARG_PARAM Endif

# Alimentation gest avance(GEARMGT), acompte non versé(GLOKORD), ctl en-cours(GOSTCTL)
Call GLOBVAR([F:SOH]SALFCY,"VEN") From TRTX3

# Alimentation entęte livraison
Call ALICDESDH From TRTVENLIV

# Issue 109784 - 2015-08-06 by CPO : Following 107712, Bad update in SDELIVERYD using FUNPREDLV
#--Le transclasse va initialiser les champs DSPTOTQTY/DSPTOTWEI/DSPTOTVOL avec les valeurs inscrite dans le SQH
#--On doit les Raz car ces champs seront mis ŕ jour dans les ss-pros appelés lors de création de SDD (également corrigés)
Raz [F:SDH]DSPTOTQTY ,[F:SDH]DSPTOTVOL, [F:SDH]DSPTOTWEI
# End issue 109784

# Récupération données stock de la transaction
If [F:SDH]LND = 2
   [F:SDH]TRSFAM = [M:DIA]TRSFAMLND
   [F:SDH]TRSCOD = [M:DIA]TRSCODLND
   [F:SDH]ENTCOD = [M:DIA]ENTCODLND
   #[F:SDH]CCEDEF = [M:DIA]CCEDEFLND
Else
   [F:SDH]TRSFAM = [M:DIA]TRSFAMLIV
   [F:SDH]TRSCOD = [M:DIA]TRSCODLIV
   [F:SDH]ENTCOD = [M:DIA]ENTCODLIV
   #[F:SDH]CCEDEF = [M:DIA]CCEDEFLIV
Endif

If [F:SDH]BPDNAM(0) <> ""
    WBPDNAM=[F:SDH]BPDNAM(0)
Else
    If [F:BPD]BPCNUM<>[F:SDH]BPCORD | [F:BPD]BPAADD<>[F:SDH]BPAADD
        Read [BPD]BPD0 = [F:SDH]BPCORD; [F:SDH]BPAADD
        If fstat Raz [F:BPD] : Endif
    Endif
    WBPDNAM=[F:BPD]BPDNAM
Endif

# Dans la valorisation TTC, on passe par les classes écrans, il faut les charger
Raz [M:SDH1]

Return


#-----------------------------------------------------------------------#
# Traitement de l'entęte livraison                                      #
#-----------------------------------------------------------------------#
$TRT_ENTETE_FIN
Call PJT_WRITE_MSG() From TRTPJT  # FGR 14/12/2011 : # X3SUIVI71065
# Recherche tarif transporteur
If GFRENUM <> 0
   Gosub RECH_TARIF_TRSP From TRTVENLIV
   If GOK = 0 Goto AB_STD Endif
   If GOK < 0 Goto ROL_TRT Endif
Endif

# Maj sf si livraison intra-société
If !([F:SDH]BETFCY=2 & [F:SDH]BETCPY<=1)
    # Maj mouvement client (en-cours livraison)
    Call  MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&       0, [F:SDH]DLVATI, "+", "O", "", [F:SDH]LND) From TRTBPMVT
    If GOK = 0 Goto AB_STD Endif
    If GOK < 0 Goto ROL_TRT Endif
Endif

If dim([F:SDH]CPY)>0 : [F:SDH]CPY=GSOCIETE : Endif

# Alimentation des montants en devise société
Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&            [F:SDH]DLVNOT,[F:SDH]DLVNOTL,[F:SDH]CHGRAT,STAT) From TRTDEV
Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&            [F:SDH]DLVATI,[F:SDH]DLVATIL,[F:SDH]CHGRAT,STAT) From TRTDEV

# --- Valorisation TTC (idem calcul facture)
[M:SDH0] = [F:SDH] : [M:SDH1] = [F:SDH] : [M:SDH2] = [F:SDH] : [M:SDH3] = [F:SDH]
Local Char WGREP : WGREP=GREP
GREP="C"
Global Integer G_CLCDSPLIN     : G_CLCDSPLIN    =1
Global Integer G_PREV_DSPLIN   : G_PREV_DSPLIN  =1 # Issue 109784 - 2015-08-06 by CPO

# 101874 : V9 : Taxe code control
# Valuation is always done in this case
GVALTTC=2
#---- Paramčtres complementaires contrôle des taxes
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non avec msg/2=Oui avec msg/3=Non sans msg/4=Oui sans msg)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
Local    Char     PARAM_T (25) (0..10)
PARAM_T(0)="2"      : # Contrôle des taxes lors de la création
PARAM_T(1)="3"      : # Pas d'affichage du msg, pas de lecture de la trace
PARAM_T(2)="0"
Call VALTTC ("GESSDHF", PARAM_T) From TRTVENFACR
#Call VALTTC ("GESSDHF") From TRTVENFACR
If PARAM_T(2)="1" GOK=0 : Goto AB_STD Endif
# 101874

GREP=WGREP

# Ecriture entęte livraison
Raz [F:SDH]CREDATTIM, [F:SDH]UPDDATTIM  ## SAM 115938 (LC - 24/11/16)

# Ini SAM 107649 (SOH or SDH dimension is major than SIH - JUCON 27/01/2017)
If WSDHLIN+1>func AFNC.ACTIV("SIH")
  GMESSAGE=mess(547,192,1) # Activity codes SOH or SDH have a dimension major than SIH. SIH must be incremented
  Call ECR_TRACE(GMESSAGE-":"-[F:SDD]SDHNUM+num$([F:SDD]SDDLIN),0) From GESECRAN
  Raz GMESSAGE
  GOK=0:  Goto AB_STD
  Return
Endif
# End SAM 107649 (SOH or SDH dimension is major than SIH - JUCON 27/01/2017)

Write [SDH]
If fstat
   GOK=0: Call FSTA("SDH") From GLOCK: Goto AB_STD
Else
   NBLIV +=1
Endif

# 107712
# Mise ŕ jour de la Répartition des élements de facturation dans les tables des lignes
If G_VALSFL>0
    If sum([M:SIHV]DDTANOT01(0..G_VALSFL-1),[M:SIHV]DDTANOT02(0..G_VALSFL-1),[M:SIHV]DDTANOT03(0..G_VALSFL-1))<>0 |
&      sum([M:SIHV]DDTANOT04(0..G_VALSFL-1),[M:SIHV]DDTANOT05(0..G_VALSFL-1),[M:SIHV]DDTANOT06(0..G_VALSFL-1))<>0 |
&      sum([M:SIHV]DDTANOT07(0..G_VALSFL-1),[M:SIHV]DDTANOT08(0..G_VALSFL-1),[M:SIHV]DDTANOT09(0..G_VALSFL-1))<>0
        nolign=1
        Filter [SDD] Where SDHNUM = [F:SDH]SDHNUM
        For [SDD]SDD0
            Readlock [SDD]SDD0 Curr
            If    fstat=1 : GOK=-1 : GLOCK="$SDELIVERYD"+[F:SDD]SDHNUM+num$([F:SDD]SDDLIN) : Break
            Elsif fstat   : GOK=0  : Call RSTA("SDD",[F:SDD]SDHNUM+num$([F:SDD]SDDLIN)) From GLOCK : Break
            Endif
            # --- Stockage a la ligne des elt de facturation
            Call UPD_DSPLIN("SDD",nolign-1) From TRTVENFACC
            Rewrite [SDD]
            If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Break : Endif
            nolign+=1
        Next
        Filter [SDD]
        If GOK<0 Goto ROL_TRT Endif
        If GOK=0 Goto AB_STD Endif
    Endif
Endif
# 107712

# Issue 116639 - 2016-07-12 by ERMIL : Move WS calls outside of transactions
#----------------------------------------------------------------#
# 78411 Sage Exchange                                            #
# Transfer SE records to new SDHNUM                              #
#----------------------------------------------------------------#
#If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
#  Local Integer SEERR
#  Local Char    SEMESSAGE(250)
#  Call TRANSFER(2,[F:SDH]SOHNUM,4,[F:SDH]SDHNUM,SEERR) From SEPPLIB
#  #If WRET : Raz GOK : Goto AB_STD : Endif      # SAM 103024.o
#  If SEERR>0 : Raz GOK : Goto AB_STD : Endif    # SAM 103024.n
#Endif

#----------------------------------------------------------------#
# Création des enregistrements sans SVCRVAT et SVCRFOOT          #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("C","SDH") From TRTVENFACC
If GOK < 1 Goto AB_STD Endif

# Pour mettre ŕ jour des tables annexes
GPOINT="AUTDLVMAJ" : Gosub ENTREE From EXEFNC
If GOK = 0 Goto AB_STD Endif
If GOK < 0 Goto ROL_TRT Endif

#85785
##--CPO for RMA Issue 75115 Digital signature of shipments and customer returns
## ----------------------------------------------------------- #
## Digital signature of shipments and customer returns         #
## ----------------------------------------------------------- #
#If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[F:SDH]CPY)="2"
#  Local Char     SAVE_GCPT
#  If GCPT<>LCPT and LCPT<>""
#    SAVE_GCPT=GCPT : GCPT=LCPT
#  Endif
#  Gosub DIGSIGN From SUBSDHA
#  If SAVE_GCPT<>GCPT GCPT=SAVE_GCPT Endif
#Endif
## ----------------------------------------------------------- #
Commit
WTRBEGIN = 0

# Issue 116639 - 2016-07-11 by ERMIL : Remove WS calls from inside transactions
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Local Integer SSTERR
  Local Char    SSTERRMSG(250)
  Local Char    SDHNUM(20) : SDHNUM = [F:SDH]SDHNUM

  Local Char WGREP : WGREP=GREP : GREP="C"
  GVALTTC=2
  PARAM_T(0)="2" : PARAM_T(1)="3" : PARAM_T(2)="0"
  Call VALTTC ("GESSDHF", PARAM_T) From TRTVENFACR
  If PARAM_T(2)="1" : GOK=0 : Goto WEBSERVICE_ERROR : Endif
  GREP=WGREP

  Call UPD_VALORISATION ("M","SDH") From TRTVENFACC
  If GOK < 1 : Goto WEBSERVICE_ERROR : Endif

  Trbegin [SDH]
  Readlock [SDH]SDH0 = [L]SDHNUM With lockwait=3
  If fstat : Call FSTA("SDH") From GLOCK : Endif

  # Update the shipment header totals
  [F:SDH]DLVINVNOT  = [M:SIHV]INVNOT
  [F:SDH]DLVINVATI  = [M:SIHV]INVATI
  [F:SDH]DLVINVNOTL = [M:SIHV]INVNOTRPT
  [F:SDH]DLVINVATIL = [M:SIHV]INVATIRPT

  # Update the values back to the table
  Rewrite [SDH]
  If fstat
    Call FSTA("SDH") From GLOCK
    Rollback
    SSTERR = 1
    Goto WEBSERVICE_ERROR
  Else
    Commit
  Endif

  # Update the line level fields back to the table
  Trbegin [SDD]

  Local Integer I
  For I=0 To [M:SDH1]NBLIG-1
    Readlock [SDD]SDD0 = [L]SDHNUM;[M:SDH1]SDDLIN(I) With lockwait=3
    If fstat : Call FSTA("SDD") From GLOCK : Endif

    [F:SDD]NETPRIATI = [M:SDH1]NETPRIATI(I)
    [F:SDD]NETPRINOT = [M:SDH1]NETPRINOT(I)

    Rewrite [SDD]
    If fstat
      Call FSTA("SDD") From GLOCK
      GOK=0
      Break
    Endif

  Next

  # If an error occurred, roll back, but dont hold up processing
  If GOK=0
    Rollback
    SSTERR = 1
    Goto WEBSERVICE_ERROR
  Else
    Commit
  Endif

Endif

If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
  Local Integer SEERR, PAERR
  Local Char    SEMESSAGE(250), PAMESSAGE(250)

  Call TRANSFER(2,[F:SDH]SOHNUM,4,[F:SDH]SDHNUM,SEERR) From SEPPLIB

  # Save the response - needed for Post Order auth
  Call POST_AUTH(4,[F:SDH]SDHNUM,PAERR,PAMESSAGE) From SEPPLIB

  If [L]SEERR | [L]PAERR : Goto WEBSERVICE_ERROR : Endif

Endif
# 116639 - issue end

# Trace livraison
Call ECR_TRACE(mess(116,197,1)-":"-[F:SDH]SDHNUM-mess(42,191,1)-":"-[F:SDH]BPCORD-[F:SDH]BPAADD-WBPDNAM,0)
&              From GESECRAN

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#Gbn-Fq76563-Edition BP seulement si on ne valide pas les livraisons ou si on valide et GSDHENDNBR ŕ non pour la société
If [M:DIA]CFMFLG <> 2 | ([M:DIA]CFMFLG=2 & GSDHENDNBR<>2)
 #----- Bon de préparation -----#
 If [M:DIA]NPRFLG=2 & [M:DIA]NPRNAM<>"" & [M:DIA]NPRDEN<>""
   #----- Code de l'état et nombre de copies -----#
   WARP_RPTCOD(0)=[M:DIA]NPRNAM
   WARP_NBRCPY   =1
   #----- Ecriture AREPORTM et mŕj indicateur d'impression sur entęte livraison -----#
   Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
   #-----
 Endif
Endif

# Si présence module Support Client et validation des livraisons
If GMODU(12)=2 & [M:DIA]CFMFLG = 2
   # Alimentation des bornes min et max des livraisons traitées
   If STRNUM=""
      STRNUM=[F:SDH]SDHNUM
   Elsif STRNUM>[F:SDH]SDHNUM
      STRNUM=[F:SDH]SDHNUM
   Endif
   If ENDNUM=""
      ENDNUM=[F:SDH]SDHNUM
   Elsif ENDNUM<[F:SDH]SDHNUM
      ENDNUM=[F:SDH]SDHNUM
   Endif
Endif

# ACA (2009-09-15) Lot S03
# 81878 : Ajout borne pour ne pas trier le tableau complet
#Sorta [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
# 81878
Call CHARG_CCE_MULTI(20,"[M:SFIT]VCRENT","[M:SFIT]DTA","[M:SIHV]XFNUM","[M:SIHV]SFICCE","[M:SIHV]DSP") From TRTX3CPT
[M:SIHV]VCRTYP=2 : [M:SIHV]NUM=[F:SDH]SDHNUM
Gosub CREMOD_DIE_FOOT From SUBSIHV

Return

#-----------------------------------------------------------------------#
# Traitement de validation en fin de livraison                          #
#-----------------------------------------------------------------------#
$TRT_VALID
Local Char WTRS(3)
If [M:DIA]CFMFLG = 2
   SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
   Lock = SYMBOLE2 With lockwait=0
   If fstat=1
      # Modification en cours sur un autre poste
      Call ECR_TRACE("          "+[F:SDH]SDHNUM-mess(10,100,1),1) From GESECRAN
   Else
      Call VALIDATION([F:SDH]SDHNUM) From TRTVENLIVV
      If  GOK=1

         # Issue X3-69499 - 2018-05-16 by TS
         Local Integer WNBLINCFM
         Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
         WNBLINCFM = rowcount([SDD])
         Filter [SDD]
         #Call ECR_TRACE(mess(54,198,1)-mess(3,429,1),0) From GESECRAN
         If [F:SDH]CFMFLG=2
           Call ECR_TRACE(mess(54,198,1)-mess(3,429,1)-":"-[F:SDH]SDHNUM,0) From GESECRAN
         Elsif WNBLINCFM=0
           Call ECR_TRACE(mess(441,197,1)-":"-[F:SDH]SDHNUM,0) From GESECRAN
         Else
           Call ECR_TRACE(mess(283,191,1)-":"-[F:SDH]SDHNUM,0) From GESECRAN
         Endif
         # End issue X3-69499

         # Issue X3-69499 - 2018-05-16 by TS
         If [F:SDH]CFMFLG=2
           #Gbn-Fq76563-Edition du BP aprčs validation et attribution du N° définitif (GSDHENDNBR=oui)
           #----- Bon de préparation -----#
           If GSDHENDNBR=2 & [M:DIA]NPRFLG=2 & [M:DIA]NPRNAM<>"" & [M:DIA]NPRDEN<>""
             #----- Code de l'état et nombre de copies -----#
             WARP_RPTCOD(0)= [M:DIA]NPRNAM
             WARP_NBRCPY   = 1
             #----- Ecriture AREPORTM et mŕj indicateur d'impression sur entęte livraison -----#
             Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
             #-----
           Endif

           #----- Bon de livraison -----#
           If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
             #----- Recherche du nouveau code état ŕ partir du modčle -----#
             If [F:BPC]BPCNUM<>[F:SDH]BPCORD
               Read [BPC] BPC0=[F:SDH]BPCORD : If fstat  Raz [F:BPC] : Endif
             Endif
             If [F:BPC]TPMCOD<>""
               If [F:TPM]TPMCOD<>[F:BPC]TPMCOD
                 Read [TPM] TPM0=[F:BPC]TPMCOD : If fstat  Raz [F:TPM] : Endif
               Endif
               If [F:TPM]SALDLV<>""
                 WARP_RPTCOD(0)=[F:TPM]SALDLV
               Else
                 WARP_RPTCOD(0)=[M:DIA]NDENAM
               Endif
             Else
               WARP_RPTCOD(0)=[M:DIA]NDENAM
             Endif
             #----- Nombre de copies -----#
             WARP_NBRCPY=[F:SDH]COPNBR
             #----- Ecriture AREPORTM et mŕj indicateur d'impression sur entęte facture -----#
             Call ALIM_ETAT(2,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
             #-----
           Endif
         # Issue X3-69499 - 2018-05-16 by TS
         Endif

      Endif
      Unlock =SYMBOLE2
   Endif
Endif
Return

#-----------------------------------------------------------------------#
# Traitement du détail livraison                                        #
#-----------------------------------------------------------------------#
$TRT_DETAIL

# Lecture détail cde qte
If [F:SOQ]SOHNUM<>[F:SWD]SOHNUM | [F:SOQ]SOPLIN<>[F:SWD]SOPLIN | [F:SOQ]SOQSEQ<>[F:SWD]SOQSEQ
   Readlock [SOQ]SOQ0 = [F:SWD]SOHNUM; [F:SWD]SOPLIN; [F:SWD]SOQSEQ
   If fstat
      GOK=0
      Call RSTA("SOQ",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)-num$([F:SWD]SOQSEQ)) From GLOCK
      Goto AB_STD
   Endif
Endif
# Lecture détail cde prix
If [F:SOH]SOHCAT = 4
# la ligne article est lue dčs l'entęte
#   Read [SOC]SOC0=[F:SWD]SOHNUM;[F:SWD]SOPLIN
#   If fstat
#      GOK=0
#      Call RSTA("SOC",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)) From GLOCK
#      Goto AB_STD
#   Endif
   # FGR 15/07/2014 : X3SUIVI101369 (début)
   If [F:SOC]SOHNUM <> [F:SWD]SOHNUM or [F:SOC]SOPLIN <> [F:SWD]SOPLIN Then
     Read [SOC]SOC0=[F:SWD]SOHNUM;[F:SWD]SOPLIN
     If fstat
       GOK=0
       Call RSTA("SOC",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)) From GLOCK
       Goto AB_STD
     Endif
   Endif
   # FGR 15/07/2014 : X3SUIVI101369 (fin)
   Raz [F:SOP]
   If [F:SOC]PLI = ""
      Filter [SOP] Where SOHNUM = [F:SWD]SOHNUM & SOPLIN = [F:SWD]SOPLIN &
&                        STRDAT <= [F:SOQ]SHIDAT & ENDDAT >= [F:SOQ]SHIDAT
      Read [SOP]SOP0 First
      If fstat : Raz [F:SOP] : Endif
      Filter [SOP]
   Endif
Else
   Readlock [SOP]SOP0 = [F:SWD]SOHNUM; [F:SWD]SOPLIN; [F:SWD]SOQSEQ
   If fstat
      GOK=0 : Call RSTA("SOP",[F:SWD]SOHNUM-num$([F:SWD]SOPLIN)-num$([F:SWD]SOQSEQ)) From GLOCK : Goto AB_STD
   Endif
Endif
# Lecture article maitre
If [F:ITM]ITMREF <> [F:SOQ]ITMREF
   Read [ITM]ITM0 = [F:SOQ]ITMREF
   If fstat
      GOK=0 : Call RSTA("ITM",[F:SOQ]ITMREF) From GLOCK : Goto AB_STD
   Endif
Endif
# Lecture article-vente
If [F:ITS]ITMREF <> [F:SOQ]ITMREF
   Read [ITS]ITS0 = [F:SOQ]ITMREF
   If fstat : Raz [F:ITS] : Endif
Endif
# Lecture article-client
If ([F:ITU]ITMREF <> [F:SOQ]ITMREF) | ([F:ITU]BPCNUM <> [F:SWD]BPCORD)
   Read [F:ITU]ITU0 = [F:SOQ]ITMREF;[F:SWD]BPCORD
   If fstat  Raz [F:ITU] : Endif
Endif

#-----------------------------------------------#
# Création détail livraison                     #
#-----------------------------------------------#

Call ALICDESDD("1") From TRTVENLIV

If GOK < 1
   Call RAZSTOSORW From STKSOR
   If GOK=0 Goto AB_STD Else Goto ROL_TRT Endif
Endif

# Il n'y a rien ŕ livrer
If [F:SDD]QTYSTU=0
   Goto TRT_DETAIL_FIN
Endif

#-----------------------------------------------#
# Récupération du compteur livraison            #
#-----------------------------------------------#
If WSDHLIN=0
    Gosub REC_CPT_LIV From TRTVENLIV
    If GOK = 0 Goto AB_STD Endif
    If GOK < 0 Goto ROL_TRT Endif
Endif

LIN = LIN+1000
[F:SDD]SDHNUM = [F:SDH]SDHNUM
[F:SDD]SDDLIN = LIN

If dim([F:SDD]CPY)>0 : [F:SDD]CPY=GSOCIETE : Endif

Write [SDD]
If fstat
   Call RAZSTOSORW From STKSOR
   GOK=0 : Call FSTA("SDD") From GLOCK : Goto AB_STD
Endif

#-----------------------------------------------#
# Maj détail commande, en-cours et allocations  #
#-----------------------------------------------#
Call MAJDETCDE("1",WDLRNOT,WDLRATI,WCPE_SOQSTA) From TRTVENLIV

If GOK < 1
   Call RAZSTOSORW From STKSOR
   If GOK=0 Goto AB_STD Else Goto ROL_TRT Endif
Endif

Gosub MAJSDD_CPTANALIN From TRTVENLIV
If GOK=0 Goto AB_STD Endif

WSOHLIN += 1
WSDHLIN += 1

# Dans la valorisation TTC, on passe par les classes écrans, il faut les charger
nolign = WSDHLIN
[M:SDH1] = [F:SDD]
[M:SDH1]VACITM1(nolign-1) = [F:SDD]VACITM(0)
[M:SDH1]VACITM2(nolign-1) = [F:SDD]VACITM(1)
[M:SDH1]VACITM3(nolign-1) = [F:SDD]VACITM(2)
[M:SDH1]VAT1(nolign-1)    = [F:SDD]VAT(0)
[M:SDH1]VAT2(nolign-1)    = [F:SDD]VAT(1)
[M:SDH1]VAT3(nolign-1)    = [F:SDD]VAT(2)
[M:SDH1]NBLIG += 1

#-----------------------------------------------#
# Cumul et alimentation zones entęte livraison  #
#-----------------------------------------------#
Call ALICUMSDH(2) From TRTVENLIV    : # Bug 82078 : Ajout origine de la livraison

# Trace détail commande pris en compte dans la livraison
#    article xxx xxxx quantité livrée xxx reste ŕ livrer xxx
Local Decimal WWQTY
WWQTY = [F:SOQ]QTY - ([F:SOQ]ODLQTY+[F:SOQ]DLVQTY)
Call ECR_TRACE("          "+mess(18,007,1)-[F:SDD]ITMREF-[F:SDD]ITMDES1+
&    "     "+mess(40,191,1)-num$([F:SDD]QTY)-mess(41,191,1)-num$(WWQTY),0)
&    From GESECRAN

# Point d'entrée aprčs création ligne détail livraison
GPOINT="AUTDLVDET" : Gosub ENTREE From EXEFNC
If GOK = 0  Goto AB_STD  Endif
If GOK < 0  Goto ROL_TRT  Endif

# Issue 109784 - 2015-08-06 by CPO : Following 107712, Bad update in SDELIVERYD using FUNPREDLV
#--Le transclasse va initialiser les champs DSPTOTQTY/DSPTOTWEI/DSPTOTVOL avec les valeurs inscrite dans le SQH
#--On doit les Raz car ces champs seront mis ŕ jour dans les ss-pros appelés lors de création de SDD (également corrigés)
#--suite
[F:SDH]DSPTOTQTY += [F:SDD]QTYSTU
[F:SDH]DSPTOTWEI += [F:SDD]DSPLINWEI
[F:SDH]DSPTOTVOL += [F:SDD]DSPLINVOL
# End issue 109784

# Transfert des elements de facturation
Local Char SVGGREP(type(GREP)-10)
SVGGREP=GREP
GREP="C"
Gosub SOH_SDH_PLUS From SUBSFIT
#If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  GOK = 0
  GREP = SVGGREP
  Goto AB_STD
Endif
# 96235
#Call MAJ_SFIT_QTY("F", "SDH", [F:SDH]SOHNUM, [F:SDD]QTYSTU, [F:SDD]NETPRINOT * [F:SDD]QTY, [F:SDD]DSPLINWEI, [F:SDD]DSPLINVOL) From SUBSFIT
Call MAJ_SFIT_QTY("F", "SDH", [F:SDD]SOHNUM, [F:SDD]QTYSTU, [F:SDD]NETPRINOT * [F:SDD]QTY, [F:SDD]DSPLINWEI, [F:SDD]DSPLINVOL) From SUBSFIT
# 96235
GREP=SVGGREP

$TRT_DETAIL_FIN
Call RAZSTOSORW From STKSOR

Return

#-----------------------------------------------------------------------#
# Traitement d'entęte commande                                          #
#-----------------------------------------------------------------------#
$SOH_DEB
Raz WDLRNOT, WDLRATI
Raz WSOHLIN

# Lecture entęte commande
Readlock [SOH]SOH0 = [F:SWD]SOHNUM
If fstat
   GOK=0 : Call RSTA("SOH",[F:SWD]SOHNUM) From GLOCK : Goto AB_STD
Endif

WDME=[F:SOH]DME : WSOHNUM=[F:SOH]SOHNUM

# Alimentation elements pied facture
#--CPO 106895 Lors du traitement de cette fiche
#--Le ALIMFOOT2 se base sur les anciens champs de transferts V5, non utilisés ŕ partir de la V6
#--Ce qui était fait dans ALIMFOOT2 est fait maintenant ds DETAIL par appel SxH_SxH_PLUS
#NBPOSTE = dim([F:SDH]INVDTA)
#Call ALIMFOOT2 (4,NBPOSTE,[F:SDH]CHGTYP,[F:SOH]CUR,[F:SDH]CUR,"NON") From SUBSFIT
#--/

Return

#-----------------------------------------------------------------------#
# Traitement de fin de commande                                         #
#-----------------------------------------------------------------------#
$SOH_FIN

# Maj entęte commande
Call MAJENTCDE (WDLRNOT,WDLRATI) From TRTVENLIV
If GOK = 0 Goto AB_STD  Endif
If GOK < 0 Goto ROL_TRT  Endif

# Maj sf si commande ouverte ou commande intra-société
If [F:SOH]SOHCAT<>4 & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
    # Maj mouvement client (en commande)
    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&                WDLRNOT, WDLRATI, "-", "F", "", [F:SOH]SOHCAT) From TRTBPMVT
    If GOK = 0 Goto AB_STD  Endif
    If GOK < 0 Goto ROL_TRT  Endif
Endif

# Trace entęte commande : commande xxxx
Call ECR_TRACE("     "+mess(10,159,1)-[F:SOH]SOHNUM,0) From GESECRAN

Return

#-----------------------------------------------------------------------#
# Verification lignes disponibles pour nouvelles commandes              #
#-----------------------------------------------------------------------#
$VERIF_LIN
# Calcul du nb de ligne de la commande
WLIN = 0
LINFLG = 1
If !clalev([F:SWD2]) : Local File SWRKDLV [SWD2] : Endif
For [SWD2]SWD0 Where PRONUM  = adxuid(1)
&                 & SWDKEY   = [F:SWD]SWDKEY
&                 & SWDDATA  = [F:SWD]SWDDATA
&                 & SWDDATA2 = [F:SWD]SWDDATA2
&                 & SOHNUM   = [F:SWD]SOHNUM
    WLIN += 1
Next

# Contrôle lignes dispo. pour nouvelle cde
If WLIN > WSDHACV - WSDHLIN
   LINFLG = 0
Endif
Return
#########################################################################
$VERIF_ESIGN
# Issue X3-135097 - 2019-05-27 by ANKUL
If OK = 2 and func AFNC.ACTIV('KPO') > 0 and func PORLEGLIB.PORLEG([F:SOH]SALFCY,"") = 1 and func PORLEGLIB.DIGSIGN([F:SOH]SALFCY, "")
  If [F:SOH]SOHCFMFLG <> 2
    Call ECR_TRACE(func AFNC.MES1(mess(7,2100,1),[F:SOH]SOHNUM),1) From GESECRAN
    OK=1 : Return
  Endif
Endif
# Issue X3-135097 - 2019-05-27 by ANKUL : end

Return
########################################
#     traitement des erreurs           #
########################################
$ROL_CHGFIC
Rollback
Call ROLL From GLOCK
If GROLL
   Call ECR_TRACE(mess(17,107,1),1)From GESECRAN
Else
   Goto CHGFIC
Endif
Return

$ROL_TRT
Rollback
WTRBEGIN = 0
GIMPORT=1
Call ROLL From GLOCK
GIMPORT=0
If GROLL
   If WSDHLIN>0
       Call ECR_TRACE("     "+mess(10,159,1)-[F:SWD]SOHNUM,0) From GESECRAN
       Call ECR_TRACE(mess(210,191,1)-"\"-mess(17,107,1),1)From GESECRAN
   Else
       Call ECR_TRACE(mess(17,107,1),1)From GESECRAN
   Endif
Else
   Goto TRTENT
Endif
Return

$AB_STD
Rollback
WTRBEGIN = 0
If WSDHLIN>0
    Call ECR_TRACE("     "+mess(10,159,1)-[F:SWD]SOHNUM,0) From GESECRAN
    Call ECR_TRACE(mess(210,191,1)-"\"-mess(17,107,1),1)From GESECRAN
Else
    Call ECR_TRACE(mess(17,107,1),1)From GESECRAN
Endif
# Issue 116639 - 2016-07-12 by ERMIL : call no longer needed here with new changes
# 78411 Sage Exchange
#If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
#  Call POST_AUTH(2,[F:SDH]SOHNUM,SEERR,SEMESSAGE) From SEPPLIB
#Endif
Return

#########################################################################
# Actions champs                                                        #
#########################################################################

######################################## Obligatoire
Subprog AM_SOHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SOHNUMFIN = VALEUR : Endif
End

######################################## Obligatoire
Subprog AM_BPCORDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   [M]BPCORDFIN = VALEUR
   Actzo [M]BPAADDDEB
Else
   Diszo [M]BPAADDDEB
Endif
End

######################################## Obligatoire
Subprog AM_BPAADDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]BPAADDFIN = VALEUR : Endif
End

######################################## Obligatoire
Subprog AP_BPCORDFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Actzo [M]BPAADDFIN
Else
   Diszo [M]BPAADDFIN
Endif
End

######################################## Obligatoire
Subprog C_BPAADDFIN(VALEUR)
Variable Char    VALEUR()
If [M]BPCORDDEB = [M]BPCORDFIN
   If VALEUR  < [M]BPAADDDEB
      GMESSAGE = mess(44,199,1) : mkstat = 2
   Endif
Endif
End

######################################## Obligatoire
Subprog AM_BPTNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]BPTNUMFIN = VALEUR : Endif
End

######################################## Obligatoire
Subprog AP_DRNFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 1
    [M]DRN=0
    Diszo [M]DRN
  Else
    # FGR 23/06/2015 : X3SUIVI109066 (début)
    #[M]DRN=1
    If [M]DRN = 0 Then
      [M]DRN = 1
    Endif
    # FGR 23/06/2015 : X3SUIVI109066 (fin)
   Actzo [M]DRN
  Endif
  Affzo [M]DRN
End
########################################
Subprog AP_CFMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   [M]NDEFLG=1
   Raz [M]NDENAM, [M]NDEDEN, [M]NDEIMP, [M]NDESRV
   Diszo [M]NDEFLG, NDENAM, NDEDEN
   Affzo [M]NDEFLG, NDENAM, NDEDEN, NDEIMP, NDESRV
Else
   Actzo [M]NDEFLG, NDENAM, NDEDEN
Endif
End
########################################
Subprog AP_NPRFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Raz [M]NPRNAM, [M]NPRDEN, [M]NPRIMP, [M]NPRSRV
   Diszo [M]NPRNAM, NPRDEN
Else
   If vireblc([M]NPRNAM,2)=""
#      Call INIT_IMP("SDH", [M]NPRNAM, [M]NPRIMP) From TRTVENIMP
      Call INIT_ARP("SDH", [M]NPRNAM) From TRTVENIMP
      Actzo [M]NPRNAM, NPRDEN
   Endif
Endif
Affzo [M]NPRNAM, NPRDEN, NPRSRV, NPRIMP
End
########################################
Subprog C_NPRNAM(VALEUR)
Variable Char    VALEUR()
Local    Char    AUTSIT(10)
Local    Integer OK
# Document obligatoire si impression bon de preparation
