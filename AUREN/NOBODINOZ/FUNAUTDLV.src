######################################################################################
## Section automatically added (screen SAD1) 07/03/2014 16:17:18 (RICAR)
######################################################################################
Subprog AM_ENA(VALEUR)
Variable Integer VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
Local File     FACILITY [FCY]

If VALEUR = 1
  Raz   [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
  Diszo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
  Effzo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
Else
  If [M:DIA]CFMFLG = 2
    Actzo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
    Read [FCY]FCY0=[M:DIA]STOFCY
    If !fstat
      [M:DIA]STRHOU = [F:FCY]STRHOU
      [M:DIA]ENDHOU = [F:FCY]ENDHOU
      Affzo [M:DIA]STRHOU,ENDHOU

      Close File [FCY]
    Endif
  Else
    Call ERREUR(mess(97,7711,1)) From GESECRAN
    mkstat=1
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog D_STRDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]STRDAYS
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog C_STRDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If VALEUR<0
  Call ERREUR(mess(100,7711,1)) From GESECRAN
  mkstat=2
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog D_ENDDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]ENDDAYS
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog C_ENDDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If VALEUR<0
  Call ERREUR(mess(100,7711,1)) From GESECRAN
  mkstat=2
Elsif VALEUR<[M:DIA]STRDAYS
  Call ERREUR(mess(99,7711,1)) From GESECRAN
  mkstat=2
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog D_STRHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]STRHOU
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog C_STRHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
Local Shortint LOK
Local Char     LHOUR
Local Char     LHOURINT : [L]LHOURINT = VALEUR

If [M:DIA]ENA=2
  If VALEUR<>''
      Call CTRL_HOU([L]LHOURINT,[L]LHOUR,[L]LOK) From PORLEGLIB
      If LOK=1
        mkstat = 2
      Else
         VALEUR       = [L]LHOUR
      Endif
  Else
      Call ERREUR(mess(94,7711,1)) From GESECRAN
      mkstat = 2
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog D_ENDHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]ENDHOU
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
Local Shortint LOK
Local Char     LHOUR
Local Char     LHOURINT : [L]LHOURINT = VALEUR

Local File     FACILITY [FCY]

If [M:DIA]ENA=2
  If VALEUR<>''
      Call CTRL_HOU([L]LHOURINT,[L]LHOUR,[L]LOK) From PORLEGLIB
      If LOK=1
        mkstat  = 2
      Else
         VALEUR = [L]LHOUR
      Endif
  Else
      Read [FCY]FCY0=[M:DIA]STOFCY
      If !fstat
        [M:DIA]ENDHOU = [F:FCY]ENDHOU
        Affzo [M:DIA]ENDHOU
        If [M:DIA]ENDHOU = ''
          Call ERREUR(mess(94,7711,1)) From GESECRAN
          mkstat = 2
        Endif
      Else
        Call ERREUR(mess(94,7711,1)) From GESECRAN
        mkstat = 2
      Endif
  Endif

  If VALEUR<>''& VALEUR <> '0000' & VALEUR <> '00:00'
    If [M:DIA]STRDAYS=[M:DIA]ENDDAYS & VALEUR<[M:DIA]STRHOU
      Call ERREUR(mess(98,7711,1)) From GESECRAN
      mkstat = 2
    Endif
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End

######################################################################################

$WEBSERVICE_ERROR

  # Issue 116639 An error occurred with either SE or SST.
  # Since those calls are outside of the transaction, can't just do a rollback
  # Have to delete the shipment here
  Local Integer OK
  Local Char PARAM2(10)(1), SAVREP(1), DELSDHNUM(20), WSMESS(255)
  If !clalev([F:SDD1]) : Local File SDELIVERYD [SDD1] : Endif
  If !clalev([F:PRH])  : Local File STOPREH    [PRH]  : Endif
  If !clalev([F:PRE])  : Local File STOPRED    [PRE]  : Endif
  If !clalev([F:ITV])  : Local File ITMMVT     [ITV]  : Endif
  If !clalev([M:ORDK]) : Local Mask ORDK       [ORDK] : Endif

  Global Integer GALLORD
  GALLORD=GRSTALLORD
  If GRSTALLORD = 3 & sum([M:SDH1]OALQTYSTU) <> 0
    GALLORD=1
  Endif
  # The deletion uses another screen of the same abbreviation.
  # So create a copy of DIA and close it.  At the end - reopen
  If !clalev([M:DIAP]) : Local Mask SAD1 [DIAP] : [M:DIAP] = [M:DIA] : Endif

  Close Mask [DIA]

  SAVREP=GREP : GREP="A": DELSDHNUM = [F:SDH]SDHNUM
  [L]OK=-9 : Raz [L]PARAM2 : # Don't ask for confirmation
  Call ANUCOD("SDH",DELSDHNUM,PARAM2,OK) From GOBJACT
  GREP=SAVREP
  # did we come from SST or SE?
  If dim([L]SSTERR)>0 & [L]SSTERR
    WSMESS = func AFNC.MES2(mess(524,192,1),mess(25,159,1),DELSDHNUM)
  Else
    WSMESS = func AFNC.MES2(mess(59,2092,1),mess(25,159,1),DELSDHNUM)
  Endif
  Call ECR_TRACE(WSMESS, 1) From GESECRAN

  # Close the new DIA (if applicable), and re-open ours and copy back.
  If clalev([M:DIA]) : Close Mask [DIA] : Endif
  Local Mask SAD1 [DIA]
  [M:DIA] = [M:DIAP]
  GOK = 0 #JOBRO.n - we need to set GOK so it won't try to validate the deleted delivery
Return

