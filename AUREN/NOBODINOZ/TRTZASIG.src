#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : TRTZASIG
# Description : Tarea batch Correcciˇn de asignaciones
# Module      : Supervisor
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espa˝a
# Created date: 18/08/2021
############################################################################
Gosub INIT
Gosub EXEC
Gosub TERMINE

End

$ACTION

Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase

Return
#####################################################################################################
$INIT
#####################################################################################################
Local Char MOD_UBI(5) : MOD_UBI = "36" # Ubicaciˇn modula
If !clalev([F:SOQ])     : Local File SORDERQ[SOQ]    : Endif
If !GSERVEUR & GTRACE=""
  Call OUVRE_TRACE("Tarea batch Correcciˇn de asignaciones "+num$(adxuid(1))) From LECFIC
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return

#####################################################################################################
$EXEC
#####################################################################################################
Gosub CASO1
#Gosub CASO2
Return

#####################################################################################################
$CASO1 #RUPTURAS PEDIDOS INCOHERENTES SIN ASIGNACION
#####################################################################################################
Local Char WSQL_CMD(250)(1..5) :Raz WSQL_CMD
Call ECR_TRACE(string$(35,"-") +" CASO 1 "+string$(35,"-"),0) From GESECRAN
Local Integer CONT:Raz CONT
WSQL_CMD(1) = "SELECT SOQ.STOFCY_0, SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.ITMREF_0"
WSQL_CMD(2) = " FROM NBZLIVE.SORDERQ SOQ LEFT OUTER JOIN (SELECT * FROM NBZLIVE.STOALL Where ALLTYP_0=4 and VCRTYP_0=2) RUPT "
WSQL_CMD(3) = " ON SOQ.SOHNUM_0 = RUPT.VCRNUM_0 AND SOQ.SOPLIN_0 = RUPT.VCRLIN_0 AND SOQ.SOQSEQ_0 = RUPT.VCRSEQ_0"
WSQL_CMD(4) = " WHERE  (ISNULL(RUPT.QTYSTUACT_0,0) <> SOQ.SHTQTY_0 OR ISNULL(RUPT.QTYSTUACT_0,0) <> SOQ.SHTQTYSTU_0) AND ISNULL(RUPT.QTYSTUACT_0,0)>=0"
#WSQL_CMD(5) = " AND SOQ.ALLQTY_0 = 0 AND SOQ.ALLQTYSTU_0 = 0"


For (Char STOFCY, Char SOHNUM, Integer SOPLIN, Char ITMREF) From num$((GTYPDBA*2)+1)  Sql WSQL_CMD As [SQL_ASIG]
#Infbox "Pedido: "+[SQL_ASIG]SOHNUM+ " Linea: "+num$([SQL_ASIG]SOPLIN)+" Articulo: "+[SQL_ASIG]ITMREF
  Call UPD_DEASIG_SOH([SQL_ASIG]STOFCY,[SQL_ASIG]SOHNUM,[SQL_ASIG]SOPLIN,[SQL_ASIG]SOPLIN)
  Call RESINCRO_ITM([SQL_ASIG]STOFCY,[SQL_ASIG]ITMREF)
  Call UPD_ASIG_SOH([SQL_ASIG]STOFCY,[SQL_ASIG]SOHNUM,[SQL_ASIG]SOPLIN,[SQL_ASIG]SOPLIN)
  Call ECR_TRACE("Pedido: "+[SQL_ASIG]SOHNUM+ " Linea: "+num$([SQL_ASIG]SOPLIN)+" Articulo: "+[SQL_ASIG]ITMREF,0) From GESECRAN
Next

Return


#####################################################################################################
$CASO2 #ASIGNACIONES PEDIDOS INCOHERENTES
#####################################################################################################
Local Char WSQL_CMD(250)(1..5) :Raz WSQL_CMD
Call ECR_TRACE(string$(35,"-") +" CASO 2 "+string$(35,"-"),0) From GESECRAN
WSQL_CMD(1) = "SELECT SOQ.STOFCY_0, SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.ITMREF_0"
WSQL_CMD(2) = " FROM NBZLIVE.SORDERQ SOQ LEFT OUTER JOIN (SELECT * FROM NBZLIVE.STOALL Where ALLTYP_0=2 and VCRTYP_0=2) ASIG "
WSQL_CMD(3) = " ON SOQ.SOHNUM_0 = ASIG.VCRNUM_0 AND SOQ.SOPLIN_0 = ASIG.VCRLIN_0 AND SOQ.SOQSEQ_0 = ASIG.VCRSEQ_0"
WSQL_CMD(4) = " WHERE  ISNULL(ASIG.QTYSTU_0,0) <> SOQ.ALLQTY_0 or ISNULL(ASIG.QTYSTUACT_0,0) <> SOQ.ALLQTYSTU_0"


For (Char STOFCY, Char SOHNUM, Integer SOPLIN, Char ITMREF) From num$((GTYPDBA*2)+1)  Sql WSQL_CMD As [SQL_ASIG]
  Call UPD_DEASIG_SOH([SQL_ASIG]STOFCY,[SQL_ASIG]SOHNUM,[SQL_ASIG]SOPLIN,[SQL_ASIG]SOPLIN)
  Call RESINCRO_ITM([SQL_ASIG]STOFCY,[SQL_ASIG]ITMREF)
  Call UPD_ASIG_SOH([SQL_ASIG]STOFCY,[SQL_ASIG]SOHNUM,[SQL_ASIG]SOPLIN,[SQL_ASIG]SOPLIN)
  Call ECR_TRACE("Pedido: "+[SQL_ASIG]SOHNUM+ " Linea: "+num$([SQL_ASIG]SOPLIN)+" Articulo: "+[SQL_ASIG]ITMREF,0) From GESECRAN
Next

Return
#####################################################################################################
$TERMINE
#####################################################################################################

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

If !GSERVEUR & GTRACE=""
  Call FERME_TRACE From LECFIC
Endif
Return

#####################################################################################################
#####################################################################################################

Subprog UPD_DEASIG_SOH(FCY,NUM,LIN,SEQ)
Value Char NUM,FCY
Value Integer LIN,SEQ
Local Integer FGSERVEUR : FGSERVEUR=GSERVEUR
GSERVEUR = 1
Gosub INIT From FUNDESALL
[M:DIA]STOFCY = FCY
[M:DIA]SHIDAT = date$
[M:DIA]SOHNUMDEB = NUM
[M:DIA]SOHNUMFIN = NUM
[M:DIA]ALLCRITENT = "[F:SOQ]SOPLIN="+ num$(LIN)
Gosub EXEC From FUNDESALL
Gosub TERMINE From FUNDESALL
GSERVEUR = FGSERVEUR
End

Subprog RESINCRO_ITM(FCY,IITMREF)
Value Char FCY,IITMREF
Local Integer FGSERVEUR : FGSERVEUR=GSERVEUR
GSERVEUR = 1
Gosub TRT_INI From FUNSTOR
Gosub INIT_DIA_SYNSTO From FUNSTOR
[M:STOR]STOFCY = FCY
[M:STOR]SYNSTO  = 2
[M:STOR]SYNITV   = 2
[M:STOR]ITMREFSTR  = IITMREF
[M:STOR]ITMREFEND  = IITMREF
Gosub EXEC_SYNSTO From FUNSTOR
Gosub TERMINE_SYNSTO From FUNSTOR
Gosub END_SYNSTO From FUNSTOR
GSERVEUR = FGSERVEUR
End

Subprog UPD_ASIG_SOH(FCY,NUM,LIN,SEQ)
Value Char NUM,FCY
Value Integer LIN,SEQ
Local Integer FGSERVEUR : FGSERVEUR=GSERVEUR
Local Char PARAM(60)(7)
PARAM(1) = FCY
PARAM(2) = date$
PARAM(3) = NUM
PARAM(6) = "[F:SOQ]SOPLIN="+ num$(LIN)
GSERVEUR = 1
Gosub INIT From FUNAUTALL
Gosub EXEC From FUNAUTALL
Gosub TERMINE From FUNAUTALL
GSERVEUR = FGSERVEUR
End
