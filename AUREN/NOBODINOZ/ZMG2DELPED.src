#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAM ZMG2DELPED: Borrado pedidos                                                                  ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 26/04/2022                                                                                    ##
## VERSION: 1.0                                                                                         ##
##########################################################################################################
## Lista ficheros a exportar:     Vista para exportación:                                               ##
## - Pedidos                      ZMGDELPED                                                             ##
##########################################################################################################
 Gosub INIT
 Gosub EXEC
 Gosub TERMINE
End
$ACTION
Case ACTION
  When "INIT"     : Gosub INIT
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(250)
  Local Char LPATH(250)
  Local Char LPATHP(250)
  Local Integer STAT
  Local Integer FLAG

  Local Char FECHOREJEC(15)
  Local Char NOMFIC_ZPED(250)



  Local Integer     TIPEXP          #Tipo exportación completa/Parcial -> 1=Parcial, 2=Completa
  Local Char        ULTEXP(30)      #Fecha última exportación anterior fichero
  Local Char        NEWULTEXP(30)   #Nueva fecha exportación

  adxifs=";"
  adxirs=chr$(013)+chr$(010)
  adxium=0

  #Check if local directory exists and creates it if not
  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  LPATH=DIRAPL+"\FTP\Magento\EXPORT\PedidosB2B"
  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

  LPATHP=DIRAPL+"\FTP\Magento\EXPORT\PedidosB2B\PROCESADOS"

  NEWULTEXP=    format$("YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", datetime$)

  #Definicion nombres de fichero a generar
  FECHOREJEC=   format$("YYYYMMDDhhmmss",date$)
  NOMFIC_ZPED=  "PedidosClean-"            + FECHOREJEC

  ## Apertura vistas de los datos a exportar

  If clalev([F:ZMGDPED])<=0   :   Local File ZMGDELPED[ZMGDPED]  :   Endif

Return

$EXEC
  ## Generar ficheros en folder local
  Gosub DELPEDIDOS
  If !FLAG
    Call ECR_TRACE("Nada para enviar", 0) From GESECRAN
    Return
  Endif
# Subida de ficheros al FTP y mueve fiheros subidos a directorio de copia
  Call ECR_TRACE("Subiendo ficheros", 0) From GESECRAN
  STAT = 0
  Call FTPPUTMOV("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","SAGE_TO_MG/PedidosB2B",LPATH,LPATHP,STAT) From ZAURFTP

  If STAT >= 0
    Call ECR_TRACE("Ficheros subidos: " +num$(STAT), 0) From GESECRAN
  Else
    Call ECR_TRACE("Error en la subida de ficheros. Error: " +num$(STAT), 1) From GESECRAN
  Endif

#Proceso terminado
  Call ECR_TRACE("Proceso terminado " + format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$), 0) From GESECRAN

Return

$TERMINE

Return

###########################################
##             DELPEDIDOS             ##
###########################################
$DELPEDIDOS

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando fichero DELPEDIDOS...",0) From GESECRAN

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  Call TIPO_EXPORTACION('DELPEDIDOS', TIPEXP, ULTEXP)

  FLAG = 0

  ## Lectura datos y escritura del fichero
  If TIPEXP=1
    Filter [F:ZMGDPED] Where UPDATE_TS >= ULTEXP

  Endif
  For [F:ZMGDPED]

    If FLAG=0 Then
      Openo filpath(LPATH+"\",NOMFIC_ZPED,"csv"), 0 Using [CSV]
      FLAG = 1
    Endif
    Wrseq [F:ZMGDPED]PEDIDO Using [CSV]

  Next

  ## Cierre fichero
  Openo Using [CSV]

  Call UPD_EXPORTACION('DELPEDIDOS', NEWULTEXP)
  If FLAG = 1 :Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + NOMFIC_ZPED + ".csv generado",0) From GESECRAN Endif

Return

######################################################
##  TIPO EXPORTACIÓN - ULTIMA EXPORTACIÓN FICHERO   ##
######################################################
Subprog TIPO_EXPORTACION(FICH, TIPEXP, ULTEXP)
Value Char         FICH
Variable Integer   TIPEXP
Variable Char      ULTEXP

  ## Apertura tabla varia 6030 - Control exportación completa/parcial y fecha última exportación
  If clalev([F:ZADI])<=0  :   Local File ATABDIV      [ZADI]  :   Endif

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  TIPEXP=0
  ULTEXP=""
  Filter [ZADI] Where NUMTAB=6030 and CODE=FICH
  For [ZADI]
    TIPEXP=[F:ZADI]N1
    ULTEXP=[F:ZADI]A1
  Next
  If TIPEXP=0   :   TIPEXP=2  : Endif

End

######################################################
##  GUARDAR ULTIMA EXPORTACIÓN FICHERO              ##
######################################################
Subprog UPD_EXPORTACION(FICH, NEWULTEXP)
Value Char    FICH
Value Char    NEWULTEXP

  ## Apertura tabla varia 6020 - Control exportación completa/parcial y fecha última exportación
  If clalev([F:ZADI])<=0  :   Local File ATABDIV      [ZADI]  :   Endif

  # Actualizar fecha última extraccion datos del fichero
  Update [F:ZADI] Where NUMTAB=6030 and CODE=FICH With A1=NEWULTEXP

End

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
