#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"            : Gosub OUVRE
  When "TITRE"            : Gosub TITRE_
  When "LECTURE"          : Gosub LECTURE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Global Integer GCONTROL
Return

##############################################################
$TITRE_
#  Gosub INS_FILTERS
Return

##############################################################
$LECTURE
  If GCONTROL = 0 Then
    GCONTROL = 1
  Else
    Gosub SEARCH
  Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$INS_FILTERS
  If !clalev([F:ZITM]) Then : Local File ITMMASTER [F:ZITM] : Endif
  If !clalev([F:ZWRH]) Then : Local File WAREHOUSE [F:ZWRH] : Endif

  # art兤ulo inicio
  Read [ZITM] First
  [M:ZCFVE0]ZINIITM = [F:ZITM]ITMREF
  Affzo [M:ZCFVE0]ZINIITM

  # art兤ulo fin
  Read [ZITM] Last
  [M:ZCFVE0]ZFINITM = [F:ZITM]ITMREF
  Affzo [M:ZCFVE0]ZFINITM

  # almac駭 inicio
  Read [ZWRH] First
  [M:ZCFVE0]ZINIWRH = [F:ZWRH]WRH
  Affzo [M:ZCFVE0]ZINIWRH

  # almac駭 fin
  Read [ZWRH] Last
  [M:ZCFVE0]ZFINWRH = [F:ZWRH]WRH
  Affzo [M:ZCFVE0]ZFINWRH

  Close Local File [ZITM],[ZWRH]
Return

##############################################################
$SEARCH
Local Clbfile LSQL(1)(1..32)
Local Integer I

  Raz [M:ZCFVE1]

  LSQL(1)   = "SELECT ITM.ITMREF_0,ITM.ITMDES1_0,ISNULL(WRH.WRH_0,'') AS WRH,ISNULL(QTY_SID.QUANTITY_SID,0) As CTD_SIH,ISNULL(QTY_SMD.QUANTITY_SMD,0) As CTD_ES "
  LSQL(2)   = "From "+nomap+".ITMMASTER ITM LEFT OUTER JOIN "+nomap+".WAREHOUSE WRH ON 1=1 LEFT OUTER JOIN "
  LSQL(3)   = "( "
  LSQL(4)   = "SELECT SMD.ITMREF_0,SMD.ITMDES1_0,SMD.WRH_0,sum(SMD.QUANTITY_SMD2) As QUANTITY_SMD "
  LSQL(5)   = "From "
  LSQL(6)   = "( "
  LSQL(7)   = "SELECT SMD2.VCRNUM_0,SMD2.ITMREF_0,SMD2.ITMDES1_0,SMD2.WRH_0, "
  LSQL(8)   = "Case SMD2.VCRTYP_0 "
  LSQL(9)   = "When 19 Then SMD2.QTYPCU_0 "
  LSQL(10)  = "When 20 Then (SMD2.QTYPCU_0*-1) "
  LSQL(11)  = "Else 0 "
  LSQL(12)  = "End As QUANTITY_SMD2 "
  LSQL(13)  = "From "+nomap+".SMVTD SMD2 "
  LSQL(14)  = "INNER JOIN "+nomap+".SMVTH SMH2 ON SMH2.VCRNUM_0 = SMD2.VCRNUM_0 "
  LSQL(15)  = "Where (SMD2.VCRTYP_0 = 19 or SMD2.VCRTYP_0 = 20) "
  LSQL(16)  = "and SMH2.IPTDAT_0 BETWEEN CONVERT(DATETIME, '"+num$(year([M:ZCFVE0]ZINIMOVDAT))+"-"+num$(month([M:ZCFVE0]ZINIMOVDAT))+"-"+num$(day([M:ZCFVE0]ZINIMOVDAT))+" 00:00:00', 102) "
  LSQL(16) += "and CONVERT(DATETIME, '"+num$(year([M:ZCFVE0]ZFINMOVDAT))+"-"+num$(month([M:ZCFVE0]ZFINMOVDAT))+"-"+num$(day([M:ZCFVE0]ZFINMOVDAT))+" 00:00:00', 102) "
  LSQL(17)  = ") As SMD "
  LSQL(18)  = "GROUP By SMD.ITMREF_0,SMD.ITMDES1_0,SMD.WRH_0 "
  LSQL(19)  = ") As QTY_SMD ON QTY_SMD.ITMREF_0 = ITM.ITMREF_0 AND QTY_SMD.WRH_0 = WRH.WRH_0 "
  LSQL(20)  = "LEFT OUTER JOIN "
  LSQL(21)  = "( "
#  LSQL(22)  = "SELECT SID.ITMREF_0,SID.ZWRH_0,sum(SID.QTY_0) As QUANTITY_SID "
#  LSQL(23)  = "From "+nomap+".SINVOICED SID "
  LSQL(22)  = "SELECT SID.ITMREF_0,SID.ZWRH_0,sum(CASE WHEN SIH.INVTYP_0=2 THEN SID.QTY_0*(-1) ELSE SID.QTY_0 END) As QUANTITY_SID "
  LSQL(23)  = "From "+nomap+".SINVOICE SIH INNER JOIN "+nomap+".SINVOICED SID ON SID.NUM_0 = SIH.NUM_0"
  LSQL(24)  = "Where SID.INVDAT_0 BETWEEN CONVERT(DATETIME, '"+num$(year([M:ZCFVE0]ZINIFACDAT))+"-"+num$(month([M:ZCFVE0]ZINIFACDAT))+"-"+num$(day([M:ZCFVE0]ZINIFACDAT))+" 00:00:00', 102) "
  LSQL(24) += "and CONVERT(DATETIME, '"+num$(year([M:ZCFVE0]ZFINFACDAT))+"-"+num$(month([M:ZCFVE0]ZFINFACDAT))+"-"+num$(day([M:ZCFVE0]ZFINFACDAT))+" 00:00:00', 102) "
  LSQL(25)  = "GROUP By SID.ITMREF_0,SID.ZWRH_0 "
  LSQL(26)  = ") As QTY_SID "
  LSQL(27)  = "ON QTY_SID.ITMREF_0 = ITM.ITMREF_0  and WRH.WRH_0 = QTY_SID.ZWRH_0 "
  LSQL(28)  = "Where 1=1 AND (ISNULL(QTY_SID.QUANTITY_SID,0)<>0 AND ISNULL(QTY_SMD.QUANTITY_SMD,0)<>0) "
  If [M:ZCFVE0]ZINIITM <> "" Then
    LSQL(29)= "and ITM.ITMREF_0 >= '"+[M:ZCFVE0]ZINIITM+"'"
  Endif
  If [M:ZCFVE0]ZFINITM <> "" Then
    LSQL(30)= "and ITM.ITMREF_0 <= '"+[M:ZCFVE0]ZFINITM+"'"
  Endif
  If [M:ZCFVE0]ZINIWRH <> "" Then
    LSQL(31)= "and WRH.WRH_0 >= '"+[M:ZCFVE0]ZINIWRH+"'"
  Endif
  If [M:ZCFVE0]ZFINWRH <> "" Then
    LSQL(32)= "and WRH.WRH_0 <= '"+[M:ZCFVE0]ZFINWRH+"'"
  Endif

#For I=1 To 32
#  Infbox LSQL(I)
#Next

  For (Char LITMREF(250),Char LITMDES(250),Char LWRH,Decimal LCTDSIH,Decimal LCTDES) From "5" Sql LSQL(1..32) As [Z00]
    [M:ZCFVE1]ITMREF(I)   = [F:Z00]LITMREF
    [M:ZCFVE1]ITMDES(I)   = [F:Z00]LITMDES
    [M:ZCFVE1]ZQTYFAC(I)  = [F:Z00]LCTDSIH
    [M:ZCFVE1]ZQTYMOV(I)  = [F:Z00]LCTDES
    [M:ZCFVE1]WRH(I)      = [F:Z00]LWRH
    I                    += 1
  Next
  [M:ZCFVE1]NBLIG = I
  Affzo [M:ZCFVE1]

  For I=0 To [M:ZCFVE1]NBLIG-1
    If [M:ZCFVE1]ZQTYFAC(I) = -1*[M:ZCFVE1]ZQTYMOV(I) Then : Chgstl [M:ZCFVE1]NBLIG(I) With ""           : Endif
    If [M:ZCFVE1]ZQTYFAC(I) > -1*[M:ZCFVE1]ZQTYMOV(I) Then : Chgstl [M:ZCFVE1]NBLIG(I) With "BACKRED"    : Endif
    If [M:ZCFVE1]ZQTYFAC(I) < -1*[M:ZCFVE1]ZQTYMOV(I) Then : Chgstl [M:ZCFVE1]NBLIG(I) With "BACKYELLOW" : Endif
    Affzo [M:ZCFVE1]NBLIG(I)
  Next

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
