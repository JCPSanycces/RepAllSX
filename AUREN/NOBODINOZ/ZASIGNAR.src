# Si kit/sous-traité, affichage de la qté livrable
#If !find([F:ZSOP2]LINTYP,2,10) Return Endif
#GERR=4: GMESSAGE="                                  "
#If [M:SOH4]DLBQTYSTU(LNOL)<[M:SOH4]WALLQTYSTU(LNOL)
