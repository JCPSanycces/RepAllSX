#<AdxTL>@(#)0.0.0.0 $Revision$ 
Call ASIGNACION("ORD1001-2000001",4000,"D16BALEAR/006",0)
End

#####################################################################################
Subprog ASIGNACION(ZP_VCRNUM,ZP_VCRLIN,ZP_ITMREF,ZP_QTY)
  Value Char ZP_VCRNUM,ZP_ITMREF
  Value Integer ZP_VCRLIN
  Value Decimal ZP_QTY
  Local Mask STOALL [ALL]
  If clalev([F:ZSTA11]) = 0 Local File STOALL  [F:ZSTA11] : Endif
  If clalev([F:ZSOH11]) = 0 Local File SORDER  [F:ZSOH11] : Endif
  If clalev([F:ZSOQ11]) = 0 Local File SORDERQ [F:ZSOQ11] : Endif
  Local Char PARAM(250)(1..5), SAVACT(20), VALEUR
  Global Libelle GVCRTYP
  Local Integer I
  PARAM(1) = "SOH4"
  PARAM(2) = "0"
  PARAM(3) = "D16BALEAR/002"
  PARAM(4) = "900"
  PARAM(5) = "2"

  Read [F:ZSOH11]SOHNUM = ZP_VCRNUM
  Read [F:ZSOQ11]SOQ0   = ZP_VCRNUM;ZP_VCRLIN;ZP_VCRLIN
#  Filter [F:ZSTA11] Where ALLTYP = 2 and VCRNUM = ZP_VCRNUM and VCRLIN = ZP_VCRLIN and ITMREF = ZP_ITMREF
#  #Cabecera
#  [M:ALL]STOFCY     = "900"
#  #[M:ALL]WA         = ""
#  [M:ALL]ITMREF     = ZP_ITMREF
#  [M:ALL]VCRNUM     = ZP_VCRNUM
#  [M:ALL]BPAADD     = "001"
#  [M:ALL]PCU        = "UN"
#  [M:ALL]PCUSTUCOE  = 1.00
#  [M:ALL]COEFUCUS   = "    1,0000 UN"
#  [M:ALL]VCRTYP     = 2
#  [M:ALL]VCRLIN     = ZP_VCRLIN
#  [M:ALL]VCRSEQ     = ZP_VCRLIN
#  [M:ALL]BPCORD     = "S0901238"
#  [M:ALL]AAASTA     = 2
#  [M:ALL]QQQSTA     = 1
#  [M:ALL]RRRSTA     = 1
#  [M:ALL]FLGSHLLOT  = 1
#  [M:ALL]PECINTLOC  = 2
#  [M:ALL]PECPLFLOC  = 2
#  [M:ALL]PECSCOLOC  = 1
#  [M:ALL]STODISFLG  = 1
#  [M:ALL]FLPNNUM    = ""
#  [M:ALL]XPALNUM    = ""
#  [M:ALL]XCTRNUM    = ""
#  [M:ALL]OWNFLG     = 2
#  [M:ALL]NOTOWNFLG  = 1
#  [M:ALL]PECOWNER   = ""
#  [M:ALL]PECTRU     = 2
#  [M:ALL]PECECC     = 2
#  [M:ALL]FLGDLULOT  = 2
#  [M:ALL]XWRH       = ""
#  [M:ALL]WRHOBY     = 1
#  [M:ALL]WECCVALMAJ = ""
#  [M:ALL]RETQTY     = 7
#  [M:ALL]QTYTOALL   = 7
#  [M:ALL]STU        = "UN"
#  [M:ALL]OLDALLQTY  = 0
#  [M:ALL]PECQTY     = 7
#  [M:ALL]SHTQTY     = 0
#  [M:ALL]ALLTYP     = 2
#  [M:ALL]XALLTYP    = "Detallada"
#  [M:ALL]XLOT       = ""
#  [M:ALL]XLOC       = ""
#  [M:ALL]XSTA       = ""
#  [M:ALL]XLOCTYP    = ""
#  [M:ALL]STOLOC     = ""
#  [M:ALL]RETDAT     = [0/00/0000]
#  [M:ALL]DLVDAT     = [15/06/2020]
#  [M:ALL]STOMGTCOD  = 2
#  [M:ALL]SERMGTCOD  = 1
#  [M:ALL]GLOALLQTY  = 0
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#  [M:ALL]AAASTA     = 2
#
#  #Líneas TIPO DE ASIGNACION 2
#
#  [M:ALL]LOT        (0) = ""
#  [M:ALL]SLO        (0) = ""
#  #[M:ALL]ECCVALMAJ = ""
#  #[M:ALL]ECCVALMIN = ""
#  #[M:ALL]SERNUM    = ""
#  [M:ALL]LPNNUM     (0) = ""
#  [M:ALL]LOC        (0) = "098"
#  [M:ALL]STA        (0) = "A"
#  [M:ALL]AVAQTY     (0) = 10
#  #A modificar------------------------
#  [M:ALL]ALLQTY     (0) = 4
#  [M:ALL]ALLQTYPCU  (0) = 7
#  [M:ALL]XPCU (0)       = "UN"
#  [M:ALL]XPCUSTUCOE (0) = 1
#  [M:ALL]TOTQTY     (0) = 7
#  #[M:ALL]SHLDAT    = ""
#  #[M:ALL]POT       = ""
#  [M:ALL]PALNUM     (0) = ""
#  [M:ALL]CTRNUM     (0) = ""
#  [M:ALL]OWNER      (0) = "900"
#  [M:ALL]STOCOU     (0) = 54
#  [M:ALL]ALLQTYORI  (0) = 3
#

  Gosub CHARGE_STOALL

  [M:ALL]NBLIG = 1
  Infbox "Pantalla cargada"
  Gosub OUVRE
  Gosub ENR #From TRTSTOALL
  Infbox"ok"
  Close Mask [ALL]
End
###################################################################################
#<AdxTL>@(#)8.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Mask SOH4    [SOH4]
Local Mask ALLPAR  [ALP]

Local Char PARBOUT(250)(1..4), SAVACT(20), VALEUR
PARBOUT(1) = "XXX"
PARBOUT(2) = "3"
PARBOUT(3) = "A-TS140"
PARBOUT(4) = "MAR"
SAVACT = GACTION : GACTION = "SAISTOALL"
Call SAISIE_CHAR(VALEUR,PARBOUT,"ISTOALL","TRTSTOALL") From GSAISIE
GACTION = SAVACT
End
#CHECK UNUSED_END

########################################################################
# Traitement TRTSTOALL  - Saisie allocation manuelle              V140 #
#                         depuis commandes et OF                       #
########################################################################
# Action SAISTOALL
#    Paramčtres     - LABR    Abréviation masque : "SOH4" par exemple
#                   - LNOL    No ligne écran (nolign-1)
#                   - LITM    Article
#                   - LFCY    Site
#
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"          : Gosub INIT
Endcase

#--- Actions liées ŕ la fenętre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE-BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "BOUTON"        : Gosub BOUTON
 When "FINSAI"        : Gosub FINSAI
 When "FIN"           : Gosub FIN
 When "RAF"           : WAFFPICK=1
 When "TIR"           : WAFFPICK=1
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE
 When "HINT"          : Gosub HINT_KEY
 When "DEB_PIC"       : Gosub DEB_PIC
 When "CRE_PIC"       : Gosub CRE_PIC
 When "ANU_PIC"       : Gosub ANU_PIC
 When "FIN_PIC"       : Gosub FIN_PIC
 When Default
Endcase

Return

#########################################################################
$INIT

# Ouverture fenętre de saisie des allocations non autorisée --> on ressort
If GNOTALL<>0
   Raz GNOTALL : FIN=1
Endif

Return

#########################################################################
$OUVRE

Global Integer GSUPLIG        : # Pour identifier que l'on supprime une ligne
Global Integer GRERBPC        : # Conso réservations clients (1=non/2=oui)
Global Integer GDIAGENSHT     : # Générations des ruptures   (1=non/2=oui)
                                # Si appel depuis fonction alloc par article
Global Integer GTYPLIG        : # 0=Normale / 1=Composant kit / 2=Contremarque
Global Integer GPRET          : # 1=Commande de pręt
Global Libelle GVCRTYP        : # Type de document
Global Char    GXSTA(12)      : # Stockage du filtre statut
Global Char    GTRUCOD(6)     : # Rčgle d'allocation
Global Libelle GUNTLOT        : # Mono-lot
Global Char    GSTOLOC(GLONLOC)
Global Char    GDEFLOC(GLONLOC), GDEFLOC2(GLONLOC), GDEFLOC3(GLONLOC)
Global Char    GDEFLOCTYP(GLONTLO), GDEFLOCTYP2(GLONTLO), GDEFLOCTYP3(GLONTLO)
#--- Issue X3-55261
Global Char    GLOCCAT(4)     : # Pour filtrer les catégories d'emplacements

Raz GRERBPC, GDIAGENSHT, GPRET

Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Char    LITM(GLONITM)   : # Article
Local Char    LFCY(GLONFCY)   : # Site
Local Char    LNUM            : # Identifiant réservations
Local Decimal LQTA
Local Integer LTYPLOC, LSTA
Local Integer LRET
Local Char    LDEFLOC(GLONLOC)
Local Char    LDEFLOCTYP(GLONTLO)
Local Integer I, J, K, NOL, WF
Local Integer OKRUP           : # 1=génération de rupture
Local Integer WPICK           : # 1=depick / 2=pick
Local Integer WAFFPICK        : # 0=pas d'alimentation picking
Local Integer WTRSTYP, WPRE
Local Integer LSST
Local Char    LWRH(GLONWRH)
Local Integer WRHGES              : # Gestion de dépôt sur le site
Local Char    WSHTWRH(GLONWRH)    : # Dépôt de rupture
Local Char    WSHTLOT(GLONLOT)    : # Lot de rupture
Local Char    WSHTLOC(GLONLOC)    : # Emplacement de rupture
Local Char    WSHTLOCTYP(GLONTLO) : # Type emplacement de rupture
Local Char    WSHTECCVALMAJ(GLONECS) : # Version de rupture     #--- TS 106217
Local Char    WDEFLOC(GLONLOC), WDEFLOC2(GLONLOC), WDEFLOC3(GLONLOC)
Local Char    WDEFLOCTYP(GLONTLO), WDEFLOCTYP2(GLONTLO), WDEFLOCTYP3(GLONTLO)
Local Integer WE1, WE2, WE3, WT1, WT2, WT3, WNBL, WLOCFLT
Local Char    WCRIT(80)
Local Char    WCRITPIC(250)   : # Critčre pour contrôle ligne stock pickée
Local Char    WCRITSTO(250)   : # Critčre pour chargement picking ligne stock
Local Char    WCRITSTO1(80)   : # Critčre article et site
Local Char    WCRITSTO2(80)   : # Critčre lot                   #--- TS 106217
Local Char    WCRITSTO21(40)  : # Critčre version               #--- TS 106217
Local Char    WCRITSTO3(80)   : # Critčre péremption
Local Char    WCRITSTO31(80)  : # Critčre DLU                   # hcb V6percri
Local Char    WCRITSTO4(100)  : # Critčre statuts
#--- Bug 64366 passage de 60 ŕ 80
Local Char    WCRITSTO5(80)   : # Critčre catégorie emplacements et dépôt
Local Char    WCRITSTO6(50)   : # Critčre propriétaire du stock
Local Char    WPICKSTO(2)
Local Char    WXSTA
Local Char    WPARAM
Local Integer WA, WQ, WR
Local Decimal WSTUACTDIS, WTOTACTDIS, WDISPO
Local Decimal WPCUDIS, WSTUDIS
Local Decimal WQTY, WQTYTOALL, WQTYARR
#DLUBPC
Local Char NBDAY(10)
Raz NBDAY
If clalev([M:ALP])=0  Local Mask ALLPAR     [ALP]   Endif

If clalev([F:ITG])=0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]   Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]   Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STL])=0  Local File STOLOT     [STL]   Endif
If clalev([F:STO])=0  Local File STOCK      [STO]   Endif
If clalev([F:STA])=0  Local File STOALL     [STA]   Endif
If clalev([F:SWW])=0  Local File STOWIPW    [SWW]   Endif
#--- TS 106217
If clalev([F:ECS])=0  Local File ECCSTA     [ECS]   Endif
#--- X3-53322
If clalev([F:LPN])=0  Local File LPN        [LPN]   Endif
If GWRHACT=2
   If clalev([F:ITW])=0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
Endif
#DLUBPC
If clalev([F:ITU])=0  Local File ITMBPC    [ITU]   Endif
# Récupération paramčtre administrateur stock
Call PARAMUTIL("STOADMIN",WPARAM,"","") From SUBAUS
GSTOADMIN = val(WPARAM)

# Récupération des paramčtres
LABR    = PARAM(1)
LNOL    = val(PARAM(2))
LITM    = PARAM(3)
LFCY    = PARAM(4)
GVCRTYP = val(PARAM(5))

#--- Lecture article
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call ERREUR(LITM-":"-mess(134,100,1)) From GESECRAN
      FIN=1 : Return
   Endif
Endif
#--- Lecture article site
If LFCY<>"" & ([F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY)
   Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
   If fstat
      Call ERREUR(LITM-":"-mess(2,196,1)-":"-LFCY) From GESECRAN
      FIN=1 : Return
   Endif
Endif

Gosub FORMAT_INV From STKLIB
# Rajout du mode affiché : "P"
Call DYNAMIC(GWSINVLOT,":","P;") From TEXTE
GWSINVLOT=ctrans(GWSINVLOT,";",":")
Call DYNAMIC(GWSINVSLO,":","P;") From TEXTE
GWSINVSLO=ctrans(GWSINVSLO,";",":")
Call DYNAMIC(GWSINVEMP,":","P;") From TEXTE
GWSINVEMP=ctrans(GWSINVEMP,";",":")
Call DYNAMIC(GWSINVSER,":","P;") From TEXTE
GWSINVSER=ctrans(GWSINVSER,";",":")
Call DYNAMIC(GWSINVWRH,":","P;") From TEXTE
GWSINVWRH=ctrans(GWSINVWRH,";",":")
#--- TS 106217
Call DYNAMIC(GWSINVECCMAJ,":","P;") From TEXTE
GWSINVECCMAJ=ctrans(GWSINVECCMAJ,";",":")
#--- Issue 110678 remplacement c par P
Call DYNAMIC(GWSINVECCMIN,":","P;") From TEXTE
GWSINVECCMIN=ctrans(GWSINVECCMIN,";",":")
#---
#--- Issue X3-53322
Call DYNAMIC(GWSINVLPNNUM,":","P;") From TEXTE
GWSINVLPNNUM=ctrans(GWSINVLPNNUM,";",":")

Return

#########################################################################
$OUVRE_BOITE

Return

#########################################################################
$DEBUT

Raz GTYPLIG, WF
# Chargement des blocs 1 et 2
# Traitement ŕ alimenter pour les différentes fonctions
Gosub CHARG_PARAM From TRTSTOALLA

#--- Bug 83065
#--- Si ordre de sous-traitance,
#--- vérification qu'un manquant sous-traitant n'est pas en préparation
If LABR= "SCO2" & [M:ALL]SHTQTY<>0
   WSRGQTY=0
   For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM
&                    & VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ & STOCOU=0
      WSRGQTY+=[F:STA]SRGQTYSTU
   Next
   If WSRGQTY>0
      Call ERREUR(mess(398,184,1)) From GESECRAN
      FIN=1 : Return
   Endif
#--- Bug 84767
Elsif [M:ALL]SHTQTY<>0
   WSRGQTY=0
   For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM
&                    & VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ
&                    & STOCOU=0 & SRGNUM<>""
      WSRGQTY+=[F:STA]SRGQTYSTU
   Next
   If WSRGQTY>0
      Call MESSAGE(mess(408,184,1)) From GESECRAN
      FIN=1 : Return
   Endif
#---
Endif
#---

# Récupération code 'gestion dépôt sur le site'
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

Call LECITM(LFCY,LITM,"",0,[M:ALL]XWRH,LRET) From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

If !find([M:ALL]ALLTYP,1,2) | [M:ALL]OLDALLQTY=0
   [M:ALL]ALLTYP=2
Endif

# Sauvegarde qté ŕ allouer pour restitution si abandon
WQTYTOALL = [M:ALL]QTYTOALL

[M:ALL]ITMREF = LITM
[M:ALL]STOFCY = LFCY
[M:ALL]VCRTYP = GVCRTYP

If GERR | FIN Return Endif

# Stockage du lot de rupture
Raz WSHTLOT
If [M:ALL]XLOT<>"*" WSHTLOT=[M:ALL]XLOT Endif

# Stockage du dépôt de rupture
WSHTWRH = [M:ALL]XWRH

# Dépôt obligatoire ou renseigné sur ligne document --> non modifiable
If [M:ALL]XWRH<>""
   [M:ALL]WRHOBY=2
Else
   [M:ALL]WRHOBY=1
   LSST=0
   # Sous-traitance
   If ([M:ALL]VCRTYP=10 & [M:ALL]PECSCOLOC=2) | [M:ALL]VCRTYP=36
      LSST=1
   Endif
   # Alimentation dépôt par défaut article-site pour filtrer le stock
   Call WRHAUTO([M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]VCRTYP,LSST,LWRH) From STKWRH
   If !find(LWRH,"","*")
      [M:ALL]XWRH = LWRH
   Endif
Endif

# Stockage du filtre statut
GXSTA = [M:ALL]XSTA

#--- Issue X3-55261
# Filtre catégorie emplacement pour le contrôle et la sélection emplacement
Raz GLOCCAT
If [M:ALL]PECINTLOC=2 GLOCCAT+="1" Endif
If [M:ALL]PECPLFLOC=2 GLOCCAT+="2" Endif
If [M:ALL]PECSCOLOC=2 GLOCCAT+="4" Endif
#---

If [M:ALL]VCRTYP=2
   LNUM=format$("K:"+num$(GLONBPC)+"X",[M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M:ALL]BPAADD)
   LNUM= vireblc(LNUM, 1)
Endif

# Si alloc détaillé et qté déjŕ allouée = qté ŕ allouer ou qté besoin
# pas de chargement de la liste de picking
If [M:ALL]ALLTYP=2 &
& ([M:ALL]QTYTOALL=[M:ALL]OLDALLQTY | [M:ALL]RETQTY=[M:ALL]OLDALLQTY)
   WAFFPICK=0
Else
   WAFFPICK=1
Endif

# Si ce n'est pas un composant de kit
If GTYPLIG<>1
   # Si qté ŕ allouer et déjŕ allouée nulles,
   # alimentation qté ŕ allouer avec qté besoin
   If [M:ALL]QTYTOALL=0 & [M:ALL]OLDALLQTY=0
      [M:ALL]QTYTOALL=[M:ALL]RETQTY
   Endif
Endif

# Alimentation du masque STOALL
Gosub ALI_MSK_ALL

# Par défaut, pas d'affichage des lignes de stock indisponibles
[M:ALL]STODISFLG=1

If [M:ALL]NBLIG>0
   Affzo [M:ALL]1-99
Else
   # Artifice (affichage du tableau) afin de traiter les colonnes invisibles
   [M:ALL]NBLIG=1
   Affzo [M:ALL]1-99
   Effzo [M:ALL]15
Endif

#------------------------------------------------------
# Chargement du filtre lignes de stock pour le picking
#------------------------------------------------------
#--- Issue X3-4501 : ajout VCRTYP=40
Case [M:ALL]VCRTYP
 When  2 : GTRUCOD = [F:ITG]ALLRULORD
           If GPRET=1
              WTRSTYP = 17
           Else
              WTRSTYP = 4
           Endif
 When 10 : If [M:ALL]PECSCOLOC=2
              GTRUCOD = [F:ITG]ALLRULSCC
              WTRSTYP = 29
           Else
              GTRUCOD = [F:ITG]ALLRULMAT
              WTRSTYP = 6
           Endif
 When 36 : GTRUCOD = [F:ITG]ALLRULSCC
           WTRSTYP = 29
 When 40 : GTRUCOD = [F:ITG]ALLRULORD
           WTRSTYP = 4
Endcase

GUNTLOT=1
Raz [F:TRU]
# Lecture rčgle d'allocation
If GTRUCOD<>""
   Read [TRU]TRU0=GTRUCOD
   If fstat
      Raz GTRUCOD
   Else
      GUNTLOT=[F:TRU]UNTLOT
   Endif
Endif

# Stockage ordre des lots (FIFO par défaut) pour picking lignes de stock
If GTRUCOD<>""
   [M:ALL]LOTMGT=[F:TRU]LOTMGT
Else
   [M:ALL]LOTMGT=2
Endif

# Lecture de la rčgle de gestion ŕ utiliser
Call LECSRU([M:ALL]STOFCY,[F:ITM]TCLCOD,WTRSTYP,"","",LRET)
&           From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

#--- TS 106217
# Stockage de la version de rupture si exclusivité
If [F:SRU]ORDVER=2
  WSHTECCVALMAJ = [M:ALL]WECCVALMAJ
Else
  WSHTECCVALMAJ = ""
Endif
#---

# Récupération de l'emplacement de rupture si exclusif
Raz WSHTLOC, WDEFLOC
# Si rčgle d'allocation/sortie
If GTRUCOD<>""

   # Récupération types emplacement ou emplacement par défaut
   # de l'article-site pour le type mouvement
   #--- Issue 110327
   #Gosub ALI_DEFLOC From STKALL
   Gosub ALI_DEFLOC From STKALF
   #---

   # Détermination du nombre de ligne de la rčgle
   I = find(0,[F:TRU]LOCFLT(0..dim([F:TRU]LOCFLT)-1))
   If I=0
      WNBL = dim([F:TRU]LOCFLT)
   Else
      WNBL = I-1
   Endif
   If min([F:TRU]LOCFLT(0..WNBL-1))>1
      # Si OF ou Ordre de sous-traitance et emplacement local renseigné
      If find([M:ALL]VCRTYP,10,36)
         If [M:ALL]STOLOC<>""
            # Si emp local exclusif sana joker on le stocke pour les ruptures
            If max([F:TRU]LOCFLT)=2
&            & !instr(1,[M:ALL]STOLOC,'*') & !instr(1,[M:ALL]STOLOC,'?')
&            & !instr(1,[M:ALL]STOLOC,'!') & !instr(1,[M:ALL]STOLOC,'#')
               WSHTLOC=[M:ALL]STOLOC
            Endif
            # Emp local dans les rčgles, mais non exclusif --> c'est fini
            If min([F:TRU]LOCFLT)=2 WF=1 Endif
         Endif
      Endif
      If WSHTLOC="" & WF<>1
         # I,J et K contiennent la 1čre position des catégories emp 1,2 et 3
         # dans le tableau des rčgles d'allocation (0 si absent)
         I = find(3,[F:TRU]LOCFLT(0..WNBL-1))
         J = find(4,[F:TRU]LOCFLT(0..WNBL-1))
         K = find(5,[F:TRU]LOCFLT(0..WNBL-1))
         # WE1,WE2 et WE3 contiennent 1 si emp par défaut 1,2 et 3
         Raz WE1, WE2, WE3
         If WDEFLOC <>"" & !instr(1,WDEFLOC,'*')  & !instr(1,WDEFLOC,'?')
&                        & !instr(1,WDEFLOC,'!')  & !instr(1,WDEFLOC,'#')
            WE1=1
         Endif
         If WDEFLOC2<>"" & !instr(1,WDEFLOC2,'*') & !instr(1,WDEFLOC2,'?')
&                        & !instr(1,WDEFLOC2,'!') & !instr(1,WDEFLOC2,'#')
            WE2=1
         Endif
         If WDEFLOC3<>"" & !instr(1,WDEFLOC3,'*') & !instr(1,WDEFLOC3,'?')
&                        & !instr(1,WDEFLOC3,'!') & !instr(1,WDEFLOC3,'#')
            WE3=1
         Endif
         # WT1,WT2 et WT3 contiennent 1 si type emp par défaut 1,2 et 3
         Raz WT1, WT2, WT3
         If WDEFLOCTYP <>"" & !instr(1,WDEFLOCTYP,'*') &!instr(1,WDEFLOCTYP,'?')
&                           & !instr(1,WDEFLOCTYP,'!') &!instr(1,WDEFLOCTYP,'#')
            WT1=1
         Endif
         If WDEFLOCTYP2<>"" & !instr(1,WDEFLOCTYP2,'*')&!instr(1,WDEFLOCTYP2,'?')
&                           & !instr(1,WDEFLOCTYP2,'!')&!instr(1,WDEFLOCTYP2,'#')
            WT2=1
         Endif
         If WDEFLOCTYP3<>"" & !instr(1,WDEFLOCTYP3,'*')&!instr(1,WDEFLOCTYP3,'?')
&                           & !instr(1,WDEFLOCTYP3,'!')&!instr(1,WDEFLOCTYP3,'#')
            WT3=1
         Endif

         # WLOCFLT contient la valeur max des catégories d'emp (3,4 ou 5)
         WLOCFLT = max([F:TRU]LOCFLT)

         # Exploitation des rčgles d'allocation pour déterminer
         # le type ou l'emplacement de rupture
         #--- Issue 110327
         #Gosub ALI_LOCATION From STKALL
         Gosub ALI_LOCATION From STKALF
         #---
      Endif
   Endif

   # Chargement des (types) emplacements de l'article-site paramétrés
   # dans la rčgle d'allocation/sortie pour filtrer le picking stock
   Call RECH_DEFLOCTYP("ALL") From STKALL

Endif

# Chargement de l'emplacement (type) de consommation (si exclusif)
Raz LDEFLOC, LDEFLOCTYP
If [F:ITF]LOCMGTCOD=2
   # Si pręt
   If WTRSTYP=17
      WPRE=2
   Else
      WPRE=1
   Endif
   Call RECH_PICLOC([M:ALL]VCRTYP,[M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]STOLOC,
&                   [M:ALL]XWRH,[M:ALL]PECSCOLOC,WPRE,"N",LDEFLOC,LDEFLOCTYP) From STKALL
Endif

#--- Positionnement filtre picking
Raz WCRIT, WCRITSTO, WCRITPIC
Raz WCRITSTO1, WCRITSTO2, WCRITSTO3, WCRITSTO31, WCRITSTO4, WCRITSTO5, WCRITSTO6   # hcb v6percri

WCRITSTO1 = '[F:STO]ITMREF=[M:ALL]ITMREF&[F:STO]STOFCY=[M:ALL]STOFCY'

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALL]BPCORD <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALL]BPCORD
   If fstat
      Raz [F:ITU]
   Endif
Endif
#DLU Client, calcul du nbre de jours ŕ retrancher ŕ la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif
#Fin DLUBPC


# Lot et péremption
If dim([M:ALL]XLOT)>0
   # hcb V6dlu nouvelle gestion
   WCRITSTO3  = '([F:STL]SHLDAT=[0/0/0]|'
   WCRITSTO31 = '([F:STL]DLUDAT=[0/0/0]|'
   If [M:ALL]DLVDAT<>[0/0/0]
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:ALL]DLVDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:ALL]DLVDAT)'      #DLUBPC
   Else
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:ALL]RETDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:ALL]RETDAT)'      #DLUBPC
   Endif
   If [F:SRU]SHLLOT=1
      WCRITPIC  = WCRITSTO3
   Elsif [F:SRU]SHLLOT=2
      WCRITPIC  = WCRITSTO31
   Endif
   If !find([M:ALL]XLOT,"","*")
      WCRITSTO2 = 'pat([F:STO]LOT,[M:ALL]XLOT)<>0'
   Endif
   #--- TS 106217
   # Si version renseignée et exclusive
   If [M:ALL]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
      WCRITSTO21 = '[F:STO]ECCVALMAJ=[M:ALL]WECCVALMAJ'
   Endif
   #---
Endif

# Si non renseigné car ajouté 05.08
If [M:ALL]PECINTLOC=0 [M:ALL]PECINTLOC=2 Endif
# Catégorie emplacement et dépôt
If [M:ALL]PECINTLOC=2
   If [M:ALL]PECPLFLOC=2
      WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
      If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
   Else
      WCRITSTO5 = '[F:STO]LOCCAT=1'
      If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
   Endif
Elsif [M:ALL]PECPLFLOC=2
   WCRITSTO5 = '[F:STO]LOCCAT=2'
   If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
Endif
If [M:ALL]PECSCOLOC=2
   If WCRITSTO5=""
      WCRITSTO5  = '[F:STO]LOCCAT=4'
   Else
      WCRITSTO5 += '|[F:STO]LOCCAT=4'
   Endif
Elsif WCRITSTO5=""
   # Pour ne rien avoir (paramétrage incohérent)
   WCRITSTO5 = '[F:STO]LOCCAT=9'
Endif

# Propriétaire
If [M:ALL]PECOWNER=""
   [M:ALL]OWNFLG=2 : [M:ALL]NOTOWNFLG=1
   WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
Else
   [M:ALL]OWNFLG=2 : [M:ALL]NOTOWNFLG=2
   WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:ALL]PECOWNER)'
Endif

Raz WA, WQ, WR
If GTRUCOD<>""
   # Statuts autorisés par les rčgles d'allocation
   For I=0 To dim([F:TRU]STAFLT)-1
      If [F:TRU]STAFLT(I)<>0
         If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
         If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
         If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
      Endif
   Next I
Else
   WA=1
Endif

[M:ALL]XSTA=vireblc([M:ALL]XSTA,4)

If !find([M:ALL]XSTA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:ALL]XSTA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable ŕ tester
   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
Endif

WCRITSTOA = 'pat([F:STO]STA,"A*")<>0'
WCRITSTOQ = 'pat([F:STO]STA,"Q*")<>0'
WCRITSTOR = 'pat([F:STO]STA,"R*")<>0'

# Alimentation des zones de la fenętre critčre et du filtre
# pour contrôle ligne stock pickée (si non administrateur stock)
[M:ALL]AAASTA=1
[M:ALL]QQQSTA=1
[M:ALL]RRRSTA=1
# hcb V6percri deb
[M:ALL]FLGSHLLOT = 2
[M:ALL]FLGDLULOT = 2
If [F:SRU]SHLLOT = 2
   [M:ALL]FLGSHLLOT = 1
   [M:ALL]FLGDLULOT = 1
Endif
If [F:SRU]SHLLOT = 1
   [M:ALL]FLGSHLLOT = 1
   [M:ALL]FLGDLULOT = 2
Endif
# hcb V6percri fin

Raz WCRIT
If WA=1
   WCRIT+='pat([F:STO]STA,"A*")<>0'
   [M:ALL]AAASTA=2
Endif
If WQ=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"Q*")<>0'
   [M:ALL]QQQSTA=2
Endif
If WR=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"R*")<>0'
   [M:ALL]RRRSTA=2
Endif

If WCRITPIC<>""
   If WCRIT<>""
      WCRITPIC+='&('+WCRIT+')'
   Endif
Else
   If WCRIT<>""
      WCRITPIC+=WCRIT
   Else
      WCRITPIC='1=1'
   Endif
Endif

Raz WAFFPICK
# Affichage liste picking si qté rupture ou qté restant ŕ allouer
#MAE, le 24/09/2010, bg 67280 : affichage liste gauche si qté total < qté besoin
#If [M:ALL]SHTQTY<>0 | [M:ALL]PECQTY<[M:ALL]QTYTOALL
If [M:ALL]SHTQTY<>0 | [M:ALL]PECQTY<[M:ALL]RETQTY
   WAFFPICK=1
Endif

Gosub TIROIR

#--- 73461
# Alimentation GRERBPC (consommation réservation client) pour calcul dispo
# selon paramčtre USERERBPC (consommation réservation client)
# Si ŕ la demande, GRERBPC reste ŕ 0 pour poser la question avant enregistrement
# Dans ce cas on ne tient pas compte des réservations client dans le calcul de dispo
If GRERBPC=0
   Case GUSERERBPC
    When 1 : GRERBPC = 1
    When 2 : GRERBPC = 2
    When Default :
   Endcase
Endif
#---

Return

#########################################################################
$ALI_MSK_ALL
Local Integer WSTOMGTCOD
Raz WSTOMGTCOD
WSTOMGTCOD = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD > 1
   WSTOMGTCOD = [F:ITF]STOMGTCOD
Endif

Raz [M:ALL]PECQTY
[M:ALL]COEFUCUS  = " ="+format$("N:5.4",[M:ALL]PCUSTUCOE)-[M:ALL]STU
[M:ALL]XALLTYP   = ""
If [M:ALL]OLDALLQTY<>0 | [M:ALL]SHTQTY<>0
   [M:ALL]XALLTYP = mess([M:ALL]ALLTYP,450,1)
Endif
[M:ALL]STOMGTCOD =  WSTOMGTCOD
[M:ALL]SERMGTCOD = [F:ITM]SERMGTCOD

NOL=0
#--- Issue 116917 (ajout SERNUM="")
For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM &
&                   VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ &
&                   ITMREF=[M:ALL]ITMREF & ALLTYP=2 & SERNUM=""

   # S'il existe plusieurs allocations pour un męme chrono stock
   # réagrégation de ces allocations
   If NOL<>0 & [F:STA]STOCOU<>0
      I=find([F:STA]STOCOU,[M:ALL]STOCOU(0..NOL-1))
      If I<>0
         [M:ALL]ALLQTY(I-1)    += [F:STA]QTYSTUACT
         [M:ALL]PECQTY         += [F:STA]QTYSTUACT
         [M:ALL]AVAQTY(I-1)    += [F:STA]QTYSTUACT
         [M:ALL]ALLQTYPCU(I-1) += [F:STA]QTYSTUACT/[M:ALL]XPCUSTUCOE(I-1)
         Call QTEARR([M:ALL]ALLQTYPCU(I-1),[M:ALL]XPCU(I-1)) From TRTDIV
         #--- Issue 115740
         [M:ALL]ALLQTYORI(I-1) += [F:STA]QTYSTUACT
         Goto NEXT_STA
      Endif
   Endif

   [M:ALL]STOCOU(NOL) = [F:STA]STOCOU
   [M:ALL]ALLQTY(NOL) = [F:STA]QTYSTUACT
   [M:ALL]PECQTY     += [F:STA]QTYSTUACT
   #--- Issue 115740
   [M:ALL]ALLQTYORI(NOL) += [F:STA]QTYSTUACT
   Read [STO]STO0=[M:ALL]STOFCY;[F:STA]STOCOU
   If fstat
      Call ERREUR([M:ALL]STOFCY-num$([F:STA]STOCOU)-":"-mess(342,199,1)-
&                  num$([M:ALL]VCRTYP)-[M:ALL]VCRNUM-num$([M:ALL]VCRLIN)-
&                  num$([M:ALL]VCRSEQ)) From GESECRAN
      Goto NEXT_STA
   Endif
   If dim([M:ALL]LOT)>0
      [M:ALL]LOT(NOL) = [F:STO]LOT
      If dim([M:ALL]SLO)>0 [M:ALL]SLO(NOL)=[F:STO]SLO Endif
      Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
      If fstat
         Call ERREUR([F:STO]LOT-[F:STO]SLO-":"-mess(123,199,1)-[M:ALL]ITMREF)
&             From GESECRAN
         Goto NEXT_STA
      Endif
      If dim([M:ALL]SHLDAT)>0 [M:ALL]SHLDAT(NOL)=[F:STL]SHLDAT Endif
      If dim([M:ALL]POT)>0
         If [M:ALL]STOMGTCOD=3
            [M:ALL]POT(NOL) = [F:STL]POT
         Elsif [M:ALL]STOMGTCOD=4
            [M:ALL]POT(NOL) = [F:STL]ACT
         Endif
      Endif
   Endif
   #--- TS 106217
   If dim([M:ALL]ECCVALMAJ)>0 [M:ALL]ECCVALMAJ(NOL)=[F:STO]ECCVALMAJ Endif
   If dim([M:ALL]ECCVALMIN)>0 [M:ALL]ECCVALMIN(NOL)=[F:STL]ECCVALMIN Endif
   #---
   If dim([M:ALL]LOC)>0    [M:ALL]LOC(NOL)   =[F:STO]LOC     Endif
   If dim([M:ALL]SERNUM)>0 [M:ALL]SERNUM(NOL)=[F:STO]SERNUM  Endif
   If dim([M:ALL]PALNUM)>0 [M:ALL]PALNUM(NOL)=[F:STO]PALNUM  Endif
   If dim([M:ALL]CTRNUM)>0 [M:ALL]CTRNUM(NOL)=[F:STO]CTRNUM  Endif
   [M:ALL]STA(NOL)       = [F:STO]STA
   [M:ALL]OWNER(NOL)     = [F:STO]OWNER
   [M:ALL]XPCU(NOL)      = [F:STO]PCU
   [M:ALL]XPCUSTUCOE(NOL)= [F:STO]PCUSTUCOE
   If [M:ALL]XPCUSTUCOE(NOL)=0 [M:ALL]XPCUSTUCOE(NOL)=1 Endif
   [M:ALL]ALLQTYPCU(NOL) = [M:ALL]ALLQTY(NOL)/[M:ALL]XPCUSTUCOE(NOL)
   Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
   [M:ALL]TOTQTY(NOL)    = [F:STO]QTYSTUACT
   [M:ALL]AVAQTY(NOL)    = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
&                         +[M:ALL]ALLQTY(NOL)
   NOL += 1
$NEXT_STA
Next

[M:ALL]NBLIG = NOL

Return

#########################################################################
$SETBOUT

# Pour interdire la navigation
GREP="M"

If !find("=",CHBOU) CHBOU+="=" Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

If [M:ALL]OLDALLQTY+[M:ALL]SHTQTY=0
   Call VIREBOUT(CHMEN,"4") From GOBJET
Endif

If [M:ALL]NBLIG=0
   Call VIREBOUT(CHMEN,"3") From GOBJET
Endif

# Pas de proposition si qté ŕ allouée = 0
# ou allocation détaillée et qté ŕ allouée < qté déjŕ allouée
If COUZON="QTYTOALL"
   If val(CZ)=0 | ([M:ALL]ALLTYP=2 & val(CZ)<=[M:ALL]OLDALLQTY)
      Call VIREBOUT(CHMEN,"1") From GOBJET
   Endif
Else
   If [M:ALL]QTYTOALL=0 | ([M:ALL]ALLTYP=2 & [M:ALL]QTYTOALL<=[M:ALL]OLDALLQTY)
      Call VIREBOUT(CHMEN,"1") From GOBJET
   Endif
Endif

# Si rčgle pas de rčgle d'allocation, pas de tunnel
If GTRUCOD=""
   Call VIREBOUT(CHMEN,"O") From GOBJET
Endif

Return

#########################################################################
$APRES_MODIF

# Si suppression d'une ligne, raffraichissement du picking
If GSUPLIG=65 & [M:ALL]STOCOU(nolign-1)<>0
   Read [STO]STO0=[M:ALL]STOFCY;[M:ALL]STOCOU(nolign-1)
   If !fstat
      Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
      If !fstat
         If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
      Endif
   Endif
Endif

# Si suppression de n lignes, raffraichissement du picking
If find(GSUPLIG,68,83)
   For I=nolign-1 To nolign1-1
      If [M:ALL]STOCOU(I)<>0
         Read [STO]STO0=[M:ALL]STOFCY;[M:ALL]STOCOU(I)
         If !fstat
            Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
            If !fstat
               If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
            Endif
         Endif
      Endif
   Next I
Endif
Raz GSUPLIG

Return

#########################################################################
$AVANT_ENR

OKRUP=0

# Contrôles relatifs aux différentes fonctions appelantes
Gosub AVANT_ENR From TRTSTOALLA
If FOK=0 Return Endif

# Quantité sélectionnée > besoin
If [M:ALL]PECQTY > [M:ALL]RETQTY
   # Si commande et ligne normale, question
   If [M:ALL]VCRTYP=2 & GTYPLIG=0
      OK=2
      Call AVERTIR(mess(19,191,1),OK) From GESECRAN
      If OK<>2 : FOK=0 : Return : Endif
   # Si OF ou commande et composant kit ou contremarque ou tache affaire, erreur
   Else
      GMESSAGE = mess(448,196,1)
      GERR=1 : FOK=0 : Return
   Endif
Endif

# Si commande, la qté ŕ allouer doit correspondre ŕ un nombre complet d'UC
If [M:ALL]VCRTYP=2 & [M:ALL]PCU<>[M:ALL]STU
   GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
   If GOK=0
      GOK=1
   Else
      Call CTRQTYPCU([M:ALL]PCU,[M:ALL]PCUSTUCOE,[M:ALL]PECQTY,WQTYARR) From STKLIB
      #--- Issue 104664
      Call QTEARR(WQTYARR,[M:ALL]STU) From TRTDIV
      If WQTYARR<>[M:ALL]PECQTY
         GMESSAGE = mess(281,192,1)
         GERR=1 : FOK=0 : Return
      Endif
   Endif
Endif

# Quantité sélectionnée <> quantité ŕ allouer
If [M:ALL]PECQTY <> [M:ALL]QTYTOALL
    # Non par défaut
    OK = 0
    Call OUINON(mess(449,196,1),OK) From GESECRAN
    If OK<>2 : FOK=0 : Return : Endif
Endif

# Si ligne de composant, génération de rupture
If GTYPLIG=1
   OKRUP=1
#--- Issue X3-4501
# Si ligne de contremarque ou allocation tache affaire, pas de génération de rupture
#Elsif GTYPLIG=2
Elsif GTYPLIG=2 | [M:ALL]VCRTYP=40
#---
   OKRUP=0
# Si ligne normale
Else
   # Si qté traitée = 0 et qté ŕ allouée = 0 --> désallocation (pas de rupture)
   If [M:ALL]PECQTY=0 & [M:ALL]QTYTOALL=0
      OKRUP=0 : Return
   Endif
   # Si alloc globale et pas de ligne saisie --> pas de rupture
   If [M:ALL]PECQTY=0 & [M:ALL]ALLTYP=1
      OKRUP=0 : Return
   Endif
   # Si qté traitée < quantité ŕ allouer, génération de ruptures ?
   If [M:ALL]PECQTY < [M:ALL]QTYTOALL
      # Si commande
      If [M:ALL]VCRTYP=2
         # Si appel depuis la fonction allocation par article
         # dans laquelle on a forcé l'allocation des ruptures
         If GDIAGENSHT=2
            OKRUP=1
         # Sinon question
         Elsif GDIAGENSHT=0
            OK=1
            # Si paramčtre génération rupture = non
            If GGENSHT=1 OK=0 Endif
            Call OUINON(mess(451,196,1),OK) From GESECRAN
            If OK=2 OKRUP=1 Endif
         Endif
      # Si OF, génération de rupture
      Else
         OKRUP=1
      Endif
   Endif
Endif

# Si commande et augmentation de la qté, consommation des réservations clients ?
If [M:ALL]VCRTYP=2 & [M:ALL]PECQTY>[M:ALL]OLDALLQTY
   If GRERBPC=0
      Case GUSERERBPC
       When 1 : GRERBPC = 1
       When 2 : GRERBPC = 2
       When 3 : Call CAL_RERQTY(1,[M:ALL]ITMREF,[M:ALL]STOFCY,LNUM,[M:ALL]RETDAT,LQTA) From STKALL : # Bug 65986
                If LQTA <> 0
                   GMESSAGE = mess(131,191,1)-":"-num$(LQTA)-[M:ALL]STU
                   # Oui par défaut
                   GRERBPC  = 1
                   Call OUINON (GMESSAGE-"\"-mess(130,191,1),GRERBPC) From GESECRAN
                   Raz GMESSAGE
                Endif
      Endcase
   Endif
Endif

Return

#########################################################################
$ENR
Local Integer WOPT, WRET, WALL
Local Decimal WALLQTY, WSHTQTY, WCSOQTY, WQTYSTU
Local Decimal WSVGQTY
Local Date    WDAT

$ENREG_S
Call DEBTRANS From GLOCK
Trbegin [STA]

# Lecture de l'article
If [F:ITM]ITMREF <> [M:ALL]ITMREF
   Read [ITM]ITM0=[M:ALL]ITMREF
   If fstat = 1
      GOK = -1
      GLOCK = "$ITMMASTER"-[M:ALL]ITMREF
      Goto ROLL_TRT
   Elsif fstat
      GOK = 0
      Call RSTA ("ITM",[M:ALL]ITMREF) From GLOCK
      Goto AB_TRT
   Endif
Endif
# Lecture de l'article-site
If [F:ITF]ITMREF <> [M:ALL]ITMREF & [F:ITF]STOFCY <> [M:ALL]STOFCY
   Read [ITF]ITF0=[M:ALL]ITMREF;[M:ALL]STOFCY
   If fstat = 1
      GOK = -1
      GLOCK = "$ITMFACILIT"-[M:ALL]ITMREF-[M:ALL]STOFCY
      Goto ROLL_TRT
   Elsif fstat
      GOK = 0
      Call RSTA ("ITF",[M:ALL]ITMREF-[M:ALL]STOFCY) From GLOCK
      Goto AB_TRT
   Endif
Endif

Raz WOPT, WRET
Raz WALLQTY, WSHTQTY

# Si alloc global, pas de ligne sélectionnée et qté ŕ allouer = qté origine
# --> rien ŕ faire
If [M:ALL]ALLTYP=1 & [M:ALL]PECQTY=0 & [M:ALL]QTYTOALL=[M:ALL]OLDALLQTY
   WALLQTY = [M:ALL]QTYTOALL
   Goto ENREG_FIN
Endif

# Suppression des allocations et manquants existants
If [M:ALL]OLDALLQTY <> 0 | [M:ALL]SHTQTY <> 0
   Call DELALL([M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,
&              [M:ALL]ITMREF,WOPT,WALLQTY,WSHTQTY,WRET)
   If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif
   WALLQTY = 0
   WSHTQTY = 0
Endif

WALL=1
WDAT=[0/0/0]
# Si alloc global, pas de ligne sélectionnée
If [M:ALL]ALLTYP=1 & [M:ALL]PECQTY=0
   # Si quantité ŕ allouer <> 0
   If [M:ALL]QTYTOALL<>0
      #--- TS 106217 ajout paramčtre LECC (avant dernier)
      Call CREALL(WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,0,WDAT,0,[M:ALL]QTYTOALL,[M:ALL]VCRTYP,
&                 [M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,"",[M:ALL]RETDAT,"","","","","","",
&                 0,0,"","",[M:ALL]BPCORD,[M:ALL]BPAADD,[M:ALL]PECSCOLOC,"",WRET) From STKALL
      If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif
      WALLQTY = [M:ALL]QTYTOALL
   Endif
   Goto ENREG_FIN
Endif
[M:ALL]ALLTYP=2

WALL=2
WDAT=[0/0/0]

# Création des allocations
For I=0 To [M:ALL]NBLIG-1
    If [M:ALL]ALLQTY(I)=0 Goto NEXT_ALL Endif

    #--- Issue 114287
    Read [STO]STO0=[M:ALL]STOFCY;[M:ALL]STOCOU(I)
    If fstat Raz [F:STO] Endif
    #---

    WQTYSTU=[M:ALL]ALLQTY(I)
    # Si gestion en titres ou UI, calcul quantité en US
    Case [F:ITF]STOMGTCOD
     When 3 : If [M:ALL]ALLQTY(I)=[F:STO]QTYSTUACT          : #--- Issue 114287
                WQTYSTU=[F:STO]QTYSTU                   : #--- Issue 114287
              Elsif  dim([M:ALL]POT(I))>0
                WQTYSTU=[M:ALL]ALLQTY(I)/([M:ALL]POT(I)/100)
              Endif
              Call QTEARR(WQTYSTU,[M:ALL]STU) From TRTDIV   : #--- Issue 114037
     When 4 : If [M:ALL]ALLQTY(I)=[F:STO]QTYSTUACT          : #--- Issue 114287
                WQTYSTU=[F:STO]QTYSTU                   : #--- Issue 114287
              Elsif dim([M:ALL]ACT(I))>0
                WQTYSTU=[M:ALL]ALLQTY(I)/([M:ALL]ACT(I))
              Endif
              Call QTEARR(WQTYSTU,[M:ALL]STU) From TRTDIV   : #--- Issue 114037
    Endcase

    #--- TS 106217 ajout paramčtre LECC (avant dernier)
    Call CREALL (WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]STOCOU(I),WDAT,WQTYSTU,
&               [M:ALL]ALLQTY(I),[M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,
&               "",[M:ALL]RETDAT,"","","","","","",0,0,LDEFLOC,LDEFLOCTYP,
&               [M:ALL]BPCORD,[M:ALL]BPAADD,[M:ALL]PECSCOLOC,"",WRET) From STKALL
    If WRET<>0
       GOK=0 : GERR=1 : Goto AB_TRT
    Endif

    WALLQTY += [M:ALL]ALLQTY(I)

$NEXT_ALL
Next I

# Génération de rupture si nécessaire
If OKRUP=1
   #--- Bug 80267
   #WSHTQTY=[M:ALL]QTYTOALL-WALLQTY
   WSHTQTY=max(0,[M:ALL]QTYTOALL-WALLQTY)
   #---
   If WSHTQTY>0
      WQTYSTU=0
      WALL=4
      WDAT=[0/0/0]
      #--- TS 106217 ajout paramčtre LECC (avant dernier)
      Call CREALL (WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,0,WDAT,WQTYSTU,WSHTQTY,
&                 [M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,"",[M:ALL]RETDAT,
&                 WSHTLOT,"","",WSHTLOC,"",WSHTWRH,0,0,"","",[M:ALL]BPCORD,
&                 [M:ALL]BPAADD,[M:ALL]PECSCOLOC,WSHTECCVALMAJ,WRET) From STKALL
      If WRET<>0
         GOK=0 : GERR=1 : Goto AB_TRT
      Endif
   Endif
Endif

Raz WCSOQTY
# Consommation des réservations client (production?)
If GRERBPC=2
   Case [M:ALL]VCRTYP
    When 2 : # Réservation client livré
             LQTA=WALLQTY-[M:ALL]OLDALLQTY
             Call CSOALL(1,LNUM,[M:ALL]ITMREF,[M:ALL]STOFCY,[M:ALL]RETDAT,
&                        LQTA,LRET) From STKALL
             If LRET=1 GOK=0 : GERR=1 : Goto AB_TRT : Endif
             WSVGQTY=LQTA
#             If LQTA>0
             If LQTA<WALLQTY-[M:ALL]OLDALLQTY
                LQTA=(WALLQTY-[M:ALL]OLDALLQTY)-LQTA
                # Réservation client
                Call CSOALL(1,[M:ALL]BPCORD,[M:ALL]ITMREF,[M:ALL]STOFCY,
&                          [M:ALL]RETDAT,LQTA,LRET) From STKALL
                If LRET=1 GOK=0 : GERR=1 : Goto AB_TRT : Endif
                WSVGQTY+=LQTA
             Endif
#             WCSOQTY=LQTA
             WCSOQTY=WSVGQTY
    When Default :
   Endcase
Endif

$ENREG_FIN
# Mises ŕ jour complémentaires relatives aux différentes fonctions appelantes
# WALLQTY contient la quantité allouée
# WSHTQTY contient la quantité en rupture
# WCSOQTY contient la quantité consommée sur les réservations clients
#FPH+
#FIXME : SE DESCOMENTA CUANDO TENGA EL FUENTE
#Gosub APRES_ENR From TRTSTOALLA
Gosub APRES_ENR
#FPH-
If GOK=0
   GERR=1 : Goto AB_TRT
Endif

Commit

# Pour sortir
FIN = 1

Return

#########################################################################
$ABA

WPICK=1
Gosub RAFFRAICHI
Effzo [M:ALL]15
Gosub ALI_MSK_ALL
# Restitution de la qté ŕ allouer
[M:ALL]QTYTOALL = WQTYTOALL
Affzo [M:ALL]1-99
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$BOUTON
#--------------------------------------------
# "1" : Aprčs Proposition (Action TRTSORPRO)
# "2" : Aprčs Critčres    (Action SAISORCRI)
# "3" : Raz
# "4" : Désallocation
#--------------------------------------------
Case BOUT
 When "1","2" : Raz WCRITSTO4, WCRIT
                Raz WCRITSTO2, WCRITSTO5
                If dim([M:ALL]XLOT)>0 & !find([M:ALL]XLOT,"","*")
                   WCRITSTO2 = 'pat([F:STO]LOT,[M:ALL]XLOT)<>0'
                Endif
                #--- TS 106217
                # Prise en compte filtre version
                If [M:ALL]PECECC=2
                # Si version renseignée et exclusive
                  If [M:ALL]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
                    If WCRITSTO2<>"" WCRITSTO2 += "&" Endif
                    WCRITSTO2 += '[F:STO]ECCVALMAJ=[M:ALL]WECCVALMAJ'
                  Endif
                Endif
                #---
                [M:ALL]XSTA=vireblc([M:ALL]XSTA,4)
                # Si statuts renseignés dans filtre allocation
                If !find([M:ALL]XSTA,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:ALL]XSTA,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable ŕ tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                Endif

                If BOUT="2"
                   If [M:ALL]PECINTLOC=2
                      If [M:ALL]PECPLFLOC=2
                         WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
                         If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
                      Else
                         WCRITSTO5 = '[F:STO]LOCCAT=1'
                         If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
                      Endif
                   Elsif [M:ALL]PECPLFLOC=2
                      WCRITSTO5 = '[F:STO]LOCCAT=2'
                      If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
                   Endif
                   If [M:ALL]PECSCOLOC=2
                      If WCRITSTO5=""
                         WCRITSTO5  = '[F:STO]LOCCAT=4'
                      Else
                         WCRITSTO5 += '|[F:STO]LOCCAT=4'
                      Endif
                   Elsif WCRITSTO5=""
                      # Pour ne rien avoir (paramétrage incohérent)
                      WCRITSTO5 = '[F:STO]LOCCAT=9'
                   Endif
                   # Propriétaire
                   If [M:ALL]OWNFLG=2
                      If [M:ALL]NOTOWNFLG=2
                         If [M:ALL]PECOWNER=""
                            WCRITSTO6 = '1=1'
                         Else
                            WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:ALL]PECOWNER)'
                         Endif
                      Else
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Else
                      If [M:ALL]NOTOWNFLG=2
                         If [M:ALL]PECOWNER=""
                            WCRITSTO6 = '[F:STO]OWNER<>[F:STO]STOFCY'
                         Else
                            WCRITSTO6 = '[F:STO]OWNER=[M:ALL]PECOWNER'
                         Endif
                      Else
                         # Si rien de coché, on force :'stock propriétaire'
                         [M:ALL]OWNFLG=2
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Endif
                Endif
                WAFFPICK=1
                Gosub TIROIR
 When "3"     : WPICK=1
                Gosub RAFFRAICHI
                Raz   [M:ALL]PECQTY
                Affzo [M:ALL]PECQTY
                Effzo [M:ALL]15
 When "4"     : WPICK=1
                Gosub RAFFRAICHI
                Raz   [M:ALL]PECQTY, [M:ALL]QTYTOALL
                Affzo [M:ALL]PECQTY, QTYTOALL
                Effzo [M:ALL]15
Endcase

Return

#########################################################################
$FINSAI

# Pour forcer l'init bouton
# (en fait mkstat ŕ 99 passe au champs suivant et dans ce cas il ne faut pas)
mkstat=99

Return
#########################################################################
$FIN

# Pour forcer l'init bouton
#mkstat=99

Return
#########################################################################
# Rollback
$ROLL_TRT
Rollback
Call ROLL From GLOCK
If GROLL
   Return
Else
   Goto ENREG_S
Endif
#########################################################################
# Abandon
$AB_TRT
Rollback
Return

#########################################################################
# Action sur champs
#########################################################################

########################################
Subprog C_QTYTOALL(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Decimal WQTYARR

# Quantité ŕ allouer > besoin
If VALEUR<>[M:ALL]QTYTOALL & VALEUR>[M:ALL]RETQTY
   GMESSAGE=mess(445,196,1)
   If find([M:ALL]VCRTYP,10,36)
      Call ERREUR(GMESSAGE) From GESECRAN
      mkstat=2 : End
   Else
      OK=2
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      If OK<>2
         mkstat=2 : End
      Endif
   Endif
   Raz GMESSAGE
Endif

# Si commande, la qté ŕ allouer doit correspondre ŕ un nombre complet d'UC
If [M:ALL]VCRTYP=2 & [M:ALL]PCU<>[M:ALL]STU
   GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
   If GOK=0
      GOK=1
   Else
      Call CTRQTYPCU([M:ALL]PCU,[M:ALL]PCUSTUCOE,VALEUR,WQTYARR) From STKLIB
      #--- Issue 104664
      Call QTEARR(WQTYARR,[M:ALL]STU) From TRTDIV
      If WQTYARR<>VALEUR
         mkstat = 2
         Call ERREUR(mess(280,192,1)-":"-num$(WQTYARR)) From GESECRAN
         VALEUR      = WQTYARR
         [M:ALL]QTYTOALL = WQTYARR
      Endif
   Endif
Endif

End

########################################
Subprog AVANT_NBLIG
# Décrémentation qté traitée
[M:ALL]PECQTY -= [M:ALL]ALLQTY(nolign-1)
End

########################################
Subprog APRES_NBLIG
# Incrémentation qté traitée
[M:ALL]PECQTY += [M:ALL]ALLQTY(nolign-1)
Affzo [M:ALL]PECQTY
End

########################################
Subprog C_NBLIG
# --> Contrôle de suppression de lignes
If find(status,65,68,83)
   GSUPLIG = status
Else
   Raz GSUPLIG
Endif
End

########################################
Subprog C_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WVARQTY
Local    Integer OK
#--- Issue X3-160680
Local Integer LTYPLOC, LSTA
Local Decimal WDISPO
#---

# Pas de quantité nulle, vous devez supprimer la ligne
If VALEUR=0
   mkstat=2 : GMESSAGE=mess(392,199,1) : End
Endif
# La quantité a été modifiée
If VALEUR<>[M:ALL]ALLQTY(nolign-1)
   # Variation de la quantité
   WVARQTY = VALEUR-[M:ALL]ALLQTY(nolign-1)
   # Quantité allouée > quantité disponible
   If VALEUR>[M:ALL]AVAQTY(nolign-1)
      mkstat=2
      Call ERREUR(mess(446,196,1)) From GESECRAN

   #--- Issue X3-160680
      End
   Else
      # Calcul du stock disponible sur l'article
      Raz LTYPLOC, LSTA
      If [M:ALL]PECPLFLOC=2 LTYPLOC+=1 Endif
      If [M:ALL]PECSCOLOC=2 LTYPLOC+=4 Endif
      # Si pas d'emplacements internes
      If [M:ALL]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
      If [M:ALL]AAASTA=2    LSTA   +=1 Endif
      If [M:ALL]QQQSTA=2    LSTA   +=2 Endif
      If [M:ALL]RRRSTA=2    LSTA   +=4 Endif
      Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:ALL]PECOWNER,WDISPO) From STKLIB
      # On retire la somme des quantités saisies diminuées des quantités déjŕ allouées
      WDISPO -= sum([M:ALL]ALLQTY)-sum([M:ALL]ALLQTYORI)
      # On ajoute la quantité de la ligne
      WDISPO += [M:ALL]ALLQTY(nolign-1)
      # On rajoute l'allouée global
      WDISPO += [M:ALL]GLOALLQTY
      # Pas de dispo
      If VALEUR>WDISPO
         mkstat=2
         Call ERREUR(mess(446,196,1)) From GESECRAN
         End
      Endif
   Endif
   # Quantité totale + variation > quantité ŕ allouer
   #Elsif ([M:ALL]PECQTY+WVARQTY)>[M:ALL]QTYTOALL
   If ([M:ALL]PECQTY+WVARQTY)>[M:ALL]QTYTOALL
   #--- End issue X3-160680

      GMESSAGE=mess(393,199,1)
      If find([M:ALL]VCRTYP,10,36)
         mkstat=2
         Call ERREUR(GMESSAGE) From GESECRAN
      Else
         OK=2
         Call AVERTIR(GMESSAGE,OK) From GESECRAN
         If OK<>2 mkstat=2 Endif
      Endif
   Endif
   Raz GMESSAGE
Endif
End

########################################
Subprog AM_ALLQTY(VALEUR)
Variable Decimal VALEUR
# Calcul quantité en UC
If [M:ALL]XPCUSTUCOE(nolign-1)=0 [M:ALL]XPCUSTUCOE(nolign-1)=1 Endif
[M:ALL]ALLQTYPCU(nolign-1) = VALEUR/[M:ALL]XPCUSTUCOE(nolign-1)
Call QTEARR([M:ALL]ALLQTYPCU(nolign-1),[M:ALL]XPCU(nolign-1)) From TRTDIV

Affzo [M:ALL]ALLQTYPCU(nolign-1)
End


#########################################################################
# TRAITEMENTS LIES AU PICKING DES LIGNES DE STOCK                       #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$FILGAUCHE

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

If WAFFPICK=0
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
Else
   # Filtre article, site
   FILGAUSUP(0)=WCRITSTO1
   # Filtre lot
   If WCRITSTO2<>""
      FILGAUSUP(0)+='&'+WCRITSTO2
   Endif
   #--- TS 106217
   # Prise en compte filtre version
   If [M:ALL]PECECC=2
     # Si version renseignée et exclusive
     If WCRITSTO21<>""
        FILGAUSUP(0)+='&'+WCRITSTO21
     Endif
   Endif
   #---
   # Filtre péremption
   If [M:ALL]FLGDLULOT = 1 & WCRITSTO31<>""    # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO31             # hcb V6cri
   Elsif [M:ALL]FLGSHLLOT = 1 & WCRITSTO3<>""  # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO3
   Endif                                       # hcb V6cri
   # Filtre catégorie emplacement
   If dim([M:ALL]LOC)>0 & WCRITSTO5<>""
      FILGAUSUP(1)+='&('+WCRITSTO5+')'         #--- TS 106217  (0-->1)
  Endif
   # Filtre propriétaire
   FILGAUSUP(1)+='&'+WCRITSTO6                 #--- TS 106217  (0-->1)

   # Filtre statuts
   If WCRITSTO4<>""
      FILGAUSUP(1)+='&('+WCRITSTO4+')'
   Else
      Raz WCRIT
      If [M:ALL]AAASTA=2
         WCRIT+=WCRITSTOA
      Endif
      If [M:ALL]QQQSTA=2
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+=WCRITSTOQ
      Endif
      If [M:ALL]RRRSTA=2
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+=WCRITSTOR
      Endif
      If WCRIT<>''
         FILGAUSUP(1)+='&('+WCRIT+')'
      Endif
   Endif
   # Filtre lignes de stock indisponibles
   If [M:ALL]STODISFLG<>2
      FILGAUSUP(2)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'    #--- TS 106217   (1-->2)
   Endif
   # Filtres supplémentaires
   #--- Issue X3-53322
   If !find([M:ALL]FLPNNUM,"","*")
      FILGAUSUP(2)+='&pat([F:STO]LPNNUM,[M:ALL]FLPNNUM)<>0'
   Endif
   #---
   If !find([M:ALL]XPALNUM,"","*")
      FILGAUSUP(2)+='&pat([F:STO]PALNUM,[M:ALL]XPALNUM)<>0'                   #--- TS 106217   (1-->2)
   Endif
   If !find([M:ALL]XCTRNUM,"","*")
      FILGAUSUP(2)+='&pat([F:STO]CTRNUM,[M:ALL]XCTRNUM)<>0'                   #--- TS 106217   (1-->2)
   Endif
   If [M:ALL]XPCUFIL<>""
      FILGAUSUP(2)+='&[F:STO]PCU=[M:ALL]XPCUFIL'                              #--- TS 106217   (1-->2)
   Endif
   # Si prise en compte filtre emplacement de la rčgle d'allocation
   If [M:ALL]PECTRU=2
      If GSTOLOC<>""
         FILGAUSUP(3) +='&(pat([F:STO]LOC,GSTOLOC)<>0'
      Endif
      If GDEFLOC<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC)<>0'
         Endif
      Elsif GDEFLOCTYP<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Endif
      Endif
      If GDEFLOC2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC2)<>0'
         Endif
      Elsif GDEFLOCTYP2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Endif
      Endif
      If GDEFLOC3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC3)<>0'
         Endif
      Elsif GDEFLOCTYP3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Endif
      Endif
      If FILGAUSUP(3)<>"" FILGAUSUP(3)+=')' Endif
   Endif
Endif

Return

##########################################################################
$AP_FILGAUCHE

WPICK=2 : Gosub RAFFRAICHI

Return

#########################################################################
$CLE_GAUCHE

SNSLIS = 1       : # Ascendant
# No série en E/S
If [M:ALL]SERMGTCOD=3
   LENLIS = 8
   Case [M:ALL]LOTMGT
    When 1,3 : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]SERNUM;[F:STO]STOCOU"
               LENLIS   = 6
    When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STS]RCPDAT;[F:STO]SERNUM;[F:STO]STOCOU"
    When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STS]RCPDAT desc;[F:STO]SERNUM desc;[F:STO]STOCOU Desc"
               SNSLIS   = 2  : # Descendant
   Endcase
Else
   LENLIS = 7
   Case [M:ALL]LOTMGT
    When 1   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
               LENLIS   = 6
    When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
    When 3   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]SHLDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
    When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STO]LOC desc;[F:STO]STOCOU desc"
               SNSLIS   = 2  : # Descendant
   Endcase
Endif

Return

#########################################################################
$HINT_KEY

Return

##########################################################################
$DEB_PIC
Local Integer I
Local Char    SYMBOLE2(20)
Return

#########################################################################
$CRE_PIC

Raz WPICKSTO

Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[M:ALL]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

#--- TS 106217
# Contrôle version par rapport ŕ la rčgle de gestion
If [F:STO]ECCVALMAJ<>""
  Call CTLECCVALMAJ([F:STO]ITMREF,[M:ALL]WECCVALMAJ,[F:STO]ECCVALMAJ,[M:ALL]RETDAT,"",LRET) From STKSOR
  If LRET<>0
    FOK=0 : GERR=1
    Return
  Endif
Endif
#---

# Contrôle si sortie mono-lot
If GUNTLOT=2 & [M:ALL]NBLIG>0
   If [F:STO]LOT<>[M:ALL]LOT(0)
      OK=1 : Call AVERTIR(mess(212,184,1), OK) From GESECRAN
      Raz GERR : # Sinon pas de dépick dans GSAISIE (la boule reste bleue)
      If OK=1  FOK=0 : Return  Endif
   Endif
Endif

#--- Dem 74755
GPOINT="PIC_STOCK" : Gosub ENTREE From EXEFNC
If FOK=0 Return Endif
#---

# Si non administrateur stock, contrôle ligne pickée par rapport
# ŕ la péremption et ŕ la rčgle d'allocation
If GSTOADMIN<>2
   WPICKSTO=string$(evalue(WCRITPIC),"OK")
   If WPICKSTO<>"OK"
      FOK=0 : GERR=1
      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
      If dim([M:ALL]LOT)>0
         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
      Endif
      GMESSAGE+="\"+mess(366,199,1)
      Return
   Endif
Endif

# Calcul du stock disponible sur l'article
Raz LTYPLOC, LSTA
If [M:ALL]PECPLFLOC=2 LTYPLOC+=1 Endif
If [M:ALL]PECSCOLOC=2 LTYPLOC+=4 Endif
# Si pas d'emplacements internes
If [M:ALL]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
If [M:ALL]AAASTA=2    LSTA   +=1 Endif
If [M:ALL]QQQSTA=2    LSTA   +=2 Endif
If [M:ALL]RRRSTA=2    LSTA   +=4 Endif

Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:ALL]PECOWNER,WTOTACTDIS) From STKLIB

#--- Issue 105939
# On retire la somme des quantités saisies
#--- Issue 115937
# On retire la somme des quantités saisies diminuées des quantités déjŕ allouées
#WTOTACTDIS -= sum([M:ALL]ALLQTY)
#--- Issue X3-160680
#WTOTACTDIS -= sum([M:ALL]ALLQTY-[M:ALL]ALLQTYORI)
WTOTACTDIS -= sum([M:ALL]ALLQTY)-sum([M:ALL]ALLQTYORI)
#---
#---
#---

# On rajoute l'allouée global
WTOTACTDIS += [M:ALL]GLOALLQTY

#--- Bug 73461
# Si on doit consommer les réservations client, on les rajoutent
If [M:ALL]VCRTYP=2 & [M:ALL]BPCORD<>"" & dim(GRERBPC)>0 & GRERBPC<>1
   Call CAL_RERQTY(1,[M:ALL]ITMREF,[M:ALL]STOFCY,LNUM,[M:ALL]RETDAT,LQTA) From STKALL
   If LQTA<>0

      #--- Bug 74284
      #WTOTACTDIS += LQTA
      If GRERBPC=0
         GMESSAGE = mess(131,191,1)-":"-num$(LQTA)-[M:ALL]STU
         # Oui par défaut
         GRERBPC  = 1
         Call OUINON (GMESSAGE-"\"-mess(130,191,1),GRERBPC) From GESECRAN
         Raz GMESSAGE
      Endif
      If GRERBPC=2  WTOTACTDIS += LQTA  Endif
      #---

   Endif
Endif
#---

# Contrôle du disponible pour sortie sur la ligne de stock
Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#WSTUACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA

# Disponible = min(dispo ligne stock, dispo article)
WDISPO = min(WSTUACTDIS,WTOTACTDIS)

# Pas de stock disponible
If WDISPO<=0
   FOK=0 : GERR=1
   If WTOTACTDIS <= 0
      GMESSAGE = mess(80,197,1)-[M:ALL]ITMREF-": "
   Else
      GMESSAGE = mess(644,197,1)-": "
   Endif
   GMESSAGE += mess(367,199,1)
   If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
      # La qté en attente de rangement est peut ętre dans une liste ŕ ranger
      GMESSAGE += "\"+mess(150,184,1)
   Endif
   Return
Endif


WQTY=[M:ALL]QTYTOALL-[M:ALL]PECQTY
# La quantité sélectionnée est supérieure ŕ la quantité ŕ allouer
If WQTY<=0
   FOK=0 : GERR=1
   GMESSAGE=mess(866,196,1)
   Return
Endif

# Contrôle de l'insertion
If [M:ALL]NBLIG+1 >= dim([M:ALL]STA)-1
   FOK=0 : GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:ALL]NBLIG
Insa nolign,1,[M:ALL]NBLIG [M:ALL]NBLIG
[M:ALL]NBLIG += 1
nolign = [M:ALL]NBLIG
NOL = nolign-1
status = 0

If WDISPO>=WQTY
   [M:ALL]ALLQTY(NOL)=WQTY
Else
   [M:ALL]ALLQTY(NOL)=WDISPO
Endif
[M:ALL]XPCU(NOL)       = [F:STO]PCU
[M:ALL]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE

If [M:ALL]XPCUSTUCOE(NOL)=0 [M:ALL]XPCUSTUCOE(NOL)=1 Endif
[M:ALL]ALLQTYPCU(NOL)  = [M:ALL]ALLQTY(NOL)/[M:ALL]XPCUSTUCOE(NOL)
Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
[M:ALL]AVAQTY(NOL)     = WSTUACTDIS
[M:ALL]TOTQTY(NOL)     = [F:STO]QTYSTUACT

If dim([M:ALL]LOT)>0    [M:ALL]LOT(NOL)    = [F:STO]LOT    Endif
If dim([M:ALL]SLO)>0    [M:ALL]SLO(NOL)    = [F:STO]SLO    Endif
If dim([M:ALL]LOC)>0    [M:ALL]LOC(NOL)    = [F:STO]LOC    Endif
If dim([M:ALL]SERNUM)>0 [M:ALL]SERNUM(NOL) = [F:STO]SERNUM Endif
# hcb 61170
If dim([M:ALL]CTRNUM)>0 [M:ALL]CTRNUM(NOL) = [F:STO]CTRNUM Endif
If dim([M:ALL]PALNUM)>0 [M:ALL]PALNUM(NOL) = [F:STO]PALNUM Endif
#--- TS 106217
If dim([M:ALL]ECCVALMAJ)>0 [M:ALL]ECCVALMAJ(NOL)=[F:STO]ECCVALMAJ Endif
If dim([M:ALL]ECCVALMIN)>0 [M:ALL]ECCVALMIN(NOL)=[F:STL]ECCVALMIN Endif
#---
#--- Issue X3-53322
If dim([M:ALL]LPNNUM)>0 [M:ALL]LPNNUM(NOL) = [F:STO]LPNNUM Endif
#---
[M:ALL]STA(NOL)        = [F:STO]STA

If dim([M:ALL]SHLDAT)>0 [M:ALL]SHLDAT(NOL) = [F:STL]SHLDAT Endif
If dim([M:ALL]POT)>0
   If [M:ALL]STOMGTCOD=3
      [M:ALL]POT(NOL) = [F:STL]POT
   Elsif [M:ALL]STOMGTCOD=4
      [M:ALL]POT(NOL) = [F:STL]ACT
   Endif
Endif

[M:ALL]OWNER(NOL)     = [F:STO]OWNER

[M:ALL]STOCOU(NOL)    = [F:STO]STOCOU

[M:ALL]PECQTY        += [M:ALL]ALLQTY(NOL)

Return

#########################################################################
$ANU_PIC

Raz I,J
OK = 0
If [M:ALL]NBLIG <> 0
   While OK <> 1
      I = find([F:STO]STOCOU,[M:ALL]STOCOU(J..[M:ALL]NBLIG-1))
      If !I Break Endif
      NOL = J+I-1
      [M:ALL]PECQTY -= [M:ALL]ALLQTY(NOL)
      Dela NOL,1,[M:ALL]NBLIG-1 [M:ALL]NBLIG
      [M:ALL]NBLIG -= 1
      OK = 1
   Wend
Endif

Return

#########################################################################
$FIN_PIC

Affzo [M:ALL]1-99

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$TIROIR

ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
If WAFFPICK<>0
   WPICK=2
   Gosub RAFFRAICHI
Endif

Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes déjŕ saisies    #
#-----------------------------------------------------------------------#

If [M:ALL]NBLIG <> 0
   For I=0 To [M:ALL]NBLIG-1
      If [M:ALL]STOCOU(I) <> 0
         Read [STO]STO0=[M:ALL]STOFCY;[M:ALL]STOCOU(I)
         Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
         If [M:ALL]SERMGTCOD=3 Read [STS]STS0=[F:STO]ITMREF;[F:STO]SERNUM Endif
         If evalue(FILGAUSUP)
            If    WPICK=1 Gosub DEPICK From GSAISIE
            Elsif WPICK=2 Gosub REPICK From GSAISIE
            Endif
         Endif
      Endif
   Next I
Endif

Return

##########################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOALL) 31-07-2006 09:22:27 (MB)
######################################################################################
Subprog IB_PECTRU
End


######################################################################################
#---------------------------------------------------------------------- #
# Mise ŕ jour complémentaires aprčs enregistrement                      #
# Si problčme mettre GOK=0 pour annuler l'enregistrement                #
# Cette étiquette est appelée depuis APRES_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$APRES_ENR
Local Integer NL, WRET
Local Decimal WALLSTU
Local Char    WTRTLIG(1)

#FPH+
If !clalev([F:ZSOH1]) : Local File SORDER    [F:ZSOH1] : Endif
If !clalev([F:ZSOQ2]) : Local File SORDERQ   [F:ZSOQ2] : Endif
If !clalev([F:ZSOP2]) : Local File SORDERP   [F:ZSOP2] : Endif

Read [F:ZSOQ2]SOQ0 = [M:ALL]VCRNUM
Read [F:ZSOQ2]SOQ0 = [M:ALL]VCRNUM;[M:ALL]VCRLIN;[M:ALL]VCRSEQ
Read [F:ZSOP2]SOP0 = [M:ALL]VCRNUM;[M:ALL]VCRLIN;[M:ALL]VCRSEQ
#FPH-
If WCSOQTY<>0
    Local Char WVCRRER
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", [M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X", [M:ALL]BPAADD)
    WVCRRER = vireblc(WVCRRER, 1)
    # Si consommation des réservations clients : Maj de l'encours correspondant
    #FPH+
    #Call MAJORDBPC(1,WVCRRER,[M:SOH4]ITMREF(LNOL),[M:SOH4]DSTOFCY(LNOL),WCSOQTY,WRET) From TRTVENALL
     Call MAJORDBPC(1,WVCRRER,[M:ALL]ITMREF,[M:ALL]STOFCY,WCSOQTY,WRET) From TRTVENALL
    #FPH-
    If WRET <> 0 GOK=0 : Return Endif
Endif
#   Mise ŕ jour commande
Call MAJALLORD([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ALLTYP, 1, WALLQTY, WSHTQTY, WRET) From TRTVENALL
If WRET <> 0 : GOK = 0 : Return : Endif
#   Si Composé de kit, il faut allouer les composants
WALLSTU=WALLQTY+WSHTQTY
#FPH+
#WALLSTU=WALLSTU-([M:SOH4]ALLQTYSTU(LNOL)+[M:SOH4]SHTQTYSTU(LNOL))
WALLSTU=WALLSTU-([F:ZSOQ2]ALLQTYSTU+[F:ZSOQ2]SHTQTYSTU)
#FPH-
Raz WTRTLIG
#FPH+
#If find([M:SOH4]LINTYP(LNOL),2,10) & WALLSTU <> 0
If find([F:ZSOP2]LINTYP,2,10) & WALLSTU <> 0
#FPH-
    If WALLSTU < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WALLSTU = abs(WALLSTU)
    Elsif WALLSTU > 0
# ----- C'est une augmentation de l'allocation
        #FPH+
        # If [M:SOH4]ALLQTYSTU(LNOL) = 0 & [M:SOH4]SHTQTYSTU(LNOL) = 0
        If [F:ZSOQ2]ALLQTYSTU= 0 & [F:ZSOQ2]SHTQTYSTU(LNOL) = 0
        #FPH-
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WALLSTU=WALLQTY+WSHTQTY
    Endif
    Call GENALLKIT ([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, WTRTLIG, GRERBPC, 2, 0, 1, 0, WALLSTU,
&                   WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return : Endif
Endif
#FPH+
#    Réaffichage du masque [M:SOH4]
#If [F:SOH]SOHNUM <> [M:SOH0]SOHNUM
#    Read [SOH]SOH0=[M:SOH0]SOHNUM
#    If fstat : Return : Endif
#Endif
#[M:SOH1]ALLSTA = [F:SOH]ALLSTA
#
#If[F:ZSOQ2]SOHNUM<>[M:SOH0]SOHNUM |[F:ZSOQ2]SOPLIN<>[M:SOH4]SOPLIN(LNOL) |[F:ZSOQ2]SOQSEQ<>[M:SOH4]SOPLIN(LNOL)
#    Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(LNOL);[M:SOH4]SOPLIN(LNOL)
#    If fstat : Return : Endif
#Endif
#
#[M:SOH4]ALLQTY(LNOL)    =[F:ZSOQ2]ALLQTY
#[M:SOH4]ALLQTYSTU(LNOL) =[F:ZSOQ2]ALLQTYSTU
#[M:SOH4]SHTQTY(LNOL)    =[F:ZSOQ2]SHTQTY
#[M:SOH4]SHTQTYSTU(LNOL) =[F:ZSOQ2]SHTQTYSTU
#[M:SOH4]DALLTYP(LNOL)   =[F:ZSOQ2]ALLTYP
#
#[M:SOH4]TALLQTYSTU(LNOL) = sum([F:SOQ]ALLQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)
#[M:SOH4]TALLQTY(LNOL)    = sum([F:SOQ]ALLQTY,[F:SOQ]ODLQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY)
#If [M:SOH0]SOHCAT = 3
#    [M:SOH4]TALLQTYSTU(LNOL) +=[F:ZSOQ2]INVQTYSTU
#    [M:SOH4]TALLQTY(LNOL)    +=[F:ZSOQ2]INVQTY
#Else
#    [M:SOH4]TALLQTYSTU(LNOL) +=[F:ZSOQ2]DLVQTYSTU
#    [M:SOH4]TALLQTY(LNOL)    +=[F:ZSOQ2]DLVQTY
#Endif
## --- Qté ŕ allouer = Qté déjŕ allouée
#[M:SOH4]WALLQTY(LNOL)   =[F:ZSOQ2]ALLQTY +[F:ZSOQ2]SHTQTY
#[M:SOH4]WALLQTYSTU(LNOL)=[F:ZSOQ2]ALLQTYSTU +[F:ZSOQ2]SHTQTYSTU
#[M:SOH4]YALLQTY(LNOL)   = [M:SOH4]ALLQTY(LNOL)
#[M:SOH4]YSHTQTY(LNOL)   = [M:SOH4]SHTQTY(LNOL)
#
#Raz [M:SOH4]DLBQTYSTU (LNOL)
## Si kit/sous-traité, sauvegarde de l'indice du kit et de la qté cdée pour calcul qté livrable
#If find([M:SOH4]LINTYP(LNOL),2,10)
#    Local Decimal WKIT_QTYSTU  : Raz WKIT_QTYSTU
#    If [M:SOH4]ALLQTYSTU(LNOL)<>0
#        WKIT_QTYSTU=[M:SOH4]QTYSTU(LNOL)
#        [M:SOH4]DLBQTYSTU(LNOL)=[M:SOH4]ALLQTYSTU(LNOL)
#    Endif
#Endif
#
#Affzo [M:SOH1]ALLSTA
#If find([M:SOH4]LINTYP(LNOL),2,10) & WTRTLIG<>""
##   composé kit ou sous-traité : il faut réafficher tous les composants
#    NL=LNOL+1
#    While find([M:SOH4]LINTYP(NL),3,4,5,11,12,13) & NL < [M:SOH4]NBLIG
#        Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(NL);[M:SOH4]SOPLIN(NL)
#        If fstat : Break : Endif
#        [M:SOH4]ALLQTY(NL)    =[F:ZSOQ2]ALLQTY
#        [M:SOH4]ALLQTYSTU(NL) =[F:ZSOQ2]ALLQTYSTU
#        [M:SOH4]SHTQTY(NL)    =[F:ZSOQ2]SHTQTY
#        [M:SOH4]SHTQTYSTU(NL) =[F:ZSOQ2]SHTQTYSTU
#        [M:SOH4]DALLTYP(NL)   =[F:ZSOQ2]ALLTYP
#        [M:SOH4]TALLQTYSTU(NL)= sum([F:SOQ]ALLQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)
#        [M:SOH4]TALLQTY(NL)   = sum([F:SOQ]ALLQTY,[F:SOQ]ODLQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY)
#        If [M:SOH0]SOHCAT = 3
#            [M:SOH4]TALLQTYSTU(NL) +=[F:ZSOQ2]INVQTYSTU
#            [M:SOH4]TALLQTY(NL)    +=[F:ZSOQ2]INVQTY
#        Else
#            [M:SOH4]TALLQTYSTU(NL) +=[F:ZSOQ2]DLVQTYSTU
#            [M:SOH4]TALLQTY(NL)    +=[F:ZSOQ2]DLVQTY
#        Endif
#        # --- Qté ŕ allouer = Qté déjŕ allouée
#        [M:SOH4]WALLQTY(NL)        =[F:ZSOQ2]ALLQTY +[F:ZSOQ2]SHTQTY
#        [M:SOH4]WALLQTYSTU(NL)     =[F:ZSOQ2]ALLQTYSTU +[F:ZSOQ2]SHTQTYSTU
