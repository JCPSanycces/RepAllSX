#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################################################
## PROGRAM ZBVIMPORT: IMPORTACIONES BEVOLTA                                                             ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 09/07/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 00.000.000                                                                    ##
## OBJETIVO: DESCARGA VIA FTP LOS FICGEROS DE PEDIDOS DE COMPRAS ENVIADOS POR BEVOLTA                   ##                                                                    ##
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I
  Local Integer J
  Local Integer NL

  Local Char H1(1)
  Local Char H2(3)
  Local Char H3(30)
  Local Char H4(8)
  Local Char H5(10)
  Local Char H6(10)
  Local Char H7(10)
  Local Char H8(250)
  Local Char H9(250)
  Local Char H10(250)
  Local Char H11(250)
  Local Char H12(250)

  Local Char L1(1)(1..)
  Local Char L2(10)(1..)
  Local Integer L2NUM(1..)
  Local Char L3(1)(1..)
  Local Char L4(30)(1..)
  Local Char L5(3)(1..)
  Local Char L6(10)(1..)
  Local Char L7(8)(1..)
  Local Char L8(1)(1..)

  Call ECR_TRACE("Iniciando importación Pedidos Bevolta",0) From GESECRAN

  DIRAPL=filpath("","","") :                      # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Bevolta\Import"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  #ORDRE = "MOVE *.pro "+DIRPRO
  #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
  ORDRE = "MOVE *.err "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

Return

$EXEC

  Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  Call FTPGETDEL("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","Export_BEVOLTA_X3",DIRFTP,RES) From ZAURFTP

  If RES < 0

    Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN

  Else

    Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN

  Endif

  #Process the dodnloaded files

  ORDRE = "dir /b "+DIRFTP+"\*.txt 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros",0) From GESECRAN

    For J = 1 To RES

      FILNAME = DIRFTP+"\"+left$(FILELIST(J),len(FILELIST(J))-4)

      Case left$(FILELIST(J),6)

        When "ZBVPOH" : Call IMPORTSIL("ZBVPOH",FILNAME+".txt") From GIMPOBJ

        When "ZBVPTH" : Call IMPORTSIL("ZBVPTH",FILNAME+".txt") From GIMPOBJ

        When "ZBVSMO" : Call IMPORTSIL("ZBVSMO",FILNAME+".txt") From GIMPOBJ

        When Default : Call ECR_TRACE("Tipo de fichero desconocido: "+FILELIST(J),1) From GESECRAN

      Endcase

      Sleep 5

      ORDRE = "MOVE "+FILNAME+".txt "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      ORDRE = "MOVE "+FILNAME+".txt.err "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      #ORDRE = "MOVE "+FILNAME+".pro "+DIRPRO
      #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      #ORDRE = "MOVE "+FILNAME+".pro.err "+DIRPRO
      #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

    Next J

    Call ECR_TRACE("Fin del procesado de ficheros. Ficheros procesados: "+num$(J-1),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            SORT ORDER LINES
##########################################################################################################

$SORTPOHLINES

  Openi FILNAME+".txt", 0 Using [FIN]                               # Received file with orders
  Iomode adxifs ";" Using [FIN]                                     # Separador de campo ";"
  Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro CR + LF
  Iomode adxium 0 Using [FIN]                                       # UTF-8 file

  Openo FILNAME+".pro", 0 Using [FOUT]                              # File for orders import
  Iomode adxifs ";" Using [FOUT]                                    # Separador de campo ";"
  Iomode adxirs chr$(13)+chr$(10) Using [FOUT]                      # Separador de registro CR + LF
  Iomode adxium 0 Using [FOUT]                                      # UTF-8 file

  #Get the header
  Rdseq H1,H2,H3,H4,H5,H6,H7,H8,H9,H10,H11,H12 Using [FIN]

  If fstat <> 0

    Openi Using [FIN]
    Openo Using [FOUT]
    Call ECR_TRACE("Error en el formato de fichero "+LFILES(J)+". Fin de fichero inesperado",1) From GESECRAN

  Else

     If H1 <> "E"

          Call ECR_TRACE("Error en el formato de fichero "+LFILES(J)+". Identificador de línea distinto del esperado (E)",1) From GESECRAN

    Else

      #Copy the header
      Wrseq H1,H2,H3,H4,H5,H6,H7,H8,H9,H10,H11,H12 Using [FOUT]

      #Get the order lines
      NL = 1
      Rdseq L1(NL),L2(NL),L3(NL),L4(NL),L5(NL),L6(NL),L7(NL),L8(NL) Using [FIN]
      L2NUM(NL) = val(" "+L2(NL))

      If fstat <> 0

        Openi Using [FIN]
        Openo Using [FOUT]
        Call ECR_TRACE("Error en el formato de fichero "+LFILES(J)+". Fichero sin lineas de pedido",1) From GESECRAN

      Else

        While fstat <> 1

          If L1(NL) <> "L"

            Call ECR_TRACE("Error en el formato de fichero "+LFILES(J)+". Identificador de línea distinto del esperado (L)",1) From GESECRAN
            Break

          Endif

          NL+=1
          Rdseq L1(NL),L2(NL),L3(NL),L4(NL),L5(NL),L6(NL),L7(NL),L8(NL) Using [FIN]
          L2NUM(NL) = val(" "+L2(NL))

        Wend

        Sorta NL-1 L1,L2NUM,L3,L4,L5,L6,L7,L8 Order By L2NUM(indice+1)

        For I = 1 To NL-1

          Wrseq L1(I),num$(L2NUM(I)),L3(I),L4(I),L5(I),L6(I),L7(I),L8(I) Using [FOUT]

        Next I

      Endif

    Endif

  Endif

  Openo Using [FOUT]
  Openi Using [FIN]

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
