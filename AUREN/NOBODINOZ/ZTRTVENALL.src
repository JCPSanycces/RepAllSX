#<AdxTL>@(#)0.0.0.0 $Revision$ 
#####################################################################################################
#                              VARIABLES
#ZDISP -> Stock disponible real
#ZDISPTEMP -> Disponible contando con reserva
#ZASIGSTD  -> Asignación realizada por el estándar
#LGENSHT   -> Variable del punto de entrada Generacion de rupturas (1=No, 2=Si)
#ZOKRUP    -> Variable Generacion de rupturas (0=No, 1=Si). Se genera desde TRTSTOALL etiqueta AUREN
#####################################################################################################
# Registro de modificaciones
# Cod         Fecha             Usuario       Descripción
# a01       22/07/2021        M. Llaja      Corrige campos de asignación en SORDERQ y ORDERS
#                                           iniciado por errores en asignaciones automáticas sucesivas
# a02       22/07/2021        M. Llaja      Error en asignacion manual en lineas de pedido
#####################################################################################################

$ACTION

Case ACTION
  When "MAJCDEALL"        :   Gosub MAJCDEALL
  When "AFTGENALLORD"     :   Gosub AFTGENALLORD
Endcase
Return
#############################################################################
#ASIGNACIÓN ESPECÍFICA Y LÍNEAS
#############################################################################
$MAJCDEALL

  If !clalev([F:ZITF4]) : Local File ITMFACILIT [F:ZITF4] : Endif
  If !clalev([F:ZSOQ4]) : Local File SORDERQ    [F:ZSOQ4] : Endif
  If !clalev([F:ZSTA2]) : Local File STOALL     [F:ZSTA2] : Endif
  If !clalev([F:ZSTA4]) : Local File STOALL     [F:ZSTA4] : Endif
  If !clalev([F:ZSTA5]) : Local File STOALL     [F:ZSTA5] : Endif
  If !clalev([F:ZSTO4]) : Local File STOCK      [F:ZSTO4] : Endif
  If !clalev([F:ZITV4]) : Local File ITMMVT     [F:ZITV4] : Endif

  Local Decimal ZDISPTEMP,ZPEND,ZRUPTURA,ZASIGSTD,ZASIGSPE,ZSTOCOU: Raz ZDISPTEMP,ZPEND,ZRUPTURA,ZASIGSTD,ZASIGSPE,ZSTOCOU

  Read [F:ZSOQ4]SOQ0 = [F:SOH]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
  Read [F:ZITF4]ITF0 = [F:ITM]ITMREF;[F:SOH]STOFCY
  If  (dim([F:STO]LOC)>0 or dim([F:STA]LOC)>0) Then

#      If ([F:SOH]SOHTYP ="ORD20" or  [F:SOH]SOHTYP ="ORD21") and [F:SOH]STOFCY="900" and  [F:ZITF4]DEFLOCTYP(0) ="098"Then
#      Else
      If ([F:SOH]SOHTYP <>"ORD20" and  [F:SOH]SOHTYP <>"ORD21") and [F:SOH]STOFCY="900" and  [F:ZITF4]ZRESERVB2C > 0 Then

        ZPEND = [F:SOQ]QTYSTU-[F:SOQ]DLVQTY-[F:SOQ]ODLQTY
        If ZPEND > 0 and [F:ZITF4]ZRESERVB2C > 0  and dim(ZDISP)>0  Then

           ZDISPTEMP = ZDISP-[F:ZITF4]ZRESERVB2C
           If ZDISPTEMP <0 Then
               ZDISPTEMP = 0
           Endif

            If ZDISPTEMP < ZPEND and ZDISPTEMP <= [F:ZSOQ4]ALLQTY
#                If GFONCTION ='GESZASIG' Then
#                  Gosub ASIG_SPE
#                Else
                  Gosub ASIG_STD
#                Endif

            Endif
         Endif
      Endif
  Endif
  If dim(ZDISP) > 0 Then
    Kill ZDISP
  Endif
  If dim(ZASIGSTD) > 0 Then
    Kill ZASIGSTD
  Endif
  If dim(ZOKRUP)> 0 Then
   Kill ZOKRUP
  Endif
  #002>
  Delete [F:ZSTA4] Where QTYSTU =0 and ALLTYP = 2 and VCRNUM =  [F:SOH]SOHNUM and VCRLIN = [F:SOQ]SOPLIN and VCRSEQ = [F:SOQ]SOQSEQ and ITMREF = [F:SOQ]ITMREF
  #002<
  #ai01
  Gosub ACTUALIZAR_SOQ_ORDERS
  #af01
Return
#############################################################################
#ASIGNACIÓN ESTÁNDAR
#############################################################################
$AFTGENALLORD
#incidencia asignado negativo

  If !clalev([F:ZITF4]) : Local File ITMFACILIT [F:ZITF4] : Endif
  If !clalev([F:ZSOQ4]) : Local File SORDERQ    [F:ZSOQ4] : Endif
  If !clalev([F:ZITV4]) : Local File ITMMVT     [F:ZITV4] : Endif
  If !clalev([F:ZSTA5]) : Local File STOALL     [F:ZSTA5] : Endif
  If !clalev([F:ZSTA2]) : Local File STOALL     [F:ZSTA2] : Endif
  If !clalev([F:ZSTO4]) : Local File STOCK      [F:ZSTO4] : Endif
  If !clalev([F:ZITV4]) : Local File ITMMVT     [F:ZITV4] : Endif
  Local Decimal ZDISPTEMP,ZPEND,ZRUPTURA,ZSTOCOU,ZASIGSTD: Raz ZDISPTEMP,ZPEND,ZRUPTURA,ZSTOCOU,ZASIGSTD

  Read [F:ZSOQ4]SOQ0 = [F:SOH]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
  Read [F:ZITF4]ITF0 = [F:ITM]ITMREF;[F:SOH]STOFCY

#      If ([F:SOH]SOHTYP ="ORD20" or  [F:SOH]SOHTYP ="ORD21") and [F:SOH]STOFCY="900" and  [F:ZITF4]DEFLOCTYP(0) ="098" Then
#
#      Else
       If ([F:SOH]SOHTYP <>"ORD20" and  [F:SOH]SOHTYP <>"ORD21") and [F:SOH]STOFCY="900" and  [F:ZITF4]ZRESERVB2C > 0 Then
        #cantidad pendiente
        ZPEND = [F:SOQ]QTYSTU-[F:SOQ]DLVQTY-[F:SOQ]ODLQTY
         #LTRTLIG<>A -> Distinto de cancelación asiganación
        If ZPEND > 0 and [F:ZITF4]ZRESERVB2C > 0  and dim(ZDISP)>0  and LTRTLIG<>"A" Then

           ZDISPTEMP = ZDISP-[F:ZITF4]ZRESERVB2C
           If ZDISPTEMP <0 Then
               ZDISPTEMP = 0
           Endif

          If ZDISPTEMP < ZPEND
                 #ASIGANCIÓN SIN MODIFICACIÓN DE CANTIDAD PEDIDA
                 If [F:ZSOQ4]QTY = [F:SOQ]QTY Then

                      #001> Segunda asignación con disponible mayor que 0 pero contando el reservado menor que 0
                      If ZDISPTEMP = 0 Then
                        [F:ZSOQ4]ALLQTY      = [F:SOQ]ALLQTY
                        [F:ZSOQ4]ALLQTYSTU   = [F:SOQ]ALLQTY
                        If LGENSHT = 1 Then
                          [F:ZSOQ4]SHTQTY    = 0
                          [F:ZSOQ4]SHTQTYSTU = 0
                        Else
                          [F:ZSOQ4]SHTQTY      = ZPEND - [F:SOQ]ALLQTY
                          [F:ZSOQ4]SHTQTYSTU   = ZPEND - [F:SOQ]ALLQTY
                        Endif
                        Rewrite [F:ZSOQ4]
                        If LGENSHT = 1 Then
                           WSVGSHTSTU = 0
                        Else
                           WSVGSHTSTU = ZPEND - [F:SOQ]ALLQTY
                        Endif
                        WSVGALLSTU = [F:SOQ]ALLQTY
                      Else
                        If [F:SOQ]ALLQTY > 0 Then #15/04/2021 caso asignacióm total con cantidad parcial asignada anteriormente
                          [F:ZSOQ4]ALLQTY      = ZDISPTEMP #Le suma lo ya asignado en SUBSOHB
                          [F:ZSOQ4]ALLQTYSTU   = ZDISPTEMP
                          If LGENSHT = 1 Then
                            [F:ZSOQ4]SHTQTY      = 0
                            [F:ZSOQ4]SHTQTYSTU   = 0
                          Else
                            [F:ZSOQ4]SHTQTY      = (ZPEND-(ZDISPTEMP + [F:SOQ]ALLQTY))
                            [F:ZSOQ4]SHTQTYSTU   = (ZPEND-(ZDISPTEMP + [F:SOQ]ALLQTY))
                          Endif
                        Else
                          [F:ZSOQ4]ALLQTY      = ZDISPTEMP
                          [F:ZSOQ4]ALLQTYSTU   = ZDISPTEMP
                          If LGENSHT = 1 Then
                            [F:ZSOQ4]SHTQTY      = 0
                            [F:ZSOQ4]SHTQTYSTU   = 0
                          Else
                            [F:ZSOQ4]SHTQTY      = ZPEND-ZDISPTEMP
                            [F:ZSOQ4]SHTQTYSTU   = ZPEND-ZDISPTEMP
                          Endif
                        Endif
                        Rewrite [F:ZSOQ4]
                        If LGENSHT = 1 Then
                          WSVGSHTSTU = 0
                        Else
                          WSVGSHTSTU = [F:ZSOQ4]SHTQTY
                        Endif
                        WSVGALLSTU = [F:ZSOQ4]ALLQTY
                      Endif
                      #CONTROL ASIGNACIONES
                      Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 2 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
                      Read [F:ZSTA5]STA0 First
                      #Asignaciones
                      If !fstat Then

                         ZSTOCOU = [F:ZSTA5]STOCOU
                         ZASIGSTD            =  [F:ZSTA5]QTYSTU
                         Raz [F:ZSTA5]QTYSTU,[F:ZSTA5]QTYSTUACT
                         If [F:SOQ]ALLQTY > 0 Then
                           [F:ZSTA5]QTYSTU     = ZDISPTEMP + [F:SOQ]ALLQTY
                           [F:ZSTA5]QTYSTUACT  = ZDISPTEMP + [F:SOQ]ALLQTY
                         Else
                           [F:ZSTA5]QTYSTU     = ZDISPTEMP
                           [F:ZSTA5]QTYSTUACT  = ZDISPTEMP
                         Endif
                         ZASIGSPE = [F:ZSTA5]QTYSTU
                         Rewrite [F:ZSTA5]
                         #Se crea ruptura en el caso de haber stock físico con reserva B2C
                         If  [F:ZSTA5]QTYSTU < ZPEND and ZDISPTEMP < ZPEND and (ZDISP >=(ZPEND-[F:SOQ]ALLQTY)) and LGENSHT <> 1  Then
                           Raz [F:ZSTA2]
                           [F:ZSTA2]          = [F:ZSTA5]
                           [F:ZSTA2]STOCOU    = 0
                           [F:ZSTA2]ALLTYP    = 4
                           [F:ZSTA2]SEQ       = [F:ZSTA5]SEQ-1
                           [F:ZSTA2]QTYSTU    = 0
                           [F:ZSTA2]QTYSTUACT = 0
                           [F:ZSTA2]LOC       = "098"
                           Write [F:ZSTA2]
                         Endif
                      Endif
                      Filter [F:ZSTA5]

                      Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
                      Read [F:ZSTA5]STA0 First
                      #Rupturas
                      If !fstat Then
                          [F:ZSTA5]QTYSTUACT =  ZPEND - ZASIGSPE
                         Rewrite [F:ZSTA5]
                      Endif
                      Filter [F:ZSTA5]

                      #CONTROL STOCK
                      Read [F:ZSTO4]STO0 = [F:SOH]STOFCY;ZSTOCOU
                      If !fstat Then
                          #Caso asignación pedido
                          If [F:SOQ]ALLQTY > 0 Then #Si ya habia asignado
                            [F:ZSTO4]CUMALLQTY -= ZASIGSTD
                            [F:ZSTO4]CUMALLQTY += ZASIGSPE
                            [F:ZSTO4]CUMALLQTA -= ZASIGSTD
                            [F:ZSTO4]CUMALLQTA += ZASIGSPE
                          Else #Si no lo había

                            [F:ZSTO4]CUMALLQTY -= ZASIGSTD
                            [F:ZSTO4]CUMALLQTY += [F:ZSOQ4]ALLQTY
                            [F:ZSTO4]CUMALLQTA -= ZASIGSTD
                            [F:ZSTO4]CUMALLQTA += [F:ZSOQ4]ALLQTY
                          Endif
                          Rewrite [F:ZSTO4]
                      Endif


                      #CONTROL MOVIMIENTOS
                      Read [F:ZITV4]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY
                      If !fstat Then
                         #Caso asignación pedido
                         If [F:SOQ]ALLQTY > 0 Then
                           [F:ZITV4]PHYALL -= ZASIGSTD
                           [F:ZITV4]PHYALL += ZASIGSPE
                           If LGENSHT <> 1 Then
                             [F:ZITV4]DETSHT += (ZASIGSTD -ZASIGSPE)
                           Endif
                         Else
                           [F:ZITV4]PHYALL -= (ZASIGSTD-[F:ZSOQ4]ALLQTY)
                           If LGENSHT <> 1 Then
                             [F:ZITV4]DETSHT += (ZASIGSTD -[F:ZSOQ4]ALLQTY)
                           Endif
                         Endif
                         Rewrite [F:ZITV4]
                      Endif

                  Else
                      #ASIGANCIÓN CON MODIFICACIÓN DE CANTIDAD PEDIDA
                      #Para este caso hay que volver a modificar la ruptura, vuelve a asignarla el estándar despues del EP BEFREWITV
                      #Se pone a cero porque la cantidad asignada se acumula en SUBSOHA (Línea 3283)
                      [F:ZSOQ4]ALLQTY      = 0
                      [F:ZSOQ4]ALLQTYSTU   = 0
                      If LGENSHT = 1 Then
                        [F:ZSOQ4]SHTQTY      = 0
                        [F:ZSOQ4]SHTQTYSTU   = 0
                        WSVGSHTSTU           = 0
                      Else
                        [F:ZSOQ4]SHTQTY      = ZPEND-[F:SOQ]ALLQTY
                        [F:ZSOQ4]SHTQTYSTU   = ZPEND-[F:SOQ]ALLQTY
                        WSVGSHTSTU = ZPEND-[F:SOQ]ALLQTY
                      Endif
                      WSVGALLSTU = 0
                      #CONTROL ASIGNACIONES
                      Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 2 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
                      Read [F:ZSTA5]STA0 First
                      #Asignaciones
                      If !fstat Then
                         ZSTOCOU            =  [F:ZSTA5]STOCOU
                         ZASIGSTD           =  [F:ZSTA5]QTYSTU
                         [F:ZSTA5]QTYSTU    =  [F:SOQ]ALLQTY
                         [F:ZSTA5]QTYSTUACT =  [F:SOQ]ALLQTY
                         Rewrite [F:ZSTA5]

                      Endif
                      Filter [F:ZSTA5]

                      Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
                      Read [F:ZSTA5]STA0 First
                      #Rupturas
                      If !fstat Then
                         [F:ZSTA5]QTYSTUACT = (ZPEND-[F:SOQ]ALLQTY)
                         Rewrite [F:ZSTA5]
                      Else
                        If  [F:ZSTA5]QTYSTU < ZPEND and ZDISPTEMP < ZPEND and LGENSHT <> 1 Then
                             Raz [F:ZSTA2]
                             [F:ZSTA2]          = [F:ZSTA5]
                             [F:ZSTA2]STOCOU    = 0
                             [F:ZSTA2]ALLTYP    = 4
                             [F:ZSTA2]SEQ       = [F:ZSTA5]SEQ-1
                             [F:ZSTA2]QTYSTU    = 0
                             [F:ZSTA2]QTYSTUACT =  (ZPEND-[F:SOQ]ALLQTY)#ZASIGSTD-ZDISPTEMP
                             [F:ZSTA2]LOC       = "098"
                             Write [F:ZSTA2]
                         Endif
                      Endif
                      Filter [F:ZSTA5]
                      #CONTROL STOCK
                      Read [F:ZSTO4]STO0 = [F:SOH]STOFCY;ZSTOCOU
                      If !fstat Then
                          #Caso asignación pedido
                          [F:ZSTO4]CUMALLQTY -= (ZASIGSTD-[F:SOQ]ALLQTY)
                          [F:ZSTO4]CUMALLQTA -= (ZASIGSTD-[F:SOQ]ALLQTY)
                          Rewrite [F:ZSTO4]
                      Endif

                      #CONTROL MOVIMIENTOS
                      Read [F:ZITV4]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY
                      If !fstat Then
                         #Caso asignación pedido
                         [F:ZITV4]PHYALL -= (ZASIGSTD-[F:SOQ]ALLQTY)
                         If LGENSHT = 1 Then
                           [F:ZITV4]DETSHT = 0
                         Else
                           [F:ZITV4]DETSHT = func ZRUPTURA([F:ZITV4]STOFCY,[F:ITV]ITMREF)
                         Endif
                         Rewrite [F:ZITV4]
                      Endif
                      #Se escribe a posteriori para no perder el valor original de [F:SOQ]
                      Rewrite [F:ZSOQ4]
                  Endif
            Endif
         Endif
      Endif
  If dim(ZDISP) > 0 Then
    Kill ZDISP
  Endif
  If dim(ZASIGSTD) > 0 Then
    Kill ZASIGSTD
  Endif
  #002>
  Delete [F:ZSTA5] Where QTYSTU =0 and ALLTYP = 2 and VCRNUM =  [F:SOH]SOHNUM and VCRLIN = [F:SOQ]SOPLIN and VCRSEQ = [F:SOQ]SOQSEQ and ITMREF = [F:SOQ]ITMREF
  #002<
Return

#####################################################################################################################
$ASIG_SPE
    ZASIGSTD        = [F:SOQ]ALLQTY
    [F:SOQ]ALLQTY - = ZASIGSTD-ZDISPTEMP

    If [F:SOQ]ALLQTY < 0 Then
      [F:SOQ]ALLQTY = 0
    Endif
    If ZDISPTEMP = 0 Then

      [F:ZSOQ4]ALLQTY      = 0
      [F:ZSOQ4]ALLQTYSTU   = 0
      [F:ZSOQ4]SHTQTY    + = ZASIGSTD
      [F:ZSOQ4]SHTQTYSTU + = ZASIGSTD
    Else

      [F:ZSOQ4]ALLQTY      = [F:SOQ]ALLQTY
      [F:ZSOQ4]ALLQTYSTU   = [F:SOQ]ALLQTY
      [F:ZSOQ4]SHTQTY    + = ZASIGSTD-ZDISPTEMP
      [F:ZSOQ4]SHTQTYSTU + = ZASIGSTD-ZDISPTEMP
    Endif

    Rewrite  [F:ZSOQ4]

    #CONTROL ASIGNACIONES
    Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 2 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
    Read [F:ZSTA5]STA0 First
    #Asignaciones
    If !fstat Then
       ZSTOCOU = [F:ZSTA5]STOCOU
       [F:ZSTA5]QTYSTU    = [F:SOQ]ALLQTY
       [F:ZSTA5]QTYSTUACT = [F:SOQ]ALLQTY
       Rewrite [F:ZSTA5]
       Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
       Read [F:ZSTA5]STA0 First
       If fstat Then
           If  [F:ZSTA5]QTYSTUACT < ZPEND  Then
             Raz [F:ZSTA2]
             [F:ZSTA2]          = [F:ZSTA5]
             [F:ZSTA2]STOCOU    = 0
             [F:ZSTA2]ALLTYP    = 4
             [F:ZSTA2]SEQ       = [F:ZSTA5]SEQ-1
             [F:ZSTA2]QTYSTU    = 0
             [F:ZSTA2]QTYSTUACT = 0#ZASIGSTD-ZDISPTEMP
             [F:ZSTA2]LOC       = "098"
             Write [F:ZSTA2]
           Endif
      Endif
    Endif
    Filter [F:ZSTA5]

    Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
    Read [F:ZSTA5]STA0 First
    #Rupturas
    If !fstat Then
       [F:ZSTA5]QTYSTUACT = (ZPEND-[F:SOQ]ALLQTY)
       Rewrite [F:ZSTA5]
    Endif
    Filter [F:ZSTA5]
    #CONTROL STOCK
    Read [F:ZSTO4]STO0 = [F:SOH]STOFCY;ZSTOCOU
    If !fstat Then
        #Caso asignación pedido
        [F:ZSTO4]CUMALLQTY -= (ZASIGSTD-[F:SOQ]ALLQTY)
        [F:ZSTO4]CUMALLQTA -= (ZASIGSTD-[F:SOQ]ALLQTY)
        Rewrite [F:ZSTO4]
    Endif

    #CONTROL MOVIMIENTOS
    Read [F:ZITV4]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY
    If !fstat Then
       #Caso asignación pedido
       [F:ZITV4]PHYALL -= (ZASIGSTD-[F:SOQ]ALLQTY)
       [F:ZITV4]DETSHT += (ZASIGSTD -[F:SOQ]ALLQTY)
       Rewrite [F:ZITV4]
    Endif

Return
#####################################################################################################################

$ASIG_STD
#ai02
If dim(ZOKRUP)<0
  Global Integer ZOKRUP
Endif
If GFONCTION ='GESZASIG' or GFONCTION = "GESZASIGM" Then
   ZOKRUP = 1
Endif
#af02
    ZASIGSTD        = [F:SOQ]ALLQTY
    [F:SOQ]ALLQTY - = ZASIGSTD-ZDISPTEMP

    If [F:SOQ]ALLQTY < 0 Then
      [F:SOQ]ALLQTY = 0
    Endif
    If ZDISPTEMP = 0 Then

      [F:ZSOQ4]ALLQTY      = 0
      [F:ZSOQ4]ALLQTYSTU   = 0
      If ZOKRUP = 1 Then
        [F:ZSOQ4]SHTQTY    + = ZASIGSTD
        [F:ZSOQ4]SHTQTYSTU + = ZASIGSTD
      Else
        [F:ZSOQ4]SHTQTY    + = 0
        [F:ZSOQ4]SHTQTYSTU + = 0
      Endif
    Else

      [F:ZSOQ4]ALLQTY      = [F:SOQ]ALLQTY
      [F:ZSOQ4]ALLQTYSTU   = [F:SOQ]ALLQTY
      If ZOKRUP = 1 Then
        [F:ZSOQ4]SHTQTY    + = ZASIGSTD-ZDISPTEMP
        [F:ZSOQ4]SHTQTYSTU + = ZASIGSTD-ZDISPTEMP
      Else
        [F:ZSOQ4]SHTQTY    + = 0
        [F:ZSOQ4]SHTQTYSTU + = 0
      Endif
    Endif

    Rewrite  [F:ZSOQ4]

    #CONTROL ASIGNACIONES
    Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 2 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
    Read [F:ZSTA5]STA0 First
    #Asignaciones
    If !fstat Then
       ZSTOCOU = [F:ZSTA5]STOCOU
       [F:ZSTA5]QTYSTU    = [F:ZSOQ4]ALLQTY
       [F:ZSTA5]QTYSTUACT = [F:ZSOQ4]ALLQTY
       Rewrite [F:ZSTA5]
       Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
       Read [F:ZSTA5]STA0 First
       If fstat Then
           If  [F:ZSTA5]QTYSTUACT < ZPEND and ZOKRUP = 1  Then
             Raz [F:ZSTA2]
             [F:ZSTA2]          = [F:ZSTA5]
             [F:ZSTA2]STOCOU    = 0
             [F:ZSTA2]ALLTYP    = 4
             [F:ZSTA2]SEQ       = [F:ZSTA5]SEQ-1
             [F:ZSTA2]QTYSTU    = 0
             [F:ZSTA2]QTYSTUACT = 0#ZASIGSTD-ZDISPTEMP
             [F:ZSTA2]LOC       = "098"
             Write [F:ZSTA2]
           Endif
      Endif
    Endif
    Filter [F:ZSTA5]

    Filter [F:ZSTA5] Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = [F:SOH]STOFCY and VCRNUM=[F:SOH]SOHNUM and VCRLIN =[F:SOQ]SOPLIN and ITMREF=[F:SOQ]ITMREF
    Read [F:ZSTA5]STA0 First
    #Rupturas
    If !fstat Then
       If ZOKRUP = 1 Then
         [F:ZSTA5]QTYSTUACT = (ZPEND-[F:ZSOQ4]ALLQTY)
       Else
         [F:ZSTA5]QTYSTUACT = 0
       Endif
       Rewrite [F:ZSTA5]
    Endif
    Filter [F:ZSTA5]
    #CONTROL STOCK
    Read [F:ZSTO4]STO0 = [F:SOH]STOFCY;ZSTOCOU
    If !fstat Then
        #Caso asignación pedido
        [F:ZSTO4]CUMALLQTY -= (ZASIGSTD-[F:ZSOQ4]ALLQTY)
        [F:ZSTO4]CUMALLQTA -= (ZASIGSTD-[F:ZSOQ4]ALLQTY)
        Rewrite [F:ZSTO4]
    Endif

    #CONTROL MOVIMIENTOS
    Read [F:ZITV4]ITV0 = [F:ITV]ITMREF;[F:ITV]STOFCY
    If !fstat Then
       #Caso asignación pedido
       [F:ZITV4]PHYALL -= (ZASIGSTD-[F:ZSOQ4]ALLQTY)
       If ZOKRUP = 1 Then
         [F:ZITV4]DETSHT += (ZASIGSTD -[F:ZSOQ4]ALLQTY)
       Else
         [F:ZITV4]DETSHT += 0
       Endif
       Rewrite [F:ZITV4]
    Endif

Return

#############################################################################
$ACTUALIZAR_SOQ_ORDERS #a01 corrige errores en campos de asignación
#############################################################################
Local Decimal TMPASIG : Raz TMPASIG
Local Decimal TMPRUPT : Raz TMPRUPT
If clalev ([F:ZSTAX]) = 0 Local File STOALL[ZSTAX] : Endif
If clalev ([F:ZORDX]) = 0 Local File ORDERS[ZORDX] : Endif
If clalev ([F:ZSOQX]) = 0 Local File SORDERQ[ZSOQX] : Endif

Read [F:ZORDX]ORD0 = 1;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
If !fstat
  For [F:ZSTAX] Where [F:ZSTAX]VCRNUM = [F:SOQ]SOHNUM and [F:ZSTAX]VCRLIN = [F:SOQ]SOPLIN and [F:ZSTAX]ITMREF = [F:SOQ]ITMREF
&     and [F:ZSTAX]STOFCY = [F:SOQ]STOFCY
    If [F:ZSTAX]ALLTYP = 2
      TMPASIG += [F:ZSTAX]QTYSTU
    Elsif [F:ZSTAX]ALLTYP = 4
      TMPRUPT += [F:ZSTAX]QTYSTUACT
    Endif
  Next
  [F:ZORDX]ALLQTY = TMPASIG
  [F:ZORDX]SHTQTY = TMPRUPT
  Rewrite [F:ZORDX]

  Read [F:ZSOQX]SOQ0 = [F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
  If !fstat
    [F:ZSOQX]ALLQTY = TMPASIG
    [F:ZSOQX]ALLQTYSTU = TMPASIG
    If TMPRUPT >= 0
      [F:ZSOQX]SHTQTY = TMPRUPT
      [F:ZSOQX]SHTQTYSTU = TMPRUPT
    Endif
    Rewrite [F:ZSOQX]
  Endif
Endif

Return

########################################################################
#CALCULA UNIDADES EN RUPTURA
########################################################################
Funprog ZRUPTURA(P_STOFCY,P_ITMREF)
  Value Char P_STOFCY,P_ITMREF
  Local Decimal ZRUP : Raz ZRUP
  If !clalev([F:ZSTA6]) : Local File STOALL     [F:ZSTA6] : Endif

  For [F:ZSTA6]STA0 Where VCRTYP= 2 and ALLTYP= 4 and STOFCY = P_STOFCY  and ITMREF=P_ITMREF
    ZRUP+= [F:ZSTA6]QTYSTUACT
  Next
End ZRUP
