#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
   When "SOHALLSEL"        :   Gosub SOHALLSEL

Endcase
Return

######################################################################
$SOHALLSEL

 If !clalev([F:ZITF5]) : Local File ITMFACILIT [F:ZITF5] : Endif

  Local Decimal ZDISPONIBLE: Raz ZDISPONIBLE
 Local Decimal ZDISPTEMP   : Raz ZDISPTEMP

 Read [F:ZITF5]ITF0  = [M:SOH4]ITMREF(nolign-1);[F:SOH]STOFCY


 If ([F:SOH]SOHTYP <>"ORD20" and  [F:SOH]SOHTYP <>"ORD21") and [F:SOH]STOFCY="900" and [F:ZITF5]ZRESERVB2C > 0   Then


    ZDISPONIBLE = func ZDISPONIBLE([F:SOH]STOFCY,"098",[M:SOH4]ITMREF(nolign-1))
    ZDISPTEMP = ZDISPONIBLE-[F:ZITF5]ZRESERVB2C
    If ZDISPTEMP < 0 Then
      ZDISPTEMP = 0
    Endif
     # WTRTALL ES 1 SI ES ASIGNACIÓN , 2 DESASIGNACIÓN
     If ZDISPTEMP = 0 and ZDISPONIBLE > 0 and WTRTALL = 1 Then
           OK=1 #INTERRUMPE LA TRANSACCIÓN
           WMESS1 ="Stock no disponible del artículo"-[M:SOH4]ITMREF(nolign-1)-".Hay stock reservado para B2C."
     Endif
 Endif
Return

##########################################################################################
Funprog ZDISPONIBLE(P_STOFCY,P_LOC,P_ITMREF)
  Value Char P_STOFCY,P_LOC,P_ITMREF

  Local Integer ZRES : Raz ZRES

  If !clalev([F:ZSTO3]) : Local File STOCK     [F:ZSTO3] : Endif

  For [F:ZSTO3]STO0 Where STOFCY = P_STOFCY and LOC = P_LOC and LOCCAT = 1 and STA ='A' and ITMREF = P_ITMREF
       ZRES += [F:ZSTO3]QTYSTU-[F:ZSTO3]CUMALLQTA
  Next

End ZRES
