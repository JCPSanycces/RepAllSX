#<AdxTL>@(#)0.0.0.0 $Revision$ Entregas
# Gestiµn de la mÃscara SDH0 (Especifico)
#FPH - 001- 26/08/2020 - Se carga campo informativo del volumen total de lÚenas
#FPH - 002 - 6.109.524 - 16/10/2020 - Solo Fenella, Alirio (y Admin) pueden modificar manualmente el campo ESTADO NAEKO en entregas
#MRE - 002 - 6.155.206 - 25/01/2021 - Maelys tambiÕn puede cambiar manualmente el campo ESTADO NAEKO en entregas
#AMG - 003 - 6.358.865 -16/06/2022 Usuario Sage X3, Alirio ya no trabaja en NBZ y juan carlos solicita el cambio
# 6.187.210 ML 11/09/2021 Interface Magento 2
######################################################################################
## AUREN - CONTROLES ESPECëFICOS ENTREGA DE VENTA
######################################################################################
$ACTION
Case ACTION
 When "SETBOUT"     :   Gosub SETBOUT
 When "EXEBOUT"     :   Gosub EXEBOUT
 When "VERIF_CRE"   :   Gosub VERIF_CRE
 When "LIENS"       :   Gosub LIENS
 When "AP_ANNULE"   :   Gosub AP_ANNULE
 When Default
Endcase
Return

######################################################################################

$LIENS
 #001>
 If [M:SDH2]VOU ="" Then
   [M:SDH2]VOU = [F:SDH]DSPVOU
   Affzo  [M:SDH2]VOU
 Endif
 [M:SDH2]ZVOLLIN  = [F:SDH]DSPTOTVOL
 Affzo  [M:SDH2]ZVOLLIN
 #001<
Return

######################################################################################
$SETBOUT
  # Botµn 'Autorizar expediciµn' no activo si:
  # entrega validada, o estado NAEKO confirmada o autorizada, o modo consulta o planta expediciµn <> 900
  If GCONSULT or [M]CFMFLG=2 or [M]ZSTANAEKO=4 or [M]ZSTANAEKO=2 or [M]STOFCY<>"900"
    Call VIREBOUT(CHAINE,"z") From GOBJET
  Endif
  # Botµn VALIDAR no activo si planta exp 900 y entrega NAEKO no confirmada
  If [M]STOFCY="900" and [M]ZSTANAEKO<>4
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
  If mkstat=4 and GREP=""  :  REP="M"   : Endif

  #002>
  If !GIMPORT
  #003>
    If (GUSER="FBING" or GUSER="JCFUE" or GUSER="MCOUS" or GUSER ="ADMIN")  Then
  #003<
      Actzo [M:SDH0]ZSTANAEKO
    Else
      Diszo [M:SDH0]ZSTANAEKO
    Endif
    Affzo [M:SDH0]ZSTANAEKO
  Endif
  #002<
Return
######################################################################################
$EXEBOUT
Local Libelle RES
  Case BOUT
  When "z"  :
    If [M]STOFCY='900' and [M]ZSTANAEKO=3
      RES=2
      Qstbox "Orden de expediciciµn ya solicitada ¢Desea enviar nueva solicitud?" Using [L]RES
      Case [L]RES
        When 1  : Gosub UPDZSTANAEKO
        When 2  : End
      Endcase
    Endif
    If [M]STOFCY="900" and [M]ZSTANAEKO<2
      Gosub UPDZSTANAEKO
    Endif
  Endcase
Return
######################################################################################
$VERIF_CRE
  If [M]ZSTANAEKO<1  :  [M]ZSTANAEKO=1  :  Endif
  Affzo [M:SDH0]ZSTANAEKO
Return
######################################################################################
$UPDZSTANAEKO
  [M:SDH0]ZSTANAEKO=2
  Affzo [M:SDH0]ZSTANAEKO
  mkstat = 4
Return

#################################################
$AP_ANNULE #
# 6.187.210.ini
If !clalev([F:ZMG2DEL]) : Local File ZMG2DEL[ZMG2DEL]  : Endif
Raz [F:ZMG2DEL]
[F:ZMG2DEL]VCRNUM=[M:SDH0]SDHNUM
Write [F:ZMG2DEL]
# 6.187.210.fin
Return
