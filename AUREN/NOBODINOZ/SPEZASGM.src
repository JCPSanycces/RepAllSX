Subprog B1_NBLIG
 Local Char PARBOUT(250)(1..20)
 PARBOUT(1) = [M:ZASGM2]ZSOHNUM(nolign-1)
 PARBOUT(2) = "SOH"
 PARBOUT(3) = ""
 GACTION    = "GOBJETC1"
 Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
End


######################################################################################
Subprog IMPORTES_AI()
  Local Decimal ZASIG
  Raz ZASIG
  Local Integer J

  For J=0 To [M:ZASGM2]NBLIG - 1
    ZASIG +=  [M:ZASGM2]ZIMPASIG   (J)
  Next
  [M:ZASGM1]ZIMPASIGAI = ZASIG
  Affzo [M:ZASGM1]
End


Subprog UPD_DEASIG_SOH(NUM,LIN,SEQ)
Value Char NUM
Value Integer LIN,SEQ
Local Integer FGSERVEUR : FGSERVEUR=GSERVEUR
GSERVEUR = 1
Gosub INIT From FUNDESALL
[M:DIA]STOFCY = [M:ZASGM0]ZSTOFCY
[M:DIA]SHIDAT = date$
[M:DIA]SOHNUMDEB = NUM
[M:DIA]SOHNUMFIN = NUM
[M:DIA]ALLCRITENT = "[F:SOQ]SOPLIN="+ num$(LIN)
Gosub EXEC From FUNDESALL
Gosub TERMINE From FUNDESALL
GSERVEUR = FGSERVEUR
End
