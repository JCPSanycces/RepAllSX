#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZASGM
# Description : Asignaciones multiproducto
# Module      : Ventas
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espańa
# Created date: 22/07/2021
############################################################################
################################################################
$ACTION
  Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "DEBUT"      : Gosub DEBUT
   When "BOUTON"     : Gosub BOUTON
   When "SETBOUT"    : Gosub SETBOUT
   When Default
  Endcase
Return

################################################################
$OUVRE
################################################################
If !clalev([F:ZSOH1]) : Local File SORDER    [F:ZSOH1] : Endif
If !clalev([F:ZSOQ1]) : Local File SORDERQ   [F:ZSOQ1] : Endif
If !clalev([F:ZSOP1]) : Local File SORDERP   [F:ZSOP1] : Endif
If !clalev([F:ZSTO1]) : Local File STOCK     [F:ZSTO1] : Endif
If !clalev([F:ZITM])  : Local File ITMMASTER [F:ZITM]  : Endif
If !clalev([F:ZITF1]) : Local File ITMFACILIT[F:ZITF1] : Endif
If !clalev([F:ZPOQ])  : Local File PORDERQ   [F:ZPOQ]  : Endif
If !clalev([F:ZPTD])  : Local File PRECEIPTD [F:ZPTD]  : Endif
Return

################################################################

$SETBOUT
 Local Integer I

# If [M:ZASGM0]ZITMREF = "" Then
#    Diszo [M:ZASGM2]ZASIGNACION
#    Diszo [M:ZASGM2]ZFECHAEXP
# Else
#    Actzo [M:ZASGM2]ZASIGNACION
#    Actzo [M:ZASGM2]ZFECHAEXP
# Endif
# Affzo [M:ZASGM2]
Return

################################################################
$DEBUT
 [M:ZASGM0]ZSTOFCY    ='900'
 [M:ZASGM0]ZLOCTYP    ='098'
 [M:ZASGM0]ZSTAORDFIR = 2
 [M:ZASGM0]ZPRINORMAL = 2
 [M:ZASGM0]ZPRIURG    = 2
 [M:ZASGM0]ZPRIMURG   = 2
 [M:ZASGM0]ZEPARAUT   = 2
 [M:ZASGM0]ZEPLINCOM  = 2
 [M:ZASGM0]ZEPPEDCOM  = 2
 Affzo [M:ZASGM0]
 ACTION=""
Return
################################################################
$BOUTON

  Case BOUT
     When "1"  :  Local Char VALBOUT(250), PARBOUT(250)(1..20)
                  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OZCRITASIGM","SPEZCASGM","SPEZCASGM") From GSAISIE

     When "2"  :  Call BUSCAR()

     When "4"  : If !clalev([F:ZSOH2])  : Local File SORDER    [F:ZSOH2] : Endif
                 If !clalev([F:ZSOQ2])  : Local File SORDERQ   [F:ZSOQ2] : Endif
                 If !clalev([F:ZTASG2]) : Local File ZTMPASIGM [F:ZTASG2] : Endif

                 If !clalev([F:ZITF2]) : Local File ITMFACILIT [F:ZITF2] : Endif
                 Local Decimal ZDISPTEMP,ZASIGN,ZPEND,ZASIGSTD,ZQTYTEMP: Raz ZDISPTEMP,ZASIGN,ZPEND,ZASIGSTD,ZQTYTEMP

                 Local Integer I,J,YN : YN = 1
                 For I=0 To [M:ZASGM2]NBLIG - 1
                     If [M:ZASGM2]ZASIGNACION (I) <  0 Then
                       Call MESSAGE("No se permiten asiganciones negativas")From GESECRAN
                       Return
                     Endif
                  Next
                  If (func ACTUALIZAR <> 2)  Then
                    Call MESSAGE("No hay datos a actualizar") From GESECRAN
                    Return
                  Else
                    Call OUINON("El cambio no podrá deshacerse. żDesea actualizar los datos?",YN) From GESECRAN
                    If (YN = 2) Then
                        For I=0 To [M:ZASGM2]NBLIG - 1
                          If [M:ZASGM2]ZASIGNACION (I) <>  0
                            If func CONTROL_STOCK([M:ZASGM0]ZSTOFCY,[M:ZASGM2]ZITMREF(I)) = 1
                              Call MESSAGE("No hay suficiente stock "+[M:ZASGM2]ZITMREF(I)+" .Actualización cancelada")From GESECRAN
                              Return
                            Endif
                          Endif
                        Next

                        #Actualización stock
                        Delete  [F:ZTASG2] Where ZUSER = GUSER
                        For I=0 To [M:ZASGM2]NBLIG - 1
                          If [M:ZASGM2]ZASIGNACION  (I) <> [M:ZASGM2]ZALLQTY (I)  Then

                            [F:ZTASG2]ZUSER   = GUSER
                            [F:ZTASG2]ZSTOFCY = [M:ZASGM0]ZSTOFCY
                            [F:ZTASG2]ZSOHNUM = [M:ZASGM2]ZSOHNUM (I)

                           # [F:ZTASG2]ZTIPO =
                            [F:ZTASG2]ZSOPLIN = [M:ZASGM2]ZSOPLIN (I)
                            [F:ZTASG2]ZITMREF = [M:ZASGM2]ZITMREF (I)
                            [F:ZTASG2]ZDIFQTY = [M:ZASGM2]ZALLQTY (I) - [M:ZASGM2]ZASIGNACION  (I)
                            [F:ZTASG2]ZQTY    = [M:ZASGM2]ZASIGNACION  (I)
                            Write  [F:ZTASG2]
                          Endif
                        Next

                        Filter [F:ZTASG2] Where ZUSER = GUSER
                        For [F:ZTASG2]ZTASG0
                           Call UPD_DEASIG_SOH([F:ZTASG2]ZSOHNUM,[F:ZTASG2]ZSOPLIN,[F:ZTASG2]ZSOPLIN)
                           Call ASIGNAR_PEDIDO([F:ZTASG2]ZSTOFCY,[F:ZTASG2]ZSOHNUM,[F:ZTASG2]ZSOPLIN,[F:ZTASG2]ZITMREF,[F:ZTASG2]ZQTY) From ZCARGAPEDM
                        Next

                        #Actualización fechas
                        For I=0 To [M:ZASGM2]NBLIG - 1
                           If [M:ZASGM2]ZFECHAEXP (I) <> [M:ZASGM2]ZSHIDAT (I) Then
                               Filter [F:ZSOQ2] Where SOHNUM = [M:ZASGM2]ZSOHNUM(I) and SOPLIN = [M:ZASGM2]ZSOPLIN (I)
                               Read  [F:ZSOQ2]SOQ0 First
                               If !fstat Then
                                  [F:ZSOQ2]SHIDAT    = [M:ZASGM2]ZFECHAEXP  (I)
                                  [F:ZSOQ2]EXTDLVDAT = ([M:ZASGM2]ZFECHAEXP (I)+[F:ZSOQ2]DAYLTI)
                                  Rewrite  [F:ZSOQ2]
                               Endif
                               Filter [F:ZSOQ2]
                           Endif
                        Next
                        Call BUSCAR()
                        Call MESSAGE("Proceso finalizado")From GESECRAN
                    Endif
                  Endif
   When Default
  Endcase
  ACTION=""
Return


################################################################

Subprog BUSCAR ()
 If [M:ZASGM0]ZSTRITMREF = "" and [M:ZASGM0]ZENDITMREF = "" and [M:ZASGM0]ZTCLCOD = "" and [M:ZASGM0]ZITMRUPT <> 2
& and [M:ZASGM0]ZTSICOD(0) = "" and [M:ZASGM0]ZTSICOD(1) = "" and [M:ZASGM0]ZTSICOD(2) = "" and [M:ZASGM0]ZTSICOD(3) = "" and [M:ZASGM0]ZTSICOD(4) = ""
  Errbox "Ingrese al menos un criterio de artículo"
  End
 Endif
 Local Integer I,J: Raz I,J
 Local Char FILTRO(255)        : FILTRO ="STOFCY='" +[M:ZASGM0]ZSTOFCY +"'"#+"'&SOQSTA<>3"
 Local Char FILTRO2(255)(2) :  FILTRO2(0) = ("1 = 1") :

 #FIXME : FILTRO EJEMPLO
 #############################PRUEBAS############################################
 #Local Char FILTRO(255)        : FILTRO ="STOFCY='" +[M:ZASGM0]ZSTOFCY+"'"
 ################################################################################
 Local Char FILTRO_STOCK (255), ZARTANT(50) : Raz ZARTANT
 Raz [M:ZASGM2]
 Raz [M:ZASGM1]

 Local Decimal ZSTOACTU,ZTOTASIG,ZTOTDISP,ZQTYSTC,ZQTYASIG,ZQTYDISP,ZIMPPEDAI,ZIMPASIGAI,ZENENTREGA,ZCOMPRAT
 Raz ZSTOACTU,ZTOTASIG,ZTOTDISP,ZQTYSTC,ZQTYASIG,ZQTYDISP,ZIMPPEDAI,ZIMPASIGAI,ZENENTREGA

 If [M:ZASGM0]ZSALFCY <> '' : FILTRO -= "&SALFCY='" +[M:ZASGM0]ZSALFCY +"'" : Endif
 If [M:ZASGM0]ZBPCORD <> '' : FILTRO -= "&BPCORD='"+[M:ZASGM0]ZBPCORD +"'" : Endif
 If [M:ZASGM0]ZPEDINI <> '' : FILTRO -= "&[F:ZSOH1]SOHTYP>='"+[M:ZASGM0]ZPEDINI +"'" : Endif
 If [M:ZASGM0]ZPEDFIN <> '' : FILTRO -= "&[F:ZSOH1]SOHTYP<='"+[M:ZASGM0]ZPEDFIN +"'" : Endif

 If [M:ZASGM0]ZFPENDPED = 2 : FILTRO2(0) += "& SOQSTA<>3" Endif
 If [M:ZASGM0]ZSTRSHIDAT <> [0/0/0] : FILTRO2(0) += "&[F:ZSOH1]SHIDAT>=[M:ZASGM0]ZSTRSHIDAT"  : Endif
 If [M:ZASGM0]ZENDSHIDAT <> [0/0/0] : FILTRO2(0) += "&[F:ZSOH1]SHIDAT<=[M:ZASGM0]ZENDSHIDAT": Endif
 #Estado orden
 If [M:ZASGM0]ZSTAORDFIR = 2 and [M:ZASGM0]ZSTAORDPLAN  = 2  :  FILTRO -= "&(DEMSTA=1|DEMSTA=2) "  : Endif
 If [M:ZASGM0]ZSTAORDFIR = 2 and [M:ZASGM0]ZSTAORDPLAN  = 1  :  FILTRO -= "&DEMSTA=1"              : Endif
 If [M:ZASGM0]ZSTAORDFIR = 1 and [M:ZASGM0]ZSTAORDPLAN  = 2  :  FILTRO -= "&DEMSTA=2"              : Endif
 If [M:ZASGM0]ZSTAORDFIR = 1 and [M:ZASGM0]ZSTAORDPLAN  = 1  :  FILTRO -= "&(DEMSTA<>2&DEMSTA<>1)" : Endif
 FILTRO -= "&(DEMSTA<>3&DEMSTA<>4)"
 #Prioridad entrega
 If [M:ZASGM0]ZPRINORMAL  = 2 and [M:ZASGM0]ZPRIURG  = 2 and [M:ZASGM0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=1|DLVPIO=2|DLVPIO=3)"     : Endif
 If [M:ZASGM0]ZPRINORMAL  = 2 and [M:ZASGM0]ZPRIURG  = 2 and [M:ZASGM0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=1|DLVPIO=2)"              : Endif
 If [M:ZASGM0]ZPRINORMAL  = 2 and [M:ZASGM0]ZPRIURG  = 1 and [M:ZASGM0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=1|DLVPIO=3)"              : Endif
 If [M:ZASGM0]ZPRINORMAL  = 2 and [M:ZASGM0]ZPRIURG  = 1 and [M:ZASGM0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=1)"                       : Endif
 If [M:ZASGM0]ZPRINORMAL  = 1 and [M:ZASGM0]ZPRIURG  = 2 and [M:ZASGM0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=2|DLVPIO=3)"              : Endif
 If [M:ZASGM0]ZPRINORMAL  = 1 and [M:ZASGM0]ZPRIURG  = 2 and [M:ZASGM0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=2)"                       : Endif
 If [M:ZASGM0]ZPRINORMAL  = 1 and [M:ZASGM0]ZPRIURG  = 1 and [M:ZASGM0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=3)"                       : Endif
 If [M:ZASGM0]ZPRINORMAL  = 1 and [M:ZASGM0]ZPRIURG  = 1 and [M:ZASGM0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO<>1&DLVPIO<>2&DLVPIO<>3)"  : Endif
 #Entrega parcial
 If [M:ZASGM0]ZEPARAUT  = 2 and [M:ZASGM0]ZEPLINCOM  = 2 and [M:ZASGM0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=2|[F:ZSOH1]DME=3)"       : Endif
 If [M:ZASGM0]ZEPARAUT  = 2 and [M:ZASGM0]ZEPLINCOM  = 2 and [M:ZASGM0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=2)"                      : Endif
 If [M:ZASGM0]ZEPARAUT  = 2 and [M:ZASGM0]ZEPLINCOM  = 1 and [M:ZASGM0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=3)"                      : Endif
 If [M:ZASGM0]ZEPARAUT  = 2 and [M:ZASGM0]ZEPLINCOM  = 1 and [M:ZASGM0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=1)"                                     : Endif
 If [M:ZASGM0]ZEPARAUT  = 1 and [M:ZASGM0]ZEPLINCOM  = 2 and [M:ZASGM0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=2|[F:ZSOH1]DME=3)"                      : Endif
 If [M:ZASGM0]ZEPARAUT  = 1 and [M:ZASGM0]ZEPLINCOM  = 2 and [M:ZASGM0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=2)"                                     : Endif
 If [M:ZASGM0]ZEPARAUT  = 1 and [M:ZASGM0]ZEPLINCOM  = 1 and [M:ZASGM0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=3)"                                     : Endif
 If [M:ZASGM0]ZEPARAUT  = 1 and [M:ZASGM0]ZEPLINCOM  = 1 and [M:ZASGM0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME<>1&[F:ZSOH1]DME<>2&[F:ZSOH1]DME<>3)"    : Endif
 #Criterios articulo
 If [M:ZASGM0]ZSTRITMREF <> "" : FILTRO2(1) += "&ITMREF>=[M:ZASGM0]ZSTRITMREF"           Endif
 If [M:ZASGM0]ZENDITMREF <> "" : FILTRO2(1) += "&ITMREF<=[M:ZASGM0]ZENDITMREF"           Endif
 If [M:ZASGM0]ZTCLCOD <> ""    : FILTRO2(1) += "&[F:ZITM]TCLCOD=[M:ZASGM0]ZTCLCOD"       Endif
 If [M:ZASGM0]ZTSICOD(0) <> "" : FILTRO2(1) += "&[F:ZITM]TSICOD(0)=[M:ZASGM0]ZTSICOD(0)" Endif
 If [M:ZASGM0]ZTSICOD(1) <> "" : FILTRO2(1) += "&[F:ZITM]TSICOD(1)=[M:ZASGM0]ZTSICOD(1)" Endif
 If [M:ZASGM0]ZTSICOD(2) <> "" : FILTRO2(1) += "&[F:ZITM]TSICOD(2)=[M:ZASGM0]ZTSICOD(2)" Endif
 If [M:ZASGM0]ZTSICOD(3) <> "" : FILTRO2(1) += "&[F:ZITM]TSICOD(3)=[M:ZASGM0]ZTSICOD(3)" Endif
 If [M:ZASGM0]ZTSICOD(4) <> "" : FILTRO2(1) += "&[F:ZITM]TSICOD(4)=[M:ZASGM0]ZTSICOD(4)" Endif
 If [M:ZASGM0]ZITMRUPT = 2     : FILTRO2(1) += "&[F:ZSOQ1]SHTQTY<>0"                     Endif

 Link [F:ZSOQ1] With  [F:ZSOH1]SOH0 = [F:ZSOQ1]SOHNUM,[F:ZSOP1]SOP0 = [F:ZSOQ1]SOHNUM;[F:ZSOQ1]SOPLIN;[F:ZSOQ1]SOQSEQ,[F:ZITM]ITM0 = [F:ZSOQ1]ITMREF  As [ZLK]
& Where evalue (FILTRO) and evalue (FILTRO2) Order By [F:ZSOQ1]SOHNUM;ITMREF
 For [ZLK]


   [M:ZASGM2]ZSOHNUM    (I) = [F:ZSOQ1]SOHNUM
   [M:ZASGM2]ZSOPLIN    (I) = [F:ZSOQ1]SOPLIN
   [M:ZASGM2]ZNETPRI    (I) = [F:ZSOP1]NETPRI
   [M:ZASGM2]ZBPCORD    (I) = [F:ZSOQ1]BPCORD
   [M:ZASGM2]ZORDDAT    (I) = [F:ZSOQ1]ORDDAT
   [M:ZASGM2]ZDME       (I) = [F:ZSOH1]DME
   [M:ZASGM2]ZDLVPIO    (I) = [F:ZSOQ1]DLVPIO
   [M:ZASGM2]ZDEMDLVDAT (I) = [F:ZSOQ1]DEMDLVDAT
   [M:ZASGM2]ZSHIDAT    (I) = [F:ZSOQ1]SHIDAT
   [M:ZASGM2]ZFECHAEXP  (I) = [F:ZSOQ1]SHIDAT
   [M:ZASGM2]ZITMREF    (I) = [F:ZSOQ1]ITMREF
   [M:ZASGM2]ZQTY       (I) = [F:ZSOQ1]QTY
   [M:ZASGM2]ZDLVQTY    (I) = [F:ZSOQ1]DLVQTY
   [M:ZASGM2]ZODLQTY    (I) = [F:ZSOQ1]ODLQTY
   #ZENENTREGA            + = [F:ZSOQ1]ODLQTY
   [M:ZASGM2]ZQTYPEND   (I) = [F:ZSOQ1]QTY - [F:ZSOQ1]DLVQTY - [F:ZSOQ1]ODLQTY
   [M:ZASGM2]ZALLQTY    (I) = [F:ZSOQ1]ALLQTY
   [M:ZASGM2]ZASIGNACION(I) = [F:ZSOQ1]ALLQTY
   [M:ZASGM2]ZNETPRINOT (I) = [F:ZSOP1]NETPRINOT * [F:ZSOQ1]QTY
   [M:ZASGM2]ZIMPPEND   (I) = [F:ZSOP1]NETPRI    * [M:ZASGM2]ZQTYPEND (I)
   [M:ZASGM2]ZIMPASIG   (I) = [F:ZSOP1]NETPRI    * [F:ZSOQ1]ALLQTY
   If [M:ZASGM2]ZQTY(I) = [M:ZASGM2]ZODLQTY(I) + [M:ZASGM2]ZDLVQTY(I)
    Diszo [M:ZASGM2]ZASIGNACION(I)
    Diszo [M:ZASGM2]ZFECHAEXP(I)
   Else
    Actzo [M:ZASGM2]ZASIGNACION(I)
    Actzo [M:ZASGM2]ZFECHAEXP(I)
   Endif
   #Totales
   I+=1
   If I > 9998
    Infbox "Los registros encontrados superan la cantidad que se puede mostrar en pantalla, ajusto los filtros"
    Break
   Endif
 Next
 [M:ZASGM2]NBLIG      = I
 FILTRO_STOCK = "STOFCY='" +[M:ZASGM0]ZSTOFCY+"'&STA='A' & LOCCAT =1"
 If [M:ZASGM0]ZLOCTYP <> '' : FILTRO_STOCK -= " & LOCTYP ='"+[M:ZASGM0]ZLOCTYP+"'" : Endif

 Link [F:ZSOQ1] With  [F:ZSOH1]SOH0 = [F:ZSOQ1]SOHNUM,[F:ZSOP1]SOP0 = [F:ZSOQ1]SOHNUM;[F:ZSOQ1]SOPLIN;[F:ZSOQ1]SOQSEQ,[F:ZITM]ITM0 = [F:ZSOQ1]ITMREF As [ZLK2]
& Where evalue (FILTRO) and evalue (FILTRO2) Order By ITMREF
 For [ZLK2]

  If [F:ZSOQ1]ITMREF <> ZARTANT Then
     ZARTANT   = [F:ZSOQ1]ITMREF
     Raz ZSTOACTU,ZTOTASIG,ZTOTDISP,ZQTYSTC,ZQTYASIG,ZQTYDISP
     Filter [F:ZSTO1] Where evalue(FILTRO_STOCK) and [F:ZSTO1]ITMREF=ZARTANT
     Read [F:ZSTO1]STO0 First
     If !fstat Then
        For [F:ZSTO1]STO0
          ZSTOACTU += [F:ZSTO1]QTYSTU
          ZTOTASIG += [F:ZSTO1]CUMALLQTA# + ZENENTREGA
          ZTOTDISP += [F:ZSTO1]QTYSTU - [F:ZSTO1]CUMALLQTA
          ZQTYSTC  += [F:ZSTO1]QTYSTU
          ZQTYASIG += [F:ZSTO1]CUMALLQTA
          ZQTYDISP += [F:ZSTO1]QTYSTU - [F:ZSTO1]CUMALLQTA
         Next
     Endif
     Filter [F:ZSTO1]
     [M:ZASGM1]ZITMREF(J)   = ZARTANT
     [M:ZASGM1]ZSTOACTU(J)   = ZSTOACTU
     [M:ZASGM1]ZTOTASIG(J)   = ZTOTASIG
     [M:ZASGM1]ZTOTDISP(J)   = ZTOTDISP
     Filter [F:ZITF1] Where STOFCY= [M:ZASGM0]ZSTOFCY and ITMREF=[F:ZSOQ1]ITMREF and DEFLOCTYP=[M:ZASGM0]ZLOCTYP
     Read[F:ZITF1]ITF0 First
     If !fstat Then
      [M:ZASGM1]ZRESERVB2C(J) = [F:ZITF1]ZRESERVB2C
     Endif
     Filter [F:ZITF1]
     [M:ZASGM1]ZQTYSTC(J)    = ZQTYSTC
     [M:ZASGM1]ZQTYASIG(J)   = ZQTYASIG
     [M:ZASGM1]ZQTYDISP(J)   = ZQTYDISP
     J+=1
   Endif
  Next
  [M:ZASGM1]NBLIG      = J



 For K = 0 To [M:ZASGM1]NBLIG-1
  Raz ZIMPPEDAI,ZIMPASIGAI,ZENENTREGA
  Link [F:ZSOQ1] With  [F:ZSOH1]SOH0 = [F:ZSOQ1]SOHNUM,[F:ZSOP1]SOP0 = [F:ZSOQ1]SOHNUM;[F:ZSOQ1]SOPLIN;[F:ZSOQ1]SOQSEQ,[F:ZITM]ITM0 = [F:ZSOQ1]ITMREF As [ZLK3]
&  Where evalue (FILTRO) and evalue (FILTRO2) and ITMREF= [M:ZASGM1]ZITMREF(K)
  For [ZLK3]
    ZIMPPEDAI += [F:ZSOP1]NETPRINOT * [F:ZSOQ1]QTY
    ZIMPASIGAI += [F:ZSOP1]NETPRI    * [F:ZSOQ1]ALLQTY
    ZENENTREGA += [F:ZSOQ1]ODLQTY
  Next
  [M:ZASGM1]ZIMPPEDAI(K)  = ZIMPPEDAI
  [M:ZASGM1]ZIMPASIGAI(K) = ZIMPASIGAI
  [M:ZASGM1]ZODLQTYT(K) = ZENENTREGA
  Filter [F:ZPOQ] Where [F:ZPOQ]LINCLEFLG <> 2 and [F:ZPOQ]ITMREF = [M:ZASGM1]ZITMREF(K) Order By [F:ZPOQ]EXTRCPDAT
  If rowcount([F:ZPOQ])<>0
    Read [F:ZPOQ] First
    If !fstat
      [M:ZASGM1]ZNEXTQTY(K) = [F:ZPOQ]QTYUOM
      [M:ZASGM1]ZNEXTQTYDAT(K) = [F:ZPOQ]EXTRCPDAT+7
    Endif
    Read [F:ZPOQ] Last
    If !fstat
      [M:ZASGM1]ZLASQTYTDAT(K) = [F:ZPOQ]EXTRCPDAT+7
    Endif
    Raz ZCOMPRAT
    For [F:ZPOQ]
      ZCOMPRAT += [F:ZPOQ]QTYUOM-[F:ZPOQ]RCPQTYPUU
    Next
    [M:ZASGM1]ZNEXTQTYT(K) = ZCOMPRAT
  Endif
  Filter [F:ZPOQ]

 Next

 Affzo [M:ZASGM0]
 Affzo [M:ZASGM1]
 Affzo [M:ZASGM2]
End
######################################################################################
Funprog CONTROL_STOCK(ZP_ZSTOFCY,ZP_ITMREF)
  Value Char ZP_ZSTOFCY,ZP_ITMREF
  Local Integer ZRES : ZRES = 2
  Local Decimal ZTOTAL  : Raz ZTOTAL
  If !clalev([F:ZSTO3]) : Local File STOCK     [F:ZSTO3] : Endif
  If !clalev([F:ZTLO2]) : Local File TABLOCTYP [F:ZTLO2] : Endif
  Local Decimal ZDISPONIBLE : Raz ZDISPONIBLE

  Filter [F:ZSTO3] Where STOFCY = ZP_ZSTOFCY and STA ='A' and ITMREF = ZP_ITMREF
  Read [F:ZSTO3]STO0 First
  If !fstat Then
    Read[F:ZTLO2]TLO0 = [M:ZASGM0]ZSTOFCY;[F:ZSTO3]LOCTYP
    If !fstat and [F:ZTLO2]LOCCAT = 1 Then
      For[F:ZSTO3]STO0
         ZDISPONIBLE += [F:ZSTO3]QTYSTU #- [F:ZSTO3]CUMALLQTA
      Next
    Endif
  Endif

  For I = 0 To [M:ZASGM2]NBLIG - 1
     If [M:ZASGM2]ZITMREF(I) = ZP_ITMREF :ZTOTAL + = [M:ZASGM2]ZASIGNACION(I) Endif
  Next
  If (ZTOTAL > ZDISPONIBLE) Then
    ZRES = 1
  Endif
  Filter [F:ZSTO3]
End ZRES
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASIG1) 04/06/2020 16:08:39 (ADMIN)
######################################################################################
Subprog AM_ZFECHAEXP(VALEUR)
  Variable Date    VALEUR
  Local Integer I

  [M:ZASGM2]ZFECHAEXP (nolign-1) = VALEUR
  Affzo [M:ZASGM2]ZFECHAEXP (nolign-1)
End
######################################################################################

Subprog AM_ZASIGNACION(VALEUR)
  Variable Decimal VALEUR
  If !clalev([F:ZSTO2]) : Local File STOCK   [F:ZSTO2] : Endif
  Local Integer I,STOKCTRL
  Local Decimal ZTOTAS,ZASIG,ZENENT,TMPTOTDISP : Raz ZTOTAS,ZASIG,TMPTOTDISP

  Local Char ZASIGNCTRL(5):Raz ZASIGNCTRL
  Local Char ZASIGPCTRL(5):Raz ZASIGPCTRL
  Call PARAM("","ZASIGNCTRL",ZASIGNCTRL) From ADOVAL
  Call PARAM("","ZASIGPCTRL",ZASIGPCTRL) From ADOVAL

  If (VALEUR > [M:ZASGM2]ZQTYPEND(nolign-1)) Then
     Call MESSAGE("La cantidad asignada no puede ser superior a la pendiente")From GESECRAN
     mkstat = 2
     End
  Endif

  Filter [F:ZSTO2] Where STOFCY =[M:ZASGM0]ZSTOFCY and ITMREF = [M:ZASGM2]ZITMREF(nolign-1)
  Read [F:ZSTO2]STO0 First
  If !fstat Then
    For I = 0 To [M:ZASGM2]NBLIG - 1
      If [M:ZASGM2]ZITMREF(I) = [M:ZASGM2]ZITMREF(nolign-1)
       If (nolign-1) <> I Then
        ZTOTAS +=  [M:ZASGM2]ZASIGNACION (I)
       Endif
       ZASIG + = [M:ZASGM2]ZALLQTY (I)
      Endif
    Next
    Local Integer IND : IND = func BUSCA_ART([M:ZASGM2]ZITMREF(nolign-1))
    TMPTOTDISP = [M:ZASGM1]ZTOTDISP(IND)
    If(([M:ZASGM1]ZQTYASIG(IND) + ZTOTAS + VALEUR - ZASIG) <= [M:ZASGM1]ZSTOACTU(IND)) or (VALEUR=0)  Then
      If VALEUR<>0 Then
        [M:ZASGM1]ZTOTASIG(IND)            = [M:ZASGM1]ZQTYASIG(IND) + ZTOTAS + VALEUR - ZASIG
        [M:ZASGM1]ZTOTDISP(IND)            = [M:ZASGM1]ZSTOACTU(IND) - [M:ZASGM1]ZTOTASIG(IND)
        [M:ZASGM2]ZIMPASIG (nolign-1) = [M:ZASGM2]ZNETPRI (nolign-1) * VALEUR
        #Call IMPORTES_AI()
        Affzo [M:ZASGM2]ZIMPASIG (nolign-1)
        Affzo [M:ZASGM1]ZTOTASIG(IND)
        Affzo [M:ZASGM1]ZTOTDISP(IND)
        Raz STOKCTRL

        If val(ZASIGNCTRL)>0 and val(ZASIGPCTRL) >0
          If TMPTOTDISP>val(ZASIGNCTRL)
            STOKCTRL = arr(TMPTOTDISP*val(ZASIGPCTRL)/100,1)
            If STOKCTRL<VALEUR
              Call MESSAGE("Porcentaje de control "+ZASIGPCTRL+"%,"+" cantidad de control "+ZASIGNCTRL+", El stock de control "+num$(STOKCTRL)
&             +" es menor a la cantidad que quiere asignar " + num$(VALEUR))From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Else
      Call MESSAGE("No hay suficiente stock")From GESECRAN
      mkstat = 2
      End
    Endif
  Endif
  Filter [F:ZSTO2]

  [M:ZASGM2]ZASIGNACION (nolign-1) = VALEUR
  Affzo [M:ZASGM2]ZASIGNACION (nolign-1)

End
###############################################################################
Funprog BUSCA_ART(ZART)
Value Char ZART
Local Integer ZIND
ZIND = find(ZART,[M:ZASGM1]ZITMREF)
End ZIND-1

Funprog ACTUALIZAR()
  Local Integer I,ZRES : ZRES = 1
  For I = 0 To [M:ZASGM2]NBLIG - 1
    If ([M:ZASGM2]ZFECHAEXP (I) <> [M:ZASGM2]ZSHIDAT (I) or [M:ZASGM2]ZALLQTY (I) <> [M:ZASGM2]ZASIGNACION (I)) Then
      ZRES = 2
      Break
    Endif
  Next
End ZRES

