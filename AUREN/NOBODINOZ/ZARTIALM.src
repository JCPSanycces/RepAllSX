#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAM ZARTIALM: CREACIÓN ARTÍCULO-ALMACEN                                                  ##
## AUTOR: AUREN AMG                                                                                         ##
## FECHA: 22/07/2021                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 06.211.127                                                                    ##
## OBJETIVO: VISTA DONDE MOSTRAMOS LOS ARTÍCULOS-PLANTA QUE NO TIENEN ARTÍCULO-ALMACÉN. RECORREMOS DICHA VISTA Y
## CREAMOS LOS REGISTROS EN LA TABLA ARTÍCULO-ALMACEN ITMWRH
##                                                                               ##
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

If GSERVEUR : Onerrgo ERRBATCH : Endif

Call ECR_TRACE("Iniciando creación Artículos - Almacen",0) From GESECRAN

#Declaramos vista (muestra los artículos - planta que no tienen artículo - almacén)  y tabla (articulo-almacen)
If !clalev([F:ZVAAL]) : Local File ZARTIALMACEN [ZVAAL] : Endif
If !clalev([F:ZAA]) : Local File ITMWRH [ZAA] : Endif

Return

$EXEC
##Recorremos vista y creamos los registros encontrados en la tabla artículo - almacen
Filter [F:ZVAAL]
For [F:ZVAAL]
      Trbegin [F:ZAA]
      [F:ZAA]ITMREF = [F:ZVAAL]ITMREF
      [F:ZAA]WRH = [F:ZVAAL]WRH
      [F:ZAA]CUNWRHFLG = 1
      [F:ZAA]STOFCY = [F:ZVAAL]STOFCY
      [F:ZAA]CUNCOD = 0
      [F:ZAA]LOCDEFFLG = 1
      [F:ZAA]EXPNUM = 0
    Write [F:ZAA]
    If !fstat Then
    Call ECR_TRACE("Creado Artículo: "+[F:ZVAAL]ITMREF+" en Almacen : "+[F:ZVAAL]WRH+" "+[F:ZVAAL]WRHNAM+".",0) From GESECRAN
        Commit
      Else
         Call ECR_TRACE("Error al crear Artículo: "+[F:ZVAAL]ITMREF+" en Almacen : "+[F:ZVAAL]WRH+" "+[F:ZVAAL]WRHNAM+".",1) From GESECRAN
        Rollback
    Endif
Next

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
