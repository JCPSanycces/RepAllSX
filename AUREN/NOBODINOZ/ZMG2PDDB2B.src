#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAM ZMG2PDDB2B: EXPORTACIÓN PDF DOCUMENTOS Magento 2                                              ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 25/08/2021                                                                                    ##
## VERSION: 1.0                                                                                         ##
##########################################################################################################
## Lista ficheros a exportar:     Vista para exportación:                                               ##
## - DOCUMENTOS                    ZMGDB2B                                                              ##
##########################################################################################################
 Gosub INIT
 Gosub EXEC
 Gosub TERMINE
End
$ACTION
Case ACTION
  When "INIT"     : Gosub INIT
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(250)
  Local Char LPATH(250)
  Local Char LPATHP(250)
  Local Integer STAT
  Local Integer FLAG

  Local Char FECHOREJEC(15)
  Global Char NOMFIC_ZDOC(250)
  Global Integer GFILEOKD

  Local Integer     TIPEXP          #Tipo exportación completa/Parcial -> 1=Parcial, 2=Completa
  Local Char        ULTEXP(30)      #Fecha última exportación anterior fichero
  Local Char        NEWULTEXP(30)   #Nueva fecha exportación

  adxifs=";"
  adxirs=chr$(013)+chr$(010)
  adxium=0

  #Check if local directory exists and creates it if not
  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  LPATH=DIRAPL+"\FTP\Magento\EXPORT\DocumentosPDFB2B"
  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

  LPATHP=DIRAPL+"\FTP\Magento\EXPORT\DocumentosPDFB2B\PROCESADOS"

  NEWULTEXP=    format$("YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", datetime$)

  #Definicion nombres de fichero a generar
  FECHOREJEC=   format$("YYYYMMDDhhmmss",date$)

  #NOMFIC_ZDOC=  "Documentos-"            + FECHOREJEC

  ## Apertura vistas de los datos a exportar

  If clalev([F:ZDOC])<=0   :   Local File ZMGDB2B[ZDOC]  :   Endif


Return

$EXEC
  ## Generar ficheros en folder local
  Gosub DOCUMENTOSPDF

# Subida de ficheros al FTP y mueve fiheros subidos a directorio de copia
  Call ECR_TRACE("Subiendo ficheros", 0) From GESECRAN
  STAT = 0
  Call FTPPUTMOV("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","SAGE_TO_MG/DocumentosPDFB2B",LPATH,LPATHP,STAT) From ZAURFTP

  If STAT >= 0
    Call ECR_TRACE("Ficheros subidos: " +num$(STAT), 0) From GESECRAN
  Else
    Call ECR_TRACE("Error en la subida de ficheros. Error: " +num$(STAT), 1) From GESECRAN
  Endif

#Proceso terminado
  Call ECR_TRACE("Proceso terminado " + format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$), 0) From GESECRAN

Return

$TERMINE

Return

###########################################
##             DOCUMENTOSPDF                 ##
###########################################
$DOCUMENTOSPDF

  Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Generando ficheros PDF DOCUMENTOS...",0) From GESECRAN

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  Call TIPO_EXPORTACION('DOCUMENTOSPDF', TIPEXP, ULTEXP)

  ## Lectura datos y escritura del fichero
  If TIPEXP=1
    Filter [ZDOC] Where UPDATE_TS >= ULTEXP
  Endif
  Local Char TMPFILE(250)
  For [ZDOC]
    Raz NOMFIC_ZDOC
    TMPFILE = [F:ZDOC]NUM + "-" + [F:ZDOC]BPR
    NOMFIC_ZDOC = filpath(LPATH+"\",TMPFILE,"pdf")
    Call SENDMAIL([F:ZDOC]NUM,"ZMGPDF",[ZDOC]FLGIMP)
    Call ECR_TRACE(format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) + " -> Fichero " + TMPFILE + ".pdf generado",0) From GESECRAN
  Next
  Call UPD_EXPORTACION('DOCUMENTOSPDF', NEWULTEXP)

Return

######################################################
##  TIPO EXPORTACIÓN - ULTIMA EXPORTACIÓN FICHERO   ##
######################################################
Subprog TIPO_EXPORTACION(FICH, TIPEXP, ULTEXP)
Value Char         FICH
Variable Integer   TIPEXP
Variable Char      ULTEXP

  ## Apertura tabla varia 6030 - Control exportación completa/parcial y fecha última exportación
  If clalev([F:ZADI])<=0  :   Local File ATABDIV      [ZADI]  :   Endif

  # żExtracción completa o parcial? si es parcial, filtro por última exportación
  TIPEXP=0
  ULTEXP=""
  Filter [ZADI] Where NUMTAB=6030 and CODE=FICH
  For [ZADI]
    TIPEXP=[F:ZADI]N1
    ULTEXP=[F:ZADI]A1
  Next
  If TIPEXP=0   :   TIPEXP=2  : Endif

End

######################################################
##  GUARDAR ULTIMA EXPORTACIÓN FICHERO              ##
######################################################
Subprog UPD_EXPORTACION(FICH, NEWULTEXP)
Value Char    FICH
Value Char    NEWULTEXP

  ## Apertura tabla varia 6020 - Control exportación completa/parcial y fecha última exportación
  If clalev([F:ZADI])<=0  :   Local File ATABDIV      [ZADI]  :   Endif

  # Actualizar fecha última extraccion datos del fichero
  Update [F:ZADI] Where NUMTAB=6030 and CODE=FICH With A1=NEWULTEXP

End

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End

##########################################################################################################
##########################################################################################################
Subprog SENDMAIL(P_NUM,P_ENVIO,P_IMP)
  Value Char P_NUM,P_ENVIO
  Value Integer P_IMP
  Local Integer YN : YN = 1
  Local Integer NBPAR_MAX : NBPAR_MAX = 20
  Local Char TBPAR(20)(1..NBPAR_MAX)
  Local Char TBVAL(250)(1..NBPAR_MAX)
  Local Char ZINFORME(50), ZDESTINO(50)
  Local Integer NBPAR
  #El alias de la tabal debe ser el estándar para que lo reconozca el WF
  If clalev([F:SIV])=0 : Local File SINVOICEV [F:SIV] : Endif
  If clalev([F:ZSIH1])=0 : Local File SINVOICE  [F:ZSIH1] : Endif
  If clalev([F:ARP])=0 : Local File AREPORT  [F:ARP] : Endif
  If P_IMP <> 2
    Read [F:ARP]ARP0 = "ZMG2BONFAC" #ZMG2BONFAC
  Else
    Read [F:ARP]ARP0 = "ZMG2BONFACH" #ZMG2BONFACH
  Endif
  Read [F:SIV]SIV0 = P_NUM
  Read [F:ZSIH1]SIH0 = P_NUM
  If !fstat  Then

      If P_IMP <> 2
        ZINFORME = "ZMG2BONFAC"
      Else
        ZINFORME = "ZMG2BONFACH"
      Endif
      ZDESTINO = P_ENVIO

      NBPAR += 1
      TBPAR(NBPAR) = "sitedeb"
      TBVAL(NBPAR) = [F:SIV]SALFCY

      NBPAR += 1
      TBPAR(NBPAR) = "sitefin"
      TBVAL(NBPAR) = [F:SIV]SALFCY

      NBPAR += 1
      TBPAR(NBPAR) = "facturedeb"
      TBVAL(NBPAR) = [F:SIV]NUM

      NBPAR += 1
      TBPAR(NBPAR) = "facturefin"
      TBVAL(NBPAR) = [F:SIV]NUM

      NBPAR += 1
      TBPAR(NBPAR) = "clientdeb"
      TBVAL(NBPAR) = [F:SIV]BPCINV

      NBPAR += 1
      TBPAR(NBPAR) = "clientfin"
      TBVAL(NBPAR) = [F:SIV]BPCINV

      NBPAR += 1
      TBPAR(NBPAR) = "datedeb"
      TBVAL(NBPAR) = [F:ZSIH1]ACCDAT

      NBPAR += 1
      TBPAR(NBPAR) = "datefin"
      TBVAL(NBPAR) = [F:ZSIH1]ACCDAT

      NBPAR += 1
      TBPAR(NBPAR) = "typedeb"
      TBVAL(NBPAR) = "1"

      NBPAR += 1
      TBPAR(NBPAR) = "typefin"
      TBVAL(NBPAR) = "5"

      NBPAR += 1
      TBPAR(NBPAR) = "codimp"
      If [F:SIV]STARPT = 2
        TBVAL(NBPAR) = 'Reimpresión'
      Else
        TBVAL(NBPAR) = "Impresión"
      Endif

      NBPAR += 1
      TBPAR(NBPAR) = "nadxuid"
      TBVAL(NBPAR) = vireblc(num$(adxuid(1)),4)

      NBPAR+=1
      TBPAR(NBPAR) = "etat"
      TBVAL(NBPAR) = [F:ARP]RPTCOD

      #The Subprog ETAT needs these parameters:
      #1 -  Name of the report (is not the name of the rpt Crystal file)
      #2 -  Name of the destination
      #3 - Language, leave this blanc to use the default language
      #4 - 0 or 1 it shows or not the info message 'print executed'
      #5 - TBPAR_BP
      #6 - TBVAL_BP
      Call ETAT(ZINFORME,ZDESTINO,"",0,"",TBPAR,TBVAL) From AIMP3
      Sleep 15
    Endif


End
