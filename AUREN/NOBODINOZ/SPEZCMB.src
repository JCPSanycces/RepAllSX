#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Gestión de la máscara ZCMBOM (Especifico)
################################################################
$ACTION
  Case ACTION
    When "OK" : Gosub OK
    When "SEL_TABLE"  : Gosub SEL_TABLE
  Endcase
Return

################################################################
$SEL_TABLE
  Case COUZON
    When "ZAGINI" : Gosub SEL_ZART
    When "ZAGFIN" : Gosub SEL_ZART
  Endcase
Return
################################################################
$SEL_ZART
  OBJET = "ITM"
  CRITERE(1) += "ZARTGEN = 2"
  START = "ITMREF"
Return
###############################################################
$OK
  Local Integer YN : YN = 1

  Call OUINON("El cambio no podrá deshacerse. żDesea lanzar el proceso?",YN) From GESECRAN
  If (YN = 2) Then
    Call CRE_ACT_BOM ([M:ZCMB]ZAGINI,[M:ZCMB]ZAGFIN,[M:ZCMB]TSICOD(0),[M:ZCMB]TSICOD(1),[M:ZCMB]TSICOD(2),[M:ZCMB]TSICOD(3),[M:ZCMB]TSICOD(4))
  Else
    FIN=0
  Endif
Return
######################################################################################

Subprog CRE_ACT_BOM (ZP_AGINI,ZP_AGFIN,ZP_FE0,ZP_FE1,ZP_FE2,ZP_FE3,ZP_FE4)

  Value Char ZP_AGINI
  Value Char ZP_AGFIN
  Value Char ZP_FE0,ZP_FE1,ZP_FE2,ZP_FE3,ZP_FE4
  If !clalev([F:ZITM1]) : Local File ITMMASTER [F:ZITM1] : Endif
  If !clalev([F:ZITM2]) : Local File ITMMASTER [F:ZITM2] : Endif
  If !clalev([F:ZBOH1]) : Local File BOM       [F:ZBOH1] : Endif
  If !clalev([F:ZBOH2]) : Local File BOM       [F:ZBOH2] : Endif
  If !clalev([F:ZBOD1]) : Local File BOMD      [F:ZBOD1] : Endif
  If !clalev([F:ZBOD2]) : Local File BOMD      [F:ZBOD2] : Endif
  If !clalev([F:ZBOD3]) : Local File BOMD      [F:ZBOD3] : Endif
  If !clalev([F:ZCD1])  : Local File ZCOLDEP    [F:ZCD1] : Endif
  If !clalev([F:ZITB1]) : Local File ITMBOM    [F:ZITB1] : Endif
  If !clalev([F:ZITB2]) : Local File ITMBOM    [F:ZITB2] : Endif
  If !clalev([F:ZAXX1]) : Local File ATEXTRA   [F:ZAXX1] : Endif

  Local Char CRITERE(250) : CRITERE= "1=1"
  Local Integer ZPERMISO,ZERROR,ZMODIFICAR
  ZMODIFICAR = 1
  ZERROR     = 1


  If ZP_FE0 <> '' : CRITERE -= "&TSICOD(0)='"+ZP_FE0+"'" : Endif
  If ZP_FE1 <> '' : CRITERE -= "&TSICOD(1)='"+ZP_FE1+"'" : Endif
  If ZP_FE2 <> '' : CRITERE -= "&TSICOD(2)='"+ZP_FE2+"'" : Endif
  If ZP_FE3 <> '' : CRITERE -= "&TSICOD(3)='"+ZP_FE3+"'" : Endif
  If ZP_FE4 <> '' : CRITERE -= "&TSICOD(4)='"+ZP_FE4+"'" : Endif
  If (ZP_AGINI<>"" and ZP_AGFIN <>"") Then
     CRITERE = "ZARTGEN = 2 & ITMREF >='"+ZP_AGINI+"' & ITMREF <='"+ ZP_AGFIN + "'"
     Filter [F:ZITM1] Where ZARTGEN = 2 and evalue (CRITERE)
  Else
     Filter [F:ZITM1] Where ZARTGEN = 2 and ITMREF = ZP_AGINI
  Endif

  Call OUVRE_TRACE("Creación/modificación BOM's") From LECFIC
   Read [F:ZITM1]ITM0 First
   For  [F:ZITM1]ITM0
       Read  [F:ZBOH1]BOH0 = [F:ZITM1]ITMREF;1;3
       If !fstat Then
          For  [F:ZITM2]ITM0 Where  CFGFLDALP1 = [F:ZITM1]ITMREF and ITMREF <> [F:ZITM1]ITMREF
            ZMODIFICAR = 1
            Read  [F:ZBOH1]BOH0 = [F:ZITM2]ITMREF;1;3
            If !fstat Then
              ZMODIFICAR = 2
              Gosub CREAR_BOM
            Else
              Gosub CREAR_BOM
            Endif
          Next
       Else
          Call ECR_TRACE("Aviso.El artículo genérico"- [F:ZITM1]ITMREF - "no tiene BOM",0) From GESECRAN
       Endif
    #Endif
  Next
  If ZERROR = 1 Then
    Call ECR_TRACE("Proceso finalizado con éxito",0) From GESECRAN
  Endif
  Call LEC_TRACE   From LECFIC
  Call FERME_TRACE From LECFIC
End

###########################################################################
$CREAR_BOM

 ZPERMISO = func PERMISO_CREAR([F:ZITM1]ITMREF,[F:ZITM2]ITMREF,ZERROR)
 If ZPERMISO = 2 Then
      Filter [F:ZBOH1] Where ITMREF = [F:ZITM1]ITMREF and BOMALTTYP = 3
      Read  [F:ZBOH1]BOH0 First
      If ZMODIFICAR = 2 Then
         Read  [F:ZBOH2]BOH0 = [F:ZITM2]ITMREF;[F:ZBOH1]BOMALT;3

         [F:ZBOH2]ITMREF    = [F:ZITM2]ITMREF
         [F:ZBOH2]IDENT1    = [F:ZBOH2]ITMREF +"~"+num$([F:ZBOH2]BOMALT)
         [F:ZBOH2]BOMALT    = [F:ZBOH1]BOMALT
         [F:ZBOH2]USESTA    = [F:ZBOH1]USESTA
         [F:ZBOH2]BOHSTRDAT = [F:ZBOH1]BOHSTRDAT
         [F:ZBOH2]BOHENDDAT = [F:ZBOH1]BOHENDDAT
         [F:ZBOH2]BOMRLE    = [F:ZBOH1]BOMRLE
         [F:ZBOH2]BASQTY    = [F:ZBOH1]BASQTY
         [F:ZBOH2]QTYCOD    = [F:ZBOH1]QTYCOD
         [F:ZBOH2]HEATEX    = [F:ZBOH1]HEATEX
         [F:ZBOH2]BOMALTTYP = [F:ZBOH1]BOMALTTYP
         [F:ZBOH2]CFGVCRNUM = [F:ZBOH1]CFGVCRNUM
         [F:ZBOH2]ACSCOD    = [F:ZBOH1]ACSCOD
         [F:ZBOH2]EXPNUM    = [F:ZBOH1]EXPNUM
         [F:ZBOH2]UPDDAT    = date$
         [F:ZBOH2]UPDDATTIM = time$
         [F:ZBOH2]UPDUSR    = GUSER

         Rewrite [F:ZBOH2]
         #Actualizar ITMBOM
         Read [F:ZITB1]ITB0 = [F:ZITM1]ITMREF;[F:ZBOH1]BOMALT;2
         Read [F:ZITB2]ITB0 = [F:ZITM2]ITMREF;[F:ZBOH2]BOMALT;2
         [F:ZITB2]          = [F:ZITB1]
         [F:ZITB2]ITMREF    = [F:ZITM2]ITMREF
         [F:ZITB2]UPDDAT    = date$
         [F:ZITB2]UPDUSR    = GUSER
         [F:ZITB2]UPDDATTIM = time$
         Rewrite  [F:ZITB2]
         #Modificar texto

         [F:ZAXX1]CODFIC = "BOM"
         [F:ZAXX1]ZONE   = "BOMDESAXX"
         [F:ZAXX1]LANGUE = "SPA"
         [F:ZAXX1]IDENT1 = [F:ZBOH2]ITMREF +"~"+num$([F:ZBOH2]BOMALT)
         [F:ZAXX1]IDENT2 = num$([F:ZBOH2]BOMALTTYP)
         [F:ZAXX1]TEXTE  = [F:ZITM2]ITMDES1
         Rewrite [F:ZAXX1]

         For [F:ZBOD1]BOD0  Where ITMREF = [F:ZITM1]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP
            Filter [F:ZBOD2] Where ITMREF = [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP and BOMSEQ = [F:ZBOD1]BOMSEQ and CPNTYP = [F:ZBOD1]CPNTYP
            Read [F:ZBOD2]BOD0 First
            If !fstat Then
              [F:ZBOD2]ITMREF    = [F:ZITM2]ITMREF
              [F:ZBOH2]IDENT1    = [F:ZBOH2]ITMREF +"~"+num$([F:ZBOH2]BOMALT)
              [F:ZBOD2]BOMALT    = [F:ZBOD1]BOMALT
              [F:ZBOD2]BOMSEQ    = [F:ZBOD1]BOMSEQ
              [F:ZBOD2]BOMSEQNUM = [F:ZBOD1]BOMSEQNUM
              [F:ZBOD2]CPNITMREF = [F:ZBOD1]CPNITMREF
              [F:ZBOD2]CPNTYP    = [F:ZBOD1]CPNTYP
              [F:ZBOD2]BOMSHO    = [F:ZBOD1]BOMSHO
              [F:ZBOD2]BOMALTTYP = [F:ZBOD1]BOMALTTYP
              [F:ZBOD2]BOMSTRLOT = [F:ZBOD1]BOMSTRLOT
              [F:ZBOD2]BOMENDLOT = [F:ZBOD1]BOMENDLOT
              [F:ZBOD2]BOMSTRDAT = [F:ZBOD1]BOMSTRDAT
              [F:ZBOD2]BOMENDDAT = [F:ZBOD1]BOMENDDAT
              [F:ZBOD2]LIKQTYCOD = [F:ZBOD1]LIKQTYCOD
              [F:ZBOD2]QTYRND    = [F:ZBOD1]QTYRND
              [F:ZBOD2]BOMUOM    = [F:ZBOD1]BOMUOM
              [F:ZBOD2]BOMSTUCOE = [F:ZBOD1]BOMSTUCOE
              [F:ZBOD2]BOMQTY    = [F:ZBOD1]BOMQTY
              [F:ZBOD2]LIKQTY    = [F:ZBOD1]LIKQTY
              [F:ZBOD2]SCA       = [F:ZBOD1]SCA
              [F:ZBOD2]CPNOPE    = [F:ZBOD1]CPNOPE
              [F:ZBOD2]OPENUMLEV = [F:ZBOD1]OPENUMLEV
              [F:ZBOD2]BOMOFS    = [F:ZBOD1]BOMOFS
              [F:ZBOD2]PICPRN    = [F:ZBOD1]PICPRN
              [F:ZBOD2]OCNPRN    = [F:ZBOD1]OCNPRN
              [F:ZBOD2]NDEPRN    = [F:ZBOD1]NDEPRN
              [F:ZBOD2]INVPRN    = [F:ZBOD1]INVPRN
              [F:ZBOD2]LIKRLE    = [F:ZBOD1]LIKRLE
              [F:ZBOD2]BOMTEXNUM = [F:ZBOD1]BOMTEXNUM
              [F:ZBOD2]CSTFLG    = [F:ZBOD1]CSTFLG
              [F:ZBOD2]ITMTOLPOS = [F:ZBOD1]ITMTOLPOS
              [F:ZBOD2]ITMTOLNEG = [F:ZBOD1]ITMTOLNEG
              [F:ZBOD2]LEVSET    = [F:ZBOD1]LEVSET
              [F:ZBOD2]SCOFLG    = [F:ZBOD1]SCOFLG
              [F:ZBOD2]FORSEL    = [F:ZBOD1]FORSEL
              [F:ZBOD2]FORQTY    = [F:ZBOD1]FORQTY
              [F:ZBOD2]EXPNUM    = [F:ZBOD1]EXPNUM
              [F:ZBOD2]ECCVALMAJ = [F:ZBOD1]ECCVALMAJ
              [F:ZBOD2]ECCVALMIN = [F:ZBOD1]ECCVALMIN
              [F:ZBOD2]ECCRLEGRP = [F:ZBOD1]ECCRLEGRP
              [F:ZBOD2]CTN       = [F:ZBOD1]CTN
              [F:ZBOD2]UPDDAT    = date$
              [F:ZBOD2]UPDDATTIM = time$
              [F:ZBOD2]UPDUSR    = GUSER

              If [F:ZBOD1]ZCOLDEP <> "" Then
                 [F:ZBOD2]ZCOLDEP = ""
                  Read [F:ZCD1]ZCD0 = [F:ZBOD1]ZCOLDEP;[F:ZITM2]CFGFLDALP2;[F:ZITM2]CFGFLDALP3;[F:ZBOD1]CPNITMREF
                  If !fstat Then
                    [F:ZBOD2]CPNITMREF = [F:ZCD1]ZARTICULO
                  Endif
              Endif
              Rewrite [F:ZBOD2]
            Else
               Raz [F:ZBOD2]
               [F:ZBOD2]           = [F:ZBOD1]
               [F:ZBOD2]ITMREF     = [F:ZITM2]ITMREF

               [F:ZBOD2]UPDDAT    = date$
               [F:ZBOD2]UPDDATTIM = time$
               [F:ZBOD2]UPDUSR    = GUSER
               [F:ZBOD2]CREDAT    = date$
               [F:ZBOD2]CREDATTIM = time$
               [F:ZBOD2]CREUSR    = GUSER

               If [F:ZBOD1]ZCOLDEP <> "" Then
                  [F:ZBOD2]ZCOLDEP = ""
                   Read [F:ZCD1]ZCD0 = [F:ZBOD1]ZCOLDEP;[F:ZITM2]CFGFLDALP2;[F:ZITM2]CFGFLDALP3;[F:ZBOD1]CPNITMREF
                   If !fstat Then
                    [F:ZBOD2]CPNITMREF = [F:ZCD1]ZARTICULO
                   Endif
                Endif
                Write [F:ZBOD2]
            Endif
        Next
        Filter [F:ZBOD2]

        #Caso en el que la nueva BOM tenga más líneas que la del AG
        For [F:ZBOD2]BOD0 Where ITMREF = [F:ZITM2]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP
          Filter [F:ZBOD1]
          Filter [F:ZBOD1]  Where ITMREF = [F:ZITM1]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP and BOMSEQ = [F:ZBOD2]BOMSEQ and CPNTYP = [F:ZBOD2]CPNTYP

          Read  [F:ZBOD1]BOD0 First
          If fstat Then
               Delete [F:ZBOD3] Where  ITMREF = [F:ZITM2]ITMREF and BOMALT = [F:ZBOH2]BOMALT  and BOMALTTYP = [F:ZBOH2]BOMALTTYP and BOMSEQ = [F:ZBOD2]BOMSEQ
          Endif
        Next
        Filter [F:ZBOD1]
        Call ECR_TRACE("BOM actualizada para"-[F:ZITM2]ITMREF,0) From GESECRAN
     Else
        #Crear
        [F:ZBOH2]           = [F:ZBOH1]
        [F:ZBOH2]ITMREF     = [F:ZITM2]ITMREF
        [F:ZBOH2]IDENT1     = [F:ZBOH2]ITMREF +"~"+num$([F:ZBOH2]BOMALT)

        [F:ZBOH2]UPDDAT    = date$
        [F:ZBOH2]UPDDATTIM = time$
        [F:ZBOH2]UPDUSR    = GUSER
        [F:ZBOH2]CREDAT    = date$
        [F:ZBOH2]CREDATTIM = time$
        [F:ZBOH2]CREUSR    = GUSER

        Write  [F:ZBOH2]
         #Crear ITMBOM
         Read [F:ZITB1]ITB0 = [F:ZITM1]ITMREF;[F:ZBOH1]BOMALT;2
         [F:ZITB2]          = [F:ZITB1]
         [F:ZITB2]ITMREF    = [F:ZITM2]ITMREF
         [F:ZITB2]CREDAT    = date$
         [F:ZITB2]CREUSR    = GUSER
         [F:ZITB2]CREDATTIM = time$
         Write [F:ZITB2]
         #Crear texto
         [F:ZAXX1]CODFIC = "BOM"
         [F:ZAXX1]ZONE   = "BOMDESAXX"
         [F:ZAXX1]LANGUE = "SPA"
         [F:ZAXX1]IDENT1 = [F:ZBOH2]ITMREF+"~"+num$([F:ZBOH2]BOMALT)
         [F:ZAXX1]IDENT2 = num$([F:ZBOH2]BOMALTTYP)
         [F:ZAXX1]TEXTE  = [F:ZITM2]ITMDES1
         Write [F:ZAXX1]
        For [F:ZBOD1]BOD0  Where ITMREF = [F:ZITM1]ITMREF and BOMALT = [F:ZBOH1]BOMALT  and BOMALTTYP = [F:ZBOH1]BOMALTTYP
            Raz [F:ZBOD2]
            [F:ZBOD2]        = [F:ZBOD1]
            [F:ZBOD2]ITMREF  = [F:ZITM2]ITMREF

            [F:ZBOD2]UPDDAT    = date$
            [F:ZBOD2]UPDDATTIM = time$
            [F:ZBOD2]UPDUSR    = GUSER
            [F:ZBOD2]CREDAT    = date$
            [F:ZBOD2]CREDATTIM = time$
            [F:ZBOD2]CREUSR    = GUSER

            If [F:ZBOD1]ZCOLDEP <> "" Then
               [F:ZBOD2]ZCOLDEP = ""
               Read [F:ZCD1]ZCD0 = [F:ZBOD1]ZCOLDEP;[F:ZITM2]CFGFLDALP2;[F:ZITM2]CFGFLDALP3;[F:ZBOD1]CPNITMREF
               If !fstat Then
                  [F:ZBOD2]CPNITMREF = [F:ZCD1]ZARTICULO
               Endif
            Endif
            Write [F:ZBOD2]
        Next
        Call ECR_TRACE("BOM creada para"-[F:ZITM2]ITMREF,0) From GESECRAN
     Endif
     Filter [F:ZBOH1]
 Endif

Return

####################################################################################################
# Comprueba que todas las líneas de BOMD con valor en CD tengan resgistro asociado en ZCOLDEP
# Parámetro : ZP_ITMREF -> Artículo de la BOM
# Devuelve  : ZRES      -> 1. Si no todos los registros con valor en CD tienen registros en ZCOLDEP
#                       -> 2. Si todos los registros con valor en CD tienen registros en ZCOLDEP
####################################################################################################
Funprog PERMISO_CREAR(ZP_ITMREF1,ZP_ITMREF2,ZERROR)
  Value Char ZP_ITMREF1,ZP_ITMREF2
  Variable Integer ZERROR
  Local Integer ZRES : ZRES = 2
  If !clalev([F:ZCD2])  : Local File ZCOLDEP    [F:ZCD2] : Endif
  If !clalev([F:ZBOH3]) : Local File BOM       [F:ZBOH3] : Endif
  If !clalev([F:ZBOD3]) : Local File BOMD      [F:ZBOD3] : Endif
  If !clalev([F:ZCD2])  : Local File ZCOLDEP    [F:ZCD2] : Endif
  If !clalev([F:ZITM3]) : Local File ITMMASTER [F:ZITM3] : Endif

  Filter [F:ZBOH3] Where ITMREF = [F:ZITM1]ITMREF and BOMALTTYP = 3
  Read [F:ZBOH3]BOH0 First
  Read [F:ZITM3]ITM0 = ZP_ITMREF2
  Filter [F:ZBOD3]  Where ITMREF =  ZP_ITMREF1 and BOMALT = [F:ZBOH3]BOMALT  and BOMALTTYP = [F:ZBOH3]BOMALTTYP and ZCOLDEP <> ""
  Read [F:ZBOD3]BOD0 First
  For [F:ZBOD3]BOD0
     Read [F:ZCD2]ZCD0 = [F:ZBOD3]ZCOLDEP;[F:ZITM3]CFGFLDALP2;[F:ZITM3]CFGFLDALP3;[F:ZBOD3]CPNITMREF
     If fstat Then
        ZRES = 1
        If  [F:ZBOD3]CPNTYP <> 7 Then
            ZERROR = 2
            Call ECR_TRACE("Error en BOM"-ZP_ITMREF2-": Componente"-[F:ZBOD3]CPNITMREF-"no existe en color dependence",1)
& From
& GESECRAN
        Else
            ZERROR = 2
            Call ECR_TRACE("Error en BOM"-ZP_ITMREF2-": Servicio"-[F:ZBOD3]CPNITMREF-"no existe en color dependence",1)
& From GESECRAN
        Endif
     Endif
  Next
  Filter [F:ZBOD3]
End ZRES
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCMBOM) 08/06/2020 16:22:22 (ADMIN)
######################################################################################
Subprog AM_ZAGINI(VALEUR)
  Variable Char    VALEUR()
  If !clalev([F:ZITM4]) : Local File ITMMASTER [F:ZITM4] : Endif
  Read [F:ZITM4]ITM0 = VALEUR
  If !fstat Then
    [M:ZCMB]ZAGINIDES = [F:ZITM4]ITMDES1
    [M:ZCMB]ZAGFINDES = [F:ZITM4]ITMDES1
  Endif
  [M:ZCMB]ZAGFIN = VALEUR
  Affzo [M:ZCMB]
End
######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCMBOM) 10/06/2020 16:59:28 (ADMIN)
######################################################################################
Subprog AM_ZAGFIN(VALEUR)
  Variable Char    VALEUR()
  If !clalev([F:ZITM5]) : Local File ITMMASTER [F:ZITM5] : Endif
  Read [F:ZITM5]ITM0 = VALEUR
  If !fstat Then
    [M:ZCMB]ZAGFINDES = [F:ZITM5]ITMDES1
  Endif
  Affzo [M:ZCMB]
End


######################################################################################
