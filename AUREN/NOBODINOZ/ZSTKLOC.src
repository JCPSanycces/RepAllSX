#<AdxTL>@(#)0.0.0.0 $Revision$ 
#FPH Auren 24/07/2020 - 026/024 - Ańadir descripción de ubicación al selector de salidas varias
#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################
# Version V6 Emplacements
# Bibliotheque des actions, selections, et sous programmes
#############################################################
# Actions saisie en fenętre
# SAIEMPLIB   : Selection emplacements libres
#############################################################
# Selections
# STKSELTLO   : Selection type emplacement
# STKSELTLO1  : Selection type emplacement filtree
# STKSELEMP   : Selection emplacements
# STKSELEMB   : Selection emplacements bloques ou en inventaire
#############################################################
# Actions sous programmes
# STKSUGTLO   : Chargement type emplacement
# STKCTRTLO   : Controle type emplacement
# STKSUGEMP   : Chargement premier emplacement libre
# STKCTREMP   : Controle emplacement
# STKCTREMPS  : Controle emplacement en sortie
# STKCTREMPM  : Controle emplacement en modification de sortie
# STKVALEMP   : Controle validite d'un emplacement
#               apres modif.caracteristiques lignes stock
# STKCTRSRG   : Vérifie que l'emplacement est de type quai
#               et appartient au site passé en paramčtre
#############################################################
# Sections (Gosub)
# STK_INILOC   : Section d'initialisation gestion emplacements
#############################################################
# Autres sous programmes (Call)
# STKCRERES   : Reservation et déréservation emplacements geres en remplissage
# STKDELRES   : Suppression reservation / toutes les reservations
# STKLIBEMP   : Mise a jour en sortie
# STKMODRES   : Modification des reservations apres insertion
#               ou suppression de lignes
# STKCHGRES   : Modification numero sequence reservation
# STKINIEMPS  : Alimente l'emplacement par défaut de la ligne doc en sortie
# STKINITEMS  : Alimente le type d'emp par défaut de la ligne doc en sortie
#############################################################

#############################################################
# Traitement d'initialisation de la gestion d'emplacements
#############################################################
$STK_INILOC
Local Integer WOUVTRS : WOUVTRS = 0
If clalev([M:STLT])  = 0
  # Ouverture masque de travail
  Local Mask STKLOCTYP [STLT]
  If clalev([F:TLO])  = 0 : Local File TABLOCTYP    [TLO]  : Endif
  If clalev([F:TLO1]) = 0 : Local File TABLOCTYP    [TLO1] : Endif
  If clalev([F:ITM])  = 0 : Local File ITMMASTER    [ITM]  : Endif
  If clalev([F:ITF])  = 0 : Local File ITMFACILIT   [ITF]  : Endif
  If GWRHACT=2
     If clalev([F:ITW])=0 : Local File ITMWRH       [ITW]  : Endif
     If clalev([F:WRH])=0 : Local File WAREHOUSE    [WRH]  : Endif
  Endif
  If clalev([F:SRU])  = 0 : Local File TABSTORUL    [SRU]  : Endif
  If clalev([F:STC])  = 0 : Local File STOLOC       [STC]  : Endif
  If clalev([F:STC0]) = 0 : Local File STOLOC       [STC0] : Endif
  If clalev([F:STF])  = 0 : Local File STOLOCAFF    [STF]  : Endif
  If clalev([F:SWL])  = 0 : Local File STOLOCRES    [SWL]  : Endif
  If clalev([F:SWL2]) = 0 : Local File STOLOCRES    [SWL2] : Endif
  If clalev([F:STO0]) = 0 : Local File STOCK        [STO0] : Endif
  If adxlog = 0
     WOUVTRS = 1
     # Effacement reservations residuelles
     Trbegin [SWL]
  Endif
  Delete [SWL] Where PRONUM = adxuid(1)
  Delete [SWL] Where CREUSR = GUSER & CREDAT < date$-2
  If WOUVTRS = 1
      Commit
  Endif
Else
  If adxlog = 0
     WOUVTRS = 1
     Trbegin [SWL]
  Endif
  Delete [SWL] Where PRONUM = adxuid(1)
  If WOUVTRS = 1
      Commit
  Endif
Endif
# CCC : 24/06/03 -> Sinon,les valeurs par défaut ne sont pas chargée correctement
Raz [M:STLT]
Return

#############################################################
$ACTION
Case ACTION
  When "OUVRE"      :
    Case GACTION
      When "SAIEMPLIB"  : Gosub OUVRE_EMPLIB
    Endcase
  When "DEBUT"      :
    Case GACTION
      When "SAIEMPLIB"  : Gosub DEBUT_EMPLIB
    Endcase
  When "SETBOUT"    :
    Case GACTION
      When "SAIEMPLIB"  : Gosub SETBOUT_EMPLIB
    Endcase
  When "BOUTON"     :
    Case GACTION
      When "SAIEMPLIB"  : Gosub BOUTON_EMPLIB
    Endcase
  When "OK"         :
    Case GACTION
      When "SAIEMPLIB"  : Gosub OK_EMPLIB
    Endcase
  When "END"        :
    Case GACTION
      When "SAIEMPLIB"  : Gosub END_EMPLIB
    Endcase
  When "FIN"
    Case GACTION
      When "SAIEMPLIB"  : Gosub FIN_EMPLIB
    Endcase

  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "VERF_TABLE"     : Gosub VERF_TABLE
  When "SEL_LISTE"      : Gosub SEL_LISTE
  When "VERF_LISTE"     : Gosub VERF_LISTE
  When "FIN_TABLE"      : Gosub FIN_TABLE
Endcase
Return

#############################################################
$SEL_TABLE
Case TABLE
  When "STKSELTLO"     : Gosub STKSELTLO
  When "STKSELTLO1"    : Gosub STKSELTLO1
  When "STKSELEMP"     : Gosub STKSELEMP
  When "STKSELEMB"     : Gosub STKSELEMB
  When "STKSELQUA"     : Gosub STKSELQUA
Endcase
Return

#############################################################
$VERF_TABLE
Return

#############################################################
$SEL_LISTE
Return

#############################################################
$VERF_LISTE
Return

#############################################################
$FIN_TABLE
Return

#############################################################
# Selection types emplacement
#############################################################
$STKSELTLO
Local Char    WFIC(10)        : WFIC = "TABLOCTYP"
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Char    WSTA(01)        : WSTA = left$(PARAM(2),1)
Local Char    WUOM(GLONUOM)   : WUOM = PARAM(3)
Local Decimal WQTY            : WQTY = val(PARAM(4))

If clalev([F:TLO]) = 0 : Local File TABLOCTYP [TLO] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif

Link [TLO] With
& [AXX]AXX0="TABLOCTYP";"TYPDESAXX";GLANGUE;[F:TLO]STOFCY;[F:TLO]LOCTYP
& As [TLO_]

Call TEXTFIC(WFIC,"LOCTYP",2,TIT(0)) From OBJDIV

NBCOL  = 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC(WFIC,"TYPDESAXX",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TLO]LOCCAT,2710,1)"
Call TEXTFIC(WFIC,"LOCCAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TLO]MONITMFLG,1,1)"
Call TEXTFIC(WFIC,"MONITMFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TLO]DEDFLG,1,1)"
Call TEXTFIC(WFIC,"DEDFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TLO]REAFLG,1,1)"
Call TEXTFIC(WFIC,"REAFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TLO]FILMGTFLG,1,1)"
Call TEXTFIC(WFIC,"FILMGTFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "AUZSST"
Call TEXTFIC(WFIC,"AUZSST",2,TIT(NBCOL)) From OBJDIV

CRITERE  = "[F:TLO]STOFCY=WFCY"
If WUOM <> ""
  CRITERE += "&([F:TLO]PCUNBR=0|find(WUOM,[F:TLO]PCU))"
Endif
ORDRE   = "[F:TLO]STOFCY;[F:TLO]LOCTYP"
START   = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 300
Default File [TLO_]
Return

#############################################################
# Fenetre de selection des emplacements
#############################################################
$STKSELEMP
#FPH>

Local Char    WFIC(10)        : WFIC = "ZSTOLOCTMP"
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Char    WTYP(GLONTLO)   : WTYP = PARAM(2)
Local Integer WCAT
Local Char    WLOC(GLONLOC)   : WLOC = toupper(VALEUR)

If !clalev([F:ZSTC])   : Local File STOLOC        [F:ZSTC] : Endif
If !clalev([F:ZAXX1])  : Local File ATEXTRA      [F:ZAXX1] : Endif
If !clalev([F:ZSTCT1]) : Local File ZSTOLOCTMP  [F:ZSTCT1] : Endif
If !clalev([F:ZSTCT2]) : Local File ZSTOLOCTMP  [F:ZSTCT2] : Endif

Delete [F:ZSTCT1] Where ZUSER = GUSER
#Link [F:ZSTC] With [F:ZAXX1]AXX0 = 'TABLOCTYP';'TYPDESAXX';'SPA';[F:ZSTC]STOFCY;[F:ZSTC]LOCTYP As [ZSEL]
#Se hace mediante tabla temporal ya que con el alias del link no se puede acceder a los campos de las dos tablas
For [F:ZSTC]STC0 Where STOFCY = WFCY
   For [F:ZAXX1]AXX0 Where CODFIC='TABLOCTYP' and ZONE = 'TYPDESAXX'and LANGUE= 'SPA' and IDENT1 =[F:ZSTC]STOFCY and IDENT2 = [F:ZSTC]LOCTYP
      [F:ZSTCT1]      = [F:ZSTC]
      [F:ZSTCT1]      = [F:ZAXX1]
      [F:ZSTCT1]ZUSER = GUSER
      Write [F:ZSTCT1]
   Next
Next
TIT(0) = mess(22,123,1)
NBCOL=0
If GVTMOD=0
   NBCOL  = 1 : COL(NBCOL) = "STOFCY"
   Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If GWRHACT=2
  NBCOL += 1 : COL(NBCOL) = "WRH"
  Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]LOKSTA,1,1)"
Call TEXTFIC(WFIC,"LOKSTA",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]CUNLOKFLG,1,1)"
Call TEXTFIC(WFIC,"CUNLOKFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#Se ańade columna
NBCOL += 1 : COL(NBCOL) = "TEXTE" : TIT(NBCOL)='Descripción'

NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]LOCCAT,2710,1)"
Call TEXTFIC(WFIC,"LOCCAT",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]OCPCOD,757,1)"
Call TEXTFIC(WFIC,"OCPCOD",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]MONITMFLG,1,1)"
Call TEXTFIC(WFIC,"MONITMFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]DEDFLG,1,1)"
Call TEXTFIC(WFIC,"DEDFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]REAFLG,1,1)"
Call TEXTFIC(WFIC,"REAFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ZSTCT2]FILMGTFLG,1,1)"
Call TEXTFIC(WFIC,"FILMGTFLG",3,TIT(NBCOL)) From OBJDIV

#MAE/hcb bg 48911
If GVTMOD =1 & (GFONC1 = "VXASC" )
    Raz WTYP
Endif
#CRITERE = "[F:STC]STOFCY=WFCY"
CRITERE = "[F:ZSTCT2]STOFCY='"+ WFCY + "'"
If WLOC <> ""
  If instr(1,WLOC,"*") | instr(1,WLOC,"?")
     #CRITERE += "&pat([F:STC]LOC,WLOC)=1"
     CRITERE += "&pat([F:ZSTCT2]LOC,'"+WLOC+"')=1"
    START = ""
  Else
    #CRITERE += "&[F:STC]LOC>=WLOC"
     CRITERE += "&[F:ZSTCT2]LOC>='"+WLOC+"'"
  Endif
Endif
If WTYP <> ""
  #CRITERE += "&pat([F:STC]LOCTYP,WTYP)=1"
  CRITERE += "&pat([F:ZSTCT2]LOCTYP,'"+WTYP+"')=1"
Endif
If len(PARAM(3)) > 0
  CRITERE += "&find([F:ZSTCT2]LOCCAT"
  For WCAT = 1 To len(PARAM(3))
      CRITERE += ","
      CRITERE += mid$(PARAM(3),WCAT,1)                   # hcb 58052
  Next WCAT
  CRITERE += ")"
Endif
If GWRHACT=2 & PARAM(6)<>""
  #--- Bug 82084
  #CRITERE += "&[F:STC]WRH=PARAM(6)"
  CRITERE += "&[F:ZSTCT2]WRH='"+PARAM(6)+"'"
  #---
Endif
CRITERE += "&[F:ZSTCT2]ZUSER='"+GUSER+"'"

ORDRE   = "[F:ZSTCT2]STOFCY;[F:ZSTCT2]LOC"

START   = "LOC"
VALEUR  = WLOC
SIZLIG  = 150
SIZCOL  = 340
Default File [ZSTCT2]
#MAE, bg 57453
DEFPAG = 1
GPE = 1

#FPH<
Return

#############################################################
# Fenetre de selection des emplacements bloques ou en inventaire
#############################################################
$STKSELEMB
Local Char    WFIC(10)        : WFIC = "STOLOC"
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Char    WTYP(GLONTLO)   : WTYP = PARAM(2)
Local Integer WCAT
Local Char    WLOC(GLONLOC)   : WLOC = toupper(VALEUR)

If clalev([F:STC]) = 0 : Local File STOLOC    [STC] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif

TIT(0) = mess(22,123,1)
NBCOL  = 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If GWRHACT=2
  NBCOL += 1 : COL(NBCOL) = "WRH"
  Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]LOKSTA,1,1)"
Call TEXTFIC(WFIC,"LOKSTA",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]CUNLOKFLG,1,1)"
Call TEXTFIC(WFIC,"CUNLOKFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]LOCCAT,2710,1)"
Call TEXTFIC(WFIC,"LOCCAT",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]OCPCOD,757,1)"
Call TEXTFIC(WFIC,"OCPCOD",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]MONITMFLG,1,1)"
Call TEXTFIC(WFIC,"MONITMFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]DEDFLG,1,1)"
Call TEXTFIC(WFIC,"DEDFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]REAFLG,1,1)"
Call TEXTFIC(WFIC,"REAFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]FILMGTFLG,1,1)"
Call TEXTFIC(WFIC,"FILMGTFLG",3,TIT(NBCOL)) From OBJDIV

CRITERE = "[F:STC]STOFCY=WFCY&([F:STC]LOKSTA=2|[F:STC]CUNLOKFLG=2)"
If WLOC <> ""
  If instr(1,WLOC,"*") | instr(1,WLOC,"?")
    CRITERE += "&pat([F:STC]LOC,WLOC)=1"
    START = ""
  Else
    CRITERE += "&[F:STC]LOC>=WLOC"
  Endif
Endif
If WTYP <> ""
  CRITERE += "&pat([F:STC]LOCTYP,WTYP)=1"
Endif
If len(PARAM(3)) > 0
  CRITERE += "&find([F:STC]LOCCAT"
  For WCAT = 1 To len(PARAM(3))
    CRITERE += ","
    CRITERE += mid$(PARAM(3),WCAT,1)
  Next WCAT
  CRITERE += ")"
Endif

ORDRE   = "LOC"
START   = "LOC"
VALEUR  = WLOC
SIZLIG  = 150
SIZCOL  = 340
Default File [STC]
Return

#############################################################
# Selection type d'emplacement filtre
#############################################################
# Chargement premier emplacement libre
# Parametre 1 : Nolign (si tableau) -1 sinon
# Parametre 2 : Type de transaction
# Parametre 3 : Code transaction
# Parametre 4 : Site
# Parametre 5 : Article
# Parametre 6 : Unite
# Parametre 7 : Quantite
# Parametre 8 : Statut
# Parametre 9 : Type emplacement
#############################################################
$STKSELTLO1

If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif

Local Integer  WNOL           : WNOL = val(PARAM(01))
Local Integer  WTRS           : WTRS = val(PARAM(02))
Local Char     WCOD(GLONADI)  : WCOD = PARAM(03)
Local Char     WFCY(GLONFCY)  : WFCY = PARAM(04)
Local Char     WITM(GLONITM)  : WITM = PARAM(05)
Local Char     WPCU(GLONUOM)  : WPCU = PARAM(06)
Local Decimal  WQTE           : WQTE = val(PARAM(07))
Local Char     WSTA(GLONSTA)  : WSTA = PARAM(08)
Local Char     WFIL(250)      : WFIL = "1=1"
Local Char     WOPT           : WOPT = PARAM(10)
If PARAM(10) <> ""
  WFIL = PARAM(10)
Endif

Local Char WTYP    # hcb 33521
WTYP = VALEUR      # hcb 33521

Local Integer  W_DIM          : W_DIM = 50
Local Char     W_TLO(GLONTLO)(1..W_DIM)
Local Char     W_DES(GLONDES)(1..W_DIM)
Local Char     W_CAT(15)     (1..W_DIM)
Local Integer  W_NUMCAT      (1..W_DIM)
Local Char     W_MON(04)     (1..W_DIM)
Local Char     W_DED(04)     (1..W_DIM)
Local Char     W_REA(04)     (1..W_DIM)
Local Char     W_FIL(04)     (1..W_DIM)
Local Integer  W_I, W_J, W_L
Local Shortint W_K
# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  GMESSAGE = mess(68,123,1)
  GERR     = 1
  FIN      = 1
  Return
Endif
# Lecture des type d'emplacements autorises
[M:STLT]STOFCY   = WFCY
[M:STLT]ITMREF   = WITM
[M:STLT]TRSTYP   = WTRS
[M:STLT]TRSCOD   = WCOD
[M:STLT]FILTRE   = WFIL

#--- Dem 65494
# Pour forcer le paramčtre 'emplacements suggérés' ŕ 'tous'
Local Integer  WLOCSUG
WLOCSUG = GLOCSUG
GLOCSUG = 1
#---
Call REALOCTYP(VALEUR)
#--- Dem 65494
GLOCSUG = WLOCSUG

W_L = 1
For W_I = 1 To [M:STLT]NBLIG-1
  Read [TLO]TLO0=[M:STLT]STOFCY;[M:STLT]LOCTYP(W_I)
  If fstat = 0

    Read [AXX] AXX0="TABLOCTYP";"TYPDESAXX";GLANGUE;[F:TLO]STOFCY;[F:TLO]LOCTYP
    If fstat Raz [F:AXX] Endif

    W_K = 1
    # Filtre unite
    If [F:TLO]PCUNBR = 0
      W_K = 0
    Else
      For W_J = 0 To [F:TLO]PCUNBR-1
        If WPCU = [F:TLO]PCU(W_J)
          If [F:TLO]MAXQTYPCU(W_J) = 0
            W_K = 0
            Break
          Else
            If WQTE <= [F:TLO]MAXQTYPCU(W_J)
              W_K = 0
              Break
            Endif
          Endif
        Endif
      Next J
    Endif
    # Filtre statut
    If W_K = 0
      If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
        Call STKCTRSTA(WSTA,[F:TLO]AUZSST,0,1,0,W_K) From STKACT
      Else
        W_K=0
      Endif
    Endif
    GMESSAGE = ""
    If W_K = 0
      If W_L <= dim(W_TLO)
        W_TLO(W_L) = [F:TLO]LOCTYP
        W_DES(W_L) = [F:AXX]TEXTE
        W_CAT(W_L) = mess([F:TLO]LOCCAT,2710,1)
        W_NUMCAT(W_L) = [F:TLO]LOCCAT
        W_MON(W_L) = mess([F:TLO]MONITMFLG,1,1)
        W_DED(W_L) = mess([F:TLO]DEDFLG,1,1)
        W_REA(W_L) = mess([F:TLO]REAFLG,1,1)
        W_FIL(W_L) = mess([F:TLO]FILMGTFLG,1,1)
        W_L += 1
      Else
        Break
      Endif
    Endif
  Endif
Next W_I

Call TEXTFIC("TABLOCTYP","LOCTYP",2,TIT(0)) From OBJDIV
TIT(0) += " : "+[M:STLT]LOCTYP(0)-num$(WQTE)-WPCU

NBCOL  = 1 : COL(NBCOL) = "ZTLO"
Call TEXTFIC("TABLOCTYP","LOCTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZDES"
Call TEXTFIC("TABLOCTYP","TYPDESAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZCAT"
Call TEXTFIC("TABLOCTYP","LOCCAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZMON"
Call TEXTFIC("TABLOCTYP","MONITMFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZDED"
Call TEXTFIC("TABLOCTYP","DEDFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZREA"
Call TEXTFIC("TABLOCTYP","REAFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZFIL"
Call TEXTFIC("TABLOCTYP","FILMGTFLG",2,TIT(NBCOL)) From OBJDIV

CRITERE = "ZTLO<> ''"
# hcb 33521 deb
If WTYP <> ""
  CRITERE = "ZTLO >= WTYP"
Endif
# hcb 33521 fin

ORDRE   = "ZNUMCAT;ZTLO"
START   = "ZTLO"
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 260

Local File    (Char ZTLO(GLONTLO), Char ZDES(GLONDES), Char ZCAT(15), Integer ZNUMCAT, Char ZMON(04),
&              Char ZDED(04),      Char ZREA(04),      Char ZFIL(04))
&     From Variable W_TLO,         W_DES,              W_CAT,         W_NUMCAT,        W_MON,
&                   W_DED,         W_REA,              W_FIL
&     As [SEL]
Default File [SEL]
Return

#############################################################
# Sous programmes divers
#############################################################
# REALOCTYP Lecture des types d'emplacements correspondant a :
#     Un site, un article, un type de transaction
#
# Passage des parametres et resultats via le masque STKLOCTYP
# Conservation des 3 derniers codes differents traites pour
# ameliorer les performances
#------------------------------------------------------------
# Entree :
# LTYP   : type d'emplacement saisi
#
# [M:STLT]STOFCY     = Site
# [M:STLT]ITMREF     = Article
# [M:STLT]TRSTYP     = Type de transaction
# [M:STLT]TRSCOD     = Code transaction
# [M:STLT]WRH        = Dépôt
#------------------------------------------------------------
# Sortie :
# [M:STLT]LOCTYP  = Tableau des types d'emplacements autorises
#                   Le premier poste (zero) est le code de la fiche article site
#                   Les postes suivants les types d'emplacements correspondant
# [M:STLT]LOC     = Emplacement par defaut fiche article site
# [M:STLT]RETCOD  = Code retour 0 = OK
#                               1 = Erreur
#
# [M:STLT]FILTRE  = Filtre sur table TLO
#############################################################
Subprog REALOCTYP(LTYP)
Value Char LTYP

Local Integer W_I, W_J, W_K, W_L, W_M
Local Char    W_TLO(GLONTLO), W_TLODEF(GLONTLO)
Local Char    W_WRK(GLONWRH)
Local Char    W_PAR(1)
Local Integer WFLGDEF : WFLGDEF=0
Local Integer WLNK2
Local Char    WFILWRH(100)        : #---Bug 65465
Local Integer WNOSTC              : #---Bug 65601

If clalev([F:TLO]) = 0 : Local File TABLOCTYP  [TLO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] : Endif
If GWRHACT=2
   If clalev([F:ITW])=0  Local File ITMWRH     [ITW] : Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE  [WRH] : Endif
Else
   Raz [M:STLT]WRH
Endif

#--- Bug 80087
If clalev([F:STC0]) = 0 : Local File STOLOC       [STC0] : Endif

#--- Bug 61447
# Site avec gestion de dépôt ?
If [M:STLT]STOFCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M:STLT]STOFCY
Endif
#---
[M:STLT]RETCOD = 0
If [M:STLT]FILTRE = ""
  [M:STLT]FILTRE = "1=1"
Endif

If [M:STLT]LOCTYPSEQ = 0
  Call PARAM([M:STLT]STOFCY,"LOCTYPSEQ",W_PAR) From ADOVAL
  [M:STLT]LOCTYPSEQ = val(W_PAR)
Endif
# Lecture article
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]   Endif
If [F:ITM]ITMREF<>[M:STLT]ITMREF
  Read [ITM]ITM0=[M:STLT]ITMREF
  If fstat
    [M:STLT]RETCOD = 1
    Goto REALOCTYP_ERR
  Endif
Endif
# Lecture article site
If !([M:STLT]STOFCY = [F:ITF]STOFCY & [M:STLT]ITMREF = [F:ITF]ITMREF)
  Read [ITF]ITF0=[M:STLT]ITMREF;[M:STLT]STOFCY
  If fstat
    [M:STLT]RETCOD = 1
    Goto REALOCTYP_ERR
  Endif
Endif
# Si gestion de dépôt et dépôt renseigné, lecture article-dépôt
If GWRHACT=2 & [M:STLT]WRH<>""
   Read [ITW]ITW0=[M:STLT]ITMREF;[M:STLT]WRH
   If fstat Raz [F:ITW] Endif
Endif

If !find([M:STLT]TRSTYP,0,7,8,13,14)
  # Le LECSRU doit avoir été fait avant
  If [F:SRU]TRSTYP<>[M:STLT]TRSTYP
    W_L=1
    Call ERREUR(mess(365,199,1)-"[F:SRU]TRSTYP="+num$([F:SRU]TRSTYP)+
&               "<>[M:STLT]TRSTYP="+num$([M:STLT]TRSTYP)) From GESECRAN
  Endif
Else
  Raz W_L
Endif

If W_L = 0
  # Si gestion de dépôt, dépôt renseigné et emplacements défaut par dépôt
  If GWRHACT=2 & [M:STLT]WRH<>"" & [F:ITW]LOCDEFFLG=2
    For W_I = 0 To dim([F:ITW]LOCNUM)-1
      If [F:ITW]LOCNUM(W_I) = [F:SRU]LOCNUM-1
        #--- Bug 65494
        #If [F:ITW]DEFLOC(W_I)<>""
        #  [M:STLT]LOC = [F:ITW]DEFLOC(W_I)
        #Else
        #  [M:STLT]LOC = "*"
        #Endif
        [M:STLT]LOC = [F:ITW]DEFLOC(W_I)
        #---
        W_TLODEF = [F:ITW]DEFLOCTYP(W_I)
        Break
      Endif
    Next W_I

  # Emplacements défaut par site
  Else
    For W_I = 0 To dim([F:ITF]LOCNUM)-1
      If [F:ITF]LOCNUM(W_I) = [F:SRU]LOCNUM-1
        #--- Bug 65494
        #If [F:ITF]DEFLOC(W_I)<>""
        #  [M:STLT]LOC = [F:ITF]DEFLOC(W_I)
        #Else
        #  [M:STLT]LOC = "*"
        #Endif
        [M:STLT]LOC = [F:ITF]DEFLOC(W_I)
        #---
        W_TLODEF = [F:ITF]DEFLOCTYP(W_I)
        Break
      Endif
    Next W_I
  Endif
Else
  W_TLODEF = "*"
Endif
W_TLO = toupper(LTYP)
# Permet de modifier l'emplacement par défaut
GPOINT = "CHGDEFLOC" : Gosub ENTREE From EXEFNC

# CCC (20/09/04) Bug 24981:
# Si type non renseigné il faut absolument charger les loctyp dans le bon ordre
If W_TLO<>""
  # Recherche si calcule precedemment
  If W_TLO=[M:STLT]LOCTYP(0) & [M:STLT]FILTRE=[M:STLT]FILTRE0
    Goto REALOCTYP_FIN
  Endif
  # Si dans tableau 2 permutation tableau 1 et 2
  If W_TLO=[M:STLT]LOCTYP1(0) & [M:STLT]NBLIG1>0 & [M:STLT]FILTRE=[M:STLT]FILTRE1
    For W_I=0 To  dim([M:STLT]LOCTYP)-1
      W_WRK    = [M:STLT]LOCTYP(W_I)
      [M:STLT]LOCTYP (W_I) = [M:STLT]LOCTYP1(W_I)
      [M:STLT]LOCTYP1(W_I) = W_WRK
    Next W_I
    W_M             = [M:STLT]NBLIG
    [M:STLT]NBLIG   = [M:STLT]NBLIG1
    [M:STLT]FILTRE0 = [M:STLT]FILTRE1
    [M:STLT]NBLIG1  = W_M
    Goto REALOCTYP_FIN
  Endif
  # Si dans tableau 3 permutation tableau 1 et 3
  If W_TLO=[M:STLT]LOCTYP2(0) & [M:STLT]NBLIG2>0  & [M:STLT]FILTRE=[M:STLT]FILTRE2
    For W_I=0 To dim([M:STLT]LOCTYP)-1
      W_WRK    = [M:STLT]LOCTYP(W_I)
      [M:STLT]LOCTYP (W_I) = [M:STLT]LOCTYP2(W_I)
      [M:STLT]LOCTYP2(W_I) = W_WRK
    Next W_I
    W_M             = [M:STLT]NBLIG
    [M:STLT]NBLIG   = [M:STLT]NBLIG2
    [M:STLT]FILTRE0 = [M:STLT]FILTRE2
    [M:STLT]NBLIG2  = W_M
    Goto REALOCTYP_FIN
  Endif
Endif
# Si non trouve decalage des tableaux
For W_I = 0 To dim([M:STLT]LOCTYP)-1
  [M:STLT]LOCTYP2(W_I) = [M:STLT]LOCTYP1(W_I)
  [M:STLT]LOCTYP1(W_I) = [M:STLT]LOCTYP (W_I)
  [M:STLT]LOCTYP (W_I) = ""
Next W_I
[M:STLT]NBLIG2    = [M:STLT]NBLIG1
[M:STLT]FILTRE2   = [M:STLT]FILTRE1
[M:STLT]NBLIG1    = [M:STLT]NBLIG
[M:STLT]FILTRE1   = [M:STLT]FILTRE0
[M:STLT]NBLIG     = 0
[M:STLT]LOCTYP(0) = W_TLO
[M:STLT]FILTRE0   = [M:STLT]FILTRE

W_I = 1
W_J = 1

# Le chargement est trié en fonction de LOCCAT afin que les emplacements interne
# soient proposés en premier

Local Integer WPATLOC, WPATTLO
# Y a t-il des jokers (hors "*") dans les filtres emplacements et types d'emp
#--- Bug 65430
#If instr(1,[M:STLT]LOC,"?")|instr(1,[M:STLT]LOC,"#")|instr(1,[M:STLT]LOC,"!")
If ([M:STLT]LOC<>"*"&instr(1,[M:STLT]LOC,"*"))|instr(1,[M:STLT]LOC,"?")|instr(1,[M:STLT]LOC,"#")|instr(1,[M:STLT]LOC,"!")
   WPATLOC=1
Else
   WPATLOC=0
Endif
#--- Bug 65430
#If instr(1,W_TLODEF,"?")|instr(1,W_TLODEF,"#")|instr(1,W_TLODEF,"!")
If (W_TLODEF<>"*"&instr(1,W_TLODEF,"*"))|instr(1,W_TLODEF,"?")|instr(1,W_TLODEF,"#")|instr(1,W_TLODEF,"!")
   WPATTLO=1
Else
   WPATTLO=0
Endif
#--- Bug 65465 + filtres avec WFILWRH dans les Link
WFILWRH="(([F:STC]LOCCAT<3&[F:STC]WRH=[M:STLT]WRH)|([F:STC]LOCCAT>2&1=1))"
#----------------------------------------------------#
# On charge d'abord ce qui correspond ŕ la saisie    #
# Le type d'emplacement est renseigné                #
#----------------------------------------------------#
#--- Bug 61952 (nouvelle séquence)
If W_TLO<>""
   # Emplacement par défaut avec joker
   If WPATLOC=1
      If [M:STLT]WRH=""
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLO
&                       & pat([F:STC]LOC,[M:STLT]LOC)=1
&                   Order By Key LNK0=STOFCY;LOCTYP
      Else
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLO
&                       & evalue(WFILWRH)
&                       & pat([F:STC]LOC,[M:STLT]LOC)=1
&                   Order By Key LNK0=STOFCY;LOCTYP
      Endif
   # Emplacement par défaut renseigné
   Elsif !find([M:STLT]LOC,"","*")
      If [M:STLT]WRH=""
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLO
&                       & [F:STC]LOC    = [M:STLT]LOC
&                   Order By Key LNK0=STOFCY;LOCTYP
      Else
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLO
&                       & evalue(WFILWRH)
&                       & [F:STC]LOC    = [M:STLT]LOC
&                   Order By Key LNK0=STOFCY;LOCTYP
      Endif
   Endif
   If WPATLOC=1 | !find([M:STLT]LOC,"","*")
      Read [LNK] First
      If !fstat
         #Read [TLO]TLO0=[M:STLT]STOFCY;[LNK]LOCTYP  : # Bug 63730
         #If !fstat
         Gosub CHARGE_REALOCTYP
         #Endif
      Endif
      Close Local File [LNK]
   Endif

   # Męme s'il y a un emplacement par défaut, ne pas en tenir compte
   # Exploite le type saisi indépendemment de l'emplacement par défaut
   If [M:STLT]WRH=""
      Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                Where evalue([M:STLT]FILTRE)
&                    & [F:STC]STOFCY = [M:STLT]STOFCY
&                    & [F:TLO]LOCTYP = W_TLO
&                Order By Key LNK0=STOFCY;LOCTYP
   Else
      Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK]
&                Where evalue([M:STLT]FILTRE)
&                    & [F:STC]STOFCY = [M:STLT]STOFCY
&                    & [F:TLO]LOCTYP = W_TLO
&                    & evalue(WFILWRH)
&                Order By Key LNK0=STOFCY;LOCTYP
   Endif
   Read [LNK] First
   If !fstat
      #Read [TLO]TLO0=[M:STLT]STOFCY;[LNK]LOCTYP   : # Bug 63730
      #If !fstat
      Gosub CHARGE_REALOCTYP
      #Endif
   Endif
   Close Local File [LNK]

Endif
#---

#--------------------------------------------------------#
# Puis les types correspondant aux valeurs par défaut    #
# Les emplacements et types d'emplacements sont issus    #
# de l'article dépôt ou de l'article site                #
#--------------------------------------------------------#
# Type d'emplacement par défaut renseigné
If WPATTLO=0 & !find(W_TLODEF,"","*")
   # Emplacement par défaut avec joker
   If WPATLOC=1
      If [M:STLT]WRH=""
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                       & pat([F:STC]LOC,[M:STLT]LOC)=1
&                   Order By Key LNK0=STOFCY;LOCTYP
      Else
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                       & pat([F:STC]LOC,[M:STLT]LOC)=1
&                       & evalue(WFILWRH)
&                   Order By Key LNK0=STOFCY;LOCTYP
      Endif
   # Pas d'emplacement par défaut
   Elsif find([M:STLT]LOC,"","*")
      If [M:STLT]WRH=""
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                   Order By Key LNK0=STOFCY;LOCTYP
      Else
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                       & evalue(WFILWRH)
&                   Order By Key LNK0=STOFCY;LOCTYP
      Endif
   # Emplacement par défaut renseigné
   Else
      If [M:STLT]WRH=""
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                       & [F:STC]LOC    = [M:STLT]LOC
&                   Order By Key LNK0=STOFCY;LOCTYP
      Else
         #--- Bug 65494
         #Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
#&                   Where evalue([M:STLT]FILTRE)
#&                       & [F:STC]STOFCY = [M:STLT]STOFCY
#&                       & [F:TLO]LOCTYP = W_TLODEF
#&                       & [F:STC]WRH    = [M:STLT]WRH
#&                       & evalue(WFILWRH)
#&                   Order By Key LNK0=STOFCY;LOCTYP
         Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                   Where evalue([M:STLT]FILTRE)
&                       & [F:STC]STOFCY = [M:STLT]STOFCY
&                       & [F:TLO]LOCTYP = W_TLODEF
&                       & evalue(WFILWRH)
&                       & [F:STC]LOC    = [M:STLT]LOC
&                   Order By Key LNK0=STOFCY;LOCTYP
         #---
      Endif
   Endif
   Read [LNK2] First
   If !fstat
      #Read [TLO]TLO0=[M:STLT]STOFCY;[LNK2]LOCTYP   : # Bug 63730
      #If !fstat
      Gosub CHARGE_REALOCTYP
      #Endif
   Endif
   Close Local File [LNK2]
# Type d'emplacement par défaut avec joker ou non renseigné
Else
   WLNK2=1
   # Type d'emplacement par défaut avec joker
   If WPATTLO=1
      # Emplacement par défaut avec joker
      If WPATLOC=1
         If [M:STLT]WRH=""
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                          & pat([F:STC]LOC,[M:STLT]LOC)=1
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                          & pat([F:STC]LOC,[M:STLT]LOC)=1
&                          & evalue(WFILWRH)
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Endif
      # Pas d'emplacement par défaut
      Elsif find([M:STLT]LOC,"","*")
         If [M:STLT]WRH=""
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                          & evalue(WFILWRH)
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Endif
      # Emplacement par défaut renseigné
      Else
         If [M:STLT]WRH=""
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                          & [F:STC]LOC    = [M:STLT]LOC
&                      Order By Key LNK0=STOFCY;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:TLO]LOCTYP,W_TLODEF)=1
&                          & evalue(WFILWRH)
&                          & [F:STC]LOC    = [M:STLT]LOC
&                      Order By Key LNK0=STOFCY;LOCTYP
         Endif
      Endif
   # Pas de type d'emplacement par défaut
   Else
      # Emplacement par défaut avec joker
      If WPATLOC=1
         If [M:STLT]WRH=""
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:STC]LOC,[M:STLT]LOC)=1
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & pat([F:STC]LOC,[M:STLT]LOC)=1
&                          & evalue(WFILWRH)
&                      Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Endif
      # Pas d'emplacement par défaut
      Elsif find([M:STLT]LOC,"","*")
         WLNK2=0
      # Emplacement par défaut renseigné
      Else
         If [M:STLT]WRH=""
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & [F:STC]LOC    = [M:STLT]LOC
&                      Order By Key LNK0=STOFCY;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK2]
&                      Where evalue([M:STLT]FILTRE)
&                          & [F:STC]STOFCY = [M:STLT]STOFCY
&                          & evalue(WFILWRH)
&                          & [F:STC]LOC    = [M:STLT]LOC
&                      Order By Key LNK0=STOFCY;LOCTYP
         Endif
      Endif
   Endif
   If WLNK2=1
      For [LNK2]LNK0
        #Read [TLO]TLO0=[M:STLT]STOFCY;[LNK2]LOCTYP   : # Bug 63730
        If W_I < dim([M:STLT]LOCTYP)
           Gosub CHARGE_REALOCTYP
        Else
           Break
        Endif
      Next
      Close Local File [LNK2]
   Endif
Endif
#--------------------------#
# Et enfin le reste...     #
#--------------------------#

#--- Bug 65494
# Si paramčtre 'suggestion emplacement' vaut 'selon paramčtre article'
# et emplacement et type emplacement paramétrés avec '*', on continue
If GLOCSUG=1 | (GLOCSUG=2 & ((W_TLODEF="*" & WPATTLO=0) | ([M:STLT]LOC="*" & WPATLOC=0)))
#---
   # Pas de dépôt renseigné
   If [M:STLT]WRH=""
      # Type d'emplacement renseigné
      If W_TLO<>""
         # Type d'emplacement par défaut avec joker
         If WPATTLO=1
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & [F:TLO]LOCTYP<>W_TLO
&                            & pat([F:TLO]LOCTYP,W_TLODEF)=0
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1          : # Bug 63730 au lieu de TLO0
         # Type d'emplacement par défaut renseigné
         Elsif !find(W_TLODEF,"","*")
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & [F:TLO]LOCTYP<>W_TLO
&                            & [F:TLO]LOCTYP<>W_TLODEF
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1          : # Bug 63730 au lieu de TLO0
         Else
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & [F:TLO]LOCTYP<>W_TLO
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1
         Endif
      # Pas de type d'emplacement
      Else
         # Type d'emplacement par défaut avec joker
         If WPATTLO=1
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & pat([F:TLO]LOCTYP,W_TLODEF)=0
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1          : # Bug 63730 au lieu de TLO0
         # Type d'emplacement par défaut renseigné
         Elsif !find(W_TLODEF,"","*")
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & [F:TLO]LOCTYP<>W_TLODEF
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1          : # Bug 63730 au lieu de TLO0
         Else
            Filter [TLO] Where STOFCY = [M:STLT]STOFCY
&                            & evalue([M:STLT]FILTRE)
&                        Order By Key TLO1
         Endif
      Endif
      #--- Bug 65601
      WNOSTC=1
      For [TLO]
         If W_I < dim([M:STLT]LOCTYP)
            Gosub CHARGE_REALOCTYP
         Else
            Break
         Endif
      Next
      #--- Bug 65601
      WNOSTC=0
      Filter [TLO]
   # Dépôt renseigné
   Else
      # Type d'emplacement renseigné
      If W_TLO<>""
         # Type d'emplacement par défaut avec joker
         If WPATTLO=1
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & [F:TLO]LOCTYP <> W_TLO
&                             & pat([F:TLO]LOCTYP,W_TLODEF)=0
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         # Type d'emplacement par défaut renseigné
         Elsif !find(W_TLODEF,"","*")
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & [F:TLO]LOCTYP <> W_TLO
&                             & [F:TLO]LOCTYP <> W_TLODEF
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & [F:TLO]LOCTYP <> W_TLO
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Endif
      # Pas de type d'emplacement
      Else
         # Type d'emplacement par défaut avec joker
         If WPATTLO=1
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & pat([F:TLO]LOCTYP,W_TLODEF)=0
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         # Type d'emplacement par défaut renseigné
         Elsif !find(W_TLODEF,"","*")
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & [F:TLO]LOCTYP <> W_TLODEF
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Else
            Link [STC] With [TLO]TLO0=[M:STLT]STOFCY;[STC]LOCTYP As [LNK3]
&                         Where evalue([M:STLT]FILTRE)
&                             & [F:STC]STOFCY  = [M:STLT]STOFCY
&                             & evalue(WFILWRH)
&                         Order By Key LNK0=STOFCY;LOCCAT;LOCTYP
         Endif
      Endif
      For [LNK3]LNK0
         #Read [TLO]TLO0=[M:STLT]STOFCY;[LNK3]LOCTYP  : # Bug 63730
         If W_I < dim([M:STLT]LOCTYP)
            Gosub CHARGE_REALOCTYP
         Else
            Break
         Endif
      Next
      Close Local File [LNK3]
   Endif

#--- Bug 65494
Endif

[M:STLT]NBLIG = W_I
Goto REALOCTYP_FIN

$REALOCTYP_ERR
Raz [M:STLT]LOCTYP

$REALOCTYP_FIN

End

#############################################################
$CHARGE_REALOCTYP
#--- Bug 61447
# Gestion de dépôt sur le site et le dépôt n'est pas un filtre
# --> vérification de l'existence de l'article dépôt
#--- Bug 65601
#If [F:FCY]WRHGES=2 & [M:STLT]WRH=""
# Issue 113580 - 2016-01-07 by MAE : ajout du test sur code activité dépot
#If [F:FCY]WRHGES=2 & [M:STLT]WRH="" & WNOSTC<>1
If GWRHACT=2 & [F:FCY]WRHGES=2 & [M:STLT]WRH="" & WNOSTC<>1
#---
  If [F:ITW]WRH<>[F:STC]WRH  : # Bug 63730
    Read [ITW]ITW0=[M:STLT]ITMREF;[F:STC]WRH
    If fstat : Return : Endif
  Endif                      : # Bug 63730
Endif
#---
Case [M:STLT]LOCTYPSEQ
  When 2 : If W_I < dim([M:STLT]LOCTYP)
             If !find([F:TLO]LOCTYP,[M:STLT]LOCTYP(1..W_I-1))
               Insa W_I,1 [M:STLT]LOCTYP
               [M:STLT]LOCTYP(W_I) = [F:TLO]LOCTYP
               W_I += 1
               W_J += 1
             Endif
             For W_K = 0 To [F:TLO]RPLNBR-1
               If W_J < dim([M:STLT]LOCTYP)
                 If !find([F:TLO]RPLLOCTYP(W_K),[M:STLT]LOCTYP(1..W_J-1))
                   If func STKLOC.TESTTLO([F:TLO]STOFCY,[F:TLO]RPLLOCTYP(W_K))=0
                     [M:STLT]LOCTYP(W_J) = [F:TLO]RPLLOCTYP(W_K)
                     W_J += 1
                   Endif
                 Endif
               Else
                 Break
               Endif
             Next W_K
           Endif
  When Default :
           If W_I < dim([M:STLT]LOCTYP)
             If !find([F:TLO]LOCTYP,[M:STLT]LOCTYP(1..W_I-1))
               [M:STLT]LOCTYP(W_I) = [F:TLO]LOCTYP
               W_I += 1
             Endif
             For W_K = 0 To [F:TLO]RPLNBR-1
               If W_I < dim([M:STLT]LOCTYP)
                 If !find([F:TLO]RPLLOCTYP(W_K),[M:STLT]LOCTYP(1..W_I-1))
                   If func STKLOC.TESTTLO([F:TLO]STOFCY,[F:TLO]RPLLOCTYP(W_K))=0
                     [M:STLT]LOCTYP(W_I) = [F:TLO]RPLLOCTYP(W_K)
                     W_I += 1
                   Endif
                 Endif
               Else
                 Break
               Endif
             Next W_K
           Endif
Endcase
Return

#############################################################
# Teste le type d'emplacement avec le filtre [m:STLT]FILTRE
#############################################################
Funprog TESTTLO(PFCY,PLOCTYP)
Value Char PFCY
Value Char PLOCTYP
Local Integer LRET
Local Char LFIL(255)
Local Integer I
LFIL = [M:STLT]FILTRE
LRET=0
Read [TLO1]TLO0=PFCY;PLOCTYP
#--- remplacement de "TLO" par "TLO1" ----#
I=instr(1,LFIL,"[F:TLO]")
While I
  LFIL = left$(LFIL,I+2)+"TLO1"+right$(LFIL,I+6)
  I=instr(1,LFIL,"[F:TLO]")
Wend
If !evalue(LFIL)
  LRET=1
#--- Bug 80087
Elsif [M:STLT]WRH<>"" & [F:TLO1]LOCCAT<3
   Filter [STC0] Where STOFCY=[F:TLO1]STOFCY & LOCTYP=[F:TLO1]LOCTYP & WRH=[M:STLT]WRH
&                Order By Key STC3
   Read [STC0] First
   If fstat LRET=1 Endif
   Filter [STC0]
#---
Endif
End LRET

#############################################################
# Action "SAIEMPLIB" de selection d'emplacements libres
# Parametre  1 : Nolign (si tableau) -1 sinon
# Parametre  2 : Type de transaction
# Parametre  3 : Code transaction
# Parametre  4 : Site
# Parametre  5 : Article
# Parametre  6 : Unite
# Parametre  7 : Quantite
# Parametre  8 : Statut
# Parametre  9 : Type emplacement
# Parametre 10 : Emplacement de depart et selectionne
# Parametre 11 : Tiers
# Parametre 12 : Options particulieres
#                  Q = desactiver controle qte max
#                  S = desactiver controle statut
#                  U = desactiver controle unite
# Parametre 13 : Filtre sur table TLO
# Parametre 14 : Dépôt
#############################################################
$OUVRE_EMPLIB
# Stockage des parametres
Local Integer  WNOL           : WNOL = val(PARAM(1))
Local Integer  WTRS           : WTRS = val(PARAM(2))
Local Char     WCOD(GLONADI)  : WCOD = PARAM(3)
Local Char     WFCY(GLONFCY)  : WFCY = PARAM(4)
Local Char     WITM(GLONITM)  : WITM = PARAM(5)
Local Char     WPCU(GLONUOM)  : WPCU = PARAM(6)
Local Decimal  WQTE           : WQTE = val(PARAM(7))
Local Char     WSTA(GLONSTA)  : WSTA = PARAM(8)
Local Char     WTYP(GLONTLO)  : WTYP = PARAM(9)
Local Char     WVAL(GLONLOC)  : WVAL = toupper(PARAM(10))
Local Char     WBPR(GLONBPR)  : WBPR = PARAM(11)
Local Char     WOPT           : WOPT = PARAM(12)
Local Char     WFIL(250)      : WFIL = "1=1"
If PARAM(13)<>"" : WFIL = PARAM(13) : Endif
Local Char     WWRH           : WWRH = PARAM(14)

Local Shortint WRET           : # Code retour
Local Char     WOBS           : # Zone texte emplacement
Local Integer  WMAX           : # Nombre d'emplacements maximum
Local Decimal  WQTY           : # Zone de travail quantite
Local Decimal  WMAXQTY        : # Zone de travail qte maximumd'unite
Local Char     WUOM(GLONUOM)  : # Zone de travail unite
Local Char     WDATREF        : # Zone de travail date heure
Local Char     WDATSTC        : # Zone de travail date heure
Local Char     WDATSWL        : # Zone de travail date heure
Local Integer  W_I, W_J, W_L, W_M, W_N
Local Char     W_LOCFIL(250)
Local Integer  W_SWL          : # Indique si un emplacement réservé (par qqn d'autre ou sur une autre ligne)
                                # est interdit (0=ok 1=interdit)
Local Shortint W_K

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  GMESSAGE = mess(68,123,1)
  GERR     = 1
  FIN      = 1
  Return
Endif

# Lecture des type d'emplacements autorises
[M:STLT]STOFCY   = WFCY
[M:STLT]ITMREF   = WITM
[M:STLT]TRSTYP   = WTRS
[M:STLT]TRSCOD   = WCOD
[M:STLT]FILTRE   = WFIL
[M:STLT]WRH      = WWRH

#--- Dem 65494
# Pour forcer le paramčtre 'emplacements suggérés' ŕ 'tous'
Local Integer  WLOCSUG
WLOCSUG = GLOCSUG
GLOCSUG = 1
#---
Call REALOCTYP(WTYP)
#--- Dem 65494
GLOCSUG = WLOCSUG

Return

#############################################################
$DEBUT_EMPLIB
Raz [M:STOE]
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]   Endif
If [F:ITM]ITMREF<>WITM
  Read [ITM]ITM0=WITM
  If fstat Raz [F:ITM] Endif
Endif

If [F:ITM]ITMREF <> ""
  [M:STOE]WITMREF  = [F:ITM]ITMREF
  #[M:STOE]WITMDES1 = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STOE]WITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:STOE]WQTYPCU  = WQTE
  [M:STOE]WPCU     = WPCU
  [M:STOE]WSTA     = WSTA
  [M:STOE]WLOCTYP  = [M:STLT]LOCTYP(0)
  WMAX = dim([M:STOE]LOC)
  For W_I = 1 To [M:STLT]NBLIG-1
    If [M:STLT]LOCTYP(0)<>"" & pat([M:STLT]LOCTYP(W_I),[M:STLT]LOCTYP(0))<>1

      #--- Bug 53024
      #Break
      Goto NEXT_STLT
      #---

    Endif
    Gosub LEC_TLO
    If W_M <> 0
      Break
    Endif

    #--- Bug 53024
    $NEXT_STLT
    #---

  Next W_I
  Affzo [M:STOE]
  # Plus d'emplacements libres
  If [M:STOE]NBLIG = 0
    GMESSAGE = (mess(17,196,1))
    GERR     = 1
    If WVAL <> ""
      GMESSAGE += " (>"+WVAL+")"
    Endif
  Endif
Else
  FIN = 1
Endif
Return

#############################################################
$LEC_TLO

Read [TLO]TLO0=[M:STLT]STOFCY;[M:STLT]LOCTYP(W_I)
If fstat = 0
  W_K = 1
  # Filtre unite
  If [F:TLO]PCUNBR = 0
    W_K = 0
  Else
    For W_J = 0 To [F:TLO]PCUNBR-1
      If WPCU = [F:TLO]PCU(W_J)
        W_K = 0
        Break
      Endif
    Next
  Endif
  # Filtre statut
  If W_K = 0
    If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
      Call STKCTRSTA(WSTA,[F:TLO]AUZSST,0,1,0,W_K) From STKACT
    Else
      W_K=0
    Endif
  Endif
  GMESSAGE = ""
  If W_K = 0
    # Type bon chargement caracteristiques unites et emplacements
    WOBS = ""
    For W_K = 0 To [F:TLO]PCUNBR-1
      If WOBS <> ""
        WOBS += " / "
      Endif
      WOBS += (num$([F:TLO]MAXQTYPCU(W_K))-[F:TLO]PCU(W_K))
    Next
    W_M = 0
    If WVAL=""
      Local Char FIL1(100)(2)    # 1čre couche de filtre
      Local Char FIL2(100)(2)    # 2čme couche de filtre
      Local Integer FILSWL(3)

      Local Integer W_F1,W_F2,W_F3
      # Dans tous les cas ,on prend d'abord l'emplacement par défaut
      # Si gestion remplissage sans contrainte on privilégie les emp vides
      # Sinon on prend indifféremment les emplacements vides ou occupés
      FIL1(0) = "pat([F:STC]LOC,[M:STLT]LOC)=1"
      FIL1(1) = "pat([F:STC]LOC,[M:STLT]LOC)<>1"
      If [F:TLO]FILMGTFLG=2 & ([F:TLO]PCU(0)="" | [F:TLO]MAXQTYPCU(0)=0)
        FIL2(0) = "[F:STC]OCPCOD=1"
        FIL2(1) = "[F:STC]OCPCOD=2"
      Else
        FIL2(0) = "[F:STC]OCPCOD<>3"
        FIL2(1) = "[F:STC]OCPCOD<>3"
      Endif

      FILSWL(0) = 0
      FILSWL(1) = 1
      FILSWL(2) = 2

      GPOINT="FILOCPCOD" : Gosub ENTREE From EXEFNC

      For W_F1=0 To 1
        # Si pas gestion de remplissage, pas besoin de regarder dans les réservations
        For W_F2=([F:TLO]FILMGTFLG=2) To ([F:TLO]FILMGTFLG=2)*2
          W_SWL = FILSWL(W_F2)
          For W_F3=0 To 1
            If W_F3=1 & FIL2(0)=FIL2(1)
              Break
            Endif
            W_LOCFIL = FIL1(W_F1)+" & "+FIL2(W_F3)
            Gosub LOA_EMP
            If W_M<>0
              Break 3
            Endif
          Next
        Next
      Next
    Else
      # On cherche d'abord l'emplacement désigné puis,
      # si gestion remplissage sans contrainte on privilégie les emp vides
      # sinon on prend indifféremment les emplacements vides ou occupés
      W_LOCFIL = "  [F:STC]LOC = WVAL "
      Gosub LOA_EMP
      If W_M=0
        If [F:TLO]FILMGTFLG=2 & ([F:TLO]PCU(0)="" | [F:TLO]MAXQTYPCU(0)=0)
          W_LOCFIL = "  [F:STC]LOC>WVAL "+"& [F:STC]OCPCOD=1"
          Gosub LOA_EMP
          If W_M=0
            W_LOCFIL = "  [F:STC]LOC>WVAL "+"& [F:STC]OCPCOD=2"
            Gosub LOA_EMP
          Endif
        Else
          W_LOCFIL = "  [F:STC]LOC>WVAL "+"& [F:STC]OCPCOD<>3"
          Gosub LOA_EMP
        Endif
      Endif
    Endif
  Endif
Endif
Return

#############################################################
# Chargement des emplacements libres du type
$LOA_EMP

I=0
Local Decimal WTLODIS
Local Char    W_WRHFIL(80)
# Filtre sur le dépôt
If GWRHACT=2 & dim(WWRH)>0 & WWRH<>""
  #--- Bug 65465
  #W_WRHFIL = "[F:STC]WRH=WWRH"
  W_WRHFIL = "([F:STC]LOCCAT<3&[F:STC]WRH=WWRH)|[F:STC]LOCCAT>2"
Else
  W_WRHFIL = "1=1"
Endif

If [F:TLO]DEDFLG = 2
  # Traitement emplacements dedies
#                                                         # hcb 103870 modification du order bye

  Link [STF] With [STC]STC0=[F:STF]STOFCY;[F:STF]LOC
&            As   [LNK]
&            Where [F:STF]STOFCY    = WFCY          &
&                  [F:STF]ITMREF    = WITM          &
&                  [F:STC]LOKSTA    = 1             &
&                  [F:STC]CUNLOKFLG = 1             &
&                  [F:STC]LOCTYP    = [F:TLO]LOCTYP &
&                  evalue(W_LOCFIL)                 &
&                  evalue(W_WRHFIL)
&              Order By Key CLE=[F:STF]STOFCY;[F:STF]ITMREF;[F:STC]LOCTYP;[F:STC]PPSSEQ
  For [LNK]
    Gosub TRT_UN_EMP
    If W_M <> 0
      Break
    Endif
  Next
Else
  # Emplacements non dedies
  Filter [STC] Where STOFCY    = WFCY          &
&                    LOCTYP    = [F:TLO]LOCTYP &
&                    evalue(W_LOCFIL)          &
&                    LOKSTA    = 1             &
&                    CUNLOKFLG = 1             &
&                    evalue(W_WRHFIL)
&              Order By Key STC2
  # Lecture emplacements
  Raz WTLODIS
  For [STC]
    # Si interdiction ou restriction de prendre un emplacement déjŕ réservé
    If W_SWL
      # S'il n'y a pas de réservation en cours, on peut a priori prendre cet emplacement
      If W_SWL<>2
        Gosub TRT_UN_EMP
      Else
        Filter [SWL2] Where !( PRONUM=adxuid(1) & find(LINNUM, WNOL, WNOL-100000, -WNOL) )
&                          & (LOKDAT>date$ | (LOKHOU>time$ & LOKDAT=date$))
&                          & STOFCY = [F:STC]STOFCY
&                          & LOC = [F:STC]LOC
        Look [SWL2] First
        If !fstat
          # S'il existe une réservation qui n'est pas celle en cours et qui est valable
          For [SWL2]
            If [F:SWL2]LOKDAT+[F:SWL2]LOKHOU <= date$+mid$(time$,1,2)+mid$(time$,4,2)
              Gosub TRT_UN_EMP
              Break
            Endif
          Next
        Endif
        Filter [SWL2]
      Endif
    Else
      Gosub TRT_UN_EMP
    Endif
    If W_M <> 0
      Break
    Endif
  Next
  Filter [STC]
  # Si suggestion emplacement (et pas sélection emplacement)
  # avec gestion remplissage et qté totale dispo du type emp > qté ŕ entrer
  If [F:TLO]FILMGTFLG=2 & WTLODIS>=WQTE
     W_M=2
  Endif
Endif

Return

#############################################################
# Validation d'un emplacement pour chargement en tableau
$TRT_UN_EMP
W_L  = 0
WQTY = 0

# Disponibilite
WDATREF = date$+mid$(time$,1,2)+mid$(time$,4,2)
WDATSTC = [F:STC]AVADAT+[F:STC]AVAHOU
If WDATSTC > WDATREF
  W_L = 1
Endif
# Statut
If W_L = 0
  If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
    Call STKCTRSTA(WSTA,[F:STC]AUZSST,0,1,0,W_K) From STKACT
  Else
    W_K = 0
  Endif
  W_L = W_K
Endif


# hcb 35935 debut
If W_L = 0
   GPOINT = "CTRSTKLOC"
   Global Integer GTR
   GTR    = 0
   GPE    = 0
   Gosub  ENTREE From EXEFNC
   W_L = GPE
Endif
# hcb 35935 fin

# Mono article
If W_L = 0
  If [F:TLO]MONITMFLG = 2
    Filter [STO0] Where STOFCY  = WFCY        &
&                       LOC     = [F:STC] LOC &
&                       ITMREF <> WITM
    Look [STO0]STO4 First
    Filter [STO0]
    If !fstat
      W_L = 1
    Else
      Filter [SWL] Where STOFCY  = WFCY       &
&                        LOC     = [F:STC]LOC &
&                        ITMREF <> WITM
      Columns [SWL] (LOKDAT, LOKHOU)
      For [SWL]SWL1
        WDATSWL = [F:SWL]LOKDAT+[F:SWL]LOKHOU
        If WDATREF <= WDATSWL
          W_L = 1
          Break
        Endif
      Next
      Columns [SWL]
      Filter [SWL]
    Endif
  Endif
Endif

# Remplissage
If W_L = 0
  W_N= find(WPCU,[F:TLO]PCU(0..[F:TLO]PCUNBR-1))
  If [F:TLO]FILMGTFLG = 2 & W_L = 0
    # On ne prend les emplacements géré en remplissage sans contrainte d'unité
    # s'il y a déjŕ une réservation en cours
    If W_N = 0
      Filter [SWL] Where STOFCY = [F:STC]STOFCY
&                      & LOC    = [F:STC]LOC
&                      & ( LINNUM <> WNOL | PRONUM <> adxuid(1))
&                      & !( LINNUM<> WNOL & PRONUM <> adxuid(1) & LINNUM<0)
      For [SWL]
        WDATSWL = [F:SWL]LOKDAT+[F:SWL]LOKHOU
        If WDATREF <= WDATSWL
          W_L = 1
          Break
        Endif
      Next
      Filter [SWL]
    Else
      WMAXQTY = [F:TLO]MAXQTYPCU(W_N-1)
      If [F:STC]PCU <> ""
        If [F:STC]PCU <> WPCU
          W_L = 1
        Else
          WQTY = [F:STC]QTYPCU
          Filter [SWL] Where STOFCY = [F:STC]STOFCY
&                          & LOC    = [F:STC]LOC
&                          & ( LINNUM <> WNOL | PRONUM <> adxuid(1))
&                          & !( LINNUM<> WNOL & PRONUM <> adxuid(1) & LINNUM<0)
          For [SWL]
            WDATSWL = [F:SWL]LOKDAT+[F:SWL]LOKHOU
            If WDATREF <= WDATSWL
              # CCC 11/08/03
              # En suggestion et sélection on n'a pas besoin des emplacements gérés
              # en remplissage déjŕ occupés dont la quantité max n'est pas renseignée
              If [F:TLO]PCUNBR=0
                W_L = 1
                Break
              Endif
              If [F:SWL]PCU <> WPCU
                W_L = 1
                Break
              Endif
              WQTY += [F:SWL]QTYPCU
            Endif
          Next
          Filter [SWL]
          # Il reste du dispo sur l'emp --> on cumule dans le dispo du type emp
          If W_L = 0 & WQTY < WMAXQTY
            WTLODIS += WMAXQTY - WQTY
          Endif
          # Remplissage de la fenętre de sélection des emplacements
          # -->  si qté emp >= capacité emp, on ne le propose pas
          #      sinon on l'affiche (il ne sera pas forcément sélectionnable)
          If WMAX>0
            If W_L = 0 & WQTY >= WMAXQTY
              W_L = 1
            Endif
          # Suggestion d'un emplacement
          # --> si qté emp + qté ŕ ranger > capacité emp, on ne le propose pas
          Else
            If W_L = 0 & (WQTY+WQTE) > WMAXQTY
              W_L = 1
            Endif
          Endif
        Endif
      Else
        WQTY = 0
        Filter [SWL] Where STOFCY = [F:STC]STOFCY &
&                          LOC    = [F:STC]LOC &
&                          (LINNUM <> WNOL |
&                          PRONUM <> adxuid(1))

        For [SWL]
          WDATSWL = [F:SWL]LOKDAT+[F:SWL]LOKHOU
          If WDATREF <= WDATSWL
            If [F:SWL]PCU <> WPCU
              W_L = 1
              Break
            Endif
            WQTY += [F:SWL]QTYPCU
          Endif
        Next
        Filter [SWL]
        # Il reste du dispo sur l'emp --> on cumule dans le dispo du type emp
        If W_L = 0 & WQTY < WMAXQTY
          WTLODIS += WMAXQTY - WQTY
        Endif
        # Remplissage de la fenętre de sélection des emplacements
        # -->  si qté emp >= capacité emp, on ne le propose pas
        #      sinon on l'affiche (il ne sera pas forcément sélectionnable)
        If WMAX>0
          If W_L = 0 & WQTY >= WMAXQTY
            W_L = 1
          Endif
        # Suggestion d'un emplacement
        # --> si qté emp + qté ŕ ranger > capacité emp, on ne le propose pas
        Else
          If W_L = 0 & (WQTY+WQTE) > WMAXQTY
            W_L = 1
          Endif
        Endif
      Endif
    Endif
  Endif
Endif

If W_L = 0
  If WMAX > 0
    [M:STOE]NBLIG += 1
    nolign   = [M:STOE]NBLIG
    [M:STOE] = [F:TLO]
    [M:STOE] = [F:STC]
    If [F:STC]QTYPCU<>0
      [M:STOE]LPCU(nolign-1) = [F:STC]PCU
      [M:STOE]LMAXQTYPCU(nolign-1) = [F:STC]MAXQTYPCU
    Endif
# Chargement du nombre d'unites occupees / maximum
    If [F:TLO]FILMGTFLG = 2
      If [F:STC]PCU = "" & WQTY = 0
        [M:STOE]TXT(nolign-1) = WOBS
      Else
        [M:STOE]TXT(nolign-1) = num$(WMAXQTY-WQTY)-WPCU
      Endif
    Else
      [M:STOE]TXT(nolign-1) = WOBS
    Endif
    If [M:STOE]NBLIG = WMAX
      W_M = 1
    Endif
  Else
    WSEL = [F:STC]LOC
    W_M  = 2
 Endif
Endif
Return

############################################################
$OK_EMPLIB
FIN = 0
Return

############################################################
$SETBOUT_EMPLIB
Return

############################################################
$BOUTON_EMPLIB
Local Integer LLIGW
Local Decimal WQTY

Case BOUT
  When "a" :
    If nolign > 0
      If [F:TLO]FILMGTFLG=2
        Raz WQTY
        If pat([M:STOE]TXT(nolign-1),"*/*")
          Read [TLO] TLO0=[M:STOE]STOFCY(nolign-1);[M:STOE]WLOCTYP
          If !fstat
            For I=0 To [F:TLO]PCUNBR-1
              If [F:TLO]PCU(I)=[M:STOE]WPCU
                WQTY = [F:TLO]MAXQTYPCU(I)
                Break
              Endif
            Next I
          Endif
        Else
          I=instr(1,[M:STOE]TXT(nolign-1),[M:STOE]WPCU)
          If I<>0
            J=instr(1,[M:STOE]TXT(nolign-1)," ")
            WQTY=val(left$([M:STOE]TXT(nolign-1),J-1))
            If len([M:STOE]WPCU)<3
              If !find(mid$([M:STOE]TXT(nolign-1),I+len([M:STOE]WPCU),1),""," ")
                Raz WQTY
              Endif
            Endif
          Endif
        Endif
      Endif
      # Emplacement non géré en remplissage
      # ou géré en remplissage avec une capacité suffisante
      If [F:TLO]FILMGTFLG<>2 | ([F:TLO]FILMGTFLG=2 & WQTY=0) | ([F:TLO]FILMGTFLG=2 & WQTY>=[M:STOE]WQTYPCU)
        If WNOL > 0
          If WNOL>100000
            WSEQW=WNOL-100000
          Else
            WSEQW=WNOL
          Endif
          #------- Recherche dans STOENTW l'emplacement qui doit rester réservé tel quel ---#
          If clalev([ENTW])
            LLIGW = sigma( 0,[M:ENTW]NBLIG-1,(indcum+1)*(WSEQW=[M:ENTW]WLOCSEQ(indcum) & [M:ENTW]WSTOSEQ(indcum)<>0) )-1
          Elsif clalev([SGW])
            LLIGW = sigma( 0,[M:SGW]NBLIG-1,(indcum+1)*(WSEQW=[M:SGW]WLOCSEQ(indcum) & [M:SGW]WSTOSEQ(indcum)<>0) )-1
          Endif
          If WNOL>100000
            Read [F:SWL]SWL0=adxuid(1);WNOL-100000
            If !fstat
              If [F:SWL]LOC<>[M:STOE]LOC(nolign-1)
                Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,PARAM(10),[M:STOE]LOC(nolign-1),WBPR,WRET)
              Else
                Call STKDELRES(WNOL, WFCY, "", W_RET) From STKLOC
              Endif
            Endif
          Else
            Read [F:SWL]SWL0=adxuid(1);WNOL
            If fstat | LLIGW<0
              Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,PARAM(10),[M:STOE]LOC(nolign-1),WBPR,WRET)
              Look [F:SWL]SWL0=adxuid(1);WNOL+100000
              If !fstat
                Call STKDELRES(WNOL+100000, WFCY, "", W_RET) From STKLOC
              Endif
            Else
              If [F:SWL]LOC<>[M:STOE]LOC(nolign-1)
                WNOL+=100000
                Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,PARAM(10),[M:STOE]LOC(nolign-1),WBPR,WRET)
              Else
                # on ne fait rien
              Endif
            Endif
          Endif

          If WRET = 0
            PARAM(1)  = num$(WNOL)
            PARAM(10) = [F:STC]LOC
            PARAM(09) = [F:STC]LOCTYP
            FIN = 1
          Else
            PARAM(09) = ""
            FIN = 0
          Endif
        Else
          PARAM(10) = [M:STOE]LOC    (nolign-1)
          PARAM(09) = [M:STOE]LOCTYP (nolign-1)
          FIN = 1
        Endif
      Else
        Call ERREUR(mess(39,196,1)) From GESECRAN
        FIN = 0
      Endif
    Else
      FIN = 1
    Endif
Endcase
Return

#############################################################
$END_EMPLIB
Return

#############################################################
$FIN_EMPLIB
Return

#############################################################
# Sous programme de reservation
#############################################################
# LNOL : Numero de sequence reservation
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQTE : Quantite
# LSTA : Statut
# LOLD : Ancien emplacement
# LNEW : Nouvel emplacement
# LBPR : Numero tiers
# LRET : Code retour
#############################################################
Subprog STKCRERES(LNOL,LFCY,LITM,LPCU,LQTE,LSTA,LOLD,LNEW,LBPR,LRET)
Value    Decimal  LNOL
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQTE
Value    Char     LSTA
Value    Char     LOLD
Value    Char     LNEW
Value    Char     LBPR
Variable Shortint LRET
Local    Decimal W_MAX
Local    Integer W_I
Local Integer WOUVTRS : WOUVTRS = 0

# Pas de traitement si GOK <> 1
If GOK <> 1
  End
Endif
# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
  End
Endif
# Lecture ancien emplacement
LRET = 0
Read [STC0]STC0=LFCY;LOLD
If fstat
  Raz [F:STC0]
Endif
# Lecture nouvel emplacement
Read [STC]STC0=LFCY;LNEW
If fstat = 0
  If [F:STC0]FILMGTFLG = 2 |
&    [F:STC0]MONITMFLG = 2 |
&    [F:STC]FILMGTFLG  = 2 |
&    [F:STC]MONITMFLG  = 2
      If adxlog = 0
         WOUVTRS = 1
        Trbegin [SWL]
      Endif
    # Annulation ancienne reservation
# hcb 99971 deb
#    Readlock [SWL]SWL0=adxuid(1);LNOL
#    Case fstat
#      When 0       : Delete [SWL]
#                     If fstat
#                       LRET = 1
#                       Call FSTA("SWL") From GLOCK
#                     Endif
#      When 4, 5    :
#      When Default : LRET = 1
#                     Call FSTA("SWL") From GLOCK
#    Endcase
     Delete  [SWL] Where PRONUM = adxuid(1) and LINNUM = LNOL
# hcb 99971 end
    # Creation nouvelle reservation
    If [F:STC]FILMGTFLG = 2 | [F:STC]MONITMFLG = 2
      If [F:TLO]STOFCY <> [F:STC]STOFCY | [F:TLO]LOCTYP <> [F:STC]LOCTYP
        Read [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
        If fstat
          Raz [F:TLO]
        Endif
      Endif
      W_MAX = 0
      If [F:TLO]PCUNBR > 0
        W_I = find(LPCU,[F:TLO]PCU(0..[F:TLO]PCUNBR-1))
        If W_I > 0
          W_MAX = [F:TLO]MAXQTYPCU(W_I-1)
        Endif
      Endif
      Raz [F:SWL]
      [F:SWL]PRONUM    = adxuid(1)
      [F:SWL]LINNUM    = LNOL
      [F:SWL]STOFCY    = LFCY
      [F:SWL]ITMREF    = LITM
      [F:SWL]LOC       = [F:STC]LOC
      [F:SWL]PCU       = LPCU
      [F:SWL]QTYPCU    = LQTE
      [F:SWL]MAXQTYPCU = W_MAX
      [F:SWL]STA       = LSTA
      [F:SWL]LOKDAT    = date$
      Call ADDTIM([F:SWL]LOKDAT,[F:SWL]LOKHOU,60)
      [F:SWL]CREUSR    = GUSER
      [F:SWL]CREDAT    = date$
      #--- Dem 61995
      GPOINT="ECR_SWL" : Gosub ENTREE From EXEFNC

      Write [SWL]
      If fstat
        LRET = 1
        Call FSTA("SWL") From GLOCK
      Endif
      If clalev([M:ENTW])
        # Permet de connaitre le n° en cours en cas d'"echap"
        [M:ENTW]WLOCSEQCUR = LNOL
      Endif
      If clalev([M:SGW])
        # Permet de connaitre le n° en cours en cas d'"echap"
        [M:SGW]WLOCSEQCUR = LNOL
      Endif
    Else
# hcb 99971 deb
#      Readlock [SWL]SWL0=adxuid(1);LNOL
#      Case fstat
#        When 0 :
#          Delete [SWL]
#          If fstat
#            LRET = 1
#            Call FSTA("SWL") From GLOCK
#          Endif
#        When 4, 5 :
#        When Default :
#          LRET = 1
#          Call FSTA("SWL") From GLOCK
#      Endcase
     Delete  [SWL] Where PRONUM = adxuid(1) and LINNUM = LNOL
# hcb 99971 end
    Endif
    If WOUVTRS = 1
        If LRET = 0
              Commit
        Else
          Rollback
        Endif
    Else
        GOK = !LRET
    Endif
  Endif
Else
  LRET = 1
Endif
End

#############################################################
# Sous programme de suppression de reservation
#############################################################
# LNOL : Numero de sequence reservation (=0 si toutes les reservations)
# LFCY : Site
# LLOC : Emplacement
# LRET : Code retour
#############################################################
Subprog STKDELRES(LNOL,LFCY,LLOC,LRET)
Value    Decimal LNOL
Value    Char    LFCY
Value    Char    LLOC
Variable Integer LRET

Local Integer LOUVTRS : Raz LOUVTRS
If GOK = 1
  If !adxlog
    LOUVTRS = 1
    Trbegin [SWL]
  Endif
  LRET = 0
  If LNOL <> 0
# hcb 99971 deb
     Delete  [SWL] Where PRONUM = adxuid(1) and LINNUM = LNOL
     Delete  [SWL] Where PRONUM = adxuid(1) and LINNUM = LNOL * -1

#    Readlock [SWL]SWL0=adxuid(1);LNOL
#    Case fstat
#      When 0 :
#        Delete [SWL]
#        If fstat
#          LRET = 1
#          Call FSTA("SWL") From GLOCK
#        Else                                             # hcb 40625  deb
#          Readlock [SWL]SWL0=adxuid(1);LNOL * -1
#          Case fstat
#               When 0 :
#                  Delete [SWL]
#                  If fstat
#                     LRET = 1
#                     Call FSTA("SWL") From GLOCK
#                  Endif
#               When 4, 5 :
#               When Default :
#                    LRET = 1
#                    Call FSTA("SWL") From GLOCK
#          Endcase                                        # hcb 40625 fin
#        Endif
#      When 4, 5 :
#      When Default :
#        LRET = 1
#        Call FSTA("SWL") From GLOCK
#    Endcase
  Else
    Delete  [SWL] Where PRONUM = adxuid(1)
#    Filter [SWL] Where PRONUM = adxuid(1)
#    For [SWL]SWL0
#      Readlock [SWL] Curr
#      Case fstat
#        When 0 :
#          Delete [SWL]
#          If fstat
#            LRET = 1
#            Call FSTA("SWL") From GLOCK
#            Break
#          Endif
#        When Default :
#          LRET = 1
#          Call FSTA("SWL") From GLOCK
#          Break
#      Endcase
#    Next
#    Filter [SWL]
# hcb 99971 end
  Endif
  If LOUVTRS=1
    If LRET = 0
      Commit
    Else
      Rollback
    Endif
  Else
    GOK = !LRET
  Endif
Endif
End

#############################################################
# Mise a jour emplacement sur sortie de stock ou modification quantite
# Doit etre appele APRES la mise a jour de la table STOCK
# Une transaction doit etre en cours
# GOK est modifie si lock ou erreur E/S
#
# LFCY : Site
# LLOC : emplacement
# LSUP : Options ("L"=Pas de mise ŕ jour de la date de libération de l'emplacement)
# LRET = Code retour   0 = OK
#############################################################
Subprog STKLIBEMP(LFCY,LLOC,LSUP,LRET)
Value    Char    LFCY
Value    Char    LLOC
Value    Char    LSUP
Variable Integer LRET

If clalev([F:STC])  = 0 : Local File STOLOC     [STC]  : Endif
If clalev([F:STC0]) = 0 : Local File STOLOC     [STC0] : Endif
If clalev([F:STF])  = 0 : Local File STOLOCAFF  [STF]  : Endif
If clalev([F:SWL])  = 0 : Local File STOLOCRES  [SWL]  : Endif
If clalev([F:STO0]) = 0 : Local File STOCK      [STO0] : Endif
If clalev([F:TLO])  = 0 : Local File TABLOCTYP  [TLO]  : Endif
If clalev([F:TUN])  = 0 : Local File TABUNIT    [TUN]  : Endif

If LLOC <> "" & GOK = 1
  Local Integer WFSTAT : WFSTAT = fstat
  Local Integer LFSTAT
  Local Char    W_PCU(GLONUOM)
  Local Decimal W_QTYPCU, W_QTYSTU
  Local Integer W_ERR
  Local Integer W_I
  Local Integer WSAVOCP

  Raz W_PCU, W_QTYPCU, W_ERR

  Read [STC]STC0=LFCY;LLOC
  Case fstat
    When 0 :
      WSAVOCP = [F:STC]OCPCOD
      #--- Emplacement avec gestion de remplissage
      If [F:STC]FILMGTFLG = 2
        Read [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
        If fstat
          GOK = 0
          Call FSTA("TLO") From GLOCK
        Else
          WOCP = 1
          Readlock [STC]STC0=LFCY;LLOC
          Case fstat
            When 0 :
              Filter [STO0] Where STOFCY = LFCY &
&                                 LOC    = LLOC &
&                                 QTYSTU > 0
&                           Order By Key STO4
              Columns [STO0] (QTYSTU,QTYPCU,PCUORI,QTYPCUORI,QTYSTUORI)
              For [STO0]
                WOCP=2
                If [F:TLO]PCUNBR=0 : # Pas d'unité renseignée en remplissage => ocpcod=2 et qtypcu=0
                  Break
                Endif
                W_QTYSTU += [F:STO0]QTYSTU
                If W_PCU = ""
                  W_PCU = [F:STO0]PCUORI
                  Read [TUN]TUN0=W_PCU
                  If fstat
                    Raz [F:TUN]
                  Endif
                Endif
                If W_PCU <> [F:STO0]PCUORI
                  W_ERR = 1
                Else
                  W_QTYPCU += [F:STO0]QTYPCU
                Endif
              Next
              Columns [STO0]
              Filter [STO0]

              # Etant donné qu'il y a une erreur dessus,
              # il vaut mieux ne pas le considérer comme libre
              If W_ERR <> 0
                [F:STC]OCPCOD    = 3
                [F:STC]PCU       = ""
                [F:STC]QTYPCU    = 0
                [F:STC]MAXQTYPCU = 0
              Else
                If W_QTYSTU=0 | !([F:STC]FILMGTFLG=2 & [F:TLO]PCUNBR>0)
                  [F:STC]OCPCOD    = WOCP
                  [F:STC]PCU       = ""
                  [F:STC]QTYPCU    = 0
                  [F:STC]MAXQTYPCU = 0
                Else
                  W_I = find(W_PCU,[F:TLO]PCU(0..[F:TLO]PCUNBR-1))
                  # Etant donné que l'unité n'est pas parmi celles autorisées,
                  # il vaut mieux ne pas le considérer comme libre
                  If W_I  = 0
                    [F:STC]OCPCOD    = 3
                    [F:STC]PCU       = ""
                    [F:STC]QTYPCU    = 0
                    [F:STC]MAXQTYPCU = 0
                  Else
                    [F:STC]PCU       = W_PCU
                    [F:STC]QTYPCU    = W_QTYPCU
                    [F:STC]MAXQTYPCU = [F:TLO]MAXQTYPCU(W_I-1)
                    If [F:STC]QTYPCU >= [F:STC]MAXQTYPCU
                      [F:STC]OCPCOD    = 3
                    Else
                      [F:STC]OCPCOD    = WOCP
                    Endif
                  Endif
                Endif
              Endif
              [F:STC]EXPNUM = [C]EXPORT
              [F:STC]UPDUSR = GUSER
              [F:STC]UPDDAT = date$
              If [F:STC]OCPCOD=1 & !instr(1,LSUP,"L")
                Gosub TRT_LIBERATION
              Endif
              Rewrite [STC]
              If fstat
                GOK = 0
                Call FSTA("STC") From GLOCK
              Endif
            When 1 :
              GOK = -1
            When Default :
              GOK = 0
              Call FSTA("STC") From GLOCK
          Endcase
        Endif
      #--- Emplacement sans gestion de remplissage
      Else

#-----------------------------------------------------------------------
# A réactiver lorsque le pb de perf du Filter ... Look first sera résolu
#-----------------------------------------------------------------------
#        Filter [STO0] Where STOFCY = LFCY &
#&                           LOC    = LLOC &
#&                           QTYSTU > 0
#&                     Order By Key STO4
#        Look [STO0] First
#        If fstat                   : # L'emplacement est vide
#          If [F:STC]OCPCOD<>1      : # et il était occupé
#            Readlock [STC]STC0=LFCY;LLOC
#            Case fstat
#              When 0       : [F:STC]OCPCOD = 1
#                             If !instr(1,LSUP,"L")
#                               Gosub TRT_LIBERATION
#                             Endif
#                             [F:STC]EXPNUM = [C]EXPORT
#                             [F:STC]UPDUSR = GUSER
#                             [F:STC]UPDDAT = date$
#                             Rewrite [STC]
#                             If fstat
#                               GOK = 0
#                               Call FSTA("STC") From GLOCK
#                             Endif
#              When 1       : GOK = -1
#              When Default : GOK = 0
#                             Call FSTA("STC") From GLOCK
#            Endcase
#          Endif
#        Else                       : # L'emplacement est occupé
#          If [F:STC]OCPCOD<>2      : # et il était vide
#            Readlock [STC]STC0=LFCY;LLOC
#            Case fstat
#              When 0       : [F:STC]OCPCOD = 2
#                             [F:STC]EXPNUM = [C]EXPORT
#                             [F:STC]UPDUSR = GUSER
#                             [F:STC]UPDDAT = date$
#                             Rewrite [STC]
#                             If fstat
#                               GOK = 0
#                               Call FSTA("STC") From GLOCK
#                             Endif
#              When 1       : GOK = -1
#              When Default : GOK = 0
#                             Call FSTA("STC") From GLOCK
#            Endcase
#          Endif
#        Endif
#        Filter [STO0]
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# A désactiver lorsque le pb de perf du Filter ... Look first sera résolu
#-----------------------------------------------------------------------
        Local Integer WSTOEXIST : Raz WSTOEXIST
        For [STO0]STO4 Where STOFCY = LFCY &
&                            LOC    = LLOC &
&                            QTYSTU > 0
          WSTOEXIST=1
          If [F:STC]OCPCOD<>2      : # L'emp est occupé et il était vide
            Readlock [STC]STC0=LFCY;LLOC
            Case fstat
              When 0       : [F:STC]OCPCOD = 2
                             [F:STC]EXPNUM = [C]EXPORT
                             [F:STC]UPDUSR = GUSER
                             [F:STC]UPDDAT = date$
                             Rewrite [STC]
                             If fstat
                               GOK = 0
                               Call FSTA("STC") From GLOCK
                             Endif
              When 1       : GOK = -1
              When Default : GOK = 0
                             Call FSTA("STC") From GLOCK
            Endcase
          Endif
          Break
        Next
        If WSTOEXIST=0
          If [F:STC]OCPCOD<>1      : # L'emp est vide et il était occupé
            Readlock [STC]STC0=LFCY;LLOC
            Case fstat
              When 0       : [F:STC]OCPCOD = 1
                             If !instr(1,LSUP,"L")
                               Gosub TRT_LIBERATION
                             Endif
                             [F:STC]EXPNUM = [C]EXPORT
                             [F:STC]UPDUSR = GUSER
                             [F:STC]UPDDAT = date$
                             Rewrite [STC]
                             If fstat
                               GOK = 0
                               Call FSTA("STC") From GLOCK
                             Endif
              When 1       : GOK = -1
              When Default : GOK = 0
                             Call FSTA("STC") From GLOCK
            Endcase
          Endif
        Endif
#-------------------------------------------------------------------------

      Endif
    When Default :
  Endcase

  If GOK=1
     GPOINT="MAJREWLOC"
     Gosub ENTREE From EXEFNC
  Endif

  fstat = WFSTAT
  Case GOK
    When  1      :
        If WSAVOCP<>[F:STC]OCPCOD
          Readlock [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
          Case fstat
            When 0:
                Case WSAVOCP
                  When 2:       [F:TLO]OCPLOC = max(0,[F:TLO]OCPLOC-1)
                  When 3:       [F:TLO]FULLOC = max(0,[F:TLO]FULLOC-1)
                  When Default: [F:TLO]FRGLOC = max(0,[F:TLO]FRGLOC-1)
                Endcase
                Case [F:STC]OCPCOD
                  When 1: [F:TLO]FRGLOC += 1
                  When 2: [F:TLO]OCPLOC += 1
                  When 3: [F:TLO]FULLOC += 1
                Endcase
                [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/max(1,[F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
                Rewrite [F:TLO]
                If fstat
                  GOK = 0
                  Call FSTA("STC") From GLOCK
                Endif
            When 1 :
                GOK = -1
            When Default :
                GOK = 0
                Call FSTA("TLO") From GLOCK
          Endcase
        Endif
    When -1      : LRET = 1
    When Default : LRET = 2
  Endcase
Endif
End

#############################################################
$TRT_LIBERATION
Case [F:STC]FRGMGTMOD
  When 2 :
    [F:STC]AVADAT = date$
    Call ADDTIM([F:STC]AVADAT,[F:STC]AVAHOU,([F:STC]TEMLTI*60))
  When 3 :
    [F:STC]LOKSTA = 2
    [F:TLO]LOKLOC += 1    # L'opération inverse se fait dans la fiche emplacement
    [F:STC]AVADAT = date$
    [F:STC]AVAHOU = mid$(time$,1,2)+mid$(time$,4,2)
Endcase
Return

############################################################
# Ajout d'un nombre de minutes sur une date + heure
############################################################
Subprog ADDTIM(LDAT,LTIM,LMIN)
Variable Date    LDAT
Variable Char    LTIM
Value    Integer LMIN

Local    Integer WHOU
Local    Integer WMIN

If LMIN > 0
  WHOU = val(mid$(time$,1,2))
  WMIN = val(mid$(time$,4,2))
  WMIN += LMIN
  While WMIN > 59
    WHOU +=  1
    WMIN -= 60
    If WHOU > 23
      WHOU  = 0
      LDAT += 1
    Endif
  Wend
  LTIM = format$("N>0:2",num$(WHOU))+format$("N>0:2",num$(WMIN))
Endif
End

#############################################################
# Chargement premier type emplacement
# LNOL : Numero de sequence reservation
# LTRS : Type de transaction
# LCOD : Code transaction
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQTE : Quantite
# LSTA : Statut
# LTYP : Type emplacement
# LOPT : Options particulieres
#        Q = desactiver controle qte max
#        S = desactiver controle statut
#        U = desactiver controle unite
# LFIL : Nom du champ filtre sur table [F:TLO]
# LWRH : Dépôt
#############################################################
#--- Bug 72649 : ajout de LLOC
Subprog STKSUGTLO(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,LQTE,LSTA,LTYP,LOPT,LFIL,LWRH,LLOC)
Value    Decimal  LNOL
Value    Integer  LTRS
Value    Char     LCOD
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQTE
Value    Char     LSTA
Variable Char     LTYP
Value    Char     LOPT
Value    Char     LFIL
Value    Char     LWRH
Variable Char     LLOC

Local Integer  WNOL              : WNOL = LNOL
Local Integer  WTRS              : WTRS = LTRS
Local Char     WCOD(GLONADI)     : WCOD = LCOD
Local Char     WFCY(GLONFCY)     : WFCY = LFCY
Local Char     WITM(GLONITM)     : WITM = LITM
Local Char     WPCU(GLONUOM)     : WPCU = LPCU
Local Decimal  WQTE              : WQTE = LQTE
Local Char     WSTA(GLONSTA)     : WSTA = LSTA
Local Char     WTYP(GLONTLO)     : WTYP = LTYP
Local Char     WOPT(len(LOPT)+1) : WOPT = toupper(LOPT)
Local Char     WFIL(250)         : WFIL = "1=1"
Local Char     WWRH(GLONWRH)     : WWRH = LWRH
Local Char     WLOC(GLONLOC)     : Raz WLOC

If LFIL <> ""
  WFIL = LFIL
Endif
# S'il n'y a pas de contrôle d'unité il ne peut pas y avoir de contrôle de quantité
If instr(1,WOPT,"U") : WOPT+="Q" : Endif
Local Integer  W_I, W_J
Local Shortint W_K

If WQTE = 0
  Goto STKSUGTLO_FIN
Endif

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
  End
Endif

LTYP=WTYP
#MAE, bg 77668
#Raz WLOC, LLOC : #--- Bug 72649
If LLOC<>"" WLOC=LLOC : Endif
Call STKSUGEMP(WNOL,WTRS,WCOD,WFCY,WITM,WPCU,WQTE,WSTA,WTYP,WLOC,"",WOPT,WFIL,WWRH)
Raz GMESSAGE, GERR
If WLOC<>""
  LLOC = WLOC  : #--- Bug 72649
  LTYP = [F:STC]LOCTYP
  Goto STKSUGTLO_FIN
Elsif WTYP<>""
  LTYP = WTYP
  Goto STKSUGTLO_FIN
Endif

If LTYP<>""
  Raz LTYP, WTYP
  Call STKSUGEMP(WNOL,WTRS,WCOD,WFCY,WITM,WPCU,WQTE,WSTA,WTYP,WLOC,"",WOPT,WFIL,WWRH)
  Raz GMESSAGE, GERR
  If WLOC<>""
    LLOC = WLOC  : #--- Bug 72649
    LTYP = [F:STC]LOCTYP
    Goto STKSUGTLO_FIN
  Elsif WTYP<>""
    LTYP = WTYP
    Goto STKSUGTLO_FIN
  Endif
Endif
Goto STKSUGTLO_FIN

WTYP = LTYP

# Lecture des type d'emplacements autorises
[M:STLT]STOFCY   = WFCY
[M:STLT]ITMREF   = WITM
[M:STLT]TRSTYP   = WTRS
[M:STLT]TRSCOD   = WCOD
[M:STLT]FILTRE   = WFIL
[M:STLT]WRH      = WWRH

Call REALOCTYP(WTYP)

For W_I = 1 To [M:STLT]NBLIG-1
  Read [TLO]TLO0=[M:STLT]STOFCY;[M:STLT]LOCTYP(W_I)
  If fstat = 0
    W_K = 1
    # Filtre unite
    If [F:TLO]PCUNBR = 0 | (instr(1,WOPT,"Q") & instr(1,WOPT,"U"))
      W_K = 0
    Else
      If instr(1,WOPT,"Q")
        For W_J = 0 To [F:TLO]PCUNBR-1
          If WPCU = [F:TLO]PCU(W_J)
            W_K = 0
            Break
          Endif
        Next J
      Else
        For W_J = 0 To [F:TLO]PCUNBR-1
          If WPCU = [F:TLO]PCU(W_J) &  WQTE <= [F:TLO]MAXQTYPCU(W_J)
            W_K = 0
            Break
          Endif
        Next J
      Endif
    Endif
    # Filtre statut
    If W_K = 0
      If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
        Call STKCTRSTA(WSTA,[F:TLO]AUZSST,0,1,0,W_K) From STKACT
      Else
        W_K=0
      Endif
    Endif
    GMESSAGE = ""
    If W_K = 0
      LTYP = [F:TLO]LOCTYP
      Break
    Endif
  Endif
Next W_I
$STKSUGTLO_FIN
End

#############################################################
# Controle type emplacement
#############################################################
# LNOL : Numero de sequence reservation
# LTRS : Type de transaction
# LCOD : Code transaction
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQTE : Quantite
# LSTA : Statut
# LOBL :
# LTYP : Type emplacement
# LRET : Code retour
# LOPT : Options particulieres
#        Q = desactiver controle qte max
#        S = desactiver controle statut
#        U = desactiver controle unite
# LFIL : Filtre sur table TLO
# LWRH : Dépôt
#############################################################
Subprog STKCTRTLO(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,LQTE,LSTA,LOBL,LTYP,LRET,LOPT,LFIL,LWRH)
Value    Decimal  LNOL
Value    Integer  LTRS
Value    Char     LCOD
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQTE
Value    Char     LSTA
Value    Integer  LOBL
Variable Char     LTYP
Variable Shortint LRET
Value    Char     LOPT
Value    Char     LFIL
Value    Char     LWRH
# Il est necessaire d'effectuer l'operation toupper, car dans les documents on utilise
# le type de donnees TEM, qui ne peut avoir l'option "format cle" car on doit pouvoir saisir "*"
LTYP = toupper(LTYP)

Local Integer  WNOL              : WNOL = LNOL
Local Integer  WTRS              : WTRS = LTRS
Local Char     WCOD(GLONADI)     : WCOD = LCOD
Local Char     WFCY(GLONFCY)     : WFCY = LFCY
Local Char     WITM(GLONITM)     : WITM = LITM
Local Char     WPCU(GLONUOM)     : WPCU = LPCU
Local Decimal  WQTE              : WQTE = LQTE
Local Char     WSTA(GLONSTA)     : WSTA = LSTA
Local Char     WTYP(GLONTLO)     : WTYP = LTYP
Local Char     WOPT(len(LOPT)+1) : WOPT = toupper(LOPT)
Local Char     WFIL(250)         : WFIL = "1=1"
Local Char     WWRH(GLONWRH)     : WWRH = LWRH

If LFIL <> ""
  WFIL = LFIL
Endif
# S'il n'y a pas de contrôle d'unité il ne peut pas yy avoir de contrôle de quantité
If instr(1,WOPT,"U") : WOPT+="Q" : Endif
Local Integer  W_I, W_J, W_L
Local Shortint W_K

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
  End
Endif
LRET = 2
If LTYP = ""
  If LOBL = 1
    GMESSAGE = mess(10,123,1)
  Else
    LRET = 0
  Endif
Else
  # Lecture des type d'emplacements autorises
  [M:STLT]STOFCY   = WFCY
  [M:STLT]ITMREF   = WITM
  [M:STLT]TRSTYP   = WTRS
  [M:STLT]TRSCOD   = WCOD
  [M:STLT]FILTRE   = WFIL
  [M:STLT]WRH      = WWRH
  Read [TLO]TLO0=WFCY;WTYP

  W_I = find(WTYP,[M:STLT]LOCTYP(1..[M:STLT]NBLIG-1))
  If !W_I
      #--- Dem 65494
      # Pour forcer le paramčtre 'emplacements suggérés' ŕ 'tous'
      Local Integer  WLOCSUG
      WLOCSUG = GLOCSUG
      GLOCSUG = 1
      #---
      If fstat
        Call REALOCTYP("")
      Else
        Call REALOCTYP(WTYP)
      Endif
      #--- Dem 65494
      GLOCSUG = WLOCSUG

      If instr(1,WTYP,"*") | instr(1,WTYP,"?")
        LRET = 0
        End
      Endif
      If [M:STLT]NBLIG > 1 & [M:STLT]RETCOD = 0
        LRET = 0
        W_L  = 1
        WTYP = [M:STLT]LOCTYP(W_L)
      Endif
      W_I = find(WTYP,[M:STLT]LOCTYP(1..[M:STLT]NBLIG-1))
  Endif
  If WTYP=LTYP & W_I <> 0
    Read [TLO]TLO0=[M:STLT]STOFCY;[M:STLT]LOCTYP(W_I)
    If fstat = 0
      W_K = 1
      # Filtre unite
      If [F:TLO]PCUNBR = 0 | instr(1,WOPT,"Q") | instr(1,WOPT,"U")
        W_K = 0
      Else
        For W_J = 0 To [F:TLO]PCUNBR-1
          If WPCU = [F:TLO]PCU(W_J)
            W_K = 0
            Break
          Endif
        Next J
      Endif
      # Filtre statut
      If W_K = 0
        If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
          Call STKCTRSTA(WSTA,[F:TLO]AUZSST,0,1,0,W_K) From STKACT
        Else
          W_K=0
        Endif
      Endif
      If W_K = 0
        LRET = 0
      Else
        LRET = 2
        GMESSAGE = LTYP-mess(16,196,1)
      Endif
    Endif
  Else
    GMESSAGE = LTYP-mess(16,196,1)
    LRET = 2
  Endif
Endif
End

#############################################################
# Chargement premier emplacement libre
#############################################################
# LNOL : Numero de sequence reservation
# LTRS : Type de transaction
# LCOD : Code transaction
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQTE : Quantite
# LSTA : Statut
# LTYP : Type emplacement
# LVAL : Emplacement de depart et selectionne
# LBPR : Numero tiers
# LOPT : Options particulieres
# LFIL : Nom du champ filtre sur table [F:TLO]
# LWRH : Dépôt
#############################################################
Subprog STKSUGEMP(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,LQTE,LSTA,LTYP,LVAL,LBPR,LOPT,LFIL,LWRH)
Value    Decimal  LNOL
Value    Integer  LTRS
Value    Char     LCOD
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQTE
Value    Char     LSTA
Variable Char     LTYP
Variable Char     LVAL
Value    Char     LBPR
Value    Char     LOPT
Value    Char     LFIL
Value    Char     LWRH

Local Char     WVAL(GLONLOC)  : WVAL = LVAL

LTYP = vireblc(LTYP,4)
# S'il y a quelque chose dans LVAL, cela veut dire que le type d'emplacement n'a pas été modifié,
# on n'a donc pas de raison de le modifier (sauf si incohérent / dépôt).
If LNOL = 0 | LQTE = 0 | LVAL <> ""
  #---
  If LVAL<>""
     Read [STC]STC0=LFCY;LVAL
     If !fstat & ([F:STC]WRH="" | [F:STC]WRH=LWRH)
        Goto STKSUGEMP_FIN
     Endif
  Else
     Goto STKSUGEMP_FIN
  Endif
  #Goto STKSUGEMP_FIN
  #---
Endif

Local Integer  WNOL           : WNOL = LNOL
Local Integer  WTRS           : WTRS = LTRS
Local Char     WCOD(GLONADI)  : WCOD = LCOD
Local Char     WFCY(GLONFCY)  : WFCY = LFCY
Local Char     WITM(GLONITM)  : WITM = LITM
Local Char     WPCU(GLONUOM)  : WPCU = LPCU
Local Decimal  WQTE           : WQTE = LQTE
Local Char     WSTA(GLONSTA)  : WSTA = LSTA
Local Char     WTYP(GLONTLO)  : WTYP = LTYP
Local Char     WVAL(GLONLOC)  : WVAL = LVAL
Local Char     WBPR(GLONBPR)  : WBPR = LBPR
Local Char     WOPT(len(LOPT)+1) : WOPT = toupper(LOPT)
Local Char     WFIL(250)      : WFIL = "1=1"
Local Char     WWRH(GLONWRH)  : WWRH = LWRH
If LFIL <> ""
  WFIL = LFIL
Endif
# S'il n'y a pas de contrôle d'unité il ne peut pas y avoir de contrôle de quantité
If instr(1,WOPT,"U") : WOPT+="Q" : Endif

Local Shortint WRET
Local Char     WOBS
Local Integer  WMAX           : # Nombre d'emplacements maximum
Local Char     WSEL(GLONLOC)
Local Decimal  WQTY
Local Decimal  WMAXQTY
Local Char     WUOM(GLONUOM)

Local Integer  W_I, W_J, W_L, W_M, W_N
Local Char     W_LOCFIL(250)
Local Integer  W_SWL          # Indique si un emplacement réservé (par qqn d'autre ou sur une autre ligne)
                              # est interdit (0=ok 1=interdit)
Local Shortint W_K
Local Integer  W_RET
Local Integer  LLIGW

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
  End
Endif

# Lecture des type d'emplacements autorises
[M:STLT]STOFCY   = WFCY
[M:STLT]ITMREF   = WITM
[M:STLT]TRSTYP   = WTRS
[M:STLT]TRSCOD   = WCOD
[M:STLT]FILTRE   = WFIL
[M:STLT]WRH      = WWRH

Call REALOCTYP(WTYP)

WMAX = -1
W_I = find(WTYP,[M:STLT]LOCTYP(1..[M:STLT]NBLIG-1))
If W_I = 0
  For W_I = 1 To [M:STLT]NBLIG-1
    Gosub LEC_TLO
    If W_M <> 0
      Break
    Endif
  Next W_I
Else
  Gosub LEC_TLO
Endif
#--- Bug 65488
# Le type d'emplacement est correct
#If W_M=2
#  LTYP = [F:TLO]LOCTYP
#Else
#  Raz LTYP
#Endif
If W_M<>2 Raz LTYP Endif
#---

If WSEL <> ""
  WVAL = WSEL
  If WNOL>100000
    WSEQW=WNOL-100000
  Else
    WSEQW=WNOL
  Endif
  #------- Recherche dans STOENTW l'emplacement qui doit rester réservé tel quel ---#
  If clalev([ENTW])
    LLIGW = sigma( 0,[M:ENTW]NBLIG-1,(indcum+1)*(WSEQW=[M:ENTW]WLOCSEQ(indcum) & [M:ENTW]WSTOSEQ(indcum)<>0) )-1
  Elsif clalev([SGW])
    LLIGW = sigma( 0,[M:SGW]NBLIG-1,(indcum+1)*(WSEQW=[M:SGW]WLOCSEQ(indcum) & [M:SGW]WSTOSEQ(indcum)<>0) )-1
  Endif
  If WNOL>100000
    Read [F:SWL]SWL0=adxuid(1);WNOL-100000
    If !fstat
      If [F:SWL]LOC<>WVAL
        Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,WRET)
      Else
        Call STKDELRES(WNOL, WFCY, "", W_RET) From STKLOC
      Endif
    Endif
  Else
    Read [F:SWL]SWL0=adxuid(1);WNOL
    If fstat | LLIGW<0
      Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,WRET)
      Look [F:SWL]SWL0=adxuid(1);WNOL+100000
      If !fstat
        Call STKDELRES(WNOL+100000, WFCY, "", W_RET) From STKLOC
      Endif
    Else
      If [F:SWL]LOC<>WVAL
        WNOL+=100000
        Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,WRET)
      Else
        # on ne fait rien
      Endif
    Endif
  Endif

  If WRET = 0
    LVAL = [F:STC]LOC
    LWRH = [F:STC]WRH
  Else
    FIN = 0
  Endif
Elsif W_M=2
  GMESSAGE = mess(201,184,1)+"\"+mess(202,184,1)
  GERR = 2
  If WNOL>100000
    Call STKDELRES(WNOL, WFCY, "", W_RET) From STKLOC
  Endif
  LVAL = ""
Else
  GMESSAGE = mess(17,196,1)
  GERR = 2
  If WVAL <> ""
    GMESSAGE += " (>"+WVAL+")"
  Endif
  If WNOL>100000
    Call STKDELRES(WNOL, WFCY, "", W_RET) From STKLOC
  Endif
  LVAL = ""
Endif

$STKSUGEMP_FIN
End

#############################################################
# Controle emplacement
#############################################################
# LNOL : No séquence emplacement (WLOCSEQ)
# LTRS : Type de transaction
# LCOD : Code transaction
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQTE : Quantite
# LSTA : Statut
# LTYP : Type emplacement
# LVAL : Emplacement de depart et selectionne
# LBPR : Numero de tiers
# LOBL : Obligatoire (1=Oui)
# LRET : Code retour (mkstat)
# LOVF : Depassement quantite
# LOPT : Options diverses = ""   on contrôle tout
#                           "U"  pas de contrôle unité
#                           "Q"  pas de contrôle quantité
#                           "S"  pas de contrôle statut
# LFIL : Nom du champ filtre sur table [F:TLO]
# LWRH : Dépôt
#
# REMARQUES : Si LTRS=13 (Inventaires), LRET prend la valeur 1
#           si message non bloquant et 2 si message bloquant
#           Seuls l'existence et l'obligation d'en saisir sont bloquants
############################################################
Subprog STKCTREMP(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,LQTE,LSTA,LTYP,LVAL,LBPR,LOBL,LRET,LOVF,LOPT,LFIL,LWRH)
Variable Decimal  LNOL
Value    Integer  LTRS
Value    Char     LCOD
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQTE
Value    Char     LSTA
Variable Char     LTYP
Variable Char     LVAL
Value    Char     LBPR
Value    Integer  LOBL
Variable Shortint LRET
Variable Decimal  LOVF
Value    Char     LOPT
Value    Char     LFIL
Value    Char     LWRH

# Il est necessaire d'effectuer l'operation toupper, car dans les documents on utilise
# le type de donnees EMP, qui ne peut avoir l'option "format cle" car on doit pouvoir saisir "*"
LVAL = toupper(LVAL)

#--- Bug 80087
If clalev([F:STC0]) = 0 : Local File STOLOC       [STC0] : Endif

Local Integer  WNOL           : WNOL = LNOL
Local Integer  WTRS           : WTRS = LTRS
Local Char     WCOD(GLONADI)  : WCOD = LCOD
Local Char     WFCY(GLONFCY)  : WFCY = LFCY
Local Char     WITM(GLONITM)  : WITM = LITM
Local Char     WPCU(GLONUOM)  : WPCU = LPCU
Local Decimal  WQTE           : WQTE = LQTE
Local Char     WSTA(GLONSTA)  : WSTA = LSTA
Local Char     WTYP(GLONTLO)  : WTYP = LTYP
Local Char     WVAL(GLONLOC)  : WVAL = vireblc(LVAL,4)
Local Char     WBPR(GLONBPR)  : WBPR = LBPR
Local Char     WOPT(len(LOPT)+1) : WOPT = toupper(LOPT)
Local Char     WFIL(250)      : WFIL = "1=1"
Local Char     WWRH(GLONWRH)  : WWRH = LWRH
Local Integer  LLIGW
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char     LMSKCOU(10) : LMSKCOU = func STKLIB.MSKDEF

If GIMPORT & LVAL = "" & [F:ITF]LOCMGTCOD <> 2         # hcb 107076
   End
Endif


#--- Bug 61447
# Site avec gestion de dépôt ?
If LFCY<>[F:FCY]FCY
  Read [FCY]FCY0=LFCY
Endif
#---
If LFIL <> ""
  WFIL = LFIL
Endif
# S'il n'y a pas de contrôle d'unité il ne peut pas y avoir de contrôle de quantité
If instr(1,WOPT,"U") : WOPT+="Q" : Endif

LOVF = 0
Raz GMESSAGE
# Controle presence obligatoire
If WVAL = ""
  If LOBL = 1
    LRET = 2
    GMESSAGE = mess(553,197,1)
  Else
    LRET = 0
  Endif
  Goto STKCTREMP_FIN
Endif

If WQTE=0    # C'est possible dans le cas des inventaires
  Goto STKCTREMP_FIN
Endif

Local Char     WDATREF
Local Char     WDATSTC
Local Decimal  W_MAX, W_QTY
Local Char     W_PCU(GLONUOM)
Local Integer  W_I, W_J, W_RET
Local Shortint W_K

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
  End
Endif
# Lecture des type d'emplacements autorises
[M:STLT]STOFCY   = WFCY
[M:STLT]ITMREF   = WITM
[M:STLT]TRSTYP   = WTRS
[M:STLT]TRSCOD   = WCOD
[M:STLT]FILTRE   = WFIL
[M:STLT]WRH      = WWRH
Read  [STC]STC0=WFCY;WVAL
If fstat
  LRET = 2
  GMESSAGE = LVAL-mess(233,192,1)
  Goto STKCTREMP_FIN
# L'emplacement n'appartient pas au dépôt
#--- Bug 63204
#Elsif [M:STLT]WRH<>"" & [F:STC]WRH<>[M:STLT]WRH
Elsif [F:STC]LOCCAT<3 & [M:STLT]WRH<>"" & [F:STC]WRH<>[M:STLT]WRH
  LRET = 2
  GMESSAGE = LVAL-":"-mess(341,184,1)-[M:STLT]WRH
  Goto STKCTREMP_FIN
Endif
#--- les caractéristiques qui nous intéressent dans le type ne changent normalement pas ---#
If [M:STLT]STOFCY<>[F:TLO]STOFCY | [F:STC]LOCTYP<>[F:TLO]LOCTYP
  Read [TLO]TLO0=[M:STLT]STOFCY;[F:STC]LOCTYP
  If fstat
    LRET = 2
    GMESSAGE = [F:STC]STOFCY-[F:STC]LOCTYP-mess(245,192,1)
    Goto STKCTREMP_FIN
  Endif
Endif

#--- Bug 61447
# Gestion de dépôt sur le site et le dépôt n'est pas un filtre
# --> vérification de l'existence de l'article dépôt
#--- Bug 63204
#If [F:FCY]WRHGES=2 & [M:STLT]WRH=""
# Issue 109575 - 2015-07-21 by SR : Si article multiple, pas de possibilité de contrôle
#If [F:FCY]WRHGES=2 & [F:STC]LOCCAT<3 & [M:STLT]WRH=""
# Issue 113580 - 2016-01-07 by MAE : ajout du test sur code activité dépot
#If [F:FCY]WRHGES=2 & [F:STC]LOCCAT<3 & [M:STLT]WRH="" & [M:STLT]ITMREF <> "*****"
If GWRHACT=2 & [F:FCY]WRHGES=2 & [F:STC]LOCCAT<3 & [M:STLT]WRH="" & [M:STLT]ITMREF <> "*****"
  Read [ITW]ITW0=[M:STLT]ITMREF;[F:STC]WRH
  If fstat
    LRET = 2
    GMESSAGE = [M:STLT]ITMREF-":"-mess(978,196,1)-[F:STC]WRH
    Goto STKCTREMP_FIN
  Endif
Endif
#---
# Test statut autorisé si pas emplacement quai ou sta<>"" et emplacement quai
If !instr(1,WOPT,"S") & !([F:TLO]LOCCAT=2 & WSTA="")
  Call STKCTRSTA(WSTA,[F:STC]AUZSST,0,1,0,W_K) From STKACT
Else
  W_K=0
Endif
If W_K <> 0
  LRET = 2
  If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
  GMESSAGE += LVAL-mess(832,196,1)-"("+WSTA+")"
  If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
Endif
# Test emplacement en inventaire
If [F:STC]CUNLOKFLG = 2 & LTRS<>13
  LRET = 2
  If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
  GMESSAGE += LVAL-mess(175,193,1)
  If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
Endif

If func STKLOC.TESTTLO([F:TLO]STOFCY,[F:TLO]LOCTYP)=0
  # Controle unite et quantite maximale (Si # 0)
  If !instr(1,WOPT,"U") & !instr(1,WOPT,"Q") & [F:TLO]PCUNBR <> 0
      W_K = 1
      For W_J = 0 To [F:TLO]PCUNBR-1
        If WPCU = [F:TLO]PCU(W_J)
          If [F:TLO]MAXQTYPCU(W_J) = 0
            W_K   = 0
            W_MAX = 0
            Break
          Else
            If  WQTE <= [F:TLO]MAXQTYPCU(W_J)
              W_K   = 0
              W_MAX = [F:TLO]MAXQTYPCU(W_J)
              Break
            Else
              LOVF = [F:TLO]MAXQTYPCU - WQTE
            Endif
          Endif
        Endif
      Next J
  Endif
  If W_K = 1
    LRET = 2
    If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
    GMESSAGE += LVAL-mess(39,196,1)
    If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
  Endif

  # Si plusieurs articles (ADC) pas de contrôle dédié
  If WITM<>""
    # Controle dedie
    If [F:TLO]DEDFLG = 2
      Read [STF]STF0=WFCY;LVAL;WITM
      If fstat
        LRET = 2
      Else
        Filter [SWL] Where STOFCY  = LFCY       &
&                          LOC     = [F:STC]LOC &
&                          ITMREF <> WITM
&                    Order By Key SWL1
        For [SWL]
          If !([F:SWL]PRONUM = adxuid(1) & ([F:SWL]LINNUM = LNOL | [F:SWL]LINNUM = LNOL-100000 | [F:SWL]LINNUM = LNOL+100000))
&          & [F:SWL]LOKDAT+[F:SWL]LOKHOU > date$+mid$(time$,1,2)+mid$(time$,4,2)
            LRET = 2
            Break
          Endif
        Next
        Filter [SWL]
      Endif
      If LRET = 2
        If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
        GMESSAGE += LVAL-mess(831,196,1)
        If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
      Endif
    Endif
  Endif
  # Controle mono article
  If [F:TLO]MONITMFLG = 2
    # Si plusieurs articles (ADC)
    If WITM=""
      LRET = 2
      If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
      GMESSAGE += LVAL-mess(85,196,1)-"("+[F:STO0]ITMREF+")"
      Goto STKCTREMP_FIN
    Endif
    Filter [STO0] Where STOFCY  = WFCY       &
&                       LOC     = [F:STC]LOC &
&                       ITMREF <> WITM
&                 Order By Key STO4
    For [STO0]
      LRET = 2
      If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
      GMESSAGE += LVAL-mess(85,196,1)-"("+[F:STO0]ITMREF+")"
      Break
    Next
    Filter [STO0]
    If LRET <> 0
      If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
    Endif
    Filter [SWL] Where  STOFCY  = WFCY       &
&                       LOC     = [F:STC]LOC &
&                       ITMREF <> WITM
    For [SWL]
      If !([F:SWL]PRONUM=adxuid(1) & ([F:SWL]LINNUM=LNOL | [F:SWL]LINNUM=LNOL-100000 | [F:SWL]LINNUM=LNOL+100000))
&      & [F:SWL]LOKDAT+[F:SWL]LOKHOU > date$+mid$(time$,1,2)+mid$(time$,4,2)
        LRET = 2
        If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
        GMESSAGE = LVAL-mess(85,196,1)-"("+[F:SWL]ITMREF+")"
        Break
      Endif
    Next
    Filter [SWL]
    If LRET <> 0
      If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
    Endif
  Endif
  # Controle remplissage
  If [F:STC]FILMGTFLG =2 & !instr(1,WOPT,"Q") & [F:TLO]PCUNBR <> 0
    Raz W_QTY, W_PCU
    Filter [SWL] Where STOFCY = LFCY       &
&                      LOC    = [F:STC]LOC
&                Order By Key SWL1
    For [SWL]
      WDATSWL = [F:SWL]LOKDAT+[F:SWL]LOKHOU
      If WDATREF <= WDATSWL
        W_PCU  = [F:SWL]PCU
        If !([F:SWL]PRONUM = adxuid(1) & ([F:SWL]LINNUM = LNOL | [F:SWL]LINNUM = LNOL-100000 | [F:SWL]LINNUM = LNOL+100000))
&        & [F:SWL]LOKDAT+[F:SWL]LOKHOU > date$+mid$(time$,1,2)+mid$(time$,4,2)
          W_QTY += [F:SWL]QTYPCU
        Endif
      Endif
    Next
    Filter [SWL]
    If W_PCU = "" | W_PCU = WPCU
      # Si l'emplacement a complčtement été déréservé, on peut l'utiliser "comme on veut"
      If [F:STC]PCU = "" | WQTE+W_QTY=0
        If ([F:STC]QTYPCU + WQTE+ W_QTY) > W_MAX
          LRET = 2
          If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
          GMESSAGE += mess(404,199,1)
          If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
        Endif
      Else
        If [F:STC]PCU <> WPCU
          LRET = 2
          If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
          GMESSAGE += LVAL-mess(671,196,1)-"("-[F:STC]PCU+")"
          If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
        Else
          If ([F:STC]QTYPCU + WQTE + W_QTY) > W_MAX
            LRET = 2
            If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
            GMESSAGE += LVAL-mess(404,199,1)-"("+num$(W_MAX)-WPCU+")"
            If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
          Endif
        Endif
      Endif
    Else
      LRET = 2
      If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
      GMESSAGE = LVAL-mess(417,199,1)
      If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
    Endif
  Endif
# hcb 35935 debut
  GPOINT = "CTRSTKLOC"
  Global Integer GTR
  GTR  = LTRS
  GPE  = 0
  Gosub  ENTREE From EXEFNC
  If GPE <> 0
     LRET = 2
  Endif
  If LRET = 2  Goto STKCTREMP_FIN  : Endif
# hcb 35935 fin
Else
  LRET = 2
  If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
  GMESSAGE = LVAL-mess(16,196,1)
  If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
  Goto STKCTREMP_FIN
Endif

If LRET = 0 & WNOL>0
  If WNOL>100000
    WSEQW=WNOL-100000
  Else
    WSEQW=WNOL
  Endif
  #------- Recherche dans STOENTW l'emplacement qui doit rester réservé tel quel ---#
  If LTRS <> 34                     # hcb test V6dem
     If clalev([ENTW])
        LLIGW = sigma( 0,[M:ENTW]NBLIG-1,(indcum+1)*(WSEQW=[M:ENTW]WLOCSEQ(indcum) & [M:ENTW]WSTOSEQ(indcum)<>0) )-1
     Elsif clalev([SGW])
        LLIGW = sigma( 0,[M:SGW]NBLIG-1,(indcum+1)*(WSEQW=[M:SGW]WLOCSEQ(indcum) & [M:SGW]WSTOSEQ(indcum)<>0) )-1
     Endif
  Endif
  If WNOL>100000
    Read [F:SWL]SWL0=adxuid(1);WNOL-100000
    If !fstat
      If [F:SWL]LOC<>WVAL
        Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,LRET)
      Else
        Call STKDELRES(WNOL, WFCY, "", W_RET) From STKLOC
      Endif
    Endif
  Else
    Read [F:SWL]SWL0=adxuid(1);WNOL
    If fstat | LLIGW<0
      Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,LRET)
      Look [F:SWL]SWL0=adxuid(1);WNOL+100000
      If !fstat
        Call STKDELRES(WNOL+100000, WFCY, "", W_RET) From STKLOC
      Endif
    Else
      If [F:SWL]LOC<>WVAL
        WNOL+=100000
        Call STKCRERES(WNOL,WFCY,WITM,WPCU,WQTE,WSTA,WVAL,WVAL,WBPR,LRET)
      Endif
    Endif
  Endif

  LNOL = WNOL
  LTYP = [F:STC]LOCTYP    # CCC : 05/06/03 - au cas oů le type contenait un filtre
  #If evalue("dim("+LMSKCOU+"LOCTYP)")>nolign-1
  #  Affzo [M]LOCTYP(nolign-1)
  #Endif
Endif
# Test emplacement bloque
If LRET=0 & [F:STC]LOKSTA = 2
  W_K=1
  If clalev([M:SGW])
    W_I=find(LNOL,[M:SGW]WLOCSEQ)
    If W_I>0
      Read [STO]STO0=[M:SGW]FCYDES;[M:SGW]WSTOCOU(W_I-1)
      If !fstat & [F:STO]LOC=WVAL
        W_K=0
      Endif
    Endif
  Endif
  If W_K<>0
    #MAE, le 25/07/08, bg 48491, GERR n'est pas réinitialiser
    #GERR = 2
    LRET = 2
    If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
    GMESSAGE += LVAL-mess(672,196,1)
    If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
  Endif
Elsif LRET=0
  WDATREF = date$+mid$(time$,1,2)+mid$(time$,4,2)
  WDATSTC = [F:STC]AVADAT+[F:STC]AVAHOU
  If WDATSTC > WDATREF
    #MAE, le 25/07/08, bg 48491, GERR n'est pas réinitialiser
    LRET = 2
    #GERR = 2    # msg d'info
    If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
    GMESSAGE += LVAL-mess(104,184,1)+num$([F:STC]AVADAT)-left$(num$([STC]AVAHOU),2)+":"+right$(num$([STC]AVAHOU),3)
    If LTRS<>13 : Goto STKCTREMP_FIN Else LRET=1 : Endif
  Endif
Endif

#--- Issue 94497 by TS : Pb performances
#If evalue("dim("+LMSKCOU+"LOCTYP)")> 0 & !GIMPORT # hcb 82353
#  Affzo [M]LOCTYP(nolign-1)
#Endif
#---

$STKCTREMP_FIN
End

#############################################################
# Controle emplacement apres modification caracteristiques ligne stock
#############################################################
# LNOL : Nolign (si tableau) -1 sinon
# LTRS : Type de transaction
# LCOD : Code transaction
# LFCY : Site
# LITM : Article
# LPCU : Unite
# LQAV : Quantite avant
# LQAP : Quantite apres
# LSTA : Statut
# LTYP : Type emplacement
# LVAL : Emplacement de depart et selectionne
# LBPR : Numero de tiers
# LRET : Code retour (mkstat)
# LOVF : Depassement quantite
# LOPT : Options diverses
# LFIL : Nom du champ filtre sur table [F:TLO]
#############################################################
Subprog STKVALEMP(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,LQAV,LQAP,LSTA,LTYP,LVAL,LBPR,LRET,LOVF,LOPT,LFIL)
Value    Decimal  LNOL
Value    Integer  LTRS
Value    Char     LCOD
Value    Char     LFCY
Value    Char     LITM
Value    Char     LPCU
Value    Decimal  LQAV
Value    Decimal  LQAP
Value    Char     LSTA
Variable Char     LTYP
Variable Char     LVAL
Value    Char     LBPR
Variable Shortint LRET
Variable Decimal  LOVF
Value    Char     LOPT
Value    Char     LFIL

# Gestion des emplacements non initialisee
If clalev([M:STLT])  = 0
  Call ERREUR(mess(68,123,1)) From GESECRAN
Else
  Local Decimal WQTE : WQTE = LQAP - LQAV
  # Pas de controle si pas de statut ou pas d'emplacement
  If !(LVAL = "" | LSTA = "" | WQTE < 0)
     Call STKCTREMP(LNOL,LTRS,LCOD,LFCY,LITM,LPCU,WQTE,LSTA,LTYP,LVAL,LBPR,1,LRET,LOVF,LOPT,LFIL,"")
  Endif
  # Mise a jour reservation
  If !(LVAL = "" | LSTA = "")
    If LRET = 0
      Call STKCRERES(LNOL,LFCY,LITM,LPCU,LQAP,LSTA,LVAL,LVAL,LBPR,LRET)
    Endif
  Endif
Endif
End

#############################################################
# Ce sous programme permet de modifier le numero de sequence des reservations
# si nolign est utilise au lieu d'un numero de sequence (CE QUI EST DECONSEILLE)
#############################################################
# LNOL : Numero de sequence de depart
# LINC : Increment positif (+1) si insertion / negatif (-1) si suppression
# LRET : Code retour : 0 = OK / 1 Erreur locke (et GOK= -1) / 2 = Erreur E/S (et GOK=0)
#
# Exemple :
# Si on insere une ligne entre la ligne 2 et la ligne 3
# Call STKMODRES(3,1)
#   Les reservations de l'ancienne ligne 3 seront affectees a la ligne 4
#   Les reservations de l'ancienne ligne 4 seront affectees a la ligne 5 etc...
#
# ATTENTION !
# En cas d'utilisation en insertion de ligne ne pas ommettre d'annuller la renumerotation
# si on sort de l'insertion par Escape
#
# Exemple
# Call STKMODRES(4,-1)
#   Les reservations de l'ancienne ligne 4 seront affectees a la ligne 3
#   Les reservations de l'ancienne ligne 5 seront affectees a la ligne 4 etc...
#############################################################
Subprog STKMODRES(LNOL,LINC,LRET)
Value    Decimal  LNOL
Value    Integer  LINC
Variable Integer  LRET
Local Integer WOUVTRS : WOUVTRS = 0

Raz LRET

If LINC <> 0 & GOK = 1
  If adxlog = 0
     WOUVTRS = 1
     Trbegin [SWL]
  Endif
  If LINC > 0
    Filter [SWL] Where PRONUM  = adxuid(1) &
&                      LINNUM >= LNOL
&                Order By LINNUM Desc
  Else
    Filter [SWL] Where PRONUM  = adxuid(1) &
&                      LINNUM >= LNOL
&                Order By Key SWL0
  Endif
  For [SWL]
    [F:SWL]LINNUM += LINC
    Rewrite [SWL]
    If fstat
      GOK = 0
      Call FSTA("SWL") From GLOCK
      Break
    Endif
  Next
  Filter [SWL]
  If WOUVTRS = 1
      Case GOK
        When 1 :
          Commit
        When -1 :
          Rollback
          LRET = 1
        When Default :
          Rollback
          LRET = 2
      Endcase
  Else
     Case GOK
        When 1 :
          LRET = 0
        When -1 :
          LRET = 1
        When Default :
          LRET = 2
      Endcase
  Endif
Endif
End

############################################################
# Ce sous programme permet de modifier le numero de sequence des reservations
############################################################
# LOLD : Numero de sequence a modifier
# LNEW : Nouveau numero de sequence
# LRET : Code retour : 0 = OK / 1 Erreur locke (et GOK= -1) / 2 = Erreur E/S (et GOK=0)
#############################################################
Subprog STKCHGRES(LOLD,LNEW,LRET)
Value    Integer  LOLD
Value    Integer  LNEW
Variable Integer  LRET

Local Integer WOUVTRS : WOUVTRS = 0
Raz LRET

If GOK = 1
  If adxlog = 0
     WOUVTRS = 1
     Trbegin [SWL]
  Endif
  Readlock [SWL]SWL0=adxuid(1);LOLD
  Case fstat
    When 0 :
      [F:SWL]LINNUM = LNEW
      Rewrite [SWL]
      If fstat
        GOK = 0
        Call FSTA("SWL") From GLOCK
      Endif
    When 1 :
      GOK = -1
    When 4, 5 :
    When Default :
      GOK = 0
      Call FSTA("SWL") From GLOCK
  Endcase

  If WOUVTRS = 1
      Case GOK
        When 1 :
          Commit
        When -1 :
          Rollback
          LRET = 1
        When Default :
          Rollback
          LRET = 2
      Endcase
  Else
      Case GOK
        When 1 :
          LRET = 0
        When -1 :
          LRET = 1
        When Default :
          LRET = 2
      Endcase
  Endif
Endif
End

########################################################################
# STKCTREMPS : Controle emplacement en sortie
########################################################################
# Parametres E : LEMP    = Emplacement a controler
#                LFCY    = Site stock
#                LLOCCAT = Categories emplacements autorises
#                          ex : "124" --> Emp interne + quai + sous-traitant
#                LBPR    = Tiers si emplacement tiers autorise
#                LWRH    = Dépôt
#
#            S : mkstat est positionne a 2 si erreur
#
########################################################################
Subprog STKCTREMPS(LEMP, LFCY, LLOCCAT, LBPR, LWRH)
Variable Char    LEMP
Value    Char    LFCY
Value    Char    LLOCCAT
Value    Char    LBPR
Value    Char    LWRH

If LEMP="" End Endif

LEMP = toupper(LEMP)

If clalev([F:STC])=0  Local File STOLOC   [STC]  Endif

Read [STC]STC0=LFCY;LEMP
If fstat
  # Emplacement inconnu
  GERR=2 : GMESSAGE=mess(18,196,1)
Elsif !pat(LLOCCAT,"*"+num$([F:STC]LOCCAT)+"*")
  # Categorie d'emplacement non autorise
  GMESSAGE=mess(399,199,1)
  mkstat=2
# Issue 110927 - 2015-10-22 by MAE : les emplacements bloqués n'empechent pas les sorties.
#Elsif [F:STC]LOKSTA=2 | [F:STC]CUNLOKFLG=2
Elsif [F:STC]CUNLOKFLG=2
  # Emplacement non disponible
  GMESSAGE=mess(18,196,1)
  mkstat=2
#--- Bug 63204
#Elsif LWRH<>"" & [F:STC]WRH<>LWRH
Elsif LWRH<>"" & [F:STC]LOCCAT<3 & [F:STC]WRH<>LWRH
  # L'emplacement n'appartient pas au dépôt
  GMESSAGE = LEMP-":"-mess(341,184,1)-LWRH
  mkstat=2
Endif

End

#############################################################
# Controle emplacement en modification de sortie
# Diminution de la quantité ou suppression de la sortie
#############################################################
# Parametres E : LEMP : Emplacement ŕ contrôler
#            S : mkstat est positionne a 2 si erreur
#
############################################################
Subprog STKCTREMPM(LEMP)
Value    Char     LEMP

If clalev([F:STC]) =0  Local File STOLOC    [STC]   Endif
If clalev([F:TLO]) =0  Local File TABLOCTYP [TLO]   Endif
If clalev([F:STO0])=0  Local File STOCK     [STO0]  Endif
If clalev([F:SWL]) =0  Local File STOLOCRES [SWL]   Endif

Read  [STC]STC0=[M:SOM]STOFCY;LEMP
If fstat
  mkstat=2 : GMESSAGE=LEMP-mess(233,192,1) : End
Endif
If [F:STC]STOFCY<>[F:TLO]STOFCY | [F:STC]LOCTYP<>[F:TLO]LOCTYP
  Read [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
  If fstat
    mkstat=2 : GMESSAGE=[F:STC]STOFCY-[F:STC]LOCTYP-mess(245,192,1) : End
  Endif
Endif

# Test emplacement en inventaire
If [F:STC]CUNLOKFLG=2
  If GMESSAGE<>"" : GMESSAGE+=chr$(13) : Endif
  mkstat=2 : GMESSAGE+=LEMP-mess(175,193,1)
  End
Endif

# Controle mono article
If [F:TLO]MONITMFLG=2
  Filter [STO0] Where STOFCY = [F:STC]STOFCY &
&                     LOC    = [F:STC]LOC    &
&                     ITMREF<> [M:SOM]ITMREF
&               Order By Key STO4
  For [STO0]
    If GMESSAGE<>"" : GMESSAGE+=chr$(13) : Endif
    mkstat=2 : GMESSAGE+=LEMP-mess(85,196,1)-"("+[F:STO0]ITMREF+")"
    Break
  Next
  Filter [STO0]
  If mkstat<>0 : End : Endif
  Filter [SWL] Where  STOFCY = [F:STC]STOFCY &
&                     LOC    = [F:STC]LOC    &
&                     ITMREF<> [M:SOM]ITMREF &
&                     PRONUM<> adxuid(1)
  For [SWL]
    If [F:SWL]LOKDAT+[F:SWL]LOKHOU>date$+mid$(time$,1,2)+mid$(time$,4,2)
      If GMESSAGE<>"" : GMESSAGE+=chr$(13) : Endif
      mkstat=2 : GMESSAGE=LEMP-mess(85,196,1)-"("+[F:SWL]ITMREF+")"
      Break
    Endif
  Next
  Filter [SWL]
  If mkstat<>0 : End : Endif
Endif

End

########################################################################
# STKCTRSRG   : Vérifie que l'emplacement est de type quai et appartient
#               au site passé en paramčtre
########################################################################
#
# Paramčtres E : PLOC : emplacement ŕ contrôler
#                PFCY : Site
#                PWRH : Dépôt
#                POBL : Obligatoire (0=Non, 1=Oui)
#
# Positionne GMESSAGE et mkstat en cas d'erreur
########################################################################
Subprog STKCTRSRG(PLOC, PFCY, PWRH, POBL)
Variable Char PLOC
Value Char    PFCY
Value Char    PWRH
Value Integer POBL

Raz mkstat
If PLOC=""
  If POBL=1
    GMESSAGE=mess(27,184,1)
    mkstat = 2
  Endif
  End
Endif
PLOC = toupper(PLOC)
Read [STC]STC0=PFCY;PLOC
If fstat
  GMESSAGE=mess(233,192,1)
  mkstat = 2
  End
Endif
If [F:STC]LOCCAT<>2
  GMESSAGE=mess(242,192,1)
  mkstat = 2
  End
Endif
If GWRHACT=2 & PWRH<>""
  If [F:STC]WRH<>PWRH
    GMESSAGE=mess(341,184,1)-[F:STC]WRH
    mkstat = 2
    End
  Endif
Endif
End

#############################################################
# Sélection emplacement de type quai uniquement
#############################################################
$STKSELQUA
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
TIT(0) = mess(22,123,1)
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC("STOLOC",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If GWRHACT=2
  NBCOL += 1 : COL(NBCOL) = "WRH"
  Call TEXTFIC("STOLOC",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC("STOLOC",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]LOKSTA,1,1)"
Call TEXTFIC("STOLOC","LOKSTA",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STC]CUNLOKFLG,1,1)"
Call TEXTFIC("STOLOC","CUNLOKFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOCTYP"

CRITERE = "[F:STC]STOFCY=WFCY & [F:STC]LOCCAT=2"
If GWRHACT=2 & PARAM(2)<>""
  CRITERE += "&[F:STC]WRH=PARAM(2)"
Endif

ORDRE   = "LOC"
SIZLIG  = 150
SIZCOL  = 340
Default File [STC]
Return

########################################################################
# STKMODSRG   : Propose de remplacer la précédente valeur par la nouvelle valeur
#                dans le cadre d'une entrée (STOENTW ouvert)
########################################################################
#
# Paramčtres E : PLOCNEW : nouvel emplacement saisi
#                PLOCOLD : empalcement précédent
#                PFCY    : Site
#                PABR    : Abréviation du masque des lignes de document
#                PNBLIG  : Nombre de lignes dans le document
#
########################################################################
Subprog STKMODSRG(PLOCNEW, PLOCOLD, PFCY, PABR, PNBLIG)
Variable Char PLOCNEW
Value    Char PLOCOLD
Value    Char PABR
Value    Char PFCY
Value Integer PNBLIG

Local Integer LRET
Local Integer I,J,F

If PLOCOLD="" | PLOCNEW=""
  End
Endif

Call OUINON(PLOCNEW-mess(54,184,1)-PLOCOLD,LRET) From GESECRAN
If LRET<> 2
  End
Endif
Raz I

If [F:STC]LOC<>PLOCNEW | [F:STC]STOFCY<>PFCY
  Read [STC]STC0=PFCY;PLOCNEW
Endif

Default Mask "["+PABR+"]"

While I>=0
  F=evalue("find(PLOCOLD,[M:"+PABR+"]LOC(I..PNBLIG-1))")
  I += F*(!!F)-(I+1)*(!F)
  If I>0 & ( evalue("[M:"+PABR+"]CREFLG(I-1)")=0
&        | ([M:ENTW]WZONSTOUPD<>"" & evalue("[M:"+PABR+"]"+[M:ENTW]WZONSTOUPD+"(I-1)")>0) )
    Assign "[M:"+PABR+"]LOC(I-1)"    With PLOCNEW
    Assign "[M:"+PABR+"]LOCTYP(I-1)" With [F:STC]LOCTYP
    If evalue("dim([M:"+PABR+"]WRH(I-1))")>0
      Assign "[M:"+PABR+"]WRH(I-1)" With [F:STC]WRH
    Endif
    Affzo [M]LOC(I-1),LOCTYP(I-1)
    If evalue("[M:"+PABR+"]WSTOSEQ(I-1)")>0
      J=0
      While J>=0
        F = evalue("find([M:"+PABR+"]WSTOSEQ(I-1), [M:ENTW]WSTOSEQ(J..[M:ENTW]NBLIG-1))")
        J += F*(!!F)-(J+1)*(!F)
        If J>0
          [M:ENTW]LOC(J-1)    = PLOCNEW
          [M:ENTW]LOCTYP(J-1) = [F:STC]LOCTYP
          [M:ENTW]WRH(J-1)    = [F:STC]WRH
        Endif
      Wend
    Endif
  Endif
Wend

End

#--- Issue 115275
########################################################################
# STKINIEMPSW : Alimente l'emplacement par défaut de la ligne doc en sortie
#               ŕ partir de l'article dépôt
########################################################################
# Paramčtres S : LEMP : Emplacement par défaut
########################################################################
Subprog STKINIEMPSW(LEMP)
Variable Char    LEMP

Local Integer I

If GIMPORT End Endif

# Récupération emp par défaut de l'art-dépôt pour le type mouvement
I = find([F:SRU]LOCNUM-1,[F:ITW]LOCNUM(0..dim([F:ITW]LOCNUM)-1))
If I<>0 & [F:ITW]DEFLOC(I-1)<>"*"
  LEMP = [F:ITW]DEFLOC(I-1)
Endif
End
#--- End issue 115275


########################################################################
# STKINIEMPS : Alimente l'emplacement par défaut de la ligne doc en sortie
########################################################################
# Paramčtres S : LEMP : Emplacement par défaut
########################################################################
Subprog STKINIEMPS(LEMP)
Variable Char    LEMP

Local Integer I

#--- Bug 73528
If GIMPORT End Endif

If LEMP=""
  # Récupération emp par défaut de l'art-site pour le type mouvement
  I = find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
  If I<>0 & [F:ITF]DEFLOC(I-1)<>"*"
    LEMP = [F:ITF]DEFLOC(I-1)
  Endif
Endif
End

########################################################################
# STKINITEMS : Alimente le type d'emp par défaut de la ligne doc en sortie
########################################################################
# Paramčtres S : LTEM : Type d'emplacement par défaut
########################################################################
Subprog STKINITEMS(LTEM)
Variable Char    LTEM

Local Integer I

#--- Bug 73528
If GIMPORT End Endif

If LTEM=""
  # Récupération type emp par défaut de l'art-site pour le type mouvement
  I = find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
  If I<>0 & [F:ITF]DEFLOCTYP(I-1)<>"*"
    LTEM = [F:ITF]DEFLOCTYP(I-1)
  Endif
Endif
End

########################################################################
# STKMODREMP : Pour un emplacement géré en remplissage et en modif
#              d'entrée, on crée une réservation négative.
#              A placer avant la sélection, la suggestion et le contrôle
########################################################################
Subprog STKMODREMP(LNOL,LFCYOLD,LITM,LPCUOLD,LQTYOLD,LSTAOLD,LLOCOLD,LBPR,LRET,LSUP)
Value    Decimal  LNOL
Value    Char     LFCYOLD
Value    Char     LITM
Value    Char     LPCUOLD
Value    Decimal  LQTYOLD
Value    Char     LSTAOLD
Value    Char     LLOCOLD
Value    Char     LBPR
Variable Shortint LRET
Value    Char     LSUP

If LLOCOLD=""
  End
Endif

If [F:STC]LOC <> LLOCOLD | [F:STC]STOFCY<>LFCYOLD
  Read [STC]STC0=LFCYOLD;LLOCOLD
Endif
If [F:STC]FILMGTFLG=2
  Call STKCRERES(-LNOL,LFCYOLD,LITM,LPCUOLD,-min(LQTYOLD,[F:STC]QTYPCU),LSTAOLD,LLOCOLD,LLOCOLD,LBPR,LRET)
Endif

End
