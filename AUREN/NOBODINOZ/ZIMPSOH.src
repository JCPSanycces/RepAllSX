#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# IMPSOH : Import / Export des Commandes Ventes                      #
######################################################################
# Issue X3-38369 - 20170726 by LD : Modification import without SALFCY in the import file : GSOCIETE is bad
# Issue X3-38400 - 20180104 by LD : Field deleted by sale order import
# Issue X3-119240 - 20181227 by LD : Sales Order Line Allocation Import

$ACTION

Case ACTION
 When "IMP_COMPILE"   : maxmem=max(maxmem/1024,5120)
 When "IMP_TRTSUP"    : Gosub IMP_TRTSUP
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_AVANT_MODFIC"  : Gosub IMP_AVANT_MODFIC
 When "IMP_INICRE"    : Gosub IMP_INICRE  : # maj des champs affiches et invisibles de SOH
 When "IMP_INIMOD"    : Gosub IMP_INIMOD  : # maj des champs affiches et invisibles de SOH
 When "INICRE_LIG"    : Gosub INICRE_LIG  : # maj des champs affiches et invisibles de SOP
 When "INIMOD_LIG"    : Gosub INIMOD_LIG  : # maj des champs affiches et invisibles de SOP
 When "VALLIG"        : Gosub VALLIG      : # maj des champs affiches et invisibles de SOQ
 When "IMP_FERME"     : Gosub IMP_FERME
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXPORT"        : Gosub EXPORT
 When "EXP_ZONE"      : Gosub EXP_ZONE

Endcase
Return


#######################################################################
#                        IMPORT
#######################################################################

$IMP_TRTSUP
Local Char FICZON_INT (20) (20)  : # champs interdits en import ( ex: SOP/SOPLIN )
FICZON_INT(0)="SOP/SOPLIN" : FICZON_INT(1)="SOP/SOPSEQ"
FICZON_INT(2)="SOQ/SOPLIN" : FICZON_INT(3)="SOQ/SOQSEQ"
Gosub IMP_CPL From TRTX3IMP

If clalev([M:IMP2])>0 and [M:IMP2]TEST<>2 #--CPO 108787 Ne pas le faire si Test, car perte contexte
  # FGR 04/12/2014 : X3SUIVI103421 (début)
  Gosub OUVRE1 From TRTVENFACR

  Global Char GSZIMPSOH(GLONADC)  # NOTE : déclarer la variable APRES le Gosub OUVRE1

  GSZIMPSOH = "IMPSOH"
  # FGR 04/12/2014 : X3SUIVI103421 (fin)
Endif

Return

######################################################################
# ---
$IMP_OUVRE
Local  Integer TUNNEL
Local  Integer  I, WNOL
Local  Char     WNEWPJT (GLONPJT) : # 71065 : PJT

# --- pour conversion des clients
Global  Integer G_GIMP5, G_GIMP6, G_GIMP7, G_GIMP8, G_GIMP9, G_IMPNUMLIG
Call TST_CHAMP("SOH","*5",G_GIMP5) From SUBIMPOBJ            : # client facture
Call TST_CHAMP("SOH","*6",G_GIMP6) From SUBIMPOBJ            : # client commande
Call TST_CHAMP("SOH","*7",G_GIMP7) From SUBIMPOBJ            : # client payeur
Call TST_CHAMP("SOH","*8",G_GIMP8) From SUBIMPOBJ            : # adresse livraison
Call TST_CHAMP("SOH","*9",G_GIMP9) From SUBIMPOBJ            : # transporteur
Call TST_CHAMP("SOQ","IMPNUMLIG",G_IMPNUMLIG) From SUBIMPOBJ : # no. ligne externe
# ---
Global Integer G_BPCNAM, G_BPDNAM, G_BPINAM
Global Integer G_BPAORD, G_BPAINV
Global Integer G_CNTNAM, G_CNDNAM, G_CNINAM
Global Integer G_LINTYP, G_FOCFLG
Global Integer G_SOQSTA
Global Integer G_PJTH             : # 71065 : PJT
Global Integer G_PJT              : # 71065 : PJT
# Issue X3-119240
Global Integer G_ALLQTY, G_ALLQTYSTU
# End issue X3-119240

# 71065 : PJT
Call TST_CHAMP ("SOH","PJT", G_PJTH)           From SUBIMPOBJ
Call TST_CHAMP ("SOP","PJT", G_PJT)            From SUBIMPOBJ
# 71065 : PJT
Call TST_CHAMP ("SOH","BPCNAM",G_BPCNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","BPDNAM",G_BPDNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","BPINAM",G_BPINAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","BPAORD",G_BPAORD)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","BPAINV",G_BPAINV)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","CNTNAM",G_CNTNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","CNDNAM",G_CNDNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOH","CNINAM",G_CNINAM)       From SUBIMPOBJ
Call TST_CHAMP ("SOP","LINTYP",G_LINTYP)       From SUBIMPOBJ
Call TST_CHAMP ("SOP","FOCFLG",G_FOCFLG)       From SUBIMPOBJ
Call TST_CHAMP ("SOP","SOQSTA",G_SOQSTA)       From SUBIMPOBJ
Local Integer WSOQSTA
Call TST_CHAMP ("SOQ","SOQSTA", WSOQSTA)       From SUBIMPOBJ
If WSOQSTA=1 G_SOQSTA=1 Endif
# Issue X3-119240
Call TST_CHAMP ("SOQ","ALLQTY", G_ALLQTY)       From SUBIMPOBJ
Call TST_CHAMP ("SOQ","ALLQTYSTU", G_ALLQTYSTU) From SUBIMPOBJ
# End issue X3-119240
# ---

Gosub OUVRE_TEXTE

Gosub OUVRE_SIHX From TRTVENFACC
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#     entete *71 ŕ *78 / pied *81 ŕ *88 / ligne *91 ŕ *98
#     les zones TSTCHAMP  1 ŕ  8 determinent l'entete
#     les zones TSTCHAMP 11 ŕ 18 determinent le pied
#     les zones TSTCHAMP 21 ŕ 28 determinent le detail
# lignes entete
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="SOH*71" : TSTCHAMP(2) ="SOH*72" : TSTCHAMP(3) ="SOH*73" : TSTCHAMP(4) ="SOH*74"
TSTCHAMP(5) ="SOH*75" : TSTCHAMP(6) ="SOH*76" : TSTCHAMP(7) ="SOH*77" : TSTCHAMP(8) ="SOH*78"
# lignes pied
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="SOH*81" : TSTCHAMP(12)="SOH*82" : TSTCHAMP(13)="SOH*83" : TSTCHAMP(14)="SOH*84"
TSTCHAMP(15)="SOH*85" : TSTCHAMP(16)="SOH*86" : TSTCHAMP(17)="SOH*87" : TSTCHAMP(18)="SOH*88"

# lignes detail
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
# -------------------------------------
# FGR 27/11/2012 : X3SUIVI86171 (début)
  Local Integer NIOK

  Call TST_CHAMP("SOP", "*91", NIOK) From SUBIMPOBJ
  If NIOK Then
    # Normalement c'est sur "SOQ*91", mais au cas oů le modčle est mal défini, ça fonctionne quand męme avec ça.
    TSTCHAMP(21)="SOP*91" : TSTCHAMP(22)="SOP*92" : TSTCHAMP(23)="SOP*93" : TSTCHAMP(24)="SOP*94"
    TSTCHAMP(25)="SOP*95" : TSTCHAMP(26)="SOP*96" : TSTCHAMP(27)="SOP*97" : TSTCHAMP(28)="SOP*98"
  Else
    TSTCHAMP(21)="SOQ*91" : TSTCHAMP(22)="SOQ*92" : TSTCHAMP(23)="SOQ*93" : TSTCHAMP(24)="SOQ*94"
    TSTCHAMP(25)="SOQ*95" : TSTCHAMP(26)="SOQ*96" : TSTCHAMP(27)="SOQ*97" : TSTCHAMP(28)="SOQ*98"
  Endif
# FGR 27/11/2012 : X3SUIVI86171 (fin)
# -------------------------------------

Gosub OUVRE_TEXTE From TRTX3IMP
# ---
Return

#######################################################################
### Des lecture d'un enregistrement
# ---------------------------------------------------------------------
# Le chargement du client commande est effectué dans cette action pour
# permettre ultérieurement (recherche sur clés secondaires)
# de retrouver une commande
######################################################################
$AP_IMPORT
Local Integer I1
Case IMPFIC
  When "SOH"
    If dim(G_GIMP6)>0 & G_GIMP6
      I1=instr(1,GIMP(6),"~")
      If I1 [F:SOH]BPCORD=left$(GIMP(6),I1-1) Else [F:SOH]BPCORD=GIMP(6) Endif
    Endif
  When Default
Endcase
Return

######################################################################
# --- Lecture d'un enregistrement
$IMPORT
Local Integer OKCHAMP
Local Integer I, I1
Local Char    LEGIS(GLONADI) # FGR 19/11/2012 : X3SUIVI71937
Local Integer WRETCTL        #--CPO 71937 26.04.2013 Cohérence

Gosub IMPORT_TEXTE

Case IMPFIC
    When "SOH" :
# ---------------------------------------------------#
#     En-tęte commande                               #
# ---------------------------------------------------#
# ---------------------------------------------------#
#     Chargement de la correspondace des clients     #
# ---------------------------------------------------#
   If G_GIMP5
      I1=instr(1,GIMP(5),"~")
      If I1 [F:SOH]BPCINV=left$(GIMP(5),I1-1) Else [F:SOH]BPCINV=GIMP(5) Endif
    Endif
    If G_GIMP6
      I1=instr(1,GIMP(6),"~")
      If I1 [F:SOH]BPCORD=left$(GIMP(6),I1-1) Else [F:SOH]BPCORD=GIMP(6) Endif
    Endif
    If G_GIMP7
      I1=instr(1,GIMP(7),"~")
      If I1 [F:SOH]BPCPYR=left$(GIMP(7),I1-1) Else [F:SOH]BPCPYR=GIMP(7) Endif
    Endif
    If G_GIMP8
      I1=instr(1,GIMP(8),"~")
      If I1 [F:SOH]BPAADD=right$(GIMP(8),I1+1) Else [F:SOH]BPAADD=GIMP(8) Endif
    Endif
    If G_GIMP9
      I1=instr(1,GIMP(9),"~")
      If I1 [F:SOH]BPTNUM=left$(GIMP(9),I1-1) Else [F:SOH]BPTNUM=GIMP(9) Endif
    Endif

# ---------------------------------------------------#
#   Chargement de l'ecran adresse client commande    #
#   Si la raison sociale est paramétrée              #
# ---------------------------------------------------#
    If GREP="C" Raz [M:ADB1], [M:ADB2], [M:ADB3] Endif
#   Chargement de l'ecran adresse client commande si raison sociale parametree
    If G_BPCNAM
        [M:ADB1]ADBBPR       = [F:SOH]BPCORD
        [M:ADB1]BPRNAM(0)    = [F:SOH]BPCNAM(0)
        [M:ADB1]BPRNAM(1)    = [F:SOH]BPCNAM(1)
        [M:ADB1]BPAADDLIG(0) = [F:SOH]BPCADDLIG(0)
        [M:ADB1]BPAADDLIG(1) = [F:SOH]BPCADDLIG(1)
        [M:ADB1]BPAADDLIG(2) = [F:SOH]BPCADDLIG(2)
        [M:ADB1]POSCOD       = [F:SOH]BPCPOSCOD
        [M:ADB1]CTY          = [F:SOH]BPCCTY
        [M:ADB1]SAT          = [F:SOH]BPCSAT
        [M:ADB1]CRY          = [F:SOH]BPCCRY
        [M:ADB1]CRYNAM       = [F:SOH]BPCCRYNAM
        [M:ADB1]ADBFLG = 2
    Endif
#   Chargement systématique du contact client commande s'il est paramétré
    If G_CNTNAM
        [M:ADB1]CNTNAM       = [F:SOH]CNTNAM
    Endif
#   Chargement systématique de l'adresse client commande si elle est paramétrée
    If G_BPAORD
        [M:ADB1]BPAADD       = [F:SOH]BPAORD
    Endif
# ---------------------------------------------------#
#   Chargement de l'ecran adresse client facture     #
#   Si la raison sociale est paramétrée              #
# ---------------------------------------------------#
    If G_BPINAM
        [M:ADB3]ADBBPR       = [F:SOH]BPCINV
        [M:ADB3]BPRNAM(0)    = [F:SOH]BPINAM(0)
        [M:ADB3]BPRNAM(1)    = [F:SOH]BPINAM(1)
        [M:ADB3]BPAADDLIG(0) = [F:SOH]BPIADDLIG(0)
        [M:ADB3]BPAADDLIG(1) = [F:SOH]BPIADDLIG(1)
        [M:ADB3]BPAADDLIG(2) = [F:SOH]BPIADDLIG(2)
        [M:ADB3]POSCOD       = [F:SOH]BPIPOSCOD
        [M:ADB3]CTY          = [F:SOH]BPICTY
        [M:ADB3]SAT          = [F:SOH]BPISAT
        [M:ADB3]CRY          = [F:SOH]BPICRY
        [M:ADB3]CRYNAM       = [F:SOH]BPICRYNAM
#        If dim([M:ADB3]EECNUM)>0 [M:ADB3]EECNUM=[F:SOH]BPIEECNUM Endif
        [M:ADB3]ADBFLG = 2
    Endif
#       Chargement systématique du contact client facture s'il est paramétré
    If G_CNINAM
        [M:ADB3]CNTNAM       = [F:SOH]CNINAM
    Endif
#   Chargement systématique de l'adresse client facture si elle est paramétrée
    If G_BPAINV
        [M:ADB3]BPAADD       = [F:SOH]BPAINV
    Endif
# ---------------------------------------------------#
#   Chargement de l'ecran adresse client livré       #
#   Si la raison sociale est paramétrée              #
# ---------------------------------------------------#
    If G_BPDNAM
        [M:ADB2]ADBBPR       = [F:SOH]BPCORD
        [M:ADB2]BPRNAM(0)    = [F:SOH]BPDNAM(0)
        [M:ADB2]BPRNAM(1)    = [F:SOH]BPDNAM(1)
        [M:ADB2]BPAADDLIG(0) = [F:SOH]BPDADDLIG(0)
        [M:ADB2]BPAADDLIG(1) = [F:SOH]BPDADDLIG(1)
        [M:ADB2]BPAADDLIG(2) = [F:SOH]BPDADDLIG(2)
        [M:ADB2]POSCOD       = [F:SOH]BPDPOSCOD
        [M:ADB2]CTY          = [F:SOH]BPDCTY
        [M:ADB2]SAT          = [F:SOH]BPDSAT
        [M:ADB2]CRY          = [F:SOH]BPDCRY
        [M:ADB2]CRYNAM       = [F:SOH]BPDCRYNAM
        [M:ADB2]CNTNAM       = [F:SOH]CNDNAM
        [M:ADB2]ADBFLG = 2
    Endif
#   Chargement systématique du contact client livré s'il est paramétré
    If G_CNDNAM
        [M:ADB2]CNTNAM       = [F:SOH]CNDNAM
    Endif
    # 88452 - order holds import
    Call TST_CHAMP("SOH","HLDCOD",OKCHAMP) From SUBIMPOBJ
    If OKCHAMP
      Call IMPHLD([F:SOH]HLDCOD) From MANHLDLIB
    Endif

# Issue X3-38369
# Only in creation, in modification Company and Sales site can not be in the file import (and it is normal)
    If GREP="C"
# End issue X3-38369
        #--CPO 71937 Si la société n'est pas dans le fichier d'import, il faut la lire depuis le SALFCY
        If [F:SOH]CPY=""
          #--lire la société du site
          GFCY=[F:SOH]SALFCY
          Call GETDEV([F:SOH]SALFCY) From DEVSUB
          [F:SOH]CPY=GSOCIETE
        Endif
        #--/
# Issue X3-38369
    Endif
# End issue X3-38369

# ---------------------------------------------------#
#     Gestion du compteur                            #
# ---------------------------------------------------#
    #- FGR 19/11/2012 : X3SUIVI71937 Multi-législation -#
    Call GETLEG([F:SOH]CPY,"G",LEGIS) From DEVSUB
    If LEGIS='' : Call GETLEG([F:SOH]CPY,"T",LEGIS) From DEVSUB : Endif

    Call TST_CHAMP(IMPFIC,"SOHTYP",OKCHAMP) From SUBIMPOBJ
    If OKCHAMP
#       Le type de cde est paramétré : il faut le récupérér pour retrouver GMANCOU
        #- FGR 19/11/2012 : X3SUIVI71937 Multi-législation -#
        #Read [TSO]TSO0 = [F:SOH]SOHTYP
        Local Integer WRET
        Call LEC_TSO_LEG(LEGIS,[F:SOH]SOHTYP,WRET) From TRTLECLEG
        #--CPO 71937 T757 Contrôle de cohérence
        #Read [TSO]TSO0 = [F:SOH]SOHTYP;LEGIS
        If WRET : Raz [F:TSO] : Endif
        Raz mkstat
        Call CONTTSO([F:SOH]SOHTYP,LEGIS,"","",[F:SOH]STOFCY,"",[F:SOH]CPY) From SUBTSO
        If mkstat OK=0 : Return : Endif
        #If fstat=0
        If WRET=0
        #--/
             GMANCOU=[F:TSO]MANCOU
        Endif
    Elsif GREP="C"
        Call TST_CHAMP(IMPFIC,"SOHNUM",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & [F:SOH]SOHNUM <> ""
#       Le type de cde n'est pas paramétré et le n° cde est importé
#       --> On regarde s'il existe un compteur manuel pour la catégorie normale
            If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
#            Filter [TSO] Where [TSO]SOHCAT=1 & [TSO]MANCOU=2
#            Read [TSO]TSO0 First

            Link [TSO] With [FGR]FGR0=[F:TSO]GFY;GCURFCY As [KTSO]

            # FGR 15/11/2012 : X3SUIVI71937
            #Filter [KTSO] Where [TSO]SOHCAT=1 & [TSO]MANCOU=2 & ([TSO]GFY="" | [FGR]FCY=GCURFCY)
            #--CPO 71937 26.04.2013 Cohérence
            #Filter [KTSO] Where [TSO]SOHCAT=1 & [TSO]MANCOU=2 & ([TSO]GFY="" | [FGR]FCY=GCURFCY) & ([TSO]LEG="" | [TSO]LEG=LEGIS)
            Filter [KTSO] Where [TSO]SOHCAT=1 & [TSO]MANCOU=2 & ([TSO]GFY="" | [FGR]FCY=GCURFCY) & ([TSO]LEG="" | [TSO]LEG=LEGIS)
&                         Order By Key CLE=[F:TSO]SOHTYP Asc;[F:TSO]LEG Desc
            #Read [KTSO]TSO0 First
            #If fstat=0
            #     [M:SOH0]SOHTYP = [F:TSO]SOHTYP
            #     GMANCOU=[F:TSO]MANCOU
            #     # 75115 : V7 : Extension of Digital Signature : New field delivery type
            #     [M:SOH2]SDHTYP=[F:TSO]SDHTYP
            #Endif
            For [KTSO]CLE
              Call CTL_ML_CONSISTENCY("TSO", "NON",[F:KTSO]SOHTYP,[F:KTSO]LEG,AVOID.ACHAR,GCURFCY,LEGIS,WRETCTL,AVOID.ACHAR) From TRTVENCTL
              If WRETCTL=0
                [M:SOH0]SOHTYP = [F:KTSO]SOHTYP
                GMANCOU=[F:KTSO]MANCOU
                # 75115 : V7 : Extension of Digital Signature : New field delivery type
                [M:SOH2]SDHTYP=[F:KTSO]SDHTYP
                Break
              Endif
            Next
            #--/
            Filter [KTSO]
        Endif
    Endif

    # En fonction de GMANCOU, il faut réactiver ou pas SOHNUM pour qu'il soit importé correctement
    If GREP="C"
        Gosub SETMODE_ON From TRTX3IMP
        If GMANCOU=1
            Diszo [M:SOH0]SOHNUM
        Elsif GMANCOU=2
            Actzo [M:SOH0]SOHNUM
        Endif
        Gosub SETMODE_OFF From TRTX3IMP
    Endif

    When "CAL"
#--------------------------------------------------------------------#
# Traitement des comptes et sections analytiques des lignes commande #
#            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"SOP"'               #
#--------------------------------------------------------------------#
        [F:CAL]ABRFIC="SOP"
        [F:CAL]VCRTYP=0
        Call IMPORT_ACCCCE(WNOL,"","","[M:SOH4]CCE") From TRTX3CPT
        nolign=WNOL+1 : status=75 : # Modif élément

    When "SOQ", "SOP" :
# ---------------------------------------------------#
#     Détails commande                               #
# ---------------------------------------------------#
        Raz WNOL
        Gosub IMP_DECLARE From TRTX3IMP
# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        If GREP = "M"
            ICLEPRIM (0) = "SOPLIN"
            ICLEPRIM (1) = "IMPNUMLIG" : ICLEBRK(1)=1
            ICLEPRIM (2) = "ITMREF" : ICLESEC(2)="SHIDAT" : TSEC(2)="DSHIDAT"
            ICLEPRIM (3) = "ITMREF"
            NBASTAB = "NBLIG"
            Gosub RECHERCHE_LIGNE From TRTX3IMP
            If nolign=0 : G_NLDET=1 : Endif
            #If nolign>0 WNOL=nolign-1 Endif        : # Bug 77807
            If nolign>0 WNOL=nolign Endif           : # Bug 77807
#           --> Traitement de suppression d'une ligne
            Call TST_CHAMP(IMPFIC,"QTY",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & [F:SOQ]QTY = 0 & nolign <> 0
                 status=65
                 # --> Contrôle de suppression de lignes
                 Call C_NBLIG From W1SOH4
                 If mkstat OK=0 : Return : Endif
                 Call AVANT_NBLIG From W1SOH4
                 Call APRES_NBLIG From W1SOH4
            Endif
        Endif
        #If WNOL=0 WNOL=[M]NBLIG Endif              : # Bug 77807
        If WNOL=0 WNOL=[M]NBLIG Else WNOL-=1 Endif  : # Bug 77807
  When "SVV" :
# -------------------------------------------------------------------#
#     Taxes                                                          #
# -------------------------------------------------------------------#
      If [F:SVV]VAT<>"" & dim([M:SIHV]XVTAX)>0
        #--CPO 71937 TVT et multi-lčg
        Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [F:TVT]TVT0=[F:SVV]VAT
        #If fstat : Raz [F:TVT] : Endif
        #--/CPO
        [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP
        [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
        [M:SIHV]XVCHA([M:SIHV]NBVAT) = [F:TVT]VATCHA
        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
        [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
        [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
        [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
        [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
        [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
        [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
        [M:SIHV]NBVAT +=1
      Endif
  When "SVF" :
# -------------------------------------------------------------------#
#     Pieds                                                          #
# -------------------------------------------------------------------#
#--      le tableau des pieds de facture
      If [F:SVF]DTA<>0 & dim([M:SIHV]XFNUM)>0
        [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
        [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
        [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

        Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
        For I=0 To dim([F:SVF]DTANET)-1
             If [F:SVF]DTAVAT(I)="" Break Endif
             Assign "[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
             Assign "[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
             Assign "[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
             Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
             Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)
             [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)
        Next
        If I=1
             [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANET(I-1)
             [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
             [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
        Endif

        [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
        [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

        [M:SIHV]NBFOOT +=1
      Endif
Endcase
Return

#----------------------------------------------------------------------
$IMPORT_TEXTE
Raz G_NLDET

Case IMPFIC
  When "SOH" :

    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif

    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif

  #When "SOQ"                # FGR 15/10/2013 : X3SUIVI89468
  When "SOQ", "SOP"          # FGR 15/10/2013 : X3SUIVI89468
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif

Endcase

Return

######################################################################
# ---
$IMP_ZONE
Local Char     IMPZONFIC(30) : IMPZONFIC =""
Local Char     IMPZONMSK(30) : IMPZONMSK =""
Local Char     IMPCAR
Local Integer  IINDICE       : IINDICE=0
Local Integer  I,J
Local Integer  WRET :#--CPO 71937 Multi-législation

# --------------------------------------------------------------- #
# Traitement particulier aprčs chargement de l'enr. importé       #
# --------------------------------------------------------------- #
# --> Raz [F:SOH] [F:SOQ] [F:SOQ]                                 #
#     Les zones paramétrées sont chargées                         #
#     Les zones non paramétrées sont vides                        #
#     En création [M] est n'est pas chargée                       #
#     En modif. [M] est chargée avec l'enr ŕ modifier             #
# --------------------------------------------------------------- #
Case IMPFIC
    When "SOH"
# --------------------------------------------------------------- #
#       Entete commande                                           #
# --------------------------------------------------------------- #
#       Texte entete
      #------------------------------
      # FGR 27/11/2012 : X3SUIVI86171
      #If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C"
      If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & (GREP="C" or GREP="M")
         [M:SOH0]SOHTEX1=[M:ITC]T_CLE_CLOB(1)
         #Raz [M:ITC]T_CLE_CLOB(1)                # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois  # FGR 03/04/2015 : X3SUIVI107412 non on perd les textes
      Endif
      #------------------------------
      # Texte pied
      # FGR 27/11/2012 : X3SUIVI86171
      #If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C"
      If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & (GREP="C" or GREP="M")
         [M:SOH0]SOHTEX2=[M:ITC]T_CLE_CLOB(2)
         #Raz [M:ITC]T_CLE_CLOB(2)                # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois  # FGR 03/04/2015 : X3SUIVI107412 non on perd les textes
      Endif
      #------------------------------

# --------------------------------------------------------------- #
#       Correspondance clients                                    #
# --------------------------------------------------------------- #
      Case IMPZON
        When "SOHTYP" : #--CPO 71937 Multi-législation
            #--Juste une re-lecture suivie de l'init des données découlant du SOHTYP
            #--Le SOHTYP est initialisé dans $IMPORT
            Call LEC_TSO_LEG(GCURLEG,[M]SOHTYP,WRET) From TRTLECLEG
            If !WRET : [M:SOH2]SDHTYP=[F:TSO]SDHTYP : Endif
        When "BPCINV"
          If G_GIMP5
            If evalue("dim([M:"+IMPMSK+"]BPCINV)")>0
              Assign ("[M:"+IMPMSK+"]BPCINV") With [F:SOH]BPCINV
              IMPMOD=1
            Endif
          Endif
        When "BPCORD"
          If G_GIMP6
            If evalue("dim([M:"+IMPMSK+"]BPCORD)")>0
              Assign ("[M:"+IMPMSK+"]BPCORD") With [F:SOH]BPCORD
              IMPMOD=1
            Endif
          Endif
        When "BPCPYR"
          If G_GIMP7
            If evalue("dim([M:"+IMPMSK+"]BPCPYR)")>0
              Assign ("[M:"+IMPMSK+"]BPCPYR") With [F:SOH]BPCPYR
              IMPMOD=1
            Endif
          Endif
        When "BPAADD"
          If G_GIMP8
            If evalue("dim([M:"+IMPMSK+"]BPAADD)")>0
              Assign ("[M:"+IMPMSK+"]BPAADD") With [F:SOH]BPAADD
              IMPMOD=1
            Endif
          Endif
        When "BPTNUM"
          If G_GIMP9
            If evalue("dim([M:"+IMPMSK+"]BPTNUM)")>0
              Assign ("[M:"+IMPMSK+"]BPTNUM") With [F:SOH]BPTNUM
              IMPMOD=1
            Endif
          Endif
        When "CCE"
          If [F:SOH]CCE(indice)=""  OK=0 : Endif
      Endcase

#     chargement champs affiches et invisibles sur appel champ saisissable obligatoire
      If IMPZON="ORDDAT" : IMPFICCPL="SOH" : Gosub CPL_FICMSK From =G_NOMTRT : Endif


    When "SOP","SOQ":
# --------------------------------------------------------------- #
#       Ligne détail                                              #
# --------------------------------------------------------------- #
        IMPZONFIC=IMPZON
        Gosub RECH_IMPFIC     : # necessaire pour import des textes lignes

        # -------------------------------------
        # FGR 15/10/2013 : X3SUIVI89468 (début) : ça n'était pas une bonne idée de le faire ici
        ## FGR 27/11/2012 : X3SUIVI86171 (début)
        ## Texte detail
        #If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" and (GREP="C" or GREP="M")
        #  [M:SOH4]SOQTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
        #  Raz [M:ITC]T_CLE_CLOB(3)               # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois
        #Endif
        ## FGR 27/11/2012 : X3SUIVI86171 (fin)
        # FGR 15/10/2013 : X3SUIVI89468 (fin)
        # -------------------------------------

        Case IMPZON
            When "ITMREF"
# --------------------------------------------------------------- #
#               En creation mise a jour du no sequentiel          #
#               de la ligne importee si ce no externe n'est       #
#               pas renseigné                                     #
#---------------------------------------------------------------- #
                If G_IMPNUMLIG : [M]IMPNUMLIG(nolign-1)=[F:SOQ]IMPNUMLIG : Endif
                If GREP="C" & [M]IMPNUMLIG(nolign-1)=0 : [M]IMPNUMLIG(nolign-1)=nolign : Endif
                IMPZONFIC=IMPZON

            When "QTY"
            # -------------------------------------
            # FGR 27/11/2012 : X3SUIVI86171 (début)
#               Texte detail sur QTY (champ obligatoire)
             #If G_DET & [M:ITC]T_CLE_CLOB(3)<>""
             #   If GREP="C" | (GREP="M" & G_NLDET)
             #      [M:SOH4]SOQTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
             #   Endif
             #Endif
             # FGR 27/11/2012 : X3SUIVI86171 (fin)
             # -------------------------------------

             # FGR 15/10/2013 : X3SUIVI89468 (début)
             # Texte detail
             If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" and (GREP="C" or GREP="M")
               [M:SOH4]SOQTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
             Endif
             # FGR 15/10/2013 : X3SUIVI89468 (fin)

             IMPZONFIC=IMPZON
            #--CPO 108900 Ajout de DDRN
# 71065 : PJT
#            When "DSTOFCY", "DDLVPIO", "DBPTNUM", "DMDL", "DDAYLTI", "DDEMDLVDAT", "DSHIDAT", "DALLTYP", "DDRN" :
            When "DSTOFCY", "DDLVPIO", "DBPTNUM", "DMDL", "DDAYLTI", "DDEMDLVDAT", "DSHIDAT", "DALLTYP", "DPJT","DDRN" :
# 71065 : PJT
# --------------------------------------------------------------- #
#               Nom différent entre [F] et [M]                    #
#               Il faut charger les zones ŕ la main               #
# --------------------------------------------------------------- #
                IMPZONFIC = mid$(IMPZON,2,19)
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            # 107890 : Scheduled invoices : (LD:08/12/16)
            When "DINVCND":
                # --------------------------------------------------------------------- #
                #  Nom différent entre [F] et [M] : Il faut charger les zones ŕ la main #
                # --------------------------------------------------------------------- #
                IMPZONFIC = mid$(IMPZON,2,19)
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            # 107890 : Scheduled invoices : (LD:08/12/16)
            When "DBPAADD":
# --------------------------------------------------------------- #
#               Nom différent entre [F] et [M]                    #
#               Il faut charger les zones ŕ la main               #
# --------------------------------------------------------------- #
                IMPZONFIC = mid$(IMPZON,2,19)
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When "WALLQTY":
# --------------------------------------------------------------- #
#               Nom différent entre [F] et [M]                    #
#               Il faut charger les zones ŕ la main               #
# --------------------------------------------------------------- #
                # Issue X3-119240
                #IMPZONFIC = mid$(IMPZON,2,19)
                #IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
                If [F:SOQ]SOQSTA<>3 & [F:SOP]SOQSTA<>3
                    If G_ALLQTY
                        IMPZONFIC = mid$(IMPZON,2,19)
                        IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
                    Elsif G_ALLQTYSTU
                        IMPZONFIC = mid$(IMPZON,2,19)+"STU"
                        IMPZONMSK= "[M]"+IMPZON+"STU"+"("+num$(nolign-1)+")"
                    Endif
                Elsif GREP="C"
                    # Import d'une commande soldée en création, elle ne doit pas s'allouer
                    # (Cas oů le paramčtre INIALLORD = Oui)
                    # Import closed order in creation, it must not be allocated
                    # (Case where INIALLORD parameter = Yes)
                    Raz [F:SOQ]ALLQTY, [F:SOQ]ALLQTYSTU
                    Raz [M:SOH4]WALLQTY(nolign-1), [M:SOH4]WALLQTYSTU(nolign-1)
                Endif
                # End issue X3-119240
            When "VACITM1","VACITM2","VACITM3":
# --------------------------------------------------------------- #
#               Nom différent entre [F] et [M]                    #
#               Il faut charger les zones ŕ la main               #
# --------------------------------------------------------------- #
#               zones indicées dans le fichier
                IMPZONFIC = mid$(IMPZON,1,6)
                IINDICE   = val(mid$(IMPZON,7,1))
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
# --------------------------------------------------------------- #
#               Dernier champs saisissable de la ligne            #
#               Içi on charge les zones d'un écran complémentaire #
#               - Ecran de saisie des motifs                      #
# --------------------------------------------------------------- #
            When "FMI" :
                Gosub CHARG_ZONE_COMPLEMENT
                IMPZONFIC = IMPZON : IMPZONMSK =""
            When "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&                "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
                #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
                If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
                  OK=0 : mkstat=1 : # Zones non concernées par SORDERP
                Endif
                #-----
            When Default :
                IMPZONFIC = IMPZON

        Endcase

        Gosub RECH_IMPFIC

#       chargement champs affiches et invisibles sur appel champ saisissable obligatoire
        If IMPZON="QTY"
#           If [F:ITM]STOMGTCOD=1 : Raz [F:SOQ]ALLQTY, [F:SOQ]SHTQTY : Endif             : # bug 33541
           If [M]STOMGTCOD(nolign-1)=1 & !find([M]LINTYP(nolign-1), 2,3,4,5,10,11,12,13) : # Bug 71111
               Raz [F:SOQ]ALLQTY, [F:SOQ]SHTQTY                                          : # Bug 71111
           Endif                                                                         : # Bug 71111
           IMPFICCPL="SOP" : Gosub CPL_FICMSK From =G_NOMTRT
           IMPFICCPL="SOQ" : Gosub CPL_FICMSK From =G_NOMTRT
           # Issue X3-38400
           # On charge manuellement [M:JJJ4]ITMREF(nolign-1) pour savoir que CPL_FICMSK a été effectué et que [M:JJJ4] a été chargé pour cette ligne avec l'enregistrement importé
           # [M:JJJ4]ITMREF(nolign-1) sera testé avant l'appel ŕ CPL_MSKFIC afin de recharger [F:SOQ] et [F:SOP] ssi [M:JJJ4] est chargé
           # We charge manually [M:JJJ4]ITMREF(nolign-1) to know that CPL_FICMSK has been done and [M:JJJ4] is charged for this line with the imported record
           # [M:JJJ4]ITMREF(nolign-1) will be tested before call of CPL_MSKFIC to recharged [F:SOQ] and [F:SOP] ssi [M:JJJ4] is charged
           [M:JJJ4]ITMREF(nolign-1)=[M:SOH4]ITMREF(nolign-1)
           # End issue X3-38400
        Endif

Endcase
Gosub CHARG_IMPZONMSK



Return

# --------------------------------------------------------------- #
#   Import de la zone                                             #
#   Chargement de la IMPZONMSK avec IMPZONFIC                     #
# --------------------------------------------------------------- #
$CHARG_IMPZONMSK

If IMPZONFIC <> "" & IMPZONMSK <> ""
    If I=0 | IINDICE <> 0
#       On recherche si la zone est paramétrée
        If IINDICE <> 0
#           Zone indicée
            I = find(IMPFIC-IMPZONFIC+"("+num$(IINDICE-1)+")",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
            If I <> 0 IMPZONFIC = IMPZONFIC + "("+num$(IINDICE-1)+")" : Endif
        Endif
        If IINDICE = 0 | IINDICE = 1 & I = 0
#           Zone non indicée ou zone indicée de 0 non trouvée
            I = find(IMPFIC-IMPZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
        Endif
    Endif
    If I <> 0
#       On charge la classe [M]
        If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
            #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
            If IMPFIC="SOQ" & IMPZON="DPJT"
              GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC([F:SOH]SALFCY)
                WNEWPJT = [F:SOH]PJT
                If  GPJTSNGDOC = G_OUI
                  If WNEWPJT <> [F:SOQ]PJT
                   If !G_PJTH
                     #-- Tentative d'import affaire ligne $1$ <> affaire entęte $2$ (Mono-Affaire) --> Rejet de la valeur ligne
                     Call ECR_TRACE(func AFNC.MES2(mess(1055,196, 1), [F:SOQ]PJT, WNEWPJT ),0) From GESECRAN
                   Else
                    #-- Affaire ligne $1$ <> entęte $2$. Maj de l'affaire ligne ŕ partir de l'entęte  (Société Mono-Affaire)--#
                    Call ECR_TRACE(func AFNC.MES2(mess(1050,196, 1), [F:SOQ]PJT, WNEWPJT ),0) From GESECRAN
                    IMPMOD=1
                    Assign IMPZONMSK With WNEWPJT
                   Endif
                  Endif
                Else
                  IMPMOD=1
                  Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
                Endif
            Else
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
            Endif
            # Issue X3-119240
            If IMPFIC="SOQ" & IMPZONFIC="ALLQTYSTU"
                # Cas oů on a importé ALLQTYSTU --> WALLQTYSTU a été alimenté, il faut calculer WALLQTY
                # Case where we imported ALLQTYSTU --> WALLQTYSTU has been initialized, we need to calculate WALLQTY
                Call CNVQTY([M]WALLQTYSTU(nolign-1),[M:SOH4]SAUSTUCOE(nolign-1),[M]STU(nolign-1),[M]WALLQTY(nolign-1)) From TRTVENQTE
            Endif
            # End issue X3-119240
        Endif
    Endif
    OK=0
Endif

Return


# --------------------------------------------------------------- #
#   Ligne détail                                                  #
#   Deux fichiers lignes [SOP] et [SOQ] pour le męme ecran        #
#   Il faut rechercher l'abréviation fichier pour chaque zone     #
# --------------------------------------------------------------- #
$RECH_IMPFIC

I=0:OK=1
If OK <> 0
#   On recherche si la zone est paramétrée pour un des deux fichiers détail
    If IINDICE <> 0
#       Zone indicée
        I = find(IMPZONFIC+"("+num$(IINDICE-1)+")",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If IINDICE = 0 | IINDICE = 1 & I = 0
#       Zone non indicée ou zone indicée de 0 non trouvée
        I = find(IMPZONFIC,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If I <> 0 & left$([M:AOE2]ZONE(I-1),3) = "SOH"
#       Zone déjŕ paramétrée dans l'entęte
        J=I
        I = find(IMPZONFIC,[M:AOE2]FLD(J..[M:AOE2]NBRLIG-1))
        If I <> 0
            I+=J : # Zone paramétrée aussi pour le détail
        Endif
    Endif
    If I <> 0
        IMPFIC = left$([M:AOE2]ZONE(I-1),3):# Zone paramétrée pour le détail
    Endif
Endif
Return

#---------------------------------------------------------------------------------------#
#  Les données saisies dans un écran complémentaires ne sont pas appelées dans IMP_ZONE #
#  Le chargement est effectué lors de l'appel de FMI                                    #
#    ( a ce moment les classes [F:SOP] et [F:SOQ] sont toujours présentes et toutes     #
#      les zones saisissables qui initialisent des données ligne de [M:SOH4]            #
#      sont deja traitees : pas de risques d'ecrasement                                 #
#---------------------------------------------------------------------------------------#
$CHARG_ZONE_COMPLEMENT
#    Ecran de saisie des motifs
IMPZONFIC="PRIREN"     : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK= "[M]"+IMPZONFIC+"("+num$(nolign-1)+")" : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN1" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN2" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN3" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN4" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN5" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN6" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN7" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN8" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
IMPZONFIC="DISCRGREN9" : Gosub RECH_IMPFIC
If I <> 0 IMPZONMSK="[M]"+IMPZONFIC+"("+num$(nolign-1)+")"  : Gosub CHARG_IMPZONMSK : Endif
Return


######################################################################
$IMP_INICRE
#  chargement champs affiches et invisibles
IMPFICCPL="SOH" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
$IMP_INIMOD
#  chargement champs affiches et invisibles
IMPFICCPL="SOH" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
# Appele en fin de INICRE_LIG du SUBSOHA
# --------------------------------------------------------------------
$INICRE_LIG
#  chargement champs affiches et invisibles
IMPFICCPL="SOP" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
# Appele en fin de INIMOD_LIG du SUBSOHA
# --------------------------------------------------------------------
$INIMOD_LIG
#  chargement champs affiches et invisibles

# Issue X3-38400
# On teste si [M:JJJ4]ITMREF(nolign-1) est chargé pour savoir si CPL_FICMSK a été effectué et [M:JJJ4] est chargé pour cette ligne avec l'enregistrement importé
# et si on doit executer CPL_MSKFIC pour recharger [F:SOQ] et [F:SOP] avec [M:JJJ4]
# We charge manually [M:JJJ4]ITMREF(nolign-1) to know that CPL_FICMSK has been done and [M:JJJ4] is charged for this line with the imported record
# [M:JJJ4]ITMREF(nolign-1) will be tested before call of CPL_MSKFIC to recharged [F:SOQ] and [F:SOP] ssi [M:JJJ4] is charged
#IMPFICCPL="SOP" : Gosub CPL_MSKFIC From =G_NOMTRT
If [M:JJJ4]ITMREF(nolign-1)=[M:SOH4]ITMREF(nolign-1)
  IMPFICCPL="SOP" : Gosub CPL_MSKFIC From =G_NOMTRT
Endif
# End Issue X3-38400

Return

######################################################################
# Appele en fin de IMP_AVANT_MODFIC du SUBSOHA
# --------------------------------------------------------------------
$IMP_AVANT_MODFIC
# Solde d'une ligne de commande : Chargement [M]SOQSTA (Zone non saisissable) suivi de recalculs suite ŕ un solde de ligne
#
# --> On charge [M:SOH4]SOQSTA avec [M:JJJ4]SOQSTA en AVANT_MODFIC car
#     La classe [M] doit etre ok dans l'action $MODIF pour la maj de l'état de la commande (ORDSTA)
# --> [M:SOH4]SOQSTA sera rechargé en $INIMOD_LIG (automatiquement avec l'action CPL_MSKFIC)
#
# --> Pour que le solde soit correct, on simule le bouton solde
If G_SOQSTA
    Local Integer WI
    For WI=0 To [M]NBLIG
        nolign=WI+1
        # Pas de solde si la ligne de commande n'est pas créée

        If [M]CREFLG(WI)<>0
            If [M:SOH4]SOQSTA(WI)<>[M:JJJ4]SOQSTA(WI) & find([M:JJJ4]SOQSTA(WI), 1,3)
                # Bug 56457 : Import modif cde avec flag solde et la ligne est importée
                If [M:SOH2]ORDCLE=2
                    ## Action TRTCLESOQ
                    Local Decimal BASPAG
                    Local Char    PARMSK(250)(1..20) , SAVACT(20)
                    SAVACT = GACTION : GACTION = "TRTCLESOQ"
                    Call TRAITE_NUM(BASPAG,PARMSK,"","TRTVENCDE","ICCLREN",4,"XYTRTVENCDE") From GTRAITE
                    GACTION = SAVACT
                    # On recharge [M:JJJ4]SOQSTA pour ętre sűr qu'en INIMOD_LIG, cela soit correct
                    [M:JJJ4]SOQSTA(WI)=[M:SOH4]SOQSTA(WI)
                Else
                    # Pas de solde si solde non autorisé
                    # On recharge [M:JJJ4]SOQSTA pour ętre sűr qu'en INIMOD_LIG, cela soit correct
                    [M:JJJ4]SOQSTA(WI)=[M:SOH4]SOQSTA(WI)
                Endif
            Elsif !find([M:JJJ4]SOQSTA(WI), 1,3)
                # Bug 56457 : Import modif cde avec flag solde mais la ligne n'est pas importée
                # Cas oů la ligne n'a pas été importée : [M:JJJ4]SOQSTA(WI)=0
                # On recharge [M:JJJ4]SOQSTA pour ętre sűr qu'en INIMOD_LIG, cela soit correct
                [M:JJJ4]SOQSTA(WI)=[M:SOH4]SOQSTA(WI)
            Endif
        Endif
    Next
Endif

Return
######################################################################
# Appele en fin de VALLIG du SUBSOHA
# --------------------------------------------------------------------
$VALLIG
#  chargement champs affiches et invisibles

# Issue X3-119240
Local Decimal WSVGALLQTY
Local Decimal WSVGALLQTYSTU
# On sauvegarde la qté allouée avant de charger le fichier avec les valeurs importées
# We save the allocated qty before initialize the file with the imported values
WSVGALLQTY = [F:SOQ]ALLQTY
WSVGALLQTYSTU  = [F:SOQ]ALLQTYSTU
# End issue X3-119240

# Issue X3-38400
# On teste si [M:JJJ4]ITMREF(nolign-1) est chargé pour savoir si CPL_FICMSK a été effectué et [M:JJJ4] est chargé pour cette ligne avec l'enregistrement importé
# et si on doit executer CPL_MSKFIC pour recharger [F:SOQ] et [F:SOP] avec [M:JJJ4]
# We charge manually [M:JJJ4]ITMREF(nolign-1) to know that CPL_FICMSK has been done and [M:JJJ4] is charged for this line with the imported record
# [M:JJJ4]ITMREF(nolign-1) will be tested before call of CPL_MSKFIC to recharged [F:SOQ] and [F:SOP] ssi [M:JJJ4] is charged
#IMPFICCPL="SOQ" : Gosub CPL_MSKFIC From =G_NOMTRT
If [M:JJJ4]ITMREF(nolign-1)=[M:SOH4]ITMREF(nolign-1)
  IMPFICCPL="SOQ" : Gosub CPL_MSKFIC From =G_NOMTRT
Endif
# End Issue X3-38400

# Issue X3-119240
# Si la qté ŕ allouer = qté allouée importée
# --> L'allocation va se déclencher avec WALLQTY, c'est le résultat de cette allocation qu'il faut considérer et non la valeur importée
# --> On restitue les valeurs qu'on avait avant le chargement avec le fichier import
# If the qty to allocate = imported allocated qty
# --> The allocation will be trigerred with WALLQTY, we have to consider the result of this allocation and not the imported value
# --> We restore the values we had before initialization with the imported file
If [M:SOH4]WALLQTY(nolign-1)= [F:SOQ]ALLQTY | [M:SOH4]WALLQTYSTU(nolign-1)= [F:SOQ]ALLQTYSTU
    [F:SOQ]ALLQTY          = WSVGALLQTY
    [F:SOQ]ALLQTYSTU       = WSVGALLQTYSTU
    [M]ALLQTY(nolign-1)    = WSVGALLQTY
    [M]ALLQTYSTU(nolign-1) = WSVGALLQTYSTU
Endif
# End issue X3-119240

Return

######################################################################
# --- Fin import
$IMP_FERME

If dim(G_BPCNAM)>0     : Kill G_BPCNAM     : Endif
If dim(G_BPDNAM)>0     : Kill G_BPDNAM     : Endif
If dim(G_BPINAM)>0     : Kill G_BPINAM     : Endif
If dim(G_CNTNAM)>0     : Kill G_CNTNAM     : Endif
If dim(G_CNDNAM)>0     : Kill G_CNDNAM     : Endif
If dim(G_CNINAM)>0     : Kill G_CNINAM     : Endif
If dim(G_LINTYP)>0     : Kill G_LINTYP     : Endif
If dim(G_FOCFLG)>0     : Kill G_FOCFLG     : Endif

#VPO 28/05/09 51611 il faut supprimer les variables
Gosub IMP_FIN_CPL From TRTX3IMP

If clalev([M:IMP2])>0 and [M:IMP2]TEST<>2 #--CPO 108787 Ne pas le faire si Test, car perte contexte
# FGR 04/12/2014 : X3SUIVI103421 (début)
  Gosub FIN_IMPORT From TRTVENFACR
Endif
  If dim(GSZIMPSOH)>0  : Kill GSZIMPSOH    : Endif
# FGR 04/12/2014 : X3SUIVI103421 (fin)
Return

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE

Global Integer GDEVSOCRND  : # stockage code arrondi devise societe
Raz GIMP
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR     [TCU]   : Endif
If clalev([F:TCO])=0    : Local File TABCOEFF   [TCO]   : Endif

If clalev([F:BPR])=0    : Local File BPARTNER   [BPR]   : Endif
If clalev([F:BPC])=0    : Local File BPCUSTOMER [BPC]   : Endif
If clalev([F:BPD])=0    : Local File BPDLVCUST  [BPD]   : Endif
If clalev([F:BPT])=0    : Local File BPCARRIER  [BPT]   : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif

If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:ITS])=0    : Local File ITMSALES   [ITS]   : Endif
If clalev([F:ITU])=0    : Local File ITMBPC     [ITU]   : Endif

#--- pour les textes
Gosub OUVRE_TEXTE
#---

Return

######################################################################
# ---
$EXPORT
Case EXPFIC
  When "SOH"
    Raz [F:CPY], [F:FCY]
    Raz [F:BPR], [F:BPC], [F:BPD], [F:BPT], [F:BPA]
    Raz [F:ITM], [F:ITS], [F:ITU]
    # retrouver la société avec le site de vente
    Read [FCY]FCY0=[F:SOH]SALFCY
    If fstat : Raz [F:FCY] : Endif
    Read [CPY]CPY0=[F:FCY]LEGCPY
    If fstat : Raz [F:CPY] : Endif
    If [F:CPY]ACCCUR<>[F:TCU]CUR
      Read [TCU]TCU0=[F:CPY]ACCCUR
      If fstat : Raz [F:TCU] : Endif
    Endif
    GDEVSOCRND=[F:TCU]CURRND
  When "SOP", "SOQ"
    Raz [F:ITM], [F:ITS], [F:ITU]
Endcase

# ---
Case EXPFIC

  When "SOH"
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:SOH]SOHTEX1)>0 & [F:SOH]SOHTEX1<>""
          G_CLE_CLOB=[F:SOH]SOHTEX1 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:SOH]SOHTEX2)>0 & [F:SOH]SOHTEX2<>""
          G_CLE_CLOB=[F:SOH]SOHTEX2 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

  When "SOQ"
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:SOQ]SOQTEX)>0 & [F:SOQ]SOQTEX<>""
          G_CLE_CLOB=[F:SOQ]SOQTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif
Endcase
# ---

Return

######################################################################
# ---
$EXP_ZONE

Case EXPZON
  When "GIMP(3)"    : Gosub E_GIMP3        : # Chgt adresse société
  When "GIMP(4)"    : Gosub E_GIMP4        : # Chgt site vente
  When "GIMP(5)"    : Gosub E_GIMP5        : # Chgt client facture
  When "GIMP(6)"    : Gosub E_GIMP6        : # Chgt client commande
  When "GIMP(7)"    : Gosub E_GIMP7        : # Chgt client payeur
  When "GIMP(8)"    : Gosub E_GIMP8        : # Chgt client livré
  When "GIMP(9)"    : Gosub E_GIMP9        : # Chgt transporteur

  When "GIMP(15)"   : Gosub E_GIMP15       : # Lecture 1ere ligne cde

  When "GIMP(52)"   : Gosub E_GIMP52       : # Chgt article

  When Default

Endcase

Return

#----------------------------------------------------------------------
#   Société ( [F:CPY] + [F:BPA] société )
$E_GIMP3
Raz [F:BPA]
# retrouver la société avec le site de vente
Read [FCY]FCY0=[F:SOH]SALFCY
If fstat : Raz [F:FCY] : Endif
Read [CPY]CPY0=[F:FCY]LEGCPY
If fstat : Raz [F:CPY] : Endif
Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Site vente ( [F:FCY] + [F:BPA] site vente )
$E_GIMP4
If [F:FCY]FCY<>[F:SOH]SALFCY
  Read [FCY]FCY0=[F:SOH]SALFCY
    If fstat : Raz [F:FCY] : Endif
Endif
Read [BPA]BPA0=3;[F:SOH]SALFCY;[F:FCY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client facture ( [F:BPR] + [F:BPC] + [F:BPA] client facture )
$E_GIMP5
If [F:BPC]BPCNUM<>[F:SOH]BPCINV
  Read [BPC]BPC0=[F:SOH]BPCINV
  If fstat : Raz [F:BPC] : Endif
Endif
If [F:BPR]BPRNUM<>[F:SOH]BPCINV
  Read [BPR]BPR0=[F:SOH]BPCINV
  If fstat : Raz [F:BPR] : Endif
Endif
Raz [F:BPA]

# -- test si adresse modifiée
If [F:SOH]BPINAM    <> "" | [F:SOH]BPIADDLIG <> "" |
&  [F:SOH]BPIPOSCOD <> "" | [F:SOH]BPICTY    <> "" |
&  [F:SOH]BPISAT    <> "" |
&  [F:SOH]BPICRY    <> "" | [F:SOH]BPICRYNAM <> ""
  [F:BPA]BPAADD       = [F:SOH]BPAINV
  [F:BPA]BPADES       = [F:SOH]BPINAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SOH]BPIADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SOH]BPIADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SOH]BPIADDLIG(2)
  [F:BPA]POSCOD       = [F:SOH]BPIPOSCOD
  [F:BPA]CTY          = [F:SOH]BPICTY
  [F:BPA]SAT          = [F:SOH]BPISAT
  [F:BPA]CRY          = [F:SOH]BPICRY
  [F:BPA]CRYNAM       = [F:SOH]BPICRYNAM
Else
  Read [BPA]BPA0=1;[F:SOH]BPCINV;[F:BPC]BPAINV
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Client commande ( [F:BPC] + [F:BPA] client cde : adresse)
$E_GIMP6
If [F:BPC]BPCNUM<>[F:SOH]BPCORD
  Read [BPC]BPC0=[F:SOH]BPCORD
  If fstat : Raz [F:BPC] : Endif
Endif

# -- test si adresse modifiée
If [F:SOH]BPCNAM    <> "" | [F:SOH]BPCADDLIG <> "" |
&  [F:SOH]BPCPOSCOD <> "" | [F:SOH]BPCCTY    <> "" |
&  [F:SOH]BPCSAT    <> "" |
&  [F:SOH]BPCCRY    <> "" | [F:SOH]BPCCRYNAM <> ""
  [F:BPA]BPAADD       = [F:SOH]BPAORD
  [F:BPA]BPADES       = [F:SOH]BPCNAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SOH]BPCADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SOH]BPCADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SOH]BPCADDLIG(2)
  [F:BPA]POSCOD       = [F:SOH]BPCPOSCOD
  [F:BPA]CTY          = [F:SOH]BPCCTY
  [F:BPA]SAT          = [F:SOH]BPCSAT
  [F:BPA]CRY          = [F:SOH]BPCCRY
  [F:BPA]CRYNAM       = [F:SOH]BPCCRYNAM
Else
  Read [BPA]BPA0=1;[F:SOH]BPCORD;[F:BPC]BPAADD
  If fstat : Raz [F:BPA] : Endif
Endif


Return

#----------------------------------------------------------------------
#   Client payeur ( [F:BPC] + [F:BPA] client payeur : adresse )
$E_GIMP7
If [F:BPC]BPCNUM<>[F:SOH]BPCPYR
  Read [BPC]BPC0=[F:SOH]BPCPYR
  If fstat : Raz [F:BPC] : Endif
Endif
#   si client divers (prendre adresse de facture)
If [F:BPC]BPCTYP=2 : Gosub E_GIMP5 : Return : Endif
#   adresse par defaut
Raz [F:BPA]
Read [BPA]BPA0=1;[F:SOH]BPCPYR;[F:BPC]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client livré ( [F:BPD] + [F:BPA] )
$E_GIMP8
Raz [F:BPD], [F:BPA]
#
Read [F:BPD]BPD0=[F:SOH]BPCORD; [F:SOH]BPAADD
If fstat : Raz [F:BPD] : Endif
# -- test si adresse modifiée
If [F:SOH]BPDNAM    <> ""   |  [F:SOH]BPDADDLIG <> ""  |
&  [F:SOH]BPDPOSCOD <> ""   |  [F:SOH]BPDCTY    <> ""  |
&  [F:SOH]BPDSAT    <> ""   |
&  [F:SOH]BPDCRY    <> ""   |  [F:SOH]BPDCRYNAM <> ""
  [F:BPA]BPADES       = [F:SOH]BPDNAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SOH]BPDADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SOH]BPDADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SOH]BPDADDLIG(2)
  [F:BPA]POSCOD       = [F:SOH]BPDPOSCOD
  [F:BPA]CTY          = [F:SOH]BPDCTY
  [F:BPA]SAT          = [F:SOH]BPDSAT
  [F:BPA]CRY          = [F:SOH]BPDCRY
  [F:BPA]CRYNAM       = [F:SOH]BPDCRYNAM
Else
  Read [BPA]BPA0=1;[F:SOH]BPCORD;[F:SOH]BPAADD
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Transporteur ( [F:BPT] + [F:BPA] )
$E_GIMP9
Raz [F:BPT], [F:BPA]

Read [BPT]BPT0=[F:SOH]BPTNUM
If fstat : Raz [F:BPT] : Endif
Read [F:BPA]BPA0=1;[F:SOH]BPTNUM;[F:BPT]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Lecture de 1čre ligne de commande
$E_GIMP15

If EXPFIC = "SOH"
  Raz [F:SOP], [F:SOQ]
#      lecture du 1er enr. détail commande (pour alimenter entęte)
  Filter [SOP] Where SOHNUM=[F:SOH]SOHNUM
  Read [SOP]SOP0 First
  Filter [SOP]
  Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM
  Read [SOQ]SOQ0 First
  Filter [SOQ]
Endif
Return

#----------------------------------------------------------------------
#   Chgt article ( [F:ITM] + [F:ITS] + [F:ITU] )
$E_GIMP52
Raz [F:ITM], [F:ITS], [F:ITU]
If [F:SOQ]ITMREF="" & [F:SOP]ITMREF<>"" : [F:SOQ]ITMREF=[F:SOP]ITMREF : Endif
If [F:ITM]ITMREF<>[F:SOQ]ITMREF
  Read [ITM]ITM0=[F:SOQ]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:SOQ]ITMREF
  Read [ITS]ITS0=[F:SOQ]ITMREF
  If fstat : Raz [F:ITS] : Endif
Endif
If [F:ITU]ITMREF<>[F:SOQ]ITMREF | [F:ITU]BPCNUM<>[F:SOH]BPCORD
  Read [ITU]ITU0=[F:SOQ]ITMREF;[F:SOH]BPCORD
  If fstat : Raz [F:ITU] : Endif
Endif
Return

######################################################################

######################################################################

$PISTAGE

Case ACTION
  When "IMP_ZONE"
    Setmode
    Infbox ACTION+IMPFIC+IMPZON
  When "IMP_TAB"
    Setmode
    Infbox ACTION+IMPFIC+IMPZON
  When Default
    Infbox ACTION
Endcase

Return

######################################################################

