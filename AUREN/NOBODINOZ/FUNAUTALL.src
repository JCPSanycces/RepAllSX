#<AdxTL>@(#)0.0.0.0 $Revision$ 
#########################################################################
#     ALLOCATIONS AUTOMATIQUES 140                                      #
#########################################################################
#                                                                       #
#     ALLOCATIONS AUTOMATIQUES                                          #
#                                                                       #
#     - Traitement        : FUNAUTALL                                   #
#     - Action e_commerce : TRTAUTALL                                   #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
# Issue X3-80449/X3-80171 - 20180301 by LD : FUNAUTALL and customer blocked/Automatic Allocation not allocating orders correctly

$ACTION

#--- Actions liťes au traitement standard
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99
 When "OK"          : GOK=1
 When "END"         : GOK=0 : FIN=1
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return
#######################################################################
#    Dťtail des actions liťes au traitement standard                  #
#######################################################################
#######################################################################
$INIT
# (llc) pour appel depuis les consultations des ruptures
Local    Char    LFCY   : LFCY   = PARAM(1)
Local    Char    LDAT   : LDAT   = PARAM(2)
Local    Char    LVCR   : LVCR   = PARAM(3)
Local    Char    LITM   : LITM   = PARAM(4)
Local    Char    LCRIT1 : LCRIT1 = PARAM(5)
Local    Char    LCRIT2 : LCRIT2 = PARAM(6)

GORDCAT=4
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SAUTALL [DIA]

Raz [M:DIA]

# (llc) pour appel depuis les consultations des rupture
If LFCY <> ""
    [M:DIA]STOFCY    = LFCY
Else
    [M:DIA]STOFCY    = GFCYDEF(7)
Endif
If LDAT <> ""
    If instr(1,LDAT,"/")
        [M:DIA]SHIDAT = "["+LDAT+"]"
    Else
        [M:DIA]SHIDAT=LDAT
    Endif
Else
    [M:DIA]SHIDAT=date$
Endif
If LVCR <> "" : [M:DIA]SOHNUMDEB = LVCR : [M:DIA]SOHNUMFIN = LVCR : Endif
If LITM <> "" : [M:DIA]ITMREFDEB = LITM : [M:DIA]ITMREFFIN = LITM : Endif

If LCRIT1 <> "" : [M:DIA]ALLCRITDET = LCRIT1 : Endif
If LCRIT2 <> ""
    If [M:DIA]ALLCRITDET<>"" [M:DIA]ALLCRITDET -= '&' Endif
    [M:DIA]ALLCRITDET -= LCRIT2
Endif
[M:DIA]CALCRITDET=[M:DIA]ALLCRITDET

If [M:DIA]DRNFLG = 1
    [M:DIA]DRN= 0
Endif
[M:DIA]DLVPIOFIN=len(mess(0,410,1))

[M:DIA]GENSHT = GGENSHT
[M:DIA]IMPCLI = GUSERERBPC
If GUSERERBPC=3 [M:DIA]IMPCLI=2 Endif

Call LECMEMO ("STD","[M:DIA]","va1") From GMEMO

# Positionner le flag si saisie des paramÍtres depuis la gestion des abonnements
[M:DIA]ABT=1
If GFONCTION1="GESABA" [M:DIA]ABT=2 Endif

Return
#######################################################################
$CONTROLE
If GOK < 1  FIN=1 Else TMP=1  Endif

Raz [F:SOH]
#TIT=" "

Return
#######################################################################
$EXEC

If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SAUTALL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# Bornage de la date de prise en compte des commandes si la requÍte est abonnťe
# Si date expťdition non renseignťe, on force la date du jour
If [M:DIA]SHIDAT = [0/0/0] & [M:DIA]ABT=2 [M:DIA]SHIDAT = date$ : Endif

# --> Rťcupťration du paramŤtre vente : GSOHAPPALL    : Allocation des commandes non signťes
Local Char     WPARAM(GLONADP)
Call PARAML([M:DIA]STOFCY,"SOHAPPALL",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSOHAPPALL= val(WPARAM)
# --> Rťcupťration du paramŤtre vente : GSOHAPPORD    : Encours si commandes non signťes
Local Char     WPARAM(GLONADP)
Call PARAML([M:DIA]STOFCY,"SOHAPPORD",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSOHAPPORD= val(WPARAM)

Gosub SEL_SOQ
# --> Premier passage
If [M:DIA]SHTFLG = 2 WFLGALL = 1
Else             WFLGALL = 2 : Endif
Raz NBALL

Gosub TRT_SOQ

# --> DeuxiŤme passage
If [M:DIA]SHTFLG = 2 WFLGALL = 2 : Gosub TRT_SOQ : Endif

Return
#######################################################################
$TERMINE

If !GSERVEUR
    If !NBALL
         Call ECR_TRACE(mess(39,192,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
# --> Aucune allocation effectuee ou lecture trace
    If !NBALL
         GERR=2:GMESSAGE = mess(39,192,1)
    Endif
    TRA=1
Endif

Return

#-----------------------------------------------------------------------#
#    Ouvre                                                              #
#-----------------------------------------------------------------------#
$OUVRE
Local Integer  OK, NBALL, WFLGALL, WALLLINNBR
Local Char     TIT(50), SYMBOLE(50)
Local Char     SVOPTIMSYMBOLE(50)      # FGR 26/08/2015 : X3SUIVI110559
Local Char     PREVLOCKERRSYMBOLE(50)  # Issue 117638 - 2016-07-27 by CPO : Order locked having multiple lines (lock error during first line but not for following line, if any)
Local Char     CRITERE(250), CRITERE1(250), CRITERE4(250), CRITENT(160), CRITDET(250)
Local Char     WMESS(120), WMESS_FIC(40), WMESS1(80), WMESS2(120)
Local Decimal  WTALLSTU, WALLSTU, WSHTSTU
Local Decimal  WALL, WSHT, WQTY
Local Decimal  WSTUDIS
Local Integer  WRET
Local Integer  WALLKIT   :# Composť Kit (0:Pas ŗ traiter,1:A Traiter,Rien ŗ allouer,2:A traiter,Allouť)
Local Char     WTRTLIG(1)
Local Char     WSALFCY(GLONFCY), WBPCNAM(GLONNAM)
Local Libelle  WALLPAR, WGENSHT

Local Char     WTSICOD(20)(0..10)


TIT = mess(31,191,1)

#---------------------------------------#
# Ouverture des fichiers utilisťs       #
#---------------------------------------#
If clalev([F:SOH]) = 0 Local File SORDER      [SOH]: Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ]: Endif
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP]: Endif
If clalev([F:SOC]) = 0 Local File SORDERC     [SOC]: Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM]: Endif
If clalev([F:ITV]) = 0 Local File ITMMVT      [ITV]: Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF]: Endif
If clalev([F:FCY]) = 0 Local File FACILITY    [FCY]: Endif
If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [BPC]: Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

Default File [SOQ]

# --- Dťclaration classe ecran pour les encours --- #
Local Mask ORDK    [ORDK] : Raz [M:ORDK]
# --- Dťclaration classe ecran pour les allocations --- #
Local Mask ALLPAR  [ALP]  : Raz [M:ALP]

#----------------------------
# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

# ------------------------------------------- #
# Alimentation ŗ partir du site de vente      #
#              du site financier    GFINRSP   #
#              de la sociťtť        GSOCIETE  #
#              de la devise sociťtť GLOCALDEV #
# ------------------------------------------- #
Call GETDEV(GFCYDEF(5)) From DEVSUB
# ------------------------------------------- #
# Rťcupťration des paramÍtres de vente        #
# ------------------------------------------- #
Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3

# C'est une fonction vente qui travaille sur un site d'expťdition
# On surcharge donc le site par dťfaut du module avec celui d'expťdition
# pour que les contrŰles d'autorisation des sites soient corrects.
#GFCYDEF(0) = GFCYDEF(7)
If LFCY <> ""
    GFCYDEF(0) = LFCY
Else
    GFCYDEF(0) = GFCYDEF(7)
Endif
# --> Rťcupťration du paramŤtre stock : GENSHT    : Gťnťration des ruptures
Local Char     WPARAM(10)
Call PARAML(GFCYDEF(0),"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT= val(WPARAM)

#Raz [M:DIA]
Local Integer  WCDTUNL
#------------------------------------------------------------#
# Chargement flag dťblocage crťdit autorisť                  #
#------------------------------------------------------------#
#Call CTLACC("/SCDTUNL") From TRTVENCTL
#If mkstat = 2 WCDTUNL = 1
#Else          WCDTUNL = 2:ENDIF
Local Char WPARAM(10)
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif

Return

#---------------------------------------------------------------------#
# Selection sur les lignes de commandes SOQ                           #
#---------------------------------------------------------------------#
$SEL_SOQ
#--> critŤres de saisie
CRITERE  = "SOQSTA <> 3"               :# ťtat ligne non soldťe
CRITERE1 = "1=1"
If [M:DIA]SOHNUMDEB <> ""
   CRITERE -= '& SOHNUM >="'+[M:DIA]SOHNUMDEB+'"'
Endif
If [M:DIA]SOHNUMFIN <> ""
   CRITERE -= '& SOHNUM <="'+[M:DIA]SOHNUMFIN+'"'
Endif
If [M:DIA]BPCORDDEB <> ""
   CRITERE -= '& BPCORD >="'+[M:DIA]BPCORDDEB+'"'
Endif
If [M:DIA]BPCORDFIN <> ""
   CRITERE -= '& BPCORD <="'+[M:DIA]BPCORDFIN+'"'
Endif
If [M:DIA]BPAADDDEB <> ""
   CRITERE -= '& BPAADD >="'+[M:DIA]BPAADDDEB+'"'
Endif
If [M:DIA]BPAADDFIN <> ""
   CRITERE -= '& BPAADD <="'+[M:DIA]BPAADDFIN+'"'
Endif
If [M:DIA]CPY <> ""                          : # Bug 66478
   CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'     : # Bug 66478
Endif                                        : # Bug 66478
If [M:DIA]STOFCY <> ""
   CRITERE -= '& STOFCY = "'+[M:DIA]STOFCY+'"'
Endif
If [M:DIA]DRNFLG = 2
   CRITERE -= "& DRN =" +num$([M:DIA]DRN)
Endif

CRITERE1 -= "& DLVPIO >=" +num$([M:DIA]DLVPIODEB)
CRITERE1 -= "& DLVPIO <=" +num$([M:DIA]DLVPIOFIN)

CRITERE4 = "1=1"
# CritŤre article : Traitement particulier pour les kits
# Dans un 1er temps, la borne article ne doit pas s'appliquer sur kits et composants
If [M:DIA]ITMREFDEB <> "" | [M:DIA]ITMREFFIN <> ""
    CRITEREITM = "1=1"
    If [M:DIA]ITMREFDEB <> ""
       CRITEREITM = '& ITMREF>="'+[M:DIA]ITMREFDEB+'"'
    Endif
    If [M:DIA]ITMREFFIN <> ""
       CRITEREITM -= '& ITMREF<="'+[M:DIA]ITMREFFIN+'"'
    Endif
    CRITERE4 -= "& (SOHCAT=4 "
    CRITERE4 -= CRITEREITM
    CRITERE4 -= ") | (SOHCAT<>4 & (find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) | (!find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)"
    CRITERE4 -= CRITEREITM
    CRITERE4 -= ")))"
Endif

#--> CritŤres supplťmentaires
CRITERE1 -= "& DEMSTA = 1"                :# statut ordre ferme

#---------------------------------------------------------------------#
# Point d'entree ajout filtres supplťmentaires                        #
#---------------------------------------------------------------------#
Local Char FILSUP (250)
FILSUP="1=1"
GPOINT="AUTALLFIL" : Gosub ENTREE From EXEFNC

#--> CritŤres paramťtrables
CRITDET = "1=1"
If [M]CALCRITDET <> "" CRITDET = [M]CALCRITDET Endif
CRITENT = "1=1"
If [M]ALLCRITENT <> "" CRITENT = [M]ALLCRITENT Endif

Return


#---------------------------------------------------------------------#
# Traitement des lignes de commandes                                  #
#---------------------------------------------------------------------#
$TRT_SOQ
Local Date     L_SHIDAT
Local Char     L_SOHNUM(type([F:SOQ]SOHNUM)-10)
Local Char     CRITERE2(150), CRITERE3(20)
Local Integer  L_COMPTEUR, L_SOQSTA, L_SOPLIN, L_SOQSEQ
Local Shortint STOP, L_DLVPIOCMP
Local Integer  WCDTSTA
Local Char     WCURRLOCKEDSOH(255) # Issue X3-51915 - 2017-08-21 by CPO : A user currently modifying an order looses all his data because of the UPDTICK error

# --> Rajout du critŤre pour le traitement des manquants
If WFLGALL = 1
    CRITERE3 = "SHTQTYSTU <> 0"
Else
    CRITERE3 = "1=1"
Endif

#---
Local Integer SAUVGPE : SAUVGPE=GPE : GPE=0
GPOINT="AUTALLTRT" : Gosub ENTREE From EXEFNC
If GPE   GPE=SAUVGPE : Return   Else   GPE=SAUVGPE   Endif
#---
SAUVGPE=GPE                                          # hcb 87717
GPE=0                                                # hcb 87717
GPOINT="SOQMODTRI" : Gosub ENTREE From EXEFNC        # hcb 87717
If GPE  = 0                                          # hcb 87717
   GPE=SAUVGPE                                       # hcb 87717
   Link [SOQ] With
&    [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ,
&    [SOC]SOC0=[SOQ]SOHNUM;[SOQ]SOPLIN
&    As [KSOQ] Order By Key KEY1=SHIDAT;DLVPIOCMP;SOHNUM;SOPLIN;SOQSEQ
Endif                                                # hcb 87717

# --> Lecture des lignes de commandes
Filter [KSOQ] Where (evalue (CRITERE) & evalue (CRITERE1) & evalue (CRITERE3) & evalue (CRITERE4) &
&                    evalue (FILSUP) & evalue (CRITDET))

Raz L_SOQSTA, L_SHIDAT, L_DLVPIOCMP, L_SOHNUM, L_SOPLIN, L_SOQSEQ, STOP, CRITERE2

$DEB_BOUCLE
If STOP=1
   CRITERE2="SOQSTA=L_SOQSTA & SHIDAT=L_SHIDAT & DLVPIOCMP=L_DLVPIOCMP & SOHNUM=L_SOHNUM & SOPLIN=L_SOPLIN & SOQSEQ>L_SOQSEQ"
   STOP=2
Elsif STOP=2
   CRITERE2="SOQSTA=L_SOQSTA & SHIDAT=L_SHIDAT & DLVPIOCMP=L_DLVPIOCMP & SOHNUM=L_SOHNUM & SOPLIN>L_SOPLIN"
   STOP=3
Elsif STOP=3
   CRITERE2="SOQSTA=L_SOQSTA & SHIDAT=L_SHIDAT & DLVPIOCMP=L_DLVPIOCMP & SOHNUM>L_SOHNUM"
   STOP=4
Elsif STOP=4
   CRITERE2="SOQSTA=L_SOQSTA & SHIDAT=L_SHIDAT & DLVPIOCMP>L_DLVPIOCMP"
   STOP=5
Elsif STOP=5
   CRITERE2="SOQSTA=L_SOQSTA & SHIDAT>L_SHIDAT "
   STOP=6
Elsif STOP=6
   CRITERE2="SOQSTA>L_SOQSTA"
   STOP=0
Else
   CRITERE2="1=1"
Endif
L_COMPTEUR=0
#For [KSOQ]SOQ3 Where evalue(CRITERE2)
For [KSOQ]KEY1 Where evalue(CRITERE2)
   # Issue X3-51915 - 2017-08-21 by CPO : A user currently modifying an order looses all his data because of the UPDTICK error
   #--among the controls there is a calculation of the credit level and an update of new value into SOH.
   #--the fix consist in testing the lock before doing the control and continuing if no lock set.
   Gosub TEST_LOCK_AND_UNLOCK_ASAP
   If OK=99 : Goto NXTSOQ : Endif #--in this case, we want to step over
   If OK=2 #--we need to go throught the VERROU in order to ensure the right locking and eventually ne error message if order already locked !
   # End issue X3-51915
     Gosub LEC_SOP
     If OK=1 Goto NXTSOQ : Endif
     Gosub SEL_SOQCOMPL
     If OK=1 Goto NXTSOQ : Endif
     Gosub SEL_SOHCOMPL
     If OK=1 Goto NXTSOQ : Endif
     Gosub SEL_SOPCOMPL
     If OK=1 Goto NXTSOQ : Endif
   Endif # Issue X3-51915 - 2017-08-21 by CPO
   Gosub VERROU
   If OK=2
       Read [SOQ]SOQ0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
       If fstat OK=1 : Goto NXTSOQ : Endif
       If [F:SOQ]ALLQTYSTU = 0 & [F:SOQ]SHTQTYSTU = 0 WTRTLIG = "C"
       Else WTRTLIG = "M" :Endif
       WSHTSTU  = [F:SOQ]SHTQTYSTU
       WTALLSTU = [F:SOQ]ALLQTYSTU + [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU + [F:SOQ]ODLQTYSTU
       If [F:SOH]SOHCAT = 3
           WTALLSTU += [F:SOQ]INVQTYSTU
       Else
           WTALLSTU += [F:SOQ]DLVQTYSTU
       Endif
       # --> Traitement de toute l'allocation : Recherche si Qtť ŗ allouer
       If WFLGALL = 2
          If WTALLSTU >= [F:SOQ]QTYSTU & WSHTSTU = 0 OK=1:Endif
       Endif
       #If OK=1 Gosub DEVERROU : Goto NXTSOQ : Endif       # FGR 07/10/2015 : X3SUIVI110559
       If OK=1 Goto NXTSOQ : Endif                         # FGR 07/10/2015 : X3SUIVI110559

       L_COMPTEUR+=1
       If L_COMPTEUR>1000
          L_SOQSTA=[F:SOQ]SOQSTA
          L_SHIDAT=[F:SOQ]SHIDAT
          L_DLVPIOCMP=[F:SOQ]DLVPIOCMP
          L_SOHNUM=[F:SOQ]SOHNUM
          L_SOPLIN=[F:SOQ]SOPLIN
          L_SOQSEQ=[F:SOQ]SOQSEQ
          STOP=1
       Endif

       Gosub TRTALL
       #Gosub DEVERROU                                     # FGR 07/10/2015 : X3SUIVI110559
       If STOP=1 Break Endif

    Endif
    $NXTSOQ
Next
Gosub DEVERROU                                             # FGR 07/10/2015 : X3SUIVI110559
If STOP Goto DEB_BOUCLE Endif
Filter [SOQ]
Return
#-----------------------------------------------------------------------#
 # Issue X3-51915 - 2017-08-21 by CPO : A user currently modifying an order looses all his data because of the UPDTICK error
 #--among the controls there is a calculation of the credit level and an update of new value into SOH.
 #--the fix consist in testing the lock before doing the control and continuing if no lock set.
$TEST_LOCK_AND_UNLOCK_ASAP

# Issue X3-80449/X3-80171
Local Integer WCHG_CDE    :    WCHG_CDE=0
# End issue X3-80449/X3-80171

  #--the current order header might not be read yet
  If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
      Read [SOH]SOH0 = [F:SOQ]SOHNUM
      If fstat OK= 99 : Return : Endif
      # Issue X3-80449/X3-80171
      WCHG_CDE = 1
      # End issue X3-80449/X3-80171
      # Issue X3-147414 - 2019-08-01 by MUARN : In case of first line back-to-back and order on credit hold
      WCDTSTA=0
  Endif
  If !evalue (CRITENT): Raz [F:SOH] : OK=99 : Return : Endif # Issue X3-141764 - 2019-07-29 by CPO : "Change In Progress on another workstation" should not be displayed when a order header formula
  OK=2
  #--The $VERROU set current locked SYMBOLE
  If [F:SOH]SOHCAT<>4
    [L]WCURRLOCKEDSOH = "SOH"+[F:SOH]SOHNUM
  Else
    # Lock fichier commande ouverte
    [L]WCURRLOCKEDSOH = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOQ]SOHNUM
  Endif
  If [L]WCURRLOCKEDSOH <> SYMBOLE Then
    #--setting the SOH lock and testing the status
    Lock =[L]WCURRLOCKEDSOH With lockwait = 0
    If fstat
      #--if locked, we set OK=1 to loop on the next order line of the link
      Raz WCURRLOCKEDSOH
      OK=1 : Return
    Endif

    #--right after, we unlock to let the existing loop handling the lock...
    Unlock =[L]WCURRLOCKEDSOH
    Raz [L]WCURRLOCKEDSOH
  Endif
Return
#-----------------------------------------------------------------------#
# Lecture du SOP pour rťcupťrer la dťsignation dans la trace            #
#-----------------------------------------------------------------------#
$LEC_SOP
OK=2
Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
If fstat & [F:SOQ]SOHCAT <> 4 OK=1 : Return
Elsif fstat
    If [F:SOC]SOHNUM <> [F:SOQ]SOHNUM | [F:SOC]SOPLIN <> [F:SOQ]SOPLIN
        Raz [F:SOP]
        Read [SOC]SOC0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN
        If fstat OK=1 : Return : Endif
    Endif
    [F:SOP] = [F:SOC]
Endif
Return
#-----------------------------------------------------------------------#
# Sťlections complťmentaires sur l'enregistrement SOQ                   #
#-----------------------------------------------------------------------#
$SEL_SOQCOMPL
Local Date WDATORI, WDATDES

# Si site non renseignť dans les critŤres, ctrl d'autorisation de la fonction pour le site
# (Si site renseignť, le ctrl a ťtť fait en saisie du chps site)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 If !find([F:SOQ]STOFCY,GUSRFCY(1..GNBAUZ)) OK=1 : Return Endif
Endif

# Si composť de kit/sous-traitť, c'est iÁi qu'on vťrifie la borne article
If find([F:SOP]LINTYP,2,10)
    WALLKIT=0
    If [M:DIA]ITMREFDEB <> "" & [F:SOP]ITMREF < [M:DIA]ITMREFDEB OK=1 : Return : Endif
    #If [M:DIA]ITMREFFIN <> "" & [F:SOP]ITMREF > [M:DIA]ITMREFDEB OK=1 : Return : Endif
    If [M:DIA]ITMREFFIN <> "" & [F:SOP]ITMREF > [M:DIA]ITMREFFIN OK=1 : Return : Endif # Issue X3-87167 MGO 10/05/2018 : Allocation of a fixed kit
    WALLKIT=1
Endif
# On exclut les lignes si :
# --> Mode de livraison contremarque receptionnťe ou ordre production
If [F:SOQ]FMI = 3 | [F:SOQ]FMI = 5
    If [F:SOP]LINTYP = 2 WALLKIT=0 Endif : # Bug 56680
    OK=1 : Return
Endif

OK=2
#-----------------------------------------------------------------------#
# ----- Sťlection sur la date expťdition -----                          #
#-----------------------------------------------------------------------#

WMESS=mess(98,197,1)-":"-[F:SOQ]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
WMESS1=mess(184,197,1)+" "+format$(GFMD,[F:SOQ]SHIDAT)
WMESS2=mess(189,197,1)-":"-mess(188,197,1)

# --> Selection si date expť. <= date expť. saisie
If [M:DIA]SHIDAT <> [0/0/0] & [F:SOQ]SHIDAT <= [M:DIA]SHIDAT Return:Endif
Gosub LEC_ITM
Gosub LEC_ITF

WDATORI = date$
## Article achetť   : On tient compte du dťlai de rťappro     : dťlai calendaire
#If find([F:ITM]CLSTYP, 1,3)
#     WDATORI = WDATORI + [F:ITF]OFS
#     If [F:ITF]OFS <> 0
#        WMESS1 -= mess(185,197,1) - ":" - num$([F:ITF]OFS)
#        WMESS2 -= "+" - mess(185,197,1)
#     Endif
## Article fabriquť : On tient compte du dťlai de fabrication : dťlai ouvrť
#Elsif find([F:ITM]CLSTYP,2,4)
#     If [F:ITF]MFGLTI <> 0
#         WMESS1 -= mess(186,197,1)- ":" - num$([F:ITF]MFGLTI)
#         WMESS2 -= "+" - mess(186,197,1)
#         Call CALC_SHIDAT(WDATORI, [F:ITF]MFGLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATDES) From TRTVENDAT
#         WDATORI = WDATDES
#     Endif
#Endif

Local Date WDATCALP, WDATCALM : WDATCALP=WDATORI : WDATCALM=WDATORI
# Article achetť   : On tient compte du dťlai de rťappro     : dťlai calendaire
If [M:DIA]LTIFLG1=2 & [F:ITM]PURFLG=2
   WDATCALP += [F:ITF]OFS
Endif

# Article fabriquť : On tient compte du dťlai de fabrication : dťlai ouvrť
If [M:DIA]LTIFLG1=2 & [F:ITM]MFGFLG=2 & [F:ITF]MFGLTI<>0
   Call CALC_SHIDAT(WDATORI, [F:ITF]MFGLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATCALM) From TRTVENDAT
Endif

# On prend ensuite la date la plus ťlevťe (un article peut Ítre achetť et fabriquť)
If [M:DIA]LTIFLG1=2
   If WDATCALP>WDATCALM
      WDATORI=WDATCALP
      WMESS1 -= mess(185,197,1)- ":" - num$([F:ITF]OFS)
      WMESS2 -= "+" - mess(185,197,1)
   Else
      WDATORI=WDATCALM
      WMESS1 -= mess(186,197,1)- ":" - num$([F:ITF]MFGLTI)
      WMESS2 -= "+" - mess(186,197,1)
   Endif
Endif

# On tient compte dans les 2 cas du dťlai de prťpa : dťlai ouvrť
If [M:DIA]LTIFLG2=2 & [F:ITF]PRPLTI<>0
    WMESS1 -= mess(187,197,1) - ":" - num$([F:ITF]PRPLTI)
    WMESS2 -= "+" - mess(187,197,1)
    Call CALC_SHIDAT(WDATORI, [F:ITF]PRPLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATDES) From TRTVENDAT
    WDATORI = WDATDES
Endif

# --> Selection si date expť. <= date trt + dťlai + dťlai prťpa
If [F:SOQ]SHIDAT <= WDATORI Return : Endif

If [M:DIA]SHIDAT = [0/0/0]
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif

OK=1
Return
#-----------------------------------------------------------------------#
# Sťlections complťmentaires sur l'entÍte comande SOH                   #
#-----------------------------------------------------------------------#
$SEL_SOHCOMPL
# Issue X3-80449/X3-80171
# Local Integer WCHG_CDE    :    WCHG_CDE=0
# End issue X3-80449/X3-80171

OK=2
If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
    Read [SOH]SOH0 = [F:SOQ]SOHNUM
    If fstat OK=1 :Return:Endif
    WCHG_CDE=1
    # Issue X3-147414 - 2019-08-01 by MUARN : In case of first line back-to-back and order on credit hold
    WCDTSTA=0
Endif

If !evalue (CRITENT) OK=1 : Return : Endif

If [F:SOH]BPCNAM(0) <> ""
    WBPCNAM=[F:SOH]BPCNAM(0)
Else
    If [F:BPC]BPCNUM<>[F:SOH]BPCORD
        Read [BPC]BPC0 = [F:SOH]BPCORD
        If fstat Raz [F:BPC] : Endif
    Endif
    WBPCNAM=[F:BPC]BPCNAM
Endif

If !find([F:SOP]LINTYP,3,4,5,11,12,13)
    WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(99,197,1)-":"-[F:SOH]BPCORD-WBPCNAM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
Else
    WMESS="  "-mess([F:SOP]LINTYP,423,1)-[F:SOQ]ITMREF-[F:SOP]ITMDES1
Endif

# --> On exclut les cdes ŗ allocation manuelle
#If [M:DIA]MANALL = 1 & [F:SOH]ALLSOH = 2 OK=1 : Return : Endif

# --> On exclut les cdes non signťes si Pas d'encours ou Pas d'allocation des commandes non signťes
If (GSOHAPPORD=1 | GSOHAPPALL=1) & [F:SOH]APPFLG<= 2 OK=1 : Return : Endif

# X3-119756 : Management of draft sales orders / X3-81821 : Hide draft SO - Exclusion from the transformation document mass processes (LD 12/21/18)
# Draft sales orders have to be excluded
If [F:SOH]DRAFTSTATUS<> 0 OK=1 : Return : Endif
# X3-119756 : Management of draft sales orders / X3-81821 : Hide draft SO - Exclusion from the transformation document mass processes (LD 12/21/18)

If func MANHLDLIB.BLK_ALLOC([F:SOH]HLDSTA,[F:SOH]HLDCOD)    # order holds
  WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(18,197,1)-num$([F:SOP]SOPLIN)-mess(13,492,1)
  Call ECR_TRACE(WMESS,0) From GESECRAN
  OK=1 : Return
Endif

If WSALFCY <> [F:SOH]SALFCY
    # --> Alimentation ŗ partir du site de vente
    Call GETDEV([F:SOH]SALFCY) From DEVSUB
    # Rťcupťration des paramÍtres de vente
    Call GLOBVAR([F:SOH]SALFCY,"VEN") From TRTX3
    WSALFCY = [F:SOH]SALFCY
Endif

# --> On exclut les commandes dt l'ťtat crťdit n'est pas ok
#     Calcul de  l'ťtat crťdit et maj de la cde uniquement si on a changť de commande
If WCHG_CDE = 1 | WCDTSTA=0
    Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,"",[F:SOH]ORDDAT,[F:SOH]UNL,2,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
Endif
If WCDTSTA <> 1
#   Si acompte non versť mais pas de blocage on continue
    If WCDTSTA=4 & GLOKORD = 1 Return Endif
#   Si dťpassement en-cours mais pas de blocage on continue
    If WCDTSTA=3 & WCDTUNL = 2 Return Endif
    OK=1
    Call ECR_TRACE(WMESS,0) From GESECRAN
    If WCDTSTA = 2 Then
      Call ECR_TRACE("         "+mess(100,197,1), 1) From GESECRAN
    Elsif WCDTSTA = 3 Then
      # FGR 10/03/2015 : X3SUIVI23273 (dťbut)
      #Call ECR_TRACE("         "+mess(101,197,1), 1) From GESECRAN
      If !([F:SOH]BETFCY = 2 & [F:SOH]BETCPY <> 2) or GCTLBETFCY = 2 Then
        Call ECR_TRACE("         "+mess(101,197,1), 1) From GESECRAN
      Endif
      # FGR 10/03/2015 : X3SUIVI23273 (fin)
    # 111303.n - Show correct message for credit card hold
    Elsif WCDTSTA=5
      Call ECR_TRACE("         "+mess(5,2092,1), 1) From GESECRAN
    Elsif GLOKORD = 2 Then
      Call ECR_TRACE("         "+mess(102,197,1), 1) From GESECRAN
    Endif
Endif

Return
#-----------------------------------------------------------------------#
# Sťlections complťmentaires sur l'enregistrement SOP                   #
#-----------------------------------------------------------------------#
$SEL_SOPCOMPL
OK=2
# On exclut les lignes si :
# --> Si Composants de kit/sous-traitť et le composť n'a pas ťtť allouť et on est en allocation
If find([F:SOP]LINTYP,3,4,5,11,12,13) & WALLKIT=0 & WFLGALL = 2 OK=1: Return : Endif
# --> Si Composants de kit/sous-traitť et on est en traitement des ruptures et on est pas dans la borne article
If find([F:SOP]LINTYP,3,4,5,11,12,13) & WFLGALL = 1
    # On vťrifie la borne article
    If [M:DIA]ITMREFDEB <> "" & [F:SOP]ITMREF < [M:DIA]ITMREFDEB OK=1 : Return : Endif
    If [M:DIA]ITMREFFIN <> "" & [F:SOP]ITMREF > [M:DIA]ITMREFDEB OK=1 : Return : Endif
Endif

# --> Non gťrť en stock et non composť ou composant de kit
If [F:SOQ]STOMGTCOD = 1 & !(find([F:SOP]LINTYP, 2,3,4,5,10,11,12,13)) OK=1: Return : Endif

#----------------------------------------------------------------------------#
# Point d'entree pour rajouter des filtres sur les enregistrements ŗ traiter #
#----------------------------------------------------------------------------#
GPOINT="AUTALLSEL" : Gosub ENTREE From EXEFNC

If find([F:SOP]LINTYP,3,4,5,11,12,13) & WALLKIT=1
    WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(99,197,1)-":"-[F:SOH]BPCORD-WBPCNAM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
Endif

Return

#-----------------------------------------------------------------------#
# Traitement d'une allocation                                           #
#-----------------------------------------------------------------------#
$TRTALL
# lecture des parametres
    WALLSTU=0
#   Calcul de la qtť ŗ allouer si Trt des qtťs allouťes
    If WFLGALL = 2
#       --> Qtť ŗ allouer = Qtť commandťe - le total allouť - rupture
        WALLSTU = [F:SOQ]QTYSTU - WTALLSTU - WSHTSTU
        #---------------------------------------------------------------------#
        # Point d'entree modification de la quantitť ŗ allouer                #
        #---------------------------------------------------------------------#
        GPOINT="MODQTEALL" : Gosub ENTREE From EXEFNC
    Endif
    If WALLSTU + WSHTSTU <> 0
        Call DEBTRANS From GLOCK
        Gosub MAJALL
    Endif
Return
#-----------------------------------------------------------------------#
# Mise ŗ jour des allocations                                           #
#-----------------------------------------------------------------------#
$MAJALL
Local Char    WTRTORD
Local Decimal WCPLQTY

GOK=1
Trbegin [SOH],[SOQ],[SOP]
#       Articles gťrťs en stock               : Allocation et maj de la cde
#       Kits et composants non gťrťs en stock : Juste alimentation de la qtť allouťe ds la cde
        If [F:SOQ]STOMGTCOD <> 1
#           Allocation partielle toujours autorisťe
#           Sauf si non cochťe ds l'ťcran et livraison.ligne/cde complŤte et ce n'est pas un kit/sous-traitť
#           Un kit et ses composants ne peuvent Ítre allouťs partiellement (sinon dťphasage possible)
            WALLPAR=0
            If [M:DIA]ALLPAR=1 & find([F:SOH]DME,2,3) & !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) WALLPAR=1 : Endif
#           Gťnťration des ruptures
#           Si cochťe ŗ l'ťcran ou kit
#           On gťnŤre toujours les ruptures sur un kit/sous-traitť et ses composants (sinon dťphasage possible)
            WGENSHT=[M:DIA]GENSHT
            If find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) WGENSHT=2 Endif
#           Gťnťration de l'allocation
            Call GENALLORD("","",WTRTLIG, [M:DIA]IMPCLI, WGENSHT, WALLPAR, WALLSTU, WSHTSTU, WRET) From TRTVENALL
            If WRET = 2 & GOK=1
                Call ECR_TRACE(WMESS,0) From GESECRAN
                Call ECR_TRACE(mess(103,197,1)-":"-mess(105,197,1)-":"-mess(367,199,1), 0) From GESECRAN
                GOK=0: Goto AB2_TRTALL
            Elsif WRET <> 0
                Call ECR_TRACE(WMESS,0) From GESECRAN
                Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
                GOK=0: Goto AB_TRTALL
            Endif
        Endif

        WALL=WALLSTU*(1/[F:SOP]SAUSTUCOE)
        Call QTEARR(WALL, [F:SOP]SAU) From TRTDIV
        WSHT=WSHTSTU*(1/[F:SOP]SAUSTUCOE)
        Call QTEARR(WSHT, [F:SOP]SAU) From TRTDIV
#
        WALLSTU= [F:SOQ]ALLQTYSTU + WALLSTU
#       Mise ŗ jour commande
        Call MAJALLORD([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ALLTYP, 1, WALLSTU, WSHTSTU, WRET) From TRTVENALL
        If WRET <> 0 : GOK = 0 : Goto AB_TRTALL : Endif
#       Alimentation de la trace
        Call ECR_TRACE(WMESS,0) From GESECRAN : Raz WMESS
        If find([F:SOP]LINTYP,2,10) WALLKIT=2 : WMESS=mess([F:SOP]LINTYP,423,1) Endif
        If [F:SOQ]STOMGTCOD=1 WMESS-=mess(283,197,1) Endif
        If WMESS <>"" Call ECR_TRACE("  "+WMESS,0) From GESECRAN Endif
        If [F:SOQ]STOMGTCOD<>1
            WMESS1 = mess(106,197,1)+":"+format$("N:15F", WALL)-[F:SOP]SAU
            WMESS2 = mess(107,197,1)+":"+format$("N:15F", WSHT)-[F:SOP]SAU
            Call ECR_TRACE("  "+mess(479,197,1)-WMESS1-WMESS2,0) From GESECRAN
        Endif
        If [F:SOH]SOHCAT = 3 WCPLQTY = [F:SOQ]INVQTYSTU Else WCPLQTY = [F:SOQ]DLVQTYSTU : Endif
        WALLSTA=1
        If [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+WCPLQTY>=[F:SOQ]QTYSTU & [F:SOQ]SHTQTYSTU=0
            WALLSTA = 3
        Elsif sum([F:SOQ]ALLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<> 0
            WALLSTA = 2
        Endif
        WMESS1 = mess(480,197,1)-format$("N:15F", [F:SOQ]QTY)-[F:SOP]SAU
        WMESS2 = mess(481,197,1)-format$("N:15F", [F:SOQ]ALLQTY)
        WMESS3 = mess(66,191,1)-":"-format$("N:15F", [F:SOQ]SHTQTY)
        Call ECR_TRACE("  "+mess(18,197,1)-format$("K:15X", mess(WALLSTA,416,1))+"=>"-WMESS1-WMESS2-WMESS3,0) From GESECRAN
        NBALL += 1
Commit
Return

# --------------------------------------
# FGR 26/08/2015 : X3SUIVI110559 (dťbut)
#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entÍte commande                      #
#-----------------------------------------------------------------------#
$VERROU
  If [F:SOH]SOHCAT<>4
    SVOPTIMSYMBOLE = "SOH"+[F:SOH]SOHNUM
  Else
    # Lock fichier commande ouverte
    SVOPTIMSYMBOLE = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOQ]SOHNUM
  Endif
  If SYMBOLE <> SVOPTIMSYMBOLE Then
    # Le changement c'est maintenant
    Gosub DEVERROU
    SYMBOLE = SVOPTIMSYMBOLE
    Gosub SET_LOCK
  Else
    OK = 2
  Endif
Return

$SET_LOCK
  Lock =SYMBOLE With lockwait = 0
  OK = 2
  If fstat
    # Issue 117638 - 2016-07-27 by CPO : Order locked having multiple lines (lock error during first line but not for following line, if any)
    #Call ECR_TRACE([F:SOH]SOHNUM - mess(10,100,1),1) From GESECRAN
    If PREVLOCKERRSYMBOLE<>SYMBOLE
      Call ECR_TRACE([F:SOH]SOHNUM - mess(10,100,1),1) From GESECRAN
      PREVLOCKERRSYMBOLE = SYMBOLE
    Endif
    Raz SYMBOLE
    # End issue 117638
    OK=1
  Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entÍte commande                           #
#-----------------------------------------------------------------------#
$DEVERROU
  If SYMBOLE <> "" Then
    Unlock =SYMBOLE
    Raz SYMBOLE
  Endif
Return

#$VERROU
##VPO 18/05/09 54861 pb lock cde ouverte
#If [F:SOH]SOHCAT<>4
#    SYMBOLE = "SOH"+[F:SOH]SOHNUM
#Else
#    # Lock fichier commande ouverte
#    SYMBOLE = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOQ]SOHNUM
#Endif
#Lock = SYMBOLE With lockwait = 0
#OK=2
#If fstat
#    Call ECR_TRACE([F:SOH]SOHNUM - mess(10,100,1),1) From GESECRAN
#    OK=1
#Endif
#Return
#
#$DEVERROU
#Unlock=SYMBOLE
#Return
# FGR 26/08/2015 : X3SUIVI110559 (fin)
# --------------------------------------

$ROL_TRTALL
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
     GOK=1  : # FGR 10/11/2009 : X3SUIVI58258
Else Goto MAJALL :Endif
Return

$AB_TRTALL
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
GOK=1  : # FGR 10/11/2009 : X3SUIVI58258
Return

$AB2_TRTALL
Rollback
GOK=1  : # FGR 10/11/2009 : X3SUIVI58258
Return
#######################################################################
#                     ETIQUETTES                                      #
#######################################################################
$LEC_ITM
If [F:ITM]ITMREF <> [F:SOQ]ITMREF
    Read [ITM]ITM0=[F:SOQ]ITMREF
    If fstat Raz [F:ITM] :Endif
Endif
Return
$LEC_ITF
If [F:ITF]ITMREF <> [F:SOQ]ITMREF | [F:ITF]STOFCY <> [F:SOQ]STOFCY
    Read [ITF]ITF0=[F:SOQ]ITMREF;[F:SOQ]STOFCY
    If fstat Raz [F:ITF] :Endif
Endif
Return
#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
# --------------------------------------- STOFCY ---------------------------------
########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# --> Rťcupťration du paramŤtre stock : GENSHT    : Gťnťration des ruptures
Local Char     WPARAM(10)
Call PARAML(VALEUR,"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT= val(WPARAM)
[M:DIA]GENSHT = GGENSHT
# --> Rťcupťration du paramŤtre vente : USERERBPC : Consommation rťservations clients
Local Char     WPARAM(10)
Call PARAML(VALEUR,"USERERBPC",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GUSERERBPC= val(WPARAM)
[M:DIA]IMPCLI = GUSERERBPC
If GUSERERBPC=3 [M:DIA]IMPCLI=2 : Endif
Affzo [M:DIA]GENSHT
Affzo [M:DIA]IMPCLI
End
########################################
# --------------------------------------- DRNFLG ---------------------------------
Subprog AP_DRNFLG(VALEUR)     : # Web - Faible - Synchrone
Variable Integer VALEUR
If VALEUR = 1
    [M:DIA]DRN = 0
Endif
If VALEUR = 2 & [M:DIA]DRN = 0
    [M:DIA]DRN = 1
    Affzo [M:DIA]DRN
Endif
If VALEUR <> 2 Grizo [M:DIA]DRN Else Actzo [M:DIA]DRN : Endif
End
########################################
# --------------------------------------- DRN ---------------------------------
Subprog C_DRN(VALEUR)         : # Web - Faible - Synchrone
Variable Integer VALEUR
If [M:DIA]DRNFLG = 1 & VALEUR <> 0 mkstat =2 : Endif
If [M:DIA]DRNFLG = 2 & VALEUR  = 0 mkstat =2 : Endif
End
########################################
# ----------------------------------- DLVPIODEB ---------------------------------
Subprog AM_DLVPIODEB(VALEUR)    : # Web - Faible - Synchrone
Variable Integer VALEUR
[M:DIA]DLVPIOFIN = VALEUR : Affzo [M:DIA]DLVPIOFIN
End
########################################
# ----------------------------------- DLVPIOFIN  ---------------------------------
Subprog C_DLVPIOFIN(VALEUR)    : # Web - Faible - Synchrone
Variable Integer VALEUR
If VALEUR < [M:DIA]DLVPIODEB GMESSAGE= mess(44,199,1) : mkstat=2:Endif
End
########################################
# ----------------------------------- SOHNUMDEB ---------------------------------
Subprog AM_SOHNUMDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]SOHNUMFIN = VALEUR : Affzo [M:DIA]SOHNUMFIN : Endif
End
########################################
# ----------------------------------- BPCCORDEB ---------------------------------
Subprog AM_BPCORDDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCORDFIN = VALEUR : Affzo [M:DIA]BPCORDFIN :Endif
End
########################################
# ----------------------------------- BPAADDDEB ---------------------------------
Subprog AS_BPAADDDEB(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]BPCORDDEB = "" mkstat=2 Endif
End
########################################
Subprog AM_BPAADDDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPAADDFIN = VALEUR : Affzo [M:DIA]BPAADDFIN : Endif
End
########################################
# ----------------------------------- BPAADDFIN ---------------------------------
Subprog AS_BPAADDFIN(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]BPCORDFIN = "" mkstat=2 Endif
End
########################################
Subprog C_BPAADDFIN(VALEUR)
Variable Char    VALEUR()
If  [M:DIA]BPCORDDEB = [M:DIA]BPCORDFIN
    If VALEUR < [M:DIA]BPAADDDEB GMESSAGE= mess(44,199,1) : mkstat=2:Endif
Endif
End
########################################
# ----------------------------------- ITMREFDEB ---------------------------------
########################################
Subprog AM_ITMREFDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Affzo [M:DIA]ITMREFFIN : Endif
End
########################################
Subprog AS_ALLCRITENT(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTTABENT, XXCONV, XXVAR
[M]FILTTABENT="find(ABRFIC,'SOH')"
End
########################################
Subprog AS_ALLCRITDET(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTTABDET, XXCONV, XXVAR
[M]FILTTABDET="find(ABRFIC,'SOQ')"
For I=0 To dim([F:SOP]TSICOD)-1
    [M]XXVAR(I)="WTSICOD("+num$(I)+"),Famille statistique"+num$(I+1)
Next
End
########################################
Subprog AM_ALLCRITDET(VALEUR)
Variable Char    VALEUR()

Local Char    WCRITDET(150), WCRITTSI(250), WCRITRES(250)
Local Char    WCRIT(250), WCRITVAL(250)
Local Integer W,I,J,K1,K2

#WCRITERE='XXXX & WTSICOD(0)="A" & YYYY & WTSICOD(1)="B"'
I=1
WCRITDET=toupper(VALEUR)
If instr(I,WCRITDET, "WTSICOD")
    I=1
    WCRITRES="("
    Repeat
    W=instr(I,WCRITDET, "WTSICOD")
    If W<>0
        J=W
        WCRIT=seg$(WCRITDET,I,J-1)
        K1 = instr(1+J+6,WCRITDET,'"')
        WCRITVAL=seg$(WCRITDET,1+J+6,K1)
        K2 = instr(K1+1,WCRITDET,'"')
        WCRITVAL+=seg$(WCRITDET,K1+1,K2)
        WCRITTSI="([F:SOQ]SOHCAT<>4&[F:SOP]TSICOD"+WCRITVAL+")|("+"[F:SOQ]SOHCAT=4&[F:SOC]TSICOD"+WCRITVAL+")"
        WCRIT+=WCRITTSI
        WCRITRES+=WCRIT
        I=K2+1
    Endif
    Until W = 0
    WCRITRES+=")"

    WCRIT=right$(WCRITDET,I)
    WCRITRES+=WCRIT

#    Infbox WCRITRES
#    Infbox num$(len(VALEUR))
#    Infbox num$(len(WCRITRES))

    If len(WCRITRES)> 250 mkstat=2 : GMESSAGE=mess(4,159,1) : End : Endif
    [M]CALCRITDET=WCRITRES
Else
    [M]CALCRITDET=VALEUR
Endif
End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
