End


######################################################################################
######################################################################################
## DespuÈs de modificar el campo 'Cod. tienda' (pantalla BPABPC) 24/11/2022 10:45:06 (ADMIN)
######################################################################################
Subprog AM_XZCODTIENDA(VALEUR)
Variable Char    VALEUR()
# 06.404.009.ini
  [M:BPAC]ZCODTIENDA([M:BPAC]XNUMLIG) = VALEUR
  [M:BPAC]FLMOD([M:BPAC]XNUMLIG)      = 1
# 06.404.009.fin
End

######################################################################################
## Antes de entrada al campo NBADR (par·metro tabla direcciones) (pantalla BPABPC) 24/11/2022 11:02:42 (ADMIN)
######################################################################################
Subprog AS_NBADR
# 06.404.009.ini
  [M:BPAC]XZCODTIENDA  = [M:BPAC]ZCODTIENDA(nolign-1)
  Affzo [M:BPAC]XZCODTIENDA
# 06.404.009.fin
End
