#<AdxTL>@(#)0.0.0.0 $Revision$ 
#CALCULO BASE ELEMENTO PIE DTO PP

$ACTION
Case ACTION
  When "CALPIEDHT"     :   Gosub CALPIEDHT
Endcase
Return

$CALPIEDHT
Local Decimal WBASE

#If JL=7 & [M:SIHV]XFDTAAMT(7)<>0 Then
#  #WBASE = WMNTCLCBAS+[M:SIHV]XFNOT(0)+[M:SIHV]XFNOT(1)+[M:SIHV]XFNOT(2)+[M:SIHV]XFNOT(3)+[M:SIHV]XFNOT(4)+[M:SIHV]XFNOT(5)+[M:SIHV]XFNOT(6)
#  WBASE = TVASMIP + [M:SIHV]XFNOT(0)+[M:SIHV]XFNOT(1)+[M:SIHV]XFNOT(2)+[M:SIHV]XFNOT(3)+[M:SIHV]XFNOT(4)+[M:SIHV]XFNOT(5)+[M:SIHV]XFNOT(6)
#  ZFNOTP=arr( (WBASE * [M:SIHV]XFDTAAMT(7) / 100) ,0.01)
#Endif

If JL=8 & [M:SIHV]XFDTAAMT(8)<>0 Then
  WBASE = TVASMIP + [M:SIHV]XFNOT(0)+[M:SIHV]XFNOT(1)+[M:SIHV]XFNOT(2)+[M:SIHV]XFNOT(3)+[M:SIHV]XFNOT(4)+[M:SIHV]XFNOT(5)+[M:SIHV]XFNOT(6)+[M:SIHV]XFNOT(7)
  ZFNOTP=arr( (WBASE * [M:SIHV]XFDTAAMT(8) / 100) ,0.01)
Endif

If JL=1 & [M:SIHV]XFDTAAMT(1)<>0 Then
  #WBASE = WMNTCLCBAS+[M:SIHV]XFNOT(0)
  WBASE = TVASMIP + [M:SIHV]XFNOT(0)
  ZFNOTP=arr( (WBASE * [M:SIHV]XFDTAAMT(1) / 100) ,0.01)
Endif

Return

