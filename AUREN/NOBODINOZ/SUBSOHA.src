#------------------------------------------------------------------------#
# Affichage entÍtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & GFLAG<>"" & dim([M:SOH4]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WK2"+GFLAG+"4"
  #----- Pour forcer l'utilisation des formats ťvaluťs si tableau vide -----#
  # Affzo nťcessaire si sections invisibles pour faire disparaitre les colonnes
  If [M:SOH4]NBLIG=0
    [M:SOH4]NBLIG=1 : Affzo [SOH4]5 : Effzo [SOH4]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

