Endif
# Bug 57682

#85785 * RMA * document amount cannot be negative
If func PORLEGLIB.DIGSIGN("", [F:SOH]CPY) & ([F:SOH]ORDINVATI<0 | [F:SOH]ORDINVATIL<0)
  GERR = 1: GMESSAGE = mess(00216,00191,1) : GOK = 0 : Return
