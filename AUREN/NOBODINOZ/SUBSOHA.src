# 76907
##############################################################################################
#    Suppression des boutons                                                                 #
#    Vťrification des qtťs prťparťes/livrťes pour suppression boutons allocation/prťparation #
##############################################################################################
$SETB_VERIF_QTY
Local Integer WI

# 100013 : Une ligne sur liste de prťpa peut ‚tre allouťe mais pas prťparťe
#WALL_PRE_STA=0 : # Par dťfaut, les boutons Allocation/Prťparation sont inactifs
WALL_STA=0 : # Par dťfaut, le bouton Allocation  est inactif
WPRE_STA=0 : # Par dťfaut, le bouton Prťparation est inactif
# 100013

# 107888 : Scheduled invoices : (LD:01/06/16)
WLIV_STA=0 : # Par dťfaut, le bouton Livraison   est inactif
# 107888 : Scheduled invoices : (LD:01/06/16)

For WI=0 To [M]NBLIG-1
  #If [M:SOH4]STOMGTCOD(WI)>1 & [M:SOH4]SOQSTA(WI)<>3

 # 107888 : Scheduled invoices : (LD:19/05/16)
 # Seules les lignes livrables peuvent Ítre allouťes/prťparťes
  #If [M:SOH4]SOQSTA(WI)<>3
  If [M:SOH4]SOQSTA(WI)<>3 & [M:SOH4]DLVFLG(WI)=2
 # 107888 : Scheduled invoices : (LD:19/05/16)

# 100013 : Une ligne sur liste de prťpa peut ‚tre allouťe mais pas prťparťe
#    # DŤs qu'on trouve une ligne qui est encore ŗ allouer ou ŗ prťparer, on active les boutons
#    If sum([M:SOH4]LPRQTY(WI),[M:SOH4]OPRQTY(WI),[M:SOH4]PREQTY(WI),[M:SOH4]ODLQTY(WI),[M:SOH4]DLVQTY(WI))<[M:SOH4]QTY(WI)
#      WALL_PRE_STA=1 : Break
#    Endif
    # DŤs qu'on trouve une ligne qui est encore ŗ allouer, on active le bouton
    If sum([M:SOH4]OPRQTY(WI),[M:SOH4]PREQTY(WI),[M:SOH4]ODLQTY(WI),[M:SOH4]DLVQTY(WI))<[M:SOH4]QTY(WI)
      WALL_STA=1
    Endif
    # DŤs qu'on trouve une ligne qui est encore ŗ prťparťe, on active le bouton
    If sum([M:SOH4]LPRQTY(WI),[M:SOH4]OPRQTY(WI),[M:SOH4]PREQTY(WI),[M:SOH4]ODLQTY(WI),[M:SOH4]DLVQTY(WI))<[M:SOH4]QTY(WI)
      WPRE_STA=1
    Endif
    # 107888 : Scheduled invoices : (LD:01/06/16)
    # DŤs qu'on trouve une ligne qui est encore ŗ livrer, on active le bouton
    If sum([M:SOH4]ODLQTY(WI),[M:SOH4]DLVQTY(WI))<[M:SOH4]QTY(WI)
      WLIV_STA=1
    Endif
    #If WALL_STA=1 & WPRE_STA=1 Break Endif
    If WALL_STA=1 & WPRE_STA=1 & WLIV_STA=1 Break Endif
    # 107888 : Scheduled invoices : (LD:01/06/16)
# 100013
  Endif
Next

Return
