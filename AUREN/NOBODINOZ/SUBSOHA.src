  #If dim([M:ADB2]ADBFLG) [M:ADB2]ADBFLG=2 Endif       : # Bug 78821
  #If dim([M:ADB3]ADBFLG) [M:ADB3]ADBFLG=2 Endif       : # Bug 78821
