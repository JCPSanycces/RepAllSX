#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAM ZMGIMPB2B: IMPORTACION PEDIDOS B2B MAGENTO                                                   ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 18/06/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 00.000.000                                                                    ##
## OBJETIVO: DESCARGA VIA FTP LOS FICGEROS DE PEDIDOS B2  PARA SER IMPORTADOS EN SAGE X3, ADECUANDO     ##
##           EL FORMATO DEL FICHERO                                                                     ##
##########################################################################################################
#001 FPH-AUREN-25/03/2021 - 6.171.123 - Prioridad para asignaciones de stock sobre clientes
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I
  Local Integer NUMLINES

  Local Char LIN(6)                             #Line Code
  Local Char ORDERNUM(!5)                       #Order number
  Local Char CLIENTORDER(15)                    #Client code
  Local Char ORDERDATE(10)                      #Order date
  Local Char DELDATE(10)                        #Delivery sate
  Local Char SKU(13)                            #Item SKU
  Local Char QTY(10)                            #Quantity
  Local Char DELCOST(10)                        #Delivery cost
  Local Char PAYTIPE(3)                         #Payment type
  Local Char PARTIAL(2)                         #Partial delivery allowed

  Local Char UNDEFINED(1)
  #001>
  If !clalev([F:ZBPC1]) : Local File BPCUSTOMER   [F:ZBPC1] : Endif
  If !clalev([F:ZBPD1]) : Local File BPDLVCUST    [F:ZBPD1] : Endif
  #001<

  Call ECR_TRACE("Iniciando importaciˇn Pedidos B2B Magento",0) From GESECRAN

  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Magento\PedidosB2B"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  ORDRE = "MOVE *.pro "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
  ORDRE = "MOVE *.err "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

Return

$EXEC

  Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  #06.306.278 : Incidencia Integraciˇn SAGE X3 / MAGENTO
  #auren inicio 01/02/2022
  #nos comentan que la direcciˇn ip es diferente
  #Call FTPGETDEL("178.255.225.113","ftpnobo_impERP","MVLsWTLqXyAze@","pedidos_base",DIRFTP,RES) From ZAURFTP
  #hablado con Yasmina, modificado hasta que Magento solucione el problema de conexiˇn (antes .113)
  Call FTPGETDEL("178.255.225.76","ftpnobo_impERP","MVLsWTLqXyAze@","pedidos_base",DIRFTP,RES) From ZAURFTP
  #auren fin

  If RES < 0

    Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN

  Else

    Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN

  Endif

  #Process the dodnloaded files

  ORDRE = "dir /b "+DIRFTP+"\*.txt 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros",0) From GESECRAN

    For I = 1 To RES

      FILNAME = DIRFTP+"\"+left$(FILELIST(I),len(FILELIST(I))-4)

      Openi FILNAME+".txt", 0 Using [FIN]                               # Received file with orders
      Iomode adxifs chr$(9) Using [FIN]                                 # Separador de campo tab
      Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro CR+LF
      Iomode adxium 0 Using [FIN]                                       # UTF-8 file

      Openo FILNAME+"SO.pro", 0 Using [FSOO]                            # File for orders import
      Iomode adxifs ";" Using [FSOO]                                    # Separador de campo ";"
      Iomode adxirs chr$(13)+chr$(10) Using [FSOO]                      # Separador de registro CR + LF
      Iomode adxium 0 Using [FSOO]                                      # UTF-8 file

      #Get the first order line
        Rdseq LIN,ORDERNUM,CLIENTORDER,ORDERDATE,DELDATE,SKU,QTY,DELCOST,PAYTIPE,PARTIAL Using [FIN]
        Rdseq UNDEFINED Using [FIN]

      If fstat <> 0

        Openi Using [FIN]
        Openo Using [FSOO]
        Call ECR_TRACE("Error en el formato de fichero "+LFILES(I)+". Fin de fichero inesperado",1) From GESECRAN

      Else

        NUMLINES = 0

        #Get the orders lines

        While fstat <> 1

          If LIN <> "PEDC1"

            Call ECR_TRACE("Error en el formato de fichero "+LFILES(I)+". LÝnea tipo pedido no encontrada",1) From GESECRAN
            Break

          Endif

          NUMLINES+=1

          DELDATE =  mid$(DELDATE,7,4)+mid$(DELDATE,4,2)+left$(DELDATE,2)

          If NUMLINES = 1

            ORDERDATE =  mid$(ORDERDATE,7,4)+mid$(ORDERDATE,4,2)+left$(ORDERDATE,2)
            #001>
            If PAYTIPE = "TPV" Then
               PAYTIPE = "3"
            Else

#               PAYTIPE = "1"
               Read [F:ZBPC1]BPC0 = CLIENTORDER
               If !fstat Then
                 Read [F:ZBPD1]BPD0 =  [F:ZBPC1]BPCNUM; [F:ZBPC1]BPDADD
                 If !fstat Then
                   PAYTIPE = num$([F:ZBPD1]DLVPIO)
                 Endif
               Endif

            Endif
            #001<
            If PARTIAL = "SI" : PARTIAL = "1" : Else PARTIAL = "3" : Endif

            Wrseq "E","090","ORD10","ORD10-"+ORDERNUM,CLIENTORDER,ORDERDATE,DELDATE,DELCOST,"900",PAYTIPE,PARTIAL Using [FSOO]

          Endif

          Wrseq "L",SKU,QTY,DELDATE Using [FSOO]

          Rdseq LIN,ORDERNUM,CLIENTORDER,ORDERDATE,DELDATE,SKU,QTY,DELCOST,PAYTIPE,PARTIAL Using [FIN]
          Rdseq UNDEFINED Using [FIN]

        Wend

        Call ECR_TRACE("Tratado el pedido "+ORDERNUM+" con lineas: "+num$(NUMLINES),0) From GESECRAN

        Openo Using [FSOO]
        Openi Using [FIN]

        Call IMPORTSIL("ZSOHMGTOB",FILNAME+"SO.pro") From GIMPOBJ

        ORDRE = "MOVE "+FILNAME+".txt "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"SO.pro "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
        ORDRE = "MOVE "+FILNAME+"SO.pro.err "+DIRPRO
        Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

      Endif

    Next I

  Call ECR_TRACE("Fin del procesado de ficheros. Ficheros procesados: "+num$(I-1),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
