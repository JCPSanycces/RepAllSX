#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Modificación de representantes de entregas en base a representantes de la ficha de clientes


If !clalev([F:ZBPC1]) : Local File BPCUSTOMER    [F:ZBPC1] : Endif
If !clalev([F:ZSDH1]) : Local File SDELIVERY     [F:ZSDH1] : Endif
If !clalev([F:ZSDD1]) : Local File SDELIVERYD    [F:ZSDD1] : Endif
Local Integer ZCONTCAB,ZCONTLIN : Raz ZCONTCAB,ZCONTLIN

For [F:ZBPC1]BPC0
  For [F:ZSDH1]SDH0 Where BPCORD = [F:ZBPC1]BPCNUM
     [F:ZSDH1]REP(0) = [F:ZBPC1]REP(0)
     [F:ZSDH1]REP(1) = [F:ZBPC1]REP(1)
     Rewrite [F:ZSDH1]
     ZCONTCAB+=1
     For [F:ZSDD1]SDD0 Where SDHNUM = [F:ZSDH1]SDHNUM
       [F:ZSDD1]REP1 = [F:ZBPC1]REP(0)
       [F:ZSDD1]REP2 = [F:ZBPC1]REP(1)
       Rewrite [F:ZSDD1]
       ZCONTLIN+=1
     Next
  Next
Next
Infbox "ENTREGAS MODIFICADAS"-num$(ZCONTCAB)-"- LÍNEAS MODIFICADAS"-num$(ZCONTLIN)
End
