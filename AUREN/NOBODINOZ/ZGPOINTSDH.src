# 06.319.491 - JC.01042022.Tarifas transporte Sage X3
###########################################################################################

$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "CALPORT"          : Gosub CALPORT                                 # 06.319.491.new (punto de entrada en SUBSDHA)
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CALPORT

# 06.319.491.ini
Local Integer LCON,LCONTROL

  Local Mask [M:SDH1]
  If !clalev([F:ZSOH]) Then : Local File SORDER     [F:ZSOH] : Endif
  For LCON=0 To [M:SDH1]NBLIG-1
    Read [F:ZSOH]SOH0 = [M:SDH1]XSOHNUM(LCON)
    If !fstat Then
      If [F:ZSOH]INVDTAAMT(0) <> 0 or [F:ZSOH]INVDTAAMT(1) <> 0 Then
        LCONTROL = 1
      Endif
    Endif
  Next
  If LCONTROL <> 0 and OK <> 2 Then
    WPOINT_ENTREE = 1
    STAT = 1
  Else
    WPOINT_ENTREE = 1
    If [M:SDH2]BPTNUM <> ""
      Call TRANSPORT([M:SDH2]BPTNUM,[M:SDH0]BPCORD,[M:SDH0]STOFCY,WCRY,WCTY,WPOSCOD,
&                    [M:SDH1]CUR,[M:SDH0]CHGTYP,date$,[M:SDH1]DLVNOT,[M:SDH2]WEU,
&                    [M:SDH2]GROWEI,[M:SDH2]VOU,[F:SDH]DSPTOTVOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                    From TRTPRICE
#If GUSER ="ADMIN" Then
#Infbox "Transportista:"-num$([M:SDH2]BPTNUM)
#Infbox "Cliente:"-num$([M:SDH0]BPCORD)
#Infbox "Planta:"-num$([M:SDH0]STOFCY)
#Infbox "Ciudad:"-num$(WCTY)
#Infbox "Cod.postal:"-num$(WPOSCOD)
#Infbox "Moneda:"-num$([M:SDH1]CUR)
#Infbox "Tipo cambio:"-num$([M:SDH0]CHGTYP)
#Infbox "Fecha:"-num$(date$)
#Infbox "Importe:"-num$([M:SDH1]DLVNOT)
#Infbox "Ud.peso:"-num$([M:SDH2]WEU)
#Infbox "Peso:"-num$([M:SDH2]GROWEI)
#Infbox "Ud.Volumen:"-num$([M:SDH2]VOU)
#Infbox "Volumen:"-num$([M:SDH2]ZVOLLIN)
#Infbox "País:"-num$(LBPTARE)
#Infbox "Precio portes:"-num$(LAMTFRE)
#Infbox num$(FRELIB)
#Infbox num$(STAT)
#Endif
      [M:SDH2]INVDTAAMT(WDACDLV-1)=LAMTFRE
      Affzo [M:SDH2]25
      STAT = 1
    Endif
  Endif
  Close Local File [ZSOH]
# 06.319.491.fin
Return

##############################################################
######################    ETIQUETAS    #######################
