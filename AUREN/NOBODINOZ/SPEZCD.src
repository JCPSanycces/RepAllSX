#<AdxTL>@(#)0.0.0.0 $Revision$ Color dependence
# GestiÛn de la m·scara ZCD (Especifico)

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla ZCD) 02/06/2020 10:56:57 (ADMIN)
######################################################################################
$ACTION
  Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "LIENS"      : Gosub LIENS
   When "SEL_TABLE"  : Gosub SEL_TABLE
   When "SETBOUT"    : Gosub  SETBOUT
   When Default
  Endcase
Return
############################################################################
$SETBOUT
  CHAINE += "A"
Return
############################################################################
$OUVRE
 If !clalev([F:ZITM1]) : Local File ITMMASTER [F:ZITM1] : Endif
 If !clalev([F:ZAXX1]) : Local File ATEXTRA   [F:ZAXX1] : Endif
 If !clalev([F:ZTCT1]) : Local File TABCTL    [F:ZTCT1] : Endif
Return
############################################################################
$LIENS
 Read [F:ZAXX1]AXX0 ='TABCTL';'TCTDESAXX';'SPA';[M:ZCD]ZTABLA;''
 [M:ZCD]ZDESTABLA =  [F:ZAXX1]TEXTE
 Read [F:ZTCT1]TCT1=[M:ZCD]ZTABLA;[M:ZCD]ZOPCION;0
 [M:ZCD]ZDESOPC = [F:ZTCT1]DESCOD

 Affzo [M:ZCD]ZDESOPC
 Affzo [M:ZCD]ZDESTABLA
Return
############################################################################

$SEL_TABLE
  Case COUZON
    When "ZTABLA"    : Gosub SEL_TABLA
    When "ZOPCION"   : Gosub SEL_OPCION
    When "ZAG"       : Gosub SEL_AG
    When "ZARTICULO" : Gosub SEL_ZARTICULO
  Endcase
Return

############################################################################
$SEL_TABLA
  OBJET = "TCT"
  START = "TCT"
Return
############################################################################
$SEL_OPCION
  OBJET = "ZTCT"

  CRITERE(1) += "TCT='"+ toupper([M:ZCD]ZTABLA)+"'"
  START = "ALPCOD"
Return
############################################################################
$SEL_AG
  OBJET = "ITM"
  CRITERE(1) += "ZARTGEN=2 | TCLCOD ='SS'"
  START = "ITMREF"
Return
############################################################################
$SEL_ZARTICULO
  Read [F:ZITM1]ITM0 = [M:ZCD]ZAG
  OBJET = "ZITM"
  CRITERE(1) += "ZARTGEN<>2 & (TCLCOD ='SS' | CFGFLDALP1 ='"+[F:ZITM1]CFGFLDALP1+"')"
  START = "ITMREF"
Return

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla ZCD) 02/06/2020 14:30:50 (ADMIN)
######################################################################################
Subprog AM_ZTABLA(VALEUR)
 Variable Char    VALEUR()

 Read [F:ZAXX1]AXX0 ='TABCTL';'TCTDESAXX';'SPA';VALEUR;''
 [M:ZCD]ZDESTABLA =  [F:ZAXX1]TEXTE
 Affzo [M:ZCD]ZDESTABLA
End
#####################################################################################
Subprog AM_ZOPCION(VALEUR)
 Variable Char    VALEUR()

 Read [F:ZTCT1]TCT1=[M:ZCD]ZTABLA;VALEUR;0
 [M:ZCD]ZDESOPC = [F:ZTCT1]DESCOD
 Affzo [M:ZCD]ZDESOPC
End

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla ZCD) 02/07/2020 16:12:14 (ADMIN)
######################################################################################
Subprog C_ZTABLA(VALEUR)
Variable Char    VALEUR()

 [M:ZCD]ZTABLA = toupper(VALEUR)
 Affzo [M:ZCD]ZTABLA
End


######################################################################################

