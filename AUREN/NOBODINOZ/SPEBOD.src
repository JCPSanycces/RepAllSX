################################################################
$ACTION
  Case ACTION
   When Default
  Endcase
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BOD3) 08/06/2020 14:00:50 (ADMIN)
######################################################################################
Subprog C_ZCOLDEP(VALEUR)
  Variable Char    VALEUR()
  If !clalev([F:ZITM1]) : Local File ITMMASTER   [F:ZITM1] : Endif
  Read [F:ZITM1]ITM0 = [M:BOD1]CPNITMREF (nolign-1)
  If !fstat and [F:ZITM1]TCLCOD <> 'SS' Then
    If [F:ZITM1]ZARTGEN = 2 and VALEUR = "" Then
      Call MESSAGE ("Color dependence obligatorio para artículos genéricos") From GESECRAN
      mkstat = 2
    Endif
    If [F:ZITM1]ZARTGEN <> 2 and VALEUR <> "" Then
      Call MESSAGE ("Color dependence no permitido para artículos no genéricos") From GESECRAN
      mkstat = 2
    Endif
  Endif
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BOD3) 08/06/2020 14:24:40 (ADMIN)
######################################################################################
Subprog AM_CPNITMREF(VALEUR)
  Variable Char    VALEUR()
  If !clalev([F:ZITM2]) : Local File ITMMASTER   [F:ZITM2] : Endif
  If !clalev([F:ZITM3]) : Local File ITMMASTER   [F:ZITM3] : Endif

  Read [F:ZITM2]ITM0 = [M:BOH0]ITMREF
  If [F:ZITM2]ZARTGEN <> 2 Then
     Read [F:ZITM3]ITM0 = VALEUR
     If [F:ZITM3]ZARTGEN = 2 Then
       Call MESSAGE ("Un artículo normal no puede tener en su composición uno genérico") From GESECRAN
       mkstat = 2
     Endif
  Endif
End


