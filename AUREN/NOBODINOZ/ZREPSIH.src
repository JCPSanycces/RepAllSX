#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Modificación de representantes de facturas en base a representantes de la ficha de clientes


If !clalev([F:ZBPC1]) : Local File BPCUSTOMER    [F:ZBPC1] : Endif
If !clalev([F:ZSIV1]) : Local File SINVOICEV     [F:ZSIV1] : Endif
If !clalev([F:ZSID1]) : Local File SINVOICED     [F:ZSID1] : Endif
Local Integer ZCONTCAB,ZCONTLIN : Raz ZCONTCAB,ZCONTLIN

For [F:ZBPC1]BPC0
  For [F:ZSIV1]SIV0 Where BPCINV = [F:ZBPC1]BPCNUM
     [F:ZSIV1]REP(0) = [F:ZBPC1]REP(0)
     [F:ZSIV1]REP(1) = [F:ZBPC1]REP(1)
     Rewrite [F:ZSIV1]
     ZCONTCAB+=1
     For [F:ZSID1]SID0 Where NUM = [F:ZSIV1]NUM
       [F:ZSID1]REP1 = [F:ZBPC1]REP(0)
       [F:ZSID1]REP2 = [F:ZBPC1]REP(1)
       Rewrite [F:ZSID1]
       ZCONTLIN+=1
     Next
  Next
Next
Infbox "FACTURAS MODIFICADAS"-num$(ZCONTCAB)-"- LÍNEAS MODIFICADAS"-num$(ZCONTLIN)
End
