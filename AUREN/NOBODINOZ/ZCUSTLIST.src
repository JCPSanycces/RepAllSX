#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog CUSTLIST(UPDDAYS,BPCNUM,BPCNAM,UPDDAT)
  Variable Integer UPDDAYS
  Variable Char BPCNUM  () ()
  Variable Char BPCNAM  () ()
  Variable Char UPDDAT ()

  Local File BPCUSTOMER [BPC]

  Local Integer LISTMAX : LISTMAZ = 100
  Local Integer I : I = 0

  Date UPDDATE : UPDDATE = date$-UPDDAYS

  Filter [F:BPC] Where UPDDAT >= [L]UPDDATE and  BPCTYP = 1 and OSTCTL <> 3
  For [F:BPC]
   [L]BPCNUM (I) = [F:BPC]BPCNUM
   [L]BPCNAM (I) = [F:BPC]BPCNAM
   [L]BPCNUM (I) = [F:BPC]BPCNUM
   I += 1
   If I >= LISTMAX : Break : Endif
  Next

  Close Local File [BPC]
End
