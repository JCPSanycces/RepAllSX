# 06.319.491 - JC.01042022.Tarifas transporte Sage X3
###########################################################################################

$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "CALPORT"          : Gosub CALPORT                                 # 06.319.491.new (punto de entrada en TRTVENLIV)
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CALPORT

# 06.319.491.ini
Local Integer LCONTROL

  If !clalev([F:ZSDD]) Then : Local File SDELIVERYD [F:ZSDD] : Endif
  If !clalev([F:ZSOH]) Then : Local File SORDER     [F:ZSOH] : Endif

  Filter [F:ZSDD] Where SDHNUM = [F:SDH]SDHNUM
  For [F:ZSDD]
    Read [F:ZSOH]SOH0 = [F:ZSDD]SOHNUM
    If !fstat Then
      If [F:ZSOH]INVDTAAMT(0) <> 0 or [F:ZSOH]INVDTAAMT(1) <> 0 Then
        LCONTROL = 1
      Endif
    Endif
  Next
  Filter [F:ZSDD]

  If LCONTROL <> 0 and OK = 2 Then
    WPOINT_ENTREE = 1
    STAT = 1
  Else
    WPOINT_ENTREE = 1
    If [F:SDH]BPTNUM <> ""
      Call TRANSPORT([F:SDH]BPTNUM,[F:SDH]BPCORD,[F:SDH]STOFCY,WCRY,WCTY,WPOSCOD,
&                    [F:SDH]CUR,[F:SDH]CHGTYP,date$,[F:SDH]DLVNOT,[F:SDH]WEU,
&                    [F:SDH]GROWEI,[F:SDH]VOU,[F:SDH]DSPTOTVOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                    From TRTPRICE
      [F:SDH]INVDTAAMT(WDACDLV-1) = LAMTFRE
      STAT = 1
    Endif
  Endif
  Close Local File [ZSOH]
# 06.319.491.fin
Return

##############################################################
######################    ETIQUETAS    #######################
