# Gestión de la máscara SOH3 (Especifico)
# 6.187.210 ML 11/09/2021 Interface Magento 2
######################################################################################
## AUREN - Control introducción elementos pie segun tipo importe AI / ii
######################################################################################
$ACTION
Case ACTION
    When "SEL_TABLE"  : Gosub SEL_TABLE
    When "VERF_TABLE" : Gosub VERF_TABLE
    When "APRES_MOD" : Gosub APRES_MOD
    When "APRES_CRE" : Gosub APRES_CRE
    When "AP_ANNULE"  :Gosub AP_ANNULE
    When Default
Endcase
Return

Subprog C_INVDTAAMT(VALEUR)
Variable Decimal VALEUR

If VALEUR < 0
  Call ERREUR("Importe negativo no permitido") From GESECRAN
  mkstat=2
Endif

If VALEUR<>0
  If [M:SOH1]PRITYP = 1
  # Precio AI
    If INVDTA(nolign-1)=3 or INVDTA(nolign-1)=5
      Call ERREUR("Elemento no permitido en pedidos AI") From GESECRAN
      mkstat=2
    Endif
  Else
  # Precio II
    If INVDTA(nolign-1)=2 or INVDTA(nolign-1)=2 or INVDTA(nolign-1)=4 or INVDTA(nolign-1)>5
      Call ERREUR("Elemento no permitido en pedido II") From GESECRAN
      mkstat=2
    Endif
  Endif
Endif

End

#######################################################################################
#######################################################################################
##AMG.STR 14/07/2021 desarrollo seleccionar dirección tienda para pedidos interplanta
$SEL_TABLE
Case TABLE
  When "ZSELDIRTIE" : Gosub SEL_ZSELDIRTIE
Endcase
Return

##############################################################
$VERF_TABLE
Case TABLE
  When "ZSELDIRTIE" : Gosub VERF_ZSELDIRTIE
Endcase
Return

$SEL_ZSELDIRTIE
  If !clalev([F:ZBPA]) Then : Local File BPADDRESS [ZBPA] : Endif
  Default File [ZBPA]

  Filter [ZBPA] Where BPANUM = [M:SOH0]BPCORD and BPATYP=1

  NBCOL = 0             # número de la columna
  TIT(NBCOL) = "Direcciones tienda" # título de la ventana
  NBCOL += 1
  TIT(NBCOL) = "Cód. dirección" # título de la segunda columna
  COL(NBCOL) = "BPAADD" # nombre del campo a mostrar en la segunda columna
  NBCOL += 1
  TIT(NBCOL) = "Descripción" # título de la primera columna
  COL(NBCOL) = "BPADES" # nombre del campo a mostrar en la primera columna
  NBCOL += 1
  TIT(NBCOL) = "Dirección" # título de la primera columna
  COL(NBCOL) = "BPAADDLIG" # nombre del campo a mostrar en la primera columna
Return

$VERF_ZSELDIRTIE
#Infbox [ZBPA]BPADES
Return

$APRES_MOD
  Gosub DIRECCION_TIENDA
Return
$APRES_CRE
  Gosub DIRECCION_TIENDA
Return

#################################################
$AP_ANNULE
# 6.187.210.ini
If !clalev([F:ZMG2DEL]) : Local File ZMG2DEL[ZMG2DEL]  : Endif
Raz [F:ZMG2DEL]
[F:ZMG2DEL]VCRNUM=[M:SOH0]SOHNUM
Write [F:ZMG2DEL]
# 6.187.210.fin
Return

##cuando se lanza APRES_MOD o APRES_CRE, actualizamos la dirección de entrega del pedido
$DIRECCION_TIENDA
If !clalev([F:ZBPAX]) Then : Local File BPADDRESS [ZBPAX] : Endif
If !clalev([F:ZSOH])  Then : Local File SORDER    [ZSOH]  : Endif
If [M:SOH1]ZDIRTIENDA<>"" Then
  Filter [ZBPAX] Where BPANUM = [M:SOH0]BPCORD and BPATYP=1 and BPAADD=[M:SOH1]ZDIRTIENDA
  Read [F:ZBPAX] First
  If !fstat Then
    Read [ZSOH]SOH0=[M:SOH0]SOHNUM
    If !fstat Then
      Trbegin [ZSOH]
      [ZSOH]BPDADDLIG(0)  = [ZBPAX]BPAADDLIG(0)
      [ZSOH]BPDADDLIG(1)  = [ZBPAX]BPAADDLIG(1)
      [ZSOH]BPDADDLIG(2)  = [ZBPAX]BPAADDLIG(2)
      [ZSOH]BPDPOSCOD     = [ZBPAX]POSCOD
      [ZSOH]BPDCTY        = [ZBPAX]CTY
      [ZSOH]BPDCRY        = [ZBPAX]CRY
      [ZSOH]BPDCRYNAM     = [ZBPAX]CRYNAM
      Rewrite[ZSOH]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Endif
Endif
  Close File [ZSOH],[ZBPAX]

Return



######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SOH1) 26/07/2021 23:04:10 (ADMIN)
######################################################################################
##control campo gris si no es interplanta
Subprog AV_ZDIRTIENDA(VALEUR)
Variable Char    VALEUR()
  #If [M:SOH0]SOHTYP <> "ORD40"
  #Infbox num$([M:SOH1]BETFCY)
  Affzo[M:SOH1]BETFCY
    If [M:SOH1]BETFCY = 1
    Grizo [M:SOH1]ZDIRTIENDA
  Else
    Actzo [M:SOH1]ZDIRTIENDA
  Endif
End

##control si no existe la dirección
Subprog C_ZDIRTIENDA(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ZBPAX]) Then : Local File BPADDRESS [ZBPAX] : Endif
If VALEUR<>""
  Filter [ZBPAX] Where BPANUM = [M:SOH0]BPCORD and BPATYP=1 and BPAADD=VALEUR
  Read [F:ZBPAX] First
  If !fstat Then

  Else
        mkstat = 2 :# bloqueamos el campo
        GMESSAGE = "Dirección inexistente para el cliente : "+[SOH]BPCNAM
  Endif
  Close File [ZBPAX]
Endif
End

