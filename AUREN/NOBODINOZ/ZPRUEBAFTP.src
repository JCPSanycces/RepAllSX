$ACTION
Case ACTION
  When "EXEC"     : Gosub EXEC
  When "TERMINE"  : Gosub TERMINE
Endcase
Return

$TERMINE

Return

$EXEC
Local Char ORDRE(255)
Local Integer STAT
Local Char LFILES(100)(1..)

  ORDRE = "E:\Sage\X3APL\folders\NBZPILOT\FTP\FtpGet.bat > E:\Sage\X3APL\folders\NBZPILOT\FTP\FtpGetLog.txt 2>&1"
  Call SYSTEME2(adxmac( 0),ORDRE,"",STAT,LFILES) From ORDSYS

Return

