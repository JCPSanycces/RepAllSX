#<AdxTL>@(#)0.0.0.0 $Revision$ 

################################################################
$ACTION
  Case ACTION
   When "DEBUT"      : Gosub DEBUT
   When "SEL_TABLE"  : Gosub SEL_TABLE
   When "BOUTON"     : Gosub BOUTON
   When "SETBOUT"    : Gosub SETBOUT
   When Default
  Endcase
Return
################################################################

$SETBOUT
 Local Integer I

 If [M:ZASG0]ZITMREF = "" Then
    Diszo [M:ZASG2]ZASIGNACION
    Diszo [M:ZASG2]ZFECHAEXP
 Else
    Actzo [M:ZASG2]ZASIGNACION
    Actzo [M:ZASG2]ZFECHAEXP
 Endif
 Affzo [M:ZASG2]
Return
################################################################
$SEL_TABLE
  Case COUZON
    When "ZITMREF" : Gosub SEL_ZARTICULO
  Endcase
Return
################################################################
$SEL_ZARTICULO
  OBJET = "ITM"
  CRITERE(1) += "STOMGTCOD = 2 & ITMSTA <> 6"
  START = "ITMREF"
Return
################################################################
$DEBUT
 [M:ZASG0]ZSTOFCY    ='900'
 [M:ZASG0]ZLOCTYP    ='098'
 [M:ZASG0]ZSTAORDFIR = 2
 [M:ZASG0]ZPRINORMAL = 2
 [M:ZASG0]ZPRIURG    = 2
 [M:ZASG0]ZPRIMURG   = 2
 [M:ZASG0]ZEPARAUT   = 2
 [M:ZASG0]ZEPLINCOM  = 2
 [M:ZASG0]ZEPPEDCOM  = 2
 Affzo [M:ZASG0]
 ACTION=""
Return
################################################################
$BOUTON

  Case BOUT
     When "1"  :  Local Char VALBOUT(250), PARBOUT(250)(1..20)
                  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OZCRITASIG","SPEZCASG","SPEZCASG") From GSAISIE

     When "2"  :  Call BUSCAR()

     When "4"  : If !clalev([F:ZSOH2])  : Local File SORDER    [F:ZSOH2] : Endif
                 If !clalev([F:ZSOQ2])  : Local File SORDERQ   [F:ZSOQ2] : Endif
                 If !clalev([F:ZTASG2]) : Local File ZTMPASIG [F:ZTASG2] : Endif

                 If !clalev([F:ZITF2]) : Local File ITMFACILIT [F:ZITF2] : Endif
                 Local Decimal ZDISPTEMP,ZASIGN,ZPEND,ZASIGSTD,ZQTYTEMP: Raz ZDISPTEMP,ZASIGN,ZPEND,ZASIGSTD,ZQTYTEMP

                 Local Integer I,J,YN : YN = 1
                 For I=0 To [M:ZASG2]NBLIG - 1
                     If [M:ZASG2]ZASIGNACION (I) <  0 Then
                       Call MESSAGE("No se permiten asiganciones negativas")From GESECRAN
                       Return
                     Endif
                  Next
                  If (func ACTUALIZAR <> 2)  Then
                    Call MESSAGE("No hay datos a actualizar") From GESECRAN
                    Return
                  Else
                    Call OUINON("El cambio no podrá deshacerse. żDesea actualizar los datos?",YN) From GESECRAN
                    If (YN = 2) Then
                        If func CONTROL_STOCK([M:ZASG0]ZSTOFCY,[M:ZASG2]ZITMREF(0)) = 1 Then
                          Call MESSAGE("No hay suficiente stock.Actualización cancelada")From GESECRAN
                          Return
                        Else
                          #Actualización stock
                          Delete  [F:ZTASG2] Where ZUSER = GUSER
                          For I=0 To [M:ZASG2]NBLIG - 1
                            If [M:ZASG2]ZASIGNACION  (I) <> [M:ZASG2]ZALLQTY (I) Then

                              [F:ZTASG2]ZUSER   = GUSER
                              [F:ZTASG2]ZSTOFCY = [M:ZASG0]ZSTOFCY
                              [F:ZTASG2]ZSOHNUM = [M:ZASG2]ZSOHNUM (I)

                             # [F:ZTASG2]ZTIPO =
                              [F:ZTASG2]ZSOPLIN = [M:ZASG2]ZSOPLIN (I)
                              [F:ZTASG2]ZITMREF = [M:ZASG2]ZITMREF (I)
                              [F:ZTASG2]ZDIFQTY = [M:ZASG2]ZALLQTY (I) - [M:ZASG2]ZASIGNACION  (I)
                              [F:ZTASG2]ZQTY    = [M:ZASG2]ZASIGNACION  (I)
                              Write  [F:ZTASG2]
                            Endif
                          Next

                          Filter [F:ZTASG2] Where ZUSER = GUSER
                          For [F:ZTASG2]ZTASG0

                             Call ASIGNAR_PEDIDO([F:ZTASG2]ZSTOFCY,[F:ZTASG2]ZSOHNUM,[F:ZTASG2]ZSOPLIN,[F:ZTASG2]ZITMREF,[F:ZTASG2]ZQTY) From ZCARGAPED
                          Next
                        Endif

                        #Actualización fechas
                        For I=0 To [M:ZASG2]NBLIG - 1
                           If [M:ZASG2]ZFECHAEXP (I) <> [M:ZASG2]ZSHIDAT (I) Then
                               Filter [F:ZSOQ2] Where SOHNUM = [M:ZASG2]ZSOHNUM(I) and SOPLIN = [M:ZASG2]ZSOPLIN (I)
                               Read  [F:ZSOQ2]SOQ0 First
                               If !fstat Then
                                  [F:ZSOQ2]SHIDAT    = [M:ZASG2]ZFECHAEXP  (I)
                                  [F:ZSOQ2]EXTDLVDAT = ([M:ZASG2]ZFECHAEXP (I)+[F:ZSOQ2]DAYLTI)
                                  Rewrite  [F:ZSOQ2]
                               Endif
                               Filter [F:ZSOQ2]
                           Endif
                        Next
                        Call BUSCAR()
                        Call MESSAGE("Proceso finalizado")From GESECRAN
                    Endif
                  Endif
   When Default
  Endcase
  ACTION=""
Return


################################################################

Subprog BUSCAR ()
 If !clalev([F:ZSOH1]) : Local File SORDER    [F:ZSOH1] : Endif
 If !clalev([F:ZSOQ1]) : Local File SORDERQ   [F:ZSOQ1] : Endif
 If !clalev([F:ZSOP1]) : Local File SORDERP   [F:ZSOP1] : Endif
 If !clalev([F:ZSTO1]) : Local File STOCK     [F:ZSTO1] : Endif
 If !clalev([F:ZITF1]) : Local File ITMFACILIT[F:ZITF1] : Endif
 Local Integer I: Raz I
 Local Char FILTRO(255)        : FILTRO ="STOFCY='" +[M:ZASG0]ZSTOFCY+"'&SOQSTA<>3"
 #FIXME : FILTRO EJEMPLO
 #############################PRUEBAS############################################
 #Local Char FILTRO(255)        : FILTRO ="STOFCY='" +[M:ZASG0]ZSTOFCY+"'"
 ################################################################################
 Local Char FILTRO_STOCK (255), ZARTANT(50)
 Local Decimal ZSTOACTU,ZTOTASIG,ZTOTDISP,QTYSTC,ZQTYASIG,ZQTYDISP
 Raz [M:ZASG2]
 Raz [M:ZASG1]ZSTOACTU,[M:ZASG1]ZTOTASIG,[M:ZASG1]ZTOTDISP,[M:ZASG1]ZQTYSTC,[M:ZASG1]ZQTYASIG,[M:ZASG1]ZQTYDISP

 Local Decimal ZSTOACTU,ZTOTASIG,ZTOTDISP,QTYSTC,ZQTYASIG,ZQTYDISP,ZIMPPEDAI,ZIMPASIGAI,ZENENTREGA
 Raz ZSTOACTU,ZTOTASIG,ZTOTDISP,QTYSTC,ZQTYASIG,ZQTYDISP,ZIMPPEDAI,ZIMPASIGAI,ZENENTREGA

 If [M:ZASG0]ZSALFCY <> '' : FILTRO -= "&SALFCY='" +[M:ZASG0]ZSALFCY +"'" : Endif
 If [M:ZASG0]ZITMREF <> '' : FILTRO -= "&ITMREF='" +[M:ZASG0]ZITMREF +"'" : Endif
 If [M:ZASG0]ZBPCORD <> '' : FILTRO -= "&BPCORD='"+[M:ZASG0]ZBPCORD +"'" : Endif
 If [M:ZASG0]ZPEDINI <> '' : FILTRO -= "&SOHTYP>='"+[M:ZASG0]ZPEDINI +"'" : Endif
 If [M:ZASG0]ZPEDFIN <> '' : FILTRO -= "&SOHTYP<='"+[M:ZASG0]ZPEDFIN +"'" : Endif
 #Estado orden
 If [M:ZASG0]ZSTAORDFIR = 2 and [M:ZASG0]ZSTAORDPLAN  = 2  :  FILTRO -= "&(DEMSTA=1|DEMSTA=2) "  : Endif
 If [M:ZASG0]ZSTAORDFIR = 2 and [M:ZASG0]ZSTAORDPLAN  = 1  :  FILTRO -= "&DEMSTA=1"              : Endif
 If [M:ZASG0]ZSTAORDFIR = 1 and [M:ZASG0]ZSTAORDPLAN  = 2  :  FILTRO -= "&DEMSTA=2"              : Endif
 If [M:ZASG0]ZSTAORDFIR = 1 and [M:ZASG0]ZSTAORDPLAN  = 1  :  FILTRO -= "&(DEMSTA<>2&DEMSTA<>1)" : Endif
 FILTRO -= "&(DEMSTA<>3&DEMSTA<>4)"
 #Prioridad entrega
 If [M:ZASG0]ZPRINORMAL  = 2 and [M:ZASG0]ZPRIURG  = 2 and [M:ZASG0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=1|DLVPIO=2|DLVPIO=3)"     : Endif
 If [M:ZASG0]ZPRINORMAL  = 2 and [M:ZASG0]ZPRIURG  = 2 and [M:ZASG0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=1|DLVPIO=2)"              : Endif
 If [M:ZASG0]ZPRINORMAL  = 2 and [M:ZASG0]ZPRIURG  = 1 and [M:ZASG0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=1|DLVPIO=3)"              : Endif
 If [M:ZASG0]ZPRINORMAL  = 2 and [M:ZASG0]ZPRIURG  = 1 and [M:ZASG0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=1)"                       : Endif
 If [M:ZASG0]ZPRINORMAL  = 1 and [M:ZASG0]ZPRIURG  = 2 and [M:ZASG0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=2|DLVPIO=3)"              : Endif
 If [M:ZASG0]ZPRINORMAL  = 1 and [M:ZASG0]ZPRIURG  = 2 and [M:ZASG0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO=2)"                       : Endif
 If [M:ZASG0]ZPRINORMAL  = 1 and [M:ZASG0]ZPRIURG  = 1 and [M:ZASG0]ZPRIMURG = 2:  FILTRO -= "&(DLVPIO=3)"                       : Endif
 If [M:ZASG0]ZPRINORMAL  = 1 and [M:ZASG0]ZPRIURG  = 1 and [M:ZASG0]ZPRIMURG = 1:  FILTRO -= "&(DLVPIO<>1&DLVPIO<>2&DLVPIO<>3)"  : Endif
 #Entrega parcial
 If [M:ZASG0]ZEPARAUT  = 2 and [M:ZASG0]ZEPLINCOM  = 2 and [M:ZASG0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=2|[F:ZSOH1]DME=3)"       : Endif
 If [M:ZASG0]ZEPARAUT  = 2 and [M:ZASG0]ZEPLINCOM  = 2 and [M:ZASG0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=2)"                      : Endif
 If [M:ZASG0]ZEPARAUT  = 2 and [M:ZASG0]ZEPLINCOM  = 1 and [M:ZASG0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=1|[F:ZSOH1]DME=3)"                      : Endif
 If [M:ZASG0]ZEPARAUT  = 2 and [M:ZASG0]ZEPLINCOM  = 1 and [M:ZASG0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=1)"                                     : Endif
 If [M:ZASG0]ZEPARAUT  = 1 and [M:ZASG0]ZEPLINCOM  = 2 and [M:ZASG0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=2|[F:ZSOH1]DME=3)"                      : Endif
 If [M:ZASG0]ZEPARAUT  = 1 and [M:ZASG0]ZEPLINCOM  = 2 and [M:ZASG0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME=2)"                                     : Endif
 If [M:ZASG0]ZEPARAUT  = 1 and [M:ZASG0]ZEPLINCOM  = 1 and [M:ZASG0]ZEPPEDCOM = 2:  FILTRO -= "&([F:ZSOH1]DME=3)"                                     : Endif
 If [M:ZASG0]ZEPARAUT  = 1 and [M:ZASG0]ZEPLINCOM  = 1 and [M:ZASG0]ZEPPEDCOM = 1:  FILTRO -= "&([F:ZSOH1]DME<>1&[F:ZSOH1]DME<>2&[F:ZSOH1]DME<>3)"    : Endif

 Link [F:ZSOQ1] With  [F:ZSOH1]SOH0 = [F:ZSOQ1]SOHNUM,[F:ZSOP1]SOP0 = [F:ZSOQ1]SOHNUM;[F:ZSOQ1]SOPLIN;[F:ZSOQ1]SOQSEQ As [ZLK] Where evalue (FILTRO) Order By [F:ZSOQ1]SOHNUM;ITMREF
 For [ZLK]

   FILTRO_STOCK = "STOFCY='" +[M:ZASG0]ZSTOFCY+"'&STA='A' & LOCCAT =1"
   If [M:ZASG0]ZLOCTYP <> '' : FILTRO_STOCK -= " & LOCTYP ='"+[M:ZASG0]ZLOCTYP+"'" : Endif
   [M:ZASG2]ZSOHNUM    (I) = [F:ZSOQ1]SOHNUM
   [M:ZASG2]ZSOPLIN    (I) = [F:ZSOQ1]SOPLIN
   [M:ZASG2]ZNETPRI    (I) = [F:ZSOP1]NETPRI
   [M:ZASG2]ZBPCORD    (I) = [F:ZSOQ1]BPCORD
   [M:ZASG2]ZORDDAT    (I) = [F:ZSOQ1]ORDDAT
   [M:ZASG2]ZDME       (I) = [F:ZSOH1]DME
   [M:ZASG2]ZDLVPIO    (I) = [F:ZSOQ1]DLVPIO
   [M:ZASG2]ZDEMDLVDAT (I) = [F:ZSOQ1]DEMDLVDAT
   [M:ZASG2]ZSHIDAT    (I) = [F:ZSOQ1]SHIDAT
   [M:ZASG2]ZFECHAEXP  (I) = [F:ZSOQ1]SHIDAT
   [M:ZASG2]ZITMREF    (I) = [F:ZSOQ1]ITMREF
   [M:ZASG2]ZQTY       (I) = [F:ZSOQ1]QTY
   [M:ZASG2]ZDLVQTY    (I) = [F:ZSOQ1]DLVQTY
   [M:ZASG2]ZODLQTY    (I) = [F:ZSOQ1]ODLQTY
   #ZENENTREGA            + = [F:ZSOQ1]ODLQTY
   [M:ZASG2]ZQTYPEND   (I) = [F:ZSOQ1]QTY - [F:ZSOQ1]DLVQTY - [F:ZSOQ1]ODLQTY
   [M:ZASG2]ZALLQTY    (I) = [F:ZSOQ1]ALLQTY
   [M:ZASG2]ZASIGNACION(I) = [F:ZSOQ1]ALLQTY
   [M:ZASG2]ZNETPRINOT (I) = [F:ZSOP1]NETPRINOT * [F:ZSOQ1]QTY
   [M:ZASG2]ZIMPPEND   (I) = [F:ZSOP1]NETPRI    * [M:ZASG2]ZQTYPEND (I)
   [M:ZASG2]ZIMPASIG   (I) = [F:ZSOP1]NETPRI    * [F:ZSOQ1]ALLQTY
   ZIMPPEDAI  +=  [M:ZASG2]ZNETPRINOT (I)
   ZIMPASIGAI +=  [M:ZASG2]ZIMPASIG   (I)
   #Totales
   If [F:ZSOQ1]ITMREF <> ZARTANT Then

     FILTRO_STOCK -= "&ITMREF='" + [F:ZSOQ1]ITMREF +"'"
     Filter [F:ZSTO1] Where evalue(FILTRO_STOCK)
     Read [F:ZSTO1]STO0 First
     If !fstat Then
        For [F:ZSTO1]STO0
          ZSTOACTU += [F:ZSTO1]QTYSTU
          ZTOTASIG += [F:ZSTO1]CUMALLQTA# + ZENENTREGA
          ZTOTDISP += [F:ZSTO1]QTYSTU - [F:ZSTO1]CUMALLQTA
          ZQTYSTC  += [F:ZSTO1]QTYSTU
          ZQTYASIG += [F:ZSTO1]CUMALLQTA
          ZQTYDISP += [F:ZSTO1]QTYSTU - [F:ZSTO1]CUMALLQTA
          ZARTANT   = [F:ZSOQ1]ITMREF
         Next
     Endif
     Filter [F:ZSTO1]
   Endif
   I+=1
 Next

 [M:ZASG2]NBLIG      = I
 [M:ZASG1]ZSTOACTU   = ZSTOACTU
 [M:ZASG1]ZTOTASIG   = ZTOTASIG
 [M:ZASG1]ZTOTDISP   = ZTOTDISP
 Filter [F:ZITF1] Where STOFCY= [M:ZASG0]ZSTOFCY and ITMREF=[M:ZASG0]ZITMREF and DEFLOCTYP=[M:ZASG0]ZLOCTYP
 Read[F:ZITF1]ITF0 First
 If !fstat Then
  [M:ZASG1]ZRESERVB2C = [F:ZITF1]ZRESERVB2C
 Endif
 [M:ZASG1]ZQTYSTC    = ZQTYSTC
 [M:ZASG1]ZQTYASIG   = ZQTYASIG
 [M:ZASG1]ZQTYDISP   = ZQTYDISP
 [M:ZASG1]ZIMPPEDAI  = ZIMPPEDAI
 [M:ZASG1]ZIMPASIGAI = ZIMPASIGAI
 Affzo [M:ZASG0]
 Affzo [M:ZASG1]
 Affzo [M:ZASG2]
End
######################################################################################
Funprog CONTROL_STOCK(ZP_ZSTOFCY,ZP_ITMREF)
  Value Char ZP_ZSTOFCY,ZP_ITMREF
  Local Integer ZRES : ZRES = 2
  Local Decimal ZTOTAL  : Raz ZTOTAL
  If !clalev([F:ZSTO3]) : Local File STOCK     [F:ZSTO3] : Endif
  If !clalev([F:ZTLO2]) : Local File TABLOCTYP [F:ZTLO2] : Endif
  Local Decimal ZDISPONIBLE : Raz ZDISPONIBLE

  Filter [F:ZSTO3] Where STOFCY = ZP_ZSTOFCY and STA ='A' and ITMREF = ZP_ITMREF
  Read [F:ZSTO3]STO0 First
  If !fstat Then
    Read[F:ZTLO2]TLO0 = [M:ZASG0]ZSTOFCY;[F:ZSTO3]LOCTYP
    If !fstat and [F:ZTLO2]LOCCAT = 1 Then
      For[F:ZSTO3]STO0
         ZDISPONIBLE += [F:ZSTO3]QTYSTU #- [F:ZSTO3]CUMALLQTA
      Next
    Endif
  Endif

  For I = 0 To [M:ZASG2]NBLIG - 1
     ZTOTAL + = [M:ZASG2]ZASIGNACION(I)
  Next
  If (ZTOTAL > ZDISPONIBLE) Then
    ZRES = 1
  Endif
  Filter [F:ZSTO3]
End ZRES
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASIG1) 04/06/2020 16:08:39 (ADMIN)
######################################################################################
Subprog AM_ZFECHAEXP(VALEUR)
  Variable Date    VALEUR
  Local Integer I

  [M:ZASG2]ZFECHAEXP (nolign-1) = VALEUR
  Affzo [M:ZASG2]ZFECHAEXP (nolign-1)
End
######################################################################################

Subprog AM_ZASIGNACION(VALEUR)
  Variable Decimal VALEUR
  If !clalev([F:ZSTO2]) : Local File STOCK   [F:ZSTO2] : Endif
  Local Integer I
  Local Decimal ZTOTAS,ZASIG,ZENENT : Raz ZTOTAS,ZASIG

  If (VALEUR > [M:ZASG2]ZQTYPEND(nolign-1)) Then
     Call MESSAGE("La cantidad asignada no puede ser superior a la pendiente")From GESECRAN
     mkstat = 2
     End
  Endif
  Filter [F:ZSTO2] Where STOFCY =[M:ZASG0]ZSTOFCY and ITMREF = [M:ZASG2]ZITMREF(nolign-1)
  Read [F:ZSTO2]STO0 First
  If !fstat Then
    For I = 0 To [M:ZASG2]NBLIG - 1
       If (nolign-1) <> I Then
        ZTOTAS +=  [M:ZASG2]ZASIGNACION (I)
       Endif
       ZASIG + = [M:ZASG2]ZALLQTY (I)
    Next

    If(([M:ZASG1]ZQTYASIG + ZTOTAS + VALEUR - ZASIG) <= [M:ZASG1]ZSTOACTU) or (VALEUR=0)  Then
      If VALEUR<>0 Then
        [M:ZASG1]ZTOTASIG            = [M:ZASG1]ZQTYASIG + ZTOTAS + VALEUR - ZASIG
        [M:ZASG1]ZTOTDISP            = [M:ZASG1]ZSTOACTU - [M:ZASG1]ZTOTASIG
        [M:ZASG2]ZIMPASIG (nolign-1) = [M:ZASG2]ZNETPRI (nolign-1) * VALEUR
        Call IMPORTES_AI()
        Affzo [M:ZASG2]ZIMPASIG (nolign-1)
        Affzo [M:ZASG1]ZTOTASIG
        Affzo [M:ZASG1]ZTOTDISP
      Endif
    Else
      Call MESSAGE("No hay suficiente stock")From GESECRAN
      mkstat = 2
      End
    Endif
  Endif
  Filter [F:ZSTO2]
  [M:ZASG2]ZASIGNACION (nolign-1) = VALEUR
  Affzo [M:ZASG2]ZASIGNACION (nolign-1)

End
###############################################################################
Funprog ACTUALIZAR()
  Local Integer I,ZRES : ZRES = 1

  For I = 0 To [M:ZASG2]NBLIG - 1
    If ([M:ZASG2]ZFECHAEXP (I) <> [M:ZASG2]ZSHIDAT (I) or [M:ZASG2]ZALLQTY (I) <> [M:ZASG2]ZASIGNACION (I)) Then
      ZRES = 2
      Break
    Endif
  Next
End ZRES

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASIG2) 18/06/2020 15:44:18 (ADMIN)
######################################################################################
Subprog B1_NBLIG
 Local Char PARBOUT(250)(1..20)
 PARBOUT(1) = [M:ZASG2]ZSOHNUM(nolign-1)
 PARBOUT(2) = "SOH"
 PARBOUT(3) = ""
 GACTION    = "GOBJETC1"
 Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
End


######################################################################################
Subprog IMPORTES_AI()
  Local Decimal ZASIG
  Raz ZASIG
  Local Integer J

  For J=0 To [M:ZASG2]NBLIG - 1
    ZASIG +=  [M:ZASG2]ZIMPASIG   (J)
  Next
  [M:ZASG1]ZIMPASIGAI = ZASIG
  Affzo [M:ZASG1]
End
