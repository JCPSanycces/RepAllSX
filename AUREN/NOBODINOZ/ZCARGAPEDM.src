#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog ASIGNAR_PEDIDO(ZP_STOFCY,ZP_VCRNUM,ZP_VCRLIN,ZP_ITMREF,ZP_QTY)
  Value Char ZP_STOFCY,ZP_VCRNUM,ZP_ITMREF
  Value Integer ZP_VCRLIN
  Value Decimal ZP_QTY
  If clalev([F:SOH4])   = 0 Local File SORDER    [F:SOH4] : Endif
  If clalev([F:ZSOP11]) = 0 Local File SORDERP [F:ZSOP11] : Endif
  If clalev([F:ZSOQ11]) = 0 Local File SORDERQ [F:ZSOQ11] : Endif
  If clalev([F:SOQ])    = 0 Local File SORDERQ    [F:SOQ] : Endif
  If clalev([F:SOH])    = 0 Local File SORDER     [F:SOH] : Endif

  Local Mask SOH0   [M:SOH0]
  Local Mask SOH0   [M:SOH1]
  Local Mask SOH4   [M:SOH4]
  Local Mask STOALL [M:ALL]
  Local Char PARAM(250)(1..5), SAVACT(20), VALEUR
  Local Integer FIN,FOK
  PARAM(1) = "SOH4"
  PARAM(2) = "0"#NOLIGN
  PARAM(3) = ZP_ITMREF
  PARAM(4) = ZP_STOFCY
  PARAM(5) = "2"

  Read [F:SOH4]SOH0 = ZP_VCRNUM
  Filter [F:ZSOQ11] Where SOHNUM = ZP_VCRNUM and SOPLIN = ZP_VCRLIN
  Read [F:ZSOQ11]SOQ0 First
  [M:SOH0]=[F:SOH4]
  Gosub LIENS_LIG
  Gosub OUVRE From TRTSTOALL

  Gosub DEBUT
  Gosub CRE_PIC
  #B2C>
  OKRUP=1
  #B2C<
  Gosub ENR
  Close Mask [M:SOH0]
  Close Mask [M:SOH1]
  Close Mask [M:SOH4]
  Close Mask [M:ALL]

End

####################################################################

$LIENS_LIG

Local Integer NOL

[M:SOH4] = [F:ZSOQ11]
Raz NOL
Read [F:ZSOQ11]SOQ0 = ZP_VCRNUM;ZP_VCRLIN;ZP_VCRLIN
Read [F:ZSOP11]SOP0 = ZP_VCRNUM;ZP_VCRLIN;ZP_VCRLIN
If !fstat Then
  #For [F:ZSOQ11]SOQ0 Where SOHNUM = ZP_VCRNUM and SOPLIN = ZP_VCRLIN
    #FPH+
    [M:SOH4]SOPLIN(NOL)    = [F:ZSOQ11]SOPLIN
    [M:SOH4]ITMREF(NOL)    = [F:ZSOQ11]ITMREF
    [M:SOH4]SAU (NOL)      = [F:ZSOP11]SAU
    [M:SOH4]STU (NOL)      = [F:ZSOP11]STU
    [M:SOH4]SAUSTUCOE (NOL)= [F:ZSOP11]SAUSTUCOE
    [M:SOH0]BPCORD         = [F:ZSOQ11]BPCORD
    [M:SOH4]DBPAADD(NOL)   = [F:ZSOQ11]BPAADD
    [M:SOH4]ALLQTYSTU(NOL) = [F:ZSOQ11]ALLQTYSTU
    [M:SOH4]SHTQTYSTU(NOL) = [F:ZSOQ11]SHTQTYSTU
    [M:SOH4]ALLQTYSTU(NOL) = [F:ZSOQ11]ALLQTYSTU
    [M:SOH4]SHTQTYSTU(NOL) = [F:ZSOQ11]SHTQTYSTU
    [M:SOH4]WALLQTYSTU(NOL)= [F:ZSOQ11]ALLQTYSTU
    #FPH-
    [M:SOH4]DPJT(NOL)       = [F:ZSOQ11]PJT
    [M:SOH4]DSTOFCY(NOL)    = [F:ZSOQ11]STOFCY
    [M:SOH4]DDLVPIO(NOL)    = [F:ZSOQ11]DLVPIO
    [M:SOH4]DBPTNUM(NOL)    = [F:ZSOQ11]BPTNUM
    [M:SOH4]DMDL(NOL)       = [F:ZSOQ11]MDL
    [M:SOH4]DDRN(NOL)       = [F:ZSOQ11]DRN
    [M:SOH4]DDAYLTI(NOL)    = [F:ZSOQ11]DAYLTI
    [M:SOH4]DDEMDLVDAT(NOL) = [F:ZSOQ11]DEMDLVDAT
    [M:SOH4]DSHIDAT(NOL)    = [F:ZSOQ11]SHIDAT
    [M:SOH4]DALLTYP(NOL)    = [F:ZSOQ11]ALLTYP
    [M:SOH4]DCCLREN(NOL)    = [F:ZSOQ11]CCLREN
    [M:SOH4]DCCLDAT(NOL)    = [F:ZSOQ11]CCLDAT
    [M:SOH4]GRPFLG(NOL)=1

    Raz [M:SOH4]WIPFLG(NOL)
    [M:SOH4]YQTY(NOL)       = [F:ZSOQ11]QTY
    [M:SOH4]CQTY(NOL)       = [F:ZSOQ11]QTY
    [M:SOH4]YALLQTY(NOL)    = [F:ZSOQ11]ALLQTY
    [M:SOH4]YSHTQTY(NOL)    = [F:ZSOQ11]SHTQTY
    [M:SOH4]YSOQSTA(NOL)    = [F:ZSOQ11]SOQSTA
    [M:SOH4]YDSHIDAT(NOL)   = [F:ZSOQ11]SHIDAT

    [M:SOH4]TALLQTYSTU(NOL) = [F:ZSOQ11]ALLQTYSTU + [F:ZSOQ11]ODLQTYSTU + [F:ZSOQ11]OPRQTYSTU + [F:ZSOQ11]PREQTYSTU
    [M:SOH4]TALLQTY(NOL)    = [F:ZSOQ11]ALLQTY + [F:ZSOQ11]ODLQTY + [F:ZSOQ11]OPRQTY + [F:ZSOQ11]PREQTY

    If [M:SOH0]SOHCAT = 3 | [M:SOH4]DLVFLG(NOL)=1
        [M:SOH4]TALLQTYSTU(NOL) += [F:ZSOQ11]INVQTYSTU
        [M:SOH4]TALLQTY(NOL)    += [F:ZSOQ11]INVQTY
    Else
        [M:SOH4]TALLQTYSTU(NOL) += [F:ZSOQ11]DLVQTYSTU
        [M:SOH4]TALLQTY(NOL)    += [F:ZSOQ11]DLVQTY
    Endif

    [M:SOH4]WALLQTY(NOL)    = [F:ZSOQ11]ALLQTY + [F:ZSOQ11]SHTQTY
    [M:SOH4]WALLQTYSTU(NOL) = [F:ZSOQ11]ALLQTYSTU + [F:ZSOQ11]SHTQTYSTU
    Affzo [M:SOH4]
    #NOL+=1
 # Next
 Endif
   [M:SOH4]NBLIG=NOL
   Affzo [M:SOH4]
Return


#########################################################################
$DEBUT
Raz GTYPLIG, WF
# Chargement des blocs 1 et 2
# Traitement ŕ alimenter pour les différentes fonctions
#FPH+

#Gosub CHARG_PARAM  From TRTSTOALLA
Gosub CHARGE_STOALL From SUBSOH1
#FPH-

#--- Bug 83065
#--- Si ordre de sous-traitance,
#--- vérification qu'un manquant sous-traitant n'est pas en préparation
If LABR= "SCO2" & [M:ALL]SHTQTY<>0
   WSRGQTY=0
   For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM
&                    & VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ & STOCOU=0
      WSRGQTY+=[F:STA]SRGQTYSTU
   Next
   If WSRGQTY>0
      Call ERREUR(mess(398,184,1)) From GESECRAN
      FIN=1 : Return
   Endif
#--- Bug 84767
Elsif [M:ALL]SHTQTY<>0
   WSRGQTY=0
   For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM
&                    & VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ
&                    & STOCOU=0 & SRGNUM<>""
      WSRGQTY+=[F:STA]SRGQTYSTU
   Next
   If WSRGQTY>0
      Call MESSAGE(mess(408,184,1)) From GESECRAN
      FIN=1 : Return
   Endif
#---
Endif
#---

# Récupération code 'gestion dépôt sur le site'
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

Call LECITM(LFCY,LITM,"",0,[M:ALL]XWRH,LRET) From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

If !find([M:ALL]ALLTYP,1,2) | [M:ALL]OLDALLQTY=0
   [M:ALL]ALLTYP=2
Endif

# Sauvegarde qté ŕ allouer pour restitution si abandon
WQTYTOALL = [M:ALL]QTYTOALL

[M:ALL]ITMREF = LITM
[M:ALL]STOFCY = LFCY
[M:ALL]VCRTYP = GVCRTYP

If GERR | FIN Return Endif

# Stockage du lot de rupture
Raz WSHTLOT
If [M:ALL]XLOT<>"*" WSHTLOT=[M:ALL]XLOT Endif

# Stockage du dépôt de rupture
WSHTWRH = [M:ALL]XWRH

# Dépôt obligatoire ou renseigné sur ligne document --> non modifiable
If [M:ALL]XWRH<>""
   [M:ALL]WRHOBY=2
Else
   [M:ALL]WRHOBY=1
   LSST=0
   # Sous-traitance
   If ([M:ALL]VCRTYP=10 & [M:ALL]PECSCOLOC=2) | [M:ALL]VCRTYP=36
      LSST=1
   Endif
   # Alimentation dépôt par défaut article-site pour filtrer le stock
   Call WRHAUTO([M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]VCRTYP,LSST,LWRH) From STKWRH
   If !find(LWRH,"","*")
      [M:ALL]XWRH = LWRH
   Endif
Endif

# Stockage du filtre statut
GXSTA = [M:ALL]XSTA

#--- Issue X3-55261
# Filtre catégorie emplacement pour le contrôle et la sélection emplacement
Raz GLOCCAT
If [M:ALL]PECINTLOC=2 GLOCCAT+="1" Endif
If [M:ALL]PECPLFLOC=2 GLOCCAT+="2" Endif
If [M:ALL]PECSCOLOC=2 GLOCCAT+="4" Endif
#---

If [M:ALL]VCRTYP=2
   LNUM=format$("K:"+num$(GLONBPC)+"X",[M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M:ALL]BPAADD)
   LNUM= vireblc(LNUM, 1)
Endif

# Si alloc détaillé et qté déjŕ allouée = qté ŕ allouer ou qté besoin
# pas de chargement de la liste de picking
If [M:ALL]ALLTYP=2 &
& ([M:ALL]QTYTOALL=[M:ALL]OLDALLQTY | [M:ALL]RETQTY=[M:ALL]OLDALLQTY)
   WAFFPICK=0
Else
   WAFFPICK=1
Endif

# Si ce n'est pas un composant de kit
If GTYPLIG<>1
   # Si qté ŕ allouer et déjŕ allouée nulles,
   # alimentation qté ŕ allouer avec qté besoin
   If [M:ALL]QTYTOALL=0 & [M:ALL]OLDALLQTY=0
      [M:ALL]QTYTOALL=[M:ALL]RETQTY
   Endif
Endif

# Alimentation du masque STOALL
Gosub ALI_MSK_ALL2

# Par défaut, pas d'affichage des lignes de stock indisponibles
[M:ALL]STODISFLG=1


If [M:ALL]NBLIG>0
   Affzo [M:ALL]1-99
Else
   # Artifice (affichage du tableau) afin de traiter les colonnes invisibles
   [M:ALL]NBLIG=1
   Affzo [M:ALL]1-99
   Effzo [M:ALL]15
Endif

#------------------------------------------------------
# Chargement du filtre lignes de stock pour le picking
#------------------------------------------------------
#--- Issue X3-4501 : ajout VCRTYP=40
Case [M:ALL]VCRTYP
 When  2 : GTRUCOD = [F:ITG]ALLRULORD
           If GPRET=1
              WTRSTYP = 17
           Else
              WTRSTYP = 4
           Endif
 When 10 : If [M:ALL]PECSCOLOC=2
              GTRUCOD = [F:ITG]ALLRULSCC
              WTRSTYP = 29
           Else
              GTRUCOD = [F:ITG]ALLRULMAT
              WTRSTYP = 6
           Endif
 When 36 : GTRUCOD = [F:ITG]ALLRULSCC
           WTRSTYP = 29
 When 40 : GTRUCOD = [F:ITG]ALLRULORD
           WTRSTYP = 4
Endcase

GUNTLOT=1
Raz [F:TRU]
# Lecture rčgle d'allocation
If GTRUCOD<>""
   Read [TRU]TRU0=GTRUCOD
   If fstat
      Raz GTRUCOD
   Else
      GUNTLOT=[F:TRU]UNTLOT
   Endif
Endif

# Stockage ordre des lots (FIFO par défaut) pour picking lignes de stock
If GTRUCOD<>""
   [M:ALL]LOTMGT=[F:TRU]LOTMGT
Else
   [M:ALL]LOTMGT=2
Endif

# Lecture de la rčgle de gestion ŕ utiliser
Call LECSRU([M:ALL]STOFCY,[F:ITM]TCLCOD,WTRSTYP,"","",LRET)
&           From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

#--- TS 106217
# Stockage de la version de rupture si exclusivité
If [F:SRU]ORDVER=2
  WSHTECCVALMAJ = [M:ALL]WECCVALMAJ
Else
  WSHTECCVALMAJ = ""
Endif
#---

# Récupération de l'emplacement de rupture si exclusif
Raz WSHTLOC, WDEFLOC
# Si rčgle d'allocation/sortie
If GTRUCOD<>""

   # Récupération types emplacement ou emplacement par défaut
   # de l'article-site pour le type mouvement
   #--- Issue 110327
   #Gosub ALI_DEFLOC From STKALL
   Gosub ALI_DEFLOC From STKALF
   #---

   # Détermination du nombre de ligne de la rčgle
   I = find(0,[F:TRU]LOCFLT(0..dim([F:TRU]LOCFLT)-1))
   If I=0
      WNBL = dim([F:TRU]LOCFLT)
   Else
      WNBL = I-1
   Endif
   If min([F:TRU]LOCFLT(0..WNBL-1))>1
      # Si OF ou Ordre de sous-traitance et emplacement local renseigné
      If find([M:ALL]VCRTYP,10,36)
         If [M:ALL]STOLOC<>""
            # Si emp local exclusif sana joker on le stocke pour les ruptures
            If max([F:TRU]LOCFLT)=2
&            & !instr(1,[M:ALL]STOLOC,'*') & !instr(1,[M:ALL]STOLOC,'?')
&            & !instr(1,[M:ALL]STOLOC,'!') & !instr(1,[M:ALL]STOLOC,'#')
               WSHTLOC=[M:ALL]STOLOC
            Endif
            # Emp local dans les rčgles, mais non exclusif --> c'est fini
            If min([F:TRU]LOCFLT)=2 WF=1 Endif
         Endif
      Endif
      If WSHTLOC="" & WF<>1
         # I,J et K contiennent la 1čre position des catégories emp 1,2 et 3
         # dans le tableau des rčgles d'allocation (0 si absent)
         I = find(3,[F:TRU]LOCFLT(0..WNBL-1))
         J = find(4,[F:TRU]LOCFLT(0..WNBL-1))
         K = find(5,[F:TRU]LOCFLT(0..WNBL-1))
         # WE1,WE2 et WE3 contiennent 1 si emp par défaut 1,2 et 3
         Raz WE1, WE2, WE3
         If WDEFLOC <>"" & !instr(1,WDEFLOC,'*')  & !instr(1,WDEFLOC,'?')
&                        & !instr(1,WDEFLOC,'!')  & !instr(1,WDEFLOC,'#')
            WE1=1
         Endif
         If WDEFLOC2<>"" & !instr(1,WDEFLOC2,'*') & !instr(1,WDEFLOC2,'?')
&                        & !instr(1,WDEFLOC2,'!') & !instr(1,WDEFLOC2,'#')
            WE2=1
         Endif
         If WDEFLOC3<>"" & !instr(1,WDEFLOC3,'*') & !instr(1,WDEFLOC3,'?')
&                        & !instr(1,WDEFLOC3,'!') & !instr(1,WDEFLOC3,'#')
            WE3=1
         Endif
         # WT1,WT2 et WT3 contiennent 1 si type emp par défaut 1,2 et 3
         Raz WT1, WT2, WT3
         If WDEFLOCTYP <>"" & !instr(1,WDEFLOCTYP,'*') &!instr(1,WDEFLOCTYP,'?')
&                           & !instr(1,WDEFLOCTYP,'!') &!instr(1,WDEFLOCTYP,'#')
            WT1=1
         Endif
         If WDEFLOCTYP2<>"" & !instr(1,WDEFLOCTYP2,'*')&!instr(1,WDEFLOCTYP2,'?')
&                           & !instr(1,WDEFLOCTYP2,'!')&!instr(1,WDEFLOCTYP2,'#')
            WT2=1
         Endif
         If WDEFLOCTYP3<>"" & !instr(1,WDEFLOCTYP3,'*')&!instr(1,WDEFLOCTYP3,'?')
&                           & !instr(1,WDEFLOCTYP3,'!')&!instr(1,WDEFLOCTYP3,'#')
            WT3=1
         Endif

         # WLOCFLT contient la valeur max des catégories d'emp (3,4 ou 5)
         WLOCFLT = max([F:TRU]LOCFLT)

         # Exploitation des rčgles d'allocation pour déterminer
         # le type ou l'emplacement de rupture
         #--- Issue 110327
         #Gosub ALI_LOCATION From STKALL
         Gosub ALI_LOCATION From STKALF
         #---
      Endif
   Endif

   # Chargement des (types) emplacements de l'article-site paramétrés
   # dans la rčgle d'allocation/sortie pour filtrer le picking stock
   Call RECH_DEFLOCTYP("ALL") From STKALL

Endif

# Chargement de l'emplacement (type) de consommation (si exclusif)
Raz LDEFLOC, LDEFLOCTYP
If [F:ITF]LOCMGTCOD=2
   # Si pręt
   If WTRSTYP=17
      WPRE=2
   Else
      WPRE=1
   Endif
   Call RECH_PICLOC([M:ALL]VCRTYP,[M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]STOLOC,
&                   [M:ALL]XWRH,[M:ALL]PECSCOLOC,WPRE,"N",LDEFLOC,LDEFLOCTYP) From STKALL
Endif

#--- Positionnement filtre picking
Raz WCRIT, WCRITSTO, WCRITPIC
Raz WCRITSTO1, WCRITSTO2, WCRITSTO3, WCRITSTO31, WCRITSTO4, WCRITSTO5, WCRITSTO6   # hcb v6percri

WCRITSTO1 = '[F:STO]ITMREF=[M:ALL]ITMREF&[F:STO]STOFCY=[M:ALL]STOFCY'

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALL]BPCORD <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALL]BPCORD
   If fstat
      Raz [F:ITU]
   Endif
Endif
#DLU Client, calcul du nbre de jours ŕ retrancher ŕ la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif
#Fin DLUBPC


# Lot et péremption
If dim([M:ALL]XLOT)>0
   # hcb V6dlu nouvelle gestion
   WCRITSTO3  = '([F:STL]SHLDAT=[0/0/0]|'
   WCRITSTO31 = '([F:STL]DLUDAT=[0/0/0]|'
   If [M:ALL]DLVDAT<>[0/0/0]
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:ALL]DLVDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:ALL]DLVDAT)'      #DLUBPC
   Else
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:ALL]RETDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:ALL]RETDAT)'      #DLUBPC
   Endif
   If [F:SRU]SHLLOT=1
      WCRITPIC  = WCRITSTO3
   Elsif [F:SRU]SHLLOT=2
      WCRITPIC  = WCRITSTO31
   Endif
   If !find([M:ALL]XLOT,"","*")
      WCRITSTO2 = 'pat([F:STO]LOT,[M:ALL]XLOT)<>0'
   Endif
   #--- TS 106217
   # Si version renseignée et exclusive
   If [M:ALL]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
      WCRITSTO21 = '[F:STO]ECCVALMAJ=[M:ALL]WECCVALMAJ'
   Endif
   #---
Endif

# Si non renseigné car ajouté 05.08
If [M:ALL]PECINTLOC=0 [M:ALL]PECINTLOC=2 Endif
# Catégorie emplacement et dépôt
If [M:ALL]PECINTLOC=2
   If [M:ALL]PECPLFLOC=2
      WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
      If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
   Else
      WCRITSTO5 = '[F:STO]LOCCAT=1'
      If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
   Endif
Elsif [M:ALL]PECPLFLOC=2
   WCRITSTO5 = '[F:STO]LOCCAT=2'
   If [M:ALL]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:ALL]XWRH)<>0' Endif
Endif
If [M:ALL]PECSCOLOC=2
   If WCRITSTO5=""
      WCRITSTO5  = '[F:STO]LOCCAT=4'
   Else
      WCRITSTO5 += '|[F:STO]LOCCAT=4'
   Endif
Elsif WCRITSTO5=""
   # Pour ne rien avoir (paramétrage incohérent)
   WCRITSTO5 = '[F:STO]LOCCAT=9'
Endif

# Propriétaire
If [M:ALL]PECOWNER=""
   [M:ALL]OWNFLG=2 : [M:ALL]NOTOWNFLG=1
   WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
Else
   [M:ALL]OWNFLG=2 : [M:ALL]NOTOWNFLG=2
   WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:ALL]PECOWNER)'
Endif

Raz WA, WQ, WR
If GTRUCOD<>""
   # Statuts autorisés par les rčgles d'allocation
   For I=0 To dim([F:TRU]STAFLT)-1
      If [F:TRU]STAFLT(I)<>0
         If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
         If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
         If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
      Endif
   Next I
Else
   WA=1
Endif

[M:ALL]XSTA=vireblc([M:ALL]XSTA,4)

If !find([M:ALL]XSTA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:ALL]XSTA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable ŕ tester
   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
Endif

WCRITSTOA = 'pat([F:STO]STA,"A*")<>0'
WCRITSTOQ = 'pat([F:STO]STA,"Q*")<>0'
WCRITSTOR = 'pat([F:STO]STA,"R*")<>0'

# Alimentation des zones de la fenętre critčre et du filtre
# pour contrôle ligne stock pickée (si non administrateur stock)
[M:ALL]AAASTA=1
[M:ALL]QQQSTA=1
[M:ALL]RRRSTA=1
# hcb V6percri deb
[M:ALL]FLGSHLLOT = 2
[M:ALL]FLGDLULOT = 2
If [F:SRU]SHLLOT = 2
   [M:ALL]FLGSHLLOT = 1
   [M:ALL]FLGDLULOT = 1
Endif
If [F:SRU]SHLLOT = 1
   [M:ALL]FLGSHLLOT = 1
   [M:ALL]FLGDLULOT = 2
Endif
# hcb V6percri fin

Raz WCRIT
If WA=1
   WCRIT+='pat([F:STO]STA,"A*")<>0'
   [M:ALL]AAASTA=2
Endif
If WQ=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"Q*")<>0'
   [M:ALL]QQQSTA=2
Endif
If WR=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"R*")<>0'
   [M:ALL]RRRSTA=2
Endif

If WCRITPIC<>""
   If WCRIT<>""
      WCRITPIC+='&('+WCRIT+')'
   Endif
Else
   If WCRIT<>""
      WCRITPIC+=WCRIT
   Else
      WCRITPIC='1=1'
   Endif
Endif

Raz WAFFPICK
# Affichage liste picking si qté rupture ou qté restant ŕ allouer
#MAE, le 24/09/2010, bg 67280 : affichage liste gauche si qté total < qté besoin
#If [M:ALL]SHTQTY<>0 | [M:ALL]PECQTY<[M:ALL]QTYTOALL
If [M:ALL]SHTQTY<>0 | [M:ALL]PECQTY<[M:ALL]RETQTY
   WAFFPICK=1
Endif

#Gosub TIROIR

#--- 73461
# Alimentation GRERBPC (consommation réservation client) pour calcul dispo
# selon paramčtre USERERBPC (consommation réservation client)
# Si ŕ la demande, GRERBPC reste ŕ 0 pour poser la question avant enregistrement
# Dans ce cas on ne tient pas compte des réservations client dans le calcul de dispo
If GRERBPC=0
   Case GUSERERBPC
    When 1 : GRERBPC = 1
    When 2 : GRERBPC = 2
    When Default :
   Endcase
Endif
#---

Return

#########################################################################
$ALI_MSK_ALL
Local Integer WSTOMGTCOD
Raz WSTOMGTCOD
WSTOMGTCOD = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD > 1
   WSTOMGTCOD = [F:ITF]STOMGTCOD
Endif

Raz [M:ALL]PECQTY
[M:ALL]COEFUCUS  = " ="+format$("N:5.4",[M:ALL]PCUSTUCOE)-[M:ALL]STU
[M:ALL]XALLTYP   = ""
If [M:ALL]OLDALLQTY<>0 | [M:ALL]SHTQTY<>0
   [M:ALL]XALLTYP = mess([M:ALL]ALLTYP,450,1)
Endif
[M:ALL]STOMGTCOD =  WSTOMGTCOD
[M:ALL]SERMGTCOD = [F:ITM]SERMGTCOD

NOL=0
#--- Issue 116917 (ajout SERNUM="")
For [STA]STA1 Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM &
&                   VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ &
&                   ITMREF=[M:ALL]ITMREF & ALLTYP=2 & SERNUM=""

   # S'il existe plusieurs allocations pour un męme chrono stock
   # réagrégation de ces allocations
   If NOL<>0 & [F:STA]STOCOU<>0
      I=find([F:STA]STOCOU,[M:ALL]STOCOU(0..NOL-1))
      If I<>0
         [M:ALL]ALLQTY(I-1)    += [F:STA]QTYSTUACT
         [M:ALL]PECQTY         += [F:STA]QTYSTUACT
         [M:ALL]AVAQTY(I-1)    += [F:STA]QTYSTUACT
         [M:ALL]ALLQTYPCU(I-1) += [F:STA]QTYSTUACT/[M:ALL]XPCUSTUCOE(I-1)
         Call QTEARR([M:ALL]ALLQTYPCU(I-1),[M:ALL]XPCU(I-1)) From TRTDIV
         #--- Issue 115740
         [M:ALL]ALLQTYORI(I-1) += [F:STA]QTYSTUACT
         Goto NEXT_STA
      Endif
   Endif

   [M:ALL]STOCOU(NOL) = [F:STA]STOCOU
   [M:ALL]ALLQTY(NOL) = [F:STA]QTYSTUACT
   [M:ALL]PECQTY     += [F:STA]QTYSTUACT
   #--- Issue 115740
   [M:ALL]ALLQTYORI(NOL) += [F:STA]QTYSTUACT
   Read [STO]STO0=[M:ALL]STOFCY;[F:STA]STOCOU
   If fstat
      Call ERREUR([M:ALL]STOFCY-num$([F:STA]STOCOU)-":"-mess(342,199,1)-
&                  num$([M:ALL]VCRTYP)-[M:ALL]VCRNUM-num$([M:ALL]VCRLIN)-
&                  num$([M:ALL]VCRSEQ)) From GESECRAN
      Goto NEXT_STA
   Endif
   If dim([M:ALL]LOT)>0
      [M:ALL]LOT(NOL) = [F:STO]LOT
      If dim([M:ALL]SLO)>0 [M:ALL]SLO(NOL)=[F:STO]SLO Endif
      Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
      If fstat
         Call ERREUR([F:STO]LOT-[F:STO]SLO-":"-mess(123,199,1)-[M:ALL]ITMREF)
&             From GESECRAN
         Goto NEXT_STA
      Endif
      If dim([M:ALL]SHLDAT)>0 [M:ALL]SHLDAT(NOL)=[F:STL]SHLDAT Endif
      If dim([M:ALL]POT)>0
         If [M:ALL]STOMGTCOD=3
            [M:ALL]POT(NOL) = [F:STL]POT
         Elsif [M:ALL]STOMGTCOD=4
            [M:ALL]POT(NOL) = [F:STL]ACT
         Endif
      Endif
   Endif
   #--- TS 106217
   If dim([M:ALL]ECCVALMAJ)>0 [M:ALL]ECCVALMAJ(NOL)=[F:STO]ECCVALMAJ Endif
   If dim([M:ALL]ECCVALMIN)>0 [M:ALL]ECCVALMIN(NOL)=[F:STL]ECCVALMIN Endif
   #---
   If dim([M:ALL]LOC)>0    [M:ALL]LOC(NOL)   =[F:STO]LOC     Endif
   If dim([M:ALL]SERNUM)>0 [M:ALL]SERNUM(NOL)=[F:STO]SERNUM  Endif
   If dim([M:ALL]PALNUM)>0 [M:ALL]PALNUM(NOL)=[F:STO]PALNUM  Endif
   If dim([M:ALL]CTRNUM)>0 [M:ALL]CTRNUM(NOL)=[F:STO]CTRNUM  Endif
   [M:ALL]STA(NOL)       = [F:STO]STA
   [M:ALL]OWNER(NOL)     = [F:STO]OWNER
   [M:ALL]XPCU(NOL)      = [F:STO]PCU
   [M:ALL]XPCUSTUCOE(NOL)= [F:STO]PCUSTUCOE
   If [M:ALL]XPCUSTUCOE(NOL)=0 [M:ALL]XPCUSTUCOE(NOL)=1 Endif
   [M:ALL]ALLQTYPCU(NOL) = [M:ALL]ALLQTY(NOL)/[M:ALL]XPCUSTUCOE(NOL)
   Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
   [M:ALL]TOTQTY(NOL)    = [F:STO]QTYSTUACT
   [M:ALL]AVAQTY(NOL)    = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
&                         +[M:ALL]ALLQTY(NOL)
   NOL += 1
#$NEXT_STA
Next

[M:ALL]NBLIG = NOL

Return
#########################################################################
#########################################################################
$ALI_MSK_ALL2
Local Integer WSTOMGTCOD
Raz WSTOMGTCOD
WSTOMGTCOD = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD > 1
   WSTOMGTCOD = [F:ITF]STOMGTCOD
Endif
NOL =0
Raz [M:ALL]PECQTY
[M:ALL]COEFUCUS  = " ="+format$("N:5.4",[M:ALL]PCUSTUCOE)-[M:ALL]STU
[M:ALL]XALLTYP   = ""
If [M:ALL]OLDALLQTY<>0 | [M:ALL]SHTQTY<>0
   [M:ALL]XALLTYP = mess([M:ALL]ALLTYP,450,1)
Endif
[M:ALL]STOMGTCOD =  WSTOMGTCOD
[M:ALL]SERMGTCOD = [F:ITM]SERMGTCOD
#B2C>
[M:ALL]QTYTOALL =[F:ZSOQ11]QTY-[F:ZSOQ11]DLVQTY-[F:ZSOQ11]ODLQTY
#B2C<
NOL=0
#--- Issue 116917 (ajout SERNUM="")
Filter [STA] Where VCRTYP=[M:ALL]VCRTYP & VCRNUM=[M:ALL]VCRNUM &
&                   VCRLIN=[M:ALL]VCRLIN & VCRSEQ=[M:ALL]VCRSEQ &
&                   ITMREF=[M:ALL]ITMREF & ALLTYP=2 & SERNUM=""
Read [STA]STA1 Last
If!fstat
   # S'il existe plusieurs allocations pour un męme chrono stock
   # réagrégation de ces allocations

   [M:ALL]ALLQTY(NOL)    += [F:STA]QTYSTUACT
   [M:ALL]PECQTY         += [F:STA]QTYSTUACT
   [M:ALL]AVAQTY(NOL)    += [F:STA]QTYSTUACT
    #FIXME : DIVISIÓN POR CERO
   #[M:ALL]ALLQTYPCU(NOL) += [F:STA]QTYSTUACT/[M:ALL]XPCUSTUCOE(NOL)
   Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
   #--- Issue 115740
   [M:ALL]ALLQTYORI(NOL) += [F:STA]QTYSTUACT


   [M:ALL]STOCOU(NOL) = [F:STA]STOCOU
   [M:ALL]ALLQTY(NOL) = [F:STA]QTYSTUACT
   [M:ALL]PECQTY     += [F:STA]QTYSTUACT
   #--- Issue 115740
   [M:ALL]ALLQTYORI(NOL) += [F:STA]QTYSTUACT
   Read [STO]STO0=[M:ALL]STOFCY;[F:STA]STOCOU
   If fstat
      Call ERREUR([M:ALL]STOFCY-num$([F:STA]STOCOU)-":"-mess(342,199,1)-
&                  num$([M:ALL]VCRTYP)-[M:ALL]VCRNUM-num$([M:ALL]VCRLIN)-
&                  num$([M:ALL]VCRSEQ)) From GESECRAN
      Goto NEXT_STA
   Endif


   [M:ALL]STA(NOL)       = [F:STO]STA
   [M:ALL]OWNER(NOL)     = [F:STO]OWNER
   [M:ALL]XPCU(NOL)      = [F:STO]PCU
   [M:ALL]XPCUSTUCOE(NOL)= [F:STO]PCUSTUCOE
   If [M:ALL]XPCUSTUCOE(NOL)=0 [M:ALL]XPCUSTUCOE(NOL)=1 Endif
   [M:ALL]ALLQTYPCU(NOL) = [M:ALL]ALLQTY(NOL)/[M:ALL]XPCUSTUCOE(NOL)
   Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
   [M:ALL]TOTQTY(NOL)    = [F:STO]QTYSTUACT
   [M:ALL]AVAQTY(NOL)    = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
&                         +[M:ALL]ALLQTY(NOL)
   #NOL += 1

Endif
$NEXT_STA


  [M:ALL]NBLIG = 1

Return
#########################################################################
$CRE_PIC
Raz NOL
Raz WPICKSTO
#FPH+
#La primera condición es para los casos que vienen de pedidos sin asignación, al no tener STOCOU en STOALL
#hay que buscar en stock por los filtros que tenemos disponibles en pantalla, y seleccionamos el último encontrado
#El segundo filtro lo hace por clave primaria y no habría problema

If [F:STO]STOCOU=0
   If [M:ZASGM0]ZLOCTYP <>"" Then
     Filter [F:STO] Where STOFCY = [M:ALL]STOFCY and ITMREF = [M:ALL]ITMREF and STA ="A" and LOC = [M:ZASGM0]ZLOCTYP
   Else
     Filter [F:STO] Where STOFCY = [M:ALL]STOFCY and ITMREF = [M:ALL]ITMREF and STA ="A"
   Endif
Else
   Filter [F:STO] Where STOFCY = [M:ALL]STOFCY  and STOCOU = [M:ALL]STOCOU
Endif
Read [STO]STO0 Last

#############ESTANDAR##################
#Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
#############ESTANDAR###################
#FPH-
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[M:ALL]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

#--- TS 106217
# Contrôle version par rapport ŕ la rčgle de gestion
If [F:STO]ECCVALMAJ<>""
  Call CTLECCVALMAJ([F:STO]ITMREF,[M:ALL]WECCVALMAJ,[F:STO]ECCVALMAJ,[M:ALL]RETDAT,"",LRET) From STKSOR
  If LRET<>0
    FOK=0 : GERR=1
    Return
  Endif
Endif
#---

# Contrôle si sortie mono-lot
If GUNTLOT=2 & [M:ALL]NBLIG>0
   If [F:STO]LOT<>[M:ALL]LOT(0)
      OK=1 : Call AVERTIR(mess(212,184,1), OK) From GESECRAN
      Raz GERR : # Sinon pas de dépick dans GSAISIE (la boule reste bleue)
      If OK=1  FOK=0 : Return  Endif
   Endif
Endif


# Si non administrateur stock, contrôle ligne pickée par rapport
# ŕ la péremption et ŕ la rčgle d'allocation
#FPH+
#If GSTOADMIN<>2
#   WPICKSTO=string$(evalue(WCRITPIC),"OK")
#   If WPICKSTO<>"OK"
#      FOK=0 : GERR=1
#      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
#      If dim([M:ALL]LOT)>0
#         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
#      Endif
#      GMESSAGE+="\"+mess(366,199,1)
#      Return
#   Endif
#Endif
#FPH-

# Calcul du stock disponible sur l'article
Raz LTYPLOC, LSTA
If [M:ALL]PECPLFLOC=2 LTYPLOC+=1 Endif
If [M:ALL]PECSCOLOC=2 LTYPLOC+=4 Endif
# Si pas d'emplacements internes
If [M:ALL]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
If [M:ALL]AAASTA=2    LSTA   +=1 Endif
If [M:ALL]QQQSTA=2    LSTA   +=2 Endif
If [M:ALL]RRRSTA=2    LSTA   +=4 Endif

Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:ALL]PECOWNER,WTOTACTDIS) From STKLIB

#--- Issue 105939
# On retire la somme des quantités saisies
#--- Issue 115937
# On retire la somme des quantités saisies diminuées des quantités déjŕ allouées
#WTOTACTDIS -= sum([M:ALL]ALLQTY)
#--- Issue X3-160680
#WTOTACTDIS -= sum([M:ALL]ALLQTY-[M:ALL]ALLQTYORI)
WTOTACTDIS -= sum([M:ALL]ALLQTY)-sum([M:ALL]ALLQTYORI)
#---
#---
#---

# On rajoute l'allouée global
WTOTACTDIS += [M:ALL]GLOALLQTY

#--- Bug 73461
# Si on doit consommer les réservations client, on les rajoutent
If [M:ALL]VCRTYP=2 & [M:ALL]BPCORD<>"" & dim(GRERBPC)>0 & GRERBPC<>1
   Call CAL_RERQTY(1,[M:ALL]ITMREF,[M:ALL]STOFCY,LNUM,[M:ALL]RETDAT,LQTA) From STKALL
   If LQTA<>0

      #--- Bug 74284
      #WTOTACTDIS += LQTA
      If GRERBPC=0
         GMESSAGE = mess(131,191,1)-":"-num$(LQTA)-[M:ALL]STU
         # Oui par défaut
         GRERBPC  = 1
         Call OUINON (GMESSAGE-"\"-mess(130,191,1),GRERBPC) From GESECRAN
         Raz GMESSAGE
      Endif
      If GRERBPC=2  WTOTACTDIS += LQTA  Endif
      #---

   Endif
Endif
#---

# Contrôle du disponible pour sortie sur la ligne de stock
Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#WSTUACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA

# Disponible = min(dispo ligne stock, dispo article)
#FPH+
#WDISPO = min(WSTUACTDIS,WTOTACTDIS)

# Pas de stock disponible
#If WDISPO<=0

If [M:ZASGM1]ZTOTASIG>[M:ZASGM1]ZSTOACTU Then
#FPH-
   FOK=0 : GERR=1
   If WTOTACTDIS <= 0
      GMESSAGE = mess(80,197,1)-[M:ALL]ITMREF-": "
   Else
      GMESSAGE = mess(644,197,1)-": "
   Endif
   GMESSAGE += mess(367,199,1)
   If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
      # La qté en attente de rangement est peut ętre dans une liste ŕ ranger
      GMESSAGE += "\"+mess(150,184,1)
   Endif
   Return
Endif

WQTY=[M:ALL]QTYTOALL-[M:ALL]PECQTY


# Ouverture de la ligne
#FPH+
#nolign = [M:ALL]NBLIG
#Insa nolign,1,[M:ALL]NBLIG [M:ALL]NBLIG
#[M:ALL]NBLIG += 1
#nolign = [M:ALL]NBLIG
#NOL = nolign-1
#FPH-
status = 0
#FIXME : ASIGNAR CANTIDAD NUEVA
If WDISPO>=WQTY
   [M:ALL]ALLQTY(NOL)=WQTY
Else
   [M:ALL]ALLQTY(NOL)=WDISPO
Endif
#FIXME : ASIGNAR CANTIDAD NUEVA
[M:ALL]ALLQTY(NOL)= ZP_QTY
[M:ALL]XPCU(NOL)       = [F:STO]PCU
[M:ALL]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE

If [M:ALL]XPCUSTUCOE(NOL)=0 [M:ALL]XPCUSTUCOE(NOL)=1 Endif
[M:ALL]ALLQTYPCU(NOL)  = [M:ALL]ALLQTY(NOL)/[M:ALL]XPCUSTUCOE(NOL)
Call QTEARR([M:ALL]ALLQTYPCU(NOL),[M:ALL]XPCU(NOL)) From TRTDIV
[M:ALL]AVAQTY(NOL)     = WSTUACTDIS
[M:ALL]TOTQTY(NOL)     = [F:STO]QTYSTUACT

If dim([M:ALL]LOT)>0    [M:ALL]LOT(NOL)    = [F:STO]LOT    Endif
If dim([M:ALL]SLO)>0    [M:ALL]SLO(NOL)    = [F:STO]SLO    Endif
If dim([M:ALL]LOC)>0    [M:ALL]LOC(NOL)    = [F:STO]LOC    Endif
If dim([M:ALL]SERNUM)>0 [M:ALL]SERNUM(NOL) = [F:STO]SERNUM Endif
# hcb 61170
If dim([M:ALL]CTRNUM)>0 [M:ALL]CTRNUM(NOL) = [F:STO]CTRNUM Endif
If dim([M:ALL]PALNUM)>0 [M:ALL]PALNUM(NOL) = [F:STO]PALNUM Endif
#--- TS 106217
If dim([M:ALL]ECCVALMAJ)>0 [M:ALL]ECCVALMAJ(NOL)=[F:STO]ECCVALMAJ Endif
If dim([M:ALL]ECCVALMIN)>0 [M:ALL]ECCVALMIN(NOL)=[F:STL]ECCVALMIN Endif
#---
#--- Issue X3-53322
If dim([M:ALL]LPNNUM)>0 [M:ALL]LPNNUM(NOL) = [F:STO]LPNNUM Endif
#---
[M:ALL]STA(NOL)        = [F:STO]STA

If dim([M:ALL]SHLDAT)>0 [M:ALL]SHLDAT(NOL) = [F:STL]SHLDAT Endif
If dim([M:ALL]POT)>0
   If [M:ALL]STOMGTCOD=3
      [M:ALL]POT(NOL) = [F:STL]POT
   Elsif [M:ALL]STOMGTCOD=4
      [M:ALL]POT(NOL) = [F:STL]ACT
   Endif
Endif

[M:ALL]OWNER(NOL)     = [F:STO]OWNER

[M:ALL]STOCOU(NOL)    = [F:STO]STOCOU

[M:ALL]PECQTY        += [M:ALL]ALLQTY(NOL)

Return

#########################################################################
$ENR
Local Integer WOPT, WRET, WALL
Local Decimal WALLQTY, WSHTQTY, WCSOQTY, WQTYSTU
Local Decimal WSVGQTY
Local Date    WDAT

$ENREG_S
Call DEBTRANS From GLOCK
Trbegin [STA]

# Lecture de l'article
If [F:ITM]ITMREF <> [M:ALL]ITMREF
   Read [ITM]ITM0=[M:ALL]ITMREF
   If fstat = 1
      GOK = -1
      GLOCK = "$ITMMASTER"-[M:ALL]ITMREF
      Goto ROLL_TRT
   Elsif fstat
      GOK = 0
      Call RSTA ("ITM",[M:ALL]ITMREF) From GLOCK
      Goto AB_TRT
   Endif
Endif
# Lecture de l'article-site
If [F:ITF]ITMREF <> [M:ALL]ITMREF & [F:ITF]STOFCY <> [M:ALL]STOFCY
   Read [ITF]ITF0=[M:ALL]ITMREF;[M:ALL]STOFCY
   If fstat = 1
      GOK = -1
      GLOCK = "$ITMFACILIT"-[M:ALL]ITMREF-[M:ALL]STOFCY
      Goto ROLL_TRT
   Elsif fstat
      GOK = 0
      Call RSTA ("ITF",[M:ALL]ITMREF-[M:ALL]STOFCY) From GLOCK
      Goto AB_TRT
   Endif
Endif

Raz WOPT, WRET
Raz WALLQTY, WSHTQTY

# Si alloc global, pas de ligne sélectionnée et qté ŕ allouer = qté origine
# --> rien ŕ faire
If [M:ALL]ALLTYP=1 & [M:ALL]PECQTY=0 & [M:ALL]QTYTOALL=[M:ALL]OLDALLQTY
   WALLQTY = [M:ALL]QTYTOALL
   Goto ENREG_FIN
Endif

# Suppression des allocations et manquants existants
If [M:ALL]OLDALLQTY <> 0 | [M:ALL]SHTQTY <> 0

   Call DELALL([M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,
&              [M:ALL]ITMREF,WOPT,WALLQTY,WSHTQTY,WRET)
   If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif
   WALLQTY = 0
   WSHTQTY = 0
Endif

WALL=1
WDAT=[0/0/0]
# Si alloc global, pas de ligne sélectionnée
If [M:ALL]ALLTYP=1 & [M:ALL]PECQTY=0
   # Si quantité ŕ allouer <> 0
   If [M:ALL]QTYTOALL<>0
      #--- TS 106217 ajout paramčtre LECC (avant dernier)
      Call CREALL(WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,0,WDAT,0,[M:ALL]QTYTOALL,[M:ALL]VCRTYP,
&                 [M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,"",[M:ALL]RETDAT,"","","","","","",
&                 0,0,"","",[M:ALL]BPCORD,[M:ALL]BPAADD,[M:ALL]PECSCOLOC,"",WRET)
      If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif
      WALLQTY = [M:ALL]QTYTOALL
   Endif
   Goto ENREG_FIN
Endif
[M:ALL]ALLTYP=2

WALL=2
WDAT=[0/0/0]

# Création des allocations
For I=0 To [M:ALL]NBLIG-1
    If [M:ALL]ALLQTY(I)=0 Goto NEXT_ALL Endif

    #--- Issue 114287
    Read [STO]STO0=[M:ALL]STOFCY;[M:ALL]STOCOU(I)
    If fstat Raz [F:STO] Endif
    #---

    WQTYSTU=[M:ALL]ALLQTY(I)
    # Si gestion en titres ou UI, calcul quantité en US
    Case [F:ITF]STOMGTCOD
     When 3 : If [M:ALL]ALLQTY(I)=[F:STO]QTYSTUACT          : #--- Issue 114287
                WQTYSTU=[F:STO]QTYSTU                   : #--- Issue 114287
              Elsif  dim([M:ALL]POT(I))>0
                WQTYSTU=[M:ALL]ALLQTY(I)/([M:ALL]POT(I)/100)
              Endif
              Call QTEARR(WQTYSTU,[M:ALL]STU) From TRTDIV   : #--- Issue 114037
     When 4 : If [M:ALL]ALLQTY(I)=[F:STO]QTYSTUACT          : #--- Issue 114287
                WQTYSTU=[F:STO]QTYSTU                   : #--- Issue 114287
              Elsif dim([M:ALL]ACT(I))>0
                WQTYSTU=[M:ALL]ALLQTY(I)/([M:ALL]ACT(I))
              Endif
              Call QTEARR(WQTYSTU,[M:ALL]STU) From TRTDIV   : #--- Issue 114037
    Endcase

    #--- TS 106217 ajout paramčtre LECC (avant dernier)
    Call CREALL (WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,[M:ALL]STOCOU(I),WDAT,WQTYSTU,
&               [M:ALL]ALLQTY(I),[M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,
&               "",[M:ALL]RETDAT,"","","","","","",0,0,LDEFLOC,LDEFLOCTYP,
&               [M:ALL]BPCORD,[M:ALL]BPAADD,[M:ALL]PECSCOLOC,"",WRET)
    If WRET<>0
       GOK=0 : GERR=1 : Goto AB_TRT
    Endif

    WALLQTY += [M:ALL]ALLQTY(I)

$NEXT_ALL
Next I

# Génération de rupture si nécessaire
If OKRUP=1
   #--- Bug 80267
   #WSHTQTY=[M:ALL]QTYTOALL-WALLQTY
   WSHTQTY=max(0,[M:ALL]QTYTOALL-WALLQTY)
   #---
   If WSHTQTY>0
      WQTYSTU=0
      WALL=4
      WDAT=[0/0/0]
      #--- TS 106217 ajout paramčtre LECC (avant dernier)
      Call CREALL (WALL,[M:ALL]STOFCY,[M:ALL]ITMREF,0,WDAT,WQTYSTU,WSHTQTY,
&                 [M:ALL]VCRTYP,[M:ALL]VCRNUM,[M:ALL]VCRLIN,[M:ALL]VCRSEQ,"",[M:ALL]RETDAT,
&                 WSHTLOT,"","",WSHTLOC,"",WSHTWRH,0,0,"","",[M:ALL]BPCORD,
&                 [M:ALL]BPAADD,[M:ALL]PECSCOLOC,WSHTECCVALMAJ,WRET)
      If WRET<>0
         GOK=0 : GERR=1 : Goto AB_TRT
      Endif
   Endif
Endif

Raz WCSOQTY
# Consommation des réservations client (production?)
If GRERBPC=2
   Case [M:ALL]VCRTYP
    When 2 : # Réservation client livré
             LQTA=WALLQTY-[M:ALL]OLDALLQTY
             Call CSOALL(1,LNUM,[M:ALL]ITMREF,[M:ALL]STOFCY,[M:ALL]RETDAT,
&                        LQTA,LRET) From STKALL
             If LRET=1 GOK=0 : GERR=1 : Goto AB_TRT : Endif
             WSVGQTY=LQTA
#             If LQTA>0
             If LQTA<WALLQTY-[M:ALL]OLDALLQTY
                LQTA=(WALLQTY-[M:ALL]OLDALLQTY)-LQTA
                # Réservation client
                Call CSOALL(1,[M:ALL]BPCORD,[M:ALL]ITMREF,[M:ALL]STOFCY,
&                          [M:ALL]RETDAT,LQTA,LRET) From STKALL
                If LRET=1 GOK=0 : GERR=1 : Goto AB_TRT : Endif
                WSVGQTY+=LQTA
             Endif
#             WCSOQTY=LQTA
             WCSOQTY=WSVGQTY
    When Default :
   Endcase
Endif

$ENREG_FIN
# Mises ŕ jour complémentaires relatives aux différentes fonctions appelantes
# WALLQTY contient la quantité allouée
# WSHTQTY contient la quantité en rupture
# WCSOQTY contient la quantité consommée sur les réservations clients
#FPH+

#Read [F:SOH]SOH0 = ZP_VCRNUM
#Filter [F:SOQ] Where SOHNUM = ZP_VCRNUM and SOPLIN = ZP_VCRLIN
#Read [F:SOQ]SOQ0 First
#[F:SOQ]ALLQTY    = ZP_QTY
#[F:SOQ]ALLQTYSTU = ZP_QTY
#[F:SOQ]ALLTYP    = 2
#Rewrite [F:SOQ]

#Gosub APRES_ENR From TRTSTOALLA
Gosub APRES_STOALL
#FPH-
If GOK=0
   GERR=1 : Goto AB_TRT
Endif

Commit

# Pour sortir
FIN = 1

Return

#########################################################################
# Rollback
$ROLL_TRT
Rollback
Call ROLL From GLOCK
If GROLL
   Return
Else
   Goto ENREG_S
Endif
#########################################################################
# Abandon
$AB_TRT
Rollback
Return
#########################################################################

#---------------------------------------------------------------------- #
# Mise ŕ jour complémentaires aprčs enregistrement                      #
# Si problčme mettre GOK=0 pour annuler l'enregistrement                #
# Cette étiquette est appelée depuis APRES_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$APRES_STOALL
Local Integer NL, WRET
Local Decimal WALLSTU
Local Char    WTRTLIG(1)

#[M:ALL]ALLTYP=2

If WCSOQTY<>0
    Local Char WVCRRER
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", [M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X", [M:ALL]BPAADD)
    WVCRRER = vireblc(WVCRRER, 1)
    # Si consommation des réservations clients : Maj de l'encours correspondant
    Call MAJORDBPC(1,WVCRRER,[M:SOH4]ITMREF(LNOL),[M:SOH4]DSTOFCY(LNOL),WCSOQTY,WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return Endif
Endif
#   Mise ŕ jour commande
Call MAJALLORD([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ALLTYP, 1, WALLQTY, WSHTQTY, WRET) From TRTVENALL
If WRET <> 0 : GOK = 0 : Return : Endif
#   Si Composé de kit, il faut allouer les composants
WALLSTU=WALLQTY+WSHTQTY
WALLSTU=WALLSTU-([M:SOH4]ALLQTYSTU(LNOL)+[M:SOH4]SHTQTYSTU(LNOL))
Raz WTRTLIG
If find([M:SOH4]LINTYP(LNOL),2,10) & WALLSTU <> 0
    If WALLSTU < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WALLSTU = abs(WALLSTU)
    Elsif WALLSTU > 0
# ----- C'est une augmentation de l'allocation
        If [M:SOH4]ALLQTYSTU(LNOL) = 0 & [M:SOH4]SHTQTYSTU(LNOL) = 0
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WALLSTU=WALLQTY+WSHTQTY
    Endif
    Call GENALLKIT ([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, WTRTLIG, GRERBPC, 2, 0, 1, 0, WALLSTU,
&                   WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return : Endif
Endif
#    Réaffichage du masque [M:SOH4]
If [F:SOH]SOHNUM <> [M:SOH0]SOHNUM
    Read [SOH]SOH0=[M:SOH0]SOHNUM
    If fstat : Return : Endif
Endif
#FPH+
#[M:SOH1]ALLSTA = [F:SOH]ALLSTA
#FPH-
If [F:SOQ]SOHNUM<>[M:SOH0]SOHNUM | [F:SOQ]SOPLIN<>[M:SOH4]SOPLIN(LNOL) | [F:SOQ]SOQSEQ<>[M:SOH4]SOPLIN(LNOL)
    Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(LNOL);[M:SOH4]SOPLIN(LNOL)
    If fstat : Return : Endif
Endif
[M:SOH4]ALLQTY(LNOL)    = [F:SOQ]ALLQTY
[M:SOH4]ALLQTYSTU(LNOL) = [F:SOQ]ALLQTYSTU
[M:SOH4]SHTQTY(LNOL)    = [F:SOQ]SHTQTY
[M:SOH4]SHTQTYSTU(LNOL) = [F:SOQ]SHTQTYSTU
[M:SOH4]DALLTYP(LNOL)   = [F:SOQ]ALLTYP

[M:SOH4]TALLQTYSTU(LNOL) = sum([F:SOQ]ALLQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)
[M:SOH4]TALLQTY(LNOL)    = sum([F:SOQ]ALLQTY,[F:SOQ]ODLQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY)
If [M:SOH0]SOHCAT = 3
    [M:SOH4]TALLQTYSTU(LNOL) += [F:SOQ]INVQTYSTU
    [M:SOH4]TALLQTY(LNOL)    += [F:SOQ]INVQTY
Else
    [M:SOH4]TALLQTYSTU(LNOL) += [F:SOQ]DLVQTYSTU
    [M:SOH4]TALLQTY(LNOL)    += [F:SOQ]DLVQTY
Endif
# --- Qté ŕ allouer = Qté déjŕ allouée
[M:SOH4]WALLQTY(LNOL)   = [F:SOQ]ALLQTY + [F:SOQ]SHTQTY
[M:SOH4]WALLQTYSTU(LNOL)= [F:SOQ]ALLQTYSTU + [F:SOQ]SHTQTYSTU
[M:SOH4]YALLQTY(LNOL)   = [M:SOH4]ALLQTY(LNOL)
[M:SOH4]YSHTQTY(LNOL)   = [M:SOH4]SHTQTY(LNOL)

Raz [M:SOH4]DLBQTYSTU (LNOL)
# Si kit/sous-traité, sauvegarde de l'indice du kit et de la qté cdée pour calcul qté livrable
If find([M:SOH4]LINTYP(LNOL),2,10)
    Local Decimal WKIT_QTYSTU  : Raz WKIT_QTYSTU
    If [M:SOH4]ALLQTYSTU(LNOL)<>0
        WKIT_QTYSTU=[M:SOH4]QTYSTU(LNOL)
        [M:SOH4]DLBQTYSTU(LNOL)=[M:SOH4]ALLQTYSTU(LNOL)
    Endif
Endif
#FPH+
#Affzo [M:SOH1]ALLSTA
#FPH-
If find([M:SOH4]LINTYP(LNOL),2,10) & WTRTLIG<>""
#   composé kit ou sous-traité : il faut réafficher tous les composants
    NL=LNOL+1
    While find([M:SOH4]LINTYP(NL),3,4,5,11,12,13) & NL < [M:SOH4]NBLIG
        Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(NL);[M:SOH4]SOPLIN(NL)
        If fstat : Break : Endif
        [M:SOH4]ALLQTY(NL)    = [F:SOQ]ALLQTY
        [M:SOH4]ALLQTYSTU(NL) = [F:SOQ]ALLQTYSTU
        [M:SOH4]SHTQTY(NL)    = [F:SOQ]SHTQTY
        [M:SOH4]SHTQTYSTU(NL) = [F:SOQ]SHTQTYSTU
        [M:SOH4]DALLTYP(NL)   = [F:SOQ]ALLTYP
        [M:SOH4]TALLQTYSTU(NL)= sum([F:SOQ]ALLQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)
        [M:SOH4]TALLQTY(NL)   = sum([F:SOQ]ALLQTY,[F:SOQ]ODLQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY)
        If [M:SOH0]SOHCAT = 3
            [M:SOH4]TALLQTYSTU(NL) += [F:SOQ]INVQTYSTU
            [M:SOH4]TALLQTY(NL)    += [F:SOQ]INVQTY
        Else
            [M:SOH4]TALLQTYSTU(NL) += [F:SOQ]DLVQTYSTU
            [M:SOH4]TALLQTY(NL)    += [F:SOQ]DLVQTY
        Endif
        # --- Qté ŕ allouer = Qté déjŕ allouée
        [M:SOH4]WALLQTY(NL)        = [F:SOQ]ALLQTY + [F:SOQ]SHTQTY
        [M:SOH4]WALLQTYSTU(NL)     = [F:SOQ]ALLQTYSTU + [F:SOQ]SHTQTYSTU
        [M:SOH4]YALLQTY(NL)   = [M:SOH4]ALLQTY(NL)
        [M:SOH4]YSHTQTY(NL)   = [M:SOH4]SHTQTY(NL)

        # Si composant de kit en rupture, calcul de la qté livrable pour le kit
        # --- Qté livrable = Qté allouée du kit - Qté Rupture ramenée au niveau kit
        If dim(WKIT_QTYSTU)>0 & WKIT_QTYSTU<>0 & [M:SOH4]SHTQTYSTU(NL)>0
            Local Decimal WRAPPORT : WRAPPORT=WKIT_QTYSTU / [M:SOH4]QTYSTU(NL)
            Local Decimal WDLBQTYSTU : WDLBQTYSTU=[M:SOH4]WALLQTYSTU(LNOL)-arr([M:SOH4]SHTQTYSTU(NL)*WRAPPORT,0.000001)
            If WDLBQTYSTU<[M:SOH4]DLBQTYSTU(LNOL) [M:SOH4]DLBQTYSTU(LNOL)=WDLBQTYSTU Endif
        Endif

        Affzo [M:SOH4]ALLQTY(NL), SHTQTY(NL), WALLQTY(NL)
        NL+=1
    Wend
Endif
Affzo [M:SOH4]ITMREF(LNOL), ALLQTY(LNOL), SHTQTY(LNOL), WALLQTY(LNOL), DALLTYP(LNOL)

# Si kit/sous-traité, affichage de la qté livrable
If !find([M:SOH4]LINTYP(LNOL),2,10) Return Endif
GERR=4: GMESSAGE="                                  "
If [M:SOH4]DLBQTYSTU(LNOL)<[M:SOH4]WALLQTYSTU(LNOL)
    Local Decimal WDLBQTY
    If [M:SOH4]SAUSTUCOE(LNOL)<>1
        WDLBQTY=[M:SOH4]DLBQTYSTU(LNOL)*(1/[M:SOH4]SAUSTUCOE(LNOL))
    Else
        WDLBQTY=[M:SOH4]DLBQTYSTU(LNOL)
    Endif
    Call QTEARR(WDLBQTY, [M:SOH4]SAU(LNOL)) From TRTDIV
    GMESSAGE=(mess(610,197,1)-num$(WDLBQTY)-[M:SOH4]SAU(LNOL))
Endif

Return

#######################################################################
# CREALL         Création d'une allocation
########################################################################
# Paramčtres E : LALL       = Type allocation (M.294)
#                LFCY       = Site
#                LITM       = Article
#                LCHR       = Chrono stock
#                LDAT       = Date fin réservation
#                LQTY       = Quantité en US
#                LQTA       = Quantité active
#                LTYP       = Type de pičce (M.701)
#                LNUM       = Numéro pičce
#                LLIN       = Numero ligne pičce
#                LSEQ       = Numero sequence pičce
#                LPRE       = Numéro préparation
#                LDTE       = Date du besoin
#                LLOT       = Lot (si rupture)
#                LSLO       = Sous-lot (si rupture)
#                LSTA       = Statut (si rupture)
#                LLOC       = Emplacement (si rupture)
#                LSER       = Série (si rupture)
#                LWRH       = Dépôt (si rupture)
#                LALLQTY    = Quantité US déjŕ allouée
#                LALLQTA    = Quantité active déjŕ allouée
#                LDEFLOC    = Emplacement de consommation
#                LDEFLOCTYP = Type emplacement de consommation
#                LBPR       = Tiers (si sous-traitance)
#                LADD       = Adresse de livraison (si sous-traitance)
#                LSCO       = Sous-traitance (2=matičre ŕ livrer)
#                LECC       = VERSION MAJEURE (SI RUPTURE)        #--- TS 106217
#            S : LRET       = Code retour (0=OK / 1=Erreur)
#
#-----------------------------------------------------------------------
# Entrée         [M:ALP]MVTDES pour stocker la désignation dans STOALL
#
########################################################################
#--- TS 106217
# Alimenter le paramčtre LECC dans tous les appels ŕ CREALL du traitement STKALL
#---
Subprog CREALL(LALL,LFCY,LITM,LCHR,LDAT,LQTY,LQTA,LTYP,LNUM,LLIN,LSEQ,
&              LPRE,LDTE,LLOT,LSLO,LSTA,LLOC,LSER,LWRH,LALLQTY,LALLQTA,
&              LDEFLOC,LDEFLOCTYP,LBPR,LADD,LSCO,LECC,LRET)       #--- TS 106217 (ajout LECC)
Value    Integer  LALL
Value    Char     LFCY
Value    Char     LITM
Value    Decimal  LCHR
Value    Date     LDAT
Value    Decimal  LQTY
Value    Decimal  LQTA
Value    Integer  LTYP
Value    Char     LNUM
Value    Integer  LLIN
Value    Integer  LSEQ
Value    Char     LPRE
Value    Date     LDTE
Value    Char     LLOT
Value    Char     LSLO
Value    Char     LSTA
Value    Char     LLOC
Value    Char     LSER
Value    Char     LWRH
Value    Decimal  LALLQTY
Value    Decimal  LALLQTA
Value    Char     LDEFLOC
Value    Char     LDEFLOCTYP
Value    Char     LBPR
Value    Char     LADD
Value    Integer  LSCO
Value    Char     LECC        #--- TS 106217
Variable Integer  LRET

Local    Integer  WALL
Local    Decimal  WQTY, WQTA, WALLQTY, WALLQTA
Local    Decimal  LSTOCOU
Local    Decimal  LWIPQTY
Raz LRET

If clalev([F:STA]) = 0 Local File STOALL [STA] : Endif
If clalev([F:ITV]) = 0 Local File ITMMVT [ITV] : Endif
If clalev([F:STO]) = 0 Local File STOCK  [STO] : Endif
If clalev([F:STC]) = 0 Local File STOLOC [STC] : Endif
#--- Issue 110327
If clalev([F:STS]) = 0 Local File STOSER [STS] : Endif
If [F:ITM]ITMREF<>LITM Read [ITM]ITM0=LITM Endif
#---
WALL    = LALL
WQTY    = LQTY
WQTA    = LQTA
WALLQTY = LALLQTY
WALLQTA = LALLQTA

# Pour utilisation de [F:STA]VCRTYP dans P.E. STOALL
[F:STA]VCRTYP = LTYP

# Maj du cumul alloué dans stock si allocation détaillé
If find(WALL,2,12)
   Gosub TRT_STO
  #--- Issue 110327
  # Suppression séries en cours de traitement
  #If LRET=0 & WALL=12 & LSER<>""
  #  If [F:ITM]SERMGTCOD=4
  #    Call DEL_STOSERW (LITM,LSER,LQTY,LRET) From STKLIB
  #    If LRET<>0 : GOK=0 Endif
  #  Endif
  #Endif
  # Gestion des séries en allocation
  If LRET=0 & [F:ITM]SERMGTCOD=4 & LSER<>""
    Call TRTSER(LITM,LSER,LQTY,LTYP,LNUM,LLIN,LRET) From STKALL
  Endif
  #--- End issue 110327
   WALL=2 : LALL=2
Endif
# Création allocation
Gosub TRT_ALL From STKALL
# Maj cumuls article-site
Gosub TRT_ITV From STKALL

If LRET<>0 & GMESSAGE<>""
   #--- Issue 116570
   If GTRACE=""
      Call ERREUR(GMESSAGE) From GESECRAN
   Else
      Call ECR_TRACE(GMESSAGE,1)  From GESECRAN
   Endif
   #Call ERREUR(GMESSAGE) From GESECRAN
   #---
   Raz GMESSAGE
Endif

End

########################################################################
# Lecture ligne stock pour vérification et mise ŕ jour
########################################################################
$TRT_STO
#--- Issue 116401 : ajout With lockwait=3
#--- Issue X3-74576 : suppression lockwait=3

Readlock [STO]STO0=LFCY;LCHR
If fstat
   Call RSTA("STO",LFCY-num$(LCHR)) From GLOCK
   GOK=0 : LRET=1
Else

   [F:STO]CUMALLQTY += WQTY
   [F:STO]CUMALLQTA += WQTA
   # Si gestion d'en-cours d'allocation, dégestion de celui-ci
   If WALL=12
      [F:STO]CUMWIPQTY -= max(0,WQTY-WALLQTY)
      [F:STO]CUMWIPQTA -= max(0,WQTA-WALLQTA)
      # Dans le cas oů l'on serait passé en négatif
      [F:STO]CUMWIPQTY  = max(0,[F:STO]CUMWIPQTY)
      [F:STO]CUMWIPQTA  = max(0,[F:STO]CUMWIPQTA)

      # Suppression qté en cours de traitement
      LSTOCOU = [F:STO]STOCOU
      LWIPQTY = WQTY-WALLQTY
      Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB

   Endif
   # Si augmentation qté allouée et cumul qté allouée <= qté stock
   # ou diminution qté allouée et cumul qté allouée >= 0

   If (WQTA>=0 & [F:STO]CUMALLQTA<=[F:STO]QTYSTUACT)
&   | (WQTA<=0 & [F:STO]CUMALLQTA>=0)
      [F:STO]UPDDAT     = date$
      [F:STO]UPDUSR     = GUSER
      [F:STO]EXPNUM     = [C]EXPORT
      Call REWSTOA From STKLIB
      If fstat
         GOK=0 : Call FSTA("STO") From GLOCK
         LRET=1
      Else
         #DA ERROR EL PUNTO DE ENTRADA
         #FPH+
         #GPOINT="ALLSTO" : Gosub ENTREE From EXEFNC
         #FPH-
      Endif

   # Le stock a évolué (un utilisateur a pris le stock par ex:)
   Else
      GOK=0
      Raz GMESSAGE
      GMESSAGE+=[F:STO]ITMREF
      If [F:STO]LOT<>""    GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT    Endif
      If [F:STO]SLO<>""    GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO   Endif
      If [F:STO]SERNUM<>""
         If GMESSAGE<>"" GMESSAGE+="\" Endif
         GMESSAGE+=mess(47,197,1)-":"-[F:STO]SERNUM
      Endif
      If [F:STO]LOC<>""
         If GMESSAGE<>"" GMESSAGE+="\" Endif
         GMESSAGE+=mess(44,197,1)-":"-[F:STO]LOC
      Endif
      If [F:STO]STA<>""
         If GMESSAGE<>"" GMESSAGE+="\" Endif
         GMESSAGE+=mess(399,198,1)-":"-[F:STO]STA
      Endif
      GMESSAGE+="\"+mess(45,196,1)-num$(WQTY)-mess(46,196,1)-num$([F:STO]QTYSTU-[F:STO]CUMALLQTY+WQTY)
      GMESSAGE+="\"+mess(585,196,1)
      LRET=1
   Endif
Endif
Return

########################################################################
# DELALL         Suppression des allocations d'une ligne de document
########################################################################
# Paramčtres E : LTYP = Type de pičce (M.701)
#                LNUM = Numéro pičce
#                LLIN = Numero ligne pičce
#                LSEQ = Numero sequence pičce
#                LITM = Article
#                LOPT = Option suppression : 0 allocations + manquants
#                                            1 allocations seules
#                                            2 manquants seuls
#                       +10 si pas de suppression des allocations/manquants
#                           en cours de réapprovisionnement (SRGNUM<>"")
#                           --> 10, 11 ou 12
#            S : LQTA = Total allocations supprimées  (en UA)
#                LSHT = Total manquants supprimées    (en UA)
#                LRET = Code retour (0=OK / 1=Erreur)
#
########################################################################
Subprog DELALL(LTYP,LNUM,LLIN,LSEQ,LITM,LOPT,LQTA,LSHT,LRET)
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Value    Char    LITM
Value    Integer LOPT
Variable Decimal LQTA
Variable Decimal LSHT
Variable Integer LRET

Local  Char      WCRITSTA(240)
Local  Integer   WRET
Local  Decimal   WCHR
Local  Integer   WSEQ

Raz LRET, LQTA, LSHT

If clalev([F:STA1])=0  Local File STOALL [STA1]  Endif
#--- Bug 84767
If clalev([F:STA2])=0  Local File STOALL [STA2]  Endif

WCRITSTA = 'VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN & VCRSEQ=LSEQ'
If LITM<>""
   WCRITSTA += '& ITMREF=LITM'
Endif

For [STA1]STA1 Where evalue(WCRITSTA)

   GOK=1
   #FPH+
   #GPOINT="DELALL" : Gosub ENTREE From EXEFNC
   #FPH-
   If GOK=0
      GOK=1 : Goto NEXT_STA1
   Endif

   Case [F:STA1]ALLTYP
    When 1,2 : If (LOPT=0 | LOPT=1) | ((LOPT=10 | LOPT=11)& [F:STA1]SRGNUM="") : #--- Bug 84767
                  LQTA += [F:STA1]QTYSTUACT
                  WCHR  = [F:STA1]STOCOU
                  WSEQ  = [F:STA1]SEQ
                  Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,WCHR,WSEQ,WRET)
                  If WRET<>0 : LRET=WRET : Break : Endif
                  #--- Bug 84767
                  #--- Bug 99909
                  #If [F:STA1]SRGNUM<>""
                  If [F:STA1]SRGNUM<>"" & [F:STA1]VCRNUM<>[F:STA1]SRGNUM
                  #---
                     Gosub SUPALL_REO
                     If LRET<>0 : Break : Endif
                  Endif
                  #---
               Endif
    When 4,5 : If (LOPT=0 | LOPT=2) | ((LOPT=10 | LOPT=12)& [F:STA1]SRGNUM="") : #--- Bug 84767
                  LSHT += [F:STA1]QTYSTUACT
                  WCHR  = [F:STA1]STOCOU
                  WSEQ  = [F:STA1]SEQ
                  Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,WCHR,WSEQ,WRET)
                  If WRET<>0 : LRET=WRET : Break : Endif
                  #--- Bug 84767
                  #--- Bug 99909
                  #If [F:STA1]SRGNUM<>""
                  If [F:STA1]SRGNUM<>"" & [F:STA1]VCRNUM<>[F:STA1]SRGNUM
                  #---
                     Gosub SUPALL_REO
                     If LRET<>0 : Break : Endif
                  Endif
                  #---
               Endif
  Endcase
  $NEXT_STA1
Next

End

#--- Bug 84767
#--------------------------------------------------------
# Suppression des allocations de réapprovisionnement
# des zones de consommations ou ruptures sur emplacement
#--------------------------------------------------------
$SUPALL_REO
Filter [STA2] Where [F:STA2]ITMREF=[F:STA1]ITMREF & [F:STA2]VCRTYP=34
&                 & [F:STA2]STOFCY=[F:STA1]STOFCY & [F:STA2]ALLTYP=2
&                 & [F:STA2]SRGNUM=[F:STA1]SRGNUM & [F:STA2]SRGLIN=[F:STA1]SRGLIN
&             Order By Key STA2
For [STA2]
    WCHR = [F:STA2]STOCOU
    WSEQ = [F:STA2]SEQ
    Call SUPALL([F:STA2]STOFCY,[F:STA2]ITMREF,WCHR,WSEQ,WRET)
    If WRET<>0 : LRET=WRET : Break : Endif
Next
Filter [STA2]
Return
#---
########################################################################
# SUPALL         Suppression d'une allocation
########################################################################
# Paramčtres E : LFCY = Site
#                LITM = Article
#                LCHR = Chrono stock
#                LCLE = Numero séquence attribué
#            S : LRET = Code retour (0=OK / 1=Erreur)
#
########################################################################
Subprog SUPALL(LFCY,LITM,LCHR,LCLE,LRET)
Value    Char     LFCY
Value    Char     LITM
Value    Decimal  LCHR
Value    Integer  LCLE
Variable Integer  LRET

Local    Integer  WALL
Local    Decimal  WQTY, WQTA
Local    Decimal  LSTOCOU
Local    Decimal  LWIPQTY
Raz LRET

If clalev([F:STA2]) = 0 Local File STOALL [STA2] : Endif
If clalev([F:ITV]) = 0 Local File ITMMVT [ITV] : Endif
If clalev([F:STO]) = 0 Local File STOCK  [STO] : Endif
#--- Issue 110327
If clalev([F:STS]) = 0 Local File STOSER [STS] : Endif
If [F:ITM]ITMREF<>LITM Read [ITM]ITM0=LITM Endif
#---
Readlock [STA2]STA0=LFCY;LITM;LCHR;LCLE
#FPH-

If fstat=1
   GOK=-1 : GLOCK = "$STOALL"-LFCY-LITM-num$(LCHR)-num$(LCLE)
   LRET=1
Elsif fstat
   GOK=0 : Call RSTA("STA",LFCY-LITM-num$(LCHR)-num$(LCLE)) From GLOCK
   LRET=1
Else
   WALL = [F:STA2]ALLTYP
   WQTY = 0-[F:STA2]QTYSTU
   WQTA = 0-[F:STA2]QTYSTUACT
   # Maj du cumul alloué dans stock si allocation détaillé
   If WALL=2
      Gosub TRT_STO
      # Point d'entrée pour écriture dans une trace
      If GTRACE<>"" GPOINT="ECRTRACE" : Gosub ENTREE From EXEFNC Endif
      #--- Issue 110327
      # Gestion des séries en allocation
      #FPH+
#      If LRET=0 & [F:ITM]SERMGTCOD=4 & [F:STA2]SERNUM<>""
#         Call TRTSER(LITM,[F:STA2]SERNUM,[F:STA2]QTYSTU*(-1),[F:STA2]VCRTYP,
#&                    [F:STA2]VCRNUM,[F:STA2]VCRLIN,LRET)
#      Endif
       #FPH-
      #---
   Endif
   # Suppression allocation

   If LRET=0
      Delete [STA2]
      If fstat
         GOK=0 : Call FSTA("STA") From GLOCK
         LRET=1
      Endif
   Endif

   # Maj cumuls article-site
   Gosub TRT_ITV
Endif

If LRET<>0 & GMESSAGE<>""
   #--- Issue 116570
   If GTRACE=""
      Call ERREUR(GMESSAGE) From GESECRAN
   Else
      Call ECR_TRACE(GMESSAGE,1)  From GESECRAN
   Endif
   #Call ERREUR(GMESSAGE) From GESECRAN
   #---
   Raz GMESSAGE
Endif

End
########################################################################
# Mise ŕ jour des cumuls articles
########################################################################
$TRT_ITV

If LRET<>0 Return Endif

#--- Issue 116401 : ajout With lockwait=3
#--- Issue X3-74576 : suppression lockwait=3
Readlock [ITV]ITV0=LITM;LFCY
If fstat=1
   GOK=-1 : GLOCK = "$ITMMVT"-LITM-LFCY
   LRET=1
Elsif fstat
   # Création ITV
   Raz [F:ITV]
   [F:ITV]ITMREF=LITM
   [F:ITV]STOFCY=LFCY
   Case WALL
    When 1 : [F:ITV]GLOALL = WQTA
    When 2 : If find([F:STO]OWNER,LFCY,"")
                If [F:STO]LOCCAT=4
                   Case left$([F:STO]STA,1)
                    When "A" : [F:ITV]SCOPHYALL = WQTA
                    When "Q" : [F:ITV]SCOCTLALL = WQTA
                    When "R" : [F:ITV]SCOREJALL = WQTA
                   Endcase
                Else
                   Case left$([F:STO]STA,1)
                    When "A" : [F:ITV]PHYALL = WQTA
                    When "Q" : [F:ITV]CTLALL = WQTA
                    When "R" : [F:ITV]REJALL = WQTA
                   Endcase
                Endif
             Else
                [F:ITV]SCCALL = WQTA
             Endif
    When 4 : [F:ITV]DETSHT = WQTA
    When 5 : [F:ITV]GLOSHT = WQTA
    When Default
   Endcase
   #########################################################
   # Il faudra voir ce que l'on fait avec TRFSTO et TRASTO
   # si transfert inter-site : ŕ priori rien
   #########################################################
   # Si transfert inter-site
   #If LTYP=22 [F:ITV]TRFSTO=WQTA Endif

   Call ECRITV From STKLIB
   If fstat
      GOK=0 : Call FSTA("ITV") From GLOCK
      LRET=1
   Endif
Else
   # Mise ŕ jour ITV
   Case WALL
    When 1 : [F:ITV]GLOALL += WQTA
    When 2 : If find([F:STO]OWNER,LFCY,"")
                If [F:STO]LOCCAT=4
                   Case left$([F:STO]STA,1)
                    When "A" : [F:ITV]SCOPHYALL += WQTA
                    When "Q" : [F:ITV]SCOCTLALL += WQTA
                    When "R" : [F:ITV]SCOREJALL += WQTA
                   Endcase
                Else
                   Case left$([F:STO]STA,1)
                    When "A" : [F:ITV]PHYALL += WQTA
                    When "Q" : [F:ITV]CTLALL += WQTA
                    When "R" : [F:ITV]REJALL += WQTA
                   Endcase
                Endif
             Else
                [F:ITV]SCCALL += WQTA
             Endif
    When 4 : [F:ITV]DETSHT += WQTA
    When 5 : [F:ITV]GLOSHT += WQTA
    When Default
   Endcase
   #########################################################
   # Il faudra voir ce que l'on fait avec TRFSTO et TRASTO
   # si transfert inter-site : ŕ priori rien
   #########################################################
   # Si transfert inter-site
   #If LTYP=22 [F:ITV]TRFSTO+=WQTA Endif

   Call REWITV From STKLIB
   If fstat
      GOK=0 : Call FSTA("ITV") From GLOCK
      LRET=1
   Endif

Endif
Return
