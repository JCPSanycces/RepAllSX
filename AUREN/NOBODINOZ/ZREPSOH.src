#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Modificación de representantes de pedidos en base a representantes de la ficha de clientes

If !clalev([F:ZBPC1]) : Local File BPCUSTOMER [F:ZBPC1] : Endif
If !clalev([F:ZSOH1]) : Local File SORDER     [F:ZSOH1] : Endif
If !clalev([F:ZSOP1]) : Local File SORDERP    [F:ZSOP1] : Endif
Local Integer ZCONTCAB,ZCONTLIN : Raz ZCONTCAB,ZCONTLIN

For [F:ZBPC1]BPC0
  For [F:ZSOH1]SOH0 Where BPCORD = [F:ZBPC1]BPCNUM
     [F:ZSOH1]REP(0) = [F:ZBPC1]REP(0)
     [F:ZSOH1]REP(1) = [F:ZBPC1]REP(1)
     Rewrite [F:ZSOH1]
     ZCONTCAB+=1
     For [F:ZSOP1]SOP0 Where SOHNUM = [F:ZSOH1]SOHNUM
       [F:ZSOP1]REP1 = [F:ZBPC1]REP(0)
       [F:ZSOP1]REP2 = [F:ZBPC1]REP(1)
       Rewrite [F:ZSOP1]
       ZCONTLIN+=1
     Next
  Next
Next
Infbox "PEDIDOS MODIFICADOS"-num$(ZCONTCAB)-"- LÍNEAS MODIFICADAS"-num$(ZCONTLIN)
End
