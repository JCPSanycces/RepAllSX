#<AdxTL>@(#)0.0.0.0 $Revision$ Facturas
# 6.187.210 ML 11/09/2021 Interface Magento 2
$ACTION
Case ACTION
 When "VERF_ANU"  : Gosub VERF_ANU
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When Default
Endcase
Return

#################################################
$VERF_ANU
  If GUSER <>"ADMIN" and ([F:SIH]INVTYP = 1 or [F:SIH]INVTYP = 2) and [F:SIH]FCY ="090" Then
    Call MESSAGE("No tiene permisos para borrar este documento")From GESECRAN
    OK = 0
    Return
  Endif
Return

#################################################
$AP_ANNULE
# 6.187.210.ini
If [M:SIH1]SIHORINUM <> "" and [M:SIH1]SIHORI = 3
  If !clalev([F:ZMG2DEL]) : Local File ZMG2DEL[ZMG2DEL]  : Endif
  Raz [F:ZMG2DEL]
  [F:ZMG2DEL]VCRNUM=[M:SIH1]SIHORINUM
  Write [F:ZMG2DEL]
Endif
# 6.187.210.fin
Return
