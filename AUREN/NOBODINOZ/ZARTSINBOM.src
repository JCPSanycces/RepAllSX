#<AdxTL>@(#)0.0.0.0 $Revision$ 
#ARTëCULOS sin BOM Y METODO VALORACIÆN <> SAC -> TIENEN QUE SER SAC

Call COMPROBAR_ART()
End
Subprog COMPROBAR_ART()
   If !clalev([F:ZITF])  :   Local File ITMFACILIT[F:ZITF]  : Endif
   If !clalev([F:ZBOH])  :   Local File BOM       [F:ZBOH]  : Endif
   #Local Integer ZCONT: Raz ZCONT
   Filter [F:ZITF] Where VLTCOD<>'SAC'
   Read [F:ZITF]ITF0 First
   For  [F:ZITF]ITF0
     For [F:ZBOH]BOH0 Where ITMREF = [F:ZITF]ITMREF
      # Infbox [F:ZITF]ITMREF- [F:ZITF]VLTCOD
       [F:ZITF]VLTCOD ='SAC'
       Rewrite [F:ZITF]
       #ZCONT+=1
     Next
   Next
   #Infbox "Registors modificados"-num$(ZCONT)
End

