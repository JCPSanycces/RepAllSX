#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAM ZMG2IMPB2C: IMPORTACION PEDIDOS B2B MAGENTO 2                                                ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 23/08/2021                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 00.000.000                                                                    ##
## OBJETIVO: DESCARGA VIA FTP LOS FICGEROS DE PEDIDOS B2  PARA SER IMPORTADOS EN SAGE X3,               ##
##                                                                                                      ##
##########################################################################################################
Gosub INIT
Gosub EXEC
End
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I
  Local Integer J
  Local Integer NL

  Call ECR_TRACE("Iniciando importación Pedidos Magento 2",0) From GESECRAN

  DIRAPL=filpath("","","") :                      # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Magento\IMPORT\PedidosB2C"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

  ORDRE = "MOVE *.err "+DIRPRO
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

Return

$EXEC

  Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  Call FTPGETDEL("62.97.118.63","ftp_nobo7importerp","nataiFovoo7Een3g","qa/MG_TO_SAGE/PedidosB2C",DIRFTP,RES) From ZAURFTP
  If RES < 0
    Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN
  Else
    Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN
  Endif

  #Process the dodnloaded files

  #Clientes
  ORDRE = "dir /b "+DIRFTP+"\CB2C*.csv 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros, Clientes",0) From GESECRAN

    For J = 1 To RES
      FILNAME = DIRFTP+"\"+left$(FILELIST(J),len(FILELIST(J))-4)
      Call IMPORTSIL("ZBPCMG2B2C",FILNAME+".csv") From GIMPOBJ

      ORDRE = "MOVE "+FILNAME+".csv "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      ORDRE = "MOVE "+FILNAME+".csv.err "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
    Next J

    Call ECR_TRACE("Fin del procesado de ficheros, Clientes. Ficheros procesados: "+num$(J-1),0) From GESECRAN

  Endif

  #Pedidos
  ORDRE = "dir /b "+DIRFTP+"\PB2C*.csv 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros, Pedidos",0) From GESECRAN

    For J = 1 To RES
      FILNAME = DIRFTP+"\"+left$(FILELIST(J),len(FILELIST(J))-4)
      Call IMPORTSIL("ZSOHMG2TOC",FILNAME+".csv") From GIMPOBJ

      ORDRE = "MOVE "+FILNAME+".csv "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      ORDRE = "MOVE "+FILNAME+".csv.err "+DIRPRO
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
    Next J

    Call ECR_TRACE("Fin del procesado de ficheros, Pedidos. Ficheros procesados: "+num$(J-1),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End
