#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
## PROGRAMA ZIMPEXPNKO: IMPORTACION EXPEDICIONES NAEKO                                                  ##
## AUTOR: AUREN                                                                                         ##
## FECHA: 04/06/2020                                                                                    ##
## VERSION: 1.0                                                                                         ##
## DOC. ESPECIFICACIONES: 00.000.000                                                                    ##
## OBJETIVO: DESCARGA VIA FTP LOS FICGEROS DE EXPEDICIONES PARA SER IMPORTADOS EN SAGE X3, ADECUANDO    ##
##           EL NUMERO DE PEDIDO Y EL ESTADO DE LA ENTREGA                                              ##
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When "EXEC"   : Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$INIT

  If GSERVEUR : Onerrgo ERRBATCH : Endif

  Local Char DIRAPL(GDIMFIC)
  Local Char DIRFTP(GDIMFIC)
  Local Char DIRPRO(GDIMFIC)
  Local Char ORDRE(GDIMFIC)
  Local Char FILNAME(GDIMFIC)
  Local Integer STAT
  Local Char LFILES(GDIMFIC)(1..100)
  Local Char FILELIST(GDIMFIC)(1..100)
  Local Integer RES
  Local Integer I

  Local Char SDHNUM(15)                         #Num. entrega
  Local Char ZSTANAEKO(1)                       #Estado entrega
  Local Char ZZGROWEI(15)                       #Peso
  Local Char ZZVOLUM(15)                        #Volúmen
  Local Char ZZNUMBOX(15)                       #Cajas
  Local Char PACNBR(15)                         #Bultos
  Local Char DPEDAT(8)                          #Fecha salida
  Local Char ETD(7)                             #Hora salida
  Local Char HEADER(250)(1..)

  Call ECR_TRACE("Iniciando importación Expediciones Naeko",0) From GESECRAN

  DIRAPL=filpath("","","") :        # Obtenemos ruta del folder
  DIRFTP = DIRAPL+"\FTP\Naeko\Expediciones"
  DIRPRO = DIRFTP+"\Proc"
  RES = filinfo (DIRPRO,7)
  If RES = -27 : End : Endif
  If RES = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+DIRPRO+'"',"",STAT) From ORDSYS : Endif

Return

$EXEC

  Call ECR_TRACE("Descargando ficheros",0) From GESECRAN

  RES = 0
  Call FTPGETDEL("ftp.naeko.es","Nobodinoz","357Nz69+","Expediciones",DIRFTP,RES) From ZAURFTP

  If RES < 0

    Call ECR_TRACE("No se pudo realizar la descarga de ficheros. Error: "+num$(RES),1) From GESECRAN

  Else

    Call ECR_TRACE("Descarga de ficheros completada. Ficheros descargados: "+num$(RES),0) From GESECRAN

  Endif

#Process the dodnloaded files

  ORDRE = "dir /b "+DIRFTP+"\*.csv 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

  If RES > 0

    If RES > 100 : RES = 100 : Endif

    Call ECR_TRACE("Iniciando el procesado de "+num$(RES)+" ficheros",0) From GESECRAN

    For I = 1 To RES

      FILNAME = DIRFTP+"\"+left$(FILELIST(I),len(FILELIST(I))-4)

      Openi FILNAME+".csv", 0 Using [FIN]

      Iomode adxifs "" Using [FIN]                                      # Separador de campo nulo para primera línea
      Iomode adxirs chr$(13)+chr$(10) Using [FIN]                       # Separador de registro
      Iomode adxium 50 Using [FIN]                                      # ASCII file
      Rdseq HEADER Using [FIN]                                          # Drop header

      Iomode adxifs ";" Using [FIN]                                     # Separador de campo ";"
      Rdseq SDHNUM,ZSTANAEKO,ZZGROWEI,ZZVOLUM,ZZNUMBOX,PACNBR,DPEDAT,ETD Using [FIN]

      SDHNUM = "DEL"+ctrans(SDHNUM,chr$(34),"")                          #Remove the " IN THE RECIVIED Field and ADD DEL PREFIX
      ETD = ctrans(ETD,chr$(34),"")                                      #Remove the " in the recivied field

      Openo FILNAME+".pro", 0 Using [FOUT]

      Iomode adxifs ";" Using [FOUT]
      Iomode adxirs chr$(13)+chr$(10) Using [FOUT]
      Iomode adxium 0 Using [FOUT]

      Wrseq SDHNUM,ZSTANAEKO,ZZGROWEI,ZZVOLUM,ZZNUMBOX,PACNBR,DPEDAT,ETD Using [FOUT]

      Openi  Using [FIN]
      Openo  Using [FOUT]

      #Call IMPORTSIL("ZNKSDH",FILNAME+".pro") From GIMPOBJ

      #ORDRE = "MOVE "+FILNAME+".pro "+DIRPRO
      #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      #ORDRE = "MOVE "+FILNAME+".csv "+DIRPRO
      #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS
      #ORDRE = "MOVE "+FILNAME+".pro.err "+DIRPRO
      #Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

    Next I

  Call ECR_TRACE("Fin del procesado de ficheros. Ficheros procesados: "+num$(RES),0) From GESECRAN

  Endif

Return

##########################################################################################################
#                            ERROR BATCH
##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl),1) From GESECRAN
End

