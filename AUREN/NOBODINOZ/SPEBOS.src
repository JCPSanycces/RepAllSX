#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################
$ACTION
  Case ACTION
   When "SETBOUT"    : Gosub SETBOUT
   When "AVANTBOUT"  : Gosub AVANTBOUT
   When Default
  Endcase
Return

################################################################
$SETBOUT
  If !clalev([F:ZITM2]) : Local File ITMMASTER   [F:ZITM2] : Endif
  Read [F:ZITM2]ITM0 = [M:BOH0]ITMREF
  If [F:ZITM2]ZARTGEN = 2 Then
    CHMEN+="2"
  Endif
Return
################################################################
$AVANTBOUT
  If BOUT ="2" Then
   Call CRE_ACT_BOM ([M:BOH0]ITMREF,"","","","","","") From SPEZCMB
  Endif
Return
