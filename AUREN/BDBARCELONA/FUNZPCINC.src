#<AdxTL>@(#)9.0.0.0 $Revision:   1.6  $
######################################################################## 
#                                                 JL - Septembre 2000  #
#    REVISION DES TARIFS VENTE : LANCEMENT                             #
#                                                                      #
#    - Traitement        : FUNZPCINC                                   #
#    - Action e_commerce : SAIZPCINC (Saisie fenõtre)                  #
#                          TRTPPCINC (Traitement standard)??????xbb    #
#                          VISUSINCL (Saisie fenõtre)                  #
#----------------------------------------------------------------------# 
# Table mise Á jour  : PPRICFICH [F:PPF]                               # 
#                      PPRICLIST [F:PPL]                               # 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             de l'Õcran PPCINCR [M:ZPCI]                              # 
######################################################################## 

######################################################################## 
# Etiquettes ACTION
######################################################################## 
$ACTION
#--- Actions liÕes Á la saisie fenõtre des variables
Case ACTION
  When "OUVRE"        : Case GACTION
                          When "SAIZPCINC"    : Gosub OUVRE_SAIZPCINC
                        Endcase  
  When "DEBUT"        : Case GACTION 
                          When "SAIZPCINC"    : Gosub DEBUT_SAIZPCINC
                        Endcase  
  When "SETBOUT"      : Case GACTION 
                          When "SAIZPCINC"    : Gosub SETBOUT_SAIZPCINC
                        Endcase  
  When "BOUTON"       : Case GACTION 
                          When "SAIZPCINC"    : Gosub BOUCLE_SAIZPCINC
                        Endcase  
  When "OK"           : Case GACTION 
                          When "SAIZPCINC"    : Gosub BOUCLE_SAIZPCINC
                        Endcase  
  When "FIN"          : Case GACTION 
                          When "SAIZPCINC"    : Gosub FIN_SAIZPCINC
                        Endcase  
  When Default
Endcase

#--- Actions liÕes au traitement standard de mise Á jour
Case ACTION
  When "INIT"         : Case GACTION
                          When "TRTPPCINC"    : Gosub INIT_TRTPPCINC
                        Endcase  
  When "AVANT_PAR"    : Case GACTION 
                          When "TRTPPCINC"    : Gosub AVANT_PAR_TRTPPCINC
                        Endcase  
  When "CONTROLE"     : Case GACTION 
                          When "TRTPPCINC"    : Gosub CONTROLE_TRTPPCINC
                        Endcase  
#      dans gsaisie
  When "DEBUT"        : Case GACTION
                          When "TRTPPCINC"    : Gosub DEBUT_TRTPPCINC 
                        Endcase
  When "TITRE"        : Case GACTION 
                          When "TRTPPCINC"    : Gosub TITRE_TRTPPCINC
                        Endcase 
  When "SETBOUT"      : Case GACTION 
                          When "TRTPPCINC"    : Gosub SETBOUT_TRTPPCINC
                        Endcase 
  When "END", "ABA"   : Case GACTION
                          When "TRTPPCINC"    : FIN=1 : JGOKMAJ=1  
                        Endcase
  When "ENR", "CRE"   : Case GACTION
                          When "TRTPPCINC"    : FIN=1 : JGOKMAJ=2  
                        Endcase
  When "EDI"          : Case GACTION
                          When "TRTPPCINC"    : Gosub EDI_TRTPPCINC     
                        Endcase
#      dans gtraite
  When "EXEC"         : Case GACTION 
                          When "TRTPPCINC"    : Gosub EXEC_TRTPPCINC
                        Endcase 
  When "SORTIE"       : Case GACTION 
                          When "TRTPPCINC"    : Gosub SORTIE_TRTPPCINC
                        Endcase     
  When Default
Endcase

#--- Actions liÕes a la visualisation des donnÕes de la derniÒre execution 
Case ACTION
  When "TITRE"        : Case GACTION
                          When "VISUSINCL"    : Gosub TITRE_VISUSINCL
                        Endcase  
  When "DEBUT"        : Case GACTION
                          When "VISUSINCL"    : Gosub DEBUT_VISUSINCL
                        Endcase  
  When Default
Endcase

Return

########################################################################
# DÕtail des actions liÕes Á la saisie fenõtre des variables
########################################################################
$OUVRE_SAIZPCINC

Global Integer JGOKMAJ, JGOKCOUL, JGFINLEC
Global Char    JGTITMAJ (250), JGTITTRA (250)
Global Integer JGCOMPTAGE 
Global Decimal JGARRRAT         : # arrondi standard des % (type donnÕe RAT)
Local  Integer I

JGTITTRA=mess(162,196,1)-mess(5,14,1)
If clalev ([F:ZNE])=0  : Local File PINCENT    [ZNE]  : Endif
If clalev ([F:ZND])=0  : Local File PINCDET    [ZND]  : Endif
If clalev ([F:ZPI])=0  : Local File PPRICINCR  [ZPI]  : Endif
If clalev ([F:PPC])=0  : Local File PPRICCONF  [PPC]  : Endif
If clalev ([F:PPR])=0  : Local File PPREASON   [PPR]  : Endif
If clalev ([F:PRS])=0  : Local File PRICSTRUCT [PRS]  : Endif
If clalev ([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev ([F:PPF])=0  : Local File PPRICFICH  [PPF]  : Endif
If clalev ([F:PPFN])=0 : Local File PPRICFICH  [PPFN] : Endif
If clalev ([F:PPL])=0  : Local File PPRICLIST  [PPL]  : Endif
If clalev ([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
If clalev ([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif

Read [F:ATY]CODTYP="RAT"
If !fstat
  I=int(([F:ATY]LNGTYP-int([F:ATY]LNGTYP))*10)
  Case I
    When 0       : JGARRRAT=1
    When 1       : JGARRRAT=0.1
    When 2       : JGARRRAT=0.01
    When 3       : JGARRRAT=0.001
    When 4       : JGARRRAT=0.0001
    When 5       : JGARRRAT=0.00001
    When 6       : JGARRRAT=0.000001
    When Default : JGARRRAT=1
  Endcase 
Endif

Read [F:PRS]PRS0=1;""
Call COLREM("C",1,"") From TRTPRICE

# -- Alimentation du compteur fiche tarif
If clalev ([F:TCA])<=0 : Local File TABCOUAFF [TCA] : Endif
Read [TCA]TCA0=5
If fstat
  GERR=1 : GMESSAGE=mess(64,199,1)  : # aucun compteur n'est affectÕ Á ce document
  FIN=1 : Return
Endif
GMANCOU = [F:TCA]MANCOU(8)
GCODNUM = [F:TCA]CODNUM(8)

Return

########################################################################
$DEBUT_SAIZPCINC

# -- Si appel direct en crÕation/modif de paramÕtrage 
If PARAM(1)<>""
  Call LECTURE("ZNE",PARAM(1),"") From CONTOBJ
  Call LECTURE("PPC",[F:ZNE]PLI,"") From CONTOBJ 
  [M:ZPCI]SIMFLG=2
  [M:ZPCI]SEEFLG=2
  [M:ZPCI]=[F:ZNE]
  [M:ZPCI]PLIDES=[F:PPC]PLIDES
  For I=0 To dim([M:ZPCI]VARCOD)-1
    [M:ZPCI]VARVAL(I)=[M:ZPCI]VARDEF(I)
  Next I
  GFLTPLI=[F:ZNE]PLI
Else
  Raz [F:ZNE]
  Raz [M:ZPCI]
Endif 
Affzo [ZPCI]
Return

########################################################################
$SETBOUT_SAIZPCINC
If [F:ZNE]COD="" : ETABOU(GSPE1)=0 : Endif
If COUZON="COD"
  If [F:ZNE]LASDATPRO<>[0/0/0] ETABOU(GSPE1)=1 Else ETABOU(GSPE1)=0 Endif
Endif
Return

########################################################################
$BOUCLE_SAIZPCINC

#--- Si on ne vient pas du paramÕtrage on revient sur choix
If PARAM(1)="" : FIN=0 : Endif

Return
########################################################################
$FIN_SAIZPCINC
#--- Trace
If !GSERVEUR & GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

#--- Sup. des globales perso
If dim(JGOKMAJ)>0    : Kill JGOKMAJ    : Endif
If dim(JGOKCOUL)>0   : Kill JGOKCOUL   : Endif
If dim(JGFINLEC)>0   : Kill JGFINLEC   : Endif
If dim(JGTITMAJ)>0   : Kill JGTITMAJ   : Endif
If dim(JGTITTRA)>0   : Kill JGTITTRA   : Endif
If dim(JGCOMPTAGE)>0 : Kill JGCOMPTAGE : Endif
If dim(JGARRRAT)>0   : Kill JGARRRAT   : Endif

#--- Hard Copy
Call IMPSCR From TRTX3

Return


########################################################################
########################################################################
$INIT_TRTPPCINC

#-- nom de la fenõtre gÕnÕrÕe lors du paramÕtrage tarifs
BOITE="WB1"+num$([F:ZNE]PLI)

#-- nom du traitement de rÕvision gÕnÕrÕ
Local Char NOMTRT (10)
NOMTRT="WBI"+[F:ZNE]COD
Call DEBTRANS From GLOCK
#-- ouverture de la trace
If !GSERVEUR & GTRACE=""
  Call OUVRE_TRACE(JGTITTRA) From LECFIC
  Call ECR_TRACE(JGTITTRA,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Endif

#-- 
Read [PPR]SPR0=[F:PPC]PRIREN

#-- gÕnÕration du traitement si inexistant
Local Char FICTRT (GDIMFIC)
FICTRT=filpath("TRT","WBI"+num$([F:ZNE]COD),"adx",nomap)
If filinfo (FICTRT,0)<0
  Call VALID([M:ZPCI]COD,nomap) From SUBZNE
Endif

Gosub VARIABLES From =NOMTRT      : # Reservation et chargement des variables parametrees
If sum([F:ZNE]TBL)<>""            
  Gosub OPEN_TBL From =NOMTRT     : # Ouverture des tables liees 
Endif

#-- mise a jour des tarifs (crÕation des fiches)
If !GSERVEUR 
  Call ECR_TRACE("-"-mess(168,195,1)-[F:ZNE]COD+" /"-mess(49,198,1)-[F:ZNE]PLI,0) From GESECRAN 
Endif

Local Char CRDOLD           : # no. de la fiche origine
Local Char CRDNEW           : # no. de la fiche crÕe 
Local Char FILTREPPF (250)  : # expression de sÕlection des fiches Á traiter

#-- constitution du filtre des fiches Á augmenter
FILTREPPF="1=1"
If [M:ZPCI]PLISTRCRD<>""
  FILTREPPF += " & PLICRD>=[M:ZPCI]PLISTRCRD"
Endif
If [M:ZPCI]PLIENDCRD<>""
  FILTREPPF += " & PLICRD<=[M:ZPCI]PLIENDCRD"
Endif
If [M:ZPCI]VLYDAT<>[00/00/00]
  FILTREPPF += " & PLISTRDAT<=[M:ZPCI]VLYDAT & PLIENDDAT>=[M:ZPCI]VLYDAT"
Endif 

Filter [PPF] Where PLI=[F:ZNE]PLI & evalue(FILTREPPF)
Raz JGFINLEC 
Read [PPF] PPF0 First
If fstat : JGFINLEC=2 : Endif

Return

########################################################################
$AVANT_PAR_TRTPPCINC

Raz JGOKMAJ, JGOKCOUL
If JGFINLEC=2 : Return : Endif
If JGFINLEC=0    
  Read [PPF] Curr : # pour la premiere fiche
Else
  Read [PPF] Next : # pour les fiches suivantes
Endif
If fstat
  JGFINLEC=2 : Return
Else 
  JGFINLEC=1 
Endif

CRDOLD=[F:PPF]PLICRD

#---
$TRTCAL
GOK=1
Trbegin SPRICINCR
#   on vide le ficher de travail [ZPI] pour cette fiche
Delete [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 
Gosub CALCUL
If     GOK<0 : Goto ROL_TRTCAL
Elsif !GOK   : Goto AB_TRTCAL 
Endif
Commit

Return

#----------------------------------------------------------------------
# Rollback
#----------------------------------------------------------------------
#-- nouvelle tentative et si echec --> rollback
$ROL_TRTCAL
Call ROLL From GLOCK
If GROLL Goto AB_MESTRTCAL Else Goto TRTCAL Endif

#-- rollback
$AB_TRTCAL
Rollback

$AB_MESTRTCAL
# mess : rollback suite Á une erreur dans la transaction
Call ECR_TRACE([F:PPF]PLI-[F:PPF]PLICRD-mess(17,107,1),1) From GESECRAN

Filter [ZPI]
Delete [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 

Return

######################################################################## 
$CONTROLE_TRTPPCINC
#--- pour positionner les flags de mise Á jour et de visu 
JGOKMAJ=2 : JGOKCOUL=0
If [M:ZPCI]SEEFLG<>2 : BOITE="" : Endif 
If JGFINLEC=2 : FIN=1 : Endif
TMP=1

Return

########################################################################
$DEBUT_TRTPPCINC

Local Integer RG
nolign=0
Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD
[M:SPLW]X1PRIREN=[F:PPR]PRIREN
[M:SPLW]X2PRIREN=[F:PPR]DES

For [ZPI]
  nolign += 1
  [M:SPLW] = [F:ZPI]
  For RG=1 To 9
    Assign "[M:SPLW]XFRAREM"+num$(RG)+"(nolign-1)" With [F:ZPI]DCGVAL(RG-1)
  Next RG
Next
[M:SPLW]NBLIG = nolign

If [F:ZNE]TYP=2  : # si modification
  [M:SPLW]PLICRD=[F:PPF]PLICRD
Else             : # si duplication ou chgt devise
  Raz [M:SPLW]PLICRD
Endif
[M:SPLW]PLISTRDAT=[M:ZPCI]NEWSTRDAT
[M:SPLW]PLIENDDAT=[M:ZPCI]NEWENDDAT
[M:SPLW]PLICRDIDX=[F:PPF]PLICRDIDX

Affzo [SPLW] 
Diszo [SPLW]
#Grizo [SPLW]
Return

########################################################################
$TITRE_TRTPPCINC
Raz TIT
If [M:ZPCI]SIMFLG=2 : TIT += mess(6,115,1)+"  " : Endif
TIT += mess([F:ZNE]TYP,454,1)-mess(2,99,1)-[F:PPF]PLICRD

Return

########################################################################
$SETBOUT_TRTPPCINC
ETABOU(GNOUV)=0 : ETABOU(GPREM)=0 : ETABOU(GDERN)=0 : ETABOU(GSUIV)=0
ETABOU(GPREC)=0 : ETABOU(GSELE)=0 : ETABOU(GCHAN)=0 
ETABOU(GJOIN)=0 : ETABOU(GCOMM)=0 : ETABOU(GDATC)=0 
ETABOU(GENRE)=0 : ETABOU(GCREE)=0 : ETABOU(GSUPP)=0 : ETABOU(GABAN)=0
ETABOU(GEDIT)=1

If [M:ZPCI]SIMFLG<>2
  If [F:ZNE]TYP=1 : ETABOU(GCREE)=1 : ETABOU(GABAN)=1 : Endif   
  If [F:ZNE]TYP=2 : ETABOU(GENRE)=1 : ETABOU(GABAN)=1 : Endif
  If [F:ZNE]TYP=3 : ETABOU(GCREE)=1 : ETABOU(GABAN)=1 : Endif
Endif

Return


########################################################################
$EDI_TRTPPCINC
Call PRTSCR("WB1"+num$([F:ZNE]PLI)+"1","SPLW","-"+TIT,0,0) From TRTX3
Return

########################################################################
$EXEC_TRTPPCINC
#--- traitement de mise Á jour (sauf simulation ou refus)
If [M:ZPCI]SIMFLG=2   : # si simulation 
  Goto FIN_FICHE
Endif

If JGOKMAJ=1            : # si traitement et maj refusÕe a la visu  
  Goto FIN_FICHE 
Endif

If [F:ZNE]TYP=2
  Gosub VERROU
  If OK=1 : Goto FINFIN_FICHE Endif
Endif

#---
$TRTMAJ
GOK=1
Trbegin SPRICINCR

If [F:ZNE]TYP=1 : Gosub MAJ_DUPLI  : Endif  
If [F:ZNE]TYP=2 : Gosub MAJ_MODIF  : Endif  
If [F:ZNE]TYP=3 : Gosub MAJ_DEVISE : Endif  

If     GOK<0 : Goto ROL_TRTMAJ
Elsif !GOK   : Goto AB_TRTMAJ 
Endif
Commit

#--- Si modification : on enleve le lock symbole
If [F:ZNE]TYP=2 :  Gosub DEVERROU : Endif

#--- En fin de fiche  : ecriture ficher trace 
$FIN_FICHE
Filter [ZPI]
Delete [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 

Raz JGTITMAJ
JGOKCOUL=0                                   : # ligne trace en noir

If [M:ZPCI]SIMFLG=2 
  JGTITMAJ += mess(6,115,1)+"  "               : # Simulation 
Endif 

If [M:ZPCI]SIMFLG=1 & JGOKMAJ=1
  JGTITMAJ += mess(43,187,1)+"  "              : # Attention 
  JGTITMAJ += mess([F:ZNE]TYP,454,1)+" "       : # suivant traitement
  JGTITMAJ += num$(CRDOLD)+"  "
  JGTITMAJ += mess(44,187,1)                   : # non effectuÕ(e)
  JGOKCOUL=1                                 : # ligne trace en rouge
Else
  JGTITMAJ += mess([F:ZNE]TYP,454,1)+" "       : # suivant traitement
  JGTITMAJ += num$(CRDOLD)+"  " 
  If [M:ZPCI]SIMFLG=1 & [F:ZNE]TYP<>2
    JGTITMAJ += mess(42,187,1)+" "             : # Fiche crÕe  
    JGTITMAJ += num$(CRDNEW)+" "
  Endif
Endif  

If JGTITMAJ<>""
  Call ECR_TRACE(JGTITMAJ,JGOKCOUL) From GESECRAN
Endif

#---
$FINFIN_FICHE

If JGFINLEC=1 : SAI=1 : Endif

Return

#----------------------------------------------------------------------
# Positionnement d'un verrou sur l'entõte commande                     
#----------------------------------------------------------------------
$VERROU
Local Integer OK
SYMBOLE = "PPF"+[F:PPF]PLICRD+"\"+[F:PPF]PLI
Lock = SYMBOLE With lockwait = 0
OK=2
If fstat = 1
    Call ECR_TRACE([F:PPF]PLI - [F:PPF]PLICRD - mess(10,100,1),1) From GESECRAN 
    OK=1
Elsif fstat 
    # problÒme sur la table 
    Call ECR_TRACE(mess(150,199,1)-"$PPRICFICH",1) From GESECRAN 
    OK=1          
Endif 
Return

#----------------------------------------------------------------------
# Suppression du verrou sur l'entõte commande                          
#----------------------------------------------------------------------
$DEVERROU
Unlock=SYMBOLE
Return


#----------------------------------------------------------------------
# Rollback
#----------------------------------------------------------------------
#-- nouvelle tentative et si echec --> rollback
$ROL_TRTMAJ
Call ROLL From GLOCK
If GROLL Goto AB_MESTRTMAJ Else Goto TRTMAJ Endif
   
#-- rollback
$AB_TRTMAJ
Rollback

$AB_MESTRTMAJ
# mess : rollback suite Á une erreur dans la transaction
Call ECR_TRACE([F:PPF]PLI-[F:PPF]PLICRD-mess(17,107,1),1) From GESECRAN

Filter [ZPI]
Delete [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 

Return

########################################################################
$SORTIE_TRTPPCINC
#-- mise Á jour donnÕes derniÒre execution
If [M:ZPCI]SIMFLG=1
  Readlock [ZNE]ZNE0=[M:ZPCI]COD
  If !fstat
    [F:ZNE]LASDATPRO = date$
    [F:ZNE]LASSTRCRD = [M:ZPCI]PLISTRCRD
    [F:ZNE]LASENDCRD = [M:ZPCI]PLIENDCRD
    [F:ZNE]LASVLYDAT = [M:ZPCI]VLYDAT
    [F:ZNE]LASSTRDAT = [M:ZPCI]PLISTRDAT
    [F:ZNE]LASENDDAT = [M:ZPCI]PLIENDDAT
    [F:ZNE]LASCUROLD = [M:ZPCI]CUROLD
    [F:ZNE]LASCURNEW = [M:ZPCI]CURNEW
    [F:ZNE]LASCHGTYP = [M:ZPCI]CHGTYP
    For I=0 To [M:ZPCI]NBVAR-1
      [F:ZNE]VARLAS(I) = [M:ZPCI]VARVAL(I)
    Next I
    Rewrite [ZNE] 
  Endif
Endif
#--
Filter [PPF] 
Filter [ZPI]
Return

########################################################################
########################################################################
$TITRE_VISUSINCL
TIT=mess(344,198,1)-format$(GFMD,[F:ZNE]LASDATPRO)
Return

########################################################################
$DEBUT_VISUSINCL
[M:PPCL]=[F:ZNE]
[M:PPCL]PLIDES=[F:PPC]PLIDES
Affzo [PPCL]
Diszo [PPCL]
#Grizo [PPCL]

Return

########################################################################
########################################################################
########################################################################


######################################################################## 
$MAJ_TARIFS
For [PPF]
  CRDOLD=[F:PPF]PLICRD
Next

#-- mise Á jour donnÕes derniÒre execution
If [M:ZPCI]SIMFLG=1
  Readlock [ZNE]ZNE0=[M:ZPCI]COD
  If !fstat
    [F:ZNE]LASDATPRO = date$
    [F:ZNE]LASSTRCRD = [M:ZPCI]PLISTRCRD
    [F:ZNE]LASENDCRD = [M:ZPCI]PLIENDCRD
    [F:ZNE]LASVLYDAT = [M:ZPCI]VLYDAT
    [F:ZNE]LASSTRDAT = [M:ZPCI]PLISTRDAT
    [F:ZNE]LASENDDAT = [M:ZPCI]PLIENDDAT
    [F:ZNE]LASCUROLD = [M:ZPCI]CUROLD
    [F:ZNE]LASCURNEW = [M:ZPCI]CURNEW
    [F:ZNE]LASCHGTYP = [M:ZPCI]CHGTYP
    For I=0 To [M:ZPCI]NBVAR-1
      [F:ZNE]VARLAS(I) = [M:ZPCI]VARVAL(I)
    Next I
    Rewrite [ZNE] 
  Endif
Endif
#--
Filter [PPF] 
Filter [ZPI]

Return

#######################################################################
# Traitement dans fichier manoeuvre SPRICINCR [ZPI] 
#######################################################################
$CALCUL

#-- nouvelles dates de validitÕ 
Raz [M:ZPCI]NEWSTRDAT, [M:ZPCI]NEWENDDAT
If [M:ZPCI]PLISTRDAT<>[0/0/0]
           [M:ZPCI]NEWSTRDAT=[M:ZPCI]PLISTRDAT
  Else     [M:ZPCI]NEWSTRDAT=[F:PPF]PLISTRDAT 
Endif
If [M:ZPCI]PLIENDDAT<>[0/0/0]
           [M:ZPCI]NEWENDDAT=[M:ZPCI]PLIENDDAT
  Else     [M:ZPCI]NEWENDDAT=[F:PPF]PLIENDDAT 
Endif

#-- On copie les ligne [PPL] de la fiche [PPF] dans ficher de travail [ZPI]
#   si changement devise, on ne copie que les lignes Á changer

Local Char FILTRESPL (50)
FILTRESPL="PLICRD=[F:PPF]PLICRD"  
If [F:ZNE]TYP=3 : FILTRESPL += " & CUR=[M:ZPCI]CUROLD" : Endif 

Filter [PPL] Where PLI=[F:PPF]PLI & evalue (FILTRESPL) 
For [PPL]
  Raz [F:ZPI]
  [F:ZPI]=[F:PPL]
# Õclatement des critÒres
  MANIP=[F:PPL]PLICRI
  For RG=1 To dim([F:PPC]FLD)
    JK=instr(1,MANIP,"~")
    If JK
      Assign "[F:ZPI]CRIT"+num$(RG) With left$(MANIP,JK-1)
      MANIP=(right$(MANIP,JK+1))
    Endif
  Next RG

# si changement de divise appel du traitement gÕnÕrÕ
  If [F:ZNE]TYP=3 : Gosub CHGDEV_LIGNE From = "WBI"+num$([F:ZNE]COD) : Endif

  Write [ZPI]  
  If fstat
    GOK=0 : Call FSTA("SPI") From GLOCK
    Break
  Endif
Next
Filter [PPL]

If GOK<>1 : Return : Endif

#----------------------------------------------------------------------
# pour chaque ligne du paramÕtrage de revision
#----------------------------------------------------------------------

Filter [ZND] Where COD=[F:ZNE]COD
For [ZND]
  If sum([F:ZNE]TBL)=""
    Gosub CAL_SANSTBL   : # suppression et/ou calcul des lignes sans tables liees
  Else
    Gosub CAL_AVECTBL   : # suppression et/ou calcul des lignes avec tables liees
  Endif
  If GOK<>1 : Break : Endif
Next
Filter [ZPI]
Filter [ZND]

Return

#---
$ERR_SEL
GERREUR=errn 
#            erreur a l'Õvaluation de 
Call ERREUR (mess(18,71,1)+"\"+[F:ZND]SELFRM+"\"+
&            errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Call ECR_TRACE(mess(18,71,1)+" "+[F:ZND]SELFRM+"  "+
&            errmes$(GERREUR),1) From GESECRAN
Resume

#----------------------------------------------------------------------
# Si absence de tables liees :
# - si parametrage de suppression : pas de lecture des lignes de la fiche

$CAL_SANSTBL
# --- constitution de la clÕ du filtre     
Local Char    EXPRESSION (250) 
Local Integer IAFF
EXPRESSION="1=1"
If [F:ZND]SELFRM<>""                        : # il y a un filtre sur la selection 
  IAFF = find([F:ZND]SELFRM,[F:ZNE]VARCOD)
  If IAFF & [F:ZNE]VARTYP(IAFF-1)="AFF"
    EXPRESSION += " & "+evalue([F:ZNE]VARCOD(IAFF-1)) : # selection dans une variable
  Else      
    EXPRESSION += " & "+[F:ZND]SELFRM                 : # selection dans la donnÕe
  Endif
Endif
If [F:ZND]DELFLG=2
  Onerrgo ERR_SEL 
  Delete [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD & evalue(EXPRESSION)
  Onerrgo ERREUR From CONTROLE 
  If    fstat=1 : GOK=-1 : GLOCK="$SPRICINCR"-[F:PPF]PLI-[F:PPF]PLICRD : Goto PAS_OK 
  Elsif fstat>5 : GOK=0  : Call FSTA("SPI") From GLOCK                 : Goto PAS_OK 
  Endif
Else
  Onerrgo ERR_SEL 
  Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD & evalue(EXPRESSION)
  Onerrgo ERREUR From CONTROLE 
  For [ZPI] 
    Readlock [ZPI] Curr 
    If fstat=1
      GOK=-1 : GLOCK="$SPRICINCR"-[F:ZPI]PLI-[F:ZPI]PLICRD-[F:ZPI]PLILIN : Goto PAS_OK
    Elsif fstat
      GOK=0  : Call RSTA("SPI","") From GLOCK : Goto PAS_OK
    Endif
    Gosub MAJ_UNE_LIGNE
    Rewrite [ZPI]
    If fstat
      GOK=0 : Call FSTA("SPI") From GLOCK : Goto PAS_OK
    Endif
  Next
  Filter [ZPI]
Endif
Return


#----------------------------------------------------------------------
# Si presence de tables liees :
# - si parametrage de suppression : boucle de lecture des lignes de la fiche
#                                   pour tester les conditions de suppression 

$CAL_AVECTBL
Local Char    EXPRESSION (250) 
Local Integer IAFF
EXPRESSION="1=1"
If [F:ZND]SELFRM<>""                        : # il y a un filtre sur la selection 
  IAFF = find([F:ZND]SELFRM,[F:ZNE]VARCOD)
  If IAFF & [F:ZNE]VARTYP(IAFF-1)="AFF"
    EXPRESSION += " & "+evalue([F:ZNE]VARCOD(IAFF-1)) : # selection dans une variable
  Else      
    EXPRESSION += " & "+[F:ZND]SELFRM                 : # selection dans la donnÕe
  Endif
Endif
Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD
For [ZPI]
  Gosub LECT_TBL From =NOMTRT 
  Onerrgo ERR_SEL
  If evalue(EXPRESSION) 
    Onerrgo ERREUR From CONTROLE
    If [F:ZND]DELFLG=2    : # suppression de la ligne
      Delete [ZPI]Curr
      If    fstat=1 : GOK=-1 : GLOCK="$SPRICINCR"-[F:PPF]PLI-[F:PPF]PLICRD : Goto PAS_OK 
      Elsif fstat>5 : GOK=0  : Call FSTA("SPI") From GLOCK                 : Goto PAS_OK 
      Endif
    Else                  : # maj de la ligne
      Readlock [ZPI] Curr 
      If fstat=1
        GOK=-1 : GLOCK="$SPRICINCR"-[F:ZPI]PLI-[F:ZPI]PLICRD-[F:ZPI]PLILIN : Goto PAS_OK
      Elsif fstat
        GOK=0  : Call RSTA("SPI","") From GLOCK : Goto PAS_OK
      Endif
      Gosub MAJ_UNE_LIGNE
        Rewrite [ZPI]
        If fstat
          GOK=0 : Call FSTA("SPI") From GLOCK : Goto PAS_OK
        Endif
    Endif
  Else
    Onerrgo ERREUR From CONTROLE
  Endif

Next 
Filter [ZPI]
Return

#---
$PAS_OK
Filter [ZPI]
Return

#----------------------------------------------------------------------
# Mise a jour d'une ligne dans le fichier de travail
#----------------------------------------------------------------------
$MAJ_UNE_LIGNE

Local Decimal MNTV   : # montant Á ajouter en valeur ou %
Local Decimal MNT    : # nouveau montant calculÕ 
Local Integer IZ
For I=0 To dim([F:ZND]INCFLD)-1
  If [F:ZND]INCFLDUPD(I)>1
    Raz MNTV, MNT, IZ
    Case [F:ZND]INCFLD(I)
      When "PRI"      : MNT=[F:ZPI]PRI       : IZ=0 : Gosub MAJ_VALEUR : [F:ZPI]PRI=MNT
      When "XFRAREM1" : MNT=[F:ZPI]DCGVAL(0) : IZ=1 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(0)=MNT
      When "XFRAREM2" : MNT=[F:ZPI]DCGVAL(1) : IZ=2 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(1)=MNT
      When "XFRAREM3" : MNT=[F:ZPI]DCGVAL(2) : IZ=3 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(2)=MNT
      When "XFRAREM4" : MNT=[F:ZPI]DCGVAL(3) : IZ=4 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(3)=MNT
      When "XFRAREM5" : MNT=[F:ZPI]DCGVAL(4) : IZ=5 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(4)=MNT
      When "XFRAREM6" : MNT=[F:ZPI]DCGVAL(5) : IZ=6 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(5)=MNT
      When "XFRAREM7" : MNT=[F:ZPI]DCGVAL(6) : IZ=7 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(6)=MNT
      When "XFRAREM8" : MNT=[F:ZPI]DCGVAL(7) : IZ=8 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(7)=MNT
      When "XFRAREM9" : MNT=[F:ZPI]DCGVAL(8) : IZ=9 : Gosub MAJ_VALEUR : [F:ZPI]DCGVAL(8)=MNT
    Endcase
  Endif
Next I
Return

#----------------------------------------------------------------------
# Type augment.: 1=non / 2=variation en % / 3=var. en mnt / 4=affectation
#----------------------------------------------------------------------
$MAJ_VALEUR

Onerrgo ERR_VAL
Case [F:ZND]INCFLDUPD(I)
  When 1       : Goto SUITE
  When 2       : MNTV=evalue([F:ZND]INCFRM(I))
                 MNT=MNT+((MNT*MNTV)/100)
                 Goto ARRONDI_VAL
  When 3       : MNTV=evalue([F:ZND]INCFRM(I))
                 MNT=MNT+MNTV 
                 Goto ARRONDI_VAL
  When 4       : MNTV=evalue([F:ZND]INCFRM(I))
                 MNT=MNTV 
                 Goto ARRONDI_VAL
  When Default : Goto SUITE 
Endcase

#---
$ARRONDI_VAL
#   pas de rÕsultat nÕgatif
If MNT<0 : MNT=0 : Endif

If IZ>0                    : # uniquement pour colonnes frais/remise 
  If[F:PRS]VALTYP(IZ-1)=1  : # si c'est un montant arrondi devise
    Call ARRDEV(MNT,[F:ZPI]CUR) From TRTDIV
  Else                     : # si c'est un taux arrondi type donnÕe RAT
    MNT=arr(MNT,JGARRRAT)
  Endif
Endif

#   arrondi paramÕtrÕ 1=non / 2=plus proche (adonix) / 3=infÕrieur / 4=supÕrieur 
Case [F:ZND]INCRNDTYP(I)
  When 1       : Goto SUITE
  When 2       : MNT=arr(MNT,[F:ZND]INCRND(I))
                 Goto SUITE
  When 3       : If [F:ZND]INCRND(I)>0
                   MNT=[F:ZND]INCRND(I)*int(MNT/[F:ZND]INCRND(I))
                 Endif
                 Goto SUITE
  When 4       : If [F:ZND]INCRND(I)>0
                   MNT=-[F:ZND]INCRND(I)*int(-MNT/[F:ZND]INCRND(I))
                 Endif
                 Goto SUITE
  When Default : Goto SUITE 
Endcase

#---
$SUITE
Onerrgo ERREUR From CONTROLE
Return

$ERR_VAL
GERREUR=errn 
#            erreur Á l'Õvaluation de  
Call ERREUR (mess(18,71,1)+"\"+[F:ZND]INCFRM(I)+"\"+
&            errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Call ECR_TRACE(mess(18,71,1)+" "+[F:ZND]INCFRM(I)+"  "+
&            errmes$(GERREUR),1) From GESECRAN
Resume


#-----------------------------------------------------------------------
# Duplication de fiche : crÕation d'une nouvelle fiche 
#-----------------------------------------------------------------------
# - recherche d'un code fiche (lecture compteur) 
# - ecriture des lignes [PPL] de la nouvelle fiche et comptage des lignes
# - Õcriture entõte nouvelle fiche [PPFN] (autre abbrÕviation)
# - si date fin de fiche origine supÕrieure Á date dÕbut de nelle fiche,
#   la fiche origine est ajustÕe (date fin = date dÕbut nelle fiche -1) 
#-----------------------------------------------------------------------
$MAJ_DUPLI
Local Integer STAT
Local Char    COMPLEMENT (15)
[F:PPFN]=[F:PPF]

If [F:PPFN]PLICRDIDX<>"" COMPLEMENT=[F:PPFN]PLICRDIDX
   Else                  COMPLEMENT=[F:PPFN]PLI
Endif

If GMANCOU<>2
  Call NUMERO(GCODNUM,"",[M:ZPCI]NEWSTRDAT,COMPLEMENT,[F:PPFN]PLICRD,STAT) From SUBANM
  If STAT=0
    [F:PPFN]PLICRD=vireblc([F:PPFN]PLICRD,4)
    CRDNEW=[F:PPFN]PLICRD
  Else
    Call ECR_TRACE(mess(60,199,1),1) From GESECRAN
#   problÒme lors de la rÕcupÕration du compteur
    GOK=0 : Return 
  Endif
Else
    Call ECR_TRACE(mess(253,199,1),1) From GESECRAN
#   le compteur doit õtre automatique   
    GOK=0 : Return
Endif

Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 
Raz JGCOMPTAGE
For [ZPI] 
  [F:PPL]=[F:ZPI]
  [F:PPL]PLICRD=[F:PPFN]PLICRD   
  [F:PPL]PLISTRDAT=[M:ZPCI]NEWSTRDAT
  [F:PPL]PLIENDDAT=[M:ZPCI]NEWENDDAT
  Raz [F:PPL] IMPNUMLIG, [F:PPL]EXPNUM, [F:PPL]UPDUSR, [F:PPL]UPDDAT
  [F:PPL]CREUSR=GUSER : [F:PPL]CREDAT=date$ 
  Write [PPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break 
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

If JGCOMPTAGE>0
  [F:PPFN]PLISTRDAT=[M:ZPCI]NEWSTRDAT
  [F:PPFN]PLIENDDAT=[M:ZPCI]NEWENDDAT
  [F:PPFN]LINNBR=JGCOMPTAGE  
  Raz [F:PPFN]EXPNUM, [F:PPFN]UPDUSR, [F:PPFN]UPDDAT
  [F:PPFN]CREUSR=GUSER : [F:PPFN]CREDAT=date$
  Write [PPFN]
  If fstat
    GOK=0  : Call FSTA("PPFN") From GLOCK : Return 
  Endif
Endif

#     m.a.j. date fin dans la fiche origine [PPF]  
#     m.a.j. date de fin dans les lignes [PPL]

If [F:PPF]PLISTRDAT<[M:ZPCI]NEWSTRDAT & [F:PPF]PLIENDDAT>=[M:ZPCI]NEWSTRDAT
  [F:PPF]PLIENDDAT=[M:ZPCI]NEWSTRDAT-1
  [F:PPF]UPDUSR=GUSER : [F:PPF]UPDDAT=date$
  Rewrite [PPF]         
  If fstat=1
    GOK=-1 : GLOCK="$PPRICFICH"-[F:PPF]PLI-[F:PPF]PLICRD : Return
  Elsif fstat 
    GOK=0  : Call FSTA("PPF") From GLOCK                 : Return
  Endif
  Update [PPL] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD        
&              With PLIENDDAT=[M:ZPCI]NEWSTRDAT-1, UPDUSR=GUSER, UPDDAT=date$ 
  If fstat=1
    GOK=-1 : GLOCK="$PPRICLIST"-[F:PPF]PLI-[F:PPF]PLICRD : Return
  Elsif fstat=3 | fstat>5
    GOK=0  : Call FSTA("SPL") From GLOCK                 : Return
  Endif
Endif

Return

#-----------------------------------------------------------------------
# Modification de fiche 
#-----------------------------------------------------------------------
# - suppression des anciennes lignes [PPL]
# - scriture des nouvelles lignes [PPL] et comptage des lignes
# - rÕcriture entõte fiche [PPF]
#-----------------------------------------------------------------------
$MAJ_MODIF

Delete [PPL] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD        
If fstat=1
  GOK=-1 : GLOCK="$PPRICLIST"-[F:PPF]PLI-[F:PPF]PLICRD   : Return
Elsif fstat>5 
  GOK=0  : Call FSTA("SPL") From GLOCK                   : Return
Endif

Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 
Raz JGCOMPTAGE
For [ZPI] 
  [F:PPL]=[F:ZPI]
  [F:PPL]PLISTRDAT=[M:ZPCI]NEWSTRDAT
  [F:PPL]PLIENDDAT=[M:ZPCI]NEWENDDAT
  [F:PPL]UPDUSR=GUSER : [F:PPL]UPDDAT=date$
  Write [PPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break 
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

Raz [F:PPF]EXPNUM : [F:PPF]LINNBR=JGCOMPTAGE
[F:PPF]PLISTRDAT=[M:ZPCI]NEWSTRDAT
[F:PPF]PLIENDDAT=[M:ZPCI]NEWENDDAT
[F:PPF]UPDUSR=GUSER : [F:PPF]UPDDAT=date$
Rewrite [PPF]
If fstat=1
  GOK=-1 : GLOCK="$PPRICFICH"-[F:PPF]PLI-[F:PPF]PLICRD : Return
Elsif fstat 
  GOK=0  : Call FSTA("PPF") From GLOCK                 : Return 
Endif

Return


#-----------------------------------------------------------------------
# Changement devise : crÕation d'une nouvelle fiche 
# - recherche d'un code fiche (lecture compteur) 
# - ecriture des lignes [PPL] de la nouvelle fiche et comptage des lignes
# - ecriture entõte nouvelle fiche [PPFN] (autre abbrÕviation)
#-----------------------------------------------------------------------
$MAJ_DEVISE
Local Integer STAT
Local Char    COMPLEMENT (15)
[F:PPFN]=[F:PPF]

If [F:PPFN]PLICRDIDX<>"" COMPLEMENT=[F:PPFN]PLICRDIDX
   Else                  COMPLEMENT=[F:PPFN]PLI
Endif

If GMANCOU<>2
  Call NUMERO(GCODNUM,"",[M:ZPCI]NEWSTRDAT,COMPLEMENT,[F:PPFN]PLICRD,STAT) From SUBANM
  If STAT=0
    [F:PPFN]PLICRD=vireblc([F:PPFN]PLICRD,4)
    CRDNEW=[F:PPFN]PLICRD
  Else
    Call ECR_TRACE(mess(60,199,1),1) From GESECRAN
#   problÒme lors de la rÕcupÕration du compteur
    GOK=0 : Return
  Endif
Else
    Call ECR_TRACE(mess(253,199,1),1) From GESECRAN
#   le compteur doit õtre automatique   
    GOK=0 : Return
Endif

Filter [ZPI] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD 
Raz JGCOMPTAGE
For [ZPI] 
  [F:PPL]=[F:ZPI]
  [F:PPL]PLICRD=[F:PPFN]PLICRD   
  [F:PPL]PLISTRDAT=[M:ZPCI]NEWSTRDAT
  [F:PPL]PLIENDDAT=[M:ZPCI]NEWENDDAT
  Raz [F:PPL] IMPNUMLIG, [F:PPL]EXPNUM, [F:PPL]UPDUSR, [F:PPL]UPDDAT
  [F:PPL]CREUSR=GUSER : [F:PPL]CREDAT=date$ 
  Write [PPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break 
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

If JGCOMPTAGE>0
  [F:PPFN]PLISTRDAT=[M:ZPCI]NEWSTRDAT
  [F:PPFN]PLIENDDAT=[M:ZPCI]NEWENDDAT
  [F:PPFN]LINNBR=JGCOMPTAGE  
  Raz [F:PPFN]EXPNUM, [F:PPFN]UPDUSR, [F:PPFN]UPDDAT
  [F:PPFN]CREUSR=GUSER : [F:PPFN]CREDAT=date$
  Write [PPFN]
  If fstat
    GOK=0  : Call FSTA("PPFN") From GLOCK : Return 
  Endif
Endif

Return

#######################################################################
# Actions champs ecran PPCINCR [ZPCI]
####################################################################### 

######################################## Code augmentation
Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
If GFONCTION="GESZNE"
  VALEUR=[F:ZNE]COD
  Gosub ALI_MSK
  mkstat=2
Endif
End

#---------------------------------------
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("ZNE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Gosub CONT_ACCES
End

#---------------------------------------
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Gosub ALI_MSK
End

#---------------------------------------

$ALI_MSK
Call LECTURE("ZNE",VALEUR,"") From CONTOBJ 
Call LECTURE("PPC",[F:ZNE]PLI,"") From CONTOBJ 
[M:ZPCI]SIMFLG=2
[M:ZPCI]SEEFLG=2
[M:ZPCI]=[F:ZNE]
[M:ZPCI]PLIDES=[F:PPC]PLIDES
For I=0 To dim([M:ZPCI]VARCOD)-1
  [M:ZPCI]VARVAL(I)=[M:ZPCI]VARDEF(I)
Next I
Affzo [M:ZPCI]
GFLTPLI=[F:ZNE]PLI
Return

#---------------------------------------

$CONT_ACCES
If [F:ZNE]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:ZNE]ACS
  If fstat
    GERR=1 : GMESSAGE=mess(3,104,1) : mkstat=2 : End
    # Vous n'avez pas accÒs Á ce code
  Elsif [F:ACC]EXEC<>2
    GERR=1 : GMESSAGE=mess(4,104,1) : mkstat=2 : End
    # Vous n'avez pas accÒs Á ce code
  Endif
Endif
Return

######################################## Flag simulation
Subprog AM_SIMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZPCI]SEEFLG=2 : Affzo [M:ZPCI]SEEFLG  
Endif
End

######################################## Flag visualisation
Subprog AS_SEEFLG(VALEUR)
Variable Integer VALEUR
If [M:ZPCI]SIMFLG=2 : VALEUR=2 : mkstat=2 : Endif
End

######################################## No fiche dÕbut
Subprog IB_PLISTRCRD
GBOUT1=mess(9,432,1)
End

#---------------------------------------
Subprog AS_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
Look [PPF] PPF0=[M]PLI;VALEUR
If mkstat
  GMESSAGE = mess(129,192,1) : # fiche n'appartenant pas au tarif
  mkstat=2
Endif 
End

######################################## No fiche fin
Subprog IB_PLIENDCRD
GBOUT1=mess(9,432,1)
End

#---------------------------------------
Subprog AS_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
Look [PPF] PPF0=[M]PLI;VALEUR
If mkstat
  GMESSAGE = mess(129,192,1) : # fiche n'appartenant pas au tarif
  mkstat=2
Endif 
End

####################################### Valide au
Subprog AS_VLYDAT(VALEUR)
Variable Date    VALEUR
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

######################################## Date dÕbut validitÕ
Subprog AS_PLISTRDAT(VALEUR)
Variable Date    VALEUR
If [M]UPDDATFLG<>2 : mkstat=2 : Endif
End

######################################## Date fin validitÕ
Subprog AS_PLIENDDAT(VALEUR)
Variable Date    VALEUR
If [M]UPDDATFLG<>2 : mkstat=2 : Endif
End

######################################## Ancienne devise
Subprog AS_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CURNEW : mkstat=2 : End : Endif
End

######################################## Nouvelle devise
Subprog AS_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CUROLD : mkstat=2 : End : Endif
End

######################################## Type de cours
Subprog AS_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP=3 & VALEUR=0 : mkstat=2 : End :  Endif
End

######################################## Valeur des variables
Subprog IB_VARVAL
Raz GBOUT1
Read [ATY]CODTYP=[F:ZNE]VARTYP(nolign-1)
If [F:ATY]OBJLIEN<>""
  GBOUT1=mess(18,100,1)
Endif
End

#---------------------------------------
Subprog C_VARVAL(VALEUR)
Variable Char    VALEUR()
Call CONTROLE(nolign,zc) From="WBI"+num$([F:ZNE]COD)
End

#---------------------------------------
Subprog AS_VARVAL(VALEUR)
Variable Char    VALEUR()
If [F:ZNE]VARTYP(nolign-1)="AFF"
  Gosub T_FORMULE
  Call AS_FORMULE From FORMULE  
  End
Endif

End

#--- c'est une formule (type=AFF)
$T_FORMULE
Local    Integer I,IJ
Raz [M:ZPCI]FLTTAB, XXCONV, XXVAR, XXPRS

Read [F:PRS]PRS0=1;""
Read [PPC]PPC0=[F:ZNE]PLI
If fstat : Raz [F:PPC] : Endif
For I=0 To dim([F:PRS]DES)-1
  If [F:PRS]DES(I)<>0 & [F:PPC]DISCRGPRO(I)=1
    Read [AXX]AXX0 = GLANGUE;[F:PRS]DES(I)
    If !fstat : [M:ZPCI]XXPRS(I) = [F:AXX]TEXTE : Endif
  Endif
Next I

[M:ZPCI]FLTTAB="find(ABRFIC,'SPI')"
#   critÒres variables du tarif
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    [M:ZPCI]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","+[F:PPC]CRIDES(I)
    IJ += 1 
  Else
    [M:ZPCI]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
  Endif
Next I
For I=0 To dim([F:PRS]DES)-1
  If [M:ZPCI]XXPRS(I)<>""
    [M:ZPCI]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"+[M:ZPCI]XXPRS(I)
    IJ += 1   
  Else
    [M:ZPCI]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
#   variables du traitement
For I=0 To dim([F:ZNE]VARCOD)-1
  If [F:ZNE]VARCOD(I)<>"" 
    [M:ZPCI]XXVAR(I)=[F:ZNE]VARCOD(I)+","+[F:ZNE]VARDES(I)
  Endif
Next I
Return

####################################################################### 

