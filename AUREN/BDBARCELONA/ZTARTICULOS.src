#<AdxTL>@(#)1.0.0.0 $Revision$
#<AdxTJ>@(#)10.0.0.0 $Revision$
#############################################################################################

Call ZTARTICULOS(BLANCOS,ZEROS)
End

#############################################################################################
Subprog ZTARTICULOS(BLANCOS, ZEROS)
Value Char BLANCOS
Value Char ZEROS

Local Char    SAVIFS(10) , SAVIRS(10)

SAVIFS = adxifs 
SAVIRS = adxirs

adxifs = ";"                                          :  # ============= Separador de camp
adxirs = ""                                           :  # ============= Separador de registre

GTRACE = "artis"                                        #============== Generamos en el servidor
GTRACE2 = "invent"
FICTRA = filpath("ZTRASPASO",GTRACE,"txt", 0)
FICTRA2 = filpath("ZTRASPASO",GTRACE2,"txt", 0)

Openo FICTRA, 0 Using [FIC1]                                        : #============== Abrir fichero
Openo FICTRA2, 0 Using [FIC2]

#Openo "C:\ZTRASPASO\ARTIS.TXT"                          #============== En el C del servidor

#Openo "#@C:\ZTRASPASO\artis.txt", 0 Using [FIC1]         #============== En el C del cliente
#Openo "#@C:\ZTRASPASO\invent.txt", 0 Using [FIC2]        #============== En el C del cliente

Gosub LECTURA

Openo Using [FIC1]
Openo Using [FIC2]

adxifs    = SAVIFS
adxirs    = SAVIRS
End                 

#############################################################################################
$LECTURA
If clalev([F:ITM])=0  : Local File ITMMASTER [ITM] : Endif
If clalev([F:TSI])=0  : Local File TABSTTITM [TSI] : Endif
If clalev([F:AST])=0  : Local File APLSTD [AST] : Endif
If clalev([F:ITV])=0  : Local File ITMMVT [ITV] : Endif

Gosub OUVRE

For [ITM]
    If ([F:ITM]TCLCOD = "PRF" or [F:ITM]TCLCOD = "PRC") and ([F:ITM]TSICOD(1) = "7IM" or [F:ITM]TSICOD(1) = "7NA")
                   
        CODART = format$("K:20X",[F:ITM]ITMREF)
        CODART = ctrans(CODART,";"," ")             #======== Código artículo
        Wrseq CODART; Using [FIC1]                      

        DESART = format$("K:69X",[F:ITM]ITMDES1)                
        DESART = ctrans(DESART,";"," ")        
        Wrseq DESART; Using [FIC1]                      #======== Descripción artículo 
        
        BARART = format$("K:18X",[F:ITM]EANCOD)                
        BARART = ctrans(BARART,";"," ")        
        Wrseq BARART; Using [FIC1]                      #======== Código de barras artículo

        Read [F:TSI]TSI0 = 1;[F:ITM]TSICOD(0)
        If fstat = 0
            FAMART = format$("K:15X",[F:TSI]TSIDES)                
            FAMART = ctrans(FAMART,";"," ")
            Wrseq FAMART; Using [FIC1]                   #======== Descripción de la familia comercial     
        Endif
                
        ESTADO = format$("K:2X",[F:ITM]ITMSTA)                
        ESTADO = ctrans(ESTADO,";"," ")
        Wrseq ESTADO; Using [FIC1]                       #======== Estado artículo

        Read [F:AST]CLE = 246;[F:ITM]ITMSTA;"SPA"
        If fstat = 0
            DESCINC = format$("K:69X",[F:AST]LANMES)                                
            DESCINC = ctrans(DESCINC,";"," ")
            Wrseq DESCINC; Using [FIC1]                  #======== Descripción estado artículo                        
        Endif
        Wrseq chr$(10) Using [FIC1]
    Endif

    Gosub ZTINVENTARIO
    Gosub OUVRE
Next

Return

#######################################################################################################
$ZTINVENTARIO

For [ITV]ITV0 Where [ITV]ITMREF = [F:ITM]ITMREF and ([ITV]STOFCY="BD1" or [ITV]STOFCY="BD3" or [ITV]STOFCY="BD7")
        
    SUMUNIART = SUMUNIART + [F:ITV]PHYSTO + [F:ITV]CTLSTO + [F:ITV]REJSTO + [F:ITV]TRASTO
Next

FECINV = num$(date$)
L = 12 - len(date$)                        
FECINV = FECINV + seg$(BLANCOS,1,L) 
Wrseq FECINV; Using [FIC2]                       #======== Fecha inventario

CODART2 = format$("K:20X",[F:ITM]ITMREF)
CODART2 = ctrans(CODART2,";"," ")
Wrseq CODART2; Using [FIC2]                      #======== Código artículo

#================== Conversión de la unidad para expresarla en unidad de venta.
If [F:ITM]SAU <> [F:ITM]STU
    If [F:ITM]SAUSTUCOE <> 0
        SUMUNIART = SUMUNIART / [F:ITM]SAUSTUCOE
    Endif
Endif

UNIART = num$(SUMUNIART)
L = 18 - len(UNIART)                    
UNIART = seg$(ZEROS,1,L) + UNIART   
Wrseq UNIART; Using [FIC2]                       #======== Unidades artículo
Wrseq chr$(10) Using [FIC2]


SUMUNIART = 0
CODART = ""
UNIART = ""
Return

############################################################################################################
$OUVRE
Local Integer L

#--------------------------- Articulos
Local Char CODART(20)
Local Char DESART(69)
Local Char BARART(18)
Local Char FAMART(15)
Local Char ESTADO(2)
Local Char DESCINC(69)

#--------------------------- Inventario
Local Char FECINV(12)
Local Char CODART2(20)
Local Decimal SUMUNIART(15,3)
Local Char UNIART(18)

Return

