# C.A.     Fecha     Descripión                              Autor                   #
# ----     -----     ----------                              -----                   #
# ZMP      02/12/04  Receta de Fabricación                   Felix Gonzalez (Infolan)#
#                    Buscador de Tarifa más cara                                     #
#                                                                                    #
######################################################################################
Subprog ZBTARIFZRC(TARITMREF,ZNETPRI)
Variable decimal ZNETPRI
Value Char TARITMREF

Gosub ouvre

For [PPL]PPL3 Where PLICRI2 = TARITMREF & PLISTRDAT <= DATE$ & PLIENDDAT >= DATE$
                        ##-- DIVISAS --##    
    If [PPL]CUR = "EUR"  
        WNETPRI = [PPL]PRI
    Else
        Read [BPS]BPS0 = [PPL]PLICRI1    ##--> Recuperamos el tipo de cobro CHGTYP
        If fstat = 0            
            Filter [TCH] Where [TCH]CHGTYP = [BPS]CHGTYP & [TCH]CURDEN = "EUR" & [TCH]CUR = [PPL]CUR
            Read [TCH] Last 
            If fstat = 0
                WNETPRI = [PPL]PRI * [TCH]CHGRAT
            Endif
            Filter [TCH]
        Endif
    Endif 
                        ##-- UNIDADES --#
    Read [ITM]ITM0 = TARITMREF
    If fstat = 0
        If [PPL]UOM <> [ITM]STU
            Read [TCO]TCO0 = [PPL]UOM;[ITM]STU
            If fstat = 0
                WNETPRI = WNETPRI/[TCO]COEUOM
            Else 
                Read [TCO]TCO0 = [ITM]STU;[PPL]UOM
                If fstat = 0 
                    WNETPRI = WNETPRI * [TCO]COEUOM
                Endif
            Endif
        Endif
    Endif
                        ##-- MODIFICADORES --##
    Read [PRS]PRS0 = 2;""
    If fstat = 0
        For NM = 0 to 8
            If [PPL]DCGVAL(NM) <> 0
                Gosub CALCULO_LIN
            Endif
        Next
    Endif    

    If ANT = 0          ##--> Guardamos el precio anterior         
        ANTPRECIO = WNETPRI
        ANT = 1
    Endif
    If ANTPRECIO < WNETPRI : ANTPRECIO = WNETPRI Endif ##--> Guardamos el importe mayor
    
    WNETPRI = 0
Next

ZNETPRI = ANTPRECIO   ##--> Obtenemos la tarifa de importe mayor
End

#########################################################
$OUVRE
If clalev([F:PPL])=0 : Local File PPRICLIST [PPL] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:ITM3])=0 : Local File ITMMASTER [ITM3] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF [TCO] : Endif

Local decimal WNETPRI, ZPRECIO, ANTPRECIO
Local integer NM, ANT
Return

##############################################################
$CALCULO_LIN
Case [PRS]VALTYP(NM)
    When 1 :    If [PRS]INCDCR(NM) = 1 : ZPRECIO += WNETPRI + [PPL]DCGVAL(NM) Endif
                If [PRS]INCDCR(NM) = 2 : ZPRECIO -= WNETPRI - [PPL]DCGVAL(NM) Endif

    When 2 :    If [PRS]INCDCR(NM) = 1  
                    ZPRECIO += WNETPRI + (WNETPRI*[PPL]DCGVAL(NM))/100
                Else
                    ZPRECIO += WNETPRI - (WNETPRI*[PPL]DCGVAL(NM))/100
                Endif

    When 3 :    If [PRS]INCDCR(NM) = 1  
                    ZPRECIO += (ZPRECIO*[PPL]DCGVAL(NM))/100
                Else
                    ZPRECIO -= (ZPRECIO*[PPL]DCGVAL(NM))/100
                Endif
Endcase
WNETPRI = ZPRECIO
Return
