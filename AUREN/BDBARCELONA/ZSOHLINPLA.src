#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
Case ACTION
   When "INIT"        : Gosub INIT
   When "CONTROLE"    : Gosub CONTROLE
   When "EXEC"        : Gosub EXEC
   When Default
Endcase
Return


$INIT
Return

$CONTROLE
Local Integer F
Local Integer ZVAL
ZVAL = 2
  For F=0 to [M:SOH4]NBLIG-1
    Call AS_DEMSTA(ZVAL) From SUBSOH 
    If (mkstat)=2
       OK=0
       Infbox "Las líneas no pueden cambiar a estado Planificado" 
       FIN=1    
    Endif
  Next
Return

$EXEC
Local Integer F
  For F=0 to [M:SOH4]NBLIG-1
    [M:SOH4]DEMSTA(F) = 2
    Affzo [M:SOH4]DEMSTA(F)
    Call AM_DEMSTA([M:SOH4]DEMSTA(F)) From SUBSOH
  Next

  If clalev([F:SOQX])<=0  :  Local File SORDERQ    [SOQX]  :  Endif
  Update [SOQX] Where SOHNUM=[M:SOH0]SOHNUM With DEMSTA=2
  If fstat
     Call ERREUR("Error actualizando estado Planificado: " + num$(fstat)) From GESECRAN
  Endif

Return



