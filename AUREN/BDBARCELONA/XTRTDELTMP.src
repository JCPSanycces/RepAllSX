#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#                                                                       #
# DESCRIPCIÓN : Proceso de borrado de tablas temporales utilizadas para #
#               informes específicos.                                   #
#                                                                       #
#########################################################################

# Declaración de variables
Local Integer STAT
Local Char    FICTRA(255)
Local Char    ORDSYS(255)(1..2)

# Declaración de tablas
If clalev([F:XDT])=0 : Local File XDELTMP [XDT] : Endif    # Borrado tablas temporales

If !GSERVEUR
   Call OUVRE_TRACE("Reinicialización de tablas temporales") From LECFIC
Endif

Call ECR_TRACE("Reinicialización de tablas temporales:" - num$(datesyst) - time$,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

For [F:XDT]XDT0 Where ZRIN=2
   FICTRA = filpath("tmp",[F:XDT]ZTABLA,"tra",0)
   If filinfo(FICTRA,0)>=0
      Call EFFACE(FICTRA,STAT) From ORDSYS
   Endif
   If filinfo(filpath("FIL",[F:XDT]ZTABLA,"fde"),0)>=0
      ORDSYS(1) = "valfil -s -z"-nomap-[F:XDT]ZTABLA
      ORDSYS(2) = FICTRA
      Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
      Call ECR_TRACE("   " + mess(52,123,1) - [F:XDT]ZTABLA,0) From GESECRAN
   Endif
Next

If !GSERVEUR
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

End

