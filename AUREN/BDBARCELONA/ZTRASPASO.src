#<AdxTL>@(#)10.0.0.0 $Revision$
#<AdxTJ>@(#)0.0.0.0 $Revision$
####################################################################

Call ZTRASPASO
End

####################################################################

Subprog ZTRASPASO
Local Char BLANCOS(100)
Local Char ZEROS(100)

For I = 1 To 100
    BLANCOS = BLANCOS + " "
Next

For I = 1 To 100
    ZEROS = ZEROS + "0"
Next

#-------------------------------------------------------------------------------------------------------------
#    ARTICULOS e INVENTARIOS
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Articulos e Inventario") From GESECRAN

Call ZTARTICULOS(BLANCOS,ZEROS) From ZTARTICULOS

Call TEMPOFF From GESECRAN
#-------------------------------------------------------------------------------------------------------------
#    Terceros clientes y proveedores
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Terceros clientes y proveedores") From GESECRAN

Call ZTERCEROS(BLANCOS,ZEROS) From ZTERCEROS

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE PRESUPUESTO DE VENTA
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas presupuestos de venta") From GESECRAN

Call ZTCLPREVEN(BLANCOS,ZEROS) From ZTCLPREVEN

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE PEDIDO DE VENTA
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas pedidos de venta") From GESECRAN

Call ZTCLPEDVEN(BLANCOS,ZEROS) From ZTCLPEDVEN

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE ENTREGAS DE VENTA
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas entregas de venta") From GESECRAN

Call ZTCLENTVEN(BLANCOS,ZEROS) From ZTCLENTVEN

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE RECEPCIONES
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas Recepciones") From GESECRAN

Call ZTCLRECOM(BLANCOS,ZEROS) From ZTCLRECOM

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE PEDIDOS DE COMPRA
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas pedidos compra") From GESECRAN

Call ZTCLPEDCOM(BLANCOS,ZEROS) From ZTCLPEDCOM

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE FACTURAS DE VENTAS
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas facturas de venta") From GESECRAN

Call ZTCLFACVEN(BLANCOS,ZEROS) From ZTCLFACVEN

Call TEMPOFF From GESECRAN

#-------------------------------------------------------------------------------------------------------------
#    CABECERA y LINEA DE FACTURAS DE COMPRAS
#-------------------------------------------------------------------------------------------------------------
Call TEMPON ("Gen. Fichero Cabecera y Lineas facturas de compra") From GESECRAN

Call ZTCLFACCOM(BLANCOS,ZEROS) From ZTCLFACCOM

Call TEMPOFF From GESECRAN
End
