#<AdxTL>@(#)4.0.0.0 $Revision:   1.1  $ Gestion du fichier SINCDET
#######################################################################
# SUBSND : Paramétrage augmentation tarifs (lignes)
#######################################################################

$ACTION
Case ACTION
 When "OUVRE"              : Gosub OUVRE
 When "LIENS"              : Gosub LIENS
 When "FILTRE"             : Gosub FILTRE
 When "SETBOUT"            : Gosub SETBOUT
 When "FILGAUCHE"          : Gosub FILTRE
 When "RAZCRE"             : Gosub RAZCRE
 When "INICRE"             : Gosub INICRE
 When "INIMOD"             : Gosub INICRE
 When Default    
Endcase 
Return

#######################################################################
$OUVRE
Local  Char    APPLI    : # nom du dossier (pour generer ecrans et traitements) 
Local  Integer I

APPLI=nomap

If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif
If clalev([F:AXX])=0 : Local File =APPLI+".ATEXTRA"     [AXX] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ZPI])=0 : Local File =APPLI+".PPRICINCR"   [ZPI] : Endif

# --- Traitements generes pour les tables liees
#     les tables sont ouvertes pour permettre l'evaluation des formules selection et calcul

For I=0 To dim([F:ZNE]TBL)-1
  If [F:ZNE]TBL(I)<>""
    Read [F:ATB]CODFIC=[F:ZNE]TBL(I)    
    If !fstat
      If evalue("clalev (["+[F:ATB]ABRFIC+"])") =0 : Local File =APPLI+"."+[F:ATB]CODFIC : Endif  
    Endif
  Endif
Next I

[M:ZPID]COD=[F:ZNE]COD

Return

#######################################################################
$LIENS
Local Integer I, IJL 
Gosub LES_COLONNES
[M:ZPID]COD=[F:ZNE]COD

Read [F:PRS]PRS0=1;""
Read [PPC]PPC0=[F:ZNE]PLI
If fstat : Raz [F:PPC] : Endif
Raz [M:ZPID]XXPRS
For I=0 To dim([F:PRS]DES)-1
  If [F:PRS]DES(I)<>0 & [F:PPC]DISCRGPRO(I)=1
    Read [AXX]AXX0 = GLANGUE;[F:PRS]DES(I)
    If !fstat : [M:ZPID]XXPRS(I) = [F:AXX]TEXTE : Endif
  Endif
Next I
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30 
Return

#######################################################################
$FILTRE
If !GPILSEL : FILTSUP = 'COD="'+[F:ZNE]COD+'"' : Endif
Return

#######################################################################
$SETBOUT
#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET
 
Return

#######################################################################
$RAZCRE
[M:ZPID]COD=[F:ZNE]COD
Diszo [ZPID]COD
Gosub LES_COLONNES
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30 
Return

#######################################################################
$INICRE
[F:ZND]COD=[F:ZNE]COD
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30 
Return

#######################################################################
# --- Garnir table des colonnes modifiables suivant structure et tarif
$LES_COLONNES
Local Integer IJL
If [M:ZPID]ZONMAJ(0)=""
  [M:ZPID]ZONMAJ(0)="PRI" : [M:ZPID]ZONMAJLIB(0)=mess(70,200,1)
  Read [F:PRS]PRS0=1;""
  For I=1 To dim([F:PRS]DES)
    If [F:PRS]DES(I-1)=0 : Break : Endif
    [M:ZPID]ZONMAJ(I)="XFRAREM"+num$(I)
    Call LECTURE ([M:ZPID]ZONMAJLIB(I), [F:PRS]DES(I-1)) From TEXTE
  Next I 
Endif
Read [F:PPC]PPC0=[F:ZNE]PLI
If [F:PPC]PRIPRO>1 & [F:PPC]PRIPRO<6
  [M:ZPID]INCFLD(IJL)=[M:ZPID]ZONMAJ(0)
  [M:ZPID]INCDES(IJL)=[M:ZPID]ZONMAJLIB(0)
  IJL +=1
Endif
For I=1 To dim([M:ZPID]ZONMAJ)-1
  If [M:ZPID]ZONMAJ(I)="" : Break : Endif
  If [F:PPC]DISCRGPRO(I-1)=1
    [M:ZPID]INCFLD(IJL)=[M:ZPID]ZONMAJ(I)
    [M:ZPID]INCDES(IJL)=[M:ZPID]ZONMAJLIB(I)
    IJL +=1
  Endif 
Next I
[M:ZPID]NBINC=IJL
Affzo [M]
Return

#---------------------------------------------------------------------
$CRIT_TARIF
Local Char    TEX (250)
Local Integer NBTEX, I, OK
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    NBTEX += 1
    If NBTEX > 1 : TEX += "\" : Endif
    TEX +="CRIT"+num$(I+1)+"  "+format$("K:20X",[F:PPC]CRIDES(I))+"  "+[F:PPC]FLDTYP(I)
  Endif
Next I
Call AVERTIR (TEX,OK) From GESECRAN

Return

#######################################################################

######################################## Ligne
Subprog AS_CODLIN(VALEUR)
Variable Decimal VALEUR
[M:ZPID]COD=[F:ZNE]COD
Diszo [ZPID]COD
End

######################################## Expression de sélection
Subprog AS_SELFRM(VALEUR)
Variable Char    VALEUR()
Local    Integer I,IJ
Raz [M:ZPID]FLTTAB, XXCONV, XXVAR
#[M:ZPID]FLTTAB="find(ABRFIC,'SPI')"

[M:ZPID]FLTTAB  ="find(ABRFIC,'SPI'"
For I=0 To dim([M:SPIE]TBL)-1
  If [M:SPIE]TBL(I)="" : Break : Endif
  Read [ATB]CODFIC=[M:SPIE]TBL(I) 
  If !fstat : [M:ZPID]FLTTAB +=",'"+[F:ATB]ABRFIC+"'" : Endif 
Next I
[M:ZPID]FLTTAB +=")"

#   critčres variables du tarif
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    [M:ZPID]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","+[F:PPC]CRIDES(I)
    IJ += 1 
  Else
    [M:ZPID]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
  Endif
Next I
For I=0 To dim([F:PRS]DES)-1
  If [M:ZPID]XXPRS(I)<>""
    [M:ZPID]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"+[M:ZPID]XXPRS(I)
    IJ += 1   
  Else
    [M:ZPID]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
#   variables du traitement
For I=0 To dim([F:ZNE]VARCOD)-1
  If [F:ZNE]VARCOD(I)<>"" 
    [M:ZPID]XXVAR(I)=[F:ZNE]VARCOD(I)+","+[F:ZNE]VARDES(I)
  Endif
Next I
End

#---------------------------------------
Subprog C_SELFRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Local Integer ER
  Local Char    CHAINE (80) 
  Default File [ZPI]         : # PPRICINCR doit etre le fichier par default
  Gosub VAR_DEF From ="WBI"+[F:ZNE]COD
  Onerrgo ERRSELFRM
  ER = 0
  CHAINE = num$(evalue(VALEUR))
  Onerrgo
  If ER
    mkstat = 2 : End
  Endif
Endif
End

$ERRSELFRM
# --- c'est une variable traitement ???
Local Char VARI : VARI=errm
If find(VARI ,[F:ZNE]VARCOD(0..dim([F:ZNE]VARCOD)-1)) : Resume : Endif
ER = errn
GERR=1 : GMESSAGE=mess(37,124,1)+"\"+errmes$(ER)+"\"+errm : # Expression incorrecte
Resume

######################################## 
Subprog AM_DELFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]INCFLDUPD, INCFRM, INCRNDTYP, INCRND
  Grizo 30 
Else
  Actzo 30
Endif
Affzo 30
End

########################################
Subprog B1_NBINC
Gosub CRIT_TARIF
End

######################################## Expression augmentation
Subprog AS_INCFRM(VALEUR)
Variable Char    VALEUR()
Local    Integer IJ
If [M]INCFLDUPD(nolign-1)<2 : mkstat=2 : End : Endif
Raz [M:ZPID]FLTTAB, XXCONV, XXVAR
#[M:ZPID]FLTTAB="find(ABRFIC,'SPI')"

[M:ZPID]FLTTAB  ="find(ABRFIC,'SPI'"
For I=0 To dim([M:SPIE]TBL)-1
  If [M:SPIE]TBL(I)="" : Break : Endif
  Read [ATB]CODFIC=[M:SPIE]TBL(I) 
  If !fstat : [M:ZPID]FLTTAB +=",'"+[F:ATB]ABRFIC+"'" : Endif 
Next I
[M:ZPID]FLTTAB +=")"

#   critčres variables du tarif
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    [M:ZPID]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","+[F:PPC]CRIDES(I)
    IJ += 1 
  Else
    [M:ZPID]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
  Endif
Next I
For I=0 To dim([F:PRS]DES)-1
  If [M:ZPID]XXPRS(I)<>""
    [M:ZPID]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"+[M:ZPID]XXPRS(I)
    IJ += 1   
  Else
    [M:ZPID]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
#   variables du traitement
For I=0 To dim([F:ZNE]VARCOD)-1
  If [F:ZNE]VARCOD(I)<>"" 
    [M:ZPID]XXVAR(I)=[F:ZNE]VARCOD(I)+","+[F:ZNE]VARDES(I)
  Endif
Next I
End

#---------------------------------------
Subprog C_INCFRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Local Integer ER
  Local Char    CHAINE (80)
  Default File [ZPI]         : # PPRICINCR doit etre le fichier par default
  Gosub VAR_DEF From ="WBI"+[F:ZNE]COD
  Onerrgo ERRINCFRM
  ER = 0
  CHAINE = num$(evalue(VALEUR))
  Onerrgo
  If ER
    mkstat = 2 : End
  Endif
Endif
End

$ERRINCFRM
# --- c'est une variable traitement ???
Local Char VARI : VARI=errm
If find(VARI ,[F:ZNE]VARCOD(0..dim([F:ZNE]VARCOD)-1)) : Resume : Endif
ER = errn
GERR=1 : GMESSAGE=mess(37,124,1)+"\"+errmes$(ER)+"\"+errm : # Expression incorrecte
Resume


########################################
Subprog AM_INCFLDUPD(VALEUR)
Variable Integer VALEUR
If VALEUR<2
  Raz [M]INCFRM(nolign-1), [M]INCRNDTYP(nolign-1), [M]INCRND(nolign-1)
  Grizo INCFRM(nolign-1), INCRNDTYP(nolign-1), INCRND(nolign-1) 
  Affzo [M]INCFRM(nolign-1), INCRNDTYP(nolign-1), INCRND(nolign-1)
Endif

End

######################################## Type arrondi
Subprog AS_INCRNDTYP(VALEUR)
Variable Integer VALEUR
If [M]INCFLDUPD(nolign-1)<2 : mkstat=2 : End : Endif
End

#---------------------------------------
Subprog AM_INCRNDTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<2
  Raz [M]INCRND(nolign-1)
  Grizo INCRND(nolign-1) 
  Affzo INCRND(nolign-1)
Endif
End

######################################## Valeur arrondi
Subprog AS_INCRND(VALEUR)
Variable Decimal VALEUR
If [M]INCFLDUPD(nolign-1)<2 | [M]INCRNDTYP(nolign-1)<2 : mkstat=2 : End : Endif
End

#######################################################################

