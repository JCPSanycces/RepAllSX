#<AdxTL>@(#)12.0.0.0 $Revision$
#############################################################################################

Call ZTERCEROS(BLANCOS,ZEROS)
End

#############################################################################################
Subprog ZTERCEROS(BLANCOS,ZEROS)
Value Char BLANCOS
Value Char ZEROS

Local Char    SAVIFS(10) , SAVIRS(10)

SAVIFS = adxifs 
SAVIRS = adxirs

adxifs = ";"                                          :  # ============= Separador de camp
adxirs = ""                                           :  # ============= Separador de registre

#dbgmode(0) = 1
#dbgmode(1) = 1

GTRACE = "terceros"                                        #============== Generamos en el servidor
FICTRA = filpath("ZTRASPASO",GTRACE,"txt", 0)

Openo FICTRA, 0 Using [FIC3]                                        : #============== Abrir fichero

#Openo "C:\ZTRASPASO\terceros.TXT"                          #============== En el C del servidor
#Openo "#@C:\ZTRASPASO\terceros.txt", 0 Using [FIC3]         #============== En c del cliente

Gosub LECTURA

Openo Using [FIC3]

adxifs    = SAVIFS
adxirs    = SAVIRS
End                 

#############################################################################################
$LECTURA
If clalev([F:BPR])=0  : Local File BPARTNER [BPR] : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS [BPA] : Endif

Gosub OUVRE

For [BPR]BPR0 
    If [F:BPR]BPSFLG = 2
        Read [BPS]BPS0 = [F:BPR]BPRNUM
        If fstat = 0
            If ([F:BPS]TSSCOD(0) = "CO" or [F:BPS]TSSCOD(0) = "TI")
                Gosub WRITERSR
            Endif
        Endif
    Endif 
    If [F:BPR]BPCFLG = 2
        If left$([F:BPR]BPRNUM,1) = "T"
            Gosub WRITERSR
        Endif
    Endif  
    Gosub OUVRE   
Next
Return

#################################################################################################
$WRITERSR

CODTER = format$("K:17X",[F:BPR]BPRNUM)
CODTER = ctrans(CODTER,";"," ")
Wrseq CODTER; Using [FIC3]                      #======== Código de terceros

If [F:BPR]BPCFLG = 2 : TIPTER = 0 Endif
If [F:BPR]BPSFLG = 2 : TIPTER = 1 Endif
If [F:BPR]BPTFLG = 2 : TIPTER = 2 Endif
If [F:BPR]REPFLG = 2 : TIPTER = 3 Endif
Wrseq num$(TIPTER); Using [FIC3]                #======== Tipo de terceros

NOMTER = format$("K:35X",[F:BPR]BPRNAM(0))    
NOMTER = ctrans(NOMTER,";"," ")
Wrseq NOMTER; Using [FIC3]                          #======== Nombre de terceros

Read[F:BPA]BPA0 = 1;[F:BPR]BPRNUM;[F:BPR]BPAADD
If fstat = 0
    DIRTER = format$("K:35X",[F:BPA]BPAADDLIG(0))
    DIRTER = ctrans(DIRTER,";"," ")
    Wrseq DIRTER; Using [FIC3]                      #======== Dirección del tercero

    COMRTER = format$("K:35X",[F:BPA]BPAADDLIG(1))
    COMRTER = ctrans(COMRTER,";"," ")
    Wrseq COMRTER; Using [FIC3]                      #======== Complemento Dirección del tercero
    
    POBTER = format$("K:35X",[F:BPA]CTY)
    POBTER = ctrans(POBTER,";"," ")
    Wrseq POBTER; Using [FIC3]                      #======== población del tercero

    CPTER = format$("K:9X",[F:BPA]POSCOD)
    CPTER = ctrans(CPTER,";"," ")
    Wrseq CPTER; Using [FIC3]                      #======== Código postal del tercero
                
    PROTER = format$("K:25X",[F:BPA]SAT)
    PROTER = ctrans(PROTER,";"," ")
    Wrseq PROTER; Using [FIC3]                      #======== provincia del tercero

    PAITER = format$("K:35X",[F:BPA]CRYNAM)
    PAITER = ctrans(PAITER,";"," ")
    Wrseq PAITER; Using [FIC3]                      #======== Pais del tercero

    WELTER = format$("K:21X",[F:BPA]TEL)
    WELTER = ctrans(WELTER,";"," ")
    Wrseq WELTER; Using [FIC3]                      #======== teléfono del tercero

Else
    DIRTER = format$("K:35X"," ")
    Wrseq DIRTER; Using [FIC3]
    COMRTER = format$("K:35X"," ")
    Wrseq COMRTER; Using [FIC3]
    POBTER = format$("K:35X"," ")
    Wrseq POBTER; Using [FIC3]
    CPTER = format$("K:9X"," ")
    Wrseq CPTER; Using [FIC3]
    PROTER = format$("K:25X"," ")
    Wrseq PROTER; Using [FIC3]
    PAITER = format$("K:35X"," ")
    Wrseq PAITER; Using [FIC3]
    WELTER = format$("K:21X"," ")
    Wrseq WELTER; Using [FIC3]
Endif

NIFTER = format$("K:25X",[F:BPR]CRN)
NIFTER = ctrans(NIFTER,";"," ")
Wrseq NIFTER; Using [FIC3]                          #======== nif del tercero

Wrseq chr$(10) Using [FIC3]
Return

######################################################################################################
$OUVRE
Local Integer L

Local Char CODTER(17)
Local Integer TIPTER(1)
Local Char NOMTER(35)
Local Char DIRTER(35)
Local Char COMRTER(35)
Local Char POBTER(35)
Local Char CPTER(9)
Local Char PROTER(25)
Local Char PAITER(35)
Local Char WELTER(21)
Local Char NIFTER(25)

Return
