#<AdxTL>@(#)10.0.0.0 $Revision$

######################################################################################
# Migraciˇn : Marcamos con #MIG
#
######################################################################################

$ACTION
Case ACTION
When "OUVRE"        : Gosub OUVRE
When "DEBUT"        : Gosub DEBUT
When "BOUTON"       : Gosub BOUTON
When Default 
Endcase
Return

###################################################################################
$DEBUT
Raz [M:ZRO0]
[M:ZRO0]VALDEB = 2
[M:ZRO0]PROVDEB = 2
Affzo [M:ZRO0]VALDEB
Affzo [M:ZRO0]PROVDEB
Return

##########################################################################
$BOUTON
If REPONSE = 1801

    [M:ZRO0]ZUSER = GUSER
    Affzo [M:ZRO0]ZUSER
    Gosub DECLARE           
    Gosub BORRAR  
            
    SIGUE = 0
    SIGUE2 = 0
    NIVEL = 1
    WFIRST = 0

    WITMREF = [M:ZRO0]ITMREFDEB
    WBOMALT = [M:ZRO0]BOMALTDEB
    WROUALT = [M:ZRO0]ROUALTDEB

    Gosub NIVELSR        #----- Bucle para los niveles -----#
    Call ZUNIFAB From ZUNIFABORI  #----- n║ de unidades fabricables ----#
        
    Call ETATN("Z-RECETAORI",GFONCTION,TBPAR,TBVAL) From ETAT 
    
    FIN = 1
Endif
Return

##########################################################################
$NIVELSR                          
While SIGUE = 0
    If WFIRST = 0            #---- Primera vez que entramos en el bucle ----#
        Gosub ESTPROD        #---- Leemos estructura de fabricaciˇn del artÝculo ----#
        If SIGUE2 = 1
            Goto FIN_NIVELSR
        Endif
        WFIRST = 1
    Else                     #---- Siguientes registros ----#
        SIGUE2 = 0
        NIVANT = NIVEL
        NIVEL += 1
        SIGUE = 1
        For [ZRO2]ZRO0 Where ZUSER=GUSER & NIVEST=NIVANT
            WITMREF = [ZRO2]CPNITMREF
            # Graba las secuencias seg˙n los niveles
            Case NIVEL 
                When 2 : WSEQANT1 = [ZRO2]CPNSEQ1 
                When 3 : WSEQANT1 = [ZRO2]CPNSEQ1 : WSEQANT2 = [ZRO2]CPNSEQ2
                When 4 : WSEQANT1 = [ZRO2]CPNSEQ1 : WSEQANT2 = [ZRO2]CPNSEQ2 : WSEQANT3 = [ZRO2]CPNSEQ3
                When 5 : WSEQANT1 = [ZRO2]CPNSEQ1 : WSEQANT2 = [ZRO2]CPNSEQ2 : WSEQANT3 = [ZRO2]CPNSEQ3 
&                      : WSEQANT4 = [ZRO2]CPNSEQ4
                When 6 : WSEQANT1 = [ZRO2]CPNSEQ1 : WSEQANT2 = [ZRO2]CPNSEQ2 : WSEQANT3 = [ZRO2]CPNSEQ3
&                      : WSEQANT4 = [ZRO2]CPNSEQ4 : WSEQANT5 = [ZRO2]CPNSEQ5
            Endcase       

            Gosub ESTPROD
            If SIGUE2 = 0
                SIGUE = 0
            Endif
        Next
        ULTNIV = NIVEL
    Endif
Wend

$FIN_NIVELSR
Return

#########################################################################
$ESTPROD

Read [BOH]BOH0 = WITMREF;WBOMALT
If fstat = 0
    If [BOH]BOHSTRDAT <= [M:ZRO0]DATINI & [BOH]BOHENDDAT >= [M:ZRO0]DATFIN
        For [BOD]BOD0 Where ITMREF=[BOH]ITMREF & BOMALT=[BOH]BOMALT & BOMSTRDAT<=[M:ZRO0]DATINI & BOMENDDAT>=[M:ZRO0]DATFIN       

            Gosub GRABA_COMPONENTES           #---- Graba detalles del componente ----#
            WITMREF = [BOD]ITMREF
            WROUALT = [BOD]BOMALT
            WCPNOPE = [BOD]CPNOPE
            Gosub GRABA_OPESUB                #---- Graba operaciones subcontrataciˇn ----#

            [ZRO]ZUSER = GUSER
            Trbegin [ZRO]
                Write [ZRO]                
            Commit    
            SIGUE2 = 0
        Next
    Else
        SIGUE2 = 1
    Endif
Else
    SIGUE2 = 1
Endif

Return

##########################################################################
$GRABA_COMPONENTES

[ZRO]NIVEST = NIVEL
[ZRO]FCY = [M:ZRO0]FCYDEB
[ZRO]ITMREF = [BOD]ITMREF
[ZRO]BOMALT = [BOD]BOMALT
[ZRO]CPNITMREF = [BOD]CPNITMREF
Case NIVEL 
    When 1 : [ZRO]CPNSEQ1 = [BOD]BOMSEQ
    When 2 : [ZRO]CPNSEQ1 = WSEQANT1 : [ZRO]CPNSEQ2 = [BOD]BOMSEQ
    When 3 : [ZRO]CPNSEQ1 = WSEQANT1 : [ZRO]CPNSEQ2 = WSEQANT2 : [ZRO]CPNSEQ3 = [BOD]BOMSEQ
    When 4 : [ZRO]CPNSEQ1 = WSEQANT1 : [ZRO]CPNSEQ2 = WSEQANT2 : [ZRO]CPNSEQ3 = WSEQANT3 
&          : [ZRO]CPNSEQ4 = [BOD]BOMSEQ
    When 5 : [ZRO]CPNSEQ1 = WSEQANT1 : [ZRO]CPNSEQ2 = WSEQANT2 : [ZRO]CPNSEQ3 = WSEQANT3 
&          : [ZRO]CPNSEQ4 = WSEQANT4 : [ZRO]CPNSEQ5 = [BOD]BOMSEQ
    When 6 : [ZRO]CPNSEQ1 = WSEQANT1 : [ZRO]CPNSEQ2 = WSEQANT2 : [ZRO]CPNSEQ3 = WSEQANT3 
&          : [ZRO]CPNSEQ4 = WSEQANT4 : [ZRO]CPNSEQ5 = WSEQANT5 : [ZRO]CPNSEQ6 = [BOD]BOMSEQ

Endcase

[ZRO]CPNSEQNUM = [BOD]BOMSEQNUM

Read [ITM]ITM0 = [BOD]CPNITMREF
If fstat = 0
    [ZRO]CPNDES = [ITM]ITMDES1
Endif

[ZRO]CPNCTD = [BOD]LIKQTY
[ZRO]CPNINI = [BOD]BOMSTRDAT
[ZRO]CPNFIN = [BOD]BOMENDDAT
[ZRO]CPNTYP = [BOD]CPNTYP

                                    #---- Graba stock fÝsico y rechazado ----#
Read [ITV]ITV0 = [BOD]CPNITMREF;[M:ZRO0]FCYDEB
If fstat = 0
    [ZRO]PHYSTO = [ITV]PHYSTO
    [ZRO]REJSTO = [ITV]REJSTO
##MIG
#    [ZRO]DISSTO = [ITV]PHYSTO - [ITV]RERSTO - [ITV]ALLSTO - [ITV]BPRSTO - [ITV]SCOSTO
    Local Decimal YRERSTO, YALLSTO,YBPRSTO
    YRERSTO=[ITV]GLOALL
    YALLSTO=([ITV]PHYALL+[ITV]CTLALL+[ITV]REJALL)
    YBPRSTO=([ITV]BPRPHYSTO+[ITV]BPRCTLSTO+[ITV]BPRREJSTO)
    YSCOSTO=([ITV]SCOPHYSTO+[ITV]SCOCTLSTO+[ITV]SCOREJSTO)

    [ZRO]DISSTO = [ITV]PHYSTO - YRERSTO - YALLSTO - YBPRSTO - YSCOSTO
##\MIG

Else
    [ZRO]PHYSTO = 0
    [ZRO]REJSTO = 0
    [ZRO]DISSTO = 0
Endif

       #---- Si el flag proveedor estß marcado busca el ˙ltimo proveedor y el ˙ltimo precio de compra ----#
If [M:ZRO0]PROVDEB = 2
    Gosub  GRABA_PROVPRE
Else
    [ZRO]CPNBPS = ""
    [ZRO]CPNPRE = 0
Endif
       #---- Si el flag de coste estß marcado busca el coste estßndar act. y precio tarifa ----#
If [M:ZRO0]VALDEB = 2
    Gosub GRABA_CSTEST
    TARBPS = [ZRO]CPNBPS
    TARITMREF = [ZRO]CPNITMREF
    WTARIFA = 0    
    Gosub GRABA_TARIFA
Endif

Return

##########################################################################
$GRABA_PROVPRE
Filter [PID] Where ITMREF = [BOD]CPNITMREF
Read [PID]PID0 Last
If fstat = 0
    [ZRO]CPNBPS = [PID]BPR
    [ZRO]CPNPRE = [PID]NETPRI
Else
    Filter [ITP] Where ITMREF = [BOD]CPNITMREF Order By Key ITP0
    Read [ITP]First
    If fstat = 0
        [ZRO]CPNBPS = [ITP]BPSNUM
        [ZRO]CPNPRE = 0
    Else
        [ZRO]CPNBPS = ""
        [ZRO]CPNPRE = 0
    Endif    
    Filter [ITP]
Endif
Filter [PID]
Return

##########################################################################
$GRABA_CSTEST
                #---- Busca el coste estßndar actualizado ----#
Local Integer XYEAR

XYEAR = year([M:ZRO0]DATINI)
Filter [ITC] Where STOFCY=[M:ZRO0]FCYDEB & ITMREF=[BOD]CPNITMREF & YEA=XYEAR & CSTTYP=2 Order By CSTSEQ
Read [ITC] Last
If fstat = 0
    [ZRO]CPNCST = [ITC]VLTTOT
Else
    [ZRO]CPNCST = 0    
Endif
Filter [ITC]   
Return

##########################################################################
$GRABA_TARIFA
#--------- Recuperamos la tarifa del artÝculo - proveedor -----------#

#--- Aperturas pantallas necesarias ---#
Local Mask POH0[POH0], POH2[POH2], POH1[POH1]

#--- Cargamos datos pantalla ---#
Local Integer NOL : NOL = 0
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:MVS])=0 : Local File BPSUPPMVT [MVS] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS [ITP] : Endif
If clalev([F:PPK])=0 : Local File PPRICLINK [PPK] : Endif
If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif
If clalev([F:PWO])=0 : Local File PWRKORDERS [PWO] : Endif

Local Integer OK

Gosub DEFTRANS From SUBPOHA
Gosub SETTRANS From SUBPOHA
Gosub OUVRE From SUBPOHA

[M:POH2]PUU(0) = "UN"

[M:POH0]BPSNUM = TARBPS
[M:POH2]ITMREF(0) = TARITMREF

#--- Recuperamos impuesto ---#
Read [BPS]BPS0 = TARBPS
Read [ITM]ITM0 = TARITMREF
Read [BPR]BPR0 = TARBPS

Read [TVC]TVC0 = [F:BPS]VACBPR;[F:ITM]VACITM
If fstat = 0
    [M:POH2]VAT1(0) = [TVC]VAT
Endif
[M:POH0]ORDDAT = [M:ZRO0]DATINI
[M:POH2]QTYUOM(0) = 1
[M:POH2]UOM(0) = [F:ITM]PUU
[M:POH1]CUR = [F:BPR]CUR
[M:POH1]CHGTYP = 1

GPUU = "UN"
GCUR = "UN"
nolign = 1

Call RECH_TARIF ("POH",NOL) From TRTACHTAR1

If WTARIFA = 0
    [F:ZRO]CPNTRF = [M:POH2]NETPRI(0)
Else
    [F:ZRO]TRFSUB = [M:POH2]NETPRI(0)
Endif    

Return

##########################################################################
$GRABA_OPESUB
Read [ROO]ROO0 = WITMREF;WROUALT;WCPNOPE;0
If fstat = 0

    If [ROO]SCOCOD <> 1
        Case [ROO]SCOCOD
            When 2  : [ZRO]CNTSUB = [ROO]WST
            When 3  : [ZRO]CNTSUB = [ROO]SCOWST
        Endcase

        [ZRO]OPESUB = [ROO]OPENUM
        [ZRO]ROUALT = WROUALT
        [ZRO]ITMSUB = [ROO]SCOITMREF

        Read [ROH]ROH0=WITMREF;WROUALT
        If fstat = 0 
            [ZRO]INISUB = [ROH]ROUSTRDAT                
            If [ROO]RPLDAT = '00000000'
                [ZRO]FINSUB = [ROH]ROUENDDAT
            Else
                [ZRO]FINSUB = [ROO]RPLDAT
            Endif
        Endif

        If [M:ZRO0]PROVDEB = 2
##MIG
#            [ZRO]BPSSUB = [ROO]BPSNUM
            [ZRO]BPSSUB = [ROO]BPRNUM
##\MIG
        Else
            [ZRO]BPSSUB = ""
        Endif

        If [M:ZRO0]VALDEB = 2
            [ZRO]CSTSUB = [ROO]REFPRI
                                    #---- Busca precio ˙ltima compra ----#
            Filter [PID2] Where ITMREF = [ROO]SCOITMREF
            Read [PID2] Last
            If fstat = 0
                [ZRO]PRESUB = [PID2]NETPRI                
            Else
                [ZRO]PRESUB = 0                
            Endif
                                    #---- Busca precio tarifa
             TARBPS = [ZRO]BPSSUB 
             TARITMREF = [ZRO]ITMSUB
             WTARIFA = 1          
             Gosub GRABA_TARIFA
        Else
            [ZRO]CSTSUB = 0
            [ZRO]PRESUB = 0
            [ZRO]TRFSUB = 0
        Endif
    Else
        [ZRO]OPESUB = 0
        [ZRO]CNTSUB = ""
        [ZRO]ROUALT = WROUALT
        [ZRO]ITMSUB = ""
        [ZRO]BPSSUB = ""
        [ZRO]CSTSUB = 0
        [ZRO]PRESUB = 0
        [ZRO]TRFSUB = 0
        [ZRO]INISUB = '00000000'
        [ZRO]FINSUB = '00000000'
    Endif
Endif
Return


########################################################################
$BORRAR
Trbegin [ZRO]     
     Delete [ZRO] Where [F:ZRO]ZUSER = GUSER 
Commit

Return

##########################################################################
$OUVRE
If clalev([F:ZRO])=0 : Local File ZRECETAORI [ZRO] : Endif
If clalev([F:ZRO2])=0 : Local File ZRECETAORI [ZRO2] : Endif
If clalev([F:BOH])=0 : Local File BOM [BOH] : Endif
If clalev([F:BOD])=0 : Local File BOMD [BOD] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Endif
If clalev([F:ITV])=0 : Local File ITMMVT [ITV] : Endif
If clalev([F:PID])=0 : Local File PINVOICED [PID] : Endif
If clalev([F:PID2])=0 : Local File PINVOICED [PID2] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS [ITP] : Endif
If clalev([F:ITC])=0 : Local File ITMCOST [ITC] : Endif
If clalev([F:ROO])=0 : Local File ROUOPE [ROO] : Endif
If clalev([F:ROH])=0 : Local File ROUTING [ROH] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK [SPK] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES [ITS] : Endif

Return

##########################################################################
$DECLARE
Local Char WITMREF
Local Integer WBOMALT, WROUALTDEB, WROUALT, WCPNOPE,SIGUE, SIGUE2, NIVEL, WFIRST, NIVANT, ULTNIV
Local Char TBPAR(1)(1), TBVAL(1)(1), TARBPS, TARITMREF
Local Integer I, WTARIFA
Return

########################################
Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR
Local Integer WANNO1
Local Integer WANNO2

WANNO1 = year(VALEUR)
WANNO2 = year([M:ZRO0]DATINI)

If WANNO1 <> WANNO2
    Errbox "Los a˝os no pueden ser diferentes" Titled "Receta fabricaciˇn"
    mkstat = 2
Else
    [M:ZRO0]DATFIN = VALEUR
    Affzo [M:ZRO0]DATFIN
Endif
End

########################################
Subprog S_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif

Choose [TRO]
& Where [TRO]FCY = [M:ZRO0]FCYDEB or [TRO]FCY =""
& Order By [TRO]ROUALT Asc Using
& [TRO]ROUALT Titled "Alternativa ruta",
& [TRO]TRODES Titled "Descripciˇn"
& Sized (80,240)
& Titled "Selecciˇn Alternativa ruta"

If status <> 7
   VALEUR = [TRO]ROUALT
   [M:ZRO0]ROUALTDEB = VALEUR
   Affzo [M:ZRO0]ROUALTDEB
Else
   Raz [M:ZRO0]ROUALTDEB  
ENDIF
Close File [TRO]
End

########################################
Subprog AM_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif

Read [TRO]TRO0 = VALEUR
If fstat = 0
    If [TRO]FCY <> [M:ZRO0]FCYDEB and [TRO]FCY <> ""
        Errbox "La alternativa no corresponde con planta" Titled "Selecciˇn Alternativa ruta"
        mkstat = 2
    Else
        [M:ZRO0]ROUALTDEB = VALEUR
        Affzo [M:ZRO0]ROUALTDEB
    Endif 
Else
    Errbox "La alternativa no existe" Titled "Selecciˇn Alternativa ruta"
    mkstat = 2
Endif
End

########################################
Subprog S_BOMALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer BOMALT1, BOMALT2, BOMALT3
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif
If clalev ([F:TBO]) <= 0 Local File TABBOMALT [TBO] Endif

Read [TRO]TRO0 = [M:ZRO0]ROUALTDEB
If fstat = 0 
    BOMALT1 = [TRO]BOMALT1
    BOMALT2 = [TRO]BOMALT2
    BOMALT3 = [TRO]BOMALT3
Endif

Choose [TBO]
& Where ([TBO]BOMALT=BOMALT1 or [TBO]BOMALT=BOMALT2 or [TBO]BOMALT=BOMALT3) & ([TBO]FCY=[M:ZRO0]FCYDEB or [TBO]FCY="")
& Order By [TBO]BOMALT Asc Using 
& [TBO]BOMALT Titled "Alternativa ruta",
& [TBO]TBODES Titled "Descripciˇn"
& Sized (80,240)
& Titled "Selecciˇn Alternativa ruta"

If status <> 7
   VALEUR = [TBO]BOMALT
   [M:ZRO0]BOMALTDEB = VALEUR
   Affzo [M:ZRO0]BOMALTDEB 
Else
   Raz [M:ZRO0]BOMALTDEB  
Endif
Close File [TBO]

End

########################################
Subprog AM_BOMALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer BOMALT1, BOMALT2, BOMALT3
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif
If clalev ([F:TBO]) <= 0 Local File TABBOMALT [TBO] Endif

Read [TRO]TRO0 = [M:ZRO0]ROUALTDEB
If fstat = 0 
    BOMALT1 = [TRO]BOMALT1
    BOMALT2 = [TRO]BOMALT2
    BOMALT3 = [TRO]BOMALT3
Endif

If VALEUR <> BOMALT1 and VALEUR <> BOMALT2 and VALEUR <> BOMALT3
    Errbox "La alternativa estructura no es valida" Titled "Validaciˇn Alternativa estructura"
    mkstat = 2
Else
    [M:ZRO0]BOMALTDEB = VALEUR
    Affzo [M:ZRO0]BOMALTDEB   
Endif    
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Endif
Read [ITM]ITM0 = VALEUR
If fstat = 0
    [ZRO0]ITMDESDEB = [ITM]ITMDES1
Else
    [ZRO0]ITMDESDEB = ""
Endif

End

