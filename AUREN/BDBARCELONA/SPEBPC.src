# ZDF  11-10-02     Dirección Fiscal de Cliente para Facturas          X.Buxadé    #
#                                                                                  #
####################################################################################

$ACTION
Case ACTION
 When "SETBOUT" : Gosub SETBOUT
 When Default
Endcase
Return


$SETBOUT
 
If CLECUR and GREP <> 'C' and GREP <> 'M'
  CHMEN += "x" 
Endif
Gosub SET_BOUT_SPE From GSAISIE


Return
########################################
Subprog AP_BPCINV(VALEUR)
Variable Char    VALEUR()
Local Integer I 
Local Char    WCODADR(3)
# --- Alimentation de l'adresse du client facture : Recherche du code adresse par défaut
If VALEUR = [M]BPCNUM
    # --- client facture = client commande  
    For I = 0 to [M:BPAC]NBADR-1 
        If [M:BPAC]BPAADDFLG(I) = 2 : [M]ZBPAFIS=[M:BPAC]CODADR(I) : Break : Endif 
    Next I 
Else
    # --- client facture <> client commande :
    Read [BPR]BPR0 = VALEUR
    If   fstat = 0 : [M]ZBPAFIS = [F:BPR]BPAADD : Endif
Endif
Affzo [M:BPC3]BPAINV 
End


########################################
Subprog AS_ZBPAFIS(VALEUR)
Variable Char    VALEUR()
If [M:BPAC]CODADR(0)="" mkstat=2 Endif
End

########################################
Subprog C_ZBPAFIS(VALEUR)
Variable Char    VALEUR()
If  [M:BPC3]BPCINV = [M:BPC0]BPCNUM 
    # --- client facture = client commande
    MATCH_BPAADD = find(VALEUR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1)) 
    If MATCH_BPAADD = 0 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
Else
    # --- client facture <> client commande
    Look [BPA]BPA0 = 1;[M:BPC3]BPCINV;VALEUR
    If   fstat>1 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
Endif

End

########################################
Subprog IB_ZBPAFIS
If  [M:BPC3]BPCINV = [M:BPC0]BPCNUM 
    Raz GBOUT2
Else
    Raz GBOUT1
Endif
End

