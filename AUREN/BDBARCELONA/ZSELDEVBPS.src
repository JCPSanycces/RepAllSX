#<AdxTL>@(#)5.0.0.0 $Revision:   1.20  $ Gestión de la máscara ITN7

$ACTION
Case ACTION
 When "DEBUT" : Gosub CARGA        
 When "OK"    : Gosub WOK        
 When Default
Endcase
Return


######################################################################################
$CARGA

Gosub OUVRE

#dbgmode (0) = 1 : # dbgmode (1) = 1

Local Char WSOHNUM
Local Integer WSOPLIN
Local Char WSOHITM

Local Char WPOHNUM
Local Char WSDHNUM
Local Decimal WAMTATI
Local Char WNUMSOL
Local Integer SWFAC

WNUMSOL = PARAM(1)
NOL =-1
Read [F:SRE]SRE0 = WNUMSOL
If fstat = 0 Then
    WSOHNUM = [F:SRE]SRECOVNUM
    WSOHITM = [F:SRE]ZRECOVITM
    WSOPLIN = [F:SRE]ZSOPLIN
Endif

SWFAC= 0 
For [SOP]SOP5 Where [SOP]SOHNUM = WSOHNUM and [SOP]ITMREF = WSOHITM and [SOP]SOPLIN = WSOPLIN
    #Pedido amb contramarca
    If [SOP]FMI = 2 or [SOP]FMI = 3
        Read [SOQ]SOQ0 = [SOP]SOHNUM;[SOP]SOPLIN;[SOP]SOPSEQ
        If fstat = 0 Then 
            Read [POQ]POQ0 = [SOQ]FMINUM;[SOQ]FMILIN;[SOQ]FMISEQ
            If fstat = 0 Then
                Read [PND]PND3 = [POQ]POHNUM;[POQ]ITMREF;[POQ]POPLIN
                If fstat = 0 Then
                      NOL += 1
                      [M:ZSDB]ZSRHNUM(NOL) = [PND]PNHNUM
                      [M:ZSDB]ZBPSNUM(NOL) = [PND]BPSNUM
                      [M:ZSDB]ZPOHNUM(NOL) = [PND]POHNUM
                      [M:ZSDB]ZPTHNUM(NOL) = [PND]POHNUM
                      [M:ZSDB]NBLIG = NOL+1
                      Affzo [M:ZSDB]
                Endif
            Endif
        Endif    
    Else
        #dbgmode (0) = 1 :  dbgmode (1) = 1
        #Pedido de compra informado en el de venta, sino busqueda STOJOU    
        If [SOP]POHNUM <> "" Then
            Read [SOQ]SOQ0 = [SOP]SOHNUM;[SOP]SOPLIN;[SOP]SOQSEQ
            If fstat = 0 Then 
                Read [POQ]POQ0 = [SOQ]FMINUM;[SOQ]FMILIN;[SOP]FMISEQ
                If fstat = 0 Then
                    Read [PND]PND3 = [POQ]POHNUM;[POQ]ITMREF;[POQ]POPLIN
                    If fstat = 0 Then
                          NOL += 1
                          [M:ZSDB]ZSRHNUM(NOL) = [PND]PNHNUM
                          [M:ZSDB]ZBPSNUM(NOL) = [PND]BPSNUM
                          [M:ZSDB]ZPOHNUM(NOL) = [PND]POHNUM
                          [M:ZSDB]ZPTHNUM(NOL) = [PND]PTHNUM
                          [M:ZSDB]NBLIG = NOL+1
                          Affzo [M:ZSDB]
                    Endif
                Endif
            Endif    
        Else
            Read [SDD]SDD1 = [SOP]SOHNUM;[SOP]SOPLIN;[SOP]SOPSEQ
            If fstat = 0 Then
                For [STJ]STJ4 Where [STJ]VCRNUM = [SDD]SDHNUM and [STJ]VCRLIN =[SDD]SDDLIN and [STJ]VCRTYP = 4    
                    For [STJ1]STJ5 Where [STJ1]LOT = [STJ]LOT and [STJ1]VCRTYP = 8 
                          NOL += 1
                          [M:ZSDB]ZSRHNUM(NOL) = [STJ1]VCRNUM
                          
                          Read [STJ2]STJ5 = [STJ1]LOT;[STJ1]VCRLIN;6
                              [M:ZSDB]ZPTHNUM(NOL) = [STJ2]VCRNUM
                          Read [F:PTD]PTD0= [STJ2]VCRNUM;[STJ2]VCRLIN    
                              [M:ZSDB]ZPOHNUM(NOL) = [PTD]POHNUM
                              [M:ZSDB]ZBPSNUM(NOL) = [PTD]BPSNUM                          
                          [M:ZSDB]NBLIG = NOL+1
                          Affzo [M:ZSDB]
                    Next
                Next    
            Endif
        Endif
        
    Endif
Next
Return

######################################################################################
$FIN 
   FIN =1
End 

######################################################################################
$OUVRE
Local Integer OK 

If clalev([F:SOP])=0 : Local File SORDERP  [SOP] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ  [SOQ] : Endif
If clalev([F:POQ])=0 : Local File PORDERQ  [POQ] : Endif
If clalev([F:PND])=0 : Local File PRETURND [PND] : Endif


If clalev([F:SIV])=0 : Local File SINVOICEV   [SIV] : Endif
If clalev([F:SIV2])=0 : Local File SINVOICEV  [SIV2] : Endif

If clalev([F:SRE])=0 : Local File SERREQUEST [SRE] : Endif
If clalev([F:SRD])=0 : Local File SRETURND   [SRD] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif
If clalev([F:STJ])=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STJ1])=0 : Local File STOJOU    [STJ1] : Endif
If clalev([F:STJ2])=0 : Local File STOJOU    [STJ2] : Endif
If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif

Local Shortint NOL 

Return

######################################################################################
$WOK
#    [M:ITN7]ZNUMABO = [M:ZSAB]ZNUMABO(nolign-1)
#    [M:ITN7]ZIMPII = [M:ZSAB]ZAMTATI(nolign-1)
#    [M:ITN7]ZDEVCLI = [M:ZSAB]ZSRHNUM(nolign-1)
 
     PARAM(2) = [M:ZSDB]ZSRHNUM(nolign-1)
#    PARAM(3) = num$([M:ZSAB]ZAMTATI(nolign-1))
#    If [M:ZSAB]ZSIHORI(nolign-1) = 6 Then
#        PARAM(4) = [M:ZSAB]ZSRHNUM(nolign-1)
#    Endif

#   Affzo [M:ITN7]ZDEVCLI
#   Affzo [M:ITN7]ZNUMABO
#   Affzo [M:ITN7]ZIMPII

Close File [SIV]
Close File [SRE]
Close File [SRD]
Close File [SIH]
Close File [SDD]


FIN = 1

Return
