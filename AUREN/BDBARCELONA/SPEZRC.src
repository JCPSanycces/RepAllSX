########################################
Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR
Local Integer WANNO1
Local Integer WANNO2

WANNO1 = year(VALEUR)
WANNO2 = year([M:ZRC0]DATINI)

If WANNO1 <> WANNO2
    Errbox "Los aŮos no pueden ser diferentes" Titled "Receta fabricaciůn"
    mkstat = 2
Else
    [M:ZRC0]DATFIN = VALEUR
    Affzo [M:ZRC0]DATFIN
Endif
End

