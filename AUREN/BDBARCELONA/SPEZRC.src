#<AdxTJ>@(#)12.0.0.0 $Revision$
######################################################################################
#                                                                                    #
# C.A.     Fecha     Descripiůn                              Autor                   #
# ----     -----     ----------                              -----                   #
# ZMP      22/09/04  Receta de Fabricaciůn                   Felix Gonzalez (Infolan)#
# ZMP      02/12/04  Modificaciůn Receta de Fabricaciůn      Aswieta Abirama(Infolan)#
#          14/05/19  Adaptaciůn para V11                     Meritxell Rufas (AUREN) #
#                                                                                    #
#------------------------------------------------------------------------------------#
# Migraciůn : Marcamos con #MIG
#
# 06.435.234 - JC.07022023.RECETA
######################################################################################

$ACTION
Case ACTION
When "OUVRE"        : Gosub OUVRE
When "DEBUT"        : Gosub DEBUT
When "BOUTON"       : Gosub BOUTON
When Default
Endcase
Return

###################################################################################
$DEBUT
Raz [M:ZRC0]
[M:ZRC0]VALDEB = 2
[M:ZRC0]PROVDEB = 2
Affzo [M:ZRC0]VALDEB
Affzo [M:ZRC0]PROVDEB
Return

##########################################################################
$BOUTON

If REPONSE = 1801

    [M:ZRC0]ZUSER = GUSER
    Affzo [M:ZRC0]ZUSER
    Gosub DECLARE
    Gosub BORRAR

    SIGUE = 0
    SIGUE2 = 0
    NIVEL = 1
    WFIRST = 0
    NIVOPE =  0

    WITMREF = [M:ZRC0]ITMREFDEB
    WBOMALT = [M:ZRC0]BOMALTDEB
    WROUALT = [M:ZRC0]ROUALTDEB

    #----- Chequear las alternativas de ruta y estructura introducidas ----#
    Gosub CHECK_ALT
    #----- Bucle para los niveles -----#
    Gosub NIVELSR
    #----- Calcular el nļ de unidades fabricables ----#
    Call ZUNIFAB From ZUNIFAB

    Call ETATN("Z-RECETA",GFONCTION,TBPAR,TBVAL) From ETAT

    FIN = 1
Endif
Return
##########################################################################
$CHECK_ALT
# Chequear que la ruta y lass alternativas de ruta y estructura introducidas estŠn vŠlidas
# para el artŪculo actual

# La ruta de producciůn del artŪculo - planta
Read [ITF]ITF0 = WITMREF;[M:ZRC0]FCYDEB
If fstat = 0
    If [ITF]MFGROU <> ""
        If [ITF]MFGROUALT = WROUALT
            Read [TRO]TRO0 = WROUALT
            If fstat = 0
                If [TRO]BOMALT1 = WBOMALT | [TRO]BOMALT2 = WBOMALT | [TRO]BOMALT3 = WBOMALT
                    WROUTE = [ITF]MFGROU
                Else
                    If WFIRST = 0
                        Infbox "La alternativa estructura introducida no es vŠlida para el artŪculo-planta"
                    Else
                        Infbox "La alternativa estructura introducida no es vŠlida para algķn artŪculo intermedio"
                    Endif
                    Gosub BORRAR
                    End
                Endif
            Endif
        Else
            If WFIRST = 0
                Infbox "La alternativa ruta introducida no es vŠlida para el artŪculo-planta"
            Else
                Infbox "La alternativa ruta introducida no es vŠlida para algķn artŪculo intermedio"
            Endif
            Gosub BORRAR
            End
        Endif
    Else
        WROUTE = WITMREF

        ## AUREN - ADAPTACI”N MIGRACI”N V11
        #Read [ROH]ROH0 = WROUTE; WROUALT
        Read [ROH]ROH0 = WROUTE; WROUALT; [M:ZRC0]FCYDEB

        If fstat
            If WFIRST = 0
                Infbox "La alternativa ruta introducida no es vŠlida para el artŪculo-planta"
            Else
                Infbox "La alternativa ruta introducida no es vŠlida para algķn artŪculo intermedio"
            Endif
            Gosub BORRAR
            End
        Endif
    Endif
Endif
Return
##########################################################################
$NIVELSR
While SIGUE = 0
    If WFIRST = 0            #---- Primera vez que entramos en el bucle ----#
        Gosub ESTOPER        #---- Leemos las operaciones del artŪculo ----#
        If SIGUE2 = 1
            Goto FIN_NIVELSR
        Endif
        WFIRST = 1
    Else                     #---- Siguientes registros ----#
        SIGUE2 = 0
        NIVANTOPE = NIVOPE
        NIVANT = NIVEL
        NIVOPE += 1
        NIVEL += 1
        SIGUE = 1

        For [ZRC2]ZRC0 Where ZUSER=GUSER & NIVCPN=NIVANT
            WITMREF = [ZRC2]CPNITMREF
            Read [ITM]ITM0 = WITMREF
            If fstat = 0
                # Comprobar si es un artŪculo con estructura y ruta

				## AUREN - ADAPTACI”N MIGRACI”N V11
                #Read [TCL]TCL0 = [ITM]TCLCOD
                #If fstat = 0
                #    If [TCL]CLSTYP = 2 | [TCL]CLSTYP = 3 | [TCL]CLSTYP = 4
                #        Gosub CHECK_ALT   #---- Chequar la ruta y las alternativas  ----#
                #    Else
                #        WROUTE = WITMREF
                #    Endif
                #Endif
                If [ITM]MFGFLG = 2
                Read [ITB]ZITB9 = [ITM]ITMREF
                If fstat = 0
                    If [ITB]LLCTYP = 2 & [ITB]BOMEXIFLG = 2
                        Gosub CHECK_ALT   #---- Chequar la ruta y las alternativas  ----#
                    Else
                        WROUTE = WITMREF
                    Endif
                Endif
                Else
                    WROUTE = WITMREF
                Endif

				## AUREN - ADAPTACI”N MIGRACI”N V11

            Endif
            Gosub ESTOPER     #---- Leemos las operaciones del artŪculo ----#
            If SIGUE2 = 0
                SIGUE = 0
            Endif
        Next
        ULTNIV = NIVEL
    Endif
Wend

$FIN_NIVELSR
Return
#########################################################################
$ESTOPER
Trbegin [ZR2], [ZRC]
For [ROO] Where ITMREF = WROUTE & ROUALT = WROUALT
    [ZR2]NIVOPE = NIVOPE
    [ZR2]NIVCPN = NIVEL
    [ZR2]ITMREF = WROUTE
    [ZR2]ZUSER = GUSER
    [ZR2]FCY = [M:ZRC0]FCYDEB

## AUREN - Nivel operaciůn no controlado
If NIVOPE >= 6
    Infbox "Nivel no controlado. Nivel:" + num$(NIVOPE) + ", ArtŪculo:" + WITMREF + ", Ruta: " + WROUTE
Endif
## AUREN - Nivel operaciůn no controlado


    # Guardar las secuencias de las operaciones
    Case NIVOPE
        When 0 : [ZR2]OPESEQ1 = [ROO]OPENUM
        When 1 : [ZR2]OPESEQ1 = [ZRC2]OPESEQ1 : [ZR2]OPESEQ2 = [ROO]OPENUM
        When 2 : [ZR2]OPESEQ1 = [ZRC2]OPESEQ1 : [ZR2]OPESEQ2 = [ZRC2]OPESEQ2 : [ZR2]OPESEQ3 = [ROO]OPENUM
        When 3 : [ZR2]OPESEQ1 = [ZRC2]OPESEQ1 : [ZR2]OPESEQ2 = [ZRC2]OPESEQ2 : [ZR2]OPESEQ3 = [ZRC2]OPESEQ3 : [ZR2]OPESEQ4 = [ROO]OPENUM
        When 4 : [ZR2]OPESEQ1 = [ZRC2]OPESEQ1 : [ZR2]OPESEQ2 = [ZRC2]OPESEQ2 : [ZR2]OPESEQ3 = [ZRC2]OPESEQ3 : [ZR2]OPESEQ4 = [ZRC2]OPESEQ4
&              : [ZR2]OPESEQ5 = [ROO]OPENUM
        When 5 : [ZR2]OPESEQ1 = [ZRC2]OPESEQ1 : [ZR2]OPESEQ2 = [ZRC2]OPESEQ2 : [ZR2]OPESEQ3 = [ZRC2]OPESEQ3 : [ZR2]OPESEQ4 = [ZRC2]OPESEQ4
&              : [ZR2]OPESEQ5 = [ZRC2]OPESEQ5 : [ZR2]OPESEQ6 = [ROO]OPENUM
    Endcase
    Case [ROO]SCOCOD
        When 1  : [ZR2]OPESUB = 1 : [ZR2]OPECNT = [ROO]WST
        When 2  : [ZR2]OPESUB = 2 : [ZR2]OPECNT = [ROO]WST
        When 3  : [ZR2]OPESUB = 2 : [ZR2]OPECNT = [ROO]SCOWST
    Endcase
    [ZR2]OPEITM = [ROO]SCOITMREF

    ## AUREN. GUARDAR DESCRIPCI”N DE LA OPERACI”N
    [ZR2]OPEDES = [ROO]ROODES

    ## AUREN - ADAPTACI”N MIGRACI”N V11
    #Read [ROH]ROH0=WROUTE;WROUALT
    Read [ROH]ROH0=WROUTE;WROUALT;[M:ZRC0]FCYDEB

    If fstat = 0
        [ZR2]OPEINI = [ROH]ROUSTRDAT

########### SAGE -  15112010 - Carlos RodrŪguez
 #If [ROO]RPLDAT = '00000000'
           [ZR2]OPEFIN = [ROH]ROUENDDAT
#       Else
 #          [ZR2]OPEFIN = [ROO]RPLDAT
#       Endif
    Endif
    If [M:ZRC0]VALDEB = 2
       If [ROO]SCOCOD = 2 | [ROO]SCOCOD = 3

##MIG
#            [ZR2]OPEBPS = [ROO]BPSNUM
            [ZR2]OPEBPS = [ROO]BPRNUM
##\MIG

            # Si es una operaciůn de subcontrataciůn el coste se ajusta a la unidad de stock del artŪculo
            If [ZR2]OPESUB =  2 & [ROO]OPESTUCOE <> 0
            #MLL
#              Filter [ZITC] Where STOFCY=[ROO]FCY & ITMREF=[ROO]ITMREF & CSTTYP=1 Order By ITCSEQ
#              Read [ZITC] Last
#              If !fstat
#                [ZR2]OPECST = [ZITC]VLTTOT / [ROO]OPESTUCOE
#              Else
#                [ZR2]OPECST = 0
#              Endif
#              Filter [ZITC]
              [ZR2]OPECST = [ROO]REFPRI / [ROO]OPESTUCOE
            #MLL
            Else
            #MLL
#              Filter [ZITC] Where STOFCY=[ROO]FCY & ITMREF=[ROO]ITMREF & CSTTYP=1 Order By ITCSEQ
#              Read [ZITC] Last
#              If !fstat
#                [ZR2]OPECST = [ZITC]VLTTOT
#              Else
#                [ZR2]OPECST = 0
#              Endif
#              Filter [ZITC]
            #MLL
                [ZR2]OPECST = [ROO]REFPRI
            Endif

            #---- Busca precio de tarifa ----#
            TARBPS = [ZR2]OPEBPS
            TARITMREF = [ZR2]OPEITM
            ##--> Recuperamos la tarifa con el mŠximo importe --##
            Variable Decimal ZNETPRI
            Call ZBTARIFZRC(TARITMREF,ZNETPRI) From ZBTARIFZRC
            [ZR2]OPETRF = ZNETPRI

            #---- Busca precio ķltima compra ----#
            Filter [PID2] Where ITMREF = [ROO]SCOITMREF
            Read [PID2] Last
            If fstat = 0
                [ZR2]OPEPRE = [PID2]AMTNOTLIN / [PID2]QTYSTU
            Else
                [ZR2]OPEPRE = 0
            Endif
            Write [ZR2]
        Else
           [ZR2]OPEBPS = ""
           [ZR2]OPECST = 0
           [ZR2]OPETRF = 0
           [ZR2]OPEPRE = 0
           Write [ZR2]
       Endif
    Else
       [ZR2]OPEBPS = ""
       [ZR2]OPECST = 0
       [ZR2]OPETRF = 0
       [ZR2]OPEPRE = 0
       Write [ZR2]
    Endif
Next

# Graba las secuencias de componentes y operaciones segķn los niveles para est. BOD
Case NIVEL
   When 2 : WSEQANT1 = [ZRC2]CPNSEQ1 : XSEQANT1 = [ZRC2]OPESEQ1
   When 3 : WSEQANT1 = [ZRC2]CPNSEQ1 : WSEQANT2 = [ZRC2]CPNSEQ2 : XSEQANT1 = [ZRC2]OPESEQ1
&         : XSEQANT2 = [ZRC2]OPESEQ2
   When 4 : WSEQANT1 = [ZRC2]CPNSEQ1 : WSEQANT2 = [ZRC2]CPNSEQ2 : WSEQANT3 = [ZRC2]CPNSEQ3
&         : XSEQANT1 = [ZRC2]OPESEQ1 : XSEQANT2 = [ZRC2]OPESEQ2 : XSEQANT3 = [ZRC2]OPESEQ3
   When 5 : WSEQANT1 = [ZRC2]CPNSEQ1 : WSEQANT2 = [ZRC2]CPNSEQ2 : WSEQANT3 = [ZRC2]CPNSEQ3
&         : WSEQANT4 = [ZRC2]CPNSEQ4 : XSEQANT1 = [ZRC2]OPESEQ1 : XSEQANT2 = [ZRC2]OPESEQ2
&         : XSEQANT3 = [ZRC2]OPESEQ3 : XSEQANT4 = [ZRC2]OPESEQ4
   When 6 : WSEQANT1 = [ZRC2]CPNSEQ1 : WSEQANT2 = [ZRC2]CPNSEQ2 : WSEQANT3 = [ZRC2]CPNSEQ3
&         : WSEQANT4 = [ZRC2]CPNSEQ4 : WSEQANT5 = [ZRC2]CPNSEQ5 : XSEQANT1 = [ZRC2]OPESEQ1
&         : XSEQANT2 = [ZRC2]OPESEQ2 : XSEQANT3 = [ZRC2]OPESEQ3 : XSEQANT4 = [ZRC2]OPESEQ4
&         : XSEQANT5 = [ZRC2]OPESEQ5

Endcase
Gosub ESTPROD
Commit
Return

#########################################################################
$ESTPROD

Read [BOH]BOH0 = WITMREF;WBOMALT
If fstat = 0
    If [BOH]BOHSTRDAT <= [M:ZRC0]DATINI & [BOH]BOHENDDAT >= [M:ZRC0]DATFIN
        For [BOD]BOD0 Where ITMREF=[BOH]ITMREF & BOMALT=[BOH]BOMALT & BOMSTRDAT<=[M:ZRC0]DATINI & BOMENDDAT>=[M:ZRC0]DATFIN
            Gosub GRABA_COMPONENTES           #---- Graba detalles del componente ----#
            [ZRC]ZUSER = GUSER
            Write [ZRC]
            SIGUE2 = 0
        Next
    Else
        SIGUE2 = 1
    Endif
Else
    SIGUE2 = 1
Endif

Return

##########################################################################
$GRABA_COMPONENTES
[ZRC]NIVCPN = NIVEL
[ZRC]FCY = [M:ZRC0]FCYDEB
[ZRC]ITMREF = [BOD]ITMREF
[ZRC]BOMALT = [BOD]BOMALT
[ZRC]CPNITMREF = [BOD]CPNITMREF
Case NIVEL
    When 1 : [ZRC]OPESEQ1 = [BOD]CPNOPE : [ZRC]CPNSEQ1 = [BOD]BOMSEQ
    When 2 : [ZRC]OPESEQ1 = XSEQANT1 : [ZRC]OPESEQ2 = [BOD]CPNOPE : [ZRC]CPNSEQ1 = WSEQANT1 : [ZRC]CPNSEQ2 = [BOD]BOMSEQ
    When 3 : [ZRC]OPESEQ1 = XSEQANT1 : [ZRC]OPESEQ2 = XSEQANT2 : [ZRC]OPESEQ3 = [BOD]CPNOPE : [ZRC]CPNSEQ1 = WSEQANT1 :
&            [ZRC]CPNSEQ2 = WSEQANT2 : [ZRC]CPNSEQ3 = [BOD]BOMSEQ
    When 4 : [ZRC]OPESEQ1 = XSEQANT1 : [ZRC]OPESEQ2 = XSEQANT2 : [ZRC]OPESEQ3 = XSEQANT3 : [ZRC]OPESEQ4 = [BOD]CPNOPE :
&            [ZRC]CPNSEQ1 = WSEQANT1 : [ZRC]CPNSEQ2 = WSEQANT2 : [ZRC]CPNSEQ3 = WSEQANT3 : [ZRC]CPNSEQ4 = [BOD]BOMSEQ
    When 5 : [ZRC]OPESEQ1 = XSEQANT1 : [ZRC]OPESEQ2 = XSEQANT2 : [ZRC]OPESEQ3 = XSEQANT3 : [ZRC]OPESEQ4 = XSEQANT4 :
&            [ZRC]OPESEQ5 = [BOD]CPNOPE : [ZRC]CPNSEQ1 = WSEQANT1 : [ZRC]CPNSEQ2 = WSEQANT2 : [ZRC]CPNSEQ3 = WSEQANT3 :
&            [ZRC]CPNSEQ4 = WSEQANT4 : [ZRC]CPNSEQ5 = [BOD]BOMSEQ
    When 6 : [ZRC]OPESEQ1 = XSEQANT1 : [ZRC]OPESEQ2 = XSEQANT2 : [ZRC]OPESEQ3 = XSEQANT3 : [ZRC]OPESEQ4 = XSEQANT4 :
&            [ZRC]OPESEQ5 = XSEQANT5 : [ZRC]OPESEQ6 = [BOD]CPNOPE : [ZRC]CPNSEQ1 = WSEQANT1 : [ZRC]CPNSEQ2 = WSEQANT2 :
&            [ZRC]CPNSEQ3 = WSEQANT3 : [ZRC]CPNSEQ4 = WSEQANT4 : [ZRC]CPNSEQ5 = WSEQANT5 : [ZRC]CPNSEQ6 = [BOD]BOMSEQ
Endcase

[ZRC]CPNSEQNUM = [BOD]BOMSEQNUM

Read [ITM]ITM0 = [BOD]CPNITMREF
If fstat = 0
    [ZRC]CPNDES = [ITM]ITMDES1
Endif

[ZRC]CPNCTD = [BOD]LIKQTY
[ZRC]CPNINI = [BOD]BOMSTRDAT
[ZRC]CPNFIN = [BOD]BOMENDDAT
[ZRC]CPNTYP = [BOD]CPNTYP

                                    #---- Graba stock fŪsico y rechazado ----#
Read [ITV]ITV0 = [BOD]CPNITMREF;[M:ZRC0]FCYDEB
If fstat = 0
    [ZRC]PHYSTO = [ITV]PHYSTO
    [ZRC]REJSTO = [ITV]REJSTO

##MIG
#    [ZRC]DISSTO = [ITV]PHYSTO - [ITV]RERSTO - [ITV]ALLSTO - [ITV]BPRSTO - [ITV]SCOSTO
    Local Decimal YRERSTO, YALLSTO,YBPRSTO
    YRERSTO=[ITV]GLOALL
    YALLSTO=([ITV]PHYALL+[ITV]CTLALL+[ITV]REJALL)
    YBPRSTO=([ITV]BPRPHYSTO+[ITV]BPRCTLSTO+[ITV]BPRREJSTO)
    YSCOSTO=([ITV]SCOPHYSTO+[ITV]SCOCTLSTO+[ITV]SCOREJSTO)

    [ZRC]DISSTO = [ITV]PHYSTO - YRERSTO - YALLSTO - YBPRSTO - YSCOSTO
##\MIG
Else
    [ZRC]PHYSTO = 0
    [ZRC]REJSTO = 0
    [ZRC]DISSTO = 0
Endif

       #---- Si el flag proveedor estŠ marcado busca el ķltimo proveedor y el ķltimo precio de compra ----#
If [M:ZRC0]PROVDEB = 2
    Gosub  GRABA_PROVPRE
Else
    [ZRC]CPNBPS = ""
    [ZRC]CPNPRE = 0
Endif
       #---- Si el flag de coste estŠ marcado busca el coste estŠndar act. y precio tarifa ----#
If [M:ZRC0]VALDEB = 2
    Gosub GRABA_CSTEST
    TARBPS = [ZRC]CPNBPS
    TARITMREF = [ZRC]CPNITMREF
    ##--> Recuperamos la tarifa con el mŠximo importe
    Variable Decimal ZNETPRI
    Call ZBTARIFZRC(TARITMREF,ZNETPRI) From ZBTARIFZRC
    [ZRC]CPNTRF = ZNETPRI
Endif

Local Decimal XQTY
Local Decimal XTOT

    ##-- Stock FŪsico (A) a Precio Medio Lote --##

## AUREN - ADAPTACI”N MIGRACI”N V11
#For [STL]STL0 Where ITMREF = [BOD]CPNITMREF & AAACUMQTY <> 0
#    If XQTY <= [ITV]PHYSTO
#        XQTY += [STL]AAACUMQTY
#        XTOT += ([STL]LOTAVC*[STL]AAACUMQTY)
#    Else
#        Break
#    Endif
#Next
For [SLF]SLF0 Where ITMREF = [BOD]CPNITMREF & STOFCY = [M:ZRC0]FCYDEB & AAACUMQTY <> 0
    If XQTY <= [ITV]PHYSTO
        XQTY += [SLF]AAACUMQTY
        XTOT += ([SLF]AVC*[SLF]AAACUMQTY)
    Else
        Break
    Endif
Next
## AUREN - ADAPTACI”N MIGRACI”N V11

[ZRC]PHYSPML = XTOT

    ##-- Valor Stock FŪsico a Coste estandar actualizado --##
[ZRC]PHYSCST = [ZRC]PHYSTO * [ZRC]CPNCST
Return

##########################################################################
$GRABA_PROVPRE
Filter [PID] Where ITMREF = [BOD]CPNITMREF & FCYLIN = [M:ZRC0]FCYDEB
Read [PID]PID0 Last
If fstat = 0
    [ZRC]CPNBPS = [PID]BPR
    [ZRC]CPNPRE = [PID]AMTNOTLIN / [PID]QTYSTU
Else
    Filter [ITP] Where ITMREF = [BOD]CPNITMREF Order By Key ITP0
    Read [ITP]First
    If fstat = 0
        [ZRC]CPNBPS = [ITP]BPSNUM
        [ZRC]CPNPRE = 0
    Else
        [ZRC]CPNBPS = ""
        [ZRC]CPNPRE = 0
    Endif
    Filter [ITP]
Endif
Filter [PID]
# 06.435.234.ini
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Endif
Read [F:ITM]ITM0 = [BOD]CPNITMREF
If !fstat Then
  If [F:ITM]TCLCOD = 'SE' Then
    Filter [ITP] Where ITMREF = [BOD]CPNITMREF Order By Key ITP0
    Read [ITP]First
    If fstat = 0
        [ZRC]CPNBPS = [ITP]BPSNUM
    Else
        [ZRC]CPNBPS = ""
    Endif
    Filter [ITP]
  Endif
Endif
# 06.435.234.fin
Return

##########################################################################
$GRABA_CSTEST
                #---- Busca el coste estŠndar actualizado ----#
Local Integer XYEAR

XYEAR = year([M:ZRC0]DATINI)

#Filter [ITC] Where STOFCY=[M:ZRC0]FCYDEB & ITMREF=[BOD]CPNITMREF & YEA=XYEAR & CSTTYP=2 Order By CSTSEQ

#AUREN
#Filter [ITC] Where STOFCY=[M:ZRC0]FCYDEB & ITMREF=[BOD]CPNITMREF & YEA=XYEAR & CSTTYP=1 Order By CSTSEQ
Filter [ITC] Where STOFCY=[M:ZRC0]FCYDEB & ITMREF=[BOD]CPNITMREF & CSTTYP=1 Order By ITCSEQ

Read [ITC] Last
If fstat = 0
    [ZRC]CPNCST = [ITC]VLTTOT
Else
    [ZRC]CPNCST = 0
Endif
Filter [ITC]
Return

########################################################################
$BORRAR
Trbegin [ZRC], [ZR2]
     Delete [ZRC] Where [F:ZRC]ZUSER = GUSER
     Delete [ZR2] Where [F:ZR2]ZUSER = GUSER
Commit
Return

##########################################################################
$OUVRE
If clalev([F:ZRC])=0 : Local File ZRECETA [ZRC] : Endif
If clalev([F:ZRC2])=0 : Local File ZRECETA [ZRC2] : Endif
If clalev([F:ZR2])=0 : Local File ZRECETA2 [ZR2] : Endif
If clalev([F:BOH])=0 : Local File BOM [BOH] : Endif
If clalev([F:BOD])=0 : Local File BOMD [BOD] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Endif
If clalev([F:ITV])=0 : Local File ITMMVT [ITV] : Endif
If clalev([F:PID])=0 : Local File PINVOICED [PID] : Endif
If clalev([F:PID2])=0 : Local File PINVOICED [PID2] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS [ITP] : Endif
If clalev([F:ITC])=0 : Local File ITMCOST [ITC] : Endif
If clalev([F:ROO])=0 : Local File ROUOPE [ROO] : Endif
If clalev([F:ROH])=0 : Local File ROUTING [ROH] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK [SPK] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES [ITS] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:PPL])=0 : Local File PPRICLIST [PPL] : Endif

## AUREN - ADAPTACI”N MIGRACI”N V11
#If clalev([F:STL])=0 : Local File STOLOT [STL] : Endif
If clalev([F:SLF])=0 : Local File STOLOTFCY [SLF] : Endif
## AUREN - ADAPTACI”N MIGRACI”N V11

If clalev([F:TRO])=0 : Local File TABROUALT [TRO] : Endif

## AUREN - ADAPTACI”N MIGRACI”N V11
#If clalev([F:TCL])=0 : Local File TABITMCLS [TCL] : Endif
If clalev([F:ITB])=0 : Local File ITMBOM [ITB] : Endif
