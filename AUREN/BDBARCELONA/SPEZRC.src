Subprog AM_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif

Read [TRO]TRO0 = VALEUR
If fstat = 0
    If [TRO]FCY <> [M:ZRC0]FCYDEB and [TRO]FCY <> ""
        Errbox "La alternativa no corresponde con planta" Titled "Selecciůn Alternativa ruta"
        mkstat = 2
    Else
        [M:ZRC0]ROUALTDEB = VALEUR
        Affzo [M:ZRC0]ROUALTDEB
    Endif
Else
    Errbox "La alternativa no existe" Titled "Selecciůn Alternativa ruta"
    mkstat = 2
Endif
End

