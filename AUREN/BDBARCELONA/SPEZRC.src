Subprog AM_BOMALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer BOMALT1, BOMALT2, BOMALT3
If clalev ([F:TRO]) <= 0 Local File TABROUALT [TRO] Endif
If clalev ([F:TBO]) <= 0 Local File TABBOMALT [TBO] Endif

Read [TRO]TRO0 = [M:ZRC0]ROUALTDEB
If fstat = 0
    BOMALT1 = [TRO]BOMALT1
    BOMALT2 = [TRO]BOMALT2
    BOMALT3 = [TRO]BOMALT3
Endif

If VALEUR <> BOMALT1 and VALEUR <> BOMALT2 and VALEUR <> BOMALT3
    Errbox "La alternativa estructura no es valida" Titled "Validaciůn Alternativa estructura"
    mkstat = 2
Else
    [M:ZRC0]BOMALTDEB = VALEUR
    Affzo [M:ZRC0]BOMALTDEB
Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Endif
Read [ITM]ITM0 = VALEUR
If fstat = 0
    [ZRC0]ITMDESDEB = [ITM]ITMDES1
Else
    [ZRC0]ITMDESDEB = ""
Endif

End

