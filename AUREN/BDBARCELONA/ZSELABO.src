#<AdxTL>@(#)1.0.0.0 $Revision:   1.20  $ Gestión de la máscara ITN7

$ACTION
Case ACTION
 When "DEBUT" : Gosub CARGA        
 When "OK"    : Gosub WOK        
 When Default
Endcase
Return


######################################################################################
$CARGA

Gosub OUVRE

#dbgmode (0) = 1 : # dbgmode (1) = 1

Local Char WSOHNUM
Local Integer WSOPLIN
Local Char WSOHITM
Local Char WSIVNUM
Local Char WSDHNUM
Local Decimal WAMTATI
Local Char WNUMSOL
Local Integer SWFAC

WNUMSOL = PARAM(1)
NOL =-1
Read [F:SRE]SRE0 = WNUMSOL
If fstat = 0 Then
    WSOHNUM = [F:SRE]SRECOVNUM
    WSOHITM = [F:SRE]ZRECOVITM
    WSOPLIN = [F:SRE]ZSOPLIN
Endif

SWFAC= 0 
For [SIV]SIV1 Where [SIV]INVTYP = 2 and ([SIV]SIHORI = 6 or [SIV]SIHORI = 4)
    WSIVNUM = [SIV]NUM
    Read [SIH]SIH0 = [SIV]NUM
    Case [SIV]SIHORI
        When 6 #Origen Devolución
            For [F:SRD]SRD0 Where [F:SRD]SRHNUM = [SIV]SIHORINUM
                If WSDHNUM <> [F:SRD]SDHNUM Then
                    For [F:SDD]SDD0 Where [F:SDD]SDHNUM  = [F:SRD]SDHNUM
                        If [F:SDD]SOHNUM = WSOHNUM and [F:SDD]ITMREF = WSOHITM and [F:SDD]SDDLIN = WSOPLIN Then 
                               NOL += 1
                               [M:ZSAB]ZNUMABO(NOL) = WSIVNUM
                               [M:ZSAB]ZAMTATI(NOL) = [F:SIH]AMTATI
                               [M:ZSAB]ZCUR(NOL)    = [F:SIV]CUR
                               [M:ZSAB]ZSOHNUM(NOL) = [F:SDD]SOHNUM
                               [M:ZSAB]ZSRHNUM(NOL) = [F:SRD]SRHNUM
                               [M:ZSAB]ZSDHNUM(NOL) = [F:SDD]SDHNUM
                               [M:ZSAB]ZSIHORI(NOL) = 6
                               [M:ZSAB]NBLIG = NOL+1
                               Affzo [M:ZSAB]
                        Endif
                    Next
                    WSDHNUM = [F:SRD]SDHNUM
                Endif
            Next
        When 4 #Origen Factura
            Read [F:SIV2]SIV0 = [F:SIV]SIHORINUM
            If fstat = 0 Then : WSIVNUM = [F:SIV]NUM : Endif
            Case [SIV2]SIHORI
                When 3 #Origen factura: entrega
                    For [F:SDD]SDD0 Where [F:SDD]SDHNUM  = [F:SIV2]SIHORINUM
                        If [F:SDD]SOHNUM = WSOHNUM and [F:SDD]ITMREF = WSOHITM and [F:SDD]SDDLIN = WSOPLIN Then 
                               NOL += 1
                               [M:ZSAB]ZNUMABO(NOL) = WSIVNUM
                               [M:ZSAB]ZAMTATI(NOL) = [F:SIH]AMTATI
                               [M:ZSAB]ZCUR(NOL) =    [F:SIV2]CUR
                               [M:ZSAB]ZSRHNUM(NOL) = [F:SIV]SIHORINUM
                               [M:ZSAB]ZSOHNUM(NOL) = [F:SDD]SOHNUM
                               [M:ZSAB]ZSDHNUM(NOL) = [F:SDD]SDHNUM
                               [M:ZSAB]ZSIHORI(NOL) = 4
                               [M:ZSAB]NBLIG = NOL+1
                               Affzo [M:ZSAB]
                        Endif
                    Next
                When 2 #Origen factura: Pedido
                    If [F:SIV2]SIHORINUM = WSOHNUM Then 
                        NOL += 1
                        [M:ZSAB]ZNUMABO(NOL) = WSIVNUM
                        [M:ZSAB]ZAMTATI(NOL) = [F:SIH]AMTATI
                        [M:ZSAB]ZCUR(NOL) =    [F:SIV]CUR
                        [M:ZSAB]ZSOHNUM(NOL) = [F:SDD]SOHNUM
                        [M:ZSAB]ZSRHNUM(NOL) = [F:SIV]SIHORINUM
                        [M:ZSAB]ZSDHNUM(NOL) = [F:SDD]SDHNUM
                        [M:ZSAB]ZSIHORI(NOL) = 4
                        [M:ZSAB]NBLIG = NOL+1
                        Affzo [M:ZSAB]
                    Endif

               Endcase
    Endcase
Next
Return


######################################################################################
$FIN 
   FIN =1
End 

######################################################################################
$OUVRE
# La abreviatura de la pantalla siempre tiene que ser [ZSAB]
Local Integer OK 

If clalev([F:SIV])=0 : Local File SINVOICEV   [SIV] : Endif
If clalev([F:SIV2])=0 : Local File SINVOICEV  [SIV2] : Endif

If clalev([F:SRE])=0 : Local File SERREQUEST [SRE] : Endif
If clalev([F:SRD])=0 : Local File SRETURND   [SRD] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif


Local Shortint NOL 

Return

######################################################################################
$WOK
#    [M:ITN7]ZNUMABO = [M:ZSAB]ZNUMABO(nolign-1)
#    [M:ITN7]ZIMPII = [M:ZSAB]ZAMTATI(nolign-1)
 #   [M:ITN7]ZDEVCLI = [M:ZSAB]ZSRHNUM(nolign-1)

    PARAM(2) = [M:ZSAB]ZNUMABO(nolign-1)
    PARAM(3) = num$([M:ZSAB]ZAMTATI(nolign-1))
    If [M:ZSAB]ZSIHORI(nolign-1) = 6 Then
        PARAM(4) = [M:ZSAB]ZSRHNUM(nolign-1)
    Endif


 #   Affzo [M:ITN7]ZDEVCLI
 #   Affzo [M:ITN7]ZNUMABO
 #   Affzo [M:ITN7]ZIMPII

Close File [SIV]
Close File [SRE]
Close File [SRD]
Close File [SIH]
Close File [SDD]


FIN = 1

Return
