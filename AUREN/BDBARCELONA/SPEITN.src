################################
# ZMI: REVISIONES MIGRACION V5 #
################################
$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog S_ZNUMABO(VALEUR)
Variable Char    VALEUR()

     
    Local Char PARAM(15)(1..10)
    Local Char SAVACT(10)
    Local Char XVALEUR
   
    PARAM(1) = [M:ITN0]SRVDEMNUM
    PARAM(2) = ""
    PARAM(3) = num$(0)
    PARAM(4) = ""
    SAVACT = GACTION : GACTION = "ZSELABO"
    Call SAISIE_CHAR(XVALEUR,PARAM,"ZSELABO","ZSELABO") From GSAISIE
    GACTION = SAVACT
    
    VALEUR = PARAM(2)
    [M:ITN9]ZIMPII = val(PARAM(3))
    [M:ITN9]ZDEVCLI = PARAM(4)
    Affzo [M:ITN9]ZIMPII 
    Affzo [M:ITN9]ZDEVCLI 

End

########################################
Subprog AP_ZIMPII(VALEUR)
Variable Decimal VALEUR
    [M:ITN9]ZCOSTTOT = VALEUR +[M:ITN9]ZDEVCST+[M:ITN9]ZCOSTMON+[M:ITN9]ZCOSTMAT
    Affzo [M:ITN9]ZCOSTTOT
End

########################################
Subprog AP_ZDEVCST(VALEUR)
Variable Decimal VALEUR
    [M:ITN9]ZCOSTTOT = [M:ITN9]ZIMPII + VALEUR +[M:ITN9]ZCOSTMON+[M:ITN9]ZCOSTMAT
    Affzo [M:ITN9]ZCOSTTOT
End

########################################
Subprog AP_ZCOSTMON(VALEUR)
Variable Decimal VALEUR
    [M:ITN9]ZCOSTTOT = [M:ITN9]ZIMPII + [M:ITN9]ZDEVCST +VALEUR +[M:ITN9]ZCOSTMAT
    Affzo [M:ITN9]ZCOSTTOT
End

########################################
Subprog AP_ZCOSTMAT(VALEUR)
Variable Decimal VALEUR
    [M:ITN9]ZCOSTTOT = [M:ITN9]ZIMPII +[M:ITN9]ZDEVCST + [M:ITN9]ZCOSTMON + VALEUR
    Affzo [M:ITN9]ZCOSTTOT
End
########################################
Subprog S_ZDEVCLI(VALEUR)
Variable Char    VALEUR()

If clalev([F:SRH])=0 : Local File SRETURN  [SRH]   : Endif
If clalev([F:SRD])=0 : Local File SRETURND [SRD]   : Endif
If clalev([F:SRE])=0 : Local File SERREQUEST [SRE] : Endif
If clalev([F:SOP])=0 : Local File SORDERP [SOP] : Endif
If clalev([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif


Local Char WSOHNUM
Local Integer WSOPLIN
Local Char WSOHITM

Read [F:SRE]SRE0 = [M:ITN0]SRVDEMNUM
If fstat = 0 Then
    WSOHNUM = [F:SRE]SRECOVNUM
    WSOHITM = [F:SRE]ZRECOVITM
    WSOPLIN = [F:SRE]ZSOPLIN
Endif

Read [SOP]SOP5 = WSOHNUM;WSOHITM;WSOPLIN
Read [SDD]SDD1 = [SOP]SOHNUM;[SOP]SOPLIN;[SOP]SOPSEQ
If fstat = 0 Then
    Read [SRD]SRD1 = [SDD]SDHNUM;[SDD]SDDLIN
Endif


Choose [SRH]
& Where ([F:SRH]SRHNUM = [F:SRD]SRHNUM)
& Order By [SRH]SRHNUM Asc Using
& [SRH]SRHNUM Titled "Nş Devolución",
& [SRH]BPCORD Titled "Cliente",
& [SRH]SALFCY Titled "Planta Venta"
& Sized(80,240)
& Titled "Selección Devoluciones"

If status <> 7
  VALEUR = [SRH]SRHNUM
Else 
  Raz VALEUR
Endif

Close File [SRH]

End

########################################
Subprog S_ZDEVPROV(VALEUR)
Variable Char    VALEUR()

    Local Char PARAM(15)(1..10)
    Local Char SAVACT(10)
    Local Char XVALEUR
   
    PARAM(1) = [M:ITN0]SRVDEMNUM
    PARAM(2) = ""
    SAVACT = GACTION : GACTION = "ZSELDEVBPS"
    Call SAISIE_CHAR(XVALEUR,PARAM,"ZSELDEVBPS","ZSELDEVBPS") From GSAISIE
    GACTION = SAVACT
    
    VALEUR = PARAM(2)
End

