#<AdxTL>@(#)1.0.0.0 $Revision$
Call ZTCLPEDVEN(BLANCOS,ZEROS)
End

#############################################################################################
Subprog ZTCLPEDVEN(BLANCOS,ZEROS)
Value Char BLANCOS
Value Char ZEROS

Local Char    SAVIFS(10) , SAVIRS(10)

SAVIFS = adxifs 
SAVIRS = adxirs

adxifs = ";"                                          :  # ============= Separador de camp
adxirs = ""                                           :  # ============= Separador de registre

GTRACE = "cabcli"                                        #============== Generamos en el servidor
GTRACE2 = "lincli"
FICTRA = filpath("ZTRASPASO",GTRACE,"txt", 0)
FICTRA2 = filpath("ZTRASPASO",GTRACE2,"txt", 0)

Openo FICTRA, 0 Using [FIC4]                                      : #============== Abrir fichero
Openo FICTRA2, 0 Using [FIC5]

#Openo "C:\ZTRASPASO\cabcli.TXT"                          #============== En el C del servidor

Gosub LECTURA

Openo Using [FIC4]
Openo Using [FIC5]

adxifs    = SAVIFS
adxirs    = SAVIRS
End                 

#############################################################################################
$LECTURA
If clalev([F:SOH])=0  : Local File SORDER [SOH] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS [BPA] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER [BPR] : Endif
If clalev([F:SOQ])=0  : Local File SORDERQ [SOQ] : Endif
If clalev([F:SOP])=0  : Local File SORDERP [SOP] : Endif
If clalev([F:TSI])=0  : Local File TABSTTITM [TSI] : Endif

Gosub OUVRECAB
Gosub OUVRELIN

For [F:SOH]SOH0 Where ([F:SOH]SALFCY="BD1" or [F:SOH]SALFCY="BD3") and ([F:SOH]DLVSTA<>3 and [F:SOH]ORDSTA<>2)
    Gosub CABSR
    Gosub LINSR 
    Gosub OUVRECAB
Next
Return

#######################################################################################
$CABSR

NUMDOC = format$("K:15X",[F:SOH]SOHNUM)
NUMDOC = ctrans(NUMDOC,";"," ")             #======== Código pedido
Wrseq NUMDOC; Using [FIC4]  

FECDOC = num$([F:SOH]ORDDAT)
FECDOC = format$("K:12X",FECDOC)
Wrseq FECDOC; Using [FIC4]                  #======== Fecha documento

CODTER = format$("K:17X",[F:SOH]BPCORD)
CODTER = ctrans(CODTER,";"," ")             #======== Código tercero
Wrseq CODTER; Using [FIC4]

PEDORIG = format$("K:8X"," ")
Wrseq PEDORIG; Using [FIC4]                    #======== Documento origen

If [F:SOH]BPDNAM <> ""
    NOMENT = format$("K:35X",[F:SOH]BPDNAM)    
Else
    Read [F:BPR]BPR0 = [F:SOH]BPCORD
    If fstat = 0
        NOMENT = format$("K:35X",[F:BPR]BPRNAM)
    Else
        NOMENT = format$("K:35X"," ")        
    Endif
Endif
NOMENT = ctrans(NOMENT,";"," ")             
Wrseq NOMENT; Using [FIC4]                  #======== nombre cliente entrega

CONTENT = format$("K:35X",[F:SOH]CNDNAM)
CONTENT = ctrans(CONTENT,";"," ")             
Wrseq CONTENT; Using [FIC4]                  #======== Persona contacto

If [F:SOH]BPDADDLIG(0) <> ""                         #============== direcciones
    DIRENT = format$("K:35X",[F:SOH]BPDADDLIG(0))
Else 
    Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If fstat = 0
        DIRENT = format$("K:35X",[F:BPA]BPAADDLIG(0))        
    Else
        DIRENT = format$("K:35X"," ")
    Endif
Endif
DIRENT = ctrans(DIRENT,";"," ")             
Wrseq DIRENT; Using [FIC4] 

COMENT = format$("K:35X"," ")
Wrseq COMENT; Using [FIC4]  

If [F:SOH]BPDCTY <> ""
    POBENT = format$("K:35X",[F:SOH]BPDCTY)    
Else
    Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If fstat = 0
        POBENT = format$("K:35X",[F:BPA]CTY)
    Else
        POBENT = format$("K:35X"," ")
    Endif
Endif
POBENT = ctrans(POBENT,";"," ")             
Wrseq POBENT; Using [FIC4]  

If [F:SOH]BPDPOSCOD <> ""
    CPENT = format$("K:9X",[F:SOH]BPDPOSCOD)    
Else
    Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If fstat = 0
        CPENT = format$("K:9X",[F:BPA]POSCOD)
    Else
        CPENT = format$("K:9X"," ")
    Endif
Endif
CPENT = ctrans(CPENT,";"," ")             
Wrseq CPENT; Using [FIC4]  

If [F:SOH]BPDSAT <> ""
    PROENT = format$("K:25X",[F:SOH]BPDSAT)    
Else
    Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If fstat = 0
        PROENT = format$("K:25X",[F:BPA]SAT)
    Else
        PROENT = format$("K:25X"," ")
    Endif
Endif
PROENT = ctrans(PROENT,";"," ")             
Wrseq PROENT; Using [FIC4]  

If [F:SOH]BPDCRY <> ""
    PAIENT = format$("K:4X",[F:SOH]BPDCRY)
Else
    Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If fstat = 0
        PAIENT = format$("K:4X",[F:BPA]CRY)
    Else
        PAIENT = format$("K:4X"," ")
    Endif
Endif
PAIENT = ctrans(PAIENT,";"," ")             
Wrseq PAIENT; Using [FIC4]  

Read [F:BPA]BPA0 = 1;[F:SOH]BPCORD;[F:SOH]BPAADD
If fstat = 0
    TELENT = format$("K:21X",[F:BPA]TEL)    
Else
    TELENT = format$("K:21X"," ")
Endif
TELENT = ctrans(TELENT,";"," ")             
Wrseq TELENT; Using [FIC4] 

Read [F:BPR]BPR0 = [F:SOH]BPCORD                    #================ DNI
If fstat = 0
    DNICLI = format$("K:25X",[F:BPR]CRN)    
Else
    DNICLI = format$("K:25X"," ")
Endif
DNICLI = ctrans(DNICLI,";"," ")             
Wrseq DNICLI; Using [FIC4] 

REFDOC = format$("K:17X",[F:SOH]CUSORDREF)
REFDOC = ctrans(REFDOC,";"," ")             
Wrseq REFDOC; Using [FIC4] 

#---------------------------------------------------------------------------------------------------
FICHERO = [F:SOH]SOHTEX1                            #============== Textos de cabecera

If FICHERO = "" or filinfo(filpath("txt",FICHERO,"txt",-1),1) <0 
    IL1 = seg$(BLANCOS,1,69)
    Wrseq IL1; Using [FIC4]
    IL2 = seg$(BLANCOS,1,69)
    Wrseq IL2; Using [FIC4]    
Else
    Local Integer I    
    Openi filpath("txt",FICHERO,"txt",0) Using [FICR]

      adxifs = chr$(10)            ##--> Como lo leemos
      adxirs= chr$(13)
     For I = 1 To 3    
        Rdseq WREGISTRO Using [FICR]                       ##-- Leemos secuencialmente el fichero de texto.    
        #If fstat <> 0 : Break Endif
       
        L = 69 - len(WREGISTRO)
        Case I 
            When 1 
                If L < 0 : IL1 = WREGISTRO Else IL1 = WREGISTRO + seg$(BLANCOS,1,L) Endif
            When 3
                If L < 0 : IL2 = WREGISTRO Else IL2 = WREGISTRO + seg$(BLANCOS,1,L) Endif
        Endcase
     Next

    adxifs = ";"        #======== como escribimos                                         
    adxirs = ""   

    If IL1 <> "" 
        Wrseq IL1; Using [FIC4] 
    Else 
        IL1 = seg$(BLANCOS,1,69)
        Wrseq IL1; Using [FIC4]
    Endif
    If IL2 <> "" 
        Wrseq IL2; Using [FIC4] 
    Else 
        IL2 = seg$(BLANCOS,1,69)
        Wrseq IL2; Using [FIC4]
    Endif

    Openi Using [FICR]
Endif

FICHERO = [F:SOH]SOHTEX2                            #============== Textos de pie
If FICHERO = "" or filinfo(filpath("txt",FICHERO,"txt",-1),1) <0 
    IL3 = seg$(BLANCOS,1,69)
    Wrseq IL3; Using [FIC4]
    IL4 = seg$(BLANCOS,1,69)
    Wrseq IL4; Using [FIC4]    
Else
    Local Integer I
    
    Openi filpath("txt",FICHERO,"txt",0) Using [FICR]
     adxifs = chr$(10)            ##--> Como lo leemos
     adxirs= chr$(13)
     
    For I = 1 To 3    
        Rdseq WREGISTRO Using [FICR]                       ##-- Leemos secuencialmente el fichero de texto.    
        #If fstat <> 0 : Break Endif
       
        L = 69 - len(WREGISTRO)
        Case I 
            When 1 
                If L < 0 : IL3 = WREGISTRO Else IL3 = WREGISTRO + seg$(BLANCOS,1,L) Endif
            When 3
                If L < 0 : IL4 = WREGISTRO Else IL4 = WREGISTRO + seg$(BLANCOS,1,L) Endif
        Endcase
    Next
    
    adxifs = ";"        #======== como escribimos                                         
    adxirs = ""   

    If IL3 <> "" 
        Wrseq IL3; Using [FIC4] 
    Else 
        IL3 = seg$(BLANCOS,1,69)
        Wrseq IL3; Using [FIC4]
     Endif
    If IL4 <> "" 
        Wrseq IL4; Using [FIC4] 
    Else 
        IL4 = seg$(BLANCOS,1,69)
        Wrseq IL4; Using [FIC4]
    Endif

    Openi Using [FICR]
Endif

#----------------------------------------------------------------------------------------------------

MODENV = num$([F:SOH]FREINV)
If MODENV = "" : MODENV = seg$(ZEROS,1,1) Endif
Wrseq MODENV; Using [FIC4] 

FECENT = num$([F:SOH]DEMDLVDAT)
FECENT = format$("K:12X",FECENT)
Wrseq FECENT; Using [FIC4]

CODREP = format$("K:35X",[F:SOH]REP(1))
CODREP = ctrans(CODREP,";"," ")             
Wrseq CODREP; Using [FIC4] 

AGEEND = format$("K:35X",[F:SOH]BPTNUM)
Wrseq AGEEND; Using [FIC4] 

BULENT = seg$(ZEROS,1,3)
Wrseq BULENT; Using [FIC4] 

TOTALBI = num$([F:SOH]ORDNOT)
L = 18 - len(TOTALBI)                    
TOTALBI = seg$(ZEROS,1,L) + TOTALBI   
Wrseq TOTALBI; Using [FIC4]                      

Wrseq chr$(10) Using [FIC4]

Return

#####################################################################################
$LINSR
For [F:SOQ]SOQ0 Where [F:SOQ]SOHNUM = [F:SOH]SOHNUM
    NUMDOC = format$("K:15X",[F:SOH]SOHNUM)
    NUMDOC = ctrans(NUMDOC,";"," ")             
    Wrseq NUMDOC; Using [FIC5]        

    NUMLIN = num$([F:SOQ]SOPLIN)
    L = 10 - len(NUMLIN)                    
    NUMLIN = seg$(ZEROS,1,L) + NUMLIN   
    Wrseq NUMLIN; Using [FIC5]

    NUMINT = num$([F:SOQ]SOQSEQ)
    L = 10 - len(NUMINT)
    NUMINT = seg$(ZEROS,1,10) + NUMINT   
    Wrseq NUMINT; Using [FIC5]

    CODLIN = format$("K:20X",[F:SOQ]ITMREF)
    CODLIN = ctrans(CODLIN,";"," ")             
    Wrseq CODLIN; Using [FIC5]

    Read [F:SOP]SOP0 = [F:SOQ]SOHNUM;[F:SOQ]SOPLIN        #============ Accedemos a líneas de precio de pedidos
    If fstat = 0
        DESCLIN = format$("K:69X",[F:SOP]ITMDES1)
        DESCLIN = ctrans(DESCLIN,";"," ")

        PRELIN = num$([F:SOP]GROPRI)
        L = 18 - len(PRELIN)                    
        PRELIN = seg$(ZEROS,1,L) + PRELIN   

        DTOART1 = num$([F:SOP]DISCRGVAL1)
        L = 18 - len(DTOART1)                    
        DTOART1 = seg$(ZEROS,1,L) + DTOART1   

        DTOART2 = num$([F:SOP]DISCRGVAL2)
        L = 18 - len(DTOART2)                    
        DTOART2 = seg$(ZEROS,1,L) + DTOART2   

        DTOART3 = num$([F:SOP]DISCRGVAL3)
        L = 18 - len(DTOART3)                    
        DTOART3 = seg$(ZEROS,1,L) + DTOART3   

        IMPLINBI = num$([F:SOP]NETPRINOT)
        L = 18 - len(IMPLINBI)                    
        IMPLINBI = seg$(ZEROS,1,L) + IMPLINBI   

        VALIMP1 = num$([F:SOP]NETPRIATI-[F:SOP]NETPRINOT)
        L = 18 - len(VALIMP1)                    
        VALIMP1 = seg$(ZEROS,1,L) + VALIMP1           

        NUMDOCORI = format$("K:15X",[F:SOP]SQHNUM)
        NUMDOCORI = ctrans(NUMDOCORI,";"," ") 

        NUMLINORI = num$([F:SOP]SQDLIN)
        L = 10 - len(NUMLINORI)                    
        NUMLINORI = seg$(ZEROS,1,L) + NUMLINORI   
    Else
        DESCLIN = format$("K:69X",DESCLIN)                             
        PRELIN = seg$(ZEROS,1,18)  
        DTOART1 = seg$(ZEROS,1,18)  
        DTOART2 = seg$(ZEROS,1,18)  
        DTOART3 = seg$(ZEROS,1,18)  
        IMPLINBI = seg$(ZEROS,1,18)  
        VALIMP1 = seg$(ZEROS,1,18)  
        NUMDOCORI = format$("K:15X"," ")   
        NUMLINORI = seg$(ZEROS,1,10)  
    Endif
        
    Wrseq DESCLIN; Using [FIC5]            
    
    UNILIN = num$([F:SOQ]QTY)                #============= Cantidad de artículo
    L = 18 - len(UNILIN)                    
    UNILIN = seg$(ZEROS,1,L) + UNILIN  
    Wrseq UNILIN; Using [FIC5]
    
    CANTPED = num$([F:SOQ]DLVQTY)
    L= 18 - len(CANTPED)
    CANTPED = seg$(ZEROS,1,L) + CANTPED        
    Wrseq CANTPED; Using [FIC5]
      
    Wrseq PRELIN; Using [FIC5]

    Wrseq DTOART1; Using [FIC5]
    
    Wrseq DTOART2; Using [FIC5]
    
    Wrseq DTOART3; Using [FIC5]
    
    Wrseq IMPLINBI; Using [FIC5]
    
    Wrseq VALIMP1; Using [FIC5]

    VALIMP2 = seg$(ZEROS,1,18)
    Wrseq VALIMP2; Using [FIC5]

    Read [F:TSI]TSI0 = 1;[F:SOP]TSICOD(0)
    If fstat = 0
        FAMARTI = format$("K:69X",[F:TSI]TSIDES)
        FAMARTI = ctrans(FAMARTI,";"," ")                         
    Else 
        FAMARTI = format$("K:69X"," ")                        
    Endif         
    Wrseq FAMARTI; Using [FIC5]

    Wrseq NUMDOCORI; Using [FIC5]

    Wrseq NUMLINORI; Using [FIC5]     
       
    Wrseq chr$(10) Using [FIC5]
    Gosub OUVRELIN
Next
Return

#####################################################################################
$OUVRECAB
Local Integer L
Local Char WREGISTRO(250)
Local Char FICHERO

#======================= Cabecera
Local Char NUMDOC(15)
Local Char FECDOC(12)
Local Char CODTER(17)
Local Char PEDORIG(8)
Local Char NOMENT(35)
Local Char CONTENT(35)

Local Char DIRENT(35)
Local Char COMENT(35)
Local Char POBENT(35)
Local Char CPENT(9)
Local Char PROENT(25)
Local Char PAIENT(4)

Local Char TELENT(21)
Local Char DNICLI(25)
Local Char REFDOC(17)
Local Char IL1(69)
Local Char IL2(69)
Local Char IL3(69)
Local Char IL4(69)

Local Char MODENV(1)
Local Char FECENT(12)
Local Char CODREP(35)
Local Char AGEEND(35)
Local Char BULENT(3)
Local Char TOTALBI(18)

Return

####################################################################
$OUVRELIN
#======================= Líneas
#Local Char NUMDOC(15)
Local Char NUMLIN(10)
Local Char NUMINT(10)
Local Char CODLIN(20)
Local Char DESCLIN(69)

Local Char UNILIN(18)
Local Char CANTPED(18)
Local Char PRELIN(18)
Local Char DTOART1(18)
Local Char DTOART2(18)
Local Char DTOART3(18)
Local Char IMPLINBI(18)
Local Char VALIMP1(18)
Local Char VALIMP2(18)
Local Char FAMARTI(69)
Local Char NUMDOCORI(15)
Local Char NUMLINORI(10)

Return

