#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "ITMNUM"     :   Gosub ITMNUM
Endcase
Return

$ITMNUM
Local integer X
If [M:ITM0]TCLCOD = "PRTB"

If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif

Call NUMCLE ([F:ITG]ITMREFCOU,GFCYDEF(9),datesyst,"","ITM",NUMERO,STAT) From SUBANM

X = Instr(1,NUMERO,"-")
NUMERO = Left$(NUMERO,X-1)

Endif

Return


















