#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
#Infbox ACTION
Case ACTION
  When "DEBUT" : Gosub DEBUT
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "FIN" : Gosub FIN
  When "ENR" : Gosub ENR
Endcase

Return

#################################################
$DEBUT

Raz [M:ZCE0]

[M:ZCE0]BPCNUM = PARAM(1)
Affzo [M:ZCE0]BPCNUM 


Return

################################################################
$FIN
  Disable GSTAENR
Return

################################################################
$ENR
If !clalev([F:MVC]) : Local File BPCUSTMVT [MVC] : Endif
Read [MVC]MVC0 = [M:ZCE0]BPCNUM;[M:ZCE0]PLANTA
If fstat = 0
Trbegin [MVC]
[F:MVC] = [M:ZCE0]
Rewrite [MVC]

Commit
Gosub CARGA
Endif

Disable GSTAENR

Return
#########################################
$APRES_MODIF

If zoncou <> "PLANTA"
Enable GSTAENR
Endif
Return


$CARGA
 
[M:ZCE0]ZNRECLA = [MVC]ZNRECLA
[M:ZCE0]ZFECRECLA = [MVC]ZFECRECLA
[M:ZCE0]ZNIMP = [MVC]ZNIMP
[M:ZCE0]ZFECIMP = [MVC]ZFECIMP
[M:ZCE0]ZIMPIMP = [MVC]ZIMPIMP

Affzo [M:ZCE0]5

[M:ZCE0]ZSUMIMP = 0
[M:ZCE0]ZSUMIMPIMP = 0

For [MVC] Where BPCNUM = [M:ZCE0]BPCNUM
 [M:ZCE0]ZSUMIMP += [MVC]ZNIMP
 If [M:ZCE0]ZULTFECIMP < [MVC]ZFECIMP
   [M:ZCE0]ZULTFECIMP = [MVC]ZFECIMP
 Endif
 [M:ZCE0]ZSUMIMPIMP += [MVC]ZIMPIMP
 If [M:ZCE0]ZULTFECREC < [MVC]ZFECRECLA
   [M:ZCE0]ZULTFECREC = [MVC]ZFECRECLA
 Endif

Next

Affzo [M:ZCE0]10

Return

########################################
Subprog AM_PLANTA(VALEUR)
Variable Char    VALEUR()
If !clalev([F:MVC]) : Local File BPCUSTMVT [MVC] : Endif
Read [MVC]MVC0 = [M:ZCE0]BPCNUM;VALEUR
If fstat <> 0 
  Errbox "No hay movimientos asociados a esta planta"
  mkstat = 2
Else
  Gosub CARGA
Endif
End

########################################
Subprog S_PLANTA(VALEUR)
Variable Char    VALEUR()
If !clalev([F:MVC]) : Local File BPCUSTMVT [MVC] : Endif


Choose [MVC] Where BPCNUM = [M:ZCE0]BPCNUM Using
& [MVC]FINRSPFCY Titled "Planta"
& Sized(80,140)
& Titled "Seleccion Planta Mvt."
If status =28
  VALEUR = [MVC]FINRSPFCY
  Gosub CARGA
Endif
End

