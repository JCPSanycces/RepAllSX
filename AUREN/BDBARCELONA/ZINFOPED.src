#<AdxTL>@(#)0.0.0.0 $Revision$
Local Date DESDE,HASTA

DESDE = gdat$(01,01,03)   :#periodo de seleccion desde
HASTA = gdat$(31,12,20)   :#periodo de seleccion hasta

Call ZINFOPED(DESDE,HASTA)
End

#############################################################################################
Subprog ZINFOPED(FECDES,FECHAS)
Value Date FECDES
Value Date FECHAS

Local Integer NUMIMP, ER
Local Char    SAVIFS(10) , SAVIRS(10)

SAVIFS = adxifs
SAVIRS = adxirs

adxifs = ";"                                          :  # ============= Separador de camp
adxirs = ""                                           :  # ============= Separador de registre

GTRACE = "ZINFOPED"                :   #Nombre del fich a generar

Openo "#@C:\temp\PEDIDOS.txt" , 0   :# genereac. fichero en estacion cliente

Call TEMPON("Gen. fich. en c:\temp\PEDIDOS.txt") From GESECRAN

Gosub LECTURA

GERRTRACE = 0

Call TEMPOFF From GESECRAN
Openo

adxifs    = SAVIFS
adxirs    = SAVIRS

End

#########################################################
$LECTURA
Local File SORDERQ [SOQ]
Local File SORDERP [SOP]
Local File SORDER [SOH]
Local File ITMMASTER [ITM]

Wrseq '"Cliente"';'"F. Pedido"'; '"Pedido"'; '"Articulo"'; '"Descrip."'; '"Unidad Stock"'; '"Cant. Pedida"';'"Cant. Entregada Val."';
& '"Cant. Entregada no Val."';'"Cant. Facturada"';'"Cant. Cancelada/Pdte."';'"Precio"';'"Divisa"';'"Estado linea"';

Wrseq chr$(10)
 


$SALTA
Filter [SOH] Where ORDDAT >= FECDES and ORDDAT <= FECHAS Order By Key SOH0
For [SOH]
  
    For [SOQ]SOQ0 Where SOHNUM = [SOH]SOHNUM 
        Read [SOP]SOP0 = [SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
        Read [ITM]ITM0 = [SOQ]ITMREF
        Wrseq [F:SOH]BPCORD;
        Wrseq [F:SOH]ORDDAT;
        Wrseq [F:SOH]SOHNUM;
        Wrseq [F:SOQ]ITMREF;
        Wrseq [F:ITM]ITMDES1;
        Wrseq [F:SOP]STU;
        Wrseq format$("N:8.3",[SOQ]QTYSTU);
        Wrseq format$("N:8.3",[SOQ]DLVQTY);
        Wrseq format$("N:8.3",[SOQ]ODLQTY);
        Wrseq format$("N:8.3",[SOQ]INVQTY);
        Wrseq format$("N:8.3",[SOQ]QTYSTU-([SOQ]DLVQTY+[SOQ]ODLQTY)) ;
        Wrseq format$("N:8.3",[SOP]NETPRI);
        Wrseq [F:SOH]CUR;
        If [SOQ]SOQSTA = 1
           Wrseq "En Espera" ;
        Elsif [SOQ]SOQSTA = 2
           Wrseq "Retraso" ;
        Elsif [SOQ]SOQSTA = 3
           Wrseq "Saldada" ;
        Endif
        Wrseq chr$(10)

    Next    

Next   
 
Return
