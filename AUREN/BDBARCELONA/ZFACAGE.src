#############################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value Integer NBPAR
Variable Char PARAMETRE()()


Call EXEC(NBPAR,PARAMETRE)

End

#################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()

Gosub OUVRE
Gosub LIMPIA
Gosub INICI

End

#################################################
$INICI
[L]CRITERE1 = "1=1"
[L]CRITERE2 = "1=1"

[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)

 ##  When "sitedeb"         : [L]CRITERE1 -= "& CPY>='"+[L]VALEUR+"'"
 ##                           [L]CRITERE2 -= "& CPY>='"+[L]VALEUR+"'"                          

 ##  When "sitefin"         : [L]CRITERE1 -= "& CPY<='"+[L]VALEUR+"'" 
 ##                           [L]CRITERE2 -= "& CPY<='"+[L]VALEUR+"'"    

   When "repnumdeb"       : [L]CRITERE1 -= "& REP1>='"+vireblc([L]VALEUR,0)+"'"
                            [L]CRITERE2 -= "& REP2>='"+vireblc([L]VALEUR,0)+"'"

   When "repnumfin"       : [L]CRITERE1 -= "& REP1<='"+vireblc([L]VALEUR,0)+"'"
                            [L]CRITERE2 -= "& REP2<='"+vireblc([L]VALEUR,0)+"'"

   When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            #[L]CRITERE1 -= "& INVDAT >=["+format$(GFMD,[L]DATREF)+']'
                            #[L]CRITERE2 -= "& INVDAT >=["+format$(GFMD,[L]DATREF)+']'
                            [L]DATREFI =[L]VALEUR

  
   When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            #[L]CRITERE1 -= "& INVDAT <=["+format$(GFMD,[L]DATREF)+']'
                            #[L]CRITERE2 -= "& INVDAT <=["+format$(GFMD,[L]DATREF)+']' 
                            [L]DATREFF =[L]VALEUR


    #When "invdat"         : 
   #                         [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
#&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
#                            [L]CRITERE1 -= "& INVDAT >=["+format$(GFMD,[L]DATREF)+']'
#                            [L]CRITERE2 -= "& INVDAT >=["+format$(GFMD,[L]DATREF)+']'


#                            [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
#&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))

#                            #Suma 90 días
#                            [L]DATREF = [L]DATREF + 90
#                            [L]CRITERE1 -= "& INVDAT <=["+format$(GFMD,[L]DATREF)+']'
#                            [L]CRITERE2 -= "& INVDAT <=["+format$(GFMD,[L]DATREF)+']'

  Endcase
 Endif
Next

Gosub PROCESO

Close File [SID]
Close File [ZFA]
Close File [REP]

Return

############################################

$PROCESO
Local Integer ZGRABA1 #FLAG REPRESENTANTE
Trbegin [ZFA]

##CRITERE1 += " & NUM = 'FAC-BD203-00548'"  ### PARA PRUEBAS, BORRAR DESPUES
Raz ZGRABA1
For [SID]SID0 Where  evalue(CRITERE1)
    Read [SIH]SIH0 = [F:SID]NUM
    If fstat = 0
        If [F:SIH]STA = 3

                      
            Raz [F:ZFA]
            If [F:SID]REP1 <> ''
                ZGRABA1 = 1
                [F:ZFA]REPNUM = [F:SID]REP1
                Gosub GRABA_REGISTRO
            Endif
        Endif
    Endif
Next

For [SID]SID0 Where  evalue(CRITERE2)
   Read [SIH]SIH0 = [F:SID]NUM
    If fstat = 0
       If [F:SIH]STA = 3
          Raz [F:ZFA]
            If [F:SID]REP2 <> ''
                ZGRABA1 = 0
                [F:ZFA]REPNUM = [F:SID]REP2
                Gosub GRABA_REGISTRO
            Endif
        Endif
    Endif
Next

Commit

Return

###########################################################
$GRABA_REGISTRO
Read [REP]REP0 = [F:ZFA]REPNUM
If fstat = 0
    [F:ZFA]REPNAM = [F:REP]REPNAM
Endif
[F:ZFA]NUM = [F:SID]NUM

Call CONVERT2([F:SIH]CUR,GLOCALDEV,GLOCALDEV,1,[F:SID]INVDAT,[F:SIH]AMTATI,MTDES,STAT) From TRTDEV
[F:ZFA]ZAMTATI = MTDES *[SIH]SNS

Call CONVERT2([F:SIH]CUR,GLOCALDEV,GLOCALDEV,1,[F:SID]INVDAT,[F:SIH]AMTNOT,MTDES,STAT) From TRTDEV
[F:ZFA]ZAMTNOT = MTDES *[SIH]SNS

If ZGRABA1 = 1
    Call CONVERT2([F:SIH]CUR,GLOCALDEV,GLOCALDEV,1,[F:SID]INVDAT,[F:SID]REPAMT1,MTDES,STAT) From TRTDEV
    [F:ZFA]REPAMT1 = MTDES * [F:SIH]SNS
Else
    Call CONVERT2([F:SIH]CUR,GLOCALDEV,GLOCALDEV,1,[F:SID]INVDAT,[F:SID]REPAMT2,MTDES,STAT) From TRTDEV
    [F:ZFA]REPAMT1 = MTDES * [F:SIH]SNS
Endif

[F:ZFA]ZIMPR = 2
IND1 = '0'
Read [BPR]BPR0 = [F:SIH]BPR
If fstat = 0
    [F:ZFA]BPR = [F:BPR]BPRNUM
    [F:ZFA]BPCNAM = [F:BPR]BPRNAM
    
Endif

[F:ZFA]CPY = [F:SIH]CPY
#[F:ZFA]CUR = [F:SIH]CUR
[F:ZFA]CUR = GLOCALDEV
[F:ZFA]INVDAT = [F:SID]INVDAT

Gosub COMPRUEBA_COBRO
                                 
#If GUSER = "INF" & [F:ZFA]NUM = "FAC-BD205-01404"
   # dbgmode(0) = 1
   # dbgmode(1) = 1
#Endif
    
If [F:BPR]CRY = 'ES'                    ##### Filtro Fecha
   If [F:SID]INVDAT >= DATREFI and [F:SID]INVDAT <= DATREFF    
      [F:ZFA]ZIMPR = 2
   Else
      [F:ZFA]ZIMPR = 1
      IND1 = '1'
   Endif
Else
   Read [DUD]DUD0 = [F:SIH]SIVTYP;[F:SIH]NUM
   If [F:DUD]DUDDAT >= DATREFI and [F:DUD]DUDDAT <= DATREFF
      [F:ZFA]ZIMPR = 2
   Else
      [F:ZFA]ZIMPR = 1
      IND1 = '1'
   Endif
Endif

If SWPENDIENTE = 1
    [F:ZFA]ZFACCOB = 1
    If [F:BPR]CRY <> 'ES'        ### Filtro pais 
         [F:ZFA]ZIMPR = 1          
    Endif 
Else
  If IND1 = '0'
    [F:ZFA]ZFACCOB = 2
    [F:ZFA]ZIMPR = 2
  Endif
Endif


[F:ZFA]USR = GUSER
Write [F:ZFA]
Return 

###########################################################

$COMPRUEBA_COBRO
Local Integer ZFLAG
Local Decimal WAMTLOC, WPAYLOC

#SWPENDIENTE = 1:  PENDIENTE DE COBRO 
Raz SWPENDIENTE
Raz ZFACCOB, ZFLAG

SWPENDIENTE = 0

For [PYD]PYD10 Where [PYD]VCRNUM = [F:SID]NUM
    For [HAE]HAE10 Where [HAE]BPRVCR = [PYD]NUM 
    Case [HAE]TYP
        When "IMP"    
            WAMTLOC = 0
            WPAYLOC = 0
            # SE COMPRUEBA SI DEL IMPAGADO HAY UN COBRO Y OTRO IMPAGADO
            Local Char WWNUM 
            WWNUM = [HAE]NUM
            $HAYOTRO
            Local Integer WHAYOTRO
            For [PY2]PYD10 Where VCRNUM = WWNUM
                For [HA2]HAE10 Where BPRVCR = [PY2]NUM 
                    If [HA2]TYP = "IMP"
                       WWNUM = [HA2]NUM
                       [HAE]TYP = [HA2]TYP
                       [HAE]NUM = [HA2]NUM
                       WHAYOTRO = 1
                    Endif
                Next
            Next
            If WHAYOTRO = 1 : Goto HAYOTRO : Endif
                # FIN SE COMPRUEBA SI DEL IMPAGADO HAY UN COBRO Y OTRO IMPAGADO
                For [DUD]DUD0 Where TYP = [HAE]TYP and NUM = [HAE]NUM
                    WAMTLOC += [DUD]AMTLOC * [DUD]SNS
                    WPAYLOC += [DUD]PAYLOC * [DUD]SNS       
                Next

                If WAMTLOC <> WPAYLOC Then 
                    SWPENDIENTE = 1
                Endif
        When Default 
    Endcase
    Next
Next

If SWPENDIENTE = 0
    For [DUD]DUD0 Where [DUD]TYP = [SIH]GTE and [DUD]NUM = [F:SID]NUM
        If [DUD]AMTLOC <> [DUD]PAYLOC
            SWPENDIENTE = 1
        Endif
    Next
Endif

Return

$LIMPIA
Trbegin [ZFA]
Delete [ZFA] Where USR = GUSER
Commit

Return


##########################################################

$OUVRE
Local Char    CRITSUP(100), PARAM(30) , VALEUR(30) , ETAT(15) 
Local Integer WNUMLIG, NUMREQ
Local Date    DATREF
Local Date    DATREFI
Local Date    DATREFF
Local Char    IND1
Local Decimal ZFACCOB
Variable Decimal MTDES
Variable Integer SWPENDIENTE, STAT

Local Char ZREPNUMDEB, ZREPNUMFIN
Local Char CRITERE1(255), CRITERE2(255)
Local Date ZINVDAT

If clalev ([F:SIH]) <= 0 : Local File SINVOICE   [SIH] : Endif
If clalev ([F:SID]) <= 0 : Local File SINVOICED  [SID] : Endif
If clalev ([F:ZFA]) <= 0 : Local File ZFACAGE    [ZFA] : Endif
If clalev ([F:REP]) <= 0 : Local File SALESREP   [REP] : Endif

If clalev ([F:PYD]) <= 0 : Local File PAYMENTD   [PYD] : Endif
If clalev ([F:HAE]) <= 0 : Local File GACCENTRY  [HAE] : Endif
If clalev ([F:PY2]) <= 0 : Local File PAYMENTD   [PY2] : Endif
If clalev ([F:HA2]) <= 0 : Local File GACCENTRY  [HA2] : Endif

If clalev ([F:DUD]) <= 0 : Local File GACCDUDATE [DUD] : Endif

If clalev ([F:BPR]) <= 0 : Local File BPARTNER   [BPR] : Endif

Return

       
