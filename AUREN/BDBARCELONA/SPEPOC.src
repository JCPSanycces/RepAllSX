#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "LIENS"        : Gosub LIENS
 When Default
Endcase
Return

$LIENS
Gosub LIENS From SUBPOCA
If [F:POH]BETFCY=2
    Actzo [POC2]PRHFCY
    Actzo [POC2]PLI, PRIVLT, WCURVLT, 25
Endif
GPE=1
Return

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
[M:POC2]FCYADD = GZDIRDEF
Affzo [M:POC2]FCYADD
End
