#<AdxTL>@(#)4.0.0.0 $Revision:   1.20  $ Gesti¾n de la mßscara ITN7

Subprog ZSELABO

    Local Char PARAM(10)(1..100)
    Local Char VALEUR(10)
    GBIDI1=1
    Call SAISIE_CHAR(VALEUR,PARAM,"ZSELABO","ZSELABO") From GSAISIE


    Gosub OUVRE
    Gosub CARGA
End

######################################################################################
$CARGA

Local Char WSOHNUM
Local Char WSIVNUM
Local Char WSDHNUM
Local Decimal WAMTATI


NOL =-1
Read [F:SRE]SRE0 = [M:ITN0]SRVDEMNUM
If fstat = 0 Then
    WSOHNUM = [F:SRE]SRECOVNUM
Endif

For [SIV]SIV1 Where [SIV]INVTYP = 2 & ([SIV]SIHORI = 6 | [SIV]SIHORI = 4)
    WSIVNUM = [SIV]NUM
    Read [SIH]SIH0 = [SIV]NUM
    Case [SIV]SIHORI
        When 6
            For [F:SRD]SRD0 Where [F:SRD]SRHNUM = [SIV]SIHORINUM
                If WSDHNUM <> [F:SRD]SDHNUM Then
                    For [F:SDD]SDD0 Where [F:SDD]SDHNUM  = [F:SRD]SDHNUM
                        If [F:SDD]SOHNUM = WSOHNUM Then
                               NOL += 1
                               [M:DIA]NUM(NOL) = WSIVNUM
                               [M:DIA]AMTATI(NOL) = [F:SIH]AMTATI
                               [M:DIA]CUR(NOL) =    [F:SIV]CUR
                               [M:DIA]SOHNUM(NOL) = [F:SDD]SOHNUM
                               [M:DIA]SRHNUM(NOL) = [F:SRD]SRHNUM
                               [M:DIA]SDHNUM(NOL) = [F:SDD]SDHNUM
                               [M:DIA]NBLIG = NOL+1
                        Endif
                    Next
                    WSDHNUM = [F:SRD]SDHNUM
                Endif
            Next
        When 4
    Endcase
Next

Return

######################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

######################################################################################
$FIN
    Close Mask [DIA]
End

######################################################################################
$OUVRE
# La abreviatura de la pantalla siempre tiene que ser [DIA]
Local Mask ZSELABO [DIA]
Local Integer OK

If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
If clalev([F:SRE])=0 : Local File SERREQUEST [SRE] : Endif
If clalev([F:SRD])=0 : Local File SRETURND   [SRD] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif


Local Shortint NOL

Return
