#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################################
#### 05/12/00 ABC
#### Y02 Denominaciones Comerciales
#### Proceso que afecta a la funcionalidad de las entregas desviando las acciones originales
#### Tambien se han suprimido acciones de campo en algunos campos del estandard:
#
#     Campo     Tipo Accion    Accion
#     ------    ------------  ------------
#
#     GROPRI    Boton4         TRTVISTAR
# 
#
##########################################################################################################################

$ACTION
Case ACTION
 When "PICKE"     : Gosub PICKE
 When Default
Endcase
Return

######################################################
$PICKE
    Gosub PICKE From SUBSDHC
    If (currbox = GBOXSO1 or currbox = GBOXSO2) and [M]NBLIG > 0
        Call ALIARTSDH([M:SDH1]ITMREF(NOL),NOL) From TRTVENLIV

        #22/03/02
        #Precio entrega interplantas, tomado del contrato
        #rab
        #ai
            #Infbox [F:SOH]SOHNUM + " " + [F:SOH]CUSORDREF  + " " + [F:SOQ]ITMREF + " " + num$([F:SOQ]SOPLIN) + " " + num$([F:SOQ]SOQSEQ)
        
            Local Date ZORDDAT
            Raz ZORDDAT
            If clalev([F:POP1])=0 Local File PORDERP [POP1] Endif 

            #Infbox  [F:SOQ]FMINUM + "  " + num$([F:SOQ]FMILIN)
            For [POP1]POP1 Where POHNUM = [F:SOQ]FMINUM & POPLIN = [F:SOQ]FMILIN
        
            #Infbox  num$([F:SOQ]FMINUM)+ " " + num$([F:SOQ]FMILIN) + " " + num$([F:SOQ]ORDDAT)
            #Infbox "SHIDAT "+num$([F:POP1]SHIDAT) + " ordat "+num$([F:SOQ]ORDDAT)
        
                If [F:SOQ]SHIDAT >= [F:POP1]STRDAT and [F:SOQ]SHIDAT <= [F:POP1]POPDAT 
                    ZORDDAT = [F:SOQ]ORDDAT
                Endif
            Next

            If ZORDDAT <> [0/0/0]
            [M]GROPRI(NOL) = [F:POP1]GROPRI
                # Calculs prix net, marge et maj montants livrés et poids 
                GNETMAR=0
                Call ALICLCAMT([M:SDH1]ITMREF(NOL), [M]QTY(NOL), NOL, "SDH1", [M:SDH1]CLCAMT1(NOL), [M:SDH1]CLCAMT2(NOL)) From TRTX3
                Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR, NOL)From TRTVENPRI
                Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,[M:SDH1]CUR,NOL,1) From TRTVENPRI
    
                #resta los valores calculados por el estándar
                [M]DLVNOT -= [M]LINDLVNOT(NOL)
                [M]DLVATI -= [M]LINDLVATI(NOL)
    
                # --> Calcul du montant liv ht et ttc de la ligne
                Gosub CALC_DLV From SUBSDHB
                
                # Incrémentation des montants et poids livraison
                Gosub ADD_TOT From SUBSDHB
    
                GNETMAR=1
            Else
                Errbox "No existe tarifa para el artículo "+[F:SOQ]ITMREF
            Endif
        #af

    Endif
    Affzo [M:SDH1] 

    GPE=1
Return


########################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

Local File BPCUSTOMER [BPC]

Read [F:BPC]BPC0 = VALEUR
If fstat = 0 Then
    [M:SDH0]FREINV = [BPC]FREINV
    Affzo [M:SDH0]FREINV 
Endif


End

########################################
Subprog AM_NETPRI(VALEUR)
Variable Decimal VALEUR
[M:SDH0]IMPORTE = [SDH]DLVNOT
Affzo [M:SDH0]IMPORTE
End

########################################
Subprog AP_BPCORD(VALEUR)
Variable Char    VALEUR()
# Infbox "DESPUES CAMPO"
End

