#<AdxTL>@(#)0.0.0.0 $Revision:   1.20  $ Gestión de la máscara ARY
#Superviseur Adonix
$PARDEF
Local Char PARAM(250)(1..20) , SAVACT(10)
Return

$MK99
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Return

Subprog C_INTCOD(VALEUR)
Variable Char    VALEUR()
Raz GMESSAGE
If vireblc(VALEUR,2)="" : mkstat=1 : Endif
If mkstat : Call ERRZON("INTCOD",743,mess(10,123,1)) From GESECRAN : End : Endif
Gosub AFF From GSAISIE
End

Subprog B1_EXTCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ARP",VALEUR,"") From GOBJET
Gosub AFF From GSAISIE
Gosub MK99
End

Subprog AS_EXTCOD(VALEUR)
Variable Char    VALEUR()
Local integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(11937,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EXTCOD(zc) From XXAUTARY1
Gosub AFF From GSAISIE
End

Subprog C_EXTCOD(VALEUR)
Variable Char    VALEUR()
Raz GMESSAGE
If !mkstat
 Call CONTROLE("ARP","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : Call ERRZON("EXTCOD",846,GMESSAGE) From GESECRAN : End : Endif
Endif
Gosub AFF From GSAISIE
End

$AMM_EXTCOD
Call AM_EXTCOD(zc)
If !mkstat & GOBJET
 zoncou = "EXTCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXTCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZEXTCOD)")>indice
 [M]EXTCOD(indice) = VALEUR
 If GINTRA : Call AV_ZEXTCOD([M]ZEXTCOD(indice)) : Endif
 Affzo ZEXTCOD(indice)
Endif
Gosub AFF From GSAISIE
End

Subprog S_EXTCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(250)(1..3)
PARAM(1) = "ARP"
PARAM(2) = ""
PARAM(3) = ""
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ") From GACTION
End

Subprog SA_EXTCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARBOUT(250)(1..4), SAVACT(20)
PARBOUT(1) = "ARP"
SAVACT = GACTION : GACTION = "SELOBJAW"
Call SAISIE_CHAR(VALEUR,PARBOUT,"DSELOBJAW","SELOBJAW") From GSAISIE
GACTION = SAVACT
End

Subprog P_EXTCOD(VALEUR)
Variable Char    VALEUR()
Call VISU("ARP",VALEUR,"") From SUBAOP
End

Subprog AV_ZEXTCOD(VALEUR)
Variable Char    VALEUR()
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
Call LECTURE("ARP",[M]EXTCOD(indice),"") From CONTOBJ
VALEUR = [F:ARP]DES
End

Subprog B1_LAN(VALEUR)
Variable Char    VALEUR()
Call OBJET("TLA",VALEUR,"") From GOBJET
Gosub AFF From GSAISIE
Gosub MK99
End

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
Local integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3587,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LAN(zc) From XXAUTARY1
Gosub AFF From GSAISIE
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
Raz GMESSAGE
If !mkstat
 Call CONTROLE("TLA","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : Call ERRZON("LAN",1505,GMESSAGE) From GESECRAN : End : Endif
Endif
Gosub AFF From GSAISIE
End

Subprog S_LAN(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(250)(1..3)
PARAM(1) = "TLA"
PARAM(2) = "!"
PARAM(3) = ""
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ") From GACTION
End

Subprog SA_LAN(VALEUR)
Variable Char    VALEUR()
Local Char PARBOUT(250)(1..4), SAVACT(20)
PARBOUT(1) = "TLA"
SAVACT = GACTION : GACTION = "SELOBJAW"
Call SAISIE_CHAR(VALEUR,PARBOUT,"DSELOBJAW","SELOBJAW") From GSAISIE
GACTION = SAVACT
End

Subprog P_LAN(VALEUR)
Variable Char    VALEUR()
Call VISU("TLA",VALEUR,"") From SUBAOP
End

$TIT_COL
Local Char TITCL(200)(1..80)
Raz TITCL
Case BASPAG
Endcase
Return

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT
$SAIMSK_ : #DX_0001
Local Integer I , J , K , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(10) , IMPZON(10) , NOMZONE(20)
IMPMSK = "ARY"
IMPTBL = 0 : indice = 0
IMPMOD = 0 : IMPZON = "INTCOD" : Gosub ACTION From =IMPTRT
If varmode([M]INTCOD,0)=0
 mkstat = 0 : Call C_INTCOD([M]INTCOD) From XXAUTARY1 : If mkstat : End   : Endif
Endif
If varmode([M]EXTCOD,0)=0
 mkstat = 0 : Call AS_EXTCOD([M]EXTCOD) From XXAUTARY1
 If mkstat=1 : Raz [M]EXTCOD : Endif
Endif
If !mkstat
 IMPMOD = 0 : IMPZON = "EXTCOD" : Gosub ACTION From =IMPTRT
 If varmode([M]EXTCOD,0)=0
  mkstat = 0 : Call C_EXTCOD([M]EXTCOD) From XXAUTARY1 : If mkstat : End   : Endif
  If IMPMOD
   mkstat = 0 : Call AM_EXTCOD([M]EXTCOD) From XXAUTARY1 : If mkstat : End   : Endif
  Endif
 Endif
Endif
If GINTRA : Call AV_ZEXTCOD([M]ZEXTCOD) From XXAUTARY1 : Endif
If varmode([M]LAN,0)=0
 mkstat = 0 : Call AS_LAN([M]LAN) From XXAUTARY1
 If mkstat=1 : Raz [M]LAN : Endif
Endif
If !mkstat
 IMPMOD = 0 : IMPZON = "LAN" : Gosub ACTION From =IMPTRT
 If varmode([M]LAN,0)=0
  mkstat = 0 : Call C_LAN([M]LAN) From XXAUTARY1 : If mkstat : End   : Endif
 Endif
Endif
mkstat = 0
End : #FX_0001

