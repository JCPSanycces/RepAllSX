#############################################################################################
#                                                                                           #
# CACT    Descripciˇn                             Fecha            Autor                    #
# ------------------------------------------------------------------------------------------#
# ZMV     Proceso copia tarifas a contratos       28/04/2003       Alex Frances (Infolan)   #
#                                                                                           #
#############################################################################################

$ACTION

Case ACTION
 
 When "DEBUT"  : Gosub DEBUT  
 When "OUVRE"  : Gosub OUVRE    
 When "OK"     : Gosub OK   
 When "SORTIE" : Gosub SORTIE 
 When "FINSAI" : Gosub FINSAI 

 When Default
Endcase
Return


#############################################################################################
$DEBUT
Raz [M:ZCTC]
Return

#############################################################################################
$SORTIE
   # Call LEC_TRACE From LECFIC
Return

#############################################################################################
$OUVRE

If clalev([F:POC])=0 : Local File PORDERC   [POC] : Endif
If clalev([F:SPL])=0 : Local File SPRICLIST [SPL] : Endif
If clalev([F:POH])=0 : Local File PORDER    [POH] : Endif
If clalev([F:POP])=0 : Local File PORDERP   [POP] : Endif
If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif

If clalev([F:POP1])=0 : Local File PORDERP  [POP1] : Endif
If clalev([F:POP2])=0 : Local File PORDERP  [POP2] : Endif
If clalev([F:POP4])=0 : Local File PORDERP  [POP4] : Endif

Return

#############################################################################################
$OK

Call OUVRE_TRACE("") From LECFIC
Call ECR_TRACE(" ",0) From GESECRAN

Call TEMPON("V") From GESECRAN
For [POC]POC0 Where [F:POC]POHNUM = [M:ZCTC]POHNUMFIN 
    Gosub BUSCA_TARIFA
Next

Call TEMPOFF From GESECRAN
FIN =1
Return

#############################################################################################
$FINSAI

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

#############################################################################################
$BUSCA_TARIFA

Local Integer SW
Local Decimal WIMPTAR

Filter [SPL] Where PLI = [M:ZCTC]PLI and PLICRI1 = [M:ZCTC]CRY and PLICRI2 = [F:POC]ITMREF and PLISTRDAT <= date$ and 
&                  PLIENDDAT >= date$ Order By Key ZPL5

SW = 0
Raz WIMPTAR
For [SPL]
    If SW = 1 Then
        If [F:SPL]PRI < WIMPTAR Then
            WIMPTAR = [F:SPL]PRI 
        Endif
    Else
        WIMPTAR = [F:SPL]PRI
        SW = 1
    Endif
Next 
Filter [SPL]  

If WIMPTAR = 0 Then 
    Call ECR_TRACE("No actualizado artÝculo " + [F:POC]ITMREF + "Sin Tarifa " + " - " + time$ ,1) From GESECRAN
Else
    Gosub GRABA
Endif
Return

#############################################################################################
$GRABA

Local Integer LASTPOPSEQ
Local Integer SWPRIGUAL
Local Integer SWGRABA
Local Date    PLISTRDAT
Local Date    PLIENDDAT

SWPRIGUAL = 0 
SWGRABA = 0 
    #Buscamos la ˙ltima sequencia para actualizar la fecha final
    For [POP]POP0 Where [POP]POHNUM = [M:ZCTC]POHNUMFIN and [POP]POPLIN = [F:POC]POPLIN
        LASTPOPSEQ = [POP]POPSEQ 
        If [POP]NETPRI = (WIMPTAR*[M:ZCTC]FACTOR) and [POP]STRDAT <= date$ and [POP]POPDAT >= date$ Then 
            Call ECR_TRACE("No actualizado " + [F:POP]ITMREF + "Tarifa igual en precio y validez de fechas" + " - " + time$ ,1) From GESECRAN
            SWPRIGUAL = 1 
        Endif
    Next    
    
    If SWPRIGUAL = 0 Then
        Read [POP2]POP1 = [M:ZCTC]POHNUMFIN;[POP]POPLIN;date$
        If fstat = 0 Then
            Trbegin [POP2]
                [POP2]POPDAT = [POP2]STRDAT
                Rewrite [POP2]
            Commit
        Endif

        Read [POP4]POP0 = [M:ZCTC]POHNUMFIN;[POP]POPLIN;LASTPOPSEQ
        If fstat = 0 Then
            Trbegin [POP4]
                [POP4]POPDAT = date$
                Rewrite [POP4]
            Commit
        Endif
    
        Read [POP1]POP0 = [M:ZCTC]POHNUMFIN;[POC]POPLIN
        If fstat = 0 Then
            [F:POP1] = [F:POP]
            [F:POP1]STRDAT = date$
            [F:POP1]POPSEQ = LASTPOPSEQ+1000
            [F:POP1]POHNUM = [M:ZCTC]POHNUMFIN
            [F:POP1]GROPRI = WIMPTAR*[M:ZCTC]FACTOR
            [F:POP1]NETPRI = WIMPTAR*[M:ZCTC]FACTOR
            Read [F:POH]POH0 = [M:ZCTC]POHNUMFIN
            If fstat = 0 Then
                [F:POP1]PRHFCY = [F:POH]POHFCY
                [F:POP1]CREDAT = [F:POH]CREDAT
                [F:POP1]CREUSR = [F:POH]CREUSR
                [F:POP1]POPDAT = [F:POH]ENDDAT
            Endif
            Trbegin [POP1]  
                Write [POP1]
                Call ECR_TRACE("Grabado " + [F:POP]ITMREF + "Precio tarifa " +num$(WIMPTAR)+ " - " + time$ ,0) From GESECRAN
            Commit
        Endif        
    Endif    
Return
