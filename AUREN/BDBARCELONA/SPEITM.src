$ACTION
Case ACTION
 When "APRES_CRE"  :  Gosub APRES_CRE
 When "VERIF_CRE"  :  Gosub VERIF_CRE
 When "INICRE"     :  Gosub INICRE
 When default
Endcase
Return

$INICRE
Return

$APRES_CRE
Return

$VERIF_CRE
Return

Subprog AM_TCLCOD(VALEUR)
Variable Char    VALEUR()
End


