#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR 
Variable Char    PARAMETRE()()
Local Integer IMPR, NUMCOP, I,DEST,NUMREQ

Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 

# -- rÈcup. entete de colonne pour les frais et remises
Call COLREM("C",1,"")     From TRTPRICE
 
[L]CRITERE = "1=1"
[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "__DESTINATION"   : [L]DEST   = val([L]VALEUR)
   When "typdeb"          : If len([L]VALEUR) <> 0
                                [L]CRITERE -= "& PAM='"+[L]VALEUR+"'" 
                            Endif
   When "facturedeb"      : If [L]VALEUR = "  " : Errbox "El N∫ de factura inicial es obligatorio" : GOK = 0 : Endif
                            [L]CRITERE -= "& NUM>='"+[L]VALEUR+"'" 
   When "facturefin"      : If [L]VALEUR = "  " : Errbox "El N∫ de factura final es obligatorio" :   GOK = 0 : Endif
                            [L]CRITERE -= "& NUM<='"+[L]VALEUR+"'"
   When "copias"          : [L]NUMCOP = val([L]VALEUR)
   #When "divisa"         : [L]PARAMETRE(I) = "divisa="+[L]VALEUR
   When "codimp"          : If [L]VALEUR = "1" 
                                [L]CRITERE -= "& SENDAT <["+format$(GFMD,gdat$(1,1,1997))+"]"
                                [L]IMPR = 1
                            Else
                                [L]CRITERE -= "& SENDAT >=["+format$(GFMD,gdat$(1,1,1997))+"]"
                                [L]IMPR = 2
                            Endif
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   #When "idioma"          : [L]PARAMETRE(I) = "idioma="+[L]VALEUR
   #When "divloc"          : [L]PARAMETRE(I) = "divloc="+GLOCALDEV
   #When "divrep"          : [L]PARAMETRE(I) = "divrep="+GSYSCUR

   When "decloc"          : #If clalev([F:TCU])  = 0 Local File TABCUR [TCU]  : Endif
                            Read [F:TCU]TCU0 = GLOCALDEV
                            If fstat = 0
                                [L]PARAMETRE(I) = "decloc="+num$([F:TCU]DECNBR)
                            Endif
   When "decrep"          : 
                            Read [F:TCU]TCU0 = GSYSCUR
                            If fstat = 0
                                [L]PARAMETRE(I) = "decrep="+num$([F:TCU]DECNBR)
                            Endif
 Endcase
 Endif
Next

Filter [F:DUD] Where evalue([L]CRITERE) 
Gosub TRT_DUD

End

###################################################################

$TRT_DUD
Raz WNUMLIG 
Default File [DUD]
For [F:DUD]DUD0 
       Call DEBTRANS From GLOCK 
       If [L]IMPR = 1 Gosub TR1
       Else           Gosub TR2
       Endif
Next 
Return

###################################################################

$TR1
Trbegin [DUD] , [ARM]

# Mise ý jour table entÍte facture(SINVOICE et SINVOICEV) si demande d'impression
If [L]IMPR = 1
 Readlock [F:DUD]DUD0 Curr   
 If fstat = 1 : GOK = -1 : GLOCK = "$GACCDUDATE" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("DUD","*") From GLOCK : Goto AB_TR1
 Endif
 [F:DUD]SENDAT = date$
 Rewrite [F:DUD]   
 If fstat=1 
  GOK=-1 : GLOCK="$GACCDUDATE"-[F:DUD]NUM
  Goto ROLL_TR1 
 Elsif fstat 
  GOK=0 : Call RSTA("GACCDUDATE",[F:DUD]NUM) From GLOCK : Goto AB_TR1 
 Endif  
Endif
 
#Initialisation ý 1 le nombre d'exemplaire si = 0
If [L]NUMCOP = 0 
   WCOPNBR = 1
Endif

#1 seul exemplaire en prÈ-visu et messagerie
If [L]DEST = 0 | [L]DEST = 2
     WCOPNBR = 1
Else WCOPNBR = [L]NUMCOP
Endif

#CrÈation de l'enregistrement dans la table AREPORTM
For I = 1 To WCOPNBR
    Raz [F:ARM]
    WNUMLIG      += 1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = [F:DUD]NUM
    [F:ARM]CLEA2   = [F:DUD]TYP
    [F:ARM]CLEN1   = [F:DUD]LIG
    [F:ARM]CLEN2   = [F:DUD]DUDLIG
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat : Break : Goto ROLL_TR1 : Endif 
Next I
Commit 

Return 
 
$ROLL_TR1

Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1 

Rollback 
Return 

###########################
$TR2
Trbegin [ARM]
#Initialisation ý 1 le nombre d'exemplaire si = 0
If [L]NUMCOP = 0
   WCOPNBR = 1
Endif
#1 seul exemplaire en prÈ-visu et messagerie
If [L]DEST = 0 | [L]DEST = 2
     WCOPNBR = 1
Else WCOPNBR = [L]NUMCOP
Endif


#CrÈation de l'enregistrement dans la table AREPORTM
For I = 1 To WCOPNBR
    Raz [F:ARM]
    WNUMLIG      += 1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = [F:DUD]NUM
    [F:ARM]CLEA2   = [F:DUD]TYP
    [F:ARM]CLEN1   = [F:DUD]LIG
    [F:ARM]CLEN2   = [F:DUD]DUDLIG
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat : Break : Goto ROLL_TR2 : Endif
Next I  
Commit 
Return 
 
$ROLL_TR2
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR2 : Endif 
 
$AB_TR2 
Rollback 
Return 

########################################################################### 

$OUVRE 
Local File GACCDUDATE [DUD] 
Local File TABCUR [TCU] 
Local File AREPORTM [ARM]

Return 
 
$DECLARE 
Local Char    CRITERE(255), CRITSUP(100), PARAM(30) , VALEUR(30) , ETAT(15)
Local Integer WNUMLIG, WCOPNBR

Local Char TYPDEB,FACTUREDEB,FACTUREHAS,DIVISA,IDIOMA
Local Integer COPIAS

Return 
 

