#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

Case ACTION
 When "OUVRE"     :    Gosub OUVRE   
 When "PICKE"     :    Gosub PICKE
 When "VERIF_CRE" :    Gosub VERIF_CRE
 When "SETBOUT"   :    Gosub SETBOUT
 When Default
Endcase
Return

########################################
$OUVRE
Global Integer SWPCK
SWPCK = 0
Return
########################################
$PICKE
Global Char WNUMPRESU
Raz WNUMPRESU
Raz SWPCK
WNUMPRESU = [F:SQH]SQHNUM
SWPCK = 1
Return

########################################
$VERIF_CRE

#Infbox [F:SQH]SQHTEX1
#Infbox [F:SQH]SQHTEX2

If SWPCK = 1 Then
    If clalev([F:SQH2])=0 : Local File SQUOTE  [SQH2] : Endif
    Read [SQH2]SQH0 = WNUMPRESU
    If fstat = 0 Then
        If [M:SOH0]SOHTEX1 = "" Then  
            [M:SOH0]SOHTEX1 = [F:SQH2]SQHTEX1 
            #[F:SOH]SOHTEX1 = [F:SQH2]SQHTEX1 
            Affzo [M:SOH0]SOHTEX1
        Endif
        If [M:SOH0]SOHTEX2 = "" Then 
            [M:SOH0]SOHTEX2 = [F:SQH2]SQHTEX2
            #[F:SOH]SOHTEX2  = [F:SQH2]SQHTEX2
            Affzo [M:SOH0]SOHTEX2
        Endif
    Endif
    Close File [F:SQH2]
    SWPCK = 0
Endif
Return

########################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

Local File BPCUSTOMER [BPC]

Read [F:BPC]BPC0 = VALEUR
If fstat = 0 Then
    [M:SOH1]FREINV = [BPC]FREINV
    Affzo [M:SOH1]FREINV 
Endif

End

########################################
Subprog AP_BPCORD(VALEUR)
Variable Char    VALEUR()
Local Integer WIMP   : # 0=No hay  1=Si hay
Local Integer WCRESUP : # 0=No   1=Si 

If clalev ([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
If GREP <> "C" : Goto FIN_CTRL : Endif
For [DUD]DUD0 Where TYP = "IMP"  and BPRPAY = [F:BPC]BPCPYR 
    If [DUD]AMTLOC <> [DUD]PAYLOC
        WIMP = 1
    Endif
Next

Gosub WCREDIT

#If WIMP = 1 and WCRESUP = 1
If WIMP = 1 or WCRESUP = 1
    Errbox "Cliente con impagados y crķdito excedido"
    mkstat = 2
Endif




$FIN_CTRL


End

###################################################################
$WCREDIT
###################################################################
#---- conversion montants devise dossier en devise sociķtķ        #
Local Decimal WMONTORG (0..2)
Local Decimal WMONTDES (0..2)
Local Integer SPSTAT
Local Decimal WORDMINAMT, WFUPMINAMT, WORDMINAMT
Local Integer WDECIMAL : WDECIMAL = 2

WMONTORG (0) = [F:BPC]ORDMINAMT
WMONTORG (1) = [F:BPC]FUPMINAMT
WMONTORG (2) = [F:BPC]OSTAUZ
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,GHIDATE,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,GHIDATE,WMONTORG (1),WMONTDES (1),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,GHIDATE,WMONTORG (2),WMONTDES (2),SPSTAT) From TRTDEV
If SPSTAT = 0
   WORDMINAMT   = arr(WMONTDES (0),WDECIMAL)
   WFUPMINAMT   = arr(WMONTDES (1),WDECIMAL)
   WOSTAUZ      = arr(WMONTDES (2),WDECIMAL)
Else
   WORDMINAMT   = [F:BPC]ORDMINAMT
   WFUPMINAMT   = [F:BPC]FUPMINAMT
   WOSTAUZ      = [F:BPC]OSTAUZ
Endif
   

#---- Calcul du total en-cours en devise sociķtķ 
Local Decimal WCRED
Local Char    SCUR (3) 
 
Local Decimal WMONTORG (0..9) 
Local Decimal WMONTDES (0..9) 
For  [MVC]MVC0 Where BPCNUM = [F:BPC]BPCNUM
      If    fstat <> 0 & fstat <> 1 : Raz [F:MVC] : Endif 
     #---- alimentation variables globales par sites comptables 
     Call GLOBVAR([F:MVC]FINRSPFCY) From AGLOBVEN 
     SCUR = [F:MVC]ACCCUR 
     WMONTORG (0) = [F:MVC]BLC 
     # Bug 18102 : On ne tient plus compte du portefeuille
#     WMONTORG (1) = [F:MVC]NYTBIL(0) 
#     WMONTORG (2) = [F:MVC]NYTBIL(1) 
#     WMONTORG (3) = [F:MVC]NYTBIL(2) 
     WMONTORG (4) = [F:MVC]NIVDLV 
     WMONTORG (5) = [F:MVC]DLVOST 
     WMONTORG (6) = [F:MVC]NPTINV 
     If   GOSTLND = 2 & dim([BPC]LNDAUZ) <> -1 
          WMONTORG (7) = [F:MVC]LNDDLV 
     Else WMONTORG (7) = 0 
     Endif 
     If   GOSTORD = 2 
          WMONTORG (8) = [F:MVC]ORDBPIATI 
     Else WMONTORG (8) = 0 
     Endif 
     If   GOSTLND = 2 & GOSTORD = 2 & dim([M]LNDAUZ) <> -1 
          WMONTORG (9) = [F:MVC]LNDBPIATI 
     Else WMONTORG (9) = 0  
     Endif 
     Call CONVERT_TAB(SCUR,GCUR,GCUR,GCHGTYP,GHIDATE,WMONTORG,WMONTDES,SPSTAT) From TRTDEV 
     WCRED += arr(sum(WMONTDES),WDECIMAL)
Next 

    If WCRED > WOSTAUZ
        WCRESUP = 1
    Endif
Return

######################################################################################
