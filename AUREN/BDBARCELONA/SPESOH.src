################################################################
$SETBOUT

If [M:SOH1]ORDSTA=2 | [M:SOH1]ALLSTA>1 | [M:SOH1]DLVSTA>1 |  [M:SOH1]INVSTA>1 
   Call VIREBOUT(CHAINE,"z") From GOBJET
Endif

Return
