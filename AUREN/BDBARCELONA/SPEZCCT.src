#<AdxTL>@(#)10.0.0.0 $Revision:   1.20  $ Gestión de la máscara ZCOPCTO
$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog S_POHNUMDEB(VALEUR)
Variable Char    VALEUR()

If clalev([F:POH])=0 : Local File PORDER [POH] : Endif

Choose[POH] 
& Where ([F:POH]POHTYP = 2 and [F:POH]POHNUM <> [M]POHNUMFIN)
& Order By [POH]POHNUM Asc Using 
& [POH]ORDDAT Titled "Fecha Pedido", 
& [POH]POHNUM Titled "N. Contrato Origen", 
& [POH]POHFCY Titled "Planta Pedido", 
& [POH]BPSNUM Titled "Proveedor",
& [POH]ORDREF Titled "Ref. Interna"
& Sized(80,240) 
& Titled "Selección Contratos"

If status <> 7
  VALEUR = [POH]POHNUM
Else 
  Raz VALEUR
Endif

End

########################################
Subprog S_POHNUMFIN(VALEUR)
Variable Char    VALEUR()

If clalev([F:POH])=0 : Local File PORDER [POH] : Endif

Choose[POH] 
& Where ([F:POH]POHTYP = 2 and [F:POH]POHNUM <> [M]POHNUMDEB)
& Order By [POH]POHNUM Asc Using 
& [POH]ORDDAT Titled "Fecha Pedido", 
& [POH]POHNUM Titled "N. Contrato Origen", 
& [POH]POHFCY Titled "Planta Pedido", 
& [POH]BPSNUM Titled "Proveedor",
& [POH]ORDREF Titled "Ref. Interna"
& Sized(80,240) 
& Titled "Selección Contratos"

If status <> 7
  VALEUR = [POH]POHNUM
Else 
  Raz VALEUR
Endif

End

########################################
Subprog AM_FLGSOLTAR(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M]FLGTARITM
Else
    Actzo [M]FLGTARITM
Endif
End

########################################
Subprog AM_FLGACTTODO(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M]FLGCRENUE
Else
    Actzo [M]FLGCRENUE
Endif


End

########################################
Subprog AM_FLGTARITM(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M]FLGSOLTAR
Else
    Actzo [M]FLGSOLTAR
Endif

End

########################################
Subprog AM_FLGCRENUE(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M]FLGACTTODO
Else
    Actzo [M]FLGACTTODO
Endif


End

########################################
Subprog C_POHNUMDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR = [M]POHNUMFIN Then
    Errbox ("Contrato origen y destino iguales")
    mkstat = 2
Endif
End

########################################
Subprog C_POHNUMFIN(VALEUR)
Variable Char    VALEUR()

If VALEUR = [M]POHNUMDEB Then
    Errbox ("Contrato origen y destino iguales")
    mkstat = 2
Endif
End

########################################
Subprog AM_POHNUMDEB(VALEUR)
Variable Char    VALEUR()

If clalev([F:POH])=0 : Local File PORDER [POH] : Endif

Read [POH]POH0 = VALEUR
If fstat <> 0 Then
    Errbox ('Número contrato inexistente')
    mkstat = 2
Endif
End



########################################
Subprog AM_POHNUMFIN(VALEUR)
Variable Char    VALEUR()
If clalev([F:POH])=0 : Local File PORDER [POH] : Endif

Read [POH]POH0 = VALEUR
If fstat <> 0 Then
    Errbox ('Número contrato inexistente')
    mkstat = 2
Endif

End

