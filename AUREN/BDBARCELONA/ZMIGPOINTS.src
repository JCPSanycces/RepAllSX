#---------------------------------------------------------------------------#
# X01: Pasar comentarios de línea del Pedido - 08/01/03 - Alex Frances      #
# I01: Cambios en la generación de ficheroS bancarioS                       #   
# ZMI: REVISADO MIGRACION V5                                                #
#                                                                           #
#---------------------------------------------------------------------------#
$ACTION
    Case ACTION
     When "AFFTRA"    : Gosub ZBENCHLIB
     When "AV_LIGNE"  : Gosub ZFICMAG
     When Default         
    Endcase
Return

$ZBENCHLIB
   # X01: Inicio
    #ZMVAI
    If !clalev([F:SOQ]) : Local File SORDERQ    [SOQ] : Endif
    If !clalev([F:MFG]) : Local File MFGHEAD    [MFG] : Endif
    #ZMVAF
    If dim([M:MBW1]VCRNUMORI)<>-1 and dim([M:MFGK]MFGNUM)<>-1
        Read [F:SOQ]SOQ0 = [M:MBW1]VCRNUMORI;[M:MBW1]VCRLINORI;[M:MBW1]VCRSEQORI    
        If !fstat
          Read [F:MFG]MFG0 = [M:MFGK]MFGNUM
          If !fstat
            Trbegin [MFG]
                [F:MFG]MFGTEX = [F:SOQ]SOQTEX
                Rewrite [MFG]
            Commit
          Endif
        Endif
    Endif
   # X01: Fin
Return

$ZFICMAG
    #I01ai
    If [F:TFB]FILREF = "58" or [F:TFB]FILREF = "19"
        Gosub DAT_ADIC
        #TYP = 2 : Gosub ENREG From FICMAG
    Else
        #TYP = 2 : Gosub ENREG From FICMAG
    Endif
    #I01af
Return

$DAT_ADIC
# Definicion de detalle de pago
If clalev([F:PLU])=0 
  Local File PAYMENTD  [PLU]
  Local File PINVOICE  [PTA] 
  Local Char WGFAC(80)
Endif

# Realizar filtro de las lineas de pago
Filter [PLU] Where NUM=[F:PYH]NUM
&   Order By Key CLE = NUM;LIN

# Inicializacion de variables
Raz WGFAC

#lectura de linea de pago
 For [PLU]CLE Where NUM=[F:PYH]NUM

# Si es norma 34 (PROVEEDORES) Nş de asiento = Documento origen de Factura provedores
# Si es otra (CLIENTES) NÂş de asiento = NÂşAsiento
    If [F:TFB]FILREF = "34"
       Read [PTA]PIH0 = [F:PLU]VCRNUM
       If fstat : Raz [F:PTA] : Endif
       WGFAC -= [F:PTA]BPRVCR
    Else
       WGFAC -= [F:PLU]VCRNUM
    Endif
 Next: # [PLU]
Return

