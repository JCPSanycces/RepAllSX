#<AdxTL>@(#)2.0.0.0 $Revision$
#---------------------------------------------------------------
    # Point d'entrée ŕ faire pour modifier le contenu de [M:SHTS]LOT
    #---------------------------------------------------------------
    # Séquence ŕ écrire dans le point d'entrée 
    # pour que la régularisation se fasse męme si le lot n'est pas renseigné
    #---

$ACTION
Case ACTION
 When "ALIM_SHTS"   : Gosub ZREGSTJAUTO 
 When Default
Endcase
Return

$ZREGSTJAUTO
     For I=0 To [M:SHTS]NBLIG-1
        If dim([M:SHTS]LOT)>0 & [M:SHTS]LOT(I)="" : [M:SHTS]LOT(I)="*" : Endif
        If dim([M:SHTS]SLO)>0 & [M:SHTS]SLO(I)="" : [M:SHTS]SLO(I)="*" : Endif
     Next I
Return
