#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()
Local Integer    IMPR
Local Char       DEVDES(3)
Local Char       WCRIT(250)
Local Date       HFEC
Local Date       DFEC
Local Integer    I
Local Integer    SW
Local Char       SOCIEDAD
Local Integer    ORDEN
Local Char       DIVISA
Local Integer    ULTREG
Local Integer    I
Local Integer    J,NUMREQ
Local Integer    K
Local Integer    L
Local Integer    M


Variable Decimal MTDES           
Variable Integer STAT            
Local Integer SW

Gosub OUVRE 
Gosub DECLARE
Gosub INICIALIZA 
 

[L]CRITERE = "1=1"
[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
  When "X3ETA"           : [L]ETAT = [L]VALEUR
  When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)

   When "sociedad"        
         WCRIT = 'CPY = "'+ [L]VALEUR +'"'

   When "datdeb"        
         AA = val(mid$([L]VALEUR, 1, 4))
         MM  = val(mid$([L]VALEUR, 5, 2))
         DD = val(mid$([L]VALEUR, 7, 2))  
         DFEC = gdat$(DD,MM,AA)

         WCRIT -='& ACCDAT >=[' + num$(DFEC) + ']' 
   When "datfin"        
         AA = val(mid$([L]VALEUR, 1, 4))
         MM  = val(mid$([L]VALEUR, 5, 2))
         DD = val(mid$([L]VALEUR, 7, 2))  
         HFEC = gdat$(DD,MM,AA)

         WCRIT -='& ACCDAT <=[' + num$(HFEC) + ']' 

   When "divisa"
         DIVISA = [L]VALEUR
      
   When "ultreg"
         ULTREG = val([L]VALEUR)
         SW = 0

   When "orden"
         ORDEN = val([L]VALEUR)

   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next

WCRIT -='& INVTYP <  5'

Filter [SIH]
If ORDEN= 1 Then
    Filter [SIH] Where evalue (WCRIT) Order By ACCDAT;NUM Asc
Else
    Filter [SIH] Where evalue (WCRIT) Order By ACCDAT;NUM Asc
Endif
For [SIH] 
    [F:ZIV]ZADXUID = GUSER
    
    Read [BPR]BPR0 = [SIH]BPR
    If fstat = 0  Then : 
        [F:ZIV]BPRNAM = [BPR]BPRNAM 
        [F:ZIV]CRN    = [BPR]CRN        
    Endif
    
    [F:ZIV]ACCDAT = [SIH]ACCDAT
    [F:ZIV]CPY =    [SIH]CPY
    
    #If [SIH]NUM = 'FAC-BD103-00278' Then
    #    dbgmode(0) = 1 : dbgmode(1) = 1
    #Endif

    If [SIH]BASTAX(0) = 0 and [SIH]BASTAX(1) = 0  and [SIH]BASTAX(2) = 0 and [SIH]BASTAX(3) = 0 and [SIH]BASTAX(4) = 0 Then
        Read [SIV]SIV0 = [SIH]NUM
        If [SIV]INVDTAAMT(1) <> 0 Then            
                [SIH]BASTAX(0) =  [SIV]INVDTAAMT(1)
                [SIH]TAX(0) = '000'
        Endif
    Else
        [F:ZIV]BASTAX(0) =  [SIH]BASTAX(0)
        [F:ZIV]BASTAX(1) =  [SIH]BASTAX(1)
        [F:ZIV]BASTAX(2) =  [SIH]BASTAX(2)
        [F:ZIV]BASTAX(3) =  [SIH]BASTAX(3)
        [F:ZIV]BASTAX(4) =  [SIH]BASTAX(4)
    Endif

    [F:ZIV]CUR = [SIH]CUR
    [F:ZIV]SNS = [SIH]SNS

    [F:ZIV]BPRVCR = [SIH]BPRVCR

    [F:ZIV]CRY = [SIH]CRY
    
    If SW = 0 Then
        [F:ZIV]NUMREG = ULTREG
        SW = 1
    Else
        [F:ZIV]NUMREG +=1
    Endif

    [F:ZIV]TIPO = 1

    Read [TCU]TCU0 = [SIH]CUR
    If fstat = 0  Then : [F:ZIV]EURRAT = [TCU]EURRAT : Endif

    [F:ZIV]TAX(0) =  [SIH]TAX(0)
    [F:ZIV]TAX(1) =  [SIH]TAX(1)
    [F:ZIV]TAX(2) =  [SIH]TAX(2)
    [F:ZIV]TAX(3) =  [SIH]TAX(3)
    [F:ZIV]TAX(4) =  [SIH]TAX(4)
     
    [F:ZIV]AMTTAX(0) =  [SIH]AMTTAX(0)
    [F:ZIV]AMTTAX(1) =  [SIH]AMTTAX(1)
    [F:ZIV]AMTTAX(2) =  [SIH]AMTTAX(2)
    [F:ZIV]AMTTAX(3) =  [SIH]AMTTAX(3)
    [F:ZIV]AMTTAX(4) =  [SIH]AMTTAX(4)
       
    [F:ZIV]NUM =  [SIH]NUM
    
    [F:ZIV]CURTYP =  [SIH]CURTYP

     ### OBTENCION DE LA TASA DE IVA
     For K = 0 To 4   
         [F:ZIV]TANTOIVA(K) = 0
         If [SIH]TAX(K) <'010' OR [SIH]TAX(K)>'019' THEN
             If [SIH]TAX(K) = '999' Then 
                [F:ZIV]TANTOIVA(K) = 0
                Goto NOCALCULA 
             Endif    
             Read [F:TVT]TVT0 = [SIH]TAX(K)
             If fstat = 0 Then 
                 [F:ZIV]TANTOIVA(K) = [F:TVT]VATRAT 
             Else
                 [F:ZIV]TANTOIVA(K) = 0
             Endif
         Else
             [F:ZIV]TANTOIVA(K) = 0
         Endif   
     $NOCALCULA
     Next K


     ### OBTENCION DE LA TASA DE RECARGO
     For M = 0 To 4   
         [F:ZIV]TANTOREC(M) = 0
         If [SIH]TAX(M) >'009' and [SIH]TAX(M)<'020' Then
             Read [F:TVT]TVT0 = [SIH]TAX(M)
             If fstat = 0 Then 
                 [F:ZIV]TANTOREC(M) = [F:TVT]VATRAT 
             Else
                 [F:ZIV]TANTOREC(M) = 0
             Endif
#asteriscado del ELSE a [F:ZIV]
         Else
             If [SIH]TAX(M) = '999' Then 
                [F:ZIV]TANTOREC(M) = 0
                Goto NOCALCULA2 
             Endif
            [F:ZIV]TANTOREC(M) = 0
         Endif
        $NOCALCULA2
     Next M

     ### CALCULO DE LA DIVISA PARA LA BASE
     For I = 0 To 4   
         Call CONVERT2([F:SIH]CUR,DIVISA,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]BASTAX(I),MTDES,STAT) From TRTDEV  
         
          MTDES = arr(MTDES,0.01)
         [F:ZIV]BASTAX(I) = [F:SIH]SNS*MTDES           
         If ([SIH]TAX(I) > '009' and [SIH]TAX(I) < '020') or [SIH]TAX(I) = '999' Then
             [F:ZIV]BASTAX(I) = 0   
         Endif
     Next I

    
     ### CALCULO DE LA DIVISA PARA EL IVA
     For J = 0 To 4   
         [F:ZIV]IVA(J) = 0
         If [SIH]TAX(J) > '019' or [SIH]TAX(J) < '009' Then
             If [SIH]TAX(J) = '999' Then 
                [F:ZIV]IVA(J) = 0
                Goto NOCALCULA3 
             Endif
             Call CONVERT2([F:SIH]CUR,DIVISA,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTTAX(J),MTDES,STAT) From TRTDEV  

                 MTDES = arr(MTDES,0.01)

             [F:ZIV]IVA(J) = [F:SIH]SNS*MTDES
       #  Else
       #      If [SIH]TAX(J) = '999' Then : Goto NOCALCULA3 : Endif
       #      [F:ZIV]IVA(J) = 0
         Endif
      $NOCALCULA3  
     Next J

     ### CALCULO DEL RECARGO
     For L = 0 To 4   
         [F:ZIV]RECARGO(L) = 0
         If [SIH]TAX(L) > '009' and [SIH]TAX(L) < '020' Then
            If [SIH]TAX(L) = '999' Then 
                [F:ZIV]RECARGO(L) = 0
                Goto NOCALCULA4 
            Endif
             Call CONVERT2([F:SIH]CUR,DIVISA,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTTAX(L),MTDES,STAT) From TRTDEV  
     
                 MTDES = arr(MTDES,0.01)
             [F:ZIV]RECARGO(L) = [F:SIH]SNS*MTDES

         #Else
             #If [SIH]TAX(L) = '999' Then : Goto NOCALCULA4 : Endif
             #[F:ZIV]RECARGO(L) = 0
         Endif
     $NOCALCULA4
     Next L


#     ### CALCULO DEL TOTAL DE FACTURA
#     Call CONVERT2([F:SIH]CUR,DIVISA,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTATI,MTDES,STAT) From TRTDEV  
#     [F:ZIV]TOTALFAC(0)  = [F:SIH]SNS*MTDES

#xbbaf 07-11-01       
      Local Integer SW020 
      SW020 = 0
      For L = 0 To 4   
         If [SIH]TAX(L) = '020'
            SW020 = 1
         Endif
      Next   

      If SW020 = 1 
          For L = 0 To 4   
            [F:ZIV]BASTAX(L) = 0
          Next   
          
          Call CONVERT2([F:SIH]CUR,DIVISA,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTNOT,MTDES,STAT) From TRTDEV

         ### AFG REDONDEO DECIMALES INI 
             #If DIVISA = GSYSCUR
             #    MTDES = arr(MTDES,1.0)
             #Else
                 MTDES = arr(MTDES,0.01)
             #Endif
         ### AFG REDONDEO DECIMALES FIN

          [F:ZIV]BASTAX(0) = MTDES * [F:SIH]SNS

      Endif

#xbbaf 07-11-01



      [F:ZIV]TOTALFAC(0) = [F:ZIV]BASTAX(0) + [F:ZIV]BASTAX(1) + [F:ZIV]BASTAX(2) + [F:ZIV]BASTAX(3) + [F:ZIV]BASTAX(4)
&                        + [F:ZIV]IVA(0) + [F:ZIV]IVA(1) + [F:ZIV]IVA(2) + [F:ZIV]IVA(3) + [F:ZIV]IVA(4)
&                        + [F:ZIV]RECARGO(0) + [F:ZIV]RECARGO(1) + [F:ZIV]RECARGO(2) +[F:ZIV]RECARGO(3)+[F:ZIV]RECARGO(4)

      Write [ZIV]
   
Next
Commit
Call TEMPOFF From GESECRAN

End
###################################################################
$OUVRE 
  
    If clalev([F:ZIV])=0  : Local File ZIVASOP     [ZIV] : Endif 
    If clalev([F:SIH])=0  : Local File SINVOICE    [SIH] : Endif 
    If clalev([F:SIV])=0  : Local File SINVOICEV   [SIV] : Endif 
    If clalev([F:BPR])=0  : Local File BPARTNER    [BPR] : Endif 
    If clalev([F:TCU])=0  : Local File TABCUR      [TCU] : Endif 
    If clalev([F:TVT])=0  : Local File TABVAT      [TVT] : Endif 

    Call TEMPON ("") From GESECRAN
    

Return 
 
###################################################################
$DECLARE 
    Local Char    CRITERE(255), CRITSUP(100), PARAM(30) , VALEUR(30) , ETAT(15)
    Local Integer WNUMLIG
Return 

###################################################################
$INICIALIZA
    Filter [ZIV]
    Trbegin [ZIV]
# Where ZADXUID = num$(adxuid(1))
#    Read [ZIV]
 #   For [ZIV]
       Delete [ZIV] Where 1=1 
      If fstat=1   
         GOK=-1 : GLOCK="$ZIVASOP"-num$(adxuid(1))         
      Elsif fstat  
         GOK= 0   
         Call RSTA("ZIV",num$(adxuid(1))) From GLOCK   
      Endif  
      If GOK <=0    Rollback : Return : Endif 
  #  Next
 Commit

 Trbegin [ZIV]

Return 

###################################################################


