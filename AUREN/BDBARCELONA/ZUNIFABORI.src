#<AdxTL>@(#)8.0.0.0 $Revision$

######################################################################################
#------------------------------------------------------------------------------------#
# Migración : Marcamos con #MIG
#
######################################################################################


Subprog ZUNIFAB

Gosub INIT
Gosub EXEC

End
#############################
$INIT
Local Integer XQTY # variable temporal de la ctd producible
Local Decimal WQTY # ctd producible final

If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ZRO]) = 0 : Local File ZRECETAORI [ZRO] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif

Return


##########################################################
$EXEC
Local Integer XNIV     : XNIV = 0       # nivel de estructura
Local Integer XNIV2    : XNIV2 = 0      # nivel de estructura
Local Integer XQTYANT  : XQTYANT = 0    # variable ctd. producible temporal
Local Integer XQTYAHO  : XQTYAHO = 0    # variable ctd. producible temporal
Local Integer GO_OUT
Local Char XFCY
Raz XQTY, WQTY

# Abrir tabla temporal donde se agrupa  
Local File ZBOMRETORI    [ZBO]
Local File ZBOMRETORI    [ZBO2]

# Reinicia la tabla temporal 
Trbegin [ZBO]
    Delete [ZBO] Where ZUSER = GUSER     
Commit

# Guardar datos en la tabla temporal desde la tabla principal
# Agrupar por nivel, artículo padre y componente
Filter [ZRO] Where ZUSER = GUSER & NIVEST = 1 & ITMREF = [M:ZRO0]ITMREFDEB Order By Key ZRO1
Read [ZRO] First
If fstat = 0 
    XITMREF = [ZRO]ITMREF
    XBOMALT = [ZRO]BOMALT
    XNIV = 1
    XNIV2 = 1
    XFCY = [ZRO]FCY
    Gosub BUCLE2

    $BUCLE_AGAIN
    XENTRA = 1
    For [ZBO2]ZBO0 Where ZUSER = GUSER & NIVEST = XNIV and ARTINT = 2
        XITMREF = [ZBO2]CPNITMREF
        XNIV2 = XNIV + 1
        Gosub BUCLE2
    Next   
    If XENTRA = 2
        XNIV += 1
        Goto BUCLE_AGAIN
    Endif
Endif

Local Decimal WPO

# Guardar la cantidad de enlace por todos los niveles respecto a artículo original
Trbegin [ZBO]
For [ZBO]ZBO0 
    If [ZBO]NIVEST = 1
        [ZBO]CENLQTY = [ZBO]ENLQTY
        Rewrite [ZBO]
    Else
        XNIV = [ZBO]NIVEST-1
        XPADRE = [ZBO]ITMREF
        X = [ZBO]ENLQTY 

        #---> Ctd de enlace para el material según los padres de el
        $BUCLE
        Read [ZBO2]ZBO1 = XNIV;XPADRE      
        If fstat = 0           
            WPO = [ZBO2]ENLQTY * X 
            X = WPO
            XNIV -= 1 
            XPADRE = [ZBO2]ITMREF
            Goto BUCLE
        Endif

        #---> Ańadir las necesidades del mismo material para los distintos niveles 
        For [ZBO2] Where CPNITMREF = [ZBO]CPNITMREF and NIVEST < [ZBO]NIVEST   
            X += [ZBO2]ENLQTY 
        Next
        [ZBO]CENLQTY = X
        Rewrite [ZBO]
        X = 0
    Endif 
Next
Commit
Gosub ABI2
Return

#################################################################
$BUCLE2
Read [BOH]BOH0 = XITMREF;XBOMALT 
If fstat = 0
    For [BOD]BOD0 Where ITMREF=[BOH]ITMREF & BOMALT=[BOH]BOMALT
        Read [ZBO]ZBO0 = GUSER;XNIV;[BOD]ITMREF;[BOD]CPNITMREF
        If fstat <> 0 
            Trbegin [ZBO]
            [ZBO]ZUSER = GUSER
            [ZBO]NIVEST =  XNIV
            [ZBO]ITMREF =  [BOD]ITMREF
            [ZBO]CPNITMREF = [BOD]CPNITMREF
            Read [ITV]ITV0 = [BOD]CPNITMREF;XFCY
            If fstat = 0
##MIG
##                [ZBO]DISQTY = [ITV]PHYSTO - [ITV]RERSTO - [ITV]ALLSTO - [ITV]BPRSTO - [ITV]SCOSTO
                Local Decimal YRERSTO, YALLSTO,YBPRSTO
                YRERSTO=[ITV]GLOALL
                YALLSTO=([ITV]PHYALL+[ITV]CTLALL+[ITV]REJALL)
                YBPRSTO=([ITV]BPRPHYSTO+[ITV]BPRCTLSTO+[ITV]BPRREJSTO)
                YSCOSTO=([ITV]SCOPHYSTO+[ITV]SCOCTLSTO+[ITV]SCOREJSTO)
            
                [ZBO]DISQTY = [ITV]PHYSTO - YRERSTO - YALLSTO - YBPRSTO - YSCOSTO
##\MIG

            Else
                [ZBO]DISQTY = 0
            Endif
            [ZBO]ENLQTY = [BOD]LIKQTY
            [ZBO]XSEQ = [BOD]BOMSEQ
            # Flag de intermediario
            Read [ITB]ITB0 = [BOD]CPNITMREF;[BOD]BOMALT
            If fstat = 0 
                If [ITB]BOMEXIFLG = 2
                    [ZBO]ARTINT = 2
                Else 
                    [ZBO]ARTINT = 1
                Endif    
            Else 
                [ZBO]ARTINT = 1
            Endif
    
            Write [ZBO]
            Commit
       Else 
           If [BOD]BOMSEQ <> [ZBO]XSEQ 
                Trbegin [ZBO]
                [ZBO]ENLQTY += [BOD]LIKQTY
                Rewrite [ZBO]
                Commit
           Endif                               
       Endif
    Next
Endif
Return

################################################################
$ABI2

XNIV = 1 
XQTYANT = 0
XQTYAHO = 0
XFIRST = 0

# Proceso de calcular la ctd producible
Gosub CTD_PROD

Return

#################################################################
$CTD_PROD

Local Integer XFLG : XFLG = 0
Local Integer XFLG2 : XFLG2 = 0
Local Integer XIND : XIND = 0
Local Char XPADRE  : XPADRE = [ZRO0]ITMREFDEB 
Local Char TABPADRE(15)(1..10)

Close File [ZBO]
Local File ZBOMRETORI [ZBO]

$BUCLE_PRINCIPAL
While XFLG <> 1
    # Bucle para averiguar la ctd producible en el nivel actual
    $SIGUIENTE_CPN
    XIND = 0 
    For [ZBO]ZBO0 Where NIVEST = XNIV & ITMREF = XPADRE & ZUSER = GUSER #---Order By NIVEST and CPNITMREF

        XQTYAHO = int([ZBO]DISQTY / [ZBO]CENLQTY) 

        # Si la entera igual a 0 comprobar si al menos podemos producir algo 
        If XQTYAHO = 0 Then 
            XQTYAHO = int([ZBO]DISQTY / [ZBO]ENLQTY)
        Endif

        # Si un artículo de materia prima no dispone de stock -> Fin proceso
        If XQTYAHO = 0 and [ZBO]ARTINT = 1 
            XFLG = 1            
            Goto FIN_WHILE
        Else If XQTYAHO = 0 & [ZBO]ARTINT = 2
                TABPADRE(XNIV) = [ZBO]ITMREF
                XPADRE = [ZBO]CPNITMREF
                XFIRST = 0
                XNIV = XNIV + 1
                XIND = 1
                Break
             Endif
        Endif

        If XFIRST = 0
            XQTYANT = XQTYAHO
            XFIRST = 1
        Else
            If XQTYAHO >= 0 and XQTYAHO < XQTYANT
                XQTYANT = XQTYAHO
            Endif
        Endif    
        XFLG2 = 1
    Next
    
    If XFLG2 = 0
        XFLG = 1
        Goto FIN_WHILE
    Endif

    If XIND = 1
        Goto SIGUIENTE_CPN
    Endif

    # Actualizar el variable global de ctd producible
    XQTY = XQTYANT  

    # Actualizar el stock disponible de todos los niveles arrestando la ctd producible cálculada 
    # de los artículos actuales
    For [ZBO] Where NIVEST = XNIV & ZUSER = GUSER              #Order By NIVEST and CPNITMREF
        XCTD = (XQTY*[ZBO]ENLQTY)
        Trbegin [ZBO]
            If [ZBO]DISQTY > XCTD
                [ZBO]DISQTY = [ZBO]DISQTY - XCTD
            Else
                [ZBO]DISQTY = 0
            Endif
            Rewrite [ZBO]
        Commit
        
        # otros niveles 
        Filter [ZBO2] Where ZUSER = GUSER & CPNITMREF = [ZBO]CPNITMREF & NIVEST <> [ZBO]NIVEST
            For [ZBO2]
                Trbegin [ZBO2]
                    If [ZBO2]DISQTY > XCTD
                        [ZBO2]DISQTY -= XCTD
                    Else
                        [ZBO2]DISQTY = 0
                    Endif
                    Rewrite [ZBO2]
                Commit
            Next
        Filter [ZBO2]
    Next
    

    # Actualizar el stock disponible del padre de los stocks actuales ańadiendo la ctd producible
    If XNIV <> 1
        XNIV = XNIV - 1
        Read [ZBO]ZBO0 = GUSER;XNIV;TABPADRE(XNIV);XPADRE
        If fstat = 0
            XPADRE = TABPADRE(XNIV)
            Trbegin [ZBO]
            [ZBO]DISQTY += XQTY
            Rewrite [ZBO]
            Commit
        Endif
    Else
        WQTY += XQTY
    Endif
    $FIN_WHILE
Wend

# Infbox "Se puede fabricar :"+ num$(WQTY)+" del artículo: AL00671 " 

Filter [ZRO] Where ZUSER=GUSER & NIVEST=1 & ITMREF=[M:ZRO0]ITMREFDEB Order By Key ZRO0
Read [ZRO] First
If fstat = 0
    Trbegin [ZRO]
    [F:ZRO]UNIFAB = WQTY
    Rewrite [ZRO]
    Commit
Endif

Return
        



