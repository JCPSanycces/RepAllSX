#############################################################################################


Subprog ZIMPORTPROVE
    Gosub OUVRE
    Gosub BUSQUEDA
End


$OUVRE

If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif

Global Char TEXTE(200)
Global Char TEXTREN (200)
Global Char FICTRA(GDIMFIC)

Global Char FICTRAI(GDIMFIC)
Global Char FICTRAE(GDIMFIC)

Local Integer ETABOU(1..GNBBOU)
Local Integer REPONSE

Local Integer QTY
Local Char INVTYP,LIG,ANALIG,INDT,INDL,INDA,INDE,PAM1,SOI1,PAM2,SOI2,PAM3,SOI3
Local Char NUM,BPR,BPRSAC,CPY,FCY,ACCDAT,CUR,BPRDAT,BPRVGR,PTE,VAC
Local Char FCYLIN,SAC,ACC,BPRLIN,AMTNOTLIN,VAT,CCE,CCE1,CCE2,CNA,AMT,UOM
Local Char DUDLIG1,DUDDAT1,AMTCUR1,DUDLIG2,DUDDAT2,AMTCUR2,DUDLIG3,DUDDAT3,AMTCUR3

#########################################################################
$BUSQUEDA

Local Char SAVIFS(10) , SAVIRS(10)
Local Char LIGNE (255),A,F,B(250), MENSAJE(250)
Local Integer I
Global Char TEXTE (200)
Local Char ARRAY(15)(10000)

FICTRA = filpath("import","CarteraProv","txt",0)
Openo FICTRA,0 Using [FICE]    

FICTRA = filpath("import","CarteraProv","csv",0) # === Directori i extensio on volem recollir el fitxer
Openi FICTRA,0 Using [FICI]

adxifs = ";"                # ============= Separador de camp
adxirs = chr$(10)           # ============= Separador de registre

fstat = 0

I=0
Repeat
    Rdseq LIGNE Using [FICI]
    If LIGNE = chr$(13) Then
        Gosub GRABA
        Raz I
        Raz ARRAY
        fstat = 0   
    Else
        ARRAY(I) = LIGNE
        I+=1
    Endif
Until fstat

Openi Using [FICI]
Openo Using [FICE]
Return

#########################################################################
$GRABA

## T
    INDT = "T"
    INVTYP = ARRAY(0)
    NUM = ARRAY(5)+"-"+ARRAY(1)
    BPR = ARRAY(2)
    BPRSAC =ARRAY(3)
    CPY = ARRAY(4)
    FCY = ARRAY(5)
    ACCDAT= ARRAY(6)
    CUR = ARRAY(7)
    BPRDAT = ARRAY(8)
    BPRVCR = ARRAY(9)
    PTE = ARRAY(10)
    VAC = ARRAY(11)

## L    
    INDL = "L"
    LIG = "1"
    FCYLIN = FCY
    SAC = BPRSAC
    ACC = ARRAY(12)
    BPRLIN = BPR
    AMTNOTLIN = ARRAY(13)
    VAT = ARRAY(14)

## A    
    INDA = "A"
    ANALIG = "1"
    CCE = ARRAY(15)
    CCE1 = ""
    CCE2 = ""
    CNA = ACC
    AMT = AMTNOTLIN
    UOM = ""
    QTY = 0

## E    
    INDE = "E"
    DUDDAT1 = ARRAY(16)
    AMTCUR1 = ARRAY(17)
    Read [F:TPT]TPT0 = PTE;1
    If fstat = 0 Then :  PAM1 = [TPT]PAM : Endif
    SOI1 = "1"

##    DUDDAT2 = ARRAY(18)
##    AMTCUR2 = ARRAY(19)
##    Read [F:TPT]TPT0 = PTE;2
##    If fstat = 0 Then :  PAM2 = [TPT]PAM : Endif
##    SOI2 = "1"

##    DUDDAT3 = ARRAY(20)
##    AMTCUR3 = ARRAY(21)
##    Read [F:TPT]TPT0 = PTE;3
##    If fstat = 0 Then :  PAM3 = [TPT]PAM : Endif
##    SOI3 = "1"

    Gosub ESCRIBE
Return

#########################################################################
$ESCRIBE
## T
Wrseq INDT; Using [FICE]
Case INVTYP
    When "1" :  Wrseq "FAC" ; Using [FICE]
    When "2" :  Wrseq "ABO" ; Using [FICE]
    When "3" :  Wrseq "DEB" ; Using [FICE]
    When "4" :  Wrseq "CRE" ; Using [FICE]
Endcase
Wrseq NUM; Using [FICE]
Wrseq BPR; Using [FICE]
Wrseq BPRSAC; Using [FICE]
Wrseq CPY; Using [FICE]
Wrseq FCY; Using [FICE]
Wrseq ACCDAT; Using [FICE]
Wrseq CUR; Using [FICE]
Wrseq BPRDAT; Using [FICE]
Wrseq BPRVCR; Using [FICE]
Wrseq PTE; Using [FICE]
Wrseq VAC; Using [FICE]

Wrseq chr$(13) Using [FICE]

## L
Wrseq INDL; Using [FICE]
Wrseq LIG; Using [FICE]
Wrseq FCYLIN; Using [FICE]
Wrseq SAC; Using [FICE]
Wrseq ACC; Using [FICE]
Wrseq BPRLIN; Using [FICE]
Wrseq AMTNOTLIN; Using [FICE]
Wrseq VAT; Using [FICE]

Wrseq chr$(13) Using [FICE]


## A
If CCE <> "" Then
    Wrseq INDA; Using [FICE]
    Wrseq ANALIG; Using [FICE]
    Wrseq CCE; Using [FICE]
    Wrseq CCE1; Using [FICE]
    Wrseq CCE2; Using [FICE]
    Wrseq CNA; Using [FICE]
    Wrseq AMT; Using [FICE]
    Wrseq UOM; Using [FICE]
    Wrseq QTY; Using [FICE]

    Wrseq chr$(13) Using [FICE]
Endif

## E
    If DUDDAT1 <> "" Then
        Wrseq INDE; Using [FICE]
        Wrseq "1"; Using [FICE]
        Wrseq DUDDAT1; Using [FICE]
        Wrseq AMTCUR1; Using [FICE]
        Wrseq PAM1; Using [FICE]
        Wrseq SOI1; Using [FICE]
        Wrseq chr$(13) Using [FICE]
    Endif

##    If DUDDAT2 <> "" Then
##        Wrseq INDE; Using [FICE]
##        Wrseq "2"; Using [FICE]
##        Wrseq DUDDAT2; Using [FICE]
##        Wrseq AMTCUR2; Using [FICE]
##        Wrseq PAM2; Using [FICE]
##        Wrseq SOI2; Using [FICE]
##        Wrseq chr$(13) Using [FICE]
##    Endif

##    If DUDDAT3 <> "" Then
##        Wrseq INDE; Using [FICE]
##        Wrseq "3"; Using [FICE]
##        Wrseq DUDDAT3; Using [FICE]
##        Wrseq AMTCUR3; Using [FICE]
##        Wrseq PAM3; Using [FICE]
##        Wrseq SOI3; Using [FICE]
##        Wrseq chr$(13) Using [FICE]
##    Endif


Return


#########################################################################
Subprog GENERA_FICHERO

Local Integer NUMIMP, ER
Local Char    SAVIFS(10) , SAVIRS(10)

SAVIFS = adxifs
SAVIRS = adxirs

FICTRA = filpath("txt","Import","txt",0)

#adxifs = chr$(59)                 # ============= Separador de camp
adxirs = chr$(13)+chr$(10)                      # ============= Separador de registre
adxirs = chr$(59)

Wrseq TEXTE Using [FICE]         # ============= Escritura en el fitxer
        
#GLTRACE   = len(TEXTE)+1
GERRTRACE = 0
adxifs    = SAVIFS
adxirs    = SAVIRS
Return
