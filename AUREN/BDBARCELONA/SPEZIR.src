#<AdxTL>@(#)201.0.0.0 $Revision:   1.8  $
$ACTION
Case ACTION
    When "LIENS"          : Gosub LIENS
    When "CREATION"       : Gosub CREATION
    When "MODIF"          : Gosub MODIF

    When Default
Endcase

Return

$LIENS
# Carga de tabla de Royalties (tableau)
    Raz [M:ZIR]
    nolign = 0
    For [ZIR] Where ITMREF = [M:ZITH]ITMREF
     nolign += 1
     [M:ZIR] = [F:ZIR]
    Next 
    [M:ZIR]NBZIR  = nolign 
    # Si existen lineas cargamos el primer registro
    If [M:ZIR]NBZIR > 0
     [M:ZIR]XITMREFBPS         = [M:ZIR]ITMREFBPS(0)
     [M:ZIR]XITMDESBPS         = [M:ZIR]ITMDESBPS(0)
     [M:ZIR]XPORCEN            = [M:ZIR]PORCEN(0)

    Endif 

Return


$CREATION
    Gosub SUBCREMOD
Return

$MODIF
   Delete [ZIR] Where ITMREF = [M:ZITH]ITMREF
   Gosub SUBCREMOD
Return

$SUBCREMOD
 For  nolign = 1 To [M:ZIR]NBZIR
   [F:ZIR] = [M:ZIR]
   [F:ZIR]ITMREF    = [F:ITM]ITMREF
   [F:ZIR]ITMREFBPS         = [M:ZIR]ITMREFBPS(nolign-1)
   [F:ZIR]ITMDESBPS         = [M:ZIR]ITMDESBPS(nolign-1)
   [F:ZIR]PORCEN            = [M:ZIR]PORCEN(nolign-1)
   Write [ZIR]
   If fstat 
    GOK = 0 : Call FSTA("ZIR") From GLOCK : Break 
   Endif 
 Next nolign 
 
Return


########################################
Subprog AS_NBZIR
Local Integer NOL
NOL = nolign-1
[M]XNUMLIG = nolign-1
     [M:ZIR]XITMREFBPS         = [M:ZIR]ITMREFBPS([M]XNUMLIG)
     [M:ZIR]XITMDESBPS         = [M:ZIR]ITMDESBPS([M]XNUMLIG)
     [M:ZIR]XPORCEN            = [M:ZIR]PORCEN([M]XNUMLIG)

Affzo [M:ZIR]XITMREFBPS
Affzo [M:ZIR]XITMDESBPS
Affzo [M:ZIR]XPORCEN

End

######################################## 
Subprog C_NBZIR 
Local Integer WRETOUR
End 


Subprog C_BPSNUM(VALEUR)
Variable Char     VALEUR
Local Integer NOL

Call UNICITE(VALEUR,[M]BPSNUM(0..NBZIR-1)) From OBJDIV
If mkstat : End : Endif
NOL = nolign -1
End


Subprog AM_XITMREFBPS(VALEUR)
Variable Char VALEUR
[M]ITMREFBPS([M]XNUMLIG) = VALEUR
End

Subprog AM_XITMDESBPS (VALEUR)
Variable Char VALEUR
[M]ITMDESBPS([M]XNUMLIG) = VALEUR
End


Subprog AP_BPSNUM(VALEUR)
Variable Char VALEUR
End

########################################
Subprog APRES_NBZIR
# Spécifique à l'import --> Recharger indice pour sortir de la boucle de saisie 
If GIMPORT indice = [M]NBZIR -1 Endif
End

########################################
Subprog AP_NBZIR
End

########################################
Subprog AM_XPORCEN(VALEUR)
Variable Decimal VALEUR
    [M]PORCEN([M]XNUMLIG) = VALEUR
End

