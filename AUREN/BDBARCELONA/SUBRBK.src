#<AdxTL>@(#)6.0.0.0 $Revision:   1.13  $
######################################################################################################
#                                                                                                    #
# CACT    Descripción                                           Fecha         Autor                  #
# ---------------------------------------------------------------------------------------------------#
# PEM     Llama a una función para convertir los ficheros de                                         #
#         importación de extractos bancarios al formato espańol 01-05-02      Pedro Escudero(Infolan)#
# ZIM     REVISADO PARA MIGRACION V5
#                                                                                                    #
######################################################################################################
#
#Mai 1998 revu le 9 Juin

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBRBK","FRELBAN",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub INIT
 When "EXEC"        : Gosub EXEC
Endcase
Return


$INIT
If clalev([F:TFB])=0  : Local File TABFILBAN    [TFB] : Endif
If clalev([F:RBK])=0  : Local File RELBANK      [RBK] : Endif
If clalev([F:RBKK])=0 : Local File RELBANK     [RBKK] : Endif
If clalev([F:TCU])=0  : Local File TABCUR       [TCU] : Endif
If clalev([F:CPY])=0  : Local File COMPANY      [CPY] : Endif
If clalev([F:BAN])=0  : Local File BANK         [BAN] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF    [TCA] : Endif
## POR,SPA
If !clalev([F:AVC])   : Local File ACTIV        [ACV] : Endif
Global Integer RBKPOR , RBKSPA : Raz [V]RBKPOR , [V]RBKSPA
Local Integer OK

Read [ACV]CODACT="KPA"
If !fstat & [F:ACV]FLACT=2
 Call EXISTE_ADX("","","SUBRBKPOR",OK) From ORDSYS
 If OK : [V]RBKPOR=1 : Endif
Endif

Read [ACV]CODACT="KSB"
If !fstat & [F:ACV]FLACT=2
 Call EXISTE_ADX("","","SUBRBKSPA",OK) From ORDSYS
 If OK : [V]RBKSPA=1 : Endif
Endif
##
TMP = 1
TRA = 1
Return


$INIT_DIA
Raz [M:DIA]
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Integer OK
Local Char    PARAM1(30)

Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
If OK
 If MACHIN<>""
  [M:DIA]FILNAM = MACHIN+"@"
 Endif
 [M:DIA]FILNAM += DIR_FICBAN

 If OS="unix"
  [M:DIA]FILNAM += "/"+GDIRBQR
 Else
  [M:DIA]FILNAM += "\"+GDIRBQR
 Endif
Else
 [M:DIA]FILNAM = filpath(GDIRBQR,"","")
Endif

#DBA le 13/08/03 :Récupération paramčtre "Fichier bancaire par défaut"
Call PARAMUTIL("FILBANKDEF",PARAM1,"","") From SUBAUS
If PARAM1<>""
 [M:DIA]NOMFIC = PARAM1
Else
 [M:DIA]NOMFIC ="RELBAN"    :#Par sécurité (historique X3)
Endif
#

# Variables pour Poste Client
Local Char URL(GDIMFIC)
Local Integer STAT
Return

$EXEC
If [M]TYPEXP=1 : # Client
 Call SET_FICNAM([M:DIA]FILNAM,[M:DIA]FICDON,URL) From ORDSYS
 Call COPSRV([M:DIA]FILNAM,[M:DIA]FICDON,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Endif
Else
 [M:DIA]FICDON = [M:DIA]FILNAM
Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(12,120,1)-[M:DIA]FILNAM) From LECFIC : #Importation du fichier
Endif

#DBA le 13/08/03 : Ajout point d'entrée pour l'espagne
GPOINT = "RBKIMP" : Gosub ENTREE From EXEFNC

#PEMai
############# PUNTO DE ENTRADA PARA ESPAŃA ###################################
If GPAYS = "ES"
    Call SPRELBAN From SPRELBAN
Endif
##############################################################################
#PEMaf

If !GPE
 ## POR,SPA
 If [V]RBKPOR
  Gosub RBKIMP From SUBRBKPOR
 Elsif [V]RBKSPA
  Call SPRELBAN From SUBRBKSPA
 Endif
 If !GPE
  Call IMPRBK([M:DIA]FICDON,[M:DIA]BAN) From SUBRBK
 Endif
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


###########################################################################
Subprog IMPRBK(FICHIER,BANQUE)
###########################################################################
Variable Char FICHIER()
Variable Char BANQUE()

Gosub DECLARE

Call MACHINE(FICHIER,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS        = chr$(10)
                SEP_CHEMIN = "/"
 When Default : IRS        = chr$(13)+chr$(10)
                SEP_CHEMIN = "\"
Endcase

POS1 = 1
POS2 = 0
Repeat
 POS2 = instr(POS1,FICHIER,SEP_CHEMIN)
 If POS2>=POS1 : POS1 = POS2+1 : Endif
Until !POS2
FIC = right$(FICHIER,POS1)

COK=1

#DBA le 18/08/03 : En espagne comme au portugal, il n'ont pas d'enreg. de type Sous-Total.
#Donc au lieu d'imposer une entęte + un détail + un total + un sous-total
#on impose uniquement la présence d'une entęte + un détail + un total.
For I = 1 To 4
 Read [TFB]TFB0 = [M:DIA]NOMFIC;"";I       
 If fstat 
  If I<>4  
   COK = 0 : Break
  Else 
   NBRECTYP=3 : Break
  Endif
 Else
  RECTYP(I) = [F:TFB]FRM
 Endif
Next I
If NBRECTYP=3
 # XYZ : Pas d'enregistrement Sous-total
 Call ECR_TRACE([M:DIA]NOMFIC-":"-mess(65,120,1),0) From GESECRAN
Endif
If !COK
 # Problčme paramétrage fichier bancaire
 Call ECR_TRACE(mess(155,117,1)-[M:DIA]NOMFIC,1) From GESECRAN
 End
Endif

For [TFB]TFB0 Where COD=[M:DIA]NOMFIC & BAN="" & RECTYP=1
 LONG += [F:TFB]LNG : #Longueur d'un champ
Next
Local Schar CHAMP(LONG)
Gosub IMPORTATION
End



$DECLARE
#CHAMP est un enregistrement du fichier texte
#RG parcourt la variable champ pour extraire chaque zone
#LIN_REL est un numéro de ligne chrono par numéro de relevé
#NBR indique qu'il y a eu au moins un relevé importé
#MAJCHRONO indique s'il faut incrémenter le numéro de relevé
#COK=-1 ligne de relevé pas bonne
#COK=0 ligne de relevé pas bonne et transaction commencée
#COK=1 ligne de relevé bonne et transaction commencée
Local Char    IMPBQE(5), IMPGUI(5), IMPDEC(1), OLDRIB(21), NEWRIB(21)
Local Schar   CTEST(1)
Local Char    NOCOMP(15),FIC(GDIMFIC)
Local Decimal IMPMONT, OLD_SOLDE, TOT_MVT
Local Integer I, J, K, RG, COK, LIN_REL, STAT, FIN, NBR, LONG
Local Integer MAJCHRONO, POS1, POS2, TRANSAC, TEM, ENREGOK
Local Char    COMPTREG(3)

Local Char    IMPCOI(4)

#DBA le 18/08/03 : Sugg 16526
Local Integer LNGBQE ,LNGGUI, LNGCPT

#DBA le 18/08/03 :Type d'enreg sous-totaux pour espagne et portugal
#Local Char RECTYP(2)(1..4)
Local Integer NBRECTYP
NBRECTYP=4
Local Char RECTYP(2)(1..NBRECTYP)    

Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Char    SEP_CHEMIN(1)                        : # Séparateur chemin ( / ou \ )
Local Char    DIR_FIC(GDIMFIC)                     : # Chemin sans nom machine
Local Integer DBL                                  : # DBL=1 si relevé déjŕ importé 

## <PP 24/10/02> Gestion des enregsitrements complémentaires 05 :intrégration du
## développement d'Emmanuel LATOUR
Local Char    PARAM1                               : # Variable pour lecture des paramčtres non alphanum.
Local Libelle LOAD05                               : # Indic. de chargement des commentaires
Local Integer REM_REL                              : # Compteur des commentaires chargés
# Récupération paramčtre "Gestion des commentaires des relevés bancaires"
Call PARAM("","RELBANKREM",PARAM1) From ADOVAL
LOAD05 = evalue("PARAM1='2'")
If LOAD05
 If clalev([F:RBR])=0  : Local File RELBANKREM   [RBR] : Endif
Endif

Return


$IMPORTATION
Raz J,K, OLD_SOLDE, TOT_MVT, NBR

#Positionnement sur la premičre ligne valide
Openi FICHIER,0
Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST
Wend

#Test si séparateur d'enregistrement
Openi FICHIER,J
Gosub LECTURE
Gosub LECTEST
K = 0
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend
Openi FICHIER,J
Local Schar CHAMP(K+LONG)

#Traitement du fichier
MAJCHRONO = 0
Raz OLDRIB
Gosub LECTURE
While !fstat
 RG = 1
 COK = 1
 ENREGOK = 1
 NOCOMP = [F:RBK]RBKNUM
 Raz [F:RBK]
 [F:RBK]RBKNUM = NOCOMP
 [F:RBK]ORI = 1
 If !find(left$(CHAMP,2),RECTYP(1..NBRECTYP))
  Call TRACE(left$(CHAMP,2),mess(4,120,1),[0/0/0]) From SUBRBK
  #Code enregistrement inexistant
  COK = -1
 Else
  Gosub CALCRIB
  If ![L]TRANSAC :# Pas de transaction en cours
   Trbegin [RBK]
   [L]TRANSAC = 1
   FIN        = 0
   LIN_REL    = 1
   REM_REL    = 0
   OLDRIB     = NEWRIB
   MAJCHRONO  = 1
  Else
   If OLDRIB <> NEWRIB
    # RIB différent
    Call TRACE(mess(51,120,1),NEWRIB,[0/0/0]) From SUBRBK
    COK = 0
   Endif
  Endif
  If COK=1
   Case left$(CHAMP,2)
    When RECTYP(1) : Gosub TRTENTETE
    When RECTYP(2) : Gosub TRTDETAIL
    When RECTYP(3) : Gosub TRTTOTAL
    When RECTYP(4) : Gosub TRTCOMP
   Endcase
  Endif
 Endif

 # <PP 24/10/02> Intrégration développement Emmanuel LATOUR : Ecriture des enregistrements de type 05 
 # dans la table des commentaires des relevés de comptes bancaires
 If left$(CHAMP,2)=RECTYP(4) & LOAD05
  [F:RBK]NUMRBK = uniqid([F:RBK])  # Bug 22737
  Write [RBR]
  If fstat
   GOK = 0 : Call FSTA("RBR") From GLOCK : Goto ROLL_RBK
  Endif
  REM_REL+=1
 Endif
 ##<Fin PP>

 If ENREGOK
  If COK=1
   If MAJCHRONO=1
    COMPTREG = ""
    Call LECTURE("TCA","3","") From CONTOBJ
    If !fstat : COMPTREG = [F:TCA]CODNUM(5) : Endif
    If COMPTREG="" : COMPTREG = "RBK" : Endif
    ## <PP 24/07/03> Bug 18971
    #Call NUMERO(COMPTREG,"",datesyst,"",[F:RBK]RBKNUM,STAT) From SUBANM
    Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
    Call NUMERO(COMPTREG,[F:CPY]MAIFCY,datesyst,"",[F:RBK]RBKNUM,STAT) From SUBANM
    If STAT | GOK<1
     # Problčme lors de la récupération du compteur
     MESSA = COMPTREG
     Call ECR_TRACE(mess(60,199,1)-MESSA,1) From GESECRAN : Goto ROLL_RBK
    Endif
    ## <Fin PP>
    MAJCHRONO = 0
   Endif
   [F:RBK]RBKLIN = LIN_REL
   [F:RBK]NUMRBK = uniqid([F:RBK])  # Bug 22737
   Write [RBK]
   If fstat
    GOK = 0 : Call FSTA("RBK") From GLOCK : Goto ROLL_RBK
   Endif
   LIN_REL +=1
   # <PP 23/07/2002> Ajout point d'entrée LIGNE pour la tréso  
   GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC
   If GOK<1 : Goto ROLL_RBK : Endif
   Gosub LECTURE
  Endif
  If COK<1
   If COK=0 : Gosub ROLL_RBK : Endif
   Repeat : #Saut jusqu'au prochain rib
    Gosub LECTURE
    # <PP 18/07/02> Bug 14215 : report modif EL
    #If !fstat : Gosub CALCRIB : Endif
   #Until (find(left$(CHAMP,2),RECTYP(1),RECTYP(2)) & NEWRIB<>OLDRIB) | fstat
    If !fstat & !DBL : Gosub CALCRIB : Endif
   Until (!DBL & find(left$(CHAMP,2),RECTYP(1),RECTYP(2)) & NEWRIB<>OLDRIB) |
&         (DBL & find(left$(CHAMP,2),RECTYP(1))) | fstat
    ## <Fin PP>
  Endif
 #Les lignes d'un RIB se terminent par une ligne Total 03
  If [F:RBK]RECTYP=3 & !FIN
   Commit
   [L]TRANSAC = 0
   NBR = 1
   If !REM_REL
    # lignes importées du relevé N°
    Call TRACE(num$(LIN_REL-1)-mess(14,120,1),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Else
   # lignes et commentaires importés du relevé N°
   Call TRACE(num$(LIN_REL-1)-tolower(mess(7,105,1))+","-num$(REM_REL)-tolower(mess(61,120,1)),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Endif
  Endif
 Else
  Gosub LECTURE
 Endif
Wend
If [L]TRANSAC  :# Transaction en cours
 Gosub ROLL_RBK
 # Pas d'enregistrement total
 Call ECR_TRACE(mess(52,120,1),0) From GESECRAN
Endif
If !NBR
 Call ECR_TRACE(mess(8,120,1),0) From GESECRAN
 #Pas de relevé ŕ importer
Endif
Return

$ROLL_RBK
Rollback
[L]TRANSAC = 0
FIN = 1
Return


$LECTURE
Getseq 1, CHAMP
If mid$(CHAMP,len(CHAMP),1)="" : fstat = 4 : Endif
Return


$LECTEST
Getseq 1, CTEST
Return


$TRTENTETE
DBL = 0  : # initialisation du témoin de recyclage 
# TRESO -- Fiche 62-13/09/02-GB -
Raz OLD_SOLDE,TOT_MVT  # initialisation de l'ancien solde et du total mouvement
# TRESO -- Fin ------------------

Call FILTRE(1) From SUBRBK
[F:RBK]RECTYP = 1
Gosub TRTCOMMUN
Filter [TFB]
OLD_SOLDE = [F:RBK]AMTCUR * [F:RBK]SNS

If COK = 1
 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=3 & OPEDAT <= [F:RBK]OPEDAT &
&                      CUR=[F:RBK]CUR
 Read [RBKK]RBK1 Last
 Filter [RBKK]
 If !fstat & [F:RBKK]AMTCUR <> [F:RBK]AMTCUR
  # L'ancien solde ne correspond pas au solde précédent
  Call TRACE(mess(11,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
  #COK = 0 : Return : # PP 22/07/02 Vu avec SVLE On importe quand męme le relevé Bugs 15186, 14209
 Endif

 If !fstat & [F:RBKK]OPEDAT <> [F:RBK]OPEDAT
  # Date ancien solde ne correspond pas au relevé précédent
  Call TRACE(mess(60,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
  #COK = 0 : Return: # PP 22/07/02 Vu avec SVLE On importe quand męme le relevé
 Endif

 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=1 & OPEDAT=[F:RBK]OPEDAT &
&                    CUR=[F:RBK]CUR & AMTCUR=[F:RBK]AMTCUR
 Read [RBKK]RBK1 First
 Filter [RBKK]
 If !fstat
  # Relevé déjŕ importé No
  Call TRACE(mess(10,120,1),mess(49,120,1)-num$([F:RBKK]RBKNUM)-[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
  DBL = 1 : COK = 0 : Return
 Endif
Endif
Return


$TRTCOMMUN
#DBA le 18/08/03 : Sugg 16526 : ajout affection des variables LNG*
[F:RBK]CHK = ""
[F:RBK]DATCHK=[0/0/0]
[F:RBK]SNS=0
COK=1
For [TFB]TFB0
 #DBA le 19/08/03 : Ajout points d'entrée pour l'espagne/ le portugal
 Gosub CTR_FRM
 If COK=1
  Case [F:TFB]FRM                                      
  When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG) : LNGBQE=[F:TFB]LNG
  When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG) : LNGGUI=[F:TFB]LNG
  When "DEVISE"
   Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
  When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
  When "COMPTE"  : LNGCPT =[F:TFB]LNG : Gosub LECBANK
  When "DTSOLDE"
   Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
  When "MTSOLDE"
   Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
  When "DTXTR"
    Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]DATXTR) From SUBRBK
  Endcase
  Gosub MAJ_FRM
  RG +=[F:TFB]LNG
 Endif
 If COK=0 : Break : Return : Endif
Next
Return


$TRTDETAIL
#DBA le 18/08/03 : Sugg 16526 : ajout affection des variables LNG*
Call FILTRE(2) From SUBRBK
[F:RBK]RECTYP = 2
For [TFB]TFB0(4)
 For [TFB]TFB0
  #DBA le 19/08/03 : Ajout points d'entrée pour l'espagne/ le portugal
  Gosub CTR_FRM  
  Case [F:TFB]FRM
   When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG): LNGBQE=[F:TFB]LNG
   When "COI"     : IMPCOI = mid$(CHAMP,RG,[F:TFB]LNG) : # <PP 23/07/02> Report modif EL
   When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG): LNGGUI=[F:TFB]LNG
   When "DEVISE"
    Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
   When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
   When "COMPTE"  : LNGCPT=[F:TFB]LNG : Gosub LECBANK
   When "CIB"     : [F:RBK]BANCIB = mid$(CHAMP,RG,[F:TFB]LNG)
   When "REJET"   : [F:RBK]RENREJ = mid$(CHAMP,RG,[F:TFB]LNG)
   When "LIBEL"   : [F:RBK]DES    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "NO"      : [F:RBK]ENTNUM = mid$(CHAMP,RG,[F:TFB]LNG)
   When "IEXO"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDCOM = 1 : Endif 
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDCOM = 2 : Endif 
   When "IIND"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDUVY = 1 : Endif
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDUVY = 2 : Endif
   When "REF"     : [F:RBK]REF    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "MONTANT"
    Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
    If [F:RBK]AMTCUR = 0 
     [F:RBK]CHK = "*"
     [F:RBK]DATCHK=date$
    Else
     [F:RBK]CHK = ""
     [F:RBK]DATCHK=[0/0/0]
    Endif
   When "DTOPE"
    Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
   When "DTVAL"
    Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]VALDAT) From SUBRBK
  Endcase
  Gosub MAJ_FRM
  RG +=[F:TFB]LNG
  If COK=0 : Break 2 : Endif
 Next
 TOT_MVT = TOT_MVT + ([F:RBK]AMTCUR * [F:RBK]SNS)
Next
Filter [TFB]
If LOAD05
 Raz [F:RBR]REMNUM
Endif
Return


$MAJ_FRM
# Demande 17420
GPE = 0
GPOINT="MAJFRM" : Gosub ENTREE From EXEFNC
If GPE : End : Endif
Return

#DBA le 19/08/03 : Ajout point d'entrée pour l'espagne/ le portugal
$CTR_FRM
GPE = 0
GPOINT="CTRFRM" : Gosub ENTREE From EXEFNC
If GPE : End : Endif
Return

#DBA le 19/08/03 : Ajout point d'entrée pour l'espagne/ le portugal
$SNS_FRM
GPE = 0
GPOINT="SNSFRM" : Gosub ENTREE From EXEFNC
If GPE : End : Endif
## POR
If [V]RBKPOR
 Gosub SNSFRM From SUBRBKPOR
 If GPE : End : Endif
Endif
Return


$TRTTOTAL
Call FILTRE(3) From SUBRBK
[F:RBK]RECTYP = 3
Gosub TRTCOMMUN
Filter [TFB]
If (OLD_SOLDE + TOT_MVT) <> [F:RBK]AMTCUR * [F:RBK]SNS
 Call TRACE(mess(13,120,1),[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
 #Nouveau solde <> Ancien solde + Total des mouvements
 COK = 0
Endif
Raz OLD_SOLDE,TOT_MVT
Return


$TRTCOMP
ENREGOK = 0
If !LOAD05
 If TEM=0
  # Filtrage d'enregistrements complémentaires : 05
  Call TRACE(mess(57,120,1),left$(CHAMP,2),[0/0/0]) From SUBRBK
  TEM = 1
 Endif
Else
 # <PP 24/10/02> Intégration développement Emmanuel LATOUR : Ecriture dans RELBANKREM...
 [F:RBR]RBKNUM = [F:RBK]RBKNUM
 [F:RBR]BAN    = [F:BAN]BAN
 [F:RBR]RBKLIN = LIN_REL-1
 [F:RBR]REMNUM +=1
 Raz [F:RBR]REM
 Call FILTRE(4) From SUBRBK
 For [TFB]TFB0
  Case [F:TFB]FRM
   When "REM"     : [F:RBR]REM = mid$(CHAMP,RG,[F:TFB]LNG)
  Endcase
  RG +=[F:TFB]LNG
 Next
 Filter [TFB]
Endif
Return


$LECBANK
#DBA le 18/08/03 : Sugg 16526 : Utilisation des variables LNG*
#ŕ la place des chiffres 5,5 et 11 en dur.
#Traitement du rib 
Raz [F:BAN]
Filter [BAN] Where mid$(BIDNUM,1,LNGBQE)=IMPBQE &
&                  mid$(BIDNUM,LNGBQE+1,LNGGUI)=IMPGUI &
&                  mid$(BIDNUM,LNGBQE+LNGGUI+1,LNGCPT)=mid$(CHAMP,RG,[F:TFB]LNG)
COK = 0
For [BAN]BAN0 
 If ([F:BAN]BAN=[M:DIA]BAN) | [M:DIA]BAN=""
  If [F:BAN]CUR=""
   Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
   [F:BAN]CUR = [F:CPY]ACCCUR : # GH 22/03/01 bug 8511 
  Endif
  If ([F:BAN]CUR=[F:RBK]CUR) | [F:RBK]CUR=""
   [F:RBK]BAN = [F:BAN]BAN
   [F:RBK]CUR = [F:BAN]CUR
   COK = 1
   Break
  Else COK=-1
  Endif
 Elsif COK=0 : COK=-2
 Endif
Next
Filter [BAN]
If COK = 0
 Call TRACE(mess(5,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
 #Rib du relevé inexistant dans fichier BANK
Elsif COK<>1
 If COK=-1
  Call TRACE(mess(6,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Devise banque différente de la devise du relevé
 Elsif COK=-2
  Call TRACE(mess(50,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Relevé d'une autre banque
 Endif
 COK=0
Endif
If val(IMPDEC)=0
 If [F:RBK]CUR<>[F:TCU]CUR
  Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
 Endif
 If [F:TCU]DECNBR<>0 : IMPDEC=num$([F:TCU]DECNBR) : Endif
Endif
Return


$CALCRIB
RANG = 1
Raz NEWRIB
Case left$(CHAMP,2)
 When RECTYP(1) : Call FILTRE(1)
 When RECTYP(2) : Call FILTRE(2)
 When RECTYP(3) : Call FILTRE(3)
 When RECTYP(4) : Call FILTRE(4)
Endcase
For [TFB]TFB0
 Case [F:TFB]FRM
  When "BANQUE"  : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG)
  When "GUICHET" : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG)
  When "COMPTE"  : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG) : Break
 Endcase
 RANG +=[F:TFB]LNG
Next
Filter [TFB]
Return

################################################################################
Subprog FILTRE(RT)
Value Integer RT
Read [TFB]TFB0=[M:DIA]NOMFIC;[M:DIA]BAN;RT
If !fstat
 Filter [TFB] Where COD=[M:DIA]NOMFIC & BAN=[M:DIA]BAN & RECTYP=RT
Else
 Read [TFB]TFB0=[M:DIA]NOMFIC;"";RT
 Filter [TFB] Where COD=[M:DIA]NOMFIC & BAN="" & RECTYP=RT
Endif
End

Subprog DEV(ISODEV,DEV,COK)
Value Char ISODEV()
Variable Char DEV()
Variable Integer COK
If ISODEV<>"   " : #3 espaces et non la chaine vide
 Filter [TCU] Where ISOCOD=ISODEV
 For [TCU]
  DEV = [F:TCU]CUR
 Next
 If fstat
  Call TRACE(mess(7,120,1),ISODEV,[0/0/0]) From SUBRBK
  #Pas de devise associée ŕ la devise iso du relevé
  COK = 0
 Endif
 Filter [TCU]
Endif
End

Subprog DAT(CHP,DAT)
Value Char CHP()
Variable Date DAT
DAT=mid$(CHP,5,2)+mid$(CHP,3,2)+mid$(CHP,1,2)
End

Subprog MT(CHP,VIRG,IMPMONT,SENS,COK)
Value Char CHP()
Value Char VIRG()
Variable Decimal IMPMONT
Variable Shortint SENS
Variable Integer COK
Local Integer I
I = len(CHP)

#DBA le 19/08/03 : Ajout points d'entrée pour l'espagne/ le portugal
Gosub SNS_FRM
If SENS<>0 : End : Endif

#DBA le 10/10/03 : Sugg. no 16527
#Determination du sens du mouvement pour l'espagne
Case left$(CHP,1)
 When"+" : SENS = 1  : End
 When"-" : SENS = -1 : End
Endcase

#Determination du sens du mouvement
IMPMONT = val(left$(CHP,I-1)) * 10
Case right$(CHP,I)
 When "A" : SENS = 1  : IMPMONT += 1
 When "B" : SENS = 1  : IMPMONT += 2
 When "C" : SENS = 1  : IMPMONT += 3
 When "D" : SENS = 1  : IMPMONT += 4
 When "E" : SENS = 1  : IMPMONT += 5
 When "F" : SENS = 1  : IMPMONT += 6
 When "G" : SENS = 1  : IMPMONT += 7
 When "H" : SENS = 1  : IMPMONT += 8
 When "I" : SENS = 1  : IMPMONT += 9
 When "J" : SENS = -1 : IMPMONT += 1
 When "K" : SENS = -1 : IMPMONT += 2
 When "L" : SENS = -1 : IMPMONT += 3
 When "M" : SENS = -1 : IMPMONT += 4
 When "N" : SENS = -1 : IMPMONT += 5
 When "O" : SENS = -1 : IMPMONT += 6
 When "P" : SENS = -1 : IMPMONT += 7
 When "Q" : SENS = -1 : IMPMONT += 8
 When "R" : SENS = -1 : IMPMONT += 9
 When "{" : SENS = 1
 When "}" : SENS = -1
 When Default
  If val(num$(CHP))<>0
   Call TRACE(mess(9,120,1),num$(IMPMONT)-mess(48,120,1)-[F:RBK]BAN,[0/0/0]) From SUBRBK
   #Sens du montant incorrect
   COK = 0 : End
  Endif
Endcase
If IMPMONT<>0
 For I=1 To val(VIRG)
  IMPMONT = IMPMONT/10
 Next I
Endif
End

Subprog TRACE(CHAINE1,CHAINE2,DAT)
Value Char CHAINE1(), CHAINE2()
Value Date DAT
If DAT <> [0/0/0]
 Call ECR_TRACE(CHAINE1-":"-CHAINE2-mess(94,100,1)-format$("D:"+GFMDAT,DAT),0) From GESECRAN
Else
 Call ECR_TRACE(CHAINE1-":"-CHAINE2,0) From GESECRAN
Endif
End

 
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 GMESSAGE = mess(26,120,1) : #Vous n'avez pas accés ŕ toutes les banques
 mkstat = 2 : End
Endif
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 GMESSAGE = (mess(25,120,1)-" "-VALEUR) : #Vous n'avez pas accés ŕ la banque
 mkstat = 2 : End
Endif
End

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If left$([M]FILNAM ,1)="#" : [M]TYPEXP=1 Else [M]TYPEXP=2 : Endif
Call AM_TYPEXP([M]TYPEXP)
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Call SET_NAMCLI([M]FILNAM) From ORDSYS
 Grizo [M]FILNAM
 End
Else
 [M:DIA]FILNAM = filpath(GDIRBQR,"","")
 Actzo [M]FILNAM
Endif
End

Subprog AM_FILNAM(VALEUR)
Variable Char    VALEUR()
Raz [M]BAN
Call RECHBAN(VALEUR) From SUBRBK
End

Subprog RECHBAN(VALEUR)
Variable Char    VALEUR()
Local Integer J,K,RANG,OK,LONG
Local Char    IBAN(5), IGUI(5), ICPT(11)
Local Schar   CTEST(1)
#DBA le 18/08/03 : Sugg 16526
Local Integer LNGBQE ,LNGGUI, LNGCPT
#
If clalev([F:TFB])=0  : Local File TABFILBAN [TFB] : Endif
If clalev([F:BAN])=0  : Local File BANK      [BAN] : Endif

For [TFB]TFB0 Where COD=[M]NOMFIC & BAN="" & RECTYP=1
 LONG += [F:TFB]LNG : #Longueur d'un champ
Next

Local Schar    CHAMP(LONG)

Openi VALEUR,0
Gosub LECTEST
While ascii(CTEST)<32 & fstat=0
 J +=1
 Gosub LECTEST
Wend

Openi VALEUR,J
Gosub LECTURE
RANG = 1
#DBA le 18/08/03 : Sugg 16526 : Utilisation des variables LNG*
#ŕ la place des chiffres 5,5 et 11 en dur.
For [TFB]TFB0 Where COD=[M]NOMFIC & BAN="" & RECTYP=1
 Case [F:TFB]FRM
  When "BANQUE"  : IBAN += mid$(CHAMP,RANG,[F:TFB]LNG) : LNGBQE=[F:TFB]LNG
  When "GUICHET" : IGUI += mid$(CHAMP,RANG,[F:TFB]LNG) : LNGGUI=[F:TFB]LNG
  When "COMPTE"  : ICPT += mid$(CHAMP,RANG,[F:TFB]LNG) : LNGCPT=[F:TFB]LNG : Break
 Endcase
 RANG +=[F:TFB]LNG
Next

Filter [BAN] Where mid$(BIDNUM,1,LNGBQE)=IBAN
&                & mid$(BIDNUM,LNGBQE+1,LNGGUI)=IGUI
&                & mid$(BIDNUM,LNGBQE+LNGGUI+1,LNGCPT)=ICPT
OK = 0
For [BAN]
 OK = 1
 Break
Next
If OK : [M]BAN = [F:BAN]BAN : Endif
Filter [BAN]
End


Subprog C_FILNAM(NOMFIC)
Variable Char     NOMFIC()

If NOMFIC="" : mkstat=1 : End : Endif

Gosub CONTFIC From GIMPOBJ 

# JML 26/04/2000
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)

Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat=2
Endif

If !mkstat
 Call EXISTE(NOMFIC,ER) From ORDSYS
 Case ER
  When 2
   GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
   mkstat = 2
  When 0
   GMESSAGE = mess(03,141,1) : # Fichier ŕ importer inexistant
   mkstat = 2
 Endcase
Endif
End

