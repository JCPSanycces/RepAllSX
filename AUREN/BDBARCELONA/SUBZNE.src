#<AdxTL>@(#)12.0.0.0 $Revision:   1.5  $ Gestion du fichier SINCENT
########################################################################
# SUBZNE                                         JL - Septembre 2000   #
#                                                                      #
#    REVISION DES TARIFS VENTE : PARAMETRAGE                           #
#                                                                      #
#    - Action e_commerce : GOBJET                                      #
#----------------------------------------------------------------------# 
#    La gestion des lignes du paramétrage est effectuée par            #
#    l'action GOBJET "ZND" qui est appelée par le bouton "Lignes"      #
#----------------------------------------------------------------------# 
# Table mise ŕ jour  : SINCENT [F:ZNE]                                 # 
#                      SINCDET [F:ZND]                                 # 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             de l'écran PPCINCRE [M:ZPIE]                             # 
########################################################################
Call OBJET("ZNE",GBIDC1,GBIDC2) From GOBJET
End
########################################################################

$ACTION
Case ACTION
 When "OUVRE"                : Gosub OUVRE
 When "RAZCRE"               : Gosub RAZCRE 
 When "LIENS"                : Gosub LIENS
 When "SETBOUT"              : Gosub SETBOUT
 When "AVANTBOUT"            : Gosub AVANTBOUT 
 When "CREATION"             : Call VALID([F:ZNE]COD,nomap)
                               Default File [ZNE]  
 When "MODIF"                : Call VALID([F:ZNE]COD,nomap)
                               Default File [ZNE]  
 When "ANNULE"               : Gosub ANNULE
 When default
Endcase
Return


#######################################################################
$OUVRE
Local Char     CLEZNE (20), CLEZND (20)
Local  Char    APPLI    : # nom du dossier (pour generer ecrans et traitements) 
APPLI=nomap

If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif
If clalev([F:AXX])=0 : Local File =APPLI+".ATEXTRA"     [AXX] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"     [ATI] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"     [ATZ] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"       [ATY] : Endif
If clalev([F:PPI])=0 : Local File =APPLI+".PPRICINCR"   [PPI] : Endif

Return

#######################################################################
$RAZCRE
[M:ZPIE]RLGTBL="PPRICINCR"
Return

#######################################################################
$LIENS
[M:ZPIE]RLGTBL="PPRICINCR"
Read [F:PRS]PRS0=1;""
Read [PPC]PPC0=[F:ZNE]PLI
If fstat : Raz [F:PPC] : Endif
Raz [M:ZPIE]XXPRS
For I=0 To dim([F:PRS]DES)-1
  If [F:PRS]DES(I)<>0 & [F:PPC]DISCRGPRO(I)=1
    Read [AXX]AXX0 = GLANGUE;[F:PRS]DES(I)
    If !fstat : [M:ZPIE]XXPRS(I) = [F:AXX]TEXTE : Endif
  Endif
Next I
If [M:ZPIE]TYP<>3
  Raz [M:ZPIE]CUROLD, [M]CURNEW, [M]CHGTYP
  Grizo CUROLD, CURNEW, CHGTYP 
Else 
  Actzo CUROLD, CURNEW, CHGTYP 
Endif 
GFLTPLI=[F:ZNE]PLI
Return

#######################################################################
$SETBOUT
#--- les boutons
#     "a" = Lignes         mess(7,105,1)
#     "b" = Exécuter       mess(52,100,1)
#     "c" = Copie          mess(91,123,1)

#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET
#---
If CLECUR1="" or REP<>""
 Call VIREBOUT(CHAINE,"abc") From GOBJET
Endif
#--- impossible d'executer si pas super utilisateur
#If [M]ACS<>"" & GPROFIL<>GSUPER
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC=GUSER;[M]ACS
  If fstat | [F:ACC]EXEC<>2 
    Call VIREBOUT(CHAINE,"b") From GOBJET
  Endif
#Endif 
Return

#######################################################################
$AVANTBOUT
Case BOUT
  When "a"
    If !VERROU
      # Modification en cours sur un autre poste
      GERR=1 : GMESSAGE=mess(10,100,1)
      Return
    Endif
Endcase
Return

#######################################################################
$ANNULE
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif

# suppression des lignes du paramétrage 
Delete [F:ZND]Where COD=[M:ZPIE]COD
If fstat
  If fstat<4 GOK=1 : Return : Endif
Endif

# Suppression des traitements générés
Local Char    NOMTRT(GDIMFIC), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT
NOMTRT="WBI"+num$([M:ZPIE]COD)
For EXT = "adx", "src"
  FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
  While filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
    FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
  Wend
Next EXT


Return

#######################################################################

#---------------------------------------------------------------------
$CRIT_TARIF
Local Char    TEX (250)
Local Integer NBTEX, I, OK
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    NBTEX += 1
    If NBTEX > 1 : TEX += "\" : Endif
    TEX +="CRIT"+num$(I+1)+"  "+format$("K:20X",[F:PPC]CRIDES(I))+"  "+[F:PPC]FLDTYP(I)
  Endif
Next I
Call AVERTIR (TEX,OK) From GESECRAN

Return
#---------------------------------------------------------------------

#######################################################################
# Génération traitements liés au paramétrage
####################################################################### 
Subprog VALID(CODE,APPLI)
Value Char CODE
Value Char APPLI

Local Integer I, I1
Local Char    NOMTRT (GDIMFIC), FICSRC (GDIMFIC)

Local Char    TBL_CODFIC (15) (0..15)  : # Tables liees Code table
Local Char    TBL_ABRFIC (5)  (0..15)  : # Tables liees Abreviation table
Local Char    TBL_CODIND (15) (0..15)  : # Tables liees Nom index 0 de la table
Local Char    TBL_EXPLNK (60) (0..15)  : # tables liess Expression lien
   
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"       [ATY] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"     [ATI] : Endif
If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif

Read [F:PRS]PRS0=1;""

NOMTRT="WBI"+[F:ZNE]COD
FICSRC = filpath("TRT",NOMTRT,"src",APPLI)
Openo FICSRC,0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WBI";[F:ZNE]COD;"                                            ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"

# --- Définition de chargement des variables traitement

Wrseq "$VARIABLES"
Wrseq "Gosub VAR_DEF"
Wrseq "Gosub VAR_AFF"
Wrseq "Return"
Wrseq 
Wrseq "$VAR_DEF"
For I=1 To [F:ZNE]NBVAR
  Read [ATY]CODTYP = [F:ZNE]VARTYP(I-1)
  Case [F:ATY]TYPTYP
    When 1 : Wrseq "Local Libelle  ";
    When 2 : Wrseq "Local Shortint ";
    When 3 : Wrseq "Local Integer  ";
    When 4 : Wrseq "Local Decimal  ";
    When 5 : Wrseq "Local Decimal  ";
    When 6 : Wrseq "Local Decimal  ";
    When 7 : Wrseq "Local Char     ";
    When 8 : Wrseq "Local Date     ";
  Endcase
  Wrseq num$([F:ZNE]VARCOD(I-1));
  If [F:ATY]TYPTYP=7
    Wrseq " (50)";
  Endif 
  Wrseq
Next I
Wrseq "Return"
Wrseq
Wrseq "$VAR_AFF"
For I=1 To [F:ZNE]NBVAR
  Wrseq num$([F:ZNE]VARCOD(I-1))+" = ";
  Read [ATY]CODTYP = [F:ZNE]VARTYP(I-1)
  Case [F:ATY]TYPTYP
    When 1,2,3,4,5,6 : Wrseq "val([M:PPCI]VARVAL("+num$(I-1)+"))"
    When 7,8         : Wrseq "[M:PPCI]VARVAL("+num$(I-1)+")"
  Endcase
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

# --- Si changement devise

If [F:ZNE]TYP=3
  Wrseq "$CHGDEV_LIGNE"
  Wrseq "Local Decimal MNTDEV" 
  If [F:PPC]CRICURNUM>0
    Wrseq "[F:PPI]CRIT"+num$([F:PPC]CRICURNUM)+"=[M:PPCI]CURNEW"
  Endif
  If [F:PPC]CRICURNUM=1
    Wrseq "[F:PPI]PLICRI1=[M:PPCI]CURNEW"
  Endif
  If [F:PPC]CRICURNUM=2
    Wrseq "[F:PPI]PLICRI2=[M:PPCI]CURNEW"
  Endif
  Wrseq "[F:PPI]CUR=[M:PPCI]CURNEW" 
  If [F:PPC]PRIPRO=2 | [F:PPC]PRIPRO=3
    Wrseq "Call CONVERT2([M:PPCI]CUROLD,[M:PPCI]CURNEW,GLOCALDEV,[M:PPCI]CHGTYP,date$," 
    Wrseq "&             [F:PPI]PRI,[F:PPI]PRI,GBIDI3) From TRTDEV" 
    Wrseq "[F:PPI]PRI=arr([F:PPI]PRI,0.0001)"
  Endif
  Wrseq "MNTDEV=[F:PPI]MINAMT : Gosub DEV_CONV : [F:PPI]MINAMT=MNTDEV"
  Wrseq "MNTDEV=[F:PPI]MAXAMT : Gosub DEV_CONV : [F:PPI]MAXAMT=MNTDEV"
  For I=0 To dim([F:PPI]DCGVAL)-1
    If [F:PRS]VALTYP(I)=1
      Wrseq "MNTDEV=[F:PPI]DCGVAL("+num$(I)+") : ";
      Wrseq "Gosub DEV_CONV : ";
      Wrseq "[F:PPI]DCGVAL("+num$(I)+")=MNTDEV"
    Endif
  Next I
  Wrseq "Return"
  Wrseq
  Wrseq "$DEV_CONV"
  Wrseq "Call CONVERT([M:PPCI]CUROLD,[M:PPCI]CURNEW,GLOCALDEV,[M:PPCI]CHGTYP,date$," 
  Wrseq "&             MNTDEV,MNTDEV,GBIDI3) From TRTDEV" 

  Wrseq "Return"
  Wrseq 
  Wrseq "#-----------------------------------------------------------------"
Endif

# --- Traitements generes pour les tables liees

Raz TBL_CODFIC, TBL_ABRFIC, TBL_CODIND, TBL_EXPLNK

For I=0 To dim([F:ZNE]TBL)-1
  If [F:ZNE]TBL(I)<>""
    Read [F:ATB]CODFIC=[F:ZNE]TBL(I)    
    If !fstat
      Filter [ATI] Where CODFIC=[F:ZNE]TBL(I) & NUMLIG=1
      Read [ATI]NUMLIG First
      If !fstat
        TBL_CODFIC(I1)=[F:ZNE]TBL(I) 
        TBL_ABRFIC(I1)=[F:ATB]ABRFIC 
        TBL_CODIND(I1)=[F:ATI]CODIND
        TBL_EXPLNK(I1)=[F:ZNE]EXPLNK(I)  
        I1 +=1
      Endif
      Filter [ATI]
    Endif
  Endif
Next I

# --- Ouverture des tables liees

Wrseq 
Wrseq "$OPEN_TBL"
For I=0 To dim(TBL_CODFIC)-1
  If TBL_CODFIC(I)<>""
    Wrseq "If clalev([F:"+vireblc(TBL_ABRFIC(I),2)+"])=0 : ",
    Wrseq "Local File '"+vireblc(TBL_CODFIC(I),2)+"' ["+vireblc(TBL_ABRFIC(I),2)+"] : Endif"
  Endif 
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

# --- Lecture des tables liees

Wrseq 
Wrseq "$LECT_TBL"
For I=0 To dim(TBL_CODFIC)-1
  If TBL_CODFIC(I)<>""
    Wrseq "Read ["+TBL_ABRFIC(I)+"]"+TBL_CODIND(I)+"="+TBL_EXPLNK(I)
    Wrseq "If fstat : Raz [F:"+TBL_ABRFIC(I)+"] : Endif"
  Endif 
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

Wrseq
Wrseq "Subprog CONTROLE(NOL,VALEUR)"
Wrseq "Value    Integer NOL"
Wrseq "Variable Char    VALEUR"
Wrseq "Case NOL"
For I=0 To [F:ZNE]NBVAR-1
 Wrseq " When "+num$(I+1)
 If [F:ZNE]VARTYP(I)="AFF"
  Wrseq " Call C_FORMULE(VALEUR) From FORMULE"
  Wrseq "  If mkstat : End : Endif"
 Endif
 If [F:ZNE]VARCTL(I)<>""
  Wrseq '  Call CONTACL("'+[F:ZNE]VARCTL(I)+'",VALEUR) From SUBACL'
  Wrseq "  If mkstat : End : Endif"
 Endif
Next I
Wrseq "Endcase"
Wrseq "End"
Wrseq
Wrseq "#-----------------------------------------------------------------"
Wrseq
Wrseq "Subprog SELECT(NOL)"
Wrseq "Value Integer NOL"
Wrseq "Case NOL"
For I=0 To [F:ZNE]NBVAR-1
 Wrseq " When "+num$(I+1)
 Read [ATY]CODTYP = [F:ZNE]VARTYP(I)
 If [F:ZNE]VARTYP(I)="AFF"
  Wrseq " Call B1_FORMUL(zc,[M:PPCI]FLTTAB,[M:PPCI]XXCONV,[M:PPCI]XXVAR) From FORMULE"
 Endif
 If [F:ATY]OBJLIEN<>""
  Wrseq '  Call SELECT("'+[F:ATY]OBJLIEN+'","",zc,"") From SELOBJ'
 Endif
Next I
Wrseq "Endcase"
Wrseq "End"
Wrseq
Wrseq "#-----------------------------------------------------------------"
Wrseq

Openo
Call VALID(NOMTRT,APPLI) From GRVALMSK2

End

#########################################################################
# Traitement de la copie paramétrage tarif transaction de saisie
# TABLE = Clé de l'enregistrement ŕ copier
#         (si la cle est numerique val(TABLE)
#########################################################################
$TRTCOP
If [M]DOSORG=nomap
  Local File SINCENT [ZNE1]
  Local File SINCDET [ZND1]
Else
  Local File =[M]DOSORG+".SINCENT" [ZNE1]
  Local File =[M]DOSORG+".SINCDET" [ZND1]
Endif
If [M]DOSDES=nomap
  Local File SINCENT [ZNE2]
  Local File SINCDET [ZND2]
Else
  Local File =[M]DOSDES+".SINCENT" [ZNE2]
  Local File =[M]DOSDES+".SINCDET" [ZND2]
Endif
Look [ZNE2] ZNE0=TABLE
If !fstat
   OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK=1 : Return : Endif
Endif

Call DEBTRANS From GLOCK
 Gosub TR_COP
Return

#------------------------------------------------------------------------
$TR_COP
GOK=1

Trbegin [ZNE2] , [ZND2]

  Delete [ZNE2] Where COD=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".SINCENT"-TABLE  : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("ZNE2",TABLE) From GLOCK         : Goto AB_TR_COP
  Endif

  Delete [ZND2] Where COD=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".SINCDET"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("ZND2",TABLE) From GLOCK        : Goto AB_TR_COP
  Endif

  For [ZND1]ZND0 Where COD=TABLE
    [F:ZND2]=[F:ZND1]
    Write [ZND2]
    If fstat
      GOK=0 : Call FSTA("ZND2") From GLOCK : Break
    Endif
  Next
  If    GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK  : Goto AB_TR_COP
  Endif 

  For [ZNE1]ZNE0 Where COD=TABLE
    [F:ZNE2]=[F:ZNE1]
    Write [ZNE2]
    If fstat
      GOK=0 : Call FSTA("ZNE2") From GLOCK : Break
    Endif
  Next
  If    GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK  : Goto AB_TR_COP
  Endif 

Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback 
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback 
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return

#######################################################################

######################################## Code tarif
Subprog AS_PLI(VALEUR)
Variable Char    VALEUR()
If GREP<>"C" : mkstat=2 : Endif
End

#---------------------------------------
Subprog AM_PLI(VALEUR)
Variable Char    VALEUR()
Raz [M]PLISTRCRD, PLIENDCRD, UPDCRDFLG, VLYDAT
Affzo PLISTRCRD, PLIENDCRD, UPDCRDFLG, VLYDAT 
GFLTPLI=VALEUR
End

######################################## No fiche début
Subprog IB_PLISTRCRD
Raz GBOUT1
If [M]PLI<>"" & [M]PLISTRCRD<>"" : GBOUT1=mess(9,432,1) : Endif
End

#---------------------------------------
Subprog AM_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : [M:ZPIE]PLIENDCRD=VALEUR : Affzo [M:ZPIE]PLIENDCRD : Endif 
End

#---------------------------------------
Subprog C_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
Look [PPF] PPF0=[M]PLI;VALEUR
If mkstat
  GERR=1 : GMESSAGE=mess(129,192,1) : # la fiche n'appartient pas au tarif
Endif 
End

######################################## No fiche fin
Subprog IB_PLIENDCRD
Raz GBOUT1
If [M]PLI<>"" & [M]PLIENDCRD<>"" : GBOUT1=mess(9,432,1) : Endif
End

#---------------------------------------
Subprog C_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
Look [PPF] PPF0=[M]PLI;VALEUR
If mkstat
  GERR=1 : GMESSAGE=mess(129,192,1) : # la fiche n'appartient pas au tarif
Endif 
End

######################################## Type de traitement
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>3
  Raz [M]CUROLD, [M]CURNEW, [M]CHGTYP
  Grizo CUROLD, CURNEW, CHGTYP 
Else 
  Actzo CUROLD, CURNEW, CHGTYP 
Endif 
End

######################################## Ancienne devise
Subprog AS_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CURNEW : mkstat=2 : End : Endif
End

######################################## Nouvelle devise
Subprog AS_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CUROLD : mkstat=2 : End : Endif
End

######################################## Type de cours
Subprog AS_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP=3 & VALEUR=0 : mkstat=2 : End :  Endif
End

######################################## Tableau des variables 
Subprog B1_NBVAR
Gosub CRIT_TARIF
End

######################################## Nom de variable
Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VARCOD) From OBJDIV
End

######################################## Type de la variable
Subprog C_VARTYP(VALEUR)
Variable Char    VALEUR()
If !find (VALEUR,"A","C","DCB","RAT","ITM","ITS","BPR","BPC","BPD","BPT",
&                "CUR","DAT","L","REP","UOM","AFF","STI","STC","FCY","CPY")
  mkstat=2
Endif
End

######################################## Valeur par défaut de la variable
Subprog AS_VARDEF(VALEUR)
Variable Char    VALEUR()
Local    Integer IJ
Raz [M:ZPIE]FLTTAB, XXCONV, XXVAR
[M:ZPIE]FLTTAB="find(ABRFIC,'PPI')"
For I=0 To dim([F:PPC]ABB)-1
  If [F:PPC]ABB(I)<>""
    [M:ZPIE]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","+[F:PPC]CRIDES(I)
    IJ += 1 
  Else
    [M:ZPIE]XXCONV(IJ)="PPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
  Endif
Next I
For I=0 To dim([F:PRS]DES)-1
  If [M:ZPIE]XXPRS(I)<>""
    [M:ZPIE]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"+[M:ZPIE]XXPRS(I)
    IJ += 1   
  Else
    [M:ZPIE]XXCONV(IJ)="PPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
End

########################################
Subprog B1_NBTBL
Gosub CRIT_TARIF
End

######################################## Table liée
Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL , I
NOL = nolign-1
If VALEUR=[M:ZPIE]RLGTBL : mkstat = 1 : End : Endif
Read [ATZ]LIEN(2) = VALEUR;[M:ZPIE]RLGTBL
If !fstat
 OK = 1
Else
 OK = 0
 For I=0 To NOL-1 : # L'ordre est important
  Read [ATZ]LIEN(2) = VALEUR;[M:ZPIE]TBL(I)
  If !fstat
    OK = 1 : Break
  Endif
 Next I
Endif
If OK & [M:ZPIE]EXPLNK(NOL)=""
 Gosub SET_LIEN
 [M:ZPIE]EXPLNK(NOL) = CHAINE2
Endif
End

$SET_LIEN
Local Char    CHAINE1(80) , CHAINE2(80) , CHAMP(80)
Local Integer K
Read [ATB]CODFIC = [F:ATZ]CODFIC
If [F:ATZ]EXPLIEN=""
 CHAINE1 = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
Else
 CHAINE1 = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
Endif
CHAINE2 = ""
Repeat
 K = instr(1,CHAINE1,";")
 If K
  CHAMP   = left$(CHAINE1,K-1)
  CHAINE1 = right$(CHAINE1,K+1)
 Else
  CHAMP   = CHAINE1
  CHAINE1 = ""
 Endif
 If left$(CHAMP,1)>="A" & left$(CHAMP,1)<="Z"
  CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
 Endif
 If CHAINE2<>"" : CHAINE2 += ";" : Endif
 CHAINE2 += CHAMP
Until CHAINE1=""
Return

######################################## Expression de lien
Subprog AS_EXPLNK(VALEUR)
Variable Char    VALEUR()
Local Integer NB , I
Raz [M:ZPIE]TABFIL, NB
[M:ZPIE]TABFIL(0) = [M:ZPIE]RLGTBL
For I=0 To nolign-2
 NB += 1
 [M:ZPIE]TABFIL(NB) = [M:ZPIE]TBL(I)
Next I
End

#---------------------------------------
Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
NOL = nolign-1
VALEUR = vireblc(toupper(VALEUR),2)
If VALEUR=""
 Read [ATZ]LIEN(2) = [M:ZPIE]TBL(NOL);[M:ZPIE]RLGTBL
 If !fstat
  OK = 1
 Else
  OK = 0
  For I=0 To NOL-1 : # L'ordre est important
   Read [ATZ]LIEN(2) = [M:ZPIE]TBL(NOL);[M:ZPIE]TBL(I)
   If !fstat
     OK = 1 : Break
   Endif
  Next I
 Endif
 If OK
  Gosub SET_LIEN
  VALEUR = CHAINE2
 Else
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif
Else
 Call CONTROLE([M:ZPIE]TBL(NOL),VALEUR) From LNKSUB
Endif
End

########################################################################
