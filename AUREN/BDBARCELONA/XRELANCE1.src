#<AdxTL>@(#)3.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE,0)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE,SIMUL)
Value    Integer NBPAR , SIMUL
Variable Char    PARAMETRE()(1..)

Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 
 
Call PARAM("","FUPBPC",GDIV(0)) From ADOVAL     :# Prise en compte seuil client
If GDIV(0)="2" : [L]SEUILCLI=1 : Endif
Call PARAM("","FUPTRI1",GDIV(1)) From ADOVAL    :# Critère de tri - abrev
Call PARAM("","FUPTRI2",GDIV(2)) From ADOVAL    :# Critère de tri - champ
Call PARAM("","FUPLEV1",[L]LIT(1)) From ADOVAL  :# Code litige niveau 1
Call PARAM("","FUPLEV2",[L]LIT(2)) From ADOVAL  :# Code litige niveau 2
Call PARAM("","FUPLEV3",[L]LIT(3)) From ADOVAL  :# Code litige niveau 3
Call PARAM("","FUPLEV4",[L]LIT(4)) From ADOVAL  :# Code litige niveau 4
Call PARAM("","FUPLEV5",[L]LIT(5)) From ADOVAL  :# Code litige niveau 5
Call PARAM("","FUPLEV6",[L]LIT(6)) From ADOVAL  :# Code litige niveau 6
Call PARAM("","FUPLEV7",[L]LIT(7)) From ADOVAL  :# Code litige niveau 7
Call PARAM("","FUPLEV8",[L]LIT(8)) From ADOVAL  :# Code litige niveau 8
Call PARAM("","FUPLEV9",[L]LIT(9)) From ADOVAL  :# Code litige niveau 9
Call PARAM("","FUPMAX",GDIV(0)) From ADOVAL     :# Niveau maxi de relance
[L]NBSEUIL = val(GDIV(0))
Call PARAM("","FUPCDT",GDIV(0)) From ADOVAL     :# Prise en compte des crédits
If GDIV(0)="2" : [L]CREDIT=1 : Endif
Call PARAM("","FUPADD",[L]ADD) From ADOVAL     :# Code adresse pour relance

[L]CRITERE = 'FLGFUP=2 & AMTCUR*(AMTCUR-TMPCUR-PAYCUR)>0 & BPRFCT="" & LEVFUP<'+num$([L]NBSEUIL)
If ![L]CREDIT
 [L]CRITERE -= "& SNS=1"
Endif

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE" : [L]NUMREQ = val([L]VALEUR)
   When "cpydeb"  : [L]CPYDEB = [L]VALEUR
   When "cpyfin"  : [L]CPYFIN = [L]VALEUR
   When "fcydeb"  : [L]CRITERE -= "& FCY>='"+[L]VALEUR+"'"
   When "fcyfin"  : [L]CRITERE -= "& FCY<='"+[L]VALEUR+"'" 
   When "allsac"  : If [L]VALEUR="1" : [L]ALLSAC=1 : Endif
   When "sac"     : If ![L]ALLSAC & [L]VALEUR<>""
                     [L]CRITERE -= "& SAC='"+[L]VALEUR+"'"
                     [L]COLL = [L]VALEUR
                    Endif
   When "gsc"     : If [L]VALEUR<>"" & ([L]ALLSAC | (![L]ALLSAC & [L]COLL=""))
                     [L]GCOLL = [L]VALEUR
                     Read [F:GSC]GSC0=[L]VALEUR 
                     Raz [L]CRITGRPSAC 
                     For K = 1 To [F:GSC]NBRSAC 
                      If [L]CRITGRPSAC<>"" 
                       [L]CRITGRPSAC+="," 
                      Endif 
                      [L]CRITGRPSAC += "'"+[F:GSC]SAC(K-1)+"'" 
                     Next 
                     [L]CRITERE -= "& find(SAC,"+[L]CRITGRPSAC+")"
                    Endif 
   When "bpcdeb"  : Case [L]RELPAY
                     When 0 : [L]CRITERE -= "& BPR>='"+[L]VALEUR+"'" 
                     When 1 : [L]CRITERE -= "& BPRPAY>='"+[L]VALEUR+"'" 
                    Endcase
   When "bpcfin"  : Case [L]RELPAY
                     When 0 : [L]CRITERE -= "& BPR<='"+[L]VALEUR+"'"
                     When 1 : [L]CRITERE -= "& BPRPAY<='"+[L]VALEUR+"'"
                    Endcase
   When "crediteur" : If [L]VALEUR="1" : [L]CREDITEUR = 1 : Endif
   When "relpay"    : If [L]VALEUR="1" : [L]RELPAY = 1 : Endif
   When "datref"    : If [L]VALEUR<>""
                       [L]DATREF=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                      Endif
   When "seuil1"    : [L]SEUIL(1) = val([L]VALEUR)
   When "seuil2"    : [L]SEUIL(2) = val([L]VALEUR)
   When "seuil3"    : [L]SEUIL(3) = val([L]VALEUR)
   When "seuil4"    : [L]SEUIL(4) = val([L]VALEUR)
   When "seuil5"    : [L]SEUIL(5) = val([L]VALEUR)
   When "seuil6"    : [L]SEUIL(6) = val([L]VALEUR)
   When "seuil7"    : [L]SEUIL(7) = val([L]VALEUR)
   When "seuil8"    : [L]SEUIL(8) = val([L]VALEUR)
   When "seuil9"    : [L]SEUIL(9) = val([L]VALEUR)
   When "agio"      : If [L]VALEUR="1" : [L]CALAGIO=1 : Endif
   When "taux"      : [L]TAUX = val([L]VALEUR)
   When "tauxcli"   : If [L]VALEUR="1" : [L]TAUXCLI=1 : Endif
   When "numedt"    : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "X3FCT"     : [L]FONCTION = [L]VALEUR
  Endcase
 Endif
Next

# Types de pièce relançables
Raz [L]CRITFUP 
For [F:GTE]GTE0 Where FUP=2 
 If [L]CRITFUP<>""  
  [L]CRITFUP+=","  
 Endif  
 [L]CRITFUP += "'"+[F:GTE]TYP+"'"  
Next  
If [L]CRITFUP=""  
 # Pas de type de pièce à relancer
 Call ERREUR(mess(16,121,1)) From GESECRAN 
 End 
Endif 
[L]CRITFUP = "find(TYP,"+[L]CRITFUP+")"  
 
For [F:CPY]CPY0 Where CPY>=[L]CPYDEB & CPY<=[L]CPYFIN

 # Paramètres
 Call PARAM([F:CPY]CPY,"FUPFCY",GDIV(0)) From ADOVAL :# Niveau de la relance
 If GDIV(0)="2" : [L]RELFCY=1 : Endif

 # Autorisations par site
 OKSITE = 1
 If [L]RELFCY=1 & FONCTION<>""
  For [FCY]FCY0 Where FINFLG=2 & LEGCPY=[F:CPY]CPY
   Read [AFF]AFF0 = [F:FCY]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Break : Endif
  Next
 Endif

 If OKSITE

  Call PARAM([F:CPY]CPY,"FUPCUR",GDIV(0)) From ADOVAL :# Devise
  If GDIV(0)="2" : [L]RELDEV=1 : Endif

  Call PARAM([F:CPY]CPY,"FUPAMT",GDIV(0)) From ADOVAL :# Montant minimum
  [L]MNTMIN = val(GDIV(0))

  Call PARAM([F:CPY]CPY,"FUPCTL",GDIV(0)) From ADOVAL :# Contrôle
  If GDIV(0)="1" : [L]CONTCLI=1 : Endif

 # Tiers à relancer
  If [L]RELPAY :# Par client payeur
   If [L]RELFCY : Filter [F:DUD] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & CPY=[F:CPY]CPY
&                                Order By Key CLE=BPRPAY;FCY
   Else         : Filter [F:DUD] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & CPY=[F:CPY]CPY
&                                 Order By Key CLE=BPRPAY
   Endif
  Else         :# Par client facturé
   If [L]RELFCY : Filter [F:DUD] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & CPY=[F:CPY]CPY
&                                 Order By Key CLE=BPR;FCY
   Else         : Filter [F:DUD] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & CPY=[F:CPY]CPY
&                                 Order By Key CLE=BPR
   Endif
  Endif

  For [F:DUD]CLE(1)  :#Par client 
 
   If [L]RELPAY
    [L]CLIENT = [F:DUD]BPRPAY
   Else
    [L]CLIENT = [F:DUD]BPR
   Endif

# Vérif code d'accès du tiers

   OKCLI = 1
   Call LECTURE("BPR",[L]CLIENT,"") From CONTOBJ 
   If [F:BPR]ACS<>""
#    Read [ACS]CODACC = GUSER;[F:BPR]ACS
#    If fstat or [F:BPR]ACSCONSUL<>2 : OKCLI = 0 : Endif
    Read [ACC]CODACC = GUSER;[F:BPR]ACS   :# 16.4.2 Correction champs potentiellement inexistants
    If fstat or [F:ACC]CONSUL<>2 : OKCLI = 0 : Endif
   Endif

   If OKCLI
    Call LECTURE("BPC",[L]CLIENT,"") From CONTOBJ 
    If !fstat
 
   # Code adresse
     [L]ADD_CLI = [F:BPC]BPAINV
     If [L]ADD<>""
      Read [F:BPA]BPA0=1;[L]CLIENT;[L]ADD
      If fstat=0 : [L]ADD_CLI = [L]ADD : Endif
     Endif
  
     If [F:BPC]FUPTYP<>1 
      If [L]RELFCY
       Gosub TRT_FCY
      Else
       Gosub TRT_CPY
      Endif
     Endif
    Endif
   Endif
  Next  :#Client
 Endif
Next :# Société
# GH 27/12/99 bug 3913
If ![L]SIMUL
 Read [FUP]FUP0(1) = [L]NUMREQ
 If fstat>2
  # Rien à imprimer
  Call ECR_TRACE(mess(21,135,1),0) From GESECRAN
  GOK=0
 Endif
Endif

# V130, Impression par langue
If ![L]SIMUL
 Call PARAM("","LANGUAGE",LANDOS) From ADOVAL : # Langue principale du dossier 
 If [M:RPT]IMPRIME>1 and [M:RPT]SERVEUR<>""
  SERVEUR = [M:RPT]SERVEUR+"@"
 Else
  SERVEUR = ""
 Endif
 Call GETPARAM("__REPORT",NBPAR,PARAMETRE,ETAT) From ETAT
 RACINE  = left$(ETAT,3)
 SUFFIXE = seg$(ETAT,7,len(ETAT)-4)
 For [FUP]FUP0(2) Where NUMEDT=[L]NUMREQ
  LANGUE = [F:FUP]LAN
  ETAT   = RACINE+LANGUE+SUFFIXE
  If filinfo(filpath("REPORT",ETAT,"rpt"),0)<0
   LANGUE = LANDOS
   ETAT   = RACINE+LANDOS+SUFFIXE
  Endif
  If filinfo(filpath("REPORT",ETAT,"rpt"),0)>=0 : # Si celui la il existe pas, on peut rien faire
   ETAT += ".rpt"
   Call SETPARAM("__REPORT",NBPAR,PARAMETRE,ETAT) From ETAT
   Call SETPARAM("langue",NBPAR,PARAMETRE,[F:FUP]LAN) From ETAT
   If !GINTRA or (SERVEUR<>"" & [M:RPT]IMPRIME=2) : # Si impression directe, Report sinon serveur Web
    Report SERVEUR With PARAMETRE(1..NBPAR)
   Else
    Call IMPRIW([M:RPT]SERVEUR,[M:RPT]IMPRIMANTE,0,PARAMETRE,NBPAR,GOK) From ETATW
   Endif
  Endif
 Next
 GOK = 0 : # Pour pas imprimer l'état std
Endif
End

###################################################################
$TRT_CPY
[L]OK=1
If ![L]CREDITEUR :# Relance par société
 Call SOLDAT([L]GCOLL,[L]COLL,"",[L]CLIENT,[F:CPY]CPY,""
&           ,[F:CPY]ACCCUR,1,datesyst,[L]SOLDE) From CNSCPTSTD
 If [L]SOLDE<0 :# Solde créditeur
  [L]OK=0
 Endif
Endif
If ![L]OK : Return : Endif

# Contrôle du seuil par client
If [L]CONTCLI & 
&    (([L]SEUILCLI & [F:BPC]FUPMINAMT) or (![L]SEUILCLI & [L]MNTMIN))
 If [L]RELPAY
  Filter [F:DUD2] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & BPRPAY=[F:DUD]BPRPAY
&                       & CPY=[F:DUD]CPY
 Else
  Filter [F:DUD2] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & BPR=[F:DUD]BPR
&                       & CPY=[F:DUD]CPY
 Endif
 Gosub CONT_SEUIL
 Filter [F:DUD2] : # gh 06/09/99
Endif
If ![L]OK : Return : Endif

Gosub TRT_DUD
Return

###################################################################
$TRT_FCY
For [F:DUD]CLE(2)  :# Par site
 [L]OK=1
 If ![L]CREDITEUR  :# Pas de prise en compte si solde créditeur
   Call SOLDAT([L]GCOLL,[L]COLL,"",[L]CLIENT,[F:CPY]CPY,[F:DUD]FCY
&             ,[F:CPY]ACCCUR,1,datesyst,[L]SOLDE) From CNSCPTSTD
   If [L]SOLDE<0
    [L]OK=0
   Endif
 Endif

# Autorisation par site
 
 OKSITE = 1
 If FONCTION<>""
  Read [AFF]AFF0 = [F:DUD]FCY;GPROFIL;FONCTION
  If fstat : OKSITE = 0 : Endif
 Endif

 If OKSITE
  If [L]OK
  # Contrôle du seuil par client
   If [L]CONTCLI & 
&     (([L]SEUILCLI & [F:BPC]FUPMINAMT) or (![L]SEUILCLI & [L]MNTMIN))
    If [L]RELPAY
     Filter [F:DUD2] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & BPRPAY=[F:DUD]BPRPAY
&                          & CPY=[F:DUD]CPY & FCY=[F:DUD]FCY
    Else
     Filter [F:DUD2] Where evalue([L]CRITERE) & evalue([L]CRITFUP) & BPR=[F:DUD]BPR
&                         & CPY=[F:DUD]CPY & FCY=[F:DUD]FCY
    Endif
    Gosub CONT_SEUIL
    Filter [F:DUD2] : # gh 06/09/99
   Endif  :#Contrôle du seuil par client
  Endif

  If [L]OK : Gosub TRT_DUD : Endif
 Endif
Next :# Site
Return
  
###################################################################

$TRT_DUD
For [F:DUD]CLE 

 If (find([F:BPC]FUPTYP,2,3,4) & [L]DATREF-[F:DUD]DUDDAT>[L]SEUIL([F:DUD]LEVFUP+1))
&   or ([F:BPC]FUPTYP=5 & [L]DATREF-[F:DUD]DUDDAT>[L]SEUIL(1))

  # Contrôle du seuil par échéance
  [L]OK=1
  If ![L]CONTCLI & 
&    (([L]SEUILCLI & [F:BPC]FUPMINAMT) or (![L]SEUILCLI & [L]MNTMIN))
   [L]MONTANT = [F:DUD]AMTRPT-[F:DUD]TMPRPT-[F:DUD]PAYRPT
   If ([L]SEUILCLI & [L]MONTANT<[F:BPC]FUPMINAMT)
&     or (![L]SEUILCLI & [L]MONTANT<[L]MNTMIN)
    [L]OK=0
   Endif
  Endif

  If [L]OK : # GH 07/12/99
   # Lecture de la pièce 
   Call LECTURE("GAS",[F:DUD]NUM,[F:DUD]TYP) From CONTOBJ 
   If fstat : [L]OK = 0
   Elsif !fstat & [F:HAE]FLGREP=2 : [L]OK=0
   Endif
  Endif

  If [L]OK 
   Raz [L]AGIO
   If [L]CALAGIO  
      # Demande de modifications (14677)
      If ![L]TAUXCLI | [F:BPC]DEP=""
         [L]TXAGIO = [L]TAUX
      Endif          
      [L]MONTANT = ([F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC)*[F:DUD]SNS
      Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
      Raz DELAI
      Call ESC_AGIO([F:BPC]DEP,[L]MONTANT,[L]DATREF,[F:DUD]DUDDAT,
&                         DELAI,[L]TXAGIO,[L]AGIO,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV 
      [L]AGIO =arr(max(0,[L]AGIO),[F:TCU]CURRND)
      
   Endif :# Calcul agios
       
   Gosub NBRDAY
   Call DEBTRANS From GLOCK 
   If ![L]SIMUL : Gosub TR1
   Else         : Gosub TR2
   Endif 
  Endif
 Endif
Next :# Echéance
Return

#############################################################

$CONT_SEUIL
Raz [L]MNT
For [F:DUD2]
 If (find([F:BPC]FUPTYP,2,3,4) & [L]DATREF-[F:DUD2]DUDDAT>[L]SEUIL([F:DUD2]LEVFUP+1))
&    or ([F:BPC]FUPTYP=5 & [L]DATREF-[F:DUD2]DUDDAT>[L]SEUIL(1))
  # Lecture de la pièce : # GH 07/12/99
  Call LECTURE("GAS",[F:DUD2]NUM,[F:DUD2]TYP) From CONTOBJ 
  If fstat | [F:HAE]FLGREP<>2
   [L]MNT += ([F:DUD2]AMTRPT-[F:DUD2]TMPRPT-[F:DUD2]PAYRPT)*[F:DUD2]SNS
  Endif
 Endif
Next
If [L]SEUILCLI & abs([L]MNT)<[F:BPC]FUPMINAMT or ![L]SEUILCLI & abs([L]MNT)<[L]MNTMIN
 [L]OK=0
Endif
Return

##########################################################################

# Réel
$TR1
Trbegin [FUP] , [DUD2] , [MVC]  

 SYMBOLE = "HAE"+[F:DUD]NUM+"\"+[F:DUD]TYP 
 Lock =SYMBOLE 
 If fstat 
  # Modification en cours sur un autre poste 
  STAT = 1 : Call ERREURT([F:DUD]TYP-[F:DUD]NUM-mess(10,100,1),STAT) From GESECRAN 
  GOK=0 : Goto AB_TR1 
 Endif 
 
 # Mise à jour table des relances
 Raz [F:FUP]  
 [F:FUP] = [F:DUD]
 [F:FUP]ADD    = [L]ADD_CLI
 [F:FUP]BPRFUP = [L]CLIENT
 [F:FUP]ACCDAT = [F:HAE]ACCDAT
 If [L]CALAGIO
  [F:FUP]DEPRAT = [L]TXAGIO 
  [F:FUP]BANCRG = [L]AGIO 
 Endif
 [F:FUP]SIM    = 1 
 # LEVFUP sert à rechercher le texte de relance
 # Relance par délai : texte associé au seuil en nombre de jours
 # Autres            : texte associé au niveau de relance
 If [F:BPC]FUPTYP=5 :#Relance par délai
  [F:FUP]LEVFUP = J
 Else
  [F:FUP]LEVFUP = [F:DUD]LEVFUP+1
 Endif
 [F:FUP]NBRDAY = [L]SEUIL(J)
 [F:FUP]DATEDT = datesyst 
 [F:FUP]DATREF = [L]DATREF
 [F:FUP]NUMEDT = [L]NUMREQ
 Case [F:BPC]FUPTYP
  When 2  :# Par facture
   [F:FUP]GRPCRI="1;"+[L]CLIENT+";"+num$([F:DUD]ACCNUM)+";"+num$([F:DUD]DUDLIG)
  When 3  :# Globale
   If [L]RELFCY  :# 1 lettre par site
    [F:FUP]GRPCRI = "2;"+[L]CLIENT+";"+[F:DUD]FCY+";"
   Else
    [F:FUP]GRPCRI = "2;"+[L]CLIENT+";"+[F:DUD]CPY+";"
   Endif
   If [L]RELDEV  :# 1 lettre par devise de transaction
    [F:FUP]GRPCRI += [F:DUD]CUR
   Endif
  When 4  :# Globale par niveau
   If [L]RELFCY  :# 1 lettre par site
    [F:FUP]GRPCRI = "3;"+[L]CLIENT+";"+[F:DUD]FCY+";"+num$([F:DUD]LEVFUP+1)+";"
   Else
    [F:FUP]GRPCRI = "3;"+[L]CLIENT+";"+[F:DUD]CPY+";"+num$([F:DUD]LEVFUP+1)+";"
   Endif
   If [L]RELDEV  :# 1 lettre par devise de transaction
    [F:FUP]GRPCRI += [F:DUD]CUR
   Endif
  When 5   :# Globale par délai
   If [L]RELFCY  :# 1 lettre par site
    [F:FUP]GRPCRI = "4;"+[L]CLIENT+";"+[F:DUD]FCY+";"
   Else
    [F:FUP]GRPCRI = "4;"+[L]CLIENT+";"+[F:DUD]CPY+";"
   Endif
   [F:FUP]GRPCRI += num$(J)+";"
   If [L]RELDEV  :# 1 lettre par devise de transaction
    [F:FUP]GRPCRI += [F:DUD]CUR
   Endif
 Endcase

 If GDIV(1)<>"" & GDIV(2)<>""
  [F:FUP]TRI    = evalue(GDIV(1)+GDIV(2))
 Endif
 If [L]RELFCY : [F:FUP]FLGFCY=1 : Endif
 #[F:FUP]LAN = [F:BPR]LAN
 [F:FUP]LAN = [F:BPR]XLAN   # N.A.C.   21/02/2007
 Write [F:FUP] 
 If fstat 
  GOK=0 : Call FSTA("FUP") From GLOCK 
  Goto AB_TR1 
 Endif 
 
 # Prise en compte des crédits ou relance globale(pour niveau maxi)
 If [L]CREDIT or [F:BPC]FUPTYP=3
  Gosub MAJ_FUPTOT
  If GOK=-1 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif

 # Mise à jour de l'échéance 
 [L]TYP    = [F:DUD]TYP 
 [L]NUM    = [F:DUD]NUM 
 [L]LIG    = [F:DUD]LIG 
 [L]DUDLIG = [F:DUD]DUDLIG 

 If [L]LIT([F:DUD]LEVFUP+1)<>""
  Update [F:DUD2] Where TYP=[L]TYP & NUM=[L]NUM & LIG=[L]LIG & DUDLIG=[L]DUDLIG 
&                With LEVFUP+=1 , DATFUP=datesyst , DPTCOD=[L]LIT([F:DUD]LEVFUP+1)
 Else
  Update [F:DUD2] Where TYP=[L]TYP & NUM=[L]NUM & LIG=[L]LIG & DUDLIG=[L]DUDLIG 
&                With LEVFUP+=1 , DATFUP=datesyst 
 Endif

 If fstat=1 
  GOK=-1 : GLOCK="$GACCDUDATE"-[L]TYP-[L]NUM-num$([L]LIG)-num$([L]DUDLIG) 
  Goto ROLL_TR1 
 Elsif fstat 
  GOK=0 : Call RSTA("DUD2",[L]TYP-[L]NUM-num$([L]LIG)-num$([L]DUDLIG)) 
&               From GLOCK 
  Goto AB_TR1 
 Endif  
   
 [L]EXIST=1 
 Readlock [F:MVC]MVC0=[L]CLIENT;[F:DUD]FCY 
 If fstat=1 
  GOK=-1 : GLOCK="$BPCUSTMVT"-[L]CLIENT-[F:DUD]FCY 
  Goto ROLL_TR1 
 Elsif fstat 
  [L]EXIST=0 
  Raz [F:MVC] 
  [F:MVC]BPCNUM    = [L]CLIENT
  [F:MVC]FINRSPFCY = [F:DUD]FCY 
 Endif 
 [F:MVC]FUPDAT = datesyst 
 [F:MVC]FUPLEV = max([F:MVC]FUPLEV,[F:DUD]LEVFUP+1)  
 If [L]EXIST
  If dim([F:MVC]UPDDAT)>0 : [F:MVC]UPDDAT = date$     : Endif 
  If dim([F:MVC]UPDUSR)>0 : [F:MVC]UPDUSR = GUSER     : Endif
  If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif
  Rewrite [F:MVC]  
 Else 
  I=find([F:DUD]CPY,GSOC(1..GNBSOC))
  If !I
   GOK=0 : I=1 : Call ERREURT("!find('"+[F:DUD]CPY+"',GSOC(1..GNBSOC))",I) From GESECRAN : Return
  Endif
  [F:MVC]ACCCUR = GDEVSOC(I)
  If dim([F:MVC]CREDAT)>0 : [F:MVC]CREDAT = date$     : Endif
  If dim([F:MVC]CREUSR)>0 : [F:MVC]CREUSR = GUSER     : Endif
  If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif 
  Write [F:MVC] 
 Endif
 If fstat 
  GOK=0 : Call RSTA("MVC",[L]CLIENT-[F:DUD]FCY) From GLOCK 
  Goto AB_TR1 
 Endif  
Commit 
Return 
 
$ROLL_TR1
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1 
Rollback 
Return 

# Simulation
$TR2
Trbegin [FUP]
# Mise à jour table des relances
 Raz [F:FUP]  
 [F:FUP] = [F:DUD]
 [F:FUP]ADD    = [L]ADD_CLI
 [F:FUP]BPRFUP = [L]CLIENT
 [F:FUP]ACCDAT = [F:HAE]ACCDAT 
 If [L]CALAGIO
  [F:FUP]DEPRAT = [L]TXAGIO 
  [F:FUP]BANCRG = [L]AGIO 
 Endif
 [F:FUP]SIM    = 2
 # LEVFUP sert à la rupture par nombre de jours de retard
 [F:FUP]LEVFUP = J
 [F:FUP]NBRDAY = [L]SEUIL(J)
 [F:FUP]DATEDT = datesyst 
 [F:FUP]DATREF = [L]DATREF
 [F:FUP]NUMEDT = [L]NUMREQ
 If [L]RELFCY
  [F:FUP]FLGFCY=1
  [F:FUP]GRPCRI = [F:DUD]FCY+";"+[L]CLIENT
 Else
  [F:FUP]GRPCRI = [F:DUD]CPY+";"+[L]CLIENT
 Endif
 Write [F:FUP] 
 If fstat 
  GOK=0 : Call FSTA("FUP") From GLOCK 
  Goto AB_TR2
 Endif 
 
 # Prise en compte des crédits
 If [L]CREDIT
  Gosub MAJ_FUPTOT
  If GOK=-1 : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif
 Endif
 
Commit
Return

$ROLL_TR2
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR2 : Endif 
 
$AB_TR2
Rollback 
Return 

$MAJ_FUPTOT
[L]EXIST=1
Readlock [F:FUT]FUT0 = [F:FUP]NUMEDT;[F:FUP]GRPCRI
If fstat=1 
 GOK=-1 : GLOCK="$FUPTOT"-num$([F:FUP]NUMEDT)-[F:FUP]GRPCRI
 Return
Elsif fstat
 [L]EXIST=0
 Raz [F:FUT]
 [F:FUT] = [F:FUP]
Endif
[F:FUT]AMT += ([F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC)*[F:DUD]SNS
[F:FUT]MAXLEV = max([F:FUT]MAXLEV,[F:FUP]LEVFUP)
If [L]EXIST
 Rewrite [F:FUT]
Else
 Write [F:FUT]
Endif
If fstat
 GOK=0 : Call FSTA("FUT") From GLOCK
 Return
Endif
Return

$NBRDAY
J=0
For I=1 To [L]NBSEUIL
 If [L]DATREF-[F:DUD]DUDDAT<[L]SEUIL(I) : Break : Endif
 J=I
Next
Return

########################################################################### 
 
$OUVRE 
Local File TABCUR [TCU]
& , GACCDUDATE [DUD]
& , GACCDUDATE [DUD2]
& , GRPSAC     [GSC]
& , FUP        [FUP]
& , FUP        [FUP2]
& , FUPTOT     [FUT]
& , GACCENTRY  [HAE]
& , BPCUSTOMER [BPC]
& , GTYPACCENT [GTE]
& , BPCUSTMVT  [MVC]
& , COMPANY    [CPY]
& , PERIOD     [PER]
& , BPARTNER   [BPR]
& , GACCOUNT   [GAC]
& , BALANCE    [BAL]
& , GACCENTRYD [DAE]
& , BPADDRESS  [BPA]
& , FISCALYEAR [FIY]
& , AFCTFCY    [AFF]
& , ACCES      [ACC]
& , FACILITY   [FCY]
Return 
 
$DECLARE 
Local Integer SEUILCLI , CREDITEUR , RELPAY , CALAGIO , TAUXCLI , RELFCY , RELDEV
&             , CONTCLI , NUMREQ , SEUIL(1..9) , ALLSAC , I , J , STAT
&             , OK , EXIST , LIG , DUDLIG , NBSEUIL , CREDIT
&             , OKSITE, OKCLI, DELAI
Local Decimal AGIO , TAUX , TXAGIO , MNTMIN , MNT , SOLDE , MONTANT
Local Char    CRITERE(255) , CRITGRPSAC(255) , CRITFUP(255) , TYP(3) , NUM(15)
&             , PARAM(30) , VALEUR(30) , CPYDEB(3) , CPYFIN(3) , CLIENT(15)
&             , GCOLL(5) , COLL(5) , LIT(3)(1..9) , ADD(3) , ADD_CLI(3) , FONCTION(10)
Local Date    DATREF
Local Char    LANGUE(3) , LANDOS(3) , ETAT(20) , SERVEUR(50) , RACINE(20) , SUFFIXE(20)
Return 
 


