#############################################################################################


Subprog IMPRIME(NBPAR,PARAMETRE)
Value Integer NBPAR
Variable Char PARAMETRE()()


Call EXEC(NBPAR,PARAMETRE)

End

#################################################
Subprog EXEC(NBPAR,PARAMETRE)
 Value    Integer NBPAR 
 Variable Char    PARAMETRE()()

 Gosub OUVRE

  Local Char    CRITERE(255), CRITSUP(100), PARAM(30) , VALEUR(30) , ETAT(15)
  Local Integer NUMREQ

[L]CRITERE = "1=1"
[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "fournisseurdeb"
         WPROVEINI = [L]VALEUR
   When "fournisseurfin"
         WPROVEFIN = [L]VALEUR
   When "datedeb"        
         AA = val(mid$([L]VALEUR, 1, 4))
         MM  = val(mid$([L]VALEUR, 5, 2))
         DD = val(mid$([L]VALEUR, 7, 2))  
         WFECHAINI = gdat$(DD,MM,AA)
   When "datefin"        
         AA = val(mid$([L]VALEUR, 1, 4))
         MM  = val(mid$([L]VALEUR, 5, 2))
         DD = val(mid$([L]VALEUR, 7, 2))  
         WFECHAFIN = gdat$(DD,MM,AA)
   When "user"
         WUSER = [L]VALEUR
  Endcase
 Endif
Next

    Gosub BORRA
    Gosub CALCULA


End
#################################################
$OUVRE

If clalev([F:SID])=0 : Local File SINVOICED [SID] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
If clalev([F:SPL])=0 : Local File SPRICLIST [SPL] : Endif
If clalev([F:ZRY])=0 : Local File ZRPTROYAL [ZRY] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
If clalev([F:ZIR])=0 : Local File ZITMROY   [ZIR] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:REP])=0 : Local File SALESREP  [REP] : Endif


Local Integer WPORCEN
Local Decimal WPRIMAY
Local Decimal WTOTMAY
Local Char    WPROVEINI
Local Char    WPROVEFIN
Local Date    WFECHAINI
Local Date    WFECHAFIN
Local Char    WUSER
Local Char    WCRIT(250)
Local Char    WBPR
Local Decimal WPRITAR
Local Decimal WTOTALITM
Local Decimal WIMPORTE
Local Decimal WGASTRA
Local Decimal WPORTRA
Local Decimal WGASCOM


Return

#################################################
$BORRA

Trbegin [ZRY]
Filter [ZRY] Where [ZRY]USER = WUSER Order By Key ZRY1

For [ZRY]
    Delete [ZRY]
Next

Filter [ZRY]
Commit

Return

#################################################
$CALCULA

#--> Filtro facturas 
WCRIT = ""
WCRIT = "1=1"
WCRIT -= '& ACCDAT >=[' +format$(GFMD,WFECHAINI)+ ']' 
WCRIT -= '& ACCDAT <=[' +format$(GFMD,WFECHAFIN)+ ']' 
WCRIT -= '& INVTYP <> 5'


Filter [SIH] Where evalue(WCRIT) Order By Key SIH0
For [SIH]SIH0
    WBPR = [SIH]BPR
    Read [BPR]BPR0 = WBPR
    If fstat = 0 Then
        If [BPR]BETFCY <> 1 Then : Goto SIGUIENTE : Endif
    Endif
    For [SID]SID0 Where [SID]NUM = [SIH]NUM
        #Busqueda tarifa
        Gosub BUSCA_TARIFA
        Gosub BUSCA_ROYALTIE
    Next

$SIGUIENTE
Next
Filter [SIH]
Return

#################################################
$BUSCA_TARIFA
Local Integer SWTAR
#-SWTAR cuando 0, no ha encontrado tarifa, cuando 1 si que hay tarifa
SWTAR = 0 
#xbbd    Read [F:SPL]ZSPL0 = "T002";[F:BPR]CRY;[SID]ITMREF
         Read [F:SPL]ZSPL0 = "T002";"ES";[SID]ITMREF

    If fstat = 0 Then
        #--> Mira si la fecha factura esta entre los límites de la fechas de validez de la tarifa
        If [SID]INVDAT >= [F:SPL]PLISTRDAT and [SID]INVDAT <= [F:SPL]PLIENDDAT Then
            WPRITAR = [SPL]PRI
            SWTAR=1
        Else
            SWTAR = 0
        Endif
    Endif
Return

#################################################
$BUSCA_ROYALTIE

    Filter [ZIR] Where [ZIR]BPSNUM >= WPROVEINI and [ZIR]BPSNUM <= WPROVEFIN Order By Key ZIR1
    For [F:ZIR]ZIR1 Where [ZIR]ITMREF = [SID]ITMREF
        #dbgmode(0)=1 : dbgmode(1)=1
        Raz WIMPORTE
        Gosub CALCULO_ROYALTIE
    Next
    Filter [ZIR]
Return

#################################################
$CALCULO_ROYALTIE
   
Local Decimal WIMP45
Local Decimal WSUB45
# --> Centro de coste pertenece a BD
If [SID]TSICOD(1) = "BD" Then
    WPORCEN = 40
Else
    WPORCEN = 50
Endif

# --> Hay tarifa
If SWTAR = 1 Then
    WPRIMAY = (WPRITAR*WPORCEN)/100
    WTOTMAY = (WPRITAR-WPRIMAY)*[SIH]RATCUR
    If WTOTMAY < ([SID]NETPRI*[SIH]RATCUR)
        #Gastos transporte
        WPORTRA =0
        WPORCOM =0
        WGASTRA =0
        WGASCOM =0

        For [F:ADI]ADI0 Where [F:ADI]NUMTAB = '999' and [F:ADI]A1 = [F:BPR]CRY
                WPORTRA = [F:ADI]A2
                Break
        Next 
        If [F:BPR]CRY = "GB" and WPORCEN = 40 Then : WPORTRA = 0 : Endif    
        
        If WPORTRA <> 0 Then : WGASTRA = (WTOTMAY * WPORTRA)/100 : Endif

        #Gastos Comisión
        Read [BPC]BPC0 = WBPR
        If fstat = 0 Then
            Read [REP]REP0 = [F:BPC]REP(0)
            If fstat = 0 Then
                WPORCOM = [F:REP]COMRAT1(0)
            Endif        
        Endif
        WGASCOM = ([SID]NETPRI * WPORCOM)/100

        WIMPORTE += ((WTOTMAY-WGASTRA-WGASCOM) * [SID]QTY * [SIH]SNS *[SIH]RATCUR)
    Else
        WIMP45 = WTOTMAY - ([SID]NETPRI*[SIH]RATCUR)
        WSUB45 = (WIMP45/WTOTMAY)*100
        If WSUB45 < 45 Then

            #--> Gastos transporte
            WPORTRA =0
            WPORCOM =0
            WGASTRA =0
            WGASCOM =0
            For [F:ADI]ADI0 Where [F:ADI]NUMTAB = '999' and [F:ADI]A1 = [F:BPR]CRY
                WPORTRA = [F:ADI]A2
                Break
            Next    
            #--> Excepcion si es Gran Bretańa i el producto BD entonces no hay desc.
            If [F:BPR]CRY = "GB" and WPORCEN = 40 Then : WPORTRA = 0 : Endif
            If WPORTRA <> 0 Then : WGASTRA = ([SID]NETPRI * WPORTRA)/100 : Endif

            #--> Gastos Comisión
            Read [BPC]BPC0 = WBPR
            If fstat = 0 Then
                Read [REP]REP0 = [F:BPC]REP(0)
                If fstat = 0 Then
                    WPORCOM = [F:REP]COMRAT1(0)
                Endif        
            Endif
            WGASCOM = ([SID]NETPRI * WPORCOM)/100

            WIMPORTE += (([SID]NETPRI-WGASTRA-WGASCOM) * [SID]QTY * [SIH]SNS * [SIH]RATCUR)
        Else
            #dbgmode(0)=1 : dbgmode(1)=1
            Goto SIGUIENTE2
        Endif
    Endif

Else
    WIMPORTE += ([SID]NETPRI * [SID]QTY * [SIH]SNS * [SIH]RATCUR)
Endif

    Gosub GRABA_TEMPORAL
$SIGUIENTE2
Return


#################################################
$GRABA_TEMPORAL

Trbegin [ZRY]
Read [ZRY]ZRY0 = [ZIR]BPSNUM;[SID]ITMREF;WUSER
If fstat = 0 Then
    [ZRY]QTY += ([SID]QTY*[SIH]SNS)
    [ZRY]IMPORTE += WIMPORTE
    [ZRY]TOTROYAL += (WIMPORTE * [ZIR]PORCEN)/100
    Rewrite [ZRY]
Else
    [ZRY]BPSNUM = [ZIR]BPSNUM
    [ZRY]ITMREF = [SID]ITMREF
    Read [ITM]ITM0 = [SID]ITMREF
    [ZRY]ITMDES = [ITM]ITMDES1
    [ZRY]QTY = ([SID]QTY*[SIH]SNS)
    [ZRY]IMPORTE = WIMPORTE
    [ZRY]PORCENTAJE = [ZIR]PORCEN
    [ZRY]TOTROYAL = (WIMPORTE * [ZIR]PORCEN)/100
    [ZRY]USER = GUSER
    Write [ZRY]
Endif
Commit

Return


