#<AdxTL>@(#)3.0.0.0 $Revision$

######################################################################################
#------------------------------------------------------------------------------------#
# Migración : Marcamos con #MIG
#
######################################################################################

Subprog ZUNIFAB

Gosub INIT
Gosub EXEC

End
#############################
$INIT
Local Integer XQTY # variable temporal de la ctd producible
Local Decimal WQTY # ctd producible final

If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ZRC]) = 0 : Local File ZRECETA    [ZRC] : Endif
If clalev([F:ZR2]) = 0 : Local File ZRECETA2   [ZR2] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif

Return


##########################################################
$EXEC
Local Integer XNIV     : XNIV = 0       # nivel de estructura
Local Integer XNIV2    : XNIV2 = 0      # nivel de estructura
Local Integer XENTRA   : XENTRA = 0     # indicador de bucle temporal
Local Integer XQTYANT  : XQTYANT = 0    # variable ctd. producible temporal
Local Integer XQTYAHO  : XQTYAHO = 0    # variable ctd. producible temporal
Local Integer GO_OUT
Local Char XFCY
Raz XQTY, WQTY

# Abrir tabla temporal donde se agrupa
Local File ZBOMRET     [ZBM]
Local File ZBOMRET     [ZBM2]

# Reinicia la tabla temporal
Trbegin [ZBM]
    Delete [ZBM] Where ZUSER = GUSER
Commit

# Guardar datos en la tabla temporal desde la tabla principal
# Agrupar por nivel, artículo padre y componente
Filter [ZRC] Where ZUSER = GUSER & NIVCPN = 1 & ITMREF = [M:ZRC0]ITMREFDEB Order By Key ZRC1
Read [ZRC] First
If fstat = 0
    XITMREF = [ZRC]ITMREF
    XBOMALT = [ZRC]BOMALT
    XNIV = 1
    XNIV2 = 1
    XFCY = [ZRC]FCY
    Gosub BUCLE2

    $BUCLE_AGAIN
    XENTRA = 1
    For [ZBM2]ZBM0 Where ZUSER = GUSER & NIVEST = XNIV and ARTINT = 2
        XENTRA = 2
        XITMREF = [ZBM2]CPNITMREF
        XNIV2 = XNIV + 1
        Gosub BUCLE2
    Next
    If XENTRA = 2
        XNIV += 1
        Goto BUCLE_AGAIN
    Endif
Endif
Filter [ZRC]

Local Decimal WPO

# Guardar la cantidad de enlace por todos los niveles respecto a artículo original
Trbegin [ZBM]
For [ZBM]ZBM0 Where ZUSER = GUSER
    If [ZBM]NIVEST = 1
        [ZBM]CENLQTY = [ZBM]ENLQTY
        For [ZRC] Where ZUSER = [ZBM]ZUSER & CPNITMREF = [ZBM]CPNITMREF & ITMREF = [ZBM]ITMREF & NIVCPN = [ZBM]NIVEST
            [ZRC]CPNCST = [ZBM]CENLQTY * [ZRC]CPNCST
            [ZRC]CPNTRF = [ZBM]CENLQTY * [ZRC]CPNTRF
            [ZRC]CPNPRE = [ZBM]CENLQTY * [ZRC]CPNPRE
            Rewrite [ZRC]
        Next

        # Modificar los coste, precio y tarifa de la operación según ctd. enlace
        For [ZR2] Where ZUSER = [ZBM]ZUSER & ITMREF = [ZBM]CPNITMREF & NIVOPE = [ZBM]NIVEST
            [ZR2]OPECST = [ZBM]CENLQTY * [ZR2]OPECST
            [ZR2]OPETRF = [ZBM]CENLQTY * [ZR2]OPETRF
            [ZR2]OPEPRE = [ZBM]CENLQTY * [ZR2]OPEPRE
            Rewrite [ZR2]
        Next
        Rewrite [ZBM]
    Else
        XNIV = [ZBM]NIVEST-1
        XPADRE = [ZBM]ITMREF
        X = [ZBM]ENLQTY

        #---> Ctd de enlace para el material según los padres de el
        $BUCLE
        Read [ZBM2]ZBM1 = GUSER;XNIV;XPADRE
        If fstat = 0
            WPO = [ZBM2]ENLQTY * X
            X = WPO
            XNIV -= 1
            XPADRE = [ZBM2]ITMREF
            Goto BUCLE
        Endif

#        #---> Ańadir las necesidades del mismo material para los niveles anteriores
#        For [ZBM2] Where ZUSER = GUSER and CPNITMREF = [ZBM]CPNITMREF and NIVEST < [ZBM]NIVEST
#            X += [ZBM2]ENLQTY
#        Next

        [ZBM]CENLQTY = X
        # Modificar los coste, precio y tarifa del componente según ctd. enlace
        For [ZRC] Where ZUSER = [ZBM]ZUSER & CPNITMREF = [ZBM]CPNITMREF & ITMREF = [ZBM]ITMREF & NIVCPN = [ZBM]NIVEST
            [ZRC]CPNCST = [ZBM]CENLQTY * [ZRC]CPNCST
            [ZRC]CPNTRF = [ZBM]CENLQTY * [ZRC]CPNTRF
            [ZRC]CPNPRE = [ZBM]CENLQTY * [ZRC]CPNPRE
            Rewrite [ZRC]
        Next
        # Modificar los coste, precio y tarifa de la operación según ctd. enlace
        For [ZR2] Where ZUSER = [ZBM]ZUSER & ITMREF = [ZBM]CPNITMREF & NIVOPE = [ZBM]NIVEST
            [ZR2]OPECST = [ZBM]CENLQTY * [ZR2]OPECST
            [ZR2]OPETRF = [ZBM]CENLQTY * [ZR2]OPETRF
            [ZR2]OPEPRE = [ZBM]CENLQTY * [ZR2]OPEPRE
            Rewrite [ZR2]
        Next
        Rewrite [ZBM]
        X = 0
    Endif
Next
Commit
Gosub ABI2
Return

#################################################################
$BUCLE2
Read [BOH]BOH0 = XITMREF;XBOMALT
If fstat = 0
    For [BOD]BOD0 Where ITMREF=[BOH]ITMREF & BOMALT=[BOH]BOMALT
        Read [ZBM]ZBM0 = GUSER;XNIV2;[BOD]ITMREF;[BOD]CPNITMREF
        If fstat <> 0
            Trbegin [ZBM]
            [ZBM]ZUSER = GUSER
            [ZBM]NIVEST =  XNIV2
            [ZBM]ITMREF =  [BOD]ITMREF
            [ZBM]CPNITMREF = [BOD]CPNITMREF
            Read [ITV]ITV0 = [BOD]CPNITMREF;XFCY
            If fstat = 0
##MIG
                Local Decimal YRERSTO, YALLSTO,YBPRSTO
                YRERSTO=[ITV]GLOALL
                YALLSTO=([ITV]PHYALL+[ITV]CTLALL+[ITV]REJALL)
                YBPRSTO=([ITV]BPRPHYSTO+[ITV]BPRCTLSTO+[ITV]BPRREJSTO)
                YSCOSTO=([ITV]SCOPHYSTO+[ITV]SCOCTLSTO+[ITV]SCOREJSTO)

                [ZBM]DISQTY = [ITV]PHYSTO - YRERSTO - YALLSTO - YBPRSTO - YSCOSTO
##\MIG
            Else
                [ZBM]DISQTY = 0
            Endif
            [ZBM]ENLQTY = [BOD]LIKQTY
            [ZBM]XSEQ = [BOD]BOMSEQ
            # Flag de intermediario
            Read [ITB]ITB0 = [BOD]CPNITMREF;[BOD]BOMALT
            If fstat = 0
                If [ITB]BOMEXIFLG = 2
                    [ZBM]ARTINT = 2
                Else
                    [ZBM]ARTINT = 1
                Endif
            Else
                [ZBM]ARTINT = 1
            Endif

            Write [ZBM]
            Commit
       Else
           If [BOD]BOMSEQ <> [ZBM]XSEQ
                Trbegin [ZBM]
                [ZBM]ENLQTY += [BOD]LIKQTY
                Rewrite [ZBM]
                Commit
           Endif
       Endif
    Next
Endif
Return

################################################################
$ABI2

XNIV = 1
XQTYANT = 0
XQTYAHO = 0
XFIRST = 0

# Proceso de calcular la ctd producible
Gosub CTD_PROD

Return

#################################################################
$CTD_PROD

Local Integer XFLG : XFLG = 0
Local Integer XFLG2 : XFLG2 = 0
Local Integer XIND : XIND = 0
Local Char XPADRE  : XPADRE = [ZRC0]ITMREFDEB

# AUREN 5.789.697 Error longitud código de 15 a 20
#Local Char TABPADRE(15)(1..10)
Local Char TABPADRE(20)(1..10)


Close File [ZBM]
Local File ZBOMRET [ZBM]

$BUCLE_PRINCIPAL
While XFLG <> 1
    # Bucle para averiguar la ctd producible en el nivel actual
    $SIGUIENTE_CPN

    XIND = 0
    For [ZBM]ZBM0 Where NIVEST = XNIV & ITMREF = XPADRE & ZUSER = GUSER #---Order By NIVEST and CPNITMREF

       # AUREN 5.789.697 Control división por 0
       If [ZBM]CENLQTY <> 0
            XQTYAHO = int([ZBM]DISQTY / [ZBM]CENLQTY)
       Endif

        # Si la entera igual a 0 comprobar si al menos podemos producir algo
        If XQTYAHO = 0 and [ZBM]ENLQTY <> 0 Then
            XQTYAHO = int([ZBM]DISQTY / [ZBM]ENLQTY)
        Endif

        # Si un artículo de materia prima no dispone de stock -> Fin proceso
        If XQTYAHO = 0 and [ZBM]ARTINT = 1
            XFLG = 1
            Goto FIN_WHILE
        Else If XQTYAHO = 0 & [ZBM]ARTINT = 2
                TABPADRE(XNIV) = [ZBM]ITMREF
                XPADRE = [ZBM]CPNITMREF
                XFIRST = 0
                XNIV = XNIV + 1
                XIND = 1
                Break
             Endif
        Endif

        If XFIRST = 0
            XQTYANT = XQTYAHO
            XFIRST = 1
        Else
            If XQTYAHO >= 0 and XQTYAHO < XQTYANT
                XQTYANT = XQTYAHO
            Endif
        Endif
        XFLG2 = 1
     Next

    If XFLG2 = 0
        XFLG = 1
        Goto FIN_WHILE
    Endif

    If XIND = 1
        Goto SIGUIENTE_CPN
    Endif

    # Actualizar el variable global de ctd producible
    XQTY = XQTYANT

    # Actualizar el stock disponible de todos los niveles arrestando la ctd producible cálculada
    # de los artículos actuales
    For [ZBM] Where NIVEST = XNIV & ZUSER = GUSER               #Order By NIVEST and CPNITMREF
        XCTD = (XQTY*[ZBM]ENLQTY)
        Trbegin [ZBM]
            If [ZBM]DISQTY > XCTD
                [ZBM]DISQTY = [ZBM]DISQTY - XCTD
            Else
                [ZBM]DISQTY = 0
            Endif
            Rewrite [ZBM]
        Commit

        # otros niveles
        Filter [ZBM2] Where ZUSER = GUSER & CPNITMREF=[ZBM]CPNITMREF & NIVEST <> [ZBM]NIVEST
            For [ZBM2]
                Trbegin [ZBM2]
                    If [ZBM2]DISQTY > XCTD
                        [ZBM2]DISQTY -= XCTD
                    Else
                        [ZBM2]DISQTY = 0
                    Endif
                    Rewrite [ZBM2]
                Commit
            Next
        Filter [ZBM2]
    Next

    # Actualizar el stock disponible del padre de los stocks actuales ańadiendo la ctd producible
    If XNIV <> 1
        XNIV = XNIV - 1
        Read [ZBM]ZBM0 = GUSER;XNIV;TABPADRE(XNIV);XPADRE
        If fstat = 0
            XPADRE = TABPADRE(XNIV)
            Trbegin [ZBM]
            [ZBM]DISQTY += XQTY
            Rewrite [ZBM]
            Commit
        Endif
    Else
        WQTY += XQTY
    Endif
    $FIN_WHILE
Wend

#Infbox "Se puede fabricar :"+ num$(WQTY)+" del artículo "

Filter [ZRC] Where ZUSER=GUSER & NIVCPN=1 & ITMREF=[M:ZRC0]ITMREFDEB Order By Key ZRC0
Read [ZRC] First
If fstat = 0
    Trbegin [ZRC]
    [F:ZRC]UNIFAB = WQTY
    Rewrite [ZRC]
    Commit
Endif

Return
