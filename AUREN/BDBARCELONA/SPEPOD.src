#<AdxTL>@(#)8.0.0.0 $Revision:   1.20  $ Gestión de la máscara POD1
$ACTION
#Infbox ACTION
Case ACTION
 When "FERME" : Gosub FERME   
 When Default
Endcase
Return

$FERME
Local Shortint NOL
Local Integer I

If clalev([F:POQ])=0 : Local File PORDERQ  [POQ] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ  [SOQ] : Endif


NOL =-1
Trbegin [SOQ]
For nolign=1 To [M:POD1]NBLIG
NOL +=1
    If [M:POD1]LINTEX(NOL) <>'' Then
        Read [SOQ]SOQ0 = [M:POD1]ORDREF;[M:POD1]POPLIN;[M:POD1]POQSEQ(NOL)
        If fstat = 0 Then
            [F:SOQ]SOQTEX = [M:POD1]LINTEX(NOL)
            Rewrite [SOQ]             
        Endif
    Endif    

[M]NBLIG = NOL +1
Next
Commit
Return
