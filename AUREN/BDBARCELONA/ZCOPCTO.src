#<AdxTL>@(#)11.0.0.0 $Revision$

#############################################################################################
#                                                                                           #
# CACT    Descripción                   Fecha            Autor                              #
# ------------------------------------------------------------------------------------------#
# ZMV     Proceso copia contratos       31/01/2003       Alex Frances (Infolan)             #
# ZMI     Revisado Migración V5                                                             #
#                                                                                           #
#############################################################################################

$ACTION

Case ACTION
 
 When "DEBUT"  : Gosub DEBUT  
 When "OUVRE"  : Gosub OUVRE    
 When "OK"     : Gosub OK   
 When "SORTIE" : Gosub SORTIE 
 When "FINSAI" : Gosub FINSAI 

 When Default
Endcase
Return


#############################################################################################
$DEBUT
Raz [M:ZCCT]
Return

#############################################################################################
$SORTIE
   # Call LEC_TRACE From LECFIC
Return

#############################################################################################
$OUVRE

If clalev([F:POC])=0 : Local File PORDERC  [POC] : Endif
If clalev([F:SOC])=0 : Local File SORDERC  [SOC] : Endif
If clalev([F:POH])=0 : Local File PORDER   [POH] : Endif
If clalev([F:POP])=0 : Local File PORDERP  [POP] : Endif
If clalev([F:SOH])=0 : Local File SORDER   [SOH] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif

If clalev([F:POC1])=0 : Local File PORDERC  [POC1] : Endif
If clalev([F:POC2])=0 : Local File PORDERC  [POC2] : Endif
If clalev([F:SOC1])=0 : Local File SORDERC  [SOC1] : Endif
If clalev([F:SOC2])=0 : Local File SORDERC  [SOC2] : Endif
If clalev([F:POH1])=0 : Local File PORDER   [POH1] : Endif
If clalev([F:POP1])=0 : Local File PORDERP  [POP1] : Endif
If clalev([F:POP2])=0 : Local File PORDERP  [POP2] : Endif
If clalev([F:POP3])=0 : Local File PORDERP  [POP3] : Endif
If clalev([F:POP4])=0 : Local File PORDERP  [POP4] : Endif

Return

#############################################################################################
$OK

Call OUVRE_TRACE("") From LECFIC
Call ECR_TRACE(" ",0) From GESECRAN
Local Integer SWEXISTE

#dbgmode(0) = 1
#dbgmode(1) = 1

Call TEMPON("V") From GESECRAN

Read [POH]POH0 = [M:ZCCT]POHNUMFIN
If fstat = 0
    For [POC]POC0 Where [F:POC]POHNUM = [M:ZCCT]POHNUMDEB        
        SWEXISTE = 0        
        Read [POC1]POC1 = [M:ZCCT]POHNUMFIN;[F:POC]ITMREF;[F:POH]RCPFCY
        If fstat = 0 Then 
            Gosub CONTROL_FLAG
        Else
            For [POC2]POC1 Where [F:POC2]POHNUM = [M:ZCCT]POHNUMFIN and [F:POC2]ITMREF = [F:POC]ITMREF
                SWEXISTE = 1
                Break                
            Next    
            If SWEXISTE = 1 Then
                Call ECR_TRACE("Linea artículo Origen con artículo destino NO COINCIDENTES --> " + [F:POC]ITMREF + " Linea " + num$([F:POC]POPLIN),1) From GESECRAN
            Else
                Gosub CONTROL_FLAG
            Endif
        Endif
    Next
Endif

Call TEMPOFF From GESECRAN
FIN =1
Return

#############################################################################################
$FINSAI

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

#############################################################################################
$CONTROL_FLAG

#Pasar solo tarifas y actualizar precios antiguos y crear nuevos
If [M:ZCCT]FLGSOLTAR = 2 and [M:ZCCT]FLGACTTODO = 2 Then
Trbegin [POP1]
    If fstat Then
       Call ECR_TRACE("No se ha encontrado el articulo -->" + [F:POC]ITMREF + "en el contrato destino",1) From GESECRAN
    Else
      For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [POC1]POPLIN and [POP]ITMREF = [POC1]ITMREF  
          Gosub WR_PORDERP  
      Next  
    Endif
Commit
Endif

#Pasar solo tarifas y creando precios nuevos
If [M:ZCCT]FLGSOLTAR = 2 and [M:ZCCT]FLGCRENUE = 2 Then
    If fstat Then
       Call ECR_TRACE("No se ha encontrado el articulo --> " + [F:POC]ITMREF + "en el contrato destino",1) From GESECRAN
    Else
      For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [F:POC]POPLIN
          Read [POP1]POP0 = [M:ZCCT]POHNUMFIN;[POP]POPLIN;[POP]POPSEQ
          If fstat  Then
              Read [POP2]POP1 = [M:ZCCT]POHNUMFIN;[POP]POPLIN;[POP]POPDAT
              If fstat = 0 Then 
                  #Read [POP3]POP0 = [M:ZCCT]POHNUMDEB;[POP]POPLIN;([POP]POPSEQ-1000)
                  #If fstat = 0 Then
                      Read [POP4]POP0 = [M:ZCCT]POHNUMFIN;[POP]POPLIN;([POP]POPSEQ-1000)
                     Trbegin [POP4]
                         [POP4]POPDAT = [POP]STRDAT
                          Rewrite [POP4]
                     Commit
                  #Endif    
              [F:POP1] = [F:POP]
              [F:POP1]POHNUM = [M:ZCCT]POHNUMFIN
              [F:POP1]GROPRI = [F:POP]GROPRI*[M:ZCCT]FACTOR
              [F:POP1]NETPRI = [F:POP]NETPRI*[M:ZCCT]FACTOR
              Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
              If fstat = 0 Then
                  [F:POP1]STRDAT = [F:POP]STRDAT
                  [F:POP1]POPDAT = [F:POH]ENDDAT
                  [F:POP1]PRHFCY = [F:POH]POHFCY
                  [F:POP1]CREDAT = date$
                  [F:POP1]CREUSR = GUSER
              Endif
              [F:POP1]LINREVNUM = 0
              [F:POP1]QUAFLG = 1
              [F:POP1]EXPNUM = 0
                    Trbegin [POP1]
                      Write [POP1]
                      Call ECR_TRACE("Grabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ)+ " - " + time$ ,0) From GESECRAN
                    Commit
                
                  #Call ECR_TRACE("El articulo " + [F:POP]ITMREF + " ha sido modificado en destino la linea " + num$([POP]POPSEQ) + " no ha sido creada",1) From GESECRAN
              Else
              [F:POP1] = [F:POP]
              [F:POP1]POPDAT = [F:POP]STRDAT
              [F:POP1]POHNUM = [M:ZCCT]POHNUMFIN
              [F:POP1]GROPRI = [F:POP]GROPRI*[M:ZCCT]FACTOR
              [F:POP1]NETPRI = [F:POP]NETPRI*[M:ZCCT]FACTOR
              Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
              If fstat = 0 Then
                  [F:POP1]PRHFCY = [F:POH]POHFCY
                  [F:POP1]CREDAT = date$
                  [F:POP1]CREUSR = GUSER
              Endif
              [F:POP1]LINREVNUM = 0
              [F:POP1]QUAFLG = 1
              [F:POP1]EXPNUM = 0
                  Trbegin [POP1]  
                      Write [POP1]
                      Call ECR_TRACE("Grabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ)+ " - " + time$ ,0) From GESECRAN
                  Commit
             Endif
          Endif    
      Next  
    Endif
Endif

#Pasar tarifas y nuevos artículos y actualizar precios antiguos y crear nuevos
If [M:ZCCT]FLGTARITM = 2 and [M:ZCCT]FLGACTTODO = 2 Then
Trbegin [POC1],[SOC1],[POP1],[POP4]
    If fstat Then
        [F:POC1] = [F:POC]
        [F:POC1]POHNUM = [M:ZCCT]POHNUMFIN
        Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
        If fstat = 0 Then 
            [F:POC1]POHFCY = [F:POH]POHFCY
            [F:POC1]BPSNUM = [F:POH]BPSNUM
            [F:POC1]PRHFCY = [F:POH]POHFCY
            [F:POC1]STRDAT = [F:POH]STRDAT
            [F:POC1]ENDDAT = [F:POH]ENDDAT
        Endif
        [F:POC1]INVQTYPUU = 0
        [F:POC1]INVQTYSTU = 0
        [F:POC1]ORDQTYPUU = 0
        [F:POC1]ORDQTYSTU = 0
        [F:POC1]RCPQTYPUU = 0
        [F:POC1]RCPQTYSTU = 0
        [F:POC1]RTNQTYPUU = 0
        [F:POC1]DLVREQNUM = 0
        [F:POC1]UPDUSR = GUSER
        [F:POC1]RTNQTYSTU = 0
        [F:POC1]LINREVNUM = 0
        [F:POC1]FRTHOR = 0
        [F:POC1]EARQTY = 0
        [F:POC1]EXPNUM = 0

        [F:POC1]CREDAT = date$
        [F:POC1]UPDDAT = date$
        [F:POC1]CREUSR = GUSER


        Write [POC1]
        Call ECR_TRACE("Grabado " + [F:POC]ITMREF + " en PORDERC"+ " - " + time$,0) From GESECRAN
        Read [F:POH]POH0 = [M:ZCCT]POHNUMDEB
        If fstat = 0 Then 
            Read [F:SOH]SOH0 = [F:POH]ORDREF
            If fstat = 0 Then 
                For [F:SOC]SOC0 Where [F:SOC]SOHNUM = [F:SOH]SOHNUM and [F:SOC]SOPLIN = [F:POC]POPLIN
                    Gosub WR_SORDERC
                Next
            Endif
        Endif
       For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [POC1]POPLIN and [POP]ITMREF = [POC1]ITMREF  
           Gosub WR_PORDERP
       Next
    Else

    Read [F:POH]POH0 = [M:ZCCT]POHNUMDEB
        If fstat = 0 Then 
            Read [F:SOH]SOH0 = [F:POH]ORDREF
            If fstat = 0 Then 
                For [F:SOC]SOC0 Where [F:SOC]SOHNUM = [F:SOH]SOHNUM and [F:SOC]SOPLIN = [F:POC]POPLIN
                    Gosub WR_SORDERC
                Next
            Endif
        Endif

      For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [POC1]POPLIN and [POP]ITMREF = [POC1]ITMREF  
          Gosub WR_PORDERP
      Next  
    Endif
Commit
Endif

#Pasar tarifas y nuevos artículos y crear precios nuevos
If [M:ZCCT]FLGTARITM = 2 and [M:ZCCT]FLGCRENUE = 2 Then
Trbegin [POC1],[SOC1],[POP1],[POP4]
    If fstat Then
        [F:POC1] = [F:POC]
        [F:POC1]POHNUM = [M:ZCCT]POHNUMFIN
        Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
        If fstat = 0 Then 
            [F:POC1]POHFCY = [F:POH]POHFCY
            [F:POC1]BPSNUM = [F:POH]BPSNUM
            [F:POC1]PRHFCY = [F:POH]POHFCY
            [F:POC1]STRDAT = [F:POH]STRDAT
            [F:POC1]ENDDAT = [F:POH]ENDDAT
        Endif
        [F:POC1]INVQTYPUU = 0
        [F:POC1]INVQTYSTU = 0
        [F:POC1]ORDQTYPUU = 0
        [F:POC1]ORDQTYSTU = 0
        [F:POC1]RCPQTYPUU = 0
        [F:POC1]RCPQTYSTU = 0
        [F:POC1]RTNQTYPUU = 0
        [F:POC1]DLVREQNUM = 0
        [F:POC1]UPDUSR = GUSER
        [F:POC1]RTNQTYSTU = 0
        [F:POC1]LINREVNUM = 0
        [F:POC1]FRTHOR = 0
        [F:POC1]EARQTY = 0
        [F:POC1]EXPNUM = 0

        [F:POC1]CREDAT = date$
        [F:POC1]UPDDAT = date$
        [F:POC1]CREUSR = GUSER

        Call ECR_TRACE("Grabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ)+ " - " + time$ ,0) From GESECRAN
        Write [POC1]
        
    #Copia a SORDERC
        Read [F:POH]POH0 = [M:ZCCT]POHNUMDEB
        If fstat = 0 Then 
            Read [F:SOH]SOH0 = [F:POH]ORDREF
            If fstat = 0 Then 
                For [F:SOC]SOC0 Where [F:SOC]SOHNUM = [F:SOH]SOHNUM and [F:SOC]SOPLIN = [F:POC]POPLIN
                    Gosub WR_SORDERC
                Next
            Endif
        Endif

       For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [POC1]POPLIN and [POP]ITMREF = [POC1]ITMREF  
           Gosub WR_PORDERP 
       Next
  Else
    #Copia a SORDERC
        Read [F:POH]POH0 = [M:ZCCT]POHNUMDEB
        If fstat = 0 Then 
            Read [F:SOH]SOH0 = [F:POH]ORDREF
            If fstat = 0 Then 
                For [F:SOC]SOC0 Where [F:SOC]SOHNUM = [F:SOH]SOHNUM and [F:SOC]SOPLIN = [F:POC]POPLIN
                    Gosub WR_SORDERC
                Next
            Endif
        Endif
      For [POP]POP0 Where [POP]POHNUM = [M:ZCCT]POHNUMDEB and [POP]POPLIN = [POC1]POPLIN and [POP]ITMREF = [POC1]ITMREF  
          Gosub WR_PORDERP  
      Next  
    Endif
Commit
Endif
Return


#############################################################################################
$WR_PORDERP
  Read [POP1]ZPOP4 = [M:ZCCT]POHNUMFIN;[POP]POPLIN;[POP]POPSEQ;[POP]ITMREF;[POP]STRDAT
  If fstat = 0 and [M:ZCCT]FLGACTTODO = 2 Then
      [F:POP1] = [F:POP]
      [F:POP1]POHNUM = [M:ZCCT]POHNUMFIN
      [F:POP1]GROPRI = [F:POP]GROPRI*[M:ZCCT]FACTOR
      [F:POP1]NETPRI = [F:POP]NETPRI*[M:ZCCT]FACTOR

      Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
      If fstat = 0 Then
          [F:POP1]PRHFCY = [F:POH]POHFCY
          [F:POP1]UPDDAT = [F:POH]CREDAT
          [F:POP1]UPDUSR = [F:POH]CREUSR
      Endif
      Call ECR_TRACE("Regrabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ) + " - " + time$ ,0) From GESECRAN
      Rewrite [POP1]
  Else
      Read [POP4]POP0 = [M:ZCCT]POHNUMFIN;[POP]POPLIN;([POP]POPSEQ-1000)
      If fstat = 0        
          [POP4]POPDAT = [POP]STRDAT
          Rewrite [POP4]
      Endif      
      [F:POP1] = [F:POP]
      [F:POP1]POHNUM = [M:ZCCT]POHNUMFIN
      [F:POP1]GROPRI = [F:POP]GROPRI*[M:ZCCT]FACTOR
      [F:POP1]NETPRI = [F:POP]NETPRI*[M:ZCCT]FACTOR
      Read [F:POH]POH0 = [M:ZCCT]POHNUMFIN
      If fstat = 0 Then
          [F:POP1]STRDAT = [F:POP]STRDAT
          [F:POP1]POPDAT = [F:POH]ENDDAT
          [F:POP1]PRHFCY = [F:POH]POHFCY
          [F:POP1]CREDAT = date$
          [F:POP1]CREUSR = GUSER
      Endif
      [F:POP1]LINREVNUM = 0
      [F:POP1]QUAFLG = 1
      [F:POP1]EXPNUM = 0

      Write [POP1]
      If fstat = 0  
          Call ECR_TRACE("Grabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ)+ " - " + time$ ,0) From GESECRAN        
      Else
         Call ECR_TRACE("No grabado " + [F:POP]ITMREF + " y sequencia " +num$([POP]POPSEQ)+ " - " + time$ ,0) From GESECRAN        
      Endif    

  Endif
Return

#############################################################################################
$WR_SORDERC
Read [F:POH1]POH0 = [M:ZCCT]POHNUMFIN
If fstat = 0 Then 
    Read [F:SOC1]SOC0 = [F:POH1]ORDREF;[F:SOC]SOPLIN
    If fstat = 0 Then
        [F:SOC1]=[F:SOC]
        [F:SOC1]CUSORDREF = [M:ZCCT]POHNUMFIN
        [F:SOC1]SOHNUM = [F:POH1]ORDREF
        [F:SOC1]VLYDATITM = [F:POH1]ENDDAT

        Read [F:SOH]SOH0 = [F:POH1]ORDREF
        If fstat = 0 Then
            [F:SOC1]SALFCY = [F:SOH]SALFCY
            [F:SOC1]BPCORD = [F:SOH]BPCORD
            [F:SOC1]STOFCY = [F:SOH]STOFCY
            Read [F:BPR]BPR0 = [F:SOH]BPCORD
            If fstat = 0 Then : [F:SOC1]BPAADD = [F:BPR]BPAADD : Endif
        Else
            Call ECR_TRACE("Regrabado " + " en SORDERC NO ENCUENTRA EL CONTRATO FIN"+ time$,0) From GESECRAN
        Endif

        [F:SOC1]UPDUSR = GUSER
        [F:SOC1]UPDDAT = date$
        Rewrite [SOC1]
        Call ECR_TRACE("Regrabado " + [F:SOC]ITMREF + " en SORDERC " + time$ ,0) From GESECRAN
    Else
        [F:SOC1]=[F:SOC]
        [F:SOC1]CUSORDREF = [M:ZCCT]POHNUMFIN
        [F:SOC1]SOHNUM = [F:POH1]ORDREF
        [F:SOC1]VLYDATITM = [F:POH1]ENDDAT

        Read [F:SOH]SOH0 = [F:POH1]ORDREF
        If fstat = 0 Then
              [F:SOC1]SALFCY = [F:SOH]SALFCY
            [F:SOC1]BPCORD = [F:SOH]BPCORD
            [F:SOC1]STOFCY = [F:SOH]STOFCY
            Read [F:BPR]BPR0 = [F:SOH]BPCORD
            If fstat = 0 Then : [F:SOC1]BPAADD = [F:BPR]BPAADD : Endif
        Else
            Call ECR_TRACE("Grabado " + " en SORDERC NO ENCUENTRA EL CONTRATO FIN"+ time$,0) From GESECRAN
        Endif

        [F:SOC1]CPLAMT = 0
        [F:SOC1]ORDQTYCUM = 0
        [F:SOC1]DLVQTYCUM = 0
        [F:SOC1]EXTQTY = 0
        [F:SOC1]EARQTY = 0
        [F:SOC1]EARDAT = date$
        [F:SOC1]EARDATCUS = date$
        [F:SOC1]CUMDATEAR = date$
        [F:SOC1]EARQTYCUS = 0
        [F:SOC1]FIMHOR = 0
        [F:SOC1]DSPPRC = 0
        [F:SOC1]ITMREVNUM = 0
        [F:SOC1]UPDUSR = GUSER
        [F:SOC1]CREUSR = GUSER
        [F:SOC1]CREDAT = date$
        [F:SOC1]UPDDAT = date$

        Call ECR_TRACE("Grabado " + [F:SOC]ITMREF + " en SORDERC "+ time$,0) From GESECRAN
        Write [SOC1]
    Endif
Endif    
Return
