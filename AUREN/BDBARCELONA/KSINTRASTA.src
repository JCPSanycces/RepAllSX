#<AdxTL>@(#)7.0.0.0 $Revision$
#<AdxTL>@(#)4.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR 
Variable Char    PARAMETRE()()
Local Integer IMPR, I



Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 

# -- récup. entete de colonne pour les frais et remises
 
[L]CRITERE = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)

  Case [L]PARAM
   When "sociedad"         : [L]CRITERE -= "& CPY>='"+[L]VALEUR+"'"
   When "fecha"  : [L]FECHA = gdat$(val(mid$([L]VALEUR,7,2)),val(mid$([L]VALEUR,5,2)),val(mid$([L]VALEUR,1,4)))
   When "cn8"    : [L]CN8=val([L]VALEUR)
 Endcase
 Endif
Next
  [L]CRITERE-= "& DEBDAT=[L]FECHA"
Gosub TRT_DEB_I
Gosub TRT_DEB_E
  
End

###################################################################
###################################################################

$TRT_DEB_I
[L]CRITERE2=[L]CRITERE + " & FLO=1"
Filter [F:DEB] Where evalue([L]CRITERE2) 

Openo filpath("BQT","INTI","CSV"),0
Gosub DETALLE

Return

##########################################################################
$TRT_DEB_E
[L]CRITERE2=[L]CRITERE + " & FLO=2"
Filter [F:DEB] Where evalue([L]CRITERE2) 

Openo filpath("BQT","INTE","CSV"),0
Gosub DETALLE

Return

##########################################################################

########################################################################### 
 
$OUVRE 
Local File DEB [DEB], TABCOUNTRY[TCY]
Return 
 
$DECLARE 
Local Char    CRITERE(255), CRITERE2(255), PARAM(30) , VALEUR(30)
Local Integer CN8
Local Date FECHA
adxirs=chr$(10)+chr$(13)
adxifs=";"

Return 
 
$DETALLE
For [DEB]DEB0
 If CN8=1
    Wrseq format$("8X",[F:DEB]CUSREF);
 Else
    Wrseq format$("25X",[F:DEB]ITMREF);
 Endif
    Wrseq "";
    Wrseq mid$([F:DEB]EECNAT,len([F:DEB]EECNAT),1);
    Wrseq mid$([F:DEB]EECNAT,len([F:DEB]EECNAT),1);
    Wrseq mid$([F:DEB]EECSCH,2,1)+"    ";
    Wrseq "";

  Filter [TCY] Where EECCOD=[F:DEB]DESCRY and EECCOD<>""   
  For [TCY]TCY0
    Wrseq format$("3X",[F:TCY]CRY);
    Break
  Next
  If [F:DEB]DESCRY="" : Wrseq ""; : Endif

  Filter [TCY] Where EECCOD=[F:DEB]ORICRY and EECCOD<>""
  For [TCY]TCY0
    Wrseq format$("3X",[F:TCY]CRY);
    Break
  Next
  If [F:DEB]ORICRY="" : Wrseq ""; : Endif

    Wrseq format$("2X",[F:DEB]REG);
    Wrseq space$(4);
    Wrseq format$("N0:12.2#",[F:DEB]NETMAS);
    Wrseq format$("N0:10.2#",[F:DEB]EECUNT);
    Wrseq "";
    Wrseq format$("N0:1#",[F:DEB]EECTRN);
    Wrseq format$("N0:10.2#",[F:DEB]FISAMT);
    Wrseq format$("N0:10.2#",[F:DEB]STAAMT);
    Wrseq "";
    Wrseq format$("14X",[F:DEB]ITMREF);
    Wrseq format$("3X",[F:DEB]EECICT);
    Wrseq "";
    Wrseq "";
    Wrseq space$(70);
    Wrseq format$("N0:10.2#",0);
    Wrseq space$(3)
    

Next
Openo



Return


