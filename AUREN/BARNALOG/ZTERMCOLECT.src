# 06.332.012 - JC.28042022.[Ticket:75813] AUDITORÍA 2021 GES-LOG: Cuentas anuales
######################################################################################

######################################################################################
##      Z27 - Buscar terminaciones Colectivo para Sociedad/Tercero
######################################################################################
Subprog TERMINACION_COLECTIVO(SOCIEDAD, TERCERO, COLECTIVO, TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO)
Variable Char SOCIEDAD()
Variable Char TERCERO()
Variable Char COLECTIVO()
Variable Char TERMINACION()
Variable Char CUENTA()
Variable Integer MODIFCOLECTIVO
Variable Integer ERRORCOLECTIVO

Local Integer EXISTE
Local Char NEWCOLEC

    EXISTE=0
    MODIFCOLECTIVO=0
    ERRORCOLECTIVO=0

    If clalev([F:ZAA])=0 : Local File ZEXCCOL[ZAA] : Endif
    If clalev([F:AD1])=0 : Local File ATABDIV[ADI] : Endif
    If clalev([F:GA1])=0 : Local File GACCOUNT[GA1] : Endif

    #Determinar si el colectivo a tratar es General o Intersociedad
    #Auren - PU9
    #Read [F:GA1] GAC1=COLECTIVO
    Read [F:GA1] GAC1=GCURLEG;COLECTIVO
    #Auren - PU9
    If   fstat
        Raz [F:GA1]

    Endif

    TERMINACION=""

    If [F:GA1]ZTIPACCSHO = 2
          NEWCOLEC= COLECTIVO
          #### Tratar colectivo Interesociedad
          #Buscar terminaciones Colectivo para Sociedad/Tercero
          Filter [ZAA] Where CPY= SOCIEDAD and BPR=TERCERO
          For [ZAA]ZAA0
            If [F:ZAA]SUFIJO = right$(COLECTIVO,len(COLECTIVO))
                EXISTE = 1
                Break
            Endif
          Next ZAA
          Filter [ZAA]


          If  EXISTE = 0
            ## NO existe esta terminación Colectivo para Sociedad/Tercero: Se asigna colectivo de ZEXCCOL


            ## Verifcar que esté permitido en la tabla 6006
            Filter [ADI] Where NUMTAB= 6006 and CODE = [F:ZAA]SUFIJO and N1= 2
            For [ADI]CODE

                NEWCOLEC= mid$(COLECTIVO,1, len(COLECTIVO) -1) + [F:ZAA]SUFIJO

                ## Verificar si el colectivo general existe
                Call  VERIFICAR_EXISTE_COLECTIVO(NEWCOLEC, CUENTA, EXISTE )
                If EXISTE = 0
                    ERRORCOLECTIVO=1
                Else
                     MODIFCOLECTIVO = 1
                     COLECTIVO =  NEWCOLEC
                Endif

               Break
            Next ADI

# 06.332.012.ini
            If EXISTE=0 Then
              Case GFONCTION
                When "GESBIC" : COLECTIVO = func ZAULIB01.GET_COLECTIVO(TERCERO,2)
                When "GESBIS" : COLECTIVO = func ZAULIB01.GET_COLECTIVO(TERCERO,3)
              Endcase
            Endif
# 06.332.012.fin

          Else
            ## Verifcar que esté permitido en la tabla 6006
            Filter [ADI] Where NUMTAB= 6006 and CODE = right$(COLECTIVO,len(COLECTIVO)) and N1= 2
            For [ADI]CODE
               TERMINACION=[F:ADI]CODE
               Break
            Next ADI
            If TERMINACION = ""
                ## Terminación no permitida: Se asume el colectivo general

                NEWCOLEC= mid$(COLECTIVO,1, len(COLECTIVO) -1)
                ## Verificar si el colectivo general existe
                Call  VERIFICAR_EXISTE_COLECTIVO(NEWCOLEC, CUENTA, EXISTE )
                If EXISTE = 0
                    ERRORCOLECTIVO=1
                Else
                     MODIFCOLECTIVO = 1
                     COLECTIVO =  NEWCOLEC
                Endif

            Endif
          Endif
          ## Para Intersociedad, la terminación está en el colectivo, en caso de que se asuma el
          ## colectivo general, tampoco hay teminación, se ha modificado el colectivo que se ha
          ## pasado como parámetro
          TERMINACION =""

    Else
        #### Tratar colectivo general
        #Buscar terminaciones Colectivo para Sociedad/Tercero
        Filter [ZAA] Where CPY= SOCIEDAD and BPR=TERCERO
        For [ZAA]ZAA0

            #Comprobar si para esta terminación existe alguna igual y activa en la tabla varia 6006
            Filter [ADI] Where NUMTAB= 6006 and CODE =[F:ZAA]SUFIJO and N1= 2
            For [ADI]CODE
               TERMINACION=[F:ADI]CODE
               Break
            Next ADI
            Filter [ADI]

            If len(TERMINACION) > 0
                #Si existe la terminación. verificar si existe un colectivo formado por el colectivo y la terminación
                NEWCOLEC= COLECTIVO + TERMINACION
                Call  VERIFICAR_EXISTE_COLECTIVO(NEWCOLEC, CUENTA, EXISTE)
                If EXISTE = 1
                    Break
                Else
                    TERMINACION=""
                Endif
            Endif

        Next ZAA
        Filter [ZAA]
# 06.332.012.ini
        If EXISTE=0 Then
          Case GFONCTION
            When "GESBIC" : COLECTIVO = func ZAULIB01.GET_COLECTIVO(TERCERO,2)
            When "GESBIS" : COLECTIVO = func ZAULIB01.GET_COLECTIVO(TERCERO,3)
          Endcase
        Endif
# 06.332.012.fin
    Endif

# 06.332.012.ini
  Case GFONCTION
    When "GESBIC"
      [M:BIC0]BPRSAC = COLECTIVO
      Affzo [M:BIC0]BPRSAC
      [F:SIH]BPRSAC = COLECTIVO
    When "GESBIS"
      [M:BIS0]BPRSAC = COLECTIVO
      Affzo [M:BIS0]BPRSAC
      [F:PIH]BPRSAC = COLECTIVO
  Endcase
# 06.332.012.ini

End


######################################################################################
##      Z27 - Comprobar si existe el colectivo
######################################################################################
Subprog VERIFICAR_EXISTE_COLECTIVO(COLECTIVO,CUENTA, EXISTE)

Variable Char COLECTIVO()
Variable Char CUENTA()
Variable Integer  EXISTE


      EXISTE=0

      If clalev([F:GA1])=0
         Local File GACCOUNT[GA1]
      Endif

      Read [F:GA1] GAC1=GCURLEG;COLECTIVO
      If    fstat=0
        CUENTA= [F:GA1]ACC
        EXISTE=1
      Endif

End





$INICRE
Local Char TERMINACION
Local Char CUENTA

    #Sólo en interactivo
    If !GIMPORT & GWEBSERV <> 2 & len([M:BIS0]BPRSAC) > 0
       Call TERMINACION_COLECTIVO([M:BIS0]CPY, [M:BIS0]BPR, [M:BIS0]BPRSAC, TERMINACION, CUENTA) From ZTERMCOLECT

            If len(TERMINACION) > 0

                # Si hay terminación: ańadirla al colectivo

                [M:BIS0]BPRSAC =  [M:BIS0]BPRSAC + TERMINACION
                Affzo  [M:BIS0]BPRSAC
                [F:PIH]BPRSAC =  [M:BIS0]BPRSAC

                #Poner Cuenta asociada al colectivo
                [M:BIS0]SACACC = CUENTA
                Affzo  [M:BIS0]SACACC

                Infbox "Colectivo/Cuenta modificado." Titled "Información"
            Endif

    Endif

Return
