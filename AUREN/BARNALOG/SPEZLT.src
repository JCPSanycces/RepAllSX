######################################################################################

Subprog VERIFICAR_DATOS(ERROR)
    Variable Integer ERROR
    Local Integer I    : I = 0
    Local Integer RESTO  : RESTO  = 0
    Local Integer VACIO  : VACIO  = 0

    If clalev([F:ZL2])=0 : Local File ZLIQBPRC[ZL2] : Endif

    ERROR = 0

    

    For I=0 To [M]NBLIG-1
        If [M]FLGRESTO(I) = 2
            RESTO  += 1
        Endif
      
        If [M]FLGVACIO(I) = 2
            VACIO  += 1
        Endif

    Next

        If RESTO = 0  | VACIO  = 0
        #### Comprobar si hay más Terceros/Sociedad

         Filter [ZL2] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY 
         Read [ZL2]First
         If fstat<>0                  
            ERROR=2  
         Endif          
         Filter [ZL2]

        
        
    Endif
End
