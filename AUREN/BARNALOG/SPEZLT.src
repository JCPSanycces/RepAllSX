    Affzo [M]UPDFLG(NOL) 
    ######################################################################################

End
######################################################################################
Subprog AM_CODIGO9(VALEUR)
    Variable Char    VALEUR()
    Local    Integer ERROR : ERROR = 0
    Local    Integer NOL   : NOL = nolign-1
    
    If [M]CODIGO8(NOL) = ""
        GERR=1
        GMESSAGE=mess(11,6201,1)
        GOK=0
        mkstat = 2
        End
    Endif
    
    Call BUSQUEDA_CRITERIOS(VALEUR,ERROR)

    If ERROR = 2
        GERR=1
        GMESSAGE=mess(8,6201,1)
        GOK=0
        mkstat = 2
        End
    Endif

    #### 30/11/10 Corrección incidencia detectada en desarrollo inicial    
    [M]UPDFLG(NOL)=1
    Affzo [M]UPDFLG(NOL) 
    ######################################################################################

End
######################################################################################
######################################################################################
Subprog BUSQUEDA_CRITERIOS(CODIGO,ERROR)
    Value    Char    CODIGO
    Variable Integer ERROR
    Local    Integer I
    Local    Integer NOL : NOL = nolign-1 
    
    ERROR = 1
    
    ### 30/11/10 Corrección incidencia
    If len(CODIGO) =0
        End
    Endif
    
    If [M]CODIGO1(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO2(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO3(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO4(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO5(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO6(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO7(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO8(NOL) = CODIGO : ERROR = 2 : Endif
    If [M]CODIGO9(NOL) = CODIGO : ERROR = 2 : Endif    

    For I=0 To [M]NBLIG-1
        If [M]CODIGO1(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO2(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO3(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO4(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO5(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO6(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO7(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO8(I) = CODIGO : ERROR = 2 : Break : Endif
        If [M]CODIGO9(I) = CODIGO : ERROR = 2 : Break : Endif
    Next
    
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ### Buscar el criterio en las agrupaciones del tercero del resto de sociedades
    ###
    ######################################################################################

    If ERROR <> 2   
        Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY  
        For [ZL1]ZLB0         
          If [F:ZL1]CODIGO1 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO2 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO3 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO4 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO5 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO6 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO7 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO8 = CODIGO : ERROR = 2 : Break : Endif
          If [F:ZL1]CODIGO9 = CODIGO : ERROR = 2 : Break : Endif
        Next ZL1
        Filter [ZL1]
    Endif
    ######################################################################################

End
######################################################################################

######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###   Cambio en las especificaciones: No se utiliza
######################################################################################

Subprog BUSQUEDA_RESTO(ERROR)
    Variable Integer ERROR
    Local Integer I    : I = 0
    Local Integer NUM  : NUM = 0

    ERROR = 2

    For I=0 To [M]NBLIG-1
        If [M]FLGRESTO(I) = 2
            NUM += 1
        Endif
    Next

    If NUM = 1 : ERROR = 1 : Endif
End
######################################################################################

######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###   Cambio en las especificaciones: No se utiliza
######################################################################################
Subprog BUSQUEDA_VACIO(ERROR)
    Variable Integer ERROR
    Local Integer I    : I = 0
    Local Integer NUM  : NUM = 0

    ERROR = 2

    For I=0 To [M]NBLIG-1
        If [M]FLGVACIO(I) = 2
            NUM += 1
        Endif
    Next

    If NUM = 1 : ERROR = 1 : Endif
End
######################################################################################
######################################################################################


######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###     En el suspuesto de cambiar el valor de los campos Incluir vacío o Incluir resto a SI, 
###     el sistema verificará si ya existe otro registro del tercero con el valor SI. 
###     en el caso que existiera, al registrar el cambio se actualizará a No el registro que anteriormente 
###     estaba a SI y se informará al usuario mediante un mensaje por pantalla de la sociedad y 
###     número de agrupación que se ha actualizado automáticamente.
###
######################################################################################

Subprog COMPROBAR_VACIO_RESTO_SI
  Local    Shortint NOL : NOL = nolign-1
  Local    Integer I
  
       

    ## Incluir Resto
    For I=0 To [M]NBLIG-1
        
        If [M]FLGRESTO(I) = 2
             Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY and FLGRESTO = 2

             Read [ZL1]First
             If fstat=0                 
              
                Update [ZL2] Where BPRNUM= [F:ZL1]BPRNUM and CPY = [F:ZL1]CPY With FLGRESTO = 1
                
                Call   MESSAGE( "Modificado a NO Incluir Resto de la Sociedad " + [F:ZL1]CPY + " Agrupación " + num$([F:ZL1]NUMAGRP))   From  GESECRAN  
              
                Break
             Endif   
            
             Filter [ZL1]

         Endif
       
    Next
    
    ## Incluir Vacio
    For I=0 To [M]NBLIG-1
        
        If [M]FLGVACIO(I) = 2
             Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY and FLGVACIO = 2

             Read [ZL1]First
             If fstat=0                 
              
                Update [ZL2] Where BPRNUM= [F:ZL1]BPRNUM and CPY = [F:ZL1]CPY With FLGVACIO = 1 
               
                Call   MESSAGE( "Modificado a NO Incluir Vacío de la Sociedad " + [F:ZL1]CPY + " Agrupación " + num$([F:ZL1]NUMAGRP))   From  GESECRAN 
                                
                Break
             Endif   
            
             Filter [ZL1]

         Endif
           
    Next


End

######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###   En el supuesto que el valor de los campos Incluir vacío o Incluir resto 
###   del registro de agrupación se cambie hacia No, el sistema no permitirá 
###   el cambio. Informando al usuario de la sociedad y número de agrupación
###   que contiene el campo a SI.
###          NO SE UTILIZA
######################################################################################

Subprog COMPROBAR_VACIO_RESTO_NO(ERROR)
    Variable Integer ERROR

  Local    Shortint NOL : NOL = nolign-1
  Local    Integer I
  
    End
   

    ## Incluir Resto
    For I=0 To [M]NBLIG-1
        
        If [M]FLGRESTO(I) = 1
             Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY and FLGRESTO = 2

             Read [ZL1]First
             If fstat=0                  
                Call   MESSAGE( "Incluir Resto de la Sociedad " + [F:ZL1]CPY + " Agrupación " + num$([F:ZL1]NUMAGRP) + " es SI")   From  GESECRAN 
                ERROR = 2
 
                Break
             Endif   
            
             Filter [ZL1]

         Endif
       
    Next
    
    ## Incluir Vacio
    For I=0 To [M]NBLIG-1
        
        If [M]FLGVACIO(I) = 1
             Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY and FLGVACIO = 2

             Read [ZL1]First
             If fstat=0               
                                             
                Call   MESSAGE( "Incluir Vacío de la Sociedad " + [F:ZL1]CPY + " Agrupación " + num$([F:ZL1]NUMAGRP) + " es SI")   From  GESECRAN 
                ERROR = 2
               
                Break
             Endif   
            
             Filter [ZL1]

         Endif
           
    Next


End



