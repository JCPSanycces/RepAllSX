#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################################
## SPEZLT - Terceros Liquidaciones                               - JGM - 05/10/2009 ##
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"            : Gosub OUVRE
        When "FILTRE"           : Gosub FILTRE
        When "CREATION"         : Gosub CREATION
        When "APRES_CRE"        : Gosub APRES_CRE
        When "LIENS"            : Gosub LIENS
        When "MODIF"            : Gosub MODIF
        When "APRES_MOD"        : Gosub APRES_MOD
        When "ANNULE"           : Gosub ANNULE
        When "DEFLIG"           : Gosub DEFLIG
        When "INICRE_LIG"       : Gosub INI_LIG    
        When "INIMOD_LIG"       : Gosub INI_LIG   
        When "VERIF_CRE"        : Gosub VERIF
        When "VERIF_MOD"        : Gosub VERIF 
        When "RAZCRE"           : Gosub RAZCRE
        When "VERF_ANU"         : Gosub VERF_ANU
                
        When Default
    Endcase
Return
######################################################################################
$OUVRE
    Gosub DECLARE From TABLEAUX

    Diszo [M:ZLT0]NUMAGRP
    Grizo [M:ZLT0]NUMAGRP
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###     
    ######################################################################################
    If clalev([F:ZL0])=0 : Local File ZLIQBPRC[ZL0] : Endif
    If clalev([F:ZL1])=0 : Local File ZLIQBPRL[ZL1] : Endif
    If clalev([F:ZL2])=0 : Local File ZLIQBPRL[ZL2] : Endif    
    
    ######################################################################################

Return
######################################################################################
$FILTRE
    Default File [ZLT]
Return
######################################################################################
$CREATION
    Gosub CREATION From TABLEAUX
    If GOK < 1  Return  Endif
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ###     En el suspuesto de cambiar el valor de los campos Incluir vacío o Incluir resto a SI, 
    ###     el sistema verificará si ya existe otro registro del tercero con el valor SI. 
    ###     en el caso que existiera, al registrar el cambio se actualizará a No el registro que anteriormente 
    ###     estaba a SI y se informará al usuario mediante un mensaje por pantalla de la sociedad y 
    ###     número de agrupación que se ha actualizado automáticamente.
    ###
    ######################################################################################  

    Call COMPROBAR_VACIO_RESTO_SI
    ######################################################################################  

Return
######################################################################################
$APRES_CRE 
    # -- Regeneración de los indicadores UPDFLG y CREFLG # 
    Gosub LIENS From TABLEAUX
    
Return



######################################################################################
$LIENS
    # -- Generación de líneas en la tabla
    Gosub LIENS From TABLEAUX

    Diszo [M:ZLT0]NUMAGRP
    Grizo [M:ZLT0]NUMAGRP
Return
######################################################################################
$MODIF
    
    Gosub MODIF From TABLEAUX
    If GOK < 1  Return  Endif

    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ###     En el suspuesto de cambiar el valor de los campos Incluir vacío o Incluir resto a SI, 
    ###     el sistema verificará si ya existe otro registro del tercero con el valor SI. 
    ###     en el caso que existiera, al registrar el cambio se actualizará a No el registro que anteriormente 
    ###     estaba a SI y se informará al usuario mediante un mensaje por pantalla de la sociedad y 
    ###     número de agrupación que se ha actualizado automáticamente.
    ###
    ######################################################################################  

    Call COMPROBAR_VACIO_RESTO_SI
    ######################################################################################  

Return
######################################################################################
$APRES_MOD 
    # -- Regeneración de los indicadores UPDFLG y CREFLG # 
    Gosub LIENS From TABLEAUX

    

Return
######################################################################################
$ANNULE
    
    Gosub ANNULE From TABLEAUX: # Borrado de líneas
    If GOK < 1  Return  Endif
Return
######################################################################################
$DEFLIG
#----------------------------------#
# Definición del fichero de líneas #
#----------------------------------#
# Criterio de lectura     (CRIT)   #
# Nombre del fichero      (FICLIG) #
# Abreviatura del fichero (ABLIG)  #
# Zona número de línea    (ZONLIG) #
#----------------------------------#
    
    Default Mask [ZLT0]
    Default File [ZLB]
    
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###     Ańadir la sociedad como criterio de selección de las líneas de agrupaciones 
    ###     
    ######################################################################################

    #CRIT = '[F:ZLB]BPRNUM="'+[M:ZLT0]BPRNUM+'"'
    #### Ańadir la sociedad como criterio de selección de las líneas de agrupaciones 
    CRIT = '[F:ZLB]BPRNUM="'+[M:ZLT0]BPRNUM+'"' + " AND " + '[F:ZLB]CPY="'+[M:ZLT0]CPY+'"'
    ######################################################################################

#    CRIT = '[F:ZLB]YNUM="'+[M:YBA0]YNUM+'"'
    FICLIG = "ZLIQBPRL": ABLIG = "ZLB"
    ZONLIG = "NUMAGRP"
Return
######################################################################################
$INI_LIG
# -- alim no pedido
    [F:ZLB]BPRNUM = [F:ZLT]BPRNUM

    ### 29/11/10 Ańadir Sociedad en las líneas de detalle Agrupación
    [F:ZLB]CPY = [F:ZLT]CPY

Return
######################################################################################

######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###   El sistema no permitirá borrar toda la ficha tercero-sociedad en el 
###   suspuesto que dicha ficha contenga alguna agrupación con los campos Incluir vacío 
###   o Incluir resto a SI y además exista otra ficha tercero-sociedad con el mismo tercero.
######################################################################################
$VERF_ANU
 Local Integer I    : I = 0
 Local    Integer ERROR : ERROR = 0 


    ERROR = 2

    For I=0 To [M]NBLIG-1
        If [M]FLGRESTO(I) = 2
            ERROR = 1
            Break
        Endif
        If [M]FLGVACIO(I) = 2
            ERROR = 1
            Break
        Endif

    Next

    If ERROR = 1 
         Filter [ZL0] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY 
         Read [ZL0]First
         If fstat=0                  
            GMESSAGE="No se puede borrar este Tercero/Sociedad. Hay alguna agrupación con los campos Incluir vacío o Incluir resto a SI y además exista otra ficha tercero-sociedad con el mismo tercero."
            OK=0
            mkstat = 2  
         Endif          
         Filter [ZL0]
    Endif


Return


#################################################################
$VERIF
    Local    Integer ERROR : ERROR = 0    

    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ###   Cambio en las especificaciones
    ######################################################################################

    #Call BUSQUEDA_RESTO(ERROR)
    #If ERROR = 2
    #    GERR=1
    #    GMESSAGE=mess(9,6201,1)
    #    OK=0
    #    mkstat = 2
    #    Return
    #Endif
    
    #ERROR = 0
   #Call BUSQUEDA_VACIO(ERROR)
    #If ERROR = 2
    #    GERR=1
    #    GMESSAGE=mess(10,6201,1)
    #    OK=0
    #    mkstat = 2
    #    Return
    #Endif
    
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ######################################################################################
    If GREP ="C"

        Call VERIFICAR_DATOS(ERROR)
        If ERROR = 2
            GERR=1
            GMESSAGE="Tiene que haber un Incluir vacio y un Incluir resto con SI"
            OK=0
            mkstat = 2
            Return
        Endif

    Endif

    If GREP ="D"
        ### Si se ha duplicado: Comprobar que los criterios no existan en otros Tercero/Sociedad
         Local    Integer I: I=0

        For I=0 To [M]NBLIG-1
                        Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY  
            For [ZL1]ZLB0         
              If [F:ZL1]CODIGO1 = [M]CODIGO1(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO2 = [M]CODIGO2(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO3 = [M]CODIGO3(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO4 = [M]CODIGO4(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO5 = [M]CODIGO5(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO6 = [M]CODIGO6(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO7 = [M]CODIGO7(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO8 = [M]CODIGO8(I): ERROR = 2  : Break : Endif
              If [F:ZL1]CODIGO9 = [M]CODIGO9(I): ERROR = 2  : Break : Endif
            Next ZL1
            Filter [ZL1]
            If  ERROR = 2
                Break
            Endif

        Next

       If  ERROR = 2
            GERR=1
            GMESSAGE= "Criterio de Agrupación duplicado en otra sociedad del tercero."
            GOK=0
            mkstat = 2   
       Endif    
    Endif

Return
######################################################################################
$RAZCRE
    Diszo [M:ZLT0]NUMAGRP
    Grizo [M:ZLT0]NUMAGRP
Return
######################################################################################

Subprog C_NBLIG
    Local    Shortint NOL : NOL = nolign-1

    If status =73
        GMESSAGE= "No se  permite insertar una agrupación. Ańádala al final."
            mkstat=2
            End
    Endif
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ### 
    ###   El mantenimiento no permitirá eliminar un registro de agrupación 
    ###   en el supuesto que el valor de los campos Incluir vacío o 
    ###   Incluir resto contenga SI.
    ######################################################################################
    If status = 65
        If [M]FLGVACIO(NOL) = 2 | [M]FLGRESTO(NOL) = 2 
            GMESSAGE= "No se  permite eliminar un registro de agrupación con Incluir vacío o Incluir resto SI."
            mkstat=2
            End
        Endif
    Endif   
    ###################################################################################### 
    If NOL = 0 and [M]NUMAGRP(NOL) = 0
        [M]NUMAGRP(NOL) = 1
    Else
        If [M]NUMAGRP(NOL) = 0
            [M]NUMAGRP(NOL) = [M]NUMAGRP(NOL-1) + 1
        Endif
    Endif
End


######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###   En el supuesto que el valor de  Incluir Vacio 
###   del registro de agrupación se cambie hacia No, el sistema no permitirá 
###   el cambio. 
###  
######################################################################################
Subprog AM_FLGVACIO(VALEUR)
Variable Integer VALEUR
Local    Shortint NOL :    NOL = nolign-1
Local    Integer  I
Local    Integer  ERROR  : ERROR = 0 
  
    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ###   Cambio en las especificaciones
    ######################################################################################
    #If VALEUR <> 2 
    #     End 
    # Endif

    #For I=0 To [M]NBLIG-1
    #    If I <> NOL
    #        [M]FLGVACIO(I) = 1
    #        [M]UPDFLG(I) =1
    #        Affzo [M]FLGVACIO(I)
    #        Affzo [M]UPDFLG(I)
    #    Endif
    #Next
    ######################################################################################
   
    #### 30/11/10 Corrección incidencia detectada en desarrollo inicial
    Local    Integer NOL   : NOL = nolign-1
    [M]UPDFLG(NOL)=1
    Affzo [M]UPDFLG(NOL) 

    
    If VALEUR = 1
        ### Valor NO
        If [M]ZFLGVACIO(NOL)= 0            
            [M]ZFLGVACIO(NOL)=1
        Endif

        If [M]ZFLGVACIO(NOL)<> VALEUR 
            ERROR =1     
        Else
            
           # If ERROR = 0
                ### Si  existen más Registros para este Tercero
           #     Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY 
           #      Read [ZL1]First
           #      If fstat =0
           #         ERROR = 1               
           #      Endif 
           #      Filter [ZL1]
    
           # Endif            
        Endif
        If ERROR =1
            GMESSAGE= "Antes de cambiar Incluir Vacio a NO, ha de modificar en otra Agrupación Incluir Vacio a SI"
            mkstat=2
        Endif
    Else
        ### Valor SI
        For I=0 To [M]NBLIG-1
            If I <> NOL
              If [M]FLGVACIO(I) = 2
                 [M]FLGVACIO(I)=1 
                 [M]UPDFLG(I) =1
                 Affzo [M]FLGVACIO(I)
                 Affzo [M]UPDFLG(I)
                 GMESSAGE= "Se ha cambiado en la Agrupación " + num$([M]NUMAGRP(I)) + " Incluir Vacio a NO."
                 GERR=2   
                 Break
               Endif
            Endif
        Next

    Endif


End
######################################################################################

######################################################################################
###
### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
###
###   En el supuesto que el valor de  Incluir resto 
###   del registro de agrupación se cambie hacia No, el sistema no permitirá 
###   el cambio. 
###  
######################################################################################
Subprog AM_FLGRESTO(VALEUR)
Variable Integer VALEUR
Local    Shortint NOL : NOL = nolign-1
Local    Integer  I
Local    Integer  ERROR  : ERROR = 0 

    ######################################################################################
    ###
    ### 30/11/2010 MODIFICACIONES TERCERO/SOCIEDAD
    ###
    ###   Cambio en las especificaciones
    ######################################################################################
    #If VALEUR <> 2 
    #     End 
    # Endif
    
    #For I=0 To [M]NBLIG-1
    #    If I <> NOL
    #       [M]FLGRESTO(I) = 1
    #        [M]UPDFLG(I) =1
    #        Affzo [M]FLGRESTO(I)
    #        Affzo [M]UPDFLG(I)
    #    Endif
    #Next
    ######################################################################################

   #### 30/11/10 Corrección incidencia detectada en desarrollo inicial
    Local    Integer NOL   : NOL = nolign-1
    [M]UPDFLG(NOL)=1
    Affzo [M]UPDFLG(NOL) 
 
   If VALEUR = 1
        ### Valor NO
        If [M]ZFLGRESTO(NOL)= 0            
            [M]ZFLGRESTO(NOL)=1
        Endif

        If [M]ZFLGRESTO(NOL)<> VALEUR 
            ERROR =1     
        Else
            
           # If ERROR = 0
           #     ### Si  existen más Registros para este Tercero
           #     Filter [ZL1] Where BPRNUM= [M:ZLT0]BPRNUM and  CPY <>[M:ZLT0]CPY 
           #      Read [ZL1]First
           #      If fstat =0
           #         ERROR = 1               
           #      Endif 
           #      Filter [ZL1]
    
           # Endif            
        Endif
        If ERROR =1
            GMESSAGE= "Antes de cambiar Incluir Resto a NO, ha de modificar en otra Agrupación Incluir Resto a SI"
            mkstat=2
        Endif
    Else
        ### Valor SI
        For I=0 To [M]NBLIG-1
            If I <> NOL
              If [M]FLGRESTO(I) = 2
                 [M]FLGRESTO(I)=1 
                 [M]UPDFLG(I) =1
                 Affzo [M]FLGRESTO(I)
                 Affzo [M]UPDFLG(I)
                 GMESSAGE= "Se ha cambiado en la Agrupación " + num$([M]NUMAGRP) + " Incluir Resto a NO."
                 GERR=2 
                 Break
              Endif
            Endif
        Next

    Endif
End
######################################################################################
Subprog AM_CODIGO1(VALEUR)
    Variable Char    VALEUR()
    Local    Integer ERROR : ERROR = 0
    
    #### 01/12/10 Corrección incidencia detectada en desarrollo inicial 
    Local    Integer NOL   : NOL = nolign-1
    If len(VALEUR) = 0 & len([M]CODIGO2(NOL)) >0
        GMESSAGE="Criterio no puede estar vacío "
        GOK=0
        mkstat = 2
        End  
    Endif
    ####################################################################
    
    Call BUSQUEDA_CRITERIOS(VALEUR,ERROR)

    If ERROR = 2
        GERR=1
        GMESSAGE=mess(8,6201,1)
        GOK=0
        mkstat = 2
        End    
    Endif

    #### 30/11/10 Corrección incidencia detectada en desarrollo inicial    
    [M]UPDFLG(NOL)=1
    Affzo [M]UPDFLG(NOL) 
    ####################################################################
End
