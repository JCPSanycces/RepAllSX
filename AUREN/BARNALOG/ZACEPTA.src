##################################################
## Z09 - SUBPROGRAMA ZPREACEPTA
## Recibe parámetro NUM -> número factura recibida
## Marca estado como preaceptado y actualiza vtos.
##################################################

Subprog ZPREACEPTA(NUMFRA)
Value    Char    NUMFRA

    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif

    Read [PIH]PIH0 = NUMFRA
    If !fstat
        If [PIH]ZACEPTA = 1
            Update [PIH] Where NUM = NUMFRA With PAZ = 3
            Update [PIH] Where NUM = NUMFRA With ZACEPTA = 3
            Update [DUD] Where NUM = NUMFRA With FLGPAZ = 3
        Endif
    Endif
End

Subprog ZACEPTA(NUMFRA)
Value    Char    NUMFRA
    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif

    Read [PIH]PIH0 = NUMFRA
    If !fstat
        If [PIH]ZACEPTA = 1
            Update [PIH] Where NUM = NUMFRA With PAZ = 4
            Update [PIH] Where NUM = NUMFRA With ZACEPTA = 4
            Update [DUD] Where NUM = NUMFRA With FLGPAZ = 4
        Endif
        If [PIH]ZACEPTA = 3
            Update [PIH] Where NUM = NUMFRA With PAZ = 4
            Update [PIH] Where NUM = NUMFRA With ZACEPTA = 4
            Update [DUD] Where NUM = NUMFRA With FLGPAZ = 4
        Endif
    Endif
End

Subprog ZESTADOFREC(NUMFRA,ESTADO,WERRCOD,WERRSTR)
Value    Char    NUMFRA
Value    Integer ESTADO

Variable Integer WERRCOD
Variable Char    WERRSTR

    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif

    Read [PIH]PIH0 = NUMFRA
    If !fstat
        If [PIH]PAZ = 4 Then
          # es innecesario generar error. lpardo 24.02.2012
          WERRCOD = 0
          WERRSTR = ""

          # la factura ya esta aceptada, no hacer nada
          #WERRCOD = 1
          #WERRSTR = "La factura "+NUMFRA+" ya esta aceptada"
        Else

#          [PIH]PAZ = ESTADO
#          [PIH]ZACEPTA = ESTADO
#          Rewrite [PIH]
#          Filter [DUD] Where NUM = NUMFRA
#          For [DUD]
#            [DUD]FLGPAZ = ESTADO
#             Rewrite [DUD]
#          Next
#          Filter [DUD]

           Update [PIH] Where NUM = NUMFRA With PAZ = ESTADO
           Update [PIH] Where NUM = NUMFRA With ZACEPTA = ESTADO
           Update [DUD] Where NUM = NUMFRA With FLGPAZ = ESTADO

          WERRCOD = 0
          WERRSTR = ""
        Endif
    Else
        WERRCOD = 2
        WERRSTR = "La factura "+NUMFRA+" no existe"
    Endif
End

Subprog ZRETENFREC(NUMFRA,MOTIVO,WERRCOD,WERRSTR)
Value    Char    NUMFRA
Value    Char    MOTIVO

Variable Integer WERRCOD
Variable Char    WERRSTR

    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif
#AUREN - PU9
    If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
#AUREN - PU9

    Read [PIH]PIH0 = NUMFRA
    If !fstat
        If [PIH]PAZ = 4 Then
          # es innecesario generar error. lpardo 24.02.2012
          WERRCOD = 0
          WERRSTR = ""

          # la factura ya esta aceptada, no hacer nada
          #WERRCOD = 1
          #WERRSTR = "La factura "+NUMFRA+" ya esta aceptada"
        Else

#AUREN - PU9
     Update [ZPX] Where NUM = NUMFRA With ZMOTIVRET = MOTIVO
#AUREN - PU9
#         [PIH]ZMOTIVRET = MOTIVO

           Update [PIH] Where NUM = NUMFRA With PAZ = 2
           Update [PIH] Where NUM = NUMFRA With ZACEPTA = 2
           Update [DUD] Where NUM = NUMFRA With FLGPAZ = 2

#          [PIH]PAZ = 2
#          [PIH]ZACEPTA = 2
#          Rewrite [PIH]

#          Filter [DUD] Where NUM = NUMFRA
#          For [DUD]
#            [DUD]FLGPAZ = 2
#             Rewrite [DUD]
#          Next
#          Filter [DUD]

          WERRCOD = 0
          WERRSTR = ""
        Endif
    Else
        WERRCOD = 2
        WERRSTR = "La factura "+NUMFRA+" no existe"
    Endif
End



Subprog ZGETNUMEROCONTADOR(CODIGOCONTADOR,CPY,VALORCONTADOR,WERR,WERRSTR)
Value    Char    CODIGOCONTADOR
Value    Char    CPY

Variable Char    VALORCONTADOR
Variable Integer WERR
Variable Char    WERRSTR

Call NUMERO(CODIGOCONTADOR,CPY,datesyst,"ADMIN",VALORCONTADOR,WERR) From SUBANM
If WERR <> 0 Then
  VALORCONTADOR = 0
  WERRSTR = "No se ha podido obtener valor para el contador"
Endif

End

