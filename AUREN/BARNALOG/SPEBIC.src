## Etiqueta aþadida por el supervisor (pantalla BIC3) 24/07/2017 14:08:59 (ADMIN)
######################################################################################
Subprog AM_TAX1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
  [M]TAX1(nolign-1)= VALEUR
  Gosub CALTVA From SUBBIC2
  If STAT
    Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
    Call ERREUR(MESSA) From GESECRAN : mkstat = 2 : End
  Endif
Endif
End
