$ACTION
Case ACTION

    When "SETBOUT"        : Gosub SETBOUT
When "AVANTBOUT" : Gosub AVANTBOUT
        When "STYLE"    : Gosub OCULTAR
        When "LIENS"    : Gosub OCULTAR
        When "RAZCRE"   : Gosub OCULTAR

    ######################################################################################
    #        Z27  Gestiû°n terminaciû°n colectivo sociedad/tercero
    ######################################################################################

     When "INICRE"           : Gosub INICRE
     When "INIMOD"           : Gosub INICRE
     When "VERIF_CRE"        : Gosub VERIF_CRE
    ######################################################################################


     When Default
Endcase
Return

$AVANTBOUT

  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARêMETRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")
  #####AUREN.FIN
  ###########################################################################################

If BOUT="w"
###AUREN.STR 25-10-2021
   Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + [M:BIC0]NUM,
&"UIAdxPubSubFile="+chr$(1)+"1"
#####AUREN.FIN

Endif
Return

$VERIF_CRE

    ####################################################################################
    ## AUREN 6.260.887 Inicializar mandato para creaciµn factura por WS
    Local Char XMANDATO
    If [M:BIC1]UMRNUM='' & GWEBSERV
       Call INIT_UMRNUM(GSOCIETE,[M:BIC1]BPRPAY,2,2,XMANDATO) From INVSDDLIB
       [M:BIC1]UMRNUM=XMANDATO
       Affzo  [M:BIC1]UMRNUM
    Endif
    ## AUREN 6.260.887 Inicializar mandato para creaciµn factura por WS
    ####################################################################################

Return


######################################################################################
#        Z27  Gestiû°n terminaciû°n colectivo sociedad/tercero
######################################################################################

$INICRE
Local Char TERMINACION
Local Char CUENTA
Local Integer MODIFCOLECTIVO
Local Integer ERRORCOLECTIVO

    #Sûô°lo en interactivo
    If !GIMPORT & GWEBSERV <> 2 & len([M:BIC0]BPRSAC) > 0
       Call TERMINACION_COLECTIVO([M:BIC0]CPY, [M:BIC0]BPR, [M:BIC0]BPRSAC, TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT
       If ERRORCOLECTIVO = 1
            GERR=1
            GMESSAGE = "Error en Terminaciµn colectivo. Revise la configuraciµn."
            GOK=0
            Return

       Else

            If len(TERMINACION) > 0   or  MODIFCOLECTIVO = 1

                # Si hay terminaciûô°n: aûôÝadirla al colectivo
                [M:BIC0]BPRSAC =  [M:BIC0]BPRSAC + TERMINACION
                Affzo  [M:BIC0]BPRSAC
                [F:SIH]BPRSAC =  [M:BIC0]BPRSAC

                #Poner Cuenta asociada al colectivo
                [M:BIC0]SACACC = CUENTA
                Affzo  [M:BIC0]SACACC

                Infbox "Colectivo/Cuenta modificado." Titled "Informaciµn"
            Endif
       Endif
    Endif


Return



######################################################################################

$SETBOUT

  If [M]STA = 3
        Call VIREBOUT(CHAINE,"M") From GOBJET     #Boton Registrar deshabilitado si factura validada
  Endif

Return

