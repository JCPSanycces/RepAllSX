$ACTION
Case ACTION
 When "EXEC" : Gosub EXEC_ZVISPDF
Endcase
Return

$EXEC_ZVISPDF

  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO SPEBIS
   Local Char ZPARVERAPU(250) : ZPARVERAPU =func AFNC.PARAM("ZPARVERAPU","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVERAPU + PARAM(1) + "/" + PARAM(2),
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
