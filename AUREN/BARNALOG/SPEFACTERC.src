#<AdxTL>@(#)10.0.0.0 $Revision$

$ACTION

#Infbox (ACTION)

Case ACTION

    When "AV_CHOIX"               : Gosub AV_CHOIX

Endcase

Return



############################################################################################
##
##   Z18 - PRESENTAR LAS FACTURAS TERCERO PROVEEDOR QUE CUMPLA LAS CONDICIONES
##
############################################################################################
$AV_CHOIX
## AUREN - DSM - Abril 2013 - Compres
Local    Char     PARAMOBJET  : PARAMOBJET  = PARAM(1)  ## Objeto en curso
Local    Char     PARAMCPY  : PARAMCPY  = PARAM(2)  ## Sociedad
Local    Char     PARAMBPR  : PARAMBPR  = PARAM(3)  ## Tercero (Proveedor)
Local    Char     PARAMMNT  : PARAMMNT  = PARAM(4)  ## Importe
Local    Date     PARAMDAT  : PARAMDAT  = PARAM(5)  ## Fecha
Local Decimal VARMNT: VARMNT = val(PARAMMNT)
## AUREN - DSM - Abril 2013 - Compres
Local Integer Z : Z=0
Local Char NOMBREPROV: NOMBREPROV=""

  Raz [M:ZFT]

  If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
  If clalev([BPS])<=0 Local File BPSUPPLIER[BPS] : Endif

  # Obtener nombre del proveedor
## AUREN - DSM - Abril 2013 - Compres
##  Read [F:BPS]BPS0=[M:BIS0]ZBPR
  Read [F:BPS]BPS0=PARAMBPR
## AUREN - DSM - Abril 2013 - Compres
  If    fstat=0
    NOMBREPROV  = [F:BPS]BPSNAM
  Endif

  Filter [PIHB]

## AUREN - DSM - Abril 2013 - Compres
#  If [M:BIS1]ZBPRDAT<> [0/0/0]
  If PARAMDAT<> [0/0/0]
## AUREN - DSM - Abril 2013 - Compres

    # Igual Sociedad, Proveedor, importe y fecha de factura
## AUREN - DSM - Abril 2013 - Compres
#    Filter [PIHB1] Where CPY= [M:BIS0]ZCPY and BPRDAT = [M:BIS1]ZBPRDAT and AMTNOT = [M:BIS1]ZAMTNOT and BPR = [M:BIS0]ZBPR Order By BPRDAT Asc; BPRVCR Asc
    Filter [PIHB] Where CPY= PARAMCPY and BPRDAT = PARAMDAT and AMTNOT = VARMNT and BPR = PARAMBPR Order By BPRDAT Asc; BPRVCR Asc
## AUREN - DSM - Abril 2013 - Compres

    # Si existen facturas
    For [PIHB]

        [M:ZFT]BPRVCR(Z)  = [F:PIHB]BPRVCR
        [M:ZFT]BPSNAM(Z)  = NOMBREPROV
        [M:ZFT]NUM(Z)     = [F:PIHB]NUM
        [M:ZFT]BPRDAT(Z)  = [F:PIHB]BPRDAT
        [M:ZFT]AMTNOT(Z)  = [F:PIHB]AMTNOT
        [M:ZFT]AMTATI(Z)  = [F:PIHB]AMTATI
        [M:ZFT]CUR(Z)     = [F:PIHB]CUR
        [M:ZFT]ZNUMREG(Z) = [F:PIHB]ZNUMREG
        [M:ZFT]ZESCDAT(Z) = [F:PIHB]ZESCDAT
        [M:ZFT]NBLIG +=1
        Z +=1
    Next
    Affzo [M:ZFT]
    Filter [PIHB]
  Endif

  If NBLIG = 0
      # Igual Sociedad, Proveedor e importe
## AUREN - DSM - Abril 2013 - Compres
#      Filter [PIHB1] Where CPY= [M:BIS0]ZCPY and BPR = [M:BIS0]ZBPR and AMTNOT = [M:BIS1]ZAMTNOT  and BPRDAT <> [M:BIS1]ZBPRDAT Order By BPRDAT Asc ; BPRVCR Asc
      Filter [PIHB] Where CPY= PARAMCPY and BPR = PARAMBPR and AMTNOT = VARMNT and BPRDAT <> PARAMDAT Order By BPRDAT Asc ; BPRVCR Asc
## AUREN - DSM - Abril 2013 - Compres
        # Si existen facturas
        For [PIHB]

            [M:ZFT]BPRVCR(Z)  = [F:PIHB]BPRVCR
            [M:ZFT]BPSNAM(Z)  = NOMBREPROV
            [M:ZFT]NUM(Z)     = [F:PIHB]NUM
            [M:ZFT]BPRDAT(Z)  = [F:PIHB]BPRDAT
            [M:ZFT]AMTNOT(Z)  = [F:PIHB]AMTNOT
            [M:ZFT]AMTATI(Z)  = [F:PIHB]AMTATI
            [M:ZFT]CUR(Z)     = [F:PIHB]CUR
            [M:ZFT]ZNUMREG(Z) = [F:PIHB]ZNUMREG
            [M:ZFT]ZESCDAT(Z) = [F:PIHB]ZESCDAT
            [M:ZFT]NBLIG +=1
            Z +=1

       Next

       Affzo [M:ZFT]
  Endif

  Filter [PIHB]

Return




######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZFACTERC) 11/05/2010 09:41:13 (ADMIN)
######################################################################################
Subprog IB_BPRDAT
End


