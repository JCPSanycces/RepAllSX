#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "EXEC" : Gosub EXEC_ZESCANER
Endcase
Return

$EXEC_ZESCANER
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + PARAM(1) + "&cpy=" + left$(PARAM(1),3) + "&act=gas",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Return
