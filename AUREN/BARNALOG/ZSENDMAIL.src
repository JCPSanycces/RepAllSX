######################################################################################
### AUREN - DSM - 06/10/2012
### Envio de correos a un pago
######################################################################################
### Nombre Funcion: SENDMAILPAGO
### --------------------------------------
######################################################################################
Subprog SENDMAILPAGO(XFLG, XNUM)
    Variable Char XFLG
    Variable Char XNUM

    #Auren en V12 no existe esta ruta##
    ##Gosub ZENVIOMAILGENERICO
    ## Generar fichero pago y lanzar workflow por cada pago ##
    ############################################################################
    Call OUVRE_TRACE("Proceso envio mail pago : " + XFLG + XNUM) From LECFIC

    Filter [PYH] Where NUM=XNUM
#AUREN - PU9
        Gosub ZCONVERT_PAGOS_XML_PDF_WEB
#    Gosub ZENVIOMAIL
#AUREN - PU9
    Filter [PYH]
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC

End
######################################################################################

## AUREN - DSM - 06/05/2013 - Tratamiento caracteres especiales de XML
Subprog CODE_XML(LIGNE)
Variable Char LIGNE
Gosub SET_CODE
For I=1 To 4
 K = instr(1,LIGNE,CA(I))
 While K
  LIGNE = left$(LIGNE,K-1)+CX(I)+right$(LIGNE,K+len(CA(I)))
  K = instr(K+ len(CX(I))+1,LIGNE,CA(I))
 Wend
Next I
End

$SET_CODE
Local Char CA(1)(1..4) , CX(6)(1..4)
CA(1) = '&' : CX(1) = "&amp;"
CA(2) = ">" : CX(2) = "&gt;"
CA(3) = '"' : CX(3) = "&quot;"
CA(4) = "<" : CX(4) = "&lt;"
Return
## AUREN - DSM - 06/05/2013 - Tratamiento caracteres especiales de XML

