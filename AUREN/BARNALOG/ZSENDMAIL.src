######################################################################################
$ZCONVERT_PAGOS_XML_PDF_WEB

  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO ZSENDMAIL
  Local Char ZPARZSENDM(250) : ZPARZSENDM =func AFNC.PARAM("ZPARZSENDM","")
  Call CALLOUTHTTP (ZPARZSENDM + [S]nomap(0) + "/" + GUSER + "/" + [PYH]NUM) From ZJAVAUTILS

  ENVIOOK = 1
  If GFONCTION="GESPAY"
    Call ECR_TRACE("Pago " + [PYH]NUM , 0) From GESECRAN
        If (ENVIOOK)
           Update [PYH] Where NUM = [F:PYH]NUM With ZDOCPAG = 2
           Update [PYH] Where NUM = [F:PYH]NUM With ZDOCULTENV = date$
           Update [PYH] Where NUM = [F:PYH]NUM With ZDOCNENVIO += 1
       Endif
  Endif
  #####AUREN.FIN
  ###########################################################################################

 #Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/enviaCorreoPago/" + [S]nomap(0) + "/" + GUSER + "/" + [PYH]NUM) From ZJAVAUTILS
Return

#AUREN - PU9
$ZENVIOMAIL_WEB
        For [PYH]

            ENVIOOK = 1
            Call ECR_TRACE("Pago " + [PYH]NUM , 0) From GESECRAN
            If (ENVIOOK)
                Gosub ZCONVERT_PAGOS_XML_PDF_WEB
            Endif

            If (ENVIOOK)
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCPAG = 2
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCULTENV = date$
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCNENVIO += 1
            Endif
        Next
        # Se libera el filtro de la tabla para no afectar al funcionamiento de otros objetos
Return
