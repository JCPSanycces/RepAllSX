#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
### AUREN Código Actividad Z30                                                     ###
### Envío mail por cada pago incluido en una remesa                                ###
######################################################################################

$ACTION
Case ACTION
 When "INIT"
  Case GACTION
   When "ZSENDMAIL"  : Gosub INIT_ZSENDMAIL
  Endcase
 When "EXEC"
  Case GACTION
    When "ZSENDMAIL"  : Gosub EXEC_ZSENDMAIL
  Endcase
 When "TERMINE"
  Case GACTION
   When "ZSENDMAIL"  : Gosub TERM_ZSENDMAIL
  Endcase
Endcase
Return


######################################################################################
$INIT_ZSENDMAIL

Return
######################################################################################

######################################################################################
$EXEC_ZSENDMAIL

    Local Libelle RES
    ## Confirmacion mail
    RES=2
    Qstbox "Se va a proceder al envio del correo electronico. Confirme para continuar  " - nomap Using [L]RES Sleep 10
    Case [L]RES
    When 1 : Gosub SENDMAILREMESA ### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
    When 2 : End
    Endcase

    End

Return

######################################################################################
### AUREN - DSM - 06/10/2012
### Envio de correos a pagos de una remesa
######################################################################################
### Nombre Funcion: SENDMAILREMESA
### --------------------------------------
######################################################################################
####Subprog SENDMAIL

#Subprog SENDMAILREMESA
$SENDMAILREMESA

    Local    Char    XFLG     : XFLG    = PARAM(1)  ## Tipo de Remesa
    Local    Char    XNUM     : XNUM    = PARAM(2)  ## Numero de Remesa
    If clalev([F:XFRM])<=0 : Local File PAYFRM    [XFRM] : Endif
    If clalev([F:PYH])<=0 : Local File PAYMENTH  [PYH] : Endif
    Local    Integer XTYP     : XTYP = val(XFLG)
    #Auren en V12 no existe esta ruta##
    ##Gosub ZENVIOMAILGENERICO
    ## Generar fichero pago y lanzar workflow por cada pago ##
    ############################################################################
    Call OUVRE_TRACE("Proceso envio de remesa nummero: " + XFLG +  XNUM) From LECFIC

    Read [XFRM]FRM0=XTYP;XNUM
    If fstat
        Call ECR_TRACE("Remesa no encontrada" + XNUM , 1) From GESECRAN
        End
    Else

        # Se filtra la tabla de pagos, ya que la regla de WorkFlow esta configurada con dichos parametros
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
        Filter [PYH] Where FRMNUM=XNUM and FRMFLG=XTYP Order By FRMLIN Asc
        #AUREN - PU9
        #Gosub ZENVIOMAIL
        Gosub ZENVIOMAIL_WEB
        #AUREN - PU9
        Filter [PYH]
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
    Endif
    ############################################################################

    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC

Return
######################################################################################



######################################################################################
$TERM_ZSENDMAIL


Return
######################################################################################

######################################################################################
### AUREN - DSM - 26/05/2011
### Proceso de adjuntar un documento
######################################################################################
### Nombre Funcion: ZDOC_ADJUNTAR_ADD
### ---------------------------------
### Parmetros:
###
### XABREV => Tipo de objeto (Obligatorio)
### XIDENT1 => Identificador de objeto (Obligatorio)
### XIDENT2 => Identifcador auxiliar
### XIDENT3 => Posicion
### XTIPODOC => Tipo de archivo
### XDOC => Ruta UNC desde el servidor
### XCAT => Tipo categoria
######################################################################################
Subprog ZDOC_ADJUNTAR_ADD (XABREV, XIDENT1, XIDENT2, XIDENT3, XTIPODOC, XDOC, XCAT )
    Value Char XABREV
    Value Char XIDENT1
    Value Char XIDENT2
    Value Integer XIDENT3
    Value Char XTIPODOC
    Value Char XDOC
    Value Integer XCAT
    Local    Integer  LINEA    : LINEA   = 0

    If clalev([F:AOX])=0 : Local File AOBJTXT   [AOX] : Endif

    LINEA = 0
    Filter [AOX] Where ABREV = XABREV and IDENT1 = XIDENT1 and IDENT2 = XIDENT2
    For [AOX]
        LINEA = val([F:AOX]IDENT3)
    Next
    Filter [AOX]
    LINEA += 1

    Raz [F:AOX]
    [F:AOX]ABREV  = XABREV
    [F:AOX]IDENT1 = XIDENT1
    [F:AOX]IDENT2 = XIDENT2
    [F:AOX]IDENT3 = format$("N0:3#",LINEA)
    [F:AOX]TYPDOC = XTIPODOC
    [F:AOX]NAM    = XDOC
    [F:AOX]CAT    = XCAT
    Write [AOX]

    If fstat
        Call ECR_TRACE("Error al guardar el documento adjunto en el objeto", 1) From GESECRAN
        ENVIOOK = 0
    Endif
 End
######################################################################################

######################################################################################
### AUREN - DSM - 26/05/2011
### Eliminar todos los fichero adjuntos de un tipo
######################################################################################
### Nombre Funcion: ZDOC_ADJUNTAR_DEL
### -----------------------------
### Parametros:
###
### XABREV => Tipo de objeto (Obligatorio)
### XIDENT1 => Identificador de objeto (Obligatorio)
### XIDENT2 => Identifcador auxiliar
### XTIPODOC => Tipo de archivo
######################################################################################
Subprog ZDOC_ADJUNTAR_DEL (XABREV, XIDENT1, XIDENT2, XTIPODOC )
    Value Char XABREV
    Value Char XIDENT1
    Value Char XIDENT2
    Value Char XTIPODOC

    If clalev([F:AOX])=0 : Local File AOBJTXT   [AOX] : Endif

    Delete [AOX] Where ABREV = XABREV and IDENT1 = XIDENT1 and IDENT2 = XIDENT2 and TYPDOC = XTIPODOC

    If fstat
        Call ECR_TRACE("Error al eliminar los documentos adjuntos al objeto", 1) From GESECRAN
        ENVIOOK = 0
    Endif
End
######################################################################################

######################################################################################
### AUREN - DSM - 27/06/2011
### Generacion de una remesa
######################################################################################
### Nombre Funcion: ZDOC_PAGO_CREATE
### -----------------------------
###
### XFICHERO => Ruta y nombre del fichero a generar
### Estructura del fichero:
### <pago fechaPago="20110311" planta="STR" empresa="001" tipoTransaccion="" banco="004901P" nombreBanco="xxxx" numPago="PG-001-11-01026" importe="12962.29" divisa="EUR" tercero="1874"
# nombreTercero="RECACOR, S.A." ccc="00494946732116952673"
### <detalle tipo="FAP" numero="001-11-003579" docOrigen="xxxx" importe="21.16" fecDocumento="yyyymmdd" fecVencimiento="yyyymmdd"/>
### <detalle tipo="FAP" numero="001-11-003579" docOrigen="xxxx" importe="21.16" fecDocumento="yyyymmdd" fecVencimiento="yyyymmdd"/>
### <detalle tipo="FAP" numero="001-11-003579" docOrigen="xxxx" importe="21.16" fecDocumento="yyyymmdd" fecVencimiento="yyyymmdd"/>
### <detalle tipo="FAP" numero="001-11-003579" docOrigen="xxxx" importe="21.16" fecDocumento="yyyymmdd" fecVencimiento="yyyymmdd"/>
### <detalle tipo="FAP" numero="001-11-003579" docOrigen="xxxx" importe="21.16" fecDocumento="yyyymmdd" fecVencimiento="yyyymmdd"/>
### ....
### </pago>
######################################################################################
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
### Agregar en el XML nombre y datos de direccion tantos campos diferentes como existentes hay en la base de datos.
######################################################################################

Subprog ZDOC_PAGO_CREATE(XFICHERO)
    Value Char XFICHERO: XFICHERO = "@" + XFICHERO
    If clalev([F:PYD])=0 : Local File PAYMENTD  [PYD] : Endif
    Local Char V_LINEA(250)(20)
    Local Char V_DATOXML(250)
    adxium = 50 # Formato ASCII
    Openo XFICHERO
    Openo XFICHERO, 0
    adxifs = ""
    adxirs = ""
## AUREN - DSM - 06/05/2013 - Tratamiento caracteres especiales de XML
    V_LINEA(0)= '<?xml version="1.0" encoding="ISO-8859-1"?>'
    Wrseq V_LINEA(0)
    Wrseq chr$(13) + chr$(10)
## AUREN - DSM - 06/05/2013 - Tratamiento caracteres especiales de XML
    V_LINEA(0) = '<pago fechapago="' + format$("D<:YYYY[-]MM[-]DD", [PYH]ACCDAT) + '"' + ' planta = "' + [PYH]FCY + '" empresa = "' + [PYH]CPY + '" tipoTransaccion = "' + [PYH]PAYTYP + '" banco = "' +
& [PYH]BAN + '"'
    V_LINEA(1) = ' nombreBanco = "'
    If clalev([F:ABN])=0 : Local File ABANK  [ABN] : Endif
    Filter [ABN] Where CRY= [PYH]BIDCRY and BAN = left$([PYH]BID,4)
    For [ABN]
        V_DATOXML = [ABN]PAB
        Call CODE_XML (V_DATOXML)
        V_LINEA(1) += V_DATOXML
    Next
    Filter [ABN]
    V_LINEA(1) += '"'

    V_LINEA(1) += ' numpago = "' + [PYH]NUM + '" importe = "'
    V_LINEA(1) += left$(format$("N:9.2",[PYH]AMTCUR),9) + '.' + right$(format$("N:9.2",[PYH]AMTCUR),11)
    V_LINEA(1) += '" divisa ="' + [PYH]CUR + '"'
    V_LINEA(2) = ' tercero = "' + [PYH]BPR + '"'
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
    V_LINEA(3) = ' ccc = "' + [PYH]BID + '"'
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
    If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
    Filter [BPR] Where BPRNUM = [PYH]BPR
    For [BPR]
        V_DATOXML = [BPR]BPRNAM
        Call CODE_XML (V_DATOXML)
       V_LINEA(3) += ' nombreTercero = "' + V_DATOXML  + '"'
    Next
    Filter [BPR]

## AUREN - DSM - 12/05/2014 - CODIGO IBAN
   If clalev([F:BID])=0 : Local File BID  [BID] : Endif
        Filter [BID] Where BIDNUM= [PYH]BID and BPANUM = [PYH]BPR and BPATYP = 1
        For [BID]
            V_LINEA(1) += ' CCC_IBAN = " ' + [BID]IBAN + ' "'
            V_LINEA(1) += ' CCC_SWIFT = " ' + [BID]BICCOD + ' "'
        Next
        Filter [BID]
## AUREN - DSM - 12/05/2014 - CODIGO IBAN

### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
###     V_LINEA(3) = ' ccc = "' + [PYH]BID + '">'
###     Wrseq V_LINEA(0), V_LINEA(1), V_LINEA(2), V_LINEA(3)

    If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
    V_LINEA(4) = ' bpaaddlig_0 = "" '
    V_LINEA(5) = ' bpaaddlig_1 = ""  '
    V_LINEA(6) = ' bpaaddlig_2 = ""  '
    V_LINEA(7) = ' bpades = ""  '
    V_LINEA(8) = ' bpacry = "" '
    V_LINEA(9) = ' bpacrynam = "" '
    V_LINEA(10) = ' bpacty = "" '
    V_LINEA(11) = ' bpafax = "" '
    V_LINEA(12) = ' bpaposcod = "" '
    V_LINEA(13) = ' bpasat = "" '
    V_LINEA(14) = ' bpatel = "" '
    V_LINEA(15) = ' bpaweb = "" '
    V_LINEA(16) = ' bpaextnum = "" '
    V_LINEA(17) = ' bpaaddflg = "" '
    V_LINEA(18) = ' '
    V_LINEA(19) = ' '
    Filter [BPA] Where BPANUM = [PYH]BPR and BPAADD = 'ENV'
    For [BPA]
        V_DATOXML = [BPA]BPAADDLIG(0)
        Call CODE_XML (V_DATOXML)
        V_LINEA(4) = ' bpaaddlig_0 = "' + V_DATOXML + '" '
        V_DATOXML = [BPA]BPAADDLIG(1)
        Call CODE_XML (V_DATOXML)
        V_LINEA(5) = ' bpaaddlig_1 = "' + V_DATOXML + '" '
        V_DATOXML = [BPA]BPAADDLIG(2)
        Call CODE_XML (V_DATOXML)
        V_LINEA(6) = ' bpaaddlig_2 = "' + V_DATOXML+ '" '
        V_DATOXML = [BPA]BPADES
        Call CODE_XML (V_DATOXML)
        V_LINEA(7) = ' bpades = "' + V_DATOXML + '" '
        V_DATOXML = [BPA]CRY
        Call CODE_XML (V_DATOXML)
        V_LINEA(8) = ' bpacry = "' + V_DATOXML + '" '
        V_DATOXML = [BPA]CRYNAM
        Call CODE_XML (V_DATOXML)
        V_LINEA(9) = ' bpacrynam = "' + V_DATOXML + '" '
        V_DATOXML = [BPA]CTY
        Call CODE_XML (V_DATOXML)
        V_LINEA(10) = ' bpacty = "' + V_DATOXML + '" '
        V_LINEA(11) = ' bpafax = "' + [BPA]FAX + '" '
        V_LINEA(12) = ' bpaposcod = "' + [BPA]POSCOD + '" '
        V_LINEA(13) = ' bpasat = "' + [BPA]SAT + '" '
        V_LINEA(14) = ' bpatel = "' + [BPA]TEL + '" '
        V_LINEA(15) = ' bpaweb = "' + [BPA]WEB + '" '
        V_LINEA(16) = ' bpaextnum = "' + [BPA]EXTNUM + '" '
        V_LINEA(17) = ' bpaaddflg = "' + left$(format$("N:1",[BPA]BPAADDFLG),1) + '" '
    Next
    Filter [BPA]
    V_LINEA(19) = ' >'
    Wrseq V_LINEA(0), V_LINEA(1), V_LINEA(2), V_LINEA(3), V_LINEA(4), V_LINEA(5), V_LINEA(6), V_LINEA(7), V_LINEA(8), V_LINEA(9), V_LINEA(10), V_LINEA(11), V_LINEA(12), V_LINEA(13), V_LINEA(14),
& V_LINEA(15), V_LINEA(16), V_LINEA(17), V_LINEA(18), V_LINEA(19)
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
    Wrseq chr$(13) + chr$(10)
    Filter [PYD] Where NUM = [PYH]NUM Order By LIN Asc
    For [PYD]
        Local Char V_DOCORIGEN
        Local Char V_DOCFEC

        If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
        Filter [HAE] Where TYP= [PYD]VCRTYP and NUM = [PYD]VCRNUM
        For [HAE]
            V_DOCORIGEN = [HAE]BPRVCR
            Call CODE_XML (V_DOCORIGEN)
            V_DOCFEC = format$("D<:YYYY[-]MM[-]DD", [HAE]BPRDATVCR)
            If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
            Filter [DUD] Where ACCNUM= [PYD]DUDNUM and DUDLIG = [DUD]DUDLIG
            For [DUD]
                V_LINEA(2) = '" fecDocumento = "' + V_DOCFEC + '" fecVencimiento="' +  format$("D<:YYYY[-]MM[-]DD", [DUD]DUDDAT) + '"/>'
            Next
            Filter [DUD]
        Next
        Filter [HAE]

        V_LINEA(0) = '<detalle tipo = "' + [PYD]VCRTYP + '" numero = "' + [PYD]VCRNUM + '" docOrigen ="' + V_DOCORIGEN + '"'
        V_LINEA(1) = ' importe = "' + left$(format$("N:9.2",[PYD]AMTLIN2),9) + '.' + right$(format$("N:9.2",[PYD]AMTLIN2),11)


        Wrseq V_LINEA(0), V_LINEA(1), V_LINEA(2)
        Wrseq chr$(13) + chr$(10)
    Next
    # Se libera el filtro de la tabla para no afectar al funcionamiento de otros objetos
    Filter [PYD]

    V_LINEA(0) = '</pago>'
    Wrseq V_LINEA(0)
    Wrseq chr$(13) + chr$(10)


    ## En caso que no existan lineas, se indica en la traza
    Openo

End
######################################################################################


######################################################################################
### AUREN - DSM - 28/06/2011
### Ejecutar un programa externo que convierte el formato XML de pagos en PDF
######################################################################################
### Nombre Funcion: ZCONVERT_PAGOS_XML_PDF
### --------------------------------------
### Parametros:
###
### XABREV => Tipo de objeto (Obligatorio)
### XIDENT1 => Identificador de objeto (Obligatorio)
### XIDENT2 => Identifcador auxiliar
### XTIPODOC => Tipo de archivo
######################################################################################
$ZCONVERT_PAGOS_XML_PDF
    Local    Integer  ERROR    : ERROR   = 0
    Local    Char     XPARAMETROS(200)

    XPARAMETROS = RUTAEXE + FICHEROEXE + " PAGO numpago=" + [PYH]NUM + " empresaenvia=" + [PYH]CPY + " fichero=" + FICHEROXML
    Char FICHIERS(200)(50)
# AUREN - DSM - 06/05/2013 - Tratamiento de ficheros XML
    ## AUREN - COMENTAR PARA PRUEBA / DESCOMENTAR PARA REAL
    System FICHIERS = XPARAMETROS
# AUREN - DSM - 06/05/2013 - Tratamiento de ficheros XML
# Infbox XPARAMETROS

    If stat1 <>0
        Call ECR_TRACE(" Fichero PDF - Error al generar ", 0) From GESECRAN
        ENVIOOK = 0
        Return
    Endif

    Call TEMPON("F") From GESECRAN

    ## Buscamos si el fichero existe.
    ## AUREN - COMENTAR PARA PRUEBA / DESCOMENTAR PARA REAL
    Gosub BUSCAR_FIX

    If ERROR =1
        Call TEMPOFF From GESECRAN
        Call ECR_TRACE(" Fichero PDF - Error al no encontrar ", 0) From GESECRAN
        ENVIOOK = 0
        Return
    Endif

    Call TEMPOFF From GESECRAN
Return
######################################################################################
$BUSCAR_FIX
    Local    Integer  XVARNUM    : XVARNUM    = 0
    $XBUSCAR
    FICTRA  = "@" + RUTAPDF + FICHEROPDF
    If filinfo(FICTRA,0)<0 and XVARNUM    <=10
        Sleep 5
        ERROR = 1
        XVARNUM    += 1
        Gosub XBUSCAR
    Endif
Return
######################################################################################

######################################################################################
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
### Algoritmo principal de generacion de mail
######################################################################################
### Nombre Funcion: ZENVIOMAIL
### --------------------------------------
### Parametros:
###
### XTYP => Tipo asiento (Obligatorio)
### XNUM => Numero de asiento (Obligatorio)
######################################################################################
$ZENVIOMAIL
        For [PYH]

            ENVIOOK = 1
            Call ECR_TRACE("Pago " + [PYH]NUM , 0) From GESECRAN

            FICHEROXML = [PYH]NUM + ".XML"
            FICHEROPDF = [PYH]NUM + ".PDF"

            If (ENVIOOK)
                Call ZDOC_PAGO_CREATE(RUTAXML + FICHEROXML)
            Endif

            If (ENVIOOK)
                Call ZDOC_ADJUNTAR_DEL("PAY", [PYH]NUM, "", "PAG")
                Call ZDOC_ADJUNTAR_ADD("PAY", [PYH]NUM, "", LINEA , "PAG", RUTAXML + FICHEROXML , 3)
            Endif

            If (ENVIOOK)
            #AUREN - PU9
                #Gosub ZCONVERT_PAGOS_XML_PDF
                Gosub ZCONVERT_PAGOS_XML_PDF_WEB
            #AUREN - PU9
            Endif

            If (ENVIOOK)
                Call ZDOC_ADJUNTAR_DEL("PAY", [PYH]NUM, "", "PDF")
                Call ZDOC_ADJUNTAR_ADD("PAY", [PYH]NUM, "", LINEA , "PDF", RUTAPDF + FICHEROPDF , 3)
            Endif

            If (ENVIOOK)
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCPAG = 2
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
###                Call WORKFLOW(2,"PAY",chr$(126)+"Z",[PYH]NUM+chr$(126)) From AWRK
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCULTENV = date$
                Update [PYH] Where NUM = [F:PYH]NUM With ZDOCNENVIO += 1
### AUREN - DSM - 06/10/2012 - Especifico 103 - Ampliacion envio mail de pagos
            Endif
        Next
        # Se libera el filtro de la tabla para no afectar al funcionamiento de otros objetos
Return

