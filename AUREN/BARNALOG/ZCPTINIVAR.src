#<AdxTL>@(#)9.0.0.0 $Revision$
#AUREN - V12
#Duplicado de CPTINIVAR subprograma AMTFORCE
#AUREN - V12
##############################################################################################################
# AMTFORCE : renvoie le montant "forcé" (lorsque le montant en banque
# d'un règlement a été forcé)
# TYP est le type de montant : 1 : montant en devise transaction ; dans ce cas LEDTYP=0
#                              2 : montant en devise référentiel ; dans ce cas LEDTYP= valeur menu local 2644)
##############################################################################################################
Subprog ZAMTFORCE(TYP,LEDTYP,MONTANT,STAT)

Value    Integer TYP
Value    Integer LEDTYP
Variable Decimal MONTANT
Variable Integer STAT

Local Char    DEVLED(GLONCUR), DEVMAINLED(GLONCUR), CODLED(GLONLED)
Local Integer SPSTAT, INI, SNS, VU, ISOC
Local Integer WLEDTYP

If clalev([F:BAN4])=0 : Local File BANK     [BAN4] : Endif
If clalev([F:CPY4])=0 : Local File COMPANY  [CPY4] : Endif
If clalev([F:GAG2])=0 : Local File GAUTACEF [GAG2] : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP [TPY] : Endif

#Issue 31729 – 2017-06-13  by MADOR - As a user I want to be able to compute
#payments with the new rate currency field

# AUREN - V12 INICIO
#Gosub DECLARE_CURRATUSR
Gosub DECLARE_CURRATUSR From CPTINIVAR
# AUREN - V12 FIN
#Issue end

Call LECLED([F:TB0]CPY,LEDTYP,CODLED,DEVLED) From CPTDIV
# F56496 : LEDTYP=0 <=> CODLED="" donc montant 0
#If CODLED="" : End : Endif
If LEDTYP>0 & CODLED="" : End : Endif
## Cas d'application :
## 1) Devise réf social=EUR, Devise banque=EUR, Devise facture=USD, Devise règlement=USD
##    et le montant en banque est forcé
## 2) Devise réf social=EUR, Devise banque=EUR, Devise facture=USD, Devise règlement=USD
## et le cours utilisé dans la pièce de règlement doit être celui de la facture d'origine

## NB : la variable V_AMTFORCE avec le paramètre TYP=1 est appelée pour alimenter le montant en devise de transaction
## (TYP=1) uniquement dans la pièce OD devise Tréso qui sera générée à la devise de banque

Local Integer VU, VSENS2, VSENS
SNS = 1 : VSENS2 = 0 : VSENS = 0
Read [GAG2]GAG0 = [F:GAU]COD ; [F:GAD]LINNUM ; "SNS"
If !fstat
## AUREN - V12 INICIO
## El sentido del apunte en ZPRIN no es fijo (SENS2), depende del sentido de la cuenta contable
## variable VU tiene en cuenta signo compuesto a partir de SENS2 o de SNSBLC
 # VU = instr(1,[F:GAG2]FORCLC,"SENS2")
  VU = instr(1,[F:GAG2]FORCLC,"SENS2") + instr(1,[F:GAG2]FORCLC,"SNSBLC")
## AUREN - V12 FIN
If VU
  VSENS2 = 1
  If [F:TB1]AMTLIN2<>0
   SNS = sgn([F:TB1]AMTLIN2)
  Endif
 Else
  VU = instr(1,[F:GAG2]FORCLC,"SENS")
  If VU
   VSENS = 1
  Endif
 Endif
Endif

WLEDTYP = [L]LEDTYP

If GTYPGEN=0 : Call SETMAINREF([F:TB0]CPY,GTYPGEN,GTYPANA) From CPTDIV : Endif

Case TYP

 When 1 : # Montant devise transaction : appelé uniquement dans la pièce d'OD dev tréso pour alimenter le montant dev pièce
  WLEDTYP = GTYPGEN
  Call SETCUR(1,[F:TB0]CPY,DEVMAINLED) From CPTDIV
  If [F:TB1]AMTBANFRC<>0
   MONTANT = [F:TB1]AMTBANFRC
   ## Bug 38912 : La variable de pièce auto SNS est théoriquement exploitée avec des montants non signés (comme AMTLIN).
   ## Par conséquent, si la ligne de pièce automatique est associée à la variable SENS
   ## alors on multipliera le montant par le signe de [F:TB1]AMTBANFRC (car [F:TB1]AMTBANFRC est signé...)
   Read [GAG2]GAG0 = [F:GAU]COD ; [F:GAD]LINNUM ; "SNS"
   If !fstat
    VU = instr(1,[F:GAG2]FORCLC,"SENS")
    If VU
     MONTANT = MONTANT*sgn(MONTANT)
    Endif
   Endif
   If MONTANT<>0 : INI = 1 : Endif
  Elsif find([F:TB1]ACCTYP,1,3)
   If [M:HAE1]CUR = DEVMAINLED
    MONTANT = [F:TB1]PAYLOCLIN
   Endif
   If MONTANT<>0 : INI = 1 : Endif
  Endif

  If !INI & [F:TB1]AMTLIN<>0
   ISOC = find([F:TB0]CPY,GSOC(1..GNBSOC))
   Call LEC_GCM(GGCMSOC(ISOC)) From CPTLEC
   #Issue 31729 – 2017-06-19  by MADOR - As a user I want to be able to compute
   #payments with the new rate currency field
   If [F:TB1]CURLIN <> DEVMAINLED and DEVMAINLED <> [M:HAE1]CUR and [F:TB1]CURLIN <> [M:HAE1]CUR
      [L]CURRATUSR = 0
   Endif
   If LEDTYP>=1 & [F:GCM]FLGVCRRAT(LEDTYP-1)=1 : # Type cours défini dans le modèle comptable
    Call CONVERT4([F:TB1]CURLIN,[M:HAE1]CUR,DEVMAINLED,[F:GCM]TYPRAT(LEDTYP-1),[M:HAE0]ACCDAT,[F:TB1]AMTLIN,
&                 MONTANT,SPSTAT,[L]CURRATUSR) From TRTDEV
   Else : # Type cours du document
    Call LEC_TPY_LEG(GLEGSOC(ISOC),[F:TB0]PAYTYP) From CPTLEC
    Call CONVERT4([F:TB1]CURLIN,[M:HAE1]CUR,DEVMAINLED,[F:TPY]RATTYP,[M:HAE0]ACCDAT,[F:TB1]AMTLIN,
&                 MONTANT,SPSTAT,[L]CURRATUSR) From TRTDEV
   Endif
   #Issue end

   If SPSTAT
    STAT = 98 : GMESSAGE = "AMTCUR"-":"-func AFNC.MES2(mess(70,109,1), [F:TB1]CURLIN, [M:HAE1]CUR)
   Endif
   MONTANT = MONTANT * SNS
  Endif

 When 2 : # Montant devise référentiel
  ## NB : Dans [PYD]PAYLOCLIN, on stocke le montant forcé de l'imputation du règlement en devise du
  ##      référentiel général principal (en prenant le cours de la facture imputée entre la dev.facturation
  ##      et la devise du référentiel général principal)
  ##      Si la devise associée au type référentiel pour lequel on initialise ici le montant est la même
  ##      que la devise du référentiel général principal, on force le montant référentiel par [PYD]PAYLOCLIN ;
  ##      sinon, on fait une conversion...

  Call SETCUR(1,[F:TB0]CPY,DEVMAINLED) From CPTDIV
  If DEVLED = DEVMAINLED
   If [F:TB1]AMTBANFRC1<>0
    MONTANT = [F:TB1]AMTBANFRC1
    If VSENS
     MONTANT = MONTANT*sgn(MONTANT)
    Endif
   Else
    If find([F:TB1]ACCTYP,1,3) : #Banque<=>Tiers ou Compte<=>Tiers
     If [F:TB1]PAYLOCLIN<>0
      If VSENS2=1 & sgn([F:TB1]PAYLOCLIN)<>sgn([F:TB1]AMTLIN2)
       MONTANT = [F:TB1]PAYLOCLIN*SNS
      Elsif VSENS=1 & sgn([F:TB1]PAYLOCLIN)<>sgn([F:TB1]AMTLIN)
       MONTANT = [F:TB1]PAYLOCLIN*sgn([F:TB1]PAYLOCLIN)
      Else
       MONTANT = [F:TB1]PAYLOCLIN
      Endif
      # On garde MONTANT valorisé avec PAYLOCLIN si:
      # - on traite le référentiel général principal
      # - la transaction de saisie des règlements est paramétrée "Application cours facture"
      # - dans le modèle comptable, le type de cours du référentiel est défini par rapport au document d'origine
      # c'est à dire par rapport à la transaction de saisie des règlements.
      # - dans le modèle comptable, le type de cours du référentiel = le type de cours défini dans la transaction
      # de saisie des règlements
      If LEDTYP<>GTYPGEN
       ISOC = find([F:TB0]CPY,GSOC(1..GNBSOC))
       Call LEC_GCM(GGCMSOC(ISOC)) From CPTLEC
       Call LEC_TPY_LEG(GLEGSOC(ISOC),[F:TB0]PAYTYP) From CPTLEC
       If LEDTYP>=1 & [F:GCM]FLGVCRRAT(LEDTYP-1)=1 & [F:GCM]TYPRAT(LEDTYP-1)<>[F:TPY]RATTYP & [F:TPY]RATINV<>2
        #Issue 31729 – 2017-06-13  by MADOR - As a user I want to be able to compute
        #payments with the new rate currency field
        Call CONVERT4([F:TB1]CURLIN,DEVLED,DEVLED,[F:GCM]TYPRAT(LEDTYP-1),[M:HAE0]ACCDAT,[F:TB1]AMTLIN,
&                     MONTANT,SPSTAT,[L]CURRATUSR) From TRTDEV
        #Issue end
        If SPSTAT
         STAT = 98 : GMESSAGE = "AMTLED"+num$(LEDTYP)-":"-func AFNC.MES2(mess(70,109,1), [M:HAE1]CUR, DEVLED)
        Endif
        If VSENS2=1 & sgn([F:TB1]AMTLIN)<>sgn([F:TB1]AMTLIN2)
         MONTANT = MONTANT * SNS
        Endif
       Endif
      Endif
     Else
      ## <PP 17/02/06> Bug 34262 : dans le cas d'un règlement avec une facture imputée et une autre imputation
      ## sans facture, si la ligne pour le compte de banque regroupait les deux imputations, la contre-valeur
      ## en devise locale de la ligne banque pour la ligne de règlement sans imputation n'était pas évaluée
      ## (du fait qu'on avait déjà un montant forcé sur la ligne correspondant à la 1ère imputation), ce qui
      ## conduisait à la génération d'un écart d'arrondi à tort
#AUREN - V12 INICIO
      #Gosub CAL_AMTFORCE
      Gosub CAL_AMTFORCE From CPTINIVAR
#AUREN - V12 FIN
     Endif
    Endif
   Endif
  Else
   If dim([F:BAN]CUR)>0 & DEVLED=[F:BAN]CUR & [F:TB1]AMTBANFRC<>0
    MONTANT = [F:TB1]AMTBANFRC
   Elsif DEVLED=[F:PYH]CUR & [F:TB1]AMTLIN2<>0
    If VSENS=1 & sgn([F:TB1]AMTLIN)<>sgn([F:TB1]AMTLIN2)
     MONTANT = [F:TB1]AMTLIN2*sgn([F:TB1]AMTLIN2)
    Else
     MONTANT = [F:TB1]AMTLIN2
    Endif
   Else
# AUREN - V12 INICIO
    #Gosub CAL_AMTFORCE
    Gosub CAL_AMTFORCE From CPTINIVAR
# AUREN - V12 FIN
   Endif
  Endif
Endcase
End
