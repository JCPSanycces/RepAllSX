# Gestiˇn de la mßscara PAYPROCTL (Especifico)

###############################################################################################
##
##    Z25 - Mostrar importe con signo cambiado (Cobro/Pago) en el detalle de la propuesta
##
###############################################################################################
Subprog C_AMTCUR(VALEUR)
Variable Decimal VALEUR
    [M:PCL]ZAMTCUR(nolign-1)= VALEUR
    If [M:PCL]ZSNS(nolign-1) <>1 Then
        [M:PCL]ZAMTCUR(nolign-1) =[M:PCL]ZAMTCUR(nolign-1) * -1
    Endif
    Affzo  [M:PCL]ZAMTCUR(nolign-1)
End

