######################################################################################
## Etiqueta adida por el supervisor (pantalla POH0) 18/03/2013 17:15:38 (ADMIN)
######################################################################################
$ACTION
  Case ACTION
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When Default
  Endcase
Return

$AVANTBOUT
If BOUT="Z"
  If [M:POH0]POHNUM = ''
    Infbox "Primero debe grabar el pedido"
  Else
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARﾁMETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + [M:POH0]POHNUM + "&cpy=" +[F:POH]CPY + "&act=ped",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

  Endif
Endif
If BOUT="z"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARﾁMETRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + [M:POH0]POHNUM,
&"UIAdxPubSubFile="+chr$(1)+"1"
  #####AUREN.FIN
  ###########################################################################################

Endif

Return


