Subprog C_GROPRI(VALEUR)
Variable Decimal VALEUR
## AUREN - DSM - Junio 2013 - Compras
    If VALEUR = 0
          Call ERREUR("El importe no puede ser cero") From GESECRAN
          mkstat=2
    Endif
## AUREN - DSM - Junio 2013 - Compras
End


