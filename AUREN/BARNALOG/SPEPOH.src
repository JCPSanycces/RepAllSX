######################################################################################
## Etiqueta adida por el supervisor (pantalla POH2) 12/04/2013 17:59:18 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
##AUREN - DSM - ABRIL 2013 - Asignaci de Tipo de compra
    If clalev([F:ITM])=0 : Local File ITMMASTER[ITM] : Endif
    Filter [ITM] Where ITMREF=VALEUR
    For [ITM]
        [M:POH2]LINPURTYP(NBLIG) = [F:ITM]ZTIPO
        Affzo [M:POH2]LINPURTYP(NBLIG)
    Next
    Filter [ITM]
##AUREN - DSM - ABRIL 2013 - Asignaci de Tipo de compra
End


