# Gestión de la máscara BPC0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BPC0) 17/04/2009 19:20:18 (ADMIN)
######################################################################################
$ACTION
 #GMESSAGE=ACTION
 # GERR = 2
Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "CREATION"       : Gosub CREATION
    When "LIENS"          : Gosub LIENS
    When "MODIF"          : Gosub MODIF
    When "VERIF_MOD"      : Gosub VERIF_MOD
    When "VERIF_CRE"      : Gosub VERIF_CRE
  When "APRES_MOD"    : Gosub REPLICA
  When "APRES_CRE"    : Gosub REPLICA

When Default

Endcase
Return

##################################
# Registro de la modificación de un registro
# 17.04.2009 LPardo
##################################
$REPLICA
Call REPLICACIONTERCERO([F:BPC]BPCNUM) From SPEBPR
Return


End
######################################################################################

######################################################################################
#        Z07 CREAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$OUVRE

    Local File ZCPGCLISOC[ZCS]
    Local File COMPANY[CPY]


Return



######################################################################################

######################################################################################
#        Z07 CREAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$CREATION

    Call GRABAR_CONDICIONES


Return

######################################################################################

######################################################################################
#     Z07 CARGAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$LIENS

    Raz [M:ZBP0]
    nolign = 0
    Filter [ZCS] Where ZCSBPCNUM=[M:BPC0]BPCNUM
    For [ZCS]
     nolign += 1
     [M:ZBP0] = [F:ZCS]
     [M:ZBP0]ZCSCPY(nolign-1)    = [F:ZCS]ZCSCPY
     [M:ZBP0]ZCSPTE(nolign-1)    = [F:ZCS]ZCSPTE
     [M:ZBP0]ZCSPLAZO1(nolign-1)    = [F:ZCS]ZCSPLAZO1
     [M:ZBP0]ZCSPLAZO2(nolign-1)    = [F:ZCS]ZCSPLAZO2
     [M:ZBP0]ZCSPLAZO3(nolign-1)    = [F:ZCS]ZCSPLAZO3




     # NOMBRE SOCIEDAD
    Read [F:CPY] CPY0=[F:ZCS]ZCSCPY
    If    fstat=0
        [M:ZBP0]ZCPYNAM(nolign-1)=[F:CPY]CPYNAM
    Endif



     If nolign >= dim([M:ZBP0]ZCSCPY)
      Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
      GOK = 0
      Break
     Endif
    Next
    [M:ZBP0]NBLIG = nolign
    Filter [ZCS]


Return

######################################################################################

######################################################################################




######################################################################################

######################################################################################
#     Z07 MODIFICAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$MODIF

    Call GRABAR_CONDICIONES

Return

######################################################################################


######################################################################################
#     Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################

Subprog GRABAR_CONDICIONES

    Delete [ZCS] Where ZCSBPCNUM=[M:BPC0]BPCNUM
    If fstat=1
         GOK = -1
         GLOCK = "$ZCPGCLISOC"-[M:BPC0]BPCNUM
         End
    Elsif fstat>5
         GOK = 0
         Call RSTA("ZCS",[M:BPC0]BPCNUM) From GLOCK
         End
    Endif

    For nolign=1 To [M:ZBP0]NBLIG
     Raz [F:ZCS]
     [F:ZCS]       = [M:ZBP0]
     [F:ZCS]ZCSBPCNUM = [M:BPC0]BPCNUM
     [F:ZCS]ZCSCPY    = [M:ZBP0]ZCSCPY(nolign-1)
     [F:ZCS]ZCSPTE    = [M:ZBP0]ZCSPTE(nolign-1)
     [F:ZCS]ZCSPLAZO1    = [M:ZBP0]ZCSPLAZO1(nolign-1)
     [F:ZCS]ZCSPLAZO2    = [M:ZBP0]ZCSPLAZO2(nolign-1)
     [F:ZCS]ZCSPLAZO3    = [M:ZBP0]ZCSPLAZO3(nolign-1)




     Write [ZCS]
     If fstat
      GOK=0 : Call FSTA("ZCS") From GLOCK : Break
     Endif
    Next

End





######################################################################################

######################################################################################
## Z07  Validar que no se pueda entrar más de una vez la misma sociedad
######################################################################################

Subprog C_ZCSCPY(VALEUR)
Variable Char    VALEUR()
Variable Char    VALEUR()
    Call UNICITE(VALEUR,[M]ZCSCPY) From OBJDIV


End


######################################################################################

######################################################################################
## Z07  Validar que no se pueda entrar más de una vez la misma sociedad
######################################################################################
Subprog AM_ZCSCPY(VALEUR)
Variable Char    VALEUR()

Read [F:CPY] CPY0=VALEUR
    If    fstat=0
        [M:ZBP0]ZCPYNAM(nolign-1)=[F:CPY]CPYNAM
        Affzo[M:ZBP0]ZCPYNAM
    Endif
End



######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog C_ZCSPLAZO1(VALEUR)
Variable Decimal VALEUR
    If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
             End
        Endif
    Else
        Raz [M]ZCSPLAZO2
    Endif
End

######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog AM_ZCSPLAZO2(VALEUR)
Variable Decimal VALEUR

 If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
         Else
            If VALEUR<=[M]ZCSPLAZO1 | [M]ZCSPLAZO1 =0
                GMESSAGE= "Valor erroneo"
                 mkstat=2
              Endif
         Endif
    Else
        Raz [M]ZCSPLAZO3

    Endif

End

######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################

Subprog C_ZCSPLAZO3(VALEUR)
Variable Decimal VALEUR


     If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
         Else
            If VALEUR<=[M]ZCSPLAZO2 | [M]ZCSPLAZO2 = 0
                GMESSAGE= "Valor erroneo"
                 mkstat=2
              Endif
         Endif
    Endif

End

######################################################################################
#     CONTROL LLAMADA MÉTODO SAVE EN VEZ DE LLAMAR A MÉTODO MODIFY
######################################################################################
$VERIF_CRE
Local Char  ZBPNUM(20)
ZBPNUM = [M]BPCNUM

If GWEBSERV

  #El if no se corresponde con el mensaje, pero es coherente
  #Es para controlar el caso que en parámetro se pasa LARG y tercero existente, ya que el
  #std recupera datos del tercero existe y si éste tenia categoria GRAL se crea un nuevo cliente
  If [M]BCGCOD="GRAL" & ZBPNUM <> ""
    GERR = 1 :  GMESSAGE = "No permitido método SAVE con Categoria LARG y Cliente existente"   : OK = 0  : Return
  Endif

  #No se llega a ejecutar este error, porqué la configuración de la categoria LARG ya obliga a indicar
  #código de tercero en el parámetro BPCNUM
  If [M]BCGCOD="LARG" & ZBPNUM = ""
    GERR = 1 :  GMESSAGE = "No permitido método SAVE con categoria LARG sin informar tercero"   : OK = 0  : Return
  Endif

