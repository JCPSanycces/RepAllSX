#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARINF67(250) : ZPARINF67 =func AFNC.PARAM("ZPARINF67","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARINF67 + nomap + "&usr=" + GUSER ,
&"UIAdxPubSubFile="+chr$(1)+"1"
  #####AUREN.FIN
  ###########################################################################################

  Endcase
Return
