#<AdxTL>@(#)0.0.0.0 $Revision$ Cambio de Departamentos
# Gestión de la máscara ZDC1 (Especifico)
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDC1) 06/07/2018 15:59:19 (AUREN)
######################################################################################
# SPEZDC Z24 -  CAMBIO DEPARTAMENTO FACTURAS TERC PROVEEDOR / FACT COMPRA            #
######################################################################################
$ACTION
    If GACTION <> "ZDCAUDIT" and GACTION <> "ZDCHOBS" and GACTION <> "ZDCHMRT"
        Case ACTION
            When "OUVRE"             : Gosub OUVRE
            When "FILTRE"            : Gosub FILTRE
            When "FILGAUCHE"         : Gosub FILGAUCHE
            When "LIENS"             : Gosub LIENS
            When "AVANT_MOD"         : Gosub AVANT_MOD
            When "MODIF"             : Gosub MODIF
            When "APRES_MOD"         : Gosub APRES_MOD
            When "VERIF_MOD"         : Gosub VERIF_MOD
            When "STYLE"             : Gosub STYLE
            When "DEBUT"             : Gosub DEBUT
            When "AVANTBOUT"         : Gosub AVANTBOUT
            When "APRES_CRE"         : Gosub APRES_CRE
        Endcase
     Else
         Case ACTION
            When "DEBUT"    : Gosub DEBUT
         Endcase
     Endif
Return

######################################################################################
$OUVRE
#InfBox("A00")
    If clalev([F:XAOX])=0  : Local File AOBJTXT    [XAOX]  : Endif
    If clalev([F:XAST])=0  : Local File APLSTD     [XAST]  : Endif
    If clalev([F:XATZ])=0  : Local File ATABZON    [XATZ]  : Endif
    If clalev([F:XATX])=0  : Local File ATEXTE     [XATX]  : Endif
    If clalev([F:AUD])=0   : Local File AUDITH     [AUD]   : Endif
    If clalev([F:AUL])=0   : Local File AUDITL     [AUL]   : Endif
    If clalev([F:XAUS])=0  : Local File AUTILIS    [XAUS]  : Endif
    If clalev([F:XAUS2])=0 : Local File AUTILIS    [XAUS2] : Endif
    If clalev([F:PIL])=0   : Local File BPSINVLIG  [PIL]   : Endif
    If clalev([F:PIA])=0   : Local File BPSINVLIGA [PIA]   : Endif
    If clalev([F:DUD])=0   : Local File GACCDUDATE [DUD]   : Endif
    If clalev([F:ITM])=0   : Local File ITMMASTER  [ITM]   : Endif
    If clalev([F:PIH])=0   : Local File PINVOICE   [PIH]   : Endif
    If clalev([F:PID])=0   : Local File PINVOICED  [PID]   : Endif
    If clalev([F:ZDT])=0   : Local File ZDPTO      [ZDT]   : Endif
    If clalev([F:ZPX])=0   : Local File ZPINVOICEA [ZPX]   : Endif
    If clalev([F:ZUD])=0   : Local File ZUSRDPT    [ZUD]   : Endif

    Read [XAUS]CODUSR= GUSER: If fstat Raz [F:XAUS] : Endif
Return

######################################################################################
$FILTRE
#InfBox("A02")
  FILTSUP  = "(ORIMOD=3 OR ORIMOD = 6) and(INVTYP=1 or INVTYP=2)"
  FILTSUP += " and ZACEPTA<>4 and ZACEPTA<>5"
  FILTSUP += " and find(FCY,GUSRFCY(1..100))<>0"
Return

######################################################################################
$FILGAUCHE
#InfBox("A04")
   FILGAUSUP(0) = "(ORIMOD=3 OR ORIMOD = 6) and(INVTYP=1 or INVTYP=2)"
   FILGAUSUP(0) += " and ZACEPTA<>4 and ZACEPTA<>5"
   FILGAUSUP(0) += " and find(FCY,GUSRFCY(1..100))<>0"
  Call CAMPOSNOEDITABLES
Return

######################################################################################
$LIENS
#InfBox("A05")
    If !GIMPORT
        Filter [DUD] Where NUM=[M:ZDC0]NUM
        Read [DUD]DUD1 First
        If !fstat
            [M:ZDC0]DUDDAT  = [F:DUD]DUDDAT
        Endif
        Filter [DUD]
        Actzo [M:ZDC0]DUDDAT
    Endif

    Local Char CRITERE(250)

    Actzo [M:ZDC1]ZDEP
    Actzo [M:ZDC1]ZMOTIVD
    Actzo [M:ZDC1]ZOBS
    Grizo [M:ZDC1]PAZ
    Grizo [M:ZDC1]ZACEPTA
    Grizo [M:ZDC1]ZAUTFLG
    Grizo [M:ZDC1]ZVNSAP

    CRITERE = "[AUD]TBL = 'PINVOICE' And [AUD]ID1 = [M:ZDC0]NUM"

    Call CARGAR_RUTA_DOCUMENTO_ADJUNTO
    Call CARGAR_AUDITORIA
    Call CARGAR_HISTORICOS
    Call CAMPOSNOEDITABLES

    If [M:ZDC0]ORIMOD = 6 Then
        [M:ZDC0]ZORIG = "PIH"
    Else
        [M:ZDC0]ZORIG = "BIS"
    Endif

     Raz  [M:ZDC1]ZMOTIVD
#    Raz  [M:ZDC1]ZMOTIVRET
     Raz  [M:ZDC1]ZOBS
     Raz  [M:ZDC1]ZINCACEP
     Read [F:ZPX]ZPX0=[M:ZDC0]NUM
     If fstat=0
#       [M:ZDC1]ZMOTIVR = [F:ZPX]ZMOTIVR
        [M:ZDC1]ZMOTIVD = [F:ZPX]ZMOTIVD
#       [M:ZDC1]ZMOTIVRET =[F:ZPX]ZMOTIVRET
        [M:ZDC1]ZOBS = [F:ZPX]ZOBS
        [M:ZDC1]ZINCACEP = [F:ZPX]ZINCACEP
        [M:ZDC1]ZOBSLIQ = [F:ZPX]ZOBSLIQ
#       Affzo [M:ZDC1]ZMOTIVR
        Affzo [M:ZDC1]ZMOTIVD
#       Affzo [M:ZDC1]ZMOTIVRET
        Affzo [M:ZDC1]ZOBS
        Affzo [M:ZDC1]ZINCACEP
        Affzo [M:ZDC1]ZOBSLIQ
     Endif
Return

######################################################################################
$VERIF_MOD
#InfBox("A06")
    Local Char ZOBS_ANT     (250)
    Local Char ZMOTIVRET_ANT(250)
    Local Char ZMOTVD_ANT   (250)

    Filter [PIH] Where NUM = [M:ZDC0]NUM
    If fstat
        ZOBS_ANT = [M:ZDC1]ZOBS
    Else
        Read [F:ZPX]ZPX0=[M:ZDC0]NUM
        If fstat=0
            ZOBS_ANT = [F:ZPX]ZOBS
        Endif
    Endif
    Filter [PIH]

    Call OUVRE_TRACE("Cambio Departamento") From LECFIC

    Trbegin [PIH]

    Update [PIH] Where NUM = [M:ZDC0]NUM With ZDEP =  [M:ZDC1]ZDEP,
&    ZUS1      = [M:ZDC1]ZUS1,
&    ZUS2      = [M:ZDC1]ZUS2

    Gosub ZPINVOICEAUX_ZAF

    If fstat
        OK=0
        GMESSAGE = "Error actualizando tabla de Facturas de Compras. Realizando Rollback."
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        Rollback : Call FSTA("PIH") From GLOCK : Return
    Else
        Call ECR_TRACE("Datos histórico factura",0) From GESECRAN
        Gosub ZHPINV_HISTORICOS
    Endif

    Commit

    ### 28/03/2011 REPLICACION DE DATOS
    Read [PIH]PIH0 = [M:ZDC0]NUM
    If fstat = 0
        Call ECR_TRACE("Replicar factura",0) From GESECRAN
        Gosub REPLICA From SPEBIS
    Endif


    OK=0
    Call FERME_TRACE From LECFIC

    Raz GREP
    Raz REP
    Gosub LIENS
Return

######################################################################################
$ZHPINV_HISTORICOS
#InfBox("A07")
    Local Integer NOLIGNZHO
    Local Integer NOLIGNZHR

    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif
    If clalev([F:ZHR])=0 : Local File ZHPINVMRET [ZHR] : Endif

    If ZOBS_ANT <> [M:ZDC1]ZOBS
        # Se consulta cual es el último registro
        NOLIGNZHO = 0
        Filter [ZHO] Where ZHONUM =[M:ZDC0]NUM Order By ZHONHIST
        For [ZHO]
            NOLIGNZHO = [ZHO]ZHONHIST +1
        Next
        # Guardar histórico ZOBS
        [F:ZHO]ZHONUM    = [M:ZDC0]NUM
        [F:ZHO]ZHONHIST  = NOLIGNZHO
        [F:ZHO]ZHOUSR    = GUSER
        [F:ZHO]ZHOCREDAT = date$
        [F:ZHO]ZHOHOU    = time$
        [F:ZHO]ZHOOBS    = ZOBS_ANT
        Write [ZHO]
    Endif

    If fstat
        OK=0
        GMESSAGE = "Error actualizando fichero histórico. Realizando Rollback."
        Rollback : Call FSTA("PIH") From GLOCK : Return
    Endif
Return

######################################################################################
Subprog CARGAR_HISTORICOS
#InfBox("A08")
    Raz [M:ZDC5]

    # Histórico observaciones
    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif

    Filter [ZHO]
    Filter [ZHO] Where ZHONUM = [M:ZDC0]NUM Order By ZHONHIST
    NOL = 0
    For [ZHO]

        [M:ZDC5]ZHOUSR(NOL) = [F:ZHO]ZHOUSR
        [M:ZDC5]ZHOCREDAT(NOL) = [F:ZHO]ZHOCREDAT
        [M:ZDC5]ZHOHOU(NOL) = [F:ZHO]ZHOHOU
        [M:ZDC5]ZHODAT(NOL) = num$(day([F:ZHO]ZHOCREDAT)) +"/" + num$(month([F:ZHO]ZHOCREDAT)) +"/" + num$(year([F:ZHO]ZHOCREDAT) ) + " " +  [F:ZHO]ZHOHOU
        [M:ZDC5]ZHOOBS(NOL) = [F:ZHO]ZHOOBS

        NOL += 1
    Next
    Filter [ZHO]

    [M:ZDC5]ZHONHIST = NOL
    # Histórico motivos retención
    If clalev([F:ZHR])=0 : Local File ZHPINVMRET [ZHR] : Endif

    NOL = 0
    Filter [ZHR]
    Filter [ZHR] Where ZHRNUM = [M:ZDC0]NUM Order By ZHRNHIST
    NOL = 0
    For [ZHR]
        [M:ZDC5]ZHRUSR(NOL) = [F:ZHR]ZHRUSR
        [M:ZDC5]ZHRCREDAT(NOL) = [F:ZHR]ZHRCREDAT
        [M:ZDC5]ZHRHOU(NOL) = [F:ZHR]ZHRHOU
        [M:ZDC5]ZHRDAT(NOL) = num$(day([F:ZHR]ZHRCREDAT)) +"/" + num$(month([F:ZHR]ZHRCREDAT)) +"/" + num$(year([F:ZHR]ZHRCREDAT) ) + " " +  [F:ZHR]ZHRHOU
        [M:ZDC5]ZHRMRET(NOL) = [F:ZHR]ZHRMRET
        NOL += 1
    Next
    Filter [ZHR]
    [M:ZDC5]ZHRNHIST = NOL

    Affzo [M:ZDC5]
End

######################################################################################
Subprog CARGAR_DETALLES_HIST_OBS
#InfBox("A09")
    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif

    Filter [ZHO] Where ZHONUM = [M:ZDC0]NUM and ZHONHIST = (nolign-1)
    For [ZHO]
        [M:ZDC6]ZHOOBS = [F:ZHO]ZHOOBS
    Next
    Filter [ZHO]
    Affzo [ZDC6]
End

######################################################################################
Subprog CARGAR_DETALLES_HIST_MRT
#InfBox("A10")
    If clalev([F:ZHR])=0 : Local File ZHPINVMRET [ZHR] : Endif

    Filter [ZHR] Where ZHRNUM = [M:ZDC0]NUM and ZHRNHIST = (nolign-1)
    For [ZHR]
        [M:ZDC7]ZHRMRET = [F:ZHR]ZHRMRET
    Next
    Filter [ZHR]
    Affzo [ZDC7]
End

######################################################################################
$AVANT_MOD
#InfBox("A11")
    Actzo [M:ZDC1]ZDEP
    Actzo [M:ZDC1]ZMOTIVD
    Actzo [M:ZDC1]ZOBS
    Grizo [M:ZDC1]PAZ
    Grizo [M:ZDC1]ZACEPTA
    Grizo [M:ZDC1]ZAUTFLG
    Grizo [M:ZDC1]ZVNSAP
Return

######################################################################################
$MODIF
#InfBox("A12")
Return

######################################################################################
$APRES_MOD
#InfBox("A13")
    Gosub RELIT From GOBJSUB
Return

######################################################################################
$STYLE
#InfBox("A14")
  #AUREN - 5.795.161 - Corrección: no se muestan doc adjuntos de facturas de compra
  #ABREV = "BIS"
  If [M:ZDC0]ORIMOD = 6 Then
    ABREV = "PIH"
  Else
    ABREV = "BIS"
  Endif
Return

######################################################################################
Subprog C_ZMOTIVD(VALEUR)
    Variable Char    VALEUR()
#InfBox("A15")
    If (VALEUR = "" or VALEUR=[M:ZDC1]ZMOTIVD) and [M:ZDC1]ZDEP <> ""
        GERR=1
        If VALEUR = ""
            GMESSAGE = mess(10,123,1)
        Else
            GMESSAGE = "Es obligatorio ańadir un nuevo motivo."
        Endif
        mkstat = 2
    Endif
End

######################################################################################
Subprog AM_ZDEP(VALEUR)
    Variable Char    VALEUR()
#InfBox("A16")
    Read [ZDT]ZDP0 = VALEUR : If fstat Raz [F:ZDT] : Endif
    [M:ZDC1]ZUS1 = [F:ZDT]ZUS1
    [M:ZDC1]ZUS2 = [F:ZDT]ZUS2
    Affzo [M:ZDC1]ZUS1
    Affzo [M:ZDC1]ZUS2
End

######################################################################################
Subprog C_ZDEP_2(VALEUR)
    Variable Char    VALEUR()
#InfBox("A17")
    If VALEUR = [M:ZDC1]ZDEP
        GERR=1
        GMESSAGE = "El departamento es el mismo. No se esta cambiando."
        mkstat = 2
    Else
      Read [ZDT]ZDP0 = VALEUR : If fstat Raz [F:ZDT] : Endif
      [M:ZDC1]ZDEP = VALEUR
      [M:ZDC1]ZUS1 = [F:ZDT]ZUS1
      [M:ZDC1]ZUS2 = [F:ZDT]ZUS2
      Affzo [M:ZDC1]ZDEP
      Affzo [M:ZDC1]ZUS1
      Affzo [M:ZDC1]ZUS2
    Endif
End

######################################################################################
$DEBUT
#InfBox("A18")
    If GACTION ="ZDCAUDIT"
        Local Integer SEQUENCE
        SEQUENCE = nolign
        nolign = 0
        For [AUL]AUL0 Where SEQ=SEQUENCE
            nolign += 1
            [M:ZDC3] = [F:AUL]
        Next
        If nolign=0
            Call MESSAGE(mess(40,127,1)) From GESECRAN : # Pas de dĂ©tail
            FIN = 1
        Else
            [M:ZDC3]NBLIG = nolign
            Affzo [ZDC3]
        Endif
    Endif

    If GACTION = "ZDCHOBS"
        Call CARGAR_DETALLES_HIST_OBS
    Endif

    If GACTION = "ZDCHMRT"
        Call CARGAR_DETALLES_HIST_MRT
    Endif
Return

######################################################################################
Subprog CARGAR_RUTA_DOCUMENTO_ADJUNTO
#InfBox("A19")
    Filter [XAOX] Where ABREV= "BIS" and IDENT1 = [M:ZDC0]NUM

    Read [XAOX]AOX0 First

    If fstat=0
        [M:ZDC1]ZDOC = [XAOX]NAM
        Affzo  [M:ZDC1]ZDOC
    Endif

    Filter [XAOX]

    Filter [XAOX] Where ABREV= "PIH" and IDENT1 = [M:ZDC0]NUM

    Read [XAOX]AOX0 First

    If fstat=0
        [M:ZDC1]ZDOC = [XAOX]NAM
        Affzo  [M:ZDC1]ZDOC
    Endif
    Filter [XAOX]
End

######################################################################################
Subprog CARGAR_AUDITORIA
#InfBox("A20")
Local Char TEXTOMENU(30)
Local Char DESCRIPCION_DPTO(30)

    Raz [M:ZDC4]

    CRITERE = "([AUD]TBL = 'PINVOICE' Or [AUD]TBL = 'ZPINVOICEA')And [AUD]ID1 = [M:ZDC0]NUM"

    Filter [AUD]
    Filter [AUD] Where evalue(CRITERE) Order By Key CLE=[F:AUD]SEQ
    NOL = 0
    For [AUD]

        If [F:AUD]EVT="INSERT"  and [F:AUD]TBL<>"ZPINVOICEA"

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZDC4]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZDC4]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZDC4]SEQ(NOL) = [F:AUD]SEQ
            [M:ZDC4]TBL(NOL) = [F:AUD]TBL
            [M:ZDC4]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZDC4]HOU(NOL) = [F:AUD]HOU
            [M:ZDC4]EVT(NOL) = [F:AUD]EVT
            [M:ZDC4]ID1(NOL) = [F:AUD]ID1
            [M:ZDC4]ADRCLI(NOL) = [F:AUD]ADRCLI

            NOL += 1
            nolign = NOL

        Endif
        If [F:AUD]EVT<>"INSERT"


        Filter [AUL]
        Filter [AUL] Where SEQ=[F:AUD]SEQ

        For [AUL]

             Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZDC4]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZDC4]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZDC4]SEQ(NOL) = [F:AUD]SEQ
            [M:ZDC4]TBL(NOL) = [F:AUD]TBL
            [M:ZDC4]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZDC4]HOU(NOL) = [F:AUD]HOU
            [M:ZDC4]EVT(NOL) = [F:AUD]EVT
            [M:ZDC4]ID1(NOL) = [F:AUD]ID1
            [M:ZDC4]ADRCLI(NOL) = [F:AUD]ADRCLI


             Read [XATZ]CODZONE= 'PINVOICE';[F:AUL]COL
             If fstat
                #AUREN - PU9
                #Raz [F:XATZ]
                Read [XATZ]CODZONE= 'ZPINVOICEA';[F:AUL]COL
                If fstat
                  Raz [F:XATZ]
                Endif
                #AUREN - PU9
             Endif

            ### Nombre de la columna
            Read [XATX]NUMERO= 'SPA';[F:XATZ]NOLONG
             If fstat
                Raz [F:XATX]
             Endif
            [M:ZDC4]ZDESCCAMPO(NOL) = [F:XATX]TEXTE


            ### Valores de la columna

            If [F:AUL]COL = "ZDEP"

                Call OBTENER_NOMBRE_DPTO([F:AUL]OVAL, DESCRIPCION_DPTO)
                [M:ZDC4]ZVALORANT(NOL)=   [F:AUL]OVAL + "-" + DESCRIPCION_DPTO

                Call OBTENER_NOMBRE_DPTO([F:AUL]NVAL , DESCRIPCION_DPTO)
                [M:ZDC4]ZVALORACT(NOL)=   [F:AUL]NVAL + "-" + DESCRIPCION_DPTO

            Else
                If [XATZ]CODTYP = "M"
                    ### SI ES UN CAMPO TIPO MENU
                    If len([F:AUL]OVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]OVAL)
                        [M:ZDC4]ZVALORANT(NOL)= TEXTOMENU

                    Endif
                    If len([F:AUL]NVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]NVAL)
                        [M:ZDC4]ZVALORACT(NOL)= TEXTOMENU

                    Endif
                Else
                    [M:ZDC4]ZVALORANT(NOL)=   [F:AUL]OVAL
                    [M:ZDC4]ZVALORACT(NOL)=   [F:AUL]NVAL
                Endif
            Endif

            NOL += 1
            nolign = NOL

        Next
        Filter [AUL]

        Endif

    Next

    Filter [AUD]
    [M:ZDC4]NBLIG = NOL

    Affzo [M:ZDC4]
End

######################################################################################
Subprog OBTENERTEXTOMENU(TEXTOMENU, CAMPO, MENU,VALOR)
Variable Char    TEXTOMENU()
Value  Char CAMPO()
Value  Integer MENU
Variable Char    VALOR()
#InfBox("A21")
     Read [XAST]CLE= MENU;val(VALOR);"SPA"
     If fstat = 0
       TEXTOMENU = [F:XAST]LANMES
     Endif
End

######################################################################################
Subprog OBTENER_NOMBRE_DPTO(CODDEP, NOMBREDEP)
Value  Char CODDEP
Variable Char    NOMBREDEP()
#InfBox("A22")
    If clalev([F:ZDT])=0 : Local File ZDPTO       [ZDT] : Endif

    Raz NOMBREDEP
    Read [ZDT]ZDP0 = CODDEP: If fstat Raz [F:ZDT] : Endif
    NOMBREDEP= [F:ZDT]ZNOM
End

######################################################################################
$AVANTBOUT
#InfBox("A23")
    If BOUT="U"
        If clalev([F:XAOX])=0 : Local File AOBJTXT  [XAOX] : Endif

        Filter [XAOX] Where IDENT1 = [M:ZDC0]NUM
        Read [XAOX]AOX0 First
        If fstat=0
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")
            Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + [M:ZDC0]NUM,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

        Endif
        Filter [XAOX]
    Endif
Return

######################################################################################
Subprog CAMPOSNOEDITABLES
#InfBox("A24")
  Actzo [M:ZDC1]ZOBS
  Affzo [M:ZDC1]ZTRAZA
End

######################################################################################
$APRES_CRE
#InfBox("A25")
    Gosub ZPINVOICEAUX_ZAF
Return

######################################################################################
$ZPINVOICEAUX_ZAF
#InfBox("A26")
    If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
    Raz [F:ZPX]
    Read [PIH]PIH0 = [M:ZDC0]NUM : If fstat Raz [F:PIH] : Endif

    Readlock [ZPX]ZPX0 =[F:PIH]NUM
    Local Integer V_STA
    V_STA = fstat
    [F:ZPX]INVTYP = [F:PIH]INVTYP
    [F:ZPX]NUM = [F:PIH]NUM

    If dim([M:ZDC0]NUM)>0 : [F:ZPX]ZMOTIVD   = [M:ZDC1]ZMOTIVD   : Endif
    If dim([M:ZDC0]NUM)>0 : [F:ZPX]ZOBS      = [M:ZDC1]ZOBS      : Endif
    If dim([M:ZDC0]NUM)>0 : [F:ZPX]ZOBSLIQ   = [M:ZDC1]ZOBSLIQ   : Endif
    If dim([M:ZDC0]NUM)>0 : [F:ZPX]ZINCACEP  = [M:ZDC1]ZINCACEP  : Endif

    If V_STA
        If dim([F:ZPX]CREDAT)>0 : [F:ZPX]CREDAT = date$        : Endif
        If dim([F:ZPX]CREUSR)>0 : [F:ZPX]CREUSR = GUSER        : Endif
        If dim([F:ZPX]CRETIM)>0 : [F:ZPX]CRETIM = time         : Endif
        If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = [0/0/0]      : Endif
        If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = ""           : Endif
        If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = 0            : Endif
        Write [ZPX]
    Else
        If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = date$        : Endif
        If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = GUSER        : Endif
        If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = time         : Endif
        Rewrite [ZPX]
    Endif

    If fstat
        GOK = 0
    Endif
Return
