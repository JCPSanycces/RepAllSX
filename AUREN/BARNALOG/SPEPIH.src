##AUREN - DSM - Abril 2013 - Control Escaner
$AVANTBOUT
Local Char NUMREGTOT
Local Char WNUMCONT
Local Integer STAT
Local Decimal NUMOBTENIDO
    If clalev([F:XAVN])=0 : Local File AVALNUM   [XAVN] : Endif

## Código SETRAM de BIS copiado a PIH y revisado por AUREN

If BOUT="y"
  If clalev([F:XAOX])=0 : Local File AOBJTXT  [XAOX] : Endif
  Filter [XAOX] Where ABREV= "PIH" and IDENT1 = [M:PIH0]NUM
  Read [XAOX]AOX0 First
  If fstat=0
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARINVOIC(250) : ZPARINVOIC =func AFNC.PARAM("ZPARINVOIC","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARINVOIC + nomap + "&usr=" + GUSER + "&id=" + [M:PIH0]NUM + "&cpy=" + [F:PIH]CPY ,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

  Endif
  Filter [XAOX]
Endif
If BOUT="O"
  If clalev([F:XAOX])=0 : Local File AOBJTXT  [XAOX] : Endif
  Filter [XAOX] Where ABREV= "PIH" and IDENT1 = [M:PIH0]NUM
  Read [XAOX]AOX0 First
  If fstat=0
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + [M:PIH0]NUM,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

  Endif
  Filter [XAOX]
Endif
If BOUT = "h"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + [M:PIH0]NUM + "&cpy=" + [F:PIH]CPY + "&act=add",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################


Endif

## FIN Código SETRAM de BIS copiado a PIH y revisado por AUREN

    If BOUT= "Z"
        WNUMCONT = "ZNR"

        If !GIMPORT & GWEBSERV <> 2
            If len([M:PIH1]ZNUMREG)=0
                If len([M:PIH0]ZCPY) > 0
                    If ([M:PIH0]ACCDAT) <> [0/0/0]

                        GOK=1
                        Call NUMERO (WNUMCONT ,[M:PIH0]ZCPY,[M:PIH0]ACCDAT,"",NUMREGTOT,STAT) From SUBANM
                        If STAT = 0

                            If len(NUMREGTOT) < 12
                                 GERR=1:GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro. Vuelva a pulsar el botón de Escaneo." : GOK=0 : Return

                            Else

                                ### Comprobar que el número que ha devuelto sea coherente
                                Read [F:XAVN]AVN0 = WNUMCONT;[M:PIH0]ZCPY;0
                                If    fstat
                                    GERR=1
                                    GMESSAGE = "Se ha producido un error en la verificación del Num. Registro. Vuelva a pulsar el botón de Escaneo"
                                    GOK=0
                                    Return
                                Else
                                    NUMOBTENIDO = val(right$(NUMREGTOT,4))
                                    NUMOBTENIDO  = [F:XAVN]VALEUR - NUMOBTENIDO
                                    If NUMOBTENIDO  > 1
                                        GERR=1
                                        GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro. Vuelva a pulsar el botón de Escaneo"
                                        GOK=0
                                        Return
                                    Endif
                                Endif


                                #### 22/02/2011 : Eliminado ańo y aumentado longitud Nu, secuencia a 9
                                #[F:PIH]ZNUMREG= right$(NUMREGTOT,6)
                                [F:PIH]ZNUMREG= right$(NUMREGTOT,4)
                                ####  FIN

                                [M:PIH1]ZNUMREG=[F:PIH]ZNUMREG
                                Affzo [M:PIH1]ZNUMREG

                            Endif

                        Else
                           # problema durante la recuperación del contador
                           GERR=1:GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro" : GOK=0 : Return
                        Endif
                    Else
                        GERR=1
                        GMESSAGE = "No se puede obtener Num. Registro. Falta Fecha Contable."
                        GOK=0
                        Return
                    Endif
                Else
                   GERR=1
                   GMESSAGE = "No se puede obtener Num. Registro. Falta Sociedad."
                   GOK=0
                   Return
                Endif
            Endif
        Endif
    Endif
Return
##AUREN - DSM - Abril 2013 - Control Escaner

