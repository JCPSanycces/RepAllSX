Subprog DES(ZP_DIE,ZP_CCE)
 Value Char ZP_DIE,ZP_CCE

 If !clalev([F:ZCCE1]) : Local File CACCE   [F:ZCCE1] : Endif
 Read [F:ZCCE1]CCE0 = ZP_DIE;ZP_CCE
 If !fstat Then
   [M:PIH3]ZCUENTA = ZP_CCE-" : "-[F:ZCCE1]DES
   Affzo [M:PIH3]ZCUENTA
 Endif

End

