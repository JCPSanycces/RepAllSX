Subprog C_BPRDAT(VALEUR)
Variable Date    VALEUR
##AUREN - DSM - Abril 2013 - Compras
    If VALEUR > [M:PIH0]ZESCDAT
          Call ERREUR("Fecha Doc/ori. no puede ser superior a Fecha Escaneo.") From GESECRAN
          mkstat=2
    Elsif VALEUR > date$
          Call ERREUR("Fecha Doc/ori. no puede ser superior a Fecha del día.") From GESECRAN
          mkstat=2
    Endif
##AUREN - DSM - Abril 2013 - Compras
End

Subprog C_BPRVCR(VALEUR)
Variable Char    VALEUR()
##AUREN - DSM - Abril 2013 - Compras
Local Integer ESPACIOS
    ESPACIOS= 0
