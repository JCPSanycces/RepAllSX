######################################################################################
##AUREN - DSM - Abril 2013 - Asignación Estado Aceptación
$ASIGNACION_ESTADO_ACEPTACION
# Estado Pendiente (1)
#    a) Existe alguna línea de entrada directa (no pedido o recepción)
#    b) Existe alguna linea de origen pedido y este este marcado como bloqueado
#    c) El importe total supere un % determinado o supere un importe predeterminado (VARIABLES GLOBALES PENDIENTES)

# Junio 2014 - Ampliación
#    d) Alguna de las lineas sea de origen pedido y en la ficha del articulo tenga la marca "Articulo recepcionado"
#       Si se produce este caso se deberá mostrar un mensaje al usuario informándole que la factura contiene
#        artículos que requieren recepción, permitiendo segui adelante con el registro de la factura o
#        permitiendo la cancelación.
#       * Si el pedido se encuentra recepcionado no se tiene en cuenta.
# Junio 2014 - Ampliación

# Estado Aceptado (4)
#    No cumpla ninguna de las anteriores
# Junio 2014 - Ampliación
Local Integer VARRECEPCIONADO: VARRECEPCIONADO = 0
# Junio 2014 - Ampliación
Local Integer VARESTADOPENDIENTE : VARESTADOPENDIENTE = 0
Local Decimal VARTOTLINAMT_TEORICO: VARTOTLINAMT_TEORICO = 0
Local Integer I
    # Caso a
    If VARESTADOPENDIENTE = 0
        If [M:PIH3]NBLIG>0
            For I=0 To [M:PIH3]NBLIG-1
                If [M:PIH3]TYPORI(I)<>1 and [M:PIH3]TYPORI(I)<>2
                    VARESTADOPENDIENTE =1
                Endif
            Next I
        Endif
    Endif
    # Caso b
    If VARESTADOPENDIENTE = 0
        If [M:PIH3]NBLIG>0
            For I=0 To [M:PIH3]NBLIG-1
                If [M:PIH3]TYPORI(I)=1
                    If clalev([F:POH])=0  : Local File PORDER[POH]: Endif
                    Filter [POH] Where POHNUM = [M:PIH3]NUMORI(I)
                    For [POH]
                        If [F:POH]ZBLOQUEO = 2
                            VARESTADOPENDIENTE =1
                        Endif
                    Next
                    Filter [POH]
                Endif
            Next I
        Endif
    Endif
    # Caso c
    If VARESTADOPENDIENTE = 0
        If [M:PIH3]NBLIG>0
            For I=0 To [M:PIH3]NBLIG-1
                If [M:PIH3]TYPORI(I) = 1 or [M:PIH3]TYPORI(I)= 2
## Asistencia 05.209.807
##                    VARTOTLINAMT_TEORICO = VARTOTLINAMT_TEORICO + (([M:PIH3]ORINETPRI(I)/[M:PIH3]ORIQTYPUU(I)) * [M:PIH3]QTYUOM(I))
                    VARTOTLINAMT_TEORICO = VARTOTLINAMT_TEORICO + ([M:PIH3]ORINETPRI(I) * [M:PIH3]QTYUOM(I))
## Asistencia 05.209.807
                Endif
            Next I
        Endif
        # Total Importe AI >VARTOTLINAMT_TEORICO
        # Total Importe AI Linias >VARTOTLINAMT_TEORICO
        If [M:PIH3]CUMLINAMT1>0

        ## Asistencia 05.899.315 - Error control desviación importe en %
        #If (((VARTOTLINAMT_TEORICO - [M:PIH3]CUMLINAMT1 )/[M:PIH3]CUMLINAMT1)* 100) > GZDESVPORIMP or ([M:PIH3]CUMLINAMT1 - VARTOTLINAMT_TEORICO) >GZDESVMAXIMP
        If ((([M:PIH3]CUMLINAMT1 - VARTOTLINAMT_TEORICO)/[M:PIH3]CUMLINAMT1)* 100) > GZDESVPORIMP or ([M:PIH3]CUMLINAMT1 - VARTOTLINAMT_TEORICO) >GZDESVMAXIMP
            VARESTADOPENDIENTE =1
        Endif
        Endif
    Endif
# Junio 2014 - Caso d
    If VARESTADOPENDIENTE = 0
        If [M:PIH3]NBLIG>0
            For I=0 To [M:PIH3]NBLIG-1
                If [M:PIH3]TYPORI(I)=1
                    If clalev([F:ITM])=0  : Local File ITEMMASTER[ITM]: Endif
                    Filter [ITM] Where ITMREF = [M:PIH3]ITMREF(I) and RCPFLG = 2
                    For [ITM]
                        If clalev([F:POQ])=0  : Local File PORDERQ[POQ]: Endif
                        ## AUREN - 06.015.541
                        # Filter [POQ] Where POHNUM = [M:PIH3]NUMORI(I) and POPLIN = [M:PIH3]LINORI(I) and SEQORI = [M:PIH3]SEQORI(I) and RCPCLEFLG = 1
                        Filter [POQ] Where POHNUM = [M:PIH3]NUMORI(I) and POPLIN = [M:PIH3]LINORI(I) and POQSEQ = [M:PIH3]SEQORI(I) and RCPCLEFLG = 1
                        ## AUREN - 06.015.541
                        For [POQ]
                            VARRECEPCIONADO =1
                            [M:PIH0]ZLIBPAZ = "Pedido no recepcionado"
                            Affzo [M:PIH0]ZLIBPAZ
                        Next
                        Filter [POQ]
                    Next
                    Filter [ITM]
                Endif
            Next I
        Endif
    Endif
    If VARRECEPCIONADO = 1 and !GIMPORT and GERR<>1
        Local Libelle RESPUESTA
        Qstbox "Hay artículos que requieren recepción, żDesea continuar?" - nomap Using [L]RESPUESTA
        If [L]RESPUESTA= 1
            VARESTADOPENDIENTE = 1
        Else
            GERR = 1
            GMESSAGE="Hay artículos que requieren recepción"
            Return
        Endif
    Endif
# Junio 2014 - Caso d

# 05.886.670 - Condiciones para actualizar estado automáticamente
    #If VARESTADOPENDIENTE = 1
    #    Gosub ACEPTACION_FACTURA_PENDIENTE
    #Else
    #    Gosub ACEPTACION_FACTURA_ACEPTADA
    #Endif

    #ZAUTFLG es =2 si Autorizada automáticamente y <>2 = Pendiente
    If ([M]ZAUTFLG<>2 and [M]ZACEPTA=1) or ([M]ZAUTFLG=2 and [M]ZACEPTA=4) or ([M]ZAUTFLG<>2 and [M]ZACEPTA<>1 and [M]AMTATI <> [F]AMTATI)
      If VARESTADOPENDIENTE = 1
        If [M]ZACEPTA<>1 & !GIMPORT & GWEBSERV <> 2
          Call ERREURT("Actualizado estado aceptación: PENDIENTE",0) From GESECRAN
        Endif
        Gosub ACEPTACION_FACTURA_PENDIENTE
      Else
        If [M]ZACEPTA<>4 & !GIMPORT & GWEBSERV <> 2
          Call ERREURT("Actualizado estado aceptación: ACEPTADA",0) From GESECRAN
        Endif
        Gosub ACEPTACION_FACTURA_ACEPTADA
      Endif
    Endif
# FIN 05.886.670 - Condiciones para actualizar estado automáticamente
Return
##AUREN - DSM - Abril 2013 - Asignación Estado Aceptación

##AUREN - DSM - Abril 2013 - Asignación Estado Aceptación
$ACEPTACION_FACTURA_ACEPTADA
    If !GIMPORT
        [M:PIH1]ZACEPTA = 4
        [M:PIH0]PAZ = 4
## Assis 05.678.441
        [M:PIH1]ZAUTFLG = 2
## Assis 05.678.441
    Endif
    Affzo [M:PIH0]PAZ
    Affzo [M:PIH1]ZACEPTA
## Assis 05.678.441
    Affzo [M:PIH1]ZAUTFLG
## Assis 05.678.441

Return
##AUREN - DSM - Abril 2013 - Asignación Estado Aceptación

## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria
Subprog CARGAR_AUDITORIA
Local Char TEXTOMENU
Local Char DESCRIPCION_DPTO
    If clalev([F:AUD])=0 : Local File AUDITH      [AUD] : Endif
    If clalev([F:AUL])=0 : Local File AUDITL      [AUL] : Endif
    If clalev([F:XAUS2])=0 : Local File AUTILIS  [XAUS2] : Endif
    If clalev([F:XATZ])=0 :  Local File ATABZON   [XATZ] : Endif
    If clalev([F:XAST])=0 :  Local File APLSTD   [XAST] : Endif
    If clalev([F:XATX])=0 :  Local File ATEXTE   [XATX] : Endif
    Raz [M:ZPIH]

    #AUREN - PU9
    #CRITERE = "[AUD]TBL = 'PINVOICE' and [AUD]ID1 = [M:BIS0]NUM"
    CRITERE = "([AUD]TBL = 'PINVOICE' or [AUD]TBL = 'ZPINVOICEA')and [AUD]ID1 = [M:PIH0]NUM"
    #AUREN - PU9
    Filter [AUD]
    Filter [AUD] Where evalue(CRITERE) Order By Key CLE=[F:AUD]SEQ
    NOL = 0
    For [AUD]

        ### AŃDIR LÍNIA CABECERA SI EVENTO INSERT (Modif 20/04/2011)

    #AUREN - PU9
        #If [F:AUD]EVT="INSERT"
        If [F:AUD]EVT="INSERT"  and [F:AUD]TBL<>"ZPINVOICEA"
    #AUREN - PU9

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZPIH]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZPIH]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZPIH]SEQ(NOL) = [F:AUD]SEQ
            [M:ZPIH]TBL(NOL) = [F:AUD]TBL
            [M:ZPIH]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZPIH]HOU(NOL) = [F:AUD]HOU
            [M:ZPIH]EVT(NOL) = [F:AUD]EVT
            [M:ZPIH]ID1(NOL) = [F:AUD]ID1
            [M:ZPIH]ADRCLI(NOL) = [F:AUD]ADRCLI

            NOL += 1
            nolign = NOL

        Endif


        If [F:AUD]EVT<>"INSERT"

        Filter [AUL]
        ### Para cada registro de cabecera de auditoria, se aĂ±adirĂˇ una lĂ­nea por cada campo afectado
        # NO AŃADIR LINEA DETALLE SI EVENTO TIPO INSERT  (Modif 20/04/2011)

        Filter [AUL] Where SEQ=[F:AUD]SEQ

        For [AUL]

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZPIH]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZPIH]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZPIH]SEQ(NOL) = [F:AUD]SEQ
            [M:ZPIH]TBL(NOL) = [F:AUD]TBL
            [M:ZPIH]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZPIH]HOU(NOL) = [F:AUD]HOU
            [M:ZPIH]EVT(NOL) = [F:AUD]EVT
            [M:ZPIH]ID1(NOL) = [F:AUD]ID1
            [M:ZPIH]ADRCLI(NOL) = [F:AUD]ADRCLI


             Read [XATZ]CODZONE= 'PINVOICE';[F:AUL]COL
             If fstat
                #AUREN - PU9
                #Raz [F:XATZ]
                Read [XATZ]CODZONE= 'ZPINVOICEA';[F:AUL]COL
                If fstat
                  Raz [F:XATZ]
                Endif
                #AUREN - PU9
             Endif

            ### Nombre de la columna
            Read [XATX]NUMERO= 'SPA';[F:XATZ]NOLONG
             If fstat
                Raz [F:XATX]
             Endif
            ### (Modif 21/04) No incluir nombre de columna, solo descripción
            #[M:ZPIH]ZDESCCAMPO(NOL) = [F:AUL]COL + "-" + [F:XATX]TEXTE
            [M:ZPIH]ZDESCCAMPO(NOL) = [F:XATX]TEXTE



            ### Valores de la columna

            If [F:AUL]COL = "ZDEP"

                Call OBTENER_NOMBRE_DPTO([F:AUL]OVAL, DESCRIPCION_DPTO) From SPEZAF
                [M:ZPIH]ZVALORANT(NOL)=   [F:AUL]OVAL + "-" + DESCRIPCION_DPTO

                Call OBTENER_NOMBRE_DPTO([F:AUL]NVAL , DESCRIPCION_DPTO) From SPEZAF
                [M:ZPIH]ZVALORACT(NOL)=   [F:AUL]NVAL + "-" + DESCRIPCION_DPTO

            Else
                If [XATZ]CODTYP = "M"
                    ### SI ES UN CAMPO TIPO MENU
                    If len([F:AUL]OVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]OVAL) From SPEZAF
                        [M:ZPIH]ZVALORANT(NOL)= TEXTOMENU

                    Endif
                    If len([F:AUL]NVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]NVAL) From SPEZAF
                        [M:ZPIH]ZVALORACT(NOL)= TEXTOMENU

                    Endif
                Else
                    [M:ZPIH]ZVALORANT(NOL)=   [F:AUL]OVAL
                    [M:ZPIH]ZVALORACT(NOL)=   [F:AUL]NVAL
                Endif
            Endif

            NOL += 1
            nolign = NOL

        Next
        Filter [AUL]

        Endif

    Next

    Filter [AUD]
    [M:ZPIH]NBLIGA = NOL

    Affzo [M:ZPIH]


End

$OUVRE
## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria
# Junio 2014
#    If clalev([F:AUD])=0 : Local File AUDITH      [AUD] : Endif
#    If clalev([F:AUL])=0 : Local File AUDITL      [AUL] : Endif
#    If clalev([F:XAUS2])=0 : Local File AUTILIS  [XAUS2] : Endif
#    If clalev([F:XATZ])=0 :  Local File ATABZON   [XATZ] : Endif
#    If clalev([F:XAST])=0 :  Local File APLSTD   [XAST] : Endif
#    If clalev([F:XATX])=0 :  Local File ATEXTE   [XATX] : Endif
#    Global Char [M:PIH0]ZCPY
## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria

  #AUREN - PU9
  If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
  #AUREN - PU9

Return
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PIH1) 19/04/2013 10:34:58 (ADMIN)
######################################################################################
Subprog C_ZRECEPDAT(VALEUR)
Variable Date    VALEUR
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción
    If VALEUR < [M:PIH1]BPRDAT
          Call ERREUR("Fecha Recepción no puede ser inferior a la fecha de factura del proveedor") From GESECRAN
          mkstat=2
    Endif
    If VALEUR > date$
          Call ERREUR("Fecha Recepción no puede ser superior a la fecha de sistema") From GESECRAN
          mkstat=2
    Endif
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción
End


## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
######################################################################################
$CALCULO_FECHA_INICIO_CALC_VENC
Local Integer VARINTANYMESFACPROV
Local Integer VARINTANYMESFACESCA
Local Date VARDESFECCALC
Local Integer VARFORZARCALC: VARFORZARCALC = 0

# 5.773.157 cambio cálculo fórmula
# Las facturas recibidas hasta la fecha de corte (día 15 del mes siguiente a la fecha de la factura),
# utilizarán como fecha de inicio de cálculo de vencimiento la fecha de factura. Todas las demás
# utilizarán la fecha de recepción
#
#    VARCARANYMESFACPROV = year([M:PIH1]BPRDAT) * 12 + month([M:PIH1]BPRDAT)
#    VARINTANYMESFACESCA = year([M:PIH0]ZESCDAT) * 12 + month([M:PIH0]ZESCDAT)
#    If VARCARANYMESFACPROV  = VARINTANYMESFACESCA
#        VARDESFECCALC = [M:PIH1]BPRDAT
#    Elsif VARCARANYMESFACPROV  < (VARINTANYMESFACESCA -1)
#        VARDESFECCALC = [M:PIH1]ZRECEPDAT
#    #Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & day([M:PIH1]ZRECEPDAT)<16
#    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:PIH1]ZRECEPDAT < gdat$(16,month([M:PIH0]ZESCDAT),year([M:PIH0]ZESCDAT)))
#        VARDESFECCALC = [M:PIH1]BPRDAT
#    #Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & day([M:PIH1]ZRECEPDAT)>15
#    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:PIH1]ZRECEPDAT > gdat$(15,month([M:PIH0]ZESCDAT),year([M:PIH0]ZESCDAT)))
#        VARDESFECCALC = [M:PIH1]ZRECEPDAT
#    Endif
   VARCARANYMESFACPROV = year([M:PIH1]BPRDAT) * 12 + month([M:PIH1]BPRDAT)
    VARINTANYMESFACESCA = year([M:PIH1]ZRECEPDAT) * 12 + month([M:PIH1]ZRECEPDAT)
    If VARCARANYMESFACPROV  = VARINTANYMESFACESCA
        VARDESFECCALC = [M:PIH1]BPRDAT
    Elsif VARCARANYMESFACPROV  < (VARINTANYMESFACESCA -1)
        VARDESFECCALC = [M:PIH1]ZRECEPDAT
    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:PIH1]ZRECEPDAT < gdat$(16,month([M:PIH1]ZRECEPDAT),year([M:PIH1]ZRECEPDAT)))
        VARDESFECCALC = [M:PIH1]BPRDAT
    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:PIH1]ZRECEPDAT > gdat$(15,month([M:PIH1]ZRECEPDAT),year([M:PIH1]ZRECEPDAT)))
        VARDESFECCALC = [M:PIH1]ZRECEPDAT
    Endif
# 5.773.157 FIN cambio cálculo fórmula

    [M:PIH1]ZDUDDAT1 = [M:PIH1]DUDDAT1
    #Si ya se ha realizado algun cálculo
    #BUG Asistencia 5.500.674: En la creación no se calcula correctamente fecha inicio cálculo. Desactivamos condición If [M:PIH1]DUDDAT1 <> [0/0/0]
    #If [M:PIH1]DUDDAT1 <> [0/0/0]
        # Se actualiza la fecha de inico de vencimiento si no es abono
        If [M:PIH0]PIVTYP <> "ABO"
            [M:PIH1]STRDUDDAT = VARDESFECCALC
        Endif
    #Endif
    Affzo [M:PIH1]STRDUDDAT
Return
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
$NOTIFICACION_CAMBIO_VENCIMIENTOS
    Local Libelle RES
    ## Confirmacion mail
    RES=2
    Qstbox "Se ha cambiado la fecha del primer vencimiento, se procedera a enviar un correo al proveedorżDesa continuar?" - nomap Using [L]RES Sleep 10
    Case [L]RES
        When 1 : Gosub ENVIO_CORREO_PROVEEDOR_VENCIMIENTOS
    Endcase
Return
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
$ENVIO_CORREO_PROVEEDOR_VENCIMIENTOS
    Local    Integer  ERROR    : ERROR   = 0
    Local    Char     XPARAMETROS(250)

    XPARAMETROS = GZVENCPROV + " " + [M:PIH0]NUM + " " + [M:PIH1]ZDUDDAT1
#    Char FICHIERS(200)(50)
# AUREN - DSM - Llamada Externa
#    System FICHIERS = XPARAMETROS
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEPIH
  Local Char ZPARSPEPIH(250) : ZPARSPEPIH =func AFNC.PARAM("ZPARSPEPIH","")
  Call CALLOUTHTTP (ZPARSPEPIH + nomap(0) + "/" + GUSER + "/" + [M:PIH0]NUM + "/" + [M:PIH1]ZDUDDAT1) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################
  #Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/enviaCorreoVencimiento/" + nomap(0) + "/" + GUSER + "/" + [M:PIH0]NUM + "/" + [M:PIH1]ZDUDDAT1) From ZJAVAUTILS

    If stat1 <>0
        Call ECR_TRACE(" Cálculo de vencimientos - Error al notificar al proveedor ", 0) From GESECRAN
        Return
    Endif
# AUREN - DSM - Llamada Externa
    Call TEMPON("F") From GESECRAN
    Call TEMPOFF From GESECRAN
Return
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
$APRES_MOD
    Gosub REPLICA
    If [M:PIH1]ZDUDDAT1 <> [M:PIH1]DUDDAT1
        Gosub NOTIFICACION_CAMBIO_VENCIMIENTOS
    Endif

    #AUREN - PU9
    Gosub ZPINVOICEAUX_PIH
    #AUREN - PU9

Return
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

######################################################################################
## AUREN - DSM - Junio 2013 - Compras - Control Facturas abono
$CONTROL_TIPO_FACTURA
    If [M:PIH0]PIVTYP = "ABO"
        [M:PIH1]PTE = ZPTEDEFAULT
        [M:PIH1]STRDUDDAT = [M:PIH0]ACCDAT
        Grizo [M:PIH1]PTE
        Affzo [M:PIH1]STRDUDDAT
    Else
        Actzo [M:PIH1]PTE
    Endif
    Affzo [M:PIH1]PTE
Return
## AUREN - DSM - Junio 2013 - Compras - Control Facturas abono
