## AUREN - DSM - Abril 2013 - Compras
$INICRE
    Gosub TERMINACION_COLECTIVO
    Gosub ASIGNACION_DEPARTAMENTO
    Gosub ASIGNACION_DEPARTAMENTO_USUARIOS
    # Junio 2014 Se realiza en el control de factura
