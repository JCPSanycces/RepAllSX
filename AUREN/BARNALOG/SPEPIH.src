##AUREN - DSM - Abril 2013 - Control Escaner
$RAZDUP
    If clalev([F:ZDT])=0  : Local File ZDPTO     [ZDT]  : Endif
    Raz [M:PIH1]ZNUMREG
    Read [ZDT]ZDP0 = [M:PIH1]ZDEP : If fstat Raz [F:ZDT] : Endif
    [M:PIH1]ZUS1 = [F:ZDT]ZUS1
    [M:PIH1]ZUS2 = [F:ZDT]ZUS2
    Affzo [M:PIH]ZUS1
    Affzo [M:PIH]ZUS2
    If GIMPORT <> 1
        [M:PIH0]ZESCAN = 1
    Endif
    Affzo [M:PIH0]ZESCAN
    Affzo [M:PIH1]ZNUMREG
    Gosub ACEPTACION_FACTURA_PENDIENTE

    [M:PIH]ZESCDAT=date$
    Affzo [M:PIH0]ZESCDAT
Return
##AUREN - DSM - Abril 2013 - Control Escaner

