Subprog AS_LINACC1(VALEUR)
  Variable Char    VALEUR()
  If clalev([F:ZGAC1])=0 : Local File GACCOUNT [F:ZGAC1] : Endif

  Read [F:ZGAC1]GAC0 = GCOA(1);VALEUR
  If !fstat Then
    [M:PIH3]ZCUENTA = VALEUR-" : "-[F:ZGAC1]DES
    Affzo [M:PIH3]ZCUENTA
  Endif

End

