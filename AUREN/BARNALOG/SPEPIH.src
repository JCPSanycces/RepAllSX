##AUREN - DSM - Abril 2013 - Control Escaner
$CONTROL_FACTURA_DUPLICADA
Local Integer DUPLICADO
Local Char VARFAC(250)
    DUPLICADO=0
    If clalev([BPR1])<=0 Local File BPARTNER[BPR1] : Endif
    If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
    For [BPR1]BPR0 Where CRN = [M:PIH0]ZNIF
        Filter [PIHB] Where CPY= [M:PIH0]ZCPY and year(BPRDAT) = year([M:PIH1]BPRDAT) and BPRVCR = [M:PIH1]BPRVCR and BPR= [F:BPR1]BPRNUM
        For [PIHB]
            # Si se encuentra una coincidencia y es Crear o Duplicar
            If GREP = "C"  | GREP = "D"
                DUPLICADO= 1
                VARFAC = [F:PIHB]NUM
                Break
            Else
                # Si es modificación y no se trata de la factura en curso
                If  [M:PIH0]NUM <> [F:PIHB]NUM
                    DUPLICADO= 1
                    Break
                Endif
            Endif
        Next
        Filter [PIHB]
    Next
    Close Local File [BPR1]
    If DUPLICADO <> 0
        GERR=1
        GMESSAGE="Ya existe una factura con igual Sociedad/NIF proveedor/Ańo fecha doc. origen/Documento origen. (" + VARFAC +")"
        OK=0
    Endif
Return
