$ZPINVOICEAUX_PIH
#AUREN - PU9
#Crea los datos de ZPINVOICEA
  Raz [F:ZPX]
  Readlock [ZPX]ZPX0 =[F:PIH]NUM
  Local Integer V_STA
  V_STA = fstat

  [F:ZPX]INVTYP = [F:PIH]INVTYP
  [F:ZPX]NUM = [F:PIH]NUM
  #Factura Compra
  If dim([M:PIH0]NUM)>0: [F:ZPX]ZOBSLIQ = [M:PIH1]ZOBSLIQ: Endif

  If V_STA
   If dim([F:ZPX]CREDAT)>0 : [F:ZPX]CREDAT = date$ : Endif
   If dim([F:ZPX]CREUSR)>0 : [F:ZPX]CREUSR = GUSER : Endif
   If dim([F:ZPX]CRETIM)>0 : [F:ZPX]CRETIM = time  : Endif
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = [0/0/0] : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = "" : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = 0  : Endif
   Write [ZPX]
  Else
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = date$ : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = GUSER : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = time  : Endif
   Rewrite [ZPX]
  Endif
  If fstat
   GOK = 0
  Endif
Return

$PICKE
# AUREN - 05.880.536 - LISTA IZDA MUESTRA PEDIDOS NO FIRMADOS
# Se tiene que controlar que no se seleccionen los no firmados
Case currbox
  When GBOXPO1 : Gosub PICKE_PEDIDO
Endcase
Return

$PICKE_PEDIDO
# AUREN - 05.880.536 - LISTA IZDA MUESTRA PEDIDOS NO FIRMADOS
# Se tiene que controlar que no se seleccionen los no firmados
    If [F:POH]APPFLG < 2
          GMESSAGE="No se puede facturar el pedido " + [F:POH]POHNUM + " : PENDIENTE DE FIRMA"
          OK = 0
          GPE = 1
          GERR = 1
          Return
    Endif
Return

######################################################################################
## AUREN - 05.897.085 - CONTROL DESVIACIÓN MÁXIMA IMPUESTO
######################################################################################
Subprog AM_AMTTAX(VALEUR)
Variable Decimal VALEUR

Local    Shortint NOL : NOL=nolign-1

Filter [TRA] Where CPY=GSOCIETE & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
  Filter [TRA] Where CPY="" & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
  If fstat>2  Raz [F:TRA] : Endif
Endif


If VALEUR > ([M:PIH4]BASTAX(NOL) * ([F:TRA]VATRAT + GZCTLIVA) / 100) or VALEUR < ([M:PIH4]BASTAX(NOL) * ([F:TRA]VATRAT - GZCTLIVA) / 100)
    GERR=1
    GMESSAGE = "Desviación impuestos fuera del margen permitido: +/- " - num$(GZCTLIVA) - "%"
    mkstat = 2
Endif

End
