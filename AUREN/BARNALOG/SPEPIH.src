    # Junio 2014 Se realiza en el control de factura
Return
## AUREN - DSM - Abril 2013 - Compras

## AUREN - DSM - Abril 2013 - Compras
$TERMINACION_COLECTIVO
Local Char TERMINACION
Local Char CUENTA
Local Integer MODIFCOLECTIVO
Local Integer ERRORCOLECTIVO
    MODIFCOLECTIVO=0
    #Solo en interactivo
    If !GIMPORT & GWEBSERV <> 2 & len([M:PIH0]BPRSAC) > 0
       Call TERMINACION_COLECTIVO([M:PIH0]ZCPY, [M:PIH0]BPR, [M:PIH0]BPRSAC, TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT
       If ERRORCOLECTIVO = 1
            GOK = 1
            GMESSAGE = "Error en Terminación colectivo. Revise la configuración."
            GOK=0
            Return

       Else
            If len(TERMINACION) > 0  or  MODIFCOLECTIVO = 1

                # Si hay terminaciĂłn: aĂ±adirla al colectivo

                [M:PIH0]BPRSAC =  [M:PIH0]BPRSAC + TERMINACION
                Affzo  [M:PIH0]BPRSAC
                [F:PIH]BPRSAC =  [M:PIH0]BPRSAC

#                #Poner CUENTA asociada al colectivo
#                [M:PIH0]SACACC = CUENTA
#                Affzo  [M:PIH0]SACACC

                Infbox "Colectivo/CUENTA modificado." Titled "Información"
            Endif
       Endif
    Endif
Return
## AUREN - DSM - Abril 2013 - Compras

## AUREN - DSM - Abril 2013 - Asignación departamento
$ASIGNACION_DEPARTAMENTO
Local Char VARDEP
Local Char VARPLANTA
Local Char VARARTICULO
Local Char VARFACTURA
Local Integer VARORIGEN
# La tipologia de la primera linea marca el origen de la planta
# 1 > Pedido
# 2 > Recepción
# 3 > Devolución
# 4 > Factura
# 5 > Varios
    If [M:PIH3]TYPORI(0)=1
        VARORIGEN = 1
        If clalev([F:POH])=0  : Local File PORDER[POH]: Endif
        Filter [POH] Where POHNUM = [M:PIH3]NUMORI(0)
        For [POH]
            VARPLANTA= [F:POH]POHFCY
        Next
        Filter [POH]
    Elsif [M:PIH3]TYPORI(0)=2
        VARORIGEN = 1
        If clalev([F:PTH])=0  : Local File PRECEIPT[PTH]: Endif
        Filter [PTH] Where PTHNUM = [M:PIH3]NUMORI(0)
        For [PTH]
            VARPLANTA= [F:PTH]PRHFCY
        Next
        Filter [PTH]
    #05.899.315 - AUREN - SI ORIGEN FACTURA, DEPARTAMENTO DE FACTURA ORIGEN
    Elsif [M:PIH3]TYPORI(0)=4
	VARORIGEN = 4
        If clalev([F:ZPIH])=0  : Local File PINVOICE [ZPIH]: Endif
        Filter [ZPIH] Where NUM = [M:PIH3]NUMORI(0)
        For [ZPIH]
            VARFACTURA= [F:ZPIH]ZDEP
        Next
        Filter [ZPIH]
    Elsif [M:PIH3]TYPORI(0) = 3 or [M:PIH3]TYPORI(0) = 5
        VARORIGEN = 2
        VARARTICULO = [M:PIH3]ITMREF(0)
    Else
        Return
    Endif

    If VARORIGEN = 1
    # Origen PLANTA
        If clalev([F:FCY])=0  : Local File FACILITY[FCY]: Endif
        Filter [FCY] Where FCY = VARPLANTA
        For [FCY]
            VARDEP= [F:FCY]ZDEP
        Next
        Filter [FCY]
    Elsif VARORIGEN = 2
    # Origen ARTICULO
        If clalev([F:ITM])=0  : Local File ITMMASTER[ITM]: Endif
        Filter [ITM] Where ITMREF = VARARTICULO
        For [ITM]
            VARDEP= [F:ITM]ZDEP
        Next
        Filter [ITM]
    Elsif VARORIGEN = 4
    # Origen FACTURA
        VARDEP= VARFACTURA
    Endif
    If VARDEP = ""
        GERR=1
        If VARORIGEN = 1
            GMESSAGE = "Campo de departamento obligatorio. Revise la configuración de la planta " + VARPLANTA
        Elsif VARORIGEN = 2
            GMESSAGE = "Campo de departamento obligatorio. Revise la configuración del artículo" + VARARTICULO
        Elsif VARORIGEN = 4
            GMESSAGE = "Campo de departamento obligatorio. Revise departamento de la factura origen"
        Endif
        GOK=0
        Return
    Else
        [M:PIH1]ZDEP = VARDEP
        Affzo [M:PIH1]ZDEP
    Endif
Return
## AUREN - DSM - Abril 2013 - Asignación departamento

## AUREN - DSM - Abril 2013 - Usuarios del departamento
$ASIGNACION_DEPARTAMENTO_USUARIOS
    If GERR = 1
        Return
    Endif
    If clalev([F:ZDT])=0  : Local File ZDPTO     [ZDT]  : Endif
    Filter [ZDT] Where ZDEP = [M:PIH1]ZDEP
    For [ZDT]
        [M:PIH1]ZUS1 = [F:ZDT]ZUS1
        [M:PIH1]ZUS2 = [F:ZDT]ZUS2
        Affzo [M:PIH1]ZUS1
        Affzo [M:PIH1]ZUS2
    Next
    Filter [ZDT]
    Affzo [M:PIH1]
Return
## AUREN - DSM - Abril 2013 - Usuarios del departamento


## AUREN - DSM - Abril 2013 - Escaner
Subprog LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER
  Local Integer RSLT
  RSLT=0
    If !GIMPORT & GWEBSERV <> 2
        Call CONTROL_FACTURAS_COINCIDENTES([M:PIH0]ZCPY,[M:PIH1]TOTLINAMT1,[M:PIH0]BPR ,[M:PIH1]BPRDAT, RSLT) From SPEBIS
        If RSLT <> 0
           # Presentar Ventana
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "ZFACTERC"
         #Call SAISIE_CHAR(VALEUR,PARMSK,"ZFACTERC","","SPEFACTERC") From GSAISIE
         ## AUREN - DSM - Abril 2013 - Compras
         PARMSK(1) = "PIH"
         PARMSK(2) = [M:PIH0]ZCPY
         PARMSK(3) = [M:PIH0]BPR
         PARMSK(4) = num$([M:PIH1]TOTLINAMT1)
         PARMSK(5) = [M:PIH1]BPRDAT
         ## AUREN - DSM - Abril 2013 - Compras
         Call SAISIE_NUM([M:PIH1]TOTLINAMT1,PARMSK,"ZFACTERC","","SPEFACTERC") From GSAISIE
         GACTION = SAVACT
        Endif
    Endif
End
