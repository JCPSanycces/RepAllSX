##############################################################################################
## LLAMADA FUNCIÓN EXTERNA TRAS CIERRE PERIODO                       AUREN - Diciembre 2018 ##
##############################################################################################

$ACTION
Case ACTION
  When "TERMINE"  :   Gosub TERMINE
  When Default
Endcase
Return

$TERMINE

  #Si proceso de cierre correcto
  If NOK=0 and OK=1

     #llamada a programa externo. Disponemos de los parámetros siguientes
     #SOCIETE -> Sociedad
     #DAT_DEB -> Fecha inicio del último periodo cerrado
     #DAT_FIN -> Fecha final del último periodo cerrado
     #PERIODE -> nş primer periodo X3 no cerrado
     #EXERCICE -> nş de ejercicio X3 del primer periodo no cerrado

  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO XYCLOPER
  Local Char ZPARXYCLOP(250) : ZPARXYCLOP =func AFNC.PARAM("ZPARXYCLOP","")
  Call CALLOUTHTTP (ZPARXYCLOP+SOCIETE+"/"+num$(EXERCICE)+"/"+num$(PERIODE)+"/"+GUSER) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################

     #Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/informesumasaldos/"+SOCIETE+"/"+num$(EXERCICE)+"/"+num$(PERIODE)+"/"+GUSER) From ZJAVAUTILS

  Endif
Return
