#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
     When "WVARPOST": Gosub WVARPOST
  Endcase
Return

$WVARPOST

  Case WLIBRO
    When 1: Gosub WVARPOST_1
  Endcase

Return

$WVARPOST_1
# Factures emeses
  If !clalev([SIH]): Local File SINVOICE: Endif

  For WIND = 0 To IND
    Read [SIH]SIH0 = WNUMFACID(WIND)
    If !fstat

      # Número de factura -> Document Origen
      WFACTURAEMISOR(WIND) = [F:SIH]BPRVCR
      WNUMBPR(WIND) = [F:SIH]BPRVCR

      # Data Expedició -> Data document origen
      If [F:SIH]BPRDAT >= [01/01/2000]
        WFECHAEXPEDICION(WIND) = mid$([F:SIH]BPRDAT,7,2) + "-" + mid$([F:SIH]BPRDAT,5,2) + "-" + mid$([F:SIH]BPRDAT,1,4)
      Endif

      # Data Operació -> Camp específic Data Operació ZOPEDAT
      If [F:SIH]ZOPEDAT >= [01/01/2000]
        WFECHAOPE(WIND) = mid$([F:SIH]ZOPEDAT,7,2) + "-" + mid$([F:SIH]ZOPEDAT,5,2) + "-" + mid$([F:SIH]ZOPEDAT,1,4)
      Endif

      # Emitida por Terceros -> Camp específic Autofactura
      If [F:SIH]ZAUTFRA = 2
        WEMITER(WIND) = "S"
      Endif

      # Descripción Operación -> Camp específic Descripción Operación
      If [F:SIH]ZOPEDES <> ""
        WDESCROPE(WIND) = [F:SIH]ZOPEDES
      Endif

      # Periodo y Ejercicio -> En funció data camp específic Data Operació ZOPEDAT
      If [F:SIH]ZOPEDAT >= [01/01/2000]
        WEJERCICIO(WIND) = mid$([F:SIH]ZOPEDAT,1,4)
        WPERIODO(WIND) = mid$([F:SIH]ZOPEDAT,5,2)
      Endif

    Endif
  Next
Return

