#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
Case ACTION
 When "VERIF_CRE"     : Gosub MIO
 When "VERIF_MOD"     : Gosub MIO
Endcase
Return

$MIO

#Campo Tipo Agrupaciˇn: Este campo se alimenta a travÚs de una tabla agrupaciˇn trabajos. No aparece nada
If clalev([F:ZP3])=0 : Local File ZPREATRA [ZP3] : Endif
Read [ZP3]ZP3 = [M]FCY;[M]CCE1;[M]CCE4
If fstat = 0
  [M]ZP2 = [F:ZP3]ZP2
Endif

#Campo Usuario: Este campo se alimenta a travÚs de una tabla Centro de responsabilidad. No aparece nada.
If clalev([F:ZP1])=0 : Local File ZPRECRES [ZP1] : Endif

Read [ZP1]ZP1 = [M]FCY;left$([M]CUENTA,2);[M]CCE1;[M]CCE5;[M]CCE4
If fstat <> 0
  Read [ZP1]ZP1 = [M]FCY;left$([M]CUENTA,1);[M]CCE1;[M]CCE5;[M]CCE4
  If fstat <> 0
    Read [ZP1]ZP2 = [M]FCY;left$([M]CUENTA,2);[M]CCE1;[M]CCE5
    If fstat <> 0
      Read [ZP1]ZP2 = [M]FCY;left$([M]CUENTA,1);[M]CCE1;[M]CCE5
      If fstat <> 0
        Read [ZP1]ZP3 = [M]FCY;left$([M]CUENTA,2);[M]CCE1;[M]CCE4
        If fstat <> 0
          Read [ZP1]ZP3 = [M]FCY;left$([M]CUENTA,1);[M]CCE1;[M]CCE4
          If fstat <> 0
            Read [ZP1]ZP4 = [M]FCY;left$([M]CUENTA,2);[M]CCE1
            If fstat <> 0
              Read [ZP1]ZP4 = [M]FCY;left$([M]CUENTA,1);[M]CCE1
              If fstat <> 0
                Read [ZP1]ZP5 = [M]FCY;left$([M]CUENTA,2);[M]CCE5;[M]CCE4
                If fstat <> 0
                  Read [ZP1]ZP5 = [M]FCY;left$([M]CUENTA,1);[M]CCE5;[M]CCE4
                  If fstat <> 0
                    Read [ZP1]ZP6 = [M]FCY;left$([M]CUENTA,2);[M]CCE5
                    If fstat <> 0
                      Read [ZP1]ZP6 = [M]FCY;left$([M]CUENTA,1);[M]CCE5
                      If fstat <> 0
                        Read [ZP1]ZP7 = [M]FCY;left$([M]CUENTA,2);[M]CCE4
                        If fstat <> 0
                          Read [ZP1]ZP7 = [M]FCY;left$([M]CUENTA,1);[M]CCE4
                          If fstat <> 0
                            Read [ZP1]ZP8 = [M]FCY;left$([M]CUENTA,2)
                            If fstat <> 0
                              Read [ZP1]ZP8 = [M]FCY;left$([M]CUENTA,1)
                            Endif
                          Endif
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
[M]CODUSR = [F:ZP1]CODUSR

#CAMPO Agrupaciˇn cliente: Este campo se alimenta a travÚs de una tabla de agrupaciˇn clientes de NSAC. No aparece nada.
If clalev([F:ZPA])=0 : Local File ZGRUCLI[ZPA] : Endif
Read [ZPA]ZPA = [M]CCE3
If fstat = 0
  [M]ZP8= [F:ZPA]ZP8
Endif


Return
