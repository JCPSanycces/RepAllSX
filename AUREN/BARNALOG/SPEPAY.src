######################################################################################
$ACTION
    Case ACTION
        When "STYLE"    : Gosub OCULTAR
        When "LIENS"    : Gosub OCULTAR
        When "RAZCRE"   : Gosub OCULTAR

          ## Z23 - ValidaciÃ³n Signo Transaccio/ Sentido Saldo Colectivo
          When "PICKE"        : Gosub PICKE
         ######################################################################################
         ######################################################################################
          ######################################################################################
          ######################################################################################
          #        Z27  GestiÃ³n terminaciÃ³n colectivo sociedad/tercero
          ######################################################################################
            When "INICRE"           : Gosub INICRE
            When "INIMOD"           : Gosub INICRE
         ######################################################################################

# AUREN - DSM - 04/07/2011 - Especifico 83 - Lista nueva de vencimientos
         When "FILGAUCHE"  : Gosub Z_FILGAUCHE
         When "PICKE"      : Gosub Z_PICKE_DEPICK
         When "DEPICK"     : Gosub Z_PICKE_DEPICK
         When "FIN_ACTION" : Gosub Z_FIN_ACTION
         When "HINT"       : Gosub Z_HINT_KEY
# AUREN - DSM - 04/07/2011 - Especifico 83 - Lista nueva de vencimientos
        When Default
    Endcase
Return

######################################################################################
#        Z27  GestiÃ³n terminaciÃ³n colectivo sociedad/tercero
######################################################################################
$INICRE
Local Char TERMINACION
Local Char CUENTA
Local Integer MODIFCOLECTIVO
Local Integer ERRORCOLECTIVO

    #SÃƒÂ³lo en interactivo
    If !GIMPORT & !GWEBSERV & len([M:PAY1]BPRSAC) > 0
       Call TERMINACION_COLECTIVO([M:PAY1]CPY, [M:PAY1]BPR, [M:PAY1]BPRSAC, TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT

       If ERRORCOLECTIVO = 1
            GERR=1
            GMESSAGE = "Error en TerminaciÃ³n colectivo. Revise la configuraciÃ³n."
            GOK=0
            Return
       Else
            If len(TERMINACION) > 0    or  MODIFCOLECTIVO = 1
                # Si hay terminaciÃƒÂ³n: aÃƒÂ±adirla al colectivo
                [M:PAY1]BPRSAC =  [M:PAY1]BPRSAC + TERMINACION
                Affzo  [M:PAY1]BPRSAC
                [F:PYH]BPRSAC =  [M:PAY1]BPRSAC
            #Poner Cuenta asociada al colectivo
                [M:PAY1]ACC = CUENTA
                Affzo  [M:PAY1]ACC
                [F:PYH]ACC = [M:PAY1]ACC
                Infbox "Colectivo/Cuenta modificado." Titled "InformaciÃ³n"
            Endif
       Endif
    Endif
Return

######################################################################################
$OCULTAR
# AUREN - 5.749.177 - camp d'entrada via web servei
If !GWEBSERV
    Grizo [M:PAY1]ZPAGINTER
Endif
Return
######################################################################################
######################################################################################
##################################################################
##    Z13 - CARGAR EL NÃšMERO DE DOCUMENTO DEL VENCIMIENTO
##################################################################
Subprog C_VCRNUM(VALEUR)
    Variable Char    VALEUR()
    Local Char XNUM
    XNUM = VALEUR
    NOL=nolign-1
    Read [F:HAE] HAE0= [M]VCRTYP(NOL); XNUM
    If    fstat=0
        [M]BPRVCR(NOL)=[F:HAE]BPRVCR
        Affzo [M]BPRVCR(NOL)
    Endif
End
##################################################################
##    Z13 - CARGAR EL NÃšMERO DE DOCUMENTO DEL VENCIMIENTO
##################################################################
Subprog C_VCRTYP(VALEUR)
Variable Char    VALEUR()
Local Char TIPO
    TIPO=VALEUR
    If len(TIPO) = 0
        ## Si  no hay Tipo no hay asiento, por lo que no puede haber num. de documento
        NOL=nolign-1
        [M]BPRVCR(NOL)=""
        Affzo [M]BPRVCR(NOL)
    Endif
End
######################################################################################

######################################################################################
######################################################################################
##
## Z23 - ValidaciÃ³n Signo Transaccio/ Sentido Saldo Colectivo
##
######################################################################################
######################################################################################
Subprog C_BPRSAC(VALEUR)
Variable Char    VALEUR()
    Local Integer RESP
    RESP =0
    Call VALIDAR_SIGNO_COLECTIVO_Y_TRANSACCION([M:PAY0]PAYTYP,VALEUR, RESP )
    If RESP <> 0
         mkstat=2
    Endif
End
######################################################################################

######################################################################################
######################################################################################
##
## Z23 - ValidaciÃ³n Signo Transaccio/ Sentido Saldo Colectivo
##
######################################################################################
######################################################################################
$PICKE
Local Integer RESUL
    If len([M:PAY1]ACC) = 0
        GMESSAGE="Antes de seleccionar un vencimiento se ha de seleccionar una cuenta."
         OK=0
        GPE=1
        GERR=1
    Endif
    Return

    RESUL=0
    #
    Case currbox
     When "GAU_CHE"+num$(ILISDU5)  : # VENCIMIENTOS AGRUPADOS

        Call VALIDAR_SIGNO_COLECTIVO_Y_TRANSACCION([M:PAY0]PAYTYP,[F:DU2_]SAC, RESUL)
        If RESUL <> 0
            OK=0
            GPE=1
            GERR=1
        Endif

     When "GAU_CHE"+num$(ILISDU6)  : # VENCIMIENTOS

        Call VALIDAR_SIGNO_COLECTIVO_Y_TRANSACCION([M:PAY0]PAYTYP,[F:DU1_]SAC, RESUL)
        If RESUL <> 0
            OK=0
            GPE=1
            GERR=1
        Endif

    Endcase

Return


######################################################################################
######################################################################################
##
## Z23 - ValidaciÃ³n Signo Transaccio/ Sentido Saldo Colectivo
##
######################################################################################
######################################################################################
Subprog VALIDAR_SIGNO_COLECTIVO_Y_TRANSACCION(TRANSACCION,COLECTIVO, RESLT)

Variable Char TRANSACCION
Variable Char COLECTIVO
Variable Integer RESLT

    RESLT=0

     ## Abrir tabla Transaccines de pagos
    If clalev([ZTYP])<=0 Local File TABPAYTYP [ZTYP] : Endif

    ## Abrir tabla Cuentas generales
    If clalev([ZGAC])<=0 Local File GACCOUNT [ZGAC] : Endif

    ## Obtener sentido Transaccines de pagos

    Read [F:ZTYP]TPY0=TRANSACCION;GCURLEG
    If fstat=0
         ## Obtener sentido saldo Colectivo
        Read [F:ZGAC]GAC1=GCURLEG;COLECTIVO
        If fstat=0

             ## Validar que la combinaciÃ³n sentido de la transacciÃ³n y sentido saldo del colectivo sea la correcta

            Case [F:ZTYP]SNS     # Evaluar signo TransacciÃ³n
                When 1           # Gasto

                      # El signo del Colectivo ha de ser Haber (2)
                      If [F:ZGAC]SNSBLC <> 2
                           # ERROR
                          GMESSAGE="El Sentido Saldo del Colectivo sólo puede ser Haber."
                           RESLT=1
                      Endif

                When 2           #Ingreso

                      # El signo del Colectivo ha de ser Debe (1)
                      If [F:ZGAC]SNSBLC <> 1
                             # ERROR
                              GMESSAGE="El Sentido Saldo del Colectivo sólo puede ser Debe."
                              RESLT=1

                      Endif

                When 3           #Indefinido

                    GMESSAGE="Signo de la Transacción " + TRANSACCION + " Indefinido"
                    GERR = 2

                 When Default
                    GMESSAGE="Signo de la Transacción " + TRANSACCION + " no especificado"
                    RESLT=1

            Endcase


        Else
            ##ERROR
            GMESSAGE="No se ha encontrado el colectivo  " + COLECTIVO
            # ERROR
            RESLT=1

        Endif

    Else
         ##ERROR
         GMESSAGE="No se ha encontrado la transacción " + TRANSACCION
         # ERROR
         RESLT=1

    Endif

End

######################################################################################
######################################################################################
##
## Z23 - ValidaciÃ³n Signo Transaccio/ Sentido Saldo Colectivo
##
######################################################################################
######################################################################################
Subprog AP_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer REST

    If len([M:PAY1]ACC) = 0
        GMESSAGE="Antes de seleccionar un vencimiento se ha de seleccionar una cuenta."
        mkstat=2
    Endif
    End

    REST =0

    Call VALIDAR_SIGNO_COLECTIVO_Y_TRANSACCION([M:PAY0]PAYTYP,[M]BPRSACINV(nolign-1), REST )
    If REST <> 0
         mkstat=2
    Endif

End

######################################################################################


# AUREN - DSM - 04/07/2011 - Especifico 83 - Lista nueva de vencimientos

###############################################################################
#### Filtre pour les tiroirs
###############################################################################
$Z_FILGAUCHE
Local Integer ILISZD6
ILISZD6=find("ZD6",OBJLIS)-1

If ILIS
 Case ILIS

  When ILISZD6   :# Echéances groupées, Echéances

   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "FLGCLE=1", " & ") From GOBJSUB
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO') ) | (DUDSTA=2 & !find(TYP,'*SO','*PO'))) ","") From GOBJSUB

   If [M]FCY<>""
    Call PARAM([M]FCY,"SEVFCYENT",OPT) From ADOVAL  : # OD inter-sites
    Call IND_SELRAP("ZD6","FCY",IND) From GOBJACT
    If OPT<>"2" | SAIRAP(IND)=""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "FCY=[M]FCY", " & ") From GOBJSUB
    Endif
   Endif
   If [M]BPR<>""
    Call PARAM([M]FCY,"SEVBPRENT",OPT) From ADOVAL : # OD inter-tiers
    Call IND_SELRAP("ZD6","BPRPAY",IND) From GOBJACT
    If OPT<>"2" | SAIRAP(IND)=""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRPAY=[M]BPR", " & ") From GOBJSUB
    Endif
   Endif
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRFCT=''", " & ") From GOBJSUB

   # Pas de pièce comptable pour les acomptes  # Bug 22468
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO') ) | ([F:GTE]DUDDATFLG=2 & !find(TYP,'*SO','*PO'))) ","") From GOBJSUB
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO') ) | ([F:HAE]FLGREP<>2 & !find(TYP,'*SO','*PO'))) ","") From GOBJSUB
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO') ) | (left$([F:HAE]REFINT,3)<>'PYH' & !find(TYP,'*SO','*PO'))) ","") From GOBJSUB

   If [M]USRPAZ<[M]MAXPAZ | ([M]USRPAZ>=[M]MAXPAZ & [L]OPTCTLBAP="1")
    Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "(SNS=1 | FLGPAZ>="+num$([M]MAXPAZ)+")", " & ") From GOBJSUB
   Endif

   GPOINT = "CRITERE" : Gosub ENTREE From EXEFNC
 Endcase
Endif
Return

###############################################################################
#### Pick les éléments des tiroirs des échéances
###############################################################################
$Z_PICKE_DEPICK
Local Integer ILISZD6
ILISZD6=find("ZD6",OBJLIS)-1

# Il faut lire la table des échéances.
Case currbox
 When "GAU_CHE"+num$(ILISZD6)  : # Tiroir Echéances
  Read [ZD6_]DUD0 = [F:ZD6_]TYP;[F:ZD6_]NUM;[F:ZD6_]LIG;[F:ZD6_]DUDLIG
  [F:DUD] = [F:ZD6_]
Endcase
Return

###############################################################################
## $HINT_KEY   : Amélioration des performances (DdM31546)
###############################################################################
$Z_HINT_KEY
Local Integer ILISZD6
ILISZD6=find("ZD6",OBJLIS)-1

If ILIS
 Case ILIS
  When ILISZD6   :# Echéances groupées, Echéances
   HINTLIS(ILIS)="DUD3"
 Endcase
Endif
Return

###############################################################################
$Z_FIN_ACTION
Local Integer ILISZD6
ILISZD6=find("ZD6",OBJLIS)-1

Case REPONSE
 When GSTAPRG,GSTASVG
  Case currbox
   When "GAU_CHE"+num$(ILISZD6)  : # Tiroir Echéances groupées
                                                         : # Tiroir Echéances
    Gosub Z_MARQUE
  Endcase

Endcase
Return

########
$Z_MARQUE
If [M]NBLIG>0
 For I=0 To [M]NBLIG-1
  If [M]DUDNUM(I)>0 & [M]DUDLIG(I)>0
   Read [DUD]DUD1 =[M]DUDNUM(I);[M]DUDLIG(I)
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
 Next I
Endif
Return
# AUREN - DSM - 04/07/2011 - Especifico 83 - Lista nueva de vencimientos

