#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################################
### Código Actividad Z30                                                           ###
### Envío mail de cada pago                                                        ###
### EL PROCESO NO TIENE CÓDIGO, ÚNICAMENTE CREADO PARA EJECUCIÓN WORKFLOW          ###
######################################################################################

$ACTION
Case ACTION
 When "INIT"
  Case GACTION
   When "ZSENDMAILP"  : Gosub INIT_ZSENDMAIL
  Endcase
 When "EXEC"
  Case GACTION
   When "ZSENDMAILP"  : Gosub EXEC_ZSENDMAIL
  Endcase
 When "TERMINE"
  Case GACTION
   When "ZSENDMAILP"  : Gosub TERM_ZSENDMAIL
  Endcase
Endcase
Return


######################################################################################
$INIT_ZSENDMAIL

Return
######################################################################################



######################################################################################
$EXEC_ZSENDMAIL

### AUREN - DSM - 06/10/2012 - Especifico 103 - AmpliaciÃ³n envio mail de pagos
    Local Libelle RES
    Local    Char    XFLG     : XFLG    = PARAM(1)  ## Tipo de asiento
    Local    Char    XNUM     : XNUM    = PARAM(2)  ## Numero de asiento

    ## Confirmación ejecución proceso envío mail
    RES=2
    Qstbox "Se va a proceder al enví­o de mail del pago.", "¿Desa continuar?" - nomap Using [L]RES Sleep 10
    Case [L]RES
    When 1 : Call SENDMAILPAGO(XFLG,XNUM) From ZSENDMAIL
    When 2 : End
    Endcase

    End
### AUREN - DSM - 06/10/2012 - Especifico 103 - AmpliaciÃ³n envio mail de pagos
Return




######################################################################################
$TERM_ZSENDMAIL


Return
######################################################################################

