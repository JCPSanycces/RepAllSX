#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
$ACTION
    Case ACTION
        When "SORTIE"      : Gosub SORTIE
        When "EXEC"        : Gosub EXEC
    Endcase
Return
#########################################################################


$EXEC
  #Char FICHIERS(200)(50)
  ## AUREN - MIGRACIÓN PU9 - COMENTADA LINEA PARA PRUEBAS
  #System FICHIERS = "#@\\172.16.1.131\VBEXE\COMPLEMENTOSX3\SETRAM.exe ANUPAGOINTERCIA " + nomap(0) + " " + [M:PAY0]NUM + " " + GUSER

  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEZAF
  Local Char ZPARXYANUP(250) : ZPARXYANUP =func AFNC.PARAM("ZPARXYANUP","")
  Call CALLOUTHTTP (ZPARXYANUP + nomap(0) + "/" + GUSER + "/" + [M:PAY0]NUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################

  #Call CALLOUTHTTP ("http://172.16.1.126/SWX3/especificospu5.svc/eliminaCobroIntercia/" + nomap(0) + "/" + GUSER + "/" + [M:PAY0]NUM) From ZJAVAUTILS

Return


#########################################################################
$SORTIE

    If [M:PAY1]ZPAGINTER <> "" and [F:PYH]STA = 1
        If clalev([F:ZPYH])<=0  : Local File PAYMENTH   [ZPYH]  : Endif

        Local Char PARBOUT(250)(1..1)
        Local Char VALBOUT(30)

        NPYH = [M:PAY1]ZPAGINTER
        PARAM(1) = [M:PAY1]ZPAGINTER

        Read [F:ZPYH]PYH0 = [M:PAY1]ZPAGINTER
        If fstat
            Raz [F:ZPYH]
            Infbox "Pago no generado " + [M:PAY1]ZPAGINTER
            Return
        Elsif [F:ZPYH]STA<11 & find(2,[F:ZPYH]STAFLG(2),[F:ZPYH]STAFLG(7),[F:ZPYH]STAFLG(8))
            [M:DIA]FCY    = [F:ZPYH]FCY
            [M:DIA]DESVCR = mess(33,121,1)-NPYH
        Else
            Raz [F:ZPYH]
            Infbox "Pago intersociedad no contabilizado, cancelación impossible " + [M:PAY1]ZPAGINTER
            Return
        Endif

        Raz [PYH]
        Raz [PYD]
        Raz [DUD]

        GACTION = "ANUPYH"
        PARBOUT(1) = [M:PAY1]ZPAGINTER
        Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ANUPYH","DANUPYH",3,"") From GTRAITE

        Read [PYH]PYH0 = [M:PAY0]NUM : If fstat Raz [F:PYH] : Endif
    Endif

Return
#########################################################################
#########################################################################
