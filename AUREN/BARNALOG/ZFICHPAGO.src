######################################################################################
### AUREN -  06.011.653                                                            ###
### Llamada programa externo generaciÛn fichero pago banco Chile                   ###
######################################################################################

$ACTION
Case ACTION
 When "INIT"
  Case GACTION
   When "ZFICHPAGO"   : Gosub INIT_ZFICHPAGO
  Endcase
 When "EXEC"
  Case GACTION
    When "ZFICHPAGO"  : Gosub EXEC_ZFICHPAGO
  Endcase
 When "TERMINE"
  Case GACTION
  When "ZFICHPAGO"    : Gosub TERM_ZFICHPAGO
  Endcase
Endcase
Return


######################################################################################
$EXEC_ZFICHPAGO

    Local Libelle RES

    ## Confirmacion generaciÛn fichero
    RES=2
    Qstbox "Se va a proceder a la generaciÛn del fichero de pago. Confirme para continuar  " - nomap Using [L]RES Sleep 10
    Case [L]RES
    When 1 : Gosub CALL_CREARFICHEROPAGO
    When 2 : End
    Endcase

    End

Return
######################################################################################

######################################################################################
$INIT_ZFICHPAGO

Return
######################################################################################

######################################################################################
$TERM_ZFICHPAGO

Return
######################################################################################

$CALL_CREARFICHEROPAGO

    ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO ZFICHPAGO
  Local Char ZPARZFICHP(250) : ZPARZFICHP =func AFNC.PARAM("ZPARZFICHP","")
  Call CALLOUTHTTP (ZPARZFICHP+ [S]nomap(0) + "/" + GUSER + "/" + [M:FRM0]FRMNUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################


   #Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/CrearFicheroPago/" + [S]nomap(0) + "/" + GUSER + "/" + [M:FRM0]FRMNUM) From ZJAVAUTILS

Return
