######################################################################################
## ZAU  14/02/2011 No permitir modificar el primer documento adjunto
######################################################################################
Subprog AS_TYPDOC(VALEUR)
Variable Char    VALEUR()

    If [M]NBLIG >  0 and nolign= 1
         mkstat=2
    Endif
End


######################################################################################

######################################################################################
## ZAU  14/02/2011 No permitir modificar el primer documento adjunto
######################################################################################
Subprog AS_CAT(VALEUR)
Variable Integer VALEUR

        If [M]NBLIG >  0 and nolign= 1
         mkstat=2
    Endif
End

######################################################################################
## ZAU  14/02/2011 No permitir modificar el primer documento adjunto
######################################################################################
Subprog AS_MOTCLE(VALEUR)
Variable Char    VALEUR()
        If [M]NBLIG >  0 and nolign= 1
         mkstat=2
    Endif
End


######################################################################################
## ZAU  14/02/2011 No permitir eliminar el primer documento adjunto
##                 No permitir insertar una documento antes del primer doc. adjunto
######################################################################################
Subprog C_NBLIG

    If status =73 and nolign= 1
        GMESSAGE= "No se  permite insertar un documento. A鼁dala al final."
        mkstat=2
        End
    Endif

    If status = 65 and nolign= 1
        GMESSAGE= "No se  permite eliminar este documento."
        mkstat=2

    Endif

End


######################################################################################

######################################################################################
## ZAU  15/02/2011 No permitir modificar el primer documento adjunto
##
######################################################################################
Subprog C_NAM(VALEUR)
Variable Char    VALEUR()
    If [M]NBLIG >  0 and nolign= 1
        If VALEUR <> [M]NAM
             GMESSAGE= "No se permite modificar el nombre del documento."
             mkstat=2
        Endif
    Endif
End


