#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################################
### Proceso de escaneo de facturas recibidas                    JGM -- 15/06/2009  ###
######################################################################################
$ACTION
Case ACTION
 When "INIT"
  #----------------------------------#
  # Inicio de ejecucciˇn del proceso #
  #----------------------------------#
  Case GACTION
   When "ZEMIINF"  : Gosub INIT_ZEMIINF
  Endcase
 When "EXEC"
  #-------------------------#
  # Ejecucciˇn del proceso  #
  #-------------------------#
  Case GACTION
   When "ZEMIINF"  : Gosub EXEC_ZEMIINF
  Endcase
 When "TERMINE"
  #--------------------------------#
  # Fin de ejecucciˇn del proceso  #
  #--------------------------------#
  Case GACTION
   When "ZEMIINF"  : Gosub TERM_ZEMIINF
  Endcase
Endcase
Return
######################################################################################
$INIT_ZEMIINF
  
Return
######################################################################################
$EXEC_ZEMIINF
Local Char INFORME
Local Char VERSION
Local Char RUTA(200)
Local    Char     XPARAMETROS(200)

INFORME = [M]TXSNAM
VERSION = [M]VERSION


If len(VERSION) <> 10 Then
  Infbox "La versiˇn del informe no es correcta. No sigue la norma aaaa_mm_tt. "
  Return
Endif

Local Char VALE 
VALE = "0"
If (mid$(VERSION,1,1) < "0" or mid$(VERSION,1,1) > "9") : VALE = "1" : endif
If (mid$(VERSION,2,1) < "0" or mid$(VERSION,2,1) > "9") : VALE = "2" : endif
If (mid$(VERSION,3,1) < "0" or mid$(VERSION,3,1) > "9") : VALE = "3" : endif
If (mid$(VERSION,4,1) < "0" or mid$(VERSION,4,1) > "9") : VALE = "4" : endif
If (mid$(VERSION,5,1) <> "_") : VALE = "5" : endif
If (mid$(VERSION,6,1) < "0" or mid$(VERSION,6,1) > "9") : VALE = "6" : endif
If (mid$(VERSION,7,1) < "0" or mid$(VERSION,7,1) > "9") : VALE = "7" : endif
If (mid$(VERSION,8,1) <> "_") : VALE = "8" : endif

If VALE <> "0" Then
  Infbox "La versiˇn del informe no es correcta. No sigue la norma aaaa_mm_tt." + VALE
  Return 
Endif


RUTA = "E:\INFORMES\PLANTILLAS\INFRESUMEN.EXE " + INFORME + " " + VERSION

Char FICHIERS(200)(50)
System FICHIERS = RUTA

If stat1 <>0
  GERR=1 
  GMESSAGE="Error al emitir informe" 
  GOK=0 
  Return
Endif

Infbox "Creaciˇn de informe finalizada"

Return
######################################################################################
$TERM_ZEMIINF

Return
######################################################################################


