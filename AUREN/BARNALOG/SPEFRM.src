# Gestión de la máscara FRM0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla FRM0) 23/10/2014 16:35:01 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog C_FRMTYP(VALEUR)
Variable Integer VALEUR

    If ([M:FRM0]PAYTYP="PSCT" | [M:FRM0]PAYTYP="PSCT2" |[M:FRM0]PAYTYP="PEFE" | [M:FRM0]PAYTYP="PLIQ" | [M:FRM0]PAYTYP="PPAG" | [M:FRM0]PAYTYP="PTRA" | [M:FRM0]PAYTYP="SCT") & VALEUR<>2

         GMESSAGE = "Tipo de remesa tiene que ser PAGO para el tipo de Transacción " + [M:FRM0]PAYTYP
         mkstat=2

    Endif

End

