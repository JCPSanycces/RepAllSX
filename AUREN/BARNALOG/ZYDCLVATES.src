$ACTION
    Case ACTION
        When "WRITE"    :    Gosub ZWRITE
    Endcase
Return

$ZWRITE
Local Char XNUM
    
    [YDI]XNUM = [YDI]NUM

    #If [YDI]TIPOIVA = "R" & [YDI]BPRVCR <> ""
    #    [YDI]NUM = [YDI]BPRVCR
    #Endif

    If [YDI]VAT = "042" or [YDI]VAT = "043"
        [YDI]CODOPE = ""
    Endif

Return
