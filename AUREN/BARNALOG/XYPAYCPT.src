#########################################################################
$ACTION
    Case ACTION
        When "EXEC"      : Gosub EXEC
    Endcase
Return
#########################################################################


$EXEC

  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO XYPAYCPT
  Local Char ZPARXYPAYC(250) : ZPARXYPAYC =func AFNC.PARAM("ZPARXYPAYC","")
  #####AUREN.FIN
  ###########################################################################################

If clalev([M:PAY0])>0
  Char FICHIERS(200)(50)
  ## AUREN - MIGRACI”N PU9 - COMENTADO PARA PRUEBAS
  #System FICHIERS = "#@\\172.16.1.131\VBEXE\COMPLEMENTOSX3\SETRAM.exe PAGOINTERCIA " + nomap(0) + " " + [M:PAY0]NUM + " " + GUSER

  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO XYPAYCPT
  Call CALLOUTHTTP (ZPARXYPAYC + nomap(0) + "/" + GUSER + "/" + [M:PAY0]NUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################
  #Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/creaCobroIntercia/" + nomap(0) + "/" + GUSER + "/" + [M:PAY0]NUM) From ZJAVAUTILS

Else
  Filter [PYH] Where FRMNUM=PARAM(3) Order By FRMLIN Asc
  For [PYH]
    Char FICHIERS(200)(50)
    ## AUREN - MIGRACI”N PU9 - COMENTADO PARA PRUEBAS
    #System FICHIERS = "#@\\172.16.1.131\VBEXE\COMPLEMENTOSX3\SETRAM.exe PAGOINTERCIA " + nomap(0) + " " + [PYH]NUM + " " + GUSER

  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO XYPAYCPT
  Call CALLOUTHTTP (ZPARXYPAYC+ nomap(0) + "/" + GUSER + "/" + [PYH]NUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################

   # Call CALLOUTHTTP ("http://192.168.50.5:81/SWX3/especificospu5.svc/creaCobroIntercia/" + nomap(0) + "/" + GUSER + "/" + [PYH]NUM) From ZJAVAUTILS
  Next
  Filter [PYH]
Endif
Return
