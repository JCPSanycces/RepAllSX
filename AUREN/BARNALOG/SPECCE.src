$ACTION
Case ACTION
  When "APRES_MOD"    : Gosub REPLICA
  When "APRES_CRE"    : Gosub REPLICA
Endcase
Return

##################################
# Registro de la modificación de un registro
# 17.04.2009 LPardo
##################################
$REPLICA
Local File ZSCCE [ZSS]

#AUREN - PU9 - Función comentada porqué produce error
[ZSS]CCE = [F:CCE]CCE
#[ZSS]AXI = [F:CCE]AXI
[ZSS]AXI = val(mid$([F:CCE]DIE,3,1))
[ZSS]DES = [F:CCE]DES
[ZSS]DESSHO = [F:CCE]DESSHO
[ZSS]FCY = [F:CCE]FCY
[ZSS]CREUSR = [F:CCE]CREUSR
[ZSS]CREDAT = [F:CCE]CREDAT
[ZSS]UPDUSR = [F:CCE]UPDUSR
[ZSS]UPDDAT = [F:CCE]UPDDAT
Write [ZSS]



Close Local File [ZSS]
Return

######################################################################################
## AUREN - PU9 - CONTROL CAMPO DIE
## En pantalla CCE0 se cambia campo DIE a Entrada para ejecución WS
## Si ejecución no WS se grisea el campo (como en std)
######################################################################################
Subprog AS_DIE(VALEUR)
Variable Char    VALEUR()

  If !GWEBSERV
    Grizo [CCE0]DIE
  Endif

End
######################################################################################

