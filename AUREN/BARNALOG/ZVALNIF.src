#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog ZVALNIF(PAIS, NIF, WERR, WERRSTR)
Value Char PAIS
Value Char NIF
Variable Integer WERR
Variable Char WERRSTR

WERR = 0

Case PAIS
    When "ES"
        Call SIRET (NIF,PAIS,WERR) From CONTSPAIN
    When "FR"
        Call SIRET (NIF,PAIS,WERR) From CONTFRANCE
    When "IT"
        Call SIRET (NIF,PAIS,WERR) From CONTITA
    When "PO"
        Call SIRET (NIF,PAIS,WERR) From CONTPOR
Endcase

WERRSTR = ""

Local File BPARTNER [BP]

If WERR = 0 Then
  Filter [BP] Where [BP]EECNUM = NIF or [BP]CRN = NIF
  Read [BP] First
  If [BP]EECNUM = NIF or [BP]CRN = NIF
    WERR = - val([BP]BPRNUM)
    WERRSTR = num$([BP]BPRNUM)-' '-[BP]BPRNAM(0)
  Endif

Endif

Close Local File [BP]

End

