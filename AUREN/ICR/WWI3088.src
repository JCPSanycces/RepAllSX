#<AdxTL>@(#)%I% Importación de datos SMO (WWI3088)
$INI_IMPORT
GERREUR = 0
Onerrgo ERREUR From SUBIMPOBJ
Local Date     DAT
Local Integer  DEBUT,NUMFLD,NBL,ANOWRITE
Local Integer  A_LIBEL, A_ER , OK_IMPRIME
Local Char     IMPFIC(GLONABR)
Local Integer  IMPFIN, RUPT, NBCRE, NBMOD, NBENR, NBERR, EGAL
Local Integer  IMPFINS, SEPNUMS, INDTRT
Local Integer  SEPNUM, DEBENR, WDEBENR
Local Integer  SAVSTA
Local Integer  FNBERR, WGNBIMP
Local Integer  K, IMPSTA , SAVLIG , IMPORTYP, LIGIMP
Local Char     VALIMP(255)(500), LIGNE(255)
Local UUident  AUUID
Local Datetime DATTIME
Local Blbfile  BLBIMP(1)(0..0)
Local Clbfile  CLBIMP(1)(0..0)
Local Char     NOMTRT(GLONADC) , TRTMSK(GLONADC) , TRTIMPORT(GLONADC)
Local Char     NOMVAR(200)
# Pour Setmode
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

OK = 1
IMPORTYP = 1
TRTIMPORT = ""
NOMTRT="WWI3088"
Gosub OUVRE From SUBIMPOBJ
If OK=0 : Return : Endif
If OK=0 : Return : Endif
Openi "D:\Sage\X3APL\folders\X3_PUB\ICRDEV\TMP\F1652188950264" Using [IMP]
Raz IMPFIN, GREP, RUPT, DEBENR, NBCRE, NBMOD, NBENR, NBERR
Raz GNBIMP, GERIMP,GNUMAOW,GNUMAOV,GMESSIMP
Raz FNBERR, WGNBIMP
OK_IMPRIME = 0
Return

$IMPORT
WDEBENR = adxseek("IMP")
NBENR += 1
SAVIRS = adxirs : SAVIFS = adxifs : SAVIUM = adxium
adxirs = IMPIRS : adxifs = IMPIFS : adxium = IMPIUM
Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUM,IMPFIN,WDEBENR) From SUBIMPOBJ
adxirs = SAVIRS : adxifs = SAVIFS : adxium = SAVIUM
If IMPFIN : Return : Endif
Case SEPNUM
 When 1 : Gosub IMPORT0
 When 2 : Gosub IMPORT1
 When 3 : Gosub IMPORT2
 When 4 : Gosub IMPORT3
Endcase
Call AFFICHE("D:\Sage\X3APL\folders\X3_PUB\ICRDEV\TMP\F1652188950264","F1652084934903",SEPNUM,IMPFIN,NBENR) From SUBIMPOBJ
FIN_IMP
If WGNBIMP<>GNBIMP and NBERR>0 : FNBERR += 1 : WGNBIMP = GNBIMP : Endif
Return

$FERME
Gosub FERME From SUBIMPOBJ
Onerrgo
Return

$DEFAUT
Default File [SMH]
Return

$IMPORT0
Raz [F:SMH]
LIGNE = VALIMP(1)
 # Menu local: VCRTYP
Call SETLIB(A_LIBEL,701,LIGNE) From SUBIMPOBJ
[F:SMH]VCRTYP = A_LIBEL
LIGNE = VALIMP(2)
 # Alphanumérique: STOFCY
[F:SMH]STOFCY = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:5c",[F:SMH]STOFCY),2) & OK_IMPRIME
 Call TRACE2(-2,"Error formato STOFCY K:5c"-num$(LIGNE),2) From SUBIMPOBJ
Endif
[F:SMH]STOFCY = vireblc(format$("K:5c",[F:SMH]STOFCY),1)
LIGNE = VALIMP(3)
 # Date: IPTDAT
Call SETDATE(DAT,LIGNE,4,A_ER) From SUBIMPOBJ
[F:SMH]IPTDAT = DAT
If A_ER & OK_IMPRIME
 Call TRACE2(-2,"Fecha incorrecta IPTDAT"-LIGNE,3) From SUBIMPOBJ
Endif
LIGNE = VALIMP(4)
 # Alphanumérique: VCRDES
[F:SMH]VCRDES = vireblc(LIGNE,2)
LIGNE = VALIMP(5)
 # Alphanumérique: PJT
[F:SMH]PJT = vireblc(LIGNE,2)
LIGNE = VALIMP(6)
 # Alphanumérique: TRSFAM
[F:SMH]TRSFAM = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:20B",[F:SMH]TRSFAM),2) & OK_IMPRIME
 Call TRACE2(-2,"Error formato TRSFAM K:20B"-num$(LIGNE),6) From SUBIMPOBJ
Endif
[F:SMH]TRSFAM = vireblc(format$("K:20B",[F:SMH]TRSFAM),1)
LIGNE = VALIMP(7)
 # Alphanumérique: WRHE
[F:SMH]WRHE = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:5c",[F:SMH]WRHE),2) & OK_IMPRIME
 Call TRACE2(-2,"Error formato WRHE K:5c"-num$(LIGNE),7) From SUBIMPOBJ
Endif
[F:SMH]WRHE = vireblc(format$("K:5c",[F:SMH]WRHE),1)
LIGNE = VALIMP(8)
 # Alphanumérique: ZBPC
[F:SMH]ZBPC = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:15c",[F:SMH]ZBPC),2) & OK_IMPRIME
 Call TRACE2(-2,"Error formato ZBPC K:15c"-num$(LIGNE),8) From SUBIMPOBJ
Endif
[F:SMH]ZBPC = vireblc(format$("K:15c",[F:SMH]ZBPC),1)
LIGNE = VALIMP(9)
 # Alphanumérique: ZFCY
[F:SMH]ZFCY = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:5c",[F:SMH]ZFCY),2) & OK_IMPRIME
 Call TRACE2(-2,"Error formato ZFCY K:5c"-num$(LIGNE),9) From SUBIMPOBJ
Endif
[F:SMH]ZFCY = vireblc(format$("K:5c",[F:SMH]ZFCY),1)
ACTION='AP_IMPORT' : Gosub ACTION From SUBIMPOBJ
Return

$IMPORT1
Raz [F:SMD]
LIGNE = VALIMP(1)
 # Alphanumérique: ITMREF
[F:SMD]ITMREF = vireblc(LIGNE,2)
If vireblc(LIGNE,2)<>vireblc(format$("K:20c",[F:SMD]ITMREF),2)
 Call TRACE2(-2,"Error formato ITMREF K:20c"-num$(LIGNE),1) From SUBIMPOBJ
Endif
[F:SMD]ITMREF = vireblc(format$("K:20c",[F:SMD]ITMREF),1)
LIGNE = VALIMP(2)
 # Alphanumérique: PCU
[F:SMD]PCU = vireblc(LIGNE,2)
LIGNE = VALIMP(3)
 # Numérique: QTYPCU
Call SETNUM(LIGNE,'.') From SUBIMPOBJ
[F:SMD]QTYPCU = val(LIGNE)
LIGNE = VALIMP(4)
 # Alphanumérique: STU
[F:SMD]STU = vireblc(LIGNE,2)
LIGNE = VALIMP(5)
 # Numérique: QTYSTU
Call SETNUM(LIGNE,'.') From SUBIMPOBJ
[F:SMD]QTYSTU = val(LIGNE)
ACTION='AP_IMPORT' : Gosub ACTION From SUBIMPOBJ
Return

