######################################################################################
Subprog B2_NBLIG
## Action PAYGAS
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Char    RESULT(250)
SAVACT = GACTION : GACTION = "PAYGAS"
PARMSK(1) = "3"
PARMSK(2) = [M:BSIMTC4]NUM(nolign-1)
Call S_TAB_CHAR(RESULT,PARMSK,"","PAYCPTTRA","") From GACTION
GACTION = SAVACT

Local Char VALC1(20), VALC2(20), VALC3(20)
Local Integer I
I=instr(1,RESULT," ")
If I
  [L]VALC1="GAS" : [L]VALC3=left$(RESULT,I-1) : [L]VALC2=right$(RESULT,I+1)
  Call OBJET([L]VALC1, [L]VALC2, [L]VALC3) From GOBJET
Endif
End


######################################################################################
$FIN_ACTION
Case BOUT
 When "w"           # Manual entry
    Gosub SETBOUT From GOBJSUB      # enforce correct handling of "Manual entry" button
Endcase
Return


######################################################################################
$AVANT_CHOI
If [M:BSIMTC0]TYPMTC = "O"                    # open item matching > disable payment grid
    Diszo [M:BSIMTC4]NBLIG
Elsif left$([M:BSIMTC0]TYPMTC,1) = "P"        # payment matching > disable open item grid
    Diszo [M:BSIMTC4]NBLIG1
Endif
Return


# X3-156158 2019-08-14 Bader begin
Funprog GET_FORMATTED_AMOUNT(PAMOUNT,PCUR)
Value Decimal PAMOUNT
Value Char PCUR
Local Char FAMT(30)
Local File TABCUR [TCU]
Call LECTURE("TCU", PCUR, "") From CONTOBJ     # Read currency table
FAMT = format$("N3zF:"+[F:TCU]CURFMT1, PAMOUNT)
End FAMT
# X3-156158 2019-08-14 Bader end


######################################################################################
## Section automatically added (screen BSIMTC4) 04/24/2020 08:49:42 (JOJAC)
######################################################################################
Subprog C_DUDPAYSTM(VALEUR)
Variable Decimal VALEUR
# X3-200184 2020-06-04 bader begin blocking message only if OI currency = transaction currency (because of currency rate changes between invoice and payment)
If [M:BSIMTC4]DUDCURAMT(nolign-1) = [M:BSIMTC4]DUDCURLOC(nolign-1) # same currencies? if yes, check for overpayment
    #JOJAC - X3-191866 - 2020-04-20 - START
     # The value must not exceed the oi amount in statement currency.
    If VALEUR > [M:BSIMTC4]DUDAMTLOC( nolign-1 )
        GMESSAGE = mess(56,117,1) # 'Overpayment not authorized'
        mkstat = 2
    Endif
    #JOJAC - X3-191866 - 2020-04-20 - END
Endif
# X3-200184 2020-06-04 bader end
End


# X3-223301 2020-11-13 Bader begin add check if payment already selected in another transaction
######################################################################################
Subprog C_PAYSEL(VALEUR)
Variable Integer VALEUR
If VALEUR = [V]CST_AYES Then
   If clalev([F:BSIPAY1]) = 0 Then : Local File BSIPAY [BSIPAY1]   : Endif
   # check if payment already matched to another transaction and selected
   Filter [F:BSIPAY1] Where NUM = [M:BSIMTC4]NUM(nolign-1) and [F:BSIPAY1]PAYSEL = [V]CST_AYES
&   and ([F:BSIPAY1]STMCOD <> [M:BSIMTC0]STMCOD or [F:BSIPAY1]LIN <> [M:BSIMTC0]LIN)
   Read [F:BSIPAY1] First
   If !fstat     # is yes > error message
      mkstat = 2
      GMESSAGE = func AFNC.MES2(mess(324,7703,1),[F:BSIPAY1]NUM,[F:BSIPAY1]STMCOD+"/"+num$([F:BSIPAY1]LIN))
   Endif
   Filter [F:BSIPAY1]
Endif
End
# X3-223301 2020-11-13 Bader end


