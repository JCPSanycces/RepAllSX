#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "EXEC" : Gosub EXEC_ZVERASTO
Endcase
Return

$EXEC_ZVERASTO
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + PARAM(1),
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Return
