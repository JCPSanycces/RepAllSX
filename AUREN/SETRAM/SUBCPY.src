Subprog AV_LEG(VALEUR)
Variable Char     VALEUR
If !func AFNC.ACTIV("LEG")
 If VALEUR="" & find(GREP,"C","D")
  VALEUR = GDOSLEG
 Endif
 Diszo LEG
Endif
End

Subprog C_CRN(VALEUR)
Variable Char    VALEUR()
If vireblc(VALEUR,2)=""
 Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
 If !fstat & dim([F:TCY]CRNOBL)>0 & [F:TCY]CRNOBL=2
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif
Endif
End

