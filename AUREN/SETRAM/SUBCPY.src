#<AdxTL>@(#)0.0.0.0 $Revision$ Sociétés
Raz GPILOBJ , GNBMASKOUV
Call OBJET("CPY",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBCPYB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "RAZCRE"       : Gosub RAZCRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "APRES_CRE"    : Gosub APRES_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "ANNULE"       : Gosub ANNULE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AP_ANNULE"    : Gosub APRES_ANNULE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "RAZDUP"       : Gosub RAZDUP
Endcase
If PSUBB
 Gosub ACTION From SUBCPYB
Endif
Return

#-----------------------------------------------------------#
$OUVRE
Local Integer LOGO
Local Clbfile ENTMES(1)
Local Char    TEXMES(250)
Gosub NUMBPA
#111767 no update on historical folder
If func DOSSUB.ISHISTFOLD(nomap)=0 & val(func AFNC.PARAM("CPYMAXLEN",""))=0
 Call MAJLENCOD("")
Endif
Return

$NUMBPA
Local Integer NUMBPA
NUMBPA = 2
Return

#------------------------------------#
Subprog MAJLENCOD(DOSSIER)
Value Char DOSSIER
Local Char    MAXCOD(GLONCPY) , MINCOD(GLONCPY) , TEXMES(250)(1..5)
Local Clbfile ENTMES(1)
Local Integer I
If DOSSIER="" or DOSSIER=nomap
 Local File COMPANY [CPY]
Else
 Local File =DOSSIER+".COMPANY" [CPY]
Endif
Raz MAXCOD , MINCOD
For [CPY]
 If len(MINCOD)=0 or len([F:CPY]CPY)<len(MINCOD)
  MINCOD = [F:CPY]CPY
 Endif
 If len([F:CPY]CPY)>len(MAXCOD)
  MAXCOD = [F:CPY]CPY
 Endif
Next CPY
If len(MAXCOD)<>len(MINCOD)
 # Attention, la longueur des codes $1$ n'est pas uniforme (il varie de $2$ [$3$] ŕ $4$ [$5$']).
 # Si vous utilisez des compteurs, incluant des codes $6$ et que ceux-ci sont définis avec un contrôle strict
 # de chronologie, les codes $7$ seront complétés par un ou plusieurs caractčres $8$ pour atteindre la longueur requise
 ENTMES  = mess(220,125,1)+mess(221,125,1)+mess(222,125,1)
 TEXMES = mess(26,113,1)+"~"+num$(len(MINCOD))+"~"+MINCOD+"~"+num$(len(MAXCOD))+"~"+MAXCOD
 TEXMES += "~"+mess(26,113,1)+"~"+mess(26,113,1)+"~"+"_"
 ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
 If GTRACE<>"" or GSERVEUR
  Raz TEXMES , I
  While ENTMES<>""
   I += 1
   K = instr(100,ENTMES," ")
   If K
    TEXMES(I) = left$(ENTMES,K-1)
    ENTMES = right$(ENTMES,K+1)
   Else
    TEXMES(I) = ENTMES
    ENTMES = ""
   Endif
  Wend
  Call ECR_TRACE(TEXMES,-1) From GESECRAN
 Else
  Call AFFMES(ENTMES) From GESECRAN
 Endif
Endif
Call MAJPAR(DOSSIER,"CPYMAXLEN",num$(len(MAXCOD))) From SUBADS
Call MAJPAR(DOSSIER,"CPYMINLEN",num$(len(MINCOD))) From SUBADS
#jira X3-125829
# clean cache after modif
Gosub CLEAN_PARAM

Close Local File
End

#--------#
# clean cache after modif
#jira X3-125829
$CLEAN_PARAM
If dim([V]GACTX)>=0
  Local Integer WIND_RESULT
  WIND_RESULT= fmet [V]GACTX.APARAM._ACLEAN()
Endif
Return

#-----------------------------------------------------------#
$RAZDUP
Actzo [CPY1]CPYLEGFLG
Return

#-----------------------------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-----------------------------------------------------------#
$LIENS
If dim([M:CPY1]BASTAB) >= 0
 If [M:CPY1]BASTAB = 0
  [M:CPY1]BASTAB = GOPTCANA
 Endif
Endif

Call GRISE([F:CPY]CPYLEGFLG)
If [F:CPY]CPYLEGFLG=2
 Default Mask [BPA]
 Call CHARG_BPA(NUMBPA,[M:CPY0]CPY,[F:CPY]BPAADD) From TRTBPA
 If dim([M:BID]NBRIB)>0
  Default Mask [BID]
  Call CHARG_RIB(NUMBPA,[M:CPY0]CPY,[F:CPY]BIDNUM) From TRTBPA
 Endif
 If clalev([M:CNT])>0
  Default Mask [CNT]
  Call CHARG_CNT(NUMBPA,[M:CPY0]CPY,[F:CPY]CNTNAM) From TRTBPA
 Endif
Endif
Gosub DEFAUT
[M:BPA]NUMBPA = NUMBPA
Read [ABB]ABB0 = "LOGO";[F:CPY]CPY;"";""
If !fstat
 [M:CPY1]LOGO = [F:ABB]BLOB
Endif
Grizo [CPY1]CPYLEGFLG
LOGO = 0
Gosub GRISE_ORICERFLG :#X3-60504
Return

$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From WGOCPY
 Endif
Next MA
Return

#-----------------------------------------------------------#
$APRES_MODIF
Case COUZON
 When "LOGO"
  If VERROU or REP="C"
   [L]LOGO = 1
  Endif
Endcase
Gosub SETBOUT
Return

#-----------------------------------------------------------#
$RAZCRE
[F:BPA]BPATYP = NUMBPA
#CHECK UNUSED_BEGIN
If dim([M:CPY1]BASTAB) >= 0
 If [M:CPY1]BASTAB = 0
  [M:CPY1]BASTAB = GOPTCANA
 Endif
 For nolign=1 To GOPTCANA
  [M:CPY1]CCEINT(nolign-1)=nolign
 Next nolign
Endif
#CHECK UNUSED_END
Affzo [CPY1]
[M:BPA]NUMBPA = NUMBPA
If dim([M:CNT]NUMBPA)>0
 [M:CNT]NUMBPA = NUMBPA
Endif
If dim([M:BID]NUMBPA)>0
 [M:BID]NUMBPA = NUMBPA
Endif
Return

#-----------------------------------------------------------#
$VERIF_CRE
Look [FCY]FCY0 = [M:CPY0]CPY
If fstat=0
 # Ce code existe déjŕ comme site
 Call ERREUR([M:CPY0]CPY-":"-mess(39,133,1)) From GESECRAN
 OK = 0
 Return
Endif
If val(func AFNC.PARAM("CPYMAXLEN",""))=0
 # Attention, si vous créez ce code $1$, un contrôle vérifiera que les autres codes $2$ seront créés avec le męme nombre
 # de caractčres ($3$), afin de garantir une homogénéité dans la numérotation des documents si vous avez inséré le code $4$
 # dans la structure des compteurs correspondants.
 # Voulez-vous continuer ?
 ENTMES  = mess(223,125,1)+mess(224,125,1)+mess(225,125,1)+chr$(10)+mess(205,100,1)
 TEXMES = mess(26,113,1)+"~"+mess(26,113,1)+"~"+num$(len([M:CPY0]CPY))+"~"+mess(26,113,1)
 ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
 OK = 1
 Call MESCTL(ENTMES,OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif

#-----------------------------------------------------------#
$VERIF_MOD

[M:CPY0]CPY = vireblc([M:CPY0]CPY,2)
If [M:CPY0]CPY = ""
 Call ERREUR(mess(38,133,1)) From GESECRAN : # Code société incorrect
 OK = 0
 Return
Endif

If [M:CPY1]CPYLEGFLG=2
 If [M:BPA]NBADR = 0
  Call ERREUR(mess(40,133,1)) From GESECRAN : # Une adresse doit au moins exister
  OK = 0
  Return
 Endif

 If find (2,[M:BPA]BPAADDFLG (0..[M:BPA]NBADR -1)) = 0
  Call ERREUR(mess(41,133,1)) From GESECRAN : # Une adresse doit ętre désignée par défaut
  OK = 0
  Return
 Endif
Endif

# check only one DPO by company
# x3 et x3 people screen CNT
# geode screen CNT2 verif in TRTCNT2
Local Integer WIND
Local Integer WOK
WOK = 0
If dim([M:CNT]NBCNT)>0
  For WIND = 0 To [M:CNT]NBCNT-1
        If [M:CNT]DPO (WIND) = 2
            WOK += 1
        Endif
  Next WIND
Endif
If WOK > 1
    Call ERREUR(mess(1,155,1)) From GESECRAN : # only one DPO  by company
    OK = 0
    Return
Endif

Return

#-----------------------------------------------------------#
$AVANT_MODFIC
# Changement de législation => sites
If dim([M:CPY1]LEG)>0 & [M:CPY1]LEG<>[F:CPY]LEG
 For [FCY]FCY1 Where LEGCPY=[F:CPY]CPY
  Readlock [FCY] Curr
  If fstat=1
   GOK = -1 : GLOCK = "$FACILITY"-[F:FCY]FCY : Break
  Endif
  [F:FCY]LEG = [M:CPY1]LEG
  Rewrite [FCY]
  If fstat
   GOK = 0 : Call FSTA("FCY") From GLOCK : Break
  Endif
 Next
Endif
Return

#-----------------------------------------------------------#
$INICRE
$INIMOD
Local Integer I
I = find (2,[M:BPA]BPAADDFLG (0..[M:BPA]NBADR -1))
If I = 0
 [F:CPY]BPAADD = [M:BPA]CODADR(0)
Else
 [F:CPY]BPAADD = [M:BPA]CODADR(I-1)
Endif
If dim([M:BID]NBRIB)>0
 I = find (2,[M:BID]BIDNUMFLG (0..[M:BID]NBRIB -1))
 If I = 0
  [F:CPY]BIDNUM = [M:BID]BIDNUM(0)
 Else
  [F:CPY]BIDNUM = [M:BID]BIDNUM(I-1)
 Endif
Endif
If dim([M:CNT]NBCNT)>0
 I = find (2,[M:CNT]CNTFLG(0..[M:CNT]NBCNT -1))
 If I = 0
  [F:CPY]CNTNAM = [M:CNT]CCNCRM(0)
 Else
  [F:CPY]CNTNAM = [M:CNT]CCNCRM(I-1)
 Endif
Endif
If [F:CPY]LEG="" & !func AFNC.ACTIV("LEG") & [F:CPY]CPYLEGFLG=2
 [F:CPY]LEG = GDOSLEG(1)
Endif
Return

#-----------------------------------------------------------#
$CREATION
If val(func AFNC.PARAM("CPYMAXLEN",""))=0
  Call MAJPAR("","CPYMAXLEN",num$(len([M:CPY0]CPY))) From SUBADS
  Call MAJPAR("","CPYMINLEN",num$(len([M:CPY0]CPY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM
Elsif len([M:CPY0]CPY)<val(func AFNC.PARAM("CPYMINLEN",""))
  Call MAJPAR("","CPYMINLEN",num$(len([M:CPY0]CPY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM
Elsif len([M:CPY0]CPY)>val(func AFNC.PARAM("CPYMAXLEN",""))
  Call MAJPAR("","CPYMAXLEN",num$(len([M:CPY0]CPY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM
Endif

$MODIF
Default Mask [BPA]
Call CREBPA(NUMBPA,[M:CPY0]CPY) From TRTBPA
If GOK < 1 : Return : Endif
If dim([M:BID]NBRIB)>0
 Default Mask [BID]
 Call CRERIB(NUMBPA,[M:CPY0]CPY) From TRTBPA
 If GOK < 1 : Return : Endif
Endif
If clalev([M:CNT])>0
 Default Mask [CNT]
 Call CRECNT(NUMBPA,[M:CPY0]CPY) From TRTBPA
 If GOK < 1 : Return : Endif
Endif
Gosub DEFAUT
#
# Création/maj du groupe "société juridique"
#
Read [AGF]AGF0 = [M:CPY0]CPY
If fstat
 Raz [F:AGF]
 [F:AGF]GRP    = [M:CPY0]CPY
 [F:AGF]DES    = [M:CPY0]CPYNAM
 [F:AGF]SHO    = [M:CPY0]CPYSHO
 [F:AGF]FLGCPY = [M:CPY1]CPYLEGFLG
 [F:AGF]FLGLEG = [M:CPY1]CPYLEGFLG
 [F:AGF]CREDAT = date$
 If dim([F:AGF]CRETIM)>0 : [F:AGF]CRETIM = time : Endif
 [F:AGF]CREUSR = GUSER
 Write [AGF]
Else
 [F:AGF]GRP    = [M:CPY0]CPY
 [F:AGF]DES    = [M:CPY0]CPYNAM
 [F:AGF]SHO    = [M:CPY0]CPYSHO
 [F:AGF]FLGCPY = [M:CPY1]CPYLEGFLG
 [F:AGF]FLGLEG = [M:CPY1]CPYLEGFLG
 [F:AGF]UPDDAT = date$
 If dim([F:AGF]UPDTIM)>0 : [F:AGF]UPDTIM = time : Endif
 [F:AGF]UPDUSR = GUSER
 Rewrite [AGF]
Endif
If fstat
 GOK = 0 : Call FSTA("AGF") From GLOCK : Return
Endif
If [M:CPY1]CPYLEGFLG=2
 Read [AGC]AGC0 = [M:CPY0]CPY;[M:CPY0]CPY
 If fstat
  [F:AGC]GRP = [M:CPY0]CPY
  [F:AGC]CPY = [M:CPY0]CPY
  Write [AGC]
  If fstat
   GOK = 0 : Call FSTA("AGC") From GLOCK : Return
  Endif
 Endif
Endif
If LOGO or REP="D"
 Read [ABB]ABB0="LOGO";[M:CPY0]CPY;"";""
 If !fstat
  [F:ABB]BLOB = [M:CPY1]LOGO
  [F:ABB]TYPBLB = 3
  [F:ABB]NAMBLB = [F:CPY]CPYNAM
  If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
  If dim([F:ABB]CREUSR)>0 : [F:ABB]CREUSR = GUSER : Endif
  If dim([F:ABB]CREDAT)>0 : [F:ABB]CREDAT = date$ : Endif
  If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM = time  : Endif
  Rewrite [ABB]
  If fstat
   GOK = 0 : Call FSTA("ABB") From GLOCK : Return
  Endif
 Else
  Raz [F:ABB]
  [F:ABB]BLOB = [M:CPY1]LOGO
  [F:ABB]TYPBLB = 3
  [F:ABB]CODBLB = "LOGO"
  [F:ABB]NAMBLB = [M:CPY0]CPYNAM
  [F:ABB]IDENT1 = [M:CPY0]CPY
  [F:ABB]IDENT2 = ""
  [F:ABB]IDENT3 = ""
  If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
  If dim([F:ABB]CREUSR)>0 : [F:ABB]CREUSR = GUSER : Endif
  If dim([F:ABB]CREDAT)>0 : [F:ABB]CREDAT = date$ : Endif
  If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM = time  : Endif
  Write [ABB]
  If fstat
   GOK = 0 : Call FSTA("ABB") From GLOCK : Return
  Endif
 Endif
Endif
Return

#-----------------------------------------------------------#
$ANNULE
Gosub NUMBPA
Call ANNBPA([L]NUMBPA,[L]CODE) From TRTBPA
Call ANNRIB([L]NUMBPA,[L]CODE) From TRTBPA
If clalev([M:CNT])>0
 Call ANNCNT([L]NUMBPA,[L]CODE) From TRTBPA
Endif
Delete [AGF] Where GRP=[L]CODE : # Groupe "société juridique"
Delete [AGC] Where CPY=[L]CODE : # Groupes oů la société était référencée
Delete [FGR] Where CPY=[L]CODE : # Groupes oů la société était référencée
Delete [ABB]ABB0 = "LOGO";[L]CODE;"";""
If fstat=1 : GOK=-1 : Call RSTA("ABB",[L]CODE) From GLOCK : Return : Endif
Return

#-----------------------------------------------------------#
$APRES_CRE
$APRES_ANNULE
If nbrecord([CPY])>=dim(GSOC) or nbrecord([FCY])>=dim(GSITE)
 # Pour utiliser cette nouvelle société, il faut redémarrer une nouvelle session
 Call MESSAGE(mess(91,127,1)) From GESECRAN
Else
 Call INISOC From GLOBSUP  : # Réinit de la tables des sociétés
Endif
Return

#-----------------------------------------------------------#
$APRES_MOD
Return

#-----------------------------------------------------------#
## Ecran CPY1
#-----------------------------------------------------------#

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Clbfile ENTMES(1)
Local Char    TEXMES(250)
Look [CPY]CPY0 = VALEUR
If fstat
 Look [FCY]FCY0 = VALEUR
 If !fstat
  # Ce code existe déjŕ comme site
  GMESSAGE = mess(39,133,1) : mkstat = 2 : End
 Endif
 If val(func AFNC.PARAM("CPYMAXLEN",""))>0
  If val(func AFNC.PARAM("CPYMAXLEN",""))=val(func AFNC.PARAM("CPYMINLEN","")) & len(VALEUR)<>val(func AFNC.PARAM("CPYMAXLEN",""))
   # Afin de garantir une homogénéité dans la numérotation des documents si vous avez inséré le code $1$ dans la structure des
   # compteurs correspondants, il ne vous est pas possible de créer un code $2$ avec un code de longueur différente de $3$.
   # Si vous voulez passer outre, l'administrateur général devra passer renseigner des valeurs différentes, pour les
   # paramčtres $4$ et $5$. Les numérotations de documents qui intčgrent un code $6$
   # complčteront alors les codes $7$ de longueur inférieure ŕ $8$ avec des caractčres $9$.
   ENTMES  = mess(226,125,1)+mess(227,125,1)+mess(228,125,1)+mess(229,125,1)+mess(230,125,1)
   TEXMES = mess(26,113,1)+"~"+mess(26,113,1)+"~"+func AFNC.PARAM("CPYMAXLEN","")+"~CPYMINLEN~CPYMAXLEN~"+mess(26,113,1)
   TEXMES += "~"+mess(26,113,1)+"~"+func AFNC.PARAM("CPYMAXLEN","")+"~_"
   ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
   Call AFFMES(ENTMES) From GESECRAN
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_CPYLEGFLG(VALEUR)
Variable Integer VALEUR
If ([M:CPY1]CPYLEGFLG=2 & VALEUR=1) or ([M:CPY1]CPYLEGFLG=1 & VALEUR=2)
 Read [FCY]FCY1(1) = [M:CPY0]CPY
 If !fstat
  GMESSAGE = mess(42,133,1) : mkstat = 2 : End
# Sites créés sur cette société juridique
 Endif
Endif
Call GRISE(VALEUR)
End

Subprog GRISE(VALEUR)
Value Integer VALEUR
If VALEUR<>2
 Effzo [CPY1]20
 Grizo [CPY1]20
 If dim([CPY1]LEG)>0
  Effzo [CPY1]LEG
  Grizo [CPY1]LEG
 Endif
 If clalev([M:BPA])  : Effzo [BPA]  : Grizo [BPA]  : Endif
 If clalev([M:BID])  : Effzo [BID]  : Grizo [BID]  : Endif
 If clalev([M:CNT])  : Effzo [CNT]  : Grizo [CNT]  : Endif
 If clalev([M:DCP])  : Effzo [DCP]  : Grizo [DCP]  : Endif
 If clalev([M:CPY3]) : Effzo [CPY3] : Grizo [CPY3] : Endif
 If clalev([M:CPYP]) : Effzo [CPYP] : Grizo [CPYP] : Endif
Else
 Actzo [CPY1]20
 If dim([CPY1]LEG)>0
  Actzo [CPY1]LEG
 Endif
 If clalev([M:BPA])  : Actzo [BPA]  : Endif
 If clalev([M:BID])  : Actzo [BID]  : Endif
 If clalev([M:CNT])  : Actzo [CNT]  : Endif
 If clalev([M:DCP])  : Actzo [DCP]  : Endif
 If clalev([M:CPY3]) : Actzo [CPY3] : Endif
 If clalev([M:CPYP]) : Actzo [CPYP] : Endif
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "AM_LEG" : Gosub ACTION
If mkstat : End : Endif
End

Subprog AS_STRPER(VALEUR)
Variable Date    VALEUR
If [M:CPY1]CPYLEGFLG<>2
 mkstat = 1 : End
Endif
If VALEUR = [0/0/0] : VALEUR = gdat$(1,1,year(date$)) : Endif
If !find(GREP,"C","D")
 mkstat = 2 : End
Endif
End

Subprog IB_MAIFCY
# Pas de tunnel Société -> Site, ŕ cause de l'écran CNT2 présent dans ces 2 objets
If clalev([M:CNT2])>0 : GBOUT1="" : Endif
End

Subprog C_MAIFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
# Ce site est dans la société
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_CRY(VALEUR)
Variable Char VALEUR()
If [M:CPY1]CPYLEGFLG<>2 : mkstat = 2 : Endif
If VALEUR="" : VALEUR = GPAYS : Endif
End

