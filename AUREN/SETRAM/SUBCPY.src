#X3-60504
Subprog AM_ORICERFLG(VALEUR)
Variable Integer VALEUR
  [M:CPY1]ORICERFLG=VALEUR
  Gosub GRISE_REXNUM
End

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
  [M:CPY1]CRY = VALEUR
  Gosub GRISE_ORICERFLG
  Gosub GRISE_EORINUM :#X3-222016
End

$GRISE_ORICERFLG
 If dim([M:CPY1]ORICERFLG)<0 : Return : Endif :#X3-69093
 If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
 If [F:TCY]CRY<>[M:CPY1]CRY
  Read [F:TCY]TCY0=[M:CPY1]CRY
 Else
  fstat=0
 Endif
 If fstat | ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
  If [M:CPY1]ORICERFLG=2
    [M:CPY1]ORICERFLG=1
    Affzo [M:CPY1]ORICERFLG
  Endif
  Grizo [M:CPY1]ORICERFLG
 Else
  Actzo [M:CPY1]ORICERFLG
 Endif
 Gosub GRISE_REXNUM
Return

$GRISE_REXNUM
  If dim([M:CPY1]REXNUM)<0 : Return : Endif :#X3-69093
  If [M:CPY1]ORICERFLG=2
    Actzo [M:CPY1]REXNUM
  Else
    If [M:CPY1]REXNUM<>""
      Raz [M:CPY1]REXNUM
      Affzo [M:CPY1]REXNUM
    Endif
    Grizo [M:CPY1]REXNUM
  Endif
Return
#end X3-60504

#X3-222016
Subprog AV_EORINUM(VALEUR)
Variable Char    VALEUR()
  Gosub GRISE_EORINUM
End

$GRISE_EORINUM
  If dim([M:CPY1]EORINUM)>=0 :#to be safe...
    Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
    If !fstat & dim([F:TCY]EORIFLG)>0 & [F:TCY]EORIFLG=[V]CST_AYES
      Actzo [M:CPY1]EORINUM
    Else
#      If [M:CPY1]EORINUM<>""
#        Raz [M:CPY1]EORINUM
#        Affzo [M:CPY1]EORINUM
#      Endif
      Grizo [M:CPY1]EORINUM
    Endif
  Endif
Return
#end X3-222016


