#<AdxTL>@(#)4.0.0.0 $Revision$
Call IMPORTATION("GASBY") From GIMPOBJ
End
# Issue X3-205959 - 2020-09-14 by MRDAB/MAPON: fixed inconsistency between Pay-to/Pay-by vs Address vs Bank account also for import/export templates
# Issue X3-195197 - 2020-08-04 by MAPON : As a data administrator user I want to be able to import bank ID in open items.
# Issue X3-169191 - 2019-12-09 by CBO : GASIMPORT failed due to inactive dimension
# Issue X3-105443 - 2019-01-02 by MDJ : Mutli Ledger - Import failed due to inactive dimension
#*X3-39795  MDJ  Manage ORIGIN and ORICOD fields in GL Entry
###################################################################################
$ACTION

Case ACTION
 When "IMP_FERME" : Gosub IMP_FERME # Issue X3-169191
# When "IMP_FERME" : Gosub LETTRAGE # Issue X3-169191
Endcase

Return

###################################################################################
$OUVRE
If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
If clalev([M:SCL]) =0 : Local Mask SAICURLED  [SCL]  : Endif
If clalev([M:VTL]) =0 : Local Mask VENTILE    [VTL]  : Endif
If clalev([M:VT2]) =0 : Local Mask VENTILE2   [VT2]  : Endif

If clalev([F:HAE1])=0 : Local File GACCENTRY [HAE1] : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP   [HAE2] : Endif
If clalev([F:CCE2])=0 : Local File CACCE     [CCE2] : Endif
If clalev([F:GMT])=0  : Local File GTMPMTC   [GMT]  : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH  [MTB]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI] : Endif
If clalev([F:ANM])=0  : Local File ACODNUM   [ANM] : Endif
If clalev([F:AVN])=0  : Local File AVALNUM   [AVN] : Endif
If clalev([F:TAM])=0  : Local File TABPAM    [TAM] : Endif
If clalev([F:BID])=0  : Local File BID       [BID] : Endif    # Issue X3-195197 by MAPON

Local Integer AX , AXE, MAXECH , MAXECR , NBECH , ECH , K , NOL, OPTTV, OPTF, NBANA, NBLED, LINORI

# Issue X3-169191
# We memorize the new dimension for having no error on other journal entry
Global Integer WGCPTRDIECCE, WGMAXDIECCE
WGMAXDIECCE = 1000
Global Char WGTABDIECCE(GLONDIE + GLONCCE + 2)(1..WGMAXDIECCE)
Raz WGCPTRDIECCE, WGTABDIECCE
# End Issue X3-169191

Local Integer STAT
Local Decimal ECHCUR, ECHLED
# Issue X3-16347
#Local Char    MESSA(80)
Local Char    MESSA(250)
# End issue X3-16347
MAXECR = dim([M:HAE2]ACC1)
MAXECH = 3*dim([M:HAE2]ACC1)

# Raz lettrage
Local Integer FLLET
Local Char    TBLET(5)(MAXECR)

# Gestion des zones communes en Saisie Colonne
Local Char    OLDBPR(GLONBPR)
Local Char    OLDTAX(GLONVAT)
Local Char    OLDMTC(5)
Local Char    OLDCSLCOD(15), OLDCSLFLO(GLONADI)
Local Char    OLDCSLBPR(GLONBPR)
Local Date    OLDDAT, OLDMIN, OLDMAX
Local Integer OLDACCNUM
Local Decimal OLDQTY
Local Char    OLDUOM(GLONUOM)
Local Char    OLDDSP(GLONDSP)
Local Char    PARAM2(GLONADW)
# Gestion des échéances
Global Integer ECHLIG(1..MAXECH)
Global Char    ECHBPR(GLONBPR)(1..MAXECH)
Global Date    ECHDAT(1..MAXECH)
Global Char    ECHPAM(GLONTAM)(1..MAXECH)
Global Libelle ECHTYP(1..MAXECH)
Global Decimal ECHAMT(1..MAXECH), ECHAMTLOC(1..MAXECH)
Global Libelle ECHFUP(1..MAXECH)
Global Libelle ECHPAZ(1..MAXECH)
Global Libelle ECHSOI(1..MAXECH)
Global Char    ECHDPT(GLONADI)(1..MAXECH)
Global Char    ECHADR(GLONADR)(1..MAXECH)
Global Char    ECHBID(GLONBID)(1..MAXECH)   # Issue X3-195197 by MAPON

Local Char    XPARAM(GLONADP)
Local Integer OKFIELD
If dim(GLONMDT)>0
 Global Char    ECHUMR(GLONMDT)(1..MAXECH)
Endif

# Localisation russe
Gosub IMP_DECLARE From SUBGASD

# Feature 79528 - SP3US26
Global Integer GUPDCHRNUM

# Feature 79529 - SP8US28
Global Integer GUPDBALCUM
Local Integer TYPLEDGDD
Local Char LEDGDD(GLONLED)
Local Integer FLGPRCSL
[L]FLGPRCSL = func AFNC.ACTIV("PRCSL")
#

# Issue X3-112608 by MRDAB
Local Integer LLED
Local Date DATE_TO_CHECK, PER_STR_DAT
Local Char LCPY(GLONCPY)
Local Tinyint BLOCKING_CASE
# Issue X3-112608 end

Trbegin [GMT]
 Delete [GMT] Where ID=num$(adxuid(2))
Commit

Return

###################################################################################
$RAZCRE
Raz [M:HAE0]
Raz [M:HAE1]
Raz [M:HAE2]
Raz [M:HAEF]
Raz [M:HAEW]
Raz [M:VTL]
Raz [M:VT2]
NBECH = 0
Raz ECHLIG, ECHBPR, ECHDAT, ECHPAM, ECHTYP, ECHAMT, ECHAMTLOC, ECHFUP, ECHPAZ, ECHSOI, ECHDPT, ECHADR, ECHBID   # Issue X3-195197 by MAPON
If dim(ECHUMR)>0
 Raz ECHUMR
Endif

# Issue X3-112608 by MRDAB
Raz LLED, DATE_TO_CHECK, PER_STR_DAT, LCPY, BLOCKING_CASE
# Issue X3-112608 end

Return

###################################################################################
$SAIMSK

Case IMPFIC

 When "HAE"

  nolign = 1
  [M:HAE0] = [F:HAE]
  [M:HAE1] = [F:HAE]

  ## Si le code transaction de saisie n'est pas défini dans le fichier ŕ importer, on importe la pičce sur la transaction
  ## de saisie par défaut. En revanche, si le fichier de données définit la transaction de saisie, on crée la pičce sur cette transaction
  #[M:HAE0]DACDIA = GFLAG
  If [F:HAE]DACDIA<>""
   GFLAG = [F:HAE]DACDIA
  Else
   If GFLAG ="" : GFLAG = GSCHSTDC : Endif
   [M:HAE0]DACDIA = GFLAG
  Endif

  Call LEC_GDE(GFLAG) From CPTLEC      # Lecture de Transaction de saisie
  If fstat <> 0
   GMESSAGE = mess(40,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_FCY([F:HAE]FCY) From CPTLEC         # Lecture du site
  If fstat <> 0
   GMESSAGE = mess(14,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC  # Lecture de la société juridique
  If fstat <> 0
   GMESSAGE = mess(15,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  If dim(GGASNEGAMT)>0
   Call PARAM([F:CPY]CPY,"GASNEGAMT",PARAM2) From ADOVAL
   GGASNEGAMT = val(PARAM2)
  Endif

  Call LEC_GTE_LEG([F:CPY]LEG,[F:HAE]TYP) From CPTLEC         # Lecture du type de pičce
  If fstat <> 0
   GMESSAGE = mess(17,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_GCM([F:CPY]ACM) From CPTLEC     # Lecture du modčle comtpable
  If fstat <> 0
   GMESSAGE = mess(198,105,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  # Issue X3-112608 by MRDAB - validation for carry forward document type
  If [F:GTE]PER = 2
    Gosub VALIDATE_CARRY_FORWARD
    If GMESSAGE <> ''
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Raz GMESSAGE
      If [L]BLOCKING_CASE
        OK=0 : Return
      Endif
      GERRTRACE -= 1
    Endif
  Endif
  # Issue X3-112608 end

  ## Initialisation dans le masque de référence [HAEF].
  ## On appelle INIMSKFMT3 pour initialiser les cours RATDIV et RATMLT s'ils sont importés
  Call GETSOC([F:HAE]FCY) From DEVSUB
  Call INIMSKFMT3([F:HAE]FCY,[F:GDE]TYPENT,GFLAG,[F:HAE]TYP,[F:HAE]ACCDAT,STAT) From SUBGASA

  If STAT
   GMESSAGE=""
   Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
   Gosub MESSAGE From CPTAUTO
   GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA : # Paramétrage ŕ revoir
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK = 0 : Return
  Endif

  For I=1 To [M:HAEF]NBRLED
   Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
   Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
  Next

  Gosub MAJ_SCL

  # Localisation Russe
  Call FLGDEM(GSOCIETE,[L]FLGDEM) From CPTDIV

  # Feature 79528 - SP3US26
  Raz GUPDCHRNUM
  # Feature 79529 - SP8US28
  # GUPDBALCUM: if the variable is set to 1 in the entry point, the update of the balance
  # is postponed at the end of the journal import
  Raz GUPDBALCUM

  GPOINT = "MSKLOAD" : Gosub ENTREE From EXEFNC

  If [F:HAE]STA <> 2
   Raz GUPDCHRNUM
  Elsif GUPDCHRNUM=1
   Gosub LEC_CHRNUM
   If STAT
    # Problčme lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    GMESSAGE=mess(60,199,1)-"("+CHRONO+") : "+MESSA
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GMESSAGE
    OK = 0 : Return
   Endif
  Endif

  # Feature 79529 - SP8US28
  # The balance will be updated normally if :
  # - If a ledger is a Double entry
  # - If PRCSL is active.
  # - If a ledger is flagged "Operating budgets"
  If [L]FLGDEM=2 or [L]FLGPRCSL
   Raz GUPDBALCUM
  Else
   Call GETLEDGDD(GSOCIETE,TYPLEDGDD,LEDGDD) From TRTGDD
   If [L]TYPLEDGDD<>0
    Raz GUPDBALCUM
   Endif
  Endif
  #

 When "DAE"

  If find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))

   If [M:HAEF]TYPENT = 2  # Saisie Ligne

    [M:HAE2]NBLIG += 1
    nolign = [M:HAE2]NBLIG
    [M:HAE2] = [F:DAE]

    [M:HAEW]NB +=1
    [M:HAEW] = [F:DAE]
    [M:HAEW]LINREF(nolign-1) = nolign

    [F:DAE]LIN = nolign : # Mémo pour ligne ana

    If [F:DAE]SNS>0
     [M:HAE2]DEB(nolign-1) = [F:DAE]AMTCUR
    Else
     [M:HAE2]CDT(nolign-1) = [F:DAE]AMTCUR
    Endif

    If (GGASNEGAMT = 1 or GCURLEG = "POR") and ([M:HAE2]DEB(nolign-1) < 0 or [M:HAE2]CDT(nolign-1) < 0)
      Call TRACE2(2,mess(327,7711,1),-1) From SUBIMPOBJ
      GERR=1
      GOK = 0 : Return
    Endif

    Assign "[M:HAE2]SAC1("+num$(nolign-1)+")" With [F:DAE]SAC
    Assign "[M:HAE2]ACC1("+num$(nolign-1)+")" With [F:DAE]ACC
    NBLED = find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
    Assign "[M:HAE2]COA1("+num$(nolign-1)+")" With [M:HAEF]COA(NBLED-1)
    Assign "[M:HAE2]CPA1("+num$(nolign-1)+")" With [F:DAE]OFFACC
    Assign "[M:HAE2]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTFLG
    If [F:DAE]SNS<=0 & [M:HAE2]CDT(nolign-1)=0
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED1
    Else
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED1
    Endif

   Else

    If [M:HAE2]NBLIG>=dim([M:HAE2]DEB)
     Call ECR_TRACE([F:HAE]NUM-mess(33,106,1),1) From GESECRAN
     # Tableau de saisie des lignes plein
     # Positionner GERR et FIN pour arręter le process
     GERR=1
     FIN=1
     OK = 0 : Return
    Endif

    nolign = [F:DAE]LIN
    NOL = [F:DAE]LIN-1
    OLDBPR    = [M:HAE2]BPR(NOL)
    OLDACCNUM = [M:HAE2]ACCNUM(NOL)
    OLDMTC    = [M:HAE2]MTC(NOL)
    OLDDAT    = [M:HAE2]MTCDAT(NOL)
    OLDMIN    = [M:HAE2]MTCDATMIN(NOL)
    OLDMAX    = [M:HAE2]MTCDATMAX(NOL)
    OLDTAX    = [M:HAE2]TAX(NOL)
    OLDCSLCOD = [M:HAE2]CSLCOD(NOL)
    OLDCSLFLO = [M:HAE2]CSLFLO(NOL)
    OLDCSLBPR = [M:HAE2]CSLBPR(NOL)
    OLDQTY    = [M:HAE2]QTY(NOL)
    OLDUOM    = [M:HAE2]UOM(NOL)
    OLDDSP    = [M:HAE2]DSP(NOL)

    [M:HAE2] = [F:DAE]

    [M:HAEW]NB +=1
    nolign = [M:HAEW]NB
    [M:HAEW] = [F:DAE]
    [M:HAEW]LINREF(nolign-1) = [F:DAE]LIN
    nolign = [F:DAE]LIN

    # Problčme des zones communes en saisie de colonnes => Ré initialise
    If [M:HAE2]BPR(NOL)    ="" & OLDBPR<>""    : [M:HAE2]BPR(NOL)    = OLDBPR    : Endif
    If [M:HAE2]TAX(NOL)    ="" & OLDTAX<>""    : [M:HAE2]TAX(NOL)    = OLDTAX    : Endif
    If [M:HAE2]CSLCOD(NOL) ="" & OLDCSLCOD<>"" : [M:HAE2]CSLCOD(NOL) = OLDCSLCOD :  Endif
    If [M:HAE2]CSLFLO(NOL) ="" & OLDCSLFLO<>"" : [M:HAE2]CSLFLO(NOL) = OLDCSLFLO :  Endif
    If [M:HAE2]CSLBPR(NOL) ="" & OLDCSLBPR<>"" : [M:HAE2]CSLBPR(NOL) = OLDCSLBPR :  Endif
    If [M:HAE2]QTY(NOL)    =0  & OLDQTY<>0     : [M:HAE2]QTY(NOL)    = OLDQTY    :  Endif
    If [M:HAE2]UOM(NOL)    ="" & OLDUOM<>""    : [M:HAE2]UOM(NOL)    = OLDUOM    :  Endif
    If [M:HAE2]DSP(NOL)    ="" & OLDDSP<>""    : [M:HAE2]DSP(NOL)    = OLDDSP    :  Endif

    [F:DAE]LIN = nolign : # Mémo pour ligne ana
    [M:HAE2]NBLIG = max([M:HAE2]NBLIG,[F:DAE]LIN)

    If [F:DAE]SNS>0
     [M:HAE2]DEB(nolign-1) = [F:DAE]AMTCUR
    Else
     [M:HAE2]CDT(nolign-1) = [F:DAE]AMTCUR
    Endif

    If (GGASNEGAMT = 1 or GCURLEG = "POR") and ([M:HAE2]DEB(nolign-1) < 0 or [M:HAE2]CDT(nolign-1) < 0)
      Call TRACE2(2,mess(327,7711,1),-1) From SUBIMPOBJ
      GERR=1
      GOK = 0 : Return
    Endif

    NBLED=find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
    Assign "[M:HAE2]SAC"+num$(NBLED)+"("+num$(nolign-1)+")" With [F:DAE]SAC
    Assign "[M:HAE2]ACC"+num$(NBLED)+"("+num$(nolign-1)+")" With [F:DAE]ACC
    Assign "[M:HAE2]CPA"+num$(NBLED)+"("+num$(nolign-1)+")" With [F:DAE]OFFACC
    Assign "[M:HAE2]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTFLG
    If [F:DAE]SNS<=0 & [M:HAE2]CDT(nolign-1)=0
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED1
    Else
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED1
    Endif
   Endif

  Elsif [F:DAE]ACCNUMORI>0

   LINORI = find([F:DAE]ACCNUMORI,[M:HAEW]ACCNUM(0..[M:HAEW]NB))
   If LINORI
    LINORI = [M:HAEW]LINREF(LINORI-1)
   Endif

   If LINORI
    Assign "[M:HAE2]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(LINORI-1)+")" With [F:DAE]AMTFLG
    If [F:DAE]SNS<=0 & [M:HAE2]CDT(LINORI-1)=0
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(LINORI-1)+")" With -[F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(LINORI-1)+")" With -[F:DAE]AMTLED1
    Else
     Assign "[M:HAE2]AMT"+num$([F:DAE]LEDTYP)+"("+num$(LINORI-1)+")" With [F:DAE]AMTLED
     Assign "[M:HAE2]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(LINORI-1)+")" With [F:DAE]AMTLED1
    Endif
   Endif

   # Localisation russe
   If [L]FLGDEM=2 : Gosub IMP_SAIMSK From SUBGASD : Endif

  Endif

 When "DAA"

  # On s'intérresse uniquement au référentiel "non automatique"
  If find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))

   nolign = [M:HAE2]NBLIG

   If [M:HAE2]PTV(nolign-1)=0 : # On génére une ligne "bidon"
    [M:HAE2]PTV(nolign-1) = [M:VT2]PTVENT
    K = [M:VT2]PTVENT+1
    [M:VT2]PTVENT = K
    [M:HAE2]PTV(nolign-1) = K
    [M:HAE2]PTF(nolign-1) = K
   Else
    NBANA = [M:HAE2]PTF(nolign-1)-[M:HAE2]PTV(nolign-1)+1
    If [F:DAA]ANALIN>=1 & [F:DAA]ANALIN<=NBANA : # Modif ligne existante
     K = [M:HAE2]PTV(nolign-1)+[F:DAA]ANALIN-1
    Elsif [M:VT2]PTVENT=[M:HAE2]PTF(nolign-1)    : # Y'a la place
     If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
      #  Trop ventilations analytiques
      Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
      GOK = 0 : Return
     Endif
     K = [M:VT2]PTVENT+1
     [M:VT2]PTVENT    = K
     [M:HAE2]PTF(nolign-1) = K
    Else                                      : # On met plus loin
     OPTV = [M:HAE2]PTV(nolign-1)
     OPTF = [M:HAE2]PTF(nolign-1)
     If [M:VT2]PTVENT+OPTF-OPTV+1>=dim([M:VT2]TBAMT)
      Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
      GOK = 0 : Return
     Endif
     K = [M:VT2]PTVENT+1
     [M:HAE2]PTV(nolign-1) = K
     For I=0 To OPTF-OPTV
      [M:VT2]TBAMT(K+I) = [M:VT2]TBAMT(OPTV+I)
      [M:VT2]TBQTY(K+I) = [M:VT2]TBQTY(OPTV+I)
      For AX=1 To dim([F:DAA]CCE)
       AXE = find(evalue("[F:DAA]DIE"+"("+num$(AX-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
       If AXE>0
        Assign"[M:VT2]TBCCE"+num$(AXE)+"("+num$(K+I)+")" With  evalue("[M:VT2]TBCCE"+num$(AX)+"("+num$(OPTV+I)+")")
       Endif
      Next AX
     Next I
     K += OPTF-OPTV+1
     [M:VT2]PTVENT = K
     [M:HAE2]PTF(nolign-1) = K
     Call ANUVENTIL([M:HAE2]PTV,[M:HAE2]PTF,[M:HAE2]NBLIG,OPTV,OPTF-OPTV+1) From VENTILE
     K -= OPTF-OPTV+1
    Endif
   Endif


   [M:HAE2]DSP(nolign-1) = "$"

   ## Transfert des infos
   For AX=1 To dim([F:DAA]CCE)
    AXE = find(evalue("[F:DAA]DIE"+"("+num$(AX-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
    If AXE>0
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With [F:DAA]CCE(AX-1)
    Endif
   Next I

   ### Pour ceux qui veulent importer les montants en devise locale et reporting
   If dim([M:VT2]TBLED)>0
    [M:VT2]TBLED([M:VT2]PTVENT) = [F:DAA]AMTLED
   Endif
   [M:VT2]TBAMT([M:VT2]PTVENT) = [F:DAA]AMTCUR
   [M:VT2]TBQTY([M:VT2]PTVENT) = [F:DAA]QTY
   If sum([M:VT2]TBQTY([M:HAE2]PTV(nolign-1)..[M:HAE2]PTF(nolign-1)))<>0
    [M:HAE2]QTY(nolign-1) = sum([M:VT2]TBQTY([M:HAE2]PTV(nolign-1)..[M:HAE2]PTF(nolign-1)))
   Endif

 Endif

 When "DUD"
  # Cas BOIRON oů l'échéancier est importé, le problčme est la définition du lien entre DAE/DUD.
  #  Les lignes DAE sur les référentiels dits automatiques génčrent des lignes d'échéances
  #  Une des solutions seraient de le gérer en EXPORT.
  #  La solution mise en place est de prendre en compte uniquement l'échéancier du "Référentiel Général Principal".
  If [F:DAE]LEDTYP=GTYPGEN
   NBECH += 1
   ECHLIG(NBECH) = [M:HAE2]NBLIG
   ECHBPR(NBECH) = [F:DUD]BPRPAY
   ECHDAT(NBECH) = [F:DUD]DUDDAT
   ECHPAM(NBECH) = [F:DUD]PAM
   ECHTYP(NBECH) = [F:DUD]PAMTYP
   ECHAMT(NBECH) = [F:DUD]AMTCUR
   ECHAMTLOC(NBECH) = [F:DUD]AMTLOC
   ECHFUP(NBECH) = [F:DUD]FLGFUP
   ECHPAZ(NBECH) = [F:DUD]FLGPAZ
   ECHDPT(NBECH) = [F:DUD]DPTCOD
   ECHSOI(NBECH) = [F:DUD]SOI
   ECHADR(NBECH) = [F:DUD]BPAPAY
   # Issue X3-195197 by MAPON
   # Issue X3-205959 by MRDAB/MAPON
   If [F:DUD]BIDNUMMAN <> ""
     Read [F:BID]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;[F:DUD]BPAPAY
     If fstat
       Read [F:BID]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;""
     Endif
     If !fstat and [F:BID]BIDNUMFLG <> [V]CST_AYES
       ECHBID(NBECH) = [F:DUD]BIDNUMMAN
     Elsif fstat
       ECHBID(NBECH) = [F:DUD]BIDNUMMAN
     Endif
   Endif
   # Issue X3-205959 end
   # Issue X3-195197 end
   If dim(ECHUMR)>0
    ECHUMR(NBECH) = [F:DUD]UMRNUM
    Call TST_CHAMP("DUD","UMRNUM",OKFIELD) From SUBIMPOBJ
    If OKFIELD & ECHUMR(NBECH)="" : ECHUMR(NBECH)="XXXXX" : Endif
   Endif

  Endif

Endcase
Return

###################################################################################
$VALID
If [M:HAE0]FCY="" : Return : Endif
If [M:HAE2]NBLIG=0
 STAT = 35 #  Il y a aucune ligne saisie
 Gosub MESSAGE From CPTAUTO
 Call TRACE2(2,"<"+GCLE+">"-MESSA-"("+num$(STAT)+")",-1) From SUBIMPOBJ
 STAT = 0 : GOK = 0 : Return
Endif
Raz STAT, MESSA, GSCHEMA
Default Mask [HAE0]
Default Mask [HAE1]
Default Mask [HAE2]

# Localisation Russe
Call FLGDEM(GSOCIETE,[L]FLGDEM) From CPTDIV
If [L]FLGDEM=2 : Gosub IMP_VALID From SUBGASD : Endif

Call CONTROLE(STAT,MESSA) From CPTBATCH
GCLE = [M:HAE0]TYP-[M:HAE0]NUM
If STAT
   Gosub MESSAGE From CPTAUTO
   Call TRACE2(2,"<"+GCLE+">"-MESSA-"("+num$(STAT)+")",-1) From SUBIMPOBJ
   STAT = 0 : # Conflit avec le STAT de l'import
   GOK = 0
   Return
Endif

If GCURLEG = "POR" and [M:HAE0]STA = 2
  Call TRACE2(2,"<"+GCLE+">"-mess(130,106,1),-1) From SUBIMPOBJ
  STAT = 0 : GOK = 0 : Return
Endif

## Traitement du lettrage
FLLET = 0
For NOL=0 To [M:HAEW]NB-1
  If (GGASNEGAMT = 1 or GCURLEG = "POR") and ([M:HAEW]DEB < 0 or [M:HAEW]CDT < 0)
    Call TRACE2(2,mess(327,7711,1),-1) From SUBIMPOBJ
    GOK =0
    Break
  Endif
 If [M:HAEW]BPR(NOL)<>"" & [M:HAEW]LEDTYP(NOL)=GTYPGEN
  Raz mkstat
  Call CONTBPRCPY([M:HAEW]BPR(NOL),[M:HAEW]FCYLIN(NOL),[M:HAEW]COA(NOL),[M:HAEW]ACC(NOL),"") From CPTSUB
  If mkstat=2
   Raz mkstat
   Call TRACE2(2,"<"+GCLE+">"-[M:HAEW]BPR(NOL)-GMESSAGE,-1) From SUBIMPOBJ
   GOK=0
  Endif
 Endif
 If [M:HAEW]MTC(NOL)<>""
  TBLET(NOL) = [M:HAEW]MTC(NOL)
  [M:HAEW]MTC(NOL) = ""
  FLLET = 1
 Endif
Next NOL

If dim(GSDDMGT)>0
 #X3-112211
 #Call PARAML([M]CPY,"SDDMGT",XPARAM) From ADOVAL
 If func AFNC.ACTIV("SDD")
  Call PARAML([M]CPY,"SDDMGT",XPARAM) From ADOVAL
  GSDDMGT=val(XPARAM)
 Endif
 #end X3-112211
Endif
Gosub CONTECHE
If !GOK : Return : Endif
GOK = 1
Call DEBTRANS From GLOCK
Gosub TR1
GCLE = [F:HAE]TYP-[F:HAE]NUM
If STAT
 Call TRACE2(2,"<"+GCLE+">"-MESSA-"("+num$(STAT)+")",-1) From SUBIMPOBJ
 STAT = 0
 GOK = 0
Else
 Call TRACE(0,GCLE) From SUBIMPOBJ
 NBCRE += 1
 GOK = 1
Endif
If GOK=1 & FLLET
 For NOL=0 To [M:HAEW]NB-1
  If TBLET(NOL)<>""
   If [M:HAEW]BPR(NOL)=""
    [F:GMT]ID     = num$(adxuid(2))
    [F:GMT]ACC    = [M:HAEW]ACC(NOL)
    [F:GMT]BPR    = [M:HAEW]BPR(NOL)
    [F:GMT]FCY    = [M:HAEW]FCYLIN(NOL)
    [F:GMT]ACCNUM = [M:HAEW]ACCNUM(NOL)
    [F:GMT]MTC    = TBLET(NOL)
    [F:GMT]DUDLIG = 0
    [F:GMT]AMTIPT = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
    Write [GMT]
   Else
    For [DUD]DUD1 Where ACCNUM=[M:HAEW]ACCNUM(NOL)
     [F:GMT]ID     = num$(adxuid(2))
     [F:GMT]ACC    = [M:HAEW]ACC(NOL)
     [F:GMT]BPR    = [M:HAEW]BPR(NOL)
     [F:GMT]FCY    = [M:HAEW]FCYLIN(NOL)
     [F:GMT]ACCNUM = [M:HAEW]ACCNUM(NOL)
     [F:GMT]MTC    = TBLET(NOL)
     [F:GMT]DUDLIG = [F:DUD]DUDLIG
     [F:GMT]AMTIPT = [F:DUD]AMTCUR
     Write [GMT]
    Next
   Endif
  Endif
 Next NOL
Endif
Return

$TR1
Trbegin [HAE]
 Default Mask [HAE0]
 Default Mask [HAE1]
 Default Mask [HAE2]

 #*X3-39795 Call VALPIECER(STAT,MESSA) From CPTBATCH
 #*X3-39795  Validation with imposed values
 Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)
 Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced
 TZONE(5)= "ORIGIN" : TVAL(5) = "3"        :# Import
 TZONE(6)= "ORICOD" : TVAL(6) = [F:AOE]EXT
 Call VALPIECER2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
  #*X3-39795  END
  #*
 If GOK<1 : Goto AB_TR1 : Endif

 If NBECH
  Call LEC_CPY([F:HAE]CPY) From CPTLEC
  Call LEC_GTE_LEG([F:CPY]LEG,[F:HAE]TYP) From CPTLEC

  For NOL=0 To [M:HAEW]NB-1
   If [M:HAEW]SAC(NOL)<>"" & [M:HAEW]LEDTYP(NOL)=GTYPGEN
    ECH = find([M:HAEW]LINREF(NOL),ECHLIG(1..NBECH))
    If ECH
     Delete [DUD] Where ACCNUM=[M:HAEW]ACCNUM(NOL)
     If fstat=1
      GOK = -1 : GLOCK="$GACCDUDATE" : Break
     Endif
     K = 0
     Raz ECHCUR, ECHLED
     Read [DAE]DAE2 = [M:HAEW]ACCNUM(NOL)
     While ECHLIG(ECH)=[M:HAEW]LINREF(NOL)
      K += 1
      Raz [F:DUD]
      [F:DUD] = [F:HAE]
      nolign = NOL+1
      [F:DUD] = [M:HAEW]
      [F:DUD]LIG=[M:HAEW]LIN(NOL)
      [F:DUD]AMTLOC=[M:HAEW]AMTLED(NOL)
      [F:DUD]DUDLIG = K
      [F:DUD]DUDSTA = 2
      [F:DUD]TYPDUD = [F:GTE]DUDTYP
      [F:DUD]FCY    = [M:HAEW]FCYLIN(NOL)
      [F:DUD]BPRPAY = ECHBPR(ECH)
      [F:DUD]BIDNUMMAN = ECHBID(ECH)    # Issue X3-195197 by MAPON
      # Initialisation du champ BPRTYP
      Call LEC_BPR([F:DUD]BPR) From CPTLEC
      If    [F:BPR]BPCFLG=2  & [F:BPR]BPSFLG<>2 : [F:DUD]BPRTYP = 1 : # Client
      Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2  : [F:DUD]BPRTYP = 2 : # Fourn
      Endif
      If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
       If [F:BPR]BPTFLG=2                        : [F:DUD]BPRTYP = 3 : # Transporteur
       Elsif [F:BPR]FCTFLG=2                     : [F:DUD]BPRTYP = 4 : # Factor
       Elsif [F:BPR]REPFLG=2                     : [F:DUD]BPRTYP = 5 : # Représentant
       Elsif [F:BPR]BPRACC=2                     : [F:DUD]BPRTYP = 6 : # Tiers divers
       Endif
      Endif

      If [F:DUD]BPRTYP=0
       Call LECTURE("GAC",[M:HAEW]ACC(NOL),[M:HAEW]COA(NOL)) From CONTOBJ
       # On regarde les autorisations par type de tiers pour initaliser le BPRTYP
       If    [F:GAC]AUZBPR(0)=2  & [F:GAC]AUZBPR(1)<>2 : [F:DUD]BPRTYP = 1 : # Client
       Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2  : [F:DUD]BPRTYP = 2 : # Fourn
       Elsif [F:GAC]UPDBLC=2                           : [F:DUD]BPRTYP = 1 : # Client
       Elsif [F:GAC]UPDBLC=3                           : [F:DUD]BPRTYP = 2 : # Fournisseur
       Endif
      Endif
      # En dernier recours c'est le sens qui détermine BPRTYP.
      If [F:DUD]BPRTYP=0
       If [F:DAE]SNS=1 : [F:DUD]BPRTYP = 2 : Else : [F:DUD]BPRTYP = 1 : Endif
      Endif

      [F:DUD]DUDDAT = ECHDAT(ECH)
      [F:DUD]PAM    = ECHPAM(ECH)
      [F:DUD]PAMTYP = ECHTYP(ECH)
      [F:DUD]AMTCUR = ECHAMT(ECH)
      [F:DUD]SNS    = [F:DAE]SNS
      [F:DUD]FLGFUP = ECHFUP(ECH)
      [F:DUD]FLGPAZ = ECHPAZ(ECH)
      [F:DUD]DPTCOD = ECHDPT(ECH)
      [F:DUD]SOI    = ECHSOI(ECH)
      [F:DUD]BPAPAY = ECHADR(ECH)
      [F:DUD]BIDNUMMAN = ECHBID(ECH)    # Issue X3-195197 by MAPON
      If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
      If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
      If ECH=NBECH or ECHLIG(ECH+1)<>[M:HAEW]LINREF(NOL)
       [F:DUD]AMTCUR = [F:DAE]AMTCUR-ECHCUR
       [F:DUD]AMTLOC = [F:DAE]AMTLED-ECHLED
       Raz ECHCUR, ECHLED
      Else
       If ECHAMTLOC(ECH)<>0
        [F:DUD]AMTLOC = ECHAMTLOC(ECH)
       Else
        Call CONVERT([F:HAE]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[F:HAE]TYPRAT
&        ,[F:HAE]ACCDAT,[F:DUD]AMTCUR,[F:DUD]AMTLOC,STAT) From TRTDEV
       Endif
       ECHCUR += [F:DUD]AMTCUR
       ECHLED += [F:DUD]AMTLOC
      Endif
      Call KEYDUD("DUD") From MODECHE
      Call SLDECH("DUD")From MODECHE

      If dim(GSDDMGT)>0 & [F:DUD]BPRTYP=1 & [F:DUD]TYPDUD=2
       Call LEC_TAM([F:CPY]LEG,[F:DUD]PAM) From CPTLEC
       If fstat | [F:TAM]SDDFLG<>2
        [F:DUD]UMRNUM = ""
       Else
        If GSDDMGT=2
         If ECHUMR(ECH)<>"XXXXX"
          [F:DUD]UMRNUM=ECHUMR(ECH)
          If [F:DUD]UMRNUM=""
           Call INIT_UMRNUM([F:DUD]CPY,[F:DUD]BPRPAY,2,2,[F:DUD]UMRNUM) From INVSDDLIB
          Endif
         Endif
         If [F:DUD]UMRNUM=""
          Gosub TIT From WOTAM : GMESSAGE  = TIT-":"-[F:DUD]PAM
          GMESSAGE += "\"+mess(270,117,1)
          Call TRACE(2,"<"+GCLE+">"-"UMRNUM - "-GMESSAGE) From SUBIMPOBJ
          Raz GMESSAGE : GOK = 0 : Break 2
         Endif
        Endif
       Endif
      Endif

      Write [DUD]
      If fstat
       GOK = 0 : Call FSTA("DUD") From GLOCK : Break 2
      Endif
      Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
      ECH += 1
     Wend
    Endif
   Endif
  Next NOL
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif

 # Feature 79528 - SP3US26
 If GUPDCHRNUM
  STAT = 0
  Gosub UPD_CHRNUM
  If STAT
   # Problčme lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   MESSA=mess(60,199,1)-"("+CHRONO+") : "+MESSA
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
  Endif
 Endif

Commit
Return

$AB_TR1
Rollback
If STAT=0
 STAT = 20 : Gosub MESSAGE From CPTAUTO
Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$CONTECHE
For ECH=1 To NBECH
 NOL = ECHLIG(ECH)-1
 If ECHBPR(ECH)=""
  ECHBPR(ECH) = [M:HAE2]BPR(NOL)
 Elsif ECHBPR(ECH)<>[M:HAE2]BPR(NOL)
  Look [BPR]BPR0 = ECHBPR(ECH)
  If fstat : ECHBPR(ECH) = [M:HAE2]BPR(NOL) : Endif
 Endif
 If ECHDAT(ECH)=[0/0/0]
  ECHDAT(ECH) = [M:HAE0]ACCDAT
 Endif
 If ECHTYP(ECH)<1 or ECHTYP(ECH)>3
  ECHTYP(ECH) = 1
 Endif
 If ECHPAM(ECH)=""
  ECHPAM(ECH) = [F:GTE]PAM
 Endif
 Call CONTTAM(ECHPAM(ECH),GCURLEG,"") From SUBTAM
 If mkstat
  Call TRACE(2,"<"+GCLE+">"-"PAM - "-ECHPAM(ECH)-GMESSAGE) From SUBIMPOBJ
  mkstat=0 : Raz GMESSAGE : GOK = 0 : Break
 Endif
 If ECHFUP(ECH)<1 or ECHFUP(ECH)>2
  ECHFUP(ECH) = [M:HAE1]FLGFUP
 Endif
 If ECHPAZ(ECH)<1 or ECHPAZ(ECH)>len(mess(0,510,1))
  ECHPAZ(ECH) = [M:HAE1]FLGPAZ
 Endif
 If ECHSOI(ECH)<1 or ECHSOI(ECH)>2
  ECHSOI(ECH) = 2
 Endif
 If ECHDPT(ECH)<>""
  Look [ADI]CODE = 315;ECHDPT(ECH)
  If fstat : ECHDPT(ECH) = "" : Endif
 Endif
 If dim(GSDDMGT)>0 & GSDDMGT=2 & ECHUMR(ECH)<>"" & [F:TAM]SDDFLG=2 & [F:GTE]DUDTYP=2
  Local Integer WBPRTYP : Raz WBPRTYP
  Gosub INI_BPRTYP
  If WBPRTYP=1
   If ECHUMR(ECH)="XXXXX" : ECHUMR(ECH)="" : Endif
   Call CTL_UMRNUM2(ECHUMR(ECH),[M]CPY,ECHBPR(ECH),ECHPAM(ECH)) From INVSDDLIB
   If mkstat
    Call TRACE(2,"<"+GCLE+">"-"UMRNUM - "-ECHUMR(ECH)-GMESSAGE) From SUBIMPOBJ
    mkstat=0 : Raz GMESSAGE : GOK = 0 : Break
   Endif
   #
   If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
   Call LEC_MDT([M]CPY,ECHUMR(ECH)) From CPTLEC
   If fstat : Raz [MDT] : Endif
   If [F:MDT]STA<>2
    GMESSAGE = mess(123,197,1)
    Call TRACE(2,"<"+GCLE+">"-"UMRNUM - "-ECHUMR(ECH)-GMESSAGE) From SUBIMPOBJ
    mkstat=0 : Raz GMESSAGE : GOK = 0 : Break
   Endif
  Endif
 Endif

# Issue X3-195197 by MAPON
 If ECHBID(ECH) <> ""
  Read [F:BID]BID0 = 1;ECHBPR(ECH);ECHBID(ECH);ECHADR(ECH)
  If fstat
   Read [F:BID]BID0 = 1;ECHBPR(ECH);ECHBID(ECH);""
  Endif
  If fstat
   GMESSAGE = mess(27,199,1)
   Call TRACE(2,"<"+GCLE+">"-"ECHBID - "-ECHBID(ECH)+":"-GMESSAGE) From SUBIMPOBJ
   mkstat = 0 : Raz GMESSAGE : GOK = 0 : Break
  Endif
 Endif
# Issue X3-195197 end
Next ECH
Return

$INI_BPRTYP
Call LEC_BPR(ECHBPR(ECH)) From CPTLEC
If    [F:BPR]BPCFLG=2  & [F:BPR]BPSFLG<>2 : [L]WBPRTYP = 1 : # Client
Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2  : [L]WBPRTYP = 2 : # Fourn
Endif
If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
 If [F:BPR]BPTFLG=2                        : [L]WBPRTYP = 3 : # Transporteur
 Elsif [F:BPR]FCTFLG=2                     : [L]WBPRTYP = 4 : # Factor
 Elsif [F:BPR]REPFLG=2                     : [L]WBPRTYP = 5 : # Représentant
 Elsif [F:BPR]BPRACC=2                     : [L]WBPRTYP = 6 : # Tiers divers
 Endif
Endif
If [L]WBPRTYP<>0 : Return : Endif

Local Char PLAN(GLONCOA)
Call LECMAINPLAN(1,[M]CPY,[L]PLAN) From CPTDIV
Call LECTURE("GAC",evalue("[M:HAE2]ACC"+num$(GTYPGEN)+"("+num$(NOL)+")"),[L]PLAN) From CONTOBJ
If    [F:GAC]AUZBPR(0)=2  & [F:GAC]AUZBPR(1)<>2 : [L]WBPRTYP = 1 : # Client
Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2  : [L]WBPRTYP = 2 : # Fourn
Elsif [F:GAC]UPDBLC=2                           : [L]WBPRTYP = 1 : # Client
Elsif [F:GAC]UPDBLC=3                           : [L]WBPRTYP = 2 : # Fournisseur
Endif
If [L]WBPRTYP<>0 : Return : Endif

If [M:HAE2]DEB(NOL)<>0
 [L]WBPRTYP = 2
Else
 [L]WBPRTYP = 1
Endif
Return

# Issue X3-169191
$IMP_FERME

  If dim(WGCPTRDIECCE) >= 0
    Kill WGCPTRDIECCE, WGMAXDIECCE, WGTABDIECCE
  Endif

  Gosub LETTRAGE

Return
# End Issue X3-169191

############################################
$LETTRAGE
If clalev([F:GMT])=0 : Local File GTMPMTC    [GMT] : Endif
If clalev([F:MTB])=0 : Local File MTCBATCH   [MTB] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
Trbegin [MTB] , [GMT]
 Read [MTB]MTB0(1) Last
 If fstat
  NUMLET = 0
 Else
  NUMLET = [F:MTB]MTCNUM
 Endif
 For [GMT]GMT0(5) Where ID=num$(adxuid(2))
  NUMLET += 1
  Read [FCY]FCY0 = [F:GMT]FCY
  For [GMT]GMT0
   Raz [F:MTB]
   [F:MTB]MTCNUM = NUMLET
   [F:MTB]ACCNUM = [F:GMT]ACCNUM
   [F:MTB]DUDLIG = [F:GMT]DUDLIG
   [F:MTB]AMTIPT = [F:GMT]AMTIPT
   [F:MTB]MTCTYP = 2
   [F:MTB]CPY    = [F:FCY]LEGCPY
   Write [MTB]
  Next
 Next
 Delete [GMT] Where ID=num$(adxuid(2))
Commit

# Gestion des échéances
Kill ECHLIG
Kill ECHBPR
Kill ECHDAT
Kill ECHPAM
Kill ECHTYP
Kill ECHAMT
Kill ECHAMTLOC
Kill ECHFUP
Kill ECHPAZ
Kill ECHSOI
Kill ECHDPT
Kill ECHADR
Kill ECHBID   # Issue X3-195197 by MAPON

If dim(ECHUMR)>0
 Kill ECHUMR
Endif

# Feature 79528 - SP3US26
Kill GUPDCHRNUM

# Feature 79529 - SP8US28
Kill GUPDBALCUM
Return

##########################################################################################################################
## Import des cours
## Si on importe le cours sur le référentiel principal, il faut propager ce cours sur les autres référentiels si
## Types de cours du référentiel=Oui
## Devise transaction <>Devise référentiel
## Devise du référentiel déjŕ gérée par un autre référentiel
## => C'est ce que contient l'écran SLC
##########################################################################################################################

$MAJ_SCL
Local Integer I,J

#-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)

If [M:HAE1]TYPRAT=0 & dim([F:GTE]TYPRAT)>0 : [M:HAE1]TYPRAT = [F:GTE]TYPRAT : Endif
If [M:HAE1]TYPRAT=0 : [M:HAE1]TYPRAT = 1 : Endif
If [M:HAE1]RATDAT=[0/0/0] : [M:HAE1]RATDAT = [M:HAE0]ACCDAT : Endif

If [M:HAE0]CPY=""
 Call LEC_FCY([M:HAE0]FCY) From CPTLEC
 Call INIT([M:HAE1]CUR,[F:FCY]LEGCPY,[M:HAE1]TYPRAT,[M:HAE1]RATDAT,0) From SUBSCL
Else
 Call INIT([M:HAE1]CUR,[M:HAE0]CPY,[M:HAE1]TYPRAT,[M:HAE1]RATDAT,0) From SUBSCL
Endif
Gosub CHARG_ZONES_DEV From SUBSCL
#-- Sauvegarde les cours enregistrés dans les Zones de stockage [M:HAEF] (utile pour Action commune : SAIRATCUR)
For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1)))-1
 [M:HAEF]RATDIVC(J) = [F:HAE]RATDIV(J)
 [M:HAEF]RATMLTC(J) = [F:HAE]RATMLT(J)
Next

Gosub INIT_COURS From SUBSCL

# On alimente RATDAT car dans le Call CONTROLE From CPTBATCH on appelle C_ACCDAT de l'étiquette CONTZONE
# Dans C_ACCDAT, si RATDAT=[0/0/0], on réinitialise les cours
For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
 I = [M:SCL]LEDTYP(J)-1
 Case [F:GCM]DACRAT(I)
  When 1 : # Multiplicateur
   If [F:HAE]RATMLT(I)<>0 : # cours a été importé
    [M:SCL]RATMLT(J)  = [F:HAE]RATMLT(I)
    [M:HAE1]RATDAT    = [F:HAE]ACCDAT
   Endif
  When 2 : # Diviseur
   If [F:HAE]RATDIV(I)<>0 : # cours a été importé
    [M:SCL]RATDIV(J)  = [F:HAE]RATDIV(I)
    [M:HAE1]RATDAT    = [F:HAE]ACCDAT
   Endif
  When 3 : # Les 2
   If [F:HAE]RATMLT(I)<>0 : # cours a été importé
    [M:SCL]RATMLT(J)  = [F:HAE]RATMLT(I)
    [M:HAE1]RATDAT    = [F:HAE]ACCDAT
   Endif
   If [F:HAE]RATDIV(I)<>0 : # cours a été importé
    [M:SCL]RATDIV(J)  = [F:HAE]RATDIV(I)
    [M:HAE1]RATDAT    = [F:HAE]ACCDAT
   Endif
 Endcase
Next

# Remplissage du masque HAEF et de HAE1. Dans Call CONTROLE From CPTBATCH on appelle CONTZONE
# qui initialise les cours dans HAE1 si ceux-ci sont vides et fait ensuite [HAEF]=[HAE1]
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(I)<>""
  # Devise de pičce = Devise de référentiel
  If [F:GCM]CUR(I)=[M:SCL]CURENT
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With 1
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With 1
   [M:HAE1]RATMLT(I) = [M:HAEF]RATMLTC(I)
   [M:HAE1]RATDIV(I) = [M:HAEF]RATDIVC(I)
  Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
   [M:HAE1]RATMLT(I) = [M:HAEF]RATMLTC(I)
   [M:HAE1]RATDIV(I) = [M:HAEF]RATDIVC(I)
  Endif
 Endif
Next

#X3-101633
[M:HAE1]TYPDUD = [F:GTE]DUDTYP
#END X3-101633

Return


$UPD_CHRNUM
Local Char    CHRONO(GLONANM) # Compteur
Local Char    ROO(GLONVCR)    # Racine de la valeur du Compteur c'est ŕ dire TOUT sauf "Complément" sauf "N°Séquence"
Local Integer FLGCMP          # Le compteur a t'il une composante de type "Complément".  0 NON 1 : OUI
Local Integer LNGSEQ          # La longueur du composant "N°Séquence"

Local Char    KEYA2(GLONVCR), KEYA3(GLONVCR)  # Clé de lecture pour AVALNUM
Local Integer KEYC1

Local Decimal SQE             # Valeur de la séquence (non formatée)
Local Char    VALSQE(GLONVCR) # Valeur formatée de la séquence

# Variables associées au Lock
Local Integer TEMPO , NBLEC , MAXLEC
Local Decimal VALMAX
TEMPO = 3   : # Pour le sleep
MAXLEC = 10 : # Nb max de tentative de lecture si le compteur est verrouillé avant d'afficher le message

# Variables de travails
Local Integer  OKTCA
Local Char     WVAL(GLONVCR)

If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev([F:WDA]) : Close Local File [WDA] : Endif
Local File GACCENTRYD [WDA]

CHRONO = ""
Call LECTCA(2,OKTCA)From SUBTCA
If OKTCA : CHRONO = [F:TCA]CODNUM(0): Endif
If CHRONO="" : CHRONO = "CHR" : Endif

Filter [WDA] Where TYP=GTYPPCE & NUM=GNUMPCE Order By Key CLE = LEDTYP;LIN
Read [WDA]CLE First

Call NUMERO(CHRONO,[F:HAE]FCY,[F:HAE]ACCDAT,num$([F:WDA]LEDTYP-1),ROO,FLGCMP,LNGSEQ,KEYA2,KEYC1,KEYA3,STAT)
If STAT
 GOK = 0 : Return
Endif

If !FLGCMP

 ## Attribution du numéro du 1čre numéro de séquence
 Raz KEYA3
 VALMAX = val(string$(LNGSEQ,"9"))
 NBLEC = 0

 Repeat
  Gosub SEQ_NORMAL_READ
  If GOK<1 : Break : Endif
  SQE = mod(SQE,VALMAX+1)
 Until SQE<>0
 If GOK<1 : STAT=99 : Return : Endif

 # Dispatch Racine du Complément et de la Séquence
 WVAL = ROO
 ROO =  left$(WVAL,len(WVAL)-LNGSEQ)
 If SQE>val(string$(LNGSEQ,"9"))
  STAT = 2 : GOK = 0 : Return
 Endif
 VALSQE = format$("N0:"+num$(LNGSEQ)+"#",SQE)

 For [WDA]CLE

  [F:WDA]CHRNUM = ROO+VALSQE
  Rewrite [WDA]
  If fstat
   GOK=0 : Call FSTA("DAE") From GLOCK : STAT = 99 : Break
  Endif
  Gosub INC
  If !GOK : Break : Endif

 Next
 If !GOK : Return : Endif
 Gosub SEQ_NORMAL_WRITE
Else

 # Dispatch Racine du Complément et de la Séquence
 WVAL = ROO
 ROO =  left$(WVAL,len(WVAL)-LNGSEQ-1)

 For [WDA]CLE(1)

  ## Attribution du numéro du 1čre numéro de séquence
  KEYA3 = num$(([F:WDA]LEDTYP-1))
  VALMAX = val(string$(LNGSEQ,"9"))
  NBLEC = 0
  Repeat
   Gosub SEQ_NORMAL_READ
   If GOK<1 : Break : Endif
   SQE = mod(SQE,VALMAX+1)
  Until SQE<>0
  If GOK<1 : Break : Endif
  If SQE>val(string$(LNGSEQ,"9"))
   STAT = 2 : GOK = 0 : Break
  Endif
  VALSQE = format$("N0:"+num$(LNGSEQ)+"#",SQE)

  For [WDA]CLE
   [F:WDA]CHRNUM = ROO+KEYA3+VALSQE
   Rewrite [WDA]
   If fstat
    GOK=0 : Call FSTA("DAE") From GLOCK : STAT = 99 : Break
   Endif
   Gosub INC
   If !GOK : Break 2 : Endif
  Next
  Gosub SEQ_NORMAL_WRITE
  If !GOK : Break : Endif
 Next
Endif
Return

$INC
SQE+=1
If mod(SQE,VALMAX+1)=0
 SQE=1
Endif
If SQE>val(string$(LNGSEQ,"9"))
 STAT = 2 : GOK = 0 : Return
Endif
VALSQE = format$("N0:"+num$(LNGSEQ)+"#",SQE)
Return


$SEQ_NORMAL_READ
Readlock [AVN]AVN0 = CHRONO;KEYA2;KEYC1;KEYA3
If fstat=1
 If NBLEC>=MAXLEC
  GOK=-1 : GLOCK = "$AVALNUM"-KEYA2-num$(KEYC1)-KEYA3 : STAT = 99
 Else
  NBLEC += 1 : Sleep TEMPO
 Endif
Elsif fstat
 SQE = 1
Else
 SQE = [F:AVN]VALEUR
Endif
Return

$SEQ_NORMAL_WRITE
Read [AVN]AVN0 = CHRONO;KEYA2;KEYC1;KEYA3
If fstat
 Raz [F:AVN]
 [F:AVN]CODNUM  = CHRONO
 [F:AVN]SITE    = KEYA2
 [F:AVN]PERIODE = KEYC1
 [F:AVN]COMP    = KEYA3
 [F:AVN]VALEUR  = SQE
 Write [AVN]
Else
 [F:AVN]VALEUR = SQE
 Rewrite [AVN]
Endif
If fstat
 GOK=0 : Call FSTA("AVN") From GLOCK : STAT = 99 : Return
Endif
Return


Subprog NUMERO(COMPTEUR,SITE,DAT,COMP,VALEUR,FLG,LNG,KEY2,KEY3,KEY4,STAT)
Value    Char    COMPTEUR
Value    Char    SITE
Value    Date    DAT
Value    Char    COMP()
Variable Char    VALEUR()
Variable Integer FLG        # 0 : Pas de Composant Complément   <=>  1 : Composant Complément
Variable Integer LNG        # La longueur de la séquence
Variable Char    KEY2()
Variable Integer KEY3
Variable Char    KEY4()
Variable Integer STAT

# Variables utilisées sous ATTRIB_NUMERO From SUBANM or SETSOC de SUBANM (VALEUR,DAT,SOC,SITE,SEQUENCE,COMP,FORMU,GCM)
Local Integer SEQUENCE
Local Char    SOC(GLONCPY) , FORMU(20),  GCM(GLONGCM)

# Variables utilisées sous ATTRIB_VARIABLE
Local Integer PERIODE

If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif

STAT = 0
Read [ANM]ANM0 = COMPTEUR
If fstat
 Call RSTA("ANM",COMPTEUR) From GLOCK
 STAT = 1 : GOK = 0 : End
Endif

# Paramčtrage du compteur doit avoir une séquence "Normal"
If [F:ANM]SEQ<>1 : End : Endif

# "No Séquence" doit ętre ŕ la fin
If [F:ANM]POSTYP([F:ANM]NBPOS-1)<>8 : End : Endif
LNG = [F:ANM]POSLNG([F:ANM]NBPOS-1)

# Gestion du type de composant : Complément
If !find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
 FLG = 0
Else
 # Si "Complément", il doit ętre "avant-derničre" position
 If [F:ANM]POSTYP([F:ANM]NBPOS-2)<>9 : End : Endif
 If [F:ANM]CTLCHR=2 &  [F:ANM]POSLNG([F:ANM]NBPOS-2)<>1
  STAT = 4 : GOK = 0 : End
 Endif
 FLG = 1
Endif

## Attribution des variables
Gosub ATTRIB_VARIABLE
If [F:ANM]NIVDEF>1 & SITE=""
 STAT = 5 : GOK = 0 : End
Endif
Case [F:ANM]NIVDEF
 When 1   : KEY2 = ""
 When 2   : Gosub SETSOC From SUBANM : KEY2 = SOC
 When 3   : KEY2 = SITE
Endcase

## Attribution du numéro (Séquence bidon)
SEQUENCE = 0
Gosub ATTRIB_NUMERO From SUBANM

## Initialiation
KEY3 = PERIODE
KEY4 = COMP
End

$ATTRIB_VARIABLE
Case [F:ANM]NIVRAZ
 When 1 : PERIODE = 0
 When 2 : PERIODE = mod(year(DAT),100)
 When 3 : PERIODE = 100*mod(year(DAT),100)+month(DAT)
 When 4
  Case GPRODUIT
   When 0 : # X3
    Local Decimal EXE : Raz EXE
    If clalev([F:PER])=0  : Local File PERIOD [PER] : Endif
    Gosub SETSOC From SUBANM
    K = find(GCM,GGCM(1..GGCMNBR))
    If K
     #CHECK UNUSED_BEGIN
     If dim(GLEDTYPGEN)>0
      Call GETEXE(SOC,GLEDTYPGEN(K),DAT,EXE) From CPTSUB
     Else
      Call GETEXE(SOC,DAT,EXE) From CPTSUB
     Endif
     #CHECK UNUSED_END
    Endif
    If EXE>0
     PERIODE = EXE
    Else
     STAT = 3 : GOK = 0 : End
    Endif
   When Default : # On fait comme pour l'année
    PERIODE = mod(year(DAT),100)
  Endcase
 When 5
  Case GPRODUIT
   When 0 : # X3
    Local Decimal EXE , PER : Raz EXE , PER
    If clalev([F:PER])=0  : Local File PERIOD [PER] : Endif
    Gosub SETSOC From SUBANM
    K = find(GCM,GGCM(1..GGCMNBR))
    If K
     #CHECK UNUSED_BEGIN
     If dim(GLEDTYPGEN)>0
      Call GETPERSOC(SOC,GLEDTYPGEN(K),DAT,EXE,PER) From CPTSUB
     Else
      Call GETPERSOC(SOC,DAT,EXE,PER) From CPTSUB
     Endif
     #CHECK UNUSED_END
    Endif
    If EXE>0
     PERIODE = 100*EXE+PER
    Else
     STAT = 3 : GOK = 0 : End
    Endif
   When Default : # On fait comme pour le mois
    PERIODE = 100*mod(year(DAT),100)+month(DAT)
  Endcase
Endcase
Return

$LEC_CHRNUM
If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif

Local Char     CHRONO(GLONANM) # Compteur
Local Integer  OKTCA

CHRONO = ""
Call LECTCA(2,OKTCA)From SUBTCA
If OKTCA : CHRONO = [F:TCA]CODNUM(0): Endif
If CHRONO="" : CHRONO = "CHR" : Endif

STAT = 0
Read [ANM]ANM0 = CHRONO
If fstat
 Call RSTA("ANM",CHRONO) From GLOCK
 STAT = 1 : GOK = 0 : Return
Endif

# Paramčtrage du compteur doit avoir une séquence "Normal"
If [F:ANM]SEQ<>1 : GUPDCHRNUM=0 : Return : Endif

# "No Séquence" doit ętre ŕ la fin
If [F:ANM]POSTYP([F:ANM]NBPOS-1)<>8 : GUPDCHRNUM=0 : Return : Endif

# Gestion du type de composant : Complément, s'il existe, il doit ętre en avant-derničre position
If find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1)) & [F:ANM]POSTYP([F:ANM]NBPOS-2)<>9
 GUPDCHRNUM=0 : Return
Endif
Return

# Issue X3-112608 by MRDAB
$VALIDATE_CARRY_FORWARD

Raz GMESSAGE, [L]PER_STR_DAT, [L]BLOCKING_CASE
[L]LCPY = [F:FCY]LEGCPY
[L]DATE_TO_CHECK = [F:HAE]ACCDAT
[L]BLOCKING_CASE = 0

For [L]LLED = 1 To len(mess(0,2644,1))
  If find([F:GTE]AUZLED([L]LLED - 1), 2, 3)
    Filter [F:FIY] Where [F:FIY]CPY = [L]LCPY and [F:FIY]FIYSTA = 2 and [F:FIY]LEDTYP = [L]LLED
    Read [F:FIY]FIY0 First
    Filter [F:FIY]
    If fstat <= 2
      Filter [F:PER] Where [F:PER]CPY = [L]LCPY and [F:PER]FIYNUM = [F:FIY]FIYNUM and [F:PER]LEDTYP = [L]LLED
      Read [F:PER]PER0 First
      Filter [F:PER]
      If !fstat & [F:PER]PERSTA = 2
        If [L]PER_STR_DAT <> [0/0/0] & [L]PER_STR_DAT <> [F:PER]PERSTR
          GMESSAGE = mess(11,101,1)
          [L]BLOCKING_CASE = 1
          Break
        Endif
        [L]PER_STR_DAT = [F:PER]PERSTR
      Endif
    Endif
  Endif
Next

If [L]PER_STR_DAT = [0/0/0]
  GMESSAGE = mess(42,106,1)
  [L]BLOCKING_CASE = 1
Endif

If ![L]BLOCKING_CASE and [L]PER_STR_DAT <> [L]DATE_TO_CHECK
  [F:HAE]ACCDAT = [L]PER_STR_DAT
  [M:HAE0]ACCDAT = [F:HAE]ACCDAT
  GMESSAGE = mess(129,106,1)
Endif

Return
# Issue X3-112608 end
