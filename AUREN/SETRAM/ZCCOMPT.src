############################################################################
###
###    Z14  No se permite un informe de cuentas si las fechas son de aþos distintos
###
############################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)

Local Char  FICHAINICIO(30),  FICHAFIN(30)
Local Date    DATDEB , DATF

    # Obtener fecha inicio
    Call GETPARAM("datedeb",NBPAR,PARAMETRE,FICHAINICIO) From ETAT
    If FICHAINICIO<>"?????"
    
        # Obtener fecha inicio
        Call GETPARAM("datefin",NBPAR,PARAMETRE,FICHAFIN) From ETAT
        
        If FICHAFIN<>"?????"
            DATDEB= FICHAINICIO
            DATFIN = FICHAFIN
            If year(DATDEB) <> year(DATFIN) 
                # ERROR
                Call ECR_TRACE("Solo se puede obtener un informe del mismo ejercicio",1) From GESECRAN 
                GOK = 0 
            Endif
    
        Endif
    Endif

End
