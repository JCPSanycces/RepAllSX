#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################################################
# Fuente: ZDGLVTO
#    Desglose de Vencimientos Asientos
#-------------------------------------------------------------------------------------
# CodAct: Z16
#-------------------------------------------------------------------------------------
# Proyecto: SETRAM
#-------------------------------------------------------------------------------------
# Version: v1
#-------------------------------------------------------------------------------------
# Fecha:
#-------------------------------------------------------------------------------------
# Desarrollador: JMD
#-------------------------------------------------------------------------------------
# Notas:
# WebServices -  Esta es una rutina que puede ser llamada desde WebServices
#-------------------------------------------------------------------------------------
# Descripcion:
#   La funcion ZDGLVTOASTO permite Ańadir/Modificar/Borrar los Vencimientos de un asiento.
#   Se adjunta justo aqui debajo un TEST a modo de ejemplo de utilizacion de los parametros
#   (mas abajo en este fuente se declara la funcion y se describen sus parametros)
#
####################################################################################################################


$TEST
Local Char    ASTNUM
Local Char    ASTTYP
Local Integer L2LIN

Local Integer L3DUDLIG     (9999)
Local Date    L3DUEDAT     (9999)
Local Decimal L3MNT        (9999)
Local Char    L3PAM     (3)(9999)
Local Integer L3FLGPAZ     (9999)


Local Integer LERR : Raz LERR
Local Integer LERRCOD
Local Char    LERRSTR (250)

Local Integer K

    ASTNUM   ="001-16-049739"
    ASTTYP   ="ODG"
    L2LIN    =1

    Raz K


    L3DUDLIG(K)= 1  :  L3DUEDAT(K)=[15/04/2017] : L3MNT(K)= 800 : L3PAM(K)="TRF" :  L3FLGPAZ(K)=4 : K+=1
    L3DUDLIG(K)= 0  :  L3DUEDAT(K)=[15/05/2017] : L3MNT(K)= 200 : L3PAM(K)="TRF" :  L3FLGPAZ(K)=4 : K+=1


    Call ZDGLVTOASTO (ASTNUM, ASTTYP, L2LIN ,LERR, LERRCOD, LERRSTR, L3DUDLIG, L3DUEDAT, L3MNT, L3PAM, L3FLGPAZ )
    If LERR : Infbox num$(LERR)-":"-LERRSTR
    Else
        Infbox("Todo OK")
    Endif

TRA=1


End

####################################################################################################################

# Procedimiento: ZDGLVTOASTO
Subprog ZDGLVTOASTO (W1NUM, W1TYP, W2LIN,  WESTATUS,  WERRCOD, WERRSTR, W3DUDLIG, W3DUEDAT, W3MNT, W3PAM, W3FLGPAZ)
#--------------------------------------------------------------------------------------------------------------
# Variables: Parametros ENTRADA
#
# W1NUM    - Val - Char         - Numero de Asiento
# W1TYP    - Val - Char         - Tipo de  de Asiento
#
# W2LIN - Val - Integer         - Li­nea de Asiento a tratar
#
# W3DUDLIG - Val - Integer      - Numero de Vencimietno
# W3DUEDAT - Val - Date         - Array de Fechas Vencimiento
# W3MNT    - Val - Decimal      - Array de Importes
# W3PAM    - Val - Char(3)      - Array de Formas de Pago
# W3FLGPAZ - Val - Integer      - Array de Autorizacion Pago
#
# Variables: Parametros RETORNO
#
# WESTATUS   - Variable - Integer - Estado ejecución
# WERRCOD    - Variable - Integer - Codigo de Error
# WERRSTR    - Variable - Char    - Mensaje de Error
#--------------------------------------------------------------------------------------------------------------
# Notas: Codigos de Error devueltos
# WESTATUS= 0 Ejecución correcta sin avisos
# WESTATUS= 1 Ejecución correcta con avisos (WERRCOD y WERRSTR detalle de avisos)
# WESTATUS= 2 Error en ejecución (WERRCOD y WERRSTR detalle de errores)
#
# WERRCOD=1 : WERRSTR="La Linea del asiento especificada no tiene tercero"
# WERRCOD=2 : WERRSTR="El asiento"-W1NUM-"no existe"
# WERRCOD=3 : WERRSTR="Se ha producido un error al actualizar vencimientos"
# WERRCOD=4 : WERRSTR="No puedo bloquear el registro"-W1NUM-"para modificarlo"
# WERRCOD=5 : WERRSTR="no se puede modificar vencimientos Pagados o en Extracto"
# WERRCOD=6 : WERRSTR="El Metodo de pago"-[F:DUD]PAM-"no existe"
# WERRCOD=7 : WERRSTR="No existe la Linea del asiento especificada como parámetro"
# WERRCOD=9 : WERRSTR="Se ha generado un vencimiento por la diferencia de importe"
# WERRCOD=98 :WERRSTR="Parametros vencimientos deben tener mismo numero de elementos"
###################################################################################################################


Value Char       W1NUM
Value Char       W1TYP
Value Integer    W2LIN
Variable Integer WESTATUS
Variable Integer WERRCOD
Variable Char    WERRSTR
Value Integer    W3DUDLIG   ()
Value Date       W3DUEDAT    ()
Value Decimal    W3MNT       ()
Value Char       W3PAM     ()()
Value Integer    W3FLGPAZ    ()

#Variables tratamiento errores
Local Integer DIMVEN
Local Integer CODERROR
Local Char DESCERROR (255)
Local Integer BLOQUEO

    Raz WESTATUS, BLOQUEO

    WESTATUS=0
    BLOQUEO=0


    #Verificación número parámetros vencimientos correcto
    WDIMVEN=dim(W3DUDLIG )
    If WDIMVEN<>dim(W3DUEDAT ) or WDIMVEN<>dim(W3MNT) or WDIMVEN<>dim(W3PAM) or WDIMVEN<>dim(W3FLGPAZ)
        WESTATUS=2
        CODERROR=98
        DESCERROR-="Parametros vencimientos deben tener mismo numero de elementos"
        Gosub ANYADIR_ERROR
    Endif

    If WESTATUS<> 2
        Gosub DEFINE
        # Verificaciones existencia asiento y líneas correctas
        Gosub PRECHECK

        If WESTATUS<> 2
            # Bloqueo del asiento para su tratamiento
            Gosub VERROU
            If WESTATUS<> 2
                BLOQUEO=1
                # Cargar vencimientos
                Gosub AFFDUD

                If WESTATUS<> 2
                    #Ańadir/Modificar/Borrar Vencimientos
                    Gosub SAIDUD

                    If WESTATUS<> 2
                       # Guardar Vencimientos de Mascara DUD1 a Tabla
                      Gosub SAVALL
                    Endif
                Endif
            Endif
        Endif
    Endif

    If  BLOQUEO=1
         Gosub DEVERROU
    Endif



End


######################################################################################
#
#    Apertura de las tablas y definición ded variables globales
#
######################################################################################
$DEFINE

    If clalev([F:HAE])=0 : Local File GACCENTRY [HAE]   : Endif :# HAE0= TYP+NUM
                                                                 # TYP: tipo asiento
                                                                 # NUM: Numero asiento

    If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE]  : Endif :# DAE0= TYP+NUM+LIG
                                                                 # TYP: tipo asiento
                                                                 # NUM: Numero asiento
                                                                 # LIG: Linea asiento

    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif :# DUD0=TYP+NUM+LIG+DUDLIG
                                                                 # TYP: tipo asiento
                                                                 # NUM: Numero asiento
                                                                 # LIG: Linea asiento
                                                                 # DUDLIG: numero vencimiento
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
    If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
    If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
    If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
    If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
    If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
    Local Integer SAVCONS
    Local Char    SYMBHAE(35)
    Local Integer I
    Local Integer LCK
    Local Char    WFCY
  Local Decimal EXERCICE, PERIODE
Return
######################################################################################


######################################################################################
#
#    Verificar si el asiento existe y no está marcado como DEFINITIVO
#    Verificar que la línea existe
#
######################################################################################
$PRECHECK
    Read [F:HAE]HAE0=W1TYP;W1NUM

    If fstat
        WESTATUS=2
        CODERROR=2
        DESCERROR-="El asiento " + W1TYP + "/" + W1NUM + " no existe"
        Gosub ANYADIR_ERROR

    Else

        Read [F:DAE]DAE0=W1TYP;W1NUM;W2LIN
        If fstat
            WESTATUS=2
            CODERROR=7
            DESCERROR-="No existe la Linea " + num$(W2LIN)
            Gosub ANYADIR_ERROR
        Else
            If len([F:DAE]BPR) = 0
                WESTATUS=2
                CODERROR=1
                DESCERROR-="La Linea del asiento especificada no tiene tercero"
                Gosub ANYADIR_ERROR
            Else
                 # Las verificaciones han sido correctas
                 WFCY=[F:HAE]FCY
                 SAVCONS=GCONSULT
            Endif
        Endif

    Endif


Return


######################################################################################
#
#  Gestión Bloqueos
#
######################################################################################
$VERROU
    [L]SYMBHAE = "HAE"+[F:HAE]NUM+"\"+[F:HAE]TYP
    Lock =SYMBHAE With lockwait=0
    If fstat
        WESTATUS=2
        CODERROR=4
        DESCERROR-="No se puede bloquear el asiento " + W1TYP + "/" + W1NUM + " para modificarlo"
        Gosub ANYADIR_ERROR

    Endif
Return

######################################################################################
#
#  Gestión DesBloqueos
#
######################################################################################
$DEVERROU

    Unlock =SYMBHAE

Return
######################################################################################


######################################################################################
#
#  Cargar Vencimientos: Rellenamos la mascara DUD1 con los vencimientos actuales
#
######################################################################################
$AFFDUD

    LCK=1
    Gosub OUVR_ECH
    Gosub CHARGECH

Return
######################################################################################


######################################################################################
#
#  Actualizamos los vencimientos de la línea según los parámetros de entrada:
#
#     Borrar todas los vencimientos cuyo número de vencimiento  no corresponda con los parámetros de entrada
#     y no esten en situación Pagado o Extracto
#
#     Modificar los vencimientos cuyo número de vencimiento  corresponda con los parámetros de entrada. Si
#     está como Pagado o Extracto:
#                        Si se han modificado datos: Error y fin de proceso
#                        Si no se han modificado datos: Ignorarlo e ir al siguiente
#
#
#     Ańadir los vencimientos cuyo número de vencimiento  no corresponda con los parámetros de entrada
#
#     Una vez tratados todos los vencimientos:
#        Si el importe de la línea es distinto a la suma de los vencimientos,
#        se generará un nuevo vencimiento por la diferencia (tener en cuenta el signo de la linea
#        Si el importe de la línea es inferior a la suma de los
#
#
######################################################################################
$SAIDUD

Local Integer EXISTEVENCIMIENTO
Local Integer NUMVENCIMIENTOS
Local Integer NOL
Local Integer NUMLINEAS
Local Decimal TOTALCALCULADO
Local Decimal TOTALLINEA




    If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
    Default Mask [DUD1]

    #Borrar todas los vencimientos cuyo número de vencimiento  no corresponda con los parámetros de entrada
    # y no esten en situación XXXXX
    mkstat=0

    If [M]NBECH<>0
        NUMLINEAS = [M]NBECH
        NUMVENCIMIENTOS = 0
        #Para cada vencimietno cargado, compruebo que exista en los parámetros
        For I=0 To [M]NBECH-1
            EXISTEVENCIMIENTO=0
            For I1=0 To WDIMVEN-1
                If W3MNT(I1)=0
                     Break
                Else
                    If [M]DUDLIG(NUMVENCIMIENTOS) = W3DUDLIG(I1)
                        EXISTEVENCIMIENTO=1
                        Break
                    Endif
                Endif
            Next
            If  EXISTEVENCIMIENTO=0
                # Si no existe el vencimiento como parámewtro de entrada: eliminarlo si no está en estado Pagado o extracto
                NOL=I

                Gosub VERIFICAR_ESTADO_VENCIMIENTO
                If ESTADOVENCIMIENTO  = 0
                    # La línea no se puede eliminar
                    # Cuando se elimina una línea, NBECH no se modifica, siempre conserva el valor inicial

                    Dela NUMVENCIMIENTOS ,1  [M]NBECH

                    # Actualizo contador de lineas reales
                    NUMLINEAS  -= 1


                Endif
            Else
                NUMVENCIMIENTOS += 1
            Endif
        Next
        [M]NBECH = NUMLINEAS
    Endif



    # Modificar o Ańadir los vencimiento que se han pasado como parámetros
    For I=0 To WDIMVEN-1

        EXISTEVENCIMIENTO=0

        If W3MNT(I)=0
             Break
        Endif

        For I1=0 To [M]NBECH-1

            If [M]DUDLIG(I1) = 0
                Break
            Endif
            If [M]DUDLIG(I1) = W3DUDLIG(I)
                EXISTEVENCIMIENTO=1
                Break
            Endif
        Next

        If  EXISTEVENCIMIENTO=1


            NOL= I1
            Gosub VERIFICAR_ESTADO_VENCIMIENTO
            If ESTADOVENCIMIENTO  = 0
                # Modifico la línea existente con los nuevos valores
                #[M]DUDLIG(NOL) = W3DUDLIG(I)
                [M]DUDDAT(NOL) = W3DUEDAT(I)
                [M]AMTCUR(NOL) = W3MNT(I)
                [M]AMTLOC(NOL) = W3MNT(I)
                [M]PAM(NOL)    = W3PAM(I)
                [M]FLGPAZ(NOL) = W3FLGPAZ(I)

            Else
                # El vencimiento no se puede modificar: Si el contenido del vencimiento
                # es distinto al de los parámettros: Error y fin del proceso
               If [M]DUDDAT(NOL) <> W3DUEDAT(I)  | [M]AMTCUR(NOL) <> W3MNT(I) | [M]AMTLOC(NOL) <> W3MNT(I) | [M]PAM(NOL) <>  W3PAM(I) | [M]FLGPAZ(NOL) <> W3FLGPAZ(I)
                 WESTATUS=2
                 CODERROR=5
                 DESCERROR-="no se puede modificar un vencimiento Pagado o en Extracto"
                 Gosub ANYADIR_ERROR
                 Break
               Endif
            Endif

        Else

            # Si el vencimiento no existe: Ańadirlo a la máscara
            nolign = [M]NBECH

            Insa nolign,1,[M]NBECH [M]NBECH
            [M]NBECH += 1

            nolign = [M]NBECH
            NOL = nolign - 1

            Raz [F:DUD]
            [F:DUD] = [F:HAE]
            [F:DUD] = [F:DAE]
            Gosub INIECH

          [F:DUD]LIG = [F:DAE]LIN
          [F:DUD]BPRTYP = VBPRTYP
          [F:DUD]BPRPAY = VBPRPAY
          [F:DUD]BPAPAY = VBPAPAY
          [F:DUD]TYPDUD = VTYPDUD
            [F:DUD]FLGPAZ = W3FLGPAZ(I)
            [F:DUD]DUDLIG=0
            [F:DUD]DUDDAT=W3DUEDAT(I)
            [F:DUD]AMTCUR=W3MNT(I)
            [F:DUD]AMTLOC=W3MNT(I)
            [F:DUD]PAM=W3PAM(I)
            [M]=[F:DUD]
         Endif
    Next

    # Una vez tratados todos los vencimientos: Comprobar si el Importe de los vencimientos
    # coincide con el de la línea, y en caso contrario, generar un vencimiento  por la diferencia
    # y devolvewr al proceso un aviso


    Raz TOTALLINEA , TOTALCALCULADO
    TOTALLINEA = TOTAL  * [F:DUD]SNS
    TOTALCALCULADO = 0

    For I=0 To NBECH-1
       TOTALCALCULADO += ([M]AMTCUR(I)* [F:DUD]SNS)
    Next

    If TOTALCALCULADO <> TOTALLINEA

        nolign = [M]NBECH

        Insa nolign,1,[M]NBECH [M]NBECH
        [M]NBECH += 1

        nolign = [M]NBECH
        NOL = nolign -1

        Raz [F:DUD]
        [F:DUD]       = [F:HAE]
        [F:DUD]       = [F:DAE]

        Gosub INIECH
        [F:DUD]DUDSTA = 2
        [F:DUD]PAMTYP = 1
         # Datos de  la línea anterior
        [F:DUD]PAM=[M]PAM(NOL-1)
        [F:DUD]BPRPAY = [F:DAE]BPR      # PAGADOR
        [F:DUD]LIG = [F:DAE]LIN
        [F:DUD]BPRTYP = VBPRTYP
        [F:DUD]BPRPAY = VBPRPAY
        [F:DUD]BPAPAY = VBPAPAY
        [F:DUD]TYPDUD = VTYPDUD
        [F:DUD]SOI=1
        [F:DUD]FLGFUP = 1

        # Autorización Pago de la línea anterior
        [F:DUD]FLGPAZ = [M]FLGPAZ(NOL-1)

        [M]=[F:DUD]

        # Fecha vencimiento máxima
        [M]DUDDAT(NOL)= max([M:DUD1]DUDDAT(0..[M:DUD1]NBECH-1))

        [M]AMTCUR(NOL) = (TOTALLINEA - TOTALCALCULADO) * [F:DUD]SNS

        [M]AMTLOC(NOL) = [M]AMTCUR(NOL)


        #Tercero pagador linea anterior

        #[M]BPRFCT(NOL)= [F:DUD]BPRPAY

         WESTATUS=1
         CODERROR=9
         DESCERROR-="Se ha generado un vencimiento por la diferencia de importe"
         Gosub ANYADIR_ERROR



    Endif





Return

######################################################################################





######################################################################################
#
#  Inicializa variables
#
######################################################################################
$OUVR_ECH

Local Integer TYPTIERS
Local Char    NUMERO(GLONVCR), TYPPCE(GLONGTE)
    TYPTIERS = 1
    NUMERO = W1NUM
Return
######################################################################################

######################################################################################
#
#  Carga la máscara con los vencimientos de la linea
#
######################################################################################
$CHARGECH
Local Char    DEVLED(GLONCUR)
Local Char    CODLED(GLONLED)
Local Decimal TOTAL, COURS
Local Decimal RATDIV, RATMLT
Local Date    DATCPT, DATEVT
Local Integer TYPCOURS, STAT, LIGECH, NUMECH,  ETAT, LIGPCE, NOL, MODIF
Local Char    DEVISE(GLONCUR), SITE(GLONFCY), SYMBOLE(30)
Local Integer VBPRTYP, VTYPDUD
Local Char VBPRPAY
Local Char VBPAPAY

     OK = 1
     MODIF = 0

     Local Mask GACCDUD [DUD1]

#--- Position des 3 devises par rapport ŕ l'Euro
Call SETFLGDEV([F:HAE]CUR,[F:CPY]CPY,[F:HAE]RATDAT) From CPTDIV

Call GETSOC([F:HAE]FCY) From DEVSUB
Call LECLED([F:CPY]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV

     TOTAL     = [F:DAE]AMTCUR      # Importe II
     DEVISE    = [F:DAE]CUR         # Divisa
     SITE      = [F:DAE]FCYLIN      # Planta
     NUMECH    = [F:DAE]ACCNUM      # Número interno
     DATCPT    = [F:DAE]ACCDAT      # Fecha contable
     DATEVT    = [F:DAE]ACCDAT      # Fecha contable
     TYPCOURS  = [F:HAE]TYPRAT      # clase Cambio
     ETAT     = [F:HAE]STA          # Estado


     SYMBOLE = "HAE"+[F:HAE]NUM+"\"+[F:HAE]TYP


     If LCK
         Lock =SYMBOLE
         If fstat
             WESTATUS=2
             CODERROR=4
             DESCERROR-="No puedo bloquear el asiento " + W1TYP + "/" + W1NUM + " para modificarlo"
             Gosub ANYADIR_ERROR
         Endif
     Endif

    Call LECTURE("FCY",SITE,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ

    Raz [M:DUD1]

    nolign = 0

    For [DUD]DUD1 Where ACCNUM=NUMECH
     nolign += 1
     [M:DUD1] = [F:DUD]
     If nolign=1
      [M:DUD1]DUDCUR = [F:DUD]CUR
      VBPRTYP = [F:DUD]BPRTYP
      VBPRPAY = [F:DUD]BPRPAY
      VBPAPAY = [F:DUD]BPAPAY
      VTYPDUD = [F:DUD]TYPDUD
      LIGPCE = [F:DUD]LIG
     Endif
    Next

    [M:DUD1]PAYTOT = sum([M:DUD1]PAYCUR(0..nolign-1))+sum([M:DUD1]TMPCUR(0..nolign-1))

    If TOTAL<0 & [M:DUD1]AMTCUR(0)>0
      TOTAL=abs(TOTAL)
     Endif
    [M:DUD1]AMTTOT = TOTAL

    [M:DUD1]NBECH = nolign

    #Sorta [M:DUD1]NBECH [M:DUD1]NBECH Order By [M:DUD1]DUDDAT(indice)

    Sorta [M:DUD1]NBECH [M:DUD1]NBECH Order By [M:DUD1]DUDLIG(indice)

Return

######################################################################################



######################################################################################
#
#    Ańadir un mensaje de error a los parametros de retorno
#
######################################################################################
$ANYADIR_ERROR

   # WERRCOD(DIMVEN)=CODERROR
   # WERRSTR(DIMVEN)-=DESCERROR
   #DIMVEN += 1

   WERRCOD=CODERROR

   WERRSTR-=DESCERROR


Return
######################################################################################


######################################################################################
#
#    Comprueba si un vencimiento se puede borrar o modificar
#    Retorno: ESTADOVENCIMIENTO = 0   Vencimiento Modificable
#             ESTADOVENCIMIENTO = 1   Vencimiento NO Modificable (Pagado o en extracto
#
######################################################################################
$VERIFICAR_ESTADO_VENCIMIENTO
Local Integer ESTADOVENCIMIENTO

    ESTADOVENCIMIENTO=0

    If [M]PAYCUR(NOL)<>0 | [M]TMPCUR(NOL)<>0

        # Vencimiento Pagado
        ESTADOVENCIMIENTO=1

    Elsif [M]SOINUM(NOL)<>""

        # Vencimiento en extracto
        ESTADOVENCIMIENTO=1

    Endif

Return
######################################################################################

######################################################################################
#
#    Inicializo valores nuevo vencimiento
#
######################################################################################

$INIECH

[F:DUD]BPRTYP = TYPTIERS

  [F:DUD] =  [F:DAE]

  [F:DUD]FCY    = [F:DAE]FCYLIN   # Planta
  [F:DUD]SAC    = [F:DAE]SAC      # Colectivo
  [F:DUD]SNS    = [F:DAE]SNS      # Sentido
  [F:DUD]TYP    = [F:HAE]TYP      # Tipo Asiento
  #[F:DUD]BPRPAY = [F:DAE]BPR      # PAGADOR

Return
######################################################################################

######################################################################################
#
#  Guardar Vencimientos de Mascara DUD1 a Tabla
#
######################################################################################
$SAVALL

    Call DEBTRANS From GLOCK
    Gosub TR
    If GOK<1
        WESTATUS=2
        CODERROR=4
        DESCERROR-="No puedo bloquear el asiento " + W1TYP + "/" + W1NUM + " para modificarlo"
        Gosub ANYADIR_ERROR

    Else
         Unlock =SYMBOLE
    Endif

Return
######################################################################################


######################################################################################
#
# Seccion: Transaccionalidad
#
######################################################################################
$TR

     GOK = 1
     Trbegin [HAE],[DUD]

     Gosub VALECH
     If   GOK<0
         Gosub ROLL_TR
         If WESTATUS= 2
            Return
         Else
            Goto TR
         Endif
     Elsif !GOK
         Gosub AB_TR
         Return
     Endif

     Gosub MODECR

     If   GOK<0
         Gosub ROLL_TR
         If WESTATUS= 2
            Return
         Else
            Goto TR
         Endif

     Elsif !GOK
         Gosub AB_TR
         Return
     Endif

     Commit

Return
######################################################################################

######################################################################################
#
#    Reintentar Transacción
#
#######################################################################################
$ROLL_TR
  Rollback

    Call ROLL From GLOCK

    If GROLL
         WESTATUS=2
         CODERROR=10
         DESCERROR-="Error grabando vencimientos. No se ha realizado ningún cambio"
         Gosub ANYADIR_ERROR

    Else
      Goto TR
    Endif
Return
######################################################################################

######################################################################################
#
#    Error Abortivo: Cancelar Transacción
#
######################################################################################
$AB_TR

     Rollback

     WESTATUS=2
     CODERROR=10
     DESCERROR-="Error grabando vencimientos. No se ha realizado ningún cambio"
     Gosub ANYADIR_ERROR

Return
######################################################################################



######################################################################################
#
#   Llamada dese SAVALL paraGuardar Vencimientos de Mascara DUD1 a Tabla
#
######################################################################################
$VALECH
Local Decimal  COURCPY, COURRPT, AROLOC, ARORPT
Local Integer  IDEV
Local Integer IND

    #Borrado de los vencimientos que no están en la máscara y que no están como Pagados o en Extracto
    For [DUD]DUD1 Where ACCNUM=NUMECH
         LIGECH = find([F:DUD]DUDLIG,[M:DUD1]DUDLIG(0..[M:DUD1]NBECH-1))
         If !LIGECH | [M:DUD1]AMTCUR(LIGECH-1)=0

            ESTADOVENCIMIENTO=0
            If [DUD]PAYCUR<>0 | [DUD]TMPCUR<>0
                # Vencimiento Pagado
                ESTADOVENCIMIENTO=1
            Elsif [DUD]SOINUM<>""
                # Vencimiento en extracto
                ESTADOVENCIMIENTO=1
            Endif
            If ESTADOVENCIMIENTO=0
              Call HISTOECH("DUD",2,[L]DATEVT) From MODECHE
              Delete [DUD]
              If fstat=1
                   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMECH) : Break
                Endif
          Endif
         Endif
    Next

    If GOK<1
        WESTATUS=2
        CODERROR=3
        DESCERROR-="Se ha producido un error al actualizar vencimientos"
        Gosub ANYADIR_ERROR
       Return
    Endif

# Recalcul des montants société et reporting
Local Char DEVLED(GLONCUR)
Local Char CODLED(GLONLED)
Local Decimal AROLED, COURS

#--- Position des 3 devises par rapport ŕ l'Euro
Call SETFLGDEV([F:HAE]CUR,[F:CPY]CPY,[F:HAE]RATDAT) From CPTDIV

Call GETSOC([F:HAE]FCY) From DEVSUB
Call LECLED([F:CPY]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
Call LECTURE("TCU",DEVLED,"") From CONTOBJ
AROLED = [F:TCU]CURRND
COURS  = [F:HAE]RATMLT/[F:HAE]RATDIV
If [M]NBECH>0
 Call CONVERT_DEV([F:HAE]CUR,[L]DEVLED,[L]DEVLED,NBECH,[M]AMTCUR(0..[M]NBECH-1),[M]AMTLOC,
&  COURS,[F:HAE]TYPRAT,[F:HAE]RATDAT,AROLED) From CPTSUB
Endif

# Modificacion de los vencimientos que existian
LIGECH = 0
For nolign=1 To [M:DUD1]NBECH
If [M:DUD1]AMTCUR(nolign-1)<>0
 If [M:DUD1]DUDLIG(nolign-1)>0
  Readlock [DUD]DUD1 = NUMECH;[M:DUD1]DUDLIG(nolign-1)
  If fstat=1
   GOK=-1
     GLOCK="$GACCDUDATE"-num$(NUMECH)
     WESTATUS=2
     CODERROR=3
     DESCERROR-="Se ha producido un error al actualizar vencimientos"
     Break
  #Elsif fstat
  #   GOK=0
  #   Call RSTA("DUD",num$(NUMECH)) From GLOCK
  #   WESTATUS=2
  #   CODERROR=3
  #   DESCERROR-="Se ha producido un error al actualizar vencimientos"
  #   Break
  Endif
  If fstat=0
      If MODIF
       Gosub INIECH
      Endif
  [F:DUD] = [M:DUD1]
  #[F:DUD]LIG = LIGPCE
  Call SLDECH("DUD")From MODECHE
  Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
      Rewrite [DUD]
      If fstat
           GOK=0
           Call FSTA("DUD") From GLOCK
           WESTATUS=2
           CODERROR=3
           DESCERROR-="Se ha producido un error al actualizar vencimientos"
           Break
      Endif
      Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
      LIGECH = max(LIGECH,[F:DUD]DUDLIG)
     Endif
  Else

    Raz [F:DUD]
    [F:DUD]       = [F:HAE]
    [F:DUD]       = [F:DAE]
    [F:DUD]       = [M]
    [F:DUD]LIG = [F:DAE]LIN
    [F:DUD]BPRTYP = VBPRTYP
    [F:DUD]BPRPAY = VBPRPAY
    [F:DUD]BPAPAY = VBPAPAY
    #[F:DUD]TYPDUD = 4  : #Asiento
    [F:DUD]TYPDUD = VTYPDUD
    [F:DUD]FCY    = [F:DAE]FCYLIN
    [F:DUD]DUDSTA = 2
    [F:DUD]PAMTYP = 1
    [F:DUD]SOI    = 1
    [F:DUD]FLGFUP = 1
    [F:DUD]DUDLIG = LIGECH + 1
    If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
    If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
    LIGECH += 1
    Call KEYDUD("DUD") From MODECHE
    Call SLDECH("DUD")From MODECHE
    Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
    [F:DUD]FIY = EXERCICE
    [F:DUD]PER = PERIODE
    Write [DUD]
    If fstat
         GOK=0
         Call FSTA("DUD") From GLOCK
         WESTATUS=2
         CODERROR=3
         DESCERROR-="Se ha producido un error al actualizar vencimientos"
         Break
    Endif
    Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
  Endif
Endif
Next nolign

If GOK<1 : Return : Endif

Return
######################################################################################


######################################################################################

######################################################################################
#
#    Actualizar la fecha de vencimiento del asiento
#
######################################################################################
$MODECR
# Mise Ă  jour de la date d'Ă©chĂ©ance de la piĂ¨ce (16095)

Readlock [HAE]HAE0=[F:HAE]TYP;NUMERO
If fstat=1
     GOK = -1
     GLOCK = "$GACCENTRY"-[F:HAE]TYP-NUMERO
     WESTATUS=2
     CODERROR=3
     DESCERROR-="Se ha producido un error al actualizar vencimientos"
     Return
Elsif !fstat
   [F:HAE]DUDDAT = max([M:DUD1]DUDDAT(0..[M:DUD1]NBECH-1))
   Rewrite [HAE]
   If fstat
       GOK = 0
       Call FSTA("HAE") From GLOCK
       WESTATUS=2
       CODERROR=3
       DESCERROR-="Se ha producido un error al actualizar vencimientos"
   Endif
Endif
Return
######################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

