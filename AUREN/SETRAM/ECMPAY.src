#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Program Name: ECMPAY (XJZPMTRCP)
# Description:  Payment Receipts Sub-Program
# Created Date: 06/13/2014
# Created By:   D> Hartman, RKL eSolutions
# Modified By:  Dom Nash, XM Developments
#-------------------------------------------------------
# Input Parameters:
# SITE    - Site Code
# BPNBR   - Business Partner ID
# PMTDATE - Payment Date (passed as yyyymmdd)
# PMTTYPE - Payment Type - comes from table TABPAYTYP
# REFDOC  - Document Reference (optional)
# CURRID  - Currency ID
# PMTAMT  - Up to 25 Payment Amts, separated by "^"
# INVCNUM - Up to 25 Invoices to Pay, separated by "^"
# DESTIN  - Payment Type (PPRCP, PAYRC)
# BANK    - Bank Account
# PREPAY  - Is Prepayment
# ANADIM  - Insert Analytical Dimensions from customer
#-------------------------------------------------------
# Output Parameters:
# RESULT  - Array of errors found during validation
########################################################
Subprog APPLY_PAYMENT(SITE, BPNBR, PMTDATE, PMTTYPE, REFDOC, CURRID, PMTAMT, INVCNUM, DESTIN, PAYBNK, PREPAY, SEQTYPE, ANADIM, RECNUM, RESULT)

    # Input Parameters
    Value Char SITE
    Value Char BPNBR
    Value Date PMTDATE
    Value Char PMTTYPE
    Value Char REFDOC
    Value Char CURRID
    Value Char PMTAMT
    Value Char INVCNUM
    Value Char DESTIN
    Value Char PAYBNK
    Value Integer PREPAY
    Value Char SEQTYPE
    Value Integer ANADIM

    # Return Parameters
    Variable Char RECNUM
    Variable Char RESULT

    If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY] : Endif
    If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
    If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
    If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
    If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
    If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
    If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
    If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
    If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif
    If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
    If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
    If clalev([F:PYA])=0 : Local File PAYMENTA   [PYA] : Endif
    If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif

    # Validate Input
    #################

    # Split the invoices and payments into arrays
    Local Char INVC(GLONSIH) (1..25)
    Local Decimal AMT (1..25)
    Gosub SPLITINVC

    # Validate Payment Code
    Local Char PAYCOD   : PAYCOD = ""
    Local Char DENDEFCD : DENDEFCD = ""
    Local Integer EXPNM : EXPNM = 0
    Local Integer SIGN  : SIGN = 0
    Local Integer ACCTY : ACCTY = 0
    Local Integer SNS   : SNS = 0
    Read [TPY]TPY0=PMTTYPE
    If fstat
        RESULT = mess(1,7730,1) + " ("+PMTTYPE+");"   # Invalid payment code
    Else
        PAYCOD   = [F:TPY]PAM
        DENDEFCD = [F:TPY]DENDEF
        EXPNM    = [F:TPY]EXPNUM
        SIGN     = [F:TPY]SNS

        Read [CDA]CDA0=DENDEFCD
        If !fstat
            ACCTY = [F:CDA]ACCTYP
            SNS   = [F:CDA]ACCSNS
        Endif
    Endif

    # Get Company for this Site Code
    Local Char COMP   : COMP = ""
    Local Char COA    : COA = ""
    Local Char BANKCD : BANKCD = ""
    Read [F:FCY]FCY0=SITE
    If !fstat
        COMP = [F:FCY]LEGCPY
        Filter [BAN] Where CPY = COMP
        Read [BAN]
        Read [F:BAN] First
        If !fstat
            BANKCD = [F:BAN]BAN
        Endif
    Else
        RESULT = RESULT + mess(2,7730,1) + " ("+SITE+");"   # Invalid site code
    Endif

    # Get COA Code
    If COMP <> ""
        Call SETGCM(COMP,COA) From CPTDIV
        If COA = ""
            RESULT = RESULT + mess(3,7730,1) + " ("+COMP+");"   # COA code not found for company
        Endif
    Else
        RESULT = RESULT + mess(4,7730,1) + " ("+COMP+");"   # Company code not found
    Endif

    # Get Customer
    Local Char COLLACCT : COLLACCT = ""
    Local Char ACCT : ACCT = ""
    Local Char INVCUST : INVCUST = ""
    Local Char CUSTNAM : CUSTNAM = ""
    Read [F:BPC]BPC0=BPNBR
    If !fstat
        INVCUST = [F:BPC]BPAINV
        CUSTNAM = [F:BPC]BPCNAM
        # Get GACCCODE
        If COA <> ""
            Read [F:CAC]CAC0=2;[F:BPC]ACCCOD;COA
            If !fstat
                ACCT = [F:CAC]ACC(0)
                Read [F:GAC]GAC0=COA;[F:CAC]ACC(0)
                If !fstat
                    COLLACCT = [F:GAC]ACCSHO
                Endif
            Endif
        Endif
    Else
        RESULT = RESULT + mess(5,7730,1) + " ("+BPNBR+");"    # Invalid customer number
    Endif

    # Make sure there is at least one invoice to apply
    Local Integer PMTCNT : PMTCNT = 0
    Local Integer I

    If PREPAY
        #need to check if order exists
        Read [F:SOH]SOH0=INVCNUM

        If !fstat
            RESULT = RESULT + mess(9,7730,1) + " ("+INVCNUM+");"    # Invalid sales order number
        Endif
    Else
        For I = 1 To 25
            If INVC(I) <> "" and AMT(I) <> 0
                PMTCNT = PMTCNT + 1

                Filter [DUD] Where NUM = INVC(I)
                Look [DUD]
                If !fstat
                    If !PREPAY
                        RESULT = RESULT + mess(6,7730,1) + " ("-INVC(I)-");"    # Invalid invoice
                    Endif
                Endif
                Filter [DUD]
            Endif
        Next
        If PMTCNT = 0
            RESULT = RESULT + mess(7,7730,1)    # No invoices included for application
        Endif
    Endif

    # Get Fiscal Year and Fiscal Period
    Local Integer FISCYR : FISCYR = 0
    Local Integer FISCPD : FISCPD = 0
    Filter [PER] Where CPY = COMP and LEDTYP = 1 and PERSTR <= PMTDATE and PEREND >= PMTDATE and PERSTA = 2
    Read [F:PER] First
    If !fstat
        FISCYR = [F:PER]FIYNUM
        FISCPD = [F:PER]PERNUM
    Endif
    Filter [PER]
    If FISCYR = 0 or FISCPD = 0
        RESULT = RESULT + mess(8,7730,1) + " ("+PMTDATE+");"    # No fiscal period defined for this payment date
    Endif

    # No errors
    If RESULT = ""

        # Process the payment
        Gosub PROCRCP

        If GOK=0
          RESULT = GMESSAGE
        Else
          RESULT = mess(16,7730,1)  # Success
        Endif

    Endif

    Close Local File [TPY]
    Close Local File [FCY]
    Close Local File [CPY]
    Close Local File [BPC]
    Close Local File [CAC]
    Close Local File [GAC]
    Close Local File [BPA]
    Close Local File [PYD]
    Close Local File [PYH]
    Close Local File [PER]
    Close Local File [DUD]
    Close Local File [BAN]
    Close Local File [PYA]
    Close Local File [SOH]

End

#########################################
# Split Invoice and Payments into Arrays
#########################################
$SPLITINVC

    Integer I, JI, KI, JA, KA
    KI = 1
    KA = 1
    INVCNUM = INVCNUM + "^"
    PMTAMT = PMTAMT + "^"
    For I = 1 To 25
        JI = instr(1,INVCNUM,"^")
        If JI
            INVC(KI) = left$(INVCNUM,JI-1)
            KI = KI + 1
            INVCNUM = (right$(INVCNUM,JI+1))
        Endif
        JA = instr(1,PMTAMT,"^")
        If JA
            AMT(KA) = val(left$(PMTAMT,JA-1))
            KA = KA + 1
            PMTAMT= (right$(PMTAMT,JA+1))
        Endif
    Next I

Return

######################
# Create the payment
######################
$PROCRCP

    # Calculate the payment total based on the payment for each invoice
    Local Decimal PMTTOT : PMTTOT = 0
    Local Integer I
    Local Char PAYDESC : PAYDESC = ""
    For I = 1 To 25
        If INVC(I) <> "" and AMT(I) <> 0
            PMTTOT = PMTTOT + AMT(I)
            If I = 1 #SET description
                PAYDESC = INVC(I)
            Endif
        Endif
    Next

    If PAYDESC = ""
        PAYDESC = mess(21,7730,1)   # Web payment ("Web Payment")
    Endif

    Local Integer STAFLA : STAFLA = 2
    Local Integer CHQTYPE : CHQTYPE = 1

    If PREPAY
        STAFLA = 1
        CHQTYPE = 0
    Else
        If PAYBNK = ""
          PAYBNK = BANKCD
        Endif
    Endif

    # Create the payment header

    Raz [F:PYH]

    # Get Next Payment Sequence Number
    Local Char FCY(4) : FCY = ""
    Local Date PRCDAT : PRCDATE = date$
    Local Char SEQ_NO : SEQ_NO = ""
    Local Integer STAT

    #If PMTTYPE = "PAPAU"
    #    Call NUMERO("PRC", "PRES", PRCDAT, "PAPAU", SEQ_NO, STAT) From SUBANM
    #Else
        Call NUMERO(SEQTYPE, FCY, PRCDAT, PMTTYPE, SEQ_NO, STAT) From SUBANM
    #Endif

    If SEQ_NO = ""
        RESULT = RESULT + mess(18,7730,1)   # No sequence number found - make sure the correct sequence counter has been selected in E-commerce
    Else

        [F:PYH]NUM = SEQ_NO

        [F:PYH]BPR       = BPNBR
        [F:PYH]BPRSAC    = COLLACCT
        [F:PYH]BAN       = PAYBNK
        [F:PYH]COA       = COA
        [F:PYH]ACC       = ACCT
        [F:PYH]PAYTYP    = PMTTYPE
        [F:PYH]PAM       = PAYCOD
        [F:PYH]CPY       = COMP
        [F:PYH]FCY       = SITE
        [F:PYH]SNS       = SIGN
        [F:PYH]CUR       = CURRID
        [F:PYH]AMTCUR    = PMTTOT
        [F:PYH]AMTBAN    = PMTTOT
        [F:PYH]BANPAYTPY = PMTTOT
        [F:PYH]BPRTYP    = 1            # Customer
        [F:PYH]STA       = 1            # Entered
        [F:PYH]STAFLG(0) = STAFLA       # Status Flags (Yes)
        [F:PYH]ACCDAT    = PMTDATE
        [F:PYH]REF       = REFDOC
        [F:PYH]ORIDAT    = date$
        [F:PYH]DUDDAT    = PMTDATE
        [F:PYH]VALDAT    = PMTDATE
        [F:PYH]BILDAT    = date$
        [F:PYH]CHQTYP    = CHQTYPE      # Check Type
        [F:PYH]CHQNUM    = REFDOC       # Gateway Reference
        [F:PYH]DES       = PAYDESC      # Payment Description
        [F:PYH]FRMTYP    = 1            # Discount Type (Payment)
        [F:PYH]PURTYP    = 1            # Purchase Type (Purchase)
        [F:PYH]PST       = 1            # Posted Status
        [F:PYH]CREDAT    = date$
        [F:PYH]CREUSR    = mess(24,7730,1)
        [F:PYH]FIY       = FISCYR
        [F:PYH]PER       = FISCPD
        [F:PYH]EXPNUM    = EXPNM
        [F:PYH]BPAINV    = INVCUST
        [F:PYH]BPANAM    = CUSTNAM

        # Get Customer Address
        Read [F:BPA]BPA0=1;BPNBR;INVCUST
        If !fstat
            [F:PYH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
            [F:PYH]POSCOD       = [F:BPA]POSCOD
            [F:PYH]CTY          = [F:BPA]CTY
            [F:PYH]SAT          = [F:BPA]SAT
            [F:PYH]CRY          = [F:BPA]CRY
            [F:PYH]CRYNAM       = [F:BPA]CRYNAM
        Endif
        Write [F:PYH]

        RECNUM = SEQ_NO

        # Create the payment detail
        Local Integer LINENO : LINENO = 1
        Local Integer ACCJNL : ACCJNL = 3
        If PREPAY
            ACCJNL = 1
        Else
            DESTIN = DENDEFCD
        Endif

        For I = 1 To 25
            If INVC(I) <> "" and AMT(I) <> 0

                Local Integer ACCNM : ACCNM = 0
                Local Integer DUDLG : DUDLG = 0
                Local Char    TYPCD : TYPCD = ""
                For [F:DUD] Where NUM = INVC(I)
                    ACCNM = [F:DUD]ACCNUM
                    DUDLG = [F:DUD]DUDLIG
                    TYPCD = [F:DUD]TYP
                Next

                Raz [F:PYD]
                [F:PYD]NUM       = SEQ_NO
                [F:PYD]LIN       = LINENO
                [F:PYD]DENCOD    = DESTIN
                [F:PYD]ACCTYP    = ACCTY
                [F:PYD]ACCSNS    = SNS
                [F:PYD]FCYLIN    = SITE
                [F:PYD]BPRLIN    = BPNBR
                [F:PYD]COA(0)    = COA
                [F:PYD]ACC(0)    = ACCT
                [F:PYD]LED(0)    = COA
                [F:PYD]CURLIN    = CURRID
                [F:PYD]AMTLIN    = AMT(I)
                [F:PYD]AMTLIN2   = AMT(I)
                [F:PYD]PAYCURLIN = AMT(I)
                [F:PYD]PAYLOCLIN = AMT(I)
                [F:PYD]VCRTYP    = TYPCD
                [F:PYD]VCRNUM    = INVC(I)
                [F:PYD]IPTTYP    = ACCJNL          # Charged Journal (Accounting Journal)
                [F:PYD]DUDNUM    = ACCNM
                [F:PYD]DUDLIG    = DUDLG
                [F:PYD]BPRINV    = BPNBR
                [F:PYD]BPRSACINV = COLLACCT
                Write [F:PYD]

                [F:DUD]TMPCUR += [F:PYD]PAYCURLIN
                [F:DUD]TMPLOC += [F:PYD]PAYLOCLIN
                Call SLDECH("DUD")From MODECHE
                Rewrite [F:DUD]
                If fstat
                  GOK=0 : Call FSTA("DUD") From GLOCK : Return
                Endif
                Call HISTOECH("DUD",1,[F:PYH]ACCDAT)From MODECHE

                #PAYMENTA
                If ANADIM
                    Gosub ADD_ANALYTIC_DIMS
                Endif

                LINENO = LINENO + 1
            Endif
        Next
    Endif
Return

#########################################
# Customer Analytical Dimensions
#########################################
$ADD_ANALYTIC_DIMS

    #Create PaymentA record
    Local Char DIE(3) (0..19)
    Local Char CCE(15) (0..19)

    Read [BPC]BPC0=BPNBR
    If fstat
        RESULT = RESULT + mess(5,7730,1)    # Invalid customer number

    Else
        #Insert PYA Record
        Raz [F:PYA]
        [F:PYA]NUM      = SEQ_NO
        [F:PYA]LIN      = LINENO
        [F:PYA]AMTANA   = PMTTOT

        For I = 0 To 19
            DIE(I)= [F:BPC]DIE(I)
            CCE(I)= [F:BPC]CCE(I)
            If DIE(I) <> ""
                [F:PYA]DIE(I)= DIE(I)
            Endif
            If CCE(I) <> ""
                [F:PYA]CCE(I) = CCE(I)
            Endif
        Next I

        Write [PYA]
    Endif

Return



$INITWS
    # Used to Test the Web Service
    #SITE = "P23"
    #BPNBR = "C2201"
    #PMTDATE = date$
    #PMTTYPE = "RECCH"
    #REFDOC = "TEST1"
    #CURRID = "USD"
    #PMTAMT = "250^25"
    #INVCNUM = "INV000081^INV000082"
    #RESULT = ""
Return
