#######################################################################
# AUREN - DSM - 20/06/2011
# Especific 71. Aceptación factura cambio Observaciones y retenciones
#
# Se ha de guardar un histórico de las modificaciones sobre el campo observaciones y motivo retención
#######################################################################
# Se ha creado la actividad Z33
#
#  Tablas creadas :
#
#   ZHPINVOBS => ZHO => Histórico de obs. de factura
#   ZHPINVMRET => ZHR => Histórico de motivo retención
#
# La estructura es similar en ambos casos:
# NUM => Número de asiento
# NHIST => Línea
# USR => Código usuario
# CREDAT => Fecha creación
# OBS => Observaciones / MRET => Motivo Retención
#######################################################################
$ZHPINV_HISTORICOS
    Local Integer NOLIGNZHO
    Local Integer NOLIGNZHR

    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif
    If clalev([F:ZHR])=0 : Local File ZHPINVMRET [ZHR] : Endif

    If ZOBS_ANT <> [M:ZAF1]ZOBS
        # Se consulta cual es el último registro
        NOLIGNZHO = 0
        Filter [ZHO] Where ZHONUM =[M:ZAF0]NUM Order By ZHONHIST
        For [ZHO]
            NOLIGNZHO = [ZHO]ZHONHIST +1
        Next
        # Guardar histórico ZOBS
        [F:ZHO]ZHONUM = [M:ZAF0]NUM
        [F:ZHO]ZHONHIST = NOLIGNZHO
        [F:ZHO]ZHOUSR = GUSER
        [F:ZHO]ZHOCREDAT = date$
        [F:ZHO]ZHOHOU = time$
        [F:ZHO]ZHOOBS = ZOBS_ANT
        Write [ZHO]
    Endif

    If ZMOTIVRET_ANT <> [M:ZAF1]ZMOTIVRET
        # Se consulta cual es el último registro
        NOLIGNZHR = 0
        Filter [ZHR] Where ZHRNUM =[M:ZAF0]NUM Order By ZHRNHIST
        For [ZHR]
            NOLIGNZHR = [ZHR]ZHRNHIST +1
        Next
        # Guardar histórico ZMOTIVRET
        [F:ZHR]ZHRNUM = [M:ZAF0]NUM
        [F:ZHR]ZHRNHIST = NOLIGNZHR
        [F:ZHR]ZHRUSR = GUSER
        [F:ZHR]ZHRCREDAT = date$
        [F:ZHR]ZHRHOU = time$
        [F:ZHR]ZHRMRET = ZMOTIVRET_ANT
        Write [ZHR]
    Endif
############################################################################################
## 18/04/2012 - AUREN - DAB - Asistencia 02.627.222 - INCIDENCIA EN EL RECHAZO DE FACTURAS.
##
##      SE INTRODUCE UN MENSAJE PARA SABER SI SE HA PRODUCIDO ALGUN ERROR Y EL ROLLBACK.
##
    If fstat
        OK=0
        GMESSAGE = "Error actualizando fichero histórico. Realizando Rollback."
        Rollback : Call FSTA("PIH") From GLOCK : Return
    Endif

## 18/04/2012 - AUREN - DAB - Asistencia 02.627.222 - INCIDENCIA EN EL RECHAZO DE FACTURAS.
## CODIGO ANTERIOR.
#    If fstat
#        OK=0 : Rollback : Call FSTA("PIH") From GLOCK : Return
#    Endif

Return
#######################################################################

#######################################################################
# AUREN - DSM - 22/06/2011
# Especific 71. Aceptación factura cambio Observaciones y retenciones
#
# Se han de cargar los datos en la pestaña de históricos
#######################################################################
# Se ha creado la actividad Z33
#
#  Tablas creadas :
#
#   ZHPINVOBS => ZHO => Histórico de obs. de factura
#   ZHPINVMRET => ZHR => Histórico de motivo retención
#
# La estructura es similar en ambos casos:
# NUM => Número de asiento
# NHIST => Línea
# USR => Código usuario
# CREDAT => Fecha creación
# OBS => Observaciones / MRET => Motivo Retención
#######################################################################
Subprog CARGAR_HISTORICOS
    Raz [M:ZAF5]

    # Histórico observaciones
    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif

    Filter [ZHO]
    Filter [ZHO] Where ZHONUM = [M:ZAF0]NUM Order By ZHONHIST
    NOL = 0
    For [ZHO]

        [M:ZAF5]ZHOUSR(NOL) = [F:ZHO]ZHOUSR
        [M:ZAF5]ZHOCREDAT(NOL) = [F:ZHO]ZHOCREDAT
        [M:ZAF5]ZHOHOU(NOL) = [F:ZHO]ZHOHOU
        [M:ZAF5]ZHODAT(NOL) = num$(day([F:ZHO]ZHOCREDAT)) +"/" + num$(month([F:ZHO]ZHOCREDAT)) +"/" + num$(year([F:ZHO]ZHOCREDAT) ) + " " +  [F:ZHO]ZHOHOU
        [M:ZAF5]ZHOOBS(NOL) = [F:ZHO]ZHOOBS

        NOL += 1

    Next
    Filter [ZHO]

    [M:ZAF5]ZHONHIST = NOL
    # Histórico motivos retención
    If clalev([F:ZHR])=0 : Local File ZHPINVMRET [ZHR] : Endif

    NOL = 0
    Filter [ZHR]
    Filter [ZHR] Where ZHRNUM = [M:ZAF0]NUM Order By ZHRNHIST
    NOL = 0
    For [ZHR]
        [M:ZAF5]ZHRUSR(NOL) = [F:ZHR]ZHRUSR
        [M:ZAF5]ZHRCREDAT(NOL) = [F:ZHR]ZHRCREDAT
        [M:ZAF5]ZHRHOU(NOL) = [F:ZHR]ZHRHOU
        [M:ZAF5]ZHRDAT(NOL) = num$(day([F:ZHR]ZHRCREDAT)) +"/" + num$(month([F:ZHR]ZHRCREDAT)) +"/" + num$(year([F:ZHR]ZHRCREDAT) ) + " " +  [F:ZHR]ZHRHOU
        [M:ZAF5]ZHRMRET(NOL) = [F:ZHR]ZHRMRET
        NOL += 1
    Next
    Filter [ZHR]
    [M:ZAF5]ZHRNHIST = NOL


    Affzo [M:ZAF5]
End
#######################################################################


#######################################################################
# AUREN - DSM - 22/06/2011
# Especific 71. Aceptación factura cambio Observaciones y retenciones
#
# Se han de cargar los datos en la pestaña de históricos
#######################################################################
# Se ha creado la actividad Z33
#
# Cargar la pantalla con el detalle de las observaciones
#######################################################################
Subprog CARGAR_DETALLES_HIST_OBS
    If clalev([F:ZHO])=0 : Local File ZHPINVOBS [ZHO] : Endif

    Filter [ZHO] Where ZHONUM = [M:ZAF0]NUM and ZHONHIST = (nolign-1)
    For [ZHO]
        [M:ZAF6]ZHOOBS = [F:ZHO]ZHOOBS
    Next
    Filter [ZHO]
    Affzo [ZAF6]
End
