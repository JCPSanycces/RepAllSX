                #Assis. 05.680.432
Local Integer VARABONO: VARABONO = 1

    If clalev([F:PID])=0 : Local File PINVOICED    [PID] : Endif

    If [M:ZAF1]ZACEPTA = 5
        Filter [PID] Where NUM = [M:ZAF0]NUM
        For [PID]
            If [F:PID]TYPORI <>5
                VARABONO = 0
            Endif
        Next
        Filter [PID]

        If VARABONO = 0
            GERR=1
            GMESSAGE = "Solo se permite rechazar Facturas/abonos que sean directos"
            mkstat = 2
            OK =0
            Return
        Endif
    Endif
                    #Assis. 05.680.432

    Call OUVRE_TRACE("Modificación Documento") From LECFIC # AUREN - DSM - 201506 - 05.508.597 - Traza
    Call ECR_TRACE("Documento a tratar "+num$([M:ZAF0]NUM),0) From GESECRAN    # AUREN - DSM - 201506 - 05.508.597 - Traza

    ### AUREN Específico 28 - Si rechazo Factura generar Abono; Si rechazo Abono generar Factura  (03/08/2011)
    ###########################################################################################################
    XERROR = 0
    If [M:ZAF1]ZACEPTA = 5
        Call ECR_TRACE("Rechazar",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
        Read [PIH]PIH0 = [M:ZAF0]NUM : If fstat Raz [F:PIH] : Endif
        # Es factura
        If [F:PIH]INVTYP = 1
            Call ECR_TRACE("Factura",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
            # factura validada
            If [F:PIH]STA = 3
                Call ECR_TRACE("Validada",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                # 20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rechazo factura
                # Gosub LANZAR_IMPORT
                If [F:PIH]ZACEPTA <>5
                    Call ECR_TRACE("Importación de factura",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                    Gosub LANZAR_IMPORT
                Endif
            Else
                Call ECR_TRACE("No se puede generar Abonos de Facturas no valdidadas",1) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                Call FERME_TRACE From LECFIC# AUREN - DSM - 201506 - 05.508.597 - Traza
                GERR=1
                GMESSAGE = "No se puede generar Abonos de Facturas no validadas"
                mkstat = 2
                OK =0
                Return
            Endif
        Else
            # Es abono
            If [F:PIH]INVTYP = 2
                Call ECR_TRACE("Abono",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                # factura validada
                If [F:PIH]STA = 3
                    Call ECR_TRACE("Validada",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                    # 20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rechazo factura
                    # Gosub LANZAR_IMPORT
                    If [F:PIH]ZACEPTA <>5
                        Call ECR_TRACE("Importación de factura",0) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                        Gosub LANZAR_IMPORT
                    Endif
                Else
                    Call ECR_TRACE("No se puede generar Factura de Abono no validado",1) From GESECRAN  # AUREN - DSM - 201506 - 05.508.597 - Traza
                    Call FERME_TRACE From LECFIC # AUREN - DSM - 201506 - 05.508.597 - Traza
                    GERR=1
                    GMESSAGE = "No se puede generar Factura de Abono no validado"
                    mkstat = 2
                    OK =0
                    Return
                Endif
            Endif
        Endif
    Endif
