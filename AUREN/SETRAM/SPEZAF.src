######################################################################################
##
## 17/02/2011 Visualizar la ruta y el nombre del primer documento adjunto
##
####################################################################################

Subprog CARGAR_RUTA_DOCUMENTO_ADJUNTO

      Filter [XAOX] Where ABREV= "BIS" and IDENT1 = [M:ZAF0]NUM

      Read [XAOX]AOX0 First

      If fstat=0

        [M:ZAF1]ZDOC = [XAOX]NAM
        Affzo  [M:ZAF1]ZDOC

      Endif
      Filter [XAOX]

      ## Assistència 05.211.197 - SAGE X3 - Factures Compres - Falta ruta arxiu escanejat
      Filter [XAOX] Where ABREV= "PIH" and IDENT1 = [M:ZAF0]NUM

      Read [XAOX]AOX0 First

      If fstat=0

        [M:ZAF1]ZDOC = [XAOX]NAM
        Affzo  [M:ZAF1]ZDOC

      Endif
      Filter [XAOX]
      ## Assistència 05.211.197 - SAGE X3 - Factures Compres - Falta ruta arxiu escanejat

End

######################################################################################
######################################################################################
##### 18/02/2001    AUDITORIA
######################################################################################

Subprog CARGAR_AUDITORIA
Local Char TEXTOMENU
Local Char DESCRIPCION_DPTO

    Raz [M:ZAF4]

    #AUREN - PU9
    #CRITERE = "[AUD]TBL = 'PINVOICE' and [AUD]ID1 = [M:ZAF0]NUM"
    CRITERE = "([AUD]TBL = 'PINVOICE' or [AUD]TBL = 'ZPINVOICEA')and [AUD]ID1 = [M:ZAF0]NUM"
    #AUREN - PU9

    Filter [AUD]
    Filter [AUD] Where evalue(CRITERE) Order By Key CLE=[F:AUD]SEQ
    NOL = 0
    For [AUD]

        ### AÃ‘ADIR LÃ?NEA CABECERA SI EVENTO INSERT (Modif 20/04/2011)

    #AUREN - PU9
        #If [F:AUD]EVT="INSERT"
        If [F:AUD]EVT="INSERT"  and [F:AUD]TBL<>"ZPINVOICEA"
    #AUREN - PU9

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZAF4]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZAF4]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZAF4]SEQ(NOL) = [F:AUD]SEQ
            [M:ZAF4]TBL(NOL) = [F:AUD]TBL
            [M:ZAF4]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZAF4]HOU(NOL) = [F:AUD]HOU
            [M:ZAF4]EVT(NOL) = [F:AUD]EVT
            [M:ZAF4]ID1(NOL) = [F:AUD]ID1
            [M:ZAF4]ADRCLI(NOL) = [F:AUD]ADRCLI

            NOL += 1
            nolign = NOL

        Endif

        ### NO AÃ‘ADIR LÃ?NEA DETALLE SI EVENTO INSERT (Modif 20/04/2011)

        If [F:AUD]EVT<>"INSERT"


        Filter [AUL]
        ### Para cada registro de cabecera de auditoria, se aÃƒÂ±adirÃƒÂ¡ una lÃƒÂ­nea por cada campo afectado
        Filter [AUL] Where SEQ=[F:AUD]SEQ

        For [AUL]

             Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZAF4]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZAF4]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZAF4]SEQ(NOL) = [F:AUD]SEQ
            [M:ZAF4]TBL(NOL) = [F:AUD]TBL
            [M:ZAF4]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZAF4]HOU(NOL) = [F:AUD]HOU
            [M:ZAF4]EVT(NOL) = [F:AUD]EVT
            [M:ZAF4]ID1(NOL) = [F:AUD]ID1
            [M:ZAF4]ADRCLI(NOL) = [F:AUD]ADRCLI


             Read [XATZ]CODZONE= 'PINVOICE';[F:AUL]COL
             If fstat
                #AUREN - PU9
                #Raz [F:XATZ]
                Read [XATZ]CODZONE= 'ZPINVOICEA';[F:AUL]COL
                If fstat
                  Raz [F:XATZ]
                Endif
                #AUREN - PU9
             Endif

            ### Nombre de la columna
            Read [XATX]NUMERO= 'SPA';[F:XATZ]NOLONG
             If fstat
                Raz [F:XATX]
             Endif
            ## No mostrar nombre campo, Ãºnicamente descripciÃ³n (modif 21/04/2011)
            #[M:ZAF4]ZDESCCAMPO(NOL) = [F:AUL]COL + "-" + [F:XATX]TEXTE
            [M:ZAF4]ZDESCCAMPO(NOL) = [F:XATX]TEXTE


            ### Valores de la columna

            If [F:AUL]COL = "ZDEP"

                Call OBTENER_NOMBRE_DPTO([F:AUL]OVAL, DESCRIPCION_DPTO)
                [M:ZAF4]ZVALORANT(NOL)=   [F:AUL]OVAL + "-" + DESCRIPCION_DPTO

                Call OBTENER_NOMBRE_DPTO([F:AUL]NVAL , DESCRIPCION_DPTO)
                [M:ZAF4]ZVALORACT(NOL)=   [F:AUL]NVAL + "-" + DESCRIPCION_DPTO

            Else
                If [XATZ]CODTYP = "M"
                    ### SI ES UN CAMPO TIPO MENU
                    If len([F:AUL]OVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]OVAL)
                        [M:ZAF4]ZVALORANT(NOL)= TEXTOMENU

                    Endif
                    If len([F:AUL]NVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]NVAL)
                        [M:ZAF4]ZVALORACT(NOL)= TEXTOMENU

                    Endif
                Else
                    [M:ZAF4]ZVALORANT(NOL)=   [F:AUL]OVAL
                    [M:ZAF4]ZVALORACT(NOL)=   [F:AUL]NVAL
                Endif
            Endif

            NOL += 1
            nolign = NOL

        Next
        Filter [AUL]

        Endif

    Next

    Filter [AUD]
    [M:ZAF4]NBLIG = NOL

    Affzo [M:ZAF4]


End


########################################################################################
##
## 18/02/2011    Se genera una lÃƒÂ­nea por cada campo auditado
##
########################################################################################
Subprog OBTENERTEXTOMENU(TEXTOMENU, CAMPO, MENU,VALOR)
Variable Char    TEXTOMENU()
Value  Char CAMPO()
Value  Integer MENU
Variable Char    VALOR()



     Read [XAST]CLE= MENU;val(VALOR);"SPA"
     If fstat = 0
       TEXTOMENU = [F:XAST]LANMES
     Endif
End


########################################################################################
##
## 21/02/2011 Obtener nombre departamento
##
########################################################################################
Subprog OBTENER_NOMBRE_DPTO(CODDEP, NOMBREDEP)
Value  Char CODDEP
Variable Char    NOMBREDEP()
    If clalev([F:ZDT])=0 : Local File ZDPTO       [ZDT] : Endif

    Raz NOMBREDEP
    Read [ZDT]ZDP0 = CODDEP: If fstat Raz [F:ZDT] : Endif
    NOMBREDEP= [F:ZDT]ZNOM

End


###########################################################################################
###
### AceptaciÃ³n masiva
###
###########################################################################################

$PICKE
Local Integer NOL

    ###########################################################
    # AUREN - 05.814.939 - CONTROL VALIDACIÓN FACTURA NSAP
    ###########################################################
    If [F:PIH]ZACEPTA <> 4 and [F:PIH]ORIMOD = 6 and [F:PIH]ZVNSAP<>2
       ITGPRODUC = 0
       For [PID] Where NUM=[F:PIH]NUM
          Read [ITM]ITM0=[F:PID]ITMREF
          If [F:ITM]TCLCOD = GZFACNSAP  : ITGPRODUC = 1 : Endif
       Next
       If ITGPRODUC <> 0
          GMESSAGE="No se puede aceptar la factura " + [F:PIH]NUM + " : PENDIENTE VALIDACIÓN NSAP"
          OK = 0
          GPE = 1
          GERR = 1
          Return
       Endif
    Endif
    ###########################################################

    nolign = [M:ZAF1]NBLIG
    Insa nolign,1,[M:ZAF1]NBLIG [M:ZAF1]NBLIG
    [M:ZAF1]NBLIG += 1
    nolign = [M:ZAF1]NBLIG
    NOL = nolign-1

    [M:ZAF1]ZNUMFACT(NOL) = [F:PIH]NUM
    Affzo [M:ZAF1]ZNUMFACT(NOL)

    ### Presentra el documento seleccionado
    [M:ZAF0]CPY = [F:PIH]CPY
    [M:ZAF0]FCY  = [F:PIH]FCY
    [M:ZAF0]PIVTYP  = [F:PIH]PIVTYP
    [M:ZAF0]BPR  = [F:PIH]BPR
    [M:ZAF0]ACCDAT  = [F:PIH]ACCDAT
    [M:ZAF0]ZESCAN  = [F:PIH]ZESCAN
    [M:ZAF0]BPRDAT  = [F:PIH]BPRDAT
    [M:ZAF0]ZNUMREG  = [F:PIH]ZNUMREG
    [M:ZAF0]NUM  = [F:PIH]NUM

    # Correcció Compras X3
    [M:ZAF0]ZESCDAT  = [F:PIH]ZESCDAT
    [M:ZAF0]DUDDAT  = [F:DUD]DUDDAT

## auren - dsm 05.586.966
    [M:ZAF0]BPRPAY = [F:PIH]BPRPAY
    [M:ZAF0]ORIMOD = [F:PIH]ORIMOD
## auren - dsm 05.586.966
    Affzo [M:ZAF0]

    [M:ZAF1]BPRVCR  = [F:PIH]BPRVCR
    [M:ZAF1]PTE = [F:PIH]PTE
    [M:ZAF1]AMTNOT = [F:PIH]AMTNOT
    [M:ZAF1]AMTATI = [F:PIH]AMTATI
    [M:ZAF1]ZDEP = [F:PIH]ZDEP
    [M:ZAF1]PAZ = [F:PIH]PAZ
    [M:ZAF1]ZUS1 = [F:PIH]ZUS1
    [M:ZAF1]ZACEPTA = [F:PIH]ZACEPTA
    [M:ZAF1]ZUS2 = [F:PIH]ZUS2
#AUREN - PU9
#    [M:ZAF1]ZMOTIVR = [F:PIH]ZMOTIVR
#    [M:ZAF1]ZMOTIVD = [F:PIH]ZMOTIVD
#    [M:ZAF1]ZMOTIVRET = [F:PIH]ZMOTIVRET
#    #[M:ZAF1]ZDOC = [F:PIH]ZDOC
#    [M:ZAF1]ZOBS = [F:PIH]ZOBS
## auren - dsm 05.586.966
#    [M:ZAF1]ZINCACEP = [F:PIH]ZINCACEP
    Raz [M:ZAF1]ZMOTIVR
    Raz [M:ZAF1]ZMOTIVD
    Raz [M:ZAF1]ZMOTIVRET
    Raz [M:ZAF1]ZOBS
    Raz [M:ZAF1]ZINCACEP
    Read [F:ZPX]ZPX0=[M:ZAF0]NUM
    If fstat=0
      [M:ZAF1]ZMOTIVR = [F:ZPX]ZMOTIVR
      [M:ZAF1]ZMOTIVD = [F:ZPX]ZMOTIVD
      [M:ZAF1]ZMOTIVRET = [F:ZPX]ZMOTIVRET
      [M:ZAF1]ZOBS = [F:ZPX]ZOBS
      [M:ZAF1]ZOBSLIQ = [F:ZPX]ZOBSLIQ
  ## auren - dsm 05.586.966
      [M:ZAF1]ZINCACEP = [F:ZPX]ZINCACEP
    Endif
#AUREN - PU9
    [M:ZAF1]CUR = [F:PIH]CUR
    [M:ZAF1]ZDEPPROD = [F:PIH]ZDEPPROD
## auren - dsm 05.586.966

     Affzo [M:ZAF1]

     Call CARGAR_RUTA_DOCUMENTO_ADJUNTO

    ##### 22/02/2001    AUDITORIA
    Call CARGAR_AUDITORIA

    [M:ZAF1]ZTRAZA = ""
    Affzo [M:ZAF1]ZTRAZA


Return

$DEPICK
Local Integer NOL

     While NOL < [M:ZAF1]NBLIG

          If [M:ZAF1]ZNUMFACT(NOL ) = [F:PIH]NUM

             Dela NOL,1,[M:ZAF1]NBLIG-1 [M:ZAF1]NBLIG
             [M:ZAF1]NBLIG = [M:ZAF1]NBLIG -1
            Break
         Endif
        NOL = NOL +1

    Wend
    Affzo [M:ZAF1]ZNUMFACT

Return


$AVANTBOUT
Local Integer NOL
Local Char GUARDAR(250)

If BOUT="Y"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARINVOIC(250) : ZPARINVOIC =func AFNC.PARAM("ZPARINVOIC","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARINVOIC + nomap + "&usr=" + GUSER + "&id=" + [M:ZAF0]NUM + "&cpy=" + [M:ZAF0]CPY ,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Endif
If BOUT="U"
  If clalev([F:XAOX])=0 : Local File AOBJTXT  [XAOX] : Endif
  Filter [XAOX] Where IDENT1 = [M:ZAF0]NUM
  Read [XAOX]AOX0 First
  If fstat=0
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARVIEWFI(250) : ZPARVIEWFI =func AFNC.PARAM("ZPARVIEWFI","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARVIEWFI + nomap + "&usr=" + GUSER + "&id=" + [M:ZAF0]NUM,
&"UIAdxPubSubFile="+chr$(1)+"1"
  #####AUREN.FIN
  ###########################################################################################


  Endif
  Filter [XAOX]
Endif
If BOUT = "h"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + [M:ZAF0]NUM + "&cpy=" + [M:ZAF0]CPY + "&act=add",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Endif

If BOUT= "Z"
        If [M:ZAF1]NBLIG = 0

            GERR=1
            GMESSAGE = "No hay niguna Factura Pendiente o Preaceptada seleccionada en la lista de AceptaciÃ³n Masiva."
            GOK=0
            Return
        Else

            While NOL < [M:ZAF1]NBLIG

                If len([M:ZAF1]ZTRAZA )  = 0
                    [M:ZAF1]ZTRAZA = [M:ZAF1]ZNUMFACT(NOL)
                Else
                    [M:ZAF1]ZTRAZA = [M:ZAF1]ZTRAZA  + " / " +[M:ZAF1]ZNUMFACT(NOL)
                Endif
                GUARDAR= [M:ZAF1]ZTRAZA
                Affzo [M:ZAF1]ZTRAZA

                Trbegin [DUD],[PIH]

                Update [DUD] Where NUM = [M:ZAF1]ZNUMFACT(NOL)  With FLGPAZ = 4
                If fstat
                    OK=0
                    Rollback
                    Call FSTA("DUD") From GLOCK
                    Break
                Endif

#lpardo 08.01.13 grup siderurgic
#                Update [PIH] Where NUM = [M:ZAF1]ZNUMFACT(NOL) With ZACEPTA =  4, PAZ = 4
                Update [PIH] Where NUM = [M:ZAF1]ZNUMFACT(NOL) With ZACEPTA =  4, PAZ = 4, ZACEPDAT = date$

                If fstat
                    OK=0
                    Rollback
                    Call FSTA("PIH") From GLOCK
                    Break
                Endif
                Commit

                ### 28/03/2011 REPLICACION DE DATOS
                Read [PIH]PIH0 = [M:ZAF1]ZNUMFACT(NOL)
                If fstat = 0
                    Gosub REPLICA From SPEBIS
                Endif

                NOL = NOL +1
            Wend

            If OK=0
                Infbox "Se ha producido un error en AceptaciÃ³n masiva."
            Else
                Infbox "Finalizada AceptaciÃ³n masiva."
            Endif

            ## Volver a cargar la lista conm las facturas Pendientes y Preaceptadas (OpciÃ³n SAGE)
            ILIS=val(right$(currbox,8))
            Gosub REMP_LISGAU From GOBJSUB

             ## Volver a cargar la lista conm las facturas Pendientes y Preaceptadas (tambiÃ©n funciona)
            # Filter [PIH_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
#&            Order With CLELISTE
#             Fillbox [ZAF1] GAU_CHE4 Hint Key = HINTLIS(4)

            OK=0
            Raz GREP
            Raz REP
            Gosub LIENS

            [M:ZAF1]ZTRAZA = GUARDAR
            Affzo [M:ZAF1]ZTRAZA

        Endif
     Endif
Return

Subprog INICIALIZAR_LISTA_FACTURAS_SELECCIONADAS

    Raz [M:ZAF1]NBLIG
    Raz [M:ZAF1]ZNUMFACT

    Affzo [M:ZAF1]NBLIG
    Affzo [M:ZAF1]ZNUMFACT
End


Subprog CAMPOSNOEDITABLES

    If currbox = GBOXZA4
        Grizo [M:ZAF1]ZMOTIVRET
        Grizo [M:ZAF1]ZMOTIVR
        Grizo [M:ZAF1]ZDEP
        Grizo [M:ZAF1]ZACEPTA
        Grizo [M:ZAF1]ZOBS
        Grizo [M:ZAF1]ZDEPPROD
    Else
         Actzo [M:ZAF1]ZOBS
         Actzo [M:ZAF1]ZDEPPROD
    Endif

    [M:ZAF1]ZTRAZA = ""
    Affzo [M:ZAF1]ZTRAZA

End



######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZAF1) 10/04/2012 15:13:53 (ADMIN)
######################################################################################
Subprog AS_ZACEPTA(VALEUR)
Variable Integer VALEUR
# AUREN - DSM - 02/04/2012 EA95. Deshacer aceptación de factura
# Si el estado anteriro era Aceptada solo se puede cambiar a Pendiente
    Read [PIH]PIH0 = [M:ZAF0]NUM : If fstat Raz [F:PIH] : Endif
    If [F:PIH]ZACEPTA = 4
          For I=2 To 5:GMENLOC(I)=1:Next I
    Else
          For I=1 To 5:GMENLOC(I)=0:Next I
    Endif
# AUREN - DSM - 02/04/2012 EA95. Deshacer aceptación de factura

###########################################################
# AUREN - 05.814.939 - CONTROL VALIDACIÓN FACTURA NSAP
###########################################################
    If [F:PIH]ZACEPTA <> 4 and [F:PIH]ORIMOD = 6 and [F:PIH]ZVNSAP<>2
       ITGPRODUC = 0
       For [PID] Where NUM=[F:PIH]NUM
          Read [ITM]ITM0=[F:PID]ITMREF
          If [F:ITM]TCLCOD = GZFACNSAP  : ITGPRODUC = 1 : Endif
       Next
       If ITGPRODUC <> 0
          GMENLOC(3)=1
          GMENLOC(4)=1
       Endif
    Endif
End

