$VERIF_MOD
     ### AceptaciÃ³n masiva


    If currbox = GBOXZA4
          GERR=1
          GMESSAGE = "En AceptaciÃ³n Masiva no se permite el botÃ³n Registrar."
          GOK=0
          mkstat = 2
         Return
    Endif

    ###### 14/02/11 Solo se introduce motivo rechazo si la factura pasa a estado Rechazado
    If [M:ZAF1]ZACEPTA = 5
