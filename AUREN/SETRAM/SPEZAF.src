######################################################################################
$ACTION

# 23/06/2011 Especific 71
#    If GACTION <> "ZAUDIT"
    If GACTION <> "ZAUDIT" and GACTION <> "ZHOBS" and GACTION <> "ZHMRT"
# 23/06/2011 Especific 71
        Case ACTION
            When "OUVRE"             : Gosub OUVRE
            When "FILTRE"            : Gosub FILTRE
            When "FILGAUCHE"         : Gosub FILGAUCHE
            When "OUVRE_BOITE"       : Gosub OUVRE_BOITE
            When "FERME"             : Gosub FERME
            When "HINT"              : Gosub HINTCLE
            When "LIENS"             : Gosub LIENS
            When "MODIF"             : Gosub MODIF
            When "APRES_MOD"         : Gosub APRES_MOD
            When "VERIF_MOD"         : Gosub VERIF_MOD
            When "STYLE"             : Gosub STYLE
            When "DEBUT"             : Gosub DEBUT

             ### AceptaciÃ³n masiva
            When "PICKE"         : Gosub PICKE
            When "DEPICK"        : Gosub DEPICK
            When "AVANTBOUT"     : Gosub AVANTBOUT
            When "APRES_CRE"     : Gosub APRES_CRE

            When Default
        Endcase
     Else
         Case ACTION
            When "DEBUT"    : Gosub DEBUT
         Endcase
     Endif
Return
######################################################################################
$OUVRE
    If clalev([F:ZUD])=0 : Local File ZUSRDPT     [ZUD] : Endif
    If clalev([F:ZDT])=0 : Local File ZDPTO       [ZDT] : Endif
    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
    If clalev([F:AUD])=0 : Local File AUDITH      [AUD] : Endif
    If clalev([F:AUL])=0 : Local File AUDITL      [AUL] : Endif

    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif
    If clalev([F:PIL])=0 : Local File BPSINVLIG   [PIL] : Endif
    If clalev([F:PIA])=0 : Local File BPSINVLIGA  [PIA] : Endif

    If clalev([F:XAUS])=0 : Local File AUTILIS  [XAUS] : Endif

    If clalev([F:XAOX])=0 : Local File AOBJTXT  [XAOX] : Endif

    ##### 22/02/2001    AUDITORIA
    If clalev([F:XAUS2])=0 : Local File AUTILIS  [XAUS2] : Endif
    If clalev([F:XAOX])=0 : Local File AOBJTXT   [XAOX] : Endif
    If clalev([F:XATZ])=0 :  Local File ATABZON   [XATZ] : Endif
    If clalev([F:XAST])=0 :  Local File APLSTD   [XAST] : Endif
    If clalev([F:XATX])=0 :  Local File ATEXTE   [XATX] : Endif
    #####  FIN
#AUREN - PU9
    If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
#AUREN - PU9

     Read [XAUS]CODUSR= GUSER: If fstat Raz [F:XAUS] : Endif

#AUREN - PU9
    If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
#AUREN - PU9

    # AUREN - 05.814.939 - CONTROL VALIDACIÓN FACTURA NSAP
    If clalev([F:PID])=0 : Local File PINVOICED   [PID] : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER   [ITM] : Endif

Return
######################################################################################
$OUVRE_BOITE
    Global Char    GBOXZA1(10), GBOXZA2(10)
    Global Char    GBOXZA5(10), GBOXZA6(10)
    Global Char    GBOXZA8(10)
    Global Char    GBOXZA7(10), GBOXZA9(10)

    ### AceptaciÃ³n masiva
    Global Char    GBOXZA4(10)

    Global Integer XERROR

# InicializaciÃ³n de los nombres de las listas izquierdas (currbox)
    GBOXZA1="GAU_CHE"+num$(find("ZA1",OBJLIS(1..9)))
    GBOXZA2="GAU_CHE"+num$(find("ZA2",OBJLIS(1..9)))
    GBOXZA5="GAU_CHE"+num$(find("ZA5",OBJLIS(1..9)))
    GBOXZA6="GAU_CHE"+num$(find("ZA6",OBJLIS(1..9)))
    GBOXZA7="GAU_CHE"+num$(find("ZA7",OBJLIS(1..9)))

    #Solicitud cambio 05.974.196
    #GBOXZA8="GAU_CHE"+num$(find("ZA8",OBJLIS(1..9)))
    GBOXZA8="GAU_CHE"+num$(find("ZAV",OBJLIS(1..9)))

    GBOXZA9="GAU_CHE"+num$(find("ZA9",OBJLIS(1..9)))

    ### AceptaciÃ³n masiva
    GBOXZA4="GAU_CHE"+num$(find("ZA4",OBJLIS(1..9)))
    XERROR = 0
Return
######################################################################################
$FERME
    If dim(GBOXZA1)>0 : Kill GBOXZA1 : Endif
    If dim(GBOXZA2)>0 : Kill GBOXZA2 : Endif
    If dim(GBOXZA5)>0 : Kill GBOXZA5 : Endif
    If dim(GBOXZA6)>0 : Kill GBOXZA6 : Endif
    If dim(GBOXZA7)>0 : Kill GBOXZA7 : Endif
    If dim(GBOXZA8)>0 : Kill GBOXZA8 : Endif
    If dim(GBOXZA9)>0 : Kill GBOXZA9 : Endif

    ### AceptaciÃ³n masiva
    If dim(GBOXZA4)>0 : Kill GBOXZA4 : Endif

    Kill XERROR
Return
######################################################################################
$HINTCLE
    Case currbox
        When GBOXZA1 : HINTLIS(val(right$(GBOXZA1,8)))="PIH0"
        When GBOXZA2 : HINTLIS(val(right$(GBOXZA2,8)))="PIH0"
         ### AceptaciÃ³n masiva
        When GBOXZA4 : HINTLIS(val(right$(GBOXZA4,8)))="PIH0"
        When GBOXZA5 : HINTLIS(val(right$(GBOXZA5,8)))="PIH0"
        When GBOXZA6 : HINTLIS(val(right$(GBOXZA6,8)))="PIH0"
        When GBOXZA7 : HINTLIS(val(right$(GBOXZA7,8)))="PIH0"

        #Solicitud cambio 05.974.196
        #When GBOXZA8 : HINTLIS(val(right$(GBOXZA8,8)))="PIH0"
        When GBOXZA8 : HINTLIS(val(right$(GBOXZA8,8)))="DUD0"

        When GBOXZA9 : HINTLIS(val(right$(GBOXZA9,8)))="PIH0"

    Endcase

Return
######################################################################################
$FILTRE2

#Solicitud cambio 05.974.196 - Facturas aceptadas pendientes de pago - GAU_CHE7
If currbox = "GAU_CHE7"
    FILTSUP = "[F:PIH]ORIMOD=3 and ([F:PIH]INVTYP=1 or [F:PIH]INVTYP=2)"
    FILTSUP += " AND ([F:PIH]ZUS1=GUSER or [F:PIH]ZUS2=GUSER"
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        FILTSUP += " or [F:PIH]ZDEP= '" + [F:ZUD]ZDEP + "'"
    Next
    FILTSUP +=")"
Else
     # AÃ‘ADIDO CONTROL PARA QUE TAMBIEN SE TRATEN ABONOS: INVTYP=2
      FILTSUP = "ORIMOD=3 and (INVTYP=1 or INVTYP=2)"
    #FILTSUP = "ORIMOD=3 and INVTYP=1"

    FILTSUP += " AND (ZUS1 = GUSER or ZUS2 = GUSER"
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        FILTSUP += " or ZDEP = '" + [F:ZUD]ZDEP + "'"
    Next
    FILTSUP +=")"
Endif

Return

$FILTRE
Local Char FILTROAUX(250)
Local Integer INICIO

  #Solicitud cambio 05.974.196 - Facturas aceptadas pendientes de pago - GAU_CHE7
  If currbox = "GAU_CHE7"
    FILTSUP  = "([F:PIH]ORIMOD=3 OR [F:PIH]ORIMOD=6) and([F:PIH]INVTYP=1 or [F:PIH]INVTYP=2)"
    FILTSUP += " AND([F:PIH]ZUS1=GUSER or [F:PIH]ZUS2=GUSER "

    FILTROAUX= FILTSUP

    INICIO=0
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        If [F:XAUS]ZFLGACPFAC = 2
            ### Ver los que hay en la lista
            FILTSUP += "or [F:PIH]ZDEP='" + [F:ZUD]ZDEP + "'"
        Else
            If INICIO = 0
                INICIO =1
                FILTSUP += "OR([F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"
            Else
                 ### Ver los que NO hay en la lista
                FILTSUP += "AND [F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"
             Endif
        Endif
        If len(FILTSUP) > 238
            FILTSUP = FILTROAUX
            Infbox "No se puede cargar la información de todos los departamentos asociados al usuario. Revise la configuración del usuario." Titled "Aviso"
            Break
        Else
            FILTROAUX= FILTSUP
        Endif
    Next

    ### Especifico 88
    ### Ver los que NO hay en la lista, pero NO hay departamentos en la lista -> Ver todos
    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO=0
         FILTSUP += "or ([F:PIH]ZDEP<>'')"
    Endif

    FILTSUP +=")"

    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO =1
         FILTSUP +=")"
    Endif

  Else

     # AÃƒâ€˜ADIDO CONTROL PARA QUE TAMBIEN SE TRATEN ABONOS: INVTYP=2
     #FILTSUP = "ORIMOD=3 and INVTYP=1"
## AUREN - DSM - Abril 2013 - Compras - Visualización de facturas del módulo de compras
     FILTSUP = "ORIMOD=3 and(INVTYP=1 or INVTYP=2)"
     FILTSUP  = "(ORIMOD=3 OR ORIMOD = 6) and(INVTYP=1 or INVTYP=2)"
## AUREN - DSM - Abril 2013-  Compras - Visualización de facturas del módulo de compras


    FILTSUP += " AND(ZUS1=GUSER or ZUS2=GUSER "

    FILTROAUX= FILTSUP

    INICIO=0
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        If [F:XAUS]ZFLGACPFAC = 2
            ### Ver los que hay en la lista
            FILTSUP += "or ZDEP='" + [F:ZUD]ZDEP + "'"
        Else
            If INICIO = 0
                INICIO =1
                FILTSUP += "OR(ZDEP<>'" + [F:ZUD]ZDEP + "'"

            Else
                 ### Ver los que NO hay en la lista
                FILTSUP += "AND ZDEP<>'" + [F:ZUD]ZDEP + "'"
             Endif
        Endif
        If len(FILTSUP) > 238
            FILTSUP = FILTROAUX
            Infbox "No se puede cargar la informaciÃƒÂ³n de todos los departamentos asociados al usuario. Revise la configuraciÃƒÂ³n del usuario." Titled "Aviso"

            Break
        Else
            FILTROAUX= FILTSUP
        Endif
    Next

    ### Especifico 88
    ### Ver los que NO hay en la lista, pero NO hay departamentos en la lista -> Ver todos
    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO=0
         FILTSUP += "or (ZDEP<>'')"
    Endif

    FILTSUP +=")"

    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO =1
         FILTSUP +=")"
    Endif
  Endif
Return

######################################################################################
$FILGAUCHE2

  #Solicitud cambio 05.974.196 - Facturas aceptadas pendientes de pago - GAU_CHE7
  If currbox = "GAU_CHE7"
    FILGAUSUP(0) = "[F:PIH]ORIMOD=3 and ([F:PIH]INVTYP=1 or [F:PIH]INVTYP=2)"
    FILGAUSUP(0) += " AND ([F:PIH]ZUS1=GUSER or [F:PIH]ZUS2=GUSER"
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        FILGAUSUP(0) += " or [F:PIH]ZDEP= '" + [F:ZUD]ZDEP + "'"
    Next
    FILGAUSUP(0) +=")"
  Else
     # AÃ‘ADIDO CONTROL PARA QUE TAMBIEN SE TRATEN ABONOS : INVTYP=2
      FILGAUSUP(0) = "ORIMOD=3 and (INVTYP=1 or INVTYP=2)"
    #FILGAUSUP(0) = "ORIMOD=3 and INVTYP=1"

    FILGAUSUP(0) += " AND (ZUS1 = GUSER or ZUS2 = GUSER"
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2
        FILGAUSUP(0) += " or ZDEP = '" + [F:ZUD]ZDEP + "'"
    Next
    FILGAUSUP(0) +=")"
  Endif

Date FECHA
FECHA = date$ + 15
Char FECHACADENA
FECHACADENA = num$(day(FECHA)) + "/" + num$(month(FECHA)) + "/" + num$(year(FECHA))

    Case currbox
        When GBOXZA1
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2)"
        When GBOXZA2
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3)"
        When GBOXZA5
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]"
        When GBOXZA6
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]"
        When GBOXZA7
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2)"
        When GBOXZA8
            #Solicitud cambio 05.974.196
            #FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:BPS]ACEPURG=2"
            FILGAUSUP(0) += " and [F:PIH]ZACEPTA=4 and [F:DUD]AMTCUR<>[F:DUD]PAYCUR"
        When GBOXZA9
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2) and [F:BPR]FRAEMIREC=2"
    Endcase
Return
######################################################################################
$FILGAUCHE
Local Char FILTROAUX(250)
Local Integer LONGMAX
Local Integer INICIO

#AUREN Aceptación masiva solo si usuario Acepta o permiso Dpto, no si usuario solo PreAcepta
Local Char FILTROMASIVA(250)

# 27/06/2011 - AUREN - DSM - Assistencia 02.110.208 - Filtro por departamento
     Read [XAUS]CODUSR= GUSER: If fstat Raz [F:XAUS] : Endif
# 27/06/2011 - AUREN - DSM - Assistencia 02.110.208 - Filtro por departamento

    LONGMAX = 238
Date FECHA
FECHA = date$ + 15
Char FECHACADENA
FECHACADENA = num$(day(FECHA)) + "/" + num$(month(FECHA)) + "/" + num$(year(FECHA))

    Case currbox
        When GBOXZA1
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2)")
        When GBOXZA2
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3)")
        When GBOXZA5
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]")
        When GBOXZA6
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]")
        When GBOXZA7
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2)")
        When GBOXZA8
            #Solicitud cambio 05.974.196
            #LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:BPS]ACEPURG=2")
            LONGMAX = LONGMAX - len(" and [F:PIH]ZACEPTA=4 and [F:DUD]AMTCUR<>[F:DUD]PAYCUR")
        When GBOXZA9
            LONGMAX = LONGMAX - len(" and(ZACEPTA=1 or ZACEPTA=2) and [F:BPR]FRAEMIREC=2")
    Endcase

  #Solicitud cambio 05.974.196 - Facturas aceptadas pendientes de pago - GAU_CHE7
  If currbox = "GAU_CHE7"

    FILGAUSUP(0) = "([F:PIH]ORIMOD=3 OR [F:PIH]ORIMOD=6) and([F:PIH]INVTYP=1 or [F:PIH]INVTYP=2)"
    FILTROMASIVA = FILGAUSUP(0)

    FILGAUSUP(0) += " AND([F:PIH]ZUS1=GUSER or [F:PIH]ZUS2=GUSER "
    FILTROMASIVA += " AND([F:PIH]ZUS2=GUSER "

    FILTROAUX= FILGAUSUP(0)
    INICIO=0
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2

         If [F:XAUS]ZFLGACPFAC = 2
            ### Ver los que hay en la lista
            FILGAUSUP(0) += "or [F:PIH]ZDEP='" + [F:ZUD]ZDEP + "'"
            # 15/03/2013 SOLO VISUALIZACIÓN: permiso Dpto no permite aceptación masiva
            If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA += "or [F:PIH]ZDEP='" + [F:ZUD]ZDEP + "'"  :  Endif
         Else
            If INICIO = 0
                INICIO =1
                FILGAUSUP(0)+= "OR([F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"
                If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA+= "OR([F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"  :  Endif
            Else
                 ### Ver los que NO hay en la lista
                FILGAUSUP(0)+= "AND [F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"
                If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA+= "AND [F:PIH]ZDEP<>'" + [F:ZUD]ZDEP + "'"  :  Endif
            Endif
         Endif

         If len(FILGAUSUP(0)) > LONGMAX
               FILGAUSUP(0) = FILTROAUX
                Infbox "No se puede cargar la información de todos los departamentos asociados al usuario. Revise la configuración del usuario." Titled "Aviso"
                Break
            Else
                FILTROAUX= FILGAUSUP(0)
            Endif
    Next
    ### Especifico 88
    ### Ver los que NO hay en la lista, pero NO hay departamentos en la lista -> Ver todos
    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO=0
         FILGAUSUP(0) += "or ([F:PIH]ZDEP<>'')"
         If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA += "or ([F:PIH]ZDEP<>'')"  :  Endif
    Endif


  Else


     # AÃƒâ€˜ADIDO CONTROL PARA QUE TAMBIEN SE TRATEN ABONOS : INVTYP=2
     #FILGAUSUP(0) = "ORIMOD=3 and INVTYP=1"
## AUREN - DSM - Abril 2013 - Compras - Visualización de facturas del módulo de compras
#     FILGAUSUP(0) = "ORIMOD=3 and(INVTYP=1 or INVTYP=2)"
     FILGAUSUP(0) = "(ORIMOD=3 OR ORIMOD = 6) and(INVTYP=1 or INVTYP=2)"
## AUREN - DSM - Abril 2013 - Compras - Visualización de facturas del módulo de compras

    #AUREN Aceptación masiva solo si usuario Acepta o permiso Dpto, no si usuario solo PreAcepta
    FILTROMASIVA = FILGAUSUP(0)

    FILGAUSUP(0) += " AND(ZUS1=GUSER or ZUS2=GUSER "
    FILTROMASIVA += " AND(ZUS2=GUSER "


    FILTROAUX= FILGAUSUP(0)
    INICIO=0
    For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2

         If [F:XAUS]ZFLGACPFAC = 2
            ### Ver los que hay en la lista
            FILGAUSUP(0) += "or ZDEP='" + [F:ZUD]ZDEP + "'"
            # 15/03/2013 SOLO VISUALIZACIÓN: permiso Dpto no permite aceptación masiva
            If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA += "or ZDEP='" + [F:ZUD]ZDEP + "'"  :  Endif
         Else
            If INICIO = 0
                INICIO =1
                FILGAUSUP(0)+= "OR(ZDEP<>'" + [F:ZUD]ZDEP + "'"
                If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA+= "OR(ZDEP<>'" + [F:ZUD]ZDEP + "'"  :  Endif
            Else
                 ### Ver los que NO hay en la lista
                FILGAUSUP(0)+= "AND ZDEP<>'" + [F:ZUD]ZDEP + "'"
                If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA+= "AND ZDEP<>'" + [F:ZUD]ZDEP + "'"  :  Endif
            Endif
         Endif

         If len(FILGAUSUP(0)) > LONGMAX
               FILGAUSUP(0) = FILTROAUX
                Infbox "No se puede cargar la informaciÃƒÂ³n de todos los departamentos asociados al usuario. Revise la configuraciÃƒÂ³n del usuario." Titled "Aviso"

                Break
            Else
                FILTROAUX= FILGAUSUP(0)
            Endif
    Next
    ### Especifico 88
    ### Ver los que NO hay en la lista, pero NO hay departamentos en la lista -> Ver todos
    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO=0
         FILGAUSUP(0) += "or (ZDEP<>'')"
         If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA += "or (ZDEP<>'')"  :  Endif
    Endif
  Endif

    FILGAUSUP(0) +=")"
    FILTROMASIVA +=")"

    If [F:XAUS]ZFLGACPFAC <> 2 and INICIO =1
         FILGAUSUP(0)+=")"
         If [F:XAUS]ZFLGVISUAL <> 2  :  FILTROMASIVA+=")"  :  Endif
    Endif

    ### AceptaciÃ³n masiva : SÃ³lo Pendientes y preaceptadas
    Call INICIALIZAR_LISTA_FACTURAS_SELECCIONADAS

Date FECHA
FECHA = date$ + 15
Char FECHACADENA
FECHACADENA = num$(day(FECHA)) + "/" + num$(month(FECHA)) + "/" + num$(year(FECHA))

    Case currbox
        When GBOXZA1
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2)"
        When GBOXZA2
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3)"
        When GBOXZA4
            ### AceptaciÃ³n masiva : SÃ³lo Pendientes y preaceptadas
            #FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=3)"
            # AUREN Aceptacion masiva solo si usuario Acepta o acceso a Dpto, no si solo PreAcepta
            FILTROMASIVA += " and(ZACEPTA=1 or ZACEPTA=3)"
            FILGAUSUP(0)=FILTROMASIVA
        When GBOXZA5
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]"
        When GBOXZA6
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:DUD]DUDDAT<=[" + FECHACADENA + "]"
        When GBOXZA7
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2)"
        When GBOXZA8
            #Solicitud cambio 05.974.196
            #FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2 or ZACEPTA=3) and [F:BPS]ACEPURG=2"
            FILGAUSUP(0) += " and [F:PIH]ZACEPTA=4 and [F:DUD]AMTCUR<>[F:DUD]PAYCUR"
        When GBOXZA9
            FILGAUSUP(0) += " and(ZACEPTA=1 or ZACEPTA=2) and [F:BPR]FRAEMIREC=2"

    Endcase
     ### AceptaciÃ³n masiva : SÃ³lo Pendientes y preaceptadas
    Call CAMPOSNOEDITABLES
Return



$LIENS
#AUREN - DSM - 01/02/2013 EA104- Ampliación campos aceptación facturas
If !GIMPORT
 Filter [DUD] Where NUM=[M:ZAF0]NUM
 Read [DUD]DUD1 First
 If !fstat
  [M:ZAF0]DUDDAT  = [F:DUD]DUDDAT
 Endif
 Filter [DUD]
 Actzo [M:ZAF0]DUDDAT
Endif
#AUREN - DSM - 01/02/2013 EA104- Ampliación campos aceptación facturas
    Local Char CRITERE(250)

    If [M:ZAF1]ZACEPTA = 4 or [M:ZAF1]ZACEPTA = 5
        Grizo [M:ZAF1]ZDEP
        Grizo [M:ZAF1]ZACEPTA
    Else
        Actzo [M:ZAF1]ZDEP
        Actzo [M:ZAF1]ZACEPTA
    Endif

# AUREN - DSM - 02/04/2012 EA95. Deshacer aceptación de factura
# Se habilita el campo de estado en caso de Aceptación, para poder deshacer
    If [M:ZAF1]ZACEPTA = 4
        # Se consulta si se ha gestionado algun vencimiento
        Local Integer ZGESTIONADOS
        ZGESTIONADOS = 0
# AUREN - PU9
#        Filter [DUD] Where NUM = [M:ZAF0]NUM and (TMPCUR<>0 or TMPLOC<>0 or TMPRPT<>0 or PAYCUR<>0 or PAYLOC<>0 or PAYRPT<>0)
        Filter [DUD] Where NUM = [M:ZAF0]NUM and (TMPCUR<>0 or TMPLOC<>0 or PAYCUR<>0 or PAYLOC<>0)
# AUREN - PU9
        For [DUD]
            ZGESTIONADOS = ZGESTIONADOS + 1
        Next
        Filter [DUD]
        # Se consulta el usuario que realiza la operación
        Local Integer ZUSUARIOVAL
        If [F:XAUS]ZFLGACPFAC = 1
            ZUSUARIOVAL = 1
            # Si es el usuario que tiene acceso por departamentos no tiene acceso
            For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and [F:XAUS]ZFLGACPFAC = 1
                ZUSUARIOVAL = 0
            Next
        Else
            ZUSUARIOVAL = 0
        Endif
        # Si es el usuario que ha realizado la aceptación
        If [M:ZAF1]ZUS2 = GUSER
            ZUSUARIOVAL = 1
        Endif

        # Solo en el caso que no exista ninguno gestionado y el usuario sea valido
        If ZGESTIONADOS = 0 and ZUSUARIOVAL = 1
            Actzo [M:ZAF1]ZACEPTA
        Endif
    Endif
# AUREN - DSM - 02/04/2012 EA95. Deshacer aceptación de factura

    Grizo [M:ZAF1]ZMOTIVD
    Grizo [M:ZAF1]ZMOTIVR

    CRITERE = "[AUD]TBL = 'PINVOICE' and [AUD]ID1 = [M:ZAF0]NUM"

     ##### 18/02/2001    AUDITORIA
    ############### INICIO ELIMINAR
    # CRITERE = "[AUD]TBL = 'PINVOICE' and [AUD]ID1 = [M:ZAF0]NUM"

    # Filter [AUD] Where evalue(CRITERE) Order By Key CLE=[F:AUD]SEQ
    #  NOL = 0
    #For [AUD]CLE
    #     NOL += 1
    #     nolign = NOL
    #     [M:ZAF2] = [F:AUD]
    # Next
    #[M:ZAF2]NBLIG = NOL
    ############### FIN ELIMINAR


# 20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rechazo factura
     ###### 14/02/11 Solo se introduce motivo rechazo si la factura pasa a estado Rechazado
#    If [M:ZAF1]ZACEPTA = 5
#        Actzo [M:ZAF1]ZMOTIVR
#    Else
#        Grizo [M:ZAF1]ZMOTIVR
#        #Raz [M:ZAF1]ZMOTIVR
#    Endif
    If [M:ZAF1]ZACEPTA = 5
        Grizo [M:ZAF1]ZMOTIVR
    Endif
# 20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rechazo factura

     ###### 14/02/11 Solo se introduce motivo retenido si la factura pasa a estado Retenido
    If [M:ZAF1]ZACEPTA =2
        Actzo [M:ZAF1]ZMOTIVRET
    Else
        Grizo [M:ZAF1]ZMOTIVRET
       # Raz [M:ZAF1]ZMOTIVRET
    Endif

    Call CARGAR_RUTA_DOCUMENTO_ADJUNTO

    ##### 22/02/2001    AUDITORIA
    Call CARGAR_AUDITORIA

    Call CARGAR_HISTORICOS # 22/06/2011 Especific 71
    ### AceptaciÃ³n masiva : SÃ³lo Pendientes y preaceptadas
    Call CAMPOSNOEDITABLES

#AUREN - DSM - Abril 2013 - Compras - Visualización según origen
    If [M:ZAF0]ORIMOD = 6 Then
        [M:ZAF0]ZORIG = "PIH"
    Else
        [M:ZAF0]ZORIG = "BIS"
    Endif
#AUREN - DSM - Abril 2013 - Compras - Visualización según origen
# AUREN - PU9
     Raz [M:ZAF1]ZMOTIVR
     Raz  [M:ZAF1]ZMOTIVD
     Raz  [M:ZAF1]ZMOTIVRET
     Raz  [M:ZAF1]ZOBS
     Raz  [M:ZAF1]ZINCACEP
    Read [F:ZPX]ZPX0=[M:ZAF0]NUM
    If fstat=0
      [M:ZAF1]ZMOTIVR = [F:ZPX]ZMOTIVR
      [M:ZAF1]ZMOTIVD = [F:ZPX]ZMOTIVD
      [M:ZAF1]ZMOTIVRET =[F:ZPX]ZMOTIVRET
      [M:ZAF1]ZOBS = [F:ZPX]ZOBS
      [M:ZAF1]ZINCACEP = [F:ZPX]ZINCACEP
      [M:ZAF1]ZOBSLIQ = [F:ZPX]ZOBSLIQ
      Affzo [M:ZAF1]ZMOTIVR
      Affzo [M:ZAF1]ZMOTIVD
      Affzo [M:ZAF1]ZMOTIVRET
      Affzo [M:ZAF1]ZOBS
      Affzo [M:ZAF1]ZINCACEP
      Affzo [M:ZAF1]ZOBSLIQ
    Endif
# AUREN - PU9

Return
