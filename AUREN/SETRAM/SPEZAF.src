#AUREN - PU9
$APRES_CRE
  # AUREN 5.788.114
  # Gosub ZPINVOICEAUX_MANT From SPEBIS
  Gosub ZPINVOICEAUX_ZAF
Return
#AUREN - PU9

$ZPINVOICEAUX_ZAF
#AUREN - PU9
#Crea los datos de ZPINVOICEAUX
  If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
  Raz [F:ZPX]
  Read [PIH]PIH0 = [M:ZAF0]NUM : If fstat Raz [F:PIH] : Endif

  Readlock [ZPX]ZPX0 =[F:PIH]NUM
  Local Integer V_STA
  V_STA = fstat
  [F:ZPX]INVTYP = [F:PIH]INVTYP
  [F:ZPX]NUM = [F:PIH]NUM
  #Acceptació factures
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVR = [M:ZAF1]ZMOTIVR: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVD = [M:ZAF1]ZMOTIVD: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVRET = [M:ZAF1]ZMOTIVRET: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZOBS = [M:ZAF1]ZOBS: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZOBSLIQ = [M:ZAF1]ZOBSLIQ: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZINCACEP = [M:ZAF1]ZINCACEP: Endif

  If V_STA
   If dim([F:ZPX]CREDAT)>0 : [F:ZPX]CREDAT = date$ : Endif
   If dim([F:ZPX]CREUSR)>0 : [F:ZPX]CREUSR = GUSER : Endif
   If dim([F:ZPX]CRETIM)>0 : [F:ZPX]CRETIM = time  : Endif
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = [0/0/0] : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = "" : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = 0  : Endif
   Write [ZPX]
  Else
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = date$ : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = GUSER : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = time  : Endif
   Rewrite [ZPX]
  Endif
  If fstat
   GOK = 0
  Endif
Return
