## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura
$LANZAR_IMPORT_ZBIS
#Compras Generar abono si rechazo de factura
    Openo FICHERO,0 Using [XBIS]

    For [PIH]PIH0 Where NUM = [M:ZAF0]NUM

        XNUMREG = "R-" + num$([F:PIH]ZNUMREG)

    ###########################################################################################################
    ### AUREN Específico 28 - Si rechazo Factura generar Abono; Si rechazo Abono generar Factura  (03/08/2011)
    #   Se pasa al fichero el valor de XTIPOFACTURA en vez de GZTYPFAC
    ###########################################################################################################
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
##        Wrseq "T" + LSEP + XTIPOFACTURA + LSEP + [PIH]BPR + LSEP + [F:PIH]CPY + LSEP + [F:PIH]FCY
##&        + LSEP + date$ + LSEP + [F:PIH]CUR + LSEP + [F:PIH]PTE + LSEP + [F:PIH]VAC
##&        + LSEP + [F:PIH]ZDEP + LSEP + "4" + LSEP + "2" + LSEP + XNUMREG  + LSEP + [F:PIH]ZUS1
##&        + LSEP + [F:PIH]ZUS2 + LSEP + "4" + LSEP + [F:PIH]NUM + LSEP + [F:PIH]BPRPAY
##&        + LSEP + [F:PIH]ACCDAT + LSEP + [F:PIH]STRDUDDAT + LSEP + [F:PIH]NUM
##&        + LSEP + [F:PIH]BPRSAC + chr$(013) Using [XBIS]
 #&        + LSEP + [F:PIH]STRDUDDAT + chr$(013) Using [XBIS]
#AUREN - PU9
## Correccio Compras X3 -> Estat Setram=Rechazado(5); Estat X3=Retenido(2)
#        Wrseq "T" + LSEP + XTIPOFACTURA + LSEP + [PIH]BPR + LSEP + [F:PIH]CPY + LSEP + [F:PIH]FCY
#&        + LSEP + date$ + LSEP + [F:PIH]CUR + LSEP + num$([F:PIH]RATCUR) + LSEP + num$([F:PIH]RATRPT) + LSEP + ZPTEDEFAULT + LSEP + [F:PIH]VAC
#&        + LSEP + [F:PIH]ZDEP + LSEP + "5" + LSEP + "2" + LSEP + XNUMREG  + LSEP + [F:PIH]ZUS1
#&        + LSEP + [F:PIH]ZUS2 + LSEP + "2" + LSEP + [F:PIH]NUM + LSEP + [F:PIH]BPRPAY
#&        + LSEP + [F:PIH]ACCDAT + LSEP + date$ + LSEP + date$ + LSEP + [F:PIH]NUM
#&        + LSEP + [F:PIH]BPRSAC + chr$(013) Using [XBIS]
# #&        + LSEP + [F:PIH]STRDUDDAT + chr$(013) Using [XBIS]
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
# Correccio Compras X3 -> Estat Setram=Rechazado(5); Estat X3=Retenido(2)
        Wrseq "T" + LSEP + XTIPOFACTURA + LSEP + [PIH]BPR + LSEP + [F:PIH]CPY + LSEP + [F:PIH]FCY
&        + LSEP + date$ + LSEP + [F:PIH]CUR + LSEP + num$([F:PIH]RATMLT) + LSEP + num$([F:PIH]RATDIV) + LSEP + ZPTEDEFAULT + LSEP + [F:PIH]VAC
&        + LSEP + [F:PIH]ZDEP + LSEP + "5" + LSEP + "2" + LSEP + XNUMREG  + LSEP + [F:PIH]ZUS1
&        + LSEP + [F:PIH]ZUS2 + LSEP + "2" + LSEP + [F:PIH]NUM + LSEP + [F:PIH]BPRPAY
&        + LSEP + [F:PIH]ACCDAT + LSEP + date$ + LSEP + date$ + LSEP + [F:PIH]NUM
&        + LSEP + [F:PIH]BPRSAC + chr$(013) Using [XBIS]
 #&        + LSEP + [F:PIH]STRDUDDAT + chr$(013) Using [XBIS]
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
# AUREN - PU9

        For [PIL]PIL0 Where NUM = [F:PIH]NUM

# 21/06/2011 - AUREN - DSM - Assistencia 02.106.517 - Cálculo de impuestos
#            Wrseq "L" + LSEP + num$([F:PIL]LIG) + LSEP + [F:PIL]FCYLIN + LSEP + [F:PIL]SAC + LSEP + [F:PIL]ACC
#&            + LSEP + [F:PIL]BPRLIN + LSEP + num$([F:PIL]AMTNOTLIN) + LSEP + [F:PIL]CNA
#&            + LSEP + [F:PIL]DSP + LSEP + [F:PIL]VAT + chr$(013) Using [XBIS]
# Se han añadido los campos de linea AMTVAT, DEDVAT, TAX1, AMTTAX1, DEDTAX1, TAX2, AMTTAX2, DEDTAX2
# AUREN - PU9
#            Wrseq "L" + LSEP + num$([F:PIL]LIG) + LSEP + [F:PIL]FCYLIN + LSEP + [F:PIL]SAC + LSEP + [F:PIL]ACC
#&            + LSEP + [F:PIL]BPRLIN + LSEP + num$([F:PIL]AMTNOTLIN) + LSEP + [F:PIL]CNA
#&            + LSEP + [F:PIL]DSP + LSEP + [F:PIL]VAT
#&            + LSEP + num$([F:PIL]AMTVAT) + LSEP + num$([F:PIL]DEDVAT)
#&            + LSEP + [F:PIL]TAX1 + LSEP + num$([F:PIL]AMTTAX1) + LSEP + num$([F:PIL]DEDTAX1)
#&            + LSEP + [F:PIL]TAX2 + LSEP + num$([F:PIL]AMTTAX2) + LSEP + num$([F:PIL]DEDTAX2)
#&            + chr$(013) Using [XBIS]
## 21/06/2011 - AUREN - DSM - Assistencia 02.106.517 - Cálculo de impuestos
            Wrseq "L" + LSEP + num$([F:PIL]LIG) + LSEP + [F:PIL]FCYLIN + LSEP + [F:PIL]SAC
&            + LSEP + [F:PIL]ACC(0) + LSEP + [F:PIL]ACC(1) + LSEP + [F:PIL]ACC(2) + LSEP + [F:PIL]ACC(3) + LSEP + [F:PIL]ACC(4)
&            + LSEP + [F:PIL]ACC(5) + LSEP + [F:PIL]ACC(6) + LSEP + [F:PIL]ACC(7) + LSEP + [F:PIL]ACC(8) + LSEP + [F:PIL]ACC(9)
&            + LSEP + [F:PIL]BPRLIN + LSEP + num$([F:PIL]AMTNOTLIN)
&            + LSEP + [F:PIL]COA(0) + LSEP + [F:PIL]COA(1) + LSEP + [F:PIL]COA(2) + LSEP + [F:PIL]COA(3) + LSEP + [F:PIL]COA(4)
&            + LSEP + [F:PIL]COA(5) + LSEP + [F:PIL]COA(6) + LSEP + [F:PIL]COA(7) + LSEP + [F:PIL]COA(8) + LSEP + [F:PIL]COA(9)
&            + LSEP + [F:PIL]LED(0) + LSEP + [F:PIL]LED(1) + LSEP + [F:PIL]LED(2) + LSEP + [F:PIL]LED(3) + LSEP + [F:PIL]LED(4)
&            + LSEP + [F:PIL]LED(5) + LSEP + [F:PIL]LED(6) + LSEP + [F:PIL]LED(7) + LSEP + [F:PIL]LED(8) + LSEP + [F:PIL]LED(9)
&            + LSEP + [F:PIL]DSP + LSEP + [F:PIL]VAT
&            + LSEP + num$([F:PIL]AMTVAT) + LSEP + num$([F:PIL]DEDVAT)
&            + LSEP + [F:PIL]TAX1 + LSEP + num$([F:PIL]AMTTAX1) + LSEP + num$([F:PIL]DEDTAX1)
&            + LSEP + [F:PIL]TAX2 + LSEP + num$([F:PIL]AMTTAX2) + LSEP + num$([F:PIL]DEDTAX2)
&            + chr$(013) Using [XBIS]
# AUREN - PU9


            For [PIA]PIA0 Where NUM = [F:PIL]NUM and LIG = [F:PIL]LIG

# AUREN - PU9
#                Wrseq "A" + LSEP + num$([F:PIA]ANALIG) + LSEP + [F:PIA]CCE + LSEP + [F:PIA]CCE(1)
#&                + LSEP + [F:PIA]CCE(2) + LSEP + [F:PIA]CCE(3) + LSEP + [F:PIA]CCE(4)
#&                + LSEP + [F:PIA]CCE(5) + LSEP + [F:PIA]CCE(6) + LSEP + [F:PIA]CCE(7)
#&                + LSEP + [F:PIA]CCE(8) + LSEP + [F:PIA]CNA
#&                + LSEP + num$([F:PIA]AMT) + chr$(013) Using [XBIS]
                Wrseq "A" + LSEP + num$([F:PIA]ANALIG) + LSEP + [F:PIA]CCE + LSEP + [F:PIA]CCE(1)
&                + LSEP + [F:PIA]CCE(2) + LSEP + [F:PIA]CCE(3) + LSEP + [F:PIA]CCE(4)
&                + LSEP + [F:PIA]CCE(5) + LSEP + [F:PIA]CCE(6) + LSEP + [F:PIA]CCE(7)
&                + LSEP + [F:PIA]CCE(8)
&                + LSEP + [F:PIA]DIE + LSEP + [F:PIA]DIE(1)
&                + LSEP + [F:PIA]DIE(2) + LSEP + [F:PIA]DIE(3) + LSEP + [F:PIA]DIE(4)
&                + LSEP + [F:PIA]DIE(5) + LSEP + [F:PIA]DIE(6) + LSEP + [F:PIA]DIE(7)
&                + LSEP + [F:PIA]DIE(8)
&                + LSEP + [F:PIA]COA + LSEP + [F:PIA]COA(1)
&                + LSEP + [F:PIA]COA(2) + LSEP + [F:PIA]COA(3) + LSEP + [F:PIA]COA(4)
&                + LSEP + [F:PIA]COA(5) + LSEP + [F:PIA]COA(6) + LSEP + [F:PIA]COA(7)
&                + LSEP + [F:PIA]COA(8) + LSEP + [F:PIA]COA(9)
&                + LSEP + [F:PIA]ACC + LSEP + [F:PIA]ACC(1)
&                + LSEP + [F:PIA]ACC(2) + LSEP + [F:PIA]ACC(3) + LSEP + [F:PIA]ACC(4)
&                + LSEP + [F:PIA]ACC(5) + LSEP + [F:PIA]ACC(6) + LSEP + [F:PIA]ACC(7)
&                + LSEP + [F:PIA]ACC(8) + LSEP + [F:PIA]ACC(9)
&                + LSEP + num$([F:PIA]AMT) + chr$(013) Using [XBIS]
# AUREN - PU9

            Next ## Bucle PIA

        Next ## Bucle PIL

        For [DUD]DUD0 Where ACCNUM = [F:PIH]ACCNUM

# 15/01/2015 AUREN Asistencia 5.458.128 Estado autorización pago = Retenido (2)

            Wrseq "E" + LSEP + num$([F:DUD]DUDLIG) + LSEP + [F:DUD]DUDDAT + LSEP + [F:DUD]PAM
&            + LSEP + num$([F:DUD]AMTCUR) + LSEP + "2" + chr$(013) Using [XBIS]

        Next ## Bucle DUD

    Next ## Bucle PIH

    Openo Using [XBIS]

    ###--- FunciÃ³n de llamada al modelo de importaciÃ³n ---###
    Call IMPSILEN ('ZBIS',FICHERO)

  # LPARDO. 210813. Lanzar creación documento rechazo
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEZAF
  Local Char ZPARSPEZAF1(250) : ZPARSPEZAF1 =func AFNC.PARAM("ZPARSPEZAF","")
  Call CALLOUTHTTP (ZPARSPEZAF1 + nomap(0) + "/" + GUSER + "/" + [M:ZAF0]NUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################


Return
## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura

######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH)
    Value Char MODELE
    Value Char NOMFICH
    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")
    Local Char MESSAGE(100)
    Local Char UUSARIO(100)

#    Call OUVRE_TRACE("GeneraciÃ³n de Abonos") From LECFIC

    Call ECR_TRACE("Importación de fichero",0) From GESECRAN    # AUREN - DSM - 201506 - 05.508.597 - Traza
    Call ECR_TRACE(NOMFICH,0) From GESECRAN    # AUREN - DSM - 201506 - 05.508.597 - Traza

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ

    If GERRTRACE <> 0
        GYNUM=0
        Call ECR_TRACE("Error importando fichero",1) From GESECRAN    # AUREN - DSM - 201506 - 05.508.597 - Traza
        XERROR = 2
    Endif
#    Call FERME_TRACE From LECFIC
#    Call LEC_TRACE From LECFIC
End

######################################################################################
######################################################################################
######################################################################################
## 14/02/11 Obligatorio si la factura pasa a estado Retenido
######################################################################################
Subprog C_ZMOTIVRET(VALEUR)
Variable Char    VALEUR()

    If VALEUR = ""
        GERR=1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End


