#######################################################################
# AUREN - DSM - 22/06/2011
# Especific 71. Aceptación factura cambio Observaciones y retenciones
#
# Se han de cargar los datos en la pestaña de históricos
#######################################################################
# Se ha creado la actividad Z33
#
# Cargar la pantalla con el detalle de las motivo de retención
#######################################################################
Subprog CARGAR_DETALLES_HIST_MRT
    If clalev([F:ZHR])=0 : Local File ZHPINMRET [ZHR] : Endif

    Filter [ZHR] Where ZHRNUM = [M:ZAF0]NUM and ZHRNHIST = (nolign-1)
    For [ZHR]
        [M:ZAF7]ZHOOBS = [F:ZHR]ZHRMRET
    Next
    Filter [ZHR]
    Affzo [ZAF7]
End
#######################################################################

$MODIF


Return
######################################################################################
$APRES_MOD
    Gosub RELIT From GOBJSUB
Return
######################################################################################
$STYLE
  #AUREN - 5.795.161 - Corrección: no se muestan doc adjuntos de facturas de compra
  #ABREV = "BIS"
  If [M:ZAF0]ORIMOD = 6 Then
    ABREV = "PIH"
  Else
    ABREV = "BIS"
  Endif
Return
######################################################################################
## ACCIONES DE PANTALLA
######################################################################################
Subprog AM_ZDEP(VALEUR)
Variable Char    VALEUR()

    Local Integer PERMISOS_OK : PERMISOS_OK = 0

    ## Especifico 88
    Read [XAUS]CODUSR= GUSER: If fstat Raz [F:XAUS] : Endif

    ## 21/02/2011
    If [F:XAUS]ZFLGACPFAC = 2
         ### Si departamento en lista usuario/Departamento
        For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP = [M:ZAF1]ZDEP
            PERMISOS_OK = 2
        Next
    Else
         ### Si departamento NO en lista usuario/Departamento
        #For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP <> [M:ZAF1]ZDEP
        #    PERMISOS_OK = 2
        #Next

        ## Especifico 88
        PERMISOS_OK = 2
        For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP = [M:ZAF1]ZDEP
            PERMISOS_OK = 0
        Next

    Endif
    ###  FIN

    If GUSER <> [M:ZAF1]ZUS2 and GUSER <> [M:ZAF1]ZUS1 and PERMISOS_OK <> 2
        GERR=1
        GMESSAGE = "No tiene permisos suficientes"
        mkstat = 2
        End
    Endif

    Read [ZDT]ZDP0 = VALEUR : If fstat Raz [F:ZDT] : Endif
    [M:ZAF1]ZUS1 = [F:ZDT]ZUS1
    [M:ZAF1]ZUS2 = [F:ZDT]ZUS2

    Affzo [M:ZAF1]ZUS1
    Affzo [M:ZAF1]ZUS2
    Actzo [M:ZAF1]ZMOTIVD
    Raz [M:ZAF1]ZMOTIVD
End

######################################################################################
Subprog C_ZMOTIVD(VALEUR)
Variable Char    VALEUR()

    If VALEUR = ""
        GERR=1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End
######################################################################################
Subprog AM_ZACEPTA(VALEUR)
Variable Integer VALEUR
    Local Integer PERMISOS_OK : PERMISOS_OK = 0

    ## Especifico 88
    Read [XAUS]CODUSR= GUSER: If fstat Raz [F:XAUS] : Endif

    ## 21/02/2011
    ## SOLO VISUALIZACIÓN: NO PUEDE REALIZAR CAMBIOS POR PERMISO A DEPARTAMENTEO 15/03/2013
    If [F:XAUS]ZFLGACPFAC = 2 and [F:XAUS]ZFLGVISUAL <> 2
        ### Si departamento en lista usuario/Departamento
        For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP = [M:ZAF1]ZDEP
            PERMISOS_OK = 2
        Next

    Else
         ### Si departamento NO en lista usuario/Departamento
        #For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP <> [M:ZAF1]ZDEP
        #    PERMISOS_OK = 2
        #Next

        ## Especifico 88
        PERMISOS_OK = 2
        For [ZUD] Where ZUSR = GUSER and ZACTIVO = 2 and ZDEP = [M:ZAF1]ZDEP
            PERMISOS_OK = 0
        Next
        If [F:XAUS]ZFLGVISUAL = 2
            PERMISOS_OK = 0
        Endif


    Endif
    ###  FIN


    If GUSER <> [M:ZAF1]ZUS2 and GUSER <> [M:ZAF1]ZUS1 and PERMISOS_OK <> 2
        GERR=1
        GMESSAGE = "No tiene permisos suficientes"
        mkstat = 2
        End
    Elsif GUSER <> [M:ZAF1]ZUS2 and GUSER = [M:ZAF1]ZUS1 and PERMISOS_OK <> 2
        If VALEUR >= 4
            GERR=1
            GMESSAGE = "No tiene permisos suficientes"
            mkstat = 2
            End
        Endif
    Endif

    If VALEUR = 5
## AUREN - DSM - Junio 2013 - Equivalencia estados
#        [M:ZAF1]PAZ = 4
        [M:ZAF1]PAZ = 2
## AUREN - DSM - Junio 2013 - Equivalencia estados
    Else
        [M:ZAF1]PAZ = VALEUR
    Endif

    Affzo [M:ZAF1]PAZ

    ###### 14/02/11 Solo se introduce motivo rechazo si la factura pasa a estado Rechazado
    #If VALEUR = 5 or VALEUR = 2
    If VALEUR = 5
        Actzo [M:ZAF1]ZMOTIVR
        #Raz [M:ZAF1]ZMOTIVR
    Else
        Grizo [M:ZAF1]ZMOTIVR
        #Raz [M:ZAF1]ZMOTIVR
    Endif
     ###### 14/02/11 Solo se introduce motivo retenido si la factura pasa a estado Retenido

    If VALEUR = 2
        Actzo [M:ZAF1]ZMOTIVRET
        #Raz [M:ZAF1]ZMOTIVRET
    Else
        Grizo [M:ZAF1]ZMOTIVRET
        #Raz [M:ZAF1]ZMOTIVRET
    Endif

    ### FIN
End
######################################################################################
Subprog C_ZMOTIVR(VALEUR)
Variable Char    VALEUR()
    If VALEUR = ""
        GERR=1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End
######################################################################################
$DEBUT
# AUREN - DSM - 22/06/2011 - Especific 71
If GACTION ="ZAUDIT"
# AUREN - DSM - 22/06/2011 - Especific 71
    Local Integer SEQUENCE
#    SEQUENCE = [M:ZAF2]SEQ(nolign-1)
    SEQUENCE = [M:ZAF2]SEQ
    nolign = 0
    For [AUL]AUL0 Where SEQ=SEQUENCE
        nolign += 1
        [M:ZAF3] = [F:AUL]
    Next
    If nolign=0
        Call MESSAGE(mess(40,127,1)) From GESECRAN : # Pas de dÃ©tail
        FIN = 1
    Else
        [M:ZAF3]NBLIG = nolign
        Affzo [ZAF3]
    Endif

# AUREN - DSM - 22/06/2011 - Especific 71
Endif

If GACTION = "ZHOBS"
    Call CARGAR_DETALLES_HIST_OBS
Endif

If GACTION = "ZHMRT"
    Call CARGAR_DETALLES_HIST_MRT
Endif
# AUREN - DSM - 22/06/2011 - Especific 71

Return
######################################################################################
## FunciÃ³n de lanzar Import de Abonos de Facturas
######################################################################################
$LANZAR_IMPORT
    Local    Integer  YERROR     : YERROR = 0
    Local    Char     RUTA(250)
    Local    Char     LSEP       : LSEP = "|"
    Local    Char     FICHERO (250)
    Local    Char     XNUMREG

    If clalev([F:APX])<=0 : Local File APARIMPEXP [APX] : Endif
    If clalev([F:TPV])<=0 : Local File TABPIVTYP  [TPV] : Endif


    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##

    Read [APX]APX0 = 'REPIMPDEF'

    RUTA = [F:APX]DIRECTORY
#AUREN - PU9
    RUTA = ctrans(RUTA,"[","")
    RUTA = ctrans(RUTA,"]","")
    If clalev([F:AVL])<=0 : Local File AVOLUME  [AVL] : Endif
    Read [AVL]CODE = RUTA
    If !fstat
      RUTA = [F:AVL]ROOT
    Endif
#AUREN - PU9
    If RUTA = ""
        Call ERREUR(mess(121,141,1)) From GESECRAN
        Return
    Endif

#AUREN - PU9
#    RUTA = left$(RUTA,len(RUTA)-1)
#AUREN - PU9

    ###########################################################################################################
    ### AUREN Específico 28 - Si rechazo Factura generar Abono; Si rechazo Abono generar Factura  (03/08/2011)
    ###########################################################################################################
    # Se Rechaza factura -> generar abono
    If [F:PIH]INVTYP = 1
        Read [TPV]TPV0 = GZTYPFAC
        If fstat
            Raz [F:TPV]
            Call ERREUR(mess(54,119,1)) From GESECRAN
            XERROR =2
            Return
        Else
            If [F:TPV]INVTYP <> 2
                Raz [F:TPV]
                Call ERREUR("Tipo de factura prohibido",1) From GESECRAN
                XERROR =2
                Return
            Else
                XTIPOFACTURA = GZTYPFAC
            Endif
        Endif
    Else
        # Se Rechaza abono -> generar factura
        If [F:PIH]INVTYP = 2
            Read [TPV]TPV0 = GZTYPABO
            If fstat
                Raz [F:TPV]
                Call ERREUR(mess(54,119,1)) From GESECRAN
                XERROR =2
                Return
            Else
                If [F:TPV]INVTYP <> 1
                    Raz [F:TPV]
                    Call ERREUR("Tipo de factura prohibido",1) From GESECRAN
                    XERROR =2
                    Return
                Else
                    XTIPOFACTURA = GZTYPABO
                Endif
            Endif
        Endif
    Endif
    ###########################################################################################################


    ### AUREN Específico 28 (codigo anterior 03/08/2011)
#    Read [TPV]TPV0 = GZTYPFAC
#    If fstat
#        Raz [F:TPV]
#        Call ERREUR(mess(54,119,1)) From GESECRAN
#        XERROR =2
#        Return
#    Else
#        If [F:TPV]INVTYP <> 2
#            Raz [F:TPV]
#            Call ERREUR("Tipo de factura prohibido",1) From GESECRAN
#            XERROR =2
#            Return
#        Endif
#    Endif

    adxium = 50        # el fichero es ascii

# Asistencia 05.680.432
#    FICHERO = filpath(RUTA,num$(adxuid(1))+"_ABO","TXT")
    FICHERO = filpath(RUTA,num$(adxuid(1))+date$+ctrans(num$(time$),":","")+"_ABO","TXT")
# Asistencia 05.680.432
## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura
    If [M:ZAF0]ORIMOD = 3 Then
        Gosub LANZAR_IMPORT_ZBIS
    Elsif [M:ZAF0]ORIMOD = 6
        Gosub LANZAR_IMPORT_ZPIH_COMPROBAR
        If XERROR = 2
            Return
        Endif
        Gosub LANZAR_IMPORT_ZPIH
    Endif
## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura
Return

## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura
$LANZAR_IMPORT_ZPIH_COMPROBAR
# Si el origen es factura de compras y la entrada de todas sus línieas es directa se generá el proceso en caso contrario no se permitirá
Local Integer VARABONO: VARABONO = 1

    If clalev([F:PID])=0 : Local File PINVOICED    [PID] : Endif

    Filter [PID] Where NUM = [M:ZAF0]NUM
    For [PID]
        If [F:PID]TYPORI <>5
            VARABONO = 0
        Endif
    Next
    Filter [PID]

    If VARABONO = 0
        Call ERREUR("Tipo de factura prohibido",1) From GESECRAN
        XERROR =2
    Endif
Return
## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura


## AUREN - DSM - Abril 2013 - Compras - Generar abono si rechazo de factura
$LANZAR_IMPORT_ZPIH
#Compras - Generar abono si rechazo de factura
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif
    If clalev([F:PIV])=0 : Local File PINVOICEV    [PIV] : Endif
    If clalev([F:PID])=0 : Local File PINVOICED    [PID] : Endif
    Openo FICHERO,0 Using [XPIH]

    For [PIH]PIH0 Where NUM = [M:ZAF0]NUM
        XNUMREG = "R-" + num$([F:PIH]ZNUMREG)
        For [PIV]PIV0 Where NUM = [M:ZAF0]NUM
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
##            Wrseq "E" + LSEP + [F:PIH]FCY + LSEP + XTIPOFACTURA + LSEP + date$  + LSEP + [F:PIH]BPR + LSEP + [F:PIH]BPRSAC
##&        + LSEP + [F:PIH]CUR + LSEP + "4"
##&        + LSEP + "4" + LSEP + "2" + LSEP + [F:PIH]BPRDAT
##&        + LSEP + [F:PIH]BPRPAY + LSEP + [F:PIH]INVREF + LSEP + [F:PIH]PTE + LSEP + [F:PIH]VAC
##&        + LSEP + [F:PIH]ZDEP + LSEP + [F:PIH]ZUS1 + LSEP + [F:PIH]ZUS2
##&        + LSEP + XNUMREG + LSEP + [F:PIH]XDUA + LSEP + [F:PIH]XFDUA + LSEP + [F:PIH]XTDUA
##&        + LSEP + date$
##&        + LSEP + [F:PIH]STRDUDDAT + LSEP + [F:PIH]NUM + LSEP + [F:PIH]NUM
##&        + LSEP + [F:PIH]BPAINV
##&        + LSEP + num$([F:PIV]TOTLINAMT) + LSEP + num$([F:PIV]TOTTAXAMT) + chr$(013) Using [XPIH]

# Correcció Compras X3 -> Estat Setram=Rechazado(5); Estat X3=Retenido(2)
#AUREN - PU9
#            Wrseq "E" + LSEP + [F:PIH]FCY + LSEP + XTIPOFACTURA + LSEP + date$  + LSEP + [F:PIH]BPR + LSEP + [F:PIH]BPRSAC
#&        + LSEP + [F:PIH]CUR + LSEP + "2"
#&        + LSEP + "5" + LSEP + "2" + LSEP + [F:PIH]BPRDAT
#&        + LSEP + [F:PIH]BPRPAY + LSEP + [F:PIH]INVREF + LSEP + ZPTEDEFAULT + LSEP + [F:PIH]VAC
#&        + LSEP + [F:PIH]ZDEP + LSEP + [F:PIH]ZUS1 + LSEP + [F:PIH]ZUS2
#&        + LSEP + XNUMREG + LSEP + [F:PIH]XDUA + LSEP + [F:PIH]XFDUA + LSEP + [F:PIH]XTDUA
#&        + LSEP + date$
#&        + LSEP + date$ + LSEP + [F:PIH]NUM + LSEP + [F:PIH]NUM
#&        + LSEP + [F:PIH]BPAINV
#&        + LSEP + num$([F:PIV]TOTLINAMT) + LSEP + num$([F:PIV]TOTTAXAMT) + chr$(013) Using [XPIH]
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
            Wrseq "E" + LSEP + [F:PIH]FCY + LSEP + XTIPOFACTURA + LSEP + date$  + LSEP + [F:PIH]BPR + LSEP + [F:PIH]BPRSAC
&        + LSEP + [F:PIH]CUR + LSEP + "2"
&        + LSEP + "5" + LSEP + "2" + LSEP + [F:PIH]BPRDAT
&        + LSEP + [F:PIH]BPRPAY + LSEP + [F:PIH]INVREF + LSEP + ZPTEDEFAULT + LSEP + [F:PIH]VAC
&        + LSEP + [F:PIH]ZDEP + LSEP + [F:PIH]ZUS1 + LSEP + [F:PIH]ZUS2
&        + LSEP + XNUMREG + LSEP + [F:PIH]SPACUS + LSEP + [F:PIH]SPACUSDAT + LSEP + [F:PIH]SPACUSBPR
&        + LSEP + date$
&        + LSEP + date$ + LSEP + [F:PIH]NUM + LSEP + [F:PIH]NUM
&        + LSEP + [F:PIH]BPAINV
&        + LSEP + num$([F:PIV]TOTLINAMT) + LSEP + num$([F:PIV]TOTTAXAMT) + chr$(013) Using [XPIH]
##AUREN - DSM - Junio 2013 - Compras - Forma pago por defecto y fecha inicio vencimiento
#AUREN - PU9

            For [PID]PID0 Where NUM = [F:PIH]NUM
# Asistencia 05.680.432 - Rebuig duplicat
#                Wrseq "L" + LSEP + num$([F:PID]TYPORI) + LSEP + [F:PID]ITMREF + LSEP + [F:PID]ITMDES
#&            + LSEP + [F:PID]UOM + LSEP + num$([F:PID]QTYUOM) + LSEP + num$([F:PID]NETPRI) + LSEP + num$([F:PID]AMTNOTLIN)
#&            + LSEP + [F:PID]LINACC + LSEP + [F:PID]LINCNA + LSEP + num$([F:PID]LINPURTYP) + LSEP + [F:PID]CCE1
#&            + LSEP + [F:PID]CCE2 + LSEP + [F:PID]CCE3 + LSEP + [F:PID]CCE4 + LSEP + [F:PID]CCE5 + LSEP + [F:PID]CCE6
#&            + LSEP + [F:PID]CCE7 + LSEP + [F:PID]CCE8 + LSEP + [F:PID]CCE9
#&            + LSEP + num$([F:PID]DEDTAXLIN1) + LSEP + num$([F:PID]DEDTAXLIN2) + LSEP + num$([F:PID]DEDTAXLIN3)
#&            + chr$(013) Using [XPIH]
            Local Integer ZTYPORI
            If [F:PIH]INVTYP = 1
                ZTYPORI = 4
            Else
                ZTYPORI = 5
            Endif

#AUREN - PU9
#                Wrseq "L" + LSEP + num$(ZTYPORI) + LSEP + [F:PID]NUM + LSEP + num$([F:PID]PIDLIN) + LSEP + [F:PID]ITMREF + LSEP + [F:PID]ITMDES
#&            + LSEP + [F:PID]UOM + LSEP + num$([F:PID]QTYUOM) + LSEP + num$([F:PID]NETPRI) + LSEP + num$([F:PID]AMTNOTLIN)
#&            + LSEP + [F:PID]LINACC + LSEP + [F:PID]LINCNA + LSEP + num$([F:PID]LINPURTYP) + LSEP + [F:PID]CCE1
#&            + LSEP + [F:PID]CCE2 + LSEP + [F:PID]CCE3 + LSEP + [F:PID]CCE4 + LSEP + [F:PID]CCE5 + LSEP + [F:PID]CCE6
#&            + LSEP + [F:PID]CCE7 + LSEP + [F:PID]CCE8 + LSEP + [F:PID]CCE9
#&            + LSEP + num$([F:PID]VAT(0)) + LSEP + num$([F:PID]VAT(1)) + LSEP + num$([F:PID]VAT(2))
#&            + LSEP + num$([F:PID]DEDTAXLIN1) + LSEP + num$([F:PID]DEDTAXLIN2) + LSEP + num$([F:PID]DEDTAXLIN3)
#&            + chr$(013) Using [XPIH]
## Asistencia 05.680.432 - Rebuig duplicat
                Wrseq "L" + LSEP + num$(ZTYPORI) + LSEP + [F:PID]NUM + LSEP + num$([F:PID]PIDLIN) + LSEP + [F:PID]ITMREF + LSEP + [F:PID]ITMDES
&            + LSEP + [F:PID]UOM + LSEP + num$([F:PID]QTYUOM) + LSEP + num$([F:PID]NETPRI) + LSEP + num$([F:PID]AMTNOTLIN)
&            + LSEP + num$([F:PID]LINPURTYP)
&            + LSEP + num$([F:PID]VAT(0)) + LSEP + num$([F:PID]VAT(1)) + LSEP + num$([F:PID]VAT(2))
&            + LSEP + num$([F:PID]DEDTAXLIN1) + LSEP + num$([F:PID]DEDTAXLIN2) + LSEP + num$([F:PID]DEDTAXLIN3)
&            + chr$(013) Using [XPIH]
             If clalev([F:CAL])=0 : Local File CPTANALIN [CAL] : Endif
             For [CAL]CAL0 Where ABRFIC = "PID" and VCRTYP = 0 and VCRNUM = [F:PIH]NUM and VCRLIN = [F:PID]PIDLIN
                Wrseq "LC"
&            + LSEP + [F:CAL]LED(0) + LSEP + [F:CAL]LED(0) + LSEP + [F:CAL]LED(2) + LSEP + [F:CAL]LED(3) + LSEP + [F:CAL]LED(4)
&            + LSEP + [F:CAL]LED(5) + LSEP + [F:CAL]LED(6) + LSEP + [F:CAL]LED(7) + LSEP + [F:CAL]LED(8) + LSEP + [F:CAL]LED(9)
&            + LSEP + [F:CAL]ACC(0) + LSEP + [F:CAL]ACC(0) + LSEP + [F:CAL]ACC(2) + LSEP + [F:CAL]ACC(3) + LSEP + [F:CAL]ACC(4)
&            + LSEP + [F:CAL]ACC(5) + LSEP + [F:CAL]ACC(6) + LSEP + [F:CAL]ACC(7) + LSEP + [F:CAL]ACC(8) + LSEP + [F:CAL]ACC(9)
&            + LSEP + [F:CAL]DSP
&            + LSEP + [F:CAL]DIE(0) + LSEP + [F:CAL]DIE(0) + LSEP + [F:CAL]DIE(2) + LSEP + [F:CAL]DIE(3) + LSEP + [F:CAL]DIE(4)
&            + LSEP + [F:CAL]DIE(5) + LSEP + [F:CAL]DIE(6) + LSEP + [F:CAL]DIE(7) + LSEP + [F:CAL]DIE(8) + LSEP + [F:CAL]DIE(9)
&            + LSEP + [F:CAL]CCE(0) + LSEP + [F:CAL]CCE(0) + LSEP + [F:CAL]CCE(2) + LSEP + [F:CAL]CCE(3) + LSEP + [F:CAL]CCE(4)
&            + LSEP + [F:CAL]CCE(5) + LSEP + [F:CAL]CCE(6) + LSEP + [F:CAL]CCE(7) + LSEP + [F:CAL]CCE(8) + LSEP + [F:CAL]CCE(9)
&            + chr$(013) Using [XPIH]
             Next
#AUREN - PU9
            Next
        Next
    Next
    Openo Using [XPIH]
    Call IMPSILEN ('ZPIH',FICHERO)

  # LPARDO. 210813. Lanzar creación documento rechazo

  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEZAF
   Local Char ZPARSPEZAF(250) : ZPARSPEZAF =func AFNC.PARAM("ZPARSPEZAF","")
   Call CALLOUTHTTP (ZPARSPEZAF + nomap(0) + "/" + GUSER + "/" + [M:ZAF0]NUM) From ZJAVAUTILS
  #####AUREN.FIN
  ###########################################################################################
Return
