#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## PAGOS INTERSOCIEDAD                                           -- 25/01/2010 --   ##
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE_BATCH"   : Gosub OUVRE
        When "FIN"           : Gosub FIN
        When "INIT"          : Gosub INIT
        When "SETBOUT"       : Gosub SETBOUT 
        When "EXEC"          : Gosub EXEC
        When "OK"            : GOK=1
        When "END"           : GOK=0
        When "CONTROLE"      : Gosub CONTROLE
        When default
    Endcase
Return
######################################################################################
$OUVRE
    If clalev([F:DUD])<=0   : Local File GACCDUDATE [DUD]   : Endif
    If clalev([F:ZDUD])<=0  : Local File GACCDUDATE [ZDUD]  : Endif
    If clalev([F:DUD2])<=0  : Local File GACCDUDATE [DUD2]  : Endif
    If clalev([F:ZCP])<=0   : Local File ZTRANCP    [ZCP]   : Endif  
    If clalev([F:ZCP1])<=0  : Local File ZTRANCP    [ZCP1]  : Endif  
    If clalev([F:SIH])<=0   : Local File SINVOICE   [SIH]   : Endif
    If clalev([F:PIH])<=0   : Local File PINVOICE   [PIH]   : Endif
    If clalev([F:PYH])<=0   : Local File PAYMENTH   [PYH]   : Endif
    If clalev([F:ZPYH])<=0  : Local File PAYMENTH   [ZPYH]  : Endif
    If clalev([F:ZPYH2])<=0 : Local File PAYMENTH   [ZPYH2] : Endif
    If clalev([F:PYD])<=0   : Local File PAYMENTD   [PYD]   : Endif
    If clalev([F:BAN])<=0   : Local File BANK       [BAN]   : Endif

    ## EA101 13-06-2012 Control tercero es intersociedad
    If clalev([F:BPR])<=0   : Local File BPARTNER   [BPR]   : Endif
    
Return
######################################################################################
$INIT
    Gosub OUVRE

    Local Mask ZPAGINT [ZPGI]
    Raz [M:ZPGI]
    [M:ZPGI]FECHA=date$
Return
######################################################################################
$CONTROLE
    If GOK<1  FIN=1 : Endif
Return
######################################################################################
$EXEC    
    Local    Integer  ZLIG               : ZLIG        = 0
    Local    Integer  ZCREAR             : ZCREAR      = 0
    Local    Char     LSEP               : LSEP        = "|"
    Local    Char     RUTA(250)
    Local    Char     ZFICHERO_COB(250) 
    Local    Char     ZFICHERO_TMP(250) 
    Local    Integer  ZENTRAR_SIH        : ZENTRAR_SIH = 0    
    Local    Integer  ZENTRAR_PIH        : ZENTRAR_PIH = 0  
    Global   Integer  ZLIN               : ZLIN        = 0
    Global   Integer  ZREGISTROS         : ZREGISTROS  = 0
    Global   Char     ZUSER_PAG
    Global   Integer  ZNUM_PAG           : ZNUM_PAG    = 0
    Local    Char     ZCPY_ORI
    Local    Char     ZFCY_ORI
    Local    Char     ZPAYTYP_ORI
    Local    Char     ZREGISTROS_TMP(250)
    Local    Char     ZENTER (2)
    Local    Integer  ESTAT
    Global   Integer  ZERROR             : ZERROR      = 0
     
    Raz ZUSER_PAG

    ZUSER_PAG = GUSER
  
    If !GSERVEUR
        Call OUVRE_TRACE("Generación de Cobros INTERSOCIEDAD") From LECFIC
    Endif

    ##---- Revisar que el parametro de Modelo de importación este informado  -------##
    If GZIMPCOB =""
        GERR=1    
        Call ECR_TRACE("Modelo de Importación de Cobros no informado",1) From GESECRAN
        mkstat=2
        Goto $FINAL_PROC
        Return
    Endif

    Filter [ZCP1] Where TAUT = 2 Order By CPYORI Asc;FCYORI Asc;PAYTYPO Asc

    For [ZCP1]
        If ZCPY_ORI <> [F:ZCP1]CPYORI or ZFCY_ORI <> [F:ZCP1]FCYORI or ZPAYTYP_ORI <> [F:ZCP1]PAYTYPO
            ZCPY_ORI    = [F:ZCP1]CPYORI
            ZFCY_ORI    = [F:ZCP1]FCYORI
            ZPAYTYP_ORI = [F:ZCP1]PAYTYPO

            For [PYH] Where SNS <> 2 and STA >= 2 and ACCDAT >= [M]FECHA and ZPAGINTER = "" and CPY = ZCPY_ORI and FCY = ZFCY_ORI and PAYTYP = ZPAYTYP_ORI

             #######################################################################
             ### 13-06-2012 ESPECÍFICO EA101
             ### Si el tercero no es una sociedad no se gestiona como intersociedad 
             #######################################################################
             Read [BPR]BPR0 = [F:PYH]BPR
             If !fstat and [F:BPR]BETFCY = 2 
               

                ZNUM_PAG = 0            
                ZUSER_PAG = [F:ZCP1]USERINF
                ZLIN = 0
                ZERROR = 0

                Gosub CREAR_FICHERO_TMP
    
                For [PYD] Where NUM = [F:PYH]NUM

                    Read [DUD2]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
                    If !fstat
                       If [F:DUD2]BPRTYP = 2                    
                            Read [PIH]PIH0 = [F:PYD]VCRNUM
                            If fstat or [F:PIH]ZINVOICE = ""
                                Raz [F:PIH]
                                If ZNUM_PAG = 0
                                    Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                    ZNUM_PAG = 1
                                Endif
                                Call ECR_TRACE("    La factura "+ [F:PYD]VCRNUM +" no tiene factura relacionada",1) From GESECRAN
                                ZERROR = 2
                            Else
                                ZENTRAR_SIH = 0
                                For [SIH] Where ZINVOICE = [F:PIH]ZINVOICE
                                    ZENTRAR_SIH += 1
                                    Read [ZDUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
                                    If fstat
                                        Raz [ZDUD]
                                    Else              
                                        Read [ZCP]ZCP1 =ZCPY_ORI;ZFCY_ORI;ZPAYTYP_ORI;[F:SIH]CPY;[F:SIH]FCY 
                                        If fstat
                                            Raz [ZCP]
                                            Filter [ZCP]
                                            If ZNUM_PAG = 0
                                                Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                                ZNUM_PAG = 1
                                            Endif
                                            Call ECR_TRACE("    No existe parametrización de Pagos Intersociedad",1) From GESECRAN
                                            Call ECR_TRACE("    Sociedad Origen  : " + ZCPY_ORI + " Planta Origen : " + ZFCY_ORI + " Transacción Origen: " + ZPAYTYP_ORI + " ",1) From GESECRAN
                                            Call ECR_TRACE("    Sociedad Destino : " + [F:SIH]CPY + " Planta Destino : " + [F:SIH]FCY + "",1) From GESECRAN
                                            ZERROR = 2
                                        Else
                                            If ZCREAR <> 2 : Gosub CREAR_FICHERO : Endif
                                            Gosub GEN_FICH_SIH                    
                                        Endif
                                    Endif
                                Next
    
                                If ZENTRAR_SIH = 0
                                    If ZNUM_PAG = 0
                                        Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                        ZNUM_PAG = 1
                                    Endif
                                    Call ECR_TRACE("    No existen facturas de cliente con la factura relacionada :" + [F:PIH]ZINVOICE + "",1) From GESECRAN
                                    ZERROR = 2
                                Endif
                            Endif
                        Elsif [F:DUD2]BPRTYP = 1
                            Read [SIH]SIH0 = [F:PYD]VCRNUM
                            If fstat or [F:SIH]ZINVOICE = ""
                                Raz [F:SIH]
                                If ZNUM_PAG = 0
                                    Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                    ZNUM_PAG = 1
                                Endif
                                Call ECR_TRACE("    La factura "+ [F:PYD]VCRNUM +" no tiene factura relacionada",1) From GESECRAN
                                ZERROR = 2
                            Else
                                ZENTRAR_PIH = 0
                                For [PIH] Where ZINVOICE = [F:SIH]ZINVOICE
                                    ZENTRAR_PIH += 1
                                    Read [ZDUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
                                    If fstat
                                        Raz [ZDUD]
                                    Else              
                                        Read [ZCP]ZCP1 =ZCPY_ORI;ZFCY_ORI;ZPAYTYP_ORI;[F:PIH]CPY;[F:PIH]FCY 
                                        If fstat
                                            Raz [ZCP]
                                            Filter [ZCP]
                                            If ZNUM_PAG = 0
                                                Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                                ZNUM_PAG = 1
                                            Endif
                                            Call ECR_TRACE("    No existe parametrización de Pagos Intersociedad",1) From GESECRAN
                                            Call ECR_TRACE("    Sociedad Origen  : " + ZCPY_ORI + " Planta Origen : " + ZFCY_ORI + " Transacción Origen: " + ZPAYTYP_ORI + " ",1) From GESECRAN
                                            Call ECR_TRACE("    Sociedad Destino : " + [F:PIH]CPY + " Planta Destino : " + [F:PIH]FCY + "",1) From GESECRAN
                                            ZERROR = 2
                                        Else
                                            If ZCREAR <> 2 : Gosub CREAR_FICHERO : Endif
                                            Gosub GEN_FICH_PIH                    
                                        Endif
                                    Endif
                                Next
    
                                If ZENTRAR_PIH = 0
                                    If ZNUM_PAG = 0
                                        Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                                        ZNUM_PAG = 1
                                    Endif
                                    Call ECR_TRACE("    No existen facturas de cliente con la factura relacionada :" + [F:SIH]ZINVOICE + "",1) From GESECRAN
                                    ZERROR = 2
                                Endif
                            Endif
                        Endif
                    Endif
                Next ## --Bucle lineas pagos

                ##-- Si no tenemos ningún error copiaremos los registros del fichero temporal al real.

                Openo Using [ZTMP]

                If ZERROR <> 2 
                    Openi ZFICHERO_TMP,0 Using [ZTMP]
    
                    Iomode  adxifs chr$(13)          Using [ZTMP]
                    Iomode  Adxium 50                Using [ZTMP]
    
                    Repeat
                        Raz ZREGISTROS_TMP
                        Rdseq ZREGISTROS_TMP,ZENTER Using [ZTMP]
                        If ZREGISTROS_TMP <> ""
                            Wrseq ZREGISTROS_TMP + chr$(13) Using [ZCOB]                    
                        Endif
                    Until fstat <> 0
    
                    Openi Using [ZTMP]
                Endif
                ##-- Borraremos el fichero temporal
                Call EFFACE(ZFICHERO_TMP,ESTAT) From ORDSYS
                If ESTAT Then : Return : Endif 
                Raz ZERROR
            ##-----------------------------------------------------------------------------------

             ### EA101 #############################################################
             Endif

            Next ## --Bucle cabecera pagos

        Endif
    Next    

    Filter [ZCP1]

    If ZCREAR = 2
        Openo  Using [ZCOB]
    Endif

    If ZCREAR <> 2 : Goto $FINAL_PROC : Return : Endif

    Gosub CERRAR_TABLAS


    Call IMPSILEN (GZIMPCOB,ZFICHERO_COB)

    If ZREGISTROS = 0 : Goto $FINAL_PROC : Return : Endif

    If clalev([F:PYH])<=0   : Local File PAYMENTH   [PYH]  : Endif
    If clalev([F:ZPYH])<=0  : Local File PAYMENTH   [ZPYH] : Endif

    For [PYH] Where REF = num$(adxuid(1))
        Update [ZPYH] Where NUM = [F:PYH]ZPAGINTER With ZPAGINTER = [F:PYH]NUM
        If fstat
            GOK=0 : Call FSTA("ZPYH") From GLOCK : Break 
        Else 
            Call ECR_TRACE("Pago nş " + [F:PYH]ZPAGINTER + " genero el pago Intersociedad " + [F:PYH]NUM + " ",0) From GESECRAN
        Endif  
    Next


    Local Char VALBOUT(30)
    Local Char PARBOUT(250)(1..3)

    For [ZPYH] Where REF = num$(adxuid(1))
        PARBOUT(1) = "9"           : # Etape de comptabilisation 3,8,9
        PARBOUT(2) = "3"           : # 1:Bordereau de remise, 2:Avis de domiciliation, 3:RĂ¨glement
        PARBOUT(3) = [F:ZPYH]NUM    : # NumĂ©ro de bordereau, d'avis ou de rĂ¨glement
        
        Filter [PYH]
        Raz [PYH]
        Read [PYH]PYH0 = [F:ZPYH]NUM : If fstat : Raz [F:PYH] : Endif
        GACTION="PAYCPT"
        
        GSERVEUR = 1
        Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYCPT","DPAYCPT",3,"") From GTRAITE
        GSERVEUR = 0
    Next

    Update [PYH] Where REF = num$(adxuid(1)) With REF = ''
    If fstat
        GOK=0 : Call FSTA("PYH") From GLOCK 
    Endif 

    $FINAL_PROC

    If ZREGISTROS = 0 
        Call ECR_TRACE("Ningún pago procesado. Actualización imposible",1) From GESECRAN
        ZUSER_PAG = GUSER
    Endif

    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif

    Kill ZREGISTROS,ZNUM_PAG,ZLIN,ZERROR
Return
######################################################################################
$SETBOUT

Return
######################################################################################
$FIN
Return
######################################################################################
$CERRAR_TABLAS
    If clalev([F:DUD])>0   : Close Local File [DUD]   : Endif
    If clalev([F:ZDUD])>0  : Close Local File [ZDUD]  : Endif
    If clalev([F:ZCP])>0   : Close Local File [ZCP]   : Endif  
    If clalev([F:ZCP1])>0  : Close Local File [ZCP1]  : Endif  
    If clalev([F:SIH])>0   : Close Local File [SIH]   : Endif
    If clalev([F:PIH])>0   : Close Local File [PIH]   : Endif
    If clalev([F:PYH])>0   : Close Local File [PYH]   : Endif
    If clalev([F:ZPYH])>0  : Close Local File [ZPYH]  : Endif
    If clalev([F:PYD])>0   : Close Local File [PYD]   : Endif
    #### EA101 ####
    If clalev([F:BPR])>0   : Close Local File [BPR]   : Endif
Return
######################################################################################
$GEN_FICH_SIH
    Local Decimal ZAMTLIN
    Local Integer ZENTRAR_DUD : ZENTRAR_DUD = 0
    Local Char    ZBANK : Raz ZBANK

    For [DUD] Where TYP = [F:SIH]GTE and NUM = [F:SIH]NUM and DUDDAT = [F:ZDUD]DUDDAT and AMTCUR = [F:ZDUD]AMTCUR
        ZENTRAR_DUD +=1
        If ([F:DUD]AMTCUR - [F:DUD]PAYCUR - [F:DUD]TMPCUR) <> 0 

            ZREGISTROS += 1
            #ZAMTLIN = [F:DUD]AMTCUR - [F:DUD]TMPCUR - [F:DUD]PAYCUR
            ZAMTLIN = [F:PYD]AMTLIN

            If [F:PYH]BID <> ''
                For [BAN] Where CPY = [F:DUD]CPY and BIDNUM = [F:PYH]BID
                    ZBANK = [F:BAN]BAN 
                Next
            Endif
    
            If ZLIN = 0
                Wrseq 'P|' + "*" + LSEP + [F:ZCP]PAYTYPD + LSEP + [F:SIH]BPR + LSEP + [F:SIH]FCY + LSEP + 
&                [F:PYH]ACCDAT + LSEP + num$(adxuid(1)) + LSEP + [F:PYH]NUM + LSEP + ZBANK + chr$(013) Using [ZTMP]
            Endif

            ZLIN += 1
            Wrseq 'D|'+ [F:DUD]TYP + LSEP + [F:DUD]NUM + LSEP + num$([F:DUD]ACCNUM) + LSEP + 
&               num$([F:DUD]DUDLIG) + LSEP + num$(ZAMTLIN) + LSEP + [F:DUD]BPR + LSEP + [F:DUD]SAC + chr$(013) Using [ZTMP]   
        Else
            If ZNUM_PAG = 0
                Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                ZNUM_PAG = 1
            Endif
            Call ECR_TRACE("    Vencimiento : " + num$([F:DUD]NUM) + " cobrado totalmente.",1) From GESECRAN
            ZERROR = 2
        Endif
        Break
    Next

    If ZENTRAR_DUD = 0
        If ZNUM_PAG = 0
            Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
            ZNUM_PAG = 1
        Endif
        Call ECR_TRACE("    No existen vencimientos que cumplan los criterios.",1) From GESECRAN
        Call ECR_TRACE("    Factura : " + [F:SIH]NUM + ". Fecha : " + [F:ZDUD]DUDDAT + ". Importe : " + num$([F:ZDUD]AMTCUR) + " " ,1) From GESECRAN
        ZERROR = 2
    Endif
Return
######################################################################################
$GEN_FICH_PIH
    Local Decimal ZAMTLIN
    Local Integer ZENTRAR_DUD : ZENTRAR_DUD = 0
    Local Char    ZBANK : Raz ZBANK

    For [DUD] Where TYP = [F:PIH]GTE and NUM = [F:PIH]NUM and DUDDAT = [F:ZDUD]DUDDAT and AMTCUR = [F:ZDUD]AMTCUR
        ZENTRAR_DUD +=1
        If ([F:DUD]AMTCUR - [F:DUD]PAYCUR - [F:DUD]TMPCUR) <> 0 

            If [F:PYH]BID <> ''
                For [BAN] Where CPY = [F:DUD]CPY and BIDNUM = [F:PYH]BID
                    ZBANK = [F:BAN]BAN 
                Next
            Endif

            ZREGISTROS += 1
            #ZAMTLIN = [F:DUD]AMTCUR - [F:DUD]TMPCUR - [F:DUD]PAYCUR
            ZAMTLIN = [F:PYD]AMTLIN

            If ZLIN = 0
                Wrseq 'P|' + "*" + LSEP + [F:ZCP]PAYTYPD + LSEP + [F:PIH]BPR + LSEP + [F:PIH]FCY + LSEP + 
&                [F:PYH]ACCDAT + LSEP + num$(adxuid(1)) + LSEP + [F:PYH]NUM  + LSEP + ZBANK + chr$(013) Using [ZTMP]
            Endif

            ZLIN += 1
            Wrseq 'D|'+ [F:DUD]TYP + LSEP + [F:DUD]NUM + LSEP + num$([F:DUD]ACCNUM) + LSEP + 
&               num$([F:DUD]DUDLIG) + LSEP + num$(ZAMTLIN) + LSEP + [F:DUD]BPR + LSEP + [F:DUD]SAC + chr$(013) Using [ZTMP]
        Else
            If ZNUM_PAG = 0
                Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
                ZNUM_PAG = 1
            Endif
            Call ECR_TRACE("    Vencimiento : " + num$([F:DUD]NUM) + " cobrado totalmente.",1) From GESECRAN
            ZERROR = 2
        Endif
        Break
    Next

    If ZENTRAR_DUD = 0
        If ZNUM_PAG = 0
            Call ECR_TRACE("Procesando pago num : " + [F:PYH]NUM,1) From GESECRAN
            ZNUM_PAG = 1
        Endif
        Call ECR_TRACE("    No existen vencimientos que cumplan los criterios.",1) From GESECRAN
        Call ECR_TRACE("    Factura : " + [F:PIH]NUM + ". Fecha : " + [F:ZDUD]DUDDAT + ". Importe : " + num$([F:ZDUD]AMTCUR) + " " ,1) From GESECRAN
        ZERROR = 2
    Endif
Return
######################################################################################
$CREAR_FICHERO

    If clalev([F:APX])=0 : Local File APARIMPEXP   [APX] : Endif

    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
    Read [APX]APX0 = 'REPIMPDEF'
    If fstat 
        Raz [F:APX]
        ERROR = 1
        Call ERREUR(mess(121,141,1)) From GESECRAN
        Return
    Endif

    RUTA = [F:APX]DIRECTORY
    RUTA = left$(RUTA,len(RUTA)-1)

    Raz ZFICHERO_COB
    ZFICHERO_COB = filpath(RUTA,num$(adxuid(1))+"_ZCOBINTER","TXT")

    LSEP = '|'

    Openo ZFICHERO_COB,0 Using [ZCOB] 

    ZCREAR = 2
Return
######################################################################################
######################################################################################
$CREAR_FICHERO_TMP

    If clalev([F:APX])=0 : Local File APARIMPEXP   [APX] : Endif

    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
    Read [APX]APX0 = 'REPIMPDEF'
    If fstat 
        Raz [F:APX]
        ERROR = 1
        Call ERREUR(mess(121,141,1)) From GESECRAN
        Return
    Endif

    RUTA = [F:APX]DIRECTORY
    RUTA = left$(RUTA,len(RUTA)-1)

    Raz ZFICHERO_TMP
    ZFICHERO_TMP = filpath(RUTA,num$(adxuid(1))+"_ZCOBTMP","TXT")

    ##-- Borraremos el fichero temporal y abriremos un nuevo fichero
    Call EFFACE(ZFICHERO_TMP,ESTAT) From ORDSYS
    If ESTAT Then : Return : Endif 

    LSEP = '|'

    Openo ZFICHERO_TMP,0 Using [ZTMP]       

Return
######################################################################################
######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH)
    Value Char MODELE
    Value Char NOMFICH
    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")
    Local Char MESSAGE(100)

#    Call OUVRE_TRACE("Generación de Cobros INTERSOCIEDAD") From LECFIC
    
    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ
    If GERRTRACE <> 0
        GYNUM=0
    Endif
#    Call FERME_TRACE From LECFIC
#    Call LEC_TRACE From LECFIC
End
######################################################################################
######################################################################################
