#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
  When "APRES_MOD"    : Gosub REPLICA
  When "APRES_CRE"    : Gosub REPLICA
Endcase
Return

# AUREN - MIGRACIÓN PU9 - FUNCIÓN REPLICA PENDIENTE DE REVISIÓN
$REPLICA

Return

$REPLICA_OLD

If [M:FAS1]CCE(5) <> '' Then
  Char RESPUESTA(200)
  Char ENTRADA(200)

  ENTRADA = "VEHICULO" + chr$(254) + [M:FAS1]CCE(5) + chr$(254) + [M:FAS0]FASCOD

  System RESPUESTA = 'c:\consolaejecucionuv\consolaejecucionuv.exe /user="ws" /password="ws" /account="SAGEX3" /hostname="172.16.1.1" /rutina="RECIBE.COD.INMO.B" /entrada="' +ENTRADA+ '"'

  If val(vireblc(RESPUESTA(0),4)) <> 1 Then
    Infbox '+'+RESPUESTA+'+'
  Endif

  If [M:FAS3]SALINVNUM <> '' Then
    Char RESPUESTA(200)
    Char ENTRADA(200)

    ENTRADA = "VEHICULO" + chr$(254) + [M:FAS3]SALINVNUM + chr$(254) + [M:FAS1]CCE(5)

    System RESPUESTA = 'c:\consolaejecucionuv\consolaejecucionuv.exe /user="ws" /password="ws" /account="SAGEX3" /hostname="172.16.1.1" /rutina="RECIBE.VTA.INMO.B" /entrada="' +ENTRADA+ '"'

    If val(vireblc(RESPUESTA(0),4)) <> 1 Then
      Infbox '+'+RESPUESTA+'+'
    Endif
  Endif
Endif

Return

