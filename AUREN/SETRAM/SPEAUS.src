#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################################
## Z09 - Gestión de Usuarios - Departamentos                                        ##
######################################################################################
$ACTION
    Case ACTION        
        When "LIENS"         : Gosub LIENS
        When "CREATION"      : Gosub CREATION
        When "MODIF"         : Gosub MODIF
        When "ANNULE"        : Gosub ANNULE
        When default
    Endcase
Return
######################################################################################
$LIENS

    Raz nolign
    nolign=0
    For [ZUD]ZUD0 Where ZUSR=[M:AUS0]USR
        nolign += 1
        [M:ZUD] = [F:ZUD] 
    Next
    [M:ZUD]NBZUD = nolign
    nolign=0
Return
######################################################################################
$CREATION
    For I=0 To [M:ZUD]NBZUD-1
        Raz [F:ZUD]
        [F:ZUD]ZUSR     = [M:AUS0]USR
        [F:ZUD]ZDEP     = [M:ZUD]ZDEP(I)
        [F:ZUD]ZACTIVO  = [M:ZUD]ZACTIVO(I)
        Write[ZUD]
        If fstat
             GOK=0 : Call FSTA("ZUD") From GLOCK : Return
        Endif
    Next I
Return
######################################################################################
$MODIF
    Gosub ACTION From SUBAUS : GPE =1 
    
    Local Integer NL

    Delete [ZUD] Where [F:ZUD]ZUSR=[M:AUS0]USR
    For NL=0 To [M:ZUD]NBZUD-1
        Raz [F:ZUD]
        [F:ZUD]ZUSR     = [M:AUS0]USR
        [F:ZUD]ZDEP     = [M:ZUD]ZDEP(NL)
        [F:ZUD]ZACTIVO  = [M:ZUD]ZACTIVO(NL)
        Write[ZUD]
        If fstat
             GOK=0 : Call FSTA("ZUD") From GLOCK : Return
        Endif
    Next NL
Return
######################################################################################
$ANNULE
    If GOK < 1  Return  Endif
    Delete [ZUD] Where [F:ZUD]ZUSR=[M:AUS0]USR
Return
######################################################################################
######################################################################################

