#####################################################################################################
#####################################################################################################
$ACTION

Case ACTION
  When "INIT"               : Gosub INIT
  When "END"                : Gosub FINISH
  When "CONTROLE"           : Gosub CONTROLE
  When "TRT_DIV"            : Gosub TRT_DIV
  When "SETBOUT"            : Gosub SETBOUT
  When "BOUTON"             : Gosub EXEBOUT
  When "MEN"                : Gosub STATUT
  When "CANCEL"             : Gosub CANCEL
  When "AV_CHOIX"           : Gosub AV_CHOIX
  When "AP_CHOIX"           : Gosub AP_CHOIX
  When "AB3_NB"             : Gosub AB345_NB
  When "BB3_NB"             : Gosub BB345_NB
  When "AB4_NB"             : Gosub AB345_NB
  When "BB4_NB"             : Gosub BB345_NB
  When "AB5_NB"             : Gosub AB345_NB
  When "BB5_NB"             : Gosub BB345_NB
  When Default
    Case BOITE
      When "FBPOINET"       : Gosub PARAM : Gosub BOITE
    Endcase
Endcase
Return

#####################################################################################################
$INIT

If clalev([F:DUD1])=0 : Local File GACCDUDATE [DUD1] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]  : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
If clalev([F:SIV])=0  : Local File SINVOICEV  [SIV]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB]  : Endif

Local Mask BPOINET [BPOI]

Return

#####################################################################################################
$DEBUT
  Gosub CHX_FILTRE
Return

#####################################################################################################
$PARAM
Case ACTION
 When "DEBUT"
  Affzo [M:BPOI]
  Gosub GRISE
Endcase
Return

$GRISE
  If [M:BPOI]ALLFCY=2 : Grizo FCYSEL : Else : Actzo FCYSEL : Endif
  If [M:BPOI]ALLSAC=2 : Grizo GRPSAC, SACSEL, SACACC : Else : Actzo GRPSAC, SACSEL, SACACC : Endif
Return

#####################################################################################################
$CONTROLE
If GOK>0
  BOITE = "FBPOINET"
Else
  BOITE = ""
Endif
Return

#####################################################################################################
# End button pressed
$FINISH

GOK=0
Effzo [M:BPOI]

Trbegin[DUD1]
  Call DELOCK("HAE") From GLOCK
Commit

Return

#####################################################################################################
$TRT_DIV
Case TRAIT
  When "CONSPIEC4" : Gosub BUTTON3_NB
  When "CONSFACT5" : Gosub BUTTON4_NB
  When "CONSREGL"  : Gosub BUTTON5_NB
Endcase
Return

#####################################################################################################
$BOITE
Case ACTION
  When "DEBUT"      : Gosub DEBUT
Endcase
Return

#####################################################################################################
$SETBOUT
# Note STADEF only works on buttons that are Non-validating
Local Integer BPOST, I
Raz CHMEN , CHBOU
CHMEN += "A"  # Cancel
# Do lines exist
If [M:BPOI]NB > 0
  # If lines exist then enable Select all and Unselet all
  CHMEN += "1"  # Function menu Select all
  CHMEN += "2"  # Function menu Unselect all
  # Enable Post if appropriate whether Calculate has been pressed or not
  Gosub SET_POST
  # Only enable Calculate button if lines exist and Post not enabled
  If !BPOST : Gosub SET_CALCULATE : Endif
Else
  STADEF = GSTABOU2+1 # Search button default - this will not work because button was set to Validating per France
  If [M:BPOI]BPRSEL <> "" : CHMEN += "V"  : Endif # Search # BPR checked here because the button is Non-validating
  CHMEN += "A"  # Cancel
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
ETABOU(GRAFF) = 1  # Refresh
Return

$SET_CALCULATE
# Enable Calculate if any checkmarks exist, but not when Post enabled
For I=0 To [M:BPOI]NB-1
  If [M:BPOI]MRK(I) = 2
    CHMEN += "X"
    STADEF = GSTABOU2+2 # Calculate button default
    Break
  Endif
Next
Return

$SET_POST
# Enable Post button if calculate has already been pressed
# Only enable the Post button when the Netting balance = 0
If [M:BPOI]SELTOT = 0 and [M:BPOI]SELITEM <> 0
  CHMEN += "G"
  STADEF = GSTABOU2+3 # Post button default
  BPOST = 1 # True
Endif
Return

#####################################################################################################
# Before button clicked and after Setbout
# This routine needs to stay as it is executed on the initial screen display after SETBOUT and data is set
$AV_CHOIX
Gosub SETBOUT
Return

#####################################################################################################
# After button clicked
$AP_CHOIX
Gosub SETBOUT
Return

#####################################################################################################
$EXEBOUT

If GERR=2 : Enable GSTABOU2+1 : Raz GERR :  Return : Endif # Mismatch on enter

# Note: 'G' is for the Post button (which was originally labeled Generate)
# Note: 'X' is for the Apply button (which was originally labeled Calculate)
Case BOUT
 When "V" : Gosub CHX_FILTRE  # Search button
 When "X" : Gosub NETCALC     # Calculate button
 When "A" : Gosub CANCEL      # Cancel button
 When "G" : Gosub AFTER_POST  ## FIN = 1  # Post button. To exit after running the GENNET action
 When Default
Endcase

Return

#####################################################################################################
$STATUT
Case BOUT
 When "1" : Call B1_NB()      # Select all
 When "2" : Call B2_NB()      # Unselect all
Endcase
Return

#####################################################################################################
$AFTER_POST

Local Integer OK

# Clear screens
If dim([M:BPOI3]NUM) > 0
  Raz [M:BPOI3]
Endif

Effzo [M:BPOI]
Gosub GRISE
Affzo [M:BPOI]

Trbegin[DUD1]
  Call DELOCK("HAE") From GLOCK
Commit

# Clear the files so newly Netted records do not appear or newly posted Open items do appear
Close File [F:DUD1]
Close File [F:HAE]
Close File [F:DAE2]

If clalev([F:DUD1])=0 : Local File GACCDUDATE [DUD1] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif

Return

#####################################################################################################
$CANCEL

Local Integer OK

# Ask first if the grid has been populated
If dim([M:BPOI]NUM) > 0 and [M:BPOI]NUM(0) <> ""
  Call OUINON(mess(412,196,1),OK) From GESECRAN
  If OK <> 2 : Return : Endif
Endif

# Clear screens
If dim([M:BPOI3]NUM) > 0
  Raz [M:BPOI3]
Endif

Effzo [M:BPOI]
Affzo [M:BPOI]
Gosub GRISE

Trbegin[DUD1]
  Call DELOCK("HAE") From GLOCK
Commit

Return

#####################################################################################################
# Search button
$CHX_FILTRE

Local Integer NOL, PBLOCK
Local Char CRITERE(255), CRITERE2(255), OCOA(GLONCOA), CRITGRPSAC(GLONSAC)(1..99), STATMESS, ORDERBY, SYMBOLE
Local Decimal ITEMTOTAL, NETTOTAL

# First time in
If [M:BPOI]BPRSEL = "" or [M:BPOI]CURSEL = "" : Return : Endif

# Clear screens if doing a new search
If dim([M:BPOI3]NUM) > 0 or [M:BPOI]NUM(0) <> ""
  Gosub CLEAR_GRID
Endif

Filter [DUD1]

CRITERE  = "[DUD1]CPY='" + [M:BPOI]CPYSEL + "'"

# If All Sites in not checked, add Site to filter
If [M:BPOI]ALLFCY <> 2
  CRITERE -= "& [DUD1]FCY='" + [M:BPOI]FCYSEL + "'"
Endif

# If all collective accounts is not checked, add either collective group or collective account
If [M:BPOI]ALLSAC<>2
 If [M:BPOI]GRPSAC<>""
  Call LECMAINPLAN(1,[M:BPOI]CPYSEL,OCOA) From CPTDIV
  Filter [GSC] Where [F:GSC]COA=OCOA & [F:GSC]GRU=[M:BPOI]GRPSAC
  Raz [L]CRITGRPSAC
  For [F:GSC]GSC0
   I+=1 : [L]CRITGRPSAC(I) = [F:GSC]SAC
  Next
  Filter [GSC]
  CRITERE -= "& find([DUD1]SAC,[L]CRITGRPSAC)"
 Else
  CRITERE -= "& [DUD1]SAC='"+[M:BPOI]SACSEL+"'"
 Endif
Endif

# BP - required field
CRITERE -= "& [DUD1]BPRPAY='" + [M:BPOI]BPRSEL + "'"

# Date range
If [M:BPOI]DUDDATDEB<>[0/0/0]
 CRITERE -= "& [DUD1]DUDDAT>=["+format$(GFMD,[M:BPOI]DUDDATDEB)+"]"
Endif
If [M:BPOI]DUDDATFIN<>[0/0/0]
 CRITERE -= "& [DUD1]DUDDAT<=["+format$(GFMD,[M:BPOI]DUDDATFIN)+"]"
Endif

# Currency - required field
CRITERE -= "& [DUD1]CUR ='" + [M:BPOI]CURSEL + "'"

# Filter out 0 amount open items, open items linked to a factor, and zero balance items.
# Only display unbalanced open items. FLGCLE (1 = Open / Unbalanced, 2 = Final, 4 = Temporary)
CRITERE -= "& [DUD1]AMTCUR<>0 & [DUD1]BPRFCT='' & [DUD1]FLGCLE=1"

# 100560.n  When Clearing all lines (B2_NB) on QA installs the DH1 link was not being reset so NO records were selected
# 100560.n  However, adding the line below makes the selection work again
If clalev([DH1]) > 0 : Close File [DH1] : Endif # 100560.n

# Linking with GACCENTRY to ensure only posted open items are retrieved.  Link seems to create a Left Outer Join.
# Therefore, I need to link GACCENTRY with GACCDUDATE in order to get only records that are posted (exist in GACCDUDATE).
# Sorting options.  1-Due date, 2-Source date, 3-Document type
Case [M:BPOI]TRI
  When 1 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [DUD1]DUDDAT Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
  When 2 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [HAE]BPRDATVCR Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
  When 3 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [DUD1]TYP Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
Endcase

Gosub LOADGRID

Return

#####################################################################################################
# Need filtering to exclude any Matched items like it is in PAYPROPAL; MAJ_TPD
# Therefore do not include any Open items that have already been Netted or Matched
Funprog TEST_MTC(MTCOK)
Value Integer MTCOK

Filter [MTB] Where ACCNUM=[F:DUD1]ACCNUM & DUDLIG=[F:DUD1]DUDLIG
Look [MTB]MTB0 First
Filter [MTB]
If !fstat
 MTCOK = 0
Endif

End MTCOK

#####################################################################################################
$LOADGRID

ITEMTOTAL = 0
NOL = 0
PBLOCK = 0
Local Integer MATCHED : MATCHED = 1

# X3-53665
Call DELOCK("HAE") From GLOCK

For [DH1]
  If !func TEST_MTC(MATCHED) | [F:DH1]FLGREP=2 : Goto READ_NEXT_DH1 : Endif
  SYMBOLE = "HAE"+num$([F:DUD1]NUM)+"\"+num$([F:DUD1]TYP)
  Lock =SYMBOLE
  If fstat
    PBLOCK=1
  Else
    #94635 RICAR 2014/04/21 - CASH VAT - BEGIN
    If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[M:BPOI]CPYSEL) = "2"
      If func PORLEGLIB.VAL_BPC_CASHVAT([F:DUD1]BPR, [F:HAE]ACCDAT) = 2
        Goto READ_NEXT_DH1
      Endif
    Endif
    #94635 RICAR 2014/04/21 - CASH VAT - END

    nolign = NOL + 1
    [M:BPOI] = [F:DUD1]
    # Make net positive or negative value based on sign (debit or credit)
    # Net total is taking into account Provisional payments per Christine B
    NETTOTAL = ([M:BPOI]AMTCUR(NOL) - [M:BPOI]PAYCUR(NOL) -[M:BPOI]TMPCUR(NOL)) * [M:BPOI]SNS(NOL)
    [M:BPOI]NETAMT(NOL) = NETTOTAL  # Open amount column
    [M:BPOI]AMTTONET(NOL) = 0  # Netting amount column
    [M:BPOI]PREVNET(NOL) = NETTOTAL  # Previous column is not displayed
    [M:BPOI]NETRES(NOL) = [M:BPOI]NETAMT(NOL) - [M:BPOI]AMTTONET(NOL)  # Remaining amount column
    ITEMTOTAL += [M:BPOI]NETAMT(NOL)

    # Open amount in ledger currency
    [M:BPOI]NETAMTLOC(NOL) = ([M:BPOI]AMTLOC(NOL) - [M:BPOI]PAYLOC(NOL) -[M:BPOI]TMPLOC(NOL)) * [M:BPOI]SNS(NOL)

    # Original amount and currently applied/payed and provisional payments
    [M:BPOI]ORIGAMTCUR(NOL) = [M:BPOI]AMTCUR(NOL) * [M:BPOI]SNS(NOL)
    [M:BPOI]ORIGPAYCUR(NOL) = [M:BPOI]PAYCUR(NOL) * [M:BPOI]SNS(NOL)
    [M:BPOI]ORIGTMPCUR(NOL) = [M:BPOI]TMPCUR(NOL) * [M:BPOI]SNS(NOL)

    # If Supplier invoice, add Payment Approval Status - 02/04/14 changed to use FLGPAZ for all lines
    STATMESS = mess([F:DUD1]FLGPAZ,510,1)
    [M:BPOI]PAYSTATUS(NOL) = STATMESS

    # If payment, add payment no. info to grid - will also be used for Payment inquiry.
    If [M:BPOI]TYPDUD(NOL) = 3
      [M:BPOI]PAYNUM(NOL) = [F:HAE]BPRVCR
    Endif

    # Add Source date, ref, and source document to grid
    [M:BPOI]BPRDATVCR(NOL) = [F:HAE]BPRDATVCR
    [M:BPOI]ACCDAT(NOL) = [F:HAE]ACCDAT
    [M:BPOI]REF(NOL) = [F:HAE]REF
    [M:BPOI]BPRVCR(NOL) = [F:HAE]BPRVCR
    [M:BPOI]FBPRVCR(NOL) = [F:HAE]BPRVCR
    # For Financials (or blank sources) set the Source document table column field to the Document number, but form mode will display the original Source document field
    If [F:HAE]ORIMOD = 2 or [F:HAE]BPRVCR = ""
      [M:BPOI]FBPRVCR(NOL) = [F:HAE]NUM
    Endif

    NOL += 1

    # Only allow up to number of rows set in screen
    If NOL+1 > dim([M:BPOI]NUM)
      GMESSAGE = mess(288,117,1)
      GERR = 2
      Break
    Endif
  Endif
  READ_NEXT_DH1
Next

[M:BPOI]NB = NOL
MAXLIG = nolign-1

# Totals section
[M:BPOI]NBITEM = NOL
[M:BPOI]TOTITEM = ITEMTOTAL
# Reset incase Calculate previously pressed
[M:BPOI]SELTOT = 0   # Total amount of calc items
[M:BPOI]SELITEM = 0  # Calculated items

# If some of the records were locked
If NOL > 0 & PBLOCK = 1
  GMESSAGE = mess(168,190,1)
  GERR = 2
Endif

# Either no records are returned based on criteria or all records have been locked by another process.
If NOL = 0
  If PBLOCK = 1
    Call ERREUR(mess(30,100,1)) From GESECRAN  # Operation in Progress on Another Workstation
  Else
    Call ERREUR(mess(99,100,1)) From GESECRAN  # No Records Selected
  Endif
  Return
Endif

Affzo [M:BPOI]

Return

#####################################################################################################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

#####################################################################################################
# Init button - right click options
Subprog IB_NB

Raz GBOUT3, GBOUT4, GBOUT5

# Check if posted journal entry.  If so, display Journal inquiry right click
Read [F:HAE] = [M:BPOI]TYP(nolign-1);[M:BPOI]NUM(nolign-1)
If !fstat
  GBOUT3 = mess(18,109,1)
Endif

# Check if invoice.  Display appropriate right click option.
Read [F:SIH]SIH2 = [M:BPOI]TYP(nolign-1);[M:BPOI]NUM(nolign-1)
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : GBOUT4 = mess(43,109,1) : # Customer invoice
  When 5 : GBOUT4 = mess(45,109,1) : # Sales invoice
 Endcase
Elsif fstat=5
 Read [F:PIH]PIH2 = [M:BPOI]TYP(nolign-1);[M:BPOI]NUM(nolign-1)
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : GBOUT4 = mess(44,109,1) : # Supplier invoice
   When 6 : GBOUT4 = mess(46,109,1) : # Purchase invoice
  Endcase
 Endif
Endif

# Check if payment, add payment right click option.
If [M:BPOI]TYPDUD(nolign-1) = 3 & [M:BPOI]PAYNUM(nolign-1) <> ""
  GBOUT5 = mess(47,109,1) : # Payment
Endif

End

#####################################################################################################
# Before line
Subprog AVANT_NB

# These fields are used in the Change total sub routine
[M:BPOI]PREVNET(nolign-1) = [M:BPOI]AMTTONET(nolign-1)
[M:BPOI]DIFAMT(nolign-1) = [M:BPOI]NETAMT(nolign-1) - [M:BPOI]AMTTONET(nolign-1)

End

#####################################################################################################
# After line
Subprog APRES_NB

# To get the checkbox to display
Affzo [M:BPOI]MRK(nolign-1)

End

#####################################################################################################
# Select all
Subprog B1_NB

Local Decimal NETTOTAL
NETTOTAL = 0

For I=0 To [M:BPOI]NB-1
  [M:BPOI]MRK(I) = 2
  [M:BPOI]AMTTONET(I) = [M:BPOI]NETAMT(I)  # Netting amount column = Open amount column
  [M:BPOI]NETRES(I) = [M:BPOI]NETAMT(I) - [M:BPOI]AMTTONET(I)  # Remaining amount column
  NETTOTAL += [M:BPOI]AMTTONET(I)
Next
[M:BPOI]SELITEM = [M:BPOI]NB
[M:BPOI]SELTOT = NETTOTAL

# In case of a previous selection and calculate was pressed
If dim([M:BPOI3]NUM) > 0
  Raz [M:BPOI3]
Endif

Gosub HIGHLIGHT

Affzo [M:BPOI]

# Set mkstat = 4 to reset the buttons properly
mkstat = 4

End

#####################################################################################################
# Unselect all
Subprog B2_NB

# Same as Refresh / Search again
Gosub CHX_FILTRE

# Set mkstat = 4 to reset the buttons properly
mkstat = 4

End

#####################################################################################################
# Journal entry inquiry
$BUTTON3_NB
Raz [M:BPOI]BIDOBJ, [M:BPOI]BIDCLE1, [M:BPOI]BIDCLE2
GFONC1 = ""  # Used for BP Invoice functions
Read [HAE]HAE0 = [M:BPOI]TYP(nolign-1);[M:BPOI]NUM(nolign-1)
If !fstat
  [M:BPOI]BIDOBJ = "GAS"
  [M:BPOI]BIDCLE1 = [M:BPOI]NUM(nolign-1)
  [M:BPOI]BIDCLE2 = [M:BPOI]TYP(nolign-1)
Endif

Return

#####################################################################################################
# Before going to the button 3, 4 or 5 inquiry functions and after the BUTTON3/4/5_NB routines
$AB345_NB
# When GCONSULT = 2 then modification is not possible in the Object going into, if 0 then modification allowed
Local Integer SAVCONS : SAVCONS=GCONSULT
GCONSULT=2
Return

#####################################################################################################
# After returning from button 3, 4, or 5 inquiry functions
$BB345_NB
GCONSULT=SAVCONS
mkstat=2
Return

#####################################################################################################
# Invoice inquiry
$BUTTON4_NB

Raz [M:BPOI]BIDOBJ, [M:BPOI]BIDCLE1, [M:BPOI]BIDCLE2
GFONC1 = ""  # Used for BP Invoice functions

Case GBOUT4
 When mess(43,109,1) : # Customer invoice
  Call LECTURE("BIC",[M:BPOI]NUM(nolign-1),"") From CONTOBJ
  If !fstat : [M:BPOI]BIDOBJ = "BIC"
    # Call the intercompany function if it is an intercompany invoice
    If func AFNC.ACTIV("INTCO") and func AFNC.PARAM("INTCPYINV",[M:BPOI]CPYSEL)="2" and [F:SIH]NBRCPY > 1
      GFONC1 = "GESBICI"
    Endif
  Endif
 When mess(44,109,1) : # Supplier invoice
  Call LECTURE("BIS",[M:BPOI]NUM(nolign-1),"") From CONTOBJ
  If !fstat : [M:BPOI]BIDOBJ = "BIS"
    # Call the intercompany function if it is an intercompany invoice
    If func AFNC.ACTIV("INTCO") and func AFNC.PARAM("INTCPYINV",[M:BPOI]CPYSEL)="2" and [F:PIH]NBRCPY > 1
      GFONC1 = "GESBISI"
    Endif
  Endif
 When mess(45,109,1) : # sales invoice
  Call LECTURE("SIH",[M:BPOI]NUM(nolign-1),"") From CONTOBJ
  If !fstat : [M:BPOI]BIDOBJ = "SIH" : Endif
 When mess(46,109,1) : # Purchase invoice
  Call LECTURE("PIH",[M:BPOI]NUM(nolign-1),"") From CONTOBJ
  If !fstat : [M:BPOI]BIDOBJ = "PIH" : Endif
Endcase

[M:BPOI]BIDCLE1  = [M:BPOI]NUM(nolign-1)

Return

#####################################################################################################
# Payment inquiry
$BUTTON5_NB

Raz [M:BPOI]BIDOBJ, [M:BPOI]BIDCLE1, [M:BPOI]BIDCLE2
GFONC1 = ""  # Used for BP Invoice functions
[M:BPOI]BIDOBJ = "PAY"
[M:BPOI]BIDCLE1 = [M:BPOI]PAYNUM(nolign-1)

Return

#####################################################################################################
# After change event for "Mark" checkbox.  Update selected totals.
Subprog AM_MRK(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  [M:BPOI]SELTOT -= [M:BPOI]AMTTONET(nolign-1)  # in case Netting amount already have a value
  [M:BPOI]AMTTONET(nolign-1) = [M:BPOI]NETAMT(nolign-1)  # Netting amount column = Open amount
  [M:BPOI]NETRES(nolign-1) = [M:BPOI]NETAMT(nolign-1) - [M:BPOI]AMTTONET(nolign-1)  # Remaining column
  [M:BPOI]SELITEM += 1
  [M:BPOI]SELTOT += [M:BPOI]AMTTONET(nolign-1)
Else
  [M:BPOI]SELTOT -= [M:BPOI]AMTTONET(nolign-1)
  [M:BPOI]AMTTONET(nolign-1) = 0 # Netting amount column
  [M:BPOI]NETRES(nolign-1) = [M:BPOI]NETAMT(nolign-1) - [M:BPOI]AMTTONET(nolign-1)  # Remaining column
  [M:BPOI]SELITEM -= 1
Endif

Affzo [M:BPOI] SELITEM, SELTOT, AMTTONET(nolign-1), NETRES(nolign-1)

# So AV_CHOIX sets the buttons correctly
[M:BPOI]MRK(nolign-1) = VALEUR

# Change the line color if an amount is updated
Gosub HIGHLIGHT_LINE

End

#####################################################################################################
# Before change event. Capture Amount to net before it gets changed.
Subprog AS_AMTTONET(VALEUR)
Variable Decimal VALEUR

[M:BPOI]PREVNET(nolign-1) = VALEUR

End

#####################################################################################################
# Change Amount to net. Also make sure amount is valid.
Subprog C_AMTTONET(VALEUR)
Variable Decimal VALEUR

# Dont make the customer enter the negative sign
If VALEUR = abs([M:BPOI]NETAMT(nolign-1))
  VALEUR = [M:BPOI]NETAMT(nolign-1)
Endif

# Make sure changed amount is valid (less then or equal to NETAMT)
If [M:BPOI]NETAMT(nolign-1) < 0
  If VALEUR < [M:BPOI]NETAMT(nolign-1) | VALEUR > 0
    VALEUR = [M:BPOI]PREVNET(nolign-1)
    GMESSAGE = mess(287,117,1)
    mkstat = 1 : End
  Endif
Else
  If VALEUR > [M:BPOI]NETAMT(nolign-1) | VALEUR < 0
    VALEUR = [M:BPOI]PREVNET(nolign-1)
    GMESSAGE = mess(287,117,1)
    mkstat = 1 : End
  Endif
Endif

End

#####################################################################################################
# After change event
Subprog AM_AMTTONET(VALEUR)
Variable Decimal VALEUR

# Update other fields
If [M:BPOI]MRK(nolign-1) <> 2 and VALEUR <> 0
  [M:BPOI]MRK(nolign-1) = 2
  [M:BPOI]SELITEM += 1
Elsif [M:BPOI]MRK(nolign-1) = 2 and VALEUR = 0
  # Unselect the line if the Amount to net has been cleared / set to 0
  [M:BPOI]MRK(nolign-1) = 1
  [M:BPOI]SELITEM -= 1
Endif
[M:BPOI]NETRES(nolign-1) = [M:BPOI]NETAMT(nolign-1) - VALEUR
[M:BPOI]SELTOT += (VALEUR - [M:BPOI]PREVNET(nolign-1))
Affzo [M:BPOI] SELITEM, SELTOT, MRK(nolign-1), NETRES(nolign-1)

# Change the line color if an amount is updated
Gosub HIGHLIGHT_LINE

End

#####################################################################################################
# Clear the Grid when the Criteria fields are changed
$CLEAR_GRID

If dim([M:BPOI3]NUM) > 0
  Raz [M:BPOI3]
Endif

Effzo [M:BPOI]30-40  # Clears the fields in block 30 (totals) and 40 (grid)
Affzo [M:BPOI]

Return

