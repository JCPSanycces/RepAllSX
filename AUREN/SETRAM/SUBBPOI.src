#####################################################################################################
#####################################################################################################
# Code added from orignal program NETLIB and changed BPOI2 to BPOI due to one screen now
#####################################################################################################
# Click of Calculate button 'X' called from CLCAL action in window FBPOINET
Subprog CL_CALC()

Local Integer K
Local Integer CRCHECK, DRCHECK

For I=0 To [M:BPOI]NB-1
  If [M:BPOI]MRK(I) = 2
    If [M:BPOI]AMTTONET(I) < 0 : CRCHECK=1 : Endif
    If [M:BPOI]AMTTONET(I) > 0 : DRCHECK=1 : Endif
  Endif
Next

If !CRCHECK & DRCHECK
  Call ERREUR(mess(285,117,1)) From GESECRAN
   Raz [M:BPOI]CALC
   GERR=2
   GOK=0
Endif
If !DRCHECK & CRCHECK
  Call ERREUR(mess(284,117,1)) From GESECRAN
  Raz [M:BPOI]CALC
  GERR=2
  GOK=0
Endif
If !CRCHECK & !DRCHECK
  Call ERREUR(mess(187,7900,1)) From GESECRAN
   Raz [M:BPOI]CALC
   GERR=2
   GOK=0
Endif

End

#####################################################################################################
# Click of Calculate button 'X' ran from EXEBOUT
$NETCALC
Local Mask BPOINET3  [BPOI3]
Local Integer WSEL, K, ITEMLINES
Local Decimal ITEMTOTAL, NETTOTAL

# If Calculate is pressed, but nothing has changed then do not re-allocate screen
If [M:BPOI]SELTOT = [M:BPOI3]SELTOT and [M:BPOI]SELITEM = [M:BPOI3]SELITEM
  Return
Endif

Raz [M:BPOI3]
NETTOTAL = 0
WSEL = 0
K = 0
ITEMTOTAL = 0
ITEMLINES = 0

Sorta [M:BPOI]NB [M:BPOI]NB Order By [M:BPOI]DUDDAT(indice),[M:BPOI]ACCNUM(indice),[M:BPOI]DUDLIG(indice)

For I=[M:BPOI]NB To 1 Step -1
  J=I-1
  # Include all lines, but set some fields differently
  If [M:BPOI]MRK(J) = 2
    [M:BPOI3]MRK(K) = 2
    WSEL += 1
    # If the Apply / Calculate button is pressed then ALWAYS set the line to fully netted, even if the Amount to net was changed manually
    [M:BPOI3]NETRES(K)=0 #  Remaining column, this will be recalculated in NET_RESULT
    [M:BPOI3]AMTTONET(K)=[M:BPOI]NETAMT(J)  # Netting amount column = Open amount
  Else
    [M:BPOI3]MRK(K) = 1
    [M:BPOI3]NETRES(K)=[M:BPOI]NETAMT(J) #  Remaining column
    [M:BPOI3]AMTTONET(K)=0  # Netting amount column
  Endif
    [M:BPOI3]TYP(K)=[M:BPOI]TYP(J)
    [M:BPOI3]NUM(K)=[M:BPOI]NUM(J)
    [M:BPOI3]BPRVCR(K)=[M:BPOI]BPRVCR(J)
    [M:BPOI3]FBPRVCR(K)=[M:BPOI]FBPRVCR(J)
    [M:BPOI3]DUDDAT(K)=[M:BPOI]DUDDAT(J)
    [M:BPOI3]NETAMT(K)=[M:BPOI]NETAMT(J)  # Open amount column
    [M:BPOI3]NETAMTLOC(K)=[M:BPOI]NETAMTLOC(J)  # Open amount column in ledger currency
    [M:BPOI3]SNS(K)=[M:BPOI]SNS(J)
    [M:BPOI3]SAC(K)=[M:BPOI]SAC(J)
    [M:BPOI3]BPR(K)=[M:BPOI]BPR(J)
    [M:BPOI3]FCY(K)=[M:BPOI]FCY(J)
    [M:BPOI3]BPRDATVCR(K)=[M:BPOI]BPRDATVCR(J)
    [M:BPOI3]ORIGAMTCUR(K)=[M:BPOI]ORIGAMTCUR(J)
    [M:BPOI3]ORIGPAYCUR(K)=[M:BPOI]ORIGPAYCUR(J)
    [M:BPOI3]ORIGTMPCUR(K)=[M:BPOI]ORIGTMPCUR(J)
    [M:BPOI3]PREVNET(K)=[M:BPOI]PREVNET(J)
    [M:BPOI3]AMTCUR(K)=[M:BPOI]AMTCUR(J)
    [M:BPOI3]PAYCUR(K)=[M:BPOI]PAYCUR(J)
    [M:BPOI3]TMPCUR(K)=[M:BPOI]TMPCUR(J)
    [M:BPOI3]TYPDUD(K)=[M:BPOI]TYPDUD(J)
    [M:BPOI3]ACCNUM(K)=[M:BPOI]ACCNUM(J)
    [M:BPOI3]DUDLIG(K)=[M:BPOI]DUDLIG(J)
    [M:BPOI3]PAYNUM(K)=[M:BPOI]PAYNUM(J)
    [M:BPOI3]PAYSTATUS(K)=[M:BPOI]PAYSTATUS(J)
    [M:BPOI3]REF(K)=[M:BPOI]REF(J)
    [M:BPOI3]DIFAMT(K)=[M:BPOI]NETAMT(J)-[M:BPOI]AMTTONET(J)
    [M:BPOI3]DIFAMT(K)=abs([M:BPOI]NETAMT(J)-[M:BPOI]AMTTONET(J))
    [M:BPOI3]BIDOBJ = "GAS"
    [M:BPOI3]BIDCLE1 = [M:BPOI]NUM(J)
    [M:BPOI3]BIDCLE2 = [M:BPOI]TYP(J)
    # Open item totals - these are always going to be the total of ALL open item records
    ITEMTOTAL += [M:BPOI]NETAMT(J)
    ITEMLINES += 1
    NETTOTAL += [M:BPOI3]AMTTONET(K) # Only calc net amounts
    K += 1  # includes all lines now
Next

# Used in NET_RESULT routine
[M:BPOI3]NB = K

# Even if net total = 0 the amounts may need to be re-allocated because it is zero'd out above
If WSEL > 0 : Gosub NET_RESULT : Endif

[M:BPOI3]SELTOT = NETTOTAL   # Total amount of calc / marked / selected line items
[M:BPOI3]SELITEM = WSEL      # No. of calc / marked / selected line items

If WSEL > 0
  Gosub LOADGRID_CALC
Else
  # Totals section
  [M:BPOI]NBITEM = ITEMLINES
  [M:BPOI]TOTITEM = ITEMTOTAL
  # Refresh screen
  Affzo [M:BPOI]
  # If no records are returned based on criteria
  Call ERREUR(mess(99,100,1)) From GESECRAN
Endif

Return

#####################################################################################################
# Load the Grid based upon the sort criteria
$LOADGRID_CALC

NOL = 0

# Include all lines, but the lines that are checked put at the top
Case [M:BPOI]TRI
  When 1 # Due date
    [M:BPOI]=[M:BPOI3]
     Sorta [M:BPOI]NB [M:BPOI]NB Order By abs([M:BPOI]MRK(indice)-2),[M:BPOI]DUDDAT(indice),[M:BPOI]ACCNUM(indice),[M:BPOI]DUDLIG(indice) # Asc
  When 2 # Source date
    [M:BPOI]=[M:BPOI3]
     Sorta [M:BPOI]NB [M:BPOI]NB Order By abs([M:BPOI]MRK(indice)-2),[M:BPOI]BPRDATVCR(indice),[M:BPOI]ACCNUM(indice),[M:BPOI]DUDLIG(indice) # Asc
  When 3 # Document type
    [M:BPOI]=[M:BPOI3]
     Sorta [M:BPOI]NB [M:BPOI]NB Order By abs([M:BPOI]MRK(indice)-2),[M:BPOI]TYP(indice),[M:BPOI]ACCNUM(indice),[M:BPOI]DUDLIG(indice) # Asc
Endcase

For I=0 To [M:BPOI]NB-1
  [M:BPOI]BIDCLE1 = [M:BPOI3]NUM(I)
  [M:BPOI]BIDCLE2 = [M:BPOI3]TYP(I)
  NOL += 1
Next

[M:BPOI]CALC = 1

# Update totals to Selection totals section
[M:BPOI]NBITEM = ITEMLINES
[M:BPOI]TOTITEM = ITEMTOTAL

# Refresh screen
Affzo [M:BPOI]

# If no records are returned based on criteria
If NOL = 0
  Call ERREUR(mess(99,100,1)) From GESECRAN
Endif

Gosub HIGHLIGHT

Return

#####################################################################################################
# Display the grid line in colors based upon the netting amount
$HIGHLIGHT_LINE

# reinitialize style
Chgstl [M:BPOI]NB(nolign-1)  With ""
[M:BPOI]HIGHLIGHT = 0

# Only highlight selected lines
If [M:BPOI]MRK(nolign-1) = 2
  If [M:BPOI]NETRES(nolign-1) = 0   # Balanced netting
    Chgstl [M:BPOI]NB(nolign-1) With "NET2"
  Else
    # If [M:BPOI]NETRES(nolign-1) <> 0   # Partial balance remaining
    Chgstl [M:BPOI]NB(nolign-1) With "NET3"
  Endif
  [M:BPOI]HIGHLIGHT = 1
Endif

Return

#####################################################################################################
# Display the grid lines in colors based upon the netting amount
$HIGHLIGHT

[M:BPOI]HIGHLIGHT = 1

# reinitialize style
Chgstl [M:BPOI]NB  With ""

# application style
For I = 0 To [M:BPOI]NB-1
  # Only highlight selected lines
  If [M:BPOI]MRK(I) = 2
    If [M:BPOI]NETRES(I) = 0   # Balanced netting
      Chgstl [M:BPOI]NB(I) With "NET2"
    Else
      # If [M:BPOI]NETRES(I) <> 0   # Partial balance remaining
      Chgstl [M:BPOI]NB(I) With "NET3"
    Endif
  Endif
Next I

Return

#####################################################################################################
# Display the grid lines as normal
$UNHIGHLIGHT

[M:BPOI]HIGHLIGHT = 0

# reinitialize style
Chgstl [M:BPOI]NB  With ""

Return

#####################################################################################################
# Adjust the Netting amounts as needed
$NET_RESULT

Local Decimal RNET

# Total net amount in NETTOTAL from loadgrid_calc routine
RNET = NETTOTAL

# Find balance to apply
# Initial Debit balance
If RNET > 0
  For I=0 To K-1
    If [M:BPOI3]AMTTONET(I) > 0
      [M:BPOI3]NETRES(I) = min([M:BPOI3]AMTTONET(I),RNET)
      RNET -= [M:BPOI3]NETRES(I)
    Endif
    If RNET = 0 : Break : Endif
  Next
  For I=0 To K-1
    If [M:BPOI3]AMTTONET(I) < 0
      [M:BPOI3]NETRES(I) = max([M:BPOI3]AMTTONET(I),RNET)
      RNET-= [M:BPOI3]NETRES(I)
    Endif
    If RNET = 0 : Break : Endif
  Next
Elsif RNET < 0
# Initial Credit balance
  For I=0 To K-1
    If [M:BPOI3]AMTTONET(I) > 0
      [M:BPOI3]NETRES(I) = 0
    Endif
  Next
  For I=0 To K-1
    If [M:BPOI3]AMTTONET(I) < 0
      [M:BPOI3]NETRES(I) = max([M:BPOI3]AMTTONET(I),RNET)
      RNET -= [M:BPOI3]NETRES(I)
    Endif
    If RNET = 0 : Break : Endif
  Next
Endif

# Update the totals
NETTOTAL = 0
For I=0 To K-1
  If [M:BPOI3]MRK(I) = 2
    [M:BPOI3]AMTTONET(I) = [M:BPOI3]NETAMT(I) - [M:BPOI3]NETRES(I)
    NETTOTAL += [M:BPOI3]AMTTONET(I)
    # If Netting amount was set to 0 then Unselect the line
    If [M:BPOI3]AMTTONET(I) = 0
      [M:BPOI3]MRK(I) = 1
      WSEL -= 1
    Endif
  Endif
Next

Return

