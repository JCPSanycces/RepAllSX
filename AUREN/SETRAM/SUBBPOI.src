## Section automatically added (screen BPOINET) 04/11/2013 19:58:04 (ROFLI)
## Section automatically added (screen BPOINETBAS) 11/01/2013 23:33:29 (BESPR)
#####################################################################################################
Subprog C_CPYSEL(VALEUR)
Variable Char    VALEUR()

If [F:CPY]CPYLEGFLG <> 2
  mkstat=2 : GMESSAGE=mess(130,121,1)
Endif
Local Char DEVLED(GLONCUR)
Call SETMAINREF(VALEUR,GTYPGEN,GTYPANA) From CPTDIV
Call LECMAINPLAN(GTYPGEN,VALEUR,[M]COA) From CPTDIV
Call C_CPY(VALEUR) From CPTTRT
If VALEUR <> [M]CPYSEL
  # Reset the sites to All
  [M]ALLFCY = 2 : [M]FCYSEL = ""
  # Reset the currency to the company currency
  If [F:CPY]ACCCUR <> ""
    Effzo [M]CURSEL
    [M]CURSEL = [F:CPY]ACCCUR
  Endif
  Gosub CLEAR_GRID
Endif

End

#####################################################################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR

Call INIALLFCY(VALEUR,[M]CPYSEL) From CPTTRT
If VALEUR = 2
  Effzo FCYSEL : Grizo FCYSEL
Else
  Actzo FCYSEL
Endif

End

#####################################################################################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR <> [M]ALLFCY
  Gosub CLEAR_GRID
Endif
If VALEUR = 2
  Effzo FCYSEL : Grizo FCYSEL
Else
  Actzo FCYSEL
Endif

End

#####################################################################################################
Subprog AS_FCYSEL(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY = 2 : mkstat = 1 : End : Endif
End

#####################################################################################################
# After change routine
# Clear the grid if a change was made
Subprog AM_FCYSEL(VALEUR)
Variable Char    VALEUR()
Gosub CLEAR_GRID
End

#####################################################################################################
Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR

If VALEUR <> [M]ALLSAC
  Gosub CLEAR_GRID
Endif
If VALEUR = 2
 Effzo GRPSAC, SACSEL, SACACC
 Grizo GRPSAC, SACSEL, SACACC
Else
 Actzo GRPSAC
 If [M]GRPSAC<>"" : Grizo SACSEL : Else : Actzo SACSEL : Endif
Endif

End

#####################################################################################################
Subprog AS_GRPSAC(VALEUR)
Variable Char    VALEUR()

If [M]ALLSAC = 2
 mkstat = 1 : End
Else
 Local Char DEVLED(GLONCUR)
 Call SETMAINREF([M]CPYSEL,GTYPGEN,GTYPANA) From CPTDIV
 Call LECMAINPLAN(GTYPGEN,[M]CPYSEL,[M]COA) From CPTDIV
Endif

End

#####################################################################################################
Subprog C_GRPSAC(VALEUR)
Variable Char    VALEUR()

If VALEUR <> [M]GRPSAC
  Gosub CLEAR_GRID
Endif

If VALEUR <> ""
 Effzo SACSEL, SACACC : Grizo SACSEL
Else
 Actzo SACSEL
Endif

End

#####################################################################################################
# Before entry
Subprog AS_SACSEL(VALEUR)
Variable Char    VALEUR()

If [M]ALLSAC = 2 | [M]GRPSAC<>""
 mkstat=1 : End
Else
 Local Char DEVLED(GLONCUR)
 Call SETMAINREF([M]CPYSEL,GTYPGEN,GTYPANA) From CPTDIV
 Call LECMAINPLAN(GTYPGEN,[M]CPYSEL,[M]COA) From CPTDIV
Endif

End

#####################################################################################################
# After change routine
# Clear the grid if a change was made
Subprog AM_SACSEL(VALEUR)
Variable Char    VALEUR()

Read [GAC]GAC1 = [M]COA;VALEUR
If !fstat
 [M]SACACC=[F:GAC]ACC
Else
 Raz [M]SACACC
Endif

Gosub CLEAR_GRID

End

#####################################################################################################
# After change routine
# Reset CUR but doesnt like it if you Clear the grid here
Subprog AM_BPRSEL(VALEUR)
Variable Char    VALEUR()

# Reset the currency to the BP currency
If [F:BPR]CUR <> ""
  Raz [M]CURSEL
  [M]CURSEL = [F:BPR]CUR
  Affzo [M]CURSEL
Endif

Gosub CLEAR_GRID

End

#####################################################################################################
