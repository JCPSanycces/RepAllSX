If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "1"
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")=1  X3-101376
 Chgfmt [M:BIC1]PJTH   With "-K:40X"           # Hide PJTH
 Chgfmt [M:BIC3]PJTLIN With "-K:40X"           # Hide PJTLIN column
 Chgfmt [M:BIC3]PCCCOD With "-K:40X"           # Issue X3-149911 - 2019-07-31 by UB : Disabling Cost type column
Elsif func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "2"
