#<AdxTL>@(#)4.0.0.0 $Revision$
GTEST=0
Raz GPILOBJ, GPILCOD
Call OBJET("BIC",GBIDC1,"1") From GOBJET
End
#
# Issue X3-195162, X3-195181, X3-195182 - 2020-06-23 by MRDAB/MAPON : Defualt bank account at the invoice level - on open item
# Issue X3-197349 - 2020-05-20 Bader: SETBOUT: disable "Open items" if coming from MODECHE
# US X3-190239  - 2020-04-14 by JUCON : Control of Invoice validation sequence (TBAI Slice 2)
# Issue X3-181159 - 2020-02-21 by MWA : Adding South America entry points
# Issue X3-101376 - 2018-07-23 by MWA : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
# Issue X3-99385  - 2018-07-12 by CBO : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#

# Issue X3-99385 : all AFNC.PARAM() with activity code are replaced by SUBBIC2.FIN_PARAM()
#* X3-112211 SMO  Implement control when reading parameters managed by activity code
#* X3-112863 DNE  Fill complementary tables for tax invoices (e. g. UAE).
#* X3-146200 DNE  Prevent wrong GL account in DB after call to GESGAS

#
$ACTION
Case ACTION
 When "DEFTRANS"    : Gosub DEFTRANS
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE  ## 101905.n
 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TITRES
 When "AFFMASK"     : Gosub AFFMASK
 When "FILTRE"      : Gosub FILTRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "CREATION"    : Gosub CREATION
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "AVANT_MODFIC": Gosub AVANT_MODFIC
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "LIENS"       : Gosub LIENS
 When "STYLE"       : Gosub STYLE #97101 RICAR - 50001 Law decret
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "ABANDON"     : Gosub ABANDON
 When "VERROU"      : Gosub VERROU
 When "DEVERROU"    : Gosub DEVERROU
 When "FERME"       : Gosub FERME
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "STATUT"      : Gosub STATUT
 When "AVANT_SUITE" : Gosub AVANT_SUITE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FIN"         : Gosub FIN
 When "AP_IMPRIME"  : Gosub RELIT From GOBJSUB
Endcase
Return

$DEFTRANS
#If GFLAG=""
# If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
# Call PARAMUTIL("TRNFACC",GFLAG,"","") From SUBAUS
#Endif
Return

$VERROU
[L]SYMBHAE = "HAE"+[F:SIH]NUM+"\"+[F:SIH]GTE
Lock =SYMBHAE With lockwait=0
If fstat
 Unlock =SYMBOLE
 [L]OK=0
Endif
Return

$DEVERROU
Unlock =SYMBHAE
Return

$FERME
GTUNCPT(6) = 0
##### BESPR 87307 06/14/2013 # Intercompany enhancement
If GFONC1 = "GESBICI"
 Gosub INTCPY_FERME From INTCPYLIB
 Gosub GL_INTCPY_FERME From INTCPYLIB #115813
 Raz GFONC1
Endif
If dim (GLBINVCA_ON) > 0 : Kill GLBINVCA_ON : Endif

# Issue X3-170918 2020-01-21 JUCON Control Software TicketBai
If dim (GLBACTKSP_ON) > 0  : Kill GLBACTKSP_ON   : Endif
If dim (GLBACTCTSW_ON) > 0 : Kill GLBACTCTSW_ON  : Endif #X3-206682 Update INVTYPSPA field with KSP act. code
# Issue X3-170918 2020-01-21 end

Return

$FIN
Return

$AVANT_OUVRE
# 101905.sn
# Update GUSRFCY and GUSRCPY based upon the menu FUNCTION not GFONCTION so Site Authorization works properly
Local Char OFONCTION(10)
OFONCTION = GFONCTION
If GFONC1 = "GESBICI"
  GFONCTION  = GFONC1
  Call AUTORIS From EXEFNC
  Raz CRE, MODI, SUPPR
  If GNBAUZ=0
   If GNBSITE=0
    GMESSAGE = mess(33,104,1)  # You must first create a site in the folder
    OK = 0
    Return
   Else
    GMESSAGE = mess(1,123,1)  # Unauthorized function
    OK = 0
    Return
   Endif
  Elsif GUSRFCY(1)="\"
   CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
   MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
   SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
  Endif
Endif
GFONCTION = OFONCTION
# 101905.en
Return

$RESET_AUZ
# 101905.sn
# Update GUSRFCY and GUSRCPY based upon the menu FUNCTION not GFONCTION so Site Authorization works properly
# The variable is getting reset somewhere after AVANT_OUVRE and before AS_FCY; it also gets reset on Save
Local Char OFONCTION(10)
OFONCTION = GFONCTION
If GFONC1 = "GESBICI"
  GFONCTION  = GFONC1
  Call AUTORIS From EXEFNC
Endif
GFONCTION = OFONCTION
# 101905.en
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
Return

$OUVRE
If GTUNCPT(6) : GMESSAGE = mess(247,199,1) : OK = 0 : Return : Endif
GTUNCPT(6) = 1
Local Char    MESSA(255) , IDENT(20) , TRANSAC(10) , SYMBHAE(35)
Local Char    JOURNAL(GLONJOU), TAXE(GLONVAT), XPARAM(10)
Local Char    DEVORG(GLONCUR), DEVORG1(GLONCUR), DEVDES(GLONCUR)
Local Char    VALC1(20), VALC2(20), VALC3(20)
Local Char    AUZFCY(15)
Local Char    CRITSUPPR (250)
Local Decimal SOMME , MONTANT , BASE , BASTVA , MONTMIN , MONTPRO
Local Decimal COURS
Local Libelle CHGDAT
Local Integer ACCFCY
Local Integer WVALFAC : WVALFAC=0
Local Decimal EXOTAX
Local Integer EXERCICE, PERIODE
Local Decimal CURRND
Local Integer FACTAVO : FACTAVO=0
Local Integer STAT , I , J , K , MAXLIG , SEQ, SIGN
Local Integer TVA, MODFAC, MODECH, CHGECHE, SAVCONS
Local Integer INDLED, INDAXI, NLED
# 2019-08-13 DNE INSERT BEGIN (X3-146200)
Local Integer SAVNBTYPLED
Local Integer SAVTYPLED(1..dim(GTYPLED))
# 2019-08-13 DNE INSERT END
Local Integer MAJANA, AXE, LIGANA
Local Integer CAS, VU, NOL
Local Char    DEPMOD(10)
Local Decimal DSCRAT
#--- variable local pour gestion adresses -----#
Local Char    BPRNAM(GLONNAM)(2)
Local Char    BPRADR(5)
Local Char    BPAADDLIG(GLONADL)(3)
Local Char    CRY(GLONCRY)
Local Char    CRYNAM(GLONNCY)
Local Char    SAT(GLONSAT)
Local Char    POSCOD(GLONPOS)
Local Char    CTY(GLONCTY)
Local Char    RETCPY(GLONCPY), LASNUM   ##### CATUA 87307 Intercompany enhancement
Local Integer RCRINTCO
Local Integer ADRVAL            #LTA.sn
#Gosub OUVRE_LTA From TRTTAXUSA  #LTA.en   # 106867.o
Gosub OUVRE_LTA From TRTTAXSST  #LTA.en   # 106867.n
Local Integer ASTATUS

CAS = 1
Gosub DECLARE_GLOBAL From SUBBICS
Gosub DECLARE_TABLE  From SUBBICS
Gosub DECLARE_MASQUE From SUBBICS

Gosub OUVRE_ACT_CODE From SUBBIS2 # Issue X3-99385
Raz LASNUM

##AP/AR RecurInv
Raz RCRINTCO

If GFONC1="GESBICX"
   GFONC1="GESBICI"
   RCRINTCO=1
Endif
##AP/AR RecurInv End

If I : Close Local File [ACV] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev([F:DNO])=0 : Local File DNODEBNOT [DNO] : Endif #issue X3-69271 - 2019-02-12 by MANOW

# Les masques BIHPER (périodes) et SAISTT (stats) sont ouverts en cas de besoin
For MA=0 To NBMASK
 Gosub SETMASK From =WINPROG
Next MA
Raz [M:VTL], [M:VT2]

##### BESPR 87307 05/14/2013 # Intercompany enhancement
If GFONC1 = "GESBICI"
 Gosub INTCPY_OUVRE From INTCPYLIB
 Gosub GL_INTCPY_OUVRE From INTCPYLIB #115813
Endif

# BRBAN 105200#US2 Need to update invoice REVCANSTA
Global Integer GLBINVCA_ON : GLBINVCA_ON = 1
If func AFNC.ACTIV("INVCA")>0
  If !clalev([F:ISIH]) : Local File SINVOICE [ISIH] : Endif
  GLBINVCA_ON = 2
Endif
#angre X3-133989
# Issue X3-145480 2019-06-18 Bader begin check activity code KSW
If func AFNC.ACTIV("KSW") Then
# Issue X3-145480 2019-06-18 Bader end
  Gosub OUVRE_QRC From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
# Issue X3-145480 2019-06-18 Bader begin check activity code KSW
Endif
# Issue X3-145480 2019-06-18 Bader end
#-
# Issue X3-170918 2020-01-21 JUCON Control Software TicketBai
#vIni X3-206682 Update INVTYPSPA field with KSP act. code
Global Integer GLBACTCTSW_ON: GLBACTCTSW_ON = 1
Global Integer GLBACTKSP_ON : GLBACTKSP_ON = 1
If func AFNC.ACTIV("CTSW")  : GLBACTCTSW_ON = 2 : Endif
If func AFNC.ACTIV("KSP")   : GLBACTKSP_ON = 2  : Endif
#End X3-206682 Update INVTYPSPA field with KSP act. code
# Issue X3-170918 2020-01-21 end

Return

#### CATUA 87307 Intercompany enhancement
$TITRES
  ##Display 'Customer intercompany invoices' to the title bar
  If GFONC1 = "GESBICI" : Call TEXTE(51089,TIT)From OBJDIV : Endif
Return
#### Intercompany enhancement End

##### BESPR 87307 6/21/13 # Intercompany enhancement
$AFFMASK
If GFONCTION = "GESBIC" and GFONC1 <> "GESBICI" : Chgfmt [M:BIC3]CPYLIN With "-KP:10X" : Endif  # Hide CPYLIN column
Return
#####

$FILTRE
FILTSUP = "ORIMOD=3"

##AP/AR RecurInv
If GFONC1 = "GESRCC" | (dim(RCRINTCO) > 0 and RCRINTCO = 1)
  If [M:RCR0]NUM ="" & [M:RCR1]RCRSTA <2
    FILTSUP += "and STA <> 2 and INVTYP = 1 and RCRNUM = '' and FCY = '" +[M:RCR0]FCY + "'"
  Endif
Endif
##AP/AR RecurInv End

##### BESPR 87307 05/15/2013 and 6/03/13 # Intercompany enhancement
If GFONC1 <> "GESBICI"
  FILTSUP += "and NBRCPY<2"
Else
  FILTSUP += "and NBRCPY>0"
Endif
#####
Return


$INICRE
# BRBAN 105200#US2 Updating invoice
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Read [F:ISIH]SIH0 = [M:BIC1]INVNUM
    If !fstat
      [F:ISIH]REVCANSTA = 1
      Rewrite [F:ISIH]
      If fstat : Call FSTA("ISIH") From GLOCK : GOK=0 : Endif
    Endif
    [F:SIH]REVCANSTA = 2
  Endif
Endif
If  GOK=0   : Goto AB_CRE : Endif
#-

# Type de facture
mkstat=0 : Call CONT_SIVTYP([F:SIH]SIVTYP)
If mkstat  : GOK = 0 : Goto AB_CRE
Else       : TRANSAC = [F:TSV]COD2
Endif

[F:SIH]ORIMOD = 3 : # Module tiers

If [F:SIH]RATDAT=[0/0/0]
 [F:SIH]RATDAT = [F:SIH]ACCDAT
 [M]RATDAT     = [F:SIH]RATDAT
Endif

#--- Détermination du type de pičce
IDENT = [M:BIC0]GTE
If IDENT = ""
 Call EVALAUTO(TRANSAC,"GTE",IDENT)
 If IDENT = ""
  GMESSAGE = mess(27,110,1)   # Type de pičce non défini
  GOK=0 : Goto AB_CRE
 Endif
Endif

#--- Contrôles sur type de pičce
Gosub CONT_GTE
If GOK=0 : Goto AB_CRE : Endif
If [F:GTE]MANNUM=2
 If vireblc([M]NUM,2)=''
  If [F:GTE]COU=''
   GMESSAGE = mess(100,121,1) :  # Numéro de facture non renseigné
   zonsui = "[M]NUM" : GOK=0 : Goto AB_CRE
  Endif
 Else
  # Contrôle la non existence de GTE;NUM dans les échéances et les pičces cpt
  mkstat=0 : Call EXISTE([M:BIC0]GTE,[M:BIC0]NUM)
  Gosub DEFAUT From =PROGOBJ
  If mkstat : zonsui = "[M]NUM" : GOK=0 : Goto AB_CRE : Endif
 Endif
Endif
#--- Détermination du journal
JOURNAL = [M:BIC0]JOU
Gosub DEFJOU
If GOK=0 : Goto AB_CRE : Endif

#--- Contrôles sur journal
Gosub CONT_JOU
If GOK=0 : Goto AB_CRE : Endif
Call GETSOC([F:SIH]FCY) From DEVSUB
If [F:GTE]MANNUM<>2 | vireblc([M]NUM,2)=''
 If func SUBBIC2.FIN_PARAM(GAC_KAG, "ARGNUM",[F:SIH]CPY)<>"2"
  Call NUMERO([F:GTE]COU,[F:SIH]FCY,[F:SIH]ACCDAT,JOURNAL,[F:SIH]NUM,STAT) From SUBANM
  If GOK<0 : Goto AB_CRE
  Elsif GOK<1 | STAT
   GOK=0
   If STAT
    # Problčme lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    GMESSAGE=mess(104,117,1)-"("+[F:GTE]COU+") : "+MESSA
   Endif
   Goto AB_CRE
  Else
   # ----------------------------------------------------------- #
   # Digital signature                                           #
   # ----------------------------------------------------------- #
   If func AFNC.ACTIV("DKS")
       Local Char DKSORIG : DKSORIG = "BIC0"
       Local Integer DKSRET : DKSRET  = 1
       Gosub DKS_INICRE_TRIGGER From DKSLIB
       If DKSRET = 0 : Return : Endif
   Endif
   # ----------------------------------------------------------- #
  Endif
 Else
  Local Char    TYPDOC(GLONADI)
  Local Integer VU
  Filter [ADI] Where NUMTAB = 362
  For [ADI]CODE
   VU = instr(1,[F:ADI]A1,num$([F:SIH]INVTYP))
   If VU
    TYPDOC = [F:ADI]CODE : Break
   Endif
  Next
  Filter [ADI]
  If !VU
   ## Cette catégorie de facture n'est associée ŕ aucun type de document
   GOK = 0 : GMESSAGE = mess(4,8890,1)
   Goto AB_CRE
  Endif
  Call NUMEROARG([F:GTE]COU,[F:SIH]FCY,TYPDOC,2,[F:SIH]ACCDAT,[F:SIH]VAC,[F:SIH]NUM,[F:SIH]CAI,[F:SIH]DATVLYCAI,STAT) From SUBANMARG
  If GOK<0 : Goto AB_CRE
  Elsif GOK<1 | STAT
   GOK=0
   If STAT
    # Problčme lors de la récupération du compteur
    Gosub MESSAGE From SUBANMARG
    GMESSAGE=mess(104,117,1)-"("+[F:GTE]COU+") : "+MESSA
   Endif
   Goto AB_CRE
  Endif
 Endif
Endif

# Législation Belge : VCS Sequencing number --str
If func AFNC.ACTIV("KBE") Then
 # Pour les factures et Notes de débit
  If  find([F:SIH]INVTYP,1,3)>0 Then
  If !GIMPORT or [M:BIC1]BELVCS=""
    Call BELSETVCS([F:SIH]FCY,[F:SIH]ACCDAT,[F:SIH]BELVCS,STAT,MESSA) From INVVCSLIB
    If GOK<0
     Goto AB_CRE
    Elsif GOK<1 | STAT
     GOK=0
     If STAT
      GMESSAGE=MESSA
     Endif
     Goto AB_CRE
    Else
     [M:BIC1]BELVCS=[F:SIH]BELVCS
     If !GIMPORT : Affzo [M:BIC1]BELVCS : Endif
    Endif
  Endif
 Endif
Endif
#Localisation Belge --end

Call ACCNUM([F:SIH]ACCNUM) From SUBGAS
CHGDAT = 1
Gosub INIMOD
Return

$CONT_GTE
Call CONTGTE(IDENT,GCURLEG,"") From SUBGTE
If mkstat : Raz mkstat : GOK=0 : Return : Endif
If [F:GTE]ENAFLG<>2    # Type de pičce : GTE \ Fiche inactive
 If !GIMPORT  : GMESSAGE = mess(22,107,1)-":"-IDENT+"\"+mess(2,126,1)
 Else         : GMESSAGE = mess(22,107,1)-IDENT-":"-mess(2,126,1)
 Endif
 zonsui = "[M]SIVTYP" : GOK=0 : Return
Elsif [F:GTE]ACS<>""    # Code d'accčs
 If func FINMIS_SYRA.CTL_EXE(GACTX, [F:GTE]ACS, GMESSAGE)<>[V]CST_AOK
  GMESSAGE = [F:GTE]ACS-GMESSAGE    # Vous n'avez pas les droits d'exécution
  zonsui = "[M]SIVTYP" : GOK=0 : Return
 Endif
Endif
If IDENT<>[F:SIH]GTE
 mkstat=0
 If func FINMIS_SYRA.CTL_VLYDAT(GACTX, [F:SIH]ACCDAT, [F:GTE]VLYSTR, [F:GTE]VLYEND, GMESSAGE)<>[V]CST_AOK
  GMESSAGE=IDENT-GMESSAGE : mkstat = 2
  zonsui="[M]ACCDAT" : GOK=0 : Return
 Endif
 [F:SIH]GTE = IDENT : [M:BIC0]GTE = IDENT
Endif
If [F:GTE]VCRREA<>2
 # Type de pičce non réel
 GMESSAGE=mess(59,119,1)
 zonsui="[M]SIVTYP" : GOK=0 : Return
Endif
Return

$CONT_JOU
If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
Call CONTJOU(JOURNAL,GCURLEG,"") From SUBJOU
If mkstat : Raz mkstat : GOK=0 : Return : Endif
If [F:JOU]ENAFLG<>2    # Journal : JOU \ Fiche inactive
 If !GIMPORT : GMESSAGE = mess(13,105,1)-":"-JOURNAL+"\"+mess(2,126,1)
 Else        : GMESSAGE = mess(13,105,1)-JOURNAL-":"-mess(2,126,1)
 Endif
 zonsui = "[M]SIVTYP" : GOK=0 : Return
Elsif [F:JOU]ACS<>""      # Code d'accčs
 If func FINMIS_SYRA.CTL_EXE(GACTX, [F:JOU]ACS, GMESSAGE)<>[V]CST_AOK
  GMESSAGE = [F:JOU]ACS-GMESSAGE
  zonsui = "[M]SIVTYP" : GOK=0 : Return
 Endif
Endif
If [F:JOU]FCY<>""      # Société/site
 Call VERSOC([F:JOU]FCY,[M]CPY,[M]FCY,[F:JOU]JOU) From CFYSUB
 If mkstat
  zonsui = "[M]FCY" : GOK=0 : Return
 Endif
Endif
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = [F:JOU]JOU-mess(8,106,1)-[F:GTE]TYP : # Journal non autorisé sur le type de pičce
 zonsui = "[M]SIVTYP" : GOK=0 : Return
Endif
Return

$AB_CRE
Return

Subprog EVALAUTO(TRANSAC,ZONE,VALEUR)
Value Char TRANSAC(), ZONE()
Variable Char VALEUR()
VALEUR=""
Read [GAG]GAG0 = TRANSAC;0;ZONE
If !fstat
 Local Char PROG(20)
 PROG = "WMGAU"+TRANSAC
 Onerrgo RIEN
 If !clalev([F:TB0])  : Local File SINVOICE [TB0] : Endif
 [F:TB0] = [F:SIH]
 Gosub OUVRE From = PROG
 Gosub LIENS From = PROG
 VALEUR = evalue([F:GAG]FORCLC)
 Onerrgo
Endif
End

$RIEN
Resume

$INIMOD
[F:SIH]AMTNOT = [M]AMTNOT
[F:SIH]AMTATI = [M]AMTATI
[F:SIH]NBRTAX = 0
Raz [F:SIH]TAX, [F:SIH]BASTAX, [F:SIH]AMTTAX
Raz [F:SIH]EXEAMTTAX

If GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP))
 Call DSCRAT([M:BIC1]DEP,DSCRAT) From INVDEPLIB
 If func CDACUR_SYRA.GET_CURRND(GACTX, [M:BIC1]CUR, CURRND, GMESSAGE)<>[V]CST_AOK
  GOK = 0 : Return
 Endif
Endif

If func SUBBIC2.FIN_PARAM(GAC_KAG, "ARGTAX",[F:SIH]CPY)<>"2"
 For I=0 To [M]NBLIG-1
  BASTVA = [M]AMTNOTLIN(I)
  TVA = 0
  TAXE = [M]TAX1(I) : MONTANT = [M]AMTTAX1(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTTAX1(I)
  Gosub SET_TAXE
  TAXE = [M]TAX2(I) : MONTANT = [M]AMTTAX2(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTTAX2(I)
  Gosub SET_TAXE
  TAXE = [M]VAT (I) : MONTANT = [M]AMTVAT (I) : BASE = BASTVA : EXOTAX = [M]EXEAMTVAT(I)
  TVA = 1
  If DSCRAT<>0 & [M]FLGDEP(I)=2 & (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP)))
   BASE = arr(BASE*(1-(DSCRAT/100)), CURRND)
  Endif
  Gosub SET_TAXE
 Next I

 # Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Comment out - Invoice Creation)
# If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
#  If GREP="C" and [M:BIC0]NUM = "" : [M:BIC0]NUM=[F:SIH]NUM : Endif
#   Local Integer ERR
#   Local Char ERRMSG(250)
#   Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXSST
#   [F:SIH]AMTATI = [M:BIC1]AMTATI
#   Gosub CREMOD_LTV From TRTTAXSST
# Endif
 # Issue 117131.e

Else
 ## Code activité KAB est actif :
 ##   1°) On calcule par code taxe les montants "théoriques" de taxe et on les conserve dans les
 ##       champs [F:SIH]THEAMTTAX(0..4).
 ##   2°) On calcule les montants réels des taxes en fonction des montants théoriques et des seuils
 ##       et on les conserve dans [F:SIH]AMTTAX et [F:SIL]AMTTAX1,[F:SIL]AMTTAX2,[F:SIL]AMTVAT
 ##   3°) On recalcule les montants TTC (AMTATILIN, AMTATI)
 For I=0 To [M]NBLIG-1
  BASTVA = [M]AMTNOTLIN(I)
  TVA = 0
  ## Taxe parafiscale/spéciale => Perception TVA
  TAXE = [M]TAX1(I) : MONTANT = [M]THEAMTTAX1(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTTAX1(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  TAXE = [M]TAX2(I) : MONTANT = [M]THEAMTTAX2(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTTAX2(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  ## Taxe provinciale entrée
  TAXE = [M]TAXRCP(I) : MONTANT = [M]THEAMTTAXR(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTRCP(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  ## Taxe provinciale sortie
  TAXE = [M]TAXISS(I) : MONTANT = [M]THEAMTTAXI(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTISS(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  ## Autre taxe provinciale 1
  TAXE = [M]TAXOTH1(I) : MONTANT = [M]THEAMTOTH1(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTOTH1(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  ## Autre taxe provinciale 2
  TAXE = [M]TAXOTH2(I) : MONTANT = [M]THEAMTOTH2(I) : BASE = [M]AMTNOTLIN(I) : EXOTAX = [M]EXEAMTOTH2(I)
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
  ## TVA
  TAXE = [M]VAT (I) : MONTANT = [M]THEAMTVAT (I) : BASE = BASTVA : EXOTAX = [M]EXEAMTVAT(I)
  TVA = 1
  If DSCRAT<>0 & [M]FLGDEP(I)=2 & (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP)))
   BASE = arr(BASE*(1-(DSCRAT/100)), CURRND)
  Endif
  Gosub SET_TAXE
  If TAXE<>"" : [F:SIH]THEAMTTAX(K-1) += MONTANT : Endif
 Next I
 For I=0 To [F:SIH]NBRTAX-1
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(I)) From CPTLEC
  Gosub LECTAX
  If [F:SIH]AMTTAX(I)<SEUIL
   [F:SIH]AMTTAX(I) = 0
  Endif
 Next
 For NOLI=0 To [M]NBLIG-1
  If [M]TAX1(NOLI)<>""
   K = find([M]TAX1(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAX1(NOLI)<>0 : # on a calculé une taxe "théorique" qui n'atteint pas le seuil
    [M]AMTTAX1(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAX1(NOLI)=0 : # On a RAZ la taxe réelle alors qu'on dépasse le seuil
    [M]AMTTAX1(NOLI) = [M]THEAMTTAX1(NOLI)
   Endif
  Endif
  If [M]TAX2(NOLI)<>""
   K = find([M]TAX2(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAX2(NOLI)<>0
    [M]AMTTAX2(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAX2(NOLI)=0
    [M]AMTTAX2(NOLI) = [M]THEAMTTAX2(NOLI)
   Endif
  Endif
  If [M]VAT(NOLI)<>""
   K = find([M]VAT(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTVAT(NOLI)<>0
    [M]AMTVAT(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTVAT(NOLI)=0
    [M]AMTVAT(NOLI) = [M]THEAMTVAT(NOLI)
   Endif
  Endif
  ## Et les 4 taxes provinciales...
  ## 1/ Taxe provinciale entrée...
  If [M]TAXRCP(NOLI)<>""
   K = find([M]TAXRCP(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAXRCP(NOLI)<>0
    [M]AMTTAXRCP(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAXRCP(NOLI)=0
    [M]AMTTAXRCP(NOLI) = [M]THEAMTTAXR(NOLI)
   Endif
  Endif
  ## 2/ Taxe provinciale sortie...
  If [M]TAXISS(NOLI)<>""
   K = find([M]TAXISS(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAXISS(NOLI)<>0
    [M]AMTTAXISS(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAXISS(NOLI)=0
    [M]AMTTAXISS(NOLI) = [M]THEAMTTAXI(NOLI)
   Endif
  Endif
  ## 3/ Autres taxes n°1 ...
  If [M]TAXOTH1(NOLI)<>""
   K = find([M]TAXOTH1(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAXOTH1(NOLI)<>0
    [M]AMTTAXOTH1(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAXOTH1(NOLI)=0
    [M]AMTTAXOTH1(NOLI) = [M]THEAMTOTH1(NOLI)
   Endif
  Endif
  ## 4/ Autres taxes n°2 ...
  If [M]TAXOTH2(NOLI)<>""
   K = find([M]TAXOTH2(NOLI),[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
   If K & [F:SIH]AMTTAX(K-1)=0 & [M]AMTTAXOTH2(NOLI)<>0
    [M]AMTTAXOTH2(NOLI) = 0
   Elsif K & [F:SIH]AMTTAX(K-1)<>0 & [M]AMTTAXOTH2(NOLI)=0
    [M]AMTTAXOTH2(NOLI) = [M]THEAMTOTH2(NOLI)
   Endif
  Endif
  [M]AMTATILIN(NOLI) = [M]AMTNOTLIN(NOLI)+[M]AMTTAX1(NOLI)+[M]AMTTAX2(NOLI)+[M]AMTVAT(NOLI)+[M]AMTTAXRCP(NOLI)+[M]AMTTAXISS(NOLI)
  [M]AMTATILIN(NOLI) += [M]AMTTAXOTH1(NOLI) + [M]AMTTAXOTH2(NOLI)
 Next
 [M]TOTATI = sum([M]AMTATILIN(0..max(nolign,[M]NBLIG)-1))
 [M]AMTATI = sum([M]AMTATILIN(0..max(nolign,[M]NBLIG)-1))
 [F:SIH]AMTATI = [M]AMTATI
 Affzo [M:BIC3]TOTATI : Affzo [M:BIC3]AMTATILIN : Affzo [M:BIC1]AMTATI
Endif

#90370 Cash VAT SPA
Gosub CASH_VAT

##### BESPR 87307 05/14/2013 # Intercompany enhancement
If GAC_INTCO
  # Issue X3-101937 by MRDAB
  Call INTCPY_INIMOD([F:SIH]NUM, 1) From INTCPYLIB
  # Issue end X3-101937
Endif
#####

Case [F:SIH]INVTYP
 When 1,3 : [F:SIH]SNS = +1
 When 2,4 : [F:SIH]SNS = -1
Endcase
For I=0 To min(dim([M:BIC1]DES),dim([F:SIH]DES))-1
 [F:SIH]DES(I) = [M:BIC1]DES(I)
Next I
#--- Controle date de facture par rapport ŕ la facture précédente
If CHGDAT
 Gosub CONTCHRONO
 If GOK<1 : Goto AB_CRE : Endif
Endif
## Initialisation champs FIY, PER rajouté en V150 pour optimisation
[L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX, [F:SIH]CPY, GTYPGEN, [F:SIH]ACCDAT, EXERCICE, PERIODE, GMESSAGE)
[F:SIH]FIY = EXERCICE
[F:SIH]PER = PERIODE

## Gestion des adresses
#Facturé
[F:SIH]BPAINV       = [M:BIC0]BPAINV
[F:SIH]BPRNAM(0)    = [M:BIC0]BPRNAMBIS(0)
[F:SIH]BPRNAM(1)    = [M:BIC0]BPRNAMBIS(1)
[F:SIH]BPAADDLIG(0) = [M:BIC0]BPAADDLIG(0)
[F:SIH]BPAADDLIG(1) = [M:BIC0]BPAADDLIG(1)
[F:SIH]BPAADDLIG(2) = [M:BIC0]BPAADDLIG(2)
[F:SIH]CTY          = [M:BIC0]CTY
[F:SIH]POSCOD       = [M:BIC0]POSCOD
[F:SIH]SAT          = [M:BIC0]SAT
[F:SIH]CRY          = [M:BIC0]CRY
[F:SIH]CRYNAM       = [M:BIC0]CRYNAM
#Payeur
[F:SIH]BPAPAY       = [M:BIC1]BPAPAY
[F:SIH]BPYNAM(0)    = [M:BIC1]BPYNAM(0)
[F:SIH]BPYNAM(1)    = [M:BIC1]BPYNAM(1)
[F:SIH]BPYADDLIG(0) = [M:BIC1]BPYADDLIG(0)
[F:SIH]BPYADDLIG(1) = [M:BIC1]BPYADDLIG(1)
[F:SIH]BPYADDLIG(2) = [M:BIC1]BPYADDLIG(2)
[F:SIH]BPYCTY       = [M:BIC1]BPYCTY
[F:SIH]BPYPOSCOD    = [M:BIC1]BPYPOSCOD
[F:SIH]BPYSAT       = [M:BIC1]BPYSAT
[F:SIH]BPYCRY       = [M:BIC1]BPYCRY
[F:SIH]BPYCRYNAM    = [M:BIC1]BPYCRYNAM

## Si modif d'une facture non validée et imprimée Alors facture passe ŕ non imprimée
If func AFNC.PARAM("FRADGI",[F:SIH]CPY)="2"
 If [F:SIH]STA<>3 & [F:SIH]STARPT=2
  [F:SIH]STARPT = 1
  [M:BIC1]STARPT = 1
  Affzo [M:BIC1]STARPT
 Endif
Endif

If GAC_INTCO & [F:SIH]NBRCPY>1 & [F:SIH]STA<>3
 Call UPD_INTCOFLO(1,2,[F:SIH]NUM,[F:SIH]NBRCPY) From INTCPYLIB2
 If GOK<0 : Return : Endif
Endif

# SAM 110033: Swiss localization: calculate BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]BPRPAY, [M:BIC1]CUR) From SUBBICSWI
  Call CREATE_SWIQRC([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]BPRPAY, [M:BIC1]CUR) From SUBBICSWI
  If not GOK : Return : Endif
Endif
# SAM 110033 END

Return

$CONTCHRONO
If !clalev([F:SIH1]) : Local File SINVOICE [SIH1] : I=1 : Else I=0 : Endif
If !clalev([F:ANM])  : Local File ACODNUM [ANM]   : J=1 : Else J=0 : Endif
Local Char OLD_NUM
Local Integer DEPL,I
Local Char CHAINE(GLONVCR)
Call LEC_GTE_LEG(GCURLEG,[F:SIH]GTE) From CPTLEC

If [F:GTE]COU<>""
  Read [ANM]ANM0 = [F:GTE]COU
  If fstat
   Call RSTA("ANM",[F:GTE]COU) From GLOCK
   STAT = 1 : GOK = 0 : Goto AB_CRE
  Endif
  If [F:ANM]CTLCHR=2      # Le controle de chronologie du compteur est positionné
   JOURNAL = [F:SIH]JOU
   # Pour les anciennes factures
   If JOURNAL = ""
    Gosub TRANSAC : JOURNAL = [F:TSV]JOU
    Gosub DEFJOU
   Endif
   If JOURNAL <> ""
    OLD_NUM = [F:SIH]NUM : OK1 = 1
    Repeat
     Call NUMERO_PREC([F:GTE]COU,[F:SIH]FCY,[F:SIH]ACCDAT,JOURNAL,OLD_NUM,SEQ,STAT) From SUBANM
     If OLD_NUM = [F:SIH]NUM : Gosub CONT_CRONO_NEXT : Break : Endif # Issue X3-195010 - 20200616 by VAVIL : Chronological control is not applied on sales invoice validation
     If STAT : GOK = 0 : Break : Endif
     Read [F:SIH1]SIH0 = OLD_NUM
     If !fstat
      If [F:SIH1]ACCDAT > [F:SIH]ACCDAT
       # Date incorrecte par rapport ŕ la facture précédente
       GMESSAGE = mess(101,121,1)
       zonsui = "[M]ACCDAT" : GOK = 0 : Break
      Endif
      OK1 = 0
     Endif
     # Issue X3-195010 - 20200616 by VAVIL : Chronological control is not applied on sales invoice validation
     If GOK <> 0 : Gosub CONT_CRONO_NEXT : Endif
     # Issue end X3-195010
    Until OK1=0 or SEQ=1
   Endif
  Endif
Endif
If I : Close Local File [SIH1] : Endif
If J : Close Local File [ANM] : Endif
Gosub DEFAUT From =PROGOBJ
Return

$DEFJOU
If JOURNAL="" & TRANSAC<>""
 Call EVALAUTO(TRANSAC,"JOU",JOURNAL)
 If JOURNAL="" : JOURNAL = [F:GTE]DEFJOU : Endif
Endif
If JOURNAL = ""
 # Journal non défini
 GMESSAGE = mess(53,141,1) : GOK=0 : Return
Else
 [F:SIH]JOU = JOURNAL : [M:BIC0]JOU = JOURNAL
Endif
Return

$LECTAX
Local Decimal SEUIL
If clalev([F:TRA])=0 : Local File TABRATVAT [TRA] : Endif
If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(I)) From CPTLEC
Filter [TRA] Where CPY=[F:SIH]CPY & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
 Filter [TRA] Where CPY="" & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If fstat>2 : STAT = 2 : Return : Endif
Endif
SEUIL = 0
If dim([F:TRA]AMTTSD)>0: # Taxes Argentines
 ## On convertit le seuil ŕ la devise de la facture
 Call CONVERT(GCURSHR,[F:SIH]CUR,[F:CPY]ACCCUR,[F:SIH]CURTYP,[F:SIH]RATDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
 If STAT
  GMESSAGE = mess(16,114,1)-GCURSHR-"->"-[F:SIH]CUR-"("+format$("D:"+GFMDAT,[F:SIH]RATDAT)-")"
  GOK=0 : Return
 Endif
Endif
Return


$SET_TAXE
If TAXE<>""
 K = find(TAXE,[F:SIH]TAX(0..[F:SIH]NBRTAX-1))
 If !K
  [F:SIH]NBRTAX += 1 : K = [F:SIH]NBRTAX
  [F:SIH]TAX(K-1) = TAXE
 Endif
 [F:SIH]BASTAX(K-1) += BASE
 [F:SIH]AMTTAX(K-1) += MONTANT
 [F:SIH]EXEAMTTAX(K-1) += EXOTAX
 If !TVA
  Call LEC_TVT_LEG(GCURLEG,TAXE) From CPTLEC
  If [F:TVT]VATCHA=2
   BASTVA += MONTANT
  Endif
 Endif
Endif
Return

$CREATION
Gosub CREFAC
If !GIMPORT : Gosub CREECH : Endif
SIGN = 1 : Gosub MAJCLI
## Transformation Facture en avoir
FACTAVO=0
Return

$CREFAC
For nolign=1 To [M]NBLIG
 Raz [F:SIL]
 [F:SIL] = [F:SIH]
 [F:SIL] = [M:BIC0]
 [F:SIL] = [M:BIC1]
 [F:SIL] = [M:BIC3]
 If [F:SIL]DSP="$" : [F:SIL]DSP = "" : Endif
 Raz [F:SIL]COA, [F:SIL]ACC, [F:SIL]LED
 ##### BESPR 87307 05/28/2013 # Intercompany enhancement
 # If intercompany then we need to re-set GPLAN and GLedger to target company so the COA is correct
 If GFONC1 = "GESBICI" and (([M]CPY <> [M]CPYLIN(nolign-1)) or (GCURINTCPY <> "" and GCURINTCPY <> [M]CPYLIN(nolign-1)))
   Call CONT_INTCPYCOA ([M]CPYLIN(nolign-1)) From INTCPYLIB
 Endif
 #####
 For NLED=1 To GNBTYPLED
  [F:SIL]COA(GTYPLED(NLED)-1) = evalue("GPLAN("+num$(NLED)+")")
  [F:SIL]ACC(GTYPLED(NLED)-1) = evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")
  TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
  [F:SIL]LED(GTYPLED(NLED)-1) = [L]LED
 Next
 [F:SIL]LIG = nolign
 [F:SIL]NUM = [F:SIH]NUM
 Write [SIL]
 If fstat
  GOK=0 : Call FSTA("SIL") From GLOCK : Break
 Endif

 ## MAJ des lignes analytiques

 # 1°) Répartition manuelle
 If dim([M:BIC3]DSP)>0 & [M:BIC3]DSP(nolign-1)="$"
  LIGANA = 0
  For I=[M]PTV(nolign-1) To [M]PTF(nolign-1)
   CAS = 1 : Gosub WRITE_SIA
   If GOK<1 : Break 3 : Endif
  Next I

 # 2°) Répartition standard
 Elsif dim([M:BIC3]DSP)>0 & [M:BIC3]DSP(nolign-1)<>""
  [M:VTL]TOTREP = [F:SIL]AMTNOTLIN : [M:VTL]QTOTREP=[F:SIL]QTY
  Call LECTURE("TCU",[M]CUR,"") From CONTOBJ
  Raz [M]LSTAXE
  Gosub SETCHPLST From SUBBICS
  Call CHARGE_VTE_STR([M:BIC3]DSP(nolign-1),[M]UOM(nolign-1),[M]LSTLED,[M]LSTACC,[M]LSTAXE) From VENTILE
  LIGANA = 0
  For I=0 To [M:VTL]BAS-1
   CAS = 2 : Gosub WRITE_SIA
   If GOK<1 : Break 3 : Endif
  Next I

 # 3°) Répartition saisie sur la ligne d'écriture générale
 Else : # Répartition saisie sur la ligne d'écriture générale
  LIGANA = 0
  CAS = 3 : Gosub WRITE_SIA
  If GOK<1 : Break 2 : Endif
 Endif
Next nolign
##### BESPR 87307 06/28/2013 # Intercompany enhancement Re-initialization Global Variables
If GFONC1 = "GESBICI" and [F:SIH]NBRCPY>1
 Call RESET_INTCPYCOA([M:BIC0]CPY,[M:BIC0]FCY) From INTCPYLIB
Endif
#####
Return

$WRITE_SIA
Raz [F:SIA]
[F:SIA] = [F:SIH]
[F:SIA] = [F:SIL]
Raz [F:SIA]DIE, [F:SIA]CCE
Case CAS
 When 1 : # Répartition analytique manuelle
  LIGANA += 1
  [F:SIA]AMT = [M:VT2]TBAMT(I)
  [F:SIA]QTY = [M:VT2]TBQTY(I)
  For AXE=1 To GNBAXE
   If GAXE(AXE)<>""
    [F:SIA]DIE(AXE-1) = GAXE(AXE)
    [F:SIA]CCE(AXE-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(I)+")")
   Endif
  Next AXE
 When 2 : # Répartition analytique standard
  LIGANA += 1
  [F:SIA]AMT = [M:VTL]AMT(I)
  [F:SIA]QTY = [M:VTL]QTY(I)
  For AXE=1 To GNBAXE
   If GAXE(AXE)<>""
    [F:SIA]DIE(AXE-1) = GAXE(AXE)
    [F:SIA]CCE(AXE-1) = evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(I)+")")
   Endif
  Next
 When 3 : # Pas de répartition analytique
  For AXE=1 To GNBAXE
   If GAXE(AXE)<>""
    [F:SIA]DIE(AXE-1) = GAXE(AXE)
    [F:SIA]CCE(AXE-1) = evalue("[M]CCE"+num$(AXE)+"("+num$(nolign-1)+")")
   Endif
  Next
  [F:SIA]AMT = [F:SIL]AMTNOTLIN
  [F:SIA]QTY = [F:SIL]QTY
  If sum([F:SIA]CCE(0..GNBAXE-1))<>""
   LIGANA = 1
  Endif
Endcase
If LIGANA
 [F:SIA]ANALIG = LIGANA
 [F:SIA]NUM = [F:SIH]NUM
 Write [SIA]
 If fstat
  GOK = 0 : Call FSTA("SIA") From GLOCK : Return
 Endif
Endif
Return

$APRES_CRE

# Issue 117131.s - 2016-09-21 by CATUA : Move WS calls outside database transactions (Invoice Creation)
If func SUBBIC2.FIN_PARAM(GAC_KAG, "ARGTAX",[F:SIH]CPY)<>"2"
  Gosub RECALC_SST # Issue 118689
Endif
# Issue 117131.e

[M:BIC0]NUM = [F:SIH]NUM
If !GIMPORT
 Raz MONTMIN, MONTPRO
 Gosub DEGRISE_CLE From =WINPROG
 Affzo [BIC0]NUM

  # 78411 Sage Exchange
  If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:BIC1]PTE)
    Local Integer SEVCRTYP
    If find([M:BIC0]INVTYP,2,4)
      SEVCRTYP = 41
      If [M:BIC1]INVNUM<>""
        Call CREDIT_COPY(40,[M:BIC1]INVNUM,41,[M:BIC0]NUM,GERR) From SEPPLIB
      Endif
    Else : SEVCRTYP = 40 : Endif
    If !func SEPPCDT.SEPP_OK(SEVCRTYP,[M:BIC0]NUM,1)
      Call CALL_SEAUTH(SEVCRTYP,[M:BIC0]NUM) From TRTSEAUTH
    Endif
  Endif

Endif
Gosub AP_ECHE

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Diszo [M:BIC1]
    Diszo [M:BIC3]
    Diszo [M:BIC0]
    Actzo [M:BIC0]ACCDAT
  Endif
Endif
#-
Return

$CREECH
Call CREECHE(1,[M]XSOI,[M]XFLGFUP,len(mess(0,510,1))) From SUBBIH
Return

$MAJCLI
Local Char WSNS(1), WTYP(1), WCAS
Local Decimal WINVAMT

#WINVAMT=[F:SIH]AMTATI*SIGN
# Montant seul car le paramčtre est utilisé pour la mise ŕ jour des cumuls    (BPCUSTMVT)
#                                      ainsi que la mise ŕ jour des documents (LASTCUSMVT)
WINVAMT=[F:SIH]AMTATI

# Prise en compte du signe.
If SIGN>0 : WSNS="+" Else WSNS="-"  : Endif

# Le champ INVTYP informe la catégorie de la facture (Facture, Avoir, Note de débit, Note de crédit,Proforma)
Case [F:SIH]INVTYP
 When 1,3 :
    WTYP="I"   # Type Facture & Note de débit, le signe est conservé.
 When 2,4 :
    WTYP="N"   # Type Avoir & Note de crédit, le signe est inversé.
  If WSNS="-" : WSNS="+" Else WSNS="-" : Endif
Endcase
# Initialisation de WCAS dans le cas de la validation de la facture
If WVALFAC : WCAS="V" : Else  WCAS="" : Endif
Gosub SETCOUR
Call MAJMVC([F:SIH]BPR,[F:SIH]CUR,[F:SIH]CURTYP,COURS,[F:SIH]ACCDAT,[F:SIH]NUM,[F:SIH]FCY,0,WINVAMT,WSNS,WTYP,WCAS,0) From TRTBPMVT
Return

$AVANT_MOD
#-----------------------------------------#
# Invoice modification control            #
#-----------------------------------------#
#If !(find(COUZON,"DES"))
If !(find(COUZON,"DES", "INVTYPSPA"))
  If [F:SIH]STA = 3 & func PORLEGLIB.PORLEG("", [F:SIH]CPY) = 1
    GERR=1:GMESSAGE=mess(76,192,1): OK=0 : Return
  Endif
Endif

If GLBINVCA_ON = 2
  If [F:SIH]REVCANSTA > 0
    GERR=1:GMESSAGE=func AFNC.MES1(mess(7,7712,1), mess([F:SIH]REVCANSTA,2053,1)) :  OK=0 : Return
  Endif
Endif

Return

$AVANT_MODFIC
## Quel est le type de référentiel flagué échéance ????
If  [M]BPRPAY<>[F:SIH]BPRPAY | [M]BPR<>[F:SIH]BPR
& | [M]BPRSAC<>[F:SIH]BPRSAC | [M]CUR<>[F:SIH]CUR
& | [M]FCY<>[F:SIH]FCY
& | [M]RATDIV(GTYPGEN-1)<>[F:SIH]RATDIV(GTYPGEN-1) | [M]RATMLT(GTYPGEN-1)<>[F:SIH]RATMLT(GTYPGEN-1)
 MODFAC = 1
Else
 MODFAC = 0
Endif
CHGDAT = ([M]ACCDAT<>[F:SIH]ACCDAT)
CHGECHE = ([M]AMTMIN=0 & [M]STA<3) &
&  ( ([M]PTE<>[F:SIH]PTE) | ([M]STRDUDDAT<>[F:SIH]STRDUDDAT) | ([M]AMTATI<>[F:SIH]AMTATI)
&  | ([M]BPR<>[F:SIH]BPR) | [M]BPRPAY<>[F:SIH]BPRPAY | [M]BPAPAY<>[F:SIH]BPAPAY )
If CHGECHE=0 & dim([M]UMRNUM)>0
 CHGECHE = ([M]UMRNUM<>[F:SIH]UMRNUM)
Endif
SIGN = -1 : Gosub MAJCLI
Return

$MODIF
Delete [SIL] Where NUM=[F:SIH]NUM
If fstat=1
 GOK=-1 : GLOCK="$BPCINVLIG"-[F:SIH]NUM : Return
Endif
Delete [SIA] Where NUM=[F:SIH]NUM
If fstat=1
 GOK=-1 : GLOCK="$BPCINVLIGA"-[F:SIH]NUM : Return
Endif
Gosub CREFAC
If GOK<1 : Return : Endif
If !GIMPORT
 If CHGECHE
  CRITSUPPR="ACCNUM="+num$([F:SIH]ACCNUM)
  Call HISTOSUPPR (CRITSUPPR) From MODECHE
  Delete [DUD] Where ACCNUM=[F:SIH]ACCNUM
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:SIH]ACCNUM) : Return # Issue X3-108393 - End replaced by Return
  Endif
  Gosub CREECH
 Else
  Call MODECHE(1,[F:SIH]NUM,[F:SIH]AMTATI,MODFAC,MODECH) From SUBBIH
 Endif
Endif
Update [DUD] Where ACCNUM=[F:SIH]ACCNUM With BPRFCT=[F:SIH]BPRFCT
SIGN = 1 : Gosub MAJCLI
Return

# Transformation Facture en avoir
$APRES_MODIF
If FACTAVO=1 & COUZON="SIVTYP"
 OK=-1
Endif
Return

$APRES_MOD

# Issue 117131.s - 2016-09-23 by CATUA : Move WS calls outside database transactions (Invoice Creation)
If func SUBBIC2.FIN_PARAM(GAC_KAG, "ARGTAX",[F:SIH]CPY)<>"2"
  Gosub RECALC_SST # Issue 118689
Endif
# Issue 117131.e

If MODECH=2 & !GIMPORT
  Call ECHEANCE(1,[F:SIH]NUM,OK) From SUBBIH
  Gosub VERROU
Endif

# 78411 Sage Exchange
# If auth exists, check for need for re-auth, If no auth exists, authorize
# If no longer SE PTE, Void any current auths
If func AFNC.ACTIV("SEPP")
  Local Integer SEVCRTYP
  If !clalev([F:SEU])  Local File SEAUTH [SEU] Endif
  If find([M:BIC0]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
  If func SEPPLIB.SEPP_DOC([M:BIC1]PTE)
    Call AUTH_CHK(SEVCRTYP,[M:BIC0]NUM,GERR,GMESSAGE) From SEPPLIB
    If GERR
      If [F:SEU]MANAUT=2
        Call MESSAGE(mess(48,2092,1)) From GESECRAN
      Endif
      GOK=0 : Return
    Endif
    If !func SEPPCDT.SEPP_OK(SEVCRTYP,[M:BIC0]NUM,1)
      Call CALL_SEAUTH(SEVCRTYP,[M:BIC0]NUM) From TRTSEAUTH
    Endif
  Elsif func SEPPCDT.SEPP_OK(SEVCRTYP,[M:BIC0]NUM,1)
    Local Integer SERR
    Local Char    SEMESSAGE(150)
    Call VOID_ALL(SEVCRTYP,[M:BIC0]NUM,SERR,SEMESSAGE) From SEPPLIB
    If SERR : Call ERREUR (SEMESSAGE) From GESECRAN : Endif
  Endif
Endif

Gosub AP_ECHE
Affzo [M:BIC1]STARPT
Return

$AP_ECHE
If !GIMPORT
 Filter [DUD] Where ACCNUM=[F:SIH]ACCNUM
 Read [DUD]DUD1 First
 If !fstat
  [M:BIC1]DUDDAT  = [F:DUD]DUDDAT
  [M:BIC1]XSOI    = [F:DUD]SOI
  [M:BIC1]XFLGFUP = [F:DUD]FLGFUP
 Else Raz [M:BIC1]DUDDAT
 Endif
 Filter [DUD]
 Affzo [BIC1]DUDDAT,XSOI,XFLGFUP
Endif
Return

$LIENS
##### BESPR 87307 06/06/2013 - Check the Intercompany invoice parameter for the Source company and do not allow editing
If GFONC1 = "GESBICI" and func SUBBIC2.FIN_PARAM(GAC_INTCO, "INTCPYINV",[M]CPY)<>"2"
  If [M]NUM<>"" and LASNUM<>[M]NUM
    GMESSAGE = func AFNC.MES1(mess(160,104,1),[M]CPY) : Grizo [BIC0] : Grizo [BIC1] : Grizo [BIC3]
    LASNUM = [M]NUM
  Endif
Else
  Actzo [BIC0] : Actzo [BIC1] : Actzo [BIC3]
Endif
#####

Raz nolign, [M:VTL], [M:VT2]
Raz [M]LSTLED, [M]LSTACC, [M]LSTAXE
## Initialisations globales plans/axes
Call GETSOC([F:SIH]FCY) From DEVSUB
Call PARAM(GSOCIETE,"DEPMGTMOD",DEPMOD) From ADOVAL
GDEPMGTMOD=val(DEPMOD)
Call INI_GLOBAL(1,[M:BIC0]CPY,STAT,MESSA) From SUBBICS
If STAT : Return : Endif
If !GIMPORT Then
 Call AFFCOL(1) From SUBBICS
 Gosub SETCHPAXE From SUBBICS
Endif
If dim([M:BIC1]NBRCCE)>0 : [M:BIC1]NBRCCE = GNBAXE : Endif
For [SIL]SIL0 Where NUM=[F:SIH]NUM
 nolign += 1
 [M:BIC0] = [F:SIL]
 [M:BIC1] = [F:SIL]
 [M:BIC3] = [F:SIL]

 ##### BESPR 87307 06/04/2013 # Intercompany enhancement
 # If intercompany then we need to re-set GL variables to the target company so the COA, Dimensions are correct
 If GFONC1 = "GESBICI" and (([M]CPY <> [M]CPYLIN(nolign-1)) or (GCURINTCPY <> "" and GCURINTCPY <> [M]CPYLIN(nolign-1)))
   Call CONT_INTCPYCOA ([M]CPYLIN(nolign-1)) From INTCPYLIB
 Endif
 #####

 For NLED=1 To GNBTYPLED
  Assign "[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")" With [F:SIL]ACC(GTYPLED(NLED)-1)
 Next

 Call CAL_BASDEPLIN([M:BIC1]DEP,[M:BIC3]FLGDEP(nolign-1),nolign) From INVDEPLIB

 If [F:SIL]DSP=""
  OK = 0 : INDAXE = 0
  For [SIA]SIA0 Where NUM=[F:SIL]NUM & LIG=[F:SIL]LIG
   LIGANA += 1
   If !OK : OK = LIGANA : Endif
   [M:VT2]TBAMT(LIGANA) = [F:SIA]AMT
   [M:VT2]TBQTY(LIGANA) = [F:SIA]QTY
   For AXE=1 To GNBAXE
    INDAXE = find(GAXE(AXE),[F:SIA]DIE(0..dim([F:SIA]DIE)-1))
    If INDAXE
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:SIA]CCE(INDAXE-1)
    Endif
   Next AXE
  Next
  If OK
   If OK=LIGANA
    For I=1 To GNBAXE
     Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")")
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")" With ""
    Next I
    LIGANA -= 1
   Else
    [M]PTV(nolign-1) = OK
    [M]PTF(nolign-1) = LIGANA
    [M]DSP(nolign-1) = "$"
    For I=1 To GNBAXE : # Pour initialiser les champs sections
     Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With ""
    Next I
   Endif
  Else
   For I=1 To GNBAXE : # Pour initialiser les champs sections
    Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With ""
   Next I
  Endif
 Endif
Next
##### PP => BESPR 87307 06/27/2013 # Intercompany enhancement Re-initialization Global Variables
If GFONC1 = "GESBICI" and [F:SIH]NBRCPY>1
 Call RESET_INTCPYCOA([M:BIC0]CPY,[M:BIC0]FCY) From INTCPYLIB
Endif
##

[M:VT2]PTVENT = LIGANA+1
[M]NBLIG = nolign

Call LEC_TCU([F:SIH]CUR) From CPTLEC
Call LEC_FCY([F:SIH]FCY) From CPTLEC
Call LEC_CPY([F:SIH]CPY) From CPTLEC
Call LEC_BPR([F:SIH]BPR) From CPTLEC
Call LEC_GTE_LEG(GCURLEG,[F:SIH]GTE) From CPTLEC

[M]CPYNAM = [F:CPY]CPYSHO
[M]BASDEP = sum([M]BASDEPLIN(0..[M]NBLIG-1))
[M]TOTNOT = sum([M]AMTNOTLIN(0..[M]NBLIG-1))
[M]TOTATI = sum([M]AMTATILIN(0..[M]NBLIG-1))
If sum([M]FLGGEN(0..[M]NBLIG-1))>[M]NBLIG
 [M]FASFLG = 2
Else
 [M]FASFLG = 1
Endif

#Menu Adresse facture la premičre fois , récupérer les infos ds BPADDRESS
If [M:BIC0]NUM = ""
 # save the two lines
 For J=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:BPR]BPRNAM))-1
  [M:BIC0]BPRNAMBIS(J) = [F:BPR]BPRNAM(J)
 Next J
 #Display only the first line
 [M:BIC0]BPRNAM(0) = [F:BPR]BPRNAM(0)

 Read [BPA]BPA0 = 1;[M:BIC0]BPR;[M:BIC0]BPAINV
 If !fstat
  For I=0 To min(dim([M:BIC0]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
   [M:BIC0]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
  Next I
  [M:BIC0]POSCOD = [F:BPA]POSCOD
  [M:BIC0]CTY    = [F:BPA]CTY
  [M:BIC0]CRY    = [F:BPA]CRY
  [M:BIC0]SAT    = [F:BPA]SAT
  If [F:BPA]CRYNAM<>"" : [M:BIC0]CRYNAM = [F:BPA]CRYNAM
  Else [M:BIC0]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[M:BIC0]CRYNAM) From TRTDIV
  Endif
 Endif
#Menu Adresse facture sur facture existante récupérer les infos ds SINVOICE
Else
# save the two lines
If [M:BIC0]BPRNAM(0)<>""
 For J=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:SIH]BPRNAM))-1
  [M:BIC0]BPRNAMBIS(J) = [F:SIH]BPRNAM(J)
 Next J
Else
 For K=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:BPR]BPRNAM))-1
  [M:BIC0]BPRNAMBIS(K) = [F:BPR]BPRNAM(K)
 Next K
Endif
#Display only the first line
[M:BIC0]BPRNAM(0) = [F:SIH]BPRNAM(0)

 For I=0 To min(dim([M:BIC0]BPAADDLIG),dim([F:SIH]BPAADDLIG))-1
  [M:BIC0]BPAADDLIG(I) = [F:SIH]BPAADDLIG(I)
 Next I
 [M:BIC0]POSCOD = [F:SIH]POSCOD
 [M:BIC0]CTY    = [F:SIH]CTY
 [M:BIC0]CRY    = [F:SIH]CRY
 [M:BIC0]SAT    = [F:SIH]SAT
 If [F:SIH]CRYNAM<>"" : [M:BIC0]CRYNAM = [F:SIH]CRYNAM
 Else [M:BIC0]CRYNAM="" : Call INIPAYS([F:SIH]CRY,[M:BIC0]CRYNAM) From TRTDIV
 Endif
Endif

Call INFOECHE(1,[F:SIH]NUM,MONTMIN,MONTPRO) From SUBBIH
[M]AMTMIN = MONTMIN
[M]AMTTMP = MONTPRO
For I=0 To min(dim([M:BIC1]DES),dim([F:SIH]DES))-1
 [M:BIC1]DES(I) = [F:SIH]DES(I)
Next I
Filter [DUD] Where ACCNUM=[F:SIH]ACCNUM
Read [DUD]DUD1 First
If !fstat
 [M]DUDDAT  = [F:DUD]DUDDAT
 [M]XSOI    = [F:DUD]SOI
 [M]XFLGFUP = [F:DUD]FLGFUP
Endif
Filter [DUD]
If !GIMPORT
 Call CHARGE_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
Endif
[M]RAT1   = [M]RATDIV(GTYPGEN-1)
[M]LABEL  = [M]CUR-"="
[M]RAT2   = [M]RATMLT(GTYPGEN-1)
[M]CURDIV = [M]CUR : # Zone invisible
[M]CURMLT = [M]CURLED(GTYPGEN-1)
#--- Paramčtre de suppression des factures : affecte le bouton Suppression
Call PARAM([M]FCY,"SIVSUP",XPARAM) From ADOVAL
GSIVSUP=val(XPARAM)
#--- Paramčtre de création de lignes ŕ zéro
Call PARAM([M]FCY,"SIVNULL",XPARAM) From ADOVAL
GSIVNULL=val(XPARAM)
#--- Code taxe obligatoire
If dim(GSAITAX)>0
 Call PARAM([M]FCY,"SAITAX",XPARAM) From ADOVAL
 GSAITAX  = val(XPARAM)
Endif
#--- Code taxe exonéré
Call PARAM([M]FCY,"EXETAX",XPARAM) From ADOVAL
GEXETAX  = XPARAM
#--- Arrondi de TVA
Call PARAM([M]FCY,"VATRND",XPARAM) From ADOVAL
GVATRND  = val(XPARAM)
#If func AFNC.ACTIV("LTA")   #LTA.sn   # 106867.so  Parameter removed now using [F:CPY]SSTTAXACT
#  Call PARAM([M]FCY,"USATAX",XPARAM) From ADOVAL
#  GLOCUSATAX = val(XPARAM)
#  If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#Endif                       #LTA.en   # 106867.eo
#20/11/07 - Bug n°44047
Read [GAC]GAC1 = GPLAN(1);[M:BIC0]BPRSAC
If !fstat : [M:BIC0]SACACC=[F:GAC]ACC : Else : Raz [M:BIC0]SACACC : Endif
#Si facture Validée -> Adresse Payeur Grisée
If [F:SIH]STA=3
 Grizo [M:BIC1]BPAPAY
Else
 Actzo [M:BIC1]BPAPAY
Endif

Call LECTURE("FCT",[F:SIH]BPRFCT,"") From CONTOBJ
[M]BPRFCTNAM = [F:FCT]FCTNAM

#JOJAC - 2018-08-30 - X3-96384 - START
#Grizo [M:BIC1]VAC
#JOJAC - 2018-08-30 - X3-96384 - END
#--------------------------------------------------------------------------------------------------
#IRMUE 16.06.12 81574:AP/AR management:The parameter NOTATI has no impact on the ‘Amount type’.
#The ‘Amount type’ field must be disabled if the status is ‘posted’ or [M:BIC3]NBLIG <> 0
#amount type is initialized with customer or customer category or parameter SALPRITYP, otherwise with "Ex tax".
#--------------------------------------------------------------------------------------------------
If  [M:BIC1]STA >= 3 | [M:BIC3]NBLIG <> 0 | (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP)))
 Diszo [M:BIC1]SALPRITYP
Else
 Actzo [M:BIC1]SALPRITYP
Endif
Call SETCOLOR([M:BIC1]SALPRITYP) From SUBBIC4

#Finance_Sophia US96/SP5/Exi81664
If [M:BIC0]FASFLG=2
 Grizo [M:BIC0]ACCDAT,BPR
 Grizo [M:BIC1]CUR,INVNUM
Else
 Actzo [M:BIC0]ACCDAT,BPR
 Actzo [M:BIC1]CUR,INVNUM
Endif

#Localisation Belge --str
If GAC_KBE Then
  If GIMPORT
    Chgfmt [M:BIC1]BELVCS  With ""
  Else
    Call DISPLAY_VCS("BIC1","",3,0)  From INVVCSLIB
  Endif
Endif
#Localisation Belge --end

Gosub SHOW_HIDE_ENTCOD From TRTADRLIB #LTA.n
If dim([M:BIC3]TOTATI)>0 : Diszo [M:BIC3]TOTATI : Endif #LTA.n

If [M:BIC1]STA = 3
 Diszo [M:BIC3]FLGDEP
 Diszo [M:BIC1]BPRVCR
 Diszo [M:BIC3]DES
Else
 Actzo [M:BIC3]FLGDEP
 Actzo [M:BIC1]BPRVCR
 Actzo [M:BIC3]DES
Endif

If dim(GSDDMGT)>0
 #X3-112211
 #Call PARAM(GSOCIETE,"SDDMGT",XPARAM) From ADOVAL
 If func AFNC.ACTIV("SDD")
  Call PARAM(GSOCIETE,"SDDMGT",XPARAM) From ADOVAL
  GSDDMGT=val(XPARAM)
 Endif
 #end X3-112211
 Gosub SHOW_HIDE_UMRNUM From INVSDDLIB
Endif

Gosub SHDCLEECNUM

Call FLD4041DIS([M:BIC1]VAC,[M:BIC0]SIVTYP)

If dim([M:BIC1]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM([M:BIC0]FCY,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
Endif

