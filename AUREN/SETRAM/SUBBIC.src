If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]CUR) From SUBBICSWI
