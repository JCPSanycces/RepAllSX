# Issue X3-38389
#85785 * RMA * document amount cannot be negative
# If func PORLEGLIB.DIGSIGN([M:BIC0]FCY, "") & ([M:BIC3]TOTATI<0)
#  GERR = 1: GMESSAGE = mess(216,191,1) : OK = 0 : Return
# Endif
  If [M]TOTATI<0
    GERR = 1: GMESSAGE = mess(109,119,1) : OK = 0 : Return
  Endif
# End issue X3-38289

If [M]TOTATI<[M]AMTTMP
 GERR=1 : GMESSAGE = mess(17,119,1)
 # Total inférieur au montant réglé
 OK = 0 : Return
Endif

# Issue 114754
#If GSIVNULL=2 & sum([M]AMTNOTLIN)=0
If (GSIVNULL=2 & sum([M]AMTNOTLIN)=0) or [M]NBLIG=0
# If !GIMPORT
  # Lignes nulles interdites ?
  GERR=1 : GMESSAGE = mess(91,106,1)
 #Endif
# End Issue 114754
 OK = 0 : Return
Endif

If ([M]AMTNOT<>[M]TOTNOT | [M]AMTATI<>[M]TOTATI)
 OK = 2
 If !GIMPORT
  # Totaux différents de l'en-tęte
  If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"WRNMSGBPC")=2
  Call AVERTIR(mess(18,119,1),OK) From GESECRAN
  Endif
 Endif
 If OK<>2
  OK = 0 : Return
 Else
  [M]AMTNOT = [M]TOTNOT
  [M]AMTATI = [M]TOTATI
  If !GIMPORT : Affzo [BIC1]AMTNOT, AMTATI : Endif
 Endif
Endif

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func PORLEGLIB.PORLEG([M:BIC0]FCY,"")=1
  Gosub VAL_SIMINV_BIC From PORLEGLIB
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If GAC_KPO
  If func PORLEGLIB.PORLEG([M:BIC0]FCY,"")=1
    Local Integer WRET
    Call LEC_TSV_LEG([F:CPY]LEG,[M:BIC0]SIVTYP,WRET) From TRTLECLEG
    If find([F:TSV]RECTYP, 2, 3)
      WRET = 1
      Filter [F:SIH2] Where [F:SIH2]ORIDOCNUM <> "" & [F:SIH2]ORIDOCNUM = [M:BIC1]ORIDOCNUM & [F:SIH2]NUM <> [M:BIC0]NUM &
&                           [F:SIH2]SIVTYP = [M:BIC0]SIVTYP & year([F:SIH2]ACCDAT) = year([M:BIC0]ACCDAT)
      Read [F:SIH2] First
      If !fstat : WRET = 0 : Endif
      Filter [F:SIH2]
      If WRET = 0
        Call ERREUR (func AFNC.MES1(mess(89,7711,1),[F:SIH2]NUM)) From GESECRAN
        OK = 0
        Return
      Endif
    Endif
  Endif
  # Issue X3-110803 by MRDAB
  If GCURLEG = "POR" and func PORLEGLIB.VAL_BPC_CASHVAT_SIVTYP([M:BIC0]BPR, [M:BIC0]ACCDAT, [M:BIC0]SIVTYP, GCURLEG) = 0
    OK = 0 : GERR = 1 :  GMESSAGE = mess(111,119,1) :  Return
  Endif
  # Issue X3-110803 end
  If GCURLEG ="POR" & !func PORLEGLIB.CONT_DATETIME(GREP,GFONCTION): OK = 0 : GERR = 1 : Return : Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

#--Checks consistency between invoice headerand lines for PJT
If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "2"
# If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")=2  X3-101376
 Call PJT_CONTROLE_HEAD_DETAIL("[M:BIC1]PJTH", "[M:BIC3]PJTLIN") From TRTPJT
 If GERR <> 0 Then
  OK = 0 :   Return
 Endif
Endif

# BRBAN 105200#US2 It's not possible to create a invoice cancelation credit note
# if it is allready associeted on another credit note or allready cancelled
If func AFNC.ACTIV("INVCA")>0
  #For Invoice cancellation credit notes
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[M:BIC0]INVTYP)>0 & [F:TSV]INVCAN=2
    Filter [F:ISIH] Where [F:ISIH]INVNUM=[M:BIC1]INVNUM
    Read [F:ISIH] First
    If !fstat
      #This invoice has already given rise to a credit memo!
      Call ERREUR ([F:SIH]INVNUM-mess(80,119,1)-[F:ISIH]NUM) From GESECRAN
      OK = 0
      Filter [F:ISIH]
      Return
    Endif
    Filter [F:ISIH]
  Else
    #Parameter INVCAN is set to YES, but it's not invoice cancellation type
    Local Char INVCLT : [L]INVCLT = "0"
    # Issue 110752 - 2015-09-15 by BRBAN
    #Call PARAM([F:FCY]LEG,"INVCAN", [L]INVCLT) From ADOVAL
    Call PARAM([F:FCY]FCY,"INVCAN", [L]INVCLT) From ADOVAL
    If val(INVCLT)=2 & find([M:BIC0]INVTYP,2,4)
      Filter [F:ISIH] Where [F:ISIH]INVNUM=[M:BIC1]INVNUM
      Read [F:ISIH] First
      If !fstat & [F:ISIH]REVCANSTA<>0
        #Invoice allready cancelled. Choose another invoice.
        Call ERREUR (mess(2,7712,1)) From GESECRAN
        OK = 0
        Filter [F:ISIH]
        Return
      Endif
      Filter [F:ISIH]
    Endif
  Endif
Endif
If GAC_KPO>0 & [F:TSV]INVCAN <> 2
  Call C_FLD40REN([M:BIC1]FLD40REN) From SUBBIC2
  If mkstat : OK = 0 : zonsui="[M:BIC1]FLD40REN": Return: Endif
  Call C_FLD41REN([M:BIC1]FLD41REN) From SUBBIC2
  If mkstat : OK = 0 : zonsui="[M:BIC1]FLD41REN": Return: Endif
Endif
# -
Return

$RAZDUP
Raz [M]AMTMIN, [M]AMTTMP
Raz [M:BIC1]STA , STARPT
If !GIMPORT
 Affzo [M:BIC1]STA, STARPT
 Actzo [M:BIC1]VAC
Endif

Call NTSDUP([M:BIC0]BPR,"BPCORD") From TRTNTSCTL   # customer notes
Actzo [M:BIC1]BPAPAY
Gosub RAZE

#--Duplication invoice with parameter=Yes => if the PJT code of the line is <> from the header one, the header is taken
If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "2"
# If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")=2 X3-101376
 Call TRAITE_DUPLICATION("[M:BIC1]PJTH") From TRTPJT
 Call PJT_MODFCY([M:BIC0]FCY, "[M:BIC3]PJTLIN") From TRTPJT
Endif

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Diszo [M:BIC1]VAC,SALPRITYP,BPAPAY,BPRVCR,CUR
  Endif
Endif

# Issue 115715 - 2016-04-22 by RICAR : POR Leg.: debit notes without reference period
Call SHOW_HIDE_PERDEB_PERFIN([M:BIC0]FCY,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
# End issue 115715

# Issue 114589 - 2016-02-23 by RMA : Hiding fields on duplication
If dim([M:BIC1]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM([M:BIC0]FCY,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
  [M:BIC1]ORIDOCNUM = ""
  Affzo [M:BIC1]ORIDOCNUM
Endif

If dim([M:BIC1]DCLEECNUM) > 0
  [M:BIC1]DCLEECNUM = ""
  Affzo [M:BIC1]DCLEECNUM
Endif
#angre X3-133989
If func AFNC.ACTIV("KSW")>0
  Gosub RAZ_SWIQRC From SWIQRCLIB2
Endif


Return

$RAZCRE
Raz [M]STA
Raz [M:VTL]
If [M:BIC0]GTE="" : Raz [M:VT2] : Endif
Gosub RAZE

# BRBAN 105200 US2
If func AFNC.ACTIV("INVCA")>0
  If [M:BIC0]SIVTYP<>''
    If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
      Diszo [M:BIC1]
      Diszo [M:BIC3]
      Actzo [M:BIC1]INVNUM
    Endif
  Endif
Endif
#angre X3-133989
If func AFNC.ACTIV("KSW")>0
  Gosub RAZ_SWIQRC From SWIQRCLIB2
Endif
#-
Return

$RAZE
If [M:BIC0]GTE<>""
 Call LEC_GTE_LEG(GCURLEG,[M:BIC0]GTE) From CPTLEC
 If [F:GTE]MANNUM=1 & COUZON="NUM"
  Raz [M:BIC0]NUM
  If !GIMPORT
   Affzo [M:BIC0]NUM
   Gosub GRISE_CLE From =WINPROG
  Endif
 Endif
Endif

Raz [M]FASFLG, [M]FLGGEN
Actzo [M:BIC0]ACCDAT,BPR
Actzo [M:BIC1]CUR,INVNUM

#-------------------------------------------------------------------------------
#IRMUE 25.06.12 81574:AP/AR management SALPRITYP is activated, if GNOTATI="Yes"
#-------------------------------------------------------------------------------
If GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP))
 Diszo [M:BIC1]SALPRITYP
Elsif dim([M:BIC1]SALPRITYP)>0 & dim(GNOTATI)>0 & GNOTATI=2
 Actzo [M:BIC1]SALPRITYP
Endif
#IRMUE 25.06.12 81574:AP/AR management <end>

#Localisation Belge --str
If GAC_KBE Then
 Raz [M:BIC1]BELVCS
 If !GIMPORT
  Affzo [M:BIC1]BELVCS
 Else
  Chgfmt [M:BIC1]BELVCS  With ""
 Endif
Endif
#Localisation Belge --end

Actzo [M:BIC1]BPRVCR
Actzo [M:BIC3]DES
Actzo [M:BIC3]FLGDEP

If dim([M:BIC3]TOTATI)>0 : Diszo [M:BIC3]TOTATI : Endif #LTA.n

Gosub SHOW_HIDE_UMRNUM From INVSDDLIB

#RMA * 85785
If dim([M:BIC1]ORIDOCNUM) > 0
  Chgfmt [M:BIC1]ORIDOCNUM With "-K:30X"
Endif

# Issue 115715 - 2016-04-22 by RICAR : POR Leg.: debit notes without reference period
# Issue 115715 - Added the "-"
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If GAC_KPO
#  Chgfmt [M:BIC1]PERDEB With "-DZ:"+GFMDAT
#  Chgfmt [M:BIC1]PERFIN With "-DZ:"+GFMDAT
  Call SHOW_HIDE_PERDEB_PERFIN([M:BIC0]FCY,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END
# End issue 115715

# PJT managed or not
If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) > "0"
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")>0  X3-101376
 Chgfmt [M:BIC1]PJTH   With "K:40X"           # Display PJTH
 Chgfmt [M:BIC3]PJTLIN With "K:40X"           # Display PJTLIN column
 Chgfmt [M:BIC3]PCCCOD With "K:40X"           # Issue X3-149911 - 2019-07-31 by UB : Enabling Cost type column
 If [M:BIC0]CPY<>""
  If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) <> "2"
  #If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")<>2  X3-101376
   Chgfmt [M:BIC1]PJTH   With "-K:40X"           # Hide PJTH
   Chgfmt [M:BIC3]PJTLIN With "-K:40X"           # Hide PJTLIN column
   Chgfmt [M:BIC3]PCCCOD With "-K:40X"           # Issue X3-149911 - 2019-07-31 by UB : Disabling Cost type column
  Endif
  Call PJT_MODFCY([M:BIC0]FCY, "[M:BIC3]PJTLIN") From TRTPJT
 Endif
Endif

# SAM 110033: Swiss localization: clear field BVRNUMREF
If func AFNC.ACTIV("KSW") Then
  Call CLEAR_BVRFIELDS() From SUBBICSWI
Endif
# SAM 110033 END

Return

$ABANDON
If REP="C" or REP="D"
 Gosub DEGRISE_CLE From =WINPROG
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
#If [M]STA>=3 or REP<>"" or CLECUR=0 or !VERROU or ([M]NBLIG=0 & func AFNC.PARAM("SIVNULL",[M]FCY)="2")
#&            or ([M]STARPT<>2 & func AFNC.PARAM("SIVCFM",[M]FCY)="2")
If [M]STA>=3 or REP<>"" or CLECUR=0 or !VERROU or (sum([M]AMTNOTLIN)=0 & func AFNC.PARAM("SIVNULL",[M]FCY)="2")
&            or [M]NBLIG=0 or ([M]STARPT<>2 & func AFNC.PARAM("SIVCFM",[M]FCY)="2")
# End Issue 114754
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
If REP<>"" or CLECUR=0
 Call VIREBOUT(CHAINE,"B") From GOBJET
Endif
If GSIVSUP=1 or [M]STA>=3 or MONTMIN<>0  #issue X3-69271 - 2019-02-12 by MANOW  #issue X3-137041 - 2019-04-17 by ANKUL
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If CLECUR
 # 101905.102686.sn
 # Update GUSRFCY and GUSRCPY based upon the menu FUNCTION not GFONCTION so Site Authorization works properly
 # The variable is getting reset in DROITSITE as it uses GFONCTION
 Local Char OFONCTION(10)
 OFONCTION = GFONCTION
 If GFONC1 = "GESBICI"
  GFONCTION  = GFONC1
 Endif
 # 101905.102686.en
 Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
 GFONCTION = OFONCTION # 101905.102686.n
 If ![L]ACCFCY | !instr(1,[L]AUZFCY,"V")
  Call VIREBOUT(CHAINE,"V") From GOBJET
 Endif
 If [M]STA>=3
  CHMEN += "1"  :   # Tool barre "Zoom" : sous menu "Pičces Comptables"
# Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
If func SUBBIC2.FIN_PARAM(GAC_SVC, "SVCFLG",[M]CPY)="2"
# End issue X3-199974
   CHMEN += "2" :   # Tool barre "Zoom" : sous menu "Pičces Analytiques" (localisation italienne)
  Endif
 Endif
Endif
If !GIMPORT & REP="" & CLECUR & VERROU
 # Bouton annulation comptable pour l'Italie
 K = find("4",XMEN(1..NBRMEN))
 If K
  # Issue 116064
  #If [M]STA>=3 & func AFNC.PARAM("POSTINVSUP",[M]CPY)="2" & [M]FASFLG<>2 :  CHMEN += "4" : Endif  # Tool barre "Fonctions" : sous menu "Annulation Comptable"
  If [M]STA>=3 & func AFNC.PARAM("POSTINVSUP",[M]CPY)="2" & [M]FASFLG<>2 & func PORLEGLIB.DIGSIGN("", [M]CPY) = 0 :  CHMEN += "4" : Endif  # Tool barre "Fonctions" : sous menu "Annulation Comptable"
  # End issue 116064
 Endif
 # Bouton Facture -> Avoir
 K = find("5",XMEN(1..NBRMEN))
 If K
  If [M]INVTYP=1 & [M]STA=3 :  CHMEN += "5" : Endif  # Tool barre "Fonctions" : sous menu "Facture - Avoir"
 Endif
Endif

# 78411 Sage Exchange
If CLECUR & GREP="" & [M:BIC0]NUM<>"" & func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:BIC1]PTE)
  #If the user clicks Invoice -> Credit, GREP="" because we are not in create mode yet, but will once they tab past NUM
  #So don't enable the button unless NUM is populated (If we are not in edit mode, NUM will always be populated)

  #If the payment method has Sage Exchange turned on - enable the menu
  If !instr(0,CHMEN,"S") : CHMEN += "S" : Endif
  # Disable accounting cancellation for Sage Exchange
  Call VIREBOUT(CHMEN,"4") From GOBJET
Endif

##### BESPR 87307 06/28/2013 - Check the Intercompany invoice parameter for the Source company and do not allow editing
If GFONC1 = "GESBICI" and func SUBBIC2.FIN_PARAM(GAC_INTCO, "INTCPYINV",[M]CPY)<>"2" and [F:SIH]NBRCPY>1
  Call VIREBOUT(CHAINE,"A") From GOBJET # Delete
  Call VIREBOUT(CHAINE,"V") From GOBJET # Post
  Call VIREBOUT(CHAINE,"B") From GOBJET # Open items
Endif
#####

# X3-197349 2020-05-20 Bader begin disable "Open items" if coming from MODECHE
If GFONC1 = "MODECHE"
  Call VIREBOUT(CHAINE,"B") From GOBJET # Open items
Endif
# X3-197349 2020-05-20 Bader end

#----- Menus "Adresse facture"  et "Adresse rčglement"  dans la ToolBar -----#
If (GREP<>"" | CLECUR ) & [M]STA<=3
 CHMEN+="67"
Endif
Raz GMESSAGE

# BRBAN 105200#US2 - Deactivate Open items button
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
   Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
Endif

#angre X3-133989
If func AFNC.ACTIV("KSW")>0
  Gosub SETBOUT_BIC From SWIQRCLIB2
Endif

Return

$AVANTBOUT
Case BOUT
 When "B" : Gosub AV_ECHEAN
 When "1" : Gosub AV_TUNNEL   # Toolbar "Zoom" : sous menu "Pičces Comptables"
 When "2" : SAVCONS=GCONSULT  # les pičces comptables
 When "6" :# Adresse Facture
  [L]BPRADR       = [M:BIC0]BPAINV
  [L]BPRNAM(0)    = [M:BIC0]BPRNAMBIS(0)
  [L]BPRNAM(1)    = [M:BIC0]BPRNAMBIS(1)
  [L]BPAADDLIG(0) = [M:BIC0]BPAADDLIG(0)
  [L]BPAADDLIG(1) = [M:BIC0]BPAADDLIG(1)
  [L]BPAADDLIG(2) = [M:BIC0]BPAADDLIG(2)
  [L]CRY          = [M:BIC0]CRY
  [L]CRYNAM       = [M:BIC0]CRYNAM
  [L]SAT          = [M:BIC0]SAT
  [L]POSCOD       = [M:BIC0]POSCOD
  [L]CTY          = [M:BIC0]CTY
  If dim([M:BIC0]ADRVAL) > 0 : [L]ADRVAL = [M:BIC0]ADRVAL : Endif   #LTA.n
 When "7" :# Adresse Payeur
  [L]BPRADR       = [M:BIC1]BPAPAY
  [L]BPRNAM(0)    = [M:BIC1]BPYNAM(0)
  [L]BPRNAM(1)    = [M:BIC1]BPYNAM(1)
  [L]BPAADDLIG(0) = [M:BIC1]BPYADDLIG(0)
  [L]BPAADDLIG(1) = [M:BIC1]BPYADDLIG(1)
  [L]BPAADDLIG(2) = [M:BIC1]BPYADDLIG(2)
  [L]CRY          = [M:BIC1]BPYCRY
  [L]CRYNAM       = [M:BIC1]BPYCRYNAM
  [L]SAT          = [M:BIC1]BPYSAT
  [L]POSCOD       = [M:BIC1]BPYPOSCOD
  [L]CTY          = [M:BIC1]BPYCTY

 #### CATUA 87307 Intercompany enhancement
 When "4" : # Accounting Cancellation
  #X3-119538 start
  If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
  Filter [F:DAE] Where [F:DAE]NUM = [M:BIC0]NUM and [F:DAE]AMTVAT <> 0
  If rowcount([F:DAE]) > 0
    GMESSAGE = mess(238,104,1)
    OK = 0
    Filter [F:DAE]
    Return
  Endif
  #X3-119538 end
  If GFONC1 = "GESBICI"
    Raz RETCPY
    If not func INTCPYLIB.CHKINTCPY(2,RETCPY)
      ##Cancellation is not allowed. Parameter POSTINVSUP must be set to Yes for company XX in order to cancel this invoice.
      GMESSAGE = func AFNC.MES1(mess(162,104,1),RETCPY)
      OK = 0 : Return
    Endif
  Endif
 #### Intercompany enhancement End

  When "V" #Validation
    # Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
    # Issue 115715
    If GAC_KPO
    #97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
    #If find([F:SIH]INVTYP,2,4) & func AFNC.ACTIV("KPO")
    # End issue 115715
      If func PORLEGLIB.DIGSIGN([F:SIH]FCY, "")
        Gosub VLD_CREDIT_NOTE_BIC From PORLEGLIB
        If GOK = 0 : Return : Endif
      Endif
    Endif
    #97101 RICAR 2014/07/03 - 50001 Law decret - END
Endcase
Return

$AV_ECHEAN
SAVCONS=GCONSULT
Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
If ![L]ACCFCY | !instr(1,[L]AUZFCY,"E")
     GCONSULT=1
Else GCONSULT=0
Endif
Raz GMESSAGE
Return

$AV_TUNNEL
    SAVCONS=GCONSULT
# 2019-08-13 DNE INSERT BEGIN (X3-146200)
    SAVNBTYPLED = GNBTYPLED
    For NLED = 1 To dim(SAVTYPLED)
        SAVTYPLED(NLED) = GTYPLED(NLED)
    Next
# 2019-08-13 DNE INSERT END
    If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
    Read [HAE]HAE0 = [M:BIC0]GTE;[M:BIC0]NUM
    If fstat
       OK = 0 : Return
    Else
       GFLAG  = [F:HAE]DACDIA
       GBIDC2 = [M:BIC0]NUM
       GBIDC3 = [M:BIC0]GTE
       GCONSULT = 1
    Endif
Return

$EXEBOUT
Case REP
 When "B" :  # Modélisé : action SAIECHBIC
  GCONSULT=SAVCONS
  Gosub AP_ECHE
  If GCONSULT<>2 : Gosub VERROU : Endif
 When "V" :  # aprčs action BICVAL (validation des factures)
  Gosub OUVRE From ="WO"+ABREV
  Gosub RELIT From GOBJSUB
Endcase
Return

$STATUT
    Case BOUT
     When "4" : # aprčs annulation comptable
        Gosub RELIT From GOBJSUB
     When "1","2" : # les pičces comptables
# 2019-08-13 DNE INSERT BEGIN (X3-146200)
        If BOUT = "1"
            GNBTYPLED = SAVNBTYPLED
            For NLED = 1 To dim(SAVTYPLED)
                GTYPLED(NLED) = SAVTYPLED(NLED)
            Next
        Endif
# 2019-08-13 DNE INSERT END
        GCONSULT=SAVCONS
     When "5"  :# Transformation Facture en avoir
        FACTAVO=1
    Endcase
Return

$APRES_CHOI
If REPONSE = GSTAANU
 REPONSE = 0
 If !VERROU : Return : Endif
 OK=1 : Call OUINON(mess(28,100,1),OK) From GESECRAN
 If OK=2
  ##AP/AR RecurInv
  Local Char RCRNUM
  Raz RCRNUM
  Call CHECKRCR([M:BIC0]NUM, "BIC0", RCRNUM) From SUBRCR
  If RCRNUM<>""
   ##The invoice number is referenced on recurring invoice, XX. You must remove the link before deleting.
   GMESSAGE = func AFNC.MES1(mess(96,119,1),RCRNUM)
   GOK = 0 : Return
  Endif
  ##AP/AR RecurInv End

  #### CATUA 87307 Intercompany enhancement
  If GFONC1 = "GESBICI"
    Raz RETCPY
    If not func INTCPYLIB.CHKINTCPY(1,RETCPY)
      ##Invoice cannot be deleted. Parameter SIVSUP must be set to Yes for company XX in order to delete this invoice.
      GMESSAGE = func AFNC.MES1(mess(161,104,1),RETCPY)
      GOK = 0 : Return
    Endif
  Endif
  #### Intercompany enhancement End

  #issue X3-69271 - 2019-02-12 by MANOW
  If [M:BIC0]INVTYP=3 and func IS_DNO([M:BIC0]NUM)=1
    If func CAN_REMOVE_INVDNO([M:BIC0]NUM)=1
      Call DEBTRANS From GLOCK
      Gosub TR2
    Else
      GMESSAGE = func AFNC.MES1(mess(237,104,1),[M:BIC0]NUM)
      GOK = 0 : Return
    Endif
  Else
    Call DEBTRANS From GLOCK
    Gosub TR2
  Endif
  #end issue

  # Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Invoice Deletion)
  If GOK=1
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
      Call CANCEL_TAX([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP) From TRTTAXSST
      If !GOK
        GMESSAGE = func AFNC.MES1(mess(539,192,1),[F:SIH]NUM)
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        Raz GMESSAGE : GOK=1
      Endif
    Endif

    If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
      Local Integer SEVCRTYP
      If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
      Call VOID_ALL(SEVCRTYP,[F:SIH]NUM,GERR,GMESSAGE) From SEPPLIB
      If GERR
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        Raz GMESSAGE, GERR : GOK=1
      Endif
    Endif
  Endif
  # Issue 117131.e

  If GOK=1
   Call ESPION(NOMFIC,1,CLECUR1,"") From ESPION
   Call MESSAGE("OBJBIC","A",CLECUR1) From SUBAMS
   CLECUR = 0
  Endif
  Gosub DEVERROU From GOBJET
  Gosub RELIT From GOBJSUB
 Endif
Endif
Return

$FIN_ACTION
Case BOUT
 When "6" : # Adresse Facture
  If [L]BPRADR<>[M:BIC0]BPAINV |
&    [L]BPRNAM(0)<>[M:BIC0]BPRNAMBIS(0) |
&    [L]BPRNAM(1)<>[M:BIC0]BPRNAMBIS(1) |
&    [L]BPAADDLIG(0)<>[M:BIC0]BPAADDLIG(0) |
&    [L]BPAADDLIG(1)<>[M:BIC0]BPAADDLIG(1) |
&    [L]BPAADDLIG(2)<>[M:BIC0]BPAADDLIG(2) |
&    [L]CRY<>[M:BIC0]CRY |
&    [L]CRYNAM<>[M:BIC0]CRYNAM |
&    [L]SAT<>[M:BIC0]SAT |
&    [L]POSCOD<>[M:BIC0]POSCOD |
&    [L]CTY<>[M:BIC0]CTY  |
&    (dim([M:BIC0]ADRVAL)>0 & [L]ADRVAL<>[M:BIC0]ADRVAL)    #LTA.n
   # Si création de facture modif d'adresse n'est pas une modif de la facture
   If !find(GREP,"C","D")
    GREP="M" : REP="M"
    If [M:BIC0]NUM<>"" : Gosub GRISE_CLE From =WINPROG : Endif
   Endif
  Endif
 When "7" : # Adresse Payeur
  If [L]BPRADR<>[M:BIC1]BPAPAY |
&    [L]BPRNAM(0)<>[M:BIC1]BPYNAM(0) |
&    [L]BPRNAM(1)<>[M:BIC1]BPYNAM(1) |
&    [L]BPAADDLIG(0)<>[M:BIC1]BPYADDLIG(0) |
&    [L]BPAADDLIG(1)<>[M:BIC1]BPYADDLIG(1) |
&    [L]BPAADDLIG(2)<>[M:BIC1]BPYADDLIG(2) |
&    [L]CRY<>[M:BIC1]BPYCRY |
&    [L]CRYNAM<>[M:BIC1]BPYCRYNAM |
&    [L]SAT<>[M:BIC1]BPYSAT |
&    [L]POSCOD<>[M:BIC1]BPYPOSCOD |
&    [L]CTY<>[M:BIC1]BPYCTY
   # Si création de facture modif d'adresse n'est pas une modif de la facture
   If !find(GREP,"C","D")
    GREP="M" : REP="M"
    If [M:BIC0]NUM<>"" : Gosub GRISE_CLE From =WINPROG : Endif
   Endif
  Endif
Endcase
Return

$TRANSAC
TRANSAC=""
If [F:SIH]SIVTYP = "" : Return : Endif
Call GETSOC([F:SIH]FCY) From DEVSUB
Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP) From CPTLEC
If fstat | [F:TSV]INVTYP=5 | [F:TSV]COD2="" : Return : Endif
TRANSAC = [F:TSV]COD2
Return


Subprog VALID(NUM)

Value Char NUM
Local Integer I , OK , STAT , INVTYP, SIGN
Local Integer NBLET , MAXLET , LETTYP , LETDEB
Local Char    MESSA(250) , IDENT(30) , TRANSAC(10), JOURNAL(GLONJOU), TIT(30)
#*X3-39795 Local Char    TZONE(10)(1..3) : # Table des zones ŕ forcer (Ex: type de pičce)
#*X3-39795 Local Char    TVAL(10)(1..3)  : # Table des valeurs des zones ŕ forcer
Local Char    TZONE(10)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
Local Char    TVAL(30)(1..10)            : # Table of values for zones to be forced
#*X3-39795 Local Char    TZONE2(10)(1..1)
#*X3-39795 Local Char    TVAL2(10)(1..1)
Local Char    TZONE2(10)(1..10)
Local Char    TVAL2(30)(1..10)
MAXLET = 150
Local Integer LETNUM(1..MAXLET) , LETLIG(1..MAXLET)
Local Decimal LETIPT(1..MAXLET) , LETMNT(1..MAXLET)
Local Decimal SOMME , SOM1 , SOM2
Local Integer WVALFAC : WVALFAC=1

# Nouvelle Variable pour la gestion des groupes de pičces
Local Char TMESSA(100)(1..10)
Local Integer NBRVCR,INDVCR
Local Integer FVAL(1..10)
Local Integer FVAL2(1..10)

IDENT  = NUM
# Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
# Issue 115715
If GAC_KPO
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
#If find([F:SIH]INVTYP,2,4) & func AFNC.ACTIV("KPO")
# End issue 115715
  If func PORLEGLIB.DIGSIGN([F:SIH]FCY, "")
    Gosub VLD_CREDIT_NOTE_BIC From PORLEGLIB
    If GOK = 0 : End : Endif
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

# Ini TBAI Slice 2 X3-190239 TicketBai : control of Invoice validation sequence (JUCON 2020-04-14)
If func AFNC.ACTIV("CTSW")
  Gosub CTL_VAL_INVSPA
Endif
# End TBAI Slice 2 X3-190239 TicketBai : control of Invoice validation sequence (JUCON 2020-04-14)

If adxtrans
 Gosub TR11
Else
 Call DEBTRANS From GLOCK
 Gosub TR1

Endif
End

$TR1
GOK = 1
Trbegin [SIH]
 Gosub TR11
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit

# Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Invoice Validation)
Local Integer WSGOK
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 and  [F:SIH]INVTYP>=1 and  [F:SIH]INVTYP<=4
  WSGOK = GOK
  Local Integer ERR
  Local Char ERRMSG(250)
  GSSTCOMMIT = 1
  If GFONCTION <> "BPCVAL"
    Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXSST
    #[F:SIH]AMTATI = [M:BIC1]AMTATI
    Gosub CREMOD_LTV From TRTTAXSST
  Else
    Call POSTBPINV(ERR,ERRMSG) From TRTTAXSST
  Endif
  GSSTCOMMIT = 0
  If !GOK
    If GTRACE=""
      GERR=1
    Else
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      GMESSAGE = func AFNC.MES1(mess(536,192,1),[F:SIH]NUM)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Raz GMESSAGE
    Endif
  Endif

  # We no longer want to end processing here.  So set GOK back
  GOK = WSGOK
Endif

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
  WSGOK = GOK
  Local Integer SEVCRTYP
  If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif

  Call DOC_VALIDATION (SEVCRTYP,[F:SIH]NUM) From SEPPLIB2
  If !GOK
    If GTRACE=""
      GERR=1
    Else
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      GMESSAGE = func AFNC.MES1(mess(60,2092,1),[F:SIH]NUM)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Raz GMESSAGE
    Endif
  Endif

  # Assuming no error - time to create the payment
  Local Integer NUMPAY
  If GOK : Call AUTO_PAYMENT(SEVCRTYP,[F:SIH]NUM,[L]NUMPAY) From SEPPLIB2 : Endif

  # We no longer want to end processing here.  So set GOK back
  GOK = WSGOK
Endif
# Issue 117131.e

# Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Comment out - Invoice Validation)
# 78411 Sage Exchange
#If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
#  Local Integer SEVCRTYP
#  If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
#  Local Integer NUMPAY
#  Call AUTO_PAYMENT(SEVCRTYP,[F:SIH]NUM,[L]NUMPAY) From SEPPLIB2 # 116638.n
#  #Call AUTO_PAYEMNT(SEVCRTYP,[F:SIH]NUM) From SEPPLIB2  # 116638.o
#Endif
# Issue 117131.e

# Issue X3-170918 2020-01-21 JUCON Control Software TicketBai
If func AFNC.ACTIV("CTSW")
  Call SEND_TBAI([F:SIH]NUM,1) From TRTSENDCTSW
Endif
# Issue X3-170918 2020-01-21 end

Return

$TR11
 Readlock [SIH]SIH0 = NUM
 If fstat=1
  GOK=-1 : GLOCK="$SINVOICE"-NUM : Return
 Elsif fstat
  GOK=0 : Call RSTA("SIH",NUM) From GLOCK : Return
 Endif

 Call GETDEV([F:SIH]FCY) From DEVSUB
 Call GETSOC([F:SIH]FCY) From DEVSUB
 #X3-112211
 #If func SUBBIC2.FIN_PARAM(GAC_SDD, "SDDMGT",[F:SIH]CPY)="2"
 If func AFNC.ACTIV("SDD") & func SUBBIC2.FIN_PARAM(GAC_SDD, "SDDMGT",[F:SIH]CPY)="2"
 #end X3-112211
  If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif
  For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
   Call LEC_TAM(GCURLEG,[F:DUD]PAM) From CPTLEC
   If !fstat & [F:TAM]SDDFLG=2 & [F:DUD]UMRNUM=""
    GMESSAGE = mess(10,123,1)
    Gosub TIT From WOMDT : GMESSAGE = mess(39,117,1)+"\"+TIT-":"-GMESSAGE
    GOK=0 : GERR=1 : Break
   Endif
  Next
  If GOK<=0 : Return : Endif
 Endif
 #49900.sn - Check for valid credit card authorization status - JOBRO
 If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
   If not func SEPPLIB2.INVOICE_AUTH_CHECK([F:SIH]NUM)
     GOK = 0
     GMESSAGE = [F:SIH]NUM-":"-mess(35,2092,1)
     GERR=1
     Return
   Endif
 Endif
 #49900.en
 Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP) From CPTLEC
# BRBAN 105200#US2 Automatic journal must be from the original invoice
Local Integer WFSTA : [L]WFSTA = fstat
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN(GCURLEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Read [F:ISIH]SIH0=[F:SIH]INVNUM
    If !fstat
      # Read the original invoice type
      Call LEC_TSV_LEG(GCURLEG,[F:ISIH]SIVTYP) From CPTLEC
    Endif
  Else
    fstat = [L]WFSTA
  Endif
Else
  fstat = [L]WFSTA
Endif
# -

 If fstat | [F:TSV]COD2 =""
  # Pičce auto non paramétrée dans le type de facture
  GMESSAGE = TIT+mess(55,119,1)-[F:SIH]SIVTYP
  If GFONCTION="BPCVAL" :  GMESSAGE = mess(55,119,1)-[F:SIH]SIVTYP : Endif
  GOK=0 : GERR=1 : Return
 Endif
 TRANSAC = [F:TSV]COD2

 # BRBAN 105200#US2 Automatic journal must be from the original invoice
 If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    # Re-read the credit note type
    Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP) From CPTLEC
  Endif
 Endif

 # Pour les anciennes factures
 JOURNAL = [F:SIH]JOU
 If JOURNAL = ""
  JOURNAL = [F:TSV]JOU
  If JOURNAL = "" & TRANSAC<>""
   Call EVALAUTO(TRANSAC,"JOU",JOURNAL)
   If JOURNAL=""
    Call LEC_GTE_LEG(GCURLEG,[F:SIH]GTE) From CPTLEC
    If !fstat
     JOURNAL = [F:GTE]DEFJOU
    Endif
   Endif
  Endif
  If JOURNAL=""
   # Journal non défini
   GMESSAGE = TIT+mess(53,141,1)
   If GFONCTION="BPCVAL" :  GMESSAGE = mess(53,141,1) : Endif
   GOK=0 : GERR=1 : Return
  Endif
  [F:SIH]JOU = JOURNAL
  If clalev([M:BIC0])>0 : [M:BIC0]JOU = JOURNAL : Endif
 Endif

 If [F:SIH]NBRCPY<=1
  Gosub JOUGNR_SRC
  If GOK<1 : Return : Endif
 Else
  If clalev([F:ICF])=0  : Local File INTCOFLO  [ICF]  : Endif
  ## Generation on the Source Company
  Gosub JOUGNR_SRC
  If GOK<1 : Return : Endif
  ## Generation on the Target Company
  Gosub JOUGNR_TRG
  If GOK<1 : Return : Endif
 Endif

 NBLET = 0
 For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM & LIG=1
  NBLET += 1
  LETNUM(NBLET) = [F:DUD]ACCNUM
  LETLIG(NBLET) = [F:DUD]DUDLIG
  LETMNT(NBLET) = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
  [F:DUD]DUDSTA = 2
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[F:SIH]ACCDAT)From MODECHE
 Next
 If GOK<=0 : Return : Endif

 [F:SIH]STA = 3
 If dim([F:SIH]EXPNUM)>0  [F:SIH]EXPNUM=[C]EXPORT : Endif
 Rewrite [SIH]
 If fstat
  GOK = 0 : Call FSTA("SIH") From GLOCK : Return
 Endif

 #issue X3-126774 by MANOW
 If find([F:SIH]INVTYP,2,4)
   If clalev([F:DNO])=0 : Local File DNODEBNOT  [DNO] : Endif #issue X3-138681 MANOW
#  Delete [F:DNO] Where [F:DNO]DNONUM=[M:BIC1]INVNUM
   Delete [F:DNO] Where [F:DNO]NUM=[F:SIH]INVNUM # [F:SIH]INVNUM instead of [M:BIC1]INVNUM for BPCVAL      #issue X3-138681 MANOW
   If fstat=1
    GOK=-1 : GLOCK = "$DNODEBNOT"-[M:BIC1]INVNUM : Goto ROLL_TR2
   Endif
 Endif
 #end issue

 # Maj client
 SIGN = -1 : Gosub MAJCLI
 If GOK<=0 : Return : Endif

 # Lettrage facture et avoir
 If [F:SIH]INVNUM<>""
  Call LETAVOIR([F:SIH]NUM,[F:SIH]INVNUM)
 Endif
 If GOK<=0 : Return : Endif

 # Etalement des prestations
 # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
 If func SUBBIC2.FIN_PARAM(GAC_SVC, "SVCFLG",[F:SIH]CPY)="2"
 # End issue X3-199974
  Call TRANSFERT("KIK1",[F:SIH]NUM,[F:SIH]SIVTYP,STAT) From CPTTRS
  If STAT : GOK=0 : Endif
  If GOK<=0 : GERR=1 : Return : Endif
 Endif

# ----------------------------------------------------------- #
# -- RMA * DKS Activity code related. Sign Document.          #
# ----------------------------------------------------------- #
If func AFNC.ACTIV("DKS")
    Local Char DKSORIG : DKSORIG = "BIC"
    Local Integer DKSRET : DKSRET = 1
    Gosub DKS_SIGN_TRIGGER From DKSLIB
    If DKSRET = 0 : GOK=0 : Return : Endif
    # Issue X3-222040- 2020-11-01 by VAVIL : [PT] QR code printed in Sales documents
    Local Integer QRSTAT
    Call GEN_QRCODE_INV(NUM,QRSTAT) From PORLEGQRCDOCLIB
    # End issue X3-222040
Endif

# X3-86640
If func FRADSILIB.DSFRA("SIH", [F:SIH]CPY)
  Gosub SIGN_SIH From FRADSILIB
  If GOK < 1 : Return : Endif
Endif

# Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Comment out - Invoice Validation)
#If func AFNC.ACTIV("LTA") and [F:CPY]SSTTAXACT = 2 and  [F:SIH]INVTYP>=1 and  [F:SIH]INVTYP<=4
#  Local Integer ERR
#  Local Char ERRMSG(250)
#  GSSTCOMMIT = 1
#  If GFONCTION <> "BPCVAL"
#    Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXSST
#    [F:SIH]AMTATI = [M:BIC1]AMTATI
#    Gosub CREMOD_LTV From TRTTAXSST
#  Else
#      Call POSTBPINV(ERR,ERRMSG) From TRTTAXSST
#  Endif
#  GSSTCOMMIT = 0
#  If !GOK : Return : Endif
#Endif
#
# 78411 Sage Exchange
# If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
#   Local Integer SEVCRTYP
#   If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
#   Call DOC_VALIDATION(SEVCRTYP,[F:SIH]NUM) From SEPPLIB2
#   If !GOK
#     GERR=1
#     Return
#   Endif
# Endif
 # Issue 117131.e

# 2019-02-18 DNE MODIF INSERT (X3-112863)
  If func LIBINVTAX.LOCDATAFNC( NUM )
      GOK = 0 # Signal error
      Return
  Endif
# 2019-02-18 DNE MODIF END

 GPE = 0
 GPOINT = "BEFVALBIC" : Gosub ENTREE From EXEFNC
 If GPE : GOK=0 : Return : Endif
Return


$JOUGNR_SRC
Raz TZONE, TVAL
TZONE(1)="TYP"    : TVAL(1)=[F:SIH]GTE
TZONE(2)="JOU"    : TVAL(2)=[F:SIH]JOU
TZONE(3)="TYPDUD" : TVAL(3)="2"

#*X3-39795 Manage ORIGINE and ORICOD
# (MWA X3-39795) start
TZONE(5)="ORIGIN" : TVAL(5)="2"   : # Automatic loading
TZONE(6)="ORICOD" : TVAL(6)="TRANSAC"
# (MWA X3-39795) end
# Passage par les groupes de pičces
Call EVALGRP(TRANSAC,"NUM","SIH]NUM",FVAL) From VALGRP
Call VALGRP3(TRANSAC,IDENT,STAT,TMESSA,TZONE,TVAL,FVAL) From VALGRP
If STAT
 GOK = 0 : GERR = 1 : GMESSAGE = TMESSA(1) : Return
Else
 # Mise ŕ jour de la table des liens + Affichage de la liste des pičces
 NBRVCR = find("",TMESSA(1..dim(TMESSA)))
 For INDVCR = 1 To NBRVCR-1
  Call LNKGRP("2",[F:SIH]NUM,[F:SIH]ACCNUM,TMESSA(INDVCR),STAT,MESSA) From VALGRP
  If STAT
   GOK = 0 : Break
  Else
   # Création de pičces
   If [L]NBRVCR>2 : Call ECR_TRACE(mess(40,107,1)-":"-MESSA,0) From GESECRAN : Endif
  Endif
  If INDVCR = 1 & [F:SIH]NBRCPY>1 : # Intercompany Invoices
   Readlock [ICF]ICF0 = "SIH";[F:SIH]NUM;[F:SIH]CPY;[F:SIH]CPY
   If fstat=1
    GOK=-1 : GLOCK="$INTCOFLO"-"SIH"-[F:SIH]NUM-[F:SIH]CPY-[F:SIH]CPY : Break
   Elsif fstat
    GOK=0 : Call RSTA("ICF","SIH"-[F:SIH]NUM-[F:SIH]CPY-[F:SIH]CPY) From GLOCK : Break
   Endif
   If instr(1,TMESSA(INDVCR),"~")
    [F:ICF]TYPVCR = left$(TMESSA(INDVCR),instr(1,TMESSA(INDVCR),"~")-1)
    [F:ICF]NUMVCR = right$(TMESSA(INDVCR),len([F:ICF]TYPVCR)+2)
   Else
    [F:ICF]NUMVCR = MESSA
   Endif
   Rewrite [ICF]
   If fstat
    GOK=0 : Call FSTA("ICF") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<=0 : GERR = 1 : Return : Endif
Endif
Return

$JOUGNR_TRG
Raz TZONE2, TVAL2
For [ICF]ICF0 Where ABRFIC="SIH" & NUM=[F:SIH]NUM & CPYSRC=[F:SIH]CPY & CPYTGR<>[F:SIH]CPY & FCYTGR=""
 GSOCIETE = [F:ICF]CPYTGR
 TZONE2(1)= "TYPDUD" : TVAL2(1)= "2"
 #*X3-39795 Manage ORIGINE and ORICOD
 # (MWA X3-39795) début
 TZONE2(5)="ORIGIN" : TVAL2(5)="2"                #Automatic loading
 TZONE2(6)="ORICOD" : TVAL2(6)=TRANSAC
 # (MWA X3-39795)  fin
 # Passage par les groupes de pičces
 Call EVALGRP(TRANSAC,"NUM","SIH]NUM",FVAL2) From VALGRP
 Call VALGRP3(TRANSAC,IDENT,STAT,TMESSA,TZONE2,TVAL2,FVAL2) From VALGRP
 If STAT
  GOK = 0 : GERR = 1 : GMESSAGE = TMESSA(1)-"("+mess(2,45,1)-GSOCIETE+")" : Break
 Else
  # Mise ŕ jour de la table des liens + Affichage de la liste des pičces
  NBRVCR = find("",TMESSA(1..dim(TMESSA)))
  For INDVCR = 1 To NBRVCR-1
   Call LNKGRP("2",[F:SIH]NUM,[F:SIH]ACCNUM,TMESSA(INDVCR),STAT,MESSA) From VALGRP
   If STAT
    GOK = 0 : Break 2
   Else
    # Création de pičces
    If [L]NBRVCR>2 : Call ECR_TRACE(mess(40,107,1)-":"-MESSA,0) From GESECRAN : Endif
   Endif
   If INDVCR = 1
    If instr(1,TMESSA(INDVCR),"~")
     [F:ICF]TYPVCR = left$(TMESSA(INDVCR),instr(1,TMESSA(INDVCR),"~")-1)
     [F:ICF]NUMVCR = right$(TMESSA(INDVCR),len([F:ICF]TYPVCR)+2)
    Else
     [F:ICF]NUMVCR = MESSA
    Endif
    Rewrite [ICF]
    If fstat
     GOK=0 : Call FSTA("ICF") From GLOCK : Break 2
    Endif
   Endif
  Next
 Endif
Next
Call GETSOC([F:SIH]FCY) From DEVSUB
If GFONC1="GESBICI"
 Call INI_GLOBAL(1,GSOCIETE,STAT,MESSA) From SUBBICS
Endif
If GOK<=0 : GERR = 1 : Return : Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
#issue X3-69271 - 2019-02-12 by MANOW
Trbegin [SIH], [SIL], [SIA], [DUD], [MVC], [DNO]
#end issue

 #issue X3-181159
 If (GSAMETP = [V]CST_AYES) Then
  # Additional table management
  GPOINT="SABICADDON"
  Gosub ENTREE From EXEFNC
  If   GOK<0 : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif
 Endif
 #end issue

 SIGN = -1 : Gosub MAJCLI
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Delete [SIA] Where NUM=[M]NUM
 If fstat=1
  GOK=-1 : GLOCK = "$BPCINVLIGA"-[M]NUM : Goto ROLL_TR2
 Endif
 Delete [SIL] Where NUM=[M]NUM
 If fstat=1
  GOK=-1 : GLOCK = "$BPCINVLIG"-[M]NUM : Goto ROLL_TR2
 Endif
 Delete [SIH] Where NUM=[M]NUM
 If fstat=1
  GOK=-1 : GLOCK = "$SINVOICE"-[M]NUM : Goto ROLL_TR2
 Endif
 CRITSUPPR="TYP='"+[M]GTE+"' & NUM='"+[M]NUM+"'"
 Call HISTOSUPPR (CRITSUPPR) From MODECHE
 Delete [DUD] Where TYP=[M]GTE & NUM=[M]NUM
 If fstat=1
  GOK=-1 : GLOCK = "$GACCDUDATE"-[M]NUM : Goto ROLL_TR2
 Endif

 #issue X3-69271 - 2019-02-12 by MANOW
 Delete [F:DNO] Where [F:DNO]DNONUM=[M:BIC0]NUM
 If fstat=1
  GOK=-1 : GLOCK = "$DNODEBNOT"-[M:BIC0]NUM : Goto ROLL_TR2
 Endif
 #end issue

 If GAC_INTCO & [F:SIH]NBRCPY>1
  Call UPD_INTCOFLO(1,3,[F:SIH]NUM,[F:SIH]NBRCPY) From INTCPYLIB2
  If   GOK<0 : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif
 Endif

# Issue 117131.s - 2016-09-17 by CATUA : Move WS calls outside database transactions (Comment out - Invoice Deletion)
# If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
#  Call CANCEL_TAX([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP) From TRTTAXSST
#  If  !GOK : GOK=-1 : Goto ROLL_TR2 : Endif
# Endif

# 78411 Sage Exchange
# If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
#  If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
#  Call VOID_ALL(SEVCRTYP,[F:SIH]NUM,GERR,GMESSAGE) From SEPPLIB
#  If GERR : GOK=0 : Goto AB_TR2 : Endif
# Endif
# Issue 117131.e

 # BRBAN 105200#US2 When deleting a invoice cancellation credit note, REVCANSTA=0 on ORISIHNUM
 If func AFNC.ACTIV("INVCA")>0
   If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Read [F:ISIH]SIH0=[F:SIH]INVNUM
    If !fstat
      [F:ISIH]REVCANSTA = 0
      Rewrite [F:ISIH]
    Endif
   Endif
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

$SHDCLEECNUM
If ! dim([M:BIC1]DCLEECNUM)>0 : Return : Endif
Local Shortint SHOWFIELD
Local Char     CRYEECFMT(30), BPRNUM(GLONBPR)
#set flg to show or hide the field  : # X3-101376  removal of AUTVAT
If func SUBBIC2.FIN_PARAM(GAC_KPO, "PORVAT", GSOCIETE) = "2" | func SUBBIC2.FIN_PARAM(GAC_KDE, "GERVAT", GSOCIETE) = "2"
  SHOWFIELD = 1
Else
  SHOWFIELD = 0
Endif

# Issue 101376
#Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GACTX.APARAM) From SYRSTACKTOOLS
#Local Integer I_R
#I_R= fmet GACTX.APARAM.ADELETERRORALL()
# End issue 101376


#get contry EECFMT of current bpr
Raz CRYEECFMT
If zoncou = "BPR"
  BPRNUM = VALEUR
Else
  BPRNUM = [M:BIC0]BPR
Endif
If BPRNUM <> ""
  Call LEC_BPR(BPRNUM) From CPTLEC
  Call LEC_TCY([F:BPR]CRY) From CPTLEC
  CRYEECFMT = [F:TCY]EECFMT
Else
  CRYEECFMT = num$(GLONEEC)+"X"
Endif
If CRYEECFMT = "" : FIELDFMT = "20X" : Endif

#show/hide
If SHOWFIELD
  If [M:BIC1]STA=3
    Chgfmt [M:BIC1]DCLEECNUM With "KP:"+CRYEECFMT
  Else
    Chgfmt [M:BIC1]DCLEECNUM With "K:"+CRYEECFMT
  Endif
Else
  Chgfmt [M:BIC1]DCLEECNUM With "-K:"+CRYEECFMT
Endif

Return


# Issue 117131.s - 2016-09-22 by CATUA : Move WS calls outside database transactions (Invoice creation)
$RECALC_SST
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Gosub RECALC_SST_BIC From TRTTAXSST #122614 - JOBRO - rework of transaction mgmt
Endif
#122614.so
