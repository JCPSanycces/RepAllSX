# Issue 117131.e

################################################
Subprog LETAVOIR(AVOIR,FACTURE)
Value Char AVOIR
Value Char FACTURE

If FACTURE="" or AVOIR="" : End : Endif

Local Char VALPAR(10)
Call PARAM([F:SIH]CPY,"LETAUTCNO",VALPAR) From ADOVAL

#BRBAN 105200#US2 If is Invoice cancellation credit note, it must be automatic matched
If func AFNC.ACTIV("INVCA")>0
  Local Char OLD_SIVYTP(50) : [L]OLD_SIVYTP=[F:TSV]SIVTYP
  Local Char OLD_LEG(30)    : [L]OLD_LEG   =[F:TSV]LEG

  #Call LEC_TSV_LEG(GCURLEG,[M]SIVTYP) From CPTLEC
  Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP) From CPTLEC
  If func TRTINVCAN.INVCAN(GCURLEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    VALPAR = "2"
  Endif
  Call LEC_TSV_LEG([L]OLD_LEG,[L]OLD_SIVYTP) From CPTLEC
Endif
#-

If val(VALPAR) = 1 : End : Endif

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE) : End : Endif

Local Integer NBLET , MAXLET , LETTYP , LETDEB , I , STAT, LETSOC
MAXLET = 150
Local Integer LETNUM(1..MAXLET) , LETLIG(1..MAXLET)
Local Decimal LETIPT(1..MAXLET) , LETMNT(1..MAXLET)
Local Decimal SOMME , SOM1 , SOM2

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
If clalev([F:SIH2])=0 : Local File SINVOICE   [SIH2] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif

Call LEC_CPY([F:SIH]CPY) From CPTLEC

If AVOIR<>[F:SIH]NUM
 Read [SIH]SIH0 = AVOIR
 If fstat : End : Endif
Endif

Read [SIH2]SIH0 = FACTURE
If fstat : End : Endif
If [F:SIH]BPRFCT<>"" & [F:SIH2]FCTVCR<>"" : End : Endif

# Lettrage en devise de société si les devises facture et avoir sont différentes
LETSOC = ([F:SIH]CUR<>[F:SIH2]CUR)

NBLET = 0
For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=AVOIR & LIG=1
 NBLET += 1
 LETNUM(NBLET) = [F:DUD]ACCNUM
 LETLIG(NBLET) = [F:DUD]DUDLIG
 If LETSOC
  LETMNT(NBLET) = [F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC
 Else
  LETMNT(NBLET) = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Endif
 [F:DUD]DUDSTA = 2
 Rewrite [DUD]
 If fstat
  GOK=0 : Call FSTA("DUD") From GLOCK : Break
 Endif
 Call HISTOECH("DUD",1,[F:SIH]ACCDAT)From MODECHE
Next
If GOK<1 : End : Endif

LETDEB = NBLET
For [DUD]DUD1 Where ACCNUM=[F:SIH2]ACCNUM
 NBLET += 1
 LETNUM(NBLET) = [F:DUD]ACCNUM
 LETLIG(NBLET) = [F:DUD]DUDLIG
 If LETSOC
  LETMNT(NBLET) = [F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC
 Else
  LETMNT(NBLET) = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Endif
Next
SOM1 = sum(LETMNT(1..LETDEB))
SOM2 = sum(LETMNT(LETDEB+1..NBLET))
## <PP 04/06/03> Bug 18743 : Si la facture d'origine comporte un code factor et que le montant de l'avoir est égal
## au montant de la facture d'origine, on supprime de le code factor de la facture
If SOM1 =  SOM2 & [F:SIH2]BPRFCT<>"" & [F:SIH]BPRFCT=""
 [F:SIH2]BPRFCT = ""
 Rewrite [SIH2]
 If fstat
  GOK = 0 : Call FSTA("SIH2") From GLOCK : End
 Endif
 For [DUD2]DUD1 Where ACCNUM = [F:SIH2]ACCNUM
  [F:DUD2]BPRFCT = ""
  Rewrite [DUD2]
  If fstat
   GOK = 0 : Call FSTA("DUD2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : End : Endif
Endif
## <Fin PP>
SOMME = min(SOM1,SOM2)
For I=1 To LETDEB
 If LETMNT(I)<SOMME
  LETIPT(I) = LETMNT(I)
  SOMME -= LETIPT(I)
 Else
  LETIPT(I) = SOMME : Break
 Endif
Next I
SOMME = min(SOM1,SOM2)
For I=LETDEB+1 To NBLET
 If LETMNT(I)<SOMME
  LETIPT(I) = LETMNT(I)
  SOMME -= LETIPT(I)
 Else
  LETIPT(I) = SOMME : Break
 Endif
Next I
If GMODU(2)=2
 If LETSOC : LETTYP = 1 : Else : LETTYP=2 : Endif
 Call LETDIF2(NBLET,LETNUM,LETLIG,LETIPT,LETTYP) From CPTLET
Else : # Pas de compta, il faut quand męme équilibrer les échéances
 For I=1 To NBLET
  Readlock [DUD]DUD1 = LETNUM(I);LETLIG(I)
  If fstat=1
   GOK = -1 : GLOCK = "$GACCDUDATE"-num$(LETNUM(I))-num$(LETLIG(I)) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("DUD",num$(LETNUM(I))-num$(LETLIG(I))) From GLOCK : Break
  Endif
  [F:DUD]PAYCUR += LETIPT(I)
  If [F:DUD]PAYCUR=[F:DUD]AMTCUR
   [F:DUD]PAYLOC = [F:DUD]AMTLOC
  Else
   Call LEC_GTE_LEG([F:CPY]LEG,[F:DUD]TYP) From CPTLEC
   Gosub SETCOUR
   Call CONVERT3(DEVORG,DEVDES,[F:CPY]ACCCUR,[F:GTE]TYPRAT
&      ,datesyst,[F:DUD]PAYCUR,[F:DUD]PAYLOC,COURS,STAT) From CPTSUB
   If STAT
    # Pas de cours de devises DEVORD -> DEVDES (datesyst)
    GMESSAGE = mess(16,114,1)-DEVORG-"->"-DEVDES-"("+format$("D:"+GFMDAT,datesyst)-")"
    GOK=0 : Break
   Endif
  Endif
  Call SLDECH("DUD")From MODECHE
  Rewrite [DUD]
  If fstat
   GOK = 0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[F:SIH]ACCDAT)From MODECHE
 Next I
Endif
End

########################################
## Ecran BIC0                         ##
########################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GFONC1 = "GESBICI" : Gosub RESET_AUZ : Endif  ## 101905.n
If [M]STA=3 : mkstat=2 : End : Endif
If VALEUR="" or [M]CPY=""
 Call INIFCY(VALEUR,[M]CPY) From CPTSUB
 If VALEUR<>""
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  [M]CPY    = [F:FCY]LEGCPY
  [M]CPYNAM = [F:CPY]CPYSHO
  Affzo CPY, CPYNAM
 Endif
Elsif [M]NBLIG<>0 | [M]AMTMIN<>0 : mkstat = 2
Endif

# Issue X3-170918 2020-01-21 JUCON Control Software TicketBai
If GLBACTKSP_ON = 2
  If GCURLEG="SPA": FMT= "K:10#": Else:  FMT= "-K:10#":  Endif
  Chgfmt [M:BIC1]INVTYPSPA With FMT
  Actzo [M:BIC1]INVTYPSPA
Endif
# Issue X3-170918 2020-01-21 end

If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_FCY(VALEUR)
Variable Char VALEUR
Local Char XPARAM(10)
Local Char MESSA(250)
Local Integer STAT : STAT = 0
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
#JOJAC - X3-114807 - 2018-11-06 - START
GSOCIETE=[F:FCY]LEGCPY
#JOJAC - X3-114807 - 2018-11-06 - END
##### BESPR 87307 05/29/2013 - Check the Intercompany invoice parameter for the Source company ONLY
If GFONC1 = "GESBICI" and func SUBBIC2.FIN_PARAM(GAC_INTCO, "INTCPYINV",[M]CPY)<>"2" : GMESSAGE = func AFNC.MES1(mess(160,104,1),[M]CPY) : mkstat = 2 : End : Endif
#####
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
[M]CPYNAM = [F:CPY]CPYSHO
Affzo CPY, CPYNAM
## Initialisations globales plans, axes...
Call GETSOC(VALEUR) From DEVSUB
Call INI_GLOBAL(1,[M:BIC0]CPY,STAT,MESSA) From SUBBICS
If STAT
 GMESSAGE = MESSA
 mkstat = 2 : End
Endif
If !GIMPORT Then
 Call AFFCOL(1) From SUBBICS
 Gosub SETCHPLST From SUBBICS
Endif
#--- Paramčtre de suppression des factures
Call PARAM(VALEUR,"SIVSUP",XPARAM) From ADOVAL
GSIVSUP=val(XPARAM)
#--- Paramčtre de création de lignes ŕ zéro
Call PARAM(VALEUR,"SIVNULL",XPARAM) From ADOVAL
GSIVNULL=val(XPARAM)
#--- Code taxe obligatoire
If dim(GSAITAX)>0
 Call PARAM(VALEUR,"SAITAX",XPARAM) From ADOVAL
 GSAITAX  = val(XPARAM)
Endif
#--- Code taxe exonéré
Call PARAM(VALEUR,"EXETAX",XPARAM) From ADOVAL
GEXETAX  = XPARAM
#--- Arrondi de TVA
Call PARAM(VALEUR,"VATRND",XPARAM) From ADOVAL
GVATRND  = val(XPARAM)
#--- Early Discount Mode
Call PARAM(GSOCIETE,"DEPMGTMOD",XPARAM) From ADOVAL
GDEPMGTMOD=val(XPARAM)

#JOJAC - X3-114807 - 2018-11-06 - START
If  [M:BIC1]STA >= 3 | [M:BIC3]NBLIG <> 0 | (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP)))
 Diszo [M:BIC1]SALPRITYP
Else
 Actzo [M:BIC1]SALPRITYP
Endif
#JOJAC - X3-114807 - 2018-11-06 - END

#--- Position des 3 devises par rapport ŕ l'Euro
If VALEUR<>[M]FCY & [M]RATDAT<>[0/0/0] & [M]CUR<>''
 Call INI_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
Endif
If func AFNC.ACTIV("LTA")   #LTA.sn
#  Call PARAM(VALEUR,"USATAX",XPARAM) From ADOVAL   # 106867.so  Parameter removed now using [F:CPY]SSTTAXACT
#  GLOCUSATAX = val(XPARAM)
#  If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif   # 106867.eo
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB
Endif                       #LTA.en

If dim(GSDDMGT)>0
 #Call PARAM(GSOCIETE,"SDDMGT",XPARAM) From ADOVAL
 #X3-112211
 If func AFNC.ACTIV("SDD")
  Call PARAM(GSOCIETE,"SDDMGT",XPARAM) From ADOVAL
  GSDDMGT=val(XPARAM)
 Endif
 #end X3-112211
 Gosub SHOW_HIDE_UMRNUM From INVSDDLIB
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char XPARAM(10)
Call GETSOC(VALEUR) From DEVSUB

#Localisation Belge --str
If GAC_KBE Then
 Call DISPLAY_VCS("BIC1","",3,0)  From INVVCSLIB
Endif
#Localisation Belge --end

Gosub SHDCLEECNUM

If dim([M:BIC1]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM(VALEUR,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
Endif

If GAC_KPO
  Call SHOW_HIDE_PERDEB_PERFIN(VALEUR,[M:BIC0]SIVTYP,"BIC1") From PORLEGLIB
  Call FLD4041DIS([M:BIC1]VAC,[M:BIC0]SIVTYP) From SUBBIC
Endif

#--- PJT managed or not
If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "1"
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")=1  X3-101376
 # if param PJTMGT = "No"  ==> PJTH/PHTLIN are hidden
 Chgfmt [M:BIC1]PJTH   With "-K:40X"           # Hide PJTH
 Chgfmt [M:BIC3]PJTLIN With "-K:40X"           # Hide PJTLIN column
 Chgfmt [M:BIC3]PCCCOD With "-K:40X"           # Issue X3-149911 - 2019-07-31 by UB : Disabling Cost type column
Elsif func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) = "2"
#Elsif fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")=2 X3-101376
 Chgfmt [M:BIC1]PJTH   With "K:40X"           # Display
 Chgfmt [M:BIC3]PJTLIN With "K:40X"           # Display PJTLIN column
 Chgfmt [M:BIC3]PCCCOD With "K:40X"           # Issue X3-149911 - 2019-07-31 by UB : Enabling Cost type column
 Call PJT_MODFCY(VALEUR , "[M:BIC3]PJTLIN") From TRTPJT
Endif

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS(VALEUR, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]CUR) From SUBBICSWI
Endif
# SAM 110033 END

# X3-54264
If [M]BPR<>""
 Call INIT_REGIME([M]BPR,VALEUR,"C",[M:BIC1]VAC) From CPTSUB
 Affzo [M:BIC1]VAC
Endif

# Issue X3-170918 2020-01-21 JUCON Control Software TicketBai
If  GLBACTKSP_ON = 2
  Gosub CTL_INVTYPSPA
Endif
# Issue X3-170918 2020-01-21 end

End

Subprog D_ACCDAT(VALEUR)
Variable Date    VALEUR
VALEUR = datesyst
End

Subprog AS_ACCDAT(VALEUR)
Variable Date    VALEUR
If [M]STA=3 : mkstat=2 : Endif
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
Local Integer EXERCICE, PERIODE, OEXERCICE, OPERIODE, ASTATUS

If !clalev([F:ANM]) : Local File ACODNUM [ANM] : Endif

#dates par modules
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
 If mkstat : End : Endif
Endif

ASTATUS = func FINPER_SYRA.GET_PER(GACTX, [M]CPY, GTYPGEN, VALEUR, EXERCICE, PERIODE, GMESSAGE)
If EXERCICE=0 | PERIODE=0
 # Date incorrecte
 GMESSAGE = mess(1,104,1)
 mkstat = 2 : End
Endif
Read [FIY]FIY0 = [M]CPY;GTYPGEN;EXERCICE
If fstat | [F:FIY]FIYSTA<>2
 # Exercice non ouvert
 GMESSAGE = mess(20,101,1)
 mkstat = 2 : End
Endif
If [F:PER]PERSTA<2
 # Période non ouverte
 GMESSAGE = mess(35,101,1)
 mkstat = 2 : End
Endif
If [F:PER]PERSTA>2
 # Période fermée
 GMESSAGE = mess(36,101,1)
 mkstat = 2 : End
Endif

#### CATUA 87307 Intercompany enhancement
If GFONC1 = "GESBICI"
  Local Char    RETCPY
  Local Integer RETVAL
  Raz RETCPY
  Raz RETVAL

  RETVAL = func INTCPYLIB.CHKFIYPER(VALEUR,RETCPY)
  If RETVAL = -1
    ##The fiscal year for company XX is not open
    GMESSAGE = func AFNC.MES1(mess(71,101,1),RETCPY)
    mkstat = 2 : End
  Elsif RETVAL = -2
    ##The period for company XX is not open
    GMESSAGE = func AFNC.MES1(mess(72,101,1),RETCPY)
    mkstat = 2 : End
  Endif
Endif
#### Intercompany enhancement End

Call LEC_GTE_LEG(GCURLEG,[M]GTE) From CPTLEC
If func FINMIS_SYRA.CTL_VLYDAT(GACTX, VALEUR, [F:GTE]VLYSTR, [F:GTE]VLYEND, GMESSAGE)<>[V]CST_AOK
 GMESSAGE = [F:GTE]TYP-GMESSAGE : mkstat = 2 : End
Endif
# Contrôle période facture (demande certification, lié au paramčtre CTLPERINV et FRADGI)
Call CTLPERINV(1,VALEUR) From CPTSUB
If mkstat : End : Endif

If [M]ACCDAT<>VALEUR
 If GREP="D"
  # BRBAN 105200 #US2 Can't clean this date if ACCDAT change on a cancelled invoice
  If func AFNC.ACTIV("INVCA")>0
    If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)<=0 & [F:TSV]INVCAN<>2
      Raz [M]STRDUDDAT
    Endif
  Else
    Raz [M]STRDUDDAT
  Endif
  #Raz [M]STRDUDDAT
  # -
  [M]BPRDAT = VALEUR : Affzo [BIC1]BPRDAT
  [M]ACCDAT = VALEUR : Affzo [BIC1]10
  For nolign=1 To [M]NBLIG
   NOL = nolign-1
   Gosub CALTVA From SUBBIC2
   [M]AMTATILIN(NOL) = [M]AMTNOTLIN(NOL)+[M]AMTTAX1(NOL)+[M]AMTTAX2(NOL)+[M]AMTVAT(NOL)
  Next nolign
  [M]TOTNOT = sum([M]AMTNOTLIN(0..[M]NBLIG-1))
  [M]TOTATI = sum([M]AMTATILIN(0..[M]NBLIG-1))
 Endif
 #--- Itialisation des cours devise
 If [M]CUR<>''
  Local Date SVG_RATDAT
  SVG_RATDAT = [M]RATDAT
  If [F:GTE]RATDAT=2 & [M]BPRDAT<>[0/0/0]
   [M]RATDAT = [M]BPRDAT
  Else
   [M]RATDAT = VALEUR
  Endif
  Call CONTDEV([M]CUR,[M]RATDAT) From TRTDEV
  If mkstat : End : Endif
  If SVG_RATDAT<>[M]RATDAT
   Call INI_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
  Endif
 Endif
 # La nouvelle date doit ętre sur la męme période comptable du référentiel général principal si le compteur contient la période
 If (GREP="" or GREP="M") & func AFNC.PARAM("FRADGI",[M]CPY)="2" & [F:GTE]COU<>""
  Read [ANM]ANM0=[F:GTE]COU
  If !fstat & find(11,[F:ANM]POSTYP(0..dim([F:ANM]POSTYP)-1))<>0
   ASTATUS = func FINPER_SYRA.GET_PER(GACTX, [M]CPY, GTYPGEN, [M]ACCDAT, OEXERCICE, OPERIODE, GMESSAGE)
   If OEXERCICE<>EXERCICE | OPERIODE<>PERIODE
    # Le numéro de pičce n'est pas défini sur la męme période
    GMESSAGE = mess(81,119,1)
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
If [M]INVTYP<>1 & [M]INVNUM<>""
 Read [SIH2]SIH0=[M]INVNUM
 If [F:SIH2]ACCDAT>VALEUR
  # La date comptable du document doit ętre supérieure ou égale ŕ la date de la facture
  GMESSAGE = mess(82,119,1)-[M]INVNUM-format$("D:"+GFMDAT4,[F:SIH2]ACCDAT)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
GBOUT2 = mess(25,109,1) : # Compte
If [M]AMTMIN<>0 | [M]STA=3
 mkstat = 2 : End
Endif
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Local Integer SVG_CURTYP
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
If [F:BPR]BPCFLG<>2
 # Ce tiers n'est pas un client
 GMESSAGE = VALEUR-":"-mess(2,119,1)
 mkstat = 2 : End
Endif
Call LECTURE("BPC",VALEUR,"") From CONTOBJ
If dim([F:BPC]BPCSTA)>0 & [F:BPC]BPCSTA<>2
 # Client non actif
 GMESSAGE = mess(4,119,1)
 mkstat = 2 : End
Endif
SVG_CURTYP=[M]CURTYP
If dim([F:BPC]CHGTYP)>0
 [M]CURTYP= [F:BPC]CHGTYP
Else
 [M]CURTYP = 1
Endif
# Si le type de cours est modifié, on réinitialise les champs liés ŕ la conversion devise
If SVG_CURTYP<>[M]CURTYP & [M]CUR<>''
 Call CHARG_ZONES_DEV("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP,0) From SUBBICS
Endif

# X3-52718 & X3-105198
If VALEUR<>[M]BPR or ([M]VAC="" and !GIMPORT) or [F:SIH]VAC=""      #Issue X3-184748 by MAPON
 Call INIT_REGIME(VALEUR,[M]FCY,"C",[M]VAC) From CPTSUB
 Affzo [M:BIC1]VAC

 If dim([F:SIH]VAC) > 0 : [F:SIH]VAC=[M]VAC : Endif
Endif
#ISSUE END X3-105198

If VALEUR<>[M]BPR & [M]BPR<>""
 Raz [M]BPRPAY , [M]BPRSAC , [M]PTE , [M]BPAINV
 If dim([M:BIC1]DCLEECNUM)>0 : Raz [M:BIC1]DCLEECNUM : Endif
 If dim([M:BIC1]UMRNUM)>0    : Raz [M:BIC1]UMRNUM    : Endif
 [M]BPR = VALEUR
 Raz [M]BPAPAY
 Affzo [BIC0]20
 Affzo [BIC1]10
 If dim([M]BPRFCT)>0 : Raz [M]BPRFCT : Endif : # GH 14/06/00 bug 5490
 If dim([M]DEP)>0    : Raz [M]DEP    : Endif : # CP 15/03/01 (passage dans l'étiquette INIT DEP)
 Effzo [BIC1]XSOI, XFLGFUP  : # GB 29/11/01 bug 8437 (pour passer ds l'init de ces zones)
Endif

#------------------------------------------------------------
#IRMUE 15.05.12 81574:AP/AR management: initializeng of amount type
#------------------------------------------------------------
Gosub INI_SALPRITYP From SUBBIC4
#IRMUE 15.05.12 81574:AP/AR management end


# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]CUR) From SUBBICSWI
Endif
# SAM 110033 END

End

Subprog AS_BPRSAC(VALEUR)
Variable Char    VALEUR()
GBOUT2 = mess(25,109,1) : # Compte
If [M]AMTMIN<>0 | [M]STA=3
 mkstat = 2 : End
Endif
##### BESPR 87307 05/15/2013 # Intercompany enhancement
If GFONC1 = "GESBICI" and (GCURINTCPY <> [M]CPY)
    Call CONT_INTCPYCOA ([M]CPY) From INTCPYLIB
Endif
#####
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog D_BPRSAC(VALEUR)
Variable Char    VALEUR()
Local Char INTERM
Local Char CODCPT(GLONCAC)
Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
[L]CODCPT = func FINCAC_SYRA.GET_ACCCOD_BPR(GACTX, GSOCIETE, [M]BPR, "C")
If [L]CODCPT<>""
 Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
 INTERM = [F:CAC]ACC(0)
Endif
If INTERM<>""
 Call LECTURE("GAC",INTERM,GPLAN(1)) From CONTOBJ
 If !fstat & [F:GAC]SAC=2
  VALEUR = [F:GAC]ACCSHO
  [M]SACACC = [F:GAC]ACC
 Else
  VALEUR = ""
  Raz [M]SACACC
 Endif
Endif
End

Subprog C_BPRSAC(VALEUR)
Variable Char    VALEUR()
If !clalev([F:GAC2]) : Local File GACCOUNT [GAC2] : Endif
If func FINACC_SYRA.CTL_BPRTYPACC(GACTX, GTYPGEN, GPLAN(1), [F:GAC2]ACC, [M]FCY, "", [M]ACCDAT, 0, 0, "C", GMESSAGE)<>[V]CST_AOK
 mkstat = 2 : End
Endif
End

Subprog AM_BPRSAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Char PLAN(GLONCOA)
 If func FINACC_SYRA.GET_MAICOA(GACTX, 1, [M]CPY, PLAN, GMESSAGE)=[V]CST_AOK
  Read [GAC]GAC1 = PLAN;VALEUR
  If !fstat : [M]SACACC=[F:GAC]ACC : Else : Raz [M]SACACC : Endif
 Endif
Else
 Raz [M]SACACC
Endif
End

Subprog D_SIVTYP(VALEUR)
Variable Char    VALEUR()
Call PARAM([M]FCY,"TYPINVCUS",VALEUR) From ADOVAL
End

Subprog AS_SIVTYP(VALEUR)
Variable Char    VALEUR()
If (GREP="" & [M]NUM<>"" & VALEUR<>"") | GREP="M"
 mkstat = 2 : End
Endif
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()
Call CONT_SIVTYP(VALEUR)
If mkstat : End : Endif
If (GREP="C" | GREP="D" | GREP="")
 If (find([M:BIC0]INVTYP,1,3) & !find([F:TSV]INVTYP,1,3)) | (!find([M:BIC0]INVTYP,1,3) & find([F:TSV]INVTYP,1,3))
  [M:BIC0]INVTYP = [F:TSV]INVTYP
  Call CHANGE_INVTYP([M]DEP) From INVDEPLIB
 Endif
 Gosub SET_SIVTYP
Endif
If !GIMPORT & GREP="" & [M:BIC0]INVTYP<>[F:TSV]INVTYP
 # Catégorie de facture différente
 GMESSAGE = mess(60,119,1)
 mkstat=2 : End
Endif

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")
  If [F:TSV]INVCAN=2 & GFONC1='GESBICI'
   GMESSAGE = mess(29,107,1)
   mkstat=2 : End
  Endif
Endif
# -
End

$SET_SIVTYP
[M:BIC0]INVTYP = [F:TSV]INVTYP    : # Catégorie de facture
[M:BIC0]GTE    = [F:TSV]GTE       : # Type de pičce
[M:BIC0]JOU    = [F:TSV]JOU       : # Journal
Return

Subprog C_NUM(VALEUR)
Variable Char     VALEUR
Local Libelle CRE
VALEUR = vireblc(VALEUR,2)
If VALEUR="" : CRE=2
Else
 Look [SIH]SIH0 = VALEUR
 If fstat : CRE=2 : Endif
Endif
If CRE & GREP<>"C"
 Call CONT_SIVTYP([M]SIVTYP)
 If mkstat : [M]NUM=VALEUR : End : Endif
 Gosub SET_SIVTYP
Endif
If CRE & [M:BIC0]GTE<>""
 Call LEC_GTE_LEG(GCURLEG,[M:BIC0]GTE) From CPTLEC
 If VALEUR<>""
  Call EXISTE([M:BIC0]GTE,VALEUR)
  If mkstat : End : Endif
  If [F:GTE]MANNUM<>2 : VALEUR = "" : Endif
 Elsif [F:GTE]COU=""
  # Numéro de facture non renseigné
  GMESSAGE = mess(100,121,1) : mkstat = 2 : End
 Endif
Endif
End

# Teste la présence de TYP;NUM dans les échéances et pičces cpt
Subprog EXISTE(TYP,NUM)
Value Char TYP()
Value Char NUM()
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
If !clalev([F:HAT]) : Local File GACCTMP   [HAT] : Endif
Look [DUD]DUD0(2) = TYP ; NUM
If !fstat
 # Une échéance existe déjŕ avec ce numéro
 GMESSAGE = mess(57,119,1)
 mkstat=2 : End
Endif
Look [HAE]HAE0 = TYP ; NUM
If fstat
 Look [HAT]HAT0 = TYP ; NUM
Endif
If !fstat
 # Une écriture existe déjŕ avec ce numéro
 GMESSAGE = mess(58,119,1)
 mkstat=2 : End
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & !GIMPORT
 mkstat = 4
Endif
End

Subprog CONT_SIVTYP(TYPFAC)
Value Char TYPFAC()
# BRBAN - 105200 - US2 - If it is an invoice cancellation, must cancel this control
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    End
  Endif
Endif
#-

If TYPFAC = ""
 # Type de facture non défini
 GMESSAGE = mess(54,119,1) : mkstat=2 : End
Endif
Call LEC_TSV_LEG(GCURLEG,TYPFAC) From CPTLEC
If fstat
 # Type de facture non défini
 GMESSAGE = TYPFAC-":"-mess(54,119,1) : mkstat=2
Elsif [F:TSV]INVTYP = 5
 # Proforma : catégorie de facture interdite
 GMESSAGE = mess(5,645,1)-":"-mess(56,119,1) : mkstat=2
Elsif [F:TSV]COD2=""
 # Pičce auto non paramétrée dans le type de facture
 GMESSAGE = mess(55,119,1)-TYPFAC : mkstat=2
Endif
End

$SEL_TABLE
Case COUZON
 When "NUM"
  OBJET = "BIC"
 When "INVNUM"
  OBJET = "BIC"
  # BRBAN 105200#US2
  If func AFNC.ACTIV("INVCA")>0
    If func TRTINVCAN.INVCAN([F:FCY]LEG ,[F:TSV]INVTYP)>0
      If [F:TSV]INVCAN=2
        CRITERE = "INVTYP=1 & BPR='"+[M]BPR+"' & BPRSAC='"+[M]BPRSAC+"' & FCY='"+[M]FCY+"' & REVCANSTA=0"
      Else
        CRITERE = "INVTYP=1 & BPR='"+[M]BPR+"' & BPRSAC='"+[M]BPRSAC+"' & FCY='"+[M]FCY+"' & CUR='"+[M]CUR+"' & REVCANSTA=0"
      Endif
    Else
      CRITERE = "INVTYP=1 & BPR='"+[M]BPR+"' & BPRSAC='"+[M]BPRSAC+"' & FCY='"+[M]FCY+"' & CUR='"+[M]CUR+"'"
    Endif
  Endif
Endcase
Return

$AVANT_SUITE
If BOUT="1"
 Gosub AVANT_SUITE From GASTRC
Elsif BOUT="2"
 Gosub AVANT_SUITE From CPTTRS
Endif
Return

##### TRAITEMENTS COMMUNS ########

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

#####################################################################################
## Etiquette écran BIC0
######################################################################################

Subprog D_BPAINV(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
#Issue X3-128399 – 2019-03-29  by MADOR - Customer BP Invoice: Incorrect address details default...
VALEUR = [F:BPC]BPAADD
#Issue X3-128399 end
If VALEUR<>""
 Gosub LECADR : End
Else
 # recherche de l'adresse par défaut mais tjs définie dans la fiche client
 Read [BPA]BPA0 = 1;[M]BPR;[F:BPC]BPAADD
 If !fstat : VALEUR = [F:BPC]BPAADD : Gosub LECADR : End : Endif
Endif
End

Subprog AS_BPAINV(VALEUR)
Variable Char    VALEUR()
If [M:BIC1]STA=3 : mkstat = 2 : End : Endif
If func IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_BPAINV(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]BPAINV
 Read [BPA]BPA0 = 1;[M]BPR;VALEUR
 If fstat
  # Adresse inexistante
  GMESSAGE = mess(10,119,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_BPAINV(VALEUR)
Variable Char    VALEUR()
Gosub LECADR
If mkstat = 2 : End : Endif #LTA.n
Gosub AFFADR
#If Misc customer and customer=pay by and invoice not posted then change also the BPAPAY code
If ([F:BPC]BPCTYP= 2 & [M:BIC1]BPRPAY = [M:BIC0]BPR & [M:BIC1]STA<>3)
 [M:BIC1]BPAPAY = VALEUR
 Affzo [M:BIC1]BPAPAY
Endif
End

$LECADR
Raz [M]BPRNAM, [M]BPAADDLIG
Read [BPA]BPA0 = 1;[M]BPR;VALEUR
If !fstat
 For I=0 To min(dim([M]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
  [M]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [M]POSCOD = [F:BPA]POSCOD
 [M]CTY    = [F:BPA]CTY
 [M]CRY    = [F:BPA]CRY
 [M]SAT    = [F:BPA]SAT
 If [F:BPA]CRYNAM<>"" : [M]CRYNAM = [F:BPA]CRYNAM
 Else [M]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[M]CRYNAM) From TRTDIV
 Endif
 # If func AFNC.ACTIV("LTA") and GLOCUSATAX       #LTA.sn   # 106867.o
 If func TRTTAXSST.CHK_SSTTAXACT([M]CPY)   # 106867.n
   If [F:BPA]ADRVAL <> 2 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
     If func TRTADRLIB.CHKADR_MANDATORY()
       GERR=1
       GMESSAGE=mess(366,192,1) # Address has not been validated
       mkstat = 2
       Return
     Else
       Call MESSAGE(mess(366,192,1)) From GESECRAN  # Address has not been validated
     Endif
   Endif

   [M]ADRVAL = [F:BPA]ADRVAL

   If dim([M:BIC1]SSTENTCOD)>0
     Gosub DEFAULT_SSTENTCOD From TRTADRLIB
   Endif
 Endif                                         #LTA.en
Endif
Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
For I=0 To dim([M]BPRNAMBIS)-1
 [M]BPRNAMBIS(I) = [F:BPR]BPRNAM(I)
Next I
[M:BIC0]BPRNAM(0) = [F:BPR]BPRNAM(0)
Return

$AFFADR
If !GIMPORT : Affzo BPRNAM, BPAADDLIG, POSCOD, CTY, CRY, CRYNAM : Endif
Return

$CASH_VAT  #90370 Cash VAT SPA
If GAC_KSP
#X3-112211
  If func AFNC.ACTIV("KSP")
    If func SUBBIC2.FIN_PARAM(GAC_KSP, "SPACSHVAT",[F:SIH]CPY)="2"
       Local Char WCRY(GLONCRY)
       Local Integer CSHVAT
       WCRY=[F:SIH]CRY
       If WCRY="": WCRY=[F:BPR]CRY: Endif
      Call CSHVATBPC([F:SIH]ACCDAT,WCRY,[F:SIH]VAC,[F:SIH]CPY,[F:SIH]TAX(),CSHVAT) From DCLVATSPA
      [F:SIH]CSHVAT=CSHVAT
    Endif
  Endif
  #END X3-112211
Endif
Return

######################################################################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

# -- RMA * Digital signature (DKS activity code related) * manually assigning a doc. number sets the document as external
If dim([M]ISEXTDOC)>0
    If VALEUR <>""
        [M]ISEXTDOC = 2
    Else
        [M]ISEXTDOC = 1
    Endif
Endif

End

######################################################################################
Subprog D_ISEXTDOC(VALEUR)
Variable Integer VALEUR

# -- RMA * Digital signature (DKS activity code related) * by default, all documents are internal
If GIMPORT
  VALEUR = 2
Else
  VALEUR = 1
Endif

End

######################################################################################
Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
#IRMUE 15.05.12 81574:AP/AR management: initializeng of amount type
Gosub INI_SALPRITYP From SUBBIC4
Gosub SHDCLEECNUM

Call FLD4041DIS([M:BIC1]VAC,[M:BIC0]SIVTYP) From SUBBIC

# Issue X3-110803 by MRDAB
#If func AFNC.ACTIV("KPO")
If GAC_KPO
  If func PORLEGLIB.VAL_BPC_CASHVAT_SIVTYP(VALEUR, [M:BIC0]ACCDAT, [M:BIC0]SIVTYP, GCURLEG) = 0
    GMESSAGE = mess(111,119,1)
    mkstat = 2
  Endif
Endif
# Issue X3-110803 end

# Issue X3-195181 by MRDAB/MAPON
Gosub PROMPT_BP_BID From SUBBIH
# Issue X3-195181 end

Setmok [BIC1] With 0
End

######################################################################################
Subprog IB_BPR

Call IB_NOTECHECK([M:BIC0]BPR,"BPCNUM",3)  From TRTNTSCTL # customer notes

End

######################################################################################
Subprog FLD4041DIS(AVAC,ASIVTYP)
Value Char AVAC
Value Char ASIVTYP

If GAC_KPO = 0 : End : Endif

Local Char HS(1)

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,1,ASIVTYP,40)
If [L]HS = "-" : Raz [M:BIC1]FLD40REN : Endif
Chgfmt [M:BIC1]FLD40REN With [L]HS+"K:5X"

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,1,ASIVTYP,41)
If [L]HS = "-" : Raz [M:BIC1]FLD41REN : Endif
Chgfmt [M:BIC1]FLD41REN With [L]HS+"K:5X"

If [M:BIC1]STA = 3
  Diszo [M:BIC1]FLD40REN
  Diszo [M:BIC1]FLD41REN
Endif

Affzo [M:BIC1]FLD40REN
Affzo [M:BIC1]FLD41REN

End
######################################################################################
Subprog AM_SIVTYP(VALEUR)
Variable Char    VALEUR()

If GAC_KPO
  Raz [M:BIC1]FLD40REN
  Raz [M:BIC1]FLD41REN

  If dim([M:BIC1]ORIDOCNUM) > 0
    Call SHOW_HIDE_ORIDOCNUM([M:BIC0]FCY,VALEUR,"BIC1") From PORLEGLIB
  Endif

  Call SHOW_HIDE_PERDEB_PERFIN([M:BIC0]FCY,VALEUR,"BIC1") From PORLEGLIB

  Call FLD4041DIS([M:BIC1]VAC,VALEUR) From SUBBIC

Endif

# BRBAN 105200 US2
If GLBINVCA_ON = 2
  Local Integer STAT
  Call LEC_TSV_LEG([F:FCY]LEG,VALEUR,STAT) From TRTLECLEG
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    If [M:BIC0]INVCRE=2 & [M:BIC1]INVNUM<>''
      Call AM_INVNUM([M:BIC1]INVNUM) From SUBBIC2
      Diszo [M:BIC1]
      Diszo [M:BIC3]
      Actzo [M:BIC1]INVNUM
    Else
      Diszo [M:BIC1]
      Diszo [M:BIC3]
      Actzo [M:BIC1]INVNUM
      Raz [M:BIC1]
      Raz [M:BIC3]
      Affzo [M:BIC1]
      Affzo [M:BIC3]
    Endif
  Endif
Endif
#-

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]CUR) From SUBBICSWI
Endif
# SAM 110033 END

End

######################################################################################
Subprog AM_ACCDAT(VALEUR)
Variable Date    VALEUR

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Call VAL_INVDAT([M:BIC0]SIVTYP,VALEUR,[F:GTE]COU) From SUBSIH
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End

######################################################################################

#issue X3-69271 - 2019-02-12 by MANOW
######################################################################################
### returns 0 - if does not exist in DNO table, 1 - if does exist
######################################################################################
Funprog IS_DNO(NUMM)
Value Char NUMM
Local Integer RET_VAL : [L]RET_VAL = 0
Filter [F:DNO] Where [F:DNO]DNONUM=NUMM
Look [F:DNO] First
If !fstat : [L]RET_VAL = 1 : Endif
Filter [F:DNO]
End [L]RET_VAL

######################################################################################
### returns 0 - no, 1 - yes
######################################################################################
Funprog CAN_REMOVE_INVDNO(NUM)
Value Char NUM
Local Integer RET_VAL : [L]RET_VAL = 1
Local Char DNONUM(20) : [L]DNONUM = ''
Local Integer DNONUMD : [L]DNONUMD = 0
Filter [F:DNO] Where [F:DNO]DNONUM=[L]NUM
Read [F:DNO] First
If !fstat
  [L]DNONUM  = [F:DNO]NUM
  [L]DNONUMD = [F:DNO]NUMD

  Filter [F:DNO] Where [F:DNO]NUM=[L]DNONUM and [F:DNO]NUMD > [L]DNONUMD
  Look [F:DNO] First
  If !fstat : [L]RET_VAL = 0 : Endif
  Filter [F:DNO]
Endif
Filter [F:DNO]
End [L]RET_VAL
#end issue

##########################################################
$CTL_INVTYPSPA
#Ini X3-206682 Update INVTYPSPA field with KSP act. code
If GCURLEG="SPA":  FMT= "K:10#"
  If [F:SIH]STA=3: Grizo [M:BIC1]INVTYPSPA: Endif
  If GLBACTCTSW_ON = 2
    Local File CTSWSP [CTSW]
    Read [CTSW]CTSW0=[F:SIH]CPY;[F:SIH]NUM
    If fstat=[V]CST_AOK & [F:CTSW]STA<>1
      Actzo [M:BIC1]INVTYPSPA
    Endif
    Close File [CTSW]
  Endif
Else:  FMT= "-K:10#"
Endif

Chgfmt [M:BIC1]INVTYPSPA With FMT
#End X3-206682 Update INVTYPSPA field with KSP act. code
Return

##########################################################
$CTL_VAL_INVSPA
#TBAI Slice 2 X3-190239 TicketBai : control of Invoice validation sequence (JUCON 2020-04-14)
Local Char WTBAI (GLONADP)
Local File SINVOICE [XSIH]

#Controling if this company manages TBAI or not
Call PARAML([F:SIH]CPY,"CTSWCPY",WTBAI) From ADOVAL
If val(WTBAI)=[V]CST_AYES
  Read [XSIH]SIH2=[F:SIH]GTE;[F:SIH]NUM
  If fstat=[V]CST_AOK
    Read [XSIH]SIH2 Prev
    If fstat=[V]CST_AOK and [F:XSIH]STA<>3 and [F:SIH]GTE=[F:XSIH]GTE
      GMESSAGE=":"-mess(36,119,1)+"."-[F:XSIH]NUM-mess(242,187,1) #This previous invoice must be validated
      If GFONCTION="GESBIC"
        GMESSAGE =[F:SIH]NUM-GMESSAGE
        If GTRACE<>""
          Call ECR_TRACE("$SINVOICE :"-GMESSAGE,1) From GESECRAN
          OK=0 : End
        Else
          OK=0 :  GERR=1 : End
        Endif
      Elsif GFONCTION="BPCVAL"
        GOK=0: End
      Endif
    Endif
  Endif
Endif
Close File [XSIH]

Return
######################################################################################
$CONT_CRONO_NEXT
# Issue X3-195010 - 20200616 by VAVIL : Chronological control is not applied on sales invoice validation
DEPL=1 : I=0
While ([F:ANM]POSTYP(I)<>8) & (I<=[F:ANM]NBPOS-1)
  DEPL += [F:ANM]POSLNG(I)
  I += 1
Wend
CHAINE = left$(OLD_NUM, DEPL-1)
Filter [F:SIH1] Where [F:SIH1]NUM > [F:SIH]NUM &  left$([F:SIH1]NUM, len(CHAINE)) = CHAINE & [F:SIH1]ACCDAT<[F:SIH]ACCDAT
  Read [F:SIH1]SIH0 Last
  If !fstat
    GMESSAGE = mess(217,121,1)
    zonsui = "[M]ACCDAT" : GOK = 0
   Endif
Filter [F:SIH1]
# Issue end X3-195010
Return
