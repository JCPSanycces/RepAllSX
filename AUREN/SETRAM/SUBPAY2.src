#<AdxTL>@(#)10.0.0.0 $Revision$
# Issue X3-216829 - 2020-11-03 by MRDAB : Remove payment remittance approval in case of any changes on payment
#ISSUE X3-195188 MANOW/MRDAB - default bank account from open item
GFLAG="GB"
Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
# Action PAYECART
Case ACTION
 When "OUVRE"  : If val(PARAM(3))=val(PARAM(4))
                  FIN=1 : PARAM(1)="9"
                 Endif
 When "DEBUT"  : Raz [M]
                 [M]CURPYH=PARAM(2)  : [M]AMTPYH=val(PARAM(3))
                 [M]CURPYD=[M]CURPYH : [M]AMTPYD=val(PARAM(4))
                 [M]CURDEV=[M]CURPYH : [M]AMTDEV=[M]AMTPYH-[M]AMTPYD
                 If [M]AMTPYD<=0   : [M]CHOIX2="xxo"
                 Elsif PARAM(5)="" : [M]CHOIX2="oxo"
                 Else              : [M]CHOIX2="ooo"
                 Endif
                 [M]CHOIX=instr(1,[M]CHOIX2,"o")
 When "OK"     : PARAM(1)=num$([M]CHOIX)
 When "END"    : PARAM(1)="0"
Endcase
Return

####### Sous programmes ##########

$CONT_BPRACC
If !(([F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2)
&| ([F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2)
&| ([F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2)
&| ([F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2)
&| ([F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2)
&| ([F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2))
 # Tiers incompatible avec le collectif
 GMESSAGE=mess(45,106,1) : mkstat=2 : Return
Endif
If [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2 : # Client non actif
 Call LECTURE("BPC",[F:BPR]BPRNUM,"") From CONTOBJ
 If [F:BPC]BPCSTA<>2 : GMESSAGE = mess(4,119,1) : mkstat=2 : Endif
Endif
If [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2 : # Fournisseur non actif
 Call LECTURE("BPS",[F:BPR]BPRNUM,"") From CONTOBJ
 If [F:BPS]ENAFLG<>2 : GMESSAGE = mess(5,119,1) : mkstat=2 : Endif
Endif
Return

###################
Subprog FOUBAP(FOU)
###################
Value Char FOU()
If FOU<>""
 Call LECTURE("BPR",FOU,"") From CONTOBJ
 If fstat<=2 & [F:BPR]BPSFLG=2
  Call LECTURE("BPS",FOU,"") From CONTOBJ
  If fstat<=2 & [F:BPS]PAYLOKFLG=2
   GMESSAGE=FOU-":"-mess(11,117,1) : # Fournisseur bloqué en paiement
   End
  Endif
 Endif
 Gosub PE_CLTPAYBPR
Endif
End

$PE_CLTPAYBPR
GPOINT = "CTLPAYBPR" : Gosub ENTREE From EXEFNC
Return

######################
Subprog ANOUV(TYP,NUM)
######################
Value Char TYP(), NUM()
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Call LECTURE("GAS",NUM,TYP) From CONTOBJ
If fstat=0 & [F:HAE]FLGREP=2 : # Pičce de fin d'exercice
 GMESSAGE = mess(20,121,1)
Endif
End

$SELECH
Case ACTSELECH
 When "DEBUT"
  Local Libelle BPRFIX, FLMT
  Local Integer IND, CAS, FINTYP, I, J, K
  Local Decimal NNUM, NLIG, MT, MT2
  Local Char    CRITERE(200), BPR(GLONBPR), PRIO(2), OPT(1), ODEFMASK(200)
  ODEFMASK=dbgstr(1)
  IND=SAVNOLIGN2-1 : NNUM=[M]DUDNUM(IND) : NLIG=[M]DUDLIG(IND)
  Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(IND)) From CPTLEC
  If [M]IPTTYP(IND)=4
   If [M]ACCTYP(IND)=1 : CAS=2
   Else: # Aucune échéance
    GMESSAGE=mess(10,117,1) : GERR=1 : FIN=1 : FINTYP=2 : Return
   Endif
  Elsif IND>0 & [M]ACCTYP(IND)=3 & NNUM=0 & NLIG=0
&     & [M]VCRTYP(IND)=[M]VCRTYP(IND-1) & VALEUR=[M]VCRNUM(IND-1)
   Call LECDUD([M]DUDNUM(IND-1),[M]DUDLIG(IND-1))
   If fstat=0 & !(find([F:DUD]TYP,"*SO","*PO") & [F:DUD]PAMTYP=1)
    NNUM=[M]DUDNUM(IND-1) : NLIG=[M]DUDLIG(IND-1) : CAS=1
   Endif
  Elsif NNUM<>0 & NLIG<>0
   Call LECDUD(NNUM,NLIG)
   If fstat=0 & [F:DUD]NUM=VALEUR
&   & (([F:DUD]TYP="*SO" & [M]IPTTYP(IND)=1)
&   |  ([F:DUD]TYP="*PO" & [M]IPTTYP(IND)=2)
&   |  !find([M]IPTTYP(IND),1,2))
&   & (!(find([F:DUD]TYP,"*SO","*PO") & [F:DUD]PAMTYP=1)
&   |  [M]ACCTYP(IND)<>3)
    CAS=3
   Endif
  Endif
 If CAS=3
  Local Mask REGECHW [RECH]
  Default Mask ODEFMASK
  Raz [M:RECH]
  nolign = 1
  [M:RECH]NECH=nolign
  [M:RECH]ACCNUM(0) = [F:DUD]ACCNUM
  [M:RECH]ACCLIG(0) = [F:DUD]DUDLIG
  CHARGE=0 : Default Mask [RECH]
  Return
  Elsif CAS
   FIN=1 : FINTYP=0 : Return
  Endif

  If [M]FCYOPT=1 : CRITERE="FCY='"+[M]FCY+"'"
  Else           : CRITERE="CPY='"+[M]CPY+"'"
  Endif
  Case [M]IPTTYP(IND)
   When 1       : CRITERE+=" & TYP='*SO'" : # Cde client
   When 2       : CRITERE+=" & TYP='*PO'" : # Cde fou
   When Default : CRITERE+=" & TYP='"+[M]VCRTYP(IND)+"'"
  Endcase
  If VALEUR<>""               : CRITERE+=" & NUM='"+VALEUR+"'" : Endif
  If find([M]IPTTYP(IND),1,2) : CRITERE+=" & PAMTYP<>1" : Endif
  Filter [DUD] Where evalue(CRITERE)
  [L]BPR=[M]BPR
  Local Mask REGECHW [RECH]
  Default Mask ODEFMASK
  Raz [M:RECH] : I = dim([M:RECH]BPRPAY)
  nolign = 0 : J = 0
  Repeat
   If [L]BPR<>"" : [L]BPRFIX=![L]BPRFIX : Endif
   If [L]BPR="" & VALEUR<>""
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD0
   Else
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD3
   Endif
   ## DBA le 27/12/02 : Optimisation recherche des échéances non soldées avec FLGCLE=1
   For [DUD] Where FLGCLE=1 & ((BPRPAY=[L]BPR & [L]BPRFIX) | ![L]BPRFIX) With Nohint
    If nolign>=I : Break : Endif
    Call MTECHE(MT,-1)
    nolign+=1 : [M:RECH]=[F:DUD]
    [M:RECH]ACCLIG(nolign-1)=[F:DUD]DUDLIG
    [M:RECH]SOLDE(nolign-1)=MT
    [M:RECH]TOTAL += [M:RECH]AMTCUR(nolign-1)-[M:RECH]SOLDE(nolign-1)
    If !J & MT>0 : J=nolign : Endif
    If NNUM=[F:DUD]ACCNUM & NLIG=[F:DUD]DUDLIG : J=nolign : Endif
   Next : # [DUD]
   [M:RECH]DEVISE = [M:RECH]CUR(0)
  Until nolign | ![L]BPRFIX
  Filter [DUD]
  If !J : J=1 : Endif
  [M:RECH]NECH=nolign
  If nolign>1 & !find("",[M:RECH]BPRFCT(0..[M:RECH]NECH-1))
   # Facture gérée par le factor XXX
   GMESSAGE=mess(89,121,1)-[M:RECH]BPRFCT(0) : GERR=1 :  FIN=1 : FINTYP=2 : Return
  Endif
  CHARGE=0 : Default Mask [RECH]

 When "FIN"

  If !CAS & PARAM(3)="1"
   NNUM=val(PARAM(1)) : NLIG=val(PARAM(2))
  Endif

  IND=SAVNOLIGN2-1 : PARAM(1)=num$([M]DUDNUM(IND)) : PARAM(2)=num$([M]DUDLIG(IND))
  Default Mask ODEFMASK
  If FINTYP=2 | (!CAS & PARAM(3)="-1") : mkstat=2 : Return
  Elsif !CAS & PARAM(3)="0" : # Pas d'échéance
   If find([M]IPTTYP(IND),1,2) &  [M]ACCTYP(IND)<>3 & ([M]IPTTYP(IND)=1 | [M]USRPAZ>=[M]MAXPAZ)
    Case [M]IPTTYP(IND)
     When 1
      Call LECTURE("SOH",VALEUR,"") From CONTOBJ
      If fstat=0 : I=[F:SOH]INVSTA : Else I=-1 : Endif
     When 2
      Call LECTURE("POH",VALEUR,"") From CONTOBJ
      If fstat=0 : I=[F:POH]INVFLG : Else I=-1 : Endif
    Endcase
    Case I
     When -1 : # Aucune échéance
      GMESSAGE=mess(10,117,1) : mkstat=2 : Return
     When 3 : # Commande totalement facturée
      GMESSAGE=mess(57,117,1) : mkstat=2 : Return
     When 2 : # Cde partiellement facturée
      GMESSAGE=mess(58,117,1)+"\"
     When Default : GMESSAGE=""
    Endcase
    GMESSAGE+=mess(21,117,1) : # Pas d'acompte demandé
    OK=2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
    If OK<>2 : mkstat=2 : Return
    Else : CAS = OK
    Endif
   Else : # Aucune échéance
    GMESSAGE=mess(10,117,1) : mkstat=2 : Return
   Endif
  Endif

  If dim([M:PAY1]VCRNUM)>0 : K=1 : Else K=2 : Endif
  GMESSAGE=""
  If CAS=0 | CAS=3
   ## Contrôles bloquants
   Read [DUD]DUD1 = NNUM;NLIG
   If fstat
    GOK=2 : Call RSTA("DUD",num$(NNUM)-num$(NLIG)) From GLOCK : mkstat=2 : Return
   Endif
   Gosub CTL_DUD
   If GMESSAGE<>"" : mkstat=2 : Return : Endif
   If NNUM<>[M]OD1 | NLIG<>[M]OD2
    ## Avertissements
    Call MTECHE(MT,IND) : FLMT=1 : # Echéance déjŕ soldée
    If [F:DUD]AMTCUR*MT<=0 : GMESSAGE+="\"+mess(15,117,1) : Endif
    Gosub VRF_DUD
    If instr(1,GMESSAGE,mess(28,121,1)) : mkstat=2 : Return : Endif  :# Bug 14084
   Endif : # NNUM<>DUDNUM & NLIG<>DUDLIG
  Endif
  If CAS<>2 & (NNUM<>[M]OD1 | NLIG<>[M]OD2)
   For I=0 To [M]NBLIG-1
    If I<>IND & [M]DUDNUM(I)=NNUM & [M]DUDLIG(I)=NLIG & [M]DENCOD(I)=[M]DENCOD(IND)
    GMESSAGE+="\"+mess(22,117,1)-num$(I+1) :# Echéance imputée ligne I+1
   Endif
  Next I
  If len(GMESSAGE)>=mod(type(GMESSAGE)-10,256)
    GMESSAGE="\"+mess(140,121,1) # Echéance imputée sur plusieurs lignes
  Endif
  ##
  If GMESSAGE<>""
   GMESSAGE=right$(GMESSAGE,2)
   I=2 : Call AVERTIR(GMESSAGE,I) From GESECRAN
   GMESSAGE="" : If I<>2 : mkstat=2 : Return : Endif
  Endif : # GMESSAGE
 Endif
 If CAS=2 & [M]OVCR<>[M]VCRTYP(IND)+"\"+VALEUR
  If K=1 : Effzo [PAY1] FCYLIN(IND),CURLIN(IND)
  Else   : Effzo [PAY2] FCYLIN(IND),CURLIN(IND)
  Endif
 Endif

 # Ritenzione
 GPE = 0
 GPOINT = "CALAMTRTZ" : Gosub ENTREE From EXEFNC
 If GPE = 0
  If dim([M]RITAMT)>0 & func AFNC.PARAM("WTMNG",[M]CPY)="2"
   Gosub SET_RTZCUR
   [M]RITAMT(IND)=0
   If [F:PIH]NUM<>VALEUR
    Read [PIH]PIH0 = VALEUR
   Endif
   If fstat=0 & (([F:PIH]INVTYP=5 & [M]IPTTYP(IND)=4) | [F:PIH]GTE=[M]VCRTYP(IND)) & [M]ACCTYP(IND)=1
    For I=0 To [F:PIH]RITNBR-1
     Call LECTURE("RTZ",[F:PIH]RITCOD(I),"") From CONTOBJ
     If fstat=0 & [F:RTZ]TYP=1 & [F:RTZ]COE1<>0 : # Retenues sur rčglement
      MT2 = ([F:PIH]RITAMT(I)-[F:PIH]RITAMTDED(I))*[F:RTZ]COE1/([F:RTZ]COE1+[F:RTZ]COE2)
      Call ARRDEV(MT2,[M]RTZCUR) From TRTDIV
      [M]RITAMT(IND) += MT2
     Endif
    Next I
    If [M]RITAMT(IND)<>0
     [M]RITAMT(IND)*=-1
     For I=0 To [M]NBLIG-1
      If I<>IND & [M]VCRTYP(I)=[M]VCRTYP(IND) & [M]VCRNUM(I)=VALEUR
       [M]RITAMT(IND)=0 : Break
      Endif
     Next I
     If [F:PIH]INVTYP=5 & [M]RITAMT(IND)<>0 & [M]AMTLIN(IND)=0
      [M]AMTLIN(IND)=[F:PIH]AMTATI
     Endif
    Endif
   Endif
   If K=1 : Affzo [PAY1]RITAMT(IND) : Else Affzo [PAY2]RITAMT(IND) : Endif
  Endif

  If NNUM<>[M]DUDNUM(IND) | NLIG<>[M]DUDLIG(IND) | CAS=3
   PARAM(1)=num$(NNUM) : PARAM(2)=num$(NLIG)

   [M]DUDNUM(IND)=NNUM : [M]DUDLIG(IND)=NLIG
   If NNUM<>0 & NLIG<>0
    [M]FCYLIN(IND)=[F:DUD]FCY : [M]CURLIN(IND)=[F:DUD]CUR
    If K=1 : Affzo [PAY1] FCYLIN(IND),CURLIN(IND)
    Else   : Affzo [PAY2] FCYLIN(IND),CURLIN(IND)
    Endif
    If !FLMT
     Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(nolign-1)) From CPTLEC
     If [F:CDA]IPTDEP = 2 : Call MTAGIO(MT,IND)
     Else                 : Call MTECHE(MT,IND)
     Endif
     FLMT=1
    Endif
   Endif
   Gosub SET_AMTLIN
   If K=1 : Affzo [PAY1]AMTLIN(IND), AMTLIN2(IND)
   Else   : Affzo [PAY2]AMTLIN(IND), AMTLIN2(IND)
   Endif
  Endif
 Endif
 [M]OVCR=[M]VCRTYP(IND)+"\"+VALEUR

Endcase
Return

$CTL_DUD
Local Char    OPTCTLBAP(1)
Call PARAMUTIL("CTLPAZ",[L]OPTCTLBAP,"","") From SUBAUS
If [M]SNS=1 & [F:DUD]BPRPAY<>[M]BPR : # Dépense
 Call FOUBAP([F:DUD]BPRPAY) From SUBPAY2
 If GMESSAGE<>"" : Return : Endif
Endif
If [F:DUD]BPRFCT<>""
 GMESSAGE = mess(89,121,1)-[F:DUD]BPRFCT : Return :  # Facture gérée par le factor FACTOR
Elsif [F:DUD]DUDSTA<>2 & !find([F:DUD]TYP,"*SO","*PO")
 If [M]SNS=1 : PRIO="FC" : Else PRIO="CF" : Endif
 For I=1 To 2
  Case mid$(PRIO,I,1)
   When "C"
    Call LECTURE("BIC",[F:DUD]NUM,"") From CONTOBJ
    If fstat=0 & [F:SIH]GTE=[F:DUD]TYP
     If !find([F:SIH]ORIMOD,3,2)
      GMESSAGE = mess(28,121,1) : # Echéance non validée
     Endif
     Break
    Endif
   When "F"
    Call LECTURE("BIS",[F:DUD]NUM,"") From CONTOBJ
    If fstat=0 & [F:PIH]GTE=[F:DUD]TYP
     If !find([F:PIH]ORIMOD,3,2) | (dim([M]RITAMT)>0 & [F:CPY]RTZFLG=2)
      GMESSAGE = mess(28,121,1) : # Echéance non validée
     Endif
     Break
    Endif
  Endcase
 Next I
 If GMESSAGE<>"" : Return : Endif
Endif

If !find([F:DUD]TYP,"*SO","*PO")
 If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
 Call LECTURE("GAS",[F:DUD]NUM,[F:DUD]TYP) From CONTOBJ
 If !fstat
  If [F:HAE]CAT = 2 | [F:HAE]CAT = 3
   # Pičces de simulation interdites
   GMESSAGE = mess(6,107,1) : Return
  Elsif [F:HAE]CAT = 5
   # Pičces modčles interdites
   GMESSAGE = mess(55,106,1) : Return
  Endif
 Endif
Endif

If [F:DUD]SNS=-1 & [F:DUD]FLGPAZ<[M]MAXPAZ & ([M]USRPAZ<[M]MAXPAZ | [L]OPTCTLBAP="1")
 # Echéance sans 'bon ŕ payer'
 GMESSAGE = mess(16,117,1)
 If [F:DUD]FLGPAZ<>0 : GMESSAGE -= "("+mess([F:DUD]FLGPAZ,510,1)+")" : Endif
Elsif [M]BPROPT=1 & [M]BPR<>"" & !find([F:DUD]TYP,"*SO","*PO")
&  & (([F:DUD]SAC<>[M]BPRSAC & [F:CDA]ACCBPR="") | ([F:DUD]BPR<>[M]BPR & [F:DUD]BPRPAY<>[M]BPR))
 # Génération OD-Tiers SAC BPR
 GMESSAGE = mess(19,117,1)-[F:DUD]SAC-[F:DUD]BPR
Endif

Call LECTURE("FCY",[F:DUD]FCY,"") From CONTOBJ
If [F:FCY]FINFLG<>2
 GMESSAGE = [F:DUD]FCY-mess(217,107,1) : Return
Endif
Return

$VRF_DUD
If [F:DUD]SNS=-1 & [F:DUD]FLGPAZ<[M]MAXPAZ & [L]OPTCTLBAP<>"1"
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(16,117,1) : # Echéance sans 'bon ŕ payer'
 If [F:DUD]FLGPAZ : GMESSAGE-="("+mess([F:DUD]FLGPAZ,510,1)+")" : Endif
Endif
If [F:DUD]SOINUM<>"" & OPT<>"R" : # Echéance sur relevé SOINUM
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(17,117,1)-[F:DUD]SOINUM
Endif
If [M]FCYOPT=3 & [M]FCY<>"" & [F:DUD]FCY<>[M]FCY : # Génération OD-sites
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(18,117,1)-[M]FCY-"->"-[F:DUD]FCY
Endif
If [M]BPROPT=3 & [M]BPR<>""
&  & (([F:DUD]SAC<>[M]BPRSAC & [F:CDA]ACCBPR="") | ([F:DUD]BPR<>[M]BPR & [F:DUD]BPRPAY<>[M]BPR))
 # Génération OD-tiers
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(19,117,1)-[M]BPRSAC-[M]BPR-"->"-[F:DUD]SAC-[F:DUD]BPR
Endif
If !find([F:DUD]TYP,"*SO","*PO") & [F:DUD]DUDSTA<>2
 # Echéance non validée
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(28,121,1)
Endif
Return

$MSG_VRF_DUD
GMESSAGE+="\" : # Echéance
If GIMPORT : GMESSAGE+=mess(1,292,1)-num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)+" : " : Endif
Return

#############
## Relevés ##
#############

$S_REL
Local Char OPT(1)
Local Char CRIT_ERE(250)
CRITERE="CPY='"+[M]CPY+"'"
If [M]FCYOPT=1
 Call PARAM([M]CPY,"SOIFCY",[L]OPT) From ADOVAL
 If [L]OPT<>"2" : CRITERE="FCY='"+[M]FCY+"'" : Endif
Endif

CRIT_ERE = CRITERE
# Bug 20067 : Pour les échéances, on s'intérresse au Tiers payeur
If [M]BPR<>""
 CRITERE+=" & BPR='"+[M]BPR+"'"
 CRIT_ERE+=" & BPRPAY='"+[M]BPR+"'"
 If [M]BPROPT=1 & [F:CDA]ACCBPR=""
  Call PARAM([M]CPY,"SOISAC",[L]OPT) From ADOVAL
  If [L]OPT<>"2" : CRITERE+=" & SAC='"+[M]BPRSAC+"'" : CRIT_ERE+=" & SAC='"+[M]BPRSAC+"'" : Endif
 Endif
Endif
#CRIT_ERE = CRITERE
CRITERE+=" & FLGPST<>2 & FLGFWD<>2"
START = "EXPNUM" : # zone numérique bidon
OBJET = "REL"
Return

$C_REL
Local Integer SOIMAX, NBSOI
SOIMAX = 500
Local Char TBSOI(GLONVCR)(1..SOIMAX)

Raz TBSOI, NBSOI
Filter [DUD] Where evalue(CRIT_ERE) & SOINUM<>""
For [DUD]DUD2(1)
 OK=0
 For [DUD]DUD2
  If [F:DUD]FLGCLE=1
     OK=1 : Break
  Endif
 Next
 #If !OK  :# Issue X3-43234 - 2017-07-21 by FHA : Keeping unsettled statements in TBSOI
 If OK    :# Issue X3-43234 - 2017-07-21 by FHA : Keeping unsettled statements in TBSOI
  If NBSOI<SOIMAX
   NBSOI+=1 : TBSOI(NBSOI)=[F:DUD]SOINUM
  Else
   Break
  Endif
 Endif
Next
Filter [DUD]
#Filter [SOI] Where !find([F:SOI]SOINUM,TBSOI(1..NBSOI))  :# Issue X3-43234 - 2017-07-21 by FHA
Filter [SOI] Where find([F:SOI]SOINUM,TBSOI(1..NBSOI))>0  :# Issue X3-43234 - 2017-07-21 by FHA
Return

$V_REL
Filter [SOI]
[M]OVCR=[F:SOI]SOINUM
[M]OD1 =-99
mkstat=4
Return

Subprog P_REL(MODIF)
Variable Integer MODIF
Local Char    NUM(GLONVCR), NUM2(GLONVCR), OPT(1), CRITERE(200)
MODIF=0
[L]OPT="R" : # Comme Relevé
[L]NUM=[M]OVCR
Raz [M]OD1, [M]OVCR

If [M]NBLIG<dim([M]VCRNUM)
 If !clalev([F:SOI])
  Onerrgo ERREUR From CONTROLE
  Local File SOI [SOI]
  Onerrgo
  If GERREUR : GERREUR=0 : Return : Endif
 Endif
 CRITERE="SOI=2 & SOINUM=[L]NUM2"
 If [F:CDA]ACCBPR<>"" : CRITERE+=" & (TYP='*SO' | TYP='*PO') & PAMTYP<>1" : # acompte attendu
 Else                 : CRITERE+=" & TYP<>'*SO' & TYP<>'*PO'"
 Endif
 [L]NUM2=[L]NUM : Gosub DUDSOI
 If [M]NBLIG<dim([M]VCRNUM) & OPT<>"" & [F:SOI]FLGFWDSOI=2
  For [SOI]SOI1 Where FWDSOI=[L]NUM
   [L]NUM2=[F:SOI]SOINUM : Gosub DUDSOI
   If [M]NBLIG=dim([M]VCRNUM) | OPT="" : Break : Endif
  Next : # [SOI]
 Endif
 If OPT="" & !MODIF : # Montants imputés = MT
  GERR=2 : GMESSAGE = mess(94,121,1)-"="-num$(sum([M]AMTLIN2(0..[M]NBLIG-1)))-[M]CUR
 Else GMESSAGE=""
 Endif
Endif
End

$DUDSOI
For [DUD]DUD2 Where evalue(CRITERE)
 Gosub CHARGE_DUD
 If [M]NBLIG=dim([M]VCRNUM) | OPT="" : Break : Endif
Next : # [DUD]
Return

$CHARGE_DUD
If [M]NBLIG=dim([M]VCRNUM) | OPT="" : Return : Endif
Local Integer NNUM, NLIG, I, NOL, OK, STAT, NOLIG
Local Decimal MT1, MT2, MT3, MT4
Local Char    REGCUR(GLONCUR)

NNUM=[F:DUD]ACCNUM : NLIG=[F:DUD]DUDLIG
Read [DUD]DUD1 = NNUM;NLIG
If fstat : # Echéance inexistante
 GMESSAGE=num$(NNUM)-num$(NLIG)-mess(38,110,1) : Return
Endif

#issue X3-195188 MANOW/MRDAB
Gosub SET_BID
If [L]OKQ=[V]CST_ANO
 Return
Endif
#issue end X3-195188 MANOW

Case [F:DUD]TYP
 When "*SO"   : GCLE=[M]BPCTYP
 When "*PO"   : GCLE=[M]BPSTYP
 When Default : GCLE=[F:DUD]TYP
Endcase
GCLE-=[F:DUD]NUM-format$("D:"+GFMDAT,[F:DUD]DUDDAT)

If [M]CUR=""
 [L]REGCUR=[F:DUD]CUR
 If find(GREP,"C","D") & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 : [L]REGCUR=GEURO : Endif
Else
 [L]REGCUR=[M]CUR
Endif

If [M]ACCDAT=[0/0/0] : [M]ACCDAT=datesyst : Endif
GLOCALDEV=[M]CURCPY

If [F:DUD]DEP <> '' # Issue X3-29143
  [M]DISDAT(NBLIG) = func PAYDEPLIB3.SETDISDAT([M:PAY1]ACCDAT) # PRD05
Endif # Issue X3-29143
Gosub SET_SNS From SUBPAY #65176

# Contrôles bloquants
GMESSAGE=""
If OPT="P" & [L]MONTANT
 MT1=[L]MONTANT
Else
 Call MTECHE(MT1,[M]NBLIG+1)
Endif
If [F:DUD]AMTCUR*MT1<=0 & OPT<>"P"
 For NOLIG=0 To [M]NBLIG-1   : # bug 12082
  If NNUM=[M]DUDNUM(NOLIG) & NLIG=[M]DUDLIG(NOLIG) : Break : Endif
 Next
 If NOLIG<=[M]NBLIG-1
  GMESSAGE=mess(22,117,1)-num$(NOLIG+1)  : # Echéance imputée en ligne...
 Else
  GMESSAGE=mess(15,117,1)  : # échéance déjŕ soldée
 Endif
Else
 Gosub CTL_DUD
 If instr(1,GMESSAGE,mess(28,121,1)) : mkstat=2 : Return : Endif  :# Bug 14084
 If GMESSAGE="" & [F:DUD]DUDSTA=2
  Call ANOUV([F:DUD]TYP,[F:DUD]NUM) From SUBPAY2
 Endif
 If GMESSAGE=""
  Call SNSPAYECH([F:CDA]ACCSNS,[M]SNS,[F:DUD]SNS,I) From SUBPAY2 : MT1*=I
  MT3=0
  If dim([M]RITAMT)>0 & func AFNC.PARAM("WTMNG",[M]CPY)="2"
   Gosub SET_RTZCUR
   Read [PIH]PIH0 = [F:DUD]NUM
   If fstat=0 & [F:PIH]GTE=[F:DUD]TYP
    For I=0 To [F:PIH]RITNBR-1
     Call LECTURE("RTZ",[F:PIH]RITCOD(I),"") From CONTOBJ
     If fstat=0 & [F:RTZ]TYP=1 & [F:RTZ]COE1<>0 : # Retenues sur rčglement
      MT4 = ([F:PIH]RITAMT(I)-[F:PIH]RITAMTDED(I))*[F:RTZ]COE1/([F:RTZ]COE1+[F:RTZ]COE2)
      GPOINT = "CALAMTRTZP" : Gosub ENTREE From EXEFNC
      Call ARRDEV(MT4,[M]RTZCUR) From TRTDIV
      MT3 += MT4
     Endif
    Next I
    If MT3<>0
     MT3*=-1
     For I=0 To [M]NBLIG-1
      If [M]VCRTYP(I)=[F:DUD]TYP & [M]VCRNUM(I)=[F:DUD]NUM
       MT3=0 : Break
      Endif
     Next I
    Endif
   Endif
  Endif
  MT4=0
  If dim([M]RITAMT)>0 & MT3<>0 & func AFNC.PARAM("WTMNG",[M]CPY)="2"
   Gosub SET_RTZCUR
   Call CONVERT([M]RTZCUR,[M]CUR,GLOCALDEV,[F:TPY]RATTYP,[M]ACCDAT,MT3,MT4,I) From TRTDEV
   If !I
    If find([F:PIH]INVTYP,2,4) : I=3 : Else I=2 : Endif
    Call SIGN2(I,[M]SNS,0,0,0,I) From PAYDIV
    MT4=I*MT4
   Endif
  Endif
  If [M]AMTCUR<>0
   MT2=[M]AMTCUR-sum([M]AMTLIN2(0..[M]NBLIG-1))-MT4
   Call CONVERT([L]REGCUR,[F:DUD]CUR,GLOCALDEV,[F:TPY]RATTYP,[M]ACCDAT,MT2,MT2,OK) From TRTDEV
   If OK : MT2=0 : Endif
  Else MT2=0
  Endif

  MT4=MT1
  Call SIGN2([F:CDA]ACCSNS,[M]SNS,[F:DUD]ACCNUM,[F:DUD]DUDLIG,3,OK) From PAYDIV
  MT2=MT2*OK
  If MT2=0 & [M]AMTCUR<>0 & sgn(MT1*OK)>0 : OPT="" : Return
  Elsif sgn(MT2)=sgn(MT1)
   If sgn(MT1)>=0 : MT1=min(MT1,MT2) : Else MT1=max(MT1,MT2) : Endif
  Endif

  STAT=0
  If MT1=MT4 & ([L]REGCUR=GLOCALDEV)
   Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ
   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
    Call LECTURE("TCU",[L]REGCUR,"") From CONTOBJ
    If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
     If [L]REGCUR=GLOCALDEV : MT2=[F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC : Endif
     For NOL=0 To [M]NBLIG-1
      If [F:DUD]ACCNUM=[M]DUDNUM(NOL) & [F:DUD]DUDLIG=[M]DUDLIG(NOL)
       Call SNSPAYECH([M]ACCSNS(NOL),[M]SNS,[F:DUD]SNS,I) From SUBPAY2
       MT2-=sgn([M]AMTLIN(NOL))*abs([M]AMTLIN2(NOL))*I
      Endif
     Next NOL
     If GREP="M"
      For [PYD]PYD1 Where NUM=[M]NUM & DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
       If [L]REGCUR=GLOCALDEV : MT2+=[F:PYD]PAYLOCLIN
       #Else                   : MT2+=[F:PYD]PAYRPTLIN
       Endif
      Next : # [PYD]
     Endif
     MT2*=OK : STAT=1
    Endif
   Endif
  Endif
  If !STAT
   Call CONVERT([F:DUD]CUR,[L]REGCUR,GLOCALDEV,[F:TPY]RATTYP,[M]ACCDAT,MT1*OK,MT2,OK) From TRTDEV
   If OK: # Pas de cours de devises [F:DUD]CUR -> CUR (ACCDAT)
    GMESSAGE=mess(16,114,1)-[F:DUD]CUR-"->"-[L]REGCUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
   Endif
  Endif
 Endif
Endif
If GMESSAGE<>""
 GMESSAGE=mess(1,292,1)-GCLE+"\"+GMESSAGE : # Echéance
 Return
Endif

# Avertissements
Gosub VRF_DUD
OK=0
For NOL=0 To [M]NBLIG-1
 If [M]DUDNUM(NOL)=[F:DUD]ACCNUM & [M]DUDLIG(NOL)=[F:DUD]DUDLIG : OK=NOL+1 : Break : Endif
Next NOL
If OK : # Echéance imputée en ligne OK
# GMESSAGE+="\"+mess(22,117,1)-num$(OK)
Endif
If GMESSAGE<>""
 If instr(1,GMESSAGE,mess(28,121,1))
  mkstat=2 : Return
 Else
  OK=2 : Call AVERTIR(mess(1,292,1)-GCLE+GMESSAGE,OK) From GESECRAN : # Echéance
  GMESSAGE="" : If OK<>2 : Return : Endif
 Endif
Endif

If [M]FCY=""
 [M]FCY=[F:DUD]FCY
 mkstat=0 : Call AP_FCY([F:DUD]FCY) From SUBPAY
 If mkstat :  mkstat=0 : Raz [M]FCY,BPR,BPRSAC,SNS,ACCDAT : Return : Else [M]FCY=[F:DUD]FCY : Endif
 mkstat=0 : Call AM_FCY([F:DUD]FCY) From SUBPAY
 If mkstat :  mkstat=0 : Raz [M]FCY,BPR,BPRSAC,SNS,ACCDAT : Return : Else [M]FCY=[F:DUD]FCY : Endif
 Affzo [PAY1]FCY
 If dim([M:PAY1]ZFCY)>0 : Affzo [PAY1]ZFCY : Endif
Endif
If [M]CUR=""
 [M]CUR=[F:DUD]CUR
 If find(GREP,"C","D") & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 :  [M]CUR=GEURO : Endif
 Call AP_CUR([M]CUR) From SUBPAY
 If dim([M:PAY1]CUR)>0 : Affzo [PAY1]CUR : Else Affzo [PAY2]CUR : Endif
 If dim([M:PAY1]ZCUR)>0 : Affzo [PAY1]ZCUR : Elsif dim([M:PAY2]ZCUR)>0 : Affzo [PAY2]ZCUR : Endif
Endif
# Initialisation du compte avant l'appel ŕ CHARGE_LIG (qui initialise les comptes lignes et déclenchent l'initialisation des sections)
If [M]ACC="" & [M]FCY<>"" & [F:DUD]BPRPAY<>"" & [F:DUD]SAC<>""
 [M]BPR=[F:DUD]BPRPAY : [M]BPRSAC=[F:DUD]SAC
 Call AS_ACC([M]ACC) From SUBPAY : mkstat=0
 If [M]BPR<>"" & [M]ACC<>""
  Call CONTACC(GTYPGEN,GPLAN(1),[M]ACC,[M]FCY,[M]CUR,[M]ACCDAT) From CPTCNT
  If !mkstat
   Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
   Gosub CONT_BPRACC From SUBPAY2
  Endif
  If !mkstat
   Call CONTBPRCPY([M]BPR,[M]FCY,[M]COA,[M]ACC,"") From CPTSUB
  Endif
  If mkstat
   Raz [M]ACC,[M]BPR,[M]BPRSAC : GMESSAGE="" : mkstat=0
   Return
  Endif
  Affzo [PAY1]BPR, BPRSAC, ACC, BPRNAM

  #150108 =>nouvelle gestion du code adresse
  If [F:DUD]BPAPAY<>""
   If [M]BPAINV<>"" & [M]BPAINV<>[F:DUD]BPAPAY
    # Attention code adresse rčglement différent
    Call MESSAGE(mess(222,117,1)) From GESECRAN
   Else
    [M]BPAINV = [F:DUD]BPAPAY
    If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
    Read [BPA] BPA0=1;[F:DUD]BPRPAY;[F:DUD]BPAPAY
    If fstat  Raz [F:BPA] : Endif
    [M]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [M]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [M]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [M]CRY          = [F:BPA]CRY
    [M]CRYNAM       = [F:BPA]CRYNAM
    [M]SAT          = [F:BPA]SAT
    [M]POSCOD       = [F:BPA]POSCOD
    [M]CTY          = [F:BPA]CTY
   Endif
  Endif
  If [M]BID="" : Call D_BIDCRY([M]BIDCRY) From SUBPAY : Endif
  If dim([M:PAY1]BIDCRY)>0 : Affzo [PAY1]BIDCRY : Else Affzo [PAY2]BIDCRY : Endif
 Endif
Endif
#
Call CHARGE_LIG(MT1,MT3) From SUBPAY4
MODIF=1
If [M]PAM=""
 If [F:TPY]DACPAM=3 | [F:TPY]NBRPAM=1 : # Invisible ou 1 seul
  [M]PAM=[F:TPY]PAM(0)
 Elsif find([F:DUD]PAM,[F:TPY]PAM(0..[F:TPY]NBRPAM-1))
  [M]PAM=[F:DUD]PAM
 Endif
 If [M]PAM<>""
  If dim([M:PAY1]PAM)>0 : Affzo [PAY1]PAM : Else Affzo [PAY2]PAM : Endif
  If dim([M:PAY1]ZPAM)>0 : Affzo [PAY1]ZPAM : Elsif dim([M:PAY1]ZPAM)>0 : Affzo [PAY2]ZPAM : Endif
 Endif
Endif
# FQ60352 - MABON 25/11/09 - Récupération code motif économique lors d'un picking d'échéance
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
  Local Char    ECOCOD
  Local Integer STAT
  Call CALC_BDFECOCOD(GFLAG,[M]BPR,[M]BID,[M]BPAINV,[M]AMTCUR,[M]CUR,[M]ACCDAT,[M]CPY,ECOCOD,STAT) From SUBPAY
  If STAT>0 Then [M]BDFECOCOD = ECOCOD Endif
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [M]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM="" & [M]BPR<>""
 [M]UMRNUM = [F:DUD]UMRNUM
Endif
Return

######################
Subprog MTECHE(MT,IND)
######################
Value Integer IND
Variable Decimal MT
# Local File [DUD]
Local Integer I, SIGN
MT=[F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
For I=0 To [M]NBLIG-1
 If I<>IND & [F:DUD]ACCNUM=[M]DUDNUM(I) & [F:DUD]DUDLIG=[M]DUDLIG(I)
  Call SNSPAYECH([M]ACCSNS(I),[M]SNS,[F:DUD]SNS,SIGN)
  MT-=[M]AMTLIN(I)*SIGN
 Endif
Next I
If GREP<>"M" : End : Endif
For [PYD]PYD1 Where NUM=[M]NUM & DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
 MT+=[F:PYD]PAYCURLIN
Next : # [PY0]
End

######################
Subprog MTAGIO(MT,IND)
######################
Value Integer IND
Variable Decimal MT
Local Integer I, NBJR, SIGN
Local Char DEP
Local Decimal SMT,TAUX
#Issue X3-69261 – 2018-11-22  by MADOR - 5.1.3 Existing process: update process GESPAY
Local Integer TOTLTI     ## Sum of all lead times
#Issue X3-69261 end
# Calcul du montant imputé ŕ l'échéance (montant réglé --> contient déjŕ l'escompte ou l'agio)
For I=0 To [M]NBLIG-1
 If I<>IND & [F:DUD]ACCNUM=[M]DUDNUM(I) & [F:DUD]DUDLIG=[M]DUDLIG(I)
  Call SNSPAYECH([M]ACCSNS(I),[M]SNS,[F:DUD]SNS,SIGN)
  SMT+=[M]AMTLIN(I)*SIGN
 Endif
Next I

# Affectation du code escompte/agio
[L]DEP=[F:DUD]DEP
Raz NBJR, TAUX
#Issue X3-69261 – 2018-11-22  by MADOR - 5.1.3 Existing process: update process GESPAY
If func AFNC.PARAM("IDNTDAEXE", [F:DUD]CPY) <> "2" or [F:DUD]SNS <> 1 or [M]ACCDAT < [F:DUD]DUDDAT
  Call CALC_LATE_CHARGE_EARLY_DISC([L]DEP, GCURLEG, SMT, [F:DUD]DUDDAT, [M]ACCDAT, [L]MT,
&                                  [L]NBJR, [F:DUD]ACCNUM, [F:DUD]DUDLIG, [L]TOTLTI, [L]TAUX) From SUBTDA
Else
  Call ERREURT(mess(32,7708,1), 0) From GESECRAN
Endif
#Issue X3-69261 end
Call LECTURE("TCU",[M]CURLIN(nolign-1),"") From CONTOBJ

If TAUX<0 : # Escompte
 #MT = arr(MT/(1+TAUX/100),[F:TCU]CURRND)
 #MT = arr(MT,[F:TCU]CURRND)
 # 27/04/04 : Reprise de la condition d'avant (=V130)...
# MT = arr(MT/(1+TAUX/100),[F:TCU]CURRND)

# If func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="1" | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="2" | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="4" | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="5"
  Call SNSPAYECH([M]ACCSNS(IND),[M]SNS,[F:DUD]SNS,SIGN)
  MT=[M]AMTLIN(IND)*SIGN
  MT *= -1
# Endif
Elsif TAUX>0 : # Agio
 MT = arr((MT*365)/(365+NBJR*TAUX/100),[F:TCU]CURRND)
 If NBJR<0 : MT*=-1 : Endif
Endif

# Détermination du signe
Call SNSPAYECH([M]ACCSNS(IND),[M]SNS,[F:DUD]SNS,SIGN)
If SIGN>0 : MT*=-1 : Endif

MT*=SIGN : # pour contre-carrer le SET_AMTLIN
End


$SET_AMTLIN
If MT<>0
 Call SNSPAYECH([M]ACCSNS(IND),[M]SNS,[F:DUD]SNS,I) : MT*=I
Endif
If [M]ACCTYP(IND)=1 : # Banque<=>Tiers
 If [M]AMTCUR<>0
  MT2=[M]AMTCUR
  For I=0 To [M]NBLIG-1
   If I<>IND : MT2-=[M]AMTLIN2(I) : Endif
  Next I
  If dim([M]RITAMT)>0 & [M]RITAMT(IND)<>0 & func AFNC.PARAM("WTMNG",[M]CPY)="2"
   Local Decimal MT3
   Gosub SET_RTZCUR
   Call CONVERT([M]RTZCUR,[M]CUR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,[M]RITAMT(IND),MT3,I) From TRTDEV
   If !I
    If find([F:PIH]INVTYP,2,4) : I=3 : Else I=2 : Endif
    Call SIGN2(I,[M]SNS,0,0,0,I) From PAYDIV
    MT3=I*MT3
    MT2-=MT3
   Endif
  Endif
 Else MT2=0
 Endif
 Call CONVERT([M]CUR,[M]CURLIN(IND),[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,MT2,MT2,I) From TRTDEV
 If !I
  Call SIGN2([M]ACCSNS(IND),[M]SNS,[M]DUDNUM(IND),[M]DUDLIG(IND),[M]IPTTYP(IND),I) From PAYDIV
  MT2=MT2*I
 Else MT2=0
 Endif
  If [M]VCRTYP(IND)="" : MT=MT2
# Bug 17662 : Si MT2=0 & AMTCUR<>0 --> les échéances st = montant d'entęte.
# Elsif MT2=0 & [M]AMTCUR<>0 & sgn(MT*I)>0 : MT=0
  Elsif sgn(MT2)=sgn(MT)
      If sgn(MT)>=0 : MT=min(MT,MT2)
      Else          : MT=max(MT,MT2)
      Endif
  Endif
Endif
indice=IND : Call AP_AMTLIN(MT) From SUBPAY
If mkstat : MT=0 : [M]AMTLIN2(IND)=0 : mkstat=0 : Endif
[M]AMTLIN(IND)=MT
Return


$AJUST
Case OK
 When 1 : # Ajustement banque
  [M]AMTCUR=sum([M]AMTLIN2)
  If dim([M:PAY1]AMTCUR)>0 : Affzo [PAY1]AMTCUR : Else Affzo [PAY2]AMTCUR : Endif
  If [M]BAN<>"" & [M]CUR=[M]CURBAN & [F:TPY]DACAMTBAN<>3
   [M]AMTBAN=[M]AMTCUR
   If dim([M:PAY1]AMTBAN)>0 : Affzo [PAY1]AMTBAN : Else Affzo [PAY2]AMTBAN : Endif
  Endif

 When 2 : # Ecart d'arrondi
  Gosub LEC_PAYRNDCDA From SUBPAY3
  Call LEC_CDA_LEG(GCURLEG,[L]PAYRNDCDA1) From CPTLEC
  If fstat | [F:CDA]ACCTYP<>1 | [F:CDA]ACCBPR<>"" : OK=0
  Else
   MT=[M]AMTCUR-sum([M]AMTLIN2)
   Call SIGN2([F:CDA]ACCSNS,[M]SNS,0,0,0,I) From PAYDIV
   Raz [F:DUD]
   Call CHARGE_LIG(I*MT,0) From SUBPAY4
  Endif
  If OK<>0
   Gosub LEC_PAYRNDCDA From SUBPAY3
   Call LEC_CDA_LEG(GCURLEG,[L]PAYRNDCDA2) From CPTLEC
   If fstat | [F:CDA]ACCTYP<>3 : OK=0
   Else
    Call SIGN2([F:CDA]ACCSNS,[M]SNS,0,0,0,I) From PAYDIV
    Raz [F:DUD]
    Call CHARGE_LIG(-I*MT,0) From SUBPAY4
   Endif
  Endif

 When 3 : OK=0
Endcase
# Issue X3-216829 by MRDAB - payment remittance approval
If [F:PYH]AMTCUR = [M]AMTCUR and OK <> 9
  [V]G_PAY_MODIFIED = [V]CST_ANO
Elsif [F:PYH]PAYAPPFLG = [V]CST_AYES
  [V]G_PAY_MODIFIED = [V]CST_AYES
Endif
# Issue X3-216829 end
If OK=0 : zonsui="AMTCUR" : Endif
Return

#####################
Subprog VERIF_SAI(OK)
#####################
Variable Integer OK
  #issue X3-47138 by MNO
  If func AFNC.ACTIV("FIFRC") & [M]BAN<>""
    If func FIFOCONVAR_CSTD.FLDFIFCP_CTL([M]BAN,[M]ACCDAT)
      If func FIFOCONVAR_CSTD.IS_FIFO_EXIST([M]BAN,[M]ACCDAT) = 1
        If [M:PAY0]NUM = ""
            GMESSAGE=mess(18,7708,1) : GERR=1 : OK=0 : End
        Else
            GMESSAGE=mess(19,7708,1) : GERR=1 : OK=0 : End
        Endif
      Endif
    Endif
  Endif
  #end issue
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
  If dim([F:CPY]BDFECOCOD)>0 Then
    # MABON - FQ57657 - 23/07/09 - Calcul du code motif économique
    Local Char    ECOCOD
    Local Integer STAT, DCLDIR
    # FQ61279 - MABON - 05/01/10 - On n'écrase pas la valeur si elle est déjŕ renseignée manuellement
    # dans le cas oů pas société déclarante directe
    Call SRC_DCLDIR([M]CPY,DCLDIR) From SUBPAY
    If ([M]BDFECOCOD="") or (DCLDIR=G_OUI) Then
      Call CALC_BDFECOCOD(GFLAG,[M]BPR,[M]BID,[M:PAY1]BPAINV,[M:PAY1]AMTCUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) From SUBPAY #CHECK IGNORE_LINE
      If STAT>0 Then
        # MABON - FQ63475 - 15/04/10 - Ajout test ECOCOD=""
        If ECOCOD="" or [M]BDFECOCOD="" Then
          [M]BDFECOCOD = ECOCOD
          If dim([M:PAY1]BDFECOCOD)>0 Then
            Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
          Endif
          If dim([M:PAY2]BDFECOCOD)>0 Then
            Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
          Endif
        Endif
      Endif
    Endif
  Endif

If [M]ACC=""
 GMESSAGE=mess(37,102,1) : # Compte obligatoire
 OK=0 : zonsui="BPR" : End
Endif

Local Libelle FLG(dim([M]DENCOD))
Local Integer I, J, STAT, NOL
Local Decimal TAMTCUR, MT
Local Char    BID(20)
Local Char    COMPTE(GLONGAC)
Local Integer INDEX, FLGACP
For I=0 To [M]NBLIG-1
 Local Libelle BPRTYP
 Call CLIFOU([M]BPR,GPLAN(1),[M]ACC,[M]SNS,[L]BPRTYP) From PAYDIV
 If GCURLEG = "POR" & [M]AMTLIN(I) < 0 & [L]BPRTYP = 1 : GMESSAGE=mess(100,7711,1) : OK=0 : zonsui="NBLIG(0)" : Break : Endif
 If [M]BPR=""
  Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(I)) From CPTLEC
  If [F:CDA]ACCBPR<>""
   Call LECTURE("CAC",[F:CDA]ACCBPR,"14~"+GPLAN(1)) From CONTOBJ
   If BPRTYP=1 : COMPTE = [F:CAC]ACC(2)
   Else        : COMPTE = [F:CAC]ACC(3)
   Endif
   Call LECTURE("GAC",[L]COMPTE,GPLAN(1)) From CONTOBJ
   If [F:GAC]SAC=2
    # Imputation DENCOD : ACCBPR compte de type collectif
    GMESSAGE=mess(23,117,1)-[M]DENCOD(I)-":"-[L]COMPTE-mess(19,104,1)
    OK=0 : zonsui="NBLIG("+num$(I)+")" : Break
   Endif
  Endif
 Endif

 If !FLG(I) & [M]DUDNUM(I)<>0
  Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(I)) From CPTLEC
  If [F:CDA]AMTMAX<>0 | [F:CDA]PRCMAX<>0
   Read [DUD]DUD1 = [M]DUDNUM(I);[M]DUDLIG(I)
   If fstat=0 : FLG(I)=2 : TAMTCUR=abs([M]AMTLIN(I)) : Endif
  Endif
  If !FLG(I) : FLG(I)=1 : Endif
  For J=I+1 To [M]NBLIG-1
   If [M]DENCOD(J)=[M]DENCOD(I)
    If FLG(I)=1 : FLG(J)=1
    Elsif [M]DUDNUM(J)=[M]DUDNUM(I) & [M]DUDLIG(J)=[M]DUDLIG(J)
     TAMTCUR+=[M]AMTLIN(J) : FLG(J)=2
    Endif
   Endif
  Next J
  If FLG(I)=2
   If [F:CDA]PRCMAX<>0
    MT=[F:DUD]AMTCUR*[F:CDA]PRCMAX/100
    Call ARRDEV(MT,[F:DUD]CUR) From TRTDIV
    If TAMTCUR>MT : OK=10 : Endif
   Endif
   If OK=1 & [F:CDA]AMTMAX<>0
    Call CONVERT([F:DUD]CUR,GCURSHR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,TAMTCUR,MT,STAT) From TRTDEV
    If !STAT & MT>[F:CDA]AMTMAX : OK=11 : Endif
   Endif
   If OK<>1
    GMESSAGE=mess([M]IPTTYP(I),659,1)
    If [M]IPTTYP(I)=3 : GMESSAGE-=[M]VCRTYP(I) : Endif
    # Imputation
    GMESSAGE-=[M]VCRNUM(I)+"\"+mess(23,117,1)-[M]DENCOD(I)-">"
    Case OK
     When 10 : GMESSAGE-=num$([F:CDA]PRCMAX)+" %"
               GMESSAGE-="("+num$(MT)-[F:DUD]CUR+")"
     When 11 : GMESSAGE-=num$([F:CDA]AMTMAX)-GCURSHR
               Call CONVERT(GCURSHR,[F:DUD]CUR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,[F:CDA]AMTMAX,MT,STAT) From TRTDEV
               If STAT : GMESSAGE-="("+num$(MT)-[F:DUD]CUR+")" : Endif
    Endcase
    OK=0 : zonsui="NBLIG(0)" : Break
   Endif
  Endif
 Endif
Next I
If OK=0 : End : Endif

If [M]CHQNUM<>"" & [M]SNS=2 : # Chčque reçu
 Local Integer OK2
 INDEX=find("SPE_CHQNUM",[G:PYH]keyname(0..[G:PYH]nbind-1))
 If INDEX
  If clalev([F:PYH2])=0 : Local File PAYMENTH [PYH2] : Endif
  Filter [PYH2] Where CHQNUM=[M]CHQNUM & SNS=2 & NUM<>[M]NUM Order By Key CLE = CHQNUM;SNS;NUM
  Read [PYH2] First
  Filter [PYH2]
  OK2 = 2
  If fstat<=2 : # Numéro de chčque sur le rčglement NUM (PAYTYP)
   Call AVERTIR(mess(56,121,1)-[F:PYH2]NUM-"("+[F:PYH2]PAYTYP+")",OK2) From GESECRAN
  Endif
  If OK2<>2 : OK = 0 : End : Endif
 Endif
Endif

MT=sum([M]AMTLIN2)
If [M]NBLIG=0 : # Il n'y a aucune ligne saisie
 GMESSAGE=mess(17,106,1) : OK=0
Elsif MT=0 : # Montant nul
 GMESSAGE=mess(177,117,1) : OK=0
Elsif MT<>[M]AMTCUR
 If MT<0 : OK=1
 Elsif [M]SNS=1 & [M]AMTCUR=0 : OK=2
 Elsif [M]SNS<>1 | [M]AMTBAN=0 | ([M]BAN<>"" & [M]CUR=[M]CURBAN) : OK=1
 Else OK=0
 Endif
 If OK=1 : # Rčglement déséquilibré - En-tęte AMTCUR - Ligne MT - Ecart AMTCUR-MT
  GMESSAGE=mess(24,117,1)+"\"+mess(62,105,1)-":"-num$([M]AMTCUR)-[M]CUR
&         +"\"+mess(7,105,1)-":"-num$(MT)-[M]CUR
&         +"\"+mess(64,111,1)-":"-num$([M]AMTCUR-MT)-[M]CUR
  OK=0
 Endif
 If OK
  [M]AMTCUR=MT
  If dim([M:PAY1]AMTCUR)>0 : Affzo [PAY1]AMTCUR : Else Affzo [PAY2]AMTCUR : Endif
  If [M]BAN<>"" & [M]CUR=[M]CURBAN & [F:TPY]DACAMTBAN<>3
   [M]AMTBAN=[M]AMTCUR
   If dim([M:PAY1]AMTBAN)>0 : Affzo [PAY1]AMTBAN : Else Affzo [PAY2]AMTBAN : Endif
  Endif
 Endif
Endif
If OK=0 : zonsui="NBLIG(0)" : End
Elsif [M]BAN<>"" & [M]CUR=[M]CURBAN & [F:TPY]DACAMTBAN=3 : [M]AMTBAN=[M]AMTCUR
Elsif [F:TPY]DACAMTBAN=3 : [M]AMTBAN=0
Endif

Call CONTACC(GTYPGEN,GPLAN(1),[M]ACC,[M]FCY,[M]CUR,[M]ACCDAT) From CPTCNT
If mkstat : OK=0 : zonsui="ACC" : End : Endif

If [M]PAM="" & [F:TPY]DACPAM<>2 : # Obligatoire ou Invisible
 [M]PAM=[F:TPY]PAM(0)
 If dim([M:PAY1]PAM)>0 : Affzo [PAY1]PAM : Else Affzo [PAY2]PAM : Endif
Endif
Call CONTTAM([M]PAM,GCURLEG,"") From SUBTAM
If mkstat
 mkstat=0 : GOK = 0 : End
Endif

# Un rčglement de type recette comptabilisation en banque par rčglement ne doit contenir
# que des acomptes de męme devise et code taxe si PPYCONSCTL=2
If [M]SNS=2 & func AFNC.PARAM("PPYCONSCTL",[M]CPY)="2" & ([F:TPY]STA3=2 | [F:TPY]STA8=2 | [F:TPY]ACETYP91=1
& | ([F:TPY]STA5<>2 & [F:TPY]STA7<>2))
 J = -1
 FLGACP = 0 : OK = 1
 For I=0 To [M]NBLIG-1
  Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(I)) From CPTLEC
  If !fstat & [F:CDA]ACCBPR<>"" & [F:CDA]RPCVAT=2 & [M]ACCTYP(I)=1
   FLGACP += 1
   If J=-1 : J=I : Endif
   If [M]VATLIN(I)<>[M]VATLIN(J)
    # Regroupement d'acomptes de codes taxes différents interdit
    OK = 0 : GMESSAGE = mess(251,117,1)
    Break
   Endif
   If [M]CURLIN(I)<>[M]CURLIN(J)
    # Regroupement d'acomptes de devises différentes interdit
    OK = 0 : GMESSAGE = mess(252,117,1)
    Break
   Endif
  Endif
 Next
 If OK = 1 & FLGACP>0 & FLGACP<>[M]NBLIG
  # Le rčglement ne doit contenir que des acomptes
  OK = 0 : GMESSAGE = mess(255,117,1)
 Endif
 If OK=0
  zonsui="NBLIG("+num$(I)+")"
  End
 Endif
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO") & [M:PAY1]SNS = 2 & func AFNC.PARAM("PORVAT",[M]FCY) = "2"
  Local Integer PREVREG : [L]PREVREG = 0
  Local Integer REG     : [L]REG     = 0

  Local Integer PREVDOC : [L]PREVDOC = 0
  Local Integer DOC     : [L]DOC     = 0

  #1 - Sales
  #2 - Purchases
  Gosub DEFMSKLIG From SUBPAY3

  For I=0 To [M]NBLIG-1
    If [M]VCRNUM(I)<>''
      #[L]REG = func SUBPAY3.GETCSHVATREG([M]VCRNUM(I))
      [L]REG = func PORLEGLIB.CSHVATREG([M:PAY1]BPR,[M]VCRNUM(I))
      If [L]PREVREG<>0 & [L]PREVREG <> [L]REG
        OK       = 0
        GMESSAGE = mess(65,7711,1)
        GERR     = 1
        Break
      Endif
      [L]PREVREG = [L]REG
    Endif
  Next

  If OK = 0
    End
  Endif

  #Accounts
  If [L]REG=2
    If !clalev([F:DUD1]) : Local File GACCDUDATE [DUD1] : Endif
    For I=0 To [M]NBLIG-1
      If [M]VCRNUM(I)<>''
        Read [F:SIH]SIH0=[M]VCRNUM(I)
        If !fstat
          [L]DOC = 1
        Else
          Read [F:PIH]PIH0=[M]VCRNUM(I)
          If !fstat
            [L]DOC = 2
          Endif
        Endif

        If [L]PREVDOC<>0 & [L]PREVDOC <> [L]DOC
          OK       = 0 : GMESSAGE = mess(69,7711,1) : GERR     = 1
          Break
        Endif

        [L]PREVDOC = [L]DOC

        For [DUD1] Where [F:DUD1]NUM = [M]VCRNUM(I)
          If [F:DUD1]BPRPAY <> [M:PAY1]BPR
            OK       = 0
            GMESSAGE = mess(73,7711,1)
            GERR     = 1
            Break
          Endif
        Next

      Else
        #Line without imputation
        Read [F:CDA]CDA0=[M]DENCOD(I)
        If !fstat
          If [F:CDA]ACCTYP=1
            OK       = 0
            GMESSAGE = mess(68,7711,1)
            GERR     = 1
            Break
          Endif
        Endif
      Endif
    Next

    If OK = 0
      End
    Endif
  Endif
Endif
#94635 RICAR 2014/04/21 - CASH VAT - END
#Issue X3-159248 – 2019-09-09  by VAVIL - SVAT - Changes related to GESPAY function
If func AFNC.ACTIV("KPO") > 0 & GCURLEG ="POR"
  Local Tinyint BPRTYP
  Local Integer BPC_CASHVAT_FLG, I : [L]BPC_CASHVAT_FLG = 0
  Local Char PREVDOC(GLONVCR)      : [L]PREVDOC      = ""
  Call CLIFOU([M]BPR,GPLAN(1),[M]ACC,[M]SNS,[L]BPRTYP) From PAYDIV
  If ([F:TPY]BPRTYP<>[L]BPRTYP & [M]BPR<>"") | [F:TPY]SNS = 3 : GMESSAGE = mess(198,117,1)-"-"-tolower(mess(86,105,1))-"-"-mess(14,151,1)-mess(218,107,1) : GERR=1 : OK=0 : End : Endif
  If [F:TPY]CSHVATRGM <>2 : [L]BPC_CASHVAT_FLG =0 : Else :[L]BPC_CASHVAT_FLG =1 : Endif
  If [F:TPY]CSHVATRGM <> func PORLEGLIB.VAL_BPC_CASHVAT([M:PAY1]BPR,[M]ACCDAT) : GMESSAGE = mess(2,76,1) - tolower(mess(2,2010,1)- mess(46,100,1)- mess(3,02287,1) - mess(4,36,1))
    GERR=1 : OK=0 : End
  Endif
  Case [L]BPRTYP
    When 1
      For I=0 To [M]NBLIG-1
        #Issue X3-160529 – 2019-10-09  by VAVIL - Changes related to GESPAY function (creating, posting and mass posting) - treatment of chargeability in Payment attributes
        Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(I)) From CPTLEC
				If [M]VCRNUM(I) = "" & [L]BPRTYP = 1 & [F:CDA]ACCTYP = 1 & [M]BPR<>""
          OK = 0 : GMESSAGE=mess(319,7711,1) : GERR  = 1 : Break
        Endif
        #Issue end
      Next
    When 2
#      For I=0 To [M]NBLIG-1
#        If [L]PREVDOC <> [M]VCRNUM(I)
#          [L]PREVDOC = [M]VCRNUM(I)
#          Read [SIH]SIH0 = [M]VCRNUM(I)
#          If !fstat
#            OK = 0 : GMESSAGE = mess(317,7711,1) : GERR  = 1  : Break
#          Endif
#        Endif
#      Next
  Endcase
  If OK = 0 : End : Endif
  If func AFNC.ACTIV("KPO")>0 & GCURLEG ="POR" & !func PORLEGLIB.CONT_DATETIME(GREP,GFONCTION) : OK = 0 : GERR = 1  : End : Endif
Endif
#Issue end
End


############################################
Subprog SNSPAYECH(CDASNS,PYHSNS,DUDSNS,SIGN)
############################################
Value Integer CDASNS, PYHSNS, DUDSNS
Variable Integer SIGN
Case CDASNS
 When 2 : SIGN=-DUDSNS : # Dépense
 When 3 : SIGN=DUDSNS  : # Recette
 When Default : SIGN=1 # Sens rčglement
Endcase
End

#######################
Subprog LECDUD(NUM,LIG)
#######################
Value Integer NUM,LIG
If [F:DUD]ACCNUM<>NUM | [F:DUD]DUDLIG<>LIG
 Read [DUD]DUD1 = NUM;LIG
Else fstat=0
Endif
End

##########
$B3_FACCDE
##########
# Version client / serveur : on ferme et ré-ouvre les fichiers avant et aprčs le tunnel
Local Char VALC2(20)
If zoncou="VCRNUM" : [L]VALC2=toupper(zc) : Else [L]VALC2=[M]VCRNUM(nolign-1) : Endif

Gosub AB3_FACCDE
Call OBJET([L]VALC1,[L]VALC2,[L]VALC3) From GOBJET
Gosub BB3_FACCDE
Return

$AB3_FACCDE
Local Integer K, I, NOL
Local Char    OPT(5), VALC1(20), VALC3(20)
If [L]VALC2="" : mkstat=2 : Return : Endif

NOL=nolign-1
If [M]VCRTYP(NOL)=[M]BPSTYP    : OPT="41235"
Elsif [M]VCRTYP(NOL)=[M]BPCTYP : OPT="31245"
Elsif [M]IPTTYP(NOL)=4         : OPT="2"
Elsif [M]SNS=1                 : OPT="21435"
Else                           : OPT="12345"
Endif

For I=1 To 5
 Case mid$(OPT,I,1)
  When "1" : # Facture client
   Call LECTURE("BIC",[L]VALC2,"") From CONTOBJ
   If fstat=0 & [F:SIH]GTE=[M]VCRTYP(NOL)
    If [F:SIH]ORIMOD=3
     [L]VALC1 = "BIC"
    Else
     [L]VALC1 = "SIH" : # Tunnel Reglt -> SIH : GBIDC2 ne peut pas ętre affecté
    Endif
    Break
   Endif
  When "2" : # Facture fournisseur
   Call LECTURE("BIS",[L]VALC2,"") From CONTOBJ
   If fstat=0 & (([M]IPTTYP(NOL)=4 & [F:PIH]INVTYP=5) | ([M]IPTTYP(NOL)<>4 & [F:PIH]GTE=[M]VCRTYP(NOL)))
    If [F:PIH]ORIMOD=3
     [L]VALC1 = "BIS"
    Elsif [F:PIH]ORIMOD=6
     [L]VALC1 = "PIH"
    Endif
    Break
   Endif
  When "3" : # Commande client
   If [M]VCRTYP(NOL)=[M]BPCTYP
    Call LECTURE("SOH",[L]VALC2,"") From CONTOBJ
    If fstat=0
     [L]VALC1 = "SOH" : # Tunnel Reglt -> CCL : GBIDC2 ne peut pas ętre affecté
     Break
    Endif
   Endif
  When "4" : # Commande fournisseur
   If [M]VCRTYP(NOL)=[M]BPSTYP
    Call LECTURE("POH",[L]VALC2,"") From CONTOBJ
    If fstat=0 & [F:POH]POHTYP=1
     [L]VALC1 = "POH"
     Break
    Endif
   Endif
  When "5" : # Pičce comptable
   Onerrgo ERREUR From CONTROLE
   If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : K=1 : Endif
   Onerrgo
   If !GERREUR
    Call LECTURE("GAS",[L]VALC2,[M]VCRTYP(NOL)) From CONTOBJ
    If fstat=0 : [L]VALC1 = "GAS" :  [L]VALC3=[M]VCRTYP(NOL) : Endif
    If K : Close Local File [HAE] : K=0 : Endif
    If [L]VALC1<>"" : Break : Endif
   Else GERREUR=0
   Endif
 Endcase
Next I
If [L]VALC1<>""
 OFONC1= GFONC1 : GFONC1="GESPAY"
 Local Char CODCPY(GLONCPY)
 CODCPY = [M]CPY
 Local Mask VENTILE2 [_VT2]
 [_VT2] = [VT2]
 Gosub AV_OBJET From SUBPAY2
Endif
Return

$BB3_FACCDE
If [L]VALC1<>""
 [VT2] = [_VT2]
 Local Char    MODELE(GLONGCM)
 Call SETGCM(CODCPY,MODELE) From CPTDIV
 Call SETPLAN2(MODELE,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
 Gosub AP_OBJET From SUBPAY2
 GFONC1=OFONC1
 If dim([L]CLECUR)>0
  Gosub OUVRE From =PROGOBJ
  Gosub OUVRE_FIC From SUBPAY3
  Gosub OUVOBJ From GOBJET : # GH 31/12/99
  If [L]CLECUR1<>"" : Read [PYH]PYH0 = [L]CLECUR1 : Endif
  Call LEC_TPY_LEG(GCURLEG,GFONC1) From CPTLEC
 Endif
Endif
mkstat=2
Return

$AV_OBJET
# V140 (CP 20/06/03 ) lié 17966 & 18557
 If dim([L]CLECUR)>0 : Gosub FERME_FIC From SUBPAY3 : Endif
GCONSULT=2
Return

$AP_OBJET
GCONSULT=0
Return

####################
## Ecran PAYECART ##
####################

Subprog C_CHOIX(VALEUR)
Variable Integer VALEUR
If mid$([M]CHOIX2,VALEUR,1)="x"
 GMESSAGE=mess(83,123,1) : mkstat=2 : # Valeur incorecte
Endif
End
######################################################################################
#Issue X3-195188 by MRDAB
$SET_BID

If !clalev([F:BIDQ])  : Local File BID        [BIDQ] : Endif
If !clalev([F:BPA])   : Local File BPADDRESS  [BPA]  : Endif

Local Integer OKQ : [L]OKQ=[V]CST_AYES
If [F:DUD]BIDNUMMAN <> ""
 If [M]BID <> "" and [M]BID <> [F:DUD]BIDNUMMAN
  Call OUINON(mess(218,121,1)-mess(219,121,1),[L]OKQ) From GESECRAN
  If [L]OKQ=[V]CST_ANO
   Return
  Endif
 Elsif [M]BID=""
  Read [F:BIDQ]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;[F:DUD]BPAPAY
  If fstat
   Read [F:BIDQ]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;""
  Endif
  If !fstat
   [M]PAB1 = [F:BIDQ]PAB1
   [M]BIDCRY = [F:BIDQ]CRY
   [M]BID=[F:DUD]BIDNUMMAN
  Endif
 Endif
Elsif [M]BID=""
 For [F:BIDQ]BID2 Where [F:BIDQ]BPATYP = 1 and [F:BIDQ]BPANUM = [F:DUD]BPRPAY and [F:BIDQ]BPAADD = [F:DUD]BPAPAY and [F:BIDQ]BIDNUMFLG = 2
  [M]PAB1 = [F:BIDQ]PAB1
  [M]BIDCRY = [F:BIDQ]CRY
  [M]BID = [F:BIDQ]BIDNUM
 Next
 If [M]BIDCRY = ""
  [M]BIDCRY = func SUBBIH.GET_CRY_FROM_ADDRESS([F:DUD]BPRPAY, [F:DUD]BPAPAY)
 Endif
Endif

If dim([M:PAY1]PAB1)>0   : Affzo [M:PAY1]PAB1   : Else Affzo [M:PAY2]PAB1    : Endif
If dim([M:PAY1]BIDCRY)>0 : Affzo [M:PAY1]BIDCRY : Else Affzo [M:PAY2]BIDCRY  : Endif
If dim([M:PAY1]BID)>0    : Affzo [M:PAY1]BID    : Else Affzo [M:PAY2]BID     : Endif

LogicClose File [F:BIDQ]

Return
#Issue X3-195188 end
################################################################################
################################################################################
$SET_RTZCUR
If dim([M]RTZCUR)>0
  If [M]RTZCUR = ""
    Call SETCUR(1,[M]CPY,RTZCUR) From CPTDIV
    [M]RTZCUR = RTZCUR
  Endif
Endif
Return
