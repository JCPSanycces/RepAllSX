######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BPS2) 14/04/2009 14:32:11 (ADMIN)
######################################################################################
$ACTION
Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "CREATION"       : Gosub CREATION
    When "LIENS"          : Gosub LIENS
    When "MODIF"          : Gosub MODIF
    When "APRES_MOD"    : Gosub REPLICA
    When "APRES_CRE"    : Gosub REPLICA
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "VERIF_MOD"        : Gosub VERIF
 When Default
Endcase
Return

##################################
# Registro de la modificación de un registro
# 17.04.2009 LPardo
##################################
$REPLICA
Call REPLICACIONTERCERO([F:BPS]BPSNUM) From SPEBPR
Return

######################################################################################
#        Z07 CREAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$OUVRE
    #### 07/12/2010
    If clalev([F:ZDT])=0  : Local File ZDPTO      [ZDT]  : Endif
    If clalev([F:ZPS])=0  : Local File ZCPGPRVSOC [ZPS]  : Endif
    If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
    ##############################################################


Return



######################################################################################

######################################################################################
#        Z07 CREAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$CREATION

    Call GRABAR_CONDICIONES


Return

######################################################################################

######################################################################################
#     Z07 CARGAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$LIENS

    Raz [M:ZBS0]
    nolign = 0
    Filter [ZPS] Where ZPSBPSNUM=[M:BPS0]BPSNUM
    For [ZPS]
     nolign += 1
     [M:ZBS0] = [F:ZPS]
     [M:ZBS0]ZPSCPY(nolign-1) = [F:ZPS]ZPSCPY
     [M:ZBS0]ZPSPTE(nolign-1) = [F:ZPS]ZPSPTE
     [M:ZBS0]ZPSPLAZO1(nolign-1) = [F:ZPS]ZPSPLAZO1
     [M:ZBS0]ZPSPLAZO2(nolign-1) = [F:ZPS]ZPSPLAZO2
     [M:ZBS0]ZPSPLAZO3(nolign-1) = [F:ZPS]ZPSPLAZO3




  # NOMBRE SOCIEDAD
    Read [F:CPY] CPY0=[F:ZPS]ZPSCPY
    If    fstat=0
        [M:ZBS0]ZCPYNAM(nolign-1)=[F:CPY]CPYNAM
    Endif



     If nolign >= dim([M:ZBS0]ZPSCPY)
      Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
      GOK = 0
      Break
     Endif
    Next
    [M:ZBS0]NBLIG = nolign
    Filter [ZPS]


Return

######################################################################################

######################################################################################
$VERIF
Local    Integer ERROR : ERROR = 0
Local    Integer I: I=0

        For I=0 To [M]NBLIG-1
            If len([M]ZPSPTE(I)) = 0  &  len([M]ZDEP(I)) = 0  & len([M]ZACCGTO(I)) = 0
                ERROR = 2
                Break
            Endif
        Next

       If  ERROR = 2
            GERR=1
            GMESSAGE= "Se ha de informar al menos uno de los siguientes campos para cada Sociedad: Condición Pago, Departamento o Cuenta Gastos."
            GOK=0
            mkstat = 2
       Endif


Return


######################################################################################

######################################################################################
#     Z07 MODIFICAR CONDICIONES PAGO SOCIEDADES
######################################################################################
$MODIF

    Call GRABAR_CONDICIONES

Return

######################################################################################


######################################################################################
#     Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################

Subprog GRABAR_CONDICIONES


    Delete [ZPS] Where ZPSBPSNUM=[M:BPS0]BPSNUM
    If fstat=1
         GOK = -1
         GLOCK = "$ZCPGPRVSOC"-[M:BPS0]BPSNUM
         End
    Elsif fstat>5
         GOK = 0
         Call RSTA("ZPS",[M:BPS0]BPSNUM) From GLOCK
         End
    Endif

    For nolign=1 To [M:ZBS0]NBLIG
     Raz [F:ZPS]
    [F:ZPS]       = [M:ZBS0]
    [F:ZPS]ZPSBPSNUM = [M:BPS0]BPSNUM
    [F:ZPS]ZPSCPY    = [M:ZBS0]ZPSCPY(nolign-1)
    [F:ZPS]ZPSPTE    = [M:ZBS0]ZPSPTE(nolign-1)
    [F:ZPS]ZPSPLAZO1    = [M:ZBS0]ZPSPLAZO1(nolign-1)
    [F:ZPS]ZPSPLAZO2    = [M:ZBS0]ZPSPLAZO2(nolign-1)
    [F:ZPS]ZPSPLAZO3    = [M:ZBS0]ZPSPLAZO3(nolign-1)



     Write [ZPS]
     If fstat
      GOK=0 : Call FSTA("ZPS") From GLOCK : Break
     Endif
    Next

End


######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES

######################################################################################

Subprog C_ZPSCPY(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]ZPSCPY) From OBJDIV

End


######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################

Subprog AM_ZPSCPY(VALEUR)
Variable Char    VALEUR()
Read [F:CPY] CPY0=VALEUR
    If    fstat=0
        [M:ZBS0]ZCPYNAM(nolign-1)=[F:CPY]CPYNAM
        Affzo[M:ZBS0]ZCPYNAM(nolign-1)
    Endif

End


