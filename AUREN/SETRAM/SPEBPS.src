######################################################################################
Subprog IB_ZDIA2
End


######################################################################################

######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog C_ZPSPLAZO1(VALEUR)
    Variable Decimal VALEUR
    If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
             End
        Endif
    Else
        Raz [M]ZPSPLAZO2(nolign-1)
    Endif
End

######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog C_ZPSPLAZO2(VALEUR)
Variable Decimal VALEUR


    If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
         Else
            If VALEUR<=[M]ZPSPLAZO1(nolign-1) | [M]ZPSPLAZO1(nolign-1) =0
                GMESSAGE= "Valor erroneo"
                 mkstat=2
              Endif
         Endif
    Else
        Raz [M]ZPSPLAZO3(nolign-1)

    Endif


End

######################################################################################
## Z07 RUTINA QUE CREA/MODIFICA CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog C_ZPSPLAZO3(VALEUR)
Variable Decimal VALEUR


     If VALEUR<>0
         If VALEUR<1
             GMESSAGE= "Valor erroneo"
             mkstat=2
         Else
            If VALEUR<=[M]ZPSPLAZO2(nolign-1) | [M]ZPSPLAZO2(nolign-1) = 0
                GMESSAGE= "Valor erroneo"
                 mkstat=2
              Endif
         Endif
    Endif

End


######################################################################################

######################################################################################
## Z07 - 09/12/10 si no hay condiciones de pago no se puede introducir plazo
######################################################################################
Subprog AS_ZPSPLAZO1(VALEUR)
Variable Decimal VALEUR

    If len([M]ZPSPTE(nolign-1)) = 0
        mkstat=2
    Else
        mkstat =0
    Endif

End


######################################################################################

######################################################################################
## Z07 - 09/12/10 si no hay condiciones de pago no se puede introducir plazo
######################################################################################
Subprog AS_ZPSPLAZO2(VALEUR)
Variable Decimal VALEUR

    If len([M]ZPSPTE(nolign-1)) = 0
        mkstat=2
    Else
        mkstat =0
    Endif

End

######################################################################################
## Z07 - 09/12/10 si no hay condiciones de pago no se puede introducir plazo
######################################################################################
Subprog AS_ZPSPLAZO3(VALEUR)
Variable Decimal VALEUR

    If len([M]ZPSPTE(nolign-1)) = 0
        mkstat=2
    Else
        mkstat =0
    Endif

End


######################################################################################

######################################################################################
## Z07 - 09/12/10 si no hay condiciones de pago no se puede introducir plazo
######################################################################################
Subprog AM_ZPSPTE(VALEUR)
Variable Char    VALEUR()

    If len(VALEUR) = 0
        [M]ZPSPLAZO1(nolign-1)=0
        [M]ZPSPLAZO2(nolign-1)=0
        [M]ZPSPLAZO3(nolign-1)=0

        Affzo [M]ZPSPLAZO1(nolign-1),ZPSPLAZO2(nolign-1),ZPSPLAZO3(nolign-1)
    Endif
End


######################################################################################



######################################################################################

######################################################################################
## Z07 - 09/12/10 Se ha de informar al menos uno de los siguientes campos: Condición Pago, Departamento o Cuenta Gastos
######################################################################################
Subprog APRES_NBLIG



    If len([M]ZPSCPY(nolign-1)) > 0

        If len([M]ZPSPTE(nolign-1)) = 0  &  len([M]ZDEP(nolign-1)) = 0  & len([M]ZACCGTO(nolign-1)) = 0
           Infbox    "Se ha de informar al menos uno de los siguientes campos: Condición Pago, Departamento o Cuenta Gastos."
        Endif
    Endif
End


