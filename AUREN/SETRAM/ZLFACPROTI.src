#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "INIT"

  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARÁMETRO SPEBIS
   Local Char ZPARLISTAF(250) : ZPARLISTAF =func AFNC.PARAM("ZPARLISTAF","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARLISTAF + nomap + "&usr=" + GUSER ,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

  Endcase
Return
