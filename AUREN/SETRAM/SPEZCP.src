#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
## PAGOS INTERSOCIEDAD                                           -- 25/01/2010 --   ##
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"         : Gosub OUVRE
        When "FIN"           : Gosub FIN
        When "DEBUT"         : Raz [M:ZCP]
        When "SETBOUT"       : Gosub SETBOUT 
        When "AV_CHOIX"      : Gosub AV_CHOIX
        When "APRES_MODIF"   : REP="M"
        When "ABA"           : REP=""
        When "ENR"           : Gosub ENR : REP="" 
        When default
    Endcase
Return
######################################################################################
$OUVRE
    If clalev([F:ZCP])<=0 : Local File ZTRANCP    [ZCP] : Endif  
    If clalev([F:TPY])<=0 : Local File TABPAYTYP  [TPY] : Endif  

    Raz [F:ZCP] 
    Read [F:ZCP]
Return
######################################################################################
$ENR    
    Local Integer Z

    Trbegin [ZCP]
    
    Delete [ZCP] Where 1=1
    
    For Z=0 To [M:ZCP]NBLIG-1  
        [F:ZCP]CPYORI    = [M:ZCP]CPYORI(Z)
        [F:ZCP]FCYORI    = [M:ZCP]FCYORI(Z)
        [F:ZCP]PAYTYPO   = [M:ZCP]PAYTYPO(Z)
        [F:ZCP]CPYDES    = [M:ZCP]CPYDES(Z)
        [F:ZCP]FCYDES    = [M:ZCP]FCYDES(Z)
        [F:ZCP]PAYTYPD   = [M:ZCP]PAYTYPD(Z)
        [F:ZCP]TAUT      = [M:ZCP]TAUT(Z)
        [F:ZCP]CRITZCP   = [M:ZCP]CRITZCP(Z)
        [F:ZCP]USERINF   = [M:ZCP]USERINF(Z)
    
        Write [ZCP]
        If fstat GOK=0 : Call FSTA("ZCP") From GLOCK : Rollback : Return : Endif
    Next Z    
    
    Commit
Return
######################################################################################
$AV_CHOIX
    Local Integer Z : Z=0
    
    Raz [M:ZCP]

    For [ZCP]
        [M:ZCP]CPYORI(Z)  = [F:ZCP]CPYORI
        [M:ZCP]FCYORI(Z)  = [F:ZCP]FCYORI   
        [M:ZCP]PAYTYPO(Z) = [F:ZCP]PAYTYPO   
        [M:ZCP]CPYDES(Z)  = [F:ZCP]CPYDES    
        [M:ZCP]FCYDES(Z)  = [F:ZCP]FCYDES    
        [M:ZCP]PAYTYPD(Z) = [F:ZCP]PAYTYPD   
        [M:ZCP]TAUT(Z)    = [F:ZCP]TAUT      
        [M:ZCP]CRITZCP(Z) = [F:ZCP]CRITZCP 
        [M:ZCP]USERINF(Z) = [F:ZCP]USERINF  
        [M:ZCP]NBLIG +=1
        Z +=1
    Next

    Affzo [M:ZCP]
Return
######################################################################################
$SETBOUT

Return
######################################################################################
$FIN

Return
######################################################################################
######################################################################################
Subprog AM_CPYDES(VALEUR)
    Variable Char    VALEUR()

    If VALEUR = [M:ZCP]CPYORI(nolign-1)
        GERR=1
        GMESSAGE = mess(27,111,1)
        mkstat=1
        End
    Endif
End
######################################################################################
Subprog AM_FCYDES(VALEUR)
    Variable Char    VALEUR()

    Local Integer IJL
    
    If VALEUR <>""                           : # controle le site doit appartenir a la societe 
       IJL=find(VALEUR,GSITE(1..GNBSITE))
       If IJL 
          If [M]CPYDES(nolign-1)<>GSOCSITE(IJL)
             GERR=1 : GMESSAGE=mess(412,199,1)   : mkstat=1 : End    
          Endif 
        Else
          GERR=1 : GMESSAGE=mess(412,199,1)  : mkstat=1 : End    
       Endif
    Endif
End
######################################################################################
Subprog C_FCYORI(VALEUR)
    Variable Char    VALEUR()
    Local Integer IJL
    
    If VALEUR <>""                           : # controle le site doit appartenir a la societe 
       IJL=find(VALEUR,GSITE(1..GNBSITE))
       If IJL 
          If [M]CPYORI(nolign-1)<>GSOCSITE(IJL)
             GERR=1 : GMESSAGE=mess(412,199,1)   : mkstat=1 : End    
          Endif 
        Else
          GERR=1 : GMESSAGE=mess(412,199,1)  : mkstat=1 : End    
       Endif
    Endif
End
######################################################################################
Subprog C_PAYTYPO(VALEUR)
    Variable Char    VALEUR()

    Read [TPY]TPY0 = VALEUR : If fstat Raz [F:TPY] : Endif

    If [F:TPY]SNS <> 1
        GERR = 1
        GMESSAGE = mess(228,117,1) 
        mkstat=1
        End
    Endif
End
######################################################################################
Subprog C_PAYTYPD(VALEUR)
    Variable Char    VALEUR()

    Read [TPY]TPY0 = VALEUR : If fstat Raz [F:TPY] : Endif

    If [F:TPY]SNS <> 2
        GERR = 1
        GMESSAGE = mess(227,117,1) 
        mkstat=1
        End
    Endif
End
######################################################################################
Subprog C_FCYDES(VALEUR)
    Variable Char    VALEUR()

    IDEM =[M]CPYORI(nolign-1)+"~"
    IDEM +=[M]FCYORI(nolign-1)+"~"
    IDEM +=[M]PAYTYPO(nolign-1)+"~"
    IDEM +=[M]CPYDES(nolign-1)+"~"
    IDEM +=[M]FCYDES(nolign-1)+"~"
    IDEM +=VALEUR
    Call UNICITE(IDEM,[M]CRITZCP) From OBJDIV
    If mkstat : End : Endif
End

######################################################################################
Subprog APRES_NBLIG
    [M:ZCP]CRITZCP(nolign-1)  = [M]CPYORI(nolign-1)+"~"
    [M:ZCP]CRITZCP(nolign-1)  +=[M]FCYORI(nolign-1)+"~"
    [M:ZCP]CRITZCP(nolign-1)  +=[M]PAYTYPO(nolign-1)+"~"
    [M:ZCP]CRITZCP(nolign-1)  +=[M]CPYDES(nolign-1)+"~"
    [M:ZCP]CRITZCP(nolign-1)  +=[M]FCYDES(nolign-1)+"~"
    [M:ZCP]CRITZCP(nolign-1)  +=[M]PAYTYPD(nolign-1)

End
######################################################################################
######################################################################################

