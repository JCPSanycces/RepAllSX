############################################################################
###
###    Z14  Debe introducirse filtro de selección en Lotes o en Pagos
###
############################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)

Local Char NUMLOT
Local Char NUMPAY

    # Obtener fecha inicio
    Call GETPARAM("lotfin",NBPAR,PARAMETRE,NUMLOT) From ETAT
    Call GETPARAM("numfin",NBPAR,PARAMETRE,NUMPAY) From ETAT

    If NUMLOT="zzzzzzzzzz" & NUMPAY="zzzzzzzzzz"
        # ERROR
        Call ECR_TRACE("Debe indicar selección de Lotes o de Pagos",1) From GESECRAN 
        GOK = 0 
   
    Endif

End

