#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

$TERMINE

    If clalev([F:ZEXVAT]) <= 0 : Local File ZEXVAT  [Z21]: Endif
    If clalev([F:YDCLVATES]) <= 0 : Local File YDCLVATES  [YDC]: Endif

# Modelo 347

    Filter [Z21] Where MODELO="347" 
    For [Z21]Z210 
        Update [YDC] Where VAT = [Z21]VAT and (TYP='FAC' or TYP = 'ABC') With D347FLG = 2
    Next Z21
    Filter [Z21]

## Modelo 349
    Filter [Z21] Where MODELO="349"
    For [Z21]Z210 
        Update [YDC] Where VAT = [Z21]VAT and (TYP='FAC' or TYP = 'ABC') With D349FLG = 2
    Next Z21
    Filter [Z21]

## Flag INTRACOMUNITARIO

    Filter [Z21] Where MODELO="INT"
    For [Z21]Z210 
        Update [YDC] Where VAT = [Z21]VAT and (TYP='FAC' or TYP = 'ABC') With CEEFLG = 2
    Next Z21
    Filter [Z21]

## Flag AUTOFACTURA

    Filter [Z21] Where MODELO="AUT"
    For [Z21]Z210 
        Update [YDC] Where VAT = [Z21]VAT and (TYP='FAC' or TYP = 'ABC') With ISPVENTA = 2
    Next Z21
    Filter [Z21]


Close Local File [Z21]
Close Local File [YDC]
   
Return
