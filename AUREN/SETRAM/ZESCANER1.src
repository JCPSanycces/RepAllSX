#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
### Proceso de escaneo de facturas recibidas                    JGM -- 15/06/2009  ###
######################################################################################
$ACTION

Case ACTION
 When "INIT"
  #----------------------------------#
  # Inicio de ejecucci del proceso #
  #----------------------------------#
  Case GACTION
   When "ZESCANER1"  : Gosub INIT_ZESCANER
  Endcase
 When "EXEC"
  #-------------------------#
  # Ejecucci del proceso  #
  #-------------------------#
  Case GACTION
   When "ZESCANER1"  : Gosub EXEC_ZESCANER
  Endcase
 When "TERMINE"
  #--------------------------------#
  # Fin de ejecucci del proceso  #
  #--------------------------------#
  Case GACTION
   When "ZESCANER1"  : Gosub TERM_ZESCANER
  Endcase
Endcase
Return
######################################################################################
$INIT_ZESCANER

Return
######################################################################################
$EXEC_ZESCANER
    Local    Char     RUTA(250)
    Local    Char     EXECICI
    Local    Char     MES
    Local    Char     DIA
    Local    Integer  LINEA    : LINEA   = 0
    Local    Integer  XNUM     : XNUM    = 0
    Local    Integer  ERROR    : ERROR   = 0
    Local    Char     XOBJETO  : XOBJETO = PARAM(1)  ## Objeto en curso
    Local    Char     XNUMFAC  : XNUMFAC = PARAM(2)  ## Numero de Factura
    Local    Date     XDAT     : XDAT    = PARAM(3)  ## Fecha de Factura
    Local    Char     XFCY     : XFCY    = PARAM(4)  ## Planta de la factura
    Local    Char     XNUMREG  : XNUMREG = PARAM(5)  ## Numero de Registro
    Local    Char     XPARAMETROS(200)

    ######################################################################################
    #
    #    Z18 - Control facturas coincidentes al pulsar el bot de escaneo
    #
    ######################################################################################
    #Call LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER From SPEBIS
    ######################################################################################

    If clalev([F:XCPY])=0 : Local File COMPANY   [XCPY] : Endif
    If clalev([F:XFCY])=0 : Local File FACILITY  [XFCY] : Endif
    If clalev([F:XAOX])=0 : Local File AOBJTXT   [XAOX] : Endif
    If clalev([F:XPIH])=0 : Local File PINVOICE  [XPIH] : Endif

    ## Buscamos la ruta donde se guardan los documentos escaneados

    If XFCY = "" or XDAT = [00/00/00] or XNUMREG = ""
        GERR=1
        GMESSAGE="Datos obligatorios no informados. Escaneo cancelado"
        GOK=0
        Return
    Endif

    Read [XFCY]FCY0 = XFCY           : If fstat Raz [F:XFCY] : Endif
    Read [XCPY]CPY0 = [F:XFCY]LEGCPY : If fstat Raz [F:XCPY] : Endif

    If XNUMFAC = "" : XNUMFAC = num$(adxuid(1)) : Endif

    RUTA = [F:XCPY]ZRUTA

    If RUTA = ""
        GERR=1
        GMESSAGE="La ruta de escaneo no esta informada"
        GOK=0
        Return
    Endif

    EXERCICI = num$(year(XDAT))
    MES      = num$(month(XDAT))
    DIA      = num$(day(XDAT))

    If len(MES) = 1
       MES = "0" + MES
    Endif

    If len(DIA) = 1
       DIA = "0" + DIA
    Endif

    RUTA = RUTA + EXERCICI + "\" + MES + "\" + DIA #+ "\"

    ## Lanzamos el programa de escaneo de documentos

    ## XPARAMETROS = GZRUTESC + " " + [F:XCPY]CPY + " " + num$(XNUMFAC) + " " + num$(XNUMREG)

    ## 24/01/2011 adida la ruta de escaneo
    ## XPARAMETROS = GZRUTESC + " " + [F:XCPY]CPY + " " + "FREC" + " " + num$(XNUMREG)
    XPARAMETROS = GZRUTESC + " " + [F:XCPY]CPY + " " + "FREC" + " " + num$(XNUMREG) + " " + RUTA


  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARﾁMETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + XNUMFAC + "&cpy=" + [F:XCPY]CPY + "&act=rpl",
&"UIAdxPubSubFile="+chr$(1)+"1"
  #####AUREN.FIN
  ###########################################################################################

    If stat1 <>0
        GERR=1
        GMESSAGE="Error en el programa de escaneo"
        GOK=0
        Return
    Endif

    Call TEMPON("F") From GESECRAN

    ## Buscamos si el fichero existe.
#Nuevo parametro ZESCAN=2 si es necesario escaner facturas. WEB-MIS-ZESCAN
If val(func AFNC.PARAM("ZESCAN","")) = 2
   Gosub BUSCAR_FIX
Endif
# AUREN - PU9 - PRUEBAS
#Endif
# AUREN - DSM - 05/2012 - ESCANER

    If ERROR =1
        Call TEMPOFF From GESECRAN
        GERR = 1
        GMESSAGE = mess(101,100,1)
        GOK=0
        Return
    Endif


    Call TEMPOFF From GESECRAN
Return
######################################################################################
$TERM_ZESCANER

Return
######################################################################################
$BUSCAR_FIX
    $XBUSCAR
    FICTRA  = filpath(RUTA,XNUMREG,"PDF")
    If filinfo(FICTRA,0)<0 and XNUM <=4
        Sleep 5
        ERROR = 1
        XNUM += 1
        Gosub XBUSCAR
    Endif
Return
######################################################################################
######################################################################################
