#<AdxTL>@(#)0.0.0.0 $Revision$ 

######################################################################################
### Proceso de escaneo de facturas recibidas                    JGM -- 15/06/2009  ###
######################################################################################
$ACTION
Case ACTION
 When "INIT"
  #----------------------------------#
  # Inicio de ejecucci del proceso #
  #----------------------------------#
  Case GACTION
   When "ZESCANER"  : Gosub INIT_ZESCANER
  Endcase
 When "EXEC"
  #-------------------------#
  # Ejecucci del proceso  #
  #-------------------------#
  Case GACTION
   When "ZESCANER"  : Gosub EXEC_ZESCANER
  Endcase
 When "TERMINE"
  #--------------------------------#
  # Fin de ejecucci del proceso  #
  #--------------------------------#
  Case GACTION
   When "ZESCANER"  : Gosub TERM_ZESCANER
  Endcase
Endcase
Return
######################################################################################
$INIT_ZESCANER

Return
######################################################################################
$EXEC_ZESCANER
    Local    Char     RUTA(250)
    Local    Char     EXECICI
    Local    Char     MES
    Local    Char     DIA
    Local    Integer  LINEA    : LINEA   = 0
    Local    Integer  XNUM     : XNUM    = 0
    Local    Integer  ERROR    : ERROR   = 0
    Local    Char     XOBJETO  : XOBJETO = PARAM(1)  ## Objeto en curso
    Local    Char     XNUMFAC  : XNUMFAC = PARAM(2)  ## Numero de Factura
    Local    Date     XDAT     : XDAT    = PARAM(3)  ## Fecha de Factura
    Local    Char     XFCY     : XFCY    = PARAM(4)  ## Planta de la factura
    Local    Char     XNUMREG  : XNUMREG = PARAM(5)  ## Numero de Registro
    Local    Char     XPARAMETROS(200)

    ######################################################################################
    #
    #    05.845.197 - Nuevo control facturas coincidentes al pulsar el bot de escaneo
    #
    ######################################################################################
    ## AUREN - JPR - 20180516 - Compras
    Local Decimal   BASEIMP(10,2)
    Local Tinyint   CHECK
    Local Date      FECHAFAC
    Local Char      PROVEEDOR(20)
    Local Char      SOCIEDAD(10)
    Local Char      USUARIO(5)

    CHECK = 0

    If clalev([F:XPIH]) = 0 : Local File PINVOICE [XPIH] : Endif

    If XOBJETO = "BIS"
      SOCIEDAD  = [M:BIS0]CPY
      BASEIMP   = [M:BIS1]AMTNOT
      FECHAFAC  = [M:BIS1]BPRDAT
      PROVEEDOR = [M:BIS0]BPR
    Else
      SOCIEDAD  = [M:PIH0]ZCPY
      BASEIMP   = [M:PIH1]TOTLINAMT1
      FECHAFAC  = [M:PIH1]BPRDAT
      PROVEEDOR = [M:PIH0]BPR
    Endif
    USUARIO = GUSER


    If SOCIEDAD = "" or XDAT = [00/00/00] or FECHAFAC = [00/00/00] or XNUMREG = "" or PROVEEDOR = "" or BASEIMP = 0

        GERR=1
        GMESSAGE="Datos obligatorios no informados. Escaneo cancelado"
        GOK=0
        Return
    Endif

    Filter [XPIH] Where CPY=SOCIEDAD and BPR=PROVEEDOR and AMTNOT=BASEIMP and BPRDAT=FECHAFAC and CREUSR=USUARIO and ZESCDAT<date$

    Read [XPIH]PIH0 First
    If fstat = 0
      # Para este proveedor, fecha, base imponible y usario de escaneo
      # ya exiten facturas escaneadas con fecha de escaneo anterior a la del sistema
      CHECK = 1
    Endif
    Filter [XPIH]

    If CHECK
      GERR     = 1
      GMESSAGE = "Ya existe una factura de igual base imponible y fecha para este proveedor escaneada por este usuario. Escaneo cancelado."
      GOK      = 0
      Return
    Endif
    ## AUREN - JPR - 20180516 - Compras -Fin
    ######################################################################################


    ######################################################################################
    #
    #    Z18 - Control facturas coincidentes al pulsar el bot de escaneo
    #
    ######################################################################################
## AUREN - DSM - Abril 2013 - Compras
#        Call LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER From SPEBIS
    If XOBJETO = "BIS"
        Call LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER From SPEBIS
    Elsif XOBJETO = "PIH"
        Call LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER From SPEPIH
    Endif
## AUREN - DSM - Abril 2013 - Compras
    ######################################################################################

    If clalev([F:XCPY])=0 : Local File COMPANY   [XCPY] : Endif
    If clalev([F:XFCY])=0 : Local File FACILITY  [XFCY] : Endif
    If clalev([F:XAOX])=0 : Local File AOBJTXT   [XAOX] : Endif
    If clalev([F:XPIH])=0 : Local File PINVOICE  [XPIH] : Endif

    ## Buscamos la ruta donde se guardan los documentos escaneados

    If XFCY = "" or XDAT = [00/00/00] or XNUMREG = ""
        GERR=1
        GMESSAGE="Datos obligatorios no informados. Escaneo cancelado"
        GOK=0
        Return
    Endif

    Read [XFCY]FCY0 = XFCY           : If fstat Raz [F:XFCY] : Endif
    Read [XCPY]CPY0 = [F:XFCY]LEGCPY : If fstat Raz [F:XCPY] : Endif

    If XNUMFAC = "" : XNUMFAC = num$(adxuid(1)) : Endif

    RUTA = [F:XCPY]ZRUTA

    If RUTA = ""
        GERR=1
        GMESSAGE="La ruta de escaneo no esta informada"
        GOK=0
        Return
    Endif

    EXERCICI = num$(year(XDAT))
    MES      = num$(month(XDAT))
    DIA      = num$(day(XDAT))

    If len(MES) = 1
       MES = "0" + MES
    Endif

    If len(DIA) = 1
       DIA = "0" + DIA
    Endif

    RUTA = RUTA + EXERCICI + "\" + MES + "\" + DIA #+ "\"

    ## Lanzamos el programa de escaneo de documentos

    ## 24/01/2011 adida la ruta de escaneo
    ## XPARAMETROS = GZRUTESC + " " + [F:XCPY]CPY + " " + "FREC" + " " + num$(XNUMREG)
    XPARAMETROS = GZRUTESC + " " + [F:XCPY]CPY + " " + "FREC" + " " + num$(XNUMREG) + " " + RUTA

  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PARﾁMETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")
    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + XNUMREG + "&cpy=" + [F:XCPY]CPY + "&act=bis",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

    Char FICHIERS(200)(50)
# AUREN - DSM - 05/2012 - ESCANER
# If XOBJETO <> "PIH"
# AUREN - PU9 - PRUEBAS
#     System FICHIERS = XPARAMETROS
# AUREN - PU9 - PRUEBAS
# Endif
# AUREN - DSM - 05/2012 - ESCANER

    If stat1 <>0
        GERR=1
        GMESSAGE="Error en el programa de escaneo"
        GOK=0
        Return
    Endif
    Call TEMPON("F") From GESECRAN

    ## Buscamos si el fichero existe.
 # AUREN - DSM - 05/2012 - ESCANER
#If XOBJETO <> "PIH"
# AUREN - PU9 - PRUEBAS
   Gosub BUSCAR_FIX
# AUREN - PU9 - PRUEBAS
#Endif
# AUREN - DSM - 05/2012 - ESCANER

    If ERROR =1
        Call TEMPOFF From GESECRAN
        GERR = 1
        GMESSAGE = mess(101,100,1)
        GOK=0
        Return
    Endif

    ## Grabamos la ruta del fichero en los elementos adjuntos de la factura
    LINEA = 0
    For [XAOX]AOX0 Where ABREV = XOBJETO and IDENT1 = XNUMFAC
        LINEA = val([F:XAOX]IDENT3)
    Next

    RUTA = RUTA + "\"

    LINEA += 1

    Raz [F:XAOX]
    [F:XAOX]ABREV  = XOBJETO
    [F:XAOX]IDENT1 = XNUMFAC
    [F:XAOX]IDENT2 = ""
    [F:XAOX]IDENT3 = format$("N0:3#",LINEA)
    [F:XAOX]TYPDOC = "PDF"
    [F:XAOX]NAM    = RUTA + XNUMREG + ".PDF"
    [F:XAOX]CAT    = 1
    Write [XAOX]
    If fstat
        Call TEMPOFF From GESECRAN
        GOK = 0 : Call FSTA("XAOX") From GLOCK : Return
    Endif

    ## Marcamos la factura como escaneada

    If PARAM(2) <> ""

        Update [XPIH] Where NUM = XNUMFAC With ZESCAN = 2
        If fstat
            Call TEMPOFF From GESECRAN
            GOK=0 : Rollback : Call FSTA("XPIH") From GLOCK : Return
        Endif
    Endif

    If XOBJETO = "BIS"
        [M:BIS0]ZESCAN = 2
        Affzo [M:BIS0]
    Elsif XOBJETO = "PIH"
        [M:PIH0]ZESCAN = 2
        Affzo [M:PIH0]
    Endif

    Call TEMPOFF From GESECRAN
Return
######################################################################################
$TERM_ZESCANER
# AUREN - DSM - 05/2012 - ESCANER
        If XOBJETO = "BIS"
        [M:BIS0]ZESCAN = 2
        Affzo [M:BIS0]
    Elsif XOBJETO = "PIH"
        [M:PIH0]ZESCAN = 2
        Affzo [M:PIH0]
    Endif
# AUREN - DSM - 05/2012 - ESCANER

Return
######################################################################################
$BUSCAR_FIX
ERROR = 0
XNUM = 0
    $XBUSCAR
 #AUREN PU9
#    FICTRA  = filpath(RUTA,XNUMREG,"PDF")
    FICTRA  = filpath("BANDERAS","","") + "\" + XNUMREG
 #AUREN PU9
    If filinfo(FICTRA,0)<0
        Sleep 5
        ERROR = 1
        XNUM += 1
        If XNUM <=4
          Gosub XBUSCAR
        Endif
     Else
      ERROR = 0
     Endif
 Return
######################################################################################
######################################################################################
