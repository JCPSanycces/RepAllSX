######################################################################################################
# Module        : Customer BP invoices
# Description   : Swiss specific initializations for customer BP invoices
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
 # 04.02.16 |Bader |U10    |CALC_BVRFIELDS: don't calculate fields in import mode (GIMPORT)
 # 08.05.19 |angre |V12    |Add handling for SWI QR-Code handling for sales invoices
 #2019-08-13|Bader |2019.R4|X3-140541 use the correct messages for QR
######################################################################################################


######################################################################################################
Subprog SHOW_HIDE_BVRFIELDS(FCY,INVTYP,PTE,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char CUR
Local Integer SHOW
Local Integer WRITQR #angre X3-139374

Gosub CHECK_SHOW From SUBSIHSWI
If !SHOW : Gosub CHECK_WRITE_QR From SUBSIHSWI : Endif ##angre X3-139374
If SHOW or WRITQR
  Chgfmt [M:BIC1]BVRREFNUM With "K:27X"
  Chgfmt [M:BIC1]PAYBAN With "K:5c"
Else
  Raz [M:BIC1]BVRREFNUM               # clear field
  Raz [M:BIC1]PAYBAN                  # clear field
  Chgfmt [M:BIC1]BVRREFNUM With "-K:27X"
  Chgfmt [M:BIC1]PAYBAN With "-K:5c"
Endif
If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
End


######################################################################################################
Subprog CALC_PAYBAN(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

Gosub CHECK_SHOW From SUBSIHSWI
If SHOW
  [M:BIC1]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
  # if paying bank is not found, display an error message
  If [M:BIC1]PAYBAN = ""
     GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
     mkstat = 2 : End
  Endif
  Chgfmt [M:BIC1]BVRREFNUM With "K:27X"
  Chgfmt [M:BIC1]PAYBAN With "K:5c"
Else
  Raz [M:BIC1]BVRREFNUM               # clear field
  Raz [M:BIC1]PAYBAN                  # clear field
  Chgfmt [M:BIC1]BVRREFNUM With "-K:27X"
  Chgfmt [M:BIC1]PAYBAN With "-K:5c"
Endif
If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
End


######################################################################################################
Subprog CLEAR_BVRFIELDS()
If dim([M:BIC1]BVRREFNUM) > 0
   Raz [M:BIC1]BVRREFNUM              # clear field
   If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
Endif
If dim([M:BIC1]PAYBAN) > 0
   Raz [M:BIC1]PAYBAN                 # clear field
   If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
Endif
End



######################################################################################################
Subprog CALC_BVRFIELDS(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR

If !GIMPORT                      # calculate ISR number and paying bank only if not in import
   Call CALC_BVRFIELDS(FCY, INVTYP, PTE, BPRPAY,CUR) From SUBSIHSWI
   [M:BIC1]PAYBAN = [F:SIH]PAYBAN
   [M:BIC1]BVRREFNUM  = [F:SIH]BVRREFNUM
   Affzo [M:BIC1]PAYBAN
   Affzo [M:BIC1]BVRREFNUM
Endif
End


######################################################################################################
# Recurring invoices:
# Same as CALC_BVRFIELDS but the invoice is in [F:TSIH] not in [F:SIH].
# Therefore CALC_BVRFIELDS From SUBSIHSWI can't be used
######################################################################################################
Subprog CALC_BVRFIELDS_BATCH(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

    Gosub CHECK_SHOW From SUBSIHSWI
    If SHOW
       If [F:TSIH]AMTATI = 0 : SHOW = 0 : Endif  # no paying bank and ISR reference number if invoice amount = 0
    Endif
    GPOINT = "CALCBVRFIELDS" : Gosub ENTREE From EXEFNC                  # entry point to overwrite conditions for SHOW

    If SHOW
      If [F:TSIH]PAYBAN = ""                # paying bank not yet entered -> calculate it
         [F:TSIH]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
         # if paying bank is not found, display an error message
         If [F:TSIH]PAYBAN = ""
            GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
            GOK = 0 : GERR = 1 : End
         Endif
      Endif
      If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
      Call CONTROL_PAYBAN([F:CPY]CPY,FCY,[F:TSIH]PAYBAN) From SUBSIHSWI  # if paying bank determined -> do additional checks
      If mkstat = 2 : GOK = 0 : GERR = 1 : End : Endif

      [F:TSIH]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:TSIH]ACCDAT,[F:TSIH]NUM)
    Else
      Raz [F:TSIH]BVRREFNUM               # clear field
      Raz [F:TSIH]PAYBAN                  # clear field
    Endif
End


######################################################################################################
# Fixed Assets:
# Same as CALC_BVRFIELDS but the invoice is in [F:HEA] not in [F:SIH].
# Therefore CALC_BVRFIELDS From SUBSIHSWI can't be used
######################################################################################################
Subprog CALC_BVRFIELDS_FA(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

    Gosub CHECK_SHOW From SUBSIHSWI
    If SHOW
       If [F:HEA]AMTATI = 0 : SHOW = 0 : Endif    # no paying bank and ISR reference number if invoice amount = 0
    Endif
    GPOINT = "CALCBVRFIELDS" : Gosub ENTREE From EXEFNC                  # entry point to overwrite conditions for SHOW

    If SHOW
      If [F:HEA]PAYBAN = ""                # paying bank not yet entered -> calculate it
         [F:HEA]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
         # if paying bank is not found, display an error message
         If [F:HEA]PAYBAN = ""
            GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
            GOK = 0 : GERR = 1 : End
         Endif
      Endif
      If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
      Call CONTROL_PAYBAN([F:CPY]CPY,FCY,[F:HEA]PAYBAN) From SUBSIHSWI  # if paying bank determined -> do additional checks
      If mkstat = 2 : GOK = 0 : GERR = 1 : End : Endif

      [F:HEA]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:HEA]ACCDAT,[F:HEA]NUM)
    Else
      Raz [F:HEA]BVRREFNUM               # clear field
      Raz [F:HEA]PAYBAN                  # clear field
    Endif
End


#angre X3-132006
################################################################################
# Create entry in SWIQRC table
###############################################################################
Subprog CREATE_SWIQRC(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR

If !GIMPORT    # qr-code creation not for import
   Call CREATE_SWIQRC(FCY, INVTYP, PTE, BPRPAY,CUR) From SUBSIHSWI
Endif
End

#angre X3-132006
################################################################################
#Recurring invoices:
# Same as CREATE_SWIQRC but the invoice is in [F:TSIH] not in [F:SIH].
# Therefore CREATE_SWIQRC From SUBSIHSWI can't be used
###############################################################################
Subprog CREATE_SWIQRC_BATCH(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR

  Gosub CHECK_WRITE_QR From SUBSIHSWI

  If WRITQR
    If [F:TSIH]PAYBAN = ""                # paying bank not yet entered -> calculate it
     [F:TSIH]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
     # if paying bank is not found, display an error message
     If [F:TSIH]PAYBAN = ""
        GMESSAGE = mess(109,3648,1) # No paying bank for QR-data generation could be determined.
        GOK = 0 : GERR = 1 : End
     Endif
  Endif
  If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
  Call CONTROL_PAYBAN_QR([F:CPY]CPY,FCY,[F:TSIH]PAYBAN) From SUBSIHSWI # if paying bank determined -> do additional checks

  [F:TSIH]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:TSIH]ACCDAT,[F:TSIH]NUM)

  ERRCOD = func SWIQRCLIB3.CREATE_SWIQRC([F:TSIH]NUM, [F:TSIH]ORIMOD, [F:TSIH]AMTATI, [F:TSIH]CUR, [F:TSIH]FCY, [F:TSIH]BPRPAY, [F:TSIH]BPRNAM, [F:TSIH]BPAPAY, [F:TSIH]BVRREFNUM)
  If ERRCOD > 0: GOK = 0 : GERR = 1
    Case ERRCOD
      When 1 : GMESSAGE = mess(112,3648,1)
      When 2 : GMESSAGE = func AFNC.MES1( mess(113,3648,1), [F:TSIH]FCY)
      When 3 : GMESSAGE = func AFNC.MES1( mess(114,3648,1), [F:TSIH]FCY)
      When 4 : GMESSAGE = func AFNC.MES1( mess(115,3648,1), [F:TSIH]FCY)
      When 5 : GMESSAGE = func AFNC.MES1( mess(116,3648,1), [F:TSIH]BPRPAY)
      When 6 : GMESSAGE = func AFNC.MES1( mess(117,3648,1), [F:TSIH]FCY)
      When 7 : GMESSAGE = func AFNC.MES1( mess(118,3648,1), [F:TSIH]BPRPAY)
    Endcase
  Endif
  Endif
End


#angre X3-132006
################################################################################
#Fixed assets:
# Same as CREATE_SWIQRC but the invoice is in [F:HEA] not in [F:SIH].
# Therefore CREATE_SWIQRC From SUBSIHSWI can't be used
###############################################################################
Subprog CREATE_SWIQRC_FA(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR

  Gosub CHECK_WRITE_QR From SUBSIHSWI
  If WRITQR
      If [F:HEA]PAYBAN = ""                # paying bank not yet entered -> calculate it
         [F:HEA]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
         # if paying bank is not found, display an error message
         If [F:HEA]PAYBAN = ""
            # X3-140541 Bader begin
            #GMESSAGE = mess(59,3648,1) # No paying bank for QR-data generation could be determined.
            GMESSAGE = mess(109,3648,1) # No payment bank for QR data generation could be found
            # X3-140541 Bader end
            GOK = 0 : GERR = 1 : End
         Endif
      Endif
      If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
      Call CONTROL_PAYBAN_QR([F:CPY]CPY,FCY,[F:HEA]PAYBAN) From SUBSIHSWI # if paying bank determined -> do additional checks

      [F:HEA]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:HEA]ACCDAT,[F:HEA]NUM)

      ERRCOD = func SWIQRCLIB3.CREATE_SWIQRC([F:HEA]NUM, [F:HEA]ORIMOD, [F:HEA]AMTATI, [F:HEA]CUR, [F:HEA]FCY, [F:HEA]BPRPAY, [F:HEA]BPRNAM, [F:HEA]BPAPAY,[F:HEA]BVRREFNUM)
      If ERRCOD > 0: GOK = 0 : GERR = 1
        Case ERRCOD
          When 1 : GMESSAGE = mess(112,3648,1)
          When 2 : GMESSAGE = func AFNC.MES1( mess(113,3648,1), [F:HEA]FCY)
          When 3 : GMESSAGE = func AFNC.MES1( mess(114,3648,1), [F:HEA]FCY)
          When 4 : GMESSAGE = func AFNC.MES1( mess(115,3648,1), [F:HEA]FCY)
          When 5 : GMESSAGE = func AFNC.MES1( mess(116,3648,1), [F:HEA]BPRPAY)
          When 6 : GMESSAGE = func AFNC.MES1( mess(117,3648,1), [F:HEA]FCY)
          When 7 : GMESSAGE = func AFNC.MES1( mess(118,3648,1), [F:HEA]BPRPAY)
        Endcase
      Endif
  Endif
End

#angre X3-132006
################################################################################
# Remove entry from SWIQRC table
###############################################################################
Subprog REMOVE_SWIQRC()
Local Integer ERRCOD
   If int(val(func AFNC.PARAM("SWICUSQRC", [F:SIH]FCY))) = 2
    Call REMOVE_SWIQRC([F:SIH]NUM, [F:SIH]ORIMOD) From SWIQRCLIB3
   Endif
End

