#<AdxTL>@(#)146.0.0.0 $Revision$
$ACTION
Case ACTION
 When "TRT_DIV" : Gosub MONO_MULTI
Endcase
Return

$MONO_MULTI
Local Integer OK
Case PARAM(1)
 When "O"
  Call MONO(OK)
  If OK : Call MESSAGE(mess(151,124,1)) From GESECRAN : Endif : # Vous Ítes en mode mono-utilisateur
 When "U"
  Call MULTI(OK)
  If OK : Call MESSAGE(mess(152,124,1)) From GESECRAN : Endif : # Vous Ítes en mode multi-utilisateur
Endcase
End

Local Integer OK, ARRET
Call OUVRE_TRACE("") From LECFIC
Call MONOMOD(2,OK,ARRET)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Call MULTIMOD(2,ARRET)
End

###############################################
## Protection des utilitaires               ###
###############################################
Subprog MONOX3(MODULE,OK,ARRET)
Value    Integer MODULE
Variable Integer OK
Variable Integer ARRET

If GHYPER or GADONIX=2
 OK = 1 : ARRET = 0 : End
Endif

Case GLCKOPT
 When 1 : # Mono-utilisateur
  Call MONO(OK)
  ARRET = 0
 When 2 : # On s'en fout
  OK = 1 : ARRET = 0
 When 3 : # Mono-module
  Call MONOMOD(MODULE,OK,ARRET)
Endcase
End

###############################################
Subprog MULTIX3(MODULE,ARRET)
Value Integer MODULE
Value Integer ARRET
Local Integer OK
Case GLCKOPT
 When 1 : Call MULTI(OK)
 When 2 : # Rien
 When 3 : Call MULTIMOD(MODULE,ARRET)
Endcase
End

######################################################################################################
## Gestion du mode mono/multi sociÈtÈs
######################################################################################################
## Pose d'un verrou non exclusif sur une sociÈtÈ
######################################################################################################
Subprog LOCKCPY(SOC,OK)
Value    Char    SOC()
Variable Integer OK

Local Integer T
OK = 1
Gosub DEFVAR_CPY
If SOC="" : SOC = TOUSOC : Endif

## Verrou du symbole MONOCPY pour Ítre seul ‡ travailler dessus
T  = time
Repeat
 If time>T+lockwait : OK = 0 : Break : Endif
 Lock =MONOCPY
Until fstat=0
If !OK : Goto FIN_LOCKCPY : Endif

## VÈrif d'un lock exclusif
Lock =COMPTA+SOC
If fstat
 OK = 0 : Goto FIN_LOCKCPY
Else
 Unlock =COMPTA+SOC
Endif

## Pose d'un verrou non exclusif
GMONOCPY = COMPTA+SOC+VERROU
Lock =GMONOCPY
If fstat
 OK = 0 : Goto FIN_LOCKCPY
Endif

## LibÈration de MONOCPY
$FIN_LOCKCPY
Unlock =MONOCPY
If !OK
 Call ECR_TRACE(mess(216,126,1)-SOC,1) From GESECRAN
 # Impossible de travailler sur la sociÈtÈ
Endif
End

######################################################################################################
## LibÈration du verrou non exclusif sur une sociÈtÈ
######################################################################################################
Subprog UNLOCKCPY()
Unlock =GMONOCPY
End

$DEFVAR_CPY
Local Char MONOCPY(10) , COMPTA(10) , VERROU(20) , TOUSOC(GLONCPY)
MONOCPY = "MONOCPY"
COMPTA  = "CPTA\"
VERROU  = "\"+num$(adxuid(2))
TOUSOC  = "xxxxx"
Return

######################################################################################################
## Pose d'un verrou exclusif sur une societe
######################################################################################################
Subprog MONOCPY(SOC,OK)
Value    Char    SOC()
Variable Integer OK

If GHYPER
 OK = 1 : End
Endif

Local Integer ISOC , JSOC , T

If clalev([F:ALK])=0 : Local File APLLCK [ALK] : Endif

Gosub DEFVAR_CPY
OK = 1

## Verrou du symbole MONOCPY pour Ítre seul ‡ travailler dessus

T  = time
Repeat
 If time>T+lockwait : OK = 0 : Break : Endif
 Lock =MONOCPY
Until fstat=0
If !OK : Goto FIN_MONOCPY : Endif

## VÈrif qu'il n'y a pas de lock exclusif ou non sur "toutes sociÈtÈs"

For [ALK] Where pat(LCKSYM,COMPTA+TOUSOC+"*")<>0
 Lock =[F:ALK]LCKSYM
 If fstat
  OK = 0 : Break
 Endif
 Unlock =[F:ALK]LCKSYM
Next
If !OK : Goto FIN_MONOCPY : Endif

## VÈrif qu'il n'y a pas de lock non exclusif sur la sociÈtÈ demandÈe

If SOC=""
 For [ALK] Where pat(LCKSYM,COMPTA+"*")<>0
  Lock =[F:ALK]LCKSYM
  If fstat
   OK = 0 : Break
  Endif
  Unlock =[F:ALK]LCKSYM
 Next
Else
 For [ALK] Where pat(LCKSYM,COMPTA+SOC+"*")<>0
  Lock =[F:ALK]LCKSYM
  If fstat
   OK = 0 : Break
  Endif
  Unlock =[F:ALK]LCKSYM
 Next
Endif
If !OK : Goto FIN_MONOCPY : Endif

## Pose d'un verrou exclusif sur la sociÈtÈ (ou toutes)

If SOC=""
 For ISOC=1 To GNBSOC
  Lock =COMPTA+GSOC(ISOC)
  If fstat
   For JSOC=1 To ISOC-1
    Unlock =COMPTA+GSOC(JSOC)
   Next JSOC
   OK = 0
   Break
  Endif
 Next ISOC
 If !OK : Goto FIN_MONOCPY : Endif
Else
 Lock =COMPTA+SOC
 If fstat : OK = 0 : Goto FIN_MONOCPY : Endif
Endif
Lock =COMPTA+TOUSOC
If fstat : OK = 0 : Goto FIN_MONOCPY : Endif

# LibÈration de MONOCPY
$FIN_MONOCPY
Unlock =MONOCPY
If !OK
 Call ECR_TRACE(mess(217,126,1)-SOC,1) From GESECRAN
 # Impossible de poser un verrou exclusif sur la sociÈtÈ
Endif
End

################################################
## Repassage en multisociÈtÈ
################################################
Subprog MULTICPY(SOC)
Value Char SOC()

Local Integer ISOC
Gosub DEFVAR_CPY
Unlock =COMPTA+TOUSOC
If SOC=""
 For ISOC=1 To GNBSOC
  Unlock =COMPTA+GSOC(ISOC)
 Next ISOC
Else
 Unlock =COMPTA+SOC
Endif
End

###############################################
## Passage en Mono / Multi                  ###
###############################################
Subprog MONO(OK)
Variable Integer OK
If GHYPER or GADONIX=2
 OK = 1 : End
Endif
Goto MONO_

####################################################################################################
Subprog MONOSUP(OK) : #  (‡ n'utiliser que pour la t‚che INIDICO qui rend le dossier inexploitable)
Variable Integer OK
####################################################################################################

$MONO_
Local File ADOVAL  [ADW]
Local File AUTILIS [AUS]

Lock MONO
If fstat=1
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN : Goto FIN_MONO
Endif

OK = 0
#107271
Local Integer MONO
Local Char WCHMONO(50)
#Read [ADW]ADW0 = "";"";"MONO"
#MONO = val([F:ADW]VALEUR)
Local Integer ISHISTFOLD
ISHISTFOLD=func DOSSUB.ISHISTFOLD(nomap)
If ISHISTFOLD
 Call GETPARHIS(nomap,"MONO",WCHMONO) From SUBADS
Else
 Call GETPAR(nomap,"MONO",WCHMONO) From SUBADS
Endif
MONO=val(WCHMONO)
If MONO>0
 Case MONO
  When 2       : Call ECR_TRACE(mess(146,124,1),1) From GESECRAN : # Modification du dossier en cours
  When 3       : Call ECR_TRACE(mess(147,124,1),1) From GESECRAN : # Sauvegarde
  When 4       : Call ECR_TRACE(mess(148,124,1),1) From GESECRAN : # RÈcup.
  When 5       : Call ECR_TRACE(mess(149,124,1),1) From GESECRAN : # R.A.Z.
  When Default : Call ECR_TRACE(mess(153,100,1),1) From GESECRAN : # Autres cas non rÈpertoriÈs
 Endcase
 Goto FIN_MONO
Endif

Local Char    LISTE(10)
Local Integer NBUSR
Call USER_LISTE(nomap,NBUSR,LISTE) From PSADX
If NBUSR>1
#If nbruser>1
 Call ECR_TRACE(nomap-mess(150,124,1)-num$(NBUSR),1) From GESECRAN : # Nombre d'utilisateurs connectÈs
 Goto FIN_MONO
Endif
Call DEBTRANS From GLOCK
#107271
#Gosub TR_MONO
If ISHISTFOLD
 Call MAJPARHIS(nomap,"MONO","1") From SUBADS
Else
 Call MAJPAR(nomap,"MONO","1") From SUBADS
Endif
If GOK=1
 OK=1
Endif

$FIN_MONO
Unlock MONO
Close Local File
End

