#######################################################
## Passage en mono-compta
#######################################################
## Il faut vÈrifier:
##    dans EXFNC
##    au lancement d'une requÍte batch
##    dans le web (+ faire les setfct/setmdu)
##
#######################################################
Subprog MONOMOD(MODULE,OK,ARRET)
Value    Integer MODULE
Variable Integer OK
Variable Integer ARRET

Local Integer I , J , K
Local Integer T , STAT , NBUSR , FLBAT , NUMMOD
Local Char    LISTE(200)(1..500)
Local Char    TEXTE(50)
Local Char    ID(10) , USER(30) , DOSSIER(30) , FONCTION(30) , MODU(10),LOGIN(30)

## On verrouille aussi les modules dÈpendants

Gosub OUVRE

## Les chefs ont le droit de tout faire...
If GHYPER or GADONIX=2
 OK = 1 : ARRET = 0 : End
Endif

## Blocage de toutes les connexions
T = time
Repeat
 Lock "MONOA"
Until !fstat or time>T+10
If fstat : Goto RATE : Endif
OK = 1
For I=1 To NBMOD
 Lock ="MONOB"+format$("N0:2#",LISMOD(I))
 If fstat : OK = 0 : Break : Endif
Next I
Unlock "MONOA"
If !OK : Gosub DELOCK : Goto RATE : Endif

## VÈrif si des utilisateurs se servent du module
Local Char SID(12)(1..) , SCLI(80)(1..) , SDOS(80)(1..) , SFCT(20)(1..) , SMOD(10)(1..)
Local Integer  NBSES,ISES
If func ASESSIONS.ISMNGSESSIONS
  Call USER_MODULE(SID,SCLI,SDOS,SFCT,SMOD,NBSES) From ASESSIONS
Else
 Local File (SID,SCLI,SDOS,SFCT,SMOD) From System adxmac(0)+"@psadx -fmo" As [SYS_] Where [SYS_]SID<>num$(adxuid(1))
 For [SYS_]
  NBSES+=1
  SID(NBSES) = num$([F:SYS_]IDSESSION)
  SCLI(NBSES) = [F:SYS_]USER
  SDOS(NBSES) = [F:SYS_]DOSSIER
  SFCT(NBSES) = [F:SYS_]FCT
  SMOD(NBSES) = num$([F:SYS_]MODU)
 Next SYS_
 Close Local File [SYS_]
Endif
For ISES=1 To NBSES
 If [L]SDOS(ISES)=nomap
  USER     = [L]SCLI(ISES)
  FONCTION = [L]SFCT(ISES)
  MODU     = [L]SMOD(ISES)
  If FONCTION=""
   NUMMOD = val(MODU)
   Call GET_CURFCT(adxmac(0),"",[L]SID(ISES),FONCTION,NUMMOD,LOGIN) From PSADX
   MODU = num$(NUMMOD)
  Endif
  If FONCTION<>"" & MODU<>"" & find(val(MODU),LISMOD(1..NBMOD))
   Read [AFC]CODINT = FONCTION
   If !fstat & [F:AFC]MONO<>2
    If OK=1
     Call ECR_TRACE(mess(35,130,1),0) From GESECRAN : # Utilisateurs connectÈs
     OK = 0
    Endif
    Call TEXTE([F:AFC]NOM,TEXTE) From OBJDIV
    Call ECR_TRACE(USER-":"-FONCTION-TEXTE,0) From GESECRAN
   Endif
  Endif
 Endif
Next
If !OK
 Gosub DELOCK
 Goto RATE
Endif

## VÈrif si des batchs tournent

If GSERVEUR
 #109897
 #Filter [ABR] Where DOSSIER=nomap & FLAG=2 & NUMREQ<>val(getenv$("RQT_ENTREP"))
 Filter [ABR] Where DOSSIER=nomap & FLAG=2 & NUMREQ<>val(GBATCHRQT)
Else
 Filter [ABR] Where DOSSIER=nomap & FLAG=2
Endif
For [ABR]NUMREQ
 Read [ABT]CODTAC = [F:ABR]TACHE
 If !fstat & [F:ABT]FONCTION<>""
  Read [AFC]CODINT = [F:ABT]FONCTION
  If !fstat & find([F:AFC]MODULE,LISMOD(1..NBMOD))
   If OK=1
    Call ECR_TRACE(mess(77,134,1),0) From GESECRAN : # T‚ches batchs en cours
    OK = 0
   Endif
   Call TEXTE([F:AFC]NOM,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ABR]USER-":"-[F:AFC]CODINT-TEXTE,0) From GESECRAN
  Endif
 Endif
Next
Filter [ABR]
If !OK
 Gosub DELOCK
 Goto RATE
Endif

## ArrÍt Èventuel de la t‚che compta
# X3-59028 - 2018-02-22 JPGA - Accounting_Task has been removed and managed like other Batch task
# X3-59028 - Code removed
End

$DELOCK
For I=1 To NBMOD
 Unlock ="MONOB"+format$("N0:2#",LISMOD(I))
Next I
Return

$RATE
Call ECR_TRACE(mess(31,134,1),1) From GESECRAN : # Passage en mono impossible
OK = 0
ARRET = 0
End

$OUVRE
Local Char    TACHE(10) , ACCBATCH(10)
Local Integer NBMOD , LISMOD(1..10)

NBMOD = 0
NBMOD += 1 : LISMOD(NBMOD) = MODULE

Case MODULE
 When 2 : # Compta
  NBMOD += 1 : LISMOD(NBMOD) = 3 : # Tiers
  NBMOD += 1 : LISMOD(NBMOD) = 4 : # Immos
  TACHE    = "ACCENTRY"
  ACCBATCH = "ACCBATCH"
  If clalev([F:BTC])=0 : Local File BATCH     [BTC] : Endif
Endcase

If clalev([F:ABP])=0 : Local File ABATPAR   [ABP] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT   [ABR] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC   [ABT] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL  [ABL] : Endif
Return

###############################################
## Repassage en multi
###############################################
Subprog MULTIMOD(MODULE,ARRET)
Value Integer MODULE
Value Integer ARRET

Local Integer I

Gosub OUVRE

## Autorisation des connexions

For I=1 To NBMOD
 Unlock ="MONOB"+format$("N0:2#",LISMOD(I))
Next I

## RedÈmarrage t‚che compta

If ARRET & find(2,LISMOD(1..NBMOD))
 Call ECR_TRACE(mess(123,126,1),0) From GESECRAN : # DÈmarrage de la t‚che de validation comptable
 Call DEBTRANS From GLOCK
 Gosub TR4 From CPTBATCH
Endif

End

