#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################
## Subprog CREECHE(TYPTIERS,RELEVE,RELANCE,BONAPAY)
## Subprog ECHEANCE(TYPTIERS,NUMERO,OK)
## Subprog MODECHE(TYPTIERS,NUMERO,MONTANT,MAJFAC,OK)
## Subprog INFOECHE(TYPTIERS,NUMERO,MONTMIN,MONTPRO)
######################################################
# Issue X3-219553 - 2020-15-10 by MRDAB - error when running Account schema header on GESBIS - COUZON not available in the context
# X3-210494 2020-09-16 Bader: SETCOUR: take into account DECRCU parameter for currency rate
# Issue X3-205959 - 2020-09-08 by MRDAB/MAPON: fixed inconsistency between Pay-to/Pay-by vs Address vs Bank account also for import/export templates
# Issue X3-133919 - 2020-07-03 by FHA : VCS field in DUD for XX5A add-on
# Issue X3-195162, X3-195181, X3-195182, X3-195185 - 2020-06-23 by MRDAB/MAPON : Defualt bank account at the invoice level - on open item
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#*X3-112211  SMO  Implement control when reading parameters managed by activity code
# X3-125815 2019-03-11 Bader: DEBUT for GACTION "SAITAX5": disable local tax fields if existing
#                             CALTVA for GACTION "SAITAX5": call CALTAXE with parameter TYPBASE = 2 instead of 1 (for amount + tax)

Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "1"
PARAM(2) = "FCADX09VENTE008"
Call SAISIE_CHAR(VALEUR,PARAM,"FBPCDUD","SUBBIH","") From GSAISIE
End

Local Integer OK
Call ECHEANCE(1,"ADX804/00000001",OK)
End

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub ENREG
 When "END"         : Gosub FIN
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE # Issue X3-195162, X3-195181 by MRDAB/MAPON
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When Default
Endcase
Return

########################
$OUVRE
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif
Local Integer NOL
NOL = nolign-1
Case GACTION
 When "SAIECHBIC", "SAIECHBIS" : Gosub OUVR_ECH
Endcase
Local Char OLDVAT(GLONVAT)
Return

########################
$DEBUT
nolign=NOL+1
Case GACTION
 When "SAITAX" :
  [M:BIHT]       = [M:BIC3]
  [M:BIHT]BASE   = [M:BIC3]AMTNOTLIN(nolign-1)
  [M:BIHT]CPY    = [M:BIC0]CPY
  [M:BIHT]ACCDAT = [M:BIC0]ACCDAT
  [M:BIHT]CUR    = [M:BIC1]CUR
  [M:BIHT]DEP    = [M:BIC1]DEP
 When "SAITAX2" :
  [M:BIHT]       = [M:BIS3]
  [M:BIHT]BASE   = [M:BIS3]AMTNOTLIN(nolign-1)
  [M:BIHT]CPY    = [M:BIS0]CPY
  [M:BIHT]ACCDAT = [M:BIS0]ACCDAT
  [M:BIHT]CUR    = [M:BIS1]CUR
  [M:BIHT]DEP    = [M:BIS1]DEP
 When "SAITAX5" :
  [M:BIHT]       = [M:EXS0]
  [M:BIHT]VAT    = VALEUR
  [M:BIHT]BASE   = [M:EXS0]AMTATI(nolign-1)
  [M:BIHT]CPY    = [M:EXS0]CPY(nolign-1)
  [M:BIHT]ACCDAT = [M:EXS0]DATEXS(nolign-1)
  [M:BIHT]CUR    = [M:EXS0]CUR(nolign-1)
# X3-125815 2019-03-08 Bader begin hide fields not relevant for Expense entry
  If func AFNC.ACTIV("PTX")
      Diszo [M:BIHT]TAXRCP
      Diszo [M:BIHT]TAXISS
      Diszo [M:BIHT]TAXOTH1
      Diszo [M:BIHT]TAXOTH2
      Diszo [M:BIHT]AMTTAXRCP
      Diszo [M:BIHT]AMTTAXISS
      Diszo [M:BIHT]AMTTAXOTH1
      Diszo [M:BIHT]AMTTAXOTH2
      Diszo [M:BIHT]DEDTAXRCP
      Diszo [M:BIHT]DEDTAXISS
      Diszo [M:BIHT]DEDTAXOTH1
      Diszo [M:BIHT]DEDTAXOTH2
  Endif
# X3-125815 2019-03-08 Bader end

 When "BIHPER" :
  If dim([M:BIC3]NBLIG)>0    : # Factures tiers clients
   [M:BIHP] = [M:BIC3]
   If dim([M:BIHP]PERTYP)>0 & [M:BIHP]PERTYP=0 : [M:BIHP]PERTYP=1 : Endif
   If dim([M:BIHP]PERNBR)>0 & [M:BIHP]PERNBR=0 : [M:BIHP]PERNBR=1 : Endif
   ## Demande 57063 : dans le cadre des CCA/PCA, pouvoir accéder aux périodes de prestation męme si la facture est validée.
   ## Par ailleurs, on rend inaccessible les champs liés ŕ la périodicité si on est dans le cas de CCA/PCA (paramčtre ITAPRE="Non")
   # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
   If [M:BIC1]STA = 3 & func AFNC.PARAM("SVCFLG",[M:BIC0]CPY)="2" : Grizo [M:BIHP]   : Endif
   If func AFNC.PARAM("SVCFLG",[M:BIC0]CPY)="1" : Grizo [M:BIHP]PERNBR, PERTYP : Endif
   # End issue X3-199974
  Elsif dim([M:BIS3]NBLIG)>0 : # Factures tiers fournisseurs
   [M:BIHP] = [M:BIS3]
   If dim([M:BIHP]PERTYP)>0 & [M:BIHP]PERTYP=0 : [M:BIHP]PERTYP=1 : Endif
   If dim([M:BIHP]PERNBR)>0 & [M:BIHP]PERNBR=0 : [M:BIHP]PERNBR=1 : Endif
   ## Demande 57063 : dans le cadre des CCA/PCA, pouvoir accéder aux périodes de prestation męme si la facture est validée
   ## Par ailleurs, on rend inaccessible les champs liés ŕ la périodicité si on est dans le cas de CCA/PCA (paramčtre ITAPRE="Non")
   # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
   If [M:BIS1]STA = 3 & func AFNC.PARAM("SVCFLG",[M:BIS0]CPY)="2" : Grizo [M:BIHP]   : Endif
   If func AFNC.PARAM("SVCFLG",[M:BIS0]CPY)="1" : Grizo [M:BIHP]PERNBR, PERTYP : Endif
   # End issue X3-199974
  Elsif dim([M:SIH4]NBLIG)>0 : # Factures ventes
   [M:BIHP] = [M:SIH4]
   If dim([M:BIHP]PERTYP)>0 & [M:BIHP]PERTYP=0 : [M:BIHP]PERTYP=1 : Endif
   If dim([M:BIHP]PERNBR)>0 & [M:BIHP]PERNBR=0 : [M:BIHP]PERNBR=1 : Endif
   If [M:SIH1]INVSTA = 3 : Grizo [M:BIHP] : Endif
  Elsif dim([M:PIH3]NBLIG)>0 : # Factures d'achat
   [M:BIHP] = [M:PIH3]
   If dim([M:BIHP]PERTYP)>0 & [M:BIHP]PERTYP=0 : [M:BIHP]PERTYP=1 : Endif
   If dim([M:BIHP]PERNBR)>0 & [M:BIHP]PERNBR=0 : [M:BIHP]PERNBR=1 : Endif
   If [M:PIH1]STA = 3  : Grizo [M:BIHP]   : Endif
  Endif
 When "SAIECHBIC", "SAIECHBIS" :
   Affzo [M]
   Gosub DEBUT_ECH
Endcase
Affzo [M]
Return

########################
$ENREG
nolign=NOL+1    # Bugs 8951 et 16576
Case GACTION
 When "SAITAX" :
   [M:BIC3] = [M:BIHT]
   VALEUR = [M:BIHT]VAT
   mkstat = 4
 When "SAITAX2" :
   [M:BIS3] = [M:BIHT]
   VALEUR = [M:BIHT]VAT
   mkstat = 4
 When "SAITAX5"
   [M:EXS0] = [M:BIHT]
   VALEUR = [M:BIHT]VAT
   mkstat = 4
 When "BIHPER" :
   If dim([M:BIC3]NBLIG)>0    : # Factures tiers clients
    [M:BIC3] = [M:BIHP]
    # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
    If [M:BIC1]STA = 3 & func AFNC.PARAM("SVCFLG",[M:BIC0]CPY)="2" : mkstat = 2
    # End issue X3-199974
    Else : mkstat = 4
    Endif
   Elsif dim([M:BIS3]NBLIG)>0 : # Factures tiers fournisseurs
    [M:BIS3] = [M:BIHP]
    # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
    If [M:BIS1]STA = 3 & func AFNC.PARAM("SVCFLG",[M:BIS0]CPY)="2" : mkstat = 2
    # End issue X3-199974
    Else : mkstat = 4
    Endif
   Elsif dim([M:SIH4]NBLIG)>0 : # Factures ventes
    [M:SIH4] = [M:BIHP] : Affzo [SIH4]1-99
    If [M:SIH1]INVSTA <> 3 : mkstat = 4 : [M:SIH4]UPDFLG(nolign-1)=1 : Endif
   Elsif dim([M:PIH3]NBLIG)>0 : # Factures d'achat
    [M:PIH3] = [M:BIHP] :  : Affzo [PIH3]1-99
    If [M:PIH1]STA <> 3    : mkstat = 4 : [M:PIH3]UPDFLG(nolign-1)=1 : Endif
   Endif
 When "SAIECHBIC", "SAIECHBIS" :
   Gosub ENREG_ECH
   mkstat = 4
Endcase
Return


########################
$FIN
Case GACTION
 When "SAIECHBIC", "SAIECHBIS" : Unlock =SYMBOLE
Endcase
Return


########################
$SEL_TABLE
Case TABLE
 When "SELSCHEMA"  : Gosub S_SCHEMA
Endcase
# Issue X3-195162 by MRDAB/MAPON
If dim(COUZON) <> -1 # Issue X3-219553 by MRDAB
  Case COUZON
   When "BIDNUM"     : Gosub S_BIDNUM # Bank account selection
  Endcase
Endif
# Issue X3-195162 end
Return

$S_SCHEMA
OBJET = "GDA"
VALEUR = 1
START = "NUMLIG"
Return

########################
$VERF_TABLE
If TABLE = "SELSCHEMA" # Issue X3-195162 by MRDAB/MAPON
  SCHEMA = [F:GDA]DIA
  If SCHEMA<>""
   If dim([M:BIC3]NBLIG)>0
    Gosub SCHEMA From SUBBIC3
   Elsif dim([M:BIS3]NBLIG)>0
    Gosub SCHEMA From SUBBIS3
   Endif
  Endif
Endif # Issue X3-195162 by MRDAB/MAPON
Return

########################
$SEL_LISTE
Case LISTE
 When "SELFRQACC" : Gosub S_FRQACC
Endcase
Return

$S_FRQACC
Local Integer I
TIT = mess(50,106,1)  : # Comptes fréquents
If clalev([F:JCO])=0 : Local File GJOUCOA [JCO] : Endif
Call LEC_JCO_LEG(GCURLEG,PARAM(1),PARAM(2)) From CPTLEC
NBTEX = 0
For I=0 To [F:JCO]FRQNBR-1
 NBTEX += 1
 TEX(NBTEX)   = [F:JCO]FRQACC(I)
 TEXTE(NBTEX) = [F:JCO]FRQCOD(I)-[F:JCO]FRQACC(I)
Next I
Return

########################################################################
$OUVR_ECH
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Local Integer TYPTIERS
Local Char    NUMERO(GLONVCR), TYPPCE(GLONGTE)
TYPTIERS = val(PARAM(1))
NUMERO = PARAM(2)
Local Integer CALL_PT : Raz CALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("SUBBIH",GENTSTD(1..GNBENTREE))
 CALL_PT=1
Endif
Return

$DEBUT_ECH
If dim([M:DUD1]UMRNUM)>0
 #X3-112211
 #If func AFNC.PARAM("SDDMGT", GSOCIETE) = "2"
 If func AFNC.ACTIV("SDD") &  func AFNC.PARAM("SDDMGT", GSOCIETE) = "2"
 #END X3-112211
  Chgfmt [M:DUD1]UMRNUM With "K:"+num$(type([M:DUD1]UMRNUM)-10)
 Else
  Chgfmt [M:DUD1]UMRNUM With "-K:"+num$(type([M:DUD1]UMRNUM)-10)
 Endif
Endif

LCK = 1
Gosub CHARGECH
## CP : habilitations boutons
If GCONSULT=1
 Grizo [M]
Endif
If OK<0
 # Modification en cours sur un autre poste
 Call ERREUR(mess(10,100,1)) From GESECRAN
Endif
If OK<1 : FIN=1 : Endif
Return

$ENREG_ECH
If sum([M]AMTCUR(0..[M]NBECH-1))<>[M]AMTTOT
 # Total des échéances incorrect
 Call ERREUR(mess(24,119,1)) From GESECRAN
 FIN=0 : Return : # pour rester en saisie
Endif
If [M]AMTTOT=0 & NBECH=1 & [M]AMTCUR(0)=0
 # 81313
 FIN=1 : Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : FIN=0
Else : Unlock =SYMBOLE
Endif
Return

$CHARGECH
Local Char    DEVLED(GLONCUR)
Local Char    CODLED(GLONLED)
Local Decimal TOTAL, COURS
Local Decimal RATDIV, RATMLT
Local Date    DATCPT, DATEVT
Local Integer TYPCOURS, STAT, LIGECH, NUMECH, ETAT, LIGPCE, NOL, MODIF
Local Char    DEVISE(GLONCUR), SITE(GLONFCY), SYMBOLE(30)
Local Char    FLTDUD(250)
Local Tinyint TEMP_FSTAT # Issue X3-195162 by MRDAB/MAPON
Local Tinyint LSTA       # Issue X3-195185 by MRDAB/MAPON

OK = 1
MODIF = 0
If TYPTIERS=1
 Local Mask BPCDUD [DUD1]
 If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
 Read [SIH]SIH0 = NUMERO
 If fstat : OK = 0 : Return : Endif
 # AUREN - 05.793.474 - Total en negatiu si abonament
 # TOTAL    = [F:SIH]AMTATI
 If [F:SIH]INVTYP = 2
    TOTAL = [F:SIH]AMTATI * -1
 Else
    TOTAL = [F:SIH]AMTATI
 Endif 
 DEVISE   = [F:SIH]CUR
 Call GETSOC([F:SIH]FCY) From DEVSUB
 If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:SIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
  OK = 0 : Return
 Endif
 TYPCOURS = [F:SIH]CURTYP
 RATDIV   = [F:SIH]RATDIV(GTYPGEN-1)
 RATMLT   = [F:SIH]RATMLT(GTYPGEN-1)
 DATCPT   = [F:SIH]RATDAT
 If DATCPT=[0/0/0]
  DATCPT   = [F:SIH]ACCDAT
 Endif
 DATEVT   = [F:SIH]ACCDAT
 SITE     = [F:SIH]FCY
 NUMECH   = [F:SIH]ACCNUM
 ETAT     = [F:SIH]STA
 SYMBOLE = "HAE"+[F:SIH]NUM+"\"+[F:SIH]GTE
Else
 Local Mask BPSDUD [DUD1]
 If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
 Read [PIH]PIH0 = NUMERO
 If fstat : OK = 0 : Return : Endif
 # AUREN - 05.793.474 - Total en negatiu si abonament
 # TOTAL    = [F:PIH]AMTATI
 If [F:PIH]INVTYP = 2
    TOTAL = [F:PIH]AMTATI * -1
 Else
    TOTAL    = [F:PIH]AMTATI
 Endif
 DEVISE   = [F:PIH]CUR
 Call GETSOC([F:PIH]FCY) From DEVSUB
 If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:PIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
  OK = 0 : Return
 Endif
 TYPCOURS = [F:PIH]CURTYP
 RATDIV   = [F:PIH]RATDIV(GTYPGEN-1)
 RATMLT   = [F:PIH]RATMLT(GTYPGEN-1)
 DATCPT   = [F:PIH]RATDAT
 If DATCPT=[0/0/0]
  DATCPT   = [F:PIH]ACCDAT
 Endif
 DATEVT   = [F:PIH]ACCDAT
 SITE     = [F:PIH]FCY
 NUMECH   = [F:PIH]ACCNUM
 ETAT     = [F:PIH]STA
 SYMBOLE  = "HAE"+[F:PIH]NUM+"\"+[F:PIH]GTE
Endif
If LCK
 Lock =SYMBOLE
 If fstat : OK=-1 : Return : Endif
Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:BID])=0 : Local File BID        [BID] : Endif # Issue X3-195162 by MRDAB/MAPON
Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Raz [M:DUD1]
nolign = 0
Raz [L]FLTDUD
If dim(CALL_PT)>0 & CALL_PT=1 : GPOINT = "FLTDUD" : Gosub ENTREE From EXEFNC : Endif
If [L]FLTDUD="" : [L]FLTDUD="ACCNUM="+num$(NUMECH) : Endif
# Issue X3-195162, X3-195181, X3-195182 by MRDAB/MAPON
Case GFONCTION
 When "GESBIS" : Default Mask [M:BIS1] : [L]LSTA = [M]STA
 When "GESPIH" : Default Mask [M:PIH1] : [L]LSTA = [M]STA
 When "GESBIC" : Default Mask [M:BIC1] : [L]LSTA = [M]STA
 When "GESSIH" : Default Mask [M:SIH1] : [L]LSTA = [M]INVSTA
 When Default
Endcase
# Issue X3-195162, X3-195181, X3-195182 end
For [F:DUD]DUD1 Where evalue(FLTDUD)
 nolign += 1
 [M:DUD1] = [F:DUD]
 If nolign=1
  [M:DUD1]DUDCUR = [F:DUD]CUR
  LIGPCE = [F:DUD]LIG
 Endif
 # Griser le code adr payeur si le tiers est de type divers. Si le tiers est de type normal, le code adresse est grisé
 # si échéance dans le circuit de paiement
 If clalev([M:BIC1])>0
  Call LEC_BPC([M:BIC1]BPRPAY) From CPTLEC
  If [F:BPC]BPCTYP = 2
   Grizo [M:DUD1]BPAPAY(nolign-1)
  Else
   If [F:DUD]FLGCLE=2 | [F:DUD]FLGCLE=4
    Grizo [M:DUD1]BPRPAY(nolign-1) # Issue X3-205959 by MRDAB/MAPON
    Grizo [M:DUD1]BPAPAY(nolign-1)
   Else
    Actzo [M:DUD1]BPRPAY(nolign-1) # Issue X3-205959 by MRDAB/MAPON
    Actzo [M:DUD1]BPAPAY(nolign-1)
   Endif
  Endif
 Elsif clalev([M:BIS1])>0
  Call LEC_BPS([M:BIS1]BPRPAY) From CPTLEC
  If [F:BPS]BPSTYP = 3
   Grizo [M:DUD1]BPAPAY(nolign-1)
  Else
   If [F:DUD]FLGCLE=2 | [F:DUD]FLGCLE=4
    Grizo [M:DUD1]BPRPAY(nolign-1) # Issue X3-205959 by MRDAB/MAPON
    Grizo [M:DUD1]BPAPAY(nolign-1)
   Else
    Actzo [M:DUD1]BPRPAY(nolign-1) # Issue X3-205959 by MRDAB/MAPON
    Actzo [M:DUD1]BPAPAY(nolign-1)
   Endif
  Endif
 Endif

 # Issue X3-195162, X3-195181, X3-195182 by MRDAB/MAPON
 If [F:DUD]BIDNUMMAN <> ""
  [M:DUD1]BIDNUM(nolign-1) = [F:DUD]BIDNUMMAN
  Read [F:BID]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;[F:DUD]BPAPAY
  If fstat
     Read [F:BID]BID0 = 1;[F:DUD]BPRPAY;[F:DUD]BIDNUMMAN;""
     If fstat
      [L]TEMP_FSTAT = fstat
      [M:DUD1]BIDCRY(nolign-1) = func GET_CRY_FROM_ADDRESS([F:DUD]BPRPAY, [F:DUD]BPAPAY)
      fstat = [L]TEMP_FSTAT
      [M:DUD1]PAB(nolign-1) = ""
      [M:DUD1]IBAN(nolign-1) = ""
     Endif
  Endif
  If !fstat
    [M:DUD1]BIDCRY(nolign-1) = [F:BID]CRY
    [M:DUD1]PAB(nolign-1) = [F:BID]PAB1
    [M:DUD1]IBAN(nolign-1) = ""
    If [F:BID]IBAN <> ""
       [M:DUD1]IBAN(nolign-1) = [F:BID]IBAN + [F:BID]BIDNUM
    Endif
  Endif
 Else
  For [F:BID]BID2 Where [F:BID]BPATYP = 1 and [F:BID]BPANUM = [F:DUD]BPRPAY and [F:BID]BPAADD = [F:DUD]BPAPAY and [F:BID]BIDNUMFLG = 2
   [M:DUD1]BIDCRY(nolign-1) = [F:BID]CRY
   [M:DUD1]BIDNUM(nolign-1) = [F:BID]BIDNUM
   [M:DUD1]PAB(nolign-1) = [F:BID]PAB1
   [M:DUD1]IBAN(nolign-1) = ""
   If [F:BID]IBAN <> ""
    [M:DUD1]IBAN(nolign-1) = [F:BID]IBAN + [F:BID]BIDNUM
   Endif
  Next
  If [M:DUD1]BIDCRY(nolign-1) = ""
   [M:DUD1]BIDCRY(nolign-1) = func GET_CRY_FROM_ADDRESS([F:DUD]BPRPAY, [F:DUD]BPAPAY)
  Endif
 Endif

 If find(GFONCTION,'GESBIS','GESPIH','GESBIC','GESSIH')
  If dim([M:DUD1]UMRNUM)>0 and func AFNC.ACTIV("SDD") and  func AFNC.PARAM("SDDMGT", GSOCIETE) = "2" and [M:DUD1]UMRNUM(nolign-1) <> ""
    Grizo [M:DUD1]BIDNUM(nolign-1)
  Else
    Actzo [M:DUD1]BIDNUM(nolign-1)
  Endif
 Endif

Next
Default Mask [M:DUD1]
# Issue X3-195162, X3-195181, X3-195182 end

[M:DUD1]PAYTOT = sum([M:DUD1]PAYCUR(0..nolign-1))+sum([M:DUD1]TMPCUR(0..nolign-1))
# AUREN - 05.793.474 - El total pot ser negatiu si factura es d'abonament, es comenta la línea
# If TOTAL<0 & [M:DUD1]AMTCUR(0)>0 : TOTAL=abs(TOTAL) : Endif
[M:DUD1]AMTTOT = TOTAL
[M:DUD1]NBECH = nolign
Sorta [M:DUD1]NBECH [M:DUD1]NBECH Order By [M:DUD1]DUDDAT(indice),[M:DUD1]DUDLIG(indice)
Return


######################################################
## Saisie des échéances d'une facture               ##
######################################################
Subprog ECHEANCE(TYPTIERS,NUMERO,OK)
Value    Integer TYPTIERS
Value    Char    NUMERO
Variable Integer OK
Local Integer LCK
Local Char WIN(GLONFEN)
Local Char TYPPCE(GLONGTE)
Local Decimal EXERCICE, PERIODE
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
LCK = 1 : Gosub CHARGECH
If OK<0
 Call ERREUR(mess(10,100,1)) From GESECRAN
 End
Elsif !OK
 End
Endif

$SAIECH
If TYPTIERS = 1
 WIN = "DBPCDUD"
Else
 WIN = "DBPSDUD"
Endif
OK = 2 : Call DIALWIN(OK,mess(22,119,1),WIN) From GESECRAN
If OK=2
 If sum([M]AMTCUR(0..[M]NBECH-1))<>[M]AMTTOT
  Call ERREUR(mess(24,119,1)) From GESECRAN   # Total des échéances incorrect
  Goto SAIECH
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<1 : Goto SAIECH : Endif
Endif
Unlock =SYMBOLE
End

$TR1
GOK = 1
Trbegin [DUD], [HAE]
 Gosub VALECH
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub MODECR
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MODECR
# Mise ŕ jour de la date d'échéance de la pičce (16095)
If TYPTIERS=1
 If dim([M:BIC0]GTE)>0    : # Factures tiers clients
  TYPPCE = [M:BIC0]GTE
 Elsif dim([M:SIH0]GTE)>0 : # Factures ventes
  TYPPCE = [M:SIH0]GTE
 Endif
Elsif TYPTIERS=2
 If dim([M:BIS0]GTE)>0    : # Factures tiers fournisseurs
  TYPPCE = [M:BIS0]GTE
 Elsif dim([M:PIH0]GTE)>0 : # Factures d'achat
  TYPPCE = [M:PIH0]GTE
 Endif
Endif
If TYPPCE="" : Return : Endif
Readlock [HAE]HAE0=TYPPCE;NUMERO
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRY"-TYPPCE-NUMERO
 Return
Elsif !fstat
 [F:HAE]DUDDAT = max([M:DUD1]DUDDAT(0..[M:DUD1]NBECH-1))
 Rewrite [HAE]
 If fstat
  GOK = 0 : Call FSTA("HAE") From GLOCK
 Endif
Endif
Return


###############################################################
## Création des échéances d'une nouvelle facture             ##
###############################################################
Subprog CREECHE(TYPTIERS,RELEVE,RELANCE,BONAPAY)
Value Integer TYPTIERS
Value Integer RELEVE
Value Integer RELANCE
Value Integer BONAPAY
Local Integer MAXECH
MAXECH = 150
Local Shortint NBECH
Local Decimal  ECHMNT(1..MAXECH) , ECHLED(1..MAXECH)
Local Date     ECHDAT(1..MAXECH)
Local Integer  ECHSOI(1..MAXECH)
Local Char     ECHPAM(GLONTAM)(1..MAXECH)
Local Integer  ECHTYP(1..MAXECH)
Local Char     SITE(GLONFCY) , DEVISE(GLONCUR) , CNDPAY(20)
Local Date     DATDEP , DATCPT
Local Integer  TYPCOURS , STAT
Local Decimal  MONTANT, MONTHT, AROLED, EXERCICE, PERIODE
Local Decimal  RATDIV, RATMLT, COURS
Local Char     OLOCALDEV(GLONCUR)
Local Integer  IDEV
Local Date     DATEVT
Local Char     DEVLED(GLONCUR)
Local Char     CODLED(GLONLED)

# Issue X3-133919
Local Integer ACTIV_XX5A
[L]ACTIV_XX5A = func AFNC.ACTIV("XX5A")

# La classe [SIH] ou [PIH] doit ętre en ligne
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif

If GCOMPTA<>3
 If clalev([F:BPR])=0 : Local File =GTABCPT+"BPARTNER"   [BPR] : Endif
 If clalev([F:BPC])=0 : Local File =GTABCPT+"BPCUSTOMER" [BPC] : Endif
 If clalev([F:BPS])=0 : Local File =GTABCPT+"BPSUPPLIER" [BPS] : Endif
Endif

Case TYPTIERS
 When 1
  SITE     = [F:SIH]FCY
  DEVISE   = [F:SIH]CUR
  If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:SIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
   GOK = 0 : End
  Endif
  DATDEP   = [F:SIH]STRDUDDAT
  DATCPT   = [F:SIH]RATDAT
  If DATCPT=[0/0/0]
   DATCPT   = [F:SIH]ACCDAT
  Endif
  TYPCOURS = [F:SIH]CURTYP
  RATDIV   = [F:SIH]RATDIV(GTYPGEN-1)
  RATMLT   = [F:SIH]RATMLT(GTYPGEN-1)
  CNDPAY   = [F:SIH]PTE
  MONTANT  = [F:SIH]AMTATI
  MONTHT   = [F:SIH]AMTNOT
  DATEVT   = [F:SIH]ACCDAT
 When 2
  SITE     = [F:PIH]FCY
  DEVISE   = [F:PIH]CUR
  If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:PIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
   GOK = 0 : End
  Endif
  DATDEP   = [F:PIH]STRDUDDAT
  DATCPT   = [F:PIH]RATDAT
  If DATCPT=[0/0/0]
   DATCPT   = [F:PIH]ACCDAT
  Endif
  TYPCOURS = [F:PIH]CURTYP
  RATDIV   = [F:PIH]RATDIV(GTYPGEN-1)
  RATMLT   = [F:PIH]RATMLT(GTYPGEN-1)
  CNDPAY   = [F:PIH]PTE
  MONTANT  = [F:PIH]AMTATI
  MONTHT   = [F:PIH]AMTNOT
  DATEVT   = [F:PIH]ACCDAT
Endcase
Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Call LECTURE("TCU",DEVISE,"") From CONTOBJ
NBECH = 0
If CNDPAY<>""
 OLOCALDEV = GLOCALDEV
 GLOCALDEV = [F:CPY]ACCCUR
 #MAE, bg 73547, ajout du paramétre date du cours
 Call DATECHE_TVA(CNDPAY,DATDEP,MONTHT,MONTANT-MONTHT,[F:TCU]CURRND
& ,ECHPAM,ECHTYP,ECHMNT,ECHDAT,ECHSOI,NBECH,SITE,DATCPT)
& From SUBTPT
 GLOCALDEV = OLOCALDEV
Endif

If NBECH=0
 NBECH = 1
 ECHDAT(1) = DATDEP
 ECHMNT(1) = MONTANT
 ECHTYP(1)    = 1 : # Echéance
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 If TYPTIERS=1 : Call LEC_GTE_LEG([F:CPY]LEG,[F:SIH]GTE) From CPTLEC
 Else          : Call LEC_GTE_LEG([F:CPY]LEG,[F:PIH]GTE) From CPTLEC
 Endif
 If !fstat & [F:GTE]PAM<>""
  Call LEC_TAM([F:CPY]LEG,[F:GTE]PAM) From CPTLEC
  If !fstat & [F:TAM]ENAFLG=2 : ECHPAM(1) = [F:TAM]PAM : Endif
 Endif
 If ECHPAM(1)=""
  Filter [TAM] Where LEG=[F:CPY]LEG & ENAFLG=2
  Read [TAM]TAM0 First
  If !fstat
   ECHPAM(1)  = [F:TAM]PAM
  Else
   Filter [TAM] Where LEG="" & ENAFLG=2
   Read [TAM]TAM0 First
   If !fstat
    ECHPAM(1)  = [F:TAM]PAM
   Endif
  Endif
  Filter [TAM]
 Endif
Endif

Call LECTURE("TCU",DEVLED,"") From CONTOBJ
AROLED = [F:TCU]CURRND

If NBECH>0
 Gosub SETCOUR
 Call CONVERT_DEV(DEVORG,DEVDES,DEVLED,NBECH,ECHMNT(1..NBECH),ECHLED,
&       COURS,TYPCOURS,DATCPT,AROLED) From CPTSUB
Endif

# Point d'entrée ajout d'échéances
GPOINT = "CREECH" : Gosub ENTREE From EXEFNC

For NOL=1 To NBECH
 Raz [F:DUD]
 Gosub INIECH
 [F:DUD]LIG = 1 : # facture non validée
 [F:DUD]FLGFUP = RELANCE
 [F:DUD]FLGPAZ = BONAPAY
 [F:DUD]DUDSTA = 0 : # Nouvelle facture donc non validée
 [F:DUD]DUDLIG = NOL
 [F:DUD]DUDDAT = ECHDAT(NOL)
 [F:DUD]PAM    = ECHPAM(NOL)
 Call CONTTAM([F:DUD]PAM,[F:CPY]LEG,"") From SUBTAM
 If mkstat
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  mkstat=0 : GOK = 0 : Break
 Endif
 [F:DUD]SOI    = 1
 If RELEVE=2
  Call LEC_TAM([F:CPY]LEG,[F:DUD]PAM) From CPTLEC
  If !fstat & [F:TAM]SOI<>""
   [F:DUD]SOI = 2
  Endif
 Endif
 [F:DUD]PAMTYP = ECHTYP(NOL)
 [F:DUD]AMTCUR = ECHMNT(NOL)
 [F:DUD]AMTLOC = ECHLED(NOL)
 [F:DUD]TYPDUD = 2  : #Facture
 Call LEC_TAM([F:CPY]LEG,[F:DUD]PAM) From CPTLEC
 If fstat | [F:TAM]SDDFLG<>2
  [F:DUD]UMRNUM = ""  #inhiber le Transclass
 Endif
 # Point d'entrée mise ŕ jour des échéances
 GPOINT = "MAJECH" : Gosub ENTREE From EXEFNC
 Call KEYDUD("DUD") From MODECHE
 Call SLDECH("DUD")From MODECHE
 Local Integer EXERCICE, PERIODE, ASTATUS
 [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX,[F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE,GMESSAGE)
 [F:DUD]FIY= EXERCICE
 [F:DUD]PER= PERIODE
 If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
 If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
 Write [DUD]
 If fstat
  GOK=0 : Call FSTA("DUD") From GLOCK : Break
 Endif
 Call HISTOECH("DUD",1,[L]DATEVT) From MODECHE
Next NOL
End

$INIECH
[F:DUD]BPRTYP = TYPTIERS
# AUREN - 05.793.474 - Cambio signo: Si Compra siempre -1, si venta siempre 1
Case TYPTIERS
 When 1
  [F:DUD] = [F:SIH]
  If [L]ACTIV_XX5A = 0 : Raz [F:DUD]BELVCS : Endif  # Issue X3-133919
  Call LECTURE("FCY",[F:SIH]FCY,"") From CONTOBJ
  [F:DUD]FCY = [F:FCY]FINRSPFCY
  [F:DUD]SAC = [F:SIH]BPRSAC
  Case [F:SIH]INVTYP
   When 1,3
    [F:DUD]SNS = +1
   When 2,4
	#[F:DUD]SNS = -1
    [F:DUD]SNS = +1
  Endcase
  [F:DUD]TYP = [F:SIH]GTE
  [F:DUD]BPRFCT = [F:SIH]BPRFCT
 When 2
  [F:DUD] = [F:PIH]
  If [L]ACTIV_XX5A = 0 : Raz [F:DUD]BELVCS : Endif  # Issue X3-133919
  [F:DUD]SAC = [F:PIH]BPRSAC
  Case [F:PIH]INVTYP
   When 1,4
    [F:DUD]SNS = -1
   When 2,3
    #[F:DUD]SNS = +1
    [F:DUD]SNS = -1
  Endcase
  [F:DUD]TYP = [F:PIH]GTE
Endcase
Return

$SETCOUR
Local Decimal COURS
Local Char    DEVORG(GLONCUR), DEVDES(GLONCUR)
#--- Position des 3 devises par rapport ŕ l'Euro
DEVORG = [L]DEVISE
DEVDES = [L]DEVLED
Call SETFLGDEV([L]DEVISE,[F:CPY]CPY,DATCPT) From CPTDIV
If [L]RATDIV=0 Then [L]RATDIV=1 Endif
COURS  = [L]RATMLT/[L]RATDIV
# X3-210494 2020-09-16 Bader begin take into account DECRCU parameter for currency rate
[L]COURS = arr([L]COURS,10^-GDECRCU)
# X3-210494 2020-09-16 Bader end
Return

########################################################
## Import d'une facture                               ##
########################################################
$IMPECHE
 # Point d'entrée mise ŕ jour des échéances
 GPOINT = "IMPECH" : Gosub ENTREE From EXEFNC
Return

########################################################
## Modification d'une facture                         ##
########################################################
Subprog MODECHE(TYPTIERS,NUMERO,MONTANT,MAJFAC,OK)
Value    Integer TYPTIERS
Value    Char    NUMERO
Value    Decimal MONTANT
Value    Integer MAJFAC
Variable Integer OK

Local Decimal OMONT , RESIDU , RESTE , EXERCICE , PERIODE
Local Integer NOL , MODECH , LCK

If TYPTIERS=1
 If clalev([M:DUD1])=0 : Local Mask BPCDUD [DUD1] : Endif
Else
 If clalev([M:DUD1])=0 : Local Mask BPSDUD [DUD1] : Endif
Endif
LCK = 1 : Gosub CHARGECH
If OK<0
 GOK = -1 : GLOCK = "%"+SYMBOLE : End
Elsif !OK
 GOK = 0 : End
Endif
If [M:DUD1]NBECH=0
 Case TYPTIERS
  When 1
   If dim([M:BIC1]XSOI)>0
    Call CREECHE(1,[M:BIC1]XSOI,[M:BIC1]XFLGFUP,len(mess(0,510,1))) From SUBBIH
    End
   Endif
  When 2
   If dim([M:BIS1]XSOI)>0
    Call CREECHE(2,[M:BIS1]XSOI,0,[M:BIS1]XFLGPAZ) From SUBBIH
    End
   Endif
 Endcase
Endif
OMONT = sum([M:DUD1]AMTCUR(0..[M:DUD1]NBECH-1))
MODECH = 0
OK = 1
If OMONT<MONTANT : # Le montant a augmenté => derničre échéance
 If [M:DUD1]NBECH>=1
  [M:DUD1]AMTCUR([M:DUD1]NBECH-1) += MONTANT-OMONT
 Else
  OK = 2 : # Si y'a pas d'échéance, on va les saisir!!
 Endif
 MODECH = 1
 If [M:DUD1]NBECH>1 : OK = 2 : Endif
Elsif OMONT>MONTANT
 RESIDU = OMONT-MONTANT
 For NOL=0 To [M:DUD1]NBECH-1
  RESTE = [M:DUD1]AMTCUR(NOL)-[M:DUD1]PAYCUR(NOL)-[M:DUD1]TMPCUR(NOL)
  If RESTE>0
   If RESTE>RESIDU
    [M:DUD1]AMTCUR(NOL) -= RESIDU : Break
   Else
    [M:DUD1]AMTCUR(NOL) -= RESTE
    RESIDU -= RESTE
   Endif
   If [M:DUD1]AMTCUR(NOL) = 0
    Dela NOL [M:DUD1]NBECH
    [M:DUD1]NBECH -= 1
    NOL -= 1
   Endif
  Endif
 Next NOL
 MODECH = 1
 If [M:DUD1]NBECH>1 : OK = 2 : Endif
Endif
If MAJFAC
 MODIF  = 1
 MODECH = 1
Endif
If MODECH
 Gosub VALECH
Endif
End

$VALECH
Local Decimal  AROLED
Local Integer  IDEV

# Issue X3-133919
Local Integer ACTIV_XX5A
[L]ACTIV_XX5A = func AFNC.ACTIV("XX5A")

# Effacement des échéances qui ne sont plus dans le tableau
# ou qui ont un montant = 0
For [DUD]DUD1 Where ACCNUM=NUMECH
 LIGECH = find([F:DUD]DUDLIG,[M:DUD1]DUDLIG(0..[M:DUD1]NBECH-1))
 If !LIGECH | [M:DUD1]AMTCUR(LIGECH-1)=0
  Call HISTOECH("DUD",2,[L]DATEVT) From MODECHE
  Delete [DUD]
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMECH) : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif

Call LECTURE("TCU",DEVLED,"") From CONTOBJ
AROLED = [F:TCU]CURRND
Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
ARORPT = [F:TCU]CURRND

# Recalcul des montants société et reporting
If [M]NBECH>0
 Gosub SETCOUR
 Call CONVERT_DEV(DEVORG,DEVDES,DEVLED
&  ,NBECH,[M:DUD1]AMTCUR(0..[M]NBECH-1),[M:DUD1]AMTLOC,COURS,TYPCOURS,DATCPT
&  ,AROLED) From CPTSUB
Endif

# Mise ŕ jour des échéances modifiées
LIGECH = 0
For nolign=1 To [M:DUD1]NBECH
 If [M:DUD1]DUDLIG(nolign-1)<>0 & [M:DUD1]AMTCUR(nolign-1)<>0
  Readlock [DUD]DUD1 = NUMECH;[M:DUD1]DUDLIG(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMECH) : Break
  Elsif fstat
   GOK=0 : Call RSTA("DUD",num$(NUMECH)) From GLOCK : Break
  Endif
  If MODIF
   Gosub INIECH
  Endif
  [F:DUD] = [M:DUD1]
  # Issue X3-195162 by MRDAB/MAPON
  Gosub SET_BIDNUM
  # Issue X3-195162 end
  [F:DUD]LIG = LIGPCE
  Call SLDECH("DUD")From MODECHE
  Local Integer EXERCICE, PERIODE, ASTATUS
  [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX,[F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE,GMESSAGE)
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
  Gosub PE_BEFWRIDUD
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
  LIGECH = max(LIGECH,[F:DUD]DUDLIG)
 Endif
Next nolign
If GOK<1 : Return : Endif

# Création des nouvelles échéances
For nolign=1 To [M:DUD1]NBECH
 If [M:DUD1]DUDLIG(nolign-1)=0 & [M:DUD1]AMTCUR(nolign-1)<>0
  Raz [F:DUD]
  Gosub INIECH
  [F:DUD] = [M:DUD1]
  [F:DUD]LIG = LIGPCE
  [F:DUD]PAMTYP = 1            : # Type échéance
  [F:DUD]DUDSTA = 1 + (ETAT>2) : # 1=non validée, 2=validée
  [F:DUD]DUDLIG = LIGECH+1
  [F:DUD]TYPDUD = 2  : #Facture
  # Issue X3-195162 by MRDAB/MAPON
  Gosub SET_BIDNUM
  # Issue X3-195162 end
  LIGECH += 1
  Call KEYDUD("DUD") From MODECHE
  Call SLDECH("DUD")From MODECHE
  Local Integer EXERCICE, PERIODE, ASTATUS
  [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX,[F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE,GMESSAGE)
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
  If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
  If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
  Gosub PE_BEFWRIDUD
  Write [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
 Endif
Next nolign
# Issue X3-107197
If dim([M:BIS3]NBLIG)>0 & func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGRTZ",[M:BIS0]CPY)="2" : # Gestion retenues Argentines
 Call CALRTZ(1,[M:BIS0]BPR,GPLAN(1),[M:BIS3]ACC1,[M:BIS3]FCYLIN,[M:BIS1]CUR,[M:BIS0]ACCDAT,[M:BIS3]AMTNOTLIN,[M:BIS3]AMTVAT,[M:BIS3]NBLIG,0) From CALRTZARG
Endif
Return

$PE_BEFWRIDUD
If dim(CALL_PT)>0 & CALL_PT=1 : GPOINT = "BEFWRIDUD" : Gosub ENTREE From EXEFNC : Endif
Return

############################################################
## Lecture des infos utiles des échéances                 ##
############################################################
Subprog INFOECHE(TYPTIERS,NUMERO,MONTMIN,MONTPRO)
Value    Integer TYPTIERS
Value    Char    NUMERO
Variable Decimal MONTMIN
Variable Decimal MONTPRO

Local Integer OK , NUMECH

MONTMIN = 0
MONTPRO = 0

If TYPTIERS=1
 If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
 If [F:SIH]NUM<>NUMERO
  Read [SIH]SIH0 = NUMERO
  If fstat : OK = 0 : End : Endif
 Endif
 NUMECH   = [F:SIH]ACCNUM
Else
 If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
 If [F:PIH]NUM<>NUMERO
  Read [PIH]PIH0 = NUMERO
  If fstat : OK = 0 : End : Endif
 Endif
 NUMECH   = [F:PIH]ACCNUM
Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif

For [DUD]DUD1 Where ACCNUM=NUMECH
 If [F:DUD]SOINUM<>""
  MONTMIN += [F:DUD]AMTCUR
 Else
  MONTMIN += [F:DUD]PAYCUR+[F:DUD]TMPCUR
 Endif
 MONTPRO += [F:DUD]TMPCUR
Next
End

########################################
## Ecran BIHP (Périodes)              ##
########################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M]STRDAT=[0/0/0]
 mkstat = 1 : End
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M]STRDAT<>[0/0/0] & VALEUR=[0/0/0]
 # Date fin de prestation ŕ renseigner
 GMESSAGE = mess(123,107,1)
 mkstat = 2 : End
Endif
End

Subprog C_PERNBR(VALEUR)
Variable Decimal VALEUR
If [M]STRDAT<>[0/0/0] & VALEUR = 0
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
End


########################################
## Ecran BIHT (saisie taxes)          ##
########################################
Subprog C_TAX1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TVT]VATTYP=1
  GMESSAGE = mess(23,119,1) : mkstat = 2 : End
# Taxe de type TVA
 Endif
Endif
End

Subprog C_TAX2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TVT]VATTYP=1
  GMESSAGE = mess(23,119,1) : mkstat = 2 : End
# Taxe de type TVA
 Endif
Endif
End

Subprog C_VAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TVT]VATTYP<>1
  GMESSAGE = mess(11,119,1) : mkstat = 2 : End
# Cette taxe n'est pas de type TVA
 Endif
Endif
End

Subprog AM_TAX1(VALEUR)
Variable Char VALEUR
[M]TAX1 = VALEUR
Gosub CALTVA
If STAT
 Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
 Call ERREUR(MESSA) From GESECRAN : mkstat = 2 : End
Endif
End

Subprog AM_TAX2(VALEUR)
Variable Char VALEUR
[M]TAX2 = VALEUR
Gosub CALTVA
If STAT
 Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
 Call ERREUR(MESSA) From GESECRAN : mkstat = 2 : End
Endif
End

Subprog AM_VAT(VALEUR)
Variable Char VALEUR
[M]VAT = VALEUR
Gosub CALTVA
If STAT
 Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
 Call ERREUR(MESSA) From GESECRAN : mkstat = 2 : End
Endif
End


$CALTVA
Local Char    TAXES(GLONVAT)(1..3), MESSA(80)
Local Decimal MONTANT(1..3) , MONTDED(1..3)
Local Integer TYPREG , STAT
Local Decimal EXEAMTTAX(1..3)
Local Decimal DSCRAT
# X3-125815 2019-03-08 Bader begin
Local Integer TYPBAS
TYPBAS = 1
# X3-125815 2019-03-08 Bader end
TAXES(1) = [M]TAX1
TAXES(2) = [M]TAX2
TAXES(3) = [M]VAT
# X3-125815 2019-03-08 Bader begin
If GACTION = "SAITAX5" : TYPBAS = 2 : Endif
# X3-125815 2019-03-08 Bader end
If dim([M]EXEAMTVAT)>0
# X3-125815 2019-03-08 Bader begin use TYPBAS instead of 1 as TYPBASE parameter
# Call CALTAXE3([M]CPY,[M]BPR,[M]ACCDAT,"",[M]CUR
#& ,3,TAXES,1,[M]BASE,MONTANT,MONTDED,EXEAMTTAX,TYPREG,STAT) From SUBTVT
 Call CALTAXE3([M]CPY,[M]BPR,[M]ACCDAT,"",[M]CUR
& ,3,TAXES,TYPBAS,[M]BASE,MONTANT,MONTDED,EXEAMTTAX,TYPREG,STAT) From SUBTVT
# X3-125815 2019-03-08 Bader end
Else
# X3-125815 2019-03-08 Bader begin use TYPBAS instead of 1 as TYPBASE parameter
# Call CALTAXE([M]CPY,[M]ACCDAT,"",[M]CUR
#&  ,3,TAXES,1,[M]BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
 Call CALTAXE([M]CPY,[M]ACCDAT,"",[M]CUR
&  ,3,TAXES,TYPBAS,[M]BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
# X3-125815 2019-03-08 Bader end
Endif
## If "Rebate on VAT" and if the line is subjeted to discount, the discount rate has to be applied on the VAT (only VAT, not the
## others taxes)
If [M]FLGDEP=2 & (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M]DEP)))
 Call DSCRAT([M]DEP,DSCRAT) From INVDEPLIB
 Call LEC_TCU([M]CUR) From CPTLEC
 If DSCRAT<>0
  MONTANT(3) = arr(MONTANT(3)*(1-(DSCRAT/100)),[F:TCU]CURRND)
  MONTDED(3) = arr(MONTDED(3)*(1-(DSCRAT/100)),[F:TCU]CURRND)
 Endif
Endif
If TYPREG<>1 & (dim([M]CEEFLG)<0 | TYPREG<>4 | [M]CEEFLG<>2)
 Raz MONTANT, MONTDED
Endif
If STAT : Return : Endif
[M]AMTTAX1 = MONTANT(1)
[M]AMTTAX2 = MONTANT(2)
[M]AMTVAT  = MONTANT(3)
If dim([M]EXEAMTVAT)>0
 [M]EXEAMTTAX1 = EXEAMTTAX(1)
 [M]EXEAMTTAX2 = EXEAMTTAX(2)
 [M]EXEAMTVAT  = EXEAMTTAX(3)
Endif
If dim([M]DEDTAX1)>0 : [M]DEDTAX1 = MONTDED(1) : Endif
If dim([M]DEDTAX2)>0 : [M]DEDTAX2 = MONTDED(2) : Endif
If dim([M]DEDVAT)>0  : [M]DEDVAT  = MONTDED(3) : Endif
Affzo AMTTAX1, AMTTAX2, AMTVAT
If dim([M]DEDTAX1)>0 : Affzo DEDTAX1, DEDTAX2, DEDVAT : Endif
If dim([M]EXEAMTVAT)>0 : Affzo EXEAMTVAT, EXEAMTTAX1, EXEAMTTAX2 : Endif
Return


########################################
## Ecran BPCDUD / BPSDUD (échéances)  ##
########################################
Subprog C_NBECH
Case status
 When 65
  Gosub SETNOL
  Gosub TST_ANU
 When 68,83
  Local Integer NOL
  For NOL=nolign-1 To nolign1-1
   Gosub TST_ANU
   If mkstat : Break : Endif
  Next NOL
Endcase
End

$TST_ANU
If [M]PAYCUR(NOL)<>0 | [M]TMPCUR(NOL)<>0
 GMESSAGE = mess(25,119,1) : mkstat = 2
# Echéance réglée, annulation impossible
Elsif [M]SOINUM(NOL)<>""
 GMESSAGE = mess(30,119,1) : mkstat = 2
# Echéance su relevé, annulation impossible
Endif
Return

Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif

# Issue X3-123841 by MRDAB
Gosub IDN_PROCESSED
# Issue X3-123841 end

End

Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif
If dim([M:DUD1]UMRNUM)>0
 If [M]AMTCUR(NOL)<>0 & abs([M]PAYCUR(NOL))+abs([M]TMPCUR(NOL))<>0
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PAM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Integer OK
If VALEUR<>[M]PAM(NOL)
 If ([M]SOINUM(NOL)<>"" | [M]SOI(NOL)=2)
  Call LEC_TAM(GCURLEG,VALEUR) From CPTLEC
  If [F:TAM]SOI="" # Pas de code relevé
   If [M]SOINUM(NOL)="" # Relevé "A faire"
    # Mode de rčglement non concerné par les relevés
    OK=1 : Call AVERTIR(mess(38,117,1),OK) From GESECRAN
    If [L]OK=1 : mkstat=2 : Else : [M]SOI(NOL)=1 : Affzo [M]SOI(NOL) : Endif
   Else
    # Mode de rčglement non concerné par les relevés
    GMESSAGE=mess(38,117,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
 If dim([M:DUD1]UMRNUM)>0
  Call LEC_TAM(GCURLEG,VALEUR) From CPTLEC
  If [F:TAM]SDDFLG<>2
   Raz [M:DUD1]UMRNUM(NOL)
  Endif
 Endif

 # SAM 101378: Localization Switzerland, 2016-01-19 Bader
 If func AFNC.ACTIV("KSW")
    Call CONT_PAM(VALEUR) From SWIBVRLIB4
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
    Call C_PAM(VALEUR) From SWIQRCLIB2    # X3-90417 CH QR bill - Suppl inv - Implement QR bill payment method 2018-06-06 Bader
 Endif
 # SAM 101378 END
Endif
End

Subprog AM_PAM(VALEUR)
Variable Char    VALEUR()
Local    Integer SEENABLEDOLD, SEENABLEDNEW
Gosub SETNOL
# 78411 - Do not allow the payment method to be changed in or out of one associated with Sage Exchange
If func AFNC.ACTIV("SEPP")
  Call LEC_TAM(GCURLEG,VALEUR) From CPTLEC
  If !fstat
    SEENABLEDNEW = [F:TAM]SEPFLG
  Endif

  Call LEC_TAM(GCURLEG,[M]PAM(NOL)) From CPTLEC
  If !fstat
    SEENABLEDOLD = [F:TAM]SEPFLG
  Endif

  If SEENABLEDOLD = 2 or SEENABLEDNEW = 2
    GMESSAGE=mess(50,2092,1)
    mkstat=2 : End
  Endif
Endif
End

Subprog IB_AMTCUR
GBOUT2 = mess(26,119,1) : # Solde
End

Subprog AS_AMTCUR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If (VALEUR<>0 & abs(VALEUR)<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
&  or [M]SOINUM(NOL)<>""
 mkstat = 2 : End
Endif

# Issue X3-123841 by MRDAB
Gosub IDN_PROCESSED
# Issue X3-123841 end

End

Subprog B2_AMTCUR(VALEUR)
Variable Decimal VALEUR
VALEUR = [M]AMTTOT-sum([M]AMTCUR(0..nolign-2))-sum([M]AMTCUR(nolign..[M]NBECH-1))
End

Subprog C_AMTCUR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]AMTCUR(NOL)<>0 & sgn(VALEUR)<>sgn([M]AMTCUR(NOL)) : mkstat=1 : End : Endif
If abs(VALEUR)<abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
 GMESSAGE = mess(27,119,1) : mkstat = 2
# Montant inférieur au rčglement
Endif
End

Subprog D_DEP(VALEUR)
Variable Char    VALEUR()
If dim([M:BIC1]DEP)>0
    VALEUR = [M:BIC1]DEP
Elsif dim([M:BIS1]DEP)>0
    VALEUR = [M:BIS1]DEP
Endif
End

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If dim([M:BIC1]DEP)>0    : # Customer invoice
 Call CNTDEPTYP(3,[F:DUD]ACCNUM,[M:BIC1]DEP,VALEUR) From CPTCNT
Elsif dim([M:BIS1]DEP)>0 : # Supplier invoice
 Call CNTDEPTYP(4,[F:DUD]ACCNUM,[M:BIS1]DEP,VALEUR) From CPTCNT
Elsif dim([M:SIH2]DEP)>0 : # Sales invoice
 Call CNTDEPTYP(1,[F:DUD]ACCNUM,[M:SIH2]DEP,VALEUR) From CPTCNT
Elsif dim([M:PIH1]DEP)>0 : # Purchase invoice
 Call CNTDEPTYP(2,[F:DUD]ACCNUM,[M:PIH1]DEP,VALEUR) From CPTCNT
Endif
End

Subprog AS_FLGFUP(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
 mkstat = 2 : End
Endif
End

Subprog AS_LEVFUP(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))
 mkstat = 2 : End
Endif
End

Subprog AS_FLGPAZ(VALEUR)
Variable Integer VALEUR
Local Char CHAINE(10)
Call PARAM([F:PIH]FCY,"FLGPAZ",CHAINE) From ADOVAL
If val(CHAINE)<>2
 VALEUR = len(mess(0,510,1))
 mkstat = 2 : End
Endif
Gosub SETNOL
If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL)))
 mkstat=2 : End
Endif
If GMODU(3)=2  :# Tiers
 If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 If VALEUR>val(LLEVPAZ)
  mkstat=2 : End
 Endif
Endif
End

Subprog D_FLGPAZ(VALEUR)
Variable Integer VALEUR
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If dim([F:PIH]BPR)>0
 Call LECTURE("BPS",[F:PIH]BPR,"") From CONTOBJ
Endif
Call LECTURE("AUS",GUSER,"") From CONTOBJ
# X3-71518 Don't consider Payment hold flag of the supplier
#If dim([F:BPS]PAYLOKFLG)>0 & [F:BPS]PAYLOKFLG=2
# VALEUR = 1
#Else
Local Char LLEVPAZ(3)
Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
VALEUR = min(len(mess(0,510,1)),val(LLEVPAZ))
#Endif
Gosub SETNOL
If NOL : VALEUR=[M]FLGPAZ(NOL-1) : Endif
End

Subprog C_FLGPAZ(VALEUR)
Variable Integer VALEUR
If GMODU(3)=2  :# Tiers
 If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 If VALEUR>val(LLEVPAZ)
  GMESSAGE = mess(29,119,1) : mkstat = 2 : End
  # Niveau de bon ŕ payer non autorisé
 Endif
Endif
End

Subprog D_PAM(VALEUR)
Variable Char    VALEUR()
If nolign>1
 VALEUR = [M]PAM(nolign-2)
Endif
End

Subprog AS_SOI(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]SOINUM(NOL)<>"" : mkstat = 2 : End : Endif
Call LEC_TAM(GCURLEG,[M]PAM(NOL)) From CPTLEC
If [F:TAM]SOI=""  # Mode de rčglement non concerné par les relevés
 VALEUR = 1 : mkstat=2 : End
Endif
End

#KC Bug 55897: Contrôle sur le chp aprés la sélection pour achats et ventes aussi
# Issue X3-205959 by MRDAB/MAPON
Subprog C_BPAPAY(VALEUR)
Variable Char    VALEUR()

If dim([M:DUD1]DUDLIG) = -1
  If VALEUR<>"" & VALEUR<>[M]BPAPAY
    If clalev([M:BIC1])>0
      Read [F:BPA]BPA0 = 1;[M:BIC1]BPRPAY;VALEUR
    Elsif clalev([M:BIS1])>0
      Read [F:BPA]BPA0 = 1;[M:BIS1]BPRPAY;VALEUR
    Elsif clalev([M:SIH1])>0
      Read [F:BPA]BPA0 = 1;[M:SIH1]BPRPAY;VALEUR
    Elsif clalev([M:PIH1])>0
      Read [F:BPA]BPA0 = 1;[M:PIH1]BPRPAY;VALEUR
    Endif
  Endif
Else
  If (VALEUR<>"" & VALEUR<>[M:DUD1]BPAPAY(nolign-1)) or GIMPORT # Issue X3-205959 by MRDAB/MAPON
    Read [F:BPA]BPA0 = 1;[M:DUD1]BPRPAY(nolign-1);VALEUR
  Endif
Endif
If fstat
 # Adresse inexistante
 GMESSAGE = mess(10,119,1)
 mkstat = 2 : End
Endif
End
# Issue X3-205959 end

#KC Bug 55897: Chp invisible pour le passer en param sur la sélection du code adresse dans
#aprés clic sur le btn Echeances pour Facture Client,Four.,Achat et Ventes
Subprog D_OBPRPAY(VALEUR)
Variable Char    VALEUR()
If (clalev([M:BIC1])>0)
 VALEUR=[M:BIC1]BPRPAY
Elsif (clalev([M:SIH1])>0)
 VALEUR=[M:SIH1]BPRPAY
Elsif (clalev([M:BIS1])>0)
 VALEUR=[M:BIS1]BPRPAY
Elsif (clalev([M:PIH1])>0)
 VALEUR=[M:PIH1]BPRPAY
Endif
End

Subprog AM_DUDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
# Issue X3-205959 by MRDAB/MAPON
If VALEUR<>[M]DUDDAT(NOL)
  If [M]BPAPAY(NOL) = "" and NOL = 0
    If clalev([M:BIC1]) > 0
      [M]BPAPAY(NOL) = [M:BIC1]BPAPAY
    Elsif clalev([M:BIS1]) > 0
      [M]BPAPAY(NOL) = [M:BIS1]BPAPAY
    Elsif clalev([M:PIH1]) > 0
      [M]BPAPAY(NOL) = [M:PIH1]BPAPAY
    Elsif clalev([M:SIH1]) > 0
      [M]BPAPAY(NOL) = [M:SIH1]BPAADD
    Else
      [M]BPAPAY(NOL) = [M]BPAPAY
    Endif
    [M]BPRPAY(NOL) = [M]OBPRPAY
  Endif

  If [M]BPAPAY(NOL)="" and NOL > 0
    [M]BPAPAY(NOL) = [M:DUD1]BPAPAY(NOL-1)
    [M]BPRPAY(NOL) = [M:DUD1]BPRPAY(NOL-1)
  Endif

  Affzo [M]BPAPAY(NOL)
  Affzo [M]BPRPAY(NOL)

  [M:DUD1]BIDCRY(NOL) = func GET_CRY_FROM_ADDRESS([M:DUD1]BPRPAY(NOL), [M:DUD1]BPAPAY(NOL)) # Issue X3-195162, X3-195181, X3-195185, X3-205959 by MRDAB/MAPON
Endif
# Issue X3-205959 end
End


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
Subprog AS_UMRNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:BIC1]BPRPAY)<=0 & dim([M:SIH1]BPRPAY)<=0 : End : Endif
Gosub SETNOL
If abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))>0 : mkstat=2 : End : Endif

Call LEC_TAM(GCURLEG,[M:DUD1]PAM(NOL)) From CPTLEC
If fstat | [F:TAM]SDDFLG<>2 : mkstat=1 : End : Endif

If dim([M:BIC1]UMRNUM)>0
 If VALEUR="" : VALEUR=[M:BIC1]UMRNUM  : Endif
 If VALEUR="" : Call INIT_UMRNUM(GSOCIETE,[M:BIC1]BPRPAY,2,2,VALEUR) From INVSDDLIB : Endif
Elsif dim([M:SIH2]UMRNUM)>0
 If VALEUR="" : VALEUR=[M:SIH2]UMRNUM  : Endif
 If VALEUR="" : Call INIT_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,2,2,VALEUR) From INVSDDLIB : Endif
Endif

End

Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:BIC1]BPRPAY)<=0 & dim([M:SIH1]BPRPAY)<=0 : End : Endif
Gosub SETNOL

If clalev([F:MDT])=0 : Local File MANDATE [MDT] : Endif
If clalev([F:TAM])=0 : Local File TABPAM  [TAM] : Endif
Local Integer FLGSDD : [L]FLGSDD = 0

If VALEUR=""
 Call LEC_TAM(GCURLEG,[M]PAM(NOL)) From CPTLEC
 If !fstat & [F:TAM]SDDFLG=2
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
Else
 If dim([M:BIC1]BPRPAY)>0
  Call CTL_UMRNUM(VALEUR,GSOCIETE,[M:BIC1]BPRPAY) From INVSDDLIB
 Elsif dim([M:SIH1]BPRPAY)>0
  Call CTL_UMRNUM(VALEUR,GSOCIETE,[M:SIH1]BPRPAY) From INVSDDLIB
 Endif
 If mkstat : End : Endif
Endif
End


######################################################################################
# Issue X3-123841 by MRDAB
Subprog AS_DEP(VALEUR)
Variable Char    VALEUR()

Gosub SETNOL
Gosub IDN_PROCESSED

End
######################################################################################
$IDN_PROCESSED

Local Char WITH_INTEREST
Local Decimal TMPDEP_CTR
Local Date TEMP_DUDDAT

[L]TEMP_DUDDAT = [M]DUDDAT(NOL)

Read [F:DUD]DUD1=[F:DUD]ACCNUM;[M]DUDLIG(NOL)
If !fstat
  Call IDN_PROCESSED([F:DUD]TYP,[F:DUD]NUM,[F:DUD]LIG,[F:DUD]DUDLIG,
&                    [L]TEMP_DUDDAT,[L]TMPDEP_CTR,[L]WITH_INTEREST) From IDNGENCTL
  If [L]WITH_INTEREST <> ""
    GMESSAGE = mess(285,7711,1)
    Diszo [M]DUDDAT(NOL)
    Diszo [M]AMTCUR(NOL)
    Diszo [M]DEP(NOL)
    mkstat = 2
  Endif
Endif

Return
# Issue X3-123841 end
######################################################################################
# Issue X3-195162, X3-195181, X3-195185, X3-205959 by MRDAB/MAPON
Subprog AM_BIDNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR<>[M]BIDNUM(nolign-1) & [M]BPRPAY(nolign-1)<>"" & VALEUR<>""
  Call LECTURE("BPR",[M]BPRPAY(nolign-1),"") From CONTOBJ
  If fstat : End : Endif
  If [F:BPR]BPSFLG=2 or [F:BPR]BPCFLG=2
    If clalev([F:BID])=0 : Local File BID [BID] : Endif
    Read [F:BID]BID0=1;[M]BPRPAY(nolign-1);VALEUR;[M]BPAPAY
    If fstat
      Read [F:BID]BID0=1;[M]BPRPAY(nolign-1);VALEUR
      If fstat=5
        #Check that the Bank account exists in the BP BID table
        Filter [F:BID] Where [F:BID]BPATYP=1 & [F:BID]BPANUM=[M]BPRPAY(nolign-1)
        #If the list is empty we let the user enter this new Bank account
        #Otherwise throw error message bank account does not exist in the list.
        If rowcount([F:BID]) <> 0
          #Non-existent Bank Account Number
          GMESSAGE = mess(27,199,1): mkstat=2 : End
        Endif
        Filter [F:BID]
      Endif
    Endif
  Endif

  [M:DUD1]BIDNUM(nolign-1) = [F:BID]BIDNUM
  [M:DUD1]PAB(nolign-1) = [F:BID]PAB1
  [M:DUD1]IBAN(nolign-1) = ""
  If [F:BID]IBAN <> ""
    [M:DUD1]IBAN(nolign-1) = [F:BID]IBAN + [F:BID]BIDNUM
  Endif

  Affzo [M:DUD1]PAB(nolign-1)
  Affzo [M:DUD1]IBAN(nolign-1)
Elsif VALEUR = ""
  [M:DUD1]PAB(nolign-1) = ""
  [M:DUD1]IBAN(nolign-1) = ""
Endif

End
######################################################################################
Funprog GET_DEF_BIDNUM(P_BPRPAY, P_BPAPAY)
Value Char P_BPRPAY
Value Char P_BPAPAY

Local Char DEF_BIDNUM(GLONBID)

  For [F:BID]BID2 Where [F:BID]BPATYP = 1 and [F:BID]BPANUM = P_BPRPAY and [F:BID]BPAADD = P_BPAPAY and [F:BID]BIDNUMFLG = 2
    [L]DEF_BIDNUM = [F:BID]BIDNUM
  Next

End [L]DEF_BIDNUM
######################################################################################
Funprog GET_CRY_FROM_ADDRESS(P_BPRPAY, P_BPAPAY)
Value Char P_BPRPAY
Value Char P_BPAPAY

  Local Char COUNTRY(GLONCRY)
  Read [F:BPA]BPA0 = 1;P_BPRPAY;P_BPAPAY
  If !fstat
    [L]COUNTRY = [F:BPA]CRY
  Endif

End [L]COUNTRY
######################################################################################
$SET_BIDNUM

  If [L]LSTA < 3 or [M:DUD1]OBPRPAY <> ""
    If [M:DUD1]BIDNUM(nolign-1) <> func GET_DEF_BIDNUM([M:DUD1]BPRPAY(nolign-1), [M:DUD1]BPAPAY(nolign-1))
     [F:DUD]BIDNUMMAN = [M:DUD1]BIDNUM(nolign-1)
    Else
     [F:DUD]BIDNUMMAN = ""
    Endif
  Else
    [F:DUD]BIDNUMMAN = ""
  Endif

Return
######################################################################################
Subprog AP_BPAPAY(VALEUR)
Variable Char    VALEUR()

  Local Char BID : [L]BID = [M:DUD1]BIDNUM(nolign-1)
  Local Char PAB : [L]PAB = [M:DUD1]PAB(nolign-1)
  Local Char IBAN : [L]IBAN = [M:DUD1]IBAN(nolign-1)
  Local Char CRY : [L]CRY = [M:DUD1]BIDCRY(nolign-1)
  Local Tinyint DEF_FOUND : [L]DEF_FOUND = 0
  Local Char LADDRESS(GLONBPA), LBPR(GLONBPR)

  If find(status,1,2)
    [L]LADDRESS = VALEUR
    [L]LBPR = [M:DUD1]BPRPAY(nolign-1)
    Gosub SET_FIELDS_DEF

    # when leaving field without changes and default not found do not clean the fields so need to read from buffer otherwise leave them clear
    If [L]BID <> "" and ![L]DEF_FOUND and VALEUR = [M:DUD1]BPAPAY(nolign-1)
      [M:DUD1]BIDNUM(nolign-1) = [L]BID
      [M:DUD1]PAB(nolign-1) = [L]PAB
      [M:DUD1]IBAN(nolign-1) = [L]IBAN
      [M:DUD1]BIDCRY(nolign-1) = [L]CRY
    Endif

    If [M:DUD1]BIDCRY(nolign-1) = ""
      [M:DUD1]BIDCRY(nolign-1) = func GET_CRY_FROM_ADDRESS([M:DUD1]BPRPAY(nolign-1), VALEUR)
    Endif

    Affzo [M:DUD1]PAB(nolign-1)
    Affzo [M:DUD1]IBAN(nolign-1)
    Affzo [M:DUD1]BIDNUM(nolign-1)
  Endif

End
######################################################################################
# Label called from SUBPIH,SUBBIS2,SUBBIC2,SUBSIH, SUBBIH
$PROMPT_BP_BID

  If GREP <> "C"

    Local Integer LACCNUM
    Local Integer LOK : [L]LOK = 0

    If dim([F:PIH]ACCNUM) <> -1
      [L]LACCNUM = [F:PIH]ACCNUM
    Elsif dim([F:SIH]ACCNUM) <> -1
      [L]LACCNUM = [F:SIH]ACCNUM
    Endif

    If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif

    If dim([M:DUD1]DUDLIG) = -1
      For [F:DUD] Where [F:DUD]ACCNUM = [L]LACCNUM and [F:DUD]BIDNUMMAN <> ""
        [L]LOK = 1
        Break
      Next
    Else
      For [F:DUD] Where [F:DUD]ACCNUM = [L]LACCNUM and [F:DUD]DUDLIG = [M:DUD1]DUDLIG(nolign-1) and [F:DUD]BIDNUMMAN <> ""
        [L]LOK = 1
        Break
      Next
    Endif

    If [L]LOK = 1
      Call OUINON(mess(244,187,1),[L]LOK) From GESECRAN
      If [L]LOK <> [V]CST_AYES
        mkstat = 2
      Endif
    Endif
  Endif

Return
######################################################################################
$S_BIDNUM
Local Char CRYA(GLONCRY),CRYB(GLONCRY), LBPAADD(GLONADR), LBPANUM(GLONBPA), LBIDCRY(GLONCRY)
Local Integer OKA

If find(GFONCTION,"GESBIS","GESBIC","GESSIH","GESPIH")
  If [M]BPRPAY(nolign-1)="" : OK=0 : Return : Endif
  [L]LBPANUM = [M]BPRPAY(nolign-1)
  [L]LBPAADD = [M]BPAPAY(nolign-1)
  [L]LBIDCRY = [M]BIDCRY(nolign-1)
Elsif find(GFONCTION,"MODECHE","MODECHE2")
  If [M:SAI1]BPRPAY(nolign-1)="" : OK=0 : Return : Endif
  [L]LBPANUM = [M:SAI1]BPRPAY(nolign-1)
  [L]LBPAADD = [M:SAI1]BPAPAY(nolign-1)
  [L]LBIDCRY = [M:SAI1]BIDCRY(nolign-1)
Endif

Onerrgo ERREUR From CONTROLE
If !clalev([F:BID]) : Local File BID [BID] : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif
Local Integer I
Local Char FMTBID(30)
Local Char LCOA(GLONCOA)

OBJET=""
CRITERE = "BPATYP=1 & BPANUM='"+[L]LBPANUM+"' & (BPAADD='"+[L]LBPAADD+"' | BPAADD='') & CRY='"+[L]LBIDCRY+"'"

FMTBID = "30X"

#Browse the Country (CRY) of all the BIDs in the list: if different then the format remains at 30X
#otherwise we take that of the BID: FMTBID
[L]CRYA=[L]LBIDCRY
[L]CRYB=[L]LBIDCRY
[L]OKA=1
For [F:BID]BID0 Where evalue(CRITERE)
 [L]CRYA=[F:BID]CRY
 If [L]CRYA<>[L]CRYB : [L]OKA=0: Break : Endif
 [L]CRYB=[L]CRYA
Next
If [L]OKA
 Call LECTURE("TCY",[L]LBIDCRY,"") From CONTOBJ
 If !fstat
  FMTBID = [F:TCY]BIDFMT
 Endif
Endif

Call TITOBJ("BID","",TIT(0)) From CONTOBJ
If [L]LBPANUM<>""
 NBCOL=10
 COL(1)  = "CRY"                        : TIT(1)  = ""
 COL(2)  = "format$(FMTBID,BIDNUM)"     : TIT(2)  = "BIDCRY"
 COL(3)  = "BPAADD"                     : TIT(3)  = mess(33,102,1) #BID address ##Adresse du RIB##
 COL(4)  = "mess([F:BID]ACCNONREI,1,1)" : TIT(4)  = mess(250,117,1) : COLTYP(4)=1 #Non-resident ##Non résident##
 COL(5)  = "PAB1"                       : TIT(5)  = "PAB1"
 COL(6)  = "PAB2"                       : TIT(6)  = "PAB2"
 COL(7)  = "BPANUM"                     : TIT(7)  = mess(31,105,1)
 COL(8)  = "BPATYP"                     : TIT(8)  = ""
 COL(9)  = "BIDNUM"                     : TIT(9)  = ""
 COL(10) = "CUR"                        : TIT(10) = "CUR"
Else
 NBCOL=11
 COL(1)  = "BNF"                        : TIT(1)  = mess(132,102,1) #Beneficiary ##Bénéficiaire
 COL(2)  = "CRY"                        : TIT(2)  = ""
 COL(3)  = "BPAADD"                     : TIT(3)  = mess(33,102,1) #BID address ##Adresse du RIB##
 COL(4)  = "mess([F:BID]ACCNONREI,1,1)" : TIT(4)  = mess(250,117,1) : COLTYP(4)=1 #Non-resident ##Non résident##
 COL(5)  = "format$(FMTBID,BIDNUM)"     : TIT(5)  = "BIDCRY"
 COL(6)  = "PAB1"                       : TIT(6)  = "PAB1"
 COL(7)  = "PAB2"                       : TIT(7)  = "PAB2"
 COL(8)  = "BPANUM"                     : TIT(8)  = mess(30,105,1)
 COL(9)  = "BPATYP"                     : TIT(9)  = ""
 COL(10) = "BIDNUM"                     : TIT(10) = ""
 COL(11) = "CUR"                        : TIT(11) = "CUR"
Endif
Onerrgo CHUT From CONTROLE
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif
For I=1 To NBCOL
 Read [AMZ]CODE = "PAY2";TIT(I)
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,TIT(I)) From OBJDIV
 Endif
Next I
If [L]LBPANUM=""
 TIT(8)  = mess(30,105,1)   :# Account
 TIT(10) = TIT(3)
Else
 TIT(9)  = TIT(2)
Endif
SIZCOL=160 : SIZLIG=80 : START="BIDNUM" : ORDRE="BIDNUM;BPAADD"
Default File [BID]
Return
######################################################################################
$FIN_TABLE
  If dim(COUZON) <> -1 # Issue X3-219553 by MRDAB
    Case COUZON
      When "BIDNUM"
        If find(GFONCTION,"GESBIS","GESBIC","GESSIH","GESPIH")
          Default Mask [M:DUD1]
        Elsif find(GFONCTION,"MODECHE","MODECHE2")
          Default Mask [M:SAI1]
        Endif
    Endcase
  Endif

Return
######################################################################################
Subprog C_BIDNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> ""
    Read [F:BID]BID0 = 1;[M:DUD1]BPRPAY(nolign-1);VALEUR;[M:DUD1]BPAPAY(nolign-1)
    If fstat
      Read [F:BID]BID0 = 1;[M:DUD1]BPRPAY(nolign-1);VALEUR;""
      If fstat or [F:BID]CRY <> [M:DUD1]BIDCRY(nolign-1)
        mkstat = 2
        GMESSAGE = mess(27,199,1)
      Endif
    Endif
  Endif

End
######################################################################################
Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()

  Local Tinyint DEF_FOUND : [L]DEF_FOUND = 0
  Local Char LADDRESS(GLONBPA), LBPR(GLONBPR)

  If VALEUR <> [M:DUD1]BPRPAY(nolign-1)
    If [F:BPR]BPRNUM <> VALEUR
      Call LECTURE("BPR",VALEUR,"") From CONTOBJ
    Endif
    [M:DUD1]BPAPAY(nolign-1) = [F:BPR]BPAADD
    If find(status,1,2)
      [L]LADDRESS = [M:DUD1]BPAPAY(nolign-1)
      [L]LBPR = VALEUR
      Gosub SET_FIELDS_DEF

      Affzo [M:DUD1]BPAPAY(nolign-1)
      Affzo [M:DUD1]PAB(nolign-1)
      Affzo [M:DUD1]IBAN(nolign-1)
      Affzo [M:DUD1]BIDNUM(nolign-1)
    Endif
  Endif


End
######################################################################################
$SET_FIELDS_DEF

  [M:DUD1]BIDCRY(nolign-1) = ""
  [M:DUD1]BIDNUM(nolign-1) = ""
  [M:DUD1]PAB(nolign-1) = ""
  [M:DUD1]IBAN(nolign-1) = ""
  For [F:BID]BID2 Where [F:BID]BPATYP = 1 and [F:BID]BPANUM = [L]LBPR and [F:BID]BPAADD = [L]LADDRESS and [F:BID]BIDNUMFLG = 2
    [M:DUD1]BIDCRY(nolign-1) = [F:BID]CRY
    [M:DUD1]BIDNUM(nolign-1) = [F:BID]BIDNUM
    [M:DUD1]PAB(nolign-1) = [F:BID]PAB1
    [M:DUD1]IBAN(nolign-1) = ""
    If [F:BID]IBAN <> ""
      [M:DUD1]IBAN(nolign-1) = [F:BID]IBAN + [F:BID]BIDNUM
    Endif
    [L]DEF_FOUND = 1
  Next

Return
# Issue X3-195162, X3-195181, X3-195185, X3-205959 end
######################################################################################

