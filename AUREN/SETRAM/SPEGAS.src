#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
Case ACTION
        When "FILGAUCHE"        : Gosub FILGAUCHE
        When "APRES_CRE"         : Gosub REPLICA
        When "APRES_MOD"         : Gosub REPLICA
        When "CREATION"         : Gosub REPLICA
        When "AVANTBOUT"           : Gosub AVANTBOUT
        When "VERIF_CRE"           : Gosub VERIF_CRE
 When Default
Endcase
Return

$AVANTBOUT
If BOUT = "h"

  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PAR簍ETRO SPEBIS
   Local Char ZPARSCANFI(250) : ZPARSCANFI =func AFNC.PARAM("ZPARSCANFI","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARSCANFI + nomap + "&usr=" + GUSER + "&id=" + [M]NUM + "&cpy=" + [M]CPY + "&act=add",
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Endif
Return

$FILGAUCHE
    FILGAUSUP="1=1"
    If ILIS=1
        FILGAUSUP += "&find([F:DAE]FCYLIN,GUSRFCY(1..GNBAUZ))"
    Endif
Return

$REPLICA
Local Char TYPO

If dim([M:HAE0]TYP)> 0
    TYPO =[M:HAE0]TYP
Else
      TYPO =[M:HAE1]TYP
Endif

If TYPO = 'CCD' Then
  Local File ZSASTO [ZAL]
  Local File GACCENTRYD [ZAL2]

  [ZAL]NUM = [M]NUM
  [ZAL]FECHA = [M]ACCDAT
  [ZAL]EMPRESA = [M]FCY

  Filter [ZAL2] Where NUM = [M]NUM
  For [ZAL2]
    If [ZAL2]SNS = 1 Then
      [ZAL]CTA_BCO = [ZAL2]ACC
      [ZAL]IMPORTE = [ZAL2]AMTCUR
    Else
      [ZAL]CTA_TRA = [ZAL2]ACC
    Endif
  Next
  If [ZAL]IMPORTE<>0  :  Write [ZAL]  : Endif
  Filter [ZAL2]

  Close Local File [ZAL]
  Close Local File [ZAL2]
Endif
If TYPO = 'AMT' or TYPO = 'SEG'  or TYPO = 'FPR' Then
  Local File ZASTOINM [ZAQ]
  ## PRIMERO DEBO BORRAR INFORMACION PREVIA SI LA HAY
  Delete [ZAQ]Where NUM = [M:HAE0]NUM
  Filter [DAE] Where NUM = [M:HAE0]NUM and LEDTYP = 1
  For [DAE]
    Local Char CUENTA
    Local Integer SENTIDO
    Local Integer LINEA
    LINEA = [DAE]LIN
    SENTIDO = [DAE]SNS
    CUENTA = [DAE]ACC
    Filter [DAA] Where NUM = [M:HAE0]NUM and LIN = LINEA
    For [DAA]
      Local Char EJE0
      Local Char EJE1
      Local Char EJE2
      Local Char EJE3
      Local Char EJE4
      Local Char EJE5
      Local Char EJE6
      Local Char EJE7
      Local Char EJE8
      Local Double IMPORTE

      IMPORTE = [DAA]AMTLED * SENTIDO
      EJE0 = [DAA]CCE(0)
      EJE1 = [DAA]CCE(1)
      EJE2 = [DAA]CCE(2)
      EJE3 = [DAA]CCE(3)
      EJE4 = [DAA]CCE(4)
      EJE5 = [DAA]CCE(5)
      EJE6 = [DAA]CCE(6)
      EJE7 = [DAA]CCE(7)
      EJE8 = [DAA]CCE(8)

      Local Double ACUM
      Filter [ZAQ] Where NUM = [M:HAE0]NUM and ACC = CUENTA and CCE(0) = EJE0 and CCE(1) = EJE1 and CCE(2) = EJE2 and CCE(3) = EJE3 and CCE(4) = EJE4 and CCE(5) = EJE5 and CCE(6) = EJE6 and CCE(7) =
& EJE7 and CCE(8) = EJE8
      For [ZAQ]
        ACUM = ACUM +[ZAQ]AMTRPT
      Next
      If ACUM = 0
        [ZAQ]TYP = [DAE]TYP
        [ZAQ]NUM = [DAE]NUM
        [ZAQ]CNA = CUENTA
        [ZAQ]ACCDAT = [DAE]ACCDAT
        [ZAQ]CCE(0) = EJE0
        [ZAQ]CCE(1) = EJE1
        [ZAQ]CCE(2) = EJE2
        [ZAQ]CCE(3) = EJE3
        [ZAQ]CCE(4) = EJE4
        [ZAQ]CCE(5) = EJE5
        [ZAQ]CCE(6) = EJE6
        [ZAQ]CCE(7) = EJE7
        [ZAQ]CCE(8) = EJE8
        [ZAQ]AMTRPT = IMPORTE
        Write [ZAQ]
      Else
        [ZAQ]AMTRPT = ACUM + IMPORTE
        Rewrite [ZAQ]
      Endif
    Next
  Next
Filter [DAE]
Filter [DAA]

  Close Local File [ZAQ]
Endif

Return

#################################################################################################
##AUREN.STR 11-11-2021 CREACI粍 ASIENTOS WS SI CAMPO FLGFUP O FLGPAZ SON = 0 INTRODUCIMOS EL DATO
#################################################################################################
$VERIF_CRE
If GWEBSERV
  If [M:HAE0]TYP="ABP" or [M:HAE0]TYP="FAP" Then
      If [M:HAE1]FLGFUP=0 Then
        [M:HAE1]FLGFUP=2
      Endif
      If [M:HAE1]FLGPAZ=0 Then
        [M:HAE1]FLGPAZ=1
      Endif
  Else
      If [M:HAE1]FLGFUP=0 Then
        [M:HAE1]FLGFUP=2
      Endif
      If [M:HAE1]FLGPAZ=0 Then
        [M:HAE1]FLGPAZ=4
      Endif
  Endif
Endif
##################################################################
Return
###################################################################################################
##AUREN.FIN
###################################################################################################
