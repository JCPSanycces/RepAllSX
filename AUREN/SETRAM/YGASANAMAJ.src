#<AdxTL>@(#)0.0.0.0 $Revision$ 
#AUREN PU9
# Cambio de estructura de GACCENTRYA y GACCENTRYD
# Campos LIG y ANALIG por LIN y ANALIN
# Los Ýndices contienen el campo LEDTYP con valor 2
#AUREN PU9
#####################################################################################
# Fuente: YGASANAMAJ
#    Modificaciˇn de Distribuciˇn AnalÝtica en Asientos Contables
#-------------------------------------------------------------------------------------
# CodAct: YMRA01
#-------------------------------------------------------------------------------------
# Proyecto: SETRAM
#-------------------------------------------------------------------------------------
# Version: v5
#-------------------------------------------------------------------------------------
# Fecha: 2011/03/18
#  2010/10/11
#        2010/01/28
#        2009/10/26
#-------------------------------------------------------------------------------------
# Desarrollador: MRA
#-------------------------------------------------------------------------------------
# Notas: Lista de Notas
# WebServices -  Esta es una rutina que puede ser llamada desde WebServices
#-------------------------------------------------------------------------------------
# Descripciˇn:
#   La funciˇn YGASANAMAJ que permite Modificar la distribuciˇn AnalÝtica para un Asiento Contable
#
#   En SETRAM, la estructura del plan de cuentas esta definida de tal forma que cada cuenta general
#    de grupo 6 y 7 tiene relaciˇn con una ˙nica cuenta analÝtica.
#   Las lineas de asiento que requieran distribuciˇn ya tendrßn informada la cuenta analitica CNA desde el momento de su creaciˇn.
#   Lo que deberß hacer la funciˇn es modificar la distribuciˇn analÝtica de la lÝnea introduciendo una nueva distribuciˇn analÝtica
#
#   Restricciones:
#    - Se deben pasar los datos ordenados de forma Ascendente por [Linea Factura / Linea AnalÝtica / Eje AnalÝtico]
#    - Al procesar un valor de LÝneaAsiento=0 o LÝneaAnalÝtica=0 no contin˙a recorriendo el array, es decir aunque declaremos un
#   array W2LINANA de 9999 elementos cuando encuentre un W2LINANA(K)=0 se considera el fin de las ordenes a procesar
######################################################################################

$TEST
# AUREN - TEST PRUEBAS - CONTROL EJES ANAL═TICOS

#    Asiento "PAG-MAD05070004",
#    queremos modificar las asignaciones analÝticas de la segunda y cuarta lÝneas de un asiento contable
#    de manera que tenga hasta 3 detalles analÝticos
#    y se informen los siguientes ejes analÝticos
#    LINEA FACTURA | LINEA ANALITICA | EJE ANALITICO |
#            2     |       1         |      1        |
#            2     |       1         |      3        |
#            2     |       2         |      1        |
#            2     |       2         |      3        |
#            2     |       2         |      4        |
#            4     |       1         |      2        |
#            4     |       1         |      3        |

Local Char    L1TYP
Local Char    L1NUM
Local Integer L2LINASS     (9999)
Local Integer L2LINANA     (9999)
Local Decimal L2AMTX       (9999)
Local Integer L2EJEANA     (9999)
Local Char    L2CCEX   (15)(9999)

Local Integer K

L1TYP             ="ODG"
L1NUM             ="001-18-018550"

Raz K

    L2LINASS(K) =2 : L2LINANA(K) =1 : L2EJEANA(K) =1 : L2AMTX(K)=  10.00   : L2CCEX(K)="0105"   : K+=1
    #la secciˇn 0103 no existe en el eje 4 -> darß error
    L2LINASS(K) =2 : L2LINANA(K) =1 : L2EJEANA(K) =4 : L2AMTX(K)=  10.00   : L2CCEX(K)="0103"   : K+=1

    L2LINASS(K) =2 : L2LINANA(K) =2 : L2EJEANA(K) =1 : L2AMTX(K)=  75.00   : L2CCEX(K)="0106"   : K+=1
    L2LINASS(K) =2 : L2LINANA(K) =2 : L2EJEANA(K) =4 : L2AMTX(K)=  75.00   : L2CCEX(K)="1005"   : K+=1
    L2LINASS(K) =2 : L2LINANA(K) =2 : L2EJEANA(K) =5 : L2AMTX(K)=  75.00   : L2CCEX(K)="9004"   : K+=1

    L2LINASS(K) =2 : L2LINANA(K) =3 : L2EJEANA(K) =1 : L2AMTX(K)=  15.00   : L2CCEX(K)="0000"   : K+=1


Local Integer LERR            : Raz LERR
Local Char    LERRSTR(250)    : Raz LERRSTR

Call YGASANAMAJ(L1TYP,L1NUM,LERR,LERRSTR,L2LINASS,L2LINANA,L2EJEANA,L2AMTX,L2CCEX)
If LERR : Infbox num$(LERR)-":"-LERRSTR
Else
    Infbox("Todo OK")
Endif
TRA=1
End


######################################################################################
# Procedimiento: YGASANAMAJ
Subprog YGASANAMAJ(W1TYP,W1NUM,WERR,WERRSTR,W2LINASS,W2LINANA,W2EJEANA,W2AMTX,W2CCEX)
#-------------------------------------------------------------------------------------
# Variables: Parametros
# W1TYP    - Val - Char         - Tipo de Asiento Contable
# W1NUM    - Val - Char         - N˙mero de Asiento
# WERR     - Variable - Integer - Cˇdigo de Error
# WERRSTR  - Variable - Char()  - Mensage de Error
# W2LINASS - Val - Integer      - Array de N˙meros de Linea de Asiento a afectar
# W2LINANA - Val - Integer      - Array de N˙meros de Linea AnalÝtica
# W2AMTX   - Val - Decimal      - Array de Importes de las lÝneas analÝticas
# W2EJEANA - Val - Integer      - Array de Ejes analÝticos a afectar
# W2CCEX   - Val - Char (15)    - Array de Secciones AnalÝticas
#-------------------------------------------------------------------------------------
# Descripciˇn:
# El programa ira a modificar la(s) linea(s) de asiento W1TYP indicada(s) en W2LINASS
# a˝adiendo las lÝneas analÝticas W2LINANA
# , devolviendo si hay error WERR>0 y un mensaje de error en WERRSTR
#
# Restricciones:
#    - Se deben pasar los datos ordenados de forma Ascendente por [Linea Factura / Linea AnalÝtica / Eje AnalÝtico]
#    - Al procesar un valor de LÝneaAsiento=0 o LÝneaAnalÝtica=0 no contin˙a recorriendo el array, es decir aunque declaremos un
#   array W2LINANA de 9999 elementos cuando encuentre un W2LINANA(K)=0 se considera el fin de las ordenes a procesar
#-------------------------------------------------------------------------------------
# Notas: Cˇdigos de Error devueltos
# WERR=1 : WERRSTR="Ficha en Modo Consulta"
# WERR=2 : WERRSTR="El Asiento Contable"-W1TYP-W1NUM-"no existe!"
# WERR=3 : WERRSTR="Los importes no cuadran!"
# WERR=4 : WERRSTR="No puedo bloquear el registro"-W1TYP-W1NUM-"para modificarlo"
# WERR=5 : WERRSTR="Parßmetros incorrectos: Dim(W1LIG)<>Dim(W2AMT,1)<>Dim(W2CCE,1)
# WERR=6 : N.A.
# WERR=7 : N.A.
# WERR=8 : WERRSTR="No se pueden modificar los desgloses analÝticos del Asiento"-W1TYP-W1NUM-"!"
# WERR=9 : N.A.
# WERR=10: WERRSTR= GMESSAGE tras el control sobre la Secciˇn introducida
# WERR=11: WERRSTR="N˙meo de LÝnea incorrecto!, parßmetro W1LIG("-num$(LF)")"
# WERR=12: WERRSTR="La Cuenta"-[F:DAE]ACC-"no tiene Natulaleza AnalÝtica Asociada!"
# WERR=13: WERRSTR="La Cuenta"-[F:DAE]ACC-"no existe!"
# WERR=14: WERRSTR="La Cuenta"-[F:DAE]ACC-"no permite la Cuenta AnalÝtica"-[F:GAC]CNA-"!"
# WERR=15: WERRSTR="Error en la conversiˇn de divisas!"
# WERR=16: WERRSTR="Periodo analÝtico no abierto"
# WERR=98 :WERRSTR="Parametros W2* deben tener mismo n˙mero de elementos!"
#####################################################################################
Value Char       W1TYP
Value Char       W1NUM
Variable Integer WERR
Variable Char    WERRSTR
Value Integer W2LINASS  ()
Value Integer W2LINANA  ()
Value Integer W2EJEANA  ()
Value Decimal W2AMTX    ()
Value Char    W2CCEX  ()()

Local Integer WDIMASS,WDIMANA

    Raz WERR, WERRSTR :    WERR=0
    WDIMASS=dim(W2LINASS)
    WDIMANA=dim(W2LINANA)
    If WDIMANA<>WDIMASS or WDIMANA<>dim(W2EJEANA) or WDIMANA<>dim(W2CCEX) or WDIMANA<>dim(W2AMTX)
        WERR=98 : If WERR : Goto NOEJECUTES : Endif
    Endif

    Raz WERR, WERRSTR

    Gosub DEFINE
    Gosub PRECHECK : If WERR : Goto NOEJECUTES : Endif
    Gosub VERROU   : If WERR : Goto NOEJECUTES : Endif

    Gosub TR       :  If WERR : Goto ABORTA     : Endif # Actualizar AnalÝtica

$ABORTA
    Gosub DEVERROU
$NOEJECUTES
    If WERR=0  and GOK=1 : WERRSTR-="OK" : Endif
End

######################################################################################
$DEFINE
    If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif :
    If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif :#HAE0=TYP;NUM
    If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif :#DAE0=TYP;NUM;LIG;LEDTYP
    If clalev([F:DAA])=0 : Local File GACCENTRYA [DAA] : Endif :#DAA2=TYP;NUM;LIG;ANALIG;LEDTYP
    If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif :#GAC0=ACC
    If clalev([F:PER])=0 : Local File PERIOD   [PER] : Endif

    If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
    If clalev([F:BLA])=0 : Local File BALANA     [BLA] : Endif

    If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif

    Local Char    WFCY
    Local Integer SAVCONS
    Local Char    SYMBHAE(35)
    Local Integer I,J, STAT
Return

######################################################################################
$PRECHECK
    Read [F:HAE]HAE0=W1TYP;W1NUM
    If fstat
        WERR=2 : WERRSTR-="El Asiento Contable"-W1TYP-W1NUM-"no existe!" : Return
    Else
      Filter [PER] Where LEDTYP = 2 and PERSTA = 2 and  [F:HAE]ACCDAT >=PERSTR and [F:HAE]ACCDAT <=PEREND
      Read [PER]PER0 First
      If fstat
          WERR=16 : WERRSTR-="El periodo analÝtico no se encuentra abierto" : Return
      Endif
    Endif

    WFCY=[F:HAE]FCY
    SAVCONS=GCONSULT

Return

######################################################################################
# Seccion: Gestiˇn Bloqueos
######################################################################################
$VERROU
#HAEPAG-MUR05030011\PAG
[L]SYMBHAE = "HAE"+[F:HAE]NUM+"\"+[F:HAE]TYP
Lock =SYMBHAE With lockwait=0
If fstat
 WERR=4 : WERRSTR-="No puedo bloquear el registro"-W1TYP-W1NUM-"para modificarlo" : Return
Endif
Return

######################################################################################
$DEVERROU
Unlock =SYMBHAE
Return

######################################################################################
# Seccion: Transaccionalidad
######################################################################################
$TR
    GOK = 1
    Trbegin [HAE],[DAE],[DAA]

     Call VALPCE(-1,[F:HAE]TYP,[F:HAE]NUM) From CPTBAL #Balance

     Gosub TRT

     Call VALPCE(1,[F:HAE]TYP,[F:HAE]NUM) From CPTBAL #Balance

     If   GOK<0 : Goto ROLL_TR
     Elsif !GOK : Goto AB_TR
     Endif
    Commit
Return
######################################################################################
$AB_TR
    Rollback
Return

######################################################################################
$ROLL_TR
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR : Endif

######################################################################################
# Seccion: Tratamiento de Actualizaciˇn
######################################################################################
$TRT
    Local Integer WASS
    Local Decimal WAMTCHK
    Local Char VALOR(30)
    Local Mask VENTILE2 [VT2]
    Local Integer LFSTAT
    Local Integer W2LINANA_Z : Raz W2LINANA_Z

    For WASS=0 To WDIMASS-1  :#Lineas Asiento Contable
           Break(W2LINASS(WASS)=0 or W2LINANA(WASS)=0)
           Readlock [F:DAE]DAE0=W1TYP;W1NUM;W2LINASS(WASS);2
            If fstat=1
             GOK=-1 : GLOCK="$GACCENTRYD"-W1TYP-W1NUM-num$(W2LINASS(WASS))-num$(2) : Break
            Elsif fstat
             GOK=0 : Call RSTA("DAE",W1TYP-W1NUM-num$(W2LINASS(WASS))-num$(2)) From GLOCK
             WERR=11: WERRSTR-="N˙meo de LÝnea incorrecto!, parßmetro W1LIG("-num$(W2LINASS(WASS))-")" : Break
            Endif

           [F:DAE]DSP=""

           Rewrite [F:DAE]
            If fstat
             GOK=0 : Call FSTA("DAE") From GLOCK : Break
            Endif

           Delete [F:DAA] Where TYP=W1TYP and NUM=W1NUM and LIN=[F:DAE]LIN and LEDTYP = 2
            If fstat=1
             GOK=-1 : GLOCK="$GACCENTRYDA"-W1TYP-W1NUM-num$([F:DAE]LIN)-num$(2) : Break
            Endif

    Next WASS
    If WERR>0 or GOK<>1 : Return  : Endif

    For WASS=0 To WDIMASS-1  :#Lineas Asiento Contable

           Break(W2LINASS(WASS)=0 or W2LINANA(WASS)=0)
           If W2CCEX(WASS)="" : Goto SALTALINEA : Endif

           Readlock [F:DAE]DAE0=W1TYP;W1NUM;W2LINASS(WASS);2
            If fstat=1
             GOK=-1 : GLOCK="$GACCENTRYD"-W1TYP-W1NUM-num$(W2LINASS(WASS))-num$(2) : Break
            Elsif fstat
             GOK=0 : Call RSTA("DAE",W1TYP-W1NUM-num$(W2LINASS(WASS))-num$(2)) From GLOCK
             WERR=11: WERRSTR-="N˙meo de LÝnea incorrecto!, parßmetro W1LIG("-num$(W2LINASS(WASS))-")" : Break
            Endif

           #Comprobamos que la Cuenta Contable tenga Naturaleza AnalÝtica
           Read [F:GAC]GAC0=[F:DAE]COA;[F:DAE]ACC
           If fstat
               WERR=13: WERRSTR-="La Cuenta"-[F:DAE]ACC-"no existe!" : Break
#          Elsif ([F:GAC]CNA="" and [F:GAC]CNASCR="")
#              WERR=12: WERRSTR-="La Cuenta"-[F:DAE]ACC-"no tiene Natulaleza AnalÝtica Asociada!" : Break
#          Else
#               #Control de si la cuenta analitica es valida para esta cuenta contable
#               VALOR=[F:GAC]CNA
#               mkstat=0
#               Call CONTCNA(VALOR,[F:DAE]FCYLIN,[F:HAE]ACCDAT,[F:DAE]ACC) From SUBGA1
#               If mkstat<>0
#                   WERR=14: WERRSTR-="La Cuenta"-[F:DAE]ACC-"no permite la Cuenta AnalÝtica"-[F:GAC]CNA-"!" : Break
#               Else
#                   [F:DAE]CNA=VALOR
#               Endif
           Endif

           Read [CPY]CPY0=[F:HAE]CPY

            #LÝneas AnalÝtica
           Raz [F:DAA]
           Readlock [F:DAA]DAA0=W1TYP;W1NUM;W2LINASS(WASS);2;W2LINANA(WASS)
           LFSTAT=fstat
           [F:DAA] = [F:HAE]
           [F:DAA] = [F:DAE]
		   [F:DAA]DIE(0) = 'AX1'
		   [F:DAA]DIE(1) = 'AX2'
		   [F:DAA]DIE(2) = 'AX3'
		   [F:DAA]DIE(3) = 'AX4'
		   [F:DAA]DIE(4) = 'AX5'
		   [F:DAA]DIE(5) = 'AX6'
		   [F:DAA]DIE(6) = 'AX7'
		   [F:DAA]DIE(7) = 'AX8'
		   [F:DAA]DIE(8) = 'AX9'
           Gosub SAIVT2 : If WERR>0 or GOK<>1 : Break : Endif

           [F:DAA]LIN    = W2LINASS(WASS)
           [F:DAA]ANALIN = W2LINANA(WASS)

           [F:DAA]AMTCUR = [M:VT2]TBAMT([M:VT2]PTVENT-1)
           #[F:DAA]AMTLED = AMTCUR

           # AUREN - 5.800.308 - CORRECCIË CONVERSIË DIVISES
           Call CONVERT([F:DAE]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[F:HAE]TYPRAT,[F:HAE]RATDAT,[F:DAA]AMTCUR,[F:DAA]AMTLED,STAT) From TRTDEV

           If STAT : WERR=15: WERRSTR-="Error en la conversiˇn de divisas!" : Break : Endif
           [F:DAA]QTY = [M:VT2]TBQTY([M:VT2]PTVENT-1)

          # Eje analitico
           [F:DAA]CCE(W2EJEANA(WASS)-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"([M:VT2]PTVENT-1)")

           If LFSTAT
               Write [DAA]
           Else
               Rewrite [DAA]
           Endif
           If fstat
            GOK = 0 : Call FSTA("DAA") From GLOCK : Break
           Endif
$SALTALINEA
    Next WASS

    If GOK<>1 : WERR=8 : WERRSTR-="No se pueden modificar los desgloses analÝticos del Asiento"-W1TYP-W1NUM-"!" : Return : Endif
    If WERR>0 : GOK=-1 : Return : Endif

    #Comprobar que cuadre por importe el importe linea=suma importes de su analitica
    For [F:DAE]DAE0(3) Where TYP=W1TYP and NUM=W1NUM
        #Para cada linea de asiento
        WAMTCHK=0
        For [F:DAA]DAA0 Where TYP=[F:DAE]TYP and NUM=[F:DAE]NUM and LIN=[F:DAE]LIN
            #Recorro todos sus detalles analÝticos
            WAMTCHK+=[F:DAA]AMTCUR
        Next
        If [F:DAE]AMTCUR<>WAMTCHK and WAMTCHK<>0
                WERR=3 : WERRSTR-="Los importes no cuadran!"-num$(WAMTCHK)-"<>"-num$([F:DAE]AMTCUR) : Break
        Endif
    Next

    If GOK<>1 : WERR=8 : WERRSTR-="No se pueden modificar los desgloses analÝticos del Asiento"-W1TYP-W1NUM-"!" : Endif
    If WERR>0 : GOK=-1 : Endif

Return

$SAIVT2

    Local Char VALOR(30)
    Local Integer AXE
    Local Integer NEWASSFLG, NEWANAFLG #Marcan nueva lÝnea asiento y nueva lÝnea analÝtica
    Raz NEWASSFLG, NEWANAFLG

    If WASS=0
        NEWASSFLG=2 : NEWANAFLG=2
    Else
        If W2LINANA(WASS)>W2LINANA(WASS-1) : NEWANAFLG=2 : Endif
        If W2LINASS(WASS)>W2LINASS(WASS-1) : NEWASSFLG=2 : NEWANAFLG=0 : Endif
    Endif

    If W2CCEX(WASS)<>""

        If  NEWASSFLG=2 & NEWANAFLG=2
            #inicializo detalles analÝticos
            Raz [M:VT2]
            [M:VT2]PTVENT +=1
        Elsif  NEWASSFLG=0 & NEWANAFLG=2
            #misma linea asiento, nueva lÝnea analÝtica
            [M:VT2]PTVENT +=1
        Elsif NEWASSFLG=0 & NEWANAFLG=0
            #misma linea asiento, nuevo detalle misma lÝnea analÝtica
        Else # NEWASSFLG=2 & NEWANAFLG=0
            #nueva linea asiento
            Raz [M:VT2]
            [M:VT2]PTVENT +=1
        Endif
        W2LINANA_Z     = W2LINANA(WASS)

        [M:VT2]TBAMT([M:VT2]PTVENT-1)=W2AMTX(WASS)
        [M:VT2]TBQTY([M:VT2]PTVENT-1)=0

        AXE    = W2EJEANA(WASS)
        VALOR  = W2CCEX(WASS)
        Assign ("[M:VT2]TBCCE"+num$(AXE)+"([M:VT2]PTVENT-1)") With VALOR

##BUG007
        Local Char WTCPY(GLONCPY)
        WTCPY=[F:CPY]CPY
        mkstat=0
#        Assign "[M]CCE("+num$(AXE)+")" With evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT-1)+")")
#        Call CONTCCE(VALOR,AXE,[F:HAE]FCY,[F:HAE]ACCDAT,[F:DAE]CNA,"[M]TBCCE#",W2LINANA(WASS)-1) From SUBGA1
#        If mkstat=2 : WERR=10 :WERRSTR-="La Secciˇn AnalÝtica"-VALOR-"no existe para el eje"-num$(AXE) : Return : Endif
#        If clalev([F:CPY])<=0 : Local File COMPANY [CPY] : Endif
#        Read [F:CPY]CPY0=WTCPY

        # AUREN - 05.917.848 - Control secciones analÝticas
        Local Char ZDIE(10)
        ZDIE = "AX" + num$(AXE)
        Read [F:CCE]CCE0=ZDIE;VALOR
        If fstat
          WERR=10 : WERRSTR-="La Secciˇn AnalÝtica"-VALOR-"no existe para el eje"-num$(AXE)
          Return
        Endif
        # AUREN - 05.917.848 - Control secciones analÝticas

    Endif

Return





