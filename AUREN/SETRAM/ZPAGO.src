####################################################################################################################
# Fuente: ZPAGO
#    Realizar Pagos
#-------------------------------------------------------------------------------------
# CodAct: Z17
#-------------------------------------------------------------------------------------
# Proyecto: SETRAM
#-------------------------------------------------------------------------------------
# Version: v1
#-------------------------------------------------------------------------------------
# Fecha: 
#-------------------------------------------------------------------------------------
# Desarrollador: JMD
#-------------------------------------------------------------------------------------
# Notas: 
# WebServices -  Esta es una rutina que puede ser llamada desde WebServices
#-------------------------------------------------------------------------------------
# Descripcion:
#   La funcion ZPAGO permite Crear un pago
#   Se adjunta justo aqui debajo un TEST a modo de ejemplo de utilizacion de los parametros
#   (mas abajo en este fuente se declara la funcion y se describen sus parametros)
#
####################################################################################################################


$TEST

Local Char       LPAYLOT
Local Char       LPAYTYP
Local Char       LBPR
Local Char       LFCY
Local Date       LACCDAT
Local Char       LBAN
Local Char       LNUM

Local Integer    LERRCOD
Local Char       LERRSTR (250) 
 
Local Char       L2VCRTYP    (3)(9999)  
Local Char       L2VCRNUM    (15)(9999)
Local Integer    L2DUDNUM    (9999) 
Local Integer    L2DUDLIG    (9999) 
Local Decimal    L2AMTLIN    (9999)

Local Integer K

    LPAYLOT = ""
    LPAYTYP = "PBCO"   

    LBPR = "3240"
    LFCY = "ORCAR"
    LACCDAT = [31/12/2009]  
    LBAN = "008122P"   

    Raz K
    Raz LERRCOD

    L2VCRTYP (K)= "FAP"  :   L2VCRNUM (K)= "022-09-004558"  : L2DUDNUM(K)=13565: L2DUDLIG(K)= 1 : L2AMTLIN(K)=1 : K+=1  
   

    Call ZPAGO (LPAYLOT, LPAYTYP,LBPR,LFCY,LACCDAT,LBAN,LNUM, LERRCOD,LERRSTR,L2VCRTYP, L2VCRNUM,L2DUDNUM,L2DUDLIG,L2AMTLIN)
    If LERRCOD: Infbox num$(LERRCOD)-":"-LERRSTR
    Else 
        Infbox("Todo OK:" - LNUM)
    Endif

End

####################################################################################################################

# Procedimiento: ZPAGO
Subprog ZPAGO (WPAYLOT, WPAYTYP,WBPR,WFCY,WACCDAT,WBAN, WNUM, WERRCOD,WERRSTR,W2VCRTYP,W2VCRNUM,W2DUDNUM,W2DUDLIG,W2AMTLIN)
#--------------------------------------------------------------------------------------------------------------
# Variables: Parametros ENTRADA
#    
# WPAYLOT  - Val - Char         - Cód Lote
# WPAYTYP  - Val - Char         - Transacción
# WBPR     - Val - Char         - Tercero
# WFCY     - Val - Char         - Planta
# WACCDAT  - Val - Date         - Fecha Contable
# WBAN     - Val - Char         - Banco
# 
# W2VCRTYP - Val - Char         - Array Tipo Asientos
# W2VCRNUM - Val - Char         - Array de Asientos
# W2DUDNUM - Val - Integer      - Array de Numero interno de la línea 
# W2DUDLIG - Val - Integer      - Array de Numero de Vencimientos
# W2AMTLIN - Val - Decimal      - Array de Importes
# 
# Variables: Parametros RETORNO
#
# WNUM       - Variable - Char    - Numero del pago creado
# WERRCOD    - Variable - Integer - Codigo de Error
# WERRSTR    - Variable - Char    - Mensaje de Error
#--------------------------------------------------------------------------------------------------------------
# Notas: Codigos de Error devueltos
#
# WERRCOD=0 : Ejecución correcta
# WERRCOD=1 : WERRSTR = No existe ruta para el fichero de importación
# WERRCOD=2 : WERRSTR = Error en la ejecución del modelo de importación
###################################################################################################################


Value Char       WPAYLOT
Value Char       WPAYTYP
Value Char       WBPR
Value Char       WFCY
Value Date       WACCDAT
Value Char       WBAN

Variable Char    WNUM
Variable Integer WERRCOD
Variable Char    WERRSTR 

Value Char       W2VCRTYP    ()()
Value Char       W2VCRNUM    ()()
Value Integer    W2DUDNUM    () 
Value Integer    W2DUDLIG    () 
Value Decimal    W2AMTLIN    ()

Local    Char     LSEP               : LSEP      = "|"
Local    Char     RUTA(250)
Local    Char     ZFICHERO_PAG(250) 

Local Integer WDIMVEN

    WDIMVEN=dim(W2VCRNUM )

    If WERRCOD = 0
        # Crear el fichero de importación para su posterior tratamiento
        Gosub CREAR_FICHERO
        If WERRCOD = 0
            # Ańadir los datos de cabecera
            Gosub CREAR_LINEA_CABECERA_PAGO
            If WERRCOD = 0
                 # Ańadir los datos de Ls lineas del pago
                 Gosub CREAR_LINEAS_PAGO
                 If WERRCOD = 0
                    # Realizar la importación del fichero para generar el pago                
                    Call IMPSILEN ("ZPAGO",ZFICHERO_PAG)                    
                    If WERRCOD = 0
                        # Obtener el nombre del pago realizado
                        Gosub DEVOLVER_NUM_PAGO_CREADO
                    Endif
                 Endif   
            Endif
        Endif
    Endif

End

######################################################################################
#
#    Z17- Crear fichero importación
#
######################################################################################
$CREAR_FICHERO

    If clalev([F:APX])=0 : Local File APARIMPEXP   [APX] : Endif

    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
    Read [APX]APX0 = 'REPIMPDEF'
    If fstat 
        Raz [F:APX]
        WERRCOD = 1
        WERRSTR = "No existe ruta para el fichero de importación"
        
    Else     
    
        RUTA = [F:APX]DIRECTORY
        RUTA = left$(RUTA,len(RUTA)-1)    
        Raz ZFICHERO_PAG
        ZFICHERO_PAG = filpath(RUTA,num$(adxuid(1))+"_ZPAGO","TXT")    
        LSEP = '|'    
        Openo ZFICHERO_PAG,0 Using [ZPAG]    
        
   Endif

Return
######################################################################################



######################################################################################
#
#    Z17- Crear linea de cabecera en el fichero de importación
#
######################################################################################

$CREAR_LINEA_CABECERA_PAGO

                Wrseq 'P|' + WPAYLOT + LSEP + WPAYTYP + LSEP + WBPR + LSEP + WFCY + LSEP + 
&                WACCDAT + LSEP +  num$(adxuid(1)) + LSEP + WBAN + chr$(013) Using [ZPAG]


Return
######################################################################################

######################################################################################
#
#    Z17- Crear las linea de los vencimientos en el fichero de importación
#
######################################################################################
$CREAR_LINEAS_PAGO

    For I=0 To WDIMVEN-1
        If len(W2VCRNUM (I) )= 0
             Break 
        Else
                        Wrseq 'D|'+ W2VCRTYP(I) + LSEP + W2VCRNUM(I) + LSEP + num$(W2DUDNUM(I)) + LSEP + 
&               num$(W2DUDLIG(I)) + LSEP + num$(W2AMTLIN(I)) + chr$(013) Using [ZPAG]

        Endif
    Next


Return
######################################################################################

######################################################################################
#
#    Z17- Realizar el proceso de umportación para crear el pago
#
######################################################################################
######################################################################################
######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN(MODELE,NOMFICH)
    Value Char MODELE
    Value Char NOMFICH
    
    
    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")
    Local Char MESSAGE(100)

    Openo  Using [ZPAG]

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ

    If GERRTRACE <> 0
        WERRCOD= 3
        WERRSTR = "Error en la ejecución del modelo de importación"  

    Endif

End
############################################################################################################################################################################


######################################################################################
#
#    Z17- Si el pago se ha creado correctamente, devuelve el número del pago
#
######################################################################################

$DEVOLVER_NUM_PAGO_CREADO

    Raz WNUM

    If clalev([F:PYH])<=0  
         Local File PAYMENTH [PYH]  
    Endif
    
    For [PYH]PYH2 Where (REF=num$(adxuid(1)))
        WNUM = [F:PYH]NUM
        Break
    Next

    
    If WNUM = ""
        WERRCOD= 3
        WERRSTR = "Error en la ejecución del modelo de importación"    
    Else
        Update [PYH] Where (REF=num$(adxuid(1))) With REF = ""
    Endif

    If clalev([F:PYH])>0   
             Close Local File [PYH]   
    Endif

End
