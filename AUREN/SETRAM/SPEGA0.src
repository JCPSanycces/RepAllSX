#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Gestión de la máscara GACCENT2 (Especifico)

#AUREN - PU9
$ACTION
Case ACTION
 When Default
Endcase
Return
#AUREN - PU9

Subprog APRES_NBLIG
Local Char TERMINACION
Local Char CUENTA
Local Integer MODIFCOLECTIVO
Local Integer ERRORCOLECTIVO



    #### Si se trata de un asiento modelo: No se ha de modificar el colectivo
   #AUREN - PU9
   If dim([M:HAE0]CAT)>0
   #AUREN - PU9
    If [M:HAE0]CAT = 5
        End
    Endif
   #AUREN - PU9
  Endif
   #AUREN - PU9
    Gosub SETNOL


     #SÃƒÂ³lo en interactivo
     If !GIMPORT & GWEBSERV <> 2
          #AUREN - PU9
        #If ([M]SAC(NOL)<>"" & [M]BPR(NOL)<>"" & [M]FCYLIN(NOL)<>"" )
        If ([M]SAC1(NOL)<>"" & [M]BPR(NOL)<>"" & [M]FCYLIN(NOL)<>"" )
          #AUREN - PU9

         #Obtener la sociedad a la que pertenece la planta
          If clalev([F:FC1])=0
             Local File FACILITY[FC1]
          Endif
          Read [F:FC1] FCY0=[M]FCYLIN(NOL)
          If    fstat=0
          #AUREN - PU9
               #Call TERMINACION_COLECTIVO([F:FC1]LEGCPY, [M]BPR(NOL), [M]SAC(NOL), TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT
               Call TERMINACION_COLECTIVO([F:FC1]LEGCPY, [M]BPR(NOL), [M]SAC1(NOL), TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT
          #AUREN - PU9
               If ERRORCOLECTIVO = 1

                    Call ERREUR("Error en Terminación colectivo. Revise la configuración.") From GESECRAN
                    mkstat=2

               Else

                    If len(TERMINACION) > 0   or  MODIFCOLECTIVO = 1

                        # Si hay terminaciÃƒÂ³n: aÃƒÂ±adirla al colectivo
                        #AUREN - PU9
                        #[M]SAC(NOL) =  [M]SAC(NOL)+ TERMINACION
                        #Affzo  [M]SAC(NOL)
                        #[M]ACC(NOL) =  CUENTA
                        #Affzo  [M]ACC(NOL)
                        [M]SAC1(NOL) =  [M]SAC1(NOL)+ TERMINACION
                        Affzo  [M]SAC1(NOL)
                        [M]ACC1(NOL) =  CUENTA
                        Affzo  [M]ACC1(NOL)
                        #AUREN - PU9

                        Infbox "Colectivo/Cuenta modificado." Titled "Información"
                    Endif
               Endif
            Endif

        Endif

    Endif
End



$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla GACCENT2) 23/01/2017 11:47:13 (ADMIN)
######################################################################################
Subprog C_NBLIG

 Call APRES_NBLIG()
End


######################################################################################

######################################################################################
## Botón Ver PDF
######################################################################################
Subprog IB_NBLIG
  If ([M]ACC1(nolign-1)<>"" and left$([M]ACC1(nolign-1),3)<>"572" and left$([M]ACC1(nolign-1),3)<>"520") or [M]ACC1(nolign-1)=""
    Raz GBOUT20
  Endif
End

Subprog IB_FCYLIN
 Call APRES_NBLIG()
End

Subprog C_FCYLIN(VALEUR)
Variable Char    VALEUR()
 Call APRES_NBLIG()
End


