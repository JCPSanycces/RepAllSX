#<AdxTL>@(#)4.0.0.0 $Revision$
Subprog ZVENDE (PLANTA,EMPRESA,CLIENTE,COLECTIVO,FECHA,DIVISA,IMPORTEAI,TASA,IMPUESTO,IMPORTEII,FPAGO,INMOVIL,NUMFRA,REGIMEN,EJE1,EJE2,EJE3,EJE4,EJE5,EJE6,EJE7,EJE8,EJE9,FACTURA)
Value Char PLANTA
Value Char EMPRESA
Value Char CLIENTE
Value Char COLECTIVO
Value Date FECHA
Value Char DIVISA
Value Decimal IMPORTEAI
Value Char TASA
Value Decimal IMPUESTO
Value Decimal IMPORTEII
Value Char FPAGO
Value Char INMOVIL
Value Char NUMFRA
Value Char REGIMEN
Value Char EJE1
Value Char EJE2
Value Char EJE3
Value Char EJE4
Value Char EJE5
Value Char EJE6
Value Char EJE7
Value Char EJE8
Value Char EJE9
Variable Char FACTURA

Local Char FRA
Local Decimal PLUSMINUS

Decimal CAMBIO 
CAMBIO = 1.00

GUSRFCY(1) = "\"

Local Mask FIXSAL[DIA] 

Gosub OUVRE From FIXSAL

[M:DIA]FCY = PLANTA
[M:DIA]CPY = EMPRESA
[M:DIA]SIVTYP = 'FAC'
[M:DIA]BPR = CLIENTE
[M:DIA]BPRSAC = COLECTIVO
[M:DIA]SALDAT = FECHA
[M:DIA]ACCDAT = FECHA
[M:DIA]CUR = DIVISA 
[M:DIA]AMTNOT = IMPORTEAI 
[M:DIA]AMTATI = IMPORTEII 
[M:DIA]BPRPAY = CLIENTE
[M:DIA]PTE = FPAGO
[M:DIA]FLGDER = 2
[M:DIA]TRACE = 2
[M:DIA]NBLIG = 1
nolign = [M:DIA]NBLIG
[M:DIA]FASCOD(nolign-1)= INMOVIL
[M:DIA]FASNUM(nolign-1) = 1
[M:DIA]AMTNOTLIN(nolign-1) = IMPORTEAI 

##[M:DIA]VACBPR = REGIMEN
##Affzo [M:DIA]VACBPR 

[M:DIA]VAT(nolign-1) = TASA 
Affzo [M:DIA]VAT(nolign-1)

[M:DIA]AMTVAT(nolign-1) = IMPUESTO
[M:DIA]AMTATILIN(nolign-1) = IMPORTEII 
[M]OPT="2"
[M:DIA]GTE = 'FAC'
[M:DIA]JOU = 'VEN'

mkstat = 0

Gosub CONTROLE From FIXSAL
Gosub EXEC From FIXSAL
Gosub FIN From FIXSAL

Gosub PLUVAL From FIXSAL
[F:FAS]SALVAL = [L]PLUVAL
PLUSMINUS = [F:FAS]SALVAL
Rewrite [FAS]
FRA = [FAS]SALINVNUM

Read [SIH]SIH0 = FRA
[SIH]BPRVCR = NUMFRA
Rewrite [SIH]

Read [SIL]SIL0 = FRA;1
[SIL]VAT = TASA
Rewrite [SIL]

Call OUVRE_TRACE("hasta") From LECFIC
Call ECR_TRACE(NUMFRA,0) From GESECRAN 
Call ECR_TRACE(TASA,0) From GESECRAN 
Call FERME_TRACE From LECFIC

#######################################
# 4ş asiento. Plus-Minus.valia
#######################################
    Local    Integer  YERROR     : YERROR = 0
    Local    Char     RUTA(250)
    Local    Char     LSEP       : LSEP = ";"
    Local    Char     FICHERO    
    Local    Char     XNUMREG

    If clalev([F:APX])<=0 : Local File APARIMPEXP [APX] : Endif
    If clalev([F:TPV])<=0 : Local File TABPIVTYP  [TPV] : Endif

    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##

    Read [APX]APX0 = 'REPIMPDEF'

    RUTA = [F:APX]DIRECTORY
    RUTA = left$(RUTA,len(RUTA)-1)

    adxium = 50        # el fichero es ascii

    FICHERO = filpath(RUTA,num$(adxuid(1))+"_ASI","TXT")

    Openo FICHERO,0 Using [XBIS]

## format$("YMD",FECHA)
Local Char FECHAPTE
FECHAPTE = mid$(FECHA,7,2)+mid$(FECHA,5,2)+mid$(FECHA,3,2)

        Wrseq "G" + LSEP + PLANTA + LSEP + "ODG" + LSEP + FECHAPTE + LSEP + FRA + " " + CLIENTE
&        + LSEP + FECHAPTE + LSEP + FECHAPTE + LSEP + FRA + " " + CLIENTE + LSEP + FECHAPTE 
&        + LSEP + INMOVIL + LSEP + DIVISA + LSEP + num$(CAMBIO) + chr$(013) Using [XBIS]

Local Char SIGNO
SIGNO = num$(PLUSMINUS)
SIGNO = left$(SIGNO,1)
If (SIGNO = "-") Then
        Wrseq "D" + LSEP + "1" + LSEP + "199900" + LSEP + LSEP + num$(abs([F:FAS]SALVAL)) + LSEP + "-1" + LSEP + INMOVIL + LSEP + ""+ chr$(013) Using [XBIS]
        Wrseq "D" + LSEP + "2" + LSEP + "671000" + LSEP + LSEP + num$(abs([F:FAS]SALVAL)) + LSEP + "1" + LSEP + INMOVIL + LSEP + ""+ chr$(013) Using [XBIS] 
Else
        Wrseq "D" + LSEP + "1" + LSEP + "199900" + LSEP + LSEP + num$([F:FAS]SALVAL) + LSEP + "1" + LSEP + INMOVIL + LSEP + ""+ chr$(013) Using [XBIS]
        Wrseq "D" + LSEP + "2" + LSEP + "771000" + LSEP + LSEP + num$([F:FAS]SALVAL) + LSEP + "-1" + LSEP + INMOVIL + LSEP + ""+ chr$(013) Using [XBIS]
Endif
        If (EJE1 <> "") Then
          Wrseq "A" + LSEP + "1" + LSEP + EJE1 + LSEP + EJE2 + LSEP + EJE3 + LSEP + "1045" + LSEP + EJE5 + LSEP + EJE6 + LSEP + EJE7 + LSEP + EJE8 + LSEP + EJE9 + LSEP + num$(abs([F:FAS]SALVAL)) + chr$(013) Using [XBIS]
        Else
          Wrseq "A" + LSEP + "1" + LSEP + "0000" + LSEP + EJE2 + LSEP + EJE3 + LSEP + "1045" + LSEP + EJE5 + LSEP + EJE6 + LSEP + EJE7 + LSEP + EJE8 + LSEP + EJE9 + LSEP + num$(abs([F:FAS]SALVAL)) + chr$(013) Using [XBIS]
        Endif

    Openo Using [XBIS] 

    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",FICHERO,"")
    Local Char MESSAGE(100)

    Call IMPORTSIL('ZSETGAS',FICHIER) From GIMPOBJ
#######################################
# Fin 4ş asiento. Plus-Minus.valia
#######################################



FACTURA = FRA
GERR = 0
End



