#<AdxTL>@(#)10.0.0.0 $Revision$
GMODU(2)=2
Raz GPILOBJ , GNBMASKOUV
Call OBJET("FCY",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 PSUBB = 1
Endif
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "RAZCRE"       : Gosub RAZCRE
 When "ANNULE"       : Gosub ANNULE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_CRE"    : Gosub APRES_CRE
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SEL_TABLE"    : Gosub SEL_TABLE
Endcase
If PSUBB
 Gosub ACTION From SUBFCYB
Endif
Return

#----------------------------------#
$OUVRE
Local Clbfile ENTMES(1)
Local Char    TEXMES(250)
Gosub NUMBPA
#111767 no update on historical folder
If func DOSSUB.ISHISTFOLD(nomap)=0 & val(func AFNC.PARAM("FCYMAXLEN",""))=0
 Call MAJLENCOD("")
Endif
Return

$NUMBPA
Local Integer NUMBPA
NUMBPA = 3
Return

#------------------------------------#
Subprog MAJLENCOD(DOSSIER)
Value Char DOSSIER
Local Char    MAXCOD(GLONCPY) , MINCOD(GLONCPY) , TEXMES(250)(1..5)
Local Clbfile ENTMES(1)
Local Integer I
If DOSSIER="" or DOSSIER=nomap
 Local File FACILITY [FCY]
Else
 Local File =DOSSIER+".FACILITY" [FCY]
Endif
Raz MAXCOD , MINCOD
For [FCY]
 If len(MINCOD)=0 or len([F:FCY]FCY)<len(MINCOD)
  MINCOD = [F:FCY]FCY
 Endif
 If len([F:FCY]FCY)>len(MAXCOD)
  MAXCOD = [F:FCY]FCY
 Endif
Next FCY
If len(MAXCOD)<>len(MINCOD)
 # Attention, la longueur des codes $1$ n'est pas uniforme (il varie de $2$ [$3$] ŕ $4$ [$5$]).
 # Si vous utilisez des compteurs, incluant des codes $6$ et que ceux-ci sont définis avec un contrôle strict
 # de chronologie, les codes $7$ seront complétés par un ou plusieurs caractčres $8$ pour atteindre la longueur requise
 ENTMES  = mess(220,125,1)+mess(221,125,1)+mess(222,125,1)
 TEXMES = mess(29,109,1)+"~"+num$(len(MINCOD))+"~"+MINCOD+"~"+num$(len(MAXCOD))+"~"+MAXCOD
 TEXMES += "~"+mess(29,109,1)+"~"+mess(29,109,1)+"~"+"_"
 ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
 If GTRACE<>"" or GSERVEUR
  Raz TEXMES , I
  While ENTMES<>""
   I += 1
   K = instr(100,ENTMES," ")
   If K
    TEXMES(I) = left$(ENTMES,K-1)
    ENTMES = right$(ENTMES,K+1)
   Else
    TEXMES(I) = ENTMES
    ENTMES = ""
   Endif
  Wend
  Call ECR_TRACE(TEXMES,-1) From GESECRAN
 Else
  Call AFFMES(ENTMES) From GESECRAN
 Endif
Endif
Call MAJPAR(DOSSIER,"FCYMAXLEN",num$(len(MAXCOD))) From SUBADS
Call MAJPAR(DOSSIER,"FCYMINLEN",num$(len(MINCOD))) From SUBADS
#jira X3-125829
# clean cache after modif
Gosub CLEAN_PARAM From SUBCPY

Close Local File
End

#----------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#----------------------------------#
$LIENS
Gosub GRISE_ORICERFLG :#X3-60505
If dim([M:FCY1]BASTAB)> 0
 If [M:FCY1]BASTAB=0
  [M:FCY1]BASTAB = GOPTCANA
 Endif
Endif
Default Mask [BPF]
Call CHARG_BPA(NUMBPA,[M:FCY0]FCY,[F:FCY]BPAADD) From TRTBPA
If clalev([M:CNF])>0
 Default Mask [CNF]
 Call CHARG_CNT(NUMBPA,[M:FCY0]FCY,[F:FCY]CNTNAM) From TRTBPA
Endif
If dim([M:BIF]NBRIB)>0
 Default Mask [BIF]
 Call CHARG_RIB(NUMBPA,[M:FCY0]FCY,[F:FCY]BIDNUM) From TRTBPA
Endif
Gosub DEFAUT
[M:BPF]NUMBPA = NUMBPA
Diszo [FCY1]LEGCPY
Return

$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From WGOFCY
 Endif
Next MA
Return

#----------------------------------#
$APRES_MODIF
Case zoncou
 When "FCY" : Look [FCY]FCY0 = zc : If fstat : Actzo [FCY1]LEGCPY : Endif
Endcase
Return

#----------------------------------#
$RAZCRE
# LTA.sn - 93205
If func AFNC.ACTIV("LTA")
  If dim([M:BPAC]XADRVAL)>0
    Chgfmt [M:BPAC]XADRVAL With "-LA:1"
    Chgfmt [M:BPAC]VALADR  With "-K:10X"
  Endif
Endif
# LTA.en - 93205
[F:BPA]BPATYP = NUMBPA
[M:BPF]NUMBPA = NUMBPA
If dim([M:CNF]NUMBPA)>0
 [M:CNF]NUMBPA = NUMBPA
Endif
If dim([M:BIF]NUMBPA)>0
 [M:BIF]NUMBPA = NUMBPA
Endif
Affzo [FCY1]
Actzo [FCY1]LEGCPY
Return

#----------------------------------#
$INICRE
$INIMOD
Local Integer I
I = find (2,[M:BPF]BPAADDFLG (0..[M:BPF]NBADR -1))
If I = 0
 [F:FCY]BPAADD = [M:BPF]CODADR(0)
Else
 [F:FCY]BPAADD = [M:BPF]CODADR(I-1)
Endif
If dim([M:BIF]NBRIB)>0
 I = find (2,[M:BIF]BIDNUMFLG (0..[M:BIF]NBRIB -1))
 If I = 0
  [F:FCY]BIDNUM = [M:BIF]BIDNUM(0)
 Else
  [F:FCY]BIDNUM = [M:BIF]BIDNUM(I-1)
 Endif
Endif
If dim([M:CNF]NBCNT)>0
 I = find (2,[M:CNF]CNTFLG (0..[M:CNF]NBCNT -1))
 If I = 0
  [F:FCY]CNTNAM = [M:CNF]CCNCRM(0)
 Else
  [F:FCY]CNTNAM = [M:CNF]CCNCRM(I-1)
 Endif
Endif
If dim([F:FCY]LEG)>0
 Read [CPY]CPY0 = [F:FCY]LEGCPY
 [F:FCY]LEG = [F:CPY]LEG
Endif
Return

#----------------------------------#
$CREATION
If val(func AFNC.PARAM("FCYMAXLEN",""))=0
  Call MAJPAR("","FCYMAXLEN",num$(len([M:FCY0]FCY))) From SUBADS
  Call MAJPAR("","FCYMINLEN",num$(len([M:FCY0]FCY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM From SUBCPY
Elsif len([M:FCY0]FCY)<val(func AFNC.PARAM("FCYMINLEN",""))
  Call MAJPAR("","FCYMINLEN",num$(len([M:FCY0]FCY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM From SUBCPY
Elsif len([M:FCY0]FCY)>val(func AFNC.PARAM("FCYMAXLEN",""))
  Call MAJPAR("","FCYMAXLEN",num$(len([M:FCY0]FCY))) From SUBADS
  #jira X3-125829
  # clean cache after modif
  Gosub CLEAN_PARAM From SUBCPY
Endif

$MODIF
Default Mask [BPF]
Call CREBPA(NUMBPA,[M:FCY0]FCY) From TRTBPA
If GOK < 1 : Return : Endif
If dim([M:BIF]NBRIB)>0
 Default Mask [BIF]
 Call CRERIB(NUMBPA,[M:FCY0]FCY) From TRTBPA
 If GOK < 1 : Return : Endif
Endif
If clalev([M:CNF])>0
 Default Mask [CNF]
 Call CRECNT(NUMBPA,[M:FCY0]FCY) From TRTBPA
 If GOK < 1 : Return : Endif
Endif
Gosub DEFAUT
Gosub CREFGR
If GOK < 1 : Return : Endif
Return

#----------------------------------#
$APRES_CRE
Call CREATIONSITE([M]FCY,[M]LEGCPY) From SUBAFP1

#----------------------------------#
$AP_ANNULE
If nbrecord([CPY])>=dim(GSOC) or nbrecord([FCY])>=dim(GSITE)
 # Pour utiliser ce nouveau site, il faut redémarrer une nouvelle session
 Call MESSAGE(mess(92,127,1)) From GESECRAN
Else
 Call INISOC From GLOBSUP  : # Réinit de la tables des sociétés
Endif
Return

#----------------------------------#
$VERIF_CRE
Look [CPY]CPY0 = [M:FCY0]FCY
If fstat = 0
 # Ce code existe déjŕ comme société
 Call ERREUR([M:FCY0]FCY-":"-mess(141,133,1)) From GESECRAN
 OK = 0
 Return
Endif
If val(func AFNC.PARAM("FCYMAXLEN",""))=0
 # Attention, si vous créez ce code $1$, un contrôle vérifiera que les autres codes $2$ seront créés avec le męme nombre
 # de caractčres ($3$), afin de garantir une homogénéité dans la numérotation des documents si vous avez inséré le code $4$
 # dans la structure des compteurs correspondants.
 # Voulez-vous continuer ?
 ENTMES  = mess(223,125,1)+mess(224,125,1)+mess(225,125,1)+chr$(10)+mess(205,100,1)
 TEXMES = mess(29,109,1)+"~"+mess(29,109,1)+"~"+num$(len([M:FCY0]FCY))+"~"+mess(29,109,1)
 ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
 OK = 1
 Call MESCTL(ENTMES,OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif

#----------------------------------#
$VERIF_MOD
[M:FCY0]FCY = vireblc([M:FCY0]FCY,2)
If [M:FCY0]FCY = ""
 Call ERREUR(mess(143,133,1)) From GESECRAN : # Code site incorrect
 OK = 0
 Return
Endif
If [M:BPF]NBADR = 0
 Call ERREUR(mess(40,133,1)) From GESECRAN : # Une adresse au moins doit exister
 OK = 0
 Return
Endif
If !find (2,[M:BPF]BPAADDFLG (0..[M:BPF]NBADR -1))
 Call ERREUR(mess(41,133,1)) From GESECRAN : # Une adresse doit ętre désignée par défaut
 OK = 0
 Return
Endif
Return

#----------------------------------#
$CREFGR
For [AGC]AGC0(1) Where CPY=[M]LEGCPY
 Readlock [FGR]FGR0 = [F:AGC]GRP;[M]FCY
 If fstat=1
  GOK = -1 : GLOCK = "$FACGROUP"-[F:AGC]GRP-[M]FCY : Break
 Elsif fstat
  Raz [F:FGR]
  [F:FGR]CPY    = [F:AGC]GRP
  [F:FGR]FCY    = [M]FCY
  Write [FGR]
  If fstat
   GOK = 0 : Call FSTA("FGR") From GLOCK : Break
  Endif
 Endif
Next
Return

#----------------------------------#
$ANNULE
Call SUPPSITE([M:FCY0]FCY) From SUBAFP1
Gosub NUMBPA
Call ANNBPA([L]NUMBPA,[L]CODE) From TRTBPA
Call ANNRIB([L]NUMBPA,[L]CODE) From TRTBPA
If clalev([M:CNF])>0
 Call ANNCNT([L]NUMBPA,[L]CODE) From TRTBPA
Endif
Delete [FGR] Where FCY=[L]CODE
Return

#-------------------------------------------------------------#
# Action SELFCY
#-------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELFCY"    : Gosub SELFCY
Endcase
Return

$SELFCY
If PARAM(1)="" : PARAM(1)="1=1" : Endif
CRITERE(1) = PARAM(1)
OPTIONS    = PARAM(2)
OBJET      = "FCY"
Return

#-------------------------------------------------------------#
# Ecran FCY0
#-------------------------------------------------------------#
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Clbfile ENTMES(1)
Local Char    TEXMES(250)
Look [FCY]FCY0 = VALEUR
If fstat
 Look [CPY]CPY0 = VALEUR
 If !fstat
  # Ce code existe déjŕ comme société
  GMESSAGE = mess(141,133,1) : mkstat = 2 : End
 Endif
 If val(func AFNC.PARAM("FCYMAXLEN",""))>0
  If val(func AFNC.PARAM("FCYMAXLEN",""))=val(func AFNC.PARAM("FCYMINLEN","")) & len(VALEUR)<>val(func AFNC.PARAM("FCYMAXLEN",""))
   # Afin de garantir une homogénéité dans la numérotation des documents si vous avez inséré le code $1$ dans la structure des
   # compteurs correspondants, il ne vous est pas possible de créer un code $2$ avec un code de longueur différente de $3$.
   # Si vous voulez passer outre, l'administrateur général devra passer renseigner des valeurs différentes, pour les
   # paramčtres $4$ et $5$. Les numérotations de documents qui intčgrent un code $6$
   # complčteront alors les codes $7$ de longueur inférieure ŕ $8$ avec des caractčres $9$.
   ENTMES  = mess(226,125,1)+mess(227,125,1)+mess(228,125,1)+mess(229,125,1)+mess(230,125,1)
   TEXMES = mess(29,109,1)+"~"+mess(29,109,1)+"~"+func AFNC.PARAM("FCYMAXLEN","")+"~FCYMINLEN~FCYMAXLEN~"+mess(29,109,1)
   TEXMES += "~"+mess(29,109,1)+"~"+func AFNC.PARAM("FCYMAXLEN","")+"~_"
   ENTMES = func AFNC.MESNC(ENTMES,TEXMES)
   Call AFFMES(ENTMES) From GESECRAN
   mkstat = 2 : End
  Endif
 Endif
Endif
End

#-------------------------------------------------------------#
# Ecran FCY1
#-------------------------------------------------------------#
Subprog AS_LEGCPY(VALEUR)
Variable Char     VALEUR
#If !(GREP = "C" | GREP = "D") : mkstat = 2 : Endif
End

Subprog C_LEGCPY(VALEUR)
Variable Char     VALEUR
Read [F:CPY]CPY0 = VALEUR
If [F:CPY]CPYLEGFLG<>2
 GMESSAGE = mess(142,133,1) : mkstat = 1 : # Société non juridique
 mkstat = 2 : End
Endif
End

Subprog IB_LEGCPY
# Pas de tunnel Site -> Société, ŕ cause de l'écran CNT2 présent dans ces 2 objets
If clalev([M:CNT2])>0 : GBOUT1="" : Endif
End

Subprog C_CRN(VALEUR)
Variable Char    VALEUR()
If vireblc(VALEUR,2)=""
 Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
 If !fstat & dim([F:TCY]CRTOBL)>0 & [F:TCY]CRTOBL=2
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif
Endif
End

#X3-60505
Subprog AM_ORICERFLG(VALEUR)
Variable Integer VALEUR
  [M:FCY1]ORICERFLG = VALEUR
  Gosub GRISE_ORICERFLG
End

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
  [M:FCY1]CRY = VALEUR
  Gosub GRISE_ORICERFLG
  Gosub GRISE_EORINUM
End

$GRISE_ORICERFLG
 If dim([M:FCY1]ORICERFLG)<0 : Return : Endif :#X3-69093
 If (dim([M:FCY4]FINFLG)>-1 & [M:FCY4]FINFLG=[V]CST_AYES) | (dim([M:FCY4]FINFLG)<0 & [F:FCY]FINFLG=[V]CST_AYES)
   If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
   If [F:TCY]CRY<>[M:FCY1]CRY
    Read [F:TCY]TCY0=[M:FCY1]CRY
   Else
    fstat=0
   Endif
   If fstat | ([F:TCY]EECFLG<>[V]CST_AYES & [F:TCY]GSPFLG<>[V]CST_AYES)
    If [M:FCY1]ORICERFLG=[V]CST_AYES
      [M:FCY1]ORICERFLG=[V]CST_ANO
      Affzo [M:FCY1]ORICERFLG
    Endif
    Grizo [M:FCY1]ORICERFLG
   Else
    Actzo [M:FCY1]ORICERFLG
   Endif
 Else
  If [M:FCY1]ORICERFLG=[V]CST_AYES
    [M:FCY1]ORICERFLG=[V]CST_ANO
    Affzo [M:FCY1]ORICERFLG
  Endif
  Grizo [M:FCY1]ORICERFLG
 Endif
 Gosub GRISE_REXNUM
Return

$GRISE_REXNUM
  If dim([M:FCY1]REXNUM)<0 : Return : Endif :#X3-69093
  If [M:FCY1]ORICERFLG=[V]CST_AYES
    Actzo [M:FCY1]REXNUM
  Else
    If [M:FCY1]REXNUM<>""
      Raz [M:FCY1]REXNUM
      Affzo [M:FCY1]REXNUM
    Endif
    Grizo [M:FCY1]REXNUM
  Endif
Return
#end X3-60505

#X3-222017
Subprog AV_EORINUM(VALEUR)
Variable Char    VALEUR()
  Gosub GRISE_EORINUM
End

$GRISE_EORINUM
  If dim([M:FCY1]EORINUM)>=0 :#to be safe...
    Call LECTURE("TCY",[M:FCY1]CRY,"") From CONTOBJ
    If !fstat & dim([F:TCY]EORIFLG)>=0 & [F:TCY]EORIFLG=[V]CST_AYES
      Actzo [M:FCY1]EORINUM
    Else
#      If [M:FCY1]EORINUM<>""
#        Raz [M:FCY1]EORINUM
#        Affzo [M:FCY1]EORINUM
#      Endif
      Grizo [M:FCY1]EORINUM
    Endif
  Endif
Return
#end X3-222017


