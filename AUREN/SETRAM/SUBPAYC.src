#####################################################################################
##    Z25 - Mostrar campo documento origen (ya existe en std PU9)
##          y descripción línea asiento contable (específico)
##          en el detalle de la propuesta
#####################################################################################
Subprog RELLENAR_COLUMNAS_ESPECIFICO_SETRAM

    # Nombre tercero --> desactivamos, existe en std PU9
    #Read [BPR]BPR0 = [F:DUD]BPR
    #If fstat
    # GOK = 0
    # Call ECR_TRACE(mess(150,192,1)-"BPARTNER"-":"-[F:DUD]TYP-[F:DUD]NUM,1) From GESECRAN
    #End
    #Endif
    #[M:PCL]ZBPRNAM(nolign-1) = [F:BPR]BPRNAM

    # Documento origen --> desactivamos, existe en std PU9
    #Read [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM
    #If fstat
    #  GOK = 0
    #    Call ECR_TRACE(mess(150,192,1)-"GACCENTRY"-":"-[F:DUD]TYP-[F:DUD]NUM,1) From GESECRAN
    #    End
    #Endif
    #[M:PCL]ZDOCORIG(nolign-1) = [F:HAE]BPRVCR

    # Descripción línea asiento contable --> No existe en PU9, se adapta SPE
    #Read [DAE]DAE0 = [F:DUD]TYP;[F:DUD]NUM ;[F:DUD]LIG
    Read [DAE]DAE0 = [F:DUD]TYP;[F:DUD]NUM ;[F:DUD]LIG;1
    If fstat
    GOK = 0
        Call ECR_TRACE(mess(150,192,1)-"GACCENTRYD"-":"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG),1) From GESECRAN
        End
    Endif
    [M:PCL]ZDESCLINEA(nolign-1) = [F:DAE]DES

    #Importe con signo cambiado --> No existe en PU9, se adapta SPE
    [M:PCL]ZAMTCUR(nolign-1) =[M:PCL]AMTCUR(nolign-1)
    If [F:DUD]SNS <>1 Then
        [M:PCL]ZAMTCUR(nolign-1) =[M:PCL]AMTCUR(nolign-1) * -1
    Endif

End
