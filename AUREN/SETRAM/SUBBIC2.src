End

Subprog AS_STRDUDDAT(VALEUR)
Variable Date     VALEUR
#If (GREP="" & [M]NUM<>"") | GREP="M" | [M]STA=3
If [M]STA=3 | [M]AMTMIN<>0
 mkstat = 2
Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AM_STRDUDDAT(VALEUR)
