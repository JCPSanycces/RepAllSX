######################################################################################
Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:MDT])=0 : Local File MANDATE [MDT] : Endif
Local Integer FLGSDD : [L]FLGSDD = 0

If VALEUR=""
 If [F:SIH]NUM<>"" & [F:SIH]PTE=[M:BIC1]PTE
  Call DUDPAMSDD(1,[F:SIH]NUM,[L]FLGSDD) From INVSDDLIB
 Else
  Call PTESDD([M:BIC1]PTE,[L]FLGSDD) From INVSDDLIB
 Endif
 If [L]FLGSDD
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
Else
 Call CTL_UMRNUM(VALEUR,GSOCIETE,[M:BIC1]BPRPAY) From INVSDDLIB
 If mkstat : End : Endif
Endif
End
