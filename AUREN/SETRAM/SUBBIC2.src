Subprog AS_VAT(VALEUR)
Variable Char    VALEUR()
If [M]STA=3 | [M]FLGGEN(nolign-1)=2 : mkstat=2 : End : Endif
##### BESPR 87307 07/08/2013 # Intercompany enhancement
Gosub SETNOL
If GFONC1 = "GESBICI" and (([M]CPY <> [M]CPYLIN(NOL)) or (GCURINTCPY <> "" and GCURINTCPY <> [M]CPYLIN(NOL)))
  Call CONT_INTCPYCOA ([M]CPYLIN(NOL)) From INTCPYLIB
Endif
#####
If GCPTVAT=2
 Gosub RECH_ACCGEN From SUBBICS
 Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
 If [F:GAC]FLGVAT<2
  If VALEUR<>""
   Raz [M]VAT(nolign-1)
   Gosub CALTVA
  Endif
  mkstat = 1 : End
 Endif
Endif

GBOUT2 = mess(1,119,1) : # Saisie taxes
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog D_VAT(VALEUR)
Variable Char    VALEUR()
Local Char CODTAX(GLONVAT)
##### BESPR 87307 07/08/2013 # Intercompany enhancement
Gosub SETNOL
If GFONC1 = "GESBICI" and (([M]CPY <> [M]CPYLIN(NOL)) or (GCURINTCPY <> "" and GCURINTCPY <> [M]CPYLIN(NOL)))
  Call CONT_INTCPYCOA ([M]CPYLIN(NOL)) From INTCPYLIB
Endif
#####
Gosub RECH_ACCGEN From SUBBICS
Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
If [F:GAC]FLGVAT=1 : End : Endif
# Paramčtre EXETAX (Tronc commun)
VALEUR = GEXETAX

# Code taxe renseigné au niveau du compte général
If func FIN_PARAM(GAC_KAG, "ARGTAX",[M:BIC0]CPY)<>"2"
 If [F:GAC]VAT(0)<>""
  VALEUR = [F:GAC]VAT(0)
  If dim([F:GAC]VAT)>1 : [M]TAX1(nolign-1) = [F:GAC]VAT(1) : Endif
  If dim([F:GAC]VAT)>2 : [M]TAX2(nolign-1) = [F:GAC]VAT(2) : Endif
 Endif
 # Code taxe n'est pas obligatoire au niveau du compte
 # On va chercher le code taxe associé au régime tiers
 If GSAITAX=1 & [F:GAC]VAT(0)=""
  Call LEC_TVB(GCURLEG,[M]VAC) From CPTLEC
  If !fstat & [F:TVB]ENAFLG=2
   CODTAX = [F:TVB]VAT
   If CODTAX<>""
    Call LEC_TVT_LEG(GCURLEG,CODTAX) From CPTLEC
    If !fstat : VALEUR = CODTAX : Endif
   Endif
  Endif
 Endif
Else
 Call LECTURE("CPY",[M:BIC0]CPY,"") From CONTOBJ
 Call LECTURE("BPC",[M:BIC0]BPR,"") From CONTOBJ
 If [F:GAC]VAT(0)<>""
  Call LEC_TVT_LEG(GCURLEG,[F:GAC]VAT(0)) From CPTLEC
  If [F:TVT]VATTYP<>2 | ([F:TVT]VATTYP=2 & [F:CPY]AGTPCP = 2 & [F:BPC]AGTPCP = 2)
   VALEUR = [F:GAC]VAT(0)
  Endif
  If dim([F:GAC]VAT)>1
   Call LEC_TVT_LEG(GCURLEG,[F:GAC]VAT(1)) From CPTLEC
   If [F:TVT]VATTYP<>2 | ([F:TVT]VATTYP=2 & [F:CPY]AGTPCP = 2 & [F:BPC]AGTPCP = 2)
    [M]TAX1(nolign-1) = [F:GAC]VAT(1)
   Endif
  Endif
  If dim([F:GAC]VAT)>2
   Call LEC_TVT_LEG(GCURLEG,[F:GAC]VAT(2)) From CPTLEC
   If [F:TVT]VATTYP<>2 | ([F:TVT]VATTYP=2 & [F:CPY]AGTPCP = 2 & [F:BPC]AGTPCP = 2)
    [M]TAX2(nolign-1) = [F:GAC]VAT(2)
   Endif
  Endif
 Endif
Endif
[M]VAT(nolign-1) = VALEUR
Gosub CALTVA
End

Subprog C_VAT(VALEUR)
Variable Char VALEUR()
If VALEUR="" & [F:GAC]FLGVAT>1 & [F:GAC]FLGVAT<5
 [M]VAT(nolign-1) = VALEUR : Affzo [M]VAT(nolign-1)
 ## Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
If VALEUR<>""
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TVT]VATTYP<>1
  ## Cette taxe n'est pas de type TVA
  GMESSAGE = mess(11,119,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_VAT(VALEUR)
Variable Char VALEUR()
If GIMPORT | VALEUR<>[M]VAT(nolign-1)
 [M]VAT(nolign-1) = VALEUR
 Gosub CALTVA
 If STAT
  Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
  GMESSAGE = MESSA
  mkstat = 2 : End
 Endif
Endif
# IRMUE 13.05.12 AP/AR management
Gosub RECALTOTAMT From SUBBIC4
End

##########################################################################################
$CALTVA

Local Char    TAXES(GLONVAT)(1..3), MESSA(80)
Local Decimal MONTVAT(1..3) , MONTDED(1..3)
Local Integer TYPREG , STAT
Local Date    DATREF
Local Decimal DSCRAT
#AUREN - V12
If GWEBSERV <>0 : Return : Endif
#AUREN - V12

#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
If dim([L]SALPRICUR)<=0
   Local Integer SALPRICUR
Endif
#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
## Les taxes provinciales argentines (Percepcion de Ingresos Brutos)
Local Decimal MONTPRV(1..4) , MONTDEDPRV(1..4)
Local Char    TAXPRV(GLONVAT)(1..4)
Local Decimal EXEAMTTAX(1..3)
Local Decimal EXEAMTPRV(1..4)
If GIMPORT & dim(GAMTVAT_SIL)>0 & GAMTVAT_SIL
 Return
#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
Elsif GIMPORT : # Importation and the taxes have to be recalculated
 [L]SALPRICUR = [M:BIC1]SALPRITYP
 [M:BIC1]SALPRITYP = 1
Endif
#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
Gosub RECH_ACCGEN From SUBBICS
Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
If [F:GAC]FLGVAT>2 & [F:GAC]FLGVAT<5
 Raz MONTVAT
Else
 TAXES(1) = [M]TAX1(nolign-1)
 TAXES(2) = [M]TAX2(nolign-1)
 TAXES(3) = [M]VAT(nolign-1)
 DATREF = [M]ACCDAT
 If [M]INVNUM<>""
  If clalev([F:SIH2])=0 : Local File SINVOICE [SIH2] : Endif
  Read [SIH2]SIH0 = [M]INVNUM
  If !fstat : DATREF = [F:SIH2]ACCDAT : Endif
 Endif
 #----------------------------------------------------------------------------------------------------
 #IRMUE 03.06.12 81574:AP/AR management
 #if amount type is "Ex tax" tax amount have to calculated from AMTNOTLIN, by "Tax inc" from AMTATILIN
 #----------------------------------------------------------------------------------------------------

 # Call CALTAXE3([M]CPY,[M]BPR,DATREF,"",[M]CUR
 #& ,3,TAXES,1,[M]AMTNOTLIN(nolign-1),MONTVAT,MONTDED,EXEAMTTAX,TYPREG,STAT) From SUBTVT
# Issue X3-114880
 If dim([M:BIC1]SALPRITYP)>0 & [M:BIC1]SALPRITYP =2
#    Call CALTAXE3([M]CPY,[M]BPR,DATREF,"",[M]CUR
#& ,3,TAXES,2,[M]AMTATILIN(nolign-1),MONTVAT,MONTDED,EXEAMTTAX,TYPREG,STAT) From SUBTVT
  Call CALTAXE([M]CPY,DATREF,"",[M]CUR,3,TAXES,2,[M]AMTATILIN(NOL),MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
 Else
#    Call CALTAXE3([M]CPY,[M]BPR,DATREF,"",[M]CUR
#&  ,3,TAXES,1,[M]AMTNOTLIN(nolign-1),MONTVAT,MONTDED,EXEAMTTAX,TYPREG,STAT) From SUBTVT
  Call CALTAXE([M]CPY,DATREF,"",[M]CUR,3,TAXES,1,[M]AMTNOTLIN(NOL),MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
 Endif
 #End Issue X3-114880
 #IRMUE 03.06.12 81574:AP/AR management <end>

 ## If "Rebate on VAT" and if the line is subjeted to discount, the discount rate has to be applied on the VAT (only VAT, not the
 ## others taxes)
  If [M]FLGDEP(nolign-1)=2 & find([M]INVTYP,1,3) & (GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP)))
  Call DSCRAT([M:BIC1]DEP,DSCRAT) From INVDEPLIB
  Local Decimal CURRND
  If func CDACUR_SYRA.GET_CURRND(GACTX, [M]CUR, CURRND, GMESSAGE)<>[V]CST_AOK
   mkstat = 2 : Return
  Endif
  If DSCRAT<>0
   MONTVAT(3) = arr(MONTVAT(3)*(1-(DSCRAT/100)), CURRND)
  Endif
 Endif

 If TYPREG<>1
  Raz MONTVAT, MONTDED
 Endif
Endif
[M]AMTTAX1(nolign-1) = MONTVAT(1)
[M]AMTTAX2(nolign-1) = MONTVAT(2)
[M]AMTVAT(nolign-1)  = MONTVAT(3)
[M]EXEAMTTAX1(nolign-1) = EXEAMTTAX(1)
[M]EXEAMTTAX2(nolign-1) = EXEAMTTAX(2)
[M]EXEAMTVAT(nolign-1)  = EXEAMTTAX(3)
If func FIN_PARAM(GAC_KAG, "ARGTAX",[M:BIC0]CPY)="2"
 If dim([M]THEAMTTAX1)>0
  [M]THEAMTTAX1(nolign-1) = MONTVAT(1)
  [M]THEAMTTAX2(nolign-1) = MONTVAT(2)
  [M]THEAMTVAT(nolign-1)  = MONTVAT(3)
 Endif

#----------------------------------------------------------------------------------------------------
 #IRMUE 03.06.12 81574:AP/AR management
 #if amount type is "Ex tax" tax amount have to calculated from AMTNOTLIN, by "Tax inc" from AMTATILIN
 #----------------------------------------------------------------------------------------------------
 #Call CALTAXEPROV(1,DATREF,[M]VAC,[M]CUR,[M]FCYLIN(nolign-1),"",[M:BIC0]BPR,[M:BIC0]BPAINV
#&                ,[M]AMTNOTLIN(nolign-1),TAXPRV,MONTPRV,MONTDEDPRV,EXEAMTPRV,TYPREG,STAT) From SUBTVTARG
 If dim([M:BIC1]SALPRITYP)>0  & [M:BIC1]SALPRITYP =2
  Call CALTAXEPROV(1,DATREF,[M]VAC,[M]CUR,[M]FCYLIN(nolign-1),"",[M:BIC0]BPR,[M:BIC0]BPAINV
&                ,[M]AMTATILIN(nolign-1),TAXPRV,MONTPRV,MONTDEDPRV,EXEAMTPRV,TYPREG,STAT) From SUBTVTARG
 Else
  Call CALTAXEPROV(1,DATREF,[M]VAC,[M]CUR,[M]FCYLIN(nolign-1),"",[M:BIC0]BPR,[M:BIC0]BPAINV
&                ,[M]AMTNOTLIN(nolign-1),TAXPRV,MONTPRV,MONTDEDPRV,EXEAMTPRV,TYPREG,STAT) From SUBTVTARG
 Endif
 #IRMUE 03.06.12 81574:AP/AR management <end>

 If TYPREG<>1
  Raz MONTPRV,MONTDEDPRV
 Endif
 [M]TAXRCP(nolign-1)     = TAXPRV(1)
 [M]TAXISS(nolign-1)     = TAXPRV(2)
 [M]TAXOTH1(nolign-1)    = TAXPRV(3)
 [M]TAXOTH2(nolign-1)    = TAXPRV(4)
 [M]AMTTAXRCP(nolign-1)  = MONTPRV(1)
 [M]AMTTAXISS(nolign-1)  = MONTPRV(2)
 [M]AMTTAXOTH1(nolign-1) = MONTPRV(3)
 [M]AMTTAXOTH2(nolign-1) = MONTPRV(4)
 [M]THEAMTTAXR(nolign-1) = MONTPRV(1)
 [M]THEAMTTAXI(nolign-1) = MONTPRV(2)
 [M]THEAMTOTH1(nolign-1) = MONTPRV(3)
 [M]THEAMTOTH2(nolign-1) = MONTPRV(4)
 [M]EXEAMTRCP(nolign-1)  = EXEAMTPRV(1)
 [M]EXEAMTISS(nolign-1)  = EXEAMTPRV(2)
 [M]EXEAMTOTH1(nolign-1) = EXEAMTPRV(3)
 [M]EXEAMTOTH2(nolign-1) = EXEAMTPRV(4)
Endif
#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
If GIMPORT
 [M:BIC1]SALPRITYP = [L]SALPRICUR
Endif
#----------------------------------------------------------------------------------------------------
#28.06.12 81574:AP/AR management
Return

# GH 01/02/00 AV_AMTATILIN -> AS_AMTATILIN pour de pbs d'import
Subprog AS_AMTATILIN(VALEUR)
Variable Decimal VALEUR
If [M]STA=3 | [M]FLGGEN(nolign-1)=2 : mkstat=2 : End : Endif
Gosub SETNOL

#VALEUR = [M]AMTNOTLIN(NOL)+[M]AMTTAX1(NOL)+[M]AMTTAX2(NOL)+[M]AMTVAT(NOL)
#If func AFNC.PARAM("ARGTAX",[M:BIC0]CPY)="2"
 #VALEUR += [M]AMTTAXRCP(NOL)+[M]AMTTAXISS(NOL)+[M]AMTTAXOTH1(NOL)+[M]AMTTAXOTH2(NOL)
#Endif
#mkstat=2

#IRMUE 13.05.12 81574:AR/AP management
If [M:BIC1]SALPRITYP <> 2 | GIMPORT
 VALEUR = [M]AMTNOTLIN(NOL)+[M]AMTTAX1(NOL)+[M]AMTTAX2(NOL)+[M]AMTVAT(NOL)
 If func FIN_PARAM(GAC_KAG, "ARGTAX",[M:BIC0]CPY)="2"
  VALEUR += [M]AMTTAXRCP(NOL)+[M]AMTTAXISS(NOL)+[M]AMTTAXOTH1(NOL)+[M]AMTTAXOTH2(NOL)
 Endif
 [M:BIC3]AMTATILIN(NOL) = VALEUR
 Gosub RECALTOTAMT From SUBBIC4
 Call CAL_BASDEPLIN([M:BIC1]DEP,[M]FLGDEP(nolign-1),nolign) From INVDEPLIB
 [M]BASDEP = sum([M]BASDEPLIN(0..max(nolign,[M]NBLIG)-1))
 If !GIMPORT
  Affzo BASDEP
 Endif
 mkstat=2
Else
 If VALEUR <> 0  #IRMUE 16.11.12 81574:AR/AP management
  [M]AMTNOTLIN(NOL) = VALEUR-[M]AMTTAX1(NOL)-[M]AMTTAX2(NOL)-[M]AMTVAT(NOL)
  If func FIN_PARAM(GAC_KAG, "ARGTAX",[M:BIC0]CPY)="2"
   VALEUR += [M]AMTTAXRCP(NOL)+[M]AMTTAXISS(NOL)+[M]AMTTAXOTH1(NOL)+[M]AMTTAXOTH2(NOL)
  Endif
 Endif
 Gosub RECALTOTAMT From SUBBIC4
 Affzo [M]AMTNOTLIN(NOL)
 Affzo [M]AMTVAT(NOL)
 [M]AMTATILIN(nolign-1) = VALEUR
 Call CAL_BASDEPLIN([M:BIC1]DEP,[M]FLGDEP(nolign-1),nolign) From INVDEPLIB
 [M]BASDEP = sum([M]BASDEPLIN(0..max(nolign,[M]NBLIG)-1))
 If !GIMPORT
  Affzo BASDEP
 Endif
Endif
GBOUT2 = mess(1,106,1) : # Solde
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AV_FLGDEP(VALEUR)
Variable Integer VALEUR
Call DISPLAY_DSCFLD([M:BIC1]DEP,"FLGDEP") From INVDEPLIB
End

Subprog AS_FLGDEP(VALEUR)
Variable Integer VALEUR
If [M]FLGGEN(nolign-1)=2 : mkstat=2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog D_FLGDEP(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Call INIT_FLGDEP(GPLAN(1),[M:BIC3]ACC1(NOL),NOL+1,VALEUR) From INVDEPLIB
End

Subprog AP_FLGDEP(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If GDEPMGTMOD = 1 | (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP))
 [M]FLGDEP(NOL) = VALEUR
 Gosub CALTVA
 [M]AMTATILIN(NOL) = [M]AMTNOTLIN(NOL)+[M]AMTTAX1(NOL)+[M]AMTTAX2(NOL)+[M]AMTVAT(NOL)
 [M]TOTATI = sum([M]AMTATILIN(0..max(nolign,[M]NBLIG)-1))
 If !GIMPORT
  Affzo AMTATILIN, TOTATI
 Endif
Endif
Call CAL_BASDEPLIN([M:BIC1]DEP,VALEUR,NOL+1) From INVDEPLIB
[M]BASDEP = sum([M]BASDEPLIN(0..max(nolign,[M]NBLIG)-1))
If !GIMPORT
 Affzo BASDEP
Endif
End

Subprog D_SALTYP(VALEUR)
Variable Integer VALEUR
Gosub RECH_ACCGEN From SUBBICS
# Tva portugaise
Case [F:GAC]VATIPT
 When 1
  VALEUR = 1 : # Marchandises
 When 2
  VALEUR = 1
  If [F:GAC]FLGVAT=2
   VALEUR = 2 :# Immos
  Endif
 When 3
  VALEUR = 1
  If [F:GAC]FLGVAT=2
   VALEUR = 3 : # Services
  Endif
 When 4 :# Déductible immos
  If [F:GAC]FLGVAT=2
   VALEUR = 2 :# Immos
  Endif
 When Default
  VALEUR = 1 : # Marchandises par défaut pour les autres valeurs de VATIPT
Endcase
End

Subprog AS_SALTYP(VALEUR)
Variable Integer VALEUR
If [M:BIC1]STA=3 : mkstat = 2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AM_DES(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Gosub RECH_ACCGEN From SUBBICS
Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
If VALEUR="//"
 VALEUR = [M:BIC1]DES(0)
Elsif VALEUR="/" | (VALEUR="=" & NOL=0)
 If [M]SAC(NOL)=""
  Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Else
  If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
  Call LECTURE("BPR",[M]BPRLIN(NOL),"") From CONTOBJ
  VALEUR = [F:BPR]BPRNAM
 Endif
Elsif VALEUR="="
 VALEUR = [M]DES(NOL-1)
Endif
End

Subprog D_QTY(VALEUR)
Variable Decimal  VALEUR
Call D_QTY(VALEUR) From SUBBICS
End

Subprog AS_QTY(VALEUR)
Variable Decimal  VALEUR
Call AS_QTY(VALEUR) From SUBBICS
If mkstat : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AS_PJTLIN(VALEUR)
Variable Char    VALEUR()
# Pour ne pas bloquer avec "Code affaire inexistant" si ma société ne gčre pas les affaires...
If func SUBBIC2.FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) <> "2" : mkstat = 1 : End : Endif
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"PJTMGT")<>2 : mkstat = 1 : End : Endif X3-101376
If [M]STA=3 : mkstat=2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

# Issue X3-149911 : Action created
Subprog AM_PJTLIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> [M:BIC3]PJTLIN(nolign-1) : Raz [M:BIC3]PCCCOD(nolign-1) :  Endif
End

# Issue X3-149911 : Same control as PJTLIN when dealing with activity code and posted documents
Subprog AS_PCCCOD(VALEUR)
Variable Char    VALEUR()
  If func FIN_PARAM(GAC_PJM, "PJTMGT",[M:BIC0]CPY) <> "2" : mkstat = 1 : End : Endif
  If [M]STA=3 or [M:BIC3]PJTLIN(nolign-1) = "": mkstat=2 : End : Endif
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR
Call AS_DSP(VALEUR) From SUBBICS
If mkstat : End : Endif
Gosub AFF_DSP
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog D_DSP(VALEUR)
Variable Char    VALEUR()
Call D_DSP(VALEUR) From SUBBICS
If mkstat : End : Endif
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Call C_DSP(VALEUR) From SUBBICS
If mkstat : End : Endif
Gosub AFF_DSP
End


$AFF_DSP
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LECTURE("DSP",VALEUR,"") From CONTOBJ
 If !fstat
  [M]AFFICHE = VALEUR-":"-[F:DSP]DES : Affzo AFFICHE
 Endif
Endif
Return


