Subprog AM_AMTATI(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]AMTNOT
 Local Integer OK
 OK = 2
 If !GIMPORT : Call AVERTIR(mess(43,119,1),OK) From GESECRAN : Endif
 If OK<>2 : mkstat = 2 : End : Endif
Endif
Raz [M]DUDDAT : # Recalculer DUDDAT par C_PTE
End

