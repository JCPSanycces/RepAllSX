Local Integer AXE
AXE = 20 : Goto SAICCE

$SAICCE
Call AS_CCE(AXE,VALEUR) From SUBBICS
If mkstat : End : Endif
##### BESPR 87307 05/31/2013 # Intercompany enhancement-if the Dimensions are not the same then cannot enter them here
Local Integer CCEDISFLG : CCEDISFLG = 0
If GFONC1 = "GESBICI" : Call CHECK_FOR_CCE(CCEDISFLG) From INTCPYLIB : Endif : If CCEDISFLG : mkstat=2 : End : Endif
#####
Gosub AFF_CCE
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

