Subprog C_BPRFCT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCT",VALEUR,"") From CONTOBJ
[M]BPRFCTNAM = [F:FCT]FCTNAM
# SAM 88426 - 2015-06-22 by LUCUE : Factoring management
If [F:FCT]FCTTYP>1 & VALEUR<>""
  If [M:BIC0]CPY<>[F:FCT]BANCPY or ([F:FCT]BANFCY<>"" and [M:BIC0]FCY<>[F:FCT]BANFCY)
       GMESSAGE=mess(204,121,1): mkstat=2 #Incompatibility between the company/site of the factor and the company/site of the invoice
  Endif
Endif
# End SAM 88426

End

######################################################################################
Subprog AP_AMTNOT(VALEUR)
Variable Decimal VALEUR
Local Integer OK
Local Char INTERV(250)

# ON regarde s'il y a un schéma de comptes par défaut paramétré pour le client saisi
# SI oui, on demande s'il faut l'appliquer
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:GDA])=0 : Local File GDIAACC    [GDA] : Endif # X3-217797.
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif # X3-217797.

If [M:BIC0]BPR<>""
 If !GIMPORT & (GREP="C" or GREP="D") and [M:BIC3]NBLIG=0
  Call LECTURE("BPC",[M:BIC0]BPR,"") From CONTOBJ
  If [F:BPC]DIA<>""
    # X3-217797 Start.
    # Search for related account structure.
    Filter [F:GDA] Where [F:GDA]DIA = [F:BPC]DIA
    Read [F:GDA] First
    If !fstat
      # If account structure is limited for a group of companies/sites.
      If [F:GDA]GFY <> ""
        # Check that selected site is inside the group.
        Filter [F:FGR] Where [F:FGR]CPY = [F:GDA]GFY and [F:FGR]FCY = [M:BIC0]FCY
        Look [F:FGR] First
        # If site not in the group, don't ask for account structure application.
        If fstat : End : Endif
      Endif
    Endif
    Filter [F:GDA]
    Filter [F:FGR]
    # X3-217797 End.

    # Voulez-vous appliquer le schéma de comptes ?
    Call OUINON([F:BPC]DIA-mess(218,117,1),OK) From GESECRAN
    If OK=2
      SCHEMA = [F:BPC]DIA
      [M]AMTNOT = VALEUR # affectation indispensable
      INTERV = dbgstr(1)
      Default Mask [BIC3]
      Gosub SCHEMA From SUBBIC3
      Default Mask INTERV
    Endif
  Endif
 Endif
Endif
End

