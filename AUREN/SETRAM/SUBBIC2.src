Raz [M:BIC1]DUDDAT
End

Subprog D_PTE(VALEUR)
Variable Char    VALEUR()
If dim([F:BPC]PTE)>0
 #----- Chargement des conditions de paiement du client -----#
 Call INIPTE ([M:BIC1]BPRPAY,[M:BIC0]BPR,"C",VALEUR) From TRTX3
Endif
If dim([M:BIC1]UMRNUM)>0
 [M:BIC1]PTE=VALEUR
 Gosub GRIZO_UMRNUM From INVSDDLIB
Endif
End

Subprog AS_PTE(VALEUR)
Variable Char     VALEUR
If [M]STA=3 | [M]AMTMIN<>0
 mkstat = 2 : End
Endif
GBOUT2 = mess(6,115,1) : # Simulation
If VALEUR="" & (GREP="C" | GREP="D") & [M]INVTYP=2 & [M]INVNUM<>""
 Read [SIH2]SIH0 = [M]INVNUM
 VALEUR = [F:SIH2]PTE
Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_PTE(VALEUR)
Variable Char    VALEUR()
If (GREP="C" | GREP="D") & (VALEUR<>[M]PTE | [M]DUDDAT=[0/0/0])
 Local Integer MAXECH
 MAXECH = 150
 Local Shortint NBECH
 Local Decimal  ECHMNT(1..MAXECH) , ECHLOC(1..MAXECH) , ECHRPT(1..MAXECH), MONTANT, MONTHT
 Local Date     ECHDAT(1..MAXECH)
 Local Integer  ECHSOI(1..MAXECH), ECHTYP(1..MAXECH)
 Local Char     ECHPAM(3)(1..MAXECH), OLOCALDEV(3), CODTPT(20)
 Local Decimal  CURRND
 If func CDACUR_SYRA.GET_CURRND(GACTX, [M]CUR, CURRND, GMESSAGE)<>[V]CST_AOK
  mkstat = 2 : End
 Endif
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 OLOCALDEV = GLOCALDEV : GLOCALDEV = [F:CPY]ACCCUR
 MONTANT = [M]AMTATI : If MONTANT = 0 : MONTANT=1000 : Endif
 MONTHT  = [M]AMTNOT
 CODTPT = VALEUR : # On change pas VALEUR, si conditions de remplacement appliquées
 # Ajout du paramétre date du cours
 Call DATECHE_TVA(CODTPT, [M]STRDUDDAT, MONTHT, MONTANT-MONTHT, CURRND, ECHPAM,
&             ECHTYP, ECHMNT, ECHDAT, ECHSOI, NBECH, [M]FCY, [M]RATDAT) From SUBTPT
 GLOCALDEV = OLOCALDEV
 [M]DUDDAT = ECHDAT(1)
Endif
If dim([M:BIC1]UMRNUM)>0
 If GREP="C" | GREP="D" | VALEUR<>[M]PTE
  Raz [M:BIC1]UMRNUM
  [M:BIC1]PTE=VALEUR
  Gosub GRIZO_UMRNUM From INVSDDLIB
 Endif
Endif
End

Subprog D_DEP(VALEUR)
Variable Char    VALEUR()
#----- Chargement Escomptes et agios du client -----#
Call INIT_ESCOMPTE([M:BIC0]BPR,GSOCIETE,"C",VALEUR) From CPTSUB
End

Subprog AS_DEP(VALEUR)
Variable Char    VALEUR()
If (GREP<>"C" & GREP<>"D") | [M]STA=3 | [M]AMTMIN<>0
 mkstat = 2
Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
If GDEPMGTMOD = 5
 [M:BIC1]DEP = VALEUR
 Actzo [M:BIC1]SALPRITYP
 Gosub INI_SALPRITYP From SUBBIC4
Endif
Call AM_DEP(VALEUR) From INVDEPLIB
End

Subprog AS_INVNUM(VALEUR)
Variable Char    VALEUR()
If [M]INVTYP=1 : mkstat = 1 : End : Endif
If [M]STA=3    : mkstat = 2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_INVNUM(VALEUR)
Variable Char VALEUR()
If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD [PYD] : Endif
Local Integer OK
If VALEUR<>""
 Read [SIH2]SIH0 = VALEUR
 If fstat
  # Facture inexistante
  GMESSAGE = mess(7,119,1)
  mkstat = 2 : End
 Elsif [F:SIH2]INVTYP<>1 & [F:SIH2]INVTYP<>3
  # Numéro d'avoir
  GMESSAGE = mess(8,119,1)
  mkstat = 2 : End

 # AUREN - 05.763.047 - Si WS no controlar factura validada
 #Elsif [F:SIH2]STA<>3
 Elsif [F:SIH2]STA<>3 & !GWEBSERV
  # Facture non validée
  GMESSAGE = mess(36,119,1)
  mkstat = 2 : End
 Elsif [F:SIH2]BPR<>[M]BPR
  # Facture du client
  GMESSAGE = mess(31,119,1)-[F:SIH2]BPR
  mkstat = 2 : End
 Elsif [F:SIH2]BPRSAC<>[M]BPRSAC
  # Facture sur le collectif
  GMESSAGE = mess(33,119,1)-[F:SIH2]BPRSAC
  mkstat = 2 : End
 Elsif [F:SIH2]FCY<>[M]FCY
  # Facture sur le site
  GMESSAGE = mess(35,119,1)-[F:SIH2]FCY
  mkstat = 2 : End
 Elsif [F:SIH2]ORIMOD<>3
  # Facture Vente
  GMESSAGE = mess(45,109,1)
  mkstat = 2 : End
 Endif
 For [DUD]DUD1 Where ACCNUM=[F:SIH2]ACCNUM
  For [PYD]PYD1 Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
   If [F:PYH]NUM<>[F:PYD]NUM
    Read [PYH]PYH0 = [F:PYD]NUM
    If !fstat & [F:PYH]STA<3
     # Rčglement en attente sur cette facture
     GMESSAGE = mess(74,119,1)
     mkstat=2 : Break 2
    Endif
   Endif
  Next
 Next

 #Localisation Belge --str
 If func AFNC.ACTIV("KBE")
  Local Char WBELVCS(GLONVCS)
  WBELVCS=[F:SIH2]BELVCS  :#-- memo VCS number
 Endif
 #Localisation Belge --end

 If VALEUR <> [M:BIC1]INVNUM
   For [SIH2]SIH0 Where INVNUM=VALEUR
    # BRBAN 105200#US2
    If func AFNC.ACTIV("INVCA")>0
      If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
        OK=2
        GMESSAGE = VALEUR-mess(80,119,1)-[F:SIH2]NUM
        mkstat=2
        Break
      Endif
    Endif
    # -
    # Cette facture a déjŕ fait l'objet d'un avoir !
    OK=2 : Call AVERTIR(VALEUR-mess(80,119,1)-[F:SIH2]NUM,OK) From GESECRAN
    If OK=1  mkstat=1 : Endif
    Break
   Next
 Endif
 If mkstat : End : Endif
 If [F:SIH2]ACCDAT>[M]ACCDAT
  # La date comptable du document doit ętre supérieure ou égale ŕ la date de la facture
  GMESSAGE = mess(82,119,1)-VALEUR-format$("D:"+GFMDAT4,[F:SIH2]ACCDAT)
  mkstat =2 : End
 Endif
Endif

#Localisation Belge --str
If func AFNC.ACTIV("KBE")
 If find([M]INVTYP,2,4) :#-- avoir/credit-note --> memo VCS number of initial invoice
  Raz [M:BIC1]BELVCS
  If func FIN_PARAM(GAC_KBE, "BELVCS",GSOCIETE)="2"
    If VALEUR<> "" : [M:BIC1]BELVCS=WBELVCS : Endif
    If !GIMPORT : Affzo [M:BIC1]BELVCS : Endif
  Endif
  If GIMPORT : [F:SIH]BELVCS=[M:BIC1]BELVCS : Endif
 Endif
Endif
#Localisation Belge --end

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If !clalev([F:ISIH]) : Local File SINVOICE  [ISIH] : Endif

  Read [F:ISIH]SIH0=VALEUR
  If !fstat
    If [F:ISIH]REVCANSTA<>0 & VALEUR <> [M:BIC1]INVNUM
      GMESSAGE = mess(2,7712,1)
      mkstat = 2
      End
    Endif
  Else
    Raz [F:ISIH]
  Endif
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    If VALEUR=''
      GMESSAGE = mess(10,123,1)
      mkstat=2
      End
    Else
      # Issue 37086 - 2017-07-12 by RMA : It should not be possible to cancel a paided invoice.
      If clalev([F:DAE]) = 0 : Local File GACCENTRYD [DAE] : Endif
      Read [F:DAE]DAE2 = [F:ISIH]ACCNUM
      If !fstat & [F:DAE]MTC <> ""
        GMESSAGE=mess(8,7712,1) :#--It's not possible to cancel a matched invoice.
        mkstat = 2
        End
      Endif
    Endif

  Endif
Endif
# -

End

Subprog AP_INVNUM(VALEUR)
Variable Char VALEUR()
If [M]INVTYP=2 & VALEUR="" & GREP="C"
 Local Char CHAINE(10)
 Call PARAM([M]FCY,"WRNINVOICE",CHAINE) From ADOVAL
 If val(CHAINE)=2 & !GIMPORT
  Local Integer OK
  OK = 2
  ## Avoir sans numéro de facture
  If !GIMPORT : Call AVERTIR(mess(9,119,1),OK) From GESECRAN : Endif
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

