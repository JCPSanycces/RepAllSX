Subprog AM_PTE(VALEUR)
Variable Char    VALEUR()
# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & !find([M:BIC0]INVTYP,2,4)
  # If Payment terms were SE and no longer are - void any outstanding Auth
  If !func SEPPLIB.SEPP_DOC(VALEUR) & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
    Local Integer SEVCRTYP
    If find([M:BIC0]INVTYP,2,4) : SEVCRTYP = 41 : Else : SEVCRTYP = 40 : Endif
    If func SEPPCDT.SEPP_OK(SEVCRTYP,[M:BIC0]NUM,1) & !find(GREP,"C","D")
      Call MESSAGE(mess(38,2092,1)) From GESECRAN
    Endif
  Endif
Endif

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, VALEUR, [M:BIC1]CUR) From SUBBICSWI
Endif
# SAM 110033 END

End
