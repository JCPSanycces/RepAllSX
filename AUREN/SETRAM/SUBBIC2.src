## Section automatically added (screen BIC1) 20/05/2015 17:58:25 (BRBAN)
######################################################################################
Subprog AM_INVNUM(VALEUR)
Variable Char    VALEUR()
# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    If !clalev([F:ISIH]) : Local File SINVOICE   [ISIH] : Endif
    If !clalev([F:ISIL]) : Local File BPCINVLIG  [ISIL] : Endif
    If !clalev([F:IDUD]) : Local File GACCDUDATE [IDUD] : Endif
    If !clalev([F:ISIA]) : Local File BPCINVLIGA [ISIA] : Endif

    Local Date    WACCDAT : [L]WACCDAT  = [M:BIC0]ACCDAT
    Local Integer WNOL    : [L]WNOL     = 0
    Local Integer WI      : [L]WI       = 0
    Local Integer WOK     : [L]WOK      = 0
    Local Char    WINVNUM : [L]WINVNUM  = ''
    Local Integer NLED
    Local Integer LIGANA,AXE,INDAXE
    Local Decimal MONTMIN,MONTPRO

    If [M:BIC0]INVCRE<>2
      Call OUINON (func AFNC.MES1(mess(1,7712,1),VALEUR),[L]WOK) From GESECRAN
      If [L]WOK=1
        mkstat=2
        End
      Endif
    Endif
    [L]WINVNUM=VALEUR
    Read [F:ISIH]SIH0=VALEUR
    If !fstat
      Raz [M:BIC3]
      Raz nolign, [M:VTL], [M:VT2]
      Raz [M]LSTLED, [M]LSTACC, [M]LSTAXE
      ## Initialisations globales plans/axes
      If !GIMPORT Then
       Call AFFCOL(1) From SUBBICS
       Gosub SETCHPAXE From SUBBICS
      Endif
      If dim([M:BIC1]NBRCCE)>0 : [M:BIC1]NBRCCE = GNBAXE : Endif
      For [ISIL]SIL0 Where NUM=[F:ISIH]NUM
       nolign += 1
       [M:BIC1] = [F:ISIL]
       [M:BIC3] = [F:ISIL]

       For NLED=1 To GNBTYPLED
        Assign "[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")" With [F:ISIL]ACC(GTYPLED(NLED)-1)
       Next

       Call CAL_BASDEPLIN([M:BIC1]DEP,[M:BIC3]FLGDEP(nolign-1),nolign) From INVDEPLIB

       If [F:ISIL]DSP=""
        OK = 0 : LIGANA = 0
        For [ISIA]SIA0 Where NUM=[F:ISIL]NUM & LIG=[F:ISIL]LIG
         LIGANA += 1
         If !OK : OK = LIGANA : Endif
         [M:VT2]TBAMT(LIGANA) = [F:ISIA]AMT
         [M:VT2]TBQTY(LIGANA) = [F:ISIA]QTY
         For AXE=1 To GNBAXE
          INDAXE = find(GAXE(AXE),[F:ISIA]DIE(0..dim([F:ISIA]DIE)-1))
          If INDAXE
           Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:ISIA]CCE(INDAXE-1)
          Endif
         Next AXE
        Next
        If OK
         If OK=LIGANA
          For I=1 To GNBAXE
           Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")")
           Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")" With ""
          Next I
          LIGANA -= 1
         Else
          [M]PTV(nolign-1) = OK
          [M]PTF(nolign-1) = LIGANA
          [M]DSP(nolign-1) = "$"
          For I=1 To GNBAXE : # Pour initialiser les champs sections
           Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With ""
          Next I
         Endif
        Endif
       Endif
      Next

      [M:VT2]PTVENT = LIGANA+1
      [M]NBLIG = nolign

      Call LEC_TCU([F:ISIH]CUR) From CPTLEC
      Call LEC_FCY([F:ISIH]FCY) From CPTLEC
      Call LEC_CPY([F:ISIH]CPY) From CPTLEC
      Call LEC_BPR([F:ISIH]BPR) From CPTLEC
      Call LEC_GTE_LEG(GCURLEG,[F:ISIH]GTE) From CPTLEC

      [M]CPYNAM = [F:CPY]CPYSHO
      [M]BASDEP = sum([M]BASDEPLIN(0..[M]NBLIG-1))
      [M]TOTNOT = sum([M]AMTNOTLIN(0..[M]NBLIG-1))
      [M]TOTATI = sum([M]AMTATILIN(0..[M]NBLIG-1))
      If sum([M]FLGGEN(0..[M]NBLIG-1))>[M]NBLIG
       [M]FASFLG = 2
      Else
       [M]FASFLG = 1
      Endif

      #Menu Adresse facture la premičre fois , récupérer les infos ds BPADDRESS
      If [M:BIC0]NUM = ""
       # save the two lines
       For J=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:BPR]BPRNAM))-1
        [M:BIC0]BPRNAMBIS(J) = [F:BPR]BPRNAM(J)
       Next J
       #Display only the first line
       [M:BIC0]BPRNAM(0) = [F:BPR]BPRNAM(0)

       Read [BPA]BPA0 = 1;[M:BIC0]BPR;[M:BIC0]BPAINV
       If !fstat
        For I=0 To min(dim([M:BIC0]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
         [M:BIC0]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
        Next I
        [M:BIC0]POSCOD = [F:BPA]POSCOD
        [M:BIC0]CTY    = [F:BPA]CTY
        [M:BIC0]CRY    = [F:BPA]CRY
        [M:BIC0]SAT    = [F:BPA]SAT
        If [F:BPA]CRYNAM<>"" : [M:BIC0]CRYNAM = [F:BPA]CRYNAM
        Else [M:BIC0]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[M:BIC0]CRYNAM) From TRTDIV
        Endif
       Endif
      #Menu Adresse facture sur facture existante récupérer les infos ds SINVOICE
      Else
      # save the two lines
      If [M:BIC0]BPRNAM(0)<>""
       For J=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:ISIH]BPRNAM))-1
        [M:BIC0]BPRNAMBIS(J) = [F:ISIH]BPRNAM(J)
       Next J
      Else
       For K=0 To min(dim([M:BIC0]BPRNAMBIS),dim([F:BPR]BPRNAM))-1
        [M:BIC0]BPRNAMBIS(K) = [F:BPR]BPRNAM(K)
       Next K
      Endif
      #Display only the first line
      [M:BIC0]BPRNAM(0) = [F:ISIH]BPRNAM(0)

       For I=0 To min(dim([M:BIC0]BPAADDLIG),dim([F:ISIH]BPAADDLIG))-1
        [M:BIC0]BPAADDLIG(I) = [F:ISIH]BPAADDLIG(I)
       Next I
       [M:BIC0]POSCOD = [F:ISIH]POSCOD
       [M:BIC0]CTY    = [F:ISIH]CTY
       [M:BIC0]CRY    = [F:ISIH]CRY
       [M:BIC0]SAT    = [F:ISIH]SAT
       If [F:ISIH]CRYNAM<>"" : [M:BIC0]CRYNAM = [F:ISIH]CRYNAM
       Else [M:BIC0]CRYNAM="" : Call INIPAYS([F:ISIH]CRY,[M:BIC0]CRYNAM) From TRTDIV
       Endif
      Endif

      Call INFOECHE(1,[F:ISIH]NUM,MONTMIN,MONTPRO) From SUBBIH
      [M]AMTMIN = MONTMIN
      [M]AMTTMP = MONTPRO
      For I=0 To min(dim([M:BIC1]DES),dim([F:ISIH]DES))-1
       [M:BIC1]DES(I) = [F:ISIH]DES(I)
      Next I
      Filter [IDUD] Where ACCNUM=[F:ISIH]ACCNUM
      Read [IDUD]DUD1 First
      If !fstat
       [M]DUDDAT  = [F:IDUD]DUDDAT
       [M]XSOI    = [F:IDUD]SOI
       [M]XFLGFUP = [F:IDUD]FLGFUP
      Endif
      Filter [IDUD]
      If !GIMPORT
       Call CHARGE_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
      Endif
      [M]RAT1   = [M]RATDIV(GTYPGEN-1)
      [M]LABEL  = [M]CUR-"="
      [M]RAT2   = [M]RATMLT(GTYPGEN-1)
      [M]CURDIV = [M]CUR : # Zone invisible
      [M]CURMLT = [M]CURLED(GTYPGEN-1)
      Diszo [M:BIC1]RAT1,RAT2

      Read [GAC]GAC1 = GPLAN(1);[M:BIC0]BPRSAC
      If !fstat : [M:BIC0]SACACC=[F:GAC]ACC : Else : Raz [M:BIC0]SACACC : Endif

      Call LECTURE("FCT",[F:ISIH]BPRFCT,"") From CONTOBJ
      [M]BPRFCTNAM = [F:FCT]FCTNAM
      Call SETCOLOR([M:BIC1]SALPRITYP) From SUBBIC4
      [M:BIC1] = [F:ISIH]
      [M:BIC1]INVNUM = [L]WINVNUM
      Raz [M:BIC1]STA,STARPT

#      [M:BIC3]TOTATI = [F:ISIH]AMTATI
#      [M:BIC3]TOTNOT = [F:ISIH]AMTNOT
#      [M:BIC1]AMTATI = [F:ISIH]AMTATI
#      [M:BIC1]AMTNOT = [F:ISIH]AMTNOT
#      [M:BIC1]INVNUM = [L]WINVNUM
#
#      Filter [F:ISIL] Where [F:ISIL]NUM=[F:ISIH]NUM
#      For [F:ISIL]
#        Gosub ALIM_BIC3
#        [M:BIC3] = [F:ISIL]
#        [M:BIC3]NUMLIG = [L]WNOL
#        [L]WNOL +=1
#      Next
#      [M:BIC3]NBLIG = [L]WNOL
#      Filter [F:ISIL]
#
#      Filter [F:IDUD] Where ACCNUM=[F:ISIH]ACCNUM
#      Read [F:IDUD]DUD1 First
#      If !fstat
#       [M:BIC1]DUDDAT  = [F:IDUD]DUDDAT
#       [M:BIC1]XSOI    = [F:IDUD]SOI
#       [M:BIC1]XFLGFUP = [F:IDUD]FLGFUP
#      Endif

      Affzo [M:BIC1]
      Affzo [M:BIC3]
    Endif
  Endif
Endif
# -
End

# SAM 110033: Swiss localization: calculate PAYBAN
Subprog AS_PAYBAN(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KSW") and [M:BIC1]PAYBAN = "" Then
  Call CALC_PAYBAN([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, [M:BIC1]BPRPAY, [M:BIC1]CUR) From SUBBICSWI
Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

# SAM 110033: Swiss localization: check if payment method is of type "ISR Printing" and if yes, apply additional controls
Subprog C_PAYBAN(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KSW") Then
   Call CONTROL_PAYBAN([M:BIC0]CPY,[M:BIC0]FCY,VALEUR) From SUBSIHSWI
Endif
End
