#---- Gestion adresse ----

Subprog D_BPAPAY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPC",[M:BIC0]BPR,"") From CONTOBJ
#si le client est de type Divers l'adresse payeur est tjs celle de l'adresse facture modifiée ou pas
If [F:BPC]BPCTYP= 2 & [M:BIC1]BPRPAY = [M:BIC0]BPR
  VALEUR = [M:BIC0]BPAINV
Else
 VALEUR = [F:BPC]BPAPYR
 If VALEUR<>""
  Gosub LECADR : End
 Else
  #Recherche de l'adresse par défaut mais tjs définie dans la fiche client
  Read [BPA]BPA0 = 1;[M]BPRPAY;[F:BPC]BPAADD
  If !fstat : VALEUR = [F:BPC]BPAADD : Gosub LECADR : End : Endif
 Endif
Endif
End

Subprog C_BPAPAY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [BPA]BPA0 = 1;[M]BPRPAY;VALEUR
 If fstat
  # Adresse inexistante
  GMESSAGE = mess(10,119,1)
  mkstat = 2 : End
 Endif
Endif
Gosub LECADR
End

$LECADR
Call LECTURE("BPC",[M]BPRPAY,"") From CONTOBJ
If ([M]BPRPAY=[M]BPR & [F:BPC]BPCTYP = 2)
 For I=0 To min(dim([M]BPYADDLIG),dim([M]BPAADDLIG))-1
  [M]BPYADDLIG(I) = [M]BPAADDLIG(I)
 Next I
 [M]BPYPOSCOD = [F:SIH]POSCOD
 [M]BPYCTY    = [F:SIH]CTY
 [M]BPYCRY    = [F:SIH]CRY
 [M]BPYSAT    = [F:SIH]SAT
 If [F:SIH]CRYNAM<>"" : [M]BPYCRYNAM = [F:SIH]CRYNAM
 Else [M]BPYCRYNAM="" : Call INIPAYS([F:SIH]CRY,[M]BPYCRYNAM) From TRTDIV
 Endif
 For I=0 To min(dim([M]BPYNAM),dim([F:SIH]BPYNAM))-1
  [M]BPYNAM(I) = [F:SIH]BPYNAM(I)
 Next I
Else
 Raz [M]BPYNAM, [M]BPYADDLIG
 Read [BPA]BPA0 = 1;[M]BPRPAY;VALEUR
 If !fstat
  For I=0 To min(dim([M]BPYADDLIG),dim([F:BPA]BPAADDLIG))-1
   [M]BPYADDLIG(I) = [F:BPA]BPAADDLIG(I)
  Next I
  [M]BPYPOSCOD = [F:BPA]POSCOD
  [M]BPYCTY    = [F:BPA]CTY
  [M]BPYCRY    = [F:BPA]CRY
  [M]BPYSAT    = [F:BPA]SAT
  If [F:BPA]CRYNAM<>"" : [M]BPYCRYNAM = [F:BPA]CRYNAM
  Else [M]BPYCRYNAM="" : Call INIPAYS([F:BPA]CRY,[M]BPYCRYNAM) From TRTDIV
  Endif
 Endif
 Call LECTURE("BPR",[M]BPRPAY,"") From CONTOBJ
 For I=0 To min(dim([M]BPYNAM),dim([F:BPR]BPRNAM))-1
  [M]BPYNAM(I) = [F:BPR]BPRNAM(I)
 Next I
Endif
Return

Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPC",[M:BIC0]BPR,"") From CONTOBJ
If (VALEUR<>"" & (GREP="D" | GREP="C"))
 If [F:BPC]BPCTYP=2 & VALEUR=[M:BIC0]BPR
  #si le client et de type Divers l'adresse payeur est tjs celle de l'adresse facture modifiée ou pas
  [M:BIC1]BPAPAY= [M:BIC0]BPAINV
 Elsif VALEUR=[F:BPC]BPCPYR
  [M:BIC1]BPAPAY = [F:BPC]BPAPYR
  If [M:BIC1]BPAPAY<>""
   Gosub LECADR
  Else
   #Recherche de l'adresse par défaut mais tjs définie dans la fiche client
   Call LECTURE("BPC",VALEUR,"") From CONTOBJ
   Read [BPA]BPA0 = 1;VALEUR;[F:BPC]BPAADD
   If !fstat : [M:BIC1]BPAPAY = [F:BPC]BPAADD : Gosub LECADR : Endif
  Endif
 Else
  #Recherche de l'adresse par défaut mais tjs définie dans la fiche client
  Call LECTURE("BPC",VALEUR,"") From CONTOBJ
  Read [BPA]BPA0 = 1;VALEUR;[F:BPC]BPAADD
  If !fstat : [M:BIC1]BPAPAY = [F:BPC]BPAADD : Gosub LECADR : Endif
 Endif
Endif

# SAM 110033: Swiss localization: recalculate PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_PAYBAN([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]PTE, VALEUR, [M:BIC1]CUR) From SUBBICSWI
Endif
# SAM 110033 END

# Issue X3-195182 by MRDAB/MAPON
Gosub PROMPT_BP_BID From SUBBIH
# Issue X3-195182 end

End

