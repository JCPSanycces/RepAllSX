######################################################################################
## Section automatically added (screen BIC1) 09/04/2020 09:28:44 (JUCON)
######################################################################################
# X3-213430 Default value of Spanish invoice type
Subprog AS_INVTYPSPA(VALEUR)
Variable Integer VALEUR

Local Char TYPSPA(1), SPACPY(GLONCPY)
If [M:BIC0]INVTYP=2
  Local File FACILITY [SFCY]
  Read [SFCY]FCY0=[M:BIC0]FCY
  If !fstat
    SPACPY=[F:SFCY]LEGCPY
    Call PARAML(SPACPY,"SIIABTYP",TYPSPA) From ADOVAL
    If val(TYPSPA)<>0: [M:BIC1]INVTYPSPA=val(TYPSPA): Else [M:BIC1]INVTYPSPA=6 Endif
    Affzo [M:BIC1]INVTYPSPA
  Endif
  Close File [SFCY]
Endif
End


######################################################################################
#AUREN>
#CARGA EJES
Subprog ZAXE(P_FCY)
  Value Char P_FCY
  If clalev([F:ZFCY1]) = 0 : Local File FACILITY [F:ZFCY1] : Endif
  If clalev([F:ZCPY1]) = 0 : Local File COMPANY [F:ZCPY1]  : Endif
  If clalev([F:ZGCM1]) = 0 : Local File GACM    [F:ZGCM1]  : Endif
  If clalev([F:ZLED1]) = 0 : Local File GLED    [F:ZLED1]  : Endif
  Local Integer I,J,ZIND:Raz ZIND

  Read [F:ZFCY1]FCY0 First
  If !fstat Then
    Read [F:ZCPY1]CPY0 = [F:ZFCY1]LEGCPY
    If !fstat Then
      Read[F:ZGCM1]GCM0 = [F:ZCPY1]ACM
      If !fstat Then
        For I=0 To 9
          Read [F:ZLED1]LED0 = [F:ZGCM1]LED(I)
          If !fstat and[F:ZLED1]ANA = 2 Then
            For J=0 To [F:ZLED1]DIENBR-1
              [M:BIC1]DIE(J)= [F:ZLED1]DIE(J)
            Next
            [M:BIC1]NBRCCE = J
            Affzo [M:BIC1]
            Break
          Endif
        Next
      Endif
    Endif
  Endif
End
#AUREN<
