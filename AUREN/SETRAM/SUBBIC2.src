If mkstat : End : Endif
Gosub AFF_CCE
End

$AFF_CCE
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LECTURE("CCE",VALEUR,GAXE(AXE)) From CONTOBJ
 If !fstat
  [M]AFFICHE = VALEUR-":"-[F:CCE]DES : Affzo AFFICHE
 Endif
Endif
Return

Subprog APRES_NBLIG
Local Integer MAXLIG
MAXLIG = max(nolign,[M]NBLIG)-1
[M]TOTNOT = sum([M]AMTNOTLIN(0..MAXLIG))
[M]TOTATI = sum([M]AMTATILIN(0..MAXLIG))
[M]BASDEP = sum([M]BASDEPLIN(0..MAXLIG))
If status<>7
 If !GIMPORT
  Affzo TOTNOT, TOTATI
  Affzo BASDEP
 Endif
Endif
##### BESPR 87307 06/04/2013 # Intercompany enhancement
Gosub SETNOL
If GFONC1 = "GESBICI" and (([M]CPY <> [M]CPYLIN(NOL)) or (GCURINTCPY <> "" and GCURINTCPY<>[M]CPYLIN(NOL)))
  Call INTCPY_APRES_NBLIG (1, [M]CPYLIN(NOL), [M]FCYLIN(NOL)) From INTCPYLIB
Endif
#####
End

Subprog AV_NBLIG
GDEV1(1) = [M]CUR
End

Subprog IB_NBLIG
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4
##### BESPR 87307 07/03/2013 # Intercompany enhancement - right click Dimension option / button
Raz GBOUT6 : If GFONC1="GESBICI" and [M]CPYLIN(nolign-1)<>[M]CPY and [M]CPYLIN(nolign-1)<>"" : Call INTCPY_IB_NBLIG ([M]CPYLIN(nolign-1),[M]FCYLIN(nolign-1),1) From INTCPYLIB : Endif
#####
If [M]STA<3 : # GH 28/02/01 bug 8177
 Call TITOBJ("GDA","",GBOUT4) From CONTOBJ : # Schémas de comptes
Endif
If nolign-1<[M]NBLIG
 Call TITOBJ("GAC","",GBOUT1) From CONTOBJ : # Comptes généraux
 GBOUT2 = mess(29,106,1) : # Codes statistiques
 If GFONC1<>"GESBICI" : GBOUT3 = mess(112,119,1) : Endif # Périodes de prestation #####BESPR 87307 05/31/2013 # Intercompany
Endif
# Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
#If func SUBBIC2.FIN_PARAM(GAC_SVC, "SVCFLG",[M]CPY)<> "2" : Raz GBOUT3 : Endif
If !func AFNC.ACTIV("SVC") #Issue X3-229448 - 2020-12-20 by VAVIL : GESBIS - SVC active + SVCFLG = No : Periodic accruals not enterable
  Raz GBOUT3
Endif
# End issue X3-199974
Call IB_NOTECHECK([M:BIC3]BPRLIN(nolign-1),"BPCNUM",5)  From TRTNTSCTL # customer notes

# BRBAN 105200#US2 Supress Account scheme header button
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Raz GBOUT4
  Endif
Endif
# -
End

##### BESPR 87307 08/13/2013 # Intercompany enhancement - right click Dimension option / button - re-display dimensions incase they changed
Subprog B6_NBLIG
Affzo [M:BIC3]CCE1(nolign-1),CCE2(nolign-1),CCE3(nolign-1),CCE4(nolign-1),CCE5(nolign-1),CCE6(nolign-1),CCE7(nolign-1),CCE8(nolign-1),CCE9(nolign-1),CCE10(nolign-1)
Affzo [M:BIC3]CCE11(nolign-1),CCE12(nolign-1),CCE13(nolign-1),CCE14(nolign-1),CCE15(nolign-1),CCE16(nolign-1),CCE17(nolign-1),CCE18(nolign-1),CCE19(nolign-1),CCE20(nolign-1)
# Must reset mkstat to 4 here to enable the SAVE button because the Affzo clears it from INTCPYCCE
mkstat = 4
End
#####

Subprog AS_NBLIG

If (nolign=1 and [M]NBLIG=0) or (GREP="D")
 Local Integer LEVEL_CTL
 LEVEL_CTL = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"HEAAMTBPC")
 Case LEVEL_CTL
 When 1     #
 When 2     # Amt-tax and Amt+tax must be entered
  If [M]AMTNOT = 0 or  [M]AMTATI = 0
    GERR=1 :  GMESSAGE = mess(108,119,1)
    mkstat=2 : End
  Endif
 When Default
 Endcase
Endif

If [M]STA<3
 If [M:BIC3]JOUCPT="" : Gosub INI_JOU : Endif
Endif
If nolign-1<[M]NBLIG
 If nolign>0 & [M]ACC1(nolign-1)<>""
  Local Integer EXERCICE, PERIODE, ASTATUS
  ASTATUS = func FINPER_SYRA.GET_PER(GACTX, [M]CPY, GTYPGEN, [M]ACCDAT, EXERCICE, PERIODE, GMESSAGE)
  Read [FIY]FIY0 = [M]CPY;GTYPGEN;EXERCICE
 Endif
Endif
Gosub AFF_NBLIG
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

$AFF_NBLIG
Local Char    VALEUR(10)
Local Integer NLED
If nolign>0
 NLED = 1
 While evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")="" & NLED<=GNBTYPLED
  NLED += 1
 Wend
 If evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")<>""
  VALEUR = evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")
  Gosub AFF_ACC
 Endif
Endif
Return

$INI_JOU
Local Char TRANSAC(GLONGAU), JOU(GLONJOU)
Local Integer STAT
[L]JOU = [M:BIC0]JOU
If [L]JOU = ""
 If [M:BIC0]SIVTYP = "" : Return : Endif
 Call LEC_TSV_LEG(GCURLEG,[M:BIC0]SIVTYP) From CPTLEC
 If fstat | [F:TSV]INVTYP=5 | [F:TSV]COD2="" : Return : Endif
 If [F:TSV]JOU<>""
  [L]JOU = [F:TSV]JOU
 Else
  TRANSAC = [F:TSV]COD2
  Call LECTURE("GAU",TRANSAC,"") From CONTOBJ
  If fstat | [F:GAU]TBL<>"SINVOICE" : Return : Endif
  Onerrgo ERREUR
  If clalev([F:TB0])=0 : Local File =[F:GAU]TBL [TB0] : Endif
  Onerrgo
  If STAT : Return : Endif
  [F:TB0] = [M:BIC0]
  [F:TB0] = [M:BIC1]
  Call EVALAUTO(TRANSAC,"JOU",[L]JOU) From SUBBIC
  If [L]JOU="" : Return : Endif
 Endif
Endif
If !clalev([F:JCO]) : Local File GJOUCOA [JCO] : Endif
Call LEC_JCO_LEG(GCURLEG,GPLAN(1),[L]JOU) From CPTLEC
If fstat | [F:JCO]FRQNBR=0 : Return : Endif
[M:BIC3]JOUCPT=[L]JOU
Return

$ERREUR
STAT=1
Resume

Subprog C_NBLIG
If find(status,65,68,83,73,82,67)
  If [M]STA>=3
    mkstat = 2 : End
  Elsif GLBINVCA_ON = 2
    If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
      mkstat = 2 : End
    Endif
  Endif
Endif

#IRMUE 14.05.12 81574:AP/AR management begin
Call SETCOLOR([M:BIC1]SALPRITYP) From SUBBIC4
If [M:BIC3]NBLIG <> 0
   Diszo [M:BIC1]SALPRITYP
Else
 If GDEPMGTMOD=1 or (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP))
   Diszo [M:BIC1]SALPRITYP
 Else
   Actzo [M:BIC1]SALPRITYP
 Endif
Endif
#IRMUE 06.11.12 81574:AP/AR management end
#Finance_Sophia US97/SP5/Exi81664
If find(status,65,68,83) & [M:BIC3]FLGGEN(nolign-1)=2
 mkstat = 2 : End
Endif

If GFONC1 = "GESBICI" : Call INTCPY_C_NBLIG (1) From INTCPYLIB  :  Endif : ##### BESPR 87307 06/13/2013 # Intercompany
End

Subprog AVANT_NBLIG
Gosub AFF_NBLIG
End

