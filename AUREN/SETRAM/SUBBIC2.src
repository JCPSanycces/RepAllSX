Subprog D_XSOI(VALEUR)
Variable Integer VALEUR
If GPAYTERM=1   :# tiers payeur
 Call LECTURE("BPC",[M]BPRPAY,"") From CONTOBJ
 If fstat
  Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
 Endif
Else
 Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
Endif
If dim([F:BPC]SOIPER)>0
 VALEUR = 1+([F:BPC]SOIPER>1)
Else
 VALEUR = 1
Endif
If VALEUR=2
 If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
 Call LEC_TPT_LEG(GCURLEG,[M]PTE,1) From CPTLEC
 VALEUR = [F:TPT]SOIFLG
Endif
End

Subprog D_XFLGFUP(VALEUR)
Variable Integer VALEUR
If GPAYTERM=1   :# tiers payeur
 Call LECTURE("BPC",[M]BPRPAY,"") From CONTOBJ
 If fstat
  Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
 Endif
Else
 Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
Endif
If dim([F:BPC]FUPTYP)>0 & [F:BPC]FUPTYP<2
 VALEUR = 1
Else
 VALEUR = 2
Endif
End

Subprog AS_NBRCCE

If [M]STA=3 : mkstat=2 : End : Endif
If [M]NBRCCE=0
 Call D_NBRCCE
Endif
Local Integer AXE
For AXE=1 To GNBAXE
 If [M]SAIAXE(AXE-1)<>2
  Diszo [M:BIC1]CCE(AXE-1)
  Grizo [M:BIC1]CCE(AXE-1)
 Else
  Actzo [M:BIC1]CCE(AXE-1)
 Endif
Next
End

