#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Issue X3-217797 - 2020-10-20 by RCU : Account structure only applied if site/company is in scope.
# Issue X3-205959 by MRDAB/MAPON - BPRPAY to be disabled for posted invoices
# Issue X3-195162, X3-195181, X3-195182 - 2020-06-23 by MRDAB/MAPON : Defualt bank account at the invoice level - on open item
# Issue X3-149911 - 2019-08-05 by UB : Add Cost type field to GESBIC invoice lines
# Issue X3-101376 - 2018-07-23 by MWA : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
# Issue X3-99385  - 2018-07-12 by CBO : Import large number of Supplier BP invoices failed on 2018 R4 cloud site


# Issue X3-99385 : all AFNC.PARAM() with activity code are replaced by SUBBIC2.FIN_PARAM()
# Issue X3-114880: during the entering a customer invoice (GESBIC) in a currency for which there is no exchange rate entered,
# there is a problem with calculating the gross value and it have to calculate like GESBIS does
# Issue X3-213430-2020-03-03 by JUCON: Default value of Spanish invoice type

GPILBOITE=0
Raz GPILOBJ, GPILCOD
Call OBJET("BIC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Return

# Issue X3-99385
#**

#**
#* Verify if activity code is ok
#* before calling func AFNC.PARAM()
#*
#* @param PACTIVITY_CODE
#* @param PARAM
#* @param SITE
#*!
Funprog FIN_PARAM(PACTIVITY_CODE, PARAM, SITE)
Value Integer PACTIVITY_CODE
Value Char PARAM
Value Char SITE

  If PACTIVITY_CODE <> 1
    End ""
  Endif

End func AFNC.PARAM(PARAM, SITE)

# End Issue X3-99385
########################################
## Ecran BIC1                         ##
########################################
Subprog D_BPRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = [M]ACCDAT
End

Subprog AS_BPRDAT(VALEUR)
Variable Date    VALEUR
If [M]STA=3
 mkstat = 2 : End
Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AM_BPRDAT(VALEUR)
Variable Date    VALEUR
Local Date SVG_RATDAT
Call AM_BPRDAT(VALEUR) From SUBBICS
#--- Initialisation des cours devise (Suggestion V140)
If [M]CUR<>'' & SVG_RATDAT<>[M]RATDAT
 Call INI_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
Endif
End

Subprog AP_BPRVCR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR<>"" & (VALEUR<>[M]BPRVCR or GREP="D")
 Filter [SIH] Where NUM<>[M]NUM
 Read [SIH]SIH1 = [M]BPR;VALEUR
 Filter [SIH]
 If !fstat
  # Référence saisie sur facture
  OK = 2 : Call AVERTIR(mess(6,119,1)-[F:SIH]NUM,OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
# Devise : toujours accessible pour atteindre la fenętre des cours => Gestion Grizo/Actzo
If [M:BIC0]AMTMIN<>0 | [M]STA=3
 Diszo [M]CUR
Else
 Actzo [M]CUR
Endif

# BRBAN 105200#US2
If GLBINVCA_ON = 2
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Diszo [M]CUR
  Endif
Endif
# -
End

Subprog D_CUR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
VALEUR = [F:BPC]CUR
End

Subprog C_CUR(VALEUR)
Variable Char VALEUR
Local Date SVG_RATDAT
If [F:GAC]ACCSHO<>[M]BPRSAC
 Read [GAC]GAC1 = GPLAN(1);[M]BPRSAC
Endif
If [F:GAC]CUR<>"" & [F:GAC]CUR<>VALEUR
 # Devise du compte
 GMESSAGE = [F:GAC]ACC-mess(13,106,1)-[F:GAC]CUR :
 mkstat = 2 : End
Endif
SVG_RATDAT = [M]RATDAT
Call LEC_GTE_LEG(GCURLEG,[M:BIC0]GTE) From CPTLEC
If [F:GTE]RATDAT=2 & [M]BPRDAT<>[0/0/0]
 [M]RATDAT = [M]BPRDAT
Else
 [M]RATDAT = [M]ACCDAT
Endif
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
 If !clalev([F:SEU]) : Local File SEAUTH [SEU] : Endif
 If func SEPPCDT.SEPP_OK(41-mod([M]INVTYP,2),[M:BIC0]NUM,1) & [F:SEU]CUR<>"" & VALEUR<>[F:SEU]CUR
  GMESSAGE = mess(47,2092,1)
  mkstat = 2 : End
 Else : Raz fstat
 Endif
Endif
Call CONTDEV(VALEUR,[M]RATDAT) From TRTDEV
If mkstat : End : Endif
If SVG_RATDAT<>[M]RATDAT
 Call INI_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
Endif
End

Subprog AM_CUR(VALEUR)
Variable Char VALEUR()
Local Integer STAT
If !GIMPORT
 [M]CUR=VALEUR
 Call INI_COURS("BIC1",[M]CPY,[M]CUR,[M]RATDAT,[M]CURTYP) From SUBBICS
Endif

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:BIC0]FCY, [M:BIC0]INVTYP, [M:BIC1]BPRPAY, VALEUR) From SUBBICSWI
Endif
# SAM 110033 END

End

Subprog AS_RAT1(VALEUR)
Variable Decimal VALEUR
If [M]STA=3 : mkstat=2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AS_RAT2(VALEUR)
Variable Decimal VALEUR
If [M]STA=3 : mkstat=2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog AM_RAT1(VALEUR)
Variable Decimal VALEUR
Local Char ZONE(10) : # Nom de zone dans la masque SAICURLED
ZONE = "RATDIV" : Goto AM_RAT

Subprog AM_RAT2(VALEUR)
Variable Decimal VALEUR
Local Char ZONE(10) : # Nom de zone dans la masque SAICURLED
ZONE = "RATMLT" : Goto AM_RAT

$AM_RAT
# Mise ŕ jour du masque SAICURLED [M:SCL]
Local Integer INDLED
INDLED = find(GTYPGEN,[M:SCL]LEDTYP(0..[M]NBRC-1))
Assign "[M]"+ZONE+"("+num$(INDLED-1)+")" With VALEUR
If [M]CURLED(INDLED-1)<>[M]CUR
 Gosub INI_AUTLED
Endif
End


$INI_AUTLED
# Mise ŕ jour du masque HAEF
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
For J=1 To len(mess(0,2644,1))
 If J<>INDLED
  If func FINACM_SYRA.GET_LEDCUR(GACTX, [M]CPY, J, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
   mkstat = 2 : Break
  Endif
  If DEVLED = [M]CURLED(INDLED-1) & [F:GCM]FLGVCRRAT(J-1)=2
   Assign "[M]"+ZONE+"("+num$(J-1)+")" With VALEUR
  Endif
 Endif
Next
Return


Subprog AS_AMTNOT(VALEUR)
Variable Decimal VALEUR
If (GREP<>"C" & GREP<>"D") | [M]STA=3 : mkstat = 2 : End : Endif
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End

Subprog C_AMTNOT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
 Local Integer LEVEL_CTL
 LEVEL_CTL = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M:BIC0]CPY,"HEAAMTBPC")
 If  LEVEL_CTL = 2
  # Amt-tax and Amt+tax must be entered
  GERR=1 :  GMESSAGE = mess(108,119,1)
  mkstat=2 : End
  Endif
 Endif
End

