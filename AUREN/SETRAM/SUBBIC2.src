#LTA.sn
Subprog AS_SSTCOD(VALEUR)
Variable Char    VALEUR()
If [M]STA=3 : mkstat = 2 : End : Endif
#LTA 79065
If [M:BIC3]SSTCOD(nolign-1)=""
  If [F:GAC]ACC<>[M:BIC3]ACC1(nolign-1) & [M:BIC3]ACC1(nolign-1)<>""
    Read [F:GAC] = GPLAN(1);[M:BIC3]ACC1(nolign-1)
    If fstat : Raz [F:GAC]FLGVAT : Endif
  Endif
  If [F:GAC]FLGVAT=1 & VALEUR = ""                 # GL account is not subject to tax then default "NT" into SST tax code
      VALEUR="NT"                                  # "NT" in SST means non-taxable
  Endif
Endif
#LTA 79065
If func SUBBIC.IS_DNO([M:BIC0]NUM)=1 : mkstat = 2 : Endif #issue X3-69271 - 2019-02-12 by MANOW
End
