#<AdxTL>@(#)2.0.0.0 $Revision$
#<AdxTL>@(#)11.0.0.0 $Revision$

#####################################################################################
# Fuente: YBISMAJ
#    ModificaciĂ³n de Vencimientos y DistribuciĂ³n AnalĂ­tica en Facturas Tercero Cliente
#-------------------------------------------------------------------------------------
# CodAct: YMRA01
#-------------------------------------------------------------------------------------
# Proyecto: SETRAM
#-------------------------------------------------------------------------------------
# Version: v9
#-------------------------------------------------------------------------------------
# Fecha: Abril 2021 - Adaptaciones para V12
# Fecha: 2017 - PU9
# Fecha: 2009/10/09
#-------------------------------------------------------------------------------------
# Desarrollador: Adaptación del YBICMAJ de Auren españa para facturas de proveedor
#-------------------------------------------------------------------------------------
# Notas: Lista de Notas
# WebServices -  Esta es una rutina que puede ser llamada desde WebServices
#-------------------------------------------------------------------------------------
# DescripciĂ³n:
#   La funciĂ³n YBISMAJ que permite Modificar los Vencimientos y Lineas de AnalĂ­tica para una Factura Tercero Proveedor
#   se adjunta justo aquĂ­ debajo un TEST a modo de ejemplo de utilizaciĂ³n de los parĂ¡metros
#   (mĂ¡s abajo en este fuente se declara la funciĂ³n y se describen sus parĂ¡metros)
#
#   Al procesar un valor de Linea AnalĂ­tica=0 no continĂºa recorriendo el array, es decir aunque declaremos un
#   array W2LINANA de 9999 elementos cuando encuentre un W2LINANA(K)=0 se considera el fin de las ordenes a procesar
######################################################################################

######################################################################################
# Procedimiento: YBISMAJ
Subprog YBISMAJ(W1NUM, WERR, WERRSTR, W2LINFAC, W2LINANA, W2EJEANA, W2CCEX, W2AMTX, W3DUEDAT, W3MNT, W3PAM, W3FLGPAZ)
#-------------------------------------------------------------------------------------
# Variables: Parametros
# W1NUM    - Val - Char         - NĂºmero de Asiento (Factura Tercero Cliente)
# W2LINFAC - Val - Integer      - Array de LĂ­neas de Factura a afectar
# W2LINANA - Val - Integer      - Array de LĂ­neas AnalĂ­ticas a afectar
# W2EJEANA - Val - Integer      - Array de Ejes AnalĂ­ticos a afectar
# W2CCEX   - Val - Char(15)     - Array de Secciones AnalĂ­ticas
# W2AMTX   - Val - Decimal      - Array de Importes
# W3DUEDAT - Val - Date         - Array de Fechas Vencimiento
# W3MNT    - Val - Decimal      - Array de Importes
# W3PAM    - Val - Char(3)      - Array de MĂ©todos de Pago
# W3FLGPAZ - Val - Integer      - Array de AutorizaciĂ³n Pago
# WERR     - Variable - Integer - CĂ³digo de Error
# WERRSTR  - Variable - Char()  - Mensage de Error
#-------------------------------------------------------------------------------------
# Notas: CĂ³digos de Error devueltos
# WERR=1 : No Utilizado
# WERR=2 : WERRSTR="La Factura"-W1NUM-"no existe!"
# WERR=3 : WERRSTR="Los importes de Vencimientos no cuadran!"
# WERR=4 : WERRSTR="No puedo bloquear el registro"-W1NUM-"para modificarlo"
# WERR=5 : WERRSTR="no se puede modificar vencimientos cobrados!"
# WERR=6 : WERRSTR="El mĂ©todo de pago"-[F:DUD]PAM-"no existe!"
# WERR=7 : WERRSTR="La Factura"-W1NUM-"no estĂ¡ Validada!"
# WERR=8 : WERRSTR="No se pueden modificar los desgloses analĂ­ticos de la Factura"-W1NUM-"!"
# WERR=9 : WERRSTR="La Factura no se puede modificar porque no se creĂ³ correctamente"
# WERR=10 :WERRSTR="La SecciĂ³n AnalĂ­tica no existe!"
# WERR=11 :WERRSTR="Los importes de Detalles Analiticos no cuadran!"
# WERR=98 :WERRSTR="Parametros W2* deben tener mismo nĂºmero de elementos!"
# WERR=99 :WERRSTR="Parametros W3* deben tener mismo nĂºmero de elementos!"
#####################################################################################
Value Char       W1NUM
Variable Integer WERR
Variable Char    WERRSTR
Value Integer    W2LINFAC    ()
Value Integer    W2LINANA    ()
Value Integer    W2EJEANA    ()
Value Char       W2CCEX    ()()
Value Decimal    W2AMTX      ()
Value Date       W3DUEDAT    ()
Value Decimal    W3MNT       ()
Value Char       W3PAM     ()()
Value Integer    W3FLGPAZ    ()

Local Integer WDIMVEN, WDIMANA

Local Integer TYPTIERS
TYPTIERS = 2


    Raz WERR, WERRSTR :    WERR=0

    WDIMANA=dim(W2LINFAC)
    If WDIMANA<>dim(W2LINANA) or WDIMANA<>dim(W2EJEANA) or WDIMANA<>dim(W2CCEX) or WDIMANA<>dim(W2AMTX)
        WERR=98 : If WERR : Goto NOEJECUTES : Endif
    Endif

    WDIMVEN=dim(W3MNT)
    If WDIMVEN<>dim(W3PAM) or WDIMVEN<>dim(W3FLGPAZ)
        WERR=99 : If WERR : Goto NOEJECUTES : Endif
    Endif


    Gosub DEFINE
    Gosub PRECHECK : If WERR : Goto NOEJECUTES : Endif
    Gosub VERROU   : If WERR : Goto NOEJECUTES : Endif

    Gosub AFFDUD                                       # Cargar Vencimientos
    Gosub SAIDUD  :  If WERR : Goto ABORTA     : Endif # Modificar Vencimientos en la Mascara DUD1
    Gosub SAVALL  :  If WERR : Goto ABORTA     : Endif # Guardar Vencimientos de Mascara DUD1 a Tabla y Actualizar Analitica

$ABORTA
    Gosub DEVERROU
$NOEJECUTES

#lpardo 060515
Gosub REPLICA From SPEBIS
#lpardo 060515

    If WERR=0 : WERRSTR-="OK" : Endif
End

######################################################################################
$DEFINE

#lpardo
If TYPTIERS = 1
    If clalev([F:SIH])=0 : Local File SINVOICE    [SIH] : Endif :#SIH0=NUM, YSH1=ACCNUM
    If clalev([F:SID])=0 : Local File SINVOICED   [SID] : Endif :#SID0=NUM;SIDLIN
    If clalev([F:SIL])=0 : Local File BPCINVLIG   [SIL] : Endif :#SIL0=NUM;LIG
    If clalev([F:SIA])=0 : Local File BPCINVLIGA  [SIA] : Endif :#SIL0=NUM;LIG;ANALIG
Else
    If clalev([F:PIH])=0 : Local File PINVOICE    [PIH] : Endif :#SIH0=NUM, YSH1=ACCNUM
    If clalev([F:PID])=0 : Local File PINVOICED   [PID] : Endif :#SID0=NUM;SIDLIN
    If clalev([F:PIL])=0 : Local File BPSINVLIG   [PIL] : Endif :#SIL0=NUM;LIG
    If clalev([F:PIA])=0 : Local File BPSINVLIGA  [PIA] : Endif :#SIL0=NUM;LIG;ANALIG
Endif
    If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif :#DUD0=TYP+NUM+LIG+DUDLIG
                                                                 #TYP: tipo asiento
                                                                 #NUM: Numero asiento
                                                                 #LIG: Linea asiento
                                                                 #DUDLIG: numero vencimiento
    Local Integer SAVCONS
    Local Char    SYMBHAE(35)
    Local Integer I
    Local Integer LCK
    Local Char    WFCY
Return

######################################################################################
$PRECHECK
If TYPTIERS = 1
    Read [F:SIH]SIH0=W1NUM
    If fstat
        WERR=2 : WERRSTR-="La Factura"-W1NUM-"no existe!" : Return
    Endif
    WFCY=[F:SIH]FCY
Else
    Read [F:PIH]PIH0=W1NUM
    If fstat
        WERR=2 : WERRSTR-="La Factura"-W1NUM-"no existe!" : Return
    Endif
    WFCY=[F:PIH]FCY
Endif

    SAVCONS=GCONSULT

If TYPTIERS = 1
    If [F:SIH]STA=3
        WERR=7 : WERRSTR-="La Factura"-W1NUM-"estĂ¡ Validada!"
        Return
    Endif
Else
    If [F:PIH]STA=3
        WERR=7 : WERRSTR-="La Factura"-W1NUM-"estĂ¡ Validada!"
        Return
    Endif
Endif
Return

######################################################################################
# Seccion: GestiĂ³n Bloqueos
######################################################################################

######################################################################################
$VERROU
If TYPTIERS = 1
  [L]SYMBHAE = "HAE"+[F:SIH]NUM+"\"+[F:SIH]GTE
  Lock =SYMBHAE With lockwait=0
Else
  [L]SYMBHAE = "HAE"+[F:PIH]NUM+"\"+[F:PIH]GTE
  Lock =SYMBHAE With lockwait=0
Endif

If fstat
 WERR=4 : WERRSTR-="No puedo bloquear el registro"-W1NUM-"para modificarlo" : Return
Endif
Return

######################################################################################
$DEVERROU
Unlock =SYMBHAE
Return
######################################################################################

######################################################################################
# Seccion: Transaccionalidad
######################################################################################

######################################################################################
$TR
GOK = 1
If TYPTIERS = 1 Then
  Trbegin [HAE],[DUD], [SIL], [SIA]
Else
  Trbegin [HAE],[DUD], [PIL], [PIA]
Endif

 Gosub VALECH
 If   GOK<0 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif
 Gosub MODECR
 If   GOK<0 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif
 Gosub MAJANA
 If   GOK<0 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

######################################################################################
$AB_TR
Rollback
Return

######################################################################################
$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR : Endif

######################################################################################
# Seccion: Tratamiento de ActualizaciĂ³n Vencimientos
######################################################################################

######################################################################################
$AFFDUD
#Rellenamos la mascara DUD1 con los vencimientos actuales
    LCK=1
    Gosub OUVR_ECH
    Gosub CHARGECH
Return

######################################################################################
$SAIDUD
    If clalev([F:TAM])=0 : Local File TABPAM    [TAM] : Endif
    Default Mask [DUD1]

#Cualquier informaciĂ³n que hubiese anteriormente para esta factura referente a vencimientos
#y desgloses debe ser descartada.
    mkstat=0
    If [M]NBECH<>0

        For I=0 To [M]NBECH-1
            status  =65
            nolign=I+1
            Call C_NBECH From SUBBIH
            If mkstat=2 : WERR=5 : WERRSTR-=GMESSAGE : Return : Endif
            Dela 0,1     [M]NBECH
        Next
        Raz [M]NBECH
    Endif

    For I=0 To WDIMVEN-1
        If W3MNT(I)=0 : Break : Endif

        nolign = [M]NBECH
        Insa nolign,1,[M]NBECH [M]NBECH
        [M]NBECH += 1
        nolign = [M]NBECH
        NOL = nolign-1
        status = 0

        Raz [F:DUD]

        #AUREN - REVISIÓN V12
        Local Integer ACTIV_XX5A
        [L]ACTIV_XX5A = func AFNC.ACTIV("XX5A")
        #AUREN - REVISIÓN V12

        Gosub INIECH From SUBBIH

        [F:DUD]SOI=1
        [F:DUD]FLGFUP = 1
        [F:DUD]FLGPAZ = W3FLGPAZ(I)

        [M]=[F:DUD]

        #AS_PAM, AS_SOI, AS_FLGUP, AS_LEVFUP from SUBBIH
            If ([M]AMTCUR(NOL)<>0 & abs([M]AMTCUR(NOL))<=abs([M]PAYCUR(NOL)+[M]TMPCUR(NOL))) or [M]SOINUM(NOL)<>""
            WERR=9 : WERRSTR-="La Factura no se puede modificar porque no se creĂ³ correctamente" : Break
            Endif

        [M]DUDLIG(NOL)=0
        [M]DUDDAT(NOL)=W3DUEDAT(I)
        [M]AMTCUR(NOL)=W3MNT(I)
        [M]AMTLOC(NOL)=W3MNT(I)

        If W3PAM(I)=""
            If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
            If TYPTIERS=1 : Read [GTE]GTE0 = [F:SIH]GTE
            Else          : Read [GTE]GTE0 = [F:PIH]GTE
            Endif
            If !fstat & [F:GTE]PAM<>""
                [F:DUD]PAM = [F:GTE]PAM
            Else
                Filter [TAM] Where LEG = GCURLEG
                Read [TAM]TAM0 First
                Filter [TAM]
                [F:DUD]PAM  = [F:TAM]PAM
            Endif
        Else
            [F:DUD]PAM=W3PAM(I)
        Endif

        [M]PAM(NOL)= [F:DUD]PAM

        #C_PAM([M]PAM(NOL))
        Filter [TAM] Where LEG = GCURLEG and PAM = [F:DUD]PAM
				Read [TAM]TAM0 First
				If fstat
					WERR=6 : WERRSTR-="El mĂ©todo de pago"-[F:DUD]PAM-"no existe!": Break
				Endif
				Filter [TAM]
    Next
    If WERR>0 : Return : Endif
Return

######################################################################################
$SAVALL

If sum([M]AMTCUR(0..[M]NBECH-1))<>[M]AMTTOT
 WERR=3 : WERRSTR-=mess(24,119,1) : # Total des Ă©chĂ©ances incorrect
 Return
Else
    Call DEBTRANS From GLOCK
    Gosub TR
    If GOK<1
        If WERR=0
            WERR=4 : WERRSTR-="No puedo bloquear el registro"-W1NUM-"para modificarlo"
        Endif
        Return
    Else : Unlock =SYMBOLE
    Endif
Endif
Return

######################################################################################
$MODECR
# Mise Ă  jour de la date d'Ă©chĂ©ance de la piĂ¨ce (16095)
If TYPTIERS=1
 If dim([M:BIC0]GTE)>0    : # Factures tiers clients
  TYPPCE = [M:BIC0]GTE
 Elsif dim([M:SIH0]GTE)>0 : # Factures ventes
  TYPPCE = [M:SIH0]GTE
 Endif
Elsif TYPTIERS=2
 If dim([M:BIS0]GTE)>0    : # Factures tiers fournisseurs
  TYPPCE = [M:BIS0]GTE
 Elsif dim([M:PIH0]GTE)>0 : # Factures d'achat
  TYPPCE = [M:PIH0]GTE
 Endif
Endif
If TYPPCE="" : Return : Endif
Readlock [HAE]HAE0=TYPPCE;NUMERO
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRY"-TYPPCE-NUMERO
 Return
Elsif !fstat
 [F:HAE]DUDDAT = max([M:DUD1]DUDDAT(0..[M:DUD1]NBECH-1))
 Rewrite [HAE]
 If fstat
  GOK = 0 : Call FSTA("HAE") From GLOCK
 Endif
Endif
Return

######################################################################################
$VALECH
Local Decimal  AROLED
Local Integer  IDEV
# Effacement des Ă©chĂ©ances qui ne sont plus dans le tableau
# ou qui ont un montant = 0
For [DUD]DUD1 Where ACCNUM=NUMECH
 LIGECH = find([F:DUD]DUDLIG,[M:DUD1]DUDLIG(0..[M:DUD1]NBECH-1))
 If !LIGECH | [M:DUD1]AMTCUR(LIGECH-1)=0
  Call HISTOECH("DUD",2,[L]DATEVT) From MODECHE
  Delete [DUD]
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMECH) : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif

Call LECTURE("TCU",DEVLED,"") From CONTOBJ
AROLOC = [F:TCU]CURRND
Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
ARORPT = [F:TCU]CURRND

# Recalcul des montants société et reporting
If [M]NBECH>0
 Gosub SETCOUR
 Call CONVERT_DEV(DEVORG,DEVDES,DEVLED
&  ,NBECH,[M:DUD1]AMTCUR(0..[M]NBECH-1),[M:DUD1]AMTLOC,COURS,TYPCOURS,DATCPT
&  ,AROLED) From CPTSUB
Endif

# Mise Ă  jour des Ă©chĂ©ances modifiĂ©es
LIGECH = 0
For nolign=1 To [M:DUD1]NBECH
 If [M:DUD1]DUDLIG(nolign-1)<>0 & [M:DUD1]AMTCUR(nolign-1)<>0
  Readlock [DUD]DUD1 = NUMECH;[M:DUD1]DUDLIG(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$(NUMECH) : Break
  Elsif fstat
   GOK=0 : Call RSTA("DUD",num$(NUMECH)) From GLOCK : Break
  Endif
  If MODIF
   Gosub INIECH
  Endif
  [F:DUD] = [M:DUD1]
  [F:DUD]LIG = LIGPCE
  Call SLDECH("DUD")From MODECHE
  Local Integer EXERCICE, PERIODE, ASTATUS
  [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX,[F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE,GMESSAGE)
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
  LIGECH = max(LIGECH,[F:DUD]DUDLIG)
 Endif
Next nolign
If GOK<1 : Return : Endif

# CrĂ©ation des nouvelles Ă©chĂ©ances
For nolign=1 To [M:DUD1]NBECH
 If [M:DUD1]DUDLIG(nolign-1)=0 & [M:DUD1]AMTCUR(nolign-1)<>0
  Raz [F:DUD]
  Gosub INIECH
  [F:DUD] = [M:DUD1]
  [F:DUD]LIG = LIGPCE
  [F:DUD]PAMTYP = 1            : # Type Ă©chĂ©ance

# AUREN BUG Ass 2173338
  #[F:DUD]DUDSTA = 1 + (ETAT>2) : # 1=non validée, 2=validée
  [F:DUD]DUDSTA = 1 + (ETAT=2)
# FI AUREN BUG Ass 2173338

  [F:DUD]DUDLIG = LIGECH+1
  [F:DUD]TYPDUD = 2  : #Facture
  LIGECH += 1
  Call KEYDUD("DUD") From MODECHE
  Call SLDECH("DUD")From MODECHE
  Local Integer EXERCICE, PERIODE, ASTATUS
  [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX,[F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE,GMESSAGE)
  [F:DUD]FIY = EXERCICE
  [F:DUD]PER = PERIODE
  If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
  If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
  Write [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[L]DATEVT)From MODECHE
 Endif
Next nolign

If dim([M:BIS3]NBLIG)>0 & func AFNC.PARAM("ARGRTZ",[M:BIS0]CPY)="2" : # Gestion retenues Argentines
 Call CALRTZ(1,[M:BIS0]BPR,GPLAN(1),[M:BIS3]ACC1,[M:BIS3]FCYLIN,[M:BIS1]CUR,[M:BIS0]ACCDAT,[M:BIS3]AMTNOTLIN,[M:BIS3]AMTVAT,[M:BIS3]NBLIG,0) From CALRTZARG
Endif
Return

######################################################################################
$SETCOUR
Local Decimal COURS
Local Char    DEVORG(GLONCUR), DEVDES(GLONCUR)
#--- Position des 3 devises par rapport à l'Euro
DEVORG = [L]DEVISE
DEVDES = [L]DEVLED
Call SETFLGDEV([L]DEVISE,[F:CPY]CPY,DATCPT) From CPTDIV
If [L]RATDIV=0 Then [L]RATDIV=1 Endif
COURS  = [L]RATMLT/[L]RATDIV
Return

######################################################################################
$INIECH
[F:DUD]BPRTYP = TYPTIERS
Case TYPTIERS
 When 1
  [F:DUD] = [F:SIH]
  Call LECTURE("FCY",[F:SIH]FCY,"") From CONTOBJ
  [F:DUD]FCY = [F:FCY]FINRSPFCY
  [F:DUD]SAC = [F:SIH]BPRSAC
  Case [F:SIH]INVTYP
   When 1,3
    [F:DUD]SNS = +1
   When 2,4
    [F:DUD]SNS = -1
  Endcase
  [F:DUD]TYP = [F:SIH]GTE
  [F:DUD]BPRFCT = [F:SIH]BPRFCT
 When 2
  [F:DUD] = [F:PIH]
  [F:DUD]SAC = [F:PIH]BPRSAC
  Case [F:PIH]INVTYP
   When 1,4
    [F:DUD]SNS = -1
   When 2,3
    [F:DUD]SNS = +1
  Endcase
  [F:DUD]TYP = [F:PIH]GTE
Endcase
Return

######################################################################################
$OUVR_ECH
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Local Char    NUMERO(GLONVCR), TYPPCE(GLONGTE)
NUMERO = W1NUM
Return

######################################################################################
$CHARGECH
Local Char    DEVLED(GLONCUR)
Local Char    CODLED(GLONLED)
Local Decimal TOTAL, COURS
Local Decimal RATDIV, RATMLT
Local Date    DATCPT, DATEVT
Local Integer TYPCOURS, STAT, LIGECH, NUMECH, ETAT, LIGPCE, NOL, MODIF
Local Char    DEVISE(GLONCUR), SITE(GLONFCY), SYMBOLE(30)
OK = 1
MODIF = 0
If TYPTIERS=1
 Local Mask BPCDUD [DUD1]
 If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
 Read [SIH]SIH0 = NUMERO
 If fstat : OK = 0 : Return : Endif
 TOTAL    = [F:SIH]AMTATI
 DEVISE   = [F:SIH]CUR
 Call GETSOC([F:SIH]FCY) From DEVSUB
 If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:SIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
  OK = 0 : Return
 Endif
 TYPCOURS = [F:SIH]CURTYP
 RATDIV   = [F:SIH]RATDIV(GTYPGEN-1)
 RATMLT   = [F:SIH]RATMLT(GTYPGEN-1)
 DATCPT   = [F:SIH]RATDAT
 If DATCPT=[0/0/0]
  DATCPT   = [F:SIH]ACCDAT
 Endif
 DATEVT   = [F:SIH]ACCDAT
 SITE     = [F:SIH]FCY
 NUMECH   = [F:SIH]ACCNUM
 ETAT     = [F:SIH]STA
 SYMBOLE = "HAE"+[F:SIH]NUM+"\"+[F:SIH]GTE
Else
 Local Mask BPSDUD [DUD1]
 If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
 Read [PIH]PIH0 = NUMERO
 If fstat : OK = 0 : Return : Endif
 TOTAL    = [F:PIH]AMTATI
 DEVISE   = [F:PIH]CUR
 Call GETSOC([F:PIH]FCY) From DEVSUB
 If func FINACM_SYRA.GET_LEDCUR(GACTX, [F:PIH]CPY, GTYPGEN, CODLED, DEVLED, GMESSAGE)<>[V]CST_AOK
  OK = 0 : Return
 Endif
 TYPCOURS = [F:PIH]CURTYP
 RATDIV   = [F:PIH]RATDIV(GTYPGEN-1)
 RATMLT   = [F:PIH]RATMLT(GTYPGEN-1)
 DATCPT   = [F:PIH]RATDAT
 If DATCPT=[0/0/0]
  DATCPT   = [F:PIH]ACCDAT
 Endif
 DATEVT   = [F:PIH]ACCDAT
 SITE     = [F:PIH]FCY
 NUMECH   = [F:PIH]ACCNUM
 ETAT     = [F:PIH]STA
 SYMBOLE  = "HAE"+[F:PIH]NUM+"\"+[F:PIH]GTE
Endif
If LCK
 Lock =SYMBOLE
 If fstat : OK=-1 : Return : Endif
Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Raz [M:DUD1]
nolign = 0
For [DUD]DUD1 Where ACCNUM=NUMECH
 nolign += 1
 [M:DUD1] = [F:DUD]
 If nolign=1
  [M:DUD1]DUDCUR = [F:DUD]CUR
  LIGPCE = [F:DUD]LIG
 Endif
 # Griser le code adr payeur si le tiers est de type divers. Si le tiers est de type normal, le code adresse est grisé
 # si échéance dans le circuit de paiement
 If clalev([M:BIC1])>0
  Call LEC_BPC([M:BIC1]BPRPAY) From CPTLEC
  If [F:BPC]BPCTYP = 2
   Grizo [M:DUD1]BPAPAY(nolign-1)
  Else
   If [F:DUD]FLGCLE=2 | [F:DUD]FLGCLE=4
    Grizo [M:DUD1]BPAPAY(nolign-1)
   Else
    Actzo [M:DUD1]BPAPAY(nolign-1)
   Endif
  Endif
 Elsif clalev([M:BIS1])>0
  Call LEC_BPS([M:BIS1]BPRPAY) From CPTLEC
  If [F:BPS]BPSTYP = 3
   Grizo [M:DUD1]BPAPAY(nolign-1)
  Else
   If [F:DUD]FLGCLE=2 | [F:DUD]FLGCLE=4
    Grizo [M:DUD1]BPAPAY(nolign-1)
   Else
    Actzo [M:DUD1]BPAPAY(nolign-1)
   Endif
  Endif
 Endif
Next
[M:DUD1]PAYTOT = sum([M:DUD1]PAYCUR(0..nolign-1))+sum([M:DUD1]TMPCUR(0..nolign-1))
If TOTAL<0 & [M:DUD1]AMTCUR(0)>0 : TOTAL=abs(TOTAL) : Endif
[M:DUD1]AMTTOT = TOTAL
[M:DUD1]NBECH = nolign
Sorta [M:DUD1]NBECH [M:DUD1]NBECH Order By [M:DUD1]DUDDAT(indice),[M:DUD1]DUDLIG(indice)
Return

######################################################################################
# Seccion: Tratamiento de ActualizaciĂ³n AnalĂ­ticas
######################################################################################

######################################################################################
$MAJANA

Local Integer K, WLF
If clalev([F:SIA])=0 : Local File BPCINVLIGA  [SIA] : Endif :#SIL0=NUM;LIG;ANALIG
Local Mask VENTILE2 [VT2]
Local Integer W2LINANA_Z : Raz W2LINANA_Z
Raz [M:VT2]

# Aqui empieza un if para tratar por separado cliente/proveedor-
If TYPTIERS = 1
  For WLF=0 To WDIMANA-1  :#Lineas Factura
    #Al procesar la primera línea analítica borro las que hubiera antes para esa línea de factura
         Break(W2LINANA(WLF)=0 or W2LINFAC(WLF)=0)
         Delete [F:SIA] Where NUM=W1NUM and LIG=W2LINFAC(WLF)
          If fstat=1
           GOK=-1 : GLOCK="$BPCINVLIGA"-W1NUM-num$(W2LINFAC(WLF)) : Break
          Endif
  Next
  If GOK<0 : Return : Endif

  For WLF=0 To WDIMANA-1  :#Lineas Factura
     Break(W2LINANA(WLF)=0 or W2LINFAC=0)

     Readlock [F:SIL]SIL0=W1NUM;W2LINFAC(WLF)
      If fstat=1
       GOK=-1 : GLOCK="$BPCINVLIG"-W1NUM-num$(W2LINFAC(WLF)) : Break
      Elsif fstat
       GOK=0 : Call RSTA("SIL",W1NUM-num$(W2LINFAC(WLF))) From GLOCK : Break
      Endif

     #Campo Distribución Analítica
     If ([F:SIL]DSP<>"")
         [F:SIL]DSP=""
         Rewrite [SIL]
          If fstat
           GOK=0 : Call FSTA("SIL") From GLOCK : Break
          Endif
     Endif

  #Lineas analitica
   Local Integer LFSTAT
   Raz [F:SIA]
   Readlock [F:SIA]SIA0=W1NUM;W2LINFAC(WLF);W2LINANA(WLF)
    LFSTAT=fstat
	[F:SIA] = [F:SIH]
	[F:SIA] = [F:SIL]

  #AUREN - REVISIÓN V12  (GAXE no siempre con valor)
  #For AXE=1 To 10
  # If GAXE(AXE)<>""
  #  [F:SIA]DIE(AXE-1) = GAXE(AXE)
  # Endif
  #Next AXE
  [F:SIA]DIE(0) = "AX1"
  [F:SIA]DIE(1) = "AX2"
  [F:SIA]DIE(2) = "AX3"
  [F:SIA]DIE(3) = "AX4"
  [F:SIA]DIE(4) = "AX5"
  [F:SIA]DIE(5) = "AX6"
  [F:SIA]DIE(6) = "AX7"
  [F:SIA]DIE(7) = "AX8"
  [F:SIA]DIE(8) = "AX9"
  #AUREN - REVISIÓN V12  (GAXE no siempre con valor)

   Gosub SAIVT2 : If WERR>0 : Break : Endif
   [F:SIA]LIG    = W2LINFAC(WLF)
   [F:SIA]ANALIG = W2LINANA(WLF)
   [F:SIA]AMT    = [M:VT2]TBAMT([M:VT2]PTVENT-1)
   [F:SIA]QTY    = [M:VT2]TBQTY([M:VT2]PTVENT-1)

  #Eje Analítico
   [F:SIA]CCE(W2EJEANA(WLF)-1) = evalue("[M:VT2]TBCCE"+num$(W2EJEANA(WLF))+"([M:VT2]PTVENT-1)")

     If LFSTAT
         Write [SIA]
     Else
         Rewrite [SIA]
     Endif
     If fstat
      GOK = 0 : Call FSTA("SIA") From GLOCK : Break
     Endif
  Next WLF
Else
  For WLF=0 To WDIMANA-1  :#Lineas Factura
    #Al procesar la primera línea analítica borro las que hubiera antes para esa línea de factura
         Break(W2LINANA(WLF)=0 or W2LINFAC(WLF)=0)
         Delete [F:PIA] Where NUM=W1NUM and LIG=W2LINFAC(WLF)
          If fstat=1
           GOK=-1 : GLOCK="$BPSINVLIGA"-W1NUM-num$(W2LINFAC(WLF)) : Break
          Endif
  Next
  If GOK<0 : Return : Endif

  For WLF=0 To WDIMANA-1  :#Lineas Factura
     Break(W2LINANA(WLF)=0 or W2LINFAC=0)

     Readlock [F:PIL]PIL0=W1NUM;W2LINFAC(WLF)
      If fstat=1
       GOK=-1 : GLOCK="$BPSINVLIG"-W1NUM-num$(W2LINFAC(WLF)) : Break
      Elsif fstat
       GOK=0 : Call RSTA("PIL",W1NUM-num$(W2LINFAC(WLF))) From GLOCK : Break
      Endif

    #Campo Distribución Analítica
     If ([F:PIL]DSP<>"")
         [F:PIL]DSP=""
         Rewrite [PIL]
          If fstat
           GOK=0 : Call FSTA("PIL") From GLOCK : Break
          Endif
     Endif

    #Lineas analitica
     Local Integer LFSTAT
     Raz [F:PIA]
     Readlock [F:PIA]PIA0=W1NUM;W2LINFAC(WLF);W2LINANA(WLF)
      LFSTAT=fstat
      If LFSTAT
	     [F:PIA] = [F:PIH]
	    Endif
	 [F:PIA] = [F:PIL]
    [F:PIA]DIE(0) = "AX1"
    [F:PIA]DIE(1) = "AX2"
    [F:PIA]DIE(2) = "AX3"
    [F:PIA]DIE(3) = "AX4"
    [F:PIA]DIE(4) = "AX5"
    [F:PIA]DIE(5) = "AX6"
    [F:PIA]DIE(6) = "AX7"
    [F:PIA]DIE(7) = "AX8"
    [F:PIA]DIE(8) = "AX9"

     Gosub SAIVT2 : If WERR>0 : Break : Endif
     [F:PIA]LIG    = W2LINFAC(WLF)
     [F:PIA]ANALIG = W2LINANA(WLF)
     [F:PIA]AMT    = [M:VT2]TBAMT([M:VT2]PTVENT-1)
     [F:PIA]QTY    = [M:VT2]TBQTY([M:VT2]PTVENT-1)

    #Eje Analítico
     [F:PIA]CCE(W2EJEANA(WLF)-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"([M:VT2]PTVENT-1)")

     If LFSTAT
         Write [PIA]
     Else
         Rewrite [PIA]
     Endif
     If fstat
      GOK = 0 : Call FSTA("PIA") From GLOCK : Break
     Endif
  Next WLF
Endif

If WERR>0 : GOK=0 : Return : Endif
If GOK<1 : WERR=8 : WERRSTR-="No se pueden modificar los desgloses analíticos de la Factura"-W1NUM-"!" : Return : Endif

Local Decimal WAMTCHK : WAMTCHK=0
If TYPTIERS = 1
  For [F:SIA]SIA0(2) Where NUM=W1NUM
      WAMTCHK=0
      For [F:SIA]SIA0(3)
          WAMTCHK+=[F:SIA]AMT
      Next
      Read [F:SIL]SIL0=[F:SIA]NUM;[F:SIA]LIG
      If [F:SIL]AMTNOTLIN<>WAMTCHK and WAMTCHK<>0
          WERR=11 :WERRSTR-="Los importes de Detalles Analiticos no cuadran!"
          Break
      Endif
  Next
Else
  For [F:PIA]PIA0(2) Where NUM=W1NUM
      WAMTCHK=0
      For [F:PIA]PIA0(3)
          WAMTCHK+=[F:PIA]AMT
      Next
      Read [F:PIL]PIL0=[F:PIA]NUM;[F:PIA]LIG
      If [F:PIL]AMTNOTLIN<>WAMTCHK and WAMTCHK<>0
          WERR=11 :WERRSTR-="Los importes de Detalles Analiticos no cuadran!"
          Break
      Endif
  Next
Endif
If WERR>0 : GOK=0 : Return : Endif

Return

$SAIVT2
    Local Char VALOR(30)
    Default Mask [DUD1]
    Local Integer AXE

    Local Char CCE

    If W2CCEX(WLF)<>""

        If W2LINANA_Z = 0
            #inicializo detalles analíticos
            Raz [M:VT2]
            [M:VT2]PTVENT +=1
        Elsif (W2LINANA(WLF)<W2LINANA_Z)
            #inicializo detalles analalíticos
            Raz [M:VT2]
            [M:VT2]PTVENT +=1
        Elsif (W2LINANA(WLF)=W2LINANA_Z)
            #como es la misma linea analítica no añado lineas a VT2
        Else
            #como es una linea analitica mayor debo incrementar linea en VT2
            [M:VT2]PTVENT +=1
        Endif
        W2LINANA_Z     = W2LINANA(WLF)

        [M:VT2]TBAMT([M:VT2]PTVENT-1)=W2AMTX(WLF)
        [M:VT2]TBQTY([M:VT2]PTVENT-1)=0

        AXE    = W2EJEANA(WLF)
        VALOR  = W2CCEX(WLF)
        Assign ("[M:VT2]TBCCE"+num$(AXE)+"([M:VT2]PTVENT-1)") With VALOR
        If mkstat=2 : WERR=10 :WERRSTR-="La Sección Analítica"-VALOR-"no existe para el eje"-num$(AXE) : Return : Endif
    Endif

Return
