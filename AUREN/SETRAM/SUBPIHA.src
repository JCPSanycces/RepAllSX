#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion contr¶le factures
#########################################################################
# SUBPIHA : Gestion des factures d'achat                   MBT 15/09/98 #
# --------------------------------------------------------------------- #
# Traitement des actions "Gosub" de l'objet "PIH"                       #
# Les traitements sur champ "Call" se trouvent dans le SUBPIH           #
#########################################################################

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE
# X3-90012 2019-04-23 Bader : VERIF: check OK after call of VERIF_PIH From SWIQRCLIB2
# Issue X3-197349 - 2020-05-20 Bader: SETBOUT: disable "Open items" if coming from MODECHE

$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseignķ la transaction est dķja choisie #
# par le menu. Vķrifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=8;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# AprĶs lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK Ó zķro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=8;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# AprĶs sķlection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=8;GFLAG : If fstat Raz [F:PTR] : Endif

#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return

$FILTRE
#---------------------------------------------------#
# Ne traiter que les factures crķķes par les achats #
#---------------------------------------------------#
Default File [PIH]
FILTSUP="ORIMOD=6"
Return

$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nķcessaire
   Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseignķ dans la transaction, prendre celui-la -----#
If [F:PTR]DOCNAM<>"" [L]REPORT1=[F:PTR]DOCNAM : Endif
Return

$OUVRE
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par dķfaut pour le module concernķ       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par dķfaut du module #
# mĻme si ce site par dķfaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
#----- Si on revient une deuxiĶme fois par tunnel alors message et retour -----#
If GTUNCPT(10)=1 GMESSAGE=mess(247,199,1) : OK=0 : Return Else GTUNCPT(10)=1 : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les ķcrans avec abrķviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
#-----------------------------------------------------#
# Contr¶le existence de la structure tarif par dķfaut #
# et chargement des libellķs colonnes par dķfaut      #
#-----------------------------------------------------#
Raz GPLISTC, GCOEUOM
Local  Decimal  MONTMIN, MONTPRO : # Informations ķchķances (Call INFOECHE)
Local  Char     CODE(3), VALC1(3), VALC2(20), VALC3(20), NUMERO(GLONVCR), SECTION(GLONCCE)
Local  Char     WMSG(120)
Local  Shortint OUVFICFLG
Local  Integer  WRET,  MAJFAC,  WNBRCP,  MODDAT, WLIGNE
Local  Integer  OKIMMO, NOLI
Local  Decimal  EXE, WCOURS
Local Integer   RET
#MAE, bg 77405
Local Char      SYMBHAE(35)
#-----
Global Char     GPIH_SYMBOL2(30), GPIH_CPYCRY(GLONCPY)
Global Libelle  GPIH_FLGPAZ, GPIH_EECFLG, GPIH_INDTAX, GPIH_PICK
Global Libelle  GPIH_INDBASTAX(max(func AFNC.ACTIV("PVA"),20))
Global Decimal  GPIH_QTEMAX, GPIH_QTE
Global Integer  GPIH_VERROU
Global Char     GPIH_FMTPER(20)(6)
# Issue 71253 - 2012-05-10 by SR : Localisation espagnole et portugaise
Global Char     GPIH_FMTKSP(20)(4)
Global Char     GPIH_FMTKPO(20)
#--- Issue 107856
Global Decimal WQTE_NONFAC

# Issue 71069 - 2016-06-20 by MUARN : simuler multi-affaire
Global Integer GUPDPJTSNGDOC
GUPDPJTSNGDOC = 6

# Issue X3-70158 - 2018-01-09 by MUARN : TRTLIG Ó la place de GREP
Global Char GPIH_TRTLIG

# Issue 84130 - 2013-03-26 by SR
Local  Integer  WCREOUVSTC : WCREOUVSTC = 0
If dim(GOUVSTC)<1 : Global Integer  GOUVSTC :WCREOUVSTC = 1 : Endif# Issue 84130 - 2013-03-22 by SR :Landed cost

#----- Dķfini dans le WWAGLOBTC -----#
#Global Libelle  GLOCARGNUM        : # Indicateur Numķrotation Argentine
#Global Libelle  GLOCITAPRE        : # Indicateur Etalement des prestations
#Global Libelle  GLOCBRIDSC        : # Indicateur Settlement discount
#----- Variables locales pour gestion picking liste de gauche -----#
Local  Char     WNUM(GLONVCR), WVCRNUMORI(GLONVCR), WPOQLNK(16), SYMBOL2(30)
Local  Integer  WLIN, I, J, K, WVCRTYPORI
Local  Shortint NOL, WPICK, SAVNBLIG, SAVGCONSULT
# Issue 87705 - 2013-02-15 by SR
# Issue 88312 - 2013-02-28 by SR
Local Integer   WMODADR1,SAVNOLIGN
Local Char ANMCOMP(5) #85785
# Issue X3-69477 - 2017-12-28 by SR :
Local Char WCRITERE(240)
# Issue X3-195220 - 2020-08-13 by SR : To be able to load FIY and PER fields in PINVOICE
Local Integer EXERCICE, PERIODE, WSTATUS
#-----
Call CTLSTRUCT (2,WRET) From TRTPRICE
If WRET<>0 OK=0 : Return : Endif
Call COLREM("C",2,"") From TRTPRICE : GPLISTC=""
Call TARIFCHGT(6)     From TRTPRICE
#--------------------------------------------------------------------------------#
# Ouverture masque des critĶres de sķlection du prķchargement des lignes facture #
#           masque des informations douaniĶres                                   #
#--------------------------------------------------------------------------------#
If !clalev ([M:SCL])    Local Mask SAICURLED [SCL]  : Endif
If !clalev ([M:PCIW])   Local Mask PCRITINV  [PCIW] : Endif
If !clalev ([M:AD66])   Local Mask ADRBPR    [AD66] : Endif
If !clalev ([M:AD67])   Local Mask ADRBPR    [AD67] : Endif
If !clalev ([M:PCEZ])   Local Mask PCEE      [PCEZ] : Endif
If !clalev ([F:TRA])    Local File TABRATVAT  [TRA] : Endif
If !clalev ([F:PTD1])   Local File PRECEIPTD [PTD1] : Endif : #VPO 20/01/11 70923
If !clalev ([F:PTDB])   Local File PRECEIPTD [PTDB] : Endif
If !clalev ([F:PIHB])   Local File PINVOICE  [PIHB] : Endif
If !clalev ([F:PIDB])   Local File PINVOICED [PIDB] : Endif
If !clalev ([F:TCA])    Local File TABCOUAFF  [TCA] : Endif
If !clalev ([F:TCY])    Local File TABCOUNTRY [TCY] : Endif
If !clalev ([F:POS])    Local File POSCOD     [POS] : Endif
If !clalev ([F:STJ])    Local File STOJOU     [STJ] : Endif
If !clalev ([F:STO])    Local File STOCK      [STO] : Endif
If !clalev ([F:GCM])    Local File GACM       [GCM] : Endif
If !clalev ([F:MAT])    Local File MATCHTOL   [MAT] : Endif   # Three way matching GRNA

# Issue 84130 - 2013-02-14 by MUARN : landed cosr
If !clalev([F:STCH])   Local File COSTSTCH   [STCH] : Endif
If !clalev([F:STCD])   Local File COSTSTCD   [STCD] : Endif
If !clalev([F:STCL])   Local File COSTSTCL   [STCL] : Endif
If !clalev([F:FCS])    Local File FRECST     [FCS]  : Endif
If !clalev([F:ICTD])   Local File INCOTERMD  [ICTD] : Endif
If !clalev([F:PID])    Local File PINVOICED  [PID]  : Endif
# Issue 89349 - 2013-10-29 by SR : Rapprochement
If !clalev([F:STCR])   Local File COSTSTCR   [STCR] : Endif
# Issue 110325 - 2016-01-05 by SR : FCC sur expķ
If !clalev([F:SHH])    Local File SHIPMENT   [SHH]  : Endif
If !clalev([F:SHD])    Local File SHIPMENTD  [SHD]  : Endif
If !clalev([F:TRNP])   Local File TRANSPORT [TRNP]  : Endif
# Issue X3-25003 - 2017-05-23 by SR : Valorisation des rķceptions
If !clalev([F:PSV])    Local File PTDSTKVAL  [PSV]  : Endif
# Issue X3-129400 - 2019-02-25 by SR :
If !clalev([F:PSV2])   Local File PTDSTKVAL  [PSV2] : Endif


#-----
If !clalev ([F:PIX])
  Link [PIDB] With [PIHB] PIH0=[F:PIDB]NUM As [PIX]
Endif
#-----
If GMODU(5)=2 : # Si module ventes actif
  If !clalev([F:SIH])   Local File SINVOICE   [SIH] : Endif
  If !clalev([F:SIV])   Local File SINVOICEV  [SIV] : Endif
  If !clalev([F:SID])   Local File SINVOICED  [SID] : Endif
  Raz [F:SID] : # Ó cause de l'INISEC "PID"
Endif
#-----------------------------------------------#
# Rķcupķration des paramĶtres achats et budget  #
# Chargement GITMFLG : 1=rķf.art  2=rķf.art/fou #
#-----------------------------------------------#
Call GETSOC(GFCYDEF(6)) From DEVSUB : GFCY=GFINRSP
Call GETFCYDEF(GFCY,"[F:FCY]FINFLG=2 & [F:FCY]LEGCPY=GSOCIETE") From TRTX3
If GFCY<>""
  Gosub CHARG_PARAM : If OK=0  Return : Endif
Endif
#-----
Read [TCU] TCU0=GLOCALDEV : If fstat Raz [F:TCU] : Endif
#-----
GCUR=GLOCALDEV
GORITITCOL=1
#-----------------------------------------------#
# Dķclaration des variables pour tableau lignes #
#-----------------------------------------------#

Gosub DECLARE From TABLEAUX
Gosub OUVRE From TEN99LIB          #1099.n Open BOX1099 table & set GS1099

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")>0
  Gosub OUVRE_PIH From SWIBVRLIB4
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub OUVRE_QRC From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
Endif
# SAM 101378 END

Return

$OUVRE_BOITE
#-------------------------------#
# AprĶs ouverture de la fenĻtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char GBOXPI2(10), GBOXPO1(10), GBOXPT1(10), GBOXPI1(10), GBOXPN1(10), GBOXSI2(10), GBOXLO1(10)
GBOXPI2="GAU_CHE"+num$(find("PI2",OBJLIS(1..8))) : # Liste des factures par fournisseur
GBOXPO1="GAU_CHE"+num$(find("PO1",OBJLIS(1..8))) : # Picking des commandes
GBOXPT1="GAU_CHE"+num$(find("PT1",OBJLIS(1..8))) : # Picking des rķceptions
GBOXPI1="GAU_CHE"+num$(find("PI1",OBJLIS(1..8))) : # Picking des factures
GBOXPN1="GAU_CHE"+num$(find("PN1",OBJLIS(1..8))) : # Picking des retours
GBOXSI2="GAU_CHE"+num$(find("SI2",OBJLIS(1..8))) : # Picking des factures ventes
GBOXLO1="GAU_CHE"+num$(find("LO1",OBJLIS(1..8))) : # dķpense liķes
Return

$SETBOUT
#-------------------------------------------------------------------------#
# Activation / dķsactivation des menus (ToolBar) et boutons (bas d'ķcran) #
#-------------------------------------------------------------------------#
GPIH_VERROU=VERROU
# Issue X3-120858 - 2018-12-21 by SR : Performances en import et Web services
If GIMPORT | GWEBSERV : Return : Endif
#----- Menus "Texte entĻte" et "Texte pied" dans la ToolBar -----#
If GREP="C" | GREP="D" | [M:PIH0]NUM<>""
  CHMEN+="FG"
Endif
#----- Menus "Adresse facture"  et "Adresse rĶglement"  dans la ToolBar -----#
If GREP<>"" | CLECUR
  CHMEN+="HI"
Endif
#----- Menu "CritĶres picking" -----#
If [M:PIH0]PIHTYP>0 & [M:PIH0]PIHTYP<>2 & [M:PIH0]BPR<>"" & [M:PIH1]CUR<>""
&                   & [M:PIH1]STA<3     & [M:PIH0]BETCPY<>2
  #----- Si modif non autorisķe, dķsactivation du prķchargement -----#
  If GREP<>"C"
    GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
    If GBIDI2 & VERROU  CHMEN+="J" : Endif
  Else
    CHMEN+="J"
  Endif
Endif
#----- Menu "Informations douaniĶres" -----#
#If CLECUR
  CHMEN+="K"
#Endif
#----- Menu "Consultation factures" dans la ToolBar -----#
If GREP="" & CLECUR & clalev([M:CPI2])=0
  CHMEN+="L"
Endif
#----- Menu "Transaction" -----#
CHMEN+="M"
#----- Menu "PiĶce comptable" -----#
If [M:PIH1]STA>2 & GMODU(2)=2
  CHMEN+="N"
Endif
#----- Menu "PiĶce analytique" -----#
If [M:PIH1]STA>2 & GLOCITAPRE
  CHMEN+="O"
Endif
#----- Menu "Annulation comptable" -----#
If !GIMPORT & !GHISTO
  If find("N",XMEN(1..NBRMEN))
    #RMA * 103303
    #If [M:PIH1]STA>2 & func AFNC.PARAM("POSTINVSUP",[M]FCY)="2" : # (ajout BY 07/08/08 pour suppression codes activitķ)
    If [M:PIH1]STA>2 & func AFNC.PARAM("POSTINVSUP",[M]FCY)="2" & func PORLEGLIB.DIGSIGNPIH([M]FCY, "",[M]PIVTYP) = 0 : # (ajout BY 07/08/08 pour suppression codes activitķ)
      CHMEN+="P"
    Endif
  Endif
Endif
#----- Menu "Trańabilitķ piĶces" -----#
# SYMEU 10/12/2008 : branchement trańabilitķ piĶces
#If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) and [M:PIH0]INVTYP<=2 Then CHMEN += "Q" Endif
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "Q" Endif : # MBT 29/12/08 en attendant modif SYMEU !
#----------------------------------------------------------#
# Suppression des boutons # CODE                           #
#                         D DUPLICATION                    #
#                         A ANNULATION  si facture validķe #
#                                       ou si GSIVSUP=1    #
#----------------------------------------------------------#
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR
  Call VIREBOUT(CHAINE,"D") From GOBJET
  # Issue 114426 - 2016-03-18 by RICAR : SIVSUP parameter to split in PIVSUP and GASSUP
  # Issue 114426
  If [M:PIH1]STA=3 | GPIVSUP=1 Call VIREBOUT(CHAINE,"A") From GOBJET : Endif #85785
  # End issue 114426
Endif
#----- Suppression des boutons "Echķances" et "Validation" si nķcessaire -----#
If GREP<>""
  Call VIREBOUT(CHAINE,"12") From GOBJET
Else
  If !CLECUR           Call VIREBOUT(CHAINE,"1")  From GOBJET : Endif
  If !CLECUR        |
&    [M:PIH1]STA<>2 |
&    !VERROU           Call VIREBOUT(CHAINE,"2")  From GOBJET : Endif
Endif
#----- Suppression du bouton "Immo" si nķcessaire -----#
OKIMMO = 1
If GREP<>"" or CLECUR=0 or [M:PIH3]NBLIG<1 or !find("",[M:PIH3]FASREF(0..[M:PIH3]NBLIG-1))
&           or !find(2,[M:PIH3]LINPURTYP(0..[M:PIH3]NBLIG-1))
&           or [M:PIH1]STA<3
  OKIMMO = 0
Elsif [M:PIH3]NBLIG>1 & find("",[M:PIH3]FASREF(0..[M:PIH3]NBLIG-1))
  NOL = 0
  While NOL<[M:PIH3]NBLIG & find("",[M:PIH3]FASREF(NOL..[M:PIH3]NBLIG-1))
    NOLI = find("",[M:PIH3]FASREF(NOL..[M:PIH3]NBLIG-1))-1+NOL
    If [M:PIH3]LINPURTYP(NOLI) = 2
      OKIMMO = 1 : Break
    Else
      OKIMMO = 0 : NOL += 1
    Endif
  Wend
Else
  Call GETEXE([F:FCY]LEGCPY,GTYPGEN,[M:PIH0]ACCDAT,EXE) From CPTSUB
# DBA le 17/03/03 : Sugg 15007
# If [F:FIY]FIYSTA = 3
  If [F:FIY]FIYSTA >2
    OKIMMO = 0
  Endif
Endif
If !OKIMMO
  Call VIREBOUT(CHAINE,"3") From GOBJET
Endif
#----- AprĶs touche f5 rķactualisation de la liste de picking -----#
#-------------------------------------------------------------------------#
# N'est plus nķcessaire car effectuķ par l'appel de l'action AP_FILGAUCHE #
#-------------------------------------------------------------------------#
# If !GIMPORT
#   If num$(REPONSE)="1799" WPICK=2 : Gosub ACTUALIS_MARQUAGE : Endif
# Endif

#RBA 110811/US2
If func AFNC.ACTIV("EDIX3") <> 0
  If func CNSEDKSTD.GET_EDI_CATACT([M]NUM, 1) <> 0
    CHMEN += "V" #Historic
  Endif
  #CJ 110811/US9
  GFCY=[M:PIH0]FCY : GBIDC2="I" : Gosub AUTORIS_OPT From CONTX3
  If GBIDI2 and ([M:PIH1]STA <> 1 and [M:PIH1]STA <> 2)
  #RBA 112138/US2
    CHMEN += "Y" #Run EDI Issue
  Else
    Call VIREBOUT(CHMEN,"Y") From GOBJET # No EDI Issue
  Endif
  #/CJ 110811/US9
Endif
#/RBA 112138/US2

# GRNA 15/09/2011 - Three way matching
Gosub PIH_SETBOUT From TWMLIB

# X3-197349 2020-05-20 Bader begin disable "Open items" if coming from MODECHE
If GFONC1 = "MODECHE"
  Call VIREBOUT(CHAINE,"1") From GOBJET # Open items
Endif
# X3-197349 2020-05-20 Bader end

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")>0
  Gosub SETBOUT_PIH From SWIBVRLIB4
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub SETBOUT_PIH From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
Endif
# SAM 101378 END
Return

$AVANTBOUT
#-----------------------------------#
# Avant exķcution des boutons       #
# --------------------------------- #
# 1 = Echķances                     #
# 2 = Validation (Comptabilisation) #
# 3 = Immo                          #
#                                   #
# F = Texte entĻte                  #
# G = Texte pied                    #
# H = Adresse facture               #
# I = Adresse rĶglement             #
# J = CritĶres picking              #
# K = Informations douaniĶres       #
# L = Consultation des factures     #
# M = Visu transaction de saisie    #
# N = PiĶce comptable               #
# O = PiĶce analytique              #
# P = Annulation comptable          #
#-----------------------------------#
Local  Libelle  WTYPADR
Local  Char     WABREV(5)
GPIH_VERROU=VERROU : Raz SYMBOL2
If [M:PIH0]NUM<>"" & GPIH_VERROU=0 & find(BOUT,"1","2","3","H","I","N")
  SYMBOL2="PIH"+[M:PIH0]NUM : Lock=SYMBOL2
  If !fstat  GPIH_VERROU=1  Else  Raz SYMBOL2 : Endif
Endif
#-----
Local  Char     SAV_ZONCOU(GLONAVA)
If GREP<>"" SAV_ZONCOU=COUZON Else SAV_ZONCOU="" : Endif
Case BOUT
  When "1" : GBIDI1=0
             GBIDC2="E" : Gosub AUTORIS_OPT From CONTX3
             If !GBIDI2
               GMESSAGE=mess(39,117,1)-":"-mess(17,137,1)  : GERR=1 : OK=0 : Goto FIN_AVANTBOUT
             Endif
  When "2" : Filter [GAC]
             If !GPIH_VERROU
               GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Goto FIN_AVANTBOUT
             Endif
             GFCY=[M:PIH0]FCY : GBIDC2="V" : Gosub AUTORIS_OPT From CONTX3
             If !GBIDI2
               GMESSAGE=mess(360,194,1)  : GERR=1 : OK=0 : Goto FIN_AVANTBOUT
             Endif
             OK=1 : Call AVERTIR(mess(156,196,1),OK) From GESECRAN
             If OK=1  OK=0 : Goto FIN_AVANTBOUT : Endif
             #---- Relecture enr. facture (peut Ļtre perdu Ó cause du picking) ----#
             If [F:PIH]NUM<>[M:PIH0]NUM | [F:PIH]INVTYP=0
               Read [PIH] PIH0=[M:PIH0]NUM
               If fstat
                 Raz [F:PIH]
                 GMESSAGE=mess(12,100,1)-"PINVOICE"-[M:PIH0]NUM : GERR=1
                 Goto FIN_AVANTBOUT
               Endif
             Endif
             #---- ProblĶme Ó la validation des factures trop de table ouvertes ----#
             If clalev([F:TCA])    Close Local File [TCA]  : Endif
             If clalev([F:PTR])    Close Local File [PTR]  : Endif
             # Issue 85800 - 2013-01-17 by MUARN : table voulue dans objet PT1
             #If clalev([F:POC])    Close Local File [POC]  : Endif
             If clalev([F:BPA])    Close Local File [BPA]  : Endif
             If clalev([F:MVS])    Close Local File [MVS]  : Endif
             If clalev([F:PIX])    Close Local File [PIX]  : Endif
             If clalev([F:PIHB])   Close Local File [PIHB] : Endif
             If clalev([F:PIDB])   Close Local File [PIDB] : Endif
             If clalev([F:PTDB])   Close Local File [PTDB] : Endif
             If clalev([F:TCY])    Close Local File [TCY]  : Endif
             If clalev([F:TVT])    Close Local File [TVT]  : Endif
             If clalev([F:TPV])    Close Local File [TPV]  : Endif
             #-----
             #############################################################################
             ##INICIO: MODIFICACIONES PARA LOCALIZACIONES COMPRAS ARGENTINA             ##
             ##ARGENTINA: 27.07.2005 - Juan Pablo Mansilla                              ##
             ##Funcionalidad agregada para gestion de retenciones e impuestos internos  ##
             ##en la factura de proveedor                                               ##
             #############################################################################
             GPOINT="XPIHTAXINT" : Gosub ENTREE From EXEFNC
             #############################################################################
             ##FIN: MODIFICACIONES PARA LOCALIZACIONES COMPRAS ARGENTINA                ##
             ##ARGENTINA: 27.07.2005                                                    ##
             #############################################################################
             #-----
  When "F","G" : If GREP="" & dim(ACTMOD)>0 & !ACTMOD  GCONSDIA=2 : Endif
  When "H" : If GREP="" & (!ACTMOD | !VERROU)  GCONSULT=1 : Endif
  When "I" : If GREP="" & (!ACTMOD | !VERROU)  GCONSULT=1 : Endif
  When "K" : Local  Integer WEXEFLG : WEXEFLG=5
  When "N" : Gosub AVANTBOUT_GAS
  When "O" : SAVGCONSULT=GCONSULT
  When "P" : If clalev([F:CPY])=0 Local File COMPANY [CPY] : OUVFICFLG=1 : Endif
  When "5" : # SAM 101378: Localization Switzerland, 2016-01-19 Bader
             If func AFNC.ACTIV("KSW")>0
                Gosub AVANTBOUT_PIH From SWIBVRLIB4
             Endif
             # SAM 101378 END
Endcase
$FIN_AVANTBOUT
If !OK & SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return

$AVANTBOUT_GAS
#-----------------#
# PiĶce comptable #
#-----------------#
SAVGCONSULT=GCONSULT
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : OUVFICFLG=1 : Endif
Read [HAE] HAE0=[M:PIH0]GTE;[M:PIH0]NUM
If !fstat
  GFLAG   =[F:HAE]DACDIA
  GBIDC2  =[M:PIH0]NUM
  GBIDC3  =[M:PIH0]GTE
  GCONSULT=1
Else
  OK=0
  If OUVFICFLG=1 Close Local File [HAE] : Raz OUVFICFLG : Endif
Endif
Return

$AVANT_SUITE
#---------------------------------------------------------------------#
# AprĶs exķcution d'une action et avant l'exķcution de l'action suite #
#---------------------------------------------------------------------#
Case BOUT
  When "N" :  # PiĶces comptables
    Gosub AVANT_SUITE From GASTRC
  When "O" :  # PiĶce analytique
    I=instr(1,VALBOUT," ")
    If !I
      OK=0
    Else
      [L]VALC1="GAS"
      [L]VALC3=left$(VALBOUT,I-1)
      [L]VALC2=right$(VALBOUT,I+1)
      GCONSULT=1
    Endif
  When "3"
    If GOKIMMO
      OK = 1
    Else
      OK = 0
    Endif
Endcase
Return

$EXEBOUT
#------------------------------------#
# AprĶs exķcution des boutons du bas #
# 1 = Echķances                      #
# 2 = Validation (Comptabilisation)  #
# 3 = Immo                           #
#------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "1" : #GBIDI2=[M:PIH0]PAZ                                        : # Bug 17191
             Call FIRST_DUD(1) From SUBPIHC
             #Trbegin [PIH]                                             : # Bug 17191
             #  Update [PIH] Where NUM=[M:PIH0]NUM With PAZ=[M:PIH0]PAZ : # Bug 17191
             #Commit                                                    : # Bug 17191
             #If currbox="GAU_CHE" & GBIDI2<>[M:PIH0]PAZ                : # Bug 17191
             #  Gosub REMPLIT_ From WGOPIH                              : # Bug 17191
             #Endif                                                     : # Bug 17191
  When "2" : If !clalev([F:TCA])  Local File TABCOUAFF  [TCA]  : Endif
             If !clalev([F:PTR])  Local File PURTRS     [PTR]  : Endif
             If !clalev([F:POC])  Local File PORDERC    [POC]  : Endif
             If !clalev([F:BPA])  Local File BPADDRESS  [BPA]  : Endif
             If !clalev([F:MVS])  Local File BPSUPPMVT  [MVS]  : Endif
             If !clalev([F:TCY])  Local File TABCOUNTRY [TCY]  : Endif
             If !clalev([F:TVT])  Local File TABVAT     [TVT]  : Endif
             If !clalev([F:TPV])  Local File TABPIVTYP  [TPV]  : Endif
             If !clalev([F:PTDB]) Local File PRECEIPTD  [PTDB] : Endif
             If !clalev([F:PIHB]) Local File PINVOICE   [PIHB] : Endif
             If !clalev([F:PIDB]) Local File PINVOICED  [PIDB] : Endif
             If !clalev([F:PIX])
               Link [PIDB] With [PIHB] PIH0=[F:PIDB]NUM As [PIX]
             Endif
             Default File [PIH]
             #----- Relecture affectation compteurs et transaction de saisie -----#
             Call LECTCA(6,OK) From SUBTCA
             If fstat | !OK  Raz [F:TCA], GMESSAGE, GERR : Endif
             Read [PTR] PTR0=8;GPTRNUM  : If fstat Raz [F:PTR]  : Endif
             #--------------------------------------------------------------------#
             Gosub RELIT From GOBJSUB
  When "3" : Gosub RELIT From GOBJSUB
Endcase
GFCY=[M:PIH0]FCY
Return

$STATUT
#-------------------------------------------#
# AprĶs exķcution des boutons de la ToolBar #
# F = Texte entĻte                          #
# G = Texte pied                            #
# H = Adresse facture                       #
# I = Adresse rĶglement                     #
# J = CritĶres picking                      #
# K = Informations douaniĶres               #
# L = Consultation des factures             #
# M = Visu transaction de saisie            #
# N = PiĶce comptable                       #
# O = PiĶce analytique                      #
# P = Annulation comptable                  #
# Q = Trańabilitķ piĶces                    #
#-------------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "F" : Gosub APRESBOUT_TEXTE
  When "G" : Gosub APRESBOUT_TEXTE
  When "J" : Gosub TIROIR
  When "H" : If !GCONSULT & GREP=""
               WTYPADR=1 : WABREV="AD66" : Gosub MAJ_ADRESSE From TRTACHFAC1
             Elsif !GIMPORT
               [M:PIH0]BPRNAM1=[M:AD66]BPRNAM(0)
               Affzo [PIH0]BPRNAM1
             Endif
             #----- Recopie adresse fournisseur facturant divers pour fournisseur payķ -----#
             If [M:PIH1]BPRPAY=[M:PIH0]BPR & [M:AD67]ADBFLG<>2
               If [F:BPS]BPSNUM<>[M:PIH0]BPR
                 Read [BPS] BPS0=[M:PIH0]BPR : If fstat  Raz [F:BPS] : Endif
               Endif
               If [F:BPS]BPSTYP=3  [M:AD67]=[M:AD66] : Endif
             Endif
  When "I" : If !GCONSULT & GREP=""
                # Issue 87705 - 2013-02-15 by SR
                WMODADR = 1
                If [M:AD67]BPAADD <> [M:PIH1]BPAPAY : WMODADR = 2 : Endif
                WTYPADR=2 : WABREV="AD67" : Gosub MAJ_ADRESSE From TRTACHFAC1
                If WMODADR = 2
                   [M:PIH1]MODADR = 2
                   Gosub ENTRE_MODIF From GOBJSUB
                Endif
             Endif
  When "K" : Gosub ACTIV_GSTAENR
  When "N" : GCONSULT=SAVGCONSULT : GFLAG=GPTRNUM
             If OUVFICFLG>0
               Close Local File [HAE] : Raz OUVFICFLG : Default File [PIH]
             Endif
  When "O" : GCONSULT=SAVGCONSULT
  When "P" : If OUVFICFLG>0
               Close Local File [CPY] : Raz OUVFICFLG : Default File [PIH]
             Endif
             Gosub RELIT From GOBJSUB
  When "Q" : Call GETDEV(GFCY)  From DEVSUB # Issue 83475 - 2012-07-19 by MUARN : conversion devise
  When "U" : Gosub RELIT From GOBJSUB
Endcase
#VPO 14/03/11 72298 ajout test dim(SAV_ZONCOU)
If dim(SAV_ZONCOU)>0 & SAV_ZONCOU<>"" & !GIMPORT  SUIZON=SAV_ZONCOU : Endif
Return
#----- Activation du bouton enregistrer -----#
$ACTIV_GSTAENR
If GREP="" & WEXEFLG=9
  Gosub ENTRE_MODIF From GOBJSUB
Endif
Return

$APRESBOUT_TEXTE
#---------------------------------#
# Texte entĻte et pied de facture #
#---------------------------------#
If mkstat=4 & GREP="" : # Texte modifiķ
  Gosub ENTRE_MODIF From GOBJSUB
Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If GREP="" & ([M:PIH0]TEX1<>"" | [M:PIH0]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Return

$HINTCLE
#-----------------------------------------------------------#
# Clķ pour optimisation du remplissage des listes de gauche #
#-----------------------------------------------------------#
Case currbox
  When GBOXPO1 : HINTLIS(val(right$(GBOXPO1,8)))="POQ1"
  When GBOXPT1 : HINTLIS(val(right$(GBOXPT1,8)))="PTD1"
  When GBOXPI1 : HINTLIS(val(right$(GBOXPI1,8)))="PID3"
  When GBOXPN1 : HINTLIS(val(right$(GBOXPN1,8)))="PND2"
  When GBOXSI2 : HINTLIS(val(right$(GBOXSI2,8)))="SIH1"
  When GBOXLO1 : HINTLIS(val(right$(GBOXLO1,8)))="LOF0"
Endcase
Return

$CLE_GAUCHE
#----------------------------------------------------------------------------#
# Ajout du numķro de facture pour le tiroir des factures/avoirs fournisseurs #
#----------------------------------------------------------------------------#
If currbox=GBOXPI2
  LENLIS+=1
  CLELISTE+=";NUM"
Endif
Return

$FILGAUCHE
# Issue X3-69477 - 2017-12-28 by SR : Section complĶtement revue pour :
#Remplissage de FILGAUSUP via ADDCRIT
#Utilisation de CRMUTIL150 pour rķcupķrer les r¶les
#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
Raz FILGAUSUP, IFILGAUSUP
If currbox=GBOXPI2    : # Liste des factures par fournisseur
  WCRITERE ="[F:PIH]ORIMOD=6"
  # Issue 114584 - 2016-02-22 by SR
  WCRITERE+= "& find([F:PIH]FCY,GUSRFCY(1..GNBAUZ))"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PIH") From CRMUTIL150
  Return
Elsif currbox=GBOXSI2 : # Picking des factures ventes
  If [M:PIH0]BETCPY=2 & [M:PIH0]BPCINV<>"" & [M:PIH1]STA<3 &
&   ([M:PIH0]SIHNUM<>"" | [M:PIH3]NBLIG=0) & GREP="C"
    WCRITERE ="[F:SIH]BPR=[M:PIH0]BPCINV"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    If GCTLDATORI=2
      WCRITERE=" [F:SIH]ACCDAT<=[M:PIH0]ACCDAT"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    WCRITERE=" [F:SIH]ORIMOD=5 & [F:SIV]BETCPY=2 & [F:SIV]PIHNUM=''"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    WCRITERE="[F:SIV]INVTYP<3 & [F:SIH]STA=3"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    WCRITERE="[F:SIV]ORIFCY<>[F:SIV]SALFCY"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"SIH") From CRMUTIL150
  Else
    WCRITERE="[F:SIH]BPR='' & [F:SIH]INVTYP=9"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  Return
Elsif currbox=GBOXLO1 : # Dķpenses liķes
  WCRITERE="CODLOF=[M:PIH0]NUM"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
Endif
If [M:PIH0]PIHTYP<>0 & [M:PIH0]BPR<>"" & [M:PIH1]CUR<>"" & [M:PIH1]STA<3 &
&  ([M:PIH0]BETCPY<>2 | [M:PIH0]SIHNUM="")
  If currbox=GBOXPO1    : # Picking des commandes
    If [M:PIH0]PIHTYP<>1
      WCRITERE ="[F:POQ]LININVFLG=9"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:POP]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
    Else
      WCRITERE ="[F:POQ]LININVFLG=1 & [F:POQ]WIPSTA<2 & [F:POQ]BPSINV=[M:PIH0]BPR"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If [M:PCIW]WITMREF<>""
         WCRITERE="pat([F:POQ]ITMREF,[M:PCIW]WITMREF)<>0"
         Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      If [M:PCIW]WNUMCDE<>""
         WCRITERE="pat([F:POQ]POHNUM,[M:PCIW]WNUMCDE)<>0"
         Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      # AUREN - V12
        If [M:PIH0]ZPOHNUM <> "" FILGAUSUP(0) +=" & pat([F:POH]POHNUM,[M:PIH0]ZPOHNUM)<>0 ": Endif
      # AUREN - V12
      WCRITERE="([F:POQ]LINCLEFLG<2 | [F:POQ]RCPQTYPUU>[F:POQ]INVQTYPUU | [F:POQ]RCPQTYSTU>[F:POQ]INVQTYSTU)"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # AUREN - 05.880.536 - MOSTRAR EN LISTA IZDA LOS PEDIDOS NO FIRMADOS
      #WCRITERE="[F:POQ]LINTYP<3 & [F:POH]APPFLG>2"
      WCRITERE="[F:POQ]LINTYP<3"
      # AUREN - 05.880.536 - MOSTRAR EN LISTA IZDA LOS PEDIDOS NO FIRMADOS
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If GCTLDATORI=2
         WCRITERE="[F:POH]ORDDAT<=[M:PIH0]ACCDAT"
         Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      WCRITERE="[F:FCY]LEGCPY=GSOCIETE"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      WCRITERE="([F:POH]BETFCY<>2 | ([F:POH]BETCPY=2 & [F:POH]SALFCY=''))"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:POP]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"POH") From CRMUTIL150
    Endif
  Elsif currbox=GBOXPT1 : # Picking des rķceptions
    If [M:PIH0]PIHTYP<>1
      WCRITERE ="[F:PTD]LININVFLG=9"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:PTD]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
    Else
      WCRITERE ="[F:PTD]LININVFLG=1 & [F:PTD]BPSINV=[M:PIH0]BPR"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If [M:PCIW]WITMREF<>""
        WCRITERE="pat([F:PTD]ITMREF,[M:PCIW]WITMREF)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      If [M:PCIW]WNUMRCP<>""
        WCRITERE="pat([F:PTD]PTHNUM,[M:PCIW]WNUMRCP)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      If [M:PCIW]WNUMCDE<>""
        WCRITERE="pat([F:PTD]POHNUM,[M:PCIW]WNUMCDE)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
     #FILGAUSUP(0)-="& ([F:PTD]QTYPUU>[F:PTD]INVQTYPUU | [F:PTD]QTYSTU>[F:PTD]INVQTYSTU)"
      WCRITERE="[F:PTD]LINTYP<3"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If [M:PCIW]WBPSNDE<>""
        WCRITERE="pat([F:PTH]BPSNDE,[M:PCIW]WBPSNDE)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      WCRITERE="[F:FCY]LEGCPY=GSOCIETE"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
      #If GCTLDATORI=2  FILGAUSUP(1)-="& [F:PTH]RCPDAT<=[M:PIH0]ACCDAT" : Endif
      If GCTLDATORI=2
        WCRITERE="(([F:PTH]NDEDAT=[0/0/0] & [F:PTH]RCPDAT<=[M:PIH0]ACCDAT)|([F:PTH]NDEDAT<>[0/0/0] & min([F:PTH]NDEDAT,[F:PTH]RCPDAT)<=[M:PIH0]ACCDAT))"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      # Issue 120453 - 2016-12-16 by SR : Retour arriĶre sur cette correction
      # Issue 95534 - 2013-12-31 by SR : Rķceptions Inter sociķtķ sont toujours facurables
  #    FILGAUSUP(1)-="& ([F:PTH]BETFCY<>2  | [F:PTH]BETCPY=2)"
      WCRITERE="([F:PTH]BETFCY<>2 | ([F:PTH]BETCPY=2 & ([F:PTD]VERFLG=2 | [F:PTD]SDHNUM='')))"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 70507 - 2012-01-18 by MUARN : qtķ facturable non nulle
      If GPIHQTYRET = 1
        WCRITERE="[F:PTD]RTNQTYPUU<[F:PTD]QTYPUU"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:PTD]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PTH") From CRMUTIL150
    Endif
  Elsif currbox=GBOXPI1 : # Picking des lignes d'une facture
    If [M:PIH0]PIHTYP<>3
      WCRITERE="[F:PID]BPR='' & [F:PID]INVTYP=9"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:PID]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
    Else
      WCRITERE="[F:PID]BPR=[M:PIH0]BPR"
      If [M:PIH1]INVNUM<>""
        WCRITERE+="& [F:PID]NUM=[M:PIH1]INVNUM"
      Else
        WCRITERE+=" & [F:PID]INVTYP=1"
      Endif
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If [M:PCIW]WITMREF<>""
        WCRITERE="pat([F:PID]ITMREF,[M:PCIW]WITMREF)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      WCRITERE="[F:PID]LINTYP<3"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      WCRITERE="[F:PIH]CPY=GSOCIETE & [F:PIH]STA=3"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If GCTLDATORI=2
         WCRITERE="[F:PIH]ACCDAT<=[M:PIH0]ACCDAT"
         Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      # Issue 71069 - 2013-08-23 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:PID]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PIH") From CRMUTIL150
    Endif
  Elsif currbox=GBOXPN1 : # Picking des retours
    If [M:PIH0]PIHTYP<>4
      WCRITERE ="[F:PND]LININVFLG=9" : FILGAUSUP(1)=""
      # Issue 71069 - 2013-08-26 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE+='&[F:PND]PJT=[M:PIH1]PJTH'
      Endif
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Else
      WCRITERE="[F:PND]LININVFLG=1 & [F:PND]BPSINV=[M:PIH0]BPR & [F:PND]LINAUTFLG<>2"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If [M:PCIW]WNUMRET<>""
        WCRITERE="pat([F:PND]PNHNUM,[M:PCIW]WNUMRET)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      If [M:PCIW]WITMREF<>""
        WCRITERE="pat([F:PND]ITMREF,[M:PCIW]WITMREF)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      WCRITERE="([F:PND]QTYPUU>[F:PND]INVQTYPUU | [F:PND]QTYSTU>[F:PND]INVQTYSTU)"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      WCRITERE="[F:PND]LINTYP<3"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      WCRITERE ="[F:PNH]CFMFLG>1 & ([F:PNH]BETFCY<>2 | [F:PNH]BETCPY=2)"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      WCRITERE="([F:PNH]BETCPY<>2 | [F:PND]PTHNUM<>'')"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      If GCTLDATORI=2
        WCRITERE="[F:PNH]RTNDAT<=[M:PIH0]ACCDAT"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      WCRITERE="[F:FCY]LEGCPY=GSOCIETE"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      # Issue 71069 - 2013-08-26 by MUARN : PJT
      If ([M:PIH3]NBLIG > 0 | ([M:PIH3]NBLIG = 0 & [M:PIH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
        WCRITERE='[F:PND]PJT=[M:PIH1]PJTH'
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
      Endif
      Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PNH") From CRMUTIL150
    Endif
  Endif
Elsif find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1)
  Case currbox
    When GBOXPO1 : WCRITERE="[F:POQ]LININVFLG=9"
                   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    When GBOXPT1 : WCRITERE="[F:PTD]LININVFLG=9"
                   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    When GBOXPI1 : WCRITERE="[F:PID]BPR='' & [F:PID]INVTYP=9"
                   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    When GBOXPN1 : WCRITERE="[F:PND]LININVFLG=9"
                   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endcase
Endif
Return

$AP_FILGAUCHE
#---------------------------------------------------------#
# AprĶs pagination avant ou arriĶre d'une liste de gauche #
#---------------------------------------------------------#
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2) Return : Endif
WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return

$TIROIR
#---------------------------------------------------#
# Click sur un tiroir                               #
# Dķsormais entiĶrement gķrķ par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel Ó la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'aprĶs crķation, d'aprĶs modif ...etc #
#---------------------------------------------------#
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2)  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
Return

$DEB_PICK
#---------------#
# Dķbut picking #
#---------------#
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2) Return : Endif
SAVNBLIG=[M:PIH3]NBLIG : WRET=0 : WMSG=""
GPIH_PICK=1
Local Integer XMESS #1099.n
Return

$PICKE
#----------------------#
# Nouvel ķlķment pickķ #
#----------------------#
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2) Return : Endif
Local Char SWPJTMSG(250)  # Issue 71069 - 2013-08-27 by MUARN : PJT
If REP=""
  If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
  Gosub AVANT_MOD : If !OK  Return : Endif
Endif
If WRET=1  OK=0 : Return : Endif
Case currbox
  When GBOXPO1 : Gosub PICKE_CDE  From SUBPIHD
  When GBOXPT1 : Gosub PICKE_RCP  From SUBPIHD
  When GBOXPI1 : Gosub PICKE_FAC2 From SUBPIHD
  When GBOXPN1 : Gosub PICKE_RET  From SUBPIHD
  When GBOXSI2 : Gosub PICKE_SIH  From SUBPIHD
Endcase
Gosub PICKE From TEN99LIB # 1099.n
Return

$DEPICK
#------------------------#
# Nouvel ķlķment dķpickķ #
#------------------------#
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2) Return : Endif
Case currbox
  When GBOXPO1 : Gosub DEPICK_CDE  From SUBPIHD
  When GBOXPT1 : Gosub DEPICK_RCP  From SUBPIHD
  When GBOXPI1 : Gosub DEPICK_FAC2 From SUBPIHD
  When GBOXPN1 : Gosub DEPICK_RET  From SUBPIHD
  When GBOXSI2 : Gosub DEPICK_SIH  From SUBPIHD
Endcase
Gosub PICKE From TEN99LIB # 1099.n
Return

$FIN_PICK
#-------------#
# Fin picking #
#-------------#
GPIH_PICK=0
If REP=""
  If !VERROU
    GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
  Elsif !CLECUR | !ACTMOD | GCONSULT
    GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
  Endif
Endif
Affzo [PIH3]1-99
Gosub TEST_VALID From SUBPIH : # MÓj bases taxables et calcul taxes ķlķments facturation
zonsui="[M:PIH3]NBLIG(max(0,nolign-1))" : # Dommage, il empĻche le contr¶le de l'onglet 1
Setmok [PIH1] With 0             : # Ne sert Ó rien (Bug superviseur 23196)
Return

$GRISAGE
#-----------------------------------------------------#
# Traitement du grisage et dķgrisage des champs ķcran #
#-----------------------------------------------------#
If [M:PIH3]NBLIG=0 & GREP="C"
  Actzo [PIH0]FCY, PIVTYP, BPR
  Actzo [PIH1]CUR
Else
  Diszo [PIH0]FCY, PIVTYP, BPR
  #VPO 09/11/10 68969 la devise ne doit pas Ļtre modifiable sur facture validķe
  If [M:PIH1]STA=3
     Diszo [PIH1]CUR
  Else
     Actzo [PIH1]CUR
  Endif
Endif
If [F:BPS]BPSNUM<>[M:PIH0]BPR
  Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
Endif
If [F:BPS]DUDCLC=1 & [M:PIH3]NBLIG=0
  Diszo [PIH1]STRDUDDAT
Elsif [M:PIH1]STA<>3
  Actzo [PIH1]STRDUDDAT
Endif
If [M:PIH0]PIHTYP=3 & [M:PIH3]NBLIG=0 & GREP="C"
  Actzo [PIH1]INVNUM
Elsif [M:PIH0]PIHTYP=3
  Diszo [PIH1]INVNUM
Endif
If [M:PIH3]NBLIG=0 Diszo [PIH4]AMTTAX Else Actzo [PIH4]AMTTAX : Endif

Return

$ACTUALIS_MARQUAGE
#---------------------------------------------------------------#
# Actualisation des ķlķments "pickķs" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                   #
#         1 = Enlever le marquage des ķlķments "pickķs"         #
#         2 = Marquer les ķlķments "pickķs"                     #
#---------------------------------------------------------------#
If [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>"" & currbox=GBOXSI2
  Read [SIH] SIH0=[M:PIH0]SIHNUM : If fstat  Raz [F:SIH] : Endif
  Read [SIV] SIV0=[M:PIH0]SIHNUM : If fstat  Raz [F:SIV] : Endif
  If [F:SIH]NUM<>"" & [F:SIV]NUM<>""
    Case WPICK
      When 1 : Gosub DEPICK From GOBJSUB : # Actualisation marquage facture vente
      When 2 : Gosub REPICK From GOBJSUB : # Actualisation marquage facture vente
    Endcase
  Endif
  Return
Endif
#-----
If [M:PIH3]NBLIG>0
  For I=0 To [M:PIH3]NBLIG-1
    Gosub MARQUAGE_LIGNE From SUBPIHD
  Next I
Endif
Return

$APRES_MODIF
#------------------------------------#
# AprĶs modification de chaque champ #
#------------------------------------#
# Issue 84130 - 2013-02-07 by MUARN landed cose  Si modification de zones impactantes
If [M:PIH3]NUMORI(nolign-1) <> ""
    # Positionnement du flag, uniquemement si nouvelle ligne
    If COUZON = "QTYUOM" & [M:PIH3]CREFLG(nolign-1)=0
       [M:PIH3]WSTCUPD(nolign-1) = 2
    Endif
Else
   If find(COUZON,"TYPORI","NUMORI","LINORI","ITMREF","GROPRI","QTYUOM","QTYVOU","QTYWEU","UOM","ACCDAT")
         [M:PIH3]WSTCUPD(nolign-1) = 2
   Endif
Endif

# SAM 101378: Localization Switzerland, 2016-01-25 Bader
If func AFNC.ACTIV("KSW")>0
  Gosub APRES_MODIF_PIH From SWIBVRLIB4
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub APRES_MODIF_PIH From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
Endif
# SAM 101378 END

If find(COUZON,"FCY","PIVTYP","BPR","VAC")
  Call FLD4041DIS([M:PIH1]VAC, [M:PIH0]PIVTYP) From SUBPIHD
Endif

If [M:PIH0]PIHTYP<>0 & [M:PIH0]BPR<>"" & [M:PIH1]CUR<>"" & [M:PIH1]STA<3
  Gosub SETBOUT From GOBJSUB
Endif
If !find(currbox,GBOXPO1,GBOXPT1,GBOXPI1,GBOXPN1,GBOXSI2) Return : Endif
# Issue 71069 - 2016-01-28 by SR : Gestion du PJT
If !find(COUZON,"FCY","PIVTYP","BPR","ACCDAT","INVNUM","PJTH") | GIMPORT      Return : Endif
If COUZON="INVNUM" [M:PIH1]INVNUM=CZ : Endif
If COUZON="ACCDAT" [M:PIH0]ACCDAT=CZ : Endif
Gosub TIROIR
Return

$DEFLIG
#----------------------------------#
# Dķfinition du fichier des lignes #
# -------------------------------- #
# CritĶre lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abrķviation fichier (ABLIG)      #
# Zone numķro ligne   (ZONLIG)     #
#----------------------------------#
Default Mask [PIH3]
Default File [PID]
CRIT   = 'NUM="'+[M:PIH0]NUM+'"'
FICLIG = "PINVOICED"
ABLIG  = "PID"
ZONLIG = "PIDLIN"
Return

$LIENS_LIG
#-----------------------------#
# AprĶs lecture ligne [F:PID] #
#-----------------------------#
Local Shortint NOL : NOL=nolign-1
If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PID]TSICOD(0) : Endif
If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PID]TSICOD(1) : Endif
If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PID]TSICOD(2) : Endif
If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PID]TSICOD(3) : Endif
If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PID]TSICOD(4) : Endif
[M:PIH3]VAT1(NOL)=[F:PID]VAT(0)
[M:PIH3]VAT2(NOL)=[F:PID]VAT(1)
[M:PIH3]VAT3(NOL)=[F:PID]VAT(2)
[M:PIH3]CUMLINAMT1+=[M:PIH3]AMTNOTLIN(NOL)
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                "PID",0,[F:PID]NUM,[F:PID]PIDLIN,0,"") From TRTX3CPT
#----- Mise Ó jour indicateur ligne (0=en cours de crķation, 1=crķķe) -----#
[M:PIH3]LINFLG(NOL)=1
#-----
[M:PIH3]PREQTYPUU(NOL)=[M:PIH3]QTYPUU(NOL)
# Issue 96640 - 2014-03-04 by SR
[M:PIH3]WOLDQTYPUU(NOL)=[M:PIH3]QTYPUU(NOL)
# End issue 96640
#VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
Gosub LECT_CDE_PTD From SUBPIHC

Gosub PIH_LIENS From TWMLIB  # Three way matching
# Issue 82703 - 2013-02-11 by SR
If [M:PIH3]CSTMAJLIN(NOL) = 0
  If [M:PIH0]PIHTYP = 2 : [M:PIH3]CSTMAJLIN(NOL) = 2 : Else : [M:PIH3]CSTMAJLIN(NOL) = 1 :  Endif
Endif
Actzo [M:PIH3]CSTMAJLIN(NOL)
If ([M:PIH1]STA = 3 | [M:PIH0]PIHTYP <> 2) : Grizo [M:PIH3]CSTMAJLIN(NOL) : Endif

# Issue 84130 - 2013-02-13 by MUARN Landed cost
[M:PIH3]WSTCUPD(NOL)=0
[M:PIH3]WSTCSEQ(NOL)=0

Return

$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
[F:PID]NUM=[M:PIH0]NUM
[F:PID]BPR=[M:PIH0]BPR
[F:PID]PIVTYP=[F:PIH]PIVTYP : [F:PID]PIHTYP=[F:PIH]PIHTYP : [F:PID]INVTYP=[F:PIH]INVTYP
If GIMPORT & ([F:PID]NUMORI="" | [F:PID]LINORI=0) [F:PID]TYPORI=5 : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expķ
Case [F:PID]TYPORI
  When 1 : [F:PID]POHNUM=[F:PID]NUMORI : [F:PID]POPLIN=[F:PID]LINORI
           [F:PID]POQSEQ=[F:PID]SEQORI
  When 2 : [F:PID]PTHNUM=[F:PID]NUMORI : [F:PID]PTDLIN=[F:PID]LINORI
           Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
           If fstat  Raz [F:PTD] : Endif
           [F:PID]POHNUM=[F:PTD]POHNUM : [F:PID]POPLIN=[F:PTD]POPLIN
           [F:PID]POQSEQ=[F:PTD]POQSEQ
  When 3 : [F:PID]PNHNUM=[F:PID]NUMORI : [F:PID]PNDLIN=[F:PID]LINORI
           Read [PND] PND0=[F:PID]PNHNUM;[F:PID]PNDLIN
           If fstat  Raz [F:PND] : Endif
           [F:PID]PTHNUM=[F:PND]PTHNUM : [F:PID]PTDLIN=[F:PND]PTDLIN
           [F:PID]POHNUM=[F:PND]POHNUM : [F:PID]POPLIN=[F:PND]POPLIN
           [F:PID]POQSEQ=[F:PND]POQSEQ
  When 4 : [F:PID]INVNUM=[F:PID]NUMORI : [F:PID]INVLIN=[F:PID]LINORI
  When 6 : [F:PID]SHIPNUM=[F:PID]NUMORI : [F:PID]SHIPLIN=[F:PID]LINORI
           Read [SHD] SHD0=[F:PID]SHIPNUM;[F:PID]SHIPLIN
           If fstat  Raz [F:SHD] : Endif
           [F:PID]POHNUM=[F:SHD]POHNUM : [F:PID]POPLIN=[F:SHD]POPLIN
           [F:PID]POQSEQ=[F:SHD]POQSEQ
Endcase
[F:PID]CPRCUR=GLOCALDEV
#----- Lecture si nķcessaire de l'article -----#
If [F:ITM]ITMREF<>[F:PID]ITMREF
  Read [ITM] ITM0=[F:PID]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGLIGNE From SUBPIHD
#----- Crķation ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Gosub PIH_INICRE_LIG From TWMLIB  # Three way matching # 95938.n
Return

$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGLIGNE From SUBPIHD
#----- Crķation ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Gosub PIH_INIMOD_LIG From TWMLIB  # Three way matching # 95938.n
Return

$VALLIG
#----------------------------------------------------------------------#
# Traitements complķmentaires ligne facture                            #
# SIGN vaut +1 en crķation ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
#----------------------------------------------------------------------#
Local Integer STAT
Gosub LECT_FICLIG From SUBPIHB : # Lecture fichiers ligne pour MAJ
# Issue X3-70158 - 2018-01-09 by MUARN : TRTLIG Ó la place de GREP
GPIH_TRTLIG = TRTLIG
Case SIGN
  When  1 : Gosub CRELIG
  When -1 : Gosub SUPLIG
  When Default
Endcase
Return

$CRELIG
#----------------------------------------#
# AprĶs Write de la ligne de facture PID #
#----------------------------------------#
#----- Ecriture des comptes et sections de la ligne de facture -----#
Call ENREG_ACCCCE(nolign-1,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE","PID",
&                 0,[F:PID]NUM,[F:PID]PIDLIN,0,"",TRTLIG) From TRTX3CPT
If GOK<1  Return : Endif
#-----

# Issue 98190 - 2014-03-21 by MUARN : pb PIDLIN si dķpick ligne
[M:PIH3]PIDLIN(nolign-1)= [F:PID]PIDLIN

If [M:PIH3]CREFLG(nolign-1)<>0  Goto MODLIG  : Endif

#----- Mise Ó jour fichiers Ó la ligne (Commande, Rķception, Retour) -----#
# Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
Gosub MAJ_FICHIERS_LIGNE From SUBPIHD             : If GOK<1 Return : Endif
#----- MÓj ligne facture vente si inter-sociķtķ -----#
If GMODU(5)=2 & [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>"" & [M:PIH3]SIDLIN(nolign-1)<>0
  Update [SID] Where NUM=[M:PIH0]SIHNUM & SIDLIN=[M:PIH3]SIDLIN(nolign-1)
&              With  PIDLIN=[F:PID]PIDLIN
  If fstat  GOK=0 : Call FSTA("SID") From GLOCK : Return : Endif
Endif
#----- Mise Ó jour statistiques ligne facture -----#
Call VALSTA("PID",SIGN) From SUBPS2  : If GOK<1 Return : Endif
Return

$MODLIG
#------------------------------------------#
# AprĶs Rewrite de la ligne de facture PID #
#------------------------------------------#
#----- Mise Ó jour fichiers Ó la ligne (Commande, Rķception, Retour) -----#
# Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
Gosub MAJ_FICHIERS_LIGNE From SUBPIHD             : If GOK<1 Return : Endif
#----- Mise Ó jour statistiques ligne facture -----#
Call VALSTA("PID",SIGN) From SUBPS2  : If GOK<1 Return : Endif
Return

$SUPLIG
#----------------------------------------------------#
# Avant Delete ou Rewrite de la ligne de facture PID #
# Soustraction statistiques ligne facture            #
#----------------------------------------------------#
Local Shortint I  : I=999
If GREP<>"A" I=nolign : Endif
#----- Mise Ó jour fichiers Ó la ligne (Commande, Rķception, Retour) -----#
# Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
Gosub MAJ_FICHIERS_LIGNE From SUBPIHD             : If GOK<1 Return : Endif
#----- Mise Ó jour statistiques ligne facture -----#
Call VALSTA("PID",SIGN) From SUBPS2  : If GOK<1 Return : Endif
If TRTLIG="M"
  #----- Cas particulier o∙ l'on modifie le texte en le supprimant -----#
  If [M:PIH3]LINTEX(nolign-1)="" & left$([F:PID]LINTEX,3)="PID"
    Call SUP_CLOB([F:PID]LINTEX,GBIDI1) From TRTX3TEX
  Endif
  Return : # Si modif c'est fini !
Endif
#----- Avant Delete de la ligne de facture PID : Suppression texte ligne -----#
If left$([F:PID]LINTEX,3)="PID"
  Call SUP_CLOB([F:PID]LINTEX,GBIDI1) From TRTX3TEX
Endif
#----- Suppression comptes et sections de la ligne de facture -----#
Call ENREG_ACCCCE(0,"","","","PID",0,[F:PID]NUM,[F:PID]PIDLIN,0,"","A") From TRTX3CPT
If GOK<1  Return : Endif
#----- MÓj ligne facture vente si inter-sociķtķ -----#
If GMODU(5)=2 & [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>"" & [F:PID]SIDLIN<>0
  Update [SID] Where NUM=[M:PIH0]SIHNUM & SIDLIN=[F:PID]SIDLIN
&              With  PIDLIN=0
  If fstat  GOK=0 : Call FSTA("SID") From GLOCK : Return : Endif
Endif
Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par dķfaut et initialisations avant crķation #
#------------------------------------------------------#
GCUR=GLOCALDEV
Raz GPIH_QTEMAX
Call GETSOC(GFCYDEF(6)) From DEVSUB : [M:PIH0]FCY=GFINRSP
Call GETFCYDEF([M:PIH0]FCY,"[F:FCY]FINFLG=2 & [F:FCY]LEGCPY=GSOCIETE") From TRTX3
If GFCY<>[M:PIH0]FCY & [M:PIH0]FCY<>""
  GFCY=[M:PIH0]FCY : Gosub CHARG_PARAM : If OK=0  Return : Endif
Endif

# Issue 71069 - 2013-08-26 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

#----- Affichage entĻtes de colonne variables -----#
Gosub AFF_TITCOL
#----- Ecran PIH0 -----#
Actzo [PIH0]1-99
If GNBAUZ=1 & [M:PIH0]FCY<>""
  Diszo [PIH0]FCY  : # Saisie inutile si un seul site permis
Endif
[M:PIH0]ACCDAT=datesyst
[M:PIH0]CPYLAN=GLANGUE
Call AM_FCY([M:PIH0]FCY) From SUBPIH : # Chargement des paramĶtres
Default File [PIH]
Raz mkstat, GERR, GMESSAGE
Actzo [PIH0]PIVTYP, BPR, BPRSAC
If GPIH_FLGPAZ<>2
  [M:PIH0]PAZ=len(mess(0,510,1)) : Diszo [PIH0]PAZ
Else
  [M:PIH0]PAZ=1 : Actzo [PIH0]PAZ
Endif
If GPIHACCDAT=2 Actzo [PIH0]ACCDAT Else Diszo [PIH0]ACCDAT : Endif
Affzo [PIH0]1-99
If [M:PIH0]PIVTYP<>""
  #MAE, ajout LEG
  Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP,RET) From TRTLECLEG
  #Read [TPV] TPV0=[M:PIH0]PIVTYP
  If !RET Call AM_PIVTYP([M:PIH0]PIVTYP) From SUBPIH : Endif
Endif
#----- Ecran PIH1 -----#
Actzo [PIH1]1-99
[M:PIH1]BPRDAT=[M:PIH0]ACCDAT
#----- Ecran PIH3 -----#
Actzo [PIH3]1-99
[M:PIH3]PCLFLG=2 : # Indicateur prķchargement Ó "OUI"
If !GIMPORT
 Affzo [PIH3]CUMLINAMT1
Endif
#-----
Gosub GRIZO_ARG
#----- Ecran PIH4 -----#
Actzo [PIH4]1-99
Actzo [PIH4]TOTTAXAMT, DIFTAXAMT : Diszo [PIH4]AMTTAX
[M:PIH4]DSPWEU=GSALDSPWEU
[M:PIH4]DSPVOU=GSALDSPVOU
#----- Effacement du total HT ... etc -----#
Raz [M:PIH3]CUMLINAMT1, MONTMIN, MONTPRO
Raz [M:PCIW], [M:PCEZ]
Raz [M:AD66], [M:AD67] : # Effacement des masques adresses facture et rĶglement
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:PIH0]TEX1, [M:PIH0]TEX2, [M:PIH3]LINTEX
If !GIMPORT  Call RESET_IMAGE(4) From GESECRAN : Endif
#----- affectation des infos du fournisseur ------#
If [M:PIH0]BPR <> ""
    VALEUR = [M:PIH0]BPR
    Read [F:BPR]BPR0 = VALEUR
    Call AM_BPR(VALEUR) From SUBPIH
Endif
#----- Mise Ó jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif

#Enable 1099 controls depending on record                                      #1099.n
If GS1099 Call SUB_GRIZE_LIENS("PIH1") From TEN99LIB : Endif #1099.n pass screen if one

# Issue 71069 - 2013-08-26 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

#RMA * 85785
If dim([M:PIH0]ORIDOCNUM) > 0
  Chgfmt [M:PIH0]ORIDOCNUM With "-K:30X"
Endif

# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
If func AFNC.ACTIV("KSW")>0
  Gosub RAZCRE_PIH From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
Endif
Return

$RAZDUP
#----------- Duplication dķsactivķe !! -----------#
# Effacement entĻte : No FAC, indicateurs Ó "NON" #
# Effacement champs ligne : Indicateurs           #
#-------------------------------------------------#
Local Shortint I
# Issue 71069 - 2013-08-26 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

# Issue 71069 - 2013-08-26 by MUARN :PJT
# Code affaire Ó la ligne (Partie : rajout paramĶtre sociķtķ pour contr¶le documents mono-affaire)
#--Duplication avec paramĶtre Ó OUI => si le code affaire de la ligne est <> de celui de l'en-tĻte, on reprend l'en-tĻte
Call TRAITE_DUPLICATION("[M:PIH1]PJTH") From TRTPJT

Raz [M:PIH0]NUM, [M:PIH0]LIBPAZ, MONTMIN, MONTPRO
If GPIH_FLGPAZ<>2
  [M:PIH0]PAZ=len(mess(0,510,1)) : Diszo [PIH0]PAZ
Else
  [M:PIH0]PAZ=1 : Actzo [PIH0]PAZ
Endif
[M:PIH1]STA=1
#----- Gestion des textes entĻte et pied -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:PIH0]TEX1,3)="PIV"
  Call DUP_CLOB("PIV",[M:PIH0]TEX1,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PIH0]TEX1 : Endif
Endif
If left$([M:PIH0]TEX2,3)="PIV"
  Call DUP_CLOB("PIV",[M:PIH0]TEX2,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PIH0]TEX2 : Endif
Endif
#-----
For I=0 To [M:PIH3]NBLIG-1
    Raz [M:PIH3]CREFLG(I), [M:PIH3]UPDFLG(I)
    Raz [M:PIH3]FASREF(I)
    #----- Gestion des textes ligne -----#
    If left$([M:PIH3]LINTEX(I),3)="PID"
      Call DUP_CLOB("PID",[M:PIH3]LINTEX(I),WRET) From TRTX3TEX
      If WRET<1  Raz [M:PIH3]LINTEX(I) : Endif
    Endif
Next I
Actzo [PIH1]BPRPAY, STRDUDDAT, INVNUM, TOTTAXAMT1
Actzo [PIH4]TOTTAXAMT, DIFTAXAMT
Raz [M:PCIW]
#----- Mise Ó jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif

#Enable 1099 controls depending on record                                      #1099.n
If GS1099 Call SUB_GRIZE_LIENS("PIH1") From TEN99LIB : Endif #1099.n pass screen if one

Call NTSDUP([M:PIH0]BPR,"BPSNUM") From TRTNTSCTL   # supplier notes

# Issue 71069 - 2013-08-26 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")>0
  Gosub RAZDUP_PIH From SWIBVRLIB4
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub RAZDUP_PIH From SWIQRCLIB2 # angre X3-90379 QR-Code Swiss
Endif
# SAM 101378 END
Return

$LIENS
#--------------------------------------------#
# Chargement GFCY : Site de la facture       #
#            GCUR : Devise facture           #
# Rķcupķration des paramĶtres ACHATS, BUDGET #
#--------------------------------------------#
# Issue 89573 - 2013-04-24 by MUARN : apres crķation d'une facture raz des tables
Raz [F:PTH], [F:PTD], [F:POH], [F:POQ], [F:POP], [F:PIHB]
# Issue 71253 - 2012-05-15 by SR : Localisation portugaise et espagnole
#----- Relecture transaction si nķcessaire -----#
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If GFCY<>[F:PIH]FCY GFCY=[F:PIH]FCY
   Gosub CHARG_PARAM
Else
   If dim([M:PIH3]DCLEECNUM) > 0
      Gosub CHARG_FMTPOR From SUBPIHC
   Endif
Endif
GCUR=[F:PIH]CUR
[M:PIH3]WCUR =GCUR
[M:PIH4]CUR2 =GCUR
#----- Chargement des sections analytiques entĻte -----#
If dim([M:PIH1]NBAXE)>0
  Call CHARG_CCEH("PIH1","NBAXE","PIH") From TRTX3CPT
Endif
#--------------------------------------------------------------------#
# Lecture PINVOICEV  complķment entĻte facture et chargement ķcran   #
# Lecture BPSUPPLIER avec chargement libellķs/formats colonnes tarif #
# Lecture BPARTNER et chargement 1Ķre date d'ķchķance                #
#--------------------------------------------------------------------#
If GIMPORT
  If clalev([F:PIVZ])=0 Local File PINVOICEV [PIVZ] : Endif
  [F:PIVZ]=[F:PIV] : # Sauvegarde buffer PIV en import
Endif
Read [PIV] PIV0=[M:PIH0]NUM
If fstat Raz [F:PIV]
         GOK=0 :  Call RSTA("PIV",[M:PIH0]NUM) From GLOCK   : Return
Endif
[M:PIH0]=[F:PIV] : [M:PIH1]=[F:PIV] : [M:PIH3]=[F:PIV] : [M:PIH4]=[F:PIV]
# Issue 71253 - 2012-05-11 by SR : Localisation Espagnole avant la lecure du fournisseur
If dim([M:PIH1]SPACUSNAM) > 0 :
  Read [F:BPS]BPS0 = [M:PIH1]SPACUSBPR
  If !fstat :  [M:PIH1]SPACUSNAM = [F:BPS]BPSSHO : Endif
Endif
If [F:BPS]BPSNUM<>[M:PIH0]BPR
   Read [BPS] BPS0=[M:PIH0]BPR
   If fstat Raz [F:BPS]
            GOK=0 : Call RSTA("BPS",[M:PIH0]BPR) From GLOCK : Return
   Endif
   Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
   Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
Endif
If GPLISTC<>[F:BPS]PLISTC
   GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE  : Endif
Call FMTREM("PIH3",GCUR)            From TRTPRICE
If [F:BPR]BPRNUM<>[M:PIH0]BPR
   Read [BPR] BPR0=[M:PIH0]BPR
   If fstat Raz [F:BPR]
            GOK=0 : Call RSTA("BPR",[M:PIH0]BPR) From GLOCK : Return
   Endif
Endif
If GACTDEB=2
  If [F:TCY]CRY<>[F:BPR]CRY
    Read [TCY] TCY0=[F:BPR]CRY : If fstat Raz [F:TCY] : Endif
  Endif
  If GPIH_CPYCRY<>[F:BPR]CRY & [F:TCY]EECFLG=2
    GPIH_EECFLG=2
  Else
    GPIH_EECFLG=1
  Endif
Else
  GPIH_EECFLG=0
Endif
# Issue 82113 - 2012-05-25 by MUARN : mise Ó jour champ bon Ó payer pour tous types facture
#If [F:PIH]PIHTYP<3 Call FIRST_DUD(0) From SUBPIHC : Endif
Call FIRST_DUD(0) From SUBPIHC
#--------------------------------------------------------------------------#
# Chargement zones Ó partir des fichiers PINVOICE [PIH] et PINVOICEV [PIV] #
#--------------------------------------------------------------------------#
[M:PIH0]BPRNAM1   =[F:PIH]BPRNAM(0) : [M:PIH4]NBTAX     =[F:PIH]NBRTAX
[M:PIH1]TOTLINAMT1=[F:PIV]TOTLINAMT : [M:PIH1]TOTTAXAMT1=[F:PIV]TOTTAXAMT
#----- Chargement du type de rķgime taxe -----#
# 71937 : Multilķgislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PIH]VAC
#  Read [ADI] CODE=1;[F:PIH]VAC : If fstat Raz [F:ADI] : Endif
#Endif
#[M:PIH1]VACTYP=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[M:PIH1]VAC,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[M:PIH1]VACTYP=[F:TVB]REGVAC
# 71937 : Multilķgislation
#-----
If [M:PIH4]NBTAX>0
  Local Shortint I
  For I=0 To [M:PIH4]NBTAX-1
  #--CPO 71937 TVT et multi-lĶg
    #Read [TVT] TVT0=[M:PIH4]TAX(I) : If fstat Raz [F:TVT] : Endif
    Call LEC_TVT_LEG(GCURLEG,[M:PIH4]TAX(I),GRET) From TRTLECLEG
    If GRET : Raz [F:TVT] Endif
    #--/CPO
    Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(I)) From TRTX3TEX
  Next I
Endif
#----- Chargement des ķlķments de facturation et des taxes -----#
Call CHARG_ELEMENTS (8,[M:PIH0]NUM,"PIH4") From TRTACHELT1
Call CHARG_TAXES    (8,[M:PIH0]NUM,"PIH4") From TRTACHELT1
#----- Affichage entĻtes de colonne variables -----#
If !clalev([F:ADL])  Gosub AFF_TITCOL : Endif
#----- Activation ou dķsactivation de certains champs -----#
If [M:PIH1]STA=3
  Diszo [PIH0]FCY, PIVTYP, ACCDAT, BPR, BPRSAC, PAZ
  Diszo [PIH1]1-99
  If dim([M:PIH1]STRDATSVC)>0 & !GLOCITAPRE  Actzo [PIH1]STRDATSVC, ENDDATSVC : Endif
  Actzo [PIH1]DES
  # Issue 71253 - 2012-05-15 by SR : Localisation portugaise et espagnole
  If [F:PTR]SPTVACOD = 1
     If func AFNC.ACTIV("KSP")
       Actzo [M:PIH1]SPACUSDAT,SPACUS,SPACUSBPR
     Endif
  Endif
  If dim([M:PIH1]STRDATSVC)>0 & !GLOCITAPRE
    Actzo [PIH3]1-99
  Else
    Diszo [PIH3]1-99
  Endif
  Diszo [PIH4]5-10, TOTTAXAMT, TOTLINAMT
Else
  Actzo [PIH0]BPRSAC
  Actzo [PIH1]1-99
  If [M:PIH0]SIHNUM<>""
    Diszo [PIH1]BPRVCR
    If GLOCARGNUM & dim([M:PIH1]TYPVCR)>0
      Diszo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR
    Endif
  Else
    Actzo [PIH1]BPRVCR
    If dim([M:PIH1]TYPVCR)>0
      If GLOCARGNUM
        If [M:PIH1]TYPVCR+[M:PIH1]CLSVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR<>""
          Diszo [PIH1]BPRVCR
        Endif
      Else
        Grizo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR
      Endif
    Endif
  Endif
  Actzo [PIH1]BPRDAT, INVREF, DES
  Actzo [PIH1]STRDUDDAT, DEP, INVDTA1, INVDTAAMT1, TOTLINAMT1, STA
  If dim([M:PIH1]STRDATSVC)>0 & !GLOCITAPRE  Actzo [PIH1]STRDATSVC, ENDDATSVC : Endif
  If dim([M:PIH1]DAS2)>0
    If [F:BPS]DADFLG=2
      Actzo [PIH1]DAS2
    Else
      Diszo [PIH1]DAS2
    Endif
  Endif
  Diszo [PIH0]FCY, PIVTYP, BPR
  Actzo [PIH1]CUR
  If [M:PIH1]CUR<>GLOCALDEV
    Actzo [PIH1]CURTYP
  Else
    Diszo [PIH1]CURTYP
  Endif
  Actzo [PIH1]VAC
  #-----
  If dim([M:PIH3]CAI)>0
    If GLOCARGNUM
      Actzo [PIH3]2
    Else
      Grizo [PIH3]2
    Endif
  Endif
  # Issue 82703 - 2013-02-04 by SR : FCC
  Actzo [PIH3]3-99
  #-----
  Actzo [PIH4]5-10, TOTTAXAMT, TOTLINAMT
  If GPIH_FLGPAZ<>2
    Diszo [PIH0]PAZ
  Else
    If [M:PIH0]PIHTYP<3
      If clalev([F:AUS])<=0 Local File AUTILIS [AUS] : Endif
      If [F:AUS]USR<>GUSER
        Read [AUS]CODUSR=GUSER :  If fstat Raz [F:AUS] : Endif
      Endif
      #----- Pas de saisie si une seule valeur possible -----#
      Call PARAMUTIL("NIVBONPAYE",GBIDC3,"",GFCY) From SUBAUS
      If val(GBIDC3)<1  GBIDC3="1" : Endif
      If val(GBIDC3)=1  Diszo [PIH0]PAZ Else Actzo [PIH0]PAZ : Endif
    Else
      #----- Si avoir toutes les valeurs sont permises -----#
      Actzo [PIH0]PAZ
    Endif
  Endif
  If GPIHACCDAT=2 Actzo [PIH0]ACCDAT Else Diszo [PIH0]ACCDAT : Endif
  If [F:PIH]PIHTYP=3 Diszo [PIH1]INVNUM Else Grizo [PIH1]INVNUM : Endif
  Actzo [PIH1]PTE
  If dim([M:PIH1]ZPTE)>0 Actzo [PIH1]ZPTE : Endif
Endif
If [M:PIH1]VACTYP=4
  Raz [M:PIH1]TOTTAXAMT1, [M:PIH4]TOTTAXAMT, [M:PIH4]DIFTAXAMT
  Grizo [PIH1]TOTTAXAMT1 : Grizo [PIH4]TOTTAXAMT, DIFTAXAMT
Elsif [M:PIH1]STA<3
  Actzo [PIH1]TOTTAXAMT1 : Actzo [PIH4]TOTTAXAMT, DIFTAXAMT
Endif
#----- Lectures des ķchķances et chargement de MONTMIN et MONTPRO -----#
Call INFOECHE(2,[F:PIH]NUM,MONTMIN,MONTPRO) From SUBBIH
If [M:PIH1]STA<3
  If MONTPRO=0 Actzo [PIH1]BPRPAY Else Diszo [PIH1]BPRPAY : Endif
Endif
#----- Effacement des critĶres de sķlection (filtre picking) -----#
Raz [M:PCIW]
#----- Chargement des informations douaniĶres -----#
[M:PCEZ]=[F:PIH]
[M:PCEZ]WPOSCOD=[F:PIH]POSCOD
[M:PCEZ]WBPSNUM=[F:PIH]BPR
[M:PCEZ]WBPAADD=[F:PIH]BPAINV
[M:PCEZ]WCRY   =[F:PIH]CRY
#-----
[M:PIH1]EECICT2=[F:PIH]EECICT
[M:PIH1]ICTCTY2=[F:PIH]ICTCTY
#----- Chargement des zones cours devise -----#
If [F:PIH]RATDAT=[0/0/0]
  If GPIHCURDAT<>2
    [F:PIH]RATDAT=[F:PIH]ACCDAT : [M:PIH1]RATDAT=[M:PIH0]ACCDAT
  Else
    [F:PIH]RATDAT=[F:PIH]BPRDAT : [M:PIH1]RATDAT=[M:PIH1]BPRDAT
  Endif
Endif
Call CHARG_RATCUR("PIH1","PIH") From TRTX3CPT
#-----
If [M:PIH1]STA=3
  Diszo [PIH1]RAT1, RAT2
Endif
#----- Chargement de la classe [M:AD66] zones adresse fournisseur facturant -----#
If [F:PIH]CRY<>"" | [F:PIH]CTY<>""
  [M:AD66]       = [F:PIH]
  [M:AD66]ADBBPR = [F:PIH]BPR
  [M:AD66]BPAADD = [F:PIH]BPAINV
  [M:AD66]ADBFLG = 2
Else
  Raz [M:AD66]
  [M:AD66]BPAADD = [F:PIH]BPAINV
  [M:AD66]ADBBPR = [F:PIH]BPR
Endif
#----- Chargement de la classe [M:AD67] zones adresse fournisseur payķ -----#
If [F:PIH]BPYCRY<>"" | [F:PIH]BPYCTY<>""
  [M:AD67]BPAADD      = [F:PIH]BPAPAY
  [M:AD67]BPRNAM(0)   = [F:PIH]BPYNAM(0)
  [M:AD67]BPRNAM(1)   = [F:PIH]BPYNAM(1)
  [M:AD67]BPAADDLIG(0)= [F:PIH]BPYADDLIG(0)
  [M:AD67]BPAADDLIG(1)= [F:PIH]BPYADDLIG(1)
  [M:AD67]BPAADDLIG(2)= [F:PIH]BPYADDLIG(2)
  [M:AD67]CRY         = [F:PIH]BPYCRY
  [M:AD67]CRYNAM      = [F:PIH]BPYCRYNAM
  [M:AD67]SAT         = [F:PIH]BPYSAT
  [M:AD67]POSCOD      = [F:PIH]BPYPOSCOD
  [M:AD67]CTY         = [F:PIH]BPYCTY
  [M:AD67]ADBBPR      = [F:PIH]BPRPAY
  [M:AD67]ADBFLG      = 2
Else
  Raz [M:AD67]
  [M:AD67]BPAADD = [F:PIH]BPAPAY
  [M:AD67]ADBBPR = [F:PIH]BPRPAY
Endif
# Issue 87705 - 2013-02-15 by SR
[M:PIH1]MODADR = 1
#-----------------------#
# Chargement des lignes #
#-----------------------#
Raz [M:PIH3]CUMLINAMT1


Gosub LIENS From TABLEAUX

# Issue 71069 - 2013-08-26 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

#-----
If GFONC1="GESPIH"  Call RAZ_CLOB From ACLOB : Endif
If [M:PIH1]STA=3  GCONSDIA=2 Else GCONSDIA=0 : Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If ([M:PIH0]TEX1<>"" | [M:PIH0]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
#----- Restitution du buffer PIV en import -----#
If GIMPORT
  [F:PIV]=[F:PIVZ] : Close Local File [PIVZ]
Elsif !clalev([F:ADL])
  #----- Mise Ó jour des listes de gauche picking -----#
  Gosub TIROIR
Endif

#1099.sn
#Display 1099 fields depending on Site>company
If func AFNC.ACTIV("FEE") Call SHOWHIDE_DAS1099("PIH1")  From TEN99LIB : Endif

#Enable 1099 controls depending on record
If GS1099 Call SUB_GRIZE_LIENS("PIH1") From TEN99LIB : Endif
#1099.en

#Localisation Belge --str
If  func AFNC.ACTIV("KBE")
  Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,RET) From TRTLECLEG
  #Read [TPV]TPV0=[F:PIH]PIVTYP : If fstat : Raz [F:TPV] : Endif
  #if fstat=0
  If RET=0
    If !GIMPORT
      If [F:TPV]INVTYP=5
        Call DISPLAY_VCS("PIH1","",3,-1)  From INVVCSLIB :#--hide VCS field
      Else
        Call DISPLAY_VCS("PIH1",[F:BPR]CRY,[F:PIH]STA,0)  From INVVCSLIB
      Endif
    Else
      If ([F:TPV]INVTYP=5) or ([F:BPR]CRY<>"BE")
          Diszo [M:PIH1]BELVCS
      Else
          Actzo [M:PIH1]BELVCS
      Endif
    Endif
  Else
    Call DISPLAY_VCS("PIH1","",3,1)  From INVVCSLIB
    Diszo [M:PIH1]BELVCS
  Endif
Endif
#Localisation Belge --end

# Issue 83026 - 2012-08-02 by MUARN : early discount
Call DISPLAY_BASDEP From SUBPIHC

# Issue 84130 - 2013-01-21 by MUARN : landed cost - onglet cout du document
If GFONCTION = "GESPIH" & [M:PIH0]PIHTYP=1 & !GIMPORT
  Local Decimal WCOURS : WCOURS = 1
  If [M:PIH1]RAT1<>0  WCOURS=[M:PIH1]RAT2/[M:PIH1]RAT1 : Endif
  Call CSTDOC("PIH3","PIH4", [M:PIH0]NUM, 17, WCOURS) From STCLIB
Endif

# Issue 71069 - 2013-08-26 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PIH0]FCY,"[M:PIH3]PJT") From TRTPJT
Endif

Call FLD4041DIS([M:PIH1]VAC, [M:PIH0]PIVTYP) From SUBPIHD

If dim([M:PIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_PORIDOCNUM([M:PIH0]FCY,[M:PIH0]PIVTYP,"PIH0") From PORLEGLIB
Endif

If func AFNC.ACTIV("KSW")>0
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub LIENS_QRC From SWIQRCLIB2 # Bader X3-90379 QR-Code Swiss
Endif
Return

$VERIF_CRE
#--------------------------#
# Vķrification en crķation #
#--------------------------#
Gosub VERIF
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif
#----- Saisie adresse fournisseur divers si nķcessaire -----#
If OK=1 & BOUT="C" & [M:AD66]ADBFLG<>2
  If [F:BPS]BPSNUM<>[M:PIH0]BPR
    Read [BPS] BPS0=[M:PIH0]BPR : If fstat  Raz [F:BPS] : Endif
  Endif
  If [F:BPS]BPSTYP=3
    Local Char SAVACT(GLONACT) : SAVACT=GACTION
    Local Char VALBOUT(250) , PARBOUT(250)(1..20)
    PARBOUT(1) = [M:PIH0]BPR
    PARBOUT(2) = "AD66"
    PARBOUT(3) = "0"
    PARBOUT(4) = "248"
    PARBOUT(5) = "195"
    GACTION = "SAIADRBPR"
    Call SAISIE_CHAR(VALBOUT,PARBOUT,"IADB","TRTX3","XWIADB") From GSAISIE
    [M:PIH0]BPRNAM1=[M:AD66]BPRNAM(0)
    If !GIMPORT  Affzo [PIH0]BPRNAM1 : Endif
    Raz mkstat
    #----- Recopie adresse fournisseur facturant divers pour fournisseur payķ -----#
    If [M:PIH1]BPRPAY=[M:PIH0]BPR & [M:AD67]ADBFLG<>2
      [M:AD67]=[M:AD66]
    Endif
    GACTION=SAVACT
  Endif
Endif
Gosub PIH_VERIF_CRE From TWMLIB  # Three way matching
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif
Gosub VERIF From TEN99LIB    # 1099.n
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif

#RMA 85785
If func PORLEGLIB.DIGSIGNPIH([M:PIH0]FCY, "", [M:PIH0]PIVTYP)
  If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
  If [F:BPS]BPSNUM <> [M:PIH0]BPR
      Read [F:BPS]BPS0=VALEUR
      If fstat : Raz [F:BPS] : Endif
  Endif
  If [F:BPS]AUTINVCOD = ""
    GMESSAGE = mess(82,7711,1)
    GERR = 1 : OK = 0
  Endif
Endif
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP([M:PIH0]PIVTYP,"PIV",GMESSAGE) = 1
    OK = 0 : GERR = 1 : Return
  Endif
Endif

# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif

Return

$INICRE
#---------------------------#
# Chargement avant le Write #
#---------------------------#
Raz [F:PIV] : # Effacement entĻte complķment avant le chargement
#-----
Local Shortint OUVFICFLG
Local Integer  STAT,RET
Local Char     PIECE(GLONGTE), TRANSAC(max(GLONGAU,10)), JOURNAL(GLONJOU), CLEFIC(GLONGTE)
[F:PIH]ORIMOD=6 : [F:PIH]CPY=GSOCIETE
# Issue 109608 - 2015-07-23 by SR : ajouter l'abrķviation table devant SNS
If [M:PIH0]PIHTYP<3 [F:PIH]INVTYP=1 : [F:PIH]SNS=+1
               Else [F:PIH]INVTYP=2 : [F:PIH]SNS=-1 : Endif

# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGENTETE From SUBPIHD : Gosub CHARGENTBIS From SUBPIHD
#----- Initialisation des rķgimes et natures CEE -----#
#----- si un type de flux est dķfini pour les facts/avoirs achats, il donnera le Rķgime et la Nature CEE
#----- sinon ces informations seront reprises des piĶces d'origine
If GACTDEB=2 & GPIH_EECFLG=2 & [F:PIH]EECNAT="" & [F:PIH]EECSCH=""
  Call INICRE_EEC("PIH",GBIDI2,[F:PIH]EECNAT,[F:PIH]EECSCH,GBIDI3,GBIDC2,GBIDC3) From FUNDEBA
Endif
#----- Ouverture des fichiers si nķcessaire -----#
If clalev([F:GAU]) =0  Local File GAUTACE   [GAU]  : OUVFICFLG+=1  : Endif
If clalev([F:GAG]) =0  Local File GAUTACEF  [GAG]  : OUVFICFLG+=2  : Endif
If clalev([F:PIHB])=0  Local File PINVOICE  [PIHB] : OUVFICFLG+=4  : Endif
If clalev([F:ANM]) =0  Local File ACODNUM   [ANM]  : OUVFICFLG+=8  : Endif
If GMODU(2)=2 : # Si le module compta est prķsent !
  If clalev([F:JOU])=0 Local File GJOURNAL  [JOU]  : OUVFICFLG+=16 : Endif
Endif
#--- Rķcupķration code piĶce auto dans le paramķtrage type facture utilisateur ---#
#MAE, ajout LEG
Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,RET) From TRTLECLEG
#Read [TPV]TPV0=[F:PIH]PIVTYP :
If RET Raz [F:TPV] : Endif
If [F:TPV]COD<>""
  TRANSAC=[F:TPV]COD
  Read [GAU] GAU0=TRANSAC
  If fstat Raz TRANSAC : Endif
Endif
#--- Chargement code piĶce auto si pas renseignķ dans type facture utilisateur ---#
If TRANSAC=""
  Case [F:PIH]INVTYP
    When 1 : TRANSAC="PIHI"   : # Facture (Invoice)
    When 2 : TRANSAC="PIHC"   : # Avoir (Credit note)
             Read [GAU] GAU0=TRANSAC
             If fstat TRANSAC="PIHI" : Endif
  Endcase
Endif
#----- Evaluation du type de piĶce comptable Ó partir de la piĶce auto -----#
If [F:PIH]GTE=""
  Call EVALAUTO(TRANSAC,"GTE",PIECE) From SUBPIHA
Else
  Raz PIECE
Endif
#----- Contr¶le si le type de piĶce existe et est actif -----#
SUIZON="PIVTYP"
If PIECE<>"" CLEFIC=PIECE Else CLEFIC=[F:PIH]GTE : Endif
#VPO 07/02/11 71149 message un peu brutal
If CLEFIC=""
  GOK=0 : Raz [F:GTE] : GMESSAGE=mess(27,110,1) : GERR=1 : Goto FIN_INICRE
Else
#MAE, ajout LEG
Call LEC_GTE_LEG(GCURLEG,CLEFIC,RET) From TRTLECLEG
#Read [GTE] GTE0=CLEFIC
Endif
If RET=5
  GOK=0 : Raz [F:GTE] : GMESSAGE=CLEFIC-mess(17,114,1) : GERR=1 : Goto FIN_INICRE
Elsif RET
  GOK=0 : Raz [F:GTE] : Call RSTA("GTE",CLEFIC) From GLOCK : Goto FIN_INICRE
Elsif [F:GTE]ENAFLG=1
  GOK=0
  Raz [F:GTE] : GMESSAGE=CLEFIC-mess(274,199,1) : GERR=1 : Goto FIN_INICRE
Endif
#----- Contr¶le si le type de piĶce est rķel -----#
If [F:GTE]VCRREA<>2
  GOK=0 : GMESSAGE=[M:PIH0]GTE-mess(59,119,1) : GERR=1 : Goto FIN_INICRE
Endif
#----- Contr¶le si les droits d'exķcution existent -----#
If [F:GTE]ACS<>""
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If mkstat
    GOK=0 : GMESSAGE=[F:GTE]ACS-GMESSAGE : GERR=1 : Goto FIN_INICRE
  Endif
Endif
#----- Contr¶le date comptable par rapport aux dates bornes du type de piĶce -----#
If CLEFIC<>[F:PIH]GTE
  Call CTLVLYDAT([F:PIH]ACCDAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
  If mkstat
    GOK=0 : GMESSAGE=[F:GTE]TYP-GMESSAGE : GERR=1 : Raz GMESSAGE
    SUIZON="ACCDAT" : Goto FIN_INICRE
  Endif
  [F:PIH]GTE=CLEFIC : [M:PIH0]GTE=CLEFIC
Endif
#----- Rķcupķration du compteur et code manuel Ó partir du type de piĶce -----#
If [F:GTE]COU<>""
  GMANCOU=[F:GTE]MANNUM
  GCODNUM=[F:GTE]COU
Endif
#----- Rķcupķration du numķro interne -----#
Call ACCNUM([F:PIH]ACCNUM) From SUBGAS
#----- Le numķro de facture doit-il Ļtre saisi ? -----#
If GMANCOU=2 & GCODNUM=""
  GMESSAGE=mess(100,121,1) : GERR=1 : GOK=0 : Goto FIN_INICRE
Endif
#----- Evaluation code journal Ó partir de la piĶce auto -----#
JOURNAL=[F:PIH]JOU
If JOURNAL=""
  Call EVALAUTO(TRANSAC,"JOU",JOURNAL) From SUBPIHA
  If JOURNAL="" JOURNAL=[F:GTE]DEFJOU : Endif
  [F:PIH]JOU=JOURNAL : [M:PIH0]JOU=JOURNAL
Endif
#----- Si la table GJOURNAL est ouverte (module compta prķsent) -----#
If clalev([F:JOU])
  #----- Contr¶le si le journal existe et est actif -----#
  If JOURNAL<>[F:JOU]JOU
    #MAE, ajout LEG
    Call LEC_JOU_LEG(GCURLEG,JOURNAL,RET) From TRTLECLEG
    If RET
    #Read [JOU] JOU0=JOURNAL
    #If fstat
      Raz [F:JOU] : GOK=0 : Call RSTA("JOU",JOURNAL) From GLOCK : Goto FIN_INICRE
    Elsif [F:JOU]ENAFLG=1
      Raz [F:JOU]
      GOK=0 : GMESSAGE=JOURNAL-mess(281,199,1) : GERR=1 : Goto FIN_INICRE
    Endif
  Endif
  #----- Test si aucun journal trouvķ -----#
  If [F:JOU]JOU=""
    GOK=0 : GMESSAGE=JOURNAL-mess(53,141,1) : GERR=1 : Goto FIN_INICRE
  Endif
  #----- Contr¶le si les droits d'exķcution existent pour le journal -----#
  If [F:JOU]ACS<>""
    Call CONTEXE([F:JOU]ACS) From CPTSUB
    If mkstat
      GOK=0 : GMESSAGE=[F:JOU]ACS-GMESSAGE : GERR=1 : Goto FIN_INICRE
    Endif
  Endif
  #----- Contr¶le journal sur sociķtķ-site -----#
  If [F:JOU]FCY<>""
    Call VERSOC([F:JOU]FCY,[F:PIH]CPY,[F:PIH]FCY,[F:JOU]JOU) From CFYSUB
    If mkstat
      GOK=0 : SUIZON="FCY" : GERR=1 : GMESSAGE=mess(13,105,1)-GMESSAGE : Goto FIN_INICRE
    Endif
  Endif
  #----- Contr¶le si journal autorisķ sur le type de piĶce
  If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
    GOK=0 : GMESSAGE=[F:JOU]JOU-mess(8,106,1)-[F:GTE]TYP : GERR=1
    Goto FIN_INICRE
  Endif
Endif

#90370 Cash VAT SPA
Gosub CASH_VAT

#85785
If func PORLEGLIB.DIGSIGNPIH([M:PIH0]FCY, "",[M:PIH0]PIVTYP)
  If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
  If [F:BPS]BPSNUM <> [M:PIH0]BPR
    Read [F:BPS]BPSNUM = [M:PIH0]BPR
    If fstat : Raz [F:BPS] : Endif
  Endif
  [L]ANMCOMP = [F:BPS]AUTINVCOD
Else
  [L]ANMCOMP = JOURNAL
Endif

#----- Rķcupķration du compteur -----#
If GMANCOU<>2 | vireblc([M:PIH0]NUM,2)=""
  #85785
  #Call NUMERO(GCODNUM,GFCY,[M:PIH0]ACCDAT,JOURNAL,[M:PIH0]NUM,STAT) From SUBANM
  Call NUMERO(GCODNUM,GFCY,[M:PIH0]ACCDAT,ANMCOMP,[M:PIH0]NUM,STAT) From SUBANM
  If GOK<0
    Goto FIN_INICRE
  Elsif GOK<1 | STAT<>0
    #--CPO  68322/59141
    #GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Local Char MESSA(80)
    GMESSAGE=mess(60,199,1)-"("+GCODNUM+") : "
    Gosub MESSAGE From SUBANM
    GMESSAGE-=MESSA : GOK=0 : GERR=1
    #--/CPO 68322/59141
    Goto FIN_INICRE
  Endif
  [F:PIH]NUM=[M:PIH0]NUM

  #85785
  If func PORLEGLIB.DIGSIGNPIH("", [F:PIH]CPY,[M:PIH0]PIVTYP)
    # ----------------------------------------------------------- #
    # Digital signature                                           #
    # ----------------------------------------------------------- #
    If func AFNC.ACTIV("DKS")
      Local Char DKSORIG(4) : DKSORIG = "PIH0"
      Local Integer DKSRET : DKSRET  = 1
      Gosub DKS_INICRE_TRIGGER From DKSLIB
      If DKSRET = 0 | !GOK
        Call MESSAGE(GMESSAGE) From GESECRAN
        GOK = 0
        Return
      Endif
    Endif
    # ----------------------------------------------------------- #
  Endif

Endif
SUIZON=""
#----- Lecture compteur pour test si chronologie activķe -----#
If [F:ANM]CODNUM<>GCODNUM
  Read [ANM] ANM0=GCODNUM
  If fstat Call RSTA("ANM",GCODNUM) From GLOCK : GOK=0 : Goto FIN_INICRE : Endif
Endif
If [F:ANM]CTLCHR=2 Gosub CTRL_CHRONOLOGIE : Endif
If GOK<>1  Raz [M:PIH0]NUM : Endif

#--- Issue 84130 by TS : Landed cost
# Alimentation des totaux charges achat et stock d'une ligne facture
Gosub ALI_FCS
#---

# Issue 84130 - 2013-02-13 by MUARN : Calculer le CPR,etc... sur toutes les lignes
Call MAJ_REPART_LIG From SUBPIHC
# Issue X3-195220 - 2020-08-13 by SR : Load FIY and PER in creation mode
Gosub LOAD_FIY_PER

#----- Fermeture des fichiers si nķcessaire -----#
$FIN_INICRE
If OUVFICFLG>15 Close Local File [JOU]  : OUVFICFLG-=16 : Endif
If OUVFICFLG>7  Close Local File [ANM]  : OUVFICFLG-=8  : Endif
If OUVFICFLG>3  Close Local File [PIHB] : OUVFICFLG-=4  : Endif
If OUVFICFLG>1  Close Local File [GAG]  : OUVFICFLG-=2  : Endif
If OUVFICFLG>0  Close Local File [GAU]  : OUVFICFLG-=1  : Endif
Default File [PIH]
Return

#------------------------------------#
# Evaluation de la piĶce automatique #
#------------------------------------#
Subprog EVALAUTO(TRANSAC,ZONE,VALEUR)
Value    Char TRANSAC
Value    Char ZONE
Variable Char VALEUR
Raz VALEUR
[F:PIHB]=[F:PIH]
Read [GAG] GAG0=TRANSAC;0;ZONE
If !fstat
  Local Char PROG(GLONADC)
  PROG="WMGAU"+TRANSAC
  Onerrgo RIEN
  If clalev([F:TB0])=0 Local File PINVOICEV [TB0] : Endif
  [F:TB0]=[F:PIV]
  Gosub OUVRE From =PROG
  Gosub LIENS From =PROG
  [F:PIH]=[F:PIHB]
  VALEUR=evalue([F:GAG]FORCLC)
  Onerrgo
Endif
End
$RIEN
Resume

$CTRL_CHRONOLOGIE
#-------------------------------------------------------------------------#
# Contr¶le de la chronologie des numķros de facture par rapport aux dates #
#-------------------------------------------------------------------------#
Local Integer SEQ
Local Char    NUMFAC(GLONPIH) : NUMFAC=[F:PIH]NUM
Repeat
  #85785
  #Call NUMERO_PREC(GCODNUM,GFCY,[F:PIH]ACCDAT,JOURNAL,NUMFAC,SEQ,STAT) From SUBANM
  Call NUMERO_PREC(GCODNUM,GFCY,[F:PIH]ACCDAT,[L]ANMCOMP,NUMFAC,SEQ,STAT) From SUBANM
  If GOK<0
    Break
  Elsif GOK<1 | STAT<>0
    #--CPO  68322/59141
    #GOK=0 : GERR=1 : GMESSAGE=GCODNUM-NUMFAC-mess(60,199,1)
    Local Char MESSA(80)
    GMESSAGE=mess(60,199,1)-"("+GCODNUM-NUMFAC+") : "
    Gosub MESSAGE From SUBANM
    GMESSAGE-=MESSA : GOK=0 : GERR=1
    #--/CPO 68322/59141
    Break
  Endif
  If NUMFAC=[F:PIH]NUM  Break : Endif
  If SEQ>=1
    Read [PIHB] PIH0=NUMFAC
    If !fstat
      If [F:PIHB]ACCDAT>[F:PIH]ACCDAT
        GOK=0 : GMESSAGE=mess(101,121,1) : GERR=1
        SUIZON="ACCDAT"
      Endif
      SEQ=0
    Endif
  Endif
Until SEQ<=1
Return

$CREATION
#---------------------------------#
# AprĶs Write de l'entĻte facture #
#---------------------------------#
Local Decimal  WQTE, WMT, WQTEUOM, WQTE2
#----- Ecriture du complķment d'entĻte facture PINVOICEV [PIV] -----#
# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGENTBIS From SUBPIHD
#----- Crķation ou duplication des textes entĻte et pied -----#
Gosub CHARG_TEXT_ENTETE
#-----
If dim([F:PIV]CREDAT)>0 [F:PIV]CREDAT=date$  : Endif
If dim([F:PIV]CREUSR)>0 [F:PIV]CREUSR=GUSER  : Endif
Write [PIV]
If fstat GOK=0 : Call FSTA("PIV") From GLOCK : Goto ERR_CREATION : Endif
#----- Ecriture des ķlķments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(8,[M:PIH0]NUM,"PIH4","C") From TRTACHELT1
If GOK<1  Goto ERR_CREATION : Endif
#----- Ecriture du tableau des taxes -----#
Call ENREG_TAXES   (8,[M:PIH0]NUM,"PIH4","C") From TRTACHELT1
If GOK<1  Goto ERR_CREATION : Endif
#----- Crķation des lignes facture -----#
Gosub CREATION From TABLEAUX : If GOK<1 Goto ERR_CREATION : Endif
#---------------------------------------------------------------------------#
# Mises Ó jour : * Fichier "Mvts fournisseurs" BPSUPPMVT [MVS] (Facturant)  #
#                  "Facturķ non comptabilisķ" et "Date derniĶre facture"    #
#                * Fichier "EntĻte commande"   PORDER    [POH]              #
#                  "Mts facturķs des ķlķments de facturation"               #
#---------------------------------------------------------------------------#
SIGN=1 : Call MAJ_MVS_INVDTA(SIGN,0) From SUBPIHC : If GOK<1 Goto ERR_CREATION : Endif
#----- Mise Ó jour statistiques entĻte facture -----#
SIGN=1 : Call VALSTA("PIH",SIGN)     From SUBPS2  : If GOK<1 Goto ERR_CREATION : Endif
#----- Crķation des ķchķances initiales de la facture -----#
If [F:PIH]STA<3
  Call CREECHE(2,1,1,[F:PIH]PAZ) From SUBBIH : If GOK<1 Goto ERR_CREATION : Endif
  #----- Point d'entrķe CALECHE, permet d'intervenir sur les ķchķances crķķes -----#
  GPOINT="CALECHE" : Gosub ENTREE From EXEFNC
  If GOK<1  Goto ERR_CREATION : Endif
  #-----
  If [F:PIH]PIHTYP=1
    Call TRT_ACOMPTES(1,1,[F:PIH]AMTATI) From SUBPIHC : # Affectation des acomptes
    If GOK<1 Goto ERR_CREATION : Endif
  Endif
  If [F:PIH]PIHTYP<3
    Call FIRST_DUD(1) From SUBPIHC
  Endif
Endif

#----- MÓj entĻte facture vente si inter-sociķtķ -----#
If GMODU(5)=2 & [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>""
  Unlock="SIV"+[M:PIH0]SIHNUM
  Update [SIV] Where NUM=[M:PIH0]SIHNUM
&              With  PIHNUM=[F:PIH]NUM
  If fstat  GOK=0 : Call FSTA("SIV") From GLOCK : Goto ERR_CREATION : Endif
Endif
#----- Autres mise Ó jour ? -----#

# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
If func AFNC.ACTIV("KSW")>0
  Gosub CREATION_PIH_QRC From SWIQRCLIB2 # Bader X3-90379 QR-Code Swiss
Endif
Return
$ERR_CREATION
Raz [M:PIH0]NUM : Return

$APRES_CRE
#-----------------------------#
# Affichage numķro de facture #
#-----------------------------#
# GMESSAGE=mess(40,107,1)-[M:PIH0]NUM : GERR=2
If !GIMPORT  Affzo [PIH0]NUM : Endif
#----- Impression contr¶le facture -----#
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nķcessaire
   Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif

If [F:PTR]DOCFLG=2
   Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
   Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que crķation
   Call ETAT([F:PTR]DOCNAM,"GESPIH",TBPAR,TBVAL) From ETAT
   #----- Relecture pour maj flag imprimķ -----#
   If !GIMPORT
     Gosub RELIT  From GOBJSUB
   Else
     Gosub LIENS  From SUBPIHA
   Endif
   Return
#-------- Affichage icone texte --------#
Elsif !GIMPORT
  If ([M:PIH0]TEX1<>"" | [M:PIH0]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
#---------------------------------------#
Raz [M:PIH3]CUMLINAMT1

# Issue 84130 - 2013-04-25 by MUARN : liens de SUBPIHA au lieu de TABLEAUX
Gosub LIENS From SUBPIHA

# Issue 70985 - 2012-06-13 by MUARN : landed cost
If !GIMPORT Affzo [M:PIH3]CPR, CPRCOE, CPRAMT, LINAMTCPR, STCNUM, CSTPUR, LINCSTPUR : Endif

#----- Mise Ó jour des listes de gauche picking -----#
If !GIMPORT  Gosub TIROIR : Endif
Return

$AB_CREATION
#---------------------------------------#
# Abandon crķation aprĶs erreur systĶme #
#---------------------------------------#
Return

$AVANT_MOD
#-----------------------------------#
# AprĶs appui sur le bouton "Modif" #
#-----------------------------------#
If [F:PIH]NUM<>[M:PIH0]NUM
  Read [PIH] PIH0=[M:PIH0]NUM : If fstat Raz [F:PIH] : Endif
Endif
#----- Il faut permettre de modifier la pķriode de prestation -----#
If find(COUZON,"STRDATSVC","ENDDATSVC","NBLIG","STRDAT","ENDDAT")
  Return
Endif
#----- Il faut toujours permettre la modification de l'adresse et des commentaires -----#
If find(COUZON,"BPRNAM","BPAINV","BPAADDLIG","CRY","CRYNAM","SAT","POSCOD","CTY","DES")
  Return
Endif
# Issue 71253 - 2012-05-10 by SR : Localisation espagnole
#----- Relecture transaction si nķcessaire -----#
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If [F:PTR]SPTVACOD = 1
   If func AFNC.ACTIV("KSP")
       If find(COUZON,"SPACUSDAT","SPACUS","SPACUSBPR")
        Return
       Endif
   Endif
Endif
#----- Facture validķe, modification ou suppression interdite !
If [F:PIH]STA=3
  #----- Ne pas sortir le message aprĶs un tunnel sur le champ grisķ du fournisseur -----#
  If COUZON="NBFAC1" & status=75  OK=0 : Return : Endif
  GMESSAGE=mess(155,194,1) : GERR=1 : OK=0 : Return
Endif
Return

$VERIF_MOD
#------------------------------#
# Vķrification en modification #
#------------------------------#
Gosub VERIF
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif
Gosub PIH_VERIF_MOD From TWMLIB  # Three way matching
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif
Gosub VERIF From TEN99LIB    # 1099.n
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif

# Issue 110704 US5 - 2016-01-08 by BRBAN
If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP([M:PIH0]PIVTYP,"PIV",GMESSAGE) = 1
    OK = 0 : GERR = 1 : Return
  Endif
Endif
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If OK=0 : Return : Endif

Return

$AVANT_MODFIC
#--------------------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:PIH]            #
# Mises Ó jour : * Fichier "Mvts fournisseurs" BPSUPPMVT [MVS] (Facturant) #
#                  "Facturķ non comptabilisķ"                              #
#                * Fichier "EntĻte commande"   PORDER    [POH]             #
#                  "Mts facturķs des ķlķments de facturation"              #
# Soustraction statistiques entĻte facture avant modification              #
# Positionnement de l'indicateur MAJFAC pour la maj des ķchķances          #
#--------------------------------------------------------------------------#
Local Integer SIGN
SIGN=-1 : Call MAJ_MVS_INVDTA(SIGN,1)   From SUBPIHC : If GOK<1 Return : Endif
SIGN=-1 : Call VALSTA("PIH",SIGN)       From SUBPS2  : If GOK<1 Return : Endif
#----- Test des modifications effectuķes pour positionnement de MAJFAC ----#
# Issue 87705 - 2013-02-15 by SR : Ajouter le test sur MODADR
If [M:PIH1]STA>2
  MAJFAC=9 : # Ne rien faire si la facture est validķe !
Elsif [M:PIH0]BPR<>[F:PIH]BPR    | [M:PIH1]BPRPAY   <>[F:PIH]BPRPAY    |
&  [M:PIH0]BPRSAC<>[F:PIH]BPRSAC | [M:PIH1]CUR      <>[F:PIH]CUR       |
&  [M:PIH1]PTE   <>[F:PIH]PTE    | [M:PIH1]STRDUDDAT<>[F:PIH]STRDUDDAT |
&  [M:PIH0]FCY   <>[F:PIH]FCY    | [M:PIH0]PAZ      <>[F:PIH]PAZ       |
&  [M:PIH1]DEP   <>[F:PIH]DEP    | [M:PIH4]AMTATI   <>[F:PIH]AMTATI    |
&  ([M:PIH4]AMTATI<0 & [M:PIH0]PIHTYP<3) | [F:PIH]AMTATI=0 |
&  [M:PIH1]RATMLT(0)<>[F:PIH]RATMLT(0) | [M:PIH1]RATDIV(0)<>[F:PIH]RATDIV(0) |
&  [M:PIH1]MODADR=2
  MAJFAC=1
Elsif sum([M:PIH4]BASTAX)<>sum([F:PIH]BASTAX)  |
&   find(0,[M:PIH3]CREFLG(0..[M:PIH3]NBLIG-1))
  MAJFAC=0
Else
  MAJFAC=9
Endif
#----- Positionnement indicateur si date modifiķe -----#
If [M:PIH0]ACCDAT<>[F:PIH]ACCDAT MODDAT=1 Else MODDAT=0 : Endif
#----- Suppression des affectations d'acompte -----#
If [F:PIH]PIHTYP=1 & MAJFAC<>9
  Call TRT_ACOMPTES(-1,2,[F:PIH]AMTATI) From SUBPIHC : If GOK<1 Return : Endif
Endif
#----- Suppression des ķchķances de la facture si modif rubrique majeure -----#
If MAJFAC=1
  If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
  #----- ##DBA le 23/01/03 : Historisation des ķchķances supprimķes
  Local Char CRITSUPPR (250)
  CRITSUPPR="TYP='"+[F:PIH]GTE+"' & NUM='"+[F:PIH]NUM+"'"
  Call HISTOSUPPR (CRITSUPPR) From MODECHE : If GOK<1  Return : Endif
  Delete [DUD] Where TYP=[F:PIH]GTE & NUM=[F:PIH]NUM
  If fstat=1  GOK=-1 : GLOCK="$GACCDUDATE"-[F:PIH]GTE-[F:PIH]NUM : Return : Endif
Endif
#----- Cas particulier o∙ l'on modifie le texte en le supprimant -----#
If [M:PIH0]TEX1="" & left$([F:PIV]TEX1,3)="PIV"
  Call SUP_CLOB([F:PIV]TEX1,WRET) From TRTX3TEX
Endif
If [M:PIH0]TEX2="" & left$([F:PIV]TEX2,3)="PIV"
  Call SUP_CLOB([F:PIV]TEX2,WRET) From TRTX3TEX
Endif
Return

$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
Local Shortint OUVFICFLG
Local Char     TRANSAC(max(GLONGAU,10)), JOURNAL(GLONJOU)
Local Integer RET

# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGENTETE From SUBPIHD

#--- Issue 84130 by TS : Landed cost
# Alimentation des totaux charges achat et stock d'une ligne facture
Gosub ALI_FCS
#---

# Issue 84130 - 2013-02-13 by MUARN : Calculer le CPR,etc... sur toutes les lignes
Call MAJ_REPART_LIG From SUBPIHC
# Issue X3-39273 - 2017-08-10 by MUARN : gestion erreur
If GOK=0 : Goto FIN_INIMOD : Endif


#----- Si la date n'a pas ķtķ modifiķe alors c'est fini (pas de ctrl chrono) -----#
If MODDAT=0 Return : Endif
# Issue X3-195220 - 2020-08-13 by SR : Load FIY and PER in update mode if ACCDATE was modified
Gosub LOAD_FIY_PER
#----- Ouverture des fichiers si nķcessaire -----#
If clalev([F:GAU])=0  Local File GAUTACE   [GAU]  : OUVFICFLG+=1 : Endif
If clalev([F:GAG])=0  Local File GAUTACEF  [GAG]  : OUVFICFLG+=2 : Endif
If clalev([F:PIHB])=0 Local File PINVOICE  [PIHB] : OUVFICFLG+=4 : Endif
If clalev([F:ANM]) =0 Local File ACODNUM   [ANM]  : OUVFICFLG+=8 : Endif
#----- Rķcupķration code compteur -----#
If [F:TCA]MODULE<>6 | [F:TCA]CPY<>GSOCIETE
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    Raz [F:TCA] : GOK=0 : Call RSTA("TCA","6") From GLOCK : Goto FIN_INIMOD
  Endif
Endif
GMANCOU=[F:TCA]MANCOU([F:PIH]PIHTYP+6) : GCODNUM=[F:TCA]CODNUM([F:PIH]PIHTYP+6)
If [F:GTE]TYP<>[F:PIH]GTE
  #MAE, ajout LEG
  Call LEC_GTE_LEG(GCURLEG,[F:PIH]GTE,RET) From TRTLECLEG
  #Read [GTE] GTE0=[F:PIH]GTE :
  If RET Raz [F:GTE] : Endif
Endif
If [F:GTE]COU<>""
  GMANCOU=[F:GTE]MANNUM : GCODNUM=[F:GTE]COU
Endif
#----- Lecture compteur pour test si chronologie activķe -----#
If [F:ANM]CODNUM<>GCODNUM
  Read [ANM] ANM0=GCODNUM
  If fstat Call RSTA("ANM",GCODNUM) From GLOCK : GOK=0 : Goto FIN_INIMOD : Endif
Endif
#----- Si chronologie active, rķcupķration code piĶce auto et code journal -----#
If [F:ANM]CTLCHR=2
  If [F:TPV]PIVTYP<>[F:PIH]PIVTYP
    #MAE, ajout LEG
    Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,RET) From TRTLECLEG
    #Read [TPV] TPV0=[F:PIH]PIVTYP :
    If RET Raz [F:TPV] : Endif
  Endif
  If [F:TPV]COD<>""
    TRANSAC=[F:TPV]COD
    Read [GAU] GAU0=TRANSAC
    If fstat Raz TRANSAC : Endif
  Endif
  If TRANSAC=""
    Case [F:PIH]INVTYP
      When 1 : TRANSAC="PIHI"   : # Facture (Invoice)
      When 2 : TRANSAC="PIHC"   : # Avoir (Credit note)
               Read [GAU] GAU0=TRANSAC
               If fstat TRANSAC="PIHI" : Endif
    Endcase
  Endif
  JOURNAL=[F:PIH]JOU
  If JOURNAL=""
    Call EVALAUTO(TRANSAC,"JOU",JOURNAL) From SUBPIHA
    If JOURNAL="" JOURNAL=[F:GTE]DEFJOU : Endif
    [F:PIH]JOU=JOURNAL : [M:PIH0]JOU=JOURNAL
  Endif

  #85785
  If func PORLEGLIB.DIGSIGNPIH([M:PIH0]FCY, "",[M:PIH0]PIVTYP)
    If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
    If [F:BPS]BPSNUM <> [M:PIH0]BPR
      Read [F:BPS]BPSNUM = [M:PIH0]BPR
      If fstat : Raz [F:BPS] : Endif
    Endif
    [L]ANMCOMP = [F:BPS]AUTINVCOD
  Else
    [L]ANMCOMP = JOURNAL
  Endif
  Gosub CTRL_CHRONOLOGIE
Endif
#----- Fermeture des fichiers si nķcessaire -----#
$FIN_INIMOD
If OUVFICFLG>7 Close Local File [ANM]  : OUVFICFLG-=8 : Endif
If OUVFICFLG>3 Close Local File [PIHB] : OUVFICFLG-=4 : Endif
If OUVFICFLG>1 Close Local File [GAG]  : OUVFICFLG-=2 : Endif
If OUVFICFLG>0 Close Local File [GAU]  : OUVFICFLG-=1 : Endif
Default File [PIH]
Return

$MODIF
#-----------------------------------#
# AprĶs Rewrite de l'entĻte facture #
#-----------------------------------#
Local Decimal  WQTE, WMT, WQTEUOM, WQTE2
#----- Rķķcriture du complķment d'entĻte facture PINVOICEV [PIV] -----#
Readlock [PIV] PIV0=[M:PIH0]NUM
If fstat=1  GOK=-1 : GLOCK="$PINVOICEV"-[M:PIH0]NUM : Return
Elsif fstat GOK=0  : Call RSTA("PIV",[M:PIH0]NUM) From GLOCK : Return : Endif
# Issue 89349- 2013-10-29 by SR : Dķplacķ dans SUBPIHD
Gosub CHARGENTBIS From SUBPIHD
#----- Crķation ou duplication des textes entĻte et pied -----#
Gosub CHARG_TEXT_ENTETE
#-----
If dim([F:PIV]UPDDAT)>0 [F:PIV]UPDDAT=date$  : Endif
If dim([F:PIV]UPDUSR)>0 [F:PIV]UPDUSR=GUSER  : Endif
Rewrite [PIV] : If fstat GOK=0 : Call FSTA("PIV") From GLOCK : Return : Endif
#----- Ecriture des ķlķments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(8,[M:PIH0]NUM,"PIH4","M") From TRTACHELT1
If GOK<1  Return : Endif
#----- Ecriture du tableau des taxes -----#
Call ENREG_TAXES   (8,[M:PIH0]NUM,"PIH4","M") From TRTACHELT1
If GOK<1  Return : Endif
#----- Modification des lignes facture -----#
Gosub MODIF From TABLEAUX  : If GOK<1 Return : Endif
#---------------------------------------------------------------------------#
# Mises Ó jour : * Fichier "Mvts fournisseurs" BPSUPPMVT [MVS] (Facturant)  #
#                  "Facturķ non comptabilisķ" et "Date derniĶre facture"    #
#                * Fichier "EntĻte commande"   PORDER    [POH]              #
#                  "Mts facturķs des ķlķments de facturation"               #
#---------------------------------------------------------------------------#
SIGN=1 : Call MAJ_MVS_INVDTA(SIGN,0) From SUBPIHC : If GOK<1 Return : Endif
#----- Mise Ó jour statistiques entĻte facture -----#
SIGN=1 : Call VALSTA("PIH",SIGN)     From SUBPS2  : If GOK<1 Return : Endif
#----- Ajustement des ķchķances en fonction des modifications effectuķes -----#
If MAJFAC<>9
  If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
  Filter [DUD] Where TYP=[M:PIH0]GTE & NUM=[M:PIH0]NUM
  Read [DUD] DUD0 First : If fstat Raz [F:DUD] : Endif
  Filter [DUD]
  If [F:DUD]TYP="" & [F:DUD]NUM=""
    Call CREECHE(2,1,1,[F:PIH]PAZ) From SUBBIH : If GOK<1 Goto ERR_CREATION : Endif
    #----- Point d'entrķe CALECHE, permet d'intervenir sur les ķchķances crķķes -----#
    GPOINT="CALECHE" : Gosub ENTREE From EXEFNC
    If GOK<1  Goto ERR_CREATION : Endif
    #-----
    If [F:PIH]PIHTYP=1
      Call TRT_ACOMPTES(1,1,[F:PIH]AMTATI) From SUBPIHC : # Affectation des acomptes
      If GOK<1 Return : Endif
    Endif
  Else
    Call MODECHE(2,[F:PIH]NUM,[F:PIH]AMTATI,MAJFAC,OK) From SUBBIH
    If GOK<1 Return : Endif
    If [F:PIH]PIHTYP=1
      Call TRT_ACOMPTES(1,2,[F:PIH]AMTATI) From SUBPIHC : # Rķaffectation des acomptes
      If GOK<1 Return : Endif
    Endif
  Endif
  If [F:PIH]PIHTYP<3
    Call FIRST_DUD(1) From SUBPIHC
  Endif
Endif
#----- Rķajustement date comptable sur les lignes si nķcessaire -----#
If MODDAT<>0
  Update [PID] Where NUM=[F:PIH]NUM With ACCDAT=[F:PIH]ACCDAT
  If fstat  GOK=0 : Call FSTA("PID") From GLOCK : Endif
Endif

#90370 Cash VAT SPA
Gosub CASH_VAT

Gosub PIH_TWMSTA_CHK From TWMLIB
#----- Autres mise Ó jour ? -----#

# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
If func AFNC.ACTIV("KSW")>0
  Gosub MODIF_PIH_QRC From SWIQRCLIB2 # Bader X3-90379 QR-Code Swiss
Endif

#############################################################################
##INICIO: MODIFICACIONES PARA LOCALIZACIONES COMPRAS ARGENTINA             ##
##ARGENTINA: 27.07.2005 - Juan Pablo Mansilla                              ##
##Funcionalidad agregada para gestion de retenciones e impuestos internos  ##
##en la factura de proveedor                                               ##
#############################################################################
GPOINT="XPIHTAXARG" : Gosub ENTREE From EXEFNC
#############################################################################
##FIN: MODIFICACIONES PARA LOCALIZACIONES COMPRAS ARGENTINA                ##
##ARGENTINA: 27.07.2005                                                    ##
#############################################################################
#-----
Return

$APRES_MOD
#MAE, bg 77405
Gosub VERROU_HAE
#--------------------------------------------------------------------------#
# AprĶs modification : affichage indicateurs entĻte et rechargement lignes #
#--------------------------------------------------------------------------#
[M:PIH1]=[F:PIH] : If !GIMPORT Affzo [PIH1] : Endif
Raz [M:PIH3]CUMLINAMT1

# Issue 84130 - 2013-02-28 by MUARN : liens de SUBPIHA au lieu de TABLEAUX
Gosub LIENS From SUBPIHA

#----- Mise Ó jour des listes de gauche picking -----#
If !GIMPORT  Gosub TIROIR : Endif
Return

$AB_MODIF
#------------------------------------#
# Abandon modif aprĶs erreur systĶme #
#------------------------------------#
Return

$ABANDON
#----------------------------------------------------#
# Abandon crķation et modification par l'utilisateur #
#----------------------------------------------------#
Gosub DEVERROU_FAC From SUBPIHC
Gosub SUPPRESS_TEX From SUBPIHC
#MAE, bg 77405
Gosub DEVERROU_HAE
#----- Mise Ó jour des listes de gauche picking -----#
If GREP="C" & !GIMPORT & BOUT="A" Raz [M:PIH0] : Gosub TIROIR : Endif
Return

$VERF_ANU
#-----------------------------------#
# Contr¶les de suppression :        #
# Interdit si facture comptabilisķe #
#          si facture avec avoir ou #
#             fact. complķmentaire  #
#-----------------------------------#
If [F:PIH]STA=3
  GMESSAGE=mess(155,194,1) : GERR=1 : OK=0 : Return
Endif
# Issue X3-39273 - 2017-08-11 by MUARN : contr¶ler aussi pour les FCC
#If [F:PIH]PIHTYP=1
If [F:PIH]PIHTYP < 3
  Look [PID] PID1(2)=4;[F:PIH]NUM
  [G:PID]currind=1 : [G:PID]currlen=0 : # Rķinitialisation clķ par dķfaut
  #-- Des avoirs ou factures complķmentaires existent, suppression interdite ! --#
  If !fstat     GMESSAGE=mess(156,194,1) : GERR=1 : OK=0 : Return : Endif
Endif
#----- Lectures ķchķances et contr¶le MONTMIN pour autorisation suppression -----#
If [F:PIH]PIHTYP<3
  Local  Decimal  MONTMIN, MONTPRO
  Call INFOECHE(2,[F:PIH]NUM,MONTMIN,MONTPRO) From SUBBIH
# If MONTMIN<>0 GMESSAGE=mess(157,194,1) : GERR=1 : OK=0 : Return : Endif
  If MONTMIN<>0
     OK=2 : Call AVERTIR (mess(171,194,1),OK) From GESECRAN
     If OK=1 OK=0 Else OK=1 : Endif
  Endif
Endif
Return

$ANNULE
#---------------------------------------#
# Avant suppression de l'entĻte facture #
#---------------------------------------#
Local Decimal  WQTE, WMT, WQTEUOM, WQTE2
#---------------------------------------------------------------------------#
# Mises Ó jour : * Fichier "Mvts fournisseurs" BPSUPPMVT [MVS] (Facturant)  #
#                  "Facturķ non comptabilisķ" et "Date derniĶre facture"    #
#                * Fichier "EntĻte commande"   PORDER    [POH]              #
#                  "Mts facturķs des ķlķments de facturation"               #
#---------------------------------------------------------------------------#
SIGN=-1 : Call MAJ_MVS_INVDTA(SIGN,0) From SUBPIHC : If GOK<1 Return : Endif
#----- Soustraction statistiques entĻte facture -----#
SIGN=-1 : Call VALSTA("PIH",SIGN)     From SUBPS2  : If GOK<1 Return : Endif
#----- Suppression des affectations d'acompte -----#
If [F:PIH]PIHTYP=1
  Call TRT_ACOMPTES(-1,3,[F:PIH]AMTATI) From SUBPIHC
  If GOK<1 Return : Endif
Endif
#----- Suppression du complķment d'entĻte facture PINVOICEV [PIV] -----#
Readlock [PIV] PIV0=[M:PIH0]NUM
If fstat=1  GOK=-1 : GLOCK="$PINVOICEV"-[M:PIH0]NUM : Return
Elsif fstat GOK=0  : Call RSTA("PIV",[M:PIH0]NUM) From GLOCK : Return : Endif
Delete [PIV]
If fstat=1  GOK=-1 : GLOCK="$PINVOICEV"-[M:PIH0]NUM : Return : Endif
#----- Suppression ķlķments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(8,[M:PIH0]NUM,"PIH4","A") From TRTACHELT1
If GOK<1  Return : Endif
#----- Suppression du tableau des taxes -----#
Call ENREG_TAXES   (8,[M:PIH0]NUM,"PIH4","A") From TRTACHELT1
If GOK<1  Return : Endif
#-- Annulation lignes facture (Action VALLIG appelķe Ó chaque ligne avec SIGN=-1) --#
Gosub ANNULE From TABLEAUX : If GOK<1 Return : Endif
#----- Suppression des ķchķances de la facture -----#
If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
#----- ##DBA le 23/01/03 : Historisation des ķchķances supprimķes
Local Char CRITSUPPR (250)
CRITSUPPR="TYP='"+[M:PIH0]GTE+"' & NUM='"+[M:PIH0]NUM+"'"
Call HISTOSUPPR (CRITSUPPR) From MODECHE : If GOK<1  Return : Endif
Delete [DUD] Where TYP=[M:PIH0]GTE & NUM=[M:PIH0]NUM
If fstat=1  GOK=-1 : GLOCK="$GACCDUDATE"-[M:PIH0]GTE-[M:PIH0]NUM : Return : Endif
#----- Suppression des textes entĻte et pied -----#
If left$([F:PIV]TEX1,3)="PIV"
  Call SUP_CLOB([F:PIV]TEX1,GBIDI1) From TRTX3TEX
Endif
If left$([F:PIV]TEX2,3)="PIV"
  Call SUP_CLOB([F:PIV]TEX2,GBIDI1) From TRTX3TEX
Endif
#----- MÓj ligne facture vente si inter-sociķtķ -----#
If GMODU(5)=2 & [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>""
  Update [SIV] Where NUM=[M:PIH0]SIHNUM
&              With  PIHNUM=""
  If fstat  GOK=0 : Call FSTA("SIV") From GLOCK : Return : Endif
Endif

# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
If func AFNC.ACTIV("KSW")>0
  Gosub ANNULE_PIH_QRC From SWIQRCLIB2 # Bader X3-90379 QR-Code Swiss
Endif
Return

$AP_ANNULE
#-----------------------------------------#
# AprĶs annulation complĶte d'une facture #
#-----------------------------------------#
#----- Mise Ó jour des listes de gauche picking (reportķ en FIN_ACTION) -----#
#If !GIMPORT  Raz [M:PIH0] : Endif
Return

$FIN_ACTION
#--------------------#
# AprĶs toute action #
#--------------------#
If REPONSE=GSTAANU
  #----- Mise Ó jour des listes de gauche picking aprĶs une annulation -----#
  If !GIMPORT & [M:PIH0]FCY=""  Raz CRITERE : Gosub TIROIR : Endif
Endif

Case BOUT
 When "5" : # SAM 101378: Localization Switzerland, 2016-01-19 Bader
            If func AFNC.ACTIV("KSW")>0
              Gosub FIN_ACTION_PIH From SWIBVRLIB4
            Endif
            # SAM 101378 END
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
 When "6" : # X3-90379 : Localization Switzerland, 2018-05-25 Bader
            If func AFNC.ACTIV("KSW")>0
               Gosub FIN_ACTION_PIH From SWIQRCLIB2
            Endif
            # X3-90379 END
Endcase
Return

$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Raz GORITITCOL
#-----
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:AD66])  Close Local Mask [AD66] : Endif
If clalev([M:AD67])  Close Local Mask [AD67] : Endif
If clalev([M:PCEZ])  Close Local Mask [PCEZ] : Endif
#-----
If GFONC1="GESPIH"
  Raz GMENBOUT, GCONSDIA
Endif
#----- Effacement icone texte -----#
If !GIMPORT  Call RESET_IMAGE(4) From GESECRAN : Endif
GTUNCPT(10)=0 : # Effacement indicateur tunnel facture d'achats
#----- Suppression variables globales "noms des currbox" -----#
If dim(GBOXPI2)>0
  Kill GBOXPI2, GBOXPO1, GBOXPT1, GBOXPI1, GBOXPN1
Endif

# Issue 71253 - 2012-05-10 by SR : Localisation espagnole et portugaise
If dim(GPIH_SYMBOL2)>0
  Kill GPIH_SYMBOL2, GPIH_FLGPAZ, GPIH_CPYCRY, GPIH_EECFLG, GPIH_INDTAX, GPIH_PICK,
&      GPIH_QTEMAX,  GPIH_QTE,    GPIH_VERROU, GPIH_INDBASTAX, GPIH_FMTPER,GPIH_FMTKSP,
&      GPIH_FMTKPO
Endif
# Exigence 82615 : Lķgislation belge --str
# FQ122815  Ajout d'un suffixe aux variables globales GDCLFEES, GACVDAS, GACVBE281
If dim(GDCLFEES_PIH) >0 Then Kill GDCLFEES_PIH  : Endif
If dim(GACVDAS_PIH)  >0 Then Kill GACVDAS_PIH   : Endif
If dim(GACVBE281_PIH)>0 Then Kill GACVBE281_PIH : Endif
# Exigence 82615 : Lķgislation belge --end
# Issue 84130 - 2013-03-22 by SR : Landed cost
If dim(GOUVSTC)>0 & WCREOUVSTC = 1  Kill GOUVSTC  : Endif

  GCREFONC = 0 # FGR 18/02/2014 : X3SUIVI96940 on remet une valeur normale.

# Issue 71069 - 2016-06-20 by MUARN : simuler multi-affaire
Kill GUPDPJTSNGDOC

# Issue X3-70158 - 2018-01-09 by MUARN : TRTLIG Ó la place de GREP
Kill GPIH_TRTLIG

Return

$VERIF
# Issue 85961 - 2012-11-22 by SR
Local Char WVAL
# Issue 92978 - 2013-09-30 by SR
Local Char  WFCY(GLONFCY)
Local Integer PLAN # Issue X3-186012 - 2020-04-01 by MUARN : check account
Local Char    WACCOUNT(GLONGAC) # Issue X3-186012 - 2020-04-01 by MUARN : check account

#-----------------------------------------------#
# Vķrifications : Au moins une ligne, ...etc... #
#-----------------------------------------------#
Local Shortint RES
# VPO 07/12/10 69066 verifier valeur Condition de paiement, Code escompte, Regime de taxe
# VPO 01/03/11 71999 ameliorer message d'erreur
If [M:PIH1]PTE<>""
    #Call CONTROLE("TPT","",[M:PIH1]PTE,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~PTE")+'"\'+GMESSAGE : Return : Endif
    #-- X3Suivi 71937 : Donnķes par lķgislation pour le Conditions de paiement
    #--CPO 71937 01/08/2013 Suite dev review
    Call CONTTPT([M:PIH1]PTE,GCURLEG,'','',[M:PIH0]FCY,'','') From SUBTPT
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~PTE")+'"\'+GMESSAGE : Return : Endif
Endif
If [M:PIH1]DEP<>""
#--CPO 71937 TABDEPAGIO
mkstat=0
    #Call CONTROLE("TDA","!",[M:PIH1]DEP,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~DEP")+'"\'+GMESSAGE : Return : Endif
    Call CONTTDA([M:PIH1]DEP,GCURLEG,"PIH1","DEP",[M:PIH0]FCY,"","") From SUBTDA
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~DEP")+'"\'+GMESSAGE : Return : Endif
    #--/CPO
Endif
If [M:PIH1]VAC<>""
    mkstat=0
    # 71937 : Multilķgislation
    #Call CONTADI([M:PIH1]VAC,"1","") From SUBADI
    #If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~VAC")+'"\'+GMESSAGE : Return : Endif
    #Call CONTROLE("ADI","",[M:PIH1]VAC,"1",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~VAC")+'"\'+GMESSAGE : Return : Endif
    Call CONTTVB([M:PIH1]VAC,GCURLEG,"PIH1","VAC",[M:PIH0]FCY,"","") From SUBTVB
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PIH1~VAC")+'"\'+GMESSAGE : Return : Endif
    # 71937 : Multilķgislation
Endif
#---------
Call C_BPRVCR([M:PIH1]BPRVCR) From SUBPIH
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If mkstat :  GERR=1 : OK=0 : Return : Endif
# Issue 86043 - 2013-04-24 by MUARN : rendre cours devise obligatoire si inexistant dans la table cours devise
Call C_RAT2([M:PIH1]RAT2) From SUBPIH
# Issue 113936 - 2016-01-22 by SR : Tester le code retour
If mkstat :  GERR=1 : OK=0 : Return : Endif

# Issue 104316 - 2014-12-01 by MUARN : contr¶le nombre ķlķments facturation rķpartis
Local Integer WNBFAC
Local Char    TRANSAC(max(GLONGAU,10))
Local Integer WRET
WNBFAC = sigma(I=0,[M:PIH4]NBFAC-1,([M:PIH4]INVLINFLG(I)>1 & [M:PIH4]INVLINFLG(I)<6 ) & [M:PIH4]INVDTAAMT(I)<>0)
Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG
If WRET Raz [F:TPV] : Endif
TRANSAC=[F:TPV]COD
If WNBFAC>9 & (TRANSAC = "PIHI2" | TRANSAC = "PIHI3")
  GMESSAGE=mess(478,194,1)-mess(479,194,1)
  GERR=1 : OK=0 : Return
Elsif WNBFAC>9
  GMESSAGE = mess(478,194,1)
  If !GIMPORT GMESSAGE -= '\' + mess(205,100,1) : Endif
  WRET=2 : Call AVERTIR(GMESSAGE,WRET) From GESECRAN
  If WRET<>2
    WRET=3 : OK=0 : Return
  Else
    Raz GMESSAGE
  Endif
Endif

If mkstat  OK=0 : Return : Endif
If dim(I)<0  Local Shortint I : Endif
If GIMPORT
  # Issue 111573 - 2015-11-16 by SR : Initialiser NBFAC
  [M:PIH4]NBFAC=[M:PIH1]NBFAC1
  #---- Si import : MÓj bases taxables et calcul taxes ķlķments facturation -----#
  If [M:PIH3]CLCFLG=2
    For I=0 To [M:PIH1]NBFAC1-1
      Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
      Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
    Next I
    If GPIHCALTAX=2
      For GPIH_INDTAX=1 To [M:PIH4]NBTAX
        Gosub CAL_TAXE_GLOB From SUBPIHB
      Next GPIH_INDTAX
    Endif
  Endif
  If [F:BPS]BPSNUM<>[M:PIH0]BPR
    Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
  Endif
  If [M:PIH3]NBLIG>0 & [F:BPS]DUDCLC=1 & ([M:PIH3]CLCFLG=2 | [M:PIH1]STRDUDDAT=[0/0/0])
    For I=0 To [M:PIH3]NBLIG-1
      If [M:PIH3]TYPORI(I)=2 &
&       ([M:PIH1]STRDUDDAT=[0/0/0] | [M:PIH1]STRDUDDAT>[M:PIH3]RCPDAT(I))
        [M:PIH1]STRDUDDAT=[M:PIH3]RCPDAT(I)
      Endif
    Next I
    If [M:PIH1]STRDUDDAT=[0/0/0] [M:PIH1]STRDUDDAT=[M:PIH0]ACCDAT : Endif
  Endif
  Raz [M:PIH3]CLCFLG
  [M:PIH4]AMTATI=sum([M:PIH4]INVDTAAMT)+[M:PIH4]TOTLINAMT+[M:PIH4]TOTTAXAMT
  # Issue X3-189678-X3-192381 - 2020-05-1ķ by SR : New-Purchase-entry-points-for-Uruguay-legislation
  If (GSAMETP = [V]CST_AYES) Then
    GPOINT = "CALTAXAMT" : Gosub ENTREE From EXEFNC
  Endif
  # End issue X3-189678-X3-192381
Else
  Gosub TEST_VALID From SUBPIH
Endif
# Issue 88312 - 2013-02-28 by SR

SAVNOLIGN = nolign
#----- Test au moins une ligne -----#
If [M:PIH3]NBLIG=0
   GMESSAGE=mess(61,199,1)  : GERR=1 : OK=0 : Goto RETOURNBLIG
# Issue 85961 - 2012-11-22 by SR
Else
  For I=0 To [M:PIH3]NBLIG-1
    # Issue X3-186012 - 2020-04-01 by MUARN : check account
    nolign = I+1
    For PLAN = 1 To 10
      WACCOUNT = evalue("[M:PIH3]LINACC"+num$(PLAN)+"("+num$(I) +")")
      Call CTRL_ACC(WACCOUNT,PLAN,GFINRSP,[M:PIH0]ACCDAT,[M:PIH1]CUR,"[M:PIH3]LINACC") From TRTX3CPT
      If mkstat
        GERR = 1
        GMESSAGE -= mess(18,197,1) - num$(I+1)
        OK = 0
        Break 2
      Endif
    Next
    # End issue X3-186012
    # Issue 88312 - 2013-02-28 by SR
    nolign = I+1
    # Issue 92978 - 2013-09-30 by SR : PE permettant de choisir le site Ó utiliser
    WFCY = GFINRSP :    GPOINT = "CHGACCFCY" : Gosub ENTREE From EXEFNC
    # Issue 87812 - 2013-02-08 by SR : Utiliser GNBDIE et pas GOPTCANA et vķrifier si les axes sont saisissables
    For J = 1 To GNBDIE
      WVAL = evalue("[M:PIH3]CCE"+num$(J)+"("+num$(I) +")")
      Call SAIS_CCE(WVAL,J,"[M:PIH3]LINACC","[M:PIH3]LINDSP") From TRTX3CPT
      If !mkstat
        # Issue 92978 - 2013-09-30 by SR : Passer WFCY au lieu de GFINRSP
        Call CTRL_CCE(WVAL,J,"[M:PIH3]LINACC",WFCY,[M:PIH0]ACCDAT) From TRTX3CPT
        If GIMPORT & mkstat
          GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:PIH3]ITMREF(nolign-1)
          #----- Simple warning si migration Intķgrale -----#
          If clalev([F:XEPA]) & clalev([F:XLPA])
            Call ECR_TRACE(GMESSAGE,-1) From GESECRAN : Raz GMESSAGE, mkstat
          Else
            GERR = 1
            GMESSAGE -= mess(18,197,1) - num$(I+1)
            OK = 0
            Break 2
          Endif
        Else
          If GMESSAGE <> ""
            GERR = 1
            GMESSAGE -= mess(18,197,1) - num$(I+1)
            OK = 0
            Break 2
          Endif
        Endif
      Endif
      # Issue 95966 - 2014-01-20 by SR
      Raz mkstat
      # Issue 106269 - 2015-02-13 by MUARN : contr¶le axes invisibles et duplication
      Call CTLCCE(WVAL,GDIE(J),GFINRSP,[M:PIH0]ACCDAT,nolign-1,
&         "GDIE(1","[M:PIH3]CCE#","GCOA(1","[M:PIH3]LINACC#") From SELCCE
      If mkstat : Raz mkstat : OK=0 : GERR=1 : Break 2 : Endif
    Next
  Next
  #-----
Endif

# Issue X3-141352 - 2019-06-05 by MUARN : check for invoicing element
If OK <> 0 & [M:PIH4]NBFAC > 0
  For I=0 To [M:PIH4]NBFAC-1
    # Issue X3-186012 - 2020-04-01 by MUARN : check account
    nolign = I+1
    For PLAN = 1 To 10
      WACCOUNT = evalue("[M:PIH4]ACC"+num$(PLAN)+"("+num$(I) +")")
      Call CTRL_ACC(WACCOUNT,PLAN,GFINRSP,[M:PIH0]ACCDAT,[M:PIH1]CUR,"[M:PIH4]ACC") From TRTX3CPT
      If mkstat
        GERR = 1
        GMESSAGE -= "-"-mess(523,197,1)-num$([M:PIH4]INVDTA(I))-[M:PIH4]INVDTALIB(I)
        OK = 0
        Break 2
      Endif
    Next
    # End issue X3-186012
    nolign = I+1
    For J = 1 To GNBDIE
      WVAL = evalue("[M:PIH4]PFICCE"+num$(J)+"("+num$(I) +")")
      # Issue X3-221393 - 2020-11-05 by MUARN : mandatory dimension and analytical distribution
      #Call SAIS_CCE(WVAL,J,"[M:PIH4]ACC","") From TRTX3CPT
      Call SAIS_CCE(WVAL,J,"[M:PIH4]ACC","[M:PIH4]DSP") From TRTX3CPT
      If !mkstat
        Call CTRL_PFICCE(WVAL,J,"[M:PIH4]ACC",GFINRSP,[M:PIH0]ACCDAT) From TRTX3CPT
        If GMESSAGE <> ""
          GERR = 1
          GMESSAGE-="-"-mess(523,197,1)-num$([M:PIH4]INVDTA(I))-[M:PIH4]INVDTALIB(I)
          OK = 0
          Break 2
        Endif
      Endif
      # contr¶le axes invisibles et duplication
      Raz mkstat
      # Issue X3-168797 - 2019-11-08 by MUARN : pour le contr¶le des enveloppes/budgets si axes invisibles
      # Call CTRL_PFICCE(WVAL,J,"[M:PIH4]ACC",GFINRSP,[M:PIH0]ACCDAT) From TRTX3CPT
      Call CTLCCE(WVAL,GDIE(J),GFINRSP,[M:PIH0]ACCDAT,nolign-1,
&       "GDIE(1","[M:PIH4]PFICCE#","GCOA(1","[M:PIH4]ACC#") From SELCCE
      If mkstat : Raz mkstat : OK=0 : GERR=1 : Break 2 : Endif
    Next
  Next I
Endif

# Issue 88312 - 2013-02-28 by SR
nolign = SAVNOLIGN
If OK = 0 : Goto RETOURNBLIG : Endif


# Issue X3-190041 - 20200506 by LD
# Analytical dimension control for the header and for the lines
Gosub VERIF_CTL_ALLCCE
If OK=0 : GERR=1 : Return : Endif
# End issue X3-190041 - 20200506 by LD

#----- Si SIVNULL=2 (interdiction crķation piĶce Ó zķro) -----#
If !GIMPORT & GSIVNULL=2 & [M:PIH4]AMTATI=0 & [M:PIH4]DIFAMTATI=0
   GMESSAGE=mess(277,199,1) : GERR=1 : OK=0 : Goto RETOURNBLIG
Endif
#----- Mise Ó jour et affichage statut de la facture par sķcuritķ -----#
If (!GIMPORT | dim(GPIH_WCOD)>0) & [M:PIH1]STA<>3
  If [M:PIH4]DIFTAXAMT<>0 | [M:PIH4]DIFLINAMT<>0 |
&    [M:PIH4]DIFAMTATI<>0 | sum([M:PIH4]INVDIFAMT)<>0 [M:PIH1]STA=1
                                                 Else [M:PIH1]STA=2 : Endif
  If !GIMPORT  Affzo [PIH1]STA : Endif
Endif
#----- Contr¶le pķriodes de prestation des lignes -----#
If dim([M:PIH1]STRDATSVC)>0
  For I=0 To [M:PIH3]NBLIG-1
    If [M:PIH3]ENDDAT(I)<[M:PIH3]STRDAT(I)
      GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(178,107,1)
      GMESSAGE-="("+mess(2,132,1) -format$(GFMD,[M:PIH3]STRDAT(I))
      GMESSAGE-=mess(95,100,1)-format$(GFMD,[M:PIH3]ENDDAT(I))+")"
      GERR=1 : OK=0 : Break
    Endif
  Next
  If GERR=1 & OK=0  Goto RETOURNBLIG : Endif
Endif
#----- Autres contr¶les -----#

# Issue 71069 - 2013-08-26 by MUARN : PJT
Call PJT_CONTROLE_HEAD_DETAIL("[M:PIH1]PJTH", "[M:PIH3]PJT") From TRTPJT
If GERR <> 0
  OK = 0
  Return
Endif

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If func AFNC.ACTIV("KPO")
  If GCURLEG ="POR" & !func PORLEGLIB.CONT_DATETIME(GREP,GFONCTION) : OK = 0 : GERR = 1 : Return : Endif
  #85785 * RMA * document amount cannot be negative
  If func PORLEGLIB.DIGSIGNPIH([M:PIH0]FCY, "", [M:PIH0]PIVTYP) & ([M:PIH4]AMTATI<0)
    GERR = 1: GMESSAGE = mess(216,191,1) : OK = 0 : Return
  Endif

  If func PORLEGLIB.PORLEG([M:PIH0]FCY,"")=1 #& func PORLEGLIB.DIGSIGNPIH([M:PIH0]FCY, "", [M:PIH0]PIVTYP)
    Local Integer WRET
    Call LEC_TPV_LEG([F:CPY]LEG,[M:PIH0]PIVTYP,WRET) From TRTLECLEG
    If find([F:TPV]RECTYP, 2, 3)
      WRET = 1
      Filter [F:PIHB] Where [F:PIHB]ORIDOCNUM <> "" & [F:PIHB]ORIDOCNUM = [M:PIH0]ORIDOCNUM & [F:PIHB]NUM <> [M:PIH0]NUM &
&                           [F:PIHB]PIVTYP = [M:PIH0]PIVTYP & year([F:PIHB]ACCDAT) = year([M:PIH0]ACCDAT)
      Read [F:PIHB] First
      If !fstat : WRET = 0 : Endif
      Filter [F:PIHB]
      If WRET = 0
        Call ERREUR (func AFNC.MES1(mess(89,7711,1),[F:PIHB]NUM)) From GESECRAN
        OK = 0
        Return
      Endif
    Endif
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")>0
  Gosub VERIF_PIH From SWIBVRLIB4
  If OK = 0 : Return : Endif
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
  Gosub VERIF_PIH From SWIQRCLIB2    # X3-90417 CH QR bill - Suppl inv - Implement QR bill payment method 2018-06-06 Bader
  If OK = 0 : Return : Endif
Endif
# SAM 101378 END
Return

#----- Retour Ó la saisie (des lignes) -----#
$RETOURNBLIG
# If MA<>2 MA=2 : Gosub AFFMASK From GOBJET : If !GIMPORT Affzo [M] : Endif : Endif
# If !GIMPORT SUIZON="NBLIG" : Endif
OK=0
Return

####################################################################
# Issue X3-190041 - 20200506 by LD
# Analytical dimension control for the header and for the lines
$VERIF_CTL_ALLCCE
Local Integer NE
Local Char SAXECTRL(GLONCCE)

# Analytical dimension control for the header
# We do nothing in import mode not to change the behavior
If !GIMPORT
  If dim([M:PIH1]CCE)>0
    # Issue X3-230999 - 20210114 by LD
    #For I = 0 To GNBDIE
    For I = 0 To GNBDIE-1
    # Issue X3-230999 - 20210114 by LD
      # Control all the header analytical dimension are fed  (if they are enterable)
      If GHEADIE = 1 : # Analytical dimension enterable (Init by GETCPY)
        If [M:PIH1]CCE(I)="" & GOBLDIE(I+1)=2
           OK=0 : GMESSAGE=mess(177,199,1) : Break
        Endif
      Endif
      # Control all the header analytical dimension are ok
      # In import mode it has been already done with the action C_ on the field
      # In interactive mode it has been done with the action C_ on the field but
      # In interactive mode it has not been done when picking a sales invoice and
      # In interactive mode it has not been done in duplication
      If [M:PIH1]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M:PIH1]CCE(I)) From W2PIH1
        If mkstat OK = 0 : Break Endif
      Endif
    Next
    If OK = 0 Return Endif
  Endif
Endif

