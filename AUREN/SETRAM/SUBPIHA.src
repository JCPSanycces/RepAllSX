# End issue X3-190041 - 20200506 by LD

#--- Issue 84130 by TS : Landed cost
# Alimentation des totaux charges achat et stock d'une ligne facture
$ALI_FCS
Local Integer NOL
Local Decimal WQTYPUU
For NOL=0 To [M:PIH3]NBLIG-1
  If [M:PIH0]PIHTYP=1
    Case [M:PIH3]TYPORI(NOL)
      When 1 : Gosub ORI_POQ
      When 2 : Gosub ORI_PTD
    Endcase
    # Alimentation de [M:PIH3] car le $MAJ_REPART_LIG travaille en classe [M]
    If [M:PIH3]TYPORI(NOL)<3
      [M:PIH3]FCSCSTPUR(NOL) = [F:PID]FCSCSTPUR
      [M:PIH3]FCSCPR(NOL)    = [F:PID]FCSCPR
    Endif
    If GOK=0 Return Endif
  Endif
Next NOL
Return

#--- Issue 84130 by TS : Landed cost
# L'origine de la facture est une commande
$ORI_POQ
If [F:POQ]POHNUM<>[M:PIH3]NUMORI(NOL)|[F:POQ]POPLIN<>[M:PIH3]LINORI(NOL)|
&  [F:POQ]POQSEQ<>[M:PIH3]SEQORI(NOL)
  Read [POQ]POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
  If fstat
    Call RSTA("POQ",[M:PIH3]NUMORI(NOL)+num$([M:PIH3]LINORI(NOL))+num$([M:PIH3]SEQORI(NOL))) From GLOCK
    GOK=0 : Return
  Elsif [F:POQ]STCNUM=""
    [F:PID]FCSCSTPUR = 0
    [F:PID]FCSCPR    = 0
    Return
  Endif
Endif

#--- Issue 97487
If ACTION="INIMOD"
  # Qtķ facturķe de la rķception Ó dķduire de la qtķ rcp pour calcul CA rķalisķ
  Local Decimal WINVQTY
  # Quantitķ facturķe de la commande Ó dķduire des rķceptions
  Local Decimal WQTYADED

 # Calcul de la quantitķ facturķe de la commande Ó dķduire des rķceptions
  WQTYADED = [F:POQ]INVQTYPUU-[F:PID]QTYPUU

  # Recherche des rķceptions de la commande
  Filter [PTD] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                    POQSEQ=[F:POQ]POQSEQ
&              Order By Key PTD2
  [F:PID]FCSCSTPUR = 0
  [F:PID]FCSCPR    = 0
  # La qtķ Ó traiter est le min des quantitķs commandķes et facturķes
  WQTYPUU = min([M:PIH3]QTYPUU(NOL),[F:POQ]QTYPUU)

  For [PTD]
    # La qtķ facturķe sur la rķception est nulle
    If [F:PTD]INVQTYPUU = 0
      WINVQTY   = 0
    # La qtķ Ó dķduire est > Ó la qtķ facturķe sur la rķception
    # on dķduira cette qtķ facturķe
    Elsif WQTYADED > [F:PTD]INVQTYPUU
      WINVQTY   = [F:PTD]INVQTYPUU
      WQTYADED -= [F:PTD]INVQTYPUU
    # La qtķ facturķe sur la rķception est > Ó la qtķ Ó dķduire
    # on dķduira cette la qtķ Ó dķduire
    Else
      WINVQTY   = WQTYADED
      WQTYADED  = 0
    Endif

    # Si la quantitķ Ó traiter est > Ó la quantitķ restant Ó facturer
    If WQTYPUU>[F:PTD]QTYPUU-WINVQTY
      [F:PID]FCSCSTPUR += [F:PTD]FCSCSTPUR*([F:PTD]QTYPUU-WINVQTY)/[F:PTD]QTYPUU
      [F:PID]FCSCPR    += [F:PTD]FCSCPR   *([F:PTD]QTYPUU-WINVQTY)/[F:PTD]QTYPUU
      WQTYPUU -= [F:PTD]QTYPUU-WINVQTY
    Else
      [F:PID]FCSCSTPUR += [F:PTD]FCSCSTPUR*WQTYPUU/[F:PTD]QTYPUU
      [F:PID]FCSCPR    += [F:PTD]FCSCPR*WQTYPUU/[F:PTD]QTYPUU
      WQTYPUU = 0
      Break
    Endif
  Next
  Filter [PTD]
Else
#---

  # Recherche des rķceptions non facturķes de la commande
  Filter [PTD] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                    POQSEQ=[F:POQ]POQSEQ & LININVFLG<>2
&              Order By Key PTD2
  [F:PID]FCSCSTPUR = 0
  [F:PID]FCSCPR    = 0
  # La quantitķ Ó traiter est le min des quantitķs commandķes et facturķes
  WQTYPUU = min([M:PIH3]QTYPUU(NOL),[F:POQ]QTYPUU)
  For [PTD]
  #--- Issue 95710
    # Si la quantitķ Ó traiter est > Ó la quantitķ restant Ó facturer
    If WQTYPUU>[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
      [F:PID]FCSCSTPUR += [F:PTD]FCSCSTPUR*([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)/[F:PTD]QTYPUU
      [F:PID]FCSCPR    += [F:PTD]FCSCPR*([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)/[F:PTD]QTYPUU
      WQTYPUU -= [F:PTD]QTYPUU-[F:PTD]INVQTYPUU
    Else
      [F:PID]FCSCSTPUR += [F:PTD]FCSCSTPUR*WQTYPUU/[F:PTD]QTYPUU
      [F:PID]FCSCPR    += [F:PTD]FCSCPR*WQTYPUU/[F:PTD]QTYPUU
      WQTYPUU = 0
      Break
    Endif
  #---
  Next
  Filter [PTD]

#--- Issue 97487
Endif

# Il reste de la quantitķ Ó traiter, on rķcupĶre les charges de la commande
If WQTYPUU>0
  If WQTYPUU>=[F:POQ]QTYPUU
    [F:PID]FCSCSTPUR += [F:POQ]FCSCSTPUR
    [F:PID]FCSCPR    += [F:POQ]FCSCPR
  Else
    [F:PID]FCSCSTPUR += [F:POQ]FCSCSTPUR*WQTYPUU/[F:POQ]QTYPUU
    [F:PID]FCSCPR    += [F:POQ]FCSCPR*WQTYPUU/[F:POQ]QTYPUU
  Endif
Endif
Return
#---

#--- Issue 84130 by TS : Landed cost
# L'origine de la facture est une rķception
$ORI_PTD
If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL)|[F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
  Read [PTD]PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
  If fstat
    Call RSTA("PTD",[M:PIH3]NUMORI(NOL)+num$([M:PIH3]LINORI(NOL))) From GLOCK
    GOK=0 : Return
  Elsif [F:PTD]STCNUM=""
    [F:PID]FCSCSTPUR = 0
    [F:PID]FCSCPR    = 0
    Return
  Endif
Endif
If [M:PIH3]QTYPUU(NOL)>=[F:PTD]QTYPUU
  [F:PID]FCSCSTPUR = [F:PTD]FCSCSTPUR
  [F:PID]FCSCPR    = [F:PTD]FCSCPR
Else
  [F:PID]FCSCSTPUR = [F:PTD]FCSCSTPUR*[M:PIH3]QTYPUU(NOL)/[F:PTD]QTYPUU
  [F:PID]FCSCPR    = [F:PTD]FCSCPR*[M:PIH3]QTYPUU(NOL)/[F:PTD]QTYPUU
Endif
Return
#---


$CHARG_PARAM
#----------------------------------------------------------------------------#
# Chargement des paramĶtres avec GFCY = Site de la facture                   #
# -------------------------------------------------------------------------- #
# Chargement GSOCIETE   : Sociķtķ juridique                                  #
#            GLOCALDEV  : Devise sociķtķ juridique                           #
#            GFINRSP    : Site financier                                     #
#            GSALDSPWEU : Unitķ de poids  pour rķpartition                   #
#            GSALDSPVOU : Unitķ de volume pour rķpartition                   #
#            GANASAI1-9 : Options de saisie des axes analytiques             #
#            GPIH_CPYCRY: Pays de la sociķtķ courante (GSOCIETE)             #
# Rķcupķration des paramĶtres ACHATS                                         #
# Rķcupķration des paramĶtres BUDGET                                         #
#            GPIHACCDAT : Modification date comptable                        #
#            GPIHCPR    : Rķgularisation prix facture (2=Avec coef approche) #
#            GPIHCURDAT : Date cours devise (1=Comptable 2=Fourniss.)        #
#            GPIHQTYAQR : Quantitķ facturable (A, A+Q, A+Q+R)                #
#            GPURCMM    : Mise Ó jour des engagements  (1=NON 2=OUI)         #
#            GPURCMMDAT : Date engagement (1=Date cde  2=Date Rķcept)        #
#            GSIVNULL   : Facture Ó zķro interdite (1=NON 2=OUI)             #
#            GPIVSUP    : Bouton suppression (1=NON 2=OUI)                   #
#            GPIHQTYRET : Facturation quantitķs retournķes                   #
#----------------------------------------------------------------------------#
# Issue 114426
Raz GPURCMM, GPURCMMDAT, GPIHACCDAT, GPIHCURDAT, GPIHQTYAQR, GSIVNULL, GPIVSUP #85785
# End issue 114426
Raz GPIHQTYRET # Issue 70507 - 2012-01-18 by MUARN : facturation quantitķs retournķes
Local  Char     PARAM2(10)
#----- Chargement des globales rķfķrenciels, comptes et sections de la sociķtķ -----#
Call GETCPY(GFCY,"PTR",8,GPTRNUM) From TRTX3CPT
If GFINRSP=""  GFINRSP=GFCY : Endif
#----- Si changement sociķtķ -----#
If GSOC_UPDFLG
  #----- Forcer le contr¶le sur le type de facture ! -----#
  If GREP<>"" & [M:PIH0]PIVTYP<>""
    Setmok [PIH0] With 0
  Endif
  #----- Lecture des affectations compteur (factures) -----#
  If dim(OK)<1  Local Integer OK : Endif
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(64,199,1) : GERR=1 : OK=0 : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(7) : GCODNUM=[F:TCA]CODNUM(7)
  #----- Chargement indicateur Numķrotation Argentine -----#
  If func AFNC.ACTIV("KAG")
    Call PARAM(GFCY,"ARGNUM",PARAM2) From ADOVAL
    GLOCARGNUM=val(PARAM2)
    If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
  Else
    Raz GLOCARGNUM
  Endif
  Gosub GRIZO_ARG
  #----- Chargement indicateur Etalement des prestations -----#
  If func AFNC.ACTIV("SVC")
   # Issue X3-199974 - 2020-06-29 by VAVIL : Analytical apportionment disconnected from legislation
    Call PARAM(GFCY,"SVCFLG",PARAM2) From ADOVAL
   # End issue X3-199974
    GLOCITAPRE=val(PARAM2)
    If GLOCITAPRE>0  GLOCITAPRE-=1 : Endif
  Else
    Raz GLOCITAPRE
  Endif
  #-----
  If func AFNC.ACTIV("SVC") | GLOCITAPRE
    #----- Relecture transaction si nķcessaire -----#
    If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
    Endif
    #----- Dates et pķriode prestation ligne -----#
    If [F:PTR]SVCDATCOD(1)=1
      #----- Saisi -----#
      If GLOCITAPRE
        If [M:PIH1]STA=3
          GPIH_FMTPER(0)="DZzP:"+GFMDAT
          GPIH_FMTPER(1)="DZzP:"+GFMDAT
          GPIH_FMTPER(2)="NP+:4#"
          GPIH_FMTPER(3)="NP:1#"
        Else
          GPIH_FMTPER(0)="DZz:"+GFMDAT
          GPIH_FMTPER(1)="DZz:"+GFMDAT
          GPIH_FMTPER(2)="N+:4#"
          GPIH_FMTPER(3)="N:1#"
        Endif
      Else
        GPIH_FMTPER(0)="DZz:"+GFMDAT
        GPIH_FMTPER(1)="DZz:"+GFMDAT
        GPIH_FMTPER(2)="-N+:4#"
        GPIH_FMTPER(3)="-N:1#"
      Endif
    Elsif [F:PTR]SVCDATCOD(1)=2
      #----- Affichķ -----#
      GPIH_FMTPER(0)="DZzP:"+GFMDAT
      GPIH_FMTPER(1)="DZzP:"+GFMDAT
      #-----
      If GLOCITAPRE
        GPIH_FMTPER(2)="NP+:4#"
        GPIH_FMTPER(3)="NP:1#"
      Else
        GPIH_FMTPER(2)="-N+:4#"
        GPIH_FMTPER(3)="-N:1#"
      Endif
    Else
      #----- Invisible -----#
      GPIH_FMTPER(0)="-DZz:"+GFMDAT
      GPIH_FMTPER(1)="-DZz:"+GFMDAT
      GPIH_FMTPER(2)="-N+:4#"
      GPIH_FMTPER(3)="-N:1#"
    Endif
    #----- Dates prestation entĻte -----#
    If dim([M:PIH1]STRDATSVC)>0
      #----- Saisi -----#
      If !GLOCITAPRE & [F:PTR]SVCDATCOD(0)=1
        GPIH_FMTPER(4)="DZz:"+GFMDAT
        GPIH_FMTPER(5)="DZz:"+GFMDAT
      #----- Affichķ -----#
      Elsif !GLOCITAPRE & [F:PTR]SVCDATCOD(0)=2
        GPIH_FMTPER(4)="DZzP:"+GFMDAT
        GPIH_FMTPER(5)="DZzP:"+GFMDAT
      #----- Invisible -----#
      Else
        GPIH_FMTPER(4)="-DZz:"+GFMDAT
        GPIH_FMTPER(5)="-DZz:"+GFMDAT
      Endif
      Affzo [PIH1]STRDATSVC, ENDDATSVC
    Endif
  Else
    GPIH_FMTPER(0)="-DZz:"+GFMDAT
    GPIH_FMTPER(1)="-DZz:"+GFMDAT
    GPIH_FMTPER(2)="-N+:4#"
    GPIH_FMTPER(3)="-N:1#"
    #-----
    If dim([M:PIH1]STRDATSVC)>0
      GPIH_FMTPER(4)="-DZz:"+GFMDAT
      GPIH_FMTPER(5)="-DZz:"+GFMDAT
      Affzo [PIH1]STRDATSVC, ENDDATSVC
    Endif
 Endif
   # Issue 71253 - 2012-05-10 by SR : Localisation espagnole
  If func AFNC.ACTIV("KSP")
     #----- Relecture transaction si nķcessaire -----#
     If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
         Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
     Endif
    If func AFNC.PARAM("SPAVAT",GFCY) = "2"
    #----- Localisation Espagnole -----#
      If find([F:PTR]SPTVACOD,0,1)
        #----- Saisi -----#
        GPIH_FMTKSP(0)="DZz:"+GFMDAT
        GPIH_FMTKSP(1)="K:40X"
        GPIH_FMTKSP(2)="K:"+num$(GLONBPS)+"g" # cf DBOPP (SUIVIPRD 83393)
        GPIH_FMTKSP(3)="KP:"+num$(GLONSHO)+"X"
      Elsif [F:PTR]SPTVACOD=2
        #----- Affichķ -----#
        GPIH_FMTKSP(0)="DZzP:"+GFMDAT
        GPIH_FMTKSP(1)="KP:40X"
        GPIH_FMTKSP(2)="KP:"+num$(GLONBPS)+"X"
        GPIH_FMTKSP(3)="KP:"+num$(GLONSHO)+"X"
      Else
        #----- Invisible -----#
        GPIH_FMTKSP(0)="-DZz:"+GFMDAT
        GPIH_FMTKSP(1)="-K:40X"
        GPIH_FMTKSP(2)="-K:"+num$(GLONBPS)+"X"
        GPIH_FMTKSP(3)="-KP:"+num$(GLONSHO)+"X"
      Endif
     Else
      #----- Invisible -----#
      GPIH_FMTKSP(0)="-DZz:"+GFMDAT
      GPIH_FMTKSP(1)="-K:40X"
      GPIH_FMTKSP(2)="-K:"+num$(GLONBPS)+"X"
      GPIH_FMTKSP(3)="-KP:"+num$(GLONSHO)+"X"
    Endif
  Endif
  # Issue 71253 - 2012-05-10 by SR : Localisation portugaise
  If func AFNC.ACTIV("KPO")
    Gosub CHARG_FMTPOR From SUBPIHC
  Endif

  # Issue 71069 - 2013-08-26 by MUARN : PJT
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)

  # Issue 117554 - 2016-08-12 by MUARN : type arrondi TVA
  Call PARAML(GFCY,"VATRND",GBIDC3) From ADOVAL
  GVATRND=val(GBIDC3)

Endif

#----- Chargement des globales unitķ poids et volume pour rķpartition -----#
Call PARAM(GFCY,"SALDSPWEU",GSALDSPWEU) From ADOVAL
Call PARAM(GFCY,"SALDSPVOU",GSALDSPVOU) From ADOVAL
#----- Chargement du pays de la sociķtķ GPIH_CPYCRY -----#
Raz GBIDI1
If clalev([F:CPY])<=0 Local File COMPANY [CPY] : GBIDI1=1 : Endif
Read [CPY] CPY0=GSOCIETE : If fstat Raz [F:CPY] : Endif
GPIH_CPYCRY=[F:CPY]CRY
If GBIDI1=1 Close Local File [CPY] : Raz GBIDI1 : Endif
#-----
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH
Call GLOBVAR(GFINRSP) From WWGLOBBUD
Call PARAM(GFCY,"PIHACCDAT",PARAM2)    From ADOVAL
GPIHACCDAT=val(PARAM2)
Call PARAM(GFCY,"PIHCURDAT",PARAM2)    From ADOVAL
GPIHCURDAT=val(PARAM2)
Call PARAM(GFCY,"PIHQTYAQR",PARAM2)    From ADOVAL
GPIHQTYAQR=val(PARAM2)
Call PARAM(GFCY,"PURCMM",PARAM2)       From ADOVAL
GPURCMM=val(PARAM2)
Call PARAM(GFCY,"PURCMMDAT",PARAM2)    From ADOVAL
GPURCMMDAT=val(PARAM2)
Call PARAM(GFCY,"SIVNULL",PARAM2)      From ADOVAL
GSIVNULL=val(PARAM2)
#85785 * new PIVSUP param
# Issue 114426
Call PARAM(GFCY,"PIVSUP",PARAM2)       From ADOVAL
GPIVSUP=val(PARAM2)
# End issue 114426
Call PARAM(GFCY,"FLGPAZ",PARAM2)       From ADOVAL
GPIH_FLGPAZ=val(PARAM2) : If GPIH_FLGPAZ=0  GPIH_FLGPAZ=2 : Endif
Call PARAM(GFCY,"CTLDATORI",PARAM2)    From ADOVAL
GCTLDATORI=val(PARAM2)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
# Issue 70507 - 2012-01-18 by MUARN : facturation quantitķ retournķe
Call PARAM(GFCY,"PIHQTYRET",PARAM2)    From ADOVAL
GPIHQTYRET=val(PARAM2)  : If GPIHQTYRET=0   GPIHQTYRET=2 : Endif
# Issue 83026 - 2012-07-11 by MUARN : early discount
Call PARAM(GFCY,"DEPMGTMOD",PARAM2) From ADOVAL
GDEPMGTMOD=val(PARAM2)
# Exigence 82615 : Lķgislation belge --str
# FQ122815  Ajout d'un suffixe aux variables globales GDCLFEES, GACVDAS, GACVBE281
Global Char GDCLFEES_PIH
If  func AFNC.ACTIV("FEE")  # Issue X3-107197
  GDCLFEES_PIH = func AFNC.PARAM("DCLFEES", GSOCIETE)
Endif  # End Issue X3-107197
Global Integer GACVDAS_PIH, GACVBE281_PIH
If func AFNC.ACTIV("DAS")   Then GACVDAS_PIH  =1 Else GACVDAS_PIH  =0 : Endif
If func AFNC.ACTIV("BE281") Then GACVBE281_PIH=1 Else GACVBE281_PIH=0 : Endif
# Exigence 82615 : Lķgislation belge --str
# Issue 84130 - 2012-12-17 by MAE : Landed cost
Call PARAM(GSOCIETE,"NODVATSTO",PARAM2) From ADOVAL
  GNODVATSTO=val(PARAM2)
Return


#---------------------------------------------------------
# Activation/dķsactivation champs Numķrotation Argentine #
#--------------------------------------------------------#
$GRIZO_ARG
If dim([M:PIH1]TYPVCR)>0
  If GLOCARGNUM
    Actzo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR
  Else
    Grizo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR
  Endif
Endif
If dim([M:PIH3]CAI)>0
  If GLOCARGNUM
    Actzo [PIH3]CAI, DATVLYCAI
  Else
    Grizo [PIH3]CAI, DATVLYCAI
  Endif
Endif

Return

# Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
# MAJ_FICHIERS_LIGNE et des ķtiquettes appelķes
# subprog MAJ_CDE
# Subprog MAJ_DESENGAGE
# Subprog MAJ_RCP

# Issue number - 2011-09-20 by VPO : ajout PE pour permettant de ne pas
# imputer la quantitķ sur-facturķe sur des rķceptions existantes.
########################################################################
# MAJ_EXTRA_QTE_PTD : Si sur-facturation (qtķ facturķe supķrieure      #
#                 Ó la qtķ rķceptionnķe) rķajustement des quantitķs    #
#                 facturķes de la rķception (PRECEIPTD)                #
########################################################################
$MAJ_EXTRA_QTE_PTD
NUMERO=[F:PTD]PTHNUM
WLIGNE=[F:PTD]PTDLIN
If [F:PID]UOM=[F:PTD]STU
  GBIDD1=WQTEUOM
Else
  Call PCAL_QTY(WQTE,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&               [F:PID]ITMREF,[F:PTH]BPSNUM,1,GBIDD2) From TRTACHQTE1
Endif
If SIGN=-1
  Update [PTD] Where PTHNUM=NUMERO & PTDLIN=WLIGNE
&              With INVQTYPUU-=WQTE*(3-(2*[F:PIH]INVTYP)),
&                   INVQTYSTU-=GBIDD1*(3-(2*[F:PIH]INVTYP))
  [F:PTD]INVQTYPUU-=WQTE*(3-(2*[F:PIH]INVTYP))
  [F:PTD]INVQTYSTU-=GBIDD1*(3-(2*[F:PIH]INVTYP))
Else
  Update [PTD] Where PTHNUM=NUMERO & PTDLIN=WLIGNE
&              With INVQTYPUU+=WQTE*(3-(2*[F:PIH]INVTYP)),
&                   INVQTYSTU+=GBIDD1*(3-(2*[F:PIH]INVTYP))
  [F:PTD]INVQTYPUU+=WQTE*(3-(2*[F:PIH]INVTYP))
  [F:PTD]INVQTYSTU+=GBIDD1*(3-(2*[F:PIH]INVTYP))
Endif
If fstat GOK=0 : Call FSTA("PTD") From GLOCK : Endif
Return

########################################################################
# MAJ_EXTRA_QTE : Si excķdent de facturation (qtķ facturķe supķrieure  #
#                 Ó la qtķ rķceptionnķe) rķajustement des quantitķs    #
#                 facturķes de la rķception (PRECEIPTD)                #
# -------------------------------------------------------------------- #
#   SIGN     : Sens de la mise Ó jour (+1=Cumul, -1=Soustraction)      #
#   WQTE     : Excķdent de quantitķ facturķe en UA                     #
#   WQTEUOM  : Excķdent de quantitķ facturķe en UOM                    #
#   [F:PTD]PTHNUM : Numķro de la rķception Ó mettre Ó jour             #
#   [F:PTD]PTDLIN : Ligne  de la rķception Ó mettre Ó jour             #
########################################################################
$MAJ_EXTRA_QTE
If [F:PTD]PTHNUM="" | [F:PTD]PTDLIN=0  : Return : Endif
# Issue 113975 - 2016-01-28 by SR : dans certains cas :
# Type de document d'origine n'est pas rķception ou facture
# Rķception directe
# Intersoc (car on l'a dķjÓ fait)
# Avoir  sur autre chose qu'une facture sur rķception,
# on ne disatche pas donc on remet tout sur la rķception
#Gosub MAJ_EXTRA_QTE_PTD : # Issue number - 2011-09-20 by VPO
If !find([F:PID]TYPORI,2,4) | [F:PTD]POHNUM="" | [M:PIH0]BETCPY=2
&  | ([F:PID]TYPORI=4 & [F:PIDB]TYPORI<>2)
    Gosub MAJ_EXTRA_QTE_PTD : # Issue number - 2011-09-20 by VPO
Endif
NUMERO=[F:PTD]PTHNUM
WLIGNE=[F:PTD]PTDLIN
# End issue 113975

If !find([F:PID]TYPORI,2,4) | [F:PTD]POHNUM="" | [M:PIH0]BETCPY=2 :  Return : Endif
If [F:PID]TYPORI=4 & [F:PIDB]TYPORI<>2  Return : Endif
# Issue X3-25003 - 2018-01-12 by SR : Se positionner sur la commande si besoin
If [F:POH]POHNUM <> [F:PTD]POHNUM
  Read [F:POH]POH0 = [F:PTD]POHNUM
  If fstat : Raz [F:POH] : Endif
Endif
#----- Si origine rķception, mettre sur-facturation sur rķception non facturķe -----#
If dim(WPOHNUM)<1 Local Char    WPOHNUM(GLONPOH) : Endif
If dim(WPOPLIN)<1 Local Integer WPOPLIN          : Endif
If dim(WPOQSEQ)<1 Local Integer WPOQSEQ          : Endif
If dim(WPRTFLG)<1 Local Integer WPRTFLG          : Endif
If dim(WQTESUP)<1 Local Decimal WQTESUP          : Endif
WPOHNUM=[F:PTD]POHNUM
WPOPLIN=[F:PTD]POPLIN
WPOQSEQ=[F:PTD]POQSEQ
WPRTFLG=[F:PID]PRTFLG : [F:PID]PRTFLG=2 : # Pour le Call MAJ_RCP
If SIGN*(3-(2*[F:PIH]INVTYP))=-1
  GBIDC3="INVQTYPUU>0"
  If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Default File [PID] : Endif
  If clalev([F:PIDC])<=0 Local File PINVOICED [PIDC] : Default File [PID] : Endif
Else
  GBIDC3="LININVFLG<2"
Endif
If clalev([F:PTDB])<=0 Local File PRECEIPTD [PTDB] : Default File [PID] : Endif
For [PTDB] PTD2 Where POHNUM=WPOHNUM
&                   & POPLIN=WPOPLIN
&                   & POQSEQ=WPOQSEQ
&                   & evalue(GBIDC3)
&                   & (PTHNUM<>NUMERO | PTDLIN<>WLIGNE)
  #----- Annulation facture ou avoir sur rķception -----#
  If SIGN*(3-(2*[F:PIH]INVTYP))=-1
    Raz GBIDD3
    For [PIDB] PID1 Where TYPORI=2 & NUMORI=[F:PTDB]PTHNUM & LINORI=[F:PTDB]PTDLIN
      GBIDD3+=[F:PIDB]QTYPUU
      #----- Tenir compte d'ķventuels avoirs sur facture -----#
      For [PIDC] PID1 Where TYPORI=4 & NUMORI=[F:PIDB]NUM & LINORI=[F:PIDB]PIDLIN
        If [F:PIDB]NETPRI=[F:PIDC]NETPRI  GBIDD3-=[F:PIDC]QTYPUU : Endif
      Next
    Next
    #-----
    If [F:PTDB]INVQTYPUU-GBIDD3>0
      WQTESUP=[F:PTDB]INVQTYPUU-GBIDD3
      If WQTESUP>=WQTE
         WQTESUP=WQTE : Raz WQTE
      Else
         WQTE-=WQTESUP
      Endif
      Call PCAL_QTY(WQTESUP,[F:PID]PUU,WQTEUOM,[F:PID]UOM,
&                   [F:PID]ITMREF,[F:PTH]BPSNUM,1,GBIDD2) From TRTACHQTE1
      WQTEMESS=WQTESUP : # Issue number - 2011-09-20 by VPO
      # Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
      Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTESUP,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
      # Issue number - 2011-09-20 by VPO : ajout message pour avertir qte prise sur reception
      If GOK
         Call MESSAGE(func AFNC.MES2(mess(423,194,1),[F:PTDB]PTHNUM-'/'-num$([F:PTDB]PTDLIN),num$(WQTEMESS-WQTESUP))) From GESECRAN
      Endif
    Endif
  #----- Facture ou annulation d'avoir sur rķception -----#
  Else
    WQTEMESS=WQTE : # Issue number - 2011-09-20 by VPO
    # Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
    Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
    # Issue number - 2011-09-20 by VPO : ajout message pour avertir qte prise sur reception
    If GOK
       Call MESSAGE(func AFNC.MES2(mess(423,194,1),[F:PTDB]PTHNUM-'/'-num$([F:PTDB]PTDLIN),num$(WQTEMESS-WQTE))) From GESECRAN
    Endif
  Endif
  If GOK<1  Break : Endif
  If WQTE=0 Break : Endif
Next
[F:PID]PRTFLG=WPRTFLG
# Issue 113975 - 2016-01-28 by SR : Si tout n'a pas ķtķ dispatchķ , on met Ó jour la rķception concernķe par la facture
If GOK<1 Return : Endif
Read [PTD] PTD0=NUMERO;WLIGNE
# Issue X3-25003 - 2018-01-12 by SR : Pas si nouvelle mķthode
If GPRIFLG = 2 & GPSVSTRDAT <= [F:POH]CREDAT : Return : Endif
If !fstat &  WQTE<>0
    Gosub MAJ_EXTRA_QTE_PTD : # MÓj qtķs facturķes de la rķception en cours si excķdent de facturation
Endif
# End issue 113975
Return

###########################################################################
# MAJ_EXTRA_INTSOC : Si excķdent de facturation (qtķ facturķe supķrieure  #
#                    Ó la qtķ rķceptionnķe) rķajustement des quantitķs    #
#                    facturķes sur les autres rķceptions inter-sociķtķs   #
#                    portant sur la mĻme ligne de livraison ou par dķfaut #
#                    sur la rķception venant d'Ļtre traitķe               #
# ----------------------------------------------------------------------- #
#   SIGN     : Sens de la mise Ó jour (+1=Cumul, -1=Soustraction)         #
#   WQTE     : Excķdent de quantitķ facturķe en UA                        #
#   WQTEUOM  : Excķdent de quantitķ facturķe en UOM                       #
#   [F:PTD]PTHNUM : Numķro de la rķception venant d'Ļtre traitķe          #
#   [F:PTD]PTDLIN : Ligne  de la rķception venant d'Ļtre traitķe          #
###########################################################################
$MAJ_EXTRA_INTSOC
If [F:PTD]PTHNUM="" | [F:PTD]PTDLIN=0 Return : Endif
NUMERO=[F:PTD]PTHNUM
WLIGNE=[F:PTD]PTDLIN
If dim(WSDHNUM)<1 Local Char    WSDHNUM(GLONSDH) : Endif
If dim(WSDDLIN)<1 Local Integer WSDDLIN          : Endif
If dim(WPRTFLG)<1 Local Integer WPRTFLG          : Endif
WSDHNUM=[F:PTD]SDHNUM
WSDDLIN=[F:PTD]SDDLIN
WPRTFLG=[F:PID]PRTFLG : [F:PID]PRTFLG=2 : # Pour le Call MAJ_RCP
If SIGN*(3-(2*[F:PIH]INVTYP))=-1  GBIDC3="LININVFLG=2"  Else  GBIDC3="LININVFLG=1" : Endif
If clalev([F:PTDB])<=0 Local File PRECEIPTD [PTDB] : Default File [PID] : Endif
For [PTDB] PTD1 Where evalue(GBIDC3)
&                   & BPSNUM  =[M:PIH0]BPR
&                   & ITMREF  =[F:PID]ITMREF
&                   & SDHNUM  =WSDHNUM
&                   & SDDLIN  =WSDDLIN
&                   & (PTHNUM<>NUMERO | PTDLIN<>WLIGNE)
  # Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
  Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
  If GOK<1  Break : Endif
  If WQTE=0 Break : Endif
Next
If SIGN*(3-(2*[F:PIH]INVTYP))=-1 & GOK=1 & WQTE<>0
  For [PTDB] PTD1 Where LININVFLG=1
&                     & BPSNUM   =[M:PIH0]BPR
&                     & ITMREF   =[F:PID]ITMREF
&                     & SDHNUM   =WSDHNUM
&                     & SDDLIN   =WSDDLIN
&                     & INVQTYPUU>0 & INVQTYPUU<=QTYPUU
&                     & (PTHNUM <>NUMERO | PTDLIN<>WLIGNE)
    # Issue 100651 - 2014-06-06 by MUARN : Dķplacement de SUBPIHA Ó SUBPIHD
    Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
    If GOK<1  Break : Endif
    If WQTE=0 Break : Endif
  Next
Endif
[F:PID]PRTFLG=WPRTFLG
If GOK<1 Return : Endif
If WQTE<>0
  Read [PTD] PTD0=NUMERO;WLIGNE
  If !fstat
    Gosub MAJ_EXTRA_QTE : # MÓj qtķs facturķes rķception si excķdent de facturation
  Endif
Endif
Return


########################################################################
# EXISTE_GTE_NUM : S/P de contr¶le de l'existence de la clķ dans les   #
#                  piĶces comptables et les ķchķances                  #
# -------------------------------------------------------------------- #
# Subprog EXISTE_GTE_NUM(TYP,NUM)                                      #
#   TYP     : Type de piĶce comptable (GTE)                            #
#   NUM     : Numķro de la facture                                     #
########################################################################
Subprog EXISTE_GTE_NUM(TYP,NUM)
Value    Char     TYP
Value    Char     NUM
If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:HAT])<=0 Local File GACCTMP    [HAT] : Endif
Look [DUD] DUD0(2)=TYP;NUM
If !fstat
  GMESSAGE=mess(57,119,1)   : # Une ķchķance existe dķjÓ avec ce numķro
  mkstat=2 : End
Endif
Look [HAT] HAT0=TYP;NUM
If !fstat
  GMESSAGE=mess(58,119,1)   : # Une ķcriture existe dķjÓ avec ce numķro
  mkstat=2 : End
Endif
If GMODU(2)=2
  If clalev([F:HAE])<=0 Local File GACCENTRY  [HAE] : Endif
  Look [HAE] HAE0=TYP;NUM
  If !fstat
    GMESSAGE=mess(58,119,1) : # Une ķcriture existe dķjÓ avec ce numķro
    mkstat=2 : End
  Endif
Endif
End

#################################################################
# Mises Ó jour complķmentaires suite Ó une annulation comptable #
# ------------------------------------------------------------- #
#       - L'appel est fait depuis le traitement ANUBIS          #
#       - Une transaction est en cours                          #
#################################################################
$MAJ_ANUBIS
# Issue X3-174264 - 2019-12-13 by SR :
# Launch MAJ_REACSTPUR in order to update Actual Purchase Cost field of the purchase order(added in V7).
Call MAJ_REACSTPUR("!#DEVALIDE") From TRTACHFAC1
If GOK<1 : Return : Endif
# End issue X3-174264
Call REGPRIX("!#DEVALIDE") From TRTACHFAC1          : # Rķgularisation inverse des prix
If GOK<1  Return : Endif
# Issue X3-25002 - 2017-05-23 by SR : Valorisation des rķceptions
Delete [F:PSV] Where NUM = [F:PIH]NUM
If fstat : GOK = 0 : Return : Endif
# End issue X3-25003
Call BUDGET ("!#DEVALIDE",GMESSAGE) From TRTACHFAC1 : # Rķ-engagement budgķtaire
If GOK<1  Return : Endif
Call VALSTA("PIH",-1) From SUBPS2                   : # MÓj statistiques entĻte facture
If GOK<1  Return : Endif
For [PID] Where NUM=[F:PIH]NUM
  Call VALSTA("PID",-1) From SUBPS2                 : # MÓj statistiques lignes facture
  If GOK<1  Break : Endif
Next
If GOK<1  Return : Endif
#----- Autres mÓj ?  Pas pour l'instant ! -----#
Return

#--------------------------------------#
# Chargement des textes entĻte et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:PIH0]TEX1<>""
  If left$([M:PIH0]TEX1,3)="PIV"
    Call CRE_CLOB([M:PIH0]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PIH0]TEX1,3)<>"BPS"
    Call DUP_CLOB("PIV",[M:PIH0]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PIV]TEX1=[M:PIH0]TEX1
Endif
If [M:PIH0]TEX2<>""
  If left$([M:PIH0]TEX2,3)="PIV"
    Call CRE_CLOB([M:PIH0]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PIH0]TEX2,3)<>"BPS"
    Call DUP_CLOB("PIV",[M:PIH0]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PIV]TEX2=[M:PIH0]TEX2
Endif
Return

#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:PIH3]LINTEX(nolign-1)<>""
  If left$([M:PIH3]LINTEX(nolign-1),3)="PID"
    Call CRE_CLOB([M:PIH3]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:PIH3]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("PID",[M:PIH3]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PID]LINTEX=[M:PIH3]LINTEX(nolign-1)
Endif
Return

#------------------------------------------------------------------------#
# Affichage entĻtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:PIH3]LINACC1)>0 | dim([M:PIH3]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE8"+GPTRNUM+"3"
  BASPAG="NBFAC" : Gosub TIT_COL From ="W1WE8"+GPTRNUM+"4"
  #----- Pour forcer l'utilisation des formats ķvaluķs si tableau vide -----#
  If [M:PIH3]NBLIG=0
    [M:PIH3]NBLIG=1 : Affzo [PIH3]5 : Effzo [PIH3]5
    [M:PIH3]NBLIG=0 # Issue 84942 - 2012-10-04 by MUARN : erreur zone obligatoire
  Endif
  If [M:PIH4]NBFAC=0
    [M:PIH4]NBFAC=1 : Affzo [PIH4]5 : Effzo [PIH4]5
    [M:PIH4]NBFAC=0 # Issue 84942 - 2012-10-04 by MUARN : erreur zone obligatoire
  Endif
  #-----
Endif
# Issue 84130 - 2013-01-24 by MUARN : landed cost
If GFONCTION = "GESPIH" & !GIMPORT
  Titcol [M:CSTI]NBCST mess(796,197,1) + " (" + GCUR + ")" For TOTDOC
  Titcol [M:CSTI]NBCST mess(797,197,1) + " (" + GLOCALDEV + ")" For TOTSOC
Endif

Raz GSOC_UPDFLG
Return

$AVANT_CHOI    #----MAE, le 19/02/08----#
#------------------------------------------------------------------------#
# facture en crķation, alimentķe par le fournisseur via les navigations  #
#------------------------------------------------------------------------#
If GCREFONC=1
   REPONSE=GSTANEW
   Gosub NOUVEAU From GOBJSUB
   Gosub SETBOUT From GOBJSUB
   #MAE, le 28/10/08, on autorise pas la modification du fournisseur quand on vient de l'acran des fournisseurs
   # FGR 18/02/2014 : X3SUIVI96940 ne pas faire le diszo : ńa dķsactive les actions sur champ (contr¶le, AM...)
   #   If [M:PIH0]BPR <> ""
   #    Diszo [M:PIH0]BPR
   #   Endif
   # FGR 18/02/2014 : X3SUIVI96940 empĻche l'exķcution du AM_BPCORD
   #GCREFONC = 0
   GCREFONC = 2
Endif
Return

$APRES_CHOI
If currbox = GBOXLO1 Then
  # Si on est sur le tiroir des dķpenses liķes
  Case REPONSE
    When GSTALFT
      # L'ķcran des dķpenses n'est pas ouvert : on peut repartir dessus
      Local Char BIDON(1)
      Call OBJET("LOF", BIDON, [F:LOF]CODLOF+"@"+num$([F:LOF]LINLOF)) From GOBJET
  Endcase
Endif
Return

#MAE, bg 77405
$VERROU_HAE
If [F:PIH]INVTYP<>5
 [L]SYMBHAE = "HAE"+[F:PIH]NUM+"\"+[F:PIH]GTE
 Lock =SYMBHAE With lockwait=0
 If fstat
  Unlock =SYMBOLE
  [L]OK=0
 Endif
Endif
Return

$DEVERROU_HAE
If SYMBHAE<>""
 Unlock =SYMBHAE
Endif
Return

$CASH_VAT   #90370 Cash VAT SPA
If func AFNC.ACTIV("KSP")
  Call LEC_BPS([F:PIH]BPR) From CPTLEC
  If [F:BPS]CSHVAT=2 or func AFNC.PARAM("SPACSHVAT",[F:PIH]CPY)="2"
    Local Integer CSHVAT
    Call CSHVATBPS([F:PIH]ACCDAT,[F:PIH]CRY,[F:PIH]VAC,[F:PIH]CPY, [F:PIH]TAX(),[F:BPS]CSHDAT,
&   [F:BPS]CSHVAT,CSHVAT) From DCLVATSPA
    [F:PIH]CSHVAT=CSHVAT
  Endif
Endif
Return

# Issue X3-195220 - 2020-08-13 by SR : Load FIY and PER fields.
$LOAD_FIY_PER
WSTATUS = func TRTX3_SYRA.GET_PER(GACTX, [F:PIH]CPY, GTYPGEN, [F:PIH]ACCDAT, EXERCICE, PERIODE, GMESSAGE)
[F:PIH]FIY = EXERCICE
[F:PIH]PER = PERIODE
Return
# End issue X3-195220
