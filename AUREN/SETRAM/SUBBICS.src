##############################################################################################################
## Actions communes pour la gestion de factures tiers clients et fournisseurs
## DECLARE_GLOBAL                  : Déclaration les variables globales
## DECLARE_TABLE                   : Ouverture tables
## DECLARE_MASQUE                  : Ouverture masques
## INI_GLOBAL                      : Initialisation des variables globales
## SETLED                          : Types de référentiels ŕ gérer pour une société et un type de document
## AFFCOL                          : Affichage colonnes comptes/sections
## SETCHPLST, SETCHPAXE, SETCHPLED : Alimentation des champs LSTAXE, LSTLED, LSTACC (liste axes, référentiels
##                                   comptes séparés par des ';')
## LECLED                          : Lecture référentiel
## INIOTHACC                       : Initialisation des comptes (propagation)
## RECH_ACCGEN                     : Recherche du plan et compte du référentiel principal général
##                                  (théoriquement, saisi dans le champ ACC1)
## RECH_ACCANA                     : Recherche du plan et compte du référentiel principal analytique
## CONTACC                         : Contrôle compte
## AM_BPRDAT                       : Aprčs modif sur champ BPRDAT (Date document origine)
## D_NBRCCE                        : Init sur variable bas tableau sections ana en-tęte
## C_NBRCCE                        : Contrôle sur variable bas tableau sections ana en-tęte
## C_CCEH                          : Contrôle sections ana saisies en en-tęte

## C_SAC                           : Contrôle sur champ SAC (Code collectif)
## D_QTY                           : Init sur champ QTY (Quantité)
## AS_QTY                          : Avant_Saisie sur champ QTY (Quantité)
## D_DSP                           : Init sur champ DSP (Répartition analytique)
## AS_DSP                          : Avant_Saisie sur champ DSP (Répartition analytique)
## D_CCE                           : Init sur champ CCE
## AS_CCE                          : Avant_Saisie sur champ CCE
## C_CCE                           : Contrôle sur champ CCE

## Subprog INI_COURS(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS)
## Subprog CHARGE_COURS(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS)

##############################################################################################################
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# Issue X3-99385 - 2018-07-12 by CBO : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
# FPE/JMA/SMO 30.01.2018 X3-66221 & X3-72953 : Ability to import       #
#                                              currency rate in AP/AR  #
#                                              invoices                #
########################################################################

$DECLARE_GLOBAL
Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes ŕ saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Char    GCODLED(GLONLED)(1..10)               : # Ledger code (LED)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GNBTYPLED                             : # Nb référentiels <> pour la société (pour init sections)
Global Integer GTYPLED(1..10)                        : # Types référentiels
Return

$DECLARE_TABLE
If clalev([F:CCE2])=0 : Local File CACCE     [CCE2] : Endif : # Sections
If clalev([F:GCM])=0  : Local File GACM      [GCM]  : Endif : # Modčles comptables
If clalev([F:LED])=0  : Local File GLED      [LED]  : Endif : # Référentiels
If clalev([F:COA])=0  : Local File GCOA      [COA]  : Endif : # Code plans
If clalev([F:DIE])=0  : Local File GDIE      [DIE]  : Endif : # Axes analytiques
If clalev([F:BPR])=0  : Local File BPARTNER  [BPR]  : Endif : # Tiers
Case CAS
 When 1
  If clalev([F:SIH2])=0 : Local File SINVOICE  [SIH2] : Endif : # En-tęte factures tiers clients
  If clalev([F:SIL2])=0 : Local File BPCINVLIG [SIL2] : Endif : # Lignes factures tiers clients
  If clalev([F:FCT])=0  : Local File FACTOR [FCT]     : Endif : # Factor  SYMEU 06/11/2008
 When 2
  If clalev([F:PIH2])=0 : Local File PINVOICE  [PIH2] : Endif : # En-tęte factures tiers fournisseurs
  If clalev([F:PIL2])=0 : Local File BPSINVLIG [PIL2] : Endif : # Lignes factures tiers fournisseurs
Endcase
Return

$DECLARE_MASQUE
Local Mask VENTILE     [VTL] : # Masque pour répartition analytique
Local Mask VENTILE2    [VT2] : # Masque pour répartition analytique
Local Mask SAICURLED   [SCL] : # Masque pour la gestion des devises
Return

Subprog INI_GLOBAL(CAS, SOCIETE, ASTATUS, MESSA)
Value    Integer CAS       : # 1:factures tiers clients  2:factures tiers fournisseurs
Value    Char    SOCIETE() : # Société
Variable Integer ASTATUS
Variable Char    MESSA()   : # Message erreur

Local Char    LEDCUR(GLONCUR)(1..len(mess(0,2644,1)))
Local Char    COACOLHEA(GLONAX1)(1..len(mess(0,2644,1)))
Local Char    DIECOLHEA(GLONAX1)(1..GOPTCANA)
Local Char    COAFMT(15)(1..len(mess(0,2644,1))) : # Chart of accounts Formats
Local Char    DIEFMT(15)(1..GOPTCANA)            : # Dimension Types Formats
Local Integer DIEOBYFLG(1..GOPTCANA)

Call SETLED(CAS,SOCIETE,GNBTYPLED,GTYPLED,GCODLED,ASTATUS,MESSA) From SUBBICS
If ASTATUS<>[V]CST_AOK : End : Endif
# JGO X3-206524 Third parameter USEDACDIE changed from no to yes
ASTATUS = func FINACM_SYRA.GET_FINREDSTC(GACTX, SOCIETE, 1, GNBTYPLED, GTYPLED, GCODLED, LEDCUR, GPLAN, COAFMT,
&                                     COACOLHEA, GNBAXE, GAXE, DIEFMT, DIECOLHEA, DIEOBYFLG, MESSA)
If ASTATUS<>[V]CST_AOK : GMESSAGE = MESSA : End : Endif
GNBPLAN = GNBTYPLED

Local Tinyint LEDTYPIAS
ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(GACTX, SOCIETE, GTYPGEN, GTYPANA, LEDTYPIAS, MESSA)
If ASTATUS<>[V]CST_AOK : GMESSAGE = MESSA : End : Endif
GSOCIETE = SOCIETE
End

# Renvoie les types de référentiels ŕ gérer pour une société et un type de document
# Renvoie aussi les code des types de référentiels (stockés ds GCM)
Subprog SETLED(CAS,SOCIETE,NBLED,LEDTYP,CODLED,STAT,MESSA)
Value    Integer CAS           : # 1:Factures clients 2:Factures fournisseurs
Value    Char    SOCIETE       : # Société ou site
Variable Integer NBLED         : # Nb de référentiels
Variable Integer LEDTYP(1..)   : # Liste types référentiels
Variable Char    CODLED()(1..10)  : # Liste des codes des types de référentiels
Variable Integer STAT          : # Statut retour
Variable Char    MESSA()       : # Message d'erreur

Local Integer I,IMOD,IREF,NLED
Local Char    MODELE(GLONGCM)

STAT = 0
If clalev([F:IDP])=0 : Local File INVDACPAR [IDP] : Endif
Raz NBLED, LEDTYP , NLED ,CODLED
Read [IDP]IDP0 = SOCIETE ; CAS
If !fstat
 For I=0 To [F:IDP]NBRLED-1
  If [F:IDP]ACCDACFLG(I)=2
   NBLED +=1
   LEDTYP(NBLED)= [F:IDP]LEDTYP(I)
  Endif
 Next
 STAT = func FINACM_SYRA.GET_GCM(GACTX, SOCIETE, MODELE, MESSA)
 If STAT<>[V]CST_AOK : GMESSAGE = MESSA : End : Endif
 IMOD= find(MODELE,GGCM(1..GGCMNBR))
 If !IMOD
  Call GLOBVAR From SETGLBGCM
  IMOD   = find(MODELE,GGCM(1..GGCMNBR))
 Endif
 If IMOD
  For IREF=1 To len(mess(0,2644,1))
   REF = evalue("GLED"+num$(IREF)+"("+num$(IMOD)+")")
   If REF<>"" & !find(REF,CODLED(1..NBLED))
    NLED+=1
    CODLED(NLED) = REF
   Endif
  Next
 Endif
Else
 ## Paramétrage saisie de facture non défini pour la société
 STAT = 99 : MESSA = mess(109,106,1)-SOCIETE : End
Endif
End

Subprog AFFCOL(CAS)
Value Integer CAS
Local Char FMT(10)
Local Integer I, ASTATUS
Case CAS
 When 1 : # Factures clients
  Default Mask [BIC3]
 When 2 : # Factures fournisseurs
  Default Mask [BIS3]
Endcase
For I=1 To GNBPLAN
 Call LECTURE("COA",evalue("GPLAN("+num$(I)+")"),"") From CONTOBJ
 ASTATUS = func FINACC_SYRA.GET_COACOLHEA(GACTX, [F:COA]COA, [M]INTCOA(I-1), GMESSAGE)
 If ASTATUS<>[V]CST_AOK : End : Endif
 [L]ASTATUS = func FINACC_SYRA.GET_COAFMT(GACTX, [F:COA]COA, FMT, GMESSAGE)
 If ASTATUS<>[V]CST_AOK : End : Endif
 FMT = "K:"+FMT
 Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
Next
For I=GNBPLAN+1 To dim([M]FMTCOA)
 FMT = "-K:10X"
 Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
Next
For I=1 To GNBAXE
 Call LECTURE("DIE",evalue("GAXE("+num$(I)+")"),"") From CONTOBJ
 ASTATUS = func FINCCE_SYRA.GET_DIECOLHEA(GACTX, [F:DIE]DIE, [M]INTDIE(I-1), GMESSAGE)
 If ASTATUS<>[V]CST_AOK : End : Endif
 ASTATUS = func FINCCE_SYRA.GET_DIEFMT(GACTX, [F:DIE]DIE, FMT, GMESSAGE)
 If ASTATUS<>[V]CST_AOK : End : Endif
 Call SAI_AMONT([M]CPY,GNBTYPLED,GTYPLED,evalue("GAXE("+num$(I)+")"),[M]SAIAXE(I-1)) From CPTDIV
 If [M]SAIAXE(I-1)=2
  FMT = "K:"+FMT
 Else
  FMT = "-K:"+FMT
 Endif
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
 Assign "[M:VT2]TBDIE("+num$(I-1)+")" With GAXE(I)
Next
For I=GNBAXE+1 To dim([M]FMTDIE)
 FMT = "-K:10X"
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
 Assign "[M:VT2]TBDIE("+num$(I-1)+")" With ""
Next
zoncou = "NBLIG"
Case CAS
 When 1
  Gosub CHG_FMT From W1BIC3
 When 2
  Gosub CHG_FMT From W1BIS3
Endcase
[M]NBLIG=1
Affzo ACC1, ACC2, ACC3, ACC4, ACC5, ACC6, ACC7, ACC8, ACC9, ACC10
Affzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
Affzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
[M]NBLIG=0
Effzo ACC1, ACC2, ACC3, ACC4, ACC5, ACC6, ACC7, ACC8, ACC9, ACC10
Effzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
Effzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
Case CAS
 When 1 : # Factures clients
  Default Mask [BIC1]
 When 2 : # Factures fournisseurs
  Default Mask [BIS1]
Endcase
End

$SETCHPLST
Gosub SETNOL
Raz [M]LSTLED, [M]LSTACC, [M]LSTAXE
Local Integer I, NLED, TLED
For NLED=1 To GNBTYPLED
 Gosub SETCHPLED
Next
Gosub SETCHPAXE
Return

$SETCHPLED
If NOL>=0 & evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")<>""
 TLED = GTYPLED(NLED) : Gosub LECLED
 If NLED>1
  [M]LSTLED += ";" : [M]LSTACC += ";"
 Endif
 [M]LSTLED += [L]LED
 [M]LSTACC += evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
Endif
Return

$SETCHPLED2
If NOL>=0 & evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")<>""
 If NLED>1
  [M]LSTLED += ";" : [M]LSTACC += ";"
 Endif
 [M]LSTLED += GCODLED(NLED)
 [M]LSTACC += evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
Endif
Return

$SETCHPAXE
For I=1 To GNBAXE
 [M]LSTAXE += GAXE(I) : [M]LSTAXE+=";"
Next
If GNBAXE>0
 [M]LSTAXE = left$([M]LSTAXE,len([M]LSTAXE)-1)
Endif
Return

$LECLED
Local Char LED(GLONLED)
Local Char DEV(GLONCUR)
##### BESPR 87307 05/28/2013 # Intercompany enhancement - use Target company for setting the ledgers
If (GFONC1 = "GESBICI" or GFONC1 = "GESBISI") and nolign > 0 and ([M]CPYLIN(nolign-1) <> "")
 STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M]CPYLIN(nolign-1), [L]TLED, LED, DEV, GMESSAGE)
 If STAT<>[V]CST_AOK : Return : Endif
Else
 STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M]CPY, [L]TLED, LED, DEV, GMESSAGE)
 If STAT<>[V]CST_AOK : Return : Endif
Endif
#####
Call LECTURE("LED",[L]LED,"") From CONTOBJ
Return


$INI_OTHACC
If NLED>1
 Local Char    CRIBLE(20)
 Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
 Local Integer INDLED, INDREF
 Local Char SVG_ACC(GLONGAC)
 SVG_ACC = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
 For INDLED=1 To NLED-1
  [L]ACCORG = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
  If [L]ACCORG<>""
   Call LECTURE("GAC",ACCORG,GPLAN(INDLED)) From CONTOBJ
   If find(GPLAN(NLED),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
    Local Integer STAT
    STAT = func FINACC_SYRA.GET_DENACC(GACTX, GPLAN(INDLED), [L]ACCORG, GPLAN(NLED), ACCDES, [L]CRIBLE, GMESSAGE)
    If STAT<>[V]CST_AOK : Return : Endif
    If [L]ACCDES<>""
     ## Le compte du type référentiel NLED a été initialisé par le type référentiel INDLED -> On sort
     INDREF = INDLED : Break
    Endif
   Elsif GPLAN(NLED)=GPLAN(INDLED) : # Demande 55712. Plans de comptes identiques
    [L]ACCDES = [L]ACCORG
    INDREF = INDLED : Break
   Else
    VALEUR="" #YYFIN_X3-35387
    mkstat = 1 : Break
   Endif
  Endif
 Next
 If mkstat : Return : Endif
 If ACCDES = ""
  Return
 Elsif GPLAN(INDREF)<>GPLAN(NLED)
  If SVG_ACC="" | (SVG_ACC<>"" & SVG_ACC<>[L]ACCDES & [L]ACCDES = [L]CRIBLE)
   VALEUR = ACCDES
   If VALEUR<>""
    Call LECTURE("GAC",VALEUR,GPLAN(NLED)) From CONTOBJ
    [M]UOM(NOL) = [F:GAC]UOM
   Else
    [M]UOM(NOL) = ""
   Endif
   If [L]ACCDES = [L]CRIBLE
    mkstat=2 : Return
   Endif
  Else
   VALEUR = SVG_ACC
  Endif
 Elsif GPLAN(NLED)=GPLAN(INDLED) : # Demande 55712. Plans de comptes identiques
  VALEUR = ACCDES : mkstat = 2 : Return
 Endif
Endif
Return

$RECH_ACCGEN
## Recherche du plan et compte du référentiel principal général (théoriquement, saisi dans le champ ACC1)
Local Integer TYPACC
TYPACC = 1 : Gosub RECH_ACC
Return

$RECH_ACCANA
## Recherche du plan et compte du référentiel principal analytique
Local Integer TYPACC
TYPACC = 2 : Gosub RECH_ACC
Return

$RECH_ACC
## <PP > plus tard appeler directement le RECH_ACC du traitement CPTDIV (comme dans SUBPAY)
Gosub SETNOL
Local Char    PLAN(GLONCOA), COMPTE(GLONGAC)
Local Integer TLED
Local Integer INDLED
If clalev([F:LED])=0 : Local File GLED [LED] : Endif
Raz COMPTE, PLAN, INDLED
Case TYPACC
 When 1
  INDLED = find(GTYPGEN,GTYPLED(1..GNBTYPLED))
 When 2
  INDLED = find(GTYPANA,GTYPLED(1..GNBTYPLED))
Endcase
If INDLED
 COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
 PLAN  = evalue("GPLAN("+num$(INDLED)+")")
Endif
## Si pas de compte sur le référentiel principal (général ou analytique selon TYPACC), on regarde s'il y a
## un compte sur un autre type de référentiel (général ou analytique selon TYPACC)...
If COMPTE=""
 For INDLED=1 To GNBTYPLED
  Case TYPACC
   When 1
    If INDLED<>GTYPGEN
     [L]TLED = GTYPLED(INDLED) : Gosub LECLED From SUBBICS
     If [F:LED]GEN=2
      COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
      PLAN  = evalue("GPLAN("+num$(INDLED)+")")
     Endif
    Endif
   When 2
    For INDLED=1 To GNBTYPLED
     If INDLED<>GTYPANA
      [L]TLED = GTYPLED(INDLED) : Gosub LECLED From SUBBICS
      If [F:LED]ANA=2
       COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
       PLAN  = evalue("GPLAN("+num$(INDLED)+")")
      Endif
     Endif
    Next
  Endcase
 Next
Endif
If COMPTE<>""
 Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
Endif
Return


Subprog CONTACC(NLED,VALEUR)
Value Integer NLED    : # Type référentiel
Variable Char VALEUR()
Local Char        CPT(GLONGAC), CRIBLE(30)
Local Integer     I, OK
Local Integer     TLED
Gosub SETNOL
## L'unique collectif et tiers se 'raccroche' au référentiel principal général
[L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
If GTYPLED(NLED) = GTYPGEN
 If VALEUR = "" : [M]SAC(NOL) = "" : End : Endif
Endif
If NLED>1
 Assign "[M]ACC"+num$(NLED)+"("+num$(NOL)+")" With VALEUR
 Local Char    TPLAN(GLONCOA)(1..NLED),TCOMPTE(GLONGAC)(1..NLED), MESSA(250)
 Local Integer I, STAT : STAT = 0
 For I=1 To NLED
  TPLAN(I)   = evalue("GPLAN("+num$(I)+")")
  TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
 Next
 STAT = func FINACC_SYRA.CTL_IPTACC(GACTX, NLED, TPLAN, TCOMPTE, 0, GMESSAGE)
 If STAT<>[V]CST_AOK : mkstat = 2 : End : Endif
Endif
If VALEUR = "" : End : Endif
CPT = VALEUR
If GMODU(2)=2  : # Compta
 If !clalev([F:JCO]) : Local File GJOUCOA [JCO] : Endif
 Call LEC_JCO_LEG(GCURLEG,GPLAN(NLED),[M]JOUCPT) From CPTLEC
 I = find(CPT,[F:JCO]FRQCOD(0..dim([F:JOU]FRQCOD)-1))
 If I
  CPT = [F:JCO]FRQACC(I-1) : # Code d'appel journal
 Else
  Read [GAC]GAC1 = GPLAN(NLED);CPT
  If !fstat
   CPT = [F:GAC]ACC     : # Code d'appel compte
  Endif
 Endif
Endif
Read [GAC]GAC0 >= GPLAN(NLED);CPT
If fstat>2 | left$([F:GAC]ACC,len(CPT))<>CPT
 # Compte inexistant
 GMESSAGE = CPT-mess(44,102,1)
 mkstat = 2 : End
Endif
If func FINACC_SYRA.CTL_ACC(GACTX, GTYPLED(NLED), GPLAN(NLED), [F:GAC]ACC, [M]FCYLIN(NOL), [M]CUR, [M]ACCDAT, 0, 0, GMESSAGE)<>[V]CST_AOK
 mkstat = 2 : End
Endif
## On est sur le type de référentiel général principal -> init/raz collectif et tiers
If GTYPLED(NLED) = GTYPGEN
 If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
 If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
 If [F:GAC]SAC=2
  [M]SAC(NOL) = [F:GAC]ACCSHO
 Else
  [M]BPRLIN(NOL) = "" : [M]SAC(NOL) = ""
 Endif
 ## Check si four n'est pas coché DAS2 et que le compte est coché DAS2 message avertissement
 If func SUBBIC2.FIN_PARAM(GAC_DAS, "CONTROLDAS",[M]CPY)="2"
  If VALEUR <> evalue ("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
   Call LECTURE("BPS",[M]BPR,"") From CONTOBJ
   If ([F:BPS]DADFLG = 1) & ([F:GAC]DAS=2)
    # Attention : compte DAS2 sur fournisseur non DAS2
    OK=2 : Call AVERTIR (mess(74,122,1),OK) From GESECRAN
    If OK<>2 : mkstat = 2 : Endif
   Endif
  Endif
 Endif
Endif
VALEUR      = [F:GAC]ACC
If [M]UOM(NOL)=""
 [M]UOM(NOL) = [F:GAC]UOM
Endif

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func SUBBIC2.FIN_PARAM(GAC_KPO, "PORVAT",[M]FCY) = "2" & GFONCTION <> "GESBIS"
  If NOL > 0
    Local Char CONTANT(GLONGAC) : CONTANT = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL-1)+")")
    Call CTRLCONTA(VALEUR,CONTANT,NLED,[M]CPY) From PORLEGLIB
  Else
   If NBLIG > 0
    Local Char CONTANT(GLONGAC) : CONTANT = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL+1)+")")
    Call CTRLCONTA(VALEUR,CONTANT,NLED,[M]CPY) From PORLEGLIB
   Endif
  Endif
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End

Subprog CONTBPR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Local Char PRIO(10)
Local Char CPTTIERS(GLONGAC), CODCPT(GLONCAC), TIERS(GLONBPR)
Local Char IPLAN(GLONCOA), ICOMPTE(GLONGAC)
Local Integer I, J, OK, INDLED
PRIO = "120"
OK=0
Gosub RECH_ACCGEN From SUBBICS
If COMPTE<>"" : # Au moins un compte renseigné
 For INDLED=1 To GNBTYPLED
  ICOMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
  IPLAN   = evalue("GPLAN("+num$(INDLED)+")")
  If ICOMPTE<>""
   OK = 0
   Call LECTURE("GAC",ICOMPTE,IPLAN) From CONTOBJ
   If [F:GAC]SAC=2
    OK  = [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
    OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
    OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
    OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
    OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
    OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
    If !OK
     # Tiers incompatible avec le collectif
     GMESSAGE = mess(45,106,1)-"\("+[F:GAC]COA-[F:GAC]ACC+"/"+VALEUR+")"
     mkstat = 2 : Break
    Endif
   Else
    OK = 1
   Endif
  Endif
 Next
 If mkstat : End : Endif
Else : # Aucun compte renseigné, on va essayer les déduire ŕ partir du tiers (client ou fournisseur)
 PLAN = GPLAN(1)
 For I=1 To len(PRIO)
  mkstat = 0
  Case mid$(PRIO,I,1)
   When "1"
    If [F:BPR]BPCFLG=2 : # Client ?
     Call LEC_BPC(VALEUR) From CPTLEC
     [L]CODCPT = func FINCAC_SYRA.GET_ACCCOD_BPR(GACTX, GSOCIETE, VALEUR, "C")
     If [L]CODCPT<>""
      Call LECTURE("CAC",[L]CODCPT,"2~"+PLAN) From CONTOBJ
      Call LECTURE("GAC",[F:CAC]ACC(0),PLAN) From CONTOBJ
      If [F:GAC]AUZBPR(0)=2
       Call CONTACC(GTYPGEN,PLAN,[F:GAC]ACC,[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From CPTCNT
       If !mkstat : OK=1 : Break : Endif
      Endif
     Endif
    Endif
   When "2"
    If [F:BPR]BPSFLG=2 : # Fournisseur ?
     Call LEC_BPS(VALEUR) From CPTLEC
     [L]CODCPT = func FINCAC_SYRA.GET_ACCCOD_BPR(GACTX, GSOCIETE, VALEUR, "F")
     If [L]CODCPT<>""
      Call LECTURE("CAC",[L]CODCPT,"3~"+PLAN) From CONTOBJ
      Call LECTURE("GAC",[F:CAC]ACC(0),PLAN) From CONTOBJ
      If [F:GAC]AUZBPR(1)=2
       Call CONTACC(GTYPGEN,PLAN,[F:GAC]ACC,[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From CPTCNT
       If !mkstat : OK=1 : Break : Endif
      Endif
     Endif
    Endif
   When Default
    If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
    Call LECTURE("BPR",VALEUR,"") From CONTOBJ
    If [F:BPR]ACCCOD<>""
     Call LECTURE("CAC",[F:BPR]ACCCOD,"17~"+PLAN) From CONTOBJ
     Call LECTURE("GAC",[F:CAC]ACC(0),PLAN) From CONTOBJ
     If [F:GAC]AUZBPR(5)=2
      Call CONTACC(GTYPGEN,PLAN,[F:GAC]ACC,[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From CPTCNT
      If !mkstat : OK=1 : Break : Endif
     Endif
    Endif
   Endcase
 Next I
 If OK
  ## Initialisation du compte de tous les types de référentiels flagués 'Général' (ŕ condition
  ## que le compte soit de type collectif pour le plan de compte associé au référentiel en question : ce
  ## sera forcément le cas pour le référentiel général principal puisqu'on a accédé au champ BPRLIN)
  NLED=1
  [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
  CPTTIERS = [F:GAC]ACC
  Call LECTURE("GAC",CPTTIERS,PLAN) From CONTOBJ
  If [F:GAC]SAC=2
    Assign "[M]ACC"+num$(GTYPLED(NLED))+"("+num$(NOL)+")" With [F:GAC]ACC
    Gosub AFFACC
  Endif
  [M]SAC(NOL) = [F:GAC]ACCSHO
  Affzo SAC(NOL)
  TIERS = VALEUR
  For NLED = 2 To GNBTYPLED
   [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
   If [F:LED]GEN=2
    Gosub INI_OTHACC From SUBBICS
    If !mkstat & [F:GAC]SAC=2
     Assign "[M]ACC"+num$(GTYPLED(NLED))+"("+num$(NOL)+")" With [F:GAC]ACC
    Else
     Assign "[M]ACC"+num$(GTYPLED(NLED))+"("+num$(NOL)+")" With ""
    Endif
    Raz mkstat
   Else
    Assign "[M]ACC"+num$(GTYPLED(NLED))+"("+num$(NOL)+")" With ""
   Endif
   Gosub AFFACC
  Next
  VALEUR = TIERS
  Call CONTBPR(VALEUR) From SUBBICS
 Else
  # Impossible de déterminer le compte collectif
  GMESSAGE = mess(44,106,1)
  mkstat = 2 : End
 Endif
Endif
End

$AFFACC
Case TLED
 When 1  : Affzo [M]ACC1(NOL)
 When 2  : Affzo [M]ACC2(NOL)
 When 3  : Affzo [M]ACC3(NOL)
 When 4  : Affzo [M]ACC4(NOL)
 When 5  : Affzo [M]ACC5(NOL)
 When 6  : Affzo [M]ACC6(NOL)
 When 7  : Affzo [M]ACC7(NOL)
 When 8  : Affzo [M]ACC8(NOL)
 When 9  : Affzo [M]ACC9(NOL)
 When 10 : Affzo [M]ACC10(NOL)
Endcase
Return


Subprog AM_BPRDAT(VALEUR)
Variable Date    VALEUR
If [M]STA=3 : End : Endif
Local Date SVG_RATDAT
SVG_RATDAT = [M]RATDAT
Call LEC_GTE_LEG(GCURLEG,[M]GTE) From CPTLEC
If [F:GTE]RATDAT=2
 [M]RATDAT = VALEUR
Else
 [M]RATDAT = [M]ACCDAT
Endif
Call CONTDEV(VALEUR,[M]RATDAT) From TRTDEV
If mkstat : End : Endif
If GREP="D"
 Raz [M]STRDUDDAT
Endif
End

Subprog C_SAC(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
Read [GAC]GAC1 = GPLAN(1);VALEUR
If fstat | [F:GAC]SAC<>2
 # Collectif inexistant
 GMESSAGE = VALEUR-mess(9,106,1)
 mkstat = 2 : End
Endif
Call CONTACC(GTYPGEN,GPLAN(1),[F:GAC]ACC,[M]FCYLIN(nolign-1),[M]CUR,[M]ACCDAT) From CPTCNT
If mkstat : End : Endif
[M]ACC1(nolign-1) = [F:GAC]ACC
End

Subprog D_NBRCCE(CODSEC)
Value Char CODSEC()
Local Integer AXE
[M]NBRCCE = GNBAXE
For AXE=1 To GNBAXE
 [M]DIE(AXE-1) = GAXE(AXE)
 Call INISEC([M]CCE(AXE-1),CODSEC,[M]DIE(AXE-1)) From SUBCDE
Next AXE
If dim([M]ZCCE)>0
 Affzo [M]ZCCE
Endif
End

Subprog C_NBRCCE
If adxgtb=2  :# Sortie du tableau
 If clalev([F:CAZ])=0 : Local File CAAUZ [CAZ] : Endif
 For AXE=1 To GNBAXE
  If [M]CCE(AXE-1)<>""
   nolign=AXE
   Call C_CCEH([M]CCE(AXE-1))
   If mkstat
    Break
   Else :# Contrôle interdiction section/section
    Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
    For I=AXE+1 To GNBAXE
     If [M]CCE(I-1)<>""
      Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
      Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
      If !fstat
       # Interdit avec la section
       GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
       mkstat = 1 : Break 2
      Endif
     Endif
    Next
   Endif
  Endif
 Next
Endif
End

Subprog C_CCEH(VALEUR)
Value Char VALEUR()
Local Char AXE(GLONDIE)
AXE = [M]DIE(nolign-1)
If VALEUR="" : End : Endif
Call LECTURE("CCE",VALEUR,[L]AXE) From CONTOBJ
Call VERIF([F:CCE]FCY,[M]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
If [F:CCE]IPT<>2
 GMESSAGE = VALEUR-mess(24,106,1) : # Section non imputable
 mkstat = 1 : End
Endif
Call CONTEXE([F:CCE]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
Call CTLVLYDAT([M]ACCDAT,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
End

Subprog D_QTY(VALEUR)
Variable Decimal    VALEUR()
Local Decimal MONTANT, ARRO, COURS
Local Integer STAT
Gosub SETNOL
Gosub RECH_ACCANA From SUBBICS
If COMPTE<>""
 If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
  Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
  Call CONVERT([M]CUR,GCURSHR,[F:CPY]ACCCUR,[M]CURTYP,[M]RATDAT,[M]AMTNOTLIN(NOL),MONTANT,STAT) From TRTDEV
  VALEUR = MONTANT/[F:GAC]VALUOM
  Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
 Endif
Endif
End

Subprog AS_QTY(VALEUR)
Variable Decimal    VALEUR()
Gosub SETNOL
Gosub RECH_ACCANA From SUBBICS
If COMPTE = ""
 mkstat = 1 : End
Endif
If [F:GAC]FLGUOM<>2 : mkstat = 1 : End : Endif
If [M]STA=3 : mkstat = 2 : End : Endif
Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR()
Gosub SETNOL
Gosub RECH_ACCANA From SUBBICS
If COMPTE = ""
 mkstat=1 : End
Elsif [M]STA=3
 mkstat = 2 : End
Endif
GBOUT1 = mess(23,106,1) : # Répartition ana
GBOUT2 = mess(21,106,1) : # Pourcentage
GBOUT3 = mess(22,106,1) : # Montant
Gosub SETCHPLST From SUBBICS
If dim(GNBSTR)>=0 : GNBSTR=0 : Endif
End

Subprog D_DSP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Gosub RECH_ACCANA From SUBBICS
If COMPTE = ""
 mkstat = 1 : End
Else
 VALEUR = [F:GAC]DSP
Endif
End

Subprog C_DSP(VALEUR)
Variable Char VALEUR()
Local Integer I, OK
Gosub SETNOL
Case VALEUR
 When ""
  End
 When "$"
  If !GIMPORT
   OK  = 1
   OK *= [M]AMTNOTLIN(NOL)=sum([M:VT2]TBAMT([M]PTV(NOL)..[M]PTF(NOL)))
   OK *= [M]QTY(NOL)=sum([M:VT2]TBQTY([M]PTV(NOL)..[M]PTF(NOL)))
   If !OK
    # Répartition déséquilibrée
    GMESSAGE = mess(28,106,1)
    mkstat = 2 : End
   Endif
  Endif
  Gosub RAZCCE
 When Default
  Call CONTDSP(VALEUR,[M]FCYLIN(NOL),[M]ACCDAT) From SUBBIC3
  If mkstat : End : Endif
  [M:VTL]TOTREP = [M]AMTNOTLIN(NOL)
  Raz [M]LSTAXE
  Gosub SETCHPLST From SUBBICS
  Call CHARGE_VTE_STR(VALEUR,[M]UOM(NOL),[M]LSTLED,[M]LSTACC,[M]LSTAXE) From VENTILE
  Call CONTVENT([M]FCYLIN(NOL),[M]ACCDAT) From SAIVENTILE
  If mkstat : End : Endif
  Gosub RAZCCE
Endcase
End

$RAZCCE
For I=1 To GNBAXE
 Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With ""
Next I
Return


Subprog D_CCE(AXE,CODSEC,VALEUR)
Value    Integer AXE      : # N° ordre axe
Value    Char    CODSEC() : # Code section par défaut
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
If [M]DSP(NOL)<>"" : mkstat=1 : End : Endif
Local Integer NLED, TLED
Local Char LED(10)
For NLED=1 To GNBTYPLED
 [L]LED = GCODLED(NLED)
 Call INICCE(VALEUR,GAXE(AXE),[L]LED,evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")"),CODSEC) From CPTINI
 If VALEUR<>"" : Break : End : Endif
Next
#If dim([M]ZCCE)>0
# Affzo [M]ZCCE(NOL)
#Endif
End

Subprog AS_CCE(AXE,VALEUR)
Value    Integer AXE      : # N° ordre axe
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
If [M]DSP(NOL)<>"" :  mkstat = 1 : End : Endif
If GIMPORT | [M]STA=3 : mkstat = 2 : End : Endif : # La saisie est faite dans l'écran ventile
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
Local Integer AXI, IND
mkstat = 1
For NLED=1 To GNBTYPLED
 [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
 Call INDLED([L]LED,GAXE(AXE),IND,AXI) From CPTDIV
 If AXI
  COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
  If COMPTE<>""
   Call LECTURE("GAC",COMPTE,GPLAN(NLED)) From CONTOBJ
   If find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
  Endif
 Endif
Next
End

Subprog C_CCE(AXE,VALEUR)
Value    Integer AXE      : # N° ordre axe
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
For NLED=1 To GNBTYPLED
 COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
 If COMPTE<>""
  [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
  Call CONTCCE(VALEUR,[L]LED,GAXE(AXE),[M]FCYLIN(NOL),[M]ACCDAT,COMPTE,[M]DIE,"[M]CCE#",NOL) From CPTCNT
 Endif
Next
End



#####################################################################################################
#--------------------------------------------------#
# Saisie cours devises                             #
#--------------------------------------------------#
#--------------------------------------------------#
# [M]RATDIV  : Cours diviseur                      #
# [M]LABEL   : Libellé devise pičce Ex: USD =      #
# [M]CURDIV  : Devise pičce                        #
# [M]RATMLT  : Cours multiplicateur                #
# [M]CURMLT  : Devise référentiel général principal#
#--------------------------------------------------#
# Exemple : devise pičce = USD ; devise référentiel = EUR
# Cours multiplicateur...
#    On va saisir : 1 USD = 2 EUR
#    Standard (1) : le cours saisi est par rapport ŕ la devise de pičce
#    Cas particulier (2) : Devise de pičce est IN et différent de EURO avec une devise de référentiels OUT
#                       => saisi des cours par rapport ŕ l'euro
# Cours diviseur...
#    On va saisir : 0.5 USD = 1 EUR
#    Standard (3) : le cours saisi est par rapport ŕ la devise de référentiel
#    Cas particulier (4) : Devise de référentiels est IN et différent de EURO avec une devise de pičce OUT
#                       => saisi des cours par rapport ŕ l'euro
# Les deux...
#    On pourra alors saisir : 2 USD = 4 EUR
Subprog INI_COURS(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS)
Value Char    ABRMSK()
Value Char    SOCIETE()
Value Char    DEVTRS()
Value Date    DATCOURS
Value Integer TYPCOURS
Local Char    MASQUE(10)
MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
Raz [M]LED, [M]CURLED, [M]RATDIV, [M]RATMLT
Call CHARG_ZONES_DEV(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS,0) From SUBBICS
Call GRISE_COURS(ABRMSK) From SUBBICS
Call INIT_COURS(ABRMSK) From SUBBICS
End

Subprog CHARGE_COURS(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS)
Value Char    ABRMSK()
Value Char    SOCIETE()
Value Char    DEVTRS()
Value Date    DATCOURS
Value Integer TYPCOURS
Local Char    MASQUE(10)
MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
Call CHARG_ZONES_DEV(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS,0) From SUBBICS
Call GRISE_COURS(ABRMSK) From SUBBICS
End


Subprog CHARG_ZONES_DEV(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS,NOLI)
Value Char    ABRMSK()
Value Char    SOCIETE()
Value Char    DEVTRS()
Value Date    DATCOURS
Value Integer TYPCOURS
Value Integer NOLI
Local Char MASQUE(10)
If clalev([M:SCL])=0  : Local Mask SAICURLED [SCL]  : Endif : # Masque pour la gestion des devises
If clalev([F:GCM])=0  : Local File GACM      [GCM]  : Endif : # Modčles comptables

MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
Local Char CODLED(GLONLED)
Local Char DEVLED(GLONCUR)
Local Integer I, J, STAT
Raz [M:SCL]
# Position des devises par rapport ŕ l'Euro
Call SETFLGDEV(DEVTRS,SOCIETE,DATCOURS) From CPTDIV

For J=1 To len(mess(0,2644,1))
 Call LECLED(SOCIETE,J,CODLED,DEVLED) From CPTDIV
 If dim([M]LED)>0
  [M]LED(J-1) = CODLED
 Else # dim(evalue("[M]LED"+num$(J)+"("+num$(NOLI-1)+")"))>0
  Assign "[M]LED"+num$(J)+"("+num$(NOLI-1)+")" With CODLED
 Endif
 If dim([M]CURLED)>0
  [M]CURLED(J-1) = DEVLED
 Else : # dim(evalue("[M]CURLED"+num$(J)+"("+num$(NOLI-1)+")"))>0
  Assign "[M]CURLED"+num$(J)+"("+num$(NOLI-1)+")" With DEVLED
 Endif
 If DEVLED=[L]DEVTRS
  [M]RATDIV(J-1) = 1
  [M]RATMLT(J-1) = 1
 Elsif DEVLED<>DEVTRS
  # Déjŕ gérée par un autre type de référentiel ?
  K = find(DEVLED,[M:SCL]CURLED(0..[M:SCL]NBRC-1))
  If J=1 or [F:GCM]FLGVCRRAT(J-1)=1 or ([F:GCM]FLGVCRRAT(J-1)=2 & !K)
   [M:SCL]IDT(I) = mess(J,2644,1)
   [M:SCL]LEDTYP(I) = J
   [M:SCL]CUR(I) = DEVTRS                                                            #(1)
   If GCURFLG=2 & DEVTRS<>GEURO & GLEDFLG(J)=1 : [M:SCL]CUR(I)=GEURO : Endif         #(2)
   [M:SCL]CURLED(I) = DEVLED
   If GCURFLG=1 & DEVLED<>GEURO & GLEDFLG(J)=2 : [M:SCL]CURLED(I)=GEURO : Endif      #(4)
   [M:SCL]IDT(I) = mess(J,2644,1)
   I+=1
  Elsif [F:GCM]FLGVCRRAT(J-1)=2 & K : # type cours pičce = 'Oui'
   [M:SCL]IDT(K-1)    = "*"
  Endif
  Gosub INIT_COURS_LED
 Endif
 If J = GTYPGEN
  If  dim([M]RAT1)>0   : [M]RAT1   = [M]RATDIV(J-1) : Endif
  If  dim([M]LABEL)>0  : [M]LABEL  = [L]DEVTRS-"="  : Endif
  If  dim([M]CURDIV)>0 : [M]CURDIV = [L]DEVTRS      : Endif # Zone invisible
  If  dim([M]RAT2)>0   : [M]RAT2   = [M]RATMLT(J-1) : Endif
  If  dim([M]CURMLT)>0 : [M]CURMLT = [M]CURLED(J-1) : Endif
 Endif
Next
[M:SCL]NBRC = I
Call GRISE_COURS(ABRMSK)
Affzo [M:SCL]
If dim([M]RATDIV)>0 : Affzo RATDIV : Endif
If dim([M]LABEL)>0  : Affzo LABEL  : Endif
If dim([M]CURDIV)>0 : Affzo CURDIV : Endif
If dim([M]RATMLT)>0 : Affzo RATMLT : Endif
If dim([M]CURMLT)>0 : Affzo CURMLT : Endif
End

$INIT_COURS_LED
Local Decimal COURS
If [F:GCM]FLGVCRRAT(J-1)=2
 COURS = TYPCOURS
Else
 COURS = [F:GCM]TYPRAT(J-1)
Endif
##
## BY 08/08/06
##
Local Decimal COURMUL, COURDIV
If dim([M]CURLED)>0
 Local Integer STAT
 Call INI_COURS2(DEVTRS,[M]CURLED(J-1),COURS,DATCOURS,COURDIV,COURMUL,STAT) From SUBSCL
 Case [F:GCM]DACRAT(J-1)
  When 1 : # Multiplicateur
   If [M]RATMLT(J-1)=0 &  [M]RATDIV(J-1)=0 : # <PP 150> Rajout condition, sinon on ecrase les cours forcés...
    If STAT
     [M]RATMLT(J-1) = 0
     [M]RATDIV(J-1) = 1
    Else
     [M]RATMLT(J-1) = arr(COURMUL/COURDIV,10^-GDECRCU)
     [M]RATDIV(J-1) = 1
    Endif
   Endif
  When 2 : # Diviseur
   If [M]RATMLT(J-1)=0 &  [M]RATDIV(J-1)=0  : # <PP 150> Rajout condition, sinon on ecrase les cours forcés...
    If STAT
     [M]RATDIV(J-1) = 0
     [M]RATMLT(J-1) = 1
    Else
     [M]RATDIV(J-1) = arr(COURDIV/COURMUL,10^-GDECRCU)
     [M]RATMLT(J-1) = 1
    Endif
   Endif
  When 3 : # Les 2
    If [M]RATMLT(J-1)=0 &  [M]RATDIV(J-1)=0  : # <PP 150> Rajout condition, sinon on ecrase les cours forcés...
     If STAT
      [M]RATMLT(J-1) = 0
      [M]RATDIV(J-1) = 0
     Else
      [M]RATMLT(J-1) = COURMUL
      [M]RATDIV(J-1) = COURDIV
    Endif
   Endif
 Endcase
Else
 Local Integer STAT
 Call INI_COURS2(DEVTRS,evalue("[M]CURLED"+num$(J)+"("+num$(NOLI-1)+")"),COURS,DATCOURS,COURDIV,COURMUL,STAT) From SUBSCL
 Case [F:GCM]DACRAT(J-1)
  When 1 : # Multiplicateur
   If evalue("[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")")=0 & evalue("[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")")=0
    If STAT
     Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With 0
     Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With 1
    Else
     # Issue X3-85710
     If COURDIV
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With arr(COURMUL/COURDIV,10^-GDECRCU)
     Else
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With 0
     Endif
     Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With 1
    Endif
   Endif
  When 2 : # Diviseur
    If evalue("[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")")=0 & evalue("[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")")=0
     If STAT
      # Issue X3-85710
      If COURMUL
       Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With arr(COURDIV/COURMUL,10^-GDECRCU)
      Else
       Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With 1
      Endif
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With 1
     Else
      # Issue X3-85710
      If COURMUL
       Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With arr(COURDIV/COURMUL,10^-GDECRCU)
      Else
       Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With 1
      Endif
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With 1
     Endif
    Endif
   When 3 : # Les 2
    If evalue("[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")")=0 & evalue("[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")")=0
     If STAT
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With 0
      Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With 0
     Else
      Assign "[M]RATMLT"+num$(J)+"("+num$(NOLI-1)+")" With COURMUL
      Assign "[M]RATDIV"+num$(J)+"("+num$(NOLI-1)+")" With COURDIV
     Endif
    Endif
 Endcase

Endif
Return

## Ancien
##
Case [F:GCM]DACRAT(J-1)
 When 1,3 :
  # Multiplicateur
  If [M]RATDIV(J-1)=0
   [M]RATDIV(J-1)=1
  Endif
  If [M]RATMLT(J-1)=0
   Call CONVERT(DEVTRS,[M]CURLED(J-1),[F:CPY]ACCCUR,COURS,[M]RATDAT,10^GDECRCU,[M]RATMLT(J-1),STAT) From TRTDEV
   If !STAT
    [M]RATMLT(J-1)  = arr([M]RATMLT(J-1)/10^GDECRCU, 10^-GDECRCU)
   Endif
  Endif
 When 2
  # Diviseur
  If [M]RATMLT(J-1)=0
   [M]RATMLT(J-1)=1
  Endif
  If [M]RATDIV(J-1)=0
   Call CONVERT([M]CURLED(J-1),DEVTRS,[F:CPY]ACCCUR,COURS,[M]RATDAT,10^GDECRCU,[M]RATDIV(J-1),STAT) From TRTDEV
   If !STAT
    [M]RATDIV(J-1)  = arr([M]RATDIV(J-1)/10^GDECRCU, 10^-GDECRCU)
   Endif
  Endif
Endcase
Return

Subprog INIT_COURS(ABRMSK)
Value Char ABRMSK
# REMPLISSAGE du masque SAICURLED [SCL]
If clalev([M:SCL])=0 : Local Mask SAICURLED [SCL] : Endif # Masque pour la gestion des devises
Local Char MASQUE(10)
MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
For J=0 To min([M:SCL]NBRC-1,len(mess(0,2644,1)))
 [M:SCL]RATDIV(J)  = [M]RATDIV([M:SCL]LEDTYP(J)-1)
 [M:SCL]RATMLT(J)  = [M]RATMLT([M:SCL]LEDTYP(J)-1)
 [M:SCL]RATDIV1(J) = [M:SCL]RATDIV(J)
 [M:SCL]RATMLT1(J) = [M:SCL]RATMLT(J)
Next
End

#-------------------------------------------------------------------------#
# WILDCATS 20180130 ------------------------------------------------------#
# Allow to import RATDIV and RATMLT fields, when existing in the template #
# and valuated in the file, taking into account the ACM rate entry value  #
#-------------------------------------------------------------------------#
# IMPSCRIPT: Template used for the invoice file imported                  #
##
#-------------------------------------------------------------------------#
# Issue X3-18618
Subprog IMP_CUR_RAT_APAR_INVOICES(IMPSCRIPT)

  Value Char IMPSCRIPT
  Local Tinyint I, J

  For I = 0 To dim([F:GCM]LED) - 1
    If [F:GCM]LED(I) <> ""
      Case [F:GCM]DACRAT(I)
        When 1  # Multiplier
          Case IMPSCRIPT
          When "BIS1"
            If [F:PIH]RATMLT(I) <> 0 and [F:PIH]CUR <> [F:GCM]CUR(I)
              [M:BIS1]RATMLT(I) = [F:PIH]RATMLT(I)
            Endif
          When "BIC1"
            If [F:SIH]RATMLT(I) <> 0 and [F:SIH]CUR <> [F:GCM]CUR(I)
              [M:BIC1]RATMLT(I) = [F:SIH]RATMLT(I)
            Endif
          Endcase
        When 2  # Divider
          Case IMPSCRIPT
          When "BIS1"
            If [F:PIH]RATDIV(I) <> 0 and [F:PIH]CUR <> [F:GCM]CUR(I)
              [M:BIS1]RATDIV(I) = [F:PIH]RATDIV(I)
            Endif
          When "BIC1"
            If [F:SIH]RATDIV(I) <> 0 and [F:SIH]CUR <> [F:GCM]CUR(I)
              [M:BIC1]RATDIV(I) = [F:SIH]RATDIV(I)
            Endif
          Endcase
        When 3  # Both
          Case IMPSCRIPT
          When "BIS1"
            If [F:PIH]RATMLT(I) <> 0 and [F:PIH]CUR <> [F:GCM]CUR(I)
              [M:BIS1]RATMLT(I) = [F:PIH]RATMLT(I)
            Endif
            If [F:PIH]RATDIV(I) <> 0 and [F:PIH]CUR <> [F:GCM]CUR(I)
              [M:BIS1]RATDIV(I) = [F:PIH]RATDIV(I)
            Endif
          When "BIC1"
            If [F:SIH]RATMLT(I) <> 0 and [F:SIH]CUR <> [F:GCM]CUR(I)
              [M:BIC1]RATMLT(I) = [F:SIH]RATMLT(I)
            Endif
            If [F:SIH]RATDIV(I) <> 0 and [F:SIH]CUR <> [F:GCM]CUR(I)
              [M:BIC1]RATDIV(I) = [F:SIH]RATDIV(I)
            Endif
          Endcase
      Endcase
    Endif
  Next I

  # Rates must be the same for all ledgers with the same Currency, same Doc rate type,
  # and same Rate type. Under these conditions, the correct rate is assumed to be the
  # lowest-indexed one.
  #
  # In any other case, we take the values from the import file. If any value is
  # missing, the corresponding one in X3 is used.

  For I = 0 To dim([F:GCM]LED) - 1
    For J = I + 1 To dim([F:GCM]LED) - 1
      If [F:GCM]CUR(I) = [F:GCM]CUR(J) and [F:GCM]CUR(I) <> ""
&     and [F:GCM]FLGVCRRAT(I) = [F:GCM]FLGVCRRAT(J)
&     and [F:GCM]TYPRAT(I) = [F:GCM]TYPRAT(J)
          Case IMPSCRIPT
            When "BIS1"
              [M:BIS1]RATMLT(J) = [M:BIS1]RATMLT(I)
              [M:BIS1]RATDIV(J) = [M:BIS1]RATDIV(I)
            When "BIC1"
              [M:BIC1]RATMLT(J) = [M:BIC1]RATMLT(I)
              [M:BIC1]RATDIV(J) = [M:BIC1]RATDIV(I)
          Endcase
      Endif
    Next J
  Next I

End
# End Issue X3-18618

#--------------------------------------------------#
# Grisage des cours saisis                         #
#--------------------------------------------------#
# [M]RAT1, [M]RATDIV(10) : Cours diviseur          #
# [M]RAT2, [M]RATMLT(10) : Cours multiplicateur    #
#--------------------------------------------------#
## En gestion de facture, on n'affiche dans l'en-tęte uniquement le cours entre la devise de transaction
## et la devise du référentiel général principal. Les cours des autres référentiels sont accessibles via
## le bouton 'Cours devises'
Subprog GRISE_COURS(ABRMSK)
Value Char ABRMSK()
If dim([M]RAT1)<=0 or dim([M]RAT2)<=0 : End : Endif
Case [F:GCM]DACRAT(GTYPGEN-1)
 When 1 :
  # Multiplicateur
  [M]RAT1 = 1 : Diszo [M]RAT1 : Actzo [M]RAT2
 When 2 :
  # Diviseur
  [M]RAT2 = 1 : Diszo [M]RAT2 : Actzo [M]RAT1
 When 3 :
  # Les deux
  Actzo [M]RAT1, RAT2
Endcase
# Devise IN
If GCURFLG=2 and GLEDFLG(GTYPGEN)=2
 Diszo [M]RAT1, RAT2
Endif
End

######################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return


