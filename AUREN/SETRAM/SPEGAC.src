# GestiÛn de la m·scara GAC1 (Especifico)

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla GAC1) 21/02/2011 11:45:27 (ADMIN)
######################################################################################
$ACTION

Case ACTION
 
 When "LIENS"             : Gosub LIENS
 When "VERIF_CRE"         : Gosub VERIF_CRE
 When "VERIF_MOD"         : Gosub VERIF_CRE

 When Default  
Endcase
Return




$LIENS
 
 If [M:GAC1]ACCSHO<> ""
     Actzo [M:GAC1]ZTIPACCSHO

 Else    
     [M:GAC1]ZTIPACCSHO =0 
     Affzo [M:GAC1]ZTIPACCSHO
     Grizo [M:GAC1]ZTIPACCSHO
 Endif

Return

$VERIF_CRE
    
    If [M:GAC1]ACCSHO <> "" and [M:GAC1]ZTIPACCSHO = 0
        GERR=1 
        GMESSAGE="Se ha de indicaar si el Colectivo (CÛdigo de llamada) es de tipo General o Intersociedad." 
        OK=0 
    Endif    
    
Return



######################################################################################

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla GAC1) 21/02/2011 12:06:21 (ADMIN)
######################################################################################
Subprog AP_ACCSHO(VALEUR)
Variable Char    VALEUR()

    If VALEUR <> ""
     Actzo [M:GAC1]ZTIPACCSHO
     If [M:GAC1]ZTIPACCSHO = 0 
        [M:GAC1]ZTIPACCSHO =1 
        Affzo [M:GAC1]ZTIPACCSHO
     Endif
    Else
         Grizo [M:GAC1]ZTIPACCSHO

    Endif
End



