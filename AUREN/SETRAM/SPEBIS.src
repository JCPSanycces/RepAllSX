Subprog AP_INVNUM(VALEUR)
Variable Char VALEUR()
# AUREN - PU9
# Copia de la rutina AP_INVNUM de SUBBIS2
If [M:BIS0]INVTYP=2 & VALEUR=""
 Local Char CHAINE(10)
 Call PARAM([M]FCY,"WRNINVOICE",CHAINE) From ADOVAL
 If val(CHAINE)=2
  Local Integer OK
  OK = 2
########################################################################
# Modificación para no visualizar mensaje en caso de llamada
# desde WEBSERVICE
########################################################################
#  If !GIMPORT : Call AVERTIR(mess(9,119,1),OK) From GESECRAN : Endif
If !GIMPORT & GWEBSERV <> 2: Call AVERTIR(mess(9,119,1),OK) From GESECRAN : Endif
# Avoir sans numéro de facture
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
# AUREN - PU9
End

