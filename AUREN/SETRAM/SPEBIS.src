######################################################################################

$AVANTBOUT

Local Char NUMREGTOT
Local Char WNUMCONT
Local Integer STAT
Local Decimal NUMOBTENIDO

# AUREN - DSM - Llamada Externa
If BOUT="y"
#Infbox "#@\\172.16.1.131\VBEXE\COMPLEMENTOSX3\TAMPONPDF\MODPDF.exe RANGOTAMPON " + [M:BIS0]NUM + " " + GUSER
#  Char FICHIERS(200)(50)
