Variable Char    VALEUR()
     If !GIMPORT & GWEBSERV <> 2
         Read [F:ZPS] ZPS01=[M:BIS0]BPR; [M:BIS0]CPY
          If    fstat=0
            VALEUR= [F:ZPS]ZACCGTO
          Endif
    Endif
End


