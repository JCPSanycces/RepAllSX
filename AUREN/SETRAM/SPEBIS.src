######################################################################################
##     Z18 - Verificar is hay facturas coincidentes en los siguientes casos:
##           Igual Sociedad, Proveedor e importe
##           Igual Sociedad, Proveedor, importe y fecha de factura
######################################################################################
Subprog CONTROL_FACTURAS_COINCIDENTES(SOCIEDAD, IMPORTE, PROVEEDOR, FECHA, RSLT)
Variable Char SOCIEDAD
Variable Decimal IMPORTE
Variable Char PROVEEDOR
Variable Date FECHA
Variable Integer RSLT

    RSLT=0
    If !GWEBSERV
       If SOCIEDAD <> ""  & PROVEEDOR <> ""

          If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif

          # Igual Sociedad, Proveedor e importe
          Filter [PIHB] Where CPY= SOCIEDAD and BPR = PROVEEDOR and AMTNOT = IMPORTE and BPRDAT <> FECHA

          Read [PIHB]PIH0 First
          If fstat=0
              # Si existen facturas
                RSLT = 1

          Else
                If FECHA <> [0/0/0]
                    Filter [PIHB]
                    # Igual Sociedad, Proveedor, importe y fecha de factura
                    Filter [PIHB] Where CPY= SOCIEDAD  and BPRDAT = FECHA and AMTNOT = IMPORTE   and BPR = PROVEEDOR
                    Read [PIHB]PIH0 First
                    If fstat=0
                         # Si existen facturas
                        RSLT = 1
                    Endif
                Endif
          Endif
          Filter [PIHB]

       Endif

    Endif

End


