######################################################################################

######################################################################################
##### 18/02/2011    AUDITORIA
######################################################################################
## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria
Subprog CARGAR_AUDITORIA()
Local Char TEXTOMENU
Local Char DESCRIPCION_DPTO
    Raz [M:ZBIS]
    #AUREN - PU9
    #CRITERE = "[AUD]TBL = 'PINVOICE' and [AUD]ID1 = [M:BIS0]NUM"
    CRITERE = "([AUD]TBL = 'PINVOICE' or [AUD]TBL = 'ZPINVOICEA')and [AUD]ID1 = [M:BIS0]NUM"
    #AUREN - PU9
    Filter [AUD]
    Filter [AUD] Where evalue(CRITERE) Order By Key CLE=[F:AUD]SEQ
    NOL = 0
    For [AUD]

        ### AŃDIR LÍNIA CABECERA SI EVENTO INSERT (Modif 20/04/2011)

    #AUREN - PU9
        #If [F:AUD]EVT="INSERT"
        If [F:AUD]EVT="INSERT"  and [F:AUD]TBL<>"ZPINVOICEA"
    #AUREN - PU9

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZBIS]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZBIS]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZBIS]SEQ(NOL) = [F:AUD]SEQ
            [M:ZBIS]TBL(NOL) = [F:AUD]TBL
            [M:ZBIS]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZBIS]HOU(NOL) = [F:AUD]HOU
            [M:ZBIS]EVT(NOL) = [F:AUD]EVT
            [M:ZBIS]ID1(NOL) = [F:AUD]ID1
            [M:ZBIS]ADRCLI(NOL) = [F:AUD]ADRCLI

            NOL += 1
            nolign = NOL

        Endif


        If [F:AUD]EVT<>"INSERT"

        Filter [AUL]
        ### Para cada registro de cabecera de auditoria, se aĂ±adirĂˇ una lĂ­nea por cada campo afectado
        # NO AŃADIR LINEA DETALLE SI EVENTO TIPO INSERT  (Modif 20/04/2011)

        Filter [AUL] Where SEQ=[F:AUD]SEQ

        For [AUL]

            Read [XAUS2]CODUSR= [F:AUD]ADOUSR: If fstat Raz [F:XAUS2] : Endif
            [M:ZBIS]ADOUSR(NOL) = [F:AUD]ADOUSR + "-" + [F:XAUS2]NOMUSR

            [M:ZBIS]SYSUSR(NOL) = [F:AUD]SYSUSR
            [M:ZBIS]SEQ(NOL) = [F:AUD]SEQ
            [M:ZBIS]TBL(NOL) = [F:AUD]TBL
            [M:ZBIS]DAT(NOL) = num$(day([F:AUD]DAT)) +"/" + num$(month([F:AUD]DAT)) +"/" + num$(year([F:AUD]DAT) ) + " " +  num$(left$([F:AUD]HOU,2)) + ":"   +  num$(mid$([F:AUD]HOU,3,2)) + ":" + num$
& (right$([F:AUD]HOU,5))


            [M:ZBIS]HOU(NOL) = [F:AUD]HOU
            [M:ZBIS]EVT(NOL) = [F:AUD]EVT
            [M:ZBIS]ID1(NOL) = [F:AUD]ID1
            [M:ZBIS]ADRCLI(NOL) = [F:AUD]ADRCLI


             Read [XATZ]CODZONE= 'PINVOICE';[F:AUL]COL
             If fstat
                #AUREN - PU9
                #Raz [F:XATZ]
                Read [XATZ]CODZONE= 'ZPINVOICEA';[F:AUL]COL
                If fstat
                  Raz [F:XATZ]
                Endif
                #AUREN - PU9
             Endif

            ### Nombre de la columna
            Read [XATX]NUMERO= 'SPA';[F:XATZ]NOLONG
             If fstat
                Raz [F:XATX]
             Endif
            ### (Modif 21/04) No incluir nombre de columna, solo descripción
            #[M:ZBIS]ZDESCCAMPO(NOL) = [F:AUL]COL + "-" + [F:XATX]TEXTE
            [M:ZBIS]ZDESCCAMPO(NOL) = [F:XATX]TEXTE



            ### Valores de la columna

            If [F:AUL]COL = "ZDEP"

                Call OBTENER_NOMBRE_DPTO([F:AUL]OVAL, DESCRIPCION_DPTO) From SPEZAF
                [M:ZBIS]ZVALORANT(NOL)=   [F:AUL]OVAL + "-" + DESCRIPCION_DPTO

                Call OBTENER_NOMBRE_DPTO([F:AUL]NVAL , DESCRIPCION_DPTO) From SPEZAF
                [M:ZBIS]ZVALORACT(NOL)=   [F:AUL]NVAL + "-" + DESCRIPCION_DPTO

            Else
                If [XATZ]CODTYP = "M"
                    ### SI ES UN CAMPO TIPO MENU
                    If len([F:AUL]OVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]OVAL) From SPEZAF
                        [M:ZBIS]ZVALORANT(NOL)= TEXTOMENU

                    Endif
                    If len([F:AUL]NVAL)> 0

                        Call OBTENERTEXTOMENU(TEXTOMENU,[F:AUL]COL, [F:XATZ]NOLIB, [F:AUL]NVAL) From SPEZAF
                        [M:ZBIS]ZVALORACT(NOL)= TEXTOMENU

                    Endif
                Else
                    [M:ZBIS]ZVALORANT(NOL)=   [F:AUL]OVAL
                    [M:ZBIS]ZVALORACT(NOL)=   [F:AUL]NVAL
                Endif
            Endif

            NOL += 1
            nolign = NOL

        Next
        Filter [AUL]

        Endif

    Next

    Filter [AUD]
    [M:ZBIS]NBLIGA = NOL

    Affzo [M:ZBIS]


End


##############################################################
## AUREN Específico 84 Control correspondencia Regimen - Tasa
##############################################################

Subprog AM_VAT(VALEUR)
Variable Char    VALEUR()

    If VALEUR <> ""
        Read [F:Z35]Z350=VALEUR;[M:BIS1]VAC
        If fstat
            Call ERREUR("La tasa " + VALEUR + " no tiene correspondecia con el Regimen " + [M:BIS1]VAC) From GESECRAN
            mkstat=2
        Endif
    Endif
End

