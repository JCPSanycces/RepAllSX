    If BOUT= "w"
#AUREN - PU9
        WNUMCONT = "ZNR"

        If !GIMPORT & GWEBSERV <> 2
            If len([M:BIS1]ZNUMREG)=0
                If len([M:BIS0]CPY) > 0
                    If ([M:BIS0]ACCDAT) <> [0/0/0]

                        GOK=1
                        Call NUMERO (WNUMCONT ,[M:BIS0]CPY,[M:BIS0]ACCDAT,"",NUMREGTOT,STAT) From SUBANM
                        If STAT = 0

                            If len(NUMREGTOT) < 12
                                 GERR=1:GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro. Vuelva a pulsar el botón de Escaneo." : GOK=0 : Return

                            Else

                                ### Comprobar que el número que ha devuelto sea coherente
                                Read [F:XAVN]AVN0 = WNUMCONT;[M:BIS0]CPY;0
                                If    fstat
                                    GERR=1
                                    GMESSAGE = "Se ha producido un error en la verificación del Num. Registro. Vuelva a pulsar el botón de Escaneo"
                                    GOK=0
                                    Return
                                Else
                                    NUMOBTENIDO = val(right$(NUMREGTOT,4))
                                    NUMOBTENIDO  = [F:XAVN]VALEUR - NUMOBTENIDO
                                    If NUMOBTENIDO  > 1
                                        GERR=1
                                        GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro. Vuelva a pulsar el botón de Escaneo"
                                        GOK=0
                                        Return
                                    Endif
                                Endif


                                #### 22/02/2011 : Eliminado ańo y aumentado longitud Nu, secuencia a 9
                                #[F:PIH]ZNUMREG= right$(NUMREGTOT,6)
                                [F:PIH]ZNUMREG= right$(NUMREGTOT,4)
                                ####  FIN

                                [M:BIS1]ZNUMREG=[F:PIH]ZNUMREG
                                Affzo [M:BIS1]ZNUMREG

                            Endif

                        Else
                           # problema durante la recuperación del contador
                           GERR=1:GMESSAGE = "Se ha producido un error al recuperar el siguiente Num. Registro" : GOK=0 : Return
                        Endif
                    Else
                        GERR=1
                        GMESSAGE = "No se puede obtener Num. Registro. Falta Fecha Contable."
                        GOK=0
                        Return
                    Endif
                Else
                   GERR=1
                   GMESSAGE = "No se puede obtener Num. Registro. Falta Sociedad."
                   GOK=0
                   Return
                Endif
            Endif
        Endif
    Endif
Return


######################################################################################
##  Z18  Control facturas Coincidentes
##         JMD 20/09/2010 CAMBIO DE FUNCIONALIDAD: SOLO SE HA DE COMPROBAR
##         AL PULSAR EL BOTON ESCANER
######################################################################################

Subprog LLAMADA_VERIFICAR_FACTURAS_COINCIDENTES_BOTON_ESCANER
  Local Integer RSLT
  RSLT=0


    If !GIMPORT & GWEBSERV <> 2

        Call CONTROL_FACTURAS_COINCIDENTES([M:BIS0]ZCPY,[M:BIS1]ZAMTNOT,[M:BIS0]ZBPR ,[M:BIS1]ZBPRDAT, RSLT)

        If RSLT <> 0

           # Presentar Ventana

         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "ZFACTERC"
## AUREN - DSM - Abril 2013 - Compras
        PARMSK(1) = "BIS"
        PARMSK(2) = [M:BIS0]ZCPY
        PARMSK(3) = [M:BIS0]ZBPR
        PARMSK(4) = num$([M:BIS1]ZAMTNOT)
        PARMSK(5) = [M:BIS1]ZBPRDAT
## AUREN - DSM - Abril 2013 - Compras
         #Call SAISIE_CHAR(VALEUR,PARMSK,"ZFACTERC","","SPEFACTERC") From GSAISIE
         Call SAISIE_NUM([M:BIS1]ZAMTNOT,PARMSK,"ZFACTERC","","SPEFACTERC") From GSAISIE

         GACTION = SAVACT


        Endif
    Endif



End

