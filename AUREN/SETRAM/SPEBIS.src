######################################################################################
##     Z18 - Documento Origen: No permitir espacios en blanco
######################################################################################
Subprog C_BPRVCR(VALEUR)
Variable Char    VALEUR()
Local Integer ESPACIOS

    ESPACIOS= 0
    ESPACIOS= instr(1,VALEUR, " ")
    If ESPACIOS <> 0
         Call ERREUR("No se permiten espacios.") From GESECRAN
          mkstat=2

    Endif
End



######################################################################################

######################################################################################
##     Z18 - Control factura duplicada: No permitir si ya existe otra factura
##           con igual Sociedad, ańo factura, NIF del proveedor y documento origen
######################################################################################
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
#Subprog CONTROL_FACTURA_DUPLICADA()
$CONTROL_FACTURA_DUPLICADA
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
Local Integer DUPLICADO
Local Char NIF


    DUPLICADO=0

    If clalev([BPR1])<=0 Local File BPARTNER[BPR1] : Endif

    #Acceder al proveedor en la tabla de terceros y obtener su NIF
    Read [F:BPR1]BPR0=[M:BIS0]BPR
    If    fstat=0
          NIF= [F:BPR1]CRN
          If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif

          # Buscar todos los terceros (proveedor) con el mismo NIF
          # Para cada proveedor encontrAdo, verificar si existen facturas que cumplan las condiciones
          For [BPR1]BPR0 Where CRN = NIF
              Filter [PIHB]

              Filter [PIHB] Where CPY= [M:BIS0]CPY and year(BPRDAT) = year([M:BIS1]BPRDAT) and BPRVCR = [M:BIS1]BPRVCR and BPR= [F:BPR1]BPRNUM

              Read [PIHB]PIH0 First

              While not fstat
                  # Si se encuentra una coincidencia y es Crear o Duplicar
                  If GREP = "C"  | GREP = "D"
                     DUPLICADO= 1
                     Break
                  Else
                    # Si es modificación y no se trata de la factura en curso
                    If  [M:BIS0]NUM <> [F:PIHB]NUM
                        DUPLICADO= 1
                        Break
                    Endif
                  Endif
                 Read [PIHB]PIH0 Next
              Wend
              Filter [PIHB]
          Next

          Close Local File [BPR1]
    Endif


    If DUPLICADO <> 0
        GERR=1
        GMESSAGE="Ya existe una factura con igual Sociedad/NIF proveedor/Ańo fecha doc. origen/Documento origen."
        OK=0
    Endif

#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
#End
Return
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures

