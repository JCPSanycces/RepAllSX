#<AdxTL>@(#)0.0.0.0 $Revision$ Factura tercero proveedor
######################################################################################
### Mantenimiento de Facturas de Compra                          JGM -- 15/06/2009 ###
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"             : Gosub OUVRE
        When "OUVRE_BOITE"       : Gosub OUVRE_BOITE
        When "SETBOUT"           : Gosub SETBOUT
        When "EXEBOUT"           : Gosub EXEBOUT
        When "RAZDUP"            : Gosub RAZDUP
        When "RAZCRE"            : Gosub RAZCRE
        When "APRES_CRE"         : Gosub APRES_CRE
        When "VERIF_CRE"         : Gosub VERIF_CRE
        When "VERIF_MOD"         : Gosub VERIF_MOD
        When "APRES_MOD"         : Gosub APRES_MOD
        When "FIN_MOD"         : Gosub FIN_MOD
        When "AVANT_ACT"         : Gosub AVANT_ACT
        When "CREATION"            : Gosub CREATION
        When "LIENS"             : Gosub LIENS
        When "AVANTBOUT"           : Gosub AVANTBOUT
        ######################################################################################
        #        Z27  GestiĂłn terminaciĂłn colectivo sociedad/tercero
        ######################################################################################
        When "INICRE"           : Gosub INICRE
        When "INIMOD"           : Gosub INICRE
        ######################################################################################
        When "STYLE"            : Gosub OCULTAR

        When Default
    Endcase
Return
######################################################################################
#        Z07  CONDICIONES PAGO SOCIEDADES  / Z09 ESCANER-ACEPTACIÓN
######################################################################################
$OUVRE
    Local File ZCPGPRVSOC[ZPS]
    If clalev([F:ZDT])=0  : Local File ZDPTO     [ZDT]  : Endif
    If clalev([F:XAOX])=0 : Local File AOBJTXT   [XAOX] : Endif

     #### 04/01/2011 Incidencia condiciones pago
    If clalev([F:BPS2])=0 : Local File BPSUPPLIER   [BPS2] : Endif

     ### ZAU 24/01/2011 Visualizar nif del proveedor
    If clalev([F:BPR2])=0 : Local File BPARTNER[BPR2] : Endif
    ###   fin ZAU

    If clalev([F:XAVN])=0 : Local File AVALNUM   [XAVN] : Endif

    ##### AUREN Específico 84 - Cod Actividad Z35
    If clalev([F:Z35])=0 :  Local File ZREGVAT   [Z35] : Endif
    ##### FIN AUREN Específico 84 - Cod Actividad Z35

## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria
    If clalev([F:AUD])=0 : Local File AUDITH      [AUD] : Endif
    If clalev([F:AUL])=0 : Local File AUDITL      [AUL] : Endif
    If clalev([F:XAUS2])=0 : Local File AUTILIS  [XAUS2] : Endif
    If clalev([F:XATZ])=0 :  Local File ATABZON   [XATZ] : Endif
    If clalev([F:XAST])=0 :  Local File APLSTD   [XAST] : Endif
    If clalev([F:XATX])=0 :  Local File ATEXTE   [XATX] : Endif
## AUREN - DSM - Abril 2013 - Compras - Cargar Auditoria

#AUREN - PU9
# AUREN - DSM - 08/10/2011 - Especifico 74 - Cuenta contable por departament
#If clalev([F:ZDA])=0 : Local File ZDPTACC [ZDA] : Endif
# AUREN - DSM - 08/10/2011 - Especifico 74 - Cuenta contable por departamento
#AUREN - PU9

#AUREN - PU9
    If clalev([F:ZPX])=0  : Local File ZPINVOICEA     [ZPX]  : Endif
#AUREN - PU9
Return
######################################################################################
$OUVRE_BOITE
    Grizo [M:BIS1]ZACEPTA
    Grizo [M:BIS0]ZESCAN
    Gosub OCULTAR
Return
######################################################################################


$CREATION
Return

######################################################################################
#        Z27  GestiĂłn terminaciĂłn colectivo sociedad/tercero
######################################################################################

$INICRE
Local Char TERMINACION
Local Char CUENTA
Local Integer MODIFCOLECTIVO
Local Integer ERRORCOLECTIVO



    MODIFCOLECTIVO=0
    #SĂłlo en interactivo
    If !GIMPORT & GWEBSERV <> 2 & len([M:BIS0]BPRSAC) > 0
       Call TERMINACION_COLECTIVO([M:BIS0]CPY, [M:BIS0]BPR, [M:BIS0]BPRSAC, TERMINACION, CUENTA, MODIFCOLECTIVO, ERRORCOLECTIVO) From ZTERMCOLECT
       If ERRORCOLECTIVO = 1
            GERR=1
            GMESSAGE = "Error en Terminación colectivo. Revise la configuración."
            GOK=0
            Return

       Else
            If len(TERMINACION) > 0  or  MODIFCOLECTIVO = 1

                # Si hay terminaciĂłn: aĂ±adirla al colectivo

                [M:BIS0]BPRSAC =  [M:BIS0]BPRSAC + TERMINACION
                Affzo  [M:BIS0]BPRSAC
                [F:PIH]BPRSAC =  [M:BIS0]BPRSAC

                #Poner Cuenta asociada al colectivo
                [M:BIS0]SACACC = CUENTA
                Affzo  [M:BIS0]SACACC

                Infbox "Colectivo/Cuenta modificado." Titled "Información"
            Endif
       Endif
    Endif


Return



######################################################################################
##      Z18 Control facturas Coincidentes
######################################################################################
$LIENS

    Gosub OCULTAR
    If !GIMPORT & GWEBSERV <> 2
         [M:BIS0]ZCPY = [M:BIS0]CPY
         [M:BIS0]ZBPR = [M:BIS0]BPR
         [M:BIS1]ZBPRDAT = [M:BIS1]BPRDAT
         [M:BIS1]ZAMTNOT = [M:BIS1]AMTNOT

        Affzo [M:BIS0]ZCPY, ZBPR
        Affzo [M:BIS1]ZAMTNOT, ZBPRDAT

        ## 24/01/2011  ZAU Acceder al proveedor en la tabla de terceros y obtener su NIF
        Read [F:BPR2]BPR0=[M:BIS0]BPR
         If    fstat=0
          [M:BIS0]ZNIF= [F:BPR2]CRN
         Affzo [M:BIS0]ZNIF
         Endif
        ##      FIN

        ##### 22/02/2001    AUDITORIA
        Call CARGAR_AUDITORIA
    Endif

# AUREN - PU9
    Read [F:ZPX]ZPX0=[M:BIS0]NUM
    If fstat=0
      [M:BIS1]ZMOTIVR = [F:ZPX]ZMOTIVR
      [M:BIS1]ZMOTIVD = [F:ZPX]ZMOTIVD
      [M:BIS1]ZOBSLIQ = [F:ZPX]ZOBSLIQ
      Affzo [M:BIS1]ZMOTIVR
      Affzo [M:BIS1]ZMOTIVD
      Affzo [M:BIS1]ZOBSLIQ
    Endif
# AUREN - PU9

Return




######################################################################################
##      Z09  CONTROL ESCANER
######################################################################################

$SETBOUT
    If [M]ZESCAN = 2 or [M]STA = 3 # or [M]NUM = ""
    # AUREN PU9
#        Call VIREBOUT(CHAINE,"Z") From GOBJET     #Boton Escaneado
        Call VIREBOUT(CHAINE,"w") From GOBJET     #Boton Escaneado
    # AUREN PU9
    Endif

    If [M]ZESCAN <> 2
        Call VIREBOUT(CHAINE,"V") From GOBJET     #Boton Validar
     Call VIREBOUT(CHAINE,"U") From GOBJET     #Boton Modificar imagen

    Endif

    If GREP = "D"
        #Call VIREBOUT(CHAINE,"Z") From GOBJET     #Boton Escaneado
         Call VIREBOUT(CHAINE,"U") From GOBJET     #Boton Modificar imagen

    Endif

    If GREP = "D"
         Call VIREBOUT(CHAINE,"U") From GOBJET     #Boton Modificar imagen
    Endif


    If [M]STA = 3
        Call VIREBOUT(CHAINE,"M") From GOBJET     #Boton Registrar deshabilitado si factura validada
    Endif

 ## AUREN - DSM - Junio 2013 - Compras - Control Facturas abono
    If [M:BIS0]PIVTYP = "ABO"
        Grizo [M:BIS1]PTE
        Grizo [M:BIS1]STRDUDDAT
    Else
        Actzo [M:BIS1]PTE
        Actzo [M:BIS1]STRDUDDAT
    Endif
 ## AUREN - DSM - Junio 2013 - Compras - Control Facturas abono


Return
######################################################################################

######################################################################################
##      Z09  CONTROL ESCANER
######################################################################################

$EXEBOUT
    If [M]NUM = "" : Return : Endif
      # AUREN - PU9
#    Case REP
#        When "Z" :  # Despues de la ejecucción del boton escaner
#        AFFICHE = 1 : Gosub RELIT From GOBJSUB
#    Endcase
    Case REP
        When "w" :  # Despues de la ejecucción del boton escaner
        AFFICHE = 1 : Gosub RELIT From GOBJSUB
    Endcase
      # AUREN - PU9
Return
######################################################################################


######################################################################################
##      Z09  CONTROL ESCANER
######################################################################################

$RAZDUP
# AUREN - DSM - EA108 - DUPLICACION FACTURAS TERCERO PROVEEDOR
    Raz [M:BIS0]ACCDAT
    Raz [M:BIS1]BPRVCR
    Raz [M:BIS1]BPRDAT
    Raz [M:BIS1]STRDUDDAT
    Raz [M:BIS1]DUDDAT
    Raz [M:BIS1]ZDUDDAT

    Raz  [M:BIS1]ZMOTIVR
    Raz  [M:BIS1]ZMOTIVD
    Raz  [M:BIS1]ZRECEPDAT
    Affzo [M:BIS0]ACCDAT
    Affzo [M:BIS1]BPRVCR
    Affzo [M:BIS1]BPRDAT
    Affzo [M:BIS1]ZMOTIVR
    Affzo [M:BIS1]ZMOTIVD
    Affzo [M:BIS1]ZRECEPDAT
    Affzo  [M:BIS1]STRDUDDAT
    Affzo [M:BIS1]DUDDAT
    Call AM_FCY([M:BIS0]FCY) From SPEBIS
    Gosub CONTROL_TIPO_FACTURA
# AUREN - DSM - EA108 - DUPLICACION FACTURAS TERCERO PROVEEDOR
    Raz [M:BIS1]ZNUMREG

# AUREN Assistencia 4.876.126
    Read [ZDT]ZDP0 = [M:BIS1]ZDEP : If fstat Raz [F:ZDT] : Endif
    [M:BIS1]ZUS1 = [F:ZDT]ZUS1
    [M:BIS1]ZUS2 = [F:ZDT]ZUS2
    Affzo [M:BIS1]ZUS1
    Affzo [M:BIS1]ZUS2
# FI AUREN Assistencia 4.876.126


# lp
If GIMPORT <> 1
    [M:BIS0]ZESCAN = 1
Endif

#    [M:BIS0]ZESCAN = 1
    Affzo [M:BIS0]ZESCAN
    Affzo [M:BIS1]ZNUMREG

   ###  Z09 22/02/2011 Si tipo de documento es Abono ==> Estado = Aceptado
   #[M:BIS1]XFLGPAZ = 1
   # Correcció compres X3
    If [M:BIS0]PIVTYP ="ABO" & GIMPORT
     # [M:BIS1]ZACEPTA = 1
     # [M:BIS1]XFLGPAZ = 1
       [M:BIS1]ZACEPTA = 5
       [M:BIS1]XFLGPAZ = 2
    Else
        [M:BIS1]ZACEPTA = 1
        [M:BIS1]XFLGPAZ = 1
    Endif
    ########## FIN



    Affzo [M:BIS1]XFLGPAZ
    Affzo [M:BIS1]ZACEPTA

    [M:BIS0]ZESCDAT=date$
    Affzo [M:BIS0]ZESCDAT


Return
######################################################################################
$RAZCRE

    Gosub OCULTAR

    If GIMPORT = 1 : Return : Endif

    ###  Z09 22/02/2011 Si tipo de documento es Abono ==> Estado = Aceptado
    #[M:BIS1]XFLGPAZ = 1
    # Correcció Compres X3
    If [M:BIS0]PIVTYP ="ABO" & GIMPORT
      # [M:BIS1]ZACEPTA = 1
      # [M:BIS1]XFLGPAZ = 1
        [M:BIS1]ZACEPTA = 5
        [M:BIS1]XFLGPAZ = 2
    Else
        [M:BIS1]ZACEPTA = 1
        [M:BIS1]XFLGPAZ = 1
    Endif
    ########## FIN


    Affzo [M:BIS1]XFLGPAZ
    Affzo [M:BIS1]ZACEPTA

    #####################################################################################
    ##      Z18  Facturas coincidentes
    ######################################################################################
    If !GIMPORT & GWEBSERV <> 2
        Raz [M:BIS0]ZCPY
        Raz [M:BIS0]ZBPR
        Raz [M:BIS1]ZBPRDAT
        Raz [M:BIS1]ZAMTNOT

        Affzo [M:BIS0]ZCPY, ZBPR
        Affzo [M:BIS1]ZAMTNOT , ZBPRDAT
    Endif
Return
######################################################################################
$APRES_CRE

    ###########################################
    ## Cambio solicitado por SETRAM 17/09/2010
    ###########################################
    #If GREP = "D" : Return : Endif

    ######################################################################################
    ###  12/11/10 CORRECION INCIDENCIA ESCANER EN DUPLICADOS
    ######################################################################################
    #If GREP = "D"
    #    Gosub REPLICA
    #    Return
    #Endif
    ######################################################################################

    Gosub ACTION From SUBBIS : GPE =1

    ######################################################################################
    ###
    ###  12/11/10 CORRECION INCIDENCIA ESCANER EN DUPLICADOS: SE HA DE HACER DESDE EL PUNTO
    ###           DE ENTRADA GOBJSUB->GESOBJET
    ######################################################################################

    If GREP <> "D"
        Update [XAOX] Where IDENT1 = num$(adxuid(1)) With IDENT1 = [M]NUM
        If fstat
            GOK=0 : Rollback : Call FSTA("XAOX") From GLOCK : Return
        Endif
    Endif

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
    Gosub CALCULO_FECHA_INICIO_CALC_VENC
## AUREN - DSM - OCT 2013 - Desactiva el recalcul només notificar si la data d'inici de cŕlcul varia
##    If clalev([F:PIH])=0 : Local File PINVOICE[PIH] : Endif
##    [F:PIH]STRDUDDAT = [M:BIS1]STRDUDDAT
##    Update [PIH] Where NUM = [M:BIS0]NUM With STRDUDDAT= [M:BIS1]STRDUDDAT
##    # Se borrán los vencimientos existentes ya que se han cálculado con la fecha contable y se vuelven a crear
##    If clalev([F:DUD])=0 : Local File GACCDUDATE[DUD] : Endif
##    Delete [DUD] Where TYP = [M:BIS0]GTE and NUM = [M:BIS0]NUM
##    Call CREECHE(2,1,1,[F:PIH]PAZ) From SUBBIH
##    If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
##    Filter [DUD] Where TYP=[M:BIS0]GTE & NUM=[M:BIS0]NUM
##    Read [DUD] DUD0 First : If fstat Raz [F:DUD] : Endif
##    Filter [DUD]
##    [M:BIS1]DUDDAT=[F:DUD]DUDDAT
##    If [M:BIS1]ZDUDDAT <> [M:BIS1]DUDDAT

    Gosub REPLICA

    If [M:BIS1]BPRDAT <> [M:BIS1]STRDUDDAT
## AUREN - DSM - OCT 2013 - Desactiva el recalcul només notificar si la data d'inici de cŕlcul varia
        Gosub NOTIFICACION_CAMBIO_VENCIMIENTOS
    Endif
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

#AUREN - PU9
Gosub ZPINVOICEAUX_MANT
#AUREN - PU9

Return
######################################################################################
$VERIF_CRE

    ###################################################################
    ##    ZAU 10/03/2011 No permitir facturas sin Condiciones de pago
    ###################################################################
    If [M:BIS1]PTE =""
        GERR=1
        GMESSAGE="No se ha introducido Condicion pago."
        OK=0
        Return
    Endif

## AUREN - DSM - Assistencia 05.234.534 - Control Venciments
    If [M:BIS1]DUDDAT = [0/0/0] & [M:BIS0]PIVTYP<>"ABO"
        GERR=1
        GMESSAGE="No existen vencimientos - por favor contacte con el personal técnico"
        OK=0
        Return
    Endif
## AUREN - DSM - Assistencia 05.234.534 - Control Venciments


## AUREN - Assistencia 05.862.538 - Factura sin departamento
## El campo es obligatorio, pero en alguna ocasión se ha podido generar factura sin departamento
## No se ha podido reproducir, se pone este control para más seguridad.
    If [M:BIS1]ZDEP = ""
        GERR=1
        GMESSAGE="No se ha introducido Departamento"
        OK=0
        Return
    Endif
## AUREN - Assistencia 05.862.538 - Factura sin departamento

    ###################################################################
    ##    Z18 Se ha de ejecutar antes la acción del estandar, ya que en
    ##        caso de que el específico detecte un error (variables GERR
    ##        y GOK) el estandar borra estas variables
    ###################################################################

    Gosub VERIF_CRE From SUBBIS
    GPE=1
    If GERR = 1
        Return
    Endif
    ###################################################################


    ###################################################################
    ##    Z18 No permitir facturas duplicadas
    ###################################################################
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
#    Call CONTROL_FACTURA_DUPLICADA()
    Gosub CONTROL_FACTURA_DUPLICADA
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
    If GERR = 1
        Return
    Endif
    ###################################################################

# lp
If GIMPORT = 1 : Return : Endif

    If [M:BIS0]ZESCAN <> 2
        GERR=1
        GMESSAGE="Factura no escaneada. Creación Imposible"
        OK=0
        Return
    Endif

    ###################################################################
    ##    Z18 No permitir crear facturas sin línea
    ###################################################################
        If [M:BIS3]NBLIG= 0
            GERR=1
            GMESSAGE="No se permite crear una factura sin líneas."
            OK=0
            Return
        Else
            ### 21/03/2011 No se permiten facturas con importe 0
            If [M:BIS1]AMTNOT = 0
                GERR=1
                GMESSAGE="No se permite crear una factura con Importe AI = 0."
                OK=0
                Return
            Endif
            If [M:BIS1]AMTATI = 0
                GERR=1
                GMESSAGE="No se permite crear una factura con Importe II = 0."
                OK=0
                Return
            Endif

        Endif



    ###################################################################

    ###################################################################
    ###
    ###    26/01/2011  Para prevenir la incidencia que se producido
    ###                en algunos casos
    ###################################################################
    If [M:BIS1]ZNUMREG = ""
         GERR=1
        GMESSAGE="No se permite crear una factura sin Número de registro."
        OK=0
        Return
    Endif

## Correcció Compras X3 Fecha recepción = fecha fra proveedor si Importación WS
    If GWEBSERV = 1
        [M:BIS1]ZRECEPDAT=[M:BIS1]BPRDAT
    Endif
## Correcció Compras X3 fin

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
    Gosub CALCULO_FECHA_INICIO_CALC_VENC
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

Return

###################################################################
##    Z18 No permitir crear facturas duplicadas
###################################################################

$VERIF_MOD

    ###################################################################
    ##    ZAU 10/03/2011 No permitir facturas sin Condiciones de pago
    ###################################################################
    If [M:BIS1]PTE =""
        GERR=1
        GMESSAGE="No se ha introducido Condicion pago."
        OK=0
        Return

    Endif
## AUREN - DSM - Assistencia 05.234.534 - Control Venciments
    If [M:BIS1]DUDDAT = [0/0/0]
        GERR=1
        GMESSAGE="No existen vencimientos - por favor contacte con el personal técnico"
        OK=0
        Return
    Endif
## AUREN - DSM - Assistencia 05.234.534 - Control Venciments


    ###################################################################
    ##    Z18 Se ha de ejecutar antes la acción del estandar, ya que en
    ##        caso de que el específico detecte un error (variables GERR
    ##        y GOK) el estandar borra estas variables
    ###################################################################

    Gosub VERIF_MOD From SUBBIS
    GPE=1
    If GERR = 1
        Return
    Endif
    ###################################################################


    ### 21/03/2011 No se permiten facturas con importe 0

    If [M:BIS3]NBLIG= 0
        GERR=1
        GMESSAGE="No se permite crear una factura sin líneas."
        OK=0
        Return
    Else
        If [M:BIS1]AMTNOT = 0
            GERR=1
            GMESSAGE="No se permite crear una factura con  Importe AI = 0."
            OK=0
            Return
        Endif
        If [M:BIS1]AMTATI = 0
            GERR=1
            GMESSAGE="No se permite crear una factura con  Importe II = 0."
            OK=0
            Return
        Endif
    Endif

    ###################################################################

    ###################################################################
    ###
    ###    26/01/2011  Para prevenir la incidencia que se producido
    ###                en algunos casos
    ###################################################################
    If [M:BIS1]ZNUMREG = ""
         GERR=1
        GMESSAGE="No se permite modificar una factura sin Número de registro."
        OK=0
        Return

    Endif

    ###################################################################
    ##    Z18 No permitir facturas duplicadas
    ###################################################################

#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
#    Call CONTROL_FACTURA_DUPLICADA()
    Gosub CONTROL_FACTURA_DUPLICADA
#20/06/2011 - AUREN - DSM - Assistencia 01.979.479 - Rebutjar factures
    If GERR = 1
        Return
    Endif
    ###################################################################

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
    Gosub CALCULO_FECHA_INICIO_CALC_VENC
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

Return

######################################################################################
Subprog AM_ZDEP(VALEUR)
    Variable Char    VALEUR()

    Read [ZDT]ZDP0 = VALEUR : If fstat Raz [F:ZDT] : Endif
    [M:BIS1]ZUS1 = [F:ZDT]ZUS1
    [M:BIS1]ZUS2 = [F:ZDT]ZUS2

    Affzo [M:BIS1]35
End
