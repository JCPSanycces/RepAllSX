######################################################################################


$REPLICA
## 21.08.13. LPardo. Agrego el doble tratamiento para facturas tercero proveedor o facturas de compra.
Local File ZPINVOICE [ZPI]
Local File BPSINVLIG [ZIL]
Local File BPSINVLIGA [ZIK]
Local File PINVOICED [ZID]
Local File GACCDUDATE [ZIM]
Local File CPTANALIN [ZIZ]
Local File ITMMASTER [ZIT]

[ZPI]NUM = [F:PIH]NUM
[ZPI]PIVTYP = [F:PIH]PIVTYP
[ZPI]BPR = [F:PIH]BPR
[ZPI]BPRSAC = [F:PIH]BPRSAC
[ZPI]CPY = [F:PIH]CPY
[ZPI]BPRDAT = [F:PIH]BPRDAT
[ZPI]BPRVCR = [F:PIH]BPRVCR
[ZPI]CUR = [F:PIH]CUR
[ZPI]PTE = [F:PIH]PTE
[ZPI]VAC = [F:PIH]VAC
[ZPI]PAZ = [F:PIH]PAZ
[ZPI]AMTATI = [F:PIH]AMTATI
[ZPI]AMTNOT = [F:PIH]AMTNOT
[ZPI]ZDEP = [F:PIH]ZDEP
[ZPI]ZACEPTA = [F:PIH]ZACEPTA
[ZPI]ZNUMREG = [F:PIH]ZNUMREG
[ZPI]ZESCDAT = [F:PIH]ZESCDAT
[ZPI]ZDEPPROD = [F:PIH]ZDEPPROD
# AUREN - PU9
[ZPI]RATCUR = [F:PIH]RATMLT
# AUREN - PU9

# 07.12.2010. FECHA CONTABLE Y PLANTA.
[ZPI]ACCDAT = [F:PIH]ACCDAT
[ZPI]FCY = [F:PIH]FCY
# 07.12.2010

# 09.10.2013. información extra para timeless
[ZPI]ORIMOD = [F:PIH]ORIMOD
# 09.10.2013. información extra para timeless

If [F:PIH]ORIMOD = 3 Then
  ## tercero proveedor
  Filter [ZIL] Where NUM = [F:PIH]NUM
  For [ZIL]
    [ZPI]NUMLIG    = [ZPI]NUMLIG + num$([ZIL]LIG)+'|'
    [ZPI]ACC       = [ZPI]ACC + [ZIL]ACC+'|'
    [ZPI]AMTNOTLIN = [ZPI]AMTNOTLIN + num$([ZIL]AMTNOTLIN)+'|'

    Filter [ZIK] Where NUM = [F:PIH]NUM and LIG = [ZIL]LIG
    For [ZIK]
      [ZPI]AMT  = [ZPI]AMT + num$([ZIK]AMT)+'\'
      [ZPI]CCE0 = [ZPI]CCE0 + [ZIK]CCE(0)+'\'
      [ZPI]CCE1 = [ZPI]CCE1 + [ZIK]CCE(1)+'\'
      [ZPI]CCE2 = [ZPI]CCE2 + [ZIK]CCE(2)+'\'
      [ZPI]CCE3 = [ZPI]CCE3 + [ZIK]CCE(3)+'\'
      [ZPI]CCE4 = [ZPI]CCE4 + [ZIK]CCE(4)+'\'
      [ZPI]CCE5 = [ZPI]CCE5 + [ZIK]CCE(5)+'\'
      [ZPI]CCE6 = [ZPI]CCE6 + [ZIK]CCE(6)+'\'
      [ZPI]CCE7 = [ZPI]CCE7 + [ZIK]CCE(7)+'\'
      [ZPI]CCE8 = [ZPI]CCE8 + [ZIK]CCE(8)+'\'
    Next
    [ZPI]AMT  = [ZPI]AMT +'|'
    [ZPI]CCE0 = [ZPI]CCE0 +'|'
    [ZPI]CCE1 = [ZPI]CCE1 +'|'
    [ZPI]CCE2 = [ZPI]CCE2 +'|'
    [ZPI]CCE3 = [ZPI]CCE3 +'|'
    [ZPI]CCE4 = [ZPI]CCE4 +'|'
    [ZPI]CCE5 = [ZPI]CCE5 +'|'
    [ZPI]CCE6 = [ZPI]CCE6 +'|'
    [ZPI]CCE7 = [ZPI]CCE7 +'|'
    [ZPI]CCE8 = [ZPI]CCE8 +'|'
    Filter [ZIK]
  Next
  Filter [ZIL]
  [ZPI]PROD = 2
Else
  ## circuito compras
  Local Char CODART
  Filter [ZID] Where NUM = [F:PIH]NUM
  For [ZID]
    If CODART = '' Then
      Filter [ZIT] Where ITMREF = [ZID]ITMREF
      Read [ZIT]ITM0 First
      CODART = [ZIT]TCLCOD
      Filter[ZIT]
    Endif
    [ZPI]NUMLIG    = [ZPI]NUMLIG    + num$([ZID]PIDLIN) + '|'

    Filter [ZIZ] Where  VCRNUM = [F:PIH]NUM and VCRLIN = [ZID]PIDLIN
    Read [ZIZ] CAL0 First
    [ZPI]ACC       = [ZPI]ACC       + [ZIZ]ACC(0) + '|'

    [ZPI]AMTNOTLIN = [ZPI]AMTNOTLIN + num$([ZID]AMTNOTLIN) + '|'

    # 09.10.2013. información extra para timeless
    [ZPI]PEDIDO    = [ZPI]PEDIDO    + [ZID]POHNUM + '|'
    # 09.10.2013. información extra para timeless

    [ZPI]AMT  = [ZPI]AMT + num$([ZID]AMTNOTLIN) + '|'
    [ZPI]CCE0 = [ZPI]CCE0 + num$([ZIZ]CCE(0)) + '|'
    [ZPI]CCE1 = [ZPI]CCE1 + num$([ZIZ]CCE(1)) + '|'
    [ZPI]CCE2 = [ZPI]CCE2 + num$([ZIZ]CCE(2)) + '|'
    [ZPI]CCE3 = [ZPI]CCE3 + num$([ZIZ]CCE(3)) + '|'
    [ZPI]CCE4 = [ZPI]CCE4 + num$([ZIZ]CCE(4)) + '|'
    [ZPI]CCE5 = [ZPI]CCE5 + num$([ZIZ]CCE(5)) + '|'
    [ZPI]CCE6 = [ZPI]CCE6 + num$([ZIZ]CCE(6)) + '|'
    [ZPI]CCE7 = [ZPI]CCE7 + num$([ZIZ]CCE(7)) + '|'
    [ZPI]CCE8 = [ZPI]CCE8 + num$([ZIZ]CCE(8)) + '|'
  Next
  Filter [ZID]
  [ZPI]PROD = 1
  If CODART = 'PRODU' Then
    [ZPI]PROD = 2
  Endif
Endif

Filter [ZIM] Where NUM = [F:PIH]NUM  Order By NUM Desc
For [ZIM]
  [ZPI]DUDDAT = [ZIM]DUDDAT
Next


Write [ZPI]
Close Local File [ZPI]
Close Local File [ZIL]
Close Local File [ZIK]
Close Local File [ZID]
Close Local File [ZIM]
Close Local File [ZIZ]
Close Local File [ZIT]

Return


