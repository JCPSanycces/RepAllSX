######################################################################################
Subprog AM_ZACEPTA(VALEUR)
    Variable Integer VALEUR
    # Correcció compres X3
    If !GIMPORT
    If VALEUR = 5
        [M:BIS1]XFLGPAZ = 4
    Else
        [M:BIS1]XFLGPAZ = VALEUR
    Endif
    Endif
End
######################################################################################
######################################################################################


######################################################################################
## Z07  CONDICIONES PAGO SOCIEDADES
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()


  ######################################################################################
  ##      Z18  Control facturas Coincidentes
