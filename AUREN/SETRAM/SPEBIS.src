## AUREN - DSM - Junio 2013 - Compras - Control Facturas abono
#####################################################################################

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
######################################################################################
$CALCULO_FECHA_INICIO_CALC_VENC
Local Integer VARINTANYMESFACPROV
Local Integer VARINTANYMESFACESCA
Local Date VARDESFECCALC
Local Integer VARFORZARCALC: VARFORZARCALC = 0
# 5.773.157 cambio cálculo fórmula
# Las facturas recibidas hasta la fecha de corte (día 15 del mes siguiente a la fecha de la factura),
# utilizarán como fecha de inicio de cálculo de vencimiento la fecha de factura. Todas las demás
# utilizarán la fecha de recepción
#
#    VARCARANYMESFACPROV = year([M:BIS1]BPRDAT) * 12 + month([M:BIS1]BPRDAT)
#    VARINTANYMESFACESCA = year([M:BIS0]ZESCDAT) * 12 + month([M:BIS0]ZESCDAT)
#    If VARCARANYMESFACPROV  = VARINTANYMESFACESCA
#        VARDESFECCALC = [M:BIS1]BPRDAT
#    Elsif VARCARANYMESFACPROV  < (VARINTANYMESFACESCA -1)
#        VARDESFECCALC = [M:BIS1]ZRECEPDAT
#    # Correcció Compras X3
#    #Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & day([M:BIS1]ZRECEPDAT)<16
#    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:BIS1]ZRECEPDAT < gdat$(16,month([M:BIS0]ZESCDAT),year([M:BIS0]ZESCDAT)))
#        VARDESFECCALC = [M:BIS1]BPRDAT
#    # Correcció Compras X3
#    #Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & day([M:BIS1]ZRECEPDAT)>15
#    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:BIS1]ZRECEPDAT > gdat$(15,month([M:BIS0]ZESCDAT),year([M:BIS0]ZESCDAT)))
#        VARDESFECCALC = [M:BIS1]ZRECEPDAT
#    Endif

    VARCARANYMESFACPROV = year([M:BIS1]BPRDAT) * 12 + month([M:BIS1]BPRDAT)
    VARINTANYMESFACESCA = year([M:BIS1]ZRECEPDAT) * 12 + month([M:BIS1]ZRECEPDAT)
    If VARCARANYMESFACPROV  = VARINTANYMESFACESCA
        VARDESFECCALC = [M:BIS1]BPRDAT
    Elsif VARCARANYMESFACPROV  < (VARINTANYMESFACESCA -1)
        VARDESFECCALC = [M:BIS1]ZRECEPDAT
    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:BIS1]ZRECEPDAT < gdat$(16,month([M:BIS1]ZRECEPDAT),year([M:BIS1]ZRECEPDAT)))
        VARDESFECCALC = [M:BIS1]BPRDAT
    Elsif VARCARANYMESFACPROV  =  (VARINTANYMESFACESCA -1) & ([M:BIS1]ZRECEPDAT > gdat$(15,month([M:BIS1]ZRECEPDAT),year([M:BIS1]ZRECEPDAT)))
        VARDESFECCALC = [M:BIS1]ZRECEPDAT
    Endif
# 5.773.157 FIN cambio cálculo fórmula

    [M:BIS1]ZDUDDAT = [M:BIS1]DUDDAT

    #Si ya se ha realizado algun cálculo
    If [M:BIS1]DUDDAT <> [0/0/0]
        # Se actualiza la fecha de inico de vencimiento si no es abono
        If [M:BIS0]PIVTYP <> "ABO"
            [M:BIS1]STRDUDDAT = VARDESFECCALC
        Endif
    Endif
    Affzo [M:BIS1]STRDUDDAT
Return
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento

## AUREN - DSM - Abril 2013 - Compras - Fecha recepción - Calculo Fecha inicio cálculo vencimiento
