######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BIS1) 25/06/2013 15:09:40 (ADMIN)
######################################################################################
Subprog C_ZRECEPDAT(VALEUR)
Variable Date    VALEUR
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción
## Correcció Compras X3 -> Control solo en interactivo
    If !GIMPORT & GWEBSERV <> 1
        If VALEUR < [M:BIS1]BPRDAT
              Call ERREUR("Fecha Recepción no puede ser inferior a la fecha de factura del proveedor") From GESECRAN
              mkstat=2
        Endif
        If VALEUR > date$
              Call ERREUR("Fecha Recepción no puede ser superior a la fecha de sistema") From GESECRAN
              mkstat=2
        Endif
    Endif
## AUREN - DSM - Abril 2013 - Compras - Fecha recepción
End



######################################################################################
##     EA109 - Control que no permita la introducción de la factura si existe un pedido no saldado (pendiente de facturar) del mismo proveedor e importe de la factura
##         EL control debe indicar el número pedido que se ha localizado con estas características para informar al usuario de la situación
##         Y la factura deberá ser introducida en el módulo de compras.
######################################################################################
$CONTROL_PEDIDO_NO_SALDADO
Local Char VARPEDIDO
Local Integer VARDUPLICADO
    VARDUPLICADO = 0
    VARPEDIDO = " / "
    If clalev([POH])<=0 Local File PORDER[POH] : Endif
    Filter [POH]
    #Filter [POH] Where INVFCY = [M:BIS0]FCY and BPSNUM = [M:BIS0]BPR and CLEFLG = 1 and TOTORD = [M:BIS1]AMTNOT
    Filter [POH] Where INVFCY = [M:BIS0]FCY and BPSNUM = [M:BIS0]BPR and CLEFLG = 1
    For [POH]
        VARPEDIDO = VARPEDIDO + [F:POH]POHNUM + " / "
        VARDUPLICADO += 1
    Next
    Filter [POH]
    If VARDUPLICADO >0
#        GERR=2
        If VARDUPLICADO >1
#            GMESSAGE="Ya existen varios pedidos no saldados " + VARPEDIDO+ " del mismo proveedor e importe"
#            GMESSAGE="Existen varios pedidos no saldados " + VARPEDIDO+ " del mismo proveedor"
            Infbox "Existen varios pedidos no saldados " + VARPEDIDO+ " del mismo proveedor" Titled "PEDIDOS NO SALDADOS"
        Else
#            GMESSAGE="Ya existe el pedido no saldado " + VARPEDIDO+ " del mismo proveedor e importe"
#            GMESSAGE="Existe el pedido no saldado " + VARPEDIDO+ " del mismo proveedor"
            Infbox "Existe el pedido no saldado " + VARPEDIDO+ " del mismo proveedor" Titled "PEDIDOS NO SALDADOS"
        Endif
        OK=0
    Endif
Return

#AUREN - PU9
$ZPINVOICEAUX_MANT
#AUREN - PU9
#Crea los datos de ZPINVOICEAUX
    #If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  Raz [F:ZPX]
  Readlock [ZPX]ZPX0 =[F:PIH]NUM
  Local Integer V_STA
  V_STA = fstat
  [F:ZPX]INVTYP = [F:PIH]INVTYP
  [F:ZPX]NUM = [F:PIH]NUM
  #Factura tercer Proveďdor
  If dim([M:BIS0]NUM)>0: [F:ZPX]ZMOTIVR = [M:BIS1]ZMOTIVR: Endif
  If dim([M:BIS0]NUM)>0: [F:ZPX]ZMOTIVD = [M:BIS1]ZMOTIVD: Endif
  If dim([M:BIS0]NUM)>0: [F:ZPX]ZOBSLIQ = [M:BIS1]ZOBSLIQ: Endif
  #Acceptació factures
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVR = [M:ZAF1]ZMOTIVR: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVD = [M:ZAF1]ZMOTIVD: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZMOTIVRET = [M:ZAF1]ZMOTIVRET: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZOBS = [M:ZAF1]ZOBS: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZOBSLIQ = [M:ZAF1]ZOBSLIQ: Endif
  If dim([M:ZAF0]NUM)>0: [F:ZPX]ZINCACEP = [M:ZAF1]ZINCACEP: Endif

  If V_STA
   If dim([F:ZPX]CREDAT)>0 : [F:ZPX]CREDAT = date$ : Endif
   If dim([F:ZPX]CREUSR)>0 : [F:ZPX]CREUSR = GUSER : Endif
   If dim([F:ZPX]CRETIM)>0 : [F:ZPX]CRETIM = time  : Endif
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = [0/0/0] : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = "" : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = 0  : Endif
   Write [ZPX]
  Else
   If dim([F:ZPX]UPDDAT)>0 : [F:ZPX]UPDDAT = date$ : Endif
   If dim([F:ZPX]UPDUSR)>0 : [F:ZPX]UPDUSR = GUSER : Endif
   If dim([F:ZPX]UPDTIM)>0 : [F:ZPX]UPDTIM = time  : Endif
   Rewrite [ZPX]
  Endif
  If fstat
   GOK = 0
  Endif

Return
#AUREN - PU9

