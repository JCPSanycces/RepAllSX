Subprog OBTENERUSUARIODEPARTAMENTO(DEPARTAMENTO)

Variable Char    DEPARTAMENTO()

    Read [ZDT]ZDP0 = DEPARTAMENTO: If fstat Raz [F:ZDT] : Endif

    [M:BIS1]ZUS1 = [F:ZDT]ZUS1
    [M:BIS1]ZUS2 = [F:ZDT]ZUS2
    Affzo [M:BIS1]ZUS1
    Affzo [M:BIS1]ZUS2

End


