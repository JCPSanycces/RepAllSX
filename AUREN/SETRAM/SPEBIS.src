## Z07 - 09/12/2010 valores por defecto proveedor/sociedad
######################################################################################

Subprog  CUENTA_GASTOS_LINEAS_EXISTENTES(CUENTA)
Variable Char    CUENTA()
Local    Integer I: I=0

    If [M:BIS3]NBLIG > 0 & len(CUENTA) >0


        For I=0 To [M:BIS3]NBLIG-1
            [M:BIS3]ACC1(I)= CUENTA
            Affzo [M:BIS3]ACC1(I)
        Next


    Endif
End

