#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#**
#* Obtener el colectivo de un tercero
#* @param PTERCERO    >   Tercero
#* @param PTIPO       >   2=Cliente;3=Proveedor
#*!
Funprog GET_COLECTIVO(PTERCERO,PTIPO)
Value Char    PTERCERO
Value Integer PTIPO

Local Char LRES(15),LACCCOD(50)

  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  If !clalev([F:ZBPS]) Then : Local File BPSUPPLIER [F:ZBPS] : Endif
  If !clalev([F:ZCAC]) Then : Local File GACCCODE   [F:ZCAC] : Endif
  If !clalev([F:ZGAC]) Then : Local File GACCOUNT   [F:ZGAC] : Endif

  Case PTIPO
    When 2
      Read [F:ZBPC]BPC0 = PTERCERO
      If !fstat Then
        LACCCOD = [F:ZBPC]ACCCOD
      Endif
    When 3
      Read [F:ZBPS]BPS0 = PTERCERO
      If !fstat Then
        LACCCOD = [F:ZBPS]ACCCOD
      Endif
  Endcase

  Read [F:ZCAC]CAC0 = PTIPO;LACCCOD;'SPA'
  If !fstat Then
    Read [F:ZGAC]GAC0 = [F:ZCAC]COA;[F:ZCAC]ACC(0)
    If !fstat Then
      LRES = [F:ZGAC]ACCSHO
    Endif
  Endif

  Close Local File [ZBPC],[ZBPS],[ZCAC],[ZGAC]

End LRES
