############################################################################
###
###    Z14  No se permite un balance si las fechas son de aþos distintos
###
############################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)

Local Char  FICHAINICIO(30),  FICHAFIN(30)
Local Date    DATDEB , DATF

    # Obtener fecha inicio
    Call GETPARAM("datdeb",NBPAR,PARAMETRE,FICHAINICIO) From ETAT
    If FICHAINICIO<>"?????"
    
        # Obtener fecha inicio
        Call GETPARAM("datfin",NBPAR,PARAMETRE,FICHAFIN) From ETAT
        
        If FICHAFIN<>"?????"
            DATDEB= FICHAINICIO
            DATFIN = FICHAFIN
            If year(DATDEB) <> year(DATFIN) 
                # ERROR
                Call ECR_TRACE("Solo se puede obtener un Balance del mismo ejercicio",1) From GESECRAN 
                GOK = 0 
            Endif
    
        Endif
    Endif

End
