#<AdxTL>@(#)6.0.0.0 $Revision$
End
# Issue X3-215462 - 2020-09-22 Bader : CHECK_BSI: the record with the values of the manual entries is always the last one not the first
# Issue X3-86310 - 2020-05-29 by CBO : no account found
#FQ68023 : GER - Reduction of acquisition and production costs
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
# Issue X3-139348 - 2019-05-24 by MWA : ACESIMTRC <> 1 in batch  infinite loop.
# Issue X3-162781 - 2019-10-25 by MWA : unexpected trace in the log
# X3-166572 2019-12-02 Bader : PAYCPT new entry point FLTUSR to change the filter on the user
# Issue X3-163360 - 2019-12-04 by FHA : No matching when different bp control between main and other ledgers
# Issue X3-166809 - 2019-12-20 by Bader : GET_RCL_DAT() and GET_RCL_MRK() added
# Issue X3-176506 - 2020-01-10 by Bader : GET_BSITRS() added
# Issue X3-166812 - 2020-01-20 by Bader : add $CHECK_BSI and use it from GET_RCL_DAT() and GET_RCL_MRK()
####################
Subprog PAYCPT(NUM)
####################
Value Char NUM()
# No de rčglement, de bordereau de remise ou d'avis de domiciliation
# Payment no, Remittance no or Paying bank notice

Local Char     CRITERE(250)(0..1), CRIT(100), SAVCRIT(100), CRITSPE(250)
Local Char     GRPPCE(GLONGRA)       : # Groupe pičce automatique / Group of Auto Journal
Local Char     PCEAUTO(GLONGAU)      : # Code pičce automatique / Auto Journal Code
Local Char     MESSA(250)            : # Messages
Local Char     MESSA_TRACE(250)      : # Messages
Local Char     TMESSAGE(250)(1..100)  : # contient les no pičces créées ou message d'erreur / Entry nos created or error messages
Local Char     TMESSA(250)(1..100)    : # contient les no pičces créées par l'appel du VALPCE / Entry nos created by call of VALPCE
Local Char     IDENT(20)(1..7)       : # Identificateurs pour génération pičce comptable / Ids for Accounting Journal entry generation
Local Char     NUMREG(GLONVCR)       : # Numéro de rčglement / Payment no
Local Char     ABR(3)                : # Abréviation fichier / Abr. of file
Local Char     NUMBOR(GLONVCR)       : # Numéro de bordereau / Remttance no
Local Char     SITE(GLONFCY)         : # Site
Local Char     JOURNAL(GLONJOU)      : # Journal
Local Char     TYPPCE(GLONGTE)       : # Type de pičce / Document type
Local Char     COMPTE(GLONGAC)       : # Compte / Account
Local Char     TIERS(GLONBPR)        : # Tiers / BP
Local Char     SITLIN(GLONFCY)       : # Site en ligne / Line Site
#*X3-39795Local Char     TZONE(10)(1..4)       : # Table des zones ŕ forcer
#*X3-39795Local Char     TVAL(30)(1..4)        : # Table des valeurs des zones ŕ forcer
Local Char     TZONE(10)(1..10)      : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char     TVAL(30)(1..10)       : # Table of values for zones to be forced         #*X3-39795
Local Char     DEVISE(GLONCUR)       : # Code devise / Currency code
Local Char     DEVLED(GLONCUR)       : # Devise référentiel général principal / Currency of the Main General Ledger
Local Char     CODLED(GLONLED)       : # Code référentiel général principal / The Main General Ledger code
Local Char     DESDEF(30)(3), MESDEF(50)(3)
Local Char     CPT_TRESO(GLONGAC)
Local Integer  FLGAUT
Local Integer  TYPBOR                : # Type bordereau de remise / Type of remittance
Local Integer  INDPCE                : # Indice pičce auto / Auto journal ind.
Local Integer  NBPIECE               : # Nombre de pičces générées / Number of Journal entries generated
Local Integer  I, II, STAT, R, XX, J : # Variables diverses / Misc. variables
Local Integer  OK, OK2               : # Variables diverses / Misc. variables
Local Integer  IND                   : # Variables diverses / Misc. variables
Local Integer  VALGRP                : # Si 1:validation groupée (=1 pičce pour X rčglements) / if 1:grouped validation(= 1 Entry for X payments)
Local Integer  GROUPAGE
Local Integer  MAXLIG
Local Integer  MAXIPT
Local Integer  NUM_ORDRE
Local Integer  TROUVE
Local Integer  ETAP
Local Integer  SCHEMA
Local Integer  NUMECT
Local Integer  LETLED                : # LETLED=1 : lettrage en devise réf. / Matching in Ledger curr.
                                     : # LETLED=0 : lettrage en devise pičce / Matching in Entry curr.
Local Integer  TYPREG
Local Integer  OKOCC1, OKOCC2
Local Integer  IMAINREF
Local Integer  XLEDTYP
Global Integer GNUMORD, GLIGCODACE

Global Integer GCAS
Global Char    GLIGTRES1              : # On stocke ici la pičce auto + ligne pičce auto
                                      : # correspondant au compte trésorerie. Va servir pour le lettrage entre le
                                      : # le compte de trésorerie mouvementé ŕ l'étape N et soldé ŕ l'étape N+1
Global Char    GLIGTRES2              : # On stocke ici la pičce auto + ligne pičce auto. Va servir pour stocker l'accnum
                                      : # du compte de trésorerie dans la table PAYACCNUM

Global Char    GLIGTRES3              : # Pour Espagne (code activité KSF actif) : on stocke ici la pičce auto + ligne pičce auto
                                      : # correspondant au compte de dettes pour effets mouvementés ŕ la remise intermédiaire
                                      : # Va servir pour stocker l'accnum de ce compte dans PAYACCNUM


Onerrgo ERREUR From CONTROLE
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY]  : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]  : Endif
If clalev([F:PYH2])=0 : Local File PAYMENTH   [PYH2] : Endif
If clalev([F:PYH3])=0 : Local File PAYMENTH   [PYH3] : Endif
If clalev([F:PYH4])=0 : Local File PAYMENTH   [PYH4] : Endif
If clalev([F:PYH5])=0
 Local File PAYMENTH [PYH5] Order By Key CLE=DUDDAT;NUM
Endif
If clalev([F:PYH6])=0 : Local File PAYMENTH   [PYH6] : Endif  # Perf 63537
If clalev([F:PYH7])=0 : Local File PAYMENTH   [PYH7] : Endif  # Perf 63537
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
If clalev([F:PYD2])=0 : Local File PAYMENTD   [PYD2] : Endif

If clalev([F:PMP])=0  : Local File PAYMTCTMP  [PMP]  : Endif
If clalev([F:PMP2])=0 : Local File PAYMTCTMP  [PMP2] : Endif
If clalev([F:PMP3])=0 : Local File PAYMTCTMP  [PMP3] : Endif

## Tables temporaires servant au lettrage des comptes de trésorerie lettrable mouvementés ŕ l'étape N-1 et
## qui sont soldés ŕ l'étape courante N
If clalev([F:PM2])=0  : Local File PAYMTCTMP2  [PM2]  : Endif

If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif
If clalev([F:DAE5])=0 : Local File GACCENTRYD [DAE5] : Endif
If clalev([F:DAE7])=0 : Local File GACCENTRYD [DAE7] : Endif
If clalev([F:DAE4])=0 : Local File GACCTMPD   [DAE4] : Endif
If clalev([F:DAT5])=0 : Local File GACCTMPD   [DAT5] : Endif
If clalev([F:DAT7])=0 : Local File GACCTMPD   [DAT7] : Endif
If clalev([F:FRM])=0  : Local File PAYFRM     [FRM]  : Endif
If clalev([F:PAN])=0  : Local File PAYACCNUM  [PAN]  : Endif
If clalev([F:PAN2])=0 : Local File PAYACCNUM  [PAN2] : Endif
If clalev([F:PMD])=0  : Local File PAYACCNUMD [PMD]  : Endif
If clalev([F:PYO])=0  : Local File PAYORDER   [PYO]  : Endif
If clalev([F:PTP])=0  : Local File PAYTMP     [PTP]  : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If clalev([F:MVS])=0  : Local File BPSUPPMVT  [MVS]  : Endif
If clalev([F:MVC])=0  : Local File BPCUSTMVT  [MVC]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:ADP])=0  : Local File ADOPAR     [ADP]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0  : Local File GLED       [LED] : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA] : Endif
If clalev([F:GAC3])=0 : Local File GACCOUNT   [GAC3] : Endif

If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GALEG])=0 : Local File GAUTACEL    [GALEG] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT    [GAC] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR      [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE   [TCH] : Endif
If clalev([F:TCK])=0 : Local File TABACCLIK   [TCK] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:DIE])=0 : Local File GDIE        [DIE] : Endif
If clalev([F:CCE])=0 : Local File CACCE       [CCE] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD      [PER] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP])=0 : Local File CADSP       [DSP] : Endif
If clalev([F:AUZ])=0 : Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM     [AVN] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON     [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND     [ATI] : Endif
If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP    [HAE2] : Endif
If GMODU(2)=2  :# Compta
 If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE] : Endif
 If clalev([F:GDD])=0 : Local File GDIAENTRYD  [GDD] : Endif
 If clalev([F:PBS])=0 : Local File GAPARBSE    [PBS] : Endif
 If clalev([F:JOU])=0 : Local File GJOURNAL    [JOU] : Endif
 If clalev([F:JST])=0 : Local File GAJOUSTA    [JST] : Endif
 If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
 If clalev([F:HAE3])=0 : Local File GACCENTRY  [HAE3] : Endif
 If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif
 If clalev([F:DAE7])=0 : Local File GACCENTRYD [DAE7] : Endif
 If clalev([F:DAE8])=0 : Local File GACCENTRYD [DAE8] : Endif
Endif
If clalev([F:CDA])=0 : Local File GACCDENCOD  [CDA] : Endif
If clalev([F:TED])=0 : Local File TABCODEDT   [TED] : Endif

If func AFNC.ACTIV("CASIN")
  If clalev([F:PCH])=0 : Local File PYHCAS     [PCH] : Endif
  If clalev([F:TFC])=0 : Local File TABFILCASH [TFC] : Endif
Endif

If clalev([M:HAE0])=0 : Local Mask GACCENT0 [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1 [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2 [HAE2] : Endif
If clalev([M:VTL])=0  : Local Mask VENTILE  [VTL]  : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2 [VT2]  : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
If clalev([M:SCL])=0  : Local Mask SAICURLED  [SCL]  : Endif

Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char    PARAM(GLONADP)
Call PARAML("","MTCNBR",PARAM) From ADOVAL
MAXLIG = min(32767,max(dim([M:HAE2]ACC1)-1,val(PARAM)))

Local Integer  XACCNUM(1..MAXLIG), XDUDLIG(1..MAXLIG)
Local Integer  XNBLET
Local Decimal  XAMTIPTLED(1..MAXLIG)
Local Decimal  XAMTIPTCUR(1..MAXLIG)


# Déclararation de variables pour la performance en comptabilisation intermédiaire en masse (Perf 63537)
Local Integer NB, STOP
Local Char FILTPYH(250), FRM(GLONVCR)

Local Integer NCLE1, NCLE2
Local Char ACLE1, ACLE2

Local Char REQ(250)
Local Integer NBPYH, LNBPYH
#F_Perf 63537)


DESDEF(0)=mess(100,117,1) : # Remise
MESDEF(0)=mess(126,117,1) : # Bordereau de remise
DESDEF(1)=mess(134,117,1) : # Domiciliation
MESDEF(1)=mess(123,117,1) : # Avis de domiciliation
DESDEF(2)=mess(27,117,1)  : # Rčglement
MESDEF(2)=DESDEF(2)       : # Rčglement

Raz CRITERE
Call ADDCRIT(CRITERE,"STA<"+num$([M:DIA]ACCSTA))
If [M:DIA]ALLCPY<>2
 Call ADDCRIT(CRITERE,'CPY="'+[M:DIA]CPY+'"')
Endif
If [M:DIA]ALLTYP<>2
 Call ADDCRIT(CRITERE,'PAYTYP="'+[M:DIA]TYP+'"')
Endif
If [M:DIA]ACCSTA=3 | ([M:DIA]ACCSTA=9 & [M:DIA]PAY9=2)
 # Etape 3 - Mise en portefeuille (par rčglement)
 # Etape 9 - Remise en banque de rčglements hors bordereau
 If [M:DIA]ALLFCY<>2
  Call ADDCRIT(CRITERE,'FCY="'+[M:DIA]FCY+'"')
 Endif
 If [M:DIA]ALLUSR<>2
  # X3-166572 2019-12-02 Bader begin new entry point to change the filter on the user
  #Call ADDCRIT(CRITERE,'(UPDUSR="'+[M:DIA]USR+'" | (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))')
  Raz [L]CRITSPE
  GPOINT = "FLTUSR" : Gosub ENTREE From EXEFNC
  If [L]CRITSPE<>""         # if there is a specific filter for the user > use the specific one
    Call ADDCRIT(CRITERE,[L]CRITSPE)
  Else                      # if there is no specific filter for the user > use the standard filter for user
    Call ADDCRIT(CRITERE,'(UPDUSR="'+[M:DIA]USR+'" | (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))')
  Endif
  # X3-166572 2019-12-02 Bader end
 Endif
 If dim([M:DIA]ALLCUR)>0 & [M:DIA]ALLCUR<>2
  If [M:DIA]CUR<>""
   Call ADDCRIT(CRITERE,'CUR="'+[M:DIA]CUR+'"')
  Elsif [M:DIA]GRPCUR<>""
   Call LEC_GCU([M:DIA]GRPCUR) From CPTLEC
  Endif
 Endif
 If [M:DIA]ALLLOT<>2
  Call ADDCRIT(CRITERE,'PAYLOT="'+[M:DIA]LOT+'"')
 Endif
 If [M:DIA]DATMAX<>[0/0/0]
  MESSA = '['+format$(GFMD,[M:DIA]DATMAX)+']'
  Call ADDCRIT(CRITERE,'((UPDDAT<>[0/0/0] & UPDDAT<='+MESSA+') | (UPDDAT=[0/0/0] & CREDAT<='+MESSA+'))')
  MESSA=""
 Endif
 If dim([M:DIA]DUDMAX)>0 & [M:DIA]DUDMAX<>[0/0/0]
  Call ADDCRIT(CRITERE,'DUDDAT<=['+format$(GFMD,[M:DIA]DUDMAX)+']')
 Endif
 If NUM<>"" : Call ADDCRIT(CRITERE,'NUM="'+NUM+'"') : Endif
 If [M:DIA]ACCSTA=9
  Call ADDCRIT(CRITERE,'FRMNUM="" & BAN<>""')
 Endif
Else
 # Etape 8 - Remise sur compte intermédiaire (d'un bordereau de remise forcément)
 # Etape 9 - Remise en banque (d'un bordereau de remise ou avis de domiciliation)
 If [M:DIA]ALLFCY<>2
  Call ADDCRIT(CRITERE,'FRMFCY="'+[M:DIA]FCY+'"')
 Endif
 If [M:DIA]ALLUSR<>2
  Call ADDCRIT(CRITERE,'FRMUSR="'+[M:DIA]USR+'"')
 Endif
 If ([M:DIA]ACCSTA=8 | [M:DIA]PAY5=2) & [M:DIA]ALLFRMTYP<>2
  Call ADDCRIT(CRITERE,'FRMTYP='+num$([M:DIA]FRMTYP))
 Endif
 If [M:DIA]DATMAX<>[0/0/0]
  Call ADDCRIT(CRITERE,'FRMDAT<=['+format$(GFMD,[M:DIA]DATMAX)+']')
 Endif
 If dim([M:DIA]DUDMAX)>0 & [M:DIA]DUDMAX<>[0/0/0]
  Call ADDCRIT(CRITERE,'DUDDAT<=['+format$(GFMD,[M:DIA]DUDMAX)+']')
 Endif
 If [M:DIA]ACCSTA=8 | [M:DIA]PAY5=2 : Call ADDCRIT(CRITERE,'FRMFLG=1')
 Else                               : Call ADDCRIT(CRITERE,'FRMFLG=2')
 Endif
 If NUM<>"" : Call ADDCRIT(CRITERE,'FRMNUM="'+NUM+'"')
 Else       : Call ADDCRIT(CRITERE,'FRMNUM<>""')
 Endif
Endif

If dim([M:DIA]ALLBAN)>0 & [M:DIA]ALLBAN<>2
 Call ADDCRIT(CRITERE,'BAN="'+[M:DIA]BAN+'"')
Endif

If CRITERE(0)="" : CRITERE(0) = "1=1" : Endif
If CRITERE(1)="" : CRITERE(1) = "1=1" : Endif


#################### Point d'entrée FILTRE ####################
Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif


If [M:DIA]PRO=2 : # Génération écritures
 Onerrgo ERREUR From CONTROLE
 If clalev([F:GRA])=0 : Local File GRPAUTACE [GRA] : Endif
 If clalev([F:GRM])=0 : Local File GRPACEMTC [GRM] : Endif
 If clalev([M:HAE2])  : Local Mask GACCENT2 [HAE2] : Endif
 Onerrgo
 If GERREUR : GERREUR=0 : End : Endif
Endif


Call DEBTRANS From GLOCK
Gosub TR_ANNUL
If GOK<1 : End : Endif

Local Integer MAJFRM, TYPCLE, NBRPYH, NBRPYHFRM
Local Char SYMBOLE(250)
MAJFRM = 1
Raz NUMBOR
If [M:DIA]ACCSTA=3 | ([M:DIA]ACCSTA=8 & NUM<>"") | ([M:DIA]ACCSTA=9 & [M:DIA]PAY9=2)
 # - Mise en portefeuille par rčglement
 # - Remise sur compte intermédiaire par rčglement męme si les rčglements sont portés sur un bordereau (comme en 130, Vu
 #   avec SDR : la validation groupée pour cette étape n'est pas une priorité)
 # - Remise en banque de rčglements hors bordereau
 If [M:DIA]ACCSTA=8
  SYMBOLE = "CPTFRM\"+NUM
  Lock =SYMBOLE With lockwait=0
 Endif
 If [M:DIA]ACCSTA<>8 or !fstat
  For [PYH2]PYH0 Where evalue(CRITERE(0)) & evalue(CRITERE(1)) & evalue(CRITSPE)
   If [M:DIA]ACCSTA<>8 or !fstat
    OK = 0
    Gosub CONTROLE
    If OK
     TYPREG = 3 : Gosub MESSA_TRACE
     CRIT="[F:TB0]NUM='"+[F:PYH2]NUM+"'"
     SAVCRIT="NUM='"+[F:PYH2]NUM+"'"
     GCAS = 1 : VALGRP=0 : NUMREG = [F:PYH2]NUM
     NUMDOC = NUMREG
     TYPCLE = 1
     GSOCIETE = [F:PYH2]CPY
     Gosub GENER_PCE
     If GOK<1
      MAJFRM = 0
     Endif
    Else
     MAJFRM = 0
    Endif
   Endif
  Next
  If [M:DIA]ACCSTA=8 & MAJFRM=1 & NUMBOR="" & NUM<>""
   # Etape de comptabilisation intermédiaire... Aucune erreur, toutes les remises ont été effectuées
   #  => bordereau peut passé l'étape supérieure
   For [PYH2]PYH0 Where FRMNUM=NUM
    TYPBOR = [F:PYH]FRMFLG
    NUMBOR = [F:PYH]FRMNUM
    Break
   Next
   Gosub MAJFRM
  Else
   Gosub MAJFRM
  Endif
 Endif
 If [M:DIA]ACCSTA=8
  Unlock =SYMBOLE
 Endif
Elsif [M:DIA]ACCSTA=8 & NUM=""
 # Remise sur compte intermédiaire (par rčglement forcément) de plusieurs bordereaux (lancement en masse)
 # PERF63537
 Filter [PYH6] Where evalue(CRITERE(0)) & evalue(CRITERE(1)) & evalue(CRITSPE) Order By Key CLE=FRMFLG;FRMNUM;FRMLIN;NUM

 Raz NB, STOP, FILTPYH, MAJFRM, FRM

 $LOOP_PYH
 Raz NB
 If STOP = 1
  STOP = 2
  FILTPYH= "[F:PYH6]FRMFLG="+num$(NCLE1)+" & [F:PYH6]FRMNUM='"+ACLE1+"' & [F:PYH6]FRMLIN="+num$(NCLE2)+"& [F:PYH6]NUM>'"+ACLE2+"'"
 Elsif STOP=2
  STOP = 3
  FILTPYH= "[F:PYH6]FRMFLG="+num$(NCLE1)+" & [F:PYH6]FRMNUM='"+ACLE1+"' & [F:PYH6]FRMLIN>"+num$(NCLE2)
 Elsif STOP=3
  STOP = 4
  FILTPYH= "[F:PYH6]FRMFLG="+num$(NCLE1)+" & [F:PYH6]FRMNUM>'"+ACLE1+"'"
 Elsif STOP=4
  STOP = 0
  FILTPYH= "[F:PYH6]FRMFLG>"+num$(NCLE1)
 Else
  FILTPYH= "1=1"
 Endif

 For [PYH6]CLE(2) Where evalue(FILTPYH)

  # Nombre de rčglement sous le bordereau
  If [F:PYH6]FRMNUM<>[L]FRM
   Call ECR_TRACE(mess([F:PYH6]FRMFLG,685,1)-[F:PYH6]FRMNUM-":",0) From GESECRAN
   [L]FRM = [F:PYH6]FRMNUM
   Filter [F:PYH7] Where FRMNUM=[L]FRM & STA<8
   LNBPYH = rowcount([F:PYH7])
   Filter [F:PYH7]
  Endif

  SYMBOLE = "CPTFRM\"+[F:PYH6]FRMNUM
  Lock =SYMBOLE With lockwait=0
  If !fstat
   For [PYH6]CLE
    MAJFRM += 1
    Read [F:PYH2]PYH0 = [F:PYH6]NUM
    OK = 0
    Gosub CONTROLE
    If OK
     TYPREG = 3 : Gosub MESSA_TRACE
     CRIT="[F:TB0]NUM='"+[F:PYH2]NUM+"'"
     SAVCRIT="NUM='"+[F:PYH2]NUM+"'"
     GCAS = 1 : VALGRP=0 : NUMREG = [F:PYH2]NUM
     NUMDOC = NUMREG
     TYPCLE = 2
     GSOCIETE = [F:PYH2]CPY
     Gosub GENER_PCE
     If GOK<1 : MAJFRM -= 1 : Endif
    Else
     MAJFRM -= 1
    Endif
    NB+=1
    If NB>GMAXUPDTRS
     NCLE1 = [F:PYH6]FRMFLG
     ACLE1 = [F:PYH6]FRMNUM
     NCLE2 = [F:PYH6]FRMLIN
     ACLE2 = [F:PYH6]NUM
     STOP=1
     Break 1
    Endif
   Next
   # Statut du Bordereau
   If [L]LNBPYH=[L]MAJFRM
    Gosub MAJFRM
    MAJFRM = 0
   Endif
   Unlock =SYMBOLE
  Else
   # Opération en cours sur autre poste
   Call ECR_TRACE(mess(30,100,1),1) From GESECRAN
  Endif
  If STOP : Break : Endif
  Call ECR_TRACE("",0) From GESECRAN
 Next
 If STOP
  Goto LOOP_PYH
 Endif
 # F_PERF63537
Else
 # Remise en banque d'un bordereau de remise ou avis de domiciliation
 For [PYH2]PYH1(2) Where evalue(CRITERE(0)) & evalue(CRITERE(1)) & evalue(CRITSPE)
  SYMBOLE = "CPTFRM\"+[F:PYH2]FRMNUM
  Lock =SYMBOLE With lockwait=0
  If !fstat
   OK = 0
   Gosub CONTROLE2
   If OK
    TYPREG = [F:PYH2]FRMFLG : Gosub MESSA_TRACE
    If [M:DIA]ACCSTA=9
     If [F:PYH2]FRMTYP = 1 | [F:PYH2]FRMTYP = 3 | ([F:PYH2]FRMTYP = 0 & [F:TPY]ACETYP91<>0) : # encaissements
      GCAS = [F:TPY]ACETYP91
     Else : # escompte
      GCAS = [F:TPY]ACETYP92
     Endif
    Else : # Au cas oů on décide par la suite de choisir le regroupement pour une remise intermédiaire
     GCAS = 1
    Endif

    If GCAS = 0 : GCAS = 1 : Endif

    MAJFRM = 1

    Case GCAS
     When 1
      For [PYH2]PYH1
       VALGRP = 0 : NUMREG = [F:PYH2]NUM
       CRIT="[F:TB0]NUM='"+[F:PYH2]NUM+"'"
       SAVCRIT="NUM='"+[F:PYH2]NUM+"'"
       NUMDOC = NUMREG
       TYPCLE = 2
       GSOCIETE = [F:PYH2]CPY
       Gosub GENER_PCE
       If GOK<1 : MAJFRM = 0 : Endif
      Next
     When 2
      VALGRP = 1
      CRIT="[F:TB0]FRMFLG="+num$([F:PYH2]FRMFLG)+" & [F:TB0]FRMNUM='"+[F:PYH2]FRMNUM+"'"
      SAVCRIT="FRMFLG="+num$([F:PYH2]FRMFLG)+" & FRMNUM='"+[F:PYH2]FRMNUM+"'"
      NUMDOC = [F:PYH2]FRMNUM
      TYPCLE = 2
      GSOCIETE = [F:PYH2]CPY
      Gosub GENER_PCE
      If GOK<1 : MAJFRM = 0 : Endif
     When 3
      # Avec le critčre "Par date d'échéance", tous les rčglements d'un Bordereau ne sont pas forcément pris en compte...
      # Pour passer le bordereau ŕ l'étape supplémentaire, seul le statut d'erreur ne peut suffir...
      Filter [PYH5] Where FRMNUM=[F:PYH2]FRMNUM & STA<>9
      NBRPYHFRM = rowcount([PYH5])
      Filter [PYH5] Where FRMNUM=[F:PYH2]FRMNUM & STA<>9 & evalue(CRITERE(0)) & evalue(CRITERE(1)) & evalue(CRITSPE)
      NBRPYH = rowcount([PYH5])
      Filter [PYH5]
      If [L]NBRPYHFRM<>[L]NBRPYH : MAJFRM=0 : Endif
      #
      #VALGRP = 0 : NUMREG = [F:PYH2]NUM
      VALGRP = 1
      For [PYH5]CLE(1) Where evalue(CRITERE(0)) & evalue(CRITERE(1)) & evalue(CRITSPE)
&      & FRMNUM=[F:PYH2]FRMNUM & FRMFLG=[F:PYH2]FRMFLG
       CRIT="[F:TB0]FRMFLG="+num$([F:PYH2]FRMFLG)+" & [F:TB0]FRMNUM='"+[F:PYH2]FRMNUM+"'"
       CRIT-= "& [F:TB0]DUDDAT=["+format$(GFMD,[F:PYH5]DUDDAT)+"] & [F:TB0]STA<>9"
       SAVCRIT="FRMFLG="+num$([F:PYH2]FRMFLG)+" & FRMNUM='"+[F:PYH2]FRMNUM+"'"
       SAVCRIT-= "& DUDDAT=["+format$(GFMD,[F:PYH5]DUDDAT)+"] & STA<>9"
       NUMDOC = [F:PYH2]FRMNUM
       TYPCLE = 3
       GSOCIETE = [F:PYH2]CPY
       Gosub GENER_PCE
       If GOK<1 : MAJFRM = 0 : Endif
      Next
     When 4
      CRIT="[F:TB0]PAYLOT='"+[F:PYH2]PAYLOT+"'"
      SAVCRIT="PAYLOT='"+[F:PYH2]PAYLOT+"'"
      TYPCLE = 2
      GSOCIETE = [F:PYH2]CPY
      Gosub GENER_PCE
      If GOK<1 : MAJFRM = 0 : Endif
    Endcase
    If NBPIECE>0 : Call ECR_TRACE("",0) From GESECRAN : Endif
    Gosub MAJFRM
   Endif
   Unlock =SYMBOLE
  Else
   # Opération en cours sur autre poste
   Call ECR_TRACE(mess([F:PYH2]FRMFLG,685,1)-[F:PYH2]FRMNUM-":"-mess(30,100,1),1) From GESECRAN
  Endif
  Call ECR_TRACE("",0) From GESECRAN
 Next
Endif
End


$GENER_PCE
If [M:DIA]PRO = 2
 GOK = 1 : GRPPCE = evalue("[F:TPY]AUTACE"+num$([M:DIA]ACCSTA))
 Read [GRA]GRA0 = GRPPCE
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub TRANSAC
  If GOK<1 : Return : Endif
 Endif
Endif
Return

$MESSA_TRACE
Case TYPREG
 When 3
   MESSA_TRACE = MESDEF(2)-[F:PYH2]NUM-":"
   # PAYTYP, BPR/ACC, (DUDDAT,) (BAN,) AMTCUR CUR
   MESSA_TRACE -=[F:PYH2]PAYTYP
   If [F:PYH2]BPR<>"" : MESSA_TRACE += ", "+[F:PYH2]BPR
   Else MESSA_TRACE += ", "+[F:PYH2]ACC
   Endif
   If [F:TPY]DACDUDDAT<>3 : MESSA_TRACE += ", "+format$("D:"+GFMDAT,[F:PYH2]DUDDAT) : Endif
   If [F:PYH2]BAN<>"" : MESSA_TRACE += ", "+[F:PYH2]BAN : Endif
   MESSA_TRACE += ", "+num$([F:PYH2]AMTCUR)-[F:PYH2]CUR
   If [M:DIA]PRO = 1 : [M:DIA]NB += 1 : Endif
 When 1,2
  MESSA_TRACE = MESDEF([F:PYH2]FRMFLG-1)-[F:PYH2]FRMNUM-":"
  # PAYTYP, FRMDAT, BAN
  MESSA_TRACE -= [F:PYH2]PAYTYP+", "+format$(GFMD,[F:PYH2]FRMDAT)+", "+[F:PYH2]BAN
  If [M:DIA]PRO = 1 : [M:DIA]NB += 1 : Endif
Endcase
Call ECR_TRACE(MESSA_TRACE,0) From GESECRAN
Return


$TRANSAC

GOK = 1
Trbegin [PYH], [PYD], [FRM], [PAN], [DUD], [PMD], [PYO], [PTP], [PMP]
 If TYPCLE = 1
  Readlock [PYH2]PYH0 Curr
  If fstat=1
   GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH2]NUM : MESSA="PYH\"+[F:PYH2]NUM : Goto ROLL_TRANSAC
  Endif
  Read [F:PYH3]PYH0 = [F:PYH2]NUM
  If !fstat
   If [M:DIA]ACCSTA=3 & [F:PYH3]STAFLG(2)=2
    Goto AB_TRANSAC
   Elsif [M:DIA]ACCSTA=8 & [F:PYH3]STAFLG(7)=2
    Goto AB_TRANSAC
   Elsif [M:DIA]ACCSTA=9 & [F:PYH3]STAFLG(8)=2
    Goto AB_TRANSAC
   Endif
  Endif
 Elsif TYPCLE = 2
  Readlock [PYH2]PYH1 Curr
  If fstat=1
   GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH2]NUM : MESSA="PYH\"+[F:PYH2]NUM : Goto ROLL_TRANSAC
  Endif
 Elsif TYPCLE = 3
  Readlock [PYH5]CLE Curr
  If fstat=1
   GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH2]NUM : MESSA="PYH\"+[F:PYH2]NUM : Goto ROLL_TRANSAC
  Endif
 Endif

 INDPCE = 0 :  : NBPIECE=0

 While [F:GRA]CODACE(INDPCE)<>""
  PCEAUTO = [F:GRA]CODACE(INDPCE)
  Call LECTURE("GAU",PCEAUTO,"") From CONTOBJ
  Raz TMESSA : Raz [F:PMD]
  If !VALGRP : GROUPAGE = 1 : Else : GROUPAGE = 2 : Endif
  Gosub VAL_IMPOSE
  If STAT
   Call ECR_TRACE(TMESSA(1),1) From GESECRAN
   GOK = 0 : Goto AB_TRANSAC
  Endif

  If GSERVEUR  : # X3-140984
   Local Integer GACESIMTRC_SAV
   GACESIMTRC_SAV = GACESIMTRC
   GACESIMTRC = 1
  Endif   : # End X3-140984

  GPOINT = "BEFGNRVCR" : Gosub ENTREE From EXEFNC
  GNUMORD = 0 : GLIGCODACE = 0
  # X3-162781 Call ECR_TRACE("Avant valpce"-num$(GOK),0) From GESECRAN
  Call VALPCE5(PCEAUTO,CRIT,[L]GROUPAGE,GRPPCE,STAT,TMESSA,TZONE,TVAL) From CPTAUTO
  # X3-162781 Call ECR_TRACE("Avant valpce"-num$(GOK),0) From GESECRAN
  If GOK<0 : Break : Endif
  If STAT
   ## Request 109148
   #Call ECR_TRACE(TMESSA(1)-"("+PCEAUTO+")",1) From GESECRAN
   #GOK = 0 : Goto AB_TRANSAC
   #If dim(GACESIMTRC)<0 or (dim(GACESIMTRC)>0 & !find(GACESIMTRC,2,3)) or (dim(GACESIMTRC)>0 & find(GACESIMTRC,2,3) & TMESSA(1)<>"") : # Request 109148
   If (!find(GACESIMTRC,2,3)) or (find(GACESIMTRC,2,3) & TMESSA(1)<>"") : # Request 109148
    Call ECR_TRACE(TMESSA(1)-"("+PCEAUTO+")",1) From GESECRAN
    GOK = 0 : Break
   Endif
   # Request 109148
  Elsif [M:HAE2]NBLIG>0
   J = 1
   While TMESSA(J)<>""
    NBPIECE += 1
    TMESSAGE(NBPIECE) = TMESSA(J)
    J += 1
   Wend
  Endif
  If GSERVEUR  : # X3-140984
   GACESIMTRC = GACESIMTRC_SAV
  Endif   : # End X3-140984
  INDPCE += 1
 Wend
 # Request 109148
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 # End Request 109148
 ## Request 109148
 #If dim(GACESIMTRC)>0 & find(GACESIMTRC,2,3)
 If GSERVEUR  : # X3-140984
   Local Integer GACESIMTRC_SAV
   GACESIMTRC_SAV = GACESIMTRC
   GACESIMTRC = 1
 Endif   : # End X3-140984
 If find(GACESIMTRC,2,3)
  GOK = 0 : Goto AB_TRANSAC
 Endif
 If GSERVEUR  : # X3-140984
  GACESIMTRC = GACESIMTRC_SAV
 Endif   : # End X3-140984
 ## End Request 109148
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 Gosub LETTRAGE
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 Gosub MAJPYH
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 Gosub DELPAYMTC
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 Gosub DELPAYPTP
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif

 # 112898.so - SE capture code moved to within payment loop
 # 78411 Sage Exchange
 #If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
 #   Call DOC_VALIDATION(50+mod([F:PYH]SNS,2),[F:PYH]NUM) From SEPPLIB2
 #   If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE,!GOK) From GESECRAN : Endif
 #   If GOK<0   : Goto ROLL_TRANSAC
 #   Elsif !GOK : Goto AB_TRANSAC
 #   Endif
 # Endif
 # 112898.eo

 If GTRACE<>""
  For I = 1 To NBPIECE
   Call ECR_TRACE("> "+mess(40,107,1)-TMESSAGE(I),0) From GESECRAN
  Next
 Endif
 If NBPIECE>0 & TYPREG = 3
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Commit

 # 112898.so - SE capture code moved to within payment loop
# 78411 Sage Exchange - backorder auth
 #If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
 #  Call AUTO_PAYEMNT(50+mod([F:PYH]SNS,2),[F:PYH]NUM) From SEPPLIB2
 #  If !GOK : Return : Endif
 #Endif
 # 112898.eo

 # Issue X3-222040 - 2020-11-02 by VAVIL : QR code printed documents
 If func AFNC.ACTIV("KPO") > 0 & GCURLEG ="POR"
   Call  GEN_QRCODE_PAY([F:PYH]NUM,STAT) From PORLEGQRCDOCLIB
 Endif
 #Issue end X3-222040

Return

$AB_TRANSAC
Rollback
Return

$ROLL_TRANSAC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRANSAC : Endif
Return

$MAJPYH
#FQ68023
If GMODU(14)=2 : # Presence of the fixed assets module
 Local Char    DEPMOD(10)
 Call PARAML(GSOCIETE ,"DEPMGTMOD",DEPMOD) From ADOVAL
 GDEPMGTMOD=val(DEPMOD)
 If clalev([F:LOFC])=0 : Local File LAYOUTFAS   [LOFC] : Endif  #FQ68023 END
Endif

For [PYH]PYH0 Where (GCAS=1 & NUM=NUMREG) | (GCAS<>1 & evalue(SAVCRIT))
 ABR = "PYH" : Gosub CRITLIG
 Filter [DAE4] Where CODAUTACE=GLIGTRES1 & LEDTYP=GTYPGEN & CRIMTC=CRIT_LIG
 Read [DAE4]DAT2 First
 Filter [DAE4]
 # Correction bug 77622 : c'est sur le référentiel 2 qu'on a le compte
 # If fstat
 #  Filter [DAE4] Where CODAUTACE=GLIGTRES1 & CRIMTC=CRIT_LIG
 #  Read [DAE4]DAT2 First
 #  Filter [DAE4]
 # Endif
 #fin correction
 If !fstat
  ## Initialisation SCHEMA : 1čre étape de comptabilisation ?
  ETAP = [M:DIA]ACCSTA-1 : TROUVE = 0
  While !TROUVE & ETAP>0
   If [F:PYH]ACCNUMTRE(ETAP-1)<>0
    TROUVE = 1
   Else
    ETAP -= 1
   Endif
  Wend
  If TROUVE = 0 : # C'est la premičre comptabilisation...
   SCHEMA = 3
  Else
   SCHEMA = [M:DIA]ACCSTA
  Endif

  ## On fait comme en V130 : si la transaction n'a pas d'étape de mise en portefeuille, [F:PYH]STAFLG(2) est initialisée
  ## ŕ 2 lors de la premičre comptabilisation
  If SCHEMA = 3 & [M:DIA]ACCSTA<>3
   [F:PYH]STAFLG(2) = 2
  Endif

  [F:PYH]ACCNUMTRE([M:DIA]ACCSTA-1) = [F:DAE4]ACCNUM : # Stk accnum compte tréso
  [F:PYH]STAFLG([M:DIA]ACCSTA-1)    = 2
  [F:PYH]STA = [M:DIA]ACCSTA

  ## Si SCHEMA>3 (=on valide la Ničme étape), alors on va s'occuper du lettrage du compte de trésorerie
  ## mouvementé en N-1 et soldé ici en N
  If SCHEMA>3
   Gosub PREPA_LETTRAGE2
  Endif

  GPOINT = "MAJPYH" : Gosub ENTREE From EXEFNC
  If GOK<1 : Break : Endif

  If [F:PYH]STAFLG(8) = 2 & [F:PYH]BANPAYTPY<>0
   Readlock [BAN]BAN0 = [F:PYH]BAN
   If fstat=1
    GOK=-1 : GLOCK="$BANK"-[F:PYH]BAN
    MESSA=mess(20,100,1)-"BAN\"+[PYH]BAN : Break
   Elsif fstat=0
    [F:BAN]PAYTPY-=[F:PYH]BANPAYTPY
    Rewrite [BAN]
    If fstat
     GOK=0 : Call FSTA("BAN") From GLOCK : Break
    Endif
   Endif
  Endif
  [M:DIA]NB += 1
  Rewrite [PYH]
  If fstat
   GOK=0 : Call FSTA("PYH") From GLOCK : Break
  Endif
 Else
  # Erreur en lecture du compte trésorerie
  GOK=0 : Call ECR_TRACE(mess(202,117,1)-GLIGTRES1,1) From GESECRAN : Break
 Endif

 #FQ68023 : GER - Reduction of acquisition and production costs
 If GMODU(14)=2 : # Presence of the fixed assets module
   # --> P14 - if the first posting of the Payment (SCHEMA = 3)
   # --> P28 - if  [PYH]SNS = "Expense"
   # --> P8 - accounts flagged "subject to discount" (param DEPMGTMOD=4 : VAT ventilation followed by the legislation GER )
   If SCHEMA=3 and [PYH]SNS = 1 and GDEPMGTMOD = 4
     Gosub ASSETS_EXPENSE_CRE
     If GOK<1 : Break : Endif
   Endif
 Endif #FQ68023 END

  # 112898.sn - SE capture code moved to within payment loop
  If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
    Call DOC_VALIDATION(50+mod([F:PYH]SNS,2),[F:PYH]NUM) From SEPPLIB2
    If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE-"-"-[F:PYH]NUM,!GOK) From GESECRAN : Endif
    If GOK<1 : Break : Endif
    # 116638 - added parameter for NUMPAY
    Local Integer NUMPAY
    Call AUTO_PAYMENT(50+mod([F:PYH]SNS,2),[F:PYH]NUM,[L]NUMPAY) From SEPPLIB2
    If GOK<1 : Break : Endif
  Endif
  # 112898.en

Next
If GOK<1 : Return : Endif
## Lettrage compte de trésorerie mouvementé en N-1 et soldé ici ŕ l'étape N : on lettre dans le męme groupe
## de lettrage les écritures (=accnums) associées au męme triplet : compte-tiers-lettre
## Parcours quadruplet ledtyp-compte-tiers-lettre
If SCHEMA>3
 For [PM2]PM20(7)
  XNBLET = 0 : LETLED = 0
  Raz XACCNUM, XDUDLIG, XAMTIPTCUR, XAMTIPTLED
  ## Parcours écritures associées au męme compte-tiers-lettre (par type référentiel) et mouvementées en N-1
  DEVISE = [F:PM2]CUR
  For [PM2]PM20
   XNBLET += 1
   If XNBLET>=MAXLIG : # Trop d'échéances ŕ lettrer (MAXLIG>MAXLIG)
    Call ECR_TRACE(mess(81,117,1)-"(MAXLIG>"+num$(MAXLIG)+")",1) From GESECRAN : GOK=0 : Break 2
   Endif
   XACCNUM(XNBLET)    = [F:PM2]ACCNUM
   XDUDLIG(XNBLET)    = [F:PM2]DUDLIG
   XAMTIPTCUR(XNBLET) = [F:PM2]AMTIPTCUR
   XAMTIPTLED(XNBLET) = [F:PM2]AMTIPTLED
  Next
  ## Parcours écritures associées au męme triplet compte-tiers-lettre et mouvementées en N (étape courante)
  For [DAT5]DAT0 Where TYP=[F:PM2]TYP & NUM=[F:PM2]NUM  & LEDTYP=[F:PM2]LEDTYP & ACC=[F:PM2]ACC & BPR=[F:PM2]BPR & FCYLIN=[F:PM2]FCY
   If !LETLED & DEVISE<>[F:DAT5]CUR : LETLED = 1 : Endif
   XNBLET += 1
   If XNBLET>=MAXLIG : # Trop d'échéances ŕ lettrer (MAXLIG>MAXLIG)
    Call ECR_TRACE(mess(81,117,1)-"(MAXLIG>"+num$(MAXLIG)+")",1) From GESECRAN : GOK=0 : Break 2
   Endif
   XACCNUM(XNBLET)    = [F:DAT5]ACCNUM
   XDUDLIG(XNBLET)    = 1
   XAMTIPTCUR(XNBLET) = [F:DAT5]AMTCUR
   XAMTIPTLED(XNBLET) = [F:DAT5]AMTLED
  Next
  If XNBLET>1
   If LETLED
    Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTLED,-1) From CPTLET
   Else
    Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTCUR,-2) From CPTLET
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
TYPBOR = [F:PYH]FRMFLG
NUMBOR = [F:PYH]FRMNUM
Return

$ASSETS_EXPENSE_CRE
Local Char MESSA(250)
#FQ68023 GER - Reduction of acquisition and production costs
### For each Payment line P10 - with a document number
#
If !clalev([F:WTVT]) : Local File TABVAT[WTVT]     : Endif
If !clalev([F:WCAC]) : Local File GACCCODE [WCAC]  : Endif
If !clalev([F:WGAC]) : Local File GACCOUNT [WGAC]  : Endif

For [PYD]PYD0 Where (NUM = [F:PYH]NUM  and VCRNUM <> "" )
  # Reading of destination code
  # P9 - the flag “Expense creation” must be checked
  # On Payment attibute
  Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
  If fstat= 0  and [F:CDA]FLGEXPCRE = 2
    #FQ68023_b
    # Research of  Accounting code in the Tax code table
    Read [F:WTVT]TVT0=[F:PYD]VATLIN;GCURLEG
    If (fstat) :  Break  : Endif
    Read[WCAC]CAC0=10;[F:WTVT]ACCCOD;[F:PYD]COA(0)
    If (fstat) : Break : Endif
    Read [WGAC]GAC0 = [F:PYD]COA(0);[F:WCAC]ACC(12)
    If fstat= 0 and  [F:WGAC]FLGEXPCRE = 2
      Look [LOFC]LOF0(1) = [F:PYD]VCRNUM
      If !fstat
        Call CREDEP("PYD", MESSA) From SUBLOF2
        # Issue X3-86310
        If !GOK
          GMESSAGE = MESSA
          Call ECR_TRACE(GMESSAGE,1) From GESECRAN
          Break
        Endif
        # End Issue X3-86310
      Endif
    Endif
  Endif
Next

Return #FQ68023 END

$PREPA_LETTRAGE2
ETAP = [M:DIA]ACCSTA-1 : TROUVE = 0 : XNBLET = 0
While !TROUVE & ETAP>0
 If [F:PYH]ACCNUMTRE(ETAP-1)<>0
  TROUVE = 1
  NUMECT = [F:PYH]ACCNUMTRE(ETAP-1)
 Else
  ETAP -= 1
 Endif
Wend
If TROUVE
 Gosub STK_ACCNUM
Endif
If GOK<1 : Return : Endif
Return


$STK_ACCNUM
## Alimentation de la table PAYMTCTMP2 pour 'préparer' le lettrage du compte de trésorerie mouvementé en N-1
## et soldé en N :
## Dans la table PAYMTCTMP2 on va stocker pour la pičce de rčglement générée ici ŕ l'étape N et qui solde
## le compte de trésorerie ([F:DAE4]TYP-[F:DAE4]NUM), l'accnum (et les montants,etc...) du compte de trésorerie
## mouvementé ŕ l'étape N-1
## 1) D'abord on s'occupe de "préparer" le lettrage du référentiel général principal (dans PAYMENTH, on stocke
##  l'accnum du compte de trésorerie du référentiel général principal)
Read [DAE5]DAE2 = NUMECT
If !fstat
 Raz [F:PM2]
 [F:PM2]TYP    = [F:DAE4]TYP
 [F:PM2]NUM    = [F:DAE4]NUM
 [F:PM2]LEDTYP = GTYPGEN
 [F:PM2]COA    = [F:DAE5]COA
 [F:PM2]ACC    = [F:DAE5]ACC
 [F:PM2]BPR    = [F:DAE5]BPR
 [F:PM2]FCY    = [F:DAE5]FCYLIN
 [F:PM2]CUR    = [F:DAE5]CUR
 [F:PM2]ACCNUM = [F:DAE5]ACCNUM
 [F:PM2]DUDLIG = 1
 [F:PM2]AMTIPTCUR = [F:DAE5]AMTCUR
 [F:PM2]AMTIPTLED = [F:DAE5]AMTLED
Else
 Read [DAT5]DAT1 = NUMECT
 If !fstat
  Raz [F:PM2]
  [F:PM2]TYP    = [F:DAE4]TYP
  [F:PM2]NUM    = [F:DAE4]NUM
  [F:PM2]LEDTYP = GTYPGEN
  [F:PM2]COA    = [F:DAT5]COA
  [F:PM2]ACC    = [F:DAT5]ACC
  [F:PM2]BPR    = [F:DAT5]BPR
  [F:PM2]FCY    = [F:DAT5]FCYLIN
  [F:PM2]CUR    = [F:DAT5]CUR
  [F:PM2]ACCNUM = [F:DAT5]ACCNUM
  [F:PM2]DUDLIG = 1
  [F:PM2]AMTIPTCUR = [F:DAT5]AMTCUR
  [F:PM2]AMTIPTLED = [F:DAT5]AMTLED
 Endif
Endif
[F:PM2]UIDUSR = adxuid(2)
Call LEC_GAC([F:PM2]ACC,[F:PM2]COA) From CPTLEC
If [F:GAC]MTC=2
 Write [PM2]
 If fstat
  GOK=0 : Call FSTA("PM2") From GLOCK : Return
 Endif
Endif
## 2) Et maintenant on s'occupe de "préparer" le lettrage des référentiels autres que le référentiel
## général principal
## Lecture écriture passée sur le compte de trésorerie mouvementé ŕ l'étape N-1
## Et maintenant on s'occupe du lettrage des référentiels autres que le référentiel général principal !!!
## Lecture écriture passée sur le compte de trésorerie mouvementé ŕ l'étape N-1
Read [DAE5]DAE2 = NUMECT
If !fstat
 For [DAE7]DAE7(4) Where TYP=[F:DAE5]TYP & NUM=[F:DAE5]NUM & IDTLIN=[F:DAE5]IDTLIN & LEDTYP<>GTYPGEN
  Call LEDTYPAUT([F:DAE7]CPY,[F:DAE7]LEDTYP,[L]FLGAUT) From CPTDIV
  If [L]FLGAUT<>2
   Raz [F:PM2]
   [F:PM2]TYP    = [F:DAE4]TYP
   [F:PM2]NUM    = [F:DAE4]NUM
   [F:PM2]LEDTYP = [F:DAE7]LEDTYP
   [F:PM2]COA    = [F:DAE7]COA
   [F:PM2]ACC    = [F:DAE7]ACC
   [F:PM2]BPR    = [F:DAE7]BPR
   [F:PM2]FCY    = [F:DAE7]FCYLIN
   [F:PM2]CUR    = [F:DAE7]CUR
   [F:PM2]ACCNUM = [F:DAE7]ACCNUM
   [F:PM2]DUDLIG = 1
   [F:PM2]AMTIPTCUR = [F:DAE7]AMTCUR
   [F:PM2]AMTIPTLED = [F:DAE7]AMTLED
   [F:PM2]UIDUSR = adxuid(2)
   Call LEC_GAC([F:PM2]ACC,[F:PM2]COA) From CPTLEC
   If [F:GAC]MTC=2
    Write [PM2]
    If fstat
     GOK=0 : Call FSTA("PM2") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
Else
 Read [DAT5]DAT1 = NUMECT
 If !fstat
  For [DAT7]DAT3(4) Where TYP=[F:DAT5]TYP & NUM=[F:DAT5]NUM & IDTLIN=[F:DAT5]IDTLIN & LEDTYP<>GTYPGEN
   Call LEDTYPAUT([F:DAT7]CPY,[F:DAT7]LEDTYP,[L]FLGAUT) From CPTDIV
   If [L]FLGAUT<>2
    Raz [F:PM2]
    [F:PM2]TYP    = [F:DAE4]TYP
    [F:PM2]NUM    = [F:DAE4]NUM
    [F:PM2]LEDTYP = [F:DAT7]LEDTYP
    [F:PM2]COA    = [F:DAT7]COA
    [F:PM2]ACC    = [F:DAT7]ACC
    [F:PM2]BPR    = [F:DAT7]BPR
    [F:PM2]FCY    = [F:DAT7]FCYLIN
    [F:PM2]CUR    = [F:DAT7]CUR
    [F:PM2]ACCNUM = [F:DAT7]ACCNUM
    [F:PM2]DUDLIG = 1
    [F:PM2]AMTIPTCUR = [F:DAT7]AMTCUR
    [F:PM2]AMTIPTLED = [F:DAT7]AMTLED
    [F:PM2]UIDUSR = adxuid(2)
    Call LEC_GAC([F:PM2]ACC,[F:PM2]COA) From CPTLEC
    If [F:GAC]MTC=2
     Write [PM2]
     If fstat
      GOK=0 : Call FSTA("PM2") From GLOCK : Break
     Endif
    Endif
   Endif
  Next
 Endif
Endif
Return


$LETTRAGE
## On s'occupe du lettrage avec la facture
For [PMP]PMP0(3) Where NUM = [L]NUMDOC : # Parcours des lettrages ŕ effectuer (GRPACEMTC)
 If [F:PMP]INVMTC = 2 : # Lettrage avec facture...

  If [F:PMP]TYPVCR=6
   ## Lettrage de l'OD tiers avec la facture : L'OD tiers est générée
   ## en devise de facturation. On peut se trouver dans le cas d'un
   ## rčglement qui rčgle X factures de devises différentes et pour lesquelle le tiers
   ## facturé est différent du tiers payeur. Dans ce cas, on aura autant de pičces OD-tiers
   ## que de devise de facturation.
   Gosub LET_OD
  Elsif [F:PMP]TYPVCR=5
   ## Demande 49107
   ## Dans le cas d'un rčglement qui rčgle X factures de devises différentes, on a autant de pičces OD-Devise.
   ## Dans ce cas, il faut autant de lettrage que de OD Devise la facture
   LETLED = 0
   DEVISE = ""
   For [PMP2]PMP0 Where NUM = [F:PMP]NUM & NUMORD = [F:PMP]NUMORD & LEDTYP = [F:PMP]LEDTYP & OCC2 = 0
    If DEVISE=""
     DEVISE = [F:PMP2]CUR
    Else
     If DEVISE <> [F:PMP2]CUR : LETLED = 1 : Break : Endif
    Endif
   Next
   If LETLED
    Gosub LET_OD   # Si devise différente => lettrage comme OD_Tiers
   Else
    Gosub LET_STD  # Si devise identique => lettrage standard
   Endif
  Else
   Gosub LET_STD
  Endif


 Elsif [F:PMP]INVMTC = 1 : # Lettrage interne...
  For [PMP2]PMP1(6) Where NUM = [F:PMP]NUM & NUMORD = [F:PMP]NUMORD & LEDTYP = [F:PMP]LEDTYP
   XNBLET = 0 : LETLED = 0 : OKOCC1 = 0 : OKOCC2 = 0
   For [PMP3]PMP1 Where NUM = [F:PMP2]NUM & NUMORD = [F:PMP2]NUMORD & LEDTYP = [F:PMP2]LEDTYP & FCY=[F:PMP2]FCY & ACC=[F:PMP2]ACC & BPR=[F:PMP2]BPR
    If [F:PMP3]OCC1<>0 : OKOCC1 = 1 : Elsif [F:PMP3]OCC2<>0 : OKOCC2=1 : Endif
    If XNBLET=0 : DEVISE = [F:PMP3]CUR : Endif
    If XNBLET>0 & !LETLED
     If  DEVISE<>[F:PMP3]CUR : LETLED = 1 : Endif
    Endif
    XNBLET += 1
    If XNBLET>=MAXLIG : # Trop d'échéances ŕ lettrer (MAXLIG>MAXLIG)
     Call ECR_TRACE(mess(81,117,1)-"(MAXLIG>"+num$(MAXLIG)+")",1) From GESECRAN : GOK=0 : Break 3
    Endif
    XACCNUM(XNBLET) = [F:PMP3]ACCNUM
    XDUDLIG(XNBLET) = [F:PMP3]DUDLIG
    XAMTIPTCUR(XNBLET) = [F:PMP3]AMTIPTCUR
    XAMTIPTLED(XNBLET) = [F:PMP3]AMTIPTLED
   Next
   If OKOCC1 & OKOCC2
    Gosub LET_DIF
   Endif
  Next
 Endif
Next
If GOK<1 : Return : Endif
Return

$LET_OD
For [PMP2]PMP2(8) Where NUM = [F:PMP]NUM & NUMORD = [F:PMP]NUMORD & LEDTYP = [F:PMP]LEDTYP & OCC2 = 0
 XNBLET = 0 : LETLED = 0
 DEVISE = [F:PMP2]CUR
 XNBLET = 1
 XACCNUM(XNBLET) = [F:PMP2]ACCNUM
 XDUDLIG(XNBLET) = [F:PMP2]DUDLIG
 XAMTIPTCUR(XNBLET) = [F:PMP2]AMTIPTCUR
 XAMTIPTLED(XNBLET) = [F:PMP2]AMTIPTLED
 For [PMP3]PMP0 Where NUM = [F:PMP2]NUM & NUMORD = [F:PMP2]NUMORD & LEDTYP = [F:PMP2]LEDTYP
&                  & OCC1 = [F:PMP2]OCC1 & OCC2<>0 & FCY=[F:PMP2]FCY & CUR=[F:PMP2]CUR
&                  & ACC  = [F:PMP2]ACC & BPR=[F:PMP2]BPR
  If !LETLED & DEVISE <> [F:PMP3]CUR : LETLED = 1 : Endif
  XNBLET += 1
  If XNBLET>=MAXLIG : # Trop d'échéances ŕ lettrer (MAXLIG>MAXLIG)
   Call ECR_TRACE(mess(81,117,1)-"(MAXLIG>"+num$(MAXLIG)+")",1) From GESECRAN : GOK=0 : Break 2
  Endif
  XACCNUM(XNBLET) = [F:PMP3]ACCNUM
  XDUDLIG(XNBLET) = [F:PMP3]DUDLIG
  XAMTIPTCUR(XNBLET) = [F:PMP3]AMTIPTCUR
  XAMTIPTLED(XNBLET) = [F:PMP3]AMTIPTLED
 Next
 Gosub LET_DIF
Next
If GOK<1 : Return : Endif
Return


$LET_STD
For [PMP2]PMP0(7) Where NUM = [F:PMP]NUM & NUMORD = [F:PMP]NUMORD & LEDTYP = [F:PMP]LEDTYP & OCC2 = 0
 XNBLET = 0 : LETLED = 0
 DEVISE = [F:PMP2]CUR
 XNBLET = 1
 XACCNUM(XNBLET) = [F:PMP2]ACCNUM
 XDUDLIG(XNBLET) = [F:PMP2]DUDLIG
 XAMTIPTCUR(XNBLET) = [F:PMP2]AMTIPTCUR
 XAMTIPTLED(XNBLET) = [F:PMP2]AMTIPTLED
 For [PMP3]PMP0 Where NUM = [F:PMP2]NUM & NUMORD = [F:PMP2]NUMORD & LEDTYP = [F:PMP2]LEDTYP
&                  & OCC1 = [F:PMP2]OCC1 & OCC2<>0 & FCY=[F:PMP2]FCY
&                  & ACC  = [F:PMP2]ACC & BPR=[F:PMP2]BPR
  If !LETLED & DEVISE <> [F:PMP3]CUR : LETLED = 1 : Endif
  XNBLET += 1
  If XNBLET>=MAXLIG : # Trop d'échéances ŕ lettrer (MAXLIG>MAXLIG)
   Call ECR_TRACE(mess(81,117,1)-"(MAXLIG>"+num$(MAXLIG)+")",1) From GESECRAN : GOK=0 : Break 2
  Endif
  XACCNUM(XNBLET) = [F:PMP3]ACCNUM
  XDUDLIG(XNBLET) = [F:PMP3]DUDLIG
  XAMTIPTCUR(XNBLET) = [F:PMP3]AMTIPTCUR
  XAMTIPTLED(XNBLET) = [F:PMP3]AMTIPTLED
 Next
 Gosub LET_DIF
Next
If GOK<1 : Return : Endif
Return

$DELPAYMTC
## Effacement de la table temporaire servant aux lettrages
Delete [PMP] Where NUM = [L]NUMDOC
If fstat=1
 GOK=-1 : GLOCK = "PAYTMPMTC"-[L]NUMDOC : Return
Endif
Delete [PM2] Where UIDUSR=adxuid(2)
If fstat=1
 GOK=-1 : GLOCK = "PAYTMPMTC2"-num$(adxuid(2)) : Return
Endif
Return


$DELPAYPTP
## Effacement de la table temporaire PAYTMP
Delete [PTP] Where UIDUSR=adxuid(2)
If fstat=1
 GOK=-1 : GLOCK = "PAYTMP"-num$(adxuid(2)) : Return
Endif
Return

$LET_DIF
If XNBLET>1
 # Si =1, ça veut dire qu'il y a une ligne de pičce auto qui devait intervenir dans le
 # groupe lettrage et qui n'a pas été générée
 If LETLED
  Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTLED,-1) From CPTLET
 Else
  Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTCUR,-2) From CPTLET
 Endif
Endif
Return

$CONTROLE
Read [F:PYH3]PYH0 = [F:PYH2]NUM
Call DROIT([F:PYH3]FCY,[F:PYH3]FRMFCY,OK)
If !OK : Return : Endif

# If all cpy then only take PYH where leg CPY = screen LEG
If dim([M:DIA]ALLCPY)>0  & [M:DIA]ALLCPY=2
 Call LEC_CPY([F:PYH3]CPY) From CPTLEC
 If [F:CPY]LEG <> GCURLEG : OK=0 : Return : Endif
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYH3]PAYTYP) From CPTLEC
If fstat=0 : Gosub ACCES : Endif
If !OK : Return : Endif

If [F:TPY]DACCHQNUM=1 & [PYH3]CHQNUM="" & [F:TPY]SNS=1 & ([F:TPY]EDTFLG=2| [F:TPY]CODEDT="")
 Call ECR_TRACE([F:PYH3]NUM-":"-mess(17,121,1),1) From GESECRAN
 OK = 0 : Return
Endif

Case [M:DIA]ACCSTA
 When 3 : # Mise en portefeuille (par rčglement forcément)
  If [F:TPY]STA3=2 & [F:PYH3]STAFLG(2)<>2 & ([F:TPY]STA2<>2 | [F:PYH3]STA>=2)
   OK = 1
  Else
   OK = 0
  Endif
 When 8
  If [F:TPY]STA8=2 & [F:PYH3]STAFLG(7)<>2
&    & ([F:TPY]STA2<>2 | [F:PYH3]STA>=2)
&    & ([F:TPY]STA3<>2 | [F:PYH3]STA>=3)
&    & (([F:TPY]STA5<>2 & [F:TPY]STA7<>2) | [F:PYH3]FRMNUM<>"")
   OK = 1
  Else
   OK = 0
  Endif
 When 9
  If [F:TPY]STA9=2 & [F:PYH3]STAFLG(8)<>2
&    & ([F:TPY]STA2<>2 | [F:PYH3]STA>=2)
&    & ([F:TPY]STA3<>2 | [F:PYH3]STA>=3)
&    & (([F:TPY]STA5<>2 & [F:TPY]STA7<>2) | [F:PYH3]FRMNUM<>"")
&    & ([F:TPY]STA8<>2 | [F:PYH3]STA>=8)
   OK = 1
  Else
   OK = 0
  Endif
  If OK=1 & [F:TPY]EDTFLG=2
   Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
   If !fstat & (([F:TED]TRT="CHE" & [F:PYH3]CHQNUM="") | ([F:TED]TRT="TRE" & [F:PYH3]EDTNUM=0))
    OK=0
   Else
    OK=1
   Endif
  Endif
Endcase
If !OK : Return : Endif
Gosub CONT_DEVISE
If !OK : Return : Endif
#Issue X3-160529 – 2019-10-07  by VAVIL - SVAT - Changes related GESPAY function in Payment attributes
If func AFNC.ACTIV("KPO") > 0 & GCURLEG ="POR" : Gosub CONT_SVT_POR : Endif
If !OK : Return : Endif
#Issue end
If [F:PYH3]FLGEND=2 : OK=0 : Return : Endif
Return

$CONTROLE2
Read [F:PYH3]PYH0 = [F:PYH2]NUM
Call DROIT([F:PYH3]FCY,[F:PYH3]FRMFCY,OK)
If !OK : Return : Endif
#If all cpy then only take PYH where leg CPY = screen LEG
If dim([M:DIA]ALLCPY)>0  & [M:DIA]ALLCPY=2
 Call LEC_CPY([F:PYH3]CPY) From CPTLEC
 If [F:CPY]LEG <> GCURLEG : OK=0 : Return : Endif
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYH3]PAYTYP) From CPTLEC
If fstat=0 : Gosub ACCES : Endif
If !OK : Return : Endif

If [F:TPY]DACCHQNUM=1 & [PYH3]CHQNUM="" & [F:TPY]SNS=1 & ([F:TPY]EDTFLG=2 | [F:TPY]CODEDT="")
 Call ECR_TRACE([F:PYH3]NUM-":"-mess(17,121,1),1) From GESECRAN
 OK = 0 : Return
Endif

Case [M:DIA]ACCSTA
 When 9
  If [F:TPY]STA9=2 & [F:PYH3]STAFLG(8)<>2
&    & ([F:TPY]STA2<>2 | [F:PYH3]STA>=2)
&    & ([F:TPY]STA3<>2 | [F:PYH3]STA>=3)
&    & (([F:TPY]STA5<>2 & [F:TPY]STA7<>2) | [F:PYH3]FRMNUM<>"")
&    & ([F:TPY]STA8<>2 | [F:PYH3]STA>=8)
   OK = 1
  Else
   OK = 0
  Endif
  If OK=1 & [F:TPY]EDTFLG=2
   Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
   If !fstat & (([F:TED]TRT="CHE" & [F:PYH3]CHQNUM="") | ([F:TED]TRT="TRE" & [F:PYH3]EDTNUM=0))
    OK=0
   Else
    OK=1
   Endif
  Endif
  ## Contrôle supplémentaire : si la transaction est flaguée 'Comptabililisation intermédiaire', on vérifie que
  ## TOUS les rčglements sont bien flagués STAFLG(7) = 2
  If [F:PYH2]FRMNUM<>"" & [F:TPY]STA8=2
   Filter [PYH3] Where FRMNUM=[F:PYH2]FRMNUM & STA<9 & STAFLG(7)<>2
   Read [PYH3]PYH1 First
   Filter [PYH3]
   If !fstat
    ## Tous les rčglements n'ont pas été remis sur compte intermédiaire
    OK = 0 : Call ECR_TRACE(mess([F:PYH2]FRMFLG,685,1)-[F:PYH2]FRMNUM-":"-mess(221,117,1),1) From GESECRAN
   Endif
  Endif
Endcase
#Issue X3-160529 – 2019-10-07  by VAVIL - SVAT - Changes related to GESPAY function in Payment attributes
If func AFNC.ACTIV("KPO") > 0 & GCURLEG ="POR" : Gosub CONT_SVT_POR : Endif
#Issue end
If !OK : Return : Endif
Return

$ACCES
If [M:DIA]TYP<>"" : OK=1
Elsif [F:TPY]ENAFLG<>2 : OK=0
Elsif dim([F:TPY]ACS)>0
 Call CONTEXE([F:TPY]ACS) From CPTSUB
 If mkstat : mkstat=0 : GMESSAGE="" : OK=0 : Else OK=1 : Endif
Else OK=1
Endif
Return

$CONT_DEVISE
Local Char PLAN(GLONCOA)
If [M:DIA]ACCSTA<>9
 ## On regarde que le compte de trésorerie qui va ętre mouvementé ŕ l'étape courante est associé ŕ une devise et
 ## si c'est le cas on regarde que la devise ne soit pas différente de la devise associée ŕ la banque et
 ## si c'est le cas on bloque avec "Devises incompatibles"
 If clalev([F:TB0])=0 :  Local File PAYMENTH   [TB0] : Endif
 Read [TB0]PYH0 = [F:PYH2]NUM
 If clalev([F:TB1])=0 :  Local File PAYMENTD   [TB1] : Endif
 Read [TB1]PYD0 = [F:PYH2]NUM ; 1
 Call SETMAINREF([F:PYH2]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call LECPLAN([F:PYH2]CPY,GTYPGEN,PLAN) From CPTDIV
 Call CPTTRESO([M:DIA]ACCSTA,[F:PYH2]CPY,GTYPGEN,CPT_TRESO,STAT) From CPTINIVAR
 Call LEC_CPY([F:PYH2]CPY) From CPTLEC
 Call LEC_BAN([F:PYH2]BAN) From CPTLEC
 Call LEC_GAC(CPT_TRESO,PLAN) From CPTLEC
 If !fstat & [F:GAC]CUR<>"" & [F:BAN]CUR<>"" & [F:GAC]CUR<>[F:BAN]CUR
  ## Devises incompatibles
  OK = 0 : Call ECR_TRACE(mess(45,102,1)-CPT_TRESO-"=>"-[F:GAC]CUR-";"-mess(45,102,1)-[F:BAN]BANACC-"=>"-[F:BAN]CUR-":"-mess(110,107,1),1) From GESECRAN
 Endif
Endif
Return

$CONT_SVT_POR
#Issue X3-160529 – 2019-10-07  by VAVIL - SVAT - Changes related to GESPAY function in Payment attributes
For [PYD]PYD0 Where [PYD]NUM = [F:PYH3]NUM
  Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
  If [PYD]VCRNUM ="" & [F:PYH3]BPRTYP = 1 & [F:CDA]ACCTYP = 1  & [M]BPR<>""
    OK = 0 : Call ECR_TRACE([F:PYH3]NUM- mess(319,7711,1),1) From GESECRAN   : Break
  Endif
Next
#Issue end
Return

$VAL_IMPOSE
If [F:PYH2]FRMNUM = "" : SITE = [F:PYH2]FCY
Else                   : SITE = [F:PYH2]FRMFCY
Endif
Call GETSOC([L]SITE) From DEVSUB
If clalev([F:TB0])=0 :  Local File PAYMENTH   [TB0] : Endif
Call LEC_BAN([F:PYH2]BAN) From CPTLEC
Read [TB0]PYH0 = [F:PYH2]NUM
##############################################################################################
# 1°) JOURNAL : # Recherche journal définie avec SRD/CB le 31/10/02
# - La pičce sera générée sur le journal de la pičce auto
Local Integer TYPREM
[L]JOURNAL = ""
If dim([F:GAU]NBRLEG)>0 & [F:GAU]NBRLEG<>0
 #x3-137577 new file for leg gautacel
 #If find(GCURLEG,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
 Read [GALEG]GALEG0 =[F:GAU]COD;0;GCURLEG
 If fstat = 0
    Call EVAL_CHAR([L]JOURNAL,"JOU",1,0,"",STAT) From CPTAUTO
 Endif
Else
 Call EVAL_CHAR([L]JOURNAL,"JOU",1,0,"",STAT) From CPTAUTO
Endif
# - Si pas de journal associé ŕ la pičce auto, on prend le journal associé au type de journal
#   de l'étape de comptabilisation courante paramétré dans la table de la banque
If [L]JOURNAL = ""
 Call LEC_BAN([F:PYH2]BAN) From CPTLEC
 If [M:DIA]ACCSTA<>8
  If fstat=0 & evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))<>len(mess(0,660,1)) : # aucun
   T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
   If T : [L]JOURNAL = [F:BAN]JOU(T-1) : Endif
  Endif
 Else
  ## Compta intermédiaire : on a un champ type journal si encaissement (JOU8) et un champ type journal si escompte (JOU82)
  If fstat=0
   If find([F:TB0]FRMTYP,0,1,3)
    If [F:TPY]JOU8<>len(mess(0,660,1)) : # aucun
     T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
     If T : [L]JOURNAL = [F:BAN]JOU(T-1) : Endif
    Endif
   Else
    If [F:TPY]JOU82<>len(mess(0,660,1)) : # aucun
     T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)+num$(2)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
     If T : [L]JOURNAL = [F:BAN]JOU(T-1) : Endif
    Endif
   Endif
  Endif
 Endif
Endif
# - Si pas de journal trouvé, on prend le journal paramétré dans le paramčtre JOUPAY[X],
#   [X] correspondant au type de journal de l'étape de comptabilisation courante
If [L]JOURNAL = ""

 If [M:DIA]ACCSTA<>8
  Call PARAM(SITE,"JOUPAY"+num$(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))),[L]JOURNAL) From ADOVAL
 Else
  If find([F:TB0]FRMTYP,0,1,3)
   Call PARAM(SITE,"JOUPAY"+num$(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))),[L]JOURNAL) From ADOVAL
  Else
   Call PARAM(SITE,"JOUPAY"+num$(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)+num$(2))),[L]JOURNAL) From ADOVAL
  Endif
 Endif

Endif
# - Si pas de journal trouvé, on prend le journal par défaut du type de pičce
If [L]JOURNAL = ""
 Call EVAL_CHAR([L]TYPPCE,"GTE",1,0,"",STAT) From CPTAUTO
 If [L]TYPPCE<>""
  Call LEC_GTE_LEG(GCURLEG,[L]TYPPCE) From CPTLEC
  If !fstat
   [L]JOURNAL = [F:GTE]DEFJOU
  Endif
 Endif
Endif
If [L]JOURNAL=""
 STAT = 1 : TMESSA(1) = PCEAUTO-":"-mess(53,141,1) : # Journal non défini
 Return
Else
 STAT = 0
Endif
TZONE(1) = "JOU" : TVAL(1) = [L]JOURNAL
####################################################################################################
# 2°) REFINT : Référence interne de la pičce (sert notamment pour les zooms rčglements). On l'initialise
# comme ne 130 par 'PYH [No rčglt]' lorsque la pičce concerne qu'un rčglement
# Lorsque la pičce concerne X rčglements (validation  groupée d'un bordereau), ce champ est laissé
# ŕ vide comme en 130..)
If VALGRP=0 & NUMREG<>""
 TZONE(2) = "REFINT" : TVAL(2) = "PYH"-NUMREG
Else
 TZONE(2) = "REFINT" : TVAL(2) = "FRM"-[F:PYH2]FRMNUM
Endif
TZONE(3) = "TYPDUD" : TVAL(3)= "3"
TZONE(5) = "ORIGIN" : TVAL(5)= "2"            #Automatic loading  #*X3-39795
TZONE(6) = "ORICOD" : TVAL(6)= PCEAUTO                            #*X3-39795

###########################################################################################################
# 4°) TYP : Type de pičce
# - La pičce sera générée sur le type de pičce défini dans la pičce auto (évaluation de la formule)
# - si pas de type de pičce trouvé, la pičce sera générée sur le type de pičce associé au type de journal
# de l'étape de comptabilisation courante paramétré dans la fiche banque
###########################################################################################################
[L]TYPPCE = ""
If dim([F:GAU]NBRLEG)>0 & [F:GAU]NBRLEG<>0
 #x3-137577
 #If find(GCURLEG,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
 Read [GALEG]GALEG0=[F:GAU]COD;0;GCURLEG
 If fstat =0
  Call EVAL_CHAR([L]TYPPCE,"GTE",1,0,"",STAT) From CPTAUTO
 Endif
Else
 Call EVAL_CHAR([L]TYPPCE,"GTE",1,0,"",STAT) From CPTAUTO
Endif
If STAT
 TMESSA(1) = mess(10,105,1)-mess(65,106,1)-GMESSAGE
 Close File [TB0]
 Return
Endif

If [L]TYPPCE=""
 Call LEC_BAN([F:PYH2]BAN) From CPTLEC
 If [M:DIA]ACCSTA<>8
  If fstat=0 & evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))<>len(mess(0,660,1)) : # aucun
   T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
   If T : [L]TYPPCE = [F:BAN]GTE(T-1) : Endif
  Endif
 Else
  ## Compta intermédiaire : on a un champ type journal si encaissement (JOU8) et un champ type journal si escompte (JOU82)
  If fstat=0
   If find([F:TB0]FRMTYP,0,1,3)
    If [F:TPY]JOU8<>len(mess(0,660,1)) : # aucun
     T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
     If T : [L]TYPPCE = [F:BAN]GTE(T-1) : Endif
    Endif
   Else
    If [F:TPY]JOU82<>len(mess(0,660,1)) : # aucun
     T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)+num$(2)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
     If T : [L]TYPPCE = [F:BAN]GTE(T-1) : Endif
    Endif
   Endif
  Endif
 Endif
Endif
Close File [TB0]
TZONE(4) = "TYP" : TVAL(4) = [L]TYPPCE
Return

Subprog DROIT(SIT1,SIT2,OK)
Value Char SIT1(), SIT2()
Variable Integer OK
If [M:DIA]ALLFCY<>2 : OK=1
Elsif [M:DIA]ACCSTA=3 | ([M:DIA]ACCSTA=9 & [M:DIA]PAY9=2)
 OK=find(SIT1,GUSRFCY(1..GNBAUZ))
Else
 OK=find(SIT2,GUSRFCY(1..GNBAUZ))
Endif
If !OK : End
Elsif [M:DIA]PRO<>2             : OK=1
Elsif !instr(1,GUSRAUZ(OK),"G") : OK=0
Else OK=1
Endif
End

$MAJFRM
If MAJFRM & NUMBOR<>"" & [M:DIA]ACCSTA<>3
 Call DEBTRANS From GLOCK
 Gosub TR_MAJFRM
Endif
Return

$TR_MAJFRM

## MAJ du champ STA (état) du bordereau.
## Le bordereau passe ŕ l'état 'supérieur' si TOUS les rčglements du bordereau ont été traités
## (nb : dans le cas d'une validation de bordereau par rčglement, si un rčglement n'est
## pas traité suite ŕ une erreur, on traite quand męme les autres (1 transaction par rčglement))
Trbegin [FRM]
 Readlock [FRM]FRM0 = TYPBOR;NUMBOR
 If fstat=1
  GOK=-1 : GLOCK="$PAYFRM"-num$(TYPBOR)-NUMBOR
  MESSA="FRM\"+num$(TYPBOR)-NUMBOR : Goto ROLL_TR_MAJFRM
 Endif
 If [F:FRM]STA<>[M:DIA]ACCSTA
  [F:FRM]STA = [M:DIA]ACCSTA
  Rewrite [FRM]
  If fstat
   GOK=0 : Call FSTA("FRM") From GLOCK
   MESSA="FRM\"+num$(TYPBOR)-NUMBOR : Goto AB_TR_MAJFRM
  Endif
 Endif
Commit
Return


$AB_TR_MAJFRM
Rollback
Return

$ROLL_TR_MAJFRM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJFRM : Endif
Return


##########################################################
# Actions appelés sur les lignes de pičces auto
##########################################################
$LECDEVBAN
Local Char CPT_TRESO(GLONGAC), PLAN(GLONCOA)
If clalev([F:GAC3])=0  : Local File GACCOUNT [GAC3]  : Endif
Call LECPLAN([F:TB0]CPY,GTYPGEN,PLAN) From CPTDIV
Call CPTTRESO([M:DIA]ACCSTA,[F:TB0]CPY,GTYPGEN,CPT_TRESO,STAT) From CPTINIVAR
If STAT : Return : Endif
fstat = 0
If [F:GAC3]COA<>PLAN or [F:GAC3]ACC<>CPT_TRESO
 Read [GAC3]GAC0 = PLAN;CPT_TRESO
Endif
Return

$REGROUP
# Action appelée sur certaines lignes de pičces auto (compte tiers, WAICCURACCX...)
# CRITIMP (critčre imposé): Pour avoir une ligne d'écriture par rčglement : utile
# dans le cas d'une validation groupée pour effectuer le lettrage mais utile aussi
# pour la MAJ du fichier PAYACCNUM (Action AV_CREAT_X appelé dans le WMGAUXXX)
# CRIMTC : Critčre pour lettrage entre pičces
#102289 RICAR 2014/11/06 - Angola tax stamp - BEGIN
#Case GCAS
# When 1
#  [L]CRITIMP = [F:TB1]NUM
#  [L]CRIMTC  = [F:TB1]NUM
# When 2
#  [L]CRITIMP = [F:TB1]NUM
#  [L]CRIMTC  = [F:TB0]FRMNUM+"/"+[F:TB1]NUM
# When 3
#  [L]CRITIMP = [F:TB1]NUM
#  [L]CRIMTC  = [F:TB1]NUM
# When 4
#  [L]CRITIMP = [F:TB1]NUM
#  [L]CRIMTC = [F:TB0]PAYLOT+"/"+[F:TB1]NUM
#Endcase
Case GCAS
 When 1
  [L]CRITIMP = [F:TB0]NUM
  [L]CRIMTC  = [F:TB0]NUM
 When 2
  [L]CRITIMP = [F:TB0]NUM
  [L]CRIMTC  = [F:TB0]FRMNUM+"/"+[F:TB0]NUM
 When 3
  [L]CRITIMP = [F:TB0]NUM
  [L]CRIMTC  = [F:TB0]NUM
 When 4
  [L]CRITIMP = [F:TB0]NUM
  [L]CRIMTC = [F:TB0]PAYLOT+"/"+[F:TB0]NUM
Endcase
If [L]REGROUP & [L]CRIGRP<>""
 [L]CRIMTC += "/"+[L]CRIGRP
Endif
#102289 RICAR 2014/11/06 - Angola tax stamp - END
Return

$APLIGFAC
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Call LECLED([M]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
#[M]DUDNUM(NOL) = [F:TB1]DUDNUM
#[M]DUDLIG(NOL) = [F:TB1]DUDLIG
## Action appelée aprčs la génération des lignes du tiers facturé.
## Pour les lignes mouvementant le tiers facturé, on stocke dans DUDNUM l'accnum correspondant ŕ l'échéance réglče
## par la ligne du rčglement qu'on est en train de traiter => Cela va nous servir ŕ créer les ordres de paiements
## (Table PAYORDER) pour les acomptes sur commandes achats et ventes
If [F:TB0]NUM = [F:PTP]NUM & [F:PTP]LIGCODACE = [F:GAD]LINNUM
 NUM_ORDRE2 = [F:PTP]NUMORD+1
Else
 NUM_ORDRE2 = 1
Endif
Read [DUD2]DUD1 = [F:TB1]DUDNUM ; [F:TB1]DUDLIG
If !fstat & find([F:DUD2]TYP,"*PO","*SO")
 [M]OLDLIG(NOL)   = NOL+1
 [F:PTP]TYPREC    = "PYO"
 [F:PTP]NUM       = [F:TB0]NUM
 [F:PTP]CODACE    = [F:GAU]COD
 [F:PTP]LIGCODACE = [F:GAD]LINNUM
 [F:PTP]VCRNUM    = NBVAL
 [F:PTP]LIG       = NOL+1
 [F:PTP]NUMORD    = NUM_ORDRE2 : # 1 rčglement qui rčgle X échéances...
 [F:PTP]SNS       = [L]SENS
 [F:PTP]CUR       = [M:HAE1]CUR
 [F:PTP]CURCPY    = DEVLED
 [F:PTP]AMTCUR    = [L]MONTLIG
 [F:PTP]DUDNUM    = [F:TB1]DUDNUM
 [F:PTP]DUDLIG    = [F:TB1]DUDLIG
 [F:PTP]UIDUSR    = adxuid(2)
 Write [PTP]
 If fstat
  GOK=0 : Call FSTA("PTP") From GLOCK
 Endif
 If GOK<1 : STAT = 20 : Return : Endif
Else
 ## Création d'un enregistrement de type 'GAU' : ce type d'enregistrement permettra de savoir pour les
 ## lignes de pičces mouvementant le tiers facturé, quelles sont les lignes de rčglements concernées. Cela servira
 ## dans la partie 'Préparation lettrage' ($MAJMTCTMP)
 [M]OLDLIG(NOL)   = NOL+1
 [F:PTP]TYPREC    = "GAU"
 [F:PTP]NUM       = [F:TB0]NUM
 [F:PTP]CODACE    = [F:GAU]COD
 [F:PTP]LIGCODACE = [M:HAE2]LIGPCEAUTO(NOL)
 [F:PTP]VCRNUM    = NBVAL : # Pour ce type d'enregistrement, on ne s'en sert pas
 [F:PTP]LIG       = [F:TB1]LIN : # Dans [F:PTP]LIG on y stocke ici le n° de la ligne de rčglement....
 [F:PTP]NUMORD    = NUM_ORDRE2
 [F:PTP]SNS       = [L]SENS
 [F:PTP]CUR       = [M:HAE1]CUR
 [F:PTP]CURCPY    = DEVLED
 [F:PTP]AMTCUR    = [F:TB1]PAYCURLIN
 [F:PTP]DUDNUM    = [F:TB1]DUDNUM
 [F:PTP]DUDLIG    = [F:TB1]DUDLIG
 [F:PTP]UIDUSR    = adxuid(2)
 Write [PTP]
 If fstat
  GOK=0 : Call FSTA("PTP") From GLOCK
 Endif
 If GOK<1 : STAT = 20 : Return : Endif
Endif
Return

$APLIGBAN
Gosub STKCPTRES : # Stockage accnum correspondant au compte tréso
Gosub MAJPOR    : # MAJ portefeuille
If GOK<1 : Return : Endif
Gosub MAJCAS1   : # MAJ Interface tréso (Etape I)
If GOK<1 : Return : Endif
Return

$APLIGODTRS
# Action 'aprčs création ligne' appelée sur la ligne de pičce auto correspondant au compte
# OD interdevise
# On stocke ici dans GLIGTRES le code pičce auto + ligne pičce auto correspondant
# au compte OD interdevise (on n'a pas encore l'accnum ŕ ce niveau...)
# (cela suppose que l'action STKCPTRES a bien été renseignée sur la ligne pičce auto
# correspondant au compte OD interdevise...)
If GLIGTRES2="" & ([F:GAU]TYPVCR=1 | [F:GAU]TYPVCR=7) : # Pičce principale, transfert de compte (A et T dans PAYACCNUM)
 [M]CODAUTACE(NOL) = [F:GAU]COD+"/"+num$([F:GAD]LINNUM)
 GLIGTRES2 = [M]CODAUTACE(NOL)
Endif
Return

$STKCPTRES
# Action 'aprčs création ligne' appelée sur la ligne de pičce auto correspondant au compte
# de trésorerie
# On stocke ici dans GLIGTRES le code pičce auto + ligne pičce auto correspondant
# au compte de trésorerie (on n'a pas encore l'accnum ŕ ce niveau...)
# (cela suppose que l'action STKCPTRES a bien été renseignée sur la ligne pičce auto
# correspondant au compte de trésorerie...)
Local Char     ABR(3)
Local Integer  TROUVE
Local Integer  ETAP, SCHEMA
If [F:GAU]TYPVCR=1 | [F:GAU]TYPVCR=7 : # Pičce principale, transfert de compte (A et T dans PAYACCNUM)
 [M]CODAUTACE(NOL) = [F:GAU]COD+"/"+num$([F:GAD]LINNUM)
 GLIGTRES1 = [M]CODAUTACE(NOL)
 ABR = "TB0" : Gosub CRITLIG
 [M]CRIMTC(NOL) = CRIT_LIG
 GLIGTRES2 = [M]CODAUTACE(NOL)
Elsif [F:GAU]TYPVCR=4 : # Od devise trésorerie (B dans PAYACCNUM)
 # La pičce d'OD tréso est générée ŕ la premičre comptabilisation pour les destinations de type Banque->Tiers
 # et ŕ la derničre comptabilisation pour les destinations de Banque->Compte (si les frais bancaires sont imputés
 # sur une devise différente de la devise de banque). Si on n'est pas dans la 1čre comptabilisation,
 # ne pas mettre ŕ jour GLIGTRES1 sinon on ne va pas réussir ŕ lettrer le compte de trésorerie de l'étape N-1 ŕ solder
 Gosub SCHEMA
 # Si SCHEMA est > 3 ŕ ce niveau, on n'est pas dans la premičre comptabilisation, ce qui signifie qu'on cherche
 # ici ŕ générer une pičce d'OD devise  pour une destination de type Banque->Cpt => On ne met pas ŕ jour GLIGTRES1
 If SCHEMA = 3 : # 1čre comptabilisation
  GLIGTRES1 = [M]CODAUTACE(NOL)
  ABR = "TB0" : Gosub CRITLIG
  [M]CRIMTC(NOL) = CRIT_LIG
 Endif
 GLIGTRES2 = [M]CODAUTACE(NOL)
Elsif [F:GAU]TYPVCR = 3 : # Pičce séparée Bq->Cpt (A2 dans PAYACCUM)
 [M]CODAUTACE(NOL) = [F:GAU]COD+"/"+num$([F:GAD]LINNUM)
 GLIGTRES2 = [M]CODAUTACE(NOL)
Endif
Return

$SCHEMA
## Schéma de comptabilisation ŕ générer
ETAP = [M:DIA]ACCSTA-1 : TROUVE = 0
While !TROUVE & ETAP>0
 If [F:TB0]ACCNUMTRE(ETAP-1)<>0
  TROUVE = 1 : SCHEMA = ETAP+1
 Else
  ETAP -= 1
 Endif
Wend
If SCHEMA = 0 : # C'est la premičre comptabilisation...
 SCHEMA = 3
Endif
Return

$CRITLIG
Local Char CRIT_LIG
Case GCAS
 When 1
  CRIT_LIG = num$(GCAS)+"/"+num$([M:DIA]ACCSTA)+"/"+evalue("[F:"+ABR+"]NUM")
 When 2
  CRIT_LIG = num$(GCAS)+"/"+num$([M:DIA]ACCSTA)+"/"+evalue("[F:"+ABR+"]FRMNUM")
 When 3
  #CRIT_LIG = num$(GCAS)+"/"+num$([M:DIA]ACCSTA)+"/"+evalue("[F:"+ABR+"]NUM")  : #+"/"+format$(GFMDAT,evalue("[F:"+ABR+"]DUDDAT"))
  CRIT_LIG = num$(GCAS)+"/"+num$([M:DIA]ACCSTA)+"/"+format$(GFMDAT,evalue("[F:"+ABR+"]DUDDAT"))
 When 4
  CRIT_LIG = num$(GCAS)+"/"+num$([M:DIA]ACCSTA)+"/"+evalue("[F:"+ABR+"]PAYLOT")
Endcase
Return

$MAJPOR
Local Char DEVLED(GLONCUR)
Local Decimal MONTLED, WAMT
Local Integer WIFFTYP
Local Integer OKUPDMVT

Call GETDEV([F:TB0]FCY) From DEVSUB
Call SETCUR(1,[F:TB0]CPY,DEVLED) From CPTDIV
Gosub SCHEMA
If SCHEMA = 3
 Call LEC_BPR([F:TB0]BPR) From CPTLEC
 OKUPDMVT = 1
 GPOINT = "UPDMVT" : Gosub ENTREE From EXEFNC
 If OKUPDMVT=1
  ## Partie clients
  If fstat=0 & [F:TB0]BPRTYP=1 & [F:TB0]SNS<>1 & [F:BPR]BPCFLG=2 : # Recette client
   # Condition pour mettre ŕ jour les cumuls    (BPCUSTMVT)
   If [M:DIA]ACCSTA=3 & [F:TPY]UPDBIL>1 & MONTLIG<>0 & [F:TB0]BPR<>""
    WAMT = MONTLIG
   Endif
   # Męme si les cumuls se sont pas mis ŕ jour, appel pour la mise ŕ jour des documents (LASTCUSMVT)
   Call MAJMVC([F:TB0]BPR,[M:HAE1]CUR,[M:HAE1]TYPRAT,0,[M:HAE0]ACCDAT,[F:TB0]NUM,[F:TB0]FCY,WAMT,[F:TB0]AMTCUR,"+","P","C",[F:TPY]UPDBIL) From TRTBPMVT

  Elsif fstat=0 & [F:TB0]BPRTYP=2 & [F:TB0]SNS=1 & [F:BPR]BPSFLG=2 : # Dépense fournisseur
   # Condition pour mettre ŕ jour les cumuls    (BPSUPPMVT)
   If [M:DIA]ACCSTA=3 & [F:TPY]UPDBIL>1 & MONTLIG<>0 & [F:TB0]BPR<>""
    WAMT = MONTLIG
    WIFFTYP = [F:TPY]UPDBIL+6
   Else
    WIFFTYP = 8 :#80467
   Endif
   # Męme si les cumuls se sont pas mis ŕ jour, appel pour la mise ŕ jour des documents (LASTSUPMVT)
   Call MAJENC_BPS([F:TB0]BPR,WIFFTYP,[F:TB0]FCY,[F:TB0]CUR,[M:HAE1]TYPRAT,[M:HAE0]ACCDAT,
&                  [F:TB0]NUM,WAMT,0,[F:TB0]AMTCUR) From TRTBPMVT
  Endif
 Endif

 # Mise ŕ jour du champ AMTNYTBIL
 If [M:DIA]ACCSTA = 3
  Call COURMNT([M:HAE1]CUR,DEVLED,DEVLED,0,[M:HAE0]ACCDAT,1,MONTLIG,MONTLED,0,STAT) From TRTDEV
  If STAT
   # Pas de cours
   Call ECR_TRACE(mess(4,109,1)-[M:HAE1]CUR-"=>"-DEVLED,1) From GESECRAN
  Else
   Read [PYH4]PYH0 = [F:TB0]NUM
   If !fstat
    [F:PYH4]AMTNYTBIL += MONTLED
    Rewrite [PYH4]
    If fstat
     GOK=0 : Call FSTA("PYH4") From GLOCK : Return
    Endif
   Endif
  Endif
 Endif

Endif
Return

$MAJCAS1
# Sous programme lié ŕ la gestion d'une interface trésorerie (code activité CASSIN)
If !func AFNC.ACTIV("CASIN") : Return : Endif
If [F:GAU]TYPVCR=8 : Return : Endif     # Pas de flux de trésorerie sur des pičces d'effet ŕ l'escompte
Local Char TREBAN(30),TRECUR(GLONCUR)
Local Integer ETAP : ETAP =[M:DIA]ACCSTA
Local Integer IMAINREF : IMAINREF = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))

# Table PYHCAS permet de stocker tous les éléments issus d'une comptabilité d'un rčglement ou de son annulation.
# Cette table est mouvementée SI :
#  1 - Le schéma de compte est de type BANQUE <=> TIERS
#  2 - La transaction de rčglements a identifié un fait générateur (champ FLGCAS de TABPAYTYP)
#  3 - Si la banque est rensignée, X3 impose un code remplaçant le TRECOD : "FIC"+société+devise

# Condition 1 : Recherche de l'élément déclenchant
If [F:TB1]ACCTYP<>1 or [F:TPY]FLGCAS<=1 : Return : Endif
Case ETAP
 When 3 : # Mise en portefeuille
  If [F:TPY]FLGCAS<>2 : Return : Endif
 When 8 : # Comptabilisation intermédiaire
  If [F:TPY]FLGCAS<>3 : Return : Endif
 When 9 : # Remise en banque
  If [F:TPY]FLGCAS<>4 : Return : Endif
 When Default
  Return
Endcase

# Condition 2 : Recherche du TRECOD
Call LEC_TCU([F:TB0]CUR) From CPTLEC
If [F:TCU]ISOCOD<>""
 [L]TRECUR = [F:TCU]ISOCOD
Else
 [L]TRECUR = [F:TCU]CUR
Endif

Raz [L]TREBAN
If [F:TB0]BAN<>""
 Call LEC_BAN([F:TB0]BAN) From CPTLEC
 [L]TREBAN=[F:BAN]TRECOD
Else
 [L]TREBAN="FIC"+format$("K:5X",[F:TB0]CPY)+format$("K:3X",[L]TRECUR)
Endif
If [L]TREBAN="" : Return : Endif

# Les 2 conditions sont justes, la table PYHCAS peut ętre mouvementée.
Raz [F:PCH]

# Element indispensable pour alimenter les zones du fichier des flux du rčglements
[F:PCH]TRECOD = [L]TREBAN
[F:PCH]ISOCOD = [L]TRECUR

#--- Montant banque => Montant dans la devise de banque
If [F:TB0]BAN = "" or [F:BAN]CUR = [M]CUR
 [F:PCH]AMTBAN = [L]MONTLIG
Elsif [F:BAN]CUR = [F:CPY]ACCCUR &  TMONTFORCE(GTYPGEN)<>0
 [F:PCH]AMTBAN = TMONTFORCE(GTYPGEN)
Else
 Call CONVERT([M]CUR,[F:BAN]CUR,[F:CPY]ACCCUR,[M:HAE1]TYPRAT,
&             [M:HAE1]RATDAT,[L]MONTLIG,[F:PCH]AMTBAN,STAT) From TRTDEV
 If STAT
  Call ECR_TRACE(mess(4,109,1)-[M]CUR-"=>"-[F:BAN]CUR,1) From GESECRAN  : STAT=20 : Return
 Endif
Endif
#--- Montant d'opération/rčglements
[F:PCH]AMTCUR = [F:TB0]AMTCUR

#--- Devise de compte "banque"
If [F:TB0]BAN <> ""  :  [F:PCH]CURBAN = [F:BAN]CUR : Endif
If [F:PCH]CURBAN=""  :  [F:PCH]CURBAN = [F:TB0]CUR : Endif

If [M]DEB(NOL)<>0                               : [F:PCH]SNS=1
Elsif [M]CDT(NOL)<>0                            : [F:PCH]SNS=-1
Elsif evalue("[M]AMT"+num$(IMAINREF)+"(NOL)")>0 : [F:PCH]SNS=1
Elsif evalue("[M]AMT"+num$(IMAINREF)+"(NOL)")<0 : [F:PCH]SNS=-1
Else                                            : [F:PCH]SNS=1
Endif

[F:PCH]PAM    = [F:TB0]PAM
[F:PCH]CHQNUM = [F:TB0]CHQNUM
[F:PCH]PAYTYP = [F:TPY]PAYTYP

# Date d'opération :
#   Si le fait générateur = Remise en Banque
#        Date d'opération sera la date comptable
#   Pour les autres faits générateurs
#        Date d'opération sera la date comptable SI Date d'échéance < Date comptable
#        Date d'opération sera la date échéance  SI Date d'échéance > Date comptable
#
If [F:TPY]FLGCAS=4 or [M]DUDDAT<[M]ACCDAT
 [F:PCH]DAT = [M]ACCDAT
Else
 [F:PCH]DAT = [M]DUDDAT
Endif
[F:PCH]VALDAT = [M]VALDAT

# Element paramétré pour alimenter les zones du fichier des flux du rčglements
[F:PCH]NASS   = [F:PCH]CHQNUM

# Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SFRPT")
 Read [PYH]PYH0 = [F:TB0]NUM
 Filter [TFC] Where MODULE=9 and CODPAR=[F:TPY]PAYTYP
 Onerrgo ERR
 For [TFC]
  Case [TFC]CODCAS
   When "DESCR"  : [F:PCH]DESCR  = evalue([F:TFC]CLCFOR)
   When "REFXRT" : [F:PCH]REFXRT = evalue([F:TFC]CLCFOR)
  Endcase
 Next
 Onerrgo
Elsif func AFNC.ACTIV("T1000")
 Read [PYH]PYH0 = [F:TB0]NUM
 Filter [TFC] Where MODULE=9 and CODPAR=[F:TPY]PAYTYP
 Onerrgo ERR
 For [TFC]
  Case [TFC]CODCAS
   When "DOPE"   : [F:PCH]DOPE   = evalue([F:TFC]CLCFOR)
   When "TRANS"  : [F:PCH]TRANS  = evalue([F:TFC]CLCFOR)
   When "DESCR"  : [F:PCH]DESCR  = evalue([F:TFC]CLCFOR)
   When "REF"    : [F:PCH]REF    = evalue([F:TFC]CLCFOR)
   When "LCR"    : [F:PCH]LCR    = evalue([F:TFC]CLCFOR)
   When "BUDG"   : [F:PCH]BUDG   = evalue([F:TFC]CLCFOR)
  Endcase
 Next
 Onerrgo
Else
 Read [PYH]PYH0 = [F:TB0]NUM
 Filter [TFC] Where MODULE=9 and CODPAR=[F:TPY]PAYTYP
 Onerrgo ERR
 For [TFC]
  Case [TFC]CODCAS
   When "DOPE"   : [F:PCH]DOPE   = evalue([F:TFC]CLCFOR)
   When "NASS"   : [F:PCH]NASS   = evalue([F:TFC]CLCFOR)
   When "CPTA"   : [F:PCH]CPTA   = evalue([F:TFC]CLCFOR)
   When "CDC"    : [F:PCH]CDC    = evalue([F:TFC]CLCFOR)
   When "DESCR"  : [F:PCH]DESCR  = evalue([F:TFC]CLCFOR)
   When "CODRIF" : [F:PCH]CODRIF = evalue([F:TFC]CLCFOR)
  Endcase
 Next
 Onerrgo
Endif
If GOK<1 : STAT = 20 : Return : Endif


If [F:PCH]DOPE = [0/0/0] : [F:PCH]DOPE = [F:PCH]DAT    : Endif

# Element utilise pour les critčres lors du lancement de la génération du fichier
[F:PCH]CPY = [F:TB0]CPY
[F:PCH]FCY = [F:TB0]FCY
[F:PCH]CUR = [F:TB0]CUR
[F:PCH]BPR = [F:TB0]BPR
[F:PCH]SAC = [F:TB0]BPRSAC
[F:PCH]COA = [F:TB0]COA
[F:PCH]ACC = [F:TB0]ACC

# Element interne pour le suivi
[F:PCH]REGNUM = [F:TB0]NUM
[F:PCH]FRMNUM = [F:TB0]FRMNUM
[F:PCH]REGLIN = [F:TB1]LIN

[F:PCH]BAN    = [F:TB0]BAN
[F:PCH]ACCDAT = [M]ACCDAT
[F:PCH]DUDDAT = [M]DUDDAT

[F:PCH]CREUSR = GUSER
[F:PCH]CREDAT = date$

Write [PCH]
If fstat
 GOK = 0 : Call FSTA("PCH") From GLOCK
 If GTRACE<>"" : MESSA="PCH\"+[F:TB0]NUM : Endif
 Return
Endif
Return

$ERR
If GTRACE<>""
 # Erreur en évaluation de zone
 Call ECR_TRACE(mess(65,106,1)-[F:TFC]CODCAS-":"-errmes$(errn)-"("+num$(errn)+")",1) From GESECRAN
 GOK=0
Endif
Resume

$MAJCAS2
# Sous programme lié ŕ la gestion d'une interface tresorerie (code activité CASIN)
If !func AFNC.ACTIV("CASIN") : Return : Endif
I = find(GLIGTRES2,[M]CODAUTACE(0..[M:HAEW]NB-1))
If I
 # Mise ŕ jour de la table PYHCAS pour alimenter ACCNUM
 Update [PCH] Where ACCNUM=0 With ACCNUM=[M:HAEW]ACCNUM(I-1), TYPVCR=[M]TYP, NUMVCR=[M]NUM
 If fstat
  GOK = 0 : Call FSTA("PCH") From GLOCK
  If GTRACE<>"" : MESSA="PCH2\"+[F:TB0]NUM+num$([M:HAEW]ACCNUM(I-1)) : Endif
 Endif
Endif
Return

$CPTDETTE
## Action 'aprčs création ligne' appelée sur la ligne de pičce auto correspondant au compte
## de dettes pour effets dans la pičce auto STEPN (ligne de pičce auto réservé pour l'Espagne : code activité
## 'KSP' actif)
GLIGTRES3 = [M]CODAUTACE(NOL)
Return


$AP_PIECE
Gosub MAJMTCTMP
Gosub MAJPAN
Gosub MAJTAB
Gosub MAJCAS2 : # MAJ Interface tréso (Etape II)
Return


####################################################################################################
# Préparation du lettrage : MAJ table PAYMTCTMP
# Preparation of matching : Updating table PAYMTCTMP
####################################################################################################
$MAJMTCTMP
Local Char    GRPPCE(GLONGRA)
Local Char    PCEAUTO(GLONGAU), NUMDOC(GLONVCR)
Local Char    COLFAC(GLONSAC) : # Collectif facturé
Local Integer I, TNBOCC1(1..len(mess(0,2644,1))), TNBOCC2(1..len(mess(0,2644,1)))
Local Integer OKWRITMP, STAT2, WSENS, VU2
Local Integer IMAINREF
Local Integer FLGAUT, OPENTB1
Local Char    WMAINCOLFAC(GLONSAC)  # Issue X3-163360

Raz OPENTB1


If clalev([F:XTB0])=0 : Local File PAYMENTH  [XTB0] : Endif
If clalev([F:XTB1])=0 : Local File PAYMENTD  [XTB1] : Endif
If clalev([F:GAD2])=0 : Local File GAUTACED  [GAD2] : Endif
If clalev([F:GAG2])=0 : Local File GAUTACEF  [GAG2] : Endif
If clalev([F:TB0]) =0 : Local File PAYMENTH   [TB0] : Endif
If clalev([F:TB1]) =0 : Local File PAYMENTD   [TB1] : OPENTB1 = 1 : Endif

GRPPCE  = evalue("[F:TPY]AUTACE"+num$([M:DIA]ACCSTA))
PCEAUTO = [F:GAU]COD

IMAINREF = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))

Case GCAS
 When 1 : NUMDOC = [F:TB0]NUM
 When 2 : NUMDOC = [F:TB0]FRMNUM
 When 3 : NUMDOC = [F:TB0]FRMNUM
Endcase


For [GRM]GRM0 Where COD=GRPPCE & (CODACE1=PCEAUTO | CODACE2=PCEAUTO)
 # Lettrage avec facture
 # Matching with invoice
 If [F:GRM]CODACE1 = PCEAUTO & [F:GRM]INVMTC = 2
  I = find([F:GRM]LIG1,[M:HAEW]LIGPCEAUTO(0..[M:HAEW]NB-1))
  If I
   Raz TNBOCC1
   While [M:HAEW]LIGPCEAUTO(I-1)=[F:GRM]LIG1
    Call LEDTYPAUT([M:HAE0]CPY,[M:HAEW]LEDTYP(I-1),[L]FLGAUT) From CPTDIV
    If [L]FLGAUT<>2
     Raz [F:PMP]
     TNBOCC1([M:HAEW]LEDTYP(I-1)) += 1
     [F:PMP]NUM     = [L]NUMDOC
     [F:PMP]NUMORD  = [F:GRM]NUMORD
     [F:PMP]LEDTYP  = [M:HAEW]LEDTYP(I-1)
     [F:PMP]INVMTC  = 2
     [F:PMP]OCC1    = TNBOCC1([M:HAEW]LEDTYP(I-1))
     [F:PMP]OCC2    = 0
     [F:PMP]ACCNUM  = [M:HAEW]ACCNUM(I-1)
     [F:PMP]DUDLIG  = 1
     [F:PMP]FCY     = [M:HAEW]FCYLIN(I-1)
     [F:PMP]ACC     = [M:HAEW]ACC(I-1)
     [F:PMP]BPR     = [M:HAEW]BPR(I-1)
     [F:PMP]AMTIPTLED = [M:HAEW]AMTLED(I-1)
     [F:PMP]AMTIPTCUR = [M:HAEW]CDT(I-1)+[M:HAEW]DEB(I-1)
     [F:PMP]CUR = [M:HAE1]CUR
     [F:PMP]TYPVCR = [F:GAU]TYPVCR
     [F:PMP]UIDUSR = adxuid(2)
     Write [PMP]
     If fstat
      GOK=0 : Call FSTA("PMP") From GLOCK : Break 2
     Endif

     If [F:GRM]INVMTC=2
      # Lettrage avec facture si on a bien 'lignes de rčglements' ŕ 'oui' dans
      # le paramétrage du lettrage pour la pičce auto PCEAUTO1 et s'il n'y a pas de pičce
      # auto PCEAUTO2 générée
      # * Si [M:HAEW]INDGRP(I-1)=0, cela signifie que la condition détail lignes de la ligne
      # de pičce auto n'est pas vérifiée. Les lignes de pičces ont été regroupées par
      # SITE+"/"+COMPTE+"/"+TIERS+"/"+NATURE+"/"+TAXE+"/"+REPART+"/"+LIBEL+"/"+CRITIMP (CRITIMP
      # étant le critčre de regroupement imposé (=numéro de rčglement pour ne pas regrouper
      # les réglements sur une męme ligne)
      # Le filtre des lignes de rčglements pour le lettrage se fera sur le compte et le tiers
      # * Si [M:HAEW]INDGRP(I-1)=1, la condition a été vérifiée (ou est vide). Les lignes
      # de pičces ont été regroupées par SITE+"/"+COMPTE+"/"+TIERS+"/"+NATURE+"/"+TAXE+"/"
      # +REPART+"/"+LIBEL+"/"+"/"+CRITIMP+"/"+CRITGRP (CRIGRP étant le critčre libre
      # permettant d'avoir un détail par imputation ou par facture réglée).
      # Le filtre des lignes de rčglements  se fera sur le compte, le tiers et le
      # critčre de regroupement libre (qui doit ętre par définition un champ de [PYD]).
      # [M:HAEW]CRITGRP(I-1) va contenir ([F:PYD]VCRNUM="xxx" ou [F:PYD]LINNUM=2, par exemple)
      # ENG :
      # Matching with invoice: if 'Payment lines' is 'Yes' in the Matching setup of the auto journal PCEAUTO1
      # and if there is no PCEAUTO2 generated
      # * If [M:HAEW]INDGRP(I-1)=0, this means that the condition line detail of the line of the auto journal
      # is not fulfilled. Lines of the entries has been grouped by
      # SITE/ACCOUNT/BP/NATURE/TAXE/DIM ALLOC/DESCRIPTION/CRITIMP (CRITIMP being a mandatory grouping criteria
      # (= payment number in order not to group payments on a same line)
      # The filter of the payment lines for the matching is done on the account and the BP
      # * If [M:HAEW]INDGRP(I-1)=1, the condition has been fulfilled (or is empty). Lines of the entry have
      # been grouped by SITE/ACCOUNT/BP/NATURE/TAX/DIM ALLOC/DESCRIPTION/CRITIMP/CRITGRP (CRITGRP is
      # a free criteria in order to get detail by allocation or by invoice paid).
      # The filter of the payment lines is then done on the account, the BP and the free grouping criteria
      # (which should be a field of [PYD]).
      # [M:HAEW]CRITGRP(I-1) will contain ([F:PYD]VCRNUM="xxx" or [F:PYD]LINNUM=2, for example)
      Raz TNBOCC2

      For [PYD]PYD0 Where NUM = [M:HAEW]CRITGRPIMP(I-1)
&                        & (([M:HAEW]INDGRP(I-1)=0) | ([M:HAEW]INDGRP(I-1)=1 & evalue([M:HAEW]CRITGRP(I-1))))

       If [M:HAEW]LEDTYP(I-1) = GTYPGEN
        COLFAC = [F:PYD]BPRSACINV
        [L]WMAINCOLFAC = COLFAC     # Issue X3-163360
       Else
        ## Lecture du code collectif facturé du référentiel [M:HAEW]LEDTYP(I-1)
        ## Read of the invoiced BP control code of the ledger [M:HAEW]LEDTYP(I-1)
        Gosub LECCOL
       Endif
       # Issue X3-163360 - start
       ###########################################################################################################
       ##AUREN.STR 09-11-2021 usamos primera condición para que funcionen los marcajes automáticos, con la segunda condicion
       ## (que está comentada) creaba 3 registros por marcaje cuando imputado terceros era negativo.
       ###########################################################################################################
       If [F:PYD]BPRINV=[M:HAEW]BPR(I-1) & [F:PYD]BPRSACINV=[M:HAEW]SAC(I-1) & [F:PYD]FCYLIN=[M:HAEW]FCYLIN(I-1)
&      & (!find([F:GAU]TYPVCR,5,6) | [F:PYD]CURLIN=[M:HAE1]CUR)
#       If [F:PYD]BPRINV=[M:HAEW]BPR(I-1) & [F:PYD]BPRSACINV=[L]WMAINCOLFAC & [F:PYD]FCYLIN=[M:HAEW]FCYLIN(I-1)
#&      & (!find([F:GAU]TYPVCR,5,6) | [F:PYD]CURLIN=[M:HAE1]CUR)
       # Issue X3-163360 - end
       ############################################################################################################
       ##AUREN.FIN
       ############################################################################################################
        OKWRITMP = 1
        Read [GAD2]GAD0 = PCEAUTO ; [F:GRM]LIG1
        If !fstat & [F:GAD2]DEBCDT<>2
         Read [XTB0]PYH0 = [F:PYD]NUM
         Read [XTB1]PYD0 = [F:PYD]NUM;[F:PYD]LIN
         Read [TB0]PYH0 = [F:PYD]NUM
         Read [TB1]PYD0 = [F:PYD]NUM;[F:PYD]LIN
         Read [GAG2]GAG0 = PCEAUTO ; [F:GRM]LIG1 ; "SNS"
         VU2 = instr(1,[F:GAG2]FORCLC,"SENS2")
         If VU2
          Call SENS2([L]WSENS,STAT2) From CPTINIVAR
          Call SUBST([F:GAG2]FORCLC,"V_SENS2",num$([L]WSENS))
          If ([M:HAE2]DEB(I-1)<>0 & evalue([F:GAG2]FORCLC)*sgn([F:XTB1]AMTLIN2)<>1)
&          | ([M:HAE2]CDT(I-1)<>0 & evalue([F:GAG2]FORCLC)*sgn([F:XTB1]AMTLIN2)<>-1)
           OKWRITMP = 0
          Endif
         Else
          VU2 = instr(1,[F:GAG2]FORCLC,"SENS")
          If VU2
           Call SENS([L]WSENS,STAT2) From CPTINIVAR
           Call SUBST([F:GAG2]FORCLC,"V_SENS",num$([L]WSENS))
           If ([M:HAE2]DEB(I-1)<>0 & evalue([F:GAG2]FORCLC)*sgn([F:XTB1]AMTLIN)<>1)
&           | ([M:HAE2]CDT(I-1)<>0 & evalue([F:GAG2]FORCLC)*sgn([F:XTB1]AMTLIN)<>-1)
            OKWRITMP = 0
           Endif
          Endif
         Endif
        Endif

        If OKWRITMP
         Read [PTP]PTP2 = "GAU";[F:PYD]NUM;[F:PYD]LIN;[F:PYD]DUDNUM;[F:PYD]DUDLIG;PCEAUTO;[F:GRM]LIG1
         If !fstat
          Read [DUD]DUD1 = [F:PYD]DUDNUM ; [F:PYD]DUDLIG
          If !fstat & !find([F:DUD]TYP,"*SO","*PO")
           TNBOCC2([M:HAEW]LEDTYP(I-1)) += 1
           [F:PMP]NUM     = [L]NUMDOC
           [F:PMP]NUMORD  = [F:GRM]NUMORD
           [F:PMP]LEDTYP  = [M:HAEW]LEDTYP(I-1)
           [F:PMP]INVMTC  = 2
           [F:PMP]OCC1    = TNBOCC1([M:HAEW]LEDTYP(I-1))
           [F:PMP]DUDLIG  = 1
           [F:PMP]BPR     = [F:PYD]BPRINV
           [F:PMP]ACC     = [M:HAEW]ACC(I-1)
           [F:PMP]FCY     = [M:HAEW]FCYLIN(I-1)
           [F:PMP]AMTIPTLED = [M:HAEW]AMTLED(I-1)
           [F:PMP]AMTIPTCUR = [M:HAEW]CDT(I-1)+[M:HAEW]DEB(I-1)
           [F:PMP]CUR = [M:HAE1]CUR
           [F:PMP]OCC2 = TNBOCC2([M:HAEW]LEDTYP(I-1))
           If [M:HAEW]LEDTYP(I-1) = GTYPGEN
            [F:PMP]ACCNUM = [F:DUD]ACCNUM
            [F:PMP]DUDLIG = [F:DUD]DUDLIG
           Else
            Read [DAE8]DAE2 = [F:DUD]ACCNUM
            If !fstat
             Filter [DAE7] Where TYP=[F:DAE8]TYP & NUM=[F:DAE8]NUM & LEDTYP=[M:HAEW]LEDTYP(I-1) & IDTLIN=[F:DAE8]IDTLIN
             Read [DAE7] First
             If !fstat
              [F:PMP]ACCNUM = [F:DAE7]ACCNUM
              [F:PMP]DUDLIG = [F:DUD]DUDLIG
             Endif
             Filter [DAE7]
            Endif
           Endif
           [F:PMP]AMTIPTLED = [F:PYD]PAYLOCLIN
           [F:PMP]AMTIPTCUR = [F:PYD]PAYCURLIN
           [F:PMP]CUR = [F:PYD]CURLIN
           [F:PMP]TYPVCR = [F:GAU]TYPVCR
           [F:PMP]UIDUSR = adxuid(2)
           Write [PMP]
           If fstat
            GOK=0 : Call FSTA("PMP") From GLOCK : Break 3
           Endif
           If [M:HAEW]LEDTYP(I-1) = GTYPGEN
            [F:DUD]TMPCUR -= [F:PYD]PAYCURLIN
            [F:DUD]TMPLOC -= [F:PYD]PAYLOCLIN
            Call SLDECH("DUD")From MODECHE
            If [F:DUD]PAYDAT=[0/0/0]
             [F:DUD]PAYDAT = [M:HAE0]ACCDAT
            Else
             [F:DUD]PAYDAT = min([F:DUD]PAYDAT,[M:HAE0]ACCDAT)
            Endif
            Rewrite [DUD]
            If fstat
             GOK=0 : Call FSTA("DUD") From GLOCK : Break 3
            Endif
           Endif
          Endif
         Endif
        Endif
       Endif
      Next
     Endif
    Endif
    I += 1
   Wend
  Endif

 Else
  # Lettrage interne
  # Internal matching
  Raz TNBOCC1
  If [F:GRM]CODACE1 = PCEAUTO & [F:GRM]INVMTC<>2
   I = find([F:GRM]LIG1,[M:HAEW]LIGPCEAUTO(0..[M:HAEW]NB-1))
   If I
    While [M:HAEW]LIGPCEAUTO(I-1)=[F:GRM]LIG1
    Call LEDTYPAUT([M:HAE0]CPY,[M:HAEW]LEDTYP(I-1),[L]FLGAUT) From CPTDIV
     If [L]FLGAUT<>2
      Raz [PMP]
      TNBOCC1([M:HAEW]LEDTYP(I-1)) += 1
      [F:PMP]NUM     = [L]NUMDOC
      [F:PMP]NUMORD  = [F:GRM]NUMORD
      [F:PMP]LEDTYP  = [M:HAEW]LEDTYP(I-1)
      [F:PMP]INVMTC  = 1
      [F:PMP]OCC1    = TNBOCC1([M:HAEW]LEDTYP(I-1))
      [F:PMP]OCC2    = 0
      [F:PMP]FCY     = [M:HAEW]FCYLIN(I-1)
      [F:PMP]ACC     = [M:HAEW]ACC(I-1)
      [F:PMP]BPR     = [M:HAEW]BPR(I-1)
      [F:PMP]ACCNUM  = [M:HAEW]ACCNUM(I-1)
      [F:PMP]DUDLIG  = 1
      [F:PMP]AMTIPTLED = [M:HAEW]AMTLED(I-1)
      [F:PMP]AMTIPTCUR = [M:HAEW]CDT(I-1)+[M:HAEW]DEB(I-1)
      [F:PMP]CUR = [M:HAE1]CUR
      [F:PMP]UIDUSR = adxuid(2)

      Write [PMP]
      If fstat
       GOK=0 : Call FSTA("PMP") From GLOCK : Break 2
      Endif
     Endif
     I += 1
    Wend
   Endif
  Endif
  If [F:GRM]CODACE2 = PCEAUTO
   I = find([F:GRM]LIG2,[M:HAEW]LIGPCEAUTO(0..[M:HAEW]NB-1))
   If I
    # A ce niveau, si TNBACCNUM([F:GRM]NUMORD)>0, cela signifie que la ligne [F:GRM]LIG1 de la pičce [F:GRM]CODACE1
    # a été générée...
    # At this level, if TNBACCNUM([F:GRM]NUMORD)>0, that means the line [F:GRM]LIG1 of the entry [F:GRM]CODACE1
    # has been generated...
    Raz TNBOCC2
    While [M:HAEW]LIGPCEAUTO(I-1)=[F:GRM]LIG2
     Call LEDTYPAUT([M:HAE0]CPY,[M:HAEW]LEDTYP(I-1),[L]FLGAUT) From CPTDIV
     If [L]FLGAUT<>2
      Raz [PMP]
      TNBOCC2([M:HAEW]LEDTYP(I-1)) += 1
      [F:PMP]NUM     = [L]NUMDOC
      [F:PMP]NUMORD  = [F:GRM]NUMORD
      [F:PMP]LEDTYP  = [M:HAEW]LEDTYP(I-1)
      [F:PMP]INVMTC  = 1
      [F:PMP]OCC1    = 0
      [F:PMP]OCC2    = TNBOCC2([M:HAEW]LEDTYP(I-1))
      [F:PMP]FCY     = [M:HAEW]FCYLIN(I-1)
      [F:PMP]ACC     = [M:HAEW]ACC(I-1)
      [F:PMP]BPR     = [M:HAEW]BPR(I-1)
      [F:PMP]ACCNUM  = [M:HAEW]ACCNUM(I-1)
      [F:PMP]DUDLIG  = 1
      [F:PMP]AMTIPTLED = [M:HAEW]AMTLED(I-1)
      [F:PMP]AMTIPTCUR = [M:HAEW]CDT(I-1)+[M:HAEW]DEB(I-1)
      [F:PMP]CUR = [M:HAE1]CUR
      [F:PMP]UIDUSR = adxuid(2)
      Write [PMP]
      If fstat
       GOK=0 : Call FSTA("PMP") From GLOCK : Break 2
      Endif
     Endif
     I += 1
    Wend
   Endif
  Endif
 Endif
Next
If OPENTB1 : Close Local File [TB1] : Endif
Return

$LECCOL
Read [DAE5]DAE2 = [F:PYD]DUDNUM
If !fstat
 Filter [DAE7] Where TYP=[F:DAE5]TYP & NUM=[F:DAE5]NUM & LEDTYP=[M:HAEW]LEDTYP(I-1) & IDTLIN=[F:DAE5]IDTLIN
 Read [DAE7] First
 If !fstat
  COLFAC = [F:DAE7]SAC
 Endif
 Filter [DAE7]
Else
 Read [DAT5]DAT1 = [F:PYD]DUDNUM
 If !fstat
  Filter [DAT7] Where TYP=[F:DAT5]TYP & NUM=[F:DAT5]NUM & LEDTYP=[M:HAEW]LEDTYP(I-1) & IDTLIN=[F:DAT5]IDTLIN
  Read [DAT7] First
  If !fstat
   COLFAC = [F:DAT7]SAC
  Endif
  Filter [DAT7]
 Endif
Endif
Return


$MAJPAN
## MAJ de la table PAYACCNUM pour le lien entre les rčglements et les écritures comptables
## On met ŕ jour la table PAYACCNUM juste pour les écritures du référentiel général principal ;
## c'est le champ IDTLIN des écritures comptables qui permettra de trouvera correspondance
## d'une écriture sur un autre type de référentiel
Local Integer ETAP      : # Etape de comptabilisation = fonction qui génčre la pičce comptable
Local Integer SCHEMA    : # Schéma comptable appliqué (=3 pour la premičre comptabilisation)
Local Integer TROUVE, I : # Variables diverses
Local Char    PANGRP(50), PANRENCOD(50)
Local Char    PLAN(GLONCOA)
Local Char    CHAINE(100), OLDCHAINE(100)
Local Integer PANACCNUM, IMAINREF
Call LECPLAN([M]CPY,GTYPGEN,PLAN) From CPTDIV
IMAINREF = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))


Local Char CRITSPE1(250)
Local Char CRITSPE2(250)
CRITSPE1 = '[M:HAEW]FCYLIN(W-1)<>[F:PYH3]FCY'
CRITSPE2 = '[M:HAEW]FCYLIN(W+W_STR-1)=[F:PYH3]FCY'
GPOINT = "CRITUPDPAN" : Gosub ENTREE From EXEFNC

Sorta [M:HAEW]NB [M:HAEW]NB Order By ([M:HAEW]LEDTYP(indice)), [M:HAEW]CRITGRPIMP(indice), [M:HAEW]LIGPCEAUTO(indice)

For I=0 To [M:HAEW]NB-1
 CHAINE    = num$([M:HAEW]LEDTYP(I))+"/"+[M:HAEW]CRITGRPIMP(I)
 If I>0
  OLDCHAINE = num$([M:HAEW]LEDTYP(I-1))+"/"+[M:HAEW]CRITGRPIMP(I-1)
#  CHAINE    = num$([M:HAEW]LEDTYP(I))+"/"+[M:HAEW]CRITGRPIMP(I) #F56500/2+F56501 : déplacement
 Endif
 If [M:HAEW]LEDTYP(I)=GTYPGEN & !find([M:HAEW]CRITGRPIMP(I),"1=1","") & (OLDCHAINE<>CHAINE)
  Raz [F:PAN]
  [F:PAN]TYPNUM = 3
  [F:PAN]NUM    = [M:HAEW]CRITGRPIMP(I) : # Contient no de rčglement

  ## Recherche du schéma de comptabilisation pour MAJ le champ STA du fichier PAYACCNUM
  Read [PYH3]PYH0 = [M:HAEW]CRITGRPIMP(I)
  If !fstat
   ETAP = [M:DIA]ACCSTA-1 : TROUVE = 0
   While !TROUVE & ETAP>0
    If [F:PYH3]ACCNUMTRE(ETAP-1)<>0
     TROUVE = 1
    Else
     ETAP -= 1
    Endif
   Wend
   If TROUVE = 0 : # C'est la premičre comptabilisation...
    SCHEMA = 3
   Else
    SCHEMA = [M:DIA]ACCSTA
   Endif
  Endif
  ## Fin recherche schéma de  comptabilisation

  [F:PAN]ACCSTA = [M:DIA]ACCSTA
  [F:PAN]STA    = SCHEMA

  If [F:GAU]TYPVCR = 7 & find([F:PAN]STA,8,9)
   [F:PAN]TYPVCR = num$([F:PAN]STA) : # Comme en 130...
  Else
   Case [F:GAU]TYPVCR
    When 1 : # Compta principale
     [F:PAN]TYPVCR = "A"
    When 2 : # Pičce Cpt->Tiers
     [F:PAN]TYPVCR = "A1"
    When 3 : # Pičce Bq->Cpt
     [F:PAN]TYPVCR = "A2"
    When 4 : # OD Devise Trésorerie
     [F:PAN]TYPVCR = "B"
    When 5 : # OD Devise
     [F:PAN]TYPVCR = "C"
    When 6 : # OD Tiers
     [F:PAN]TYPVCR = "D"
    When 7 : # Transfert de compte
     [F:PAN]TYPVCR = "T"
    When 8 : # Effets ŕ l'escompte
     [F:PAN]TYPVCR = "G"
     If [M:DIA]ACCSTA = 9 : [F:PAN]STA = 10 : Endif
    #102289 RICAR 2014/11/06 - Angola tax stamp - BEGIN
    When 10 : # Tax stamp
     [F:PAN]TYPVCR = "S"
    #102289 RICAR 2014/11/06 - Angola tax stamp - END
   Endcase
  Endif

#102289 RICAR 2014/11/06 - Angola tax stamp - BEGIN
  ## <Begin> TAX STAMP
  #If find([F:PAN]TYPVCR,"C","D","E","G")
  If find([F:PAN]TYPVCR,"C","D","E","G","S")
  ## <End> TAX STAMP
#102289 RICAR 2014/11/06 - Angola tax stamp - END
   [F:PAN]CPTBAN = 0
  Elsif find([F:PAN]TYPVCR,"B","8","9")
   [F:PAN]CPTBAN = 2
  Elsif [F:PAN]TYPVCR = "A"
   W = find(GLIGTRES2,[M:HAEW]CODAUTACE(0..[M:HAEW]NB-1))
   If W
    [F:PAN]ACCNUM = [M:HAEW]ACCNUM(W-1)
    Read [GAC3]GAC0 = PLAN;evalue("[M:HAEW]ACC"+"("+num$(W-1)+")")
    If !fstat & [F:GAC3]CUR<>"" & [F:PYH3]CUR<>[F:GAC3]CUR
     [F:PAN]CPTBAN = 1
    Else
     [F:PAN]CPTBAN = 2
    Endif
   Else
    Read [GAC3]GAC0 = PLAN;[F:BAN]BANACC
    Call LEC_BAN([F:PYH3]BAN) From CPTLEC
    If !fstat & [F:PYH3]CUR<>[F:BAN]CUR & [F:GAC3]CUR<>""
     [F:PAN]CPTBAN = 1
    Else
     [F:PAN]CPTBAN = 2
    Endif
   Endif
  Elsif [F:PAN]TYPVCR = "A2" : # Pičce séparée destination Bq->Cpt
   Call LEC_BAN([F:PYH3]BAN) From CPTLEC
   # NB : [M:HAE0]CUR correspond ŕ la devise d'imputation de destination de type Bq->Cpt
   If [M:HAE1]CUR<>[F:BAN]CUR : # On a une pičce OD tréso...
    [F:PAN]CPTBAN = 1
   Else
    [F:PAN]CPTBAN = 2
   Endif

  Endif

  If [F:PAN]CPTBAN = 2
   W = find(GLIGTRES2,[M:HAEW]CODAUTACE(0..[M:HAEW]NB-1))
   If W
    [F:PAN]ACCNUM = [M:HAEW]ACCNUM(W-1)
    If [F:PAN]ACCSTA=9 & GCAS<>1 & evalue(CRITSPE1)
     W_STR = 0
     While W<>0
      W_STR += W
      W = find(GLIGTRES2,[M:HAEW]CODAUTACE(W_STR..[M:HAEW]NB-1))
      If W<>0 & evalue(CRITSPE2)
       [F:PAN]ACCNUM = [M:HAEW]ACCNUM(W+W_STR-1)
       Break
      Endif
     Wend
    Endif
   Endif
  Elsif [F:PAN]CPTBAN = 1
   [F:PAN]ACCNUM = [M:HAEW]ACCNUM(I)
  Else
   [F:PAN]ACCNUM = [M:HAEW]ACCNUM(I)
  Endif

  ## Sert pour la création de l'enreg TYPNUM=1
  If [F:PYH2]FRMNUM<>""
   [L]PANACCNUM = [F:PAN]ACCNUM
   If GCAS=1 & find([F:PAN]TYPVCR,"A","T","8","9") : # Remise en banque d'un bordereau
    [L]PANGRP = "R"+[M:HAEW]CRITGRPIMP(I) : # Comme en 130, si regroup par rčglement , on met dans GRP "R"+N° rčglement
   Elsif GCAS=3
    [L]PANGRP = "D"+[F:PYH2]DUDDAT : # Si regroup par date d'échéance, on met "D"+Date échéance du rčglement
   Elsif GCAS=2
    [L]PANGRP = "B"+[F:PYH2]FRMNUM
   Else
    [L]PANGRP = ""
   Endif

   If GCAS<>2 & !find([F:PAN]TYPVCR,"8","9")
    [L]PANRENCOD = "R"+[M:HAEW]CRITGRPIMP(I)
   Endif
  Endif
  ## <Fin PP>

  If [F:PYH2]FRMNUM<>"" & GCAS = 2 & [F:PAN]TYPVCR = "A" : # Remise en banque d'un bordereau
   [F:PAN]GRP = "B"+[F:PYH2]FRMNUM
  Elsif [F:PYH2]FRMNUM<>"" & GCAS = 1 & [F:PAN]TYPVCR = "A"
   [F:PAN]GRP = "R"+[M:HAEW]CRITGRPIMP(I)
  Elsif GCAS = 3
   [F:PAN]GRP = "D"+[F:PYH2]DUDDAT
  Else
   [F:PAN]GRP = ""
  Endif

  [F:PAN]RENCOD = ""
  [F:PAN]RVSACCNUM = 0

  ## le champ ACETYP du fichier PAYACCNUM permet de savoir le type de génération de pičce. Si GCAS=2, on aura
  ## la gestion du fichier PAYACCNUMD pour les rčglements traités. Dans le programme d'annulation comptable,
  ## si le rčglement pour lequel on cherche ŕ faire l'annulation comptable a le champ ACETYP égal ŕ 2 dans PAYACCNUM,
  ## on extournera la pičce en s'appuyant sur le fichier PAYACCNUMD
  [F:PAN]ACETYP = GCAS
  Write [PAN]
  If fstat
   GOK=0 : Call FSTA("PAN") From GLOCK : Break
  Endif

  ## Espagne : Création d'un enregistrement supplémentaire dans PAYACCNUM permettant de stocker l'accum correspondant
  ## au compte de dettes pour effets mouvementés lors de la remise en banque (comme en V130)
  # Issue X3-103268
  #If func AFNC.PARAM("SPADESVAL",[M]CPY)="2" & [M:DIA]ACCSTA=9 & [F:TPY]STA3=2 & [F:TPY]UPDBIL>1 & [F:TPY]AUTACE10<>"" & ([F:PYH2]FRMTYP=2 | [F:PYH2]FRMTYP=4) & [F:PYH2]BPRTYP=1
  If func AFNC.ACTIV("KSP") & func AFNC.PARAM("SPADESVAL",[M]CPY)="2" &
&    [M:DIA]ACCSTA=9 & [F:TPY]STA3=2 & [F:TPY]UPDBIL>1 & [F:TPY]AUTACE10<>"" & ([F:PYH2]FRMTYP=2 | [F:PYH2]FRMTYP=4) & [F:PYH2]BPRTYP=1
   Raz [F:PAN2]
   [F:PAN2] = [F:PAN]
   [F:PAN2]STA = -10
   W = find(GLIGTRES3,[M:HAEW]CODAUTACE(0..[M:HAEW]NB-1))
   If W
    [F:PAN2]ACCNUM = [M:HAEW]ACCNUM(W-1)
   Endif
   Write [PAN2]
   If fstat
    GOK=0 : Call FSTA("PAN2") From GLOCK : Break
   Endif
  Endif
 Endif
Next

If GOK<1 : STAT = 20 : Return : Endif
If [F:PYH2]FRMNUM<>""
 Gosub ECRPANFRM
 If GOK<1 : STAT = 20 : Return : Endif
Endif
Return


$ECRPANFRM
Raz [F:PAN]
#[F:PAN]TYPNUM = 1
[F:PAN]TYPNUM = [F:PYH2]FRMFLG  # Bug 22262
[F:PAN]NUM    = [F:PYH2]FRMNUM
[F:PAN]STA    = SCHEMA
[F:PAN]ACCSTA = [M:DIA]ACCSTA

If [F:GAU]TYPVCR = 7 & find([F:PAN]STA,8,9) : # TYPVCR=7 = Transfert de compte (T dans PAYACCNUM)
 [F:PAN]TYPVCR = num$([F:PAN]STA)
Else
 Case [F:GAU]TYPVCR
  When 1 : # Compta principale
   [F:PAN]TYPVCR = "A"
  When 2 : # Pičce Cpt->Tiers
   [F:PAN]TYPVCR = "A1"
  When 3 : # Pičce Bq->Cpt
   [F:PAN]TYPVCR = "A2"
  When 4 : # OD Devise Trésorerie
   [F:PAN]TYPVCR = "B"
  When 5 : # OD Devise
   [F:PAN]TYPVCR = "C"
  When 6 : # OD Tiers
   [F:PAN]TYPVCR = "D"
  When 7 : # Transfert de compte
   [F:PAN]TYPVCR = "T"
  ## <Begin> TAX STAMP
  When 10 : # Tax stamp
   [F:PAN]TYPVCR = "S" #102289 RICAR 2014/11/06 - Angola tax stamp
  ## <End> TAX STAMP
 Endcase
Endif

#102289 RICAR 2014/11/06 - Angola tax stamp - BEGIN
## <Begin> TAX STAMP
#If find([F:PAN]TYPVCR,"C","D","E")
If find([F:PAN]TYPVCR,"C","D","E","S")
## <End> TAX STAMP
#102289 RICAR 2014/11/06 - Angola tax stamp - END
 [F:PAN]CPTBAN = 0
Elsif find([F:PAN]TYPVCR,"A","8","9")
 [F:PAN]CPTBAN = 2
Endif

#If GCAS=1 & find([F:PAN]TYPVCR,"A","T","8","9") : # Remise en banque d'un bordereau
# [F:PAN]GRP = "R"+[M:HAEW]CRITGRPIMP(I) : # Comme en 130, si regroup par rčglement , on met dans GRP "R"+N° rčglement
#Elsif GCAS=3
# [F:PAN]GRP = "D"+[F:PYH2]DUDDAT : # Si regroup par date d'échéance, on met "D"+Date échéance du rčglement
#Else
# [F:PAN]GRP = ""
#Endif
#If !find([F:PAN]TYPVCR,"8","9")
# [F:PAN]RENCOD = "R"+[M:HAEW]CRITGRPIMP(I)
#Endif

[F:PAN]ACCNUM = [L]PANACCNUM
[F:PAN]GRP    = [L]PANGRP
[F:PAN]RENCOD = [L]PANRENCOD

[F:PAN]RVSACCNUM = 0
[F:PAN]ACETYP = GCAS
Write [PAN]
If fstat
 GOK=0 : Call FSTA("PAN") From GLOCK : Return
Endif
If !GOK : Return : Endif
Return


$MAJTAB
## 1°) MAJ table PAYACCNUMD
## 2°) MAJ table PAYORDER
Local Integer OKLED, OKTMP
Local Decimal COEFF
For [PTP]PTP1(5) Where CODACE = [F:GAU]COD & VCRNUM = NBVAL
 # Parcours sur index PTP1 car un męme rčglement peut générer deux lignes sur un męme compte (qui peuvent ętre
 # regroupées...) générées par deux lignes de pičces auto différentes
 Filter [DAE4] Where TYP = [M:HAE0]TYP & NUM = [M:HAE0]NUM & LEDTYP = GTYPGEN & OLDLIG = [F:PTP]LIG
 Read [DAE4]DAT0 First
 Filter [DAE4]
 If !fstat
  If [F:PTP]TYPREC = "PMD"
   ## 1°) MAJ table PAYACCNUMD
   ## Le but de la tenue du fichier PAYACCNUMD est de conserver un historique des lignes d'écritures qui
   ## sont regroupées alors qu'elles concernent des rčglements différents (possible dans le cas d'une validation
   ## groupée par bordereau (GCAS<>1)). On a besoin d'un tel fichier pour pouvoir faire une annulation comptable
   ## d'un rčglement porté sur un bordereau et comptabilisé sur une pičce qui concerne d'autres rčglements
   [F:PMD]NUM    = [F:PTP]NUM
   [F:PMD]ACCSTA = [M:DIA]ACCSTA
   [F:PMD]TYP    = [M:HAE0]TYP
   [F:PMD]VCRNUM = [M:HAE0]NUM
   [F:PMD]ACCNUM = [F:DAE4]ACCNUM
   Raz [F:PMD]AMTCUR
   For [PTP]PTP1
    [F:PMD]AMTCUR += [F:PTP]AMTCUR*[F:PTP]SNS
   Next
   If [F:PMD]AMTCUR<0 : [F:PMD]SNS = -1 : Else : [F:PMD]SNS = +1 : Endif
   [F:PMD]AMTCUR = abs([F:PMD]AMTCUR)

   Write [PMD]
   If fstat
    GOK=0 : Call FSTA("PMD") From GLOCK : Break
   Endif
  Elsif [F:PTP]TYPREC = "PYO"
   ## 2°) MAJ table PAYORDER (ordres de paiements acomptes sur commandes achats et ventes)
   For [PTP]PTP1
    Read [PYO]PYO0 = [F:PTP]DUDNUM ; [F:PTP]DUDLIG ; [F:DAE4]ACCNUM
    If fstat
     Raz [F:PYO]
     [F:PYO]DUDNUM    = [F:PTP]DUDNUM
     [F:PYO]DUDLIG    = [F:PTP]DUDLIG
     [F:PYO]PAYNUM    = [F:DAE4]ACCNUM
     [F:PYO]DUDPAYAMT = [F:PTP]AMTCUR
     [F:PYO]INVNUM    = 0
     [F:PYO]PAYVCR    = [F:PTP]NUM
     Write [PYO]
     If fstat
      GOK=0 : Call FSTA("PYO") From GLOCK : Break 2
     Endif
    Elsif !fstat
     # Męme échéance imputée sur 2 lignes de rčglement comptabilisées dans la męme écriture
     [F:PYO]DUDPAYAMT += [F:PTP]AMTCUR
     Rewrite [PYO]
     If fstat
      GOK=0 : Call FSTA("PYO") From GLOCK : Break 2
     Endif
    Endif
    # Pour les acomptes (*SO et *PO), il faut MAJ PAY* et TMP* de l'échéance maintenant...
    Read [DUD2]DUD1 = [F:PTP]DUDNUM ; [F:PTP]DUDLIG
    If !fstat
     Local Decimal AMTPAYC, AMTPAYL
     AMTPAYC = 0 : AMTPAYL = 0
     [F:DUD2]PAYCUR += [F:PTP]AMTCUR
     AMTPAYC = [F:PTP]AMTCUR
     OKLED = 0 : OKTMP = 0
     If [F:DUD2]PAYCUR = [F:DUD2]AMTCUR
      [F:DUD2]PAYLOC = [F:DUD2]AMTLOC
      [F:DUD2]TMPCUR = 0
      [F:DUD2]TMPLOC = 0
      OKLED = 1 : OKTMP = 1
     Elsif [F:DUD2]PAYCUR = [F:DUD2]TMPCUR
      [F:DUD2]PAYLOC = [F:DUD2]TMPLOC
      [F:DUD2]TMPCUR = 0
      [F:DUD2]TMPLOC = 0
      OKLED = 1 : OKTMP = 1
     Endif
     If !OKLED & [F:PTP]CUR = [F:PTP]CURCPY
      [F:DUD2]PAYLOC = [F:DUD2]PAYCUR
      AMTPAYL = AMTPAYC
      OKLED = 1
     Endif
     If !OKLED
      Read [DAE4]DAT1 = [F:DAE4]ACCNUM
      If [F:DAE4]AMTCUR <> [F:PTP]AMTCUR : # Il y a pu avoir regroupement de lignes...
       Call LEC_TCU([F:DAE4]CUR) From CPTLEC
       COEFF = arr([F:PTP]AMTCUR/[F:DAE4]AMTCUR,[F:TCU]CURRND)
      Else
       COEFF = 1
      Endif
      If !OKLED
       [F:DUD2]PAYLOC += [F:DAE4]AMTLED*COEFF
      Endif
     Endif
     If !OKTMP
      [F:DUD2]TMPCUR -= AMTPAYC
      [F:DUD2]TMPLOC -= AMTPAYL
     Endif
     Call SLDECH("DUD")From MODECHE
     If [F:DUD2]PAYDAT=[0/0/0]
      [F:DUD2]PAYDAT = [M:HAE0]ACCDAT
     Else
      [F:DUD2]PAYDAT = min([F:DUD2]PAYDAT,[M:HAE0]ACCDAT)
     Endif
     Rewrite [DUD2]
     If fstat
      GOK=0 : Call FSTA("DUD2") From GLOCK : Break 2
     Endif
    Endif
   Next
  Endif
 Endif
Next
If GOK<1 : STAT = 20 : Return : Endif
Return


$LIGNE
Call LEC_GAC(CPTGEN,PLGEN) From CPTLEC
If [F:GAC]SAC = 2
 [M:HAE2]REFINTLIN(NOL) = "PYH"-[L]CRITIMP
Endif
If find(GCAS,1) : Return : Endif
If [F:TB0]NUM = [F:PTP]NUM & GLIGCODACE = [F:GAD]LINNUM
 ## <Bug 35546> On écrit aussi dans [PTP] pour l'enregistrement [GAU]...
 #NUM_ORDRE = [F:PTP]NUMORD+1
 GNUMORD = GNUMORD+1
Else
 GNUMORD = 1
Endif
Raz [F:PTP]
## NB : les lignes d'écritures seront par la suite triées par ligne de pičce auto (LIGPCEAUTO). Le no de ligne contenue
## dans [M]LIG va donc changer par la suite. Dans [M]OLDLIG, on aura le no de ligne avant ce tri (besoin technique
## pour la gestion du fichier PAYACCNUMD pour la validation groupée de X rčglements)
[M]OLDLIG(NOL)   = NOL+1
[F:PTP]NUM       = [F:TB0]NUM
[F:PTP]CODACE    = [F:GAU]COD
[F:PTP]LIGCODACE = [F:GAD]LINNUM
GLIGCODACE       = [F:PTP]LIGCODACE
[F:PTP]VCRNUM    = NBVAL     : # On gčre ce champ pour les OD-Devises (X pičces peuvent ętre générées ŕ l'appel d'un VALPCE)
[F:PTP]LIG       = NOL+1
[F:PTP]NUMORD    = GNUMORD : # 1 rčglement qui rčgle X échéances...
[F:PTP]SNS       = [L]SENS
[F:PTP]AMTCUR    = [L]MONTLIG
[F:PTP]TYPREC    = "PMD"
[F:PTP]UIDUSR    = adxuid(2)
Write [PTP]
If fstat
 GOK=0 : Call FSTA("PTP") From GLOCK
Endif
If GOK<1 : STAT = 20 : Return : Endif
Return


$TR_ANNUL
GOK=1
Trbegin [PTP]
 Delete [PTP] Where UIDUSR=adxuid(2)
 If fstat=1
  GLOCK = "PAYTMP" : Goto ROLL_TR_ANNUL
 Elsif fstat>5
  Call RSTA("PTP","") From GLOCK : Goto AB_TR_ANNUL
 Endif
Commit
Trbegin [PTP]
 Delete [PTP] Where UIDUSR=0
 If fstat=1
  GLOCK = "PAYTMP" : Goto ROLL_TR_ANNUL
 Elsif fstat>5
  Call RSTA("PTP","") From GLOCK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif
Return


#######################################################################
Subprog ADDCRIT(CRITERE,SUBCRIT)
Variable Char CRITERE()(0..)
Value    Char SUBCRIT
If CRITERE(0)=""
 CRITERE(0) = SUBCRIT
Else
 If len(CRITERE(0))+len(SUBCRIT)<240
  CRITERE(0) -= "&"-SUBCRIT
 Else
  If CRITERE(1)=""
   CRITERE(1) = SUBCRIT
  Else
   CRITERE(1) -= "&"-SUBCRIT
  Endif
 Endif
Endif
End


Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
Local Integer K
Repeat
 K = instr(1,CHAINE,AB1)
 If K
  CHAINE = left$(CHAINE,K-1)+AB2+right$(CHAINE,K-1+len(AB1)+1)
 Endif
Until K=0
End


#######################################################################
# X3-166809 2019-12-20 Bader begin functions to return reconciliation mark and date

# Get reconciliation date (called from bank account line of payment validation automatic journals, PRINC...):
# if the payment is linked to a BSI transaction and a RELBANK record has been created for the transaction,
# we return the actual date, an empty date otherwise
# [F:TB0] holds the payment header
Funprog GET_RCL_DAT()
Local Date RCLDAT
Local Integer HDL_MRK : HDL_MRK = [V]CST_ANO    # checked in $CHECK_BSI
RCLDAT = [0/0/0]
Gosub CHECK_BSI       # check if payment comes from BSI and a RELBANK record exists. Returns correct value for RCLDAT
End RCLDAT

# Get reconciliation mark (called from bank account line of payment validation automatic journals, PRINC...):
# if the payment is linked to a BSI transaction and a RELBANK record has been created for the transaction,
# we return a reconciliation mark, an empty string otherwise
# [F:TB0] holds the payment header
Funprog GET_RCL_MRK()
Local Char RCLMRK(5)
Local Integer HDL_MRK : HDL_MRK = [V]CST_AYES
RCLMRK = ""
Gosub CHECK_BSI       # check if payment comes from BSI and a RELBANK record exists. Returns correct value for RCLMRK
End [L]RCLMRK
# X3-166809 2019-12-20 Bader end


# X3-166812 2020-01-20 Bader begin
# Check if payment is linked to a BSI transaction. If yes, read related RELBANK entry. Only if RELBANK record exists,
# two different behaviors depending on where the code is called from (guided by the value of [L]HDL_MRK):
# [L]HDL_MRK = [V]CST_AYES: assign reconciliation mark from RELBANK record to [L]RCLMRK
# [L]HDL_MRK = [V]CST_ANO:  assign date$ to [L]RCLDAT
# [l]HDL_MRK must be declared and initialized in the calling Subprog
$CHECK_BSI
If dim([F:TB0]BSITRS) > 0 and [F:TB0]BSITRS <> ""
  Local Integer I, LIN
  Local Char STM(30)
  Local File RELBANK [RBK]
  I = instr(1,[F:TB0]BSITRS,"/")    # search for "/" in BSITRS of payment
  If I > 0
      [L]STM = left$([F:TB0]BSITRS,I-1)        # extract statement code
      [L]LIN = val(right$([F:TB0]BSITRS,I+1))  # extract transaction number = line
      Filter [F:RBK] Where BSISTM = [L]STM and BSILIN = [L]LIN and CHK <> "BSI"   # read corresponding RELBANK record
# X3-215462 2020-09-22 Bader begin the record with the values of the manual entries is always the last one not the first
#      Read [F:RBK] First
      Read [F:RBK] Last
# X3-215462 2020-09-22 Bader end
      If !fstat
          If [L]HDL_MRK = [V]CST_AYES          # we come from GET_RCL_MRK
            [L]RCLMRK = [F:RBK]CHK             # assig reconciliation mark from RELBANK record to variable RCLMRK
          Else                                 # we come from GET_RCL_DAT
            [L]RCLDAT = date$                  # assign actual date to variable RCLDAT
          Endif
      Endif
      Filter [F:RBK]
  Endif
Endif
Return
# X3-166812 2020-01-20 Bader end


# X3-176506 - 2020-01-10 by Bader begin function to return BSI transaction
# Get BSI transaction (called from bank account line of payment validation automatic journals, PRINC...):
# if the payment is linked to a BSI transaction, we return a BSI transaction, an empty string otherwise
# [F:TB0] holds the payment header
Funprog GET_BSITRS()
Local Char BSITRS(30)
[L]BSITRS = ""
If dim([F:TB0]BSITRS) > 0 and [F:TB0]BSITRS <> ""
  [L]BSITRS = [F:TB0]BSITRS
Endif
End [L]BSITRS
# X3-176506 - 2020-01-10 by Bader end
