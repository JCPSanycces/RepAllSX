#<AdxTL>@(#)3.0.0.0 $Revision$
Call OBJET("BIC",GBIDC1,GBIDC2) From GOBJET
End


#########################################
Subprog CONTDSP(VALEUR,FCY,DAT)
Variable Char    VALEUR
Value    Char    FCY
Value    Date    DAT
If VALEUR = "" : End : Endif
Call LECTURE("DSP",VALEUR,"1") From CONTOBJ
If fstat
 # Répartition inexistante
 GMESSAGE = VALEUR-mess(37,106,1)
 mkstat = 2 : End
Endif
Call VERIF([F:DSP]FCY,[L]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
If func FINMIS_SYRA.CTL_VLYDAT(GACTX, [L]DAT, [F:DSP]VLYSTR, [F:DSP]VLYEND, GMESSAGE)<>[V]CST_AOK
 GMESSAGE = VALEUR-GMESSAGE : mkstat = 2 : End
Endif
If func FINMIS_SYRA.CTL_EXE(GACTX, [F:DSP]ACS, GMESSAGE)<>[V]CST_AOK
 GMESSAGE = VALEUR-GMESSAGE : End
Endif
End

$ERR_SCHEMA
 # Ligne....Erreur en évaluation de la formule....
 Call ERREUR(SCHEMA-mess(3,61,1)-num$([F:GDC]LINNUM)-mess(65,106,1)-[F:GDC]LIGDES) From GESECRAN
 Resume
Return

$SCHEMA
Local Integer AXE , NOL , DEB , NOMBRE , I , OKCPT, N
Local Char    COMPTE(GLONGAC) , SECTION(GLONCCE) , SITE(GLONFCY)
Local Decimal COEFF(1..dim([M]ACC1))
Local Decimal TOTAL , MONTANT , SOMME
Local Char MSG(250)

DEB = [M]NBLIG
NOMBRE = 0

If clalev([F:GDC])=0 : Local File GDIAACCD [GDC] : Endif

Read [GDA]GDA0=SCHEMA

# récupération du code plan du réf géné principal de la société associée à la facture en cours de création
Call LECTURE("FCY",[M:BIC0]FCY, "") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY, "") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM, "") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED([F:GCM]GENLEDTYP-1), "") From CONTOBJ

# message d'erreur dès qu'on cherche à charger un schéma de comptes qui ne contient pas au minimum
# le code plan du réf géné principal de la société associée à la facture en cours de création
If find([F:LED]COA, [F:GDA]COA)=0
 # Schéma de comptes par défaut ZZZ incorrect - Ne contient pas le plan XXX
 MSG = mess(79,119,1)
 Call DYNAMIC(MSG, "$1$", [F:GDA]DIA) From TEXTE
 Call DYNAMIC(MSG, "$2$", [F:LED]COA) From TEXTE
 Call ERREUR(MSG) From GESECRAN
 Return # on n'applique pas le schéma
Endif

#--- Contrôle de validité de dates.
If func FINMIS_SYRA.CTL_VLYDAT(GACTX, [M]ACCDAT, [F:GDA]VLYSTR, [F:GDA]VLYEND, GMESSAGE)<>[V]CST_AOK
 GMESSAGE = SCHEMA-GMESSAGE : mkstat = 2 : Return
Endif

For [GDC]GDC0 Where DIA=SCHEMA
 If [M]NBLIG>=dim([M]ACC1) : Break : Endif
 NOL = [M]NBLIG

 # Compte de TVA ou TVA/CEE
 # si l'un des comptes du plan du réf général principal est avec FLGVAT=3 ou 4, alors il ne faut pas charger la ligne.
 COMPTE = [F:GDC]ACC([F:GCM]GENLEDTYP-1)
 Call LECTURE("GAC",COMPTE,[F:COA]COA) From CONTOBJ
 If [F:GAC]FLGVAT=3 or [F:GAC]FLGVAT=4
  OKCPT = 0
 Else
  OKCPT = 1
  NOMBRE += 1
  COEFF(NOMBRE) = [F:GDC]COE
 Endif

 For N=0 To dim([F:GDC]ACC)-1
  If evalue("dim([M:BIC3]ACC"+num$(N+1)+")")<0 : Break : Endif
  If [F:GDC]ACC(N)<>""
   COMPTE = [F:GDC]ACC(N)

   If NOL=0 : SITE = [M]FCY : Else : SITE = [M]FCYLIN(NOL-1) : Endif

   Call LECTURE("GAC",COMPTE,[F:GDA]COA(N)) From CONTOBJ

   [M]FCYLIN(NOL) = SITE

   # bug 55710 - Problème C
   If find([F:GDA]COA(N), GPLAN(1..10))>0
    C = find([F:GDA]COA(N), GPLAN(1..10))
    Assign "[M]ACC"+num$(C)+"("+num$(NOL)+")" With COMPTE

    # la zone SAC doit être alimentée avec le code d'appel du compte collectif du plan du référentiel général principal
    # on appelle l'action de contrôle du champ pour faire l'initialisation de SAC
    If C=[F:GCM]GENLEDTYP
     If [F:GAC]SAC=2 : [M]SAC(NOL)=[F:GAC]ACCSHO : Endif
    Endif
   Endif

   # bug 55710 - Problème C
   If [M]UOM(NOL)=""
    [M]UOM(NOL) = [F:GAC]UOM
   Endif

# si le compte est de type collectif, on initialise le tiers avec celui saisi en entête
   If [F:GAC]SAC=2 & [F:GDC]BPR="" # compte collectif + BPR non renseigné dans le schéma de comptes
    [M]BPRLIN(NOL) = [M:BIC0]BPR
   Else
    [M]BPRLIN(NOL) = [F:GDC]BPR
   Endif

   If [F:GDC]DSP<>""
    [M]DSP(NOL) = [F:GDC]DSP
   Else
    For AXE=1 To GOPTCANA
     SECTION = [F:GDC]CCE(AXE-1)
     If dim([M]DSP(NOL))>0
      [M]DSP(NOL)=""
# V140 pour que le Affzo ne déclenche pas D_DSP(qui peut alimenter DSP) alors que CCE non vide
     Endif

# [M:BIC1]DIE pas encore initialisé à ce niveau donc pas exploitable
     I = find([F:GDA]DIE(AXE-1), GAXE)
     If I>0 : Assign "[M]CCE"+num$(I)+"(NOL)" With SECTION : Endif
    Next AXE
   Endif
  Endif
 Next

 If OKCPT
  If [F:GDC]VAT<>""
   [M]VAT(NOL) = [F:GDC]VAT
  Endif

  If [F:GDC]LIGDES<>""
   Onerrgo ERR_SCHEMA
   Assign "[M]DES(NOL)" With evalue([F:GDC]LIGDES)
   Onerrgo
  Endif
  GPOINT = "LOAD_GDALIN" : Gosub ENTREE From EXEFNC
  [M]NBLIG += 1
 Endif
Next

nolign =   [M]NBLIG+1

# Issue X3-32601
If dim(CURRND) < 0
  Local Decimal CURRND
Endif
# End Issue X3-32601

TOTAL = sum(COEFF(1..NOMBRE))
MONTANT = [M]AMTNOT-sum([M]AMTNOTLIN(0..[M]NBLIG-1))
SOMME = 0
If TOTAL<>0 & MONTANT<>0
 ASTATUS = func CDACUR_SYRA.GET_CURRND(GACTX, [M]CUR, CURRND, GMESSAGE)
 For I=1 To NOMBRE
  NOL = DEB+I-1
  nolign = NOL+1
  [M]AMTNOTLIN(NOL) = arr(MONTANT*(SOMME+COEFF(I))/TOTAL, CURRND)-arr(MONTANT*SOMME/TOTAL, CURRND)
  SOMME += COEFF(I)

  If [M]VAT(NOL)=""
   Call D_VAT([M]VAT(NOL)) From SUBBIC2
  Endif

  If [M]TAX1(NOL)<>""
   Call LEC_TVT_LEG(GCURLEG,[M]TAX1(NOL)) From CPTLEC
   Call RNDTVA([M]AMTNOTLIN(NOL), [F:TVT]VATRAT, CURRND, [M]AMTTAX1(NOL)) From SUBTVT
  Endif
  If [M]TAX2(NOL)<>""
   Call LEC_TVT_LEG(GCURLEG,[M]TAX2(NOL)) From CPTLEC
   Call RNDTVA([M]AMTNOTLIN(NOL), [F:TVT]VATRAT, CURRND, [M]AMTTAX2(NOL)) From SUBTVT
  Endif
  Gosub CALTVA From SUBBIC2
  [M]AMTATILIN(NOL) = [M]AMTNOTLIN(NOL)+[M]AMTTAX1(NOL)+[M]AMTTAX2(NOL)+[M]AMTVAT(NOL)
 Next I
Endif
Affzo [M:BIC3]20
Call APRES_NBLIG From SUBBIC2
If DEB<>[M]NBLIG : mkstat=4 : Endif
Return

