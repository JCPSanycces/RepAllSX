#<AdxTL>@(#)12.0.0.0 $Revision$
########################################################################
## Action modélisées
########################################################################
$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "FIN_TABLE" : Gosub FIN_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELSAC"    : Gosub S_SAC
 When "SELSHO"    : Gosub S_SHO
 When "SELACC"    : Gosub S_ACC
 When "SELSACBPR" : Gosub S_SACBPR
 When "SELSACCF"  : Gosub S_SACBPRCF : # Sélection collectif client/Fourn
 When "SELPCE"    : Gosub S_PCE
 When "SELBPRC"   : Gosub S_BPRC : # Sélection tiers client
 When "SELBPRF"   : Gosub S_BPRF : # Sélection tiers fournisseur
 When "SELBPR"    : Gosub S_BPR
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELEXE"    : Gosub S_EXE
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELPCE"
  If type([M]TYP)>10
   [M]TYP = [F:HAE]TYP : Affzo [M]TYP
  Endif
Endcase
Return

$S_SAC
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "TYP=3"
ORDRE   = "ACCSHO"
START   = "ACCSHO"
OBJET   = "GAC"
Return

$S_SHO
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = 'ACCSHO<>"" & COA=PARAM(1)'
START = "ACCSHO"
ORDRE = "ACCSHO"
OBJET = "GAC"
Return

$S_ACC
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ACC])=0 : Local File ACCES  [ACC]  : Endif
If clalev([F:ACS])=0 : Local File ACCCOD [ACS]  : Endif
If GUSRACS=2
 OBJET = "ACS"
 SUPP = ""
Else
 CRITERE = "USR=GUSER & MODIF=2"
 START = "CODACC"
 TIT(0) = mess(5,104,1) : # Choix code d'accčs
 NBCOL = 0
 NBCOL += 1 : COL(NBCOL) = "[F:ACC]USR"    : FICHE = "ACCES"  : Gosub TEXTE 
 NBCOL += 1 : COL(NBCOL) = "[F:ACC]CODACC" : FICHE = "ACCES"  : Gosub TEXTE 
 NBCOL += 1 : COL(NBCOL) = "[F:ACS]INTACC" : FICHE = "ACCCOD" : Gosub TEXTE 
 Link [ACC] With [ACS]ACS0 = CODACC As [ACC_]
 Default File [ACC_]
Endif
Return

$TEXTE
Read [ATZ]CODZONE = FICHE;right$(COL(NBCOL),instr(1,COL(NBCOL),"]")+1)
Call TEXTE([F:ATZ]NOCOURT,TIT(NBCOL)) From OBJDIV  
Return

$S_SACBPR
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "TYP=3 & AUZBPR(5)=2"
ORDRE   = "ACCSHO"
START   = "ACCSHO"
OBJET   = "GAC"
Return

$S_SACBPRCF
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "TYP=3"
If PARAM(1)="C"
 CRITERE -= "& AUZBPR(0)=2"
Elsif PARAM(1)="F"
 CRITERE -= "& AUZBPR(1)=2"
Endif
ORDRE   = "ACCSHO"
START   = "ACCSHO"
OBJET   = "GAC"
Return

$S_BPRC
PARAM(2) = "C"
Goto S_BPR

$S_BPRF
PARAM(2) = "F"
Goto S_BPR

$S_BPR
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET     [AOB]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
If clalev([F:ACT])=0  : Local File ACTION     [ACT]  : Endif
If clalev([F:BPR2])=0 : Local File BPARTNER   [BPR2] : Endif
If clalev([F:BPC2])=0 : Local File BPCUSTOMER [BPC2] : Endif
If clalev([F:BPS2])=0 : Local File BPSUPPLIER [BPS2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif

# PARAM(1) Site
# PARAM(2) Type de tiers

Local Char    SOC(GLONCPY)
Local Integer ISITE, MULT

Read[CPY]CPY0=PARAM(1)
If !fstat
 SOC   = [F:CPY]CPY
Else
 ISITE = find(PARAM(1),GSITE(1..GNBSITE)) 
 If ISITE>0 : SOC = GSOCSITE(ISITE) : Endif
Endif

If SOC=""
 OBJET = "BPR"
 SUPP = ""
Else
 Read [ACT]ACTION = TABLE
 If fstat=0
  Call TEXTE([F:ACT]INTITA,TIT(0)) From OBJDIV  
 Endif
 If TIT(0)=""
  TIT(0) = mess(18,100,1)-mess(31,105,1) : # Sélection Tiers
 Endif
 NBCOL  = 0
 NBCOL += 1 : COL(NBCOL) = "[F:BPR2]BPRNUM" : FICHE = "BPARTNER" : Gosub TEXTE
 NBCOL += 1 : COL(NBCOL) = "[F:BPR2]BPRNAM" : FICHE = "BPARTNER" : Gosub TEXTE
 NBCOL += 1 : COL(NBCOL) = "[F:BPR2]BPRSHO" : FICHE = "BPARTNER" : Gosub TEXTE
#AUREN - PU9
 ### 09/02/2011 ZAU : Ańadir columnas CIF y CIF europeo
 NBCOL += 1 : COL(NBCOL) = "[F:BPR2]CRN" : FICHE = "BPARTNER" : Gosub TEXTE
 NBCOL += 1 : COL(NBCOL) = "[F:BPR2]EECNUM" : FICHE = "BPARTNER" : Gosub TEXTE
#AUREN - PU9

 Read[ACV]CODACT="MUL"

# BY/GH le 15/09/2000
# Adonix génčre les liens "externes gauches" lors des link. Peu importe que le lien
# n'existe pas, la classe correspondante sera vide. Mais il ne faut pas transmettre
# ŕ Oracle de clause sur ces tables, car elles seront systématiquement fausses.
# D'oů la ruse de mettre des num$ qui empęchent la transmission ŕ Oracle

 If !fstat & [F:ACV]FLACT=2
  If clalev([F:BPE])=0  : Local File BPEXCEPT [BPE]  : Endif
  Case PARAM(2)
   When "C"
    Link [BPR2] With [BPE]BPE0=[F:BPR2]BPRNUM;SOC
&                  , [BPC2]BPC0=[F:BPR2]BPRNUM As [LIEN]
    CRITERE  = "(find([BPE]CPY,'') | ([BPE]CPY='"+SOC+"' & num$([BPE]ACEAUZ)='2'))"
    CRITERE += "& [BPC2]BPCSTA=2 & [BPC2]BPCTYP<>4 & [BPR2]BPCFLG=2"
   When "F"
    Link [BPR2] With [BPE]BPE0=[F:BPR2]BPRNUM;SOC
&                  , [BPS2]BPS0=[F:BPR2]BPRNUM As [LIEN] 
    CRITERE  = "(find([BPE]CPY,'') | ([BPE]CPY='"+SOC+"' & num$([BPE]ACEAUZ)='2'))"
    CRITERE += "& [BPS2]ENAFLG=2 & BPSFLG=2"
   When Default
    Link [BPR2] With [BPE]BPE0(1)=[F:BPR2]BPRNUM;SOC
&                  , [BPC2]BPC0=[F:BPR2]BPRNUM
&                  , [BPS2]BPS0=[F:BPR2]BPRNUM As [LIEN]
    CRITERE  = "(find([BPE]CPY,'') | ([BPE]CPY='"+SOC+"' & num$([BPE]ACEAUZ)='2'))"
    CRITERE += "& ((num$([BPC2]BPCSTA)='2' & num$([BPC2]BPCTYP)<>'4' & [BPR2]BPCFLG=2)"
    CRITERE += "| (num$([BPS2]ENAFLG)='2' & [BPR2]BPSFLG=2)"
    CRITERE += "| find(2,[BPR2]BPTFLG,[BPR2]FCTFLG,[BPR2]REPFLG,[BPR2]BPRACC))"
  Endcase
 Else
  Case PARAM(2)
   When "C"
    Link [BPR2] With [BPC2]BPC0=[F:BPR2]BPRNUM As [LIEN] 
    CRITERE  = "[BPC2]BPCTYP<>4 & [BPC2]BPCSTA=2 & [BPR2]BPCFLG=2"
   When "F"
    Link [BPR2] With [BPS2]BPS0=[F:BPR2]BPRNUM As [LIEN] 
    CRITERE  = "[BPS2]ENAFLG=2 & BPSFLG=2"
   When Default
    Link [BPR2] With [BPC2]BPC0=[F:BPR2]BPRNUM
&                  , [BPS2]BPS0=[F:BPR2]BPRNUM As [LIEN] 
    CRITERE  = "((num$([BPC2]BPCTYP)<>'4' & num$([BPC2]BPCSTA)='2' & [BPR2]BPCFLG=2)"
    CRITERE += "| (num$([BPS2]ENAFLG)='2' & [BPR2]BPSFLG=2)"
    CRITERE += "| find(2,[BPR2]BPTFLG,[BPR2]FCTFLG,[BPR2]REPFLG,[BPR2]BPRACC))"
  Endcase
 Endif
 Read [AOB]ABREV = "BPR" : # mb 8.3.2 bug 13336 Pour sélectionner ŕ partir de la valeur saisie
 If !fstat & [F:AOB]SELCAR<>0
  CRITOBJ = COL(1)+'>="'+left$(VALEUR,[F:AOB]SELCAR)+'"'
 Endif
 ORDRE = "[F:BPR2]BPRNUM"
 Default File [LIEN]
 DEFPAG = 1
Endif
Return

$S_PCE
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
Default File [HAE]
CRITERE = ""
If PARAM(1)<>""
 CRITERE = '[F:HAE]TYP="'+PARAM(1)+'"'
Endif
OBJET = "GAS"
Return

##################################################################################
$S_EXE
TIT = mess(23,101,1) : # Choix exercice
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Local Integer NB_EXE
If clalev([M:FIY1])=0
 Local Mask FIY1 [FIY1]
 NB_EXE = dim([M:FIY1]FIYNUM)
 Close Mask [FIY1]
Else
 NB_EXE = dim([M:FIY1]FIYNUM)
Endif
Local Char TEXTE(10)(1..NB_EXE,1..3)
NBTEX = 0 
For [FIY]FIY0 Where CPY=PARAM(1)
 NBTEX += 1 
 TEX  (NBTEX)  = num$([F:FIY]FIYNUM)
 TEXTE(NBTEX)  = format$("N:3#",[F:FIY]FIYNUM)
 TEXTE(NBTEX) += "     "+format$("D:"+GFMDAT4,[F:FIY]FIYSTR)
 TEXTE(NBTEX) += "     "+format$("D:"+GFMDAT4,[F:FIY]FIYEND)
Next 
Return
