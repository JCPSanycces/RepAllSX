$ACTION
Case ACTION
 When "INIT"
  ###########################################################################################
  ######AUREN.INICIO 22-10-2021, URL POR PAR¡METRO SPEBIS
   Local Char ZPARTRASFO(250) : ZPARTRASFO =func AFNC.PARAM("ZPARTRASFO","")

    Callui RETOUR = "" With  "UIAction="+chr$(1) + "OpenFile",
&"UILocalDir="+chr$(1) + "HTTPS",
&"UILocalFile=" +chr$(1) + ZPARTRASFO + nomap + "&usr=" + GUSER ,
&"UIAdxPubSubFile="+chr$(1)+"1"

  #####AUREN.FIN
  ###########################################################################################

Endcase
Return
