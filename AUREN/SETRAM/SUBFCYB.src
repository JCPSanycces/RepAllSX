Subprog AM_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
If [M:FCYP]DADFLG<>2
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
 If VALEUR<>""
  Read [FCY]FCY0=VALEUR
  If !fstat
    [M:FCYP]HRMTAXWAG=[F:FCY]HRMTAXWAG
    [M:FCYP]FLGAPP=[F:FCY]FLGAPP
    [M:FCYP]FLGFOR=[F:FCY]FLGFOR
    [M:FCYP]FLGPEC=[F:FCY]FLGPEC
