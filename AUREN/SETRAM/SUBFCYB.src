$AVANT_MOD
  # FGR 29/08/2014 : X3SUIVI95632
  If find("GESAIN", GNAVIG(1..GPILNAV-1)) <> 0 Then
    Read [BPR]BPR2(2)=2;[M:FCY0]FCY
    If fstat = 0 Then
      mkstat = 2
      GMESSAGE = mess(1148,196,1)
      Return
    Endif
  Endif
Return

