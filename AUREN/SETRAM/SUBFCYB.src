##########################################################
$CREDFC
Call CREDFC([M:FCY0]FCY) From TRTDFC
If GOK <1 : Return : Endif
Return

#################################################################################
$MAJBPR
# --------------------------------------------------------------------- #
#    Si le site est un tiers                                            #
#    --> Il faut que le tiers soit l'image du site                      #
#    --> Il faut réécrire les adresses les RIB et les contacts du tiers #
# --------------------------------------------------------------------- #
Read [BPR] BPR2(2)=2;[F:FCY]FCY
If fstat = 0
    #--------------------#
    # maj des adresses   #
    #--------------------#
    Default Mask [BPF]
    For I=0 To [M]NBADR-1
        [M]FLMOD(I)=1
    Next
    Call CREBPA(1,[F:BPR]BPRNUM) From TRTBPA
    If GOK < 1 : Return : Endif
    #--------------------#
    # maj des rib        #
    #--------------------#
    Default Mask [BIF]
    For I=0 To [M]NBRIB-1
        [M]FLMOD(I)=1
    Next
    Call CRERIB(1,[F:BPR]BPRNUM) From TRTBPA
    If GOK < 1 : Return : Endif
    #--------------------#
    # maj des contacts   #
    #--------------------#
    Default Mask [CNF]
    For I=0 To [M]NBCNT-1
        [M]FLMOD(I)=1
    Next
    Call CRECNT(1,[F:BPR]BPRNUM) From TRTBPA
    If GOK < 1 : Return : Endif
    #---------------------------------------------------------#
    # Site et tiers doivent avoir la męme adresse par défault #
    #---------------------------------------------------------#
    Readlock [BPR]BPR0 = [F:BPR]BPRNUM
    If fstat = 1
        GOK = -1 : GLOCK = "$BPARTNER"-[F:FCY]FCY : Return
    Endif
    [F:BPR]BPAADD = [F:FCY]BPAADD
    [F:BPR]UPDDAT = date$
    [F:BPR]UPDUSR = GUSER
    # Issue X3-138149 - 2019-05-02 by MUARN : export chrono
    [F:BPR]EXPNUM    = [C]EXPORT
    Rewrite [BPR]
    If fstat <> 0 GOK=0 : Call FSTA("BPR") From GLOCK : Endif
Endif

Filter [BPR]

Return

#################################################################################
$VERF_ANU
Local Char CRITERE1(150)
Local Char TIT, DES(GLONAX3)
#--------------------------------------------------------------------#
# probleme si suppression site et que ce site est lui meme financier #
# il faut verifier a la main ne pas laisser l objet le faire         #
#--------------------------------------------------------------------#
CRITERE1 = '([F:FCY2]FCY <> [M:FCY0]FCY and [F:FCY2]FINRSPFCY = [M:FCY0]FCY)'

If GMODU(2)=2
 Read [ACV]CODACT="DAS"
 If !fstat & [F:ACV]FLACT=2
  CRITERE1 += '| ([F:FCY2]FCY <> [M:FCY0]FCY and [F:FCY2]DADFCY = [M:FCY0]FCY)'
 Endif
Endif

Filter [FCY2] Where evalue(CRITERE1)

Look [FCY2] First
Filter [FCY2]

If fstat = 0
    #-- message :  on ne peut pas supprimer site utilisé par site xxx
    Call ERREUR (mess(238,199,1)) From GESECRAN
    OK = 0 : Return
Endif

#--------------------------------------------------------------------#
# Type de données CFY qui peut contenir un site                      #
#--------------------------------------------------------------------#
# Compte
If clalev([F:GAC])=0 :  Local File GACCOUNT [GAC]  : Endif
Call TITFNC("GESGAC",TIT) From CONTOBJ
Filter [GAC] Where FCY=[M:FCY0]FCY
Read [GAC] First
If !fstat
 Call LECTEXTRA([L]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
 GMESSAGE = mess(101,126,1)-[F:GAC]COA+"-"+[F:GAC]ACC-"("+[L]DES+")"-mess(198,133,1)-"GACCOUNT ("+TIT+")\"-mess(176,115,1)
 OK = 0
Endif
Filter [GAC]
If !OK : Return : Endif

# Journal
If GMODU(2)=2
 If clalev([F:JOU])=0 :  Local File GJOURNAL [JOU]  : Endif
 Call TITFNC("GESJOU",TIT) From CONTOBJ
 Filter [JOU] Where FCY=[M:FCY0]FCY
 Read [JOU] First
 If !fstat
  Call LECTEXTRA([L]DES,"GJOURNAL","DESTRA",[F:JOU]JOU,[F:JOU]LEG) From ATEXTRA
  # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
  GMESSAGE = mess(101,126,1)-[F:JOU]JOU-"("+[L]DES+")"-mess(198,133,1)-"GJOURNAL ("+TIT+")\"-mess(176,115,1)
  OK = 0
 Endif
 Filter [JOU]
 If !OK : Return : Endif
Endif

# Enveloppe
Read [ACV]CODACT="GDD"
If !fstat & [F:ACV]FLACT=2
 If clalev([F:ENV])=0 :  Local File ENVELOPPE [ENV]  : Endif
 Call TITFNC("GESENV",TIT) From CONTOBJ
 Filter [ENV] Where FCY=[M:FCY0]FCY
 Read [ENV] First
 If !fstat
  Call LECTEXTRA([L]DES,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
  # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
  GMESSAGE = mess(101,126,1)-[F:ENV]ENV-"("+[L]DES+")"-mess(198,133,1)-"ENVELOPPE ("+TIT+")\"-mess(176,115,1)
  OK = 0
 Endif
 Filter [ENV]
 If !OK : Return : Endif
Endif

# Section analytique
If clalev([F:CCE])=0 :  Local File CACCE [CCE]  : Endif
Call TITFNC("GESCCE",TIT) From CONTOBJ
Filter [CCE] Where FCY=[M:FCY0]FCY
Read [CCE]First
If !fstat
 Call LECTEXTRA([L]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
 # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
 GMESSAGE = mess(101,126,1)-[F:CCE]DIE+"-"+[F:CCE]CCE-"("+[L]DES+")"-mess(198,133,1)-"CACCE ("+TIT+")\"-mess(176,115,1)
 OK = 0
Endif
Filter [CCE]
If !OK : Return : Endif

# Répartition ŕ priori
If clalev([F:DSP])=0 :  Local File CADSP [DSP]  : Endif
Call TITFNC("GESDSP",TIT) From CONTOBJ
Filter [DSP] Where FCY=[M:FCY0]FCY
Read [DSP] First
If !fstat
 Call LECTEXTRA([L]DES,"CADSP","DESTRA",[F:DSP]DSP,"") From ATEXTRA
  # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
 GMESSAGE = mess(101,126,1)-[F:DSP]DSP-"("+[L]DES+")"-mess(198,133,1)-"CADSP ("+TIT+")\"-mess(176,115,1)
 OK = 0
Endif
Filter [DSP]
If !OK : Return : Endif

Return

#JOJAC - 2016-08-25 - X3PEOP-1320 - START
$STYLE
# SEGAY 16/04/2012 - 81084
# Display\hide fields based on legilation code
#JASMI - 2016-06-06 - REQ 114309 - START
#  Call SHOW_LEGACTCALLS From WOCTRSHOW
If GMODU(15)=2 |GMODU(20)=2
  Call DISPLAY_HIDE() From SUBFCYBLEG
Endif
#JASMI - 2016-06-06 - REQ 114309 - END
Return
# END 81084 -
#Return
#JOJAC - 2016-08-25 - X3PEOP-1320 - END
################################################################################
$SELFCYPAR
#Issue X3-35547 – 2017-06-08  by MADOR - As a treasury responsible I want
#to have an object to manage bank/cash register
Local Integer NBTEX
Local Char    TEX(80)(1..1000)
Local Char    TEXTE(80)(1..200,1..4)

If PARAM(1)<>""
    NBTEX = 0

    TIT(0) = mess( 3, 45,1)                  : # Site
    TIT(1) = mess( 2, 45,1)                  : # Company
    TIT(2) = mess( 3, 45,1)                  : # Site
    TIT(3) = mess(38,100,1)                  : # Name
    TIT(4) = mess( 3,675,1)                  : # Short name

    If clalev([FCY_])=0
        Local File FACILITY [FCY], COMPANY  [CPY]
        Link [FCY] With [CPY]CPY0=[F:FCY]LEGCPY As [FCY_]
&       Order By Key FCY1
    Endif

    For [FCY_]

        If func AFNC.PARAM(PARAM(1),[F:FCY]FCY) = "2"
            NBTEX         += 1
            TEX(NBTEX)     = [F:FCY]FCY
            TEXTE(NBTEX,1) = [F:CPY]CPY + " " + [F:CPY]CPYNAM
            TEXTE(NBTEX,2) = [F:FCY]FCY
            TEXTE(NBTEX,3) = [F:FCY]FCYNAM
            TEXTE(NBTEX,4) = [F:FCY]FCYSHO
        Endif

    Next

    If NBTEX = 0
       GERR     = 2
       GMESSAGE = mess(231,111,1)
       mkstat   = 2
    Endif
Endif
#Issue end
Return
################################################################################
$FINFCYPAR
#Issue X3-35547 – 2017-06-08  by MADOR - As a treasury responsible I want
#to have an object to manage bank/cash register
If clalev([FCY_])>0 : Close File [FCY_] : Endif
#Issue end
Return
################################################################################
## Ecran FCY2
################################################################################
Subprog C_UVYDAY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
   Local Integer WLG
   Local Char WCH
   WLG = len(VALEUR)
   For WPOS = 1 To WLG
   WCH = mid$(VALEUR,WPOS,1)
    If (WCH <> mid$("LMMJVSD",WPOS,1)) & (WCH <> " ")
           GMESSAGE = mess(149,100,1) : mkstat = 1
    Endif
   Next
Endif
End

Subprog AS_DADFLG(VALEUR)
Variable Integer VALEUR
If [M]FINFLG<>2
 Grizo [M:DFC]
 mkstat = 1
 End
Endif
End

Subprog C_DADFLG(VALEUR)
Variable Integer VALEUR
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2] : Endif
If VALEUR=2 : End : Endif
For [FCY2]
 If [F:FCY2]DADFCY = [M:FCY0]FCY & [F:FCY2]FCY <> [M:FCY0]FCY
  GMESSAGE = mess(10,122,1) : # Sites attachés ŕ ce site DADS
  mkstat = 2
  Break
 Endif
Next
If mkstat<>2
 Grizo [M:DFC]
 If [M]DADFCY=[M]FCY
  Effzo [M]DADFCY
  Effzo [M]ZDADFCY
 Endif
Endif
End

Subprog AS_DADFCY(VALEUR)
Variable Char    VALEUR()
If [M]FINFLG<>2
 Grizo [M:DFC]
 mkstat = 1
 End
Endif
If [M]DADFLG=2
 VALEUR=[M:FCY0]FCY
 Actzo [M:DFC]
 mkstat = 2
 End
Endif
End

Subprog C_DADFCY(VALEUR)
Variable Char    VALEUR()
Local Integer DAS
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2] : Endif

Call LECTURE("CPY", [M:FCY1]LEGCPY, "") From CONTOBJ

# Test présence du code activité
Call ACTIV("DAS",DAS) From SUBACV

# la DAS2 est un besoin purement franco français et ce message DOIT bloquer UNIQUEMENT
# pour un site financier rattaché ŕ une société de LEG=FRA qd la DAS2 est présente dans le dossier.
If VALEUR="" & [M]FINFLG=2 & [F:CPY]LEG="FRA" & DAS=1
 GMESSAGE = mess(8,122,1) : # Un site financier doit ętre rattaché ŕ un site DADS
 mkstat = 2
 End
Endif
If VALEUR=[M:FCY0]FCY & [M]DADFLG=1
 GMESSAGE = mess(9,122,1) : # Ce n'est pas un site DADS
 mkstat = 2
 End
Endif
Read [FCY2]FCY0 = VALEUR
If !fstat & [F:FCY2]LEGCPY <> [M:FCY1]LEGCPY
 GMESSAGE = mess(30,106,1)-[F:FCY2]LEGCPY : # Ce site est ds la soc.
 mkstat = 2
 End
Endif
End

Subprog S_DADFCY(VALEUR)
Variable Char     VALEUR
Local    Char    PARAM(250)(1..3)
Filter [FCY] Where LEGCPY=[M]LEGCPY & DADFLG=2
PARAM(1) = "FCY"
PARAM(2) = "H"
PARAM(3) = ""
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
Filter [FCY]
End

Subprog C_PAYBAN(VALEUR)
Variable Char    VALEUR()
# Contrôle de cohérence entre sociéte de la banque et société du site
If VALEUR <> "" & [F:BAN]CPY <> [M:FCY1]LEGCPY
 # Cette banque appartient ŕ la société xxxx
 GMESSAGE= mess(42,121,1)-[F:BAN]CPY
   mkstat=2
Endif
End

################################################################################
## Ecran FCY4
################################################################################
Subprog C_FINFLG(VALEUR)
Variable Integer VALEUR
Local Char SOC(250)
If VALEUR=1
 SOC = ""
 For [CPY] Where MAIFCY=[M]FCY
  If SOC<>"" : SOC += "," : Endif
  SOC += [F:CPY]CPY
 Next CPY
 If SOC<>""
  GMESSAGE = mess(70,104,1)+"\"+SOC : # Site référencé dans la société
  mkstat = 2 : End
 Endif
Else
 [M]FINRSPFCY = [M]FCY
 Affzo FINRSPFCY
Endif
Call GRISE_FIN(VALEUR)
End

Subprog GRISE_FIN(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Grizo [FCY4]FINRSPFCY
Else
 Actzo [FCY4]FINRSPFCY
Endif
Affzo [FCY4]FINRSPFCY : #FQ56093
End

Subprog AS_FINRSPFCY(VALEUR)
Variable Char VALEUR()
If [M]FINFLG=2
 mkstat = 1 : End
Endif
End

Subprog C_FINRSPFCY(VALEUR)
Variable Char VALEUR()
If VALEUR="" & GPRODUIT<>1 & (GPRODUIT<>2 | (GPRODUIT=2 & GPAYE=1))  : ## GEODE et PAYE
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR<>""
 If VALEUR<>[M]FCY
  Read [FCY]FCY0 = VALEUR
  If !fstat & [F:FCY]LEGCPY<>[M]LEGCPY
   GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
   mkstat = 2 : End
  Endif
 Else
  [M]FINFLG = 2
  Affzo FINFLG
  Call GRISE_FIN([M]FINFLG)
 Endif
Endif
End

