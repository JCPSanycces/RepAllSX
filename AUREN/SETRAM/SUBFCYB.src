#------------------------------------------------------------------
# For Sage HRM
#------------------------------------------------------------------
$MAJ_ESB
Local  Integer L_K
If clalev([F:CTR1])=0 : Local File EMPLOCTR    [CTR1] : Endif
Delete [ESB] Where [F:ESB]FCY=[F:FCY]FCY & [F:ESB]NIVEAU=4
If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[F:ESB]REFNUM-[F:ESB]CTRNUM-[F:ESB]CTRDAT-num$(4)-num$([F:ESB]RANG)
Endif
If !GOK  Then Return Endif
Filter [F:CTR1] Where ETRFCY=[F:FCY]FCY
If rowcount([F:CTR1]) > 0 Then
    For [F:CTR1]CTR1
      For L_K=0 To len(mess(0,50,1))
          If [F:FCY]CHEF(L_K)<> ""
              Raz [F:ESB]
              [F:ESB]REFNUM=[F:CTR1]REFNUM
              [F:ESB]CTRNUM=[F:CTR1]CTRNUM
              [F:ESB]CTRDAT=[F:CTR1]CTRDAT
              [F:ESB]CHEF=[F:FCY]CHEF(L_K)
              [F:ESB]NIVEAU=4
              [F:ESB]RANG=L_K+1
              Gosub WRITE_ESB
              If !GOK : Break 2 : Endif
          Endif
      Next L_K
    Next
Endif
Return

$WRITE_ESB
  Read [F:ESB]ESB0 = [F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT;[F:FCY]CHEF(L_K);4;L_K+1
  If fstat
    [F:ESB]FCY=[F:FCY]FCY
    If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
    If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
    If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
    Write [F:ESB]
  Else
    [F:ESB]FCY=[F:FCY]FCY
    If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
    If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
    If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
    Rewrite [F:ESB]
  Endif
  If fstat
      GOK = 0 : Call FSTA("ESB") From GLOCK : Return
  Endif
Return
#JOJAC - 2016-08-25 - X3PEOP-1320 - END

