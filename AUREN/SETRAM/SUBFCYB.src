$INIDIE
If dim([M:FCY4]DIE)<=0 : Return : Endif
Raz [M:FCY4]DIE
Raz [M:FCY4]CCE
Call SETPLAN2(ACMCUR,NBPLAN,GPLAN,REFTYP,NBAXE,[M:FCY4]DIE,OBLIG) From CPTDIV
[M:FCY4]BASTAB = NBAXE
For I=0 To [M:FCY4]BASTAB-1
 For J=0 To dim([F:FCY]DIE)-1
  If [F:FCY]DIE(J)=[M:FCY4]DIE(I)
   [M:FCY4]CCE(I) = [F:FCY]CCE(J)
   Break
  Endif
 Next J
Next I
Return

