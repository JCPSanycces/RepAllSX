Raz GPILOBJ
  Call OBJET("FCY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "CREATION"     : Gosub CREATION
 When "RAZCRE"       : Gosub RAZCRE
 When "APRES_CRE"    : Gosub APRES_CRE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "AVANT_MOD"    : Gosub AVANT_MOD    # FGR 29/08/2014 : X3SUIVI95632
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "LIENS"        : Gosub LIENS
 When "VERF_ANU"     : Gosub VERF_ANU
 When "AP_ANNULE"    : Gosub AP_ANNULE
 #JOJAC - 2016-08-25 - X3PEOP-1320 - START
 When "FERME"        : Gosub FERME
 When "STYLE"        : Gosub STYLE :# SEGAY 16/04/2012 - 81084
 When "ABANDON"      : Gosub ABANDON : # SEGAY 16/04/2012 - 81084
 #JOJAC - 2016-08-25 - X3PEOP-1320 - END
 When "SEL_LISTE"    : Case LISTE
                           When "SELFCYPAR": Gosub SELFCYPAR
                       Endcase
 When "FIN_LISTE"    : Case LISTE
                           When "SELFCYPAR": Gosub FINFCYPAR
                       Endcase
Endcase
#JOJAC - 2016-08-25 - X3PEOP-1320 - START
If GMODU(15)=2 |GMODU(20)=2
  If func AFNC.ACTIV("KZA")>0  Then
    Gosub ACTION From SUBFCYBKSA
  Endif
  #JASMI - 2015-09-22 - Localization for Angola - START
  #removed SUBFCYKAQ as there is no source in the file
  #If func AFNC.ACTIV("KAQ")>0 Then
  #  Gosub ACTION From SUBFCYKAQ
  #Endif
  #JASMI - 2015-09-22 - Localization for Angola - END
  # Issue X3-77595 - 2019-03-14 by BRBAN : HR portuguese legislation
  If func AFNC.ACTIV("FPOPH")>0  Then
    Gosub ACTION From SUBFCYBPOR
  Endif
  #DEHEN - 2016-04-12 - Requirement 114362 - US 3 - START
  #If func AFNC.ACTIV("KMIEA")>0  Then
  #  Gosub ACTION From SUBFCYBMID
  #Endif
  #DEHEN - 2016-04-12 - Requirement 114362 - US 3 - END
  #JOJAC - 2016-08-25 - X3PEOP-1320 - END
Endif
Return

