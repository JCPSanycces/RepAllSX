## Etiquette ajoutée par le superviseur (écran FCY5) 16/04/2009 14:46:55 (TS)
######################################################################################

Subprog C_WRHFLG(VALEUR)
Variable Integer VALEUR
Local    Integer I
If dim([M:FCY5]WRHGES)>0 & VALEUR<>[M:FCY2]WRHFLG
   If VALEUR=2
      Actzo [M:FCY5]5
   # Ce site est avec gestion de dépôt
   Elsif [M:FCY5]WRHGES=2
      GMESSAGE=mess(951,196,1)
      mkstat=2 : End
   Else
      # Au cas oů
      Filter [WRH] Where STOFCY=[M:FCY0]FCY
      I = rowcount([WRH])
      Filter [WRH]
      # Il y a des dépôts sur ce site"
      If I<>0
         GMESSAGE=mess(950,196,1)
         mkstat=2 : End
      Endif
      Effzo [M:FCY5]1-99
      Grizo [M:FCY5]1-99
   Endif
Endif
End
######################################################################################

Subprog C_WRHGES(VALEUR)
Variable Integer VALEUR
Local    Integer I
If VALEUR<>[M:FCY5]WRHGES
   If VALEUR=2
      Actzo [M:FCY5]10

      # Que faire si on active la gestion de dépôt alors qu'il y a du stock

   Else
      Filter [WRH] Where STOFCY=[M:FCY0]FCY
      I = rowcount([WRH])
      Filter [WRH]
      # Il y a des dépôts sur ce site"
      If I<>0
         GMESSAGE=mess(950,196,1)
         mkstat=2 : End
      Endif
      Effzo [M:FCY5]10
      Grizo [M:FCY5]10
   Endif
Endif
End
