Subprog C_BPASGE(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>""
 I=find(VALEUR,[M:BPF]CODADR(0..[M:BPF]NBADR-1))
 If I=0
  GMESSAGE = mess(16,199,1) : # Code adresse inexistant
  mkstat = 2 : End
 Else
  [M:FCYP]BPADESSGE=[M:BPF]BPADES(I-1)
 Endif
Else
 Raz [M:FCYP]BPADESSGE #81672
Endif
End

Subprog C_BPADCL(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>""
 I=find(VALEUR,[M:BPF]CODADR(0..[M:BPF]NBADR-1))
 If I=0
  GMESSAGE = mess(16,199,1) : # Code adresse inexistant
  mkstat = 2 : End
 Else
  [M:FCYP]BPADESDCL=[M:BPF]BPADES(I-1)
 Endif
Else
 Raz [M:FCYP]BPADESDCL #81672
Endif
End

Subprog C_CNTDDS(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & !find(VALEUR,[M:CNF]CCNCRM(0..[M:CNF]NBCNT-1))
 GMESSAGE = mess(26,199,1) : # Contact inexistant
 mkstat = 2 : End
Endif
End

Subprog AV_CHEFNAM(VALEUR)
Variable Char    VALEUR()
If [M]CHEF(nolign-1)="" : [L]VALEUR="" : End : Endif
If !clalev([F:ID]) : Local File EMPLOID [ID] : Endif

Read [ID]ID0=[M]CHEF(nolign-1)
[L]VALEUR=toupper([F:ID]NAM)-tolower([F:ID]SRN)
End

