######################################################################################
## Etiquette ajoutée par le superviseur (écran FCYPAYINT) 04/03/2019 18:03:36 (OLCAU)
######################################################################################
# OLCAU X3-61173
Subprog C_IDCCP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & (VALEUR=[M:FCYP]CLLCVT)
  GMESSAGE = mess(324,199,1) : # N° IDCCP doit etre différent du N° de conv collective
  mkstat = 2 : End
Endif
End


######################################################################################
Subprog C_RSKWRK(VALEUR)
Variable Char    VALEUR()
If clalev([F:WAC])=0 : Local File TRVACC [WAC] : Endif

If VALEUR <> ""
  Read [F:WAC]WAC0 = VALEUR
   If [F:WAC]LEG <> "" and [F:WAC]LEG <> GCURLEG
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:WAC]LEG
      mkstat = 2 : End
   Endif
Endif

End

