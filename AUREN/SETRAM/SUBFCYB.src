######################################################################################
Subprog C_PRF(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif


If VALEUR <> ""
#  Read [PRF]PRF0 = GCURLEG;VALEUR
  Filter [F:PRF] Where PRFCOD=VALEUR
  Read [F:PRF] First
  If fstat
      GMESSAGE = VALEUR-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:PRF]
      Read [F:PRF]PRF0 = GCURLEG;VALEUR
      If fstat
        Filter [F:PRF] Where PRFCOD=VALEUR
        Read [F:PRF] First
        GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:PRF]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [PRF]
End


