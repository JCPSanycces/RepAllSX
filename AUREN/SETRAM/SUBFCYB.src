Subprog C_HRMDADFLG(VALEUR)
Variable Integer VALEUR
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2] : Endif
If VALEUR=2 : End : Endif
For [FCY2]
 If [F:FCY2]DADFCY = [M:FCY0]FCY & [F:FCY2]FCY <> [M:FCY0]FCY
  GMESSAGE = mess(10,122,1) : # Sites attachés ŕ ce site DADS
  mkstat = 2
  Break
 Endif
Next
If mkstat<>2
 Grizo [M:FCYP]10
 Grizo [M:FCYP]FLGAPP, FLGFOR
 If [M:FCYP]HRMDADFCY=[M:FCY0]FCY
  Effzo [M:FCYP]HRMDADFCY
  Effzo [M:FCYP]ZHRMDADFCY
 Endif
Endif
End

Subprog AM_HRMDADFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:FCYP]10-20
Else
 Effzo [M:FCYP]10
 Grizo [M:FCYP]10
 Effzo [M:FCYP]FLGAPP, FLGFOR
 Grizo [M:FCYP]FLGAPP, FLGFOR
Endif
Affzo [M:FCYP]10-20
End


Subprog AS_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
If [M:FCYP]HRMDADFLG=2
 VALEUR = [M:FCY0]FCY
 mkstat = 2 : End
Endif
End

Subprog C_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If VALEUR<>""
 Read [FCY]FCY0=VALEUR
 If !fstat & [F:FCY]LEGCPY<>[M:FCY1]LEGCPY
  GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
  mkstat = 2 : End
 Endif
 If VALEUR=[M:FCY0]FCY & [M:FCYP]HRMDADFLG=1
  GMESSAGE = mess(9,122,1) : # Ce n'est pas un site DADS
  mkstat = 2 : End
 Endif
Endif

End

Subprog C_HRMPAYBAN(VALEUR)
Variable Char    VALEUR()
# Contrôle de cohérence entre sociéte de la banque et société du site
If VALEUR <> "" & [F:BAN]CPY <> [M:FCY1]LEGCPY
 # Cette banque appartient ŕ la société xxxx
 GMESSAGE= mess(42,121,1)-[F:BAN]CPY
 mkstat = 2 : End
Endif
End

Subprog AV_SPAOPEIGIC(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("KSP")
 Call LEC_CPY([M]LEGCPY) From CPTLEC
 If !fstat
  If func AFNC.PARAM("SPAVAT",[F:CPY]CPY)<>"2"
   [M]FMTESP = "-LA:1"
  Else
   [M]FMTESP = "+LA:1"
  Endif
 Endif
Endif
End
