Subprog C_SRV(VALEUR)
Variable Char    VALEUR()
If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif

If VALEUR <> ""
  Read [SRV]SRV0 = VALEUR
   If [F:SRV]LEG <> "" and [F:SRV]LEG <> GCURLEG
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:SRV]LEG
      mkstat = 2 : End
   Endif
Endif

End


