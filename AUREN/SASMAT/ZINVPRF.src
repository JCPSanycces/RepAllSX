# ZIMS - Motor de sincronización
# Fecha inicio ZIMS: 16/05/2022
# Desarrollador: JC
# Código de desarrollo: ZIMS
# Descripción del desarrollo: Motor de sincronización con herramienta externa - Registro de factura proforma cuando salta el workflow
#######################################################################################

Subprog REGISTRA_PROFORMA()
Local Integer LSTAT
  If !clalev([F:BPC1]) Then : Local File BPCUSTOMER [F:BPC1] : Endif
  Read [F:BPC1]BPC0 = [F:SIH]BPR
  If !fstat and (left$([F:BPC1]BCGCOD,3) = 'B2B') Then
    Call ZTSKNEW([F:SIH]INVTYP,[F:SIH]NUM,[F:SIH]BPR,GREP,LSTAT) From ZTSKGEST
  Endif
  Close Local File [BPC1]
End
