#<AdxTL>@(#)0.0.0.0 $Revision$ 
#001 FPH-AUREN 26/01/21-06.138.458. GESTIÆN DEL TRATAMIENTO DE FACTURA SIMPLIFICADA O TICKET
$ACTION

  Case ACTION
    When "SETBOUT" : Gosub SETBOUT
    When Default
  Endcase
Return

####################################################
$SETBOUT
   #001+
   If !clalev([F:ZTSV1]) : Local File TABSIVTYP   [F:ZTSV1] : Endif

   Read [F:ZTSV1]TSV0 = [M:BIC0]SIVTYP;GCURLEG
   If !fstat Then
      If  [F:ZTSV1]ZFACSIMP = 2 Then
        Actzo [M:BIC0]ZTICKETINI
        Actzo [M:BIC0]ZTICKETFIN
        Actzo [M:BIC0]ZNUMTICKET
      Else
        Diszo [M:BIC0]ZTICKETINI
        Diszo [M:BIC0]ZTICKETFIN
        Diszo [M:BIC0]ZNUMTICKET
        Raz [M:BIC0]ZTICKETINI
        Raz [M:BIC0]ZTICKETFIN
        Raz [M:BIC0]ZNUMTICKET
      Endif
   Else
      Diszo [M:BIC0]ZTICKETINI
      Diszo [M:BIC0]ZTICKETFIN
      Diszo [M:BIC0]ZNUMTICKET
      Raz [M:BIC0]ZTICKETINI
      Raz [M:BIC0]ZTICKETFIN
      Raz [M:BIC0]ZNUMTICKET
   Endif
   Affzo [M:BIC0]
   #001-
Return
######################################################################################

Subprog AM_SIVTYP(VALEUR)
Variable Char    VALEUR()
 #001+
   If !clalev([F:ZTSV2]) : Local File TABSIVTYP   [F:ZTSV2] : Endif

   Read [F:ZTSV2]TSV0 = VALEUR;GCURLEG
   If !fstat Then
      If  [F:ZTSV2]ZFACSIMP = 2 Then
        Actzo [M:BIC0]ZTICKETINI
        Actzo [M:BIC0]ZTICKETFIN
        Actzo [M:BIC0]ZNUMTICKET
      Else
        Diszo [M:BIC0]ZTICKETINI
        Diszo [M:BIC0]ZTICKETFIN
        Diszo [M:BIC0]ZNUMTICKET
      Endif
   Else
      Diszo [M:BIC0]ZTICKETINI
      Diszo [M:BIC0]ZTICKETFIN
      Diszo [M:BIC0]ZNUMTICKET
   Endif
   Affzo [M:BIC0]
   #001-
End


######################################################################################
