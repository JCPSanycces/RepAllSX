## DespuÚs del campo 'Funciˇn' (pantalla ZTSK0) 17/05/2022 09:24:17 (AURFP)
######################################################################################
Subprog AP_ZFUNCID(VALEUR)
Variable Integer VALEUR
  If !clalev([F:ZAPL]) Then : Local File APLSTD [F:ZAPL] : Endif
  Read [F:ZAPL]CLE = 6003;VALEUR;GLANGUE
  If !fstat Then
    [M:ZTSK0]ZFUNDES = [F:ZAPL]LANMES
    Affzo [M:ZTSK0]ZFUNDES
  Endif
  Close Local File [ZAPL]
End

