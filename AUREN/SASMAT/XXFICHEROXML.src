$ACTION
  Case ACTION
    When "WRISIIFILE"   : Gosub WSIIFILE
    When "WRISIIRESP"   : Gosub RESPUESTA
    When "AFTVARSII"    : Gosub AFTVARSII #modificamos xml
    When Default
  Endcase
Return

#################################

$WSIIFILE
Openo filpath("BQT","SII_"+date$+"_"+left$(time$,2)+mid$(time$,4,2)+"_0"+mid$(time$,7,2),"XML"),0 Using [XXX]
Wrseq DATAXML Using [XXX]
Openo Using [XXX]
Return

#################################
$RESPUESTA

Openo filpath("BQT","RSII_"+date$+"_"+left$(time$,2)+mid$(time$,4,2)+"_0"+mid$(time$,7,2),"XML"),0 Using [YYY]
Wrseq RESULTADO Using [YYY]
Openo Using [YYY]
Return



