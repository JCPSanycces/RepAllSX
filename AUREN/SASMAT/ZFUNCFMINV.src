#######################################################################################

$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "CFMINVAFT"      : Goto CFMINVAFT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CFMINVAFT
  Gosub INSERT_ZTSKMGR  # ZIMS.JC.16052022
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# ZIMS.JC.16052022
$INSERT_ZTSKMGR
Local Integer LSTAT

  Read [F:BPC]BPC0 = [F:SI2]BPR
  If !fstat and (left$([F:BPC]BCGCOD,3) = 'B2B') Then
    Call ZTSKNEW([F:SI2]INVTYP,[F:SI2]NUM,[F:SI2]BPR,'',LSTAT) From ZTSKGEST
  Endif
Return

