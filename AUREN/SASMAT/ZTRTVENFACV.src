Local Integer LSTAT
Call ZTSKNEW(1,'B2B01-IN22-000549','B2B5352611396','',LSTAT) From ZTSKGEST
End

#######################################################################################
$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "CFMINVMAJ"      : Goto CFMINVMAJ
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CFMINVMAJ
  Gosub INSERT_ZTSKMGR  # ZIMS.JC.16052022
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# ZIMS.JC.16052022
$INSERT_ZTSKMGR
Local Integer LSTAT

  Read [F:BPC]BPC0 = [F:SIH]BPR
  If !fstat and (left$([F:BPC]BCGCOD,3) = 'B2B') Then
    Call ZTSKNEW([F:SIH]INVTYP,[F:SIH]NUM,[F:SIH]BPR,'',LSTAT) From ZTSKGEST
  Endif
Return

