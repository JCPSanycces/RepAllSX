#####################################################################################
# Src: SPEZMGR
#-------------------------------------------------------------------------------------
# Proyecto: Sasmat - PDPaola
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# ZIMS - Motor de sincronización
# Fecha inicio ZIMS: 16/05/2022
# Desarrollador: JC
# Código de desarrollo: ZIMS
# Descripción del desarrollo: Motor de sincronización con herramienta externa
#######################################################################################

$ACTION

#If GUSER="AURFP" Then : Infbox ACTION : Endif
Case ACTION
  When "SETBOUT"    : Gosub SETBOUT
  When "AVANTBOUT"  : Gosub AVANTBOUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SETBOUT
  Raz CHMEN

  If [M:ZMGR0]ZSTATUS = "PL" or [M:ZMGR0]ZSTATUS = "ER" or [M:ZMGR0]ZSTATUS = "TO" Then
    CHMEN += "1"
  Endif
  If [M:ZMGR0]ZSTATUS = "ST" Then
    CHMEN += "2"
  Endif
  If [M:ZMGR0]ZSTATUS = "ST" Then
    CHMEN += "3"
  Endif

Return

##############################################################
$AVANTBOUT
  Case BOUT
    When "1" : Gosub DETENER_COMUNICACION
    When "2" : Gosub RELANZAR_COMUNICACION
    When "3" : Gosub MODIFICAR_REINTENTOS
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$DETENER_COMUNICACION

Local Integer YESNO : YESNO = 2
Local Char    LMSJ(50)

  Call BUSCA_FUNCION([M:ZMGR0]ZFUNCID,LMSJ)
  Call OUINON("Se va a detener la comunicación para\"+LMSJ+" número "+[M:ZMGR0]ZIDCTRL+"\żDesea continuar?",YESNO) From GESECRAN
  If YESNO = 2
    Gosub ABRIR_TABLAS
    Read [F:ZTM0]ZTM0 = [M:ZMGR0]ZIDUNICO
    If !fstat Then
      [M:ZMGR0]ZSTATUS = 'ST'
      Affzo [M:ZMGR0]ZSTATUS
      [F:ZTM0]ZSTATUS  = 'ST'
      Trbegin [F:ZTM0]
      Rewrite [F:ZTM0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Gosub CERRAR_TABLAS
  Endif

Return

##############################################################
$RELANZAR_COMUNICACION

Local Integer LRET
Local Integer YESNO : YESNO = 2
Local Char    LMSJ(50)

  Call BUSCA_FUNCION([M:ZMGR0]ZFUNCID,LMSJ)
  Call OUINON("Se va a relanzar la comunicación para\"+LMSJ+" número "+[M:ZMGR0]ZIDCTRL+"\żDesea continuar?",YESNO) From GESECRAN
  If YESNO = 2
    Gosub ABRIR_TABLAS
    Read [F:ZTM0]ZTM0 = [M:ZMGR0]ZIDUNICO
    If !fstat Then
      Raz [F:ZTM1]
      Call NUMERO("ZMGR",nomap,date$,"null",[F:ZTM1]ZIDUNICO,LRET) From SUBANM
      [F:ZTM1]ZFUNCID     = [F:ZTM0]ZFUNCID
      [F:ZTM1]ZIDCTRL     = [F:ZTM0]ZIDCTRL
      [F:ZTM1]ZINDEX      = [F:ZTM0]ZINDEX
      [F:ZTM1]ZCONEXNI    = [F:ZTM0]ZCONEXNI
#      [F:ZTM1]ZTIMESTAMP  = datetime$
      [F:ZTM1]ZSTATUS     = 'PL'
      Trbegin [F:ZTM1]
      Write   [F:ZTM1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Gosub CERRAR_TABLAS
  Endif

Return

##############################################################
$MODIFICAR_REINTENTOS

Local Integer YESNO : YESNO = 2
Local Char    LMSJ(50)

  Call BUSCA_FUNCION([M:ZMGR0]ZFUNCID,LMSJ)
  Call OUINON("Se van a modificar los reintento para\"+LMSJ+" número "+[M:ZMGR0]ZIDCTRL+"\żDesea continuar?",YESNO) From GESECRAN
  If YESNO = 2
    Local Char    LINPUT(10)
    Local Integer LOK
    Call SAICAR(LINPUT,"Reintentos","Cantidad","ZMGR",0,0,"",LOK) From GESECRAN
    If LOK = 2 and val(LINPUT) <> 0 Then
      Gosub ABRIR_TABLAS
      Read [F:ZTM0]ZTM0 = [M:ZMGR0]ZIDUNICO
      If !fstat Then
        [M:ZMGR0]ZCONEXNI = val(LINPUT)
        Affzo [M:ZMGR0]ZCONEXNI
        [F:ZTM0]ZCONEXNI  = val(LINPUT)
        Trbegin [F:ZTM0]
        Rewrite [F:ZTM0]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
      Gosub CERRAR_TABLAS
    Endif
  Endif

Return

##############################################################
$ABRIR_TABLAS
  If !clalev([F:ZTM0]) Then : Local File ZTSKMGR [F:ZTM0] : Endif
  If !clalev([F:ZTM1]) Then : Local File ZTSKMGR [F:ZTM1] : Endif
Return

##############################################################
$CERRAR_TABLAS
  Close Local File [ZTM0],[ZTM1]
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
Subprog BUSCA_FUNCION(PFUNCID,PFUNCDES)
Value     Integer PFUNCID
Variable  Char    PFUNCDES

Local Char LMASC(5)  : LMASC = "el"
Local Char LFEM(5)   : LFEM  = "la"

  If !clalev([F:APL0]) Then : Local File APLSTD [F:APL0] : Endif
  Case PFUNCID
    When  1
      Read [F:APL0]CLE = 6003;PFUNCID;'SPA'
      If !fstat Then
        PFUNCDES = LFEM-[F:APL0]LANMES
      Endif
    When  2
      Read [F:APL0]CLE = 6003;PFUNCID;'SPA'
      If !fstat Then
        PFUNCDES = LMASC-[F:APL0]LANMES
      Endif
    When  3
      Read [F:APL0]CLE = 6003;PFUNCID;'SPA'
      If !fstat Then
        PFUNCDES = LFEM-[F:APL0]LANMES
      Endif
    When  4
      Read [F:APL0]CLE = 6003;PFUNCID;'SPA'
      If !fstat Then
        PFUNCDES = LMASC-[F:APL0]LANMES
      Endif
    When  5
      Read [F:APL0]CLE = 6003;PFUNCID;'SPA'
      If !fstat Then
        PFUNCDES = LMASC-[F:APL0]LANMES
      Endif
  Endcase
  Close Local File [APL0]
End
