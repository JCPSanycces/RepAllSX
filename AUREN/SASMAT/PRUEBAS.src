#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer L
L = func LANZA_PROCESO(300,'2022-0000000009')
End



Funprog LANZA_PROCESO(PTREINTENTO,PZIDUNICO)
Value Decimal PTREINTENTO
Value Char    PZIDUNICO

Local Char LFECHA(50),HORACARMASX(50),HORACARSYS(50),LFECHADATE(50),LFECHASYS(50)
Local Integer LHORA,LHORAMASX,LX,LRET

  Local File ZTSKMGR [F:ZZZ]
  Filter [F:ZZZ] Where ZIDUNICO = PZIDUNICO
  Read   [F:ZZZ] First

  LX = PTREINTENTO
  LHORA = [F:ZZZ]ZHOURSEND
  LHORAMASX = LHORA + LX
  LFECHA = [F:ZZZ]ZDATESEND
  Call CONV_NUMAHORA(LHORAMASX,HORACARMASX)
  Call CONV_NUMAHORA(time,HORACARSYS)

  LFECHADATE = left$(LFECHA,4)+"-"+mid$(LFECHA,5,2)+"-"+mid$(LFECHA,7,2)+"T"+num$(HORACARMASX)+"Z"
  LFECHASYS  = left$(date$,4)+"-"+mid$(date$,5,2)+"-"+mid$(date$,7,2)+"T"+num$(HORACARSYS)+"Z"

#Infbox LFECHADATE
#Infbox LFECHASYS

  If LFECHADATE >= LFECHASYS Then
    Infbox "se lanza el proceso"
  Else
   Infbox "no se lanza el proceso"
  Endif


  Filter [F:ZZZ]
  Close Local File [ZZZ]
End LRET


Subprog CONV_NUMAHORA(WHDIANUM, WHDIACAR)
Value Integer WHDIANUM
Variable Char WHDIACAR

Local Integer WHORAS,WMINUTOS,WSEGUNDOS
Local Decimal WAUX1, WAUX2

  If WHDIANUM>86400
    WHDIACAR="00:00:00"
  Else
    WHORAS=int(WHDIANUM/3600)
    WAUX1 = WHDIANUM - WHORAS * 3600
    WMINUTOS = int(WAUX1/60)
    WAUX2 = WHDIANUM - (WHORAS * 3600) - (WMINUTOS * 60)
    WSEGUNDOS = WAUX2
    WHDIACAR = format$("N0:2X",WHORAS)+":"+format$("N0:2X",WMINUTOS)+":"+format$("N0:2X",WSEGUNDOS)
  Endif
End
