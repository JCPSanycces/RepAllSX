#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
    When "BEFWRIDVS"   : Gosub BEFWRIDVS
    When Default
  Endcase
Return

#########################################
$BEFWRIDVS
  If !clalev([F:ZSIH1]) : Local File SINVOICE   [F:ZSIH1] : Endif
  If !clalev([F:ZSIV1]) : Local File SINVOICEV  [F:ZSIV1] : Endif
  If !clalev([F:ZTSV1]) : Local File TABSIVTYP  [F:ZTSV1] : Endif
  If !clalev([F:ZFCY1]) : Local File FACILITY   [F:ZFCY1] : Endif
  If !clalev([F:ZBPR1]) : Local File BPARTNER   [F:ZBPR1] : Endif

  If clalev([F:DVS])
    Read [F:ZSIH1]SIH0 = [F:DVS]NUM
    Read [F:ZSIV1]SIV0 = [F:DVS]NUM
    Read [F:ZBPR1]BPR0 = [F:ZSIH1]BPR
    Read [F:ZFCY1]FCY0 = [F:ZSIH1]FCY

    Read [F:ZTSV1]TSV0 = [F:ZSIH1]SIVTYP;[F:ZFCY1]LEG
    If !fstat and [F:ZTSV1]ZFACSIMP = 2 Then
       #Forzamos gestión de Tickets (TCKINI, TCKEND, TCKNUM).
#      #Como X3 no tiene gestión de tickets, se deberían rellenar a través del punto de entrada.
#      #Si el cliente usa la misma numeración que de factura, sería copiar el valor del campo
      [F:DVS]TCKINI    = [F:ZSIH1]ZTICKETINI
      [F:DVS]TCKEND    = [F:ZSIH1]ZTICKETFIN
      [F:DVS]TCKNUM    = [F:ZSIH1]ZNUMTICKET
      [F:DVS]BPRNAM(0) = ""      
      [F:DVS]CRN       = ""               
      [F:DVS]EECNUM    = ""      
#      Endif
#    Endif
   Endif
  Endif

Return
