#<AdxTL>@(#)0.0.0.0 $Revision$
Call ZTSKWSPOST()
End

#####################################################################################
# Src: ZSTKWS
#-------------------------------------------------------------------------------------
# Proyecto: Sasmat - PDPaola
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# ZIMS - Motor de sincronización
# Fecha inicio ZIMS: 16/05/2022
# Desarrollador: JC
# Código de desarrollo: ZIMS
# Descripción del desarrollo: Gestión de envío de datos a través de WS hacia los endpoints
#######################################################################################

##############################################################
#**
#* realiza el envío de datos a través de WS REST, en modo síncrono, hacia los endpoints de PdPTools
#*
#*!
Funprog ZTSKWSPOST(PCONEXDIR,PCONEXUSR,PCONEXPWD,PJSON)
Value     Char    PCONEXDIR,PCONEXUSR,PCONEXPWD
Variable  Clbfile PJSON

Local     Integer RETVAL
Local     Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local     Clbfile RESHEAD(0),RESBODY(0)

  # Add a parameter
  HCOD(1) = 'pdp-api-key'
  HVAL(1) = '"'+PCONEXPWD+'"'
  HCOD(2) = 'Content-Type'
  HVAL(2) = '"application/json"'

  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("REST_MOTOR_INTEGRA","POST",PCONEXDIR,PCOD,PVAL,HCOD,HVAL,PJSON,0,'',RESHEAD,RESBODY)

  # Manage the errors
  # 200 - OK
  # 201 - OK
  # 400 - Error. Campo requerido
  # 401 - Error. Acceso no autorizado
  # 404 - Error. Endpoint no existe
  # 405 - Error. El método no existe
  # 409 - Error. El registro ya existe
  # 500 - Error de sistema
  # 504 - Error de Timeout

  Kill RESHEAD,RESBODY,PCOD,PVAL,HCOD,HVAL

End RETVAL

##############################################################
#**
#* realiza el envío de datos a través de WS REST, en modo síncrono, hacia los endpoints de PdPTools
#*
#*!
Funprog ZTSKWSDELETE(PCONEXDIR,PCONEXUSR,PCONEXPWD,PJSON,PINDEX)
Value     Char    PCONEXDIR,PCONEXUSR,PCONEXPWD,PINDEX
Variable  Clbfile PJSON

Local     Integer RETVAL
Local     Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local     Clbfile RESHEAD(0),RESBODY(0)

  # Add a parameter
  HCOD(1) = 'pdp-api-key'
  HVAL(1) = '"'+PCONEXPWD+'"'
  HCOD(2) = 'Content-Type'
  HVAL(2) = '"application/json"'

  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("REST_MOTOR_INTEGRA","DELETE",PCONEXDIR+'/'+PINDEX,PCOD,PVAL,HCOD,HVAL,'{}',0,'',RESHEAD,RESBODY)

  # Manage the errors
  # 200 - OK
  # 201 - OK
  # 400 - Error. Campo requerido
  # 401 - Error. Acceso no autorizado
  # 404 - Error. Endpoint no existe
  # 405 - Error. El método no existe
  # 409 - Error. El registro ya existe
  # 500 - Error de sistema
  # 504 - Error de Timeout

  Kill RESHEAD,RESBODY,PCOD,PVAL,HCOD,HVAL

End RETVAL
