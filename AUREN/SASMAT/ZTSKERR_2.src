#<AdxTL>@(#)0.0.0.0 $Revision$
Call ZFUNTKERR()
End

#####################################################################################
# Src: ZTSKERR
#-------------------------------------------------------------------------------------
# Proyecto: Sasmat - PDPaola
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# ZIMS - Motor de sincronizaciˇn
# Fecha inicio ZIMS: 16/05/2022
# Desarrollador: JC
# Cˇdigo de desarrollo: ZIMS
# Descripciˇn del desarrollo: Gestiˇn de errores de tareas
#######################################################################################

##############################################################
#**
#* funciˇn estß dise˝ada para poder dar un tratamiento de errores diferenciado
#*
#*!
Subprog ZFUNTKERR()

Local Char    LCONEXDIR(250),LCONEXUSR(250),LCONEXPWD(250),LERROR(50)

  If !clalev([F:ZTM1]) Then : Local File ZTSKMGR  [F:ZTM1] : Endif
  If !clalev([F:AXX1]) Then : Local File ATEXTRA  [F:AXX1] : Endif
  If !clalev([F:AXX2]) Then : Local File ATEXTRA  [F:AXX2] : Endif
  If !clalev([F:ZTC1]) Then : Local File ZTSKCFG  [F:ZTC1] : Endif

  # realiza un pooling de tareas en estado ERROR ordenadas por Timestamp
  Filter [F:ZTM1] Where ZSTATUS = 'ER' Order By ZTIMESTAMP Asc
  # para cada tarea
  For [ZTM1]
    # busca en la tabla ZTSKCFG los datos necesarios para establecer la conexiˇn y cußl es la funciˇn que debe ejecutarse
    Read [F:ZTC1]ZTC0 = [F:ZTM1]ZFUNCID
    # si el id de la funciˇn existe
    If !fstat Then
      LCONEXDIR = [F:ZTC1]ZCONEXDIR
      LCONEXUSR = [F:ZTC1]ZCONEXUSR
      LCONEXPWD = [F:ZTC1]ZCONEXPWD
      # actualiza los campos ZTIMESEND, ZDATESEND y ZHOURSEND y se incrementa el contador ZCONEXNI
      [F:ZTM1]ZSTATUS   = 'SE'
      [F:ZTM1]ZTIMESEND = datetime$
      [F:ZTM1]ZDATESEND = date$
      [F:ZTM1]ZHOURSEND = time
      [F:ZTM1]ZCONEXNI += 1
      # se consulta el correspondiente cˇdigo de error existente en el campo ZRESPID
      Filter [F:AXX1] Where CODFIC = 'ATABDIV' and ZONE = 'LNGDES' and LANGUE = GLANGUE and IDENT1 = '6002' and IDENT2 = num$([F:ZTM1]ZFUNCID)
      Read   [F:AXX1] First
      # de encontrarse se obtendrß la funciˇn a invocar
      If !fstat and [F:AXX1]TEXTE <> '' Then
        Local Char LPROGNAME(GLONADC) : LPROGNAME = [F:AXX1]TEXTE
        # se invoca la funciˇn a ejecutar
        Call CONTROLE([F:ZTM1]ZIDUNICO,[F:ZTM1]ZINDEX,LCONEXDIR,LCONEXUSR,LCONEXPWD,LERROR) From =LPROGNAME
        # en caso de que el error devuelto sea 200 O 201, se considera que la ejecuciˇn ha sido correcta y se actualiza el estado a COMPLETED
        If find(LERROR,'200','201') <> 0 Then
          [F:ZTM1]ZSTATUS = 'CO'
        Else
          [F:ZTM1]ZSTATUS = 'ST'
        Endif
      # si la funciˇn de error no estß definida
      Else
        # se actualiza igualmente la tarea a STOPPED
        [F:ZTM1]ZSTATUS = 'ST'
        # y se invocarß por defecto una funciˇn de error genÚrica ZFUNERRDEF
        Call ZFUNERRDEF([F:ZTM1]ZINDEX)
      Endif
    # si el id de la funciˇn no existe
    Else
      # se actualiza igualmente la tarea a STOPPED
      [F:ZTM1]ZSTATUS = 'ST'
      # y se invocarß por defecto una funciˇn de error genÚrica ZFUNERRDEF
      Call ZFUNERRDEF([F:ZTM1]ZINDEX)
    Endif
    [F:ZTM1]ZRESPID   = LERROR
    Filter [F:AXX2] Where CODFIC = 'ATABDIV' and ZONE = 'LNGDES' and LANGUE = GLANGUE and IDENT1 = '6001' and IDENT2 = LERROR
    Read   [F:AXX2] First
    [F:ZTM1]ZRESPMSG  = [F:AXX2]TEXTE
    [F:ZTM1]ZTIMEREC  = datetime$
    [F:ZTM1]ZDATEREC  = date$
    Filter [F:AXX2]
    Trbegin [F:ZTM1]
    Rewrite [F:ZTM1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Close Local File [ZTM1],[AXX1],[AXX2],[ZTC1]

End

##############################################################
#**
#* funciˇn que envia un mail informando del error a un usuario administrador mediante el sistema de workflows de Sage X3
#*
#*!
Subprog ZFUNERRDEF(PINDEX)
Value Char PINDEX

  Global Char GCORREO(250),GWFINDICE(250)
  GCORREO   = "joseluis.chiva@auren.es"
  GWFINDICE = PINDEX
  Call WORKFLOW (1,"ZES","",GUSER) From AWRK
  If dim(GCORREO)   > 0 Then : Kill GCORREO   : Endif
  If dim(GWFINDICE) > 0 Then : Kill GWFINDICE : Endif

End
