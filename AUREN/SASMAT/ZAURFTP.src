Subprog FTPGETDEL (SERVER,USER,PWD,FTPFOLDER,LPATH,RESULT)
Value Char SERVER()
Value Char USER()
Value Char PWD()
Value Char FTPFOLDER()
Value Char LPATH()
Variable Integer RESULT

Local Char NL(2)
Local Integer STAT
Local Char LFILES(100)(1..)
Local Char FTPFILE(GDIMFIC)(1..)
Local Char ORDRE(250)

  RESULT = -1
  NL = chr$(13)+chr$(10)

#Check if local directory exists and creates it if not

  STAT = filinfo (LPATH,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATH+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution

  If Delfile (filpath(LPATH,"FtpFileLst",'bat')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FtpGetDel",'bat')) = -27 : End: Endif
  If Delfile (filpath(LPATH,"FtpListOrder",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FtpGetDelOrder",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FileLstLog",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"GetDelLog",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FileList",'txt')) = -27 : End : Endif

#Creates ftp .bat file to get the file list to download and delete

  Openo filpath(LPATH,"FtpFileLst","bat"), 0 Using [FOUT]
  Wrseq "ftp -i -n -s:"+LPATH+"\FtpListOrder.txt"+NL Using [FOUT]
  Openo Using [FOUT]

  Openo filpath(LPATH,"FtpListOrder","txt"), 0 Using [FOUT]
  Wrseq "open "+SERVER+NL+
&       "user "+USER+NL+
&       PWD+NL+
&       "quote pasv"+NL+
&       "cd /"+FTPFOLDER+NL+
&       "lcd "+LPATH+NL+
&       "ls"+NL+
&       "ls *.??? FileList.txt"+NL+
&       "Quit"+NL Using [FOUT]

# 211021 IDV Fallo al abrir la conexión, se fuerza
#        Se ańade la línea de ls+NL

  Openo Using [FOUT]

#Executes ft .bat file to get the file list to download and delte

  ORDRE = LPATH+"\FtpFileLst.bat > "+LPATH+"\FileLstLog.txt 2>&1"
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

  RESULT = 0

  If filinfo(filpath(LPATH,"FileList","txt"),7) > 0

  #Crete the command file to download and delete the above files

    Openo filpath(LPATH,"FtpGetDel","bat"), 0 Using [FOUT]
    Wrseq "ftp -i -n -s:"+LPATH+"\FtpGetDelOrder.txt"+NL Using [FOUT]
    Openo Using [FOUT]

    Openo filpath(LPATH,"FtpGetDelOrder","txt"), 0 Using [FOUT]
    Wrseq "open "+SERVER+NL+
&       "user "+USER+" "+NL+
&       PWD+NL+
&       "quote pasv"+NL+
&       "cd /"+FTPFOLDER+NL+
&       "ls"+NL+
&       "lcd "+LPATH+chr$(13) Using [FOUT]

# 211021 IDV Fallo al abrir la conexión, se fuerza
#        Se ańade la línea de ls+NL


    Openi filpath(LPATH,"FileList","txt"), 0 Using [FIN]
    Iomode adxifs "" Using [FIN]
    Iomode adxirs NL Using [FIN]
    Iomode adxium 0 Using [FIN]
    Rdseq FTPFILE Using [FIN]
    While !fstat
        Wrseq "get "+chr$(34)+FTPFILE+chr$(34) Using [FOUT]
        Wrseq "delete "+chr$(34)+FTPFILE+chr$(34) Using [FOUT]
        Rdseq FTPFILE Using [FIN]
        RESULT = RESULT + 1
    Wend
    Wrseq "quit"+chr$(13) Using [FOUT]

    Openo Using [FOUT]
    Openi Using [FIN]

    #Execute the previous script

    ORDRE = LPATH+"\FtpGetDel.bat > "+LPATH+"\GetDelLog.txt 2>&1"
    Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

  Endif

#Clean the script files

  If Delfile (filpath(LPATH,"FtpFileLst",'bat')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FtpGetDel",'bat')) = -27 : End: Endif
  If Delfile (filpath(LPATH,"FtpListOrder",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FtpGetDelOrder",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FileLstLog",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"GetDelLog",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATH,"FileList",'txt')) = -27 : End : Endif

End

##########################################################################################################

Subprog FTPPUTMOV (SERVER,USER,PWD,FTPFOLDER,LPATH,LPATHDES,RESULT)
Value Char SERVER()
Value Char USER()
Value Char PWD()
Value Char FTPFOLDER()
Value Char LPATH()
Value Char LPATHDES()
Variable Integer RESULT

Local Char NL(2)
Local Integer I
Local Integer STAT
Local Char LFILES(GDIMFIC)(1..)
Local Char FILELIST(GDIMFIC)(1..)
Local Char ORDRE(250)

  RESULT = -1
  NL = chr$(13)+chr$(10)

#Check if destination directory exists and creates it if not

  STAT = filinfo (LPATHDES,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATHDES+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution

  If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : End: Endif
  If Delfile (filpath(LPATHDES,"FtpPutOrder",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"FileCount",'txt')) = -27 : End : Endif

#Check the files to upload

  ORDRE = "dir /b /a-d-s-h "+LPATH+" 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RESULT,LFILES) From ORDSYS

  If RESULT > 0

#Create the command file to upload the files

    Openo filpath(LPATHDES,"FtpPut","bat"), 0 Using [FOUT]
    Wrseq "ftp -i -n -s:"+LPATHDES+"\FtpPutOrder.txt"+NL Using [FOUT]
    Openo Using [FOUT]

    Openo filpath(LPATHDES,"FtpPutOrder","txt"), 0 Using [FOUT]

    Wrseq "open "+SERVER+NL+
&         "user "+USER+" "+NL+
&         PWD+NL+
&         "quote pasv"+NL+
&         "cd /"+FTPFOLDER+NL+
&         "lcd "+LPATH+NL+
&         "ls"+NL+
&         "mput *.*"+NL+
&         "quit"+NL Using [FOUT]

# 211021 IDV Fallo al abrir la conexión, se fuerza
#        Se ańade la línea de ls+NL

    Openo Using [FOUT]

  #Execute the previous script

    ORDRE = LPATHDES+"\FtpPut.bat > "+LPATHDES+"\PutLog.txt 2>&1"
    Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

#Clean the script files

    If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : RESULT = -2 : End: Endif
    If Delfile (filpath(LPATHDES,"FtpPutOrder",'txt')) = -27 : RESULT = -2 : End : Endif
    If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : RESULT = -2 : End : Endif
    If Delfile (filpath(LPATHDES,"FileCount",'txt')) = -27 : End : Endif

#Move de uploaded files

  ORDRE = "MOVE "+LPATH+"\*.* "+LPATHDES
  Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILES) From ORDSYS

  Endif

End

##########################################################################################################

Subprog SFTPPUTMOV (SERVER,USER,PWD,FTPFOLDER,LPATH,LPATHDES,LINDEX,RESULT)
Value     Char    SERVER()
Value     Char    USER()
Value     Char    PWD()
Value     Char    FTPFOLDER()
Value     Char    LPATH()
Value     Char    LPATHDES()
Value     Char    LINDEX()
Variable  Integer RESULT

Local     Integer I
Local     Integer STAT
Local     Char    LFILES(GDIMFIC)(1..)
Local     Char    FILELIST(GDIMFIC)(1..)
Local     Char    ORDRE(250)
Local     Char    PUERTO(10) : PUERTO = '61022'
Local     Char    LFILENAME(250)

  RESULT = -1

#Check if destination directory exists and creates it if not
  STAT = filinfo (LPATHDES,7)
  If STAT = -27 : End : Endif
  If STAT = -20 : Call SYSTEME (adxmac(0),'ae_mkdir'-'"'+LPATHDES+'"',"",STAT) From ORDSYS : Endif

#Delete files if they are present from a previous execution
  If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : End : Endif
  If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : End : Endif

  Sleep 10

#Check the files to upload
  ORDRE = "dir /b /a-d-s-h "+LPATH+"\"+LINDEX+".pdf"+" 2>nul"
  Call SYSTEME2 (adxmac(0),ORDRE,"",RESULT,LFILES) From ORDSYS

  If RESULT > 0
    For I = 1 To RESULT

      LFILENAME = LFILES(I)

#Create the command file to upload the files
      Openo filpath(LPATHDES,"FtpPut","bat",nomap)
      adxifs = ';'
      adxirs = chr$(13) + chr$(10)
      adxium = 50

      Wrseq 'C:\WinSCP\WinSCP.com /hostkey=* /command "option batch continue" "option confirm off" "open sftp://' + USER + ':' + PWD  + '@' + SERVER + ':' + PUERTO + '" "cd ' + FTPFOLDER +
&           '" "put ' + LPATH+'\'+LFILENAME + '" "exit" "/log=' + LPATHDES + '\PutLog.txt"'

      Openo

      System CHAINE = filpath(LPATHDES,"FtpPut","bat")

#Clean the script files
      If Delfile (filpath(LPATHDES,"FtpPut",'bat')) = -27 : RESULT = -2 : End : Endif
      If Delfile (filpath(LPATHDES,"PutLog",'txt')) = -27 : RESULT = -2 : End : Endif

#Move de uploaded files
      ORDRE = "MOVE "+LPATH+"\"+LFILENAME+".* "+LPATHDES
      Call SYSTEME2(adxmac(0),ORDRE,"",STAT,LFILENAME) From ORDSYS

    Next
  Endif

End
