Call ZFUNTKERR()
End

#####################################################################################
# Src: ZTSKERR
#-------------------------------------------------------------------------------------
# Proyecto: Sasmat - PDPaola
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# ZIMS - Motor de sincronización
# Fecha inicio ZIMS: 16/05/2022
# Desarrollador: JC
# Código de desarrollo: ZIMS
# Descripción del desarrollo: Gestión de errores de tareas
#######################################################################################

##############################################################
#**
#* función está diseńada para poder dar un tratamiento de errores diferenciado
#*
#*!
Subprog ZFUNTKERR()

Local Integer LOK   # 0=error ; 1=ok

  If !clalev([F:ZTM1]) Then : Local File ZTSKMGR  [F:ZTM1] : Endif
  If !clalev([F:ADI1]) Then : Local File ATABDIV  [F:ADI1] : Endif

  # realiza un pooling de tareas en estado ERROR ordenadas por Timestamp
  Filter [F:ZTM1] Where ZSTATUS = 'ER' Order By ZTIMESTAMP Asc
  # para cada tarea
  For [ZTM1]
    # se consulta el correspondiente código de error existente en el campo ZRESPID
    Filter [F:ADI1] Where NUMTAB = 6001 and CODE = num$([F:ZTM1]ZRESPID)
    Read   [F:ADI1] First
    # encontrarse se obtendrá la función a invocar
    If !fstat and [F:ADI1]A1 <> '' Then
      Local Char LPROGNAME(GLONADC) : LPROGNAME = [F:ADI1]A1
      # se invoca la función a ejecutar
      Call CONTROLE('',LOK) From =LPROGNAME           # cuando se definan las funciones de error, habrá que ańadir parámetros si se necesitan
      # si la ejecución ha sido correcta, se actualiza el estado a STOPPED
      If find(LOK,1) <> 0 Then
        [F:ZTM1]ZSTATUS   = 'ST'
        [F:ZTM1]ZRESPMSG  = 'Error tratado mediante la función'-LPROGRAME
        Trbegin [F:ZTM1]
        Rewrite [F:ZTM1]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    # si la función de error no está definida
    Else
      # se actualiza igualmente la tarea a STOPPED
      [F:ZTM1]ZSTATUS   = 'ST'
      [F:ZTM1]ZRESPMSG  = 'Error sin función. Aviso enviado por correo'
      Trbegin [F:ZTM1]
      Rewrite [F:ZTM1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      # y se invocará por defecto una función de error genérica ZFUNERRDEF
      Call ZFUNERRDEF([F:ZTM1]ZINDEX)
    Endif
  Next
  Close Local File [ZTM1],[ADI1]

End

##############################################################
#**
#* función que envia un mail informando del error a un usuario administrador mediante el sistema de workflows de Sage X3
#*
#*!
Subprog ZFUNERRDEF(PINDEX)
Value Char PINDEX

  Global Char GCORREO(250),GWFINDICE(250)
  GCORREO   = "it.babylon@pdpaola.com"
  GWFINDICE = PINDEX
  Call WORKFLOW (1,"ZES","",GUSER) From AWRK
  If dim(GCORREO)   > 0 Then : Kill GCORREO   : Endif
  If dim(GWFINDICE) > 0 Then : Kill GWFINDICE : Endif

End
