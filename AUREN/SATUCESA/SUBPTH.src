$AS_VATX
#------------------------------#
# Avant saisie des codes taxes #
#------------------------------#
If [M:PTH1]POHNUM(nolign-1)<>"" | [M:PTH1]LINTYP(nolign-1)=2
  mkstat=2
Endif
