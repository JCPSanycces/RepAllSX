  Call MAJ_CALTAX_LIG("PTH1",NOL) From TRTACHDIV1
Endif
Call MAJ_BASTAX_LIG(NOL,+1) From SUBPTHD : # Mŗj bases et mts taxe
Call MAJ_CUMULS_LIG(NOL,+1) From SUBPTHD : # Mŗj cumuls et ťlťments
SENS=+1 : Gosub MAJ_TOTWEI  From SUBPTH  : # Mŗj totaux poids brut et net
[M:PTH1]LINFLG(NOL)=1
Gosub BAPRES_NBLIG From SUBPTH
#----- Si composť affichage des composants -----#
If [M:PTH1]LINTYP(NOL)=2  Affzo [PTH1]10 : Endif
#-----
Return

