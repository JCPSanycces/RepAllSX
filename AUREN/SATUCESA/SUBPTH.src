Subprog B4_NBLIG
#---------------------------------------------------------------------#
# Ouverture du complťment lot par clic droit (1er bit de GOUVLOT ŗ 0) #
#---------------------------------------------------------------------#
GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complťment lot par clic droit (1er bit de GOUVLOT ŗ 0)
GOUVENT = 1     # permet de passer le test de l'ouverture de la fenetre complťment lot
End


