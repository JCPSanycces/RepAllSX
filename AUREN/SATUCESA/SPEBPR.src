######################################################################################
## AUREN 05.867.011 -> ASIGNAR MODELO IMPRESI”N MAIL SI SE ACTIVA FLAG 
######################################################################################
Subprog AM_ZENVFACPDF(VALEUR)
Variable Integer VALEUR

   If VALEUR = 2 
      [M:BPC1]TPMCOD='MAIL'
      Affzo [M:BPC1]TPMCOD
   Else 
      [M:BPC1]TPMCOD=''
      Affzo [M:BPC1]TPMCOD
   Endif

End
