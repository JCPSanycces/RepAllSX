# 06.390.286 - JC.12092022.Desarrollo especifico anticipos y provisiones a proveedores
########################################################################

$ACTION

#If GUSER="IMPAU" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  [M:ZPC0]ZTIPO     = 1
  [M:ZPC0]ZIMPORTE  = [F:PIV]ZRESPROVISIO
  GIMPPROVISION     = [F:PIV]ZRESPROVISIO
  Affzo [M:ZPC0]ZIMPORTE
  Affzo [M:ZPC0]ZTIPO
  Grizo [M:ZPC0]ZIMPORTE
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Anticipo' (pantalla ZANTVTA) 13/09/2022 11:33:59 (IMPAU)
######################################################################################
Subprog AM_ZTIPO(VALEUR)
Variable Integer VALEUR

  # total
  If VALEUR = 1 Then
    [M:ZPC0]ZIMPORTE  = [F:PIV]ZRESPROVISIO
    GIMPPROVISION     = [F:PIV]ZRESPROVISIO
    Affzo [M:ZPC0]ZIMPORTE
    Grizo [M:ZPC0]ZIMPORTE
  # parcial
  Else
    Actzo [M:ZPC0]ZIMPORTE
  Endif

End

######################################################################################
## Después de modificar el campo 'Importe' (pantalla ZANTVTA) 13/09/2022 11:39:09 (IMPAU)
######################################################################################
Subprog AM_ZIMPORTE(VALEUR)
Variable Decimal VALEUR
  If VALEUR > [F:PIV]ZRESPROVISIO Then
    mkstat = 2
    Call ERREUR("El importe no puede superar el restante de la provisión") From GESECRAN
    [M:ZPC0]ZIMPORTE  = [F:PIV]ZRESPROVISIO
    GIMPPROVISION     = [F:PIV]ZRESPROVISIO
    Affzo [M:ZPC0]ZIMPORTE
  Else
    GIMPPROVISION     = VALEUR
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
