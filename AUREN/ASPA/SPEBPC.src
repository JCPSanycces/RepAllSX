#<AdxTL>@(#)0.0.0.0 $Revision$ Clientes
#001. CAMBIOS
#006 JC.27072022.Adaptacion Especifico Seguridad
########################################################################

$ACTION

  Case ACTION
   When "SETBOUT"     : Gosub SETBOUT
   When "RAZCRE"      : Gosub RAZCRE
   When "RAZDUP"      : Gosub RAZDUP
   When "APRES_MODIF" : Gosub APRES_MODIF
  Endcase
Return
###############################################################################

$APRES_MODIF

#006.ini
##001>
#
#If ([F:ZAUS2]ZOFICINA = [M:BPC2]TSCCOD(0)) or (left$([F:ZAUS2]ZOFICINA,1)="0" and right$([F:ZAUS2]ZOFICINA,2)=right$([F:BPC]TSCCOD(0),2)) or [F:ZAUS2]ZEDIMASTER = 2 Then
#
##001<
#
#  Else
#     If GREP<>"C" Then
#        Call MESSAGE("El fichero no puede ser modificado pues fue creado por otra oficina") From GESECRAN
#        #001>
#        GCONSULT = 1
#        Enable GSTANEW
#     Endif
#     #001<
#  Endif

  # si el usuario tiene marcado el check 'Edici¾n maestros oficinas', permite modificar SIEMPRE...
  If [F:ZAUS2]ZEDIMASTER = 2 Then
  # ...sino
  Else
    If !clalev([F:ZFGR]) Then : Local File FACGROUP [F:ZFGR] Endif
    # busca si la familia estadĒstica pertenece al grupo de sociedades indicado en la ficha del usuario
    Read [F:ZFGR]FGR0 = [F:ZAUS2]ZCPY;[F:BPC]TSCCOD(0)
    # si existe, permite modificar
    If !fstat Then
    Else
      # comprueba si la oficina indicada en la ficha de usuario es la de la familia estadĒstica 1
      If [F:ZAUS2]ZOFICINA = [F:BPC]TSCCOD(0) Then
      Else
        If GREP<>"C" Then
          Call MESSAGE("El fichero no puede ser modificado pues fue creado por otra oficina") From GESECRAN
          GCONSULT = 1
          Enable GSTANEW
        Endif
      Endif
    Endif
    Close Local File [ZFGR]
  Endif

#006.fin
Return
###############################################################################
$SETBOUT
  If !clalev([F:ZAUS2]) : Local File AUTILIS  [F:ZAUS2] : Endif
  If !clalev([F:ZAUS3]) : Local File AUTILIS  [F:ZAUS3] : Endif

  Read [F:ZAUS2]CODUSR = GUSER
  Read [F:ZAUS3]CODUSR = [F:BPC]CREUSR

  #001>
#006.ini
#  If ([F:ZAUS2]ZOFICINA = [M:BPC2]TSCCOD(0)) or (left$([F:ZAUS2]ZOFICINA,1)="0" and right$([F:ZAUS2]ZOFICINA,2)=right$([M:BPC2]TSCCOD(0),2)) or [F:ZAUS2]ZEDIMASTER = 2 Then
#    GCONSULT = 0
#   #001<
#  Else
#    GCONSULT = 1
#    Enable GSTANEW
#  Endif
#006.fin

  If GREP="C" Then
   Disable GSTANEW
  Endif

  Diszo [M:BPC2]TSCCOD(0)
  Affzo [M:BPC2]TSCCOD(0)
Return
###############################################################################

$RAZCRE

  #Call ASIG_OFI(GUSER)
  #001>
  Disable GSTANEW
  #001<
Return
##############################################################################
$RAZDUP
  #Call ASIG_OFI(GUSER)
Return

##############################################################################
Subprog ASIG_OFI(P_USR)
  Value Char P_USR
  If !clalev([F:ZAUS1]) : Local File AUTILIS  [F:ZAUS1] : Endif

  Read [F:ZAUS1]CODUSR = P_USR
  If !fstat Then
    [M:BPC2]TSCCOD(0) = [F:ZAUS1]ZOFICINA
    Affzo [M:BPC2]TSCCOD(0)
  Endif
End
