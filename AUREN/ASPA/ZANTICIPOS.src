#<AdxTL>@(#)0.0.0.0 $Revision$ 
#ACTUALIZAR DATOS EN FACTURAS CON ANTICIPO
If !clalev([F:ZSID1]) : Local File SINVOICED   [F:ZSID1] : Endif
If !clalev([F:ZSIV1]) : Local File SINVOICEV   [F:ZSIV1] : Endif
Local Integer ZCONT:Raz ZCONT

For [F:ZSID1]SID0
 If [F:ZSID1]ITMREF = "000OT0001" Then
  Update [F:ZSIV1] Where NUM = [F:ZSID1]NUM With ZANTICIPO = 2
   zcont+=1
 Endif

Next
infbox num$(zcont)
End
