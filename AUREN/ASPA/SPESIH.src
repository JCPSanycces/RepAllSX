######################################################################################
## Control del botón 'Proy Financ SPE' (pantalla SIH4) 04/08/2021 12:57:52 (IMPAU)
######################################################################################
# JC.04082021.NEW
# copio la acción del campo estándar en el específico
Subprog C_ZCCE2(VALEUR)
Variable Char    VALEUR()
  Local    Integer AXE : AXE=2 : Gosub C_CCEX From SUBSIH
End

######################################################################################
# JC.04082021.NEW
# copio la acción del campo estándar en el específico
$SEL_ZSELCCE
Local Integer ERR , I , J , K , MAXLNK, NBRLNK, IND1, IND2

Local Char    DIEAZC(GLONDIE)   : # Axe de la sÃĐlection
Local Char    FCY(GLONFCY)      : # le site
Local Date    DAT               : # la date
Local Integer NOL               : # le numÃĐro de ligne dans le tableau
Local Char    LSTDIE(255)       : # Permet de dÃĐterminer les axes               Exemple : "[M]DIE#", # indique zone indicÃĐe
Local Char    LSTCCE(255)       : # Permet de dÃĐterminer les sections           Exemple : "[M]CCE#", # indique zone indicÃĐe
Local Char    LSTCOA(150)       : # Permet de dÃĐterminer les plans de compte    Exemple : "[M]COA#", # indique zone indicÃĐe
Local Char    LSTACC(150)       : # Permet de dÃĐterminer les comptes            Exemple : "[M]ACC#", # indique zone indicÃĐe

#Pour ne pas s'arrÃŠter au numÃĐro d'axe en cours. Besoin de toutes la liste la
#selection et le contrÃīle des sections budgets opÃĐrationnels (entitÃĐ et enveloppe)
Local Integer CAS_GDD : CAS_GDD=0

If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

#--------------------------------------------------------------------------------------------------
# RÃĐcupÃĐration des paramÃĻtres
#--------------------------------------------------------------------------------------------------

# JC.04082021.INICIO
#DIEAZC = PARAM(1)
#FCY    = PARAM(2)
#If PARAM(3)<>""
# DAT = gdat$(PARAM(3))
#Else
# DAT = [0/0/0]
#Endif
#NOL = val(PARAM(4))
#
#LSTDIE = PARAM(5)
#LSTCCE = PARAM(6)
#LSTCOA = PARAM(7)
#LSTACC = PARAM(8)
DIEAZC  = GDIE(2)           # DIE
FCY     = GFINRSP           # FCY
DAT     = [M:SIH0]INVDAT    # DAT
NOL     = nolign-1          # NOL
LSTDIE  = "GDIE(1"          # NAMDIE
LSTCCE  = "[M:SIH4]CCE#"    # NAMCCE
LSTCOA  = "GCOA(1"          # NAMCOA
LSTACC  = ""                # NAMACC
# JC.04082021.FIN

#--------------------------------------------------------------------------------------------------
## SpÃĐcifique budgets opÃĐrationnels : On passe directement Ã  l'action suite de SELCCE
#--------------------------------------------------------------------------------------------------
If func AFNC.ACTIV("GDD")
 Call LEC_DIE(PARAM(1)) From CPTLEC
 If [F:DIE]ENT=2 | [F:DIE]ENV=2
  OK=0 : Return
 Endif
Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenÃŠtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOCCE
For I=1 To NBSEL
 COL(I) = SELZON(I)
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
Endif
Next I
NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)-mess(36,103,1) : # Choix Sections analytiques
START  = "[F:CCE]CCE"
ORDRE  = "[F:CCE]DIE;[F:CCE]CCE"
OBJET  = ""


#--------------------------------------------------------------------------------------------------
## CritÃĻres pour la sÃĐlection standard
#--------------------------------------------------------------------------------------------------

## CritÃĻres de sÃĐlection
## Le link fait des liaisons "externes gauches"
## Toute la subtilitÃĐ de la chose est de mettre des fonctions qui
## ne sont pas transmises Ã  la base de donnÃĐes : len() , num$()
## sinon celle-ci ne renvoie rien du tout...sniff
CRITERE(1)   = "[F:CCE]ENAFLG=2"
CRITERE(1)  -= " & [F:CCE]DIE='"+[L]DIEAZC+"'"

If [L]FCY<>""
 CRITERE(1) -= '& ([F:CCE]FCY="" | [F:CCE]FCY="'+[L]FCY+'" | [F:FGR]CPY<>"")'
Endif

If DAT<>[0/0/0]
 CRITERE(1) -= '& ([F:CCE]VLYSTR=[0/0/0] | [F:CCE]VLYSTR<=['+format$(GFMD,DAT)+'])'
 CRITERE(1) -= '& ([F:CCE]VLYEND=[0/0/0] | [F:CCE]VLYEND>=['+format$(GFMD,DAT)+'])'
Endif

CRITERE(2) = '& (GUSRACS=2 | [F:CCE]ACS="" | num$([F:ACC]EXEC)="2")'

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(2) -= '& left$([F:CCE]CCE,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

#--------------------------------------------------------------------------------------------------
## CritÃĻres pour la sÃĐlection spÃĐcifique
#--------------------------------------------------------------------------------------------------
#
If GFONCTION="BUDGET"
 CRITERE(1) -= " & [F:CCE]BUDTRK=2"
Else
 CRITERE(1) -= " & [F:CCE]IPT=2"
Endif

#--------------------------------------------------------------------------------------------------
## Liste des comptes et plans de compte associÃĐs
## Evaluation des codes interdiction comptes/sections =>  Identifie le nombre de compte Ã  gÃĐrer
## Liste des sections et axes associÃĐs
## Evaluation des codes interdiction sections/sections =>  Identifie le nombre d'axes Ã  gÃĐrer
#
# Nb: sortie de cet ÃĐtiquette par JHA, car besoin d'acces depuis $SELCCE et subprog CTLCCE From TRTGDD
#--------------------------------------------------------------------------------------------------
#
Gosub EVAL_CAZ

#--------------------------------------------------------------------------------------------------
## Link du filtre
#--------------------------------------------------------------------------------------------------
#-- Nombre de liens Ã  faire selon la prÃĐsence des codes interdiction (comptes/sections + sections/sections)
NBRLNK = [L]NBAUZCPT+[L]NBAUZCCE
#-- Nombre maximum de link est 12... donc au niveau des codes interdictions,
#   le maxi qu'on peut linker [AUZ] avec [CCE] est 8
MAXLNK = 4

## Si liens avec les codes interdictions, il risque d'y avoir un problÃĻme de nombre de fichiers ouverts
If NBRLNK
 ERR = 0
 Onerrgo ERROUV
 For I=1 To min(MAXLNK,NBRLNK)
  Case I
   When 1 : Local File CAAUZ [CA1] : Columns [CA1] (TYP,AUZ1,AUZ2)
   When 2 : Local File CAAUZ [CA2] : Columns [CA2] (TYP,AUZ1,AUZ2)
   When 3 : Local File CAAUZ [CA3] : Columns [CA3] (TYP,AUZ1,AUZ2)
   When 4 : Local File CAAUZ [CA4] : Columns [CA4] (TYP,AUZ1,AUZ2)
   When 5 : Local File CAAUZ [CA5] : Columns [CA5] (TYP,AUZ1,AUZ2)
   When 6 : Local File CAAUZ [CA6] : Columns [CA6] (TYP,AUZ1,AUZ2)
   When 7 : Local File CAAUZ [CA7] : Columns [CA7] (TYP,AUZ1,AUZ2)
   When 8 : Local File CAAUZ [CA8] : Columns [CA8] (TYP,AUZ1,AUZ2)
  Endcase
 Next I
 Onerrgo
 If ERR
  # Si problÃĻme, on se dÃĐroute sur le select standard
  OBJET = "CCE"
  Return
 Endif
Endif

## A ce stade, l'option est de privilÃĐgier les codes intersections comptes/sections puis sections/sections.
Local Integer NBRAUZ
Local Char    TOTAUZ(5)(1..MAXLNK)
Local Integer TYPAUZ(1..MAXLNK)

NBRAUZ = 0
For I=1 To [L]NBAUZCPT
 If NBRAUZ<MAXLNK
  NBRAUZ += 1
  CRITERE(3) -= '& string$(1,[F:CA'+num$(NBRAUZ)+']AUZ1)=""'
  TYPAUZ(NBRAUZ) = 2
  TOTAUZ(NBRAUZ) = [L]AUZCPT(I-1)
 Endif
Next I
For I=1 To [L]NBAUZCCE
 If NBRAUZ<MAXLNK
  NBRAUZ += 1
  CRITERE(3) -= '& string$(1,[F:CA'+num$(NBRAUZ)+']AUZ1)=""'
  TYPAUZ(NBRAUZ) = 1
  TOTAUZ(NBRAUZ) = [L]AUZCCE(I-1)
 Endif
Next I

# JC.04082021.INICIO
# 06.350.465.Quito el filtro del cliente porque Carlos y Xavier me lo han pedido en el correo con asunto 'Auren X3 - Cambio en pantalla de Facturas de Venta'
#CRITERE(4) = ' & [F:CCE]ZCLIENTE = "'+[M:SIH0]BPCINV+'"'
# JC.04082021.FIN

Case NBRAUZ
 When 0
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&  As [LNC]

 When 1
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&  As [LNC]

 When 2
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&  As [LNC]

 When 3
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&  As [LNC]


 When 4
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&  As [LNC]

 When 5
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&  As [LNC]

 When 6
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&  As [LNC]

 When 7
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&               , [CA7]CAZ0     = [L]TYPAUZ(7);TOTAUZ(7);[F:CCE]AUZ
&  As [LNC]

 When 8
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&               , [CA7]CAZ0     = [L]TYPAUZ(7);TOTAUZ(7);[F:CCE]AUZ
&               , [CA8]CAZ0     = [L]TYPAUZ(8);TOTAUZ(8);[F:CCE]AUZ
&  As [LNC]


Endcase

Default File [LNC]
DEFPAG = 1
Return


$EVAL_CAZ
#--------------------------------------------------------------------------------------------------
# Liste des comptes, plans, sections, axes et ÃĐvaluations des codes interdictions impliquÃĐs
# NB: dÃĐportÃĐ de $SELCCE pour ÃŠtre utilisable dans l'action SELCCEGDD (JHA-04/02/09)
#--------------------------------------------------------------------------------------------------

## Evaluation des codes interdiction comptes/sections =>  Identifie le nombre de compte Ã  gÃĐrer
##################################################################################################################
Local Char ACC(GLONGAC)(0..9), COA(GLONCOA)(0..9)
Local Integer NBCPT
Raz [L]COA, ACC

If instr(1,[L]LSTACC,";")
 #----------------------------------------------------------------------------------------------------
 # CAS 1 : le [L]LSTACC contient une liste de compte sÃĐparÃĐe par des ";"
 #       & le [L]LSTCOA contient les plans de compte associÃĐ au compte (idem sÃĐparÃĐe par des ";")
 #----------------------------------------------------------------------------------------------------
 While [L]LSTACC<>""
  J = instr(1,[L]LSTCOA,";")
  I = instr(1,[L]LSTACC,";")
  If I
   [L]COA([L]NBCPT) = left$([L]LSTCOA,J-1) : [L]LSTCOA = vireblc(right$([L]LSTCOA,J+1),2)
   [L]ACC([L]NBCPT) = left$([L]LSTACC,I-1) : [L]LSTACC = vireblc(right$([L]LSTACC,I+1),2)
  Else
   [L]COA([L]NBCPT) = [L]LSTCOA : [L]LSTCOA = ""
   [L]ACC([L]NBCPT) = [L]LSTACC : [L]LSTACC = ""
  Endif
 [L]NBCPT += 1
 Wend
Elsif instr(1,[L]LSTACC,"#")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 2 : le [L]LSTACC contient par exemple [M]ACC# ce qui entraine la lecture de [M]ACC1, [M]ACC2... [M]ACC10
 #       & le [L]LSTCOA est soit sur le mÃŠme principe
 #                          soit la liste de plan de compte sÃĐparÃĐe par des ";"
 #                          soit une variable dimentionnÃĐe par exemple [M]COA(x  (oÃđ x indique le dÃĐbut de lecture 0 ou1)
 #------------------------------------------------------------------------------------------------------------
 Raz ACC
 K = instr(1,[L]LSTACC,"#")
 For I=0 To 9
  Onerrgo ERROUV
  ERR = 0
  [L]ACC(I) = evalue(left$([L]LSTACC,K-1)+num$(I+1)+"("+num$(NOL)+")")
  Onerrgo
  If ERR : Break : Endif
 Next
 Raz COA
 K = instr(1,[L]LSTCOA,"#")
 If K
  For I=0 To 9
   Onerrgo ERROUV
   ERR = 0
   [L]COA(I) = evalue(left$([L]LSTCOA,K-1)+num$(I+1)+"("+num$(NOL)+")")
   If [L]COA(I)="" : [L]NBCPT=I : Break : Endif
   Onerrgo
   If ERR : Break : Endif
  Next
 Elsif instr(1,[L]LSTCOA,";")
  While [L]LSTCOA<>""
   J = instr(1,[L]LSTCOA,";")
   If J
    [L]COA([L]NBCPT) = left$([L]LSTCOA,J-1) : [L]LSTCOA = vireblc(right$([L]LSTCOA,J+1),2)
   Else
    [L]COA([L]NBCPT) = [L]LSTCOA : [L]LSTCOA = ""
   Endif
   [L]NBCPT += 1
  Wend
 Elsif instr(1,[L]LSTCOA,"(")
  K = instr(1,[L]LSTCOA,"(")
  IND1 = val(mid$([L]LSTCOA,K+1,1))
  [L]LSTCOA = left$([L]LSTCOA,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]COA([L]NBCPT) = evalue([L]LSTCOA+"("+num$(I)+")")
   #JHA :091209
   #Je commente la ligne suivante certainement ajoutÃĐe en crÃĐation pour optimiser le traitement
   # or pour les engagements multi-rÃĐfÃĐrentiel, il est nÃĐcessaire de continuer le parcours
   #If  [L]COA([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
 Endif
Elsif instr(1,[L]LSTACC,"(")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 3 : le [L]LSTACC contient une parenthÃĻse... par exemple [M]ACC(x ce qui entraine la lecture de [M]ACC(0), [M]ACC(1)... x indique le dÃĐbut de lecture.
 #       & le [L]LSTCOA est sur le mÃŠme principe
 #------------------------------------------------------------------------------------------------------------
  K = instr(1,[L]LSTACC,"(")
  IND1 = val(mid$([L]LSTACC,K+1,1))
  [L]LSTACC = left$([L]LSTACC,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]ACC(NBCPT) = evalue([L]LSTACC+"("+num$(I)+")")
   If  [L]ACC([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
  Raz NBCPT
  K = instr(1,[L]LSTCOA,"(")
  IND1 = val(mid$([L]LSTCOA,K+1,1))
  [L]LSTCOA = left$([L]LSTCOA,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]COA(NBCPT) = evalue([L]LSTCOA+"("+num$(I)+")")
   If  [L]COA([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
Elsif [L]LSTACC<>""
 #------------------------------------------------------------------------------------------------------------------
 # CAS 4 : le [L]LSTACC contient une seul compte
 #       & le [L]LSTCOA contient le plan de compte liÃĐ au compte
 #------------------------------------------------------------------------------------------------------------
 [L]NBCPT = 1
 [L]ACC = [L]LSTACC
 [L]COA = [L]LSTCOA
Endif

# Compte renseignÃĐ, lecture des codes interdictions.
Local Char COAAUZ(GLONCOA)(0..9), CPTAUZ(GLONGAC)(0..9),  AUZCPT(5)(0..9)
Local Integer NBAUZCPT
Raz COAAUZ,CPTAUZ,AUZCPT,NBAUZCPT
For I=0 To [L]NBCPT-1
 If [L]COA(I)<>"" & [L]ACC(I)<>""
  Read [GAC]GAC0 = [L]COA(I);[L]ACC(I)
  If !fstat
   [L]COAAUZ([L]NBAUZCPT) = [F:GAC]COA
   [L]CPTAUZ([L]NBAUZCPT) = [F:GAC]ACC
   [L]AUZCPT([L]NBAUZCPT) = [F:GAC]AUZ
   [L]NBAUZCPT+=1
  Endif
 Endif
Next

## Evaluation des codes interdiction sections/sections =>  Identifie le nombre d'axes Ã  gÃĐrer
##################################################################################################################
Local Char CCE(GLONCCE)(0..19), DIE(GLONDIE)(0..19)
Local Integer NBCCE
Raz [L]CCE, DIE

If instr(1,[L]LSTCCE,";")
 #----------------------------------------------------------------------------------------------------
 # CAS 1 : le [L]LSTCCE contient une liste de sections sÃĐparÃĐe par des ";"
 #       & le [L]LSTDIE contient les axes associÃĐ aux sections (idem sÃĐparÃĐe par des ";")
 #----------------------------------------------------------------------------------------------------
 While [L]LSTCCE<>""
  J = instr(1,[L]LSTCCE,";")
  I = instr(1,[L]LSTDIE,";")
  If I
   [L]CCE([L]NBCCE) = left$([L]LSTCCE,J-1) : [L]LSTCCE = vireblc(right$([L]LSTCCE,J+1),2)
   [L]DIE([L]NBCCE) = left$([L]LSTDIE,I-1) : [L]LSTDIE = vireblc(right$([L]LSTDIE,I+1),2)
  Else
   [L]DIE([L]NBCCE) = [L]LSTDIE : [L]LSTDIE = ""
   [L]CCE([L]NBCCE) = [L]LSTCCE : [L]LSTCCE = ""
  Endif
 [L]NBCCE += 1
 Wend
Elsif instr(1,[L]LSTCCE,"#")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 2 : le [L]LSTCCE contient par exemple [M]CCE# ce qui entraine la lecture de [M]CCE1, [M]CCE2... [M]CCE10
 #       & le [L]LSTDIE est soit sur le mÃŠme principe
 #                          soit la liste des axes sÃĐparÃĐe par des ";"
 #                          soit une variable dimentionnÃĐe par exemple [M]DIE(x  (oÃđ x indique le dÃĐbut de lecture 0 ou1)
 #------------------------------------------------------------------------------------------------------------
 Raz CCE
 K = instr(1,[L]LSTCCE,"#")
 For I=0 To 19
  Onerrgo ERROUV
  ERR = 0
  [L]CCE(I) = evalue(left$([L]LSTCCE,K-1)+num$(I+1)+"("+num$(NOL)+")")
  Onerrgo
  If ERR : Break : Endif
 Next

 Raz DIE
 K = instr(1,[L]LSTDIE,"#")
 If K
  For I=0 To 19
   Onerrgo ERROUV
   ERR = 0
   [L]DIE(I) = evalue(left$([L]LSTDIE,K-1)+num$(I+1)+"("+num$(NOL)+")")
   If  [L]DIE(I)=""        : [L]NBCCE = I   : Break : Endif
   If  [L]DIE(I)=[L]DIEAZC & !CAS_GDD : [L]NBCCE = I+1 : Break : Endif
   Onerrgo
   If ERR : Break : Endif
  Next
 Elsif instr(1,[L]LSTDIE,";")
  While [L]LSTDIE<>""
   J = instr(1,[L]LSTDIE,";")
   If J
    [L]DIE([L]NBCCE) = left$([L]LSTDIE,J-1) : [L]LSTDIE = vireblc(right$([L]LSTDIE,J+1),2)
   Else
    [L]DIE([L]NBCCE) = [L]LSTDIE : [L]LSTDIE = ""
   Endif
  If [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
  [L]NBCCE += 1
  Wend
 Elsif instr(1,[L]LSTDIE,"(")
  K = instr(1,[L]LSTDIE,"(")
  IND1 = val(mid$([L]LSTDIE,K+1,1))
  [L]LSTDIE = left$([L]LSTDIE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 :Endif
  If IND1=1 : IND2=20 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]DIE([L]NBCCE) = evalue([L]LSTDIE+"("+num$(I)+")")
   If  [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
   [L]NBCCE+=1
   Onerrgo
   If ERR : Break : Endif
  Next
 Endif
Elsif instr(1,[L]LSTCCE,"(")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 3 : le [L]LSTCCE contient une parenthÃĻse... par exemple [M]CCE(x ce qui entraine la lecture de [M]CCE(0), [M]CCE(1)... x indique le dÃĐbut de lecture.
 #       & le [L]LSTDIE est soit sur le mÃŠme principe
 #------------------------------------------------------------------------------------------------------------------
  K = instr(1,[L]LSTCCE,"(")
  IND1 = val(mid$([L]LSTCCE,K+1,1))
  [L]LSTCCE = left$([L]LSTCCE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 : Endif
  If IND1=1 : IND2=20 : Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]CCE(I) = evalue([L]LSTCCE+"("+num$(I)+")")
   Onerrgo
   If ERR : Break : Endif
  Next
  K = instr(1,[L]LSTDIE,"(")
  IND1 = val(mid$([L]LSTDIE,K+1,1))
  [L]LSTDIE = left$([L]LSTDIE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 : Endif
  If IND1=1 : IND2=20 : Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]DIE([L]NBCCE) = evalue([L]LSTDIE+"("+num$(I)+")")
   If  [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
   [L]NBCCE+=1
   Onerrgo
   If ERR : Break : Endif
  Next
Elsif [L]LSTCCE<>""
 #------------------------------------------------------------------------------------------------------------------
 # CAS 4 : le [L]LSTCCE contient une seule section
 #       & le [L]LSTDIE contient l'axe
 #------------------------------------------------------------------------------------------------------------
 [L]NBCCE = 1
 [L]CCE = [L]LSTCCE
 [L]DIE = [L]LSTDIE
Endif

# Sections renseignÃĐs, lecture des codes interdictions.
Local Char DIEAUZ(GLONDIE)(0..19), CCEAUZ(GLONCCE)(0..19), AUZCCE(GLONADI)(0..19)
Local Integer NBAUZCCE

Raz DIEAUZ, CCEAUZ, AUZCCE, NBAUZCCE
For I=0 To [L]NBCCE-1
 If [L]DIE(I)<>"" & [L]CCE(I)<>""
  Read [CCE]CCE0 = [L]DIE(I);[L]CCE(I)
  If !fstat
   [L]DIEAUZ([L]NBAUZCCE) = [F:CCE]DIE
   [L]CCEAUZ([L]NBAUZCCE) = [F:CCE]CCE
   [L]AUZCCE([L]NBAUZCCE) = [F:CCE]AUZ
   [L]NBAUZCCE+=1
  Endif
 Endif
Next
Return

$ERROUV
ERR = errn
Resume

######################################################################################
$VERF_ZSELCCE
  [M:SIH4]CCE2(nolign-1) = [F:CCE]CCE
  Affzo [M:SIH4]CCE2(nolign-1)
Return

######################################################################################
#005 ZCCC
$SEL_ZSELCCC
  If !clalev([F:ZBID]) Then : Local File BID  [F:ZBID] : Endif
  Default File [F:ZBID]
  Filter [F:ZBID] Where BPANUM = [M:SIH0]SALFCY and BPATYP = 3

  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección cuenta IBAN"                                         # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Prefijo IBAN"                                                  # título de la primera columna
  COL(NBCOL)  = "IBAN"                                                          # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Nš cuenta bancaria"                                            # título de la segunda columna
  COL(NBCOL)  = "BIDNUM"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "BIC"                                                           # título de la tercera columna
  COL(NBCOL)  = "BICCOD"                                                        # nombre del campo a mostrar en la primera columna

Return

######################################################################################
#005 ZCCC
$VERF_ZSELCCC
  [M:SIH2]ZCCCREG = [F:ZBID]IBAN + [F:ZBID]BIDNUM
  Affzo [M:SIH2]ZCCCREG
Return

######################################################################################
## Antes de campo 'Cuenta CCC Factura' (pantalla SIH2) 27/07/2022 09:54:00 (IMPAU)
######################################################################################
#005 ZCCC
Subprog AV_ZCCC(VALEUR)
Variable Char    VALEUR()
  If left$([M:SIH2]PTE,4) = 'TRFR' Then
    Actzo [M:SIH2]ZCCC
  Else
    VALEUR = ''
    Diszo [M:SIH2]ZCCC
  Endif

  If [M:SIH1]INVSTA = 3 Then
    Diszo [M:SIH2]ZCCC
  Else
    Actzo [M:SIH2]ZCCC
  Endif
End

######################################################################################
## Después del campo 'Cuenta CCC Factura' (pantalla SIH2) 27/07/2022 10:16:30 (IMPAU)
######################################################################################
#005 ZCCC
Subprog AP_ZCCC(VALEUR)
Variable Char    VALEUR()
  VALEUR = [M:SIH2]ZCCCREG
End
