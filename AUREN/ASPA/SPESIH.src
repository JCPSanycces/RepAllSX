# JC.30122021.Contabiliza con el proyecto indicado si no se selecciona desde la lupa (se escribe o se copia en el campo)
Subprog AM_ZCCE2(VALEUR)
Variable Char    VALEUR()
  [M:SIH4]CCE2(nolign-1) = VALEUR
  Affzo [M:SIH4]CCE2(nolign-1)
End

#########################################################################
Subprog ZCRE_CLOB(CODETEX,ZIDTEX,P_TEXT)
  Value    Char    CODETEX
  Variable Char ZIDTEX#, P_TEXT
  Variable Clbfile P_TEXT
  If !clalev([F:ZTXC1]) : Local File TEXCLOB [F:ZTXC1] : Endif
  If !clalev([F:ZTXC2]) : Local File TEXCLOB [F:ZTXC2] : Endif
  Local Integer STAT
  Local Char ZCODE(30)

  Delete [F:ZTXC2] Where CODE = ZIDTEX
  [F:ZTXC1]CODE   = ZIDTEX
  [F:ZTXC1]TEXTE  = P_TEXT
  [F:ZTXC1]IDENT1 = ""
  [F:ZTXC1]IDENT2 = ""
  [F:ZTXC1]IDENT3 = [F:ZTXC1]CODE
  [F:ZTXC1]CREUSR = GUSER
  [F:ZTXC1]CREDAT = date$
  [F:ZTXC1]CRETIM = time
  Write [ZTXC1]
  Call VIRE_CLOB(CODETEX,STAT) From ACLOB
End
####################################################################
#Devuelve fecha próxima de facturación anterior a la facturación
###################################################################
Funprog OLDDATE(P_CONNUM)
  Value Char P_CONNUM
  Local Date ZDATE    : Raz ZDATE

  If !clalev([F:ZCON2]) : Local File CONTSERV   [F:ZCON2] : Endif

  Read [F:ZCON2]CON0 = P_CONNUM

  If !fstat and [F:ZCON2]NEXINVDAT<> [0/0/0] Then
    #Prefacturación
    If [F:ZCON2]INVMET = 1 Then
      Case [F:ZCON2]INVFRYBAS
        When 2 : ZDATE = [F:ZCON2]NEXINVDAT - ([F:ZCON2]INVFRY)
        When 3 : ZDATE = [F:ZCON2]NEXINVDAT - ([F:ZCON2]INVFRY)
        When 4 : ZDATE = addmonth([F:ZCON2]NEXINVDAT,-([F:ZCON2]INVFRY))
        When 5 : ZDATE = gdat$(day([F:ZCON2]NEXINVDAT),month([F:ZCON2]NEXINVDAT),year([F:ZCON2]NEXINVDAT)-[F:ZCON2]INVFRY)
      Endcase
    Endif
    #Postfacturación
    If [F:ZCON2]INVMET = 2 Then
      Case [F:ZCON2]INVFRYBAS
        When 2 : ZDATE = [F:ZCON2]NEXINVDAT - [F:ZCON2]INVFRY
        When 3 : ZDATE = [F:ZCON2]NEXINVDAT - ([F:ZCON2]INVFRY*7)
        When 4 : ZDATE = addmonth([F:ZCON2]NEXINVDAT,-([F:ZCON2]INVFRY+1))
        When 5 : ZDATE = gdat$(day([F:ZCON2]NEXINVDAT),month([F:ZCON2]NEXINVDAT),year([F:ZCON2]NEXINVDAT)-[F:ZCON2]INVFRY)
      Endcase
    Endif

  Endif

End ZDATE
######################################################################################
## Etiqueta aņadida por el supervisor (pantalla SIH2) 08/04/2021 10:37:37 (DEVAU)
######################################################################################
Subprog C_NBLIG

  #001>
  If !clalev([F:ZSIH4]) : Local File SINVOICE    [F:ZSIH4] : Endif
  If !clalev([F:ZSIV4]) : Local File SINVOICEV   [F:ZSIV4] : Endif
  If !clalev([F:ZPID1]) : Local File PINVOICED   [F:ZPID1] : Endif
  Local Integer I

  #Borrar
#  If [F:SIV]INVSTA < 3 Then
  If [M:SIH1]INVSTA < 3 Then
    If status = 65 Then
       Read  [F:ZSIH4]SIH0 =  [M:SIH2]ZDOC(nolign-1)
       Read  [F:ZSIV4]SIV0 =  [M:SIH2]ZDOC(nolign-1)
       If !fstat Then
# 06.390.285.ini (INCIDENCIA - II)
#          If  [F:ZSIV4]ZANTICIPO = 2 Then
#            [M:SIH2]INVDTAAMT(0)- = [F:ZSIH4]BASTAX
#          Else
#            [M:SIH2]INVDTAAMT(1)- = [F:ZSIH4]AMTNOT
#          Endif
#          Affzo [M:SIH2]INVDTAAMT(0)
#          Affzo [M:SIH2]INVDTAAMT(1)
          If  [F:ZSIV4]ZANTICIPO = 2 Then
            Update [F:ZSIV4] Where NUM = [M:SIH2]ZDOC(nolign-1) With ZRESANTICIPO += [M:SIH2]ZIMPORTE(nolign-1)
            [M:SIH2]INVDTAAMT(0) -= [M:SIH2]ZIMPORTE(nolign-1)
            Affzo [M:SIH2]INVDTAAMT(0)
            Local Integer TMPLIN: TMPLIN = nolign
            nolign = 1
            Call AM_INVDTAAMT([M:SIH2]INVDTAAMT(0)) From SUBSIH
            Update [F:ZSIV4] Where NUM = [M:SIH2]ZDOC(nolign-1) With ZSALDADO      = 1
            GZBORRADOC=1
          Else
            Update [F:ZSIV4] Where NUM = [M:SIH2]ZDOC(nolign-1) With ZRESPROVISIO += [M:SIH2]ZIMPORTE(nolign-1)
            [M:SIH2]INVDTAAMT(1) -= [M:SIH2]ZIMPORTE(nolign-1)
            Affzo [M:SIH2]INVDTAAMT(1)
            Local Integer TMPLIN: TMPLIN = nolign
            nolign = 2
            Call AM_INVDTAAMT([M:SIH2]INVDTAAMT(1)) From SUBSIH
            nolign = TMPLIN
            Update [F:ZSIV4] Where NUM = [M:SIH2]ZDOC(nolign-1) With ZSALDADO      = 1
            GZBORRADOC=1
          Endif
          If !clalev([F:ZAPS2]) Then : Local File ZANTPROSIH [F:ZAPS2] : Endif
          Delete [F:ZAPS2] Where ZTIPODOC = 'SIH' and ZANTPRO = [M:SIH2]ZDOC(nolign-1) and ZSIH = [M:SIH0]NUM
       Endif
# 06.390.285.ini (INCIDENCIA - II)
    Endif
  Else
#Infbox [F:SIV]NUM
    Call MESSAGE("Factura validada") From GESECRAN
    mkstat = 2
    End
  Endif
  #001<


End

