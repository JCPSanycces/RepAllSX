#<AdxTL>@(#)0.0.0.0 $Revision$ Facturas
#001 08/04/21 Lista izquierda provisinoes y anticipos
#002 30/04/21 Refacturación clientes
#003 - JC.21022022.Incidencia especifico proyectos analiticos en facturación cuotas
#004 ZSUPL - JC.21022022.Implementación suplidos clientes
# 06.337.504 - JC.04052022.Línea "vacía" en los abonos de venta
# 06.350.465 - JC.31052022.Campo 'Proy Financ' en blanco cuando se crea la factura de venta manualmente
#005 ZCCC - JC.27072022.Especifico ccc variable en formato factura de venta
##06.379.971 AMG.08082022 Auren X3 - Bug en específico de refacturación de gastos
# 06.390.285 - JC.12092022.Mejoras especifico anticipos y provisiones de clientes
########################################################################

$ACTION
#Infbox ACTION

  Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "LIENS"         : Gosub LIENS
    When "APRES_CRE"     : Gosub APRES_CRE
    When "APRES_MOD"     : Gosub APRES_MOD
    When "RAZCRE"        : Gosub RAZCRE
    When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
    When "FILGAUCHE"     : Gosub FILGAUCHE
    When "FERME"         : Gosub FERME
    When "PICKE"         : Gosub PICKE
    When "DEPICK"        : Gosub DEPICK
    When "APRES_MODIF"   : Gosub APRES_MODIF
    When "SEL_TABLE"     : Gosub SEL_TABLE
    When "VERF_TABLE"    : Gosub VERF_TABLE
    When "VERIF_CRE"     : Gosub VERIF_CRE
    When "VERIF_MOD"     : Gosub VERIF_MOD
    When "FIN"           : Gosub FIN
  Endcase
Return

######################################################################################
$OUVRE
# 06.390.285.ini (INCIDENCIA - II)
  Global Integer GZBORRADOC
# 06.390.285.fin (INCIDENCIA - II)
Return

######################################################################################
$FIN
#  If dim(GIMPPROVISION) > 0 Then : Kill GIMPPROVISION : Endif
#  If dim(GIMPANTICIPO)  > 0 Then : Kill GIMPANTICIPO  : Endif
#  If dim(GZBORRADOC)    > 0 Then : Kill GZBORRADOC    : Endif
Return

######################################################################################
$RAZCRE
#  [M:SIH0]SIVTYP ='FVN'
#  Affzo [M:SIH0]SIVTYP
Return
#001>

######################################################################################

$FERME
 If dim(ZLISTPROV)>0
  Kill ZLISTPROV
 Endif
 If dim(ZLISTANT)>0
  Kill ZLISTANT
 Endif
 #002>
 If dim(ZLISTREFACT)>0
  Kill ZLISTREFACT
 Endif
 #002<
#004 ZSUPL.ini
 If dim(ZLISTSUPLIDO)>0 : Kill ZLISTSUPLIDO : Endif
#004 ZSUPL.fin
Return
######################################################################################

$OUVRE_BOITE
  #002>
  Global Char ZLISTPROV(10),ZLISTANT(10),ZLISTREFACT(10)
  #002<
  ZLISTPROV = "GAU_CHE"+num$(find("ZSIH1",OBJLIS(1..9)))
  ZLISTANT  = "GAU_CHE"+num$(find("ZSIH2",OBJLIS(1..9)))
  #002>
  ZLISTREFACT  = "GAU_CHE"+num$(find("ZPI1",OBJLIS(1..9)))
  #002<
#004 ZSUPL.ini
  Global Char ZLISTSUPLIDO(10)
  ZLISTSUPLIDO = "GAU_CHE"+num$(find("ZPI2",OBJLIS(1..9)))
#004 ZSUPL.fin
Return
######################################################################################

$FILGAUCHE
  #No contabilizadas
  If [F:SIV]INVSTA < 3 Then
      If currbox = ZLISTPROV Then
        Local Integer IROW : IROW = 1
        Local Integer FIRSTROW : FIRSTROW =0
        FILGAUSUP(0)= "[F:SIV]SIVTYP='PRV'&[F:SIV]ZSALDADO<>2&[F:SIV]INVSTA=3&[F:SIV]NUM<>'"+[M:SIH0]NUM+"'&[F:SIV]SALFCY='"+[M:SIH0]SALFCY+"'&[F:SIV]BPCINV='"+[M:SIH0]BPCINV+"'"
        Local Char WKFILROLE(250)
        Call FILROLE("ZSIH1",WKFILROLE) From SUBARL
        If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
      Endif

      If currbox = ZLISTANT Then
        Local Integer IROW : IROW = 1
        Local Integer FIRSTROW : FIRSTROW =0
        FILGAUSUP(0)+="[F:SIV]ZANTICIPO=2&[F:SIV]ZSALDADO<>2&[F:SIV]INVSTA=3&[F:SIV]NUM<>'"+[M:SIH0]NUM+"'&[F:SIV]SALFCY='"+[M:SIH0]SALFCY+"'&[F:SIV]BPCINV='"+[M:SIH0]BPCINV+"'"
        Local Char WKFILROLE(250)
        Call FILROLE("ZSIH2",WKFILROLE) From SUBARL
        If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
      Endif
  Else
    FILGAUSUP(0)+="1=2"
  Endif

  #002>
  #Refacturación
    #AMG.STR FILTRO No contabilizadas [F:SIV]INVSTA < 3 20-07-2021
 If [F:SIV]INVSTA < 3 Then
   If currbox = ZLISTREFACT Then
      Local Integer IROW : IROW = 1
      Local Integer FIRSTROW : FIRSTROW =0
      Raz FILGAUSUP(0)
      FILGAUSUP(0)+="[F:PID]ITMREF='000OT0004'&[F:PID]ZSALDADO<>2&[F:PIH]STA=3&[F:PID]FCYLIN='"+[M:SIH0]SALFCY+"'&[F:PID]ZBPCNUM='"+[M:SIH0]BPCINV+"'"
      Local Char WKFILROLE(250)
      Call FILROLE("ZPI1",WKFILROLE) From SUBARL
      If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
   Endif
 Endif #AMG.END
  #002<

#004 ZSUPL.ini
  #Suplidos
  If [F:SIV]INVSTA < 3 Then
    If currbox = ZLISTSUPLIDO Then
      Local Integer IROW : IROW = 1
      Local Integer FIRSTROW : FIRSTROW =0
      Raz FILGAUSUP(0)
      FILGAUSUP(0)+="[F:PID]ITMREF='000OT0057'&[F:PID]ZSALDADO<>2&[F:PIH]STA=3&[F:PID]FCYLIN='"+[M:SIH0]SALFCY+"'&[F:PID]ZBPCNUM='"+[M:SIH0]BPCINV+"'"
      Local Char WKFILROLE(250)
      Call FILROLE("ZPI2",WKFILROLE) From SUBARL
      If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
    Endif
  Endif
#004 ZSUPL.fin
Return

######################################################################################
$LIENS

 If !clalev([F:ZSIV3]) : Local File SINVOICEV   [F:ZSIV3] : Endif
 Local Integer I :Raz I

# 06.390.285.ini (INCIDENCIA - II)
  Local Decimal LTOTANTICIPO,LTOTPROVISION
  If !clalev([F:ZAPS1]) Then : Local File ZANTPROSIH [F:ZAPS1] : Endif
  Filter [F:ZAPS1] Where ZSIH = [M:SIH0]NUM
  For [ZAPS1]
    Read [F:ZSIV3]SIV0 = [F:ZAPS1]ZANTPRO
    If !fstat Then
      If [F:ZSIV3]ZANTICIPO = 2 Then
        [M:SIH2]ZTIPO(I)  = "Anticipo"
        LTOTANTICIPO      += [F:ZAPS1]ZIMPORTE
      Else
        [M:SIH2]ZTIPO(I)  = "Provision"
        LTOTPROVISION     += [F:ZAPS1]ZIMPORTE
      Endif
      [M:SIH2]ZDOC(I)     = [F:ZAPS1]ZANTPRO
      [M:SIH2]ZIMPORTE(I) = [F:ZAPS1]ZIMPORTE
      [M:SIH2]ZID(I)      = [F:ZAPS1]ZID
      I+=1
    Endif
  Next
  Filter [F:ZAPS1]
  Close Local File [ZAPS1]
# 06.390.285.fin (INCIDENCIA - II)

 [M:SIH2]NBLIG = I
 Affzo [M:SIH2]

# 06.390.285.ini (INCIDENCIA - II)
  [M:SIH2]INVDTAAMT(0) = LTOTANTICIPO
  [M:SIH2]INVDTAAMT(1) = LTOTPROVISION
  Affzo [M:SIH2]INVDTAAMT(0)
  Affzo [M:SIH2]INVDTAAMT(1)
# 06.390.285.fin (INCIDENCIA - II)

Return
######################################################################################
 $PICKE
  #002>
  If !clalev([F:ZITM3]) : Local File ITMMASTER   [F:ZITM3] : Endif
  If !clalev([F:ZTVC3]) : Local File TABVAC      [F:ZTVC3] : Endif
  #002<
  If !clalev([F:ZCAL3]) : Local File CPTANALIN   [F:ZCAL3] : Endif        # proy financ. Mejora refacturación.new
  Local Integer I,J,ZFLG:ZFLG = 1
  If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
    Return
   Endif
  Endif

# 06.390.285.ini (INCIDENCIA - II)
#  For J=0 To [M:SIH2]NBLIG - 1
#    If [M:SIH2]ZDOC(J) = [F:SIV]NUM Then
#      ZFLG = 0
#      Break
#    Endif
#  Next
# 06.390.285.fin (INCIDENCIA - II)

  #003.ini
  #Selección contratos de servicio
  If  currbox ="GAU_CHE4" Then
    [M:SIH4]ZCCE2([M:SIH4]NBLIG)  = [F:CON]CCE(1)
    [M:SIH4]CCE2([M:SIH4]NBLIG)   = [F:CON]CCE(1)
  Endif
  #003.fin

  #Provisiones
# 06.390.285.ini (INCIDENCIA - II)
#  If  currbox ="GAU_CHE1" and ZFLG = 1 Then
#    [M:SIH2]INVDTAAMT(1)+ = [F:SIH]AMTNOT
#    Insa [M:SIH2]NBLIG, 1, [M:SIH2]NBLIG [M:SIH2]NBLIG
#    [M:SIH2]ZDOC([M:SIH2]NBLIG) = [F:SIV]NUM
#    [M:SIH2]ZTIPO([M:SIH2]NBLIG) = "Provision"
#    [M:SIH2]NBLIG += 1
#  Endif
  If  currbox ="GAU_CHE1" and ZFLG = 1 Then
    Local   Char    S_MOTIVO(250)
    Local   Char    S_PARAM(250)(1..20)
    Global  Decimal GIMPPROVISION
    Call SAISIE_CHAR(S_MOTIVO,S_PARAM,"OZPROVTA","","SPEZPV") From GSAISIE
    [M:SIH2]INVDTAAMT(1)           += GIMPPROVISION
    Insa [M:SIH2]NBLIG, 1, [M:SIH2]NBLIG [M:SIH2]NBLIG
    [M:SIH2]ZDOC([M:SIH2]NBLIG)     = [F:SIV]NUM
    [M:SIH2]ZTIPO([M:SIH2]NBLIG)    = "Provision"
    [M:SIH2]ZIMPORTE([M:SIH2]NBLIG) = GIMPPROVISION
    [M:SIH2]NBLIG += 1
  Endif
# 06.390.285.fin (INCIDENCIA - II)

  #Anticipos
# 06.390.285.ini (INCIDENCIA - II)
#  If  currbox ="GAU_CHE3" and ZFLG = 1 Then
#    [M:SIH2]INVDTAAMT(0)+ = [F:SIH]BASTAX
#    Insa [M:SIH2]NBLIG, 1, [M:SIH2]NBLIG [M:SIH2]NBLIG
#    [M:SIH2]ZDOC([M:SIH2]NBLIG) = [F:SIV]NUM
#    [M:SIH2]ZTIPO([M:SIH2]NBLIG) = "Anticipo"
#    [M:SIH2]NBLIG += 1
#  Endif
  If  currbox ="GAU_CHE3" and ZFLG = 1 Then
    Local   Char    S_MOTIVO(250)
    Local   Char    S_PARAM(250)(1..20)
    Global  Decimal GIMPANTICIPO
    Call SAISIE_CHAR(S_MOTIVO,S_PARAM,"OZANTVTA","","SPEZAV") From GSAISIE
    [M:SIH2]INVDTAAMT(0)           += GIMPANTICIPO
    Insa [M:SIH2]NBLIG, 1, [M:SIH2]NBLIG [M:SIH2]NBLIG
    [M:SIH2]ZDOC([M:SIH2]NBLIG)     = [F:SIV]NUM
    [M:SIH2]ZTIPO([M:SIH2]NBLIG)    = "Anticipo"
    [M:SIH2]ZIMPORTE([M:SIH2]NBLIG) = GIMPANTICIPO
    [M:SIH2]NBLIG += 1
  Endif
# 06.390.285.fin (INCIDENCIA - II)

  #Refacturación
  #002>
  If  currbox ="GAU_CHE5" Then

    Read [F:ZITM3]ITM0 = [F:PID]ITMREF
    If !fstat Then                                                        # 06.337.504.new
      [M:SIH4]ZFACPROV ([M:SIH4]NBLIG) = [F:PID]NUM
      [M:SIH4]ZLINPROV ([M:SIH4]NBLIG) = [F:PID]PIDLIN
      [M:SIH4]ITMREF   ([M:SIH4]NBLIG) = [F:PID]ITMREF
      [M:SIH4]ITMDES   ([M:SIH4]NBLIG) = [F:PID]ITMDES1
      [M:SIH4]GROPRI   ([M:SIH4]NBLIG) = [F:PID]GROPRI
      [M:SIH4]NETPRI   ([M:SIH4]NBLIG) = [F:PID]NETPRI
      [M:SIH4]QTY      ([M:SIH4]NBLIG) = [F:PID]QTYSTU
      [M:SIH4]STU      ([M:SIH4]NBLIG) = [F:PID]PUU
      [M:SIH4]VACITM1  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(0)
      [M:SIH4]VACITM2  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(1)
      [M:SIH4]VACITM3  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(2)
      Filter [F:ZTVC3] Where VACBPR = [M:SIH1]VACBPR  and VACITM = [F:ZITM3]VACITM(0)
      Read [F:ZTVC3]TVC0 First
      If !fstat Then
        [M:SIH4]VAT1  ([M:SIH4]NBLIG)    =  [F:ZTVC3]VAT
      Endif
      # proy financ. Mejora refacturación.ini
      Read [F:ZCAL3]CAL0 = 'PID';0;[F:PID]NUM;[F:PID]PIDLIN;0;'';1
      If !fstat Then
        [M:SIH4]ZCCE2    ([M:SIH4]NBLIG) = [F:ZCAL3]CCE(1)
        [M:SIH4]CCE2     ([M:SIH4]NBLIG) = [F:ZCAL3]CCE(1)
      Endif
      # proy financ. Mejora refacturación.fin

      [M:SIH4]NBLIG+=1
    Endif                                                                 # 06.337.504.new
  Endif

  Affzo  [M:SIH4]
  #002<

#004 ZSUPL.ini
  If  currbox ="GAU_CHE6" Then

    Read [F:ZITM3]ITM0 = [F:PID]ITMREF
    If !fstat Then                                                        # 06.337.504.new
      [M:SIH4]ZFACPROV ([M:SIH4]NBLIG) = [F:PID]NUM
      [M:SIH4]ZLINPROV ([M:SIH4]NBLIG) = [F:PID]PIDLIN
      [M:SIH4]ITMREF   ([M:SIH4]NBLIG) = [F:PID]ITMREF
      [M:SIH4]ITMDES   ([M:SIH4]NBLIG) = [F:PID]ITMDES1
      [M:SIH4]GROPRI   ([M:SIH4]NBLIG) = [F:PID]GROPRI
      [M:SIH4]NETPRI   ([M:SIH4]NBLIG) = [F:PID]NETPRI
      [M:SIH4]QTY      ([M:SIH4]NBLIG) = [F:PID]QTYSTU
      [M:SIH4]STU      ([M:SIH4]NBLIG) = [F:PID]PUU
      [M:SIH4]VACITM1  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(0)
      [M:SIH4]VACITM2  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(1)
      [M:SIH4]VACITM3  ([M:SIH4]NBLIG) = [F:ZITM3]VACITM(2)
      Filter [F:ZTVC3] Where VACBPR = [M:SIH1]VACBPR  and VACITM = [F:ZITM3]VACITM(0)
      Read [F:ZTVC3]TVC0 First
      If !fstat Then
        [M:SIH4]VAT1  ([M:SIH4]NBLIG)    =  [F:ZTVC3]VAT
      Endif
      # proy financ. Mejora refacturación.ini
      Read [F:ZCAL3]CAL0 = 'PID';0;[F:PID]NUM;[F:PID]PIDLIN;0;'';1
      If !fstat Then
        [M:SIH4]ZCCE2    ([M:SIH4]NBLIG) = [F:ZCAL3]CCE(1)
        [M:SIH4]CCE2     ([M:SIH4]NBLIG) = [F:ZCAL3]CCE(1)
      Endif
      # proy financ. Mejora refacturación.fin

      [M:SIH4]NBLIG+=1
    Endif                                                                 # 06.337.504.new
  Endif

  Affzo  [M:SIH4]
#004 ZSUPL.fin

  Affzo  [M:SIH2]


Return
######################################################################################
$DEPICK
 Local Integer ZI,I: Raz ZI
 #Provisiones
 If currbox ="GAU_CHE1" Then
# 06.390.285.ini (INCIDENCIA - II)
#   [M:SIH2]INVDTAAMT(1)- = [F:SIH]AMTNOT
   [M:SIH2]INVDTAAMT(1) -= GIMPPROVISION
# 06.390.285.fin (INCIDENCIA - II)
 Endif
 #Anticipos
 If currbox ="GAU_CHE3" Then
# 06.390.285.ini (INCIDENCIA - II)
#   [M:SIH2]INVDTAAMT(0)- = [F:SIH]BASTAX
   [M:SIH2]INVDTAAMT(0) -= GIMPANTICIPO
# 06.390.285.fin (INCIDENCIA - II)
 Endif
 For I=0 To [M:SIH2]NBLIG-1
  If [M:SIH2]ZDOC(I)=[F:SIV]NUM
    Dela I [M:SIH2]NBLIG
    [M:SIH2]NBLIG=[M:SIH2]NBLIG-1
  Endif
 Next
 Affzo  [M:SIH2]

 #002>
 If currbox ="GAU_CHE5" Then
   For I=0 To [M:SIH4]NBLIG-1
    If [M:SIH4]ITMREF(I)=[F:PID]ITMREF
      Dela I [M:SIH4]NBLIG
      [M:SIH4]NBLIG=[M:SIH4]NBLIG-1
    Endif
   Next
   Affzo  [M:SIH4]
 Endif
 #002<

#004 ZSUPL.ini
 If currbox ="GAU_CHE6" Then
   For I=0 To [M:SIH4]NBLIG-1
    If [M:SIH4]ITMREF(I)=[F:PID]ITMREF
      Dela I [M:SIH4]NBLIG
      [M:SIH4]NBLIG=[M:SIH4]NBLIG-1
    Endif
   Next
   Affzo  [M:SIH4]
 Endif
#004 ZSUPL.fin
Return
#001<

######################################################################################
$APRES_CRE
 If !clalev([F:ZCON2]) : Local File CONTSERV    [F:ZCON2] : Endif
 If !clalev([F:ZCAL1]) : Local File CPTANALIN   [F:ZCAL1] : Endif
 If !clalev([F:ZSID1]) : Local File SINVOICED   [F:ZSID1] : Endif
 #002>
 If !clalev([F:ZPID1]) : Local File PINVOICED    [F:ZPID1] : Endif
 #002<
 #001>
 If !clalev([F:ZSIV1]) : Local File SINVOICEV    [F:ZSIV1] : Endif
 If !clalev([F:ZSIV2]) : Local File SINVOICEV    [F:ZSIV2] : Endif
 Local Integer ZCONT : Raz ZCONT
 Local Integer ZCONP : Raz ZCONP
 #001<

 Local Integer I

 For I=0 To [M:SIH4]NBLIG - 1
  If [M:SIH4]CONNUM (I) <> "" Then
    Call ASIGN_DATE(I,[M:SIH4]ITMREF (I),[M:SIH4]CONNUM (I))
    #Asignar sección analítica
    Read [F:ZCON2]CON0 = [M:SIH4]CONNUM (I)
    If !fstat Then
       Update [F:ZCAL1] Where ABRFIC='SID'and VCRNUM = [M:SIH0]NUM and VCRLIN = [M:SIH4]SIDLIN (I) With CCE(1) = [F:ZCON2]CCE(1)
    Endif
  Endif

  #Control anticipos
  #001>
  If [M:SIH4]ITMREF (I)  ="000OT0001" Then
     ZCONT+=1
  Endif
  #001<

# 06.390.285.ini (INCIDENCIA - II)
  #Control provisiones
  If [M:SIH4]ITMREF (I)  ="000OT0005" Then
     ZCONP+=1
  Endif
# 06.390.285.fin (INCIDENCIA - II)

  #003.ini
  If GFONCTION="FUNAUTINVC" Then
    Update [F:SID] Where NUM = [M:SIH0]NUM and SIDLIN = [M:SIH4]SIDLIN(I) With ZCCE2 = [F:ZCON2]CCE(1)
  Endif
  #003.fin
 Next

# 06.390.285.ini (INCIDENCIA - II)
  If ZCONP > 0 Then
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZRESPROVISIO = [F:SIH]AMTNOT
  Endif
# 06.390.285.fin (INCIDENCIA - II)

 #001>
  If ZCONT > 0 Then
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZANTICIPO = 2
# 06.390.285.ini (INCIDENCIA - II)
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZRESANTICIPO = [F:SIH]BASTAX
# 06.390.285.fin (INCIDENCIA - II)
  Else
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZANTICIPO = 1
  Endif

  #Documentos asociados

  Update [F:ZSIV1] Where ZFACT = [M:SIH0]NUM With ZSALDADO = 1

  Affzo [M:SIH2]

# 06.390.285.ini (INCIDENCIA - II)
  If !clalev([F:ZAPS0]) Then : Local File ZANTPROSIH [F:ZAPS0] : Endif
  If !clalev([F:ZSIV3]) Then : Local File SINVOICEV  [F:ZSIV3] : Endif
  Filter [F:ZAPS0] Where ZSIH = [M:SIH0]NUM
  For    [F:ZAPS0]
    Read [F:ZSIV3]SIV0 = [F:ZAPS0]ZANTPRO
    If !fstat Then
      If GZBORRADOC=0
        If [F:ZSIV3]ZANTICIPO = 2 Then
          [F:ZSIV3]ZRESANTICIPO += [F:ZAPS0]ZIMPORTE
        Else
          [F:ZSIV3]ZRESPROVISIO += [F:ZAPS0]ZIMPORTE
        Endif
        Trbegin [F:ZSIV3]
        Rewrite [F:ZSIV3]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Next
  Filter [F:ZAPS0]
  Delete [F:ZAPS0] Where ZSIH = [M:SIH0]NUM
# 06.390.285.fin (INCIDENCIA - II)

  For I=0 To [M:SIH2]NBLIG - 1
# 06.390.285.ini (INCIDENCIA - II)
#   Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 2
#   Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZFACT    = [F:SIV]NUM
   If GZBORRADOC=0
     If [M:SIH2]ZTIPO(I) = 'Anticipo'
       Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I)  With ZRESANTICIPO  -= [M:SIH2]ZIMPORTE(I)
     Elsif [M:SIH2]ZTIPO(I) = 'Provision'
       Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I)  With ZRESPROVISIO  -= [M:SIH2]ZIMPORTE(I)
     Endif
   Endif
   [F:ZAPS0]ZTIPODOC  = 'SIH'
   [F:ZAPS0]ZANTPRO   = [M:SIH2]ZDOC(I)
   [F:ZAPS0]ZTIPOANPR = [M:SIH2]ZTIPO(I)
   [F:ZAPS0]ZSIH      = [M:SIH0]NUM
   [F:ZAPS0]ZIMPORTE  = [M:SIH2]ZIMPORTE(I)
   Local Integer STAT
   Call NUMERO("ZANPR",nomap,date$,"",[F:ZAPS0]ZID,STAT) From SUBANM
   Trbegin  [F:ZAPS0]
   Write    [F:ZAPS0]
   If !fstat Then
    Commit
   Else
    Rollback
   Endif
   Read [F:ZSIV2]SIV0 = [M:SIH2]ZDOC(I)
   If [F:ZSIV2]ZRESANTICIPO = 0 and [F:ZSIV2]ZRESPROVISIO = 0 Then
     Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 2
   Else
     Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 1
   Endif
# 06.390.285.fin (INCIDENCIA - II)
  Next

# 06.390.285.ini (INCIDENCIA - II)
  Raz GZBORRADOC
# 06.390.285.fin (INCIDENCIA - II)

 #001<

 #002>
 For I=0 To [M:SIH4]NBLIG - 1
   If  [M:SIH4]ITMREF (I)="000OT0004" Then
       #06.379.971.INI
#       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
#       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
       ##06.379.971.FIN
   Endif
 Next
 #002<

#004 ZSUPL.ini
 For I=0 To [M:SIH4]NBLIG - 1
   If  [M:SIH4]ITMREF (I)="000OT0057" Then
       #06.379.971.INI
       #Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
       #Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
       Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
       #06.379.971.FIN
   Endif
 Next
#004 ZSUPL.fin

  Gosub RELIT From GOBJSUB                                                                    # 06.390.285.new

Return

######################################################################################
$APRES_MOD

 #001>
 If !clalev([F:ZSIV1]) : Local File SINVOICEV    [F:ZSIV1] : Endif
 If !clalev([F:ZSIV2]) : Local File SINVOICEV    [F:ZSIV2] : Endif
 If !clalev([F:ZSIV3]) : Local File SINVOICEV    [F:ZSIV3] : Endif
 Local Integer ZCONT : Raz ZCONT
 Local Integer ZCONP : Raz ZCONP
 #001<
 #002>
 If !clalev([F:ZPID1]) : Local File PINVOICED    [F:ZPID1] : Endif
 #002<
 Local Integer I

 For I=0 To [M:SIH4]NBLIG - 1

  #Control anticipos
  #001>
  If [M:SIH4]ITMREF (I)  ="000OT0001" Then
     ZCONT+=1
  Endif
  #001<

# 06.390.285.ini (INCIDENCIA - II)
  #Control provisiones
  If [M:SIH4]ITMREF (I)  ="000OT0005" Then
     ZCONP+=1
  Endif
# 06.390.285.fin (INCIDENCIA - II)
 Next

# 06.390.285.ini (INCIDENCIA - II)
  If ZCONP > 0 Then
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZRESPROVISIO = [F:SIH]AMTNOT
  Endif
# 06.390.285.fin (INCIDENCIA - II)

 #001>
  If ZCONT > 0 Then
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZANTICIPO = 2
# 06.390.285.ini (INCIDENCIA - II)
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZRESANTICIPO = [F:SIH]BASTAX
# 06.390.285.fin (INCIDENCIA - II)
  Else
    Update [F:ZSIV1] Where NUM = [M:SIH0]NUM With ZANTICIPO = 1
  Endif

  #Documentos asociados

  Update [F:ZSIV1] Where ZFACT = [M:SIH0]NUM With ZSALDADO = 1
  #Update [F:ZSIV1] Where ZFACT = [M:SIH0]NUM With ZFACT    =""
  Affzo [M:SIH2]
# 06.390.285.ini (INCIDENCIA - II)
  If !clalev([F:ZAPS0]) Then : Local File ZANTPROSIH [F:ZAPS0] : Endif
  Filter [F:ZAPS0] Where ZSIH = [M:SIH0]NUM
  For    [F:ZAPS0]
    Read [F:ZSIV3]SIV0 = [F:ZAPS0]ZANTPRO
    If !fstat Then
      If GZBORRADOC=0
        If [F:ZSIV3]ZANTICIPO = 2 Then
          [F:ZSIV3]ZRESANTICIPO += [F:ZAPS0]ZIMPORTE
        Else
          [F:ZSIV3]ZRESPROVISIO += [F:ZAPS0]ZIMPORTE
        Endif
        Trbegin [F:ZSIV3]
        Rewrite [F:ZSIV3]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Next
  Filter [F:ZAPS0]
  Delete [F:ZAPS0] Where ZSIH = [M:SIH0]NUM
# 06.390.285.fin (INCIDENCIA - II)

  For I=0 To [M:SIH2]NBLIG - 1
# 06.390.285.ini (INCIDENCIA - II)
#   Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 2
#   Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZFACT    = [F:SIV]NUM
   If GZBORRADOC=0
     If [M:SIH2]ZTIPO(I) = 'Anticipo'
       Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I)  With ZRESANTICIPO  -= [M:SIH2]ZIMPORTE(I)
     Elsif [M:SIH2]ZTIPO(I) = 'Provision'
       Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I)  With ZRESPROVISIO  -= [M:SIH2]ZIMPORTE(I)
     Endif
   Endif
   Read [F:ZSIV2]SIV0 = [M:SIH2]ZDOC(I)
   [F:ZAPS0]ZTIPODOC  = 'SIH'
   [F:ZAPS0]ZTIPOANPR = [M:SIH2]ZTIPO(I)
   [F:ZAPS0]ZANTPRO   = [M:SIH2]ZDOC(I)
   [F:ZAPS0]ZSIH      = [M:SIH0]NUM
   [F:ZAPS0]ZIMPORTE  = [M:SIH2]ZIMPORTE(I)
   Local Integer STAT
   Call NUMERO("ZANPR",nomap,date$,"",[F:ZAPS0]ZID,STAT) From SUBANM
   Trbegin  [F:ZAPS0]
   Write    [F:ZAPS0]
   If !fstat Then
    Commit
   Else
    Rollback
   Endif
   If [F:ZSIV2]ZRESANTICIPO = 0 and [F:ZSIV2]ZRESPROVISIO = 0 Then
     Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 2
   Else
     Update [F:ZSIV1] Where NUM = [M:SIH2]ZDOC (I) With ZSALDADO = 1
   Endif
# 06.390.285.fin (INCIDENCIA - II)
  Next

# 06.390.285.ini (INCIDENCIA - II)
  Raz GZBORRADOC
# 06.390.285.fin (INCIDENCIA - II)

 #001<

  #002>
   For I=0 To [M:SIH4]NBLIG - 1
     If  [M:SIH4]ITMREF (I)="000OT0004" Then
         #06.379.971.INI
         #Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
         #Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
         Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
         Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
         #06.379.971.FIN
     Endif
   Next
 #002<

#004 ZSUPL.ini
   For I=0 To [M:SIH4]NBLIG - 1
     If  [M:SIH4]ITMREF (I)="000OT0057" Then
         #06.379.971.INI
#         Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
#         Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and [M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
          Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZSALDADO = 2
          Update [F:ZPID1] Where NUM = [M:SIH4]ZFACPROV (I) and PIDLIN=[M:SIH4]ZLINPROV (I)  With ZFACCLI  = [F:SIV]NUM
         #06.379.971.FIN
     Endif
   Next
#004 ZSUPL.fin

  Gosub RELIT From GOBJSUB                                                                    # 06.390.285.new

Return           # JC.30092021.NEW. Este Return no estaba cuando revisé el código

