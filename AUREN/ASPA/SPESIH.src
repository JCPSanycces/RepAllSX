######################################################################################
Subprog ASIGN_DATE(P_INDEX,P_ITMREF,P_CONNUM)
     Value Char P_ITMREF,P_CONNUM
     Value Integer  P_INDEX
     If !clalev([F:ZITM1]) : Local File ITMMASTER  [F:ZITM1] : Endif
     If !clalev([F:ZCON1]) : Local File CONTSERV   [F:ZCON1] : Endif
     If !clalev([F:ZPER1]) : Local File PERIOD     [F:ZPER1] : Endif
     If !clalev([F:ZPER2]) : Local File PERIOD     [F:ZPER2] : Endif
     If !clalev([F:ZAXX1]) : Local File ATEXTRA    [F:ZAXX1] : Endif

     Local Date ZFECINI,ZFECFIN : Raz ZFECINI,ZFECFIN
     Local Integer I, ZPERINI,ZCONT   : Raz ZPERINI,ZCONT
     Local Char ZIDTEX(20)
     Local Clbfile ZTEXT
     Local Date ZNEXTDATE :Raz ZNEXTDATE



     Read [F:ZITM1]ITM0 = P_ITMREF

     If !fstat and [F:ZITM1]HDKITMTYP = 5 Then

         Read [F:ZCON1]CON0 = P_CONNUM
         If !fstat Then
           #CON-320-0950
           # ZNEXTDATE =[F:ZCON1]NEXINVDAT #func OLDDATE(P_CONNUM)
            ZNEXTDATE = func OLDDATE(P_CONNUM)
            Filter [F:ZPER1] Where CPY = [F:ZCON1]CPY and LEDTYP = 1 and PERSTA = 2 and PERSTR <= ZNEXTDATE and PEREND>= ZNEXTDATE

            Read [F:ZPER1]PER0 First
            If !fstat Then
              ZFECINI = [F:ZPER1]PERSTR
              #Prefacturación
              If day(ZNEXTDATE) >28 and [F:ZCON1]INVMET = 1 Then
                ZFECINI = eomonth(ZFECINI)
                ZFECINI = gdat$(1,month(ZFECINI)+1,year(ZFECINI))
              Endif
              #Postfacturación
#                 Call OUVRE_TRACE("Debugger facturas") From LECFIC
#                 Call ECR_TRACE(num$([F:ZCON1]NEXINVDAT),0) From GESECRAN

               # 06.306.388 : Auren X3 - Error en específico de contratos de servicio (textos)
               #str.auren error en fecha entrada de texto de artículo aņadimos = a la condicion de abajo
              If day([F:ZCON1]NEXINVDAT) >=28 and [F:ZCON1]INVMET = 2 Then
               #fin.auren 01022022

               # ZFECINI = eomonth(ZFECINI)
                ZFECINI = gdat$(1,month([F:ZCON1]NEXINVDAT)-1,year([F:ZCON1]NEXINVDAT))
                 # Call ECR_TRACE("cambio"-num$(ZFECINI),0) From GESECRAN


              Endif
              #ZFECFIN = [F:ZPER1]PEREND
              #                When 2 : ZFECFIN = (ZNEXTDATE + [F:ZCON1]INVFRY)-1
#                When 3 : ZFECFIN = (ZNEXTDATE + ([F:ZCON1]INVFRY*7))-1
#                When 4 : ZFECFIN = addmonth(ZNEXTDATE,[F:ZCON1]INVFRY)-1
#                When 5 : ZFECFIN = gdat$(day(ZNEXTDATE),month(ZNEXTDATE),year(ZNEXTDATE)+[F:ZCON1]INVFRY)
              Case [F:ZCON1]INVFRYBAS

                 When 2 : ZFECFIN = (ZFECINI + [F:ZCON1]INVFRY)-1
                 When 3 : ZFECFIN = (ZFECINI + ([F:ZCON1]INVFRY*7))-1
                 When 4 : ZFECFIN = addmonth(ZFECINI,[F:ZCON1]INVFRY)-1
                 When 5 : ZFECFIN = gdat$(day(ZFECINI),month(ZFECINI),year(ZFECINI)+[F:ZCON1]INVFRY)
              Endcase
            Endif

            Filter [F:ZPER1]

         Endif
         If ZFECFIN = [0/00/00] Then
           Call MESSAGE("Revise Fecha próxima factura en contrato de servicio para el artículo"-P_ITMREF) From GESECRAN
         Else
           Read [F:ZAXX1]AXX0 ="ITMMASTER";"DES2AXX";[F:SIV]LAN;P_ITMREF;""

           If [F:ZCON1]ZIMPRIMIR = 2 Then
            ZTEXT = [F:ZAXX1]TEXTE-num$(ZFECINI)+"-"+num$(ZFECFIN)+chr$(13)+chr$(10)-[F:ZCON1]ZDESCRIPCION+chr$(13)+chr$(10)
           Else
            ZTEXT = [F:ZAXX1]TEXTE-num$(ZFECINI)+"-"+num$(ZFECFIN)+chr$(13)+chr$(10)
           Endif
           Call ZCRE_CLOB("SID",[M:SIH4]SIDTEX(P_INDEX),ZTEXT)
         Endif
     Endif
End


######################################################################################
## Etiqueta aņadida por el supervisor (pantalla SIH4) 09/12/2020 15:58:23 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
 Variable Char    VALEUR()
 Local Integer  WTEXSEQ,WRETOUR

 Call NUM_TXC("SID",WTEXSEQ,WRETOUR) From TRTX3TEX
 [M:SIH4]SIDTEX(nolign-1)  = "SID~"+format$("N0:8#",num$(WTEXSEQ))
 Affzo [M:SIH4]SIDTEX(nolign-1)
End

