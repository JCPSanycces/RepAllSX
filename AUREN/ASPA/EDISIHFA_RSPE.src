#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  If GUSER = 'IMP_AURENX3' Then : Infbox "dentro mťtodo" : Endif
  If GUSER = 'IMP_AURENX3' Then : Infbox "WCATACT:"-WCATACT : Endif
  If GUSER = 'IMP_AURENX3' Then : Infbox "WPARCOD:"-WPARCOD : Endif
Return
