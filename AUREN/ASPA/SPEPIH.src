#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara PIH3 (Especifico)
#004 ZSUPL - JC.21022022.Implementación suplidos clientes
#005 ZESUC - AMG.09082022.Entidad sucedida
# 06.390.286 - JC.12092022.Desarrollo especifico anticipos y provisiones a proveedores
# 06.429.467 - JC.09012023.Desarrollo anticipos y provisiones de proveedor en LIVE defectuoso
########################################################################

$ACTION
#Infbox "spepih"-ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "FILGAUCHE"     : Gosub FILGAUCHE
  When "LIENS"         : Gosub LIENS
  When "VERIF_CRE"     : Gosub VERIF
  When "VERIF_MOD"     : Gosub VERIF
  When "APRES_CRE"     : Gosub APRES_CRE
  When "APRES_MOD"     : Gosub APRES_MOD
  When "SETBOUT"       : Gosub SETBOUT
  When "PICKE"         : Gosub PICKE
  When "DEPICK"        : Gosub DEPICK
  When "FIN"           : Gosub FIN
  When "FERME"         : Gosub FERME
  When Default
Endcase
Return

######################################################################################
$OUVRE
# 06.390.286.ini
  Global Integer GZBORRADOC
# 06.390.286.fin
Return

######################################################################################
$FIN
#  If dim(GIMPPROVISION) > 0 Then : Kill GIMPPROVISION : Endif
#  If dim(GIMPANTICIPO)  > 0 Then : Kill GIMPANTICIPO  : Endif
#  If dim(GZBORRADOC)    > 0 Then : Kill GZBORRADOC    : Endif
Return

######################################################################################
$FILGAUCHE

# 06.390.286.ini
  Gosub FILGAUCHE     From SUBPIHA

  #No contabilizadas
  If [F:PIH]STA < 3 Then
    Raz WCRITERE

    # provisiones
# 06.429.467.ini
#    If currbox = "GAU_CHE1" Then
    If currbox = "GAU_CHE2" Then
# 06.429.467.fin
      Local Integer IROW : IROW = 1
      Local Integer FIRSTROW : FIRSTROW =0
      WCRITERE= "([F:PIH]PIVTYP='PFP'|[F:PIH]PIVTYP='PFR')&[F:PIV]ZSALDADO<>2&[F:PIH]STA=3&[F:PIH]NUM<>'"+[M:PIH0]NUM+"'&[F:PIH]FCY='"+[M:PIH0]FCY+"'&[F:PIH]BPR='"+[M:PIH0]BPR+"'"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
#      FILGAUSUP(0)+= "([F:PIH]PIVTYP='PFP'|[F:PIH]PIVTYP='PFR')&[F:PIV]ZSALDADO<>2&[F:PIH]STA=3&[F:PIV]NUM<>'"+[M:PIH0]NUM+"'&[F:PIH]FCY='"+[M:PIH0]FCY+"'&[F:PIV]BPR='"+[M:PIH0]BPR+"'"
      Local Char WKFILROLE(250)
      Call FILROLE("ZPIH1",WKFILROLE) From SUBARL
      If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
    Endif

    # anticipos
# 06.429.467.ini
#    If currbox = "GAU_CHE2" Then
    If currbox = "GAU_CHE4" Then
# 06.429.467.fin
      Local Integer IROW : IROW = 1
      Local Integer FIRSTROW : FIRSTROW =0
      WCRITERE="[F:PIV]ZANTICIPO=2&[F:PIV]ZSALDADO<>2&[F:PIH]STA=3&[F:PIH]NUM<>'"+[M:PIH0]NUM+"'&[F:PIH]FCY='"+[M:PIH0]FCY+"'&[F:PIH]BPR='"+[M:PIH0]BPR+"'"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
#      FILGAUSUP(0)+="[F:PIV]ZANTICIPO=2&[F:PIV]ZSALDADO<>2&[F:PIH]STA=3&[F:PIV]NUM<>'"+[M:PIH0]NUM+"'&[F:PIH]FCY='"+[M:PIH0]FCY+"'&[F:PIV]BPR='"+[M:PIH0]BPR+"'"
      Local Char WKFILROLE(250)
      Call FILROLE("ZPIH2",WKFILROLE) From SUBARL
      If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
    Endif
  Else
    WCRITERE="1=2"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
#    FILGAUSUP(0)+="1=2"
  Endif

  If currbox = "GAU_CHE5" and [M:PIH0]PIVTYP = 'FCR' Then
    Local Integer IROW : IROW = 1
    Local Integer FIRSTROW : FIRSTROW =0
    WCRITERE="& [F:PIH]FCY='"+[M:PIH0]FCY+"'"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Local Char WKFILROLE(250)
    Call FILROLE("PI1",WKFILROLE) From SUBARL
    If WKFILROLE ="" : WKFILROLE ="1=1" : Endif
  Endif

  GPE=1
# 06.390.286.fin

Return

######################################################################################
$LIENS
# 06.390.286.ini
Local Integer I :Raz I

  If !clalev([F:ZPIV3]) : Local File PINVOICEV   [F:ZPIV3] : Endif

#  Read [F:ZPIV3]PIV0 = [F:PIV]ZFACT
#  If !fstat Then
#    If [F:ZPIV3]ZANTICIPO = 2 Then
#      [M:PIH1]ZTIPO(I) = "Anticipo"
#    Else
#      [M:PIH1]ZTIPO(I) = "Provision"
#    Endif
#    [M:PIH1]ZDOC(I) = [F:ZPIV3]NUM
#    I+=1
#  Endif
  Local Decimal LTOTANTICIPO,LTOTPROVISION
  If !clalev([F:ZAPS1]) Then : Local File ZANTPROSIH [F:ZAPS1] : Endif
  Filter [F:ZAPS1] Where ZSIH = [M:PIH0]NUM
  For [ZAPS1]
    Read [F:ZPIV3]PIV0 = [F:ZAPS1]ZANTPRO
    If !fstat Then
      If [F:ZPIV3]ZANTICIPO = 2 Then
        [M:PIH1]ZTIPO(I)  = "Anticipo"
        LTOTANTICIPO      += [F:ZAPS1]ZIMPORTE
      Else
        [M:PIH1]ZTIPO(I)  = "Provision"
        LTOTPROVISION     += [F:ZAPS1]ZIMPORTE
      Endif
      [M:PIH1]ZDOC(I)     = [F:ZAPS1]ZANTPRO
      [M:PIH1]ZIMPORTE(I) = [F:ZAPS1]ZIMPORTE
      [M:PIH1]ZID(I)      = [F:ZAPS1]ZID
      I+=1
    Endif
  Next
  Filter [F:ZAPS1]
  Close Local File [ZAPS1]
# 06.390.286.fin

  [M:PIH1]NBLIG = I
  Affzo [M:PIH1]

# 06.390.286.ini
  [M:PIH1]INVDTAAMT1(0) = LTOTANTICIPO
  [M:PIH1]INVDTAAMT1(1) = LTOTPROVISION
  Affzo [M:PIH1]INVDTAAMT1(0)
  Affzo [M:PIH1]INVDTAAMT1(1)
# 06.390.286.fin
Return
######################################################################################
$PICKE
# 06.390.286.ini
Local Integer I,J,ZFLG:ZFLG = 1
  If !clalev([F:ZITM3]) : Local File ITMMASTER   [F:ZITM3] : Endif
  If !clalev([F:ZTVC3]) : Local File TABVAC      [F:ZTVC3] : Endif
  If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
    Return
   Endif
  Endif

#  For J=0 To [M:PIH1]NBLIG - 1
#    If [M:PIH1]ZDOC(J) = [F:PIV]NUM Then
#      ZFLG = 0
#      Break
#    Endif
#  Next

  #Provisiones
# 06.429.467.ini
#  If  currbox ="GAU_CHE1" and ZFLG = 1 Then
  If  currbox ="GAU_CHE2" and ZFLG = 1 Then
# 06.429.467.fin
    Local   Char    S_MOTIVO(250)
    Local   Char    S_PARAM(250)(1..20)
    Global  Decimal GIMPPROVISION
    Call SAISIE_CHAR(S_MOTIVO,S_PARAM,"OZPROCMP","","SPEZPC") From GSAISIE
    [M:PIH1]INVDTAAMT1(1)          += (-1 * GIMPPROVISION)
    Affzo [M:PIH1]INVDTAAMT1(1)

    Local Integer TMPLIN: TMPLIN = nolign
    Local Decimal LVALOR: Raz LVALOR
    nolign = 2
    Call AVANT_NBFAC1 From SUBPIH
    Call AS_INVDTAAMT1(LVALOR) From SUBPIH
    LVALOR = -1*[M:PIH1]INVDTAAMT1(1)
    Call AM_INVDTAAMT1(LVALOR) From SUBPIH
    Call APRES_NBFAC1 From SUBPIH
    nolign = TMPLIN
    Insa [M:PIH1]NBLIG, 1, [M:PIH1]NBLIG [M:PIH1]NBLIG
    [M:PIH1]ZDOC([M:PIH1]NBLIG)     = [F:PIV]NUM
    [M:PIH1]ZTIPO([M:PIH1]NBLIG)    = "Provision"
    [M:PIH1]ZIMPORTE([M:PIH1]NBLIG) = -1*GIMPPROVISION
    [M:PIH1]NBLIG += 1
  Endif

  #Anticipos
# 06.429.467.ini
#  If  currbox ="GAU_CHE2" and ZFLG = 1 Then
  If  currbox ="GAU_CHE4" and ZFLG = 1 Then
# 06.429.467.fin
    Local   Char    S_MOTIVO(250)
    Local   Char    S_PARAM(250)(1..20)
    Global  Decimal GIMPANTICIPO
    Call SAISIE_CHAR(S_MOTIVO,S_PARAM,"OZANTCMP","","SPEZAC") From GSAISIE
    [M:PIH1]INVDTAAMT1(0)          += (-1 * GIMPANTICIPO)
    Affzo [M:PIH1]INVDTAAMT1(0)

    Local Integer TMPLIN: TMPLIN = nolign
    Local Decimal LVALOR: Raz LVALOR
    nolign = 1
    Call AVANT_NBFAC1 From SUBPIH
    Call AS_INVDTAAMT1(LVALOR) From SUBPIH
    LVALOR = -1*[M:PIH1]INVDTAAMT1(0)
    Call AM_INVDTAAMT1(LVALOR) From SUBPIH
    Call APRES_NBFAC1 From SUBPIH
    nolign = TMPLIN
    Insa [M:PIH1]NBLIG, 1, [M:PIH1]NBLIG [M:PIH1]NBLIG
    [M:PIH1]ZDOC([M:PIH1]NBLIG)     = [F:PIV]NUM
    [M:PIH1]ZTIPO([M:PIH1]NBLIG)    = "Anticipo"
    [M:PIH1]ZIMPORTE([M:PIH1]NBLIG) = -1*GIMPANTICIPO
    [M:PIH1]NBLIG += 1

  Endif

  Affzo  [M:PIH1]
  Affzo  [M:PIH3]
# 06.390.286.fin
Return

######################################################################################
$DEPICK
Local Integer ZI,I: Raz ZI

# 06.390.286.ini
 #Provisiones
 # 06.429.467.ini
#  If currbox ="GAU_CHE1" Then
  If currbox ="GAU_CHE2" Then
# 06.429.467.fin

    Local Integer TMPLIN: TMPLIN = nolign
    Local Decimal LVALOR
    nolign = 2
    Call AVANT_NBFAC1 From SUBPIH
    LVALOR = [M:PIH1]INVDTAAMT1(1)
    Call AS_INVDTAAMT1(LVALOR) From SUBPIH
#    Raz LVALOR
    [M:PIH1]INVDTAAMT1(1) -= (-1 * GIMPPROVISION)
    Affzo [M:PIH1]INVDTAAMT1(1)
    LVALOR = [M:PIH1]INVDTAAMT1(1)
    Call AM_INVDTAAMT1(LVALOR) From SUBPIH
    Call APRES_NBFAC1 From SUBPIH
    nolign = TMPLIN
  Endif
 #Anticipos
# 06.429.467.ini
#  If currbox ="GAU_CHE2" Then
  If currbox ="GAU_CHE4" Then
# 06.429.467.fin

    Local Integer TMPLIN: TMPLIN = nolign
    Local Decimal LVALOR
    nolign = 1
    Call AVANT_NBFAC1 From SUBPIH
    LVALOR = [M:PIH1]INVDTAAMT1(0)
    Call AS_INVDTAAMT1(LVALOR) From SUBPIH
#    Raz LVALOR
    [M:PIH1]INVDTAAMT1(0) -= (-1 * GIMPANTICIPO)
    Affzo [M:PIH1]INVDTAAMT1(0)
    LVALOR = [M:PIH1]INVDTAAMT1(0)
    Call AM_INVDTAAMT1(LVALOR) From SUBPIH
    Call APRES_NBFAC1 From SUBPIH
    nolign = TMPLIN
  Endif
  For I=0 To [M:PIH1]NBLIG-1
    If [M:PIH1]ZDOC(I)=[F:PIV]NUM
      Dela I [M:PIH1]NBLIG
      [M:PIH1]NBLIG=[M:PIH1]NBLIG-1
    Endif
  Next

  Affzo  [M:PIH1]
# 06.390.286.fin

Return

############################################################################################################################################################################
#001>
$VERIF
  Local Integer I

# 06.390.286.ini
  If ([M:PIH1]INVDTAAMT1(0) + [M:PIH1]INVDTAAMT1(1)) > 0 and [M:PIH4]AMTATI < 0 Then
    Call ERREUR("No se permite importe de anticipo + provisión superior al importe de las líneas") From GESECRAN
    OK=0
  Endif
# 06.390.286.fin

  For I=0 To [M:PIH3]NBLIG-1
    If [M:PIH3]ITMREF(I) = "000OT0004" and [M:PIH3]ZBPCNUM (I) = "" Then
      Call MESSAGE("Para artículo de refacturación el cliente es obligatorio")From GESECRAN
      GERR = 1
      OK = 0
      Return
    Endif
#004 ZSUPL.ini
    If [M:PIH3]ITMREF(I) = "000OT0057" and [M:PIH3]ZBPCNUM (I) = "" Then
      Call MESSAGE("Para artículo suplido el cliente es obligatorio")From GESECRAN
      GERR = 1
      OK = 0
      Return
    Endif
#004 ZSUPL.fin
  Next

## 06.390.286.ini
#  For I=0 To [M:PIH1]NBFAC1-1
#    [M:PIH4]INVDTAAMT(I) = [M:PIH1]INVDTAAMT1(I)
#    Affzo [M:PIH4]INVDTAAMT(I)
#  Next
## 06.390.286.fin

Return

######################################################################################
$APRES_CRE

Local Integer ZCONT : Raz ZCONT
Local Integer ZCONP : Raz ZCONP
Local Integer I

# 06.390.286.ini
  If !clalev([F:ZPIV1]) : Local File PINVOICEV    [F:ZPIV1] : Endif
  If !clalev([F:ZPIV2]) : Local File PINVOICEV    [F:ZPIV2] : Endif

  For I=0 To [M:PIH3]NBLIG - 1
  #Control anticipos
  If [M:PIH3]ITMREF (I)  ="000OT0001" Then
     ZCONT+=1
  Endif

  #Control provisiones
  If [M:PIH3]ITMREF (I)  ="000OT0005" Then
     ZCONP+=1
  Endif

  Next

  If ZCONP > 0 Then
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZRESPROVISIO  = [F:PIH]AMTNOT
  Endif

  If ZCONT > 0 Then
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZANTICIPO     = 2
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZRESANTICIPO  = [F:PIH]BASTAX
  Else
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZANTICIPO     = 1
  Endif

  #Documentos asociados
  Update [F:ZPIV1] Where ZFACT = [M:PIH0]NUM With ZSALDADO      = 1

  Affzo [M:PIH1]

  If !clalev([F:ZAPS0]) Then : Local File ZANTPROSIH [F:ZAPS0] : Endif
  If !clalev([F:ZPIV3]) Then : Local File PINVOICEV  [F:ZPIV3] : Endif
  Filter [F:ZAPS0] Where ZSIH = [M:PIH0]NUM
  For    [F:ZAPS0]
    Read [F:ZPIV3]PIV0 = [F:ZAPS0]ZANTPRO
    If !fstat Then
      If GZBORRADOC=0
        If [F:ZPIV3]ZANTICIPO = 2 Then
          [F:ZPIV3]ZRESANTICIPO += (-1 * [F:ZAPS0]ZIMPORTE)
        Else
          [F:ZPIV3]ZRESPROVISIO += (-1 * [F:ZAPS0]ZIMPORTE)
        Endif
        Trbegin [F:ZPIV3]
        Rewrite [F:ZPIV3]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Next
  Filter [F:ZAPS0]
  Delete [F:ZAPS0] Where ZSIH = [M:PIH0]NUM

  For I=0 To [M:PIH1]NBLIG - 1
   If GZBORRADOC=0
     If [M:PIH1]ZTIPO(I) = 'Anticipo'
       Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I)  With ZRESANTICIPO  -= (-1 * [M:PIH1]ZIMPORTE(I))
     Elsif [M:PIH1]ZTIPO(I) = 'Provision'
       Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I)  With ZRESPROVISIO  -= (-1 * [M:PIH1]ZIMPORTE(I))
     Endif
   Endif
   [F:ZAPS0]ZTIPODOC  = 'PIH'
   [F:ZAPS0]ZANTPRO   = [M:PIH1]ZDOC(I)
   [F:ZAPS0]ZTIPOANPR = [M:PIH1]ZTIPO(I)
   [F:ZAPS0]ZSIH      = [M:PIH0]NUM
   [F:ZAPS0]ZIMPORTE  = [M:PIH1]ZIMPORTE(I)
   Local Integer STAT
   Call NUMERO("ZANPR",nomap,date$,"",[F:ZAPS0]ZID,STAT) From SUBANM
   Trbegin  [F:ZAPS0]
   Write    [F:ZAPS0]
   If !fstat Then
    Commit
   Else
    Rollback
   Endif
   Read [F:ZPIV2]PIV0 = [M:PIH1]ZDOC(I)
   If [F:ZPIV2]ZRESANTICIPO = 0 and [F:ZPIV2]ZRESPROVISIO = 0 Then
     Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I) With ZSALDADO = 2
   Endif
  Next

  Raz GZBORRADOC

  Gosub RELIT From GOBJSUB
# 06.390.286.fin

Return

######################################################################################
$APRES_MOD

Local Integer ZCONT : Raz ZCONT
Local Integer ZCONP : Raz ZCONP
Local Integer I

# 06.390.286.ini
  If !clalev([F:ZPIV1]) : Local File PINVOICEV    [F:ZPIV1] : Endif
  If !clalev([F:ZPIV2]) : Local File PINVOICEV    [F:ZPIV2] : Endif

  For I=0 To [M:PIH3]NBLIG - 1
    #Control anticipos
    If [M:PIH3]ITMREF (I)  ="000OT0001" Then
      ZCONT+=1
    Endif

    #Control provisiones
    If [M:PIH3]ITMREF (I)  ="000OT0005" Then
      ZCONP+=1
    Endif
  Next

  If ZCONP > 0 Then
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZRESPROVISIO  = [F:PIH]AMTNOT
  Endif

  If ZCONT > 0 Then
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZANTICIPO     = 2
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZRESANTICIPO  = [F:PIH]BASTAX
  Else
    Update [F:ZPIV1] Where NUM = [M:PIH0]NUM With ZANTICIPO     = 1
  Endif

  #Documentos asociados
  Update [F:ZPIV1] Where ZFACT = [M:PIH0]NUM With ZSALDADO      = 1

  Affzo [M:PIH1]

  If !clalev([F:ZAPS0]) Then : Local File ZANTPROSIH [F:ZAPS0] : Endif
  If !clalev([F:ZPIV3]) Then : Local File PINVOICEV  [F:ZPIV3] : Endif
  Filter [F:ZAPS0] Where ZSIH = [M:PIH0]NUM
  For    [F:ZAPS0]
    Read [F:ZPIV3]PIV0 = [F:ZAPS0]ZANTPRO
    If !fstat Then
      If GZBORRADOC=0
        If [F:ZPIV3]ZANTICIPO = 2 Then
          [F:ZPIV3]ZRESANTICIPO += (-1 * [F:ZAPS0]ZIMPORTE)
        Else
          [F:ZPIV3]ZRESPROVISIO += (-1 * [F:ZAPS0]ZIMPORTE)
        Endif
        Trbegin [F:ZPIV3]
        Rewrite [F:ZPIV3]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Next
  Filter [F:ZAPS0]
  Delete [F:ZAPS0] Where ZSIH = [M:PIH0]NUM

  For I=0 To [M:PIH1]NBLIG - 1
   If GZBORRADOC=0
     If [M:PIH1]ZTIPO(I) = 'Anticipo'
       Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I)  With ZRESANTICIPO  -= (-1 * [M:PIH1]ZIMPORTE(I))
     Elsif [M:PIH1]ZTIPO(I) = 'Provision'
       Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I)  With ZRESPROVISIO  -= (-1 * [M:PIH1]ZIMPORTE(I))
     Endif
   Endif
   [F:ZAPS0]ZTIPODOC  = 'PIH'
   [F:ZAPS0]ZANTPRO   = [M:PIH1]ZDOC(I)
   [F:ZAPS0]ZTIPOANPR = [M:PIH1]ZTIPO(I)
   [F:ZAPS0]ZSIH      = [M:PIH0]NUM
   [F:ZAPS0]ZIMPORTE  = [M:PIH1]ZIMPORTE(I)
   Local Integer STAT
   Call NUMERO("ZANPR",nomap,date$,"",[F:ZAPS0]ZID,STAT) From SUBANM
   Trbegin  [F:ZAPS0]
   Write    [F:ZAPS0]
   If !fstat Then
    Commit
   Else
    Rollback
   Endif
   Read [F:ZPIV2]PIV0 = [M:PIH1]ZDOC(I)
   If [F:ZPIV2]ZRESANTICIPO = 0 and [F:ZPIV2]ZRESPROVISIO = 0 Then
     Update [F:ZPIV1] Where NUM = [M:PIH1]ZDOC(I) With ZSALDADO = 2
   Endif
  Next

  Raz GZBORRADOC
Gosub FILGAUCHE
Gosub HINTCLE       From SUBPIHA
  Gosub RELIT From GOBJSUB
# 06.390.286.fin

Return

######################################################################################

$SETBOUT
  Local Integer I

  For I=0 To [M:PIH3]NBLIG-1
#004 ZSUPL.ini
#    If [M:PIH3]ITMREF(I) = "000OT0004" and [M:PIH3]ZSALDADO (I) = 2 Then
    If ([M:PIH3]ITMREF(I) = "000OT0004" or [M:PIH3]ITMREF(I) = "000OT0057") and [M:PIH3]ZSALDADO (I) = 2 Then
#004 ZSUPL.fin

      Diszo [M:PIH3]ITMDES    (I)
      Diszo [M:PIH3]ITMDES1   (I)
      Diszo [M:PIH3]ZBPCNUM   (I)
      Diszo [M:PIH3]UOM       (I)
      Diszo [M:PIH3]QTYUOM    (I)
      Diszo [M:PIH3]NETPRI    (I)
      Diszo [M:PIH3]AMTNOTLIN (I)
      Diszo [M:PIH3]LINACC1   (I)
      Diszo [M:PIH3]LINACC2   (I)
      Diszo [M:PIH3]LINPURTYP (I)
      Diszo [M:PIH3]VAT1      (I)
      Diszo [M:PIH3]VAT2      (I)
      Diszo [M:PIH3]VAT3      (I)
      Diszo [M:PIH3]MATTOL    (I)
      Affzo [M:PIH3]ITMDES    (I)
      Affzo [M:PIH3]ITMDES1   (I)
      Affzo [M:PIH3]ZBPCNUM   (I)
      Affzo [M:PIH3]UOM       (I)
      Affzo [M:PIH3]QTYUOM    (I)
      Affzo [M:PIH3]NETPRI    (I)
      Affzo [M:PIH3]AMTNOTLIN (I)
      Affzo [M:PIH3]LINACC1   (I)
      Affzo [M:PIH3]LINACC2   (I)
      Affzo [M:PIH3]LINPURTYP (I)
      Affzo [M:PIH3]VAT1      (I)
      Affzo [M:PIH3]VAT2      (I)
      Affzo [M:PIH3]VAT3      (I)
      Affzo [M:PIH3]MATTOL    (I)
    Endif
  Next
#  Affzo [M:PIH3]

#005.ini
If [M:PIH0]ZENTSUC=1 Then
    Grizo [M:PIH0]ZNOMENSUC
Endif
If [M:PIH0]ZENTSUC=2 Then
    Actzo [M:PIH0]ZNOMENSUC
Endif
If [M:PIH1]STA =3 Then
    Grizo [M:PIH0]ZNOMENSUC
    Grizo [M:PIH0]ZENTSUC
Endif
#005.fin

Return

######################################################################################
$FERME
 If dim(ZLISTPROV)>0
  Kill ZLISTPROV
 Endif
 If dim(ZLISTANT)>0
  Kill ZLISTANT
 Endif
Return

######################################################################################

Subprog C_ZBPCNUM(VALEUR)
  Variable Char    VALEUR()

  If [M:PIH3]ITMREF(nolign-1) ="000OT0004" and VALEUR ="" Then
    Call MESSAGE("Para artículo de refacturación el cliente es obligatorio")From GESECRAN
    mkstat = 2
    End
  Endif
#004 ZSUPL.ini
  If [M:PIH3]ITMREF(nolign-1) ="000OT0057" and VALEUR ="" Then
    Call MESSAGE("Para artículo suplido el cliente es obligatorio")From GESECRAN
    mkstat = 2
    End
  Endif
#004 ZSUPL.fin
End

######################################################################################

Subprog C_NBLIG

  If (status = 65 or  status = 68) and [M:PIH3]ITMREF(nolign-1) = "000OT0004" and  [M:PIH3]ZSALDADO(nolign-1) <> 2  Then
     Call MESSAGE("No se pueden borrar líneas con artículos de refacturación en estado saldado")From GESECRAN
    mkstat =2
    End

  Endif
#004 ZSUPL.ini
  If (status = 65 or  status = 68) and [M:PIH3]ITMREF(nolign-1) = "000OT0057" and  [M:PIH3]ZSALDADO(nolign-1) <> 2  Then
     Call MESSAGE("No se pueden borrar líneas con artículos suplidos en estado saldado")From GESECRAN
    mkstat =2
    End

  Endif
#004 ZSUPL.fin

# 06.390.286.ini
  If !clalev([F:ZPIH4]) : Local File PINVOICE    [F:ZPIH4] : Endif
  If !clalev([F:ZPIV4]) : Local File PINVOICEV   [F:ZPIV4] : Endif
  Local Integer I

  #Borrar
  If [M:PIH1]STA < 3 Then
    If status = 65 Then
      Read  [F:ZPIH4]PIH0 =  [M:PIH1]ZDOC(nolign-1)
      Read  [F:ZPIV4]PIV0 =  [M:PIH1]ZDOC(nolign-1)
      If !fstat Then
        If  [F:ZPIV4]ZANTICIPO = 2 Then
          Update [F:ZPIV4] Where NUM = [M:PIH1]ZDOC(nolign-1) With ZRESANTICIPO += (-1 * [M:PIH1]ZIMPORTE(nolign-1))
#          [M:PIH1]INVDTAAMT1(0) -= [M:PIH1]ZIMPORTE(nolign-1)
#          Affzo [M:PIH1]INVDTAAMT1(0)
#          Local Integer TMPLIN: TMPLIN = nolign
#          nolign = 1
#          Call AM_INVDTAAMT1([M:PIH1]INVDTAAMT1(0)) From SUBPIH
#          nolign = TMPLIN
          Local Integer TMPLIN: TMPLIN = nolign
          Local Decimal LVALOR
          nolign = 1
          Call AVANT_NBFAC1 From SUBPIH
          LVALOR = [M:PIH1]INVDTAAMT1(0)
          Call AS_INVDTAAMT1(LVALOR) From SUBPIH
          [M:PIH1]INVDTAAMT1(0) -= [M:PIH1]ZIMPORTE(nolign-1)
          Affzo [M:PIH1]INVDTAAMT1(0)
          LVALOR = [M:PIH1]INVDTAAMT1(0)
          Call AM_INVDTAAMT1(LVALOR) From SUBPIH
          Call APRES_NBFAC1 From SUBPIH
          nolign = TMPLIN
          Update [F:ZPIV4] Where NUM = [M:PIH1]ZDOC(nolign-1) With ZSALDADO      = 1
          GZBORRADOC=1
        Else
          Update [F:ZPIV4] Where NUM = [M:PIH1]ZDOC(nolign-1) With ZRESPROVISIO += (-1 * [M:PIH1]ZIMPORTE(nolign-1))
#          [M:PIH1]INVDTAAMT1(1) -= [M:PIH1]ZIMPORTE(nolign-1)
#          Affzo [M:PIH1]INVDTAAMT1(1)
#          Local Integer TMPLIN: TMPLIN = nolign
#          nolign = 2
#          Call AM_INVDTAAMT1([M:PIH1]INVDTAAMT1(1)) From SUBPIH
#          nolign = TMPLIN
          Local Integer TMPLIN: TMPLIN = nolign
          Local Decimal LVALOR
          nolign = 2
          Call AVANT_NBFAC1 From SUBPIH
          LVALOR = [M:PIH1]INVDTAAMT1(1)
          Call AS_INVDTAAMT1(LVALOR) From SUBPIH
          [M:PIH1]INVDTAAMT1(1) -= [M:PIH1]ZIMPORTE(nolign-1)
          Affzo [M:PIH1]INVDTAAMT1(1)
          LVALOR = [M:PIH1]INVDTAAMT1(1)
          Call AM_INVDTAAMT1(LVALOR) From SUBPIH
          Call APRES_NBFAC1 From SUBPIH
          nolign = TMPLIN
          Update [F:ZPIV4] Where NUM = [M:PIH1]ZDOC(nolign-1) With ZSALDADO      = 1
          GZBORRADOC=1
        Endif
        If !clalev([F:ZAPS2]) Then : Local File ZANTPROSIH [F:ZAPS2] : Endif
        Delete [F:ZAPS2] Where ZTIPODOC = 'PIH' and ZANTPRO = [M:PIH1]ZDOC(nolign-1) and ZSIH = [M:PIH0]NUM
      Endif
    Endif
  Else
#    Call MESSAGE("Factura validada") From GESECRAN
#    mkstat = 2
#    End
  Endif

End

#001<

#005.ini
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PIH0) 09/08/2022 13:11:59 (DEVAU)
######################################################################################
Subprog AP_ZENTSUC(VALEUR)
Variable Integer VALEUR
#entidad sucedida
If [M:PIH0]ZENTSUC=1 Then
    [M:PIH0]ZNOMENSUC=""
    Diszo [M:PIH0]ZNOMENSUC
    Grizo [M:PIH0]ZNOMENSUC
Endif
If [M:PIH0]ZENTSUC=2 Then
    Actzo [M:PIH0]ZNOMENSUC
Endif
#fin entidad sucedida
End

######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PIH0) 23/09/2022 08:40:35 (DEVAU)
######################################################################################
Subprog C_ZNOMENSUC(VALEUR)
Variable Char    VALEUR()

If !clalev([F:ZES]) Then : Local File ZENTSUC [ZES] : Endif

Filter [ZES] Where ACTIVO = 2 and NOMBRERAZON=VALEUR
Read [ZES]First
If fstat Then
  Call ERREUR("Nombre entidad sucedida INCORRECTO") From GESECRAN
  zonsui="[M:PIH0]ZNOMENSUC"
Endif

End
######################################################################################
#005.fin

######################################################################################
## Después de modificar el campo 'Artículo' (pantalla PIH3) 21/10/2022 10:15:46 (IMPAU)
######################################################################################
# 06.390.286
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  If VALEUR = '000OT0001' or VALEUR = '000OT0005' Then
    Grizo [M:PIH3]LINACC1(nolign-1)
  Endif
End
