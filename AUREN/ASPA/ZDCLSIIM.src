############################################################################
# Script name : ZDCLSIIM
# Description : Monitor SII Manual
# Module      : Contabilidad
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren
# Created date: 16/09/2021
############################################################################

######################################################################################
######################################################################################

$ACTION
Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "BOUTON" : Gosub BOUTON
  When Default
Endcase

Return

$OUVRE
Gosub OUVRE From ZDCLSII
Return

$BOUTON
If BOUT = "1"
  Gosub EXEC2
Endif
Return

$EXEC2


[M:DSII]CPY =  [M:ZDSIIM]CPY
[M:DSII]STAALL = 2
Gosub LECTURE From ZDCLSII
Gosub SORTIE From ZDCLSII

#mes anterior
Local Date TMPDAT:Raz TMPDAT
TMPDAT=gdat$(1,month(date$),year(date$))-15
TMPDAT=gdat$(1,month(TMPDAT),year(TMPDAT))

[M:DSII]CPY =  [M:ZDSIIM]CPY
[M:DSII]STAALL = 2
[M:DSII]DATINI = TMPDAT
[M:DSII]DATEND=gdat$(eomonth(TMPDAT))
Gosub LECTURE From ZDCLSII
Gosub SORTIE From ZDCLSII


Return
