#<AdxTL>@(#)0.0.0.0 $Revision$ 
#006 JC.27072022.Adaptacion Especifico Seguridad
########################################################################

$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
  Endcase
Return

#################################################
$SEL_TABLE

 If dim(TABLE)>0 Then
   Case TABLE
      When "SELRESP"    : Gosub SEL_RESP
      When "ZSELGRUPYM" : Gosub SEL_ZSELGRUPYM        # JC.04082021.NEW
   Endcase
 Endif
 If dim(COUZON)> 0 Then
   Case COUZON #Seg˙n campo
      When "ZFCY"         : Gosub SEL_FCY
      When "ZCLIENTE"     : Gosub SEL_CLI
   Endcase
 Endif
Return
#################################################

$SEL_FCY
  If !clalev([F:ZAUS1]) : Local File AUTILIS  [F:ZAUS1] : Endif
  Read [F:ZAUS1]CODUSR = GUSER
##  # Nombre del Objeto, Criterio y nombre del campo a devolver
  OBJET = "ADI"
#006.ini
#  CRITERE(1) += "right$([F:ADI]CODE,2)='" + right$([F:ZAUS1]ZOFICINA,2) + "' & [F:ADI]NUMTAB=30"
  If !clalev([F:ZFGR]) Then : Local File FACGROUP [F:ZFGR] Endif
  Filter [F:ZFGR] Where CPY = [F:ZAUS1]ZCPY
  CRITERE(1) = "[F:ADI]NUMTAB=30"
  If rowcount([F:ZFGR]) > 0 Then
    Local Integer LCONT
    CRITERE(1) += " AND ("
    For [F:ZFGR]
      If LCONT = 0 Then
        CRITERE(1) += "[F:ADI]CODE='"+[F:ZFGR]FCY+"'"
      Else
        CRITERE(1) += " OR [F:ADI]CODE='"+[F:ZFGR]FCY+"'"
      Endif
      LCONT += 1
    Next
    CRITERE(1) += ")"
  Endif
#006.fin
  START = "CODE"

Return
####################################################
$SEL_RESP
  If !clalev([F:ZAUS2]) : Local File AUTILIS  [F:ZAUS2] : Endif
  Local Char ZFIC(10) : ZFIC = "AUTILIS"


  #Establecer el tÌtulo de la ventana
  Call TEXTFIC(ZFIC,"AUTILIS", 2, TIT(0)) From OBJDIV
  NBCOL = 0
  NBCOL +=1 : COL(NBCOL)="USR"          :  Gosub ZTEXTO
  NBCOL +=1 : COL(NBCOL)="LOGIN"        :  TIT(NBCOL) = "Usuario"#Gosub ZTEXTO
  NBCOL +=1 : COL(NBCOL)="ZOFICINA"     :  Gosub ZTEXTO

#006.ini
#  CRITERE = "right$(ZOFICINA,2)='"+right$([M:ZPRO0]ZFCY,2) + "'"
  CRITERE = "ZOFICINA='"+[M:ZPRO0]ZFCY+"'"
#006.fin
  ORDRE   = "[F:ZAUS2]USR"
  START = ""
  SIZLIG  = 100
  SIZCOL  = 300

  Default File [F:ZAUS2]
Return
#########################################################################
$ZTEXTO
  #Calcular el tÌtulo de la columna
  Call TEXTFIC(ZFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

#################################################
$SEL_CLI

  # Nombre del Objeto, Criterio y nombre del campo a devolver
  OBJET = "BPC"
  CRITERE(1) += "[F:BPC]BPCSTA  =2"
  START = "BPCNUM"

Return
#################################################
$SEL_ZSELGRUPYM
# JC.04082021.INICIO
  If !clalev([F:ZVGP]) Then : Local File ZVGRUPOSPRJ [F:ZVGP] : Endif
  Default File [ZVGP]
  Filter [F:ZVGP] Where LEV = 40 and PYM = [M:ZPRO2]PYM(nolign-1) and left$(GRU,3) = [M:ZPRO0]ZAREA and !find(GRU,[M:ZPRO2]GRU(0..nolign-2))
  NBCOL       = 0                                                               # n˙mero de la columna
  TIT(NBCOL)  = "Grupos"                                                        # tÌtulo de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Grupo"                                                         # tÌtulo de la primera columna
  COL(NBCOL)  = "GRU"                                                           # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "DescripciÛn"                                                   # tÌtulo de la segunda columna
  COL(NBCOL)  = "DESCRIPCION"                                                   # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Nivel"                                                         # tÌtulo de la tercera columna
  COL(NBCOL)  = "LEV"                                                           # nombre del campo a mostrar en la tercera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Pir·mide"                                                      # tÌtulo de la cuarta columna
  COL(NBCOL)  = "PYM"                                                           # nombre del campo a mostrar en la cuarta columna
# JC.04082021.FIN
Return


#######################################################################################
Subprog RESPONSABLE(P_COD)
  Value Char P_COD
  If !clalev([F:ZAXX]) : Local File ATEXTRA  [F:ZAXX] : Endif

  Filter [F:ZAXX] Where CODFIC='AUTILIS' and LANGUE='SPA' and ZONE='INTUSR' and IDENT1=P_COD
  Read [F:ZAXX]First
  If !fstat Then
    [M:ZPRO0]ZNOMBRE = [F:ZAXX]TEXTE
  Endif
  Affzo [M:ZPRO0]ZNOMBRE
End
#######################################################################################
Subprog RAZON_SOCIAL(P_COD)
  Value Char P_COD
  If !clalev([F:ZBPC1]) : Local File BPCUSTOMER  [F:ZBPC1] : Endif

  Read [F:ZBPC1]BPC0 =P_COD
  If !fstat Then
    [M:ZPRO0]ZBPCNAM = [F:ZBPC1]BPCNAM
  Endif
  Affzo [M:ZPRO0]ZBPCNAM
End

######################################################################################
## Control en el campo 'Oficina' (pantalla ZPROYECTOS0) 28/07/2022 15:30:13 (IMPAU)
######################################################################################
Subprog C_ZFCY(VALEUR)
Variable Char    VALEUR()

#006.ini
  If !clalev([F:ZFG0]) Then : Local File FACGROUP [F:ZFG0] Endif
  If !clalev([F:ZAU0]) Then : Local File AUTILIS  [F:ZAU0] Endif
  Read [F:ZAU0]CODUSR = GUSER
  If !fstat Then
    Read [F:ZFG0]FGR0 = [F:ZAU0]ZCPY;VALEUR
    If fstat <> 0 Then
      If [F:ZAU0]ZOFICINA <> VALEUR Then
        mkstat = 2
        Call ERREUR("Esta oficina no est· asociada al usuario") From GESECRAN
      Endif
    Endif
  Endif
  Close Local File [ZFG0],[ZAU0]
#006.fin

End

######################################################################################
Subprog AM_ZFCY(VALEUR)
  Variable Char    VALEUR()

  If clalev([F:ZFCY]) = 0 : Local File FACILITY [F:ZFCY] : Endif

  Read [F:ZFCY]FCY0 = VALEUR
  If !fstat Then
    [M:ZPRO0]ZCPY   = [F:ZFCY]LEGCPY
    [M:ZPRO1]FCY    = [F:ZFCY]FCY
    [M:ZPRO1]LIBFCY = [F:ZFCY]FCYNAM
  Else
    Raz [M:ZPRO0]ZCPY
    Raz [M:ZPRO1]FCY
    Raz [M:ZPRO1]LIBFCY
  Endif
  Affzo [M:ZPRO1]FCY
  Affzo [M:ZPRO0]ZCPY
  Affzo [M:ZPRO1]LIBFCY
End

######################################################################################

Subprog AM_ZCLIENTE(VALEUR)
  Variable Char    VALEUR()
  If clalev([F:ZBPC1]) = 0 : Local File BPCUSTOMER [F:ZBPC1] : Endif

  Read [F:ZBPC1]BPC0 = VALEUR
  [M:ZPRO0]ZNOMBRE =  [F:ZBPC1]BPCNAM
  ##AMG.STR bug no guardaba razÛn social
  [M:ZPRO0]ZBPCNAM = [F:ZBPC1]BPCNAM
  Affzo [M:ZPRO0]ZBPCNAM
  ##AMG.FIN
  Affzo [M:ZPRO0]ZNOMBRE
End
######################################################################################

Subprog AM_ZTIPO(VALEUR)
  Variable Integer VALEUR

  If VALEUR = 1 Then
     Actzo [M:ZPRO0]ZCLIENTE
  Else
     Diszo [M:ZPRO0]ZCLIENTE
     Raz   [M:ZPRO0]ZCLIENTE
     Raz   [M:ZPRO0]ZNOMBRE
  Endif
  Affzo [M:ZPRO0]ZCLIENTE
  Affzo [M:ZPRO0]ZNOMBRE
End

######################################################################################
## Antes de entrada al campo 'Tipo de proyecto' (pantalla ZPROYECTOS0) 04/08/2021 10:08:54 (IMPAU)
######################################################################################
Subprog AS_ZTIPO(VALEUR)
Variable Integer VALEUR
# JC.04082021.INICIO
# de momento, ocultamos los valores 'Estructura' e 'Internos'
  Raz GMENLOC
  GMENLOC(2) = 1
  GMENLOC(3) = 1
# JC.04082021.FIN
End

######################################################################################
Subprog AM_ZRESPONSABLE(VALEUR)
Variable Char    VALEUR()
  Call RESPONSABLE(VALEUR)
End


######################################################################################
