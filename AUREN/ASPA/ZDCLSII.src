#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZDCLSII
# Description : Monitor SII
# Module      : Contabilidad
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren
# Created date: 16/09/2021
############################################################################

######################################################################################
######################################################################################

$ACTION

Case ACTION
  When "INIT"   : Gosub INIT2
  When "EXEC"   : Gosub EXEC2
  When Default
Endcase

Return

$INIT2
Return

$EXEC2
If clalev([F:ZCPY])=0 : Local File COMPANY    [ZCPY] : Endif
Filter [F:ZCPY] Where [F:ZCPY]CPYLEGFLG = 2
Gosub OUVRE
For [F:ZCPY]
  [M:DSII]CPY =  [F:ZCPY]CPY
  [M:DSII]STAALL = 2
  Gosub LECTURE
  Gosub SORTIE
Next
#mes anterior
Local Date TMPDAT:Raz TMPDAT
TMPDAT=gdat$(1,month(date$),year(date$))-15
TMPDAT=gdat$(1,month(TMPDAT),year(TMPDAT))
For [F:ZCPY]
  [M:DSII]CPY =  [F:ZCPY]CPY
  [M:DSII]STAALL = 2
  [M:DSII]DATINI = TMPDAT
  [M:DSII]DATEND=gdat$(eomonth(TMPDAT))
  Gosub LECTURE
  Gosub SORTIE
Next
Filter [F:ZCPY]
Return

End

######################################################################################
## SII monitor management 06/24/2020 JUCON   CNSDCIISTD
######################################################################################
#$ACTION
#Case ACTION
#  When "OUVRE"       : Gosub OUVRE
#  When "LECTURE"     : Gosub LECTURE
#  When "SETBOUT"     : Gosub SETBOUT
#  When "SORTIE"      : Gosub SORTIE
#  When "FERME"       : Gosub SORTIE
#  When "AV_AFFICHE"  : Gosub AV_AFFICHE
#  When "SEL_TABLE"   : Gosub SEL_TABLE
#  When "SEL_LISTE"   : Gosub SEL_LISTE
#Endcase
#Return

$OUVRE
  If GSERVEUR : Onerrgo ERRBATCH : Endif

  If GSERVEUR=1 or GACTION = "ZDCLSIIM" # AUREN
    Local Mask DCLSII   [DSII]
    Local Mask DCLSII1  [DSII1]
    Local Mask DCLSII2  [DSII2]
    Local Mask DCLSII3  [DSII3]
    Local Mask DCLSII4  [DSII4]
    Local Mask DCLSII5  [DSII5]
    Local Mask DCLSII6  [DSII6]
    Local Mask DCLSII7  [DSII7]
    Local Mask DCLSIIBC [DSIIBC] # DAFER X3-212589 Consignment goods 05-11-2020
  Endif

  # Variables Declaration
  Local Date    WDATE, WDAT1, WDAT2    # Date day
  Local Char    CRITERE(250)           # Selection criteria
  Local Char    CRITERE1(250)          # Selection criteria cash
  Local Char    CRITGEN (250)          # Selection criteria for sending
  Local Char    CRITOPE(250)           # Selection criteria without site
  Local Char    CRITGEN1 (250)         # Selection criteria for sending
  Local Char    CRITGENO (250)         # Selection criteria for sending
  Local Char    MENSAJE(250)           # Log Message
  Local Char    BLOQUEO(30)            # Logic lock
  Local Char    BLOQUEOIVA(30)         # Logic VAT lock
  Local Integer OKK,I,J,STAT,AUXINT,OK

  # Tables declaration
  If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif # Companies
  If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif # Sites

  If GMODU(2)=2
    If clalev([F:DVS])=0 : Local File DCLVATSPA  [DVS] : Endif # Spanish Tax declaration working table
    If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif # Miscellaneous tables
    If clalev([F:CPS])=0 : Local File CASHPAYSPA [CPS] : Endif # Payments in cash
    If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif # BPs
    If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif # Addresses
  Endif

  If clalev([F:DSII])=0 : Local File DCLSII  [DSII] : Endif

  # Variables declaration
  Local Char AUXLNK(100), WREP(60), WEXPAPP(1)
  Local Char INICPY(5)(1..8), FINCPY(5)(1..8), INITYPENV(1)(1..8), FINTYPENV(1)(1..8), INITYPGTE(5)(1..8), FINTYPGTE(5)(1..8) # DAFER X3-212589 Consignment goods 05-11-2020
  Local Char ININUM(60)(1..8), FINNUM(60)(1..8), INILIN(2)(1..8), FINLIN(2)(1..8) # DAFER X3-212589 Consignment goods 05-11-2020
  Local Integer ICRIT, NBSITE, WTYPENV, NBREC, WNBLIN(1..8) # DAFER X3-212589 Consignment goods 05-11-2020
  Local Integer GRP
  Local Char INIFCY(5)(1..8), FINFCY(5)(1..8) # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Global Integer NOL,MAXLIG, CHGPAG, NBLU, RETOUR, SUITE, CHANGE, CHARGMT # AUREN
  NBSITE = max(1,GNBSITE)
  Local Char    TSITE(GLONFCY)(1..NBSITE)
  NBSITE = 0

  Global Integer GXX: GXX=0
  Global Integer GWSTA
  Global Integer GMODCRI: GMODCRI=0
  Global Integer GSIIEXTAP, GMETSII, GSIIFCY : GSIIEXTAP=1 # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Global Date  GFECSII
  Local Integer WFLGMOD

  Local Char WCPY(5), WVAL(1)
  Filter [CPY] Where LEG="SPA"
  Read First
  If fstat=[V]CST_AOK
    WCPY=[F:CPY]CPY
  Endif
  Filter [CPY]
  If WCPY=""
    Read [CPY] First
    WCPY=[F:CPY]CPY
  Endif

  Call PARAML(WCPY,"SIIEXTAP",WVAL) From ADOVAL
  GSIIEXTAP=val(WVAL)

  Call PARAML(WCPY,"GMETSII",WVAL) From ADOVAL
  GMETSII=val(WVAL)

  Call PARAML(WCPY,"SIIFCY",WVAL) From ADOVAL # X3-237572 SII Monitor by site by DAFER 2021-06-16
  GSIIFCY=val(WVAL)
  If GSIIFCY<>2: GSIIFCY=1: Endif

  Gosub DEFCRIT

Return

#------------------------------------------------------------------------------#
$DEFCRIT
  If GUSRFCY(1)<>"\" and GNBAUZ=1 : PARAM(1) = GUSRFCY(1) : Endif
  # Parameters
  For I=1 To dim(PARAM)
    Case I
       When 1 : # Site
                If PARAM(I)<>""
                    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
                        [M:DSII]FCY = PARAM(I)
                        [M:DSII]CPY = [F:FCY]LEGCPY
                        PARAM(2)=""
                    Endif
                Endif
            When 2 : # Company
                If PARAM(I)<>""
                    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
                    If !fstat
                        [M:DSII]CPY = PARAM(I)
                        If [M:DSII]FCY<>""
                            Call LECTURE("FCY",[M:DSII]FCY,"") From CONTOBJ
                            If [F:FCY]LEGCPY<>[M:DSII]CPY : [M:DSII]FCY="" : Endif
                        Endif
                    Endif
                Endif
            When 3 : # Initial date
                If instr(1,PARAM(I),"/")
                    [M:DSII]DATINI = "["+PARAM(I)+"]"
                Elsif PARAM(I)<>""
                    [M:DSII]DATINI  = PARAM(I)
                Endif
            When 4 : # End date
                If instr(1,PARAM(I),"/")
                    [M:DSII]DATEND = "["+PARAM(I)+"]"
                Elsif PARAM(I)<>""
                    [M:DSII]DATEND  = PARAM(I)
                Endif
            When 5 : Break
        Endcase
    Next I

    # Default values
    If [M:DSII]FCY="" & [M:DSII]CPY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
        [M:DSII]FCY = GFCYDEF
        Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
        [M:DSII]CPY = [F:FCY]LEGCPY
    Endif

    If [M:DSII]DATINI=[0/0/0] or [M:DSII]DATEND=[0/0/0] or [M:DSII]DATEND>eomonth(date$)
        [M:DSII]DATINI=gdat$(1,month(date$),year(date$))
        [M:DSII]DATEND=gdat$(eomonth(date$))
    Endif
    [M:DSII]VCRSTA=1
    [M:DSII]ALLCOM=2
    [M:DSII]STAALL=1

Return

#------------------------------------------------------------------------------#
$SETBOUT
  If [M:DSII]ALLCOM=2: Grizo [M:DSII]TYPCOM: Else Actzo [M:DSII]TYPCOM Endif
  If [M:DSII]STAALL=2: Grizo [M:DSII]VCRSTA: Else Actzo [M:DSII]VCRSTA Endif
  Affzo [M:DSII]TYPCOM, VCRSTA

 # Deactivar bot鏮 reactivar todos si no hay error filtrado
 # Deactivate button reactivate all if no error is filtered
  If [M:DSII]VCRERRNUM = ""
    Call VIREBOUT(CHAINE,"a") From GOBJET
  Endif

  If SUITE<>0
    If evalue("[M:"+ABMSK(2)+"]NBLIGR")<>0 and evalue("[M:"+ABMSK(1)+"]NBLIG")=0
      If SUITE<>1  : CHAINE += "+" : Endif : # Page +
      If RETOUR<>1 : CHAINE += "-" : Endif : # Page -
    Endif
    If SUITE<>1 : CHAINE += "D" : Endif : # Page derni鋨e
  Endif

 Return

#------------------------------------------------------------------------------#
$AV_AFFICHE
  [M:DSII1]NBLIG=NBREC
  If [M:DSII1]VCRNUM(0)=""
    Raz [M:DSII1]
  Endif
  If [M:DSII2]VCRNUM(0)=""
    Raz [M:DSII2]
  Endif
  If [M:DSII3]VCRNUM(0)=""
    Raz [M:DSII3]
  Endif
  If [M:DSII4]VCRNUM(0)=""
    Raz [M:DSII4]
  Endif
  If [M:DSII5]VCRNUM(0)=""
    Raz [M:DSII5]
  Endif
  If [M:DSII6]VCRNUM(0)=""
    Raz [M:DSII6]
  Endif
  If [M:DSII7]VCRNUM(0)=""
    Raz [M:DSII7]
  Endif
  If [M:DSIIBC]VCRNUM(0)="" # DAFER X3-212589 Consignment goods 05-11-2020
    Raz [M:DSIIBC]
  Endif
  Affzo [DSII1]1-99
  Affzo [DSII2]1-99
  Affzo [DSII3]1-99
  Affzo [DSII4]1-99
  Affzo [DSII5]1-99
  Affzo [DSII6]1-99
  Affzo [DSII7]1-99
  Affzo [DSIIBC]1-99 # DAFER X3-212589 Consignment goods 05-11-2020
Return

#------------------------------------------------------------------------------#
$LECTURE
  Local Char WMSG(250), WRECSII(2)
  Local Integer YESNO

  Raz GMESSAGE
  Gosub CONTROLE
  If GMESSAGE<>"": Errbox(GMESSAGE): Return : Endif
  GXX=1 # AUREN
  GSIIEXTAP=1 # AUREN
  #Generating records in the table
  If GXX=1 and GSIIEXTAP=1
    Raz WRECSII
    Gosub RES_DVS From TRTDCLSIISTD
  Endif
  If GXX>0 and GSIIEXTAP=1:  Gosub EXEC: Endif
  #Gosub CHANGE_MSK From GCONSULT # AUREN
  CHGPAG = 1 # AUREN
  If CHGPAG<0 : NOL = MAXLIG : Endif

  If GXX=0: GXX=1: Return: Endif  ##
  Gosub INIT
  Gosub LOAD_FILTER
  If GSIIEXTAP=2: GXX=2: Endif
  CRITGEN=CRITERE
  CRITGEN1=CRITERE1
  CRITGENO=CRITOPE
  Filter [F:DSII]

#    # ------------------------------------------------------- #
#    # CHGPAG = 1    :    Search                               #
#    # ------ = 2    :    Next                                 #
#    #        = 3    :    F5 (Update page)                     #
#    # CHGPAG = -1   :    Last                                 #
#    # ------ = -2   :    Previous (previous page)             #
#    # ------------------------------------------------------- #
   If CHGPAG > 0
    SUITE=1
    If CHGPAG = 1
      RETOUR = 1
    Elsif CHGPAG = 2
      RETOUR = 2
    Endif
    For WTYPENV=1 To 8 # DAFER X3-212589 Consignment goods 05-11-2020
      Gosub FIL_BY_MASK
    Next
  Else
    RETOUR=1
    If CHGPAG = -1
      SUITE = 1
    Else
      SUITE = 2
    Endif
    For WTYPENV=1 To 8 # DAFER X3-212589 Consignment goods 05-11-2020
      Gosub FIL_BY_MASK
    Next
  Endif

  If CHGPAG<>2 & CHGPAG<>-2 & GXX=1 : Raz [M:DSII1], [M:DSII2], [M:DSII3], [M:DSII4], [M:DSII5], [M:DSII6], [M:DSII7], [M:DSIIBC]: Endif # DAFER X3-212589 Consignment goods 05-11-2020
  NOL=-1

  Affzo [M:DSII1]
  Affzo [M:DSII2]
  Affzo [M:DSII3]
  Affzo [M:DSII4]
  Affzo [M:DSII6]
  Affzo [M:DSII5]
  Affzo [M:DSII7]
  Affzo [M:DSIIBC] # DAFER X3-212589 Consignment goods 05-11-2020
  Raz GMODCRI
Return
#------------------------------------------------------------------------------#
$INIT
   Call LECTURE("CPY",[M:DSII]CPY,"") From CONTOBJ
Return

#------------------------------------------------------------------------------#
$LOAD_FILTER
  Raz CRITERE, ICRIT, CRITERE1 # X3-237572 SII Monitor by site by DAFER 2021-06-16

  WDAT1=gdat$(1,1,year([M:DSII]DATINI))
  WDAT2=gdat$(31,12,year([M:DSII]DATINI))

  # Company/Site
  If [M:DSII]CPY<>""
    Call ADDCRIT(CRITERE,ICRIT,"CPY",'[F:DSII]CPY="'+[M:DSII]CPY+'"'," & ") From GOBJSUB
  Endif
  CRITOPE=CRITERE
  If [M:DSII]FCY<>""
    Call ADDCRIT(CRITERE,ICRIT,"FCY",'[F:DSII]FCY="'+[M:DSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:DSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITERE,ICRIT,"FCY",'find([F:DSII]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  CRITERE1=CRITERE

  # Range of dates
  If [M:DSII]DATINI<>[0/0/0]
    Call ADDCRIT(CRITERE, ICRIT,"DATINI",'[F:DSII]DATOPE>=['+format$(GFMD,[M:DSII]DATINI)+']'," & ") From GOBJSUB
    Call ADDCRIT(CRITERE1, ICRIT,"DATINI",'[F:DSII]DATOPE>=['+format$(GFMD,WDAT1)+']'," & ") From GOBJSUB
    Call ADDCRIT(CRITOPE , ICRIT,"DATINI",'[F:DSII]DATOPE>=['+format$(GFMD,WDAT1)+']'," & ") From GOBJSUB
  Endif
  If [M:DSII]DATEND<>[0/0/0]
    Call ADDCRIT(CRITERE, ICRIT,"DATEND",'[F:DSII]DATOPE<=['+format$(GFMD,[M:DSII]DATEND)+']'," & ") From GOBJSUB
    Call ADDCRIT(CRITERE1, ICRIT,"DATEND",'[F:DSII]DATOPE<=['+format$(GFMD,WDAT2)+']'," & ") From GOBJSUB
    Call ADDCRIT(CRITOPE , ICRIT,"DATEND",'[F:DSII]DATOPE<=['+format$(GFMD,WDAT2)+']'," & ") From GOBJSUB
  Endif

  # BPs
  If [M:DSII]BPR<>""
    Call ADDCRIT(CRITERE, ICRIT,"BPR",'[F:DSII]BPR="'+[M:DSII]BPR+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITERE1, ICRIT,"BPR",'[F:DSII]BPR="'+[M:DSII]BPR+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITOPE , ICRIT,"BPR",'[F:DSII]BPR="'+[M:DSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:DSII]LOT<>""
    Call ADDCRIT(CRITERE, ICRIT,"LOT",'[F:DSII]LOTNUM="'+[M:DSII]LOT+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITERE1, ICRIT,"LOT",'[F:DSII]LOTNUM="'+[M:DSII]LOT+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITOPE , ICRIT,"LOT",'[F:DSII]LOTNUM="'+[M:DSII]LOT+'"'," & ") From GOBJSUB
  Endif

  # Error number
  If [M:DSII]VCRERRNUM<>""
    Call ADDCRIT(CRITERE, ICRIT,"VCRERRNUM",'[F:DSII]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITERE1, ICRIT,"VCRERRNUM",'[F:DSII]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'," & ") From GOBJSUB
    Call ADDCRIT(CRITOPE , ICRIT,"VCRERRNUM",'[F:DSII]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:DSII]ALLCOM<>2
    Case [M:DSII]TYPCOM
      When 1: Call ADDCRIT(CRITERE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=1'," & ")  From GOBJSUB
              Call ADDCRIT(CRITERE1,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=1'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=1'," & ") From GOBJSUB
      When 2: Call ADDCRIT(CRITERE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=2'," & ")  From GOBJSUB
              Call ADDCRIT(CRITERE1,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=2'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=2'," & ") From GOBJSUB
      When 3: Call ADDCRIT(CRITERE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=3'," & ")  From GOBJSUB
              Call ADDCRIT(CRITERE1,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=3'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"TYPCOM",'[F:DSII]TYPCOM=3'," & ") From GOBJSUB
    Endcase
  Endif

 # Document status
  If [M:DSII]STAALL<>2
    Case [M:DSII]VCRSTA
      When 1: Call ADDCRIT(CRITERE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA<2'," & ")  From GOBJSUB : GWSTA=1
              Call ADDCRIT(CRITERE1,ICRIT,"VCRSTA",'[F:DSII]VCRSTA<2'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA<2'," & ") From GOBJSUB
      When 2: Call ADDCRIT(CRITERE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=2'," & ")  From GOBJSUB : GWSTA=2
              Call ADDCRIT(CRITERE1,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=2'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=2'," & ") From GOBJSUB
      When 3: Call ADDCRIT(CRITERE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=3'," & ")  From GOBJSUB : GWSTA=3
              Call ADDCRIT(CRITERE1,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=3'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=3'," & ") From GOBJSUB
      When 4: Call ADDCRIT(CRITERE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=4'," & ")  From GOBJSUB : GWSTA=4
              Call ADDCRIT(CRITERE1,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=4'," & ") From GOBJSUB
              Call ADDCRIT(CRITOPE,ICRIT,"VCRSTA",'[F:DSII]VCRSTA=4'," & ") From GOBJSUB
    Endcase
  Endif

  If GMODCRI=1 : Raz [M:DSII1], [M:DSII2], [M:DSII3], [M:DSII4], [M:DSII5], [M:DSII6], [M:DSII7], [M:DSIIBC]:  Endif # DAFER X3-212589 Consignment goods 05-11-2020

Return

######################################################################################
# Load screens                                                                       #
######################################################################################
$CARGA_XSII
  If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2
      Case [F:DSII]TYPENV
        When 1: Raz [M:DSII1]
        When 2: Raz [M:DSII2]
        When 3: Raz [M:DSII3]
        When 4: Raz [M:DSII4]
        When 5: Raz [M:DSII5]
        When 6: Raz [M:DSII6]
        When 7: Raz [M:DSII7]
        When 8: Raz [M:DSIIBC] # DAFER X3-212589 Consignment goods 05-11-2020
      Endcase
    Endif
    NBLU = 2
  Endif

  If CHGPAG > 0

    If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
      NOL    += 1
      If NOL=0
        INICPY(WTYPENV)    = [F:DSII]CPY
        INITYPENV(WTYPENV) = num$(WTYPENV)
        INITYPGTE(WTYPENV) = [F:DSII]GTE
        ININUM(WTYPENV)    = [F:DSII]VCRNUM
        INILIN(WTYPENV)    = num$([F:DSII]VCRLIN)
      Endif
      FINCPY(WTYPENV)      = [F:DSII]CPY
      FINTYPENV(WTYPENV)   = num$(WTYPENV)
      FINTYPGTE(WTYPENV)   = [F:DSII]GTE
      FINNUM(WTYPENV)      = [F:DSII]VCRNUM
      FINLIN(WTYPENV)      = num$([F:DSII]VCRLIN)
    Else
      If NOL <= 0 : RETOUR=2 : Return : Endif
        NOL    -= 1
        If NOL=MAXLIG-1
          FINCPY(WTYPENV)    = [F:DSII]CPY
          FINTYPENV(WTYPENV) = num$(WTYPENV)
          FINTYPGTE(WTYPENV) = [F:DSII]GTE
          FINNUM(WTYPENV)    = [F:DSII]VCRNUM
          FINLIN(WTYPENV)    = num$([F:DSII]VCRLIN)
        Endif
        INICPY(WTYPENV)    = [F:DSII]CPY
        INITYPENV(WTYPENV) = num$(WTYPENV)
        INITYPGTE(WTYPENV) = [F:DSII]GTE
        ININUM(WTYPENV)    = [F:DSII]VCRNUM
        INILIN(WTYPENV)    = num$([F:DSII]VCRLIN)
    Endif
    nolign = NOL+1
    Case [F:DSII]TYPENV
      When 1: [M:DSII1] =[F:DSII]:  Chgstl [M:DSII1]NBLIG(NOL) With ""
              If [M:DSII1]VCRSTA=0: [M:DSII1]VCRSTA=1: Endif
              If CHGPAG>0: NBREC=NOL+1: Else: If WNBLIN(1)=0: WNBLIN(1)=1: NBREC=NOL+1: Endif: Endif
      When 2: [M:DSII2] =[F:DSII]:  Chgstl [M:DSII2]NBLIGR(NOL) With ""
              Local Char WRESGAS(1), WRESCRE(1)
              If [M:DSII2]VCRSTA=0: [M:DSII2]VCRSTA=1: Endif
              If GSIIFCY=1 or GSIIEXTAP=2 # Begin X3-237572 SII Monitor by site by DAFER 2021-06-16
                Call PARAML([M:DSII]CPY,"SIIFGAS",WRESGAS) From ADOVAL
                Call PARAML([M:DSII]CPY,"SIIFECHCR",WRESCRE) From ADOVAL
              Else
                Call PARAML([M:DSII]FCY,"SIIFGAS",WRESGAS) From ADOVAL
                Call PARAML([M:DSII]FCY,"SIIFECHCR",WRESCRE) From ADOVAL
              Endif # End X3-237572 SII Monitor by site by DAFER 2021-06-16
              If GSIIEXTAP=1
                If val(WRESGAS)=2 or val(WRESCRE)=2: [M:DSII2]DATREGCON(NOL)=func SUBADC.DAT_DATETIME([F:DSII]DATVCRORI)
                Else
                  If [F:DVS]SCDREF<>"": [M:DSII2]DATREGCON(NOL)=[F:DVS]ACCDAT
                  Else:  [M:DSII2]DATREGCON(NOL)=[F:DSII]DATOPE
                  Endif
                Endif
              Else
                If filinfo(filpath("FIL","DOCSIINX3","fde",nomap),0)>0
                  If !clalev([DSIID]): Local File DOCSIINX3 [DSIID]: Endif
                  Read [DSIID]DSIID0=[M:DSII]CPY;2;[M:DSII2]GTE(NOL);[M:DSII2]VCRNUM(NOL);[M:DSII2]VCRLIN(NOL)
                  If fstat=[V]CST_AOK:  [M:DSII2]DATREGCON(NOL)=[F:DSIID]FECHACONT: Endif
                Endif
              Endif
              If CHGPAG>0: [M:DSII2]NBLIGR=NOL+1  : Else: If WNBLIN(2)=0: WNBLIN(2)=1: [M:DSII2]NBLIGR=NOL+1  : Endif: Endif
      When 3: [M:DSII3] =[F:DSII]
              If CHGPAG>0: [M:DSII3]NBLIGC=NOL+1  : Else: If WNBLIN(3)=0: WNBLIN(3)=1: [M:DSII3]NBLIGC=NOL+1  : Endif: Endif
      When 4: [M:DSII4] =[F:DSII]
              If CHGPAG>0: [M:DSII4]NBLIGI=NOL+1  : Else: If WNBLIN(4)=0: WNBLIN(4)=1: [M:DSII4]NBLIGI=NOL+1  : Endif: Endif
      When 5: [M:DSII5]=[F:DSII]
              If CHGPAG>0: [M:DSII5]NBLIGCA=NOL+1: Else: If WNBLIN(5)=0: WNBLIN(5)=1: [M:DSII5]NBLIGCA=NOL+1: Endif: Endif
      When 6: [M:DSII6]=[F:DSII]
              If CHGPAG>0: [M:DSII6]NBLIGPA=NOL+1: Else: If WNBLIN(6)=0: WNBLIN(6)=1: [M:DSII6]NBLIGPA=NOL+1: Endif: Endif
      When 7: [M:DSII7] =[F:DSII]:
              If CHGPAG>0: [M:DSII7]NBLIGM=NOL+1  : Else: If WNBLIN(7)=0: WNBLIN(7)=1: [M:DSII7]NBLIGM=NOL+1  : Endif: Endif
      When 8: [M:DSIIBC] =[F:DSII]: # DAFER X3-212589 Consignment goods 05-11-2020
              If CHGPAG>0: [M:DSIIBC]NBLIGBC=NOL+1  : Else: If WNBLIN(7)=0: WNBLIN(7)=1: [M:DSIIBC]NBLIGBC=NOL+1  : Endif: Endif
    Endcase

 Return

#------------------------------------------------------------------------------#
$FIL_BY_MASK
  Local Integer WAUT
  CRITGEN1="& 1=1" # Ini X3-237572 SII Monitor by site by DAFER 2021-06-16
  If GSIIFCY=2
    If [M:DSII]FCY<>""
      Call ADDCRIT(CRITGEN1,ICRIT,"FCY",'[F:DSII]FCY="'+[M:DSII]FCY+'"'," & ") From GOBJSUB
    Endif
    # Site autorization
    If GUSRFCY(1)<>"\" & ([M:DSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
      Call ADDCRIT(CRITGEN1,ICRIT,"FCY",'find([F:DSII]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
    Endif
  Endif

  Filter [F:DSII]

  Case WTYPENV    # Ini X3-237572 SII Monitor by site by DAFER 2021-06-16
    When 7, 4:       CRITERE=CRITGENO-CRITGEN1
    When Default: CRITERE=CRITGEN-CRITGEN1
  Endcase # End X3-237572 SII Monitor by site by DAFER 2021-06-16

  Case CHGPAG
    When 2 : # Next
      AUXLNK=FINCPY(WTYPENV)+FINTYPENV(WTYPENV)+FINTYPGTE(WTYPENV)+FINNUM(WTYPENV)+FINLIN(WTYPENV)
      Call ADDCRIT(CRITERE,ICRIT,"DKEY",'[F:DSII]DKEY>"'+AUXLNK+'"'," & ") From GOBJSUB
    When -2 : # Previous
      AUXLNK=INICPY(WTYPENV)+INITYPENV(WTYPENV)+INITYPGTE(WTYPENV)+ININUM(WTYPENV)+INILIN(WTYPENV)
      Call ADDCRIT(CRITERE,ICRIT,"DKEY",'[F:DSII]DKEY<"'+AUXLNK+'"'," & ") From GOBJSUB
  Endcase

  If CHGPAG > 0
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Filter [F:DSII] Where evalue(CRITERE) Order By Key DSII0
    Else
      Filter [F:DSII] Where evalue(CRITERE) Order By Key DSII2 Desc
    Endif
  Else
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Filter [F:DSII] Where evalue(CRITERE) Order By Key DSII0
    Else
      Filter [F:DSII] Where evalue(CRITERE) Order By Key DSII2 Desc
    Endif
  Endif
  Local File AMSK [WAMSK]
  ###C嫮culo MAXLIG de cada pantalla para paginaci鏮
  Case WTYPENV
    When 1: Read [WAMSK]ABRMSK="DSII1"
    When 2: Read [WAMSK]ABRMSK="DSII2"
    When 3: Read [WAMSK]ABRMSK="DSII3"
    When 4: Read [WAMSK]ABRMSK="DSII4"
    When 5: Read [WAMSK]ABRMSK="DSII5"
    When 6: Read [WAMSK]ABRMSK="DSII6"
    When 7: Read [WAMSK]ABRMSK="DSII7"
    When 8: Read [WAMSK]ABRMSK="DSIIBC" # DAFER X3-212589 Consignment goods 05-11-2020
  Endcase

  If fstat=[V]CST_AOK
    If [F:WAMSK]ACTBLOC(0)<>"":  MAXLIG=func AFNC.ACTIV([F:WAMSK]ACTBLOC(0)) Else :  MAXLIG=[F:WAMSK]NBLIGT(0): Endif
  Endif
  Close File [WAMSK]
  If CHGPAG<0 : NOL = MAXLIG : Endif
  For [F:DSII] Where TYPENV=WTYPENV With Nohint

    Raz WAUT
    If GUSRFCY(1) = "\" | find([F:DSII]FCY, GUSRFCY(1..GNBAUZ)): WAUT=1: Endif
    If GSIIEXTAP=2 | WTYPENV=3| WTYPENV=4 | WTYPENV=7 | WTYPENV=8: WAUT=1: Endif # DAFER X3-212589 Consignment goods 05-11-2020
    If WAUT=1
      Gosub CARGA_XSII
      If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
        Break
      Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
        Break
      Endif
    Endif
  Next

  NOL=-1
  Raz WNBLIN()
  Filter [F:DSII]

Return
#------------------------------------------------------------------------------#
$TERMINE
Return

#------------------------------------------------------------------------------#
$SORTIE
  If [M:DSII]CPY<>""
    BLOQUEO="DCLSII~"+[M:DSII]CPY+"~"+num$(month([M:DSII]DATINI))+num$(year([M:DSII]DATINI))
    Unlock =BLOQUEO
    Unlock =BLOQUEOIVA
    If !GSERVEUR
      TRA=1
    Else
      TRA=0
    Endif
  Endif
  #Kill GXX, GWSTA, GMODCRI, GSIIEXTAP, GMETSII, GFECSII, GSIIFCY # X3-237572 SII Monitor by site by DAFER 2021-06-16 # AUREN
  Raz GCURLEG
Return

#------------------------------------------------------------------------------#
$CONTROLE
  If [M:DSII]CPY<>""
    BLOQUEO="DCLSII~"+[M:DSII]CPY+"~"+num$(month([M:DSII]DATINI))+num$(year([M:DSII]DATINI))
    Lock =BLOQUEO With lockwait=0
    If fstat
      GMESSAGE= mess(30,100,1)   # The record is used by an other user
    Else
      Gosub CONTROL_IVA From TRTDCLSIISTD         # Controling if Spanish declaration is locked
    Endif
  Endif
Return

#------------------------------------------------------------------------------#
$EXEC
  If [M:DSII]STAALL=2 or [M:DSII]VCRSTA=1
    Gosub READ_IVA  From TRTDCLSIISTD    # Raading record of this VAT period
    If GMETSII=2
      Gosub READ_CPS  From TRTDCLSIISTD  # Reading cash records
    Endif
    Gosub MNG_CANCEL From TRTDCLSIISTD   # REading cancellations
    Gosub READ_BIENCON From TRTDCLSIISTD # Reading consignment goods // DAFER X3-212589 Consignment goods 05-11-2020
    If clalev ([GTE]): Close File [GTE]: Endif
  Endif
Return

#------------------------------------------------------------------------------#
$ERRBATCH
End

#------------------------------------------------------------------------------#
$SEL_TABLE
  If GSIIEXTAP=1
    Case COUZON
      When "BPR"
        OBJET = "BPR"
    Endcase
  Endif
Return

#------------------------------------------------------------------------------#
$SEL_LISTE
  If GSIIEXTAP=2
    Local Integer NBTEX, I, XLONG: XLONG=func AFNC.ACTIV("SIILI")
    Local Char TEX(50)(XLONG)
    Local Char TEXTE(GLONDES)(1..dim(TEX),1..2) , TIT(GLONDES)(0..2)
    Local Char CRITLIS (250)
    Raz NBTEX

    TIT(0) = mess(122,124,1)  # Table selection
    TIT(1) = mess(3,14,1)     # A/P-A/R accounting'
    TIT(2) = mess(2,697,1)    # Company name
    Local File DCLSII [WW5S]

    If [M:DSII]STAALL=2: CRITLIS="1=1"
    Else CRITLIS="VCRSTA=[M:DSII]VCRSTA"
    Endif

    For [WW5S]DSII0 Where BPR<>"" and DATINI>=[M:DSII]DATINI and DATEND<=[M:DSII]DATEND and evalue(CRITLIS)
      I=find([F:WW5S]BPR,TEXTE())
      If I=0
        NBTEX +=1
        TEX(NBTEX)       = [F:WW5S]BPR
        TEXTE(NBTEX,1)   = [F:WW5S]BPR
        TEXTE(NBTEX,2)   = [F:WW5S]BPRNAM
      Endif
    Next
    Close File [WW5S]
  Endif

Return


