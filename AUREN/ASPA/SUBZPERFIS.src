#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SUBZPERFIS
# Description : Periodos fiscales
# Module      : Contabilidad
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren
# Created date: 02/08/2021
############################################################################

######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"  : Gosub OUVRE
  When "DEBUT"  : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON

  When Default
Endcase

Return

######################################################################################
$OUVRE
######################################################################################
If !clalev([F:ADW])     : Local File ADOVAL[ADW]    : Endif
If !clalev([F:CPY])     : Local File COMPANY[CPY]   : Endif
If !clalev([F:JST])     : Local File GAJOUSTA[JST]   : Endif
Return

######################################################################################
$DEBUT
######################################################################################
Local Integer J : Raz J
Raz [M:ZPERFIS]
For [F:CPY] Where [F:CPY]CPYLEGFLG = 2
 [M:ZPERFIS]CPY(J) = [F:CPY]CPY
 Read [F:ADW]ADW0 = [F:CPY]CPY;"";"ACHSTRDAT"
 If !fstat
  [M:ZPERFIS]ZFACREC(J) = [F:ADW]VALEUR
 Endif
 Read [F:ADW]ADW0 = [F:CPY]CPY;"";"VENSTRDAT"
 If !fstat
  [M:ZPERFIS]ZFACEMI(J) = [F:ADW]VALEUR
 Endif
  J+=1
Next
[M:ZPERFIS]NBLIG = J
Affzo [M:ZPERFIS]
Return

######################################################################################
$BOUTON
######################################################################################
If BOUT = "1"
  Local Integer FQ,FCHG : FQ = 1 :FCHG = 0
  Qstbox "Se cambiaran los parámetros, continuar?" Using FQ
  If FQ = 1
    Call OUVRE_TRACE("Periodos fiscales") From LECFIC
    For I = 0 To [M:ZPERFIS]NBLIG-1
      If [M:ZPERFIS]ZFACREC(I) <> [0/0/0]
       Read [F:ADW]ADW0 = [M:ZPERFIS]CPY(I);"";"ACHSTRDAT"
       If !fstat
        If [F:ADW]VALEUR <> [M:ZPERFIS]ZFACREC(I)
          [F:ADW]VALEUR = [M:ZPERFIS]ZFACREC(I)
          Rewrite [F:ADW]
          If !fstat
            Call ECR_TRACE("Parámetro cambiado: ACHSTRDAT",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas recibidas, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACREC(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
        Endif
       Elsif fstat = 5
        Raz [F:ADW]
        [F:ADW]PARAM = "ACHSTRDAT"
        [F:ADW]CMP = [M:ZPERFIS]CPY(I)
        [F:ADW]VALEUR = [M:ZPERFIS]ZFACREC(I)
        Write [F:ADW]
        If !fstat
            Call ECR_TRACE("Parámetro cambiado: ACHSTRDAT",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas recibidas, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACREC(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
       Endif
       ##
       Read [F:ADW]ADW0 = [M:ZPERFIS]CPY(I);"";"SIIFECSII"
       If !fstat
        If [F:ADW]VALEUR <> [M:ZPERFIS]ZFACREC(I)
          [F:ADW]VALEUR = [M:ZPERFIS]ZFACREC(I)
          Rewrite [F:ADW]
          If !fstat
            Call ECR_TRACE("Parámetro cambiado: SIIFECSII",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas cierre SII, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACREC(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
        Endif
       Elsif fstat = 5
        Raz [F:ADW]
        [F:ADW]PARAM = "SIIFECSII"
        [F:ADW]CMP = [M:ZPERFIS]CPY(I)
        [F:ADW]VALEUR = [M:ZPERFIS]ZFACREC(I)
        Write [F:ADW]
        If !fstat
            Call ECR_TRACE("Parámetro cambiado: SIIFECSII",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas cierre SII, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACREC(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
       Endif
       ##
       Read [F:JST]JST0 = [M:ZPERFIS]CPY(I);"COMP"
       If !fstat
        If [F:JST]OPGSTRDAT  <> [M:ZPERFIS]ZFACREC(I)
          [F:JST]OPGSTRDAT  = [M:ZPERFIS]ZFACREC(I)
          Rewrite [F:JST]
          If !fstat
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ "  COMP, Fecha inicio apertura: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACREC(I)),0) From GESECRAN
          Endif
        Endif
       Endif
      Endif

     If [M:ZPERFIS]ZFACEMI(I) <> [0/0/0]
       Read [F:ADW]ADW0 = [M:ZPERFIS]CPY(I);"";"VENSTRDAT"
       If !fstat
        If [F:ADW]VALEUR <> [M:ZPERFIS]ZFACEMI(I)
          [F:ADW]VALEUR = [M:ZPERFIS]ZFACEMI(I)
          Rewrite [F:ADW]
          If !fstat
            Call ECR_TRACE("Parámetro cambiado: VENSTRDAT",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas emitidas, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACEMI(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
        Endif
       Elsif fstat = 5
        Raz [F:ADW]
        [F:ADW]PARAM = "VENSTRDAT"
        [F:ADW]CMP = [M:ZPERFIS]CPY(I)
        [F:ADW]VALEUR = [M:ZPERFIS]ZFACEMI(I)
        Write [F:ADW]
        If !fstat
            Call ECR_TRACE("Parámetro cambiado: VENSTRDAT",0) From GESECRAN
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ ", Facturas emitidas, fecha: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACEMI(I)),0) From GESECRAN
          Else
            Call FSTA('ADOVAL') From GLOCK
          Endif
       Endif
       Read [F:JST]JST0 = [M:ZPERFIS]CPY(I);"VENTA"
       If !fstat
        If [F:JST]OPGSTRDAT  <> [M:ZPERFIS]ZFACEMI(I)
          [F:JST]OPGSTRDAT  = [M:ZPERFIS]ZFACEMI(I)
          Rewrite [F:JST]
          If !fstat
            Call ECR_TRACE("  Sociedad: "+ [M:ZPERFIS]CPY(I)+ "  VENTA, Fecha inicio apertura: "+format$("D:DD[/]MM[/]YY",[M:ZPERFIS]ZFACEMI(I)),0) From GESECRAN
          Endif
        Endif
       Endif
     Endif
    Next
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
Gosub DEBUT
Return
