# Gestión de la máscara ZENVFAC (Especifico)
#006 JC.27072022.Adaptacion Especifico Seguridad
# 06.438.708 JC.06022023.Específico Emisión facturas AUREN - Campo Selección facturas se salta seguridad específica
########################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZENVFAC) 23/02/2021 16:39:34 (DEVAU)
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When Default
Endcase
Return

######################################################################################
$DEBUT
  [M:ZEF]ZTIPO ='FVN'
  [M:ZEF]ZPDF  = 2
  Affzo  [M:ZEF]
  ACTION=""
Return
######################################################################################
$BOUTON
  Local Integer I,YN : YN = 1
  Local Char ZENVIO(10) : Raz ZENVIO
  Case BOUT
    When "1" : Call BUSCAR()
    When "2" :
                 If [M:ZEF]ZPDF = 2 Then
                   ZENVIO = "FILE"
                   Call OUINON("żDeseas imprimir estas facturas?",YN) From GESECRAN
                 Endif
                 If [M:ZEF]ZMAIL = 2 Then
                   ZENVIO = "MESSPDF"
                   Call OUINON("żDeseas enviar esta factura por correo electrónico?",YN) From GESECRAN
                 Endif
                 If YN = 2 Then
                     For I= 0 To [M:ZEF]NBLIG - 1
                       If [M:ZEF]ZSEL(I) = 2 Then
                         Call SENDMAIL([M:ZEF]ZNUM(I),ZENVIO)
                       Endif
                     Next
                 Endif

  Endcase
  ACTION=""
Return
######################################################################################

#################################################
$SEL_TABLE

#006.ini
 If dim(COUZON)> 0 Then
   Case COUZON #Según campo
      When "ZFCY"         : Gosub SEL_FCY
   Endcase
# 06.438.708.ini
 Else
  Case TABLE
    When "ZSELENVSIH"     : Gosub SEL_ZSELENVSIH
  Endcase
# 06.438.708.fin
 Endif
#006.fin

Return

#################################################
$SEL_FCY
#006.ini
  If !clalev([F:ZAUS1]) : Local File AUTILIS  [F:ZAUS1] : Endif
  Read [F:ZAUS1]CODUSR = GUSER
##  # Nombre del Objeto, Criterio y nombre del campo a devolver
  OBJET = "ADI"
  If !clalev([F:ZFGR]) Then : Local File FACGROUP [F:ZFGR] Endif
  Filter [F:ZFGR] Where CPY = [F:ZAUS1]ZCPY
  CRITERE(1) = "[F:ADI]NUMTAB=30"
  If rowcount([F:ZFGR]) > 0 Then
    Local Integer LCONT
    CRITERE(1) += " AND ("
    For [F:ZFGR]
      If LCONT = 0 Then
        CRITERE(1) += "[F:ADI]CODE='"+[F:ZFGR]FCY+"'"
      Else
        CRITERE(1) += " OR [F:ADI]CODE='"+[F:ZFGR]FCY+"'"
      Endif
      LCONT += 1
    Next
    CRITERE(1) += ")"
  Endif
  START = "CODE"
#006.fin

Return

#################################################
$SEL_ZSELENVSIH
# 06.438.708.ini
Local Clbfile LEVALUE(2)

  If !clalev([F:ZAUS1]) : Local File AUTILIS  [F:ZAUS1] : Endif
  Read [F:ZAUS1]CODUSR = GUSER
  If !clalev([F:ZFGR]) Then : Local File FACGROUP [F:ZFGR] Endif
  Filter [F:ZFGR] Where CPY = [F:ZAUS1]ZCPY
  LEVALUE = "1=1"
  If rowcount([F:ZFGR]) > 0 Then
    Local Integer LCONT
    LEVALUE += " AND ("
    For [F:ZFGR]
      If LCONT = 0 Then
        LEVALUE += "[F:ZSIV]SALFCY='"+[F:ZFGR]FCY+"'"
      Else
        LEVALUE += " OR [F:ZSIV]SALFCY='"+[F:ZFGR]FCY+"'"
      Endif
      LCONT += 1
    Next
    LEVALUE += ")"
  Endif

  If !clalev([F:ZSIV]) Then : Local File SINVOICEV [F:ZSIV] : Endif
  Default File [F:ZSIV]
  Filter [F:ZSIV] Where evalue(LEVALUE)

  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección Facturas"                                            # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Nş factura"                                                    # título de la primera columna
  COL(NBCOL)  = "[F:ZSIV]NUM"                                                   # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Cliente facturado"                                             # título de la segunda columna
  COL(NBCOL)  = "[F:ZSIV]BPCINV"                                                # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Raz.social"                                                    # título de la tercera columna
  COL(NBCOL)  = "[F:ZSIV]BPINAM"                                                # nombre del campo a mostrar en la tercera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha factura"                                                 # título de la cuarta columna
  COL(NBCOL)  = "[F:ZSIV]INVDAT"                                                # nombre del campo a mostrar en la cuarta columna
# 06.438.708.fin
Return

######################################################################################
#Muestra facturas no contabilizadas
######################################################################################
Subprog BUSCAR()
   If !clalev([F:ZSIV1]) : Local File SINVOICEV [F:ZSIV1] : Endif
   If !clalev([F:ZAUS1]) : Local File AUTILIS   [F:ZAUS1] : Endif

   Read [F:ZAUS1]CODUSR = GUSER

   #Local Char CRITERE(250) : CRITERE = "SALFCY='"+[F:ZAUS1]ZOFICINA+"'"
#006.ini
#   Local Char CRITERE(250) : CRITERE = "right$(SALFCY,2)='"+right$([F:ZAUS1]ZOFICINA,2)+"'"
#   Local Char CRITERE(250) : CRITERE = "(SALFCY='"+[F:ZAUS1]ZOFICINA+"'"
   Local Integer LCONT
   If !clalev([F:ZFGR]) Then : Local File FACGROUP [F:ZFGR] Endif
   Filter [F:ZFGR] Where CPY = [F:ZAUS1]ZCPY
   For [ZFGR]
    If LCONT = 0 Then
      CRITERE = "(SALFCY='"+[F:ZFGR]FCY+"'"
    Else
      CRITERE -= "OR SALFCY='"+[F:ZFGR]FCY+"'"
    Endif
    LCONT += 1
   Next
   CRITERE += ")"
   Filter [F:ZFGR]
   Close Local File [ZFGR]
#006.fin
   Local Integer I : Raz I

#006.ini
   #Oficinas
   If [M:ZEF]ZFCYINI <> ''  :     CRITERE -= "&SALFCY>=[M:ZEF]ZFCYINI"  : Endif
   If [M:ZEF]ZFCYFIN <> ''  :     CRITERE -= "&SALFCY<=[M:ZEF]ZFCYFIN"  : Endif
#006.fin
   #Tipo factura
   If [M:ZEF]ZTIPO <> ''    :  [L]CRITERE -= "&SIVTYP=[M:ZEF]ZTIPO"     : Endif
   #Sociedades
   If [M:ZEF]ZCPYINI <> ''  :  [L]CRITERE -= "& CPY>=[M:ZEF]ZCPYINI"    : Endif
   If [M:ZEF]ZCPYFIN <> ''  :  [L]CRITERE -= "& CPY<=[M:ZEF]ZCPYFIN"    : Endif
   #Facturas
   If [M:ZEF]ZFACINI <> ''  :  [L]CRITERE -= "& NUM>=[M:ZEF]ZFACINI"    : Endif
   If [M:ZEF]ZFACFIN <> ''  :  [L]CRITERE -= "& NUM<=[M:ZEF]ZFACFIN"    : Endif
   #Clientes
   If [M:ZEF]ZCLIINI <> ''  :  [L]CRITERE -= "& BPCINV>=[M:ZEF]ZCLIINI" : Endif
   If [M:ZEF]ZCLIFIN <> ''  :  [L]CRITERE -= "& BPCINV<=[M:ZEF]ZCLIFIN" : Endif
   #Fechas
   If [M:ZEF]ZFECHAINI<> [0/0/0]  :  [L]CRITERE -= "& INVDAT>=[M:ZEF]ZFECHAINI" : Endif
   If [M:ZEF]ZFECHAFIN<> [0/0/0]  :  [L]CRITERE -= "& INVDAT<=[M:ZEF]ZFECHAFIN" : Endif
   #Validadas Si/No
   If [M:ZEF]ZVAL = 2 Then
      [L]CRITERE -= "&INVSTA=3"
   Else
      [L]CRITERE -= "&INVSTA<>3"
   Endif

   Filter [F:ZSIV1] Where  evalue(CRITERE)
   Read [F:ZSIV1]SIV0 First
   For [F:ZSIV1]SIV0
     [M:ZEF]ZCPY       (I) = [F:ZSIV1]CPY
     [M:ZEF]ZFCY       (I) = [F:ZSIV1]SALFCY
     [M:ZEF]ZSIVTYP    (I) = [F:ZSIV1]SIVTYP
     [M:ZEF]ZNUM       (I) = [F:ZSIV1]NUM
     [M:ZEF]ZBPCINV    (I) = [F:ZSIV1]BPCINV
     [M:ZEF]ZINVDAT    (I) = [F:ZSIV1]INVDAT
     [M:ZEF]ZINVSTA    (I) = [F:ZSIV1]INVSTA
     I+=1
     If I = 10000 Then : Break : Endif                                    #006.new
   Next
   [M:ZEF]NBLIG = I
   Affzo [M:ZEF]

End

######################################################################################
#Marca o desmarca todos los checks
#Parámetros P_VALOR:
#                    1- Desmarca
#                    2- Marca
######################################################################################

Subprog MARCAR(P_VALOR)
  Value Integer P_VALOR
  Local Integer J

  For J=0 To [M:ZEF]NBLIG - 1
     [M:ZEF]ZSEL (J) = P_VALOR
  Next
  Affzo [M:ZEF]
End

Subprog SENDMAIL(P_NUM,P_ENVIO)
  Value Char P_NUM,P_ENVIO
  Local Integer YN : YN = 1
  Local Integer NBPAR_MAX : NBPAR_MAX = 20
  Local Char TBPAR(20)(1..NBPAR_MAX)
  Local Char TBVAL(250)(1..NBPAR_MAX)
  Local Char FONCTION
  Local Char ZINFORME(50), ZDESTINO(50)
  Local Integer NBPAR
  #El alias de la tabal debe ser el estándar para que lo reconozca el WF
  If clalev([F:SIV])=0 : Local File SINVOICEV [F:SIV] : Endif
  If clalev([F:ZSIH1])=0 : Local File SINVOICE  [F:ZSIH1] : Endif
  If clalev([F:ARP])=0 : Local File AREPORT  [F:ARP] : Endif
  Read [F:ARP]ARP0 = "AURENFACTURA"
  Read [F:SIV]SIV0 = P_NUM
  Read [F:ZSIH1]SIH0 = P_NUM
  If !fstat  Then


      ZINFORME = "AURENFACTURA"
      ZDESTINO = P_ENVIO

      NBPAR += 1
      TBPAR(NBPAR) = "sitedeb"
      TBVAL(NBPAR) = [F:SIV]SALFCY

      NBPAR += 1
      TBPAR(NBPAR) = "sitefin"
      TBVAL(NBPAR) = [F:SIV]SALFCY

      NBPAR += 1
      TBPAR(NBPAR) = "facturedeb"
      TBVAL(NBPAR) = [F:SIV]NUM

      NBPAR += 1
      TBPAR(NBPAR) = "facturefin"
      TBVAL(NBPAR) = [F:SIV]NUM


      NBPAR += 1
      TBPAR(NBPAR) = "clientdeb"
      TBVAL(NBPAR) = [F:SIV]BPCINV

      NBPAR += 1
      TBPAR(NBPAR) = "clientfin"
      TBVAL(NBPAR) = [F:SIV]BPCINV

      NBPAR += 1
      TBPAR(NBPAR) = "datedeb"
      TBVAL(NBPAR) = [F:ZSIH1]ACCDAT

      NBPAR += 1
      TBPAR(NBPAR) = "datefin"
      TBVAL(NBPAR) = [F:ZSIH1]ACCDAT

      NBPAR += 1
      TBPAR(NBPAR) = "typedeb"
      TBVAL(NBPAR) = "1"

      NBPAR += 1
      TBPAR(NBPAR) = "typefin"
      TBVAL(NBPAR) = "5"

      NBPAR += 1
      TBPAR(NBPAR) = "codimp"
      TBVAL(NBPAR) = vireblc(num$([F:SIV]STARPT),4)

      NBPAR += 1
      TBPAR(NBPAR) = "usr"
      TBVAL(NBPAR) = GUSER

      NBPAR += 1
      TBPAR(NBPAR) = "nadxuid"
      TBVAL(NBPAR) = vireblc(num$(adxuid(1)),4)

      NBPAR+=1
      TBPAR(NBPAR) = "ncopias"
      TBVAL(NBPAR) = "0"

      NBPAR+=1
      TBPAR(NBPAR) = "etat"
      TBVAL(NBPAR) = [F:ARP]RPTCOD

      #The Subprog ETAT needs these parameters:
      #1 -  Name of the report (is not the name of the rpt Crystal file)
      #2 -  Name of the destination
      #3 - Language, leave this blanc to use the default language
      #4 - 0 or 1 it shows or not the info message 'print executed'
      #5 - TBPAR_BP
      #6 - TBVAL_BP
      Sleep 5
      Call ETAT(ZINFORME,ZDESTINO,"",0,"",TBPAR,TBVAL) From AIMP3

       #Marca factura como "Enviada por mail"
#        Read [F:SIV]SIV0 = [F:SIH]NUM
#        [F:SIV]ZENVMAIL = 2
#        Rewrite [F:SIV]
#
#        [M:SIH1]ZENVMAIL = [F:SIV]ZENVMAIL
#        Affzo [M:SIH1]ZENVMAI
    Endif


End

########################################################################################################
#Túnel factura
Subprog B1_NBLIG
  Local Char PARBOUT(250)(1..20)

  PARBOUT(1) = [M:ZEF]ZNUM (nolign-1)
  PARBOUT(2) = "SIH"
  PARBOUT(3) = ""
  GACTION    = "GOBJETC1"
  Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
End
########################################################################################################

#Marcar todas
Subprog B2_NBLIG
  Call MARCAR(2)
End
########################################################################################################

#Desmarcar todas
Subprog B3_NBLIG
 Call MARCAR(1)
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZENVFAC) 24/02/2021 17:31:53 (DEVAU)
######################################################################################
Subprog AM_ZPDF(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:ZEF]ZMAIL = 1
    Affzo [M:ZEF]ZMAIL
  Endif
End
######################################################################################

Subprog AM_ZMAIL(VALEUR)
Variable Integer VALEUR
 If VALEUR = 2 Then
    [M:ZEF]ZPDF = 1
    Affzo [M:ZEF]ZPDF
 Endif
End


######################################################################################
######################################################################################
## Control en el campo 'Oficina inicio' (pantalla ZENVFAC) 03/08/2022 11:37:35 (IMPAU)
######################################################################################
Subprog C_ZFCYINI(VALEUR)
Variable Char    VALEUR()

#006.ini
  If VALEUR <> '' Then
    If !clalev([F:ZFG0]) Then : Local File FACGROUP [F:ZFG0] Endif
    If !clalev([F:ZAU0]) Then : Local File AUTILIS  [F:ZAU0] Endif
    Read [F:ZAU0]CODUSR = GUSER
    If !fstat Then
      Read [F:ZFG0]FGR0 = [F:ZAU0]ZCPY;VALEUR
      If fstat <> 0 Then
        If [F:ZAU0]ZOFICINA <> VALEUR Then
          mkstat = 2
          Call ERREUR("Esta oficina no está asociada al usuario") From GESECRAN
        Endif
      Endif
    Endif
    Close Local File [ZFG0],[ZAU0]
  Endif
#006.fin

End

######################################################################################
## Control en el campo 'Oficina fin' (pantalla ZENVFAC) 03/08/2022 11:37:35 (IMPAU)
######################################################################################
Subprog C_ZFCYFIN(VALEUR)
Variable Char    VALEUR()

#006.ini
  If VALEUR <> '' Then
    If !clalev([F:ZFG0]) Then : Local File FACGROUP [F:ZFG0] Endif
    If !clalev([F:ZAU0]) Then : Local File AUTILIS  [F:ZAU0] Endif
    Read [F:ZAU0]CODUSR = GUSER
    If !fstat Then
      Read [F:ZFG0]FGR0 = [F:ZAU0]ZCPY;VALEUR
      If fstat <> 0 Then
        If [F:ZAU0]ZOFICINA <> VALEUR Then
          mkstat = 2
          Call ERREUR("Esta oficina no está asociada al usuario") From GESECRAN
        Endif
      Endif
    Endif
    Close Local File [ZFG0],[ZAU0]
  Endif
#006.fin

End
