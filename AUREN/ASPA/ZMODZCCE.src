#<AdxTL>@(#)0.0.0.0 $Revision$ 
#RESPONSABLE
If !clalev([F:ZAXX]) : Local File ATEXTRA  [F:ZAXX] : Endif
If !clalev([F:ZCEE1]) : Local File CACCE[F:ZCEE1] : Endif
If !clalev([F:ZBPC1]) : Local File BPCUSTOMER[F:ZBPC1] : Endif
 Local Integer ZCONT: Raz ZCONT
  For [F:ZCEE1]CCE0
  Filter [F:ZAXX] Where CODFIC='AUTILIS' and LANGUE='SPA' and ZONE='INTUSR' and IDENT1=[F:ZCEE1]ZRESPONSABLE
  Read [F:ZAXX]First
  If !fstat Then
     [F:ZCEE1]ZNOMBRE = [F:ZAXX]TEXTE
     Rewrite [F:ZCEE1]

     ZCONT+=1
  Endif
 Next

 Raz ZCONT

 #CLIENTES
 For [F:ZCEE1]CCE0
  Read [F:ZBPC1]BPC0 = [F:ZCEE1]ZCLIENTE
  If !fstat Then
     [F:ZCEE1]ZBPCNAM = [F:ZBPC1]BPCNAM
     Rewrite [F:ZCEE1]
   ZCONT+=1
  Endif

 Next

#Infbox num$(ZCONT)
 End
