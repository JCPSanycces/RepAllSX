#<AdxTL>@(#)0.0.0.0 $Revision$
##Cambia el nombre del pdf adjunto en facturas
$ACTION

Case ACTION
  When "REPORT" :Gosub REP
Endcase
Return
# When "PARAM" :Gosub PARAM
#When "REPORT" :Gosub REP
$REP

  If [F:ARP]RPTCOD ="AURENFACTURA" Then

      Local Char DIR(GDIMFIC),FILELIST(GDIMFIC)(1..100)
      Local Integer RES,I
      Local Char ZFICH(250),ZDIR(250),ZPATH(250),ORDRE(250) :Raz ZFICH,ZDIR,ZPATH,ORDRE
       ZFICH   = [F:SIV]BPCINV+"_"+[F:SIV]INVDAT+"_"+[F:SIV]NUM+".PDF"
       ZDIR="E:\Sage\X3PROD\folders\AURENLIVE\AURENFACTURA"

       ORDRE = "dir /b "+ZDIR+"\"+ZFICH+" 2>nul"

       Sleep 5
       Call SYSTEME2 (adxmac(0),ORDRE,"",RES,FILELIST) From ORDSYS

       If RES > 0

        For I=1 To RES

          If FILELIST(I) = ZFICH Then

           ZPATH = ZDIR+"\"+FILELIST(I)

           Call COPCLI(ZPATH,ZPATH,STAT) From ORDSYS

          Endif
        Next
      Endif
  Endif
Return
