# 06.390.286 - JC.12092022.Desarrollo especifico anticipos y provisiones a proveedores
########################################################################

$ACTION

#Infbox "mipantalla"-ACTION
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  [M:ZAC0]ZTIPO     = 1
  [M:ZAC0]ZIMPORTE  = [F:PIV]ZRESANTICIPO
  GIMPANTICIPO      = [F:PIV]ZRESANTICIPO
  Affzo [M:ZAC0]ZIMPORTE
  Affzo [M:ZAC0]ZTIPO
  Grizo [M:ZAC0]ZIMPORTE
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Despuťs de modificar el campo 'Anticipo' (pantalla ZANTVTA) 13/09/2022 11:33:59 (IMPAU)
######################################################################################
Subprog AM_ZTIPO(VALEUR)
Variable Integer VALEUR
  # total
  If VALEUR = 1 Then
    [M:ZAC0]ZIMPORTE  = [F:PIV]ZRESANTICIPO
    GIMPANTICIPO      = [F:PIV]ZRESANTICIPO
    Affzo [M:ZAC0]ZIMPORTE
    Grizo [M:ZAC0]ZIMPORTE
  # parcial
  Else
    Actzo [M:ZAC0]ZIMPORTE
  Endif

End

######################################################################################
## Despuťs de modificar el campo 'Importe' (pantalla ZANTVTA) 13/09/2022 11:39:09 (IMPAU)
######################################################################################
Subprog AM_ZIMPORTE(VALEUR)
Variable Decimal VALEUR
  If VALEUR > [F:PIV]ZRESANTICIPO Then
    mkstat = 2
    Call ERREUR("El importe no puede superar el restante del anticipo") From GESECRAN
    [M:ZAC0]ZIMPORTE  = [F:PIV]ZRESANTICIPO
    GIMPANTICIPO      = [F:PIV]ZRESANTICIPO
    Affzo [M:ZAC0]ZIMPORTE
  Else
    GIMPANTICIPO      = VALEUR
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
