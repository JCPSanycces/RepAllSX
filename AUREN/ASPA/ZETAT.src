$ALIMETAT
 Infbox ctrans(GFILPATH,"#","")
 Infbox FICHIER
  VAL_ETAT ="PRUEBA2.PDF"
Return
$ALIMETAT2
  Local Char XPARAM(250)(1..10), XPAR(50), XVAL(50), XETAT(20)

  Local Integer XNB, XK, XI


  NBPAR += 1: PARAMETRE(NBPAR) = '_ExportFile=' + chr$(1) + "PRUEBAS.PDF": # Nombre de la impresora a asignar

  For XI=1 To NBPAR

  XK = instr(1,PARAMETRE(XI),'=')

  If XK

  XPAR = left$(PARAMETRE(XI),XK-1)

  XVAL = right$(PARAMETRE(XI),XK+1)


  Case XPAR

  When '_ExportFile'

  Call SETPARAM(XPAR,NBPAR,PARAMETRE,XVAL) From ETAT

  Endcase

  Endif

  Next XI
Return
