# When "ALIMETAT" : Gosub ALIMETAT


$IMPRIME
 Infbox VAL_ETAT

 VAL_ETAT="E:\Sage\X3PROD\folders\AURENPROT2\AURENFACTURA\PRUEBAS.PDF"
