#<AdxTL>@(#)0.0.0.0 $Revision$
#Después de la cancelación contable
$ACTION
Case ACTION
  When "AFTDELVCR"     : Gosub AFTDELVCR
 When Default
Endcase
Return

$AFTDELVCR

  If !clalev([F:ZPID1]) : Local File PINVOICED   [F:ZPID1] : Endif
  If !clalev([F:ZSID1]) : Local File SINVOICED   [F:ZSID1] : Endif

  Update [F:ZPID1] Where NUM = [F:PIH]NUM and ITMREF = "000OT0004"  With ZSALDADO = 1
  Update [F:ZPID1] Where NUM = [F:PIH]NUM and ITMREF = "000OT0004"  With ZFACCLI  = ""

  #Se modifica al trazabilidad a facturas de venta

  Update [F:ZSID1] Where ZFACPROV = [F:PIH]NUM   With ZLINPROV  = 0
  Update [F:ZSID1] Where ZFACPROV = [F:PIH]NUM   With ZFACPROV  = ""
Return
