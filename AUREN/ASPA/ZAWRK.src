#Cambia el nombre del pdf adjunto en facturas
$ACTION
Case ACTION
When "MESSAGE" : Gosub MESSAGE
Endcase
Return
#When "MESSAGE" : Gosub MESSAGE
#####################################################################
$MESSAGE

 If [F:AWA]CODE = "ZSIHMAILSP" Then
   Local Char FICHIER(250),ORDRE(250),DIRTMP(250)
   Local Integer STAT
   Local Char PATH(250)
   Local Char FILELIST(GDIMFIC)(1..100)
   Local Char ZNUM(30) : Raz ZNUM

   FICHIER= filpath("","","")+"\tmp\"+ [F:SIV]BPCINV+"_"+[F:SIV]INVDAT+"_"+[F:SIV]NUM+".pdf"


   Call MOVE (PCEJOI(NBJOI),FICHIER,STAT) From ORDSYS
   PCEJOI(NBJOI)=[F:SIV]BPCINV+"_"+[F:SIV]INVDAT+"_"+[F:SIV]NUM+".pdf"
   GPE=1
   Call SEND_MAIL(FICHIER,[F:SIV]NUM)
 Endif
Return
#####################################################################

Subprog SEND_MAIL(P_PATH,P_NUM)
  Value Char P_PATH,P_NUM
  If clalev([F:ZSIV1])=0 : Local File SINVOICEV   [F:ZSIV1] : Endif
  If clalev([F:ZAUS1])=0 : Local File AUTILIS     [F:ZAUS1] : Endif
  If clalev([F:ZBPA1])=0 : Local File BPADDRESS   [F:ZBPA1] : Endif
  If clalev([F:ZBPA2])=0 : Local File BPADDRESS   [F:ZBPA2] : Endif
  Local Integer STA
  Local Integer TRACE
  Local Char FIC_TRACE(250)
  Local Char ISSUERMAIL(250)
  Local Char A_USER(250)(1..)
  Local Char CC_USER(250)(1..)
  Local Char HEADER(250)
  Local Clbfile BODY(0)
  Local Char ATTACHMENTS(250)(1..)

  Read [F:ZSIV1]SIV0 = P_NUM
  Filter  [F:ZBPA1] Where BPAADDFLG=2 and BPANUM = [F:ZSIV1]BPCINV
  Read [F:ZBPA1]BPA0 First
  If !fstat Then

      Filter [F:ZBPA2] Where BPAADDFLG=2 and BPANUM = GUSER
      Read [F:ZBPA2]BPA0 First
      If ! fstat Then
          A_USER(1)  = [F:ZBPA1]WEB(0) #destino
          CC_USER(1) = [F:ZBPA2]WEB(0) #copia
          HEADER="Factura AUREN"-P_NUM
          ISSUERMAIL = [F:ZBPA2]WEB(0)#origen
          TRACE = 2
          ATTACHMENTS(1)= P_PATH

          Append BODY , 'Apreciado/a cliente,'+chr$(10) 
          Append BODY , 'Adjunto a este correo le remitimos la factura n˙mero:' -P_NUM + '.' +chr$(10) 
          Append BODY , 'Si tiene cualquier consulta al respecto no dude en ponerse en contacto con nosotros.'+chr$(10)
          Append BODY , 'Sin otro particular, aprovecho para enviarle un cordial saludo.'+chr$(10)
          
          STA =func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,HEADER,BODY,ATTACHMENTS,TRACE)
      Endif
  Endif
  Filter  [F:ZBPA1]
  Filter  [F:ZBPA2]
End
