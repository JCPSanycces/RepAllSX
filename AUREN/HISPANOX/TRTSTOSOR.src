Subprog AV_LOT(VALEUR)
Variable Char    VALEUR()

If [M:SOR]STOCOU(nolign-1)=0
   Chgstl LOT(nolign-1) With "AWARNLOW"
Else
   Chgstl LOT(nolign-1) With ""
Endif
End

########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local    Date WDAT
WDAT = [M:SOR]DLVDAT
If WDAT=[0/0/0]
   WDAT=[M:SOR]RETDAT
Endif
Call STKCTRLOTS(VALEUR,[M:SOR]ITMREF,WDAT,[M:SOR]BPRNUM,[M:SOR]STOFCY) From STKACT
End

