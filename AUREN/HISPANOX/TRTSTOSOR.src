#<AdxTL>@(#)9.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Mask SMO0    [SMO0]
Local Mask SMO1    [SMO1]
Local Mask STOSORW [SOW]
Local Mask ALLPAR  [ALP]

Local Char PARBOUT(250)(1..6), SAVACT(20), VALEUR
PARBOUT(1) = "SMO1"
PARBOUT(2) = "0"
PARBOUT(3) = "0"
PARBOUT(4) = "A-TS140"
PARBOUT(5) = "MAR"
PARBOUT(6) = "20"
SAVACT = GACTION : GACTION = "SAISTOSOR"
Call SAISIE_CHAR(VALEUR,PARBOUT,"ISTOSOR","TRTSTOSOR","XYTRTSTOSOR") From GSAISIE
GACTION = SAVACT

End
#CHECK UNUSED_END

########################################################################
# Traitement TRTSTOSOR - Saisie des sorties                       V140 #
#                                                                      #
########################################################################
# Action SAISTOSOR
#    Paramčtres     - LABR    Abréviation masque : "SDH1" par exemple
#                   - LNOL    No ligne écran (nolign-1)
#                   - LNBL    Nombre lignes écran
#                   - LITM    Article
#                   - LFCY    Site
#                   - GVCRTYP Type de document
#
########################################################################
# Prérequis    : Ecran de stockage STOSORW [SOW] doit ętre ouvert
#
########################################################################
# Attention    : Si modifs liés au picking, penser ŕ modifier la régul.
#                (traitements TRTSHTRA et TRTSHTRP)
#
########################################################################
$ACTION

#--- Actions liées au traitement standard
Case ACTION
 When "INIT"          : Gosub INIT
Endcase

#--- Actions liées ŕ la fenętre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "BOUTON"        : Gosub BOUTON
 When "MEN"           : Gosub MENU
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
 When "RAF"           : WAFFPICK=1
 When "TIR"           : WAFFPICK=1
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE
 When "HINT"          : Gosub HINT_KEY
 When "DEB_PIC"       : Gosub DEB_PIC
 When "CRE_PIC"       : Gosub CRE_PIC
 When "ANU_PIC"       : Gosub ANU_PIC
 When "FIN_PIC"       : Gosub FIN_PIC
Endcase

Return

#########################################################################
$INIT

# Ouverture fenętre de saisie des sorties inutile --> on ressort
If GOUVSOR<>1 FIN=1 Endif

Return

#########################################################################
$OUVRE
Global Integer GSUPLIG        : # Pour identifier que l'on supprime une ligne
Global Char    GLOCCAT(4)     : # Pour filtrer les catégories d'emplacements
Global Integer GTYPLIG        : # 0=Normale / 1=Composant kit
Global Libelle GVCRTYP        : # Type de document
Global Char    GXSTA(12)      : # Stockage du filtre statut
Global Char    GCHARGRUPT(1)  : # Si "N" pas de rechargement des ruptures
Global Integer GNOLIG         : # nolign-1 (pour accés aux axes ana origines)
Global Char    GCRITPIC(250)  : # Critčre pour contrôle ligne stock pickée
Global Integer GSAISERIE      : # Pour maj picking si no séries (E/S) saisis
Global Libelle GUNTLOT        : # Mono-lot
Global Char    GSTOLOC(GLONLOC)
Global Char    GDEFLOC(GLONLOC), GDEFLOC2(GLONLOC), GDEFLOC3(GLONLOC)
Global Char    GDEFLOCTYP(GLONTLO), GDEFLOCTYP2(GLONTLO), GDEFLOCTYP3(GLONTLO)
Global Char    GLABR          : # Abréviation masque origine

Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Integer LNBL            : # Nombre lignes écran
Local Char    LITM(GLONITM)   : # Article
Local Char    LFCY(GLONFCY)   : # Site
Local Integer LRET
Local Integer I, J, K, NOL, WF
Local Integer WCHARGSOW       : # 1=chargement de SOW ŕ partir des allocations
Local Integer OKRUP           : # 1=génération de rupture
Local Integer WPICK           : # 1=depick / 2=pick
Local Integer WAFFPICK        : # 0=pas d'alimentation picking
Local Char    WTRUCOD         : # Rčgle d'allocation
Local Integer WRHGES          : # Gestion de dépôt sur le site

Local Integer LSST
Local Char    LWRH(GLONWRH)
Local Char    WSHTWRH(GLONWRH)    : # Dépôt de rupture
Local Char    WSHTLOT(GLONLOT)    : # Lot de rupture
Local Char    WSHTLOC(GLONLOC)    : # Emplacement de rupture
Local Char    WSHTLOCTYP(GLONTLO) : # Type emplacement de rupture
Local Char    WSHTECCVALMAJ(GLONECS) : # Version de rupture     #--- TS 106217
Local Char    WDEFLOC(GLONLOC), WDEFLOC2(GLONLOC), WDEFLOC3(GLONLOC)
Local Char    WDEFLOCTYP(GLONTLO), WDEFLOCTYP2(GLONTLO), WDEFLOCTYP3(GLONTLO)
Local Integer WE1, WE2, WE3, WT1, WT2, WT3, WNBL, WLOCFLT
Local Char    WCRIT(200)
Local Char    WCRITSTO(250)   : # Critčre pour chargement picking ligne stock
Local Char    WCRITSTO1(80)   : # Critčre article et site
Local Char    WCRITSTO2(80)   : # Critčre lot                   #--- TS 106217
Local Char    WCRITSTO21(40)  : # Critčre version               #--- TS 106217
Local Char    WCRITSTO3(80)   : # Critčre péremption
Local Char    WCRITSTO31(80)  : # Critčre DLU                   # hcb V6percri
Local Char    WCRITSTO4(100)  : # Critčre statuts
Local Char    WCRITSTO5(80)   : # Critčre catégorie emplacements et dépôt
Local Char    WCRITSTO6(50)   : # Critčre propriétaire du stock
Local Char    WPICKSTO(2)
Local Char    WAUZSST(30)
Local Char    PADMIN
Local Date    WDAT            : # Date de référence pour péremption
Local Integer WA, WQ, WR
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO
Local Decimal WQTY, WQTYSTU
Local Integer WGENR           : # 1 si on a enregistré , 0 sinon
Local Integer LTYPLOC, LSTA
Local Decimal LSTOCOU, LWIPQTY, LWIPQTA
Local Integer LIND1           : # Indice pour récupérer sections ana document
                                # 0 : section entęte, nolign : section ligne
Local Integer LIND2           : # Indice tableau sections analytiques
Local Char    LANA(GLONCDE)   : # Code section analytique par défaut
Local Char    SECTION
Local Integer WNBLIG, WRAFF
#DLUBPC
Local Char NBDAY(10)
#--- Issue 110327
Local Char    WNUMDEB(GLONSER)
Local Char    WNUMFIN(GLONSER)
Local Integer WNBSER
#---
Raz WGENR
Raz GSAISERIE

If clalev([F:ITG])=0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]   Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]   Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STA])=0  Local File STOALL     [STA]   Endif
If clalev([F:STL])=0  Local File STOLOT     [STL]   Endif
If clalev([F:STO])=0  Local File STOCK      [STO]   Endif
If clalev([F:STS])=0  Local File STOSER     [STS]   Endif
If clalev([F:SWW])=0  Local File STOWIPW    [SWW]   Endif
#--- TS 106217
If clalev([F:ECS])=0  Local File ECCSTA     [ECS]   Endif
#--- X3-53322
If clalev([F:LPN])=0  Local File LPN        [LPN]   Endif
If GWRHACT=2
   If clalev([F:ITW])=0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
Endif
#DLUBPC
If clalev([F:ITU])=0  Local File ITMBPC    [ITU]   Endif

# Récupération paramčtre administrateur stock
Call PARAMUTIL("STOADMIN",PADMIN,"","") From SUBAUS
GSTOADMIN = val(PADMIN)

# Récupération des paramčtres
LABR    = PARAM(1)
LNOL    = val(PARAM(2))
LNBL    = val(PARAM(3))
LITM    = PARAM(4)
LFCY    = PARAM(5)
GVCRTYP = val(PARAM(6))

GLABR  = LABR
GNOLIG = LNOL

#------------------------------------------------------------------------
# Resynchro des qtés en cours de traitement pour l'article et le site
#------------------------------------------------------------------------
Local Char  WPARAM(250)(1..20)
WPARAM(1) = LITM
WPARAM(2) = LFCY
Call TRAITE_NUM(GBIDD1,WPARAM,"","FUNSTOWIPW","",1,"XYFUNSTOWIPW") From GTRAITE
#------------------------------------------------------------------------

#--- Lecture article
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call ERREUR(LITM-":"-mess(134,100,1)) From GESECRAN
      FIN=1 : Return
   Endif
Endif
#--- Lecture article site
If LFCY<>"" & ([F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY)
   Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
   If fstat
      Call ERREUR(LITM-":"-mess(2,196,1)-":"-LFCY) From GESECRAN
      FIN=1 : Return
   Endif
Endif

# Passage en invisible des zones stock selon l'article
Gosub FORMAT_INV From STKLIB
#--- Issue 110678
# Rajout de la couleur : "c" et du mode affiché : "P"
#Call DYNAMIC(GWSINVLOT,":","c;") From TEXTE
#GWSINVLOT=ctrans(GWSINVLOT,";",":")
#Call DYNAMIC(GWSINVSLO,":","c;") From TEXTE
#GWSINVSLO=ctrans(GWSINVSLO,";",":")
#Call DYNAMIC(GWSINVEMP,":","c;") From TEXTE
#GWSINVEMP=ctrans(GWSINVEMP,";",":")
#Call DYNAMIC(GWSINVSER,":","c;") From TEXTE
#GWSINVSER=ctrans(GWSINVSER,";",":")
#Call DYNAMIC(GWSINVSERF,":","c;") From TEXTE
#GWSINVSERF=ctrans(GWSINVSERF,";",":")
#Call DYNAMIC(GWSINVWRH,":","c;") From TEXTE
#GWSINVWRH=ctrans(GWSINVWRH,";",":")
#--- TS 106217
#Call DYNAMIC(GWSINVECCMAJ,":","c;") From TEXTE
#GWSINVECCMAJ=ctrans(GWSINVECCMAJ,";",":")
#Call DYNAMIC(GWSINVECCMIN,":","c;") From TEXTE
#GWSINVECCMIN=ctrans(GWSINVECCMIN,";",":")
#---

# Passage en invisible des quantités en UA si non géré en titre
If [F:ITF]STOMGTCOD>2
   GSINVACT = "NPz:"+GUNTFMT
Else
   GSINVACT = "-NPz:"+GUNTFMT
Endif

# Passage en invisible des quantités en UA si non géré en titre
#If [F:ITM]STOMGTCOD>2
#   GSINVACT = "NPz:"+GUNTFMT
#   Call TEXTE(19667,GSINTACT1) From OBJDIV
#   Call TEXTE(19668,GSINTACT2) From OBJDIV
#   Call TEXTE(23370,GSINTACT3) From OBJDIV
#Else
#   GSINVACT = "-NPz:"+GUNTFMT
#   Raz GSINTACT1, GSINTACT2, GSINTACT3
#Endif

# Passage en invisible des quantités physiques si non géré en titre
#If [F:ITM]STOMGTCOD>2
#   GSINVPHY  = "NPz:"+GUNTFMT
#   Call TEXTE(23687,GSINTPHY1) From OBJDIV
#   Call TEXTE(23688,GSINTPHY2) From OBJDIV
#Else
#   GSINVPHY  = "-NPz:"+GUNTFMT
#   Raz GSINTPHY1, GSINTPHY2
#Endif

Return

#########################################################################
$OUVRE_BOITE
#--- Issue 110327
# Récupération des noms de currbox des tiroirs
Global Char  GBOXSTO(10),GBOXSTS(10)
GBOXSTO = "GAU_CHE1"
GBOXSTS = "GAU_CHE2"
# OBJLIS n'est pas connu ???
#GBOXSTO = "GAU_CHE"+num$(find("STO",OBJLIS(1..8)))
#GBOXSTS = "GAU_CHE"+num$(find("STS",OBJLIS(1..8)))
#---
Return

#########################################################################
$DEBUT
#-----------------------------------------------------------------------
# Traitement ŕ alimenter pour les différentes fonctions
# Chargement des blocs 1 et 2 de [M:SOR]
#-----------------------------------------------------------------------
Raz GTYPLIG, WF
Raz [M:SOR]

Gosub CHARGE_PARAM From TRTSTOSORA

If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

Call LECITM(LFCY,LITM,"",0,[M:SOR]XWRH,LRET) From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

GPOINT="MODISSPAR" : Gosub ENTREE From EXEFNC

#--- Issue 110327
If [F:ITM]SERMGTCOD>1 & fix([M:SOR]SORQTY)<>[M:SOR]SORQTY
   Call ERREUR(mess(470,197,1)) From GESECRAN
   FIN=1 : Return
Endif
#---

[M:SOR]ITMREF = LITM
[M:SOR]STOFCY = LFCY
#--- Bug 65418
#[M:SOR]VCRTYP = GVCRTYP
If [M:SOR]VCRTYP=0 : [M:SOR]VCRTYP=GVCRTYP : Endif
#---
If GERR | FIN Return Endif

# Stockage du lot de rupture
Raz WSHTLOT
If [M:SOR]XLOT<>"*" WSHTLOT=[M:SOR]XLOT Endif

# Stockage du dépôt de rupture
WSHTWRH = [M:SOR]XWRH

# Dépôt obligatoire ou renseigné sur ligne document --> non modifiable
If [M:SOR]XWRH<>""
   [M:SOR]WRHOBY=2
Else
   [M:SOR]WRHOBY=1
   LSST=0
   # Sous-traitance
   If (find([M:SOR]VCRTYP,10,12) & [M:SOR]PECSCOLOC=2)
&   |([M:SOR]VCRTYP=34 & [M:ALP]LOCCAT=4)
      LSST=1
   Endif
   # Alimentation dépôt exclusif article-site pour filtrer le stock
   Call WRHAUTO([M:SOR]STOFCY,[M:SOR]ITMREF,[M:SOR]VCRTYP,LSST,LWRH) From STKWRH
   If !find(LWRH,"","*")
      [M:SOR]XWRH = LWRH
   Endif
Endif

# Stockage du filtre statut
GXSTA = [M:SOR]XSTA

# Si non renseigné car ajouté 05.08
If [M:SOR]PECINTLOC=0 [M:SOR]PECINTLOC=2 Endif
# Filtre catégorie emplacement pour le contrôle et la sélection emplacement
Raz GLOCCAT
If [M:SOR]PECINTLOC=2 GLOCCAT+="1" Endif
If [M:SOR]PECPLFLOC=2 GLOCCAT+="2" Endif
If [M:SOR]PECSCOLOC=2 GLOCCAT+="4" Endif

# Par défaut, pas d'affichage des lignes de stock indisponibles
[M:SOR]STODISFLG=1

# Si ligne existante(déjŕ créée) ou en cours de saisie(fin de ligne éxécutée)
# on regarde si [M:SOW] est déjŕ chargé,
# dans le cas contraire on l'alimente ŕ partir des allocations
#If evalue("[M:"+LABR+"]CREFLG(LNOL)")<>0 |
#& (evalue("[M:"+LABR+"]CREFLG(LNOL)") =0 & evalue("[M:"+LABR+"]UPDFLG(LNOL)")<>0)

# Le [SOW] est-il déjŕ chargé pour cette ligne ?
WCHARGSOW=1
If [M:SOR]WSTOSEQ<>0 & [M:SOW]NBLIG>0
   For I=0 To [M:SOW]NBLIG-1
      If [M:SOW]WSTOSEQ(I)=[M:SOR]WSTOSEQ
         Raz WCHARGSOW
         Break
      Endif
   Next I
Endif

# Il n'est pas déjŕ chargé --> on l'alimente ŕ partir des allocations
If WCHARGSOW=1
   Raz [M:ALP] : Transmask [M:SOR] To [M:ALP]  # Issue 25606_Transmask [M:ALP] = [M:SOR]
   [M:ALP]VCRSEQ = 0
   [M:ALP]TYPQTY = 2
   [M:ALP]QTY    = [M:SOR]SORQTYACT
   [M:ALP]STA    = [M:SOR]XSTA
   [M:ALP]WRH    = [M:SOR]XWRH
   [M:ALP]BESDAT = [M:SOR]RETDAT
   # Chargement STOSORW ŕ partir des allocations
   Call ALLSTOSORW(LABR,LNOL,LNBL,1,0,0,LRET) From STKSOR
   If LRET<>0
      FIN=1 : Return
   Endif
Endif

#TS TEST####################
# Ligne en cours de saisie (fin de ligne non exécuté)
#Else
#   If evalue("[M:"+LABR+"]WSTOSEQ(LNOL)")=0
#      Local Integer LLIG
#      # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
#      Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
#      If LRET<>0
#         FIN=1 : Return
#      Endif
#   Endif
#FIN TS TEST####################

#Endif

[M:SOR]WSTOSEQ = evalue("[M:"+LABR+"]WSTOSEQ(LNOL)")

# Récupération ou initialisation des sections ana dans [SOW]
# S'il y a déjŕ des lignes de stock chargées dans [SOW]
If LABR<>""
   Case LABR
    When "SDH1"               : LANA="STKLIV"
    When "SIH4"               : LANA="STKFAC"
    When "PNH1"               : LANA="STKPRT"
    When "SMO1","DBY0","BBY1" : LANA="STJSOR"
    When "MTK3","MBM"         : LANA="STKSOF"
    When "SRE9","ITN8"        : LANA="STKHDT"
   Endcase
   Call STKINISEC ([M:SOR]WSTOSEQ,LANA,"SOW") From STKECR
Endif

# Alimentation des sections analytiques dans [SOR]
Raz J
If [M:SOW]NBLIG2>0
   For I=0 To [M:SOW]NBLIG2-1
      If [M:SOW]WSTOSEQ2(I)=[M:SOR]WSTOSEQ
         For J=1 To GNBDIE
            [M:SOR]CCE(J-1) = evalue("[M:SOW]CCE"+num$(J)+"(I)")
         Next J
         Break
      Endif
   Next I
Endif

# Pas de section ana dans [SOW], il faut les alimenter dans [SOR]
If J=0 & LABR<>""
   Case LABR
    When "SDH1"               : LANA="STKLIV"
    When "SIH4"               : LANA="STKFAC"
    When "PNH1"               : LANA="STKPRT"
    When "SMO1","DBY0","BBY1" : LANA="STJSOR"
    When "MTK3","MBM"         : LANA="STKSOF"
    When "SRE9","ITN8"        : LANA="STKHDT"
   Endcase
   For I=1 To GNBDIE
#      GAXE=I
      Call INISEC(SECTION,LANA,I) From TRTX3CPT
      [M:SOR]CCE(I-1) = SECTION
   Next I
Endif

# Alimentation du masque STOSOR
GCHARGRUPT = ""
Gosub ALI_MSK_SOR

If FIN=1 Return Endif

If [M:SOR]NBLIG>0
   Affzo [M:SOR]1-99
Else
   # Artifice (affichage du tableau) afin de traiter les colonnes invisibles
   [M:SOR]NBLIG=1
   Affzo [M:SOR]1-99
   Effzo [M:SOR]15
   # Si rien dans le filtre issu du document origine, on charge avec la saisie
   # de la ligne du document (uniquement lot et emplacement et sauf si "$")
   If evalue("dim([M:"+LABR+"]LOT(LNOL))")>0
      If [M:SOR]XLOT="" & evalue("[M:"+LABR+"]LOT("+num$(LNOL)+")")<>"$"
         [M:SOR]XLOT = evalue("[M:"+LABR+"]LOT("+num$(LNOL)+")")
      Endif
   Endif
   If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
      If [M:SOR]XLOC="" & evalue("[M:"+LABR+"]LOC("+num$(LNOL)+")")<>"$"
         [M:SOR]XLOC = evalue("[M:"+LABR+"]LOC("+num$(LNOL)+")")
      Endif
   Endif
Endif

# Positionnement de l'état du champ 'Total physique'
If [M:SOR]STOMGTCOD>2
   Diszo [M:SOR]PECQTY
Else
   Grizo [M:SOR]PECQTY
Endif

Gosub ETA_MSK_SOR

#------------------------------------------------------
# Chargement du filtre lignes de stock pour le picking
#------------------------------------------------------
# Récupération de la rčgle d'allocation
Case [M:SOR]VCRTYP

 When 3,4,5,8        : # Préparation/Livraison sous-traitance
                       If [M:SOR]TRSTYP=20
                          WTRUCOD = [F:ITG]ALLRULSCO
                       # Préparation, Livraison, Facture, Retour fou
                       Else
                          WTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 6              : # Réception (conso matičres sous-traitance)
                       WTRUCOD = [F:ITG]ALLRULSCC
 When 12             : # Suivi matičre (opération de sous-traitance)
                       If [M:SOR]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matičre (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       WTRUCOD = [F:ITG]ALLRULTRF
 When 34             : # Réappro zones de consommation
                       If [M:ALP]LOCCAT=4
                          WTRUCOD = [F:ITG]ALLRULSCO
                       Else
                          WTRUCOD = [F:ITG]ALLRULTRF
                       Endif
 When Default
Endcase

GUNTLOT=1
Raz [F:TRU]
# Lecture rčgle d'allocation
If WTRUCOD<>""
   Read [TRU]TRU0=WTRUCOD
   If fstat
      Raz WTRUCOD
   Else
      GUNTLOT=[F:TRU]UNTLOT
   Endif
Endif

# Stockage ordre des lots (FIFO par défaut) pour picking lignes de stock
If WTRUCOD<>""
   [M:SOR]LOTMGT=[F:TRU]LOTMGT
Else
   [M:SOR]LOTMGT=2
Endif

# Lecture de la rčgle de gestion ŕ utiliser
Call LECSRU([M:SOR]STOFCY,[F:ITM]TCLCOD,[M:SOR]TRSTYP,[M:SOR]TRSCOD,"",LRET)
&           From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

#--- TS 106217
# Stockage de la version de rupture si exclusivité
If [F:SRU]ORDVER=2
  WSHTECCVALMAJ = [M:SOR]WECCVALMAJ
Else
  WSHTECCVALMAJ = ""
Endif
#---

Raz WSHTLOC, WSHTLOCTYP

# Si rčgle d'allocation/sortie
If WTRUCOD<>""

   # Récupération types emplacement ou emplacement par défaut
   # de l'article-site pour le type mouvement
   #--- Issue 110327
   #Gosub ALI_DEFLOC From STKALL
   Gosub ALI_DEFLOC From STKALF
   #---

   # Détermination du nombre de ligne de la rčgle
   I = find(0,[F:TRU]LOCFLT(0..dim([F:TRU]LOCFLT)-1))
   If I=0
      WNBL = dim([F:TRU]LOCFLT)
   Else
      WNBL = I-1
   Endif
   If min([F:TRU]LOCFLT(0..WNBL-1))>1
      # Si sortie OF ou EO et emplacement local renseigné
      If find([M:SOR]TRSTYP,6,29)
         If [M:SOR]STOLOC<>""
            # Si emp local exclusif sans joker on le stocke pour les ruptures
            If max([F:TRU]LOCFLT)=2
&            & !instr(1,[M:SOR]STOLOC,'*') & !instr(1,[M:SOR]STOLOC,'?')
&            & !instr(1,[M:SOR]STOLOC,'!') & !instr(1,[M:SOR]STOLOC,'#')
               WSHTLOC=[M:SOR]STOLOC
            Endif
            # Emp local dans les rčgles, mais non exclusif --> c'est fini
            If min([F:TRU]LOCFLT)=2 WF=1 Endif
         Endif
      Endif
      If WSHTLOC="" & WF<>1

         # I,J et K contiennent la 1čre position des catégories emp 1,2 et 3
         # dans le tableau des rčgles d'allocation (0 si absent)
         I = find(3,[F:TRU]LOCFLT(0..WNBL-1))
         J = find(4,[F:TRU]LOCFLT(0..WNBL-1))
         K = find(5,[F:TRU]LOCFLT(0..WNBL-1))
         # WE1,WE2 et WE3 contiennent 1 si emp par défaut 1,2 et 3
         Raz WE1, WE2, WE3
         If WDEFLOC <>"" & !instr(1,WDEFLOC,'*')  & !instr(1,WDEFLOC,'?')
&                        & !instr(1,WDEFLOC,'!')  & !instr(1,WDEFLOC,'#')
            WE1=1
         Endif
         If WDEFLOC2<>"" & !instr(1,WDEFLOC2,'*') & !instr(1,WDEFLOC2,'?')
&                        & !instr(1,WDEFLOC2,'!') & !instr(1,WDEFLOC2,'#')
            WE2=1
         Endif
         If WDEFLOC3<>"" & !instr(1,WDEFLOC3,'*') & !instr(1,WDEFLOC3,'?')
&                        & !instr(1,WDEFLOC3,'!') & !instr(1,WDEFLOC3,'#')
            WE3=1
         Endif
         # WT1,WT2 et WT3 contiennent 1 si type emp par défaut 1,2 et 3
         Raz WT1, WT2, WT3
         If WDEFLOCTYP <>"" & !instr(1,WDEFLOCTYP,'*') &!instr(1,WDEFLOCTYP,'?')
&                           & !instr(1,WDEFLOCTYP,'!') &!instr(1,WDEFLOCTYP,'#')
            WT1=1
         Endif
         If WDEFLOCTYP2<>"" & !instr(1,WDEFLOCTYP2,'*')&!instr(1,WDEFLOCTYP2,'?')
&                           & !instr(1,WDEFLOCTYP2,'!')&!instr(1,WDEFLOCTYP2,'#')
            WT2=1
         Endif
         If WDEFLOCTYP3<>"" & !instr(1,WDEFLOCTYP3,'*')&!instr(1,WDEFLOCTYP3,'?')
&                           & !instr(1,WDEFLOCTYP3,'!')&!instr(1,WDEFLOCTYP3,'#')
            WT3=1
         Endif

         # WLOCFLT contient la valeur max des catégories d'emp (3,4 ou 5)
         WLOCFLT = max([F:TRU]LOCFLT)

         # Exploitation des rčgles d'allocation pour déterminer
         # le type ou l'emplacement de rupture
         #--- Issue 110327
         #Gosub ALI_LOCATION From STKALL
         Gosub ALI_LOCATION From STKALF
         #---
      Endif
   Endif

   # Chargement des (types) emplacements de l'article-site paramétrés
   # dans la rčgle d'allocation/sortie pour filtrer le picking stock
   Call RECH_DEFLOCTYP("SOR") From STKALL

Endif

#-------------------------------
# Positionnement filtre picking
#-------------------------------
Raz GCRITPIC, WCRIT, WCRITSTO
Raz WCRITSTO1, WCRITSTO2, WCRITSTO3, WCRITSTO31, WCRITSTO4, WCRITSTO5, WCRITSTO6                # hcb v6percri

# Article et site
WCRITSTO1 = '[F:STO]ITMREF=[M:SOR]ITMREF&[F:STO]STOFCY=[M:SOR]STOFCY'

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:SOR]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:SOR]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif

#DLU Client, calcul du nbre de jours ŕ retrancher ŕ la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif


# Lot et péremption
If dim([M:SOR]XLOT)>0
   # hcb V6dlu nouvelle gestion
   WCRITSTO3  = '([F:STL]SHLDAT=[0/0/0]|'
   WCRITSTO31 = '([F:STL]DLUDAT=[0/0/0]|'
   If [M:SOR]DLVDAT<>[0/0/0]
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:SOR]DLVDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:SOR]DLVDAT)'
   Else
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:SOR]RETDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:SOR]RETDAT)'
   Endif
   If [F:SRU]SHLLOT=1
      GCRITPIC  = WCRITSTO3
   Elsif [F:SRU]SHLLOT=2
      GCRITPIC  = WCRITSTO31
   Endif
   If !find([M:SOR]XLOT,"","*")
      WCRITSTO2 = 'pat([F:STO]LOT,[M:SOR]XLOT)<>0'
   Endif
   #--- TS 106217
   # Si version renseignée et exclusive
   If [M:SOR]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
      WCRITSTO21 = '[F:STO]ECCVALMAJ=[M:SOR]WECCVALMAJ'
   Endif
   #---
Endif

# Catégorie emplacement et dépôt
If [M:SOR]PECINTLOC=2
   If [M:SOR]PECPLFLOC=2
      WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
      If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
   Else
      WCRITSTO5 = '[F:STO]LOCCAT=1'
      If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
   Endif
Elsif [M:SOR]PECPLFLOC=2
   WCRITSTO5 = '[F:STO]LOCCAT=2'
   If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
Endif
If [M:SOR]PECSCOLOC=2
   If WCRITSTO5=""
      WCRITSTO5  = '[F:STO]LOCCAT=4'
   Else
      WCRITSTO5 += '|[F:STO]LOCCAT=4'
   Endif
Elsif WCRITSTO5=""
   # Pour ne rien avoir (paramétrage incohérent)
   WCRITSTO5 = '[F:STO]LOCCAT=9'
Endif

# Propriétaire
If [M:SOR]PECOWNER=""
   [M:SOR]OWNFLG=2 : [M:SOR]NOTOWNFLG=1
   WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
Else
   [M:SOR]OWNFLG=2 : [M:SOR]NOTOWNFLG=2
   WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SOR]PECOWNER)'
Endif

# Si réappro des zones de consommation,
# restriction des s-statuts autorisés (emplacement)
# par ceux de la rčgle de gestion
If [M:SOR]VCRTYP=34
   Call STKAUZSST([F:SRU]AUZSST,[M:SOR]AUZSST,WAUZSST) From STKECR2
   [F:SRU]AUZSST = WAUZSST
   # Construction de la formule :
   Call DECODE_STAT([F:SRU]AUZSST,[F:SRU]FORSTA) From TRTCATEG
Endif

Raz WA, WQ, WR
# Statuts autorisés par les rčgles de gestion d'E/S
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif

[M:SOR]XSTA=vireblc([M:SOR]XSTA,4)

# Si statuts renseignés dans filtre allocation
If !find([M:SOR]XSTA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:SOR]XSTA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable ŕ tester
   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
# Sinon prise en compte des sous-statuts autorisés
Elsif !find([F:SRU]AUZSST,"","*")
   Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG

#--- Issue 121665
# Incompatibilité entre s-statuts de la rčgle de gestion et ceux de l'emp réappro
# --> on prend ceux de l'emp réappro et on filtre pour ne pas avoir de stock ok
Elsif [M:SOR]VCRTYP=34 & [F:SRU]AUZSST=""
   [F:SRU]AUZSST = [M:SOR]AUZSST
   Call DECODE_STAT([F:SRU]AUZSST,[F:SRU]FORSTA) From TRTCATEG
   WCRITSTO4="pat([F:STO]STA,'')<>0"
#--- End TS

Endif

WCRITSTOA = 'pat([F:STO]STA,"A*")<>0'
WCRITSTOQ = 'pat([F:STO]STA,"Q*")<>0'
WCRITSTOR = 'pat([F:STO]STA,"R*")<>0'

# Alimentation des zones de la fenętre critčre et du filtre
# pour contrôle ligne stock pickée (si non administrateur stock)
[M:SOR]AUZSST=[F:SRU]AUZSST
[M:SOR]FORSTA=[F:SRU]FORSTA
[M:SOR]AAASTA=1
[M:SOR]QQQSTA=1
[M:SOR]RRRSTA=1

# hcb V6percri deb
[M:SOR]FLGSHLLOT = 2
[M:SOR]FLGDLULOT = 2
If [F:SRU]SHLLOT = 2
   [M:SOR]FLGSHLLOT = 1
   [M:SOR]FLGDLULOT = 1
Endif
If [F:SRU]SHLLOT = 1
   [M:SOR]FLGSHLLOT = 1
   [M:SOR]FLGDLULOT = 2
Endif
# hcb V6percri fin

Raz WCRIT
If WA=1
   WCRIT+='pat([F:STO]STA,"A*")<>0'
   [M:SOR]AAASTA=2
Endif
If WQ=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"Q*")<>0'
   [M:SOR]QQQSTA=2
Endif
If WR=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"R*")<>0'
   [M:SOR]RRRSTA=2
Endif

If WCRITSTO4<>""
   If GCRITPIC<>""
      GCRITPIC+='&('+WCRITSTO4+')'
   Else
      GCRITPIC+=WCRITSTO4
   Endif
Elsif GCRITPIC<>""
   If WCRIT<>""
      GCRITPIC+='&('+WCRIT+')'
   Endif
Else
   If WCRIT<>""
      GCRITPIC+=WCRIT
   Else
      GCRITPIC='1=1'
   Endif
Endif

Raz WAFFPICK
# Affichage liste picking si qté rupture ou qté restant ŕ sortir
If [M:SOR]SHTQTY<>0 | [M:SOR]SHTQTY+[M:SOR]PECQTYACT<[M:SOR]SORQTYACT
   WAFFPICK=1
Endif
Gosub TIROIR


If [M:SOR]VCRTYP=34 & GCONSULT = 2
   Affzo [M:SOR]
   Diszo [M:SOR]
Endif

Return

#########################################################################
$ALI_MSK_SOR

Local Decimal WORIALLSTU, WORIALLPCU, WENCALLSTU
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Integer WRET, WMAX, I1, I2

Raz [M:SOR]PECQTY, [M:SOR]PECQTYACT, [M:SOR]SHTQTY, [M:SOR]PECQTYORI

[M:SOR]COEFUCUS  = " ="+format$("N:5.4",[M:SOR]PCUSTUCOE)-[M:SOR]STU
[M:SOR]STOMGTCOD = [F:ITF]STOMGTCOD
[M:SOR]NEGSTO    = [F:ITM]NEGSTO
[M:SOR]SERMGTCOD = [F:ITM]SERMGTCOD

# Nb de lignes maximum du tableau [SOR]
WMAX = dim([M:SOR]STOCOU)

NOL=0
If [M:SOW]NBLIG<=0 Goto ALI_MSK_SOR_FIN Endif

For I=0 To [M:SOW]NBLIG-1
   # Nb max de lignes atteint
   If NOL>=WMAX
      Goto ALI_MSK_SOR_SUI
   Endif
   # Si rupture et pas de chargement des ruptures
   If [M:SOW]WSTOCOU(I)=0 & dim(GCHARGRUPT)>0 & GCHARGRUPT="N"
      Goto NEXT_SOW
   Endif

   If [M:SOW]WSTOSEQ(I)=[M:SOR]WSTOSEQ
      [M:SOR]ICOMVTATT(NOL) = ""
      [M:SOR]STOCOU(NOL)    = [M:SOW]WSTOCOU(I)
      [M:SOR]QTYSTU(NOL)    = [M:SOW]WQTYSTU(I)
      [M:SOR]QTYSTUORI(NOL) = [M:SOW]WQTYSTU(I)
      [M:SOR]QTYSTUACT(NOL) = [M:SOW]WQTYSTUACT(I)
      If [M:SOR]STOCOU(NOL)<>0
         [M:SOR]PECQTY     += [M:SOW]WQTYSTU(I)
         [M:SOR]PECQTYACT  += [M:SOW]WQTYSTUACT(I)
         [M:SOR]PECQTYORI  += [M:SOW]WQTYSTUACT(I)
      Else
         [M:SOR]SHTQTY     += [M:SOW]WQTYSTUACT(I)
      Endif
      [M:SOR]ALLSTU(NOL)    = [M:SOW]WALLSTU(I)
      [M:SOR]ALLSTUACT(NOL) = [M:SOW]WALLSTUACT(I)

      # Si mouvement en attente
      If [M:SOR]STOCOU(NOL)=0
         [M:SOR]ICOMVTATT(NOL) = "247"
         If dim([M:SOR]LOT)>0 [M:SOR]LOT(NOL)=[M:SOW]WLOT(I) Endif
         If dim([M:SOR]SLO)>0 [M:SOR]SLO(NOL)=[M:SOW]WSLO(I) Endif
         If dim([M:SOR]LOC)>0 [M:SOR]LOC(NOL)=[M:SOW]WLOC(I) Endif
         If dim([M:SOR]WRH)>0 [M:SOR]WRH(NOL)=[M:SOW]WWRH(I) Endif
         #--- TS 106217
         If dim([M:SOR]ECCVALMAJ)>0 [M:SOR]ECCVALMAJ(NOL)=[M:SOW]WECCVALMAJ(I) Endif
         #---
         [M:SOR]STA(NOL)=[M:SOW]WSTA(I)
         If dim([M:SOR]SERNUM)>0
            # No série de rupture
            [M:SOR]SERNUM(NOL)=[M:SOW]WSERNUM(I)
            If [M:SOW]WSERNUM(I)<>""
               WNB = [M:SOW]WQTYSTUACT(I)
               If WNB = 1
                  [M:SOR]SERNUMF(NOL) = [M:SOW]WSERNUM(I)
               Else
                  Call PLUS_NB([M:SOR]SERNUM(NOL),WNB,[M:SOR]SERNUMF(NOL),WRET)
&                              From STKLIB
                  If WRET<>0
                     Raz [M:SOR]SERNUM(NOL), [M:SOR]SERNUMF(NOL)
                  Endif
               Endif
            Endif
         Endif
         Raz [M:SOR]SERNUMFLG(NOL)
         Raz [M:SOR]AVAQTYPCU(NOL),[M:SOR]AVAQTYSTU(NOL),[M:SOR]TOTQTYSTU(NOL)
         Raz [M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL),[M:SOR]XPCUSTUCOE(NOL)
         If dim([M:SOR]SHLDAT)>0 Raz [M:SOR]SHLDAT(NOL) Endif
         If dim([M:SOR]POT)>0    Raz [M:SOR]POT(NOL)    Endif
         Goto ALI_MSK_SOR_SUI
      Endif
      Read [STO]STO0=[M:SOR]STOFCY;[M:SOR]STOCOU(NOL)
      If fstat Goto NEXT_SOW Endif

      If dim([M:SOR]LOT)>0
         [M:SOR]LOT(NOL) = [F:STO]LOT
         If dim([M:SOR]SLO)>0 [M:SOR]SLO(NOL)=[F:STO]SLO Endif
         Read [STL]STL0=[M:SOR]ITMREF;[F:STO]LOT;[F:STO]SLO
         If fstat
            Call ERREUR([F:STO]LOT-[F:STO]SLO-":"-mess(123,199,1)-[M:SOR]ITMREF)
&                From GESECRAN
            Goto NEXT_SOW
         Endif
         If dim([M:SOR]SHLDAT)>0 [M:SOR]SHLDAT(NOL)=[F:STL]SHLDAT Endif
         If dim([M:SOR]POT)>0
            If [M:SOR]STOMGTCOD=3
               [M:SOR]POT(NOL) = [F:STL]POT
            Elsif [M:SOR]STOMGTCOD=4
               [M:SOR]POT(NOL) = [F:STL]ACT
            Endif
         Endif
      Endif
      #--- TS 106217
      If dim([M:SOR]ECCVALMAJ)>0 [M:SOR]ECCVALMAJ(NOL)=[F:STO]ECCVALMAJ Endif
      If dim([M:SOR]ECCVALMIN)>0 [M:SOR]ECCVALMIN(NOL)=[F:STL]ECCVALMIN Endif
      #---
      If dim([M:SOR]WRH)>0     [M:SOR]WRH(NOL) = [F:STO]WRH  Endif
      If dim([M:SOR]LOC)>0     [M:SOR]LOC(NOL) = [F:STO]LOC  Endif
      If dim([M:SOR]SERNUM)>0
         [M:SOR]SERNUM(NOL)  = [F:STO]SERNUM
         [M:SOR]SERNUMF(NOL) = [F:STO]SERNUM
         # Si pas de no série sur la ligne de stock et no dans STOSORW
         # récupération dans STOSOR (cas des no gérés en sortie et saisis)
         # ou cas des no série gérés en E/S globale saisis									: #--- Issue 110327
         If [M:SOR]SERNUM(NOL) = ""
            [M:SOR]SERNUM(NOL)=[M:SOW]WSERNUM(I)
            If [M:SOW]WSERNUM(I)<>""
               WNB = [M:SOW]WQTYSTUACT(I)
               If WNB = 1
                  [M:SOR]SERNUMF(NOL) = [M:SOW]WSERNUM(I)
               Else
                  Call PLUS_NB([M:SOR]SERNUM(NOL),WNB,[M:SOR]SERNUMF(NOL),WRET)
&                              From STKLIB
                  If WRET<>0
                     Raz [M:SOR]SERNUM(NOL), [M:SOR]SERNUMF(NOL)
                  Endif
               Endif
            Endif
         Endif
      Endif
      # Ligne de stock avec no série ?
      Raz [M:SOR]SERNUMFLG(NOL)
      If [F:STO]SERNUM<>"" [M:SOR]SERNUMFLG(NOL)=1 Endif

      #--- Issue X3-53322
      If dim([M:SOR]LPNNUM)>0 [M:SOR]LPNNUM(NOL)=[F:STO]LPNNUM  Endif
      #---
      If dim([M:SOR]PALNUM)>0 [M:SOR]PALNUM(NOL)=[F:STO]PALNUM  Endif
      If dim([M:SOR]CTRNUM)>0 [M:SOR]CTRNUM(NOL)=[F:STO]CTRNUM  Endif
      [M:SOR]OWNER(NOL)     = [F:STO]OWNER
      [M:SOR]STA(NOL)       = [F:STO]STA
      [M:SOR]XPCU(NOL)      = [F:STO]PCU
      [M:SOR]XPCUSTUCOE(NOL)= [F:STO]PCUSTUCOE
      If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
      [M:SOR]QTYPCU(NOL)    = [M:SOR]QTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
      Call QTEARR([M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV

      If dim([M:SOR]STOFLD1)>0 [M:SOR]STOFLD1(NOL)= [F:STO]STOFLD1 Endif
      If dim([M:SOR]STOFLD2)>0 [M:SOR]STOFLD2(NOL)= [F:STO]STOFLD2 Endif

      # Si plan de rangement, la quantité allouée est disponible
      If GLABR="REO1"
         #--- Issue 95050
         # Si la liste ŕ ranger existe déjŕ, ne pas ajouter la qté traitée
         If [M:SOR]VCRNUM<>"" & [M:SOR]VCRLIN<>0
            [M:SOR]AVAQTYSTU(NOL) = [F:STO]QTYSTU - [F:STO]CUMWIPQTY
         Else
            [M:SOR]AVAQTYSTU(NOL) = [F:STO]QTYSTU - [F:STO]CUMWIPQTY + [M:SOR]QTYSTU(NOL)
         Endif
         #[M:SOR]AVAQTYSTU(NOL) = [F:STO]QTYSTU - [F:STO]CUMWIPQTY + [M:SOR]QTYSTU(NOL)
         #---
         [M:SOR]AVAQTYPCU(NOL) = [M:SOR]AVAQTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
         Call QTEARR([M:SOR]AVAQTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV
      Else
         # Calcul du disponible pour sortie sur la ligne de stock
         Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
         # On rajoute la quantité sortie de la ligne au disponible
         [M:SOR]AVAQTYSTU(NOL) = WSTUDIS + [M:SOR]QTYSTU(NOL)
         [M:SOR]AVAQTYPCU(NOL) = WPCUDIS + [M:SOR]QTYPCU(NOL)
      Endif
      [M:SOR]TOTQTYSTU(NOL) = [F:STO]QTYSTU

      #--- Bug 41947
      # Si pičce origine, calcul de la quantité allouée non consommée
      Raz WORIALLSTU, WORIALLPCU
      If [M:SOR]VCRTYPORI<>0 & [M:SOR]VCRNUMORI<>"" & [M:SOR]VCRLINORI<>0
         For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYPORI & VCRNUM=[M:SOR]VCRNUMORI &
&                            VCRLIN=[M:SOR]VCRLINORI & VCRSEQ=[M:SOR]VCRSEQORI &
&                            STOCOU=[F:STO]STOCOU
            WORIALLSTU += [F:STA]QTYSTU
         Next
         WORIALLSTU -= [M:SOR]ALLSTU(NOL)
      Endif
      # Si quantité allouée non consommée, rajout sur le disponible
      If WORIALLSTU>0
         WORIALLPCU = WORIALLSTU/[M:SOR]XPCUSTUCOE(NOL)
         Call QTEARR(WORIALLPCU,[M:SOR]XPCU(NOL)) From TRTDIV
         [M:SOR]AVAQTYSTU(NOL) += WORIALLSTU
         [M:SOR]AVAQTYPCU(NOL) += WORIALLPCU
      Endif

      # Si la pičce d'origine a déjŕ été sélectionnée au cours de cette transaction
      # il faut déduire les allocations déjŕ en cours de traitement
      # --> détermination de la quantité allouée réellement disponible
      If [M:SOR]TWSTOSEQ(0)<>0
         WENCALLSTU = 0
         K=0
         While [M:SOR]TWSTOSEQ(K)<>0 & K<dim([M:SOR]TWSTOSEQ)
            WENCALLSTU+=sigma(L=0,[M:SOW]NBLIG-1,[M:SOW]WALLSTU(L)
&                       *( [M:SOW]WSTOCOU(L)=[F:STO]STOCOU&[M:SOW]WSTOSEQ(L)=[M:SOR]TWSTOSEQ(K)))
            K+=1
         Wend
         [M:SOR]AVAQTYSTU(NOL)-=WENCALLSTU
         [M:SOR]AVAQTYPCU(NOL) = [M:SOR]AVAQTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
         Call QTEARR([M:SOR]AVAQTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV
      Endif
      #---

      $ALI_MSK_SOR_SUI

      # Transfert zones de l'écran STOSORW vers l'écran STOSOR
      GPOINT="SOW_SOR" : Gosub ENTREE From EXEFNC

      NOL += 1
   Endif

   $NEXT_SOW
Next I

$ALI_MSK_SOR_FIN

# Tableau chargé
If NOL<WMAX
   [M:SOR]NBLIG = NOL
# Nombre mouvements ŕ charger (NOL) > Nombre de lignes maxi du tableau (WMAX)
# Veuillez modifier le code activité SLS pour pouvoir modifier les mouvements
Else
   I1   = instr(1,mess(69,184,1),"%")
   I2   = instr(I1+1,mess(69,184,1),"%")
   WMES = left$(mess(69,184,1),I1-1)+num$(NOL)+mid$(mess(69,184,1),I1+1,I2-I1-1)
&         +num$(WMAX)+right$(mess(69,184,1),I2+1)
   Call ERREUR(WMES+chr$(13)+mess(71,184,1)) From GESECRAN
   Effzo [M:SOR]1-99
   FIN = 1
Endif

Return

#########################################################################
$ETA_MSK_SOR

# Pas d'accés  si reappro type zone de consommation
If (LABR="REO1" & find([M:REO1]ORIREO(LNOL),2))
   Diszo [M:SOR]1-99
Endif

# Si pas de ligne, on se casse
If [M:SOR]NBLIG=0 Return Endif

If dim([M:SOR]WRH)>0
   If WRHGES=2
      Diszo [M:SOR]WRH
   Else
      Grizo [M:SOR]WRH
   Endif
Endif
If dim([M:SOR]LOT)>0    Diszo [M:SOR]LOT    Endif
If dim([M:SOR]SLO)>0    Diszo [M:SOR]SLO    Endif
If dim([M:SOR]LOC)>0    Diszo [M:SOR]LOC    Endif
If dim([M:SOR]PALNUM)>0 Diszo [M:SOR]PALNUM Endif
If dim([M:SOR]CTRNUM)>0 Diszo [M:SOR]CTRNUM Endif
If dim([M:SOR]STOFLD1)>0 Diszo [M:SOR]STOFLD1 Endif
If dim([M:SOR]STOFLD2)>0 Diszo [M:SOR]STOFLD2 Endif
#--- TS 106217
If dim([M:SOR]ECCVALMAJ)>0 Diszo [M:SOR]ECCVALMAJ Endif
#--- Issue X3-53322
If dim([M:SOR]LPNNUM)>0    Diszo [M:SOR]LPNNUM    Endif

# Si no séries gérés en sortie
If [M:SOR]SERMGTCOD=2
   Actzo [M:SOR]QTYSTU
   Actzo [M:SOR]QTYPCU
   If dim([M:SOR]SERNUM)>0
      Actzo [M:SOR]SERNUM

      #--- Bug 85510
      # Si trf inter-site et intra-société, ou BP non livrable
      # pas de saisie des no séries
      #If [M:SOR]TRFFCY<>"" & [M:SOR]BETCPY<>2 Diszo [M:SOR]SERNUM Endif
      If ([M:SOR]TRFFCY<>"" & [M:SOR]BETCPY<>2) | [M:SOR]FLGSAISER=1
         Diszo [M:SOR]SERNUM
      Endif
      #---

   Endif
   Diszo [M:SOR]STA
# Si no séries gérés en E/S
Elsif [M:SOR]SERMGTCOD=3
   Diszo [M:SOR]QTYSTU
   Diszo [M:SOR]QTYPCU
   If dim([M:SOR]SERNUM)>0 Diszo [M:SOR]SERNUM Endif
   Diszo [M:SOR]STA
#--- Issue 110327
# Si no séries gérés en E/S globale
Elsif [M:SOR]SERMGTCOD=4
   Actzo [M:SOR]QTYSTU
   Diszo [M:SOR]QTYPCU
   If dim([M:SOR]SERNUM)>0 Actzo [M:SOR]SERNUM Endif
   Diszo [M:SOR]STA
#---
Else
   Actzo [M:SOR]QTYSTU
   Actzo [M:SOR]QTYPCU
   If dim([M:SOR]SERNUM)>0 Diszo [M:SOR]SERNUM Endif
   Diszo [M:SOR]STA
Endif

# Si no séries gérés en sortie et (no série existant ou retour fournisseur)
# ou si mouvement en attente, on boucle sur le tableau pour affiner l'état
If ([M:SOR]SERMGTCOD=2 & ([M:SOR]VCRTYP=8 | sigma(NOL=0,[M:SOR]NBLIG-1,[M:SOR]SERNUMFLG(NOL)=1)>0))
&  | sigma(NOL=0,[M:SOR]NBLIG-1,[M:SOR]STOCOU(NOL)=0)>0
   For NOL=0 To [M:SOR]NBLIG-1
      # Si mouvement en attente
      If [M:SOR]STOCOU(NOL)=0
         Actzo [M:SOR]QTYSTU(NOL) : Affzo [M:SOR]QTYSTU(NOL)
         Diszo [M:SOR]QTYPCU(NOL) : Affzo [M:SOR]QTYPCU(NOL)
         If dim([M:SOR]LOT)>0
            Actzo [M:SOR]LOT(NOL)
            If [M:SOR]LOT(NOL)<>"" Affzo [M:SOR]LOT(NOL) Endif
         Endif
         If dim([M:SOR]SLO)>0
            Actzo [M:SOR]SLO(NOL)
            If [M:SOR]SLO(NOL)<>"" Affzo [M:SOR]SLO(NOL) Endif
         Endif
         If dim([M:SOR]WRH)>0
            If WRHGES=2
               If [M:SOR]XWRH=""
                  Actzo [M:SOR]WRH(NOL)
               Else
                  If [M:SOR]WRHOBY=2
                     Diszo [M:SOR]WRH(NOL)
                  Else
                     Actzo [M:SOR]WRH(NOL)
                  Endif
                  [M:SOR]WRH(NOL)=[M:SOR]XWRH
               Endif
               If [M:SOR]WRH(NOL)<>"" Affzo [M:SOR]WRH(NOL) Endif
            Else
               Grizo [M:SOR]WRH(NOL)
            Endif
         Endif
         #--- TS 106217
         If dim([M:SOR]ECCVALMAJ)>0
            #--- Si version exclusive et renseignée, pas de modification
            If [M:SOR]ECCVALMAJ(NOL)<>"" & [F:SRU]ORDVER=2
               Diszo [M:SOR]ECCVALMAJ(NOL)
            Else
               Actzo [M:SOR]ECCVALMAJ(NOL)
            Endif
            Affzo [M:SOR]ECCVALMAJ(NOL)
         Endif
         #---
         If dim([M:SOR]LOC)>0
            Actzo [M:SOR]LOC(NOL)
            If [M:SOR]LOC(NOL)<>"" Affzo [M:SOR]LOC(NOL) Endif
         Endif
         If dim([M:SOR]SERNUM)>0
            # Si no série géré en sortie, pas de saisie
            # car problčme pour régulariser par la suite
            If [M:SOR]SERMGTCOD=2
               Diszo [M:SOR]SERNUM(NOL)
            Else
               Actzo [M:SOR]SERNUM(NOL)
            Endif
            If [M:SOR]SERNUM(NOL)<>"" Affzo [M:SOR]SERNUM(NOL) Endif
         Endif
         Actzo [M:SOR]STA(NOL)
         If [M:SOR]STA(NOL)<>"" Affzo [M:SOR]STA(NOL) Endif
      # Si no séries gérés en sortie
      Elsif [M:SOR]SERMGTCOD=2 & dim([M:SOR]SERNUM)>0
         # Si no série existant ou retour fournisseur, pas de saisie
         If [M:SOR]SERNUMFLG(NOL)=1 | [M:SOR]VCRTYP=8
            Diszo [M:SOR]QTYSTU(NOL)
            Diszo [M:SOR]QTYPCU(NOL)
            Diszo [M:SOR]SERNUM(NOL)
         Endif
      Endif
   Next NOL
Endif

Return

#########################################################################
$SETBOUT

# Pour interdire la navigation
GREP="M"

If !find("=",CHBOU) CHBOU+="=" Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif
# Pas de Raz si pas de ligne
If [M:SOR]NBLIG=0
   Call VIREBOUT(CHMEN,"3") From GOBJET
Endif
# Pas de proposition si qte origine (hors rupture) >= qte ŕ sortir
If [M:SOR]PECQTYORI >= [M:SOR]SORQTYACT
   Call VIREBOUT(CHMEN,"1") From GOBJET
Endif

# Si no série non géré en E/S ou plus de quantité ŕ traiter
# pas de saisie des no série ŕ sortir
#--- Issue 110327
#If [M:SOR]SERMGTCOD<>3 | [M:SOR]SORQTYACT=[M:SOR]PECQTYACT+[M:SOR]SHTQTY
If [M:SOR]SERMGTCOD<3 | [M:SOR]SORQTYACT=[M:SOR]PECQTYACT+[M:SOR]SHTQTY
#---
   Call VIREBOUT(CHMEN,"K") From GOBJET
Endif
# Si livraison de pręt ou de sous-traitance ou plan de réappro,
# pas de sortie d'un stock manquant
If (LABR="SDH1" & ([M:SDH0]LND=2 | (dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2))) | LABR="REO1"
   Call VIREBOUT(CHMEN,"L") From GOBJET
Endif
# Si stock négatif interdit, pas de sortie d'un stock manquant
#--- dem 61614
#If [M:SOR]NEGSTO<>2 | [M:SOR]PECQTYACT+[M:SOR]SHTQTY>=[M:SOR]SORQTYACT
If ([M:SOR]TRSTYP<>4 & [M:SOR]NEGSTO<>2) | ([M:SOR]TRSTYP=4 & GSHTDLV<3) |
&   [M:SOR]PECQTYACT+[M:SOR]SHTQTY>=[M:SOR]SORQTYACT
   Call VIREBOUT(CHMEN,"L") From GOBJET
Endif
# Pas de sections analytiques si invisible
If [M:SOR]CCECODS=3
   Call VIREBOUT(CHMEN,"M") From GOBJET
Endif

Return

#########################################################################
$APRES_MODIF
Local Integer I,J,K
NOL = nolign-1

#--- 110327
If find(COUZON,"SERNUM","QTYSTU","QTYPCU")
   GSAISERIE=1
Endif
#---

# Raffraichissement du picking suite ŕ saisie des no série (E/S)
If GSAISERIE=1
   Gosub TIROIR
Endif

# Si suppression d'une ligne, raffraichissement du picking
If GSUPLIG=65 & [M:SOR]STOCOU(nolign-1)<>0
   # Plusieurs lignes ont-elles le męme chrono stock ?
   K=sigma(J=0,[M:SOR]NBLIG-1,(1*([M:SOR]STOCOU(J)=[M:SOR]STOCOU(NOL))))
   # Si chrono stock unique, on dépicke
   If K=1
      Read [STO]STO0=[M:SOR]STOFCY;[M:SOR]STOCOU(NOL)
      If !fstat
         Read [STL]STL0=[M:SOR]ITMREF;[F:STO]LOT;[F:STO]SLO
         If !fstat
            If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
         Endif
      Endif
   Endif
Endif

# Si suppression de n lignes, raffraichissement du picking
If find(GSUPLIG,68,83)
   For I=nolign-1 To nolign1-1
      If [M:SOR]STOCOU(I)<>0
         # Plusieurs lignes ont-elles le męme chrono stock ?
         K=sigma(J=0,[M:SOR]NBLIG-1,(1*([M:SOR]STOCOU(J)=[M:SOR]STOCOU(I))))
         # Si chrono stock unique, on dépicke
         If K=1
            Read [STO]STO0=[M:SOR]STOFCY;[M:SOR]STOCOU(I)
            If !fstat
               Read [STL]STL0=[M:SOR]ITMREF;[F:STO]LOT;[F:STO]SLO
               If !fstat
                  If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
               Endif
            Endif
         Endif
      Endif
   Next I
Endif

Raz GSUPLIG, GSAISERIE

Return

#########################################################################
$AVANT_ENR
OKRUP=0

# Pas de ligne saisie
#If [M:SOR]NBLIG = 0
#   GMESSAGE = mess(61,199,1)
#   GERR=1 : FOK=0 : Return
#Endif

# Si on est sur un bon de préparation
If find(LABR,"PREP","PRH1")

   # Si quantité totale > quantité ŕ sortir
   If [M:SOR]PECQTYACT+[M:SOR]SHTQTY > [M:SOR]SORQTYACT
      GMESSAGE = mess(465,199,1)
      GERR=1 : FOK=0
   # Sinon si quantité totale < quantité ŕ sortir
   Elsif [M:SOR]PECQTYACT+[M:SOR]SHTQTY < [M:SOR]SORQTYACT
      # Si composant de kit
      If GTYPLIG=1
         GMESSAGE = mess(427,199,1)
         GERR=1 : FOK=0 : Return
      Endif
      # Si la qtée sélectionnée est nulle et on avait de l'allocation globale
      If [M:SOR]PECQTYACT+[M:SOR]SHTQTY = 0 & [M:SOR]GLOALLQTY+[M:SOR]GLOSHTQTY > 0
         # Ligne de prépa allouée en global et pas de stock sélectionné
         # L'enregistrement n'est pas possible
         GMESSAGE = mess(329,184,1)
         GERR=1 : FOK=0 : Return
      Endif
      # Non par défaut
      OK=0
      # Si bon de prépa livrable (on génčre une rupture selon)
      If (LABR="PRH1" & [M:PRH1]DLVFLG>1) | (LABR="PREP" & [M:PREP]DLVFLG(LNOL)>1)
         # Si stock négatif autorisé
         If [M:SOR]NEGSTO=2
            # Voulez-vous générer une rupture ?
            GMESSAGE=mess(395,199,1)
            Call OUINON(GMESSAGE,OK) From GESECRAN
            If OK<>2
               FOK=0
            Else
               OKRUP=1
            Endif
         Else
            # La qtée sélectionnée est < ŕ la qté ŕ traiter
            GMESSAGE = mess(466,199,1)
            GERR=1 : FOK=0 : Return
         Endif
      # Si bon de prépa en cours (on génčre toujours une rupture)
      Else
         # Voulez-vous enregistrer ?
         GMESSAGE=mess(390,199,1)
         Call OUINON(GMESSAGE,OK) From GESECRAN
         If OK<>2
            FOK=0
         Else
            OKRUP=1
         Endif
      Endif
      Raz GMESSAGE
   Endif
   Return

Endif

# Si no série en sortie sans compteur
If [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU=""
   #--- Bug 70723
   #MAE, le 27/09/2010, bg 67175, si inter-site et intra-société, pas de n° série a saisir
   #If [M:SOR]TRFFCY="" & [M:SOR]BETCPY=2
   # Contrôle si (pas intersite ou pas intersociété) et pas retour fournisseur
   #--- Bug 83893
   #If ([M:SOR]TRFFCY="" | [M:SOR]BETCPY=2) & LABR<>"PNH1"
   If ([M:SOR]TRFFCY="" | [M:SOR]BETCPY=2) & !find(LABR,"PNH1","REO1")
   #---
      If find("",[M:SOR]SERNUM(0..[M:SOR]NBLIG-1))
         # Les no série n'ont pas été renseignés
         GMESSAGE = mess(312,184,1)
         GERR=1 : FOK=0 : Return
      Endif
   Endif
Endif

#--- Issue 110327
# Si no série en E/S globale
If [F:ITM]SERMGTCOD=4
  If find("",[M:SOR]SERNUM(0..[M:SOR]NBLIG-1))
    # Les no série n'ont pas été renseignés
    GMESSAGE = mess(312,184,1)
    GERR=1 : FOK=0 : Return
  Endif
Endif
#---

# Si no séries gérés en sortie ou E/S globale,				: #--- Issue 110327
# contrôle de cohérence, entre les différentes lignes (pas de colision entre no)
#--- Issue 110327
#If [F:ITM]SERMGTCOD=2 & [M:SOR]NBLIG>1
If find([F:ITM]SERMGTCOD,2,4) & [M:SOR]NBLIG>1
#---
   If clalev([M:SOM])=0  Local Mask STOSORM  [SOM]  Endif
   Default Mask [SOR]
   J=0
   # Alimentation des no début et fin dans l'écran [SOM] pour tri
   For I=0 To [M:SOR]NBLIG-1
      If [M:SOR]SERNUM(I)<>""
         [M:SOM]SERNUM(J)  = [M:SOR]SERNUM(I)
         [M:SOM]SERNUMF(J) = [M:SOR]SERNUMF(I)
         J+=1
      Endif
   Next I
   [M:SOM]NBLIG = J
   If [M:SOM]NBLIG>1
      # Tri des no séries
      Sorta [M:SOM]NBLIG [M:SOM]SERNUM,[M:SOM]SERNUMF
      J=0
      For J=1 To [M:SOM]NBLIG-1
         If [M:SOM]SERNUMF(J-1)>=[M:SOM]SERNUM(J)
            # Des no série sont présents plusieurs fois
            #--- Issue 110327
            #GMESSAGE = mess(464,199,1)
            GMESSAGE = mess(464,199,1)-[M:SOM]SERNUM(J)-"-->"-[M:SOM]SERNUMF(J-1)
            #---
            GERR=1 : FOK=0 : Break
         Endif
      Next J
      If GERR=1 Return Endif
   Endif
Endif

# Si article géré en titre ou en UI, ou plan de réappro
# on permet de ne pas respecter la qté ŕ sortir
If find([M:SOR]STOMGTCOD,3,4) | LABR="REO1"
   # Si quantité totale > quantité ŕ sortir, confirmer vous la saisie ?
   If [M:SOR]PECQTYACT+[M:SOR]SHTQTY > [M:SOR]SORQTYACT
      GMESSAGE = mess(465,199,1)+"\"+mess(623,196,1)
      # Non par défaut
      OK=0
      Call OUINON(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      # Saisie non confirmée
      If OK<>2 FOK=0 Endif
   # Sinon si quantité totale < quantité ŕ sortir
   Elsif [M:SOR]PECQTYACT+[M:SOR]SHTQTY < [M:SOR]SORQTYACT
      # Si livraison de pręt ou sous-traitance, pas de sortie d'un stock manquant
      If LABR="SDH1" & ([M:SDH0]LND=2 | (dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2))
         # La quantité sélectionnée ne peut ętre inférieure ŕ la qté ŕ traiter ?
         GMESSAGE=mess(509,199,1)
         GERR=1 : FOK=0
      # Sinon si stock négatif autorisé, et pas plan de réappro
      # générer rupture ou confirmer saisie ?
      Elsif [M:SOR]NEGSTO=2 & LABR<>"REO1"
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "DIVCHX1"
         PARMSK(1) = "466"
         PARMSK(2) = "199"
         Call SAISIE_NUM(VALEUR,PARMSK,"ICHX1","STKECR2","") From GSAISIE
         GACTION = SAVACT
         # Génération rupture
         If PARMSK(3)="A"
            OKRUP=1
         # Saisie non confirmée
         Elsif PARMSK(3)<>"B"
            FOK=0
         Endif
      # Sinon confirmez-vous la saisie ?
      Else
         GMESSAGE = mess(466,199,1)+"\"+mess(623,196,1)
         # Non par défaut
         OK=0
         Call OUINON(GMESSAGE,OK) From GESECRAN
         Raz GMESSAGE
         # Saisie non confirmée
         If OK<>2 FOK=0 Endif
      Endif
   Endif
# Si article non géré en titre ou en UI, et pas plan de réappro
Else
   # Si quantité totale > quantité ŕ sortir
   If [M:SOR]PECQTYACT+[M:SOR]SHTQTY > [M:SOR]SORQTYACT
      GMESSAGE = mess(465,199,1)
      GERR=1 : FOK=0
   # Sinon si quantité totale < quantité ŕ sortir
   Elsif [M:SOR]PECQTYACT+[M:SOR]SHTQTY < [M:SOR]SORQTYACT
      # Si composant de kit
      If GTYPLIG=1
         GMESSAGE = mess(427,199,1)
         GERR=1 : FOK=0 : Return
      Endif
      # Si livraison de pręt ou sous-traitance, pas de sortie d'un stock manquant
      If LABR="SDH1" & ([M:SDH0]LND=2 | (dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2))
         # La quantité sélectionnée ne peut ętre inférieure ŕ la qté ŕ traiter ?
         GMESSAGE=mess(509,199,1)
         GERR=1 : FOK=0 : Return
      # Sinon si stock négatif autorisé
      Elsif [M:SOR]NEGSTO=2
         # Voulez-vous générer une rupture ?
         GMESSAGE=mess(395,199,1)
      Else
         # Voulez-vous enregistrer ?
         GMESSAGE=mess(390,199,1)
      Endif
      # Non par défaut
      OK=0
      Call OUINON(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      If OK<>2
         FOK=0
      Elsif [M:SOR]NEGSTO=2
         OKRUP=1
      Endif
   Endif
Endif

Return

#########################################################################
$ENR

If dim([M:SOW]WSTOCOU) <= 0
   Call ERREUR (mess(339,199,1)-'SOW') From GESECRAN
   Return
Endif

# Peut on ajouter les lignes dans l'écran de travail
If [M:SOW]NBLIG+[M:SOR]NBLIG >= dim([M:SOW]WSTOCOU)
   Call MESSAGE(mess(352,199,1)) From GESECRAN
   Return
Endif

# Suppression des lignes [SOW] initiales pour la ligne de document
Call DELSTOSORW(LNOL,LNOL,LABR,[M:SOR]STOFCY,LRET) From STKSOR
If LRET<>0 Return Endif

Trbegin [STO]

# Alimentation de l'écran de stockage STOSORW
WNBLIG = [M:SOW]NBLIG
J      = [M:SOW]NBLIG
If [M:SOR]NBLIG>0

   #--- Issue 110327
   # Tri du tableau [M:SOR] par chrono stock et no série pour réagréger si nécessaire
   If [F:ITM]SERMGTCOD=4
      Sorta [M:SOR]NBLIG [M:SOR]NBLIG Order By [M:SOR]STOCOU(indice),[M:SOR]SERNUM(indice)
   Endif
   #---

   For I=0 To [M:SOR]NBLIG-1
      # Si qté ŕ sortir > qté déjŕ allouée, maj qté en cours de traitement
      If [M:SOR]QTYSTUACT(I)>[M:SOR]ALLSTUACT(I)
         Readlock [STO]STO0=[M:SOR]STOFCY;[M:SOR]STOCOU(I)
         If !fstat
            LWIPQTY = max(0,[M:SOR]QTYSTU(I)-[M:SOR]ALLSTU(I))
            LWIPQTA = max(0,[M:SOR]QTYSTUACT(I)-[M:SOR]ALLSTUACT(I))
            If LWIPQTA>[F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
               GMESSAGE = mess(160,195,1)-num$(I+1)-":"-mess(142,184,1)-"\"-
&                         mess(45,196,1)-num$(LWIPQTA)-mess(46,196,1)-
&                         num$([F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA)
               Call ERREUR(GMESSAGE) From GESECRAN
               LRET=1 : Break
            Endif
            [F:STO]CUMWIPQTY += LWIPQTY
            [F:STO]CUMWIPQTA += LWIPQTA
            LSTOCOU = [F:STO]STOCOU
            Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
            Rewrite [STO]
            If fstat
               Call FSTA("STO") From GLOCK
               Goto ENR_SUI
            Endif
         Elsif [M:SOR]STOCOU(I)<>0
            GMESSAGE = mess(160,195,1)-num$(I+1)-":"-mess(232,188,1)-
&                      "[STOCK]"-mess(50,196,1)-num$([M:SOR]STOCOU(I))
            Call ERREUR(GMESSAGE) From GESECRAN
            LRET=1 : Break
         Endif
      Endif
      #--- Issue 110327
      # Création no série en cours de traitement
      If [F:ITM]SERMGTCOD=4 & [M:SOR]SERNUM(I)<>""
        Call CRE_STOSERW([M:SOR]ITMREF,[M:SOR]SERNUM(I),[M:SOR]QTYSTU(I),LRET) From STKLIB
        If LRET<>0 : Break : Endif
      Endif
      #---

      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4 & I>0 & [M:SOR]SERNUM(I)<>"" & [M:SOR]STOCOU(I)=[M:SOR]STOCOU(I-1)
         Raz WNUMDEB, LRET
         Call PLUS_UN([M:SOR]SERNUMF(I-1),WNUMDEB,LRET) From STKLIB
         # Si no série début = no série fin+1 de la ligne précédente, agrégation
         If LRET=0 & WNUMDEB=[M:SOR]SERNUM(I)
            [M:SOW]WQTYSTU(J-1)    += [M:SOR]QTYSTU(I)
            [M:SOW]WQTYSTUACT(J-1) += [M:SOR]QTYSTUACT(I)
            [M:SOW]WALLSTU(J-1)    += [M:SOR]ALLSTU(I)
            [M:SOW]WALLSTUACT(J-1) += [M:SOR]ALLSTUACT(I)
            Goto ENR_SUI
         Endif
      Endif
      #---

      [M:SOW]WSTOSEQ(J)    = [M:SOR]WSTOSEQ
      [M:SOW]WSTOCOU(J)    = [M:SOR]STOCOU(I)
      [M:SOW]WQTYSTU(J)    = [M:SOR]QTYSTU(I)
      [M:SOW]WQTYSTUACT(J) = [M:SOR]QTYSTUACT(I)
      Raz [M:SOW]WPLFSTO(J)
      Raz [M:SOW]WLOT(J), [M:SOW]WSLO(J), [M:SOW]WLOC(J), [M:SOW]WWRH(J)
      Raz [M:SOW]WSTA(J), [M:SOW]WSERNUM(J)
      #--- TS 106217
      Raz [M:SOW]WECCVALMAJ(J)

      #--- Issue 110327
      # Si série géré en sortie ou en E/S globale
      #If [F:ITM]SERMGTCOD=2 & dim([M:SOR]SERNUM)>0
      If find([F:ITM]SERMGTCOD,2,4) & dim([M:SOR]SERNUM)>0
      #---
         [M:SOW]WSERNUM(J)=[M:SOR]SERNUM(I)
      Endif
      # Sortie sur ligne de stock
      If [M:SOR]STOCOU(I)<>0
         [M:SOW]WALLSTU(J)    = [M:SOR]ALLSTU(I)
         [M:SOW]WALLSTUACT(J) = [M:SOR]ALLSTUACT(I)
      # Sortie en attente
      Else
         If dim([M:SOR]LOT)>0    [M:SOW]WLOT(J)   =[M:SOR]LOT(I) Endif
         If dim([M:SOR]SLO)>0    [M:SOW]WSLO(J)   =[M:SOR]SLO(I) Endif
         If dim([M:SOR]LOC)>0    [M:SOW]WLOC(J)   =[M:SOR]LOC(I) Endif
         If dim([M:SOR]WRH)>0    [M:SOW]WWRH(J)   =[M:SOR]WRH(I) Endif
         If dim([M:SOR]SERNUM)>0 [M:SOW]WSERNUM(J)=[M:SOR]SERNUM(I) Endif
         #--- TS 106217
         If dim([M:SOR]ECCVALMAJ)>0 [M:SOW]WECCVALMAJ(J)=[M:SOR]ECCVALMAJ(I) Endif
         #---
         [M:SOW]WSTA(J)=[M:SOR]STA(I)
         Raz [M:SOW]WALLSTU(J), [M:SOW]WALLSTUACT(J)
      Endif

      # Transfert zones de l'écran STOSOR vers l'écran STOSORW
      GPOINT="SOR_SOW" : Gosub ENTREE From EXEFNC

      [M:SOW]NBLIG += 1
      J += 1

      $ENR_SUI
   Next I
   If LRET<>0 Goto AB_TRT Endif
Endif

# Génération d'une ligne de rupture si nécessaire
If OKRUP=1
   [M:SOW]WSTOSEQ(J)    = [M:SOR]WSTOSEQ
   Raz [M:SOW]WSTOCOU(J)
   [M:SOW]WQTYSTUACT(J) = [M:SOR]SORQTYACT-[M:SOR]PECQTYACT-[M:SOR]SHTQTY
   [M:SOR]SHTQTY       += [M:SOW]WQTYSTUACT(J)
   [M:SOW]WQTYSTU(J)    = [M:SOW]WQTYSTUACT(J)
   Raz [M:SOW]WALLSTU(J), [M:SOW]WALLSTUACT(J)
   Raz [M:SOW]WSLO(J), [M:SOW]WSTA(J), [M:SOW]WSERNUM(J)
   Raz [M:SOW]WPLFSTO(J)
   [M:SOW]WLOT(J) = WSHTLOT
   [M:SOW]WLOC(J) = WSHTLOC
   [M:SOW]WWRH(J) = WSHTWRH
   #--- TS 106217
   [M:SOW]WECCVALMAJ(J) = WSHTECCVALMAJ
   #---
   [M:SOW]NBLIG  += 1
Endif

Commit

# Si ligne de stock alors stockage sections analytiques
If [M:SOW]NBLIG <> WNBLIG
   J=[M:SOW]NBLIG2
   [M:SOW]WSTOSEQ2(J)=[M:SOR]WSTOSEQ
   For I=1 To GNBDIE
      Assign "[M:SOW]CCE"+num$(I)+"(J)" With [M:SOR]CCE(I-1)
   Next I
   [M:SOW]NBLIG2 += 1
Endif

# On a enregistré
WGENR = 1
FIN   = 1

Return

#########################################################################
$AB_TRT
Rollback
Return

#########################################################################
$ABA

WPICK=1
Gosub RAFFRAICHI
Effzo [M]15
GCHARGRUPT = ""
Gosub ALI_MSK_SOR
Affzo [M]1-99
WPICK=2
Gosub RAFFRAICHI
Return

#########################################################################
$BOUTON
#--------------------------------------------
# "1" : Aprčs Proposition (Action TRTSORPRO)
# "2" : Aprčs Critčres    (Action SAISORCRI)
# "3" : Raz
#--------------------------------------------
Case BOUT
 When "1","2" : Raz WCRITSTO2, WCRITSTO4, WCRITSTO5, WCRIT
                If dim([M:SOR]XLOT)>0 & !find([M:SOR]XLOT,"","*")
                   WCRITSTO2 = 'pat([F:STO]LOT,[M:SOR]XLOT)<>0'
                Endif
                #--- TS 106217
                # Prise en compte filtre version
                If [M:SOR]PECECC=2
                  # Si version renseignée et exclusive
                  If [M:SOR]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
                    If WCRITSTO2<>"" WCRITSTO2 += "&" Endif
                    WCRITSTO2 += '[F:STO]ECCVALMAJ=[M:SOR]WECCVALMAJ'
                  Endif
                Endif
                #---
                [M:SOR]XSTA=vireblc([M:SOR]XSTA,4)
                # Si statuts renseignés dans filtre allocation
                If !find([M:SOR]XSTA,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SOR]XSTA,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable ŕ tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                # Sinon prise en compte des sous-statuts autorisés
                Elsif !find([M:SOR]AUZSST,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SOR]AUZSST,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable ŕ tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                Endif
                #--- Bug 65771
                #If BOUT="2"
                   # Catégorie emplacement et dépôt
                   If [M:SOR]PECINTLOC=2
                      If [M:SOR]PECPLFLOC=2
                         WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
                         If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
                      Else
                         WCRITSTO5 = '[F:STO]LOCCAT=1'
                         If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
                      Endif
                   Elsif [M:SOR]PECPLFLOC=2
                      WCRITSTO5 = '[F:STO]LOCCAT=2'
                      If [M:SOR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOR]XWRH)<>0' Endif
                   Endif
                   If [M:SOR]PECSCOLOC=2
                      If WCRITSTO5=""
                         WCRITSTO5  = '[F:STO]LOCCAT=4'
                      Else
                         WCRITSTO5 += '|[F:STO]LOCCAT=4'
                      Endif
                   Elsif WCRITSTO5=""
                      # Pour ne rien avoir (paramétrage incohérent)
                      WCRITSTO5 = '[F:STO]LOCCAT=9'
                   Endif

                   # Propriétaire
                   If [M:SOR]OWNFLG=2
                      If [M:SOR]NOTOWNFLG=2
                         If [M:SOR]PECOWNER=""
                            WCRITSTO6 = '1=1'
                         Else
                            WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SOR]PECOWNER)'
                         Endif
                      Else
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Else
                      If [M:SOR]NOTOWNFLG=2
                         If [M:SOR]PECOWNER=""
                            WCRITSTO6 = '[F:STO]OWNER<>[F:STO]STOFCY'
                         Else
                            WCRITSTO6 = '[F:STO]OWNER=[M:SOR]PECOWNER'
                         Endif
                      Else
                         # Si rien de coché, on force : 'stock propriétaire'
                         [M:SOR]OWNFLG=2
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Endif
                #--- Bug 65771
                #Endif
                WAFFPICK=1
                Gosub TIROIR
 When "3"     : # La ligne a déjŕ été créé (pas de libération de stock)
                If evalue("[M:"+LABR+"]CREFLG(LNOL)")<>0
                   WPICK=1
                   Gosub RAFFRAICHI
                   Raz   [M:SOR]PECQTY, [M:SOR]PECQTYACT, [M:SOR]SHTQTY
                   Affzo [M:SOR]PECQTY, PECQTYACT, SHTQTY
                   Effzo [M:SOR]15
                # La ligne est en cours de saisie (libération du stock)
                Else
                   WRAFF=0
                   # Si livraison,facture ou suivi d'OF, on vérifie si la ligne
                   # a été préchargé ŕ partir des allocations d'une cde / d'un OF
                   # Dans ce cas, il faut se contenter d'un raffraichissement
                   If find(LABR,"SDH1","SIH4","MTK3","MBM")
                      For I=0 To [M:SOW]NBLIG-1
                         If evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LNOL..LNOL))")
                            If [M:SOW]WSTOCOU(I)<>0 & [M:SOW]WALLSTUACT(I)<>0
                               WRAFF=1 : Break
                            Endif
                         Endif
                      Next I
                   Endif

                   If WRAFF=1
                      WPICK=1
                      Gosub RAFFRAICHI
                      Raz   [M:SOR]PECQTY, [M:SOR]PECQTYACT, [M:SOR]SHTQTY
                      Affzo [M:SOR]PECQTY, PECQTYACT, SHTQTY
                      Effzo [M:SOR]15
                   Else
                      # Suppression des lignes [SOW] initiales pour la ligne de document
                      Call DELSTOSORW(LNOL,LNOL,LABR,[M:SOR]STOFCY,LRET) From STKSOR
                      If LRET<>0 Return Endif
                      Raz   [M:SOR]PECQTY, [M:SOR]PECQTYACT, [M:SOR]SHTQTY
                      Affzo [M:SOR]PECQTY, PECQTYACT, SHTQTY
                      Effzo [M:SOR]15
                      WAFFPICK=1
                      Gosub TIROIR
                      # Raffraichissement de la ligne de document
                      If evalue("dim([M:"+LABR+"]LOT(LNOL))")>0
                         Assign "[M:"+LABR+"]LOT(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]SLO(LNOL))")>0
                         Assign "[M:"+LABR+"]SLO(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
                         Assign "[M:"+LABR+"]LOC(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]STA(LNOL))")>0
                         Assign "[M:"+LABR+"]STA(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]SERNUM(LNOL))")>0
                         Assign "[M:"+LABR+"]SERNUM(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")>0
                         Assign "[M:"+LABR+"]SERNUMF(LNOL)" With ""
                      Endif
                      If evalue("dim([M:"+LABR+"]WRH(LNOL))")>0
&                      & [M:SOR]WRHOBY<>2
                         Assign "[M:"+LABR+"]WRH(LNOL)" With ""
                      #--- TS 106217 voir ce qu'il faut faire ???
                      #If evalue("dim([M:"+LABR+"]ECCVALMAJ(LNOL))")>0
                      #   Assign "[M:"+LABR+"]LOT(LNOL)" With ""
                      #Endif
                      #---
                      Endif
                   Endif
                Endif
Endcase

Return

#########################################################################
$MENU

#--------------------------------------------
# "K" : Aprčs saisie no série en fenętre
# "L" : Sortie d'un stock manquant
#--------------------------------------------
Case BOUT
 When "K"     : If GSAISERIE=1 Gosub TIROIR Endif
 When "L"     : Call B3_NBLIG
Endcase

Return

#########################################################################
$FIN

# Si on a pas enregistré
If WGENR<>1
   Goto FIN_SUI
Endif

# Réalimente les champs lot,sous-lot,emplacement,statut et no de série
# de la ligne de document aprčs saisie du détail de cette ligne
Local Char     LSERNUMF(GLONSER)
Local Integer  I
Local Char     CAR(1)            : CAR = "$"
Local Char     WLOT(GLONLOT)
Local Char     WSLO(GLONSLO)
Local Char     WLOC(GLONLOC)
Local Char     WSTA(GLONSTA)
Local Char     WSERNUM(GLONSER)
Local Char     WSERNUMF(GLONSER)
Local Char     WPALNUM(GLONPAL)
Local Char     WCTRNUM(GLONCTR)
Local Char     WWRH(GLONWRH)
#--- Issue 53322
Local Char     WLPNNUM(GLONLPN)
Local Shortint WABRLPN : Raz WABRLPN
#---
Local Shortint WABRLOT
Local Shortint WABRSLO
Local Shortint WABRLOC
Local Shortint WABRSTA
Local Shortint WABRSER
Local Shortint WABRPAL
Local Shortint WABRCTR
Local Shortint WABRWRH

Raz LRET

# Positionnement des flags présence zone dans l'écran
Raz WABRLOT, WABRSLO, WABRLOC, WABRSTA, WABRSER, WABRPAL, WABRCTR, WABRWRH
If evalue("dim([M:"+LABR+"]LOT(LNOL))")>0
   WABRLOT=1
Endif
If evalue("dim([M:"+LABR+"]SLO(LNOL))")>0
   WABRSLO=1
Endif
If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
   WABRLOC=1
Endif
If evalue("dim([M:"+LABR+"]STA(LNOL))")>0
   WABRSTA=1
Endif
If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") >0 &
&  evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")>0
   WABRSER=1
Endif
If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")>0
   WABRPAL=1
Endif
If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")>0
   WABRCTR=1
Endif
#--- Issue 53322
If evalue("dim([M:"+LABR+"]LPNNUM(LNOL))")>0
   WABRLPN=1
Endif
#---
#If evalue("dim([M:"+LABR+"]WRH(LNOL))")>0
#   WABRWRH=1
#Endif

Raz WLOT, WSLO, WLOC, WSTA, WSERNUM, WSERNUMF, WPALNUM, WCTRNUM, WWRH
#--- Issue 53322
Raz WLPNNUM

If [M:SOR]NBLIG<>0
   # Si gestion no séries et no série définis dans l'écran -> tri selon ces no
   If [F:ITM]SERMGTCOD>1 & WABRSER=1
      Sorta [M:SOR]NBLIG [M:SOR]NBLIG Order By [M:SOR]SERNUM(indice)
   Endif

   Raz WQTY
   For I=0 To [M:SOR]NBLIG-1
      If I=0
         If WABRLOT=1 WLOT    = [M:SOR]LOT(I)    Endif
         If WABRSLO=1 WSLO    = [M:SOR]SLO(I)    Endif
         If WABRLOC=1 WLOC    = [M:SOR]LOC(I)    Endif
         If WABRSTA=1 WSTA    = [M:SOR]STA(I)    Endif
         If WABRPAL=1 WPALNUM = [M:SOR]PALNUM(I) Endif
         If WABRCTR=1 WCTRNUM = [M:SOR]CTRNUM(I) Endif
         If WABRSER=1
            WSERNUM  = [M:SOR]SERNUM(I)
            WSERNUMF = [M:SOR]SERNUMF(I)
         Endif
         #--- Issue 53322
         If WABRLPN=1 WLPNNUM = [M:SOR]LPNNUM(I) Endif
         #---
         #If WABRWRH=1 WWRH    = [M:SOR]WRH(I)    Endif
      Else
         If WABRLOT=1 & WLOT<>CAR
            If WLOT<>[M:SOR]LOT(I)       WLOT=CAR    Endif
         Endif
         If WABRSLO=1 & WSLO<>CAR
            If WSLO<>[M:SOR]SLO(I)       WSLO=CAR    Endif
         Endif
         If WABRLOC=1 & WLOC<>CAR
            If WLOC<>[M:SOR]LOC(I)       WLOC=CAR    Endif
         Endif
         If WABRSTA=1 & WSTA<>CAR
            If WSTA<>[M:SOR]STA(I)       WSTA=CAR    Endif
         Endif
         If WABRPAL=1 & WPALNUM<>CAR
            If WPALNUM<>[M:SOR]PALNUM(I) WPALNUM=CAR Endif
         Endif
         If WABRCTR=1 & WCTRNUM<>CAR
            If WCTRNUM<>[M:SOR]CTRNUM(I) WCTRNUM=CAR Endif
         Endif
         #--- Issue 53322
         If WABRLPN=1 & WLPNNUM<>CAR
            If WLPNNUM<>[M:SOR]LPNNUM(I) WLPNNUM=CAR Endif
         Endif
         #---
         If WABRSER=1
            If WSERNUM="" WSERNUM = [M:SOR]SERNUM(I) Endif
            WSERNUMF = [M:SOR]SERNUMF(I)
         Endif
         #If WABRWRH=1 & WWRH<>CAR
         #   If WWRH<>[M:SOR]WRH(I)       WWRH=CAR    Endif
         #Endif
      Endif
      WQTY += [M:SOR]QTYSTU(I)
   Next

   If [F:ITM]LOTMGTCOD =1 Raz WLOT             Endif
   If [F:ITM]LOTMGTCOD<>4 Raz WSLO             Endif
   If [F:ITF]LOCMGTCOD<>2 Raz WLOC             Endif
   If [F:ITM]SERMGTCOD <2 Raz WSERNUM,WSERNUMF Endif
   If WRHGES<>2           Raz WWRH             Endif
   #--- Issue X3-53322
   If [F:ITF]LPNMGTCOD<>2 Raz WLPNNUM          Endif
   #---
   If WABRSER=1 & WSERNUM<>"" & WSERNUMF<>"" & WQTY > 1                   # hcb 85646
      Call PLUS_NB(WSERNUM,WQTY,LSERNUMF,LRET) From STKLIB
#      If LRET<>0 Return Endif                                  # hcb 105866
      If LSERNUMF<>WSERNUMF
         WSERNUM = CAR
         WSERNUMF= CAR
      Endif
   Endif
Endif

If WABRLOT=1 Assign "[M:"+LABR+"]LOT(LNOL)" With WLOT Endif
If WABRSLO=1 Assign "[M:"+LABR+"]SLO(LNOL)" With WSLO Endif
If WABRLOC=1 Assign "[M:"+LABR+"]LOC(LNOL)" With WLOC Endif
If WABRSTA=1 Assign "[M:"+LABR+"]STA(LNOL)" With WSTA Endif
If WABRPAL=1 Assign "[M:"+LABR+"]PALNUM(LNOL)" With WPALNUM Endif
If WABRCTR=1 Assign "[M:"+LABR+"]CTRNUM(LNOL)" With WCTRNUM Endif
#--- Issue X3-53322
If WABRLPN=1 Assign "[M:"+LABR+"]LPNNUM(LNOL)" With WLPNNUM Endif
#---
If WABRSER=1
   Assign "[M:"+LABR+"]SERNUM(LNOL)"  With WSERNUM
   Assign "[M:"+LABR+"]SERNUMF(LNOL)" With WSERNUMF
Endif
#If WABRWRH=1 Assign "[M:"+LABR+"]WRH(LNOL)" With WWRH Endif
Assign "[M:"+LABR+"]MVTDES(LNOL)" With [M:SOR]MVTDES

# Issue 92882 - 2013-11-07 by MAE : déplacé en FIN_SUI
#Default Mask "["+LABR+"]"   # hcb 89583
#Affzo [M]                   # hcb 89583


$FIN_SUI
#-----------------------------------------------------------------------
# Traitement ŕ alimenter pour les différentes fonctions
# pour exploiter ce qui a été fait dans l'écran de gestion des sorties
#-----------------------------------------------------------------------
Gosub APRES_ENR From TRTSTOSORA
Default Mask "["+LABR+"]"   # hcb 89583
Affzo [M]                   # hcb 89583

Return

#########################################################################
$FINSAI

Default Mask "["+LABR+"]"

[M]UPDFLG(LNOL)=1

# Réaffectation (Diszo) de l'état des zones stock du document
Call ETAZONSORL(LABR,LNOL) From STKECR2

# TS le 26.10.05
# Affichage de l'écran contenant les lignes de document
#Affzo [M]1-99

# Si on a enregistré & accés par bouton --> bouton 'Enregistrer' dans le document
# Ne pas positionner mkstat dans les autres cas, car les actions suivantes ne
# seraient pas exécutées (ex: TRTCRENOM dans les livraisons)
If WGENR=1 & GREP="" mkstat=4 Endif

$FINSAI_SUI
Return

#########################################################################
# Action sur champs
#########################################################################

########################################
Subprog AV_SHTQTY(VALEUR)
Variable Decimal VALEUR
Chgstl SHTQTY With "AWARNLOW"
End

########################################
Subprog IB_NBLIG
Local Integer NOL
NOL=nolign-1

# Si livraison de pręt ou de sous-traitance ou stock négatif interdit,
# pas de sortie d'un stock manquant
If find([M:SOR]TRSTYP,17,20) | [M:SOR]NEGSTO<>2 |
&  [M:SOR]PECQTYACT+[M:SOR]SHTQTY>=[M:SOR]SORQTYACT
   Raz GBOUT3
Endif

#--- Issue 110327
# Si no série non géré en sortie ou E/S globale, ou mvt en attente,
# ou no série déjŕ existant, ou quantité <= 1 pas de saisie éclatée des no série
#If [M:SOR]SERMGTCOD<>2 | [M:SOR]STOCOU(NOL)=0 | [M:SOR]SERNUMFLG(NOL)=1 |
#&  [M:SOR]QTYSTU(NOL)<=1
If !find([M:SOR]SERMGTCOD,2,4) | [M:SOR]STOCOU(NOL)=0 | [M:SOR]SERNUMFLG(NOL)=1 |
&  ([M:SOR]SERMGTCOD=2 & [M:SOR]QTYSTU(NOL)<=1)
#---
   Raz GBOUT2
Endif

# Si no série géré en sortie et trf inter-site mais intra-société
# pas de saisie éclatée des no série
If [M:SOR]SERMGTCOD=2 & [M:SOR]TRFFCY<>"" & [M:SOR]BETCPY<>2
   Raz GBOUT2
Endif

#--- Bug 85510
# Si no série géré en sortie et BP non livrable (avec emp dest saisissable)
If [M:SOR]SERMGTCOD=2 & [M:SOR]FLGSAISER=1
   Raz GBOUT2
Endif
#---

# Si no série non géré en E/S ou plus de quantité ŕ traiter
# pas de saisie des no série ŕ sortir
If [M:SOR]SERMGTCOD<>3 | [M:SOR]SORQTYACT=[M:SOR]PECQTYACT+[M:SOR]SHTQTY
   Raz GBOUT1
Endif

End

########################################
Subprog B3_NBLIG
Local Integer NOL
Local Integer WRHGES

If [F:FCY]FCY<>[M:SOR]STOFCY
   Read [FCY]FCY0=[M:SOR]STOFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

nolign =  [M:SOR]NBLIG+1
NOL = nolign-1

[M:SOR]ICOMVTATT(NOL)="247"

[M:SOR]QTYSTUACT(NOL)=[M:SOR]SORQTYACT-([M:SOR]PECQTYACT+[M:SOR]SHTQTY)

# Calcul nouvelle quantité US
[M:SOR]QTYSTU(NOL) = [M:SOR]QTYSTUACT(NOL)

# Calcul nouvelle quantité sélectionnée
[M:SOR]SHTQTY += [M:SOR]QTYSTUACT(NOL)

# Calcul quantité en UC
#If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
#[M:SOR]QTYPCU(NOL) = [M:SOR]QTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
#Call QTEARR([M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV

Raz [M:SOR]SERNUMFLG(NOL)

Insa [M:SOR]NBLIG+1,1,[M:SOR]NBLIG [M:SOR]NBLIG
[M:SOR]NBLIG+=1

Affzo [M]PECQTY, PECQTYACT, SHTQTY

Actzo [M:SOR]QTYSTU(NOL)
Diszo [M:SOR]QTYPCU(NOL)
If dim([M:SOR]LOT)>0    Actzo [M:SOR]LOT(NOL)    Endif
If dim([M:SOR]SLO)>0    Actzo [M:SOR]SLO(NOL)    Endif
If dim([M:SOR]LOC)>0    Actzo [M:SOR]LOC(NOL)    Endif
If dim([M:SOR]SERNUM)>0
   # Si no série géré en sortie, pas de saisie
   # car problčme pour régulariser par la suite
   If [F:ITM]SERMGTCOD=2
      Diszo [M:SOR]SERNUM(NOL)
   Else
      Actzo [M:SOR]SERNUM(NOL)
   Endif
Endif
Actzo [M:SOR]STA(NOL)
If dim([M:SOR]WRH)>0
   If WRHGES=2
      # Dépôt saisi sur la ligne de document
      If [M:SOR]XWRH=""
         Actzo [M:SOR]WRH(NOL)
      Else
         If [M:SOR]WRHOBY=2
            Diszo [M:SOR]WRH(NOL)
         Else
            Actzo [M:SOR]WRH(NOL)
         Endif
         [M:SOR]WRH(NOL)=[M:SOR]XWRH
      Endif
   Else
      Grizo [M:SOR]WRH(NOL)
   Endif
Endif
#--- TS 106217
If dim([M:SOR]ECCVALMAJ)>0
   #--- Si version exclusive et renseignée, pas de modification
   If [M:SOR]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
      [M:SOR]ECCVALMAJ(NOL) = [M:SOR]WECCVALMAJ
      Diszo [M:SOR]ECCVALMAJ(NOL)
   Else
      Actzo [M:SOR]ECCVALMAJ(NOL)
   Endif
   Affzo [M:SOR]ECCVALMAJ(NOL)
Endif
#---
Affzo [M:SOR]15
mkstat=4

End

########################################
Subprog AVANT_NBLIG
Local Integer I, NOL
NOL = nolign-1

# Calcul nouvelle quantité sélectionnée
If [M:SOR]STOCOU(NOL)<>0
   [M]PECQTY    -= [M]QTYSTU(NOL)
   [M]PECQTYACT -= [M]QTYSTUACT(NOL)
Else
   [M]SHTQTY    -= [M]QTYSTU(NOL)
Endif

End

########################################
Subprog APRES_NBLIG
Local Integer NOL
NOL = nolign-1

# Calcul nouvelle quantité sélectionnée
If [M:SOR]STOCOU(NOL)<>0
   [M]PECQTY    += [M]QTYSTU(NOL)
   [M]PECQTYACT += [M]QTYSTUACT(NOL)
Else
   [M]SHTQTY    += [M]QTYSTU(NOL)
Endif

Affzo [M]PECQTY, PECQTYACT, SHTQTY

End

########################################
Subprog C_NBLIG
Local Integer NOL

# --> Suppression de lignes
If find(status,65,68,83)
   GSUPLIG = status
Else
   Raz GSUPLIG
Endif

# --> Reprise interdite
If status=82 mkstat=2 Endif

End

