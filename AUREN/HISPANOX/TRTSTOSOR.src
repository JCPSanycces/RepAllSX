WDAT = [M:SOR]DLVDAT
If WDAT=[0/0/0]
   WDAT=[M:SOR]RETDAT
Endif
Call STKCTRSLOS(VALEUR,[M:SOR]LOT(nolign-1),[M:SOR]ITMREF,WDAT,[M:SOR]BPRNUM,[M:SOR]STOFCY) From STKACT
End

########################################
#--- TS  106217
Subprog AV_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If [M:SOR]STOCOU(nolign-1)=0
   Chgstl ECCVALMAJ(nolign-1) With "AWARNLOW"
Else
   Chgstl ECCVALMAJ(nolign-1) With ""
Endif
End

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET
Call CTLECCVAL(VALEUR,[M:SOR]STOFCY,[M:SOR]ITMREF,[M:SOR]TRSTYP,[M:SOR]TRSCOD,
&              [M:SOR]RETDAT,LRET) From STKSOR
If LRET>0 mkstat=2 Endif
End
#---

########################################
Subprog AV_SERNUM(VALEUR)
Variable Char    VALEUR()
If [M:SOR]STOCOU(nolign-1)=0
   Chgstl SERNUM(nolign-1) With "AWARNLOW"
Else
   Chgstl SERNUM(nolign-1) With ""
Endif
End

########################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL = nolign-1

# No série non modifié
If [M:SOR]SERNUM(NOL)=VALEUR End Endif

#--- Issue 110327
# Si pas de mvt en attente et séries non gérés en sortie ou en E/S globale --> pas de contrôle
#If [M:SOR]STOCOU(NOL)<>0 & [F:ITM]SERMGTCOD<>2 End Endif
If [M:SOR]STOCOU(NOL)<>0 & !find([F:ITM]SERMGTCOD,2,4) End Endif
#---
If VALEUR=""
   Raz [M:SOR]SERNUMF(NOL)
Else
   Read [STS]STS0=[M:SOR]ITMREF;VALEUR
	 #--- Issue 110327
   # Si no série existe, erreur
   #If !fstat
   #   mkstat=2 : GMESSAGE=mess(3,187,1) : End
   #Endif
   # Si séries en E/S globale et ligne de stock
   If [F:ITM]SERMGTCOD=4 & [M:SOR]STOCOU(NOL)<>0
      If fstat
         mkstat=2 : GMESSAGE=VALEUR-":"-mess(43,196,1) : End
      Elsif [F:STS]STOCOU<>[M:SOR]STOCOU(NOL)
         mkstat=2 : GMESSAGE=VALEUR-":"-mess(447,184,1) : End
      Elsif [F:STS]ISSDAT<>[0/0/0]
         mkstat=2 : GMESSAGE=VALEUR-":"-mess(37,184,1) : End
      Elsif [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
         mkstat=2 : GMESSAGE=VALEUR-":"-mess(443,184,1) : End
      Endif
      If [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
        If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
          OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
          If OK=1  mkstat=2 : End  Endif
        Endif
      Endif
      #--- Si le no série n'a pas déjŕ été saisi
      If VALEUR<[M:SOR]SERNUM(NOL) | VALEUR>[M:SOR]SERNUMF(NOL)
        #--- No série en cours de traitement?
        If func STKLIB.REC_STOSERW_UID([M:SOR]ITMREF,VALEUR,adxuid(1))<>0
           mkstat=2 : GMESSAGE=VALEUR-":"-mess(449,184,1) : End
        Endif
      Endif
   # Si mouvement en attente et séries en sortie ou E/S globale
   Elsif !fstat
      mkstat=2 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
   Endif
   #--- End issue 110327
   If [M:SOR]QTYSTU(NOL)=1
      [M:SOR]SERNUMF(NOL) = VALEUR
   Else
      # Vérification que les no série n'existent pas
      # et alimentation du no série fin
      WNBSERIE = [M:SOR]QTYSTU(NOL)
      WNUMDEB  = VALEUR
      For J=2 To WNBSERIE
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOR]ITMREF;WNUMFIN
	          #--- Issue 110327
            #If fstat
            #   WNUMDEB = WNUMFIN
            #Else
            #   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            #Endif
            # Si séries en E/S globale et ligne de stock
            If [F:ITM]SERMGTCOD=4 & [M:SOR]STOCOU(NOL)<>0
               If fstat
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
               Elsif [F:STS]STOCOU<>[M:SOR]STOCOU(NOL)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
               Elsif [F:STS]ISSDAT<>[0/0/0]
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
               Elsif [F:STS]SDHNUM<>"" &(!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
               Endif
               If OK=1 & [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
                 If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                   OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                   If OK=1  mkstat=2 : Break  Endif
                 Endif
               Endif
               #--- Si le no série n'a pas déjŕ été saisi
               If WNUMFIN<[M:SOR]SERNUM(NOL) | WNUMFIN>[M:SOR]SERNUMF(NOL)
                  #--- No série en cours de traitement?
                  If func STKLIB.REC_STOSERW_UID([M:SOR]ITMREF,WNUMFIN,adxuid(1))<>0
                     mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
                  Endif
               Endif
            # Si mouvement en attente et séries en sortie ou E/S globale
            Elsif !fstat
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            Endif
            WNUMDEB = WNUMFIN
            #--- End issue 110327
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
         Endif
      Next J
      If mkstat=2 End Endif
      [M:SOR]SERNUMF(NOL) = WNUMFIN
   Endif
Endif

#--- Issue 110327
[M:SOR]SERNUM(NOL) = VALEUR
#---
Affzo [M]SERNUMF(NOL)

End

########################################
Subprog AV_SERNUMF(VALEUR)
Variable Char    VALEUR()
If [M:SOR]STOCOU(nolign-1)=0
   Chgstl SERNUMF(nolign-1) With "AWARNLOW"
Else
   Chgstl SERNUMF(nolign-1) With ""
Endif
End

