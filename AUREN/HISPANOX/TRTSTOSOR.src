########################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If [M:SOR]STOCOU(nolign-1)=0
   Chgstl QTYSTU(nolign-1) With "AWARNLOW"
Else
   Chgstl QTYSTU(nolign-1) With ""
Endif
End

########################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WVARQTY, WVARQTA, WQTYSTUACT, WK
Local    Decimal WORIALLSTU, WORIALLSTUACT         : #--- Bug 41947
Local    Integer OK, NOL, NBL
NOL = nolign-1
NBL = [M:SOR]NBLIG-1

# Pas de quantité nulle, vous devez supprimer la ligne
If VALEUR=0
   mkstat=2 : GMESSAGE=mess(392,199,1) : End
Endif

# La quantité a été modifiée
If VALEUR<>[M:SOR]QTYSTU(NOL)

   # Calcul nouvelle quantité UA
   WQTYSTUACT = VALEUR

   If [M:SOR]STOCOU(NOL)<>0
      If dim([M:SOR]POT)>0
         # Si gestion en titres ou UI, calcul quantité en UA
         Case [M:SOR]STOMGTCOD
          When 3 : If [M:SOR]POT(NOL)<>0
                      WQTYSTUACT = VALEUR*([M:SOR]POT(NOL)/100)
                      Call QTEARR(WQTYSTUACT,[M:SOR]STU) From TRTDIV
                   Endif
          When 4 : If [M:SOR]POT(NOL)<>0
                      WQTYSTUACT = VALEUR*[M:SOR]POT(NOL)
                      Call QTEARR(WQTYSTUACT,[M:SOR]STU) From TRTDIV
                   Endif
         Endcase
      Endif
   Endif

   # Variation de la quantité
   WVARQTY = VALEUR    -[M:SOR]QTYSTU(NOL)
   WVARQTA = WQTYSTUACT-[M:SOR]QTYSTUACT(NOL)

   #--- TS
   # Si mvt normal, diminution de la quantité,
   # recalcul de la portion de quantité allouée si nécessaire
   If [M:SOR]STOCOU(NOL)<>0 & WVARQTY<0 & [M:SOR]ALLSTUACT(NOL)>0
      [M:SOR]ALLSTUACT(NOL)-=max(0,abs(WVARQTA)-([M:SOR]QTYSTUACT(NOL)-[M:SOR]ALLSTUACT(NOL)))
      [M:SOR]ALLSTU(NOL)   -=max(0,abs(WVARQTY)-([M:SOR]QTYSTU(NOL)   -[M:SOR]ALLSTU(NOL)))
   Endif
   #---

   # Si mvt normal et augmentation de la quantité
   If [M:SOR]STOCOU(NOL)<>0 & WVARQTY>0
      #--- Issue 110327
      # Si no série en sortie ou en E/S globale, il faut calculer la somme des qtés sortie (WK)
      # pour les lignes ayant le męme chrono stock que celle modifiée
      #If [M:SOR]SERMGTCOD=2
      If find([M:SOR]SERMGTCOD,2,4)
      #---
         Case NOL
          When 0       : WK = sigma(J=1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When NBL     : WK = sigma(J=0,NBL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When Default : WK = sigma(J=0,NOL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
                         WK+= sigma(J=NOL+1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
         Endcase
         # Si qté ŕ sortir > disponible - somme (qté sortie - qté sortie origine)
         # du męme chrono
         If VALEUR>[M:SOR]AVAQTYSTU(NOL)-WK
            mkstat=2 : GMESSAGE=mess(446,196,1) : End
         Elsif GLABR<>"REO1"
            Gosub VERF_DISPO
            # Pas de stock disponible
            If WQTYSTUACT>WDISPO
               mkstat=2 : GMESSAGE =mess(446,196,1) : End
            Endif
         Endif
      # Sinon si qté ŕ sortir > disponible
      Elsif VALEUR>[M:SOR]AVAQTYSTU(NOL)
         mkstat=2 : GMESSAGE=mess(446,196,1) : End
      Elsif GLABR<>"REO1"
         Gosub VERF_DISPO
         # Pas de stock disponible
         If WQTYSTUACT>WDISPO
            mkstat=2 : GMESSAGE =mess(446,196,1) : End
         Endif
      Endif

      #--- Bug 41947
      # Recalcul de la portion de quantité allouée si nécessaire
      If WORIALLSTUACT<>0
         [M:SOR]ALLSTUACT(NOL)+=min(WVARQTA,abs(WORIALLSTUACT-[M:SOR]ALLSTUACT(NOL)))
         [M:SOR]ALLSTU(NOL)   +=min(WVARQTY,abs(WORIALLSTU   -[M:SOR]ALLSTU(NOL)))
      Endif
      #---

   # Mvt en attente et qté totale US + variation US > qté ŕ sortir US
   Elsif [M:SOR]STOCOU(NOL)=0 & ([M:SOR]PECQTYACT+WVARQTA)>[M:SOR]SORQTYACT
      mkstat=2 : GMESSAGE=mess(393,199,1) : End
   Endif

   # Alimentation nouvelle quantité UA
   [M:SOR]QTYSTUACT(NOL) = WQTYSTUACT
Endif
End

$VERF_DISPO
Local Integer LTYPLOC, LSTA
Local Decimal WDISPO

# Calcul du stock disponible sur l'article
Raz LTYPLOC, LSTA
If [M:SOR]PECPLFLOC=2 LTYPLOC+=1 Endif
If [M:SOR]PECSCOLOC=2 LTYPLOC+=4 Endif
# Si pas d'emplacements internes
If [M:SOR]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
If [M:SOR]AAASTA=2    LSTA   +=1 Endif
If [M:SOR]QQQSTA=2    LSTA   +=2 Endif
If [M:SOR]RRRSTA=2    LSTA   +=4 Endif
Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:SOR]PECOWNER,WDISPO) From STKLIB
# On retire la somme des quantités saisies
WDISPO -= sum([M:SOR]QTYSTUACT)
# On ajoute la quantité de la ligne
WDISPO += [M:SOR]QTYSTUACT(NOL)
# On ajoute la somme des quantités allouées
WDISPO += sum([M:SOR]ALLSTUACT)

#--- Bug 41947
# Si pičce origine, il faut prendre en compte la qté allouée sur pičce origine
If [M:SOR]VCRTYPORI<>0 & [M:SOR]VCRNUMORI<>"" & [M:SOR]VCRLINORI<>0
   For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYPORI & VCRNUM=[M:SOR]VCRNUMORI &
&                      VCRLIN=[M:SOR]VCRLINORI & VCRSEQ=[M:SOR]VCRSEQORI &
&                      STOCOU=[M:SOR]STOCOU(NOL)
       WORIALLSTU    += [F:STA]QTYSTU
       WORIALLSTUACT += [F:STA]QTYSTUACT
   Next
   # On retire la quantité allouée de la ligne
   WDISPO -= [M:SOR]ALLSTUACT(NOL)
   # On ajoute la quantité allouée de la ligne origine
   WDISPO += WORIALLSTU
Endif
#---

# On rajoute l'allouée global
WDISPO += [M:SOR]GLOALLQTY

Return

########################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL    = nolign-1

If [M:SOR]STOCOU(NOL)<>0
   # Calcul quantité en UC
   If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
   [M:SOR]QTYPCU(NOL) = VALEUR/[M:SOR]XPCUSTUCOE(NOL)
   Call QTEARR([M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV
   Affzo [M]QTYPCU(NOL)
Endif

#--- Issue 110327
# Si pas de mvt en attente et séries non gérés en sortie ou en E/S globale --> pas de recalcul
#If [F:ITM]SERMGTCOD<2 | ([M:SOR]STOCOU(NOL)<>0 & [F:ITM]SERMGTCOD<>2) End Endif
If [F:ITM]SERMGTCOD<2 | ([M:SOR]STOCOU(NOL)<>0 & !find([F:ITM]SERMGTCOD,2,4)) End Endif
#---

# Si pas de no série saisie --> pas de recalcul
If [M:SOR]SERNUM(NOL)="" End Endif

# La quantité a diminué
If VALEUR < [M:SOR]QTYSTU(NOL)
   WNBSER  = VALEUR
   WNUMDEB = [M:SOR]SERNUM(NOL)
   If WNBSER=1
      [M:SOR]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SOR]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
      Endif
   Endif
# La quantité a augmenté
Else
   # Vérification que les no série n'existent pas
   # pour le surplus et alimentation du no série fin
   WNBSER  = VALEUR-[M:SOR]QTYSTU(NOL)
   WNUMDEB = [M:SOR]SERNUMF(NOL)
   For J=1 To WNBSER
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
         Read [STS]STS0=[M:SOR]ITMREF;WNUMFIN
         #--- Issue 110327
         #If fstat
         #   WNUMDEB = WNUMFIN
         #Else
         #   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
         #Endif
         # Si séries en E/S globale et ligne de stock
         If [F:ITM]SERMGTCOD=4 & [M:SOR]STOCOU(NOL)<>0
            If fstat
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
            Elsif [F:STS]STOCOU<>[M:SOR]STOCOU(NOL)
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
            Elsif [F:STS]ISSDAT<>[0/0/0]
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
            Elsif [F:STS]SDHNUM<>"" &(!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
            Endif
            If OK=1 & [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
              If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                If OK=1  mkstat=2 : Break  Endif
              Endif
            Endif
            #--- No série en cours de traitement?
            If func STKLIB.REC_STOSERW_UID([M:SOR]ITMREF,WNUMFIN,adxuid(1))<>0
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
            Endif
         # Si mouvement en attente et séries en sortie ou E/S globale
         Elsif !fstat
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
         Endif
         WNUMDEB = WNUMFIN
         #--- End issue 110327
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
      Endif
   Next J
   If mkstat=2 End Endif
   [M:SOR]SERNUMF(NOL) = WNUMFIN
Endif

#--- Issue 110327
[M:SOR]QTYSTU(NOL) = VALEUR
#---
Affzo [M:SOR]SERNUM(NOL), SERNUMF(NOL)

End

########################################
Subprog AV_QTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:SOR]STOCOU(nolign-1)=0
   Chgstl QTYPCU(nolign-1) With "AWARNLOW"
Else
   Chgstl QTYPCU(nolign-1) With ""
Endif
End

########################################
Subprog AS_QTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:SOR]STOCOU(nolign-1)=0 | [M:SOR]XPCU(nolign-1)=[M:SOR]STU
   mkstat=2
Endif
End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WVARQTY, WVARQTA, WQTYSTU, WQTYSTUACT, WK
Local    Decimal WORIALLSTU, WORIALLSTUACT         : #--- Bug 41947
Local    Integer OK, NOL, NBL
NOL = nolign-1
NBL = [M:SOR]NBLIG-1

# La quantité a été modifiée
If VALEUR<>[M:SOR]QTYPCU(NOL)

   # Pas de quantité nulle, vous devez supprimer la ligne
   If VALEUR=0
      mkstat=2 : GMESSAGE=mess(392,199,1) : End
   Endif

   # Calcul quantité en US
   If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
   WQTYSTU = VALEUR*[M:SOR]XPCUSTUCOE(NOL)
   Call QTEARR(WQTYSTU,[M:SOR]STU) From TRTDIV

   # Calcul nouvelle quantité UA
   WQTYSTUACT = WQTYSTU

   If [M:SOR]STOCOU(NOL)<>0
      If dim([M:SOR]POT)>0
         # Si gestion en titres ou UI, calcul quantité en UA
         Case [M:SOR]STOMGTCOD
          When 3 : If [M:SOR]POT(NOL)<>0
                      WQTYSTUACT = WQTYSTU*([M:SOR]POT(NOL)/100)
                      Call QTEARR(WQTYSTUACT,[M:SOR]STU) From TRTDIV
                   Endif
          When 4 : If [M:SOR]POT(NOL)<>0
                      WQTYSTUACT = WQTYSTU*[M:SOR]POT(NOL)
                      Call QTEARR(WQTYSTUACT,[M:SOR]STU) From TRTDIV
                   Endif
         Endcase
      Endif
   Endif

   # Variation de la quantité
   WVARQTY = WQTYSTU   -[M:SOR]QTYSTU(NOL)
   WVARQTA = WQTYSTUACT-[M:SOR]QTYSTUACT(NOL)

   #--- TS
   # Si mvt normal, diminution de la quantité,
   # recalcul de la portion de quantité allouée si nécessaire
   If [M:SOR]STOCOU(NOL)<>0 & WVARQTY<0 & [M:SOR]ALLSTUACT(NOL)>0
      [M:SOR]ALLSTUACT(NOL)-=max(0,abs(WVARQTA)-([M:SOR]QTYSTUACT(NOL)-[M:SOR]ALLSTUACT(NOL)))
      [M:SOR]ALLSTU(NOL)   -=max(0,abs(WVARQTY)-([M:SOR]QTYSTU(NOL)   -[M:SOR]ALLSTU(NOL)))
   Endif
   #---

   # Si mvt normal et augmentation de la quantité
   If [M:SOR]STOCOU(NOL)<>0 & WVARQTY>0
      #--- Issue 110327
      # Si no série en sortie ou en E/S globale, il faut calculer la somme des qtés sortie (WK)
      # pour les lignes ayant le męme chrono stock que celle modifiée
      #If [M:SOR]SERMGTCOD=2
      If find([M:SOR]SERMGTCOD,2,4)
      #---
         Case NOL
          When 0       : WK = sigma(J=1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When NBL     : WK = sigma(J=0,NBL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When Default : WK = sigma(J=0,NOL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
                         WK+= sigma(J=NOL+1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
         Endcase
         # Si qté ŕ sortir > disponible - somme (qté sortie - qté sortie origine)
         # du męme chrono
         If WQTYSTU>[M:SOR]AVAQTYSTU(NOL)-WK
            mkstat=2 : GMESSAGE=mess(446,196,1) : End
         Elsif GLABR<>"REO1"
            Gosub VERF_DISPO
            # Pas de stock disponible
            If WQTYSTUACT>WDISPO
               mkstat=2 : GMESSAGE =mess(446,196,1) : End
            Endif
         Endif
      # Sinon si qté ŕ sortir > disponible
      Elsif WQTYSTU>[M:SOR]AVAQTYSTU(NOL)
         mkstat=2 : GMESSAGE=mess(446,196,1) : End
      Elsif GLABR<>"REO1"
         Gosub VERF_DISPO
         # Pas de stock disponible
         If WQTYSTUACT>WDISPO
            mkstat=2 : GMESSAGE =mess(446,196,1) : End
         Endif
      Endif

      #--- Bug 41947
      # Recalcul de la portion de quantité allouée si nécessaire
      If WORIALLSTUACT<>0
         [M:SOR]ALLSTUACT(NOL)+=min(WVARQTA,abs(WORIALLSTUACT-[M:SOR]ALLSTUACT(NOL)))
         [M:SOR]ALLSTU(NOL)   +=min(WVARQTY,abs(WORIALLSTU   -[M:SOR]ALLSTU(NOL)))
      Endif
      #---

   # Mvt en attente et qté totale US + variation US > qté ŕ sortir US
   Elsif [M:SOR]STOCOU(NOL)=0 & ([M:SOR]PECQTYACT+WVARQTA)>[M:SOR]SORQTYACT
      mkstat=2 : GMESSAGE=mess(393,199,1) : End
   Endif

   # Alimentation nouvelles quantités US et UA
   [M:SOR]QTYSTU(NOL)    = WQTYSTU
   [M:SOR]QTYSTUACT(NOL) = WQTYSTUACT
Endif

End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL    = nolign-1

Affzo [M]QTYSTU(NOL)

#--- Issue 110327
# Si pas de mvt en attente et séries non gérés en sortie ou en E/S globale --> pas de recalcul
#If [F:ITM]SERMGTCOD<2 | ([M:SOR]STOCOU(NOL)<>0 & [F:ITM]SERMGTCOD<>2) End Endif
If [F:ITM]SERMGTCOD<2 | ([M:SOR]STOCOU(NOL)<>0 & !find([F:ITM]SERMGTCOD,2,4)) End Endif
#---

# Si pas de no série saisie --> pas de recalcul
If [M:SOR]SERNUM(NOL)="" End Endif

# La quantité a diminué
If VALEUR < [M:SOR]QTYPCU(NOL)
   WNBSER  = [M:SOR]QTYSTU(NOL)
   WNUMDEB = [M:SOR]SERNUM(NOL)
   If WNBSER=1
      [M:SOR]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SOR]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
      Endif
   Endif
# La quantité a augmenté
Else
   # Vérification que les no série n'existent pas
   # et alimentation du no série fin
   WNBSER  = [M:SOR]QTYSTU(NOL)
   WNUMDEB = [M:SOR]SERNUM(NOL)
   For J=2 To WNBSER
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
         Read [STS]STS0=[M:SOR]ITMREF;WNUMFIN
         #--- Issue 110327
         #If fstat
         #   WNUMDEB = WNUMFIN
         #Else
         #   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
         #Endif
         # Si séries en E/S globale et ligne de stock
         If [F:ITM]SERMGTCOD=4 & [M:SOR]STOCOU(NOL)<>0
            If fstat
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
            Elsif [F:STS]STOCOU<>[M:SOR]STOCOU(NOL)
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
            Elsif [F:STS]ISSDAT<>[0/0/0]
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
            Elsif [F:STS]SDHNUM<>"" &(!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
            Endif
            If OK=1 & [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
              If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                If OK=1  mkstat=2 : Break  Endif
              Endif
            Endif
            #--- No série en cours de traitement?
            If func STKLIB.REC_STOSERW_UID([M:SOR]ITMREF,WNUMFIN,adxuid(1))<>0
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
            Endif
         # Si mouvement en attente et séries en sortie ou E/S globale
         Elsif !fstat
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
         Endif
         WNUMDEB = WNUMFIN
         #--- End issue 110327
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
      Endif
   Next J
   If mkstat=2 End Endif
   [M:SOR]SERNUMF(NOL) = WNUMFIN
Endif
Affzo [M:SOR]SERNUM(NOL), SERNUMF(NOL)

End

#########################################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()

If [M:SOR]VCRTYP=34 & !find([M:SOR]AUZSST,"","*")
   Call STKCTRSTA(VALEUR,[M:SOR]AUZSST,0,2,0,mkstat) From STKACT
Endif

End


#########################################################################
# TRAITEMENTS LIES AU PICKING DES LIGNES DE STOCK                       #
#########################################################################

#########################################################################
# Actions de la saisie fenętre (traitement GSAISIE)                     #
#########################################################################

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $FILGAUCHE
# par les nouvelles étiquettes $FILGAUCHE, $FILGAUSTO, $FILGAUSTS, $FILGAU2
#########################################################################
$FILGAUCHE

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

Case currbox
 When GBOXSTO : Gosub FILGAUSTO
 When GBOXSTS : Gosub FILGAUSTS
Endcase
Return

#########################################################################
$FILGAUSTO

If WAFFPICK=0
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
   Return
Endif
# Filtre article, site
WCRITSTO1 = '[F:STO]ITMREF=[M:SOR]ITMREF&[F:STO]STOFCY=[M:SOR]STOFCY'
FILGAUSUP(0)=WCRITSTO1
# Filtre lot
If WCRITSTO2<>""
   FILGAUSUP(0)+='&'+WCRITSTO2
Endif
#--- TS 106217
# Prise en compte filtre version
If [M:SOR]PECECC=2
   # Si version renseignée et exclusive
   If WCRITSTO21<>""
      FILGAUSUP(0)+='&'+WCRITSTO21
   Endif
Endif
#---
# Filtre péremption
If [M:SOR]FLGDLULOT = 1 & WCRITSTO31<>""    # hcb V6cri
   FILGAUSUP(0)+='&'+WCRITSTO31             # hcb V6cri
Elsif [M:SOR]FLGSHLLOT = 1 & WCRITSTO3<>""  # hcb V6cri
   FILGAUSUP(0)+='&'+WCRITSTO3
Endif                                       # hcb V6cri

Gosub FILGAU2

Return

#########################################################################
$FILGAUSTS

If WAFFPICK=0 | [F:ITM]SERMGTCOD<>4
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STS]ITMREF=""&[F:STS]STOFCY=""'
   Return
Endif

# Filtre article, site
WCRITSTO1 = '[F:STS]ITMREF=[M:SOR]ITMREF&[F:STS]STOFCY=[M:SOR]STOFCY'
FILGAUSUP(0)=WCRITSTO1

# Filtre série dispo et ok
FILGAUSUP(0)+='&[F:STS]ISSDAT=[0/0/0]&[F:STS]STOCOU<>0&([F:STS]SDHNUM=""|([F:STS]SDHNUM=[M:SOR]VCRNUM&[F:STS]SDDLIN=[M:SOR]VCRLIN))'

# Filtre lot
If WCRITSTO2<>""
   FILGAUSUP(0)+='&'+WCRITSTO2
Endif
#--- TS 106217
# Prise en compte filtre version
If [M:SOR]PECECC=2
   # Si version renseignée et exclusive
   If WCRITSTO21<>""
      FILGAUSUP(0)+='&'+WCRITSTO21
   Endif
Endif
#---

Gosub FILGAU2

Return

#########################################################################
$FILGAU2

# Filtre inventaire
FILGAUSUP(1)+='&[F:STO]CUNLOKFLG<>2'

# Filtre catégorie emplacement
If dim([M:SOR]LOC)>0 & WCRITSTO5<>""
   FILGAUSUP(1)+='&('+WCRITSTO5+')'         #--- TS 106217  (0-->1)
Endif
#--- TS 106217
# Filtre propriétaire
FILGAUSUP(1)+='&'+WCRITSTO6
#---
# Filtre statuts
If WCRITSTO4<>""
   FILGAUSUP(1)+='&('+WCRITSTO4+')'
Else
   Raz WCRIT
   If [M:SOR]AAASTA=2
      WCRIT+=WCRITSTOA
   Endif
   If [M:SOR]QQQSTA=2
      If WCRIT<>"" WCRIT+='|' Endif
      WCRIT+=WCRITSTOQ
   Endif
   If [M:SOR]RRRSTA=2
      If WCRIT<>"" WCRIT+='|' Endif
      WCRIT+=WCRITSTOR
   Endif
   If WCRIT<>''
      FILGAUSUP(1)+='&('+WCRIT+')'
   Endif
Endif
# Filtre lignes de stock indisponibles
#If [M:SOR]STODISFLG<>2
#   FILGAUSUP(1)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
#Endif
# Filtres supplémentaires
#--- Issue X3-53322
If !find([M:SOR]FLPNNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]LPNNUM,[M:SOR]FLPNNUM)<>0'
Endif
#---
If !find([M:SOR]XPALNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]PALNUM,[M:SOR]XPALNUM)<>0'    #--- TS 106217   (1-->2)
Endif
If !find([M:SOR]XCTRNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]CTRNUM,[M:SOR]XCTRNUM)<>0'    #--- TS 106217   (1-->2)
Endif
If [M:SOR]XPCUFIL<>""
   FILGAUSUP(2)+='&[F:STO]PCU=[M:SOR]XPCUFIL'               #--- TS 106217   (1-->2)
Endif

# Si série en E/S le no doit ętre connu
If [M:SOR]SERMGTCOD=3
   # Si lot (sous-lot) obligatoire le no doit ętre connu
   If [F:ITM]LOTMGTCOD=3
      FILGAUSUP(2)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SERNUM<>""))' #--- TS 106217   (1-->2)
   Elsif [F:ITM]LOTMGTCOD=4
      FILGAUSUP(2)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SLO<>""&[F:STO]SERNUM<>""))' #--- TS 106217   (1-->2)
   Else
      FILGAUSUP(2)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]SERNUM<>""))'                #--- TS 106217   (1-->2)
   Endif
Else
   # Si lot (sous-lot) obligatoire le no doit ętre connu
   If [F:ITM]LOTMGTCOD=3
      FILGAUSUP(2)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""))'                   #--- TS 106217   (1-->2)
   Elsif [F:ITM]LOTMGTCOD=4
      FILGAUSUP(2)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SLO<>""))'    #--- TS 106217   (1-->2)
   Endif
Endif

# Si prise en compte filtre emplacement de la rčgle d'allocation
If [M:SOR]PECTRU=2
   If GSTOLOC<>""
      FILGAUSUP(3)+='&(pat([F:STO]LOC,GSTOLOC)<>0'
   Endif
   If GDEFLOC<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC)<>0'
      Endif
   Elsif GDEFLOCTYP<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
      Endif
   Endif
   If GDEFLOC2<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC2)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC2)<>0'
      Endif
   Elsif GDEFLOCTYP2<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
      Endif
   Endif
   If GDEFLOC3<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC3)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC3)<>0'
      Endif
   Elsif GDEFLOCTYP3<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
      Endif
   Endif
   If FILGAUSUP(3)<>"" FILGAUSUP(3)+=')' Endif
Endif

# Filtre lignes de stock indisponibles
If [M:SOR]STODISFLG<>2
   FILGAUSUP(3)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
Endif

# Filtre stock supplémentaire
If [M:SOR]FILSTO<>""
   FILGAUSUP(3)+='&evalue([M:SOR]FILSTO)'
Endif

#--- TS 106217
# Filtre propriétaire
#FILGAUSUP(3)+='&'+WCRITSTO6
#---

Return
#--- End issue 110327

##########################################################################
$AP_FILGAUCHE

WPICK=2 : Gosub RAFFRAICHI

Return

#########################################################################
$CLE_GAUCHE

#--- Issue 110327
If currbox=GBOXSTO
  SNSLIS = 1       : # Ascendant
  # No série en E/S
  If [M:SOR]SERMGTCOD=3
    LENLIS = 8
    Case [M:SOR]LOTMGT
     When 1,3 : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]SERNUM;[F:STO]STOCOU"
                LENLIS   = 6
     When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STS]RCPDAT;[F:STO]SERNUM;[F:STO]STOCOU"
     When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STS]RCPDAT desc;[F:STO]SERNUM desc;[F:STO]STOCOU Desc"
                SNSLIS   = 2  : # Descendant
    Endcase
  Else
    LENLIS = 7
    Case [M:SOR]LOTMGT
     When 1   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
                LENLIS   = 6
     When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
     When 3   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]SHLDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
     When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STO]LOC desc;[F:STO]STOCOU desc"
                SNSLIS   = 2  : # Descendant
    Endcase
  Endif
#--- Issue 110327
Endif

Return

#########################################################################
$HINT_KEY

#Case currbox
# When Default : Return
# When GBOXSQ1 : HINTLIS(val(right$(GBOXSQ1,8)))="SQD1"
#Endcase

Return

##########################################################################
$DEB_PIC
Local Integer I, WRET
Local Char    SYMBOLE2(20)
#--- Issue 121665
Local Shortint W_K

Return

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $CRE_PIC par les nouvelles étiquettes
# $CRE_PIC, $CRE_PICSTO, $CRE_PICSTS, $CTRL_PIC, $CTRL_DISPO et $ALIM_PIC
#########################################################################
$CRE_PIC
Case currbox
 When GBOXSTO : Gosub CRE_PICSTO
 When GBOXSTS : Gosub CRE_PICSTS
Endcase

Return

#########################################################################
$CRE_PICSTO
Raz WPICKSTO
Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

Gosub CTRL_PIC
If FOK=0 | GERR=1 : Return : Endif

Gosub CTRL_DISPO
If FOK=0 | GERR=1 : Return : Endif

# Contrôle de l'insertion
If [M:SOR]NBLIG+1 >= dim([M:SOR]STA)-1
   FOK=0 : GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:SOR]NBLIG
Insa nolign,1,[M:SOR]NBLIG [M:SOR]NBLIG
[M:SOR]NBLIG += 1
nolign = [M:SOR]NBLIG
NOL = nolign-1
status = 0

[M:SOR]ICOMVTATT(NOL)=""

# Quantité UA restant ŕ traiter
WQTYSTU=max(0,[M:SOR]SORQTYACT-([M:SOR]PECQTYACT+[M:SOR]SHTQTY))

If WDISPO>=WQTYSTU
   [M:SOR]QTYSTUACT(NOL)=WQTYSTU
Else
   [M:SOR]QTYSTUACT(NOL)=WDISPO
Endif

[M:SOR]QTYSTU(NOL) = [M:SOR]QTYSTUACT(NOL)

If dim([M:SOR]POT)>0
   If [M:SOR]STOMGTCOD=3
      [M:SOR]POT(NOL) = [F:STL]POT
   Elsif [M:SOR]STOMGTCOD=4
      [M:SOR]POT(NOL) = [F:STL]ACT
   Endif
   # Si gestion en titres ou UI, calcul quantité en UA
   Case [M:SOR]STOMGTCOD
    When 3 : If [M:SOR]QTYSTUACT(NOL)=[F:STO]QTYSTUACT    : #--- Issue 114287
                [M:SOR]QTYSTU(NOL) = [F:STO]QTYSTU        : #--- Issue 114287
             Elsif [M:SOR]POT(NOL)<>0
                [M:SOR]QTYSTU(NOL) = [M:SOR]QTYSTUACT(NOL)*100/[M:SOR]POT(NOL)
                Call QTEARR([M:SOR]QTYSTU(NOL),[M:SOR]STU) From TRTDIV
             Endif
    When 4 : If [M:SOR]QTYSTUACT(NOL)=[F:STO]QTYSTUACT    : #--- Issue 114287
                [M:SOR]QTYSTU(NOL) = [F:STO]QTYSTU        : #--- Issue 114287
             Elsif [M:SOR]POT(NOL)<>0
                [M:SOR]QTYSTU(NOL) = [M:SOR]QTYSTUACT(NOL)/[M:SOR]POT(NOL)
                Call QTEARR([M:SOR]QTYSTU(NOL),[M:SOR]STU) From TRTDIV
             Endif
   Endcase
Endif

[M:SOR]XPCU(NOL)       = [F:STO]PCU
[M:SOR]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE

If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif
[M:SOR]QTYPCU(NOL) = [M:SOR]QTYSTU(NOL)/[M:SOR]XPCUSTUCOE(NOL)
Call QTEARR([M:SOR]QTYPCU(NOL),[M:SOR]XPCU(NOL)) From TRTDIV

[M:SOR]AVAQTYPCU(NOL)  = WPCUDIS
[M:SOR]AVAQTYSTU(NOL)  = WSTUDIS
[M:SOR]TOTQTYSTU(NOL)  = [F:STO]QTYSTU

If dim([M:SOR]SERNUM)>0  [M:SOR]SERNUM(NOL) = [F:STO]SERNUM Endif
If dim([M:SOR]SERNUMF)>0 [M:SOR]SERNUMF(NOL)= [F:STO]SERNUM Endif

Gosub ALIM_PIC

Return

#########################################################################
$CRE_PICSTS

Raz WPICKSTO

Read [STS]STS0=[F:STS]ITMREF;[F:STS]SERNUM
If fstat
   Call RSTA ("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK
   FOK=0 : Return
Endif
Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
If fstat
   Call RSTA ("STO",[F:STS]STOFCY-num$([F:STS]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

#--- No série en cours de traitement?
If func STKLIB.REC_STOSERW_UID([F:STS]ITMREF,[F:STS]SERNUM,adxuid(1))<>0
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(449,184,1)
   FOK=0  : Return
Endif

If [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
  If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
    OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
    If OK=1  FOK=0 : Return  Endif
  Endif
Endif

Raz I, J, OK
# La ligne de stock est-elle déjŕ dans le tableau [M:SOR]
If [M:SOR]NBLIG <> 0
  I = find([F:STS]STOCOU,[M:SOR]STOCOU(J..[M:SOR]NBLIG-1))
Endif

# Calcul et contrôle disponible ligne de stock
Gosub CTRL_DISPO
If FOK=0 | GERR=1 : Return : Endif

If I<=0
  # Les contrôles sur la ligne de stock ne sont ŕ faire que celle-ci
  # n'est pas déjŕ dans le tableau [M:SOR]
  Gosub CTRL_PIC
  If FOK=0 | GERR=1 : Return : Endif
Else
  # Contrôle du disponible de la ligne de stock du no série
  # cette ligne de stock peut ętre présente plusieurs fois dans le tableau
  Local Decimal WSTOCOU
  WSTOCOU=[M:SOR]STOCOU(I-1)
  WQTY=sigma(J=0,[M:SOR]NBLIG-1,([M:SOR]QTYSTU(J)-[M:SOR]QTYSTUORI(J))*([M:SOR]STOCOU(J)=WSTOCOU))
  WQTY+=1
  If WQTY>[M:SOR]AVAQTYSTU(I-1)
     FOK=0 : GERR=1 : GMESSAGE=mess(446,196,1)
     Return
  Endif

  # Si non article géré en titre ou en UI, et pas plan de réappro
  If !find([M:SOR]STOMGTCOD,3,4) & LABR<>"REO1"
    # La quantité est déjŕ supérieure ŕ la qte ŕ traiter
    If [M:SOR]PECQTYACT+[M:SOR]SHTQTY>=[M:SOR]SORQTYACT
      FOK=0 : GERR=1 : GMESSAGE=mess(393,199,1)
      Return
    Endif
  Endif
  # Recherche si le no série pické peut ętre ajouté ŕ une séquence de séries
  # pour la ligne de stock concernée (début ou fin)
  Raz J
  While OK<>1
    I = find([F:STS]STOCOU,[M:SOR]STOCOU(J..[M:SOR]NBLIG-1))
    If I<>0
      NOL = J+I-1
      J   = NOL+1
      Call PLUS_UN([F:STS]SERNUM,WNUMDEB,LRET) From STKLIB
      If LRET=0 & WNUMDEB=[M:SOR]SERNUM(NOL)
        OK=2 : Break
      Endif
      Call MOINS_UN([F:STS]SERNUM,WNUMFIN,LRET) From STKLIB
      If LRET=0 & WNUMFIN=[M:SOR]SERNUMF(NOL)
        OK=3 : Break
      Endif
    Else
      OK=1
    Endif
  Wend
Endif
# Si OK=2 ou 3, le no série peut ętre ajouté ŕ la ligne de stock indicé par NOL
# dans le tableau [M:SOR]
If OK>1
  If OK=2
    [M:SOR]SERNUM(NOL)  = [F:STS]SERNUM
  Elsif OK=3
    [M:SOR]SERNUMF(NOL) = [F:STS]SERNUM
  Endif
  [M:SOR]QTYSTUACT(NOL) += 1
  [M:SOR]QTYSTU(NOL)    += 1
  [M:SOR]QTYPCU(NOL)    += 1
  [M:SOR]PECQTY         += 1
  [M:SOR]PECQTYACT      += 1
# Sinon il faut ajouter une ligne dans [M:SOR]
Else
  # Contrôle de l'insertion
  If [M:SOR]NBLIG+1 >= dim([M:SOR]STA)-1
    FOK=0 : GERR=1
    GMESSAGE=mess(122,199,1)
    Return
  Endif
  # Ouverture de la ligne
  nolign = [M:SOR]NBLIG
  Insa nolign,1,[M:SOR]NBLIG [M:SOR]NBLIG
  [M:SOR]NBLIG += 1
  nolign = [M:SOR]NBLIG
  NOL = nolign-1
  status = 0

  [M:SOR]SERNUM(NOL)    = [F:STS]SERNUM
  [M:SOR]SERNUMF(NOL)   = [F:STS]SERNUM
  [M:SOR]ICOMVTATT(NOL) = ""
  [M:SOR]QTYSTUACT(NOL) = 1
  [M:SOR]QTYSTU(NOL)    = 1
  [M:SOR]QTYPCU(NOL)    = 1
  If dim([M:SOR]POT)>0
    If [M:SOR]STOMGTCOD=3
      [M:SOR]POT(NOL) = [F:STL]POT
    Elsif [M:SOR]STOMGTCOD=4
      [M:SOR]POT(NOL) = [F:STL]ACT
    Endif
  Endif
  [M:SOR]XPCU(NOL)       = [F:STO]PCU
  [M:SOR]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
  If [M:SOR]XPCUSTUCOE(NOL)=0 [M:SOR]XPCUSTUCOE(NOL)=1 Endif

  [M:SOR]AVAQTYPCU(NOL)  = WPCUDIS
  [M:SOR]AVAQTYSTU(NOL)  = WSTUDIS
  [M:SOR]TOTQTYSTU(NOL)  = [F:STO]QTYSTU

  Gosub ALIM_PIC

Endif

#--- Si no série en cours de traitement ou alloué, il faut l'ajouter au disponible
If [F:ITM]SERMGTCOD=4
  If func STKLIB.REC_STOSERW([M:SOR]ITMREF,[F:STS]SERNUM)<>0
    [M:SOR]AVAQTYPCU(NOL) += 1
    [M:SOR]AVAQTYSTU(NOL) += 1
  Elsif [F:STS]SDHNUM<>"" & [F:STS]SDHNUM=[M:SOR]VCRNUM & [F:STS]SDDLIN=[M:SOR]VCRLIN
    [M:SOR]AVAQTYPCU(NOL) += 1
    [M:SOR]AVAQTYSTU(NOL) += 1
    [M:SOR]ALLSTU(NOL)    += 1
    [M:SOR]ALLSTUACT(NOL) += 1
  Endif
Endif

Return

#########################################################################
#--- Contrôle de la ligne de stock pické
$CTRL_PIC

#--- TS 106217
# Contrôle version par rapport ŕ la rčgle de gestion
If [F:STO]ECCVALMAJ<>""
  #--- Issue X3-133507 by TS
  If [M:SOR]VCRTYP<>34
  #---
    Call CTLECCVALMAJ([F:STO]ITMREF,[M:SOR]WECCVALMAJ,[F:STO]ECCVALMAJ,[M:SOR]RETDAT,"",LRET) From STKSOR
    If LRET<>0
      FOK=0 : GERR=1
      Return
    Endif
  #--- Issue X3-133507 by TS
  Else
    If [F:SRU]ORDVER=2 & [M:SOR]WECCVALMAJ<>"" & [M:SOR]WECCVALMAJ<>[F:STO]ECCVALMAJ
      GMESSAGE=mess(426,184,1)-":"-[M:SOR]WECCVALMAJ
      FOK=0 : GERR=1
      Return
    Endif
  Endif
  #---
Endif
#---

# Contrôle si sortie mono-lot
If GUNTLOT=2 & [M:SOR]NBLIG>0
   If [F:STO]LOT<>[M:SOR]LOT(0)
      OK=1 : Call AVERTIR(mess(211,184,1), OK) From GESECRAN
      Raz GERR : # Sinon pas de dépick dans GSAISIE (la boule reste  bleue)
      If OK=1  FOK=0 : Return  Endif
   Endif
Endif

#--- Bug 86912
If LABR="PNH1" & [M:PNH1]PTHNUM(LNOL)<>"" & [F:STO]LOT<>""
  If clalev([F:STJ])=0  Local File STOJOU [STJ]  Endif
  I=0
  Columns [STJ] (STOFCY,ITMREF,VCRTYP,VCRNUM,VCRLIN,UPDCOD,REGFLG,LOT)
  For [STJ]STJ1 Where STOFCY=[M:PNH1]PNHFCY & VCRTYP=6 & VCRNUM=[M:PNH1]PTHNUM(LNOL)
&                   & VCRLIN=[M:PNH1]PTDLIN(LNOL) & ITMREF=[M:PNH1]ITMREF(LNOL)
&                   & LOT=[F:STO]LOT & UPDCOD=2 & REGFLG<>2
    I+=1 : Break
  Next
  Columns [STJ]
  If I=0
    OK=1 : Call AVERTIR(mess(43,197,1)-[F:STO]LOT+"\"+mess(410,184,1), OK) From GESECRAN
    Raz GERR : # Sinon pas de dépick dans GSAISIE (la boule reste  bleue)
    If OK=1  FOK=0 : Return  Endif
  Endif
Endif
#---

If [F:STO]LOCCAT=2
   Raz WRET
   # Contrôle que la ligne de stock en attente de rangement est complčte
   Call CTLPLFLOC([M:SOR]ITMREF,"",WRET) From STKSOR
   If WRET<>0
      FOK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-": "
      Case WRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Return
   Endif
Endif

#--- Issue 121665
If LABR="REO1"
  Read [STC]STC0=[M:REO1]STOFCY;GREOLOC
  If !fstat
    Call STKCTRSTA([F:STO]STA,[F:STC]AUZSST,0,0,0,W_K) From STKACT
    If W_K<>0
      FOK=0 : GERR=1
      GMESSAGE=[F:STO]STA-mess(832,196,1)-"("+GREOLOC+")"
      Return
    Endif
  Endif
Endif
#---

# Ligne de stock faisant l'objet d'une demande d'analyse
If [M:SOR]PECQLYCTL<>2 & [F:STO]QLYCTLDEM<>""
   FOK=0 : GERR=1
   GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
   If [F:ITM]LOTMGTCOD>1
      GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
   Endif
   If [F:ITM]LOTMGTCOD=4
      GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
   Endif
   If [F:ITM]SERMGTCOD=3
      GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
   Endif
   If [F:ITF]LOCMGTCOD=2
      GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
   Endif
   GMESSAGE+="\"+mess(460,199,1)
   Return
Endif
# Si non administrateur stock, contrôle ligne pickée par rapport
# ŕ la péremption et ŕ la rčgle de gestion
If GSTOADMIN<>2
   WPICKSTO=string$(evalue(GCRITPIC),"OK")
   If WPICKSTO<>"OK"
      FOK=0 : GERR=1
      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
      If [F:ITM]LOTMGTCOD>1
         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
      Endif
      If [F:ITM]LOTMGTCOD=4
         GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
      Endif
      If [F:ITM]SERMGTCOD=3
         GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
      Endif
      If [F:ITF]LOCMGTCOD=2
         GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
      Endif
      GMESSAGE+="\"+mess(366,199,1)
      Return
   Endif
Endif

# Si non article géré en titre ou en UI, et pas plan de réappro
If !find([M:SOR]STOMGTCOD,3,4) & LABR<>"REO1"
   # La quantité est déjŕ supérieure ŕ la qte ŕ traiter
   If [M:SOR]PECQTYACT+[M:SOR]SHTQTY>=[M:SOR]SORQTYACT
      FOK=0 : GERR=1
      GMESSAGE=mess(393,199,1)
      Return
   Endif
Endif

Return

#########################################################################
#--- Calcul et contrôle du disponible de la ligne de stock pické
$CTRL_DISPO

If LABR="REO1"
   #--- Issue 104979
   #WSTUDIS = [F:STO]QTYSTU - [F:STO]CUMWIPQTY
   WSTUDIS = [F:STO]QTYSTU - [F:STO]CUMALLQTY - [F:STO]CUMWIPQTY
   #---
   WPCUDIS = WSTUDIS/[F:STO]PCUSTUCOE
   Call QTEARR(WPCUDIS,[F:STO]PCU) From TRTDIV
   WDISPO  = WSTUDIS
Else

   # Calcul du stock disponible sur l'article
   Raz LTYPLOC, LSTA
   If [M:SOR]PECPLFLOC=2 LTYPLOC+=1 Endif
   If [M:SOR]PECSCOLOC=2 LTYPLOC+=4 Endif
   # Si pas d'emplacements internes
   If [M:SOR]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
   If [M:SOR]AAASTA=2    LSTA   +=1 Endif
   If [M:SOR]QQQSTA=2    LSTA   +=2 Endif
   If [M:SOR]RRRSTA=2    LSTA   +=4 Endif

   #--- Issue 84803 by TS
   If [M:SOR]AUZSST<>[F:SRU]AUZSST & GSTOADMIN=2
     Local Integer L
     Local Integer WWA, WWQ, WWR
     Local Char    WAUZSST(30), WLEFT(30)
     WAUZSST = [M:SOR]AUZSST
     L = instr(1,WAUZSST+',',',')
     Repeat
       WLEFT = left$(WAUZSST,L-1)
       Case left$(WLEFT,1)
         When "A" : WWA = 1
         When "Q" : WWQ = 1
         When "R" : WWR = 1
       Endcase
       WAUZSST = right$(WAUZSST,L+1)
       L = instr(1,WAUZSST+',',',')
     Until WAUZSST=""
     If WWA=1 & [M:SOR]AAASTA<>2 LSTA+=1 Endif
     If WWQ=1 & [M:SOR]QQQSTA<>2 LSTA+=2 Endif
     If WWR=1 & [M:SOR]RRRSTA<>2 LSTA+=4 Endif
   Endif
   #--- End issue 84803

   Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:SOR]PECOWNER,WTOTACTDIS) From STKLIB

   # On retire la somme des quantités saisies
   WTOTACTDIS -= sum([M:SOR]QTYSTUACT)
   # On rajoute l'allouée global
   WTOTACTDIS += [M:SOR]GLOALLQTY

   If [M:SOR]VCRTYPORI<>0 & [M:SOR]VCRNUMORI<>"" & [M:SOR]VCRLINORI<>0
      # Ajout stock alloué sur la pičce origine si création
      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYPORI & VCRNUM=[M:SOR]VCRNUMORI &
&                         VCRLIN=[M:SOR]VCRLINORI & VCRSEQ=[M:SOR]VCRSEQORI
         WTOTACTDIS += [F:STA]QTYSTUACT
      Next
   Else
      # Ajout stock alloué sur la pičce
      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYP & VCRNUM=[M:SOR]VCRNUM &
&                         VCRLIN=[M:SOR]VCRLIN & VCRSEQ=0 & ALLTYP=2
          WTOTACTDIS += [F:STA]QTYSTUACT
      Next
   Endif

   # Contrôle du disponible pour sortie sur la ligne de stock
   Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

   #--- TS en attente (pose des problčmes en maj : stock ayant évolué ----#
   # Pouvoir picker une ligne de stock en rajoutant les allocations de la ligne
   # origine dans le disponible, et en exploitant celles-ci par la suite
   #---------------------#
   #If [F:STO]CUMALLQTA<>0
   #   If [M:SOR]VCRTYPORI<>0 & [M:SOR]VCRNUMORI<>"" & [M:SOR]VCRLINORI<>0
   #      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYPORI & VCRNUM=[M:SOR]VCRNUMORI &
   #&                            VCRLIN=[M:SOR]VCRLINORI & VCRSEQ=[M:SOR]VCRSEQORI &
   #&                            STOCOU=[F:STO]STOCOU
   #         WSTUACTDIS += [F:STA]QTYSTUACT
   #         WSTUDIS    += [F:STA]QTYSTU
   #      Next
   #   Else
   #      For [STA]STA1 Where VCRTYP=[M:SOR]VCRTYP & VCRNUM=[M:SOR]VCRNUM &
   #&                         VCRLIN=[M:SOR]VCRLIN & VCRSEQ=0 & STOCOU=[F:STO]STOCOU
   #         WSTUACTDIS += [F:STA]QTYSTUACT
   #         WSTUDIS    += [F:STA]QTYSTU
   #      Next
   #   Endif
   #   WPCUDIS = WSTUDIS/[F:STO]PCUSTUCOE
   #   Call QTEARR(WPCUDIS,[F:STO]PCU) From TRTDIV
   #Endif
   #--- TS end ---#

   # Disponible = min(dispo ligne stock, dispo article)
   WDISPO = min(WSTUACTDIS,WTOTACTDIS)

   # Pas de stock disponible
   If WDISPO<=0
      FOK=0 : GERR=1
      If WTOTACTDIS <= 0
         GMESSAGE = mess(80,197,1)-[M:SOR]ITMREF-": "
      Else
         GMESSAGE = mess(644,197,1)-": "
      Endif
      GMESSAGE += mess(367,199,1)
      If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
         # La qté en attente de rangement est peut ętre dans une liste ŕ ranger
         GMESSAGE += "\"+mess(150,184,1)
      Endif
      Return
   Endif
Endif

Return

#########################################################################
#--- Alimentation de la ligne de stock pické
$ALIM_PIC

If dim([M:SOR]LOT)>0     [M:SOR]LOT(NOL)    = [F:STO]LOT    Endif
If dim([M:SOR]SLO)>0     [M:SOR]SLO(NOL)    = [F:STO]SLO    Endif
If dim([M:SOR]LOC)>0     [M:SOR]LOC(NOL)    = [F:STO]LOC    Endif
If dim([M:SOR]WRH)>0     [M:SOR]WRH(NOL)    = [F:STO]WRH    Endif

# Ligne de stock avec no série ?
Raz [M:SOR]SERNUMFLG(NOL)
If [F:STO]SERNUM<>"" [M:SOR]SERNUMFLG(NOL)=1 Endif
#--- TS 106217
If dim([M:SOR]ECCVALMAJ)>0 [M:SOR]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ Endif
If dim([M:SOR]ECCVALMIN)>0 [M:SOR]ECCVALMIN(NOL) = [F:STL]ECCVALMIN Endif
#---
[M:SOR]STA(NOL)        = [F:STO]STA
[M:SOR]OWNER(NOL)      = [F:STO]OWNER

If dim([M:SOR]SHLDAT)>0  [M:SOR]SHLDAT(NOL) = [F:STL]SHLDAT Endif

#--- Issue X3-53322
If dim([M:SOR]LPNNUM)>0  [M:SOR]LPNNUM(NOL) = [F:STO]LPNNUM Endif
#---
If dim([M:SOR]PALNUM)>0  [M:SOR]PALNUM(NOL) = [F:STO]PALNUM Endif
If dim([M:SOR]CTRNUM)>0  [M:SOR]CTRNUM(NOL) = [F:STO]CTRNUM Endif

If dim([M:SOR]STOFLD1)>0 [M:SOR]STOFLD1(NOL)= [F:STO]STOFLD1 Endif
If dim([M:SOR]STOFLD2)>0 [M:SOR]STOFLD2(NOL)= [F:STO]STOFLD2 Endif

[M:SOR]STOCOU(NOL)    = [F:STO]STOCOU

[M:SOR]PECQTY        += [M:SOR]QTYSTU(NOL)
[M:SOR]PECQTYACT     += [M:SOR]QTYSTUACT(NOL)

If dim([M:SOR]LOT)>0    Diszo [M:SOR]LOT(NOL)    Endif
If dim([M:SOR]SLO)>0    Diszo [M:SOR]SLO(NOL)    Endif
If dim([M:SOR]LOC)>0    Diszo [M:SOR]LOC(NOL)    Endif
If dim([M:SOR]WRH)>0
   If WRHGES=2
      Diszo [M:SOR]WRH(NOL)
   Else
      Grizo [M:SOR]WRH(NOL)
   Endif
Endif
#--- TS 106217
If dim([M:SOR]ECCVALMAJ)>0 Diszo [M:SOR]ECCVALMAJ(NOL) Endif
#---

If [F:ITM]SERMGTCOD=2
   If dim([M:SOR]SERNUM)>0
      # No série déjŕ existant ou retour fournisseur, pas de saisie
      If [M:SOR]SERNUMFLG(I)=1 | [M:SOR]VCRTYP=8
         Diszo [M:SOR]QTYSTU(NOL)
         Diszo [M:SOR]QTYPCU(NOL)
         Diszo [M:SOR]SERNUM(NOL)
      Else
         Actzo [M:SOR]QTYSTU(NOL)
         Actzo [M:SOR]QTYPCU(NOL)
         # Si trf inter-site mais intra-société, pas de saisie no série
         If [M:SOR]TRFFCY<>"" & [M:SOR]BETCPY<>2
            Diszo [M:SOR]SERNUM(NOL)
         Else
            Actzo [M:SOR]SERNUM(NOL)
         Endif
      Endif
   Else
      Actzo [M:SOR]QTYSTU(NOL)
      Actzo [M:SOR]QTYPCU(NOL)
   Endif
Elsif [F:ITM]SERMGTCOD=3
   Diszo [M:SOR]QTYSTU(NOL)
   Diszo [M:SOR]QTYPCU(NOL)
   If dim([M:SOR]SERNUM)>0 Diszo [M:SOR]SERNUM(NOL) Endif
# Si no séries gérés en E/S globale
Elsif [M:SOR]SERMGTCOD=4
   Actzo [M:SOR]QTYSTU
   Diszo [M:SOR]QTYPCU
   If dim([M:SOR]SERNUM)>0 Actzo [M:SOR]SERNUM Endif
Else
   Actzo [M:SOR]QTYSTU(NOL)
   Actzo [M:SOR]QTYPCU(NOL)
   If dim([M:SOR]SERNUM)>0 Diszo [M:SOR]SERNUM(NOL) Endif
Endif
Diszo [M:SOR]STA(NOL)

Return
#--- End issue 110327

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $ANU_PIC
# par les nouvelles étiquettes $ANU_PIC, $ANU_PICSTO, $ANU_PICSTS
#########################################################################
$ANU_PIC

Raz I,J
Case currbox
 When GBOXSTO : Gosub ANU_PICSTO
 When GBOXSTS : Gosub ANU_PICSTS
Endcase
Return

#########################################################################
$ANU_PICSTO

OK = 0
If [M:SOR]NBLIG <> 0
   # Le dépick d'une ligne de stock peut entraîner la suppression
   # de plusieurs lignes de [SOR] (męme chrono stock)
   # - si article avec no série en sortie
   # - de façon exceptionnelle suite ŕ une régul de mvt en attente ou ...
   While OK <> 1
      I = find([F:STO]STOCOU,[M:SOR]STOCOU(J..[M:SOR]NBLIG-1))
      If I<>0
         NOL = J+I-1
         J   = NOL
         [M:SOR]PECQTY    -= [M:SOR]QTYSTU(NOL)
         [M:SOR]PECQTYACT -= [M:SOR]QTYSTUACT(NOL)
         Dela NOL,1,[M:SOR]NBLIG-1 [M:SOR]NBLIG
         [M:SOR]NBLIG -= 1
         If J>[M:SOR]NBLIG-1 OK=1 Endif
      Else
         OK=1
      Endif
   Wend
Endif

Return

#########################################################################
$ANU_PICSTS

OK = 0
If [M:SOR]NBLIG <> 0
  While OK <> 1
    I = find([F:STS]STOCOU,[M:SOR]STOCOU(J..[M:SOR]NBLIG-1))
    If I<>0
      NOL = J+I-1
      J   = NOL+1
      # Le no sére dépické est celui de la séquence unitaire de série de [M:SOR]
      If [F:STS]SERNUM=[M:SOR]SERNUM(NOL) & [F:STS]SERNUM=[M:SOR]SERNUMF(NOL)
        [M:SOR]PECQTY    -= [M:SOR]QTYSTU(NOL)
        [M:SOR]PECQTYACT -= [M:SOR]QTYSTUACT(NOL)
        Dela NOL,1,[M:SOR]NBLIG-1 [M:SOR]NBLIG
        [M:SOR]NBLIG -= 1
        OK=1
      # Le no série dépické est le premier de la séquence de série de [M:SOR]
      Elsif [F:STS]SERNUM=[M:SOR]SERNUM(NOL)
        [M:SOR]QTYSTU(NOL)    -= 1
        [M:SOR]QTYSTUACT(NOL) -= 1
        [M:SOR]PECQTY         -= 1
        [M:SOR]PECQTYACT      -= 1
        If [M:SOR]ALLSTU(NOL)>0
          [M:SOR]ALLSTU(NOL)    -= 1
          [M:SOR]ALLSTUACT(NOL) -= 1
        Endif
        Call PLUS_UN([F:STS]SERNUM,[M:SOR]SERNUM(NOL),WRET) From STKLIB
        OK=1
      # Le no série dépické est le dernier de la séquence de série de [M:SOR]
      Elsif [F:STS]SERNUM=[M:SOR]SERNUMF(NOL)
        [M:SOR]QTYSTU(NOL)    -= 1
        [M:SOR]QTYSTUACT(NOL) -= 1
        [M:SOR]PECQTY         -= 1
        [M:SOR]PECQTYACT      -= 1
        If [M:SOR]ALLSTU(NOL)>0
          [M:SOR]ALLSTU(NOL)    -= 1
          [M:SOR]ALLSTUACT(NOL) -= 1
        Endif
        Call MOINS_UN([F:STS]SERNUM,[M:SOR]SERNUMF(NOL),WRET) From STKLIB
        OK=1
      # Le no série dépické est dans la séquence de série de [M:SOR]
      # Il faut éclaté en 2 la ligne correspondante dans [M:SOR]
      Elsif [F:STS]SERNUM>[M:SOR]SERNUM(NOL) & [F:STS]SERNUM<[M:SOR]SERNUMF(NOL)
        Insa NOL+1,1,[M:SOR]NBLIG+1 [M:SOR]NBLIG
        [M:SOR]NBLIG += 1
        [M:SOR]ICOMVTATT(NOL+1)  = [M:SOR]ICOMVTATT(NOL)
        [M:SOR]SERNUMFLG(NOL+1)  = [M:SOR]SERNUMFLG(NOL)
        [M:SOR]STA(NOL+1)        = [M:SOR]STA(NOL)
        [M:SOR]XPCU(NOL+1)       = [M:SOR]XPCU(NOL)
        [M:SOR]XPCUSTUCOE(NOL+1) = [M:SOR]XPCUSTUCOE(NOL)
        [M:SOR]OWNER(NOL+1)      = [M:SOR]OWNER(NOL)
        [M:SOR]STOCOU(NOL+1)     = [M:SOR]STOCOU(NOL)
        If dim([M:SOR]LOT)>0       [M:SOR]LOT(NOL+1)       = [M:SOR]LOT(NOL)       Endif
        If dim([M:SOR]SLO)>0       [M:SOR]SLO(NOL+1)       = [M:SOR]SLO(NOL)       Endif
        If dim([M:SOR]ECCVALMAJ)>0 [M:SOR]ECCVALMAJ(NOL+1) = [M:SOR]ECCVALMAJ(NOL) Endif
        If dim([M:SOR]ECCVALMIN)>0 [M:SOR]ECCVALMIN(NOL+1) = [M:SOR]ECCVALMIN(NOL) Endif
        If dim([M:SOR]WRH)>0       [M:SOR]WRH(NOL+1)       = [M:SOR]WRH(NOL)       Endif
        If dim([M:SOR]LOC)>0       [M:SOR]LOC(NOL+1)       = [M:SOR]LOC(NOL)       Endif
        If dim([M:SOR]SHLDAT)>0    [M:SOR]SHLDAT(NOL+1)    = [M:SOR]SHLDAT(NOL)    Endif
        If dim([M:SOR]POT)>0       [M:SOR]POT(NOL+1)       = [M:SOR]POT(NOL)       Endif
        #--- Issue X3-53322
        If dim([M:SOR]LPNNUM)>0    [M:SOR]LPNNUM(NOL+1)    = [M:SOR]LPNNUM(NOL)    Endif
        #---
        If dim([M:SOR]PALNUM)>0    [M:SOR]PALNUM(NOL+1)    = [M:SOR]PALNUM(NOL)    Endif
        If dim([M:SOR]CTRNUM)>0    [M:SOR]CTRNUM(NOL+1)    = [M:SOR]CTRNUM(NOL)    Endif
        If dim([M:SOR]STOFLD1)>0   [M:SOR]STOFLD1(NOL+1)   = [M:SOR]STOFLD1(NOL)   Endif
        If dim([M:SOR]STOFLD2)>0   [M:SOR]STOFLD2(NOL+1)   = [M:SOR]STOFLD2(NOL)   Endif
        If dim([M:SOR]SERNUMF)>0
          [M:SOR]SERNUMF(NOL+1)   = [M:SOR]SERNUMF(NOL)
          Call MOINS_UN([F:STS]SERNUM,[M:SOR]SERNUMF(NOL),WRET) From STKLIB
        Endif
        If dim([M:SOR]SERNUM)>0
          Call PLUS_UN([F:STS]SERNUM,[M:SOR]SERNUM(NOL+1),WRET) From STKLIB
        Endif
        Call NB_SERIE([M:SOR]SERNUM(NOL),[M:SOR]SERNUMF(NOL),WNBSER,WRET) From STKLIB
        [M:SOR]QTYSTU(NOL+1)    = [M:SOR]QTYSTU(NOL)-WNBSER-1
        [M:SOR]QTYPCU(NOL+1)    = [M:SOR]QTYSTU(NOL+1)
        [M:SOR]QTYSTUACT(NOL+1) = [M:SOR]QTYSTU(NOL+1)
        [M:SOR]QTYSTU(NOL)      = WNBSER
        [M:SOR]QTYPCU(NOL)      = [M:SOR]QTYSTU(NOL)
        [M:SOR]QTYSTUORI(NOL)   = [M:SOR]QTYSTU(NOL)
        [M:SOR]QTYSTUACT(NOL)   = [M:SOR]QTYSTU(NOL)
        [M:SOR]TOTQTYSTU(NOL+1) = [M:SOR]TOTQTYSTU(NOL)

        # Le stock dispo ne change pas, il est le męme pour les deux [SOR]
        [M:SOR]AVAQTYSTU(NOL+1) = [M:SOR]AVAQTYSTU(NOL)
        [M:SOR]AVAQTYPCU(NOL+1) = [M:SOR]AVAQTYSTU(NOL+1)
        #WSTUDIS = [M:SOR]AVAQTYSTU(NOL)
        #[M:SOR]AVAQTYSTU(NOL)   = min(WSTUDIS,[M:SOR]QTYSTU(NOL))
        #[M:SOR]AVAQTYPCU(NOL)   = [M:SOR]AVAQTYSTU(NOL)
        #[M:SOR]AVAQTYSTU(NOL+1) = min(WSTUDIS,[M:SOR]QTYSTU(NOL+1))
        #[M:SOR]AVAQTYPCU(NOL+1) = [M:SOR]AVAQTYSTU(NOL+1)

        # On met toute la qté allouée possible sur le [M:SOR] origine
        # puis on complčte sur le nouveau [M:SOR]
        [M:SOR]ALLSTU(NOL+1)    = 0
        [M:SOR]ALLSTUACT(NOL+1) = 0
        [M:SOR]ALLSTU(NOL)      = max(0,[M:SOR]ALLSTU(NOL)-1)
        If [M:SOR]ALLSTU(NOL)>[M:SOR]QTYSTU(NOL)
          [M:SOR]ALLSTU(NOL+1)  = [M:SOR]ALLSTU(NOL)-[M:SOR]QTYSTU(NOL)
          [M:SOR]ALLSTU(NOL)    = [M:SOR]QTYSTU(NOL)
        Endif
        [M:SOR]ALLSTUACT(NOL)   = [M:SOR]ALLSTU(NOL)
        [M:SOR]ALLSTUACT(NOL+1) = [M:SOR]ALLSTU(NOL+1)
        # On met toute la qté origine possible sur le [M:SOR] origine
        # puis on complčte sur le nouveau [M:SOR]
        [M:SOR]QTYSTUORI(NOL+1) = 0
        If [M:SOR]QTYSTUORI(NOL)>[M:SOR]QTYSTU(NOL)
          [M:SOR]QTYSTUORI(NOL+1)  = [M:SOR]QTYSTUORI(NOL)-[M:SOR]QTYSTU(NOL)
          [M:SOR]QTYSTUORI(NOL)    = [M:SOR]QTYSTU(NOL)
        Endif
        [M:SOR]PECQTY    -= 1
        [M:SOR]PECQTYACT -= 1
      Endif
    Else
      OK=1
    Endif
  Wend
Endif

Return
#--- End issue 110327

#########################################################################
$FIN_PIC

Affzo [M:SOR]1-99

If [M:SOR]NBLIG<>0
   # Repositionnement sur la ligne pickée
   zonsui = "[M:SOR]NBLIG("+num$(NOL)+")"
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$TIROIR
#-----------------------------------------------------------------------#
# Remplissage de la liste de picking                                    #
#-----------------------------------------------------------------------#

ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
If WAFFPICK<>0
   WPICK=2
   Gosub RAFFRAICHI
Endif

Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes déjŕ saisies    #
#-----------------------------------------------------------------------#

#--- Issue 110327
If currbox=GBOXSTO
#---
  If [M:SOR]NBLIG <> 0
    For I=0 To [M:SOR]NBLIG-1
      If [M:SOR]STOCOU(I) <> 0
        Read [STO]STO0=[M:SOR]STOFCY;[M:SOR]STOCOU(I)
        Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
        If [M:SOR]SERMGTCOD=3 Read [STS]STS0=[F:STO]ITMREF;[F:STO]SERNUM Endif
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Endif
    Next I
  Endif
#--- Issue 110327
Elsif currbox=GBOXSTS
  If [M:SOR]NBLIG <> 0
    For I=0 To [M:SOR]NBLIG-1
      WRET=0
      For J=1 To [M:SOR]QTYSTU(I)
        If J=1
          WNUMFIN=[M:SOR]SERNUM(I)
        Else
          Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
          If WRET<>0 : Break : Endif
        Endif
        Read [STS]STS0=[M:SOR]ITMREF;WNUMFIN
        Read [STO]STO0=[M:SOR]STOFCY;[F:STS]STOCOU
        WNUMDEB=WNUMFIN
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Next J
    Next I
  Endif
Endif
#--- End issue 110327

Return

##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 17/11/2003 16:39:49 (TS)
##########################################################################
Subprog AV_NBLIG

#Chgfmt [M]LOT(indice) With GWSINVLOT
#Chgfmt [M]SLO(indice) With GWSINVSLO
#Chgfmt [M]SERNUM(indice) With GWSINVSER
#Chgfmt [M]SERNUMF(indice) With GWSINVSERF
#Chgfmt [M]LOC(indice) With GWSINVEMP
#Chgfmt [M]SHLDAT(indice) With GWSINVSHL
#Chgfmt [M]POT(indice) With GWSINVPOT
#Chgfmt [M]QTYSTUACT(indice) With GSINVACT
#Gosub AFF From GSAISIE

End

##########################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOSOR) 03/12/2004 16:18:56 (TS)
######################################################################################

Subprog AV_ICOMVTATT(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
