#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
 When "SETBOUT":    Gosub SETBOUT
 When "DEBUT":    Gosub DEBUT
 When Default
Endcase
Return


$DEBUT
Gosub ACTION From GIMPOBJ
GPE = 1
If GFONCTION = "ZGIMPOBJ"
  [DIA]MODIMP = "ZPQH"
  Grizo [DIA]MODIMP
  Grizo [DIA]AOWSTA
  #Grizo [DIA]TYPEXP
Endif
Return

$SETBOUT
Gosub ACTION From GIMPOBJ
GPE = 1
If GFONCTION = "ZGIMPOBJ"
  Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return
