#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer LTOUSOC : LTOUSOC = 2
Local Char    LSOC : LSOC = ''
Local Integer LTOUCLIENT : LTOUCLIENT = 1
Local Char    LCLIENT : LCLIENT = ''
Local Integer LTRACE : LTRACE = 2
Local Integer LCONT : LCONT = 1
Local Char    LFILETXT(250) : LFILETXT = filpath("tmp","","") + "\resincroBPC.txt"

  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  # borramos el fichero si existe...
  If filinfo(LFILETXT, 7) > 0 Then
    System "ae_rm " + LFILETXT
  Endif
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILETXT Using [ZIMP]
  For [F:ZBPC]
    Call RESYNCHRO_BPCMVT(2,'',1,[F:ZBPC]BPCNUM,2) From FUNBPCMVT
    Wrseq num$(LCONT) + ";" + [F:ZBPC]BPCNUM Using [ZIMP]
    LCONT+=1
#    If LCONT > 10 Then Break Endif
  Next
  # cerramos el fichero
  Openo Using [ZIMP]

End
