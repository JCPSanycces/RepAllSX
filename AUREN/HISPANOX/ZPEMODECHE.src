#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : ZPEMODECHE
# Description : Puntos de entrada MODECHE
# Module      : Ventas
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espaþa
# Created date: 14/06/2022
############################################################################

######################################################################################

######################################################################################
$ACTION
Case ACTION
  When "BEFWRIHDU"  : Gosub BEFWRIHDU
  When Default
Endcase
Return

$BEFWRIHDU
Local Decimal ULTIMP
If clalev ([F:ZHDU])=0  : Local File HISTODUD   [ZHDU]  : Endif
If clalev ([F:ZPYD])=0  : Local File PAYMENTD   [ZPYD]  : Endif
If clalev ([F:ZPYD2])=0  : Local File PAYMENTD   [ZPYD2]  : Endif
If clalev ([F:ZPYH])=0  : Local File PAYMENTH   [ZPYH]  : Endif
If clalev ([F:ZTPY])=0  : Local File TABPAYTYP   [ZTPY]  : Endif
If clalev ([F:ZBPC])=0  : Local File BPCUSTOMER   [ZBPC]  : Endif
If clalev ([F:ZDUD])=0  : Local File GACCDUDATE   [ZDUD]  : Endif
If clalev ([F:ZBANK])=0  : Local File BANK   [ZBANK]  : Endif
If clalev ([F:ZHAE])=0  : Local File GACCENTRY   [ZHAE]  : Endif

If dim(GREPETIDO)<0 :Global Char GREPETIDO(20) : Raz GREPETIDO Endif
Filter [ZHDU] Where ACCNUM=CL1 & DUDLIG=CL2
Read [ZHDU]HDU0 Last Hint Key HDU1
If !fstat
  ULTIMP = [ZHDU]PAYCUR
Else
  ULTIMP = 0
Endif
Filter [ZHDU]
If [F:HDU]FLGEVT= "A" : Return Endif # parece que es un flag que se usa en la anulaciµn

If [F:DUDH]BPRTYP = 1 and [F:DUDH]SNS = 1 and date$>[F:DUDH]DUDDAT and [F:DUDH]PAYCUR>ULTIMP
  Global Char GASUNTOF(200),GLINEA1F(200),GLINEA2F(200),GLINEA3F(200),GLINEA4F(200),GLINEA5F(200),GLINEA6F(200),GLINEA7F(200)
  Raz GASUNTOF,GLINEA1F,GLINEA2F,GLINEA3F,GLINEA4F,GLINEA5F,GLINEA6F,GLINEA7F
  Filter [F:ZPYD] Where [F:ZPYD]DUDNUM =[F:DUDH]ACCNUM Order By UPDDATTIM Desc
  Read [F:ZPYD] First
  If !fstat
    If GREPETIDO <> [F:ZPYD]NUM
      GREPETIDO=[F:ZPYD]NUM
    Else
      Filter [F:ZPYD]
      Return
    Endif
    Read [F:ZPYH]PYH0=[F:ZPYD]NUM
    If [F:ZPYH]STA = 9 and [F:ZPYH]PAYTYP = "SCPAG" # por si entra el pagare y tener en cuenta la contabilizacion
      Filter [F:ZPYD]
      Return
    Endif
    Read [F:ZTPY]TPY0 = [F:ZPYH]PAYTYP;[F:ZPYH]COA
    Read [F:ZBPC]BPC0= [F:ZPYH]BPR
    Read [F:ZBANK] = [F:ZPYH]BAN


    GASUNTOF = "Cobrament Fra/s atraÓade/s client "+[F:ZPYH]BPR+"-"+[F:ZBPC]BPCSHO+" Import total= "+num$([F:ZPYH]AMTBAN)+""
    GLINEA1F = "Bon dia! "
    If [F:ZPYH]PAYTYP = "SCPAG"
      GLINEA2F = "En data "+format$("DZ:DD[/]MM[/]YY",date$)+", Rebut cobrament x "+[F:ZTPY]DES+" amb vto. "+format$("DZ:DD[/]MM[/]YY",[F:ZPYH]ZPAGDAT)+" del client "+[F:ZPYH]BPR+"-"+[F:ZBPC]BPCSHO

    Else
      GLINEA2F = "En data "+format$("DZ:DD[/]MM[/]YY",date$)+", Rebut cobrament x "+[F:ZTPY]DES+" del client "+[F:ZPYH]BPR+"-"+[F:ZBPC]BPCSHO
    Endif
    If [F:ZBANK]BANCSH = 1
      GLINEA3F = "A travÕs del banc "+ [F:ZBANK]DES
    Else
      GLINEA3F = "A travÕs de la Caixa "+ [F:ZBANK]DES
    Endif
    GLINEA4F = "Import total= "+num$([F:ZPYH]AMTBAN)+""
    GLINEA5F = "Que cancel la"+"/"+"les factures atraÓades: "
    For [F:ZPYD2] Where [F:ZPYD2]NUM=[F:ZPYD]NUM
      Read [F:ZDUD]DUD1=[F:ZPYD2]DUDNUM;[F:ZPYD2]DUDLIG
      If !fstat
        GLINEA6F += [F:ZPYD2]VCRNUM+" dÇimport "+num$([F:ZPYD2]PAYLOCLIN)+" amb vto "+ format$("DZ:DD[/]MM[/]YY",[F:ZDUD]DUDDAT) +chr$(13)+chr$(10) #" . "
      Endif
    Next
    GLINEA7F = "Recordar treure el bloqueig del client si el tinguÕs fet per aquest concepte i avisar al Dpto.Comercial perquÒ en tinguin constÁncia."
    Call WORKFLOW (1,"ZEI","",GUSER) From AWRK
  Else
    Filter [F:ZHAE] Where [F:ZHAE]NUM =[F:DUDH]NUM Order By UPDDATTIM Desc
    Read [F:ZHAE] First
    If !fstat
      If [F:ZHAE]BPRVCR <> ""
        Read [F:ZPYH]PYH0 =[F:ZHAE]BPRVCR
        If !fstat
          If [F:ZPYH]PAYTYP = "SCPAG"
            Filter [F:ZHAE]
            Return
          Endif
        Endif
      Endif
    Endif
    Read [F:ZBPC]BPC0= [F:DUDH]BPR
    GASUNTOF = "Cobrament Fra/s atraÓade/s client "+[F:DUDH]BPR+"-"+[F:ZBPC]BPCSHO+" Import total= "+num$([F:DUDH]PAYCUR)+""
    GLINEA1F = "Bon dia!"
    GLINEA2F = "En relaciµ a les factures atraÓades:"
    GLINEA3F = "        - "+[F:DUDH]NUM+" dÇimport "+num$([F:DUDH]PAYCUR)+" amb vto " +format$("DZ:DD[/]MM[/]YY",[F:DUDH]DUDDAT)
    GLINEA4F = "Us informem que en data "+format$("DZ:DD[/]MM[/]YY",date$)+" han estat saldades a travÕs de Marcatge/liquidaciµ neta tercers. "
    GLINEA5F = ""
    GLINEA6F = "Recordar treure el bloqueig del client si el tinguÕs fet per aquest concepte i avisar al Dpto.Comercial perquÒ en tinguin constÁncia."
    Call WORKFLOW (1,"ZEI","",GUSER) From AWRK
  Endif
  Filter [F:ZPYD]
  Kill GASUNTOF,GLINEA1F,GLINEA2F,GLINEA3F,GLINEA4F,GLINEA5F,GLINEA6F,GLINEA7F
Endif
Return
