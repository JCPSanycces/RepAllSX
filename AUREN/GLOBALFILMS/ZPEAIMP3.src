#IMPRIME # PARAM # REPORT -> Puntos de entrada de AIMP3

$ACTION
#Infbox ACTION

   Case ACTION
      When "PARAM"        :    Gosub PARAM
   Endcase
Return

###################################################################################################

#Intervenimos el proceso AIMP3 con el punto de entrada PARAM para generar un fichero PDF en
#un directorio parametrizado al efecto. ( VALORES PARAMETROS / SUP supervisor / Varios / ZDIRDOCWEB ..... C:\SAGE\X3V9\folders\AZETA\ZEMAIL
$PARAM
Local Char WNUMDOC(20)
Local Integer WLONCAD, WLONNUM, WCONTA
Local Char WDIRDOCWEB(250),XVAL(50)

#If [M]PRT="PDF"
#  29 Abobe Acrobat (*.pdf)
#  30 PDF   == NO GENERA PDF !!!!
Call GETPARAM("_FormatExport",NBPAR,PARAMETRE,XVAL) From ETAT
If val(XVAL)=29 or val(XVAL)=30

 Local Char DIR(250)
 Call PARAM(GSOCIETE,"ZDIRDOCWEB",WDIRDOCWEB) From ADOVAL
 If WDIRDOCWEB=""
  WDIRDOCWEB="ZDOCWEB"
#  WDIRDOCWEB="E:\Sage\X3V8\folders\GLOBALPR\ZDOCWEB"
 Endif


# NOMFIC =filpath("","","")+"\ZDOCWEB\TRAZA.TXT"
# NOMFIC ="C:\inetpub\wwwroot\PUBLICACION\PresuPed_CRM_X3\PDFS_TMP\TRAZA.TXT"
# Openo NOMFIC,0 Using [ZBIZ]
# Iomode adxifs "" Using [ZBIZ]
# Iomode adxirs chr$(13)+chr$(10) Using [ZBIZ]
# Iomode adxium 50 Using [ZBIZ]
# For WCONTA=1 To 99
#     Wrseq PARAMETRE(WCONTA) Using [ZBIZ]
# Next
# Openo Using [ZBIZ]
#Local Char FICSRV(250)
#Call GRABARFICHERO(PARAMETRE,FICSRV) From ZCOMUN


   For WCONTA=1 To 99
      If left$(PARAMETRE(WCONTA),11)="facturedeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-11
         WNUMDOC = mid$(PARAMETRE(WCONTA),12,WLONNUM)
         Break
      Elsif left$(PARAMETRE(WCONTA),9)="devisdeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-9
         WNUMDOC = mid$(PARAMETRE(WCONTA),10,WLONNUM)
         Break
      Elsif left$(PARAMETRE(WCONTA),12)="commandedeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-12
         WNUMDOC = mid$(PARAMETRE(WCONTA),13,WLONNUM)
         Break
      Elsif left$(PARAMETRE(WCONTA),13)="livraisondeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-13
         WNUMDOC = mid$(PARAMETRE(WCONTA),14,WLONNUM)
         Break
      Elsif left$(PARAMETRE(WCONTA),8)="ccptdeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-8
         WNUMDOC = mid$(PARAMETRE(WCONTA),9,WLONNUM)
         Break
      Elsif left$(PARAMETRE(WCONTA),10)="mfgnumdeb="
         WLONCAD=len(PARAMETRE(WCONTA))
         WLONNUM=WLONCAD-10
         WNUMDOC = mid$(PARAMETRE(WCONTA),11,WLONNUM)
         Break
      Endif
   Next WCONTA
   For WCONTA=1 To 99
      If left$(PARAMETRE(WCONTA),12)="_ExportFile="
        If instr(1,WDIRDOCWEB,":")<1
          Call CREAR_DIR(WDIRDOCWEB) From ZCOMUN
          PARAMETRE(WCONTA)="_ExportFile="+chr$(1)+filpath("","","")+WDIRDOCWEB+WNUMDOC+".PDF"
        Else
          Call DIR_NOM(WDIRDOCWEB) From ZCOMUN
          PARAMETRE(WCONTA)="_ExportFile="+chr$(1)+WDIRDOCWEB+WNUMDOC+".PDF"
        Endif
#         PARAMETRE(WCONTA)="_ExportFile="+chr$(1)+filpath("","","")+"\ZDOCWEB\"+WNUMDOC+".PDF"
#         PARAMETRE(WCONTA)="_ExportFile="+chr$(1)+"C:\inetpub\wwwroot\PresuPed_CRM_X3\PDFS_TMP\"+WNUMDOC+".PDF"
#         PARAMETRE(WCONTA)="_ExportFile="+chr$(1)+WDIRDOCWEB+"\"+WNUMDOC+".PDF"
#         Local Char FICSRV(250)
#         Call GRABARFICHERO(PARAMETRE,FICSRV) From ZCOMUN
         Break
      Endif
   Next WCONTA
Endif
Return
###################################################################################################
