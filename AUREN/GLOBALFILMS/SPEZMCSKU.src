#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZMCSKU
# Description : Mantenimiento Cliente SKU.
# Module      : Datos base
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espańa
# Created date: 30/06/2022
############################################################################
################################################################
$ACTION

  Case ACTION
    When "OUVRE"            :Gosub OUVRE
    When "DEBUT"            :Gosub DEBUT
    When "OK"               :Gosub OK
    When "APRES_MODIF"      :#Gosub APRES_MODIF
   When Default
  Endcase
Return

################################################################
$OUVRE
If !clalev([F:ZMCSKU]) : Local File ZMCSKU [ZMCSKU] : Endif
If !clalev([F:ZMSKU]) : Local File ZMSKU [ZMSKU] : Endif
Return

################################################################
$APRES_MODIF

Return

$OK
Delete [F:ZMCSKU] Where [F:ZMCSKU]BPCNUM=[F:BPC]BPCNUM
For I=0 To [M:ZMCSKU]NBLIG-1
  Raz [F:ZMCSKU]
  [F:ZMCSKU]BPCNUM=[F:BPC]BPCNUM
  [F:ZMCSKU]SKU=[M:ZMCSKU]SKU(I)
  [F:ZMCSKU]SKUC=[M:ZMCSKU]SKUC(I)
  Write [F:ZMCSKU]
Next
Return

$DEBUT
Raz [M:ZMCSKU]
For [F:ZMCSKU] Where [F:ZMCSKU]BPCNUM = [F:BPC]BPCNUM
  I = [M:ZMCSKU]NBLIG
  [M:ZMCSKU]BPCNUM(I)=[F:BPC]BPCNUM
  [M:ZMCSKU]SKU(I)=[F:ZMCSKU]SKU
  [M:ZMCSKU]SKUC(I)=[F:ZMCSKU]SKUC
  Read [F:ZMSKU]ZMSKU0 = [F:ZMCSKU]SKU
  If !fstat
    [M:ZMCSKU]ITMREF(I)=[F:ZMSKU]ITMREF
    [M:ZMCSKU]ANCHO(I)=[F:ZMSKU]ANCHO
    [M:ZMCSKU]LONG(I)=[F:ZMSKU]LONG
    [M:ZMCSKU]MANDRIL(I)=[F:ZMSKU]MANDRIL
  Endif
  [M:ZMCSKU]NBLIG+=1
Next
Affzo [M:ZMCSKU]
Return



######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMCSKU) 01/07/2022 04:39:38 (ADMIN)
######################################################################################
Subprog AM_SKU(VALEUR)
Variable Char    VALEUR()
Read [F:ZMSKU]ZMSKU0 = VALEUR
If !fstat
  [M:ZMCSKU]ITMREF(nolign-1)=[F:ZMSKU]ITMREF
  [M:ZMCSKU]ANCHO(nolign-1)=[F:ZMSKU]ANCHO
  [M:ZMCSKU]LONG(nolign-1)=[F:ZMSKU]LONG
  [M:ZMCSKU]MANDRIL(nolign-1)=[F:ZMSKU]MANDRIL
Endif
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMCSKU) 01/07/2022 04:46:36 (ADMIN)
######################################################################################
Subprog C_SKU(VALEUR)
Variable Char    VALEUR()
Read [F:ZMSKU]ZMSKU0 = VALEUR
If fstat
  Errbox "SKU valor incorrecto"
  mkstat=2
Endif
End

######################################################################################
