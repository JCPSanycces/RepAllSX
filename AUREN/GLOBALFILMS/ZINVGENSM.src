#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_GEN
  When "TERMINE"        : Gosub TERMINE_GEN
  When "INIT"           : Gosub INIT_DIA_GEN
  When "OK"             : Gosub OK_GEN
  When "END"            : Gosub END_GEN
Endcase
Return

$OUVRE_BATCH
Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Incio generación ENT/SAL Inventario",0) From GESECRAN
Else
  Call OUVRE_TRACE("Incio generación ENT/SAL Inventario") From LECFIC
Endif
Call ECR_TRACE("Generación",0) From GESECRAN
Call ECR_TRACE("Generación",-1) From GESECRAN
Call PRTSCR("ZINVGENSM","","",0,1) From ATRTX3
Call ECR_TRACE("Generación",-1) From GESECRAN
Return

$TRT_INI
If !clalev([ZINVE])  : Local File ZINVE      [ZINVE] : Endif
If !clalev([ZISLO])  : Local File ZINVSTOLOT [ZISLO] : Endif
If !clalev([ZISPR])  : Local File ZINVSTOPRO [ZISPR] : Endif
If !clalev([STO])    : Local File STOCK      [STO]   : Endif
If !clalev([STA])    : Local File STOALL     [STA]   : Endif
If !clalev([ITM])    : Local File ITMMASTER  [ITM]   : Endif
Return

$TERMINE_GEN
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif
Return

$INIT_DIA_GEN
Local Mask ZINVGENSM [ZIGSM]
Raz [M:ZIGSM]
[M:ZIGSM]FECMOV = date$
Return

$OK_GEN
FIN  = 1
Return

$END_GEN
Raz [M:ZIGSM]
FIN = 1
Return

$EXEC_GEN
Local Integer I, J, WCONENT, WCONSAL, LESTASI
Local Char LSTOFCY(5)(1..500)
Local Char LITMREF(10)(1..500)
Local Decimal LSTOCOU(1..500)
Local Decimal LQTYSTU(1..500)
Local Integer LNBRDET, LBOBSAL, LBOBENT
Local Char LARTAUX(10), LULTSLO(5), LULTSLO_ZINV(5), LNUESLO(5), LNUESLOAUX(10)
Local Char WJOBFIC(10), LDESMOV(25)
Local Char WNOMFIC(250)
Local Decimal LNUMLIN, LQTYSAL, LQTYENT, LKGTEOBOB
Local Integer LSLONUM, LSLONUM_ZINV, LNUESLONUM, LUTILIZADO

Gosub TRT_INI

If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Incio generación ENT/SAL inventario",0) From GESECRAN
Else
  Call OUVRE_TRACE("Incio generación ENT/SAL inventario") From LECFIC
Endif
Call ECR_TRACE("Generación ENT/SAL inventario",0) From GESECRAN
Call ECR_TRACE("Generación ENT/SAL inventario",-1) From GESECRAN
Call PRTSCR("ZINVGENSM","","",0,1) From ATRTX3
Call ECR_TRACE("Generación ENT/SAL inventario",-1) From GESECRAN

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

#########################################################################################################
#Tratamiento salidas
Filter [ZINVE] Where [ZINVE]PROCESADO="N" and ACCION="SA"
&      Order By Key ZINVE0
Raz LARTAUX
LDESMOV="INVENTARIO"
LNUMLIN=1000
WCONSAL=0
Delete [ZISPR] Where 1=1
For [ZINVE]
   WCONSAL+=1
   Call ECR_TRACE("Art.: "+[F:ZINVE]ARTICULO+"-"+num$([F:ZINVE]ANCHO)+"-"+num$([F:ZINVE]LONGITUD)+"-"+num$([F:ZINVE]MANDRIL)+
&                 " Lote: "+[F:ZINVE]LOTE+" "+[F:ZINVE]LOTEORI+" Ubic.: "+[F:ZINVE]UBICACION,0) From GESECRAN
   If LARTAUX<>[F:ZINVE]ARTICULO
      If LARTAUX=""
         #Si primera vez -> abrir fichero
         LARTAUX=[F:ZINVE]ARTICULO
         Raz [F:ITM]
         Read [ITM]ITM0=[F:ZINVE]ARTICULO
         If fstat
            Call ECR_TRACE("Error leyendo artículo - fstat: "+num$(fstat),1) From GESECRAN
         Endif

         WJOBFIC = num$(time)
         WNOMFIC = filpath("BQT","SALIDA_"+LARTAUX+"_"+format$("DDMMYYYY",[M:ZIGSM]FECMOV)+"_"+WJOBFIC,"txt")
         Openo WNOMFIC,0 Using [ZSAL]
       Else
         #Si se cambia de articulo -> se cierra fichero y se abre otro fichero
         Openo WNOMFIC Using [ZSAL]

         Raz [F:ITM]
         Read [ITM]ITM0=[F:ZINVE]ARTICULO
         If fstat
            Call ECR_TRACE("Error leyendo artículo - fstat: "+num$(fstat),1) From GESECRAN
         Endif

         LARTAUX=[F:ZINVE]ARTICULO
         WJOBFIC = num$(time)
         WNOMFIC = filpath("BQT","SALIDA_"+LARTAUX+"_"+format$("DDMMYYYY",[M:ZIGSM]FECMOV)+"_"+WJOBFIC,"txt")
         Openo WNOMFIC,0 Using [ZSAL]
       Endif
       LDESMOV="INVENTARIO"+" "+LARTAUX
       Wrseq "E","20","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZSAL]
   Endif
   #Wrseq "E","20","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZSAL]

   Raz LSTOFCY
   Raz LITMREF
   Raz LSTOCOU
   Raz LQTYSTU

   LNBRDET=1
   LBOBSAL=[F:ZINVE]BOBINAS+[F:ZINVE]BOBINASASIG-[F:ZINVE]BOBINASN-[F:ZINVE]BOBINASASIGN
   For I=1 To LBOBSAL
      #Se debe dar de salida el numero de bobinas original, excepto las asignadas
      Filter [STO] Where ITMREF=[F:ZINVE]ARTICULO and STOFCY=[F:ZINVE]PLANTA and LOT=[F:ZINVE]LOTE and
&                        LOC=[F:ZINVE]UBICACION and ZANCHO=[F:ZINVE]ANCHO and ZLONGITUD=[F:ZINVE]LONGITUD and
&                        ZLOTORI=[F:ZINVE]LOTEORI and ZMANDRIL=[F:ZINVE]MANDRIL
      For [STO]
         Filter [STA] Where STOFCY=[F:STO]STOFCY and ITMREF=[F:STO]ITMREF and STOCOU=[F:STO]STOCOU
         LESTASI=1
         For [STA]
            LESTASI=2
            Break
         Next
         Filter [STA]
         LUTILIZADO=1
#         For J=1 To LNBRDET-1
#            If LSTOCOU(J)=[F:STO]STOCOU
#               LUTILIZADO=2
#               Break
#            Endif
#         Next
         Filter [ZISPR] Where PLANTA=[F:STO]STOFCY and ARTICULO=[F:STO]ITMREF and STOCOU=[F:STO]STOCOU
         For [ZISPR]
            LUTILIZADO=2
            Break
         Next
         Filter [ZISPR]
         If LUTILIZADO=1 and LESTASI=1
            LSTOFCY(LNBRDET)=[F:STO]STOFCY
            LITMREF(LNBRDET)=[F:STO]ITMREF
            LSTOCOU(LNBRDET)=[F:STO]STOCOU
            LQTYSTU(LNBRDET)=[F:STO]QTYSTU
            Raz [F:ZISPR]
            [F:ZISPR]PLANTA=[F:STO]STOFCY
            [F:ZISPR]ARTICULO=[F:STO]ITMREF
            [F:ZISPR]STOCOU=[F:STO]STOCOU
            Write [ZISPR]
            LNBRDET+=1
            Break
         Endif
      Next
      Filter [STO]
   Next

   If LNBRDET>0
      #Si stock a dar de salida se calcula el total de la salida
      LQTYSAL=0
      For J=1 To LNBRDET-1
         LQTYSAL+=LQTYSTU(J)
      Next
      Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBSAL),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),
&               num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYSAL),[F:ITM]STU,num$(LQTYSAL) Using [ZSAL]
      LNUMLIN+=1000
      For J=1 To LNBRDET-1
         Raz [F:STO]
         Read [STO]STO0=LSTOFCY(J);LSTOCOU(J)
         Wrseq "S",[F:STO]PCU,num$(0-[F:STO]QTYPCU),[F:STO]LOT,[F:STO]SLO,[F:STO]LOC,[F:STO]STA Using [ZSAL]
      Next
   Endif
Next
Filter [ZINVE]
If LARTAUX<>""
   Openo WNOMFIC Using [ZSAL]
Endif
Call ECR_TRACE("Fin procesamiento salidas",0) From GESECRAN
Call ECR_TRACE("Lineas procesadas (SAL): "+num$(WCONSAL),0) From GESECRAN

#########################################################################################################
#Tratamiento entradas

#Se borran los registros de la tabla sublotes de inventario. En esta tabla se guardan mientras se procesa el fichero
#de recuento del articulo los sublotes nuevos que se generan para el articulo procesado.

Filter [ZINVE] Where [ZINVE]PROCESADO="N" and ACCION="EN"
&      Order By Key ZINVE0
Raz LARTAUX
LDESMOV="INVENTARIO"
LNUMLIN=1000
WCONENT=0
For [ZINVE]
   WCONENT+=1
   Call ECR_TRACE("Art.: "+[F:ZINVE]ARTICULO+"-"+num$([F:ZINVE]ANCHO)+"-"+num$([F:ZINVE]LONGITUD)+"-"+num$([F:ZINVE]MANDRIL)+
&                 " Lote: "+[F:ZINVE]LOTE+" "+[F:ZINVE]LOTEORI+" Ubic.: "+[F:ZINVE]UBICACION,0) From GESECRAN
   If LARTAUX<>[F:ZINVE]ARTICULO
      If LARTAUX=""
         #Si primera vez -> abrir fichero
         LARTAUX=[F:ZINVE]ARTICULO
         Delete [ZISLO] Where ARTICULO=LARTAUX
         Raz [F:ITM]
         Read [ITM]ITM0=[F:ZINVE]ARTICULO
         If fstat
            Call ECR_TRACE("Error leyendo artículo - fstat: "+num$(fstat),1) From GESECRAN
         Endif

         WJOBFIC = num$(time)
         WNOMFIC = filpath("BQT","ENTRADA_"+LARTAUX+"_"+format$("DDMMYYYY",[M:ZIGSM]FECMOV)+"_"+WJOBFIC,"txt")
         Openo WNOMFIC,0 Using [ZENT]
       Else
         #Si se cambia de articulo -> se cierra fichero y se abre otro fichero
         Openo WNOMFIC Using [ZENT]

         Raz [F:ITM]
         Read [ITM]ITM0=[F:ZINVE]ARTICULO
         If fstat
            Call ECR_TRACE("Error leyendo artículo - fstat: "+num$(fstat),1) From GESECRAN
         Endif
         LARTAUX=[F:ZINVE]ARTICULO
         Delete [ZISLO] Where ARTICULO=LARTAUX

         WJOBFIC = num$(time)
         WNOMFIC = filpath("BQT","ENTRADA_"+LARTAUX+"_"+format$("DDMMYYYY",[M:ZIGSM]FECMOV)+"_"+WJOBFIC,"txt")
         Openo WNOMFIC,0 Using [ZENT]
       Endif
       LDESMOV="INVENTARIO"+" "+LARTAUX
       Wrseq "E","19","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZENT]
   Endif

   Raz LSTOFCY
   Raz LITMREF
   Raz LSTOCOU
   Raz LQTYSTU

   #Se calcula el total de la entrada
   LKGTEOBOB=arr(([F:ZINVE]ANCHO/1000*[F:ZINVE]LONGITUD)*[F:ITM]ZFACTOR,0.0001)
   LQTYENT=[F:ZINVE]BOBINASN*LKGTEOBOB

   LBOBENT=[F:ZINVE]BOBINASN+[F:ZINVE]BOBINASASIGN-[F:ZINVE]BOBINAS-[F:ZINVE]BOBINASASIG
   LNUMLIN+=1000
   Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBENT),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),
&            num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYENT),[F:ITM]STU,num$(LQTYENT),num$(1.9748) Using [ZENT]
#&            num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYENT),[F:ITM]STU,num$(LQTYENT),num$([F:ZINVE]PRECOS) Using [ZENT]

   Call ULTSLO(LARTAUX,[F:ZINVE]LOTE,LULTSLO) From ZINVGENSM
   Call ULTSLO_ZINV(LARTAUX,[F:ZINVE]LOTE,LULTSLO_ZINV) From ZINVGENSM

   LSLONUM=val(LULTSLO)
   LSLONUM_ZINV=val(LULTSLO_ZINV)
   If LSLONUM_ZINV>LSLONUM
      LNUESLONUM=LSLONUM_ZINV
   Else
      LNUESLONUM=LSLONUM
   Endif
   For J=1 To LBOBENT
      LNUESLONUM+=1
      LNUESLOAUX="00000"+num$(LNUESLONUM)
      LNUESLO=right$(LNUESLOAUX,len(LNUESLOAUX)-4)
      Wrseq "S",[F:ITM]STU,num$(LKGTEOBOB),"",[F:ZINVE]LOTE,LNUESLO,[F:ZINVE]LOTEORI,[F:ZINVE]UBICACION,"A" Using [ZENT]
      Raz [F:ZISLO]
      [F:ZISLO]ARTICULO=LARTAUX
      [F:ZISLO]LOTE=[F:ZINVE]LOTE
      [F:ZISLO]SUBLOTE=LNUESLO
      Write [ZISLO]
      If fstat
         Call ECR_TRACE("Error grabando sublote [ZISLO] - fstat: "+num$(fstat),1) From GESECRAN
      Endif
   Next
Next
Filter [ZINVE]
If LARTAUX<>""
   Openo WNOMFIC Using [ZENT]
Endif
Call ECR_TRACE("Fin procesamiento entradas",0) From GESECRAN
Call ECR_TRACE("Lineas procesadas (ENT): "+num$(WCONENT),0) From GESECRAN
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

Subprog ULTSLO(WITMREF,WLOT,WSLO)
Value Char WITMREF
Value Char WLOT
Variable Char WSLO

If !clalev([SLO])    : Local File STOLOT     [SLO]   : Endif
Filter [SLO] Where ITMREF=WITMREF and LOT=WLOT
&      Order By Key STL0

WSLO="00000"
For [SLO]
   WSLO=[F:SLO]SLO
Next
Filter [SLO]
End

Subprog ULTSLO_ZINV(WITMREF,WLOT,WSLO)
Value Char WITMREF
Value Char WLOT
Variable Char WSLO

If !clalev([ZISLO])  : Local File ZINVSTOLOT [ZISLO] : Endif
Filter [ZISLO] Where ARTICULO=WITMREF and LOTE=WLOT
&      Order By Key ZISLO0

WSLO="00000"
For [ZISLO]
   WSLO=[F:ZISLO]SUBLOTE
Next
Filter [ZISLO]
End
