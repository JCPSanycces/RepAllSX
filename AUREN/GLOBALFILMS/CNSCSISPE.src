#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta CSI (Facturas venta)
$ACTION
Case ACTION
   When "OUVRE"        :   Gosub OUVRE
   When "FILTRE"       :   Gosub FILTRE
   When "AV_AFFICHE"   :   Gosub AV_AFFICHE
   When "APRES_MODIF"  :   Gosub APRES_MODIF
Endcase
Return

$OUVRE
If clalev([F:SID])= 0 : Local File SINVOICED [SID] : Endif
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:BPC])= 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR])= 0 : Local File BPARTNER [BPR] : Endif
If clalev([F:MVC])= 0 : Local File BPCUSTMVT [MVC] : Endif
If clalev([F:DUD])= 0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCY])= 0 : Local File FACILITY [FCY] : Endif
Local Char WWCPY(10)
Return


$FILTRE
If  CHGPAG=1
  Gosub DEL_CUMUL
  Gosub AFF_CUMUL
Endif
If [M:CSI1]ZFACELEDEB<>""
   WFIL2+="&[F:SIH]XX02FACTELEC>=[M:CSI1]ZFACELEDEB"
Endif
If [M:CSI1]ZFACELEFIN<>""
   WFIL2+="&[F:SIH]XX02FACTELEC>=[M:CSI1]ZFACELEFIN"
Endif
Return


$AV_AFFICHE
If  CHGPAG=1
   Gosub DEL_CUMUL
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Gosub RESTO_DATOS
Return


$APRES_MODIF
Raz [M:CSI2]NBLIG
Effzo [M:CSI2]
Gosub DEL_CUMUL
Gosub AFF_CUMUL
Return


$CAL_CUMUL
Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0
For [SIH]
   If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=5
      #Factura o Proforma
      [M:CSI1]ZTOTIMPAI+=[F:SIH]AMTNOT
      [M:CSI1]ZTOTIMPII+=[F:SIH]AMTATI
   Endif
   If [F:SIH]INVTYP=2
      #Abono
      [M:CSI1]ZTOTIMPAI-=[F:SIH]AMTNOT
      [M:CSI1]ZTOTIMPII-=[F:SIH]AMTATI
   Endif
   Filter [SID] Where NUM=[F:SIH]NUM
   For [SID]
      If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=5
        [M:CSI1]ZTOTKG+=[SID]ZQTYKG
        [M:CSI1]ZTOTM2+=[SID]ZQTYM2
        [M:CSI1]ZBOB  +=[SID]ZQTYBOB
      Elsif [F:SIH]INVTYP=2 and len([SID]SRHNUM)>0
        # Abono FINANCIEROS no hacen referencia a devolucion fisica alguna, por lo que SRHNUM estará vacio
        [M:CSI1]ZTOTKG-=[SID]ZQTYKG
        [M:CSI1]ZTOTM2-=[SID]ZQTYM2
        [M:CSI1]ZBOB  -=[SID]ZQTYBOB
      Endif
#      Raz [F:ITM]
#      Read [ITM]ITM0=[F:SID]ITMREF
#      If [F:SID]SAU="M2"
#         If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=5
#            [M:CSI1]ZTOTKG+=arr([F:SID]QTY*[F:ITM]ZFACTOR,0.01)
#            [M:CSI1]ZTOTM2+=arr([F:SID]QTY,0.01)
#         Endif
#         If [F:SIH]INVTYP=2
#            [M:CSI1]ZTOTKG-=arr([F:SID]QTY*[F:ITM]ZFACTOR,0.01)
#            [M:CSI1]ZTOTM2-=arr([F:SID]QTY,0.01)
#         Endif
#      Endif
#      If [F:SID]SAU="KG"
#         If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=5
#            [M:CSI1]ZTOTKG+=arr([F:SID]QTY,0.01)
#            If [F:ITM]ZFACTOR<>0
#               [M:CSI1]ZTOTM2+=arr([F:SID]QTY/[F:ITM]ZFACTOR,0.01)
#            Else
#               [M:CSI1]ZTOTM2+=0
#            Endif
#         Endif
#         If [F:SIH]INVTYP=2
#            [M:CSI1]ZTOTKG-=arr([F:SID]QTY,0.01)
#            If [F:ITM]ZFACTOR<>0
#               [M:CSI1]ZTOTM2-=arr([F:SID]QTY/[F:ITM]ZFACTOR,0.01)
#            Else
#               [M:CSI1]ZTOTM2+=0
#            Endif
#         Endif
#      Endif
   Next
   Filter [SID]
Next
Filter [SIH]
[M:CSI1]ZTOTKG   =arr([M:CSI1]ZTOTKG,0.01)
[M:CSI1]ZTOTM2   =arr([M:CSI1]ZTOTM2,1)
[M:CSI1]ZTOTIMPAI=arr([M:CSI1]ZTOTIMPAI,0.01)
Return

$AFF_CUMUL
Affzo [M:CSI1]ZBOB
Affzo [M:CSI1]ZTOTKG
Affzo [M:CSI1]ZTOTM2
Affzo [M:CSI1]ZTOTIMPAI
Affzo [M:CSI1]ZTOTIMPII
Return

$DEL_CUMUL
Raz [M:CSI1]ZBOB
Raz [M:CSI1]ZTOTKG
Raz [M:CSI1]ZTOTM2
Raz [M:CSI1]ZTOTIMPAI
Raz [M:CSI1]ZTOTIMPII
Return

$RESTO_DATOS
Local Integer F
For F=0 To [M:CSI2]NBLIG-1
   Raz [M:CSI2]ZKG(F),[M:CSI2]ZM2(F),[M:CSI2]ZBOB(F)
   Filter [SID] Where NUM=[M:CSI2]NUM(F)
   For [SID]
      If [M:CSI2]INVTYP(F)=1 or [M:CSI2]INVTYP(F)=5
        [M:CSI2]ZKG(F) +=[SID]ZQTYKG
        [M:CSI2]ZM2(F) +=[SID]ZQTYM2
        [M:CSI2]ZBOB(F)+=[SID]ZQTYBOB
      Elsif [M:CSI2]INVTYP(F)=2
        # Abono FINANCIEROS no hacen referencia a devolucion fisica alguna, por lo que SRHNUM estará vacio
        If len([SID]SRHNUM)>0
          [M:CSI2]ZKG(F) -=[SID]ZQTYKG
          [M:CSI2]ZM2(F) -=[SID]ZQTYM2
          [M:CSI2]ZBOB(F)-=[SID]ZQTYBOB
        Endif
      Endif
   Next
   Filter [SID]
   [M:CSI2]ZM2(F)=arr([M:CSI2]ZM2(F),1)
   If [M:CSI2]INVTYP(F)=2
      [M:CSI2]AMTNOT(F)=[M:CSI2]AMTNOT(F) *-1
      [M:CSI2]AMTATI(F)=[M:CSI2]AMTATI(F) *-1
      [M:CSI2]AMTPAY(F)=[M:CSI2]AMTPAY(F) *-1
   Endif
   Gosub DATOS_ASEG
Next
Return


$DATOS_ASEG
Local Decimal WWENCOURS
# Cliente
 If [F:BPC]BPCNUM<>[CSI2]BPCINV(F) Then
     Raz [F:BPC]
     Read [F:BPC]BPC0=[CSI2]BPCINV(F)
          Raz [F:BPR]
     Read [F:BPR]BPR0=[CSI2]BPCINV(F)
 Endif
 # Encurso Cliente
  If [F:FCY]FCY<>[CSI2]SALFCY(F)
     Raz [F:FCY]
     Read [F:FCY]FCY0=[CSI2]SALFCY(F)
  Endif
  WWCPY=[F:FCY]LEGCPY

  If [F:MVC]BPCNUM<>[CSI2]BPCINV(F) or [F:MVC]CPY<>WWCPY Then
     Raz [F:MVC]
     Read [F:MVC]MVC1=[CSI2]BPCINV(F);WWCPY

  Endif
  # Vencimiento
  Raz [F:DUD]
  Filter [F:DUD] Where NUM=[M:CSI2]NUM(F)
  Read  [F:DUD]DUD0 First
  Filter [F:DUD]
  [M:CSI2]ZFECVTO(F)=[F:DUD]DUDDAT
  [M:CSI2]ZMODPAG(F)=[F:DUD]PAM
  If [F:BPC]CDTISR <> 0 Then
     [M:CSI2]ZASEGSN(F)=2
  Else
     [M:CSI2]ZASEGSN(F)=1
  Endif
  [M:CSI2]ZASEGIMP(F)=[F:BPC]CDTISR

  [M:CSI2]ZPAIS(F)=[F:BPR]CRY
  Call CALENC([F:BPC]BPCNUM, datesyst, WWENCOURS) From TRTBPMVT
  [M:CSI2]ZTOTENC(F)=WWENCOURS

Return
