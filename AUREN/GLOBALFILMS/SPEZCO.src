$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If [M:ZCO1]ITMREFFIN="" | [M:ZCO1]ITMREFFIN<VALEUR
   [M:ZCO1]ITMREFFIN = VALEUR
   Affzo [M:ZCO1]ITMREFFIN
Endif
End

Subprog AM_ORDDATDEB(VALEUR)
Variable Date    VALEUR
If [M:ZCO1]ORDDATFIN=[0/0/0] | [M:ZCO1]ORDDATFIN<VALEUR
   [M:ZCO1]ORDDATFIN = VALEUR
   Affzo [M:ZCO1]ORDDATFIN
Endif
End

Subprog AM_SHIDATDEB(VALEUR)
Variable Date    VALEUR

If [M:ZCO1]SHIDATFIN=[0/0/0] | [M:ZCO1]SHIDATFIN<VALEUR
   [M:ZCO1]SHIDATFIN = VALEUR
   Affzo [M:ZCO1]SHIDATFIN
Endif
End

Subprog AM_ENDDATDEB(VALEUR)
Variable Date    VALEUR

If [M:ZCO1]ENDDATFIN=[0/0/0] | [M:ZCO1]ENDDATFIN<VALEUR
   [M:ZCO1]ENDDATFIN = VALEUR
   Affzo [M:ZCO1]ENDDATFIN
Endif
End

Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

If [M:ZCO1]CORTE=2
   Affzo [M:ZCO1]PTEASIG
   Affzo [M:ZCO1]PTEASIGSPC
   Affzo [M:ZCO1]ASICSTO
   Affzo [M:ZCO1]PTEPROG
   Affzo [M:ZCO1]PROGRAM
   Affzo [M:ZCO1]PLANIFI
   Affzo [M:ZCO1]COROK
   Affzo [M:ZCO1]CORNOK
   Affzo [M:ZCO1]NOENTREGA
   Affzo [M:ZCO1]ENTREGA
   Affzo [M:ZCO1]FFINMFENT
   Affzo [M:ZCO1]REPDEB1
   Affzo [M:ZCO1]WSTDEB
   Affzo [M:ZCO1]ENDDATDEB
   Affzo [M:ZCO1]ENDDATFIN
   Affzo [M:ZCO1]MFGNUMDEB

   Grizo [M:ZCO1]PTEASIG
   Grizo [M:ZCO1]PTEASIGSPC
   Grizo [M:ZCO1]ASICSTO
   Grizo [M:ZCO1]PTEPROG
   Grizo [M:ZCO1]PROGRAM
   Grizo [M:ZCO1]PLANIFI
   Grizo [M:ZCO1]COROK
   Grizo [M:ZCO1]CORNOK
   Grizo [M:ZCO1]NOENTREGA
   Grizo [M:ZCO1]ENTREGA
   Grizo [M:ZCO1]FFINMFENT
   Grizo [M:ZCO1]REPDEB1
   Grizo [M:ZCO1]WSTDEB
   Grizo [M:ZCO1]ENDDATDEB
   Grizo [M:ZCO1]ENDDATFIN
   Grizo [M:ZCO1]MFGNUMDEB
Else
   Actzo [M:ZCO1]PTEASIG
   Actzo [M:ZCO1]PTEASIGSPC
   Actzo [M:ZCO1]ASICSTO
   Actzo [M:ZCO1]PTEPROG
   Actzo [M:ZCO1]PROGRAM
   Actzo [M:ZCO1]PLANIFI
   Actzo [M:ZCO1]COROK
   Actzo [M:ZCO1]CORNOK
   Actzo [M:ZCO1]NOENTREGA
   Actzo [M:ZCO1]ENTREGA
   Actzo [M:ZCO1]FFINMFENT
   Actzo [M:ZCO1]REPDEB1
   Actzo [M:ZCO1]WSTDEB
   Actzo [M:ZCO1]ENDDATDEB
   Actzo [M:ZCO1]ENDDATFIN
   Actzo [M:ZCO1]MFGNUMDEB
Endif
End


Subprog C_CORTE(VALEUR)
Variable Integer VALEUR

If VALEUR=2
   [M:ZCO1]PTEASIG=1
   [M:ZCO1]PTEASIGSPC=1
   [M:ZCO1]ASICSTO=1
   [M:ZCO1]PTEPROG=1
   [M:ZCO1]PROGRAM=1
   [M:ZCO1]PLANIFI=1
   [M:ZCO1]COROK=1
   [M:ZCO1]CORNOK=1
   [M:ZCO1]NOENTREGA=1
   [M:ZCO1]ENTREGA=1
   [M:ZCO1]FFINMFENT=1
   [M:ZCO1]MFGNUMDEB=""
   [M:ZCO1]REPDEB1=""
   [M:ZCO1]WSTDEB=""
   Affzo [M:ZCO1]PTEASIG
   Affzo [M:ZCO1]PTEASIGSPC
   Affzo [M:ZCO1]ASICSTO
   Affzo [M:ZCO1]PTEPROG
   Affzo [M:ZCO1]PROGRAM
   Affzo [M:ZCO1]PLANIFI
   Affzo [M:ZCO1]COROK
   Affzo [M:ZCO1]CORNOK
   Affzo [M:ZCO1]NOENTREGA
   Affzo [M:ZCO1]ENTREGA
   Affzo [M:ZCO1]FFINMFENT
   Affzo [M:ZCO1]REPDEB1
   Affzo [M:ZCO1]WSTDEB
   Affzo [M:ZCO1]ENDDATDEB
   Affzo [M:ZCO1]ENDDATFIN
   Affzo [M:ZCO1]MFGNUMDEB

   Grizo [M:ZCO1]PTEASIG
   Grizo [M:ZCO1]PTEASIGSPC
   Grizo [M:ZCO1]ASICSTO
   Grizo [M:ZCO1]PTEPROG
   Grizo [M:ZCO1]PROGRAM
   Grizo [M:ZCO1]PLANIFI
   Grizo [M:ZCO1]COROK
   Grizo [M:ZCO1]CORNOK
   Grizo [M:ZCO1]NOENTREGA
   Grizo [M:ZCO1]ENTREGA
   Grizo [M:ZCO1]FFINMFENT
   Grizo [M:ZCO1]REPDEB1
   Grizo [M:ZCO1]WSTDEB
   Grizo [M:ZCO1]ENDDATDEB
   Grizo [M:ZCO1]ENDDATFIN
   Grizo [M:ZCO1]MFGNUMDEB
Else
   Actzo [M:ZCO1]PTEASIG
   Actzo [M:ZCO1]PTEASIGSPC
   Actzo [M:ZCO1]ASICSTO
   Actzo [M:ZCO1]PTEPROG
   Actzo [M:ZCO1]PROGRAM
   Actzo [M:ZCO1]PLANIFI
   Actzo [M:ZCO1]COROK
   Actzo [M:ZCO1]CORNOK
   Actzo [M:ZCO1]NOENTREGA
   Actzo [M:ZCO1]ENTREGA
   Actzo [M:ZCO1]FFINMFENT
   Actzo [M:ZCO1]REPDEB1
   Actzo [M:ZCO1]WSTDEB
   Actzo [M:ZCO1]ENDDATDEB
   Actzo [M:ZCO1]ENDDATFIN
   Actzo [M:ZCO1]MFGNUMDEB
Endif
End
