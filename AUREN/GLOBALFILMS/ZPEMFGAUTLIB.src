#<AdxTL>@(#)0.0.0.0 $Revision$
#<< JLPR 25.10 >>
#MFGAUTLIB (fuente estandar que gestiona importacion OF......SE HA MODIFICADO para permitir la importacion de varias lineas)
#MFIMAJ     -> PE existente antes de realizar el   <<  Write [MFI]  >>
#AUTLIBMAJ  -> PE existente antes de realizar el   <<  Write [MFG]  >>
#ROHMAJ     -> PE existente antes de realizar el   <<  Write [ROH]  >>
#MFMMAJ     -> PE existente antes de realizar el   <<  Write [MFM]  >>
#BOMDET     -> PE existente en CREMAT, que me permite rellenar la mascara [M:MFGX] que es una copia de la [M:MFG2]

$ACTION
#If GUSER="ADMIN"
#Infbox  " $ACTION  " + ACTION + "/"+num$(dim([M:MFGX]ZSUPERFICIE))
#Endif
#If !GIMPORT Return Endif

Case ACTION
   When "MFIMAJ"     :   Gosub MFIMAJ
   When "AUTLIBMAJ"  :   Gosub AUTLIBMAJ
   When "ROHMAJ"     :   Gosub ROHMAJ
   When "BOMDET"     :   Gosub BOMDET
   When "MFMMAJ"     :   Gosub MFMMAJ
Endcase
Return

$ROHMAJ
[F:ROH]LASWORQTY       = [M:MFGK]ZIMPKGS
Return

$AUTLIBMAJ
[F:MFG]EXTQTY          = [M:MFGK]ZIMPKGS
[F:MFG]RMNEXTQTY       = [M:MFGK]ZIMPKGS
Return

$MFIMAJ

[F:MFI]ZGRPCOR         = [M:MFGK]ZGRPCOR
[F:MFI]ZQTYBOB         = [M:MFGK]ZQTYBOB
[F:MFI]ZBOBCTE         = [M:MFGK]ZBOBCTE
[F:MFI]ZBOBSTK         = [M:MFGK]ZBOBSTK
[F:MFI]ZUBICACTE       = [M:MFGK]ZUBICACTE
[F:MFI]ZUBICASTK       = [M:MFGK]ZUBICASTK
[F:MFI]ZANCHO          = [M:MFGK]ZANCHO
[F:MFI]ZNRANCHO        = [M:MFGK]ZNRANCHO
[F:MFI]ZLONGITUD       = [M:MFGK]ZLONGITUD
[F:MFI]ZMFGDATE        = [M:MFGK]ZMFGDATE
[F:MFI]ZEMPALME        = [M:MFGK]ZEMPALME
[F:MFI]ZNTIRADAS       = [M:MFGK]ZNTIRADAS
[F:MFI]ZMANDRIL        = [M:MFGK]ZMANDRIL
[F:MFI]ZFACTOR         = [M:MFGK]ZFACTOR
[F:MFI]ZFABCOR         = [M:MFGK]ZFABCOR
[F:MFI]ZSUPERFICIE     = [M:MFGK]ZSUPERFICIE
[F:MFI]ZIMPLNG         = [M:MFGK]ZIMPLNG
[F:MFI]ZIMPKGS         = [M:MFGK]ZIMPKGS
[F:MFI]ZAUTOMA         = 2 #[M:MFGK]ZAUTOMA
Return

$MFMMAJ
If dim(GZOF)>0 Then
  If GZOF=1 Then
    #If dim([M:MFGX]ZSUPERFICIE(I))<0 : Return Endif
    [F:MFM]ZSUPERFICIE     = [M:MFGX]ZSUPERFICIE(I)
    [F:MFM]ZFABCOR         = [M:MFGX]ZFABCOR(I)
    [F:MFM]ZMANDFLG        = [M:MFGX]ZMANDFLG(I)
    [F:MFM]ZRETQTYREA      = [M:MFGX]ZRETQTYREA(I)
  Endif
Else
    [F:MFM]ZSUPERFICIE     = [M:MFG2]ZSUPERFICIE(I)
    [F:MFM]ZFABCOR         = [M:MFG2]ZFABCOR(I)
    [F:MFM]ZMANDFLG        = [M:MFG2]ZMANDFLG(I)
    [F:MFM]ZRETQTYREA      = [M:MFG2]ZRETQTYREA(I)
Endif
Return

$BOMDET
Read [F:MFO]MFO0=[M:MFGK]MFGNUM;[F:ROO]OPENUM;0
If fstat<>0
  Local Integer NOLM
  Raz [M:MFGX]NBLIG
  NOLM=[M:MFGX]NBLIG
  # Código copiado de SPEMFG2.src  $ADD_MATERIAL   cambiando la máscara [M:MFG2] por [M:MFGX]
  [M:MFGX]CPNTYP(NOLM)     = 1
  [M:MFGX]ITMREF(NOLM)     = [F:ITM]ITMREF
  [M:MFGX]ITMDES1(NOLM)    = [F:ITM]ITMDES1
  [M:MFGX]MFGLIN(NOLM)     = 0
  [M:MFGX]MFGLINK(NOLM)    = 1
  [M:MFGX]QTYCOD(NOLM)     = 1
  [M:MFGX]CUMFLG(NOLM)     = 1
  [M:MFGX]CUMFXDQTY(NOLM)  = 0
  [M:MFGX]BASQTY(NOLM)     = 1
  [M:MFGX]BOMOPE(NOLM)     = 0
  [M:MFGX]BOMOFS(NOLM)     = 0
  [M:MFGX]STU(NOLM)        = [F:ITM]STU
  [M:MFGX]BOMUOM(NOLM)     = [F:ITM]STU
  [M:MFGX]BOMSTUCOE(NOLM)  = 1
  [M:MFGX]BOMQTY(NOLM)     = 1
  [M:MFGX]LIKQTY(NOLM)     = 1
  [M:MFGX]LIKQTYCOD(NOLM)  = 1
  [M:MFGX]QTYRND(NOLM)     = 2
  [M:MFGX]SCA(NOLM)        = 0
  [M:MFGX]BOMSHO(NOLM)     = ""
  [M:MFGX]PICPRN(NOLM)     = 1
  #Campos Especificos Corte
  [M:MFGX]ZFACTOR(NOLM)    = [M:MFGK]ZIMPKGS/[M:MFGK]ZIMPM2S
  [M:MFGX]ZFABCOR(NOLM)    = [F:ITM]ZFABCOR
  [M:MFGX]ZMANDFLG(NOLM)   = 1
  [M:MFGX]ZSUPERFICIE(NOLM)= [M:MFGK]ZIMPM2S
  #
  [M:MFGX]RETQTY(NOLM)     = [M:MFGK]ZIMPKGS
  [M:MFGX]ZRETQTYREA(NOLM) = [M:MFGK]ZIMPKGS
  [M:MFGX]RETDAT(NOLM)     = [M:MFGK]STRDAT
  [M:MFGX]USEQTY(NOLM)     = 0
  [M:MFGX]ALLQTY(NOLM)     = 0
  [M:MFGX]ALLSTA(NOLM)     = 1
  [M:MFGX]SHTQTY(NOLM)     = 0
  [M:MFGX]BOMSEQ(NOLM)     = 0
  [M:MFGX]STOMGTCOD(NOLM)  = 2
  [M:MFGX]PLANNER(NOLM)    = "" : # [F:ITF]PLANNER
  [M:MFGX]SCOFLG(NOLM)     = 1  : # [M:MFMW]SCOFLG
  [M:MFGX]LOC(NOLM)        = "" : # [M:MFMW]LOC
  [M:MFGX]RELSCATIA(NOLM)  = 1  : # [M:MFMW]RELSCATIA        # 47579 mm 09.09
  If dim([M:MFGX]TYPQTY(NOLM)) > 0 : [M:MFGX]TYPQTY(NOLM) = 2 : Endif
  [M:MFGX]PJT(NOLM)        = [M:MFGK]PJT
  [M:MFGX]PTOCOD(NOLM)     = func ITMLIB.GET_PTOCOD([M:MFGX]ITMREF(NOLM),[M:MFGK]MFGFCY) : # GH 09/01/2015 bug 105215
  [M:MFGX]MATSTA(NOLM)     = 1

  [M:MFGX]NBLIG+=1
Endif
LRET=9  # Para evitar que siga la ejecuación del standar
Return
