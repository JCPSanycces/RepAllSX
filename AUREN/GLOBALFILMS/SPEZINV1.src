#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPINVE1 (Especifico)

$ACTION
Local Integer WP
Case ACTION
When "AB1_NBLIG"
  WP=0
  Gosub ABX_NBLIG
When "BB1_NBLIG"
When "AB2_NBLIG"
  WP=1
  Gosub ABX_NBLIG
When "BB2_NBLIG"
When "AB3_NBLIG"
  WP=2
  Gosub ABX_NBLIG
When "BB3_NBLIG"
When "AB4_NBLIG"
  WP=3
  Gosub ABX_NBLIG
When "BB4_NBLIG"

When "AB5_NBLIG"
  WP=4
  Gosub ABX_NBLIG
When "BB5_NBLIG"
When "AB6_NBLIG"
  WP=5
  Gosub ABX_NBLIG
When "BB6_NBLIG"
When "AB7_NBLIG"
  WP=6
  Gosub ABX_NBLIG
When "BB7_NBLIG"
When "AB8_NBLIG"
  WP=7
  Gosub ABX_NBLIG
When "BB8_NBLIG"

Endcase
Return

$ABX_NBLIG
Local Shortint F : F=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
# del 1 al 4 pedidos y del 5 al 8 Entregas
If [M:ZINV1]BOBASIPED(F)>0
  If WP<=3
    WOBJET="SOH"
    WCLE1 =func PED_ASI("PED",WP,F)
  Else
    WOBJET="SDH"
    WCLE1 =func PED_ASI("ENT",WP-4,F)
  Endif
  WCLE2 =""
Else
  Raz WOBJET,WCLE1,WCLE2
Endif
Return

Funprog PED_ASI(TYP,WP,F)
Value Char TYP
Value Integer WP,F
Local Char NUM(GLONVCR)(10)
Call CTAD_ASIG_DET(FFCY,[M:ZINV1]ITMREF(F),[M:ZINV1]ANCHO(F),[M:ZINV1]LONGITUD(F),[M:ZINV1]MANDRIL(F),TYP,"",[M:ZINV1]LOT(F),[M:ZINV1]LOC(F),NUM) From ZCNSSFCSTD
End NUM(WP)






Funprog LOT_ORI(ART,LOT)
Value Char ART,LOT
Local Char TXT(255)(10),BD_TIPO(1),LOT_ORI(GLONLOT)
Raz TXT,LOT_ORI
BD_TIPO=[M:ZINV0]FLDCHR(0)
TXT(0)="select distinct ZLOTORI_0 "
TXT(1)="from STOCK "
TXT(2)="where ITMREF_0='"+ART+"' and LOT_0='"+LOT+"'"
For (Char FLOT(GLONLOT)) From BD_TIPO Sql TXT As [MYT]
  LOT_ORI=FLOT
  Break
Next
End LOT_ORI

Funprog BOB_ASI
Local Integer OK,BOBASI,YN,T
Local Char M(255)
M="Bob Contadas inferior a Asignadas#"
OK=1
BOBASI= [M:ZINV1]BOBASIPED(nolign-1)+[M:ZINV1]BOBASIOF(nolign-1)
If [M:ZINV1]BOBCUENTA(nolign-1)<BOBASI
#  MSG= "Imposible indicar un nş de bobinas inferior a las ASIGNADAS\"+num$([M:ZINV1]BOBCUENTA(nolign-1))+"<"+num$(BOBASI)
#  Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
#  OK=0
  MSG= "No deberia indicar un nş de bobinas inferior a las ASIGNADAS\"+num$([M:ZINV1]BOBCUENTA(nolign-1))+"<"+num$(BOBASI)+"\.\Está seguro de continuar"
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    OK=0
  Else
    [M:ZINV1]ERR(nolign-1)=2
    Affzo [M:ZINV1]ERR(nolign-1)
    T=instr(1,[M:ZINV1]MENSAJE(nolign-1),M)
    If T<1
    [M:ZINV1]MENSAJE(nolign-1)+=M
    Affzo [M:ZINV1]ERR(nolign-1)
    Endif
  Endif
Else
  Call BOB_ASI_MSG(M)
#  [M:ZINV1]MENSAJE(nolign-1)=func ZCOMUN.REPLACE([M:ZINV1]MENSAJE(nolign-1),M,"",1,T)
#   Affzo [M:ZINV1]ERR(nolign-1)
#  If [M:ZINV1]MENSAJE(nolign-1)=""
#    [M:ZINV1]ERR(nolign-1)=1
#    Affzo [M:ZINV1]ERR(nolign-1)
#  Endif
Endif
End OK

Subprog BOB_ASI_MSG(M)
Value Char M
Local Char MSG(255)
Local Integer T
MSG="Bob Contadas inferior a Asignadas#"
If M=""
  M=MSG
Endif
[M:ZINV1]MENSAJE(nolign-1)=func ZCOMUN.REPLACE([M:ZINV1]MENSAJE(nolign-1),M,"",1,T)
Affzo [M:ZINV1]MENSAJE(nolign-1)
If [M:ZINV1]MENSAJE(nolign-1)=""
  [M:ZINV1]ERR(nolign-1)=1
  Affzo [M:ZINV1]ERR(nolign-1)
Endif
End


Subprog PREC_LOT
Local Decimal PRE
Raz PRE
If [M:ZINV1]PRELOT(nolign-1)<=0
  # Mostrar Precio Lote
  If [M:ZINV1]ITMREF(nolign-1)<>""
    #1şQue haya precio para la ubicación
    PRE=func SPEZINVE.PRECIOS_LOT ([M:ZINV0]FFCY,[M:ZINV1]ITMREF(nolign-1),[M:ZINV1]LOT(nolign-1),[M:ZINV1]LOC(nolign-1))
    #2şQue haya precio SIN  la ubicacion
    If PRE<=0
    PRE=func SPEZINVE.PRECIOS_LOT ([M:ZINV0]FFCY,[M:ZINV1]ITMREF(nolign-1),[M:ZINV1]LOT(nolign-1),"")
    Endif
  Endif
  #Si no hay, por defecto será PrecioMedio
  If PRE>0
    [M:ZINV1]PRELOT(nolign-1)=arr(PRE,0.0001)
  Else
    [M:ZINV1]PRELOT(nolign-1)=[M:ZINV1]PREMED(nolign-1)
  Endif
  Affzo [M:ZINV1]PRELOT(nolign-1)
Endif
End

Funprog EXISTE
Local Integer ESTA
ESTA=0
Local Integer F
Local Char MSG(255)
If [M:ZINV1]NUEVA(nolign-1)=2 #or [M:ZINV0]STA=""
  #No puede existir en rejilla
  For F=0 To [M:ZINV1]NBLIG-1
    If F<>nolign-1
      If [M:ZINV1]PROCESADO(F)=1 and [M:ZINV1]ITMREF(F)=[M:ZINV1]ITMREF(nolign-1) and [M:ZINV1]ANCHO(F)=[M:ZINV1]ANCHO(nolign-1) and [M:ZINV1]LONGITUD(F)=[M:ZINV1]LONGITUD(nolign-1) and [M:ZINV1]
& MANDRIL(F)=[M:ZINV1]MANDRIL(nolign-1) and [M:ZINV1]LOC(F)=[M:ZINV1]LOC(nolign-1) and [M:ZINV1]LOT(F)=[M:ZINV1]LOT(nolign-1)
        MSG="Ya existe este ART+ANC+LNG+MND+UBI+LOT en lŞ "+num$(F+1)+"\Deberá indicar las bobinas en dicha fila"
        Break
      Endif
    Endif
  Next
  If MSG=""
    #No puede estar incluido en otro inventario en curso
    MSG=func SPEZINVE.INVENTARIO_EN_CURSO(nolign-1)
  Endif
  If MSG<>""
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    ESTA=1
  Endif
Endif
End ESTA

Funprog ENTRAR_FLD
Local Integer R
If [M:ZINV0]STA="" and ([M:ZINV1]PROCESADO(nolign-1)=2 or [M:ZINV1]ERR(nolign-1)=2 or ([M:ZINV0]ZPROCESO=2 and [M:ZINV1]NUEVA(nolign-1)=1)) or ([M:ZINV0]STA="" and [M:ZINV0]ZPROCESO<>2)
  R=0
Else
  R=1
Endif
End R

Subprog CALCULOS
Local Decimal FSTK
Local Integer M2,BOB
If [M:ZINV1]NUEVA(nolign-1)=2
  BOB=[M:ZINV1]BOBCUENTA(nolign-1)
Else
  BOB=[M:ZINV1]BOBSTK(nolign-1)
Endif

M2=([M:ZINV1]ANCHO(nolign-1)*[M:ZINV1]LONGITUD(nolign-1)/1000)*BOB
If M2<>0
  If [M:ZINV1]KGSSTK(nolign-1)<=0
    [M:ZINV1]KGSSTK(nolign-1)=arr([M:ZINV1]FACTORART(nolign-1)*M2,0.0001)   # KGS    = FACTOR * M2
  Endif
  FSTK=arr([M:ZINV1]KGSSTK(nolign-1)/M2,0.0000001)                          # FACTOR = KGS    / M2
Endif
If FSTK=0
  FSTK=1
Endif
[M:ZINV1]FACTORSTK(nolign-1) =FSTK
Affzo [M:ZINV1]FACTORSTK(nolign-1)
If [M:ZINV1]ANCHO(nolign-1)>0
[M:ZINV1]LNGTEO(nolign-1)    =arr(([M:ZINV1]KGSSTK(nolign-1)/FSTK)/[M:ZINV1]ANCHO(nolign-1)*1000,1)   #arr((FKGS/[M:ZINV1]FACTORSTK(F))/FANC*1000,1)
Endif
Affzo [M:ZINV1]LNGTEO(nolign-1)
End

Subprog DATOS_LOT
#
Raz [M:ZINV1]PRELOT(nolign-1)
Call PREC_LOT
#
If [M:ZINV1]ZLOTORI(nolign-1)=""
  [M:ZINV1]ZLOTORI(nolign-1)=func LOT_ORI([M:ZINV1]ITMREF(nolign-1),[M:ZINV1]LOT(nolign-1))
  Affzo [M:ZINV1]ZLOTORI(nolign-1)
Endif
End

$TEST_ANU
If [M:ZINV0]ZPROCESO<>2
    mkstat = 2
Elsif [M:ZINV1]PROCESADO(NOL)=2
  MSG= "Linea procesada\Imposible eliminarla"
  Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
  mkstat = 2
  Return
Elsif [M:ZINV1]NUEVA(NOL)<2
  MSG= "Linea fijada durante proceso\Imposible eliminarla\Deberá marcarla como IGNORAR"
  Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
  mkstat = 2
  Return
Else
  Local Integer YN : YN=1
  MSG= "Está seguro de eliminar esta linea\.\Recuerde que no deberia BORRAR lineas\Se recomienda marcarla como IGNORAR"
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    mkstat = 2
    Return
  Endif
Endif
[M:ZINV0]FLDCHR(2) ="B"
Return

$TEST_MOD
[M:ZINV0]FLDCHR(2) ="M"
Return

$TEST_INSERT
If [M:ZINV0]ZPROCESO<>2
    mkstat = 2
Elsif [M:ZINV1]NBLIG<=0
  Infbox "Imposible ańadir sin haber FIJADO antes"
  mkstat=2
Else
  [M:ZINV0]FLDCHR(2) ="A"
Endif
Return

$TEST_VALID
Return


