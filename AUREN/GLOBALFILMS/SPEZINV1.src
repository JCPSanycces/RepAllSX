Subprog AV_BOBCUENTA(VALEUR)
Variable Decimal VALEUR
##Antes de campo.....Solo se puede para lineas nuevas
#If not func ENTRAR_FLD
#  mkstat=2
#Endif
If [M:ZINV0]STA="" and [M:ZINV0]ZPROCESO<>2
  mkstat=2
Endif
End

Subprog AM_BOBCUENTA(VALEUR)
Variable Decimal VALEUR
Local Decimal RVAL
If VALEUR=0 and [M:ZINV1]BOBCUENTA(nolign-1)>0 and [M:ZINV1]OK(nolign-1)=2
  [M:ZINV1]OK(nolign-1)=1
  Affzo [M:ZINV1]OK(nolign-1)
  If [M:ZINV1]ERR(nolign-1)=2
    Call BOB_ASI_MSG("")
  Endif
Elsif VALEUR>0 or  [M:ZINV1]OK(nolign-1)=2
  [M:ZINV1]OK(nolign-1)=2
  Affzo [M:ZINV1]OK(nolign-1)
  RVAL=[M:ZINV1]BOBCUENTA(nolign-1)
  [M:ZINV1]BOBCUENTA(nolign-1)=VALEUR
  If not func BOB_ASI
    [M:ZINV1]BOBCUENTA(nolign-1)=RVAL
    mkstat=2
    End
  Endif
Endif
If [M:ZINV1]NUEVA(nolign-1)=2 #or [M:ZINV0]STA=""
  If VALEUR<1
    mkstat=2
  Else
#    [M:ZINV1]BOBSTK(nolign-1)=0
#    Affzo [M:ZINV1]BOBSTK(nolign-1)
    [M:ZINV1]LNGSTK(nolign-1)=[M:ZINV1]LONGITUD(nolign-1)*VALEUR
    Affzo [M:ZINV1]LNGSTK(nolign-1)
    Raz [M:ZINV1]KGSSTK(nolign-1)
    Call CALCULOS
  Endif
Endif
End

Subprog C_BOBCUENTA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 and [M:ZINV1]NUEVA(nolign-1)=2  #([M:ZINV1]NUEVA(nolign-1)=2 or [M:ZINV0]STA="")
  mkstat=2
Endif
End


Subprog AV_OK(VALEUR)
Variable Integer VALEUR
#Antes de campo.....Solo se puede marcar manualmente para indicar que NO HAY BOBINAS
If ([M:ZINV0]STA="" and [M:ZINV0]ZPROCESO=2 and [M:ZINV1]BOBCUENTA(nolign-1)>0) or  [M:ZINV1]PROCESADO(nolign-1)=2 or ([M:ZINV0]STA="" and [M:ZINV0]ZPROCESO<>2)#  or [M:ZINV1]ERR(nolign-1)=2
  mkstat=2
Endif
End

Subprog AM_OK(VALEUR)
Variable Integer VALEUR
Local Integer K,RVAL
If VALEUR=2
    If not func BOB_ASI
    mkstat=2
    End
  Endif
Elsif [M:ZINV1]BOBCUENTA(nolign-1)=0 and [M:ZINV1]ERR(nolign-1)=2
  RVAL=[M:ZINV1]BOBCUENTA(nolign-1)
  [M:ZINV1]BOBCUENTA(nolign-1)=[M:ZINV1]BOBASIPED(nolign-1)+[M:ZINV1]BOBASIOF(nolign-1)  # PAra aegurarme de que se cumple
  K=func BOB_ASI
  [M:ZINV1]BOBCUENTA(nolign-1)=RVAL
Endif
End


Subprog AV_KGSSTK(VALEUR)
Variable Decimal VALEUR
#Antes de campo.....Solo se puede para lineas nuevas
If not func ENTRAR_FLD
  mkstat=2
Endif
End

Subprog AM_KGSSTK(VALEUR)
Variable Decimal VALEUR
[M:ZINV1]KGSSTK(nolign-1)=VALEUR
Call CALCULOS
# Avisar en caso de que haya mas de un 10% de difŞ respecto al factor del articulo
Local Decimal DIF,P
DIF=[M:ZINV1]FACTORART(nolign-1)-[M:ZINV1]FACTORSTK(nolign-1)
P=arr(DIF*100/[M:ZINV1]FACTORART(nolign-1),0.01)
If P>=10
  Local Char MSG(255)
  Local Integer YN : YN=1
  MSG="Esta seguro de continuar\El factor resultante "+num$([M:ZINV1]FACTORSTK(nolign-1))+" tiene una difŞ de "+num$(P)+"%\Respecto al teórico del articulo "+num$([M:ZINV1]FACTORART(nolign-1))
  Call OUINON(MSG , YN) From GESECRAN
  If YN=1
    mkstat=2
    End
  Endif
Endif
End

Subprog AV_PRELOT(VALEUR)
Variable Decimal VALEUR
#Antes de campo.....Solo se puede para lineas nuevas
If not func ENTRAR_FLD
  mkstat=2
Endif
End

Subprog AM_PRELOT(VALEUR)
Variable Decimal VALEUR
[M:ZINV1]PRELOT(nolign-1)=VALEUR
# Avisar en caso de que haya mas de un 10% de difŞ respecto al Precio Medio del articulo
Local Decimal DIF,P
DIF=[M:ZINV1]PREMED(nolign-1)-[M:ZINV1]PRELOT(nolign-1)
P=arr(DIF*100/[M:ZINV1]PREMED(nolign-1),0.01)
If P>=10
  Local Char MSG(255)
  Local Integer YN : YN=1
  MSG="Esta seguro de continuar\El precio lote indicado "+num$([M:ZINV1]PRELOT(nolign-1))+" tiene una difŞ de "+num$(P)+"%\Respecto al precio medio del articulo "+num$([M:ZINV1]PREMED(nolign-1))
  Call OUINON(MSG , YN) From GESECRAN
  If YN=1
    mkstat=2
    End
  Endif
Endif
End

Subprog AV_ZLOTORI(VALEUR)
Variable Char    VALEUR()
#Antes de campo.....Solo se puede para lineas nuevas
If not func ENTRAR_FLD
  mkstat=2
Endif
End

Subprog AV_IGNORAR(VALEUR)
Variable Integer VALEUR
#Antes de campo.....Solo se puede para lineas nuevas
If (not func ENTRAR_FLD or [M:ZINV0]FLDCHR(2)="A") and not ([M:ZINV0]FLDCHR(2)="M" and [M:ZINV1]PROCESFECHA(nolign-1)="")or ([M:ZINV0]STA="" and [M:ZINV0]ZPROCESO<>2)
  mkstat=2
Endif
End

Subprog AM_IGNORAR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZINV1]PROCESADO(nolign-1)=VALEUR
  Affzo [M:ZINV1]PROCESADO(nolign-1)
Elsif [M:ZINV1]PROCESFECHA(nolign-1)=""
  [M:ZINV1]PROCESADO(nolign-1)=VALEUR
  Affzo [M:ZINV1]PROCESADO(nolign-1)
Endif
End
