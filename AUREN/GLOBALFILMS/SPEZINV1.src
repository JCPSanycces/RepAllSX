Subprog APRES_NBLIG
#Despues de linea
#Infbox "Hola desde APRES_NBLIG  (Despues de linea)"
# Si existe articulo, imposible ańadir fila, en su lugar ajustar la existente....De estar procesada, habrá que fijar un nuevo inventario
# Grabar fila
[M:ZINV0]FLDCHR(2)=""
End

Subprog C_NBLIG
#Control
#--------------------------------------------------------#
# Contrôle sur numéro de ligne                           #
#--------------------------------------------------------#
# mkstat=2   para impedir accion                         #
#--------------------------------------------------------#
Case status
When 65:             #GMODIF = 1                      # Annulation simple
                     NOL=nolign-1
                     Gosub TEST_ANU
When 68,83:          #GMODIF = 1
                     For NOL=nolign-1 To nolign1-1    # Annulation multiple
                         Gosub TEST_ANU
                         If mkstat : Break : Endif
                     Next NOL
When 75:             #GMODIF=0                        # Modification
                     NOL=nolign-1
                     Gosub TEST_MOD
When 73,82:          NOL=nolign-1                     # Insertion
                     Gosub TEST_INSERT
When 1,4,5,20,21,26,31,92,93: Gosub TEST_VALID
Endcase
End

