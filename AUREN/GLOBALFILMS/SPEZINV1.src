Subprog IB_NBLIG
#Inic campo
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4  # Pedidos venta
Raz GBOUT5,GBOUT6,GBOUT7,GBOUT8  # Albaranes venta
Local Shortint F : F=nolign-1
Local Char NUM(GLONVCR)(10)
If [M:ZINV1]BOBASIPED(F)>0
  Call CTAD_ASIG_DET(FFCY,[M:ZINV1]ITMREF(F),[M:ZINV1]ANCHO(F),[M:ZINV1]LONGITUD(F),[M:ZINV1]MANDRIL(F),"PED","",[M:ZINV1]LOT(F),[M:ZINV1]LOC(F),NUM) From ZCNSSFCSTD
  If NUM(0)<>"" : GBOUT1="Pedido "+ NUM(0) : Endif
  If NUM(1)<>"" : GBOUT2="Pedido "+ NUM(1) : Endif
  If NUM(2)<>"" : GBOUT3="Pedido "+ NUM(2) : Endif
  If NUM(3)<>"" : GBOUT4="Pedido "+ NUM(3) : Endif
  Call CTAD_ASIG_DET(FFCY,[M:ZINV1]ITMREF(F),[M:ZINV1]ANCHO(F),[M:ZINV1]LONGITUD(F),[M:ZINV1]MANDRIL(F),"ENT","",[M:ZINV1]LOT(F),[M:ZINV1]LOC(F),NUM) From ZCNSSFCSTD
  If NUM(0)<>"" : GBOUT5="Entrega "+ NUM(0) : Endif
  If NUM(1)<>"" : GBOUT6="Entrega "+ NUM(1) : Endif
  If NUM(2)<>"" : GBOUT7="Entrega "+ NUM(2) : Endif
  If NUM(3)<>"" : GBOUT8="Entrega "+ NUM(3) : Endif
Endif
End






Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
#Antes de campo.....Solo se puede para lineas nuevas
If not func ENTRAR_FLD
  mkstat=2
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:ZINV1]ITMREF(nolign-1)=VALEUR
If func EXISTE
  mkstat=2
  End
Endif
Local Decimal PREC(3)
Call PRECIOS([M:ZINV0]FFCY,[M:ZINV1]ITMREF(nolign-1),PREC) From SPEZINVE
# Mostrar precio coste
[M:ZINV1]PRECOS(nolign-1)=PREC(0)
Affzo [M:ZINV1]PRECOS(nolign-1)
# Mostrar precio medio
[M:ZINV1]PREMED(nolign-1)=PREC(1)
Affzo [M:ZINV1]PREMED(nolign-1)
#
Raz [M:ZINV1]PRELOT(nolign-1)
Call PREC_LOT
# Linea ańadida manualmente
[M:ZINV1]NUEVA(nolign-1)=2
Affzo [M:ZINV1]NUEVA(nolign-1)
# Sacar factor teórico del artiuclo
If clalev([F:ITM])<=0   :  Local File ITMMASTER [F:ITM] : Endif
Read [F:ITM]ITM0=[M:ZINV1]ITMREF(nolign-1)
If fstat=0
  [M:ZINV1]FACTORART(nolign-1)=arr([ITM]ZFACTOR,0.0000001)
  Affzo [M:ZINV1]FACTORART(nolign-1)
Endif
# Mostrar lote
If [M:ZINV0]FLOT<>""
  [M:ZINV1]LOT(nolign-1)=[M:ZINV0]FLOT
  Call DATOS_LOT
Endif
End


