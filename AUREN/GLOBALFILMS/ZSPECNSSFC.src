Subprog AM_LONGITUD(VALEUR)
Variable Decimal VALEUR
If [M:ZSFC1]LONGITUD2<VALEUR
  [M:ZSFC1]LONGITUD2=VALEUR
  Affzo [M:ZSFC1]LONGITUD2
Endif
End

Subprog AM_ANCHODESDE(VALEUR)
Variable Decimal VALEUR
If [M:ZSFC1]ANCHOHASTA<VALEUR
  [M:ZSFC1]ANCHOHASTA=VALEUR
  Affzo [M:ZSFC1]ANCHOHASTA
Endif
End

