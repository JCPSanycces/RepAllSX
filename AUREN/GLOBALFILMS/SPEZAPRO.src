#<AdxTL>@(#)0.0.0.0 $Revision$
#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
  When "OUVRE"       :  Gosub OUVRE
  When "TITRE"       :  Gosub TITRE_S
  When "DEBUT"       :  Gosub DEBUT
  When "SETBOUT"     :  Gosub SETBOUT

  When "BOUTON"      :  Gosub BOUTON
  When "APRES_MODIF" :  Gosub APRES_MODIF

  When "END"         :  Gosub FIN_S
Endcase
Return

$OUVRE
Local Integer FLAG_ERR,FLG_OK
Local Char BD_TIPO(1)
Local Integer YN
Local Date FSTD(12)

If clalev([F:SOHX])<=0   :  Local File SORDER    [F:SOHX] : Endif
If clalev([F:SOQX])<=0   :  Local File SORDERQ   [F:SOQX] : Endif
If clalev([F:SOPX])<=0   :  Local File SORDERP   [F:SOPX] : Endif
If !clalev([F:ITM])      :  Local File ITMMASTER [F:ITM]  : Endif
If !clalev([F:STO])      :  Local File STOCK     [F:STO]  : Endif
If !clalev([F:ADI])      :  Local File ATABDIV   [F:ADI]  : Endif

# Tope de filas en rejilla
Local Integer TFILAS_CTE,TFILAS_RES
#Call PARAM("","ZTOPE",TOPE_FILAS) From ADOVAL        #  "" = PLANTA
#val(func AFNC.PARAM("ZTOPE",""))-1    #  "" = PLANTA
TFILAS_CTE= 99
TFILAS_RES= 499
#
Local Char PEDRES(GLONTSO)
Call PARAM("","ZPEDRES",PEDRES) From ADOVAL        #  "" = PLANTA
#
FLG_OK=-1
Return

$FIN_S
Return

$TITRE_S
TIT="NECESIDADES APROVISIONAMIENTO << EN PRUEBAS # PDTE.VALIDAR >>"
Return


$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
Case maskcou
When "ZPAPRO0"
  Case COUZON
  When "PRESENTACION","MOSTRAR","TOTALES","FECORI"
    Return
  Endcase
When "ZPAPRO1"
  Return
Endcase
Call VACIAR_REJILLA
Return


$DEBUT
# Valores por defecto
Gosub BORRA_PANTALLA
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
#Infbox "hola desde DEBUT"
[M:ZPAPR0]FLDCHR(0)=BD_TIPO
[M:ZPAPR0]FLDCHR(1)=PEDRES
[M:ZPAPR0]FLDDEC(0)=TFILAS_CTE
[M:ZPAPR0]FLDDEC(1)=TFILAS_RES
#Infbox [M:ZPAPR0]FLDCHR(0) + "  " + [M:ZPAPR0]FLDCHR(1)
[M:ZPAPR0]HORIZONTE   =3  # 3 meses
[M:ZPAPR0]FECORI      =1  # 1 pedidos
[M:ZPAPR0]PRESENTACION=1  # 1 Kgs
[M:ZPAPR0]MOSTRAR     =1  # 1 Todo
# Se asume primer dia del mes anterior
[M:ZPAPR0]FECFIN      =eomonth(addmonth(date$,-1))
[M:ZPAPR0]FECINI      =func ZCOMUN.CHAR_TO_DATE("01/" + format$("D:MM[/]YYYY",addmonth([M:ZPAPR0]FECFIN,-11)))
Call FILTROS_ABC
Return

$SETBOUT
# BOTONES, ańadidos a la derecha.    Por defecto SI habilitados
# MENUS  , ańadidos a la derecha.    Por defecto NO habilitados

# Refresco los valores iniciales
If FLG_OK=-1
  FLG_OK=0
  Affzo [M:ZPAPR0]10-15
Endif
#
Call TITULOS_REJILLA
Return


$BOUTON
Case BOUT
  When "1"    :     Gosub BUSCAR
Endcase
Return



#===================================
#Subrutinas propias
#===================================

$BUSCAR
FLG_OK=1
Call COMPROBACIONES(FLG_OK)
If not FLG_OK
  Return
Endif
#
# Se muestran los articulos que esten incluidos en pedidos o Stock
Call MOSTRAR
Call MOSTRAR_COLOR
#
#Onerrgo
Return


$BORRA_PANTALLA
Call VACIAR_REJILLA
Raz [M:ZPAPR0]  ##NCTES,[M:ZPAPR0]NABC
Effzo [M:ZPAPR0]20-25
Return



Subprog MOSTRAR
Local Char MSG(255),ABC_COD(5)
Local Char TXT(255)(15)
Local Integer F,OK,TF,X,HAYFIL_ANC,HAYFIL_ART,ABCTODOS,FLG_OK0
Local Decimal Z
#Onerrgo ERRORES_FIN
Local Char BD_TIPO(1)
BD_TIPO=[M:ZPAPR0]FLDCHR(0)
#
Call OUVRE_VLC("SACANDO DATOS - Articulos","Articulo","Estado") From GESECRAN
#
ABCTODOS=func ABC_TODOS
Call MONTAR_SQL(TXT)
Call VACIAR_REJILLA
#Local Integer YN
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  Return
#Endif

# Grabo en un fichero, pues a partir de cierto nş de registros no puedo anidar FOR pues da error de SQL ocupado con otra consulta
Local Char FSRVTMP(250)
FSRVTMP= filpath("tmp",num$(timestamp$),"txt")    # Nombre del fichero de destino en el servidor
Openo FSRVTMP Using [FIC1]                        # Lo abre para escritura
Iomode adxifs  ";"  Using [FIC1]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC1]
Iomode adxium  50 Using [FIC1] #  50 = ASCII  0 = UTF8
Raz TF
For (Char FLITM0(GLONITM),Integer FLANCHO0,Integer FLLARGO0,Integer FLMANDRIL0) From BD_TIPO Sql TXT As [ZMYT]
  Wrseq FLITM0,FLANCHO0,FLLARGO0,FLMANDRIL0 Using [FIC1]
  TF+=1
Next
Openo Using [FIC1]                                # Lo cierra


# Abro fichero
Openi FSRVTMP Using [FIC2]                        # Lo abre para lectura
Iomode adxifs  ";"  Using [FIC2]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC2]
Iomode adxium  50 Using [FIC2] #  50 = ASCII  0 = UTF8
Local Char FLITM(GLONITM)
Local Integer FLANCHO,FLLARGO,FLMANDRIL
# Totales por Articulo y Articulo+Ancho
Local Integer TANC(7),TART(7),TFIN(7)
Local Char RART(GLONITM)
Local Integer RANC
Raz RART,RANC,TANC,TART,TFIN,HAYFIL_ANC
FLG_OK0=1
Repeat
  Rdseq FLITM,FLANCHO,FLLARGO,FLMANDRIL Using [FIC2]
  If FLITM=""
    Break
  Endif
#  If FLITM="194"
#    Infbox "Debugger"
#  Endif
  If [M:ZPAPR0]TOTALES=1
    If RART<>FLITM
      Gosub MOSTRAR_TOT_ART
      RART=FLITM
      RANC=FLANCHO
      Raz HAYFIL_ART,HAYFIL_ANC
      Read [F:ITM]ITM0=FLITM
      If fstat
        Infbox "Avise al programador.....No existe articulo ("+PITM+")   fstat="+num$(fstat)
        Break
      Endif
    Endif
    If RANC<>FLANCHO
      Gosub MOSTRAR_TOT_ANC
      RANC=FLANCHO
      Raz HAYFIL_ANC
    Endif
  Endif
  MSG ="ITM = ("+FLITM+") \ "
  MSG+="ANC=("+num$(FLANCHO)+") \ "
  MSG+="LAR=("+num$(FLLARGO)+") \ "
  MSG+="MAN=("+num$(FLMANDRIL)+") \ "
#  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  F=[M:ZPAPR1]NBLIG
  Call AFF_VLC(MSG,num$(F+1)-" de "-num$(TF)-"   "-num$(arr(100*(F+1)/TF,1))-"%") From GESECRAN
  OK=1
#  If not ABCTODOS
    Raz ABC_COD
    Filter [F:ADI] Where NUMTAB=6004 and A1=FLITM and N1=FLANCHO and N2=FLLARGO
    Read [F:ADI] First
    If fstat=0
      ABC_COD=[F:ADI]A2
    Else
      fstat=0
    Endif
    Filter [F:ADI]
    OK=func ABC_OK(ABC_COD)
#  Endif
  If OK
    Gosub MOSTRAR_OK
    If not FLG_OK0
      Break
    Endif
  Endif
Until fstat <> 0
Openi Using [FIC2]
If [M:ZPAPR0]TOTALES=1
  Gosub MOSTRAR_TOT_ART
  If [M:ZPAPR0]FITM=""
    # Mostrar TOT_FIN
    F=[M:ZPAPR1]NBLIG
    [M:ZPAPR1]ITMREF(F)    = "TOTAL FINAL "
    [M:ZPAPR1]STKFIS(F)    = TFIN(0)
    [M:ZPAPR1]STKRES1(F)   = TFIN(1)
    [M:ZPAPR1]STKRES(F)    = TFIN(2)
    [M:ZPAPR1]STKDIS(F)    = [M:ZPAPR1]STKFIS(F)-[M:ZPAPR1]STKRES(F)-[M:ZPAPR1]STKRES1(F)
    [M:ZPAPR1]STKPDT(F)    = TFIN(3)
    [M:ZPAPR1]STKENT(F)    = [M:ZPAPR1]STKFIS(F)+[M:ZPAPR1]STKPDT(F)
    [M:ZPAPR1]STKDEM(F)    = TFIN(4)
    [M:ZPAPR1]STKDEM1(F)   = TFIN(5)
    [M:ZPAPR1]STKDEM2(F)   = TFIN(6)
    [M:ZPAPR1]STKSAL(F)    = [M:ZPAPR1]STKDEM(F)+[M:ZPAPR1]STKDEM1(F)+[M:ZPAPR1]STKDEM2(F)
    [M:ZPAPR1]STK(F)       = [M:ZPAPR1]STKENT(F)-[M:ZPAPR1]STKSAL(F)
    [M:ZPAPR1]NBLIG+=1
  Endif
Endif
Call FERME_VLC   From GESECRAN
Affzo [M:ZPAPR1]5
F=Delfile(FSRVTMP)
If F<>0
  MSG="No se pudo borrar fichero temporarl\"+FSRVTMP
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
Endif
#Onerrgo
End

$MOSTRAR_OK
[M:ZPAPR1]ITMREF(F)    = FLITM
[M:ZPAPR1]ZANCHO(F)    = FLANCHO
[M:ZPAPR1]ZLONGITUD(F) = FLLARGO
[M:ZPAPR1]ZABC(F)      = ABC_COD
[M:ZPAPR1]ZMANDRIL(F)  = FLMANDRIL
[M:ZPAPR1]ZFACTOR(F)   = [F:ITM]ZFACTOR
# Entradas
[M:ZPAPR1]STKFIS(F)    = func STKFIS([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO)
[M:ZPAPR1]STKRES1(F)   = func STKRES_PED_RES([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FLDCHR(1))
[M:ZPAPR1]STKRES(F)    = -[M:ZPAPR1]STKRES1(F)+func STKRES([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO)
[M:ZPAPR1]STKDIS(F)    = [M:ZPAPR1]STKFIS(F)-[M:ZPAPR1]STKRES(F)-[M:ZPAPR1]STKRES1(F)
[M:ZPAPR1]STKPDT(F)    = func STKPDT([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO)
[M:ZPAPR1]STKENT(F)    = [M:ZPAPR1]STKFIS(F)+[M:ZPAPR1]STKPDT(F)
# Salidas
[M:ZPAPR1]STKDEM(F)    = func STKDEM ([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FLDCHR(1),2)
[M:ZPAPR1]STKDEM1(F)   = func STKDEM ([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FLDCHR(1),3)
[M:ZPAPR1]STKDEM2(F)   = func STKDEM2([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO)
[M:ZPAPR1]STKSAL(F)    = [M:ZPAPR1]STKDEM(F)+[M:ZPAPR1]STKDEM1(F)+[M:ZPAPR1]STKDEM2(F)
#
[M:ZPAPR1]STK(F)       = [M:ZPAPR1]STKENT(F)-[M:ZPAPR1]STKSAL(F)
Case [M:ZPAPR0]MOSTRAR
When 1  # Todo
  OK=1
When 2  # Solo faltas
  OK=([M:ZPAPR1]STK(F)<0)
When 3  # Solo sobrante
  OK=([M:ZPAPR1]STK(F)>0)
When 4  # Solo cero
  OK=([M:ZPAPR1]STK(F)=0)
Endcase
If [M:ZPAPR1]STKENT(F)=0 and [M:ZPAPR1]STKSAL(F)=0 and [M:ZPAPR0]SINSTPD=1
  OK=0
Endif
If OK
  Gosub MOSTRAR_OK_RESTO
Else
  Raz [M:ZPAPR1]ITMREF(F) , [M:ZPAPR1]ZANCHO(F) , [M:ZPAPR1]ZLONGITUD(F), [M:ZPAPR1]ZMANDRIL(F)
  Raz [M:ZPAPR1]STKFIS(F) , [M:ZPAPR1]STKRES1(F), [M:ZPAPR1]STKRES(F)   , [M:ZPAPR1]STKDIS(F)
  Raz [M:ZPAPR1]STKPDT(F) , [M:ZPAPR1]STKENT(F) , [M:ZPAPR1]STKDEM(F)   , [M:ZPAPR1]STKDEM1(F)
  Raz [M:ZPAPR1]STKDEM2(F), [M:ZPAPR1]STKSAL(F) , [M:ZPAPR1]STK(F)
Endif
Return

$MOSTRAR_OK_RESTO
[M:ZPAPR1]VTAMES(F)  = func VTAMES([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO)
If [M:ZPAPR1]VTAMES(F)<>0 and [M:ZPAPR1]STK(F)>0
[M:ZPAPR1]PREVIS(F)  = ([M:ZPAPR1]VTAMES(F)*[M:ZPAPR0]HORIZONTE)-[M:ZPAPR1]STK(F)
[M:ZPAPR1]TIESTK(F)  = func ZCOMUN.REDONDEAR([M:ZPAPR1]STK(F)/[M:ZPAPR1]VTAMES(F),2)
Endif
[M:ZPAPR1]NUMCTES(F) = func VTA_COMUN([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FECINI,[M:ZPAPR0]FECFIN,2,0)
[M:ZPAPR1]VTAMED(F)  = func VTA_COMUN([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FECINI,[M:ZPAPR0]FECFIN,1,0)
For X=0 To 11
  If [M:ZPAPR0]FLDDAT(X)<>[0/0/0]
    Z=func VTA_COMUN([M:ZPAPR0]FFCY,FLITM,FLANCHO,FLLARGO,FLMANDRIL,[M:ZPAPR0]PRESENTACION,BD_TIPO,[M:ZPAPR0]FLDDAT(X),eomonth([M:ZPAPR0]FLDDAT(X)),1,1)
    [M:ZPAPR1]MESVTA_0(F)+=Z
    Case X
    When 0
      [M:ZPAPR1]MESVTA_1(F)= Z
    When 1
      [M:ZPAPR1]MESVTA_2(F)= Z
    When 2
      [M:ZPAPR1]MESVTA_3(F)= Z
    When 3
      [M:ZPAPR1]MESVTA_4(F)= Z
    When 4
      [M:ZPAPR1]MESVTA_5(F)= Z
    When 5
      [M:ZPAPR1]MESVTA_6(F)= Z
    When 6
      [M:ZPAPR1]MESVTA_7(F)= Z
    When 7
      [M:ZPAPR1]MESVTA_8(F)= Z
    When 8
      [M:ZPAPR1]MESVTA_9(F)= Z
    When 9
      [M:ZPAPR1]MESVTA_10(F)= Z
    When 10
      [M:ZPAPR1]MESVTA_11(F)= Z
    When 11
      [M:ZPAPR1]MESVTA_12(F)= Z
    Endcase
  Endif
Next
#Acumulo
If [M:ZPAPR0]TOTALES=1
  TANC(0)+=[M:ZPAPR1]STKFIS(F)
  TANC(1)+=[M:ZPAPR1]STKRES1(F)
  TANC(2)+=[M:ZPAPR1]STKRES(F)
  TANC(3)+=[M:ZPAPR1]STKPDT(F)
  TANC(4)+=[M:ZPAPR1]STKDEM(F)
  TANC(5)+=[M:ZPAPR1]STKDEM1(F)
  TANC(6)+=[M:ZPAPR1]STKDEM2(F)
Endif
#Cuento fila, para mostrar total
HAYFIL_ANC+=1
#Controlar total filas Rejilla
If [M:ZPAPR0]TOTALES=1
  X=3  # Para acomodar lineas de totales  (Ancho+Articulo+Final)
Else
  X=0
Endif
If [M:ZPAPR1]NBLIG+X>=[M:ZPAPR0]FLDDEC(1)
  MSG="Alcanzado máximo de " + num$([M:ZPAPR0]FLDDEC(1)+1) + " filas para mostrar resultados\.\Ajuste los filtros"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  FLG_OK0=0
Else
  [M:ZPAPR1]NBLIG+=1
Endif
Return

$MOSTRAR_TOT_ART
If RART<>"" and HAYFIL_ART+HAYFIL_ANC>0
  Gosub MOSTRAR_TOT_ANC
  # Mostrar
  If not([M:ZPAPR0]FITM<>"" and [M:ZPAPR0]FZANCHO>0)
    X=2
  Else
    X=1
  Endif
  If HAYFIL_ART>1
    F=[M:ZPAPR1]NBLIG
    [M:ZPAPR1]ITMREF(F)    = "TOTAL Artículo "+[M:ZPAPR1]ITMREF(F-X)
    [M:ZPAPR1]STKFIS(F)    = TART(0)
    [M:ZPAPR1]STKRES1(F)   = TART(1)
    [M:ZPAPR1]STKRES(F)    = TART(2)
    [M:ZPAPR1]STKDIS(F)    = [M:ZPAPR1]STKFIS(F)-[M:ZPAPR1]STKRES(F)-[M:ZPAPR1]STKRES1(F)
    [M:ZPAPR1]STKPDT(F)    = TART(3)
    [M:ZPAPR1]STKENT(F)    = [M:ZPAPR1]STKFIS(F)+[M:ZPAPR1]STKPDT(F)
    [M:ZPAPR1]STKDEM(F)    = TART(4)
    [M:ZPAPR1]STKDEM1(F)   = TART(5)
    [M:ZPAPR1]STKDEM2(F)   = TART(6)
    [M:ZPAPR1]STKSAL(F)    = [M:ZPAPR1]STKDEM(F)+[M:ZPAPR1]STKDEM1(F)+[M:ZPAPR1]STKDEM2(F)
    [M:ZPAPR1]STK(F)       = [M:ZPAPR1]STKENT(F)-[M:ZPAPR1]STKSAL(F)
  Endif
  [M:ZPAPR1]NBLIG+=1
  # Acumular para TOT_FIN
  For X=0 To dim(TANC)-1
    TFIN(X)+=TART(X)
  Next
  # Borrar
  Raz TART
Endif
Return

$MOSTRAR_TOT_ANC
If RANC>0 and HAYFIL_ANC>0
  # Mostrar
  If not([M:ZPAPR0]FITM<>"" and [M:ZPAPR0]FZANCHO>0) and HAYFIL_ANC>1
    F=[M:ZPAPR1]NBLIG
    [M:ZPAPR1]ITMREF(F)    = "Total Ancho "+num$([M:ZPAPR1]ZANCHO(F-1))
    [M:ZPAPR1]STKFIS(F)    = TANC(0)
    [M:ZPAPR1]STKRES1(F)   = TANC(1)
    [M:ZPAPR1]STKRES(F)    = TANC(2)
    [M:ZPAPR1]STKDIS(F)    = [M:ZPAPR1]STKFIS(F)-[M:ZPAPR1]STKRES(F)-[M:ZPAPR1]STKRES1(F)
    [M:ZPAPR1]STKPDT(F)    = TANC(3)
    [M:ZPAPR1]STKENT(F)    = [M:ZPAPR1]STKFIS(F)+[M:ZPAPR1]STKPDT(F)
    [M:ZPAPR1]STKDEM(F)    = TANC(4)
    [M:ZPAPR1]STKDEM1(F)   = TANC(5)
    [M:ZPAPR1]STKDEM2(F)   = TANC(6)
    [M:ZPAPR1]STKSAL(F)    = [M:ZPAPR1]STKDEM(F)+[M:ZPAPR1]STKDEM1(F)+[M:ZPAPR1]STKDEM2(F)
    [M:ZPAPR1]STK(F)       = [M:ZPAPR1]STKENT(F)-[M:ZPAPR1]STKSAL(F)
    [M:ZPAPR1]NBLIG+=1
  Endif
  HAYFIL_ART+=1
  # Acumular para TOT_ART
  For X=0 To dim(TANC)-1
    TART(X)+=TANC(X)
  Next
  # Borrar
  Raz TANC
Endif
Return

Subprog MOSTRAR_COLOR
If [M:ZPAPR0]MOSTRAR>1
  End
Endif
Local Integer F
For F=0 To [M:ZPAPR1]NBLIG-1
  #toupper(left$([M:ZPAPR1]ITMREF(F),5))
  #"Total Ancho "
  If [M:ZPAPR1]ITMREF(F)=""

  Elsif instr(1,[M:ZPAPR1]ITMREF(F),"Ancho")>0
    Chgstl [M:ZPAPR1]NBLIG(F) With "GRAS"
  Elsif instr(1,[M:ZPAPR1]ITMREF(F),"Artículo")>0
    Chgstl [M:ZPAPR1]NBLIG(F) With "GDD3G"
  Elsif instr(1,[M:ZPAPR1]ITMREF(F),"FINAL")>0
    Chgstl [M:ZPAPR1]NBLIG(F) With "GRAS"
  Else
    If [M:ZPAPR1]STK(F)<0
      Chgstl [M:ZPAPR1]NBLIG(F) With "BACKRED"
    Elsif [M:ZPAPR1]STK(F)=0
      Chgstl [M:ZPAPR1]NBLIG(F) With "BACKYELLOW"
    Endif
  Endif
Next
End


Subprog COMPROBACIONES(FLG_OK)
Variable Integer FLG_OK
Local Char MSG(255)
If [M:ZPAPR0]FFCY=""
  MSG="Debe indicar una planta"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  FLG_OK=0
Endif
If [M:ZPAPR0]FECINI=[0/0/0] or [M:ZPAPR0]FECFIN=[0/0/0]
  MSG="Debe indicar una fecha desde/hasta\Para estadisticas ventas"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  FLG_OK=0
Endif
If [M:ZPAPR0]FLDCHR(1)=""
  MSG="No se ha definido el parámetro para diferenciar los pedidos de <<RESERVA>>\Se asumirá que no existen tales pedidos"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
Endif
End

Subprog FILTROS_ABC
Local Char BD_TIPO(1)
BD_TIPO=[M:ZPAPR0]FLDCHR(0)
#
Local Integer F
Local Char TXT(255)(12)
Raz TXT
TXT(0)="select distinct A2_0 "
TXT(1)="from ATABDIV "
TXT(2)="where NUMTAB_0=6004 "
TXT(3)="order by A2_0 "
For (Char FLABC(5)) From BD_TIPO Sql TXT As [MYT]
 F=[M:ZPAPR0]NABC
 [M:ZPAPR0]CODABC(F)=FLABC
 [M:ZPAPR0]SEL(F)   =2
 [M:ZPAPR0]NABC+=1
Next
Affzo [M:ZPAPR0]25
End

Funprog ABC_TODOS
Local Integer F,V
V=1
For F=0 To [M:ZPAPR0]NABC-1
  If [M:ZPAPR0]SEL(F)<>2
    V=0
    Break
  Endif
Next
End V

Funprog ABC_OK(ABC_COD)
Value Char ABC_COD
Local Integer F,OK
Raz OK
For F=0 To [M:ZPAPR0]NABC-1
  If [M:ZPAPR0]SEL(F)=2 and [M:ZPAPR0]CODABC(F)=ABC_COD
    OK=1
    Break
  Endif
Next
End OK

Funprog VTAMES (PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Venta media de los últimos 12 meses, SIN CONTAR el actual
# De todos lo clientes
Local Date FINI,FFIN
Local Decimal VTAS
FFIN = eomonth(addmonth(date$,-1))
FINI = func ZCOMUN.CHAR_TO_DATE("01/" + format$("D:MM[/]YYYY",addmonth([M:ZPAPR0]FECFIN,-11)))
VTAS = func VTA_COMUN (PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO,FINI,FFIN,1,0)
End VTAS

Funprog VTA_COMUN (PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO,FINI,FFIN,TIPO,CTES)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND,TIPO,CTES
Value Date FINI,FFIN
Local Char TXT(255)(12),W(255),C(255),D(30)
Local Decimal VTAS
Local Integer F,M,FLAG_ERR
# Nş de meses
M=func ZCOMUN.REDONDEAR((FFIN-FINI)/30, 0)
Raz VTAS
W =func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
Case [M:ZPAPR0]FECORI
When 1  # Pedidos
  W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "c.STOFCY_0='", 1, F)
  W+="and c.ORDDAT_0>='" + format$("D:YYYYMMDD",FINI) + "' "
  W+="and c.ORDDAT_0<='" + format$("D:YYYYMMDD",FFIN) + "' "
When 2  # Entregas        BPCINV
  W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "c.SALFCY_0='", 1, F)
  W+="and c.DLVDAT_0>='" + format$("D:YYYYMMDD",FINI) + "' "
  W+="and c.DLVDAT_0<='" + format$("D:YYYYMMDD",FFIN) + "' "
When 3  # Facturas        BPR
  W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "c.FCY_0='", 1, F)
  W+="and c.ACCDAT_0>='" + format$("D:YYYYMMDD",FINI) + "' "
  W+="and c.ACCDAT_0<='" + format$("D:YYYYMMDD",FFIN) + "' "
Endcase
If CTES=1 and [M:ZPAPR0]NCTES>0
  # Busco clientes por IN (...)
  Raz C
  For F=0 To [M:ZPAPR0]NCTES-1
    D="'"+[M:ZPAPR0]BPCINV(F)+"'"
    If len(C+D)+1+21>255   #  1 es la coma   ##   21 son los caracteres necesarios para sql  <<and c.... in (...)>>
      Infbox "Demaseados clientes\Deberá borrar a partir del " + [M:ZPAPR0]BPCINV(F)
      Raz C
    Else
      If C<>""
        C+=","
      Endif
      C+=D
      Endif
  Next
  If C<>""
    Case [M:ZPAPR0]FECORI
    When 1,2  # Pedidos ó Entregas
      TXT(4)="and c.BPCINV_0 in ("+C+") "
    When 3    # Facturas
      TXT(4)="and c.BPR_0 in ("+C+") "
    Endcase
  Endif
Endif
Case TIPO
When 1  # Ventas
  Case PUND
  When 1  # Kgs
    TXT(1)="select isnull(sum(QTYSTU_0 ),0) "
  When 2  # M2
    TXT(1)="select isnull(sum((ZANCHO_0*ZLONGITUD_0/1000)*ZQTYBOB_0),0) "
  When 3  # Bobinas
    TXT(1)="select isnull(sum(ZQTYBOB_0),0) "
  Endcase
When 2 # Nş clientes
  Case [M:ZPAPR0]FECORI
  When 1,2  # Pedidos ó Entregas
    TXT(1)="select distinct c.BPCINV_0 "
  When 3    # Facturas
    TXT(1)="select distinct c.BPR_0 "
  Endcase
  TXT(0)="with CONSULTA (Ctes) as ( "
  TXT(5)=") "
  TXT(6)="select count(Ctes) from CONSULTA"
Endcase
TXT(2)= func VTAMES_FROM
TXT(3)="where " + W
#Local Integer YN
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  End VTAS
#Endif
FLAG_ERR=0
Onerrgo ERRORES_SQL
For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
  If FLAG_ERR=1
    Call ERREURT(TXT, 1) From GESECRAN   #0-Informativo, 1-Error
    Break
  Endif
  Case TIPO
  When 1  # Ventas
    VTAS=func ZCOMUN.REDONDEAR(FLQTY/M,0)
  When 2  # Nş clientes
    VTAS=FLQTY
  Endcase
Next
Onerrgo
End VTAS

Funprog VTAMES_FROM
Local Char W(255)
Case [M:ZPAPR0]FECORI
When 1  # Pedidos
  W="from SORDER c    inner join SORDERQ l     on c.SOHNUM_0=l.SOHNUM_0 "
When 2  # Entregas
  W="from SDELIVERY c inner join SDELIVERYD l  on c.SDHNUM_0=l.SDHNUM_0 "
When 3  # Facturas
  W="from SINVOICE c  inner join SINVOICED l   on c.NUM_0=l.NUM_0 "
Endcase
End W

Funprog STKDEM2(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Stock fisico
Local Integer BOB
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Raz TXT,W,QTY
# Sacar el stock minimo, INDEPENDIENTEMENTE del mandril
# << EN BOBINAS >>
W ="where NUMTAB_0=6004 "
W+="and A1_0='"+PITM+"' "
W+="and N1_0="+num$(PANCHO)+" "
W+="and N2_0="+num$(PLARGO)+" "
TXT(0)="select N3_0 "
TXT(1)="from ATABDIV "
TXT(2)=W
For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
  BOB=FLQTY
Next
Case PUND
When 1  # Kgs      KGS = FACTOR * M2
  QTY=BOB*( [F:ITM]ZFACTOR * (PANCHO*PLARGO/1000) )   # Hacemos un Read en ruptura de control
When 2  # M2       M2  = KGS / FACTOR
    QTY=BOB * (PANCHO*PLARGO/1000)
When 3  # Bobinas
  QTY=BOB
Endcase
End QTY

Funprog STKFIS(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Stock fisico
Local Integer FLAG_ERR
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Raz TXT,W,QTY
W=func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
Case PUND
When 1  # Kgs      KGS = FACTOR * M2
  TXT(0)="select isnull(sum(QTYSTU_0),0) "
When 2  # M2       M2  = KGS / FACTOR
  TXT(0)="select isnull(sum(ZANCHO_0*ZLONGITUD_0/1000),0) "
When 3  # Bobinas
  TXT(0)="select isnull(count(ITMREF_0),0) "
Endcase
TXT(1)="from STOCK "
TXT(2)="where " + W
#Onerrgo ERRORES_SQL
For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
  If FLAG_ERR=1
    Call ERREURT(TXT, 1) From GESECRAN   #0-Informativo, 1-Error
    Break
  Endif
  QTY=FLQTY
Next
#Onerrgo
End QTY

Funprog STKRES(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Stock Reservado, TODO
#  FACTOR = KGS / M2   ##    M2 = KGS / FACTOR    #     KGS = FACTOR * M2
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Raz TXT,W,QTY
W=func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
W+="and CUMALLQTY_0 > 0 "
Case PUND
When 1  # Kgs      KGS = FACTOR * M2
  TXT(0)="select isnull(sum(CUMALLQTY_0),0) "
When 2  # M2       M2  = KGS / FACTOR
  TXT(0)="select isnull(sum(CUMALLQTY_0/ZFACTOR_0),0) "
When 3  # Bobinas
  TXT(0)="select isnull(count(ITMREF_0),0) "
Endcase
TXT(1)="from STOCK "
TXT(3)="where " + W
For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
  QTY=FLQTY
Next
End QTY

Funprog STKDEM(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO,PEDRES,CONRES)
Value Char PFCY,PITM,BD_TIPO,PEDRES
Value Integer PANCHO,PLARGO,PMANDRIL,PUND,CONRES
# Pedidos pendientes de servir
#  FACTOR = KGS / M2   ##    M2 = KGS / FACTOR    #     KGS = FACTOR * M2
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Local Integer F
Raz TXT,W,QTY
If not (CONRES=3 and PEDRES="")
  W =func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
  W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "SOH.STOFCY_0='", 1, F)
  W+="and SOH.ORDSTA_0<>2 and SOQ.INVFLG_0<>2 and SOQ.DEMSTA_0=1 and SOQ.SOQSTA_0<>3 "
  If [M:ZPAPR0]FSERV<>[0/0/0]
  W+="and SOH.DEMDLVDAT_0<='" + format$("D:YYYYMMDD",[M:ZPAPR0]FSERV) + "' "  # La misma fecha que en Propuesta OF
  Endif
  F=CONRES
  If CONRES=2 and PEDRES=""
    F=1
  Endif
  Case F
  When 1 # Todo
  When 2 # Todo SIN -- RES
    W+="and SOH.SOHTYP_0<>'"+PEDRES+"' "
  When 3 # Solo RES
    W+="and SOH.SOHTYP_0= '"+PEDRES+"' "
  Endcase
  Case PUND
  When 1  # Kgs      KGS = FACTOR * M2
    TXT(0)="select isnull(sum(QTYSTU_0-DLVQTYSTU_0),0) "
  When 2  # M2       M2  = KGS / FACTOR
    TXT(0)="select isnull(sum( (QTYSTU_0-DLVQTYSTU_0) / (QTYSTU_0/((ZANCHO_0*ZLONGITUD_0/1000)*ZQTYBOB_0)) ),0) "
  When 3  # Bobinas
    TXT(0)="select isnull(sum(round((QTYSTU_0-DLVQTYSTU_0)/( QTYSTU_0/ZQTYBOB_0),0)),0) "  # En SORDERQ no tenemos una columna para bobinas asignadas. Tenemos ZQTYBOB + ZDLVQTYBOB
  Endcase
  TXT(1)="from SORDER SOH inner join SORDERQ SOQ  on SOH.SOHNUM_0=SOQ.SOHNUM_0 "
  TXT(3)="where " + W
  #  Local Integer YN
  #  Local Char FICSRV(250)
  #  Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
  #  Call OUINON(FICSRV, YN) From GESECRAN
  #  If YN=1
  #    End qty
  #  Endif
  For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
    QTY=FLQTY
  Next
Endif
End QTY

Funprog STKRES_PED_RES(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO,PEDRES)
Value Char PFCY,PITM,BD_TIPO,PEDRES
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Stock Reservado, solo pedidos marcados como RES
#  FACTOR = KGS / M2   ##    M2 = KGS / FACTOR    #     KGS = FACTOR * M2
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Local Integer F
Raz TXT,W,QTY
If PEDRES<>""
  W =func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
  W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "SOH.STOFCY_0='", 1, F)
  W+="and SOH.SOHTYP_0='"+PEDRES+"' "
  W+="and SOH.ORDSTA_0<>2 and SOQ.INVFLG_0<>2 and SOQ.DEMSTA_0=1 and SOQ.SOQSTA_0<>3 "
  Case PUND
  When 1  # Kgs      KGS = FACTOR * M2
    TXT(0)="select isnull(sum(ALLQTYSTU_0),0) "
  When 2  # M2       M2  = KGS / FACTOR
    TXT(0)="select isnull(sum(ALLQTYSTU_0/(QTYSTU_0/((ZANCHO_0*ZLONGITUD_0/1000)*ZQTYBOB_0))),0) "
  When 3  # Bobinas
    TXT(0)="select isnull(sum(round(ALLQTYSTU_0/( QTYSTU_0/ZQTYBOB_0),0)),0) "  # En SORDERQ no tenemos una columna para bobinas asignadas. Tenemos ZQTYBOB + ZDLVQTYBOB
  Endcase
  TXT(1)="from SORDER SOH inner join SORDERQ SOQ  on SOH.SOHNUM_0=SOQ.SOHNUM_0 "
  TXT(3)="where " + W
#  Local Integer YN
#  Local Char FICSRV(250)
#  Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#  Call OUINON(FICSRV, YN) From GESECRAN
#  If YN=1
#    End qty
#  Endif
  For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
    QTY=FLQTY
  Next
Endif
End QTY

Funprog STKPDT(PFCY,PITM,PANCHO,PLARGO,PMANDRIL,PUND,BD_TIPO)
Value Char PFCY,PITM,BD_TIPO
Value Integer PANCHO,PLARGO,PMANDRIL,PUND
# Pedidos a proveedor, pendientes de recibir
Local Decimal QTY
Local Char TXT(255)(12),W(255)
Local Integer F
Raz TXT,W,QTY
W=func SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
W=func ZCOMUN.REPLACE(W, "STOFCY_0='", "POH.POHFCY_0='", 1, F)
W+="and POH.CLEFLG_0<>2 "    # Cab.pedido no saldado
W+="and POQ.RCPCLEFLG_0<>2 " # Lin.pedido no saldada por recepcion
W+="and POQ.LINCLEFLG_0<>2"  # Lin.pedido no saldada
If [M:ZPAPR0]FSERV<>[0/0/0]
W+="and POQ.EXTRCPDAT_0<='" + format$("D:YYYYMMDD",[M:ZPAPR0]FSERV) + "' "  # De momento no cogemos la fecha del contenedor
Endif
Case PUND
When 1  # Kgs      KGS = FACTOR * M2
  TXT(0)="select isnull(sum(QTYSTU_0-RCPQTYSTU_0),0) "
When 2  # M2       M2  = KGS / FACTOR
  TXT(0)="select isnull(sum( (ZQTYBOB_0-ZRCPQTYBOB_0)*(ZANCHO_0*ZLONGITUD_0/1000) ),0) "   # Bobinas pdtes * M2 bobina
When 3  # Bobinas
  TXT(0)="select isnull(sum(ZQTYBOB_0-ZRCPQTYBOB_0),0) "
Endcase
  TXT(1)="from PORDER POH inner join PORDERQ POQ  on POH.POHNUM_0=POQ.POHNUM_0 "
TXT(3)="where " + W
#Local Integer YN
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  End QTY
#Endif
For (Decimal FLQTY) From BD_TIPO Sql TXT As [MYT]
  QTY=FLQTY
Next
End QTY


Funprog SQLWHERE(PFCY,PITM,PANCHO,PLARGO,PMANDRIL)
Value Char PFCY,PITM
Value Integer PANCHO,PLARGO,PMANDRIL
Local Char W(255)
Raz W
W ="STOFCY_0='"+ PFCY +"' "
W+="and ITMREF_0='" + PITM+"' "
W+="and ZANCHO_0=" + num$(PANCHO)+" "
W+="and ZLONGITUD_0=" + num$(PLARGO)+" "
W+="and ZMANDRIL_0=" + num$(PMANDRIL)+" "
End W

Subprog TITULOS_REJILLA
# Monto los 12 titulos posibles
Local Char T(15)(12)
Local Integer F,M,Y
M=month([M:ZPAPR0]FECINI)
Y=year ([M:ZPAPR0]FECINI)
Raz T
For F=0 To 11
  T(F)=left$(month$(M),3)+"/"+right$(num$(Y),3)
  [M:ZPAPR0]FLDDAT(F)=func ZCOMUN.CHAR_TO_DATE("01/"+num$(M)+"/"+num$(Y))
  M+=1
  If M=13
    M=1
    Y+=1
  Endif
  If [M:ZPAPR0]FLDDAT(F)>[M:ZPAPR0]FECFIN
    Raz T(F),[M:ZPAPR0]FLDDAT(F)
  Endif
Next
# Asigno los titulos a las columnas
Titcol [M:ZPAPR1]NBLIG T(0)  For MESVTA_1
Titcol [M:ZPAPR1]NBLIG T(1)  For MESVTA_2
Titcol [M:ZPAPR1]NBLIG T(2)  For MESVTA_3
Titcol [M:ZPAPR1]NBLIG T(3)  For MESVTA_4
Titcol [M:ZPAPR1]NBLIG T(4)  For MESVTA_5
Titcol [M:ZPAPR1]NBLIG T(5)  For MESVTA_6
Titcol [M:ZPAPR1]NBLIG T(6)  For MESVTA_7
Titcol [M:ZPAPR1]NBLIG T(7)  For MESVTA_8
Titcol [M:ZPAPR1]NBLIG T(8)  For MESVTA_9
Titcol [M:ZPAPR1]NBLIG T(9)  For MESVTA_10
Titcol [M:ZPAPR1]NBLIG T(10) For MESVTA_11
Titcol [M:ZPAPR1]NBLIG T(11) For MESVTA_12
#
#Titcol [M:ZPAPR1]NBLIG "Avg "+num$(year(date$)-1) For VTAMED
End


Subprog MONTAR_SQL(TXT)
Variable Char TXT
Local Char W(255)(2)
Raz TXT,W
# Común
W(0)="ITMREF_0, ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0 "
W(1)  ="where STOFCY_0='"+ [M:ZPAPR0]FFCY +"' "
If [M:ZPAPR0]FITM<>""
  W(1)+="and ITMREF_0='"+[M:ZPAPR0]FITM+"' "
Endif
If [M:ZPAPR0]FZANCHO>0
  W(1)+="and ZANCHO_0="+num$([M:ZPAPR0]FZANCHO)+" "
Endif
If [M:ZPAPR0]FZMANDRIL>0
  W(1)+="and ZMANDRIL_0="+num$([M:ZPAPR0]FZMANDRIL)+" "
Endif
If [M:ZPAPR0]FLONINI>0
  W(1)+="and ZLONGITUD_0>=" + num$([M:ZPAPR0]FLONINI) + " "
Endif
If [M:ZPAPR0]FLONFIN>0
  W(1)+="and ZLONGITUD_0<=" + num$([M:ZPAPR0]FLONFIN) + " "
Endif

TXT(0)="With CONSULTA (ITMREF, ANCHO, LARGO, MANDRIL) As ( "
TXT(1)="select "+W(0)
TXT(2)="from STOCK "
TXT(3)=W(1)
TXT(4)="union all "
TXT(5)="select distinct "+W(0)
TXT(6)="from SORDERQ "
TXT(7)=W(1)
TXT(8)=") "
TXT(9)="select distinct ITMREF, ANCHO, LARGO, MANDRIL "
TXT(10)="from CONSULTA "
TXT(11)="Order By ITMREF, ANCHO, LARGO, MANDRIL"
End


Subprog VACIAR_REJILLA
Raz   [M:ZPAPR1]NBLIG
Effzo [M:ZPAPR1]5
End

$ERRORES
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
FLAG_ERR=1
Resume

$ERRORES_SQL
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
FLAG_ERR=1
Resume


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End
