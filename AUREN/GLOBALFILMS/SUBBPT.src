#<AdxTL>@(#)1.0.0.0 $Revision$
Call OBJET("BPT",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
# GESTION DES TRANSPORTEURS
#
# SUBBPT                                 eb novembre 97
#########################################################################
$ACTION
Case ACTION
 When "OUVRE"            : Gosub OUVRE
 When "FERME"            : Gosub FERME
 When "LIENS"            : Gosub LIENS
 When "AFFMASK"          : Gosub AFFMASK
 When "SETBOUT"          : Gosub SETBOUT
 When "DEFLIG"           : Gosub DEFLIG
 When "RAZCRE"           : Gosub RAZCRE
 When "RAZDUP"           : Gosub RAZDUP
 When "INICRE"           : Gosub INIBPT
 When "INICRE_LIG"       : Gosub INICRELIG
 When "VERIF_CRE"        : Gosub VERIF_CREMOD : # cg le 30/01/98
 When "CREATION"         : Gosub CREATION
 When "INIMOD"           : Gosub INIBPT
 When "AVANT_MOD"        : Gosub AVANTMOD
 When "AVANT_MODFIC"     : Gosub AVANT_MODFIC
 When "FIN_MOD"          : Gosub FINMODIF
 When "ABANDON"          : Gosub FINMODIF
 When "VERIF_MOD"        : Gosub VERIF_CREMOD : # cg le 30/01/98
 When "MODIF"            : Gosub MODIF
 When "ANNULE"           : Gosub ANNULE
 #When "DEVERROU"         : Gosub FINMODIF     : # cg le 14/09/98 # FGR 05/07/2011 : X3SUIVI7545 ligne a mettre en commentaire
 When "DEVERROU"         : Gosub DEVERROU     : # FGR 15/10/2009 : X3SUIVI58119
 When "VERROU"           : Gosub VERROU       : # cg le 14/09/98
 When "APRES_MODIF"      : Gosub APRES_MODIF  : # jl le 11/10/99
 When "APRES_CRE"        : Gosub APRES_CRE    : # jl le 28/12/99
 When "APRES_MOD"        : Gosub APRES_MOD    : # jl le 28/12/99
 When "AP_ANNULE"        : Gosub AP_ANNULE    : #Modif CRM 31 juillet 2000
# ---
 When "SEL_LISTE"        : Gosub SEL_LISTE
Endcase
Return

###########################################################################
#    CHOIX DANS LES LISTES                                                #
###########################################################################
$SEL_LISTE
Case LISTE
    When "SELLARE"       : Gosub SL_ARE
Endcase
Return

####################################################################
$GRIZE_LIENS
#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#

If [M:BPT1]VOU=""     Grizo [M:BPT1]COEWEIVOL  Else  Actzo [M:BPT1]COEWEIVOL  Endif
#MAE, le 04/10/10, bg 66379, on ne grise pas l'onglet Région
#If [M:BPT1]PLIFLG=1 : Diszo [M:BPT2]           Else  Actzo [M:BPT2]           Endif
Return

#########################################################################
$OUVRE

# 85683
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
# 85683

Global Integer GIBPTEXIST
GIBPTEXIST = 0

Local Char    SYMBOLE2(20) : # cg le 28/01/98
Local Integer DIMBPYTAB    : # nb de régions table
Local Integer DIMBPYSCR    : # nb de régions ecran (pour stockage)
Local Integer DIMBPWTAB    : # nb de fourchettes table
Local Integer DIMBPWSCR    : # nb de fourchettes ecran

Local Integer WBPATYP : WBPATYP = 1
#----    positionnement sur 3eme masque si appel des tiers
If   clalev ([M:BPR0])
     PRMASK    = 3
Endif

#----    déclaration des variables
Gosub DECLARE From TABLEAUX

#---- alimentation des variables globales liées au site
Call GLOBVAR (GFCYDEF(9)) From WWGLOBACH
Call GLOBVAR (GFCYDEF(9)) From WWGLOBVEN

#---- stockage valeur des codes activités
# Raz I
# If clalev ([F:ACV])=0 : Local File ACTIV [ACV] : I=1 : Endif
