Gosub CRECNT
If GOK<1 : Return : Endif
#----    création enregistrement rib
Gosub CRERIB
If GOK<1 : Return : Endif
#----    modification des lignes : définition des régions
Gosub MODIF From TABLEAUX    : # Enregistrement des lignes
If GOK<1 : Return : Endif
#----    création enregistrements tarifs transporteurs
Gosub CRETAR
If GOK<1 : Return : Endif

