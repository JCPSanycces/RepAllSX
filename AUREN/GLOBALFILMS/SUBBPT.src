###################################################################
$LIENS
GIBPTEXIST = 0

#----    alimentation masque tiers
Read [BPR]BPR0 = [M:BPT0]BPTNUM
If   fstat = 0
     [M:BPRT] = [F:BPR]
     [M:BPT0]BPTNAM = [F:BPR]BPRNAM
     [M:BPRT]CUR    = [F:BPT]CUR   : # Récupération devise transporteur
Else
     Raz [M:BPRT]
Endif

#---- devise dans les onglet
[M:BPT1]X1CUR=[M:BPRT]CUR
[M:BPT1]X2CUR=[M:BPRT]CUR
[M:BPT1]X3CUR=[M:BPRT]CUR
[M:BPT3]X4CUR=[M:BPRT]CUR

#---- unité de poids
[M:BPT1]X1UOM=[M:BPT1]WEU

#---- maj tableau des bornes début fourchettes
For I=0 To dim([M:BPT1]PLIMAX)-1
  If I=0                       [M:BPT1]PLIMIN(I)=0
    Elsif  [M:BPT1]PLIMAX(I)=0 [M:BPT1]PLIMIN(I)=0
    Else                       [M:BPT1]PLIMIN(I)=[M:BPT1]PLIMAX(I-1)
  Endif
Next I

Default Mask [BPAT]
Call CHARG_BPA(WBPATYP,[M:BPT0]BPTNUM,[F:BPT]BPAADD) From TRTBPA
Default Mask [BIDT]
Call CHARG_RIB(WBPATYP,[M:BPT0]BPTNUM,"~") From TRTBPA
Default Mask [CNTT]
Call CHARG_CNT(WBPATYP,[M:BPT0]BPTNUM,[F:BPT]CNTNAM) From TRTBPA
Gosub DEFAUT

#----    lecture des lignes : définition des régions
Gosub LIENS From TABLEAUX : # Chargement des lignes

#----    lecture des tarifs
Gosub CHARG_TAR



#----    chargement des tarifs de la 1ere region du tableau
If dim([M:BPT3]NBARE)>0
   status=1 : nolign=1 : Call AV_NBARE : Call AS_NBARE
Endif

#LSE 02/03/2007
##---------------------------------------------------#
##Modif CRM 6/02/2002
#If GMODU(13) = 2
#    Call SETPREREP("BPT") From TRTMST4
#Endif
##---------------------------------------------------#

#Initialisation CRM
Gosub LIENS_CRM From TRTBPCRM

Gosub GRIZE_LIENS

#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPT0]BPTNUM <> ""
    Read [BPRW]BPR0 = [M:BPT0]BPTNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif



Return

####################################################################
$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From="WGO"+GABREV
 Endif
Next MA
Return

####################################################################
#-------------------------------------------------------
$CHARG_TAR
Local Integer RGARE            : # rang de la region dans tableau
Local Char    PE_CARPRIFLD (6) : # origine appel du point entree
Raz [M:BPT3]
#     si pas gestion tarifs transporteurs (codes activités BPW=0 ou BPY=0)
If dim([M:BPT3]NBARE)<=0 | dim([M:BPT1]NBPLI)<=0 : Return : Endif
#----    Zones affichées de ecran des tarifs
[M:BPT3]X4CUR=[M:BPRT]CUR
[M:BPT3]X1WEU=[M:BPT1]WEU
For I=0 To [M:BPT1]NBPLI-1
  [M:BPT3]TARMIN(I)=[M:BPT1]PLIMIN(I)
  [M:BPT3]TARMAX(I)=[M:BPT1]PLIMAX(I)
  [M:BPT3]TARBKT(I)=[M:BPT1]PLIBKT(I)
Next I
[M:BPT3]NBTAR=[M:BPT1]NBPLI
#----    Zones invisibles (tarifs par régions)
For [CAP] CAP0 Where BPTNUM=[M:BPT0]BPTNUM
  RGARE = find ([F:CAP]BPTARE,[M:BPT3]BPTAREP)
  If !RGARE
    # FGR 17/03/2010 : X3SUIVI63335 (début)
    If [M:BPT3]NBARE+1 >= dim([M:BPT3]BPTAREP) Then
      # Le tableau est plein on arręte de le remplir
      GMESSAGE = mess(979,196,1)
      GERR = 2
      Break
    Endif
    # FGR 17/03/2010 : X3SUIVI63335 (fin)
    [M:BPT3]NBARE +=1
    RGARE=[M:BPT3]NBARE
    [M:BPT3]BPTAREP([M:BPT3]NBARE-1)=[F:CAP]BPTARE
  Endif
  If evalue ("dim([M:BPT3]PRI"+num$([F:CAP]RANG)+")")>0
    Assign "[M:BPT3]PRI"+num$([F:CAP]RANG)+"("+num$(RGARE-1)+")" With [F:CAP]PRI
  Endif
  If evalue ("dim([M:BPT3]ADL"+num$([F:CAP]RANG)+")")>0
    Assign "[M:BPT3]ADL"+num$([F:CAP]RANG)+"("+num$(RGARE-1)+")" With [F:CAP]ADL
  Endif
  PE_CARPRIFLD="LECTAR"
  GPOINT="CARPRIFLD" : Gosub ENTREE From EXEFNC
Next
Return

########################################################
$RAZCRE

Grizo [M:BPRT]BETFCY, FCY
#----    init. type entité en création pour le subbpa
[F:BPA]BPATYP = WBPATYP
#
If [M:BPRT]CRY = ""
    [M:BPRT]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
    Endif
    [M:BPRT]LAN = [F:TCY]LAN
    [M:BPRT]CUR = [F:TCY]CUR
Endif
#
[M:BPT1]X1CUR=[M:BPRT]CUR
[M:BPT1]X2CUR=[M:BPRT]CUR
[M:BPT1]X3CUR=[M:BPRT]CUR
[M:BPT3]X4CUR=[M:BPRT]CUR
#[M:BPT2]CRY  =GPAYS
#Affzo [M:BPRT]CRY, LAN, CUR
#Affzo [M:BPT1]X1CUR, X2CUR, X3CUR
#Affzo [M:BPT2]CRY
#Affzo [M:BPT3]X4CUR

#CRM
Gosub RAZCRE_CRM From TRTBPCRM

Gosub GRIZE_LIENS

#LSE 06/02/2007
Affzo [M:BPT0]1-99
Affzo [M:BPRT]1-99
Affzo [M:BPAT]1-99
Affzo [M:BPT1]1-99
Affzo [M:BPT2]1-99
Affzo [M:BPT3]1-99
Affzo [M:BIDT]1-99
Affzo [M:CNTT]1-99


Return

########################################################
$RAZDUP

Grizo [M:BPRT]BETFCY, FCY
#---------------------------------------------------#
#Modif CRM 6/12/2002
#---------------------------------------------------#
If !GIBPTEXIST
    #Voulez-vous partager les interlocuteurs de la société XXXX ?
    Local Integer IASKBPR
    Local Char SZMESS(250)
    IASKBPR = 0
    If [M:CNTT]NBCNT > 0
        SZMESS = mess(834, 196, 2) + ' ' + [M:BPT0]BPTNUM
        Call OUINON(SZMESS, IASKBPR) From GESECRAN
        If IASKBPR <> 2
            Raz [M:CNTT]
            Raz [M:CNTT]NBCNT
            Affzo [M:CNTT]1-99
        Endif
    Endif
Endif

#En duplication TIERS : On ne duplique pas les informations RIB ! #JPGA:12/06/2006 - BUG140:38475
# Raz + Affzo + Non validation du Mask
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
Look [BPR] BPR0=CZ
If fstat>0
    # Si le client n'existe pas, on efface les RIB (qui ne doivent pas venir du client dupliqué) # ACA 44754
    Effzo [M:BIDT]
Endif

#---------------------------#
# init. flags du tiers      #
#---------------------------#
If CLECUR
    If zc <> [M:BPT0]BPTNUM
        Look  [BPR]BPR0 = num$(zc)
        If fstat
           #-- on remet les indicateurs a zero
           [M:BPRT]BPSFLG    = 1
           [M:BPRT]BPCFLG    = 1
           [M:BPRT]REPFLG    = 1
           [M:BPRT]FCTFLG    = 1
        #-- pas celui de tiers divers
        #  [M:BPRT]BPRACC    = 1
           [M:BPRT]BPTFLG    = 2
        Endif
    Endif
Endif

#CRM
Gosub RAZDUP_CRM From TRTBPCRM

Gosub GRIZE_LIENS

Return

########################################################
$INIBPT

#----    récup rubriques dans BPT
[F:BPT]BPTNAM = [M:BPRT]BPRNAM
[F:BPT]BPTSHO = [M:BPRT]BPRSHO

# Alimentation du code adresse par défaut et du contact par défaut
Local Shortint WI
WI = find (2,[M:BPAT]BPAADDFLG (0..[M:BPAT]NBADR -1))
If WI<>0 [F:BPT]BPAADD = [M:BPAT]CODADR (WI-1) Endif

#LSE 17/07/2006 FQ 36999
#WI = find (2,[M:CNTT]CNTFLG (0..[M:CNTT]NBCNT -1))
#If WI<>0 [F:BPT]CNTNAM = [M:CNTT]CCNCRM (WI-1) Else [F:BPT]CNTNAM="" Endif
If [M:CNTT]NBCNT >0
    WI = find (2,[M:CNTT]CNTFLG (0..[M:CNTT]NBCNT -1))
    If WI <> 0
        [F:BPT]CNTNAM = [M:CNTT]CCNCRM (WI-1)
    Else
        [F:BPT]CNTNAM  =[M:CNTT]CCNCRM (0)
    Endif
Else
    [F:BPT]CNTNAM  =""
Endif


Return

########################################################
$INICRELIG
[F:CAA]BPTNUM = [M:BPT0]BPTNUM
Return

########################################################
$CREATION
#----    création enregistrement tiers
Gosub CREBPR
If GOK<1 : Return : Endif
#----    création enregistrement adresse
Gosub CREBPA
If GOK<1 : Return : Endif
#----    création enregistrement contact
Gosub CRECNT
If GOK<1 : Return : Endif
#----    création enregistrement rib
Gosub CRERIB
If GOK<1 : Return : Endif
#----    enregistrement des lignes : définition des régions
Gosub CREATION From TABLEAUX : # Ecriture des lignes
If GOK<1 : Return : Endif
#----    création enregistrements tarifs transporteurs
Gosub CRETAR
If GOK<1 : Return : Endif

