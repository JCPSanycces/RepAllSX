##################################################
$ANNULE
#----    lecture bpartner pour depositionner le flag BPTFLG
Update [BPR] Where [F:BPR]BPRNUM = [M:BPT0]BPTNUM With BPTFLG = 1
If    fstat <> 0
      Call ERREUR(mess(4,192,1)) From GESECRAN
      GOK = 0 : Return
Endif
Return

##################################################
$APRES_MODIF
Local Integer OKWEU
#----    si saisie de donnée poids et pas de saisie de unité poids : message
Case COUZON
  When "ADL", "BKT", "PLIMAX", "PLIBKT" : Gosub CONT_WEU
  When Default
Endcase

#----    si modif dans tableau des fourchettes --> maj onglet des tarifs
Case COUZON
  When "PLIMAX", "PLIBKT", "PLIUOMRND" : [M:BPT1]MODIF=1
  When "WEU"                           : Gosub WEU
  When Default
Endcase

#----    positionnement sur champ suivant
#        pour TARPRI dans bloc tableau : en CS  positionnement OK mais reste en mode commande
#                                        en WEB ne se positionne pas sur le champ
Case COUZON
    When "CODADR" SUIZON= "XBPADES"
    When "CCNCRM" SUIZON= "KCNTTTL"
    When "BPTAREP" SUIZON= "TARPRI"
Endcase
Return

$CONT_WEU

If val(CZ)<>0 & [M:BPT1]WEU=""
  OKWEU=2
  Call AVERTIR(mess(169,192,1),OKWEU) From GESECRAN
#              saisir une unité de poids
Endif
Return

$WEU
[M:BPT1]X1UOM=CZ
[M:BPT3]X1WEU=CZ
Affzo [M:BPT1]X1UOM : Affzo [M:BPT3]X1WEU
Return

##################################################
$CREBPR
#----------------------------------------------#
# cg le 30/01/98                               #
# il faut récuperer le code adresse par defaut #
# si on ne trouve pas on recupere la premiere  #
#----------------------------------------------#
#Local Shortint I,J,K
#I = find (2,[M:BPAT]BPAADDFLG (0..[M:BPAT]NBADR -1))
#If I <> 0     I -= 1 : Endif
#If I < 0      I = 0  : Endif
#J = find (2,[M:CNTT]CNTFLG (0..[M:CNTT]NBCNT -1))
Local Shortint K
#K = find (2,[M:BIDT]BIDNUMFLG (0..[M:BIDT]NBRIB -1))

Look [BPR]BPR0 = [F:BPT]BPTNUM
If fstat <> 0
     Raz [F:BPR]
     [F:BPR]          = [M:BPRT]
     [F:BPR]BPRNUM    = [F:BPT]BPTNUM
     [F:BPR]BPAADD    = [F:BPT]BPAADD
     [F:BPR]CNTNAM    = [F:BPT]CNTNAM
#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTT]CCNCRM (J-1)
#     Else          [F:BPR]CNTNAM    = ""
#     endif

     #--- Le RIB par défaut du tiers vient maintenant
     #--- du RIB par défaut de l'adresse par défaut du tiers
     #If K <> 0
     #    [F:BPR]BIDNUM    = [M:BIDT]BIDNUM (K-1)
     #    [F:BPR]BIDCRY    = [M:BIDT]BIDCRY (K-1)
     #Else
     #    [F:BPR]BIDNUM    = ""
     #    [F:BPR]BIDCRY    = ""
     #Endif
     Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
     If !fstat
        [F:BPR]BIDNUM=[F:BPA]BPABID
     Else
        [F:BPR]BIDNUM=""
     Endif

     [F:BPR]BPSFLG    = 1
     [F:BPR]BPCFLG    = 1
     [F:BPR]REPFLG    = 1
     [F:BPR]FCTFLG    = 1
#-- pas celui de tiers divers
#    [F:BPR]BPRACC    = 1
     For I = 0 To 3
         [F:BPR]BPRFLG (I) = 1
     Next I
     [F:BPR]ENAFLG    = 2
     [F:BPR]BPTFLG    = 2
     [F:BPR]CREDAT    = date$
     [F:BPR]CREUSR    = GUSER
     # Issue X3-138149 - 2019-05-02 by MUARN : export chrono
     [F:BPR]EXPNUM    = [C]EXPORT

     Write [BPR]
     If fstat
            GOK = 0 : Call FSTA("BPR") From GLOCK
     Endif
Else
     Readlock [BPR]BPR0 = [F:BPT]BPTNUM
     If    fstat = 1
           GOK = -1 : GLOCK = "$BPARTNER"-[F:BPT]BPTNUM : Return
     Endif
     Local Char WSAV_CUR(GLONCUR)
     [L]WSAV_CUR      = [F:BPR]CUR        : # Sauvegarde devise tiers
     [F:BPR]          = [M:BPRT]
     [F:BPR]BPRNUM    = [F:BPT]BPTNUM
     [F:BPR]CUR       = [L]WSAV_CUR       : # Restitution devise tiers
#     [F:BPR]BPAADD    = [M:BPAT]CODADR (I)
#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTT]CCNCRM (J-1)
#     Else          [F:BPR]CNTNAM    = ""
#     endif

     #--- Le RIB par défaut du tiers vient maintenant
     #--- du RIB par défaut de l'adresse par défaut du tiers
     #If   K <> 0 : [F:BPR]BIDNUM    = [M:BIDT]BIDNUM (K-1)
     #              [F:BPR]BIDCRY    = [M:BIDT]BIDCRY (K-1)
     #Else          [F:BPR]BIDNUM    = ""
     #              [F:BPR]BIDCRY    = ""
     #Endif

    # X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table
    Local Shortint K: K=0
    If [M:CNTT]NBCNT>0
      K = find ([F:BPR]CNTNAM,[M:CNTT]CCNCRM (0..[M:CNTT]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPR]CNTNAM    = [F:BPT]CNTNAM
    Endif
    # We check the default contact in Customers Table
    ###
    If [F:BPR]BPCFLG=2 or [F:BPR]PPTFLG=2
      If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
      Readlock [F:BPC]BPC0=[F:BPT]BPTNUM
      If !fstat
        K=0
        If [M:CNTT]NBCNT>0
          K = find ([F:BPC]CNTNAM,[M:CNTT]CCNCRM (0..[M:CNTT]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPC]CNTNAM    = [F:BPT]CNTNAM
          Rewrite [F:BPC]
          If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
        Endif
      Endif
    Endif
    ###
    # We check the default contact in Suppliers Table
    ###
    If [F:BPR]BPSFLG=2
      If clalev([F:BPS])=0 : Local File BPSUPPLIER[BPS] : Endif
      Readlock [F:BPS]BPS0=[F:BPT]BPTNUM
      If !fstat
        K=0
        If [M:CNTT]NBCNT>0
          K = find ([F:BPS]CNTNAM,[M:CNTT]CCNCRM (0..[M:CNTT]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPS]CNTNAM    = [F:BPT]CNTNAM
          Rewrite [F:BPS]
          If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
        Endif
      Endif
    Endif
    # END X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table

     [F:BPR]BPTFLG    = 2
     [F:BPR]UPDDAT    = date$
     [F:BPR]UPDUSR    = GUSER
     # Issue X3-138149 - 2019-05-02 by MUARN : export chrono
     [F:BPR]EXPNUM    = [C]EXPORT
     Rewrite [BPR]
Endif
Return

########################################
$CREBPA
#Call CREBPA_CPYFCY(GABREV,[M:BPT0]BPTNUM,1) From TRTADR
#If   GOK < 1 : Return :ENDIF

Default Mask [BPAT]
Call CREBPA(WBPATYP,[M:BPT0]BPTNUM) From TRTBPA
If GOK < 1 : Return : Endif
Return

########################################
$CRECNT
#Call CRECNT_CPYFCY(GABREV,[M:BPT0]BPTNUM,1) From TRTADR
#If   GOK < 1 : Return :ENDIF

Default Mask [CNTT]
Call CRECNT(WBPATYP,[M:BPT0]BPTNUM) From TRTBPA
If GOK < 1 : Return : Endif
  Call MAJ_CNTNAM("[F:BPT]") From SUBBPR  # FGR 10/01/2013 X3SUIVI83886
Return

########################################
$CRERIB
#Call CRERIB_CPYFCY([M:BPT0]BPTNUM,1) From TRTADR
#If   GOK < 1 : Return :ENDIF

Default Mask [BIDT]
Call CRERIB(WBPATYP,[M:BPT0]BPTNUM) From TRTBPA
If GOK < 1 : Return : Endif

Return

########################################
$CRETAR
Local Char    PE_CARPRIFLD (6) : # origine appel du point entree
#FJCG - Inicio - AURENV12
If dim([M:BPT3]NBARE)>0 | dim([M:BPT1]NBPLI)>0 : Return : Endif
#FJCG - Fin - AURENV12
#     suppression de toutes les lignes
Delete [CAP] Where BPTNUM=[M:BPT0]BPTNUM
#     si pas gestion tarifs transporteurs (codes activités BPW=0 ou BPY=0)
If dim([M:BPT3]NBARE)<=0 | dim([M:BPT1]NBPLI)<=0 : Return : Endif
#     création des nouvelles lignes
For I=0 To [M:BPT3]NBARE-1
  For J=0 To [M:BPT1]NBPLI-1
    If evalue ("[M:BPT3]PRI"+num$(J+1)+"("+num$(I)+")")<>0 |
&      evalue ("[M:BPT3]ADL"+num$(J+1)+"("+num$(I)+")")<>0
      [F:CAP]BPTNUM = [M:BPT0]BPTNUM
      [F:CAP]BPTARE = [M:BPT3]BPTAREP(I)
      [F:CAP]RANG   = J+1
      [F:CAP]MINQTY = [M:BPT1]PLIMIN(J)
      [F:CAP]MAXQTY = [M:BPT1]PLIMAX(J)
      [F:CAP]BKT    = [M:BPT1]PLIBKT(J)
      [F:CAP]WEIRND = [M:BPT1]PLIUOMRND(J)
      [F:CAP]PRI    = evalue ("[M:BPT3]PRI"+num$(J+1)+"("+num$(I)+")")
      [F:CAP]ADL    = evalue ("[M:BPT3]ADL"+num$(J+1)+"("+num$(I)+")")
      PE_CARPRIFLD="CRETAR"
      GPOINT="CARPRIFLD" : Gosub ENTREE From EXEFNC
      Write [CAP]
    Endif
  Next J
Next I
Return
###################################################################
#########################################################################
#       Actions Champs : BPT0 - Transporteur
#########################################################################
########################################
Subprog AP_BPTNUM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_BPTNUM(VALEUR)
Variable Char    VALEUR()
GIBPTEXIST = 0

#-------------------------------------#
# il faut verrouiller symbole BPR     #
# si pas deja fait dans action verrou #
#-------------------------------------#
Read [BPR]BPR0 = VALEUR
If fstat = 0
    If GREP = "C" | GREP = "D" | GREP = ""
           [M:BPRT] = [F:BPR]
           [M:BPT0]BPTNAM = [F:BPR]BPRNAM
           Affzo [M:BPT0]BPTNAM
           Affzo [M:BPRT]1-99
           Default Mask [BPAT]
           Call CHARG_BPA(1,VALEUR,[F:BPR]BPAADD) From TRTBPA
           Default Mask [BIDT]
           Call CHARG_RIB(1,VALEUR,"~") From TRTBPA
           Default Mask [CNTT]
           Call CHARG_CNT(1,VALEUR,[F:BPR]CNTNAM) From TRTBPA
           Default Mask [BPT0]
           Affzo [M:BPAT]1-99
           Affzo [M:CNTT]1-99
           Affzo [M:BIDT]1-99

           GIBPTEXIST = 1
     Endif
     If GNAVIG(GPILNAV-1) <> "GESBPR" or (GNAVIG(GPILNAV-1) = "GESBPR" and [M:BPR0]BPRNUM <> VALEUR) Then # FGR 16/04/2012 : X3SUIVI81335
       SYMBOLE2 = "BPR"+num$(VALEUR)
       Lock = SYMBOLE2 With lockwait = 0
       If fstat
         If GREP = "C" or GREP = "D"
           GERR=1 : GMESSAGE = mess(10,100,1) : mkstat = 2
         Endif
       Else
         # FGR 16/04/2012 : X3SUIVI81335
         Global Integer GILOCKBPR

         GILOCKBPR = 1
       Endif
    Endif
Endif
End

#########################################################################
#       Actions Champs : BPT1 - Gestion
#########################################################################
########################################
Subprog AM_WEU(VALEUR)
Variable Char    VALEUR()
[M:BPT1]X1UOM=VALEUR
If [M:BPT1]VOU="" : Raz [M:BPT1]COEWEIVOL : Grizo [M:BPT1]COEWEIVOL : Endif
Affzo [M]X1UOM,COEWEIVOL
End
########################################
Subprog AM_VOU(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  Raz [M:BPT1]COEWEIVOL : Grizo [M:BPT1]COEWEIVOL
Else
  Actzo [M:BPT1]COEWEIVOL
  If [M:BPT1]COEWEIVOL=0 : [M:BPT1]COEWEIVOL=1 : Endif
Endif
Affzo [M]COEWEIVOL
End

########################################
Subprog AP_NBPLI
# --- si on sort du tableau
#     on doit réorganiser le tableau (onglet des tarifs)

If status = 65 : [M:BPT1]MODIF=1 : End : Endif  : # si on supprime une ligne

If status > 65 & status <= 90 : End : Endif
If find(status,7,27,28) | status >= 1792 : End : Endif

If [M:BPT1]MODIF=1
  Raz [M:BPT1]MODIF
  Gosub MAJ_FOURCHETTES
Endif
End

#--- Si en sortie du tableau des fourchettes poids il ya des modifs
#    mise ŕ jour du tableau des bornes début de ce tableau
#    mise ŕ jour onglet tarifs (notamment le stockage en zones invisibles)
$MAJ_FOURCHETTES
Variable Integer I, IMAJ, ISUP, IINS, IAFF, TROUVE
Local    Char    ZAVANT, ZAPRES
# mise ŕ jour du tableau des bornes début du tableau fourchettes
For I=0 To dim([M:BPT1]PLIMAX)-1
  If I=0                       [M:BPT1]PLIMIN(I)=0
    Elsif  [M:BPT1]PLIMAX(I)=0 [M:BPT1]PLIMIN(I)=0
    Else                       [M:BPT1]PLIMIN(I)=[M:BPT1]PLIMAX(I-1)
  Endif
Next I

# si dans onglet tarif et pas dans tableau fourchettes on supprime dans tarif
For IMAJ=0 To dim([M:BPT3]TARMAX)-1
$SUITE
  If [M:BPT3]TARMAX(IMAJ)<>0
    Raz TROUVE
    TROUVE = find([M:BPT3]TARMAX(IMAJ),[M:BPT1]PLIMAX(0..dim([M:BPT1]PLIMAX)-1))
    If !TROUVE : ISUP=IMAJ : Gosub SUP_TAR : Goto SUITE : Endif
  Endif
Next IMAJ

# si dans tableau fourchettes et absent onglet tarifs on insčre dans tarifs
For IMAJ=0 To dim([M:BPT1]PLIMAX)-1
  If [M:BPT1]PLIMAX(IMAJ)<>0
    If [M:BPT1]PLIMAX(IMAJ)<>[M:BPT3]TARMAX(IMAJ)
      IINS=IMAJ : Gosub AJOUT_TAR
    Endif
    [M:BPT3]TARMIN(IMAJ)=[M:BPT1]PLIMIN(IMAJ)
    [M:BPT3]TARMAX(IMAJ)=[M:BPT1]PLIMAX(IMAJ)
    [M:BPT3]TARBKT(IMAJ)=[M:BPT1]PLIBKT(IMAJ)
  Endif
Next IMAJ

[M:BPT3]NBTAR=[M:BPT1]NBPLI
Affzo [M:BPT3]15

Return

#--- Suppression une ligne dans tableau tarifs
$SUP_TAR
#     si pas gestion tarifs transporteurs (codes activités BPW=0 ou BPY=0)
If dim([M:BPT3]NBARE)<=0 | dim([M:BPT1]NBPLI)<=0 : Return : Endif
Dela ISUP,1,[M:BPT3]NBTAR-1  [M:BPT3]NBTAR
[M:BPT3]NBTAR -= 1
For I=ISUP To dim([M:BPT3]TARMAX)-1
  For IJ=0 To [M:BPT3]NBARE-1
    ZAVANT="[M:BPT3]PRI"+num$(I+1)+"("+num$(IJ)+")"
    ZAPRES="[M:BPT3]PRI"+num$(I+2)+"("+num$(IJ)+")"
    If evalue ("dim("+ZAVANT+")") > 0
      Assign ZAVANT With 0
    Endif
    If evalue ("dim("+ZAPRES+")") > 0
      Assign ZAVANT With evalue(ZAPRES)
      Assign ZAPRES With 0
    Endif
    ZAVANT="[M:BPT3]ADL"+num$(I+1)+"("+num$(IJ)+")"
    ZAPRES="[M:BPT3]ADL"+num$(I+2)+"("+num$(IJ)+")"
    If evalue ("dim("+ZAVANT+")") > 0
      Assign ZAVANT With 0
    Endif
    If evalue ("dim("+ZAPRES+")") > 0
      Assign ZAVANT With evalue(ZAPRES)
      Assign ZAPRES With 0
    Endif
  Next IJ
Next I
I=dim([M:BPT3]TARMAX)-1
Raz [M:BPT3]TARMIN(I), [M:BPT3]TARMAX(I), [M:BPT3]TARPRI(I), [M:BPT3]TARADL(I)
Return

#--- Ajout une ligne dans tableau des tarifs
$AJOUT_TAR
#     si pas gestion tarifs transporteurs (codes activités BPW=0 ou BPY=0)
If dim([M:BPT3]NBARE)<=0 | dim([M:BPT1]NBPLI)<=0 : Return : Endif
If [M:BPT3]NBTAR<dim([M:BPT3]TARMAX) : # insertion
  Insa IINS,1,[M:BPT3]NBTAR [M:BPT3]NBTAR
  [M:BPT3]NBTAR += 1
  For I=dim([M:BPT3]TARMAX)-1 To IINS Step -1

    For IJ=0 To [M:BPT3]NBARE-1
      ZAVANT="[M:BPT3]PRI"+num$(I+1)+"("+num$(IJ)+")"
      ZAPRES="[M:BPT3]PRI"+num$(I+2)+"("+num$(IJ)+")"
      If evalue ("dim("+ZAPRES+")") > 0
        Assign ZAPRES With 0
      Endif
      If evalue ("dim("+ZAVANT+")") > 0
        Assign ZAPRES With evalue(ZAVANT)
        Assign ZAVANT With 0
      Endif
      ZAVANT="[M:BPT3]ADL"+num$(I+1)+"("+num$(IJ)+")"
      ZAPRES="[M:BPT3]ADL"+num$(I+2)+"("+num$(IJ)+")"
      If evalue ("dim("+ZAPRES+")") > 0
        Assign ZAPRES With 0
      Endif
      If evalue ("dim("+ZAVANT+")") > 0
        Assign ZAPRES With evalue(ZAVANT)
        Assign ZAVANT With 0
      Endif
    Next IJ
  Next I
  Raz [M:BPT3]TARPRI(IINS), [M:BPT3]TARADL(IINS)
Endif
Return

########################################
Subprog C_PLIMAX(VALEUR)
Variable Decimal VALEUR

##Variable Integer WERR  # FGR 24/07/2012 : N'existe pas.

NOL=nolign-1
If NOL>0
 If VALEUR <= [M:BPT1]PLIMAX(NOL-1)
   GERR=1
   GMESSAGE = mess(143,192,1) : # Borne incompatible avec la ligne précédente
   mkstat=2 : End
 Endif
Endif
If nolign<dim([M:BPT1]PLIMAX) & [M:BPT1]PLIMAX(NOL+1)<>0
  If VALEUR >= [M:BPT1]PLIMAX(NOL+1)
    GERR=1
    GMESSAGE = mess(144,192,1) : # Borne incompatible avec la ligne suivante
    mkstat=2 : End
  Endif
Endif
End

#########################################################################
#       Actions Champs : BPT2 - Régions
#########################################################################

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
If   VALEUR = ""
     GERR=1
     GMESSAGE = mess(6,199,1) : # valeur incorrecte
     mkstat = 2 : End
Endif
End

########################################
Subprog APRES_NBLIG

#Local Integer OK
#Local Char TST_TARIF(30) (1..dim([M:BPT2]POSCOD))
#For I=1 To [M:BPT2]NBLIG
#  TST_TARIF(I)=[M:BPT2]STOFCY(I-1)+"/"+[M:BPT2]CRY(I-1)+"/"+[M:BPT2]POSCOD(I-1)
#Next I
#I=uni(TST_TARIF(1..[M:BPT2]NBLIG))
#If I<>0
#  J=find(TST_TARIF(I),TST_TARIF)
#  Call AVERTIR(mess(78,191,1)-num$(I)-mess(79,191,1)-num$(J),OK) From GESECRAN
#Endif

#-----
Local Integer  WMAX : WMAX=max([M:BPT2]NBLIG,nolign)
#-----
If WMAX>1
  Local Integer  I
  Local Char     WTAB_UNICITE(30)(0..WMAX-1)
  Local Char     WZON_UNICITE(30)
  For I=0 To WMAX-1
    If I<>nolign-1
      WTAB_UNICITE(I)=[M:BPT2]STOFCY(I)+"/"+[M:BPT2]CRY(I)+"/"+[M:BPT2]POSCOD(I)
    Else
      WZON_UNICITE   =[M:BPT2]STOFCY(I)+"/"+[M:BPT2]CRY(I)+"/"+[M:BPT2]POSCOD(I)
    Endif
  Next I
  I=find(WZON_UNICITE,WTAB_UNICITE)
  If I
    Call MESSAGE(mess(78,191,1)-num$(nolign)-mess(79,191,1)-num$(I)) From GESECRAN
  Endif
Endif
#-----
End

#########################################################################
#       Actions Champs : BPT3 - Tarifs
#########################################################################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

#------------------------------------------------------------------------

$CHARG_ARE
Local Integer INBPLI                                # FGR 19/03/2010 : X3SUIVI63335

  INBPLI = min([M:BPT1]NBPLI, dim([M:BPT3]TARMIN))  # FGR 19/03/2010 : X3SUIVI63335
  Raz [M:BPT3]TARPRI, TARADL
  #For I=0 To [M:BPT1]NBPLI-1
  #For I=0 To INBPLI                                # FGR 19/03/2010 : X3SUIVI63335
  For I=0 To INBPLI-1                               # FGR 22/07/2010 : X3SUIVI66174
    [M:BPT3]TARMIN(I)=[M:BPT1]PLIMIN(I)
    [M:BPT3]TARMAX(I)=[M:BPT1]PLIMAX(I)
    [M:BPT3]TARBKT(I)=[M:BPT1]PLIBKT(I)
    If evalue ("dim([M:BPT3]PRI"+num$(I+1)+")")>NOL
      [M:BPT3]TARPRI(I)= evalue ("[M:BPT3]PRI"+num$(I+1)+"("+num$(NOL)+")")
    Endif
    If evalue ("dim([M:BPT3]ADL"+num$(I+1)+")")>NOL
      [M:BPT3]TARADL(I)= evalue ("[M:BPT3]ADL"+num$(I+1)+"("+num$(NOL)+")")
    Endif
  Next I
  #[M:BPT3]NBTAR=[M:BPT1]NBPLI
  [M:BPT3]NBTAR = INBPLI                            # FGR 19/03/2010 : X3SUIVI63335
  If INBPLI <> [M:BPT1]NBPLI Then
    GMESSAGE = mess(980,196,1)
    GERR = 4
  Else
    GMESSAGE = " "
    GERR = 4
  Endif
  Affzo [M:BPT3]15
Return

########################################
Subprog AV_NBARE
If GIMPORT : End : Endif
If status=71 | status=1
  Local Integer NOL
  NOL = min(nolign,[M:BPT3]NBARE)
  If [M:BPT3]LIGNE<>0
    [M:BPT3]LIGNE -= 1
    pcolor = GCOUL(0) : # noir
    Affzo [M:BPT3]BPTAREP([M:BPT3]LIGNE)
  Endif
  pcolor = GCOUL(1) : # rouge
  Affzo [M:BPT3]BPTAREP(NOL-1)
  [M:BPT3]LIGNE = NOL
  pcolor = GCOUL(0) : # noir
Endif
End

########################################
Subprog AS_NBARE
Gosub SETNOL
If nolign>0
  [M:BPT3]XREG=NOL+1
#---
  [M:BPT3]XREGLIB=[M:BPT3]BPTAREP([M:BPT3]XREG-1)
  Affzo [M:BPT3]10
#---
  Gosub CHARG_ARE
Endif
End

########################################
$SL_ARE
Local Char     WREGION (10)
Local Shortint I
For I=0 To [M:BPT2]NBLIG-1
#  WREGION=format$("10X",[M:BPT2]BPTARE(I))
  WREGION=[M:BPT2]BPTARE(I)
  If !find (WREGION, TEX(0..NBTEX))
    NBTEX +=1
    TEX(NBTEX)=WREGION
  Endif
Next I
TIT = mess(227,195,1)
Return

#---------------------------------------
Subprog C_BPTAREP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Call UNICITE(VALEUR,[M:BPT3]BPTAREP) From OBJDIV
End

########################################
Subprog C_NBTAR
If status=75 & [M:BPT3]XREG<1  : # si on veut modifier le tableau
  GERR=1
  GMESSAGE=mess(67,191,1)      : # selectionner une région
  mkstat=2
Endif
End

########################################
Subprog AM_TARPRI(VALEUR)
Variable Decimal VALEUR
If  evalue ("dim([M:BPT3]PRI"+num$(nolign)+")")>[M:BPT3]XREG-1
  Assign "[M:BPT3]PRI"+num$(nolign)+"("+num$([M:BPT3]XREG-1)+")" With VALEUR
Endif
End

########################################
Subprog AM_TARADL(VALEUR)
Variable Decimal VALEUR
If  evalue ("dim([M:BPT3]ADL"+num$(nolign)+")")>[M:BPT3]XREG-1
  Assign "[M:BPT3]ADL"+num$(nolign)+"("+num$([M:BPT3]XREG-1)+")" With VALEUR
Endif
End

#######################################################################
