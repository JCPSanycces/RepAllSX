#    Mise ŕ jour de la raison sociale
If WMAJNAM=0 Return Endif
If [M:BPRT]BPCFLG = 2
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    Update [BPC] Where [F:BPC]BPCNUM = [M:BPT0]BPTNUM With BPCNAM=[M:BPRT]BPRNAM, BPCSHO=[M:BPRT]BPRSHO
    If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
Endif
If [M:BPRT]BPSFLG = 2
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    Update [BPS] Where [F:BPS]BPSNUM = [M:BPT0]BPTNUM With BPSNAM=[M:BPRT]BPRNAM, BPSSHO=[M:BPRT]BPRSHO
    If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
Endif
If dim([M:BPRT]REPFLG)>0 & [M:BPRT]REPFLG=2
    If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
    Update [REP] Where [F:REP]REPNUM = [M:BPT0]BPTNUM With REPNAM=[M:BPRT]BPRNAM
    If fstat GOK=0 : Call FSTA("REP") From GLOCK : Endif
Endif

