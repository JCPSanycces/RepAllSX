###################################################################
$FIN_GILOCKBPR
  # FGR 16/04/2012 : X3SUIVI81335
  If dim(GILOCKBPR) >= 0 Then
    Gosub DEVERROU
    Kill GILOCKBPR
  Endif
Return

###################################################################
$VERROU
If [M:BPT0]BPTNUM <> ""
        Read [BPR]BPR0 = [M:BPT0]BPTNUM
        If fstat = 0
            #------------------------------------#
            # il faut verrouiller symbole BPR    #
            #------------------------------------#
            SYMBOLE2 = "BPR"+num$([M:BPT0]BPTNUM)
            Lock = SYMBOLE2 With lockwait = 0
            If fstat
#              Call ERREUR(mess(10,100,1)) From GESECRAN
               #-- on debloque le BPS - modif non autorisée
               #-- sinon on a probleme sur lock reste dans le fichier
               Unlock = SYMBOLE
               OK = 0
            Endif
         Endif
Endif
Return

###################################################################
# cg le 30/01/ 98

$VERIF_CREMOD
#----------------------------------#
# avant la creation du fournisseur #
# on verifie qu'une adresse existe #
#----------------------------------#
If [M:BPAT]NBADR = 0
        Call ERREUR(mess(31,199,1)) From GESECRAN
        OK = 0 : Return
Endif
#---------------------------------------------------#
# on verifie qu une adresse est désignée par défaut #
#---------------------------------------------------#
If find (2,[M:BPAT]BPAADDFLG (0..[M:BPAT]NBADR -1)) = 0
        Call ERREUR(mess(110,199,1)) From GESECRAN
        OK = 0 : Return
Endif
# ---- 1 région au moins doit ętre révérencée, si gestion tarif
#If    [M:BPT1]PLIFLG = 2 & [M:BPT2]NBLIG = 0
#      Call ERREUR(mess(38,199,1)) From GESECRAN
#      OK = 0 : Return
#Endif
Return

