# If !fstat : DIMBPYTAB=DIMFIL : DIMBPYSCR=DIME : Endif
# Read [ACV]CODACT="BPW"
# If !fstat : DIMBPWTAB=DIMFIL : DIMBPWSCR=DIME : Endif
# If I=1 : Close Local File [ACV] : Endif

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="BPT"

Return

###################################################################
$FERME

#CRM
Gosub FERME_CRM From TRTBPCRM

Kill GIBPTEXIST

# 85683
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
# 85683

Return

##################################################
$SETBOUT
#    pas de changement de code
Call VIREBOUT(CHAINE,"H") From GOBJET
#    simulation inactif si enregistrement actif
If CLECUR1="" or REP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

# ----------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                        #
# ----------------------------------------------------------------------------------------- #
# C : Consultations comptes  : Actif si transporteur en ligne                               #
# ----------------------------------------------------------------------------------------- #
If CLECUR CHMEN += "C" : Endif
Gosub SET_BOUT_SPE From GSAISIE

Return

########################################################
$DEFLIG
#----     Les lignes = définition des régions
#----     Le fichier des lignes doit ętre "par défaut"
Default File [CAA]
Default Mask [BPT2]
#----     Critčre de lecture
CRIT   = 'BPTNUM="'+[M:BPT0]BPTNUM+'"'
#----     Nom et abréviation du fichier lignes
FICLIG = "CARAREA" : ABLIG  = "CAA"
#----     zone ligne
ZONLIG = "LINNUM"
Return

