$AVANT_MODFIC
Local Integer WMAJNAM : Raz WMAJNAM
If [M:BPRT]BPRNAM <> [F:BPT]BPTNAM | [M:BPRT]BPRSHO <> [F:BPT]BPTSHO WMAJNAM=1 Endif
Return

