Subprog AM_ZFAGREPRES(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   [M:ZSOH1]ZFAGFLG=2
Else
   [M:ZSOH1]ZFAGFLG=1
Endif
Affzo [M:ZSOH1]ZFAGFLG
End


