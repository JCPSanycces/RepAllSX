######################################################################################
## Etiqueta a˝adida por el supervisor (Objeto ZAH) 08/04/2015 13:04:03 (ADMIN)
######################################################################################
$ACTION
#Infbox(ACTION)
Case ACTION

 When "LIENS" : Gosub LIENS
 When "EXEBOUT" : Gosub CREAR_FICHERO
 When Default
Endcase
Return
######################################################################################

$LIENS
    Local Integer TOTALUNIDADES
    Local Integer TOTALBOBINAS

    If !clalev([F:XITM]) : Local File ITMMASTER [XITM] : Endif

    [ZAS1]NBLIG = 0
    TOTALBOBINAS=0
    TOTTALUNIDADES=0

    Filter [ZAD] Where [ZAD]NUMENT = [ZAS0]NUMENT
    For [ZAD]

        [M:ZAS1]NUMENT([M:ZAS1]NBLIG)   = [ZAD]NUMENT
        [M:ZAS1]FECENT([M:ZAS1]NBLIG)   = [ZAD]FECENT
        [M:ZAS1]CODCART([M:ZAS1]NBLIG)   = [ZAD]CODCART
        [M:ZAS1]CODARTICULO([M:ZAS1]NBLIG)   = [ZAD]CODSTYLE
        Read [F:XITM]ITM0 = [ZAD]CODSTYLE
        [M:ZAS1]DESARTICULO([M:ZAS1]NBLIG)   = [XITM]ITMDES1
        [M:ZAS1]UNIDADES([M:ZAS1]NBLIG)   = [ZAD]UNIDADES
        [M:ZAS1]ZCODPALET([M:ZAS1]NBLIG)   = [ZAD]ZCODPALET
        [M:ZAS1]ZLOTE([M:ZAS1]NBLIG)   = [ZAD]ZLOTE
        [M:ZAS1]ZUNICOMPRA([M:ZAS1]NBLIG)   = [ZAD]ZUNICOMPRA
        [M:ZAS1]ZANCHO([M:ZAS1]NBLIG)   = [ZAD]ZANCHO
        [M:ZAS1]ZLONGITUD([M:ZAS1]NBLIG)   = [ZAD]ZLONGITUD
        [M:ZAS1]ZMANDRIL([M:ZAS1]NBLIG)   = [ZAD]ZMANDRIL
        [M:ZAS1]ZBOBINAS([M:ZAS1]NBLIG)   = [ZAD]ZBOBINAS
        [M:ZAS1]ZPORARANCEL([M:ZAS1]NBLIG)   = [ZAD]ZPORARANCEL
        #[M:ZAS1]ZGASNORMALES([M:ZAS1]NBLIG)   = [ZAD]ZGASNORMALES
        #[M:ZAS1]ZGASEXTRAS([M:ZAS1]NBLIG)   = [ZAD]ZGASEXTRAS
        [M:ZAS1]ZPUNITARIO([M:ZAS1]NBLIG)   = [ZAD]ZPUNITARIO
        [M:ZAS1]ZRPTOCOSTES([M:ZAS1]NBLIG)   = [ZAD]ZRPTOCOSTES
        [M:ZAS1]ZSUBTOTALUNI([M:ZAS1]NBLIG)   = [ZAD]ZSUBTOTALUNI
        [M:ZAS1]ZSUBTOTALLIN([M:ZAS1]NBLIG)   = [ZAD]ZSUBTOTALLIN


        TOTALBOBINAS = TOTALBOBINAS+[ZAD]ZBOBINAS
        TOTALUNIDADES = TOTALUNIDADES+[ZAD]UNIDADES

        #[M:ZAS1]CODCART([M:ZAS1]NBLIG)  = [ZAD]CODCART
        #[M:ZAS1]CODSTYLE([M:ZAS1]NBLIG) = [ZAD]CODSTYLE
        #Read [F:XITM]ITM0 = [ZAD]CODSTYLE
        #[M:ZAS1]ITMDES1([M:ZAS1]NBLIG)  = ""
        #[M:ZAS1]ZREFITM ([ZAS1]NBLIG) = [XITM]ZREFITM
        #[M:ZAS1]CODCOLOR([ZAS1]NBLIG) = [ZAD]CODCOLOR
        #[M:ZAS1]CODTALLA([ZAS1]NBLIG) = [ZAD]CODTALLA
        #[M:ZAS1]FECPRO([ZAS1]NBLIG)   = [ZAD]FECPRO
        #[M:ZAS1]PACKS([ZAS1]NBLIG)    = [ZAD]PACKS
        #[M:ZAS1]UNIDADES([ZAS1]NBLIG) = [ZAD]UNIDADES
        #[M:ZAS1]PROCESADA([ZAS1]NBLIG)   = [ZAD]PROCESADA

        [M:ZAS1]NBLIG += 1

    Next
    Filter [ZAD] Where 1=1

    Affzo [ZAS1]

    [M:ZAS0]TOTALBOB = TOTALBOBINAS
    [M:ZAS0]TOTUNITS = TOTALUNIDADES

    Affzo [ZAS0]

Return

$CREAR_FICHERO
    Local Integer VUELTAS

    VUELTAS=0
    adxifs=";"
    Filter [F:ZAH] Where 1=1 and [ZAH]NUMENT=[M:ZAS0]NUMENT
    For [F:ZAH]
        #WTROBAT = 1
        #WPOHNUM = [F:ZPOH]POHNUM
        If VUELTAS=0 Then
            Openo filpath("BQT",[F:ZAH]NUMENT+format$("D:YYYYMMDD",date$),"TXT"),0 Using [TIE]
            Wrseq "E",[F:ZAH]PLANTA,format$("D:YYYYMMDD",[F:ZAH]FECENT),[F:ZAH]NUMENT,[F:ZAH]IDPROVEEDOR,"EUR","",format$("D:YYYYMMDD",date$) Using [TIE]
        Endif

        Filter [F:ZAD] Where 1=1 and [ZAD]NUMENT=[M:ZAS0]NUMENT
        For [F:ZAD]
            Read [F:XITM]ITM0 = [ZAD]CODSTYLE
            Wrseq "L",[F:ZAH]NUMPED,[F:ZAD]LIN,[F:ZAD]CODSTYLE,[F:XITM]ITMDES1,[F:ZAD]ZBOBINAS,[F:ZAD]ZANCHO,[F:ZAD]ZMANDRIL,[F:ZAD]ZLONGITUD,[F:ZAH]IDPROVEEDOR,[F:ZAD]ZUNICOMPRA,[F:ZAD]UNIDADES,[F:
& ZAD]ZPORARANCEL,[F:ZAD]ZPORARANCEL*[F:ZAD]UNIDADES,[F:ZAD]ZRPTOCOSTES,[F:ZAD]ZRPTOCOSTES*[F:ZAD]UNIDADES,[F:ZAD]ZRPTOCOSTES,[F:ZAD]ZRPTOCOSTES*[F:ZAD]UNIDADES Using
& [TIE]
            Wrseq "S","A2",[F:ZAD]ZUNICOMPRA,[F:ZAD]UNIDADES,[F:ZAH]UBICACION,[F:ZAD]ZLOTE,"","" Using [TIE]

            [F:ZAD]ZFECHAVAL=date$
            Rewrite [F:ZAD]
        Next

        Openo Using [TIE]
    Next

Return
