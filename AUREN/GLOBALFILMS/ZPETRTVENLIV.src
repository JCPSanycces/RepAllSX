#<AdxTL>@(#)0.0.0.0 $Revision$
#PE ALISOQSDH (TRTVENLIV), para recalcular las bobinas entregadas en funcion de la cantidad de stock.
## ZPV - Precio Venta / Cantidades Reals.
##     ---->  Carga campos ZCTDREAL ZPRIREAL y ZCTDREAL del pedido de Venta

$ACTION
Case ACTION
   When "ALISOQSDH"   :  Gosub ALISOQSDH
   When "CALPORT"     :  Gosub CALPORT
Endcase
Return

$ALISOQSDH
Local Decimal ZBOBLIV

#Infbox "FJCG - ALISOQSDH - TRVENLIV "
If [F:SOQ]QTYSTU<>0
   #ZBOBLIV=[F:SOQ]ZQTYBOB*[M:SDH1]QTYSTU(NOL)/[F:SOQ]QTYSTU
   #Infbox "PE - ALISOQSDH: "+num$(ZBOBLIV)
   #[M:SDH1]ZQTYBOB(NOL)=arr(ZBOBLIV,0.01)
Endif

## ZPV - Precio Venta / Cantidades Res

If [F:SOP]SAU="M2"
   [M:SDH1]ZCTDREAL(NOL)=[F:SOQ]QTY
   [M:SDH1]QTY(NOL)=[F:SOQ]QTY
   [M:SDH1]ZPRIREAL(NOL)=[F:SOP]GROPRI
   [M:SDH1]SAUSTUCOE(NOL)=[F:SOQ]ALLQTYSTU/[F:SOQ]QTY
  # Call AM_SAUSTUCOE([M:SDH1]SAUSTUCOE(NOL)) From SUBSDH
  # [M:SDH1]GROPRI(NOL)=arr([F:SOP]GROPRI*[F:SOQ]QTY/[F:SOQ]ALLQTYSTU,0.0001)
   [M:SDH1]ZCTDREALUS(NOL)=[F:SOQ]ALLQTYSTU
 #  Call CALC_PRECIOS([M:SDH1]GROPRI(NOL),NOL) From SPESDH
Else
   [M:SDH1]ZCTDREAL(NOL)=[F:SOQ]ALLQTY
   [M:SDH1]ZPRIREAL(NOL)=[F:SOP]GROPRI
   [M:SDH1]ZCTDREALUS(NOL)=[F:SOQ]ALLQTYSTU
Endif


## FIN ZPV - Precio Venta / Cantidades Reals

Return

$CALPORT
If [F:SDH]BPTNUM<>""
   Call TRANSPORT([F:SDH]BPTNUM,[F:SDH]BPCORD,[F:SDH]STOFCY,WCRY,WCTY,WPOSCOD,
&                 [F:SDH]CUR,[F:SDH]CHGTYP,date$,[F:SDH]DLVNOT,[F:SDH]WEU,
&                 [F:SDH]GROWEI,[F:SDH]VOU,[F:SDH]VOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                 From TRTPRICE
   STAT=10
   WPOINT_ENTREE = 1
   [F:SDH]ZIMPPORCAL=LAMTFRE
Endif
Return
