#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZMLONG
# Description : Mantenimiento Intervalos Long.
# Module      : Datos base
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espa±a
# Created date: 30/06/2022
############################################################################
################################################################
$ACTION

  Case ACTION
    When "OUVRE"            :Gosub OUVRE
    When "DEBUT"            :Gosub DEBUT
    When "OK"               :Gosub OK
    When "APRES_MODIF"      :Gosub APRES_MODIF
   When Default
  Endcase
Return

################################################################
$OUVRE
If !clalev([F:ZMLONG]) : Local File ZMLONG [ZMLONG] : Endif
Return

################################################################
$APRES_MODIF
If status = 65
  If nolign<>[M:ZMLONG]NBLIG
    Errbox "Solo puede borrar la ultima lĒnea"
    mkstat=2
    Return
  Endif
Endif
Return

$OK
Delete [F:ZMLONG] Where [F:ZMLONG]ITMREF=[F:ITM]ITMREF
For I=0 To [M:ZMLONG]NBLIG-1
  Raz [F:ZMLONG]
  [F:ZMLONG]ITMREF=[F:ITM]ITMREF
  [F:ZMLONG]LONG=[M:ZMLONG]LONG(I)
  [F:ZMLONG]RANGFIN=[M:ZMLONG]RANGFIN(I)
  [F:ZMLONG]RANGINI=[M:ZMLONG]RANGINI(I)
  Write [F:ZMLONG]
Next
Return

$DEBUT
Raz [M:ZMLONG]
For [F:ZMLONG] Where [F:ZMLONG]ITMREF = [F:ITM]ITMREF
  I = [M:ZMLONG]NBLIG
  [M:ZMLONG]ITMREF(I)=[F:ITM]ITMREF
  [M:ZMLONG]LONG(I)=[F:ZMLONG]LONG
  [M:ZMLONG]RANGFIN(I)=[F:ZMLONG]RANGFIN
  [M:ZMLONG]RANGINI(I)=[F:ZMLONG]RANGINI
  [M:ZMLONG]NBLIG+=1
Next
Affzo [M:ZMLONG]
Return
######################################################################################
## Etiqueta a±adida por el supervisor (pantalla ZMLONG) 30/06/2022 19:43:07 (ADMIN)
######################################################################################
Subprog AS_RANGINI(VALEUR)
Variable Decimal VALEUR
If nolign>1
  VALEUR=[M:ZMLONG]RANGFIN(nolign-2)+1
Endif
End

Subprog C_RANGINI(VALEUR)
Variable Decimal VALEUR
If nolign>1
  If VALEUR<>[M:ZMLONG]RANGFIN(nolign-2)+1
    Errbox "Valor debe ser "+ num$([M:ZMLONG]RANGFIN(nolign-2)+1)
    VALEUR = [M:ZMLONG]RANGFIN(nolign-2)+1
    mkstat=2
    End
  Endif
Endif

If [M:ZMLONG]RANGFIN(nolign-1) <> 0 and VALEUR>=[M:ZMLONG]RANGFIN(nolign-1)
  Errbox "Valor debe ser menor a "+ num$([M:ZMLONG]RANGFIN(nolign-1))
  mkstat=2
  End
Endif

If VALEUR<0
  Errbox "Valor debe ser mayor a 0"
  mkstat=2
  End
Endif
End

Subprog C_RANGFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR <= [M:ZMLONG]RANGINI(nolign-1)
  Errbox "Valor debe ser mayor a "+num$([M:ZMLONG]RANGINI(nolign-1))
  mkstat=2
  End
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
If VALEUR <= [M:ZMLONG]RANGINI(nolign-1) or VALEUR >=[M:ZMLONG]RANGFIN(nolign-1)
  Errbox "Valor debe estar dentro del rango"
  mkstat = 2
  End
Endif
End


######################################################################################
