#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog PASAR_COMBI_AJUSTAR_CON_STOCK(TOPE)
Value Integer TOPE
# Aqui venimos por cada combinación que se monta para producir Todas las bobinas
# Por cada fila, vemos de ajustarla para que el desperdicio sea <= marcado
# Al volver, compararemos si la combinacion es mas optima que anterior, en cuyo nos la quedamos
#
Onerrgo ERRORES_FIN

Local Integer F, DIF_JUM, FIN,RESTO,TDIF,TTRZ,TANC
Local Char COMB(255)

# Desmarco anchos a fabricar, pues marcaré los que se queden pendientes al ser sustituidos por anchos A
Call QUITAR_MARCAS(0) From SPEZGOFS1

# Ajustar las combinaciones, puedo mezclar diferentes ANCHOS en una combinacion, mediante opcion "Combinar" de los jumbos
For F=0 To [M:ZGOFS2]NTMP-1
  DIF_JUM=func DESPERD_JUMBO([M:ZGOFS2]TANCHOJ(F))-[M:ZGOFS2]SMERMA
  RESTO=[M:ZGOFS2]TDIF(F)
  # Meter stock en trozo sobrante
  Call ANADIR_STOCK ([M:ZGOFS2]TDIF(F)-[M:ZGOFS2]SMERMA,COMB)
  [M:ZGOFS2]TDIFTRZA(F)=COMB
  RESTO=[M:ZGOFS2]TDIF(F)-func SUMAR_ANCHOS_COMB(COMB,"",5)
  If RESTO=0 or (RESTO<DIF_JUM and [M:ZGOFS2]SMINSTK=2)
    # Está dentro de los limites
  Else
    # Despues de esta llamada se asume que no podemos optimizarlo mas
    # Vemos la mejor opcion para cambiar anchos existentes por anchos de stock
    Call COMBINAR_AJUSTAR_CON_ANCHOS_A([M:ZGOFS2]TCOMBI(F),[M:ZGOFS2]TDIFTRZA(F))
  Endif
Next
# Montar combinacion con los pedidos que faltan
For F=0 To [M:ZGOFS2]NJUM-1
  If TOPE=0 or TOPE=[M:ZGOFS2]JANCHO(F)
    Call COMBINAR_PDTE ([M:ZGOFS2]JANCHO(F)-[M:ZGOFS2]SMERMA,[M:ZGOFS2]JMERMAC(F))
  Endif
Next

# Quedarme con la mas optima


#Determinar calculo de sobrante y trozos para saber si es mas optima que combinacion anterior
# 1ş Actualizo Ancho lŞ - sobrante lŞ y cuento trozos
Raz TDIF,TTRZ
For F=0 To [M:ZGOFS2]NTMP-1
  TANC=func SUMAR_ANCHOS_COMB([M:ZGOFS2]TCOMBI(F),[M:ZGOFS2]TDIFTRZA(F),5)
  [M:ZGOFS2]TDIF(F)=[M:ZGOFS2]TANCHOJ(F)-[M:ZGOFS2]SMERMA-TANC
  If [M:ZGOFS2]TDIF(F)>0
    TTRZ+=1
  Endif
Next
# 2ş Actualizo Total sobrante & trozos combinación
For F=0 To [M:ZGOFS2]NTMP-1
  [M:ZGOFS2]TDIFT(F)  = TDIF
  [M:ZGOFS2]TTROZOS(F)= TTRZ
Next
End


Subprog COMBINAR_AJUSTAR_CON_ANCHOS_A(COMBP,COMBA)
Variable Char COMBP,COMBA

Local Integer ANC(60),ANCR(60)            # Tope de 51 anchos por combinacion...51x5=255
Local Integer RANC(60),RREP(60),RDIF(60)
Local Integer DIF_ANC
Local Integer A0,A1,A2,A3,A4
Local Integer OK_STOCK
Local Decimal DIF_OPC,DIF_MENOR
Local Integer F,V
Local Char COMB(255)
# Basicamente funciona igual que COMBINAR_AJUSTAR_CON_ANCHOS_PED, excepto por
#   - Ańadiremos tantos de stock como sean necesarias, por lo que no controlamos
#         - Si bobina asignada o no, en lugar de ello debe estar marcada para  tenerla en cuenta
#         - Si hay bobinas suficientes, motivo por el cual nos quedamos con los decimales para determinar mejor opcion
#   - De no desear un ancho en concreto, lo desmarcaremos y repetiremos calculo
#

#MONTAR_RESTOS_POSIBLES
Raz ANC,ANCR,RANC,RREP,RDIF
# Acumular nş de veces que aparece el ancho en la combinacion, para determinar <<Repeticiones Ancho>>

COMB=COMBP
If COMBA<>"" and COMB<>""
  COMB+="-"
Endif
COMB+=COMBA
Call CONTAR_ANCHOS_COMB(COMB,5,ANC,ANCR) From SPEZGOFS4
# Montar restos posibles de la combinación
A2=0
For A0=0 To dim(ANC)-1
  For A1=1 To ANCR(A0)
    RANC(A2)=ANC(A0)
    RREP(A2)=A1
    RDIF(A2)=A1*ANC(A0)+DIF_ANC
    A2+=1
  Next
Next

DIF_MENOR=9999.999
# A2 = indice con la mejor opcion de resto posible
# A3 = indice con la mejor opcion de ancho posible
A2=-1
A3=-1
For A1=0 To dim(RDIF)-1
  If RANC(A1)=0
    Break
  Endif
  For A0=0 To [M:ZGOFS2]NTIA-1
    # La rejilla de anchos está ordenada por Anchos ASC
    If RDIF(A1)<[M:ZGOFS2]NANCHO(A0)
      Break
    Elsif [M:ZGOFS2]NSEL(A0)=2
      DIF_OPC=RDIF(A1)/[M:ZGOFS2]NANCHO(A0)
      # Terminamos en cuanto encontremos la primera opcion SIN restos. >>>En anchos A, De no desearla, que la desmarquen
      If DIF_OPC=int(DIF_OPC)# and func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC)
        A2=A1
        A3=A0
        DIF_MENOR=DIF_OPC
        Break 2
      Elsif DIF_OPC-int(DIF_OPC)<DIF_MENOR-int(DIF_MENOR) # and func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC)
        A2=A1
        A3=A0
        DIF_MENOR=DIF_OPC
      Endif
    Endif
  Next
Next
#
If DIF_MENOR<9999 and A2<>-1
  #Quito de la combinacion el "resto posible"....  1şStocks   2şPedidos
  For A0=1 To RREP(A2)
    COMBA=func ZCOMUN.REPLACE(COMBA, format$("N0:4",RANC(A2)), "", 1,V)
    If V>0
      COMBA=func ZCOMUN.REPLACE(COMBA, "--", "-", 1,V)
    Else
      COMBP=func ZCOMUN.REPLACE(COMBP, format$("N0:4",RANC(A2)), "", 1,V)
      COMBP=func ZCOMUN.REPLACE(COMBP, "--", "-", 1,V)
      Call MARCAR_ANCHO_PED(RANC(A2))
    Endif
  Next
  #Ańado a la combinacion el "ancho posible"
  For A0=1 To int(DIF_MENOR)
    If COMBA<>""
      COMBA+="-"
    Endif
    COMBA+=format$("N0:4",[M:ZGOFS2]NANCHO(A3))
  Next
Endif
End


Subprog ANADIR_STOCK(TROZO,COMBF)
Value Integer TROZO   # Trozo disponible
Variable Char COMBF   # Combinación sugerida
# Dado un trozo, vemos la mejor combinacion posible de Anchos de stock A a meter
Local Char COMB(255),COMB_MEJOR (255)
Local Integer DIF,DIF_MEJOR
Local Integer TANC   # Para llevar la suma de los trozos que metemos
Local Integer NPOS   # Posición del elemento con el que empezamos a combinar
Local Integer NORD
#Local Integer
Raz TANC,COMB,COMB_MEJOR   #,COMBF     La comento porque puede ser que tenga algo !!!!    Ej. Sustituyendo por pedidos, es posible que un ancho me cuadre pero el nş de bobinas > bobians pdtes pedidos
# Terminamos si difŞ combinación es mas pequeńa que el menor ancho posible
If TROZO<func SPEZGOFS1.SACAR_MENOR_A
  End
Endif
DIF_MEJOR=9999
For NPOS=0 To [M:ZGOFS2]NTIA-1
  If [M:ZGOFS2]NSEL(NPOS)=2
    If func TERMINAR([M:ZGOFS2]NANCHO(NPOS),TROZO,0,COMB_MEJOR,DIF_MEJOR)
      Break
    Endif
    # Empezamos a combinar, con el elemento indicado en NPOS
    TANC=-1
    For NORD=NPOS+1 To [M:ZGOFS2]NTIA-1
      If [M:ZGOFS2]NSEL(NORD)=2
        If func TERMINAR([M:ZGOFS2]NANCHO(NORD),TROZO,1,COMB_MEJOR,DIF_MEJOR)
          Break 2
        Endif
        If TANC=-1
          TANC=[M:ZGOFS2]NANCHO(NPOS)
          COMB=format$("N0:4",TANC)
        Endif
        If TANC+[M:ZGOFS2]NANCHO(NORD)>TROZO
          Gosub ANADIR_STOCK_TOT
          TANC=[M:ZGOFS2]NANCHO(NPOS)
          COMB=format$("N0:4",TANC)
          If TANC+[M:ZGOFS2]NANCHO(NORD)>TROZO
            Break
          Endif
        Endif
        TANC+=[M:ZGOFS2]NANCHO(NORD)
        COMB+="-"+format$("N0:4",[M:ZGOFS2]NANCHO(NORD))
      Endif
    Next
    Gosub ANADIR_STOCK_TOT
  Endif
Next
If COMB_MEJOR<>""
  If COMBF<>"":COMBF+="-":Endif
  COMBF+=COMB_MEJOR
Endif
End

$ANADIR_STOCK_TOT
If TANC>0
  DIF=TROZO-TANC
  If DIF<DIF_MEJOR
    DIF_MEJOR=DIF
    COMB_MEJOR=COMB
  Endif
Endif
Return


Funprog SUMAR_ANCHOS_COMB(COMB1,COMB2,L)
Value Char COMB1,COMB2
Value Integer L
Local Integer F,ANC
Local Char COMB(255)
COMB=COMB1
If COMB2<>""
  If COMB<>"" and L=5
    COMB+="-"
  Endif
  COMB+=COMB2
Endif
Raz ANC
# Siempre se combina de 4 en 4 en alguna de las siguientes 2 formas
# Forma 1 025003001000    =====>  L=4
# Forma 2 0250-0300-1000  =====>  L=5
For F=1 To len(COMB) Step L
  ANC+=val(mid$(COMB,F,4))
Next
End ANC


Funprog TERMINAR(ANC,TROZO,OP,COMB,DIF_MEJOR)
Value Integer ANC,TROZO,OP
Variable Integer DIF_MEJOR
Variable Char COMB
Local Integer FIN,F,G,DIF
FIN=0
# Terminamos si AnchoA > del trozo
If ANC>TROZO and OP=0
  FIN=1
Else
  G=int(TROZO/ANC)
  If TROZO/ANC=G
  # Terminamos si AnchoA multiplo del trozo
    Raz COMB
    For F=1 To G
      If COMB<>"":COMB+="-":Endif
      COMB+=format$("N0:4",ANC)
    Next
    FIN=1
  Else
  # Vemos si opcion multiplo mejor que actual
    DIF=TROZO-(G*ANC)
    If DIF<DIF_MEJOR
      DIF_MEJOR=DIF
      Raz COMB
      For F=1 To G
      If COMB<>"":COMB+="-":Endif
        COMB+=format$("N0:4",ANC)
      Next
    Endif

  Endif
Endif
End FIN

Funprog DESPERD_JUMBO(ANC)
Value Integer ANC
Local Integer F,MERMA
For F=0 To [M:ZGOFS2]NJUM-1
  If [M:ZGOFS2]JANCHO(F)=ANC
    MERMA=[M:ZGOFS2]JMERMAC(F)
    Break
  Endif
Next
End MERMA

Subprog MARCAR_ANCHO_PED(ANC)
Value Integer ANC
Local Integer F
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0 and [M:ZGOFS2]ANCHO(F)=ANC
    [M:ZGOFS2]ASIGNADA(F)=-1
    Break
  Endif
Next
End

###########################################
###########################################

Subprog COMBINAR_PDTE(TOPE,TOPE_DIF)
Value Integer TOPE,TOPE_DIF

Local Integer F,ELE,TANC,DIF_ANC
Local Char COMB(255)

Call CAMBIAR_INVERTIR

Raz COMB,TANC

While func HAY_PDTES>0
For F=0 To TELE
  If [M:ZGOFS2]ASIGNADA(F)=0
    ELE=[M:ZGOFS2]ANCHO(F)
    If TANC+ELE>TOPE
      Gosub COMBINAR_GUARDAR_COMBI_2
      Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
    Endif
    Call COMBINAR_2_ACUMULAR(F,TANC,COMB)
  Endif
Next
Wend
# Guardar resto, ultima combinacion para completar produccion
If TANC>0
  Gosub COMBINAR_GUARDAR_COMBI_2
  While func HAY_PDTES(0)>0
  For F=0 To TELE
    If [M:ZGOFS2]ASIGNADA(F)=0
      ELE=[M:ZGOFS2]ANCHO(F)
      If TANC+ELE>TOPE
        Gosub COMBINAR_GUARDAR_COMBI_2
        Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
      Endif
      Call COMBINAR_2_ACUMULAR(F,TANC,COMB)
    Endif
  Next
  Wend
Endif
End

$COMBINAR_GUARDAR_COMBI_2
Local Decimal Q,DIF_MENOR

If COMB=""
  Infbox "Avise al programador    COMB vacio...(COMBINAR_GUARDAR_COMBI_2)"
Elsif TANC>TOPE
  Infbox "Avise al programador    TANC>TOPE   "+ num$(TANC) + ">"+num$(TOPE) + "...(COMBINAR_GUARDAR_COMBI_2)"
Else
  DIF_ANC=TOPE-TANC
  If DIF_ANC >0
    # Meter stock en trozo sobrante
    Call ANADIR_STOCK ([M:ZGOFS2]TDIF(F)-[M:ZGOFS2]SMERMA,COMB)
    [M:ZGOFS2]TDIFTRZA(F)=COMB
  Endif
  Q=[M:ZGOFS5]NPDT
  [M:ZGOFS5]PANCHOJ(Q)= TOPE
  [M:ZGOFS5]COMBI(Q)  = COMB
  [M:ZGOFS5]CANCHO(Q) = TANC
  [M:ZGOFS5]CDIF(Q)   = TOPE-[M:ZGOFS5]CANCHO(Q)
  [M:ZGOFS5]NPDT+=1
  If [M:ZGOFS5]NPDT>=500
    Infbox "Se ha superado el limite de combinaciones posibles ([M:ZGOFS2]NCOM>=8000)"
  Endif
  #Marcar bobinas como incluidas
  Call QUITAR_MARCAS (22) From SPEZGOFS1
Endif
Raz COMB,TANC
Return


Subprog COMBINAR_2_ACUMULAR(F,TANC,COMB)
Value Integer F
Variable Integer TANC
Variable Char COMB
Local Integer ELE
Local Char TXT(255)
ELE=[M:ZGOFS2]ANCHO(F)
TXT=format$("N0:4",ELE)
[M:ZGOFS]ASIGNADA(F)=-1
TANC+=ELE
If len(COMB+TXT)+int(255/5)>=255
  Infbox "Avise al programador...Superado limite de " + num$(int(255/5)) + " anchos posibles (Subprog COMBINAR_2_ACUMULAR)"
Else
  COMB+=TXT  # Recordar que ningun elemento puede ser superior al TOPE
Endif
End


Funprog HAY_PDTES
Local Integer F,C
Raz C
For F=INI To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0
    C+=1
  Endif
Next
End C

Subprog CAMBIAR_INVERTIR
Local Integer F
# Invertimos seleccion...-1 = 0   y   0 = 1
# Para que los 0 sean los que tenemos pendientes de combinar
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=-1
    [M:ZGOFS2]ASIGNADA(F)=0
  Else
    [M:ZGOFS2]ASIGNADA(F)=1
  Endif
Next
End C
End



$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End

