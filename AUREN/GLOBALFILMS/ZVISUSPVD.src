Subprog LLENAR_REJILLA
Local Integer F,ZOK
# vaciar rejilla
Raz [M:ZSPLV]NBLIG
Effzo [M:ZSPLV]10
#
If [M:ZSPLV]FCY='' or [M:ZSPLV]FECHA=[0/0/0] or [M:ZSPLV]BPCNUM=''   End   Endif
# Generar precios
Call GENERAR_TARIFAS([M:ZSPLV]FCY,[M:ZSPLV]FECHA,[M:ZSPLV]BPCNUM,"",ZOK) From ZGENTARCTE
If not ZOK   Return   Endif
# Mostrar datos, del  usuario y funcion en  la que estamos..un usuario puede estar a la vez, para un mismo cliente, consultando tarifas aqui y generando emails en otra pantalla de ciertos articulos
Filter [F:ZTCD]
Filter [F:ZTCD] Where BPCNUM=[M:ZSPLV]BPCNUM and SALFCY=[M:ZSPLV]FCY and CREUSR =GUSER and CODINT=GFONCTION Order By Key ZTACD0
For [F:ZTCD]
   F=[M:ZSPLV]NBLIG
   [M:ZSPLV]SALFCY(F)   =[F:ZTCD]SALFCY
   [M:ZSPLV]ITMREF(F)   =[F:ZTCD]ITMREF
   [M:ZSPLV]LONGITUD(F) =[F:ZTCD]LONGITUD
   [M:ZSPLV]PRI(F)      =[F:ZTCD]PRI
   [M:ZSPLV]PLISTRDAT(F)=[F:ZTCD]PLISTRDAT
   [M:ZSPLV]PLIENDDAT(F)=[F:ZTCD]PLIENDDAT
   [M:ZSPLV]CUR(F)      =[F:ZTCD]CUR
   [M:ZSPLV]UOM(F)      =[F:ZTCD]UOM
   [M:ZSPLV]PLI(F)      =[F:ZTCD]PLI
   [M:ZSPLV]PLICRD(F)   =[F:ZTCD]PLICRD
#   [M:ZSPLV]PLILIN(f)   =[F:SPLX]PLILIN
   If [M:ZSPLV]NBLIG+1>=[M:ZSPLV]FLDNUM(0)
     MSG="FALTAN DATOS !!!\Alcanzado máximo de " + num$([M:ZSPLV]FLDNUM(0)+1) + " filas para precios\.\Avise para que se lo aumenten"
     Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
     Break
   Else
     [M:ZSPLV]NBLIG+=1
   Endif
Next
Filter [ZTCD]
Affzo [M:ZSPLV]10
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZSPLV) 09/05/2017 15:17:48 (ADMIN)
######################################################################################
Subprog AM_FECHA(VALEUR)
Variable Date    VALEUR
[M:ZSPLV]FECHA=VALEUR
Call LLENAR_REJILLA
End

Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
[M:ZSPLV]BPCNUM=VALEUR
Call LLENAR_REJILLA
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:ZSPLV]FCY=VALEUR
Call LLENAR_REJILLA
End


