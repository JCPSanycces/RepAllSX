$ACTION
Case ACTION
 When "INIT"     : Gosub INIT_ZVISUSPVD
 When "OUVRE"    : Gosub OUVRE_ZVISUSPVD
 When "DEBUT"    : Gosub DEBUT_ZVISUSPVD
 When "FIN"      : Gosub FIN_ZVISUSPVD
 When "TITRE"    : Gosub TITRE_S
 When Default
Endcase
Return


$TITRE_S
TIT="Consulta tarifas venta << EN PRUEBAS # PDTE.VALIDAR >>"
Return


$INIT_ZVISUSPVD
Local    Char     WCLI(15)       :    WCLI=PARAM(1)
Return

$OUVRE_ZVISUSPVD
Local    Char     WCLI(15)       :    WCLI=PARAM(1)

If clalev([F:ZTCD])=0 : Local File ZTARCTED   [F:ZTCD] : Endif
#If clalev([F:SPLX])=0 : Local File SPRICLIST  [F:SPLX] : Endif
#If clalev([F:BPCX])=0 : Local File BPCUSTOMER [F:BPCX] : Endif
#If clalev([F:ITMX])=0 : Local File ITMMASTER  [F:ITMX] : Endif
Return


$DEBUT_ZVISUSPVD
Raz [M:ZSPLV]
[M:ZSPLV]FLDNUM(0)=func ZCOMUN.FILAS_GRID("ZSPLV","NBLIG")
[M:ZSPLV]BPCNUM    = WCLI
#Gosub LIRED
[M:ZSPLV]FCY       = GFCYDEF(8)
If GFONCTION="ZENVTARCTE"
  [M:ZSPLV]FECHA     = [M:ZETC0]FECHA
Else
  [M:ZSPLV]FECHA     = date$
Endif
Affzo [M:ZSPLV]FCY
Affzo [M:ZSPLV]FECHA
Call LLENAR_REJILLA
Return

$FIN_ZVISUSPVD
Return


