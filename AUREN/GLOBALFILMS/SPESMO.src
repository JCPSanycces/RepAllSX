$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]
NOL=nolign-1

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=([M:SMO1]ZANCHO(NOL)/1000)*[M:SMO1]ZLONGITUD(NOL)
LVOLUMEN=([M:SMO1]ZANCHO(NOL)/1000)*[M:SMO1]ZLONGITUD(NOL)*LFACTOR
If VALEUR<>0 and [M:SMO1]ZANCHO(NOL)<>0 and [M:SMO1]ZMANDRIL(NOL)<>0 and [M:SMO1]ZLONGITUD(NOL)<>0
   If [M:SMO1]PCU(NOL)="KG"
      [M:SMO1]QTYPCU(NOL)=arr(VALEUR*LVOLUMEN,0.0001)
   Endif
   If [M:SMO1]PCU(NOL)="M2"
      [M:SMO1]QTYPCU(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
   Endif
   [M:SMO1]QTYSTU(NOL) = [M:SMO1]QTYPCU(NOL) * [M:SMO1]PCUSTUCOE(NOL)
    Call QTEARR( [M:SMO1]QTYSTU(NOL),[M:SMO1]STU(NOL)) From TRTDIV
Else
   [M:SMO1]QTYPCU(NOL)=[M:SMO1]ZQTYBOB(NOL)
Endif
Affzo [M:SMO1]QTYPCU(NOL)
Affzo [M:SMO1]QTYSTU(NOL)

#[M:SMO1]PALNUM(NOL)=num$([M:SMO1]ZANCHO(NOL))
#[M:SMO1]CTRNUM(NOL)=num$([M:SMO1]ZLONGITUD(NOL))
#[M:SMO1]CTRNUM(NOL)=num$([M:SMO1]ZMANDRIL(NOL))
#[M:SMO1]NBSLO(NOL)=VALEUR
#Affzo [M:SMO1]PALNUM(NOL)
#Affzo [M:SMO1]CTRNUM(NOL)
#Affzo [M:SMO1]NBSLO(NOL)
End

Subprog AM_ZANCHO(VALEUR)
Variable Decimal VALEUR
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1
LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=(VALEUR/1000)*[M:SMO1]ZLONGITUD(NOL)
LVOLUMEN=(VALEUR/1000)*[M:SMO1]ZLONGITUD(NOL)*LFACTOR
If [M:SMO1]ZQTYBOB(NOL)<>0 and VALEUR<>0 and [M:SMO1]ZMANDRIL(NOL)<>0 and [M:SMO1]ZLONGITUD(NOL)<>0
   If [M:SMO1]PCU(NOL)="KG"
      [M:SMO1]QTYPCU(NOL)=arr([M:SMO1]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
   Endif
   If [M:SMO1]PCU(NOL)="M2"
      [M:SMO1]QTYPCU(NOL)=arr([M:SMO1]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
   Endif
   [M:SMO1]QTYSTU(NOL) = [M:SMO1]QTYPCU(NOL) * [M:SMO1]PCUSTUCOE(NOL)
    Call QTEARR( [M:SMO1]QTYSTU(NOL),[M:SMO1]STU(NOL)) From TRTDIV
Else
   [M:SMO1]QTYPCU(NOL)=[M:SMO1]ZQTYBOB(NOL)
Endif
Affzo [M:SMO1]QTYPCU(NOL)
Affzo [M:SMO1]QTYSTU(NOL)

#[M:SMO1]PALNUM(NOL)=num$(VALEUR)
#[M:SMO1]CTRNUM(NOL)=num$([M:SMO1]ZLONGITUD(NOL))
#[M:SMO1]CTRNUM(NOL)=num$([M:SMO1]ZMANDRIL(NOL))
#[M:SMO1]NBSLO(NOL)=[M:SMO1]ZQTYBOB(NOL)
#Affzo [M:SMO1]PALNUM(NOL)
#Affzo [M:SMO1]CTRNUM(NOL)
#Affzo [M:SMO1]NBSLO(NOL)
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]
NOL=nolign-1
LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=([M:SMO1]ZANCHO(NOL)/1000)*VALEUR
LVOLUMEN=([M:SMO1]ZANCHO(NOL)/1000)*VALEUR*LFACTOR
If [M:SMO1]ZQTYBOB(NOL)<>0 and [M:SMO1]ZANCHO(NOL)<>0 and [M:SMO1]ZMANDRIL(NOL)<>0 and VALEUR<>0
   If [M:SMO1]PCU(NOL)="KG"
      [M:SMO1]QTYPCU(NOL)=arr([M:SMO1]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
   Endif
   If [M:SMO1]PCU(NOL)="M2"
      [M:SMO1]QTYPCU(NOL)=arr([M:SMO1]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
   Endif
   [M:SMO1]QTYSTU(NOL) = [M:SMO1]QTYPCU(NOL) * [M:SMO1]PCUSTUCOE(NOL)
    Call QTEARR( [M:SMO1]QTYSTU(NOL),[M:SMO1]STU(NOL)) From TRTDIV
Else
   [M:SMO1]QTYPCU(NOL)=[M:SMO1]ZQTYBOB(NOL)
Endif
Affzo [M:SMO1]QTYPCU(NOL)
Affzo [M:SMO1]QTYSTU(NOL)

#[M:SMO1]PALNUM(NOL)=num$([M:SMO1]ZANCHO(NOL))
#[M:SMO1]CTRNUM(NOL)=num$(VALEUR)
#[M:SMO1]CTRNUM(NOL)=num$([M:SMO1]ZMANDRIL(NOL))
#[M:SMO1]NBSLO(NOL)=[M:SMO1]ZQTYBOB(NOL)
#Affzo [M:SMO1]PALNUM(NOL)
#Affzo [M:SMO1]CTRNUM(NOL)
#Affzo [M:SMO1]NBSLO(NOL)
End
