#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox GFONCTION - GACTION - ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "OK"           : Gosub OK
 When "AVANT_OK"     : Gosub AVANT_OK
 When Default
Endcase
Return


$APRES_MODIF
  #Infbox "COUZON=" + COUZON + "   COUIND=" + num$(COUIND) + "   CZ=" + CZ
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
Case COUZON
When "ZANCHOD"
  If val(CZ)<ANCHO_GC
    Call ERREURT("El ancho minimo de la bobina debería ser " + num$(ANCHO_GC)+"\Asegúrese en caso de cambiarlo", 0) From GESECRAN   #0-Informativo, 1-Error
#    CZ=num$(ANCHO_GC)
#    [M:ZAL0]ZANCHOD=ANCHO_GC:    Affzo [M:ZAL0]ZANCHOD
  Endif
  If val(CZ)>[M:ZAL0]ZANCHOH
    [M:ZAL0]ZANCHOH=val(CZ)
  Endif
Endcase

If maskcou <>"ZASILOT1" :  Call BORRA_REJILLA : Endif
Return


$AVANT_OK
Local Integer OK
OK=1
If [M:ZAL1]NBLIG<1
  OK=0
Endif
If OK=0
  GMESSAGE="Observe que NO ha seleccionado bobina alguna"
  GERR=1  # No ejecutará ACCION  "OK"
Endif
Return

$OUVRE
Local Decimal  ANCHO_GC  # JLPR 13.07.16Para saber el ancho minimo del GC
Local Shortint WLMINANCHO : WLMINANCHO=[M:MFG1]ZMINANCHO
#Local Integer WTEST : WTEST =0

Local Integer WLGRCOR   : # Grupo de Corte en Tratamiento
Local Char WLITMREF(20) : # Articulo Material Asignado

If !clalev([F:STO]) : Local File STOCK [STO] : Endif
#If !clalev([F:STL]) : Local File STOLOT  [STL] : Endif
If !clalev([F:ZMFL]): Local File ZMFGLOT [ZMFL] : Endif
If !clalev([F:ITMX]): Local File ITMMASTER [ITMX] : Endif
If !clalev([F:MFGX]): Local File MFGHEAD [MFGX] : Endif
Return

$DEBUT
Raz [M:ZAL1]
Raz [M:ZAL0]

# JLPR Asignar Grupo Corte Actual
WLGRCOR=[M:ZMFC0]ZGRPCOR
[M:ZAL0]ZGRPCOR=WLGRCOR
[M:ZAL0]ZSTOFCY=[M:MFG0]MFGFCY
#[M:ZAL0]ZMANDRIL=[M:ZMFC0]ZMANDRIL

If [M:ZMFC3]ITMREF(0)<>"" Then
    # Incializo el Articulo si ya hay material asignado previamente
    [M:ZAL0]ZITMREF=[M:ZMFC3]ITMREF(0)
Else
  # Buscar Otro material asignado en un grupo de corte diferente
  For I = 0 To [M:MFG2]ZNBLOT - 1
     If [M:MFG2]ZLTGRPCOR(I)<>WLGRCOR
       [M:ZAL0]ZITMREF=[M:MFG2]ZLTITMREF(I)
       Break
     Endif
  Next
Endif

# Desactivo introduccion de articulo si hay material asignado previamente
If [M:ZAL0]ZITMREF="" Then : [M:ZAL0]ZITMREF=[M:ZMFC0]ITMREF : Endif
If [M:ZAL0]ZITMREF<>"" Then
   Diszo [M:ZAL0]ZITMREF
#   WTEST=1 # PRIMERA BUSQUEDA
Endif

#JLPR 13.07.16 Sacar ancho del GC
#If [M:ZMFC0]ZANCHO<>0 Then
#    [M:ZAL0]ZANCHOD=[M:ZMFC0]ZANCHO
#    #Diszo [M:ZAL0]ZANCHOD
#Endif
#If WLMINANCHO<>0 Then
#    [M:ZAL0]ZANCHOD=WLMINANCHO
##    Diszo [M:ZAL0]ZANCHOD
#Endif
Local Integer F1
Raz ANCHO_GC
For F1=0 To [M:ZMFC4]NBLIG-1
  If [M:ZMFC4]ZGRPCOR(F1)=  [M:ZAL0]ZGRPCOR
    ANCHO_GC+= [M:ZMFC4]ZANCHO(F1) * [M:ZMFC4]ZNRANCHO(F1)
  Endif
Next
If ANCHO_GC<=0
  ANCHO_GC=[M:ZMFC0]ZANCHO * [M:ZMFC0]ZNRANCHO
Endif
[M:ZAL0]ZANCHOD=ANCHO_GC

Gosub BUSCAR

Affzo [M:ZAL1]
Affzo [M:ZAL0]
Return

$BOUTON
Case BOUT
    When "B" :  Gosub BUSCAR
Endcase
Return

$SETBOUT
Call MOSTRAR_MATERIA_PRIMA_COLOR
Return

$BUSCAR
Local Char WLCRITERIO (250)
Local Char WLCRITERI2 (250)
Local Integer WLNOL : WLNOL = 0
Local Integer WLI, WLLOTUSADO, WLLOTUTILOF
Local Decimal WLQTYSTUASI

Call BORRA_REJILLA

WLCRITERIO="1=1"
If [M:ZAL0]ZITMREF <> "" : WLCRITERIO -= "& (ITMREF = '" + [M:ZAL0]ZITMREF + "')" : Endif
If [M:ZAL0]ZSTOFCY <> "" : WLCRITERIO -= "& (STOFCY = '" + [M:ZAL0]ZSTOFCY + "')" : Endif
If [M:ZAL0]ZANCHOD <> 0  : WLCRITERIO -= "& (ZANCHO >= " + num$([M:ZAL0]ZANCHOD) + ")" : Endif
If [M:ZAL0]ZANCHOH <> 0  : WLCRITERIO -= "& (ZANCHO <= " + num$([M:ZAL0]ZANCHOH) + ")" : Endif
If [M:ZAL0]ZLONGD <> 0   : WLCRITERIO -= "& (ZLONGITUD >= " + num$([M:ZAL0]ZLONGD) + ")" : Endif
If [M:ZAL0]ZLONGH <> 0   : WLCRITERIO -= "& (ZLONGITUD <= " + num$([M:ZAL0]ZLONGH) + ")" : Endif
If [M:ZAL0]ZMANDRIL <> 0 : WLCRITERIO -= "& (ZMANDRIL = " + num$([M:ZAL0]ZMANDRIL) + ")" : Endif

#WLCRITERIO -= "& ((QTYSTU - CUMALLQTY) > 0)"
WLCRITERIO -= "& (CUMALLQTY=0)"  # Si tiene asignacion, es que está en una OF en curso

Raz [F:ITMX]
Read [F:ITMX]ITM0=[M:ZAL0]ZITMREF

#Infbox WLCRITERIO

#######################################################################################################
# JLPR 17_11_16   S/Acuerdo con Tachi                                                                 #
#     - No se mostraran bobinas que ya esten en otras OF en curso !!!                                 #
#     - No se permite declarar produccion PARCIAL de una OF, es decir, que se producen de una sola vez#
#     - Al asignar, habría que controlar que asignara por la cantidad asignada a la OF, pues ahora lo hace mientras quede
#     -    Ej. OF  donde se necesitan 5000                                                            #
#                  1 bob de  3000 se asigna por 1000, pues los otros 2000 estaban en otra OF          #
#                  1 bob de 32000 se asinga por 4000                                                  #
#          Ahora mismo, al asignar dicha OF X3 haria lo siguiente,  asumiendo que la otra OF está sin asignar
#                 - La bobina de  3000 la asignaria por 3000                                          #
#                 - La bobina de 32000 la asignaria por 2000                                          #
#######################################################################################################
Filter [F:STO]
Filter [F:STO] Where  evalue (WLCRITERIO) Order By ZLONGITUD;ZANCHO;LOT;SLO
For [F:STO]
  # Raz [F:STL]
  # Read [F:STL]STL0 = [F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
  # If !fstat Then
      # Buscar Lote  asignada en otra OF
      WLLOTUSADO = 0
      Raz [F:ZMFL]
      Filter [F:ZMFL]
      Filter [F:ZMFL] Where STOFCY=[F:STO]STOFCY and ITMREF=[F:STO]ITMREF and LOT=[F:STO]LOT and SLO=[F:STO]SLO and MFGNUM<>[M:MFG0]MFGNUM
      For [F:ZMFL]
        Read [F:MFGX]MFG0=[F:ZMFL]MFGNUM
        If !fstat and [F:MFGX]MFGTRKFLG<5  #MFGSTA<>4
           # Rechazar stok
           # Existe Lote Pre-asignado y la Orden no está ni asignada, ni cerrada
           WLLOTUSADO = 1
           Break
        Endif
      Next
      Filter [F:ZMFL]
      # No mostrar si ya se asignó a este GC......Tiene sentido cuando estamos modificando
      For WLI=0 To [M:ZMFC3]NBLOT - 1
         If [M:ZMFC3]LOT(WLI)=[F:STO]LOT and [M:ZMFC3]SLO(WLI)=[F:STO]SLO Then
            WLLOTUSADO=1
            Break
         Endif
      Next

      If !WLLOTUSADO  Then

          [M:ZAL1]LOT(WLNOL)=[F:STO]LOT
          [M:ZAL1]SLO(WLNOL)=[F:STO]SLO
          [M:ZAL1]ZANCHO(WLNOL)=[F:STO]ZANCHO
          [M:ZAL1]ZMANDRIL(WLNOL)=[F:STO]ZMANDRIL
          [M:ZAL1]ZLONGITUD(WLNOL)=[F:STO]ZLONGITUD
          [M:ZAL1]ZNCORTES(WLNOL)=[F:STO]ZNCORTES
          [M:ZAL1]ZPROVEEDOR(WLNOL)=[F:STO]ZPROVEEDOR

          # Buscar lotes usados en otros grupos en la propia OF
           [M:ZAL1]ZUSADO(WLNOL)=1
           [M:ZAL1]ZINFGC(WLNOL)=""
           For WLI=0 To [M:MFG2]ZNBLOT - 1
              If [M:MFG2]ZLTITMREF(WLI)=[F:STO]ITMREF &
&                [M:MFG2]ZLTLOT(WLI)=[F:STO]LOT &
&                [M:MFG2]ZLTSLO(WLI)=[F:STO]SLO &
&                [M:MFG2]ZLTGRPCOR(WLI)<>[M:ZMFC0]ZGRPCOR Then
                 [M:ZAL1]ZUSADO(WLNOL)=2
                 [M:ZAL1]ZINFGC(WLNOL)-=num$([M:MFG2]ZLTGRPCOR(WLI))
              Endif
           Next
         # [M:ZAL1]QTYSTU(WLNOL)=([F:STO]QTYSTU - [F:STO]CUMALLQTY)
          [M:ZAL1]QTYSTU(WLNOL)=[F:STO]QTYSTU
          [M:ZAL1]SEL(WLNOL)=1
          [M:ZAL1]STOCOU(WLNOL)= [F:STO]STOCOU
          [M:ZAL1]LOC(WLNOL)= [F:STO]LOC
          [M:ZAL1]STU(WLNOL)= [F:ITMX]STU
          # 09_11_16 JLPR INI
          [M:ZAL1]QTYSTU(WLNOL)   =[F:STO]QTYSTU-[F:STO]CUMALLQTY
          [M:ZAL1]ZLONGITUD(WLNOL)=([F:STO]ZLONGITUD*[M:ZAL1]QTYSTU(WLNOL))/[F:STO]QTYSTU
          WLNOL +=1
          # 09_11_16 JLPR FIN
       Endif
   #Endif
#   If WLNOL=2999
#      Break
#   Endif
Next
Filter [F:STO]
[M:ZAL1]NBLIG=WLNOL
Affzo [M:ZAL1]10
Return

$OK
#If [M:ZAL1]NBLIG<1
#  Infbox "Observe que NO ha seleccionado Materia prima     alguna"
#  Return
#Endif

Local Integer I, WLI, WLNLOT, WNUELOT,F
Local Integer WLLONGASI,WLSUPERFASI

#JLPR  Si ańadimos lineas y luego bobinas, estas se pierden, para resolverlo
#      1ş)  Guardar bobinas en LOTES-PREASIGNADOS  en MFG2 en lugar de ZMFC3
#      2ş)  Llenar ZMFC3 desde MFG2   Call GC_CARGABOBINAS From ZMFCOTRT
WLNLOT=[M:ZMFC3]NBLOT
If [M:ZAL1]ZSELITM<>"" Then

   For WLI = 0 To [M:ZAL1]NBLIG - 1
      If [M:ZAL1]SEL(WLI)=2
         WNUELOT=2
         For I=0 To [M:ZMFC3]NBLOT-1
#            If [M:ZMFC3]STOCOU(I)=[M:ZAL1]STOCOU(WLI)
            If [M:ZMFC3]LOT(I)=[M:ZAL1]LOT(WLI) and [M:ZMFC3]SLO(I)=[M:ZAL1]SLO(WLI)
               WNUELOT=1
            Endif
         Next
      If WNUELOT=2
#            [M:ZMFC3]ITMREF(WLNLOT)=[M:ZAL1]ZSELITM
#            [M:ZMFC3]LOT(WLNLOT)=[M:ZAL1]LOT(WLI)
#            [M:ZMFC3]SLO(WLNLOT)=[M:ZAL1]SLO(WLI)
#            [M:ZMFC3]ZGRPCOR(WLNLOT)=[M:ZMFC0]ZGRPCOR
#            [M:ZMFC3]ZANCHO(WLNLOT)=[M:ZAL1]ZANCHO(WLI)
#            [M:ZMFC3]ZLONGITUD(WLNLOT)=[M:ZAL1]ZLONGITUD(WLI)
#            [M:ZMFC3]ZMANDRIL(WLNLOT)=[M:ZAL1]ZMANDRIL(WLI)
#            [M:ZMFC3]ZPROVEEDOR(WLNLOT)=[M:ZAL1]ZPROVEEDOR(WLI)
#            [M:ZMFC3]ZNCORTES(WLNLOT)=[M:ZAL1]ZNCORTES(WLI)
#            # [M:ZMFC3]ZSTOFCY(WLNLOT)=[M:ZAL0]ZSTOFCY
#            [M:ZMFC3]STOCOU(WLNLOT)=[M:ZAL1]STOCOU(WLI)
#            [M:ZMFC3]LOC(WLNLOT)=[M:ZAL1]LOC(WLI)
#            [M:ZMFC3]QTYSTU(WLNLOT)=[M:ZAL1]QTYSTU(WLI)
#            [M:ZMFC3]ZQTYSTUREAL(WLNLOT)=[M:ZAL1]QTYSTU(WLI)
#            [M:ZMFC3]STU(WLNLOT)=[M:ZAL1]STU(WLI)
#            [M:ZMFC3]NBLOT+=1
#            WLNLOT+=1

            F=[M:MFG2]ZNBLOT
            [M:MFG2]ZLTITMREF(F)=[M:ZAL1]ZSELITM
            [M:MFG2]ZLTLOT(F)=[M:ZAL1]LOT(WLI)
            [M:MFG2]ZLTSLO(F)=[M:ZAL1]SLO(WLI)
            [M:MFG2]ZLTGRPCOR(F)=[M:ZMFC0]ZGRPCOR
            [M:MFG2]ZLTANCHO(F)=[M:ZAL1]ZANCHO(WLI)
            [M:MFG2]ZLTLONGITUD(F)=[M:ZAL1]ZLONGITUD(WLI)
            [M:MFG2]ZLTMANDRIL(F)=[M:ZAL1]ZMANDRIL(WLI)
            [M:MFG2]ZLTPROVEEDOR(F)=[M:ZAL1]ZPROVEEDOR(WLI)
            [M:MFG2]ZLTNCORTES(F)=[M:ZAL1]ZNCORTES(WLI)
            [M:MFG2]ZLTSTOFCY(F)=[M:MFG0]MFGFCY
            [M:MFG2]ZLTSTOCOU(F)=[M:ZAL1]STOCOU(WLI)
            [M:MFG2]ZLTLOC(F)=[M:ZAL1]LOC(WLI)
            [M:MFG2]ZLTQTYSTUASI(F)=[M:ZAL1]QTYSTU(WLI)
            [M:MFG2]ZLTQTYSTUREA(F)=[M:ZAL1]QTYSTU(WLI)
            [M:MFG2]ZLTSTU(F)=[M:ZAL1]STU(WLI)

            # Calculamos cantidades a asignar
            WLLONGASI=[M:ZAL1]ZLONGITUD(WLI)
            WLSUPERFASI=[M:ZAL1]ZANCHO(WLI)*WLLONGASI/1000
            [M:MFG2]ZLTSUPERF(F)=WLSUPERFASI
            If WLSUPERFASI > 0 Then
              [M:MFG2]ZLTFACTOR(F)=[M:ZAL1]QTYSTU(WLI)/WLSUPERFASI
            Else
              [M:MFG2]ZLTFACTOR(F)=1 #[M:ZAL1]QTYSTU(WLI)    JLPR 02-12-16
            Endif
            [M:MFG2]ZLTLONGSOB(F)=0
            [M:MFG2]ZLTSOBRANTE(F)=1
            Call DETERMINAR_SOBRANTE(F)
            [M:MFG2]ZLTSUPERF(F)=WLSUPERFASI
            Call MFG2_LEER_LOTASI_R(F) From SPEMFG2
            [M:MFG2]ZNBLOT+=1
            WLNLOT+=1
         Endif
      Endif
   Next
Endif
Affzo [M:MFG2]15
Call SUMA_QTYREAL From ZMFCOTRT2

#Asginar numero de cortes y proveedor
#Infbox "WLNLOT" + num$(WLNLOT)
If WLNLOT>0
   [M:ZMFC0]ZNCORTES=[M:ZAL1]ZNCORTES(0)+1
   [M:ZMFC0]ZPROVEEDOR=[M:ZAL1]ZPROVEEDOR(0)
Endif
Gosub GC_CARGABOBINAS From ZMFCOTRT
#Infbox "Fin OK"
Return

Subprog DETERMINAR_SOBRANTE(L)
#Por si ańadimos un lote a un grupo de corte nuevo, el cual ya tenia indicado un sobrante
Value Integer L
Local Integer F,SO,LG
SO=1
LG=0
For F=0 To [M:MFG2]ZNBLOT-1
  If F<>L and [M:MFG2]ZLTLOT(F)=[M:MFG2]ZLTLOT(L) and [M:MFG2]ZLTSLO(F)=[M:MFG2]ZLTSLO(L)
    LG=[M:MFG2]ZLTLONGSOB(F)
    SO=[M:MFG2]ZLTSOBRANTE(F)
    Break
  Endif
Next
[M:MFG2]ZLTLONGSOB(L)=LG
[M:MFG2]ZLTSOBRANTE(L)=SO
End

Subprog MOSTRAR_MATERIA_PRIMA_COLOR
Local Integer F
For F=0 To [M:ZAL1]NBLIG-1
#  If [M:ZAL1]QTYSTU(F)<>[M:ZAL1]QTYSTUSTK(F)
  If not func SPEZGOFS.UBICACION_OK([M:ZAL1]LOC(F))
    Chgstl [M:ZAL1]NBLIG(F) With "BACKRED"
  Endif
Next
End


Subprog BORRA_REJILLA
Raz [M:ZAL1]
[M:ZAL1]NBLIG=0
Affzo [M:ZAL1]
End

# Gestión de la máscara ZASILOT1 (Especifico)

######################################################################################
##
######################################################################################
Subprog APRES_NBLIG
Local Integer NOL : NOL = nolign -1
Local Shortint WLI

If [M:ZAL1]ZSELITM = "" and [M:ZAL1]SEL(NOL)=2
 [M:ZAL1]ZSELITM=[M:ZAL0]ZITMREF
 [M:ZAL1]ZSELANCHO=[M:ZAL1]ZANCHO(NOL)
 [M:ZAL1]ZSELMANDRIL=[M:ZAL1]ZMANDRIL(NOL)
 [M:ZAL1]ZSELSTU=[M:ZAL1]STU(NOL)
Endif
[M:ZAL1]ZSELQTYBOB=0
[M:ZAL1]ZSELQTYSTU=0
[M:ZAL1]ZSELSUPERF=0
[M:ZAL1]ZSELLONG=0
For WLI=0 To [M:ZAL1]NBLIG - 1
   If  [M:ZAL1]SEL(WLI)=2   Then
      [M:ZAL1]ZSELQTYBOB += 1
      [M:ZAL1]ZSELQTYSTU += [M:ZAL1]QTYSTU(WLI)
      [M:ZAL1]ZSELSUPERF += ([M:ZAL1]ZLONGITUD(NOL)*[M:ZAL1]ZANCHO(NOL) / 1000)
      [M:ZAL1]ZSELLONG   += [M:ZAL1]ZLONGITUD(NOL)
    Endif
Next
If [M:ZAL1]ZSELQTYBOB=0
   [M:ZAL1]ZSELITM=""
   [M:ZAL1]ZSELANCHO=0
   [M:ZAL1]ZSELMANDRIL=0
   [M:ZAL1]ZSELSTU=""
Endif
Affzo [M:ZAL1]5
End

Subprog AM_SEL(VALEUR)
Variable Integer VALEUR
Local Char MSG(255)
Local Integer F
F=nolign-1
If VALEUR=2 and not func SPEZGOFS.UBICACION_OK([M:ZAL1]LOC(F))
    MSG="Recuerde que no se permite seleccionar Materia prima de la ubiacion "+[M:ZAL1]LOC(F)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    VALEUR=1
Endif
End

Subprog AS_SEL(VALEUR)
Variable Integer VALEUR

Local Integer NOL : NOL = nolign -1
#If [M:ZAL1]ZSELITM <> "" & ([M:ZAL1]ZSELANCHO<>[M:ZAL1]ZANCHO(NOL)
#& | [M:ZAL1]ZSELMANDRIL<>[M:ZAL1]ZMANDRIL(NOL)) Then
#   VALEUR=1
#   mkstat = 2
#Endif
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASILOT0) 17/05/2016 19:31:25 (ADMIN)
######################################################################################
Subprog AP_ZANCHOD(VALEUR)
Variable Decimal VALEUR
#If VALEUR>[M:ZAL0]ZANCHOH:[M:ZAL0]ZANCHOH=VALEUR:Endif
End

Subprog AP_ZLONGD(VALEUR)
Variable Decimal VALEUR
If VALEUR>[M:ZAL0]ZLONGH:[M:ZAL0]ZLONGH=VALEUR:Endif
End


######################################################################################
