#<AdxTL>@(#)0.0.0.0 $Revision$
# ZPLN - Consulta planificacion

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
# When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "LIS"          : Gosub LIS
# When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$LIS
Call PRTSCR("ZCNSPLN0","","",0,0) From ATRTX3 : # <MG> 01/03/00
Call IMPSCR From ATRTX3                   : # <MG> 01/03/00
Return

$DEBUT
Raz [M:ZCPLN0]
[M:ZCPLN0]MFGFCY=GFCYDEF(0)
Affzo [M:ZCPLN0]
Return

$OUVRE
If !clalev([F:MFG])  : Local File MFGHEAD    [MFG] : Endif
If !clalev([F:SCH])  : Local File SCHEDULING [SCH] : Endif
If !clalev([F:MFO])  : Local File MFGOPE     [MFO] : Endif
If !clalev([F:MFI])  : Local File MFGITM     [MFI] : Endif
If !clalev([F:ZMSQ]) : Local File ZMFGSOQ    [ZMSQ] : Endif
If !clalev([F:SOH])  : Local File SORDER     [SOH] : Endif
If !clalev([F:SOQ])  : Local File SORDERQ    [SOQ] : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC] : Endif
Return

$BOUTON
Case BOUT
    When "B" :  Gosub BUSCAR
Endcase
Return

$BUSCAR
Local Char LHOUC1(5), WENDHHMI(4)
Local Char WLCRITERIO (250)
Local Char WLCRITERIO1 (250)
Local Integer WLABCCLS, WLNOL
Local Integer LMFGFLG

#LMFGFLG: Flag para gestionar colores en el grid
#LMFGFLG: 1->Ningun aviso por colores
#         2->Pedido fuera de plazo - rojo
#         3->Saldada - en verde si usuario "ACAMP" -> No utilizado
#         4->No planificada

WLNOL = 0

Raz [M:ZCPLN0]NBLIG
Effzo [M:ZCPLN0]10

WLCRITERIO="1=1"
If [M:ZCPLN0]MFGFCY <> "" : WLCRITERIO -= "& MFGFCY=[M:ZCPLN0]MFGFCY" : Endif
If [M:ZCPLN0]FECSTR <> [0/0/0] : WLCRITERIO -= "& ((STRDAT>=[M:ZCPLN0]FECSTR & STRDAT<=[M:ZCPLN0]FECEND)" : Endif
If [M:ZCPLN0]FECEND <> [0/0/0] : WLCRITERIO -= "| (ENDDAT>=[M:ZCPLN0]FECSTR & ENDDAT<=[M:ZCPLN0]FECEND))" : Endif
If [M:ZCPLN0]WSTSTR <> "" :  WLCRITERIO -= "& [MFO]EXTWST>=[M:ZCPLN0]WSTSTR" : Endif
If [M:ZCPLN0]WSTEND <> "" :  WLCRITERIO -= "& [MFO]EXTWST<=[M:ZCPLN0]WSTEND" : Endif

WLCRITERIO -= "& [MFG]SCDFLG<>1"

If [M:ZCPLN0]MFGSTR<>""
   WLCRITERIO -= "& [MFG]MFGNUM=[M:ZCPLN0]MFGSTR"
Endif
If [M:ZCPLN0]SOHSTR<>"" or [M:ZCPLN0]BPCSTR<>""
   If [M:ZCPLN0]SOHSTR<>""
      WLCRITERIO -= "& [ZMSQ]SOHNUM=[M:ZCPLN0]SOHSTR"
   Endif
   If [M:ZCPLN0]BPCSTR<>""
      WLCRITERIO -= "& [SOH]BPCORD=[M:ZCPLN0]BPCSTR"
   Endif
   Link [MFG] With [MFO]MFO0=[F:MFG]MFGNUM;5,[ZMSQ]ZMSQ0(1)=[F:MFG]MFGNUM,[SOH]SOH0=[F:ZMSQ]SOHNUM,[BPC]BPC0=[F:SOH]BPCORD As [LNK]
Else
   Link [MFG] With [MFO]MFO0=[F:MFG]MFGNUM;5 As [LNK]
Endif

Filter [LNK] Where evalue(WLCRITERIO)
For [LNK]
   [M:ZCPLN0]MFGFLG(WLNOL)=1 : #Ningun aviso por colores
   If [M:ZCPLN0]FILAGR=2
      #Si solamente se quieren ver las OF's fuera de plazo
      Filter [ZMSQ] Where MFGNUM=[F:MFG]MFGNUM
      For [ZMSQ]
         Raz [F:SOH]
         Read [SOH]SOH0=[F:ZMSQ]SOHNUM
         Raz [F:SOQ]
         Read [SOQ]SOQ0=[F:SOH]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
         If [F:SOQ]SHIDAT<[F:MFG]ENDDAT or ([F:SOQ]SHIDAT<[F:MFG]ENDDAT and [M:ZCPLN0]ENDHOR(WLNOL)>"15:00")
            #Si la fecha de expedicion es menor a la de planficacion o la fecha es igual pero la hora de fin
            #es a partir de las 15:00 se considera en retraso
            [M:ZCPLN0]MFGFLG(WLNOL)=2 :#Retraso
         Endif
      Next
      Filter [ZMSQ]
      If [M:ZCPLN0]MFGFLG(WLNOL)<>2
         Goto $NEXTOF
      Endif
   Endif

   Raz [F:MFO]
   Filter [MFO] Where MFGNUM=[F:MFG]MFGNUM
   Read [MFO] First
   Filter [MFO]

   Raz [F:MFI]
   Filter [MFI] Where MFGNUM=[F:MFG]MFGNUM
   Read [MFI] First
   Filter [MFI]

   Raz [F:SCH]
   Read [SCH]SCH0=[F:MFG]MFGNUM;[F:MFO]OPENUM;0

   Call CONVHOU1([F:MFO]FRCSTRHOU,LHOUC1) From ZTRTCNSPLN

   [M:ZCPLN0]MFGNUM(WLNOL)=[F:MFG]MFGNUM
   [M:ZCPLN0]STRDAT(WLNOL)=[F:MFG]STRDAT
   [M:ZCPLN0]STRHOR(WLNOL)=LHOUC1
   [M:ZCPLN0]ENDDAT(WLNOL)=[F:MFG]ENDDAT
   [M:ZCPLN0]EXTWST(WLNOL)=[F:MFO]EXTWST
   [M:ZCPLN0]ITMREF(WLNOL)=[F:MFI]ITMREF

   #Llamda copiada de FUNGROU (Visualizacion grafica del escalonamiento de una OF)
   Call OPETIME([F:MFG]MFGFCY, [F:MFO]EXTWST, [F:MFG]ENDDAT, [F:SCH]OPEENDFRD, WENDHHMI) From JALLIBB
   Call CONVHOU1(WENDHHMI,LHOUC1) From ZTRTCNSPLN
   [M:ZCPLN0]ENDHOR(WLNOL)=LHOUC1

   Filter [ZMSQ] Where MFGNUM=[F:MFG]MFGNUM
   [M:ZCPLN0]PEDIDOS(WLNOL)=""
   Raz WLABCCLS
   For [ZMSQ]
      Raz [F:SOH]
      Read [SOH]SOH0=[F:ZMSQ]SOHNUM
      Raz [F:SOQ]
      Read [SOQ]SOQ0=[F:SOH]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
      If [F:SOQ]SHIDAT<[F:MFG]ENDDAT or ([F:SOQ]SHIDAT<[F:MFG]ENDDAT and [M:ZCPLN0]ENDHOR(WLNOL)>"15:00")
         #Si la fecha de expedicion es menor a la de planficacion o la fecha es igual pero la hora de fin
         #es a partir de las 15:00 se considera en retraso
         [M:ZCPLN0]MFGFLG(WLNOL)=2 :#Retraso
      Endif

      If [F:MFG]MFGTRKFLG>4
         #[M:ZCPLN0]MFGFLG(WLNOL)=3 :#Saldada
      Endif

      Raz [F:BPC]
      Read [BPC]BPC0=[F:SOH]BPCORD
      If [F:BPC]ABCCLS=1
         WLABCCLS=1
      Endif
      [M:ZCPLN0]PEDIDOS(WLNOL)-=mid$([F:ZMSQ]SOHNUM,7,len([F:ZMSQ]SOHNUM)-6)+"-"+format$("D:DDMMYY",[F:SOH]SHIDAT)+"-"+
&                               format$("D:DDMMYY",[F:SOH]DEMDLVDAT)+"-"+mid$([F:BPC]BPCNAM,1,20)+"/"
      [M:ZCPLN0]ABCCLS(WLNOL)=WLABCCLS
   Next
   If [F:MFO]FRCSTRHOU="" and [M:ZCPLN0]MFGFLG(WLNOL)<>2
      #Si no tiene hora de comienzo no se muestra, probablemente ha sido escalonada pero no planificada
      #Goto $NEXTOF
      [M:ZCPLN0]MFGFLG(WLNOL)=4 :#Sin hora de inicio
   Endif

   Filter [ZMSQ]
   WLNOL+=1
$NEXTOF
Next
Filter [MFG]
[M:ZCPLN0]NBLIG=WLNOL

If WLNOL>0
   Sorta [M:ZCPLN0]NBLIG [M:ZCPLN0]NBLIG Order By [M:ZCPLN0]EXTWST(indice),[M:ZCPLN0]STRDAT(indice),[M:ZCPLN0]STRHOR(indice)
   Affzo [M:ZCPLN0]10
   Call APLICA_COLOR()
Endif
Return

Subprog APLICA_COLOR()
Local Integer LI

For LI=0 To [M:ZCPLN0]NBLIG
   If [M:ZCPLN0]MFGFLG(LI)=3
      #Puesto a piñon, aunque convendria parametrizar de alguna forma. Mostraria en verde las saldadas
      #Chgstl [M:ZCPLN0]NBLIG(LI) With "APARPLAG"
   Endif
   If [M:ZCPLN0]MFGFLG(LI)=2
      Chgstl [M:ZCPLN0]NBLIG(LI) With "BACKRED"
   Endif
   If [M:ZCPLN0]MFGFLG(LI)=4
      Chgstl [M:ZCPLN0]NBLIG(LI) With "AERROR"
   Endif
   If [M:ZCPLN0]MFGFLG(LI)=1
      Chgstl [M:ZCPLN0]NBLIG(LI) With ""
   Endif
Next
Affzo [M:ZCPLN0]10
End

#########################################################################
# Transformation HHMM en HH:MM
# 06.06 31012
#   LHOUC   = HHMM en caractères
#   LHOUC2  = HH:MM en caractères
#
#FJCG - Copiado de JALLIBB
Subprog CONVHOU1(LHOUC,LHOUC1)
#
Value     Char        LHOUC
Variable  Char        LHOUC1
#
Local Char    HH(2)
Local Char    MM(2)
Local Integer ND
Local Decimal HEURE
Local Decimal MINUTE

#
HH = mid$(LHOUC,1,2)
ND = 3
MM = mid$(LHOUC,ND,2)
HEURE = val(HH)
MINUTE = val(MM)

LHOUC1 = format$("N0:2#",HEURE)+":"+format$("N0:2#",MINUTE)
End
######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZCNSPLN0) 12/11/2016 19:56:13 (ADMIN)
######################################################################################
Subprog AM_FECSTR(VALEUR)
Variable Date    VALEUR
If [M]FECEND = [0/0/0]     : [M]FECEND = VALEUR : Affzo [M]FECEND : Endif
If [M]FECEND < VALEUR : [M]FECEND = VALEUR : Affzo [M]FECEND : Endif
End

Subprog AM_WSTSTR(VALEUR)
Variable Char    VALEUR()
If [M]WSTEND = ""     : [M]WSTEND = VALEUR : Affzo [M]WSTEND : Endif
If [M]WSTEND < VALEUR : [M]WSTEND = VALEUR : Affzo [M]WSTEND : Endif
End


######################################################################################
