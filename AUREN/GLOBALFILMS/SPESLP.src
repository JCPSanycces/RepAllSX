#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
If dim([M:SLP]ZENDDAT)>0
#Infbox ACTION + "/"+ [M:SLP]ZENDDAT
Endif
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "AV_CHOIX"    : Gosub AV_CHOIX
Endcase
Return

#Z0001.ini
$AV_CHOIX
Gosub GRUPOCORTE
Call APLICAR_COLOR
Return
#Z0001.fin

$DEBUT
Onerrgo ERRORES_FIN
Raz [M:SLP]ZENDDAT,[M:SLP]ZTRATEXT,[M:SLP]ZTRATINT
Affzo [M:SLP]ZENDDAT
Affzo [M:SLP]ZTRATEXT
Affzo [M:SLP]ZTRATINT
# Si nos pasan un nŗ de OF
If PARAM(2)="10" and PARAM(3)<>"" and GACTION="STKLBEIMP"
  # Sacar del articulo datos de TRAT Ext TSICOD_2 e INT TSICOD_3. En una OF NO SE PUEDEN MEZCLAR articulos
  Call MOSTRAR_CAMPOS(val(PARAM(2)))
  Call AM_VCRNUMSTR(PARAM(3))
Else
  Call MOSTRAR_CAMPOS(val(PARAM(2)))
Endif
[M:SLP]ZETIQ=1
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
Onerrgo
Return

$OUVRE
# Se utilizan en los puntos de entrada del fuente ZPESUBSLPB.src
If clalev([F:SOH]) <=0 : Local File SORDER     [F:SOH]  : Endif
If clalev([F:ZMSQ])<=0 : Local File ZMFGSOQ    [F:ZMSQ] : Endif
If clalev([F:ZMFL])<=0 : Local File ZMFGLOT    [F:ZMFL] : Endif
If clalev([F:SOHX])<=0 : Local File SORDER     [F:SOHX] : Endif
If clalev([F:BPC]) <=0 : Local File BPCUSTOMER [F:BPC]  : Endif
Local Char BD_TIPO(1)
Local Char ART(GLONITM)
Local Integer MOSTRAR : MOSTRAR=1
Return

$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
If not(COUZON="NBLIG" or COUZON="ZBPCLOGO"  or COUZON="ZFECPROD" or COUZON="TRT" or COUZON="LBENBR" or COUZON="LBEFMT" or COUZON="PRT" or COUZON="ZTIPETI" or COUZON="ZTRATINTR"  or COUZON="ZTRATEXTR"
& or ((COUZON="ZSOHNUM"
& or COUZON="ZBPCF" or COUZON="ZANCHOF" or
& COUZON="ZLARGO" or COUZON="ZETIQ") and [M:SLP]NBLIG>0))
  Raz [M:SLP]NBLIG
  Effzo [M:SLP]15
  MOSTRAR=1
Endif
Return

$SETBOUT
# Para que solo lo haga cuando venga de Ordenes de fabricacion o cambiemos el nŗ de OF a mostrar
If MOSTRAR and [M:SLP]NBLIG>0
  Call ASIGNAR_LOTE
  Call ANADIR_SOBRANTE(BD_TIPO)
  Call APLICAR
  MOSTRAR=0
Else
  Call APLICAR_COLOR
Endif
Return

$BOUTON
If BOUT="1"
  MOSTRAR=1
Endif

Return

Subprog ANADIR_SOBRANTE(BD_TIPO)
Value Char BD_TIPO
#Ańadir un registro por cada sobrante que tengamos
Local Integer F
Local Char TXT(255)(3),OF(GLONVCR)
OF=[M:SLP]VCRNUM(0)
If OF=""  :   End  :  Endif
TXT(0)="select distinct st.LOT_0,st.SLO_0,ZLOTORI_0,st.ZANCHO_0,ZLONGSOB_0,st.ZMANDRIL_0,QTYSTUASI_0 /(st.ZANCHO_0*st.ZLONGITUD_0/1000) as factor "
TXT(1)="from ZMFGLOT zl inner join STOCK st on zl.STOCOU_0=st.STOCOU_0 "
TXT(2)="where MFGNUM_0='"+OF+"' and ZLONGSOB_0>0"
For(Char FLOT(GLONLOT),Char FSLOT(GLONSLO),Char FLOTORI(GLONLOT),Integer FANCHO,Integer FLONGSOB,Integer FMANDIRL,Decimal FFACTOR) From BD_TIPO Sql TXT As [MYT]
  F = [M:SLP]NBLIG
  [M:SLP]LBENBR(F)   = 1
  [M:SLP]ZFECPROD(F) = [M:SLP]ZENDDAT
  [M:SLP]ZTRATINTR(F)= [M:SLP]ZTRATINTR(F-1)
  [M:SLP]ZTRATEXTR(F)= [M:SLP]ZTRATEXTR(F-1)
  [M:SLP]ITMREF(F)   = [M:SLP]ITMREF(F-1)
  [M:SLP]ZLOTPT(F)   = FLOT
  [M:SLP]ZLOT(F)     = FLOT
  [M:SLP]ZSLOT(F)    = FSLOT
  [M:SLP]ZLOTORI(F)  = FLOTORI
  [M:SLP]ZNBLIG(F)   = F
  [M:SLP]TRT(F)      = [M:SLP]TRT(F-1)
  [M:SLP]ZTRT(F)     = [M:SLP]ZTRT(F-1)
  [M:SLP]TRSTYP(F)   = [M:SLP]TRSTYP(F-1)
  [M:SLP]VCRNUM(F)   = [M:SLP]VCRNUM(F-1)
  [M:SLP]VCRLIN(F)   = [M:SLP]VCRLIN(F-1)
  [M:SLP]ITMREF(F)   = [M:SLP]ITMREF(F-1)
  [M:SLP]ZGRPCOR(F)  = -1
  [M:SLP]ZANCHO(F)   = FANCHO
  [M:SLP]ZLONGITUD(F)= FLONGSOB
  [M:SLP]ZMANDRIL(F) = FMANDIRL
  [M:SLP]QTYSTU(F)   = (FANCHO*FLONGSOB/1000)*FFACTOR
  [M:SLP]STU(F)      = [M:SLP]STU(F-1)
  [M:SLP]PCU(F)      = [M:SLP]PCU(F-1)
  [M:SLP]ZBPCLOGO(F) = 2
  [M:SLP]LBEFMT(F)   = [M:SLP]LBEFMT(F-1)
  [M:SLP]PRT(F)      = [M:SLP]PRT(F-1)
  [M:SLP]SERIMP(F)   = [M:SLP]SERIMP(F-1)
  [M:SLP]DEFIMP(F)   = [M:SLP]DEFIMP(F-1)
  [M:SLP]PRTDRV(F)   = [M:SLP]PRTDRV(F-1)
  [M:SLP]PRTPOR(F)   = [M:SLP]PRTPOR(F-1)
  [M:SLP]PRTDES(F)   = [M:SLP]PRTDES(F-1)
  [M:SLP]TYPIMP(F)   = [M:SLP]TYPIMP(F-1)
  [M:SLP]NBLIG+=1
Next
Affzo [M:SLP]15
End

Subprog ASIGNAR_LOTE
If [M:SLP]LBEVCRTYP<>10
  End
Endif
# Variables para contador lote. Se asume que:
#    - No se hacen producciones parciales, es decir, que las OF se hacen completas
#    - CONTADOR_LOT se inicializa al cambiar de  OF
#    - Como no se ordena por NŗAsiento en standar haré:
#            - Lleno rejilla
#            - Ordeno por Nŗ Asiento + Nŗ lŖ
#            - Asigno Lote, para que coincida con el de X3 cuando se cierre OF
Local Integer F,C
Local Char ROF(GLONVCR),LOT(GLONLOT)
Raz C,ROF
# Se ordena por NŗAsiento + NŗLinea
#Z0001.ini
#Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]VCRNUM(indice),[M:SLP]VCRLIN(indice)
#Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]VCRNUM(indice),[M:SLP]VCRLIN(indice),[M:SLP]ZGRPCOR(indice) Asc
Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]VCRNUM(indice),[M:SLP]VCRLIN(indice),[M:SLP]ZGRPCOR(indice),[M:SLP]ZLOT(indice),[M:SLP]ZSLOT(indice) Asc
# Asigno Lote
If [M:SLP]STOFCY <> "100" #Z0001
  For F=0 To [M:SLP]NBLIG-1
    If ROF<>[M:SLP]VCRNUM(F)
      ROF=[M:SLP]VCRNUM(F)
      Call CONV_NUMOF_LOTE(ROF,LOT) From ZPESUBANM
      Raz C
    Endif
    C+=1
    If [M:SLP]ZMONOLOTE(F)=2
      [M:SLP]ZLOTPT(F)=LOT
    Else
      [M:SLP]ZLOTPT(F)=LOT+format$("N0:3",C)
    Endif
  Next
Else #Z0001
  For F=0 To [M:SLP]NBLIG-1
    If ROF<>[M:SLP]VCRNUM(F)
      ROF=[M:SLP]VCRNUM(F)
      Call CONV_NUMOF_LOTE(ROF,LOT) From ZPESUBANM
      Raz C
    Endif
    C+=1
    If [M:SLP]ZMONOLOTE(F)=2
      [M:SLP]ZLOTPT(F)=LOT
    Endif
  Next

  If GFONCTION="GESMFG"
    Local Integer TMPGC,TLEN,TSLO : Raz TMPGC,TLEN,TSLO
    Local Char TMPLOT(30),TMPSLO(5) : Raz TMPLOT,TMPSLO
    If !clalev([F:ZTMPSLO])  : Local File ZTMPSLO    [ZTMPSLO] : Endif
    If !clalev([F:STK2])  : Local File STOCK    [STK2] : Endif
    Local Integer PRESLO: Raz PRESLO
    Filter [F:ZTMPSLO] Where [F:ZTMPSLO]MFGNUM=[M:MFG0]MFGNUM
    Read [F:ZTMPSLO] First
    If !fstat
      For F=0 To [M:SLP]NBLIG-1
        If [M:SLP]ZMONOLOTE(F)<>2
          Read [F:ZTMPSLO]ZTMPSLO=[M:SLP]VCRNUM(F);F
          If !fstat
            [M:SLP]ZLOTPT(F)=[F:ZTMPSLO]LOT
            [M:SLP]ZSLOPT(F)=[F:ZTMPSLO]SLO
          Endif
        Endif
      Next
    Else
      For F=0 To [M:SLP]NBLIG-1
        If [M:SLP]ZMONOLOTE(F)<>2
          If TMPGC<>[M:SLP]ZGRPCOR(F)
            If F>0
              Raz PRESLO
              For I = 0 To F-1
                If I <> F
                  If [M:SLP]ZLOT(I)=[M:SLP]ZLOT(F)
                    PRESLO+=1
                  Endif
                Endif
              Next
            Endif

            Filter [F:STK2] Where [F:STK2]LOT=[M:SLP]ZLOT(F) and [F:STK2]STOFCY=[M:SLP]STOFCY  and [F:STK2]ITMREF=[M:SLP]ITMREF(F) Order By [F:STK2]SLO Desc
            Read [F:STK2] First
            If !fstat
              TMPSLO=[F:STK2]SLO
            Else
              Errbox "No se pudo obtener Sub-Lote"
              Filter [F:STK2]
              Break
            Endif
            Filter [F:STK2]

            TMPGC=[M:SLP]ZGRPCOR(F)
            TMPLOT=[M:SLP]ZLOT(F)
            #TMPSLO=[M:SLP]ZSLOT(F)
            TLEN=len(TMPSLO)
            Raz C

          Endif
          C+=1
          [M:SLP]ZLOTPT(F)=TMPLOT
          TSLO=val(TMPSLO)+C+PRESLO
          [M:SLP]ZSLOPT(F)=format$("N0:"+num$(TLEN),TSLO)
        Endif
      Next
      For F=0 To [M:SLP]NBLIG-1
        If [M:SLP]ZMONOLOTE(F)<>2
          If [M:SLP]VCRNUM(F)<>"" and [M:SLP]VCRLIN(F)<>0 and [M:SLP]ZLOTPT(F)<>"" and [M:SLP]ZSLOPT(F)<>""
            Raz [F:ZTMPSLO]
            [F:ZTMPSLO]MFGNUM=[M:SLP]VCRNUM(F)
            [F:ZTMPSLO]MFGLIN=[M:SLP]VCRLIN(F)
            [F:ZTMPSLO]LOT=[M:SLP]ZLOTPT(F)
            [F:ZTMPSLO]SLO=[M:SLP]ZSLOPT(F)
            [F:ZTMPSLO]SLOORI=[M:SLP]ZSLOT(F)
            [F:ZTMPSLO]ITMREF=[M:SLP]ITMREF(F)
            [F:ZTMPSLO]NBLIN=F
            Write [F:ZTMPSLO]
            If fstat
              Call FSTA("ZTMPSLO") From GLOCK
            Endif
          Endif
        Endif
      Next
    Endif
  Endif
#Z0001.fin
Endif
End


#Esta funcion deberia devolver tambien como parametros de salida ZLOTORI
Subprog LOTE_ORIGEN(MFGNUM_P,MFGLIN_P,FCY,STOCOU_P,LOT,SLOT,LOTORI)
Value Char MFGNUM_P,FCY
Value Integer MFGLIN_P
Value Decimal STOCOU_P
Variable Char LOT,SLOT,LOTORI
# Saco lotes y sublotes del GC...puede haber mas de uno por los empalmes....Mostramos el 1ŗ
Raz LOT,SLOT,LOTORI
If clalev([F:ZMFI])<=0 : Local File MFGITM     [F:ZMFI] : Endif
If clalev([F:ZMFL])<=0 : Local File ZMFGLOT    [F:ZMFL] : Endif

#If STOCOU_P>0
#  Filter [F:ZMFL] Where STOFCY=FCY and STOCOU=STOCOU_P and MFGNUM=MFGNUM_P
#  For [F:ZMFL]
#    LOT =[F:ZMFL]LOT
#    SLOT=[F:ZMFL]SLO
#    LOTORI=func ZPESTKLIB.LOTEORIGEN_BOBINAMADRE(FCY,[F:ZMFI]ITMREF,LOT)
#    Break
#  Next
#  Filter [F:ZMFL]
#Endif
#If LOT=""
  # Saco GC de linea OF
  Filter [F:ZMFI] Where MFGNUM=MFGNUM_P and MFGLIN=MFGLIN_P and MFGFCY=FCY
  For [F:ZMFI]
    # Saco Lote origen
    Filter [F:ZMFL] Where MFGNUM=MFGNUM_P and ZGRPCOR=[F:ZMFI]ZGRPCOR and STOFCY=FCY Order By LOT;SLO
    For [F:ZMFL]
      LOT =[F:ZMFL]LOT
      SLOT=[F:ZMFL]SLO
      LOTORI=func ZPESTKLIB.LOTEORIGEN_BOBINAMADRE(FCY,[F:ZMFI]ITMREF,LOT)
      Break
    Next
    Filter [F:ZMFL]
    Break
  Next
  Filter [F:ZMFI]
#Endif
End

Subprog APLICAR
If [M:SLP]NBLIG>0
  Call APLICAR_FILTROS
  Call APLICAR_ORDENAR
  Call APLICAR_COLOR
Endif
End

Subprog APLICAR_FILTROS
Local Integer F,OK
# Por defecto todo SI, pero si hay filtros adicionales solo los que lo cumplan
For F=0 To [M:SLP]NBLIG-1
  OK=1
  If  OK and   [M:SLP]ZSOHNUM<>"" and  [M:SLP]ZSOHNUM<>[M:SLP]ZSOH(F)
    OK=0
  Endif
  If  OK and   [M:SLP]ZBPCF<>""   and  [M:SLP]ZBPCF<>[M:SLP]ZBPC(F)
    OK=0
  Endif
  If  OK and   [M:SLP]ZANCHOF>0   and  [M:SLP]ZANCHOF<>[M:SLP]ZANCHO(F)
    OK=0
  Endif
  If  OK and   [M:SLP]ZLARGO>0    and  [M:SLP]ZLARGO<>[M:SLP]ZLONGITUD(F)
    OK=0
  Endif
  If  OK and   [M:SLP]ZETIQ=2     and  [M:SLP]ZBPC(F)=""  # 2=Solo clientes
    OK=0
  Endif
  If  OK and   [M:SLP]ZETIQ=3     and  [M:SLP]ZBPC(F)<>"" # 3=Solo stock
    OK=0
  Endif
  If not OK
    [M:SLP]TRT(F)=1
    [M:SLP]ZTRT(F)=2
  Else
    [M:SLP]TRT(F)=2
    [M:SLP]ZTRT(F)=1
  Endif
Next
End

Subprog APLICAR_ORDENAR
# Ordenar rejilla, para facilitar saber lo que se imprimirį, por si el usuario deseata desmarcar algo
If [M:SLP]ZSOHNUM<>""
  Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]ZTRT(indice),[M:SLP]ZSOH(indice),[M:SLP]ZLOTPT(indice),[M:SLP]ZNBLIG(indice)
Elsif [M:SLP]ZBPCF<>""
  Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]ZTRT(indice),[M:SLP]ZBPC(indice),[M:SLP]ZSOH(indice),[M:SLP]ZLOTPT(indice),[M:SLP]ZNBLIG(indice)
Else
  #Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]ZTRT(indice),[M:SLP]ZLOTPT(indice),[M:SLP]ZNBLIG(indice) #Z0001
  Sorta [M:SLP]NBLIG [M:SLP]NBLIG Order By [M:SLP]VCRNUM(indice),[M:SLP]ZGRPCOR(indice),[M:SLP]ZLOT(indice),[M:SLP]ZSLOT(indice),[M:SLP]ZSLOPT(indice) Asc #Z0001
Endif
Affzo [M:SLP]15
End

Subprog APLICAR_COLOR
Local Integer F
For F=0 To [M:SLP]NBLIG-1
  If [M:SLP]TRT(F)=1
    Chgstl [M:SLP]NBLIG(F) With ""
  Else
    Chgstl [M:SLP]NBLIG(F) With "BACKGREEN"
  Endif
Next
End


Funprog CTE_PED(PED,CTEPED,PEDLIN,PEDSEQ)
Value Char PED
Value Integer PEDLIN,PEDSEQ
Variable Char CTEPED

Local Integer F,Q
Local Char CTE(GLONBPC)
Raz CTE,CTEPED,Q
If clalev([F:SOH])<=0  : Local File SORDER  [F:SOH]  : Endif
Filter [F:SOH] Where SOHNUM=PED
Read [F:SOH] First
If fstat=0
  CTE   =[F:SOH]BPCORD
  CTEPED=[F:SOH]CUSORDREF
Else
  For F=0 To [M:SLP]NBLIG-1
    If [M:SLP]ZSOH(F)=PED
      Q+=1
    Endif
  Next
  If Q<1
    Infbox "No se encontró pedido " + PED + "  (Funprog CTE_PED(PED,CTEPED,PEDLIN,PEDSEQ)  ZPESUBSLPB.src"
  Endif
Endif
Filter [F:SOH]
#Coger valor de haberlo en SORDERQ.ZCUSORDREF
If Q<1
  If clalev([F:SOQ])<=0  : Local File SORDERQ [F:SOQ]  : Endif
  Filter [F:SOQ] Where SOHNUM=PED and SOPLIN=PEDLIN and SOQSEQ=PEDSEQ
  Read [F:SOQ] First
  If fstat=0
    If [F:SOQ]ZCUSORDREF<>""
      CTEPED=[F:SOQ]ZCUSORDREF
    Endif
  Else
    Infbox "No se encontró linea " + num$(PEDLIN) +"  pedido " + PED + "    (Funprog CTE_PED(PED,CTEPED,PEDLIN,PEDSEQ)  ZPESUBSLPB.src"
  Endif
  Filter [F:SOQ]
Endif
End CTE

Funprog CTE_REF(ART,CTE,ANC,CTEREFDES)
Value Char ART,CTE
Value Integer ANC
Variable Char CTEREFDES
Local Char CTEREF(40)
Raz CTEREF,CTEREFDES
If ART<>"" and CTE<>""
  If clalev([F:ZBPCRD])<=0  : Local File ZBPCREFD [F:ZBPCRD]  : Endif
  #If clalev([F:ITU])<=0  : Local File ITMBPC [F:ITU]  : Endif
  #Read [F:ITU]ITU0=ART;CTE
  #If fstat=0
  #  CTEREF   =[F:ITU]ITMREFBPC
  #  CTEREFDES=[F:ITU]ITMDESBPC
  #Endif
  # 1ŗ) Sacar datos de   ZBPCREFD [F:ZBPCRD]
  Filter [F:ZBPCRD] Where BPCNUM=CTE and ITMREF=ART and ANCHO=ANC
  Read [F:ZBPCRD] First
  If fstat=0
    CTEREF   =[F:ZBPCRD]REFBPC
    CTEREFDES=[F:ZBPCRD]DESREFBPC
  Endif
  Filter [F:ZBPCRD]
  # 2ŗ) Si faltan datos, sacarlos de ZBPCREFH [F:ZBPCRH]
  If CTEREF="" or CTEREFDES=""
    If clalev([F:ZBPCRH])<=0  : Local File ZBPCREFH [F:ZBPCRH]  : Endif
    Filter [F:ZBPCRH] Where BPCNUM=CTE and ITMREF=ART
    Read [F:ZBPCRH] First
    If fstat=0
      If CTEREF=""
        CTEREF   =[F:ZBPCRH]REFBPC
      Endif
      If CTEREFDES=""
        CTEREFDES=[F:ZBPCRH]DESREFBPC
      Endif
    Endif
    Filter [F:ZBPCRH]
  Endif
Endif
End CTEREF

Funprog INFORME(DEST,SRV,NAM)
Variable Char DEST,SRV,NAM
Raz DEST
Local Char INF(GLONARP)
Raz INF
Case [M:SLP]LBEVCRTYP
When 10
#  If [M:SLP]ZTIPETI<=1
#    INF="ZETIDPBOLSAOF"
#  Else
#    INF="ZETIDPCAJAOF"
#  Endif
  If [M:SLP]ZTIPETI<=1 and [M:SLP]STOFCY='200'
    INF="ZETIDPBOLSAOF"
  Elsif [M:SLP]ZTIPETI<=1 and [M:SLP]STOFCY='100'
    INF="ZETIDPBOLSAOFGF"
  Elsif [M:SLP]ZTIPETI>1 and [M:SLP]STOFCY='200'
    INF="ZETIDPCAJAOF"
  Elsif [M:SLP]ZTIPETI>1 and [M:SLP]STOFCY='100'
    INF="ZETIDPCAJAOFGF"
  Endif
When 15
  If [M:SLP]ZTIPETI<=1
    INF="ZETIDPBOLSA"
  Else
    INF="ZETIDPCAJA"
  Endif
Endcase
DEST=func ZCOMUN.INFORME(GUSER, INF,SRV,NAM)
End INF

Subprog MOSTRAR_CAMPOS(V)
Value Integer V
Local Char D(1)
#If V=10
  D="+"
#Else
#  D="-"
#Endif
Chgfmt [M:SLP]ZENDDAT With D
Chgfmt [M:SLP]ZBPCF With D
Chgfmt [M:SLP]ZSOHNUM With D
Chgfmt [M:SLP]ZNADA With D
Chgfmt [M:SLP]ZANCHOF With D
Chgfmt [M:SLP]ZLARGO With D
Chgfmt [M:SLP]ZETIQ With D
End



Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  Raz [M:SLP]ZENDDAT,[M:SLP]ZTRATEXT,[M:SLP]ZTRATINT
Else
  # Sacar de la cabecera de OF el dato ENDDAT, que serį la "Fecha Produccion"
  Filter [F:MFG] Where evalue ("MFGNUM=VALEUR")
  If rowcount([F:MFG])>0
    For [F:MFG]
      [M:SLP]ZENDDAT=[F:MFG]ENDDAT
      Break
    Next
    # Sacar datos del articulo
    Filter [F:MFI] Where evalue ("MFGNUM=VALEUR")
    If rowcount([F:MFI])>0
      For [F:MFI]
        ART=[F:MFI]ITMREF
        Break
      Next
      Filter [F:ITM] Where evalue ("ITMREF=ART")
      For [F:ITM]
        [M:SLP]ZTRATEXT=[F:ITM]TSICOD(2)
        [M:SLP]ZTRATINT=[F:ITM]TSICOD(3)
        Break
      Next
      Filter [F:ITM]
    Endif
    Filter [F:MFI]
  Endif
  Filter [F:MFG]
Endif
Affzo [M:SLP]ZENDDAT
Affzo [M:SLP]ZTRATEXT
Affzo [M:SLP]ZTRATINT
End

Subprog AM_ZSOHNUM(VALEUR)
Variable Char    VALEUR()
Local Char MSG(255)
If VALEUR =""
  Actzo [M:SLP]ZBPCF
Else
  Filter [F:SOH] Where SOHNUM=VALEUR
  If rowcount([F:SOH])<1
    MSG="No existe el pedido " + VALEUR
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Else
    Read [F:SOH] First
    If [M:SLP]ZBPCF<>"" and [F:SOH]BPCORD<>[M:SLP]ZBPCF
      MSG="El cliente del pedido es diferente al indicado para filtrar\" + [F:SOH]BPCORD +"<>"+[M:SLP]ZBPCF
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      mkstat=2
      End
    Else
      [M:SLP]ZBPCF=[F:SOH]BPCORD
      Affzo [M:SLP]ZBPCF
      Grizo [M:SLP]ZBPCF
    Endif
  Endif
  Filter [F:SOH]
Endif
[M:SLP]ZSOHNUM=VALEUR
Call APLICAR
End

Subprog AM_ZBPCF(VALEUR)
Variable Char    VALEUR()
[M:SLP]ZBPCF=VALEUR
#Affzo [M:SLP]ZBPCF
If VALEUR <>""
  Call AM_ZSOHNUM([M:SLP]ZSOHNUM)
Else
  Call APLICAR
Endif
End

Subprog AM_ZETIQ(VALEUR)
Variable Integer VALEUR
If VALEUR=3
  # Solo Stock
  [M:SLP]ZBPCF=""
  [M:SLP]ZSOHNUM=""
  Affzo [M:SLP]ZBPCF
  Affzo [M:SLP]ZSOHNUM
  Grizo [M:SLP]ZBPCF
  Grizo [M:SLP]ZSOHNUM
Else
  Actzo [M:SLP]ZSOHNUM
  If [M:SLP]ZSOHNUM=""
    Actzo [M:SLP]ZBPCF
  Endif
Endif
[M:SLP]ZETIQ=VALEUR
Call APLICAR
End

Subprog AM_ZANCHOF(VALEUR)
Variable Decimal VALEUR
[M:SLP]ZANCHOF=VALEUR
Call APLICAR
End

Subprog AM_ZLARGO(VALEUR)
Variable Decimal VALEUR
[M:SLP]ZLARGO=VALEUR
Call APLICAR
End


Subprog AM_ZTIPETI(VALEUR)
Variable Integer VALEUR
Local Char INF(GLONARP),DEST(GLONAIM),SRV(80),NAM(80)
Local Integer F,T
[M:SLP]ZTIPETI=VALEUR
INF=func INFORME(DEST,SRV,NAM)
If INF<>""
  T=[M:SLP]NBLIG-1
  If T<0
    T=0
  Else
    Call AM_LBEFMT(INF) From SUBSLP
  Endif
  For F=0 To T
    [M:SLP]LBEFMT(F)=INF
    If DEST<>""
      [M:SLP]PRT(F)   = DEST
      [M:SLP]SERIMP(F)= SRV
      [M:SLP]DEFIMP(F)= NAM
    Endif
  Next
  Affzo [M:SLP]15
Endif
End

Subprog AM_TRT(VALEUR)
Variable Integer VALEUR
[M:SLP]TRT(nolign-1)=VALEUR
If VALEUR=1
  [M:SLP]ZTRT(nolign-1)=2
  Chgstl [M:SLP]NBLIG(nolign-1) With ""
Else
  [M:SLP]ZTRT(nolign-1)=1
  Chgstl [M:SLP]NBLIG(nolign-1) With "BACKGREEN"
Endif
Affzo [M:SLP]TRT    #(nolign-1)
Affzo [M:SLP]ZTRT   #(nolign-1)
#  Affzo [M:SLP]15
#Call APLICAR_ORDENAR
#Call APLICAR_COLOR
End

Subprog AM_LBEVCRTYP(VALEUR)
Variable Integer VALEUR
Call MOSTRAR_CAMPOS(VALEUR)
End

Subprog AM_ZBPCLOGO(VALEUR)
Variable Integer VALEUR
If [M:SLP]ZBPC(nolign-1)<>""
  If VALEUR=2
    VALEUR=1
  Else
    VALEUR=2
  Endif
  [M:SLP]ZBPCLOGO(nolign-1)=VALEUR
  Affzo [M:SLP]ZBPCLOGO(nolign-1)
Endif
End


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End

#Z0001.ini
$GRUPOCORTE
If [M:SLP]ZGRPCORH<>0
  For I = 0 To [M:SLP]NBLIG-1
    If [M:SLP]ZGRPCOR(I)=[M:SLP]ZGRPCORH
      [M:SLP]TRT(I)=2
    Else
      [M:SLP]TRT(I)=1
    Endif
    Affzo [M:SLP]TRT(I)
  Next
Endif
Return
#Z0001.fin
