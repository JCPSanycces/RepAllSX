#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTRE -> Para construir filtro especifico para la consulta CSP (Lineas pedidos venta)
$ACTION
Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "FILTRE"   :   Gosub FILTRE
   When "AV_AFFICHE"    : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:ITM])= 0  : Local File ITMMASTER [ITM]  : Endif
If clalev([F:ZUTH])= 0 : Local File ZCONTAINH [ZUTH] : Endif
If clalev([F:ZUTS])= 0 : Local File ZCONTAINS [ZUTS] : Endif
If clalev([F:ZMSQ])= 0 : Local File ZMFGSOQ   [ZMSQ] : Endif
If clalev([F:MFGX])= 0 : Local File MFGHEAD   [MFGX] : Endif
If clalev([F:MFOX])= 0 : Local File MFGOPE    [MFOX] : Endif
If clalev([F:POHX])= 0 : Local File PORDER    [POHX] : Endif
If clalev([F:SOPX])= 0 : Local File SORDERP   [SOPX] : Endif
If clalev([F:SOQX])= 0 : Local File SORDERQ   [SOQX] : Endif
Return

$FILTRE
Raz [M:CSP1]ZTOTBOB
Raz [M:CSP1]ZTOTKG
Raz [M:CSP1]ZTOTM2
Raz [M:CSP1]ZTOTIMP
Affzo [M:CSP1]ZTOTBOB
Affzo [M:CSP1]ZTOTKG
Affzo [M:CSP1]ZTOTM2
Affzo [M:CSP1]ZTOTIMP

If [M:CSP1]ZANCHO>0
   WFIL2+="&[F:SOQ]ZANCHO="+num$([M:CSP1]ZANCHO)
Endif
If [M:CSP1]ZMANDRIL>0
   WFIL2+="&[F:SOQ]ZMANDRIL="+num$([M:CSP1]ZMANDRIL)
Endif
If [M:CSP1]ZLONGITUD>0
   WFIL2+="&[F:SOQ]ZLONGITUD="+num$([M:CSP1]ZLONGITUD)
Endif
If [M:CSP1]ZSHIDATDEB<>[0/0/0]
   WFIL2+="&[F:SOQ]SHIDAT>=[M:CSP1]ZSHIDATDEB"
Endif
If [M:CSP1]ZSHIDATFIN<>[0/0/0]
   WFIL2+="&[F:SOQ]SHIDAT<=[M:CSP1]ZSHIDATFIN"
Endif
If [M:CSP1]ZFECFINFADEB<>[0/0/0]
   WFIL2+="&[F:SOQ]ZFECFINFAB=[M:CSP1]ZFECFINFADEB"
Endif
If [M:CSP1]ZREPDEB<>""
   WFIL2+="&[F:SOP]REP1=[M:CSP1]ZREPDEB"
Endif
If [M:CSP1]ZREPFIN<>""
   WFIL2+="&[F:SOP]REP1=[M:CSP1]ZREPFIN"
Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif

For I=0 To [M:CSP2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CSP2]ITMREF(F)
   Raz [F:SOPX]
   Read [SOPX]SOP0(2)=[M:CSP2]SOHNUM(F);[M:CSP2]SOPLIN(F)
   Raz [F:SOQX]
   Read [SOQX]SOQ0(2)=[M:CSP2]SOHNUM(F);[M:CSP2]SOPLIN(F)
   If [F:SOPX]SAU="M2"
      [M:CSP2]ZQTYKG(F)=arr([F:SOQX]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSP2]ZQTYM2(F)=arr([F:SOQX]QTY,0.01)
   Endif
   If [F:SOPX]SAU="KG"
      [M:CSP2]ZQTYKG(F)=arr([F:SOQX]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSP2]ZQTYM2(F)=arr([F:SOQX]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSP2]ZQTYM2(F)=0
      Endif
   Endif
   Filter [ZUTS] Where SOHNUM=[M:CSP2]SOHNUM(F) and SOPLIN=[M:CSP2]SOPLIN(F)
   For [ZUTS]
      [M:CSP2]ZNUMCNTR(F)=[F:ZUTS]NUMCNTR
      [M:CSP2]ZPOHNUM(F) =[F:ZUTS]POHNUM
      Break
   Next
   Filter [ZUTS]
   Raz [F:ZUTH]
   If len([M:CSP2]ZNUMCNTR(F))>0
      Read [ZUTH]ZCNTR0=[M:CSP2]ZNUMCNTR(F)
      [M:CSP2]ZFECLLEDES(F)=[F:ZUTH]FECLLEDES
   Endif
   Raz [F:POHX]
   If len([M:CSP2]ZPOHNUM(F))>0
      Read [POHX]POH0=[M:CSP2]ZPOHNUM(F)
      [M:CSP2]ZEXTRCPDAT(F)=[F:POHX]EXTRCPDAT1
   Endif

   Filter [ZMSQ] Where SOHNUM=[M:CSP2]SOHNUM(F) and SOPLIN=[M:CSP2]SOPLIN(F)
   For [ZMSQ]
      Raz [F:MFGX]
      Read [MFGX]MFG0=[F:ZMSQ]MFGNUM
      If len([M:CSP2]ZMFGNUM(F))=0
         [M:CSP2]ZMFGNUM(F)-=[F:ZMSQ]MFGNUM
      Else
         [M:CSP2]ZMFGNUM(F)-="  "+[F:ZMSQ]MFGNUM
      Endif
      If len([M:CSP2]ZFECFINOF(F))
         [M:CSP2]ZFECFINOF(F)-=format$("D:DDMMYY",[F:MFGX]ENDDAT)
      Else
         [M:CSP2]ZFECFINOF(F)-="  "+format$("D:DDMMYY",[F:MFGX]ENDDAT)
      Endif
      #Break
   Next
   Filter [ZMSQ]
Next
Return

$CAL_CUMUL
Raz [M:CSP1]ZTOTBOB
Raz [M:CSP1]ZTOTKG
Raz [M:CSP1]ZTOTM2
Raz [M:CSP1]ZTOTIMP
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOQ0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SOP]ITMREF

   [M:CSP1]ZTOTBOB+=[F:SOQ]ZQTYBOB
   If [F:SOP]SAU="M2"
      [M:CSP1]ZTOTKG+=arr([F:SOQ]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSP1]ZTOTM2+=arr([F:SOQ]QTY,0.01)
   Endif
   If [F:SOP]SAU="KG"
      [M:CSP1]ZTOTKG+=arr([F:SOQ]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSP1]ZTOTM2+=arr([F:SOQ]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSP1]ZTOTM2+=0
      Endif
   Endif
   [M:CSP1]ZTOTIMP+=[F:SOQ]QTY*[F:SOP]NETPRINOT
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CSP1]ZTOTBOB
Affzo [M:CSP1]ZTOTKG
Affzo [M:CSP1]ZTOTM2
Affzo [M:CSP1]ZTOTIMP
Return
