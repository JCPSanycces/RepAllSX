#<AdxTL>@(#)0.0.0.0 $Revision$
#NEW_LOT - PE utilizado para en las devoluciones de cliente asignar los datos especificos ancho, mandril, etc.
#          ya que no actua igual que en recepciones y no sirve el PE DOC_ENTW pues cuando es una devolucion no pasa
#          por el.
$ACTION
#Infbox ACTION
Case ACTION
   When "DOC_ENTW"     :   Gosub DOC_ENTW
   When "DEFLOT"       :   Gosub DEFLOT
   When "BEFORE_STW"   :   Gosub BEFORE_STW
   When "STKENTSLO"    :   Gosub STKENTSLO
   When "NEW_LOT"      :   Gosub NEW_LOT
Endcase
Return

$NEW_LOT
If LABR="SRH1"
#   [M:ENTW]ZMANDRIL(WLIG)=[M:SRH1]ZMANDRIL(LLIGDOC)
#   [M:ENTW]ZLONGITUD(WLIG)=[M:SRH1]ZLONGITUD(LLIGDOC)
#   [M:ENTW]ZANCHO(WLIG)=[M:SRH1]ZANCHO(LLIGDOC)
#   [M:ENTW]ZPROVEEDOR(WLIG)=[M:SRH1]ZPROVEEDOR(LLIGDOC)
#   [M:ENTW]ZFACTOR(WLIG)=[M:SRH1]ZFACTOR(LLIGDOC)
   [M:ENTW]ZMANDRIL(WLIG) =[F:STJ]ZMANDRIL
   [M:ENTW]ZLONGITUD(WLIG)=[F:STJ]ZLONGITUD
   [M:ENTW]ZANCHO(WLIG)   =[F:STJ]ZANCHO
   [M:ENTW]ZPROVEEDOR(WLIG)=[F:STJ]ZPROVEEDOR
   [M:ENTW]ZFACTOR(WLIG)  =[F:STJ]ZFACTOR
   [M:ENTW]ZMFGDATE(WLIG)  =[F:STJ]ZMFGDATE
   [M:ENTW]ZEMPALME(WLIG)  =[F:STJ]ZEMPALME
Endif
Return

$DOC_ENTW
If LABR="PTH1"
   #Infbox "DOC_ENTW: "+LABR+" "+num$(LLIG)+" "+num$(LNBLIG)+" "+num$(WLIG)+" "+num$([M:PTH1]ZMANDRIL(LLIG))+" "+num$([M:PTH1]ZMANDRIL(LNBLIG))
   [M:ENTW]ZMANDRIL(WLIG)=[M:PTH1]ZMANDRIL(LLIG)
   [M:ENTW]ZLONGITUD(WLIG)=[M:PTH1]ZLONGITUD(LLIG)
   [M:ENTW]ZANCHO(WLIG)=[M:PTH1]ZANCHO(LLIG)
   [M:ENTW]ZPROVEEDOR(WLIG)=[M:PTH1]ZPROVEEDOR(LLIG)
   [M:ENTW]ZFACTOR(WLIG)=[M:PTH1]ZFACTOR(LLIG)
   [M:ENTW]ZMFGDATE(WLIG)=[M:PTH1]ZMFGDATE(LLIG)
   [M:ENTW]ZEMPALME(WLIG)=[M:PTH1]ZEMPALME(LLIG)
   #Infbox  [M:ENTW]USRFLD2(WLIG)+" "+[M:PTH1]ZPROVEEDOR(LLIG)
Endif

If LABR="SMR1"
   #Infbox "DOC_ENTW: "+LABR+" "+num$(LLIG)+" "+num$(LNBLIG)+" "+num$(WLIG)+" "+num$([M:SMR1]ZMANDRIL(LLIG))+" "+num$([M:SMR1]ZMANDRIL(LNBLIG))
   [M:ENTW]ZMANDRIL(WLIG)=[M:SMR1]ZMANDRIL(LLIG)
   [M:ENTW]ZLONGITUD(WLIG)=[M:SMR1]ZLONGITUD(LLIG)
   [M:ENTW]ZANCHO(WLIG)=[M:SMR1]ZANCHO(LLIG)
   [M:ENTW]ZPROVEEDOR(WLIG)=[M:SMR1]ZPROVEEDOR(LLIG)
   [M:ENTW]ZFACTOR(WLIG)=[M:SMR1]ZFACTOR(LLIG)
   [M:ENTW]ZMFGDATE(WLIG)=[M:SMR1]ZMFGDATE(LLIG)
   [M:ENTW]ZEMPALME(WLIG)=[M:SMR1]ZEMPALME(LLIG)
Endif

#Las devoluciones no entran aqui pero de momento se deja este codigo
If LABR="SRH1"
   #Infbox "DOC_ENTW: "+LABR+" "+num$(LLIG)+" "+num$(LNBLIG)+" "+num$(WLIG)+" "+num$([M:SMR1]ZMANDRIL(LLIG))+" "+num$([M:SMR1]ZMANDRIL(LNBLIG))
   [M:ENTW]ZMANDRIL(WLIG)=[M:SRH1]ZMANDRIL(LLIG)
   [M:ENTW]ZLONGITUD(WLIG)=[M:SRH1]ZLONGITUD(LLIG)
   [M:ENTW]ZANCHO(WLIG)=[M:SRH1]ZANCHO(LLIG)
   [M:ENTW]ZPROVEEDOR(WLIG)=[M:SRH1]ZPROVEEDOR(LLIG)
   [M:ENTW]ZFACTOR(WLIG)=[M:SRH1]ZFACTOR(LLIG)
   [M:ENTW]ZMFGDATE(WLIG)=[M:SRH1]ZMFGDATE(LLIG)
   [M:ENTW]ZEMPALME(WLIG)=[M:SRH1]ZEMPALME(LLIG)
Endif

If LABR="MTK2"
     If clalev([F:MFIX])<=0 : Local File MFGITM [MFIX] : Endif
     Raz [F:MFIX]
     Read [MFIX]MFI0=[M:MTK2]MFGNUMIT(LLIG);[M:MTK2]MFGLIN(LLIG)

     [M:ENTW]ZMANDRIL(WLIG)=[M:MTK2]ZMANDRIL(LLIG)
     [M:ENTW]ZANCHO(WLIG)=[M:MTK2]ZANCHO(LLIG)
     [M:ENTW]ZLONGITUD(WLIG)=[M:MTK2]ZLONGITUD(LLIG)
     [M:ENTW]ZFACTOR(WLIG)=[M:MTK2]ZFACTOR(LLIG)
     [M:ENTW]ZNCORTES(WLIG)=[M:MTK2]ZNCORTES(LLIG)
     [M:ENTW]ZPROVEEDOR(WLIG)=[M:MTK2]ZPROVEEDOR(LLIG)
     [M:ENTW]ZMFGDATE(WLIG)=[M:MTK2]ZMFGDATE(LLIG)
     [M:ENTW]ZEMPALME(WLIG)=[M:MTK2]ZEMPALME(LLIG)

     #NUMBOBPED se inicializa en el punto de entrada STKENTSLO (STKENT), con esta variable controlamos
     #el numero de bobinas que estan destinadas de una linea de OF a pedido de cliente.
     If dim(NUMBOBPED)>0
       If NUMBOBPED<>0
          NUMBOBPED=NUMBOBPED-1
          [M:ENTW]LOCTYP(WLIG)="GEN"
          [M:ENTW]LOC(WLIG)="GENERAL1"
       Else
          [M:ENTW]LOCTYP(WLIG)="GEN"
          If len([F:MFIX]ZUBICASTK)=0
             [M:ENTW]LOC(WLIG)="PTEUBICA"
          Else
             [M:ENTW]LOC(WLIG)=[F:MFIX]ZUBICASTK
          Endif
       Endif
     Endif
Endif
Return

$DEFLOT
   #Infbox "STKENT-DEFLOT: "+PABR+" "+num$(PNOLNUM)+" "+num$(NBLIGLOT)+" "+[M]USRFLD1([M]NUMLIGLOT(0))+" "+[M]USRFLD1([M]NUMLIGLOT(1))
   [M]USRFLD1([M]NUMLIGLOT(PNOLNUM))= [M]USRFLD1([M]NUMLIGLOT(0)) : #num$([M:SMR1]ZMANDRIL(LLIG))
   [M]USRFLD2([M]NUMLIGLOT(PNOLNUM))= [M]USRFLD2([M]NUMLIGLOT(0)) : #num$([M:SMR1]ZPROVEEDOR(LLIG))
Return

$BEFORE_STW
#If LABR="MTK2"
  # Infbox "FJCP-BEFORE_STW"
#Endif
Return

$STKENTSLO
Local Integer NUMBOBPED

If GUSER="ADMIN"
#   Infbox "ZPESTKENT - "+ACTION
Endif

If LABR="MTK2"
   #Infbox "FJCP-STKENTSLO"
   LSLO="0001"
   If FMOD = 1
    FMOD=0
    [M:MTK2]NBSLO(LLIG) = [M:MTK2]ZTMPBOB
   Else
    [M:MTK2]NBSLO(LLIG)     = [M:MTK2]ZQTYBOB(LLIG)
   Endif


   NUMBOBPED=0
   If clalev([ZMSQ])<=0 : Local File ZMFGSOQ [ZMSQ] : Endif
   Filter [ZMSQ] Where MFGNUM=[M:MTK0]MFGNUM and MFGLIN=[M:MTK2]MFGLIN(LLIG)
   For [ZMSQ]
      NUMBOBPED+=[F:ZMSQ]ZQTYBOBASI
   Next
   #Infbox GFONCTION+" "+LABR+" "+num$(WLIG)+" "+num$([M:MTK2]MFGLIN(LLIG))+" "+num$(NUMBOBPED)+" "+num$(WSTOSEQ)
   #Infbox GFONCTION+" "+num$([M:STLT]TRSTYP)+" "+num$(NUMBOBPED)

Endif
Return
