#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso que recorre ITMMVT para recuperar el precio medio, guardandolo en ITF y en una tabla historica
#especifica. El valor guardado en ITF se utilizara para el proceso de actualización de tarifas.
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_ACTPREB
  When "TERMINE"        : Gosub TERMINE_ACTPREB
  When "INIT"           : Gosub INIT_DIA_ACTPREB
  When "OK"             : Gosub OK_ACTPREB
  When "END"            : Gosub END_ACTPREB
Endcase
Return

$TRT_INI
If clalev([F:ZHPB])<=0 : Local File ZHISPREB    [ZHPB] : Endif
If clalev([F:ITF])<=0  : Local File ITMFACILIT  [ITF] : Endif
If clalev([F:ITV])<=0  : Local File ITMMVT      [ITV] : Endif
If clalev([F:SLF])<=0  : Local File STOLOTFCY   [SLF] : Endif
Return

$EXEC_ACTPREB
Local Date FECCAL

FECCAL=date$

Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Inicio actualizar precio base tarifa",0) From GESECRAN
Else
  Call OUVRE_TRACE("Inicio actualizar precio base tarifa") From LECFIC
Endif

WMSG = "Actualización precio base: "-[M:ZAPB]STOFCYSTR+" a "+[M:ZAPB]STOFCYEND+" - "+format$("D:DDMMYYYY",FECCAL)
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZACTPREB","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

Gosub ACTPREB_AVC
Return

$ACTPREB_AVC
Local Integer OK

OK=1
Trbegin [ZHPB]
Filter [ITV] Where STOFCY>=[M:ZAPB]STOFCYSTR and STOFCY<=[M:ZAPB]STOFCYEND
For [ITV]
   Call ECR_TRACE("Procesando artículo: "+[F:ITV]ITMREF,0) From GESECRAN
   Raz [F:ZHPB]
   Read [F:ZHPB]ZHPB0=[F:ITV]STOFCY;[F:ITV]ITMREF;FECCAL
   If fstat
      [F:ZHPB]STOFCY=[F:ITV]STOFCY
      [F:ZHPB]ITMREF=[F:ITV]ITMREF
      [F:ZHPB]FECACT=FECCAL
      [F:ZHPB]AVC   =[F:ITV]AVC
      Write [F:ZHPB]
      If fstat
         Call ECR_TRACE("Error grabando [ZHPB] - fstat: "+num$(fstat),1) From GESECRAN
         OK = 0
         Break
      Endif
   Else
      [F:ZHPB]AVC   =[F:ITV]AVC
      Rewrite [F:ZHPB]
      If fstat
         Call ECR_TRACE("Error modificando [ZHPB] - fstat: "+num$(fstat),1) From GESECRAN
         OK = 0
         Break
      Endif
   Endif
   Update [ITF] Where ITMREF=[F:ZHPB]ITMREF and STOFCY=[F:ZHPB]STOFCY
&         With ZPRETAR=[F:ZHPB]AVC
Next
Filter [ITV]
If OK
   Commit
Else
   Rollback
Endif
Return

$INIT_DIA_ACTPREB
Local Mask ZACTPREB [ZAPB]
Raz [M:ZAPB]
[M:ZAPB]STOFCYSTR = GFCYDEF(0)
[M:ZAPB]STOFCYEND = GFCYDEF(0)
Return

$TERMINE_ACTPREB
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

Return

$OK_ACTPREB
Raz [M:ZAPB]
FIN  = 1
Return

$END_ACTPREB
Raz [M:ZAPB]
FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
