#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog B1_NOMFIC(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char FICSRV(255),FICCLI(255)
Raz FICSRV,FICCLI,[M:ZIMPLOT]NOMFICSRV
OK=1
Call PEDIRFICHERO (FICSRV,OK,FICCLI) From ZCOMUN
If OK
  [M:ZIMPLOT]NOMFIC =FICCLI: Affzo [M:ZIMPLOT]NOMFIC
  [M:ZIMPLOT]NOMFICSRV=FICSRV
Endif
End
