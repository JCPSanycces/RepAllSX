#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTRE -> Para construir filtro especifico para la consulta CST (Lineas facturas venta)
$ACTION
Case ACTION
   When "OUVRE"        :   Gosub OUVRE
   When "FILTRE"       :   Gosub FILTRE
   When "AV_AFFICHE"   :   Gosub AV_AFFICHE
   When "APRES_MODIF"  :   Gosub APRES_MODIF
Endcase
Return

$OUVRE
If clalev([F:ITM])= 0  : Local File ITMMASTER [ITM]  : Endif
If clalev([F:SIHX])= 0 : Local File SINVOICE  [SIHX] : Endif
If clalev([F:SIDX])= 0 : Local File SINVOICED [SIDX] : Endif
Return

$FILTRE
If  CHGPAG=1
  Gosub DEL_CUMUL
  Gosub AFF_CUMUL
Endif
If [M:CST1]ZANCHO>0
   WFIL2+="&[F:SID]ZANCHO="+num$([M:CST1]ZANCHO)
Endif
If [M:CST1]ZMANDRIL>0
   WFIL2+="&[F:SID]ZMANDRIL="+num$([M:CST1]ZMANDRIL)
Endif
If [M:CST1]ZLONGITUD>0
   WFIL2+="&[F:SID]ZLONGITUD="+num$([M:CST1]ZLONGITUD)
Endif
If len([M:CST1]ZREP0)>0
   WFIL2+="&[F:SID]REP1='"+[M:CST1]ZREP0+"'"
Endif
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Gosub RESTO_DATOS
Return

$APRES_MODIF
Raz [M:CST2]NBLIG
Effzo [M:CST2]
Gosub DEL_CUMUL
Gosub AFF_CUMUL
Return


$CAL_CUMUL
Gosub DEL_CUMUL
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SID0
For [LNK]
    If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=5
      [M:CST1]ZTOTKG +=[SID]ZQTYKG
      [M:CST1]ZTOTM2 +=[SID]ZQTYM2
      [M:CST1]ZTOTBOB+=[SID]ZQTYBOB
      [M:CST1]ZTOTIMP+=[F:SID]AMTNOTLIN+[F:SID]DDTANOT(0)
    Elsif [F:SIH]INVTYP=2
      # Abono FINANCIEROS no hacen referencia a devolucion fisica alguna, por lo que SRHNUM estarį vacio
      If len([SID]SRHNUM)>0
        [M:CST1]ZTOTKG -=[SID]ZQTYKG
        [M:CST1]ZTOTM2 -=[SID]ZQTYM2
        [M:CST1]ZTOTBOB-=[SID]ZQTYBOB
      Endif
      [M:CST1]ZTOTIMP-=[F:SID]AMTNOTLIN+[F:SID]DDTANOT(0)
    Endif
#   Raz [F:ITM]
#   Read [ITM]ITM0=[F:SID]ITMREF
#
#   If [F:SIH]INVTYP=2
#      #Abono
#      [M:CST1]ZTOTBOB-=[F:SID]ZQTYBOB
#   Else
#      [M:CST1]ZTOTBOB+=[F:SID]ZQTYBOB
#   Endif
#   If [F:SIH]INVTYP=2
#      #Abono
#      If [F:SID]SAU="M2"
#         [M:CST1]ZTOTKG+=-1*arr([F:SID]QTY*[F:ITM]ZFACTOR,0.01)
#         [M:CST1]ZTOTM2+=-1*arr([F:SID]QTY,0.01)
#      Endif
#      If [F:SID]SAU="KG"
#         [M:CST1]ZTOTKG+=-1*arr([F:SID]QTY,0.01)
#         If [F:ITM]ZFACTOR<>0
#            [M:CST1]ZTOTM2+=-1*arr([F:SID]QTY/[F:ITM]ZFACTOR,0.01)
#         Else
#            [M:CST1]ZTOTM2+=0
#         Endif
#      Endif
#      [M:CST1]ZTOTIMP+=-1*[F:SID]AMTNOTLIN
#   Else
#      If [F:SID]SAU="M2"
#         [M:CST1]ZTOTKG+=arr([F:SID]QTY*[F:ITM]ZFACTOR,0.01)
#         [M:CST1]ZTOTM2+=arr([F:SID]QTY,0.01)
#      Endif
#      If [F:SID]SAU="KG"
#         [M:CST1]ZTOTKG+=arr([F:SID]QTY,0.01)
#         If [F:ITM]ZFACTOR<>0
#            [M:CST1]ZTOTM2+=arr([F:SID]QTY/[F:ITM]ZFACTOR,0.01)
#         Else
#            [M:CST1]ZTOTM2+=0
#         Endif
#      Endif
#      [M:CST1]ZTOTIMP+=[F:SID]AMTNOTLIN
#   Endif
Next
Filter [LNK]
[M:CST1]ZTOTKG =arr([M:CST1]ZTOTKG,0.01)
[M:CST1]ZTOTM2 =arr([M:CST1]ZTOTM2,1)
[M:CST1]ZTOTIMP=arr([M:CST1]ZTOTIMP,0.01)
Return

$AFF_CUMUL
Affzo [M:CST1]ZTOTBOB
Affzo [M:CST1]ZTOTKG
Affzo [M:CST1]ZTOTM2
Affzo [M:CST1]ZTOTIMP
Return

$DEL_CUMUL
Raz [M:CST1]ZTOTBOB
Raz [M:CST1]ZTOTKG
Raz [M:CST1]ZTOTM2
Raz [M:CST1]ZTOTIMP
Return

$RESTO_DATOS
Local Integer F
For F=0 To [M:CST2]NBLIG-1
   Read [SIDX]SID0=[M:CST2]NUM(F);[M:CST2]SIDLIN(F)
  [M:CST2]DDTANOT(F)   =[SIDX]DDTANOT(0)
  [M:CST2]AMTNOTLIN(F)+=[SIDX]DDTANOT(0)
  If [M:CST2]INVTYP(F)=2
  # Abono FINANCIEROS no hacen referencia a devolucion fisica alguna, por lo que SRHNUM estarį vacio
    If len([M:CST2]SRHNUM(F))<=0
      Raz [M:CST2]ZQTYKG(F), [M:CST2]ZQTYM2(F), [M:CST2]ZQTYBOB(F)
    Endif
    [M:CST2]ZQTYKG(F)   =[M:CST2]ZQTYKG(F) *-1
    [M:CST2]ZQTYM2(F)   =[M:CST2]ZQTYM2(F) *-1
    [M:CST2]ZQTYBOB(F)  =[M:CST2]ZQTYBOB(F)*-1
    [M:CST2]DDTANOT(F)  =[M:CST2]DDTANOT(F)*-1
    [M:CST2]QTY(F)      =[M:CST2]QTY(F)    *-1
    [M:CST2]PFM(F)      =[M:CST2]PFM(F)    *-1
    [M:CST2]QTYSTU(F)   =[M:CST2]QTYSTU(F) *-1
    [M:CST2]AMTNOTLIN(F)=[M:CST2]AMTNOTLIN(F)*-1
    [M:CST2]AMTATILIN(F)=[M:CST2]AMTATILIN(F)*-1
  Endif
#   Raz [F:ITM]
#   Read [ITM]ITM0=[M:CST2]ITMREF(F)
#
#   Raz [F:SIHX]
#   Read [SIHX]SIH0=[M:CST2]NUM(F)
#
#   Raz [F:SIDX]
#   Read [SIDX]SID0=[M:CST2]NUM(F);[M:CST2]SIDLIN(F)
#   If [F:SIHX]INVTYP=2
#      #Abono
#      [M:CST2]ZQTYBOB(F)=-1*[F:SIDX]ZQTYBOB
#      [M:CST2]QTY(F)=-1*[F:SIDX]QTY
#      [M:CST2]QTYSTU(F)=-1*[F:SIDX]QTYSTU
#      [M:CST2]AMTNOTLIN(F)=-1*[F:SIDX]AMTNOTLIN
#      [M:CST2]AMTATILIN(F)=-1*[F:SIDX]AMTATILIN
#   Else
#      [M:CST2]ZQTYBOB(F)=[F:SIDX]ZQTYBOB
#   Endif
#   If [F:SIDX]SAU="M2"
#      If [F:SIHX]INVTYP=2
#         #Abono
#         [M:CST2]ZQTYKG(F)=-1*arr([F:SIDX]QTY*[F:ITM]ZFACTOR,0.01)
#         [M:CST2]ZQTYM2(F)=-1*arr([F:SIDX]QTY,0.01)
#      Else
#         [M:CST2]ZQTYKG(F)=arr([F:SIDX]QTY*[F:ITM]ZFACTOR,0.01)
#         [M:CST2]ZQTYM2(F)=arr([F:SIDX]QTY,0.01)
#      Endif
#   Endif
#   If [F:SIDX]SAU="KG"
#      If [F:SIHX]INVTYP=2
#         #Abono
#         [M:CST2]ZQTYKG(F)=-1*arr([F:SIDX]QTY,0.01)
#      Else
#         [M:CST2]ZQTYKG(F)=arr([F:SIDX]QTY,0.01)
#      Endif
#      If [F:SIHX]INVTYP=2
#         #Abono
#         If [F:ITM]ZFACTOR<>0
#            [M:CST2]ZQTYM2(F)=-1*arr([F:SIDX]QTY/[F:ITM]ZFACTOR,0.01)
#         Else
#            [M:CST2]ZQTYM2(F)=0
#         Endif
#      Else
#         If [F:ITM]ZFACTOR<>0
#            [M:CST2]ZQTYM2(F)=arr([F:SIDX]QTY/[F:ITM]ZFACTOR,0.01)
#         Else
#            [M:CST2]ZQTYM2(F)=0
#         Endif
#      Endif
#   Endif
Next
Return
