#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox ACTION
Case ACTION
   When "TRT_LIGCDE" : Gosub TRT_LIGCDE
Endcase
Return

$TRT_LIGCDE
If [F:SOH]ZFAGFLG=2 Then

  [M:ZSIH1]ZFAGFLG=2
  [M:ZSIH1]ZFAGREPRES=[F:SOH]ZFAGREPRES
  [M:ZSIH1]ZFAGSTP=1
  [M:ZSIH1]ZFAGSTL=1
  [M:ZSIH1]ZFAGICMAN=1
  Gosub ZFAG_CALCULO_COMISION From SPEZSIH1
  Affzo [M:ZSIH1]
Endif

Return
