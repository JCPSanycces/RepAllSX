#<AdxTL>@(#)0.0.0.0 $Revision$
# CNSCPQSPE   Consulta lineas devoluciones COMPRAS  M:CPQ1 + M:CPQ2   F:PNH
# FILTER -> Para construir filtro especifico
# Tipo ventana  CONSULTA # INQUIRY
$ACTION
#Infbox ACTION
Case ACTION
   When "OUVRE"    :   Gosub OUVRE
   When "FILTRE"   :   Gosub FILTRE
   When "FERME"    :   Gosub FIN
   When "TITRE"    :   Gosub INI_VALORES
   When "APRES_MODIF": Gosub LIMPIAR
   When "AV_AFFICHE"    : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:PNDX])= 0 : Local File PRETURND   [PNDX] : Endif
If clalev([F:ITM])= 0 : Local File ITMMASTER   [ITM] : Endif
Return

$FILTRE
Local Char TMP(200)
Local Integer T

Raz [M:CPQ1]ZTOTBOB
Raz [M:CPQ1]ZTOTKG
Raz [M:CPQ1]ZTOTM2
Raz [M:CPQ1]ZTOTIMPAI
Raz [M:CPQ1]ZTOTIMPII
Affzo [M:CPQ1]ZTOTBOB
Affzo [M:CPQ1]ZTOTKG
Affzo [M:CPQ1]ZTOTM2
Affzo [M:CPQ1]ZTOTIMPAI
Affzo [M:CPQ1]ZTOTIMPII

TMP=""
If [M:CPQ1]ZPRECOG=2 Then Call MONTAR_TMP(TMP,1):Endif
If [M:CPQ1]ZPREVIS=2 Then Call MONTAR_TMP(TMP,2):Endif
If [M:CPQ1]ZPFIRMA=2 Then Call MONTAR_TMP(TMP,3):Endif
If [M:CPQ1]ZPABONO=2 Then Call MONTAR_TMP(TMP,4):Endif
If [M:CPQ1]ZACEPTA=2 Then Call MONTAR_TMP(TMP,5):Endif
If [M:CPQ1]ZNOACEP=2 Then Call MONTAR_TMP(TMP,6):Endif
If TMP<>"" Then
  TMP+=')'
  WFIL2+="&" + TMP
Endif
Return

Subprog MONTAR_TMP(TMP_P, VALOR_P)
Variable Char TMP_P
Value Integer VALOR_P
  If TMP_P ="" Then
    TMP_P+='('
  Else
    TMP_P+=' |'
  Endif
  TMP_P+='[F:PNH]ZSITFLG=' + num$(VALOR_P)
End


$LIMPIAR
  [M:CPQ2]NBLIG=0:      Affzo [M:CPQ2]
  [M:CPQ1]ZTOTBOB=0:    Affzo [M:CPQ1]ZTOTBOB
  [M:CPQ1]ZTOTKG=0:     Affzo [M:CPQ1]ZTOTKG
  [M:CPQ1]ZTOTM2=0:     Affzo [M:CPQ1]ZTOTM2
  [M:CPQ1]ZTOTIMPAI=0:  Affzo [M:CPQ1]ZTOTIMPAI
  [M:CPQ1]ZTOTIMPII=0:  Affzo [M:CPQ1]ZTOTIMPII
Return

$INI_VALORES
  [M:CPQ1]ZACEPTA=2:Affzo[M:CPQ1]ZACEPTA
  [M:CPQ1]ZNOACEP=2:Affzo[M:CPQ1]ZNOACEP
  [M:CPQ1]ZPABONO=2:Affzo[M:CPQ1]ZPABONO
  [M:CPQ1]ZPFIRMA=2:Affzo[M:CPQ1]ZPFIRMA
  [M:CPQ1]ZPRECOG=2:Affzo[M:CPQ1]ZPRECOG
  [M:CPQ1]ZPREVIS=2:Affzo[M:CPQ1]ZPREVIS
Return


$FIN
  If GPE=1 Then GPE=0:Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
For F=0 To [M:CPQ2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CPQ2]ITMREF(F)
   Raz [F:PNDX]
   Read [PNDX]PND0=[M:CPQ2]PNHNUM(F);[M:CPQ2]PNDLIN(F)
   If [F:PNDX]UOM="M2"
      [M:CPQ2]ZQTYKG(F)=arr([F:PNDX]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPQ2]ZQTYM2(F)=arr([F:PNDX]QTYPUU,0.01)
   Endif
   If [F:PNDX]UOM="KG"
      [M:CPQ2]ZQTYKG(F)=arr([F:PNDX]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPQ2]ZQTYM2(F)=arr([F:PNDX]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPQ2]ZQTYM2(F)=0
      Endif
   Endif
Next
Return

$CAL_CUMUL
Raz [M:CPQ1]ZTOTBOB
Raz [M:CPQ1]ZTOTKG
Raz [M:CPQ1]ZTOTM2
Raz [M:CPQ1]ZTOTIMPAI
Raz [M:CPQ1]ZTOTIMPII
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key PND0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:PND]ITMREF

   [M:CPQ1]ZTOTBOB+=[F:PND]ZQTYBOB
   If [F:PND]PUU="M2"
      [M:CPQ1]ZTOTKG+=arr([F:PND]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPQ1]ZTOTM2+=arr([F:PND]QTYPUU,0.01)
   Endif
   If [F:PND]PUU="KG"
      [M:CPQ1]ZTOTKG+=arr([F:PND]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPQ1]ZTOTM2+=arr([F:PND]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPQ1]ZTOTM2+=0
      Endif
   Endif
   [M:CPQ1]ZTOTIMPAI+=[F:PND]LINAMT
   [M:CPQ1]ZTOTIMPII+=[F:PND]LINATIAMT
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CPQ1]ZTOTBOB
Affzo [M:CPQ1]ZTOTKG
Affzo [M:CPQ1]ZTOTM2
Affzo [M:CPQ1]ZTOTIMPAI
Affzo [M:CPQ1]ZTOTIMPII
Return
