# Gestión de la máscara ZCNTRASOH (Especifico)
$ACTION
#Infbox "SPEZCNTRAS: "+ACTION
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCNTRASOH) 15/11/2015 12:32:20 (ADMIN)
######################################################################################
Subprog CL_ICOLNKS(VALEUR)
Variable Char    VALEUR()
Local Integer LMAXLNKS, NOL

NOL=nolign-1
If [M:ZCNTRAS]NUMLNKS(NOL)=0
   LMAXLNKS=max([M:ZCNTRAS]NUMLNKS(0..[M:ZCNTRAS]NBLIG1-1))
   [M:ZCNTRAS]NUMLNKS(NOL)=LMAXLNKS+1
   Affzo [M:ZCNTRAS]NUMLNKS(NOL)
Else
   [M:ZCNTRAS]NUMLNKS(NOL)=0
   Affzo [M:ZCNTRAS]NUMLNKS
Endif
End

Subprog CL_ICOLNKP(VALEUR)
Variable Char    VALEUR()
Local Integer LMAXLNKS, LMAXLNKP, COMP, NOL
Local Char POHSOH(1)

NOL=nolign-1
If [M:ZCNTRAS]NUMLNKP(NOL)=0
   LMAXLNKS=max([M:ZCNTRAS]NUMLNKS(0..[M:ZCNTRAS]NBLIG1-1))
   Call DAME_COMP("S",LMAXLNKS,COMP) From SPEZCNTRAS
   If COMP>-1
      If [M:ZCNTRAS]ITMREF(COMP)=[M:ZCNTRAS]PITMREF(NOL) and [M:ZCNTRAS]ANCHO(COMP)=[M:ZCNTRAS]PANCHO(NOL)
         [M:ZCNTRAS]NUMLNKP(NOL)=LMAXLNKS
         Affzo [M:ZCNTRAS]NUMLNKP(NOL)
      Endif
   Endif
Else
   [M:ZCNTRAS]NUMLNKP(NOL)=0
   Affzo [M:ZCNTRAS]NUMLNKP
Endif
End

Subprog DAME_COMP(LSOHPOH,LNUMLNK,LCOMP)
Value Char LSOHPOH
Value Integer LNUMLNK
Variable Integer LCOMP
Local Integer J

LCOMP=-1
If LSOHPOH="S"
   For J=0 To [M:ZCNTRAS]NBLIG1-1
      If [M:ZCNTRAS]NUMLNKS(J)=LNUMLNK
         LCOMP=J
         Break
      Endif
   Next
Endif
If LSOHPOH="P"
   For J=0 To [M:ZCNTRAS]NBLIG2-1
      If [M:ZCNTRAS]NUMLNKP(J)=LNUMLNK
         LCOMP=J
         Break
      Endif
   Next
Endif
End

######################################################################################
