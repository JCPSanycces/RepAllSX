#<AdxTL>@(#)0.0.0.0 $Revision$
#MODQTEALL -> PE de FUNAUTALL para intervenir sobre la cantidad a asignar para que de una cantidad mayor
#             a la pedida para asegurarnos de que se va a asignar igual o mįs de lo pedido.
#             Este PE se llama desde asignaciones automįticas de pedidos (Ventas/Asignaciones/Asignaciones automaticas"

#De este especifico hay que eliminar toda referencia a ZASIPED una vez hecha la migracion (recuperando la copia del fuente y eliminando ZASIPED)
$ACTION
Case ACTION
   When "MODQTEALL"     :   Gosub MODQTEALL
Endcase
Return

$MODQTEALL
Local Shortint LI,LQYTBOB
Local Decimal LALLAUX
Local Integer LASITRAS

Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - WALLSTU: "+num$(WALLSTU)+" ZFABCOR: "+num$([F:ITM]ZFABCOR)+" - "+GFONCTION+" - "+GACTION,0) From GESECRAN
If WALLSTU>0
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SOQ]ITMREF
   If [F:ITM]ZFABCOR=2
      If clalev([F:STOX])<=0 : Local File STOCK   [STOX] : Endif

      If GFONCTION="GESMTK" and GACTION="TRTAUTALL"
         #Si la asignacion se lanza tras la declaracion de produccion
         Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL (1) - PED: "+[F:SOQ]SOHNUM+" - REF: "+[F:SOQ]ITMREF+" - "+num$([F:SOQ]ZANCHO)+" - "+num$([F:SOQ]ZMANDRIL)+" - "+num$([F:SOQ]ZLONGITUD)+
&                       " - BOB.PED.: "+num$([F:SOQ]ZQTYBOB)         ,0) From GESECRAN
         If clalev([ZAAM])<=0 : Local File ZASIAUTMTK [ZAAM] : Endif
#         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
#&               ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
#&               CUMALLQTY=0 and (LOC="GENERAL" or LOC="GENERAL1")
         Read [ZAAM]ZAAM1=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
         If fstat<>0
            Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - REF: "+[F:SOQ]ITMREF+" - "+num$([F:SOQ]ZANCHO)+" - "+num$([F:SOQ]ZMANDRIL)+" - "+num$([F:SOQ]ZLONGITUD)+
&                          " ERROR [ZAAM] - fstat: "+num$(fstat),0) From GESECRAN
         Endif
         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&               LOT=[F:ZAAM]LOT and LOC=[F:ZAAM]LOCCLI and ZANCHO=[F:SOQ]ZANCHO and
&               ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&               CUMALLQTY=0
      Else
         Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL (2) - REF: "+[F:SOQ]ITMREF+" - "+num$([F:SOQ]ZANCHO)+" - "+num$([F:SOQ]ZMANDRIL)+" - "+num$([F:SOQ]ZLONGITUD),0) From GESECRAN
         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&               ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&               LOC<>"GENERAL" and LOC<>"GENERAL1" and CUMALLQTY=0
      Endif
      LALLAUX=0
      LI=0
      For [STOX]
         LI+=1
         LALLAUX+=[F:STOX]QTYSTU
         If LI=[F:SOQ]ZQTYBOB
            Break
         Endif
      Next
      Filter [STOX]
      Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - WALLSTU: "+num$(WALLSTU)+" LALLAUX: "+num$(LALLAUX)+" BOB.PED.: "+num$([F:SOQ]ZQTYBOB)+
&                    " LI: "+num$(LI),0) From GESECRAN
      If WALLSTU<>LALLAUX
         WALLSTU=LALLAUX+0.1
      Endif
   Endif
Endif
Return


$MODQTEALLT
Local Shortint LI,LQYTBOB
Local Decimal LALLAUX
Local Integer LASITRAS, LSIHAY

Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - WALLSTU: "+num$(WALLSTU)+" ART: "+[F:SOQ]ITMREF+" ZFABCOR: "+num$([F:ITM]ZFABCOR)+" - "+GFONCTION,0) From GESECRAN
If WALLSTU>0
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SOQ]ITMREF
   If [F:ITM]ZFABCOR=2
      If clalev([F:STOX])<=0 : Local File STOCK   [STOX] : Endif
      If clalev([F:ZASP])<=0 : Local File ZASIPED [ZASP] : Endif

      Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - GSERVEUR: "+"NO"+" - "+GFONCTION,0) From GESECRAN
      Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&            ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&            CUMALLQTY=0
      #Inicio (solo en el arranque)
      LASITRAS=0
      Filter [ZASP] Where VCRTYP=2 and VCRNUM=[F:SOQ]SOHNUM and VCRLIN=[F:SOP]ZSOPLIN
      Raz [F:ZASP]
      For [ZASP]
         Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - ASIGNACION TRAPASO: "+"SI"+" - "+GFONCTION,0) From GESECRAN
         LASITRAS=1
         Break
      Next
      Filter [ZASP]
      If LASITRAS=1 : #or LASITRAS=0
         #Asignamos solamente lo que viene con asignacion del traspaso
         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&               ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD :# and
#&               LOT=[F:ZASP]LOT and LOC=[F:ZASP]LOC and CUMALLQTY=0
      Endif
      #Fin (solo en el arranque)
      LALLAUX=0
      LI=0
      For [STOX]
         Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - STO: "+[F:STOX]LOT+" - "+GFONCTION,0) From GESECRAN
         Filter [ZASP] Where VCRTYP=2 and VCRNUM=[F:SOQ]SOHNUM and VCRLIN=[F:SOP]ZSOPLIN and ITMREF=[F:SOQ]ITMREF and
&                            ANCHO=[F:SOQ]ZANCHO and MANDRIL=[F:SOQ]ZMANDRIL and LONGITUD=[F:SOQ]ZLONGITUD and
&                            LOT=[F:STOX]LOT and LOC=[F:STOX]LOC :#and ASIGNADA=1
         LSIHAY=0
         For [ZASP]
             LSIHAY=1
             Break
         Next
         Filter [ZASP]
         #[F:ZASP]ASIGNADA=2
         #Rewrite [F:ZASP]
         If LSIHAY
            LI+=1
            LALLAUX+=[F:STOX]QTYSTU
            If LI=[F:SOQ]ZQTYBOB
               Break
            Endif
         Endif
      Next
      Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - LALLAUX: "+num$(LALLAUX),0) From GESECRAN
      #If WALLSTU<LALLAUX
         #WALLSTU+=0.001
         WALLSTU=LALLAUX
      #Endif
   Endif
Endif
Return
