#<AdxTL>@(#)0.0.0.0 $Revision$
#Utilizamos la accion FILGAUCHE para filtrar la lista de stocks segun los valores de la linea de documento
#asignando a FILGAUSUP(2) el filtro que nos interesa
$ACTION
#Infbox ACTION
Case ACTION
When "AVANT_ENR"  :  Gosub AVANT_ENR
When "FILGAUCHE"  :  Gosub FILGAUCHE
When "DEBUT"

Endcase
Return

#No actua porque en el estandar se inicializa la variable FILGAUSUP(2)
$FILGAUCHE
#If GUSER="ADMIN"
#Infbox "FILGAUCHE - XYTRTSTOALL "+LABR
#Endif

Case LABR
When"SOH4"
   FILGAUSUP(2)="&[F:STO]ZANCHO="+num$([M:SOH4]ZANCHO(LNOL))+" &[F:STO]ZMANDRIL="+num$([M:SOH4]ZMANDRIL(LNOL))+
&                " &[F:STO]ZLONGITUD="+num$([M:SOH4]ZLONGITUD(LNOL))
    #JLPR 17-11-16 S/Tachi no hemos de permitir que se escoga stock de las ubicaciones  PTREVISI + DEVOLUCI
    FILGAUSUP(2)+='& not (LOC="PTREVISI" or LOC="DEVOLUCI")'
#   If GUSER="ADMIN"
#   Infbox FILGAUSUP(2)
#   Endif
   [M:ALL]XANCHO=[M:SOH4]ZANCHO(LNOL)
   [M:ALL]XMANDRIL=[M:SOH4]ZMANDRIL(LNOL)
   [M:ALL]XLONGITUD=[M:SOH4]ZLONGITUD(LNOL)
   [M:ALL]XPROVEEDOR=[M:SOH4]ZPROVEEDOR(LNOL)
   [M:ALL]XQTYBOB=[M:SOH4]ZQTYBOB(LNOL)

When  LABR="MFG2"
   #FJCG-Lo comento porque si no no asigna aquellas bobinas preasignadas menores a este ancho
   #FILGAUSUP(2)="&[F:STO]ZANCHO>="+num$([M:MFG2]ZANCHO(LNOL))

   # JLPR 13.07.16 a˝ade
   FILGAUSUP(2)="&[F:STO]ZANCHO>="+num$([M:MFG1]ZMINANCHO)
Endcase
Return

$AVANT_ENR
Local Char WMSG(255)
Local Integer WLINEA
For WLINEA=0 To [M:ALL]NBLIG-1
   If [M:ALL]TOTQTY(WLINEA)<>[M:ALL]ALLQTY(WLINEA) and [M:ALL]ITMREF<>"900"
      WMSG="Linea "+num$(WLINEA+1)+" no asignada totalmente"+" "+num$([M:ALL]TOTQTY(WLINEA))+" "+num$([M:ALL]ALLQTY(WLINEA))
      If GUSER<>"ADMIN"
        Infbox WMSG
        FOK=0
        Break
      Else
        Local Integer YN
        YN=1
        Call OUINON("User=ADMIN\Desea continuar\"+WMSG, YN) From GESECRAN
        If YN=1
          FOK=0
          Break
        Endif
      Endif
   Endif
Next
If FOK=0
   GPE=1
   Return
Endif
Return
