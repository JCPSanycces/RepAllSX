#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
When "INIT"            : Gosub INIT
When "EXEC"            : Gosub EXEC
Endcase
Return


$INIT
Local Char WRUTA(250), WFICH(250)
Local Integer WSTAT
Return


$CONTROLE
Return


$EXEC
Local Integer F,R
Raz F
WFICH=filpath("BQT","","")+"\"+GUSER+"COPFIR.TXT"
If filinfo(WFICH,0)>0 Then
 Call EFFACE(WFICH,WSTAT) From ORDSYS
 If WSTAT=0  F+=1 Endif
Endif

WFICH=filpath("BQT","","")+"\"+GUSER+"COPIAR.TXT"
If filinfo(WFICH,0)>0 Then
 Call EFFACE(WFICH,WSTAT) From ORDSYS
 If WSTAT=0  F+=1 Endif
Endif

WFICH=filpath("BQT","","")+"\"+GUSER+"ENVIAR.TXT"
If filinfo(WFICH,0)>0 Then
 Call EFFACE(WFICH,WSTAT) From ORDSYS
 If WSTAT=0  F+=1 Endif
Endif

WFICH=filpath("BQT","","")+"\"+GUSER+"FIRMAR.BAT"
If filinfo(WFICH,0)>0 Then
 Call EFFACE(WFICH,WSTAT) From ORDSYS
 If WSTAT=0  F+=1 Endif
Endif

For R=0 To [XX02FE1]NBLIG-1
  WFICH=filpath("BQT","","")+"\FE"+[XX02FE1]NUM(R)+".PDF"
  If filinfo(WFICH,0)>0 Then
   Call EFFACE(WFICH,WSTAT) From ORDSYS
   If WSTAT=0  F+=1 Endif
  Endif
Next

Infbox "PROCESO REALIZADO   (Borrados "+num$(F)+" ficheros)"
Return

$SORTIE
Return
