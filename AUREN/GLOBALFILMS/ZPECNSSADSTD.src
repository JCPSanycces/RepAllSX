#<AdxTL>@(#)0.0.0.0 $Revision$
#CUSLOASAD - PE para la consulta de asignaciones detalladas
$ACTION
Case ACTION
   When "CUSLOASAD" :   Gosub CUSLOASAD
Endcase
Return

$CUSLOASAD
If [M:SAD2]VCRTYP(nolign-1)= 2
   Raz [F:SOH]
   Read [SOH]SOH0=[M:SAD2]VCRNUM(nolign-1)
   Raz [F:BPC]
   Read [F:BPC]BPC0=[F:SOH]BPCORD
Endif
If [M:SAD2]VCRTYP(nolign-1)= 4
   Raz [F:SDH]
   Read [SDH]SDH0=[M:SAD2]VCRNUM(nolign-1)
   Raz [F:BPC]
   Read [F:BPC]BPC0=[F:SDH]BPCORD
Endif
[M:SAD2]ZBPCNUM(nolign-1)=[F:BPC]BPCNUM
Return
