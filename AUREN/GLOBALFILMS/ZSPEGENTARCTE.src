## Etiqueta ańadida por el supervisor (pantalla ZGTARCTE) 22/02/2017 12:17:19 (ADMIN)
######################################################################################
Subprog AM_BPCNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M:ZGTC]BPCNUMEND<VALEUR
  [M:ZGTC]BPCNUMEND=VALEUR
  Affzo [M:ZGTC]BPCNUMEND
Endif
End


