#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
If GACTION="SAIPKD"
#If GUSER="ADMIN"   Infbox "Depurar  $ACTION   SPEPKD.src"  Endif
   Case ACTION
      When "GAU"      :  Gosub GAUCHE
      When "OUVRE"    :  Gosub ZPV_OUVRE
      When "FIN_PIC"  :  Gosub ZPV_FIN_PIC
      When "DEB_PIC"  :  Gosub ZPV_DEB_PIC
   Endcase
Endif
Return

$GAUCHE
Gosub ACTION From FUNPKD
GPE=1
#
Local Integer II,ZOK
[M:PKD1]ZPCKLEN= [F:SPH]ZPCKLEN
[M:PKD1]ZPCKWID= [F:SPH]ZPCKWID
[M:PKD1]ZPCKHEI= [F:SPH]ZPCKHEI
[M:PKD1]ZPCKWEI= [F:SPH]ZPCKWEI
Affzo [M:PKD1]ZPCKLEN
Affzo [M:PKD1]ZPCKWID
Affzo [M:PKD1]ZPCKHEI
Affzo [M:PKD1]ZPCKWEI

# Z0001.ini
If GFONCTION = "GESPRH"
  If clalev([F:ZSTK]) = 0 Local File STOCK [ZSTK] Endif
  For IX = 0 To [M:PKD1]NBLIG - 1
    Filter [F:ZSTK] Where [F:ZSTK]STOFCY=[F:SPH]STOFCY and [F:ZSTK]LOT=[M:PKD1]LOT(IX) and [F:ZSTK]SLO = [M:PKD1]SLO(IX)
    Read [F:ZSTK] First
    If !fstat
      [M:PKD1]ZANCHO(IX)    = [F:ZSTK]ZANCHO
      [M:PKD1]ZLONGITUD(IX) = [F:ZSTK]ZLONGITUD
      [M:PKD1]ZMANDRIL(IX)  = [F:ZSTK]ZMANDRIL
      Affzo [M:PKD1]ZANCHO(IX)
      Affzo [M:PKD1]ZLONGITUD(IX)
      Affzo [M:PKD1]ZMANDRIL(IX)
    Endif
    Filter [F:ZSTK]
  Next

  Return
Endif
# Z0001.fin

#FJCG - Se muestran las caracteristicas de la bobina
If clalev([F:SDDX]) = 0 Local File SDELIVERYD [SDDX] Endif
For II = 0 To [M:PKD1]NBLIG - 1
   Raz [SDDX]
   Read [SDDX]SDD0=[M:PKD0]VCRNUM;[M:PKD1]VCRLIN(II)
   [M:PKD1]ZANCHO(II)    = [F:SDDX]ZANCHO
   [M:PKD1]ZLONGITUD(II) = [F:SDDX]ZLONGITUD
   [M:PKD1]ZMANDRIL(II)  = [F:SDDX]ZMANDRIL
   Affzo [M:PKD1]ZANCHO(II)
   Affzo [M:PKD1]ZLONGITUD(II)
   Affzo [M:PKD1]ZMANDRIL(II)
   Call EMPAQUETADO_OK([M:PKD1]VCRLIN(II),ZOK) From SPESDH
   If ZOK
     Chgstl [M:PKD1]NBLIG(II) With ""
   Else
     Chgstl [M:PKD1]NBLIG(II) With "BACKRED"
   Endif
Next
Return

# ZPV Carga Pesos reales en lineas de bultos

$ZPV_OUVRE
If !clalev([F:ZPVCR]) : Local File ZPVCTDREAL [ZPVCR]: Endif
Local Integer WLNBLIG
Return

$ZPV_DEB_PIC
# Me guardo el total de lineas ya introducidas.
WLNBLIG=[M:PKD1]NBLIG
Return

$ZPV_FIN_PIC
If GUSER="PALAU"   Infbox "Depurar    $ZPV_FIN_PIC       XWFPKD.src"  Endif
Local Shortint WLFOUND : WLFOUND=0
#If GUSER='ADMIN' : Infbox "HOLA"  : Endif
# For a partir de la ultima linea introducida antes del pick (DEB_PIC)

For II = WLNBLIG To [M:PKD1]NBLIG - 1
   Raz [F:ZPVCR]
   Filter [F:ZPVCR] Where STOFCY = [M:PKD0]STOFCY and ITMREF=[M:PKD1]ITMREF(II)
& and LOT=[M:PKD1]LOT(II) and SLO=[M:PKD1]SLO(II) and SDHNUM=[M:PKD0]VCRNUM
   For [F:ZPVCR]
     WLFOUND=1
    Break
   Next
   Filter [F:ZPVCR]
   If WLFOUND and [M:PKD1]LIGWEU(II)=[F:ZPVCR]STU
      # Unidad peseo del contenido = unidad peso del embalage
      # Coeficiente 1
      [M:PKD1]NETWEI(II)   =[F:ZPVCR]CTDREALUS
      [M:PKD1]NETWEIPCK(II)=[F:ZPVCR]CTDREALUS
      [M:PKD1]QTY(II)      =[F:ZPVCR]CTDREALUS
      [M:PKD1]QTYSTU(II)   =[F:ZPVCR]CTDREALUS
      [M:PKD1]QTYPCU(II)   =[F:ZPVCR]CTDREALUS
   Endif
Next

Gosub TOT_GROWEI From FUNPKD
Return
