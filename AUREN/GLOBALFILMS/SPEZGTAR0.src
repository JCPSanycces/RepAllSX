Subprog CERRAR
Local Char MSG(255)
Local Integer YN
MSG="Estį seguro de marcar este cįlculo como cerrado\.\Observe que hay lineas pendientes de generar"
YN=1 # Por defecto es NO
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  End
Endif
End

Subprog GRABAR_RESTO
Local Integer F
Local Char TXT(255)(10)
If [M:ZGTAR0]CERRADO=2
  Raz TXT
  TXT(0)="UPDATE ZGTARVD SET ZGEN_0=2 WHERE ZGEN_0<>2 AND ZREVISION_0="+num$([M:ZGTAR0]ZREVISION)
  Execsql  From GFLDCHR(0) Sql TXT
  End
Endif
#Grabar ZGTARVH1
If !clalev([F:ZTVH1])      :  Local File ZGTARVH1 [F:ZTVH1]  : Endif
Delete [F:ZTVH1] Where [F:ZTVH1]ZREVISION=[M:ZGTAR0]ZREVISION
For F=0 To [M:ZGTAR0]NBLIG-1
  Raz [F:ZTVH1]
  [F:ZTVH1]ZREVISION=[M:ZGTAR0]ZREVISION
  [F:ZTVH1]PLI      =[M:ZGTAR0]PLI
  [F:ZTVH1]ZTSCCOD0 =[M:ZGTAR0]ZTSCCOD0(F)
  [F:ZTVH1]ZTSCCOD1 =[M:ZGTAR0]ZTSCCOD1(F)
  [F:ZTVH1]ZPOR     =[M:ZGTAR0]ZPOR(F)
  [F:ZTVH1]ZFIJO    =[M:ZGTAR0]ZFIJO(F)
  Write [F:ZTVH1]
Next
End


Subprog GENERAR
If not func OK_COMPROBACIONES End Endif
#If GUSER<>"ADMIN"
#  MSG="29.03.17  En desarrollo\.\Contactar con Jose Luis Palau"
#  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#  End
#Endif
#Impedir uso de tabla para asegurarnos integridad
If !clalev([F:SPL])      :  Local File SPRICLIST [F:SPL]  : Endif
Lock [F:SPL]
If fstat<>0
  MSG="Imposible continuar, pues la tabla de tarifas estį siendo usada en otro puesto"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  End
Endif
#
Call OUVRE_TRACE("Revisión tarifas venta")  From LECFIC
Call ECR_TRACE(" ",0)             From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Revisión tarifas venta    "+ format$(GFMD,date$) + " " + time$,0) From GESECRAN
Call ECR_TRACE("Usuario  "+GUSER,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0)             From GESECRAN
#
If !clalev([F:SPF])        :  Local File SPRICFICH [F:SPF]    : Endif
If !clalev([F:WZTVH])      :  Local File ZGTARVH   [F:WZTVH]  : Endif
If !clalev([F:WZTVD])      :  Local File ZGTARVD   [F:WZTVD]  : Endif
Link [F:WZTVD] With  [F:WZTVH]ZTVH0=[F:WZTVD]ZREVISION As [WTARF]
#Generar modelo importacion de las tarifas seleccionadas
Gosub GENERAR_TARIFAS
#Si todas lineas generadas, marcar cįlculo como cerrado
Call TODO_CALCULADO
#Desbloquear
Unlock [F:SPL]
Close Local File  [F:WZTVH],[F:WZTVD],[F:SPF],[F:SPL]
#Cerrar y mostrar traza
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
#
#Infbox"No olvide generar tarifas a partir de la fecha de inico de las nuevas tarifas generadas"
End


Funprog OK_COMPROBACIONES
Local Char MSG(255),RDAT(255),PDTE(255)
Local Integer YN,F,N,R,S
#
Raz N,R,S
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2 and [M:ZGTAR1]SEL(F)=2
    S+=1
    If ([M:ZGTAR0]ZTIPO=2 or [M:ZGTAR1]SEL(F)=2)
      If [M:ZGTAR1]PRECACTU(F)<>[M:ZGTAR1]PRECNUEV(F) or [M:ZGTAR1]ZOK=2 or [M:ZGTAR1]ZBAJA=2
        N+=1
      Endif
      If [M:ZGTAR1]PRECDIF(F)<0
        R+=1
      Endif
    Endif
  Endif
Next
If S<1
  MSG="No se ha seleccionado tarifa alguna"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  End 0
Elsif N<1
  MSG="No se ha cambiado precio alguno\Cambie fecha fin en caso de querer ampliar vigencia"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End 0
Elsif R>0
  MSG="Observe que hay "+num$(R)+" filas donde se ha bajado el precio\Estį seguro de continuar"
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    End 0
  Endif
Endif
#
Raz RDAT,MSG,R
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2 and RDAT<>[M:ZGTAR1]PLICRD(F) and ([M:ZGTAR0]ZTIPO=2 or [M:ZGTAR1]SEL(F)=2)
    RDAT=[M:ZGTAR1]PLICRD(F)
    If [M:ZGTAR1]ZFECINI(F)=[0/0/0]
      MSG+="Tarifa "+[M:ZGTAR1]PLICRD(F)+" sin fecha inicio\"
    Elsif [M:ZGTAR1]ZFECINI(F)<=date$
      MSG+="Tarifa "+[M:ZGTAR1]PLICRD(F)+" fecha inicio debe ser posterior al dia de hoy\"
    Elsif MSG=""
      PDTE=func PDTE_REV(RDAT)
      If PDTE<>""
        MSG="La tarifa "+RDAT+" tiene los siguientes articulos en revisiones abiertas\"+PDTE
        Break
      Endif
    Endif
    R+=1
  Endif
Next
If MSG<>""
  Call ERREURT("Imposible continuar\\"+MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End 0
Endif
#
If R=1
  MSG="Estį seguro de generar la tarifa seleccionada"
Else
  MSG="Estį seguro de generar las "+num$(R)+" tarifas seleccionadas"
Endif
YN=1 # Por defecto es NO
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  End 0
Endif
End 1

Funprog PDTE_REV(TARF)
Value Char TARF
Local Char TXT(255)(12)
Local Char PDTE(255)
# Ver si en la tarifa indicada, hay articulos incluidos en revisiones abiertas que no hayamos revisado su precio
# Columna ZOK,   se usa para distinguir lineas sin revisar de lineas cuyo precio permanece igual
# Columna ZBAJA, se usa para indicar que no debe pasar al genera la nueva tarifa
TXT(0)="select distinct d.ZREVISION_0,d.ITMREF_0 "
TXT(1)="from ZGTARVD d inner join ZGTARVH h on h.ZREVISION_0=d.ZREVISION_0 "
TXT(2)="where h.CERRADO_0<>2 and d.ZGEN_0<>2 and d.ZBAJA_0<>2 and d.ZOK_0<>2 and d.PRECACTU_0=d.PRECNUEV_0 and d.PLICRD_0='"+TARF+"' "
TXT(3)="order by ZREVISION_0,ITMREF_0"
Raz PDTE
For (Decimal FULT,Char FITM(GLONITM)) From GFLDCHR(0) Sql TXT As [MYT]
  PDTE+=num$(FULT)+" "+FITM+"\"
Next
End PDTE

$GENERAR_TARIFAS
Local Integer O,R  #Usadas en     Gosub DATOS_PRECIO From SPEZGTAR2
Local Integer F,L
Local Char RTAR(GLONVCR)
O=2
#
#Recorrer rejilla y generar tarifas seleccionadas
#   AVISO !!!!    una tarifa puede estar varias veces, por ejemplo os fuera multiplanta
#                 Generarla una sola vez
#
######################################################
#  POR cada tarifa
#     Generar fichero e importarlo
#     Si importación OK
#         Marcar lineas cįlculo como generadas
#         Si todas lineas generadas, marcar cįlculo como cerrado
#         Actualizar fecha INI/FIN en tarifa antigua
######################################################
Raz RTAR
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2 and [M:ZGTAR1]SEL(F)=2
    If RTAR<>[M:ZGTAR1]PLICRD(F)
      RTAR=[M:ZGTAR1]PLICRD(F)
      Gosub GENERAR_TARIFA
      [M:ZGTAR1]ZGEN(F)=2
    Endif
  Endif
Next
Return

Funprog TARIFA_GENERADA(TARF)
Value Char TARF
Local Integer F,GENERADA
Raz GENERADA
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]PLICRD(F)=TARF and [M:ZGTAR1]ZGEN(F)=2
    GENERADA+=1
  Endif
Next
End GENERADA

$GENERAR_TARIFA
If func SPEZGTAR2.TODO_IGUAL([M:ZGTAR0]ZREVISION,RTAR) Return  Endif
If func TARIFA_GENERADA(RTAR) Return  Endif


Local Char STR(GLONSPX),SEP(1),MAT(GLONSPX)(0..4)
Local Decimal PRECIO
Local Date FFIN,FINI
Local Integer PR(3)

Update [F:WZTVD] Where [F:WZTVD]PLICRD=RTAR With ESTADO=""
# Trbegin [WTARF]
# La importacion silenciosa no permite definir trasacciones, pues ya las define ella y
# X3 NO SOPORTA anidamiento de trasacciones
# Variables para XML
Local Char WNOM(20),WJOB(10),WXML(250),WOUT(250),WDIR(250),WFICH(250)
# Comprobar directorio y crearlo en caso de que no exista
WDIR="ZIMPEXP\IMPOR"
TMP=filpath("","","","","",adxmac(0)) +"\" + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
# Abrir fichero
WNOM="ZSPL"    #   Modelo de importación
WJOB = num$(time)
WXML = WNOM+"_"+RTAR+"_"+format$("D:YYYYMMDD",date$)+"_"+WJOB
WOUT = filpath(WDIR,WXML,"xml")
Openo WOUT,0 Using [TIF]
# Inicio
Call XML_INICIO("UTF") From ZXML
Call XML_INICIO_NOMBRE(WNOM) From ZXML
#Cabecera Tarifa
Call XML_ABRE_ETIQUETA("E") From ZXML
Call XML_LINEA("SPF_PLI",[M:ZGTAR1]PLI(F))             From ZXML       # Tarifa
Call XML_LINEA("SPF_PLICRD","")                        From ZXML       # Nŗde tarifa
Call XML_LINEA("SPF_PLISTRDAT",format$("D:YYYY[-]MM[-]DD",[M:ZGTAR1]ZFECINI(F)))                From ZXML       # Fecha Inicio
Call XML_LINEA("SPF_PLIENDDAT",format$("D:YYYY[-]MM[-]DD",addmonth([M:ZGTAR1]ZFECINI(F),24)))   From ZXML       # Fecha Fin, 24 meses mas
#Lineas, paso todas las que hay actualmente en la tarifa, pero cambio el precio en caso de que se haya indicado un cįlculo en la fecha actual [M:ZGTAR0]ZFECHA
Raz PR
Filter [F:SPL] Where PLICRD=RTAR Order By PLICRD;PLILIN
For [F:SPL]
  #Criterios
  STR=[F:SPL]PLICRI
  SEP="~"
  Call ARRAY(STR,SEP,MAT) From ZCOMUN
  #Precio actual o nuevo
  PRECIO=[F:SPL]PRI


  Gosub DATOS_PRECIO From SPEZGTAR2
  If R<1 and [M:ZGTAR0]ZTIPO=2
    Call ECR_TRACE("Se asume precio actual. Linea ańadida a tarifa DESPUES de fijar cįlculo",-1) From GESECRAN
  Elsif R>1
    PRECIO=[F:SPL]PRI
    Call ECR_TRACE("Se asume precio actual. Linea encontrada en "+num$(R)+" cįlculos pdtes. Esto NO deberķa de ocurrir !!!",-1) From GESECRAN
  Endif

  If PRECIO=-99
    PR(2)+=1
  Elsif PRECIO=[F:SPL]PRI
    PR(0)+=1
  Else
    PR(1)+=1
  Endif
  #

  If PRECIO>0
    Call XML_ABRE_ETIQUETA("L") From ZXML
    Call XML_LINEA("SPL_L__7", MAT(0))                       From ZXML       # Criterio 1
    Call XML_LINEA("SPL_L__8", MAT(1))                       From ZXML       # Criterio 2
    Call XML_LINEA("SPL_L__9", MAT(2))                       From ZXML       # Criterio 3
    Call XML_LINEA("SPL_L__10",MAT(3))                       From ZXML       # Criterio 4
    Call XML_LINEA("SPL_L__11",MAT(4))                       From ZXML       # Criterio 5
    Call XML_LINEA("SPL_UOM",[F:SPL]UOM)                     From ZXML       # Unidad venta
    Call XML_LINEA("SPL_CUR",[F:SPL]CUR)                     From ZXML       # Moneda
    Call XML_LINEA("SPL_MINQTY","0")                         From ZXML       # Cantidad INI
    Call XML_LINEA("SPL_MAXQTY","9999999")                   From ZXML       # Cantidad FIN
    Call XML_LINEA("SPL_PRI",num$(PRECIO))                   From ZXML       # PRECIO
    Call XML_CIERRA_ETIQUETA("L") From ZXML
  Endif
Next
Filter [F:SPL]
Call XML_CIERRA_ETIQUETA("E") From ZXML
# Fin
Call XML_FIN(WNOM) From ZXML
Openo Using [TIF]   #Cerramos el fichero XML generado

#Return

# Lanzamos importación
#Infbox "DEPURAR"
Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
# De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
WFICH = filpath("ZIMPEXP\IMPOR",WXML,"XML.err")
If filinfo(WFICH,0) > 0 Then
#  Rollback
  MSG= "No se importaron los nuevos precios de tarifa "+RTAR+"\Debido a problemas en la importacion del fichero\"+WXML
  Call ERREURT(MSG,1)   From GESECRAN   #0-Informativo, 1-Error
  Call ECR_TRACE(MSG,1) From GESECRAN
  Return
Endif
#Commit
Call ECR_TRACE(num$(PR(0))+" lineas con el mismo precio que habia",0) From GESECRAN
Call ECR_TRACE(num$(PR(1))+" lineas NUEVO precio",0) From GESECRAN
Call ECR_TRACE(num$(PR(2))+" lineas dadas de baja",0) From GESECRAN
Call ECR_TRACE(num$(PR(0)+PR(1))+" total lineas ańadidas en nueva tarifa",0) From GESECRAN
# Actualizar fecha INI/FIN en tarifa antigua
#Determinar fecha fin.....Dia anterior al de inicio de la nueva
FFIN=nday$(nday([M:ZGTAR1]ZFECINI(F))-1)
#Determinar fecha Ini.....Si INI>FFIN entonces INI=FFIN
Read [F:SPF]SPF0=[M:ZGTAR1]PLI(F);[M:ZGTAR1]PLICRD(F)
If [F:SPF]PLISTRDAT<FFIN
  FINI=[F:SPF]PLISTRDAT
Else
  FINI=FFIN
Endif
[F:SPF]PLISTRDAT=FINI
[F:SPF]PLIENDDAT=FFIN
Rewrite [F:SPF]
Update [F:SPL] Where [F:SPL]PLI=[F:SPF]PLI and [F:SPL]PLICRD=[F:SPF]PLICRD With [F:SPL]PLISTRDAT=FINI,[F:SPL]PLIENDDAT=FFIN
Call ECR_TRACE("Tarifa "+[M:ZGTAR1]PLI(F)+"  "+[M:ZGTAR1]PLICRD(F)+" vigencia actualizada a "+format$("DD[/]MM[/]YY",FINI)+"  "+format$("DD[/]MM[/]YY",FFIN),0) From GESECRAN
Call ECR_TRACE("PROCESO TERMINADO",0) From GESECRAN
Return

Subprog TODO_CALCULADO()
If !clalev([F:WZTVH])      :  Local File ZGTARVH   [F:WZTVH]  : Endif
If !clalev([F:WZTVD])      :  Local File ZGTARVD   [F:WZTVD]  : Endif
Filter  [F:WZTVD]
Filter  [F:WZTVD] Where ZREVISION=[M:ZGTAR0]ZREVISION and ZGEN<>2
If rowcount([F:WZTVD])<1
  Update [F:WZTVH] Where [F:WZTVH]ZREVISION=[M:ZGTAR0]ZREVISION With [F:WZTVH]CERRADO=2
  Call ECR_TRACE("Calculo "+num$([M:ZGTAR0]ZREVISION)+" marcado como cerrado, al estar todas sus lineas generadas",0) From GESECRAN
Endif
Filter  [F:WZTVD]
End
