#<AdxTL>@(#)0.0.0.0 $Revision$
#AUR01 11/01/2022 ML Ordenamiento de grilla Lineas por artķculo
# Gestión de la mįscara ZGTAR0 (Especifico)

Subprog C_ZREVISION(VALEUR)
Variable Char VALEUR
End

Subprog IB_NBLIG
Local Integer F
F=nolign-1
Raz GBOUT1
If [M:ZGTAR0]ZPOR(F)<>0 or [M:ZGTAR0]ZFIJO(F)<>0
  GBOUT1="Limpiar"
Endif
End

Subprog B1_NBLIG
Local Integer F,L
L=nolign-1
Raz [M:ZGTAR0]ZPOR(L),[M:ZGTAR0]ZFIJO(L)
Affzo [M:ZGTAR0]ZPOR(L)
Affzo [M:ZGTAR0]ZFIJO(L)
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2
    If func OK_TIPO(L,F)
      Raz [M:ZGTAR1]ZPOR(F),[M:ZGTAR1]ZFIJO(F)
      Affzo [M:ZGTAR1]ZPOR(F)
      Affzo [M:ZGTAR1]ZFIJO(F)
      Call CALCULAR(F)
    Endif
  Endif
Next
End

Subprog AM_ZTIPO(VALEUR)
Variable Integer VALEUR
#Infbox "Subprog AM_ZTIPO"
[M:ZGTAR0]ZTIPO=VALEUR
Call ESTADO From SUBZGTAR
End

Subprog AP_ZBASE(VALEUR)
Variable Decimal VALEUR
#Infbox "Subprog AP_ZBASE"
#[M:ZGTAR0]ZBASE=VALEUR
#Call ESTADO From SUBZGTAR
End

Subprog AM_ZBASE(VALEUR)
Variable Decimal VALEUR
Local Decimal RVAL
Local Integer R
RVAL=[M:ZGTAR0]ZBASE
[M:ZGTAR0]ZBASE=VALEUR
If (VALEUR <=0 and RVAL>0) or (VALEUR >0 and RVAL=0)
  Call VACIAR_REJILLAS(0) From SUBZGTAR
  Call ESTADO From SUBZGTAR
  R=1
Endif
#Solo se puede cambiar en ALTAS  GREP="C" or "D"
#En modificaciones, no se puede  GREP="M"
If [M:ZGTAR0]ZITMREF<>""
  Call ITM_DATOS([M:ZGTAR0]ZITMREF,[M:ZGTAR0]FCY,0)
  If [M:ZGTAR1]NBLIG<=0 #GREP="C" or GREP="D"# or GREP="M"
    Call CARGAR_TARIFAS_ITM([M:ZGTAR0]ZITMREF)
#  Elsif GREP="M"
  Else
    Call REVISAR_CALCULOS
  Endif
Elsif R=1
  Affzo [M:ZGTAR1]5
Endif
End

Subprog AM_PLI(VALEUR)
Variable Char VALEUR
Local Integer RGT
#Infbox "Depurar"
If (GREP="C" or GREP="D")
  RGT=func TAR_EN_PROCESO(VALEUR)
  If RGT>0
    MSG="Imposible continuar\La tarifa indicada estį incluido en " + num$(RGT) + " filas de tarifas\pendientes de cįlculo  o  anulación"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Elsif not func TAR_DATOS(VALEUR)
    mkstat=2
    End
  Else
    Call CARGAR_TARIFA(VALEUR)
  Endif
Else
  VALEUR=[M:ZGTAR0]PLI
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:ZGTAR0]FCY=VALEUR
If [M:ZGTAR0]ZITMREF<>""
  Call AM_ZITMREF([M:ZGTAR0]ZITMREF)
Endif
End


Subprog AM_ZITMREF(VALEUR)
Variable Char VALEUR
Local Integer RGT
#Infbox "Depurar"
#[M:ZGTAR0]ZITMREF=VALEUR
Call ITM_DATOS(VALEUR,[M:ZGTAR0]FCY,1)
If (GREP="C" or GREP="D")
  RGT=func ART_EN_PROCESO(VALEUR,11,-1)
  If RGT<=0
    RGT=func ART_EN_PROCESO(VALEUR,12,-1)
  Endif
  If RGT>0
    MSG="Imposible continuar\El articulo indicado estį incluido en " + num$(RGT) + " filas de tarifas\pendientes de cįlculo  o  anulación"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Else
    Call CARGAR_TARIFAS_ITM(VALEUR)
  Endif
Else
  VALEUR=[M:ZGTAR0]ZITMREF
Endif
End

Subprog AM_ZPOR(VALEUR)
Variable Decimal VALEUR
Local Decimal RVAL
RVAL=[M:ZGTAR0]ZPOR(nolign-1)
[M:ZGTAR0]ZPOR(nolign-1)=VALEUR
Call REVISAR_CALCULOS_TIPO_CTE(nolign-1,RVAL,[M:ZGTAR0]ZFIJO(nolign-1))
Call VACIAR_REJILLA2 From SUBZGTAR
End

Subprog AM_ZFIJO(VALEUR)
Variable Decimal VALEUR
Local Decimal RVAL
RVAL=[M:ZGTAR0]ZFIJO(nolign-1)
[M:ZGTAR0]ZFIJO(nolign-1)=VALEUR
Call REVISAR_CALCULOS_TIPO_CTE(nolign-1,[M:ZGTAR0]ZPOR(nolign-1),RVAL)
Call VACIAR_REJILLA2 From SUBZGTAR
End




Subprog ITM_DATOS(ITMP,FCYP,DE_ART)
Value Char ITMP,FCYP
Value Integer DE_ART
If !clalev([F:ITM])      :  Local File ITMMASTER [F:ITM]  : Endif
Read [F:ITM]ITM0=ITMP
#Mostramos como base el PMP del articulo
If (GREP="C" or GREP="D") and (DE_ART or [M:ZGTAR0]ZBASE<0)
  If !clalev([F:ITV])      :  Local File ITMMVT [F:ITV]  : Endif
  Read [F:ITV]ITV0=ITMP;FCYP
  Raz [M:ZGTAR0]ZBASE
  If [F:ITV]AVCBASQTY<>0
    [M:ZGTAR0]ZBASE  =arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,0.0001)
  Endif
  Call ESTADO From SUBZGTAR
Endif
[M:ZGTAR0]ZBASEM2=arr([M:ZGTAR0]ZBASE*[ITM]ZFACTOR,0.0001)
Affzo [M:ZGTAR0]ZBASEM2
Affzo [M:ZGTAR0]ZBASE
End

Subprog CARGAR_TARIFA(TARF)
Value Char TARF
#Llenar rejilla Tipo/Subtipo cliente
Call CARGAR_TARIFA_LLENAR_REJILLA_TIPO_CTE(TARF)
If [M:ZGTAR0]NBLIG<=0
  mkstat=2
  End
Endif
#Llenar rejilla lineas
Call CARGAR_TARIFA_LINEAS(TARF)
End


Funprog TAR_DATOS(TARF)
Value Char TARF
Local Integer F,R,D(5),OK
If !clalev([F:SPC])      :  Local File SPRICCONF [F:SPC]  : Endif
OK=1
Read [F:SPC]SPC0=TARF
If [F:SPC]PLIENAFLG<>2
  Call ERREURT("Tarifa INACTIVA", 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Endif
Raz R,D
For F=0 To 4
  If [F:SPC]ABB(F)="BPC" and [F:SPC]FLD(F)="TSCCOD" and ([F:SPC]FLDTYPCPL(F)="30" or [F:SPC]FLDTYPCPL(F)="31")
    If [F:SPC]FLDTYPCPL(F)="30"
      D(0)=F+1
    Else
      D(1)=F+1
    Endif
    R+=1
  Endif
Next
If R<>2
  Call ERREURT("Tarifa no es del tipo esperado\Tipo Cte + Subtipo Cte", 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Endif
[M:ZGTAR0]NADA1  =num$(D(0)-1)+num$(D(1)-1) # Me guardo el nŗ de campo/posición correspondiente a Tipo+Subtipo
End OK

Subprog CARGAR_TARIFA_LINEAS(TARF)
Value Char TARF
Local Integer D0,D1,F,RF
Local Char TXT(255)(10),FL(255),DTARF(255)
#Local Integer F
#If !clalev([F:WTRF])      :  Local File SPRICLIST [F:WTRF]  : Endif
#FL="PLICRI"+num$(D(0))+",PLICRI"+num$(D(1))+",PLILIN "
#Filter [F:WTRF] Where PLI=TARF Order By PLICRD;PLILIN
#Gosub LLENAR_LINEAS
#Filter [F:WTRF]
#Sacar tarifas a mostrar
Raz DTARF,RF
For F=0 To [M:ZGTAR0]NBLIG-1
  If DTARF<>""    DTARF+=","   Endif
  DTARF+="'"+[M:ZGTAR0]ZPLICRD(F)+"'"
Next
#
D0=val(mid$([M:ZGTAR0]NADA1,1,1))+1
D1=val(mid$([M:ZGTAR0]NADA1,2,1))+1
Raz TXT
FL="PLICRI"+num$(D0)+"_0,PLICRI"+num$(D1)+"_0,PLILIN_0 "
TXT(0)="select PRI_0,PLI_0,PLICRD_0,PLILIN_0 "
TXT(1)="from SPRICLIST "
TXT(2)="where PLI_0='"+TARF+"' and PLICRD_0 in ("+DTARF+") "
TXT(3)="order by "+FL
Gosub LLENAR_LINEAS
End

Subprog CARGAR_TARIFA_LLENAR_REJILLA_TIPO_CTE(TARF)
Value Char TARF
Local Integer D0,D1
Local Char TXT(255)(10),FL(255)
Local Integer F
Call VACIAR_REJILLAS(0) From SUBZGTAR
# Sacar tarifas cuyo     Fecha_fin > Dia_de_hoy
D0=val(mid$([M:ZGTAR0]NADA1,1,1))+1
D1=val(mid$([M:ZGTAR0]NADA1,2,1))+1
FL="PLICRI"+num$(D0)+"_0,PLICRI"+num$(D1)+"_0 "
TXT(0)="select distinct PLICRD_0,"+FL
TXT(1)="from SPRICLIST "
TXT(2)="where PLI_0='"+TARF+"' and PLIENDDAT_0>getdate()"
TXT(3)="order by "+FL
For (Char FTR(GLONVCR),Char FD0(GLONADI),Char FD1(GLONADI)) From GFLDCHR(0) Sql TXT As [MYT]
  F=[M:ZGTAR0]NBLIG
  [M:ZGTAR0]ZPLICRD(F) =FTR
  [M:ZGTAR0]ZTSCCOD0(F)=FD0
  [M:ZGTAR0]ZTSCCOD1(F)=FD1
  If [M:ZGTAR0]NBLIG+1>=GFLDNUM(0)
    MSG="Alcanzado mįximo de " + num$(GFLDNUM(0)+1) + " filas para mostrar Tip/Subtipo Ctes\.\Avise para que se lo aumenten"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Call VACIAR_REJILLAS(0) From SUBZGTAR
    Break
  Else
    [M:ZGTAR0]NBLIG+=1
  Endif
Next
Affzo [M:ZGTAR0]10
End

Subprog CARGAR_REJILLA_TIPO_CTE(REV)
Value Integer REV
Local Integer F
If !clalev([F:ZTVH1])      :  Local File ZGTARVH1 [F:ZTVH1]  : Endif
Filter [F:ZTVH1] Where ZREVISION=REV Order By ZTSCCOD0;ZTSCCOD1
For [F:ZTVH1]
  F=[M:ZGTAR0]NBLIG
  [M:ZGTAR0]ZTSCCOD0(F)=[F:ZTVH1]ZTSCCOD0
  [M:ZGTAR0]ZTSCCOD1(F)=[F:ZTVH1]ZTSCCOD1
  [M:ZGTAR0]ZPOR(F)    =[F:ZTVH1]ZPOR
  [M:ZGTAR0]ZFIJO(F)   =[F:ZTVH1]ZFIJO
  [M:ZGTAR0]NBLIG+=1
Next
Affzo [M:ZGTAR0]10
End

Subprog CARGAR_TARIFAS_ITM_RESTO(ITMP)
Value Char ITMP
Local Char TXT(255)(15)
Local Integer F,RF,R

#If GUSER="ADMIN"
#Infbox "Depurar"
#Endif
#If GUSER<>"ADMIN"    End     Endif
If [M:ZGTAR0]ZTIPO<>1 or [M:ZGTAR0]FCY="" or ((GREP="C" or GREP="D") and date$>=[01/06/2017])     End     Endif

#Averiguar si ya lo hemos ańadido
Raz TXT,RF
TXT(0)="select count(*) "
TXT(1)="from ZGTARVD "
TXT(2)="where ZREVISION_0="+num$([M:ZGTAR0]ZREVISION)+" and not PLICRI_0 like '"+[M:ZGTAR0]FCY+"~%'"
For (Integer FRGT)From GFLDCHR(0) Sql TXT As [WTRF]
  F=[WTRF]FRGT
Next
If F>0   End    Endif

#Ańadir los registros del resto de plantas
Raz TXT
TXT(0)="select PRI_0,l.PLI_0,l.PLICRD_0,PLILIN_0 "
TXT(1)="from SPRICLIST l "
TXT(2)="inner join SPRICCONF e on l.PLI_0=e.PLI_0 "
TXT(3)="where PLIENAFLG_0=2 and getdate()>=l.PLISTRDAT_0 and getdate()<=l.PLIENDDAT_0 and "
TXT(4)="((PLICRI1_0='"+ITMP+"' and ABB_0='ITM' and FLD_0='ITMREF') or (PLICRI2_0='"+ITMP+"' and ABB_1='ITM' and FLD_1='ITMREF') or "
TXT(5)= "(PLICRI3_0='"+ITMP+"' and ABB_2='ITM' and FLD_2='ITMREF') or (PLICRI4_0='"+ITMP+"' and ABB_3='ITM' and FLD_3='ITMREF') or "
TXT(6)= "(PLICRI5_0='"+ITMP+"' and ABB_4='ITM' and FLD_4='ITMREF')) "
TXT(7)="and "
TXT(8) ="((PLICRI1_0<>'"+[M:ZGTAR0]FCY+"' and ABB_0='SPK' and FLD_0='SALFCY') or (PLICRI2_0<>'"+[M:ZGTAR0]FCY+"' and ABB_1='SPK' and FLD_1='SALFCY') or "
TXT(9) = "(PLICRI3_0<>'"+[M:ZGTAR0]FCY+"' and ABB_2='SPK' and FLD_2='SALFCY') or (PLICRI4_0<>'"+[M:ZGTAR0]FCY+"' and ABB_3='SPK' and FLD_3='SALFCY') or "
TXT(10)= "(PLICRI5_0<>'"+[M:ZGTAR0]FCY+"' and ABB_4='SPK' and FLD_4='SALFCY')) "
TXT(11)="order by PLI_0,l.PLICRD_0,PLILIN_0"
RF=-99 # Para evitar que se borre la rejilla con registros actuales, pues deseamos ańadir a los existentes
R=[M:ZGTAR1]NBLIG
Gosub LLENAR_LINEAS
If [M:ZGTAR1]NBLIG>R
  Infbox "IMPORTANTE !!!!  No olvide situarse en rejilla para activa Registrar, tras lo cual hacer click"
Endif
If [M:ZGTAR1]NBLIG>R   GZFLG=1    Endif
End

Subprog CARGAR_TARIFAS_ITM(ITMP)
Value Char ITMP
Local Char TXT(255)(15)
Local Integer F,RF
#Sacar todas las lineas de tarifas que cumplan:
#   activas
#   fecha_fin > Fecha_de_hoy
#   donde aparece el articulo
#
#If !clalev([F:SPL])      :  Local File SPRICLIST [F:SPL]  : Endif
#If !clalev([F:SPF])      :  Local File SPRICFICH [F:SPF]  : Endif
#If !clalev([F:SPC])      :  Local File SPRICCONF [F:SPC]  : Endif
#Link [SPL] With [SPC]SPC0=[F:SPL]PLI As [WTRF]
#&          Where [SPC]PLIENAFLG=2 and (PLICRI1=ITMP and [SPC]ABB(0)='ITM') or (PLICRI2=ITMP and [SPC]ABB(1)='ITM') or
#&                                     (PLICRI3=ITMP and [SPC]ABB(2)='ITM') or (PLICRI4=ITMP and [SPC]ABB(3)='ITM') or
#&                                     (PLICRI5=ITMP and [SPC]ABB(4)='ITM')
#OK=1
Raz TXT,F
TXT(0)="select PRI_0,l.PLI_0,l.PLICRD_0,PLILIN_0 "
TXT(1)="from SPRICLIST l "
TXT(2)="inner join SPRICCONF e on l.PLI_0=e.PLI_0 "
TXT(3)="where PLIENAFLG_0=2 and getdate()>=l.PLISTRDAT_0 and getdate()<=l.PLIENDDAT_0 and "
TXT(4)="((PLICRI1_0='"+ITMP+"' and ABB_0='ITM' and FLD_0='ITMREF') or (PLICRI2_0='"+ITMP+"' and ABB_1='ITM' and FLD_1='ITMREF') or "
TXT(5)= "(PLICRI3_0='"+ITMP+"' and ABB_2='ITM' and FLD_2='ITMREF') or (PLICRI4_0='"+ITMP+"' and ABB_3='ITM' and FLD_3='ITMREF') or "
TXT(6)= "(PLICRI5_0='"+ITMP+"' and ABB_4='ITM' and FLD_4='ITMREF')) "
#31-05-17 Se acuerda NO acotar por PLANTA, pues si una tarifa es multiplanta, se han de revisar todos sus precios !!!!!
#         tanto si es por articulos como par tarifa
##If [M:ZGTAR0]FCY<>""
##TXT(7)="and "
##TXT(8) ="((PLICRI1_0='"+[M:ZGTAR0]FCY+"' and ABB_0='SPK' and FLD_0='SALFCY') or (PLICRI2_0='"+[M:ZGTAR0]FCY+"' and ABB_1='SPK' and FLD_1='SALFCY') or "
##TXT(9) = "(PLICRI3_0='"+[M:ZGTAR0]FCY+"' and ABB_2='SPK' and FLD_2='SALFCY') or (PLICRI4_0='"+[M:ZGTAR0]FCY+"' and ABB_3='SPK' and FLD_3='SALFCY') or "
##TXT(10)= "(PLICRI5_0='"+[M:ZGTAR0]FCY+"' and ABB_4='SPK' and FLD_4='SALFCY')) "
##Endif

#TXT(6)="order by PRI_0,l.PLI_0,l.PLICRD_0,PLILIN_0"
TXT(11)="order by PLI_0,l.PLICRD_0,PLILIN_0"
#If GUSER="ADMIN"
#Local Integer YN
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  End
#Endif
#Endif

$LLENAR_LINEAS
If !clalev([F:SPL])      :  Local File SPRICLIST [F:SPL]  : Endif
If RF<>-99
  Call VACIAR_REJILLAS(1) From SUBZGTAR
Endif
Local Char D(1)
For (Decimal FPRE,Char FPLI(GLONSPC),Char FCRD(GLONVCR),Integer FLIN) From GFLDCHR(0) Sql TXT As [WTRF]
  Gosub LINEA_ANADIDA
  F=[M:ZGTAR1]NBLIG
  Insa F,1,[M:ZGTAR1]NBLIG [M:ZGTAR1]NBLIG
  Gosub LLENA_FILA_GRID
  If [M:ZGTAR0]ZTIPO=1
    RGT=func ART_EN_PROCESO([M:ZGTAR1]ITMREF(F),[M:ZGTAR0]ZTIPO,F)
    If RGT>0
      [M:ZGTAR1]ZGEN(F)=2
#      [M:ZGTAR1]SEL(F) =1
      Chgstl [M:ZGTAR1]NBLIG(F) With "BACKRED"
    Endif
  Else
    RGT=func ART_EN_PROCESO([M:ZGTAR1]ITMREF(F),[M:ZGTAR0]ZTIPO,F)
    If RGT>0
      MSG="Imposible continuar\El articulo "+[M:ZGTAR1]ITMREF(F)+ " estį incluido en " + num$(RGT) + " filas de tarifas\pendientes de cįlculo  o  anulación"
      Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
      Call VACIAR_REJILLAS(1) From SUBZGTAR
      Break
    Endif
  Endif
  If [M:ZGTAR1]NBLIG+1>=GFLDNUM(1)
    MSG="Alcanzado mįximo de " + num$(GFLDNUM(1)+1) + " filas para mostrar lineas de tarifa\.\Avise para que se lo aumenten"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Call VACIAR_REJILLAS(1) From SUBZGTAR
    Break
  Else
    [M:ZGTAR1]NBLIG+=1
#    Break
  Endif
Next
#AUR01.ini
Sorta [M:ZGTAR1]NBLIG [M:ZGTAR1]NBLIG Order By [M:ZGTAR1]ITMREF([S]indice) Asc
#AUR01.fin
Affzo [M:ZGTAR1]5
If RF=-99    Return   Endif
End

$LLENA_FILA_GRID
Read [F:SPL]SPL0=[WTRF]FPLI;[WTRF]FCRD;[WTRF]FLIN
D=func ITM_TARIFA([F:SPL]PLI)
#[M:ZGTAR1]SEL(F)     =2
[M:ZGTAR1]PLI(F)     =[F:SPL]PLI
[M:ZGTAR1]PLICRD(F)  =[F:SPL]PLICRD
[M:ZGTAR1]PLICRI(F)  =[F:SPL]PLICRI
[M:ZGTAR1]PLILIN(F)  =[F:SPL]PLILIN
[M:ZGTAR1]ITMREF(F)  =evalue("[F:SPL]PLICRI"+D)
[M:ZGTAR1]CUR(F)     =[F:SPL]CUR
[M:ZGTAR1]UOM(F)     =[F:SPL]UOM
[M:ZGTAR1]PRECACTU(F)=[F:SPL]PRI
[M:ZGTAR1]VIGENCIA(F)=format$("DD[/]MM[/]YY",[F:SPL]PLISTRDAT)+"  "+format$("DD[/]MM[/]YY",[F:SPL]PLIENDDAT)
If RF=-99
  If [M:ZGTAR0]ZBASE>0
    Call ZPORBASE_TAR(F)
  Endif
  Call CALCULAR(F)
Endif
Return

Subprog ZPORBASE_TAR(L)
Value Integer L
Local Decimal BASE
Local Integer F
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]PLICRD(F)=[M:ZGTAR1]PLICRD(L) and ([M:ZGTAR1]ZPORBASE(F)<>0 or [M:ZGTAR1]ZOK(F)=2 or [M:ZGTAR1]ZBAJA(F)=2)
    [M:ZGTAR1]ZPORBASE(L)=[M:ZGTAR1]ZPORBASE(F)
    [M:ZGTAR1]ZFECINI(L) =[M:ZGTAR1]ZFECINI(F)
    [M:ZGTAR1]ZOK(L)     =[M:ZGTAR1]ZOK(F)
    [M:ZGTAR1]ZBAJA(L)   =[M:ZGTAR1]ZBAJA(F)
    Break
  Endif
Next
End

Funprog ITM_TARIFA(TARF)
Value Char TARF
Local Integer F
Local Char D(1)
If !clalev([F:SPC])      :  Local File SPRICCONF [F:SPC]  : Endif
Read [F:SPC]SPC0=TARF
D="1"
For F=0 To 4
  If [F:SPC]ABB(F)="ITM" and [F:SPC]FLD(F)="ITMREF"
    D=num$(F+1)
    Break
  Endif
Next
End D

Subprog REVISAR_CALCULOS_TIPO_CTE(L,RPOR,RFIJ)
Value Integer L
Value Decimal RPOR,RFIJ
Local Integer F
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2
    #Comprobar si linea corresponde a Tipo/Subtipo
    If func OK_TIPO(L,F)
      If [M:ZGTAR1]ZPOR(F)=0 or [M:ZGTAR1]ZPOR(F)=RPOR
        [M:ZGTAR1]ZPOR(F) =[M:ZGTAR0]ZPOR(L)
        Affzo [M:ZGTAR1]ZPOR(F)
        Call CALCULAR(F)
      Elsif [M:ZGTAR1]ZPOR(F) <>[M:ZGTAR0]ZPOR(L)
        Chgstl [M:ZGTAR1]ZPOR(F) With "BACKYELLOW"
      Endif
      If [M:ZGTAR1]ZFIJO(F)=0 or [M:ZGTAR1]ZFIJO(F)=RFIJ
        [M:ZGTAR1]ZFIJO(F) =[M:ZGTAR0]ZFIJO(L)
        Affzo [M:ZGTAR1]ZFIJO(F)
        Call CALCULAR(F)
      Elsif [M:ZGTAR1]ZFIJO(F) <>[M:ZGTAR0]ZFIJO(L)
        Chgstl [M:ZGTAR1]ZFIJO(F) With "BACKYELLOW"
      Endif
    Endif
  Else
    Gosub COLOR_ZGEN
  Endif
Next
End

Funprog OK_TIPO(L,F)
Value Integer L,F
Local Integer D0,D1,OK
Local Char STR(GLONSPX),SEP(1),MAT(GLONSPX)(0..4)
STR=[M:ZGTAR1]PLICRI(F)
SEP="~"
Call ARRAY(STR,SEP,MAT) From ZCOMUN
D0=val(mid$([M:ZGTAR0]NADA1,1,1))
D1=val(mid$([M:ZGTAR0]NADA1,2,1))
If MAT(D0)=[M:ZGTAR0]ZTSCCOD0(L) and MAT(D1)=[M:ZGTAR0]ZTSCCOD1(L)
  OK=1
Else
  OK=0
Endif
End OK

Subprog REVISAR_CALCULOS
Local Integer F
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)<>2
    Call CALCULAR(F)
  Else
    Gosub COLOR_ZGEN
  Endif
Next
#Affzo [M:ZGTAR1]5
End

$COLOR_ZGEN
If [M:ZGTAR1]ZFECGEN(F)=[0/0/0]
  Chgstl [M:ZGTAR1]NBLIG(F) With "BACKORANGE"
Else
  Chgstl [M:ZGTAR1]NBLIG(F) With "BACKGREEN"
Endif
Return

Subprog CALCULAR(F)
Value Integer F
Local Decimal V,RPREC
RPREC=[M:ZGTAR1]PRECNUEV(F)
If [M:ZGTAR0]ZBASE>0
  If [M:ZGTAR1]ZPORBASE(F)=0
    V=[M:ZGTAR1]PRECACTU(F)
  Else
    If [M:ZGTAR1]UOM(F)="M2"
      V=[M:ZGTAR0]ZBASEM2 / ( (100-[M:ZGTAR1]ZPORBASE(F)) /100)
    Else
      V=[M:ZGTAR0]ZBASE   / ( (100-[M:ZGTAR1]ZPORBASE(F)) /100)
    Endif
  Endif
Else
  V=[M:ZGTAR1]PRECACTU(F)
  #1ŗ Aplicar %
  V+=[M:ZGTAR1]PRECACTU(F)*[M:ZGTAR1]ZPOR(F)/100
  #2ŗ Aplicar Fijo
  V+=[M:ZGTAR1]ZFIJO(F)
Endif
If [M:ZGTAR1]UOM(F)="M2"
  [M:ZGTAR1]PRECNUEV(F)=arr(V,0.001)
Else
  [M:ZGTAR1]PRECNUEV(F)=arr(V,0.01)
Endif
[M:ZGTAR1]PRECDIF(F) =[M:ZGTAR1]PRECNUEV(F)-[M:ZGTAR1]PRECACTU(F)
If [M:ZGTAR1]PRECDIF(F)=0 and ([M:ZGTAR1]ZPORBASE(F)<>0 or [M:ZGTAR1]ZPOR(F)<>0 or [M:ZGTAR1]ZFIJO(F))
  [M:ZGTAR1]ZOK(F)=2
Endif
If [M:ZGTAR1]PRECACTU(F)=0
  [M:ZGTAR1]PRECDIFP(F)=100
Else
  [M:ZGTAR1]PRECDIFP(F)=arr([M:ZGTAR1]PRECDIF(F)*100/[M:ZGTAR1]PRECACTU(F),0.01)
Endif
Affzo [M:ZGTAR1]PRECNUEV(F)
Affzo [M:ZGTAR1]PRECDIF(F)
Affzo [M:ZGTAR1]PRECDIFP(F)
Affzo [M:ZGTAR1]ZOK(F)
If RPREC<>[M:ZGTAR1]PRECNUEV(F) and RPREC<>0  # RPREC=0 Linea ańadida
  Gosub LINEA_CAMBIADA
  If [M:ZGTAR1]PRECACTU(F)<>[M:ZGTAR1]PRECNUEV(F)
    Chgstl [M:ZGTAR1]NBLIG(F) With "BACKYELLOW"
  Else
    Chgstl [M:ZGTAR1]NBLIG(F) With ""
    If not (GREP="C" or GREP="D")
      Chgstl [M:ZGTAR1]PRECNUEV(F) With "BACKYELLOW"
    Endif
  Endif
Elsif [M:ZGTAR1]ZGEN(F)=2
  Gosub COLOR_ZGEN
Else
  Chgstl [M:ZGTAR1]NBLIG(F) With ""
Endif
End


Subprog COLORES(T)
Value Integer T
Local Integer F
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZGEN(F)=2
    Gosub COLOR_ZGEN
  Else
    If T=0
#      If [M:ZGTAR1]PRECACTU(F)<>[M:ZGTAR1]PRECNUEV(F) and ([M:ZGTAR1]UPDFLG(F)=1 or [M:ZGTAR1]CREFLG(F)=1)
#        Chgstl [M:ZGTAR1]PRECACTU(F) With "BACKCYAN"
#      Endif
    Else
      If [M:ZGTAR1]PRECACTU(F)<>[M:ZGTAR1]PRECNUEV(F)
        Chgstl [M:ZGTAR1]PRECACTU(F) With "BACKYELLOW"
        Chgstl [M:ZGTAR1]PRECNUEV(F) With "BACKYELLOW"
      Else

      Endif
    Endif
  Endif
#  #
#  If [M:ZGTAR0]ZTIPO=1
#    Affzo [M:ZGTAR1]ZPORBASE(F)
#  Else
#    Affzo [M:ZGTAR1]ZPOR (F)
#    Affzo [M:ZGTAR1]ZFIJO(F)
#  Endif
Next
End


$LINEA_ANADIDA
nolign=[M:ZGTAR1]NBLIG+1
status=73
Call INSERE("NUMLIN") From TABLEAUX
If mkstat End : Endif
status=0
Return

$LINEA_CAMBIADA
nolign=F+1
status=71
Call LINNUM("NUMLIN") From TABLEAUX
If mkstat End : Endif
status=0
Return

Funprog LINEAS_GENERADAS(L)
Variable Integer L
#Local Integer F,L
#Raz L
#For F=0 To [M:ZGTAR1]NBLIG-1
#  If [M:ZGTAR1]ZGEN(F)=2
#    L+=1
#  Endif
#Next
#End L
Local Char TXT(255)(10)
Local Integer RGT
Raz RGT
TXT(0)="select count(*) from ZGTARVD where ZREVISION_0="+num$([M:ZGTAR0]ZREVISION)+" and ZGEN_0=2"
For (Integer FRGT) From GFLDCHR(0) Sql TXT As [MYT]
  RGT=[MYT]FRGT
Next
Raz L
TXT(0)="select count(*) from ZGTARVD where ZREVISION_0="+num$([M:ZGTAR0]ZREVISION)
For (Integer FRGT) From GFLDCHR(0) Sql TXT As [MYT]
  L=[MYT]FRGT
Next
End RGT


Funprog ART_EN_PROCESO(ITMP,TIPO,F)
Value Char ITMP
Value Integer TIPO,F
Local Char TXT(255)(10)
Local Integer RGT
Raz RGT
#TXT(0)="select count(*) from ZGTARVD where ITMREF_0='"+ITMP+"' and ZGEN_0<>2"
TXT(0)="select count(*) "
TXT(1)="from ZGTARVH c inner join ZGTARVD l on c.ZREVISION_0=l.ZREVISION_0 "
TXT(2)="where ITMREF_0='"+ITMP+"' and ZGEN_0<>2 and c.ZREVISION_0<>"+num$([M:ZGTAR0]ZREVISION)
Case TIPO
When 1
  TXT(3)=" and PLICRD_0='"+[M:ZGTAR1]PLICRD(F)+"'"
When 2
  TXT(3)=" and ZTIPO_0=1"
When 11
  TXT(2)="where ZITMREF_0='"+ITMP+"' and ZGEN_0<>2"
When 12
#  TXT(3)=" and ZTIPO_0=2"
Endcase
#If [M:ZGTAR0]FCY<>""
#TXT(2)+=" and c.FCY_0='"+[M:ZGTAR0]FCY+"'"
#Endif
For (Integer FRGT) From GFLDCHR(0) Sql TXT As [MYT]
  RGT=[MYT]FRGT
Next
End RGT

Funprog TAR_EN_PROCESO(TARP)
Value Char TARP
Local Char TXT(255)(10)
Local Integer RGT
Raz RGT
TXT(0)="select count(*) from ZGTARVD where PLI_0='"+TARP+"' and ZGEN_0<>2"
For (Integer FRGT) From GFLDCHR(0) Sql TXT As [MYT]
  RGT=[MYT]FRGT
Next
End RGT


