#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "ZCALPRE"   :   Gosub ZCALPRE
Endcase
Return

#Tarifa 101: CRIT1 Planta / CRIT2 Pais / CRIT3 Clietne / CRIT4 artículo
#Resto tarifas:  CRIT1 Planta / CRIT2 Pais / CRIT3 Tipo / CRIT4 Subtipo / CRIT5 articulo
$ZCALPRE
#If [F:SPI]CRIT1="200" and [F:SPI]CRIT5="100"
#Dbgaff
#Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
Raz [F:ITF]
If [F:SPI]PLI="101"
   Read [F:ITF]ITF0=[F:SPI]CRIT4;[F:SPI]CRIT1
Else
   Read [F:ITF]ITF0=[F:SPI]CRIT5;[F:SPI]CRIT1
Endif
#If [F:ITF]ZPRETAR<>0
   MNTV = [F:ITF]ZPRETAR*(1+PORINC/100)
#Endif
Return
