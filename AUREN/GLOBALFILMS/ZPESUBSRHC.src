#<AdxTL>@(#)0.0.0.0 $Revision$
#<< JLPR 25.10 >>
#REAJUST     -> WQTYSAU no redondea a decimales establecidos para QTY
#            -> Call QTEARR.... si redondea
#            -> If WQTYSAU=WQTY no se cumple e interpreta que es un cambio de unidad
#     WQTYSAU=LQTYSTU / [M:SRH1]SAUSTUCOE(NOL)
#     WQTY=WQTYSAU
#     Call QTEARR(WQTY,[M:SRH1]SAU(NOL)) From TRTDIV
#     # Point d'entrée pour ajuster la qté retour calculée
#     GPOINT="REAJUST" : Gosub ENTREE From EXEFNC
#     If WQTYSAU=WQTY
#
#
#ALIPICSRH  , lo uso para quitar lotes devueltos parcialmente de [M:ENT]


$ACTION
Case ACTION
When "REAJUST"   : Gosub REAJUST
When "ALIPICSRH" : Gosub ALIPICSRH
Endcase
Return

$ALIPICSRH
[M:SRH1]NBSLO(NOL)   =[M:SRH1]ZQTYBOB(NOL)
Return


$REAJUST
#> 20181108 - cuando se hace una devolución de una línea de entrega que ya ha sido devuelta parcialmente, entra por aquí
# se cambia de integer a decimal ya que hay casos que el valor que puede dar en M2 tiene decimales
#Local Integer ZM2
Local Decimal ZM2
#< 20181108
Local Decimal ZKG
#Call QTEARR(WQTYSAU,[M:SRH1]SAU(NOL)) From TRTDIV
[M:SRH1]ZQTYBOB(NOL)-=func SPESRH.BOB_DEV([F:SDD]SDHNUM,[F:SDD]SDDLIN)
[M:SRH1]NBSLO(NOL)   =[M:SRH1]ZQTYBOB(NOL)  # Este valor lo sobreescribe el standar, motivo por el cual usamos el punto de entrada posterior   ALIPICSRH
ZM2= arr(([M:SRH1]ZANCHO(NOL)* [M:SRH1]ZLONGITUD(NOL)/1000)*[M:SRH1]ZQTYBOB(NOL),0.01)
#> 20180913 - obtenemos el factor
Read [ITM]ITM0 = [M:SRH1]ITMREF(NOL)
#ZKG=arr(ZM2*[M:SRH1]SAUSTUCOE(NOL),0.0001)
ZKG=arr(ZM2*[ITM]ZFACTOR,0.0001)



#<
If [M:SRH1]SAU(NOL)="M2"
#  [M:SRH1]QTY(NOL)   =ZM2
#  [M:SRH1]EXTQTY(NOL)=ZM2
  WQTYSAU = ZM2

  WQTY    = ZM2
Else
#  [M:SRH1]QTY(NOL)   =ZKG
#  [M:SRH1]EXTQTY(NOL)=ZKG

#> 20180913 - si son KG dejar calcular el estandar
#  WQTYSAU = ZKG
#  WQTY    = ZKG
#< 20180913
Endif
If [M:SRH1]STU(NOL)="M2"
  [M:SRH1]QTYSTU(NOL)=ZM2
Else
#> 20180913 - si son KG dejar calcular el estandar
#  [M:SRH1]QTYSTU(NOL)=ZKG
#< 20180913
Endif
[M:SRH1]ZCTDREAL(NOL)=WQTY
Return
