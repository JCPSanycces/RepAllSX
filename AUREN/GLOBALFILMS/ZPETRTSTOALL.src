#<AdxTL>@(#)0.0.0.0 $Revision$
#PIC_STOCK -> PE de TRTSTOALL para intervenir en la selecciˇn hecha por picking (manual), para
#evitar que se entrege una bobina de mas
$ACTION
Case ACTION
   When "PIC_STOCK"     :   Gosub PIC_STOCK
Endcase
Return

$PIC_STOCK
#Infbox "PIC_STOCK: ZPETRTSTOALL "+GFONCTION+"  "+GFONC1+"  "+num$([M:ALL]RETQTY)+" "+num$([M:ALL]PECQTY)
If GFONCTION="GESSOH"
  Local Decimal HASTA
  If [ITM]ITMREF<>[M:ALL]ITMREF
    Read [ITM]ITM0=[M:ALL]ITMREF
  Endif
  If [ITM]ZDIVANCHO=0   HASTA=1/10   Else    HASTA=1/([ITM]ZDIVANCHO*10)   Endif
  If abs([M:ALL]RETQTY-[M:ALL]PECQTY)<HASTA and [M:ALL]ITMREF<>"900"
#Infbox "Cantidad asginada supera el limite permitido"
    FOK=0
  Endif
  If [M:ALL]NBLIG=[M:ALL]XQTYBOB
   #Infbox "Total bobinas ya asignado"
    FOK=0
  Endif
Endif
Return

