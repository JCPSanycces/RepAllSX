Subprog AS_ZORICRY(VALEUR)
Variable Char    VALEUR()

  #Asegurar posicionamiento de la tabla
  If !clalev([F:BPR]) : Local File BPARTNER [F:BPR] : Endif
  If [F:BPR]BPRNUM <> [M:PTH0]BPSNUM
    Read [F:BPR]BPR0 = [M:PTH0]BPSNUM
    If fstat : End : Endif
  Endif

  #Asignación del país de origen
#  If [M:PTH0]ZORICRY = ''
     [M:PTH0]ZORICRY = [F:BPR]CRY
     Affzo [M:PTH0]ZORICRY
#  Endif
End

Subprog AM_ZORICRY(VALEUR)
Variable Char    VALEUR()
  If VALEUR = '' : End : Endif

  For I=0 To  [M:PTH1]NBLIG-1
    [M:PTH1]ORICRY(I) = VALEUR
    ZGAVIS = 0
  Next

  Affzo [M:PTH1]10
End
#< 06.302.559


