Affzo [M:PTH1]NBSLO(NOL)
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH1) 03/03/2016 19:11:10 (ADMIN)
######################################################################################
Subprog AP_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

NOL=nolign-1

#[M:PTH1]NBSLO(NOL)=VALEUR
#Affzo [M:PTH1]NBSLO(NOL)

#> 20181113 - mismo control que hay en C_NBLIG
# mismo comportamiento que al hacer picking
Grizo [PTH1]LOT(NOL)        #  Lote, se forma automaticamente en base a logaritmo acordado
Grizo [PTH1]NBSLO(NOL)      #  Nş de bobinas indica el nş de sublotes que se crearan
Actzo [M:PTH1]ZQTYBOB(NOL),ZPROVEEDOR(NOL)
If  [M:PTH1]POHNUM(NOL)<>""
  Grizo [M:PTH1]ZANCHO(NOL),ZMANDRIL(NOL),ZLONGITUD(NOL)

#> MA - permitimos modificar la longitud en modo creación de línea
  If [M:PTH1]CREFLG(NOL)=0 Then
     Actzo [M:PTH1]ZLONGITUD(NOL)
  Endif
#< MA
Else
  Actzo [M:PTH1]ZANCHO(NOL),ZMANDRIL(NOL),ZLONGITUD(NOL)
Endif

# ya que lo bloqueamos, informamos de este dato..
If [M:PTH1]NBSLO(NOL) <> VALEUR Then
  [M:PTH1]NBSLO(NOL)=VALEUR
  Affzo [M:PTH1]NBSLO(NOL)
Endif

#Infbox "AP_ZQTYBOB"
#< 20181113
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH1) 28/09/2016 12:17:15 (ADMIN)
######################################################################################
Subprog AM_ZQTYSTUREAL(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR, LANCHO

NOL=nolign-1  #> MA - es la línea de abajo

If VALEUR=0
  Call CALCULAR_QTY(NOL)
  End
Endif

# NOL=nolign-1 #> MA - lo subimos arriba

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LANCHO = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:PTH1]ITMREF(NOL),[M:PTH1]ZANCHO(NOL))

LSUPERFICIE=(LANCHO/1000)*[M:PTH1]ZLONGITUD(NOL)
LVOLUMEN=(LANCHO/1000)*[M:PTH1]ZLONGITUD(NOL)*LFACTOR

#LSUPERFICIE=([M:PTH1]ZANCHO(NOL)/1000)*[M:PTH1]ZLONGITUD(NOL)
#LVOLUMEN=([M:PTH1]ZANCHO(NOL)/1000)*[M:PTH1]ZLONGITUD(NOL)*LFACTOR

[M:PTH1]ZFACTOR(NOL)=LFACTOR

   If [M:PTH1]UOM(NOL)="M2"
      [M:PTH1]QTYPUU(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LSUPERFICIE,1)
      [M:PTH1]QTYUOM(NOL)=[M:PTH1]QTYPUU(NOL)
   Else
      [M:PTH1]QTYUOM(NOL)=VALEUR
   Endif
   [M:PTH1]QTYSTU(NOL)=VALEUR
   Gosub CAL_QTYPUU From SUBPTHB
   Affzo [M:PTH1]QTYPUU(NOL)
   Affzo [M:PTH1]QTYUOM(NOL)
   Affzo [M:PTH1]QTYSTU(NOL)
End


