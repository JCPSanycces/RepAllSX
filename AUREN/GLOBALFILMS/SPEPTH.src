## Etiqueta ańadida por el supervisor (pantalla PTH1) 13/11/2017 11:12:08 (ADMIN)
######################################################################################
Subprog C_NBLIG
Local Integer NOL  :     NOL=nolign-1
Grizo [PTH1]LOT(NOL)        #  Lote, se forma automaticamente en base a logaritmo acordado
Grizo [PTH1]NBSLO(NOL)      #  Nş de bobinas indica el nş de sublotes que se crearan
Actzo [M:PTH1]ZQTYBOB(NOL),ZPROVEEDOR(NOL)
If  [M:PTH1]POHNUM(NOL)<>""
  Grizo [M:PTH1]ZANCHO(NOL),ZMANDRIL(NOL),ZLONGITUD(NOL)

#> MA - permitimos modificar la longitud en modo creación de línea
  If [M:PTH1]CREFLG(NOL)=0 Then
     Actzo [M:PTH1]ZLONGITUD(NOL)
  Endif
#< MA
Else
  Actzo [M:PTH1]ZANCHO(NOL),ZMANDRIL(NOL),ZLONGITUD(NOL)
Endif
#If GUSER="PALAU"   Infbox  "Depurar  Subprog C_NBLIG   SPEPTH.src     (status="+num$(status)+")"    Endif
Case status
When 65:             #                      # Annulation simple
When 68,83:          #                      # Annulation multiple
                     For NOL=nolign-1 To nolign1-1
#                         Gosub TEST_ANU
                         If mkstat : Break : Endif
                     Next NOL
When 75:             #                      # Modification
  # No se puede modificar si viene de pedido.....Habrá que borrar linea de entrada y volver a ańadirla
  If not(GREP="C" or [M:PTH1]CREFLG(NOL)=0) and GMODIF<>1 #and [M:PTH1]POHNUM(NOL)<>""
    If ZGAVIS
      Raz ZGAVIS
      Call ERREURT("Recuerde que no puede modificar (Bobinas+Ancho+Mandril+Longitud+Proveedor)\De necesitarlo, deberá seguir estos pasos:\1ş) Eliminar la linea de la recepción\2"
&  + "ş) Ajustar linea pedido\3ş) Ańadir la",1) From GESECRAN   #0-Informativo, 1-Error
    Endif
    Diszo [M:PTH1]ZQTYBOB(NOL),ZANCHO(NOL),ZMANDRIL(NOL),ZLONGITUD(NOL),ZPROVEEDOR(NOL)
  Endif
When 73:             #                      # Insertion
When 82:             #                      # Ańadir fila al final
Endcase

#Infbox "C_NBLIG "+ num$(NOL)
#Infbox "C_NBLIG" #AZ
#Call LIENS_BOBINAS()
#Infbox "ZQTYBOB: " +num$([M:PTH1]ZQTYBOB(NOL))
#Infbox "NBSLO: " + num$([M:PTH1]NBSLO(NOL))

Call CALC_1LIN_PTH_BOBINAS(NOL) #> 20180727
End

Subprog APRES_NBLIG
#If GUSER="PALAU"   Infbox  "Depurar  Subprog APRES_NBLIG   SPEPTH.src     (status="+num$(status)+")"    Endif
# Independientemente de la unidad de stock......Nos aseguramos de saldar linea pedido en caso de que las bobinas recepcionadas >= pedidas
Local Integer NOL  :     NOL=nolign-1
If [M:PTH1]ZQTYBOBORI(NOL)=[M:PTH1]ZQTYBOB(NOL) and [M:PTH1]WSOLDE(NOL)<>2 and find(status,75,73,82)>0
  Call AM_WSOLDE(2) From SUBPTH
Endif



#Infbox "APRES_NBLIG" #AZ
#Infbox "ZQTYBOB: " +num$([M:PTH1]ZQTYBOB(NOL))
#Infbox "NBSLO: " + num$([M:PTH1]NBSLO(NOL))

Call CALC_1LIN_PTH_BOBINAS(NOL) #> 20180727

#> 20181113 control de costes estandar: coste compra unitario / coste compra
#If [M:PTH1]ZQTYBOB(NOL) <> 0 Then
#  Call MAJ_CPR_LIG(NOL) From SUBPTHD
#  Affzo [PTH1]CSTPUR(NOL)
#  Affzo [PTH1]LINCSTPUR(NOL)


#  [M:PTH1]LINAMTCPR(NOL)=[M:PTH1]CPR(NOL)*[M:PTH1]QTYSTU(NOL)
#  [M:PTH1]LINAMTCPR(NOL) = arr([M:PTH1]LINAMTCPR(NOL),0.0001)
#  #Call ARRDEV([M:PTH1]LINAMTCPR(NOL),GLOCALDEV) From TRTDIV
#  Affzo [PTH1]LINAMTCPR(NOL)
#Endif

#Call GET_AJUST_COSTES(NOL)
#< 20181113
End

####################################################################################################################
Subprog AVANT_NBLIG
#If GUSER="ADMIN"   Infbox  "Depurar  Subprog AVANT_NBLIG   SPEPTH.src     (status="+num$(status)+")"    Endif
Local Integer NOL  :     NOL=nolign-1
If find (status,75,73,82)  [M:PTH1]ZFLG(NOL)=2    Endif           #  Para controlar que nos hemos posicionado en la fila


#Infbox "AVANT_NBLIG" #AZ
