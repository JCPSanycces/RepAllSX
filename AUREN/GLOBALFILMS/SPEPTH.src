$ACTION
#If GUSER="ADMIN" or GUSER="ADMI2"
#If GUSER="ADMIN" : Infbox ACTION :Endif
#Endif
Case ACTION
 When "OUVRE"     :  Gosub OUVRE
 When "VALLIG"    :  Gosub VALLIG
 When "LIENS"     :  Gosub LIENS
 When "DEB_PICK"  :  Gosub DEB_PICK
 When "PICKE"     :  Gosub PICKE
 When "FIN_PICK"  :  Gosub FIN_PICK
 When "SETBOUT"   :  Gosub SETBOUT
 When "VERIF_MOD" :  Gosub FACTOR : Gosub VERIF  #> MA 20190103 - ańadimos VERIF
 When "VERIF_CRE" :  Gosub FACTOR : Gosub VERIF  #> MA 20190103 - ańadimos VERIF
 When "APRES_CRE" :  Gosub APRES_CRE  #> 20180727
 When "APRES_MOD" :  Gosub APRES_MOD
 When "LIENS_LIG" :  Gosub LIENS_LIG
 When "EXEACT"    :  Gosub EXEACT
 When Default
Endcase
Return

$OUVRE
Local Integer F,ZNBL,FLGPICK
Global Integer ZGAVIS
########################################
## PARAMETROS    son de tipo CHAR     ##
##      nombre parametro máximo 10    ##
########################################
Local Char TMP2(255)
#Tope 1, a partir del cual avisamos y NO dejamos continuar
Local Decimal ZTOP1
Call PARAM("","ZTOP1",TMP2) From ADOVAL
ZTOP1=val(TMP2)
#Tope 2, a partir del cual avisamos y SI dejamos continuar
Local Decimal ZTOP2
Call PARAM("","ZTOP2",TMP2) From ADOVAL
ZTOP2=val(TMP2)

GDECPRI = 4 #> 20181113 - cambiamos a 6 decimales
Return

$LIENS
ZGAVIS=1
Call CAL_QTY([M:PTH0]PTHNUM)

#> 20180727
  # leemos primero la pantalla
  #Gosub LIENS           From SUBPTHA
  #GPE=1

  # realizamos ajustes bobinas en recepciones..
  Call CALC_PTH_BOBINAS()
  Call CALC_POH_BOBINAS()
#< 20180727
Return

$EXEACT
Call AM_CUR([M:PTH0]CUR) From SUBPTH
Return

$APRES_MOD
Call CAL_QTY([M:PTH0]PTHNUM)
#> 20180727 - ajuste bobinas en recepciones y pedidos de compra
# 06.305.573.ini
Gosub AJSTBOB
#Call CALC_PTH_BOBINAS()
#Call CALC_POH_BOBINAS()
#Call CALC_PTH_PROV()
# 06.305.573.fin
#< 20180727
Return

$LIENS_LIG
#Call CAL_QTY([M:PTH0]PTHNUM)
[M:PTH1]ZFLG(nolign-1)=2
Return


##############################################
$APRES_CRE
#> 20180727 - ajuste bobinas en recepciones y pedidos de compra
# 06.305.573.ini
Gosub AJSTBOBC
#Call CALC_PTH_BOBINAS()
#Call CALC_POH_BOBINAS()
#Call CALC_PTH_PROV()
# 06.305.573.fin
#< 20180727
Return

Subprog CAL_QTY(LPTHNUM)
Value Char LPTHNUM()
If clalev([F:PTDX])<=0 :  Local File PRECEIPTD  [PTDX] :  Endif
[M:PTH1]ZTOTBOB=0
[M:PTH1]ZTOTKG=0
[M:PTH1]ZTOTM2=0
Filter [PTDX] Where PTHNUM=LPTHNUM
For [PTDX]
   [M:PTH1]ZTOTBOB=[M:PTH1]ZTOTBOB+[F:PTDX]ZQTYBOB
   If [F:PTDX]UOM="KG"
      [M:PTH1]ZTOTKG=[M:PTH1]ZTOTKG+[F:PTDX]QTYUOM
   Elsif [F:PTDX]UOM="M2"
      [M:PTH1]ZTOTKG=[M:PTH1]ZTOTKG+([F:PTDX]QTYUOM*[F:PTDX]UOMSTUCOE)
   Endif
   [M:PTH1]ZTOTM2=[M:PTH1]ZTOTM2+( func SPESOH.MODIFICA_ANCHO_DIVISOR([F:PTDX]ITMREF,[F:PTDX]ZANCHO)/1000)*[F:PTDX]ZLONGITUD*[F:PTDX]ZQTYBOB
Next
Filter [PTDX]
Affzo [M:PTH1]ZTOTKG
Affzo [M:PTH1]ZTOTM2
End

$VALLIG
If clalev([F:POQX])<=0 : Local File PORDERQ [POQX] : Endif
#Solamente funciona cuando se crea, modifica y borra una línea, no cuando se modifica la linea
#mediante la accion de modificacion de las entradas de stock
Update [POQX] Where POHNUM=[F:PTD]POHNUM and POPLIN=[F:PTD]POPLIN and POQSEQ=[F:PTD]POQSEQ With ZRCPQTYBOB+=[F:PTD]ZQTYBOB*SIGN
If fstat
  Call ERREURT("Error modificando bobinas recibidas\fstat="+num$(fstat),1) From GESECRAN   #0-Informativo, 1-Error
Endif
If [F:PTD]ZANCHO=0
   #Infbox "Sin Ancho"
   #GOK=0
   #Return
Endif
If [F:PTD]ZLONGITUD=0
   #Infbox "Sin Longitud"
   #GOK=0
   #Return
Endif
If [F:PTD]ZMANDRIL=0
   #Infbox "Sin Mandril"
   #GOK=0
   #Return
Endif
If [F:PTD]ZPROVEEDOR=""
   #Infbox "Sin Proveedor"
   #GOK=0
   Return
Endif
Return

$DEB_PICK
ZNBL=[M:PTH1]NBLIG-1
#If ZNBL<0   Raz  ZNBL   Endif  #> MA 20181113 - borramos este ajuste, lo hacemos en el FIN_PICK
Return

$PICKE
Return

$FIN_PICK
If ZNBL<[M:PTH1]NBLIG  FLGPICK=1   Endif

#> MA 20181113 - ajustamos cantidades en M2 al acabar un picking

# ajuste del ZNBL cuando hay más de 1 línea
If [M:PTH1]NBLIG > 0 : ZNBL += 1 : Endif

#Infbox "[M:PTH1]NBLIG: " + num$([M:PTH1]NBLIG)
#Infbox "ZNBL: "+ num$(ZNBL)

If [M:PTH1]NBLIG > ZNBL Then
  If !clalev([PQ]) : Local File PORDERQ [PQ] : Endif
  Local Integer LCON
  # recorro la línea nueva..
  For LCON=ZNBL To [M:PTH1]NBLIG-1
    [M:PTH1]MAJFLG(LCON) = 9 #MLL
    Call CALCULAR_QTY(LCON)

    # si viene de un pedido de compra y la unidad en M2
    If [M:PTH1]POHNUM(LCON)<>"" and [M:PTH1]POPLIN(LCON)<>0 and [M:PTH1]UOM(LCON)="M2" Then
      Filter [PQ] Where [PQ]POHNUM=[M:PTH1]POHNUM(LCON) and [PQ]POPLIN=[M:PTH1]POPLIN(LCON)
      Read [PQ] First
      If !fstat Then
        # si los valores no coinciden porque la US es KG pero trabajan con M2 y esté en modo creación
        If [PQ]ZQTYBOB=[M:PTH1]ZQTYBOB(LCON) and [PQ]QTYUOM <> [M:PTH1]QTYUOM(LCON) and [M:PTH1]CREFLG(LCON)=0 Then
          [M:PTH1]QTYUOM(LCON) = [PQ]QTYUOM # ponemos la cantidad original del estandar
          Affzo [M:PTH1]QTYUOM(LCON)
        Endif
        #Infbox "DENTRO : " +num$([PQ]CPR) + " : " + num$([M:PTH1]CPR(LCON))
        #If [PQ]CPR <> [M:PTH1]CPR(LCON) Then
        #  [M:PTH1]CPR(LCON) = [PQ]CPR
        #  Affzo [M:PTH1]CPR(LCON)
        #Endif
      Endif
      Filter [PQ]
    Endif


    #> 20181113 control de costes estandar: coste compra unitario / coste compra
    #If [M:PTH1]ZQTYBOB(LCON) <> 0 Then
    #  Call MAJ_CPR_LIG(LCON) From SUBPTHD
    #  Affzo [PTH1]CSTPUR(LCON) ,LINCSTPUR(LCON)
    #Endif
    #< 20181113

    Call GET_AJUST_COSTES(LCON)
  Next
  Close Local File [PQ]
  Affzo [M:PTH1] #MLL
  zonsui = "[M:PTH1]POHNUM([M:PTH1]NBLIG-1)" #MLL


Endif
#< MA 20181113


Return

$SETBOUT
If FLGPICK=1
  Raz FLGPICK
  Local Integer NOL
  For F=ZNBL To [M:PTH1]NBLIG-1
    If [M:PTH1]NBSLO(F)<>[M:PTH1]ZQTYBOB(F) and [M:PTH1]ZQTYBOB(F)>0
      NOL=F
      Gosub ASNBSLO
    Endif
  Next
Endif
Return

$FACTOR
Local Integer F
For F=0 To [M:PTH1]NBLIG-1
  If not func FACTOR_OK(F,ZTOP1,ZTOP2) # and GUSER="ADMIN"
    OK=0
    Break
  Endif
Next
Return

Funprog FACTOR_OK(F,DIF1,DIF2)
Value Integer F
Value Decimal DIF1,DIF2
Local Integer OK : OK=1
Local Integer YN : YN=1  # Por defecto es NO
Local Decimal FACTOR,FACTOR_ART,LM2,LANCHO,DIF,DIF_POR,QTY_ORI
Local Char STU(GLONUOM),MSG(255)
Raz FACTOR,FACTOR_ART,STU,MSG,QTY_ORI
If clalev([F:ITMW])<=0   :  Local File ITMMASTER [F:ITMW] : Endif
If clalev([F:PTDW])<=0   :  Local File PRECEIPTD [F:PTDW] : Endif
Raz [F:PTDW]
Read [F:PTDW]PTD0=[M:PTH0]PTHNUM;[M:PTH1]PTDLIN(F)
QTY_ORI=[F:PTDW]QTYSTU
Raz [F:ITMW]
Read [F:ITMW]ITM0=[M:PTH1]ITMREF(F)
FACTOR_ART=arr([F:ITMW]ZFACTOR,0.000001)
STU=[F:ITMW]STU
If [M:PTH1]NBSLO(F)>1 and [M:PTH1]ZFLG(F)<>2
  MSG="En la linea "+num$(F+1)+"\Hay que posicionarse, para indicar detalle de SUBLOTES"
  Call ERREURT("IMPOSIBLE CONTINUAR\"+MSG,1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Elsif [F:ITMW]ZFABCOR=2 and [M:PTH1]ZQTYBOB(F)<1
  MSG="En la linea "+num$(F+1)+"\No se han indicado bobinas"
  Call ERREURT("IMPOSIBLE CONTINUAR\"+MSG,1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Elsif [F:ITMW]ZFABCOR=2 and [M:PTH1]ZQTYBOB(F)>1 and [M:PTH1]NBSLO(F)<>[M:PTH1]ZQTYBOB(F)
  MSG="En la linea "+num$(F+1)+"\Bobinas a dar de alta<>Bobinas indicadas\"+num$([M:PTH1]NBSLO(F))+"<>"+num$([M:PTH1]ZQTYBOB(F))
  Call ERREURT("IMPOSIBLE CONTINUAR\"+MSG,1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Elsif STU="KG" and QTY_ORI<>[M:PTH1]QTYSTU(F)
  LANCHO    = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:PTH1]ITMREF(F),[M:PTH1]ZANCHO(F))
  LM2       = (LANCHO/1000)*[M:PTH1]ZLONGITUD(F)*[M:PTH1]ZQTYBOB(F)
  If LM2=0
    FACTOR=1
  Else
    FACTOR=arr([M:PTH1]QTYSTU(F)/LM2,0.000001)
  Endif
  DIF=arr(FACTOR-FACTOR_ART,0.000001)
  DIF_POR=arr(DIF*100/FACTOR_ART,0.01)
  MSG+="En la linea "+num$(F+1)+"\hay una difŞ de "+num$(DIF)+" que es un "+num$(DIF_POR)+"%"
  MSG+="\respecto factor del articulo ("+num$(FACTOR_ART)+")\y el resultante ("+num$(FACTOR)+") de Kgs/M2 introducidos ("+num$([M:PTH1]QTYSTU(F))+"/"+num$(int(LM2))+")"
  If abs(DIF_POR)>=DIF1
    Call ERREURT("IMPOSIBLE CONTINUAR\"+MSG,1) From GESECRAN   #0-Informativo, 1-Error
    OK=0
  Elsif abs(DIF_POR)>=DIF2
    Call OUINON("ESTA SEGURO DE CONTINUAR\"+MSG, YN) From GESECRAN
    If YN=1
      OK=0
    Endif
  Endif
Endif
If OK and [M:PTH1]ZPROVEEDOR(F)=""
  MSG="En la linea "+num$(F+1)+"\No se ha indicado RfŞProveedor\necesaria para formar LOTE"
  Call ERREURT("IMPOSIBLE CONTINUAR\"+MSG,1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Endif
End OK

Subprog AS_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1

If [M]UPDFLG(NOL)<>0 | [M]CREFLG(NOL)<>0
   #mkstat=2
Endif

# MA
# si no está en modo creación de línea, no puede modificar este valor,
# para ello debe hacerlo desde la pantalla de entrada manual
If [M]CREFLG(NOL)<>0
   mkstat=2
Endif
End

