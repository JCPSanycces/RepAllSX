#      [M:PTH1]QTYUOM(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LSUPERFICIE,1)
#      [M:PTH1]QTYSTU(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LVOLUMEN,0.001)
#   Endif
#   If [M:PTH1]UOM(NOL)="KG"
#      [M:PTH1]QTYUOM(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LVOLUMEN,0.001)
#   Endif
#   If [M:PTH1]UOM(NOL)="M2"
#      [M:PTH1]QTYPUU(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LSUPERFICIE,1)
#      [M:PTH1]QTYUOM(NOL)=[M:PTH1]QTYPUU(NOL)
#   Endif
#   Gosub CAL_QTYPUU From SUBPTHB
#   Affzo [M:PTH1]QTYPUU(NOL)
#   Affzo [M:PTH1]QTYUOM(NOL)
#   Affzo [M:PTH1]QTYSTU(NOL)
#   If [M:PTH1]LINTYP(NOL)<3
#     If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
#       Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
#     Endif
#     Call CONVERT_VOUWEU("PTH1",NOL,[M:PTH1]LINWEU(NOL),[M:PTH1]LINVOU(NOL),[M:PTH1]QTYSTU(NOL),WOLDQTYSTU) From STCLIB
#   Endif
#   If !GIMPORT Affzo [PTH1]QTYVOU(NOL),QTYWEU(NOL) : Endif
#   Call AM_QTYUOM([M:PTH1]QTYUOM(NOL)) From SUBPTH
#Endif
#Affzo [M:PTH1]ZFACTOR(NOL)
##[M:PTH1]NBSLO(NOL)=[M:PTH1]ZQTYBOB(NOL)
##Affzo [M:PTH1]NBSLO(NOL)
End

#> MA - Modificamos la función para que se pase la línea por parámetro
#Subprog CALCULAR_QTY
Subprog CALCULAR_QTY(NOL)
Value Integer NOL
#< MA

Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR, LANCHO
#Local Integer NOL
Local    Decimal  WOLDQTYSTU
WOLDQTYSTU = [M:PTH1]QTYSTU(NOL)

#NOL=nolign-1 #> MA - se pasa por parámetro
LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LANCHO = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:PTH1]ITMREF(NOL),[M:PTH1]ZANCHO(NOL))

LSUPERFICIE=(LANCHO/1000)* [M:PTH1]ZLONGITUD(NOL)
LVOLUMEN   =LSUPERFICIE  * LFACTOR

#LSUPERFICIE=(VALEUR/1000)*[M:PTH1]ZLONGITUD(NOL)
#LVOLUMEN=(VALEUR/1000)*[M:PTH1]ZLONGITUD(NOL)*LFACTOR

[M:PTH1]ZFACTOR(NOL)=LFACTOR
If [M:PTH1]ZQTYBOB(NOL)<>0
   If   [M:PTH1]UOM(NOL)="KG"
      [M:PTH1]QTYUOM(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
      [M:PTH1]QTYSTU(NOL)=[M:PTH1]QTYUOM(NOL)
   Elsif [M:PTH1]UOM(NOL)="M2"
      [M:PTH1]QTYUOM(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LSUPERFICIE,0.0001)
      [M:PTH1]QTYSTU(NOL)=arr([M:PTH1]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
   Endif
   Gosub CAL_QTYPUU From SUBPTHB
   Affzo [M:PTH1]QTYUOM(NOL)
   Affzo [M:PTH1]QTYSTU(NOL)
   If [M:PTH1]LINTYP(NOL)<3
     If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
       Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
     Endif
     Call CONVERT_VOUWEU("PTH1",NOL,[M:PTH1]LINWEU(NOL),[M:PTH1]LINVOU(NOL),[M:PTH1]QTYSTU(NOL),WOLDQTYSTU) From STCLIB
   Endif
   If !GIMPORT Affzo [PTH1]QTYVOU(NOL),QTYWEU(NOL) : Endif
   Call AM_QTYUOM([M:PTH1]QTYUOM(NOL)) From SUBPTH
Endif
Affzo [M:PTH1]ZFACTOR(NOL)
Gosub ASNBSLO

End

