End


####################################################################################################################
##############################################
#**
#* 20180727
#* Ajustes en las líneas las bobinas recepciones
#*!
Subprog CALC_PTH_BOBINAS()

Local Integer LCON
#Local Decimal LQTYBOB


# abrir tablas
If !clalev([R0]) : Local File PRECEIPTD [R0] : Endif

# actualizo num. bobinas en tabla y línea..
For LCON=0 To [M:PTH1]NBLIG-1

  # no coinciden las bobinas se modifica..
  If [M:PTH1]ZQTYBOB(LCON) <> [M:PTH1]NBSLO(LCON) Then
    Gosub GET_CALC_PTH_BOBINAS
  Endif

Next

# cerrar tablas..
Close Local File [R0]
End

#**
#* Calcula las bobinas de una línea
#*
#* @param PLIN = línea a tratar
#*!
Subprog CALC_1LIN_PTH_BOBINAS(PLIN)
Value Integer PLIN

If !clalev([R0]) : Local File PRECEIPTD [R0] : Endif
Local Integer LCON : LCON = PLIN
Gosub GET_CALC_PTH_BOBINAS
Close Local File [R0]
End


#########################################
#**
#* LCON = posición de la línea
#* Recalcula tabla y pantalla, en caso de existir en tabla solo en pantalla
#*!
$GET_CALC_PTH_BOBINAS

# si existe la recepción + línea
Read [R0]PTD0 = [M:PTH0]PTHNUM;[M:PTH1]PTDLIN(LCON)
If !fstat Then
  [R0]ZQTYBOB = [M:PTH1]NBSLO(LCON)
  Rewrite [R0]
  If !fstat Then
    [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
    Affzo [M:PTH1]ZQTYBOB(LCON)
  Endif
Else
  #en el caso de ser una creación solo actualizamos la pantalla
  [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
  Affzo [M:PTH1]ZQTYBOB(LCON)
Endif

Return


#**
#* 20180727
#* Recorre todas las líneas de la recepción
#* Ajustes en las líneas las bobinas en pedidos de venta
#*!
Subprog CALC_POH_BOBINAS()

Local Integer LCON
Local Decimal LQTYBOB


# abrir tablas
If !clalev([R0]) : Local File PRECEIPTD [R0] : Endif
If !clalev([P0]) : Local File PORDERQ   [P0] : Endif

# actualizo num. bobinas en tabla y línea..
For LCON=0 To [M:PTH1]NBLIG-1

  # recorre todas las líneas y sus pedidos aunque no hay incoherencia..
  # revisamos que el dato de bobinas pendientes en pedidos de venta sea el correcto
  If [M:PTH1]POHNUM(LCON) <> "" Then
    # sumo todas las bobinas recepcionadas..
    Raz LQTYBOB
    For [R0] Where [R0]POHNUM = [M:PTH1]POHNUM(LCON) and [R0]POPLIN = [M:PTH1]POPLIN(LCON)
      LQTYBOB += [R0]ZQTYBOB
    Next

    # actualizamos la línea del pedido para que salga correctamente en los browser
    Filter [P0] Where [P0]POHNUM = [M:PTH1]POHNUM(LCON) and [P0]POPLIN = [M:PTH1]POPLIN(LCON)
      Read [P0] First
      If !fstat Then

        [P0]ZRCPQTYBOB = LQTYBOB
        Rewrite [P0]
      Endif
    Filter [P0]
  Endif

Next

# cerrar tablas..
Close Local File [R0], [P0]
End

#**
#* Ajusta los costes que vengan de un pedido de compra
#*
#* @param PNOL > línea
#*!
Subprog GET_AJUST_COSTES(PNOL)
Value Integer PNOL

Local Integer LCON

If !clalev([P0]) : Local File PORDERQ   [P0] : Endif

# si estoy creando la línea, comprobamos los costes del pedido
If [M:PTH1]CREFLG(PNOL) = 0 Then

    Filter [P0] Where [P0]POHNUM = [M:PTH1]POHNUM(PNOL) and [P0]POPLIN = [M:PTH1]POPLIN(PNOL)
      Read [P0] First
      If !fstat Then
        If [PTH1]CSTPUR(PNOL) <> [P0]CSTPUR Then
          [PTH1]CSTPUR(PNOL) = [P0]CSTPUR
          Affzo [PTH1]CSTPUR(PNOL)
        Endif

        # solo si tiene el mismo número de bobinas
        If [PTH1]LINCSTPUR(PNOL) <> [P0]LINCSTPUR and [M:PTH1]ZQTYBOB(PNOL)=[P0]ZQTYBOB Then
          [PTH1]LINCSTPUR(PNOL) = [P0]LINCSTPUR
          Affzo [PTH1]LINCSTPUR(PNOL)
        Endif


        If [PTH1]LINAMTCPR(PNOL) <> [P0]LINAMTCPR and [M:PTH1]ZQTYBOB(PNOL)=[P0]ZQTYBOB Then
          [PTH1]LINAMTCPR(PNOL) = [P0]LINAMTCPR
          Affzo [PTH1]LINAMTCPR(PNOL)
        Endif


        [PTH1]ZPROVEEDOR(PNOL) = [P0]ZPROVEEDOR

      Endif
    Filter [P0]


Endif


Close Local File [P0]
End

######################################################################################
#**
#* Controla que la cantidad modificada del campo QTYUOM este dentro de unos márgenes establecidos
#*
#* @param F  -> línea de la entrada a modificar
#* @param PQTY -> es el VALEUR de la cantidad modificada
#* @param DIF1 -> parámetro ZTOP1
#* @param DIF2 -> parámetro ZTOP2
#*!
Subprog CONTROL_FACTOR_QTYUOM(F,PQTY,DIF1,DIF2)
Value Integer F
Value Decimal PQTY
Value Decimal DIF1,DIF2
Local Integer OK : OK=1
Local Integer YN : YN=1  # Por defecto es NO
Local Decimal FACTOR,FACTOR_ART,LM2,LANCHO,DIF,DIF_POR,QTY_ORI
Local Char STU(GLONUOM),MSG(255)
Raz FACTOR,FACTOR_ART,STU,MSG,QTY_ORI


If clalev([F:ITMW])<=0   :  Local File ITMMASTER [F:ITMW] : Endif

QTY_ORI=[M:PTH1]QTYUOM(F) # lo que habia antes de modificar el Valor en US

Raz [F:ITMW]
Read [F:ITMW]ITM0=[M:PTH1]ITMREF(F)
FACTOR_ART=arr([F:ITMW]ZFACTOR,0.000001)
STU=[F:ITMW]STU

# si la cantidad introducida son M2 hay que pasarlo a KG
If [M:PTH1]UOM(F) = "M2" and 1=2 Then
  LANCHO  = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:PTH1]ITMREF(F),[M:PTH1]ZANCHO(F))
  LM2     = PQTY # al venir en M2 guardamos ese valor aqui
  PQTY    = PQTY * [M:PTH1]UOMSTUCOE(F) # calculamos la cantidad a KG

Else  # si son KG
  LANCHO    = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:PTH1]ITMREF(F),[M:PTH1]ZANCHO(F))
  LM2       = (LANCHO/1000)*[M:PTH1]ZLONGITUD(F)*[M:PTH1]ZQTYBOB(F)
Endif

If STU="KG" and QTY_ORI<>PQTY

  If LM2=0
    FACTOR=1
  Else
    FACTOR=arr(PQTY/LM2,0.000001)
  Endif
  DIF=arr(FACTOR-FACTOR_ART,0.000001)
  DIF_POR=arr(DIF*100/FACTOR_ART,0.01)
  MSG+="En la linea "+num$(F+1)+"\hay una difŞ de "+num$(DIF)+" que es un "+num$(DIF_POR)+"%"
  MSG+="\respecto factor del articulo ("+num$(FACTOR_ART)+")\y el resultante ("+num$(FACTOR)+") de Kgs/M2 introducidos ("+num$(PQTY)+"/"+num$(int(LM2))+")"

  If abs(DIF_POR)>=DIF1
    mkstat = 2
    GMESSAGE = "IMPOSIBLE CONTINUAR\"+MSG
  Elsif abs(DIF_POR)>=DIF2
    Call OUINON("ESTA SEGURO DE CONTINUAR\"+MSG, YN) From GESECRAN
    If YN=1
      mkstat = 2
    Endif
  Endif
Endif

End

##############################################
#**
#* MA 20181213
#* Ajustes en STOJOU y STOCK para actualizar el proveedor si es necesario..
#*!
Subprog CALC_PTH_PROV()

# abrir tablas
If !clalev([J0]) : Local File STOJOU [J0] : Endif
If !clalev([S0]) : Local File STOCK  [S0] : Endif

Local Integer LCON

# actualizo num. bobinas en tabla y línea..
For LCON=0 To [M:PTH1]NBLIG-1

  If [M:PTH1]ZPROVEEDOR(LCON) <> "" Then
    # actualizamos la stojou si proveedor está en blanco

    For [J0] Where [J0]VCRTYP=6 and [J0]VCRNUM=[M:PTH0]PTHNUM and [J0]VCRLIN=[M:PTH1]PTDLIN(LCON) and [J0]ZPROVEEDOR=""

      [J0]ZPROVEEDOR=[M:PTH1]ZPROVEEDOR(LCON)
      Rewrite [J0]

      # buscamos stock con proveedor en blanco
      Filter [S0] Where [S0]ITMREF=[J0]ITMREF and [S0]LOT=[J0]LOT and [S0]SLO=[J0]SLO and [S0]ZPROVEEDOR=""
        Read [S0] First
        If !fstat Then
          [S0]ZPROVEEDOR=[M:PTH1]ZPROVEEDOR(LCON)
          Rewrite [S0]
        Endif

      Filter [S0]
    Next

  Endif

Next

# cerrar tablas..
Close Local File [J0],[S0]
End

######################################################################################
Subprog C_QTYUOM(VALEUR)
Variable Decimal VALEUR

Local Integer LLIN : LLIN = nolign-1
Local Char TMP(255)
#Tope 1, a partir del cual avisamos y NO dejamos continuar
Local Decimal LTOP1 : Call PARAM("","ZTOP1",TMP) From ADOVAL : LTOP1=val(TMP)
#Tope 2, a partir del cual avisamos y SI dejamos continuar
Local Decimal LTOP2 : Call PARAM("","ZTOP2",TMP) From ADOVAL : LTOP2=val(TMP)

# ejecutamos el control si está en recepciones
If GFONC1 = "GESPTH" Then


  If [M:PTH1]UOM(LLIN) = "M2" and [M:PTH1]ZQTYBOB(LLIN) <> 0 Then
    # no permitimos modificar la cantidad si viene en M2

    #GMESSAGE = "No puede modificar cantidades en M2"
    #Call ERREUR("No puede modificar cantidades en M2") From GESECRAN
    #mkstat = 2

  Else
    Call CONTROL_FACTOR_QTYUOM(LLIN, VALEUR, LTOP1, LTOP2)
  Endif
Endif

End

######################################################################################
Subprog AS_UOM(VALEUR)
Variable Char    VALEUR()

If VALEUR = "M2" Then
  Grizo [M:PTH1]QTYUOM(nolign-1)
  mkstat=2
Else
  Actzo [M:PTH1]QTYUOM(nolign-1)
Endif

End

######################################################################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()

If VALEUR = "M2" Then
  Grizo [M:PTH1]QTYUOM(nolign-1)
Else
  Actzo [M:PTH1]QTYUOM(nolign-1)
Endif
End

######################################################################################
Subprog AS_QTYUOM(VALEUR)
Variable Decimal VALEUR

If [M:PTH1]UOM(nolign-1) = "M2" Then
  Grizo [M:PTH1]QTYUOM(nolign-1)
Else
  Actzo [M:PTH1]QTYUOM(nolign-1)
Endif
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH1) 03/12/2018 15:22:45 (ADMIN)
######################################################################################
Subprog C_POPLIN(VALEUR)
Variable Decimal VALEUR

Local Integer NOL : NOL = nolign-1
Local Integer LOK

Call GET_POH_CRE(NOL,[M:PTH1]POHNUM(NOL),VALEUR,LOK)
If LOK <> 2 Then
    GERR=1
    GMESSAGE="No se permite registrar esta línea. Está pendiente de registrar una línea anterior."
    mkstat=2
Endif
End


######################################################################################
#**
#* Comprueba que no haya 2 líneas del mismo pedido en modo creación
#*
#* @param PNOL
#* @param PPOHNUM
#* @param PPOPLIN
#* @param POK
#*!
Subprog GET_POH_CRE(PNOL, PPOHNUM, PPOPLIN, POK)
Variable Integer POK
Value Char    PPOHNUM
Value Integer PPOPLIN
Value Integer PNOL

POK = 2 # por defecto permite modificar..
Local Integer LLIN

For LLIN=0 To [M:PTH1]NBLIG-1
  If [M:PTH1]POHNUM(LLIN) = PPOHNUM and [M:PTH1]POPLIN(LLIN) = PPOPLIN
&    and LLIN <> PNOL and [M:PTH1]CREFLG(LLIN) = 0 Then

    POK = 1
    Break
  Endif

Next

End

# MA 20180103 - el campo TOTLINAMT no se está calculando correctamente
$VERIF

# Verificamos que el campo TOTLINAMT esté correctamente calculado, en caso contrario, cambiamos el valor y relanzamos la verificación estandar
Local Integer LLIN
Local Decimal LTOTLIN

# sumamos importe líneas AI
For LLIN=0 To [M:PTH1]NBLIG-1
  If [M:PTH1]LINTYP(LLIN)<>2  # SUBPTHD Lin.83
    LTOTLIN+=[M:PTH1]LINAMT(LLIN)
  Endif
Next

# si son diferentes, modificamos el dato
If [M:PTH2]TOTLINAMT <> LTOTLIN
  [M:PTH2]TOTLINAMT = LTOTLIN
  Affzo [M:PTH2]TOTLINAMT
Endif
Return


######################################################################################
$AJSTBOB #ajuste bobinas en recepciones y pedidos de compra # 06.305.573
######################################################################################
Local Integer LCON
Local Decimal LQTYBOB
# abrir tablas
If !clalev([R0]) : Local File PRECEIPTD [R0] : Endif
If !clalev([P0]) : Local File PORDERQ   [P0] : Endif
If !clalev([J0]) : Local File STOJOU [J0] : Endif
If !clalev([S0]) : Local File STOCK  [S0] : Endif
#Local Decimal AX,BX,CX: Raz AX,BX,CX
# actualizo num. bobinas en tabla y línea..

For LCON=0 To [M:PTH1]NBLIG-1
  # no coinciden las bobinas se modifica..
  If [M:PTH1]ZQTYBOB(LCON) <> [M:PTH1]NBSLO(LCON) Then
    # si existe la recepción + línea
    Read [R0]PTD0 = [M:PTH0]PTHNUM;[M:PTH1]PTDLIN(LCON)
    If !fstat Then
      [R0]ZQTYBOB = [M:PTH1]NBSLO(LCON)
      Rewrite [R0]
      If !fstat Then
        [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
        Affzo [M:PTH1]ZQTYBOB(LCON)
      Endif
      Gosub UPD_ZPROVEEDOR
    Else
      #en el caso de ser una creación solo actualizamos la pantalla
      [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
      Affzo [M:PTH1]ZQTYBOB(LCON)

      Gosub UPD_ZPROVEEDOR
    Endif
   Endif
   #################################
   If [M:PTH1]POHNUM(LCON) <> "" Then
    # sumo todas las bobinas recepcionadas..
    Raz LQTYBOB
    For [R0] Where [R0]POHNUM = [M:PTH1]POHNUM(LCON) and [R0]POPLIN = [M:PTH1]POPLIN(LCON)
      LQTYBOB += [R0]ZQTYBOB
    Next
    # actualizamos la línea del pedido para que salga correctamente en los browser
      Read [P0]POQ0 = [M:PTH1]POHNUM(LCON);[M:PTH1]POPLIN(LCON);1
      If !fstat Then
        [P0]ZRCPQTYBOB = LQTYBOB
        Rewrite [P0]
      Endif
   Endif

Next

# cerrar tablas..
Close Local File [R0]
Close Local File [P0]
Close Local File [J0]
Close Local File [S0]

Return

######################################################################################
$AJSTBOBC #ajuste bobinas en recepciones y pedidos de compra # 06.305.573
######################################################################################
Local Integer LCON
Local Decimal LQTYBOB
# abrir tablas
If !clalev([R0]) : Local File PRECEIPTD [R0] : Endif
If !clalev([P0]) : Local File PORDERQ   [P0] : Endif
If !clalev([J0]) : Local File STOJOU [J0] : Endif
If !clalev([S0]) : Local File STOCK  [S0] : Endif
#Local Decimal AX,BX,CX: Raz AX,BX,CX
# actualizo num. bobinas en tabla y línea..

For LCON=0 To [M:PTH1]NBLIG-1
  # no coinciden las bobinas se modifica..
  If [M:PTH1]ZQTYBOB(LCON) <> [M:PTH1]NBSLO(LCON) Then
    # si existe la recepción + línea
    Read [R0]PTD0 = [M:PTH0]PTHNUM;[M:PTH1]PTDLIN(LCON)
    If !fstat Then
      [R0]ZQTYBOB = [M:PTH1]NBSLO(LCON)
      Rewrite [R0]
      If !fstat Then
        [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
        Affzo [M:PTH1]ZQTYBOB(LCON)
      Endif
    Else
      #en el caso de ser una creación solo actualizamos la pantalla
      [M:PTH1]ZQTYBOB(LCON) = [M:PTH1]NBSLO(LCON)
      Affzo [M:PTH1]ZQTYBOB(LCON)
    Endif
   Endif
   #################################
   If [M:PTH1]POHNUM(LCON) <> "" Then
    # sumo todas las bobinas recepcionadas..
    Raz LQTYBOB
    For [R0] Where [R0]POHNUM = [M:PTH1]POHNUM(LCON) and [R0]POPLIN = [M:PTH1]POPLIN(LCON)
      LQTYBOB += [R0]ZQTYBOB
    Next
    # actualizamos la línea del pedido para que salga correctamente en los browser
      Read [P0]POQ0 = [M:PTH1]POHNUM(LCON);[M:PTH1]POPLIN(LCON);1
      If !fstat Then
        [P0]ZRCPQTYBOB = LQTYBOB
        Rewrite [P0]
      Endif
   Endif

   Gosub UPD_ZPROVEEDOR

Next

# cerrar tablas..
Close Local File [R0]
Close Local File [P0]
Close Local File [J0]
Close Local File [S0]

Return

$UPD_ZPROVEEDOR # 06.305.573

If [M:PTH1]ZPROVEEDOR(LCON) <> "" Then
  Update [J0] Where [J0]VCRTYP=6 and [J0]VCRNUM=[M:PTH0]PTHNUM and [J0]VCRLIN=[M:PTH1]PTDLIN(LCON) and [J0]ZPROVEEDOR=""
& With [J0]ZPROVEEDOR=[M:PTH1]ZPROVEEDOR(LCON)

  Update [S0] Where [S0]ITMREF=[M:PTH1]ITMREF(LCON) and [S0]LOT=[M:PTH1]LOT(LCON) and [S0]ZPROVEEDOR=""
& With [S0]ZPROVEEDOR=[M:PTH1]ZPROVEEDOR(LCON)

Endif

Return
