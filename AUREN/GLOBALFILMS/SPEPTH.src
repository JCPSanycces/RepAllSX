######################################################################################
Subprog AS_NBSLO(VALEUR)
Variable Decimal VALEUR
#Local Integer NOL :  NOL=nolign-1 #ML
#VALEUR=[M:PTH1]ZQTYBOB(NOL) #ML
#Gosub ASNBSLO #ML
End

