#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# TRTX3CPT ; Traitements communs pour gestion des données comptables   #
########################################################################
# Action :                                                             #
#  - SAIHEACCE       : Saisie des sections entęte                      #
# Gosub :                                                              #
#  - DECL_GLOBAL_CPT : Déclaration des globales comptes et axes        #
#  - SAUV_GLOBAL_CPT : Sauvegarde des globales en cas de tunnel        #
#  - REST_GLOBAL_CPT : Restauration des globales au retour d'un tunnel #
#  - OPEN_FILES      : Ctrl que les fichiers soient ouverts            #
# Subprog :                                                            #
#  - GETCPY          : Chargement des globales suivant la société      #
#  - INIT_GLOBAL_CPT : Chargement des globales suivant la société      #
#  - ACTUALIS_FMTDIE : Réactualisation des formats sections dans [M]   #
#                                                                      #
#  - TRACE_GLOBAL_CPT: Trace du contenu des globales (pour tests)      #
#  - RECUP_GLOBAL_CPT: Récupération des globales pour migration v150   #
#                                                                      #
#  - ENREG_ACCCCE    : Enregistrement cptes et sections dans CPTANALIN #
#  - CHARG_ACCCCE    : Chargement des comptes et sections ligne        #
#  - IMPORT_ACCCCE   : Chargement comptes et sections en import        #
#  - CHARG_ACCX      : Chargement des comptes type entęte              #
#  - CHARG_CCE       : Chargement des sections ligne d'un document     #
#  - CHARG_CCEH      : Chargement des sections entęte d'un document    #
#  - CHARG_CCEX      : Chargement sections type entęte, noms variables #
#  - INISEC          : Initialisation sections d'une ligne sans compte #
#  - INIT_CCE        : Initialisation des sections d'une ligne         #
#  - INIT_CCEH       : Initialisation des sections entęte              #
#  - INIT_CCEX       : Initialis. sections type entęte, noms variables #
#  - AVSAI_CCEH      : Avant saisie des sections d'entęte              #
#  - SAIS_CCE        : Avant saisie des sections d'une ligne           #
#  - CTRL_PFICCE     : Contrôle des sections d'une ligne élément fact  #
#  - CTRL_CCE        : Contrôle des sections d'une ligne               #
#  - CTRL_CCE2       : Contrôle des sections d'une ligne               #
#  - CTRL_CCEH       : Contrôle des sections entete                    #
#  - AVSAI_ACC       : Avant saisie des comptes d'une ligne            #
#  - APMOD_ACC       : Aprčs modification des comptes d'une ligne      #
#  - CTRL_ACC        : Contrôle des comptes d'une ligne                #
#  - CTRL_DSP        : Contrôle code répartition analytique            #
#  - INIT_DIE        : Initialisation tableau axes tables de base      #
#  - CHARG_DIE       : Chargement tableau axes des tables de base      #
#  - RECH_INDACC     : Recherche indice compte général ou analytique   #
#  - RECH_ACC        : Recherche compte général ou analytique          #
#  - RECH_BUDOPE     : Recherche budget opé (cpte, enveloppe, entité)  #
#  - CHARG_RATCUR    : Chargement cours devise                         #
#                                                                      #
#  - CHARG_CCECOD    : Chargement mode de saisie d'une section DIETRS  #
#  - CHARG_TABCCE    : Chargement [F:CAL]CCE dans un tableau [M]CCE    #
#  - INIT_TABCCE     : Initialisation des sections en tableau CCE(20)  #
#  - SAIS_TABCCE     : Avant saisie des sections en tableau            #
#  - CTRL_TABCCE     : Contrôle des sections en tableau                #
#  - ENREG_TABCCE    : Enregistrement sections [M]CCE(20) ds CPTANALIN #
# Fonction :                                                           #
#  - TRFSEC          : Récupération de la section d'un document        #
#  - TRFSECMSK       : Récupération de la section d'un écran           #
#  - TRFSECORI       : Récupération de la section d'un doc origine     #
#  - TYPLEDAUTO      : Type de référentiel automatique ?               #
########################################################################
# Issue 121835 - 20170418 by LD : Analytical dimensions not transfered
#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)


$ACTION
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenętre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub OUV_SAIHEACCE
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Aprčs l'ouverture de la fenętre #
  #---------------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub DEB_SAIHEACCE
  Endcase
 When "SETBOUT"
  #------------------------#
  # Activation des boutons #
  #------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub SETB_SAIHEACCE
  Endcase
 When "OK"
  #--------------------------------#
  # Aprčs l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub OK_SAIHEACCE
  Endcase
 When "ABA"
  #-------------------------------------#
  # Aprčs l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub ABA_SAIHEACCE
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Aprčs chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAIHEACCE" : REP="M"
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir ŕ la fenętre précédente #
  #------------------------------------------#
  Case GACTION
   When "SAIHEACCE" : Gosub FINSAI_SAIHEACCE
  Endcase
Endcase
Return


#--------------------------------------------------------------------------#
# Déclaration des globales référentiels, comptes et sections d'une société #
# ------------------------------------------------------------------------ #
# Ces globales sont maintenant définies dans le dictionnaire des variables #
#    globales et générées dans le WWAGLOBX3 exécuté au lancement de X3     #
#--------------------------------------------------------------------------#
$DECL_GLOBAL_CPT
#----- Globales utilisées pour les comptes d'une société -----#
Global Integer GNBTYPLED                : # Nbre de référentiel      (max 10)
Global Integer GTYPLED         (1..10)  : # Types de référentiel
Global Integer GTYPLED_X3TC    (1..10)  : # Types de référentiel : #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
Global Char    GLEDSOC(GLONLED)(1..10)  : # Codes  référentiel
Global Char    GDEVLED(GLONCUR)(1..10)  : # Devises référentiel
#-----
Global Integer GNBCOA                   : # Nbre de plans comptables (max 10)
Global Char    GCOA(GLONCOA)   (1..10)  : # Codes plans
Global Char    GCOLCOA(20)     (1..10)  : # Entętes colonnes comptes
Global Char    GFMTCOA(15)     (1..10)  : # Formats des comptes
Global Libelle GSCRCOA                  : # Type de présentation (fiche + tableau)
#----- Globales utilisées pour les sections analytiques d'une société -----#
Global Integer GNBDIE                   : # Nbre d'axes (max 20)
Global Char    GDIE(GLONDIE)   (1..20)  : # Codes axes
Global Integer GOBLDIE         (1..20)  : # Axes obligatoires (O/N)
Global Integer GENVDIE         (1..20)  : # Axes enveloppe ou entité (O/N)
Global Char    GCOLDIE(20)     (1..20)  : # Entętes colonnes sections
Global Char    GFMTDIE(15)     (1..20)  : # Formats des sections
Global Libelle GSCRDIE                  : # Type de présentation des sections(fiche + tableau)
#Global Libelle GSCRDIE2                : # Type de présentation des sections(fiche + tableau) # FQ 59219
#Global Libelle GSCRDIE3                : # Type de présentation des sections(fiche + tableau) # FQ 59219
Global Libelle GSCRCOA                  : # Type de présentation des comptes (fiche + tableau)
Global Libelle GHEADIE                  : # Mode de saisie sections entęte
Global Libelle GSTODIE                  : # Mode de saisie sections mvt stock
#-----
Global Char    GSOC_ACTIVE(GLONCPY)     : # Pour tester un changement de société
Global Libelle GSOC_UPDFLG              : # Indicateur changement de société

#-----
Return


#--------------------------------------------------------#
# Sauvegarde des globales (en cas de tunnel par exemple) #
#--------------------------------------------------------#
$SAUV_GLOBAL_CPT
If dim(GNBTYPLED)>0   Local Integer WGNBTYPLED            : WGNBTYPLED  =GNBTYPLED   : Endif
If dim(GNBCOA)>0      Local Integer WGNBCOA               : WGNBCOA     =GNBCOA      : Endif
If dim(GNBDIE)>0      Local Integer WGNBDIE               : WGNBDIE     =GNBDIE      : Endif
If dim(GSCRCOA)>0     Local Integer WGSCRCOA              : WGSCRCOA    =GSCRCOA     : Endif
If dim(GSCRDIE)>0     Local Integer WGSCRDIE              : WGSCRDIE    =GSCRDIE     : Endif
If dim(GSCRDIE2)>0    Local Integer WGSCRDIE2             : WGSCRDIE2   =GSCRDIE2    : Endif # FQ 59219
If dim(GSCRDIE3)>0    Local Integer WGSCRDIE3             : WGSCRDIE3   =GSCRDIE3    : Endif # FQ 59219
If dim(GHEADIE)>0     Local Integer WGHEADIE              : WGHEADIE    =GHEADIE     : Endif
If dim(GSTODIE)>0     Local Integer WGSTODIE              : WGSTODIE    =GSTODIE     : Endif
If dim(GSOC_ACTIVE)>0 Local Char    WGSOC_ACTIVE(GLONCPY) : WGSOC_ACTIVE=GSOC_ACTIVE : Endif
If dim(GSOC_UPDFLG)>0 Local Libelle WGSOC_UPDFLG          : WGSOC_UPDFLG=GSOC_UPDFLG : Endif
#-----
If dim(GTYPLED)>0
  Local Integer WGTYPLED(1..10)
  WGTYPLED(1) =GTYPLED(1)
  WGTYPLED(2) =GTYPLED(2)
  WGTYPLED(3) =GTYPLED(3)
  WGTYPLED(4) =GTYPLED(4)
