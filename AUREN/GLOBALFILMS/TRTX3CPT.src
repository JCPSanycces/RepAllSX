#-------------------------------------------------------------------------#
# Chargement des globales référentiels, comptes et sections d'une société #
# ----------------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                                 #
#   - WSITE   : Site                                                      #
#   - WABRFIC : Abréviation table des transactions de saisie              #
#   - WDTRTYP : Type de la transaction                                    #
#   - WDTRNUM : Code de la transaction                                    #
# Nota : Si WABRFIC="" ---> Pas de transaction de saisie                  #
#-------------------------------------------------------------------------#
Subprog GETCPY(WSITE,WABRFIC,WDTRTYP,WDTRNUM)
Value Char    WSITE
Value Char    WABRFIC
Value Integer WDTRTYP
Value Char    WDTRNUM
#-----
$TRT_GETCPY
Local Integer I, J, K
Local Char    WMODELE(GLONGCM)

#-----
Call GETDEV(WSITE) From DEVSUB
#-----
If GSOCIETE<>GSOC_ACTIVE
  #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
  Raz GNBTYPLED, GTYPLED_X3TC, GTYPLED, GLEDSOC, GDEVLED, GNBCOA, GCOA, GNBDIE, GDIE, GOBLDIE,
&     GENVDIE, GSCRCOA,   GSCRDIE

  If dim(GSCRDIE2)>0 & dim(GSCRDIE3)>0 # FQ 59219
     Raz GSCRDIE2, GSCRDIE3
  Endif
  If GMODU(2)=2
    #----- Recherche du modčle comtable de la société -----#
    Call SETGCM(GSOCIETE,WMODELE) From CPTDIV
    #----- Chargement codes plans, types de référentiel et axes d'une société   -----#
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    Call SETPLAN2(WMODELE,GNBCOA,GCOA,GTYPLED_X3TC,GNBDIE,GDIE,GOBLDIE) From CPTDIV
    For I=1 To 10
        GTYPLED(I)=GTYPLED_X3TC(I)
    Next I
    #----- Chargement codes et devises pour les référentiels associés ŕ un plan -----#
    GNBTYPLED=GNBCOA
    For I=1 To GNBTYPLED
      Call LECLED(GSOCIETE,GTYPLED_X3TC(I),GLEDSOC(I),GDEVLED(I)) From CPTDIV
    Next I
  Endif
  #----- Chargement entętes colonnes et formats des comptes -----#
  For I=1 To dim(GCOA)
    If I<=GNBCOA
      Call LECTEXTRA(GCOLCOA(I),"GCOA","COLHEA",GCOA(I),"") From ATEXTRA
      #-----
      J=find(GCOA(I),GCOACOD(1..GCOANBR))
      If J
        GFMTCOA(I)="K:"+GCOAFMT(J)
      Else
        GFMTCOA(I)="K:15x"
      Endif
      #----- Modif formats suivant transaction (saisie/affiché/invisible) -----#
      If WABRFIC<>""
        Case WABRFIC
          When "PTR"
            If WDTRTYP<>9
              If I=1
                Read [PTR] PTR0=WDTRTYP;WDTRNUM : If fstat  Raz [F:PTR] : Endif
                GSCRCOA=[F:PTR]LEDTYPSCR
              Endif
              #-----
              If [F:PTR]LEDTYPCOD(GTYPLED_X3TC(I)-1)=2
                GFMTCOA(I)=left$(GFMTCOA(I),1)+"P"+right$(GFMTCOA(I),2)
              Elsif [F:PTR]LEDTYPCOD(GTYPLED_X3TC(I)-1)<>1
                GFMTCOA(I)="-"+GFMTCOA(I)
              Endif
            Endif
          When "SLT"
          When "CTR"
          When "SRT"
          When "MTS"
          When "BTS"
        Endcase
      Endif
    Else
      GCOLCOA(I)=""
      GFMTCOA(I)="-K:15x"
    Endif
  Next I
  #----- Chargement entętes colonnes et formats des sections analytiques -----#
  If WABRFIC<>""
    If !clalev([F:DTR])  Local File DIETRS [DTR] : Endif
    Read [DTR] DTR0=WABRFIC;WDTRTYP;WDTRNUM;0.0
    If fstat
      Raz [F:DTR] : [F:DTR]CCESCR=1 : [F:DTR]HEACCECOD=3 : [F:DTR]STOCCECOD=3
    Endif
    GSCRDIE=[F:DTR]CCESCR
    If dim(GSCRDIE2)>0 GSCRDIE2=[F:DTR]CCESCR2  Endif # FQ 59219
    If dim(GSCRDIE3)>0 GSCRDIE3=[F:DTR]CCESCR3  Endif # FQ 59219
    GHEADIE=[F:DTR]HEACCECOD
    GSTODIE=[F:DTR]STOCCECOD
  Else
    GSCRDIE=1
    If dim(GSCRDIE2)>0 GSCRDIE2=1 Endif # FQ 59219
    If dim(GSCRDIE3)>0 GSCRDIE3=1 Endif # FQ 59219
    GHEADIE=3
    GSTODIE=3
  Endif
  #-----

  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
  # Recherche de l'axe géré ŕ l'affaire/Search for the dimension type managed by project
  # Pour la réinitialisation de la section de cet axe en cas de modification du code affaire
  # For the reinitialization of the dimension when the project code is modified
  If func ASYRFNC.ACTIV("PJM")
      GPJMDIE = func TRTX3CPT.GETPJMDIE(GSOCIETE, GNBTYPLED, GLEDSOC)
  Endif
  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)

  If !clalev([F:DIE])  Local File GDIE [DIE] : Endif
  For I=1 To dim(GDIE)
    If I<=GNBDIE
      Read [DIE] DIE0=GDIE(I) : If fstat  Raz [F:DIE] : Endif
      If [F:DIE]ENV=2 | [F:DIE]ENT=2  GENVDIE(I)=2  Else  GENVDIE(I)=1 : Endif

      Call LECTEXTRA(GCOLDIE(I),"GDIE","COLHEA",GDIE(I),"") From ATEXTRA
      #-----
      J=find(GDIE(I),GDIECOD(1..GDIENBR))
      If J
        GFMTDIE(I)="K:"+GDIEFMT(J)
      Else
        GFMTDIE(I)="K:15c"
      Endif
      #----- Modif formats des sections suivant transaction (saisie/affiché/invisible) -----#
      If WABRFIC<>""
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;1;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          GFMTDIE(I)=left$(GFMTDIE(I),1)+"P"+right$(GFMTDIE(I),2)
        Elsif [F:DTR]CCECOD<>1
          GFMTDIE(I)="-"+GFMTDIE(I)
        Endif
      Endif
    Else
      GOBLDIE(I)=0
      GENVDIE(I)=0
      GCOLDIE(I)=""
      GFMTDIE(I)="-K:15c"
    Endif
  Next I
  #-----
  GSOC_ACTIVE=GSOCIETE
  GSOC_UPDFLG=1
  #If GUSER="MBT"                        : # ŕ virer !!!
  #  Call TRACE_GLOBAL_CPT From TRTX3CPT : # ŕ virer !!!
  #Endif                                 : # ŕ virer !!!
Endif
# Maj des formats pour les entités détails
# [M:MFG2],[M:MFG3],[M:SCO2],[M:SCO3],[M:MTK2],[M:MTK3],...
Gosub ACTUALIS_FMTDIE23
#-----
End

# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
#############################################################################
# GETPJMDIE
#############################################################################
#**
#* Récupération de l'axe géré ŕ l'affaire pour une société
#* Return the dimension type managed by project for a company
#*
#* @param PCY       Société/Company
#* @param PNBTYPLED Nbre de référentiel/Number of ledger types (max 10)
#* @param PLEDSOC   Tableau des codes référentiels/Array of ledger codes
#*
#* L'axe is retourné par le funprog et dans la variable globale GPJMDIE
#* Dimension is returned by the funprog and returned in GPJMDIE global variable
#*
#*!
Funprog GETPJMDIE(PCPY, PNBTYPLED, PLEDSOC)
Value    Char     PCPY              : # Société/Company
Value    Integer  PNBTYPLED         : # Nbre de référentiel/Number of ledger types  (max 10)
Value    Char     PLEDSOC()(1..10)  : # Tableau des codes référentiels/Array of ledger codes

Local Char    WPJMDIE(GLONDIE)
Local Integer WI_LED, WI_DIE
Local Integer WLED_OK

Raz GPJMDIE
Raz WPJMDIE

# Récupération du référentiel géré ŕ l'affaire/Search for the ledger managed by project
WLED_OK = [V]CST_AFALSE
If !clalev([F:LED])  Local File GLED [LED] : Endif
For WI_LED = 1 To PNBTYPLED
  Call LEC_LED(PLEDSOC(WI_LED)) From CPTLEC
  If [F:LED]PJMFLG = [V]CST_AYES
      WLED_OK = [V]CST_ATRUE         : # Référentiel flagué Gestion ŕ l'affaire/Ledger managed by project
      Break
  Endif
Next WI_LED

# Récupération de l'axe géré ŕ l'affaire/Search for the dimension type managed by project
If WLED_OK = [V]CST_ATRUE
    If !clalev([F:DIE])  Local File GDIE [DIE] : Endif
    # Recherche de l'axe géré ŕ l'affaire pour le référentiel géré ŕ l'affaire
    # Search for the dimension type managed by project for the ledger managed by project
    For WI_DIE = 0 To dim([F:LED]DIE)-1
        Call LEC_DIE([F:LED]DIE(WI_DIE)) From CPTLEC
        If [F:DIE]PJMFLG = [V]CST_AYES
            WPJMDIE_OK = [V]CST_ATRUE : # Axe flagué Gestion ŕ l'affaire/Dimension type managed by project
            WPJMDIE = [F:DIE]DIE
            GPJMDIE = [F:DIE]DIE
            Break
        Endif
    Next
Endif

End WPJMDIE
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)

####################################################################################################
# X3-3808  : Update project dimension on sales documents / X3-56299 (LD 10/02/17)
#**
#* Utilisé dans la fonction Sections par défaut
#* Appelé au niveau des identifiants pour déterminer l'identifiant en fonction d'un contexte
#* Ex : Utilisé dans la Section par défaut SOI Article/prix commande ouverte qui peut ętre appelée dans un contexte avec une classe [M] ou une classe [F]
#* Used in the function Default dimensions
#* Called for the identifiers to define the identifiers depending on the context
#* Ex : Used in the default dimensions SOI Sales Contract lines which can be called in a context with a class [M] or a class [F]
#*
#* @param ACTX    Classe contexte/Class context
#* @param CDE     Section par défaut/Default dimensions
#* @param IDENT   Identifiant/Identifier
#* @param AXE     Axe/Dimension type
#*
#* Retourne la valeur de l'identifiant
#* Returns the identifier value
#*!
Funprog GET_CDE_IDENT_VALUE (ACTX,CDE,IDENT,AXE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char    CDE
Value Integer IDENT
Value Char    AXE

Local Char    IDT_VAL : Raz IDT_VAL

Case IDENT
  When 1  : # Article/Product
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOI1])>0
          IDT_VAL=[M:SOI1]ITMREF
        Elsif clalev ([F:SOC])>0
          IDT_VAL=[F:SOC]ITMREF
        Endif
      When Default
    Endcase
  When 2   : # Client/Customer
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOR1])>0
          IDT_VAL=[M:SOR1]BPCORD
        Elsif clalev ([F:SOH])>0
          IDT_VAL=[F:SOH]BPCORD
        Endif
      When Default
    Endcase
  When 3   : # Fournisseur/Supplier
  When 4   : # Représentant/Sales Rep
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOI1])>0
          IDT_VAL=[M:SOI1]REP(nolign-1)
        Elsif clalev ([F:SOP])>0
          IDT_VAL=[F:SOP]REP1
        Endif
      When Default
    Endcase
  When 5   : # Acheteur/Buyer
  When 6   : # Pičce/Document
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOR1])>0
          IDT_VAL=[M:SOR1]CCE
        Elsif clalev ([F:SOH])>0
          IDT_VAL=TRTX3CPT.TRFSEC("SOH",AXE)
        Endif
      When Default
    Endcase
  When 7   : # Société/Company
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
          IDT_VAL=GSOCIETE
      When Default
    Endcase
  When 8   : # Site/Site
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOR1])>0
          IDT_VAL=[M:SOR1]SALFCY
        Elsif clalev ([F:SOC])>0
          IDT_VAL=[F:SOC]SALFCY
        Endif
      When Default
    Endcase
  When 9   : # Devise/Currency
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOR1])>0
          IDT_VAL=[M:SOR1]CUR
        Elsif clalev ([F:SOH])>0
          IDT_VAL=[F:SOH]CUR
        Endif
      When Default
    Endcase
  When 10  : # Taxe/Tax
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOI1])>0
          IDT_VAL=[M:SOI1]VAT(0)
        Elsif clalev ([F:SOH])>0
          IDT_VAL=[F:SOC]VAT(0)
        Endif
      When Default
    Endcase
  When 11  : # Pied vente/Sales footer
  When 12  : # Escompte/Discount
  When 13  : # Banque/Bank
  When 14  : # Compte/Account
  When 15  : # Immo/Fixed asset
  When 16  : # Pied achat/Purchase footer
  When 17  : # Tiers divers/Miscellaneous business partner
  When 18  : # Sections valorisation/Costing dimensions
  When 19  : # Frais généraux/Overhead costs
  When 20  : # Document origine/Source document
  When 21  : # Sections précédentes/Previous dimensions
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOI1])>0
          IDT_VAL="[M:SOI1]CCE#"
        Elsif clalev ([F:SOC])>0
          IDT_VAL="[F:SOR]CCE#"
        Endif
      When Default
    Endcase
  When 22  : # Demandeur/Requester
  When 23  : # Charges achats/Purchase costs
  When 24  : # Affaire/Project
    Case CDE
      When "SOI"  : # Article prix commande ouverte /Sales Contract lines
        If clalev ([M:SOI1])>0
          IDT_VAL=func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT_OPPNUM(ACTX,[M:SOI1]DPJT)
        Elsif clalev ([F:SOC])>0
          IDT_VAL=func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT_OPPNUM(ACTX,[F:SOC]PJT)
        Endif
      When Default
    Endcase
  When Default
Endcase

End IDT_VAL
# X3-3808  : Update project dimension on sales documents / X3-56299 (LD 10/02/17)

#-------------------------------------------------------------------------#
# Chargement des globales référentiels, comptes et sections d'une société #
# ----------------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                                 #
#   - WSITE   : Site                                                      #
#   - WABRFIC : Abréviation table des transactions de saisie              #
#   - WDTRTYP : Type de la transaction                                    #
#   - WDTRNUM : Code de la transaction                                    #
# Nota : Si WABRFIC="" ---> Pas de transaction de saisie                  #
#-------------------------------------------------------------------------#
Subprog INIT_GLOBAL_CPT(WSITE,WABRFIC,WDTRTYP,WDTRNUM)
Value Char    WSITE
Value Char    WABRFIC
Value Integer WDTRTYP
Value Char    WDTRNUM
#-----
Goto TRT_GETCPY
#-----
End : # N'est pas utilisé mais ça fait plus propre !


#-------------------------------------------------------------------------------------#
# Réactualisation formats de saisie des sections analytiques stockés dans les masques #
# ----------------------------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                                             #
#   - WSITE   : Site                                                                  #
#   - WABRFIC : Abréviation table des transactions de saisie                          #
#   - WDTRTYP : Type de la transaction                                                #
#   - WDTRNUM : Code de la transaction                                                #
# Nota : Si WABRFIC="" ---> Pas de transaction de saisie                              #
#-------------------------------------------------------------------------------------#
Subprog ACTUALIS_FMTDIE(WSITE,WABRFIC,WDTRTYP,WDTRNUM)
Value Char    WSITE
Value Char    WABRFIC
Value Integer WDTRTYP
Value Char    WDTRNUM
#-----
Local Integer I, J
Gosub ACTUALIS_FMTDIE23
End

#-----------------------------------------------------------------------------------------#
# Réactualisation des formats de saisie des sections analytiques stockés dans les masques #
#-----------------------------------------------------------------------------------------#
$ACTUALIS_FMTDIE23
If dim([M:MFG2]FMTDIE)>0 | dim([M:MFG3]FMTDIE)>0 : Gosub ACTUALIS_FMTDIE23_MFG : Endif
# Issue X3-69383 - 2018-05-04 by MUARN : ajout SCO1
If dim([M:SCO2]FMTDIE)>0 | dim([M:SCO3]FMTDIE)>0 | dim([M:SCO1]FMTDIE)>0 : Gosub ACTUALIS_FMTDIE23_SCO : Endif
If dim([M:MTK2]FMTDIE)>0 | dim([M:MTK3]FMTDIE)>0 : Gosub ACTUALIS_FMTDIE23_MTK : Endif
Return

#---------------------------------------------------#
# Cas particulier de la fenętre OMFG                #
# - [M:MFG2]FMTDIE de 1 ŕ 20 pour [M:MFG2]CCE1...20 #
# - [M:MFG3]FMTDIE de 1 ŕ 20 pour [M:MFG3]CCE1...20 #
#---------------------------------------------------#
$ACTUALIS_FMTDIE23_MFG
If dim([M:MFG2]FMTDIE)<1 & dim([M:MFG3]FMTDIE)<1  Return : Endif
For I=1 To dim(GDIE)
  If I<=GNBDIE
    J=find(GDIE(I),GDIECOD(1..GDIENBR))
    If J
      If dim([M:MFG2]FMTDIE)>0  [M:MFG2]FMTDIE(I)="K:"+GDIEFMT(J) : Endif
      If dim([M:MFG3]FMTDIE)>0  [M:MFG3]FMTDIE(I)="K:"+GDIEFMT(J) : Endif
    Else
      If dim([M:MFG2]FMTDIE)>0  [M:MFG2]FMTDIE(I)="K:15c"         : Endif
      If dim([M:MFG3]FMTDIE)>0  [M:MFG3]FMTDIE(I)="K:15c"         : Endif
    Endif
    #----- Modif formats suivant transaction (saisie/affiché/invisible)
    If WABRFIC<>""
      If dim([M:MFG2]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;2;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:MFG2]FMTDIE(I)=left$([M:MFG2]FMTDIE(I),1)+"P"+right$([M:MFG2]FMTDIE(I),2)
        Elsif [F:DTR]CCECOD<>1
          [M:MFG2]FMTDIE(I)="-"+[M:MFG2]FMTDIE(I)
        Endif
      Endif
      If dim([M:MFG3]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;3;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:MFG3]FMTDIE(I)=left$([M:MFG3]FMTDIE(I),1)+"P"+right$([M:MFG3]FMTDIE(I),2)
        Elsif [F:DTR]CCECOD<>1
          [M:MFG3]FMTDIE(I)="-"+[M:MFG3]FMTDIE(I)
        Endif
      Endif
    Endif
  Else
    If dim([M:MFG2]FMTDIE)>0  [M:MFG2]FMTDIE(I)="-K:15c" : Endif
    If dim([M:MFG3]FMTDIE)>0  [M:MFG3]FMTDIE(I)="-K:15c" : Endif
  Endif
Next I
Return

#---------------------------------------------------#
# Cas particulier de la fenętre OSCO                #
# - GFMTDIE        de 1 ŕ 20 pour [M:SCO1]CCE(20)   #
# - [M:SCO2]FMTDIE de 0 ŕ 19 pour [M:SCO2]CCE1...20 #
# - [M:SCO3]FMTDIE de 0 ŕ 19 pour [M:SCO3]CCE(20)   #
#---------------------------------------------------#
$ACTUALIS_FMTDIE23_SCO
# Issue X3-69383 - 2018-05-04 by MUARN : ajout SCO1
If dim([M:SCO2]FMTDIE)<1 & dim([M:SCO3]FMTDIE)<1 & dim([M:SCO1]FMTDIE)>0 Return : Endif
  For I=1 To GNBDIE
    J=find(GDIE(I),GDIECOD(1..GDIENBR))
    If J
      If dim([M:SCO1]FMTDIE)>0  [M:SCO1]FMTDIE(I-1)="K:"+GDIEFMT(J) : Endif # Issue X3-69383 - 2018-05-04 by MUARN
      If dim([M:SCO2]FMTDIE)>0  [M:SCO2]FMTDIE(I-1)="K:"+GDIEFMT(J) : Endif
      If dim([M:SCO3]FMTDIE)>0  [M:SCO3]FMTDIE(I-1)="K:"+GDIEFMT(J) : Endif
    Else
      If dim([M:SCO1]FMTDIE)>0  [M:SCO1]FMTDIE(I-1)="K:15c"         : Endif # Issue X3-69383 - 2018-05-04 by MUARN
      If dim([M:SCO2]FMTDIE)>0  [M:SCO2]FMTDIE(I-1)="K:15c"         : Endif
      If dim([M:SCO3]FMTDIE)>0  [M:SCO3]FMTDIE(I-1)="K:15c"         : Endif
    Endif
    #----- Modif formats suivant transaction (saisie/affiché/invisible)
    If WABRFIC<>""
      # Issue X3-69383 - 2018-05-04 by MUARN : ajout SCO1
      If dim([M:SCO1]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;1;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:SCO1]FMTDIE(I-1)=left$([M:SCO1]FMTDIE(I-1),1)+"P"+right$([M:SCO1]FMTDIE(I-1),2)
        Elsif [F:DTR]CCECOD<>1
          [M:SCO1]FMTDIE(I-1)="-"+[M:SCO1]FMTDIE(I-1)
        Endif
      Endif
      If dim([M:SCO2]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;2;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:SCO2]FMTDIE(I-1)=left$([M:SCO2]FMTDIE(I-1),1)+"P"+right$([M:SCO2]FMTDIE(I-1),2)
        Elsif [F:DTR]CCECOD<>1
          [M:SCO2]FMTDIE(I-1)="-"+[M:SCO2]FMTDIE(I-1)
        Endif
      Endif
      If dim([M:SCO3]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;3;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:SCO3]FMTDIE(I-1)=left$([M:SCO3]FMTDIE(I-1),1)+"P"+right$([M:SCO3]FMTDIE(I-1),2)
        Elsif [F:DTR]CCECOD<>1
          [M:SCO3]FMTDIE(I-1)="-"+[M:SCO3]FMTDIE(I-1)
        Endif
      Endif
    Endif
  Next I
  # Issue X3-69383 - 2018-05-04 by MUARN : ajout SCO1
  For I=GNBDIE+1 To dim([M:SCO1]FMTDIE)
    [M:SCO1]FMTDIE(I-1)="-K:15c"
  Next I
  For I=GNBDIE+1 To dim([M:SCO2]FMTDIE)
    [M:SCO2]FMTDIE(I-1)="-K:15c"
  Next I
  For I=GNBDIE+1 To dim([M:SCO3]FMTDIE)
    [M:SCO3]FMTDIE(I-1)="-K:15c"
  Next I
Return

#---------------------------------------------------#
# Cas particulier de la fenętre OMTK                #
# - [M:MTK2]FMTDIE de 1 ŕ 20 pour [M:MTK2]CCE1...20 #
# - [M:MTK3]FMTDIE de 1 ŕ 20 pour [M:MTK3]CCE1...20 #
#---------------------------------------------------#
$ACTUALIS_FMTDIE23_MTK
If dim([M:MTK2]FMTDIE)<1 & dim([M:MTK3]FMTDIE)<1  Return : Endif
For I=1 To dim(GDIE)
  If I<=GNBDIE
    J=find(GDIE(I),GDIECOD(1..GDIENBR))
    If J
      If dim([M:MTK2]FMTDIE)>0  [M:MTK2]FMTDIE(I)="K:"+GDIEFMT(J) : Endif
      If dim([M:MTK3]FMTDIE)>0  [M:MTK3]FMTDIE(I)="K:"+GDIEFMT(J) : Endif
    Else
      If dim([M:MTK2]FMTDIE)>0  [M:MTK2]FMTDIE(I)="K:15c"         : Endif
      If dim([M:MTK3]FMTDIE)>0  [M:MTK3]FMTDIE(I)="K:15c"         : Endif
    Endif
    #----- Modif formats suivant transaction (saisie/affiché/invisible)
    If WABRFIC<>""
      If dim([M:MTK2]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;2;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:MTK2]FMTDIE(I)=left$([M:MTK2]FMTDIE(I),1)+"P"+right$([M:MTK2]FMTDIE(I),2)
        Elsif [F:DTR]CCECOD<>1
          [M:MTK2]FMTDIE(I)="-"+[M:MTK2]FMTDIE(I)
        Endif
      Endif
      If dim([M:MTK3]FMTDIE)>0
        Read [DTR] DTR1=WABRFIC;WDTRTYP;WDTRNUM;3;GDIE(I) : If fstat  Raz [F:DTR] : Endif
        If [F:DTR]CCECOD=2
          [M:MTK3]FMTDIE(I)=left$([M:MTK3]FMTDIE(I),1)+"P"+right$([M:MTK3]FMTDIE(I),2)
        Elsif [F:DTR]CCECOD<>1
          [M:MTK3]FMTDIE(I)="-"+[M:MTK3]FMTDIE(I)
        Endif
      Endif
    Endif
  Else
    If dim([M:MTK2]FMTDIE)>0  [M:MTK2]FMTDIE(I)="-K:15c" : Endif
    If dim([M:MTK3]FMTDIE)>0  [M:MTK3]FMTDIE(I)="-K:15c" : Endif
  Endif
Next I
Return


#-------------------------------------------------------#
# Ecriture dans la trace du contenu des globales compta #
#-------------------------------------------------------#
Subprog TRACE_GLOBAL_CPT
Local Integer I
Local Char    WMSG1(50), WMSG2(51), WMSG3(40)
#-----
If GTRACE=""
  Call OUVRE_TRACE("Trace du contenu des globales compta d'une société") From LECFIC
Endif
#-----
Call ECR_TRACE("-- Globales utilisées pour les comptes ("+GSOCIETE+") --",0) From GESECRAN
Call ECR_TRACE("GNBTYPLED  ="-num$(GNBTYPLED),0)                             From GESECRAN
#-----
For I=1 To 10
  WMSG1 ="GTYPLED("+num$(I)+")"+space$(2-len(num$(I)))+"="-num$(GTYPLED(I))
  If GTYPLED(I)>0  WMSG1-=mess(GTYPLED(I),2644,1) : Endif
  WMSG1+=space$(36-len(WMSG1))
  WMSG2 ="GLEDSOC("+num$(I)+")"+space$(2-len(num$(I)))+"="-GLEDSOC(I)
  WMSG2+=space$(30-len(WMSG2))
  WMSG3 ="GDEVLED("+num$(I)+")"+space$(2-len(num$(I)))+"="-GDEVLED(I)
  WMSG3+=space$(24-len(WMSG3))
  Call ECR_TRACE(WMSG1+WMSG2+WMSG3,0) From GESECRAN
Next I
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
For I=1 To 10
  WMSG1 ="GTYPLED_X3TC("+num$(I)+")"+space$(2-len(num$(I)))+"="-num$(GTYPLED_X3TC(I))
  If GTYPLED_X3TC(I)>0  WMSG1-=mess(GTYPLED_X3TC(I),2644,1) : Endif
  WMSG1+=space$(36-len(WMSG1))
  WMSG2 ="GLEDSOC("+num$(I)+")"+space$(2-len(num$(I)))+"="-GLEDSOC(I)
  WMSG2+=space$(30-len(WMSG2))
  WMSG3 ="GDEVLED("+num$(I)+")"+space$(2-len(num$(I)))+"="-GDEVLED(I)
  WMSG3+=space$(24-len(WMSG3))
  Call ECR_TRACE(WMSG1+WMSG2+WMSG3,0) From GESECRAN
Next I
#-----
Call ECR_TRACE("--",0)                     From GESECRAN
WMSG1 ="GNBCOA  ="-num$(GNBCOA)
WMSG1+=space$(18-len(WMSG1))+num$(GSCRCOA)
If GSCRCOA>0  WMSG1-=mess(GSCRCOA,99,1) : Endif
Call ECR_TRACE(WMSG1,0) From GESECRAN
#-----
For I=1 To 10
  WMSG1 ="GCOA("+num$(I)+")"+space$(2-len(num$(I)))+"="-GCOA(I)
  WMSG1+=space$(36-len(WMSG1))
  WMSG2 ="GCOLCOA("+num$(I)+")"+space$(2-len(num$(I)))+"="-GCOLCOA(I)
  WMSG2+=space$(30-len(WMSG2))
  WMSG3 ="GFMTCOA("+num$(I)+")"+space$(2-len(num$(I)))+"="-GFMTCOA(I)
  WMSG3+=space$(24-len(WMSG3))
  Call ECR_TRACE(WMSG1+WMSG2+WMSG3,0) From GESECRAN
Next I
#-----
Call ECR_TRACE("-- Globales utilisées pour les sections("+GSOCIETE+") --",0) From GESECRAN
WMSG1 ="GNBDIE  ="-num$(GNBDIE)
WMSG1+=space$(23-len(WMSG1))+"GSCRDIE+23 ="
WMSG1+=space$(36-len(WMSG1))
Raz WMSG2
If GSCRDIE>0
  WMSG2=mess(GSCRDIE,99,1) : Endif
If dim(GSCRDIE2)>0 & GSCRDIE2>0
  WMSG2+=space$(17-len(WMSG2))+mess(GSCRDIE2,99,1)
Endif
If dim(GSCRDIE3)>0 & GSCRDIE3>0
  WMSG2+=space$(34-len(WMSG2))+mess(GSCRDIE3,99,1)
Endif

Call ECR_TRACE(WMSG1+WMSG2,0) From GESECRAN
#-----
For I=1 To 20
  WMSG1 ="GDIE("+num$(I)+")"+space$(2-len(num$(I)))+"="-GDIE(I)
  If GOBLDIE(I)=2
    WMSG1+=space$(18-len(WMSG1))+left$(mess(4,65,1),5)
  Endif
  If GENVDIE(I)=2
    WMSG1+=space$(26-len(WMSG1))+left$(mess(178,108,1),3)+"/"+left$(mess(179,108,1),3)
  Endif
  WMSG1+=space$(36-len(WMSG1))
  WMSG2 ="GCOLDIE("+num$(I)+")"+space$(2-len(num$(I)))+"="-GCOLDIE(I)
  WMSG2+=space$(30-len(WMSG2))
  WMSG3 ="GFMTDIE("+num$(I)+")"+space$(2-len(num$(I)))+"="-GFMTDIE(I)
  WMSG3+=space$(24-len(WMSG3))
  Call ECR_TRACE(WMSG1+WMSG2+WMSG3,0) From GESECRAN
Next I
#-----
Call ECR_TRACE("--",0) From GESECRAN
#-----
WMSG1 ="GSOC_ACTIVE="-GSOC_ACTIVE
WMSG1+=space$(36-len(WMSG1))
WMSG2 ="GSOC_UPDFLG="-num$(GSOC_UPDFLG)
WMSG2+=space$(30-len(WMSG2))
WMSG3=space$(24)
Call ECR_TRACE(WMSG1+WMSG2+WMSG3,0) From GESECRAN
#-----
Call ECR_TRACE("-----------------------------------------------",0) From GESECRAN
#-----
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
#-----
End


#---------------------------------------------------------------------------------#
# Récupération des globales référentiels, comptes et sections pour migration v150 #
# ------------------------------------------------------------------------------- #
# Paramčtre ŕ passer au sous-programme :                                          #
#   - WAPPLI  : Nom du dossier ŕ migrer                                           #
#   - WSITE   : Site                                                              #
#---------------------------------------------------------------------------------#
Subprog RECUP_GLOBAL_CPT(WAPPLI,WSITE)
Value  Char    WAPPLI
Value  Char    WSITE
#-----
Gosub TRT_GETDEV
#----- Ne pas recharger les globales si męme société que précédemment -----#
If dim([V]GSOC_ACTIVE2)>0 & [V]GSOC_ACTIVE2<>"" & [V]GSOC_ACTIVE2=[V]GSOCIETE
  End
Endif
#-----
If dim([V]GLONLED)<1  Global Shortint GLONLED : Endif
If dim([V]GLONCOA)<1  Global Shortint GLONCOA : Endif
If dim([V]GLONDIE)<1  Global Shortint GLONDIE : Endif
#-----
# Issue 74556 - 2011-06-23 by VPO : lecture ATY ssi besoin
If [V]GLONLED=0
  Read [ATY] CODTYP="LED"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3 : Endif
  [V]GLONLED=[F:ATY]LNGTYP
Endif
If [V]GLONCOA=0
  Read [ATY] CODTYP="COA"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3 : Endif
  [V]GLONCOA=[F:ATY]LNGTYP
Endif
If [V]GLONDIE=0
  Read [ATY] CODTYP="DIE"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3 : Endif
  [V]GLONDIE=[F:ATY]LNGTYP
Endif
#----- Globales utilisées pour les comptes et sections d'une société -----#
Global Integer GNBTYPLED                   : # Nbre de référentiel      (max 10)
Global Integer GTYPLED            (1..10)  : # Types de référentiel
Global Integer GTYPLED_X3TC    (1..10)  : # Types de référentiel : #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
Global Char    GLEDSOC([V]GLONLED)(1..10)  : # Codes  référentiel
Global Char    GDEVLED([V]GLONCUR)(1..10)  : # Devises référentiel
Global Integer GNBCOA                      : # Nbre de plans comptables (max 10)
Global Char    GCOA   ([V]GLONCOA)(1..10)  : # Codes plans
Global Integer GNBDIE                      : # Nbre d'axes (max 20)
Global Char    GDIE   ([V]GLONDIE)(1..20)  : # Codes axes
#-----
Global Char    GSOC_ACTIVE2(GLONCPY)       : # Société active
[V]GSOC_ACTIVE2=[V]GSOCIETE
#-----
Local  Integer WOBLDIE            (1..20)  : # Axes oligatoires (O/N)
#-----
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
Raz [V]GNBTYPLED, [V]GTYPLED_X3TC, [V]GTYPLED, [V]GLEDSOC, [V]GDEVLED, [V]GNBCOA, [V]GCOA, [V]GNBDIE, [V]GDIE
#----- Si modčle comptable non renseigné, c'est fini ! -----#
If [F:CPY]ACM=""  End : Endif
#-----
If GMODU(2)=2
  #-----
  # Issue 74556 - 2011-06-23 by VPO : ajout clalev
  If clalev([LED])=0 : Local File =WAPPLI+".GLED"  [LED] : Endif
  If clalev([ACV])=0 : Local File =WAPPLI+".ACTIV" [ACV] : Endif
  #-----
  Local Integer J, K
  Local Libelle WLEDTYP
  #-----
  Global Integer GOPTCANA
  # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
  If [F:ACV]CODACT<>"ANA"
    Read [ACV] CODACT="ANA" : If fstat  Raz [F:ACV] : Endif
  Endif
  [V]GOPTCANA=[F:ACV]DIME
  #-----
  WLEDTYP=[F:GCM]GENLEDTYP : Gosub TRT_GCOA
  WLEDTYP=[F:GCM]ANALEDTYP : Gosub TRT_GCOA
  #-----
  For I=1 To len(mess(0,2644,1))
    If I<>[F:GCM]GENLEDTYP & I<>[F:GCM]ANALEDTYP
      WLEDTYP=I : Gosub TRT_GCOA
    Endif
  Next I
  #-----
Endif
[V]GNBTYPLED=[V]GNBCOA
#-----
#Close Local File [ATY], [FCY], [CPY], [ADW], [ADP]
#If [V]GMODU(2)=2
#  Close Local File [GCM], [LED], [ACV]
#Endif
#-----
End


#--------------------------------#
# Chargement des plans de compte #
#--------------------------------#
$TRT_GCOA
If !find([F:GCM]LED(WLEDTYP-1),[V]GLEDSOC(1..GNBCOA))
  Read [LED] LED0=[F:GCM]LED(WLEDTYP-1)
  If !fstat
    [V]GNBCOA+=1
    [V]GCOA   (GNBCOA)=[F:LED]COA
    [V]GTYPLED(GNBCOA)=WLEDTYP
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    [V]GTYPLED_X3TC(GNBCOA)=WLEDTYP
    [V]GLEDSOC(GNBCOA)=[F:GCM]LED(WLEDTYP-1)
    [V]GDEVLED(GNBCOA)=[F:GCM]CUR(WLEDTYP-1)
    Gosub TRT_GDIE
  Endif
Endif
Return


#---------------------------------#
# Chargement des axes analytiques #
#---------------------------------#
$TRT_GDIE
If [V]GNBDIE>=[V]GOPTCANA  Return : Endif
For J=1 To [F:LED]DIENBR
  If !find([F:LED]DIE(J-1),GDIE(1..GNBDIE))
    [V]GNBDIE+=1
    [V]GDIE   (GNBDIE)=[F:LED]DIE(J-1)
    K=find([F:LED]DIE(J-1),[F:CPY]DIE(0..dim([F:FCY]DIE)-1))
    If K  [L]WOBLDIE(GNBDIE)=[F:CPY]OBYDIE(K-1) : Endif
    If [V]GNBDIE>=[V]GOPTCANA  Break : Endif
  Endif
Next J
Return


#----------------------------------------------------#
# Récupération société et devise pour migration v150 #
# -------------------------------------------------- #
# Paramčtre ŕ passer au sous-programme :             #
#   - WAPPLI  : Nom du dossier ŕ migrer              #
#   - WSITE   : Site                                 #
#----------------------------------------------------#
Subprog GETDEV(WAPPLI,WSITE)
Value  Char    WAPPLI
Value  Char    WSITE
#-----
Gosub TRT_GETDEV
#-----
#Close Local File [ATY], [FCY], [CPY], [ADW], [ADP]
#If [V]GMODU(2)=2
#  Close Local File [GCM]
#Endif
#-----
End


#-------------------------------------------#
# Traitement récupération société et devise #
#-------------------------------------------#
$TRT_GETDEV
#-----
# Issue 74556 - 2011-06-23 by VPO : ajout clalev
If clalev([ATY])=0 : Local File =WAPPLI+".ATYPE"    [ATY] : Endif
If clalev([FCY])=0 : Local File =WAPPLI+".FACILITY" [FCY] : Endif
If clalev([CPY])=0 : Local File =WAPPLI+".COMPANY"  [CPY] : Endif
If clalev([ADW])=0 : Local File =WAPPLI+".ADOVAL"   [ADW] : Endif
If clalev([ADP])=0 : Local File =WAPPLI+".ADOPAR"   [ADP] : Endif
#-----
If dim([V]GLONCPY)<1  Global Shortint GLONCPY : Endif
If dim([V]GLONFCY)<1  Global Shortint GLONFCY : Endif
If dim([V]GLONCUR)<1  Global Shortint GLONCUR : Endif
If dim([V]GLONADI)<1  Global Shortint GLONADI : Endif
#-----
# Issue 74556 - 2011-06-23 by VPO : lecture ATY ssi besoin
If [V]GLONCPY=0
  Read [ATY] CODTYP="CPY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
  [V]GLONCPY=[F:ATY]LNGTYP
Endif
If [V]GLONFCY=0
  Read [ATY] CODTYP="FCY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
  [V]GLONFCY=[F:ATY]LNGTYP
Endif
If [V]GLONCUR=0
  Read [ATY] CODTYP="CUR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
  [V]GLONCUR=[F:ATY]LNGTYP
Endif
If [V]GLONADI=0
  Read [ATY] CODTYP="ADI"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
  [V]GLONADI=[F:ATY]LNGTYP
Endif
#-----
# Issue 74556 - 2011-06-23 by VPO : definition globales ssi besoin
If dim([V]GSOCIETE)<1  : Global Char GSOCIETE ([V]GLONCPY) : Endif
If dim([V]GFINRSP)<1   : Global Char GFINRSP  ([V]GLONFCY) : Endif
If dim([V]GLOCALDEV)<1 : Global Char GLOCALDEV([V]GLONCUR) : Endif
If dim([V]GCURSHR)<1   : Global Char GCURSHR  ([V]GLONCUR) : Endif
If dim([V]GCURLEG)<1   : Global Char GCURLEG  ([V]GLONADI) : Endif
#-----
# Issue 74556 - 2011-06-23 by VPO : lecture FCY et CPY ssi besoin
If [F:FCY]FCY<>WSITE
  Read [FCY] FCY0=WSITE         : If fstat  Raz [F:FCY] : Endif
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
  Read [CPY] CPY0=[F:FCY]LEGCPY : If fstat  Raz [F:CPY] : Endif
Endif
#-----
[V]GSOCIETE =[F:FCY]LEGCPY
[V]GFINRSP  =[F:FCY]FINRSPFCY
[V]GLOCALDEV=[F:CPY]ACCCUR
[V]GCURLEG  =[F:FCY]LEG
#-----
If [V]GCURLEG="" : # on ne charge qu'une fois la valeur
  Read [ADW] ADW0="";"";"DOSLEG"
  If !fstat
    If instr(1,[F:ADW]VALEUR,"~")
      [V]GCURLEG=left$([F:ADW]VALEUR,instr(1,[F:ADW]VALEUR,"~")-1)
    Else
      [V]GCURLEG=[F:ADW]VALEUR
    Endif
  Endif
Endif
#-----
If dim([V]GMODU)<1  Global Libelle  GMODU(1..20) : Endif
Local  Char     WPARAM(10)
Local  Integer  I
#-----
Call PARAM("","CURSHRFLD",WPARAM) From ADOVAL
[V]GCURSHR=WPARAM
Call PARAM("","MODULE1",WPARAM) From ADOVAL
If WPARAM=""  WPARAM="2222222222" : Endif
For I=1 To 10  [V]GMODU(I)=val(mid$(WPARAM,I,1))    : Next I
Call PARAM("","MODULE2",WPARAM) From ADOVAL
If WPARAM=""  WPARAM="2222222222" : Endif
For I=1 To 10  [V]GMODU(I+10)=val(mid$(WPARAM,I,1)) : Next I
#-----
If [V]GMODU(2)=2
  If dim([V]GTYPGEN)<1  Global Libelle  GTYPGEN : Endif
  If dim([V]GTYPANA)<1  Global Libelle  GTYPANA : Endif
  # Issue 74556 - 2011-06-23 by VPO : ajout clalev + lecture ssi besoin
  If clalev([GCM])=0 : Local File =WAPPLI+".GACM" [GCM] : Endif
  If [F:GCM]GCM<>[F:CPY]ACM
    Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:GCM] : Endif
  Endif
  [V]GTYPGEN=max([F:GCM]GENLEDTYP,1)
  [V]GTYPANA=max([F:GCM]ANALEDTYP,1)
Endif
#-----
Return


#----------------------------------------------------------------#
# Enregistrement des comptes et sections de la ligne du document #
#      dans la table CPTANALIN, appelé par l'action VALLIG       #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WNOL     : Indice de la ligne en cours (nolign-1)          #
#   - WNOMACC  : Préfice du nom des comptes                      #
#                "" = il n'y a pas de gestion des comptes        #
#                Nota : Si "(" ŕ la fin du nom, c'est que        #
#                       les comptes sont en tableau ACC(0-9)     #
#                       au lieu de ACC1 ŕ ACC10                  #
#                       par exemple les commandes ouvertes       #
#   - WNOMDSP  : Nom du champ du code répartition                #
#                "" = il n'y a pas de code répartition           #
#   - WNOMCCE  : Préfixe du nom des sections analytiques         #
#                Nota : Si le nom ne commence pas par "["        #
#                       c'est un code section par défaut         #
#                       pour charger les sections par un INISEC  #
#                       Si "(" ŕ la fin du nom, c'est que        #
#                       les Sections sont en tableau CCE(0-19)   #
#                       au lieu de CCE1 ŕ CCE20                  #
#   - WABRFIC  : Abréviation table des lignes du document        #
#   - WVCRTYP  : Type de la pičce                                #
#   - WVCRNUM  : Numéro de la pičce                              #
#   - WVCRLIN  : Numéro de ligne de la pičce                     #
#   - WVCRSEQ  : Numéro de séquence de la pičce                  #
#   - WCPLCLE  : Complément clé                                  #
#   - WMAJCOD  : Code mise ŕ jour                                #
#                  "C" = Création                                #
#                  "M" = Modification                            #
#                  "A" = Annulation                              #
#----------------------------------------------------------------#
Subprog ENREG_ACCCCE(WNOL,WNOMACC,WNOMDSP,WNOMCCE,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE,WMAJCOD)
Value    Integer WNOL
Value    Char    WNOMACC
Value    Char    WNOMDSP
Value    Char    WNOMCCE
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
Value    Char    WMAJCOD
#-----
Local    Integer I, J
#-----
Local File CPTANALIN [CAL2] : # ŕ cause de l'INISEC qui peut écraser le buffer !
#----- Si l'enregistrement n'existe pas dans CPTANALIN, il faut passer en création -----#
If WMAJCOD="M"
  Look [CAL2] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
  If fstat  WMAJCOD="C" : Endif
Endif
#----- Suppression comptes et sections de la ligne du document -----#
If WMAJCOD="A"
  Delete [CAL2] Where ABRFIC=WABRFIC
&                   & VCRTYP=WVCRTYP
&                   & VCRNUM=WVCRNUM
&                   & VCRLIN=WVCRLIN
&                   & VCRSEQ=WVCRSEQ
&                   & CPLCLE=WCPLCLE
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN"-WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ) : End
  Endif
  End
#----- Modification des comptes et sections de la ligne du document -----#
Elsif WMAJCOD="M"
  Readlock [CAL2] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN"-WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ) : End
  Elsif fstat
    GOK=0  : Call RSTA("CAL",WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)) From GLOCK : End
  Endif
#----- Création des comptes et sections de la ligne du document -----#
Else
  Raz [F:CAL2]
  [F:CAL2]ABRFIC=WABRFIC
  [F:CAL2]VCRTYP=WVCRTYP
  [F:CAL2]VCRNUM=WVCRNUM
  [F:CAL2]VCRLIN=WVCRLIN
  [F:CAL2]VCRSEQ=WVCRSEQ
  [F:CAL2]CPLCLE=WCPLCLE
  [F:CAL2]ANALIG=1
Endif
#----- Effacement des comptes -----#
For I=0 To 9
  Raz [F:CAL2]LED(I), [F:CAL2]COA(I), [F:CAL2]ACC(I)
Next I
#----- Mise ŕ jour des comptes -----#
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
For I=1 To 10
  J=GTYPLED_X3TC(I)
  If J
    [F:CAL2]LED(J-1)=GLEDSOC(I)
    [F:CAL2]COA(J-1)=GCOA(I)
    If WNOMACC<>""
      #----- Comptes sur la ligne ACC1(nolign-1), ACC2(nolign-1) ...etc -----#
      If right$(WNOMACC,len(WNOMACC))<>"("
        If evalue("dim("+WNOMACC+num$(I)+")")>0
          [F:CAL2]ACC(J-1)=evalue(WNOMACC+num$(I)+"(WNOL)")
        Else
          Raz [F:CAL2]ACC(J-1)
        Endif
      #----- Comptes en tableau ACC(0), ACC(1), ACC(2) ... etc -----#
      Else
        If evalue("dim("+WNOMACC+"I-1))")>0
          [F:CAL2]ACC(J-1)=evalue(WNOMACC+"I-1)")
        Else
          Raz [F:CAL2]ACC(J-1)
        Endif
      Endif
      #-----
    Endif
  Endif
Next I
#----- Mise ŕ jour code répartition -----#
If WNOMDSP<>"" & evalue("dim("+WNOMDSP+")")>0
  [F:CAL2]DSP=evalue(WNOMDSP+"(WNOL)")
Endif
#----- Mise ŕ jour des sections analytiques -----#
For I=1 To max(GNBDIE,GOPTCANA)
  [F:CAL2]DIE(I-1)=GDIE(I)
  If left$(WNOMCCE,1)="["
    #----- Sections sur la ligne CCE1(nolign-1), CCE2(nolign-1) ...etc -----#
    If right$(WNOMCCE,len(WNOMCCE))<>"(" & evalue("dim("+WNOMCCE+num$(I)+")")>0
      [F:CAL2]CCE(I-1)=evalue(WNOMCCE+num$(I)+"(WNOL)")
    #----- Sections en tableau CCE(0), CCE(1), CCE(2) ... etc -----#
    Elsif right$(WNOMCCE,len(WNOMCCE))="(" & evalue("dim("+WNOMCCE+"I-1))")>0
      [F:CAL2]CCE(I-1)=evalue(WNOMCCE+"I-1)")
    Endif
  Else
    Call INISEC([F:CAL2]CCE(I-1),WNOMCCE,GDIE(I)) From SUBCDE
  Endif
Next I

#----- CPO 71515 - Point d'entrée
GPOINT="ENREG_ACCCCE" : Gosub ENTREE From EXEFNC
#-----

#-----
If WMAJCOD="M"  Rewrite [CAL2]  Else  Write [CAL2] : Endif
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : End : Endif
If clalev([F:CAL])  [F:CAL]=[F:CAL2] : Endif : # pour avoir en ligne ce que l'on écrit
#-----
End


#--------------------------------------------------------------#
# Chargement des comptes et sections de la ligne du document   #
#      Appelé par l'action LIENS_LIG ou aprčs un picking       #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WNOL     : Indice de la ligne en cours (nolign-1)        #
#   - WNOMACC  : Préfice du nom des comptes                    #
#                "" = il n'y a pas de gestion des comptes      #
#   - WNOMDSP  : Nom du champ du code répartition              #
#                "" = il n'y a pas de code répartition         #
#   - WNOMCCE  : Préfixe du nom des sections analytiques       #
#   - WABRFIC  : Abréviation table des lignes du document      #
#   - WVCRTYP  : Type de la pičce                              #
#   - WVCRNUM  : Numéro de la pičce                            #
#   - WVCRLIN  : Numéro de ligne de la pičce                   #
#   - WVCRSEQ  : Numéro de séquence de la pičce                #
#   - WCPLCLE  : Complément clé                                #
#--------------------------------------------------------------#
Subprog CHARG_ACCCCE(WNOL,WNOMACC,WNOMDSP,WNOMCCE,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE)
Value    Integer WNOL
Value    Char    WNOMACC
Value    Char    WNOMDSP
Value    Char    WNOMCCE
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
#-----
Local    Integer I, J
#-----
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
If 1=0 #--need more analysis...
  Local Integer IERROROPT
  Local Char    SZPROGNAME(GLONADC)
  Gosub CHARG_ACCCCE_FROMGENERATEDSCRIPT
  If IERROROPT <> 1 and dim(IERRTRTX3CPT) < 0 Then
    End
  Endif
Endif
# End issue X3-38496
#-----
Read [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
If !fstat
  If WNOMACC<>""
    For I=1 To 10
      If evalue("dim("+WNOMACC+num$(I)+")")>0
        Assign WNOMACC+num$(I)+"(WNOL)" With ""
      Endif
    Next I
    For I=1 To 10 : # max(GNBTYPLED,2)
      J=find([F:CAL]LED(I-1),GLEDSOC(1..GNBTYPLED))
      If J & evalue("dim("+WNOMACC+num$(J)+")")>0
        Assign WNOMACC+num$(J)+"(WNOL)" With [F:CAL]ACC(I-1)
      Endif
    Next I
  Endif
  If WNOMDSP<>""
    Assign WNOMDSP+"(WNOL)" With [F:CAL]DSP
  Endif
  For I=1 To 20
    If evalue("dim("+WNOMCCE+num$(I)+")")>0
      Assign WNOMCCE+num$(I)+"(WNOL)" With ""
    Endif
  Next I
  For I=1 To max(GNBDIE,GOPTCANA)
    J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    If J & evalue("dim("+WNOMCCE+num$(J)+")")>0
      Assign WNOMCCE+num$(J)+"(WNOL)" With [F:CAL]CCE(I-1)
    Endif
  Next I
Endif
#-----
End
#------------------------------------------
# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
$CHARG_ACCCCE_FROMGENERATEDSCRIPT
  Local Integer WPOSITION
  Local Char    WICHFILE(GLONABR+GLONAVA+GLONAVA)
  Local Char    WSCREEN(GLONABR+4)
  Local Char    WFIELD_CCE(GLONAVA), WFIELD_ACC(GLONAVA)


  Raz WSCREEN
  If WNOMACC<>""
    WSCREEN = left$(WNOMACC,instr(1,WNOMACC,"]"))
    WFIELD_ACC = right$(WNOMACC,instr(1,WNOMACC,"]")+1)
  Endif
  If WNOMCCE<>""
    WFIELD_CCE = right$(WNOMCCE,instr(1,WNOMCCE,"]")+1)
    If WSCREEN<>""
      If WSCREEN<>left$(WNOMCCE,instr(1,WNOMCCE,"]"))
        Raz WSCREEN #--one script by screen; not handling ACC and CCE from 2 different screens (we use the old code)
      Endif
    Else
      WSCREEN = left$(WNOMCCE,instr(1,WNOMCCE,"]"))
    Endif
  Endif

  If WSCREEN<>""
    #--the wscreen var will contain something like "[M:SIH4]"; we have to replace the 'M','[',']' and ':' characters
    WPOSITION = instr(1,WSCREEN,"[")
    If WPOSITION : WSCREEN = right$(WSCREEN,WPOSITION+1) : Endif
    WPOSITION = instr(1,WSCREEN,"M")
    If WPOSITION : WSCREEN = right$(WSCREEN,WPOSITION+1) : Endif
    WPOSITION = instr(1,WSCREEN,":")
    If WPOSITION : WSCREEN = right$(WSCREEN,WPOSITION+1) : Endif
    WPOSITION = instr(1,WSCREEN,"]")
    If WPOSITION : WSCREEN = left$(WSCREEN,WPOSITION-1) : Endif

    If WSCREEN<>"" and len(WSCREEN)<=4 #--only existing and tested screeen calls
      Raz WICHFILE
      WICHFILE = WSCREEN
      If WFIELD_ACC<>""
        WICHFILE += WFIELD_ACC
      Endif
      If WFIELD_CCE<>""
        WICHFILE += WFIELD_CCE
      Endif

      #--We are replacing the assign/evalue with generated scripts (as done in SUBSFIT.UPD_NBFAC)
      Call OPTIMISATION_CHARG_ACCCCE(WICHFILE,WNOL,WNOMACC,WNOMDSP,WNOMCCE,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE,IERROROPT)
      If IERROROPT = 0 Then
        SZPROGNAME = func GET_NOM_SCRIPT_OPT("CHARG_ACCCCE",WICHFILE)
        If [L]SZPROGNAME <> ""
          Gosub DYNAMIQUE_LOAD_CCE From =SZPROGNAME
        Else
          IERROROPT = 1
        Endif
      Endif
    Else
      IERROROPT = 1
    Endif
  Else
    IERROROPT = 1
  Endif

  If IERROROPT = 1 or dim(IERRTRTX3CPT) >= 0 Then
    # On se replie sur la méthode non optimisée
    $NOT_DYNAMIQUE_LOAD_CCE       # Pour détecter, en trace timing que le script généré n'a pas été utilisé
    If GTRACE <> "" Then
      Call ECR_TRACE("Generated script not used (1).", -1) From GESECRAN
    Endif
    #--Old code executed after Return
    If dim(IERRTRTX3CPT) >= 0 Then
      Kill IERRTRTX3CPT
    Endif
  Endif

Return
#------------------------------------------
Subprog OPTIMISATION_CHARG_ACCCCE(WSCREEN,WNOL,WNOMACC,WNOMDSP,WNOMCCE,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE,IERROR)
Value    Char    WSCREEN
Value    Integer WNOL
Value    Char    WNOMACC
Value    Char    WNOMDSP
Value    Char    WNOMCCE
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
Variable Integer IERROR
#-----
Local    Integer I, J
#-----

Local Integer PSUBB
Local Integer IVALIDOK
Local Integer IOK
Local Integer INB
Local Char    SZADXIFS(type(adxifs)-10)
Local Char    SZADXIRS(type(adxirs)-10)
Local Char    SZPROGNAME(GLONADC)
Local Char    SZFULLSRC(250)
Local Char    SZFULLADX(250)
Local Char    SVERSIONSRC(10)

Local Integer ZWTMPMAXNBDIE

  SZPROGNAME = func GET_NOM_SCRIPT_OPT("CHARG_ACCCCE",WSCREEN)
  If [L]SZPROGNAME = "" : IERROR = 1 : End : Endif

  SVERSIONSRC = "V1.0"                                  # Vesion du script généré pour permettre des évolutions
  #---------------------------------------------------
  IERROR = 0
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
  #---------------------------------------------------
  PSUBB = 1
  If filinfo(filpath("TRT", SZPROGNAME, "src", 0), 0) >= 0 and filinfo(filpath("TRT", SZPROGNAME, "adx", 0), 0) >= 0 Then
    # On regarde si le traitement est toujours valable
    Call CONTROLE(SVERSIONSRC, IOK) From =SZPROGNAME
    If IOK = 0 Then
      Call EFFACE_ADX("", nomap, SZPROGNAME, IVALIDOK) From ORDSYS
      Call EFFACE(SZFULLSRC, IVALIDOK) From ORDSYS
      Call EFFACE(SZFULLADX, IVALIDOK) From ORDSYS
      PSUBB = 0
    Endif
  Else
    PSUBB = 0
  Endif
  #---------------------------------------------------
  If !PSUBB Then
    SZADXIFS = adxifs
    SZADXIRS = adxirs
    adxifs = ""
    adxirs = chr$(10)
    # --------------------------------------------------
    Openo SZFULLSRC, 0 Using [LOADCCE]
    # --------------------------------------------------
    Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"                  Using [LOADCCE]
    Wrseq "#Generated script from TRTX3CPT"             Using [LOADCCE]
    Wrseq "#" + string$(80, "=")                        Using [LOADCCE]
    Wrseq "End"                                         Using [LOADCCE]
    Wrseq ""                                            Using [LOADCCE]
    Wrseq "$DYNRIEN"                                    Using [LOADCCE]
    Wrseq "Local Integer IERRTRTX3CPT"                  Using [LOADCCE]
    Wrseq "  IERRTRTX3CPT = 1"                          Using [LOADCCE]
    Wrseq "Resume"                                      Using [LOADCCE]
    Wrseq ""                                            Using [LOADCCE]
    # --------------------------------------------------
    Wrseq "#" + string$(80, "=")                        Using [LOADCCE]
    Wrseq "Subprog CONTROLE(SVERSION, IOK)"             Using [LOADCCE]
    Wrseq "Value Char SVERSION"                         Using [LOADCCE]
    Wrseq "Variable Integer IOK"                        Using [LOADCCE]
    Wrseq ""                                            Using [LOADCCE]
    Wrseq "  IOK = 1"                                   Using [LOADCCE]
    Wrseq "  If SVERSION <> '" + SVERSIONSRC + "' Then" Using [LOADCCE] #--handling future script versions (due to fixes, improvements, etc.)
    Wrseq "    IOK = 0"                                 Using [LOADCCE]
    Wrseq "    End"                                     Using [LOADCCE]
    Wrseq "  Endif "                                    Using [LOADCCE]
    Wrseq "End "                                        Using [LOADCCE]
    # --------------------------------------------------
    Wrseq "#" + string$(80, "=")                        Using [LOADCCE]
    Wrseq "$DYNAMIQUE_LOAD_CCE"                         Using [LOADCCE]
    Wrseq "  Onerrgo DYNRIEN"                           Using [LOADCCE]
    #-----
    Wrseq "  Read [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1"   Using [LOADCCE]
    Wrseq "  If !fstat"                                                           Using [LOADCCE]
    If WNOMACC<>""
      Wrseq "    If WNOMACC<>''"                                                    Using [LOADCCE]
      For ZWTMPNBDIE = 1 To 10
        Wrseq "      If dim("+WNOMACC+num$(ZWTMPNBDIE)+")>0"                        Using [LOADCCE]
        Wrseq "        "+WNOMACC+num$(ZWTMPNBDIE)+"(WNOL) = ''"                     Using [LOADCCE]
        Wrseq "      Endif"                                                         Using [LOADCCE]
      Next ZWTMPNBDIE
      Wrseq "      For I=1 To 10"                                                   Using [LOADCCE]
      Wrseq "        J=find([F:CAL]LED(I-1),GLEDSOC(1..GNBTYPLED))"                 Using [LOADCCE]
      Wrseq "        If J"                                                          Using [LOADCCE]
      Wrseq "          Case J"                                                      Using [LOADCCE]
      For ZWTMPNBDIE = 1 To 10
        Wrseq "            When "+num$(ZWTMPNBDIE)+" : "                            Using [LOADCCE]
        Wrseq "                     "+"If dim("+WNOMACC+num$(ZWTMPNBDIE)+"(WNOL)"+")>0"     Using [LOADCCE]
        Wrseq "                       "+WNOMACC+num$(ZWTMPNBDIE)+"(WNOL) = [F:CAL]ACC(I-1)" Using [LOADCCE]
        Wrseq "                     "+"Endif"                                               Using [LOADCCE]
      Next ZWTMPNBDIE
      Wrseq "          Endcase"                                                     Using [LOADCCE]
      Wrseq "        Endif"                                                         Using [LOADCCE]
      Wrseq "      Next I"                                                          Using [LOADCCE]
      Wrseq "    Endif    "                                                         Using [LOADCCE]
    Endif
    Wrseq "    If WNOMDSP<>''"                                                    Using [LOADCCE]
    Wrseq "      WNOMDSP(WNOL) = [F:CAL]DSP"                                      Using [LOADCCE]
    Wrseq "    Endif"                                                             Using [LOADCCE]
    If WNOMCCE<>""
      For ZWTMPNBDIE = 1 To 20
        Wrseq "    If dim("+WNOMCCE+num$(ZWTMPNBDIE)+")>0"                          Using [LOADCCE]
        Wrseq "      "+WNOMCCE+num$(ZWTMPNBDIE)+"(WNOL) = ''"                       Using [LOADCCE]
        Wrseq "    Endif"                                                           Using [LOADCCE]
      Next ZWTMPNBDIE
      Wrseq "    For I=1 To max(GNBDIE,GOPTCANA)"                                   Using [LOADCCE]
      Wrseq "      J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))"                         Using [LOADCCE]
      Wrseq "      If J"                                                            Using [LOADCCE]
      Wrseq "        Case J"                                                        Using [LOADCCE]
      For ZWTMPNBDIE = 1 To 10
        Wrseq "           When "+num$(ZWTMPNBDIE)+" : "                             Using [LOADCCE]
        Wrseq "                     "+"If dim("+WNOMCCE+num$(ZWTMPNBDIE)+"(WNOL)"+")>0"     Using [LOADCCE]
        Wrseq "                       "+WNOMCCE+num$(ZWTMPNBDIE)+"(WNOL) = [F:CAL]CCE(I-1)" Using [LOADCCE]
        Wrseq "                     "+"Endif"                                               Using [LOADCCE]
      Next ZWTMPNBDIE
      Wrseq "        Endcase"                                                       Using [LOADCCE]
      Wrseq "      Endif"                                                           Using [LOADCCE]
      Wrseq "    Next I"                                                            Using [LOADCCE]
    Endif
    Wrseq "  Endif    "                                                           Using [LOADCCE]

    Wrseq ""                                                                      Using [LOADCCE]
    Wrseq "  Onerrgo"                                                             Using [LOADCCE]
    Wrseq "Return"                                                                Using [LOADCCE]
    Wrseq "#" + string$(80, "=")                                                  Using [LOADCCE]
    Wrseq ""                                                                      Using [LOADCCE]
    # --------------------------------------------------

    Openo Using [LOADCCE]
    # --------------------------------------------------
    # On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    # --------------------------------------------------
    # Compilation du traitement généré
    Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
    If !IVALIDOK Then
      IERROR = 1
    Endif
    # --------------------------------------------------
  Endif
End
#------------------------------------------
Funprog GET_NOM_SCRIPT_OPT(WSUBPROG,WABRMSK)
Value Char WSUBPROG
Value Char WABRMSK

Local Char SZPROGNAME(GLONADC) : Raz [L]SZPROGNAME

  SZPROGNAME = "W"
  Case WSUBPROG
     When "CHARG_CCE"    : SZPROGNAME += WSUBPROG
     When "CHARG_ACCCCE" : SZPROGNAME += WSUBPROG
     When Default : Raz SZPROGNAME
  Endcase
  If len(SZPROGNAME)+len(WABRMSK)<=GLONADC
    If WABRMSK<>""
      SZPROGNAME += "_"+WABRMSK
    Endif
  Else
    Raz [L]SZPROGNAME
  Endif

End SZPROGNAME
# End issue X3-38496

#--------------------------------------------------------------#
# Chargement des comptes et sections de la ligne du document   #
#      Appelé par les traitements d'import                     #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WNOL     : Indice de la ligne en cours (nolign-1)        #
#   - WNOMACC  : Préfice du nom des comptes                    #
#                "" = il n'y a pas de gestion des comptes      #
#   - WNOMDSP  : Nom du champ du code répartition              #
#                "" = il n'y a pas de code répartition         #
#   - WNOMCCE  : Préfixe du nom des sections analytiques       #
#                                                              #
# Nota : La classe [F:CAL] doit ętre alimentée !               #
# Si traitement des éléments de facturation, penser ŕ charger  #
# la classe CPTANALIN [F:CAL] ŕ partir de CPTFOOTLNK [F:CFL]   #
#--------------------------------------------------------------#
Subprog IMPORT_ACCCCE(WNOL,WNOMACC,WNOMDSP,WNOMCCE)
Value    Integer WNOL
Value    Char    WNOMACC
Value    Char    WNOMDSP
Value    Char    WNOMCCE
#-----
Local    Integer I, J
#-----
If WNOMACC<>""
  For I=1 To 10 : # max(GNBTYPLED,2)
    If [F:CAL]ACC(I-1)<>""
      If [F:CAL]LED(I-1)<>""
        J=find([F:CAL]LED(I-1),GLEDSOC(1..GNBTYPLED))
      Else
        J=I
      Endif
      If J & evalue("dim("+WNOMACC+num$(J)+")")>0
        Assign WNOMACC+num$(J)+"(WNOL)" With [F:CAL]ACC(I-1)
      Endif
    Endif
  Next I
Endif
#-----
If WNOMDSP<>""
  If [F:CAL]DSP<>""
    Assign WNOMDSP+"(WNOL)" With [F:CAL]DSP
  Endif
Endif
#-----
For I=1 To max(GNBDIE,GOPTCANA)
  If [F:CAL]CCE(I-1)<>""
    If [F:CAL]DIE(I-1)<>""
      J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    Else
      J=I
    Endif
    If J & evalue("dim("+WNOMCCE+num$(J)+")")>0
      Assign WNOMCCE+num$(J)+"(WNOL)" With [F:CAL]CCE(I-1)
    Endif
  Endif
Next I
#-----
End


#--------------------------------------------------------------#
# Chargement des comptes présentés comme des comptes entęte    #
# indicés et stockés dans une table du document (ex PORDERC)   #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WNOMACC  : Nom du champ contenant les comptes (ex "ACC") #
#   - WABRFIC  : Abréviation table contenant les comptes       #
#--------------------------------------------------------------#
Subprog CHARG_ACCX(WABRMSK,WBASTAB,WNOMACC,WABRFIC)
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WNOMACC
Value    Char    WABRFIC
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Integer I, J
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
#-----
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBCOA"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#----- Si le tableau n'existe pas, c'est fini ! -----#
If evalue("dim("+[L]BATAB+")")<1  End : Endif
#-----
If WNOMACC=""
  WNOMACC="ACC"
Endif
#-----
Assign [L]BATAB With GNBCOA
#-----
For I=1 To GNBCOA
  Assign [L]ECRAN+"COA(I-1)" With GCOA(I)
  J=evalue("find([F:"+WABRFIC+"]COA(I-1),GCOA(1..GNBDIE))")
  If J
    Assign [L]ECRAN+WNOMACC+"(J-1)" With evalue("[F:"+WABRFIC+"]"+WNOMACC+"(I-1)")
  Endif
Next I
#-----
End


#--------------------------------------------------------------#
# Chargement des sections analytiques de la ligne du document  #
# depuis CPTANALIN                                             #
#               Appelé par l'action LIENS_LIG                  #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WNOL     : Indice de la ligne en cours (nolign-1)        #
#   - WABRFIC  : Abréviation table des lignes du document      #
#   - WVCRTYP  : Type de la pičce                              #
#   - WVCRNUM  : Numéro de la pičce                            #
#   - WVCRLIN  : Numéro de ligne de la pičce                   #
#   - WVCRSEQ  : Numéro de séquence de la pičce                #
#   - WCPLCLE  : Complément clé                                #
#--------------------------------------------------------------#
Subprog CHARG_CCE(WABRMSK,WNOL,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE)
Value    Char    WABRMSK
Value    Integer WNOL
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Integer I, J
#-----
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
#-----
Read [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
If !fstat
  For I=1 To 20
    If evalue("dim("+[L]ECRAN+"CCE"+num$(I)+")")>0
      Assign [L]ECRAN+"CCE"+num$(I)+"(WNOL)" With ""
    Endif
  Next I
  For I=1 To max(GNBDIE,GOPTCANA)
    J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    If J
      Assign [L]ECRAN+"CCE"+num$(J)+"(WNOL)" With [F:CAL]CCE(I-1)
    Endif
  Next I
Endif
#-----
End


#--------------------------------------------------------------#
# Chargement des sections analytiques entęte du document       #
# Tables de base (paramétrage):                                #
# cas oů les sections ne sont pas stockées dans CPTANALIN      #
#                 Appelé par l'action LIENS                    #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WABRFIC  : Abréviation table entęte du document          #
#--------------------------------------------------------------#
Subprog CHARG_CCEH(WABRMSK,WBASTAB,WABRFIC)
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WABRFIC
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Integer I, J
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
#-----
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#----- Si le tableau n'existe pas (soumis ŕ code activité ANA), c'est fini ! -----#
If evalue("dim("+[L]BATAB+")")<1  End : Endif
#-----
Assign [L]BATAB With GNBDIE
#-----
For I=1 To max(GNBDIE,GOPTCANA)
  # Issue 74433 - 2011-06-17 by VPO : pb code activité ANA désactivé & GOPTCANA=0
  # il faut tester dim de DIE
  If evalue("dim("+[L]ECRAN+"DIE(I-1)"+")")>0
    Assign [L]ECRAN+"DIE(I-1)" With GDIE(I)
  Endif
  J=evalue("find([F:"+WABRFIC+"]DIE(I-1),GDIE(1..GNBDIE))")
  If J
    Assign [L]ECRAN+"CCE(J-1)" With evalue("[F:"+WABRFIC+"]CCE(I-1)")
  Endif
Next I
#-----
End


#--------------------------------------------------------------#
# Chargement des sections analytiques présentées comme des     #
# sections d'entęte mais stockées dans une table particuličre  #
# pouvant ętre CPTANALIN et avec des noms de champs écran      #
# particuliers.                                                #
# Avant l'appel ŕ ce S/P, il faut lire la table contenant les  #
# sections (table dont l'abréviation est WABRFIC)              #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WABRFIC  : Abréviation table contenant les sections      #
#   - WDIENAM  : Nom du champ contenant le code axe            #
#   - WCCENAM  : Nom du champ contenant la section analytique  #
#--------------------------------------------------------------#
Subprog CHARG_CCEX(WABRMSK,WBASTAB,WABRFIC,WDIENAM,WCCENAM)
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WABRFIC
Value    Char    WDIENAM
Value    Char    WCCENAM
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Integer I, J
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
#-----
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#-----
Assign [L]BATAB With GNBDIE
#-----
For I=1 To max(GNBDIE,GOPTCANA)
  # Issue 74433 - 2011-06-17 by VPO : pb code activité ANA désactivé & GOPTCANA=0
  # il faut tester dim de DIE
  If evalue("dim("+[L]ECRAN+WDIENAM+"(I-1)"+")")>0
    Assign [L]ECRAN+WDIENAM+"(I-1)" With GDIE(I)
  Endif
  J=evalue("find([F:"+WABRFIC+"]DIE(I-1),GDIE(1..GNBDIE))")
  If J
    Assign [L]ECRAN+WCCENAM+"(J-1)" With evalue("[F:"+WABRFIC+"]CCE(I-1)")
  Endif
Next I
#-----
End


#------------------------------------------------------------------#
# Initialisation sections analytiques ligne sans gestion de compte #
# ---------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                          #
#   - WSECTION : Valeur de la section chargée en sortie            #
#   - WSECDEF  : Code paramétrage sections par défaut              #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                          #
#------------------------------------------------------------------#
Subprog INISEC(WSECTION,WSECDEF,WAXE)
Variable Char    WSECTION
Value    Char    WSECDEF
Value    Integer WAXE
#-----
Local    Char    WNOMCPT(20)
Local    Integer WNOL
#-----
Raz [L]WNOMCPT, [L]WNOL
Gosub TRT_INIT_CCE
#-----
End


#----------------------------------------------------------------#
# Initialisation des sections analytiques d'une ligne            #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WSECTION : Valeur de la section chargée en sortie          #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                        #
#   - WSECDEF  : Code paramétrage sections par défaut            #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                "" = il n' y a pas de gestion des comptes       #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#   - WNOL     : Indice de la ligne encours (nolign-1)           #
#                 0 si WNOMCPT=""                                #
#----------------------------------------------------------------#
Subprog INIT_CCE(WSECTION,WAXE,WSECDEF,WNOMCPT,WNOL)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WSECDEF
Value    Char    WNOMCPT
Value    Integer WNOL
#-----
Gosub TRT_INIT_CCE
#-----
End


#---------------------------------------------------------------#
# Traitement de l'initialisation des sections analytiques ligne #
#---------------------------------------------------------------#
$TRT_INIT_CCE
#----- Si no d'axe au delŕ du maxi, pas la peine d'initialiser ! -----#
If WAXE>GNBDIE  Return : Endif
#-----
Local    Char    ACC(GLONGAC)
Local    Integer I, ILED, IDIE, IGAC
Local    Libelle WACCFLG
#-----
If GMODU(2)=2
  If !clalev([F:LED])  Local File GLED     [LED] : Endif
Endif
Raz [L]WACCFLG
If WNOMCPT<>""
  If !clalev([F:GAC])  Local File GACCOUNT [GAC] : Endif
  If right$(WNOMCPT,len(WNOMCPT))="("
    [L]WACCFLG=1
  Endif
Endif
#-----
Raz WSECTION
For I=1 To GNBCOA
  Call INDLED(GLEDSOC(I),GDIE(WAXE),[L]ILED,[L]IDIE) From CPTDIV
  If [L]ILED & [L]IDIE
    If WNOMCPT<>""
      If [L]WACCFLG=1
        [L]ACC=evalue(WNOMCPT+"[L]I-1)")
      Else
        [L]ACC=evalue(WNOMCPT+num$([L]I)+"([L]WNOL)")
      Endif
      # Issue X3-58146 - 2017-10-05 by MUARN : Ajout [F:GAC] pour ACC
      If [F:GAC]COA<>GLEDCOA([L]ILED) | [F:GAC]ACC<>[L]ACC
        Read [GAC] GAC0=GLEDCOA([L]ILED);[L]ACC : If fstat  Raz [F:GAC] : Endif
      Endif
      If [F:GAC]ACC<>""
        IGAC=find(GDIE(WAXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        If IGAC
          Call INISEC(WSECTION,WSECDEF,GDIE(WAXE)) From SUBCDE
          #If WSECTION=""
          #  WSECTION=[F:GAC]CCEDEF(IGAC-1)
          #Endif
        Endif
      Else
        Call INISEC(WSECTION,WSECDEF,GDIE(WAXE)) From SUBCDE
      Endif
    Else
      Call INISEC(WSECTION,WSECDEF,GDIE(WAXE)) From SUBCDE
    Endif
  Endif
  If WSECTION<>""  Break : Endif
Next I
#-----
Return


#--------------------------------------------------------------#
# Initialisation des sections analytiques en entęte            #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WSECDEF  : Code paramétrage sections par défaut          #
#                (exemple "POH")                               #
#--------------------------------------------------------------#
Subprog INIT_CCEH(WABRMSK,WBASTAB,WSECDEF)
Value   Char    WABRMSK
Value   Char    WBASTAB
Value   Char    WSECDEF
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Char    SECTION(GLONCCE)
#Local    Char    MSK_COURANT
Local    Char    WFMTDIE
Local    Integer I
#----- Chargement abréviation du masque courant -----#
#If instr(1,dbgstr(1),",")
#  [L]MSK_COURANT=vireblc(left$(dbgstr(1),instr(1,dbgstr(1),",")-1),4)
#Else
#  [L]MSK_COURANT=vireblc(dbgstr(1),4)
#Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]" : # Default Mask "["+WABRMSK+"]"
Endif
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#-----
For [L]I=1 To GNBDIE
  Assign [L]ECRAN+"DIE([L]I-1)" With GDIE([L]I)
  If evalue([L]ECRAN+"CCE([L]I-1)")="" & GENVDIE([L]I)<>2
    Call INISEC([L]SECTION,WSECDEF,GDIE([L]I)) From SUBCDE
    Assign [L]ECRAN+"CCE([L]I-1)" With [L]SECTION
  Endif
Next [L]I
Assign [L]BATAB With GNBDIE
#----- Affichage et rétablissement masque par défaut si nécessaire -----#
#If !GIMPORT  Affzo [M]DIE, CCE : Endif
#If WABRMSK<>""
#  Default Mask [L]MSK_COURANT
#Endif
#-----
End


#--------------------------------------------------------------#
# Initialisation des sections analytiques présentées comme des #
# sections d'entęte mais avec des noms de champs écran         #
# particuliers.                                                #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WSECDEF  : Code paramétrage sections par défaut          #
#   - WDIENAM  : Nom du champ contenant le code axe            #
#   - WCCENAM  : Nom du champ contenant la section analytique  #
#--------------------------------------------------------------#
Subprog INIT_CCEX(WABRMSK,WBASTAB,WSECDEF,WDIENAM,WCCENAM)
Value   Char    WABRMSK
Value   Char    WBASTAB
Value   Char    WSECDEF
Value   Char    WDIENAM
Value   Char    WCCENAM
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Char    SECTION(GLONCCE)
Local    Char    MSK_COURANT
Local    Char    WFMTDIE
Local    Integer I
#----- Chargement abréviation du masque courant -----#
If instr(1,dbgstr(1),",")
  [L]MSK_COURANT=vireblc(left$(dbgstr(1),instr(1,dbgstr(1),",")-1),4)
Else
  [L]MSK_COURANT=vireblc(dbgstr(1),4)
Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]" : Default Mask "["+WABRMSK+"]"
Endif
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#-----
For [L]I=1 To GNBDIE
  Assign [L]ECRAN+WDIENAM+"([L]I-1)" With GDIE([L]I)
  If evalue([L]ECRAN+WCCENAM+"([L]I-1)")=""
    Call INISEC([L]SECTION,WSECDEF,GDIE([L]I)) From SUBCDE
    Assign [L]ECRAN+WCCENAM+"([L]I-1)" With [L]SECTION
  Endif
Next [L]I
Assign [L]BATAB With GNBDIE
#----- Affichage et rétablissement masque par défaut si nécessaire -----#
If !GIMPORT  Affzo [M]1-99 : Endif
If WABRMSK<>""
  Default Mask [L]MSK_COURANT
Endif
#-----
End


#-----------------------------------------------------------#
# Avant saisie des sections analytiques d'entęte            #
# --------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                   #
#   - WSECTION : Valeur de la section avant saisie (VALEUR) #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                   #
#                                                           #
# En sortie mkstat=2 si il est inutile de saisir la section #
#-----------------------------------------------------------#
Subprog AVSAI_CCEH(WSECTION,WAXE)
Variable Char    WSECTION
Value    Integer WAXE
#-----
If WAXE<1 | WAXE>20  End : Endif
If GENVDIE(WAXE)=2   mkstat=2 : Endif
#-----
End


#----------------------------------------------------------------#
# Avant saisie des sections analytiques d'une ligne              #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WSECTION : Valeur de la section ŕ contrôler                #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                        #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                "" = il n' y a pas de gestion des comptes       #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#   - WNOMDSP  : Nom du champ du code répartition                #
#                (exemples "[M:PIH4]DSP" ou "[M:PIH3]LINDSP")    #
#                "" = il n'y a pas de code répartition           #
#----------------------------------------------------------------#
Subprog SAIS_CCE(WSECTION,WAXE,WNOMCPT,WNOMDSP)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WNOMCPT
Value    Char    WNOMDSP
#----- Si code répartition renseigné, alors pas de saisie de section -----#
If WNOMDSP<>"" & evalue(WNOMDSP+"(nolign-1)")<>""  mkstat=2 : End : Endif
#----- Pas de module compta => pas de ctrl
If GMODU(2)<>2  : End : Endif
#-----
Local    Char    ACC(GLONGAC)
Local    Integer I
Local    Libelle WACCFLG
#-----
Raz [L]WACCFLG
If WNOMCPT<>""
  If !clalev([F:GAC])  Local File GACCOUNT [GAC] : Endif
  If right$(WNOMCPT,len(WNOMCPT))="("
    [L]WACCFLG=1
  Endif
  # Issue 73830 - 2011-10-18 by VPO : on doit controler les référentiels et non pas les plans de compte
  #For [L]I=1 To GNBCOA
  #  mkstat=2
  #  If [L]WACCFLG=1
  #    [L]ACC=evalue(WNOMCPT+"[L]I-1)")
  #  Else
  #    [L]ACC=evalue(WNOMCPT+num$([L]I)+"(nolign-1)")
  #  Endif
  #  If [F:GAC]COA<>GCOA([L]I) | [F:GAC]ACC<>[L]ACC
  #    Read [GAC] GAC0=GCOA([L]I);[L]ACC : If fstat  Raz [F:GAC] : Endif
  #  Endif
  #  If [F:GAC]ACC<>""
  #    If find(GDIE(WAXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  #      Raz mkstat : Break
  #    Endif
  #  Endif
  #Next [L]I

  Local Integer NLED
  Local Integer AXI, IND
  mkstat = 1
  For NLED=1 To GNBTYPLED
   Call INDLED(GLEDSOC(NLED),GDIE(WAXE),IND,AXI) From CPTDIV
   If AXI
    If [L]WACCFLG=1
      [L]ACC=evalue(WNOMCPT+"NLED-1)")
    Else
      [L]ACC=evalue(WNOMCPT+num$(NLED)+"(nolign-1)")
    Endif
    If [F:GAC]COA<>GCOA(NLED) | [F:GAC]ACC<>[L]ACC
      Read [GAC] GAC0=GCOA(NLED);[L]ACC : If fstat  Raz [F:GAC] : Endif
    Endif
    If [F:GAC]ACC<>""
      If find(GDIE(WAXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        Raz mkstat : Break
      Endif
    Endif
   Endif
  Next
  # FIN Issue 73830 - 2011-10-18 by VPO : on doit controler les référentiels et non pas les plans de compte

Else
  #----- Recherche indice compte analytique -----#
  Call RECH_INDACC(2,I)
  If I=0  mkstat=2 : Endif : # Pas d'indice, pas de saisie !
Endif
#-----
End

#----------------------------------------------------------------#
# Contrôle sections analytiques ligne d'un élément facturation   #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WSECTION : Valeur de la section ŕ contrôler                #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                        #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                "" = il n' y a pas de gestion des comptes       #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#   - WFCY     : Site financier de la société (GFINRSP)          #
#   - WDATE    : Date                                            #
#----------------------------------------------------------------#
Subprog CTRL_PFICCE(WSECTION,WAXE,WNOMCPT,WFCY,WDATE)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WNOMCPT
Value    Char    WFCY
Value    Date    WDATE
#-----
Local    Char    WNOMCCE(15) : [L]WNOMCCE="[M]PFICCE"
Local    Integer NOL         : [L]NOL=nolign-1
Local    Libelle WINDIC      : [L]WINDIC=1
#-----
Gosub CTRL_CCE_DEB
# Bug 71102 : Il faut laisser le contrôle bloquant dans tous les cas
#----- Erreur non bloquante si saisie en mode fiche uniquement -----#
#If mkstat & GSCRDIE=2
#  Raz mkstat : GERR=2 : GMESSAGE=mess(278,199,1)+"\"+GMESSAGE
#Endif
#-----
End

