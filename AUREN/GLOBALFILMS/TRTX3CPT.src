#---------------------------------------------------#
# Restauration des globales (au retour d'un tunnel) #
#---------------------------------------------------#
$REST_GLOBAL_CPT
If dim(WGNBTYPLED)>0   GNBTYPLED  =WGNBTYPLED   : Endif
If dim(WGNBCOA)>0      GNBCOA     =WGNBCOA      : Endif
If dim(WGNBDIE)>0      GNBDIE     =WGNBDIE      : Endif
If dim(WGSCRCOA)>0     GSCRCOA    =WGSCRCOA     : Endif
If dim(WGSCRDIE)>0     GSCRDIE    =WGSCRDIE     : Endif
If dim(WGSCRDIE2)>0    GSCRDIE2   =WGSCRDIE2    : Endif # FQ 59219
If dim(WGSCRDIE3)>0    GSCRDIE3   =WGSCRDIE3    : Endif # FQ 59219
If dim(WGHEADIE)>0     GHEADIE    =WGHEADIE     : Endif
If dim(WGSTODIE)>0     GSTODIE    =WGSTODIE     : Endif
If dim(WGSOC_ACTIVE)>0 GSOC_ACTIVE=WGSOC_ACTIVE : Endif
If dim(WGSOC_UPDFLG)>0 GSOC_UPDFLG=WGSOC_UPDFLG : Endif
#-----
If dim(WGTYPLED)>0
  GTYPLED(1) =WGTYPLED(1)
  GTYPLED(2) =WGTYPLED(2)
  GTYPLED(3) =WGTYPLED(3)
  GTYPLED(4) =WGTYPLED(4)
  GTYPLED(5) =WGTYPLED(5)
