Local    Libelle WINDIC      : [L]WINDIC=1
#-----
Gosub CTRL_CCE_DEB

End
# End issue X3-38251

# Issue X3-51175 - 2017-08-04 by CPO : post a delivery with an analytic section inactive
Subprog CTRL_F_CCE(WSECTION,WAXE,WNOMCPT,WFCY,WDATE,WNOMCCE)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WNOMCPT
Value    Char    WFCY
Value    Date    WDATE
Value    Char    WNOMCCE # Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
#-----
If WNOMCCE = "" : [L]WNOMCCE="[F]CCE"  : Endif
WNOMCPT = "" #--for the 51175 we only need to control CCE (as we do while using GESSxH fonctions). If needed, this will have to be modified and tested on a different feature
Local    Libelle WINDIC      : [L]WINDIC=2 #--for an [F], CCE are dimensioned fields in the table; if not /!\ write another CTRL_F_CCE if needed !
#-----
Gosub CTRL_CCE_DEB

End
# End issue X3-51175

#--------------------------------------------------------------#
# Contrôle des sections analytiques entęte         GA 08/2006  #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WSECTION : Valeur de la section chargée en sortie        #
#   - WDIE     : Code de l'axe courant                         #
#   - WFCY     : Site financier de la société (GFINRSP)        #
#   - WDATE    : Date                                          #
#--------------------------------------------------------------#
Subprog CTRL_TABCCE(WSECTION,WDIE,WFCY,WDATE)
Variable Char    WSECTION
Value    Char    WDIE
Value    Char    WFCY
Value    Date    WDATE
#-----
Local    Char    WNOMCPT(15) : [L]WNOMCPT=""
Local    Char    WNOMCCE(15) : [L]WNOMCCE="[M]CCE"
Local    Integer NOL         : [L]NOL=0
Local    Libelle WINDIC      : [L]WINDIC=2
Local    Integer WAXE
#-----
WAXE = find(WDIE,GDIE(1..GNBDIE))
Gosub CTRL_CCE_DEB
End

#--------------------------------------------------------------#
# Contrôle des sections analytiques entęte                     #
#  ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WSECTION : Valeur de la section chargée en sortie        #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                      #
#   - WFCY     : Site financier de la société (GFINRSP)        #
#   - WDATE    : Date                                          #
#--------------------------------------------------------------#
Subprog CTRL_CCEH(WSECTION,WAXE,WFCY,WDATE)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WFCY
Value    Date    WDATE
#----- Si section entętes et import, accepter les sections non renseignées -----#
If GIMPORT & WSECTION=""  End : Endif
#----- Si section de type enveloppe ou entité, ne pas contrôler si vide -----#
If WSECTION=""
  If GENVDIE(WAXE)=2  End : Endif
Endif
#-----
Local    Char    WNOMCPT(15) : [L]WNOMCPT=""
Local    Char    WNOMCCE(15) : [L]WNOMCCE="[M]CCE"
Local    Integer NOL         : [L]NOL=0
Local    Libelle WINDIC      : [L]WINDIC=2
#-----
Gosub CTRL_CCE_DEB
End

# Issue X3-51175 - 2017-08-04 by CPO : post a delivery with an analytic section inactive
Subprog CTRL_F_CCEH(WSECTION,WAXE,WFCY,WDATE,WNOMCCE)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WFCY
Value    Date    WDATE
Value    Char    WNOMCCE

#----- Si section entętes et import, accepter les sections non renseignées -----#
If GIMPORT & WSECTION=""  End : Endif
#----- Si section de type enveloppe ou entité, ne pas contrôler si vide -----#
If WSECTION=""
  If GENVDIE(WAXE)=2  End : Endif
Endif
#-----
Local    Char    WNOMCPT(15) : [L]WNOMCPT=""
Local    Integer NOL         : [L]NOL=0
Local    Libelle WINDIC      : [L]WINDIC=2

If WNOMCCE = "" : WNOMCCE="[F]CCE" : Endif
#-----
Gosub CTRL_CCE_DEB
End
# End issue X3-51175

#---------------------------------------------------------#
# Début contrôle des sections analytiques entęte ou ligne #
#---------------------------------------------------------#
$CTRL_CCE_DEB
#-----
If GMODU(2)<>2  Return : Endif
#-----
Local Char    ACC(GLONGAC)
Local Char    WSECTION2(GLONCCE)
Local Integer I, J, K, ILED, IDIE, IGAC, OK
Local Libelle WACCFLG
#-----
If WFCY=""  WFCY=GFINRSP : Endif
#-----
If !clalev([F:CCE])  Local File CACCE  [CCE] : Endif
If !clalev([F:CAZ])  Local File CAAUZ  [CAZ] : Endif
#-----
Raz [L]WACCFLG
If WNOMCPT<>""
  If !clalev([F:GAC])  Local File GACCOUNT [GAC] : Endif
  If right$(WNOMCPT,len(WNOMCPT))="("
    [L]WACCFLG=1
  Endif
Endif
#----- Contrôles de base -----#
Gosub CTRL_CCE_BASIC : # Contrôles basiques
If mkstat  Return : Endif
#----- Contrôles par référentiels -----#
For [L]I=1 To GNBCOA
  Call INDLED(GLEDSOC([L]I),GDIE(WAXE),[L]ILED,[L]IDIE) From CPTDIV
  If [L]ILED & [L]IDIE
    If WNOMCPT<>""
      If [L]WACCFLG=1
        [L]ACC=evalue(WNOMCPT+"[L]I-1)")
      Else
        [L]ACC=evalue(WNOMCPT+num$([L]I)+"([L]NOL)")
      Endif
      If [F:GAC]COA<>GLEDCOA([L]ILED) | [F:GAC]ACC<>[L]ACC
        Read [GAC] GAC0=GLEDCOA([L]ILED);[L]ACC : If fstat  Raz [F:GAC] : Endif
      Endif
      If [F:GAC]ACC<>""
        [L]IGAC=find(GDIE(WAXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      Else
        [L]IGAC=1
      Endif
    Else
      [L]IGAC=1
    Endif
    Gosub CTRL_CCE_LED : # Contrôles suivant le référentiel
  Endif
  If mkstat  Break : Endif
Next [L]I
If mkstat  Return : Endif
#-----
Return


#-----------------------------------------------------------#
# Contrôles sur sections analytiques suivant le référentiel #
#-----------------------------------------------------------#
$CTRL_CCE_LED
#----- Contrôle qu'au moins un axe est renseigné -----#
If WNOMCPT<>"" & [F:GAC]ACC<>"" & WSECTION="" & GLEDDIEOBY([L]ILED)=2
  [L]OK=0
  For [L]J=[L]IDIE+1 To GLEDDIENBR([L]ILED)
    If find(evalue("GDIE"+num$([L]J)+"([L]ILED)"),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      [L]OK=1 : Break
    Endif
  Next [L]J
  If ![L]OK : # C'est le dernier axe saisissable..
    [L]OK=0
    For [L]J=1 To [L]IDIE-1
      [L]K=find(evalue("GDIE"+num$([L]J)+"([L]ILED)"),GDIE(1..GNBDIE))
      If [L]WINDIC=1
        [L]WSECTION2=evalue([L]WNOMCCE+num$(K)+"([L]NOL)")
      Else
        [L]WSECTION2=[M]CCE([L]K-1)
      Endif
      If [L]WSECTION2<>""  [L]OK=1 : Break : Endif
    Next [L]J
    If ![L]OK
      GMESSAGE=mess(98,106,1) : # Au moins un axe doit ętre renseigné.
      mkstat=1 : Return
    Endif
  Endif
Endif
If WSECTION="" : Return : Endif
# Issue X3-75274 - 2018-02-20 by MUARN : Plus de blocage car un axe pour appartenir ŕ plusieurs référentiels d'un męme modčle comptable
#----- Section interdite/axe -----#
#If ![L]IGAC
#   GMESSAGE=WSECTION-mess(93,106,1)-GDIE(WAXE)-"("+GLEDSOC([L]I)+")" : # Section interdite/axe
#   mkstat=1 : Return
#Endif
#----- Contrôle interdiction compte/section -----#
If WNOMCPT<>"" & [F:GAC]ACC<>""
  Look [CAZ] CAZ0=2;[F:GAC]AUZ;[F:CCE]AUZ
  If !fstat
    GMESSAGE=WSECTION-mess(27,106,1)-[L]ACC-"("+GCOA([L]I)+")" : # Interdit avec le compte
    mkstat=1 : Return
  Endif
Endif
#-----
Return


#--------------------------------------------#
# Contrôles de base sur sections analytiques #
#--------------------------------------------#
$CTRL_CCE_BASIC
#----- Contrôle que l'axe est obligatoire -----#
If WSECTION="" & GOBLDIE(WAXE)=2
   # Issue X3-57427 - 2017-10-11 by MUARN : ajout dim
   # Issue X3-38655 - 2017-06-29 by MUARN : faire en import sauf SMR
   # Issue 59774 - 2017-10-24 by MAE/TS : en import, les controles ne sont pas effectués sur tous les documents stocks
   # męme comportement qu'en interactif, pas de controle sur les axes analytiques, męme si axe obligatoire sur la société
   # Issue X3-76039 - 2018-03-20 by MUARN : en simulation d'import ( GIMPORT est positionné mais pas d'ouverture [M:AOE1])
   # il faut afficher l'erreur, comme la génération des factures achats en inter-société
   #If  !GIMPORT | ( GIMPORT & dim([M:AOE1]OBJ)>0 & [M:AOE1]OBJ <> "SMR" )
   If  !GIMPORT | ( GIMPORT & dim([M:AOE1]OBJ)>0 & (!find ([M:AOE1]OBJ,"SMR","SMO","SCS"))) | ( GIMPORT & dim([M:AOE1]OBJ)<0 )
       GMESSAGE=mess(46,106,1)-GDIE(WAXE) : # Section obligatoire/axe
       mkstat=1 : Return
   Else
       If dim(GCCE_STJ) > 0 & GCCE_STJ = 1
          GMESSAGE=mess(46,106,1)-GDIE(WAXE) : # Section obligatoire/axe
          mkstat=1 : Return
       Endif
   Endif
Endif
If WSECTION=""  Return : Endif
#----- Section inexistante -----#
If [F:CCE]DIE<>GDIE(WAXE) | [F:CCE]CCE<>WSECTION
  Read [CCE] CCE0=GDIE(WAXE);WSECTION
  If fstat
    GMESSAGE=WSECTION-mess(35,106,1) : # Section inexistante
    mkstat=1 : Return
  Endif
Endif
# Issue X3-51175 - 2017-08-04 by CPO : post a delivery with an analytic section inactive
If [F:CCE]ENAFLG<>2
  GMESSAGE=WSECTION-mess(2,126,1) : # Fiche inactive
  mkstat=1 : Return
Endif
# End issue X3-51175
#----- Section compatible avec le site/société -----#
Call VERIF([F:CCE]FCY,WFCY,WSECTION) From CFYSUB
If mkstat  Return : Endif
# Dde 69524
#----- Section non imputable
If [F:CCE]IPT<>2
 GMESSAGE = WSECTION-mess(24,106,1) : # Section non imputable
 mkstat = 1 : Return
Endif
# Dde 69524
#----- Code d'accčs, droit d'exécution -----#
Call CONTEXE([F:CCE]ACS) From CPTSUB
If mkstat  GMESSAGE=WSECTION-GMESSAGE : Return : Endif
#----- Contrôle validité date -----#
Call CTLVLYDAT(WDATE,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
If mkstat  GMESSAGE=WSECTION-GMESSAGE : Return : Endif
#----- Contrôle code interdiction section/section -----#
If !clalev([F:CCE2])  Local File CACCE  [CCE2] : Endif
For [L]I=1 To GNBDIE
  If [L]I<>WAXE
    If [L]WINDIC=1
      [L]WSECTION2=evalue([L]WNOMCCE+num$([L]I)+"([L]NOL)")
    Else
      # Issue X3-51175 - 2017-08-04 by CPO : post a delivery with an analytic section inactive
      #--for this fix, the WNOMCCE comes from [F]CCE...
      #[L]WSECTION2=[M]CCE([L]I-1)
      [L]WSECTION2=evalue([L]WNOMCCE+"([L]I-1)")
      # End issue X3-51175
    Endif
    If [L]WSECTION2<>""
      If [F:CCE2]DIE<>GDIE([L]I) | [F:CCE2]CCE<>WSECTION2
        Read [CCE2] CCE0=GDIE([L]I);WSECTION2
        If fstat  Raz [F:CCE2] : Endif
      Endif
      Look [CAZ] CAZ0=1;[F:CCE]AUZ;[F:CCE2]AUZ
      If !fstat
        GMESSAGE=WSECTION-mess(26,106,1)-[F:CCE2]CCE : # Interdit avec la section
        mkstat=1 : Break
      Endif
    Endif
  Endif
Next [L]I
#-----
Return


#----------------------------------------------------------------#
# Avant saisie des comptes d'une ligne de document               #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WCOMPTE  : Valeur du compte avant saisie (VALEUR)          #
#   - WPLAN    : Numéro du plan de compte (1 ŕ 10)               #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#                                                                #
# En sortie mkstat=2 si il est inutile de saisir le compte       #
#----------------------------------------------------------------#
Subprog AVSAI_ACC(WCOMPTE,WPLAN,WNOMCPT)
Value    Char    WCOMPTE
Value    Integer WPLAN
Value    Char    WNOMCPT
#-----
If WCOMPTE="" | WPLAN<2  End : Endif
#-----
Local Integer I, J
Local Char    WACC(GLONGAC)
Local Libelle WACCFLG
#-----
If right$(WNOMCPT,len(WNOMCPT))="("
  [L]WACCFLG=1
Else
  [L]WACCFLG=0
Endif
#-----
For I=1 To WPLAN-1
  If [L]WACCFLG=1
    WACC=evalue(WNOMCPT+"I-1)")
  Else
    WACC=evalue(WNOMCPT+num$(I)+"(nolign-1)")
  Endif
  If WACC<>""
    If [F:GAC]COA<>GCOA(I) | [F:GAC]ACC<>WACC
      Read [GAC] GAC0=GCOA(I);WACC : If fstat  Raz [F:GAC] : Endif
    Endif
    J=find(GCOA(WPLAN),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
    If J & [F:GAC]DEFACC(J-1)<>""
      If [F:GAC]DEFACC(J-1)=[F:GAC]SCRACC(J-1)  mkstat=2 : Endif
      Break
    Endif
    #----- Pas de saisie si plan de compte identique (demande 55712) -----#
    If GCOA(WPLAN)=GCOA(I)  mkstat=2 : Break : Endif
    #-----
  Endif
Next I
#-----
End


#----------------------------------------------------------------#
# Aprčs modification des comptes d'une ligne de document         #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WCOMPTE  : Valeur du compte avant saisie (VALEUR)          #
#   - WPLAN    : Numéro du plan de compte (1 ŕ 10)               #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#                                                                #
# En sortie initialisation des autres comptes si nécessaire      #
#----------------------------------------------------------------#
Subprog APMOD_ACC(WCOMPTE,WPLAN,WNOMCPT)
Value    Char    WCOMPTE
Value    Integer WPLAN
Value    Char    WNOMCPT
#-----
If WCOMPTE="" | WPLAN>GNBCOA-1  End : Endif
#-----
Local Integer I, J, K
Local Char    WACC(GLONGAC)
Local Libelle WACCFLG
#-----
If right$(WNOMCPT,len(WNOMCPT))="("
  [L]WACCFLG=1
Else
  [L]WACCFLG=0
Endif
#-----
For I=WPLAN To GNBCOA
  If I=WPLAN
    WACC=WCOMPTE
  Elsif [L]WACCFLG=1
    WACC=evalue(WNOMCPT+"I-1)")
  Else
    WACC=evalue(WNOMCPT+num$(I)+"(nolign-1)")
  Endif
  If WACC<>""
    If I>WPLAN & GCOA(I)=GCOA(WPLAN)
      If [L]WACCFLG=1
        Assign WNOMCPT+"I-1)" With WCOMPTE
      Else
        Assign WNOMCPT+num$(I)+"(nolign-1)" With WCOMPTE
      Endif
    Else
      If [F:GAC]COA<>GCOA(I) | [F:GAC]ACC<>WACC
        Read [GAC] GAC0=GCOA(I);WACC : If fstat  Raz [F:GAC] : Endif
      Endif
      For K=I+1 To GNBCOA
        J=find(GCOA(K),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
        If J & [F:GAC]DEFACC(J-1)<>""
          If [L]WACCFLG=1
            # Issue 77054 - 2011-10-18 by VPO : mettre la valeur par défaut que si le compte est vide
            If evalue(WNOMCPT+"K)")=""
              Assign WNOMCPT+"K)" With [F:GAC]DEFACC(J-1)
            Endif
          Else
            # Issue 77054 - 2011-10-18 by VPO : mettre la valeur par défaut que si le compte est vide
            # Issue 84072 - 2012-09-07 by MUARN : il faut toujours réinitialisé les comptes suivants aprčs modification
            # Issue 106746 - 2015-04-02 by SR : Réactivation correction 77054
            # Issue 119221 - 2016-11-08 by MUARN : crible strict, forcer l'alimentation
            If evalue(WNOMCPT+num$(K)+"(nolign-1)")=""
              Assign WNOMCPT+num$(K)+"(nolign-1)" With [F:GAC]DEFACC(J-1)
            Elsif [F:GAC]SCRACC(J-1) = [F:GAC]DEFACC(J-1)
              Assign WNOMCPT+num$(K)+"(nolign-1)" With [F:GAC]DEFACC(J-1)
            Endif
          Endif
        Endif
      Next K
    Endif
  Endif
Next I
#-----
End


#----------------------------------------------------------------#
# Contrôle des comptes d'une ligne de document                   #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WCOMPTE  : Valeur du compte ŕ contrôler                    #
#   - WPLAN    : Numéro du plan de compte (1 ŕ 10)               #
#   - WFCY     : Site financier de la société (GFINRSP)          #
#   - WDATE    : Date                                            #
#   - WDEVISE  : Devise                                          #
#   - WNOMCPT  : Préfixe du nom des comptes                      #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC")    #
#                "" = Pas de contrôle sur les x plans de compte  #
#                Nota : Si le nom des comptes se termine par "(" #
#                c'est que les comptes sont indicés LINACC(0-9)  #
#                dans un tableau ŕ part qui est commun ŕ toutes  #
#                les lignes contenant les sections comme les     #
#                contrats d'achat par exemple                    #
#----------------------------------------------------------------#
Subprog CTRL_ACC(WCOMPTE,WPLAN,WFCY,WDATE,WDEVISE,WNOMCPT)
Variable Char    WCOMPTE
Value    Integer WPLAN
Value    Char    WFCY
Value    Date    WDATE
Value    Char    WDEVISE
Value    Char    WNOMCPT
#-----
If WCOMPTE<>""
  If [F:GAC]COA<>GCOA(WPLAN) | [F:GAC]ACC<>WCOMPTE
    Read [GAC] GAC0=GCOA(WPLAN);WCOMPTE : If fstat Raz [F:GAC] : Endif
  Endif
  #----- Compte inexistant -----#
  If [F:GAC]ACC=""
    GMESSAGE=WCOMPTE-mess(38,106,1) : mkstat=1
    Goto ERR_ACC
  Endif
  #----- Contrôle imputation comptes sur les x plans de comptes -----#
  If WPLAN>1 & WNOMCPT<>""
    #-----
    Local Char    TPLAN  (GLONCOA)(1..WPLAN)
    Local Char    TCOMPTE(GLONGAC)(1..WPLAN)
    Local Integer I
    Local Integer WSTA
    Local Char    WMSG(250)
    Local Libelle WACCFLG
    #-----
    If right$(WNOMCPT,len(WNOMCPT))="("
      [L]WACCFLG=1
    Else
      [L]WACCFLG=0
    Endif
    #-----
    For [L]I=1 To WPLAN-1
      [L]TPLAN(I)=GCOA(I)
      If [L]WACCFLG=1
        #VPO 07/01/11 70477 ajout (I) manquant
        [L]TCOMPTE(I)=evalue(WNOMCPT+"[L]I-1)")
      Else
        [L]TCOMPTE(I)=evalue(WNOMCPT+num$([L]I)+"(nolign-1)")
      Endif
    Next [L]I
    [L]TPLAN  (WPLAN)=GCOA(WPLAN)
    [L]TCOMPTE(WPLAN)=WCOMPTE
    Call CNTIPTACC(WPLAN,[L]TPLAN,[L]TCOMPTE,[L]WMSG,[L]WSTA) From CPTCNT
    If [L]WSTA
      GMESSAGE=[L]WMSG : mkstat=1
      Goto ERR_ACC
    Endif
  Endif
  #----- Classe de compte interdite avec le type de pičce -----#
  If !clalev([F:COA])  Local File GCOA    [COA] : Endif
  If !clalev([F:CLS])  Local File GACCCLS [CLS] : Endif
  If [F:COA]COA<>[F:GAC]COA
    Read [COA] COA0=[F:GAC]COA
  Endif
  Read [CLS] CLS0=[F:COA]LEGCLS;[F:GAC]CLSCOD
  If [F:CLS]TYP=2
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    GMESSAGE=WCOMPTE-mess(57,106,1)-"("+mess(GTYPLED_X3TC(WPLAN),2644,1)+")" : mkstat=1
    Goto ERR_ACC
  Endif
  #----- Compte non compatible avec le site -----#
  Call VERIF([F:GAC]FCY,WFCY,WCOMPTE) From CFYSUB
  If mkstat  Goto ERR_ACC : Endif
  #----- Contrôle devise du compte -----#
  If WDEVISE<>"" & [F:GAC]CUR<>"" & [F:GAC]CUR<>WDEVISE & WDEVISE<>GDEVLED(WPLAN)
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    GMESSAGE=WCOMPTE-mess(13,106,1)-[F:GAC]CUR-"("+mess(GTYPLED_X3TC(WPLAN),2644,1)+")" : mkstat=1
    Goto ERR_ACC
  Endif
  #----- Contrôle validité date -----#
  Call CTLVLYDAT(WDATE,[F:GAC]VLYSTR,[F:GAC]VLYEND) From CPTSUB
  If mkstat
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    GMESSAGE=WCOMPTE-GMESSAGE-"("+mess(GTYPLED_X3TC(WPLAN),2644,1)+")"
    Goto ERR_ACC
  Endif
  #----- Contrôle accčs et droit d'exécution -----#
  Call CONTEXE([F:GAC]ACS) From CPTSUB
  If mkstat
    #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
    GMESSAGE=WCOMPTE-GMESSAGE-"("+mess(GTYPLED_X3TC(WPLAN),2644,1)+")"
    Goto ERR_ACC
  Endif
  #====== VINCI : Test si fournisseur et compte cochés DAS2 =====#
  #VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED

  Local Integer LDAS : # X3-104535
  LDAS = func AFNC.ACTIV("DAS")
  If LDAS = G_OUI

    If func AFNC.PARAM("CONTROLDAS",GSOCIETE)="2" & GTYPLED_X3TC(WPLAN)=GTYPGEN & [F:GAC]DAS=2
      #----- Lecture du fournisseur -----#
      Local Char WBPSNUM(GLONBPS)
      If instr(1,WNOMCPT,"PIH")
        WBPSNUM=[M:PIH0]BPR
      Elsif instr(1,WNOMCPT,"PNH")
        WBPSNUM=[M:PNHC]BPSINV
      Elsif instr(1,WNOMCPT,"POC")
        WBPSNUM=[M:POC1]BPSINV
      Elsif instr(1,WNOMCPT,"POH")
        WBPSNUM=[M:POH1]BPSINV
      Elsif instr(1,WNOMCPT,"POI")
        If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(nolign-1)
          Read [BPS] BPS0=[M:POI1]BPSNUM(nolign-1) : If fstat  Raz [F:BPS] : Endif
        Endif
        If [F:BPS]BPSINV=""
          WBPSNUM=[M:POI1]BPSNUM(nolign-1)
        Else
          WBPSNUM=[F:BPS]BPSINV
        Endif
      Elsif instr(1,WNOMCPT,"PSH")
        If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
          Read [BPS] BPS0=[M:PSH1]BPSNUM(nolign-1) : If fstat  Raz [F:BPS] : Endif
        Endif
        If [F:BPS]BPSINV=""
          WBPSNUM=[M:PSH1]BPSNUM(nolign-1)
        Else
          WBPSNUM=[F:BPS]BPSINV
        Endif
      Elsif instr(1,WNOMCPT,"PTH")
        WBPSNUM=[M:PTHC]BPSINV
      Endif
      If [F:BPS]BPSNUM<>WBPSNUM
        Read [BPS] BPS0=WBPSNUM : If fstat  Raz [F:BPS] : Endif
      Endif
      #----- Attention : compte DAS2 sur fournisseur non DAS2 -----#
      If [F:BPS]DADFLG=1
        Local Integer WOK
        WOK=2 : Call AVERTIR([F:GAC]ACC-"-"-mess(74,122,1)-"("+WBPSNUM+")",WOK) From GESECRAN
        If WOK<>2  mkstat=1 : Goto ERR_ACC : Endif
      Endif
    Endif

  Endif : # X3-104535
  #=====
Endif
End
# Bug 71102 : Il faut laisser le contrôle bloquant dans tous les cas
#----- Erreur non bloquante si saisie en mode fiche uniquement -----#
$ERR_ACC
#If mkstat & GSCRDIE=2
#  Raz mkstat : GERR=2
#Endif
#-----
End


#-----------------------------------------------------#
# Contrôle du code répartition analytique             #
# --------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :             #
#   - WDSP   : Code répartition ŕ contrôler           #
#   - WFCY   : Site financier de la société (GFINRSP) #
#              ou site comptable ([M:PIH0]FCY)        #
#   - WDATE  : Date                                   #
#-----------------------------------------------------#
Subprog CTRL_DSP(WDSP,WFCY,WDATE)
Variable Char    WDSP
Value    Char    WFCY
Value    Date    WDATE
#-----
If WDSP=""  End : Endif
If !clalev([F:DSP])  Local File CADSP [DSP] : Endif
Call CONTDSP(WDSP,WFCY,WDATE) From SUBBIC3
If mkstat   End : Endif
End


#----------------------------------------------------------------#
# Initialisation tableau axes analytiques des tables de base     #
#              Appelé par l'action RAZCRE                        #
# -------------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                        #
#   - WCODE    : Numéro de la table ŕ gérer (menu local 2230)    #
#   - WSOCIETE : Société ("" = pas de déclinaison par société)   #
#   - WABRMSK  : Abréviation du masque écran                     #
#   - WBASTAB  : Nom de la variable de bas de tableau            #
#---------------------------------------------------------------#
Subprog INIT_DIE(WCODE,WSOCIETE,WABRMSK,WBASTAB)
Value    Integer WCODE
Value    Char    WSOCIETE
Value    Char    WABRMSK
Value    Char    WBASTAB
#-----
Gosub TR_INIT_DIE
#-----
End


#----------------------------------------------------------------#
# Chargement tableau axes analytiques des tables de base         #
#               Appelé par l'action LIENS                        #
# ---------------------------------------------------------------#
# Paramčtres ŕ passer au sous-programme :                        #
#   - WCODE    : Numéro de la table ŕ gérer (menu local 2230)    #
#                Pour les catégories article, client, fournisseur#
#                faire +100 sur article, client, fournisseur     #
#   - WSOCIETE : Société ("" = pas de déclinaison par société)   #
#   - WABRMSK  : Abréviation du masque écran                     #
#   - WBASTAB  : Nom de la variable de bas de tableau            #
#----------------------------------------------------------------#
Subprog CHARG_DIE(WCODE,WSOCIETE,WABRMSK,WBASTAB)
Value    Integer WCODE
Value    Char    WSOCIETE
Value    Char    WABRMSK
Value    Char    WBASTAB
#-----
Local    Integer J
#----- Initialisation des codes axe analytique -----#
Gosub TR_INIT_DIE
#----- Chargement des sections analytiques -----#
For [L]I=0 To [F:CDI]NBRDIE-1
  Case WCODE
    When  1 : # Article
      For [L]J=0 To dim([F:ITM]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:ITM]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:ITM]CCE([L]J)
          Break
        Endif
      Next [L]J
    When  2 : # Client
      For [L]J=0 To dim([F:BPC]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:BPC]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:BPC]CCE([L]J)
          Break
        Endif
      Next [L]J
    When  3 : # Fournisseur
      For [L]J=0 To dim([F:BPS]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:BPS]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:BPS]CCE([L]J)
          Break
        Endif
      Next [L]J
    When  4 : # Commercial
      For [L]J=0 To dim([F:REP]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:REP]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:REP]CCE([L]J)
          Break
        Endif
      Next [L]J
    When  6 : # Frais généraux
      For [L]J=0 To dim([F:ONA]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:ONA]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:ONA]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 10 : # Pied de facture vente
      For [L]J=0 To dim([F:SFI]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:SFI]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:SFI]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 11 : # Escompte/Agio
      For [L]J=0 To dim([F:TDA]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:TDA]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:TDA]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 14 : # Pied de facture achat
      For [L]J=0 To dim([F:PFI]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:PFI]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:PFI]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 15 : # Tiers divers
    When 16 : # Sections de valorisation
      For [L]J=0 To dim([F:MWC]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:MWC]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:MWC]CCE([L]J)
          Break
        Endif
      Next [L]J
    When  17 : # Issue 84130 - 2013-01-28 by SR : Landed cost
      For [L]J=0 To dim([F:FCS]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:FCS]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:FCS]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 101 : # Catégorie Article
      #For [L]J=0 To dim([F:ITM]DIE)-1 MAE, bg 67252, pb ds l'abréviation
      For [L]J=0 To dim([F:ITG]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:ITG]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:ITG]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 102 : # Catégorie Client
      #For [L]J=0 To dim([F:BPC]DIE)-1 MAE, bg 67252, pb ds l'abréviation
      For [L]J=0 To dim([F:BCG]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:BCG]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:BCG]CCE([L]J)
          Break
        Endif
      Next [L]J
    When 103 : # Catégorie Fournisseur
      #For [L]J=0 To dim([F:BPS]DIE)-1 MAE, bg 67252, pb ds l'abréviation
      For [L]J=0 To dim([F:BSG]DIE)-1
        If evalue([L]ECRAN+"DIE([L]I)")=[F:BSG]DIE([L]J)
          Assign [L]ECRAN+"CCE([L]I)" With [F:BSG]CCE([L]J)
          Break
        Endif
      Next [L]J
  Endcase
Next [L]I
#-----
End


#---------------------------------------------------------#
# Traitement de l'initialisation des codes axe analytique #
#---------------------------------------------------------#
$TR_INIT_DIE
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Char    BATAB(GLONABR+4+GLONAVA)  #BATAB(20) Gbn-108341
Local    Integer I, WWCODE
#-----
If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
#-----
WWCODE = WCODE
If WWCODE>100 WWCODE-=100 Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#-----
Read [CDI] CDI0=WWCODE
If fstat  Raz [F:CDI] : Endif
#-----
For [L]I=0 To evalue("dim("+[L]ECRAN+"DIE)")-1
  Assign [L]ECRAN+"DIE([L]I)" With ""
  Assign [L]ECRAN+"CCE([L]I)" With ""
Next [L]I
#-----
Assign [L]BATAB With [F:CDI]NBRDIE
For [L]I=0 To [F:CDI]NBRDIE-1
  Assign [L]ECRAN+"DIE([L]I)" With [F:CDI]DIE([L]I)
Next [L]I
Return

#-----------------------------------------------#
# Recherche indice compte général ou analytique #
# --------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :       #
#   - WTYPACC  : Type du compte ŕ rechercher    #
#                1 = Compte général             #
#                2 = Compte analytique          #
#   - WINDACC  : Indice du compte recherché     #
#-----------------------------------------------#
Subprog RECH_INDACC(WTYPACC,WINDACC)
Value    Integer WTYPACC
Variable Integer WINDACC
#-----
Local    Integer I
Raz WINDACC
If WTYPACC=0 | WTYPACC>2  End : Endif
#----- Recherche indice compte sur le référentiel principal -----#
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
Case WTYPACC
  When 1 : WINDACC=find(GTYPGEN,GTYPLED_X3TC(1..GNBTYPLED))
  When 2 : WINDACC=find(GTYPANA,GTYPLED_X3TC(1..GNBTYPLED))
Endcase
#----- Recherche indice compte sur les autres types de référentiel -----#
If WINDACC=0 & GMODU(2)=2
  If !clalev([F:LED])  Local File GLED  [LED] : Endif
  For I=1 To GNBTYPLED
    Case WTYPACC
      When 1
        If GTYPLED_X3TC(I)<>GTYPGEN
          If [F:LED]LED<>GLEDSOC(I)
            Read [LED] LED0=GLEDSOC(I) : If fstat  Raz [F:LED] : Endif
          Endif
          If [F:LED]GEN=2  WINDACC=I : Break : Endif
        Endif
      When 2
        If GTYPLED_X3TC(I)<>GTYPANA
          If [F:LED]LED<>GLEDSOC(I)
            Read [LED] LED0=GLEDSOC(I) : If fstat  Raz [F:LED] : Endif
          Endif
          If [F:LED]ANA=2  WINDACC=I : Break : Endif
        Endif
    Endcase
  Next I
Endif
#-----
End


#-------------------------------------------------------------#
# Recherche compte général ou analytique sur ligne document   #
# ----------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                     #
#   - WTYPACC  : Type du compte ŕ rechercher                  #
#                1 = Compte général                           #
#                2 = Compte analytique                        #
#   - WNOMCPT  : Préfixe du nom des comptes                   #
#                (exemples "[M:PIH4]ACC" ou "[M:PIH3]LINACC") #
#   - WNOL     : Indice de la ligne en cours                  #
#   - WACC     : Compte recherché                             #
#-------------------------------------------------------------#
Subprog RECH_ACC(WTYPACC,WNOMCPT,WNOL,WACC)
Value    Integer  WTYPACC
Value    Char     WNOMCPT
Value    Shortint WNOL
Variable Char     WACC
#-----
Local    Char    WCOA(GLONCOA)
Local    Integer WINDACC
Local    Integer I
#-----
Raz WACC, WCOA, WINDACC
If WTYPACC=0 | WTYPACC>2  | WNOMCPT=""  End : Endif
#----- Recherche compte sur le référentiel principal -----#
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
Case WTYPACC
  When 1 : WINDACC=find(GTYPGEN,GTYPLED_X3TC(1..GNBTYPLED))
  When 2 : WINDACC=find(GTYPANA,GTYPLED_X3TC(1..GNBTYPLED))
Endcase
If WINDACC
  WACC=evalue(WNOMCPT+num$(WINDACC)+"(WNOL)")
  WCOA=GCOA(WINDACC)
Endif
#----- Recherche compte sur les autres types de référentiel -----#
If WACC="" & GMODU(2)=2
  If !clalev([F:LED])  Local File GLED  [LED] : Endif
  For I=1 To GNBTYPLED
    Case WTYPACC
      When 1
        If GTYPLED_X3TC(I)<>GTYPGEN
          If [F:LED]LED<>GLEDSOC(I)
            Read [LED] LED0=GLEDSOC(I) : If fstat  Raz [F:LED] : Endif
          Endif
          If [F:LED]GEN=2  WINDACC=I : Break : Endif
        Endif
      When 2
        If GTYPLED_X3TC(I)<>GTYPANA
          If [F:LED]LED<>GLEDSOC(I)
            Read [LED] LED0=GLEDSOC(I) : If fstat  Raz [F:LED] : Endif
          Endif
          If [F:LED]ANA=2  WINDACC=I : Break : Endif
        Endif
    Endcase
  Next I
  If WINDACC
    WACC=evalue(WNOMCPT+num$(WINDACC)+"(WNOL)")
    WCOA=GCOA(WINDACC)
  Endif
Endif
#----- Lecture du compte si nécessaire -----#
If clalev([F:GAC])
  If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WACC
    Read [GAC] GAC0=WCOA;WACC : If fstat  Raz [F:GAC] : Endif
  Endif
Endif
#-----
End


#--------------------------------------------#
# Recherche pour une société :               #
#    - du plan de compte budgétaire          #
#    - de l'axe enveloppe                    #
#    - de l'axe entité                       #
# ------------------------------------------ #
# En entrée                                  #
#   - WSOC    : Société                      #
#                                            #
# En sortie                                  #
#   - WBUDCOA : Code plan compte budgértaire #
#   - WENVDIE : Code axe enveloppe           #
#   - WENTDIE : Code axe entité              #
#--------------------------------------------#
Subprog RECH_BUDOPE(WSOC,WBUDCOA,WENVDIE,WENTDIE)
Value    Char     WSOC
Variable Char     WBUDCOA
Variable Char     WENVDIE
Variable Char     WENTDIE
#-----
Local    Integer I, J
#-----
If !clalev([F:CPY])  Local File COMPANY [CPY] : Endif
If !clalev([F:GCM])  Local File GACM    [GCM] : Endif
If !clalev([F:LED])  Local File GLED    [LED] : Endif
If !clalev([F:DIE])  Local File GDIE    [DIE] : Endif
#-----
Raz WBUDCOA, WENVDIE, WENTDIE
If [F:CPY]CPY<>WSOC
  Read [CPY] CPY0=WSOC : If fstat Raz [F:CPY] : End : Endif
Endif
 If [F:GCM]GCM<>[F:CPY]ACM
  Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:GCM] : End : Endif
Endif
#-----
For I=0 To dim ([F:GCM]LED)-1
  If [F:GCM]LED(I)<>""
    Read [LED] LED0=[F:GCM]LED(I) : If fstat  Raz [F:LED] : Endif
    If [F:LED]GDD=2 & WBUDCOA=""
      WBUDCOA=[F:LED]COA
    Endif
    If WENVDIE="" | WENTDIE=""
      For J=0 To dim([F:LED]DIE)-1
        Read [DIE] DIE0=[F:LED]DIE(J) : If fstat  Raz [F:DIE] : Endif
        If [F:DIE]ENV=2 & WENVDIE=""
          WENVDIE=[F:DIE]DIE
        Endif
        If [F:DIE]ENT=2 & WENTDIE=""
          WENTDIE=[F:DIE]DIE
        Endif
        If WENVDIE<>"" & WENTDIE<>""  Break : Endif
      Next J
    Endif
  Endif
  If WBUDCOA<>"" & WENVDIE<>"" & WENTDIE<>""  Break : Endif
Next I
#-----
End


#--------------------------------------------------------------#
# Chargement cours devise entęte facture achats/ventes         #
#      Appelé par l'action LIENS                               #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation masque écran contenant les cours  #
#   - WABRFIC  : Abréviation table entęte facture              #
#--------------------------------------------------------------#
Subprog CHARG_RATCUR(WABRMSK,WABRFIC)
Value    Char    WABRMSK
Value    Char    WABRFIC
#-----
Local    Char    ECRAN(GLONABR+4)          #ECRAN(10) Gbn-108341
Local    Integer I, J
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
# Issue 104096 - 2014-11-25 by SR : ne fonctionne pas si il existe des référentiels automatiques
#----- Le transclasse semble suffisant mais le paramétrage a pu changer -----#
#For I=1 To GNBTYPLED
#  Assign [L]ECRAN+"LED(I-1)" With GLEDSOC(I)
#  J=evalue("find([F:"+WABRFIC+"]LED(I-1),GLEDSOC(1..GNBTYPLED))")
#  If J
#    Assign [L]ECRAN+"CURLED(J-1)" With evalue("[F:"+WABRFIC+"]CURLED(I-1)")
#    Assign [L]ECRAN+"RATMLT(J-1)" With evalue("[F:"+WABRFIC+"]RATMLT(I-1)")
#    Assign [L]ECRAN+"RATDIV(J-1)" With evalue("[F:"+WABRFIC+"]RATDIV(I-1)")
#  Endif
#Next I
# End issue 104096
#-----
#Assign [L]ECRAN+"RAT1"   With evalue ([L]ECRAN+"RATDIV(GTYPGEN-1)")
#Assign [L]ECRAN+"LABEL"  With evalue ([L]ECRAN+"CUR")-"="
#Assign [L]ECRAN+"RAT2"   With evalue ([L]ECRAN+"RATMLT(GTYPGEN-1)")
#Assign [L]ECRAN+"CURDIV" With evalue ([L]ECRAN+"CUR")
#Assign [L]ECRAN+"CURMLT" With evalue ([L]ECRAN+"CURLED(GTYPGEN-1)")
#-----
If !GIMPORT
  Local    Char    WCUR(GLONCUR)
  Local    Libelle WCURTYP
  Local    Date    WDAT
  #-----
  [L]WCUR   =evalue([L]ECRAN+"CUR")
  [L]WCURTYP=evalue([L]ECRAN+"CURTYP")
  If WABRMSK="SIH2"
    [L]WDAT =[M:SIH0]INVDAT
  Else
    [L]WDAT =evalue([L]ECRAN+"RATDAT")
  Endif
  #-----
  Call CHARGE_COURS(WABRMSK,GSOCIETE,[L]WCUR,[L]WDAT,[L]WCURTYP) From SUBBICS
Endif
#----- Le CHARGE_COURS écrase les valeurs RAT1 et RAT2 ???? -----# MBT 15/07/2010
Assign [L]ECRAN+"RAT1"   With evalue ([L]ECRAN+"RATDIV(GTYPGEN-1)")
Assign [L]ECRAN+"LABEL"  With evalue ([L]ECRAN+"CUR")-"="
Assign [L]ECRAN+"RAT2"   With evalue ([L]ECRAN+"RATMLT(GTYPGEN-1)")
Assign [L]ECRAN+"CURDIV" With evalue ([L]ECRAN+"CUR")
Assign [L]ECRAN+"CURMLT" With evalue ([L]ECRAN+"CURLED(GTYPGEN-1)")
#-----
End


#--------------------------------------------------------------#
# Avant saisie des sections analytiques en mode tableau        #
# Remplace les formats évalués qui ne fonctionnement pas       #
# si saisie de ACC ou CCE en mode tableau   -  GA 08/2006      #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WSECTION : Valeur de la section ŕ contrôler              #
#   - WAXE     : Numéro de l'axe (1 ŕ 20)                      #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
# NB: La transaction courante doit déjŕ avoir été lue          #
#--------------------------------------------------------------#
Subprog SAIS_TABCCE(WSECTION,WDIE,WABRFIC,WIND)
Variable Char    WSECTION
Value    Char    WDIE
Value    Char    WABRFIC
Value    Integer WIND

Local    Integer WCCECOD

  Call CHARG_CCECOD(WCCECOD,WDIE,WABRFIC,WIND)
 #---- Axe Non saisissable
  If WCCECOD =2 : mkstat=2 : Endif
#-----
End

#--------------------------------------------------------------#
# Recherche mode saisie des sections analytiques DIETRS        #
# ------------------------------------------------------------ #
# Paramčtres du sous-programme :                               #
#   - WCCECOD  : Mode de saisie associé ŕ cet axe DIETRS       #
#   - WDIE     : Code de l'axe                                 #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
# La transaction courante doit déjŕ avoir été lue (par GETCPY) #
#--------------------------------------------------------------#
Subprog CHARG_CCECOD(WCCECOD,WDIE,WABRFIC,WIND)
Variable Integer WCCECOD
Value    Char    WDIE
Value    Char    WABRFIC
Value    Integer WIND

Local    Integer J

  J=find(WDIE,GDIE(1..GNBDIE))
  If J=0 : End : Endif

  If !clalev([F:DTR])  Local File DIETRS [DTR] : Endif
  Raz [F:DTR]

 #---- Mode de saisie de cet axe analytique pour cette transaction  -----#
 #---- lecture DIETRS (saisie/affiché/invisible)                    -----#
  Case WABRFIC
    When "PTR"
      If [F:PTR]PTRNUM<>""
         Read [DTR] DTR1=WABRFIC;[F:PTR]PTRTYP;[F:PTR]PTRNUM;WIND;GDIE(J) : If fstat  Raz [F:DTR] : Endif
      Endif
    When "SLT" : # pas de tableau de sections CCE(20)
    When "CTR" : # pas de tableau de sections CCE(20)
    When "SRT" : # pas de tableau de sections CCE(20)
    When "MTS" : # pas de tableau de sections CCE(20)
    When "BTS" : # pas de tableau de sections CCE(20)
  Endcase
  Case WIND
    When 1 :
    #---- Mode de saisie (Entęte)
     WCCECOD=[F:DTR]CCECOD
    When 2 :
    #---- Mode de saisie (Détail 1)
     WCCECOD=[F:DTR]CCECOD
    When 3 :
    #---- Mode de saisie (Détail 2)
     WCCECOD=[F:DTR]CCECOD
  Endcase
#-----
End


#--------------------------------------------------------------#
# Initialisation des sections analytiques en tableau CCE(20)   #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WNOMDIE  : Nom du tableau contenant les axes             #
#   - WNOMCCE  : Nom du tableau contenant les sections         #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WSECDEF  : Code paramétrage sections par défaut          #
#                (exemple "POH")                               #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
Subprog INIT_TABCCE(WABRMSK,WNOMDIE,WNOMCCE,WBASTAB,WSECDEF,WABRFIC,WIND)
Value    Char    WABRMSK
Value    Char    WNOMDIE
Value    Char    WNOMCCE
Value    Char    WBASTAB
Value    Char    WSECDEF
Value    Char    WABRFIC
Value    Integer WIND
#-----
Local    Char    SECTION(GLONCCE)
Local    Char    MSK_COURANT
Local    Char    WFMTDIE
Local    Integer WCCECOD

Local    Integer I, J, WNBDIE
Local    Char    WMSK (GLONAMK)

#----- Chargement abréviation du masque courant -----#
If instr(1,dbgstr(1),",")
  [L]MSK_COURANT=vireblc(left$(dbgstr(1),instr(1,dbgstr(1),",")-1),4)
Else
  [L]MSK_COURANT=vireblc(dbgstr(1),4)
Endif
#-----
If WABRMSK=""
   WMSK="[M]"
Else
   WMSK="[M:"+WABRMSK+"]" : Default Mask "["+WABRMSK+"]"
Endif
If WBASTAB=""
   WBASTAB="NBAXE"
Endif
If WNOMDIE=""
   WNOMDIE="DIE"
Endif
If WNOMCCE=""
   WNOMCCE="CCE"
Endif
#-----
[L]J=0
For [L]I=1 To GNBDIE
  Call CHARG_CCECOD(WCCECOD,GDIE([L]I),WABRFIC,WIND)
 #---- Axe Invisible => non chargé dans le tableau
 # GA 01/2009 If WCCECOD<>3 ne pas afficher les axes non paramétrés WCCECOD=0
  If find(WCCECOD,1,2)
    Assign WMSK+WNOMDIE+"([L]J)" With GDIE([L]I)
    If evalue(WMSK+WNOMCCE+"([L]J)")=""
      Call INISEC([L]SECTION,WSECDEF,GDIE([L]I)) From SUBCDE
      Assign WMSK+WNOMCCE+"([L]J)" With [L]SECTION
    Endif
    [L]J+=1
  Endif
Next [L]I
Assign WMSK+WBASTAB With [L]J : # avant GNBDIE
#----- Affichage et rétablissement masque par défaut si nécessaire -----#
If WABRMSK<>""
  Default Mask [L]MSK_COURANT
Endif
#-----
End

#--------------------------------------------------------------#
# Enregistrement sections du document [M]CCE(20)               #
#      dans la table CPTANALIN, appelé par l'action VALLIG     #
# ------------------------------------------------------------ #
# Paramčtres ŕ passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WNOMDSP  : Nom du champ du code répartition              #
#                "" = il n'y a pas de code répartition         #
#   - WNOMDIE  : Nom du tableau contenant les axes             #
#   - WNOMCCE  : Nom du tableau contenant les sections         #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WABRFIC  : Abréviation table des lignes du document      #
#   - WVCRTYP  : Type de la pičce                              #
#   - WVCRNUM  : Numéro de la pičce                            #
#   - WVCRLIN  : Numéro de ligne de la pičce                   #
#   - WVCRSEQ  : Numéro de séquence de la pičce                #
#   - WCPLCLE  : Complément clé                                #
#   - WMAJCOD  : Code mise ŕ jour                              #
#                  "C" = Création                              #
#                  "M" = Modification                          #
#                  "A" = Annulation                            #
#--------------------------------------------------------------#
Subprog ENREG_TABCCE(WABRMSK,WNOMDSP,WNOMDIE,WNOMCCE,WBASTAB,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE,WMAJCOD)
Value    Char    WABRMSK
Value    Char    WNOMDSP
Value    Char    WNOMDIE
Value    Char    WNOMCCE
Value    Char    WBASTAB
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
Value    Char    WMAJCOD
#-----
Local    Integer I, J, WNBDIE
Local    Char    WMSK (GLONAMK)
#-----
# FQ 72191 GA 04/2011 ne pas insérer ligne vide
If WABRFIC="" | WVCRTYP=0 | WVCRNUM=""
  Call ECR_TRACE("CPTANALIN: erreur de chargement"-adxpno(1)-WMAJCOD-WABRMSK-WABRFIC-WVCRNUM,1) From GESECRAN
  End
Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#----- Suppression comptes et sections de la ligne du document -----#
If WMAJCOD="A"
  Delete [CAL] Where ABRFIC=WABRFIC
&                  & VCRTYP=WVCRTYP
&                  & VCRNUM=WVCRNUM
&                  & VCRLIN=WVCRLIN
&                  & VCRSEQ=WVCRSEQ
&                  & CPLCLE=WCPLCLE
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN"-WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ) : End
  Endif
  End
#----- Modification des comptes et sections de la ligne du document -----#
Elsif WMAJCOD="M"
  Readlock [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN"-WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ) : End
  Elsif fstat
    GOK=0  : Call RSTA("CAL",WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)) From GLOCK : End
  Endif
#----- Création des comptes et sections de la ligne du document -----#
Else
  Raz [F:CAL]
  [F:CAL]ABRFIC=WABRFIC
  [F:CAL]VCRTYP=WVCRTYP
  [F:CAL]VCRNUM=WVCRNUM
  [F:CAL]VCRLIN=WVCRLIN
  [F:CAL]VCRSEQ=WVCRSEQ
  [F:CAL]CPLCLE=WCPLCLE
  [F:CAL]ANALIG=1
Endif
  If WABRMSK<>""
     WMSK="[M:"+WABRMSK+"]"
  Else
     WMSK=""
  Endif
  If WBASTAB=""
     WBASTAB="NBAXE"
  Endif
  If WNOMDIE=""
     WNOMDIE="DIE"
  Endif
  If WNOMCCE=""
     WNOMCCE="CCE"
  Endif
#----- Mise ŕ jour code répartition -----#
  If WNOMDSP<>"" & evalue("dim("+WMSK+WNOMDSP+")")>0
    [F:CAL]DSP=evalue(WMSK+WNOMDSP)
  Endif
#----- Liste et Valeurs par défaut sections analytiques -----#
  # Issue X3-67804 - 2018-04-27 by MUARN : a faire en création seulement
  If WMAJCOD = "C"
    For I=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(I-1)=GDIE(I)
      Call INISEC([F:CAL]CCE(I-1),WABRFIC,GDIE(I)) From SUBCDE
    Next I
  Endif
  If WNOMCCE<>""
  # ---------------
  # Tableau [M]CCE
  # ---------------
    If evalue("dim("+WMSK+WBASTAB+")")>0
      WNBDIE = evalue(WMSK+WBASTAB)
      For I=0 To WNBDIE-1
        J=find(evalue(WMSK+WNOMDIE+"(I)"),[F:CAL]DIE(0..GNBDIE-1))
        If J & evalue("dim("+WMSK+WNOMCCE+")")>0
           [F:CAL]CCE(J-1)=evalue(WMSK+WNOMCCE+"(I)")
        Endif
      Next I
    Endif
  Endif
#-----
If WMAJCOD="M"  Rewrite [CAL]  Else  Write [CAL] : Endif
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : End : Endif
#-----
End


#------------------------------------------------------------#
# Chargement des sections depuis CPTANALIN                   #
# Appelé par l'action LIENS pour maj d'un tableau contenant  #
# les sections CCE(20)                          - GA 08/2006 #
# ---------------------------------------------------------- #
# Paramčtres ŕ passer au sous-programme :                    #
#   - WABRMSK  : Abréviation du masque écran                 #
#   - WNOMDIE  : Nom du tableau contenant les axes           #
#   - WNOMCCE  : Nom du tableau contenant les sections       #
#   - WBASTAB  : Var. bas de tableau contenant les sections  #
#   - WSECFIC  : Code paramétrage sections                   #
#   - WVCRTYP  : Type de la pičce                            #
#   - WVCRNUM  : Numéro de la pičce                          #
#   - WVCRLIN  : Numéro de ligne de la pičce                 #
#   - WVCRSEQ  : Numéro de séquence de la pičce              #
#   - WCPLCLE  : Complément clé                              #
#------------------------------------------------------------#
Subprog CHARG_TABCCE(WABRMSK,WNOMDIE,WNOMCCE,WBASTAB,WSECFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE)
Value    Char    WABRMSK
Value    Char    WNOMDIE
Value    Char    WNOMCCE
Value    Char    WBASTAB
#Value    Char    WNOMDSP   # FQ 69909 Ctrl des sources Unexpected argument delcaration
Value    Char    WSECFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
#-----
Local    Integer I, J, WNBDIE
Local    Char    WMSK (GLONAMK)
#-----
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#-----
Read [CAL] CAL0=WSECFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
If !fstat
  If WABRMSK<>""
     WMSK="[M:"+WABRMSK+"]"
  Else
     WMSK="[M]"
  Endif
  If WBASTAB=""
     WBASTAB="NBAXE"
  Endif
  If WNOMDIE=""
     WNOMDIE="DIE"
  Endif
  If WNOMCCE=""
     WNOMCCE="CCE"
  Endif
  If WNOMCCE<>""
  # ---------------
  # Tableau [M]CCE
  # ---------------
    If evalue("dim("+WMSK+WBASTAB+")")>0 & evalue("dim("+WMSK+WNOMDIE+")")>0
      WNBDIE = evalue(WMSK+WBASTAB)
      For I=0 To WNBDIE-1
        J=find(evalue(WMSK+WNOMDIE+"(I)"),[F:CAL]DIE(0..GNBDIE-1))
        If J & evalue("dim("+WMSK+WNOMCCE+")")>0
           Assign WMSK+WNOMCCE+"(I)" With [F:CAL]CCE(J-1)
        Endif
      Next I
    Endif
  Endif
Endif
#-----
End


# -------------------------------------------------------------------------
# Liste des fichiers a ouvrir pour acceder aux plans de comptes et sections
# -------------------------------------------------------------------------
$OPEN_FILES

If GMODU(2)=2  : # en presence du module cpta
  If clalev([F:BLA])=0 : Local File BALANA [BLA] : Endif
  If clalev([F:BUD])=0 : Local File BUD    [BUD] : Endif
  If clalev([F:BUP])=0 : Local File BUDPAR [BUP] : Endif
Endif

If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:CAZ])=0 : Local File CAAUZ      [CAZ] : Endif

If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED   [GAD] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif

If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif : # Modele comptable
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif : # Referentiel(s)
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif : # Plan(s) de compte(s)
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif : # Axe(s) analytique(s)

If clalev([F:DTR])=0 : Local File DIETRS     [DTR] : Endif
If clalev([F:CAL])=0 : Local File CPTANALIN  [CAL] : Endif

Return


#########################################################################
# Action SAIHEACCE : Saisie des sections analytiques entęte             #
# --------------------------------------------------------------------- #
#    PARAM(1) = WABMSK : Abréviation de l'écran entęte document         #
#    PARAM(2) = FCY    : Site financier (en principe GFINRSP)           #
#    PARAM(3) = DAT    : Date                                           #
#########################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenętre #
#--------------------------------------------------------------#
$OUV_SAIHEACCE
#----- Variables locales -----#
Local Char    WABMSK(4)     : WABMSK=PARAM(1)
Local Char    WFCY(GLONFCY) : WFCY  =PARAM(2)
Local Date    WDATE         : WDATE =PARAM(3)
Local Integer SAVNOLIGN     : SAVNOLIGN=nolign
Local Libelle FLGSAI        : FLGSAI=1
Local Libelle FLGEXE
Local Integer I
Return

#----------------------------------------------------------#
# Aprčs l'ouverture de la fenętre des sections analytiques #
#----------------------------------------------------------#
$DEB_SAIHEACCE
#----- Si pas de gestion de section alors c'est fini ! -----#
If dim([M:HCCE]NBAXE)<1  FIN=1 : Return : Endif
#-----
Raz [M:HCCE]
For I=1 To max(GNBDIE,GOPTCANA)
  [M:HCCE]DIE(I-1)=evalue("[M:"+WABMSK+"]DIE(I-1)")
  [M:HCCE]CCE(I-1)=evalue("[M:"+WABMSK+"]CCE(I-1)")
Next I
[M:HCCE]NBAXE=GNBDIE
[M:HCCE]WFCY =WFCY
[M:HCCE]WDATE=WDATE
Affzo [HCCE]1-99
#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
If GHEADIE<>1
  Diszo [HCCE]1-99 : Raz FLGSAI
Elsif GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Diszo [HCCE]1-99 : Raz FLGSAI : Return : Endif
  If clalev([M:PNH1])
    If !GPNH_VERROU | [M:PNH1]CFMFLG=2  Diszo [HCCE]1-99 : Raz FLGSAI : Endif
  Elsif clalev([M:PTH1])
    If !GPTH_VERROU                     Diszo [HCCE]1-99 : Raz FLGSAI : Endif
  Endif
Endif
Return

#--------------------------------------#
# Activation/désactivation des boutons #
#--------------------------------------#
$SETB_SAIHEACCE
If !FLGSAI
  CHBOU="F" : # Pas de saisie bouton "Fin" uniquement !
Endif
Return

#--------------------------------#
# Aprčs l'exécution du bouton OK #
#--------------------------------#
$OK_SAIHEACCE
If FLGSAI<>0
  For I=1 To max(GNBDIE,GOPTCANA)
    Assign "[M:"+WABMSK+"]DIE(I-1)" With [M:HCCE]DIE(I-1)
    Assign "[M:"+WABMSK+"]CCE(I-1)" With [M:HCCE]CCE(I-1)
  Next I
  FLGEXE=1
Endif
FIN=1
mkstat=4
Return

#-------------------------------------#
# Aprčs l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAIHEACCE
FLGEXE=0
For I=1 To max(GNBDIE,GOPTCANA)
  [M:HCCE]DIE(I-1)=evalue("[M:"+WABMSK+"]DIE(I-1)")
  [M:HCCE]CCE(I-1)=evalue("[M:"+WABMSK+"]CCE(I-1)")
Next I
Raz REP
Affzo [HCCE]1-99
Return

#------------------------------------------#
# Avant de revenir ŕ la fenętre précédente #
#------------------------------------------#
$FINSAI_SAIHEACCE
If FLGEXE=1  mkstat=4 : Endif
nolign=SAVNOLIGN
Return

###################################################
# TRFSEC Récupération de la section d'un document #
# ----------------------------------------------- #
# ABRFIC : Abréviation de la table                #
# AXE    : Code de l'axe ŕ récupérer              #
#                                                 #
# La classe de la table du document d'origine     #
#   doit ętre ouverte et alimentée !              #
###################################################
Funprog TRFSEC(ABRFIC,AXE)
Value Char     ABRFIC : # Abréviation de la table du document
Value Char     AXE    : # Code de l'axe
#-----
Local Libelle  VCRTYP
Local Char     VCRNUM(GLONVCR)
Local Integer  VCRLIN
Local Integer  VCRSEQ
Local Char     CPLCLE(30)
Local Shortint ANALIG
#----- Section analytique récupérée -----#
Local Integer  INDAXE,OCALW : OCALW=1
Local Char     WCCE(GLONCCE)
Local Libelle  WERR
#-----
# FQ 72191 GA 04/2011 l'appel de INISEC est fait quand on a déjŕ renseigné le futur [F:CAL], ne pas l'écraser ...
If !clalev([F:CALW]) : Local File CPTANALIN [CALW] : OCALW=2 : Endif
#----- Valeurs par défaut -----#
Raz VCRTYP, VCRNUM, VCRLIN, VCRSEQ, CPLCLE
ANALIG=1
#-----
If evalue("clalev([F:"+left$(ABRFIC,3)+"])")=0  Goto FIN_TRFSEC : Endif
#-----
Case ABRFIC
  When "" : WERR=1 : Call ERREUR("TRFSEC(ABRFIC,AXE) : ABRFIC not VALID !") From GESECRAN
    #----- Documents module achats -----#
  When "PQD"  : VCRNUM=[F:PQD]PQHNUM    : VCRLIN=[F:PQD]PQDLIN
  When "PSD"  : VCRNUM=[F:PSD]PSHNUM    : VCRLIN=[F:PSD]PSDLIN
  When "POP"  : VCRNUM=[F:POP]POHNUM    : VCRLIN=[F:POP]POPLIN    : VCRSEQ=[F:POP]POPSEQ
  When "UOP"  : VCRNUM=[F:UOP]POHNUM    : VCRLIN=[F:UOP]POPLIN    : VCRSEQ=[F:UOP]POPSEQ
                CPLCLE=num$([F:UOP]LINREVNUM)
  When "PTD"  : VCRNUM=[F:PTD]PTHNUM    : VCRLIN=[F:PTD]PTDLIN
  When "PND"  : VCRNUM=[F:PND]PNHNUM    : VCRLIN=[F:PND]PNDLIN
  When "PID"  : VCRNUM=[F:PID]NUM       : VCRLIN=[F:PID]PIDLIN
  When "PVF"  : VCRTYP=[F:PVF]VCRTYP    : VCRNUM=[F:PVF]VCRNUM    : VCRSEQ=[F:PVF]IND
  # Issue 81115 - 2012-04-12 by SR
  When "PTI"  :  If dim([F:PTI]NUM) > 0
                     ABRFIC = "PID" : VCRNUM=[F:PTI]NUM       : VCRLIN=[F:PTI]PIDLIN
                 # Issue 120331 - 2016-12-09 by SR : ajout FCC sur commande/Expédition
                 Elsif dim([F:PTI]PTHNUM) > 0
                     ABRFIC = "PTD" : VCRNUM=[F:PTI]PTHNUM    : VCRLIN=[F:PTI]PTDLIN
                 Else
                     # Issue X3-89034 - 2018-04-30 by MUARN : utilisation de PTI non POP
                     #ABRFIC = "POP" : VCRNUM=[F:POP]POHNUM    : VCRLIN=[F:POP]POPLIN    : VCRSEQ=[F:POP]POPSEQ
                     ABRFIC = "POP" : VCRNUM=[F:PTI]POHNUM    : VCRLIN=[F:PTI]POPLIN    : VCRSEQ=[F:PTI]POPSEQ
                 Endif
    #----- Documents module ventes -----#
  When "SQD"  : VCRNUM=[F:SQD]SQHNUM    : VCRLIN=[F:SQD]SQDLIN
  When "SOP"  : VCRNUM=[F:SOP]SOHNUM    : VCRLIN=[F:SOP]SOPLIN    : VCRSEQ=[F:SOP]SOPSEQ
  When "VOP"  : VCRNUM=[F:VOP]SOHNUM    : VCRLIN=[F:VOP]SOPLIN    : VCRSEQ=[F:VOP]SOPSEQ
                CPLCLE=num$([F:VOP]LINREVNUM)
  When "SDD"  : VCRNUM=[F:SDD]SDHNUM    : VCRLIN=[F:SDD]SDDLIN
  When "SRD"  : VCRNUM=[F:SRD]SRHNUM    : VCRLIN=[F:SRD]SRDLIN
  When "SID"  : VCRNUM=[F:SID]NUM       : VCRLIN=[F:SID]SIDLIN
  When "SVF"  : VCRTYP=[F:SVF]VCRTYP    : VCRNUM=[F:SVF]VCRNUM    : VCRSEQ=[F:SVF]DTA
    #----- Documents module GPAO -----#
  When "MFI"  : VCRNUM=[F:MFI]MFGNUM    : VCRLIN=[F:MFI]MFGLIN
  When "MFO"  : VCRNUM=[F:MFO]MFGNUM    : VCRLIN=[F:MFO]OPENUM    : VCRSEQ=[F:MFO]OPESPLNUM
                CPLCLE="EXTWST"
  When "MFO1" : VCRNUM=[F:MFO]MFGNUM    : VCRLIN=[F:MFO]OPENUM    : VCRSEQ=[F:MFO]OPESPLNUM
                CPLCLE="EXTWST"
                ABRFIC="MFO"    # Issue 85182 - 2012-10-25 by CCC
  When "MFO2" : VCRNUM=[F:MFO]MFGNUM    : VCRLIN=[F:MFO]OPENUM    : VCRSEQ=[F:MFO]OPESPLNUM
                CPLCLE="EXTLAB"
                ABRFIC="MFO"    # Issue 85182 - 2012-10-25 by CCC
  When "MFM"  : VCRNUM=[F:MFM]MFGNUM    : VCRLIN=[F:MFM]MFGLIN    : VCRSEQ=[F:MFM]BOMSEQ
                CPLCLE=[F:MFM]ITMREF
  When "MKI"  : VCRNUM=[F:MKI]MFGTRKNUM : VCRLIN=[F:MKI]ITMTRKLIN
  When "MKO"  : VCRNUM=[F:MKO]MFGTRKNUM : VCRLIN=[F:MKO]OPETRKLIN : CPLCLE=[F:MKO]CPLWST
  When "MKO1" : VCRNUM=[F:MKO]MFGTRKNUM : VCRLIN=[F:MKO]OPETRKLIN : CPLCLE=[F:MKO]CPLWST
  When "MKO2" : VCRNUM=[F:MKO]MFGTRKNUM : VCRLIN=[F:MKO]OPETRKLIN : CPLCLE=[F:MKO]CPLLAB
  When "MKM"  : VCRNUM=[F:MKM]MFGNUM    : VCRLIN=[F:MKM]MATTRKLIN
  When "SCI"  : VCRTYP=36               : VCRNUM=[F:SCI]SCONUM    : VCRLIN=[F:SCI]SCILIN
  When "SCM"  : VCRTYP=36               : VCRNUM=[F:SCM]SCONUM    : VCRLIN=[F:SCM]SCILIN
                VCRSEQ=[F:SCM]SCMLIN
  When "SCS"  : VCRTYP=36               : VCRNUM=[F:SCS]SCONUM    : VCRLIN=[F:SCS]SCILIN
                VCRSEQ=[F:SCS]SCSLIN
  When "MWI"  : VCRNUM=[F:MWI]MFGTRKNUM : VCRLIN=[F:MWI]MFGTRKLIN : CPCLE=[F:MWI]OVENAT+"~"+[F:MWI]ITMREF
  # FQ 66830 GA 09/2010 ctrl des sources erreur [F:MWI]MFGYRKNUM (2 fois)
  When "MWI1" : VCRNUM=[F:MWI]MFGTRKNUM : VCRLIN=[F:MWI]MFGTRKLIN : CPCLE=[F:MWI]OVENAT+"~"+[F:MWI]ITMREF
  When "MWI2" : VCRNUM=[F:MWI]MFGTRKNUM : VCRLIN=[F:MWI]MFGTRKLIN : CPCLE=[F:MWI]ITMREF
    #----- Documents module CRM -----#
  When "HDT"  : VCRNUM=[F:HDT]HDTNUM
  When "HDI"  : VCRNUM=[F:HDI]SRENUM    : VCRLIN=[F:HDI]HDTORD
    #----- Documents module stocks -----#
  # FQ 66830 GA 09/2010 ctrl des sources erreur [F:SMD]VCRNIM
  When "SMD"  : VCRTYP=[F:SMD]VCRTYP    : VCRNUM=[F:SMD]VCRNUM    : VCRLIN=[F:SMD]VCRLIN
  When "SGD"  : VCRTYP=29               : VCRNUM=[F:SGS]VCRNUM    : VCRLIN=[F:SGD]VCRLIN
    #----- Reprise des sections entęte d'un document d'origine -----#
  When Default
    If evalue("dim([F:"+ABRFIC+"]CCE)")>0 & evalue("dim([F:"+ABRFIC+"]DIE)")>0
      INDAXE=evalue("find(AXE,[F:"+ABRFIC+"]DIE)")
      If INDAXE
        WCCE=evalue("[F:"+ABRFIC+"]CCE(min(max(INDAXE-1,0),GOPTCANA-1))")
      Endif
    Else
      WERR=1 : Call ERREUR("TRFSEC(ABRFIC,AXE) : ABRFIC not valid !") From GESECRAN
    Endif
Endcase
#-----
If WERR=0 & WCCE=""
  Read [CALW] CAL0=ABRFIC;VCRTYP;VCRNUM;VCRLIN;VCRSEQ;CPLCLE;ANALIG
  If !fstat
    INDAXE=find(AXE,[F:CALW]DIE)
    If INDAXE
      WCCE=[F:CALW]CCE(min(max(INDAXE-1,0),GOPTCANA-1))
    Endif
  Else
    Raz [F:CALW]
  Endif
Endif
#-----
$FIN_TRFSEC
# FQ 72191 GA 04/2011
If OCALW=2 Close Local File [CALW] Endif
End WCCE

#--- Bug 70214
###################################################
# TRFSECMSK Récupération de la section d'un écran #
# ----------------------------------------------- #
# ABRMSK : Abréviation de l'écran                 #
# AXE    : Code de l'axe ŕ récupérer              #
#                                                 #
# La classe de l'écran d'origine doit ętre        #
# ouverte et alimentée !                          #
###################################################
Funprog TRFSECMSK(ABRMSK,AXE)
Value Char     ABRMSK : # Abréviation de l'écran
Value Char     AXE    : # Code de l'axe

Local Integer  INDAXE
Local Char     WCCE(GLONCCE)
Local Libelle  WERR

If evalue("clalev([M:"+ABRMSK+"])")=0  Goto FIN_TRFSECMSK : Endif

Onerrgo ERR_TRFSECMSK
Case ABRMSK
  When ""            : Call ERREUR("TRFSECMSK(ABRMSK,AXE) : ABRMSK not VALID!") From GESECRAN
  When "SRE9","ITN8" : If GFONCTION="GESSRE"
                         WCCE=evalue("[M:SRE9]CCE"+num$(find(AXE,GDIE))+"("+num$(GNOLIG)+")")
                       Elsif GFONCTION="GESITN"
                         WCCE=evalue("[M:ITN8]CCE"+num$(find(AXE,GDIE))+"("+num$(GNOLIG)+")")
                       Else
                         WCCE=evalue("[M:"+ABRMSK+"]CCE"+num$(find(AXE,GDIE))+"("+num$(GNOLIG)+")")
                       Endif
  When "MFG1"        : WCCE=evalue("[M:MFG1]CCE"+num$(find(AXE,GDIE)))
                       If WCCE="" & dim(GNOLIG)>0 & GNOLIG<[M:MFG1]NBLIG
                          WCCE=evalue("[M:"+ABRMSK+"]CCE"+num$(find(AXE,GDIE))+"("+num$(GNOLIG)+")")
                       Endif
  When Default       : WCCE=evalue("[M:"+ABRMSK+"]CCE"+num$(find(AXE,GDIE))+"("+num$(GNOLIG)+")")
Endcase

Onerrgo
$FIN_TRFSECMSK
End WCCE
$ERR_TRFSECMSK
WERR=1 : Call ECR_TRACE("TRFSECMSK(ABRMSK,AXE) : Error on"-ABRMSK-AXE,1) From GESECRAN
Onerrgo
End ""

#**----------------------------------------------------------------<br/>
#* TRFSECX : Récupčre la section analytique d'un masque ou fichier.
#*             La liste des écrans ou fichiers est passée en paramčtre.
#*             Si l'abréviation n'est pas ouverte, c'est la suivante qui est utilisée...
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR : Liste des abréviations séparées par une "," (ex : "MTK2,MBI,MKI")
#* @param PTYP : Liste des types d'abréviations séparées par une "," (ex : "M,M,F")
#* @param AXE  : code axe
#**<br/>----------------------------------------------------------------
Funprog TRFSECX(PABR,PTYP,AXE)
Value Char     PABR
Value Char     PTYP
Value Char     AXE

Local Integer NBABR : NBABR = 1 + sigma(1,len(PABR),seg$(PABR,indcum,indcum)=",")

Local Integer I, J
Local Char    LABR(GLONABR), LTYP(1)
Local Char    LABRTMP(len(PABR)), LTYP(len(PTYP))
Local Char    WCCE(GLONCCE)
Local Char    CAR(250)

Raz J
Onerrgo ERR_TRFSECX
LABRTMP=toupper(vireblc(PABR,4))
LTYPTMP=toupper(vireblc(PTYP,4))
CAR = sigma(I=32,43,chr$(I))+sigma(I=45,47,chr$(I))+sigma(I=58,64,chr$(I))+sigma(I=91,127,chr$(I))
LABRTMP=ctrans(LABRTMP,CAR,"")
LTYPTMP=ctrans(LTYPTMP,CAR,"")

For I=0 To NBABR-1
    J=instr(1,LABRTMP,",")
    LTYP=seg$(LTYPTMP,I*2+1,I*2+1)
    If J=0
        LABR = LABRTMP
    Else
        LABR = left$(LABRTMP,J-1)
        LABRTMP = right$(LABRTMP,J+1)
    Endif
    Case LTYP
        When "F" :
            If evalue("clalev([F:"+LABR+"])")>0
                WCCE = func TRFSEC(LABR, AXE)
                Break
            Endif
        When "M" :
            If evalue("clalev([M:"+LABR+"])")>0
                WCCE = func TRFSECMSK(LABR, AXE)
                Break
            Endif
    Endcase
Next
Onerrgo
End WCCE

$ERR_TRFSECX
Call ECR_TRACE('TRFSECX("'+PABR+'","'+PTYP+'","'+AXE+'") : '+errmes$(errn),1) From GESECRAN
Onerrgo
End ""

# FQ 71312
###################################################
# TRFSECORI Récup de la section d'un doc origine  #
# ----------------------------------------------- #
# ABRMSK : Abréviation de l'écran                 #
# AXE    : Code de l'axe ŕ récupérer              #
###################################################
Funprog TRFSECORI(ABRMSK,AXE)
Value Char     ABRMSK : # Abréviation de l'écran
Value Char     AXE    : # Code de l'axe

Local Char     WABRFIC(GLONABR)
Local Libelle  WVCRTYP
Local Char     WVCRNUM
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Char     WCPLCLE
Local Shortint WANALIG : WANALIG=1

Local Integer  INDAXE,OCALW : OCALW=1
Local Char     WCCE(GLONCCE)
Local Libelle  WERR

If ABRMSK="" Call ERREUR("TRFSECORI(ABRMSK,AXE) : ABRMSK not VALID!") From GESECRAN : End "" : Endif

Raz WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE,WCCE

If evalue("dim([M:"+ABRMSK+"]VCRNUMORI)")>0   WVCRNUM=evalue("[M:"+ABRMSK+"]VCRNUMORI(nolign-1)") Endif
If evalue("dim([M:"+ABRMSK+"]VCRLINORI)")>0   WVCRLIN=evalue("[M:"+ABRMSK+"]VCRLINORI(nolign-1)") Endif
If evalue("dim([M:"+ABRMSK+"]VCRSEQORI)")>0   WVCRSEQ=evalue("[M:"+ABRMSK+"]VCRSEQORI(nolign-1)") Endif

If WVCRNUM="" : End "" : Endif

# FQ 72191 GA 04/2011 l'appel de INISEC est fait quand on a déjŕ renseigné le futur [F:CAL], ne pas l'écraser ...
If !clalev([F:CALW]) : Local File CPTANALIN [CALW] : OCALW=2 : Endif

Onerrgo ERR_TRFSECORI
Case ABRMSK
  When "POH1"        :
       Case [M:POH2]VCRTYPORI(nolign-1)          # Ctrl des sources avant [M:POH1]
            When 2  :   WABRFIC="SOP"
            When 10 :   WABRFIC="MFO"
                        WCPLCLE="EXTWST"
            When 36 :   WVCRTYP=36
                 Case [M:POH2]LINTYP(nolign-1)   # Ctrl des sources avant [M:POH1]
                    When 2 :  WABRFIC="SCI"
                    When 3 :  WABRFIC="SCS"
                    When 4 :  WABRFIC="SCM"
                 Endcase
       Endcase
  When "POI1"        :
       Case [M:POI1]VCRTYPORI(nolign-1)
            When 2  :   WABRFIC="SOP"
            When 10 :   WABRFIC="MFO"
                        WCPLCLE="EXTWST"
            When 36 :   WVCRTYP=36
                 Case [M:POI1]LINTYP(nolign-1)
                    When 2 :  WABRFIC="SCI"
                    When 3 :  WABRFIC="SCS"
                    When 4 :  WABRFIC="SCM"
                 Endcase
       Endcase
  When Default       :
Endcase

If WABRFIC<>""
  Read [CALW] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;WANALIG
  If !fstat
    INDAXE=find(AXE,[F:CALW]DIE)
    If INDAXE
      WCCE=[F:CALW]CCE(min(max(INDAXE-1,0),GOPTCANA-1))
    Endif
  Else
    Raz [F:CALW]
  Endif
Endif
Onerrgo
$FIN_TRFSECORI
# FQ 72191 GA 04/2011
If OCALW=2 Close Local File [CALW] Endif
End WCCE
$ERR_TRFSECORI
WERR=1 : Call ECR_TRACE("TRFSECORI(ABRMSK,AXE) : Error on"-ABRMSK-num$(WVCRTYP)-AXE,1) From GESECRAN
Onerrgo
# FQ 72191 GA 04/2011
If OCALW=2 Close Local File [CALW] Endif
End ""

###################################################
# TYPLEDAUTO Type de référentiel automatique      #
# ----------------------------------------------- #
# TYPLED : Type de référentie ŕ tester            #
#                                                 #
# au retour WFLAG référentiel automatique ?       #
#           0=Non,  1=Oui                         #
###################################################
Funprog TYPLEDAUTO(TYPLED)
Value Integer TYPLED : # Type de référentiel
#-----
Local Integer WFLAG
Local Char    WLEDTYPAUT(len([V]GLEDTYPAUT))
#-----
[L]WLEDTYPAUT=[V]GLEDTYPAUT
#----- Si la valeur 10 est trouvée alors que l'on recherche 1, il faut l'enlever -----#
If TYPLED=1 & instr(1,[V]GLEDTYPAUT,"10")
  [L]WLEDTYPAUT =left$ ([V]GLEDTYPAUT,instr(1,[V]GLEDTYPAUT,"10")-1)
  [L]WLEDTYPAUT+=right$([V]GLEDTYPAUT,instr(1,[V]GLEDTYPAUT,"10")+2)
Endif
#-----
If instr(1,[L]WLEDTYPAUT,num$(TYPLED))  WFLAG=1  Else  WFLAG=0 : Endif
#-----
End WFLAG

################################################################################
# Contrôle des paramčtres de sections par défaut (0=erreur; 1=OK)    module TC #
################################################################################
Subprog VERF_PARAM(PPARAM,PVAL,PRET)
Value Char PPARAM
Value Char PVAL
Variable Integer PRET
If !clalev([F:CDE]) : Local File CACCEDEF [CDE] : Endif
PRET=1
If PVAL="" : End : Endif
If find(PPARAM,"BALCCE","INVVARCCE","LABVARCCE","MATVARCCE","OPEVARCCE","OVEVARCCE","SCOVARCCE","WIPBALCCE")
    If dim([M:ADWP]CMP)>0 & [M:ADWP]CMP<>""
        Look [CDE]CDE0=PVAL;[M:ADWP]CMP
    Endif
    If fstat | !(dim([M:ADWP]CMP)>0 & [M:ADWP]CMP<>"")
        Look [CDE]CDE0=PVAL;""
    Endif
    If fstat
        PRET=0
    Endif
Endif
End

# Charge les CCE de PVCR.PSFINUM dans PSFICCE et PSDIDSP
Subprog CHARG_CCE_MULTI(PVCRTYP,PVCR,PVCRDTA,PSFINUM,PSFICCE,PSFIDSP)
Value Integer PVCRTYP
Value Char    PVCR
Value Char    PVCRDTA
Value Char    PSFINUM
Value Char    PSFICCE
Value Char    PSFIDSP   # FGR 01/02/2010 : X3SUIVI60986

# Issue 121835
Local Char    WVCR(GLONVCR)
Local Integer WSFINUM
# End issue 121835
Local Integer ISFI, ISFINUM, I, J

If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

For ISFI=0 To evalue("dim("+PVCR+")") - 1
    # Issue 121835
    If evalue(PVCRDTA+"(ISFI)")=0 Break Endif
    # End issue 121835

    ISFINUM = evalue ( "find (" + PVCRDTA+"(ISFI), "  + PSFINUM + ") -1 ")
    # Issue 121835
    If ISFINUM>-1
        WVCR = evalue(PVCR+"(ISFI)")
        WSFINUM = evalue(PSFINUM+"(ISFINUM)")
    #    If ISFINUM>-1 & evalue(PVCR+"(ISFI)") <> "" & evalue(PSFINUM+"(ISFINUM)") > 0
    #      Read [CAL]CAL0="SVF";PVCRTYP;evalue(PVCR+"(ISFI)");0;evalue(PSFINUM+"(ISFINUM)");"";1
        If WVCR<>"" & WSFINUM > 0
          Read [CAL]CAL0="SVF";PVCRTYP;WVCR;0;WSFINUM;"";1
    # End issue 121835
          If !fstat
            # ACA (2010-03-04) Bug 63011 : Repartition analytique
            If [F:CAL]DSP <>""
                # 96708 : Transfert des sections analytiques des éléments de facturation
                #Assign PSFIDSP With [F:CAL]DSP
                Assign PSFIDSP+"(ISFINUM)" With [F:CAL]DSP
                # 96708
                For I=1 To GOPTCANA
                  If evalue("dim("+PSFICCE+num$(I)+")")>0
                      Assign PSFICCE+num$(I)+"(ISFINUM)" With ""
                  Endif
                Next I
            Else
                # 96708 : Transfert des sections analytiques des éléments de facturation
                Assign PSFIDSP+"(ISFINUM)" With ""
                # 96708
                For I=1 To max(GNBDIE,GOPTCANA)
                  J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
                  If J & evalue("dim("+PSFICCE+num$(J)+")")>0
                    If evalue (PSFICCE+num$(J)+"(ISFINUM)")=""
                      Assign PSFICCE+num$(J)+"(ISFINUM)" With [F:CAL]CCE(I-1)
                    Endif
                  Endif
                Next I
            Endif
          Endif
        Endif
    # Issue 121835
    Endif
    # End issue 121835
Next ISFI

End

