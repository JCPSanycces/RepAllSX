# Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
#--got non existing field error during FUNAUTFAE
Subprog CTRL_CCE_NOMCCE(WSECTION,WAXE,WNOMCPT,WFCY,WDATE,WNOMCCE)
Variable Char    WSECTION
Value    Integer WAXE
Value    Char    WNOMCPT
Value    Char    WFCY
