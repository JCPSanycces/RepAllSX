#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta CPS (lineas facturas compra)
# 06.325.600 AMG.16032022- LISTADO LINEAS FACTURA COMPRA - LISTADO LINEAS ALBARANES COMPRA
###############################################################################################

$ACTION
Case ACTION
  When "FILTRE"       : Gosub FILTRE
  When "LECTURE"      : Gosub LECTURE
  When "OUVRE"        : Gosub OUVRE
  When "AV_AFFICHE"   : Gosub AV_AFFICHE
Endcase
Return

$FILTRE
# 06.325.600.str
Gosub ACTION From CNSCPJSTD
GPE=1
# 06.325.600.fin

Raz [M:CPJ1]ZTOTBOB
Raz [M:CPJ1]ZTOTKG
Raz [M:CPJ1]ZTOTM2
Raz [M:CPJ1]ZTOTIMPAI
Raz [M:CPJ1]ZTOTIMPII
Affzo [M:CPJ1]ZTOTBOB
Affzo [M:CPJ1]ZTOTKG
Affzo [M:CPJ1]ZTOTM2
Affzo [M:CPJ1]ZTOTIMPAI
Affzo [M:CPJ1]ZTOTIMPII

If [M:CPJ1]ZANCHODEB>0
   WFIL2+="&[F:PID]ZANCHO>="+num$([M:CPJ1]ZANCHODEB)
Endif
If [M:CPJ1]ZANCHOEND>0
   WFIL2+="&[F:PID]ZANCHO<="+num$([M:CPJ1]ZANCHOEND)
Endif
If [M:CPJ1]ZLONGITUDDEB>0
   WFIL2+="&[F:PID]ZLONGITUD>="+num$([M:CPJ1]ZLONGITUDDEB)
Endif
If [M:CPJ1]ZLONGITUDEND>0
   WFIL2+="&[F:PID]ZLONGITUD<="+num$([M:CPJ1]ZLONGITUDEND)
Endif


Return

$OUVRE
If clalev([F:ITM])= 0  : Local File ITMMASTER [ITM] : Endif
If clalev([F:PIDX])= 0 : Local File PINVOICED [PIDX] : Endif
Return

$AV_AFFICHE1
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
For F=0 To [M:CPJ2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CPJ2]ITMREF(F)
   Raz [F:PIDX]
   Read [PIDX]PID0=[M:CPJ2]NUM(F);[M:CPJ2]PIDLIN(F)
   If [F:PIDX]PUU="M2"
      [M:CPJ2]ZQTYKG(F)=arr([F:PIDX]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPJ2]ZQTYM2(F)=arr([F:PIDX]QTYPUU,0.01)
   Endif
   If [F:PIDX]PUU="KG"
      [M:CPJ2]ZQTYKG(F)=arr([F:PIDX]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPJ2]ZQTYM2(F)=arr([F:PIDX]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPJ2]ZQTYM2(F)=0
      Endif
   Endif
Next
Return

$CAL_CUMUL
Raz [M:CPJ1]ZTOTBOB
Raz [M:CPJ1]ZTOTKG
Raz [M:CPJ1]ZTOTM2
Raz [M:CPJ1]ZTOTIMPAI
Raz [M:CPJ1]ZTOTIMPII
# 06.325.600.str
#Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) Order By Key PID0
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
# 06.325.600.fin
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:PID]ITMREF

   [M:CPJ1]ZTOTBOB+=[F:PID]ZQTYBOB
   If [F:PID]PUU="M2"
      [M:CPJ1]ZTOTKG+=arr([F:PID]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPJ1]ZTOTM2+=arr([F:PID]QTYPUU,0.01)
   Endif
   If [F:PID]PUU="KG"
      [M:CPJ1]ZTOTKG+=arr([F:PID]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPJ1]ZTOTM2+=arr([F:PID]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPJ1]ZTOTM2+=0
      Endif
   Endif
   [M:CPJ1]ZTOTIMPAI+=[F:PID]AMTNOTLIN
   [M:CPJ1]ZTOTIMPII+=[F:PID]AMTNOTLIN
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CPJ1]ZTOTBOB
Affzo [M:CPJ1]ZTOTKG
Affzo [M:CPJ1]ZTOTM2
Affzo [M:CPJ1]ZTOTIMPAI
Affzo [M:CPJ1]ZTOTIMPII
Return

#Auren.str 14/02/2022
#06.306.389 : LISTADO LINEAS FACTURA COMPRAS
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT
Local   Integer  NUMECH
Local   Integer  WFLGPAZ
Local   Decimal  WRATCUR, WRATRPT
Local   Shortint WI


Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#MAE, est ce qu'on vient de article ou article site ?
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CPJ1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CPJ1]ITMREF
        Diszo [M:CPJ1]FCY
        Diszo [M:CPJ1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CPJ1]BPR
       Diszo [M:CPJ1]BPSNUMDEB : Diszo [M:CPJ1]BPSNUMFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CPJ1]PJTDEB
      Diszo [M:CPJ1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCPJSTD
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [PID] With [PIH]PIH0=[PID]NUM
&          As [LNK]


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPJ]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PID0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key CLE=[F:PIH]BPRDAT;[F:PIH]NUM;[F:PID]PIDLIN :# 69747
#&                    Order By Key CLE=[F:PIH]BPRDAT;[F:PIH]NUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPJ]TRI
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key CLE=[F:PIH]BPRDAT Desc ;[F:PIH]NUM Desc ;[F:PID]PIDLIN Desc :# 69747
#&                    Order By Key CLE=[F:PIH]BPRDAT Desc ; [F:PIH]NUM Desc
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PID0 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPJ2] : Endif

#-- lecture
$BOUCLE
For [LNK]
  #----- Filtre sur la société -----#
  If [M:CPJ1]CPY<>""
    If [F:FCY]FCY<>[F:PIH]FCY
      Read [FCY] FCY0=[F:PIH]FCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPJ1]CPY  Goto SUIV : Endif
  Endif
  #----- Filtre sur le bon ŕ payer -----#
  For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
    [F:PIH]PAZ=[F:DUD]FLGPAZ
    Break
  Next
  If !evalue(WFIL2)  Goto SUIV : Endif
  #-----
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPJ2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:PID]NUM=FINNUM and [F:PID]PIDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:PIH]NUM
         DEBDAT = [F:PIH]BPRDAT
         DEBLIN = [F:PID]PIDLIN :# 69747
     Endif
     FINNUM = [F:PIH]NUM
     FINDAT = [F:PIH]BPRDAT
     FINLIN = [F:PID]PIDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:PID]NUM=DEBNUM and [F:PID]PIDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:PIH]NUM
         FINDAT = [F:PIH]BPRDAT
         FINLIN = [F:PID]PIDLIN :# 69747
     Endif
     DEBNUM = [F:PIH]NUM
     DEBDAT = [F:PIH]BPRDAT
     DEBLIN = [F:PID]PIDLIN :# 69747
  Endif

  nolign = NOL+1

  [M:CPJ2]=[F:PIH] : # trans classe sur PINVOICE
  [M:CPJ2]=[F:PID] : # trans classe sur PINVOICED

#MAE, exi 91193
#calcul du cours de change si devise différente
If [F:PIH]CUR <> GLOCALDEV
    If [F:PIH]RATDIV(0)<>0  WCOURS=[F:PIH]RATMLT(0)/[F:PIH]RATDIV(0) : Endif
Endif

#CONVERSION EN DEVISE DOCUMENT (SOCIÉTÉ POUR LINAMT)
If GLOCALDEV <> [F:PIH]CUR
  #récupération arrondi devise société
  # Issue X3-232436 - 2021-01-22 by MUARN
  #If GLOCALDEV <> [F:PIH]CUR
  If [F:TCU]CUR <> GLOCALDEV
    Read [TCU] TCU0 = GLOCALDEV
       If fstat Raz [F:TCU] : Endif
  Endif
  [M:CPJ2]AMTNOTLINSOC(nolign-1) = arr([M:CPJ2]AMTNOTLIN(nolign-1)*WCOURS,[F:TCU]CURRND)
  # Issue X3-232436 - 2021-01-22 by MUARN : use good currency for runding
  [M:CPJ2]AMTATILINSOC(nolign-1) = arr([M:CPJ2]AMTATILIN(nolign-1)*WCOURS,[F:TCU]CURRND)
  #récupération arrondi devise document
  # Issue X3-232436 - 2021-01-22 by MUARN
  #If GLOCALDEV <> [F:PIH]CUR
  If [F:TCU]CUR <> [M:CPJ2]CUR(nolign-1)
    Read [TCU] TCU0 = [M:CPJ2]CUR(nolign-1)
       If fstat Raz [F:TCU] : Endif
  Endif
  [M:CPJ2]CSTPURDOC(nolign-1) = arr([M:CPJ2]CSTPUR(nolign-1)/WCOURS,[F:TCU]CURRND)
  [M:CPJ2]LINCSTPURDOC(nolign-1) = arr([M:CPJ2]LINCSTPUR(nolign-1)/WCOURS,[F:TCU]CURRND)
  # MUARN, exi 91193
  # Issue X3-232436 - 2021-01-22 by MUARN : use good currency for runding
  #[M:CPJ2]AMTATILINSOC(nolign-1) = arr([M:CPJ2]AMTATILIN(nolign-1)*WCOURS,[F:TCU]CURRND)
Else
  [M:CPJ2]AMTNOTLINSOC(nolign-1) = [M:CPJ2]AMTNOTLIN(nolign-1)
  [M:CPJ2]CSTPURDOC(nolign-1) = [M:CPJ2]CSTPUR(nolign-1)
  [M:CPJ2]LINCSTPURDOC(nolign-1) = [M:CPJ2]LINCSTPUR(nolign-1)
  # MUARN, exi 91193
  [M:CPJ2]AMTATILINSOC(nolign-1) = [M:CPJ2]AMTATILIN(nolign-1)
Endif

#06.306.389 : LISTADO LINEAS FACTURA COMPRAS
#auren 01-02-2022 especifico para poder exportar datos Z

   Raz [F:ITM]
   Read [ITM]ITM0=[M:CPJ2]ITMREF(nolign-1)
   Raz [F:PIDX]
   Read [PIDX]PID0=[M:CPJ2]NUM(nolign-1);[M:CPJ2]PIDLIN(nolign-1)
   If [F:PIDX]PUU="M2"
      [M:CPJ2]ZQTYKG(nolign-1)=arr([F:PIDX]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPJ2]ZQTYM2(nolign-1)=arr([F:PIDX]QTYPUU,0.01)
   Endif
   If [F:PIDX]PUU="KG"
      [M:CPJ2]ZQTYKG(nolign-1)=arr([F:PIDX]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPJ2]ZQTYM2(nolign-1)=arr([F:PIDX]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPJ2]ZQTYM2(nolign-1)=0
      Endif
   Endif

#fin auren 01-02-2022

#fin MAE 91193

  #US 71069/16  PJT by RBA
  [M:CPJ2]PJT(nolign-1)       = [F:PID]PJT
  #/US 71069/16  PJT by RBA

  $SUIV
Next
Filter [LNK]
GPE=1
Return
#auren.fin 06.306.389 : LISTADO LINEAS FACTURA COMPRAS
