#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Gestión de la máscara ZGOFS (Especifico)

#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
When "OUVRE"       :  Gosub OUVRE
When "TITRE"       :  Gosub TITRE_S
When "DEBUT"       :  Gosub DEBUT
When "SETBOUT"     :  Gosub SETBOUT

When "BOUTON"      :  Gosub BOUTON
When "APRES_MODIF" :  Gosub APRES_MODIF

When "END"         :  Gosub FIN_S
Endcase
Return

$OUVRE
Local Integer FLAG_ERR,FLG_OK
Local Char BD_TIPO(1)
Local Integer YN

If clalev([F:SOHX])<=0   :  Local File SORDER    [F:SOHX] : Endif
If clalev([F:SOQX])<=0   :  Local File SORDERQ   [F:SOQX] : Endif
If clalev([F:SOPX])<=0   :  Local File SORDERP   [F:SOPX] : Endif
If !clalev([F:ITM])      :  Local File ITMMASTER [F:ITM]  : Endif
If !clalev([F:STO])      :  Local File STOCK     [F:STO]  : Endif
If !clalev([F:ROH])      :  Local File ROUTING   [F:ROH]  : Endif
If !clalev([F:MFG])      :  Local File MFGHEAD   [F:MFG]  : Endif
If clalev ([F:ZMSQ])<=0  :  Local File ZMFGSOQ   [F:ZMSQ] : Endif
If clalev ([F:ZMFL])<=0  :  Local File ZMFGLOT   [F:ZMFL] : Endif
If clalev ([F:ACV])<=0   :  Local File ACTIV     [F:ACV]  : Endif

# Tope de filas en rejilla
Local Integer TFILAS_PED,TFILAS_STO,TFILAS_ELE
TFILAS_PED=func ZCOMUN.FILAS_GRID("ZPGOFS1","NPED")
TFILAS_STO=func ZCOMUN.FILAS_GRID("ZPGOFS1","NSTO")
TFILAS_ELE=func ZCOMUN.FILAS_GRID("ZPGOFS2","NELE")
#If GUSER="ADMIN"
#  Infbox "TFILAS_STO="+num$(TFILAS_STO)+"   TFILAS_PED="+num$(TFILAS_PED)
#Endif
Return

$FIN_S
Return

$TITRE_S
TIT="PROPUESTA OFs"# << EN PRUEBAS # PDTE.VALIDAR >>"
Return



$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
If    COUZON="FEMPALME" and CZ="2"
    Chgstl [M:ZGOFS0]FEMPALME With "BACKRED"
Elsif COUZON="FEMPALME" and CZ="1"
    Chgstl [M:ZGOFS0]FEMPALME With ""
Endif

#If COUZON="EMPALMAR"
#Infbox "maskcou = " + maskcou
#Endif
Case maskcou
When "ZPGOFS0"
  # Criterios de seleccion de pedidos
  Call VACIAR_REJILLA_PED(COUZON)
  Case COUZON
  When "FARTINI"
    If [M:ZGOFS0]FARTFIN<CZ
      [M:ZGOFS0]FARTFIN=CZ
      Affzo [M:ZGOFS0]FARTFIN
    Endif
  When "FFECINI"
    If [M:ZGOFS0]FFECFIN<CZ
      [M:ZGOFS0]FFECFIN=CZ
      Affzo [M:ZGOFS0]FFECFIN
    Endif
  When "FFPDINI"
    If [M:ZGOFS0]FFPDFIN<CZ
      [M:ZGOFS0]FFPDFIN=CZ
      Affzo [M:ZGOFS0]FFPDFIN
    Endif
  When "FCTEINI"
    If [M:ZGOFS0]FCTEFIN<CZ
      [M:ZGOFS0]FCTEFIN=CZ
      Affzo [M:ZGOFS0]FCTEFIN
    Endif
  When "FANCINI"
    If [M:ZGOFS0]FANCFIN<val(CZ)
      [M:ZGOFS0]FANCFIN=val(CZ)
      Affzo [M:ZGOFS0]FANCFIN
    Endif
  When "FLONINI"
    If [M:ZGOFS0]FLONFIN<val(CZ)
      [M:ZGOFS0]FLONFIN=val(CZ)
      Affzo [M:ZGOFS0]FLONFIN
    Endif
  Endcase
When "ZPGOFS1"
  # Pedidos + Materia prima a usar
  Case COUZON
  When "PEDSEL","PBOBINASC"
    # Cambios en la seleccion de pedidos
    Call VACIAR_CALCULOS From SPEZGOFS1
  When "JSEL", "NJUM","JUMBO","JUMBOF","JAGRUPAR"
    # Cambios en la seleccion de jumbos a mostrar en Stock/Materia prima
    Call VACIAR_REJILLA_STO (COUZON)
    If COUZON="JUMBO" and [M:ZGOFS1]JUMBOF<val(CZ)
      [M:ZGOFS1]JUMBOF=val(CZ)
      Affzo [M:ZGOFS1]JUMBOF
    Endif
  When "SSEL"
    # Cambios en la seleccion de jumbos a usar
    If not func HAY_MAS_JUMBOS([M:ZGOFS1]SANCHO(COUIND))
      Call VACIAR_CALCULOS From SPEZGOFS1
    Endif
  Endcase
When "ZPGOFS2"
  # Proponer OF / Cálculos
  If (COUZON<>"NSUG" and COUZON <>"SSEL") #  AND (COUZON<>"NTIA" and COUZON <>"NSEL")
    Call VACIAR_CALCULOS From SPEZGOFS1
  Endif
Endcase
#Case COUZON
#When "FARTINI"
#  If [M:ZGOFS0]FARTFIN<[M:ZGOFS0]FARTINI
#    [M:ZGOFS0]FARTFIN=[M:ZGOFS0]FARTINI
#    Affzo [M:ZGOFS0]FARTFIN
#  Endif
#When "FCTEINI"
#  If [M:ZGOFS0]FCTEFIN<[M:ZGOFS0]FCTEINI
#    [M:ZGOFS0]FCTEFIN=[M:ZGOFS0]FCTEINI
#    Affzo [M:ZGOFS0]FCTEFIN
#  Endif
#Endcase
Return


$DEBUT
# Valores por defecto
Gosub BORRA_PANTALLA
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
[M:ZGOFS0]FLDNUM(0)=TFILAS_ELE
Call LEER_JUMBOS
Local Char D(10)
D="-"
#Infbox "GUSER=" + GUSER
# Por defecto se miniminiza SOBRANTE
[M:ZGOFS2]SMINRES=1
Affzo [M:ZGOFS2]SMINRES
[M:ZGOFS2]SMINSTK=2
Affzo [M:ZGOFS2]SMINSTK
Raz [M:ZGOFS2]SMERMA
#Sacar destino por defecto del usuario
Local Char INFO(GLONARP),SRV(80),NAM(80) # ,DEST(GLONAIM)
INFO="ZRECETTE"
[M:ZGOFS4]RDEST=func ZCOMUN.INFORME(GUSER, INFO,SRV,NAM)
Affzo [M:ZGOFS4]RDEST
[M:ZGOFS4]RIMP =2
Affzo [M:ZGOFS4]RIMP
#
[M:ZGOFS4]STRDAT=date$
Affzo [M:ZGOFS4]STRDAT
[M:ZGOFS4]ENDDAT=date$
Affzo [M:ZGOFS4]ENDDAT
If GUSER<>"ADMIN"
  # 3 Rejilla Combinaciones
  Chgfmt [M:ZGOFS2]NCOM With D
  Chgfmt [M:ZGOFS2]NADA1 With D
  Chgfmt [M:ZGOFS2]CANCHOJ With D
  Chgfmt [M:ZGOFS2]POS With D
  Chgfmt [M:ZGOFS2]ORD With D
  Chgfmt [M:ZGOFS2]COMBI With D
  Chgfmt [M:ZGOFS2]CANCHO With D
  Chgfmt [M:ZGOFS2]CDIF With D
  Chgfmt [M:ZGOFS2]CANCHOA With D
  Chgfmt [M:ZGOFS2]CNUM With D

  # 5 Rejilla Opciones TMP
  Chgfmt [M:ZGOFS2]NTMP With D
  Chgfmt [M:ZGOFS2]TNADA With D
  Chgfmt [M:ZGOFS2]TANCHOJ With D
  Chgfmt [M:ZGOFS2]TOPCION With D
  Chgfmt [M:ZGOFS2]TNCOM With D
  Chgfmt [M:ZGOFS2]TCOMBI With D
  Chgfmt [M:ZGOFS2]TDIF With D
  Chgfmt [M:ZGOFS2]TDIFT With D
  Chgfmt [M:ZGOFS2]TTROZOS With D
  Chgfmt [M:ZGOFS2]TELE With D
  Chgfmt [M:ZGOFS2]TELET With D
  Chgfmt [M:ZGOFS2]TDIFTRZ With D
  Chgfmt [M:ZGOFS2]TANADIR With D
  Chgfmt [M:ZGOFS2]TANCHO With D
  Chgfmt [M:ZGOFS2]TANCHOA With D
  # 6 Rejilla Opciones
  Chgfmt [M:ZGOFS2]NOPC With D
  Chgfmt [M:ZGOFS2]NADA2 With D
  Chgfmt [M:ZGOFS2]OANCHOJ With D
  Chgfmt [M:ZGOFS2]OPCION With D
  Chgfmt [M:ZGOFS2]ONCOM With D
  Chgfmt [M:ZGOFS2]OCOMBI With D
  Chgfmt [M:ZGOFS2]ODIF With D
  Chgfmt [M:ZGOFS2]ODIFT With D
  Chgfmt [M:ZGOFS2]OTROZOS With D
  Chgfmt [M:ZGOFS2]OELE With D
  Chgfmt [M:ZGOFS2]OELET With D
  Chgfmt [M:ZGOFS2]ODIFTRZ With D
  Chgfmt [M:ZGOFS2]OANADIR With D
  Chgfmt [M:ZGOFS2]OANCHO With D
  Chgfmt [M:ZGOFS2]OANCHOA With D
Endif
Chgfmt [M:ZGOFS2]SLARGOT With D
Return

$SETBOUT
# BOTONES, ańadidos a la derecha.    Por defecto SI habilitados
# MENUS  , ańadidos a la derecha.    Por defecto NO habilitados
#No hay pedidos seleccionados
If [M:ZGOFS1]TLIN=0
  Call VIREBOUT(CHAINE,"234") From GOBJET
  Call VIREBOUT(CHAINE,"5")   From GOBJET
  Gosub SET_BOUT_SPE From GSAISIE
Endif
#
Local Char ART(GLONITM)
ART=func ARTICULO
If ART=""
  Chgtbk [M:ZGOFS1]20 With ""
  Chgtbk [M:ZGOFS2]10 With ""
Else
  Chgtbk [M:ZGOFS1]20 With "Jumbos " + ART
  Chgtbk [M:ZGOFS2]10 With "Bobinas a producir articulo " + ART
Endif
Return


$BOUTON
#If date$>=[13/02/2018]     Call ERREURT("Datos licencia insuficientes",1) From GESECRAN     :    Return     Endif
Case BOUT
  When "1"    :     Gosub BUSCAR_PEDIDOS
  When "2"    :     Gosub VALIDAR_JUMBOS
  When "3"    :     Gosub PROPONER_OF
  When "4"    :     Gosub GENERAR_OF
Endcase
Return



#===================================
#Subrutinas propias
#===================================

$BUSCAR_PEDIDOS
#
FLG_OK=0
Gosub COMPROBACIONES
If not FLG_OK
  Return
Endif
#
FLG_OK=0
Call VACIAR_REJILLA_PED("")
Call VACIAR_REJILLA_STO("")
[M:ZGOFS0]STA="1"
Gosub MOSTRAR_PEDIDOS
Call TOT_NPED_COL
Affzo [M:ZGOFS1]10
[M:ZGOFS0]STA=""
If not FLG_OK
  Return
Endif
If [M:ZGOFS1]NPED>0 and [M:ZGOFS1]JUMBO+[M:ZGOFS1]JUMBOF>0 and ([M:ZGOFS0]FARTINI<>"" and [M:ZGOFS0]FARTINI=[M:ZGOFS0]FARTFIN)
  Gosub VALIDAR_JUMBOS
  If [M:ZGOFS2]NJUM>0
#    Gosub PROPONER_OF
  Endif
Endif
Return

$VALIDAR_JUMBOS
Local Char ART(GLONITM)
FLG_OK=0
Call MOSTRAR_MATERIA_PRIMA(FLG_OK,BD_TIPO,TFILAS_STO)
If not FLG_OK
  Return
Endif
Call MOSTRAR_MATERIA_PRIMA_COLOR
Return


$PROPONER_OF
Local Integer F
Local Char RSTA(5),MND(255),MND_A(255)
If [M:ZGOFS0]FOF=2
    MSG="No se permite proponer OF, si hemos marcado la opcion\.\<<Mostrar OF en las que está incluido>>"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
If [M:ZGOFS1]JAGRUPAR=2
    MSG="No se permite proponer OF, si hemos marcado la opcion\.\<<Agrupar sub_lotes>>"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
# A comentar
If [M:ZGOFS2]NJUM<1
  [M:ZGOFS2]JANCHO([M:ZGOFS2]NJUM)=1020
  [M:ZGOFS2]NJUM+=1
Endif
If [M:ZGOFS2]NJUM<1
    MSG="No se ha indicado ANCHO de jumbos con los que trabajar\Asegúrese de que hay materia prima para el articulo seleccionado"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
For F=0 To [M:ZGOFS2]NJUM-1
  If [M:ZGOFS2]JANCHO(F)<=0
    MSG="Hay jumbos con ancho=0\Bórrelos de la rejilla"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
  Endif
Next
If [M:ZGOFS2]NLAR<1
  LAR=1000
  [M:ZGOFS2]LLARGO([M:ZGOFS2]NLAR)=LAR
  RSTA=[M:ZGOFS0]STA
  [M:ZGOFS0]STA="1" # Para evitar que se ejecute  AV_LSEL from  SPEZGOFS1
  [M:ZGOFS2]LSEL([M:ZGOFS2]NLAR)    =2
  [M:ZGOFS2]LAGRUPAR([M:ZGOFS2]NLAR)=2
  [M:ZGOFS0]STA=RSTA
  [M:ZGOFS2]NLAR+=1
  Affzo [M:ZGOFS2]50
Endif
If [M:ZGOFS2]NELE<1
#     A borrar  INI
  For F=1 To 4
    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=190
    [M:ZGOFS2]NELE+=1
  Next
  For F=1 To 6
    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=260
    [M:ZGOFS2]NELE+=1
    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=280
    [M:ZGOFS2]NELE+=1
  Next
  For F=1 To 10
    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=320
    [M:ZGOFS2]NELE+=1
  Next
  For F=1 To 12
    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=345
    [M:ZGOFS2]NELE+=1
  Next
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=290
#    [M:ZGOFS2]NELE+=1
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=470
#    [M:ZGOFS2]NELE+=1
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=580
#    [M:ZGOFS2]NELE+=1
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=580
#    [M:ZGOFS2]NELE+=1
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=580
#    [M:ZGOFS2]NELE+=1
#    [M:ZGOFS2]ANCHO([M:ZGOFS2]NELE)=720
#    [M:ZGOFS2]NELE+=1
    Affzo [M:ZGOFS2]10
    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=190
    [M:ZGOFS2]NTIA+=1
    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=250
    [M:ZGOFS2]NTIA+=1
    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=320
    [M:ZGOFS2]NTIA+=1
    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=350
    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=940
#    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=350
#    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=440
#    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=1010
#    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=450
#    [M:ZGOFS2]NTIA+=1
#    [M:ZGOFS2]NANCHO([M:ZGOFS2]NTIA)=490
#    [M:ZGOFS2]NTIA+=1
# A borrar  FIN
Endif
If [M:ZGOFS2]NELE<1
    Affzo [M:ZGOFS2]35
    MSG="No se han indicado ANCHO de bobinas a fabricar\Asegúrese de haber marcado pedidos"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ANCHO(F)<=0
    MSG="Hay anchos de bobinas a fabricar con ancho=0\Bórrelos de la rejilla"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
  Endif
Next
F=func MANDRILES(MND,MND_A)
If F>2
  MSG="Imposible mezclar mas de 2 mandriles en el cálculo, pues tan solo tenemos 2 ejes de salida\" + num$(F) + " Mandriles encontrados " + MND
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  Return
Elsif MND_A<>""
  Call ERREURT(MND_A, 0) From GESECRAN   #0-Informativo, 1-Error
  Return

Endif


Gosub BUSCAR From SPEZGOFS1
Return

$GENERAR_OF
#Onerrgo ERRORES_FIN
Local Integer BOMALT
Local Char TXT(255)(3)
ART=func ARTICULO
Read[F:ITM]ITM0=ART
If fstat<>0
    MSG="No se encontró el articulo "+ART
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
If [M:ZGOFS4]LNGUSA<[M:ZGOFS4]NSUG*[M:ZGOFS4]SLARGOB(0)
    MSG="No hay Materia Prima suficiente, por lo que deberá:\- Disminuir bobinas de pedidos\- De ser posible, marcar mas jumbos a usar\.\Long.necesaria " + num$([M:ZGOFS4]NSUG*[M:ZGOFS4]SLARGOB(0)) +
& " > " + num$([M:ZGOFS4]LNGUSA) + " Long.usada"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
If [M:ZGOFS4]NSUG<=0
    MSG="No hay opción alguna para fabricar\Revise Propuesta OFs y Resumen"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
MSG=func SPEZGOFS4.JUMBOS_SIN_EMPALMAR
If MSG<>""
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    Return
  Endif
Endif
BOMALT=func SPEZGOFS4.GC_EXCEDIDOS
If BOMALT>0
  MSG="Está seguro de generar esta OF\Observe que hay "+num$(BOMALT)+" combinaciones (grupos de corte) que superan la merma indicada"
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    Return
  Endif
Endif
If [M:ZGOFS4]LNGMER>0
  MSG="Observe que hay una merma por longitud de "+num$([M:ZGOFS4]LNGMER)+"\Está seguro de generar esta OF\.\Deberá indicar que se empalmas las bobinas para evitarla"
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    Return
  Endif
Endif
Read [F:ACV]CODACT="MFI"
If fstat<>0
  Call FSTA("ACV") From GLOCK
  Return
Elsif [F:ACV]DIME<[M:ZGOFS4]NGRC
    MSG="El tope actual de lineas de una OF es de "+num$([F:ACV]DIME)+"\Hasta subirlo, imposible generar OF actual de "+num$([M:ZGOFS4]NGRC)+" lineas"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif

Raz TXT
TXT(0)="select BOMALT_0 "
TXT(1)="From BOM "
TXT(2)="Where ITMREF_0='" + ART +"' and BOMALTTYP_0=2"
BOMALT=-1
For (Integer FBOMALT) From BD_TIPO Sql TXT As [MYT]
  BOMALT=FBOMALT
Next
If BOMALT=-1
    MSG="No se ha indicado <<Alternativa estruct.>> de produccion, para el articulo " + ART + "\Revise los datos al final de la pestańa RESUMEN"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
Read [F:ROH]ROH0=[M:ZGOFS4]ROUNUM;[M:ZGOFS4]ROUALT;[M:ZGOFS0]FFCY
If fstat>0
    MSG="No existe <<Ruta + Alternativa>> indicada, para el articulo " + ART + "\Revise los datos al final de la pestańa RESUMEN"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Elsif [F:ROH]USESTA<>2
    MSG="La <<Ruta + Alternativa>> indicada, para el articulo " + ART + "\No está en EXPLOTACION\Revise los datos al final de la pestańa RESUMEN"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
If [M:ZGOFS4]STRDAT=[0/0/0] or [M:ZGOFS4]ENDDAT=[0/0/0]
    MSG="Debe indicar fecha inicio y fin\Revise los datos al final de la pestańa RESUMEN"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Elsif [M:ZGOFS4]STRDAT>[M:ZGOFS4]ENDDAT
    MSG="Fecha inicio NO PUEDE ser mayor que fin\Revise los datos al final de la pestańa RESUMEN"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
Raz MSG
For F=0 To [M:ZGOFS4]NGRC-1
  If ([M:ZGOFS4]GANCHO(F)*[M:ZGOFS4]GLARGO(F)/1000) *[M:ZGOFS4]GCANT(F)<1
    MSG+="GC nş"+num$([M:ZGOFS4]GRUPOC(F))+"  "+num$([M:ZGOFS4]GCANT(F))+" Bobinas de Ancho="+num$([M:ZGOFS4]GANCHO(F))+" Largo="+num$([M:ZGOFS4]GLARGO(F))+"\"
  Endif
Next
If MSG<>""
  MSG="Imposible continuar por haber anchos = 0\Revise los datos al final de la pestańa RESUMEN\"+MSG
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  Return
Endif
If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
Call LECTCA(8,OK) From SUBTCA
If OK=0
    MSG = mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)    # pour import
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif

MSG= "Se va a generar una OF con lo indicado en la pestańa RESUMEN\.\Desea continuar"
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  Return
Endif

#If GUSER<>"ADMIN"
#    MSG="14.09.16  En desarrollo\.\Contactar con Jose Luis Palau"
#    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#  Return
#Endif

FLG_OK=0
Gosub GENERAR_OF_IMP
If FLG_OK
  FLG_OK=0
  Gosub GENERAR_OF_GRABAR_RESTO
  If FLG_OK
    #Asignar materia prima a OF
    #Infbox "Depurar"
    If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [F:ITF] : Endif
    Call ALLOC_OF2("C", 1, SIGUIENTE, 2, 1, "R", FLG_OK) From MFGALL
    If FLG_OK=0
      Call GENERAR_OF_IMPRIMIR(SIGUIENTE,INFO)
      If clalev ([F:MTS]) <= 0:Local File MFGTRS     [F:MTS] : Endif
      Filter [F:MTS] Where MTSTYP=1 and ENAFLG=2 and TRSAUTO=1
      Read [F:MTS] First
      If fstat<>0
        MSG="OF nş "+SIGUIENTE+"\.\Grabada y asignada su materia prima\.\PERO NO SE PUDO CALCULAR coste provisional\Deberá hacerlo mediante opción standard"
        Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
      Else
        Call CALCULA_COSTES([M:ZGOFS0]FFCY,SIGUIENTE) From SPEMFG
        MSG="OF nş "+SIGUIENTE+"\.\Grabada\Asignada su materia prima\Calculado coste provisional"
        Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
      Endif
    Else
      MSG="OF nş "+SIGUIENTE+"\.\Grabada pero NO asignada su materia prima !!!"
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
    Endif
  Endif
Endif
Gosub FIN From GSAISIE
#Onerrgo
Return


Subprog GENERAR_OF_IMPRIMIR(MFGNUMP,INFO)
Value Char MFGNUMP,INFO
If [M:ZGOFS4]RIMP=2
  Call IMPRIMIR_DOCUMENTO_P("GESMFG",MFGNUMP,INFO,[M:ZGOFS4]RDEST,"SPA") From ZIMPRESION
Endif
End



$GENERAR_OF_IMP
  Local Integer F
  Local Decimal QTY,M2_TOT,FACTOR
  # Variables para sacar siguiente nş del contador
  Local Integer STAT
  Local Char SIGUIENTE(GLONVCR)
  #
  Call NUMERO([F:TCA]CODNUM(0),[M:ZGOFS0]FFCY,[M:ZGOFS4]STRDAT,"",SIGUIENTE,STAT) From SUBANM
  If STAT <> 0
    MSG="Imposible generar OF\No se pudo obtener siguiente nş OF\"+[F:TCA]CODNUM(0) + "   STAT="+num$(STAT)
    Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
    Return
  Endif

  # Variables para XML
  Local Char WNOM(20),WJOB(10),WXML(250),WOUT(250),WDIR(250),WFICH(250)

  # Comprobar directorio y crearlo en caso de que no exista
  WDIR="ZIMPEXP\IMPOR"
  TMP=filpath("","","","","",adxmac(0)) +"\" + WDIR
  If filinfo(TMP,7)<0
    Local Integer STAT
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
  Endif
  # Abrir fichero
  WNOM="ZMFG"    #   Modelo de importación
  WJOB = num$(time)
  WXML = WNOM+"_ZGOFS_"+SIGUIENTE+"_"+format$("D:YYYYMMDD",date$)+"_"+WJOB
  WOUT = filpath(WDIR,WXML,"xml")
  Openo WOUT,0 Using [TIF]
  # Inicio
  Call XML_INICIO("UTF") From ZXML
  Call XML_INICIO_NOMBRE(WNOM) From ZXML
  # Volcar rejilla a fichero
  For F=0 To [M:ZGOFS4]NGRC-1
#   FACTOR= arr([M:ZGOFS4]KGSUSA/[M:ZGOFS4]M2USA,0.000001)   # Factor medio de la OF
    FACTOR= [F:ITM]ZFACTOR                                   # S/Acuerda coger el factor del artículo para lo producido, pues es el que se usó en los pedidos
    QTY   = ([M:ZGOFS4]GANCHO(F)*[M:ZGOFS4]GLARGO(F)/1000)   # M2  / Bobina
    M2_TOT= QTY*[M:ZGOFS4]GCANT(F)                           # M2  / LŞ Grupo Corte
#   QTY   = QTY*[F:ITM]ZFACTOR                               # Kgs / Bobina
    QTY   = QTY*FACTOR                                       # Kgs / Bobina
    QTY   = arr(QTY*[M:ZGOFS4]GCANT(F),0.0001)               # Kgs / LŞ Grupo Corte
    Call XML_ABRE_ETIQUETA("D") From ZXML

    Call XML_LINEA("MFI_MFGFCY",[M:ZGOFS0]FFCY)       From ZXML       # Planta
    Call XML_LINEA("MFI_BOMALT",num$(BOMALT))         From ZXML       # Alternativa estruct.
    Call XML_LINEA("MFI_ITMREF",ART)                  From ZXML       # Articulo
    Call XML_LINEA("MFI_STRDAT",format$("D:YYYY[-]MM[-]DD",[M:ZGOFS4]STRDAT)) From ZXML  # Fecha inicio
    Call XML_LINEA("MFI_ENDDAT",format$("D:YYYY[-]MM[-]DD",[M:ZGOFS4]ENDDAT)) From ZXML  # Fecha fin
    Call XML_LINEA("MFI_EXTQTY",num$(QTY))            From ZXML       # Kgs linea Grupo Corte
    Call XML_LINEA("MFI_MFGNUM",SIGUIENTE)            From ZXML       # Nş OF
    Call XML_LINEA("MFI___8",[M:ZGOFS4]ROUNUM)        From ZXML       # Ruta
    Call XML_LINEA("MFI___9",num$([M:ZGOFS4]ROUALT))  From ZXML       # Alternativa
    Call XML_LINEA("MFI___10","C")                    From ZXML       # Código actualiacion    C = CREAR
    Call XML_LINEA("MFI___11","1")                    From ZXML       # Estado de la OF        1 = FIRME
    Call XML_LINEA("MFI_MFGLIN",num$((F+1)*1000))     From ZXML       # Nş linea OF
    Call XML_LINEA("MFI_ZGRPCOR",num$([M:ZGOFS4]GRUPOC(F)))    From ZXML       # Nş Grupo Corte
    Call XML_LINEA("MFI_ZQTYBOB",num$([M:ZGOFS4]GCANT(F)))     From ZXML       # Nş bobinas total
    Call XML_LINEA("MFI_ZBOBCTE",num$([M:ZGOFS4]GCANT(F)-[M:ZGOFS4]GBOBSTK(F)))     From ZXML       # Nş bobinas asignadas a pedidos
    Call XML_LINEA("MFI_ZBOBSTK",num$([M:ZGOFS4]GBOBSTK(F)))   From ZXML       # Nş bobinas stock
    Call XML_LINEA("MFI_ZUBICACTE","GENERAL1")                 From ZXML       # Ubicación bobinas asignadas a pedidos
    Call XML_LINEA("MFI_ZUBICASTK","PTEUBICA")                 From ZXML       # Ubicacion bobinas stock
    Call XML_LINEA("MFI_ZANCHO",num$([M:ZGOFS4]GANCHO(F)))     From ZXML       # Ancho
    Call XML_LINEA("MFI_ZNRANCHO",num$([M:ZGOFS4]GANCHOR(F)))  From ZXML       # Repeticiones Ancho
    Call XML_LINEA("MFI_ZLONGITUD",num$([M:ZGOFS4]GLARGO(F)))  From ZXML       # Largo
    Call XML_LINEA("MFI_ZNTIRADAS",num$([M:ZGOFS4]GLARGOR(F))) From ZXML       # Repeticiones Largo / Tiradas
    Call XML_LINEA("MFI_ZMANDRIL",num$(func MANDRIL([M:ZGOFS4]GANCHO(F),[M:ZGOFS4]GLARGO(F))))     From ZXML       # Mandril
    Call XML_LINEA("MFI_ZFACTOR",num$(FACTOR))                 From ZXML       # Factor medio de la OF  F=KGS/M2
    Call XML_LINEA("MFI_ZFABCOR","true")                       From ZXML       # Para indicar que es una OF de corte
    Call XML_LINEA("MFI_ZSUPERFICIE",num$(M2_TOT))             From ZXML       # M2  / LŞ Grupo Corte
    Call XML_LINEA("MFI_ZIMPLNG",num$([M:ZGOFS4]LNGUSA))       From ZXML       # Total OF fórmula Operacion longitud
    Call XML_LINEA("MFI_ZIMPKGS",num$([M:ZGOFS4]KGSUSA))       From ZXML       # Total OF fórmula Operacion  kgs
    Call XML_LINEA("MFI_ZIMPM2S",num$([M:ZGOFS4]M2USA))        From ZXML       # Total OF Superficie, para materia prima   MFGMAT[F:MFM]
    Call XML_LINEA("MFI_ZAUTOMA","2")                          From ZXML       # Creada automatiacamente  1=NO  2=SI

    Call XML_CIERRA_ETIQUETA("D") From ZXML
  Next
  # Fin
  Call XML_FIN(WNOM) From ZXML
  Openo Using [TIF]   #Cerramos el fichero XML generado
  # Lanzamos importación
  Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
  # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
  WFICH = filpath("ZIMPEXP\IMPOR",WXML,"XML.err")
  If filinfo(WFICH,0) > 0 Then
      MSG= "Hubieron Problemas en la importacion del fichero\"+WXML
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
      Return
  Endif
  Read [F:MFG]MFG0=SIGUIENTE
  If fstat<>0
      MSG= "Avise al programador\La OF nş "+SIGUIENTE+" no existe\A pesar de que no hubieron problemas en la importacion"
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
      Return
  Endif
  FLG_OK=1
Return


$GENERAR_OF_GRABAR_RESTO
  Onerrgo ERRORES_MFG
  # Grabar Pedidos asignados
  Call GRABAR_PED_ASI(SIGUIENTE)
  If GOK=0  :  Return  :  Endif
  # Grabar Lotes
  Call GRABAR_LOTASI(SIGUIENTE,ART)
  If GOK=0  :  Return  :  Endif
  # La asignacion de materia prima se lanza desde codigo       hará al entrar a la ventana y comprobar que la rejilla está vacia
  #Gosub ADD_MATERIAL From SPEMFG2
  FLG_OK=1
  Onerrgo
Return

Subprog GRABAR_LOTASI(MFG,ART)
Value Char MFG,ART
Local Integer F,Q,GC,M
Local Integer JMB(500)  # Para saber cuantos JUMBOS/bobinas se utilizan de Materia Prima.....mínimo una
Raz[F:ZMFL]
#Infbox "Debug    Subprog GRABAR_LOTASI(MFG)"
For F=0 To [M:ZGOFS4]NGRC-1
  If GC<>[M:ZGOFS4]GRUPOC(F)
    GC=[M:ZGOFS4]GRUPOC(F)
    Call MONTAR_ARRAY([M:ZGOFS4]GJUMF(F),JMB) # Contiene el jumbo a usar
    For Q=0 To dim(JMB)-1
      If JMB(Q)>0
        If [M:ZGOFS4]SRESTO(JMB(Q)-1) > 0
          M=2  # Si
        Else
          M=1  # No
        Endif
       [F:ZMFL]MFGNUM    = MFG
       [F:ZMFL]ZGRPCOR   = GC
       [F:ZMFL]MFGLIN    = 0  #  No se usa
       [F:ZMFL]ITMREF    = ART
       [F:ZMFL]STOFCY    = [M:ZGOFS0]FFCY
       [F:ZMFL]STOCOU    = [M:ZGOFS4]STOCOU(JMB(Q)-1)
       [F:ZMFL]LOT       = [M:ZGOFS4]SLOTE(JMB(Q)-1)
       [F:ZMFL]SLO       = [M:ZGOFS4]SSLOTE(JMB(Q)-1)
       [F:ZMFL]ITMREF    = ART
       [F:ZMFL]ZANCHO    = [M:ZGOFS4]SANCHO(JMB(Q)-1)
       [F:ZMFL]ZLONGITUD = [M:ZGOFS4]SLARGO(JMB(Q)-1)
       [F:ZMFL]ZMANDRIL  = [M:ZGOFS4]SMANDRIL(JMB(Q)-1)
       [F:ZMFL]STU       = [M:ZGOFS4]STU(JMB(Q)-1)
       [F:ZMFL]QTYSTUASI = [M:ZGOFS4]QTYSTU(JMB(Q)-1)
       [F:ZMFL]ZQTYSTUREAL=[M:ZGOFS4]QTYSTU(JMB(Q)-1)
       [F:ZMFL]ZNCORTES  =  0  #  No se usa
       [F:ZMFL]ZPROVEEDOR= [M:ZGOFS4]ZPROVEEDOR(JMB(Q)-1)
       [F:ZMFL]ZLONGSOB  = [M:ZGOFS4]SRESTO(JMB(Q)-1)
       [F:ZMFL]ZSOBRANTE = M
       [F:ZMFL]ZFACTOR   = [F:ZMFL]QTYSTUASI*1000 /([F:ZMFL]ZLONGITUD *[F:ZMFL]ZANCHO)
       Write [F:ZMFL]
       If fstat
          GOK=0
          Call FSTA("ZMFL") From GLOCK
          Break 2
       Endif
       Call ECR_TRACE("Lotes "+[F:ZMFL]LOT+" "+[F:ZMFL]SLO+" Kgs "+num$([F:ZMFL]QTYSTUASI)+" Long "+num$([F:ZMFL]ZLONGITUD)+" Long.Sobr " +num$([F:ZMFL]ZLONGSOB),0)   From GESECRAN
      Endif
    Next
  Endif
Next
End


Subprog GRABAR_PED_ASI(MFG)
Value Char MFG
Local Integer F,Q,N,PED(500),BOB(500)
Raz N,PED,BOB
# Recorro la rejilla de grupos de corte
# Infbox "Debug       Subprog GRABAR_PED_ASI"
Raz[F:ZMSQ]
For F=0 To [M:ZGOFS4]NGRC-1
  # Saco todos los pedidos asignados a esta linea de OF, para grabar tantos registros como pedidos haya
  Call MONTAR_ARRAY([M:ZGOFS4]GPEDF(F),PED) # Contiene el nş de fila del grid
  Call MONTAR_ARRAY([M:ZGOFS4]GPEDB(F),BOB) # Contiene el nş de bobinas que se han asignado
  For Q=0 To dim(PED)-1
    If PED(Q)>0
      N+=1
      [F:ZMSQ]MFGNUM     = MFG
      [F:ZMSQ]MFGLIN     = (F+1)*1000
      [F:ZMSQ]MSQLIN     = N
      [F:ZMSQ]SOHNUM     = [M:ZGOFS4]PSOHNUM(PED(Q)-1)
      [F:ZMSQ]SOPLIN     = [M:ZGOFS4]PSOPLIN(PED(Q)-1)
      [F:ZMSQ]SOQSEQ     = [M:ZGOFS4]PSOQSEQ(PED(Q)-1)
      [F:ZMSQ]ZQTYBOBASI = BOB(Q)
      Write [F:ZMSQ]
      If fstat
        GOK=0
        Call FSTA("ZMSQ") From GLOCK  #  Muestra el mensaje del fstat
        Break 2
      Endif
      Call ECR_TRACE("Pedido "+[F:ZMSQ]SOHNUM+" lŞ "+num$([F:ZMSQ]SOPLIN)+" Bob "+num$([F:ZMSQ]ZQTYBOBASI),0)   From GESECRAN
      #JLPR 15_11    S/FJCG: Ya no se modifica la fecha de fabricacion en el pedido al programar se debe hacer al planificar
#      # Actualizo fechas previstas de entrega en  <<cantidades lineas de pedidos  SORDERQ >>
#      Local Date ENDDAT
#      ENDDAT=[M:ZGOFS4]ENDDAT
#      Gosub GUARDAR_PEDASI_ACTUALIZAR_PED_CAB From SPEMFG
#      If GOK=0  :  Break 2  :  Endif
    Endif
  Next
Next
End


Subprog MONTAR_ARRAY(D,R)
Value Char D         #   D viene con elementos de 3 numeros separados por guiones  Ej. 001-005-010
Variable Integer R   #   R integer R(500)
Local Integer F,N
Raz R,N
For F=1 To len(D) Step 4
  R(N)=val(mid$(D,F,3))
  N+=1
Next
End


Funprog MANDRIL(ANC,LAR)
Value Integer ANC,LAR
Local Integer F,M,D
Raz M
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PEDSEL(F)=2 and [M:ZGOFS1]PANCHO(F)=ANC and [M:ZGOFS1]PLARGO(F)=LAR
    M=[M:ZGOFS1]PMANDRIL(F)
    Break
  Endif
Next
# Si ancho no incluido en pedidos, se asume mandril del ancho mas proximo
D=9999
If M=0
  For F=0 To [M:ZGOFS1]NPED-1
    If [M:ZGOFS1]PEDSEL(F)=2  and [M:ZGOFS1]PLARGO(F)=LAR
      If abs([M:ZGOFS1]PANCHO(F)-ANC) < D
        M=[M:ZGOFS1]PMANDRIL(F)
        D=abs([M:ZGOFS1]PANCHO(F)-ANC)
      Endif
    Endif
  Next
Endif
End M

Subprog MOSTRAR_MATERIA_PRIMA_COLOR
Local Integer F
If [M:ZGOFS1]JAGRUPAR=1
  For F=0 To [M:ZGOFS1]NSTO-1
    If [M:ZGOFS1]SLARGO(F)<>[M:ZGOFS1]SLARGOSTK(F) or not func UBICACION_OK([M:ZGOFS1]LOC(F))
      Chgstl [M:ZGOFS1]NSTO(F) With "BACKRED"
    Endif
  Next
Endif
End

#######################################################################################################
# JLPR 17_11_16   S/Acuerdo con Tachi                                                                 #
#     - No se mostraran bobinas que ya esten en otras OF en curso !!!                                 #
#     - No se permite declarar produccion PARCIAL de una OF, es decir, que se producen de una sola vez#
#     - Al asignar, habría que controlar que asignara por la cantidad asignada a la OF, pues ahora lo hace mientras quede
#     -    Ej. OF  donde se necesitan 5000                                                            #
#                  1 bob de  3000 se asigna por 1000, pues los otros 2000 estaban en otra OF          #
#                  1 bob de 32000 se asinga por 4000                                                  #
#          Ahora mismo, al asignar dicha OF X3 haria lo siguiente,  asumiendo que la otra OF está sin asignar
#                 - La bobina de  3000 la asignaria por 3000                                          #
#                 - La bobina de 32000 la asignaria por 2000                                          #
#######################################################################################################
Subprog MOSTRAR_MATERIA_PRIMA(FLG_OK, BD_TIPO,TFILAS_STO)
Variable Integer FLG_OK
Value Char BD_TIPO
Value Integer TFILAS_STO

Local Date FIFO
Local Char CRITERE(250), MSG(250), ART(GLONITM), C(250), D(250),RD(250)
Local Integer F,YN,BOB
Local Decimal QTY
# Código copiado de ZALTRT
#Onerrgo ERRORES_FIN
ART=func ARTICULO
If ART="" and [M:ZGOFS0]FARTINI=[M:ZGOFS0]FARTFIN
  ART=[M:ZGOFS0]FARTINI
Endif
If ART=""
    MSG="No se ha seleccionado pedido alguno"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    End
Endif
#
CRITERE="1=1"
CRITERE -= "& (ITMREF = '"  + ART + "')"
CRITERE -= "& (STOFCY = '"  + [M:ZGOFS0]FFCY + "')"
#Omito control para permitir EMPALMAR bobinas mas cortas y conseguir el largo necesario
#CRITERE -= "& (ZLONGITUD>=" + num$(func LARGO_MINIMO) + ")"

#CRITERE -= "& (ZMANDRIL = " + [M:ZGOFS0]FMANFIN + ")" # El mandril del jumbo nos da igual
#CRITERE -= "& ((QTYSTU - CUMALLQTY) > 0)"
#CRITERE -= "& CUMALLQTY=0"  # Si tiene asignacion, es que está en una OF en curso

Raz C
If [M:ZGOFS1]JUMBO>0
  C="ZANCHO>=" + num$([M:ZGOFS1]JUMBO)
Endif
If [M:ZGOFS1]JUMBOF>0
  If C<>"" :   C+=" & "    :     Endif
  C+="ZANCHO<=" + num$([M:ZGOFS1]JUMBOF)
Endif

If C=""
  For F=0 To [M:ZGOFS1]NJUM-1
    If [M:ZGOFS1]JSEL(F)=2
      If C=""
        C+="ZANCHO=" + num$([M:ZGOFS1]JANCHO(F))
      Else
        C+=" or ZANCHO=" + num$([M:ZGOFS1]JANCHO(F))
      Endif
    Endif
  Next
Endif
If C=""
  MSG="No hay JUMBOS seleccionadas\Imposible mostrar Materia Prima"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End
Endif
CRITERE -= "& (" + C + ")"

#YN = 1 :# By default points on No
#MSG= CRITERE :#vireblc(format$("K:250X", evalue(CRITERE)), 2)
#Call OUINON(MSG, YN) From GESECRAN
#If YN=1
#  end
#Endif

Read [F:ITM]ITM0=ART
#If [F:ITM]STU<>[F:ITM]PUU and [F:ITM]PUUSTUCOE=1
#  MSG="Está seguro de continuar\.\Observe que el articulo " + ART + "\La unidad de STOCK<>COMPRA ("+[F:ITM]STU+"<>"+[F:ITM]PUU+")\Y el coeficiente de conversión es 1\Asumiendo que el precio irá en "
# +
#& [F:ITM]PUU + " multiplicaremos dicho precio por " +[F:ITM]STU +"\lo que implica que el precio " + [F:ITM]PUU +"= al precio "+[F:ITM]STU
#  Call OUINON(MSG, YN) From GESECRAN
#  If YN=1
#    End
#  Endif
#Endif
If [M:ZGOFS1]JAGRUPAR=2
  Filter [F:STO] Where  evalue (CRITERE) Order With "LOT;ZANCHO;ZLONGITUD;ZMANDRIL"
Else
  Filter [F:STO] Where  evalue (CRITERE)
Endif
If rowcount([F:STO])<1
  MSG="No hay JUMBOS del articulo " + ART + "\En los anchos seleccionados"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End
Endif
Call VACIAR_REJILLA_STO("")
Raz RD,BOB,QTY
For [F:STO]
  # Determinar disponible=Stock-Asignado....IMPORTANTE que se asigne la materia prima de una OF, pues de lo contrario NO SE TENDRA EN CUENTA
  # 17.11 Se toma la decisión de no incluir bobinas asignadas a OF en curso. Pero las muestro para que se sepa
  If [M:ZGOFS1]JAGRUPAR=2
    D=[F:STO]LOT+"#"+num$([F:STO]ZANCHO)+"#"+num$([F:STO]ZLONGITUD)+"#"+num$([F:STO]ZMANDRIL)
  Else
    D=num$([M:ZGOFS1]NSTO)
  Endif
  If RD<>D
    Gosub MOSTRAR_MATERIA_PRIMA_D
    RD=D
    If [M:ZGOFS1]NSTO+1>=TFILAS_STO
      MSG="Alcanzado máximo de " + num$(TFILAS_STO+1) + " filas para mostrar materia prima/jumbos\\Ajuste los filtros"
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      RD="##"
      Break
    Else
      [M:ZGOFS1]NSTO+=1
    Endif
  Endif
  #Acumular    Bobinas + Kgs
  BOB+=1
  QTY+=([F:STO]QTYSTU-[F:STO]CUMALLQTY)
Next
RD="FIN"
Gosub MOSTRAR_MATERIA_PRIMA_D
Filter [F:STO]
If [M:ZGOFS1]JAGRUPAR=1
  Sorta [M:ZGOFS1]NSTO [M:ZGOFS1]NSTO Order By [M:ZGOFS1]SANCHO(indice),[M:ZGOFS1]SFIFO(indice),[M:ZGOFS1]SLARGO(indice)
Endif
Affzo [M:ZGOFS1]20
Call TOT_NSTO
FLG_OK=1
#Onerrgo
End

$MOSTRAR_MATERIA_PRIMA_D
If RD="##"
  Return
Elsif RD<>""
  # Pongo los totales de fila anterior
  F=[M:ZGOFS1]NSTO-1
  [M:ZGOFS1]SM2(F)        =[M:ZGOFS1]SM2(F)*BOB
  [M:ZGOFS1]QTYSTU(F)     =QTY       #[F:STO]QTYSTU-[F:STO]CUMALLQTY
  [M:ZGOFS1]SIMPORTE(F)   =[M:ZGOFS1]QTYSTU(F)*[M:ZGOFS1]SPRECIO(F)
  [M:ZGOFS1]SBOB(F)       =BOB
Endif
If RD="FIN"
  Return
Endif
F=[M:ZGOFS1]NSTO
If [F:STO]CUMALLQTY=0 and func UBICACION_OK([F:STO]LOC) and [M:ZGOFS1]JAGRUPAR=1
  [M:ZGOFS1]SSEL(F)       =2
Else
  [M:ZGOFS1]SSEL(F)       =1
Endif
[M:ZGOFS1]SLOTE(F)      =[F:STO]LOT
[M:ZGOFS1]SSLOTE(F)     =[F:STO]SLO
[M:ZGOFS1]SMANDRIL(F)   =[F:STO]ZMANDRIL
[M:ZGOFS1]SANCHO(F)     =[F:STO]ZANCHO
[M:ZGOFS1]QTYSTU(F)     =[F:STO]QTYSTU-[F:STO]CUMALLQTY
[M:ZGOFS1]SLARGOSTK(F)  =[F:STO]ZLONGITUD

[M:ZGOFS1]SLARGO(F)     =arr(([F:STO]ZLONGITUD*[M:ZGOFS1]QTYSTU(F))/[F:STO]QTYSTU,1)
[M:ZGOFS1]SLARGOC(F)    =[M:ZGOFS1]SLARGO(F)
[M:ZGOFS1]SM2(F)        =([M:ZGOFS1]SANCHO(F)*[M:ZGOFS1]SLARGO(F))/1000

[M:ZGOFS1]STU(F)        =[F:ITM]STU
# func COSTE(ART, [F:STO]LOT, [F:STO]SLO, BD_TIPO, FIFO)*[F:ITM]ZFACTOR
# No es necesario aplicar el coeficiente al precio, pues ya lo aplica X3 al guardarlo
# [M:ZGOFS1]SPRECIO(F)    =arr(func ZCOMUN.ART_COSTE([M:ZGOFS0]FFCY,ART,[F:STO]LOT,[F:STO]SLO,FIFO)/[F:ITM]PUUSTUCOE,0.0001)
[M:ZGOFS1]SPRECIO(F)    =arr(func ZCOMUN.ART_COSTE([M:ZGOFS0]FFCY,ART,[F:STO]LOT,[F:STO]SLO,FIFO),0.0001)
[M:ZGOFS1]SIMPORTE(F)   =[M:ZGOFS1]QTYSTU(F)*[M:ZGOFS1]SPRECIO(F)
[M:ZGOFS1]SFIFO(F)      =FIFO
[M:ZGOFS1]LOC(F)        =[F:STO]LOC
[M:ZGOFS1]ZNCORTES(F)   =[F:STO]ZNCORTES
[M:ZGOFS1]ZPROVEEDOR(F) =[F:STO]ZPROVEEDOR
[M:ZGOFS1]STOCOU(F)     =[F:STO]STOCOU
[M:ZGOFS1]ZFACTOR(F)    =[F:STO]ZFACTOR

If [F:STO]CUMALLQTY>0
[M:ZGOFS1]ASIGNADO(F)   =func BOBINAS_ASIGNADAS([F:STO]STOCOU,[F:STO]ZLONGITUD/[F:STO]QTYSTU)
Endif
If [M:ZGOFS1]JAGRUPAR=2
[M:ZGOFS1]SSLOTE(F)     =""
[M:ZGOFS1]STOCOU(F)     =0
Endif
Raz BOB,QTY
Return

Funprog UBICACION_OK(LOC)
Value Char LOC
Local Integer OK
OK=1
Case LOC
When "DEVOLUCI"
OK=0
When "PTEREVIS"
OK=0
When "0GENERAL"
OK=0
When "GENERAL"
OK=0
When "GENERAL1"
OK=0
Endcase
End OK

Funprog COSTE(ITM,LOT,SLOT,BD_TIPO,FIFO)
Value Char ITM,LOT,SLOT,BD_TIPO
Variable Date FIFO
Local Decimal COSTE_UNITARIO
COSTE_UNITARIO=func ZCOMUN.ART_COSTE([M:ZGOFS0]FFCY,ITM,LOT,SLOT,FIFO)
End COSTE_UNITARIO


$MOSTRAR_PEDIDOS
Local Char MSG(255),TXT(255)(13),W(255)(4)
Local Integer F,BOB
Local Decimal QTYKGS
Raz MSG,TXT,W,F
#Onerrgo ERRORES_FIN


#Infbox "Debugger"
#Dbgaff
# SORDER .ORDSTA<>2 Estado No saldado
# SORDER .INVSTA =1 Facturado NO            and SOH.INVSTA_0<>2
# SORDERQ.SOQSTA<>3 Estado No saldado
# SORDERQ.INVFLG =1 Facturado NO
# SORDERQ.DEMSTA =1 Estado orden Firme
# (Cantidad pedido - cantidad asignada) >= peso de una bobina

W(0)+="and SOH.SALFCY_0='" + [M:ZGOFS0]FFCY + "' "
If [M:ZGOFS0]FOF=1
  W(0)+="and SOH.ORDSTA_0<>2 and SOQ.INVFLG_0<>2 and SOQ.DEMSTA_0=1 and SOQ.SOQSTA_0<>3 and SOQ.ZCORTE_0=2 "
  W(0)+="and SOQ.QTY_0-SOQ.ALLQTY_0>=SOQ.QTY_0/SOQ.ZQTYBOB_0 "
Endif
If [M:ZGOFS0]FARTINI<>""
  W(0)+="and SOQ.ITMREF_0>='" + [M:ZGOFS0]FARTINI + "' "
Endif
If [M:ZGOFS0]FARTFIN<>""
  W(0)+="and SOQ.ITMREF_0<='" + [M:ZGOFS0]FARTFIN + "' "
Endif
If [M:ZGOFS0]FFECINI<>[0/0/0]
  W(3)+="and SOQ.SHIDAT_0>='" + format$("D:YYYYMMDD",[M:ZGOFS0]FFECINI) + "' "
Endif
If [M:ZGOFS0]FFECFIN<>[0/0/0]
  W(3)+="and SOQ.SHIDAT_0<='" + format$("D:YYYYMMDD",[M:ZGOFS0]FFECFIN) + "' " #SOH.DEMDLVDAT_0  #  SOH.EXTDLVDAT_0
Endif
If [M:ZGOFS0]FFPDINI<>[0/0/0]
  W(3)+="and SOH.ORDDAT_0>='" + format$("D:YYYYMMDD",[M:ZGOFS0]FFPDINI) + "' "
Endif
If [M:ZGOFS0]FFPDFIN<>[0/0/0]
  W(3)+="and SOH.ORDDAT_0<='" + format$("D:YYYYMMDD",[M:ZGOFS0]FFPDFIN) + "' "
Endif
If [M:ZGOFS0]FCTEINI<>""
  W(1)+="and SOH.BPCORD_0>='" + [M:ZGOFS0]FCTEINI + "' "
Endif
If [M:ZGOFS0]FCTEFIN<>""
  W(1)+="and SOH.BPCORD_0<='" + [M:ZGOFS0]FCTEFIN + "' "
Endif
If [M:ZGOFS0]FMANFIN>0
  W(1)+="and SOQ.ZMANDRIL_0=" + num$([M:ZGOFS0]FMANFIN) + " "
Endif
If [M:ZGOFS0]FANCINI>0
  W(1)+="and SOQ.ZANCHO_0>=" + num$([M:ZGOFS0]FANCINI) + " "
Endif
If [M:ZGOFS0]FANCFIN>0
  W(1)+="and SOQ.ZANCHO_0<=" + num$([M:ZGOFS0]FANCFIN) + " "
Endif
If [M:ZGOFS0]FLONINI>0
  W(1)+="and SOQ.ZLONGITUD_0>=" + num$([M:ZGOFS0]FLONINI) + " "
Endif
If [M:ZGOFS0]FLONFIN>0
  W(1)+="and SOQ.ZLONGITUD_0<=" + num$([M:ZGOFS0]FLONFIN) + " "
Endif
If [M:ZGOFS0]FPEDIDO<>""
  W(1)+="and SOH.SOHNUM_0='" + [M:ZGOFS0]FPEDIDO + "' "
Endif
# 10_11_16 JLPR S/Tachi mostrar en OF SHIDAT_0 en lugar de EXTDLVDAT_0
W(2)+="SOH.SOHNUM_0,SOH.ORDDAT_0,SOQ.SHIDAT_0,SOH.BPCORD_0,SOQ.SOPLIN_0,SOQ.SOQSEQ_0,SOQ.ITMREF_0,SOQ.ZANCHO_0,"
W(2)+="SOQ.ZLONGITUD_0,SOQ.ZMANDRIL_0,SOQ.ZQTYBOB_0,SOP.NETPRI_0,SOP.SAU_0,SOQ.QTY_0,SOQ.ALLQTY_0"
TXT(0)="select " + W(2)+" "
TXT(1)="from SORDER SOH inner join SORDERQ SOQ  on SOH.SOHNUM_0=SOQ.SOHNUM_0 INNER JOIN SORDERP SOP ON SOH.SOHNUM_0=SOP.SOHNUM_0 and SOQ.SOPLIN_0=SOP.SOPLIN_0 "
TXT(2)="where 1=1 " + W(0)
TXT(3)=W(1)
TXT(4)=W(3)
#TXT(0)="select " + W(2)+", count(ST.VCRLIN_0) "
#TXT(1)="from SORDER SOH inner join SORDERQ SOQ  on SOH.SOHNUM_0=SOQ.SOHNUM_0 INNER JOIN SORDERP SOP ON SOH.SOHNUM_0=SOP.SOHNUM_0 and SOQ.SOPLIN_0=SOP.SOPLIN_0 LEFT JOIN ZMFGSOQ ZMSQ ON
# SOQ.SOHNUM_0=Z"
#&  + "MSQ.SOHNUM_0 AND SOQ.SOPLIN_0=ZMSQ.SOPLIN_0 "
#TXT(2)="left join STOALL ST on SOQ.SOHNUM_0=ST.VCRNUM_0 and SOQ.SOPLIN_0=ST.VCRLIN_0 "
#TXT(3)="where ZMSQ.SOHNUM_0 IS null and SOQ.QTY_0-SOQ.ALLQTY_0>=SOQ.QTY_0/SOQ.ZQTYBOB_0 " + W(0)
#TXT(4)=W(1)
#TXT(5)="group by "+W(2)+" "
#TXT(6)="UNION ALL "
#TXT(7)="select " + W(2)+", sum(ZMSQ.ZQTYBOBASI_0) "
#TXT(8)="From SORDER SOH INNER JOIN SORDERQ SOQ  ON SOH.SOHNUM_0=SOQ.SOHNUM_0 INNER JOIN SORDERP SOP ON SOH.SOHNUM_0=SOP.SOHNUM_0 and SOQ.SOPLIN_0=SOP.SOPLIN_0 INNER JOIN ZMFGSOQ ZMSQ ON
# SOQ.SOHNUM_0="
#&  + "ZMSQ.SOHNUM_0 and SOQ.SOPLIN_0=ZMSQ.SOPLIN_0 "
#TXT(9)="where ZMSQ.ZQTYBOBASI_0<SOQ.ZQTYBOB_0 " + W(0)
#TXT(10)=W(1)
#TXT(11)="group by "+W(2)+" "
#TXT(12)="having sum(ZMSQ.ZQTYBOBASI_0)<SOQ.ZQTYBOB_0"
##TXT(12)="Order By ITMREF_0, ZMANDRIL_0, SOH.SOHNUM_0, SOQ.SOPLIN_0"# ,ZLONGITUD_0,ZANCHO_0"

#If GUSER="ADMIN"
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  Return
#Endif
#Endif

For (Char FSOHNUM(GLONVCR),Date FORDDAT,Date FDEMDLVDAT,Char FBPCORD(GLONBPR),Integer FSOPLIN,Integer FSOQSEQ,Char FITMREF(GLONITM),Integer FZANCHO,Integer FZLONGITUD,Integer FMANDRIL,Decimal FZQTYBOB
& ,Decimal FNETPRI,Char FSAU,Decimal FQTY,Decimal FZQTYBOBASI) From BD_TIPO Sql TXT As [MYT]
  If [M:ZGOFS0]FOF=1
    # Por cada linea de pedido determinar  Bobinas en OF en curso, Asignadas y Enviadas
    BOB=FZQTYBOB-func BOBINAS_EN_CURSO(FSOHNUM,FSOPLIN,BD_TIPO,"")
    QTYKGS=arr((BOB*FQTY)/FZQTYBOB,0.0001)
  Else
    BOB=FZQTYBOB
    QTYKGS=FQTY
  Endif
  If BOB>0
    F=[M:ZGOFS1]NPED
    [M:ZGOFS1]PITM(F)     =FITMREF
    [M:ZGOFS1]PSOHNUM(F)  =FSOHNUM
    [M:ZGOFS1]PFECPED(F)  =FORDDAT
    [M:ZGOFS1]PFECENT(F)  =FDEMDLVDAT
    [M:ZGOFS1]PCTE(F)     =FBPCORD
    [M:ZGOFS1]PSOPLIN(F)  =FSOPLIN
    [M:ZGOFS1]PSOQSEQ(F)  =FSOQSEQ
    [M:ZGOFS1]PANCHO(F)   =FZANCHO
    [M:ZGOFS1]PLARGO(F)   =FZLONGITUD
    [M:ZGOFS1]PM2(F)      =FZANCHO*FZLONGITUD/1000
    [M:ZGOFS1]PMANDRIL(F) =FMANDRIL
    [M:ZGOFS1]PBOBINAS(F) =BOB #FZQTYBOB-FZQTYBOBASI
    [M:ZGOFS1]PBOBINASC(F)=[M:ZGOFS1]PBOBINAS(F)
    [M:ZGOFS1]PM2LIN(F)   =[M:ZGOFS1]PM2(F)*[M:ZGOFS1]PBOBINAS(F)
    [M:ZGOFS1]ZQTYKG(F)   =QTYKGS
    [M:ZGOFS1]PPRECIO(F)  =FNETPRI
    [M:ZGOFS1]SAU(F)      =FSAU
    If [M:ZGOFS0]FOF=1
      [M:ZGOFS1]POF(F)      =func PEDIDO_EN_OF(FSOHNUM,FSOPLIN,BOB,FZQTYBOB,F,BD_TIPO)
    Endif
    If [M:ZGOFS0]FARTINI<>"" and [M:ZGOFS0]FARTINI=[M:ZGOFS0]FARTFIN and [M:ZGOFS0]FOF=1
      [M:ZGOFS1]PEDSEL(F) =2
    Endif
    Case FSAU
    When "KG"
      [M:ZGOFS1]PIMPORTE(F) =QTYKGS              * [M:ZGOFS1]PPRECIO(F)
    When "M2"
      [M:ZGOFS1]PIMPORTE(F) =[M:ZGOFS1]PM2LIN(F) * [M:ZGOFS1]PPRECIO(F)
#      If QTYKGS<>[M:ZGOFS1]PM2LIN(F)
#        Infbox "Revise pedido "+FSOHNUM+" "+num$(FSOPLIN)+"  M2 pedido "+ num$(FQTY)+" <> "+num$([M:ZGOFS1]PM2LIN(F))+ " M2 calculo"
#      Endif
    When Default
      Infbox "Revise pedido "+FSOHNUM+" "+num$(FSOPLIN)+" Unidad venta NO contemplada ("+ FSAU +")"
    Endcase
    [M:ZGOFS1]PBOBSTK(F)  =func STOCK_ART([M:ZGOFS0]FFCY,FITMREF,FZLONGITUD,FZANCHO,FMANDRIL,1)
    [M:ZGOFS1]PBOBPDT(F)  =func STOCK_OF_EN_CURSO([M:ZGOFS0]FFCY, FITMREF,FZLONGITUD,FZANCHO,FMANDRIL,BD_TIPO)
    If [M:ZGOFS1]PBOBPDT(F)>0
      [M:ZGOFS1]POF(F)    =func BOBINAS_EN_OF(F,BD_TIPO)+[M:ZGOFS1]POF(F)
    Endif

    If [M:ZGOFS1]NPED+1>=TFILAS_PED
      MSG="FALTAN DATOS !!!\Alcanzado máximo de " + num$(TFILAS_PED+1) + " filas para mostrar pedidos\.\Ajuste los filtros"
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      Break
    Else
      [M:ZGOFS1]NPED+=1
    Endif
  Endif
Next
If [M:ZGOFS1]NPED<1
    MSG="No se han encontrado lineas marcadas como <<Corte>>, pendientes de fabricar\.\Ajuste los filtros"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
Else
  # Ordeno rejilla
  Sorta [M:ZGOFS1]NPED [M:ZGOFS1]NPED Order By [M:ZGOFS1]PITM(indice),[M:ZGOFS1]PLARGO(indice),[M:ZGOFS1]PANCHO(indice),[M:ZGOFS1]PSOHNUM(indice),[M:ZGOFS1]PSOPLIN(indice)
  Affzo [M:ZGOFS1]10
  Call TOT_NPED
Endif
FLG_OK=1
#Onerrgo
Return

$COMPROBACIONES
If [M:ZGOFS0]FFCY=""
    MSG="Se debe indicar una planta"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
If [M:ZGOFS0]FOF=2 and ([M:ZGOFS0]FARTINI=""  or ([M:ZGOFS0]FPEDIDO="" and ([M:ZGOFS0]FANCINI=0 or [M:ZGOFS0]FLONINI=0)))
    MSG="Debe indicar:\- Un articulo\- Un nş de pedido  ó  Un Largo y Ancho\.\en caso de marcar la opcion\.\Mostrar OF en las que está incluido"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Return
Endif
FLG_OK=1
#Onerrgo
Return

$BORRA_PANTALLA
Call VACIAR_REJILLA_PED("")
Call VACIAR_REJILLA_STO("")
Raz [M:ZGOFS0],[M:ZGOFS1]
Gosub ESTADO
Affzo [M:ZGOFS0]
Affzo [M:ZGOFS1]
Return

$ESTADO
Chgfmt [M:ZGOFS0]FMANINI With "-"
Chgfmt [M:ZGOFS0]STA     With "-"
Chgfmt [M:ZGOFS0]NADA1   With "-"
Chgfmt [M:ZGOFS2]SAVISOPDTE    With "-"
Chgfmt [M:ZGOFS2]SAVISORESTO   With "-"
Chgfmt [M:ZGOFS2]SLARGOT       With "-"
Return



#===================================
#Procedimientos y funciones PROPIOS
#===================================

Funprog STOCK_OF_EN_CURSO(FCY,ART,LNG,ANC,MAN,BD_TIPO)
Value Char FCY,ART,BD_TIPO
Value Integer LNG,ANC,MAN
Local Integer Q
Local Char TXT(255)(3)
# ITMSTA    1=En espera    2=En curso     3=Saldada    4=Excluida
Raz TXT
TXT(0)="select sum(ZBOBSTK_0) "
TXT(1)="from MFGITM "
TXT(2)="where ITMSTA_0<3 and ZBOBSTK_0>0 and MFGFCY_0='"+FCY+"' and ITMREF_0='"+ART+"' and ZLONGITUD_0="+num$(LNG)+" and ZANCHO_0="+num$(ANC)+" and ZMANDRIL_0="+num$(MAN)
For (Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
  Q=FBOB
Next
End Q

Funprog STOCK_ART(FCY,ART,LNG,ANC,MAN,TIPO)
Value Char FCY,ART
Value Integer LNG,ANC,MAN,TIPO    #  1->Disponible (Fisico-Asignado), 2->Fisico
Local Integer Q
Local Char CRITERE(250)
CRITERE="1=1"
CRITERE -= "& (STOFCY = '"  + FCY + "')"
CRITERE -= "& (ITMREF = '"  + ART + "')"
CRITERE -= "& (ZLONGITUD=" + num$(LNG) + ")"
CRITERE -= "& (ZANCHO="    + num$(ANC) + ")"
CRITERE -= "& (ZMANDRIL= " + num$(MAN) + ")"
If TIPO=1
  CRITERE -= "& (CUMALLQTY<=0)"
Endif
# Cada registro en STOCK corresponde a una bobina
# Si hemos asignado algo, entonces esa bobina ya no corresponde con el Largo solicitado, por eso preguntamos por CUMALLQTY<=0
Filter [F:STO] Where  evalue (CRITERE)
Q=rowcount([F:STO])
Filter [F:STO]
End Q



Funprog PEDIDO_EN_OF(FSOHNUM,FSOQLIN,BOB,BOBPED,F,BD_TIPO)
Value Char FSOHNUM,BD_TIPO
Value Integer FSOQLIN,BOB,BOBPED,F
Local Char TXT(255)(5),TMP(255)
Local Integer TBOB
Raz TXT,TMP,TBOB
TXT(0)="select MFGNUM_0,sum(ZQTYBOBASI_0) "
TXT(1)="from ZMFGSOQ "
TXT(2)="where SOHNUM_0='"+FSOHNUM+"' and SOPLIN_0=" + num$(FSOQLIN)+" "
TXT(3)="group by MFGNUM_0 "
TXT(4)="order by MFGNUM_0"
For (Char FMFG(GLONVCR), Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
  If TMP<>""
    TMP+="#"
  Endif
  TMP+=num$(FBOB)+"x"+FMFG
  TBOB+=FBOB
Next
If TBOB+BOB>BOBPED
  If [M:ZGOFS0]FOF=2
    TMP="AVISO Bobinas_OF_curso + PdteCorte > Pedido ("+num$(TBOB)+"+"+num$(BOB)+">"+num$(BOBPED)+") Probablemente esten en stock o asignadas a otro pedido" + TMP
  Else
    TMP+="AVISO Bobinas_OF_curso + PdteCorte > Pedido ("+num$(TBOB)+"+"+num$(BOB)+">"+num$(BOBPED)+") Probablemente esten en stock o asignadas a otro pedido"
  Endif
Endif
End TMP

Funprog BOBINAS_ASIGNADAS(STOCOU_P,COE_LNG)
Value Decimal STOCOU_P,COE_LNG
Local Decimal TKGS
Local Char    OFS(255),RNUM(GLONVCR)
Raz OFS,TKGS,RNUM
If !clalev([F:WSTA])      :  Local File STOALL     [F:WSTA]  : Endif
Filter [F:WSTA]
Filter [F:WSTA] Where [F:WSTA]STOCOU=STOCOU_P Order By VCRNUM
For [F:WSTA]
  If RNUM<>[F:WSTA]VCRNUM
    Gosub BOBINAS_ASIGNADAS_TOT
    RNUM=[F:WSTA]VCRNUM
  Endif
  TKGS+=[F:WSTA]QTYSTU
Next
Gosub BOBINAS_ASIGNADAS_TOT
End OFS

$BOBINAS_ASIGNADAS_TOT
If TKGS>0
  If OFS<>""   OFS+="#"   Endif
  OFS+= RNUM+"("+num$(arr(TKGS*COE_LNG,1))+" Long)"+"("+num$(TKGS)+" Kgs)"
Endif
Raz TKGS
Return

Funprog BOBINAS_EN_OF(F,BD_TIPO)
Value Integer F
Value Char BD_TIPO
Local Char TXT(255)(12),OFS(255)
Raz OFS,TXT
TXT(0)="select MFGNUM_0,sum(ZBOBSTK_0) "
TXT(1)="from MFGITM "
TXT(2)="where ITMSTA_0<3 and ZBOBSTK_0>0 and MFGFCY_0='"+[M:ZGOFS0]FFCY+"' and ITMREF_0='"+[M:ZGOFS1]PITM(F)+"' "
TXT(3)="and ZLONGITUD_0="+num$([M:ZGOFS1]PLARGO(F))+" and ZANCHO_0="+num$([M:ZGOFS1]PANCHO(F))+" and ZMANDRIL_0="+num$([M:ZGOFS1]PMANDRIL(F))+" "
TXT(4)="group by MFGNUM_0"
For (Char FMFG(GLONVCR),Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
  OFS+=num$(FBOB)+"x"+FMFG+"#"
Next
End OFS

Funprog BOBINAS_EN_CURSO(PED,LIN,BD_TIPO,OF)
Value Char PED,BD_TIPO,OF
Value Integer LIN
Local Integer BOB
Local Char TXT(255)(12)
Raz BOB,TXT
TXT(0)="select "
TXT(1)="isnull((select sum(ZP.ZQTYBOBASI_0) from MFGITM MI inner join ZMFGSOQ ZP on MI.MFGNUM_0=ZP.MFGNUM_0 and MI.MFGLIN_0=ZP.MFGLIN_0 where MI.ITMSTA_0<3 and MI.MFITRKFLG_0<5 "
If OF<>""
  TXT(2)="and MI.MFGNUM_0<>'"+OF+"' "
Endif
TXT(2)+="and ZP.SOHNUM_0='"+PED+"' and ZP.SOPLIN_0="+num$(LIN)+"),0) as BobEnOF, "
TXT(3)="isnull((select count(VCRLIN_0) from STOALL where VCRTYP_0=2 and VCRNUM_0='"+PED+"' and VCRLIN_0="+num$(LIN)+"),0) as BobAsig, "
TXT(4)="isnull((select sum(ZQTYBOB_0)  from SDELIVERYD where VCRNUMORI_0='"+PED+"' and VCRLINORI_0="+num$(LIN)+" ),0) as BobServ"
For (Decimal FBOBOFS, Decimal FBOBASI, Decimal FBOBSER) From BD_TIPO Sql TXT As [MYT]
  BOB=FBOBOFS+FBOBASI+FBOBSER
Next
End BOB

Funprog HAY_MAS_JUMBOS(ANC)
Value Integer ANC
Local Integer F
OK=0
For F=0 To [M:ZGOFS1]NSTO-1
  If [M:ZGOFS1]SSEL(F)=2 and [M:ZGOFS1]SANCHO(F)=ANC
    OK=1
    Break
  Endif
Next
End OK

Subprog MOSTRAR_ANCHOS_A (ART)
Value Char ART
Local Integer F
Local Char TXT(255)(5),BD_TIPO(1)
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
Raz [M:ZGOFS2]NTIA,F
Effzo [M:ZGOFS2]35
Raz TXT
TXT(0)="select distinct N1_0 "
TXT(1)="from ATABDIV "
TXT(2)="where NUMTAB_0=6004 and A1_0='"+ART+"'"
#If clalev([F:ADI])<=0    :  Local File ATABDIV   [F:ADI]  : Endif
#Filter [F:ADI] Where evalue ("NUMTAB=6004 & A1(0)=ART") # Order By N1(0)
#For [F:ADI]
For (Decimal FLANCHO) From BD_TIPO Sql TXT As [MYT]
  F=[M:ZGOFS2]NTIA
  [M:ZGOFS2]NANCHO(F)   = FLANCHO #[F:ADI]N1(0)
  [M:ZGOFS2]NSEL(F  )   = 1#2
  [M:ZGOFS2]NTIA+=1
Next
#Filter [F:ADI]
Sorta [M:ZGOFS2]NTIA [M:ZGOFS2]NTIA Order By [M:ZGOFS2]NANCHO(indice)
Affzo [M:ZGOFS2]35
End



Funprog ARTICULO
Local Char ART(GLONITM)
Local Integer F
Raz ART
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PEDSEL(F)=2
    ART=[M:ZGOFS1]PITM(F)
    Break
  Endif
Next
End ART

Funprog LARGO_MINIMO
Local Integer M,F
M=0
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PLARGO(F)<M or M=0
    M=[M:ZGOFS1]PLARGO(F)
  Endif
Next
End M


Subprog LEER_JUMBOS
Local Integer F
Raz [M:ZGOFS1]NJUM,F
Effzo [M:ZGOFS1]35  # Jumbos
If clalev([F:ADI])<=0    :  Local File ATABDIV   [F:ADI]  : Endif
Filter [F:ADI] Where evalue ("NUMTAB=6005") # Order By N1(0)
For [F:ADI]
  F=[M:ZGOFS1]NJUM
  [M:ZGOFS1]JSEL(F)     = 1 #2
  [M:ZGOFS1]JANCHO(F)   = [F:ADI]N1(0)
  [M:ZGOFS1]NJUM+=1
Next
Filter [F:ADI]
Sorta [M:ZGOFS1]NJUM [M:ZGOFS1]NJUM Order By [M:ZGOFS1]JANCHO(indice)
Affzo [M:ZGOFS1]35
#
[M:ZGOFS1]JUMBO=1680
Affzo [M:ZGOFS1]JUMBO
[M:ZGOFS1]JUMBOF=2000
Affzo [M:ZGOFS1]JUMBOF
End

Subprog VACIAR_REJILLA_PED(FLD)
Value Char FLD
Raz [M:ZGOFS1]NPED  # Pedidos
Effzo [M:ZGOFS1]10
Raz [M:ZGOFS1]TM2, [M:ZGOFS1]TBOBINA, [M:ZGOFS1]TIMPORTE, [M:ZGOFS1]TLIN
Affzo [M:ZGOFS1]TM2
Affzo [M:ZGOFS1]TBOBINA
Affzo [M:ZGOFS1]TIMPORTE
Affzo [M:ZGOFS1]TLIN
Call VACIAR_REJILLA_STO("")
End

Subprog VACIAR_REJILLA_STO(FLD)
Value Char FLD
# Rejilla stock
Raz   [M:ZGOFS1]NSTO  # Stock
Effzo [M:ZGOFS1]20
Raz [M:ZGOFS1]TM2MP, [M:ZGOFS1]TBOBINAMP, [M:ZGOFS1]TIMPORTEP, [M:ZGOFS1]TLARGOMP
# Rejilla anchos jumbos a usar
Raz   [M:ZGOFS2]NJUM #,[M:ZGOFS1]JUMBO,[M:ZGOFS1]JUMBOF
Effzo [M:ZGOFS2]5
#Affzo [M:ZGOFS1]JUMBO
#Affzo [M:ZGOFS1]JUMBOF
# Cálculos
Call VACIAR_CALCULOS From SPEZGOFS1
End


Subprog TOT_NSTO
Local Integer F,RANC(2),E,TLNG
Local Decimal TM2MP,TBOBMP,TLARMP,TIMPP
Raz TM2MP,TBOBMP,TLARMP,TIMPP,RANC,TLNG
Call BORRAR_JUMBOS
#Infbox "debug Materia prima"
For F=0 To [M:ZGOFS1]NSTO-1
  #Acumulo los seleccionados
  If [M:ZGOFS1]SSEL(F)=2
    TM2MP+ =[M:ZGOFS1]SM2(F)
    TLARMP+=[M:ZGOFS1]SLARGO(F)
    TIMPP+ =[M:ZGOFS1]SIMPORTE(F)
    # Se asume que se empalman todos los marcados << de un mismo ancho >>, en una sola bobina
    If [M:ZGOFS1]EMPALMAR(F)<>2
      TBOBMP+=1
    Else
      If RANC(0)<>[M:ZGOFS1]SANCHO(F)
        Gosub TOT_NSTO_EMPALME
        RANC(0)=[M:ZGOFS1]SANCHO(F)
        TBOBMP+=1
      Endif
      TLNG+=[M:ZGOFS1]SLARGO(F)
    Endif
    #Ańado Ancho JUMBOS a usar
    If RANC(1)<>[M:ZGOFS1]SANCHO(F)
      RANC(1)=[M:ZGOFS1]SANCHO(F)
      E=[M:ZGOFS2]NJUM
      [M:ZGOFS2]JANCHO(E)   =[M:ZGOFS1]SANCHO(F)
      [M:ZGOFS2]JCOMBINAR(E)=1#2
      [M:ZGOFS2]JMERMAP(E)  =3.5
      [M:ZGOFS2]JMERMAC(E)  =int([M:ZGOFS2]JANCHO(E)*([M:ZGOFS2]JMERMAP(E)/100)+0.5)
      [M:ZGOFS2]NJUM+=1
    Endif
  Endif
Next
Gosub TOT_NSTO_EMPALME
[M:ZGOFS1]TM2MP    =TM2MP
[M:ZGOFS1]TBOBINAMP=TBOBMP
[M:ZGOFS1]TIMPORTEP=TIMPP
[M:ZGOFS1]TLARGOMP =TLARMP
Affzo [M:ZGOFS1]TM2MP
Affzo [M:ZGOFS1]TBOBINAMP
Affzo [M:ZGOFS1]TIMPORTEP
Affzo [M:ZGOFS1]TLARGOMP
Sorta [M:ZGOFS2]NJUM [M:ZGOFS2]NJUM Order By [M:ZGOFS2]JANCHO(indice)#,[M:ZGOFS2]JLARGO(indice)
Affzo [M:ZGOFS2]5
If [M:ZGOFS4]NCTE>0
  Call RESUMEN From SPEZGOFS4
Endif
End

$TOT_NSTO_EMPALME
If RANC(0)>0
  For A=0 To [M:ZGOFS1]NSTO-1
    If [M:ZGOFS1]SANCHO(A)=RANC(0)
      If [M:ZGOFS1]SSEL(A)=2 and [M:ZGOFS1]EMPALMAR(A)=2
        [M:ZGOFS1]SLARGOC(A)=TLNG
      Else
        [M:ZGOFS1]SLARGOC(A)=[M:ZGOFS1]SLARGO(A)
      Endif
    Endif
  Next
Endif
TLNG=0
Return

Subprog TOT_NPED_COL
Local Integer F,X
Local Char RITM(GLONITM)
Raz X,RITM
# Invertir colores cuando cambie articulo....compo papel pijama
For F=0 To [M:ZGOFS1]NPED-1
  If RITM<>[M:ZGOFS1]PITM(F)
    RITM=[M:ZGOFS1]PITM(F)
    If X=0
      X=1
    Else
      X=0
    Endif
  Endif
  If X=0
    Chgstl [M:ZGOFS1]NPED(F) With "BACKGREEN" #"CAZ"
  Endif
  If instr(1,[M:ZGOFS1]POF(F),"ERROR")>0
    Chgstl [M:ZGOFS1]NPED(F) With "BACKRED"
  Endif
Next
# Poner Art en naranja cuando se haya incluido linea en OFs
# Poner Bobinas amarillo si hay bobinas Stk
For F=0 To [M:ZGOFS1]NPED-1
 If [M:ZGOFS1]POF(F)<>""
    If [M:ZGOFS0]FOF=1
      Chgstl [M:ZGOFS1]PITM(F) With "BACKORANGE"
      Chgstl [M:ZGOFS1]POF(F)  With "BACKORANGE"
    Else
      Chgstl [M:ZGOFS1]PITM(F) With "BACKYELLOW"
      Chgstl [M:ZGOFS1]POF(F)  With "BACKYELLOW"
    Endif
 Endif
 If [M:ZGOFS1]PBOBSTK(F)+[M:ZGOFS1]PBOBPDT(F) >0
    Chgstl [M:ZGOFS1]PBOBSTK(F) With "BACKYELLOW"
    Chgstl [M:ZGOFS1]PBOBPDT(F) With "BACKYELLOW"
 Endif
Next
Affzo [M:ZGOFS1]10
End

Subprog LARGO_COL
Local Integer F
For F=0 To [M:ZGOFS2]NLAR-1
  If [M:ZGOFS2]LSEL(F)=1
    Chgstl [M:ZGOFS2]NLAR(F) With ""
  Else
    Chgstl [M:ZGOFS2]NLAR(F) With "AEXPEXC1"
  Endif
Next
Affzo [M:ZGOFS2]50
End

Subprog BORRAR_JUMBOS
# Borro rejilla JUMBOS a usar
Effzo [M:ZGOFS2]5
Raz   [M:ZGOFS2]NJUM
Affzo [M:ZGOFS2]5
#Effzo [M:ZGOFS3]5
#Raz   [M:ZGOFS3]NLNG
#Affzo [M:ZGOFS3]5
End

Subprog TOT_NPED
Local Integer F,EA,EL,L,Q,TBOB,TLIN,RLAR,LAR
Local Decimal TM2,TIMP
Local Char ART(GLONITM),RSTA(1),LA(10),RLA(10)
Raz TM2,TBOB,TIMP,TLIN,RLAR,RLA,Q,LAR
#Borro rejilla Anchos y Largos
Effzo [M:ZGOFS2]10
Effzo [M:ZGOFS2]50
Effzo [M:ZGOFS3]5
Raz [M:ZGOFS2]NELE,[M:ZGOFS2]NLAR,[M:ZGOFS3]NLNG

#Infbox "debug Pedidos"
# La rejilla está ordenada por Articulo - Largo - Ancho
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PEDSEL(F)=2
    ART=[M:ZGOFS1]PITM(F)
    #Acumulo los seleccionados
    TM2+ =[M:ZGOFS1]PM2LIN(F)
    TBOB+=[M:ZGOFS1]PBOBINASC(F)
    TIMP+=[M:ZGOFS1]PIMPORTE(F)
    TLIN+=1
    #Ańado LARGOS de Bobinas a producir.....Rejila ordenada por ITM+LARGO
    If RLAR<>[M:ZGOFS1]PLARGO(F)
      L=[M:ZGOFS2]NLAR
      [M:ZGOFS2]LLARGO(L)=[M:ZGOFS1]PLARGO(F)
      # Por defecto marco el primer largo
      If RLAR=0
        RSTA=[M:ZGOFS0]STA
        [M:ZGOFS0]STA="1" # Para evitar que se ejecute  AV_LSEL from  SPEZGOFS1
        [M:ZGOFS2]LSEL(L)    =2
        [M:ZGOFS2]LAGRUPAR(L)=2
        [M:ZGOFS0]STA=RSTA
        LAR=[M:ZGOFS1]PLARGO(F) # Me guardo el largo marcado
      Endif
      RLAR=[M:ZGOFS1]PLARGO(F)
      [M:ZGOFS2]NLAR+=1
    Endif
    #Ańado rejilla propuesta largos
    LA=format$("N0:5",[M:ZGOFS1]PLARGO(F)) + format$("N0:4",[M:ZGOFS1]PANCHO(F))
    If RLA<>LA
      Gosub LARGOS
      RLA=LA
    Endif
    Q+=[M:ZGOFS1]PBOBINASC(F)
  Endif
Next
Gosub LARGOS
Call CARGAR_ANCHOS (LAR)
[M:ZGOFS1]TM2=TM2
[M:ZGOFS1]TBOBINA=TBOB
[M:ZGOFS1]TIMPORTE=TIMP
[M:ZGOFS1]TLIN=TLIN
Affzo [M:ZGOFS1]TM2
Affzo [M:ZGOFS1]TBOBINA
Affzo [M:ZGOFS1]TIMPORTE
Affzo [M:ZGOFS1]TLIN
If TLIN=0
  Call VACIAR_REJILLA_STO("")
Endif
Sorta [M:ZGOFS2]NELE [M:ZGOFS2]NELE Order By [M:ZGOFS2]ANCHO(indice)
Affzo [M:ZGOFS2]10
Affzo [M:ZGOFS2]50
Call MOSTRAR_ANCHOS_A (ART)
Call LARGO_COL
Affzo [M:ZGOFS3]5
End

$LARGOS
Local Integer A
If RLA<>""
  A=[M:ZGOFS3]NLNG
  [M:ZGOFS3]LARGO(A)=val(mid$(RLA,1,5))
  [M:ZGOFS3]ANCHO(A)=val(mid$(RLA,6,4))
  [M:ZGOFS3]CANT(A) =Q
  [M:ZGOFS3]NLNG+=1
Endif
Raz Q
Return

Subprog CARGAR_ANCHOS(LAR)
Value Integer LAR
Local Integer F,A,B,L,Q,OK,WOK
Local Char LA(250),RLA(250),MSG(255)(2)
Raz RLA,MSG
# Actualizo datos rejilla según largo seleccionado
Call ACTU_REJILLA (LAR) From SPEZGOFS3
# Borro rejilla
Raz [M:ZGOFS2]NELE
Effzo [M:ZGOFS2]10
# Cargo rejilla con anchos marcados como agrupar.   Rejilla ordenada por  Articulo + Largo + Ancho
WOK=1
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PEDSEL(F)=2
    # Ver si largo marcado como AGRUPAR
    OK=0
    For Q=0 To [M:ZGOFS2]NLAR-1
      If [M:ZGOFS2]LLARGO(Q)=[M:ZGOFS1]PLARGO(F) and [M:ZGOFS2]LAGRUPAR(Q)=2
        OK=[M:ZGOFS2]LLARGO(Q)
        Break
      Endif
    Next
    #Ańado a Bobinas a producir
    If OK
      LA=format$("N0:5",[M:ZGOFS1]PLARGO(F)) + format$("N0:4",[M:ZGOFS1]PANCHO(F))
      If RLA<>LA
        Gosub CARGAR_ANCHOS_TOT
        RLA=LA
        If WOK=0   Break    Endif
      Endif
      #Ańado mandril del pedido
      C=int([M:ZGOFS1]PBOBINASC(F)/int([M:ZGOFS3]DIVISOR(L))+0.5)
      If C=0:C=1:Endif
      For B=1 To C
        For Q=0 To [M:ZGOFS2]NELE-1
          If [M:ZGOFS2]MANDRIL(Q)=0 and [M:ZGOFS2]ANCHO(Q)=[M:ZGOFS1]PANCHO(F)
            [M:ZGOFS2]MANDRIL(Q)=[M:ZGOFS1]PMANDRIL(F)
            Break
          Endif
        Next
      Next
    Endif
  Endif
Next

If WOK=0
  Raz [M:ZGOFS2]NELE
  Effzo [M:ZGOFS2]10
Else
  Sorta [M:ZGOFS2]NELE [M:ZGOFS2]NELE Order By [M:ZGOFS2]ANCHO(indice)
  Affzo [M:ZGOFS2]10
  # Mostrar avisos
  If MSG(0)=""
    Chgfmt [M:ZGOFS2]SAVISOPDTE    With "-"
  Else
    MSG(0)="Hay bobinas pdtes de fabricar !!!! (LxA)  " + MSG(0)
    Chgfmt [M:ZGOFS2]SAVISOPDTE    With "+"
  Endif
  [M:ZGOFS2]SAVISOPDTE=MSG(0)
  Affzo [M:ZGOFS2]SAVISOPDTE
  If MSG(1)=""
    Chgfmt [M:ZGOFS2]SAVISORESTO   With "-"
  Else
    MSG(1)="Quedan restos !!!! (LxA) " + MSG(1)
    Chgfmt [M:ZGOFS2]SAVISORESTO   With "+"
  Endif
  [M:ZGOFS2]SAVISORESTO=MSG(1)
  Affzo [M:ZGOFS2]SAVISORESTO
Endif
End

$CARGAR_ANCHOS_TOT
Local Integer C
# Sacar cantidad bobinas de rejilla
C=0
For L=0 To [M:ZGOFS3]NLNG-1
  If [M:ZGOFS3]LARGO(L)=[M:ZGOFS1]PLARGO(F) and [M:ZGOFS3]ANCHO(L)=[M:ZGOFS1]PANCHO(F)
    C=[M:ZGOFS3]CANTD(L)/int([M:ZGOFS3]DIVISOR(L))
    If C=0 Then
      # Minimo cabe un ancho, pues ancho bobina pedido<=ancho jumbo
      C=1
    Endif
    # Avisar si quedan pedidos por servir
    If [M:ZGOFS3]CANTP(L)>0
      If MSG(0)<>""
        MSG(0)+=" # "
      Endif
      MSG(0)+= num$([M:ZGOFS3]CANTP(L)) + " de " + num$([M:ZGOFS3]LARGO(L)) + "x" + num$([M:ZGOFS3]ANCHO(L))
    Endif
    # Avisar si quedan restos de largo
    If [M:ZGOFS3]RESTO(L)>0
      If MSG(1)<>""
        MSG(1)+=" # "
      Endif
      MSG(1)+= num$([M:ZGOFS3]RESTO(L)) + "x" + num$([M:ZGOFS3]ANCHO(L)) + " al cortar bobina de "  + num$([M:ZGOFS3]LARGO(L)) + "x" + num$([M:ZGOFS3]ANCHO(L))
    Endif
    Break
  Endif
Next
For B=1 To C
  A=[M:ZGOFS2]NELE
  [M:ZGOFS2]ANCHO(A)=[M:ZGOFS1]PANCHO(F)
  If A+1>=[M:ZGOFS0]FLDNUM(0)
    MSG="FALTAN DATOS !!!\Alcanzado máximo de " + num$(A+1) + " filas para mostrar bobinas a producir\.\Ajuste los filtros o pida que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    WOK=0
    Break
  Else
    [M:ZGOFS2]NELE+=1
  Endif
Next
Return

Funprog ITM_SEL
Local Char ITM(GLONITM)
Local Integer F,MAN
  ITM=[M:ZGOFS1]PITM(nolign-1)
#  MAN=[M:ZGOFS1]PMANDRIL(nolign-1)
  For F=0 To [M:ZGOFS1]NPED-1
    If [M:ZGOFS1]PEDSEL(F)=2
      ITM=[M:ZGOFS1]PITM(F)
#      MAN=[M:ZGOFS1]PMANDRIL(F)
      Break
    Endif
  Next
End ITM

Funprog MANDRILES(MND,MND_A)
Variable Char MND,MND_A
Local Integer F,N,Q,A
Local Char RM(5)
# Sacar cuantos mandriles diferentes hay
Raz MND,MND_A,N,RM
For F=0 To [M:ZGOFS2]NELE-1
  RM=format$("N0:3",[M:ZGOFS2]MANDRIL(F))
  If instr(1,MND,RM)<1
    N+=1
    If MND<>"":MND+="-":Endif
    MND+=RM
  Endif
Next
# No puede haber diferentes mandriles para un mismo ancho
If N<3
  Raz A
  For F=0 To [M:ZGOFS2]NELE-1
    If A<>[M:ZGOFS2]ANCHO(F)
      A=[M:ZGOFS2]ANCHO(F)
      For Q=0 To [M:ZGOFS2]NELE-1
        If [M:ZGOFS2]ANCHO(Q)=[M:ZGOFS2]ANCHO(F) and [M:ZGOFS2]MANDRIL(Q)<>[M:ZGOFS2]MANDRIL(F)
          MND_A="Imposible incluir mandriles diferentes del mismo ancho en el cálculo\Ancho " + num$([M:ZGOFS2]ANCHO(Q)) + " mandriles " + num$([M:ZGOFS2]MANDRIL(F)) +" y " + num$([M:ZGOFS2]MANDRIL(Q)
& )
          Break 2
        Endif
      Next
    Endif
  Next
Endif
End N





#===================================
#Procedimientos EVENTOS pantallas
#===================================

Subprog AV_PEDSEL(VALEUR)
Variable Integer VALEUR
Local Char MSG(250)
Local Char ITM(GLONITM)
If [M:ZGOFS0]STA=""
  # El ancho del mandril va en funcion del largo. Cuanto mas largo mas ancho ha de ser para resistir rel bobinado
  ITM=func ITM_SEL
  If not ([M:ZGOFS1]PITM(nolign-1)=ITM) # and [M:ZGOFS1]PMANDRIL(F)=MAN)
    MSG="Imposible mezclar ARTICULOS en un mismo cálculo\Articulo " + ITM + " # " + [M:ZGOFS1]PITM(nolign-1) # + "\Mandril " +  num$(MAN) + " # " + [M:ZGOFS1]PMANDRIL(nolign-1)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
  Else
    Call TOT_NPED
  Endif
Endif
End


Subprog AM_PEDSEL(VALEUR)
Variable Integer VALEUR
[M:ZGOFS0]STA="1"
[M:ZGOFS1]PEDSEL(nolign-1)=VALEUR
Call TOT_NPED
[M:ZGOFS0]STA=""
End

Subprog AM_PBOBINASC(VALEUR)
Variable Decimal VALEUR
If [M:ZGOFS1]PEDSEL(nolign-1)<>2
  VALEUR=[M:ZGOFS1]PBOBINASC(nolign-1)
  End
Elsif VALEUR>[M:ZGOFS1]PBOBINAS(nolign-1)
  MSG="Bobinas para cálculo, no puede ser superior a las del pedido"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
[M:ZGOFS0]STA="1"
[M:ZGOFS1]PBOBINASC(nolign-1)=VALEUR
If VALEUR=[M:ZGOFS1]PBOBINAS(nolign-1)
  Chgstl [M:ZGOFS1]PBOBINASC(nolign-1) With ""
Else
  Chgstl [M:ZGOFS1]PBOBINASC(nolign-1) With "BACKRED"
Endif
Call TOT_NPED
[M:ZGOFS0]STA=""
End

Subprog B1_NSTO
Local Integer F
[M:ZGOFS0]STA="1"
For F=0 To [M:ZGOFS1]NSTO-1
  [M:ZGOFS1]SSEL(F)=1
Next
Affzo [M:ZGOFS1]20
Call TOT_NSTO
[M:ZGOFS0]STA=""
End

Subprog IB_NPED
Local Integer F
F=nolign-1
If [M:ZGOFS1]PSOHNUM(F)=""
  GBOUT4=""
Else
  GBOUT4="Pedido "+[M:ZGOFS1]PSOHNUM(F)
Endif
End


Subprog B1_NPED  #  Marcar todo
Local Integer F, MAN
Local Char ITM(GLONITM)
ITM=func ITM_SEL
If not ([M:ZGOFS1]PITM(nolign-1)=ITM) # and [M:ZGOFS1]PMANDRIL(F)=MAN)
  MSG="Imposible mezclar ARTICULOS en un mismo cálculo\Articulo " + ITM + " # " + [M:ZGOFS1]PITM(nolign-1) # + "\Mandril " +  num$(MAN) + " # " + [M:ZGOFS1]PMANDRIL(nolign-1)
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End
Endif
[M:ZGOFS0]STA="1"
ITM=[M:ZGOFS1]PITM(nolign-1)
MAN=[M:ZGOFS1]PMANDRIL(nolign-1)
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PITM(F)=ITM #and [M:ZGOFS1]PMANDRIL(F)=MAN
    [M:ZGOFS1]PEDSEL(F)=2
  Endif
Next
Affzo [M:ZGOFS1]10
Call TOT_NPED
[M:ZGOFS0]STA=""
End

Subprog B2_NPED  #  Desmarcar todo
Local Integer F
[M:ZGOFS0]STA="1"
For F=0 To [M:ZGOFS1]NPED-1
  [M:ZGOFS1]PEDSEL(F)=1
Next
Affzo [M:ZGOFS1]10
Call TOT_NPED
Call TOT_NSTO
[M:ZGOFS0]STA=""
End

Subprog B3_NPED  #  Invertir
Local Integer F,MAN
Local Char ITM(GLONITM)
[M:ZGOFS0]STA="1"
ITM=[M:ZGOFS1]PITM(nolign-1)
MAN=[M:ZGOFS1]PMANDRIL(nolign-1)
For F=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PITM(F)=ITM #and [M:ZGOFS1]PMANDRIL(F)=MAN
    Case [M:ZGOFS1]PEDSEL(F)
    When 1
      [M:ZGOFS1]PEDSEL(F)=2
    When 2
      [M:ZGOFS1]PEDSEL(F)=1
    Endcase
  Endif
Next
Affzo [M:ZGOFS1]10
Call TOT_NPED
[M:ZGOFS0]STA=""
End

Subprog AM_SSEL(VALEUR)
Variable Integer VALEUR
Local Char MSG(255)
# No se permite seleccionar registros de Stock que esten siendo usados en OF en curso
If [M:ZGOFS1]JAGRUPAR=2
  VALEUR=1
Elsif [M:ZGOFS1]SLARGO(nolign-1)<>[M:ZGOFS1]SLARGOSTK(nolign-1)
  If VALEUR=2
    MSG="Recuerde que no se permite seleccionar Materia prima incluida en OFs en curso\Se deberá declarar produccion de dichas OFs\para dejar libre  la materia prima, por el SOBRANTE que se indique"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  Endif
  VALEUR=1
Elsif not func UBICACION_OK([M:ZGOFS1]LOC(nolign-1))
  If VALEUR=2
    MSG="Recuerde que no se permite seleccionar Materia prima de la ubiacion "+[M:ZGOFS1]LOC(nolign-1)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  Endif
  VALEUR=1
Endif
[M:ZGOFS1]SSEL(nolign-1)=VALEUR
If VALEUR<>2
  [M:ZGOFS1]EMPALMAR(nolign-1)=VALEUR
  Affzo [M:ZGOFS1]EMPALMAR(nolign-1)
Endif
Call TOT_NSTO
End

Subprog AM_EMPALMAR(VALEUR)
Variable Integer VALEUR
# Si la fila no seleccionada NO se permite empalmar
If [M:ZGOFS1]JAGRUPAR=2
  VALEUR=1
Elsif [M:ZGOFS1]SSEL(nolign-1)<>2
  VALEUR=1
  [M:ZGOFS1]EMPALMAR(nolign-1)=VALEUR
  Affzo [M:ZGOFS1]EMPALMAR(nolign-1)
  End
Endif
[M:ZGOFS1]EMPALMAR(nolign-1)=VALEUR
Affzo [M:ZGOFS1]EMPALMAR(nolign-1)
Call TOT_NSTO
End

Subprog AM_FPEDIDO(VALEUR)
Variable Char    VALEUR()
Local Char MSG(255)
If VALEUR =""
  Actzo [M:ZGOFS0]FCTEINI
  Actzo [M:ZGOFS0]FCTEFIN
Else
  Read [F:SOHX]SOH0=VALEUR
  If fstat<>0
    MSG="No existe el pedido " + VALEUR
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Else
#    If [M:ZGOFS0]FCTEINI<>"" and [F:SOHX]BPCORD<>[M:ZGOFS0]FCTEINI
#      MSG="El cliente del pedido es diferente al indicado para filtrar\" + [F:SOHX]BPCORD +"<>"+[M:ZGOFS0]FCTEINI
#      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#      mkstat=2
#      End
#    Else
      [M:ZGOFS0]FCTEINI=[F:SOHX]BPCORD
      [M:ZGOFS0]FCTEFIN=[F:SOHX]BPCORD
      Affzo [M:ZGOFS0]FCTEINI
      Affzo [M:ZGOFS0]FCTEFIN
      Grizo [M:ZGOFS0]FCTEINI
      Grizo [M:ZGOFS0]FCTEFIN
#    Endif
  Endif
Endif
[M:ZGOFS0]FPEDIDO=VALEUR
End


