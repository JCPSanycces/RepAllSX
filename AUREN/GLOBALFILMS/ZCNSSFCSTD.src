#  mkstat = 2
#Endif
#End
##########################################################################
Subprog IB_ITMREF
If [M:ZSFC1]ITMREF=""
  Raz GBOUT2, GBOUT3, GBOUT4
Endif
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char     VALEUR
[M:ZSFC1]UOM       = [F:ITM]STU
[M:ZSFC1]STU       = [F:ITM]STU
[M:ZSFC1]ITMSTA    = [F:ITM]ITMSTA
[M:ZSFC1]STOMGTCOD = [F:ITM]STOMGTCOD
Affzo [M:ZSFC1]STU
Affzo [M:ZSFC1]ITMSTA
Affzo [M:ZSFC1]STOMGTCOD
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:ZSFC1]FLG = 0
If [M:ZSFC1]ITMREFHASTA<VALEUR
  [M:ZSFC1]ITMREFHASTA=VALEUR
  Affzo [M:ZSFC1]ITMREFHASTA
Endif
End
############################################################
Subprog C_DETFLG(VALEUR)
Variable Integer VALEUR
[M:ZSFC1]FLG = 0
If VALEUR=2 & [M]CUMFLG=2 & [M:ZSFC1]WMAXLIG<8
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=2 & [M]CUMFLG=1 & [M:ZSFC1]WMAXLIG<4
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=1 & [M]CUMFLG=2 & [M:ZSFC1]WMAXLIG<2
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Endif
End
############################################################
Subprog C_CUMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]DETFLG=2 & [M:SFC1]WMAXLIG<5
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=2 & [M]DETFLG=1 & [M:SFC1]WMAXLIG<2
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=12
Elsif VALEUR=1 & [M]DETFLG=2 & [M:SFC1]WMAXLIG<4
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Endif
End
############################################################
Subprog IB_NBLIG
If nolign > 0
  #Effzo [M:ZSFC2]
  #If [M]ALLSTO(nolign-1) = 0 & GFONC1 <> "GESPNH" : Raz GBOUT4 : Endif
  #If [M]GLOALL(nolign-1) = 0     : Raz GBOUT5 : Endif
  #If [M]DETSHT(nolign-1) = 0 & [M]GLOSHT(nolign-1) = 0  : Raz GBOUT6 : Endif
  #If [M]TRFSTO(nolign-1) = 0     : Raz GBOUT7 : Endif
  #If [M]TRASTO(nolign-1) = 0     : Raz GBOUT8 : Endif
  #If [M]BPRSTO(nolign-1) = 0     : Raz GBOUT9 : Endif
  #If [M]STOFCY(nolign-1) = "***"
  #  If [M:SFC1]FCY = "" & [M:SFC1]BASPAG <> 0
  #    Raz GBOUT11
  #    Raz GBOUT12
  #  Endif
  #Endif
Endif
End

