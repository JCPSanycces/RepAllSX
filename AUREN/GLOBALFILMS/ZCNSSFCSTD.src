$CARGAR
#If date$>=[13/02/2018]     Call ERREURT("Datos licencia insuficientes",1) From GESECRAN     :    Return     Endif
Local Char REQUEST(255)(6)
#Local Char ANCHO(25)
#Local Char LONGITUD(25)
#Local Char MANDRIL(25)

Local Shortint ANCHO
Local Integer LONGITUD
Local Shortint MANDRIL

Local Integer NUMBOBINAS
Local Char NBOBINAS(25)
Local Char SQLCANT(255)(5)
Local Double CANTIDADPEDIDO
Local Double CANTIDADOF
Local Char CRITERIO(255)
Local Char FILTRO(255)
Local Char FILTRO2(255)
Local Integer BOBASIGNADAS
Local Integer BOBDISPONIBLES
Local Char FILTRO_CANT(255)
Local Char FILTRO_PROV(255)
Local Char DESARTI(30)
Local Integer FILAS
Local Double ZFACTOR
Local Char MEDIDA(5)
Local Char CAMPOPROVEEDOR(100)(2)
Local Char SENTENCIAFOR(255)
Local Char FLD(255)(10)

nolign=0

[M:ZSFC1]FLG = 1

#Hace invisible una columna del grid.
#Chgfmt [M:ZSFC2]LOT With "-K:30X"
#Chgfmt [M:ZSFC2]SLO With "-K:30X"

#If [M:ZSFC1]ITMREF<>""
If [M:ZSFC1]ZPROVAGRUP=2
  Chgfmt [M:ZSFC2]ZPROVEEDOR With "+"
Else
  Chgfmt [M:ZSFC2]ZPROVEEDOR With "-"
Endif
    Raz CANTIDADPEDIDO
    Raz CANTIDADOF
    Raz BOBASIGNADAS
    Raz [M:ZSFC2]
    Effzo [M:ZSFC2]5
    If [M:ZSFC1]ZDETALLADO=2
        Chgfmt [M:ZSFC2]LOT With "K:5"
        Chgfmt [M:ZSFC2]ZLOTORI With "K:5"
        Chgfmt [M:ZSFC2]LOC With "K:5"
        Chgfmt [M:ZSFC2]BOBMAL With "-"

#        Gosub STOCKCONDETALLE
    Else
        Chgfmt [M:ZSFC2]LOT With "-K:5"
        Chgfmt [M:ZSFC2]ZLOTORI With "-K:5"
        Chgfmt [M:ZSFC2]LOC With "-K:5"
        Chgfmt [M:ZSFC2]BOBMAL With "+"

#        Gosub STOCKSINDETALLE
    Endif
#Endif

Local Char D(1)
If [M:ZSFC1]ZOCULTAR=2
  D="-K:5"
Else
  D="K:5"
Endif
Chgfmt [M:ZSFC2]QTYSTU     With D
Chgfmt [M:ZSFC2]ZQTYASIPED With D
Chgfmt [M:ZSFC2]ZQTYASIOF  With D
Chgfmt [M:ZSFC2]ZQTYDISP   With D
Chgfmt [M:ZSFC2]LNGSTK     With D
Chgfmt [M:ZSFC2]LNGASI     With D
Chgfmt [M:ZSFC2]LNGDIS     With D

Gosub MOSTRAR
Return

$MOSTRAR
Local Char BD_TIPO(1)
Local Integer F,TF,BOB(2)
Local Decimal KGS(2)
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO
TF=func ZCOMUN.FILAS_GRID("ZCONSSFC2", "NBLIG")
Gosub MONTAR_SQL

#FLD(2)=",LOT_0,ZLOTORI_0,LOC_0 "
#REQUEST(0)="SELECT   STOFCY_0,ITMREF_0,STA_0,ZANCHO_0,ZMANDRIL_0,ZLONGITUD_0"+FLD(2)+FLD(0)+",sum(QTYPCU_0) As CTD1,sum(QTYSTU_0) As CTD2,"
#REQUEST(1)="sum(QTYSTUACT_0) As CTD3,sum(QTYPCUORI_0) As CTD4, sum(QTYSTUORI_0) As CTD5, count(SLO_0) As BOBINAS "
#CTD1 Cantidad en UnidadEnvasado
#CTD2 Cantidad en UnidadStock
#CTD3 Cantidad en UnidadStock     activa
#CTD4 Cantidad en UnidadEnvasado  original
#CTD5 Cantidad en UnidadStock     original
#CTD6 Cantidad en UnidadStock     asignada

#Local Integer YN
#Local Char FICSRV(250)
#Call GRABARFICHERO(REQUEST,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  Return
#Endif

For (Char FFCY(GLONFCY),Char FITM(GLONITM), Char FEST(5),Shortint FANC,Shortint FMAN,Integer FLNG, Char FLOT(GLONLOT),Char FZLT(GLONLOT),Char FUBI(GLONLOC),Char FPRO(GLONBPR),Double FCT1,Double FCT2,
& Double FCT3,Double FCT4,Double FCT5,Double FCT6,Double FBOB) From BD_TIPO Sql REQUEST As [XXX]
  Call CTAD_ASIG(FFCY,FITM,FANC,FLNG,FMAN,"PED",FPRO,FLOT,FUBI,KGS(0),BOB(0))
  Call CTAD_ASIG(FFCY,FITM,FANC,FLNG,FMAN,"OF" ,FPRO,FLOT,FUBI,KGS(1),BOB(1))
  F=[M:ZSFC2]NBLIG
  [M:ZSFC2]STOFCY(F)    =FFCY
  [M:ZSFC2]ITMREF(F)    =FITM
  [M:ZSFC2]STA(F)       =FEST
  [M:ZSFC2]ZANCHO(F)    =FANC
  [M:ZSFC2]ZMANDRIL(F)  =FMAN
  [M:ZSFC2]ZLONGITUD(F) =FLNG
  [M:ZSFC2]LOT(F)       =FLOT
  [M:ZSFC2]ZLOTORI(F)   =FZLT
  [M:ZSFC2]ZPROVEEDOR(F)=FPRO
  [M:ZSFC2]LOC(F)       =FUBI
  [M:ZSFC2]ZQTYBOB(F)   =FBOB
  [M:ZSFC2]BOBASI(F)    =BOB(0)
  [M:ZSFC2]BOBASIOF(F)  =BOB(1)
  If [M:ZSFC1]ZDETALLADO=1
  [M:ZSFC2]BOBMAL(F)    =func HAY_BOB_MAL(F)
  [M:ZSFC2]ZQTYBOB(F)   =FBOB-[M:ZSFC2]BOBMAL(F)
  Endif
  [M:ZSFC2]BOBDIS(F)    =[M:ZSFC2]ZQTYBOB(F)   -[M:ZSFC2]BOBASI(F)    -[M:ZSFC2]BOBASIOF(F)

  If [M:ZSFC1]ZOCULTAR=1
  [M:ZSFC2]QTYSTU(F)    =FCT2
  [M:ZSFC2]ZQTYASIPED(F)=KGS(0)
  [M:ZSFC2]ZQTYASIOF(F) =KGS(1)
  [M:ZSFC2]ZQTYDISP(F)  =[M:ZSFC2]QTYSTU(F)    -[M:ZSFC2]ZQTYASIPED(F)-[M:ZSFC2]ZQTYASIOF(F)

  [M:ZSFC2]LNGSTK(F)    =[M:ZSFC2]ZLONGITUD(F)*[M:ZSFC2]ZQTYBOB(F)
  [M:ZSFC2]LNGASI(F)    =arr(([M:ZSFC2]ZQTYASIPED(F)+[M:ZSFC2]ZQTYASIOF(F))*[M:ZSFC2]LNGSTK(F)/[M:ZSFC2]QTYSTU(F),5)
  [M:ZSFC2]LNGDIS(F)    =[M:ZSFC2]LNGSTK(F)-[M:ZSFC2]LNGASI(F)
  Endif

  [M:ZSFC2]QTYPCU(F)    =FCT1
  [M:ZSFC2]QTYSTUACT(F) =FCT3
  [M:ZSFC2]QTYPCUORI(F) =FCT4
  [M:ZSFC2]QTYSTUORI(F) =FCT5

  If [M:ZSFC2]NBLIG+1>=TF
    MSG="Alcanzado máximo de " + num$(TF+1) + " filas\\Ajuste los filtros"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Break
  Else
    [M:ZSFC2]NBLIG+=1
  Endif
Next
Call MOSTRAR_TOT
Return

Subprog MOSTRAR_TOT_COL
If [M:ZSFC2]NBLIG>0
  Chgstl [M:ZSFC2]NBLIG([M:ZSFC2]NBLIG-1) With "GDD3G" #"GRAS"
  Local Integer F
  For F=0 To [M:ZSFC2]NBLIG-1
    If [M:ZSFC1]ZDETALLADO=2
      If not func SPEZGOFS.UBICACION_OK([M:ZSFC2]LOC(F))
        Chgstl [M:ZSFC2]NBLIG(F) With "BACKRED"
      Endif
    Else
      If [M:ZSFC2]BOBMAL(F)>0
        Chgstl [M:ZSFC2]BOBMAL(F) With "BACKRED"
        Chgstl [M:ZSFC2]ZQTYBOB(F) With "BACKRED"
        Chgstl [M:ZSFC2]BOBDIS(F)  With "BACKRED"
      Endif
    Endif
  Next
Endif
End

Funprog HAY_BOB_MAL(F)
Value Integer F
Local Integer BOB
Local Char TXT(255)(10),BD_TIPO(1)
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO
Raz BOB,TXT
TXT(0)="select LOC_0,count(*) as Bob "
TXT(1)="from STOCK "
TXT(2)="where STOFCY_0='"+[M:ZSFC2]STOFCY(F)+"' and ITMREF_0='"+[M:ZSFC2]ITMREF(F)+"' and ZANCHO_0="+num$([M:ZSFC2]ZANCHO(F))+" "
TXT(3)="and ZMANDRIL_0="+num$([M:ZSFC2]ZMANDRIL(F))+" and ZLONGITUD_0="+num$([M:ZSFC2]ZLONGITUD(F))+" and STA_0='"+[M:ZSFC2]STA(F)+"' "
If [M:ZSFC2]ZPROVEEDOR(F)<>""
  TXT(4)="and ZPROVEEDOR_0='"+[M:ZSFC2]ZPROVEEDOR(F)+"' "
Endif
TXT(5)="group by LOC_0"
For (Char FLOC(GLONLOC),Integer FBOB) From BD_TIPO Sql TXT As [WYZ]
  If not func SPEZGOFS.UBICACION_OK(FLOC)
    BOB=FBOB
  Endif
Next
End BOB

Subprog MOSTRAR_TOT
Local Integer F,G
G=[M:ZSFC2]NBLIG
[M:ZSFC2]STOFCY(G) = toupper(mess(142,124,1))
[M:ZSFC2]NBLIG+=1
For F=0 To G-1
  [M:ZSFC2]ZQTYBOB(G)   +=[M:ZSFC2]ZQTYBOB(F)
  [M:ZSFC2]BOBASIOF(G)  +=[M:ZSFC2]BOBASIOF(F)
  [M:ZSFC2]BOBASI(G)    +=[M:ZSFC2]BOBASI(F)
  If [M:ZSFC1]ZDETALLADO=1
  [M:ZSFC2]BOBMAL(G)    +=[M:ZSFC2]BOBMAL(F)
  Endif

  [M:ZSFC2]QTYSTU(G)    +=[M:ZSFC2]QTYSTU(F)
  [M:ZSFC2]ZQTYASIPED(G)+=[M:ZSFC2]ZQTYASIPED(F)
  [M:ZSFC2]ZQTYASIOF(G) +=[M:ZSFC2]ZQTYASIOF(F)

  [M:ZSFC2]LNGSTK(G)    +=[M:ZSFC2]LNGSTK(F)
  [M:ZSFC2]LNGASI(G)    +=[M:ZSFC2]LNGASI(F)
Next
  [M:ZSFC2]BOBDIS(G)    +=[M:ZSFC2]ZQTYBOB(G)   -[M:ZSFC2]BOBASI(G)    -[M:ZSFC2]BOBASIOF(G)
  [M:ZSFC2]ZQTYDISP(G)  +=[M:ZSFC2]QTYSTU(G)    -[M:ZSFC2]ZQTYASIPED(G)-[M:ZSFC2]ZQTYASIOF(G)
  [M:ZSFC2]LNGDIS(G)    +=[M:ZSFC2]LNGSTK(G)    -[M:ZSFC2]LNGASI(G)
End


Subprog CTAD_ASIG(FCY,ITM,ANC,LNG,MAD,TIP,PRV,LOT,UBI,KGS,BOB)
Value Char FCY,ITM,TIP,PRV,LOT,UBI
Value Integer ANC,LNG,MAD
Variable Decimal KGS
Variable Integer BOB
Local Char TXT(255)(10),BD_TIPO(1)
Raz TXT,KGS,BOB
########################################################################
# En la tabla STOCK cada registro identifica una BOBINA              ###
# Una bobina no puede estar asignada SIMULTANEAMENTE mas de una vez  ###
# Dicho esto, una bobina se considera asignada en cuanto CUMALLQTY>0 ###
########################################################################
#                                                                      #
#      Es llamado desde  SPEZINVE.src      Subprog MOSTRAR_INV         #
#                                                                      #
########################################################################
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO
TXT(0)="select sum(a.QTYSTU_0) as KGS, count(*) as BOB "
TXT(1)="from STOCK s inner join STOALL a ON s.STOFCY_0=a.STOFCY_0 and s.ITMREF_0=a.ITMREF_0 and s.STOCOU_0=a.STOCOU_0 "
TXT(2)="where s.STOFCY_0='"+FCY+"' and s.ITMREF_0='"+ITM+"' and s.ZANCHO_0="+num$(ANC)+" and s.ZMANDRIL_0="+num$(MAD)+" and s.ZLONGITUD_0="+num$(LNG)+" "
Case TIP
When "PED"
  TXT(3)+="and a.VCRTYP_0 IN(2,4) "
When "OF"
  TXT(3)+="and a.VCRTYP_0=10 "
When Default
  # Todo
Endcase
If PRV<>""
  TXT(3)+="and s.ZPROVEEDOR_0='"+PRV+"' "
Endif
If LOT<>""
  TXT(3)+="and s.LOT_0='"+LOT+"' "
Endif
If UBI<>""
  TXT(3)+="and s.LOC_0='"+UBI+"' "
Endif
If GFONCTION="ZFINVE"
  If [M:ZINV0]FSLO<>""
    TXT(3)+="and s.SLO_0='" + [M:ZINV0]FSLO + "' "
  Endif
Endif
For (Double FCTD,Integer FBOB) From BD_TIPO Sql TXT As [ZZZ]
  KGS=FCTD
  BOB=FBOB
Next
End

Subprog CTAD_ASIG_DET(FCY,ITM,ANC,LNG,MAD,TIP,PRV,LOT,UBI,NUM)
Value Char FCY,ITM,TIP,PRV,LOT,UBI
Value Integer ANC,LNG,MAD
Variable Char NUM()
Local Char TXT(255)(10),BD_TIPO(1)
Local Integer L
Raz NUM,L
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO
TXT(0)="select distinct a.VCRNUM_0 "
TXT(1)="from STOCK s inner join STOALL a ON s.STOFCY_0=a.STOFCY_0 and s.ITMREF_0=a.ITMREF_0 and s.STOCOU_0=a.STOCOU_0 "
TXT(2)="where s.STOFCY_0='"+FCY+"' and s.ITMREF_0='"+ITM+"' and s.ZANCHO_0="+num$(ANC)+" and s.ZMANDRIL_0="+num$(MAD)+" and s.ZLONGITUD_0="+num$(LNG)+" "
Case TIP   #  Pedidos de venta
When "PED"
  TXT(3)+="and a.VCRTYP_0=2  "
When "ENT"  # Entregas cliente o Albaranes Salida
  TXT(3)+="and a.VCRTYP_0=4  "
When "OF"
  TXT(3)+="and a.VCRTYP_0=10 "
When Default
  # Todo
Endcase
If PRV<>""
  TXT(3)+="and s.ZPROVEEDOR_0='"+PRV+"' "
Endif
If LOT<>""
  TXT(3)+="and s.LOT_0='"+LOT+"' "
Endif
If UBI<>""
  TXT(3)+="and s.LOC_0='"+UBI+"' "
Endif
If GFONCTION="ZFINVE"
  If [M:ZINV0]FSLO<>""
    TXT(3)+="and s.SLO_0='" + [M:ZINV0]FSLO + "' "
  Endif
Endif
TXT(4)="Order by a.VCRNUM_0"
For (Char FVCR(GLONVCR)) From BD_TIPO Sql TXT As [ZZZ]
  If L>dim(NUM)-1
    Break
  Else
    NUM(L)=FVCR
    L+=1
  Endif
Next
End


$STOCKSINDETALLE
#Local Decimal LBOBASI, LBOBAASI

nolign=0
##MONTAMOS EL FILTRO
If [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]FCY<>"" and [M:ZSFC1]ITMREFHASTA<>"" Then
    FILTRO = " WHERE (STOCK.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STOCK.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"') AND STOCK.STOFCY_0='"+[M:ZSFC1]FCY+"' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE (STOCK.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STOCK.ITMREF_0<='"+[M:ZSFC1]ITMREFHASTA+"') "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STOCK.STOFCY_0 ='"+[M:ZSFC1]FCY+"' "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STOCK.ITMREF_0 <>'' AND STOCK.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STOCK.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STOCK.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STOCK.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"' AND STOCK.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STOCK.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STOCK.STOFCY_0='"+[M:ZSFC1]FCY+"'"
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STOCK.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"' AND STOCK.STOFCY_0<>'"+[M:ZSFC1]FCY+"'"
Endif

If ([M:ZSFC1]ANCHODESDE<>0) and ([M:ZSFC1]ANCHOHASTA<>0) Then
    FILTRO+=" AND (STOCK.ZANCHO_0>="+num$([M:ZSFC1]ANCHODESDE)+" AND STOCK.ZANCHO_0<="+num$([M:ZSFC1]ANCHOHASTA)+")"
Elsif ([M:ZSFC1]ANCHODESDE<>0) and ([M:ZSFC1]ANCHOHASTA=0) Then
    FILTRO+=" AND STOCK.ZANCHO_0>="+num$([M:ZSFC1]ANCHODESDE)
Elsif ([M:ZSFC1]ANCHODESDE=0) and ([M:ZSFC1]ANCHOHASTA<>0) Then
    FILTRO+=" AND STOCK.ZANCHO_0<="+num$([M:ZSFC1]ANCHOHASTA)
Endif
If ([M:ZSFC1]MANDRIL<>0) Then
    FILTRO+=" AND STOCK.ZMANDRIL_0>="+num$([M:ZSFC1]MANDRIL)
Endif
If ([M:ZSFC1]LONGITUD<>0) and ([M:ZSFC1]LONGITUD2<>0)  Then
    FILTRO+=" AND (STOCK.ZLONGITUD_0>="+num$([M:ZSFC1]LONGITUD)+" AND STOCK.ZLONGITUD_0<="+num$([M:ZSFC1]LONGITUD2)+") "
Endif
If ([M:ZSFC1]ZPROVEEDOR<>"") Then
    FILTRO+=" AND STOCK.ZPROVEEDOR_0='"+[M:ZSFC1]ZPROVEEDOR+"'"
Endif
#JLPR 17-11-16 S/Tachi no hemos de permitir que se escoga stock de las ubicaciones  PTREVISI + DEVOLUCI
FILTRO2+=" and not (STOCK.LOC_0='PTREVISI' or STOCK.LOC_0='DEVOLUCI')"

If [M:ZSFC1]ZPROVAGRUP=2
    CAMPOPROVEEDOR=" STOCK.ZPROVEEDOR_0, "
Else
    CAMPOPROVEEDOR=""
Endif


REQUEST(0)="SELECT STOCK.STOFCY_0, STOCK.STA_0, STOCK.ZANCHO_0, STOCK.ZMANDRIL_0, STOCK.ZLONGITUD_0, sum(STOCK.QTYPCU_0) As CTD1, sum(STOCK.QTYSTU_0) As CTD2, sum(STOCK.QTYSTUACT_0) As CTD3,"
REQUEST(1)="sum(STOCK.QTYPCUORI_0) As CTD4, sum(STOCK.QTYSTUORI_0) As CTD5, COUNT(STOCK.SLO_0) AS BOBINAS,"+CAMPOPROVEEDOR+"STOCK.ITMREF_0 "
REQUEST(2)="From STOCK "
REQUEST(3)=FILTRO
REQUEST(4)=FILTRO2
If [M:ZSFC1]ZPROVAGRUP=2
    REQUEST(5)=" GROUP By STOCK.STOFCY_0, STOCK.ITMREF_0, STOCK.STA_0, STOCK.ZANCHO_0, STOCK.ZMANDRIL_0, STOCK.ZLONGITUD_0, STOCK.ZPROVEEDOR_0"
Else
    REQUEST(5)=" GROUP By STOCK.STOFCY_0, STOCK.ITMREF_0, STOCK.STA_0, STOCK.ZANCHO_0, STOCK.ZMANDRIL_0, STOCK.ZLONGITUD_0"
Endif

If [M:ZSFC1]ZPROVAGRUP=2 Then
For (Char PLANTA(5),Char ESTADO(5),Shortint ANCHO,Shortint MANDRIL,Integer LONGITUD,Double CANT1,Double CANT2,Double CANT3,Double CANT4,Double CANT5,Double CANTBOBINAS
& ,Char
& PROVEEDOR(15),Char REFARTI(20)) From "5"
& Sql REQUEST
& As
& [XXX]
      NUMBOBINAS=NUMBOBINAS+1

      #DESARTI=""
      Raz [F:ITM]
      Read [ITM]ITM0=[F:XXX]REFARTI

      Raz [F:FCY]
      Read [F:FCY]FCY0=[F:XXX]PLANTA
      #DESARTI = [F:ITM]ITMDES1
      ZFACTOR = [F:ITM]ZFACTOR
      MEDIDA = [F:ITM]STU

      ANCHO = [F:XXX]ANCHO
      LONGITUD = [F:XXX]LONGITUD
      MANDRIL = [F:XXX]MANDRIL

      Gosub EXTRAER_CTDASIGNADA

      [M:ZSFC2]STOFCY(nolign)=[F:XXX]PLANTA
      [M:ZSFC2]STA(nolign)=[F:XXX]ESTADO
      [M:ZSFC2]ZANCHO(nolign)=[F:XXX]ANCHO
      [M:ZSFC2]ZLONGITUD(nolign)=[F:XXX]LONGITUD
      [M:ZSFC2]ZMANDRIL(nolign)=[F:XXX]MANDRIL
      [M:ZSFC2]LOT(nolign)=""
      [M:ZSFC2]ZLOTORI(nolign)=""
      [M:ZSFC2]ZQTYBOB(nolign)=[F:XXX]CANTBOBINAS
      [M:ZSFC2]BOBASI(nolign)=BOBASIGNADAS
      [M:ZSFC2]BOBDIS(nolign)=[F:XXX]CANTBOBINAS - BOBASIGNADAS
      [M:ZSFC2]ZPROVEEDOR(nolign)=[F:XXX]PROVEEDOR
      [M:ZSFC2]ITMREF(nolign)=[F:XXX]REFARTI
      #[M:ZSFC2]ITMDES1(nolign)=DESARTI
      [M:ZSFC2]FCYSHO(nolign)=[F:FCY]FCYSHO

      #CANTIDADES EN KG
      If MEDIDA="KG" Then
          [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
          [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
          [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
          [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
          [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
          [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
          [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF

          #CANTIDADES EN M2
          [M:ZSFC2]ZQTYPCU(nolign)=[M:ZSFC2]QTYPCU(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYSTU(nolign)=[M:ZSFC2]QTYSTU(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYSTUACT(nolign)=[M:ZSFC2]QTYSTUACT(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYASIPEDM2(nolign)=[M:ZSFC2]ZQTYASIPED(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYASIOFM2(nolign)=[M:ZSFC2]ZQTYASIOF(nolign) / ZFACTOR
      Else
          [M:ZSFC2]ZQTYPCU(nolign)=[F:XXX]CANT1
          [M:ZSFC2]ZQTYSTU(nolign)=[F:XXX]CANT2
          [M:ZSFC2]ZQTYSTUACT(nolign)=[F:XXX]CANT3
          [M:ZSFC2]ZQTYASIPEDM2(nolign)=CANTIDADPEDIDO
          [M:ZSFC2]ZQTYASIOFM2(nolign)=CANTIDADOF

          [M:ZSFC2]QTYPCU(nolign)=[M:ZSFC2]ZQTYPCU(nolign) * ZFACTOR
          [M:ZSFC2]QTYSTU(nolign)=[M:ZSFC2]ZQTYSTU(nolign) * ZFACTOR
          [M:ZSFC2]QTYSTUACT(nolign)=[M:ZSFC2]ZQTYSTUACT(nolign) * ZFACTOR
          [M:ZSFC2]ZQTYASIPED(nolign)=[M:ZSFC2]ZQTYASIPEDM2(nolign) * ZFACTOR
          [M:ZSFC2]ZQTYASIOF(nolign)=[M:ZSFC2]ZQTYASIOFM2(nolign) * ZFACTOR
      Endif

      nolign+=1
      If nolign=3000 Then
          Infbox("La consulta devuelve demasiados registros. Se visualizarán los 3000 primeros")
          Break
      Endif
Next

Else

For (Char PLANTA(5),Char ESTADO(5),Shortint ANCHO,Shortint MANDRIL,Integer LONGITUD,Double CANT1,Double CANT2,Double CANT3,Double CANT4,Double CANT5,Double CANTBOBINAS
& ,Char REFARTI(20)) From "5"
& Sql REQUEST
& As
& [XXX]
      NUMBOBINAS=NUMBOBINAS+1

      #DESARTI=""
      Raz [F:ITM]
      Read [ITM]ITM0=[F:XXX]REFARTI

      Raz [F:FCY]
      Read [F:FCY]FCY0=[F:XXX]PLANTA
      #DESARTI = [F:ITM]ITMDES1
      ZFACTOR = [F:ITM]ZFACTOR
      MEDIDA = [F:ITM]STU

      ANCHO = [F:XXX]ANCHO
      LONGITUD = [F:XXX]LONGITUD
      MANDRIL = [F:XXX]MANDRIL

      Gosub EXTRAER_CTDASIGNADA

      [M:ZSFC2]STOFCY(nolign)=[F:XXX]PLANTA
      [M:ZSFC2]STA(nolign)=[F:XXX]ESTADO
      [M:ZSFC2]ZANCHO(nolign)=[F:XXX]ANCHO
      [M:ZSFC2]ZLONGITUD(nolign)=[F:XXX]LONGITUD
      [M:ZSFC2]ZMANDRIL(nolign)=[F:XXX]MANDRIL
      [M:ZSFC2]LOT(nolign)=""
      [M:ZSFC2]ZLOTORI(nolign)=""
      [M:ZSFC2]ZQTYBOB(nolign)=[F:XXX]CANTBOBINAS
      [M:ZSFC2]BOBASI(nolign)=BOBASIGNADAS
      [M:ZSFC2]BOBDIS(nolign)=[F:XXX]CANTBOBINAS - BOBASIGNADAS
      [M:ZSFC2]ZPROVEEDOR(nolign)=""
      [M:ZSFC2]ITMREF(nolign)=[F:XXX]REFARTI
      #[M:ZSFC2]ITMDES1(nolign)=DESARTI
      [M:ZSFC2]FCYSHO(nolign)=[F:FCY]FCYSHO

      #CANTIDADES EN KG
      If MEDIDA="KG" Then
          [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
          [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
          [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
          [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
          [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
          [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
          [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF

          #CANTIDADES EN M2
          [M:ZSFC2]ZQTYPCU(nolign)=[M:ZSFC2]QTYPCU(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYSTU(nolign)=[M:ZSFC2]QTYSTU(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYSTUACT(nolign)=[M:ZSFC2]QTYSTUACT(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYASIPEDM2(nolign)=[M:ZSFC2]ZQTYASIPED(nolign) / ZFACTOR
          [M:ZSFC2]ZQTYASIOFM2(nolign)=[M:ZSFC2]ZQTYASIOF(nolign) / ZFACTOR
      Else
          [M:ZSFC2]ZQTYPCU(nolign)=[F:XXX]CANT1
          [M:ZSFC2]ZQTYSTU(nolign)=[F:XXX]CANT2
          [M:ZSFC2]ZQTYSTUACT(nolign)=[F:XXX]CANT3
          [M:ZSFC2]ZQTYASIPEDM2(nolign)=CANTIDADPEDIDO
          [M:ZSFC2]ZQTYASIOFM2(nolign)=CANTIDADOF

          [M:ZSFC2]QTYPCU(nolign)=[M:ZSFC2]ZQTYPCU(nolign) * ZFACTOR
          [M:ZSFC2]QTYSTU(nolign)=[M:ZSFC2]ZQTYSTU(nolign) * ZFACTOR
          [M:ZSFC2]QTYSTUACT(nolign)=[M:ZSFC2]ZQTYSTUACT(nolign) * ZFACTOR
          [M:ZSFC2]ZQTYASIPED(nolign)=[M:ZSFC2]ZQTYASIPEDM2(nolign) * ZFACTOR
          [M:ZSFC2]ZQTYASIOF(nolign)=[M:ZSFC2]ZQTYASIOFM2(nolign) * ZFACTOR
      Endif

      nolign+=1
      If nolign=3000 Then
          Infbox("La consulta devuelve demasiados registros. Se visualizarán los 3000 primeros")
          Break
      Endif
Next


Endif

Gosub CALCULAR_TOTALES


#Pasamos a la variable NBLIG de la pantalla el nş de líneas del grid
[M:ZSFC2]NBLIG=nolign

#En el caso que haya más de una línea con la función Affzo hacemos un refresco de los campos
If [M:ZSFC2]NBLIG>0
   #Affzo [M:ZSFC2]5
Endif

Return

$STOCKCONDETALLE
Local Char REQUEST(255)(5)
Local Char SQLBOBINAS(255)(4)
Local Char FILTRO(255)

Call OUVRE_TRACE("Inicio Consulta") From LECFIC

nolign=0
##MONTAMOS EL FILTRO
If [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]FCY<>"" and [M:ZSFC1]ITMREFHASTA<>"" Then
    FILTRO = " WHERE (STO.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STO.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"') AND STO.STOFCY_0='"+[M:ZSFC1]FCY+"' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE (STO.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STO.ITMREF_0<='"+[M:ZSFC1]ITMREFHASTA+"') "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STO.STOFCY_0 ='"+[M:ZSFC1]FCY+"' "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STO.ITMREF_0 <>'' AND STO.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STO.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STO.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY="" Then
    FILTRO = " WHERE STO.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"' AND STO.STOFCY_0<>'' "
Elsif [M:ZSFC1]ITMREF<>"" and [M:ZSFC1]ITMREFHASTA="" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STO.ITMREF_0 >='"+[M:ZSFC1]ITMREF+"' AND STO.STOFCY_0<>'"+[M:ZSFC1]FCY+"'"
Elsif [M:ZSFC1]ITMREF="" and [M:ZSFC1]ITMREFHASTA<>"" and [M:ZSFC1]FCY<>"" Then
    FILTRO = " WHERE STO.ITMREF_0 <='"+[M:ZSFC1]ITMREFHASTA+"' AND STO.STOFCY_0<>'"+[M:ZSFC1]FCY+"'"
Endif

If ([M:ZSFC1]ANCHODESDE<>0) and ([M:ZSFC1]ANCHOHASTA<>0) Then
    FILTRO+=" AND (STO.ZANCHO_0>="+num$([M:ZSFC1]ANCHODESDE)+" AND STO.ZANCHO_0<="+num$([M:ZSFC1]ANCHOHASTA)+")"
Elsif ([M:ZSFC1]ANCHODESDE<>0) and ([M:ZSFC1]ANCHOHASTA=0) Then
    FILTRO+=" AND STO.ZANCHO_0>="+[M:ZSFC1]ANCHODESDE
Elsif ([M:ZSFC1]ANCHODESDE=0) and ([M:ZSFC1]ANCHOHASTA<>0) Then
    FILTRO+=" AND STO.ZANCHO_0<="+num$([M:ZSFC1]ANCHOHASTA)
Endif
If ([M:ZSFC1]MANDRIL<>0) Then
  FILTRO+=" AND STO.ZMANDRIL_0>="+num$([M:ZSFC1]MANDRIL)
Endif
If ([M:ZSFC1]LONGITUD<>0) and ([M:ZSFC1]LONGITUD2<>0)  Then
    FILTRO+=" AND (STO.ZLONGITUD_0>="+num$([M:ZSFC1]LONGITUD)+" AND STO.ZLONGITUD_0<="+num$([M:ZSFC1]LONGITUD2)+") "
Endif
If ([M:ZSFC1]ZPROVEEDOR<>"") Then
  FILTRO+=" AND STO.ZPROVEEDOR_0='"+[M:ZSFC1]ZPROVEEDOR+"'"
Endif

If [M:ZSFC1]ZPROVAGRUP=2
    CAMPOPROVEEDOR=", STO.ZPROVEEDOR_0"
Else
    CAMPOPROVEEDOR=""
Endif


REQUEST(0)="SELECT STO.STOFCY_0,STO.ITMREF_0,STO.LOT_0,STO.ZLOTORI_0,STO.STA_0,STO.ZANCHO_0,STO.ZMANDRIL_0, STO.ZLONGITUD_0,sum(STO.QTYPCU_0) As CTD1,"+
& "sum(STO.QTYSTU_0) As CTD2,"
REQUEST(1)="sum(STO.QTYSTUACT_0) As CTD3,sum(STO.QTYPCUORI_0) As CTD4, sum(STO.QTYSTUORI_0) As CTD5,STO.LOC_0 AS UBICACION"+CAMPOPROVEEDOR
REQUEST(2)=" FROM STOCK "
REQUEST(3)=FILTRO
If [M:ZSFC1]ZPROVAGRUP=2

    REQUEST(4)="GROUP BY STO.STOFCY_0, STO.ITMREF_0, STO.LOT_0, STO.ZLOTORI_0, STO.STA_0,  STO.ZANCHO_0, STO.ZMANDRIL_0, STO.ZLONGITUD_0, STO.ZPROVEEDOR_0, STO.LOC_0 "
Else

    REQUEST(4)="GROUP BY STO.STOFCY_0, STO.ITMREF_0, STO.LOT_0, STO.ZLOTORI_0, STO.STA_0,  STO.ZANCHO_0, STO.ZMANDRIL_0, STO.ZLONGITUD_0, STO.LOC_0"
Endif

If [M:ZSFC1]ZPROVAGRUP=2

For (Char PLANTA(5), Char REFARTI(20), Char LOTE(15),Char LOTORI(15), Char ESTADO(5),
&    Shortint ANCHO, Shortint MANDRIL, Integer LONGITUD,
&    Double CANT1,Double CANT2,
&    Double CANT3,Double CANT4,Double CANT5, Char UBICACION(30),Char PROVEEDOR(15)) From "5" Sql REQUEST As [XXX]

#Call ECR_TRACE(time$+" "+"For - 1",0) From GESECRAN

  Raz NUMBOBINAS
  Raz BOBASIGNADAS

  SQLBOBINAS(0)="SELECT COUNT(STC.SLO_0) AS BOBINAS FROM STOCK STC INNER JOIN FACILITY FAC ON STC.STOFCY_0 = FAC.FCY_0 "
  SQLBOBINAS(1)="WHERE STC.ITMREF_0='"+[F:XXX]REFARTI+"' AND STC.ZANCHO_0="+num$([F:XXX]ANCHO)+" AND STC.ZMANDRIL_0="+num$([F:XXX]MANDRIL)+" AND STC.ZLONGITUD_0="+num$([F:XXX]LONGITUD) +" "
  SQLBOBINAS(2)="AND STC.STOFCY_0='"+[F:XXX]PLANTA+"' AND STC.ZLOTORI_0='"+[F:XXX]LOTORI+"' AND STC.LOC_0='"+[F:XXX]UBICACION+"' AND STC.LOT_0='"+[F:XXX]LOTE+"' AND STC.ZPROVEEDOR_0='"+[F:XXX]
& PROVEEDOR+"'"
  SQLBOBINAS(3)=" GROUP BY STC.STOFCY_0, STC.ITMREF_0, STC.STA_0, STC.ZANCHO_0, STC.ZMANDRIL_0, STC.ZLONGITUD_0,STC.ZPROVEEDOR_0, STC.LOT_0, STC.ZLOTORI_0, STC.LOC_0"

  For (Integer BOBINAS) From "5" Sql SQLBOBINAS As [YYY]
    NUMBOBINAS=NUMBOBINAS+[F:YYY]BOBINAS
  Next

  #DESARTI=""
  Raz [F:ITM]
  Read [ITM]ITM0=[F:XXX]REFARTI
  Raz [F:FCY]
  Read [F:FCY]FCY0=[F:XXX]PLANTA
  #DESARTI = [F:ITM]ITMDES1
  ZFACTOR = [F:ITM]ZFACTOR
  MEDIDA = [F:ITM]STU
  Gosub EXTRAER_CTDASIGNADA

  [M:ZSFC2]STOFCY(nolign)=[F:XXX]PLANTA
  [M:ZSFC2]STA(nolign)=[F:XXX]ESTADO
  [M:ZSFC2]ZANCHO(nolign)=[F:XXX]ANCHO
  [M:ZSFC2]ZMANDRIL(nolign)=[F:XXX]MANDRIL
  [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
  [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
  [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
  [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
  [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
  [M:ZSFC2]ZLONGITUD(nolign)=[F:XXX]LONGITUD
  [M:ZSFC2]LOT(nolign)=[F:XXX]LOTE
  [M:ZSFC2]ZLOTORI(nolign)=[F:XXX]LOTORI
  [M:ZSFC2]LOC(nolign)=[F:XXX]UBICACION
  [M:ZSFC2]ZQTYBOB(nolign)=NUMBOBINAS
  [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
  [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF
  [M:ZSFC2]BOBASI(nolign)=BOBASIGNADAS
  [M:ZSFC2]BOBDIS(nolign)=NUMBOBINAS - BOBASIGNADAS
  [M:ZSFC2]ZPROVEEDOR(nolign)=[F:XXX]PROVEEDOR
  [M:ZSFC2]ITMREF(nolign)=[F:XXX]REFARTI
  #[M:ZSFC2]ITMDES1(nolign)=DESARTI
  [M:ZSFC2]FCYSHO(nolign)=[F:FCY]FCYSHO

  #CANTIDADES EN KG
  If MEDIDA="KG" Then
      [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
      [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
      [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
      [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
      [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
      [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
      [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF

      #CANTIDADES EN M2
      [M:ZSFC2]ZQTYPCU(nolign)=[M:ZSFC2]QTYPCU(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYSTU(nolign)=[M:ZSFC2]QTYSTU(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYSTUACT(nolign)=[M:ZSFC2]QTYSTUACT(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYASIPEDM2(nolign)=[M:ZSFC2]ZQTYASIPED(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYASIOFM2(nolign)=[M:ZSFC2]ZQTYASIOF(nolign) / ZFACTOR
  Else
      [M:ZSFC2]ZQTYPCU(nolign)=[F:XXX]CANT1
      [M:ZSFC2]ZQTYSTU(nolign)=[F:XXX]CANT2
      [M:ZSFC2]ZQTYSTUACT(nolign)=[F:XXX]CANT3
      [M:ZSFC2]ZQTYASIPEDM2(nolign)=CANTIDADPEDIDO
      [M:ZSFC2]ZQTYASIOFM2(nolign)=CANTIDADOF

      [M:ZSFC2]QTYPCU(nolign)=[M:ZSFC2]ZQTYPCU(nolign) * ZFACTOR
      [M:ZSFC2]QTYSTU(nolign)=[M:ZSFC2]ZQTYSTU(nolign) * ZFACTOR
      [M:ZSFC2]QTYSTUACT(nolign)=[M:ZSFC2]ZQTYSTUACT(nolign) * ZFACTOR
      [M:ZSFC2]ZQTYASIPED(nolign)=[M:ZSFC2]ZQTYASIPEDM2(nolign) * ZFACTOR
      [M:ZSFC2]ZQTYASIOF(nolign)=[M:ZSFC2]ZQTYASIOFM2(nolign) * ZFACTOR
  Endif
  nolign+=1
  If nolign=500 Then
      Infbox("La consulta devuelve demasiados registros. Se visualizarán los 500 primeros")
      Break
  Endif
Next
Else


For (Char PLANTA(5), Char REFARTI(20), Char LOTE(15),Char LOTORI(15), Char ESTADO(5),
&    Shortint ANCHO, Shortint MANDRIL, Integer LONGITUD,
&    Double CANT1,Double CANT2,
&    Double CANT3,Double CANT4,Double CANT5,Char UBICACION(30)) From "5" Sql REQUEST As [XXX]


#For (Char REFARTI(20),Char PLANTA(5),Char ESTADO(5),Shortint ANCHO,Shortint MANDRIL,Integer LONGITUD,Char LOTE(15),Char SERIELOTE(15),Double CANT1,Double CANT2,Double CANT3,Double CANT4,Double CANT5
#& ,Char NOMPLANTA(15)) From "5" Sql REQUEST As [XXX]


  Raz NUMBOBINAS
  Raz BOBASIGNADAS

  SQLBOBINAS(0)="SELECT COUNT(STC.SLO_0) AS BOBINAS FROM STOCK STC INNER JOIN FACILITY FAC ON STC.STOFCY_0 = FAC.FCY_0 "
  SQLBOBINAS(1)="WHERE STC.ITMREF_0='"+[F:XXX]REFARTI+"' AND STC.ZANCHO_0="+num$([F:XXX]ANCHO)+" AND STC.ZMANDRIL_0="+num$([F:XXX]MANDRIL)+" AND STC.ZLONGITUD_0="+num$([F:XXX]LONGITUD) +" "
  SQLBOBINAS(2)="AND STC.STOFCY_0='"+[F:XXX]PLANTA+"' AND STC.ZLOTORI_0='"+[F:XXX]LOTORI+"' AND STC.LOC_0='"+[F:XXX]UBICACION+"' AND STC.LOT_0='"+[F:XXX]LOTE+"'"
  SQLBOBINAS(3)=" GROUP BY STC.STOFCY_0, STC.ITMREF_0, STC.STA_0, STC.ZANCHO_0, STC.ZMANDRIL_0, STC.ZLONGITUD_0, STC.LOT_0, STC.SLO_0, STC.ZLOTORI_0"

  For (Integer BOBINAS) From "5" Sql SQLBOBINAS As [YYY]
    NUMBOBINAS=NUMBOBINAS + [F:YYY]BOBINAS
  Next

  #DESARTI=""
  Raz [F:ITM]
  Read [ITM]ITM0=[F:XXX]REFARTI
  ZFACTOR = [F:ITM]ZFACTOR
  MEDIDA = [F:ITM]STU
  Raz [F:FCY]
  Read [F:FCY]FCY0=[F:XXX]PLANTA
  #DESARTI = [F:ITM]ITMDES1

  Gosub EXTRAER_CTDASIGNADA

  [M:ZSFC2]STOFCY(nolign)=[F:XXX]PLANTA
  [M:ZSFC2]STA(nolign)=[F:XXX]ESTADO
  [M:ZSFC2]ZANCHO(nolign)=[F:XXX]ANCHO
  [M:ZSFC2]ZMANDRIL(nolign)=[F:XXX]MANDRIL
  [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
  [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
  [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
  [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
  [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
  [M:ZSFC2]ZLONGITUD(nolign)=[F:XXX]LONGITUD
  [M:ZSFC2]LOT(nolign)=[F:XXX]LOTE
  [M:ZSFC2]ZLOTORI(nolign)=[F:XXX]LOTORI
  [M:ZSFC2]LOC(nolign)=[F:XXX]UBICACION
  [M:ZSFC2]ZQTYBOB(nolign)=NUMBOBINAS
  [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
  [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF
  [M:ZSFC2]BOBASI(nolign)=BOBASIGNADAS
  [M:ZSFC2]BOBDIS(nolign)=NUMBOBINAS - BOBASIGNADAS
  [M:ZSFC2]ZPROVEEDOR(nolign)=""
  [M:ZSFC2]ITMREF(nolign)=[F:XXX]REFARTI
  #[M:ZSFC2]ITMDES1(nolign)=DESARTI
  [M:ZSFC2]FCYSHO(nolign)=[F:FCY]FCYSHO

  #CANTIDADES EN KG
  If MEDIDA="KG" Then
      [M:ZSFC2]QTYPCU(nolign)=[F:XXX]CANT1
      [M:ZSFC2]QTYSTU(nolign)=[F:XXX]CANT2
      [M:ZSFC2]QTYSTUACT(nolign)=[F:XXX]CANT3
      [M:ZSFC2]QTYPCUORI(nolign)=[F:XXX]CANT4
      [M:ZSFC2]QTYSTUORI(nolign)=[F:XXX]CANT5
      [M:ZSFC2]ZQTYASIPED(nolign)=CANTIDADPEDIDO
      [M:ZSFC2]ZQTYASIOF(nolign)=CANTIDADOF

      #CANTIDADES EN M2
      [M:ZSFC2]ZQTYPCU(nolign)=[M:ZSFC2]QTYPCU(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYSTU(nolign)=[M:ZSFC2]QTYSTU(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYSTUACT(nolign)=[M:ZSFC2]QTYSTUACT(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYASIPEDM2(nolign)=[M:ZSFC2]ZQTYASIPED(nolign) / ZFACTOR
      [M:ZSFC2]ZQTYASIOFM2(nolign)=[M:ZSFC2]ZQTYASIOF(nolign) / ZFACTOR
  Else
      [M:ZSFC2]ZQTYPCU(nolign)=[F:XXX]CANT1
      [M:ZSFC2]ZQTYSTU(nolign)=[F:XXX]CANT2
      [M:ZSFC2]ZQTYSTUACT(nolign)=[F:XXX]CANT3
      [M:ZSFC2]ZQTYASIPEDM2(nolign)=CANTIDADPEDIDO
      [M:ZSFC2]ZQTYASIOFM2(nolign)=CANTIDADOF

      [M:ZSFC2]QTYPCU(nolign)=[M:ZSFC2]ZQTYPCU(nolign) * ZFACTOR
      [M:ZSFC2]QTYSTU(nolign)=[M:ZSFC2]ZQTYSTU(nolign) * ZFACTOR
      [M:ZSFC2]QTYSTUACT(nolign)=[M:ZSFC2]ZQTYSTUACT(nolign) * ZFACTOR
      [M:ZSFC2]ZQTYASIPED(nolign)=[M:ZSFC2]ZQTYASIPEDM2(nolign) * ZFACTOR
      [M:ZSFC2]ZQTYASIOF(nolign)=[M:ZSFC2]ZQTYASIOFM2(nolign) * ZFACTOR
  Endif
  nolign+=1
  If nolign=3000 Then
      Infbox("La consulta devuelve demasiados registros. Se visualizarán los 3000 primeros")
      Break
  Endif
Next

Endif

Gosub CALCULAR_TOTALES

[M:ZSFC2]NBLIG=nolign
#If [M:ZSFC2]NBLIG>0
#   Affzo [M:ZSFC2]5
#Endif

Call ECR_TRACE(time$+" "+"Fin proceso",0) From GESECRAN
Call FERME_TRACE From LECFIC
Return

$EXEBOUT
Return

$AP_MAGNETO
[M:ZSFC1]FLG = 0
Return

$CLECUR
If CLECUR=1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:ZSFC1]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   #Affzo [M:ZSFC1]ITMDES1
Endif
Return

$EXTRAER_CTDASIGNADA
#Return
Raz BOBASIGNADAS
Raz FILTRO_CANT
Raz BOBASIGNADAS
Raz CANTIDADPEDIDO
Raz CANTIDADOF
Raz FILTRO_PROV
 If [M:ZSFC1]ZCONDETALLE=1  Then
  #Infbox("FLO")
    #FILTRO_CANT = " AND (STOCK.LOT_0='"+[F:XXX]LOTE+"') AND STOCK.SLO='"+[F:XXX]SERIELOTE+"'"
    FILTRO_CANT = " AND (STOCK.STOFCY_0='"+[F:XXX]PLANTA+"' AND STOCK.ZLOTORI_0='"+[F:XXX]LOTORI+"' AND STOCK.LOT_0='"+[F:XXX]LOTE+"' AND STOCK.LOC_0='"+[F:XXX]UBICACION+"')"
    #Infbox(FILTRO_CANT)
 Endif


###################################################
#EXTRAEMOS LA CANTIDAD ASIGNADA EN PEDIDOS
If [M:ZSFC1]ZPROVAGRUP=2 Then
    CAMPOPROVEEDOR=" AND (STOCK.ZPROVEEDOR_0='"+[F:XXX]PROVEEDOR+"') "
Else
    If ([M:ZSFC1]ZPROVEEDOR<>"") Then
        CAMPOPROVEEDOR=" AND STOCK.ZPROVEEDOR_0='"+[M:ZSFC1]ZPROVEEDOR+"'"
    Else
        CAMPOPROVEEDOR=""
    Endif
Endif

SQLCANT(0)="SELECT SUM(STOALL.QTYSTU_0) AS CANTIDAD,COUNT(*) AS BOBAS FROM STOCK INNER JOIN STOALL ON STOCK.STOFCY_0 = STOALL.STOFCY_0 "
SQLCANT(1)="AND STOCK.ITMREF_0 = STOALL.ITMREF_0 AND STOCK.STOCOU_0 = STOALL.STOCOU_0 WHERE (STOCK.ITMREF_0='"+[F:XXX]REFARTI+"') AND (STOCK.ZANCHO_0="+num$([F:XXX]ANCHO)+") "
SQLCANT(2)="AND (STOCK.ZMANDRIL_0="+num$([F:XXX]MANDRIL)+") AND (STOCK.ZLONGITUD_0="+num$([F:XXX]LONGITUD)+")"+CAMPOPROVEEDOR+" AND STOALL.VCRTYP_0 IN(2,4) AND STOCK.STOFCY_0='"
&+[F:XXX]PLANTA+"'"
SQLCANT(3)=FILTRO_CANT
For (Double CANT,Integer BOBAS) From "5" Sql SQLCANT As [ZZZ]

    CANTIDADPEDIDO=[F:ZZZ]CANT
    If [F:ZZZ]CANT>0 Then
      BOBASIGNADAS=[F:ZZZ]BOBAS
    Endif

Next

###################################################
#EXTRAEMOS LA CANTIDAD ASIGNADA EN PEDIDOS DE VENTA
SQLCANT(0)="SELECT SUM(STOALL.QTYSTU_0) AS CANTIDAD,COUNT(*) AS BOBAS FROM STOCK INNER JOIN STOALL ON STOCK.STOFCY_0 = STOALL.STOFCY_0 "
SQLCANT(1)="AND STOCK.ITMREF_0 = STOALL.ITMREF_0 AND STOCK.STOCOU_0 = STOALL.STOCOU_0 WHERE (STOCK.ITMREF_0='"+[F:XXX]REFARTI+"') AND (STOCK.ZANCHO_0="+num$([F:XXX]ANCHO)+") "
SQLCANT(2)="AND (STOCK.ZMANDRIL_0="+num$([F:XXX]MANDRIL)+") AND (STOCK.ZLONGITUD_0="+num$([F:XXX]LONGITUD)+")"+CAMPOPROVEEDOR+" AND STOALL.VCRTYP_0=10 AND STOCK.STOFCY_0='"
&+[F:XXX]PLANTA+"'"
SQLCANT(3)=FILTRO_CANT
For (Double CANT, Integer BOBAS) From "5" Sql SQLCANT As [ZZZ]
    CANTIDADOF=[F:ZZZ]CANT
    If [F:ZZZ]CANT>0 Then
        BOBASIGNADAS+=[F:ZZZ]BOBAS
    Endif
Next

Return

$CALCULAR_TOTALES
###############################################################
nolign=nolign+1
 #pcolor = GCOUL(3)

 [M:ZSFC2]STOFCY(nolign-1) = "***"
 [M:ZSFC2]FCYSHO(nolign-1) = toupper(mess(142,124,1))
 Raz [M:ZSFC2]ZANCHO(nolign-1)
 Raz [M:ZSFC2]ZLONGITUD(nolign-1)
 Raz [M:ZSFC2]ZMANDRIL(nolign-1)
 Raz [M:ZSFC2]ZPROVEEDOR(nolign-1)


For FILAS=0 To nolign-2
    [M:ZSFC2]ZQTYBOB(nolign-1)=[M:ZSFC2]ZQTYBOB(nolign-1) + [M:ZSFC2]ZQTYBOB(FILAS)
    [M:ZSFC2]ZQTYASIPED(nolign-1)=[M:ZSFC2]ZQTYASIPED(nolign-1) + [M:ZSFC2]ZQTYASIPED(FILAS)
    [M:ZSFC2]ZQTYASIOF(nolign-1)=[M:ZSFC2]ZQTYASIOF(nolign-1) + [M:ZSFC2]ZQTYASIOF(FILAS)
    [M:ZSFC2]BOBASI(nolign-1)=[M:ZSFC2]BOBASI(nolign-1) + [M:ZSFC2]BOBASI(FILAS)
    [M:ZSFC2]BOBDIS(nolign-1)=[M:ZSFC2]BOBDIS(nolign-1) + [M:ZSFC2]BOBDIS(FILAS)

    [M:ZSFC2]QTYPCU(nolign-1)=[M:ZSFC2]QTYPCU(nolign-1) + [M:ZSFC2]QTYPCU(FILAS)
    [M:ZSFC2]QTYSTU(nolign-1)=[M:ZSFC2]QTYSTU(nolign-1) + [M:ZSFC2]QTYSTU(FILAS)
    [M:ZSFC2]QTYSTUACT(nolign-1)=[M:ZSFC2]QTYSTUACT(nolign-1) + [M:ZSFC2]QTYSTUACT(FILAS)
    [M:ZSFC2]QTYPCUORI(nolign-1)=[M:ZSFC2]QTYPCUORI(nolign-1) + [M:ZSFC2]QTYPCUORI(FILAS)
    [M:ZSFC2]QTYSTUORI(nolign-1)=[M:ZSFC2]QTYSTUORI(nolign-1) + [M:ZSFC2]QTYSTUORI(FILAS)

    [M:ZSFC2]ZQTYASIPEDM2(nolign-1)=[M:ZSFC2]ZQTYASIPEDM2(nolign-1) + [M:ZSFC2]ZQTYASIPEDM2(FILAS)
    [M:ZSFC2]ZQTYASIOFM2(nolign-1)=[M:ZSFC2]ZQTYASIOFM2(nolign-1) + [M:ZSFC2]ZQTYASIOFM2(FILAS)
    [M:ZSFC2]ZQTYPCU(nolign-1)=[M:ZSFC2]ZQTYPCU(nolign-1) + [M:ZSFC2]ZQTYPCU(FILAS)
    [M:ZSFC2]ZQTYSTU(nolign-1)=[M:ZSFC2]ZQTYSTU(nolign-1) + [M:ZSFC2]ZQTYSTU(FILAS)
    [M:ZSFC2]ZQTYSTUACT(nolign-1)=[M:ZSFC2]ZQTYSTUACT(nolign-1) + [M:ZSFC2]ZQTYSTUACT(FILAS)

Next

Return


$MONTAR_SQL    #JLPR 19-12-16
Raz FILTRO
#FILTRO=" Where 1=1 "
#JLPR 17-11-16 S/Tachi no hemos de permitir que se escoga stock de las ubicaciones  PTREVISI + DEVOLUCI
#FILTRO="Where not (LOC_0='PTREVISI' or LOC_0='DEVOLUCI') "
FILTRO="Where 1=1 "
If [M:ZSFC1]FCY<>""
    FILTRO += "and STOFCY_0='"+[M:ZSFC1]FCY+"' "
Endif
If [M:ZSFC1]ITMREF<>""
    FILTRO += "and ITMREF_0>='"+[M:ZSFC1]ITMREF+"' "
Endif
If [M:ZSFC1]ITMREFHASTA<>"" Then
    FILTRO += "and ITMREF_0<='"+[M:ZSFC1]ITMREFHASTA+"' "
Endif
If [M:ZSFC1]ANCHODESDE>0
    FILTRO +=" and ZANCHO_0>="+num$([M:ZSFC1]ANCHODESDE)+" "
Endif
If [M:ZSFC1]ANCHOHASTA<>0
    FILTRO +=" and ZANCHO_0<="+num$([M:ZSFC1]ANCHOHASTA)+" "
Endif
If [M:ZSFC1]MANDRIL>0
    FILTRO +=" and ZMANDRIL_0="+num$([M:ZSFC1]MANDRIL)+" "
Endif
If [M:ZSFC1]LONGITUD>0
    FILTRO +=" and ZLONGITUD_0>="+num$([M:ZSFC1]LONGITUD)+" "
Endif
If [M:ZSFC1]LONGITUD2>0
    FILTRO +=" and ZLONGITUD_0<="+num$([M:ZSFC1]LONGITUD2)+" "
Endif
If [M:ZSFC1]ZPROVEEDOR<>"" Then
    FILTRO +=" and ZPROVEEDOR_0='"+[M:ZSFC1]ZPROVEEDOR+"' "
Endif

Raz FLD
If [M:ZSFC1]ZPROVAGRUP=2
    FLD(0)=",ZPROVEEDOR_0 "
    FLD(1)=",ZPROVEEDOR_0 "
Else
    FLD(0)=",'' as ZPROVEEDOR_0 "
    FLD(1)=""
Endif
If [M:ZSFC1]ZDETALLADO=2
    FLD(2)=",LOT_0,ZLOTORI_0,LOC_0 "
    FLD(3)=",LOT_0,ZLOTORI_0,LOC_0 "
Else
    FLD(2)=",'' as LOT_0,'' as ZLOTORI_0,'' as LOC_0 "
    FLD(3)=""
Endif
#REQUEST(0)="SELECT STO.STOFCY_0,STO.ITMREF_0,STO.LOT_0,STO.ZLOTORI_0,STO.STA_0,STO.ZANCHO_0,STO.ZMANDRIL_0, STO.ZLONGITUD_0,sum(STO.QTYPCU_0) As CTD1,"+
#& "sum(STO.QTYSTU_0) As CTD2,"
#REQUEST(1)="sum(STO.QTYSTUACT_0) As CTD3,sum(STO.QTYPCUORI_0) As CTD4, sum(STO.QTYSTUORI_0) As CTD5,STO.LOC_0 AS UBICACION"+CAMPOPROVEEDOR

#REQUEST(0)="SELECT STOCK.STOFCY_0, STOCK.STA_0, STOCK.ZANCHO_0, STOCK.ZMANDRIL_0, STOCK.ZLONGITUD_0, sum(STOCK.QTYPCU_0) As CTD1, sum(STOCK.QTYSTU_0) As CTD2, sum(STOCK.QTYSTUACT_0) As CTD3,"
#REQUEST(1)="sum(STOCK.QTYPCUORI_0) As CTD4, sum(STOCK.QTYSTUORI_0) As CTD5, COUNT(STOCK.SLO_0) AS BOBINAS,"+CAMPOPROVEEDOR+"STOCK.ITMREF_0 "

#Montar SQL
REQUEST(0)="SELECT   STOFCY_0,ITMREF_0,STA_0,ZANCHO_0,ZMANDRIL_0,ZLONGITUD_0"+FLD(2)+FLD(0)+",sum(QTYPCU_0) As CTD1,sum(QTYSTU_0) As CTD2,"
REQUEST(1)="sum(QTYSTUACT_0) As CTD3,sum(QTYPCUORI_0) As CTD4, sum(QTYSTUORI_0) As CTD5, sum(CUMALLQTY_0) As CTD6, count(SLO_0) AS BOBINAS "
REQUEST(2)="from STOCK "
REQUEST(3)=FILTRO
REQUEST(4)="group by STOFCY_0,ITMREF_0,STA_0,ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0"+FLD(3)+FLD(1)+" "
REQUEST(5)="order by STOFCY_0,ITMREF_0"+FLD(3)+",STA_0,ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0"+FLD(1)
Return


##########################################################################
#Subprog AV_FCY(VALEUR)
#Variable Char     VALEUR
#If [M]FCYSEL <> ""
#   mkstat = 1
#Endif
#End
