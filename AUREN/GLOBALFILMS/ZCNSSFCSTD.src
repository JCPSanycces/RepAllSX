$FERME
#Infbox "ZCNSSFCSTD-FERME"+" "+num$(dim(ZANCHO))+" "+num$(dim(ZLONGITUD))+" "+num$(dim(ZMANDRIL))+" "+num$(dim(ZPROVEEDOR))
If GFONC1="GESSOH"
   If nolign>0
      [M:SOH0]ZANCHOAUX =[M:ZSFC2]ZANCHO(nolign-1)
      [M:SOH0]ZMANDRILAUX =[M:ZSFC2]ZMANDRIL(nolign-1)
      [M:SOH0]ZLONGITUDAUX =[M:ZSFC2]ZLONGITUD(nolign-1)
      #ZPROVEEDOR =[M:ZSFC2]ZPROVEEDOR(nolign-1)
      #Infbox num$(nolign-1)+" "+num$(ZANCHO)+" "+num$(ZLONGITUD)+" "+num$(ZMANDRIL)+" "+ZPROVEEDOR
   Endif
Endif
