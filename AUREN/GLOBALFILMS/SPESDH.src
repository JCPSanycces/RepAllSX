$PRECIOS
Gosub RECH_TARIF_TRSP From SUBSDHA
#
Local Integer F,YN
Local Char MSGW(255)
For F=0 To [M:SDH1]NBLIG-1
  If  [M:SDH1]GROPRI(F)<=0
    MSGW+=num$(F+1)+"-"
  Endif
Next
If MSGW<>""# and GUSER="ADMIN"
  MSGW="ESTA SEGURO DE CONTINUAR\.\Las siguientes lineas tiene precio 0 !!\"+MSGW
  YN=1 # Por defecto NO
  Call OUINON(MSGW, YN) From GESECRAN
  If YN=1
    OK=0
    Return
  Endif
Endif
# Si ventan en M2 comprobar que QTY=Bob*M2
#> 20180821 - al poner integer redondeaba los decimales
#Local Integer M2
Local Decimal M2
#< 20180821
Local Decimal LANCHO
Raz MSGW,M2
For F=0 To [M:SDH1]NBLIG-1
#> 20180821 - el índice NOL no existe, debe ser F
  #LANCHO=func SPESOH.MODIFICA_ANCHO_DIVISOR([M:SDH1]ITMREF(NOL),[M:SDH1]ZANCHO(F))
  LANCHO=func SPESOH.MODIFICA_ANCHO_DIVISOR([M:SDH1]ITMREF(F),[M:SDH1]ZANCHO(F))
#< 20180821
  M2=[M:SDH1]ZQTYBOB(F)*LANCHO*[M:SDH1]ZLONGITUD(F)/1000
  If  [M:SDH1]SAU(F)="M2" and  [M:SDH1]QTY(F)<>M2
    MSGW+=num$(F+1)+"- Cantidad indicada "+num$( [M:SDH1]QTY(F))+" <> Superficie "+num$(M2)+"\"
  Endif
Next
If MSGW<>""# and GUSER="ADMIN"
    Call ERREURT("Ventas en M2 !!!\"+MSGW, 1) From GESECRAN   #0-Informativo, 1-Error
#    OK=0
#    Return
Endif
Return

#$VERIF_CRE
#Gosub RECH_TARIF_TRSP From SUBSDHA
#Return
#
#$VERIF_MOD
#Gosub RECH_TARIF_TRSP From SUBSDHA
#Return

$APRES_CRE
Local Shortint WIDENT3, WLI, WLJ, WLK
Local Char WITMREF(20)(1..30)

If clalev([F:AOX])<=0  : Local File AOBJTXT [AOX]  : Endif
If clalev([F:AOX1])<=0 : Local File AOBJTXT [AOX1] : Endif

Delete [AOX1] Where ABREV="SDH" and IDENT1=[M:SDH0]SDHNUM
If fstat
   Infbox "Error borrando COA - fstat: "+num$(fstat)
Endif

#Obtenemos el maximo IDENT3
Filter [AOX1] Where ABREV="SDH" and IDENT1=[M:SDH0]SDHNUM
WIDENT3=0
For [AOX1]
   If WIDENT3<val([F:AOX1]IDENT3)
      WIDENT3=val([F:AOX1]IDENT3)
   Endif
Next
Filter [AOX1]

Raz WITMREF
WLK=0
#Adjuntamos a la entrega el COA de cada articulo
For WLI=0 To [M:SDH1]NBLIG-1
   If !find([M:SDH1]ITMREF(WLI),WITMREF)
      WLK+=1
      WITMREF(WLK)=[M:SDH1]ITMREF(WLI)
      Filter [AOX] Where ABREV="ITM" and IDENT1=[M:SDH1]ITMREF(WLI) and MOTCLE(0)="COA"
      For [AOX]
         WIDENT3+=1
         Raz [F:AOX1]
         [F:AOX1]ABREV   ='SDH'
         [F:AOX1]IDENT1  =[M:SDH0]SDHNUM
         [F:AOX1]IDENT3  = format$("N0:3",WIDENT3)
         [F:AOX1]TYPDOC  =[F:AOX]TYPDOC
         [F:AOX1]NAM     =[F:AOX]NAM
         [F:AOX1]CAT     =[F:AOX]CAT
         [F:AOX1]IDTSTO  =[F:AOX]IDTSTO
         [F:AOX1]IDTCNT  =[F:AOX]IDTCNT
         [F:AOX1]VERSION =[F:AOX]VERSION
         For WLJ=0 To 4
            [F:AOX1]MOTCLE(WLJ)=[F:AOX]MOTCLE(WLJ)
         Next
         Write [AOX1]
         If fstat
            Infbox "Error grabando COA - fstat: "+num$(fstat)
         Endif
      Next
      Filter [AOX]
   Endif
Next

Call CAL_QTY([M:SDH0]SDHNUM)

#If GUSER="ADMIN"
Gosub MODQTYSOQ
#Endif

#JLPR 15-02-17 INI
Call MOD_SPACK([M:SDH0]SDHNUM)
#JLPR 15-02-17 FIN
Return


Subprog MOD_SPACK(ENT)
Value Char ENT
#If GUSER<>"ADMIN" : End : Endif
# SOLO si vendo en KGS y CantidadReal<>Cantidad
# Calculo peso de una bobina
# Actualizo peso en SPACKD  NETWEI
# Actualizo peso en SPACK   NETWEI
# Actualizo peso en SDELIVERY
Local Decimal KG_BOB,KG_BOB_STU,KG_WEI,KGSPCK
If clalev([F:SDHX])<=0 : Local File SDELIVERY  [F:SDHX] : Endif
If clalev([F:SDDX])<=0 : Local File SDELIVERYD [F:SDDX] : Endif
If clalev([F:SPDX])<=0 : Local File SPACKD     [F:SPDX] : Endif
If clalev([F:SPHX])<=0 : Local File SPACK      [F:SPHX] : Endif
If clalev([F:ITMX])<=0 : Local File ITMMASTER  [F:ITMX] : Endif
# Actualizo peso en SPACKD  NETWEI
Filter [F:SDDX] Where SDHNUM=ENT
For [F:SDDX]
   If [F:SDDX]SAU="KG"
      KGSPCK=func KGS_SPACKD(ENT,[F:SDDX]SOPLIN)
      If [F:SDDX]ZCTDREAL<>[F:SDDX]QTY or (KGSPCK>0 and [F:SDDX]ZCTDREAL<>KGSPCK)
        Read [F:ITMX]ITM0=[F:SDDX]ITMREF
        KG_BOB= [F:SDDX]ZCTDREAL/[F:SDDX]ZQTYBOB
        Call QTEARR(KG_BOB    , [F:SDDX]SAU) From TRTDIV
        KG_BOB_STU= KG_BOB * [F:SDDX]SAUSTUCOE
        Call QTEARR(KG_BOB_STU, [F:SDDX]STU) From TRTDIV
        KG_WEI    = KG_BOB_STU * [F:ITM]ITMWEI
        If [F:SDDX]ZQTYBOB=1
          Update [F:SPDX] Where VCRTYP=4 and VCRNUM=ENT and VCRLIN=[F:SDDX]SOPLIN               With NETWEI=KG_WEI,QTY=KG_BOB_STU,QTYPCU=KG_BOB_STU
        Else
          Update [F:SPDX] Where VCRTYP=4 and VCRNUM=ENT and VCRLIN=[F:SDDX]SOPLIN and PACIND>1  With NETWEI=KG_WEI,QTY=KG_BOB_STU,QTYPCU=KG_BOB_STU
          KG_BOB_STU+=[F:SDDX]ZCTDREAL-(KG_BOB_STU*[F:SDDX]ZQTYBOB)
          Call QTEARR(KG_BOB_STU, [F:SDDX]STU) From TRTDIV
          KG_WEI     = KG_BOB_STU * [F:ITM]ITMWEI
          Update [F:SPDX] Where VCRTYP=4 and VCRNUM=ENT and VCRLIN=[F:SDDX]SOPLIN and PACIND=1  With NETWEI=KG_WEI,QTY=KG_BOB_STU,QTYPCU=KG_BOB_STU
        Endif
      Endif
   Endif
Next
Filter [F:SDDX]
# Actualizo peso en SPACK   NETWEI     y aprovecho para calcular TOT_WEI y TOT_TARA
Local Char RPCK(GLONVCR)
Local Decimal TOT_WEI,TOT_TARA
Raz RPCK,TOT_WEI,TOT_TARA
Filter [F:SPDX] Where VCRTYP=4 and VCRNUM=ENT Order By PACNUM
For [F:SPDX]
  If RPCK<>[F:SPDX]PACNUM
    Gosub ACT_SPACK
    RPCK=[F:SPDX]PACNUM
  Endif
  KG_BOB +=[F:SPDX]NETWEI
  TOT_WEI+=[F:SPDX]NETWEI
Next
Filter [F:SPDX]
Gosub ACT_SPACK
# Actualizo pesos en SDELIVERY
Update [F:SDHX] Where SDHNUM=ENT With NETWEI=TOT_WEI,GROWEI=TOT_WEI+TOT_TARA
End

$ACT_SPACK
If RPCK<>""
  Update [F:SPHX]  Where VCRTYP=4 and VCRNUM=ENT and PACNUM=RPCK With NETWEI=KG_BOB
  Filter [F:SPHX]  Where VCRTYP=4 and VCRNUM=ENT and PACNUM=RPCK
  For [F:SPHX]
    TOT_TARA+=[F:SPHX]PCKWEI
    Break
  Next
  Filter [F:SPHX]
Endif
Raz KG_BOB
Return

Funprog KGS_SPACKD(ENT,LIN)
Value Char ENT
Value Integer LIN
Local Decimal KGS
If clalev([F:SPDX])<=0 : Local File SPACKD     [F:SPDX] : Endif
Filter [F:SPDX] Where VCRTYP=4 and VCRNUM=ENT and VCRLIN=LIN
Raz KGS
For [F:SPDX]
  KGS+=[F:SPDX]QTY
Next
Filter [F:SPDX]
End KGS



$MODQTYSOQ
Local Integer LLINEA, LBOBSER

#Esta sin terminar

#Solamente funciona cuando se crea, modifica y borra una línea, no cuando se modifica la linea
#mediante la accion de modificacion de las salidas de stock
If clalev([F:SOQX])<=0 : Local File SORDERQ    [SOQX] : Endif
If clalev([F:SDDX])<=0 : Local File SDELIVERYD [SDDX] : Endif
For LLINEA=0 To [M:SDH1]NBLIG-1
   Filter [SDDX] Where SOHNUM=[M:SDH1]XSOHNUM(LLINEA) and SOPLIN=[M:SDH1]SOPLIN(LLINEA) and SOQSEQ=[M:SDH1]SOQSEQ(LLINEA)
   LBOBSER=0
   For [SDDX]
      LBOBSER+=[F:SDDX]ZQTYBOB
   Next
   Filter [SDDX]
   Update [SOQX] Where SOHNUM=[M:SDH1]XSOHNUM(LLINEA) and SOPLIN=[M:SDH1]SOPLIN(LLINEA) and SOQSEQ=[M:SDH1]SOQSEQ(LLINEA)
&         With   ZDLVQTYBOB=LBOBSER
   If fstat
      Infbox "Error modificando pedido - bobinas entregadas"
   Endif
Next
Return



