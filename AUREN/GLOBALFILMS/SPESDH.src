$ACTION
#If GUSER='ADMIN' : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        :   Gosub OUVRE
  When "SETBOUT"      :   Gosub SETBOUT
  When "INIMOD"       :   Gosub INIMOD
  When "VERIF_MOD"    :   Gosub PRECIOS #VERIF_MOD
  When "VERIF_CRE"    :   Gosub PRECIOS #VERIF_CRE
  When "MODIF"        :   Gosub MODIF
  When "CREATION"     :   Gosub CREATION
  When "ANNULE"       :   Gosub ANNULE
  When "INICRE_LIG"   :   Gosub INICRE_LIG
  When "INIMOD_LIG"   :   Gosub INIMOD_LIG
  When "FILGAUCHE"    :   Gosub FILGAUCHE
  When "APRES_CRE"    :   Gosub APRES_CRE
  When "APRES_MOD"    :   Gosub APRES_CRE
  When "VALLIG"       :   Gosub VALLIG
  When "LIENS_LIG"    :   Gosub LIENS_LIG
  When "LIENS"        :   Gosub LIENS
  When "BB1_NBLIG"    :   Gosub BB1_NBLIG
  When "FIN_PICK"     :   Gosub FIN_PICK
  When "AB1_QTY"      :   Gosub AB1_QTY
  When "BB1_QTY"      :   Gosub BB1_QTY
  When "BB1_NBLIG"    :   Gosub BB2_NBLIG
  When "AV_IMPRIME"   :   Gosub AV_IMPRIME
 When Default
Endcase
Return

$OUVRE
Gosub ZPV_OUVRE
Return

$CREATION
