$AV_IMPRIME
#Local Integer LQTYBOBSD, LQTYBOBPD
#
#If clalev([F:SDDX])<=0 :  Local File SDELIVERYD [SDDX] :  Endif
#If clalev([F:SPDX])<=0 :  Local File SPACKD     [SPDX] :  Endif
