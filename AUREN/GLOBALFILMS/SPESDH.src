#
#Filter [SPDX] Where VCRTYP=4 and VCRNUM=[M:SDH0]SDHNUM
#For [SPDX]
#   LQTYBOBPD+=1
#Next
#Filter [SPDX]
#If LQTYBOBSD<>LQTYBOBPD
#   Infbox "Empaquetado incorrecto. Ctd. entrega: "+num$(LQTYBOBSD)+"  Ctd. empaq.: "+num$(LQTYBOBPD)
#   OK=0
#Endif
If [M:SDH0]ZAVISO<>""
  Call ERREURT([M:SDH0]ZAVISO, 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Elsif not ZGOK   #No se imprime si hay diferencias y ya se valido/facturó
  OK=0
Endif
Return

Subprog EMPAQUETADO_OK(LIN,ZOK)
Value    Integer LIN
Variable Integer ZOK   :  ZOK=1
#
Local Integer LQTYBOBSD, LQTYBOBPD
Local Decimal LQTYKGSSD, LQTYKGSPD
Local Char    WMSG(80), CRIT(100)(2)

If clalev([F:SDDX])<=0 :  Local File SDELIVERYD [SDDX] :  Endif
If clalev([F:SPDX])<=0 :  Local File SPACKD     [SPDX] :  Endif

If LIN=0   Raz [M:SDH0]ZAVISO    Endif

CRIT(0)="SDHNUM=[M:SDH0]SDHNUM"
CRIT(1)="VCRTYP=4&VCRNUM=[M:SDH0]SDHNUM"
If LIN>0
  CRIT(0)+="&SDDLIN=LIN"
  CRIT(1)+="&VCRLIN=LIN"
Endif
Filter [SDDX] Where evalue(CRIT(0))
For [SDDX]
   LQTYBOBSD+=[F:SDDX]ZQTYBOB
   LQTYKGSSD+=[F:SDDX]ZCTDREALUS
Next
Filter [SDDX]

Filter [SPDX] Where evalue(CRIT(1))
For [SPDX]
   LQTYBOBPD+=1
   LQTYKGSPD+=[SPDX]QTY
Next
Filter [SPDX]
If LQTYBOBPD<>0 and LQTYBOBSD<>LQTYBOBPD
   WMSG+="\ Bob.entrega: "+num$(LQTYBOBSD)+" <>  empaq "+num$(LQTYBOBPD)
Endif
If LQTYKGSPD=0
  WMSG+="Sin empaquetado"
Elsif LQTYKGSSD<>LQTYKGSPD
   WMSG+="\ Kgs.entrega: "+num$(LQTYKGSSD)+" <>  empaq "+num$(LQTYKGSPD)
Endif
If WMSG=""
  Chgfmt [M:SDH0]ZAVISO With "-"
  If LIN=0   ZGOK=1    Endif
Elsif  [M:SDH1]CFMFLG=2 or [M:SDH1]INVFLG=2
  ZGOK=0
Else
  If LQTYKGSPD<>0 ZOK=0   Endif
  If LIN=0
    Chgfmt [M:SDH0]ZAVISO With "+"
    If LQTYKGSPD=0
    [M:SDH0]ZAVISO=WMSG
    Else
    [M:SDH0]ZAVISO="Revise empaquetado"+WMSG
    Endif
    Affzo [M:SDH0]ZAVISO
  Endif
Endif
End

Subprog EMPAQUETADO_OK_D
If  [M:SDH1]CFMFLG=2 or [M:SDH1]INVFLG=2 End   Endif
Local Integer F,ZOK
For F=0 To [M:SDH1]NBLIG-1
  Call EMPAQUETADO_OK([M:SDH1]SDDLIN(F),ZOK)
  If ZOK
    Chgstl [M:SDH1]NBLIG(F) With ""
  Else
    Chgstl [M:SDH1]NBLIG(F) With "BACKRED"
  Endif
Next
End

