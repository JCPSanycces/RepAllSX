   GBOUT1  = "Modif. Cantidad Real"
Endif
End


Subprog ZPV_AS_GROPRI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
If [M:SDH1]QTYSTU(NOL)<>[M:SDH1]ZCTDREALUS(NOL)
   mkstat = 2
   End
Endif
End
