Subprog CAL_QTY(LSDHNUM)
Value Char LSDHNUM()
If clalev([F:SDDX])<=0 :  Local File SDELIVERYD [SDDX] :  Endif
Raz [M:SDH1]ZTOTBOB,[M:SDH1]ZTOTKG,[M:SDH1]ZTOTM2
Filter [SDDX] Where SDHNUM=LSDHNUM
For [SDDX]
   [M:SDH1]ZTOTBOB+=[F:SDDX]ZQTYBOB
   [M:SDH1]ZTOTKG +=[F:SDDX]ZQTYKG
   [M:SDH1]ZTOTM2 +=[F:SDDX]ZQTYM2
Next
Filter [SDDX]
Affzo [M:SDH1]ZTOTBOB,ZTOTKG,ZTOTM2
End


Subprog AM_ZCTDREAL(VALEUR)
Variable Decimal VALEUR
# El cambio del peso se realiza mediante accion asociada a celda de rejilla QTY  =>  AB1_QTY+BB1_QTY, excepto para ventas en M2
# Se llama a ventana ZPVMODCR donde se permite el cambio TOTAL e INDIVIDUAL de las bobinas de la linea
# De realizar algun cambio en las cantidades ocurre lo siguiente:
#    1ş El nuevo peso queda en ZCTDREAL
#    2ş Se recalcula el Nuevo_Valor = PRECIO * ZCTDREAL, donde PRECIO corresponderá con el precio tarifa acordado con Cte (GROPRI)
#    3ş Como no podemos cambiar QTY al estar relaccionado con el stock, se determina:
#                - Guardamos precio acordado con Cte en ZCPRPRIREAL = GROPRI
#                - Se determina nuevo precio del standar GROPRI = Nuevo_Valor / QTY, para de esta manera continue todo normalmente (Stock+Valoracion+Margenes+etc..)
#                - Se actualiza el margen
#    4ş Durante la impresion de documentos, se imprimira una de las siguientes opciones
#                - ZCTDREAL * ZCPRPRIREAL en caso de que ZCTDREAL>0 y ZCTDREAL<>QTY
#                - Standar, es decir QTY * GROPRI


#Local Integer NOL
#NOL = nolign-1
#
#VALEUR=[SDH1]ZCTDREAL(NOL) # No permitimos la modificacion manual del campo solo a traves del boton contextual
#If 1=1 : End : Endif # FJCP Salimos
#### FJCP Codigo de Asier Lax Eliminado
End


Subprog C_NBLIG
Local Integer NOL
NOL = nolign-1
#JLPR 22-02-17 INI
# IMPEDIR QUE SE AŃADAN LINEAS SIN HACER PICKING
Case status
When 73,82
  If GUSER="ADMIN" or GUSER="ESPEC"
    Infbox "Aviso para "+GUSER+".  No se deberian ańadir lineas SIN PICKING"
  Else
    mkstat=2
    End
  Endif
When 75
  If GUSER="ADMIN" or GUSER="ESPEC"
    Infbox "Aviso para "+GUSER+".  No se deberian modificar precios ó Dtos"
  Else
    Diszo [M:SDH1]GROPRI(NOL)
    Diszo [M:SDH1]ZPRIREAL(NOL)
    Diszo [M:SDH1]DISCRGVAL1(NOL)
  Endif
  Diszo [M:SDH1]QTY(NOL)
  Diszo [M:SDH1]SAUSTUCOE(NOL)
  If [M:SDH1]SAU(NOL)="M2"
    Diszo [M:SDH1]ZCTDREAL(NOL)
  Endif
Endcase
#JLPR 22-02-17 FIN
Call ZPV_C_NBLIG
End

Subprog IB_NBLIG
Call ZPV_IB_NBLIG
End


Subprog IB_QTY
Call ZPV_IB_QTY
End


Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
Call ZPV_AS_GROPRI(VALEUR)
If mkstat<>0 : End : Endif
End

$SETBOUT
# 06.409.695.INI
Diszo [M:SDH2]INVDTAAMT(2)
# 06.409.695.FIN

# Necesito que se ejecute 1ş el standard, para evitar que me abilite lo que desabilito
Gosub ACTION From SUBSDH
GPE=1
#
If GREP<>"" or !func LCKSDH([M:SDH0]SDHNUM)
   Call VIREBOUT(CHAINE,"4xy") From GOBJET
Endif

Gosub CONTROL_IMPORTES
#
Call EMPAQUETADO_OK_D
Local Integer ZOK
Call EMPAQUETADO_OK(0,ZOK)
If [M:SDH0]ZAVISO=""
  Chgfmt [M:SDH0]ZAVISO With "-"
Else
  Chgstl [M:SDH0]ZAVISO With "BACKRED"
Endif
Return

Funprog LCKSDH(NUM)
Value Char NUM
Local Char SYMBOLE(100)
Local Integer VERROU
SYMBOLE="SDH"+[L]NUM
Call TESTLOCK(SYMBOLE,VERROU) From GLOCKM
If !VERROU
  Lock =SYMBOLE With lockwait=0
  If !fstat : VERROU=1 : Endif
Endif
End VERROU


$CONTROL_IMPORTES
 #  Infbox "CONTROL IMPORTES"
  Local Decimal WLTOTALBI, WLTOTALBIDOC

  Local Integer WLI

  WLTOTALBI=0
  For WLI=0 To [M:SDH1]NBLIG - 1
     WLTOTALBI+=arr([M:SDH1]QTY(WLI)*arr([M:SDH1]GROPRI(WLI)*(1-[M:SDH1]DISCRGVAL1(WLI)/100),0.0001),0.01)
  Next

  #AUREN - 05.978.607 - X3 no redondea hacia arriba 0.025 -> 0.02 en vez de 0.03, se resta 0.001 para corregir redondeo
  #WLTOTALBIDOC=arr(WLTOTALBI*(1-[M:SDH2]INVDTAAMT(0)/100),0.01)

# 06.409.695.INI
#  WLTOTALBIDOC=arr((WLTOTALBI*(1-[M:SDH2]INVDTAAMT(0)/100))-0.001,0.01)
  WLTOTALBIDOC=arr((WLTOTALBI*(1-[M:SDH2]INVDTAAMT(0)/100)+[M:SDH2]INVDTAAMT(2)+[M:SDH2]INVDTAAMT(1))-0.0001,0.01)
#  Infbox num$(WLTOTALBIDOC)-" - "-num$([M:SDH1]DLVINVNOT)
## 06.409.695.FIN


  If (WLTOTALBI <> [M:SDH1]DLVNOT) or (WLTOTALBIDOC <> [M:SDH1]DLVINVNOT)
    # Infbox "TOTAL BI LINEAS" - num$(WLTOTALBI) - num$([M:SDH1]DLVNOT)
    # Infbox "TOTAL BI DOC" -  num$(WLTOTALBIDOC) -  num$([M:SDH1]DLVINVNOT)
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif

Return

#####################################################################
#####################################################################
###### Procesos especificos ZPV - Precio Venta / Cantidades Reales
#####################################################################
#####################################################################

$ZPV_OUVRE
If !clalev([F:XSTA]) : Local File STOALL [XSTA]: Endif
If !clalev([F:XSTO]) : Local File STOCK [XSTO]: Endif
If !clalev([F:ZPVCR]) : Local File ZPVCTDREAL [ZPVCR]: Endif

Global Integer WGMODCR
Global Integer ZGOK
Return



$ZPV_LIENS_LIG
Local Integer WI
# cargar Mascara ZSDH1 - Detalle cantidades reales

WI= [M:ZSDH1]ZNBCR
If [M:SDH1]CFMFLG=1
   # Leemos de STOALL y cantidad real de ZPVCTDREAL
   Filter [F:XSTA] Where VCRNUM=[M:SDH0]SDHNUM and VCRLIN=[M:SDH1]SDDLIN(NOL) and ALLTYP=2

   For [F:XSTA]
       [M:ZSDH1]CRSTOFCY(WI)=[F:XSTA]STOFCY
       [M:ZSDH1]CRSTOCOU(WI)=[F:XSTA]STOCOU
       [M:ZSDH1]CRSTOSEQ(WI)=[M:SDH1]WSTOSEQ(NOL)
       [M:ZSDH1]CRSDDLIN(WI)=[M:SDH1]SDDLIN(NOL)
       [M:ZSDH1]CRITMREF(WI)=[F:XSTA]ITMREF
       Raz [F:XSTO]
       Read [F:XSTO]STO0=[F:XSTA]STOFCY;[F:XSTA]STOCOU
       If !fstat
          [M:ZSDH1]CRLOT(WI)=[F:XSTO]LOT
          [M:ZSDH1]CRSLO(WI)=[F:XSTO]SLO
       Endif
       [M:ZSDH1]CRQTYSTU(WI)=[F:XSTA]QTYSTU
       [M:ZSDH1]CRSTOSEQ(WI)=[M:SDH1]WSTOSEQ(NOL)
       [M:ZSDH1]CRSTU(WI)=[M:SDH1]STU(NOL)
       [M:ZSDH1]CRITMDES(WI)=[M:SDH1]ITMDES(NOL)
       Raz [F:ZPVCR]
       Read [F:ZPVCR]ZPVCR2=[F:XSTA]VCRNUM;[F:XSTA]VCRLIN;[F:XSTA]STOFCY;[F:XSTA]STOCOU
       If fstat
          [M:ZSDH1]CTDREALUS(WI)=[F:XSTA]QTYSTU
       Else
          [M:ZSDH1]CTDREALUS(WI)=[F:ZPVCR]CTDREALUS
       Endif
       WI+=1
   Next
   Filter [F:XSTA]
Endif
[M:ZSDH1]ZNBCR=WI
Affzo [M:ZSDH1]
Return


## Al pulsar el boton registrar
$ZPV_CREATION
Local Integer WI,WJ, WSDDLIN

#Filter [F:XSTA] Where VCRNUM=[M:SDH0]SDHNUM and ALLTYP=2
# For [F:XSTA]
#     Infbox "STOALL.STOCOU=" - num$([F:XSTA]STOCOU)
# Next
#Filter [F:XSTA]
WSDDLIN=0
WJ=0
For WI = 0 To [M:ZSDH1]ZNBCR - 1

   If WSDDLIN<>[M:ZSDH1]CRSDDLIN(WI) : WSDDLIN=[M:ZSDH1]CRSDDLIN(WI) : WJ=0 : Endif
   WJ+=1
   Raz [F:ZPVCR]
   [F:ZPVCR]SDHNUM=[F:SDH]SDHNUM
   [F:ZPVCR]SDDLIN=WSDDLIN
   [F:ZPVCR]LINEA=WJ
   [F:ZPVCR]DLVDAT=[F:SDH]DLVDAT
   [F:ZPVCR]STOFCY=[F:SDH]STOFCY
   [F:ZPVCR]STOCOU=[M:ZSDH1]CRSTOCOU(WI)
   [F:ZPVCR]ITMREF=[M:ZSDH1]CRITMREF(WI)
   [F:ZPVCR]LOT=[M:ZSDH1]CRLOT(WI)
   [F:ZPVCR]SLO=[M:ZSDH1]CRSLO(WI)
   [F:ZPVCR]QTYSTU=[M:ZSDH1]CRQTYSTU(WI)
   [F:ZPVCR]STU=[M:ZSDH1]CRSTU(WI)
   [F:ZPVCR]CTDREALUS=[M:ZSDH1]CTDREALUS(WI)
   Write [F:ZPVCR]
   If fstat
      GOK=0
      Call FSTA("ZPVCR") From GLOCK
      Break
   Endif

Next

Return

## Al pulsar el boton registrar
$ZPV_MODIF
Local Integer WI,WJ, WSDDLIN
# Borrar Consumos Reales Entregas
Delete [F:ZPVCR] Where SDHNUM=[M:SDH0]SDHNUM
If fstat
   GOK=0
   Call FSTA("ZPVCR") From GLOCK
   Return
Endif
#Filter [F:XSTA] Where VCRNUM=[M:SDH0]SDHNUM and ALLTYP=2
# For [F:XSTA]
#     Infbox "STOALL.STOCOU=" - num$([F:XSTA]STOCOU)
# Next
#Filter [F:XSTA]
WSDDLIN=0
WJ=0
For WI = 0 To [M:ZSDH1]ZNBCR - 1

   If WSDDLIN<>[M:ZSDH1]CRSDDLIN(WI) : WSDDLIN=[M:ZSDH1]CRSDDLIN(WI) : WJ=0 : Endif
   WJ+=1
   Raz [F:ZPVCR]
   [F:ZPVCR]SDHNUM=[F:SDH]SDHNUM
   [F:ZPVCR]SDDLIN=WSDDLIN
   [F:ZPVCR]LINEA=WJ
   [F:ZPVCR]DLVDAT=[F:SDH]DLVDAT
   [F:ZPVCR]STOFCY=[F:SDH]STOFCY
   [F:ZPVCR]STOCOU=[M:ZSDH1]CRSTOCOU(WI)
   [F:ZPVCR]ITMREF=[M:ZSDH1]CRITMREF(WI)
   [F:ZPVCR]LOT=[M:ZSDH1]CRLOT(WI)
   [F:ZPVCR]SLO=[M:ZSDH1]CRSLO(WI)
   [F:ZPVCR]QTYSTU=[M:ZSDH1]CRQTYSTU(WI)
   [F:ZPVCR]STU=[M:ZSDH1]CRSTU(WI)
   [F:ZPVCR]CTDREALUS=[M:ZSDH1]CTDREALUS(WI)
   Write [F:ZPVCR]
   If fstat
      GOK=0
      Call FSTA("ZPVCR") From GLOCK
      Break
   Endif

Next

Return


$ZPV_ANNULE
# Borrar Consumos Reales Entregas
Delete [F:ZPVCR] Where SDHNUM=[M:SDH0]SDHNUM
If fstat
   GOK=0
   Call FSTA("ZPVCR") From GLOCK
   Return
Endif
Return

### Despues de ejecucion del botón

$ZPV_BB1_NBLIG
If mkstat = 4 Then
   # Si activada la accion Registrar
   Call ZPV_DEL_CRSDDLIN([M:SDH1]SDDLIN(NOL))
   Call ZPV_ADD_CRSDDLIN(NOL)
   Affzo [M:ZSDH1]
   mkstat = 4
Endif

Return

# Despues de hacer Picking
$ZPV_FIN_PICK
Local Shortint NOL
#Ańadir Nuevos
For NOL=0 To [M:SDH1]NBLIG - 1
   If [M:SDH1]CREFLG(NOL)=0 | GREP="C"
      Call ZPV_DEL_CRSDDLIN([M:SDH1]SDDLIN(NOL))
      Call ZPV_ADD_CRSDDLIN(NOL)
   Endif
  Next
 # Borrar Eliminados
 Call ZPV_DEL_CRSDDLIN_NOEXISTEN()
 Affzo [M:ZSDH1]
Return




# Borra detalle cantidades real en ZSDH1
# Parametro SDDLIN
Subprog ZPV_DEL_CRSDDLIN(WLSDDLIN)
Value Integer WLSDDLIN
Local Integer WLI
WLI=[M:ZSDH1]ZNBCR-1
While WLI>=0
 If [M:ZSDH1]CRSDDLIN(WLI)=WLSDDLIN
    Dela WLI,1 [M:ZSDH1]CRSTOSEQ, [M:ZSDH1]CRSTOFCY, [M:ZSDH1]CRSTOCOU,[M:ZSDH1]CRSDDLIN
    Dela WLI,1 [M:ZSDH1]CRITMREF,[M:ZSDH1]CRITMDES,[M:ZSDH1]CRLOT, [M:ZSDH1]CRSLO
    Dela WLI,1 [M:ZSDH1]CRQTYSTU,[M:ZSDH1]CTDREALUS,[M:ZSDH1]CRSTU
    [M:ZSDH1]ZNBCR -=1
 Endif
 WLI -=1
Wend
End


# Ańade detalle cantidades real en ZSDH1 busca en STOSORW [SOW]
# Parametro WNOL linea actual [M:SDH1]
Subprog ZPV_ADD_CRSDDLIN(WNOL)
Value Integer WNOL
Local Integer WLI,WLJ
Local Integer WLSTOSEQ
WLSTOSEQ=[M:SDH1]WSTOSEQ(WNOL)
WLJ=[M:ZSDH1]ZNBCR
If WLSTOSEQ<>0 & [M:SOW]NBLIG>0 Then
  For WLI=0 To [M:SOW]NBLIG - 1
      If [M:SOW]WSTOSEQ(WLI)=WLSTOSEQ
          [M:ZSDH1]CRSTOFCY(WLJ)=[M:SDH0]STOFCY
          [M:ZSDH1]CRSTOCOU(WLJ)=[M:SOW]WSTOCOU(WLI)
          [M:ZSDH1]CRQTYSTU(WLJ)=[M:SOW]WQTYSTU(WLI)
          [M:ZSDH1]CTDREALUS(WLJ)=[M:SOW]WQTYSTU(WLI)
          [M:ZSDH1]CRSTOSEQ(WLJ)=[M:SDH1]WSTOSEQ(WNOL)
          [M:ZSDH1]CRSDDLIN(WLJ)=[M:SDH1]SDDLIN(WNOL)
          [M:ZSDH1]CRITMREF(WLJ)=[M:SDH1]ITMREF(WNOL)
          [M:ZSDH1]CRITMDES(WLJ)=[M:SDH1]ITMDES(WNOL)
          Raz [F:XSTO]
          Read [F:XSTO]STO0=[M:ZSDH1]CRSTOFCY(WLJ);[M:ZSDH1]CRSTOCOU(WLJ)
          If !fstat
              [M:ZSDH1]CRLOT(WLJ)=[F:XSTO]LOT
              [M:ZSDH1]CRSLO(WLJ)=[F:XSTO]SLO
          Endif
          [M:ZSDH1]CRSTU(WLJ)=[M:SDH1]STU(WNOL)
          WLJ+=1
      Endif
  Next
  [M:ZSDH1]ZNBCR=WLJ
Endif
End


# Borra detalle cantidades real en ZSDH1
# Parametro SDDLIN
Subprog ZPV_DEL_CRSDDLIN_NOEXISTEN()
Local Integer WLSDDLIN
Local Integer WLI, WFIND
WLSDDLIN=0
For WLI = 0 To [M:ZSDH1]ZNBCR-1
 If WLSDDLIN<>[M:ZSDH1]CRSDDLIN(WLI)
    WLSDDLIN=[M:ZSDH1]CRSDDLIN(WLI)
    WFIND=0
    WFIND=find(WLSDDLIN,[M:SDH1]SDDLIN(0..[M:SDH1]NBLIG-1))
    If !WFIND Then
       Call ZPV_DEL_CRSDDLIN(WLSDDLIN)
    Endif

 Endif
Next
End


$ZPV_AB1_QTY
WGMODCR=0
Return


$ZPV_BB1_QTY
If WGMODCR=1 Then
   #[M:SDH1]UPDFLG(NOL)=1
  # Infbox "REcalculo Precio" - num$(NOL)
   ### Recalculo Precio.
   Call CALC_PRECIOS([M:SDH1]ZPRIREAL(NOL),NOL)
   [M:SDH1]UPDFLG(NOL)=1
  # zonsui="GROPRI(" + num$(NOL) + ")"   # Fuerzo la edicion del GRID
   mkstat = 4  # Fuerzo el botón registrar
Endif
Return


Subprog CALC_PRECIOS(WLPRECIOREAL,WNOL)
Value Decimal WLPRECIOREAL
Value Integer WNOL
#
Local Decimal WLIMPORTEREAL, WLPRECIONUEVO, WLCANTIDADREAL, WLCANTIDADENTREGA
Local Decimal LANCHO,LM2


# FJCP Parche para arreglar los fallos de M2 recalculados en la asignacion.
If [M:SDH1]SAU(WNOL)="M2"
   LANCHO = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:SDH1]ITMREF(NOL),[M:SDH1]ZANCHO(WNOL))
   LM2=LANCHO*[M:SDH1]ZLONGITUD(WNOL)*[M:SDH1]ZQTYBOB(WNOL)/1000
   [M:SDH1]QTY(WNOL)      =LM2
   [M:SDH1]ZCTDREAL(WNOL) =LM2
#> 69503 - redondeamos este valor ya que da un error en el estandar cuando trae más de 4 decimales
   #[M:SDH1]SAUSTUCOE(WNOL)=[M:SDH1]QTYSTU(WNOL)/[M:SDH1]QTY(WNOL)  #  KG / M2
   [M:SDH1]SAUSTUCOE(WNOL)=arr([M:SDH1]QTYSTU(WNOL)/[M:SDH1]QTY(WNOL),0.0001)  #  KG / M2
#< 69503
   Affzo [M:SDH1]SAUSTUCOE(WNOL)
   Affzo [M:SDH1]QTY(WNOL)
Endif
# FJCP FIN  Parche

#FJCG inicio
If [M:SDH1]SAU(WNOL)="M2"
   [M:SDH1]ZQTYKG(WNOL)=[M:SDH1]ZCTDREALUS(WNOL)
   [M:SDH1]ZQTYM2(WNOL)=[M:SDH1]ZCTDREAL(WNOL)
Else
   [M:SDH1]ZQTYKG(WNOL)=[M:SDH1]ZCTDREALUS(WNOL)
   [M:SDH1]ZQTYM2(WNOL)=[M:SDH1]ZANCHO(WNOL)*[M:SDH1]ZLONGITUD(WNOL)*[M:SDH1]ZQTYBOB(WNOL)/1000
Endif
#FJCG fin

   If  [M:SDH1]ZCTDREAL(WNOL)<> [M:SDH1]QTY(WNOL) Then
    #   Infbox "REcalculo Precio -2 " - num$(wNOL)
    #  WLPRECIOREAL = [M:SDH1]ZPRIREAL(wNOL)
      WLCANTIDADREAL =  [M:SDH1]ZCTDREAL(WNOL)
      WLIMPORTEREAL = WLPRECIOREAL * WLCANTIDADREAL
      WLCANTIDADENTREGA = [M:SDH1]QTY(WNOL)
    #  Infbox "Cantidad Entregada" - num$(WLCANTIDADENTREGA)
      If WLCANTIDADENTREGA<>0 Then
          WLPRECIONUEVO = arr(WLIMPORTEREAL / WLCANTIDADENTREGA,0.0001)
      Else
          WLPRECIONUEVO = WLPRECIOREAL
      Endif
      [M:SDH1]GROPRI(WNOL) = WLPRECIONUEVO

     Else
       [M:SDH1]GROPRI(WNOL) = WLPRECIOREAL
    Endif
    Affzo [M:SDH1]GROPRI(WNOL)

    # --> Calculo del precio neto
    Call CLCNETPRI([M:SDH1]QTY(WNOL), [M:SDH1]CUR, WNOL) From TRTVENPRI
  #  If mkstat : End : Endif

    Call CTLNETPRI([M:SDH0]BPCORD,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,[M:SDH1]CUR, WNOL) From TRTVENPRI
   # If mkstat : End : Endif
   If GUSER='ADMIN' Then
   # Infbox "Precios NETO" - num$([M:SDH1]NETPRI(WNOL)) - "BRUTO: " -  num$([M:SDH1]GROPRI(WNOL))
   Endif
    [M:SDH1]NETPRINOT(WNOL)=[M:SDH1]NETPRI(WNOL)
    Affzo [M:SDH1]NETPRI(WNOL)
    Affzo [M:SDH1]NETPRINOT(WNOL)
    # --> Calculo del margen
    Call CLCPFM([M:SDH0]SALFCY, [M]PRITYP, [M]CHGTYP, [M:SDH1]SHIDAT, [M:SDH1]CUR, WNOL, 2) From TRTVENPRI
    # --> Calculo del margen real
    If [M:SDH1]STU(WNOL) = [M:SDH1]SAU(WNOL) and [M:SDH1]ZCTDREAL(WNOL)<>0 and [M:SDH1]QTYSTU(WNOL)<>0
& and [M:SDH1]ZCTDREAL(WNOL)<>[M:SDH1]QTYSTU(WNOL)
      [M:SDH1]ZCPRPRIREAL(WNOL)=arr([M:SDH1]CPRPRI(WNOL)*[M:SDH1]QTYSTU(WNOL)/[M:SDH1]ZCTDREAL(WNOL),0.0001)
      [M:SDH1]ZPFMREAL(WNOL)=[M:SDH1]NETPRI(WNOL)-[M:SDH1]ZCPRPRIREAL(WNOL)
    Else
      [M:SDH1]ZPFMREAL(WNOL)=[M:SDH1]PFM(WNOL)
      [M:SDH1]ZCPRPRIREAL(WNOL)=[M:SDH1]CPRPRI(WNOL)

    Endif
    Affzo [M:SDH1]ZCPRPRIREAL(WNOL)
    Affzo [M:SDH1]ZPFMREAL(WNOL)
End


