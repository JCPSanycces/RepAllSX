Subprog AM_ZPRIREAL(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
Call CALC_PRECIOS(VALEUR,NOL)
End

######################################################################################
## Después de modificar el campo 'Artículo' (pantalla SDH1) 23/12/2022 11:11:51 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# 06.409.695.ini
  If [M:SDH0]STOFCY = '100'
    If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
    If !clalev([F:ZITM]) Then : Local File ITMMASTER  [F:ZITM] : Endif
    Read [F:ZBPC]BPC0 = [M:SDH0]BPCORD
    If !fstat Then
      If [F:ZBPC]ZPLASTAXFLG <> 2 Then
        [M:SDH1]ZPLASTICTAX(nolign-1) = 0
      Else
        Read [F:ZITM]ITM0 = [M:SDH1]ITMREF(nolign-1)
        If !fstat Then
          [M:SDH1]ZPLASTICTAX(nolign-1) = [F:ZITM]ZPLASTICTAX
        Endif
      Endif
      Affzo [M:SDH1]ZPLASTICTAX(nolign-1)
    Endif
    Close Local File [ZBPC],[ZITM]
  Endif
# 06.409.695.fin

End
