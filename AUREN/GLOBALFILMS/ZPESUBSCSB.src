#PE ALI_DOC_SCS1 - PE para alimentar los campos especificos de stock (ancho, mandril,...)

$ACTION
Case ACTION
   When "ALI_DOC_SCS1"     :   Gosub ALI_DOC_SCS1
Endcase
Return

$ALI_DOC_SCS1
[M:SCS1]ZANCHO(NOL)=[F:STO]ZANCHO
[M:SCS1]ZMANDRIL(NOL)=[F:STO]ZMANDRIL
[M:SCS1]ZLONGITUD(NOL)=[F:STO]ZLONGITUD
[M:SCS1]ZPROVEEDOR(NOL)=[F:STO]ZPROVEEDOR
[M:SCS1]ZMFGDATE(NOL)=[F:STO]ZMFGDATE
[M:SCS1]ZEMPALME(NOL)=[F:STO]ZEMPALME
Return
