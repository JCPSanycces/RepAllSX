#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "CALPFM1" : Gosub CALPFM1
Endcase
Return

$CALPFM1
# ZPV - Precio Cantidad Real Venta
# Gosub ZPV_CALPFM1  # Comentado los costes se calculan en campos especificos
# FIN ZPV - Precio Cantidad Real Venta
Return


### ZPV - Precio Cantidad Real Venta
$ZPV_CALPFM1
If GCALPFM=0 & GFONCTION="GESSDH" and  dim([M:SDH1]ZCTDREALUS)<>0
   If ([M:SDH1]ZCTDREALUS(NLIG)-WQTY)<>0 and WQTY<>0
     # Infbox "COSTE INCIAL " - num$(COUTHT)
      XCPRPRI=arr((COUTHT*[M:SDH1]ZCTDREALUS(NLIG)/WQTY),0.0001)
     # Infbox "COSTE FINAL " - num$(XCPRPRI)
      XPFM = PHTNET  - XCPRPRI
   Endif
Endif
Return
