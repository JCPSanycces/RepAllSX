#<AdxTL>@(#)0.0.0.0 $Revision$
# Z0001-1 - JC.21072022.Trazabilidad
#####################################################################

#MODDISPAR -> PE utilizado, aunque no es su objetivo, para mostrar los valores de ancho, longitud, ..., en
#             la ventana detalle de stock en salidas varias.
$ACTION
Case ACTION
   When "MODISSPAR" :   Gosub MODISSPAR
   When "SOW_SOR"   :   Gosub SOW_SOR
Endcase
Return

$MODISSPAR
#Infbox "ZPETRTSTOSOR - "+ACTION
If [M:SOR]TRSTYP=2
   #Salida varia
   [M:SOR]ZANCHO=[M:SMO1]ZANCHO(LNOL)
   [M:SOR]ZMANDRIL=[M:SMO1]ZMANDRIL(LNOL)
   [M:SOR]ZLONGITUD=[M:SMO1]ZLONGITUD(LNOL)
   [M:SOR]ZPROVEEDOR=[M:SMO1]ZPROVEEDOR(LNOL)
   [M:SOR]ZMFGDATE=[M:SMO1]ZMFGDATE(LNOL)
   [M:SOR]ZEMPALME=[M:SMO1]ZEMPALME(LNOL)
Endif
Return

$SOW_SOR
#If GUSER="ADMIN"
#   Infbox "ZPETRTSTOSOR - "
#Endif
If LABR="SDH1"
   #[M:SOM]ZANCHO=[M:SDH1]ZANCHO(LNOL)
   [M:SOR]ZANCHO=[M:SDH1]ZANCHO(LNOL)
   [M:SOR]ZMANDRIL=[M:SDH1]ZMANDRIL(LNOL)
   [M:SOR]ZLONGITUD=[M:SDH1]ZLONGITUD(LNOL)
   [M:SOR]ZPROVEEDOR=[M:SDH1]ZPROVEEDOR(LNOL)
   [M:SOR]ZMFGDATE=[M:SDH1]ZMFGDATE(LNOL)
   [M:SOR]ZEMPALME=[M:SDH1]ZEMPALME(LNOL)
Endif
If LABR="PRH1"
   [M:SOR]ZANCHO=[M:PRH1]ZANCHO(LNOL)
   [M:SOR]ZMANDRIL=[M:PRH1]ZMANDRIL(LNOL)
   [M:SOR]ZLONGITUD=[M:PRH1]ZLONGITUD(LNOL)
   [M:SOR]ZPROVEEDOR=[M:PRH1]ZPROVEEDOR(LNOL)
   [M:SOR]ZMFGDATE=[M:PRH1]ZMFGDATE(LNOL)
   [M:SOR]ZEMPALME=[M:PRH1]ZEMPALME(LNOL)
# Z0001-1.ini
   [M:SOR]ZLONGITUDD(NOL)=[F:STO]ZLONGITUD
   [M:SOR]ZANCHOD(NOL)=[F:STO]ZANCHO
   [M:SOR]ZMANDRILD(NOL)=[F:STO]ZMANDRIL
   [M:SOR]ZMFGDATED(NOL)=[F:STO]ZMFGDATE
   [M:SOR]ZEMPALMED(NOL)=[F:STO]ZEMPALME
   [M:SOR]USRFLD1(NOL)=[F:STO]USRFLD1
   [M:SOR]USRFLD2(NOL)=[F:STO]USRFLD2
   [M:SOR]USRFLD4(NOL)=[F:STO]USRFLD4
# Z0001-1.fin
Endif
Return
