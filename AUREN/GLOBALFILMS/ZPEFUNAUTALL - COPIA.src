#<AdxTL>@(#)0.0.0.0 $Revision$
#MODQTEALL -> PE de FUNAUTALL para intervenir sobre la cantidad a asignar para que de una cantidad mayor
#             a la pedida para asegurarnos de que se va a asignar igual o m·s de lo pedido.
#             Este PE se llama desde asignaciones autom·ticas de pedidos (Ventas/Asignaciones/Asignaciones automaticas"
$ACTION
Case ACTION
   When "MODQTEALL"     :   Gosub MODQTEALL
Endcase
Return

$MODQTEALL
Local Shortint LI,LQYTBOB
Local Decimal LALLAUX
Local Integer LASITRAS

Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - WALLSTU: "+num$(WALLSTU)+" ZFABCOR: "+num$([F:ITM]ZFABCOR)+" - "+GFONCTION,0) From GESECRAN
If WALLSTU>0
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SOQ]ITMREF
   If [F:ITM]ZFABCOR=2
      If clalev([F:STOX])<=0 : Local File STOCK   [STOX] : Endif
      If clalev([F:ZASP])<=0 : Local File ZASIPED [ZASP] : Endif

      If GSERVEUR
         #Si se lanza en batch la tarea de asignacion desde la declaracion de produccion
         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and LOC="0RESERVA" and
&               ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&               CUMALLQTY=0
      Else
         Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&               ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&               CUMALLQTY=0
         #Inicio (solo en el arranque)
         LASITRAS=0
         Filter [ZASP] Where VCRTYP=2 and VCRNUM=[F:SOQ]SOHNUM and VCRLIN=[F:SOP]ZSOPLIN
         Raz [F:ZASP]
         For [ZASP]
            LASITRAS=1
            Break
         Next
         Filter [ZASP]
         If LASITRAS=1 : #or LASITRAS=0
            #Asignamos solamente lo que viene con asignacion del traspaso
            Filter [STOX] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and
&                  ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD and
&                  LOT=[F:ZASP]LOT and LOC=[F:ZASP]LOC and CUMALLQTY=0
         Endif
         #Fin (solo en el arranque)
      Endif
      LALLAUX=0
      LI=0
      For [STOX]
         LI+=1
         LALLAUX+=[F:STOX]QTYSTU
         If LI=[F:SOQ]ZQTYBOB
            Break
         Endif
      Next
      Call ECR_TRACE(" PE MODQTEALL ZPEFUNAUTALL - LALLAUX: "+num$(LALLAUX),0) From GESECRAN
      #If WALLSTU<LALLAUX
         #WALLSTU+=0.001
         WALLSTU=LALLAUX
      #Endif
   Endif
Endif
Return
