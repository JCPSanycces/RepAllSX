#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZCNMATSOB1
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return

$AUTORIS
Global Integer INICIO

INICIO=1

Return

$FERME
Return

$OUVRE
If clalev([F:MFGX])<=0 : Local File MFGHEAD [MFGX] : Endif
[M:ZCNMTSB1]DESDEFECHA=date$
[M:ZCNMTSB1]HASTAFECHA=date$

Return

$DEB_CRIT
Return

$LECTURE
If INICIO=0 Then
    Gosub CARGAR
Endif

Return

$SETBOUT
INICIO=0

Return

$EXEBOUT
Return

$AP_MAGNETO
Return

$CLECUR
Return

$CARGAR
Local Char REQUEST(255)(9)
Local Char FILTRO(255)(5)
Local Integer FILAS

Raz [M:ZCNMTSO2]

nolign=0

##############################################################################
# MONTAMOS LOS FILTROS
##############################################################################
If [M:ZCNMTSB1]ITMREF<>"" and [M:ZCNMTSB1]FCY<>"" and [M:ZCNMTSB1]ITMREFEND<>"" Then
    FILTRO(0) = " WHERE (ZMFGLOT.ITMREF_0 >='"+[M:ZCNMTSB1]ITMREF+"' AND ZMFGLOT.ITMREF_0 <='"+[M:ZCNMTSB1]ITMREFEND+"') AND ZMFGLOT.STOFCY_0='"+[M:ZCNMTSB1]FCY+"' "
Elsif [M:ZCNMTSB1]ITMREF<>"" and [M:ZCNMTSB1]ITMREFEND<>"" and [M:ZCNMTSB1]FCY="" Then
    FILTRO(0) = " WHERE (ZMFGLOT.ITMREF_0 >='"+[M:ZCNMTSB1]ITMREF+"' AND ZMFGLOT.ITMREF_0<='"+[M:ZCNMTSB1]ITMREFEND+"') "
Elsif [M:ZCNMTSB1]ITMREF="" and [M:ZCNMTSB1]ITMREFEND="" and [M:ZCNMTSB1]FCY<>"" Then
    FILTRO(0) = " WHERE ZMFGLOT.STOFCY_0 ='"+[M:ZCNMTSB1]FCY+"' "
Elsif [M:ZCNMTSB1]ITMREF="" and [M:ZCNMTSB1]ITMREFEND="" and [M:ZCNMTSB1]FCY="" Then
    FILTRO(0) = " WHERE ZMFGLOT.ITMREF_0 <>'' AND ZMFGLOT.STOFCY_0<>'' "
Elsif [M:ZCNMTSB1]ITMREF<>"" and [M:ZCNMTSB1]ITMREFEND="" and [M:ZCNMTSB1]FCY="" Then
    FILTRO(0) = " WHERE ZMFGLOT.ITMREF_0 >='"+[M:ZCNMTSB1]ITMREF+"' AND ZMFGLOT.STOFCY_0<>'' "
Elsif [M:ZCNMTSB1]ITMREF="" and [M:ZCNMTSB1]ITMREFEND<>"" and [M:ZCNMTSB1]FCY="" Then
    FILTRO(0) = " WHERE ZMFGLOT.ITMREF_0 <='"+[M:ZCNMTSB1]ITMREFEND+"' AND ZMFGLOT.PLNFCY_0<>'' "
Elsif [M:ZCNMTSB1]ITMREF<>"" and [M:ZCNMTSB1]ITMREFEND="" and [M:ZCNMTSB1]FCY<>"" Then
    FILTRO(0) = " WHERE ZMFGLOT.ITMREF_0 >='"+[M:ZCNMTSB1]ITMREF+"' AND ZMFGLOT.STOFCY_0<>'"+[M:ZCNMTSB1]FCY+"'"
Elsif [M:ZCNMTSB1]ITMREF="" and [M:ZCNMTSB1]ITMREFEND<>"" and [M:ZCNMTSB1]FCY<>"" Then
    FILTRO(0) = " WHERE ZMFGLOT.ITMREF_0 <='"+[M:ZCNMTSB1]ITMREFEND+"' AND ZMFGLOT.STOFCY_0<>'"+[M:ZCNMTSB1]FCY+"'"
Endif

If ([M:ZCNMTSB1]ANCHODEB<>0) and ([M:ZCNMTSB1]ANCHOEND<>0) Then
    FILTRO(1)=" AND (ZMFGLOT.ZANCHO_0>="+num$([M:ZCNMTSB1]ANCHODEB)+" AND ZMFGLOT.ZANCHO_0<="+num$([M:ZCNMTSB1]ANCHOEND)+")"
Elsif ([M:ZCNMTSB1]ANCHODEB<>0) and ([M:ZCNMTSB1]ANCHOEND=0) Then
    FILTRO(1)=" AND ZMFGLOT.ZANCHO_0>="+num$([M:ZCNMTSB1]ANCHODEB)
Elsif ([M:ZCNMTSB1]ANCHODEB=0) and ([M:ZCNMTSB1]ANCHOEND<>0) Then
    FILTRO(1)=" AND ZMFGLOT.ZANCHO_0<="+num$([M:ZCNMTSB1]ANCHOEND)
Endif
If ([M:ZCNMTSB1]LONGITUDDEB<>0) and ([M:ZCNMTSB1]LONGITUDEND<>0) Then
    FILTRO(2)=" AND ZMFGLOT.ZLONGITUD_0>="+num$([M:ZCNMTSB1]LONGITUDDEB)
Elsif ([M:ZCNMTSB1]LONGITUDDEB<>0) and ([M:ZCNMTSB1]LONGITUDEND=0) Then
    FILTRO(2)=" AND ZMFGLOT.ZLONGITUD_0>="+num$([M:ZCNMTSB1]LONGITUDDEB)
Elsif ([M:ZCNMTSB1]LONGITUDDEB=0) and ([M:ZCNMTSB1]LONGITUDEND<>0) Then
    FILTRO(2)=" AND ZMFGLOT.ZLONGITUD_0<="+num$([M:ZCNMTSB1]LONGITUDEND)
Endif
If ([M:ZCNMTSB1]MANDRIL<>0) Then
    FILTRO(3)=" AND ZMFGLOT.ZMANDRIL_0>="+num$([M:ZCNMTSB1]MANDRIL)
Endif
FILTRO(4)=" AND (MFGHEAD.ENDDAT_0>='"+[M:ZCNMTSB1]DESDEFECHA+"' AND MFGHEAD.ENDDAT_0<='"+[M:ZCNMTSB1]HASTAFECHA+"') "
FILTRO(4)+=" AND ZMFGLOT.ZLONGSOB_0>0"


##############################################################################
# ABRIMOS LA QUERY
##############################################################################
REQUEST(0)="SELECT MFGHEAD.PLNFCY_0,FACILITY.FCYNAM_0,ZMFGLOT.ITMREF_0,ITMMASTER.ITMDES1_0,ZMFGLOT.ZANCHO_0,ZMFGLOT.ZMANDRIL_0,"
REQUEST(1)="ZMFGLOT.ZLONGITUD_0,ZMFGLOT.ZLONGSOB_0,ZMFGLOT.LOT_0,MFGHEAD.MFGNUM_0,MFGHEAD.ENDDAT_0 FROM MFGHEAD "
REQUEST(2)="INNER JOIN FACILITY ON MFGHEAD.PLNFCY_0=FACILITY.FCY_0 "
REQUEST(3)="INNER JOIN ZMFGLOT ON MFGHEAD.MFGNUM_0=ZMFGLOT.MFGNUM_0 INNER JOIN ITMMASTER ON ZMFGLOT.ITMREF_0=ITMMASTER.ITMREF_0 "
REQUEST(4)=FILTRO(0)
REQUEST(5)=FILTRO(1)
REQUEST(6)=FILTRO(2)
REQUEST(7)=FILTRO(3)
REQUEST(8)=FILTRO(4)

Raz [M:ZCNMTSO2]NBLIG
Effzo [M:ZCNMTSO2]5
For (Char PLANTA(15),Char NOMPLANTA(15),Char ARTICULO(20),Char DESARTI(30),Shortint ANCHO,Integer MANDRIL,Integer LONGITUD,Integer SOBRANTE,Char LOT,Char MFGNUM,Date FECHA) From "5" Sql
& REQUEST As [XXX]
      FILAS=[M:ZCNMTSO2]NBLIG
      [M:ZCNMTSO2]STOFCY(FILAS)=[F:XXX]PLANTA
      [M:ZCNMTSO2]FCYSHO(FILAS)=[F:XXX]NOMPLANTA
      [M:ZCNMTSO2]ZQTYBOB(FILAS)=1
      [M:ZCNMTSO2]ZANCHO(FILAS)=[F:XXX]ANCHO
      [M:ZCNMTSO2]ZMANDRIL(FILAS)=[F:XXX]MANDRIL
      [M:ZCNMTSO2]ITMREF(FILAS)=[F:XXX]ARTICULO
      [M:ZCNMTSO2]ITMDES1(FILAS)=DESARTI
      [M:ZCNMTSO2]ZMFGNUM(FILAS)=MFGNUM
      [M:ZCNMTSO2]ZFECHA(FILAS)=FECHA
      [M:ZCNMTSO2]ZLONGITUD(FILAS)=[F:XXX]LONGITUD
      [M:ZCNMTSO2]ZSOBRANTE(FILAS)=[F:XXX]SOBRANTE
      [M:ZCNMTSO2]ZLOT(FILAS)=LOT
      Raz [F:MFGX]
      Read [MFGX]MFG0=MFGNUM
      [M:ZCNMTSO2]MFGTRKFLG(FILAS)=[F:MFGX]MFGTRKFLG

      [M:ZCNMTSO2]NBLIG+=1
      If [M:ZCNMTSO2]NBLIG>=3000 Then
          Infbox("La consulta devuelve demasiados registros. Se visualizarán los 3000 primeros")
          Break
      Endif
Next
Gosub CALCULAR_TOTALES
Affzo [M:ZCNMTSO2]5

Return

$CALCULAR_TOTALES
Local Integer I

FILAS=[M:ZCNMTSO2]NBLIG

[M:ZCNMTSO2]STOFCY(FILAS) = "***"
[M:ZCNMTSO2]FCYSHO(FILAS) = toupper(mess(142,124,1))
Raz [M:ZCNMTSO2]ZANCHO(FILAS)
Raz [M:ZCNMTSO2]ZLONGITUD(FILAS)
Raz [M:ZCNMTSO2]ZMANDRIL(FILAS)
Raz [M:ZCNMTSO2]ZFECHA(FILAS)

For I=0 To [M:ZCNMTSO2]NBLIG-1
    [M:ZCNMTSO2]ZQTYBOB(FILAS)+=[M:ZCNMTSO2]ZQTYBOB(I)
    [M:ZCNMTSO2]ZLONGITUD(FILAS)+=[M:ZCNMTSO2]ZLONGITUD(I)
    [M:ZCNMTSO2]ZSOBRANTE(FILAS)+=[M:ZCNMTSO2]ZSOBRANTE(I)

Next
[M:ZCNMTSO2]NBLIG+=1

Return


######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCNMATSOB1) 22/02/2016 16:01:37 (ADMIN)
######################################################################################
Subprog IB_NBLIG
End

Subprog IB_ITMREF
End

Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_QTYTYP(VALEUR)
Variable Integer VALEUR
End

Subprog C_DETFLG(VALEUR)
Variable Integer VALEUR
End

Subprog C_CUMFLG(VALEUR)
Variable Integer VALEUR
End


######################################################################################
