Subprog IB_ITMREF
End

$ADD_MATERIAL
Local Integer WI, WLI, NOLM, NOL, SLIG
Local Decimal LRETQTY, LRETQTYREA
Local Decimal LSUPERFICIE
Local Shortint LANCHO
Local Integer LLONGITUD
Local Char WCCE(20)
Local Decimal WLFACTOR, WLQTYSOB
Local Integer WLTEST


If [M:MFG1]NBLIG=0 or [M:MFG2]ZNBLOT=0 or [M:MFG1]ZANCHOMAT=0 or [M:MFG1]ZMAXLONG=0: Return : Endif
NOL = -1
#buscamos linea de corte
For WLI = 0 To [M:MFG1]NBLIG-1
   If [M:MFG1]ZFABCOR(WLI)=2
      NOL=WLI
      Break
   Endif
Next
If NOL = -1 : Return : Endif
If [M:MFG2]ZLTITMREF(0)="" : Return : Endif
#Read[F:ITM]ITM0=[M:MFG1]ITMREF(NOL)
#Read[F:ITF]ITF0=[M:MFG1]ITMREF(NOL);[M:MFG0]MFGFCY
Read[F:ITM]ITM0=[M:MFG2]ZLTITMREF(0)
Read[F:ITF]ITF0=[M:MFG2]ZLTITMREF(0);[M:MFG0]MFGFCY
nolign += 1
NOLM = [M:MFG2]NBLIG   # nolign - 2   19.07.16 JLPR

#Infbox "NOLM" - num$(NOLM)
#Infbox "NOL" - num$(NOL)
## GH 19/06/13 bug 90478 Chgt d'article => recalcul de la qté dispo de la ligne composant de l'OF
#If [M:MFG2]ITMREF(WLIG)<>[M:MFMW]ITMREF
#   If [F:ITF]STOMGTCOD=2
#      Local Decimal WDIS
#      Local Integer WRET
#      Call STODISALL([M:MFG0]MFGFCY,[M:MFMW]ITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
#      [M:MFG2]AVAQTY(WLIG) = WDIS
#   Else
#      [M:MFG2]AVAQTY(WLIG) = 0
#   Endif
#Endif

[M:MFG2]CPNTYP(NOLM)    = 1
#[M:MFG2]ITMREF(NOLM)    = [M:MFG1]ITMREF(NOL)
#[M:MFG2]ITMDES1(NOLM)   = [M:MFG1]ITMDES1(NOL)
[M:MFG2]ITMREF(NOLM)    = [F:ITM]ITMREF
[M:MFG2]ITMDES1(NOLM)   = [F:ITM]ITMDES1
[M:MFG2]MFGLIN(NOLM)    = 0
[M:MFG2]MFGLINK(NOLM)   = 1
[M:MFG2]QTYCOD(NOLM)    = 1
[M:MFG2]CUMFLG(NOLM)    = 1
[M:MFG2]CUMFXDQTY(NOLM) = 0
[M:MFG2]BASQTY(NOLM)    = 1
[M:MFG2]BOMOPE(NOLM)    = 0
[M:MFG2]BOMOFS(NOLM)    = 0
[M:MFG2]STU(NOLM)       = [F:ITM]STU
[M:MFG2]BOMUOM(NOLM)    = [F:ITM]STU
[M:MFG2]BOMSTUCOE(NOLM) = 1
[M:MFG2]BOMQTY(NOLM)    = 1
[M:MFG2]LIKQTY(NOLM)    = 1
[M:MFG2]LIKQTYCOD(NOLM) = 1
[M:MFG2]QTYRND(NOLM)    = 2
[M:MFG2]SCA(NOLM)       = 0
[M:MFG2]BOMSHO(NOLM)    = ""
[M:MFG2]PICPRN(NOLM)    = 1
#Campos Especificos Corte

[M:MFG2]ZANCHO(NOLM)    = [M:MFG1]ZANCHOMAT : # Maximo Ancho de las bobinas Seleccionadas
[M:MFG2]ZLONGITUD(NOLM) = [M:MFG1]ZMAXLONG  : # Longitud total de corte necesaria

#JLPR 02-12-16 Comento y sustituyo por función para asignar factor
#JLPR 14-12-16 Tras comentarlo con Cerda y Tachi se acuerda que el factor a indicar en el Producto terminado sea el indicado en el articulo por:
#                                         - Hacerlo coincidir con el de los pedidosde venta
#                                         - Dicho factor es de conocimiento público, es decir, que está disponible para los clientes y cualquiera que desee consultarlo
#              Al indicar un peso real de la bobina, obviamente dicho factor variará pero al asignar se hace que KgsPedido=KgsStock.
#[M:MFG2]ZFACTOR(NOLM)   = [F:ITM]ZFACTOR
[M:MFG2]ZFACTOR(NOLM)   = func SPEMFG.RECALCULAR_FACTOR(0)

[M:MFG2]ZFABCOR(NOLM)   = [F:ITM]ZFABCOR

# Buscmos Mandril, Nş Cortes,

[M:MFG2]ZMANDRIL(NOLM)    = [M:MFG1]ZMANDMAT
[M:MFG2]ZMANDFLG(NOLM)    = 1
#### Calculo Cantidad

LSUPERFICIE=[M:MFG1]ZSUPERFMAT
LSUPERFICIE=arr(LSUPERFICIE,0.0001)

#Infbox "Ancho " - num$(LANCHO) - "Longitud " - num$(LLONGITUD)
#LANCHO=[M:MFG2]ZANCHO(NOLM)
#LLONGITUD=[M:MFG2]ZLONGITUD(NOLM)

#LSUPERFICIE=arr((LANCHO/1000)*LLONGITUD,0.0001)

[M:MFG2]ZSUPERFICIE(NOLM)=LSUPERFICIE
# Calcula LRETQTY en Base a Lotes Preasigandos
LRETQTY=0
LRETQTYREA=0
WLQTYSOB=0
For WLI=0 To [M:MFG2]ZNBLOT - 1
   # Buscar si Lote ya sumado en las filas procesadas
   WLTEST=1
   For WLJ=0 To WLI -1
      If [M:MFG2]ZLTSTOCOU(WLI)=[M:MFG2]ZLTSTOCOU(WLJ)
         WLTEST=0  # Lote Encontrado , no sumar
         Break
      Endif
   Next
   If WLTEST
      LRETQTY   +=[M:MFG2]ZLTQTYSTUASI(WLI)
      LRETQTYREA+=[M:MFG2]ZLTQTYSTUREA(WLI)
      # CALCULO Cantidad Sobrante
      If [M:MFG2]ZLTSOBRANTE(WLI)=2
         WLQTYSOB+=arr(([M:MFG2]ZLTLONGSOB(WLI)*[M:MFG2]ZLTANCHO(WLI)/1000)*[M:MFG2]ZLTFACTOR(WLI),0.0001)
      Endif
   Endif

Next
#WLI -=1
#If  WLI>=0 Then
#  If [M:MFG2]ZSLONG>=0 and WLI>=0 Then
#     WLQTYSOB=arr(([M:MFG2]ZSLONG*[M:MFG2]ZLTANCHO(WLI)/1000)*[M:MFG2]ZLTFACTOR(WLI),0.0001)
#  Else
#     WLQTYSOB=arr(([M:MFG1]ZLONGSOB*[M:MFG2]ZLTANCHO(WLI)/1000)*[M:MFG2]ZLTFACTOR(WLI),0.0001)
#  Endif
#Endif
LRETQTY-=WLQTYSOB  # descuento cantidad sobrante
LRETQTYREA-=WLQTYSOB
If LRETQTY<=0
# Si es Cero o menor que cero
# Se calcula LRETQTY en base La Superficie teorica
   If [M:MFG2]STU(NOLM)="M2"
       LRETQTY=LSUPERFICIE
   Else
       LRETQTY=arr((LSUPERFICIE*[M:MFG2]ZFACTOR(NOLM)),0.0001)
   Endif
Endif


#    Call C_RETQTY(LRETQTY) From SUBMFG2
#    If mkstat Then : End : Endif
Call AM_RETQTY(LRETQTY) From SUBMFG2
[M:MFG2]RETQTY(NOLM)=LRETQTY
[M:MFG2]ZRETQTYREA(NOLM)=LRETQTYREA
[M:MFG2]RETDAT(NOLM)    = [M:MFG1]STRDAT
[M:MFG2]USEQTY(NOLM)    = 0
[M:MFG2]ALLQTY(NOLM)    = 0
[M:MFG2]ALLSTA(NOLM)    = 1
[M:MFG2]SHTQTY(NOLM)    = 0
#                    [M:MFG2]AVAQTY(WLIG)    = 0 : # GH 19/06/13 bug 90478
[M:MFG2]BOMSEQ(NOLM)    = 0
#                    [M:MFG2]CSTFLG(WLIG)    = [M:MFMW]CSTFLG
[M:MFG2]STOMGTCOD(NOLM) = 2
[M:MFG2]PLANNER(NOLM)   = "" : # [F:ITF]PLANNER
[M:MFG2]SCOFLG(NOLM)    = 1 : #[M:MFMW]SCOFLG
[M:MFG2]LOC(NOLM)       = "" :# [M:MFMW]LOC
[M:MFG2]RELSCATIA(NOLM) = 1 #[M:MFMW]RELSCATIA        # 47579 mm 09.09
#                    If dim([M:MFMW]PKC)>0        # 47226 mm 05.08
#                        [M:MFG2]PKC(WLIG)       = [M:MFMW]PKC    # 43424 mm 01.08
#                    Endif
#                    If [M:MFMW]STOMGTCOD = 3
#                        If dim([M:MFMW]DEFPOT) > 0
#                            If [M:MFMW]DEFPOT <> 0
#                                [M:MFG2]DEFPOT(WLIG) = [M:MFMW]DEFPOT
#                                [M:MFG2]TYPQTY(WLIG) = 1
#                                [M:MFG2]RETQTY2(WLIG) = [M:MFMW]RETQTY2
#                                [M:MFG2]TYPQTY2(WLIG) = 2
#                            Else
#                                [M:MFG2]TYPQTY(WLIG) = 2
#                            Endif
#                        Endif
#                    Else
#                        If dim([M:MFG2]TYPQTY(WLIG)) > 0 : [M:MFG2]TYPQTY(WLIG) = 2 : Endif
#                    Endif
If dim([M:MFG2]TYPQTY(NOLM)) > 0 : [M:MFG2]TYPQTY(NOLM) = 2 : Endif
If [M:MFG1]NBLIG = 1
                        [M:MFG2]PJT(NOLM) = [M:MFG1]PJT(0)
Else
  If [M:MFG2]MFGLIN(NOLM) = 0
     LITM = [M:MFG1]PJT(0)
  Else
     For I = 0 To [M:MFG1]NBLIG-1
        If [M:MFG1]MFGLIN(I) = [M:MFG2]MFGLIN(NOLM)
           [M:MFG2]PJT(NOLM) = [M:MFG1]PJT(I)
           Break
        Endif
     Next I
   Endif
Endif

[M:MFG2]PTOCOD(NOLM) = func ITMLIB.GET_PTOCOD([M:MFG2]ITMREF(NOLM),[M:MFG0]MFGFCY) : # GH 09/01/2015 bug 105215
                    #If [F:ITF]PTOCOD <> ""
                    #   [M:MFG2]PTOCOD(WLIG) = [F:ITF]PTOCOD
                    #Else
                    #   Call PARAM([M:MFG0]MFGFCY,"DEFPTO",[M:MFG2]PTOCOD(WLIG)) From ADOVAL : #  GDEFPTO : # GH 20/11/13 bug 94608
                    #Endif

                    # chargement des sections analytiques

SLIG = nolign
nolign = NOLM + 1
For J = 1 To GNBDIE
    Call INISEC(WCCE,"MFM",J) From TRTX3CPT
    Assign "[M:MFG2]CCE"+num$(J)+"("+num$(NOLM)+")" With WCCE
Next
nolign = SLIG
[M:MFG2]MATSTA(NOLM)    = 1
[M:MFG2]XMATSTA(NOLM) = mess([M:MFG2]MATSTA(NOLM),363,1)
[M:MFG2]NBLIG     += 1
[M:MFG1]DMATNBR   += 1
Affzo [M:MFG2]
MMODIF = 1
mkstat = 4
Return

Subprog IB_NBLIG
If [M:MFG2]ITMREF(nolign-1)=""
   GBOUT15 = "Ańadir Material Corte"
Else
   GBOUT15 = ""
Endif
End

Subprog B15_NBLIG
Gosub ADD_MATERIAL
End

