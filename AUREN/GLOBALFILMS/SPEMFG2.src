######################################################################################
Subprog AS_ZANCHO(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"MFMW")
   If [M:MFMW]ZFABCOR<>2 :  mkstat=2 : Endif
Else
   If [M:MFG2]ZFABCOR(nolign-1)<>2 :  mkstat=2 : Endif
Endif
End

Subprog C_ZANCHO(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:MFG1]ZMINANCHO
   mkstat=2
Endif
End



Subprog AS_RETQTY(VALEUR)
Variable Decimal VALEUR
# Si fabricacion por corte no permitimos la modificacion la cantidad necesitada
If instr(1,dbgstr(1),"MFMW")
   If [M:MFMW]ZFABCOR=2 :  mkstat=2 : Endif
Else
   If [M:MFG2]ZFABCOR(nolign-1)=2 :  mkstat=2 : Endif
Endif
End

