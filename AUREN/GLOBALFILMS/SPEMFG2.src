End

######################################################################################
##
######################################################################################
Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
Local Decimal  LSUPERFICIE
Local Shortint LANCHO
Local Integer LLONGITUD

If instr(1,dbgstr(1),"MFMW")
   LANCHO=[M:MFMW]ZANCHO
Else
   LANCHO=[M:MFG2]ZANCHO(nolign-1)
Endif
LLONGITUD=VALEUR
Gosub CALCULA_SUPERFICIE
End

Subprog AS_ZMANDRIL(VALEUR)
Variable Decimal VALEUR
#Infbox GACTION  : # MFiBSUBFICH
If instr(1,dbgstr(1),"MFMW")
   If [M:MFMW]ZFABCOR<>2 :  mkstat=2 : Endif
Else
   If [M:MFG2]ZFABCOR(nolign-1)<>2 :  mkstat=2 : Endif
Endif

End


######################################################################################
## Calculo Superficie
######################################################################################
$CALCULA_SUPERFICIE
Local Decimal LRETQTY

#Infbox "Ancho " - num$(LANCHO) - "Longitud " - num$(LLONGITUD)

LSUPERFICIE=arr((LANCHO/1000)*LLONGITUD,0.0001)

If instr(1,dbgstr(1),"MFMW") and [M:MFMW]ZFABCOR=2 Then
 #  Infbox "Superficie " - num$(LSUPERFICIE) - "Factor " - num$([M:MFMW]ZFACTOR)
   [M:MFMW]ZSUPERFICIE=LSUPERFICIE
   If [M:MFMW]STU="M2"
      LRETQTY=LSUPERFICIE
   Else
       LRETQTY=arr((LSUPERFICIE*[M:MFMW]ZFACTOR),0.0001)
    Endif
    Call C_RETQTY(LRETQTY) From SUBMFG2
    If mkstat Then : End : Endif
    Call AM_RETQTY(LRETQTY) From SUBMFG2
    [M:MFMW]RETQTY=LRETQTY
    Affzo [M:MFMW]RETQTY
    Gosub CALCULA_MERMA From SPEMFG
Else
  If  [M:MFG2]ZFABCOR(nolign-1)=2 Then
  # Infbox "Superficie " - num$(LSUPERFICIE) - "Factor " - num$([M:MFG2]ZFACTOR(nolign-1))
   [M:MFG2]ZSUPERFICIE(nolign-1)=LSUPERFICIE
   If [M:MFG2]STU(nolign-1)="M2"
      LRETQTY=LSUPERFICIE
   Else
       LRETQTY=arr((LSUPERFICIE*[M:MFG2]ZFACTOR(nolign-1)),0.0001)
    Endif
    Call C_RETQTY(LRETQTY) From SUBMFG2
    If mkstat Then : End : Endif
    Call AM_RETQTY(LRETQTY) From SUBMFG2
    [M:MFG2]RETQTY(nolign-1)=LRETQTY
    Affzo [M:MFG2]RETQTY(nolign-1)
    Gosub CALCULA_MERMA From SPEMFG
  Endif
Endif

Return

