######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla MFMW) 05/12/2015 15:29:59 (ADMI2)
######################################################################################
Subprog AM_RETQTY(VALEUR)
Variable Decimal VALEUR
Local Decimal LRETQTY
Local Decimal  LSUPERFICIE,LFACTOR
Local Shortint LANCHO
Local Integer NOL
Local Integer LLONGITUD
Local Char LSTU(5)

If instr(1,dbgstr(1),"MFMW") and [M:MFMW]ZFABCOR=2

   LRETQTY=VALEUR
   LSTU=[M:MFMW]STU
   LANCHO=[M:MFMW]ZANCHO
   LFACTOR=[M:MFMW]ZFACTOR
   Gosub CALCULA_LONGITUD
   [M:MFMW]ZSUPERFICIE=LSUPERFICIE
   [M:MFMW]ZLONGITUD=LLONGITUD
   Affzo [M:MFMW]ZSUPERFICIE
   Affzo [M:MFMW]ZLONGITUD
Else

 If [M:MFG2]ZFABCOR=2
   NOL=nolign-1
   LRETQTY=VALEUR
   LSTU=[M:MFG2]STU(NOL)
   LANCHO=[M:MFG2]ZANCHO(NOL)
   LFACTOR=[M:MFG2]ZFACTOR(NOL)
   Gosub CALCULA_LONGITUD
   [M:MFG2]ZSUPERFICIE(NOL)=LSUPERFICIE
   [M:MFG2]ZLONGITUD(NOL)=LLONGITUD
   Affzo [M:MFG2]ZSUPERFICIE(NOL)
   Affzo [M:MFG2]ZLONGITUD(NOL)
 Endif
Endif
End

######################################################################################
## Calculo Superficie y Longitud
######################################################################################
$CALCULA_LONGITUD
#Infbox "fjcp: ANCHO:" -num$(LANCHO) - " factor: " - num$((LFACTOR))
If LSTU="M2" or LFACTOR=0
  LSUPERFICIE=LRETQTY
Else
   LSUPERFICIE=arr((LRETQTY/LFACTOR),0.0001)
Endif
LLONGITUD=arr((LSUPERFICIE/LANCHO)*1000,1)

Return
#################################################################################
### Subprogramas y rutinas para la gestion de los Lotes Pre-Asignados



### Grabar en tabla ZMFGSOQ (Pedidos Asignados OF)
$MFG2_GUARDAR_LOTASI
Local Integer WLI,WLJ, WGC
Raz[F:ZMFL]
Filter [F:ZMFL]
Delete [ZMFL] Where evalue("MFGNUM='" + [F:MFG]MFGNUM + "'")
If fstat<>0
      GOK=0
      Call FSTA("ZMFL") From GLOCK
      Return
Endif
Raz[F:ZMFL]
[F:ZMFL]=[F:MFG]
# JLPR 20.05.16 Se comentan las lineas, Tras consensuarlo con Fco.Cerda se acuerda permitir que podamos asignar MP sin Lineas
For WLI = 0 To [M:MFG2]ZNBLOT - 1
#   WGC = 0
#   For WLJ =0 To [MFG1]NBLIG -1
#      If [M:MFG2]ZLTGRPCOR(WLI)=[M:MFG1]ZGRPCOR(WLJ)
#         WGC=1
#         Break
#      Endif
#    Next
#    If WGC Then  : # Grabar si existe grupo de corte

       [F:ZMFL]MFGLIN=[M:MFG2]ZLTMFGLIN(WLI)
       [F:ZMFL]ZGRPCOR=[M:MFG2]ZLTGRPCOR(WLI)
       [F:ZMFL]ITMREF=[M:MFG2]ZLTITMREF(WLI)
       [F:ZMFL]ZANCHO= [M:MFG2]ZLTANCHO(WLI)
       [F:ZMFL]ZLONGITUD=[M:MFG2]ZLTLONGITUD(WLI)
       [F:ZMFL]ZMANDRIL=[M:MFG2]ZLTMANDRIL(WLI)
       [F:ZMFL]STOFCY=[M:MFG2]ZLTSTOFCY(WLI)
       [F:ZMFL]STOCOU=[M:MFG2]ZLTSTOCOU(WLI)
       [F:ZMFL]LOT=[M:MFG2]ZLTLOT(WLI)
       [F:ZMFL]SLO=[M:MFG2]ZLTSLO(WLI)
       [F:ZMFL]QTYSTUASI=[M:MFG2]ZLTQTYSTUASI(WLI)
       [F:ZMFL]ZQTYSTUREAL=[M:MFG2]ZLTQTYSTUREA(WLI)
       [F:ZMFL]STU=[M:MFG2]ZLTSTU(WLI)
       #  [F:ZMFL]ZNCORTES=[M:MFG2]ZLTNCORTES(WLI)
       [F:ZMFL]ZPROVEEDOR=[M:MFG2]ZLTPROVEEDOR(WLI)
       [F:ZMFL]ZSOBRANTE=[M:MFG2]ZLTSOBRANTE(WLI)

       [F:ZMFL]ZFACTOR=[M:MFG2]ZLTFACTOR(WLI)
       If [F:ZMFL]ZFACTOR=0 Then
           If ([F:ZMFL]ZLONGITUD*[F:ZMFL]ZANCHO) <>0
             [F:ZMFL]ZFACTOR=[F:ZMFL]QTYSTUASI*1000 /([F:ZMFL]ZLONGITUD *[F:ZMFL]ZANCHO)
           Endif
       Endif
      [F:ZMFL]ZLONGSOB=[M:MFG2]ZLTLONGSOB(WLI)
       Write [F:ZMFL]
       If fstat
          GOK=0
          Call FSTA("ZMFL") From GLOCK
          Break
       Endif
#   Endif
Next
Return

$MFG2_LEER_LOTASI
Local Integer WLI

If clalev([F:STOX])<=0 : Local File STOCK [STOX] : Endif

Filter [F:ZMFL]
Filter [F:ZMFL] Where MFGNUM=[F:MFG]MFGNUM
WLI=0
For  [F:ZMFL]
  [M:MFG2]ZLTMFGLIN(WLI)   =[F:ZMFL]MFGLIN
  [M:MFG2]ZLTGRPCOR(WLI)   =[F:ZMFL]ZGRPCOR
  [M:MFG2]ZLTGCANCHO(WLI)  =func ANCHO_GRUPO_CORTE([F:ZMFL]ZGRPCOR)
  [M:MFG2]ZLTITMREF(WLI)   =[F:ZMFL]ITMREF
  [M:MFG2]ZLTANCHO(WLI)    =[F:ZMFL]ZANCHO
  [M:MFG2]ZLTLONGITUD(WLI) =[F:ZMFL]ZLONGITUD
  [M:MFG2]ZLTMANDRIL(WLI ) =[F:ZMFL]ZMANDRIL
  [M:MFG2]ZLTSTOFCY(WLI)   =[F:ZMFL]STOFCY
  [M:MFG2]ZLTSTOCOU(WLI)   =[F:ZMFL]STOCOU
  [M:MFG2]ZLTLOT(WLI)      =[F:ZMFL]LOT
  [M:MFG2]ZLTSLO(WLI)      =[F:ZMFL]SLO
  [M:MFG2]ZLTQTYSTUASI(WLI)=[F:ZMFL]QTYSTUASI
  [M:MFG2]ZLTQTYSTUREA(WLI)=[F:ZMFL]ZQTYSTUREAL
  [M:MFG2]ZLTSTU(WLI)      =[F:ZMFL]STU
  [M:MFG2]ZLTSUPERF(WLI)   =([F:ZMFL]ZANCHO * ([F:ZMFL]ZLONGITUD-[F:ZMFL]ZLONGSOB) / 1000)
  [M:MFG2]ZLTFACTOR(WLI)   =[F:ZMFL]ZFACTOR
# [M:MFG2]ZLTNCORTES(WLI)  =[F:ZMFL]ZNCORTES
# [M:MFG2]ZLTPROVEEDOR(WLI)=[F:ZMFL]ZPROVEEDOR
  [M:MFG2]ZLTSOBRANTE(WLI) =[F:ZMFL]ZSOBRANTE
  [M:MFG2]ZLTLONGSOB(WLI)  =[F:ZMFL]ZLONGSOB
  Call MFG2_LEER_LOTASI_R(WLI)
  WLI += 1
Next
Filter [F:ZMFL]
[M:MFG2]ZNBLOT=WLI
Call CALCULA_SOBRANTE
Call LOTASI_COLOR
Affzo[M:MFG2]25
Return

Funprog ANCHO_GRUPO_CORTE(GC)
Value Integer GC
Local Integer I,A
Raz A
For I=0 To [M:MFG1]NBLIG-1
  If GC=[M:MFG1]ZGRPCOR(I)
    A+=[M:MFG1]ZANCHO(I)*[M:MFG1]ZNRANCHO(I)
  Endif
Next
End A

Subprog MFG2_LEER_LOTASI_R (WLI)
Value Integer WLI
Local Date FIFO
# Se llama tambien desde ZMFCOTRT + ZALTRT
[M:MFG2]ZQTYTEOR(WLI)    =func ZCOMUN.REDONDEAR(([M:MFG2]ZLTANCHO(WLI)*[M:MFG2]ZLTLONGITUD(WLI)/1000)*[M:MFG2]ZLTFACTOR(WLI), 4)
If [M:MFG2]ZLTFACTOR(WLI)<>0 and [M:MFG2]ZLTANCHO(WLI)<>0
[M:MFG2]ZLNGTEOR(WLI)    =func ZCOMUN.REDONDEAR(([M:MFG2]ZLTQTYSTUASI(WLI)/[M:MFG2]ZLTFACTOR(WLI))/ [M:MFG2]ZLTANCHO(WLI) *1000,0)
Endif
[M:MFG2]CST(WLI)         =func ZCOMUN.ART_COSTE([M:MFG0]MFGFCY,[M:MFG2]ZLTITMREF(WLI), [M:MFG2]ZLTLOT(WLI),[M:MFG2]ZLTSLO(WLI), FIFO)
Raz [F:STOX]
#Read  [STOX]STO0=[M:MFG0]MFGFCY;[F:ZMFL]STOCOU       #STO3 : ITMREF+STOFCY+LOT+SLO+LOC
Filter [F:STOX]
Filter [F:STOX] Where ITMREF=[M:MFG2]ZLTITMREF(WLI) and LOT=[M:MFG2]ZLTLOT(WLI) and SLO=[M:MFG2]ZLTSLO(WLI)
Read [F:STOX] First
If fstat=0
  [M:MFG2]ZLTPROVEEDOR(WLI)=[F:STOX]ZPROVEEDOR
  [M:MFG2]ZLTLOC(WLI)      =[F:STOX]LOC
  [M:MFG2]ZQTYDISP(WLI)    =[F:STOX]QTYSTU-[F:STOX]CUMALLQTY
  [M:MFG2]ZLTFACTOR(WLI)   =[F:STOX]ZFACTOR
Endif
Filter [F:STOX]
End

### Borrar Lotes Pre-asignados a una OF
### de la tabla ZMFGLOT
$MFG2_BORRA_LOTASI
Delete  [F:ZMFL] Where MFGNUM=[M:MFG0]MFGNUM
If fstat
      GOK=0
      Call FSTA("F:ZMFL") From GLOCK
Endif
Return

### Borrar Lotes Pre-asignados de una linea de corte (ITMREF y Grupo de corte)
### de la pantalla MFG2 de la OF EN curso
Subprog MFG2_BORRAR_LOTASI(WLGRPCOR)

Value Shortint WLGRPCOR
Local Integer WLI
# Borrar valores Mascara [MFG2] para la referencia
WLI=[M:MFG2]ZNBLOT-1
While WLI>=0
 If [M:MFG2]ZLTGRPCOR(WLI)=WLGRPCOR
    Dela WLI,1 [M:MFG2]ZNBLOT(WLI)
#    Dela WLI,1 [M:MFG2]ZLTMFGLIN, [M:MFG2]ZLTGRPCOR, [M:MFG2]ZLTITMREF,[M:MFG2]ZLTANCHO
#    Dela WLI,1 [M:MFG2]ZLTLONGITUD,[M:MFG2]ZLTMANDRIL,[M:MFG2]ZLTSTOFCY, [M:MFG2]ZLTSTOCOU
#    Dela WLI,1 [M:MFG2]ZLTLOT,[M:MFG2]ZLTSLO,[M:MFG2]ZLTQTYSTUASI,[M:MFG2]ZLTQTYSTUREA,[M:MFG2]ZLTSTU
#    Dela WLI,1 [M:MFG2]ZLTSUPERF,[M:MFG2]ZLTFACTOR,[M:MFG2]ZLTFACTOR
#    Dela WLI,1 [M:MFG2]ZLTNCORTES,[M:MFG2]ZLTPROVEEDOR,[M:MFG2]ZLTSOBRANTE, [M:MFG2]ZLTLONGSOB
    [M:MFG2]ZNBLOT -=1
 Endif
 WLI -=1
Wend
Affzo [M:MFG2]15
End

$MFMW_GUARDAR_LOTASI
Local Integer WLI,WLJ
# FJCP 12/02/2016 Cambio Lotes presasignados a lineas de productos y no de materiales.
#Call MFG2_BORRAR_LOTASI([M:MFMW]ITMREF,0)
#WLJ=[M:MFG2]ZNBLOT
#For WLI = 0 To [M:MFMW]ZNBLOT - 1
#      #[M:MFG2]ZLTMFGLIN(WLJ)=[M:MFMW]MFGLIN(WLI)
