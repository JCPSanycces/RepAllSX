#      [M:MFG2]ZLTGRPCOR(WLJ)=[M:MFMW]ZGRPCOR(WLI)
#      [M:MFG2]ZLTITMREF(WLJ)=[M:MFMW]ZLTITMREF(WLI)
#      [M:MFG2]ZLTANCHO(WLI)=[M:MFMW]ZLTANCHO(WLI)
#      [M:MFG2]ZLTLONGITUD(WLJ)=[M:MFMW]ZLTLONGITUD(WLI)
#      [M:MFG2]ZLTMANDRIL(WLJ)= [M:MFMW]ZLTMANDRIL(WLI)
#      [M:MFG2]ZLTSTOFCY(WLJ)=[M:MFMW]ZLTSTOFCY(WLI)
#      [M:MFG2]ZLTSTOCOU(WLJ)=[M:MFMW]ZLTSTOCOU(WLI)
