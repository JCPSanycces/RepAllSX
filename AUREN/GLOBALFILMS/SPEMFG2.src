## Etiqueta ańadida por el supervisor (pantalla MFG2) 11/05/2016 15:57:51 (ADMIN)
######################################################################################
Subprog AS_ZLTLONGSOB(VALEUR)
Variable Decimal VALEUR
# Si está asignada o cerrada no se permite modificar la longitud sobrante
If [M:MFG1]ALLSTA<>1  | [M:MFG0]MFGSTA = 4 Then
   mkstat = 2
Endif
End

Subprog C_ZLTLONGSOB(VALEUR)
Variable Decimal VALEUR
Local Shortint NOL : NOL = nolign - 1

If VALEUR <0 | VALEUR > [M:MFG2]ZLTLONGITUD(NOL) Then
    mkstat = 2
Endif
End

Subprog AM_ZLTLONGSOB(VALEUR)
Variable Decimal VALEUR
Local Shortint NOL : NOL = nolign - 1

If VALEUR>0 Then
  [M:MFG2]ZLTSOBRANTE(NOL)=2
Else
  [M:MFG2]ZLTSOBRANTE(NOL)=1
Endif
Affzo [M:MFG2]ZLTSOBRANTE(NOL)
[M:MFG2]ZLTLONGSOB(NOL)=VALEUR
#Call SOBRANTE(NOL)
# Actualizo campos por si un lote esta asignado a varios grupos de corte.
For I= 0 To [M:MFG2]ZNBLOT - 1
   If I <> NOL & [M:MFG2]ZLTLOT(I)=[M:MFG2]ZLTLOT(NOL) & [M:MFG2]ZLTSLO(I)=[M:MFG2]ZLTSLO(NOL) Then
      [M:MFG2]ZLTSOBRANTE(I)=[M:MFG2]ZLTSOBRANTE(NOL)
#      [M:MFG2]ZLTLONGSOB(I)=VALEUR
      [M:MFG2]ZLTLONGSOB(I) =[M:MFG2]ZLTLONGSOB(NOL)
      Affzo [M:MFG2]ZLTLONGSOB(I)
      Affzo [M:MFG2]ZLTSOBRANTE(I)
   Endif
Next
#
#Dbgaff
#[M:MFG2]ZLTLONGSOB(NOL)=VALEUR
Call CALCULA_SOBRANTE
mkstat=4
End

#Subprog SOBRANTE(NOL)
#Value Integer NOL
#Local Integer I
## Actualizo campos por si un lote esta asignado a varios grupos de corte.
#For I= 0 To [M:MFG2]ZNBLOT - 1
#   If I <> NOL & [M:MFG2]ZLTLOT(I)=[M:MFG2]ZLTLOT(NOL) & [M:MFG2]ZLTSLO(I)=[M:MFG2]ZLTSLO(NOL) Then
#      [M:MFG2]ZLTSOBRANTE(I)=[M:MFG2]ZLTSOBRANTE(NOL)
#      [M:MFG2]ZLTLONGSOB(I) =[M:MFG2]ZLTLONGSOB(NOL)
#      Affzo [M:MFG2]ZLTLONGSOB(I)
#      Affzo [M:MFG2]ZLTSOBRANTE(I)
#   Endif
#Next
#Call CALCULA_SOBRANTE
#End

Subprog CALCULA_SOBRANTE
Local Integer WTEST
Local Decimal WKG(3)
Local Integer WLN(3),WM2(3),F
Raz [M:MFG2]ZSLONG,WKG,WLN,WM2
For I= 0 To [M:MFG2]ZNBLOT - 1
  # Determino Kgs Sobrante y usados
  [M:MFG2]ZLTQTYSOB(I)=arr(([M:MFG2]ZLTLONGSOB(I)*[M:MFG2]ZLTANCHO(I)/1000)*[M:MFG2]ZLTFACTOR(I),0.0001)
  [M:MFG2]ZLTQTYUSA(I)=[M:MFG2]ZLTQTYSTUASI(I)-[M:MFG2]ZLTQTYSOB(I)
  # Acumulo
   WTEST=1
   For J = 0 To I - 1
     If [M:MFG2]ZLTLOT(I)=[M:MFG2]ZLTLOT(J) & [M:MFG2]ZLTSLO(I)=[M:MFG2]ZLTSLO(J) Then
        WTEST = 0
     Endif
   Next
   If WTEST = 1 Then
      [M:MFG2]ZSLONG += [M:MFG2]ZLTLONGSOB(I)
      WKG(0)+=[M:MFG2]ZLTQTYSTUASI(I)
      WKG(1)+=[M:MFG2]ZLTQTYSOB(I)
      WKG(2)+=[M:MFG2]ZLTQTYUSA(I)
      WLN(0)+=[M:MFG2]ZLTLONGITUD(I)
      WLN(1)+=[M:MFG2]ZLTLONGSOB(I)
      WLN(2)+=([M:MFG2]ZLTLONGITUD(I)-[M:MFG2]ZLTLONGSOB(I))
      WM2(0)+=arr([M:MFG2]ZLTLONGITUD(I)*[M:MFG2]ZLTANCHO(I)/1000,1)
      WM2(1)+=arr([M:MFG2]ZLTLONGSOB(I) *[M:MFG2]ZLTANCHO(I)/1000,1)
   Endif
Next
# Borro rejilla Totales
Raz [M:MFG2]ZNBTOT
Effzo [M:MFG2]25
# Muestro & Refreso
F=[M:MFG2]ZNBTOT
[M:MFG2]ZTDES(F)="Total lotes"
[M:MFG2]ZTKGS(F)=WKG(0)
[M:MFG2]ZTLNG(F)=WLN(0)
[M:MFG2]ZTM2 (F)=WM2(0)
[M:MFG2]ZNBTOT+=1
F=[M:MFG2]ZNBTOT
[M:MFG2]ZTDES(F)="Sobrante"
[M:MFG2]ZTKGS(F)=WKG(1)
[M:MFG2]ZTLNG(F)=WLN(1)
[M:MFG2]ZTM2 (F)=WM2(1)
[M:MFG2]ZNBTOT+=1
F=[M:MFG2]ZNBTOT
[M:MFG2]ZTDES(F)="Usado"
[M:MFG2]ZTKGS(F)=WKG(2)
[M:MFG2]ZTLNG(F)=WLN(2)
[M:MFG2]ZTM2 (F)=WM2(0)-WM2(1)
[M:MFG2]ZNBTOT+=1
# Totales a Producir
Gosub TOT_A_PRODUCIR
Affzo [M:MFG2]ZSLONG
Affzo [M:MFG2]15,25
#JLPR 20.05.16  Lanzar Exluir & Ańadir de
Gosub CALCULA_LONGITUDTOTAL From SPEMFG
Gosub CALCULA_MERMA From SPEMFG
Call EXCLUIR_ANADIR
Call LOTASI_COLOR
# Avisaar en caso de que Kgs usados en rejilla standar sea distinto a Kgs usados en rejilla totales
If [M:MFG2]ZTKGS(2)<>[M:MFG2]RETQTY(0)
  Chgstl [M:MFG2]ZTKGS(2)  With "BACKRED"
  Chgstl [M:MFG2]RETQTY(0) With "BACKRED"
Endif
If [M:MFG2]ZTLNG(5)<>0
  Chgstl [M:MFG2]ZTLNG(5)  With "BACKYELLOW"
Endif
End

$TOT_A_PRODUCIR
#Raz WTEST,WKG,WLN,WM2
##Ordeno por GrupoCorte+LŞ
#Sorta [M:MFG1]NBLIG [M:MFG1]NBLIG Order By [M:MFG1]ZGRPCOR(indice),[M:MFG1]NOLIG(indice)
#For I=0 To [M:MFG1]NBLIG-1
#  If WTEST<>[M:MFG1]ZGRPCOR(I)
#    WTEST=[M:MFG1]ZGRPCOR(I)
#    WLN+=[M:MFG1]ZLONGITUD(I)*[M:MFG1]ZNTIRADAS(I)
#  Endif
#  If [M:MFG1]ZQTYBOBUNI(I)>0
#    WKG+=[M:MFG1]ZQTYBOBUNI(I)*([M:MFG1]ZBOBCTE(I)+[M:MFG1]ZBOBSTK(I))
#  Else
#    WKG+=[M:MFG1]UOMEXTQTY(I)
#  Endif
#  WM2+=([M:MFG1]ZLONGITUD(I)*[M:MFG1]ZANCHO(I)/1000)*([M:MFG1]ZBOBCTE(I)+[M:MFG1]ZBOBSTK(I))
#Next
##Ordeno por LŞ
#Sorta [M:MFG1]NBLIG [M:MFG1]NBLIG Order By [M:MFG1]NOLIG(indice)
#Affzo [M:MFG1]5
Call TOTAPRODUCIR(WKG,WLN,WM2)

[M:MFG2]ZNBTOT+=1
F=[M:MFG2]ZNBTOT
[M:MFG2]ZTDES(F)="A producir"
[M:MFG2]ZTKGS(F)=WKG
[M:MFG2]ZTLNG(F)=WLN
[M:MFG2]ZTM2 (F)=WM2
[M:MFG2]ZNBTOT+=1
F=[M:MFG2]ZNBTOT
[M:MFG2]ZTDES(F)="DifŞ"
[M:MFG2]ZTKGS(F)=[M:MFG2]ZTKGS(2)-[M:MFG2]ZTKGS(4)
[M:MFG2]ZTLNG(F)=[M:MFG2]ZTLNG(2)-[M:MFG2]ZTLNG(4)
[M:MFG2]ZTM2 (F)=[M:MFG2]ZTM2 (2)-[M:MFG2]ZTM2 (4)
[M:MFG2]ZNBTOT+=1
Return

Subprog TOTAPRODUCIR(WKG,WLN,WM2)
Variable Decimal WKG
Variable Integer WLN,WM2
Raz WKG,WLN,WM2
Local Integer LLONGITM, LLONGGRP
Local Integer ZGRN(50),ZGRL(50),F,G,H
Raz ZGRN,ZGRL,G
#  Los Grupos de corte, no tienen por que ir correlativos
#  1ş) Saca los GC involucrados
#  2ş) Acumulo datos de cada GC
For F=0 To [M:MFG1]NBLIG -1
  If [M:MFG1]ZFABCOR(F)=2 and ([M:MFG1]ITMTYP(F)=1 or [M:MFG1]ITMTYP(F)=2)
    If find([M:MFG1]ZGRPCOR(F),ZGRN)=0
      ZGRN(G)=[M:MFG1]ZGRPCOR(F)
      G+=1
    Endif
  Endif
Next
# Por cada GC determino su longitud, Kgs y M2
For H=0 To G-1
  Raz LLONGGRP
  For F=0 To [M:MFG1]NBLIG -1
    If [M:MFG1]ZGRPCOR(F)=ZGRN(H)
      Gosub TOTAPRODUCIR_CALCULO
    Endif
  Next
  WLN+=LLONGGRP # Acumulo Longitud Grupo Anterior
Next
End

$TOTAPRODUCIR_CALCULO
# Acumulo  la Longitud mayor del GC
LLONGITM=([M:MFG1]ZLONGITUD(F)*[M:MFG1]ZNTIRADAS(F))
If LLONGITM>LLONGGRP Then LLONGGRP=LLONGITM Endif
# Acumulo  Kgs
If [M:MFG1]ZQTYBOBUNI(F)>0
  WKG+=[M:MFG1]ZQTYBOBUNI(F)*([M:MFG1]ZBOBCTE(F)+[M:MFG1]ZBOBSTK(F))
Else
  WKG+=[M:MFG1]UOMEXTQTY(F)
Endif
# Acumulo  M2
WM2+=([M:MFG1]ZLONGITUD(F)*[M:MFG1]ZANCHO(F)/1000)*([M:MFG1]ZBOBCTE(F)+[M:MFG1]ZBOBSTK(F))
Return


Subprog LOTASI_COLOR
# Poner en rojo si difŞ
  For I= 0 To [M:MFG2]ZNBLOT - 1
    If abs([M:MFG2]ZLTQTYSTUASI(I)-[M:MFG2]ZQTYTEOR(I))>1  or  abs([M:MFG2]ZLTLONGITUD(I)-[M:MFG2]ZLNGTEOR(I))>5 or (abs([M:MFG2]ZLTQTYSTUASI(I)-[M:MFG2]ZQTYDISP(I))>1 and [M:MFG1]MFGTRKFLG<5 and [M:
& MFG1]ALLSTA=1)
      Chgstl [M:MFG2]ZNBLOT(I) With "BACKYELLOW"
      If abs([M:MFG2]ZLTQTYSTUASI(I)-[M:MFG2]ZQTYTEOR(I))>1
        Chgstl [M:MFG2]ZLTQTYSTUASI(I) With "BACKRED"
        Chgstl [M:MFG2]ZQTYTEOR(I) With "BACKRED"
      Endif
      If abs([M:MFG2]ZLTLONGITUD(I)-[M:MFG2]ZLNGTEOR(I))>5
        Chgstl [M:MFG2]ZLTLONGITUD(I) With "BACKRED"
        Chgstl [M:MFG2]ZLNGTEOR(I) With "BACKRED"
      Endif
      If abs([M:MFG2]ZLTQTYSTUASI(I)-[M:MFG2]ZQTYDISP(I))>1 and [M:MFG1]MFGTRKFLG<5 and [M:MFG1]ALLSTA=1
        Chgstl [M:MFG2]ZLTQTYSTUASI(I) With "BACKRED"
        Chgstl [M:MFG2]ZQTYDISP(I) With "BACKRED"
      Endif
    Else
      Chgstl [M:MFG2]ZNBLOT(I) With "NORMAL"
    Endif
  Next
End
#

Subprog EXCLUIR_ANADIR
Local Decimal  RWQTY
# Solo si está   <<NO Asignado>>
  If [M:MFG1]ALLSTA<>1 : End  :  Endif
# Si no hay nada en Lotes preasignados, nos salimos

#  EXCLUIR si rejilla llena, independientemente de si hay o no Lotes preasignados
  If [M:MFG2]NBLIG>0
    Call B3_NBLIG From SUBMFG2
  Endif
#  JLPR 28.11...hacerlo solo cuando haya algo en Lotes preasignados, para permitir crear OF temporal con Matarial IMPREVISTO, con el fin de asignar a contenedores de materia prima que vendrá
  RWQTY=[M:MFG2]RETQTY(0)
  If [M:MFG2]ZNBLOT>0
  #  AŃADIR Si hay Lotes preasignados y rejilla vacia, que deberia de estarlo !!!!!
    If [M:MFG2]ZNBLOT>0   and [M:MFG2]NBLIG<1
      Call B15_NBLIG From SPEMFG2
    Endif
    Affzo [M:MFG2]10
  Elsif [M:MFG2]NBLIG>0
    # Si no hay lotes y el 1er articulo indicado en rejilla componentes del standar marcado como corte, entonces ZFABCOR=2
    Local Integer F
    For F=0 To [M:MFG2]NBLIG-1
      Read [F:ITM]ITM0=[M:MFG2]ITMREF(F)
      [M:MFG2]ZFABCOR(F)=[F:ITM]ZFABCOR
    Next
  Endif
  If RWQTY<>[M:MFG2]RETQTY(0)
    [M:MFG1]ZACTU = 2
    mkstat=4
  Endif
End
