Subprog AS_BOMQTY(VALEUR)
Variable Decimal VALEUR
Local Decimal WLQTYMAND
If [M:MFMW]ZFABCOR=2 :   mkstat=2 : Endif
If [M:MFMW]ZMANDFLG=2 and  [M:MFMW]ZTEST Then
   Gosub CALCULA_QTYMAND
   VALEUR = WLQTYMAND
   [M:MFMW]ZTEST=0
Endif
End
######################################################################################
##
######################################################################################
$CALCULA_QTYMAND
    # Calculo Cantidad necesario
    WLQTYMAND=0
    For WLI=0 To [M:MFG1]NBLIG - 1
       If [M:MFG1]ZFABCOR(WLI)=2 and [M:MFG1]ZMANDRIL(WLI)=[F:ITM]ZMANDRIL
          WLQTYMAND += ([M:MFG1]ZANCHO(WLI)*[M:MFG1]ZQTYBOB(WLI)/1000)
       Endif
    Next
Return



Subprog AS_LIKQTY(VALEUR)
Variable Decimal VALEUR
If [M:MFMW]ZFABCOR=2  :  mkstat=2 : Endif
If [M:MFMW]ZMANDFLG=2 and [M:MFMW]ZTEST Then
   Gosub CALCULA_QTYMAND
   VALEUR = WLQTYMAND
   [M:MFMW]ZTEST=0
Endif
End
