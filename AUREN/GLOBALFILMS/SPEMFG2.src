######################################################################################
##
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Decimal  LSUPERFICIE
Local Shortint LANCHO
Local Integer LLONGITUD
Local Integer WLOK
# Asigna Factor
If [F:ITM]ZFACTOR <>0
   [M:MFMW]ZFACTOR = [F:ITM]ZFACTOR
Else
   [M:MFMW]ZFACTOR = 1
Endif
Affzo [M:MFMW]ZFACTOR

If [M:MFMW]ZANCHO=0 : [M:MFMW]ZANCHO=[M:MFG1]ZANCHOMAT : Endif
Affzo [M:MFMW]ZANCHO

If [M:MFMW]ZLONGITUD=0 : [M:MFMW]ZLONGITUD=[M:MFG1]ZMAXLONG : Endif
Affzo [M:MFMW]ZLONGITUD

# Asigna Flag Facturacion Corte
If  [F:ITM]ZFABCOR=2
  [M:MFMW]ZFABCOR=[F:ITM]ZFABCOR
  #[M:MFMW]ZANCHO=[M:MFG1]ZMINANCHO
  #[M:MFMW]ZLONGITUD=[M:MFG1]ZMAXLONG
  # Affzo [M:MFMW] ZLONGITUD,ZANCHO
  LLONGITUD=[M:MFMW]ZLONGITUD
  LANCHO=[M:MFMW]ZANCHO
  Gosub CALCULA_SUPERFICIE

Else
   [M:MFMW]ZFABCOR=1
Endif

### Control Es Mandril?
If [F:ITM]ZMANDFLG = 2
   [M:MFMW]ZTEST=1
    [M:MFMW]ZMANDFLG=2
   # [M:MFMW]LIKQTYCOD=2
    # Affzo [M:MFMW]LIKQTYCOD
    #If [F:ITM]ZMANDRIL<>[M:MFG1]ZMANDMAT
       #WLOK=1
       #Call OUINON("Diametro Mmandril no coincide,żContinuar?",WLOK) From GESECRAN
       #If !WLOK Then
       #   mkstat=2
       #Endif
    #Endif

Else
    [M:MFMW]ZTEST=0
    [M:MFMW]ZMANDFLG=1
Endif
End

