#<AdxTL>@(#)0.0.0.0 $Revision$
#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
  When "OUVRE"       :  Gosub OUVRE
  When "TITRE"       :  Gosub TITRE_S
  When "DEBUT"       :  Gosub DEBUT
  When "SETBOUT"     :  Gosub SETBOUT

  When "BOUTON"      :  Gosub BOUTON
  When "APRES_MODIF" :  Gosub APRES_MODIF

  When "END"         :  Gosub FIN_S
  When "FIN"

  When "AVANT_LIS"
  When "LIS"

Endcase
Return

$OUVRE
Local Integer VBUSCAR
If clalev([F:WSIH]) <=0   :  Local File SINVOICE   [F:WSIH]  : Endif
Return

$FIN_S
Return

$TITRE_S
TIT="MARGENES + AJUSTE COSTE EN LINEAS DE FRA"# << EN PRUEBAS # PDTE.VALIDAR >>"
Return

$DEBUT
If GFONCTION1="GESZINVT"    Raz  [M:ZMARG0],[M:ZMARG]   Endif
Chgfmt [M:ZMARG0]ZNADA With "-"  #  ZNADA se usa para guardar valores !!!!!
# Guardo valores
# Tope de filas en rejilla
[M:ZMARG0]FLDNUM(0) = func ZCOMUN.FILAS_GRID("ZMARG","NBLIG")
[M:ZMARG0]FLDNUM(1) = func ZCOMUN.FILAS_GRID("ZMARG","NLOTE")
[M:ZMARG0]FLDNUM(2) = func ZCOMUN.FILAS_GRID("ZMARG","NLOTU")
[M:ZMARG0]FLDNUM(3) = 0 # Total filas a regularizar - Amarillo
If GUSER="ADMIN"
  [M:ZMARG0]FLDNUM(4) = -100   # Margen inferior
  [M:ZMARG0]FLDNUM(5) = 100    # Margen superior
Else
  [M:ZMARG0]FLDNUM(4) = 5   # Margen inferior
  [M:ZMARG0]FLDNUM(5) = 40  # Margen superior
Endif
[M:ZMARG0]FLDNUM(6) = 0  # Para lanzar coloreado rejilla en SETBOUT
[M:ZMARG0]FLDNUM(7) = 0  # Para saber cuando estoy recalculando
[M:ZMARG0]FLDNUM(8) = 0  # Para saber nş fila en NBLIG, para poner en azul o quitarlo, ademas de evitar volver a llenar rejilla NLOTE con lo mismo
[M:ZMARG0]FLDNUM(9) = 0  # Para saber nş fila en NLOTU, para evitar volver a llenar rejilla NLOTU con lo mismo
[M:ZMARG0]FLDNUM(10)= func ZCOMUN.FILAS_GRID("ZMARG1","NBLIG")
[M:ZMARG0]FLDNUM(11)= func ZCOMUN.FILAS_GRID("ZMARG2","NBLIG")
[M:ZMARG0]FLDNUM(12)= func ZCOMUN.FILAS_GRID("ZMARG3","NBLIG")
#
[M:ZMARG0]FLDCHR(0) = func ZCOMUN.DATA_BASE_TIPO()
[M:ZMARG0]FLDCHR(1) = ""  # Para no preguntar al ajustar
# Valores por defecto
[M:ZMARG0]ZAVISO=">= "+num$([M:ZMARG0]FLDNUM(4))+"  y  <= "+num$([M:ZMARG0]FLDNUM(5))
Affzo [M:ZMARG0]ZAVISO
[M:ZMARG0]FDIF=100 # Para impedir que coja precios teoricos del fichero Excel facilitado en su dia   5
Affzo [M:ZMARG0]FDIF
[M:ZMARG0]ORDEN=1
Affzo [M:ZMARG0]ORDEN
[M:ZMARG0]FUNI=1
Affzo [M:ZMARG0]FUNI
[M:ZMARG0]FTIPO=1
Affzo [M:ZMARG0]FTIPO
[M:ZMARG0]FECINI=gdat$(1,month(date$),year(date$))
[M:ZMARG0]FECFIN=eomonth(date$)
Affzo [M:ZMARG0]FECINI,FECFIN
[M:ZMARG0]ZDTO=2
Affzo [M:ZMARG0]ZDTO
#
Local Char FSRVTMP(250)
#FSRVTMP=filpath("tmp",[M:ZMARG0]FLDCHR(1),"csv","","",adxmac(0))
FSRVTMP=filpath("tmp","Precios_14_01_17","csv","","",adxmac(0))
If filinfo(FSRVTMP,7)<0
  Infbox "Imposible sacar COSTES TEORICOS, al no encontrarse fichero "+FSRVTMP
Endif
Call BORRA_GRID
# Mostrar datos si venimos de GESZINVT
If GFONCTION1="GESZINVT" and [M:ZINVT0]ZFRA<>""
  VBUSCAR=1
  [M:ZMARG0]FFRA=[M:ZINVT0]ZFRA
  Call AM_FFRA([M:ZMARG0]FFRA) From SPEZMARG
  [M:ZMARG0]FITMREF=[M:ZINVT0]FITM
#  Read [F:WSIH]SIH0=[M:ZMARG0]FFRA
#  [M:ZMARG0]FFCY  =[F:WSIH]FCY
#  [M:ZMARG0]FECINI=[F:WSIH]ACCDAT
#  [M:ZMARG0]FECFIN=[F:WSIH]ACCDAT
  Affzo [M:ZMARG0]FFRA,FITMREF
#  Affzo [M:ZMARG0]FITMREF
#  Affzo [M:ZMARG0]FFCY
#  Affzo [M:ZMARG0]FECINI
#  Affzo [M:ZMARG0]FECFIN
Elsif GFONCTION1="GESZINVT" and [M:ZINVT0]ZNOL>=0
  VBUSCAR=2
  [M:ZMARG0]FECINI=date$
  [M:ZMARG0]FECFIN=date$
  Affzo [M:ZMARG0]FECINI
  Affzo [M:ZMARG0]FECFIN
Elsif GUSER<>"ADMIN"
  [M:ZMARG0]FMARINF=5
  Affzo [M:ZMARG0]FMARINF
  [M:ZMARG0]FMARSUP=25
  Affzo [M:ZMARG0]FMARSUP
Endif
Return

$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
If VBUSCAR<>22
  If COUZON<>"ORDEN" and COUZON<>"ZSEL" and COUZON<>"COEN" and COUZON<>"INVUNID" and COUZON<>"NBLIG"   Call BORRA_GRID   Endif
Endif
Return


$SETBOUT
Case VBUSCAR
When 1
  Raz VBUSCAR
  Call BUSCAR
When 2
#  If GUSER="ADMIN"  Infbox "Depurar  (SUBZMARG.src $SETBOUT)"    Endif
  VBUSCAR=22
  Local Integer F,ZOK
  F=[M:ZINVT0]ZNOL
  Call MOSTRAR_LOTES_FACTURADOS("",0,"",[M:ZINVT1]ITMREF(F),[M:ZINVT1]LOT(F),[M:ZINVT1]SLO(F),ZOK) From SPEZMARG
  Affzo [M:ZMARG]15
Endcase
If [M:ZMARG0]FLDNUM(6)
  Raz [M:ZMARG0]FLDNUM(6)
  Call REJ1_COL(-1)
  If [M:ZMARG0]FLDCHR(1) = "NO"
    Call AJUSTAR
    Raz [M:ZMARG0]FLDCHR(1)
  Endif
Endif
Return

$BOUTON
#If date$>=[13/02/2018]     Call ERREURT("Datos licencia insuficientes",1) From GESECRAN     :    Return     Endif
Raz [M:ZMARG0]FLDCHR(1)
Case BOUT
When "1"
  Call BUSCAR
#  If GUSER="ADMIN"
#     If [M:ZMARG0]FLDCHR(1)="ERROR"
#      Raz [M:ZMARG0]FLDCHR(1)
#     Else
##       [M:ZMARG0]FLDCHR(1) = "NO"
#       Call RECALCULAR
#     Endif
#  Endif
When "2"
  Call RECALCULAR
When "3"
  Call AJUSTAR
Endcase
Return

Subprog BUSCAR
Local Integer ZOK  :   ZOK=1
Local Integer F,ROK
Local Decimal MARGEN,COSTE,VENTA,DTOP
Local Char CRITERE(255)
Call BORRA_GRID
#Infbox "Depurar"
Raz [M:ZMARG0]FLDCHR(1)
If not func COMPROBACIONES  End   Endif
If clalev([F:WSOH]) <=0   :  Local File SORDER     [F:WSOH]  : Endif
If clalev([F:WSID]) <=0   :  Local File SINVOICED  [F:WSID]  : Endif
If clalev([F:WSIH]) <=0   :  Local File SINVOICE   [F:WSIH]  : Endif
If clalev([F:WFCY]) <=0   :  Local File FACILITY   [F:WFCY]  : Endif
#CRITERE="NETPRINOT<>0 and INVDAT>=[M:ZMARG0]FECINI and INVDAT<=[M:ZMARG0]FECFIN"
CRITERE="INVDAT>=[M:ZMARG0]FECINI and INVDAT<=[M:ZMARG0]FECFIN"
# and (arr(PFM*100/NETPRINOT,0.01)<=[M:ZMARG0]FMARINF or arr(PFM*100/NETPRINOT,0.01)>=[M:ZMARG0]FMARSUP)
If [M:ZMARG0]FCPY   <>"" CRITERE+=" and CPY=[M:ZMARG0]FCPY" Endif
If [M:ZMARG0]FBPCINV<>"" CRITERE+=" and BPCINV=[M:ZMARG0]FBPCINV" Endif
If [M:ZMARG0]FITMREF<>"" CRITERE+=" and ITMREF=[M:ZMARG0]FITMREF" Endif
If [M:ZMARG0]FFRA<>""    CRITERE+=" and NUM=[M:ZMARG0]FFRA" Endif
Case [M:ZMARG0]FUNI
When 2  CRITERE+=" and SAU='KG'"
When 3  CRITERE+=" and SAU='M2'"
Endcase
Filter [F:WSID] Where evalue(CRITERE)
For [F:WSID]
  COSTE=arr([F:WSID]CPRPRI/[F:WSID]SAUSTUCOE,0.0001)
  If [F:WSID]AMTNOTLIN=0
  DTOP=0
  Else
  DTOP =arr([F:WSID]DDTANOT(0)*100/[F:WSID]AMTNOTLIN,0.01)
  Endif
  VENTA=[F:WSID]NETPRINOT/[F:WSID]SAUSTUCOE
  If [M:ZMARG0]ZDTO=2    VENTA+=arr(VENTA*(DTOP/100),0.0001)   Endif
  If VENTA<>0
    MARGEN=arr((VENTA-COSTE)*100/VENTA,0.01)
  Else
    MARGEN=0
  Endif
  If ([M:ZMARG0]FMARINF =0 and [M:ZMARG0]FMARSUP=0)       or
&    ([M:ZMARG0]FMARINF<>0 and MARGEN<=[M:ZMARG0]FMARINF) or
&    ([M:ZMARG0]FMARSUP<>0 and MARGEN>=[M:ZMARG0]FMARSUP)
    If [M:ZMARG0]FTIPO=1
      ROK=1
    Else
      Read [F:WSIH]SIH0=[F:WSID]NUM
      If [F:WSIH]INVTYP=[ZMARG0]FTIPO-1 Then ROK=1 Else ROK=0 Endif
    Endif
    If ROK
      F=[M:ZMARG]NBLIG
      If F+1>=[M:ZMARG0]FLDNUM(0)
        MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(0)+1) + " filas para mostrar lineas de Fra\.\Pida que se lo aumenten"
        Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
        ZOK=0
      Else
        Gosub MOSTRAR_LIN
      Endif
    Endif
  Endif
  If not ZOK   Break   Endif
Next
Call RESUMEN
Call ORDENA_GRID
If not ZOK [M:ZMARG0]FLDCHR(1) = "ERROR"   Endif
End

$MOSTRAR_LIN
Read [F:WSOH]SOH0=[F:WSID]SOHNUM
Read [F:WFCY]FCY0=[F:WSID]SALFCY
[M:ZMARG]LEGCPY(F)   =[F:WFCY]LEGCPY
[M:ZMARG]SALFCY(F)   =[F:WSID]SALFCY
[M:ZMARG]NUM(F)      =[F:WSID]NUM
[M:ZMARG]INVDAT(F)   =[F:WSID]INVDAT
[M:ZMARG]BPCINV(F)   =[F:WSID]BPCINV
[M:ZMARG]SIDLIN(F)   =[F:WSID]SIDLIN
[M:ZMARG]SDHNUM(F)   =[F:WSID]SDHNUM
[M:ZMARG]SDDLIN(F)   =[F:WSID]SDDLIN
[M:ZMARG]ORDDAT(F)   =[F:WSOH]ORDDAT
[M:ZMARG]ITMREF(F)   =[F:WSID]ITMREF
[M:ZMARG]ZANCHO(F)   =func SPESOH.MODIFICA_ANCHO_DIVISOR([F:WSID]ITMREF,[F:WSID]ZANCHO)
[M:ZMARG]ZLONGITUD(F)=[F:WSID]ZLONGITUD
[M:ZMARG]NUM(F)      =[F:WSID]NUM
[M:ZMARG]CPRPRI(F)   =COSTE
[M:ZMARG]DTO(F)      =DTOP
[M:ZMARG]NETPRINOT(F)=VENTA
[M:ZMARG]NETPRINOTORI(F)=[M:ZMARG]NETPRINOT(F)
[M:ZMARG]PFM(F)      =VENTA-[M:ZMARG]CPRPRI(F) #arr([F:WSID]PFM/[F:WSID]SAUSTUCOE,0.0001)  #
[M:ZMARG]PFMP(F)     =MARGEN
[M:ZMARG]ZQTYBOB(F)  =[F:WSID]ZQTYBOB
[M:ZMARG]QTYSTU(F)   =[F:WSID]QTYSTU
[M:ZMARG]QTYSTUORI(F)=[F:WSID]QTYSTU
[M:ZMARG]STU(F)      =[F:WSID]STU
[M:ZMARG]SAU(F)      =[F:WSID]SAU
[M:ZMARG]SAUSTUCOE(F)=[F:WSID]SAUSTUCOE
[M:ZMARG]COSTEORI(F) =arr([F:WSID]ZCPRPRIORI/[F:WSID]SAUSTUCOE,0.0001)
[M:ZMARG]NBLIG+=1
Call RESUMEN_ACU(F,ZOK)
Return

Subprog RESUMEN_ACU(L,ZOK)
Value    Integer L
Variable Integer ZOK
Local Integer F,T
Local Char MSG(255)
Local Decimal  COSTE,VENTA
# Decimales en precios
#  Coste       5 decimales
#  Venta Kgs 2 decimales    M2 3 decimales
#
# Decimales en cantidades
#  4  KG y M2
T=-1
For F=0 To [M:ZMARG1]NBLIG-1
  If [M:ZMARG1]ITMREF(F)=[M:ZMARG]ITMREF(L) and [M:ZMARG1]BPCINV(F)=[M:ZMARG]BPCINV(L)
    T=F
    Gosub RESUMEN_ACU_DAT
    Break
  Endif
Next
If T=-1
  T=[M:ZMARG1]NBLIG
  If T+1>=[M:ZMARG0]FLDNUM(10)
    MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(10)+1) + " filas para mostrar RESUMEN\.\Pida que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    ZOK=0
  Else
    [M:ZMARG1]ITMREF(T)=[M:ZMARG]ITMREF(L)
    [M:ZMARG1]BPCINV(T)=[M:ZMARG]BPCINV(L)
    Gosub RESUMEN_ACU_DAT
    [M:ZMARG1]NBLIG+=1
  Endif
Endif
End

$RESUMEN_ACU_DAT
ZCANTK=arr([M:ZMARG]QTYSTU(L),0.0001)
[M:ZMARG1]CANTK(T) +=ZCANTK

ZCANTM=arr([M:ZMARG]QTYSTU(L)/[M:ZMARG]SAUSTUCOE(L),0.0001)
[M:ZMARG1]CANTM(T) +=arr(ZCANTM,0.0001)

COSTE=arr([M:ZMARG]CPRPRI(L)   *ZCANTK,0.01)
VENTA=arr([M:ZMARG]NETPRINOT(L)*ZCANTK,0.01)
[M:ZMARG1]COSTEK(T)+=COSTE
[M:ZMARG1]VENTAK(T)+=VENTA
[M:ZMARG1]COSTEM(T)+=COSTE
[M:ZMARG1]VENTAM(T)+=VENTA
Return

Subprog RESUMEN
Local Integer F,T
# Filas de total por unidad venta
#T=evalue("[M:ZMARG"+num$(F)+"]NBTOT")
#Assign ("[M:ZMARG"+num$(F)+"]TUNIDAD(T)") With "KG"
T=[M:ZMARG1]NBTOT
[M:ZMARG1]TUNIDAD(T)="KG"
[M:ZMARG1]NBTOT+=1
T=[M:ZMARG1]NBTOT
[M:ZMARG1]TUNIDAD(T)="M2"
[M:ZMARG1]NBTOT+=1
#
T=[M:ZMARG2]NBTOT
[M:ZMARG2]TUNIDAD(T)="KG"
[M:ZMARG2]NBTOT+=1
T=[M:ZMARG2]NBTOT
[M:ZMARG2]TUNIDAD(T)="M2"
[M:ZMARG2]NBTOT+=1
#
T=[M:ZMARG3]NBTOT
[M:ZMARG3]TUNIDAD(T)="KG"
[M:ZMARG3]NBTOT+=1
T=[M:ZMARG3]NBTOT
[M:ZMARG3]TUNIDAD(T)="M2"
[M:ZMARG3]NBTOT+=1
#
For T=0 To [M:ZMARG1]NBLIG-1
  [M:ZMARG1]MARGENK(T) =[M:ZMARG1]VENTAK(T)-[M:ZMARG1]COSTEK(T)
  If [M:ZMARG1]CANTK(T)<>0
  [M:ZMARG1]COSTEKM(T) =arr([M:ZMARG1]COSTEK(T)/[M:ZMARG1]CANTK(T),0.00001)
  [M:ZMARG1]VENTAKM(T) =arr([M:ZMARG1]VENTAK(T)/[M:ZMARG1]CANTK(T),0.01)
  [M:ZMARG1]MARGENKM(T)=[M:ZMARG1]MARGENK(T)/[M:ZMARG1]CANTK(T)
  Endif
  If [M:ZMARG1]VENTAK(T)<>0
  [M:ZMARG1]MARGENPK(T)=arr([M:ZMARG1]MARGENK(T)*100/[M:ZMARG1]VENTAK(T),0.01)
  Endif

  [M:ZMARG1]MARGENM(T) =[M:ZMARG1]VENTAM(T)-[M:ZMARG1]COSTEM(T)
  If [M:ZMARG1]CANTM(T)<>0
  [M:ZMARG1]COSTEMM(T) =arr([M:ZMARG1]COSTEM(T)/[M:ZMARG1]CANTM(T),0.00001)
  [M:ZMARG1]VENTAMM(T) =arr([M:ZMARG1]VENTAM(T)/[M:ZMARG1]CANTM(T),0.001)
  [M:ZMARG1]MARGENMM(T)=[M:ZMARG1]MARGENM(T)/[M:ZMARG1]CANTM(T)
  Endif
  If [M:ZMARG1]VENTAM(T)<>0
  [M:ZMARG1]MARGENPM(T)=arr([M:ZMARG1]MARGENM(T)*100/[M:ZMARG1]VENTAM(T),0.01)
  Endif
  # Acumular para totales
  [M:ZMARG1]TCANT(0) +=[M:ZMARG1]CANTK(T)
  [M:ZMARG1]TCOSTE(0)+=[M:ZMARG1]COSTEK(T)
  [M:ZMARG1]TVENTA(0)+=[M:ZMARG1]VENTAK(T)
  [M:ZMARG1]TCANT(1) +=[M:ZMARG1]CANTM(T)
  [M:ZMARG1]TCOSTE(1)+=[M:ZMARG1]COSTEM(T)
  [M:ZMARG1]TVENTA(1)+=[M:ZMARG1]VENTAM(T)
  #
  Call RESUMEN_ACU_CTE(T)
  Call RESUMEN_ACU_ART(T)
Next
For T=0 To 1
  [M:ZMARG1]TMARGEN(T) =[M:ZMARG1]TVENTA(T)-[M:ZMARG1]TCOSTE(T)
  If [M:ZMARG1]TCANT(T)<>0
  [M:ZMARG1]TCOSTEM(T) =arr([M:ZMARG1]TCOSTE(T)/[M:ZMARG1]TCANT(T),0.00001)
  [M:ZMARG1]TVENTAM(T) =arr([M:ZMARG1]TVENTA(T)/[M:ZMARG1]TCANT(T),0.01)
  [M:ZMARG1]TMARGENM(T)=[M:ZMARG1]TMARGEN(T)/[M:ZMARG1]TCANT(T)
  Endif
  If [M:ZMARG1]TVENTA(T)<>0
  [M:ZMARG1]TMARGENP(T)=arr([M:ZMARG1]TMARGEN(T)*100/[M:ZMARG1]TVENTA(T),0.01)
  Endif
  #
  [M:ZMARG2]TCANT(T)   =[M:ZMARG1]TCANT(T)
  [M:ZMARG2]TCOSTE(T)  =[M:ZMARG1]TCOSTE(T)
  [M:ZMARG2]TVENTA(T)  =[M:ZMARG1]TVENTA(T)
  [M:ZMARG2]TCOSTEM(T) =[M:ZMARG1]TCOSTEM(T)
  [M:ZMARG2]TVENTAM(T) =[M:ZMARG1]TVENTAM(T)
  [M:ZMARG2]TMARGEN(T) =[M:ZMARG1]TMARGEN(T)
  [M:ZMARG2]TMARGENM(T)=[M:ZMARG1]TMARGENM(T)
  [M:ZMARG2]TMARGENP(T)=[M:ZMARG1]TMARGENP(T)
  #
  [M:ZMARG3]TCANT(T)   =[M:ZMARG1]TCANT(T)
  [M:ZMARG3]TCOSTE(T)  =[M:ZMARG1]TCOSTE(T)
  [M:ZMARG3]TVENTA(T)  =[M:ZMARG1]TVENTA(T)
  [M:ZMARG3]TCOSTEM(T) =[M:ZMARG1]TCOSTEM(T)
  [M:ZMARG3]TVENTAM(T) =[M:ZMARG1]TVENTAM(T)
  [M:ZMARG3]TMARGEN(T) =[M:ZMARG1]TMARGEN(T)
  [M:ZMARG3]TMARGENM(T)=[M:ZMARG1]TMARGENM(T)
  [M:ZMARG3]TMARGENP(T)=[M:ZMARG1]TMARGENP(T)
Next
Sorta [M:ZMARG2]NBLIG [M:ZMARG2]NBLIG Order By [M:ZMARG2]BPCINV(indice)
Sorta [M:ZMARG3]NBLIG [M:ZMARG3]NBLIG Order By [M:ZMARG3]ITMREF(indice)
Affzo [M:ZMARG2]5-10
Affzo [M:ZMARG3]5-10
End

Subprog RESUMEN_ACU_CTE(L)
Value    Integer L
Local Integer F,T
T=-1
For F=0 To [M:ZMARG2]NBLIG-1
  If [M:ZMARG2]BPCINV(F)=[M:ZMARG1]BPCINV(L)
    T=F
    Gosub RESUMEN_ACU_CTE_DAT
    Break
  Endif
Next
If T=-1
  T=[M:ZMARG2]NBLIG
  If T+1>=[M:ZMARG0]FLDNUM(11)
    MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(11)+1) + " filas para mostrar RESUMEN CLIENTE\.\Pida que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
#    ZOK=0
  Else
    [M:ZMARG2]BPCINV(T)=[M:ZMARG1]BPCINV(L)
    Gosub RESUMEN_ACU_CTE_DAT
    [M:ZMARG2]NBLIG+=1
  Endif
Endif
End

$RESUMEN_ACU_CTE_DAT
[M:ZMARG2]CANTK(T) +=[M:ZMARG1]CANTK(L)
[M:ZMARG2]COSTEK(T)+=[M:ZMARG1]COSTEK(L)
[M:ZMARG2]VENTAK(T)+=[M:ZMARG1]VENTAK(L)
[M:ZMARG2]CANTM(T) +=[M:ZMARG1]CANTM(L)
[M:ZMARG2]COSTEM(T)+=[M:ZMARG1]COSTEM(L)
[M:ZMARG2]VENTAM(T)+=[M:ZMARG1]VENTAM(L)
# Columnas calculadas
[M:ZMARG2]MARGENK(T) =[M:ZMARG2]VENTAK(T)-[M:ZMARG2]COSTEK(T)
If [M:ZMARG2]CANTK(T)<>0
[M:ZMARG2]COSTEKM(T) =arr([M:ZMARG2]COSTEK(T)/[M:ZMARG2]CANTK(T),0.00001)
[M:ZMARG2]VENTAKM(T) =arr([M:ZMARG2]VENTAK(T)/[M:ZMARG2]CANTK(T),0.01)
[M:ZMARG2]MARGENKM(T)=[M:ZMARG2]MARGENK(T)   /[M:ZMARG2]CANTK(T)
Endif
If [M:ZMARG2]VENTAK(T)<>0
[M:ZMARG2]MARGENPK(T)=arr([M:ZMARG2]MARGENK(T)*100/[M:ZMARG2]VENTAK(T),0.01)
Endif
[M:ZMARG2]MARGENM(T) =[M:ZMARG2]VENTAM(T)-[M:ZMARG2]COSTEM(T)
If [M:ZMARG2]CANTM(T)<>0
[M:ZMARG2]COSTEMM(T) =arr([M:ZMARG2]COSTEM(T)/[M:ZMARG2]CANTM(T),0.00001)
[M:ZMARG2]VENTAMM(T) =arr([M:ZMARG2]VENTAM(T)/[M:ZMARG2]CANTM(T),0.001)
[M:ZMARG2]MARGENMM(T)=[M:ZMARG2]MARGENM(T)   /[M:ZMARG2]CANTM(T)
Endif
If [M:ZMARG2]VENTAM(T)<>0
[M:ZMARG2]MARGENPM(T)=arr([M:ZMARG2]MARGENM(T)*100/[M:ZMARG2]VENTAM(T),0.01)
Endif
Return

Subprog RESUMEN_ACU_ART(L)
Value    Integer L
Local Integer F,T
T=-1
For F=0 To [M:ZMARG3]NBLIG-1
  If [M:ZMARG3]ITMREF(F)=[M:ZMARG1]ITMREF(L)
    T=F
    Gosub RESUMEN_ACU_ART_DAT
    Break
  Endif
Next
If T=-1
  T=[M:ZMARG3]NBLIG
  If T+1>=[M:ZMARG0]FLDNUM(12)
    MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(11)+1) + " filas para mostrar RESUMEN CLIENTE\.\Pida que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
#    ZOK=0
  Else
    [M:ZMARG3]ITMREF(T)=[M:ZMARG1]ITMREF(L)
    Gosub RESUMEN_ACU_ART_DAT
    [M:ZMARG3]NBLIG+=1
  Endif
Endif
End

$RESUMEN_ACU_ART_DAT
[M:ZMARG3]CANTK(T) +=[M:ZMARG1]CANTK(L)
[M:ZMARG3]COSTEK(T)+=[M:ZMARG1]COSTEK(L)
[M:ZMARG3]VENTAK(T)+=[M:ZMARG1]VENTAK(L)
[M:ZMARG3]CANTM(T) +=[M:ZMARG1]CANTM(L)
[M:ZMARG3]COSTEM(T)+=[M:ZMARG1]COSTEM(L)
[M:ZMARG3]VENTAM(T)+=[M:ZMARG1]VENTAM(L)
# Columnas calculadas
[M:ZMARG3]MARGENK(T) =[M:ZMARG3]VENTAK(T)-[M:ZMARG3]COSTEK(T)
If [M:ZMARG3]CANTK(T)<>0
[M:ZMARG3]COSTEKM(T) =arr([M:ZMARG3]COSTEK(T)/[M:ZMARG3]CANTK(T),0.00001)
[M:ZMARG3]VENTAKM(T) =arr([M:ZMARG3]VENTAK(T)/[M:ZMARG3]CANTK(T),0.01)
[M:ZMARG3]MARGENKM(T)=[M:ZMARG3]MARGENK(T)   /[M:ZMARG3]CANTK(T)
Endif
If [M:ZMARG3]VENTAK(T)<>0
[M:ZMARG3]MARGENPK(T)=arr([M:ZMARG3]MARGENK(T)*100/[M:ZMARG3]VENTAK(T),0.01)
Endif
[M:ZMARG3]MARGENM(T) =[M:ZMARG3]VENTAM(T)-[M:ZMARG3]COSTEM(T)
If [M:ZMARG3]CANTM(T)<>0
[M:ZMARG3]COSTEMM(T) =arr([M:ZMARG3]COSTEM(T)/[M:ZMARG3]CANTM(T),0.00001)
[M:ZMARG3]VENTAMM(T) =arr([M:ZMARG3]VENTAM(T)/[M:ZMARG3]CANTM(T),0.001)
[M:ZMARG3]MARGENMM(T)=[M:ZMARG3]MARGENM(T)   /[M:ZMARG3]CANTM(T)
Endif
If [M:ZMARG3]VENTAM(T)<>0
[M:ZMARG3]MARGENPM(T)=arr([M:ZMARG3]MARGENM(T)*100/[M:ZMARG3]VENTAM(T),0.01)
Endif
Return

Subprog RECALCULAR
Local Integer F,ZOK
[M:ZMARG0]FLDNUM(7)=1
For F=0 To [M:ZMARG]NBLIG-1
  If [M:ZMARG]SDHNUM(F)="" and abs([M:ZMARG]PFMP(F))>=100 and [M:ZMARG]CPRPRI(F)<>0 and not ([M:ZMARG]SAU(F)<>[M:ZMARG]STU(F) and [M:ZMARG]SAUSTUCOE(F)=1)
    [M:ZMARG]CPRPRIN(F)=0.0001
    [M:ZMARG]PFMN(F)   =[M:ZMARG]NETPRINOT(F)
    [M:ZMARG]PFMPN(F)  =arr([M:ZMARG]PFMN(F)*100/[M:ZMARG]NETPRINOT(F),0.01)
    [M:ZMARG]ZSEL(F)   =2
  Elsif [M:ZMARG]SDHNUM(F)<>""  # De no haber nş entrega, entonces la Fra se hizo manualmente SIN CONTROL DE STOCK, pues este se determina en las entregas/albaranes
    nolign=F+1
    Call MOSTRAR_LOTES_FACTURADOS([M:ZMARG]SDHNUM(F),[M:ZMARG]SDDLIN(F),"","","","",ZOK) From SPEZMARG
    If ZOK=0
      Call ERREURT("Imposible recalcular\Hay OFs Pdte.cerrar coste ó Recepciones Pdte.Fra\En lotes incluidos en entrega\"+[M:ZMARG]SDHNUM(F)+" LŞ "+num$([M:ZMARG]SDDLIN(F))+
& "\Haga click en fila "+num$(F+1)+" para detalles", 1) From GESECRAN   #0-Informativo, 1-Error
      Break
    Endif
  Endif
Next
If ZOK=0
  [M:ZMARG0]FLDNUM(7)=0
  For F=0 To [M:ZMARG]NBLIG-1
    [M:ZMARG]ZSEL(F)   =1
  Next
Endif
Affzo [M:ZMARG]10
[M:ZMARG0]FLDNUM(6)=1 # Para ejecutar coloreado en SETBOUT
End


Subprog AJUSTAR
Local Integer F,T
Local Char MSG(255)
Local Integer YN
Local Decimal COE,COSTE
If [M:ZMARG0]FLDNUM(3)<1 End Endif
If [M:ZMARG0]FLDCHR(1) = ""
  MSG="Está seguro de PROCESAR las "+num$([M:ZMARG0]FLDNUM(3))+" FILAS mostradas en AMARILLO"
  YN=1 # Por defecto es NO
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1  End  Endif
Endif
#
If clalev([F:WSID]) <=0   :  Local File SINVOICED  [F:WSID]  : Endif
For F=0 To [M:ZMARG]NBLIG-1
  If [M:ZMARG]CPRPRIN(F)=0.0001 and [M:ZMARG]SDHNUM(F)=""
    COSTE=0
  Else
    COSTE=[M:ZMARG]CPRPRIN(F)
  Endif
  If [M:ZMARG]ZSEL(F)=2 #[M:ZMARG]CPRPRI(F)<>COSTE and COSTE<>0 and [M:ZMARG]PFMPN(F)>=FLDNUM(4)and [M:ZMARG]PFMPN(F)<=FLDNUM(5)
    Readlock [F:WSID]SID0=[M:ZMARG]NUM(F);[M:ZMARG]SIDLIN(F)
    If fstat=0
      # Guardo datos originales...SOLO LA 1Ş VEZ !!!!
      If [F:WSID]ZCPRPRIORI =0
        [F:WSID]ZCPRPRIORI  =[F:WSID]CPRPRI
        [F:WSID]ZNETPRINOTOR=[F:WSID]NETPRINOT
        [F:WSID]ZPFMORI     =[F:WSID]PFM
        [F:WSID]ZQTYSTUORI  =[F:WSID]QTYSTU
        [F:WSID]ZSAUSTUCOEOR=[F:WSID]SAUSTUCOE
      Endif
      # Ajustes por cambio de coeficiente
      If [M:ZMARG]COEN(F)<>0
        COE=[M:ZMARG]COEN(F)
        [F:WSID]SAUSTUCOE=COE
        [F:WSID]QTYSTU   =arr([F:WSID]QTYSTU*COE,0.0001)
        If [F:WSID]STU="KG" Then [F:WSID]ZQTYKG=[F:WSID]QTYSTU Else [F:WSID]ZQTYKG=0  Endif
      Else
        COE=[F:WSID]SAUSTUCOE
      Endif
      # Ajustes por Invertir....28-04-17 NO SE USA...está invisible !!!!
      If [M:ZMARG]INVUNID(F)=2
        [F:WSID]QTYSTU   =[M:ZMARG]QTYSTU(F)
        [F:WSID]NETPRINOT=[M:ZMARG]NETPRINOT(F)
      Endif
      # Ajustes por cambio de coste
      [F:WSID]CPRPRI=COSTE*COE
      [F:WSID]PFM   =[F:WSID]NETPRINOT-[F:WSID]CPRPRI
      Rewrite [F:WSID]
      If fstat<>0
        Infbox "No se pudo ACTUALIZAR lŞ "+num$([M:ZMARG]SIDLIN(F))+" de Fra "+[M:ZMARG]NUM(F)+" (fstat="+num$(fstat)+"). Deberá volver a intentarlo"
      Elsif GUSER="ADMIN"
#        Infbox "COSTE="+num$(COSTE)+"  [F:WSID]CPRPRI="+num$([F:WSID]CPRPRI)+"  [F:WSID]PFM="+num$([F:WSID]PFM)+" [F:WSID]SAUSTUCOE="+num$([F:WSID]SAUSTUCOE)+"  [F:WSID]QTYSTU="+num$([F:WSID]QTYSTU)
      Endif
      Unlock [F:WSID]
    Else
      Infbox "No se pudo cambiar lŞ "+num$([M:ZMARG]SIDLIN(F))+" de Fra "+[M:ZMARG]NUM(F)+" Por estar siendo usada. Deberá volver a intentarlo"
    Endif
  Endif
Next
If GUSER="ADMIN"   Call BORRA_GRID  Else  Call BUSCAR   Endif
End



Funprog COMPROBACIONES
If [M:ZMARG0]FECINI=[0/0/0] or [M:ZMARG0]FECFIN=[0/0/0] End 0 Endif
If not func ZCOMUN.FECHA_INI_FIN([M:ZMARG0]FECINI, [M:ZMARG0]FECFIN) End 0  Endif
If [M:ZMARG0]FMARINF<>0 and [M:ZMARG0]FMARINF >=[M:ZMARG0]FMARSUP End 0  Endif
End 1

Subprog ORDENA_GRID
Case [M:ZMARG0]ORDEN
When 1
  Sorta [M:ZMARG]NBLIG  [M:ZMARG]NBLIG  Order By [M:ZMARG]SALFCY(indice), [M:ZMARG]ITMREF(indice),[M:ZMARG]NUM(indice),[M:ZMARG]SDDLIN(indice)
  Sorta [M:ZMARG1]NBLIG [M:ZMARG1]NBLIG Order By [M:ZMARG1]ITMREF(indice),[M:ZMARG1]BPCINV(indice)
When 2
  Sorta [M:ZMARG]NBLIG  [M:ZMARG]NBLIG  Order By [M:ZMARG]SALFCY(indice), [M:ZMARG]BPCINV(indice),[M:ZMARG]NUM(indice),[M:ZMARG]SDDLIN(indice)
  Sorta [M:ZMARG1]NBLIG [M:ZMARG1]NBLIG Order By [M:ZMARG1]BPCINV(indice),[M:ZMARG1]ITMREF(indice)
When 3
  Sorta [M:ZMARG]NBLIG  [M:ZMARG]NBLIG  Order By [M:ZMARG]SALFCY(indice), [M:ZMARG]NUM(indice),[M:ZMARG]SDDLIN(indice)
  Sorta [M:ZMARG1]NBLIG [M:ZMARG1]NBLIG Order By [M:ZMARG1]ITMREF(indice),[M:ZMARG1]BPCINV(indice)
Endcase
Affzo [M:ZMARG]10
Affzo [M:ZMARG1]5-10
[M:ZMARG0]FLDNUM(6)=1 # Para ejecutar coloreado en SETBOUT
End

Subprog REJ1_COL(L)
Value  Integer L #
Local Integer F,T,INI,FIN
Local Char STYL(30),MSG(255)
Raz T,MSG
If L>=0
  INI=L: FIN=L
Else
  INI=0: FIN=[M:ZMARG]NBLIG-1
Endif
For F=INI To FIN
  # Saber filas que se ajustaran
  If [M:ZMARG]ZSEL(F)=2 or ([M:ZMARG0]FLDNUM(7)=1 and [M:ZMARG]CPRPRI(F)<>[M:ZMARG]CPRPRIN(F) and [M:ZMARG]CPRPRIN(F)<>0 and [M:ZMARG]PFMPN(F)>=FLDNUM(4)and [M:ZMARG]PFMPN(F)<=FLDNUM(5))
    STYL="BACKYELLOW"
    If [M:ZMARG0]FLDNUM(7)=1     [M:ZMARG]ZSEL(F)=2   Endif
    Affzo [M:ZMARG]ZSEL(F)
    T+=1
  Else
    STYL=""
    If [M:ZMARG0]FLDNUM(7)=1 and [M:ZMARG]CPRPRI(F)<>[M:ZMARG]CPRPRIN(F) and [M:ZMARG]CPRPRIN(F)<>0
      MSG+=num$(F+1)+"#"
    Endif
  Endif
  Chgstl [M:ZMARG]NBLIG(F)    With STYL
  # Saber filas con unidad venta <> stock
  If [M:ZMARG]SAU(F)<>[M:ZMARG]STU(F)
    If [M:ZMARG]SAUSTUCOE(F)=1 Then STYL="BACKRED" Else STYL="BACKGREEN" Endif
    Chgstl [M:ZMARG]CPRPRI(F)    With STYL
    Chgstl [M:ZMARG]NETPRINOT(F) With STYL
    Chgstl [M:ZMARG]PFM(F)       With STYL
    Chgstl [M:ZMARG]PFMP(F)      With STYL
    Chgstl [M:ZMARG]SAU(F)       With STYL
    Chgstl [M:ZMARG]STU(F)       With STYL
    Chgstl [M:ZMARG]SAUSTUCOE(F) With STYL
  Endif
  #Marcar lineas ya AJUSTADAS
  If [M:ZMARG]COSTEORI(F)<>0
    Chgstl [M:ZMARG]NUM(F)      With "LIGBUDA"
    Chgstl [M:ZMARG]INVDAT(F)   With "LIGBUDA"
    Chgstl [M:ZMARG]COSTEORI(F) With "LIGBUDA"
  Endif
  #Colorear columnas con nuevos datos
  Chgstl [M:ZMARG]CPRPRIN(F) With "BACKORANGE"
  Chgstl [M:ZMARG]PFMN(F)    With "BACKORANGE"
  Chgstl [M:ZMARG]PFMPN(F)   With "BACKORANGE"
  # %Dto total Fra.no aplicado
  If [M:ZMARG0]ZDTO<>2 and [M:ZMARG]DTO(F)<>0
    Chgstl [M:ZMARG]DTO(F)   With "BACKRED"
  Endif
Next
#
If [M:ZMARG0]FLDNUM(7)=1 and T=0
  Call ERREURT("Tras el recalculo, todo está correcto\Lo que significa que los margenes estan correctos", 0) From GESECRAN   #0-Informativo, 1-Error
Elsif [M:ZMARG0]FLDNUM(7)=1 and MSG<>""
  Call ERREURT("Revise estas lineas, pues NO se marcaron\Su margen fuera del intervalo indicado\"+MSG, 0) From GESECRAN   #0-Informativo, 1-Error
Endif
[M:ZMARG0]FLDNUM(3)=T
[M:ZMARG0]FLDNUM(7)=0  # Se pone a 1 en Subprog RECALCULAR
End

Subprog BORRA_GRID
Raz [M:ZMARG]NBLIG,[M:ZMARG]NLOTE,[M:ZMARG]NLOTU
Effzo [M:ZMARG]10-20

Affzo [M:ZMARG]10-20
[M:ZMARG0]FLDNUM(8)=-1
[M:ZMARG0]FLDNUM(9)=-1

Raz [M:ZMARG1]NBLIG,[M:ZMARG1]NBTOT
Effzo [M:ZMARG1]5-10

Raz [M:ZMARG2]NBLIG,[M:ZMARG3]NBTOT
Effzo [M:ZMARG2]5-10

Raz [M:ZMARG3]NBLIG,[M:ZMARG3]NBTOT
Effzo [M:ZMARG3]5-10
End

