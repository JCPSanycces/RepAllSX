#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para la asginacion de pedidos de proveedor a contenedor
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
If !clalev([F:POH])    : Local File PORDER     [POH] : Endif
If !clalev([F:POP])    : Local File PORDERP    [POP] : Endif
If !clalev([F:POQ])    : Local File PORDERQ    [POQ] : Endif
If !clalev([F:ITP])    : Local File ITMBPS     [ITP] : Endif
If !clalev([F:ZCNTRX]) : Local File ZCONTAINH  [ZCNTRX] : Endif
If !clalev([F:ZCNTRP]) : Local File ZCONTAINP  [ZCNTRP] : Endif
If !clalev([F:ZCNTRS]) : Local File ZCONTAINS  [ZCNTRS] : Endif
Return

$DEBUT
Local Char LNUMCNTR(25)

LNUMCNTR=PARAM(1)
Raz [M:ZCNTRAP]
Raz [M:ZCNTRAP]POHNUMSTR
[M:ZCNTRAP]POHNUMSTR=PARAM(2)
Affzo [M:ZCNTRAP]POHNUMSTR

Raz [F:ZCNTRX]
Read [ZCNTRX]ZCNTR0=LNUMCNTR
If fstat
   Infbox "No existe contenedor: "+LNUMCNTR
Endif
#Gosub CARGAR
Return

$SETBOUT
If [M:ZCNTRAP]NBLIG=0
    Call VIREBOUT(CHMEN,"2") From GOBJET
Endif
Return

$BOUTON
Local Integer LRET
Case BOUT
    When "1" :  Gosub CARGAR
    When "2" :  Gosub ASIGNAR :  Gosub CARGAR
Endcase
Return

$APRES_MODIF
If COUZON="POHNUMSTR"
   [M:ZCNTRAP]POHNUMSTR=CZ
   Gosub CARGAR
Endif
Return

$CARGAR
Local Decimal LBOBASI, LBOBAASI
Local Decimal LVOLUMEN

Filter [POH] Where POHNUM=[M:ZCNTRAP]POHNUMSTR
nolign=0
For [POH]
   Filter [POQ] Where POHNUM=[F:POH]POHNUM
   For [POQ]
      Filter [ZCNTRP] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
      LBOBASI=0
      For [ZCNTRP]
          LBOBASI+=[F:ZCNTRP]BOBASI
      Next
      Filter [ZCNTRP]

      LBOBAASI=[F:POQ]ZQTYBOB-LBOBASI

      If LBOBAASI<>0
         Raz [F:POP]
         Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POP]POPSEQ
         Raz [F:ITP]
         Read [ITP]ITP0=[F:POQ]ITMREF;[F:POH]BPSNUM
         [M:ZCNTRAP]POHNUM(nolign)  =[F:POQ]POHNUM
         [M:ZCNTRAP]POPLIN(nolign)  =[F:POQ]POPLIN
         [M:ZCNTRAP]POQSEQ(nolign)  =[F:POQ]POQSEQ
         [M:ZCNTRAP]ITMREF(nolign)  =[F:POQ]ITMREF
         [M:ZCNTRAP]ANCHO(nolign)   =[F:POQ]ZANCHO
         [M:ZCNTRAP]MANDRIL(nolign) =[F:POQ]ZMANDRIL
         [M:ZCNTRAP]LONGITUD(nolign) =[F:POQ]ZLONGITUD
         [M:ZCNTRAP]ITMDES1(nolign) =[F:POP]ITMDES1
         [M:ZCNTRAP]BOBPED(nolign)  =[F:POQ]ZQTYBOB
         [M:ZCNTRAP]BOBASI(nolign)  =LBOBASI
         [M:ZCNTRAP]BOBPTE(nolign)  =LBOBAASI
         LVOLUMEN=([F:POQ]ZANCHO/100)*[F:POQ]ZLONGITUD*[F:ITP]ZESPESORP
         [M:ZCNTRAP]QTYPED(nolign)=[M:ZCNTRAP]QTYPED(nolign)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)
         [M:ZCNTRAP]QTYASI(nolign)=[M:ZCNTRAP]QTYASI(nolign)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)
         [M:ZCNTRAP]QTYPTE(nolign)=[M:ZCNTRAP]QTYPTE(nolign)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)
         nolign+=1
      Endif
   Next
   Filter [POQ]
   [M:ZCNTRAP]NBLIG=nolign
Next
[M:ZCNTRAP]BPSNUM=[F:POH]BPSNUM
Filter [POH]
Affzo [M:ZCNTRAP]10
Return

$ASIGNAR
Local Integer LOK,I,MAXLIN

MAXLIN=0
Filter [ZCNTRP] Where NUMCNTR=LNUMCNTR
For [F:ZCNTRP]
   If [F:ZCNTRP]NUMLIN>MAXLIN
      MAXLIN=[F:ZCNTRP]NUMLIN
   Endif
Next
Filter [ZCNTRP]

LOK=1
Trbegin [ZCNTRP]
For I=0 To [M:ZCNTRAP]NBLIG-1
   MAXLIN=MAXLIN+1000
   [F:ZCNTRP]NUMCNTR=LNUMCNTR
   [F:ZCNTRP]POHNUM =[M:ZCNTRAP]POHNUM(I)
   [F:ZCNTRP]POPLIN =[M:ZCNTRAP]POPLIN(I)
   [F:ZCNTRP]POQSEQ =[M:ZCNTRAP]POQSEQ(I)
   [F:ZCNTRP]NUMLIN =MAXLIN
   [F:ZCNTRP]BOBASI =[M:ZCNTRAP]BOBPTE(I)
   Write [ZCNTRP]
   If fstat
      LOK=0
      Infbox "Error grabando linea [ZCNTRP] - fstat: "+num$(fstat)
      Break
   Endif
   If I=0
      #En la primera iteracion si el contenedor no tiene ya pedido asigando se le asigna el primero
      If len([F:ZCNTRX]NUMCNTR)<>0 and len([F:ZCNTRX]PEDNUM)=0
         Update [ZCNTRX] Where NUMCNTR=LNUMCNTR With PEDNUM=[M:ZCNTRAP]POHNUM(I)
      Endif
   Endif
Next
If LOK
   Commit
Else
   Rollback
Endif
Return
