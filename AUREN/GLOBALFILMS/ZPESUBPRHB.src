#<AdxTL>@(#)0.0.0.0 $Revision$
# Z0001-1 - JC.21072022.Trazabilidad
#####################################################################

#CHG_ALLTYP -> PE de SUBPRHB (preparacion entregas), aunque su objetivo es otro se utiliza para
#              inicializar unas variables
$ACTION
Case ACTION
   When "CHG_ALLTYP"     :   Gosub CHG_ALLTYP
   When "ZBEFCRELINPTH"  :   Gosub ZBEFCRELINPTH
Endcase
Return

$CHG_ALLTYP
#Global Decimal ZGNBRBOB
#Infbox "CHG_ALLTYP: "+num$([F:PRE]ZQTYBOB)
ZGNBRBOB=0
Return

########################################################
$ZBEFCRELINPTH
# Z0001-1.ini
  If [M:SOH4]ALLQTY(I) = 0 or [M:SOH4]SHTQTY(I) <> 0 Then
    ZNOALLQTY = 1
  Endif
# Z0001-1.fin
Return
