#<AdxTL>@(#)0.0.0.0 $Revision$ Consulta corte
#Consulta general pedidos

$ACTION
Case ACTION
   When "OUVRE"   : Gosub OUVRE
   When "LECTURE" : Gosub LECTURE
   When Default
Endcase
Return

$OUVRE
 If !clalev([F:SOH])   : Local File SORDER     [SOH] : Endif
 If !clalev([F:SOQ])   : Local File SORDERQ    [SOQ] : Endif
 If !clalev([F:SOP])   : Local File SORDERP    [SOP] : Endif
 If !clalev([F:SDH])   : Local File SDELIVERY  [SDH] : Endif
 If !clalev([F:MFG])   : Local File MFGHEAD    [MFG] : Endif
 If !clalev([F:MFI])   : Local File MFGITM     [MFI] : Endif
 If !clalev([F:MFO])   : Local File MFGOPE     [MFO] : Endif
 If !clalev([F:SCH])   : Local File SCHEDULING [SCH] : Endif
 If !clalev([F:ZOFS])  : Local File ZMFGSOQ    [ZOFS] : Endif : #Pedidos asignados a OF's
 If !clalev([F:STO])   : Local File STOCK      [STO] : Endif
 If !clalev([F:STA])   : Local File STOALL     [STA] : Endif
 If !clalev([F:ZCNTRH]) : Local File ZCONTAINH [ZCNTRH] : Endif
 If !clalev([F:ZCNTRP]) : Local File ZCONTAINP [ZCNTRP] : Endif
 If !clalev([F:ZCNTRS]) : Local File ZCONTAINS [ZCNTRS] : Endif
 If !clalev([F:ZCNTRM]) : Local File ZCONTAINM [ZCNTRM] : Endif
 If !clalev([F:POQ])   : Local File PORDERQ    [POQ] : Endif
 If !clalev([F:ITM])   : Local File ITMMASTER  [ITM] : Endif
 If !clalev([F:BPC])   : Local File BPCUSTOMER [BPC] : Endif
 If !clalev([F:ZTDC])  : Local File ZTEXDOC    [ZTDC] : Endif
 If !clalev([F:ZCGP])  : Local File ZCONGENPED [ZCGP] : Endif : #Tabla auxiliar para la consulta

 Local Integer WCONT : WCONT = 0
 Local Char WCRITERE(250), WCRITSIT(250)(0..2)
 Local Char WCRITADI(250)
 Local Integer WSITLPED(1..10)

[M:ZCO1]STOFCY=GFCYDEF(0)
[M:ZCO1]CORTE=2

[M:ZCO1]PTEASIG=1
[M:ZCO1]PTEASIGSPC=1
[M:ZCO1]ASICSTO=1
[M:ZCO1]PTEPROG=1
[M:ZCO1]PROGRAM=1
[M:ZCO1]PLANIFI=1
[M:ZCO1]COROK=1
[M:ZCO1]CORNOK=1
[M:ZCO1]NOENTREGA=1
[M:ZCO1]ENTREGA=1
[M:ZCO1]FFINMFENT=1

Return

$LECTURE
Local Integer NBRBOBSTO, NBRBOBASIPED, NBRBOBASITOT, NBRBOBDIS, NBRBOBTRA, NBRBOBTRAASIG, NBRBOBTRADIS
Local Integer PEDASI, PEDENOF, OK
Local Integer NBROF, LMFGTRKFLGULT, LSCDFLGULT, NBRBOBOF, NBRBOBOFNSAL, NBRBOBNEC
Local Date LFECULT
Local Char LMFGNUM(25), LHOUC1(5), WENDHHMI(4)

WCRITERE = "1=1"

If [M:ZCO1]STOFCY <> ""
   WCRITERE += "& [SOQ]STOFCY = [M:ZCO1]STOFCY "
Endif
If [M:ZCO1]ITMREFDEB <> ""
   WCRITERE += "& [SOQ]ITMREF >= [M:ZCO1]ITMREFDEB "
Endif
If [M:ZCO1]ITMREFFIN <> ""
   WCRITERE += "& [SOQ]ITMREF <= [M:ZCO1]ITMREFFIN "
Endif
If [M:ZCO1]BPCORD <> ""
   WCRITERE += "& [SOQ]BPCORD = [M:ZCO1]BPCORD "
Endif
If [M:ZCO1]ANCHO <> 0
   WCRITERE += "& [SOQ]ZANCHO = "+num$([M:ZCO1]ANCHO)
Endif
If [M:ZCO1]MANDRIL <> 0
   WCRITERE += "& [SOQ]ZMANDRIL = "+num$([M:ZCO1]MANDRIL)
Endif
If [M:ZCO1]LONGITUD <> 0
   WCRITERE += "& [SOQ]ZLONGITUD = "+num$([M:ZCO1]LONGITUD)
Endif
If [M:ZCO1]ORDDATDEB <> [00/00/0000]
   WCRITERE += "& [SOH]ORDDAT >= [M:ZCO1]ORDDATDEB"
Endif
If [M:ZCO1]ORDDATDEB <> [00/00/0000]
   WCRITERE += "& [SOH]ORDDAT <= [M:ZCO1]ORDDATFIN"
Endif
If [M:ZCO1]SHIDATDEB <> [00/00/0000]
   WCRITERE += "& [SOQ]SHIDAT >= [M:ZCO1]SHIDATDEB"
Endif
If [M:ZCO1]SHIDATDEB <> [00/00/0000]
   WCRITERE += "& [SOQ]SHIDAT <= [M:ZCO1]SHIDATFIN"
Endif
If [M:ZCO1]SOHNUMDEB <> ""
   WCRITERE += "& [SOQ]SOHNUM = [M:ZCO1]SOHNUMDEB "
Endif
If [M:ZCO1]ZCUSORDREF <> ""
   WCRITERE += "& [SOQ]ZCUSORDREF = [M:ZCO1]ZCUSORDREF "
Endif

If WCRITERE = "1=1"
   Return
Endif

#[M:ZCO1]CORTE: 1 - No / 2 - Sí
#               No - Todas las lineas de pedidos según el crtierio
#               Sí - Solo líneas pendientes de programar total o parcialmente en OF
Link [SOQ] With [SOH]SOH0=[SOQ]SOHNUM As [LNK]
If [M:ZCO1]CORTE=2
   Filter [LNK] Where evalue(WCRITERE) and [SOQ]ZCORTE=2 and [SOQ]SOQSTA <> 3
Else
   Filter [LNK] Where evalue(WCRITERE)
Endif

#Cumplimentamos la tabla de trabajo auxiliar ZCONSGENPED [ZCGP]
Delete [ZCGP] Where CREUSR=GUSER and CREDAT<=date$
If fstat
   Infbox "Problema borrando tabla auxiliar [ZCGP]"
   Return
Endif

Trbegin [ZCGP]
OK=1
For [LNK]
   Raz [F:SOP]
   Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
   NBRBOBNEC=0
   Raz [F:ZCGP]
   [F:ZCGP]CREUSR=GUSER
   [F:ZCGP]CREDAT=date$
   [F:ZCGP]SALFCY=[F:SOH]SALFCY
   [F:ZCGP]ORDDAT=[F:SOH]ORDDAT
   [F:ZCGP]SOHNUM=[F:SOH]SOHNUM
   [F:ZCGP]SOPLIN=[F:SOQ]SOPLIN
   [F:ZCGP]SOQSEQ=[F:SOQ]SOQSEQ
   [F:ZCGP]ITMREF=[F:SOQ]ITMREF
   [F:ZCGP]ANCHO =[F:SOQ]ZANCHO
   [F:ZCGP]LONGITUD =[F:SOQ]ZLONGITUD
   [F:ZCGP]MANDRIL =[F:SOQ]ZMANDRIL

   [F:ZCGP]PTEASIG=1
   [F:ZCGP]PTEASIGSPC=1
   [F:ZCGP]ASICSTO=1
   [F:ZCGP]PTEPROG=1
   [F:ZCGP]PROGRAM=1
   [F:ZCGP]PLANIFI=1
   [F:ZCGP]COROK=1
   [F:ZCGP]CORNOK=1
   [F:ZCGP]NOENTREGA=1
   [F:ZCGP]ENTREGA=1
   [F:ZCGP]FFINMFENT=1

   NBRBOBASIPED=0
   Filter [STA] Where VCRTYP=2 and VCRNUM=[F:SOQ]SOHNUM and VCRLIN=[F:SOQ]SOPLIN and ALLTYP=2
   For [STA]
      NBRBOBASIPED+=1
   Next
   Filter [STA]
   NBRBOBNEC=[F:SOQ]ZQTYBOB-NBRBOBASIPED

   Filter [ZOFS] Where SOHNUM=[F:SOQ]SOHNUM and SOPLIN=[F:SOQ]SOPLIN
   NBROF=0
   Raz LMFGNUM
   LFECULT=[0/0/0]
   Raz LMFGTRKFLGULT
   Raz LSCDFLGULT
   NBRBOBOFNSAL=0
   For [ZOFS]
      Raz [F:MFG]
      Read [MFG]MFG0=[F:ZOFS]MFGNUM
      NBROF+=1
      Case NBROF
         When 1
            [F:ZCGP]MFGNUM=[F:ZOFS]MFGNUM
            [F:ZCGP]MFGLIN=[F:ZOFS]MFGLIN
         When 2
            [F:ZCGP]MFGNUM2=[F:ZOFS]MFGNUM
            [F:ZCGP]MFGLIN2=[F:ZOFS]MFGLIN
      Endcase
      If [F:MFG]ENDDAT>LFECULT
          #JLP - Se ańade al haber dos OF y se cruzan los datos - 30/08/17
          [F:ZCGP]MFGNUM=[F:ZOFS]MFGNUM
          [F:ZCGP]MFGLIN=[F:ZOFS]MFGLIN
         #Nos quedamos con la fecha mas alta y el numero de OF
         LFECULT=[F:MFG]ENDDAT
         LMFGNUM=[F:MFG]MFGNUM
         LMFGTRKFLGULT=[F:MFG]MFGTRKFLG
         LSCDFLGULT=[F:MFG]SCDFLG
      Endif
      NBRBOBOF+=[F:ZOFS]ZQTYBOBASI
      If [F:MFG]MFGTRKFLG<5
         #OF No saldada
         NBRBOBOFNSAL+=[F:ZOFS]ZQTYBOBASI
      Endif
      Filter [ZCNTRM] Where MFGNUM=[F:ZOFS]MFGNUM and MFGLIN=[F:ZOFS]MFGLIN
      For [ZCNTRM]
          [F:ZCGP]POHNUM=[F:ZCNTRM]POHNUM
          [F:ZCGP]POPLIN=[F:ZCNTRM]POPLIN
      Next
      Filter [ZCNTRM]
   Next
   Filter [ZOFS]
   NBRBOBNEC-=NBRBOBOFNSAL
   If LMFGNUM<>""
      [F:ZCGP]ENDDATULT=LFECULT
      [F:ZCGP]MFGTRKFLGULT=LMFGTRKFLGULT
      [F:ZCGP]SCDFLGULT=LSCDFLGULT
      Raz [F:MFG]
      Read [MFG]MFG0=LMFGNUM
      Raz [F:MFO]
      Filter [MFO] Where MFGNUM=LMFGNUM
      Read [MFO] First
      Filter [MFO]
      Raz [F:SCH]
      Read [SCH]SCH0=[F:MFG]MFGNUM;[F:MFO]OPENUM;0

      Call CONVHOU1([F:MFO]FRCSTRHOU,LHOUC1) From ZTRTCNSPLN
     [F:ZCGP]STRHORULT=LHOUC1

      #Llamada copiada de FUNGROU (Visualizacion grafica del escalonamiento de una OF)
      Call OPETIME([F:MFG]MFGFCY, [F:MFO]EXTWST, [F:MFG]ENDDAT, [F:SCH]OPEENDFRD, WENDHHMI) From JALLIBB
      Call CONVHOU1(WENDHHMI,LHOUC1) From ZTRTCNSPLN
      [F:ZCGP]ENDHORULT=LHOUC1
      [F:ZCGP]WST=[F:MFO]EXTWST
   Endif

If [F:SOQ]SOHNUM="SON10016167443" and GUSER="ADMIN"
#Dbgaff
Endif

   Raz [F:SDH]
   If [F:SOQ]SOQSTA=3
       #Entregado
       [F:ZCGP]SITLPED=10
       [F:ZCGP]NOENTREGA=1
       [F:ZCGP]ENTREGA=2
       Read [SDH]SDH0=[F:SOQ]SDHNUM
       If fstat=0
          [F:ZCGP]SDHNUM=[F:SOQ]SDHNUM
       Endif
   Else
       [F:ZCGP]SITLPED=9
       [F:ZCGP]NOENTREGA=2
       [F:ZCGP]ENTREGA=1
       If [F:SOQ]ZCORTE=2
          #Corte
          If LMFGNUM<>""
             #Esta en OF
             If [F:MFG]MFGTRKFLG>=5 : #5-Saldada / 6-Coste calculado
                #Comprobamos si el corte coincide con el pedido
                Filter [ZOFS] Where SOHNUM=[F:SOQ]SOHNUM and SOPLIN=[F:SOQ]SOPLIN
                For [ZOFS]
                   Raz [F:MFI]
                   Read [MFI]MFI0=[F:ZOFS]MFGNUM;[F:ZOFS]MFGLIN
                   If fstat=0
                      If [F:MFI]ZANCHO<>[F:SOQ]ZANCHO or [F:MFI]ZLONGITUD<>[F:SOQ]ZLONGITUD or [F:MFI]ZMANDRIL<>[F:SOQ]ZMANDRIL
                         [F:ZCGP]CORNOK=2
                         [F:ZCGP]SITLPED=8 : #Cortado NOK
                      Endif
                   Endif
                Next
                Filter [ZOFS]
                If [F:ZCGP]CORNOK=1
                   [F:ZCGP]COROK=2
                   [F:ZCGP]SITLPED=7 : #Cortado OK
                Endif
             Else
                If [F:MFG]SCDFLG>=2
                   #Esta escalonada
                   [F:ZCGP]SITLPED=6 : #Planificada
                   [F:ZCGP]PLANIFI=2
                Else
                   [F:ZCGP]SITLPED=5 : #Programada
                   [F:ZCGP]PROGRAM=2
                Endif
             Endif
             If [F:MFG]ENDDAT>[F:SOQ]DEMDLVDAT
                [F:ZCGP]FFINMFENT=2
             Endif
          Else
             #No esta en OF
             [F:ZCGP]SITLPED=4 : #Sin Programar
             [F:ZCGP]PTEPROG=2
          Endif
       Else
          #No corte
          If NBRBOBASIPED=0
             [F:ZCGP]SITLPED=1 : #Pendiente asignar
             [F:ZCGP]PTEASIG=2
             Filter [ZCNTRS] Where [ZCNTRS]SOHNUM=[F:SOQ]SOHNUM and [ZCNTRS]SOPLIN=[F:SOQ]SOPLIN
             NBRBOBPTEASISPC=[F:SOQ]ZQTYBOB
             For [ZCNTRS]
                NBRBOBPTEASISPC-=[F:ZCNTRS]BOBASI
                #Si esta asignado a un pedido de compra nos quedamos con el numero de pedido y la linea (el ultimo)
                [F:ZCNTRS]POHNUM=[F:ZCNTRS]POHNUM
                [F:ZCNTRS]POPLIN=[F:ZCNTRS]POPLIN
             Next
             Filter [ZCNTRS]
             If NBRBOBPTEASISPC>0
                [F:ZCGP]SITLPED=2 : #Pendiente asignar SPC (SIN PEDIDO DE COMPRA)
                [F:ZCGP]PTEASIGSPC=2
             Endif
          Else
             [F:ZCGP]SITLPED=3 : #Asignado contra stock
             [F:ZCGP]ASICSTO=2
          Endif
       Endif
   Endif
   [F:ZCGP]REP1=[F:SOP]REP1
   [F:ZCGP]QTYBOB=[F:SOQ]ZQTYBOB
   [F:ZCGP]BOBASI=NBRBOBASIPED
   [F:ZCGP]BOBOF =NBRBOBOF
   [F:ZCGP]BOBOFNSAL=NBRBOBOFNSAL
   [F:ZCGP]BOBNEC =NBRBOBNEC

   If [M:ZCO1]CORTE=1
      Write [ZCGP]
      If fstat
         Infbox "Error generando tabla auxiliar [ZCGP-1] - fstat: "+num$(fstat)
         OK=0
         Break
      Endif
   Else
      If NBRBOBNEC>0
         #Si marcado click corte, solo se inserta si hay necesidad
         Write [ZCGP]
         If fstat
            Infbox "Error generando tabla auxiliar [ZCGP-2] - fstat: "+num$(fstat)
            OK=0
            Break
         Endif
      Endif
   Endif
Next

If OK
   Commit
Else
   Rollback
   Return
Endif

WCONT = 0

#WSITLPED -> utilizada en principio para contemplar la situacion de la linea de pedido pero abandonada por campos
#            independientes por cada estado, debido a que hay situaciones no excluyentes entre si.
Raz WSITLPED
WCRITSIT(0)='CREUSR="'+GUSER+'" & CREDAT=['+format$(GFMD,date$)+']'
WCRITSIT(1)=""
WCRITSIT(2)=""
If [M:ZCO1]PTEASIG=2
   WSITLPED(1)= 1
   WCRITSIT(1)+="& [ZCGP]PTEASIG=2"
Endif
If [M:ZCO1]PTEASIGSPC=2
   WSITLPED(2)= 2
   WCRITSIT(1)+="& [ZCGP]PTEASIGSPC=2"
Endif
If [M:ZCO1]ASICSTO=2
   WSITLPED(3)= 3
   WCRITSIT(1)+="& [ZCGP]ASICSTO=2"
Endif
If [M:ZCO1]PTEPROG=2
   WSITLPED(4)= 4
   WCRITSIT(1)+="& [ZCGP]PTEPROG=2"
Endif
If [M:ZCO1]PROGRAM=2
   WSITLPED(5)= 5
   WCRITSIT(1)+="& [ZCGP]PROGRAM=2"
Endif
If [M:ZCO1]PLANIFI=2
   WSITLPED(6)= 6
   WCRITSIT(1)+="& [ZCGP]PLANIFI=2"
Endif
If [M:ZCO1]COROK=2
   WSITLPED(7)= 7
   WCRITSIT(1)+="& [ZCGP]COROK=2"
Endif
If [M:ZCO1]CORNOK=2
   WSITLPED(8)= 8
   WCRITSIT(1)+="& [ZCGP]CORNOK=2"
Endif
If [M:ZCO1]NOENTREGA=2
   WSITLPED(9)= 9
   WCRITSIT(1)+="& [ZCGP]NOENTREGA=2"
Endif
If [M:ZCO1]ENTREGA=2
   WSITLPED(10)= 10
   WCRITSIT(1)+="& [ZCGP]ENTREGA=2"
Endif
If [M:ZCO1]REPDEB1<>""
    WCRITSIT(2)+="& [ZCGP]REP1='"+[ZCO1]REPDEB1+"'"
Endif
If [M:ZCO1]WSTDEB<>""
    WCRITSIT(2)+="& [ZCGP]WST='"+[ZCO1]WSTDEB+"'"
Endif
If [M:ZCO1]MFGNUMDEB<>""
    WCRITSIT(2)+="& ([ZCGP]MFGNUM=[M:ZCO1]MFGNUMDEB or [ZCGP]MFGNUM2=[M:ZCO1]MFGNUMDEB)"
Endif
If [M:ZCO1]ENDDATDEB<>[0/0/0]
    WCRITSIT(2)+="& [ZCGP]ENDDATULT>=[M:ZCO1]ENDDATDEB"
Endif
If [M:ZCO1]ENDDATFIN<>[0/0/0]
    WCRITSIT(2)+="& [ZCGP]ENDDATULT<=[M:ZCO1]ENDDATFIN"
Endif

Raz  [M:ZCO3]
Effzo [M:ZCO3]
[M:ZCO3]NBLIG = 0

If [M:ZCO1]CORTE=2
   Filter [ZCGP] Where evalue(WCRITSIT(0))
Else
   Filter [ZCGP] Where evalue (WCRITSIT)
Endif
For [ZCGP]
   Raz [F:SOH]
   Read [SOH]SOH0=[F:ZCGP]SOHNUM
   Raz [F:SOQ]
   Read [SOQ]SOQ0=[F:ZCGP]SOHNUM;[F:ZCGP]SOPLIN;[F:ZCGP]SOQSEQ
   Raz [F:SOP]
   Read [SOP]SOP0=[F:ZCGP]SOHNUM;[F:ZCGP]SOPLIN;[F:ZCGP]SOQSEQ
   Raz [F:MFG]
   If [F:ZCGP]MFGNUM<>""
      Read [MFG]MFG0=[F:ZCGP]MFGNUM
   Endif

   [M:ZCO3]STRHOR(WCONT)=[F:ZCGP]STRHORULT

   [M:ZCO3]ENDHOR(WCONT)=[F:ZCGP]ENDHORULT

   [M:ZCO3]MFGNUM(WCONT) = [F:ZCGP]MFGNUM
   [M:ZCO3]OFSTRDAT(WCONT) = [F:MFG]STRDAT
   [M:ZCO3]OFENDDAT(WCONT) = [F:ZCGP]ENDDATULT
   [M:ZCO3]MFGTRKFLG(WCONT) = [F:ZCGP]MFGTRKFLGULT
   [M:ZCO3]SCDFLG(WCONT) = [F:ZCGP]SCDFLGULT
   [M:ZCO3]SITLPED(WCONT) = [F:ZCGP]SITLPED
   [M:ZCO3]WST(WCONT) = [F:ZCGP]WST
   [M:ZCO3]REP1(WCONT) = [F:ZCGP]REP1
   [M:ZCO3]POHNUM(WCONT) = [F:ZCGP]POHNUM

   [M:ZCO3]SOHNUM(WCONT) = [F:ZCGP]SOHNUM
   [M:ZCO3]ORDDAT(WCONT) = [F:ZCGP]ORDDAT
   [M:ZCO3]CUSORDREF(WCONT) = [F:SOH]CUSORDREF
   [M:ZCO3]BPCORD(WCONT) = [F:SOH]BPCORD
   [M:ZCO3]BPTNUM(WCONT) = [F:SOH]BPTNUM
   [M:ZCO3]ZCORTE(WCONT) = [F:SOQ]ZCORTE
   [M:ZCO3]SOPLIN(WCONT) = [F:SOQ]SOPLIN
   [M:ZCO3]ITMREF(WCONT) = [F:SOQ]ITMREF
   [M:ZCO3]QTY(WCONT)    = [F:SOQ]QTY
   [M:ZCO3]ORDDAT(WCONT) = [F:SOQ]ORDDAT
   [M:ZCO3]STOFCY(WCONT) = [F:SOQ]STOFCY
   [M:ZCO3]SHIDAT(WCONT) = [F:SOQ]SHIDAT
   [M:ZCO3]DEMDLVDAT(WCONT) = [F:SOQ]DEMDLVDAT
   [M:ZCO3]BPCORD(WCONT) = [F:SOQ]BPCORD
   [M:ZCO3]SOQSTA(WCONT) = [F:SOQ]SOQSTA
   [M:ZCO3]SDHNUM(WCONT) = [F:SOQ]SDHNUM
   [M:ZCO3]ZBOBPED(WCONT) = [F:SOQ]ZQTYBOB
   [M:ZCO3]ZBOBASIPED(WCONT) = [F:ZCGP]BOBASI
   [M:ZCO3]ZBOBNEC(WCONT) = [F:ZCGP]BOBNEC
   [M:ZCO3]ZANCHO(WCONT) = [F:SOQ]ZANCHO
   [M:ZCO3]ZMANDRIL(WCONT) = [F:SOQ]ZMANDRIL
   [M:ZCO3]ZLONGITUD(WCONT) = [F:SOQ]ZLONGITUD
   [M:ZCO3]ZFECFINFAB(WCONT) = [F:SOQ]ZFECFINFAB
   [M:ZCO3]ZCUSORDREF(WCONT) = [F:SOQ]ZCUSORDREF

   #Calculo KG y M2
   Raz [F:ITM]
   Read [ITM]ITM0=[M:ZCO3]ITMREF(WCONT)

   [M:ZCO3]SAU(WCONT)    = [F:SOP]SAU
   If [F:SOP]SAU="M2"
      [M:ZCO3]QTYKG(WCONT)=arr([F:SOQ]QTY*[F:ITM]ZFACTOR,0.01)
      [M:ZCO3]QTYM2(WCONT)=arr([F:SOQ]QTY,0.01)
   Endif
   If [F:SOP]SAU="KG"
      [M:ZCO3]QTYKG(WCONT)=arr([F:SOQ]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:ZCO3]QTYM2(WCONT)=arr([F:SOQ]QTY/[F:ITM]ZFACTOR,0.01)
   Else
         [M:ZCO3]QTYM2(WCONT)=0
      Endif
   Endif
   [M:ZCO3]NETPRI(WCONT)=[F:SOP]NETPRI

   Raz [F:ZTDC]
   Read [ZTDC]ZTDOC0=2;[F:SOH]SOHNUM
   [M:ZCO3]OBSPRE1(WCONT) = [F:ZTDC]LINTEX1
   [M:ZCO3]OBSPRE2(WCONT) = [F:ZTDC]LINTEX2
   [M:ZCO3]OBSPRE3(WCONT) = [F:ZTDC]LINTEX3

   Raz [F:BPC]
   Read [BPC]BPC0=[F:SOH]BPCORD
   [M:ZCO3]ORDTEX(WCONT) = [F:BPC]ORDTEX

   #Calculo bobinas disponibles
   NBRBOBSTO=0
   NBRBOBASITOT=0
   Filter [STO] Where ITMREF=[F:SOQ]ITMREF and STOFCY=[F:SOQ]STOFCY and ZANCHO=[F:SOQ]ZANCHO and
&                     ZMANDRIL=[F:SOQ]ZMANDRIL and ZLONGITUD=[F:SOQ]ZLONGITUD
   For [STO]
      NBRBOBSTO+=1
      Filter [STA] Where STOFCY=[F:STO]STOFCY and ITMREF=[F:STO]ITMREF and STOCOU=[F:STO]STOCOU
      For [STA]
         NBRBOBASITOT+=1
      Next
      Filter [STA]
   Next
   Filter [STO]
   NBRBOBDIS=NBRBOBSTO-NBRBOBASITOT
   [M:ZCO3]NBRBOBDIS(WCONT) = NBRBOBDIS

   #Calculo bobinas en transito
   NBRBOBTRA=0
   NBRBOBTRAASIG=0
   Link [ZCNTRH] With [ZCNTRP]ZCNTRP0(1)=[F:ZCNTRH]NUMCNTR, [POQ]POQ0(2)=[F:ZCNTRP]POHNUM;[F:ZCNTRP]POPLIN As [LNK1]
   Filter [LNK1] Where [POQ]ITMREF=[F:SOQ]ITMREF and [POQ]ZANCHO=[F:SOQ]ZANCHO and ZMANDRIL=[F:SOQ]ZMANDRIL and
&                      [POQ]ZLONGITUD=[F:SOQ]ZLONGITUD and
&                      [ZCNTRH]FECLLEDES<=[M:ZCO1]FECREF and [ZCNTRH]SITCNTR<9
   For [LNK1]
      NBRBOBTRA+=[F:POQ]ZQTYBOB
      Filter [ZCNTRS] Where NUMCNTR=[F:ZCNTRH]NUMCNTR and POHNUM=[F:ZCNTRP]POHNUM and POPLIN=[F:ZCNTRP]POPLIN
      For [ZCNTRS]
         NBRBOBTRAASIG+=[F:ZCNTRS]BOBASI
      Next
      Filter [ZCNTRS]
   Next
   Filter [LNK1]
   NBRBOBTRADIS = NBRBOBTRA - NBRBOBTRAASIG
   [M:ZCO3]NBRBOBTRADIS(WCONT) = NBRBOBTRADIS
   [M:ZCO3]NBLIG += 1
   WCONT += 1
   If WCONT>2999
      Infbox "Numero de lineas a mostrar sobrepasado"
   Endif
Next
Filter [ZCGP]
nolign=WCONT
Gosub CALCULAR_TOTALES

If WCONT>0
   Affzo [M:ZCO3]5
   If [M:ZCO1]CORTE=1
      Call APLICA_COLOR()
   Endif
Endif

Return

$CALCULAR_TOTALES
Local Integer FILAS
###############################################################
#pcolor = GCOUL(3)
#Chgstl [M:ZSFC2]NBLIG(nolign-1) With "BACKRED"
[M:ZCO3]STOFCY(WCONT) = "***"
#[M:ZCO3]FCYSHO(nolign-1) = toupper(mess(142,124,1))

For FILAS=0 To WCONT-1
   Raz [M:ZCO3]SCDFLG(WCONT)
   Raz [M:ZCO3]MFGTRKFLG(WCONT)
   Raz [M:ZCO3]SITLPED(WCONT)
   Raz [M:ZCO3]SOQSTA(WCONT)
   Raz [M:ZCO3]ZCORTE(WCONT)
   [M:ZCO3]ZBOBNEC(WCONT) =[M:ZCO3]ZBOBNEC(WCONT) + [M:ZCO3]ZBOBNEC(FILAS)
   [M:ZCO3]QTY(WCONT)    =[M:ZCO3]QTY(WCONT) + [M:ZCO3]QTY(FILAS)
   [M:ZCO3]QTYKG(WCONT)  = [M:ZCO3]QTYKG(WCONT) + [M:ZCO3]QTYKG(FILAS)
   [M:ZCO3]QTYM2(WCONT)  = [M:ZCO3]QTYM2(WCONT) + [M:ZCO3]QTYM2(FILAS)
Next
WCONT+=1
[M:ZCO3]NBLIG += 1
Return

Subprog APLICA_COLOR()
Local Integer LI

For LI=0 To [M:ZCO3]NBLIG
   If [M:ZCO3]SOQSTA(LI)=3
      #Fondo verde: Linea servida
      Chgstl [M:ZCO3]NBLIG(LI) With "BACKGREEN"
   Else
      If [M:ZCO3]ZCORTE(LI)=2
         #Corte
         If [M:ZCO3]MFGTRKFLG(LI)>=5
            #Linea asignada con OF Saldada o Coste calculado
            Chgstl [M:ZCO3]NBLIG(LI) With "AEXPEXCHVA" : #Fondo verde mas brillante que BACKGREEN
         Else
            If len([M:ZCO3]MFGNUM(LI))>0
              #Esta programada
               If [M:ZCO3]SCDFLG(LI)>=2
                  #Esta escalonada
                  Chgstl [M:ZCO3]NBLIG(LI) With "BACKYELLOW"
               Else
                  #No esta escalonada
                  Chgstl [M:ZCO3]NBLIG(LI) With "AERROR" : #Naranja oscuro
               Endif

               If [M:ZCO3]OFENDDAT(LI)>[M:ZCO3]DEMDLVDAT(LI)
                  #Si fecha fin mayor fecha entrega solicitada
                  Chgstl [M:ZCO3]NBLIG(LI) With "BACKRED" : #Rojo
               Endif
            Else
               #No esta programada
               Chgstl [M:ZCO3]NBLIG(LI) With "CPYFLD" : #Azul
            Endif
         Endif
      Else
         If [M:ZCO3]ZBOBNEC(LI)>0
            Chgstl [M:ZCO3]NBLIG(LI) With "BACKORANGE"
         Else
            Chgstl [M:ZCO3]NBLIG(LI) With ""
         Endif
      Endif
   Endif
Next
Affzo [M:ZCO3]5
End
