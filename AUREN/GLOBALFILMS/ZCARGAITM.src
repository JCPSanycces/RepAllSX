#<AdxTL>@(#)0.0.0.0 $Revision$
#GESTIėN PARA SACAR LAS LINEAS DE PEDIDO A PARTIR DE UN FILTRO PREVIO
#LAS LINEAS MARCADAS PASAN A LINEAS DE PEDIDOS
# PEDRO 12/09/2016


$ACTION
 #Infbox ACTION
 Case ACTION
     When "OUVRE"       : Gosub OUVRE
     When "DEBUT"       : Gosub DEBUT
     When "OK"          : Gosub OK
     When "SETBOUT"     : Gosub DESHABILITA
     When "BOUTON"      : Gosub EJECUTA
  Endcase
Return

########################################################################################################

$DESHABILITA
  If [M:ZCITM]NBLIG=0
      Call VIREBOUT(CHAINE,"O") From GOBJET
      Gosub SET_BOUT_SPE From GSAISIE
  Endif
Return

########################################################################################################

$EJECUTA
  Case BOUT
      When "L" :  Gosub LIMPIAR    # BOTON LIMPIAR
      When "X" :  Gosub CARGAR     # BOTON BUSCAR
      When "Y" :  Gosub ACUMULAR   # BOTON AčADIR
                  Gosub LIMPIAR
  Endcase
Return

########################################################################################################

$OUVRE
Global Integer WNUMLIN
Global Integer WNUMLINC
If clalev([F:STO]) = 0 Local File STOCK       [STO]: Endif
If clalev([F:SOH]) = 0 Local File SORDER      [SOH]: Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ]: Endif
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP]: Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM]: Endif
If clalev([F:ITP]) = 0 Local File ITMBPS      [ITP]: Endif
If clalev([F:BPS]) = 0 Local File BPSUPPLIER  [BPS]: Endif
If clalev([F:ZCAR]) = 0 Local File ZCARITM    [ZCAR]: Endif
If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
If !clalev([F:AXX]) : Local File ATEXTRA [AXX] : Endif

Return

########################################################################################################

$DEBUT
    Raz[M:ZCITM]
    [M:ZCITM]WDESANC  = 0
    [M:ZCITM]WHASANC  = 9999
    [M:ZCITM]WDESLAR  = 0
    [M:ZCITM]WHASLAR  = 9999
    Affzo [M:ZCITM]
Return

########################################################################################################

$LIMPIAR
  [M:ZCITM]NBLIG=0
  WNUMLIN = 0
  [M:ZCITM]WITMREF  = ""
  [M:ZCITM]WDESANC  = 0
  [M:ZCITM]WHASANC  = 9999
  [M:ZCITM]WDESLAR  = 0
  [M:ZCITM]WHASLAR  = 9999
  [M:ZCITM]WDESBPS  = ""
  [M:ZCITM]WHASBPS  = ""
  Affzo [M:ZCITM]
Return

########################################################################################################

## AL EJECUTAR EL BOTON BUSCAR CARGA LOS DATOS EN EL PRIMER GRID
$CARGAR
Local Char WFILTRO(250)
Local Char MSG(250),TXT(250)(10), W(250)(2)
Local Integer F
Local Char BD_TIPO(1)

BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()

Raz MSG,TXT,W,F

[M:ZCITM]NBLIG=0
WNUMLIN = 0
Affzo [M:ZCITM]

#JLPR 17_11_16 S/Tachi, hasta qua se parametrize, evitar las 2 ubicaciones
WFILTRO = "STO.STOFCY_0 = " +  num$([M:SOH0]SALFCY) +  " AND CUMALLQTY_0 = 0 AND NOT (LOC_0='PTREVISI' or LOC_0='DEVOLUCI')"

If [M:ZCITM]WITMREF = "" Then # ARTICULO
   Errbox 'ARTICULO NECESARIO'
   Return
Else
   WFILTRO = "STO.ITMREF_0 = '" + [M:ZCITM]WITMREF + "' AND " + WFILTRO
Endif

If [M:ZCITM]WDESANC = 9999999 Then # DESDE ANCHO
   Errbox 'ANCHO INICIAL NECESARIO'
   Return
Else
   WFILTRO = "STO.ZANCHO_0 >= " + num$([M:ZCITM]WDESANC)  + " AND " + WFILTRO
Endif

If [M:ZCITM]WHASANC = 0 Then # HASTA ANCHO
   # Si el campo hasta ancho viene vacio se entiende que su valor es el ultimo
   #[M:ZCITM]WHASANC  = 9999
   #Affzo [M:ZCITM]WHASANC
Else
   WFILTRO = "STO.ZANCHO_0 <= " + num$([M:ZCITM]WHASANC) + " AND " + WFILTRO
Endif

If [M:ZCITM]WDESLAR = 99999999 Then # DESDE LARGO
   Errbox 'LARGO INICIAL NECESARIO'
   Return
Else
   WFILTRO = "STO.ZLONGITUD_0 >= " + num$([M:ZCITM]WDESLAR) + " AND " + WFILTRO
Endif

If [M:ZCITM]WHASLAR = 0 Then # HASTA LARGO
   # Si el campo hasta LARGO viene vacio se entiende que su valor es el ultimo
  #[M:ZCITM]WHASLAR  = 9999
  #Affzo [M:ZCITM]WHASLAR
Else
   WFILTRO = "STO.ZLONGITUD_0 <= " + num$([M:ZCITM]WHASLAR) + " AND " + WFILTRO
Endif

If [M:ZCITM]WDESBPS = "" Then # DESDE PROVEEDOR
Else
   WFILTRO = "STO.ZPROVEEDOR_0 >= '" + [M:ZCITM]WDESBPS + "' AND " + WFILTRO
Endif

If [M:ZCITM]WHASBPS = "" Then # HASTA PROVEEDOR
Else
   WFILTRO = "STO.ZPROVEEDOR_0 <= '" + [M:ZCITM]WHASBPS + "' AND " + WFILTRO
Endif

#  Link [STO] With [ITM]ITM0 = [STO]ITMREF As [LNK] Order By Key CLE = [F:STO]ZANCHO Desc
#  nolign = 0
#

#  TXT(0)="select SOH.SOHNUM_0, SOH.ORDDAT_0, SOH.DEMDLVDAT_0, SOH.BPCORD_0, SOQ.SOPLIN_0, SOQ.ITMREF_0, SOQ.ZANCHO_0, SOQ.ZLONGITUD_0, SOQ.ZMANDRIL_0, SOQ.ZQTYBOB_0, SOP.NETPRI_0, 0 "
#  TXT(1)="from SORDER SOH inner join SORDERQ SOQ  on SOH.SOHNUM_0=SOQ.SOHNUM_0 INNER JOIN SORDERP SOP ON SOH.SOHNUM_0=SOP.SOHNUM_0 and SOQ.SOPLIN_0=SOP.SOPLIN_0 LEFT JOIN ZMFGSOQ ZMSQ ON
# SOQ.SOHNUM_0=Z"
#&       + "MSQ.SOHNUM_0 AND SOQ.SOPLIN_0="
#&       + "ZMSQ.SOPLIN_0 "
#  TXT(2)="Where ZMSQ.SOHNUM_0 IS null " + W(0)
#  TXT(3)=W(1)
#  TXT(4)="UNION ALL "
#  TXT(5)="select SOH.SOHNUM_0, SOH.ORDDAT_0, SOH.DEMDLVDAT_0, SOQ.BPCORD_0, SOQ.SOPLIN_0, SOQ.ITMREF_0, SOQ.ZANCHO_0, SOQ.ZLONGITUD_0, SOQ.ZMANDRIL_0, SOQ.ZQTYBOB_0, SOP.NETPRI_0, ZMSQ.ZQTYBOBASI_0 "
#  TXT(6)="From SORDER SOH INNER JOIN SORDERQ SOQ  ON SOH.SOHNUM_0=SOQ.SOHNUM_0 INNER JOIN SORDERP SOP ON SOH.SOHNUM_0=SOP.SOHNUM_0 and SOQ.SOPLIN_0=SOP.SOPLIN_0 INNER JOIN ZMFGSOQ ZMSQ ON
# SOQ.SOHNUM_0="
#&       + "ZMSQ.SOHNUM_0 and SOQ.SOPLIN_0"
#&       + "=ZMSQ.SOPLIN_0 "
#  TXT(7)="Where ZMSQ.ZQTYBOBASI_0<SOQ.ZQTYBOB_0 " + W(0)
#  TXT(8)=W(1)
#  TXT(9)="Order By ITMREF_0, ZMANDRIL_0, SOH.SOHNUM_0, SOQ.SOPLIN_0"# ,ZLONGITUD_0,ZANCHO_0"

TXT(0)="SELECT STO.ITMREF_0,ZANCHO_0,ZLONGITUD_0,STO.ZMANDRIL_0,ZPROVEEDOR_0,LOT_0,COUNT(*) As CANTIDAD, sum(QTYPCU_0) * ITM.ITMWEI_0 As KGS, sum(QTYPCU_0) * ITM.SAUSTUCOE_0 As M2 "
TXT(1)="From STOCK STO INNER JOIN ITMMASTER ITM ON ITM.ITMREF_0 = STO.ITMREF_0 "
TXT(2)="Where " + WFILTRO
TXT(3)="GROUP By STO.ITMREF_0,STOFCY_0,ZANCHO_0,ZLONGITUD_0,STO.ZMANDRIL_0,ZPROVEEDOR_0,LOT_0,ITM.ITMWEI_0,ITM.SAUSTUCOE_0 "
TXT(4)="Order By STO.ITMREF_0,ZANCHO_0,ZLONGITUD_0,STO.ZMANDRIL_0"

#### las siguientes instrucciones crean un fichero en la carpeta tmp donde esta la sentencia de SQL para poder depurar
#Local Char FICSRV(250)
#Local Integer YN
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  Return
#Endif

For (Char FITMREF(GLONITM),Integer FZANCHO,Integer FZLONGITUD,Integer FZMANDRIL,Char FZPROVEEDOR(GLONBPS),Char FLOT(GLONLOT),Decimal FCANTIDAD,Decimal FKGS,Decimal FM2)
&     From BD_TIPO Sql TXT As [MYT]

      F = [M:ZCITM]NBLIG

      [M:ZCITM]ITMREF(F)=FITMREF
      [M:ZCITM]WDESPROV(F)=FZPROVEEDOR
      [M:ZCITM]ANCHO(F)=FZANCHO
      [M:ZCITM]LARGO(F)=FZLONGITUD
      [M:ZCITM]MANDRIL(F)=FZMANDRIL
      [M:ZCITM]LOTE(F)=FLOT
      [M:ZCITM]STOCK(F)=FCANTIDAD
      [M:ZCITM]KGS(F)=FKGS
      [M:ZCITM]M2(F)=FM2
      [M:ZCITM]CANTIDAD(F)=0

      [M:ZCITM]NBLIG+=1

Next

# Ordeno el grid
#Sorta [M:ZCITM]NBLIG Order By [M:ZCITM]ANCHO(indice),[M:ZCITM]LARGO(indice)

If F = 0 Then # la busqueda no ha devuelto nada. Insertamos un registro con el articulo y su ancho y largo inicial para que se pueda meter a mano.
 F = [M:ZCITM]NBLIG

      [M:ZCITM]ITMREF(F)=WITMREF

      [M:ZCITM]WDESPROV(F)=""
      [M:ZCITM]ANCHO(F)=WDESANC
      [M:ZCITM]LARGO(F)=WDESLAR
      [M:ZCITM]MANDRIL(F)=0
      [M:ZCITM]LOTE(F)=""
      [M:ZCITM]STOCK(F)=0
      [M:ZCITM]KGS(F)=0
      [M:ZCITM]M2(F)=0
      [M:ZCITM]CANTIDAD(F)=0

      [M:ZCITM]NBLIG+=1
Endif

WNUMLIN = F

Affzo [M:ZCITM]

Return

#########################################################################################################

## AL EJECUTAR EL BOTON AčADIR CARGAMOS EN EL GRID DE LINEAS AčADIDAS LAS LINEAS QUE HEMOS INDICADO CANTIDAD EN EL GRID DE SELECCION.
## SI LA LINEA TIENE INTRODUCIDA MAS CANTIDAD QUE STOCK TENEMOS QUE GUARDAR 2 LINEAS ( 1 CON LA CANTIDAD DE TIENE DE STOCK Y OTRA CON EL RESTO Y LA MARCAMOS )

$ACUMULAR
Local Char WFILTRO(250)
Local Char MSG(250),TXT(250)(10), W(250)(2)
Local Integer F
Local Char BD_TIPO(1)

For I = 0 To WNUMLIN
   If [M:ZCITM]CANTIDAD(I) <> 0 Then
      If [M:ZCITM]CANTIDAD(I) > [M:ZCITM]STOCK(I) Then
        ## SI LA LINEA TIENE INTRODUCIDA MAS CANTIDAD QUE STOCK TENEMOS QUE GUARDAR 2 LINEAS

            ## UNA CON LO QUE EXCEDE DEL STOCK Y LA MARCAMOS COMO EXCESO

            F = [M:ZCITM]NBLIG1

            [M:ZCITM]CITMREF(F) = [M:ZCITM]ITMREF(I)
            [M:ZCITM]CPROVEEDOR(F) = [M:ZCITM]WDESPROV(I)
            [M:ZCITM]CANCHO(F) = [M:ZCITM]ANCHO(I)
            [M:ZCITM]CLARGO(F) = [M:ZCITM]LARGO(I)
            [M:ZCITM]CMANDRIL(F) = [M:ZCITM]MANDRIL(I)
            [M:ZCITM]CLOTE(F) = ""
            [M:ZCITM]CCANTIDAD(F) = [M:ZCITM]CANTIDAD(I) - [M:ZCITM]STOCK(I)
            [M:ZCITM]CEXCEDE(F) = "SI"

            [M:ZCITM]NBLIG1+=1

          ## SI LA LINEA ES NUEVA ( CREADA POR EL USUARIO NO EXISTE EL LOTE ) NO GUARDAMOS LA LINEA

            ## OTRA CON LA CANTIDAD QUE TIENE DE STOCK
            If [M:ZCITM]LOTE(I) <> "" Then
                F = [M:ZCITM]NBLIG1

                [M:ZCITM]CITMREF(F) = [M:ZCITM]ITMREF(I)
                [M:ZCITM]CPROVEEDOR(F) = [M:ZCITM]WDESPROV(I)
                [M:ZCITM]CANCHO(F) = [M:ZCITM]ANCHO(I)
                [M:ZCITM]CLARGO(F) = [M:ZCITM]LARGO(I)
                [M:ZCITM]CMANDRIL(F) = [M:ZCITM]MANDRIL(I)
                [M:ZCITM]CLOTE(F) = [M:ZCITM]LOTE(I)
                [M:ZCITM]CCANTIDAD(F) = [M:ZCITM]STOCK(I)
                [M:ZCITM]CEXCEDE(F) = "NO"

                [M:ZCITM]NBLIG1+=1
            Endif
        Else
            F = [M:ZCITM]NBLIG1

            [M:ZCITM]CITMREF(F) = [M:ZCITM]ITMREF(I)
            [M:ZCITM]CPROVEEDOR(F) = [M:ZCITM]WDESPROV(I)
            [M:ZCITM]CANCHO(F) = [M:ZCITM]ANCHO(I)
            [M:ZCITM]CLARGO(F) = [M:ZCITM]LARGO(I)
            [M:ZCITM]CMANDRIL(F) = [M:ZCITM]MANDRIL(I)
            [M:ZCITM]CLOTE(F) = [M:ZCITM]LOTE(I)
            [M:ZCITM]CCANTIDAD(F) = [M:ZCITM]CANTIDAD(I)
            [M:ZCITM]CEXCEDE(F) = "NO"

            [M:ZCITM]NBLIG1+=1
        Endif
      Endif
Next

WNUMLINC = F

Affzo [M:ZCITM]

Return

#########################################################################################################

## AL EJECUTAR EL BOTON OK INSERTAMOS LOS ARTICULOS QUE HAY EN EL GRID DE AčADIDOS EN LA TABLA ZCARITM.

$OK
     For I = 0 To WNUMLINC
       If [M:ZCITM]CCANTIDAD(I) > 0 Then

         Raz [F:ZCAR]
         [F:ZCAR]SOHNUM  = [M:SOH0]SOHNUM
         [F:ZCAR]STOFCY  = [M:SOH2]STOFCY
         [F:ZCAR]ITMREF  = [M:ZCITM]CITMREF(I)
         [F:ZCAR]ZPROVEEDOR  = [M:ZCITM]CPROVEEDOR(I)
         [F:ZCAR]ZANCHO  = [M:ZCITM]CANCHO(I)
         [F:ZCAR]ZMANDRIL = [M:ZCITM]CMANDRIL(I)
         [F:ZCAR]ZLONGITUD = [M:ZCITM]CLARGO(I)
         [F:ZCAR]LOT  = [M:ZCITM]CLOTE(I)
         [F:ZCAR]QTY  = [M:ZCITM]CCANTIDAD(I)
         [F:ZCAR]EXCEDE  = [M:ZCITM]CEXCEDE(I)
         [F:ZCAR]CARGADO = "NO"
         [F:ZCAR]CREUSR  = GUSER
         Write [F:ZCAR]
       Endif

     Next

Return

#########################################################################################################

#CARGA_LINPEDART: Funcion para cumplimentar la mascara de pedidos y realizar las operaciones
#necesarias.
#Codigo obtenido de la carga de presupuesto en pedido (SUBSOHC)

Subprog CARGA_LINPEDART(WART,WQTY,WZANCHO,WZLONGITUD,WZMANDRIL,WZPROVEEDOR,WEXCEDE)
Value Char WART
Value Decimal WQTY
Value Integer WZANCHO
Value Integer WZLONGITUD
Value Integer WZMANDRIL
Value Char WZPROVEEDOR
Value Char WEXCEDE


Local Integer I
Local Integer NOL

#--- Lecture des tables articles
Call LEC_TABART(WART)
Local Integer RETF
#--- Controler que l'article-site existe
If [F:ITM]STOMGTCOD <> 1
    Call CONTITF([F:ITM]ITMREF, [M:SOH2]STOFCY, [F:ITM]STOMGTCOD) From TRTVENCTL
    If mkstat=2
        GERR=1:GMESSAGE=mess(27,159,1)-[F:ITM]ITMREF-mess(25,192,1)-[M:SOH2]STOFCY
        OK=0: End
    Endif
    # Si commande inter-site, vķrifier que l'article-site de rķception existe
    If [M:SOH1]BETFCY=2 & [M:SOH0]SOHCAT<>3 & [F:ITM]RCPFLG=2
        If [F:BPD]BPCNUM<>[M:SOH0]BPCORD | [F:BPD]BPAADD<>[M:SOH1]BPAADD
           Read [BPD]BPD0=[M:SOH0]BPCORD;[M:SOH0]BPAADD
           If fstat Raz [F:BPD] Endif
        Endif
        If [F:BPD]RCPFCY<>""
            Call CONTITF([F:ITM]ITMREF, [F:BPD]RCPFCY, [F:ITM]STOMGTCOD) From TRTVENCTL
            If mkstat=2
                GERR=1:GMESSAGE=mess(74,187,1)-":"-[F:ITM]ITMREF-mess(293,192,1)-[F:BPD]RCPFCY
                OK=0: End
            Endif
        Endif
    Endif
    # Si commande Ó facturation directe inter-site, l'article ne doit pas Ļtre rķceptionnķ
    If [M:SOH0]SOHCAT=3 & [M:SOH1]BETFCY=2
        If [F:ITM]RCPFLG=2
            GERR=1: GMESSAGE=[F:ITM]ITMREF-":"-mess(98,197,1)-mess(3,446,1)-mess(269,194,1) : OK=0 :
            End
        Endif
    Endif
Endif

# Contr¶le de l'insertion
If [M:SOH4]NBLIG+1 >= dim([M:SOH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : End
Endif

# Ouverture de la ligne
nolign = [M:SOH4]NBLIG
Insa nolign,1,[M:SOH4]NBLIG [M:SOH4]NBLIG
[M:SOH4]NBLIG += 1
nolign = [M:SOH4]NBLIG
NOL = nolign-1
status = 0

# Alimentation de la classe [M:SOH4] de la ligne
Call ALIAYUSOH(NOL,WQTY,WZANCHO,WZLONGITUD,WZMANDRIL,WZPROVEEDOR,WEXCEDE)

If GERR=1
    OK=0 : End
Endif

Call LINNUM("SOPLIN") From TABLEAUX

# Article normal ou composķ
TYP=1
# Composant
If find([M:SOH4]LINTYP(NOL),3,4,5,7,8,9,11,12,13) TYP=4 Endif

Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SOH",[M]GROPRI(NOL)) From TRTVENTAR
# --> Calcul du prix net
Call CLCNETPRI([M]QTY(NOL), [M:SOH0]CUR, NOL) From TRTVENPRI
If GDACLOK = 1
    # --> Calcul du prix net
    Call CTLNETPRI([M:SOH0]BPCORD,[M:SOH0]CHGTYP,[M:SOH0]ORDDAT,[M:SOH0]CUR,NOL) From TRTVENPRI
    If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
Endif

# --- Si Initialisation de la qtķ Ó allouer, Dde d'utilisation des rķservations clients
If [M:SOH4]WALLQTY(NOL)>0 & GUSERERBPC=3
    [M:SOH4]RERBPCFLG(NOL)=1
    Local Char WVCRRER
    Local Decimal WALLCLI
    WVCRRER= vireblc(format$("K:"+num$(GLONBPC)+"X",[M:SOH0]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M:SOH4]DBPAADD(NOL)), 1)
    #--- Bug 65986
    #Call CAL_RERQTY(1,[M]ITMREF(NOL),[M]DSTOFCY(NOL),WVCRRER,WALLCLI) From STKALL
    Call CAL_RERQTY(1,[M:SOH4]ITMREF(NOL),[M:SOH4]DSTOFCY(NOL),WVCRRER,[M:SOH4]DSHIDAT(NOL),WALLCLI) From STKALL
    #---

    If WALLCLI <> 0
        GMESSAGE = mess(207,191,1)-":"-num$([M:SOH4]WALLQTY(NOL))-[M:SOH4]SAU(NOL)-"\"-mess(131,191,1)-num$(WALLCLI)-[M:SOH4]STU(NOL)
        OK=2 : Call OUINON (GMESSAGE-"\"-mess(130,191,1),OK) From GESECRAN
        If OK = 2 [M:SOH4]RERBPCFLG(NOL)=2 : Endif
    Endif
Endif

If GLINREP=2
    # Alimentation des reprķsentants s'ils n'ont pas ķtķ alimentķs par le client commande
    If [F:BPC]BPCNUM <> [M:SOH0]BPCORD
        Read [BPC]BPC0 = [M:SOH0]BPCORD
        If fstat <> 0 Raz [F:BPC] : Endif
    Endif

    # Alimentation du 1er reprķsentant
    If dim([M:SOH4]REP1) > 0
       If  [M:SOH1]REP(0) <> ""
           [M:SOH4]REP1(NOL)= [M:SOH1]REP(0)
       Else
           [M:SOH4]REP1(NOL)= [F:BPD]REP(0)
       Endif
        If [F:REP]REPNUM <> [M:SOH4]REP1(NOL)
            Read [F:REP]REP0 = [M:SOH4]REP1(NOL)
            If fstat Raz [F:REP] : Endif
        Endif
        If [F:BPC]COMCAT <> 0 [M:SOH4]REPRAT1(NOL)=[F:REP]COMRAT1([F:BPC]COMCAT-1) : Endif
        Affzo [M:SOH4]REP1(NOL), REPRAT1(NOL)
    Endif
    # Alimentation du 2eme reprķsentant
    If dim([M:SOH4]REP2) > 0
        If [M:SOH4]REP1(NOL)<>""
           If [M:SOH1]REP(1) <> ""
              [M:SOH4]REP2(NOL) = [M:SOH1]REP(1)
           Else
              [M:SOH4]REP2(NOL) = [F:BPD]REP(1)
           Endif
            If [F:REP]REPNUM <> [M:SOH4]REP1(NOL)
                Read [F:REP]REP0 = [M:SOH4]REP1(NOL)
                If fstat Raz [F:REP] : Endif
            Endif
            If [F:BPC]COMCAT <> 0 [M:SOH4]REPRAT2(NOL)=[F:REP]COMRAT2([F:BPC]COMCAT-1) : Endif
            Affzo [M:SOH4]REP2(NOL), REPRAT2(NOL)
        Endif
    Endif
Endif

# Calculs prix net, marge et maj montants livrķs et poids
GNETMAR=0
Call ALICLCAMT([M:SOH4]ITMREF(NOL), [M:SOH4]QTY(NOL), NOL, "SOH4", [M:SOH4]CLCAMT1(NOL), [M:SOH4]CLCAMT2(NOL)) From TRTX3
Call CLCPFM([M:SOH4]DSTOFCY(NOL),[M:SOH1]PRITYP,[M:SOH0]CHGTYP,[M:SOH0]ORDDAT,[M:SOH1]CUR,NOL,1) From TRTVENPRI
#Call APRES_LIGNE(NOL,0) From SUBSOHB
GNETMAR=1

# --> Recalcul date expedition
Call CALC_SHIDAT(date$, [M:SOH4]DDAYLTI(NOL), [M:SOH4]DSTOFCY(NOL), 1, 1,[M:SOH0]ORDDAT, [M:SOH4]DSHIDAT(NOL)) From TRTVENDAT
# --> Recalcul date de livraison prķvue
Call CALC_DLVDAT([M:SOH4]DSHIDAT(NOL), [M:SOH4]DDAYLTI(NOL), [M:SOH4]DBPAADD(NOL), [M:SOH0]BPCORD, 0,0,
&             [M:SOH4]EXTDLVDAT(NOL)) From TRTVENDAT

nolign  = NOL+1

# A vķrifier

# qtķ commandķe
WORDQTY    = WQTY

#--------
#Aqui iria el tratamiento de kit

#Aqui iria originalmente el tratamiento si el origen es gratuito
#--------

#Llamadas a las funciones para la carga de gratuitos
Gosub P1_NBLIG From SUBSOH
Gosub P2_NBLIG From SUBSOH

Raz GMESSAGE
End

Subprog LEC_TABART(WART)
Value Char WART
#-----------------------------------------------------------------------#
# Lecture des tables articles                                           #
#-----------------------------------------------------------------------#
If [F:ITM]ITMREF <> WART
   Read [ITM]ITM0=WART
   If fstat Raz [F:ITM] Endif
Endif
If [F:ITS]ITMREF <> WART
   Read [ITS]ITS0 = WART
   If fstat Raz [F:ITS] Endif
Endif
If ([F:ITU]ITMREF <> WART) | ([F:ITU]BPCNUM <> [F:SOH]BPCORD)
   Read [F:ITU]ITU0 = WART;[F:SOH]BPCORD
   If fstat Raz [F:ITU] Endif
Endif
End

########################################################################
Subprog ALIAYUSOH(NOL,WQTACDE,WZANCHO,WZLONGITUD,WZMANDRIL,WZPROVEEDOR,WEXCEDE)
Value    Integer NOL
Variable Decimal WQTACDE
Value Integer WZANCHO
Value Integer WZLONGITUD
Value Integer WZMANDRIL
Value Char WZPROVEEDOR
Value Char WEXCEDE


Local Char    VAT(GLONVAT)(3)
Local Integer WRET, J
Local Char    SECTION(GLONCDE)
Local Decimal COEF

# ACA - 48862 - Controle statut & substitution
GERR=0
WITM = [F:ITM]ITMREF
WFLDNAM = "ITMREF"
[M:SOH4]DSTOFCY(NOL) = [M:SOH2]STOFCY
# On vķrifie si substitution nķcessaire, on passe alors par les tests
# Issue 65392 - 2010-07-08 by ACA : No item substitution when composed (kit or nomenclature)
Call CTLSBSITM(WITM, [M:SOH0]ORDDAT, WRET) From TRTVENCTL
If WRET > 0 : # Si substitution
    If [F:SQD]LINTYP<>2 and [F:SQD]LINTYP<>6
       Gosub TRT_RPLITM From SUBSOHB
    Else
      GERR=1
      GMESSAGE=mess(346,192,1)-"("+[F:ITM]ITMREF+")"
    Endif
    # Si ligne a supprimer, GERR a ķtķ mis Ó 1
Else
    # On vķrifie si l'article est utilisable (fait dans TRT_RPLITM si substitut)
    If [F:ITM]ITMSTA = 6
        GMESSAGE = mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
        GERR=1
    Endif
Endif
If GERR=1
    Dela nolign, 1 [M:SOH4]NBLIG
    [M:SOH4]NBLIG = [M:SOH4]NBLIG-1
    End
Elsif GERR>0
    Local Integer OK : OK=1
    Call AVERTIR (GMESSAGE, OK) From GESECRAN
Endif

[M:SOH4]ITMREF(NOL) = [F:ITM]ITMREF
[M]GRPFLG(NOL) = 1
[M]LINTYP(NOL) = 1
[M]FOCFLG(NOL) = 1
If [F:ITS]ITMTYP = 2 [M]LINTYP(NOL) = 6 :Endif
If [F:ITS]ITMTYP = 3 [M]LINTYP(NOL) = 2 :Endif
Call INIT_ITM(NOL, [F:ITM]ITMREF) From SUBSOHB

Raz [M:SOH4]SOPLIN(NOL)
# A cause de l'INISEC "SOP" qui peut Ļtre paramķtrķ avec [F:POP]
If GMODU(6)=2 & GNBDIE>0 Raz [F:POP] : Endif
# Chargement sections analytiques

#FJCG - esta por ver como se recarga las CEE
#Call CHARG_ACCCCE(NOL,"","","[M:SOH4]CCE",
#&                    "SQD",0,[F:SQD]SQHNUM,[F:SQD]SQDLIN,0,"") From TRTX3CPT

For J = 1 To GNBDIE
   If evalue("dim([M:SOH4]CCE"+num$(J)+"(NOL))") >0 & evalue("[M:SOH4]CCE"+num$(J)+"(NOL)")=""
       Call INISEC(SECTION,"SOP",J) From TRTX3CPT
       Assign "[M:SOH4]CCE"+num$(J)+"(NOL)" With SECTION
   Endif
Next J

###################################################################
# Especifico de carga de lineas PEDRO

If clalev ([F:ZCIT])<=0 : Local File ZBPCITMTAR [ZCIT] : Endif
If clalev ([F:STO]) = 0 Local File STOCK       [STO]: Endif

Raz [F:ZCIT]
Read [ZCIT]ZCIT0(2)=[F:BPC]BPCNUM;[F:ITM]ITMREF
[M:SOH4]ZTARIFA(NOL)=[F:ZCIT]PLI
If dim(GZTARIFA)<=0 : Global Char GZTARIFA(10) : Endif
GZTARIFA=[F:ZCIT]PLI

[M:SOH4]ZQTYBOB(NOL)    =  WQTACDE
Call AM_ZQTYBOB(WQTACDE) From SPESOH
[M:SOH4]ZANCHO(NOL)     =  WZANCHO
[M:SOH4]ZMANDRIL(NOL) = WZMANDRIL
[M:SOH4]ZLONGITUD(NOL)  =  WZLONGITUD
Call AM_ZLONGITUD([M:SOH4]ZLONGITUD(NOL)) From SPESOH
[M:SOH4]ZPROVEEDOR(NOL) =  WZPROVEEDOR
If WEXCEDE = "SI" Then
  [M:SOH4]ZCORTE(NOL)   =  2
Else
  [M:SOH4]ZCORTE(NOL)   =  1
Endif
[M:SOH4]ZCTDREAL(NOL) = [M:SOH4]QTY(NOL)
[M:SOH4]DDEMDLVDAT(NOL) = date$
[M:SOH4]QTYSTU(NOL)-=0.01
[M:SOH4]ZCTDREALUS(NOL) = [M:SOH4]QTYSTU(NOL)

# Alimentation de la quantitķ Ó commander
#[M:SOH4]QTY(NOL) = WQTACDE

###################################################################

#Call CNVQTY(WQTACDE,[M:SOH4]SAUSTUCOE(NOL),[M:SOH4]STU(NOL),[M:SOH4]QTYSTU(NOL)) From TRTVENQTE

[M:SOH4]DBPAADD(NOL)    =  [M:SOH1]BPAADD
[M:SOH4]DDRN(NOL)       =  [M:SOH2]DRN
[M:SOH4]DDLVPIO(NOL)    =  [M:SOH2]DLVPIO
[M:SOH4]DMDL(NOL)       =  [M:SOH2]MDL
[M:SOH4]DBPTNUM(NOL)    =  [M:SOH2]BPTNUM
#If dim([M:ADB2]CNTNAM)>0
    [M:SOH4]CNDNAM(NOL) =  [M:ADB2]CNTNAM
#Endif

#[M:SOH4]DDAYLTI(NOL)    =  [F:BPD]DAYLTI
[M:SOH4]DDAYLTI(NOL)    =  [M:SOH2]DAYLTI
#[M:SOH4]DDEMDLVDAT(NOL) =  [M:SOH2]DEMDLVDAT
[M:SOH4]DSHIDAT(NOL)    =  [M:SOH2]SHIDAT

[M:SOH4]DALLTYP(NOL)    =  [M:SOH2]ALLTYP

# ---------------------------------------------------------------------------- #
#     Gestion du FMI                                                           #
#     On calcule FMI pour kit, composķ nom. composants nom. et article normaux #
#     On garde   FMI Ó 1 pour les composants de kit (Bug 27897)                #
# ---------------------------------------------------------------------------- #
If [F:ITS]CTMFLG = 2 & [F:ITM]PHAFLG <> 2 & !find ([M:SOH4]LINTYP(NOL),3,4,5,11,12,13)
# Correction: le test ķtait diffķrent de celui effectuķ dans ALIFMI,
# pour le mĻme article on avait un FMI diffķrent en saisie directe de cde et en rķcup devis ... (llc)
    If [F:ITM]PURFLG=2
        If [F:ITM]MFGFLG=1 | ([F:ITM]MFGFLG=2 & [F:ITF]REOCOD=2)
            If GMODU(6) = 2        #   Il faut avoir le module achat
#       --> Calcul de la qtķe cdķe en UV
                Local Decimal QTY_UV
                If [M:SOH4]SAU(NOL) <> [F:ITM]SAU
                    Call SCAL_QUV([M:SOH4]QTY(NOL), [M:SOH4]ITMREF(NOL),[M:SOH0]BPCORD,[M:SOH4]SAU(NOL),[F:ITM]SAU, QTY_UV, GBIDD1) From TRTVENQTE
                Else
                    QTY_UV = [M:SOH4]QTY(NOL)
                Endif
                If QTY_UV < [F:ITS]CTMQTY | [F:ITS]CTMQTY = 0
                    [M:SOH4]FMI(NOL) = 3
                Else
                    [M:SOH4]FMI(NOL) = 2
                    [M:SOH4]STOMGTCOD(NOL) = 1
                Endif
                [M:SOH4]DALLTYP(NOL) = 2
            Endif
        Endif
    Endif
    If [F:ITM]MFGFLG = 2
        If [F:ITM]PURFLG = 1 | ([F:ITM]PURFLG = 2 & [F:ITF]REOCOD = 3)
            If GMODU(8) = 2     #   Il faut avoir le module production
                [M:SOH4]FMI(NOL) = 5
                [M:SOH4]DALLTYP(NOL) = 2
            Endif
        Endif
    Endif
Endif

If GINIALLORD=2
    # -- Si Commande non bloquķe, pas en dķpassement d'en-cours avec blocage
    #       Ligne ferme
    #       Article gķrķ en stock ou composķ kit/sous-traitķ
    # ----> Initialisation de la qtķ Ó allouer
#    If  (find([M]CDTSTA,1,4) | ([M]CDTSTA=3 & GCDTUNL=2)) & [M]DEMSTA(NOL)=1 & [M]FMI(NOL)=1 & ([M]STOMGTCOD(NOL)<>1 | find([M]LINTYP(NOL),2,10))
    If  (find([M:SOH1]CDTSTA,1,4) | ([M:SOH1]CDTSTA=3 & GCDTUNL=2)) & [M:SOH4]DEMSTA(NOL)=1 & [M:SOH4]FMI(NOL)=1 & ([M:SOH4]STOMGTCOD(NOL)<>1 | find([M:SOH4]LINTYP(NOL),2,10))
        Local Decimal COEF
        # (Il faut toujours repartir des qtķ en US pour effectuer les calculs)
        # --- Qtķ Ó allouer = Qtķ dķjÓ allouķe + Reste Ó allouer
        [M:SOH4]WALLQTYSTU(NOL) =[M:SOH4]ALLQTYSTU(NOL)+([M:SOH4]QTYSTU(NOL)-[M:SOH4]TALLQTYSTU(NOL))
        COEF=1/[M:SOH4]SAUSTUCOE(NOL)
        Call CNVQTY([M:SOH4]WALLQTYSTU(NOL),COEF,[M:SOH4]SAU(NOL),[M:SOH4]WALLQTY(NOL)) From TRTVENQTE
    Endif
Endif

[M:SOH4]YQTY(NOL)     =  [M:SOH4]QTY(NOL)
[M:SOH4]CQTY(NOL)     =  [M:SOH4]QTY(NOL)
[M:SOH4]YSOQSTA(NOL)  =  [M:SOH4]SOQSTA(NOL)
[M:SOH4]YDSHIDAT(NOL) =  [M:SOH4]DSHIDAT(NOL)



End

######################################################################################
# Despues de modificar la cantidad de la linea verificamos si los datos estan correctos
Subprog AM_CANTIDAD(VALEUR)
    Variable Decimal VALEUR
    Local Integer I

    I = nolign - 1

    If [M:ZCITM]ANCHO(I) = 0
         Infbox "ANCHO NECESARIO EN LA LINEA"
    Endif
    If [M:ZCITM]LARGO(I) = 0
         Infbox "LONGITUD NECESARIA EN LA LINEA"
    Endif
    If [M:ZCITM]MANDRIL(I) = 0
         Infbox "MANDRIL NECESARIO EN LA LINEA"
    Endif
End


######################################################################################
