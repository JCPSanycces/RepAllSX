Subprog CL_ICOLNKS(VALEUR)
Variable Char    VALEUR()
Local Integer LMAXLNKS, NOL

NOL=nolign-1
If [M:ZCNTRAM]NUMLNKS(NOL)=0
   LMAXLNKS=max([M:ZCNTRAM]NUMLNKS(0..[M:ZCNTRAM]NBLIG1-1))
   [M:ZCNTRAM]NUMLNKS(NOL)=LMAXLNKS+1
   Affzo [M:ZCNTRAM]NUMLNKS(NOL)
Else
   [M:ZCNTRAM]NUMLNKS(NOL)=0
   Affzo [M:ZCNTRAM]NUMLNKS
Endif
End

Subprog CL_ICOLNKP(VALEUR)
Variable Char    VALEUR()
Local Integer LMAXLNKS, LMAXLNKP, COMP, NOL
Local Char POHSOH(1)

NOL=nolign-1
If [M:ZCNTRAM]NUMLNKP(NOL)=0
   LMAXLNKS=max([M:ZCNTRAM]NUMLNKS(0..[M:ZCNTRAM]NBLIG1-1))
   Call DAME_COMP("M",LMAXLNKS,COMP) From SPEZCNTRAM
   If COMP>-1
      If [M:ZCNTRAM]ITMREF(COMP)=[M:ZCNTRAM]PITMREF(NOL) :#and [M:ZCNTRAM]ANCHO(COMP)=[M:ZCNTRAM]PANCHO(NOL)
         [M:ZCNTRAM]NUMLNKP(NOL)=LMAXLNKS
         Affzo [M:ZCNTRAM]NUMLNKP(NOL)
      Endif
   Endif
Else
   [M:ZCNTRAM]NUMLNKP(NOL)=0
   Affzo [M:ZCNTRAM]NUMLNKP
Endif
End

Subprog DAME_COMP(LMFGPOH,LNUMLNK,LCOMP)
Value Char LMFGPOH
Value Integer LNUMLNK
Variable Integer LCOMP
Local Integer J

LCOMP=-1
If LMFGPOH="M"
   For J=0 To [M:ZCNTRAM]NBLIG1-1
      If [M:ZCNTRAM]NUMLNKS(J)=LNUMLNK
         LCOMP=J
         Break
      Endif
   Next
Endif
If LMFGPOH="P"
   For J=0 To [M:ZCNTRAM]NBLIG2-1
      If [M:ZCNTRAM]NUMLNKP(J)=LNUMLNK
         LCOMP=J
         Break
      Endif
   Next
Endif
End

