$ACTION
Case ACTION
When "OUVRE"       :   Gosub OUVRE
When "VERIF_CRE"   :   Gosub VERIF_CREMOD
When "VERIF_MOD"   :   Gosub VERIF_CREMOD
Endcase
Return

$OUVRE
If !clalev ([F:ZPTD])   Local File PRECEIPTD [F:ZPTD] : Endif
Return


$VERIF_CREMOD
If 1=1 : Return : Endif # FJCP No funciona forzar importes control Verificar
[M:PIH4]TOTLINAMT=[M:PIH4]CLCLINAMT
[M:PIH4]TOTTAXAMT=[M:PIH4]TOTTAXCLC
[M:PIH1]TOTLINAMT1=[M:PIH4]CLCLINAMT
[M:PIH1]TOTTAXAMT1=[M:PIH4]TOTTAXCLC
[M:PIH1]STA=2

Affzo [M:PIH4]TOTLINAMT
Affzo [M:PIH4]TOTTAXAMT
Affzo [M:PIH1]TOTLINAMT1
Affzo [M:PIH1]TOTTAXAMT1
Affzo [M:PIH1]STA
Return

