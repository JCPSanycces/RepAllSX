#<AdxTL>@(#)0.0.0.0 $Revision$
#PE CPRCAL -> que se llama desde SUBPTHD, pero hace la llamada a una rutina de SUBPTHA. Utilizado para intervenir
#             el calculo del coste de la entrada
# 06.305.573 23/02/2022 ML
$ACTION
Case ACTION
   When "CPRCAL"     :   Gosub CPRCAL
Endcase
Return

#Rutina para intervenir el calculo del coste segun los valores introducidos en la cabecera de la recepcion
$CPRCAL
#If GUSER="ADMIN" Infbox "Depurar CPRCAL   ZPESUBPTHA.src"  Endif
If GFONCTION="GESPTH" or GFONCTION="GESPTH2"
   # 06.305.573.ini
   Local Integer IX
   Local Decimal SUMPRECOM
   Raz IX,SUMPRECOM
   For IX=0 To [M:PTH1]NBLIG-1
     SUMPRECOM=SUMPRECOM+[M:PTH1]CPRPRI(IX)  #  CPRPRI=> Precio coste
   Next
   # 06.305.573.fin
   Gosub CAL_GTOS
   WCPRFLG=2
   [M:PTH1]CPR(NOL)=[M:PTH1]CPRPRI(NOL)-WPRIPUR+(WPRIPUR*[M:PTH1]CPRCOE(NOL)+WCPRAMT)+
&                   [M:PTH1]ZGTOARAUNI(NOL)+[M:PTH1]ZGTONORUNI(NOL)+[M:PTH1]ZGTOEXTUNI(NOL)
   WNEWCPR=[M:PTH1]CPR(NOL)
Endif
Return

$CAL_GTOS
#Local Integer I # 06.305.573
#Local Decimal PRECOMUS, SUMPRECOM, PREMEDUSNOR, PREMEDUSEXT, PORPREMED, TOTNOREXT # 06.305.573
Local Decimal PRECOMUS, PREMEDUSNOR, PREMEDUSEXT, PORPREMED, TOTNOREXT
#Sumatorio precios de compra
# 06.305.573.ini
#SUMPRECOM=0
#For I=0 To [M:PTH1]NBLIG-1
#   #Comentada la siguiente linea porque se basa en los coeficientes del articulo y depende tambien de si la linea esta facturada o no.
#   #Call CALCUL_PRIPUR(I,PRECOMUS) From SUBPTHB
##  SUMPRECOM=SUMPRECOM+[M:PTH1]CSTPUR(I)  #  CSTPUR=> Coste compra unitario. En el momento de CREAR unarecepción, su valor es CERO !!!!
#   SUMPRECOM=SUMPRECOM+[M:PTH1]CPRPRI(I)  #  CPRPRI=> Precio coste
#Next
# 06.305.573.fin
##Total gastos normales y extras
#TOTNOREXT=[M:PTH0]ZGTOSNOR+[M:PTH0]ZGTOSEXT
#
##Gasto normal unitario
#PREMEDUSNOR=0
#If [M:PTH0]ZTOTPESO<>0
#   PREMEDUSNOR=[M:PTH0]ZGTOSNOR/[M:PTH0]ZTOTPESO
#Endif
#
##Gasto extra unitario
#PREMEDUSEXT=0
#If [M:PTH0]ZTOTPESO<>0
#   PREMEDUSEXT=[M:PTH0]ZGTOSEXT/[M:PTH0]ZTOTPESO
#Endif

PORPREMED=0
If SUMPRECOM<>0
   PORPREMED=([M:PTH1]CPRPRI(NOL)*100/SUMPRECOM)
Endif
[M:PTH1]ZGTOARAUNI(NOL)=0
If [M:PTH0]ZPORGTOSARA<>0
   [M:PTH1]ZGTOARAUNI(NOL)=arr([M:PTH1]CPRPRI(NOL)*[M:PTH0]ZPORGTOSARA/100,0.0001)
Endif
Affzo [M:PTH1]ZGTOARAUNI(NOL)
[M:PTH1]ZGTONORUNI(NOL)=0
If [M:PTH0]ZGTOSNOR<>0
   #[M:PTH1]ZGTONORUNI(NOL)=arr(PREMEDUSNOR*PORPREMED/100,0.0001)
   [M:PTH1]ZGTONORUNI(NOL)=arr(([M:PTH0]ZGTOSNOR*PORPREMED/100)/[M:PTH1]QTYSTU(NOL),0.0001)
Endif
Affzo [M:PTH1]ZGTONORUNI(NOL)
[M:PTH1]ZGTOEXTUNI(NOL)=0
If [M:PTH0]ZGTOSEXT<>0
   #[M:PTH1]ZGTOEXTUNI(NOL)=arr(PREMEDUSEXT*PORPREMED/100,0.0001)
   [M:PTH1]ZGTOEXTUNI(NOL)=arr(([M:PTH0]ZGTOSEXT*PORPREMED/100)/[M:PTH1]QTYSTU(NOL),0.0001)
Endif
Affzo [M:PTH1]ZGTOEXTUNI(NOL)
Return
