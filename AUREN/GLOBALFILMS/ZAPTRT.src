#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZASIPED1 (Especifico)
$ACTION
#Infbox GFONCTION - GACTION - ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "OK"           : Gosub OK
 When Default
Endcase
Return


$DEBUT
Local Integer WTEST : WTEST =0
Raz [M:ZAP1]
Raz [M:ZAP0]
If [M:MFG1]ITMREF(WLLIG)<>"" Then
    [M:ZAP0]ZITMREF=[M:MFG1]ITMREF(WLLIG)
    [M:ZAP0]ZITMREFH=[M:MFG1]ITMREF(WLLIG)
    WTEST=1 # PRIMERA BUSQUEDA
Endif
If [M:MFG1]ZANCHO(WLLIG)<>0 Then
    [M:ZAP0]ZANCHOD=[M:MFG1]ZANCHO(WLLIG)
    [M:ZAP0]ZANCHOH=[M:MFG1]ZANCHO(WLLIG)
    WTEST=1
Endif
If [M:MFG1]ZLONGITUD(WLLIG)<>0 Then
    [M:ZAP0]ZLONGD=[M:MFG1]ZLONGITUD(WLLIG)
    [M:ZAP0]ZLONGH=[M:MFG1]ZLONGITUD(WLLIG)
    WTEST=1
Endif
If [M:MFG1]ZMANDRIL(WLLIG)<>0 Then
    [M:ZAP0]ZMANDRILD=[M:MFG1]ZMANDRIL(WLLIG)
    [M:ZAP0]ZMANDRILH=[M:MFG1]ZMANDRIL(WLLIG)
    WTEST=1
Endif
Affzo [M:ZAP1]
Affzo [M:ZAP0]
If WTEST Then
    Gosub BUSCAR
Endif
Return

$OUVRE
Local    Integer    WLLIG   : WLLIG = val(PARAM(1))
If !clalev([F:SOQ])  : Local File SORDERQ [SOQ] : Endif
If !clalev([F:SOH])  : Local File SORDER  [SOH] : Endif
If !clalev ([F:ZMSQ]): Local File ZMFGSOQ [ZMSQ] : Endif
#Infbox num$([M:MFG1]MFGLIN(WLLIG))
Return

$SETBOUT
Return

$BOUTON
Case BOUT
    When "B" :  Gosub BUSCAR
Endcase
Return

$BUSCAR
Local Char WLCRITERIO (250)
Local Integer WLNOL : WLNOL = 0
Local Integer WLI
Local Decimal WLQTYBOBASI, WLQTYBOBASI2
Raz [M:ZAP1]
[M:ZAP1]NBLIG=0
Affzo [M:ZAP1]

WLCRITERIO = " (SOQSTA < 3) & (ZCORTE = 2) "

If [M:ZAP0]ZITMREF <> "" : WLCRITERIO -= "& (ITMREF >= '" + [M:ZAP0]ZITMREF + "')" : Endif
If [M:ZAP0]ZITMREFH <> "" : WLCRITERIO -= "& (ITMREF <= '" + [M:ZAP0]ZITMREFH + "')" : Endif
If [M:ZAP0]ZANCHOD <> 0 : WLCRITERIO -= "& (ZANCHO >= " + num$([M:ZAP0]ZANCHOD) + ")" : Endif
If [M:ZAP0]ZANCHOH <> 0 : WLCRITERIO -= "& (ZANCHO <= " + num$([M:ZAP0]ZANCHOH) + ")" : Endif
If [M:ZAP0]ZLONGD <> 0 : WLCRITERIO -= "& (ZLONGITUD >= " + num$([M:ZAP0]ZLONGD) + ")" : Endif
If [M:ZAP0]ZLONGH <> 0 : WLCRITERIO -= "& (ZLONGITUD <= " + num$([M:ZAP0]ZLONGH) + ")" : Endif
If [M:ZAP0]ZMANDRILD <> 0 : WLCRITERIO -= "& (ZMANDRIL >= " + num$([M:ZAP0]ZMANDRILD) + ")" : Endif
If [M:ZAP0]ZMANDRILH <> 0 : WLCRITERIO -= "& (ZMANDRIL <= " + num$([M:ZAP0]ZMANDRILH) + ")" : Endif

Infbox WLCRITERIO

Filter [F:SOQ]
Filter [F:SOQ] Where  evalue (WLCRITERIO)
For [F:SOQ]
   Read [F:SOH]SOH0 = [F:SOQ]SOHNUM
   If !fstat Then
      # Buscar Cantidad ya asignada en tablas en otras ordenes de produccion
      WLQTYBOBASI=0
      Filter [F:ZMSQ] Where SOHNUM=[F:SOQ]SOHNUM and SOPLIN=[F:SOQ]SOPLIN and SOQSEQ=[F:SOQ]SOQSEQ and MFGNUM<>[M:MFG0]MFGNUM
      For [F:ZMSQ]
        WLQTYBOBASI+=[F:ZMSQ]ZQTYBOBASI
      Next
      Filter [F:ZMSQ]
     # Infbox "HOLA" - num$([M:MFG1]ZNBLP)
       WLQTYBOBASI2=0
      ##  BUSCAR en el cuadro de la mascara la Cantidad ya ASIGNADA a esta linea de producto de la OF en curso y descontar lo de otras lineas
      For WLI=0 To [M:MFG1]ZNBLP - 1
         If [M:MFG1]ZSOHNUM(WLI)=[F:SOQ]SOHNUM and [M:MFG1]ZSOPLIN(WLI)=[F:SOQ]SOPLIN and [M:MFG1]ZSOQSEQ(WLI)=[F:SOQ]SOQSEQ Then

            If [M:MFG1]ZMFGLIN(WLI)=[M:MFG1]MFGLIN(WLLIG) Then
               WLQTYBOBASI2 +=[M:MFG1]ZQTYBOBASI(WLI)
            Endif
            WLQTYBOBASI +=[M:MFG1]ZQTYBOBASI(WLI)
&        Endif
      Next
    #  Infbox "HOLA-2"
      If WLQTYBOBASI<[F:SOQ]ZQTYBOB
         [M:ZAP1]ITMREF(WLNOL)=[F:SOQ]ITMREF
         [M:ZAP1]ZANCHO(WLNOL)=[F:SOQ]ZANCHO
         [M:ZAP1]ZLONGITUD(WLNOL)=[F:SOQ]ZLONGITUD
         [M:ZAP1]ZMANDRIL(WLNOL)=[F:SOQ]ZMANDRIL
         [M:ZAP1]ZQTYBOB(WLNOL)=[F:SOQ]ZQTYBOB-WLQTYBOBASI
         [M:ZAP1]SOHNUM(WLNOL)=[F:SOQ]SOHNUM
         [M:ZAP1]SOPLIN(WLNOL)= [F:SOQ]SOPLIN
         [M:ZAP1]SOQSEQ(WLNOL)=[F:SOQ]SOQSEQ
         [M:ZAP1]ORDDAT(WLNOL)=[F:SOQ]ORDDAT
         [M:ZAP1]BPCNAM(WLNOL)=[F:SOH]BPCNAM
         [M:ZAP1]EXTDLVDAT(WLNOL)=[F:SOQ]EXTDLVDAT
         # Si primera busqueda reconstruimos cantidades ya asignadas en esta OF
         If WTEST=1 Then [M:ZAP1]ZQTYBOBASI(WLNOL)=WLQTYBOBASI2 : Endif
         If [M:ZAP1]ZQTYBOBASI(WLNOL)<>0 Then
           [M:ZAP1]ZSELITM = [M:ZAP1]ITMREF(WLNOL)
           [M:ZAP1]ZSELANCHO = [M:ZAP1]ZANCHO(WLNOL)
           [M:ZAP1]ZSELLONG = [M:ZAP1]ZLONGITUD(WLNOL)
           [M:ZAP1]ZSELMANDRIL = [M:ZAP1]ZMANDRIL(WLNOL)
           [M:ZAP1]ZSELQTYBOB+=[M:ZAP1]ZQTYBOBASI(WLNOL)
         Endif
         WLNOL +=1
       Endif
   Endif
Next
WTEST=0 # Reseteo Primera Busqueda

[M:ZAP1]NBLIG=WLNOL
Affzo [M:ZAP1]10
Return

$APRES_MODIF
Return


$OK
Local Integer WNLPED, WLI
ZGMODPEDASI=1
# Borrar cualquier asignacio previa de pedidos a linea.
Call BORRAR_PEDASI([M:MFG1]MFGLIN(WLLIG)) From SPEMFG
WNLPED=[M:MFG1]ZNBLP
If [M:ZAP1]ZSELITM<>""
   # PARAM(0)=[M:ZAP1]ZSELITM
   [M:MFG1]ITMREF(WLLIG)=[M:ZAP1]ZSELITM
   [M:MFG1]ZANCHO(WLLIG)=[M:ZAP1]ZSELANCHO
   [M:MFG1]ZLONGITUD(WLLIG)=[M:ZAP1]ZSELLONG
   [M:MFG1]ZMANDRIL(WLLIG)=[M:ZAP1]ZSELMANDRIL
   [M:MFG1]ZQTYBOB(WLLIG)=[M:ZAP1]ZSELQTYBOB
   Affzo [M:MFG1]ITMREF(WLLIG)
   Affzo [M:MFG1]ZANCHO(WLLIG)
   Affzo [M:MFG1]ZLONGITUD(WLLIG)
   Affzo [M:MFG1]ZMANDRIL(WLLIG)
   Affzo [M:MFG1]ZQTYBOB(WLLIG)
   [M:MFG1]ZPEDCLI(WLLIG)=2
   # Asigna pedidos seleccionados a mascara de pedidos detalle
  WNLPED=[M:MFG1]ZNBLP
  For WLI = 0 To [M:ZAP1]NBLIG - 1
    If [M:ZAP1]ZQTYBOBASI(WLI)<>0
       [M:MFG1]ZMFGLIN(WNLPED)=[M:MFG1]MFGLIN(WLLIG)
       [M:MFG1]ZSOHNUM(WNLPED)=[M:ZAP1]SOHNUM(WLI)
       [M:MFG1]ZSOPLIN(WNLPED)=[M:ZAP1]SOPLIN(WLI)
       [M:MFG1]ZSOQSEQ(WNLPED)=[M:ZAP1]SOQSEQ(WLI)
       [M:MFG1]ZQTYBOBASI(WNLPED)=[M:ZAP1]ZQTYBOBASI(WLI)
       WNLPED +=1
    Endif
  Next
  [M:MFG1]ZNBLP=WNLPED

Else  # No hay pedidos asignados
   [M:MFG1]ZPEDCLI(WLLIG)=1
Endif
Affzo [M:MFG1]ZPEDCLI(WLLIG)
Affzo [M:MFG1]35
Return




######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASIPED1) 29/12/2015 17:34:41 (ADMIN)
######################################################################################
Subprog C_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign -1

If VALEUR<>0 and VALEUR > [M:ZAP1]ZQTYBOB(NOL)
 mkstat =2
Endif
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZASIPED1) 31/12/2015 12:20:50 (ADMIN)
######################################################################################
Subprog APRES_NBLIG
Local Integer NOL : NOL = nolign -1
Local Shortint WLI

If [M:ZAP1]ZSELITM = "" and [M:ZAP1]ZQTYBOBASI(NOL)<>0
  [M:ZAP1]ZSELITM = [M:ZAP1]ITMREF(NOL)
  [M:ZAP1]ZSELANCHO = [M:ZAP1]ZANCHO(NOL)
  [M:ZAP1]ZSELLONG = [M:ZAP1]ZLONGITUD(NOL)
  [M:ZAP1]ZSELMANDRIL = [M:ZAP1]ZMANDRIL(NOL)
  Affzo [M:ZAP1]5
Endif
[M:ZAP1]ZSELQTYBOB=0
For WLI=0 To [M:ZAP1]NBLIG - 1
   [M:ZAP1]ZSELQTYBOB+=[M:ZAP1]ZQTYBOBASI(WLI)
Next
Affzo [M:ZAP1]ZSELQTYBOB

[M:ZAP1]ZSELQTYBOB=0
For WLI=0 To [M:ZAP1]NBLIG - 1
   [M:ZAP1]ZSELQTYBOB+=[M:ZAP1]ZQTYBOBASI(WLI)
Next
Affzo [M:ZAP1]ZSELQTYBOB
If [M:ZAP1]ZSELQTYBOB=0
  [M:ZAP1]ZSELITM = ""
  [M:ZAP1]ZSELANCHO = 0
  [M:ZAP1]ZSELLONG = 0
  [M:ZAP1]ZSELMANDRIL = 0
  Affzo [M:ZAP1]5
Endif
End

Subprog AS_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign -1
If [M:ZAP1]ZSELITM <> "" & ([M:ZAP1]ZSELITM <> [M:ZAP1]ITMREF(NOL)
& | [M:ZAP1]ZSELANCHO<>[M:ZAP1]ZANCHO(NOL)
& | [M:ZAP1]ZSELLONG<>[M:ZAP1]ZLONGITUD(NOL)
& | [M:ZAP1]ZSELMANDRIL<>[M:ZAP1]ZMANDRIL(NOL)) Then
  mkstat = 2
Endif
End

Subprog AP_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR

End

Subprog AM_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR

End

######################################################################################
