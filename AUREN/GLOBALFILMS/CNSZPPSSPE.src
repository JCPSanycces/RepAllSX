#######################################################################################

$ACTION

#If GUSER="ADMIN" Then : Infbox "CNSZPPSSPE -"-ACTION : Endif
Case ACTION
  When "EXEBOUT"    : Gosub EXEBOUT
  When "LECTURE"    : Gosub LECTURE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$LECTURE
  [M:ZPPS1]CPY='001'
  [M:ZPPS1]CUR='EUR'
  [M:ZPPS1]ZDUDDATFIN=[01/02/2022]
  [M:ZPPS1]ZDUDDATINI=[01/01/2022]
  [M:ZPPS1]ZNUMSEM=12
  Affzo [M:ZPPS1]
Return

##############################################################
$EXEBOUT
  Case BOUT
    When "b" Then : Gosub BUSQUEDA
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$BUSQUEDA
Local Char LWHERE(250)
  Gosub ABRE_TABLAS
  Gosub CARGA_GRID
  Gosub MUESTRA_COLUMNAS
  Gosub NOMBRE_COLUMNA
  Gosub CIERRA_TABLAS
  Affzo [M:ZPPS2]
Return

##############################################################
$ABRE_TABLAS
  If !clalev([F:ZDUD]) Then : Local File GACCDUDATE [F:ZDUD] : Endif
  If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
  If !clalev([F:ZSIV]) Then : Local File SINVOICEV  [F:ZSIV] : Endif
Return

##############################################################
$CIERRA_TABLAS
  Close Local File [ZDUD],[ZBPC],[ZSIV]
Return

##############################################################
$CARGA_GRID
Local Integer I

  LWHERE = "CPY=[M:ZPPS1]CPY & DUDDAT>=[M:ZPPS1]ZDUDDATINI & DUDDAT<=[M:ZPPS1]ZDUDDATFIN & CUR=[M:ZPPS1]CUR & AMTCUR-PAYCUR <> 0"
  Filter [F:ZDUD] Where evalue(LWHERE) Order By DUDDAT Asc
  For [ZDUD]
    Read [F:ZBPC]BPC0     = [F:ZDUD]BPRPAY
    Read [F:ZSIV]SIV0     = [F:ZDUD]NUM
    [M:ZPPS2]CPY(I)       = [F:ZDUD]CPY
    [M:ZPPS2]VCRNUM(I)    = [F:ZDUD]NUM
    [M:ZPPS2]BPCNUM(I)    = [F:ZDUD]BPAPAY
    [M:ZPPS2]BPCNAM(I)    = [F:ZBPC]BPCNAM
    [M:ZPPS2]ORINUM(I)    = [F:ZSIV]PIHNUM
    [M:ZPPS2]ORIDAT(I)    = [F:ZSIV]INVDAT
    [M:ZPPS2]DUDDAT(I)    = [F:ZDUD]DUDDAT
    [M:ZPPS2]PER(I)       = month([F:ZDUD]DUDDAT)
    [M:ZPPS2]CUR(I)       = [F:ZDUD]CUR
    [M:ZPPS2]AMTCUR(I)    = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
#Infbox num$(week([F:ZDUD]DUDDAT))
#Infbox num$(week([M:ZPPS1]ZDUDDATINI))
    Case week([F:ZDUD]DUDDAT) - week([M:ZPPS1]ZDUDDATINI) + 1
      When 1  : [M:ZPPS2]ZSEMANA1(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 2  : [M:ZPPS2]ZSEMANA2(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 3  : [M:ZPPS2]ZSEMANA3(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 4  : [M:ZPPS2]ZSEMANA4(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 5  : [M:ZPPS2]ZSEMANA5(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 6  : [M:ZPPS2]ZSEMANA6(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 7  : [M:ZPPS2]ZSEMANA7(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 8  : [M:ZPPS2]ZSEMANA8(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 9  : [M:ZPPS2]ZSEMANA9(I)  = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 10 : [M:ZPPS2]ZSEMANA10(I) = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 11 : [M:ZPPS2]ZSEMANA11(I) = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
      When 12 : [M:ZPPS2]ZSEMANA12(I) = [F:ZDUD]AMTCUR - [F:ZDUD]PAYCUR
    Endcase
    [M:ZPPS2]NBLIG+=1
    I = [M:ZPPS2]NBLIG
#If I > 2 Then Break Endif
  Next
#  [M:ZPPS2]CPY(0)='001'
#  [M:ZPPS2]VCRNUM(0)='X910-21000007'
#  [M:ZPPS2]BPCNUM(0)='01323'
#  [M:ZPPS2]BPCNAM(0)='MULTISAC EMBALAGENS FLEXIVEIS UNIPE'
#  [M:ZPPS2]ORINUM(0)='X910-21000007'
#  [M:ZPPS2]ORIDAT(0)=[17/11/2022]
#  [M:ZPPS2]DUDDAT(0)=[17/11/2022]
#  [M:ZPPS2]PER(0)=1
#  [M:ZPPS2]CUR(0)='EUR'
#  [M:ZPPS2]AMTCUR(0)=100
#  [M:ZPPS2]ZSEMANA1(0)=1.01
#  [M:ZPPS2]ZSEMANA2(0)=2.01
#  [M:ZPPS2]ZSEMANA3(0)=3.01
#  [M:ZPPS2]ZSEMANA4(0)=4.01
#  [M:ZPPS2]ZSEMANA5(0)=5.01
#  [M:ZPPS2]ZSEMANA6(0)=6.01
#  [M:ZPPS2]ZSEMANA7(0)=7.01
#  [M:ZPPS2]ZSEMANA8(0)=8.01
#  [M:ZPPS2]ZSEMANA9(0)=9.01
#  [M:ZPPS2]ZSEMANA10(0)=10.01
#  [M:ZPPS2]ZSEMANA11(0)=11.01
#  [M:ZPPS2]ZSEMANA12(0)=12.01
#  [M:ZPPS2]NBLIG=1
#  Affzo [M:ZPPS2]
Return

##############################################################
$MUESTRA_COLUMNAS
  Case [M:ZPPS1]ZNUMSEM
    When 1
      Chgfmt [M:ZPPS2]ZSEMANA2  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA3  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA4  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA5  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA6  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"
    When 2
      Chgfmt [M:ZPPS2]ZSEMANA3  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA4  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA5  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA6  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"
    When 3
      Chgfmt [M:ZPPS2]ZSEMANA4  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA5  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA6  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"
    When 4
      Chgfmt [M:ZPPS2]ZSEMANA5  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA6  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"
    When 5
      Chgfmt [M:ZPPS2]ZSEMANA6  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"
    When 6
      Chgfmt [M:ZPPS2]ZSEMANA7  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"
    When 7
      Chgfmt [M:ZPPS2]ZSEMANA8  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA7  With "K:9"
    When 8
      Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA11 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9"
      Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA7  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA8  With "K:9"
    When 9
      Chgfmt [M:ZPPS2]ZSEMANA9  With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA7  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA8  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA9  With "K:9"
    When 10
      Chgfmt [M:ZPPS2]ZSEMANA10 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA7  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA8  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA9  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA10 With "K:9"
    When 11
      Chgfmt [M:ZPPS2]ZSEMANA12 With "-K:9" : Chgfmt [M:ZPPS2]ZSEMANA1  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA2  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA3  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA4  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA5  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA6  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA7  With "K:9"
      Chgfmt [M:ZPPS2]ZSEMANA8  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA9  With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA10 With "K:9"  : Chgfmt [M:ZPPS2]ZSEMANA11 With "K:9"
  Endcase
Return

##############################################################
$NOMBRE_COLUMNA
  Case [M:ZPPS1]ZNUMSEM
    When 1
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)
    When 2
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
    When 3
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)
    When 4
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
    When 5
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA5  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+4,2022)),5)
    When 6
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA5  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+4,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA6  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+5,2022)),5)
    When 7
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA5  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+4,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA6  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+5,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA7  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+6,2022)),5)
    When 8
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA5  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+4,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA6  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+5,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA7  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+6,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA8  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+7,2022)),5)
    When 9
      Chgtzn [M:ZPPS2]ZSEMANA1  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI),2022)),5)    : Chgtzn [M:ZPPS2]ZSEMANA2  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+1,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA3  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+2,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA4  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+3,2022)),5)
      Chgtzn [M:ZPPS2]ZSEMANA5  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+4,2022)),5)  : Chgtzn [M:ZPPS2]ZSEMANA6  With "Semana"-left$(num$(aweek(week([M:ZPPS1]ZDUDDATINI)+5,2022)),5)
