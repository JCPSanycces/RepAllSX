#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para visualizar el resultado de las combinaciones resultante de las selecciones hechas en el envio
#de tarifas
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT_ZVISRESET
 When "OUVRE"    : Gosub OUVRE_ZVISRESET
 When "DEBUT"    : Gosub DEBUT_ZVISRESET
 When "FIN"      : Gosub FIN_ZVISRESET
 When Default
Endcase
Return

$INIT_ZVISRESET
Return

$OUVRE_ZVISRESET
If clalev([F:ZETAR])<=0 : Local File ZETARART    [ZETAR] : Endif
If clalev([F:ITMX])<=0  : Local File ITMMASTER   [ITMX]  : Endif
If clalev([F:ZTACD])<=0 : Local File ZTARCTED    [ZTACD] : Endif
If clalev([F:SPLX])<=0  : Local File SPRICLIST   [SPLX]  : Endif
Return

$DEBUT_ZVISRESET
Raz [M:ZVRET]
Gosub LIRED
Return

$FIN_ZVISRESET
Return

$LIRED
Local   Integer  SNOL
Filter [ZETAR] Order By Key ZETAR0
SNOL=0

For [ZETAR]
   Raz [F:ITMX]
   Read [ITMX]ITM0=[F:ZETAR]ITMREF
   Raz [F:ZTACD]
   Read [ZTACD]ZTACD0=[F:ZETAR]SALFCY;[F:ZETAR]BPCNUM;[F:ZETAR]ITMREF;[F:ZETAR]ZLONGITUD;[F:ZETAR]PLI
   Raz [F:SPLX]
   Filter [SPLX] Where PLICRD=[F:ZTACD]PLICRD and PLI=[F:ZTACD]PLI
   For [SPLX]
      Break
   Next
   Filter [SPLX]
   [M:ZVRET]SALFCY(SNOL)=[F:ZETAR]SALFCY
   [M:ZVRET]BPCNUM(SNOL)=[F:ZETAR]BPCNUM
   [M:ZVRET]ITMREF(SNOL)=[F:ZETAR]ITMREF
   [M:ZVRET]LONGITUD(SNOL)=[F:ZETAR]ZLONGITUD
   [M:ZVRET]PRI(SNOL)=[F:ZETAR]PRI
   [M:ZVRET]CUR(SNOL)=[F:ZTACD]CUR
   [M:ZVRET]UOM(SNOL)=[F:ZTACD]UOM
   [M:ZVRET]PLI(SNOL)=[F:ZETAR]PLI
   [M:ZVRET]PLICRD(SNOL)=[F:SPLX]PLICRD
   [M:ZVRET]PLILIN(SNOL)=[F:SPLX]PLILIN
   SNOL+=1
Next
Filter [ZETAR]
[M:ZVRET]NBLIG=SNOL
Affzo [M:ZVRET]5
Return
