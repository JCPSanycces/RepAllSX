#<AdxTL>@(#)0.0.0.0 $Revision$


#Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1

$ACTION
#If GUSER= "ADMIN" and dim([M:ENT]PECQTY)>0
#  Infbox ACTION + "/"+num$([M:ENT]PECQTY)
#Endif
Case ACTION
When "OUVRE"       : Gosub OUVRE
When "DEBUT"       : Gosub DEBUT
When "SETBOUT"     : Gosub SETBOUT
Endcase
Return

$OUVRE
Local Integer PRIMERA_VEZ    :    PRIMERA_VEZ=1
Local Integer XF             :    XF=nolign-1
Local Char BD_TIPO(1)

Return

$DEBUT
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
#Z0001.ini
If GFONCTION="GESMTK"
  Gosub ACTION From TRTSTOENT
  GPE=1
  If [M:ENT]NBLIG>1
    For IX=0 To [M:ENT]NBLIG-1
      [M:ENT]QTYPCU(IX)=[M:MTK2]UOMCPLQTY(nolign-1)/[M:MTK2]NBSLO(nolign-1)
      If IX = [M:ENT]NBLIG-1
        [M:ENT]QTYPCU(IX)=[M:ENT]QTYTOENT-([M:MTK2]UOMCPLQTY(nolign-1)/[M:MTK2]NBSLO(nolign-1))*([M:MTK2]NBSLO(nolign-1)-1)
      Endif
      [M:ENT]QTYSTU(IX)=[M:ENT]QTYPCU(IX)
      Affzo [M:ENT]QTYPCU(IX)
      Affzo [M:ENT]QTYSTU(IX)
    Next
  Else
    [M:ENT]QTYPCU(0)=[M:ENT]QTYTOENT
    [M:ENT]QTYSTU(0)=[M:ENT]QTYPCU(0)
    Affzo [M:ENT]QTYPCU(0)
    Affzo [M:ENT]QTYSTU(0)
  Endif
  [M:ENT]PECQTY=[M:ENT]QTYTOENT
  Affzo [M:ENT]PECQTY
Endif
#Z0001.fin
#> 69503 - no entra por aquí si se ejecuta desde recepciones
If GFONCTION<>"GESSRH" or GFONC1<>"GESSRH"
    Return
Endif
#< 69503
[M:ENT]COETOENT = [M:SRH1]SAUSTUCOE(XF)
Affzo [M:ENT]COETOENT
####

Return


$SETBOUT
#Return
#> 69503 - no entra por aquí si se ejecuta desde recepciones
#If not PRIMERA_VEZ or GFONCTION<>"GESSRH"
If not PRIMERA_VEZ or GFONCTION<>"GESSRH" or GFONC1<>"GESSRH"
#< 69503
    Return
Endif
PRIMERA_VEZ=0
# 1ş) Borrar filas que fueron devueltas parcialmente
Local Char TXT(255)(10)
Local Integer F,I,LRET
Local Decimal QTY_DEV,ZQTY,ZRST,VALEUR
I=-1
F=[M:ENT]NBLIG-1
While F>=0 and I<F
  I+=1
  Raz TXT,QTY_DEV
  TXT(0)="select sum(QTYPCU_0) "
  TXT(1)="from STOJOU "
  TXT(2)="where VCRTYP_0=13 and ITMREF_0='"+[M:ENT]ITMREF+"' and LOT_0='"+[M:ENT]LOTAFF(I)+"' and SLO_0='"+[M:ENT]SLOAFF(I)+"'"
  For (Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
    QTY_DEV=FBOB
    Break
  Next
  If QTY_DEV<>0
    Gosub BORRAR_LIN
    I-=1
    F=[M:ENT]NBLIG-1
  Endif
Wend

Gosub GESSELECTION From TRTSTOENTB
Affzo [M:ENT]PECQTY
# 2ş) Dejar solo el nş de filas indicado en [M:SRH1]ZQTYBOB(NOL)
F=[M:ENT]NBLIG-[M:SRH1]ZQTYBOB(XF)
If F>0
  For I=1 To F
    Gosub BORRAR_LIN
  Next
  Gosub GESSELECTION From TRTSTOENTB
  Affzo [M:ENT]PECQTY
Endif

###### 69503 ?
[M:ENT]COETOENT = [M:SRH1]SAUSTUCOE(XF)
Affzo [M:ENT]COETOENT
####
[M:ENT]PECQTY = [M:ENT]QTYTOENT  # igualamos las cantidades...
Affzo [M:ENT]PECQTY

# JLPR 14-02-17 Es standar convierte UV(m2) a US(kg) y Coeficiente=1, motivo por el cual pongo las cantidades en Kg
# Pongo la cantidad  repartida entre las bobinas, así como Ancho+Long+Mand UV
If [M:SRH1]SAU(XF)="M2"
#> 69503
  #[M:ENT]PECQTY=arr([M:ENT]PECQTY,0.01)  # Cantidad entregada S/LŞ entrega
  [M:ENT]PECQTY=int([M:ENT]PECQTY)  # Cantidad entregada S/LŞ entrega


#[M:ENT]PECQTY = [M:ENT]QTYTOENT  # igualamos las cantidades...
  Affzo [M:ENT]PECQTY

  ZQTY   =arr([M:ENT]PECQTY/[M:SRH1]ZQTYBOB(XF),0.0001)
  Local Decimal LCOEF
 #> MA - redondeamos a 6 decimales
  #LCOEF = arr([M:SRH1]SAUSTUCOE(XF),0.0001)
  LCOEF = arr([M:SRH1]SAUSTUCOE(XF),0.000001)
  Local Decimal LQTYPCU
 #< MA
  For F=0 To [M:ENT]NBLIG-1
  #  [M:ENT]PCU(F)      =[M:SRH1]SAU(XF)
  #  [M:ENT]PCUSTUCOE(F)=[M:SRH1]SAUSTUCOE(XF)
  #  [M:ENT]ZANCHO(F)   =[M:SRH1]ZANCHO(XF)
  #  [M:ENT]ZMANDRIL(F) =[M:SRH1]ZMANDRIL(XF)
  #  [M:ENT]ZLONGITUD(F)=[M:SRH1]ZLONGITUD(XF)
    [M:ENT]LOC(F)      = [M:SRH1]LOC(XF)
   #> MA - comprobamos cantidades, sobre todo si son devoluciones completas
#    [M:ENT]QTYPCU(F)   = arr(ZQTY*LCOEF, 0.0001)
    LQTYPCU = arr(ZQTY*LCOEF, 0.0001)
    Call GET_ENTQTY([M:SRH1]DETSDHNUM(XF), [M:SRH1]SDDLIN(XF), [M:ENT]ITMREF,      [M:ENT]LOTAFF(F),
&                   [M:ENT]SLOAFF(F),      [M:ENT]ZANCHO(F),   [M:ENT]ZLONGITUD(F),LQTYPCU,          [M:ENT]QTYPCU(F))
   #< MA
    Affzo [M:ENT]QTYPCU(F)
   # FJCP Comentado 28/12/2018 Grizo [M:ENT]QTYPCU(F)

   #> MA - si cantidad US difiere igualamos cantidades
    If [M:ENT]QTYPCU(F) <> [M:ENT]QTYSTU(F) and [M:ENT]PCU(F)="KG" Then
      [M:ENT]QTYSTU(F) = [M:ENT]QTYPCU(F)
      Affzo [M:ENT]QTYSTU(F)
    Endif
   #< MA

#    If [M:ENT]PCUSTUCOE(F)=1 and [M:ENT]PCU(F)<>[M:SRH1]SAU(XF)
#      nolign=F+1
#      If F=0
#        VALEUR=ZQTY+ZRST
#        Call AM_QTYPCU(VALEUR) From TRTSTOENT
#      Else
#        VALEUR=ZQTY
#        Call AM_QTYPCU(VALEUR) From TRTSTOENT
#      Endif
#    Endif
  Next
  Affzo [M:ENT]10
Endif

#> MA - Operativa similar a la de M2
If [M:SRH1]SAU(XF)="KG" Then

  ZQTY   =arr([M:ENT]PECQTY/[M:SRH1]ZQTYBOB(XF),0.0001)
  Local Decimal LCOEF
  LCOEF = arr([M:SRH1]SAUSTUCOE(XF),0.000001)

  For F=0 To [M:ENT]NBLIG-1
    [M:ENT]LOC(F)      = [M:SRH1]LOC(XF)
   #> MA - comprobamos cantidades, sobre todo si son devoluciones completas
#    [M:ENT]QTYPCU(F)   = arr(ZQTY*LCOEF, 0.0001)
    LQTYPCU = arr(ZQTY*LCOEF, 0.0001)
    Call GET_ENTQTY([M:SRH1]DETSDHNUM(XF),  [M:SRH1]SDDLIN(XF), [M:ENT]ITMREF,      [M:ENT]LOTAFF(F),
&                   [M:ENT]SLOAFF(F),       [M:ENT]ZANCHO(F),   [M:ENT]ZLONGITUD(F),LQTYPCU,          [M:ENT]QTYPCU(F))
   #< MA
    Affzo [M:ENT]QTYPCU(F)
    Grizo [M:ENT]QTYPCU(F)

   #> MA - si cantidad US difiere igualamos cantidades
    If [M:ENT]QTYPCU(F) <> [M:ENT]QTYSTU(F) and [M:ENT]PCU(F)="KG" Then
      [M:ENT]QTYSTU(F) = [M:ENT]QTYPCU(F)
      Affzo [M:ENT]QTYSTU(F)
    Endif
  Next
  Affzo [M:ENT]10

Endif

Affzo [M:ENT]10 #70007 - actualizamos pantalla

Return #< 69503

ZQTY  =arr([M:SRH1]QTYSTU(XF)/[M:SRH1]ZQTYBOB(XF),0.0001)
ZRST  =[M:SRH1]QTYSTU(XF)-(ZQTY*[M:SRH1]ZQTYBOB(XF))
For F=0 To [M:ENT]NBLIG-1
#  [M:ENT]PCU(F)      =[M:SRH1]SAU(XF)
#  [M:ENT]PCUSTUCOE(F)=[M:SRH1]SAUSTUCOE(XF)
#  [M:ENT]ZANCHO(F)   =[M:SRH1]ZANCHO(XF)
#  [M:ENT]ZMANDRIL(F) =[M:SRH1]ZMANDRIL(XF)
#  [M:ENT]ZLONGITUD(F)=[M:SRH1]ZLONGITUD(XF)
  [M:ENT]LOC(F)      =[M:SRH1]LOC(XF)
  If [M:ENT]PCUSTUCOE(F)=1 and [M:ENT]PCU(F)<>[M:SRH1]SAU(XF)
    nolign=F+1
    If F=0
      VALEUR=ZQTY+ZRST
      Call AM_QTYPCU(VALEUR) From TRTSTOENT
    Else
      VALEUR=ZQTY
      Call AM_QTYPCU(VALEUR) From TRTSTOENT
    Endif
  Endif
Next
Affzo [M:ENT]10
Return


$BORRAR_LIN
# Código copiado de TRTSTOENT.src    C_NBLIG     If find(status,68,83)
If dim([M:ENT]LOC)>0
    Call STKDELRES([M:ENT]WLOCSEQ(I), [M:ENT]STOFCY, [M:ENT]LOC(I), LRET) From STKLOC
Endif
[M:ENT]QTYSTU (I) = 0
Dela I,1,[M:ENT]NBLIG-1 [M:ENT]NBLIG : [M:ENT]NBLIG-=1
Return

#**
#* comprueba que la cantidad calculada en el caso de ser una bobina completa no supere la cantidad entregada
#*
#* @param PSDHNUM número entrega
#* @param PSDHLIN línea entrega
#* @param PITM artículo
#* @param PLOT lote línea
#* @param PSUBLOT sublote línea
#* @param PANC ancho de la línea
#* @param PLON longitud de la línea
#* @param PQTYCAL cantidad calculada previamente
#* @param PQTYFIN resultado cantidad a aplicar
#*!
Subprog GET_ENTQTY(PSDHNUM,PSDHLIN,PITM,PLOT,PSUBLOT,PANC,PLON,PQTYCAL,PQTYFIN)
Variable  Decimal PQTYFIN
Value     Char    PSDHNUM
Value     Integer PSDHLIN
Value     Char    PITM
Value     Char    PLOT
Value     Char    PSUBLOT
Value     Integer PANC
Value     Integer PLON
Value     Decimal PQTYCAL

If !clalev([J0]) : Local File STOJOU [J0] : Endif

PQTYFIN = PQTYCAL  # por defecto dejamos la cantidad calculada

# busca la entrega a la que hace referencia para no superar cantidades
Filter [J0] Where [J0]VCRTYP=4 and [J0]VCRNUM=PSDHNUM and [J0]VCRLIN=PSDHLIN and [J0]ITMREF=PITM and
&                 [J0]LOT=PLOT and [J0]SLO=PSUBLOT
  Read [J0] First
  If !fstat Then
    # si es una devolución completa, revisamos que la cantidad calculada no supere la cantidad entregada
    If [J0]ZANCHO=PANC and [J0]ZLONGITUD=PLON Then

      # la cantidad calculada no puede superar la cantidad entregada
      If PQTYCAL <> (-1*[J0]QTYSTU) Then
        PQTYFIN = -1*[J0]QTYSTU
      Endif

    Endif
  Endif
Filter [J0]

Close Local File [J0]

End
