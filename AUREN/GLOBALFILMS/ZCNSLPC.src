#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento de consulta de lineas de pedidos de compra
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "TITRE"        : Gosub TITRE_S
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$TITRE_S
TIT="Consulta lineas pedidos compra << EN PRUEBAS # PDTE.VALIDAR >>"
Return

$OUVRE
If !clalev([F:POH])    : Local File PORDER     [POH] : Endif
If !clalev([F:POP])    : Local File PORDERP    [POP] : Endif
If !clalev([F:POQ])    : Local File PORDERQ    [POQ] : Endif
If !clalev([F:ITM])    : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITP])    : Local File ITMBPS     [ITP] : Endif
If !clalev([F:BPS])    : Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:BPC])    : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:SOH])    : Local File SORDER     [SOH] : Endif
If !clalev([F:SOP])    : Local File SORDERP    [SOP] : Endif
If !clalev([F:SOQ])    : Local File SORDERQ    [SOQ] : Endif
If !clalev([F:MFM])    : Local File MFGMAT     [MFM] : Endif
If !clalev([F:ZCNTR])  : Local File ZCONTAINH  [ZCNTR]  : Endif
If !clalev([F:ZCNTRP]) : Local File ZCONTAINP  [ZCNTRP] : Endif
If !clalev([F:ZCNTRS]) : Local File ZCONTAINS  [ZCNTRS] : Endif
If !clalev([F:ZCNTRM]) : Local File ZCONTAINM  [ZCNTRM] : Endif
# Tope de filas en rejilla
Local Integer TFILAS
TFILAS=func ZCOMUN.FILAS_GRID("ZCNSLPC","NBLIG")
# Para llevar un control de si contenedor incluye pedido venta u OF
Local Integer UT_OK
Return

$DEBUT
Raz [M:ZCLPC]
[M:ZCLPC]STOFCYSTR=GFCYDEF(0)
[M:ZCLPC]SITCNTRSTR=1
[M:ZCLPC]SITCNTREND=8
Affzo [M:ZCLPC]STOFCYSTR
Affzo [M:ZCLPC]SITCNTRSTR
Affzo [M:ZCLPC]SITCNTREND
Chgfmt [M:ZCLPC]NADA1 With "-"
Chgfmt [M:ZCLPC]NADA2 With "-"
Chgfmt [M:ZCLPC]NADA3 With "-"
Return

$SETBOUT
If [M:ZCLPC]NBLIG=0
    #Call VIREBOUT(CHMEN,"2") From GOBJET
Else
  Call MOSTRAR_COLOR
Endif
Return

$BOUTON
Local Integer LRET
Case BOUT
    When "1" :  Gosub CARGAR
Endcase
Return

$APRES_MODIF
#If COUZON="ANCHOSTR"
#   [M:ZCLPC]ANCHOSTR=val(CZ)
#   Gosub CARGAR
#Endif
#If COUZON="FECLLESTR"
#   #[M:ZCLPC]FECLLESTR=gdat$(val(seg$(CZ,1,2)),val(seg$(CZ,4,5)),val(seg$(CZ,7,10)))
#   [M:ZCLPC]FECLLESTR=gdat$(val(seg$(CZ,7,8)),val(seg$(CZ,5,6)),val(seg$(CZ,1,4)))
#   Gosub CARGAR
#Endif
Call VACIAR_REJILLA
Return

$CARGAR
Local Decimal LBOBASI
Local Decimal LVOLUMEN
Local Char CRITERIO(250),RCTN(GLONVCR)

Effzo [M:ZCLPC]10
CRITERIO='1=1'
If [M:ZCLPC]STOFCYSTR<>''
   CRITERIO+=' & [POQ]PRHFCY="'+[M:ZCLPC]STOFCYSTR+'"'
Endif
If [M:ZCLPC]POHNUMSTR<>''
   CRITERIO+=' & [POQ]POHNUM>="'+[M:ZCLPC]POHNUMSTR+'"'
Endif
If [M:ZCLPC]POHNUMEND<>''
   CRITERIO+=' & [POQ]POHNUM<="'+[M:ZCLPC]POHNUMEND+'"'
Endif
If [M:ZCLPC]BPSSTR<>''
   CRITERIO+=' & [POQ]BPSNUM>="'+[M:ZCLPC]BPSSTR+'"'
Endif
If [M:ZCLPC]BPSEND<>''
   CRITERIO+=' & [POQ]BPSNUM<="'+[M:ZCLPC]BPSEND+'"'
Endif
If [M:ZCLPC]ITMREFSTR<>''
   CRITERIO+=' & [POQ]ITMREF>="'+[M:ZCLPC]ITMREFSTR+'"'
Endif
If [M:ZCLPC]ITMREFEND<>''
   CRITERIO+=' & [POQ]ITMREF<="'+[M:ZCLPC]ITMREFEND+'"'
Endif
If [M:ZCLPC]ANCHOSTR<>0
   CRITERIO+=' & [POQ]ZANCHO>='+num$([M:ZCLPC]ANCHOSTR)
Endif
If [M:ZCLPC]ANCHOEND<>0
   CRITERIO+=' & [POQ]ZANCHO<='+num$([M:ZCLPC]ANCHOEND)
Endif
If [M:ZCLPC]FECLLESTR<>[00/00/0000]
   CRITERIO+=' & [F:ZCNTR]FECLLEDES>=['+format$(GFMD,[M:ZCLPC]FECLLESTR)+']'
Endif
If [M:ZCLPC]FECLLEEND<>[00/00/0000]
   CRITERIO+=' & [F:ZCNTR]FECLLEDES<=['+format$(GFMD,[M:ZCLPC]FECLLEEND)+']'
Endif
If [M:ZCLPC]MATRICULA<>''
   CRITERIO+=' & [F:ZCNTR]MATRICULA="'+[M:ZCLPC]MATRICULA+'"'
Endif
If [M:ZCLPC]FNUMCNTR<>''
   CRITERIO+=' & [F:ZCNTR]NUMCNTR="'+[M:ZCLPC]FNUMCNTR+'"'
Endif
CRITERIO+=' & [F:ZCNTR]SITCNTR>='+num$([M:ZCLPC]SITCNTRSTR)+' & [F:ZCNTR]SITCNTR<='+num$([M:ZCLPC]SITCNTREND)

#CRITERIO+='& [F:ZCNTR]SITCNTR<9'

Link [POH] With [POQ]POQ0(1)=[POH]POHNUM, [ZCNTRP]ZCNTRP2=[POQ]POHNUM;[POQ]POPLIN,
&               [ZCNTR]ZCNTR0=[ZCNTRP]NUMCNTR As [LNK]

#Infbox num$([M:ZCLPC]FECLLESTR)+" "+CRITERIO

Filter [LNK] Where evalue(CRITERIO)

nolign=0

Raz RCTN

For [LNK]

   #Saber si se incluye pedido venta u OF solicitado
   If [M:ZCLPC]FPED="" and [M:ZCLPC]FOF=""
      UT_OK=1
   Elsif RCTN<>[F:ZCNTRP]NUMCNTR
      RCTN=[F:ZCNTRP]NUMCNTR
      UT_OK=0
      If [M:ZCLPC]FPED<>"" and not UT_OK
        Filter [ZCNTRS] Where NUMCNTR=RCTN
        For [ZCNTRS]
           If [M:ZCLPC]FPED="" or [M:ZCLPC]FPED=[F:ZCNTRS]SOHNUM
              UT_OK=1
           Endif
        Next
        Filter [ZCNTRS]
      Endif
      If [M:ZCLPC]FOF<>"" and not UT_OK
        Filter [ZCNTRM] Where NUMCNTR=RCTN
        For [ZCNTRM]
           If [M:ZCLPC]FOF="" or [M:ZCLPC]FOF=[F:ZCNTRM]MFGNUM
              UT_OK=1
           Endif
        Next
        Filter [ZCNTRM]
      Endif
   Endif

   If UT_OK
     #Calculamos el numero de bobinas asignadas de la linea de pedido de compra
     LBOBASI=0
     Filter [ZCNTRS] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
     For [ZCNTRS]
         LBOBASI+=[F:ZCNTRS]BOBASI
     Next
     Filter [ZCNTRS]

     Filter [ZCNTRM] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
     For [ZCNTRM]
         LBOBASI+=[F:ZCNTRM]BOBASI
     Next
     Filter [ZCNTRM]

     #Recuperamos los datos a mostrar de la linea de pedido de compra
     Filter [ZCNTRP] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
     For [ZCNTRP]
        [M:ZCLPC]NUMCNTR(nolign)  =[F:ZCNTRP]NUMCNTR
        Break
     Next
     Filter [ZCNTRP]

     Raz [F:POP]
     Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
     Raz [F:ITP]
     Read [ITP]ITP0=[F:POQ]ITMREF;[F:POH]BPSNUM
     Raz [F:BPS]
     Read [BPS]BPS0=[F:POH]BPSNUM
     [M:ZCLPC]SITCNTR(nolign)   =[F:ZCNTR]SITCNTR
     [M:ZCLPC]FECLLEDES(nolign) =[F:ZCNTR]FECLLEDES
     [M:ZCLPC]FECLLEPUE(nolign) =[F:ZCNTR]FECLLEPUE
     [M:ZCLPC]FECPRELLE(nolign) =[F:ZCNTR]FECPRELLE
     [M:ZCLPC]FECHABL(nolign)   =[F:ZCNTR]FECHABL
     [M:ZCLPC]MATRICU(nolign)   =[F:ZCNTR]MATRICULA
     [M:ZCLPC]POHNUM(nolign)    =[F:POQ]POHNUM
     [M:ZCLPC]POPLIN(nolign)    =[F:POQ]POPLIN
     [M:ZCLPC]ITMREF(nolign)    =[F:POQ]ITMREF
     [M:ZCLPC]ANCHO(nolign)     =[F:POQ]ZANCHO
     [M:ZCLPC]MANDRIL(nolign)   =[F:POQ]ZMANDRIL
     [M:ZCLPC]LONGITUD(nolign)  =[F:POQ]ZLONGITUD
     [M:ZCLPC]ITMDES1(nolign)   =[F:POP]ITMDES1
     [M:ZCLPC]BOBPEDC(nolign)   =[F:POQ]ZQTYBOB
     [M:ZCLPC]BOBASI(nolign)    =LBOBASI
     [M:ZCLPC]BOBDIS(nolign)    =[F:POQ]ZQTYBOB-LBOBASI
     [M:ZCLPC]BPSNUM(nolign)    =[F:POH]BPSNUM
     [M:ZCLPC]BPSNAM(nolign)    =[F:BPS]BPSNAM
     [M:ZCLPC]OCNNUM(nolign)    =[F:POH]OCNNUM
     Raz [F:ITM]
     Read [ITM]ITM0=[F:POQ]ITMREF
     [M:ZCLPC]QTYPED(nolign)   +=[F:POQ]QTYSTU
     If [F:POQ]PUU="M2"
        [M:ZCLPC]QTYPEDM2(nolign)+=[F:POQ]QTYPUU
     Endif
     If [F:POQ]PUU="KG"
        If [F:ITM]ZFACTOR<>0
           [M:ZCLPC]QTYPEDM2(nolign)+=arr([F:POQ]QTYPUU/[F:ITM]ZFACTOR,0.001)
        Endif
     Endif
     nolign+=1
  #  JLPR 03-02-17 Comento y ańado lineas
  #   If nolign>=799
  #      Break
  #   Endif
     If func TOPE_FILAS(TFILAS)
      Break
     Endif
  #  JLPR 03-02-17 Comento y ańado lineas


     #Recuperamos los datos a mostrar de las lineas de los pedidos de venta asignados a la linea de compra
     Filter [ZCNTRS] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
     LBOBASI=0
     For [ZCNTRS]
        [M:ZCLPC]BPSNUM(nolign) =[F:POH]BPSNUM
        #Infbox [F:POQ]POHNUM+" "+num$([F:POQ]POPLIN)+" "+[F:ZCNTRS]SOHNUM+" "+num$([F:ZCNTRS]SOPLIN)
        Raz [SOH]
        Read [SOH]SOH0=[F:ZCNTRS]SOHNUM
        Raz [F:BPC]
        Read [BPC]BPC0=[F:SOH]BPCORD
        [M:ZCLPC]SITCNTR(nolign) =[F:ZCNTR]SITCNTR
        [M:ZCLPC]POPLIN(nolign)  =[F:POQ]POPLIN
        [M:ZCLPC]ITMREF(nolign)  =[F:POQ]ITMREF
        [M:ZCLPC]ANCHO(nolign)   =[F:POQ]ZANCHO
        [M:ZCLPC]MANDRIL(nolign) =[F:POQ]ZMANDRIL
        [M:ZCLPC]LONGITUD(nolign) =[F:POQ]ZLONGITUD
        [M:ZCLPC]ITMDES1(nolign) =[F:POP]ITMDES1
        Raz [F:SOQ]
        Read [SOQ]SOQ0(2)=[F:ZCNTRS]SOHNUM;[F:ZCNTRS]SOPLIN
        [M:ZCLPC]SOHNUM(nolign) =[F:ZCNTRS]SOHNUM
        [M:ZCLPC]SOPLIN(nolign) =[F:ZCNTRS]SOPLIN
        [M:ZCLPC]BOBPEDV(nolign)=[F:SOQ]ZQTYBOB
        [M:ZCLPC]BPCNUM(nolign) =[F:SOH]BPCORD
        [M:ZCLPC]BPCNAM(nolign) =[F:BPC]BPCNAM
        nolign+=1
     Next
     Filter [ZCNTRS]
  #  JLPR 03-02-17 Comento y ańado lineas
  #  If nolign>=799
  #     Break
  #  Endif
     If func TOPE_FILAS(TFILAS)
      Break
     Endif
  #  JLPR 03-02-17 Comento y ańado lineas

    #Infbox [F:POQ]POHNUM+" "+num$([F:POQ]POPLIN)+" "+num$(nolign)

     #Recuperamos los datos a mostrar de las lineas de las OF asignadas a la linea de compra
     Filter [ZCNTRM] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
     LBOBASI=0
     For [ZCNTRM]
        [M:ZCLPC]SITCNTR(nolign) =[F:ZCNTR]SITCNTR
        [M:ZCLPC]BPSNUM(nolign)  =[F:POH]BPSNUM
        #Infbox [F:POQ]POHNUM+" "+num$([F:POQ]POPLIN)+" "+[F:ZCNTRM]MFGNUM+" "+num$([F:ZCNTRM]MFGLIN)
        [M:ZCLPC]POPLIN(nolign)  =[F:POQ]POPLIN
        [M:ZCLPC]ITMREF(nolign)  =[F:POQ]ITMREF
        [M:ZCLPC]ANCHO(nolign)   =[F:POQ]ZANCHO
        [M:ZCLPC]MANDRIL(nolign) =[F:POQ]ZMANDRIL
        [M:ZCLPC]LONGITUD(nolign)=[F:POQ]ZLONGITUD
        [M:ZCLPC]ITMDES1(nolign) =[F:POP]ITMDES1
        Raz [MFM]
        Read [MFM]MFM0(2)=[F:ZCNTRM]MFGNUM;[F:ZCNTRM]MFGLIN
        [M:ZCLPC]MFGNUM(nolign)  =[F:ZCNTRM]MFGNUM
        #[M:ZCLPC]MFGLIN(nolign) =[F:ZCNTRM]MFGLIN
        [M:ZCLPC]BOBOF(nolign)   =[F:ZCNTRM]BOBASI
        nolign+=1
     Next
     Filter [ZCNTRM]
  #  JLPR 03-02-17 Comento y ańado lineas
  #  If nolign>=799
  #     Break
  #  Endif
     If func TOPE_FILAS(TFILAS)
        Break
     Endif
  #  JLPR 03-02-17 Comento y ańado lineas
  Endif
Next
[M:ZCLPC]NBLIG=nolign

Gosub CALCULAR_TOTALES

If [M:ZCLPC]NBLIG>0
   Affzo [M:ZCLPC]10
Endif
Return

$CALCULAR_TOTALES
Local Integer FILAS
Local Integer WCONT
###############################################################
#pcolor = GCOUL(3)
#Chgstl [M:ZSFC2]NBLIG(nolign-1) With "BACKRED"
WCONT = nolign
[M:ZCLPC]POHNUM(WCONT) = "***"
[M:ZCLPC]SITCNTR(WCONT) = 10
#[M:ZCO3]FCYSHO(nolign-1) = toupper(mess(142,124,1))
For FILAS=0 To WCONT-1
   [M:ZCLPC]BOBPEDC(WCONT) =[M:ZCLPC]BOBPEDC(WCONT)  + [M:ZCLPC]BOBPEDC(FILAS)
   [M:ZCLPC]BOBASI(WCONT)  =[M:ZCLPC]BOBASI(WCONT)   + [M:ZCLPC]BOBASI(FILAS)
   [M:ZCLPC]BOBDIS(WCONT)  =[M:ZCLPC]BOBDIS(WCONT)   + [M:ZCLPC]BOBDIS(FILAS)
   [M:ZCLPC]QTYPED(WCONT)  =[M:ZCLPC]QTYPED(WCONT)   + [M:ZCLPC]QTYPED(FILAS)
   [M:ZCLPC]QTYPEDM2(WCONT)=[M:ZCLPC]QTYPEDM2(WCONT) + [M:ZCLPC]QTYPEDM2(FILAS)
   [M:ZCLPC]BOBPEDV(WCONT) =[M:ZCLPC]BOBPEDV(WCONT)  + [F:SOQ]ZQTYBOB
Next
nolign+=1
[M:ZCLPC]NBLIG += 1
Return

Subprog MOSTRAR_COLOR
Local Integer F
For F=0 To [M:ZCLPC]NBLIG-1
  If [M:ZCLPC]MFGNUM(F) =[M:ZCLPC]FOF and [M:ZCLPC]FOF<>""
    Chgstl [M:ZCLPC]NBLIG(F) With "BACKYELLOW"
  Endif
  If [M:ZCLPC]SOHNUM(F)=[M:ZCLPC]FPED and [M:ZCLPC]FPED<>""
    Chgstl [M:ZCLPC]NBLIG(F) With "BACKGREEN"
  Endif
  # Comprobar que existe pedido
  If [M:ZCLPC]SOHNUM(F)<>""
    Read [SOQ]SOQ0(2)=[M:ZCLPC]SOHNUM(F);[M:ZCLPC]SOPLIN(F)
    If fstat<>0
      If [M:ZCLPC]SOHNUM=""
        Chgstl [M:ZCLPC]NBLIG(F) With "BACKRED"
      Else
        Chgstl [M:ZCLPC]POHNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]OCNNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]SOHNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]SOPLIN(F) With "BACKRED"
        Chgstl [M:ZCLPC]BOBPEDV(F)With "BACKRED"
        Chgstl [M:ZCLPC]BPCNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]BPCNAM(F) With "BACKRED"
      Endif
    Endif
  Endif
  # Comprobar que existe OF
  If [M:ZCLPC]MFGNUM(F)<>""
    Filter [MFM] Where MFGNUM =[M:ZCLPC]MFGNUM(F)
    If rowcount([MFM])<1
      If [M:ZCLPC]FOF=""
        Chgstl [M:ZCLPC]NBLIG(F) With "BACKRED"
      Else
        Chgstl [M:ZCLPC]POHNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]OCNNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]MFGNUM(F) With "BACKRED"
        Chgstl [M:ZCLPC]BOBOF(F)  With "BACKRED"
      Endif
    Endif
    Filter [MFM]
  Endif
Next
End

Funprog TOPE_FILAS(TF)
Value Integer TF
Local Integer TOPE
TOPE=0
If nolign>=TF-1
    MSG="Alcanzado máximo de " + num$(TF) + " filas para consulta\.\Ajuste los filtros"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    TOPE=1
Endif
End TOPE

Subprog VACIAR_REJILLA
Raz [M:ZCLPC]NBLIG
Effzo [M:ZCLPC]10
End
