#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "OUVRE"         : Gosub OUVRE
When "FILTRE"        : Gosub FILTRE
When "DEFLIG"        : Gosub DEFLIG
When "LIENS"         : Gosub LIENS
When "LIENS_LIG"     : Gosub LIENS_LIG
When "INICRE_LIG"    : Gosub INICRE_LIG
When "INIMOD_LIG"    : Gosub INIMOD_LIG
When "VALLIG"        : Gosub VALLIG
When "CREATION"      : Gosub CREATION
When "ANNULE"        : Gosub ANNULE
When "MODIF"         : Gosub MODIF
When "APRES_MOD"     : Gosub APRES_MOD
When "APRES_CRE"     : Gosub APRES_CRE


When "TITRE"         : Gosub TITRE_S
When "AFFMASK"       : Gosub AFFMASK
When "EFFMASK"       : Gosub EFFMASK
When "SETBOUT"       : Gosub SETBOUT
When "FERME"         : Gosub FERME
When "APRES_MODIF"   : Gosub APRES_MODIF
When "APRES_CHOI"    : Gosub APRES_CHOI
#Acciones control flujo CREACION     RAZCRE + VERIF_CRE + INICRE + CREATION + APRES_CRE + AB_CREATION
When "RAZCRE"        : Gosub RAZCRE
When "VERIF_CRE"     : Gosub VERIF_CRE
When "INICRE"        : Gosub INICRE
#Acciones control flujo MODIFICACION   LIENS + STYLE + AVANT_MOD + VERIF_MOD + AVANT_MOFIC + INIMOD + MODIF + APRES_MODIF + AB_MODIF
When "STYLE":        : Gosub STYLE
When "INIMOD":       : Gosub INIMOD
#Accion tras hacer click en un boton predefinido
When "EXEACT"        : Gosub EXEACT
#Accion tras hacer click en un boton ańadido
When "EXEBOUT"       : Gosub EXEBOUT
Endcase
Return


$OUVRE
Local  Char    MSG(255)
Local  Integer ZCOLOREAR
Global Integer GZFLG
########################################
## PARAMETROS    son de tipo CHAR     ##
##      nombre parametro máximo 10    ##
########################################
#Local Char WPARAM(255)
##Cliente para facturas TPV
#Local Char CTEFRASTPV(GLONBPR)
#Call PARAM("","ZCTEFRASTP",CTEFRASTPV) From ADOVAL
#Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
#CTEFRASTPV=WPARAM
#
Gosub DECLARE From TABLEAUX
Return

$FILTRE
Default File [ZTVH]
Return

$DEFLIG
Default Mask [ZGTAR1]
Default File [ZTVD]
CRIT   = '[F:ZTVD]ZREVISION='+num$([M:ZGTAR0]ZREVISION)
FICLIG = "ZGTARVD"
ABLIG  = "ZTVD"
ZONLIG = "NUMLIN"
Return

$LIENS
#Call VACIAR_REJILLA2
Local Integer LIN_CERR,LIN
Call ESTADO
Case [M:ZGTAR0]ZTIPO
When 1
  Call ITM_DATOS([M:ZGTAR0]ZITMREF,[M:ZGTAR0]FCY,0) From SPEZGTAR0
  LIN_CERR=func SPEZGTAR0.LINEAS_GENERADAS(LIN)
  If LIN_CERR>0
    Grizo [M:ZGTAR0]ZBASE
  Else
    Actzo [M:ZGTAR0]ZBASE
  Endif
When 2
  If func SPEZGTAR0.TAR_DATOS([M:ZGTAR0]PLI)
  Endif
  Call CARGAR_REJILLA_TIPO_CTE([M:ZGTAR0]ZREVISION) From SPEZGTAR0
Endcase
Affzo [M:ZGTAR0]PLI
#Imposible modificar
Grizo [M:ZGTAR0]ZTIPO
Grizo [M:ZGTAR0]ZITMREF
Grizo [M:ZGTAR0]PLI
Grizo [M:ZGTAR0]FCY
If [M:ZGTAR0]CERRADO=2
  Grizo [M:ZGTAR0]CERRADO
Else
  Actzo [M:ZGTAR0]CERRADO
Endif

Gosub LIENS From TABLEAUX
Affzo [M:ZGTAR1]5
Return

$LIENS_LIG
#Gosub LIENS From TABLEAUX
#Infbox "LIENS_LIG   [M:ZGTAR1]PRECNUEV(nolign-1)="+num$([M:ZGTAR1]PRECNUEV(nolign-1)) + "   [F:ZTVD]PRECNUEV="+num$([F:ZTVD]PRECNUEV)
Call CALCULAR(nolign-1) From SPEZGTAR0
Return

$INIMOD_LIG
#Gosub MODIF From TABLEAUX
#Infbox "INIMOD_LIG   [M:ZGTAR1]PRECNUEV(nolign-1)="+num$([M:ZGTAR1]PRECNUEV(nolign-1))
#Infbox "INIMOD_LIG   [M:ZGTAR1]UPDFLG(nolign-1)="+num$([M:ZGTAR1]UPDFLG(nolign-1))
#Infbox "INIMOD_LIG   [M:ZGTAR1]CREFLG(nolign-1)="+num$([M:ZGTAR1]CREFLG(nolign-1))
Gosub INI_LIG
Return

$INICRE_LIG
#Gosub CREATION From TABLEAUX
#Infbox "INICRE_LIG   [M:ZGTAR1]UPDFLG(nolign-1)="+num$([M:ZGTAR1]UPDFLG(nolign-1))
#Infbox "INICRE_LIG   [M:ZGTAR1]CREFLG(nolign-1)="+num$([M:ZGTAR1]CREFLG(nolign-1))
Gosub INI_LIG
Return

$INI_LIG
[F:ZTVD]ZREVISION = [M:ZGTAR0]ZREVISION
Return


$CREATION
#Infbox "CREATION   [M:ZGTAR0]ZITMREF="+[M:ZGTAR0]ZITMREF
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
Return


$VALLIG
Return

$ANNULE
Gosub ANNULE From TABLEAUX
If GOK < 1 : Return : Endif
Return

$MODIF
Gosub MODIF From TABLEAUX
If GOK < 1 : Return : Endif
Call GRABAR_RESTO From SPEZGTAR0
Return

$APRES_MOD
Gosub LIENS From TABLEAUX
Return

$APRES_CRE
#Infbox "APRES_CRE  [M:ZGTAR0]ZITMREF="+[M:ZGTAR0]ZITMREF
Gosub LIENS From TABLEAUX
If GOK < 1 : Return : Endif
Call GRABAR_RESTO From SPEZGTAR0
Gosub RELIT From GOBJSUB
Return





$TITRE_S
TIT="REVISAR TARIFAS VENTA"# <<EN PRUEBAS # PDTE.VALIDAR>>"
Return

$APRES_CHOI
#Infbox "APRES_CHOI   REPONSE="+num$(REPONSE)
#If REPONSE=GSTALFT Call VACIAR_REJILLA2 Endif
#Call VACIAR_REJILLA2
#Affzo [M:ZGTAR2]5
Return

$VERIF_CRE
#Comprobaciones
Raz MSG
#If [M:ZGTAR0]FCY=""
#  MSG+="Debe indicar una planta\"
#Endif
If [M:ZGTAR0]ZFECHA=[0/0/0]
  MSG+="Debe indicar una fecha cálculo\"
Endif
If  [M:ZGTAR1]NBLIG<=0
  MSG+="No hay lineas para cálculo\"
Endif
If MSG<>""
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  OK=0
  Return
Endif
Return

$SETBOUT
#Call ESTADO
# BOTONES, ańadidos a la derecha.    Por defecto SI habilitados
# MENUS  , ańadidos a la derecha.    Por defecto NO habilitados
#No hay pedidos seleccionados
If [M:ZGTAR0]CERRADO=2 or (GREP="C" or GREP="D" or GREP="M")
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
#
If ZCOLOREAR
  Raz ZCOLOREAR
  Call COLORES(1) From SPEZGTAR0
Endif
If GZFLG=1
  Raz GZFLG
  mkstat=4
#  REPONSE=92   # 91 New/Crear
#  Gosub REPONSE From GOBJSUB
Endif
Return

$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
#
#If maskcou="ZGTAR0" and ( COUZON="ZPOR" or COUZON="ZFIJO")
#  Call COLORES(0) From SPEZGTAR0
#Endif
Return

$STYLE
Call CARGAR_TARIFAS_ITM_RESTO([M:ZGTAR0]ZITMREF)  From SPEZGTAR0
#
Call COLORES(1) From SPEZGTAR0
#Affzo [M:ZGTAR0]LAVISO
Return

$EXEBOUT
Case BOUT
When "1"
  Call GENERAR From SPEZGTAR0
  #Refrescar registro en pantalla
  Gosub RELIT From GOBJSUB

When "2":  Call CERRAR  From SPEZGTAR0
Endcase
Return

$EXEACT
Return

$RAZCRE
#Sacar el siguiente nş
Local Char TXT(255)(10)
#
[M:ZGTAR0]ZREVISION=1
TXT(0)="select max(ZREVISION_0) from ZGTARVH"
For (Decimal FULT) From GFLDCHR(0) Sql TXT As [MYT]
  [M:ZGTAR0]ZREVISION=[MYT]FULT+1
Next
#
TXT(0)="select max(ZFECHA_0) from ZGTARVH where CERRADO_0<>2"
For (Date FULT) From GFLDCHR(0) Sql TXT As [MYT]
  [M:ZGTAR0]ZFECHA=[MYT]FULT
Next
#
Raz [M:ZGTAR0]FCY
Affzo [M:ZGTAR0]ZREVISION
Affzo [M:ZGTAR0]ZFECHA
Affzo [M:ZGTAR0]FCY
Affzo [M:ZGTAR0]ZTIPO
Grizo [M:ZGTAR0]CERRADO
Affzo [M:ZGTAR0]LAVISO
Return

$INICRE
#Call NUMERO (GCPT,[M:ZGTAR0]FCY,[F:SOH]ORDDAT,"",GNUM,STAT) From SUBANM
#If GOK<0 Return Endif
#Infbox "INICRE  [M:ZGTAR0]ZITMREF="+[M:ZGTAR0]ZITMREF
[F:ZTVH]ZREVISION = [M:ZGTAR0]ZREVISION
[F:ZTVH]ZITMREF   = [M:ZGTAR0]ZITMREF
[F:ZTVH]PLI       = [M:ZGTAR0]PLI
Return

$INIMOD
[F:ZTVH]ZITMREF   = [M:ZGTAR0]ZITMREF
[F:ZTVH]PLI       = [M:ZGTAR0]PLI
Return


$AFFMASK
# Valores por defecto
GZFLG=0
[M:ZGTAR0]ZTIPO=1
# Guardo valores
Global Char GFLDCHR(80)(5)
Global Decimal GFLDNUM(5)
GFLDCHR(0) = func ZCOMUN.DATA_BASE_TIPO()
# Tope de filas en rejilla
GFLDNUM(0) = func ZCOMUN.FILAS_GRID("ZGTAR0","NBLIG")
GFLDNUM(1) = func ZCOMUN.FILAS_GRID("ZGTAR1","NBLIG")
GFLDNUM(2) = func ZCOMUN.FILAS_GRID("ZGTAR2","NBLIG")
Call ESTADO
Chgfmt [M:ZGTAR0]FCY     With "-"
Return

$EFFMASK
#Infbox "$EFFMASK    MA="+num$(MA)+"    maskcou="+maskcou
Return

$FERME
Kill GFLDCHR,GFLDNUM
Return


Subprog ESTADO
#Local Char MOSTRAR(1)
Chgfmt [M:ZGTAR0]NADA1    With "-"
#Chgfmt [M:ZGTAR0]NADA2    With "-"
#Según TIPO CALCULO
Case[M:ZGTAR0]ZTIPO
When 1
  Raz [M:ZGTAR0]NBLIG,[M:ZGTAR0]PLI
  Affzo [M:ZGTAR0]PLI
  Effzo [M:ZGTAR0]10
#  Chgfmt [M:ZGTAR0]ZITMREF With "+"
#  Chgfmt [M:ZGTAR0]ZBASE   With "+"
#  Chgfmt [M:ZGTAR0]FCY     With "+"
  Actzo [M:ZGTAR0]ZITMREF
  Actzo [M:ZGTAR0]ZBASE
  Actzo [M:ZGTAR0]FCY
  Grizo [M:ZGTAR0]PLI
#  MOSTRAR="-"
  Grizo [M:ZGTAR1]SEL  # ACTZO
When 2
  Raz [M:ZGTAR0]ZITMREF,[M:ZGTAR0]ZBASE,[M:ZGTAR0]ZBASEM2,[M:ZGTAR0]FCY
  Affzo [M:ZGTAR0]ZITMREF
  Affzo [M:ZGTAR0]ZBASE
  Affzo [M:ZGTAR0]ZBASEM2
  Affzo [M:ZGTAR0]FCY
#  Chgfmt [M:ZGTAR0]ZITMREF With "-"
#  Chgfmt [M:ZGTAR0]ZBASE   With "-"
#  Chgfmt [M:ZGTAR0]FCY     With "-"
  Grizo [M:ZGTAR0]ZITMREF
  Grizo [M:ZGTAR0]ZBASE
  Grizo [M:ZGTAR0]FCY
  Actzo [M:ZGTAR0]PLI
#  MOSTRAR='+'
  Grizo [M:ZGTAR1]SEL
Endcase
#Chgfmt [M:ZGTAR0]PLI      With MOSTRAR
#Chgfmt [M:ZGTAR0]NBLIG    With MOSTRAR
#Chgfmt [M:ZGTAR0]ZTSCCOD0 With MOSTRAR
#Chgfmt [M:ZGTAR0]ZTSCCOD1 With MOSTRAR
#Chgfmt [M:ZGTAR0]ZPOR     With MOSTRAR
#Chgfmt [M:ZGTAR0]ZFIJO    With MOSTRAR
#Según Base >0
If [M:ZGTAR0]ZBASE>0
  Chgfmt [M:ZGTAR0]ZBASEM2  With "+"
  Affzo [M:ZGTAR0]ZBASEM2
#  Chgfmt [M:ZGTAR1]ZPORBASE With "+"
#  Chgfmt [M:ZGTAR1]ZPOR     With "-"
#  Chgfmt [M:ZGTAR1]ZFIJO    With "-"
  Actzo [M:ZGTAR1]ZPORBASE
  Grizo [M:ZGTAR1]ZPOR
  Grizo [M:ZGTAR1]ZFIJO
Else
  Raz [M:ZGTAR0]ZBASEM2
  Affzo [M:ZGTAR0]ZBASEM2
  Chgfmt [M:ZGTAR0]ZBASEM2  With "-"
#  Chgfmt [M:ZGTAR1]ZPORBASE With "-"
#  Chgfmt [M:ZGTAR1]ZPOR     With "+"
#  Chgfmt [M:ZGTAR1]ZFIJO    With "+"
  Grizo [M:ZGTAR1]ZPORBASE
  Actzo [M:ZGTAR1]ZPOR
  Actzo [M:ZGTAR1]ZFIJO
Endif
#Affzo [M:ZGTAR1]5
End

Subprog VACIAR_REJILLAS(T)
Value Integer T
If T<=0
  #Rejilla cabecera
  Raz [M:ZGTAR0]NBLIG
  Effzo [M:ZGTAR0]10
  If T<0 End Endif
Endif
Raz [M:ZGTAR1]NBLIG
Effzo [M:ZGTAR1]5
Raz [M:ZGTAR2]NBLIG
Effzo [M:ZGTAR2]5
End

Subprog VACIAR_REJILLA2
Raz [M:ZGTAR2]NBLIG
Effzo [M:ZGTAR2]5
#Affzo [M:ZGTAR2]5
End
