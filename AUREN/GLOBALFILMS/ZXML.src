#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################################
# Subprogramas para gestionar XML
#######################################################################################
Subprog XML_INICIO(WTIPO)
    Value Char WTIPO()

    # WTIPO = "ISO" | "UTF"
    If WTIPO = "ISO"
      Wrseq '<?xml version="1.0" encoding="ISO 8859" ?>' Using [TIF]
    Endif
    If WTIPO = "UTF"
      Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [TIF]
    Endif
End


Subprog XML_INICIO_NOMBRE(WNOMBRE)
     Value Char WNOMBRE()
     Wrseq '<p:WWIMP' + WNOMBRE + ' xmlns:p="http://com.sage/X3/WWIMP' + WNOMBRE +
&          ' xmlns:xsi="http://www.w3.orq/2001/XMLSchema-Instance" xsi:schemaLocation="http://com.sage/X3/WWIMP'
&          + WNOMBRE + ' WWIMP' +  WNOMBRE + '.xsd ">' Using [TIF]
End


Subprog XML_FIN(WNOMBRE)
     Value Char WNOMBRE()
     Wrseq "</p:WWIMP" + WNOMBRE + ">" Using [TIF]
End


Subprog XML_ABRE_ETIQUETA(WNOMBRE)
     Value Char WNOMBRE()
     Wrseq "     <" + WNOMBRE + ">" Using [TIF]
End


Subprog XML_CIERRA_ETIQUETA(WNOMBRE)
     Value Char WNOMBRE()
     Wrseq "     </" + WNOMBRE + ">" Using [TIF]
End


Subprog XML_LINEA(WNOMBRE,WVALOR)
     Value Char WNOMBRE()
     Value Char WVALOR()

     Wrseq "          <" + WNOMBRE + ">" + WVALOR + "</" + WNOMBRE + ">" Using [TIF]

 End

 ###################################################################
