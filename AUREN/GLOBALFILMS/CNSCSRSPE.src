#<AdxTL>@(#)0.0.0.0 $Revision$
# CNSCSRSPE   Consulta lineas devoluciones VENTAS  M:CSR1 + M:CSR2   F:SRH
# FILTER -> Para construir filtro especifico
# Tipo ventana  CONSULTA # INQUIRY
$ACTION
#Infbox ACTION
Case ACTION
   When "OUVRE"       :   Gosub OUVRE
   When "FILTRE"      :   Gosub FILTRE
   When "FERME"       :   Gosub FIN
   When "TITRE"       :   Gosub INI_VALORES
   When "APRES_MODIF" :   Gosub LIMPIAR
   When "AV_AFFICHE"  :   Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:SRDX])= 0 : Local File SRETURND  [SRDX] : Endif
If clalev([F:BPAX])= 0 : Local File BPADDRESS [BPAX] : Endif
Local Char WFILF(250)  : WFILF = "1=1"
Return

$FILTRE
Local Char TMP(200)
Local Integer T

Raz [M:CSR1]ZTOTBOB
Raz [M:CSR1]ZTOTKG
Raz [M:CSR1]ZTOTM2
Raz [M:CSR1]ZTOTIMPAI
Raz [M:CSR1]ZTOTIMPII
Affzo [M:CSR1]ZTOTBOB
Affzo [M:CSR1]ZTOTKG
Affzo [M:CSR1]ZTOTM2
Affzo [M:CSR1]ZTOTIMPAI
Affzo [M:CSR1]ZTOTIMPII

TMP=""
If [M:CSR1]ZPRECOG=2 Then Call MONTAR_TMP(TMP,1):Endif
If [M:CSR1]ZPREVIS=2 Then Call MONTAR_TMP(TMP,2):Endif
If [M:CSR1]ZPFIRMA=2 Then Call MONTAR_TMP(TMP,3):Endif
If [M:CSR1]ZPABONO=2 Then Call MONTAR_TMP(TMP,4):Endif
If [M:CSR1]ZACEPTA=2 Then Call MONTAR_TMP(TMP,5):Endif
If [M:CSR1]ZNOACEP=2 Then Call MONTAR_TMP(TMP,6):Endif
If TMP<>"" Then
  TMP+=')'
  WFIL2+="&" + TMP
Endif
Return

Subprog MONTAR_TMP(TMP_P, VALOR_P)
Variable Char TMP_P
Value Integer VALOR_P
  If TMP_P ="" Then
    TMP_P+='('
  Else
    TMP_P+=' |'
  Endif
  TMP_P+='[F:SRH]ZSITFLG=' + num$(VALOR_P)
End


$LIMPIAR
  [M:CSR2]NBLIG=0:      Affzo [M:CSR2]
  [M:CSR1]ZTOTBOB=0:    Affzo [M:CSR1]ZTOTBOB
  [M:CSR1]ZTOTKG=0:     Affzo [M:CSR1]ZTOTKG
  [M:CSR1]ZTOTM2=0:     Affzo [M:CSR1]ZTOTM2
  [M:CSR1]ZTOTIMPII=0:  Affzo [M:CSR1]ZTOTIMPII
  [M:CSR1]ZTOTIMPII=0:  Affzo [M:CSR1]ZTOTIMPII
Return

$INI_VALORES
  [M:CSR1]ZACEPTA=2:Affzo[M:CSR1]ZACEPTA
  [M:CSR1]ZNOACEP=2:Affzo[M:CSR1]ZNOACEP
  [M:CSR1]ZPABONO=2:Affzo[M:CSR1]ZPABONO
  [M:CSR1]ZPFIRMA=2:Affzo[M:CSR1]ZPFIRMA
  [M:CSR1]ZPRECOG=2:Affzo[M:CSR1]ZPRECOG
  [M:CSR1]ZPREVIS=2:Affzo[M:CSR1]ZPREVIS
Return

$FIN
  If GPE=1 Then GPE=0:Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif

For F=0 To [M:CSR2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CSR2]ITMREF(F)
   Raz [F:SRDX]
   Read [SRDX]SRD0=[M:CSR2]SRHNUM(F);[M:CSR2]SRDLIN(F)
   If [F:SRDX]SAU="M2"
      [M:CSR2]ZQTYKG(F)=arr([F:SRDX]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSR2]ZQTYM2(F)=arr([F:SRDX]QTY,0.01)
   Endif
   If [F:SRDX]SAU="KG"
      [M:CSR2]ZQTYKG(F)=arr([F:SRDX]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSR2]ZQTYM2(F)=arr([F:SRDX]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSR2]ZQTYM2(F)=0
      Endif
   Endif
   # Adresse de livraison
  If [F:SRH]BPAADD<>"" Then
     Read [BPAX]BPA0=1;[M:CSR2]BPCORD(F);[M:CSR2]BPAADD(F)
     If !fstat Then
        [M:CSR2]BPADES(F)=[BPAX]BPAADDLIG
     Endif
  Endif
Next
Return

$CAL_CUMUL
Raz [M:CSR1]ZTOTBOB
Raz [M:CSR1]ZTOTKG
Raz [M:CSR1]ZTOTM2
Raz [M:CSR1]ZTOTIMPAI
Raz [M:CSR1]ZTOTIMPII
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILF) Order By Key SRD0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SRD]ITMREF

   [M:CSR1]ZTOTBOB+=[F:SRD]ZQTYBOB
   If [F:SRD]SAU="M2"
      [M:CSR1]ZTOTKG+=arr([F:SRD]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSR1]ZTOTM2+=arr([F:SRD]QTY,0.01)
   Endif
   If [F:SRD]SAU="KG"
      [M:CSR1]ZTOTKG+=arr([F:SRD]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSR1]ZTOTM2+=arr([F:SRD]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSR1]ZTOTM2+=0
      Endif
   Endif
   [M:CSR1]ZTOTIMPAI+=[F:SRD]QTY*[F:SRD]NETPRINOT
   [M:CSR1]ZTOTIMPII+=[F:SRD]QTY*[F:SRD]NETPRIATI
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CSR1]ZTOTBOB
Affzo [M:CSR1]ZTOTKG
Affzo [M:CSR1]ZTOTM2
Affzo [M:CSR1]ZTOTIMPAI
Affzo [M:CSR1]ZTOTIMPII
Return
