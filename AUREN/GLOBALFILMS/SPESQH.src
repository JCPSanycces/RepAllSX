# Gestión de la máscara SQH2 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SQH2) 24/12/2015 18:32:42 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR

Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL
Local Integer LPOHENCNTR, LSOHENCNTR
Local Char LNUMCNTR(25)

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=([M:SQH2]ZANCHO(NOL)/1000)*[M:SQH2]ZLONGITUD(NOL)
LVOLUMEN=([M:SQH2]ZANCHO(NOL)/1000)*[M:SQH2]ZLONGITUD(NOL)*LFACTOR

If VALEUR<>0 and [M:SQH2]ZANCHO(NOL)<>0 and [M:SQH2]ZMANDRIL(NOL)<>0 and [M:SQH2]ZLONGITUD(NOL)<>0
   If [M:SQH2]SAU(NOL)="M2"
      [M:SQH2]QTY(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
   Endif
   If [M:SQH2]SAU(NOL)="KG"
      [M:SQH2]QTY(NOL)=arr(VALEUR*LVOLUMEN,0.001)
   Endif
Else
   [M:SQH2]QTY(NOL)=VALEUR
Endif

Affzo [M:SQH2]QTY(NOL)

[M:SQH2]ZQTYALT(NOL)=0
If [M:SQH2]SAU(NOL)="M2"
   [M:SQH2]ZQTYALT(NOL)=arr(VALEUR*LVOLUMEN,0.001)
Endif
If [M:SQH2]SAU(NOL)="KG"
   [M:SQH2]ZQTYALT(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
Endif
Affzo [M:SQH2]ZQTYALT(NOL)

Call AM_QTY([M:SQH2]QTY(NOL)) From SUBSQH
End

Subprog AM_ZANCHO(VALEUR)
Variable Decimal VALEUR

Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL
Local Integer LPOHENCNTR, LSOHENCNTR
Local Char LNUMCNTR(25)

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=(VALEUR/1000)*[M:SQH2]ZLONGITUD(NOL)
LVOLUMEN=(VALEUR/1000)*[M:SQH2]ZLONGITUD(NOL)*LFACTOR

If [M:SQH2]ZQTYBOB(NOL)<>0 and VALEUR<>0 and [M:SQH2]ZMANDRIL(NOL)<>0 and [M:SQH2]ZLONGITUD(NOL)<>0
   If [M:SQH2]SAU(NOL)="M2"
      [M:SQH2]QTY(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
   Endif
   If [M:SQH2]SAU(NOL)="KG"
      [M:SQH2]QTY(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
   Endif
Else
   [M:SQH2]QTY(NOL)=[M:SQH2]ZQTYBOB(NOL)
Endif

Affzo [M:SQH2]QTY(NOL)

[M:SQH2]ZQTYALT(NOL)=0
If [M:SQH2]SAU(NOL)="M2"
   [M:SQH2]ZQTYALT(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
Endif
If [M:SQH2]SAU(NOL)="KG"
   [M:SQH2]ZQTYALT(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
Endif
Affzo [M:SQH2]ZQTYALT(NOL)

Call AM_QTY([M:SQH2]QTY(NOL)) From SUBSQH
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR

Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL
Local Integer LPOHENCNTR, LSOHENCNTR
Local Char LNUMCNTR(25)

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=([M:SQH2]ZANCHO(NOL)/1000)*VALEUR
LVOLUMEN=([M:SQH2]ZANCHO(NOL)/1000)*VALEUR*LFACTOR

If [M:SQH2]ZQTYBOB(NOL)<>0 and [M:SQH2]ZANCHO(NOL)<>0 and [M:SQH2]ZMANDRIL(NOL)<>0 and VALEUR<>0
   If [M:SQH2]SAU(NOL)="M2"
      [M:SQH2]QTY(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
   Endif
   If [M:SQH2]SAU(NOL)="KG"
      [M:SQH2]QTY(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
   Endif
Else
   [M:SQH2]QTY(NOL)=[M:SQH2]ZQTYBOB(NOL)
Endif

Affzo [M:SQH2]QTY(NOL)

[M:SQH2]ZQTYALT(NOL)=0
If [M:SQH2]SAU(NOL)="M2"
   [M:SQH2]ZQTYALT(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
Endif
If [M:SQH2]SAU(NOL)="KG"
   [M:SQH2]ZQTYALT(NOL)=arr([M:SQH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
Endif
Affzo [M:SQH2]ZQTYALT(NOL)

Call AM_QTY([M:SQH2]QTY(NOL)) From SUBSQH
End


