#<AdxTL>@(#)0.0.0.0 $Revision$
#Utilizamos la accion FILGAUCHE para filtrar la lista de stocks segun los valores de la linea de documento
#asignando a FILGAUSUP(2) el filtro que nos interesa
$ACTION
#Infbox ACTION
Case ACTION
  When "AVANT_ENR"  :  Gosub AVANT_ENR
  When "FILGAUCHE"  :  Gosub FILGAUCHE
Endcase
Return

#FJCG - Se copia la rutina FILGAUCHE del estandar para poder inicializar la variable FILGAUSUP(2) con los filtros
#       de los campos especificos y se anula la estandar con GPE=1.
$FILGAUCHE

#If GUSER="ADMIN"
#   Infbox "FILGAUCHE - XYTRTSTOSOR - LABR:"+LABR+" ANCHO: "+num$([M:SOR]ZANCHO)+" LONG: "+num$([M:SOR]ZLONGITUD)+" MAND: "+num$([M:SOR]ZMANDRIL)
#Endif

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

#FJCG - Inicio especifico
If LABR="SMO1"
   FILGAUSUP(2)="&[F:STO]ZANCHO="+num$([M:SOR]ZANCHO)+" &[F:STO]ZMANDRIL="+num$([M:SOR]ZMANDRIL)+
&               " &[F:STO]ZLONGITUD="+num$([M:SOR]ZLONGITUD)
Endif
#FJCG - Fin especifico

If WAFFPICK=0
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
Else
   # Filtre article, site
   FILGAUSUP(0)=WCRITSTO1
   # Filtre lot
   If WCRITSTO2<>""
      FILGAUSUP(0)+='&'+WCRITSTO2
   Endif
   # Filtre péremption
   If [M:SOR]FLGDLULOT = 1 & WCRITSTO31<>""    # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO31             # hcb V6cri
   Elsif [M:SOR]FLGSHLLOT = 1 & WCRITSTO3<>""  # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO3
   Endif                                       # hcb V6cri
   # Filtre catégorie emplacement
   If dim([M:SOR]LOC)>0 & WCRITSTO5<>""
      #--- Bug 60932
      #FILGAUSUP(0)+='&'+WCRITSTO5+
      FILGAUSUP(0)+='&('+WCRITSTO5+')'
   Endif
   # Filtre inventaire
   FILGAUSUP(0)+='&[F:STO]CUNLOKFLG<>2'

   # Filtre statuts
   If WCRITSTO4<>""
      FILGAUSUP(1)+='&('+WCRITSTO4+')'
   Else
      Raz WCRIT
      If [M:SOR]AAASTA=2
         WCRIT+=WCRITSTOA
      Endif
      If [M:SOR]QQQSTA=2
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+=WCRITSTOQ
      Endif
      If [M:SOR]RRRSTA=2
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+=WCRITSTOR
      Endif
      If WCRIT<>''
         FILGAUSUP(1)+='&('+WCRIT+')'
      Endif
   Endif
   # Filtre lignes de stock indisponibles
   #If [M:SOR]STODISFLG<>2
   #   FILGAUSUP(1)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
   #Endif
   # Filtres supplémentaires
   If !find([M:SOR]XPALNUM,"","*")
      FILGAUSUP(1)+='&pat([F:STO]PALNUM,[M:SOR]XPALNUM)<>0'
   Endif
   If !find([M:SOR]XCTRNUM,"","*")
      FILGAUSUP(1)+='&pat([F:STO]CTRNUM,[M:SOR]XCTRNUM)<>0'
   Endif
   If [M:SOR]XPCUFIL<>""
      FILGAUSUP(1)+='&[F:STO]PCU=[M:SOR]XPCUFIL'
   Endif

   # Si série en E/S le no doit ętre connu
   If [M:SOR]SERMGTCOD=3
      # Si lot (sous-lot) obligatoire le no doit ętre connu
      If [F:ITM]LOTMGTCOD=3
         FILGAUSUP(1)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SERNUM<>""))'
      Elsif [F:ITM]LOTMGTCOD=4
         FILGAUSUP(1)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SLO<>""&[F:STO]SERNUM<>""))'
      Else
         FILGAUSUP(1)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]SERNUM<>""))'
      Endif
   Else
      # Si lot (sous-lot) obligatoire le no doit ętre connu
      If [F:ITM]LOTMGTCOD=3
         FILGAUSUP(1)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""))'
      Elsif [F:ITM]LOTMGTCOD=4
         FILGAUSUP(1)+='&([F:STO]LOCCAT<>2|([F:STO]LOCCAT=2&[F:STO]LOT<>""&[F:STO]SLO<>""))'
      Endif
   Endif

   # Si prise en compte filtre emplacement de la rčgle d'allocation
   If [M:SOR]PECTRU=2
      If GSTOLOC<>""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GSTOLOC)<>0'
      Endif
      If GDEFLOC<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC)<>0'
         Endif
      Elsif GDEFLOCTYP<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Endif
      Endif
      If GDEFLOC2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC2)<>0'
         Endif
      Elsif GDEFLOCTYP2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Endif
      Endif
      If GDEFLOC3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC3)<>0'
         Endif
      Elsif GDEFLOCTYP3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Endif
      Endif
      If FILGAUSUP(3)<>"" FILGAUSUP(3)+=')' Endif

   Endif

   # Filtre lignes de stock indisponibles
   If [M:SOR]STODISFLG<>2
      FILGAUSUP(3)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
   Endif

   # Filtre stock supplémentaire
   If [M:SOR]FILSTO<>""
      FILGAUSUP(3)+='&evalue([M:SOR]FILSTO)'
   Endif
   # Filtre propriétaire
   FILGAUSUP(3)+='&'+WCRITSTO6

Endif
#FJCG - Inicio especifico
GPE=1
#FJCG - Fin especifico
Return

$AVANT_ENR
#JLPR 01-02-17 Comentado y ańadido lineas
#Local Integer WLINEA
Local Integer WLINEA,YN
Local Char MSG(250)
For WLINEA=0 To [M:SOR]NBLIG-1
   If [M:SOR]TOTQTYSTU(WLINEA)<>[M:SOR]QTYSTU(WLINEA)
#      Infbox "No se permite dejar restos (2) - linea: "+num$(WLINEA+1)+" - "+
#&      num$([M:SOR]TOTQTYSTU(WLINEA))+" - "+num$([M:SOR]QTYSTU(WLINEA))+" - XYTRTSTOSOR"
#If GUSER<>"ADMIN"
#      FOK=0
#Endif
#      Break
       MSG="No se permite dejar restos (2) - linea: "+num$(WLINEA+1)+" - "+num$([M:SOR]TOTQTYSTU(WLINEA))+" - "+num$([M:SOR]QTYSTU(WLINEA))+" - XYTRTSTOSOR"
      If GUSER="ADMIN"
        YN=1 # Por defecto es NO
        Call OUINON("Está seguro de continuar\"+MSG+"\GFONCTION="+GFONCTION+"  GFONCTION1="+GFONCTION1, YN) From GESECRAN
        If YN=1
          FOK=0
          Break
        Endif
      Else
        Infbox MSG
        FOK=0
        Break
      Endif
   Endif
Next
If FOK=0
   GPE=1
   Return
Endif
Return
