Subprog AM_ZANCHODEB(VALEUR)
Variable Decimal VALEUR
If [M]ZANCHOEND = 0     : [M]ZANCHOEND = VALEUR : Affzo [M]ZANCHOEND : Endif
If [M]ZANCHOEND < VALEUR : [M]ZANCHOEND = VALEUR : Affzo [M]ZANCHOEND : Endif
End

Subprog AM_ZLONGITUDDEB(VALEUR)
Variable Decimal VALEUR
If [M]ZLONGITUDEND = 0     : [M]ZLONGITUDEND = VALEUR : Affzo [M]ZLONGITUDEND : Endif
If [M]ZLONGITUDEND < VALEUR : [M]ZLONGITUDEND = VALEUR : Affzo [M]ZLONGITUDEND : Endif
End


