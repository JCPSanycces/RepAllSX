#<AdxTL>@(#)0.0.0.0 $Revision$
#Inhabilitamos la accion estandar TERMINE para que no active la traza cuando se lanza la asignacion
#automaticamente desde seguimientos
$ACTION
Case ACTION
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#Copiada del proceso estandar FUNAUTALL
$TERMINE

#Ponemos GPE a 1 para que no ejecute la accion estandar.

GPE=1

If !GSERVEUR
    If !NBALL
         Call ECR_TRACE(mess(39,192,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
# --> Aucune allocation effectuee ou lecture trace
    If !NBALL
         GERR=2:GMESSAGE = mess(39,192,1)
    Endif
    If GFONCTION="GESMTK" and GACTION="TRTAUTALL"
       TRA=0
    Else
       TRA=1
    Endif
Endif

Return
