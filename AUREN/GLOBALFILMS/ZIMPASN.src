#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
    Case ACTION
        When "OUVRE" : Gosub OUVRE
        When "EXEC" : Gosub EXEC
        When "OK"   : Gosub OK
        When "SORTIE"  : Gosub FIN
        When "CONTROLE" : Gosub CONTROLE
        When Default
    Endcase
Return

$OUVRE

    Global Char WNOM(250)
    Global Integer WEXE

    WEXE = 0

    #If !clalev([F:ZAH]) : Local File ZASNH [ZAH] : Endif
    #If !clalev([F:ZAD]) : Local File ZASND [ZAD] : Endif


Return


$FIN
    Kill WNOM
    Kill WEXE
Return

$ABRIR

    Local File ZASNH [ZAH]
    Local File ZASND [ZAD]
    Local File ZASND [ZAD2]

    Local File ITMMASTER [ITM]
    Local File STOLOC [TUBI]
    Local Mask ZCRISELFIC [ZSF0]
    Local File PORDERQ [POQ]

    Local Char A(250)(1..110)
    Local Char TIPOUBI(20)
    Local Char NUMENT(25)
    Local Integer WLINEA
    Local Integer WGERROR   #ERROR Global
    Local Integer WERROR    #ERROR DE RECUPERACION
    #Separadores de campo
    adxifs=";"
    adxirs=chr$(13)+chr$(10)
    adxium=50 # ASCII

Return



$OK

    WEXE = 1
    WNOM = [M:ZSF]NOMFIC(0)
Return

$CONTROLE
    TMP = 1
    TIT = "Importación en curso"
Return


$CERRAR

    Close File [ZAH]
    Close File [ZAD]
Return


$EXEC

    If WEXE = 1
        Gosub ABRIR

     #   Delete  [ZAH] Where 1=1
     #   Delete  [ZAD] Where 1=1

     Call OUVRE_TRACE("Importación de ASN ") From LECFIC
     Call ECR_TRACE(" Importación de ASN ",0) From GESECRAN


        WNOM = mid$(WNOM,7,len(WNOM))


         #WNOM = FILPATH("BQT",WNOM,"")
         WNOM = "C:\Sage\X3V8\folders\GLOBAL\BQT\"+WNOM
         Openi WNOM Using [TIE]
         Trbegin [ZAH],[ZAD]

         WGERROR = 0
         WERROR = 0
         Gosub LEER_REGISTRO
         While !fstat
             Gosub IMPORTAR
             Gosub LEER_REGISTRO
         Wend

         If WGERROR = 0
             Commit
             Gosub CALCULAR_IMPORTES

         Else
             Rollback
         Endif

         Openi Using [TIE]
        Gosub CERRAR

        Call ECR_TRACE(" Finaliza la importación de ASN ",0) From GESECRAN
        Call FERME_TRACE From LECFIC
        TRA = 1

    Endif
Return

$IMPORTAR
    If NUMENT<>vireblc(A(1),2)
        WLINEA = 1 #CONTADOR DE LINEAS INICIALIZADO
    Endif
    WERROR = 0 #INICILAIZAMOS EL ERROR A 0
    #COMPROBAR SI YA SE HA IMPORTADO LA ENTREGA
    Read [ZAH]ZAH0 = vireblc(A(1),2)
    If fstat
        If WLINEA=1 Then
            Raz [ZAH]

            Filter [F:TUBI] Where 1=1 and STOFCY=[M:ZSF0]FCY and LOC=[M:ZSF0]LOC
            For [F:TUBI]
              TIPOUBI = [F:TUBI]LOCTYP
            Next
            [ZAH]NUMENT=vireblc(A(1),2)
            [ZAH]NUMPED=vireblc(A(3),2)
            [ZAH]IDPROVEEDOR=[M:ZSF0]BPSNUM
            [ZAH]PLANTA=[M:ZSF0]FCY
            [ZAH]UBICACION=[M:ZSF0]LOC
            [ZAH]FECENT=gdat$(val(seg$(A(2),1,2)),val(seg$(A(2),4,5)),val(seg$(A(2),7,10)))
            [ZAH]TUBIINI=TIPOUBI
            [ZAH]ZPORARANCEL=[M:ZSF0]ZPORARANCEL
            [ZAH]ZGASNORMALES=[M:ZSF0]ZGASNORMALES
            [ZAH]ZGASEXTRAS=[M:ZSF0]ZGASEXTRAS
            [ZAH]PROCESAR=1
            Write [ZAH]
        Endif

    Else
        If WLINEA=1 Then
            Call ECR_TRACE(" Nş de entrega ya importado",1) From GESECRAN
        Endif
    Endif

    ###############################################################
    #LINEAS
    ###############################################################
    Read [ZAD]ZAD0 = vireblc(A(1),2);WLINEA
    If fstat
        Raz [ZAD]

         #Infbox(num$(vireblc(A(1),2))+num$(WLINEA))
        [ZAD]NUMENT=vireblc(A(1),2)
        [ZAD]LIN=WLINEA
        [ZAD]CODSTYLE=vireblc(A(4),2)
        [ZAD]ZBOBINAS=val(vireblc(A(5),2))
        [ZAD]ZANCHO=val(vireblc(A(6),2))
        [ZAD]ZLONGITUD=val(vireblc(A(7),2))
        [ZAD]ZMANDRIL=val(vireblc(A(8),2))
        [ZAD]ZLOTE=vireblc(A(9),2)
        [ZAD]CODCART=vireblc(A(13),2)
        [ZAD]UNIDADES=val(vireblc(A(11),2))
        [ZAD]ZCODPALET=vireblc(A(12),2)
        [ZAD]ZUNICOMPRA=vireblc(A(10),2)
        #[ZAD]ZPORARANCEL=[M:ZSF0]ZPORARANCEL
        #[ZAD]ZGASNORMALES=[M:ZSF0]ZGASNORMALES
        #[ZAD]ZGASEXTRAS=[M:ZSF0]ZGASEXTRAS
        [ZAD]FECENT=gdat$(val(seg$(A(2),1,2)),val(seg$(A(2),4,5)),val(seg$(A(2),7,10)))
        [ZAD]ZFECHAREC=format$("D:YYYYMMDD",date$)
        [ZAD]PROCESADA=1

        Filter [F:POQ] Where 1=1 and POHNUM=[ZAH]NUMPED and ITMREF=[ZAD]CODSTYLE and ZANCHO=[ZAD]ZANCHO and ZLONGITUD=[ZAD]ZLONGITUD and ZMANDRIL=[ZAD]ZMANDRIL
        For [F:POQ]
            [ZAD]ZPUNITARIO=[F:POQ]CPRPRI
        Next

        #If WLINEA=1 Then
        #    [ZAD]ZPUNITARIO=30
        #Elsif WLINEA=2 Then
        #    [ZAD]ZPUNITARIO=2
        #Elsif WLINEA=3 Then
        #    [ZAD]ZPUNITARIO=10
        #Endif

        Write [ZAD]
    Endif
    WLINEA=WLINEA+1



    NUMENT=vireblc(A(1),2)

Return

$CALCULAR_IMPORTES
    Local Double CANTIDAD
    Local Double ARANCELES
    Local Double GASNORMALES
    Local Double GASEXTRAS
    Local Double TOTALKILOS
    Local Double TOTALIMPORTES
    Local Double KILOSPROMEDIO
    Local Double PORUNITARIO
    Local Double SUMUNITARIOS
    Local Double VALPROMEDIO
    Local Double CALCARANCEL

    Raz [ZAH]

    Read [ZAH]
    For [F:ZAH]
        ARANCELES=[F:ZAH]ZPORARANCEL
        GASNORMALES=[F:ZAH]ZGASNORMALES
        GASEXTRAS=[F:ZAH]ZGASEXTRAS

        TOTALIMPORTES=GASNORMALES+GASEXTRAS

        Filter [F:ZAD] Where 1=1 and NUMENT=[F:ZAH]NUMENT
        For [F:ZAD]
            CANTIDAD=[F:ZAD]UNIDADES

            TOTALKILOS=0
            SUMUNITARIOS=0
            Filter [F:ZAD2] Where 1=1 and NUMENT=[F:ZAH]NUMENT
            For [F:ZAD2]
                TOTALKILOS = TOTALKILOS+([F:ZAD2]UNIDADES)
                SUMUNITARIOS =SUMUNITARIOS+([F:ZAD2]ZPUNITARIO)
            Next

            KILOSPROMEDIO = (TOTALIMPORTES/TOTALKILOS)*10
            #Infbox("kilospromedio " + num$(KILOSPROMEDIO))
            PORUNITARIO = ar2(([F:ZAD]ZPUNITARIO*100)/SUMUNITARIOS)
            #Infbox("porunitario " + num$(([F:ZAD]ZPUNITARIO*100)/SUMUNITARIOS) + " = " + num$((PORUNITARIO)))
            VALPROMEDIO=ar2((PORUNITARIO*KILOSPROMEDIO)/100)
            CALCARANCEL=(ARANCELES*[F:ZAD]ZPUNITARIO)/100

            [F:ZAD]ZPORARANCEL=CALCARANCEL
            [F:ZAD]ZRPTOCOSTES=VALPROMEDIO
            [F:ZAD]ZSUBTOTALUNI=[F:ZAD]ZPUNITARIO+CALCARANCEL+VALPROMEDIO
            [F:ZAD]ZSUBTOTALLIN=([F:ZAD]ZPUNITARIO+CALCARANCEL+VALPROMEDIO)*[F:ZAD]UNIDADES

            Rewrite [ZAD]

            #Infbox("arancel: " + num$(CALCARANCEL))
            #Infbox("reparto costes: " + num$(VALPROMEDIO))
            #Infbox("susbtotal precio unitario: " + num$([F:ZAD]PACKS+CALCARANCEL+VALPROMEDIO))

        Next

        Filter [F:ZAD] Where 1=1
    Next
    Filter [F:ZAH] Where 1=1

Return


$CABECERA

    WLINEA = 1 #CONTADOR DE LINEAS INICIALIZADO
    WERROR = 0 #INICILAIZAMOS EL ERROR A 0
    #COMPROBAR SI YA SE HA IMPORTADO LA ENTREGA
    Read [ZAH]ZAH0 = vireblc(A(2),2)
    If fstat
        Call ECR_TRACE(" ------ Procesando ASN : "+vireblc(A(2),2)+" ",0) From GESECRAN

        Raz [ZAH]
        [ZAH]NUMENT        = vireblc(A(2),2)
        #[ZAH]FECENT        = vireblc(A(3),2)
        [ZAH]IDCLIENT      = vireblc(A(4),2)
        [ZAH]IDTRANS       = vireblc(A(5),2)
        [ZAH]TOTCAR        = val(vireblc(A(6),2))
        [ZAH]TOTPACKS      = val(vireblc(A(7),2))
        [ZAH]TOTWEIGH      = val(vireblc(A(8),2))
        [ZAH]TOTUNITS      = val(vireblc(A(9),2))
        [ZAH]TUBIINI       = "REC"


        Gosub LEER_REGISTRO
        If vireblc(A(1),2) = "HEADER2"
            [ZAH]NUMPED = vireblc(A(2),2)
            Write [ZAH]
        Else
            #ERROR!!!! --> fICHERO ERRONEO
            Call ECR_TRACE(" Formato de fichero erroneo no esta el campo HEADER2",1) From GESECRAN
            WERROR = 1
            WGERROR = 1
        Endif

        Gosub LEER_REGISTRO
        If vireblc(A(1),2) = "HEADER3"
            #OK
        Else
            #ERROR!!!! --> fICHERO ERRONEO
            Call ECR_TRACE(" Formato de fichero erroneo no esta el campo HEADER3 ",1) From GESECRAN
            WERROR = 1
            WGERROR = 1
        Endif

    Else
       WERROR  = 1
       WGERROR = 1
       #RECEPCION YA SE HA IMPORTADO
       Call ECR_TRACE(" Atención ASN : "+vireblc(A(2),2)+" ya importado ",1) From GESECRAN

    Endif
Return

$LINEA

    Local Char WITMREF(20)

    Raz WITMREF

    Local Char WART(50)

    WART = vireblc(A(2),2)+"-"+vireblc(A(3),2)
    Filter [F:ITM] Where 1=1 and (ZREFITM = vireblc(A(2),2) or ZREFITM = WART )  and ZTALLA =  vireblc(A(4),2)
    For [F:ITM]
        WITMREF = [F:ITM]ITMREF
    Next
    Filter [F:ITM] Where 1=1
    #WITMREF = "BMSMN00365"
    If WITMREF <> ""
        Raz [ZAD]
            [ZAD]NUMENT   = [ZAH]NUMENT
            [ZAD]LIN      = WLINEA
            [ZAD]CODCART  = vireblc(A(1),2)
            [ZAD]CODSTYLE = [F:ITM]ITMREF
            [ZAD]CODCOLOR = vireblc(A(3),2)
            [ZAD]CODTALLA = vireblc(A(4),2)
            [ZAD]UPCCODE  = vireblc(A(5),2)
            [ZAD]COO  = vireblc(A(6),2)
            [ZAD]UNIDADES = val(vireblc(A(7),2))
            [ZAD]PACKS    = val(vireblc(A(8),2))
            [ZAD]PEDPOH   = vireblc(A(9),2)
        Write [ZAD]
        WLINEA += 1
    Else
       WERROR  = 0
       WGERROR = 1

       Call ECR_TRACE(" Atención Referencia: "+vireblc(A(2),2) +" TALLA "+vireblc(A(4),2)+" no tiene correspondencia "+WART ,1) From GESECRAN

    Endif
Return


$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return
