#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "APRES_CRE"   :   Gosub APRES_CRE
Endcase
Return

$APRES_CRE
Local Char SAVACTION(30)
Local Integer I
Local Char VALBOUT(250), PARBOUT(250)(1..20)
Global Integer ZGQTYBOB
#ZGQTYBOB -> Variable para controlar que el numero de bobinas que se asigne cuando se lanza la asignacion
#            automatica a través de FUNAUTALL no supere al de bobinas
#            pedidas, se declara e inicializa en esta rutina y se utiliza en el PE PECSTOALG de STKALL

#Gosub CREJOBASI

If clalev([ZAAM])<=0 : Local File ZASIAUTMTK [ZAAM] : Endif
If clalev([ZMSQ])<=0 : Local File ZMFGSOQ    [ZSOQ] : Endif
If clalev([SOQX])<=0 : Local File SORDERQ    [SOQX] : Endif
If clalev([STJX])<=0 : Local File STOJOU     [STJX] : Endif

For I=0 To [M:MTK2]NBITM-1
   Filter [ZMSQ] Where MFGNUM=[M:MTK0]MFGNUM and MFGLIN=[M:MTK2]MFGLIN(I)
   For [ZMSQ]
      Delete [ZAAM] Where 1=1
      Raz [F:SOQX]
      Read [SOQX]SOQ0=[F:ZMSQ]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
      If fstat=0
         Raz [F:ZAAM]
         [F:ZAAM]STOFCY   =[M:MTK0]MFGFCY
         [F:ZAAM]MFGTRKNUM=[M:MTK0]MFGTRKNUM
         [F:ZAAM]ITMTRKLIN=[M:MTK2]ITMTRKLIN(I)
         [F:ZAAM]MFGNUM   =[M:MTK0]MFGNUM
         [F:ZAAM]MFGLIN   =[M:MTK2]MFGLIN(I)
         [F:ZAAM]SOHNUM   =[F:SOQX]SOHNUM
         [F:ZAAM]SOPLIN   =[F:SOQX]SOPLIN
         [F:ZAAM]SOQSEQ   =[F:SOQX]SOQSEQ
         [F:ZAAM]ITMREF   =[F:SOQX]ITMREF
         [F:ZAAM]ZANCHO   =[F:SOQX]ZANCHO
         [F:ZAAM]ZLONGITUD=[F:SOQX]ZLONGITUD
         [F:ZAAM]ZMANDRIL =[F:SOQX]ZMANDRIL
         Filter [STJX] Where STOFCY=[M:MTK0]MFGFCY and VCRTYP=15 and VCRNUM=[M:MTK0]MFGTRKNUM and VCRLIN=[M:MTK2]ITMTRKLIN(I) and
&                            LOC="GENERAL1" and REGFLG=1
         For [STJX]
            Break
         Next
         Filter [STJX]
         [F:ZAAM]LOT    =[F:STJX]LOT
         [F:ZAAM]LOCCLI =[F:STJX]LOC
         [F:ZAAM]QTYSTU =[F:STJX]QTYSTU
         Write [ZAAM]

         ZGQTYBOB=0
         PARBOUT(1)=[M:MTK0]MFGFCY
         PARBOUT(2)=format$("YYYYMMDD",date$+30)
         PARBOUT(3)=[F:ZMSQ]SOHNUM
         PARBOUT(4)=""
         PARBOUT(5)="SOPLIN="+num$([F:ZMSQ]SOPLIN)
         PARBOUT(6)="SOPLIN="+num$([F:ZMSQ]SOPLIN)
         FLGEXE=1
         SAVACTION=GACTION
         GACTION="TRTAUTALL"
         Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FUNAUTALL","",1,"XYFUNAUTALL") From GTRAITE
         GACTION=SAVACTION
      Endif
   Next
   Filter [ZMSQ]
Next
Return

$CREJOBASI
Local Char DIRJOB(250), FICJOB(250), DIRIMP(250)
Local Integer WLI, WHORA
#Local Char HORACAR

If clalev ([F:ABP])<=0  : Local File ABATPAR  [ABP]  : Endif
If clalev ([F:ZMSQ])<=0 : Local File ZMFGSOQ  [ZMSQ] : Endif
If clalev ([F:AUSX])<=0 : Local File AUTILIS  [AUSX] : Endif
If clalev ([F:FCYX])<=0 : Local File FACILITY [FCYX] : Endif
If clalev ([F:CPYX])<=0 : Local File COMPANY  [CPYX] : Endif

Raz [AUSX]
Read [AUSX]CODUSR="ADMIN"
Raz [FCYX]
Read [FCYX]FCY0=[M:MTK0]MFGFCY
Raz [CPYX]
Read [CPYX]CPY0=[F:FCYX]LEGCPY
Raz [ABP]
Read [ABP]SPOOL First

Filter [ZMSQ] Where MFGNUM=[M:MTK0]MFGNUM
For [ZMSQ]
   WHORA=time
   WHORA=WHORA+120
   # Call CONV_NUMAHORA(WHORA,HORACAR) From ZTRTGSP

   #DIRJOB="D:\SAGE\SAGEX3V5\X3V5\Folders\ZBATCH\"
   DIRJOB = [F:ABP]REPJOB(0)

   FICJOB = DIRJOB+"\"+[M:MTK0]MFGNUM+[F:ZMSQ]SOHNUM+num$([F:ZMSQ]SOPLIN)+date$+ctrans(time$,":","")+".job"

   Raz [AUSX]
   Read [AUSX]CODUSR=GUSER

   Openo FICJOB,0 Using [ZJOB]
   Iomode adxirs chr$(10) Using [ZJOB]

   Wrseq "DOSSIER="+nomap(0) Using [ZJOB]  : #nomap(0) es el dossier actual
   Wrseq "UTIL="+[F:AUSX]USR Using [ZJOB]  : #Usuario ADMIN
   Wrseq "PASSE="+[F:AUSX]PASSE Using [ZJOB]   : #Password. BAABAA es sin password
   Wrseq "GRP=" Using [ZJOB]               : #Grupo de tareas
   Wrseq "TACHE=FUNAUTALL" Using [ZJOB]       : #Tarea a procesar. Asignacion automatica de pedidos
   Wrseq "DATE="+format$("YYYYMMDD",date$) Using [ZJOB]  : #Fecha de lanzamiento de la tarea en formato YYYYMMDD
   Wrseq "HEURE=0700" Using [ZJOB]         : #Hora de lanzamiento en formato HHMM
   Wrseq "ABT=1" Using [ZJOB]
   Wrseq "ALLCRITDET=SOPLIN="+num$([F:ZMSQ]SOPLIN) Using [ZJOB]
   Wrseq "ALLPAR=1" Using [ZJOB]
   Wrseq "CALCRITDET=SOPLIN="+num$([F:ZMSQ]SOPLIN) Using [ZJOB]
   Wrseq "CPY="+[F:FCYX]LEGCPY Using [ZJOB]
   Wrseq "DLVPIODEB=1" Using [ZJOB]
   Wrseq "DLVPIOFIN=3" Using [ZJOB]
   Wrseq "DRNFLG=1" Using [ZJOB]
   Wrseq "FILTTABDET=find(ABRFIC,'SOQ')" Using [ZJOB]
   Wrseq "FILTTABENT=find(ABRFIC,'SOH')" Using [ZJOB]
   Wrseq "GENSHT=1" Using [ZJOB]
   Wrseq "IMPCLI=2" Using [ZJOB]
   Wrseq "LTIFLG1=2" Using [ZJOB]
   Wrseq "LTIFLG2=2" Using [ZJOB]
   Wrseq "SHIDAT="+format$("YYYYMMDD",date$+30) Using [ZJOB]
   Wrseq "SHTFLG=1" Using [ZJOB]
   Wrseq "SOHNUMDEB="+[F:ZMSQ]SOHNUM Using [ZJOB]
   Wrseq "SOHNUMFIN="+[F:ZMSQ]SOHNUM Using [ZJOB]
   Wrseq "STOFCY="+[M:MTK0]MFGFCY Using [ZJOB]
   Wrseq "XXVAR(0)=WTSICOD(0),Famille statistique1" Using [ZJOB]
   Wrseq "XXVAR(1)=WTSICOD(1),Famille statistique2" Using [ZJOB]
   Wrseq "XXVAR(2)=WTSICOD(2),Famille statistique3" Using [ZJOB]
   Wrseq "XXVAR(3)=WTSICOD(3),Famille statistique4" Using [ZJOB]
   Wrseq "XXVAR(4)=WTSICOD(4),Famille statistique5" Using [ZJOB]
   Wrseq "ZCPY="+[F:FCYX]FCYNAM Using [ZJOB]
   Wrseq "ZSTOFCY="+[F:FCYX]FCYNAM Using [ZJOB]

   Openo Using [ZJOB]
Next
Filter[ZMSQ]
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla MTK0) 25/01/2017 11:33:40 (ADMIN)
######################################################################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
#Read [F:MFG]MFG0=VALEUR
#If fstat=0 and [F:MFG]ALLSTA>3
#  Infbox "Imposible declarar produccion de la OF indicada por estar asignada en RUPTURA"
#  mkstat=2
#Endif

# Comprobar si KGS Usados OF <> KGS LOTES PREASIGNADOS
Local Char TXT(255)(12),BD_TIPO(1),MSG(255)
Local Integer LNG(2),YN
Raz TXT
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
TXT(0)="with consulta(Ofn,Art,Lot,Slo,Tkgs,TSob) as ("
TXT(1)="select distinct lt.MFGNUM_0,ITMREF_0,LOT_0,SLO_0,QTYSTUASI_0,round(cast(lt.ZLONGSOB_0 * ZANCHO_0 as decimal)/1000*ZFACTOR_0,4) "
TXT(2)="from ZMFGLOT lt "
TXT(3)="inner join MFGHEAD c on lt.MFGNUM_0=c.MFGNUM_0 "
TXT(4)="where lt.MFGNUM_0='"+VALEUR+"')"
TXT(5)="select sum(Tkgs)-sum(TSob),m.RETQTY_0 "
TXT(6)="from consulta cs "
TXT(7)="inner join MFGMAT m on cs.Ofn=m.MFGNUM_0 "
TXT(8)="group by cs.Ofn,m.RETQTY_0"
For (Decimal FQTYLOT,Decimal FQTYOF) From BD_TIPO Sql TXT As [MYT]
  If FQTYLOT<>FQTYOF
    MSG="Imposible declarar produccion de la OF indicada\Deberá revisarla pues Kgs Lotes<>Kgs Usados\"+num$(FQTYLOT)+"<>"+num$(FQTYOF)+
& "\Deberá seguir estos pasos\1ş Desasignar\2ş En pestańa componentes Revisar Sobrante&Merma\3ş Excluir y después Incluirş\4ş Asignar"##\5ş Volver a intentar declarar produccion"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
#    End
  Endif
Next
# Comprobar sobranre
Raz TXT,LNG
TXT(0)="with consulta(Gr,Ln)            as (select distinct ZGRPCOR_0,ZLONGITUD_0*ZNTIRADAS_0  from MFGITM  where MFGNUM_0='"+VALEUR+"'),"
TXT(1)="     consulta2(Lot,Slo,Lng,Sob) as (select distinct LOT_0,SLO_0,ZLONGITUD_0,ZLONGSOB_0 from ZMFGLOT where MFGNUM_0='"+VALEUR+"') "
TXT(2)="select 0,sum(Ln) from consulta "
TXT(3)="union all "
TXT(4)="select 1,sum(Lng)-sum(Sob) from consulta2"
For (Integer FTIP,Decimal FLNG) From BD_TIPO Sql TXT As [MYT]
  LNG(FTIP)=FLNG
Next
If LNG(0)<>LNG(1)
  MSG= "ESTA SEGURO DE CONTINUAR\Hay una difŞ en longitud de " + num$(abs(LNG(0)-LNG(1)))
  MSG+="\Entre USADA ("+num$(LNG(1)) +") y PRODUCIDA ("+num$(LNG(0))+")"
  YN=1
  Call OUINON(MSG,YN) From GESECRAN
  If YN=1
    mkstat=2
    End
  Endif
Endif
# Comprobar coste

# Comprobar margen
End


