#<AdxTL>@(#)0.0.0.0 $Revision$
# Z0001-03-04-01 - JC.04072022 - Control existencia SKU
#################################################################################################

$ACTION
Case ACTION
 When "CREATION"   :   Gosub CREAR_CONTENEDOR
 When "MODIF"      :   Gosub MODIF_CONTENEDOR
 When "VERIF_MOD"  :   Gosub VERIF_MOD
 When "APRES_MOD"  :   Gosub APRES_MOD
 When "OUVRE"      :   Gosub OUVRE
 When "SETBOUT"    :   Gosub SETBOUT
 When "LIENS_LIG"  :   Gosub LIENS_LIG
When Default
Endcase
Return

$SETBOUT
  # Habilitar opcion menu "Consulta lineas Pedido"
  CHMEN+="Z"
Return

$OUVRE
If clalev([F:ZCNTR])<=0  : Local File ZCONTAINH [ZCNTR]  : Endif
If clalev([F:ZCNTRP])<=0 : Local File ZCONTAINP [ZCNTRP] : Endif
If clalev([F:ZCNTRS])<=0 : Local File ZCONTAINS [ZCNTRS] : Endif
Return

$APRES_MOD
Call CAL_QTY([M:POH0]POHNUM)
Return

$LIENS_LIG
Call CAL_QTY([M:POH0]POHNUM)
Return

Subprog CAL_QTY(LPOHNUM)
Value Char LPOHNUM()

If clalev([F:POQX])<=0 :  Local File PORDERQ   [POQX] :  Endif
If clalev([F:POPX])<=0 :  Local File PORDERP   [POPX] :  Endif
[M:POH2]ZTOTBOB=0
[M:POH2]ZTOTKG=0
[M:POH2]ZTOTM2=0
Filter [POQX] Where POHNUM=LPOHNUM
For [POQX]
   [M:POH2]ZTOTBOB=[M:POH2]ZTOTBOB+[F:POQX]ZQTYBOB
   Raz [F:POPX]
   Read [POPX]POP0=[F:POQX]POHNUM;[F:POQX]POPLIN;[F:POQX]POQSEQ
   If [F:POQX]PUU="KG"
      [M:POH2]ZTOTKG=[M:POH2]ZTOTKG+[F:POQX]QTYUOM
      If [F:POQ]UOMPUUCOE<>0
         [M:POH2]ZTOTM2=[M:POH2]ZTOTM2+([F:POQX]ZANCHO/1000*[F:POQX]ZLONGITUD)*[F:POQX]ZQTYBOB
      Endif
   Endif
   If [F:POQX]PUU="M2"
      [M:POH2]ZTOTKG=[M:POH2]ZTOTKG+[F:POQX]QTYSTU
      [M:POH2]ZTOTM2=[M:POH2]ZTOTM2+[F:POQX]QTYUOM
   Endif
Next
Filter [POQX]

Affzo [M:POH2]ZTOTBOB
Affzo [M:POH2]ZTOTKG
Affzo [M:POH2]ZTOTM2
End

$CREAR_CONTENEDOR
Local Char NUMERO(25)
Local Integer NUMLIN, STAT

If [M:POH0]POHFCY="200" and [M:POH0]BPSNUM="100"
   Return
Endif
Call NUMERO ("ZCNTR",GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
If STAT <> 0
   GOK = 0 : Return
Endif
Raz [F:ZCNTR]
[F:ZCNTR]NUMCNTR = NUMERO
[F:ZCNTR]STOFCY  = [F:POH]POHFCY
[F:ZCNTR]BPSNUM  = [F:POH]BPSNUM
[F:ZCNTR]BPTNUM  = [F:POH]BPTNUM
[F:ZCNTR]FFWNUM  = [F:POH]FFWNUM
[F:ZCNTR]MDL     = [F:POH]MDL
[F:ZCNTR]PEDNUM  = [F:POH]POHNUM
[F:ZCNTR]FECPRESAL= [F:POH]ORDDAT
[F:ZCNTR]FECPRESAL= [F:POH]EXTRCPDAT1
[F:ZCNTR]FLGRCPDOC= 1
[F:ZCNTR]TIPCNTR = 1
[F:ZCNTR]SITCNTR = 1
Write [ZCNTR]
If fstat
    GMESSAGE="Error creando contenedor - fstat : "+num$(fstat) : GERR=1 : GOK=0 : Return
Endif
NUMLIN=0
For I=0 To [M:POH2]NBLIG-1
   NUMLIN+=1000
   Raz [F:ZCNTRP]
   [F:ZCNTRP]NUMCNTR= [F:ZCNTR]NUMCNTR
   [F:ZCNTRP]NUMLIN = NUMLIN
   [F:ZCNTRP]POHNUM = [F:POH]POHNUM
   [F:ZCNTRP]POPLIN = [M:POH2]POPLIN(I)
   [F:ZCNTRP]POQSEQ = 1
   [F:ZCNTRP]BOBASI = [M:POH2]ZQTYBOB(I)
   Write [ZCNTRP]
   If fstat
       GMESSAGE="Error creando lineas contenedor - fstat : "+num$(fstat) : GERR=1 : GOK=0 : Return
   Endif
Next
Return

$MODIF_CONTENEDOR
#JLPR 21-02-17 INI
If not func HAY_CONTENEDOR([F:POH]POHNUM)
  Gosub CREAR_CONTENEDOR
  Return
Endif
#JLPR 21-02-17 FIN

Local Integer I, NUMLIN, LNBRCNTP
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
Local Char LNUMCNTR(25)

For I=0 To [M:POH2]NBLIG-1
   Call CTRL_CNTR([M:POH0]POHNUM,[M:POH2]POPLIN(I),"",0,LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
   #Si linea NO esta en contenedor(LPOPENCNTR) y hay solo un contenedor(LPOHENCNTR and LNBRCNTP=1) para el pedido se ańade al mismo
   If LPOHENCNTR and not LPOPENCNTR and LNBRCNTP=1
      NUMLIN=0
      Filter [ZCNTRP] Where NUMCNTR=LNUMCNTR
      For [ZCNTRP]
         If NUMLIN<[F:ZCNTRP]NUMLIN
            NUMLIN=[F:ZCNTRP]NUMLIN
         Endif
      Next
      Filter [ZCNTRP]
      NUMLIN+=1000
      Raz [F:ZCNTRP]
      [F:ZCNTRP]NUMCNTR= LNUMCNTR
      [F:ZCNTRP]NUMLIN = NUMLIN
      [F:ZCNTRP]POHNUM = [M:POH0]POHNUM
      [F:ZCNTRP]POPLIN = [M:POH2]POPLIN(I)
      [F:ZCNTRP]POQSEQ = 1
      [F:ZCNTRP]BOBASI = [M:POH2]ZQTYBOB(I)
      Write [ZCNTRP]
      If fstat
         GMESSAGE="Error creando lineas contenedor - fstat : "+num$(fstat) : GERR=1 : GOK=0 : Return
      Endif
   #Si linea SI esta en contenedor(LPOPENCNTR) y hay solo un contenedor(LPOHENCNTR and LNBRCNTP=1) para el pedido se actualizan las bobinas
   Elsif LPOHENCNTR and LPOPENCNTR and LNBRCNTP=1
      Filter [ZCNTRP] Where POHNUM=[M:POH0]POHNUM and POPLIN=[M:POH2]POPLIN(I)
      For [ZCNTRP]
        [F:ZCNTRP]BOBASI = [M:POH2]ZQTYBOB(I)
        Rewrite [ZCNTRP]
        If fstat
           GMESSAGE="Error actualizando linea contenedor - fstat : "+num$(fstat) : GERR=1 : GOK=0 : Return
        Endif
      Next
   #Si linea SI esta en contenedor(LPOPENCNTR) y hay MAS DE un contenedor(LPOHENCNTR and LNBRCNTP>1) para el pedido se avisa de que NOSE actualizan las bobinas
   Elsif LPOHENCNTR and LNBRCNTP>1 and (not LPOPENCNTR or WBOBASI<>[M:POH2]ZQTYBOB(I))
      Infbox "AVISO IMPORTANTE !!!.  Este pedido está incluido en "+num$(LNBRCNTP)+
& " contenedores Cuya situación<=Pdte.enviar proveedor.   El cambio de bobinas, deberá reflejarlo en el contenedor que corresponda"
   Endif
Next
Return

$VERIF_MOD
Local Integer I, LINMOD, LNBRCNTP
Local Decimal LBOBASI
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
Local Char LNUMCNTR(25)

LINMOD=1
For I=0 To [M:POH2]NBLIG-1
   Call CTRL_CNTR([M:POH0]POHNUM,[M:POH2]POPLIN(I),"",0,LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
   If LPOHENCNTR
      Filter [ZCNTRP] Where POHNUM=[M:POH0]POHNUM and POPLIN=[M:POH2]POPLIN(I)
      LBOBASI=0
      For [ZCNTRP]
         LBOBASI+=[F:ZCNTRP]BOBASI
      Next
      Filter [ZCNTRP]
      #Si habia bobinas asignadas y ha cambiado la cantidad se impide la modificacion
      If LBOBASI>0 and LBOBASI<>[M:POH2]ZQTYBOB(I)
         LINMOD=2
         Break
      Endif
   Else
   Endif
Next
If LINMOD=2
   Infbox "Linea "+num$(I+1)+" asignada a contenedor "+LNUMCNTR+", verifique cantidades"
   #OK=0
Endif
Return



$BORRA_LINPOH_CNTR
Delete [ZCNTRP] Where POHNUM=[M:POH0]POHNUM and POPLIN=[M:POH2]POPLIN(NOL)
If fstat
   Infbox "Error borrando linea contenedor [ZCNTRP]- fstat: "+num$(fstat)
   LOK=0
Endif
Delete [ZCNTRS] Where POHNUM=[M:POH0]POHNUM and POPLIN=[M:POH2]POPLIN(NOL)
If fstat
   Infbox "Error borrando linea contenedor [ZCNTRS] - fstat: "+num$(fstat)
   LOK=0
Endif
Return



Funprog HAY_CONTENEDOR(LPEDCOM)
Value Char LPEDCOM
Local Integer FILAS
If clalev([F:ZCNTRP])<=0 : Local File ZCONTAINP [ZCNTRP] : Endif
Filter [ZCNTRP]
Filter [ZCNTRP] Where POHNUM=LPEDCOM
FILAS=rowcount([ZCNTRP])
Filter [ZCNTRP]
End FILAS



#LNBRCNT -> numero de contenedores en que esta el pedido de compra
Subprog CTRL_CNTR(LPEDCOM,LPOPLIN,LPEDVTA,LSOPLIN,LNUMCNTR,POHENCNTR,POPENCNTR,LNBRCNTP,SOHENCNTR,WBOBASI)
Value Char LPEDCOM()
Value Integer LPOPLIN
Value Char LPEDVTA()
Value Integer LSOPLIN
Variable Char LNUMCNTR()
Variable Integer POHENCNTR
Variable Integer POPENCNTR
Variable Integer LNBRCNTP
Variable Integer SOHENCNTR,WBOBASI
Local Char LNUMAUX(25)

If clalev([F:ZCNTR]) <=0 : Local File ZCONTAINH [ZCNTR]  : Endif
If clalev([F:ZCNTRP])<=0 : Local File ZCONTAINP [ZCNTRP] : Endif
If clalev([F:ZCNTRS])<=0 : Local File ZCONTAINS [ZCNTRS] : Endif

LNBRCNTP=0
LNUMCNTR=""
POHENCNTR=0
POPENCNTR=0
Raz WBOBASI

If len(LPEDCOM)<>0
   Filter [ZCNTRP] Where POHNUM=LPEDCOM and POPLIN=LPOPLIN
   For [ZCNTRP]
      LNUMCNTR=[F:ZCNTRP]NUMCNTR
      POHENCNTR=2
      POPENCNTR=1
      WBOBASI=[ZCNTRP]BOBASI
      Break
   Next
   Filter [ZCNTRP]

   Filter [ZCNTRP] Where POHNUM=LPEDCOM
   LNUMAUX=""
   For [ZCNTRP]
      If LNUMAUX<>[F:ZCNTRP]NUMCNTR
        LNUMAUX=[F:ZCNTRP]NUMCNTR
        Read[ZCNTR]ZCNTR0=LNUMAUX
        If [ZCNTR]SITCNTR<5
          POHENCNTR=1
          LNBRCNTP+=1
        Endif
      Endif
   Next
   Filter [ZCNTRP]

   If LNUMAUX<>""
      #Si pedido en contenedor aunque linea no esté se retorna el numero de contenedor
      LNUMCNTR=LNUMAUX
   Endif
Endif
SOHENCNTR=0
If len(LPEDVTA)<>0
   Filter [ZCNTRS] Where SOHNUM=LPEDVTA and SOPLIN=LSOPLIN
   For [ZCNTRS]
      LNUMCNTR=[F:ZCNTRS]NUMCNTR
      SOHENCNTR=1
      Break
   Next
   Filter [ZCNTRS]
Endif
If POHENCNTR=2
   #Infbox "Linea de compra en contenedor: "+LNUMCNTR
Endif
If SOHENCNTR=2
   #Infbox "Linea de venta en contenedor: "+LNUMCNTR
Endif
End


$TEST_ANU
LOK=0
Call CTRL_CNTR([M:POH0]POHNUM,[M:POH2]POPLIN(NOL),"",0,LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
If LPOHENCNTR
   Call OUINON("Linea en contenedor: "+LNUMCNTR+". Se eliminara irreversiblemente esa relacion.\ Seguro?", LRESP) From GESECRAN
   If LRESP=2
      LOK=1
      Gosub BORRA_LINPOH_CNTR
   Endif
Endif
If LOK=0 mkstat=2  Endif
Return

Subprog C_NBLIG
Local Integer NOL, LRESP, LOK, LNBRCNTP
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
Local Char LNUMCNTR(25)
Case status
When 65     # Annulation simple
  NOL=nolign-1
  Gosub TEST_ANU
When 68,83  # Annulation multiple
   For NOL=nolign-1 To nolign1-1
    Gosub TEST_ANU
    If LOK=0 Break  Endif
   Next
When 73,82  # Insertion
    NOL=nolign-1
#    If GUSER="ADMIN" Infbox "DEPURAR (Subprog C_NBLIG)     [M:POH2]EXTRCPDAT(NOL)=" + num$([M:POH2]EXTRCPDAT(NOL)) Endif
    [M:POH2]ZESTA(NOL)="A"
Endcase
End

Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
[M:POH2]ZQTYBOB(nolign-1)=VALEUR
Gosub COMUN_KGS_M2
End

Subprog AM_ZANCHO(VALEUR)
Variable Decimal VALEUR
[M:POH2]ZANCHO(nolign-1)=VALEUR
Gosub COMUN_KGS_M2
# Z0001-03-04-01.ini
  Call COMPRUEBA_SKU([M:POH2]ITMREF(nolign-1),VALEUR,[M:POH2]ZLNGSTD(nolign-1),[M:POH2]ZMANDRIL(nolign-1))
# Z0001-03-04-01.fin
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
[M:POH2]ZLONGITUD(nolign-1)=VALEUR
Gosub COMUN_KGS_M2
# Z0001-03-04-01.ini
  Local Integer LONGSTD
  LONGSTD = func COMPRUEBA_LONG([M:POH2]ITMREF(nolign-1),VALEUR)
  If LONGSTD = 0 Then
    mkstat = 2
    Call ERREUR("La longitud"-num$(VALEUR)-"no está definida en ninguno de los intervalos definidos para el artículo"-[M:POH2]ITMREF(nolign-1)) From GESECRAN
  Else
    [M:POH2]ZLNGSTD(nolign-1) = LONGSTD
    Affzo [M:POH2]ZLNGSTD(nolign-1)
    Call COMPRUEBA_SKU([M:POH2]ITMREF(nolign-1),[M:POH2]ZANCHO(nolign-1),[M:POH2]ZLNGSTD(nolign-1),[M:POH2]ZMANDRIL(nolign-1))
  Endif
# Z0001-03-04-01.fin
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla POH2) 04/07/2022 18:39:19 (ADMIN)
######################################################################################
Subprog AM_ZMANDRIL(VALEUR)
Variable Decimal VALEUR

# Z0001-03-04-01.ini
  Call COMPRUEBA_SKU([M:POH2]ITMREF(nolign-1),[M:POH2]ZANCHO(nolign-1),[M:POH2]ZLNGSTD(nolign-1),VALEUR)
# Z0001-03-04-01.fin

End

$COMUN_KGS_M2
#JLPR 16-03-17
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR, LANCHO
Local Integer NOL, LNBRCNTP
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR, WBOBASI
Local Char LNUMCNTR(25)

NOL=nolign-1
LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LANCHO = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:POH2]ITMREF(NOL),[M:POH2]ZANCHO(NOL))

LSUPERFICIE=(LANCHO/1000)*[M:POH2]ZLONGITUD(NOL)
LVOLUMEN   =LSUPERFICIE*LFACTOR

#LSUPERFICIE=([M:POH2]ZANCHO(NOL)/1000)*VALEUR
#LVOLUMEN=([M:POH2]ZANCHO(NOL)/1000)*VALEUR*LFACTOR

If [M:POH2]ZQTYBOB(NOL)<>0
   If [F:ITM]STU="KG"
     #> MA 20181204 - redondeo cantidades a 4 decimales
      #[M:POH2]QTYUOM(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
      [M:POH2]QTYUOM(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
     #< MA
      [M:POH2]QTYSTU(NOL)=[M:POH2]QTYUOM(NOL)
   Endif
   If [F:ITM]STU="M2"
     #> MA 20181204 - redondeo cantidades a 4 decimales
      #[M:POH2]QTYUOM(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
      [M:POH2]QTYUOM(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LSUPERFICIE,0.0001)
     #< MA
      [M:POH2]QTYSTU(NOL)=[M:POH2]QTYUOM(NOL)
   Endif
   If [M:POH2]PUU(NOL)="KG"
     #> MA 20181204 - redondeo cantidades a 4 decimales
      #[M:POH2]QTYPUU(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LVOLUMEN,0.001)
      [M:POH2]QTYPUU(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LVOLUMEN,0.0001)
     #< MA
   Endif
   If [M:POH2]PUU(NOL)="M2"
     #> MA 20181204 - redondeo cantidades a 4 decimales
      #[M:POH2]QTYPUU(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
      [M:POH2]QTYPUU(NOL)=arr([M:POH2]ZQTYBOB(NOL)*LSUPERFICIE,0.0001)
     #< MA
      [M:POH2]QTYUOM(NOL)=[M:POH2]QTYPUU(NOL)
   Endif
   Affzo [M:POH2]QTYUOM(NOL)
   Affzo [M:POH2]QTYSTU(NOL)
   Affzo [M:POH2]QTYPUU(NOL)
Endif
If [M:POH0]POHNUM<>""
   Call CTRL_CNTR([M:POH0]POHNUM,[M:POH2]POPLIN(NOL),"",0,LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
Endif
If NOL>0
   [M:POH2]ZFORBOB(NOL)=[M:POH2]ZFORBOB(NOL-1)
Endif
Call INI_TARIF(NOL,"ITMREF") From SUBPOHB
Call RECH_TARIF ("POH",NOL) From TRTACHTAR1
Return

##############################################################
# Z0001-03-04-01
Funprog COMPRUEBA_LONG(PITM,PLONG)
Value Char    PITM
Value Decimal PLONG

  If !clalev([F:ZML0]) Then : Local File ZMLONG [F:ZML0] : Endif
  Filter [F:ZML0] Where ITMREF = PITM
  For [ZML0]
    If PLONG >= [F:ZML0]RANGINI and PLONG <= [F:ZML0]RANGFIN Then
      End [F:ZML0]LONG
      Filter [F:ZML0]
      Close Local File [ZML0]
    Endif
  Next
  Filter [F:ZML0]
  Close Local File [ZML0]
End 0

##############################################################
# Z0001-03-04-01
Subprog COMPRUEBA_SKU(PITM,PANCHO,PLONG,PMANDRIL)
Value Char    PITM
Value Integer PANCHO,PLONG,PMANDRIL

  If PANCHO <> 0 and PLONG <> 0 and PMANDRIL <> 0 Then
    If !clalev([F:ZMS0]) Then : Local File ZMSKU [F:ZMS0] : Endif
    Read [F:ZMS0]ZMSKU1 = PITM;PLONG;PANCHO;PMANDRIL
    If fstat <> 0 Then
      Local Char    LSKU(100)
      LSKU = ctrans(space$(4-len(PITM))+PITM,' ','0')+ctrans(space$(5-len(num$(PLONG)))+num$(PLONG),' ','0')+ctrans(space$(4-len(num$(PANCHO)))+num$(PANCHO),' ','0')+
&            ctrans(space$(3-len(num$(PMANDRIL)))+num$(PMANDRIL),' ','0')
      Local Integer LOK : LOK = 2
      Call OUINON("Se va a crear el SKU"-LSKU-"\żContinuar?",LOK) From GESECRAN
      If LOK = 2 Then
        [F:ZMS0]ITMREF  = PITM
        [F:ZMS0]LONG    = PLONG
        [F:ZMS0]ANCHO   = PANCHO
        [F:ZMS0]MANDRIL = PMANDRIL
        [F:ZMS0]SKU     = LSKU
        Trbegin [F:ZMS0]
        Write   [F:ZMS0]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
    Close Local File [ZMS0]
  Endif

End

