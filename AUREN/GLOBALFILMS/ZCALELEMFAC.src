#<AdxTL>@(#)0.0.0.0 $Revision$
# 06.409.695 - AMG.23122022.Llei 72022 impost del plàstic per envasos d’un sol ús
######################################################################################

$ACTION
Case ACTION
   When "AUTINVDEND"     :   Gosub AUTINVDEND
Endcase
Return

$AUTINVDEND

# 06.409.695.ini
  If [F:SIV]SALFCY = '100' Then
    If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
    If !clalev([F:ZITM]) Then : Local File ITMMASTER  [F:ZITM] : Endif
    If !clalev([F:ZADI]) Then : Local File ATABDIV    [F:ZADI] : Endif
    If !clalev([F:ZSID]) Then : Local File SINVOICED  [F:ZSID] : Endif
    Read [F:ZBPC]BPC0 = [F:SIV]BPCINV
    If !fstat Then

      [F:SIV]INVDTAAMT(2)=0

      Filter [F:ZSID] Where NUM=[F:SIH]NUM
        For [F:ZSID]
          [F:ZSID]ZKGPLASTAX = ([F:ZSID]ZCTDREALUS * [F:ZSID]ZPLASTICTAX) / 100
          Rewrite[F:ZSID]
           Local Char LDATESYS(15)
          LDATESYS = num$(year([F:SIV]INVDAT))+ctrans(space$(2-len(num$(month([F:SIV]INVDAT))))+num$(month([F:SIV]INVDAT)),' ','0')+ctrans(space$(2-len(num$(day([F:SIV]INVDAT))))+num$(day([F:SIV]
& INVDAT)),' ','0')

        Filter [F:ZADI] Where NUMTAB = 6007
        For [ZADI]
          If LDATESYS >= [F:ZADI]A1 and LDATESYS <= [F:ZADI]A2
            [F:ZSID]ZIMPPLASTAX = ar2([F:ZSID]ZKGPLASTAX * [F:ZADI]N1)
            Rewrite[F:ZSID]
          Else
            [F:ZSID]ZIMPPLASTAX = 0
            Rewrite[F:ZSID]
          Endif
        Next
        Filter [F:ZADI]
        [F:SIV]INVDTAAMT(2) += ar2([F:ZSID]ZIMPPLASTAX)
        Next
     Endif
    Close Local File [ZBPC],[ZITM],[ZADI],[ZSID]
  Endif
# 06.409.695.fin


Return
