#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Gestión de la máscara ZPGOFS1 (Especifico)

#LOS EVENTOS DE VENTANA SE GESTIONAN EN EL SPECIFICO INDICADO EN LA accion QUE LLAMA A LA VENTANA
$BUSCAR
Onerrgo ERRORES_FIN
#----- Apertura del fichero de traza y escritura de las selecciones -----#
Call OUVRE_TRACE("Propuesta OF")  From LECFIC
Call ECR_TRACE(" ",0)             From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Propuesta OF   "+ format$(GFMD,date$) + " " + time$,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0)             From GESECRAN
If [M:ZGOFS2]JCOMBINAR(0)=2
  Call ECR_TRACE("Combinando JUMBOS   ",0)   From GESECRAN
Else
  Call ECR_TRACE("SIN combinar jumbos ",0)   From GESECRAN
Endif
If [M:ZGOFS2]SMINRES=2
  Call ECR_TRACE("Prima minimizar restos. ESto significa que intentaremos combinar hasta que desperdicio=0, lo que nos hará tener mas stock   ",0)   From GESECRAN
Else
  Call ECR_TRACE("Prima minimizar stock.  ESto significa que dejaremos de combinar con ANCHOS A, en cuanto desperdicio < maximo indicado en la jumbo, lo que nos hará tener mas desperdicio   ",0)
& From GESECRAN
Endif


Local Integer RTOPE,F,RPDTE
RPDTE=0  # Lo usraé para detectar si hemos entrado en buvcle sin fin en COMBINAR

Sorta [M:ZGOFS2]NELE [M:ZGOFS2]NELE Order By [M:ZGOFS2]ANCHO(indice)
Affzo [M:ZGOFS2]10

Sorta [M:ZGOFS2]NJUM [M:ZGOFS2]NJUM Order By [M:ZGOFS2]JANCHO(indice)#,[M:ZGOFS2]JLARGO(indice)
Affzo [M:ZGOFS2]5

Sorta [M:ZGOFS2]NTIA [M:ZGOFS2]NTIA Order By [M:ZGOFS2]NANCHO(indice)
Affzo [M:ZGOFS2]35

Call VACIAR_CALCULOS

Raz RTOPE
#Infbox "debug"
Call ECR_TRACE("Articulo "+func SPEZGOFS.ARTICULO,0)   From GESECRAN
# Mostrar Largos seleccionados
For F=0 To [M:ZGOFS2]NLAR-1
  If [M:ZGOFS2]LSEL(F)=2 or [M:ZGOFS2]LAGRUPAR(F)=2
  Call ECR_TRACE("Jumbo Ancho "+num$([M:ZGOFS2]LLARGO(F)),0)   From GESECRAN
  Endif
Next
# Mostrar Jumbos
For F=0 To [M:ZGOFS2]NJUM-1
  Call ECR_TRACE("Jumbo Ancho "+num$([M:ZGOFS2]JANCHO(F)),0)   From GESECRAN
Next
# Mostrar bobinas
Local Char W(255)
Raz W
Call ECR_TRACE("Detalle " + num$([M:ZGOFS2]NELE) +" bobinas a fabricar",0)   From GESECRAN
For F=0 To [M:ZGOFS2]NELE-1
  If W<>""
    W+="-"
  Endif
  W+=format$("N0:4",[M:ZGOFS2]ANCHO(F))
  If len(W)>250
  Call ECR_TRACE(W,0)   From GESECRAN
  Raz W
  Endif
Next
If W<>""
  Call ECR_TRACE(W,0)   From GESECRAN
  Raz W
Endif
Call ECR_TRACE("Total bobinas a fabricar "+num$([M:ZGOFS2]NELE),0)   From GESECRAN


For F=0 To [M:ZGOFS2]NJUM-1
  If [M:ZGOFS2]JANCHO(F)>0
    If RTOPE<>[M:ZGOFS2]JANCHO(F)
      If RTOPE>0 and [M:ZGOFS2]JCOMBINAR(F)=1  # Dejar lineas en blanco
        [M:ZGOFS2]CNUM([M:ZGOFS2]NCOM) = [M:ZGOFS2]NCOM+1
        [M:ZGOFS2]NCOM+=1
        [M:ZGOFS2]NOPC+=1
        [M:ZGOFS2]NSUG+=1
      Endif
      RTOPE=[M:ZGOFS2]JANCHO(F)
#      If BOUT="5"
        Call ECR_TRACE(string$(70,"="),0) From GESECRAN
        Call ECR_TRACE("Ancho jumbo="+ num$(RTOPE)+"   Merma ancho mínima de="+num$([M:ZGOFS2]SMERMA) +"  Comienzo cálculo combinaciones elementos que no superen ancho " + num$(RTOPE-[M:ZGOFS2]SMERMA)
& + " y un desperdicio máximo de " + num$([M:ZGOFS2]JMERMAC(F)),0)   From GESECRAN
        Call COMBINAR_2 (RTOPE,[M:ZGOFS2]JMERMAC(F),RPDTE) From SPEZGOFSB
        If RPDTE=-1
          Call FERME_TRACE From LECFIC
          Infbox "Revise traza. Proceso abortado por entrar en   BUCLE SIN FIN"
          Return
        Endif
#        Return
#      Else
#        Call COMBINAR (RTOPE-[M:ZGOFS2]SMERMA)
#      Endif
      If [M:ZGOFS2]JCOMBINAR(F)=1
        Call OPCIONES (RTOPE)
      Endif
    Endif
  Endif
Next
If RTOPE>0
  If [M:ZGOFS2]JCOMBINAR(0)=2
    Call OPCIONES (0)
    Call MEJOR_OPCION (0)
  Else
    Call MEJOR_OPCION (1)
  Endif
Endif

Call RESUMEN From SPEZGOFS4
Call FERME_TRACE From LECFIC
TRA=1  # para que se vea
Onerrgo
Return



Subprog OPCIONES (TOPE)
Value Integer TOPE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Partiendo de las combinaciones anteriores, comenzamos a calcular posibles opciones que nos permitan fabricar las bobinas indicadas      (Subprog OPCIONES (TOPE="+num$(TOPE)+")",0)
& From GESECRAN
Local Integer OPC,OPC_NUM,MEJOR_OPC(4)
Raz OPC_NUM,MEJOR_OPC
MEJOR_OPC(0)=-1
#1ş por orden de creacion
Call OPCIONES_MONTAR (TOPE,OPC_NUM,MEJOR_OPC)
#2ş por orden DIFŞ asc
Call ORDENAR_COMB (TOPE)
Call OPCIONES_MONTAR (TOPE,OPC_NUM,MEJOR_OPC)
Call ORDENAR_COMB (-1)
#Infbox "debug"
Call OPCIONES_SUPRIMIR(OPC,TOPE)
Call ACTU_OPC_SUG (TOPE,OPC)
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
End


Subprog OPCIONES_SUPRIMIR (OPC, TOPE)
Variable Integer OPC
Value Integer TOPE
Call ECR_TRACE("De las combinaciones posibles anteriores, tan solo sugiero las mas óptimas      (Subprog OPCIONES_SUPRIMIR (TOPE="+num$(TOPE)+",OPC="+num$(OPC)+"))",0)   From GESECRAN
Call ECR_TRACE("Puede haber varias, con el mismo desperdicio y nş trozos, pero con anchos sobrantes diferentes   (Ej.  20-30  =  40-10, ambos tienen un sobrante de 50 en 2 trozos",0)   From GESECRAN
#Suprimir las opciones que no incluyan todos los elementos
Local Integer F,RC,TE,TR,TD,TA
# Actualizo Totales x Opción
RC=-1
For F=[M:ZGOFS2]NOPC-1 To 0 Step -1
  If [M:ZGOFS2]OANCHOJ(F)=TOPE or TOPE=0
    If RC<>[M:ZGOFS2]OPCION(F)
      RC=[M:ZGOFS2]OPCION(F)
      TE=[M:ZGOFS2]OELET(F)
      TD=[M:ZGOFS2]ODIFT(F)
      TR=[M:ZGOFS2]OTROZOS(F)
      TA=[M:ZGOFS2]OANCHOA(F)
      If [M:ZGOFS2]OELET(F)=[M:ZGOFS2]NELE
        Call DETALLE_TROZOS(TOPE,RC)
      Endif
    Else
      [M:ZGOFS2]OELET(F)  =TE
      [M:ZGOFS2]ODIFT(F)  =TD
      [M:ZGOFS2]OTROZOS(F)=TR
      [M:ZGOFS2]OANCHOA(F)=TA
    Endif
  Endif
Next
# Suprimo opciones cuyo "Total elementos < Elementos a cortar"
# Calculo mejor opcion con el menor ODIFT y OTROZOS
TD=-1  # Total sobrante
TR=-1  # Nş de trozos
TA=-1  # Total anchos stock
OPC=-1
For F=0 To [M:ZGOFS2]NOPC-1
  If [M:ZGOFS2]OANCHOJ(F)=TOPE or TOPE=0
    If [M:ZGOFS2]OELET(F)<[M:ZGOFS2]NELE
      Chgstl [M:ZGOFS2]NOPC(F) With "TDB01" #"ZJLPR"#
    Else
      If [M:ZGOFS2]ODIFT(F)<TD or TD=-1
        TD =[M:ZGOFS2]ODIFT(F)
        TR =[M:ZGOFS2]OTROZOS(F)
        OPC=[M:ZGOFS2]OPCION(F)
        TA =[M:ZGOFS2]OANCHOA(F)
      Elsif [M:ZGOFS2]ODIFT(F)=TD and [M:ZGOFS2]OTROZOS(F)<TR
        TR= [M:ZGOFS2]OTROZOS(F)
        OPC=[M:ZGOFS2]OPCION(F)
        TA =[M:ZGOFS2]OANCHOA(F)
      Elsif [M:ZGOFS2]ODIFT(F)=TD and [M:ZGOFS2]OTROZOS(F)=TR  and [M:ZGOFS2]OANCHOA(F)<TA
        OPC=[M:ZGOFS2]OPCION(F)
        TA =[M:ZGOFS2]OANCHOA(F)
      Endif
    Endif
  Endif
Next
# Marco la opción y Paso las opciones a la nueva rejilla
Local Integer L
#Infbox "debug"
For F=0 To [M:ZGOFS2]NOPC-1
  If ([M:ZGOFS2]OANCHOJ(F)=TOPE or TOPE=0) and [M:ZGOFS2]OELET(F)=[M:ZGOFS2]NELE
    If [M:ZGOFS2]ODIFT(F)=TD and [M:ZGOFS2]OTROZOS(F)=TR and not func EXISTE_DETALLE_TROZOS (TOPE,[M:ZGOFS2]ODIFTRZ(F),[M:ZGOFS2]OPCION(F))
      L=[M:ZGOFS2]NSUG
      [M:ZGOFS2]SANCHOJ(L) = [M:ZGOFS2]OANCHOJ(F)
      [M:ZGOFS2]SOPCION(L) = [M:ZGOFS2]OPCION(F)
      [M:ZGOFS2]SCOMBI(L)  = [M:ZGOFS2]OCOMBI(F)
      [M:ZGOFS2]SANADIR(L) = [M:ZGOFS2]OANADIR(F)
      [M:ZGOFS2]SANCHO(L)  = [M:ZGOFS2]OANCHO(F)
      [M:ZGOFS2]SDIF(L)    = [M:ZGOFS2]ODIF(F)
      [M:ZGOFS2]SDIFT(L)   = [M:ZGOFS2]ODIFT(F)
      [M:ZGOFS2]STROZOS(L) = [M:ZGOFS2]OTROZOS(F)
      [M:ZGOFS2]SDIFTRZ(L) = [M:ZGOFS2]ODIFTRZ(F)
      [M:ZGOFS2]SANCHOA(L) = [M:ZGOFS2]OANCHOA(F)
      [M:ZGOFS2]NSUG+=1
    Endif
    If [M:ZGOFS2]OPCION(F)=OPC
      Chgstl [M:ZGOFS2]NOPC(F) With "CAZ"
    Endif
  Endif
Next
Affzo [M:ZGOFS2]25
Affzo [M:ZGOFS2]30
End

Funprog EXISTE_DETALLE_TROZOS (TOPE,DET,OPC)
Value Integer TOPE,OPC
Value Char DET
Local Integer EXISTE,F
EXISTE =0
If DET<>""
  For F=0 To [M:ZGOFS2]NSUG-1
    If ([M:ZGOFS2]SANCHOJ(F)=TOPE or TOPE=0) and [M:ZGOFS2]SDIFTRZ(F)=DET and [M:ZGOFS2]SOPCION(F) <>OPC
      EXISTE =1
      Break
    Endif
  Next
Endif
End EXISTE

