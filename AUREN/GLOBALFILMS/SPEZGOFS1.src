Subprog ORDENAR_COMB (TOPE)
Value Integer TOPE
# Ordeno Ancho_Combinaciones por DIFŞ ASC, para ir montando con las mas optimas
Case TOPE
When 0
  Sorta [M:ZGOFS2]NCOM [M:ZGOFS2]NCOM Order By [M:ZGOFS2]CDIF(indice),[M:ZGOFS2]CANCHOJ(indice)
When Default
  Sorta [M:ZGOFS2]NCOM [M:ZGOFS2]NCOM Order By [M:ZGOFS2]CNUM(indice)
Endcase
Affzo [M:ZGOFS2]20
End


Subprog MEJOR_OPCION (TOPE)
Value Integer TOPE
Local Integer F,OPCION_MEJOR(5),OK
Raz OPCION_MEJOR
# Determino la mejor opción
#Infbox "debug"
For F=0 To [M:ZGOFS2]NSUG-1
  If [M:ZGOFS2]SCOMBI(F)<>""
    # Mejor opción = Menor diferencia y menor nş de trozos
#    If OPCION_MEJOR(2)=0 or ([M:ZGOFS2]SDIFAT(F)<OPCION_MEJOR(0) and [M:ZGOFS2]STROZOSA(F)<=OPCION_MEJOR(1))
#      OPCION_MEJOR(0)=[M:ZGOFS2]SDIFAT(F)
#      OPCION_MEJOR(1)=[M:ZGOFS2]STROZOSA(F)
#      OPCION_MEJOR(2)=[M:ZGOFS2]SOPCION(F)
#      OPCION_MEJOR(3)=[M:ZGOFS2]SANCHOJ(F)
#    Endif
    OK=0
    If [M:ZGOFS2]SDIFT(F)<OPCION_MEJOR(0) or OPCION_MEJOR(2)=0
      OK=1
    Elsif [M:ZGOFS2]SDIFT(F)=OPCION_MEJOR(0) and [M:ZGOFS2]STROZOS(F)<OPCION_MEJOR(1)
      OK=1
    Elsif [M:ZGOFS2]SDIFT(F)=OPCION_MEJOR(0) and [M:ZGOFS2]STROZOS(F)=OPCION_MEJOR(1) and [M:ZGOFS2]SANCHOA(F)<OPCION_MEJOR(4)
#      If [M:ZGOFS2]SMINSTK=2 and [M:ZGOFS2]SANCHOA(F)<OPCION_MEJOR(4)
        OK=1
#      Endif
    Endif

    If OK
      OPCION_MEJOR(0)=[M:ZGOFS2]SDIFT(F)
      OPCION_MEJOR(1)=[M:ZGOFS2]STROZOS(F)
      OPCION_MEJOR(2)=[M:ZGOFS2]SOPCION(F)
      OPCION_MEJOR(3)=[M:ZGOFS2]SANCHOJ(F)
      OPCION_MEJOR(4)=[M:ZGOFS2]SANCHOA(F)
    Endif
  Endif
Next
# Marco la mejor opcion
For F=0 To [M:ZGOFS2]NSUG-1
  If [M:ZGOFS2]SOPCION(F)=OPCION_MEJOR(2) and ([M:ZGOFS2]SANCHOJ(F)=OPCION_MEJOR(3) or TOPE=0)
    [M:ZGOFS2]SSEL(F)=2
  Endif
Next F

# Ordenar
#Sorta [M:ZGOFS2]NSUG [M:ZGOFS2]NSUG Order By [M:ZGOFS2]SDIFAT(indice),[M:ZGOFS2]SOPCION(indice),[M:ZGOFS2]SDIFA(indice)
Affzo [M:ZGOFS2]30
End


