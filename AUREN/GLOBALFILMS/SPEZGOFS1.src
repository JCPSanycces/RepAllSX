Subprog METER_ANCHO_A (RESTO,ANC_A,NUM_A)
Value Integer RESTO
Variable Integer ANC_A,NUM_A
Local Decimal SOBRANTE
Local Integer NUM,DIF,DIF_ELE
Raz ANC_A,NUM_A,DIF
# Proponer la opcion con menor desperdicio
For F=0 To [M:ZGOFS2]NTIA-1
  If [M:ZGOFS2]NSEL(F)=2
    NUM=int(RESTO/[M:ZGOFS2]NANCHO(F))
    If NUM>0
      DIF_ELE=mod(RESTO,[M:ZGOFS2]NANCHO(F))
      If DIF_ELE<DIF or DIF=0
        DIF_ELE=DIF
        ANC_A=[M:ZGOFS2]NANCHO(F)
        NUM_A=NUM
      Endif
    Else
      Break
    Endif
  Endif
Next
End

Funprog SACAR_MENOR_A
Local Integer F,MENOR
For F=0 To [M:ZGOFS2]NTIA-1
  If [M:ZGOFS2]NSEL(F)=2
    MENOR=[M:ZGOFS2]NANCHO(F)
    Break # Rejilla ordenada, luego el primer elemento marcado es el menor
  Endif
Next
End MENOR


Subprog DETALLE_TROZOS(TOPE,OPC)
Value Integer TOPE,OPC
Local Char D(255)
Local Integer T(100),E
Raz D,T,E
#Infbox "debug DETALLE_TROZOS"
# Me guardo los trozos
For F=0 To [M:ZGOFS2]NOPC-1
  If ([M:ZGOFS2]OANCHOJ(F)=TOPE or TOPE=0) and [M:ZGOFS2]OPCION(F)=OPC
    If [M:ZGOFS2]ODIF(F)>0
      T(E)=[M:ZGOFS2]ODIF(F)
      E+=1
      If E>=int(255/5)
        If GUSER="ADMIN"
          Infbox "Aviso informativo Det.Trozos.  Opcion " + num$(OPC)+" ha superado limite de " + num$(int(255/5)) + " trozos"
        Endif
        Break
      Endif
    Endif
  Elsif E>0
    Break
  Endif
Next
D= func DETALLE_TROZOS_MONTAR(T)
#Actualizo rejilla
For F=0 To [M:ZGOFS2]NOPC-1
  If ([M:ZGOFS2]OANCHOJ(F)=TOPE or TOPE=0) and [M:ZGOFS2]OPCION(F)=OPC
    [M:ZGOFS2]ODIFTRZ(F)=D
  Endif
Next
End

Funprog DETALLE_TROZOS_MONTAR(T)
Value Integer T
Local Char D(255)
Raz D
# Ordenar
Sorta T
# Monto el detalle
For F=0 To dim(T)-1
  If T(F)<>0
    If D<>""
      D+="-"
    Endif
    D+=format$("N0:4",T(F))
  Endif
Next
End D

Subprog OPCIONES_MONTAR(TOPE,OPC_NUM,MEJOR_OPC)
Value Integer TOPE
Variable Integer OPC_NUM,MEJOR_OPC
Onerrgo ERRORES_FIN
Local Integer F,L,A,SALTAR,INI,Z,GUARDAR_ULTIMO
Local Integer O,TDIF,ELEM,TELEM,TROZOS,COMPLETO, ULTIMO_ELE_COMB
Call ECR_TRACE("Partiendo de las combinaciones anteriores, comenzamos a calcular posibles opciones que nos permitan fabricar las bobinas indicadas      (Subprog OPCIONES_MONTAR (TOPE="+num$(TOPE)+
& ",OPC_NUM,MEJOR_OPC))",0)   From GESECRAN
For F=0 To [M:ZGOFS2]NCOM-1
  If [M:ZGOFS2]CANCHOJ(F)=TOPE or TOPE=0
    INI=F
#    If [M:ZGOFS2]COMBI(F)="08400840"
#      Infbox "DEBUG"
#    Endif
    While INI<=[M:ZGOFS2]NCOM-1
      Call QUITAR_MARCAS(0)
      TDIF=0:TELEM=0:TROZOS=0
      A=0:SALTAR=0:ULTIMO_ELE_COMB=0
      GUARDAR_ULTIMO=1  # NO se guardará ULTIMO_ELE_COMB cuando estemos buscando ""mas opciones del elemento F""
      For L=INI To [M:ZGOFS2]NCOM-1
        If [M:ZGOFS2]CANCHOJ(L)=TOPE or TOPE=0
          If INI>F and TELEM=0 # Para que lo haga solo la 1Ş vez
            #Estamos buscando mas opciones del elememto F
            Z=F
            GUARDAR_ULTIMO=0
            Gosub GUARDAR_ELE_COMBI
            GUARDAR_ULTIMO=1
          Endif
          Z=L
          Gosub GUARDAR_ELE_COMBI
          If COMPLETO
            Break
          Endif
        Endif
      Next
      If A>0
        Call PASAR_COMBI(TOPE,OPC_NUM,MEJOR_OPC)
      Endif
      If ULTIMO_ELE_COMB>0 and not COMPLETO
        INI=ULTIMO_ELE_COMB+1
      Else
        INI=L+1
      Endif
    Wend
  Endif
Next
Affzo [M:ZGOFS2]25
Onerrgo
End

$GUARDAR_ELE_COMBI
If func MARCAR (Z,ELEM,OPC_NUM+1,COMPLETO,5)
  #Saltarnos las combinaciones cuyo primer elemento ya exista  ===>   << 06.09.16  JLPR     no se usa
  If A=0
    Call PASAR_COMBI(TOPE,OPC_NUM,MEJOR_OPC)
#        SALTAR=func OPCION_EXISTENTE([M:ZGOFS2]COMBI(L))
#        If not SALTAR
      OPC_NUM+=1
#      If OPC_NUM=98
#        Infbox "Debug  OPC_num=98"
#      Endif

#        Endif
#        Infbox "SALTAR=" + num$(SALTAR) + "  L" + num$(L) + "   [M:ZGOFS2]COMBI(L)=" + [M:ZGOFS2]COMBI(L)
  Endif
  A+=1 # Para saber que se han ańadido opciones
  If not SALTAR
    #O=[M:ZGOFS2]NOPC
    O=[M:ZGOFS2]NTMP
    TDIF+= [M:ZGOFS2]CDIF(Z)
    TELEM+=ELEM
    If [M:ZGOFS2]CDIF(Z)<>0
      TROZOS+=1
    Endif
#    [M:ZGOFS2]OANCHOJ(O) = [M:ZGOFS2]CANCHOJ(Z)
#    [M:ZGOFS2]OPCION(O)  = OPC_NUM
#    [M:ZGOFS2]ONCOM(O)   = Z+1
#    [M:ZGOFS2]OCOMBI(O)  = func COMBI_TXT([M:ZGOFS2]COMBI(Z))
#    [M:ZGOFS2]ODIF(O)    = [M:ZGOFS2]CDIF(Z)
#    [M:ZGOFS2]ODIFT(O)   = TDIF
#    [M:ZGOFS2]OELE(O)    = A
#    [M:ZGOFS2]OELET(O)   = TELEM
#    [M:ZGOFS2]OTROZOS(O) = TROZOS
#
#    [M:ZGOFS2]NOPC+=1
    [M:ZGOFS2]TANCHOJ(O) = [M:ZGOFS2]CANCHOJ(Z)
    [M:ZGOFS2]TOPCION(O) = OPC_NUM
    [M:ZGOFS2]TNCOM(O)   = Z+1
    [M:ZGOFS2]TCOMBI(O)  = [M:ZGOFS2]COMBI(Z) #func COMBI_TXT([M:ZGOFS2]COMBI(Z))
    [M:ZGOFS2]TDIF(O)    = [M:ZGOFS2]CDIF(Z)
    [M:ZGOFS2]TDIFT(O)   = TDIF
    [M:ZGOFS2]TELE(O)    = A
    [M:ZGOFS2]TELET(O)   = TELEM
    [M:ZGOFS2]TTROZOS(O) = TROZOS
    [M:ZGOFS2]TANADIR(O) = [M:ZGOFS2]COMBA(Z)
    [M:ZGOFS2]TANCHOA(O) = [M:ZGOFS2]CANCHOA(Z)

    [M:ZGOFS2]NTMP+=1

## AUREN - Incidencia 05.871.331 -> aumentar nş lineas de 100 a 500
    #If [M:ZGOFS2]NTMP>=100
    #  Infbox "Superado limite de 100     OPC_NUM = " + num$(OPC_NUM) + "    [M:ZGOFS2]CANCHOJ(Z)=" + num$([M:ZGOFS2]CANCHOJ(Z))
    #Endif
    If [M:ZGOFS2]NTMP>=500
      Infbox "Superado limite de 500     OPC_NUM = " + num$(OPC_NUM) + "    [M:ZGOFS2]CANCHOJ(Z)=" + num$([M:ZGOFS2]CANCHOJ(Z))
    Endif
## AUREN - Incidencia 05.871.331 -> aumentar nş lineas de 100 a 500

#        Infbox "OPC_NUM=" + num$(OPC_NUM) + "  z" + num$(z) + "   OCOMBI=" + [M:ZGOFS2]OCOMBI(O) + "   TDIF="+num$(TDIF)
    If GUARDAR_ULTIMO
      ULTIMO_ELE_COMB=Z
    Endif
  Endif
Endif
Return

Subprog PASAR_COMBI(TOPE,OPC,MEJOR_OPC)
Value Integer TOPE,OPC
Variable Integer MEJOR_OPC
Local Integer F,ULT,OK
OK=0
ULT=[M:ZGOFS2]NTMP-1
If ULT>=0
  If [M:ZGOFS2]TELET(ULT)=[M:ZGOFS2]NELE
    Call PASAR_COMBI_ACTU
    If [M:ZGOFS2]TDIFT(ULT)<MEJOR_OPC(1) or MEJOR_OPC(0)=-1
      OK=1
    Elsif [M:ZGOFS2]TDIFT(ULT)=MEJOR_OPC(1) and [M:ZGOFS2]TTROZOS(ULT)<MEJOR_OPC(2)
      OK=1
    Elsif [M:ZGOFS2]TDIFT(ULT)=MEJOR_OPC(1) and [M:ZGOFS2]TTROZOS(ULT)=MEJOR_OPC(2)  and [M:ZGOFS2]TANCHOA(ULT)<MEJOR_OPC(3)  # and [M:ZGOFS2]SMINSTK=2
      OK=1
    Endif
    Call ECR_TRACE("Pasando combinacion      (Subprog PASAR_COMBI (TOPE="+num$(TOPE)+",OPC="+num$(OPC)+",MEJOR_OPC))",0)   From GESECRAN
    Call ECR_TRACE("Total difŞ="+num$([M:ZGOFS2]TDIFT(ULT))+"/"+num$(MEJOR_OPC(1))+"     nş trozos="+num$([M:ZGOFS2]TTROZOS(ULT))+"/"+num$(MEJOR_OPC(2))+"     Suma anchos stock="+num$([M:ZGOFS2]
& TANCHOA(ULT))+"/"+num$(MEJOR_OPC(3)),0)   From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Endif
Endif
If OK
  MEJOR_OPC(0)=0
  MEJOR_OPC(1)=[M:ZGOFS2]TDIFT(ULT)
  MEJOR_OPC(2)=[M:ZGOFS2]TTROZOS(ULT)
  MEJOR_OPC(3)=[M:ZGOFS2]TANCHOA(ULT)
  # Pasar
  For F=0 To ULT
    O=[M:ZGOFS2]NOPC
    [M:ZGOFS2]OANCHOJ(O) = [M:ZGOFS2]TANCHOJ(F)
    [M:ZGOFS2]OPCION(O)  = [M:ZGOFS2]TOPCION(F)
    [M:ZGOFS2]ONCOM(O)   = [M:ZGOFS2]TNCOM(F)
    [M:ZGOFS2]OCOMBI(O)  = [M:ZGOFS2]TCOMBI(F)
    [M:ZGOFS2]ODIF(O)    = [M:ZGOFS2]TDIF(F)
    [M:ZGOFS2]ODIFT(O)   = [M:ZGOFS2]TDIFT(ULT)
    [M:ZGOFS2]OELE(O)    = [M:ZGOFS2]TELE(F)
    [M:ZGOFS2]OELET(O)   = [M:ZGOFS2]TELET(ULT)
    [M:ZGOFS2]OTROZOS(O) = [M:ZGOFS2]TTROZOS(ULT)
    [M:ZGOFS2]OANADIR(O) = [M:ZGOFS2]TANADIR(F)
    [M:ZGOFS2]OANCHO(O)  = [M:ZGOFS2]TANCHO(F)
    [M:ZGOFS2]OANCHOA(O) = [M:ZGOFS2]TANCHOA(ULT)

    [M:ZGOFS2]NOPC+=1
    If [M:ZGOFS2]NOPC>=8000
      Infbox "Se hasuperado el limite de opciones posibles ([M:ZGOFS2]NOPC>=8000)"
    Endif
  Next
  Call DETALLE_TROZOS(TOPE,OPC)
Endif
# Borrar
Raz [M:ZGOFS2]NTMP
Effzo [M:ZGOFS2]45
End

Subprog PASAR_COMBI_ACTU
Local Integer F,TDIF,TTRZ,TANA
#Determinar calculo de sobrante y trozos para saber si es mas optima que combinacion anterior
# 1ş Actualizo Ancho lŞ - sobrante lŞ y cuento trozos
Raz TDIF,TTRZ,TANA
For F=0 To [M:ZGOFS2]NTMP-1
  [M:ZGOFS2]TANCHO(F) = func SPEZGOFSA.SUMAR_ANCHOS_COMB([M:ZGOFS2]TCOMBI(F),[M:ZGOFS2]TANADIR(F),5)
  [M:ZGOFS2]TDIF(F)   = [M:ZGOFS2]TANCHOJ(F) - [M:ZGOFS2]SMERMA - [M:ZGOFS2]TANCHO(F)
  TDIF+= [M:ZGOFS2]TDIF(F)
  If [M:ZGOFS2]TDIF(F)>0
    TTRZ+=1
  Endif
  TANA+= func SPEZGOFSA.SUMAR_ANCHOS_COMB([M:ZGOFS2]TANADIR(F),"",5)
Next
# 2ş Actualizo Total sobrante & trozos combinación & Anchos A
For F=0 To [M:ZGOFS2]NTMP-1
  [M:ZGOFS2]TDIFT(F)  = TDIF
  [M:ZGOFS2]TTROZOS(F)= TTRZ
  [M:ZGOFS2]TANCHOA(F)= TANA
Next
End



Funprog COMBI_TXT (C)
Value Char C
Local Char T(255)
Raz T
For H=1 To len(C) Step 4
  If T<>""  :  T+="-"   :   Endif
  T+=mid$(C,H,4)
Next
End T

#Funprog OPCION_EXISTENTE(C)
#Value Char C
#Local Integer F,SALTAR
#SALTAR=0
##Infbox "C=" + C
#For F=0 To [M:ZGOFS2]NCOM-1
#  If  [M:ZGOFS2]OELE(F)=1 and  [M:ZGOFS2]OCOMBI(F)=C
#    SALTAR=1
#    Break
#  Endif
#Next
#End SALTAR

Funprog MARCAR(F,ELEM,OPC,COMPLETO,L)
Value Integer F,OPC,L
Variable Integer ELEM,COMPLETO
Local Integer I, OK, OK_ELE
Local Char T(255),ELE(4)
T=[M:ZGOFS2]COMBI(F)
OK=1
ELEM=0
#Para ser OK, todos los elementos de la combinacion tienen que poder asignarse
For I=1 To len(T) Step L
  ELE=mid$(T,I,4)
  OK_ELE=0
  ELEM+=1
  For K=0 To [M:ZGOFS2]NELE-1
    If [M:ZGOFS2]ANCHO(K)=val(ELE) and [M:ZGOFS2]ASIGNADA(K)=0
      [M:ZGOFS2]ASIGNADA(K)=-1
      OK_ELE=1
#      Infbox "t="+T + "  ele="+ELE
      Break
    Endif
  Next
  If not OK_ELE
    OK=0
    Call QUITAR_MARCAS (-1)
    Break
  Endif
Next
Call QUITAR_MARCAS (OPC)
#Indicar si con este elemento completamos la fabricacion de todas las bobinas, para empezar de nuevo a partir del siguiente, en caso de haber marcado la opcion de combinar diferentes ANCHOS de jumbo
# (840x2+1000x2 = 1680x1+2000x1)
COMPLETO=1
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0
    COMPLETO=0
    Break
  Endif
Next
End OK




Subprog QUITAR_MARCAS(V)
Value Integer V
Local Integer F
For F=0 To [M:ZGOFS2]NELE-1
  Case V
  When 0       # Vaciar, para siguiente opción
    [M:ZGOFS2]ASIGNADA(F)=V
  When -1      # Desasignar, al no haberse podido completar la combinacion
    If [M:ZGOFS2]ASIGNADA(F)=V
      [M:ZGOFS2]ASIGNADA(F)=0
    Endif
  When Default # Cambiar de -1 al siguiente nş de opcion
    If [M:ZGOFS2]ASIGNADA(F)=-1
      [M:ZGOFS2]ASIGNADA(F)=V
    Endif
  Endcase
Next
End



Subprog COMBINAR(TOPE)
Value Integer TOPE     # Ancho jumbo - Merma ancho minimo por temas de margenes al fabricar
Local Integer F, DIF_ANC(100),TA,RA
Local Integer TELE, NPOS,NORD, NELE, ELEP,ELEO
Local Char COMB(255)
Onerrgo ERRORES_FIN
# Se asume que los elementos nos vienn ordenados  ASC

#If not func ZCOMUN.CONTINUAR
#  End
#Endif



#Empezamos a hacer combinaciones de elementos, que no superen el "TOPE ANCHO"
TELE=[M:ZGOFS2]NELE-1
NPOS=0                   # Posicion elemento
NORD=NPOS+1              # Elemento a integrar en combinación
#TOPE=[M:ZGOFS2]ANCHOMAX  # Tope ancho
COMB=""

# WHILE  condi .... WEND
# REPEAT       .... UNTIL condi
# Por cada elemento, haga todas las posibles combinaciones, para ello tengo
#   POS, para indicar cada elemento
#   ORD, para indicar posicion en la que empiezo
#   ELE, para indicar elemento a combinar
While NPOS<=TELE
  # Sumamos elemento marcado como POS
  ELEP=[M:ZGOFS2]ANCHO(NPOS)
  TANC=ELEP
  COMB=format$("N0:4",ELEP)  # Ningun elemento puede ser superior al TOPE
  NORD=NPOS+1
  NELE=NORD
#  Infbox "NPOS=" + num$(NPOS+1)
  While TANC<=TOPE
    ELEO=[M:ZGOFS2]ANCHO(NELE)
#    Infbox "NPOS=" + num$(NPOS+1) + "(" + num$(ELEP) +  ")   NORD="+num$(NORD+1) + "     NELE=" + num$(NELE+1) +"(" + num$(ELEO) +  ")    TANC+ELEO=" + num$(TANC+ELEO)
    If TANC+ELEO>TOPE or NELE>TELE
      Gosub GUARDAR_COMBI
      Gosub COMBI_POSIBLE
      NORD+=1
      NELE=NORD
      ELEO=[M:ZGOFS2]ANCHO(NELE)
      COMB=format$("N0:4",ELEP)  # Ningun elemento puede ser superior al TOPE
      TANC=ELEP
      If NORD>TELE or ELEP+ELEO>TOPE
#        NPOS+=1
        Break
      Endif
    Endif

    #Sumo ancho,formo combinacion y paso al siguiente elemento
    TANC+=ELEO
    If ELEO>0
      COMB+=format$("N0:4",ELEO)
      If len(COMB)+int(255/5)>=255
        Infbox "Avise al programador...Superado limite de " + num$(int(255/5)) + " anchos posibles (Combinar)"
#        NPOS+=1
        Break
      Endif
    Endif
#    Infbox "NPOS=" + num$(NPOS+1) + "(" + num$(ELEP) +  ")   NORD="+num$(NORD+1) + "     NELE=" + num$(NELE+1) +"(" + num$(ELEO) +  ")    COMB=" + COMB
    NELE+=1
  Wend
  NPOS+=1

Wend
Affzo [M:ZGOFS2]20
Onerrgo
End

$GUARDAR_COMBI
If COMB=""
#  Infbox "COMB vacio...me salgo"
  Return
Endif
If TANC>TOPE
#  Infbox "TANC>TOPE, se asume primer elemento    " + num$(ELEP)
  COMB=format$("N0:4",ELEP)
Endif
#Infbox "GUARDAR_COMBI  NPOS=" + num$(NPOS+1)  +  "   NORD="+num$(NORD+1) + "     F=" + num$([M:ZGOFS2]NCOM+1) +  "  COMB=" + COMB
Local Integer F
F=[M:ZGOFS2]NCOM
[M:ZGOFS2]CANCHOJ(F)= TOPE
[M:ZGOFS2]POS(F)    = NPOS
[M:ZGOFS2]ORD(F)    = NORD
[M:ZGOFS2]COMBI(F)  = COMB
[M:ZGOFS2]CANCHO(F )= TANC
[M:ZGOFS2]CDIF(F)   = TOPE-[M:ZGOFS2]SMERMA-[M:ZGOFS2]CANCHO(F)
[M:ZGOFS2]NCOM+=1
If [M:ZGOFS2]NCOM>=8000
  Infbox "Se ha superado el limite de combinaciones posibles ([M:ZGOFS2]NCOM>=8000)"
Endif
Return

$COMBI_POSIBLE
Local Integer Q,ANCHO_POSIBLE, HAY
# Ver si podemos meter una combinación sin el último elemento, siempre y cuando haya elementos cuyo ancho <=dif+Ancho
If not ([M:ZGOFS2]CDIF(F)>0 and [M:ZGOFS2]ANCHO(NELE-1)=[M:ZGOFS2]ANCHO(NELE))
  Return
Endif
ANCHO_POSIBLE=[M:ZGOFS2]CDIF(F)+[M:ZGOFS2]ANCHO(NELE)
HAY=0
For Q=0 To TELE
  If [M:ZGOFS2]ANCHO(Q)>[M:ZGOFS2]ANCHO(NELE-1) and [M:ZGOFS2]ANCHO(Q)<=ANCHO_POSIBLE
    HAY=Q
    Break
  Endif
Next
If HAY
  #Quito de la ultima combinacion el último elemento
  COMB=left$(COMB,len(COMB)-4)
  TANC-=[M:ZGOFS2]ANCHO(NELE-1)
  Q=HAY
  While Q<=TELE and TANC+[M:ZGOFS2]ANCHO(Q)<=TOPE
    #Sumo ancho,formo combinacion y paso al siguiente elemento
    ELEO=[M:ZGOFS2]ANCHO(Q)
    TANC+=ELEO
    COMB+=format$("N0:4",ELEO)
#    Infbox "NPOS=" + num$(NPOS+1) + "(" + num$(ELEP) +  ")   NORD="+num$(NORD+1) + "     NELE=" + num$(NELE+1) +"(" + num$(ELEO) +  ")    COMB=" + COMB
    Q+=1
  Wend
  Gosub GUARDAR_COMBI
Endif
Return

Funprog LARGO_SEL
Local Integer LAR,L
For L=0 To [M:ZGOFS2]NLAR-1
  If [M:ZGOFS2]LSEL(L)=2
    LAR=[M:ZGOFS2]LLARGO(L)
    Break
  Endif
Next
End LAR

Subprog TOT_SUG
Affzo [M:ZGOFS2]30
Call RESUMEN From SPEZGOFS4
End

Subprog VACIAR
Raz [M:ZGOFS2]NJUM,[M:ZGOFS2]NELE,[M:ZGOFS2]NTIA
Effzo [M:ZGOFS2]5
Effzo [M:ZGOFS2]10
Effzo [M:ZGOFS2]35
Call VACIAR_CALCULOS
Raz   [M:ZGOFS3]
Effzo [M:ZGOFS3]5
End

Subprog VACIAR_CALCULOS
Raz [M:ZGOFS2]NCOM,[M:ZGOFS2]NOPC,[M:ZGOFS2]NSUG
Effzo [M:ZGOFS2]20
Effzo [M:ZGOFS2]25
Effzo [M:ZGOFS2]30
# Borrar pantalla RESUMEN
Call VACIAR_REJILLAS From SPEZGOFS4
End

Funprog ANCHO_OK(ANC)
Value Integer ANC
Local Integer OK
OK=1
Local Integer ANC_MAX
ANC_MAX=val(func AFNC.PARAM("ZANCHOMAX",""))
If ANC>ANC_MAX
  MSG="Imposible superar el ANCHO MAXIMO establecido\" + num$(ANC_MAX)
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Endif
End OK





Subprog AM_SSEL(VALEUR)
Variable Integer VALEUR
Local Integer ANC,OPC,F
# Si opcion estaba marcada, nos salimos...Siempre una marcada
If [M:ZGOFS2]SSEL(nolign-1)=2
  VALEUR=2
  End
# No se permite marcar las lineas en blanco para separar Anchos Jumbo
Elsif [M:ZGOFS2]SOPCION(nolign-1)=0
  VALEUR=1
  End
Endif
# Marcamos todas las del mismo Ancho+Opcion
ANC=[M:ZGOFS2]SANCHOJ(nolign-1)
OPC=[M:ZGOFS2]SOPCION(nolign-1)
For F=0 To [M:ZGOFS2]NSUG-1
  If [M:ZGOFS2]SANCHOJ(F)=ANC and [M:ZGOFS2]SOPCION(F)=OPC
    [M:ZGOFS2]SSEL(F)=2
  Else
    [M:ZGOFS2]SSEL(F)=1
  Endif
Next
Call TOT_SUG
End

Subprog AM_ANCHO(VALEUR)
Variable Decimal VALEUR
If not func ANCHO_OK(VALEUR)
  mkstat=2
Endif
End

Subprog AM_JANCHO(VALEUR)
Variable Decimal VALEUR
If not func ANCHO_OK(VALEUR)
  mkstat=2
Elsif [M:ZGOFS2]JMERMAP(nolign-1)=0
  [M:ZGOFS2]JMERMAP(nolign-1)=3.5
  Affzo [M:ZGOFS2]JMERMAP(nolign-1)
  [M:ZGOFS2]JMERMAC(nolign-1)  =int(VALEUR*([M:ZGOFS2]JMERMAP(nolign-1)/100)+0.5)
  Affzo [M:ZGOFS2]JMERMAC(nolign-1)
Endif
End

Subprog AM_JMERMAP(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=3.5
Endif
[M:ZGOFS2]JMERMAC(nolign-1)  =int([M:ZGOFS2]JANCHO(nolign-1)*(VALEUR/100)+0.5)
Affzo [M:ZGOFS2]JMERMAC(nolign-1)
End


Subprog AM_NANCHO(VALEUR)
Variable Decimal VALEUR
If not func ANCHO_OK(VALEUR)
  mkstat=2
Endif
End


Subprog AM_JCOMBINAR(VALEUR)
Variable Integer VALEUR
Local Integer F
For F=0 To [M:ZGOFS2]NJUM-1
  [M:ZGOFS2]JCOMBINAR(F)=VALEUR
Next
Affzo [M:ZGOFS2]5
End

Subprog AV_LSEL(VALEUR)
Variable Integer VALEUR
# No entramos si hay un solo largo o marcamos uno ya seleccionado, pues por defecto solo puedo haber uno
If [M:ZGOFS0]STA="" and [M:ZGOFS2]NLAR<2
  mkstat=2
Endif
End

Subprog AM_LSEL(VALEUR)
Variable Integer VALEUR
If [M:ZGOFS2]NLAR<2 or VALEUR<>2
  VALEUR=2
  [M:ZGOFS2]LSEL(nolign-1)=VALEUR
  Affzo [M:ZGOFS2]LSEL(nolign-1)
  End
Endif
# Desmarcar el resto de largos
Local Integer F
For F=0 To [M:ZGOFS2]NLAR-1
  If F<>nolign-1
    [M:ZGOFS2]LSEL(F)    =1
    [M:ZGOFS2]LAGRUPAR(F)=1
    Chgstl [M:ZGOFS2]NLAR(F) With ""
  Else
    [M:ZGOFS2]LSEL(F)    =2
    [M:ZGOFS2]LAGRUPAR(F)=2
    Chgstl [M:ZGOFS2]NLAR(F) With "AEXPEXC1"
  Endif
Next
# Cargar los anchos que haya del largo seleccionado
Call CARGAR_ANCHOS ([M:ZGOFS2]LLARGO(nolign-1)) From SPEZGOFS
Affzo [M:ZGOFS2]50
End


Subprog AM_LAGRUPAR(VALEUR)
Variable Integer VALEUR
Local Char MSG(255)
Local Integer LAR,F,G
# Si es la fila seleccionada LAGRUPAR=2
If [M:ZGOFS2]LSEL(nolign-1)=2
  VALEUR=2
  [M:ZGOFS2]LAGRUPAR(nolign-1)=VALEUR
  Affzo [M:ZGOFS2]LAGRUPAR(nolign-1)
#  Infbox "No se permite cambiar agrupar"
  End
Endif
# Sacar Largo seleccionado y nş agrupaciones, pues no podemos agrupar mas de 2 largos
Raz LAR,G
For F=0 To [M:ZGOFS2]NLAR-1
  If [M:ZGOFS2]LSEL(F)=2
    LAR=[M:ZGOFS2]LLARGO(F)
  Endif
  If [M:ZGOFS2]LAGRUPAR(F)=2
    G+=1
  Endif
Next
#
If [M:ZGOFS2]LLARGO(nolign-1)>LAR
  MSG="Imposible agrupar largos superiores al seleccionado\" + num$([M:ZGOFS2]LLARGO(nolign-1)) +" > " + num$(LAR)
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  VALEUR=1
  [M:ZGOFS2]LAGRUPAR(nolign-1)=VALEUR
  Affzo [M:ZGOFS2]LAGRUPAR(nolign-1)
Elsif G>=2 and VALEUR=2
  MSG="Imposible agrupar mas de 2 largos"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  VALEUR=1
  [M:ZGOFS2]LAGRUPAR(nolign-1)=VALEUR
  Affzo [M:ZGOFS2]LAGRUPAR(nolign-1)
Else
  [M:ZGOFS2]LAGRUPAR(nolign-1)=VALEUR
  Call CARGAR_ANCHOS (LAR) From SPEZGOFS
  Affzo [M:ZGOFS2]50
Endif
End

Subprog AM_SMINSTK(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZGOFS2]SMINRES=1
Else
  [M:ZGOFS2]SMINRES=2
Endif
Affzo [M:ZGOFS2]SMINRES
End

Subprog AM_SMINRES(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZGOFS2]SMINSTK=1
Else
  [M:ZGOFS2]SMINSTK=2
Endif
Affzo [M:ZGOFS2]SMINSTK
End

Subprog AM_SMERMA(VALEUR)
Variable Decimal VALEUR
Local Integer F,J
Local Char MSG(255)
Raz MSG,J
For F=0 To [M:ZGOFS2]NJUM-1
  J+=1
  If VALEUR>[M:ZGOFS2]JMERMAC(F)
    If MSG<>""
      MSG+="\"
    Endif
    MSG+=num$([M:ZGOFS2]JANCHO(F)) + "     " + num$(VALEUR) + ">" + num$([M:ZGOFS2]JMERMAC(F))
  Endif
Next
If MSG<>""
  MSG="Merma minima no puede ser superior al desperdicio indicado en las jumbos a usar\"+MSG
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
Elsif J=0
  MSG="Antes se debe indicar jumbos a usar"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
Endif
End

Subprog B1_NTIA # Marcar
Local Integer F
For F=0 To [M:ZGOFS2]NTIA-1
  [M:ZGOFS2]NSEL(F)=2
Next
Call VACIAR_CALCULOS
Affzo [M:ZGOFS2]35
End

Subprog B2_NTIA # Desmarcar
Local Integer F
For F=0 To [M:ZGOFS2]NTIA-1
  [M:ZGOFS2]NSEL(F)=1
Next
Call VACIAR_CALCULOS
Affzo [M:ZGOFS2]35
End

Subprog B3_NTIA # Invertir
Local Integer F
For F=0 To [M:ZGOFS2]NTIA-1
  If [M:ZGOFS2]NSEL(F)=2
    [M:ZGOFS2]NSEL(F)=1
  Else
    [M:ZGOFS2]NSEL(F)=2
  Endif
Next
Call VACIAR_CALCULOS
Affzo [M:ZGOFS2]35
End


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End


