#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento que dado el fichero de lotes origen    seleccionado por el usuario,
#Actualiza campo ZLOTORI en la tabla STOCK

$ACTION
#Infbox ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "OK"          : Gosub OK
  When Default
Endcase
Return

$CONTROLE
TMP = 1
TIT = "Importación en curso"
Return

$OUVRE
Global Char WNOMFIC(250)
Global Char WSALFCY(10)
Global Char WBPTNUM(15)
Global Integer WEXE
Local Char TIT(80)

WEXE = 0
WBPTNUM = ""
WSALFCY = ""
TIT = "Importacion lotes origen"
Return

$INIT
Local Mask ZIMPLOT [M:ZIMPLOT]
Raz [M:ZIMPLOT]
[M:ZIMPLOT]SALFCY=GFCYDEF(3)
Return

$DEBUT
Affzo [M:ZIMPLOT]
Return

$OK
WEXE = 1
WSALFCY = [M:ZIMPLOT]SALFCY
WNOMFIC = [M:ZIMPLOT]NOMFIC
Return

$EXEC
If WEXE=1
   Gosub PROCESA
Endif
Return

$PROCESA
Local Char A(250)(1..110)
Local Char WOUT(250)
Local Char WJOB(10)
Local Char MSG(255),RLOT(255)

Local Integer WOK
Local Integer CONT

If clalev([STO])<=0 : Local File STOCK     [F:STO] : Endif


Call OUVRE_TRACE("Importación de lotes origen ") From LECFIC
Call ECR_TRACE(" Importación de lotes origen: "+WBPTNUM+" Planta: "+WSALFCY,0) From GESECRAN

Call ECR_TRACE(" Inicio importación lotes origen ",0) From GESECRAN

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

#lectura de fichero
#WNOMFIC = mid$(WNOMFIC,7,len(WNOMFIC))
#WNOMFIC = filpath("BQT","","") +"\" +WNOMFIC
WNOMFIC=[M:ZIMPLOT]NOMFICSRV
Openi WNOMFIC Using [TIE]

#Gosub LEER_REGISTRO   :#fichero viene con cabecera de los campos
Gosub LEER_REGISTRO

Raz CONT

WOK=1
Trbegin [F:STO]

While !fstat
   Call ECR_TRACE("Procesando:  "+vireblc(A(2),2)+"  Lote "+vireblc(A(9),2)+"  origen "+vireblc(A(10),2),0) From GESECRAN
   CONT += 1
   #A(1) --> L
   #A(2) --> Articulo
   #A(3) --> Descripcion
   #A(4) --> NşBobinas
   #A(5) --> Ancho
   #A(6) --> Mandril
   #A(7) --> Longitud
   #A(8) --> Proveedor
   #A(9) --> Lote existente
   #A(10) --> Lote origen

  Filter [F:STO] Where ITMREF=vireblc(A(2),2) and LOT=vireblc(A(9),2)
  If rowcount([F:STO])>0
    For [F:STO]
      If [F:STO]ZLOTORI<>vireblc(A(10),2)
        [F:STO]ZLOTORI=vireblc(A(10),2)
        Rewrite [F:STO]
      Endif
      MSG="   S/Lote " + [F:STO]SLO + " asignado lote origen"
      If val(A(5))<>[F:STO]ZANCHO
        MSG+=" Ancho Stock " + num$([F:STO]ZANCHO)+" <> " + A(5)+" Telecarga"
      Endif
      If val(A(7))<>[F:STO]ZLONGITUD
        MSG+=" Largo Stock " + num$([F:STO]ZLONGITUD)+" <> " + A(7)+" Telecarga"
      Endif
      If val(A(6))<>[F:STO]ZMANDRIL
        MSG+=" Mandril Stock " + num$([F:STO]ZMANDRIL)+" <> " + A(6)+" Telecarga"
      Endif
      Call ECR_TRACE(MSG,0) From GESECRAN
    Next
  Else
      Call ECR_TRACE("   No se han encontrado lotes en STOCK",0) From GESECRAN
  Endif
   Gosub LEER_REGISTRO
   If !WOK
      Break
   Endif
Wend
Openi Using [TIE]
Filter [F:STO]

If !OK
   CONT=0
   Rollback
Else
   Commit
   # Mostrar registros en Stock SIN lote origen
  Filter [F:STO] Where ZLOTORI="" Order By ITMREF;LOT;SLO
#  Infbox num$(rowcount([F:STO]))
  Raz RLOT
  For [F:STO]
    If RLOT<>[F:STO]ITMREF+[F:STO]LOT
      RLOT=[F:STO]ITMREF+[F:STO]LOT
      Call ECR_TRACE("   "+[F:STO]ITMREF+" " + [F:STO]LOT +" "+[F:STO]SLO + " Se ha quedado SIN lote origen",0) From GESECRAN
    Endif
  Next
  Filter [F:STO]
Endif
Call ECR_TRACE(" Fin proceso importacion lotes origen ",0) From GESECRAN
Call ECR_TRACE(" Fin importación lotes origen: "+num$(CONT),0) From GESECRAN
Call FERME_TRACE From LECFIC
TRA = 1
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10) Using [TIE]
Return

$TERMINE
TRA = 1
Return
