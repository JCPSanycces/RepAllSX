Subprog AM_ORDEN(VALEUR)
Variable Integer VALEUR
[M:ZMARG0]ORDEN=VALEUR
Call ORDENA_GRID From SUBZMARG
End


Subprog IB_NBLIG
If [M:ZMARG]NBLIG<1  End   Endif
If [M:ZMARG]NBLIG<1 and GFONCTION1="GESZINVT" and [M:ZINVT0]ZNOL<=0    End     Endif
Local Char TIT(100)
Local Integer NOL   :  NOL =nolign-1
Local Integer ZOK
If [M:ZMARG0]FLDNUM(8)=NOL    End    Endif
Raz TIT
Call BORRA_GRID
If [M:ZMARG]NUM(NOL)<>""
  GBOUT1="Fra "+[M:ZMARG]NUM(NOL)+" lŞ "+num$([M:ZMARG]SIDLIN(NOL))
  If [M:ZMARG]SDHNUM(NOL)<>""
    TIT="Entrega "+[M:ZMARG]SDHNUM(NOL)+" lŞ "+num$([M:ZMARG]SDDLIN(NOL))
    Call MOSTRAR_LOTES_FACTURADOS([M:ZMARG]SDHNUM(NOL),[M:ZMARG]SDDLIN(NOL),"DET","","","",ZOK)
    [M:ZMARG0]FLDNUM(8)=NOL
  Else
#    Call ERREURT("Se hizo una Fra SIN ENTREGA\No hay movtos. en STOJOU\Se asume precio teorico", 0) From GESECRAN   #0-Informativo, 1-Error
#  Infbox "Se hizo una Fra SIN ENTREGA\No hay movtos. en STOJOU\Se asume precio teorico"
  Endif
Endif
Chgtbk [M:ZMARG]15 With TIT
#
If [M:ZMARG]SAU(NOL)=[M:ZMARG]STU(NOL) or [M:ZMARG]INVUNID(NOL)=2
  Grizo [M:ZMARG]COEN(NOL)
Else
  Actzo [M:ZMARG]COEN(NOL)
Endif
#
If [M:ZMARG]CPRPRIN(NOL)=0
  Grizo [M:ZMARG]ZSEL(NOL)
Else
  Actzo [M:ZMARG]ZSEL(NOL)
Endif
#
If [M:ZMARG]ZSEL(NOL)=2
  Grizo [M:ZMARG]INVUNID(NOL)
Else
  Actzo [M:ZMARG]INVUNID(NOL)
Endif
End

Subprog AM_ZSEL(VALEUR)
Variable Integer VALEUR
If [M:ZMARG]CPRPRIN(nolign-1)=0 or abs([M:ZMARG]PFMPN(nolign-1))>100
  VALEUR=1
Endif
[M:ZMARG]ZSEL(nolign-1)= VALEUR
Call REJ1_COL(nolign-1) From SUBZMARG
End

Subprog AM_INVUNID(VALEUR)
Variable Integer VALEUR
Local Decimal COE
Local Integer NOL   :  NOL =nolign-1
#Infbox "depurar"
If [M:ZMARG]COEN(NOL)<>0 Then COE=[M:ZMARG]COEN(NOL) Else COE=[M:ZMARG]SAUSTUCOE(NOL) Endif
# Para cuando
#    unidad STU<>SAU
#    COE<>1
#    Margen <500%
If [M:ZMARG]SAU(NOL)=[M:ZMARG]STU(NOL)  or [M:ZMARG]SAUSTUCOE(NOL)=1 or not [M:ZMARG]PFMP(NOL)<-100
  VALEUR=1
  Actzo [M:ZMARG]COEN(NOL)
Elsif [M:ZMARG]INVUNID(NOL)=2
  VALEUR=2
Elsif VALEUR=2
  [M:ZMARG]INVUNID(NOL)=VALEUR
  Grizo [M:ZMARG]COEN(NOL)
  # Ajustar precio venta/Cant  y calculo nuevos margenes......   Precio*Cant = IMPORTE, el cual no puede cambiar.   Si cambiamos precio, igual con cantidad !!!!
  [M:ZMARG]NETPRINOT(NOL)=arr([M:ZMARG]NETPRINOTORI(NOL)/COE,0.0001)
  [M:ZMARG]QTYSTU(NOL)   =arr([M:ZMARG]QTYSTU(NOL)*COE,0.0001)
  [M:ZMARG]PFM(NOL)      =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRI(NOL)
  [M:ZMARG]PFMP(NOL)     =arr([M:ZMARG]PFM(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
  Affzo [M:ZMARG]NETPRINOT(NOL)
  Affzo [M:ZMARG]PFM(NOL)
  Affzo [M:ZMARG]PFMP(NOL)
  Affzo [M:ZMARG]QTYSTU(NOL)
  If [M:ZMARG]CPRPRIN(NOL)<>0
    [M:ZMARG]PFMN(NOL)   =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRIN(NOL)
    [M:ZMARG]PFMPN(NOL)  =arr([M:ZMARG]PFMN(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
    Affzo [M:ZMARG]PFMN(NOL)
    Affzo [M:ZMARG]PFMPN(NOL)
  Endif
Endif
#[M:ZMARG0]FLDNUM(6)=1 # Para ejecutar coloreado en SETBOUT
Call REJ1_COL(NOL) From SUBZMARG
End

Subprog AM_COEN(VALEUR)
Variable Decimal VALEUR
Local Integer NOL   :  NOL =nolign-1
#Imposible cambiar si MISMAS unidades
If [M:ZMARG]SAU(NOL)=[M:ZMARG]STU(NOL)
  VALEUR=[M:ZMARG]COEN(NOL)
Else
  #El cambio afecta a coste
  [M:ZMARG]COEN(NOL)=VALEUR
#  Call MOSTRAR_LOTES_FACTURADOS([M:ZMARG]SDHNUM(nolign-1),[M:ZMARG]SDDLIN(nolign-1),"COEN") From SPEZMARG
  [M:ZMARG]NETPRINOT(NOL)=arr([M:ZMARG]NETPRINOTORI(NOL)/[M:ZMARG]COEN(NOL),0.0001)
  [M:ZMARG]QTYSTU(NOL)   =arr([M:ZMARG]QTYSTU(NOL)*[M:ZMARG]COEN(NOL),0.0001)
  [M:ZMARG]PFM(NOL)      =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRI(NOL)
  [M:ZMARG]PFMP(NOL)     =arr([M:ZMARG]PFM(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
  Affzo [M:ZMARG]NETPRINOT(NOL)
  Affzo [M:ZMARG]PFM(NOL)
  Affzo [M:ZMARG]PFMP(NOL)
  Affzo [M:ZMARG]QTYSTU(NOL)
  If [M:ZMARG]CPRPRIN(NOL)<>0
    [M:ZMARG]PFMN(NOL)   =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRIN(NOL)
    [M:ZMARG]PFMPN(NOL)  =arr([M:ZMARG]PFMN(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
    Affzo [M:ZMARG]PFMN(NOL)
    Affzo [M:ZMARG]PFMPN(NOL)
  Endif
Endif
#[M:ZMARG0]FLDNUM(6)=1 # Para ejecutar coloreado en SETBOUT
[M:ZMARG0]FLDNUM(7)=1 # Para que lo marque si corresponde
Call REJ1_COL(NOL) From SUBZMARG
End

Subprog IB_NLOTE
Local Integer NOL:       NOL=nolign-1
Local Char TIT(100)
Raz GBOUT1,GBOUT2
[M:ZMARG0]ZNADA=[M:ZMARG]SLO(NOL)
Case [M:ZMARG]TRSTYP0(NOL)
When 1  # Entrada varia
When 3  # Recepción proveedor
  If [M:ZMARG]VCRNUM(NOL)<>""
    TIT="Recepción "+[M:ZMARG]VCRNUM(NOL)+" lŞ "+num$([M:ZMARG]VCRLIN(NOL))
  Endif
  GBOUT2=TIT
When 5  # Entrada OF
  If [M:ZMARG]VCRNUMORI(NOL)<>""
    If [M:ZMARG0]FLDNUM(9)<>NOL
      [M:ZMARG0]FLDNUM(9)=NOL
      TIT="OF "+[M:ZMARG]VCRNUMORI(NOL)+" lŞ "+num$([M:ZMARG]VCRLINORI(NOL))
      Call MOSTRAR_LOTES_USADOS([M:ZMARG]VCRNUMORI(NOL),[M:ZMARG]VCRLINORI(NOL))
    Endif
  Else
    TIT=""
  Endif
  GBOUT1=TIT
  Chgtbk [M:ZMARG]20 With TIT
When 12 # Devolucion entrega
Endcase
End

Subprog IB_NLOTU
Raz GBOUT1,GBOUT2
[M:ZMARG0]ZNADA=[M:ZMARG]SLOU(nolign-1)
If [M:ZMARG]VCRNUMU(nolign-1)<>""
  Case [M:ZMARG]VCRTYP(nolign-1)
  When 6  # Recepción proveedor
    GBOUT2="Recepción "+[M:ZMARG]VCRNUMU(nolign-1)+" lŞ "+num$([M:ZMARG]VCRLINU(nolign-1))
  When 10 # OF
    GBOUT1="OF "       +[M:ZMARG]VCRNUMU(nolign-1)+" lŞ "+num$([M:ZMARG]VCRLINU(nolign-1))
  Endcase
Endif
End






######################################################################################

Subprog MOSTRAR_LOTES_USADOS(OFNUM,LIN)
Value Char    OFNUM
Value Integer LIN
#
Local Decimal CANT,VALO,MATORI,CANTMP
Local Char PESTA(80)
MATORI=[M:ZMARG]OMATTOTO(nolign-1)
Call COSTES_OF_MAT(OFNUM,CANT,VALO,"GRID",[M:ZMARG0]FLDCHR(0),PESTA,CANTMP)
[M:ZMARG]KGSUSA=CANT
[M:ZMARG]CSTUSA=VALO
If [M:ZMARG]KGSPRD<>0 [M:ZMARG]AVGUSA=arr((VALO/[M:ZMARG]KGSPRD),0.0001) Endif
Affzo [M:ZMARG]17-20
Call MOSTRAR_LOTES_USADOS_COL(OFNUM,LIN)
End

Subprog MOSTRAR_LOTES_USADOS_COL(OFNUM,LIN)
Value Char    OFNUM
Value Integer LIN
#Mostrar en lotes usados en linea de OF pasada
Local Char TXT(255)(10),STYL(30)
Local Integer F
TXT(0)="select l.LOT_0,l.SLO_0 "
TXT(1)="From MFGITM c inner join ZMFGLOT l on c.MFGNUM_0=l.MFGNUM_0 and c.ZGRPCOR_0=l.ZGRPCOR_0 "
TXT(2)="where c.MFGNUM_0='"+OFNUM+"' and c.MFGLIN_0="+num$(LIN)
For (Char FLOT(GLONLOT),Char FSLO(GLONSLO))From [M:ZMARG0]FLDCHR(0) Sql TXT As [MYT]
  For F=0 To [M:ZMARG]NLOTU-1
    If [M:ZMARG]LOTU(F)=[MYT]FLOT and [M:ZMARG]SLOU(F)=[MYT]FSLO Then
#      STYL="TDB10" Else STYL="" Endif  # LIGBUDA
#      Chgstl [M:ZMARG]NLOTU(F) With "TDB10"  # LIGBUDA
      Chgstl [M:ZMARG]LOTU(F)     With "LIGBUDA"
      Chgstl [M:ZMARG]SLOU(F)     With "LIGBUDA"
      Chgstl [M:ZMARG]LQTYSTUU(F) With "LIGBUDA"
      Chgstl [M:ZMARG]LSTUU(F)    With "LIGBUDA"
    Endif
    # Comprobación precio original y recalculado
    If [M:ZMARG]PRECO(F)<>[M:ZMARG]PRECA(F) and [M:ZMARG]PRECA(F)<>0
      Chgstl [M:ZMARG]PRECO(F) With "TDB11"
    Endif
    If [M:ZMARG]PRECT(F)<>[M:ZMARG]PREC(F)
      Chgstl [M:ZMARG]PRECT(F) With "TDB11"
    Else
      Chgstl [M:ZMARG]PRECO(F) With "TDB11"
      Chgstl [M:ZMARG]PRECA(F) With "TDB11"
    Endif
    If [M:ZMARG]LESTADO(F)<>"OK"
      Chgstl [M:ZMARG]LESTADO(F) With "BACKRED"
    Endif
  Next
Next
End

Subprog MOSTRAR_LOTES_FACTURADOS_COL
Local Integer F
For F=0 To [M:ZMARG]NLOTE-1
  Chgstl [M:ZMARG]AMTORD(F)     With "BACKORANGE"
  If [M:ZMARG]OMATTOT(F)=[M:ZMARG]OMATTOTT(F) and [M:ZMARG]OMATTOTO(F)<>[M:ZMARG]OMATTOTT(F)
    Chgstl [M:ZMARG]OMATTOTO(F) With "TDB31"  #Teorico OK  = Original tachado
  Else
    Chgstl [M:ZMARG]OMATTOTT(F) With "TDB31"  #Original OK = Teorico tachado
    If [M:ZMARG]OMATTOT(F)<>[M:ZMARG]OMATTOTO(F)
      Chgstl [M:ZMARG]OMATTOTO(F) With "BACKRED"  #Precio Original <> Recalculado
    Endif
  Endif
  If [M:ZMARG]ESTADO(F)<>"OK"
    Chgstl [M:ZMARG]LOT(F)    With "BACKRED"
    Chgstl [M:ZMARG]SLO(F)    With "BACKRED"
    Chgstl [M:ZMARG]ESTADO(F) With "BACKRED"
  Endif
Next
End

Subprog MOSTRAR_LOTES_FACTURADOS(ENTREGA,LIN,TIP,PITM,PLOT,PSLO,ZOK)
Value Char       ENTREGA,TIP,PITM,PLOT,PSLO
Value Integer    LIN
Variable Integer ZOK
#
Local Char TXT(255)(10),ZFCY(GLONFCY),ZSTU(GLONUOM),STYL(30),PESTA(80)
Local Decimal TCAN,IMP(8),TEORICO,TVAL
Local Integer F,NOL
Local Date FIFO
#
ZOK=1
Call BORRA_GRID
If PITM<>""
  TEORICO=func COSTE_TEORICO(PITM)
Else
  NOL=nolign-1
  TEORICO=func COSTE_TEORICO([M:ZMARG]ITMREF(NOL))
Endif
If TIP<>""
  If [M:ZMARG0]FLDNUM(8)<>-1
    F=[M:ZMARG0]FLDNUM(8)
    If [M:ZMARG]ZSEL(F)=2 Then STYL="BACKYELLOW" Else STYL="" Endif
    Chgstl [M:ZMARG]SALFCY(F) With STYL
    Chgstl [M:ZMARG]SDHNUM(F) With STYL
    Chgstl [M:ZMARG]SDDLIN(F) With STYL
  Endif
  STYL="AMKCUR"
  Chgstl [M:ZMARG]SALFCY(NOL)    With STYL
  Chgstl [M:ZMARG]SDHNUM(NOL)    With STYL
  Chgstl [M:ZMARG]SDDLIN(NOL)    With STYL
Endif
# TRSTYP  4-Entrega cliente
# Los lotes que vendemos, tan solo aparecen por alguno de los siguientes 4 motivos
#         1-Entrada varia
#         3-Recepción proveedor
#         5-Entrada OF
#        12-Devolución entrega. Las devoluciones deberian tener el mismo coste que cuando se entregaron
#                               Si la entrega corresponde a una devolucion, Sacar 1Ş entrega en la que se entregó, para sacar de ahi sus datos de coste
#                               pues se asume que sigue siendo el mismo, al no imputar Gtos Devol ???..PDte confirmar con cliente 18-08-17
# Sacar lotes vendidos y su origen
Raz TXT,TCAN,TVAL
If ENTREGA<>""
  TXT(0)="select distinct e.STOFCY_0,e.ITMREF_0,e.LOT_0,e.SLO_0,e.STU_0,e.QTYSTU_0,s.TRSTYP_0,s.VCRTYP_0,s.VCRNUM_0,s.VCRLIN_0,s.VCRTYPORI_0,s.VCRNUMORI_0,s.VCRLINORI_0"
  TXT(1)=",case s.TRSTYP_0 when 1 then s.PRIORD_0 else 0 end "
  TXT(2)="from STOJOU e inner join STOJOU s on e.ITMREF_0=s.ITMREF_0 and e.LOT_0=s.LOT_0 and e.SLO_0=s.SLO_0 "
  TXT(3)="where (e.VCRNUM_0='"+ENTREGA+"' and e.VCRLIN_0="+num$(LIN)+" and e.TRSTYP_0=4 and e.REGFLG_0<>2)"
  TXT(4)=" and ((s.TRSTYP_0=1 or s.TRSTYP_0=3 or s.TRSTYP_0=5) and s.REGFLG_0<>2)"# or s.TRSTYP_0=12)"
Else
  TXT(0)="select distinct STOFCY_0,ITMREF_0,LOT_0,SLO_0,STU_0,QTYSTU_0,TRSTYP_0,VCRTYP_0,VCRNUM_0,VCRLIN_0,VCRTYPORI_0,VCRNUMORI_0,VCRLINORI_0"
  TXT(1)=",case TRSTYP_0 when 1 then PRIORD_0 else 0 end "
  TXT(2)="from STOJOU  "
  TXT(3)="where ITMREF_0='"+PITM+"' and LOT_0='"+PLOT+"' and SLO_0='"+PSLO+"' and REGFLG_0<>2"
  TXT(4)=" and (TRSTYP_0=1 or TRSTYP_0=3 or TRSTYP_0=5)"# or s.TRSTYP_0=12)"
Endif
For (Char FFCY(GLONFCY),Char FITM(GLONITM),Char FLOT(GLONLOT),Char FSLO(GLONSLO),Char FSTU(GLONUOM),Decimal FCANT,Integer FSTYP,
&    Integer FVTYP,Char FNUM(GLONVCR),Integer FLIN,Integer FVTYPO,Char FNUMO(GLONVCR),Integer FLINO,Decimal FPRI)From [M:ZMARG0]FLDCHR(0) Sql TXT As [MYT0]
  ZFCY=[MYT0]FFCY
  ZSTU=[MYT0]FSTU
  F=[M:ZMARG]NLOTE
  #Recalcular coste
  Raz IMP
  Case [MYT0]FSTYP
  When 1  # Entrada varia
    #IMP(4)=func ZCOMUN.ART_COSTE([MYT0]FFCY,[MYT0]FITM,[MYT0]FLOT,[MYT0]FSLO,FIFO)
    IMP(0)=[MYT0]FPRI
    IMP(4)=[MYT0]FPRI
    PESTA="OK"
  When 3  # Recepción proveedor
    Call COSTES_RECE([MYT0]FNUM,[MYT0]FLIN,IMP,[M:ZMARG0]FLDCHR(0),PESTA)
  When 5  # Entrada OF
    Call COSTES_OF([MYT0]FNUMO,IMP,[M:ZMARG0]FLDCHR(0),PESTA)
  When 12 # Devolucion entrega
  Endcase
  If PESTA<>"OK" and  PESTA<>"SIN Materia Prima !!!"  ZOK=0    Endif
  [M:ZMARG]LITM(F)     =[MYT0]FITM
  [M:ZMARG]LOT(F)      =[MYT0]FLOT
  [M:ZMARG]SLO(F)      =[MYT0]FSLO
  [M:ZMARG]LSTU(F)     =[MYT0]FSTU
  [M:ZMARG]LQTYSTU(F)  =[MYT0]FCANT*-1 # Al ser entregas/salidas, en STOJOU se muestra en negativo
  [M:ZMARG]TRSTYP0(F)  =[MYT0]FSTYP
  [M:ZMARG]TRSTYP(F)   =[MYT0]FVTYP
  [M:ZMARG]VCRNUM(F)   =[MYT0]FNUM
  [M:ZMARG]VCRLIN(F)   =[MYT0]FLIN
  [M:ZMARG]TRSTYPORI(F)=[MYT0]FVTYPO
  [M:ZMARG]VCRNUMORI(F)=[MYT0]FNUMO
  [M:ZMARG]VCRLINORI(F)=[MYT0]FLINO
  # Determinar precio/Kg de materia prima
  [M:ZMARG]OMATTOTT(F) =TEORICO
  [M:ZMARG]OMATTOTO(F) =IMP(0)   # Materia prima original, la que habia
  If [MYT0]FSTYP=5  # OF
    # cuando son bobinas que se CORTARON
    #         ==>   No tiene sentido comporarlo con teorico, pues este corresponde con el de adquisicion
    #         ==>   Se tiene en cuenta el teorico a la hora de valorar las bobinas que se usaron en la fabricacion
    [M:ZMARG]OMATTOTR(F) =IMP(4) # Materia prima recalculada
    [M:ZMARG]OMATTOT(F)  =IMP(4) # Materia prima
    [M:ZMARG]OMACTOT(F)  =IMP(1) # Maquina
    [M:ZMARG]OLABTOT(F)  =IMP(2) # Mano obra
  Else
    If TEORICO<>0 Then DIF=arr((IMP(4)-TEORICO)*100/TEORICO,0.01) Else DIF=0 Endif
    [M:ZMARG]ODIF(F)   =DIF
    If abs(DIF)>[M:ZMARG0]FDIF and [M:ZMARG0]FDIF<>100
      [M:ZMARG]OMATTOT(F)  =TEORICO
    Else
      [M:ZMARG]OMATTOT(F)  =IMP(4)
    Endif
  Endif
  [M:ZMARG]AMTORD(F)   =[M:ZMARG]OMATTOT(F)+[M:ZMARG]OMACTOT(F)+[M:ZMARG]OLABTOT(F)
  [M:ZMARG]PRIORD(F)   =[MYT0]FPRI
  [M:ZMARG]ESTADO(F)   =PESTA
  TCAN+=[MYT0]FCANT
  TVAL+=([MYT0]FCANT*[M:ZMARG]AMTORD(F))
  If [M:ZMARG]NLOTE+1>=[M:ZMARG0]FLDNUM(1)
    MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(1)+1) + " filas para mostrar lotes facturados\.\Pida que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    Break
  Else
    [M:ZMARG]NLOTE+=1
  Endif
Next
#Si no hay movtos en STOJOU es debido a que
If TVAL=0 and TCAN=0
  [M:ZMARG]CSTFRA=TEORICO
  If TIP<>""
    Call ERREURT("No hay mvtos.en STOJOU para entrega "+ENTREGA+" lŞ "+num$(LIN)+"\Se asume precio teorico", 0) From GESECRAN   #0-Informativo, 1-Error
  Endif
Else
  [M:ZMARG]KGSFRA=TCAN*-1
  If TCAN<>0 [M:ZMARG]CSTFRA=arr((TVAL/TCAN),0.0001) Endif
Endif
#If [M:ZMARG]COEN(NOL)<>0
#  [M:ZMARG]NETPRINOT(NOL)=arr([M:ZMARG]NETPRINOTORI(NOL)/[M:ZMARG]COEN(NOL),0.0001)
#  [M:ZMARG]QTYSTU(NOL)   =arr([M:ZMARG]QTYSTU(NOL)*[M:ZMARG]COEN(NOL),0.0001)
#  [M:ZMARG]PFM(NOL)      =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRI(NOL)
#  [M:ZMARG]PFMP(NOL)     =arr([M:ZMARG]PFM(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
#  Affzo [M:ZMARG]NETPRINOT(NOL)
#  Affzo [M:ZMARG]PFM(NOL)
#  Affzo [M:ZMARG]PFMP(NOL)
#  Affzo [M:ZMARG]QTYSTU(NOL)
#  If [M:ZMARG]CPRPRIN(NOL)<>0
#    [M:ZMARG]PFMN(NOL)   =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CPRPRIN(NOL)
#    [M:ZMARG]PFMPN(NOL)  =arr([M:ZMARG]PFMN(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
#    Affzo [M:ZMARG]PFMN(NOL)
#    Affzo [M:ZMARG]PFMPN(NOL)
#  Endif
#Endif
If TIP="DET" or PITM<>""
  Affzo [M:ZMARG]12-20
  Call MOSTRAR_LOTES_FACTURADOS_COL
Elsif [M:ZMARG]CSTFRA<>0 and [M:ZMARG]CSTFRA<>[M:ZMARG]CPRPRI(NOL) and ([M:ZMARG]SAUSTUCOE(NOL)=1 or abs([M:ZMARG]CSTFRA-[M:ZMARG]CPRPRI(NOL))>0.001)
  #Determinar nuevos margenes
  [M:ZMARG]CPRPRIN(NOL)=[M:ZMARG]CSTFRA
  [M:ZMARG]PFMN(NOL)   =[M:ZMARG]NETPRINOT(NOL)-[M:ZMARG]CSTFRA
  If [M:ZMARG]NETPRINOT(NOL)<>0
  [M:ZMARG]PFMPN(NOL)  =arr([M:ZMARG]PFMN(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
  Else
#  [M:ZMARG]PFMPN(NOL)  =arr([M:ZMARG]PFMN(NOL)*100/[M:ZMARG]NETPRINOT(NOL),0.01)
  Endif
Endif
End



Subprog BORRA_GRID
Chgtbk [M:ZMARG]15 With ""
Chgtbk [M:ZMARG]20 With ""
Raz [M:ZMARG]NLOTE,[M:ZMARG]NLOTU
Effzo [M:ZMARG]12-20
[M:ZMARG0]FLDNUM(9)=-1
End

Subprog COSTES_RECE(ENT,LIN,IMP,BD,PESTA)
Value Char       ENT,BD
Value Integer    LIN
Variable Decimal IMP
Variable Char    PESTA
Local Char TXT(255)(10)
Raz TXT,IMP,PESTA
#  LINAMTCPR = Coste Stock
#  LINCSTPUR = Coste compra/Proveedor
#  Round(LINCSTPUR_0/QTYSTU_0,4)   =   Round(LINAMTCPR_0/QTYSTU_0,4)-(ZGTOARAUNI_0+ZGTOEXTUNI_0+ZGTONORUNI_0)
TXT(0)="select Round(LINAMTCPR_0/QTYSTU_0,4),Round(LINCSTPUR_0/QTYSTU_0,4),LININVFLG_0,LINPSTFLG_0,RCPDAT_0 "
TXT(1)="from PRECEIPTD "
TXT(2)="where PTHNUM_0='"+ENT+"' and PTDLIN_0="+num$(LIN)+" "
For (Decimal FCOSTE,Decimal FPROV,Integer FFRA,Integer FCONT,Date FREC)From BD Sql TXT As [MYT]
  IMP(0)=[MYT]FCOSTE
  IMP(1)=[MYT]FPROV
  IMP(2)=[MYT]FCOSTE-[MYT]FPROV
  IMP(4)=[MYT]FCOSTE
#  If [MYT]FFRA=2 or [MYT]FCONT=2 or year(FREC)<2017
    PESTA="OK"
#  Else
#    PESTA="Pdte.Fra"
#  Endif
  Break
Next
End

Subprog COSTES_OF(OFNUM,IMP,BD,PESTA)
Value Char       OFNUM,BD
Variable Decimal IMP()
Variable Char    PESTA
#
Local Char TXT(255)(10)
Gosub COSTES_OF_COMUN
If IMP(5)=0 or IMP(6)=0
  #Recalculo Ers/Kg OF en funcion de los kilos gastados y su valor
  Local Decimal CANT,VALO,CANTMP
  Call COSTES_OF_MAT(OFNUM,CANT,VALO,"PESTA",BD,PESTA,CANTMP)
  If CANT<>0 IMP(4)=arr(VALO/CANT,0.0001) Endif
  IMP(6)=CANTMP
  IMP(7)=CANT
#  If GUSER="ADMIN" Infbox "Depurar  (Subprog COSTES_OF(OFNUM,IMP,BD,PESTA))"    Endif
  If PESTA="OK"
    # Guardar recalculo, si OF fué calculada de "Costes"
    If clalev([F:WMFC]) <=0   :  Local File MFGCOST     [F:WMFC]  : Endif
    Update [F:WMFC] Where VCRTYP=10 and VCRNUM=OFNUM With ZMATTOT=IMP(4),ZKGSPROD=CANT,ZKGSMP=CANTMP
  Endif
Else
  PESTA="OK"
  IMP(4)=IMP(5)
Endif
End

Subprog COSTES_OF_2(OFNUM,IMP,BD,PESTA)
Value Char       OFNUM,BD
Variable Decimal IMP()
Variable Char    PESTA
#
Local Char TXT(255)(10)
Gosub COSTES_OF_COMUN
#Recalculo Ers/Kg OF en funcion de los kilos gastados y su valor
Local Decimal CANT,VALO
Call COSTES_OF_MAT_2(OFNUM,CANT,VALO,"PESTA",BD,PESTA)
If CANT<>0 IMP(4)=arr(VALO/CANT,0.0001) Endif
End

Subprog COSTES_OF_3(OFNUM,IMP,BD,PESTA)
Value Char       OFNUM,BD
Variable Decimal IMP()
Variable Char    PESTA
#
Local Char TXT(255)(10)
Gosub COSTES_OF_COMUN
End

$COSTES_OF_COMUN
Raz TXT,IMP
TXT(0)="select MATTOT_0,MACTOT_0,LABTOT_0,CSTTOT_0,ZMATTOT_0,ZKGSMP_0,ZKGSPROD_0 "
TXT(1)="from MFGCOST "
TXT(2)="where VCRNUM_0='"+OFNUM+"' and MFCTYP_0=(select max(MFCTYP_0) from MFGCOST where VCRNUM_0='"+OFNUM+"')"
For (Decimal FMP,Decimal FMQ,Decimal FMO,Decimal FTO,Decimal FMPZ,Decimal FKGSMP,Decimal FKGSPRD)From BD Sql TXT As [MYT]
  IMP(0)=[MYT]FMP
  IMP(1)=[MYT]FMQ
  IMP(2)=[MYT]FMO
  IMP(3)=[MYT]FTO
  IMP(5)=[MYT]FMPZ    # Materia prima RECALCULADA, para recalcular solo una vez
  IMP(6)=[MYT]FKGSMP  # Kgs Materia prima CONSUMIDA
  IMP(7)=[MYT]FKGSPRD # Kgs Materia prima PRODUCIDA
  Break
Next
Return



Subprog COSTES_OF_MAT(OFNUM,CANT,VALO,TIP,BD,PESTA,CANTMP)
Value Char       OFNUM,TIP,BD
Variable Decimal CANT,VALO,CANTMP
Variable Char    PESTA
#
Local Decimal PREC,PRECO,PRECA,PRECT,PREC1,DIF,IMPU(8)
Local Date FIFO
Local Char TXT(255)(10),PESTA(80)
Local Integer F,PASO
PASO=0
Raz TXT,CANT,VALO,PESTA,CANTMP
If TIP="GRID"
  Raz   [M:ZMARG]NLOTU
  Effzo [M:ZMARG]20
Endif
TXT(0)="select distinct STOFCY_0,ITMREF_0,LOT_0,SLO_0,QTYSTUASI_0-round(ZANCHO_0*l.ZLONGSOB_0/1000*ZFACTOR_0,4),l.STU_0,c.EXTQTY_0,MFGTRKFLG_0 "
TXT(1)="from ZMFGLOT l inner join MFGHEAD c on c.MFGNUM_0=l.MFGNUM_0 "
TXT(2)="where l.MFGNUM_0='"+OFNUM+"' "
TXT(3)="order by LOT_0,SLO_0"
For (Char FFCY(GLONFCY),Char FITM(GLONITM),Char FLOT(GLONLOT),Char FSLO(GLONSLO),Decimal FCANT,Char FSTU(GLONUOM),Decimal FPROD,Integer FESTA) From BD Sql TXT As [MYT0]
  If CANT=0
    PRECT=func COSTE_TEORICO([MYT0]FITM)
    # Imposible recalcular o guardar recalculo si la OF a recalcular no está en "Costes"
    If [MYT0]FESTA=6
      PESTA="OK"
    Else
      PESTA="Pdte.Coste ("+func ZCOMUN.ML_TXT(339,[MYT0]FESTA,"SPA")+")"
    Endif
  Endif
  PRECO=func ZCOMUN.ART_COSTE([MYT0]FFCY,[MYT0]FITM,[MYT0]FLOT,[MYT0]FSLO,FIFO)
  Case TIP
  When "PESTA"
    CANT=[MYT0]FPROD   # guardo cantidad PRODUCIDA
    Gosub MOSTRAR_RESTO
    VALO+=(arr(PREC*[MYT0]FCANT,0.0001))
    CANTMP+=[MYT0]FCANT# guardo cantidad CONSUMIDA
  When "GRID"
    [M:ZMARG]KGSPRD=[MYT0]FPROD
    CANT+=[MYT0]FCANT
    F=[M:ZMARG]NLOTU
    Gosub MOSTRAR_RESTO
    [M:ZMARG]ITMU(F)    =[MYT0]FITM
    [M:ZMARG]LOTU(F)    =[MYT0]FLOT
    [M:ZMARG]SLOU(F)    =[MYT0]FSLO
    [M:ZMARG]LQTYSTUU(F)=[MYT0]FCANT
    [M:ZMARG]LSTUU(F)   =[MYT0]FSTU
    [M:ZMARG]PRECT(F)   =PRECT
    [M:ZMARG]PRECO(F)   =PRECO
    [M:ZMARG]DIFU(F)    =DIF
    [M:ZMARG]PRECA(F)   =PRECA
    [M:ZMARG]PREC(F)    =PREC
    [M:ZMARG]VALOR(F)   =arr([M:ZMARG]PREC(F)*[MYT0]FCANT,0.0001)
    VALO+=[M:ZMARG]VALOR(F)
    If [M:ZMARG]NLOTU+1>=[M:ZMARG0]FLDNUM(2)
      MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(2)+1) + " filas para mostrar lotes usados\.\Pida que se lo aumenten"
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      Break
    Else
      [M:ZMARG]NLOTU+=1
    Endif
  Endcase
#  If TIP<>"GRID"
#    CANT=[MYT0]FPROD
#    Gosub MOSTRAR_RESTO
#    VALO+=(arr(PREC*[MYT0]FCANT,0.0001))
#  Else
#    [M:ZMARG]KGSPRD=[MYT0]FPROD
#    CANT+=[MYT0]FCANT
#    F=[M:ZMARG]NLOTU
#    Gosub MOSTRAR_RESTO
#    [M:ZMARG]ITMU(F)    =[MYT0]FITM
#    [M:ZMARG]LOTU(F)    =[MYT0]FLOT
#    [M:ZMARG]SLOU(F)    =[MYT0]FSLO
#    [M:ZMARG]LQTYSTUU(F)=[MYT0]FCANT
#    [M:ZMARG]LSTUU(F)   =[MYT0]FSTU
#    [M:ZMARG]PRECT(F)   =PRECT
#    [M:ZMARG]PRECO(F)   =PRECO
#    [M:ZMARG]DIFU(F)    =DIF
#    [M:ZMARG]PRECA(F)   =PRECA
#    [M:ZMARG]PREC(F)    =PREC
#    [M:ZMARG]VALOR(F)   =arr([M:ZMARG]PREC(F)*[MYT0]FCANT,0.0001)
#    VALO+=[M:ZMARG]VALOR(F)
#    If [M:ZMARG]NLOTU+1>=[M:ZMARG0]FLDNUM(2)
#      MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(2)+1) + " filas para mostrar lotes usados\.\Pida que se lo aumenten"
#      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#      Break
#    Else
#      [M:ZMARG]NLOTU+=1
#    Endif
#  Endif
Next
If CANT=0   PESTA="SIN Materia Prima !!!"   Endif
End



Subprog COSTES_OF_MAT_2(OFNUM,CANT,VALO,TIP,BD,PESTA)
Value Char       OFNUM,TIP,BD
Variable Decimal CANT, VALO
Variable Char    PESTA
#
Local Decimal PREC,PRECO,PRECA,PRECT,PREC1,DIF,IMPU(8)
Local Date FIFO
Local Char TXT(255)(10),PESTA(80)
Local Integer F,PASO
PASO=1
Raz TXT,CANT,VALO,PESTA
If TIP="GRID"
  Raz   [M:ZMARG]NLOTU
  Effzo [M:ZMARG]20
Endif
TXT(0)="select distinct STOFCY_0,ITMREF_0,LOT_0,SLO_0,QTYSTUASI_0-round(ZANCHO_0*l.ZLONGSOB_0/1000*ZFACTOR_0,4),l.STU_0,c.EXTQTY_0,MFGTRKFLG_0 "
TXT(1)="from ZMFGLOT l inner join MFGHEAD c on c.MFGNUM_0=l.MFGNUM_0 "
TXT(2)="where l.MFGNUM_0='"+OFNUM+"' "
TXT(3)="order by LOT_0,SLO_0"
For (Char FFCY(GLONFCY),Char FITM(GLONITM),Char FLOT(GLONLOT),Char FSLO(GLONSLO),Decimal FCANT,Char FSTU(GLONUOM),Decimal FPROD,Integer FESTA) From BD Sql TXT As [MYT1]
  If CANT=0
    PRECT=func COSTE_TEORICO([MYT1]FITM)
  Endif
  PRECO=func ZCOMUN.ART_COSTE([MYT1]FFCY,[MYT1]FITM,[MYT1]FLOT,[MYT1]FSLO,FIFO)
  If [MYT1]FESTA=6
    PESTA="OK"
  Else
    PESTA="Pdte.Coste ("+func ZCOMUN.ML_TXT(339,[MYT1]FESTA,"SPA")+")"
  Endif
#  If TIP<>"GRID" or PASO=1
    CANT=[MYT1]FPROD
    Gosub MOSTRAR_RESTO
    VALO+=(arr(PREC*[MYT1]FCANT,0.0001))
#  Else
#    [M:ZMARG]KGSPRD=[MYT1]FPROD
#    CANT+=[MYT1]FCANT
#    F=[M:ZMARG]NLOTU
#    Gosub MOSTRAR_RESTO
#    [M:ZMARG]ITMU(F)    =[MYT1]FITM
#    [M:ZMARG]LOTU(F)    =[MYT1]FLOT
#    [M:ZMARG]SLOU(F)    =[MYT1]FSLO
#    [M:ZMARG]LQTYSTUU(F)=[MYT1]FCANT
#    [M:ZMARG]LSTUU(F)   =[MYT1]FSTU
#    [M:ZMARG]PRECT(F)   =PRECT
#    [M:ZMARG]PRECO(F)   =PRECO
#    [M:ZMARG]DIFU(F)    =DIF
#    [M:ZMARG]PRECA(F)   =PRECA
#    [M:ZMARG]PREC(F)    =PREC
#    [M:ZMARG]VALOR(F)   =arr([M:ZMARG]PREC(F)*[MYT1]FCANT,0.0001)
#    VALO+=[M:ZMARG]VALOR(F)
#    If [M:ZMARG]NLOTU+1>=[M:ZMARG0]FLDNUM(2)
#      MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$([M:ZMARG0]FLDNUM(2)+1) + " filas para mostrar lotes usados\.\Pida que se lo aumenten"
#      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#      Break
#    Else
#      [M:ZMARG]NLOTU+=1
#    Endif
#  Endif
Next
End


$MOSTRAR_RESTO
#select distinct TRSTYP_0,VCRTYP_0,VCRNUM_0,VCRLIN_0,VCRTYPORI_0,VCRNUMORI_0,VCRLINORI_0 from STOJOU where  ITMREF_0='019' and LOT_0='000530005' and SLO_0='0001' and (TRSTYP_0=1 or TRSTYP_0=3 or
# TRSTYP_0=5 or TRSTYP_0=12)   --VCRNUM_0='SRT100170053' or VCRNUMORI_0='SRT100170053' or VCRNUMREG_0='SRT100170053'  --ITMREF_0='019' and LOT_0='000530005' and SLO_0='0001' order by ROWID desc
Raz PRECA
Case PASO
When 0
  If clalev([F:WSTJ0]) <=0   :  Local File STOJOU     [F:WSTJ0]  : Endif
  Filter [F:WSTJ0] Where ITMREF=[MYT0]FITM and LOT=[MYT0]FLOT and SLO=[MYT0]FSLO and (TRSTYP=1 or TRSTYP=3 or TRSTYP=5) and REGFLG<>2# orTRSTYP=12)
  Default File [F:WSTJ0]
When 1
  If clalev([F:WSTJ3]) <=0   :  Local File STOJOU     [F:WSTJ3]  : Endif
  Filter [F:WSTJ3] Where ITMREF=[MYT1]FITM and LOT=[MYT1]FLOT and SLO=[MYT1]FSLO and (TRSTYP=1 or TRSTYP=3 or TRSTYP=5) and REGFLG<>2# orTRSTYP=12)
  Default File [F:WSTJ3]
Endcase
For [F]
  Case [F]TRSTYP
  When 1  # Entrada varia
    PRECA=[F]PRIORD
    If TIP="GRID"
      [M:ZMARG]VCRTYP(F) =[F]VCRTYP
      [M:ZMARG]VCRNUMU(F)=[F]VCRNUM
      [M:ZMARG]VCRLINU(F)=[F]VCRLIN
      [M:ZMARG]LESTADO(F)="OK"
    Endif
  When 3  # Recepción proveedor
    Local Char RPESTA(80)
    RPESTA=PESTA
    Call COSTES_RECE([F]VCRNUM,[F]VCRLIN,IMPU,BD,PESTA)
    PRECA=IMPU(0)
    If TIP="GRID"
      [M:ZMARG]VCRTYP(F) =[F]VCRTYP
      [M:ZMARG]VCRNUMU(F)=[F]VCRNUM
      [M:ZMARG]VCRLINU(F)=[F]VCRLIN
      [M:ZMARG]LESTADO(F)=PESTA
    Endif
    PESTA=RPESTA
  When 5  # Entrada OF
    RPESTA=PESTA
    Case PASO
    When 0
      Call COSTES_OF_2([F]VCRNUMORI,IMPU,BD,PESTA)
      If TIP="GRID" # PASO=1 es cuando estoy calculando la 2ŞOF, es decir, que alguna bobina usada en la OF 1Ş venia de otra OF
        [M:ZMARG]VCRTYP(F) =[F:WSTJ0]VCRTYPORI
        [M:ZMARG]VCRNUMU(F)=[F:WSTJ0]VCRNUMORI
        [M:ZMARG]VCRLINU(F)=[F:WSTJ0]VCRLINORI
        [M:ZMARG]LESTADO(F)=PESTA
      Endif
    When 1
      Call COSTES_OF_3([F]VCRNUMORI,IMPU,BD,PESTA)
    Endcase
    PRECA=IMPU(3)
    PESTA=RPESTA
  When 12 # Devolucion entrega
  Endcase
  Break
Next
Filter [F]
If PRECA<>0 and PRECA<>PRECO Then PREC1=PRECA Else PREC1=PRECO Endif
If PRECT<>0 Then DIF=arr((PREC1-PRECT)*100/PRECT,0.01) Else DIF=0 Endif
If dim ([M:ZMARG0]FDIF)>0
  If abs(DIF)>[M:ZMARG0]FDIF and [M:ZMARG0]FDIF<>100 Then PREC=PRECT Else PREC=PREC1 Endif
Else
  PREC=PREC1
Endif
Return

Funprog COSTE_TEORICO(ITM)
Value Char ITM
End 0
#
Local Char FLITM(GLONITM)
Local Decimal COSTE,FLCST
Raz COSTE
# Abro fichero
Local Char FSRVTMP(250)
#FSRVTMP= filpath("tmp",[M:ZMARG0]FLDCHR(1),"csv") # Nombre del fichero de destino en el servidor
FSRVTMP= filpath("tmp","Precios_14_01_17","csv")  # Nombre del fichero de destino en el servidor
Openi FSRVTMP Using [FIC2]                        # Lo abre para lectura
Iomode adxifs  ";"  Using [FIC2]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC2]
Iomode adxium  50 Using [FIC2] #  50 = ASCII  0 = UTF8
Repeat
  Rdseq FLITM,FLCST Using [FIC2]
  If FLITM=ITM
    COSTE=FLCST
    Break
  Endif
Until fstat <> 0
Openi Using [FIC2]
End COSTE

