Subprog AM_FECINI(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]   VALEUR=gdat$(1,month(date$),year(date$))   Endif
[M:ZMARG0]FECFIN=eomonth(VALEUR)
Affzo [M:ZMARG0]FECFIN
End

Subprog AM_FECFIN(VALEUR)
Variable Date    VALEUR
If [M:ZMARG0]FECINI=[0/0/0]   [M:ZMARG0]FECINI=gdat$(1,month(date$),year(date$)):Affzo [M:ZMARG0]FECINI   Endif
If VALEUR=[0/0/0]             VALEUR=eomonth([M:ZMARG0]FECINI)                     Endif
End

Subprog AM_FFRA(VALEUR)
Variable Char    VALEUR()
If VALEUR=""    End   Endif
If clalev([F:WSIH]) <=0   :  Local File SINVOICE   [F:WSIH]  : Endif
Read [F:WSIH]SIH0=VALEUR
If fstat=0
  [M:ZMARG0]FECINI=gdat$(1,month([F:WSIH]ACCDAT),year([F:WSIH]ACCDAT))
  [M:ZMARG0]FECFIN=eomonth([F:WSIH]ACCDAT)
  [M:ZMARG0]FCPY  =[F:WSIH]CPY
  Affzo [M:ZMARG0]FECINI,FECFIN,FCPY
Else
  Call ERREURT("No existe la Fra indicada", 1) From GESECRAN
  mkstat=2
Endif
End


