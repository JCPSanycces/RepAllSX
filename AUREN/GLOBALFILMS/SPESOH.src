# 06.409.695
Subprog C_ZPLASTICTAX(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 0 or VALEUR > 100 Then
    Call ERREUR("El valor introducido no es correcto (rango 0-100)") From GESECRAN
    mkstat=2
  Endif
End


