Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()
If clalev([F:BPCW])=0 : Local File BPCUSTOMER [F:BPCW] : Endif
Raz [M:SOH1]ZBPAINV,[M:SOH1]ZBPAFRA
Read [F:BPCW]BPC0=VALEUR
If fstat=0
  [M:SOH1]ZBPAINV=[F:BPCW]BPAINV
  [M:SOH1]ZBPAFRA=func ZCOMUN.DIR_ENV_FRA([F:BPCW]BPCINV)
Endif
Affzo [M:SOH1]ZBPAINV
Affzo [M:SOH1]ZBPAFRA
#
Local Integer NOL   :   NOL=nolign-1
[M:SOH0]BPCORD=VALEUR
Gosub SACAR_TARIFA
End


