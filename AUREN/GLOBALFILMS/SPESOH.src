#<AdxTL>@(#)0.0.0.0 $Revision$
# 06.409.695 - JC.23122022.Llei 72022 impost del plŕstic per envasos d’un sol ús
######################################################################################

$ACTION
If GUSER="ADMIN"
#Infbox ACTION
Endif
Case ACTION
 When "OUVRE"      :   Gosub OUVRE
 When "SETBOUT"    :   Gosub SETBOUT
 When "ANNULE"     :   Gosub ANNULE
 When "APRES_MOD"  :   Gosub APRES_MOD
 When "LIENS"      :   Gosub LIENS
 When "LIENS_LIG"  :   Gosub LIENS_LIG
 When "FIN"        :   Gosub FIN
 When "APRES_CRE"  :   Gosub APRES_CRE           # Especifico de carga de lineas PEDRO
 When "AB19_NBLIG" :   Gosub AB19_NBLIG          # Especifico de carga de lineas PEDRO
 When "BB19_NBLIG" :   Gosub BB19_NBLIG          # Especifico de carga de lineas PEDRO
 When "STYLE"      :   Gosub STYLE
 When "VERIF_MOD"  :   Gosub PRECIOS
 When "VERIF_CRE"  :   Gosub PRECIOS
 When Default
Endcase
Return



$LIENS
[M:SOH1]ZBPAINV=[F:SOH]BPAINV
[M:SOH1]ZBPAFRA=func ZCOMUN.DIR_ENV_FRA([F:SOH]BPCINV)
Return


$PRECIOS
Local Integer F,YN
Local Char MSGW(255)
Raz MSGW
For F=0 To [M:SOH4]NBLIG-1
  If  [M:SOH4]INVFLG(F)<2 and [M:SOH4]SOQSTA(F)<3 and [M:SOH4]GROPRI(F)<=0
    MSGW+=num$(F+1)+"-"
  Endif
Next
If MSGW<>""# and GUSER="ADMIN"
  MSGW="ESTA SEGURO DE CONTINUAR\.\Las siguientes lineas tiene precio 0 !!\"+MSGW
  YN=1 # Por defecto NO
  Call OUINON(MSGW, YN) From GESECRAN
  If YN=1
    OK=0
  Endif
Endif


# 06.409.695.ini
  If [M:SOH0]SALFCY = '100' Then
    If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
    If !clalev([F:ZITM]) Then : Local File ITMMASTER  [F:ZITM] : Endif
    If !clalev([F:ZADI]) Then : Local File ATABDIV    [F:ZADI] : Endif
    Read [F:ZBPC]BPC0 = [M:SOH0]BPCORD
    If !fstat Then
      Local Integer LCON
      Raz [M:SOH3]INVDTAAMT(2)
      For LCON=0 To [M:SOH4]NBLIG-1
        [M:SOH4]ZKGPLASTAX(LCON) = ([M:SOH4]QTYSTU(LCON) * [M:SOH4]ZPLASTICTAX(LCON)) / 100
        Local Char LDATESYS(15)
        LDATESYS = num$(year([M:SOH0]ORDDAT))+ctrans(space$(2-len(num$(month([M:SOH0]ORDDAT))))+num$(month([M:SOH0]ORDDAT)),' ','0')+ctrans(space$(2-len(num$(day([M:SOH0]ORDDAT))))+num$(day([M:SOH0]
& ORDDAT)),' ','0')
        Filter [F:ZADI] Where NUMTAB = 6007
        For [ZADI]
          If LDATESYS >= [F:ZADI]A1 and [L]LDATESYS <= [F:ZADI]A2
            [M:SOH4]ZIMPPLASTAX(LCON) = ar2([M:SOH4]ZKGPLASTAX(LCON) * [F:ZADI]N1)
          Else
            [M:SOH4]ZIMPPLASTAX(LCON)=0
          Endif
        Next
        Filter [F:ZADI]
        Affzo [M:SOH4]ZPLASTICTAX(LCON)
        Affzo [M:SOH4]ZKGPLASTAX(LCON)
        Affzo [M:SOH4]ZIMPPLASTAX(LCON)
        [M:SOH3]INVDTAAMT(2) += ar2([M:SOH4]ZIMPPLASTAX(LCON))
        Affzo [M:SOH3]INVDTAAMT(2)
      Next
    Endif
    Close Local File [ZBPC],[ZITM],[ZADI]
  Endif
# 06.409.695.fin


Return

$OUVRE
  If clalev([ZCNTRS])<=0 : Local File ZCONTAINS [ZCNTRS] : Endif

  # Especifico de carga de lineas PEDRO

  Global Integer WCARGAITM
  If clalev([F:ZCAR])<=0 : Local File ZCARITM  [ZCAR] : Endif
  Delete [F:ZCAR] Where [F:ZCAR]CREUSR  = GUSER
  WCARGAITM = 0
Return

$APRES_MOD
  Call CAL_QTY([M:SOH0]SOHNUM)

  Gosub ASIGNACION_AUTOMATICA    # Especifico de carga de lineas PEDRO
Return

$LIENS_LIG
Call CAL_QTY([M:SOH0]SOHNUM)
Return

######################################################################################
# Especifico de carga de lineas PEDRO
$APRES_CRE
  Gosub ASIGNACION_AUTOMATICA
Return

$ASIGNACION_AUTOMATICA
  Local Char SAVACTION(30)
  Local Char VALBOUT(250), PARBOUT(250)(1..20)

  If clalev ([F:ZCAR])<=0 : Local File ZCARITM  [ZCAR] : Endif

  Filter [ZCAR] Where CREUSR = GUSER
  For [ZCAR]
     PARBOUT(1)=[F:ZCAR]STOFCY
     PARBOUT(2)=format$("YYYYMMDD",date$+30)
     PARBOUT(3)=[M:SOH0]SOHNUM
     PARBOUT(4)=""
     PARBOUT(5)=""
     PARBOUT(6)=""
     FLGEXE=1
     SAVACTION=GACTION
     GACTION="TRTAUTALL"
     Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FUNAUTALL","",1,"XYFUNAUTALL") From GTRAITE
     GACTION=SAVACTION
     Break
  Next
  Filter [ZCAR]

  Delete [F:ZCAR] Where [F:ZCAR]CREUSR  = GUSER

Return

$ AB19_NBLIG
  WCARGAITM = 0
Return

$ BB19_NBLIG
  Gosub CARGAR_LINEAS
  If WCARGAITM = 1 Then
     mkstat = 4
  Endif

Return

######################################################################################
### COGEMOS LAS LINEAS QUE TENEMOS EN LA TABLA AUXILIAR ZCARITM EN ESTADO CARGADO NO
### LAS LINEAS QUE TENEMOS A EXCEDE SI TIENEN QUE PONER INDICAR EL CAMPO CORTE = CORTE
### AGRUPAMOS CANTIDADES POR ARTICULO,ANCHO,LONGITUD,PROVEEDOR Y EXCEDE
# Especifico de carga de lineas PEDRO
$CARGAR_LINEAS
  Local Char WFILTRO(250)
  Local Char MSG(250),TXT(250)(10), W(250)(2)
  Local Integer F
  Local Char BD_TIPO(1)

  If clalev([F:ZCAR])<=0 : Local File ZCARITM [ZCAR] : Endif

  BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()

  WFILTRO = "CREUSR_0 = '" + GUSER + "' AND CARGADO_0 = 'NO'"

  TXT(0)="SELECT ITMREF_0,ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0,ZPROVEEDOR_0,sum(QTY_0) As CANTIDAD,EXCEDE_0 "
  TXT(1)="From ZCARITM "
  TXT(2)="Where " + WFILTRO
  TXT(3)="GROUP By ITMREF_0,ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0,ZPROVEEDOR_0,EXCEDE_0 "
  TXT(4)="Order By ITMREF_0,ZANCHO_0,ZLONGITUD_0,ZMANDRIL_0"

  #### las siguientes instrucciones crean un fichero en la carpeta tmp donde esta la sentencia de SQL para poder depurar
#  Local Char FICSRV(250)
#  Local Integer YN
#  Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#  Call OUINON(FICSRV, YN) From GESECRAN
#  If YN=1
#    Return
#  Endif

  For (Char FITMREF(GLONITM),Integer FZANCHO,Integer FZLONGITUD,Integer FZMANDRIL,Char FZPROVEEDOR(GLONBPS),Decimal FCANTIDAD,Char FEXCEDE(2))
&     From BD_TIPO Sql TXT As [MYT]
        Call CARGA_LINPEDART(FITMREF,FCANTIDAD,FZANCHO,FZLONGITUD,FZMANDRIL,FZPROVEEDOR,FEXCEDE) From ZCARGAITM
        WCARGAITM = 1
  Next

  Filter [ZCAR] Where CREUSR = GUSER
  For [ZCAR]
     [ZCAR]CARGADO  = "SI"
     Rewrite [ZCAR]
  Next
  Filter [ZCAR]

  Affzo [M:SOH4]1-99

Return

######################################################################################


Subprog CAL_QTY(LSOHNUM)
Value Char LSOHNUM()

If GUSER="ADMIN"
#Dbgaff
Endif

If clalev([F:SOQX])<=0 :  Local File SORDERQ   [SOQX] :  Endif
If clalev([F:SOPX])<=0 :  Local File SORDERP   [SOPX] :  Endif
[M:SOH4]ZTOTBOB=0
[M:SOH4]ZTOTKGS=0
[M:SOH4]ZTOTM2=0
Filter [SOQX] Where SOHNUM=LSOHNUM
For [SOQX]
   [M:SOH4]ZTOTBOB=[M:SOH4]ZTOTBOB+[F:SOQX]ZQTYBOB
   Raz [F:SOPX]
   Read [SOPX]SOP0=[F:SOQX]SOHNUM;[F:SOQX]SOPLIN;[F:SOQX]SOQSEQ
   If [F:SOPX]SAU="KG"
      [M:SOH4]ZTOTKGS=[M:SOH4]ZTOTKGS+[F:SOQX]ZQTYKG
      [M:SOH4]ZTOTM2=[M:SOH4]ZTOTM2+[F:SOQX]ZQTYM2
   Endif
   If [F:SOPX]SAU="M2"
      [M:SOH4]ZTOTKGS=[M:SOH4]ZTOTKGS+[F:SOQX]ZQTYKG
      [M:SOH4]ZTOTM2=[M:SOH4]ZTOTM2+[F:SOQX]ZQTYM2
   Endif
Next
Filter [SOQX]

Affzo [M:SOH4]ZTOTBOB
Affzo [M:SOH4]ZTOTKGS
Affzo [M:SOH4]ZTOTM2
End

$SETBOUT
#Si no esta completamente asignado en detalle no se permite entregar desde pedido.
If [M:SOH1]ALLSTA<>3 or [M:SOH2]ALLTYP<>2
   Call VIREBOUT(CHAINE,"2") From GOBJET
   Gosub SET_BOUT_SPE From GSAISIE
Endif
 # Habilitar opcion menu "Consulta Y=lineas y Z=Pedido"
  CHMEN+="YZ"
######################################################################################
# Especifico de carga de lineas PEDRO
  # Deshabilitamos el boton de Multiseleccion de productos
  If [M:SOH1]DLVSTA = 3
     Call VIREBOUT(CHAINE,"z") From GOBJET
     Gosub SET_BOUT_SPE From GSAISIE
 Endif
######################################################################################

# 06.409.695.INI
  Diszo [M:SOH3]INVDTAAMT(2)
# 06.409.695.FIN

Return

$FIN
Return

$ANNULE
If !clalev([F:ZTDOC]) : Local File ZTEXDOC [ZTDOC] : Endif
Delete [F:ZTDOC] Where VCRTYP=2 and NUMDOC=[M:SOH0]SOHNUM
If fstat
   Call FSTA("ZTDOC") From GLOCK
   GOK=0
Endif
Return

$STYLE
Local Integer F, LBOBASI

If !clalev([F:STAX]) : Local File STOALL [STAX] : Endif
For F=0 To [M:SOH4]NBLIG-1
  If [M:SOH4]ALLQTY(F)>0
    Raz LBOBASI
    Filter [STAX] Where VCRTYP=2 and VCRNUM=[M:SOH0]SOHNUM and VCRLIN=[M:SOH4]SOPLIN(F) and ALLTYP=2
    For [STAX]
       LBOBASI+=1
    Next
    Filter [STAX]
    If LBOBASI=[M:SOH4]ZQTYBOB(F)
       Chgstl [M:SOH4]NBLIG(F) With "BACKGREEN"
    Else
       Chgstl [M:SOH4]NBLIG(F) With "AERROR"
    Endif
  Else
    If [M:SOH4]SOQSTA(F)<3
       Chgstl [M:SOH4]NBLIG(F) With "BACKRED"
    Else
       Chgstl [M:SOH4]NBLIG(F) With ""
    Endif
  Endif
Next
Affzo [M:SOH4]5
Return

Subprog XC_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
If [F:ITM]ITMREF <> VALEUR
   Read [ITM]ITM0=VALEUR
   If fstat GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif
   If [F:ITM]ZFABCOR=2
      If [M:SOH0]ZANCHOAUX>0
         [M:SOH4]ZANCHO(NOL)   = [M:SOH0]ZANCHOAUX
         [M:SOH4]ZLONGITUD(NOL) = [M:SOH0]ZLONGITUDAUX
         [M:SOH4]ZMANDRIL(NOL)  = [M:SOH0]ZMANDRILAUX
         Affzo [M:SOH4]ZANCHO(NOL)
         Affzo [M:SOH4]ZLONGITUD(NOL)
         Affzo [M:SOH4]ZMANDRIL(NOL)
      Endif
   Endif
Endif
End

Subprog XAM_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Integer LTARLON
NOL=nolign-1
If [M:SOH0]ZANCHOAUX>0
   [M:SOH4]ZANCHO(NOL)   = [M:SOH0]ZANCHOAUX
   [M:SOH4]ZLONGITUD(NOL) = [M:SOH0]ZLONGITUDAUX
   [M:SOH4]ZMANDRIL(NOL)  = [M:SOH0]ZMANDRILAUX
   Affzo [M:SOH4]ZANCHO(NOL)
   Affzo [M:SOH4]ZLONGITUD(NOL)
   Affzo [M:SOH4]ZMANDRIL(NOL)
   Raz [M:SOH0]ZANCHOAUX
   Raz [M:SOH0]ZLONGITUDAUX
   Raz [M:SOH0]ZMANDRILAUX
Endif

#JLPR INI 08-05-17
[M:SOH4]ITMREF(NOL)=VALEUR
Gosub SACAR_TARIFA
#
#If clalev ([F:ZCIT])<=0 : Local File ZBPCITMTAR [ZCIT] : Endif
#Raz [F:ZCIT]
##Read [ZCIT]ZCIT0(2)=[F:BPC]BPCNUM;[F:ITM]ITMREF
#
#LTARLON=1
#Filter [ZCIT] Where BPCNUM=[M:SOH0]BPCORD and ITMREF=[M:SOH4]ITMREF(NOL) and ZLONGITUD=[M:SOH4]ZLONGITUD(NOL)
#For [ZCIT]
#   LTARLON=2
#Next
#Filter [ZCIT]
#
#If LTARLON=1
#   Filter [ZCIT] Where BPCNUM=[M:SOH0]BPCORD and ITMREF=[M:SOH4]ITMREF(NOL) and ZLONGITUD=0
#   For [ZCIT]
#      LTARLON=2
#   Next
#   Filter [ZCIT]
#Endif
#
#[M:SOH4]ZTARIFA(NOL)=[F:ZCIT]PLI
#If dim(GZTARIFA)<=0 : Global Char GZTARIFA(10) : Endif
#GZTARIFA=[F:ZCIT]PLI
#Affzo [M:SOH4]ZTARIFA(NOL)
#JLPR FIN 08-05-17

#JLPR INI 23-06-17   Se acuerda que para articulos de corte, la columna CANTIDAD, es calculada para M2 y KG en funcion de Superficie (Bob*Anc*Lar) y coeficiente para KG
If clalev([F:ITM])<=0 : Local File ITMMASTER [F:ITM] : Endif
Read [F:ITM]ITM0=[M:SOH4]ITMREF(NOL)
#If [F:ITM]ZFABCOR=2 and ([M:SOH4]SAU(NOL)="M2" or [M:SOH4]SAU(NOL)="KG")
If [F:ITM]ZFABCOR=2 and [M:SOH4]SAU(NOL)="M2"
  Diszo [M:SOH4]QTY(NOL)
Else
  Actzo [M:SOH4]QTY(NOL)
Endif
#JLPR FIN 23-06-17

# 06.409.695.ini
  If [M:SOH0]SALFCY = '100'
    If !clalev([F:ZBPC]) Then : Local File BPCUSTOMER [F:ZBPC] : Endif
    If !clalev([F:ZITM]) Then : Local File ITMMASTER  [F:ZITM] : Endif
    Read [F:ZBPC]BPC0 = [M:SOH0]BPCORD
    If !fstat Then
      If [F:ZBPC]ZPLASTAXFLG <> 2 Then
        [M:SOH4]ZPLASTICTAX(NOL) = 0
      Else
        Read [F:ZITM]ITM0 = [M:SOH4]ITMREF(NOL)
        If !fstat Then
          [M:SOH4]ZPLASTICTAX(NOL) = [F:ZITM]ZPLASTICTAX
        Endif
      Endif
      Affzo [M:SOH4]ZPLASTICTAX(NOL)
    Endif
    Close Local File [ZBPC],[ZITM]
  Endif
# 06.409.695.fin

End

Subprog XAM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR, LANCHO
Local Decimal WSAUSTUCOE, WANC_QTYSTU
Local Integer NOL, LNBRCNTP
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
Local Char LNUMCNTR(25)

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1

If [F:ITM]ZFABCOR=2
   WANC_QTYSTU=[M:SOH4]QTYSTU(NOL)

   LESPESOR=0
   If [F:ITP]ZESPESORP<>0
      LESPESOR=[F:ITP]ZESPESORP
   Else
      LESPESOR=[F:ITM]ZESPESOR
   Endif
   LDENSIDAD=0
   If [F:ITP]ZDTYP<>0
      LDENSIDAD=[F:ITP]ZDTYP
   Else
      LDENSIDAD=[F:ITM]DTY
   Endif
   LDENSIDAD=(LDENSIDAD*1000000/1000)
   LFACTOR=0
   If [F:ITM]ZFACTOR=0
      LFACTOR=LDENSIDAD*LESPESOR
   Else
      LFACTOR=[F:ITM]ZFACTOR
   Endif

   LANCHO = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:SOH4]ITMREF(NOL),[M:SOH4]ZANCHO(NOL))

   LSUPERFICIE=(LANCHO/1000)*[M:SOH4]ZLONGITUD(NOL)
   LVOLUMEN=(LANCHO/1000)*[M:SOH4]ZLONGITUD(NOL)*LFACTOR

#   LSUPERFICIE=([M:SOH4]ZANCHO(NOL)/1000)*[M:SOH4]ZLONGITUD(NOL)
#   LVOLUMEN=([M:SOH4]ZANCHO(NOL)/1000)*[M:SOH4]ZLONGITUD(NOL)*LFACTOR

   WSAUSTUCOE=[M:SOH4]SAUSTUCOE(NOL)

   If VALEUR<>0 and [M:SOH4]ZANCHO(NOL)<>0 and [M:SOH4]ZLONGITUD(NOL)<>0
      If [M:SOH4]SAU(NOL)="M2"
          [M:SOH4]QTY(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
      Endif
      If [M:SOH4]SAU(NOL)="KG"
         #Infbox num$(LVOLUMEN)+" "+num$(VALEUR)
         [M:SOH4]QTY(NOL)=arr(VALEUR*LVOLUMEN,0.001)
      Endif
   Else
      [M:SOH4]QTY(NOL)=VALEUR
   Endif

   If [F:ITM]STU<>[M:SOH4]SAU(NOL)
      WSAUSTUCOE=[F:ITM]ZFACTOR
      [M:SOH4]SAUSTUCOE(NOL)=[F:ITM]ZFACTOR
      [M:SOH4]QTYSTU(NOL)=[M:SOH4]QTY(NOL)*[F:ITM]ZFACTOR
      Affzo [M:SOH4]SAUSTUCOE(NOL)
   Endif

   WANC_QTYSTU=[M:SOH4]QTYSTU(NOL)
   Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL),[M]QTYSTU(NOL)) From TRTVENQTE
   Affzo [M:SOH4]QTY(NOL)

   If [F:ITM]STU<>[M:SOH4]SAU(NOL)
      [M:SOH4]QTYSTU(NOL)+=0.01
      Affzo [M:SOH4]QTYSTU(NOL)
   Endif

   [M:SOH4]ZQTYALT(NOL)=0
   [M:SOH4]ZQTYKG(NOL)=0
   [M:SOH4]ZQTYM2(NOL)=0
   If [M:SOH4]SAU(NOL)="M2"
      [M:SOH4]ZQTYALT(NOL)=arr(VALEUR*LVOLUMEN,0.001)
   Endif
   If [M:SOH4]SAU(NOL)="KG"
      [M:SOH4]ZQTYALT(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
      [M:SOH4]ZQTYKG(NOL)=arr(VALEUR*LVOLUMEN,0.001)
      [M:SOH4]ZQTYM2(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
   Endif
   [M:SOH4]ZQTYKG(NOL)=arr(VALEUR*LVOLUMEN,0.001)
   [M:SOH4]ZQTYM2(NOL)=arr(VALEUR*LSUPERFICIE,0.001)
   Affzo [M:SOH4]ZQTYALT(NOL)
   Affzo [M:SOH4]ZQTYKG(NOL)
   Affzo [M:SOH4]ZQTYM2(NOL)

   If GINIALLORD=2 & WANC_QTYSTU<>[M]QTYSTU(NOL) & (GAPPSOH<2 | ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2))
      Gosub INIT_WALLQTYSTU From SUBSOH
   Endif

   Call AM_QTY([M:SOH4]QTY(NOL)) From SUBSOH

   If [M:SOH4]WALLQTY(NOL)>0 and [F:ITM]ZFABCOR=2 and [F:ITM]ITMREF<>"900"
      [M:SOH4]WALLQTY(NOL)+=0.1
   Endif
   Affzo [M:SOH4]WALLQTY(NOL)
Else
   [M:SOH4]ZQTYKG(NOL)=[M:SOH4]QTY(NOL)
   [M:SOH4]ZQTYM2(NOL)=0
Endif
If [M:SOH0]SOHNUM<>""
   Call CTRL_CNTR("",0,[M:SOH0]SOHNUM,[M:SOH4]SOPLIN(NOL),LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
Endif
End

Subprog XAM_ZANCHO(VALEUR)
Variable Decimal VALEUR
End


Subprog XAM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
#JLPR 08-05-17  INI
Local Integer NOL   :   NOL=nolign-1
[M:SOH4]ZLONGITUD(NOL)=VALEUR
Gosub COMUN_ANC_LON
Gosub SACAR_TARIFA
#Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR, LANCHO
#Local Decimal WSAUSTUCOE, WANC_QTYSTU
#Local Integer NOL, LNBRCNTP
#Local Integer LRESP, LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
#Local Char LNUMCNTR(25)
#Local Integer LTARLON
#
#If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
#Raz [F:ITP]
#
#NOL=nolign-1
#
#If [F:ITM]ZFABCOR=2
#   LESPESOR=0
#   If [F:ITP]ZESPESORP<>0
#      LESPESOR=[F:ITP]ZESPESORP
#   Else
#      LESPESOR=[F:ITM]ZESPESOR
#   Endif
#   LDENSIDAD=0
#   If [F:ITP]ZDTYP<>0
#      LDENSIDAD=[F:ITP]ZDTYP
#   Else
#      LDENSIDAD=[F:ITM]DTY
#   Endif
