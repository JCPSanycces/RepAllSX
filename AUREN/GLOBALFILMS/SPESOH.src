Subprog AM_ZMANDRIL(VALEUR)
Variable Decimal VALEUR
Local Integer LRESP, LBOBDIS
NOL=nolign-1
LBOBDIS=func ZLIBCONS.BOBDISP([M:SOH2]STOFCY,[M:SOH4]ITMREF(NOL),[M:SOH4]ZANCHO(NOL),VALEUR,[M:SOH4]ZLONGITUD(NOL),[M:SOH0]SOHNUM)
If [M:SOH4]ZQTYBOB(NOL)>LBOBDIS
   Infbox mess(1,6120,1)+": "+num$(LBOBDIS)+" Disp."
Endif
End

Subprog C_NBLIG
Local Integer NOL, LRESP, LOK, LNBRCNTP
Local Integer LPOHENCNTR, LPOPENCNTR, LSOHENCNTR,WBOBASI
Local Char LNUMCNTR(25)

NOL=nolign-1

If status=65 or status=68
   #status 65 y 68: borrado lineas grid
   For NOL=nolign-1 To nolign-1
      LPOHENCNTR=0
      LPOPENCNTR=0
      LSOHENCNTR=0
      Call CTRL_CNTR("",0,[M:SOH0]SOHNUM,[M:SOH4]SOPLIN(NOL),LNUMCNTR,LPOHENCNTR,LPOPENCNTR,LNBRCNTP,LSOHENCNTR,WBOBASI) From SPEPOH
      If LSOHENCNTR
         Call OUINON("Linea en contenedor: "+LNUMCNTR+". Se eliminara irreversiblemente esa relacion.\ Seguro?", LRESP) From GESECRAN
         If LRESP=2
            LOK=1
            Gosub BORRA_LINSOH_CNTR
            If LOK
            Else
               mkstat=2
            Endif
         Else
            mkstat=2
            Break
         Endif
      Endif
   Next
Endif
If WCARGAITM = 1 Then
  #Infbox "HAY CARGA AUTOMATICA: "
  #zonsui="GROPRI(" + num$(nolign-1) + ")"   # Fuerzo la edicion del GRID
  mkstat = 4    # Fuerzo el botón registrar
  WCARGAITM = 0
  #Infbox "DESPUES DE CARGA AUTOMATICA: "
Endif

# 06.409.695.ini
  If [M:SOH0]SALFCY = '100' Then
    If [M:SOH4]SOQSTA(nolign-1) = 3 Then
      Diszo [M:SOH4]ZPLASTICTAX(nolign-1)
    Else
      Actzo [M:SOH4]ZPLASTICTAX(nolign-1)
    Endif
  Else
    Diszo [M:SOH4]ZPLASTICTAX(nolign-1)
  Endif
# 06.409.695.fin

End

$BORRA_LINSOH_CNTR
Delete [ZCNTRS] Where SOHNUM=[M:SOH0]SOHNUM and SOPLIN=[M:SOH4]SOPLIN(NOL)
If fstat
   Infbox "Error borrando linea contenedor [ZCNTRS] - fstat: "+num$(fstat)
   LOK=0
Endif
Return

Subprog AM_ZTARIFA(VALEUR)
Variable Char    VALEUR()
Local Integer NOL

NOL=nolign-1

If dim(GZTARIFA)<=0 : Global Char GZTARIFA(10) : Endif
GZTARIFA=VALEUR
WANC_QTYSTU=[M:SOH4]QTYSTU(NOL)
Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL),[M]QTYSTU(NOL)) From TRTVENQTE
Affzo [M:SOH4]QTY(NOL)

If GINIALLORD=2 & WANC_QTYSTU<>[M]QTYSTU(NOL) & (GAPPSOH<2 | ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2))
   Gosub INIT_WALLQTYSTU From SUBSOH
Endif
Affzo [M:SOH4]WALLQTY(NOL)
Call AM_QTY([M:SOH4]QTY(NOL)) From SUBSOH

#If dim([V]GZTARIFA)>=0
#   Kill GZTARIFA
#Endif
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla WK2GFE4) 24/01/2016 10:02:48 (ADMIN)
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
If [M:SOH0]ZANCHOAUX>0 and [M:SOH4]ZANCHO(NOL)=0 and [M:SOH4]ZLONGITUD(NOL)=0 and [M:SOH4]ZMANDRIL(NOL)=0
   [M:SOH4]ZANCHO(NOL)    = [M:SOH0]ZANCHOAUX
   [M:SOH4]ZLONGITUD(NOL) = [M:SOH0]ZLONGITUDAUX
   [M:SOH4]ZMANDRIL(NOL)  = [M:SOH0]ZMANDRILAUX
   Affzo [M:SOH4]ZANCHO(NOL)
   Affzo [M:SOH4]ZLONGITUD(NOL)
   Affzo [M:SOH4]ZMANDRIL(NOL)
   Raz [M:SOH0]ZANCHOAUX
   Raz [M:SOH0]ZLONGITUDAUX
   Raz [M:SOH0]ZMANDRILAUX
Endif
End

Subprog AS_ZPROVEEDOR(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1

Call RECH_TARIF(1,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SOH",[M]GROPRI(NOL)) From TRTVENTAR
Call CLCNETPRI([M]QTY(NOL), [M:SOH0]CUR, NOL) From TRTVENPRI
Call CLCPFM([M]DSTOFCY(NOL), [M:SOH1]PRITYP, [M]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR, NOL, 1) From TRTVENPRI
Affzo [M:SOH4]GROPRI(NOL)
End

Subprog AP_QTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

  NOL = nolign-1
#Infbox "AP_QTY" - num$(NOL)
  [M:SOH4]ZCTDREAL(NOL)  = VALEUR
  Affzo [M:SOH4]ZCTDREAL(NOL)

  [M:SOH4]ZCTDREALUS(NOL)  = [M:SOH4]QTYSTU(NOL)
  Affzo [M:SOH4]ZCTDREALUS(NOL)

End


Subprog AV_NETPRI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

  NOL = nolign-1

  [M:SOH4]ZPRIREAL(NOL)  = VALEUR
  Affzo [M:SOH4]ZPRIREAL(NOL)

End

#funcion que convierte el ancho si tiene divisor en el articulo
Funprog MODIFICA_ANCHO_DIVISOR(ITMREF,ANCHO)
   Value Char ITMREF
   Value Integer ANCHO
   Local Decimal WANCHO

   If clalev ([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif

   WANCHO = ANCHO

   If [F:ITM]ITMREF<>ITMREF Read [F:ITM]ITM0=ITMREF  Endif
   If [F:ITM]ZDIVANCHO <> 0
      WANCHO = ANCHO / [F:ITM]ZDIVANCHO
   Endif

End WANCHO


