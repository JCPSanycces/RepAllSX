$FILTRE
Default File [SOH]
# La cde doit ętre classique et autorisée par transaction
FILTSUP = "SOHCAT < 4 & (GORDCAT = 4 | GORDCAT = SOHCAT)"
# X3-119756 : Management of draft sales orders / X3-81820 : Hide draft SO - Filter picking lists on downstream objects (LD 12/20/18)
# Draft sales orders have to be excluded
FILTSUP+= " & DRAFTSTATUS=0"
# X3-119756 : Management of draft sales orders / X3-81820 : Hide draft SO - Filter picking lists on downstream objects (LD 12/20/18)
# Issue X3-242624 by MRDAB
If GFONCTION = "FUNSNS"
  FILTSUP+= " & !find(CPY,GPREFUNCPYS)"
Endif
# Issue X3-242624 end
Return
####################################################################
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critčre de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [SOH4]
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (début)
#Default File [SOP]
#Default File [LSOP]
If dim(SAVACT) >= 0 and find(SAVACT,"MODIF","CREATION","ANNULE") Then
  Default File [SOP]
Else
  Default File [LSOP]
Endif
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (fin)

CRIT = 'SOHNUM="'+[M:SOH0]SOHNUM+'"'
FICLIG = "SORDERP" : ABLIG = "SOP"
ZONLIG = "SOPLIN"
Return
####################################################################
$CREATION

#----------------------------------------------------------------#
# Création des enregistrements sans SVCRVAT et SVCRFOOT          #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("C","SOH") From TRTVENFACC
# Issue X3-211941 - 2020-08-28 by SR
#If GOK<1 Return Endif
If GOK<1  Goto ERR_CREATION : Endif

#---------------------------------#
# Creation des lignes de commande #
#---------------------------------#
# Enregistrement des lignes du tableau
Gosub CAL_OST From SUBSOHA: # Issue 73816 : No allocation if credit limit exceeded during order creation/modification
Gosub CREATION From TABLEAUX
# Issue X3-211941 - 2020-08-28 by SR
#If GOK<1: Return: Endif
If GOK<1  Goto ERR_CREATION : Endif

# Issue X3-31898 - 2017-11-23 by FGR : BEGIN
  Gosub PJM_ORDERS_SOQQTY
  # Issue X3-211941 - 2020-08-28 by SR
  #If GOK < 1 : Return : Endif
  If GOK<1  Goto ERR_CREATION : Endif
# Issue X3-31898 - 2017-11-23 by FGR : END

#----------------------------------------------------------------#
# ACA - Creation des enr. analytiques des elts de facturation    #
#----------------------------------------------------------------#
[M:SIHV]VCRTYP=20 : [M:SIHV]NUM=[F:SOH]SOHNUM
Gosub CREMOD_DIE_FOOT From SUBSIHV
# Issue X3-211941 - 2020-08-28 by SR
#If GOK < 1 : Return : Endif
If GOK<1  Goto ERR_CREATION : Endif

# Recalcul des statuts de la commande
Gosub MAJSTASOH From SUBSOHB
#------------------------------------#
# Mise ŕ jour des mouvements clients #
#------------------------------------#

#-- Maj de l'encours des commandes ---#
Local Char WSENS, WGREP
WSENS='+'  : WGREP=GREP
Gosub MAJ_ENCOURS From SUBSOHA
# Issue X3-211941 - 2020-08-28 by SR
#If GOK<1: Return: Endif
If GOK<1  Goto ERR_CREATION : Endif

#Issue 118686.sn - 2017-03-15 by CATUA
#Sage Sales Tax
#Move ACOMPTES call to APRES_CRE since tax is calculated at the end of creation (out of transaction)
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  WPMTREP = "C"
Else
  #----- Création des acomptes -----#
  Call ACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&             [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&             1,OK) From TRTTPT
  # Issue X3-211941 - 2020-08-28 by SR
  #If GOK < 1 : Return : Endif
  If GOK<1  Goto ERR_CREATION : Endif
  #LSE 07/08/2006
Endif
#Issue 118686.en - 2017-03-15 by CATUA

#Incrémentation des étapes avant-vente de l'affaire
# FGR 24/11/2011 X3SUIVI71065 (début)
# Local Char SZMESSAGE(250)
# Local Integer IBRETOUR
# IBRETOUR=1
# Call ADDOPPSTE("SOH", [M:SOH1]PREOPP, [M:SOH1]PJT, [M:SOH0]SOHNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
# If IBRETOUR=0
#     GMESSAGE = SZMESSAGE
#     GERR = 1
#     GOK = 0
# Endif
  #Call PJT_ADDOPPSTE("SOH") From SUBOPPB                  # FGR 12/08/2015 : X3SUIVI108275
  Call CRM_MANAGE_STEPB("SOH") From OPPOR_CSTD_PROGS_CRM   # FGR 12/08/2015 : X3SUIVI108275
  # Issue X3-211941 - 2020-08-28 by SR
  #If GOK < 1 : Return : Endif
  If GOK<1  Goto ERR_CREATION : Endif
# FGR 24/11/2011 X3SUIVI71065 (fin)
# FGR 29/04/2011 : X3SUIVI63021 (début) : déplacé depuis APRES_CRE
Local Char LREP(GLONREP)

  #--------------------------------------------------------------------#
  # Création des contrats de service liés ŕ la cde      CRM 18.09.2000 #
  #--------------------------------------------------------------------#
  If dim([M:SOH1]REP(0)) > 0 Then
    LREP = [M:SOH1]REP(0)
  Endif
  # Issue X3-128754 - 2019-02-27 by LD
#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  Local Char SAVFMTDIE(15)(1..dim(GFMTDIE))
#  Local Integer SAVGHEADIE: SAVGHEADIE=GHEADIE
#  For X=1 To dim(GFMTDIE)
#    SAVFMTDIE(X)=GFMTDIE(X)
#  Next
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
  # Issue X3-128754 - 2019-02-27 by LD

  Call CRECONSER([M:SOH0]SOHNUM, [M:SOH0]SALFCY, [M:SOH0]BPCORD, [M:SOH1]BPCINV, LREP, [M:SOH0]ORDDAT, [M:SOH0]CUR) From SUBCONB1
  # FGR 29/04/2011 : X3SUIVI63021 (début) : Plus gestion des erreurs

  # Issue X3-128754 - 2019-02-27 by LD
#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  GHEADIE=SAVGHEADIE
#  For X=1 To dim(GFMTDIE)
#    GFMTDIE(X)=SAVFMTDIE(X)
#  Next
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
  # Issue X3-128754 - 2019-02-27 by LD
  If GERR <> 0 Then
    GOK = 0
    # Issue X3-211941 - 2020-08-28 by SR
    #Return
    Goto ERR_CREATION
  Endif
# FGR 29/04/2011 : X3SUIVI63021 (fin) : déplacé depuis APRES_CRE

# 117129.n
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Call VALIDATE_INV_ELEM From TRTTAXUSA
  # Issue X3-211941 - 2020-08-28 by SR
  #If GERR=1 : GOK = 0 : Return : Endif
  If GERR=1 : GOK = 0 :  Goto ERR_CREATION : Endif
Endif

# 117129.o
## Detail local tax data
## If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
#If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
#  Gosub CREMOD_LTV From TRTTAXSST   # 106867.n
#  # Gosub CREMOD_LTV From TRTTAXUSA   # 106867.o
#  If GOK < 1 : Return : Endif
#Endif

# Issue X3-86334 - 2018-05-09 By USA : Begin
#  Infbox('Start')
  If func SUBSOHREV.INIT_VSORDER_RECORD([F:SOH]SALFCY, [F:SOH]SOHNUM, [F:SOH]REVNUM) >= [V]CST_AERROR Then
    GOK = 0
    # Issue X3-211941 - 2020-08-28 by SR
    #Return
    Goto ERR_CREATION
  Endif
# Issue X3-86334 - 2018-05-09 By USA : End

# Maj des statistiques
Call VALSTA("SOH",1) From SUBPS2
# Issue X3-211941 - 2020-08-28 by SR
#If GOK < 1 : Return : Endif
If GOK<1  Goto ERR_CREATION : Endif

Gosub DEVERROU_SQH From SUBSOHA

Return
# Issue X3-211941 - 2020-08-28 by SR : Erase SOHNUM
$ERR_CREATION
Raz [M:SOH0]SOHNUM
Return
# End issue X3-211941

####################################################################
# FGR 13/02/2014 : X3SUIVI96419 : plus de place dans SUBSOHA
$MODIF

#----------------------------------------------------------------#
# Modification des enregistrements sans SVCRVAT et SVCRFOOT      #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("M","SOH") From TRTVENFACC
If GOK<1 Return Endif

#-------------------------------------#
# Modification des lignes de commande #
#-------------------------------------#
If clalev([F:SOQ1])=0 Local File SORDERQ[SOQ1] Endif
If clalev([F:SOP1])=0 Local File SORDERP[SOP1] Endif
Gosub CAL_OST From SUBSOHA : # Issue 73816 : No allocation if credit limit exceeded during order creation/modification
Gosub MODIF From TABLEAUX
If GOK<1 : Return : Endif

# Issue X3-31898 - 2017-11-23 by FGR : BEGIN
  Gosub PJM_ORDERS_SOQQTY
  If GOK < 1 : Return : Endif
# Issue X3-31898 - 2017-11-23 by FGR : END

# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD
Gosub PJM_PRGBIL_TBECHK_UPD
If GOK < 1 : Return : Endif
# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD

#----------------------------------------------------------------#
# ACA - Modification des enr. analytiques des elts de facturation#
#----------------------------------------------------------------#
[M:SIHV]VCRTYP=20 : [M:SIHV]NUM=[F:SOH]SOHNUM
Gosub CREMOD_DIE_FOOT From SUBSIHV
If GOK < 1 : Return : Endif

Close Local File [SOP1]
Close Local File [SOQ1]

Default File [SOH]

# Recalcul des statuts de la commande
Gosub MAJSTASOH From SUBSOHB
#----------------------------#
# Maj des mouvements clients #
#----------------------------#

#-- Maj de l'encours des commandes ---#
Local Char WSENS, WGREP
WSENS='+'  : WGREP=GREP
Gosub MAJ_ENCOURS From SUBSOHA
If GOK<1: Return: Endif

# Bug 64124 : Calcul état crédit de la commande (pour que CDTSTA soit maj lors de l'appel au workflow)
Call SDCDTSTA ([M:SOH0]SOHNUM,[M:SOH0]BPCORD,[M:SOH0]CHGTYP,0,"",[M:SOH0]ORDDAT,[M:SOH2]UNL, 2,[M:SOH1]CDTSTA,GBIDD1,GBIDD1)
& From TRTVENCDT
[F:SOH]CDTSTA=[M:SOH1]CDTSTA
# Bug 64124
#------------------------------------------#
# Modification des acomptes de la commande #
#------------------------------------------#

#Issue 118686.sn - 2017-03-15 by CATUA
#Sage Sales Tax
#Move ACOMPTES call to APRES_MOD since tax is calculated at the end of modification (out of transaction)
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  WPMTREP = "M"
Else
  If MODPTE=1 | MODPTE=3
    #----- Suppression des acomptes existants
    Call ACOMPTES(5,2,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                 [F:SOH]CUR,0,"","","",1,OK) From TRTTPT
    If GOK<1 Return : Endif
  Endif
  If MODPTE=1
    #----- Récréation des acomptes
    Call ACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                 [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&                 1,OK) From TRTTPT
    If GOK < 1 Return : Endif
  Endif
  #--CPO 82311 Acomptes sur commande et modification du client facturé ou du tiers payeur
  If MODPTE<>1 and MODPTE<>3 and (MODBPCINV=1 | MODBPCPYR=1)
    Gosub UPDATE_DUD_SOH_MODBPC From SUBSOHB
    If GOK<1 Return : Endif
  Endif
  Raz MODBPCINV,MODBPCPYR
  #--/CPO
Endif
#Issue 118686.en - 2017-03-15 by CATUA

#LSE 07/08/2006
#Incrémentation des étapes avant-vente de l'affaire
# FGR 24/11/2011 X3SUIVI71065 (début)
# Local Char SZMESSAGE(250)
# Local Integer IBRETOUR
# IBRETOUR=1
# Call ADDOPPSTE("SOH", [M:SOH1]PREOPP, [M:SOH1]PJT, [M:SOH0]SOHNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
# If IBRETOUR=0
#     GMESSAGE = SZMESSAGE
#     GERR = 1
#     GOK = 0
# Endif
  #Call PJT_ADDOPPSTE("SOH") From SUBOPPB                  # FGR 12/08/2015 : X3SUIVI108275
  Call CRM_MANAGE_STEPB("SOH") From OPPOR_CSTD_PROGS_CRM   # FGR 12/08/2015 : X3SUIVI108275
  If GOK < 1 : Return : Endif
# FGR 24/11/2011 X3SUIVI71065 (fin)

# FGR 29/04/2011 : X3SUIVI63021 (début) : déplacé depuis APRES_MOD
Local Char LREP(GLONREP)
Local Integer NI
Local Integer NE

  If dim([M:SOH1]REP(0)) > 0 Then
    LREP = [M:SOH1]REP(0)
  Endif

  # Issue X3-128754 - 2019-02-27 by LD
#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  Local Char SAVFMTDIE(15)(1..dim(GFMTDIE))
#  Local Integer SAVGHEADIE: SAVGHEADIE=GHEADIE
#  For X=1 To dim(GFMTDIE)
#    SAVFMTDIE(X)=GFMTDIE(X)
#  Next
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
  # Issue X3-128754 - 2019-02-27 by LD

  Call CRECONSER([M:SOH0]SOHNUM, [M:SOH0]SALFCY, [M:SOH0]BPCORD, [M:SOH1]BPCINV, LREP, [M:SOH0]ORDDAT, [M:SOH0]CUR) From SUBCONB1

  # Issue X3-128754 - 2019-02-27 by LD
#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  GHEADIE=SAVGHEADIE
#  For X=1 To dim(GFMTDIE)
#    GFMTDIE(X)=SAVFMTDIE(X)
#  Next
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
  # Issue X3-128754 - 2019-02-27 by LD

  If GERR = 1 Then
    GOK = 0
    Return
  Endif
  # Et suppression de ceux dont les lignes ont été supprimées
  For NI = 0 To [M:SOH0]NBCON-1
    # On regarde si le contrat est toujours dans SOH4
    NE = find([M:SOH0]CONUMDEL(NI), [M:SOH4]CONNUM(0..[M:SOH4]NBLIG-1))
    If NE = 0 Then
      # Si on ne l'a pas trouvé c'est qu'on doit le supprimer
      Call DELSOHCON(2, [M:SOH0]SOHNUM, [M:SOH0]CONNUMLIG(NI)) From SUBCONB1
      If GERR = 1 Then
        GOK = 0
        Break
      Endif
    Endif
  Next NI
  If GOK < 1 Then
    Return
  Endif
# FGR 13/02/2013 : X3SUIVI96419 (début)

# 117129.n
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Call VALIDATE_INV_ELEM From TRTTAXUSA
  If GERR=1 : GOK = 0 : Return : Endif
Endif

# 117129.o
## Detail local tax data
## If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
#If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
#  Gosub CREMOD_LTV From TRTTAXSST   # 106867.n
#  # Gosub CREMOD_LTV From TRTTAXUSA   # 106867.o
#  If GOK < 1 : Return : Endif
#Endif

  # -------------------------------------------------
  # Issue X3-8085/121537 - 2017-02-15 by FGR : BEGIN
  Gosub PJM_OPPOR_PSO From SUBSOHA1
  # Issue X3-8085/121537 - 2017-02-15 by FGR : END
  # -------------------------------------------------

# Maj des statistiques
Call VALSTA("SOH",1) From SUBPS2
If GOK < 1 : Return : Endif

Gosub DEVERROU_SQH From SUBSOHA

# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#--If only header properties that do not impact the scheduling invoices lines of the order's lines
#--There is no use to call the AUPDATE class method (a direct update will do just fine)
Gosub MODIF_INVCND From LIBSAL_INVCND_SOH
# End issue 107888

#--CPO 79343
If GSOHSUPPLIGDSP>0
  Call MESSAGE(mess(251,191,1)) From GESECRAN
  Raz GSOHSUPPLIGDSP
Endif
#--/CPO

# Issue X3-244526 by MRDAB
If [V]GPREFUN = 2 and ((dim([V]GCONTRACTS_TO_CLOSE) and maxtab([V]GCONTRACTS_TO_CLOSE) > -1)
&                  or (dim([L]CONTRACTS_TO_UPDATE) and maxtab([L]CONTRACTS_TO_UPDATE) > -1))
  Gosub UPDATE_PREPAYMENT_CONTRACTS
Endif
# Issue X3-244526 end

# Issue X3-243729 by SDEM
If dim([V]G_AC_PREPM)>0 & [V]G_AC_PREPM & [V]GPREFUN = 2
  If dim([V]GDEL_ARR) > 0
    Gosub DEL_LINE_PREP_CONTRACT
  Endif
  If dim([V]GUPD_SO_LINE) > 0
    Gosub UPD_PREP_CONTRACT_VS_SO_LINE
  Endif
Endif
# Issue X3-243729 End

Return

####################################################################
$AVANT_MOD
#-----------------------------------------#
# Controle de modification d'une commande #
#-----------------------------------------#
# --> Commande modifiable ssi non soldee
If [F:SOH]ORDSTA = 2
   # Commande modifiable (uniquement rajout de ligne)
   # si toute les lignes sont associées ŕ des contrats de service
   If find("",[M:SOH4]CONNUM(0..[M:SOH4]NBLIG-1))
      GERR=1 : GMESSAGE = mess(16,192,1) : OK=0 : Return
   Endif
Endif

# Si GREV<>0, on est déjŕ passé dans cette action (Depuis bt solde ligne de commande), ne pas refaire le traitement
If GREV=0
    # --> Demande de modification avec ou sans avenant
    Gosub DEM_AVENANT From SUBSOHA
    If GREV=2
       Affzo [M:SOH0]REVNUM
    Endif
    # --> Gestion des signatures
    # Commande signée, modification ?
    If find([F:SOH]APPFLG, 2,3)
       OK=2 : Call AVERTIR(mess(229,191,1)+"\"+mess(60,123,1)-"?",OK) From GESECRAN
       If OK=1 OK=0 : Return Else OK=1 : Endif
    Endif
    Gosub AVANT_MOD_BOUT From SUBSOHA : # Bug 77357
Endif

Return
###############################################################
# 101874 : V9 : Taxe code control
# Move in SUBSOHA1
###############################################################
$ANNULE
#------------------------------------------#
# Annulation d'une commande                #
#------------------------------------------#

Local Decimal  WQUOATI, WQUONOT : # En devis
Local Integer WRET

# Raz des variables utilisées pour la maj des mvts clients
Raz WQUONOT, WQUOATI

#----------------------------------------------------------------#
# Suppression des enregistrements sans SVCRVAT et SVCRFOOT       #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("A","SOH") From TRTVENFACC
If GOK<1 Return Endif

If left$([F:SOH]SOHTEX1,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX1,WRET) From TRTX3TEX
Endif
If left$([F:SOH]SOHTEX2,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX2,WRET) From TRTX3TEX
Endif

#-----------------------------------------------------------------#
# Suppression des enr. historiques VOH VOP VOQ VOC  (avenants)    #
#-----------------------------------------------------------------#
Gosub SUP_HISTO From SUBSOHA
If GOK < 1 : Return : Endif

#------------------------------------------#
# --> Mise ŕ jour des mouvements clients   #
#------------------------------------------#
If sum([M:SOH4]SQDLIN) <> 0
    If clalev([F:SOP1])=0 Local File SORDERP[SOP1] Endif
    If clalev([F:SOQ1])=0 Local File SORDERQ[SOQ1] Endif
Endif
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK<1 : Return : Endif

# --> Gestion des signatures
#------------------------------------------------------------------------#
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow #
#------------------------------------------------------------------------#
If GAPPSOH>1
  Call ANNULE_SUIVI("SOH",mess(653,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
Endif

If sum([M:SOH4]SQDLIN) <> 0
    Close Local File [SOP1]
    Close Local File [SOQ1]
    Default File [SOH]
Endif

#----------------------------------------------------------------#
# ACA - Suppression des enr. analytiques des elts de facturation #
#----------------------------------------------------------------#
[M:SIHV]VCRTYP=20 : [M:SIHV]NUM=[F:SOH]SOHNUM
Gosub ANU_DIE_FOOT From SUBSIHV
If GOK < 1 : Return : Endif

#-- Maj de l'encours des commandes ---#
Local Char WSENS, WGREP
WSENS='-'  : WGREP=''
Gosub MAJ_ENCOURS From SUBSOHA
If GOK<1: Return: Endif

#----- Suppression des acomptes liés ŕ cette commande
Call ACOMPTES(5,2,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                 [F:SOH]CUR,0,"","","",1,OK) From TRTTPT : If GOK<1 Return : Endif

  # FGR 05/05/2011 : X3SUIVI71031 (début)
  #---------------------------------------------------------------#
  #Mise ŕ jour du champs "Nb de devis" de la fiche Affaire.       #
  #---------------------------------------------------------------#
  If [M:SOH1]PJT <> "" and GMODU(13) = 2 Then
    # --------------------------------------
    # FGR 12/08/2015 : X3SUIVI108275 (début)
    #    # FGR 11/03/2009 : X3SUIVI53266 Mis tout le code dans un S/P dans SUBOPPB
    #    Local Char SZMESSAGE(250)
    #    Local Integer IERROR
    #
    #    Call DELOPPSTE("SOH", [M:SOH1]PJT, [M:SOH0]SOHNUM, SZMESSAGE, IERROR) From SUBOPPB
    #    If IERROR = 0 Then
    #      GOK = 0
    #      GMESSAGE = SZMESSAGE
    #      Return
    #    Endif
    Call CRM_DEL_STEPB("SOH") From OPPOR_CSTD_PROGS_CRM
    If GERR = 1 Then
      Return
    Endif
    # FGR 12/08/2015 : X3SUIVI108275 (fin)
    # --------------------------------------
  Endif
  # FGR 05/05/2011 : X3SUIVI71031 (fin)

# Detail local tax data
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Gosub CREMOD_LTV From TRTTAXSST   # 106867.n
  # Gosub CREMOD_LTV From TRTTAXUSA   # 106867.o
  If GOK < 1 : Return : Endif
Endif

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:SOH3]PTE)
  Call VOID_ALL(2,[F:SOH]SOHNUM,GERR,GMESSAGE) From SEPPLIB
  If GERR : GOK=0 : Return : Endif
Endif

  # ------------------------------------------------
  # Issue X3-7539/119856 - 2016-11-23 by FGR : BEGIN
  If func ASYRFNC.ACTIV("PJM") Then
    Local Instance LPJMSOLITMH Using C_PJMSOLITMH
    Local Integer IRET

    LPJMSOLITMH = NewInstance C_PJMSOLITMH AllocGroup null
    IRET = fmet LPJMSOLITMH.DOC_DELINK("", 2, [F:SOH]SOHNUM)
    If IRET > [V]CST_AOK Then
      If func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(LPJMSOLITMH, GMESSAGE) = [V]CST_AWARNING Then
        GERR = 2
      Else
        GOK = 0
        GERR = 1
      Endif
    Endif
    FreeGroup LPJMSOLITMH
    Raz LPJMSOLITMH
    If IRET >= [V]CST_AERROR Then
      Return
    Endif
  Endif
  # Issue X3-7539/119856 - 2016-11-23 by FGR : END
