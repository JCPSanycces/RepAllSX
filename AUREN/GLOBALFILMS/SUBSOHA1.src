####################################################################
$PJM_ORDERS_SOQQTY_FREEGROUP
  # -------------------------------------------------
  # Issue X3-18442/120906 - 2017-01-13 by FGR : BEGIN
  If func ASYRFNC.ACTIV("PJM") Then
    If dim(ZPJMSOQQTY) >= 0 and ZPJMSOQQTY <> null Then
      FreeGroup ZPJMSOQQTY
      Raz ZPJMSOQQTY
    Endif
    If dim(ZINSPJM) >= 0 and ZINSPJM <> null Then
      FreeGroup ZINSPJM
      Raz ZINSPJM
    Endif
  Endif
  # Issue X3-18442/120906 - 2017-01-13 by FGR : END
  # -------------------------------------------------
Return

# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD
####################################################################
$PJM_PRGBIL_TBECHK_UPD


# Update situation lines when a sales order line is updated
# A method is called with the technical class TECPROBIL fed in VALLIG to do the update
# The method updates the situation lines not invoiced with TBECHK = Yes

If func ASYRFNC.ACTIV("PJM") Then
    Local Integer IPJMRET, IRET
    Local Char SMESS(250)
    If dim(ZPJMTECPROBIL) >= 0 and ZPJMTECPROBIL <> null Then
      If dim(ZPJMPRGBILH) < 0 Then
        Local Instance ZPJMPRGBILH Using C_PJMPRGBILH
      Endif
      ZPJMPRGBILH = NewInstance C_PJMPRGBILH AllocGroup null
      IPJMRET = fmet ZPJMPRGBILH.SET_FLAG_TBECHK("", ZPJMTECPROBIL)
      If IPJMRET >= [V]CST_AERROR Then
        IRET= func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ZPJMPRGBILH, SMESS)
        If IRET > 1 & IRET < [V]CST_AERROR
            GMESSAGE = SMESS
            GERR = 2
        Else
            GMESSAGE = SMESS
            GOK = 0
            GERR = 1
        Endif
      Endif
      Gosub PJM_PRGBIL_TBECHK_UPD_FREEGROUP
      If GOK < 1 Return : Endif
    Endif
Endif

Return
####################################################################
$PJM_PRGBIL_TBECHK_UPD_FREEGROUP

# Issue X3-200515/227027 - 2020-12-18 by MUARN : general tour without PJM
If func ASYRFNC.ACTIV("PJM") Then
# End issue X3-200515/227027
  If dim(ZPJMTECPROBIL) >= 0 and ZPJMTECPROBIL <> null Then
    FreeGroup ZPJMTECPROBIL
    Raz ZPJMTECPROBIL
  Endif
  If dim(ZPJMPRGBILH) >= 0 and ZPJMPRGBILH <> null Then
    FreeGroup ZPJMPRGBILH
    Raz ZPJMPRGBILH
  Endif
# Issue X3-200515/227027 - 2020-12-18 by MUARN : general tour without PJM
Endif
# End issue X3-200515/227027


Return

