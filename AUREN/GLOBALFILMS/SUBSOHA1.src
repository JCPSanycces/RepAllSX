              When 6 : If find(SAXECTRL,[M:SOH4]CCE6(0..I-1))>0
#                         GBIDI1=sigma(indcum=1,I,SAXECTRL=[M:SOH4]CCE6(indcum-1)*(([M:SOH4]CCE1(indcum-1)<>"" and [M:SOH4]CCE1(I)<>"" and [M:SOH4]CCE1(indcum-1)<>[M:SOH4]CCE1(I)) or
