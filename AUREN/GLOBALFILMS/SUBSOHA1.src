####################################################################
# Issue X3-243690 by MRDAB
Subprog SHOW_HIDE_PREPAYMENT_INVOICE_FIELDS(P_FCY)
Value Char P_FCY

If dim([V]G_AC_PREPM) < 1 or !G_AC_PREPM : End : Endif

Local Char PARAM_VAL(GLONADP)

Call PARAML(P_FCY,"PREFUN",[L]PARAM_VAL) From ADOVAL
[V]GPREFUN = val([L]PARAM_VAL)

If [V]GPREFUN = 2
  Chgfmt [M:SOH4]PCNTNUM     With "K:" + num$(GLONPREPI)
  Chgfmt [M:SOH4]PREPSTA     With "LA2432:15X"
Else
  Chgfmt [M:SOH4]PCNTNUM     With "-K:" + num$(GLONPREPI)
  Chgfmt [M:SOH4]PREPSTA     With "-LA2432:15X"
  Raz [M:SOH4]PREPSTA,PCNTNUM
Endif
Affzo [M:SOH4]

End
# Issue X3-243690 end
####################################################################
# Issue X3-244837 by MRDAB
$READ_PREPAYMENT_INVOICE_STATUS

If dim([V]G_AC_PREPM) < 1 or ![V]G_AC_PREPM : Return : Endif

Local Integer I

If [V]GPREFUN = 2
  If dim([M:SOH4]PREPSTA) > 0 and [M:SOH4]NBLIG > 0
    For [L]I=0 To [M:SOH4]NBLIG-1
      If [M:SOH4]PCNTNUM([L]I) = ""
        [M:SOH4]PREPSTA([L]I) = 1
      Else
        Read [F:PREPI]PREPI0 = [M:SOH4]PCNTNUM([L]I)
        If !fstat
          If [F:PREPI]STAT = 1
            [M:SOH4]PREPSTA([L]I) = 2
          Else
            [M:SOH4]PREPSTA([L]I) = func IS_PREPINV_FULLY_PAID([M:SOH4]PCNTNUM([L]I)) + 2 # Issue X3-244526 by MRDAB
          Endif
        Else
          [M:SOH4]PREPSTA([L]I) = 1
        Endif
      Endif
    Next [L]I
  Endif
Endif

Return
####################################################################
# Issue X3-244526 by MRDAB
# the function returns 0 - created, 1 - invoiced, 2 - fully paid
####################################################################
Funprog IS_PREPINV_FULLY_PAID(P_PCNTNUM)
Value Char P_PCNTNUM

Local Tinyint RESULT : [L]RESULT = 0
Local Decimal TOTAMTATI, TOTPAYAMTATI : [L]TOTAMTATI = 0 : [L]TOTPAYAMTATI = 0

If !clalev([F:PREPID])  : Local File PREPINVOICED [PREPID]  : Endif
If !clalev([F:PREPIP])  : Local File PREPINVOICEP [PREPIP]  : Endif

For [F:PREPID] Where [F:PREPID]PCNTNUM = P_PCNTNUM and [F:PREPID]INVNUM <> "" and [F:PREPID]CREMEMNUM = ""
  [L]TOTAMTATI += [F:PREPID]AMTATILIN
Next

For [F:PREPIP] Where [F:PREPIP]PCNTNUM = P_PCNTNUM
  [L]TOTPAYAMTATI += [F:PREPIP]PAYAMTNOT
  [L]TOTPAYAMTATI += [F:PREPIP]PAYAMTTAX
Next

If [L]TOTAMTATI = [L]TOTPAYAMTATI and [L]TOTPAYAMTATI > 0
  [L]RESULT = 2
Elsif [L]TOTAMTATI > 0
  [L]RESULT = 1
Endif

End [L]RESULT
# Issue X3-244526 end
# Issue X3-244837 end
####################################################################
# Issue X3-244526 by MRDAB
$LOCK_PREPAYMENT_CONTRACTS

Local Integer CONTRACT_INDEX
# Issue X3-243729 by SDEM
If [V]GPREFUN = 2
  If dim([V]GCONTRACTS_TO_CLOSE) and maxtab([V]GCONTRACTS_TO_CLOSE) > -1
    For [L]CONTRACT_INDEX = 0 To maxtab([V]GCONTRACTS_TO_CLOSE)
      If [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX) <> ""
        Lock = "PREPI~" + [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX)
        If fstat
          GERR=1 : OK=0 : GMESSAGE=[V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX)-":"-mess(10,100,1)
          Gosub UNLOCK_PREPAYMENT_CONTRACTS
          Return
        Endif
      Endif
    Next
  Endif
  If dim([V]GDEL_ARR) and maxtab([V]GDEL_ARR) > -1
    For [L]CONTRACT_INDEX = 0 To maxtab([V]GDEL_ARR)
      If [V]GDEL_ARR([L]CONTRACT_INDEX) <> ""
        Lock = "PREPI~" + [V]GDEL_ARR([L]CONTRACT_INDEX)
        If fstat
          GERR=1 : OK=0 : GMESSAGE=[V]GDEL_ARR([L]CONTRACT_INDEX)-":"-mess(10,100,1)
          Gosub UNLOCK_PREPAYMENT_CONTRACTS
          Return
        Endif
      Endif
    Next
  Endif
  # Issue X3-246053 by MRDAB
  If dim([L]SOH_CHANGED_FOR_PREPAYMENT_INV)> 0 and [L]SOH_CHANGED_FOR_PREPAYMENT_INV = [V]CST_ATRUE and dim([L]CONTRACTS_TO_UPDATE) > 0 and maxtab([L]CONTRACTS_TO_UPDATE) > -1
    For [L]CONTRACT_INDEX = 0 To maxtab([L]CONTRACTS_TO_UPDATE)
      If [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX) <> ""
        Lock = "PREPI~" + [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX)
        If fstat
          GERR=1 : OK=0 : GMESSAGE=[L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX)-":"-mess(10,100,1)
          Gosub UNLOCK_PREPAYMENT_CONTRACTS
          Return
        Endif
      Endif
    Next
  Endif
  # Issue X3-246053 end
Endif
# Issue X3-243729 End
Return
####################################################################
$UNLOCK_PREPAYMENT_CONTRACTS

Local Integer CONTRACT_INDEX

For [L]CONTRACT_INDEX = 0 To maxtab([V]GCONTRACTS_TO_CLOSE)
  If [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX) <> ""
    Unlock = "PREPI~" + [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX)
  Endif
Next
# Issue X3-243729 by SDEM
For [L]CONTRACT_INDEX = 0 To maxtab([V]GDEL_ARR)
  If [V]GDEL_ARR([L]CONTRACT_INDEX) <> ""
    Unlock = "PREPI~" + [V]GDEL_ARR([L]CONTRACT_INDEX)
  Endif
Next
# Issue X3-243729 End

# Issue X3-246053 by MRDAB
If dim ([L]CONTRACTS_TO_UPDATE)> 0
  For [L]CONTRACT_INDEX = 0 To maxtab([L]CONTRACTS_TO_UPDATE)
    If [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX) <> ""
      Unlock = "PREPI~" + [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX)
    Endif
  Next
Endif
# Issue X3-246053 end

Return
####################################################################
$UPDATE_PREPAYMENT_CONTRACTS

Local Integer CONTRACT_INDEX

For [L]CONTRACT_INDEX = 0 To maxtab([V]GCONTRACTS_TO_CLOSE)
  If [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX) <> ""
    Read [F:PREPI]PREPI0 = [V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX)
    If !fstat
      [F:PREPI]STAT = 3
      Rewrite [F:PREPI]
      If fstat
        Call FSTA("PREPI") From GLOCK : GOK=0 : Break
      Endif
    Else
      Call RSTA("PREPI",[V]GCONTRACTS_TO_CLOSE([L]CONTRACT_INDEX)) From GLOCK : GOK=0 : Break
    Endif
  Endif
Next

# Issue X3-246053 by MRDAB
If GOK > 0
  For [L]CONTRACT_INDEX = 0 To maxtab([L]CONTRACTS_TO_UPDATE)
    If [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX) <> ""
      Read [F:PREPI]PREPI0 = [L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX)
      If !fstat
        [F:PREPI]PCNTDAT = [M:SOH0]ORDDAT
        If [F:PREPI]PCNTBPR <> [M:SOH1]BPCINV
          [F:PREPI]PCNTBPR = [M:SOH1]BPCINV
          Gosub SET_CONTRACT_CONTROL
        Endif
        [F:PREPI]PCNTPTE = [M:SOH3]PTE
        [F:PREPI]PCNTDEP = [M:SOH3]DEP
        Rewrite [F:PREPI]
        If fstat
          Call FSTA("PREPI") From GLOCK : GOK=0 : Break
        Endif
      Else
        Call RSTA("PREPI",[L]CONTRACTS_TO_UPDATE([L]CONTRACT_INDEX)) From GLOCK : GOK=0 : Break
      Endif
    Endif
  Next
Endif

Gosub UNLOCK_PREPAYMENT_CONTRACTS
Raz [L]CONTRACTS_TO_UPDATE
Raz [L]SOH_CHANGED_FOR_PREPAYMENT_INV
# Issue X3-246053 end
If GOK > 0
  Raz [V]GCONTRACTS_TO_CLOSE
Endif

Return
# Issue X3-244526 end
####################################################################
# Issue X3-246053 by MRDAB
$DISABLE_FIELDS_FOR_INVOICED_PREPAYMENTS

If [V]GPREFUN = 2 and dim([M:SOH4]PREPSTA) > 0
  If max([M:SOH4]PREPSTA) > 2
    Diszo [M:SOH0]ORDDAT
    Diszo [M:SOH1]BPCINV
    Diszo [M:SOH3]PTE, DEP
  Endif
Endif

Return
####################################################################
$GATHER_CONTRACTS_TO_UPDATE

If [V]GPREFUN = 2 and dim([L]CONTRACTS_TO_UPDATE) > 0
  Raz [L]CONTRACTS_TO_UPDATE
  Raz [L]SOH_CHANGED_FOR_PREPAYMENT_INV
  Local Integer I
  If [M:SOH0]ORDDAT <> [F:SOH]ORDDAT or [M:SOH1]BPCINV <> [F:SOH]BPCINV or [M:SOH3]PTE <> [F:SOH]PTE or [M:SOH3]DEP <> [F:SOH]DEP
    [L]SOH_CHANGED_FOR_PREPAYMENT_INV = [V]CST_ATRUE
    For [L]I=0 To [M:SOH4]NBLIG - 1
      If [M:SOH4]PCNTNUM([L]I) <> "" and [M:SOH4]SOQSTA([L]I) <> 3
        [L]CONTRACTS_TO_UPDATE(maxtab([L]CONTRACTS_TO_UPDATE)+1) = [M:SOH4]PCNTNUM([L]I)
      Endif
    Next
  Endif
Endif

Return
####################################################################
$SET_CONTRACT_CONTROL

Local Char INTERM(20)
Local Char CODCPT(GLONCAC)

If !clalev([F:CAC])     : Local File GACCCODE [CAC]         : Endif
If !clalev([F:GAC])     : Local File GACCOUNT [GAC]         : Endif

Call LECTURE("BPC",[M:SOH1]BPCINV,"") From CONTOBJ
[L]CODCPT = func FINCAC_SYRA.GET_ACCCOD_BPR(GACTX,GSOCIETE,[M:SOH1]BPCINV, "C")
If [L]CODCPT<>""
  Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(1)) From CONTOBJ
  [L]INTERM = [F:CAC]ACC(0)
Endif
If [L]INTERM<>""
  Call LECTURE("GAC",[L]INTERM,GCOA(1)) From CONTOBJ
  If !fstat & [F:GAC]SAC=2
    [F:PREPI]PPBPACC = [F:GAC]ACCSHO
  Else
    [F:PREPI]PPBPACC = ""
  Endif
Endif

Return
# Issue X3-246053 end
####################################################################
# Issue X3-247735 by MRDAB
$CHECK_TPT_FOR_PREPAYMENT_INVOICES

If func SUBTPT.CHKPREPTPT([M:SOH3]PTE)
  GERR=1 : OK = 0 : GMESSAGE= mess(605,192,1)
  Return
Endif

Return
# Issue X3-247735 end
####################################################################
# Issue X3-243729 by SDEM
#---------------------------------------------------------#
#Takes care of deleting all the prepayment contracts      #
# created linked to a deleted line X3-243729----> SDEM    #
#---------------------------------------------------------#
$DEL_LINE_PREP_CONTRACT
  Local Integer SI

  If [V]GDEL_ARR([L]SI) = "" : Return : Endif
  If !clalev([F:PREPI])  : Local File PREPINVOICE [PREPI]  : Endif
  For [L]SI = 0 To maxtab([V]GDEL_ARR)
    Delete [F:PREPI] Where [F:PREPI]PCNTNUM = [V]GDEL_ARR([L]SI)
    If fstat=1 Then
      GERR=1 : GMESSAGE=[M:SOH4]PCNTNUM([L]SI)-":"-mess(10,100,1)
      Break
    Endif
  Next
  Raz [V]GDEL_ARR

Return
# Issue X3-243729 end

#-------------------------------------------------------------------------------------#
#    Verifies if all the lines are allowed can be delete & loads them into GDEL_ARR   #
# (all line have status < create/ none) Issue X3-243729 by SDEM                       #
#-------------------------------------------------------------------------------------#
$VERF_ANU_SO_LINE
  # Issue X3-243729 by SDEM
  If dim([V]G_AC_PREPM)>0 and [V]G_AC_PREPM and [V]GPREFUN = 2
    Local Integer IL
    If [M:SOH4]NBLIG >= 1 & (sum([M:SOH4]PREPSTA) > [M:SOH4]NBLIG)
      For IL = 0 To [M:SOH4]NBLIG-1
        If find([M:SOH4]PREPSTA(IL),3,4)<>0
          GMESSAGE = mess(606,192,1)-":"-[M:SOH4]PCNTNUM(IL)
          GOK = 0 :OK = 0 : GERR = 1 : Raz [V]GDEL_ARR : Break
        Elsif [M:SOH4]PREPSTA(IL) = 2
          Lock = "PREPI~" + [M:SOH4]PCNTNUM(IL)
          If fstat=1
            GERR=1 : GMESSAGE=[M:SOH4]PCNTNUM(IL)-":"-mess(10,100,1)
            OK=0 : GOK = 0 : Raz [V]GDEL_ARR : Break
          Endif
          [V]GDEL_ARR(maxtab([V]GDEL_ARR)+1) = [M:SOH4]PCNTNUM(IL)
        Endif
      Next
      If OK = 0 : Return : Endif
    Endif
  Endif
  # Issue X3-243729 End
Return

#-------------------------------------------------------#
# The sales order line amount has been updated.         #
# Check the existing prepayments X3-246884 By SDEM      #
# ------------------------------------------------------#
$UPD_PREP_MESS
  If dim(G_AC_PREPM)>0 & [V]G_AC_PREPM & [V]GPREFUN = 2 & find([M:SOH4]PREPSTA(nolign-1),3,4) & CHG_FLG = [V]CST_AFALSE
    GERR = 2 : GMESSAGE = mess(607,192,1)
    CHG_FLG = [V]CST_ATRUE
  Endif
Return


#--------------------------------------------------------------#
#   Loading the GUPD_SO_LINE array with the contract numbers   #
#   that needs to be changed  --------->   X3-246884 By SDEM   #
#--------------------------------------------------------------#
$LOAD_GUPD_SO_LINE
  If dim(G_AC_PREPM)>0 and [V]G_AC_PREPM and [V]GPREFUN = 2 and find([M:SOH4]PREPSTA(nolign-1),2,3,4)
    If !find(GUPD_SO_LINE,[M:SOH4]PCNTNUM(nolign-1))
      GUPD_SO_LINE(maxtab(GUPD_SO_LINE)+1) = [M:SOH4]PCNTNUM(nolign-1)
      GUPD_SO_LINE(maxtab(GUPD_SO_LINE)+1) = [M:SOH4]PCNTNUM(nolign-1)+" $ "+ num$(nolign-1)
    Endif
  Endif
Return

#--------------------------------------------------------------#
# Update prepayment contracts according to changes on SO lines #
# (all line have status = create/ none)Issue X3-246884 by SDEM #
#--------------------------------------------------------------#
$UPD_PREP_CONTRACT_VS_SO_LINE
  Local Integer INDX,LIN_NUM

  If [V]GUPD_SO_LINE(INDX) = "" : Return :Endif
  If !clalev([F:PREPI])  : Local File PREPINVOICE [PREPI]  : Endif
  If !clalev([F:PREPID]) : Local File PREPINVOICED [PREPID] : Endif
  For INDX = 0 To maxtab(GUPD_SO_LINE)
    [L]LIN_NUM = val(right$(GUPD_SO_LINE(INDX+1),(instr(1,GUPD_SO_LINE(INDX+1),"$")+1)))
    Readlock [F:PREPI]PREPI0 = GUPD_SO_LINE(INDX)
    If !fstat
      [F:PREPI]PCNTAMTNOT = [M:SOH4]LINORDNOT(LIN_NUM)
      [F:PREPI]PCNTAMTATI = [M:SOH4]LINORDATI(LIN_NUM)
      [L]LIN_NUM         += 1
      Rewrite [F:PREPI]
      For [F:PREPID] Where [F:PREPID]PCNTNUM = GUPD_SO_LINE(INDX)
        [F:PREPID]PPCT = arr(([F:PREPID]AMTNOTLIN / [F:PREPI]PCNTAMTNOT) * 100, 0.000001)
        Rewrite [F:PREPID]
      Next
      Unlock [F:PREPI]
    Elsif fstat=1
      GERR=1 : GMESSAGE=[M:SOH4]PCNTNUM(INDX)-":"-mess(10,100,1)
      Break
    Endif
  Next INDX
  Raz [V]GUPD_SO_LINE
Return

#-------------------------------------#
# reset prepayment status of SO lines #
#  Issue X3-246884 by SDEM            #
#-------------------------------------#
$RESET_PREP_STA
If  GREP="D" & dim([V]G_AC_PREPM)>0 and [V]G_AC_PREPM and [V]GPREFUN = 2
  Raz   [M:SOH4]PREPSTA,PCNTNUM
  Affzo [M:SOH4]PREPSTA,PCNTNUM
Endif
Return
