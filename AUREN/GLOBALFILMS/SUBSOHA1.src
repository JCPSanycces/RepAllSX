# Process SST and update tables outside of the transaction - Issue 117129
$RECALC_SST
  If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
    Gosub RECALC_SST_SOH From TRTTAXSST  #JOBRO 122614.n transaction management
  Endif                                  #JOBRO 122614.n
