#&                                                ([M:SOH4]CCE7(indcum-1)<>"" and [M:SOH4]CCE7(I)<>"" and [M:SOH4]CCE7(indcum-1)<>[M:SOH4]CCE7(I))))
                         If GBIDI1<1
                           SAXECTRL = ""
