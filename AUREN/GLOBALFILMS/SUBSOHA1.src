#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Contient les traitements des actions appelés par l'objet SUBSOH       #
# Etiquettes                                                            #
# Issue X3-128754 - 2019-02-27 by LD : Error “Some mandatory Analytical Dimensions were not indicated” when trying to add new line item the order
# Issue X3-242624 - 2021-05-07 by MRDAB - Prepayments button deactivated for companies using prepayment invoices
# Issue X3-243690 - 2021-05-17 by MRDAB - new Prepayment invoice/contract fields on GESSOH
# Issue X3-244837 - 2021-05-24 by MRDAB - feed the new Prepayment invoice/contract fields
# Issue X3-244526 - 2021-05-28 by MRDAB : closing SO lines linked with prepayment invoices
# Issue X3-243729 - 2021-05-31 SDEM --> deletion SO lines contracts with status create
# Issue X3-246053 - 2021-08-06 by MRDAB - control header fields vs GESPREPI and update GESPREPI
#########################################################################
$RAZCRE

GCONSDIA=0

[M:SOH0]ORDDAT=date$

#------------------------------------------------------------------------#
# Chargement site par défaut                                             #
# Récupération des paramčtres vente du site / de la société              #
# Chargement globales référenciels, comptes et sections de la société    #
# Réalimentation du cours devise dossier/devise cde                      #
# -----------------------------------------------------------------------#
GFCY=GFCYDEF(5)
# Ctrl site par défaut par rapport au critčre, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2") From TRTX3
Call GLOBVAR(GFCY,"VEN") From TRTX3
Gosub CHARG_PARAM From SUBSOHA: : If GERR=1 OK=0 : Return Endif # Bug 120236
[M:SOH0]SALFCY=GFCY

## Alimentation du type de commande avec le premier existant
Local Char WSOHTYP(GLONTSO) : Local Integer  WSOHCAT : Local Char WSDHTYP(GLONTSD)
Local Integer WRECTYP

  # --------------------------------------
  # FGR 24/02/2015 : X3SUIVI104383 (début)
  #Gosub SOHTYP From TRTVENCDE : [M:SOH0]SOHTYP=WSOHTYP : [M:SOH0]SOHCAT=WSOHCAT
  Case GORDCAT
    When 1, 4
      # 1-Normale ou Toutes catégories
      WSOHTYP = GSOHTYPNOR
    When 2
      # 2-Pręt
      WSOHTYP = GSOHTYPLND
    When 3
      # 3-Factur.directe
      WSOHTYP = GSOHTYPINV
  Endcase
  # 218177 : Behavior harmonization on sales document type / X3-241356 : harmonization in document type - sales order  - 2021-04-08 by LD
  # First the type is initialized from the general parameter associated to the category
  # And if it is not ok, we search for the first type available

#  If WSOHTYP = "" Then
#    Gosub SOHTYP From TRTVENCDE
#  Else
#    Local Integer IRET
#
#    Call LEC_TSO_LEG(GCURLEG, WSOHTYP, IRET) From TRTLECLEG
#    WSOHCAT = [F:TSO]SOHCAT
#    WSDHTYP = [F:TSO]SDHTYP
#    GCPT    = [F:TSO]CODNUM ## SAM 115915 LC (21/11/16)
#    WRECTYP = [F:TSO]RECTYP
#  Endif
#  [M:SOH0]SOHTYP = WSOHTYP
#  [M:SOH0]SOHCAT = WSOHCAT
  If WSOHTYP<>""
    Call CONTTSO(WSOHTYP,GCURLEG,"SOH0","SOHTYP",GFCY,"",GSOCIETE) From SUBTSO
    If !mkstat
      [M:SOH0]SOHTYP=WSOHTYP
    Endif
  Endif
  If mkstat | WSOHTYP = ""
    Raz GMESSAGE
    Raz mkstat
    # Search for first type available
    Gosub SOHTYP From TRTVENCDE
  Endif
  If WSOHTYP<>""
    [M:SOH0]SOHTYP =  WSOHTYP
    [M:SOH0]SOHCAT = [F:TSO]SOHCAT
    [M:SOH2]SDHTYP = [F:TSO]SDHTYP
    WRECTYP = [F:TSO]RECTYP
    Call AP_SOHTYP([M:SOH0]SOHTYP) From SUBSOH
    If GERR=1 Return Endif
    Call AM_SOHTYP([M:SOH0]SOHTYP) From SUBSOH
  Endif
  # 218177 : Behavior harmonization on sales document type / X3-241356 : harmonization in document type - sales order  - 2021-04-08 by LD

  # FGR 24/02/2015 : X3SUIVI104383 (fin)
  # --------------------------------------

# 75115 : V7 : Extension of Digital Signature : New field delivery type
#[M:SOH2]SDHTYP=WSDHTYP # Issue X3-218177 - 2021-05-28 by MUARN : already done before
GMANCOU = 1
# Init.devise pr init.format saisie colonnes remise pr pouvoir ensuite afficher le tableau des lignes
[M:SOH1]CUR=GLOCALDEV
#----------------------------------------------------#
# Chargement libellés et formats colonnes tarif      #
#----------------------------------------------------#
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Call ALICOLREM (1,2,GFLAG,"SOH4",[M:SOH1]CUR,1,[M:SOH0]PLISTC) From TRTPRICE
#Else
#    # Alimentation du format des colonnes frais/remise
#    Call ALIFORREM (2, GFLAG, "SOH4", 0, [M:SOH1]CUR) From TRTPRICE
#Endif
# -----------------------------------------------------------------------#
# Affichage entętes colonnes variables (comptes et sections analytiques) #
# -----------------------------------------------------------------------#
Gosub AFF_TITCOL From SUBSOHA # Bug 120236

[M:SOH2]ALLTYP=GALLTYP

If [M:SOH0]SOHCAT=2 & dim([M:SOH1]LNDRTNDAT)> 0
    If [M:SOH1]LNDRTNDAT = [0/0/0]
        [M:SOH1]LNDRTNDAT  = addmonth([M:SOH0]ORDDAT,1)
    Endif
Endif

# 107890 : Scheduled invoices : (LD:14/01/16)
If [M:SOH0]SOHCAT=1
    [M:SOH3]VCRINVCNDDAT=[M:SOH0]ORDDAT
Endif
# 107890 : Scheduled invoices : (LD:14/01/16)

[M:SOH2]STOFCY=GFCYDEF(7)
If [M:SOH2]STOFCY<>""
   Read [FCY]FCY0=[M:SOH2]STOFCY
   #If [F:FCY]LEGCPY <> GSOCIETE  Raz [M:SOH2]STOFCY Endif                   # bug 120236
   If [F:FCY]LEGCPY <> GSOCIETE and GFCYDEF(5)<>"" :Raz [M:SOH2]STOFCY:Endif # bug 120236
Endif

# -- gestion des textes
Call RAZ_CLOB From ACLOB
Raz [M:SOH0]SOHTEX1, [M:SOH0]SOHTEX2

Call RESET_IMAGE (4) From GESECRAN

#--------------------------------#
# Effacement des masques adresse #
#--------------------------------#
Raz GTARFLG
Raz [M:ADB1], [M:ADB2], [M:ADB3]
#If dim([M:SOH3]NBAXE) > 0 [M:SOH3]NBAXE = GOPTCANA Endif

Raz [M:SOH1]CDTSTA   : # Pour recalculer l'état crédit
[M:SOH1]HLDSTA = 1  # order holds
[M:SOH1]ORDSTA = 1:[M:SOH1]ALLSTA=1:[M:SOH1]DLVSTA=1:[M:SOH1]INVSTA=1
[M:SOH1]OCNPRN = 1

# --> Gestion des signatures : Positionnement flag modif signature
[M:SOH1]APPFLG = 1  : GUPDAPPFLG=1

If dim(GWEBSERV)=1 & GWEBSERV=1
    Raz GWEBFOCITMREF, GWEBFOCQTY, GWEBFOCUOM, GWEBFOCMOTIF, GWEBNBGRA
    # Bug 57682
    If clalev([M:ACL1])  Raz [M:ACL1] : Endif
    If clalev([M:ACL2])  Raz [M:ACL2] : Endif
    # Bug 57682
Endif
Local Integer WNEWSFITAMBPC : WNEWSFITAMBPC = 0 :#CPO 73887
If [M:SOH0]BPCORD <> ""
    # FGR 07/04/2015 : X3SUIVI107457 (début)
    #    VALEUR = [M:SOH0]BPCORD
    #    Gosub BAP_BPCORD From SUBSOH
    #    Call AM_BPCORD(VALEUR) From SUBSOH
    VALEUR = [M:SOH0]BPCORD
    Gosub BAP_BPCORD From SUBSOH
    Call AP_BPCORD(VALEUR) From W1SOH0
    Call AM_BPCORD(VALEUR) From W1SOH0
    # FGR 07/04/2015 : X3SUIVI107457 (fin)
    WNEWSFITAMBPC = 1 :#CPO 73887 Il ne faut plus faire le NEW_SFIT en fin de Razcre
Endif

# GRNA 18/05/2011
Local Char CUSSEAORI(GLONAOB) : CUSSEAORI = "SOH1"
Gosub RAZCRE From CUSSEALIB

#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#
Gosub GRIZE_LIENS From SUBSOHA # Bug 120236

#-- X3Suivi 75115 Libellé Catégorie --#
[M:SOH0]WSOHCAT = mess(8,105,1) - ':' - mess([M:SOH0]SOHCAT,412,1)

  # FGR 13/01/2014 : X3SUIVI96419 (début)
  Raz [M:SOH0]NBCON
  Raz [M:SOH0]CONUMDEL
  Raz [M:SOH0]CONNUMLIG
  # FGR 13/01/2014 : X3SUIVI96419 (fin)

Affzo [M:SOH0]1-99
Affzo [M:SOH1]1-99

Raz YSQHNUM

# Remplissage des boites de picking
Gosub REMPBOX From SUBSOHC

#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SOH0]DSPWEU = GSALDSPWEU
[M:SOH0]DSPVOU = GSALDSPVOU

# -- ACA - Ouverture du tableau de stockage des éléments facture
If WNEWSFITAMBPC=0 :#CPO 73887
  Local Char SFIT_OBJ : SFIT_OBJ="SOH"
  Gosub INIT_SFIT From SUBSFIT
  Call NEW_SFIT ("M","SOH3","","","",[0/0/0]) From SUBSFIT
Endif

Gosub FREEGROUP_GSOHVCRINVCND From LIBSAL_INVCND_SOH # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management

# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#--Also we have to Raz the differents flags
Raz [M:SOH4]DINVCNDISCHG, [M:SOH4]DINVCNDPREV, [M:SOH4]DINVCNDTODEL, [M:SOH4]DINVCNDTOUPD, [M:SOH4]DINVCNDTODIS
# End issue 107888

# Issue X3-135076 by ANKUL - drives visibility of fields for PT Signature
If func AFNC.ACTIV('KPO') > 0
  If dim([M:SOH1]SOHCFMFLG) > 0 and dim([M:SOH0]SOHNUMEND) > 0 and dim([M:SOH1]SOHVALDATC) > 0
    Chgfmt [M:SOH1]SOHCFMFLG   With "-LA1:15X"
    Chgfmt [M:SOH0]SOHNUMEND   With "-K:" + num$(GLONVCR) + "X"
    Chgfmt [M:SOH1]SOHVALDATC  With "-K:10X"
  Endif
Endif
# Issue X3-135076 end

Return

#########################################################################
# ------------------------------------------------------------------------------------------------------------ #
# Suppression des boutons                                                                                      #
# ------------------------------------------------------------------------------------------------------------ #
#     H : Changement de code                                                                                   #
#     A : Supprimer  : Si cde préparée, livrée, facturée                                                       #
#     1 : Allocation : Si aucune cde ou si cde alloc. auto ou si cde soldée                                    #
#                         ou si cde non signée et pas d'encours ou pas d'alloc des cdes non signées            #
#                         ou si tout est préparé et/ou livré                                                   #
#                      Si aucune ligne gérée en stock                                                          #
#     2 : Livraison  : Si aucune cde ou cde ŕ facturation directe ou si cde soldée                             #
#                         ou si cde non signée                                                                 #
#     3 : Facture    : Si aucune cde ou non cde ŕ facturation directe ou si cde soldée                         #
#                         ou si cde non signée                                                                 #
#     4 : Proforma   : Si aucune cde, si cde partiel.liv ou fac, si cde non signée                             #
#                      Si cde inter-site, si cde pręt ou si déjŕ proforma                                      #
#     5 : Solde      : Si aucune cde, si cde soldée, ou solde non autorisé                                     #
#                      Si cde préparée                                                                         #
#                      Si cde inter-site générée par le module achat                                           #
#     6 : Préparation: Si aucune cde ou cde ŕ facturation directe ou si cde soldée                             #
#                         ou si plus rien ŕ préparer, si cde non signée                                        #
# ------------------------------------------------------------------------------------------------------------ #
$SETBOUT

# Issue X3-57674:80644 - 2018-03-01 by SDEM : Revision mgmt button on right panel Begin
  If ([M:SOH0]REVNUM = 0)
    Call VIREBOUT(CHAINE, "7") From GOBJET
  Endif
# Issue X3-57674:80644- 2018-03-01 by SDEM : Revision mgmt button on right panel End
  # FGR 13/08/2014 : X3SUIVI93839 Déplacé de SUBSOHA
Local Integer I
Local Decimal WPREQTY :

WPREQTY=sum([M:SOH4]LPRQTY,[M:SOH4]OPRQTY,[M:SOH4]PREQTY)
# 100013 : Une ligne sur liste de prépa peut ętre allouée mais pas préparée
#Local Integer WALL_PRE_STA : # Bug 76907
Local Integer WALL_STA
Local Integer WPRE_STA
# 100013
Local Integer WLIV_STA      : # 107888 : Scheduled invoices : (LD:01/06/16)
Gosub SETB_VERIF_QTY From SUBSOHA        : # Bug 76907

# Si l'on vient d'ailleurs suppression du bouton créér et des accčs aux autres enr.
#MAE, on ne supprim epas l'accés au bouton créer si on vient des clients
#If GFONC1 <> "GESSOH"
#--CPO 75453 Erreur indice
#If GFONC1 <> "GESSOH" & GNAVIG(GPILNAV-1) <> "GESBPC"
#   Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET # Bug 73701 - Le L (impression liste) est retiré du VIREBOUT
#Endif
If GFONC1 <> "GESSOH"
  If GPILNAV>1
    If !find(GNAVIG(GPILNAV-1),"GESBPC")
      Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET
    Endif
  Else
    Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET
  Endif
Endif
#--CPO fin

# Pas de bouton "Livraison","Facture","Proforma" et "Préparation"
# si l'on vient par tunnel des livraisons ou factures
If find(GFONC1,"GESSDH","GESSIH")
   Call VIREBOUT(CHAINE,"2346") From GOBJET
Endif
# Bug 39742 : Si mode consultation, il faut désactiver les boutons
If GCONSULT
   Call VIREBOUT(CHAINE,"123456") From GOBJET
Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
If !CLECUR | [M]DLVSTA <> 1 | [M]INVSTA <> 1 | WPREQTY<>0
   Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If GREP <> "" | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | ([M:SOH1]APPFLG<3 & (GSOHAPPORD=1 | GSOHAPPALL=1)) |
&  sum([M:SOH4]STOMGTCOD) = [M:SOH4]NBLIG |
&  WALL_STA = 0       : # 100013 : Une ligne sur liste de prépa peut âtre allouée mais pas préparée
#&  WALL_PRE_STA = 0  : # 100013
#&  sum([M:SOH4]LPRQTY,[M:SOH4]OPRQTY,[M:SOH4]PREQTY,[M:SOH4]ODLQTY,[M:SOH4]DLVQTY)>=sum([M:SOH4]QTY) : # Bug 76907
   Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
# 107888 : Scheduled invoices : (LD:01/06/16)
# Desable Delivery button if all the lines deliverable are delivered
#If GREP <> "" | [M:SOH0]SOHCAT = 3  | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3
#   Call VIREBOUT(CHAINE,"2") From GOBJET
#Endif
If GREP <> "" | [M:SOH0]SOHCAT = 3  | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3 |
&  WLIV_STA = 0
   Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
# 107888 : Scheduled invoices : (LD:01/06/16)
# Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
#If GREP <> "" | [M:SOH0]SOHCAT <> 3 | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3
If GREP <> "" |  CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3
   Call VIREBOUT(CHAINE,"3") From GOBJET
Endif
If [M:SOH0]SOHCAT <> 3
   If [M:SOH0]SOHCAT<>1
     Call VIREBOUT(CHAINE,"3") From GOBJET
   Else
     #--Only if there are scheduling invoices associated to the order lines
     If [M:SOH4]NBLIG>0 and sigma(0,[M:SOH4]NBLIG-1,[M:SOH4]DINVCND(indcum)<>"" and [M:SOH4]QTY(indcum)>[M:SOH4]INVQTY(indcum))=0
       Call VIREBOUT(CHAINE,"3") From GOBJET
     Endif
   Endif
Endif
# End issue 107888
If GREP <> "" | CLECUR = 0 | [M:SOH1]DLVSTA > 1 | [M:SOH1]INVSTA > 1 | [M:SOH1]APPFLG<3 |
&  ([M:SOH1]BETFCY=2 & [M:SOH1]BETCPY<=1) | [M:SOH0]SOHCAT = 2 | [M:SOH3]PRFNUM <> ""
   Call VIREBOUT(CHAINE,"4") From GOBJET
Endif
If GREP<>"" | CLECUR=0 | [M:SOH1]ORDSTA=2 | [M:SOH2]ORDCLE=1 | WPREQTY<>0 |
&  ([M:SOH0]ORIFCY<>"" & [M:SOH0]ORIFCY<>[M:SOH0]SALFCY)
   Call VIREBOUT(CHAINE,"5") From GOBJET
Endif
If GREP <> "" | [M:SOH0]SOHCAT = 3  | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3 |
&  WPRE_STA = 0       : # 100013 : Une ligne sur liste de prépa peut âtre allouée mais pas préparée
#&  WALL_PRE_STA = 0  : # 100013
#&  sum([M:SOH4]LPRQTY,[M:SOH4]OPRQTY,[M:SOH4]PREQTY,[M:SOH4]ODLQTY,[M:SOH4]DLVQTY)>=sum([M:SOH4]QTY) : # Bug 76907
   Call VIREBOUT(CHAINE,"6") From GOBJET
Endif
# Issue X3-57674:80644 - 2018-03-01 by SDEM : Revision mgmt button on right panel Begin
If ([M:SOH0]REVNUM = 0) | GREP <> "" | CLECUR = 0
   Call VIREBOUT(CHAINE, "7") From GOBJET
Endif
# Issue X3-57674:80644- 2018-03-01 by SDEM : Revision mgmt button on right panel End
# -------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                     #
# -------------------------------------------------------------------------------------- #
#   E,F : Texte              : Actif si commande en ligne ou création ou duplication     #
# H,J,K : Adresse            : Actif si commande en ligne ou création ou duplication     #
#     U : Info douaničres    : Actif si devis en ligne                                   #
#   L,M : Contremarque       : Désactivé si aucune cde ou cde soldée                     #
#     R : Acomptes           : Actif si commande en ligne et rien en cours               #
#     T : Situation commande : Actif si commande en ligne et rien en cours               #
#     W : Transaction                                                                    #
#     V : Bouton bidon en C/S, permettant de valoriser une cde sur le site e_commerce    #
#     N : Traçabilité pičces                                          SEGAY 05/12/2008   #
#     O : Sage Sales Tax                                              RBU 26/04/2012     #
# -------------------------------------------------------------------------------------- #
If GREP="C" | GREP="D" | CLECUR
    CHMEN += "EF"
    CHMEN += "HJK"
Endif
If CLECUR CHMEN += "UP" Endif
If CLECUR & GREP="" & [M:SOH1]ORDSTA <> 2
# Issue X3-222637 - 2020-12-18 by SR : Is BTB authorized for this user ?
#    For I=0 To [M]NBLIG-1
#        If find([M]FMI(I),2,3) & [M]FMINUM(I) = ""                       : # Bug 82706
#        If find([M]FMI(I),2,3) & [M]FMINUM(I) = "" & GFONC1 <> "GESPOH"   : # Bug 82706
#         #Issue 119459.sn - 2017-02-24 by CATUA
#         #Check Block BTB (Back-To-Back) flag within manual hold reason miscellaneous table (204)
#         #If func MANHLDLIB.BLK_BACK_TO_BACK([M:SOH1]HLDSTA,[M:SOH1]HLDCOD) = [V]CST_ANO
#             If !instr(0,CHMEN,"L") CHMEN += "L" Endif
#         #Endif
#        If ([M]FMI(I) = 5) & [M]FMINUM(I) = ""
#         #Issue 119459.sn - 2017-03-02 by CATUA
#         #Check Block BTB (Back-To-Back) flag within manual hold reason miscellaneous table (204)
#         #If func MANHLDLIB.BLK_BACK_TO_BACK([M:SOH1]HLDSTA,[M:SOH1]HLDCOD) = [V]CST_ANO
#         If !instr(0,CHMEN,"M") CHMEN += "M" Endif
#         #Endif
#    Next
    # Is there any Purchase BtoB line ?
    I = sigma(I=0,[M:SOH4]NBLIG-1, 1* (find([M]FMI(I),2,3)>0 & [M]FMINUM(I) = ""))
    If I & GFONC1 <> "GESPOH"
      # "B" is the option in the function. "L" is the button in the Window
      # if "B" option activated, "L" button will be added
      GFCY=[M:SOH0]SALFCY : GBIDC2="B" : Gosub AUTORIS_OPT From CONTX3
      If GBIDI2
        If !instr(0,CHMEN,"L") CHMEN += "L" Endif
      Endif
    Endif
    # Is there any WO BtoB Line ?
    I = sigma(I=0,[M:SOH4]NBLIG-1, 1* ([M]FMI(I) = 5 & [M]FMINUM(I) = ""))
    If I
      # "G" is the option in the function. "M" is the button in the Window
      # if "G" option activated, "M" button will be added, otherwise it will be removed
      GFCY=[M:SOH0]SALFCY : GBIDC2="G" : Gosub AUTORIS_OPT From CONTX3
      If GBIDI2
        If !instr(0,CHMEN,"M") CHMEN += "M" Endif
      Endif
    Endif
# End issue X3-222637
Endif
If CLECUR & GREP = ""
    CHMEN += "RT"
Endif
CHMEN += "0"  # FGR 31/07/2014 : X3SUIVI101684 "W" devient "0"
# If  func AFNC.ACTIV("LTA") & GLOCUSATAX : CHMEN += "O" : Endif   # 106867.o  #This menu option does not exist for v7 and above
If dim(GWEBSERV)=1 & GWEBSERV=1 CHMEN += "V" : Endif
If !find(GREP,"C","D") and !find("CONSPIV",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SEGAY 05/12/2008 : branchement traçabilité pičces

# 78411 Sage Exchange
If CLECUR & GREP="" & func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:SOH3]PTE) & [M:SOH1]CDTSTA<>4
  #If the payment method has Sage Exchange turned on - enable the menu
  If !instr(0,CHMEN,"S") : CHMEN += "S" : Endif
Endif

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func AFNC.ACTIV("KPO")
  Local Char    LSIVTIP(30) : [L]LSIVTIP=''
  Call PARAM([M]STOFCY,"SIVTYP",[L]LSIVTIP) From ADOVAL
  If func PORLEGLIB.VAL_SIMINV([L]LSIVTIP) = 2
    Call VIREBOUT(CHAINE,"3") From GOBJET
  Endif

  # Issue X3-135076 by ANKUL - drives the availability of Signature button
  If GREP<>"" or !CLECUR or func PORLEGLIB.DIGSIGN([M:SOH0]SALFCY, "") <> 1 or [M:SOH1]SOHCFMFLG = 2
    Call VIREBOUT(CHAINE,"8") From GOBJET
  Endif
  # Issue X3-135076  end
  # Issue X3-135097 - 2019-05-27 by ANKUL : begin
  If func PORLEGLIB.PORLEG([M:SOH0]SALFCY,"") =1 & func PORLEGLIB.DIGSIGN([M:SOH0]SALFCY, "")
    If [M:SOH1]SOHCFMFLG <> 2
      Call VIREBOUT(CHAINE,"234E") From GOBJET
    Endif
  Endif
  # Issue X3-135097 - 2019-05-27 by ANKUL : end
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END
#RBA 110811/US2
If func AFNC.ACTIV("EDIX3") <> 0
  If func CNSEDKSTD.GET_EDI_CATACT([M]SOHNUM, 4) <> 0
    CHMEN += "G" #Historic
  Endif
#CJ 110811/US9
 GFCY=[M:SOH0]SALFCY : GBIDC2="I" : Gosub AUTORIS_OPT From CONTX3
  If GBIDI2
 #RBA 112138/US2
     CHMEN += "O" #Run EDI Issue
  Else
  Call VIREBOUT(CHMEN,"O") From GOBJET # No EDI Issue
  Endif
#/CJ 110811/US9
Endif
#/RBA 112138/US2
# 119630.sn - JOBRO - disable order hold / release button if in edit mode
If GREP<>"" : Grizo [M:SOH1]HLDBTN : Endif
# 119360.en
# Issue X3-81805 - 2018-04-06 by VAVIL : Is possible delete documents that go to SAF-T
If func PORLEGLIB.PORLEG([M:SOH0]SALFCY,"") :  Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
# End issue X3-81805
# Issue X3-242624 by MRDAB - Prepayments deactivated for companies using prepayment invoices
#Call GLOBVAR([M:SOH0]SALFCY) From WWGLOBTC # Issue X3-243690 by MRDAB - moved to LIENS
If [V]GPREFUN = 2
  Call VIREBOUT(CHMEN,"R") From GOBJET
Endif
# Issue X3-242624 end
Gosub SET_BOUT_SPE From GSAISIE
Return

#########################################################################
$DEFTRANS

# Si on ne vient pas de la gestion des commandes
If GFONC1 <> "GESSOH" Raz GFLAG Endif

# Par défaut on a droit ŕ toutes les transactions
GORDCAT= 4
# Si tunnel, on filtre avec la catégorie de commande
If SAVCLE1<>"" & !GIMPORT : # Bug 56046 : Si SAVCLE1<>"", on vient d'un vrai tunnel
   Read [SOH]SOH0=CLE1
   If !fstat GORDCAT = [F:SOH]SOHCAT Endif
Endif

# GRNA 18/05/2011
Local Char CUSSEAPAR : CUSSEAPAR = "TRSCSORD"
Gosub DEFTRANS From CUSSEALIB
Return

#########################################################################
$VARIANTE
# La transaction lu est elle utilisable ?
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=2;[F:AWI]TRN
If fstat
   OK = 0
Elsif [F:SLT]ENAFLG<>2 | (GORDCAT <> 4 & [F:SLT]ORDCAT <> 4 & [F:SLT]ORDCAT <> GORDCAT)
   OK = 0
Endif
Return

#########################################################################
$SETTRANS
Gosub SETTRANS_DEF

If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=2;GFLAG
If clalev ([F:DTR])=0 Local File DIETRS [DTR] Endif
Read [DTR]DTR0="SLT";2;GFLAG;0;0

GORDCAT    = [F:SLT]ORDCAT
WSLTDOCFLG = [F:SLT]DOCFLG
WSLTDOCNAM = [F:SLT]DOCNAM
WSLTSNSFLG = [F:SLT]SNSFLG
WSLTSNSNAM = [F:SLT]SNSNAM
WSLTSTRNUM = [F:SLT]STRNUM
GAVASTOCOD = [F:SLT]AVASTOCOD
GWALLQTYCOD= [F:SLT]WALLQTYCOD

If  func AFNC.ACTIV("LTA") : GSSTENTCOD  = [F:SLT]SSTENTCOD  : Endif  #LTA.n

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SLT]GFY

Close Local File [SLT], [DTR]
Return

#########################################################################
$SETTRANS_DEF

Local  Shortint WSLTDOCFLG, WSLTSNSFLG
Local  Char     WSLTDOCNAM(GLONARP), WSLTSNSNAM(GLONARP)
Local  Char     WSLTSTRNUM(GLONTRS)
Global Integer  GAVASTOCOD  : GAVASTOCOD=1  : # Flag visu date 1ere disponibilité sur qte commandée
Global Integer  GWALLQTYCOD : GWALLQTYCOD=1 : # Flag saisie qté ŕ allouer
Global Integer  GSSTENTCOD  #LTA.n
GORDCAT = 4
Raz WSLTDOCFLG, WSLTDOCNAM, WSLTSNSFLG, WSLTSNSNAM, WSLTSTRNUM

Return

