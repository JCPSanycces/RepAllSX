    If clalev([M:ACL2])  Close Local Mask [ACL2] : Endif

    #----- Gestion des adresses
    GACTSAD=SAVGACTSAD
    # Bug 57682
Endif

#--------------------------------------------------------------#
# Restitution des variables globales                           #
# Suppression des variables globales spécifiques au traitement #
#--------------------------------------------------------------#
Raz GORITRFBPP
GVENCFG=0
GORITITCOL=0
#-----
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1 ="GESSOH" Raz GCREPARBOU : Endif
#--- Si on vient par tunnel des devis
#    positionner mkstat qui permettra de forcer un réaffichage au retour du tunnel
If GFONC1 = "GESSQH" mkstat=GSTALIT : Endif
#-- effacement icone texte
Call RESET_IMAGE (4) From GESECRAN

#-- Appel l'état "PRTSCR"
If !GIMPORT : Call IMPSCR From ATRTX3 : Endif

# Remise ŕ blc des msgs qu'on aurait pu mettre en bas d'écran (kit non gere en stock par ex)
GERR=4: GMESSAGE="                                  "

If dim(GSOHSUPPLIGDSP)>0 Kill  GSOHSUPPLIGDSP  Endif : #--CPO 79343 Afin d'afficher un message si suppr ligne et doc ori avec elts fact
If dim(GINVTYP)>0 : Raz GINVTYP : Endif #Gbn-83877
If dim(G_PREV_DSPLIN)>0  Kill  G_PREV_DSPLIN : Endif : #--CPO 102340

  GCREFONC = 0 # FGR 18/02/2014 : X3SUIVI96940 on remet une valeur normale.

# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
Local Integer IJCPO
If dim(GSOHVCRINVCND_UPD)>0
  #If maxtab(GSOHVCRINVCND_UPD)>0
  #  FreeGroup GSOHVCRINVCND_UPD(1..maxtab(GSOHVCRINVCND_UPD)) #--Does it work ?
  #Endif
  For IJCPO= 0 To maxtab(GSOHVCRINVCND_UPD)
    If GSOHVCRINVCND_UPD(IJCPO)<>null
      FreeGroup GSOHVCRINVCND_UPD(IJCPO)
      GSOHVCRINVCND_UPD(IJCPO)=null
    Endif
  Next
  Kill GSOHVCRINVCND_UPD
Endif
# End issue 107888
  Gosub PJM_ORDERS_SOQQTY_FREEGROUP  # Issue X3-18442/120906 - 2017-01-13 by FGR

# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD
Gosub PJM_PRGBIL_TBECHK_UPD_FREEGROUP
# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD

# Issue 122614 - JOBRO
If dim(G_SST_EXCEPTION) > 0
  Kill G_SST_EXCEPTION
Endif
# End Issue 122614

# Issue X3-243690 by MRDAB
If GMODU(3) = 2 and GFONCTION1 <> "GESPREPI"
  Gosub KILL_G_ACT_CODE From SUBPREPI
Endif
# Issue X3-244526 by MRDAB
If dim([V]GCONTRACTS_TO_CLOSE) > 0
  Kill [V]GCONTRACTS_TO_CLOSE
Endif
# Issue X3-244526 end
# Issue X3-243690 end
# Issue X3-243729 by SDEM
If dim([V]GDEL_ARR)>0
  Kill [V]GDEL_ARR,GUPD_SO_LINE
Endif
# Issue X3-243729 End


Return

###########################################################################################
$ABANDON

Gosub DEVERROU_SQH From SUBSOHA

Local Integer I, WRET

If GREP="D"
   If left$([M:SOH0]SOHTEX1,3)="SOH"
      Call SUP_CLOB([M:SOH0]SOHTEX1,WRET) From TRTX3TEX
   Endif
   If left$([M:SOH0]SOHTEX2,3)="SOH"
      Call SUP_CLOB([M:SOH0]SOHTEX2,WRET) From TRTX3TEX
   Endif
Endif
If GREP="D" | sum([M:SOH4]DETSQHNUM)<>""
   For I=0 To [M]NBLIG-1
      If GREP="D" | ([M:SOH4]DETSQHNUM(I)<>"" & [M:SOH4]CREFLG(I)=0)
          If left$([M:SOH4]SOQTEX(I),3)="SOQ"
             Call SUP_CLOB([M:SOH4]SOQTEX(I),WRET) From TRTX3TEX
          Endif
      Endif
   Next I
Endif

Call RAZ_CLOB From ACLOB

Actzo [M:SOH0]SOHNUM

If GREP="C"
   Raz GREP
   Gosub REMPBOX From SUBSOHC
Endif

Raz GORITRFBPP
  Gosub PJM_ORDERS_SOQQTY_FREEGROUP  # Issue X3-18442/120906 - 2017-01-13 by FGR
  Gosub PJM_OPPOR_PSO_FREEGROUP      # Issue X3-8085/121537 - 2017-02-15 by FGR

# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD
Gosub PJM_PRGBIL_TBECHK_UPD_FREEGROUP
# 200515 : Progress billing / X3-199480 : Billing plan update when the sales order lines is updated (quantity or price) (*)  - 2020-07-27 by LD

# Issue X3-244526 by MRDAB
If [V]GPREFUN = 2
  # Issue X3-246053 by MRDAB
  If (dim([V]GCONTRACTS_TO_CLOSE) and maxtab([V]GCONTRACTS_TO_CLOSE) > -1) or (dim([L]CONTRACTS_TO_UPDATE) and maxtab([L]CONTRACTS_TO_UPDATE) > -1)
    Gosub UNLOCK_PREPAYMENT_CONTRACTS
    Raz [V]GCONTRACTS_TO_CLOSE
    Raz [L]CONTRACTS_TO_UPDATE
    Raz [L]SOH_CHANGED_FOR_PREPAYMENT_INV
  Endif
  # Issue X3-246053 end

  # Issue X3-243729 by SDEM
  If dim([V]GDEL_ARR) and maxtab([V]GDEL_ARR) > -1
    Raz [V]GDEL_ARR,[V]GUPD_SO_LINE,[V]CHG_FLG
  Endif
  # Issue X3-243729 End
Endif
# Issue X3-244526 end

Return

