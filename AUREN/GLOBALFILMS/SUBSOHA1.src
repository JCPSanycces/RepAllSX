####################################################################
# X3-69134 : Performance enhancements for sales order import : X3-74053 : Analytical dimensions management (LD:05/29/18)
# Now it is not done in import, we consider it has been done in SUBSOH.C_CCEX, it is not necessary to redo it
# X3-69134 : Performance enhancements for sales order import : X3-74053 : Analytical dimensions management (LD:05/29/18)
# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
$VERIF_CTL_ALLCCE

Local Integer NE
Local Char SAXECTRL(GLONCCE)

  If func AFNC.ACTIV("ANA")>0
    # -------------------------------------
    For I = 0 To [M:SOH3]NBAXE-1
      If [M:SOH3]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M:SOH3]CCE(I)) From W1SOH3
        If mkstat Then
          OK = 0
          Break
        Endif
      Endif
    Next
    If OK = 0 Then
      Return
    Endif

    #--This control has to be done also during Creation/Update of a document
    For I=0 To [M:SOH4]NBLIG-1
      # -------------------------------------
      For NE = 1 To 20
        If evalue("type([M:SOH4]CCE" + num$(NE) + "(I)) >= 0") Then
          SAXECTRL = evalue("[M:SOH4]CCE" + num$(NE) + "(I)")
          # X3-69134 : Performance enhancements for sales order import : X3-74053 : Analytical dimensions management (LD:05/29/18)
          #--No need to do a control if at least one of doc's previous lines has the same value
          #--Has to be done during IMPORT as it is done in SUBSOH.C_CCEX
          If GIMPORT and I>0  and SAXECTRL<>""
            GBIDI1=0
            Case NE
              When 1 : If find(SAXECTRL,[M:SOH4]CCE1(0..I-1))>0
                         SAXECTRL = ""
                       Endif
              When 2 : If find(SAXECTRL,[M:SOH4]CCE2(0..I-1))>0
                         #--all previous sections have the same values for all i-1 lines (if not the ctrl forbiden section/section has to be done)
#                         GBIDI1=sigma(indcum=1,I,SAXECTRL=[M:SOH4]CCE2(indcum-1)*([M:SOH4]CCE1(indcum-1)<>"" and [M:SOH4]CCE1(I)<>"" and [M:SOH4]CCE1(indcum-1)<>[M:SOH4]CCE1(I)))
                         If GBIDI1<1
                           SAXECTRL = ""
                         Endif
                       Endif
              When 3 : If find(SAXECTRL,[M:SOH4]CCE3(0..I-1))>0
#                         GBIDI1=sigma(indcum=1,I,SAXECTRL=[M:SOH4]CCE3(indcum-1)*(([M:SOH4]CCE1(indcum-1)<>"" and [M:SOH4]CCE1(I)<>"" and [M:SOH4]CCE1(indcum-1)<>[M:SOH4]CCE1(I)) or
#&                                                ([M:SOH4]CCE2(indcum-1)<>"" and [M:SOH4]CCE2(I)<>"" and [M:SOH4]CCE2(indcum-1)<>[M:SOH4]CCE2(I))))
                         If GBIDI1<1
                           SAXECTRL = ""
                         Endif
                       Endif
              When 4 : If find(SAXECTRL,[M:SOH4]CCE4(0..I-1))>0
#                         GBIDI1=sigma(indcum=1,I,SAXECTRL=[M:SOH4]CCE4(indcum-1)*(([M:SOH4]CCE1(indcum-1)<>"" and [M:SOH4]CCE1(I)<>"" and [M:SOH4]CCE1(indcum-1)<>[M:SOH4]CCE1(I)) or
#&                                                ([M:SOH4]CCE2(indcum-1)<>"" and [M:SOH4]CCE2(I)<>"" and [M:SOH4]CCE2(indcum-1)<>[M:SOH4]CCE2(I)) or
#&                                                ([M:SOH4]CCE3(indcum-1)<>"" and [M:SOH4]CCE3(I)<>"" and [M:SOH4]CCE3(indcum-1)<>[M:SOH4]CCE3(I))))
                         If GBIDI1<1
                           SAXECTRL = ""
                         Endif
                       Endif
              When 5 : If find(SAXECTRL,[M:SOH4]CCE5(0..I-1))>0
#                         GBIDI1=sigma(indcum=1,I,SAXECTRL=[M:SOH4]CCE5(indcum-1)*(([M:SOH4]CCE1(indcum-1)<>"" and [M:SOH4]CCE1(I)<>"" and [M:SOH4]CCE1(indcum-1)<>[M:SOH4]CCE1(I)) or
#&                                                ([M:SOH4]CCE2(indcum-1)<>"" and [M:SOH4]CCE2(I)<>"" and [M:SOH4]CCE2(indcum-1)<>[M:SOH4]CCE2(I)) or
#&                                                ([M:SOH4]CCE3(indcum-1)<>"" and [M:SOH4]CCE3(I)<>"" and [M:SOH4]CCE3(indcum-1)<>[M:SOH4]CCE3(I)) or
#&                                                ([M:SOH4]CCE4(indcum-1)<>"" and [M:SOH4]CCE4(I)<>"" and [M:SOH4]CCE4(indcum-1)<>[M:SOH4]CCE4(I))))
                         If GBIDI1<1
