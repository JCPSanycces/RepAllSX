#########################################################################
$APRES_MODIF
If find(COUZON,"SOHTYP","SALFCY","BPCORD","BPAADD","STOFCY","CUR","PRITYP","PTE","VACBPR")
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   If COUZON="SALFCY" [M]SALFCY=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPCORD" [M]BPCORD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPAADD" [M]BPAADD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="PTE" [M]PTE=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="PRITYP" [M]PRITYP=val(CZ) Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="VACBPR" [M]VACBPR=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   Gosub TIROIR From SUBSOHC
Endif
# --> Gestion des signatures : Positionnement du flag modif signatures
If find(COUZON,"BPCINV","BPCPYR","BPCGRU","BPAADD","PJT","VACBPR","MDL","DAYLTI","DME","IME","PTE","DEP","INVDTAAMT","BPTNUM")
    GUPDAPPFLG=2
Endif
If find(COUZON,"DBPAADD","DMDL","DDAYLTI","QTY","SAUSTUCOE","GROPRI","DBPTNUM") | instr(1,COUZON,"DISCRGVAL") | instr(1,COUZON,"VACITM")
    [M:SOH4]WUPDAPPFLG(nolign-1)=2
Endif
Return
####################################################################
# Bug 43581 - TS le 07.11.07
####################################################################
$MAJITV
Local Decimal WQTY
Local Char    WSENS
Local Char    WTYP    :    WTYP="S"
Local Integer WRET
#---------------------------------------------------------------------------------#
# Maj des cumuls articles : En-cde client dans ITMMVT                             #
#---------------------------------------------------------------------------------#

Case TRTLIG
    When "C" :
        # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
        If [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1
            Return
        Endif
        WFLGMOD=1 : WSENS="+"

    When "M" :
        Case SIGN
            When -1 : # Avant maj
                Local Integer WFLGMOD : Raz WFLGMOD
                If [F:SOH]APPFLG=0 & GSOHAPPORD=1 & [F:SOQ]STOMGTCOD<>1 & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMSTA=1
                    # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
                    # Si la cde passe de signée ŕ non signée et pas de maj encours si cde non signée, diminution de l'encde
                    # --> Diminution qté cdée non réalisée
                    WFLGMOD=1 : WSENS="-"
                Elsif [F:SOH]APPFLG<>0 | GSOHAPPORD=2
                    # Si non géré en stock(avant et aprčs) ou demande non ferme(avant et aprčs), pas de maj
                    If ([F:SOQ]STOMGTCOD=1 & [M]STOMGTCOD(NOL)=1) | ([F:SOQ]DEMSTA<>1 & [M]DEMSTA(NOL)<>1)
                        Return
                    Endif
                    # Si non géré en stock(avant) et demande non ferme(aprčs)
                    # ou non géré en stock(aprčs) et demande non ferme(avant), pas de maj
                    If ([F:SOQ]STOMGTCOD=1 & [M]DEMSTA(NOL)<>1) | ([M]STOMGTCOD(NOL)=1 & [F:SOQ]DEMSTA<>1)
                        Return
                    Endif
                    # Si le stock devient géré et demande ferme(aprčs)
                    If [F:SOQ]STOMGTCOD=1 & [M]STOMGTCOD(NOL)<>1 & [M]DEMSTA(NOL)=1
                        # Si commande soldée(aprčs)
                        If [M]SOQSTA(NOL)=3
                            WFLGMOD=3 : WSENS="+"
                        # Si commande non soldée(aprčs)
                        Else
                            WFLGMOD=1 : Return
                        Endif
                    Endif
                    # Si le stock devient non géré et demande ferme(avant)
                    If [F:SOQ]STOMGTCOD<>1 & [M]STOMGTCOD(NOL)=1 & [F:SOQ]DEMSTA=1
                        # Si commande soldée(avant)
                        If [F:SOQ]SOQSTA=3
                            WFLGMOD=3 : WSENS="-"
                        # Si commande non soldée(avant)
                        Else
                            WFLGMOD=1 : WSENS="-"
                        Endif
                    Endif
                    # Si géré en stock(avant et aprčs)
                    If [F:SOQ]STOMGTCOD<>1 & [M]STOMGTCOD(NOL)<>1
                        # Si la demande devient ferme
                        If [F:SOQ]DEMSTA<>1 & [M]DEMSTA(NOL)=1
                            # Si commande soldée(aprčs)
                            If [M]SOQSTA(NOL)=3
                                WFLGMOD=3 : WSENS="+"
                            # Si commande non soldée(aprčs)
                            Else
                                WFLGMOD=1 : Return
                            Endif
                        Endif
                        # Si la demande devient non ferme
                        If [F:SOQ]DEMSTA=1 & [M]DEMSTA(NOL)<>1
                            # Si commande soldée(avant)
                            If [F:SOQ]SOQSTA=3
                                WFLGMOD=3 : WSENS="-"
                            # Si commande non soldée(avant)
                            Else
                                WFLGMOD=1 : WSENS="-"
                            Endif
                        Endif
                    Endif
                    # Si demande ferme(avant et aprčs)
                    If [F:SOQ]DEMSTA=1 & [M]DEMSTA(NOL)=1
                        # Si la commande devient soldée
                        If [M]SOQSTA(NOL)=3 & [F:SOQ]SOQSTA<>3
                            WFLGMOD=2 : WSENS="-"
                        # Si la commande devient non soldée
                        Elsif [M]SOQSTA(NOL)<>3 & [F:SOQ]SOQSTA=3
                            WFLGMOD=2 : Return
                        # Le site ou la quantité ont été modifiés
                        Elsif [F:SOQ]STOFCY<>[M]DSTOFCY(NOL) | [F:SOQ]QTYSTU<>[M]QTYSTU(NOL)
                            WFLGMOD=1 : WSENS="-"
                        Else
                            #--CPO 83940 L'En-Commande client non mis ŕ jour en passant la méthode de livr. de stock ŕ contremarque
                            #--Dans ce cas prčcis, le WFLGMOD ŕ été positionné ŕ 1 avec le WSENS="-", mais parce que l'on sort directement
                            #--par le return, on ne fait pas la mise ŕ jour de l'en-commande. J'ai ajouté le test sur WFLGMOD=0, ainsi on ne sort pas
                            #--si on a une mise ŕ jour ŕ faire (du fait des if d'avant).
                            #--Comme les if sont trčs hétérogčnes, on ne peut pas ętre sűrs que le Return seul ici implique qu'il n'y a pas de mise ŕ jour...
                            #Return
                            If WFLGMOD=0 : Return : Endif
                            #--/
                        Endif
                    Endif
                Endif
            When +1 : # Aprčs maj
                If [F:SOH]APPFLG=0 & GSOHAPPORD=1 & [F:SOQ]STOMGTCOD<>1 & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMSTA=1
                    # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
                    # Si la cde passe de signée ŕ non signée et pas de maj encours si cde non signée, ajout qté cdée livrée (non réalisée)
                    # --> Ajout qté cdée livrée (réalisé)
                    WFLGMOD=4 : WSENS="+"
                # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
                Elsif [F:SOH]APPFLG<>0 | GSOHAPPORD=2
                    If [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1
                        Return
                    Endif
                Endif
                If WFLGMOD=0 : Return : Endif
                WSENS="+"
        Endcase
    When "A" :
        # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
#  89410 : Pas de maj si cde non signée et maj encours article ŕ non
#       # Pas de maj si la cde passe de signée ŕ non signée
        #If ([F:SOH]APPFLG=0 & GSOHAPPORD=1) | [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1
        # 94587 : Pb naming convention
        #If ([F:SOH]APPFLG=0 & GSOHAPPORD=1 & [M:SOH0]YAPPFLG=1) | [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1
        If ([F:SOH]APPFLG=0 & GSOHAPPORD=1 & [M:SOH0]OLDAPPFLG=1) | [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1
        # 94587
#  89410
            Return
        Endif
        WFLGMOD=1 : WSENS="-"
Endcase

# Calcul du reste ŕ livrer
# 107888 : Scheduled invoices : (LD:10/05/16)
Case WFLGMOD
    When 1 : If [F:SOH]SOHCAT<>3 & [F:SOQ]DLVFLG=2
    #When 1 : If [F:SOH]SOHCAT<>3
                 # Commande normale/pręt et ligne livrable :
                 # --> On tient compte du livré validé
                 WQTY = [F:SOQ]QTYSTU-[F:SOQ]DLVQTYSTU
             Else
                 # Commande ŕ facturation directe
                 # Commande normale et ligne non livrable  :
                 # --> On tient compte du facturé validé
                 WQTY = [F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU
             Endif
    When 2 : If [F:SOH]SOHCAT<>3 & [F:SOQ]DLVFLG=2
    #When 2 : If [F:SOH]SOHCAT<>3
                 # Commande normale/pręt et ligne livrable :
                 # --> On tient compte du livré validé
                 WQTY = [F:SOQ]QTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]ODLQTYSTU
             Else
                 # Commande ŕ facturation directe
                 # Commande normale et ligne non livrable  :
                 # --> On tient compte du facturé validé
                 WQTY = [F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU-[F:SOQ]ODLQTYSTU
             Endif
    When 3 : WQTY = [F:SOQ]ODLQTYSTU
    When 4 : WQTY = [F:SOQ]LPRQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU
Endcase
# 107888 : Scheduled invoices : (LD:10/05/16)

Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WQTY, WSENS, WTYP, WRET) From TRTVENMAJ
If WRET <> 0 Return : Endif

Return

####################################################################
$MAJORDERS
#-------------------------------#
# Maj de l'en-cours dans ORDERS #
#-------------------------------#
Local  Decimal  WCPLQTY

If [F:SOH]SOHCAT = 3
    WCPLQTY = [F:SOQ]INVQTYSTU
Else
    WCPLQTY = [F:SOQ]DLVQTYSTU
Endif
# Maj uniquement si ligne non soldée
If [F:SOQ]SOQSTA <> 3
#  Maj si modif ligne et la quantité ou le type en-cours ou l'état
#  de la ligne ou le site d'expédition ont évolué
#  Maj si modif FMI
   If TRTLIG = "M"
      If [M]QTY(NOL)       <> [M]YQTY(NOL)
&      | [M]SOQSTA(NOL)    <> [M]YSOQSTA(NOL)
&      | [M]ALLQTY(NOL)    <> [M]YALLQTY(NOL)
&      | [M]SHTQTY(NOL)    <> [M]YSHTQTY(NOL)
&      | [M]DSHIDAT(NOL)   <> [M]YDSHIDAT(NOL)
&      | [M]WIPFLG(NOL)    <> ""
          Raz WTRTORD
#         --> Solde    de ligne
#             FMI modifié ŕ contremarque directe
          If (SIGN = -1 &  ([M]WIPFLG(NOL)= "A" | [M]SOQSTA(NOL) <> [M]YSOQSTA(NOL)))
#              If [M]SOQSTA(NOL)<>[M]YSOQSTA(NOL) & [M]ODLQTY(NOL)<>0
##                 Si Solde de ligne et encours livraison             : Modification de la qté prévue
              If sum([M]ODLQTY(NOL),[M]LPRQTY(NOL),[M]OPRQTY(NOL),[M]PREQTY(NOL))<>0
#                 Si encours livraison                               : Modification de la qté prévue
                  WTRTORD="S"
              Else
##                 Si Solde    de ligne et pas d'encours de livraison
##                    FMI modifié ŕ contremarque directe              : Suppression de l'en-cours
#                 Si pas d'encours de livraison                      : Suppression de l'en-cours
                  WTRTORD="A"
              Endif
              Gosub APPELWIP From TRTVENMAJ
              If WTRTORD="A" [F:SOQ]DEMNUM="" Endif
          Endif
#         Modification de l'en-cours si l'article est géré en stock
          If  SIGN = +1 & [M]STOMGTCOD(NOL) <> 1
              # Gestion des signatures : Si la cde passe de signée ŕ non signée
              # --> Modification de la qté prévue si encours de livraison
              If [F:SOH]APPFLG=0 & GSOHAPPORD=1
                  If sum([M]ODLQTY(NOL),[M]LPRQTY(NOL),[M]OPRQTY(NOL),[M]PREQTY(NOL))<>0
#                     Si encours livraison                             : Modification de la qté prévue
                      WTRTORD="S" :  Gosub APPELWIP From TRTVENMAJ
                  Endif
              Else
                  WTRTORD="M" :  Gosub APPELWIP From TRTVENMAJ
              Endif
          Endif
      Endif
#  Maj si l'article est géré en stock et si création ou suppression ligne
   Elsif [F:SOQ]STOMGTCOD <> 1
      If SIGN = -1
          WTRTORD = "A" : Gosub APPELWIP From TRTVENMAJ
      Elsif SIGN = +1 & [F:SOQ]DEMNUM <> ""
          WTRTORD = "C" : Gosub APPELWIP From TRTVENMAJ
      Endif
   Endif
Endif
Return
####################################################################
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#--Too many instructions => moved to SUBSOHA1
$INICRE
# FGR 23/06/2014 : X3SUIVI99912 (début) : c'était fait trop tard
If dim(GWEBSERV)=1 & GWEBSERV=1
  #----- Gestion des adresses                         : # Bug 78821
  If dim([M:ADB1]ADBFLG) [M:ADB1]ADBFLG=2 Endif       : # Bug 78821
  If dim([M:ADB2]ADBFLG) [M:ADB2]ADBFLG=2 Endif       : # Bug 78821
  If dim([M:ADB3]ADBFLG) [M:ADB3]ADBFLG=2 Endif       : # Bug 78821
Endif
# FGR 23/06/2014 : X3SUIVI99912 (fin)

#---------------------------#
# Chargement avant le write #
#---------------------------#
Local Integer I, SPSTAT
Local Decimal COURS

If GAPPSOH>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

# -- Raz variable utilisée pour la maj des mvts clients
Raz WQUONOT, WQUOATI

# Récupération du compteur de commande
If GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:SOH0]SOHNUM,2)="")
    # Issue X3-43209 by MRDAB -> DELETED
    Call NUMERO (GCPT,[F:SOH]SALFCY,[F:SOH]ORDDAT,"",GNUM,STAT) From SUBANM
    If GOK<0 Return Endif
    If STAT = 0
#       Si compteur manuel et le n° n'a pas été renseigné #
        If GMANCOU=2 & vireblc([M:SOH0]SOHNUM,2)=""
            If !GIMPORT
                GERR=2:GMESSAGE = mess(265,199,1)
            Endif
        Endif
        [F:SOH]SOHNUM  = GNUM
        [M:SOH0]SOHNUM = GNUM
        Affzo [M:SOH0]SOHNUM
    Else
       GERR=1:GMESSAGE = mess(60,199,1) : GOK=0 : Return
    Endif
Endif
# Issue X3-123565 - 20190212 by VAVIL : Chronological control on Sales Orders, -> DELETED

# Issue 112736
# Unuseful because done in CHARGENTETE
## Raz du no devis de l'entęte commande s'il y en a plusieurs
#If [F:SOH]SQHNUM <> ""
#   For I=0 To [M:SOH4]NBLIG-1
#      If [M:SOH4]DETSQHNUM(I) <> "" & [M:SOH4]DETSQHNUM(I) <> [F:SOH]SQHNUM
#         Raz [F:SOH]SQHNUM, [M:SOH3]SQHNUM
#         Break
#      Endif
#   Next I
## Maj du no devis dans l'entęte commande s'il n'y en a qu'une
#Else
#   For I=0 To [M:SOH4]NBLIG-1
#      If [M:SOH4]DETSQHNUM(I) <> ""
#         If [F:SOH]SQHNUM = ""
#            [F:SOH]SQHNUM = [M:SOH4]DETSQHNUM(I)
#            [M:SOH3]SQHNUM= [M:SOH4]DETSQHNUM(I)
#         Elsif [F:SOH]SQHNUM <> [M:SOH4]DETSQHNUM(I)
#            Raz [F:SOH]SQHNUM, [M:SOH3]SQHNUM
#            Break
#         Endif
#      Endif
#   Next I
#Endif
# End issue 112736

# Alimentation cours en devise société
Call COURSITE([M]CUR,[M]SALFCY,[M]CHGTYP,[M]ORDDAT,COURS,SPSTAT) From TRTDEV
[F:SOH]CHGRAT=COURS

Gosub CHARGENTETE From SUBSOHA

# Gestion des signatures
# --> Si les conditions de la rčgle de workflow ne sont pas respectées, il faut initialiser le flag ŕ non signé
#     Sinon c'est le workflow qui initialisera le flag ŕ non signé
If [F:SOH]APPFLG=0 & [F:SOH]ORDSTA=2 [F:SOH]APPFLG=1 Endif


# 101380 - need to reset SFISSTCOD when creating from an order
If GCREPARBOU=1
  Call RELOAD_SFISST From SUBSOHA
Endif

# Tax by document
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  GTAXBYDOC = 1
Endif

# valorisation TTC (idem calcul facture)
If !(dim(G_SIH_CAL)>0 & G_SIH_CAL<>"C")

    # 101874 : V9 : Taxe code control
    Gosub INIVALTTC From SUBSOHA
    If GOK=0 : Return Endif
    # 101874

    # ACA (2009-09-22) Lot S03
    # 81878 : Ajout borne pour ne pas trier le tableau complet
    #Sorta [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
    # 81878
    Call CHARG_CCE_MULTI(1,"[M:SFIT]VCRENT","[M:SFIT]DTA","[M:SIHV]XFNUM","[M:SIHV]SFICCE","[M:SIHV]DSP") From TRTX3CPT
Endif

# Bug 57682
If dim(GWEBSERV)=1 & GWEBSERV=1
  If [M:ACL1]CLOB=[M:ACL1]CLOBSVG & [M:ACL2]CLOB=[M:ACL2]CLOBSVG
      # Si aucune modification de texte, ne rien faire !
  Else
      Call RANGE_TEXTE ([L]WRET) From SUBSOHA
      ##----- Gestion des adresses                    : # Bug 78821
      #If dim([M:ADB1]ADBFLG) [M:ADB1]ADBFLG=2 Endif  : # Bug 78821
      #If dim([M:ADB2]ADBFLG) [M:ADB2]ADBFLG=2 Endif  : # Bug 78821
      #If dim([M:ADB3]ADBFLG) [M:ADB3]ADBFLG=2 Endif  : # Bug 78821
  Endif
  # FGR 23/06/2014 : X3SUIVI99912 (début) : c'était déjŕ trop tard
  #----- Gestion des adresses                         : # Bug 78821
  #  If dim([M:ADB1]ADBFLG) [M:ADB1]ADBFLG=2 Endif       : # Bug 78821
  #  If dim([M:ADB2]ADBFLG) [M:ADB2]ADBFLG=2 Endif       : # Bug 78821
  #  If dim([M:ADB3]ADBFLG) [M:ADB3]ADBFLG=2 Endif       : # Bug 78821
  # FGR 23/06/2014 : X3SUIVI99912 (fin)
Endif
# Bug 57682

Return
