########################################################
#Met ŕ jour le contrat sélectionné sur la demande de service
#LSE 09/01/2007
If GPILNAV>1
    If GNAVIG(GPILNAV-1) = "GESSRE"
        Gosub SELECTSOH From SUBSREB3
    Endif
Endif

If dim(GWEBSERV)=1 & GWEBSERV=1
    Kill GWEBFOCITMREF, GWEBFOCQTY, GWEBFOCUOM, GWEBFOCMOTIF, GWEBNBGRA
    # Bug 57682
    If clalev([M:ACL])   Close Local Mask [ACL]  : Endif
