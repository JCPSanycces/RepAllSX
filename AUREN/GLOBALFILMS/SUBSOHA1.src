    If dim([L]WRET)<1  Local Integer WRET : Endif

    #----- Gestion des adresses
    Local Integer SAVGACTSAD : SAVGACTSAD=GACTSAD : GACTSAD=2
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    # Bug 57682
Endif

If GIMPORT Gosub SETTRANS_DEF From SUBSOHA1 Endif

Raz GSOC_ACTIVE
GFCY = GFCYDEF (5)
# Ctrl site par défaut par rapport au critčre, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2") From TRTX3
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM From SUBSOHA : If GERR=1 OK=0 : Return Endif
# --- Déclaration des fenetres d'adresses ------------- #
# Bug 70949
If clalev([M:ADB1])=0
    Local Mask ADRBPC [ADB1]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBV])
    Local Mask ADRBPC [ADBV] : [M:ADBV]=[M:ADB1] : # Sauvegarde de l'écran d'adresse ADB1 ŕ cause de la navigation
  Endif
Endif
If clalev([M:ADB2])=0
    Local Mask ADRBPC [ADB2]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBW])
    Local Mask ADRBPC [ADBW] : [M:ADBW]=[M:ADB2] : # Sauvegarde de l'adresse ADB2 ŕ cause de la navigation
  Endif
Endif
If clalev([M:ADB3])=0
    Local Mask ADRBPC [ADB3]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBX])
    Local Mask ADRBPC [ADBX] : [M:ADBX]=[M:ADB3] : # Sauvegarde de l'adresse ADB2 ŕ cause de la navigation
  Endif
Endif
# Bug 70949

Raz [M:ADB1], [M:ADB2], [M:ADB3]
