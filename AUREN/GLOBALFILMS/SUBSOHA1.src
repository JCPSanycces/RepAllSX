$FERME
GCONSDIA=0

  Gosub KILL_RECOVERED_AUPDTICK From SUBSOHA  # FGR 07/07/2015 : X3SUIVI109276

# Bug 70949
# --- Restitution des écrans d'adresse ŕ cause de la navigation -----#
