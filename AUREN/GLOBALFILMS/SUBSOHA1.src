#&                                                ([M:SOH4]CCE3(indcum-1)<>"" and [M:SOH4]CCE3(I)<>"" and [M:SOH4]CCE3(indcum-1)<>[M:SOH4]CCE3(I)) or
#&                                                ([M:SOH4]CCE4(indcum-1)<>"" and [M:SOH4]CCE4(I)<>"" and [M:SOH4]CCE4(indcum-1)<>[M:SOH4]CCE4(I)) or
#&                                                ([M:SOH4]CCE5(indcum-1)<>"" and [M:SOH4]CCE5(I)<>"" and [M:SOH4]CCE5(indcum-1)<>[M:SOH4]CCE5(I)) or
