#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ADI1 (Especifico)

$ACTION
#Infbox "ACTION = " + ACTION
Case ACTION
 When "OUVRE"         :  Gosub OUVRE
 When "STYLE"         :  Gosub STYLE
 When "SETBOUT"       :  Gosub SETBOUT
 When "APRES_MODIF"   :  Gosub APRES_MODIF
 When "VERIF_MOD"     :  Gosub VERIF_MOD
 When "VERIF_CRE"     :  Gosub VERIF_CRE
 When Default
Endcase
Return


$OUVRE
Local Integer PZANCHO_MAX
#Call PARAM("","ZANCHO_MAX",PZANCHO_MAX) From ADOVAL        #  "" = PLANTA
PZANCHO_MAX= val(func AFNC.PARAM("ZANCHOMAX",""))
#Infbox "PZANCHO_MAX = " + num$(PZANCHO_MAX)
Return

$STYLE
Gosub TODO_OK
Return

$SETBOUT
If [M:ADI1]NUMTAB=6003
  Diszo [M:ADI1]N15
Else
  Actzo [M:ADI1]N15
Endif
Return

$APRES_MODIF
If [M:ADI1]NUMTAB<>6003
  Return
Endif
Gosub ACTUALIZAR
Call SUMAR (COUIND)
Return

$VERIF_MOD
Gosub TODO_OK
Return

$VERIF_CRE
Gosub TODO_OK
Return

$TODO_OK
Case [M:ADI1]NUMTAB
When 6005   :     Gosub EXISTE_RGTO
When 6003   :     Gosub ANCHO_OK
When 6004   :     Gosub EXISTE_RGTO
Endcase
Return

$EXISTE_RGTO
Local Integer F, EXISTE,FA,ANC,LNG
Local Char ART(GLONITM)
Onerrgo ERRORES_FIN
For FA=0 To [M:ADI1]NBLIG-1
  EXISTE =0
  ART=[M:ADI1]A1(FA)
  ANC=val([M:ADI1]N1(FA))
  LNG=val([M:ADI1]N2(FA))
  If ANC>PZANCHO_MAX
    MSG="El articulo " + ART + " ancho " + num$(ANC) +" excede el ancho máximo de " + num$(PZANCHO_MAX)+"\Revise la fila " + num$(FA+1)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    OK=0
    Break
  Else
    For F=0 To [M:ADI1]NBLIG-1
      If F<>FA
        If ART=[M:ADI1]A1(F) and ANC=val([M:ADI1]N1(F)) and LNG=val([M:ADI1]N2(F))
          EXISTE=F+1
          Break
        Endif
      Endif
    Next
    If EXISTE
      MSG="El articulo " + ART + " ancho " + num$(ANC) + " largo " + num$(LNG) + " se ha duplicado\Revise las filas " + num$(FA+1) + " y " + num$(EXISTE)
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      OK=0
      Break
    Endif
  Endif
Next
Onerrgo
Return


$ANCHO_OK
Onerrgo ERRORES_FIN
Local Integer F, EXISTE
For F=0 To [M:ADI1]NBLIG-1
  Call SUMAR (F)
  If val([M:ADI1]N15(F))>PZANCHO_MAX
    MSG="Imposible superar el ANCHO máximo de " + num$(PZANCHO_MAX) + "\Revise los anchos indicados en fila " + num$(F+1) + " pues suman " + [M:ADI1]N15(F)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    OK=0
    Break
  Else
    # Ver si otro registro tiene los mismos elementos
    EXISTE=func EXISTE_ELEMENTOS(F)
    If EXISTE
      MSG="la combinacion de elementos de la fila " + num$(F+1) + " ya existe en fila " + num$(EXISTE)
      Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
      OK=0
      Break
    Endif
  Endif
Next
Onerrgo
Return


$ACTUALIZAR
Case COUZON
When "N1"     :    [M:ADI1]N1(COUIND)=CZ
When "N2"     :    [M:ADI1]N2(COUIND)=CZ
When "N3"     :    [M:ADI1]N3(COUIND)=CZ
When "N4"     :    [M:ADI1]N4(COUIND)=CZ
When "N5"     :    [M:ADI1]N5(COUIND)=CZ
When "N6"     :    [M:ADI1]N6(COUIND)=CZ
When "N7"     :    [M:ADI1]N7(COUIND)=CZ
When "N8"     :    [M:ADI1]N8(COUIND)=CZ
When "N9"     :    [M:ADI1]N9(COUIND)=CZ
When "N10"    :    [M:ADI1]N10(COUIND)=CZ
When "N11"    :    [M:ADI1]N11(COUIND)=CZ
When "N12"    :    [M:ADI1]N12(COUIND)=CZ
When "N13"    :    [M:ADI1]N13(COUIND)=CZ
When "N14"    :    [M:ADI1]N14(COUIND)=CZ
Endcase
Return


Funprog EXISTE_ELEMENTOS (FILA_ACTUAL)
Value Integer FILA_ACTUAL
Local Integer F,EXISTE,E1(15),E2(15)
Local Char TXT_INI(250)
EXISTE =0
Call ELEMENTOS (E1,FILA_ACTUAL)
TXT_INI= func NBR_TO_TXT(E1)
For F=0 To [M:ADI1]NBLIG-1
  If F<>FILA_ACTUAL
    Call ELEMENTOS (E2,F)
    If TXT_INI=func NBR_TO_TXT(E2)
      EXISTE=F+1
      Break
    Endif
  Endif
Next
End EXISTE

Funprog NBR_TO_TXT(NB)
Value Integer NB
Local Char TX(250)
Local Integer F
Raz TX
For F=0 To dim(NB)-1
  TX+=num$(NB(F))
Next
End TX


Subprog ELEMENTOS(E1,F)
Variable Integer E1
Value Integer F
Local Integer L
Raz E1
E1(0)=val([M:ADI1]N1(F))
E1(1)=val([M:ADI1]N2(F))
E1(2)=val([M:ADI1]N3(F))
E1(3)=val([M:ADI1]N4(F))
E1(4)=val([M:ADI1]N5(F))
E1(5)=val([M:ADI1]N6(F))
E1(6)=val([M:ADI1]N7(F))
E1(7)=val([M:ADI1]N8(F))
E1(8)=val([M:ADI1]N9(F))
E1(9)=val([M:ADI1]N10(F))
E1(10)=val([M:ADI1]N11(F))
E1(11)=val([M:ADI1]N12(F))
E1(12)=val([M:ADI1]N13(F))
E1(13)=val([M:ADI1]N14(F))
Sorta E1
End

Subprog SUMAR(F)
Value Integer F
Local Integer T
T=0
T+=val([M:ADI1]N1(F)) +val([M:ADI1]N2(F))+val([M:ADI1]N3(F))+val([M:ADI1]N4(F)) +val([M:ADI1]N5(F)) +val([M:ADI1]N6(F))
T+=val([M:ADI1]N7(F)) +val([M:ADI1]N8(F))+val([M:ADI1]N9(F))+val([M:ADI1]N10(F))+val([M:ADI1]N11(F))+val([M:ADI1]N12(F))
T+=val([M:ADI1]N13(F))+val([M:ADI1]N14(F))
[M:ADI1]N15(F)=num$(T)
Affzo [M:ADI1]N15
End


Subprog AS_N15(VALEUR)
Variable Char    VALEUR()
End

$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl)
FLAG_ERR=1
End

