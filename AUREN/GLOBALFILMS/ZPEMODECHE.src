#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "CRITERE" : Gosub $FILTRO
Endcase
Return

$FILTRO
If [M:DDM]ZANTSTA = 0 : [M:DDM]ZANTSTA = 1 : Endif
If [M:DDM]ZNANTSTA = 0 : [M:DDM]ZNANTSTA = 2 : Endif
If [M:DDM]ZNANTSTA = 2 & [M:DDM]ZANTSTA = 2 Then
  [L]CRITERE2+=' & (1=1) '
Elsif [M:DDM]ZNANTSTA = 2
  [L]CRITERE2+=' & (([DUD]ZANTSTA=1) | ([DUD]ZANTSTA=0))'

Elsif [M:DDM]ZANTSTA = 2
   [L]CRITERE2+=' & ([DUD]ZANTSTA=2)'
Else
 [L]CRITERE2+=' & (1=1)'
Endif
#[L]CRITERE2='(([DUD]ZANTSTA=' + num$([M:DDM]ZANTSTA)+') | ([DUD]ZANTSTA='+num$([M:DDM]ZNANTSTA)+'))'
Return
