#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox ACTION
Case ACTION
   When "ALISIH" : Gosub ALISIH
   When "ALISID" : Gosub ALISIH
Endcase
Return

$ALISIH
If INVORI=2 Then
#Infbox "HOLA"
   [F:SIH]ZFAGFLG=[F:SOH]ZFAGFLG
   [F:SIH]ZFAGREPRES=[F:SOH]ZFAGREPRES
   [F:SIH]ZFAGSTP=1
   [F:SIH]ZFAGSTL=1
   [F:SIH]ZFAGICMAN=1
Endif
Return

# ZPV - PRECIO REAL de VEnta
$ALISID
If INVORI=3 Then
#Infbox "HOLA"
   [F:SID]ZCTDREAL=[F:SDD]ZCTDREAL
   [F:SID]ZCTDREALUS=[F:SDD]ZCTDREALUS
   [F:SID]ZPRIREAL=[F:SDD]ZPRIREAL
Endif
Return
