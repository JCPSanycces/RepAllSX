#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"     : Gosub $OUVRE
 When "CREATION"  : Gosub $CREATION
 When "AV_ANNULE" : Gosub $AV_ANNULE
 When "MODIF"     : Gosub $MODIF
 When Default
Endcase
Return

$OUVRE
### ZFAG - Facturacion Agencia
  Gosub ZFAG_SPEBIC_OUVRE
### Fin ZFAG - Facturacion Agencia
Return


$CREATION
### ZFAG - Facturacion Agencia
  Gosub ZFAG_SPEBIC_CREATION
### Fin ZFAG - Facturacion Agencia
Return

$MODIF
### ZFAG - Facturacion Agencia
  Gosub ZFAG_SPEBIC_MODIF
### Fin ZFAG - Facturacion Agencia
Return




### ZFAG - Facturacion Agencia
### Acciones especificas Objeto  BIC

$ZFAG_SPEBIC_OUVRE
If !clalev([F:XZFLQ]) : Local File ZFAGLIQCOM [F:XZFLQ] : Endif
Return


$ZFAG_SPEBIC_CREATION
###  Marca registros liquidaciˇn comision como facturados
Local Integer WI
For WI=0 To [M:BIC3]NBLIG -1
   If [M:BIC3]ZFAGDOCORG(WI)<>""
       Read [F:XZFLQ]ZFALQ0=[M:BIC3]ZFAGDOCORG(WI);[M:BIC3]ZFAGNUMLIQ(WI)
       If fstat=0
          [F:XZFLQ]NUMFRA=[F:SIH]NUM
          [F:XZFLQ]FACTUR=2
          Rewrite [F:XZFLQ]
          If fstat
             GOK=0
             Call FSTA("ZFLQ") From GLOCK
          Endif

       Endif
   Endif
Next
### Fin ZFAG - Facturacion Agencia
Return

$ZFAG_SPEBIC_MODIF
###  Marca todos los registros liquidaciˇn comision como no facturados, para la factura modificada
Update [F:XZFLQ] Where NUMFRA=[M:BIC0]NUM With FACTUR=1,NUMFRA=""
If fstat=0
    ###  Marca registros liquidaciˇn comision como facturados
    Gosub ZFAG_SPEBIC_CREATION
Else
    GOK=0
    Call FSTA("ZFLQ") From GLOCK
Endif
Return

$AV_ANNULE
### ZFAG - Facturacion Agencia
###  Marca registros liquidaciˇn comision como no facturados
Local Integer WI

For WI=0 To [M:BIC3]NBLIG -1
   If [M:BIC3]ZFAGDOCORG(WI)<>""
       Read [F:XZFLQ]ZFALQ0=[M:BIC3]ZFAGDOCORG(WI);[M:BIC3]ZFAGNUMLIQ(WI)
       If fstat=0
          [F:XZFLQ]NUMFRA=""
          [F:XZFLQ]FACTUR=1
          Rewrite [F:XZFLQ]
          If fstat
             GOK=0
             Call FSTA("ZFLQ") From GLOCK
          Endif

       Endif
   Endif
Next
### Fin ZFAG - Facturacion Agencia
Return

Subprog AS_ZFAGDOCORG(VALEUR)
Variable Char    VALEUR()
# solo se permite edicion en modo creacion.
If GREP<>'C'
   mkstat=2
Endif
End

Subprog AS_ZFAGNUMLIQ(VALEUR)
Variable Decimal VALEUR
# solo se permite edicion en modo creacion.
If GREP<>'C'
   mkstat=2
Endif
End


