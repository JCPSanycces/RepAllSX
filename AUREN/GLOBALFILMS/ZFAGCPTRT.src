#<AdxTL>@(#)0.0.0.0 $Revision$
# ZFAG - Facturacion Comisiones Agencia
# Contabilizacion de Provisiones
# FJCP 19/04/2016

$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub INIT
  When "INIT"          : Gosub INIT
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
  When "INIT_DIA"           : Gosub INIT_DIA
  When "OK"             : Gosub OK
  When "END"            : Gosub FIN
Endcase
Return


$INIT
If clalev([F:ZFAPR])<=0 : Local File ZFAGPRVCOM    [ZFAPR] : Endif
If clalev([F:SIH])<=0 : Local File SINVOICE    [SIH] : Endif
Return

$EXEC
Local Integer NASI
Local Char    BORNUM(20), MESSA(80), IDENT(20)(1..2)
Local Integer STAT

If clalev([M:HAE0])=0 : Local Mask GACCENT0 [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1 [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2 [HAE2] : Endif
If clalev([M:VTL])=0  : Local Mask VENTILE  [VTL]  : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2 [VT2]  : Endif
Default Mask [M:ZFACP]

Local Char CRITERIO(250)
#Local Integer OK
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Contabilizar Prevision Comisiones Agencia",0) From GESECRAN
Else
  Call OUVRE_TRACE("Contabilizar Prevision Comisiones Agencias") From LECFIC
Endif
WMSG = "Contabilizar Prevision Comisiones Agencia"
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZFAGCP","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN


CRITERIO='[F:ZFAPR]CONTAB=1'
If [M:ZFACP]FCY<>''
   CRITERIO+=' & [F:ZFAPR]FCY="'+[M:ZFACP]FCY+'"'
Endif
If [M:ZFACP]BPCREP<>''
   CRITERIO+=' & [F:ZFAPR]BPCREP>="'+[M:ZFACP]BPCREP+'"'
Endif
If [M:ZFACP]BPCREPH<>''
   CRITERIO+=' & [F:ZFAPR]BPCREP<="'+[M:ZFACP]BPCREPH+'"'
Endif

If [M:ZFACP]ACCDAT<>[0/0/0]
   CRITERIO+=' & [F:ZFAPR]ACCDAT>=[M:ZFACP]ACCDAT'
Endif
If [M:ZFACP]ACCDATH<>[0/0/0]
   CRITERIO+=' & [F:ZFAPR]ACCDAT<=[M:ZFACP]ACCDATH'
Endif
#Infbox CRITERIO

 NASI = 0

Filter [F:ZFAPR] Where evalue(CRITERIO)

For [F:ZFAPR]

   Call DEBTRANS From GLOCK
   Gosub TR2

Next
Filter [F:ZFAPR]

If NASI>0
   Call ECR_TRACE(" \"+num$(NASI)-"Asientos Generados",0) From GESECRAN
Endif
TRA=1
Return

$TR2
GOK=1
Trbegin [ZFAPR], [SIH]
  IDENT(1) = [F:ZFAPR]DOCORG
  IDENT(2) = ""
  # LANZAR ASIENTO AUTOMATICO
  Call VALPCE("ZFACP",IDENT,STAT,MESSA) From CPTAUTO
  If STAT
    # Cambio Colectivo : Error
    Call ECR_TRACE("Error Asiento Automatico:"-[F:ZFAPR]DOCORG-":"-MESSA,1) From GESECRAN
    GOK = 0
  Else

    Call ECR_TRACE("Documento Origen:"-[F:ZFAPR]DOCORG-":"-mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
#    [F:XCC]VCRNUMDES=[M:HAE0]NUM
#    [F:XCC]VCRTYPDES=[M:HAE0]TYP

  Endif
  If GOK=1 Then   # Modificar  [F:ZFAPR]
    [F:ZFAPR]CONTAB=2
    Rewrite [F:ZFAPR]
    If fstat<>0
        Call ECR_TRACE("Error Modificando Registro: "-[F:ZFAPR]DOCORG-":",1) From GESECRAN
        GOK=0
    Endif
  Endif
  If GOK=1 Then   # Modificar  [F:SIH]
     Raz [F:SIH]
     Read [F:SIH]SIH0=[F:ZFAPR]DOCORG
     If !fstat
        [F:SIH]ZFAGSTP=3
        [F:SIH]ZFAGFECPRV=[F:ZFAPR]ACCDAT
        Rewrite [F:SIH]
        If fstat
           Call FSTA("F:ZFAPR") From GLOCK
           GOK=0
        Endif
     Endif
  Endif

If GOK <0 : Goto ROLL_TR2
Elsif !GOK : Goto AB_TR2
Endif
NASI+=1
Commit
Return


$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return



$INIT_DIA
Local Mask ZFAGCP [ZFACP]
Raz [M:ZFACP]
[M:ZFACP]FCY = GFCYDEF(0)
Return

$TERMINE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

Return

$OK
Raz [M:ZFACP]
FIN  = 1
Return

$FIN
Raz [M:ZFACP]
FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
