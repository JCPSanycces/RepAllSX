Subprog AM_BPCNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]BPCNUMEND = ""     : [M]BPCNUMEND = VALEUR : Affzo [M]BPCNUMEND : Endif
If [M]BPCNUMEND < VALEUR : [M]BPCNUMEND = VALEUR : Affzo [M]BPCNUMEND : Endif
End

