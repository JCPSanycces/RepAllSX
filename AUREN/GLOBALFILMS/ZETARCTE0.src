Variable Char    VALEUR()
If [M]REPNUMEND = ""     : [M]REPNUMEND = VALEUR : Affzo [M]REPNUMEND : Endif
If [M]REPNUMEND < VALEUR : [M]REPNUMEND = VALEUR : Affzo [M]REPNUMEND : Endif
End

