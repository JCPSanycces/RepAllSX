#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "FILTRE" : Gosub $FILTRO
Endcase
Return

$FILTRO
#If [M:DI1]ZANTSTA = 0 : [M:DI1]ZANTSTA = 1 : Endif
#
#[L]CRITSPE='([DUD]ZANTSTA=' + num$([M:DI1]ZANTSTA)+')'
#If GUSER='ADMIN' : Dbgaff: Endif
If [M:DI1]ZANTSTA = 0 : [M:DI1]ZANTSTA = 1 : Endif
If [M:DI1]ZNANTSTA = 0 : [M:DI1]ZNANTSTA = 2 : Endif


If [M:DI1]ZNANTSTA = 2 & [M:DI1]ZANTSTA = 2 Then
  [L]CRITSPE=' (1=1) '
Elsif [M:DI1]ZNANTSTA = 2
  [L]CRITSPE='(([DUD]ZANTSTA=1) | ([DUD]ZANTSTA=0))'

Elsif [M:DI1]ZANTSTA = 2
   [L]CRITSPE='([DUD]ZANTSTA=2)'
Else
 [L]CRITSPE='(1=1)'
Endif


Return
