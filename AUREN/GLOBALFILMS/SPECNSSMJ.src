Subprog AP_ZITMREFDEB(VALEUR)
Variable Char    VALEUR()
If [M]ZITMREFFIN = ""     : [M]ZITMREFFIN = VALEUR : Affzo [M]ZITMREFFIN : Endif
If [M]ZITMREFFIN < VALEUR : [M]ZITMREFFIN = VALEUR : Affzo [M]ZITMREFFIN : Endif
End

Subprog AM_ZANCHODEB(VALEUR)
Variable Decimal VALEUR
If [M]ZANCHOFIN = 0     : [M]ZANCHOFIN = VALEUR : Affzo [M]ZANCHOFIN : Endif
If [M]ZANCHOFIN < VALEUR : [M]ZANCHOFIN = VALEUR : Affzo [M]ZANCHOFIN : Endif
End

Subprog AM_ZLONGITUDDEB(VALEUR)
Variable Decimal VALEUR
If [M]ZLONGITUDFIN = 0     : [M]ZLONGITUDFIN = VALEUR : Affzo [M]ZLONGITUDFIN : Endif
If [M]ZLONGITUDFIN < VALEUR : [M]ZLONGITUDFIN = VALEUR : Affzo [M]ZLONGITUDFIN : Endif
End


