Subprog AM_ZFAGICMAN(VALEUR)
Variable Integer VALEUR
If VALEUR=1 Then
  [M:ZSIH1]ZFAGICMAN=1
  Gosub ZFAG_CALCULO_COMISION
Endif
Affzo [M:ZSIH1]ZFAGIMPCOM
Affzo [M:ZSIH1]ZTOTCOM
End



Subprog AM_ZFAGIMPCOM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
   mkstat = 2
Else
   [M:ZSIH1]ZFAGICMAN = 2
   Affzo [M:ZSIH1]ZFAGICMAN
Endif
End
