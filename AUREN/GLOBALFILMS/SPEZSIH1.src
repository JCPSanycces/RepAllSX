#<AdxTL>@(#)0.0.0.0 $Revision$
# ZFAG - Facturacion Comisiones Agencias
# Acciones especificas de Objeto SIH
#
$OUVRE
If !clalev([F:ZFAPR]) : Local File ZFAGPRVCOM [ZFAPR] : Endif
Return

$INICRE
  If [M:ZSIH1]ZFAGICMAN=0 : [M:ZSIH1]ZFAGICMAN=1 :Endif
  Gosub ZFAG_CALCULO_COMISION
  [F:SIH]ZFAGFLG=[M:ZSIH1]ZFAGFLG
  [F:SIH]ZFAGREPRES=[M:ZSIH1]ZFAGREPRES
  [F:SIH]ZFAGIMPCOM=[M:ZSIH1]ZFAGIMPCOM
  [F:SIH]ZFAGICMAN=[M:ZSIH1]ZFAGICMAN
  [F:SIH]ZFAGNUMFAC=[M:ZSIH1]ZFAGNUMFAC
  [F:SIH]ZFAGSTP=1
  [F:SIH]ZFAGSTL=1
 Return

$INIMOD
  If [M:ZSIH1]ZFAGICMAN=0 : [M:ZSIH1]ZFAGICMAN=1 :Endif
  Gosub ZFAG_CALCULO_COMISION
  [F:SIH]ZFAGFLG=[M:ZSIH1]ZFAGFLG
  [F:SIH]ZFAGREPRES=[M:ZSIH1]ZFAGREPRES
  [F:SIH]ZFAGIMPCOM=[M:ZSIH1]ZFAGIMPCOM
  [F:SIH]ZFAGICMAN=[M:ZSIH1]ZFAGICMAN
  [F:SIH]ZFAGNUMFAC=[M:ZSIH1]ZFAGNUMFAC
  [F:SIH]ZFAGSTP=[M:ZSIH1]ZFAGSTP
  [F:SIH]ZFAGSTL=[M:ZSIH1]ZFAGSTL
 Return

$LIENS
 Raz [M:ZSIH1]
 [M:ZSIH1]ZFAGFLG=[F:SIH]ZFAGFLG
 [M:ZSIH1]ZFAGREPRES=[F:SIH]ZFAGREPRES
 [M:ZSIH1]ZFAGNUMFAC=[F:SIH]ZFAGNUMFAC
 [M:ZSIH1]ZFAGSTP=[F:SIH]ZFAGSTP
 [M:ZSIH1]ZFAGIMPCOM=[F:SIH]ZFAGIMPCOM
 [M:ZSIH1]ZFAGICMAN=[F:SIH]ZFAGICMAN
 If [M:ZSIH1]ZFAGSTP>1
    Raz [F:ZFAPR]
    Filter [F:ZFAPR] Where DOCORG=[F:SIH]NUM
    Read [F:ZFAPR]ZFAPR0 First
     Filter [F:ZFAPR]
     [M:ZSIH1]ZIMPPRV=[F:ZFAPR]IMPORTE
 Endif
 [M:ZSIH1]ZFAGFECPRV=[F:SIH]ZFAGFECPRV
 [M:ZSIH1]ZFAGSTL=[F:SIH]ZFAGSTL

 # LIQUIDACION
 Local Decimal WTOTLIQ : WTOTLIQ=0
 Local Integer WI : WI =0
 If !clalev([F:ZFALQ]) : Local File ZFAGLIQCOM [ZFALQ] : Endif

 Raz [F:ZFALQ]
 Filter [F:ZFALQ] Where DOCORG=[F:SIH]NUM Order By NUMLIQ
 For [F:ZFALQ]
    [M:ZSIH1]ACCDAT(WI)=[F:ZFALQ]ACCDAT
    [M:ZSIH1]IMPORTE(WI)=[F:ZFALQ]IMPORTE
    [M:ZSIH1]FACTUR(WI)=[F:ZFALQ]FACTUR
    [M:ZSIH1]NUMFRA(WI)=[F:ZFALQ]NUMFRA
    [M:ZSIH1]ZFAGFECLIQ=[F:ZFALQ]ACCDAT
    WTOTLIQ+=[F:ZFALQ]IMPORTE
    WI+=1
 Next
 [M:ZSIH1]NBZLQ=WI

 [M:ZSIH1]ZFAGIMPLIQ=WTOTLIQ
 Filter [F:ZFALQ]

  # Total Comision
  Local Decimal WTOTCOM : WTOTCOM=0
  If !clalev([F:XSID]) : Local File SINVOICED [XSID] : Endif

  Raz [F:XSID]

  Filter [F:XSID] Where NUM=[F:SIH]NUM
  For [F:XSID]
    WTOTCOM+=[F:XSID]REPAMT2
  Next
  Filter [F:XSID]

Local Decimal WWDTOPP
WWDTOPP=0
#### Calculo Dto PP.
#### Parametrizado com elemento de facturacion 1
For WI=0 To 7
  If [F:SIV]INVDTA(WI)=1
      WWDTOPP=[F:SIV]INVDTAAMT(WI)
      Break
  Endif
Next

[M:ZSIH1]ZTOTCOM=ar2(WTOTCOM*(1-WWDTOPP/100))
#If [M:ZSIH1]ZFAGICMAN=1  # si Introduccion no es manual se asigna el Importe de la comision.
 #  [M:ZSIH1]ZFAGIMPCOM=[M:ZSIH1]ZTOTCOM
#Endif




  #[M:ZSIH1]ZTOTCOM=WTOTCOM

  Affzo [M:ZSIH1]


Return

######################################################################################
## Rutina que calcula la comision del documento
$ZFAG_CALCULO_COMISION
Local Integer WLI
Local Decimal WLIMPCOM,WLREPBAS, WLREPAMT
WLIMPCOM=0
For WLI=0 To [M:SIH4]NBLIG - 1
  Call CALCULO_COMREP(WLI,WLREPBAS,WLREPAMT)
  WLIMPCOM+=WLREPAMT
Next

Local Decimal WWDTOPP
WWDTOPP=0
#### Calculo Dto PP.
#### Parametrizado com elemento de facturacion 1
For WLI=0 To [M:SIH2]NBFAC -1
  If [M:SIH2]INVDTA(WLI)=1
      WWDTOPP=[M:SIH2]INVDTAAMT(WLI)
      Break
  Endif
Next

[M:ZSIH1]ZTOTCOM=ar2(WLIMPCOM*(1-WWDTOPP/100))
If [M:ZSIH1]ZFAGICMAN=1  # si Introduccion no es manual se asigna el Importe de la comision.
   [M:ZSIH1]ZFAGIMPCOM=[M:ZSIH1]ZTOTCOM
Endif
Return

# Copiado de TRTVENFAC
#----------------------------------------------------------#
# Calcul base et montant des commissions représentants     #
#----------------------------------------------------------#
Subprog CALCULO_COMREP(WNOL,WREPBAS,WREPAMT)
Value Integer WNOL
Variable Decimal WREPBAS, WREPAMT
WREPBAS=0
WREPAMT=0
If clalev([F:REP]) = 0 Local File SALESREP [REP] Endif
#---- Calcul commission représentant1
If [M:SIH4]REP2(WNOL) <> ""
   If [M:SIH4]REP2(WNOL) <> [F:REP]REPNUM
      Read [REP]REP0=[F:SID]REP2
      If fstat Raz [F:REP] Endif
   Endif
   Case [F:REP]COMBAS
    When 1   : WREPBAS = [M:SIH4]NETPRINOT(WNOL) * [M:SIH4]QTY(WNOL)
    When 2   : WREPBAS = [M:SIH4]PFM(WNOL)  * [M:SIH4]QTY(WNOL)
    When 3   : Call FORMULE_REP ([F:REP]COMFOR2,WREPBAS) From TRTVENFAC
   Endcase
   Call ARRDEV (WREPBAS,[F:SIV]CUR) From TRTDIV

   WREPAMT = WREPBAS * [M:SIH4]REPRAT2(WNOL) /100 * [M:SIH4]REPCOE(WNOL)
   Call ARRDEV (WREPAMT,[M:SIH2]CUR) From TRTDIV

Endif

End



# Gestión de la máscara ZSIH1 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZSIH1) 02/09/2016 13:02:56 (ADMIN)
######################################################################################
Subprog AS_ZFAGNUMFAC(VALEUR)
Variable Char    VALEUR()
If [M:SIH1]INVSTA=3 or [M:ZSIH1]ZFAGFLG<>2
   mkstat=2
Endif
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZSIH1) 02/11/2016 10:01:24 (ADMIN)
######################################################################################
Subprog AS_ZFAGREPRES(VALEUR)
Variable Char    VALEUR()
If [M:SIH1]INVSTA=3  or [M:ZSIH1]ZFAGSTL>1
   mkstat=2
Endif
End

Subprog AM_ZFAGREPRES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   [M:ZSIH1]ZFAGFLG=2
Else
   [M:ZSIH1]ZFAGFLG=1
Endif
Affzo [M:ZSIH1]ZFAGFLG
End

Subprog AS_ZFAGIMPCOM(VALEUR)
Variable Decimal VALEUR
If [M:SIH1]INVSTA=3 or [M:ZSIH1]ZFAGFLG<>2 or [M:ZSIH1]ZFAGSTL>1
   mkstat=2
Endif
End





######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZSIH1) 02/11/2016 14:34:06 (ADMIN)
######################################################################################
Subprog AS_ZFAGICMAN(VALEUR)
Variable Integer VALEUR
If [M:SIH1]INVSTA=3  or [M:ZSIH1]ZFAGSTL>1 or [M:ZSIH1]ZFAGFLG<>2
   mkstat=2
Endif
End

