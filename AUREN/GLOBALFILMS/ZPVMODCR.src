#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox GFONCTION - GACTION - ACTION
# Entrando AVANT_OUVRE   OUVRE   OUVRE_BOITE  TITRE   DEBUT (se ve la pantalla)     SETBOUT    AV_CHOIX
# Click en MateriaPrima       APRES_MODIF   SETBOUT     AP_CHOIX     AVANT_BOUTON  (Se muestra pantalla)
        # Al volver a la pantalla  BOUTON   SETBOUT     AV_CHOIX
# Tecla INTRO                      AP_CHOIX    AVANT_OK    OK    FIN     FINSAI
# click en "Salir de la función"   AP_CHOIX    END               FIN     FINSAI


Case ACTION

 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "OK"           : Gosub OK

# When "CONTROLE"    : Gosub CONTROLE
 When "AVANT_OK"     : Gosub AVANT_OK
 When "TITRE"        : Gosub TITRE_

 When "END"          : Gosub END_
 When "FIN"          : Gosub FIN
Endcase

$OUVRE
Local Integer WLLIG
Local Integer WLMODIF
WLMODIF = 0
WLLIG = val(PARAM(1))
Return

$DEBUT
Local Shortint WLI,WLJ
Local Integer WLSDDLIN  # Linea de pedido
Raz [M:ZPVM0]
Raz [M:ZPVM1]

   WLSDDLIN=[M:SDH1]SDDLIN(WLLIG)
   [M:ZPVM0]SDDLIN=[M:SDH1]SDDLIN(WLLIG)
   [M:ZPVM0]ITMREF=[M:SDH1]ITMREF(WLLIG)
   [M:ZPVM0]ZANCHO=[M:SDH1]ZANCHO(WLLIG)
   [M:ZPVM0]ZLONGITUD=[M:SDH1]ZLONGITUD(WLLIG)
   [M:ZPVM0]QTYSTU=[M:SDH1]QTYSTU(WLLIG)
   [M:ZPVM0]ZCTDREALUS=0
   [M:ZPVM0]STU=[M:SDH1]STU(WLLIG)
  # [M:ZPVM0]ZMANDRIL=[M:SDH1]ZMANDRIL(WLLIG)
  # [M:ZPVM0]ZNTIRADAS=[M:SDH1]ZNTIRADAS(WLLIG)
  # [M:ZPVM0]ZFACTOR=[M:SDH1]ZFACTOR(WLLIG)
  # [M:ZPVM0]ZQTYBOB=[M:SDH1]ZQTYBOB(WLLIG)
  # [M:ZPVM0]ZSUPERFICIE=[M:SDH1]ZSUPERFICIE(WLLIG)
WLJ=0
For WLI=0 To [M:ZSDH1]ZNBCR - 1
   If WLSDDLIN=[M:ZSDH1]CRSDDLIN(WLI)
      [M:ZPVM1]CRSTOCOU(WLJ)=[M:ZSDH1]CRSTOCOU(WLI)
      [M:ZPVM1]CRLOT(WLJ)=[M:ZSDH1]CRLOT(WLI)
      [M:ZPVM1]CRSLO(WLJ)=[M:ZSDH1]CRSLO(WLI)
      [M:ZPVM1]CRSTU(WLJ)=[M:ZSDH1]CRSTU(WLI)
      [M:ZPVM1]CRQTYSTU(WLJ)=[M:ZSDH1]CRQTYSTU(WLI)
      [M:ZPVM1]LCTDREALUS(WLJ)=[M:ZSDH1]CTDREALUS(WLI)
      # Acumulamos importe Real
      [M:ZPVM0]ZCTDREALUS+=[M:ZSDH1]CTDREALUS(WLI)
      WLJ+=1
   Endif
Next
[M:ZPVM1]NBLIG = WLJ
Affzo [M:ZPVM0]
Affzo [M:ZPVM1]

#JLPR 30-06-17
# Si el empaquetado está hecho, NO PUEDEN CAMBIAR CANTIDADES
If clalev([F:SPD]) = 0 Local File SPACKD [F:SPD] Endif
Filter  [F:SPD]
Filter  [F:SPD] Where VCRNUM=[M:SDH0]SDHNUM and VCRLIN=[M:SDH1]SDDLIN(WLLIG)
If rowcount([F:SPD])>0
  Call ERREURT("EMPAQUETADO HECHO !!!\Deberá borrarlo para poder cambiar cantidades",1) From GESECRAN   #0-Informativo, 1-Error
  Diszo [M:ZPVM0]ZCTDREALUS
  [M:ZPVM0]EMPAQ=2
  Affzo [M:ZPVM0]EMPAQ
Endif
Filter  [F:SPD]
Return

$AVANT_OK
Return

$OK
Local Integer WLI,WLJ
If WGMODCR

  [M:SDH1]ZCTDREALUS(WLLIG)=[M:ZPVM0]ZCTDREALUS
  Affzo [M:SDH1]ZCTDREALUS(WLLIG)
  If [M:SDH1]STU(WLLIG)=[M:SDH1]SAU(WLLIG) Then
   [M:SDH1]ZCTDREAL(WLLIG)=[M:ZPVM0]ZCTDREALUS
   Affzo [M:SDH1]ZCTDREAL(WLLIG)
  Endif
  # Actualiza Mascara Detalle cantidades Reales
  For WLI=0 To [M:ZSDH1]ZNBCR - 1
     If [M:ZSDH1]CRSDDLIN(WLI)=WLSDDLIN Then
        For WLJ =0 To [M:ZPVM1]NBLIG - 1
          If [M:ZSDH1]CRSTOCOU(WLI)=[M:ZPVM1]CRSTOCOU(WLJ)
             [M:ZSDH1]CTDREALUS(WLI)=[M:ZPVM1]LCTDREALUS(WLJ)
             Affzo [M:ZSDH1]CTDREALUS(WLI)
          Endif
        Next
     Endif
  Next
Endif
Return

$END_
#Infbox "$END"
WGMODCR=0
Return

$TITRE_
Return

$FIN
Return


# Gestión de la máscara ZPVMCR0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZPVMCR0) 14/09/2016 12:16:34 (ADMIN)
######################################################################################


Subprog AM_ZCTDREALUS(VALEUR)
Variable Decimal VALEUR
# PESO TOTAL DE TODAS LAS BOBINAS DE LA LINEA DE ENTREGA
# De cambiarlo, se reparte equitativamente entre todas las bobinas, para ello
#   1ş INICAL/NUEVO, para determinar desviacion
#   2ş Multiplicamos Inicial de cada bobina x desviacion anterior, para obtener nuevo peso
Local Decimal WLCOEF, WLSUMA

If VALEUR<>0 and [M:ZPVM0]QTYSTU<>0 and [M:ZPVM1]NBLIG>0
   # Reajustar peso real
   WLCOEF = VALEUR / [M:ZPVM0]QTYSTU
   WLSUMA=0
   For I=0 To [M:ZPVM1]NBLIG - 2
      [M:ZPVM1]LCTDREALUS(I)=arr([M:ZPVM1]CRQTYSTU(I)*WLCOEF,0.0001)
      WLSUMA += [M:ZPVM1]LCTDREALUS(I)
      Affzo [M:ZPVM1]LCTDREALUS(I)
   Next
   [M:ZPVM1]LCTDREALUS(I)=arr(VALEUR-WLSUMA,0.0001)
   Affzo [M:ZPVM1]LCTDREALUS(I)
   WGMODCR=1
Else
   mkstat=2 : End
Endif
End


Subprog C_NBLIG
  If [M:ZPVM0]EMPAQ=2     Diszo  [M:ZPVM1]LCTDREALUS(nolign - 1)   Endif
End


Subprog AM_LCTDREALUS(VALEUR)
Variable Decimal VALEUR
# PESO INDIVIDUAL DE CADA BOBINA
# De cambiarlo, simplemente determinamos el nuevo TOTAL
Local Integer NOL :  NOL = nolign - 1
 [M:ZPVM0]ZCTDREALUS=0
 For I=0 To [M:ZPVM1]NBLIG - 1
    If I=NOL Then
       # Acumulamos importe Real
      [M:ZPVM0]ZCTDREALUS+=VALEUR
    Else
       # Acumulamos importe Real
      [M:ZPVM0]ZCTDREALUS+=[M:ZPVM1]LCTDREALUS(I)
    Endif
 Next
 Affzo[M:ZPVM0]ZCTDREALUS
 WGMODCR=1
End


