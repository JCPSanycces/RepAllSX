#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox ACTION
Case ACTION
   When "VALLIG"      :  Gosub VALLIG
   When "INICRE_LIG"  :  Gosub INICRE_LIG
   When "INIMOD_LIG"  :  Gosub $INICRE_LIG
   When "AFFMASK"     :  Gosub AFFMASK #Z0001
Endcase
Return

#Z0001.ini
$AFFMASK
Gosub ACTION From SUBPRH
GPE=1
Gosub ADD_TXT
Return
#Z0001.fin

$VALLIG
Return

$INICRE_LIG
[F:PND]ZQTYKG=0
[F:PND]ZQTYM2=0
If [F:PND]PUU="M2"
   [F:PND]ZQTYKG=[F:PND]QTYPUU
   If [F:PND]UOMPUUCOE
      [F:PND]ZQTYM2=[F:PND]QTYPUU/[F:PND]SAUSTUCOE
   Endif
Endif
If [F:PND]UOMPUUCOE="KG"
   [F:PND]ZQTYKG=[F:PND]QTYPUU
   [F:PND]ZQTYM2=[F:PND]QTYPUU*[F:PND]SAUSTUCOE
Endif
Return

#Z0001.ini
$ADD_TXT
If !clalev([F:TCC]) Local File TEXCPT  [TCC] Endif
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif
If !clalev([F:ZPRH]) Local File STOPREH [ZPRH] Endif
If !clalev([F:ZTDOC]) : Local File ZTEXDOC [ZTDOC] : Endif

Read [F:ZTDOC]ZTDOC0=2;[F:PRE]ORINUM
If !fstat
  Local Integer STAT,WTEXSEQ
  Local Char TMPCOD(20)
  Raz STAT,WTEXSEQ,TMPCOD
  Call NUM_TXC("PRH",WTEXSEQ,STAT) From TRTX3TEX
  If STAT=0
     TMPCOD="PRH"+"~"+format$("N0:8#",num$(WTEXSEQ))
     Raz [F:TXC]
    [F:TXC]CODE=TMPCOD
    [F:TXC]IDENT3=TMPCOD
    [F:TXC]TEXTE="{\rtf1\ansi{\fonttbl{\f0 MS Sans Serif;}}\uc0\pard\fs24\pard\ql\pard\ql\fs24 "+[F:ZTDOC]LINTEX1+"\fs24\par\pard\dl\fs24 "+[F:ZTDOC]LINTEX2+"\fs24\par\pard\dl\fs24 "+[F:ZTDOC]LINTEX3+
& "\fs24\par}"
    Write [F:TXC]
    If fstat
      Call FSTA("TEXCLOB") From GLOCK
    Else
      Read [F:ZPRH]PRH0=[F:PRH]PRHNUM
      If !fstat
        [F:ZPRH]PRPTEX1=TMPCOD
        Rewrite [F:ZPRH]
      Endif
    Endif
  Endif
Endif
Return
#Z0001.fin
