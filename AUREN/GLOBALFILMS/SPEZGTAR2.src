#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog MOSTRAR_TARIFA_NUEVA(L)
Value Integer L
#Limpiar rejilla
Raz [M:ZGTAR2]NBLIG
Effzo [M:ZGTAR2]5
#
#If func TODO_IGUAL([M:ZGTAR0]ZREVISION,[M:ZGTAR1]PLICRD(L))
##  MSG="No se ha variado precio alguno en la tarifa "+[M:ZGTAR1]PLICRD(L)
##  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
#  End
#Endif
Local Integer F,R,ZOK,O
Local Char D(1)
#Impedir uso de tabla para asegurarnos integridad
If !clalev([F:SPL])      :  Local File SPRICLIST [F:SPL]  : Endif
Lock [F:SPL]
If fstat<>0
  MSG="Imposible continuar, pues la tabla de tarifas estį siendo usado en otro puesto"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  End
Endif
#Marco filas en ZGTARVD como liberadas, para llevar un control de las que se han ańadido desues de fijar calculo
If !clalev([F:WZTVH])      :  Local File ZGTARVH [F:WZTVH]  : Endif
If !clalev([F:WZTVD])      :  Local File ZGTARVD [F:WZTVD]  : Endif
Update [F:WZTVD] Where [F:WZTVD]PLICRD=[M:ZGTAR1]PLICRD(L) With ESTADO=""
Link [F:WZTVD] With  [F:WZTVH]ZTVH0=[F:WZTVD]ZREVISION As [WTARF]
#Llenar rejilla
Gosub LLENAR_REJILLA
#Desbloquear
Unlock [F:SPL]
Close Local File  [F:WZTVH] ,[F:WZTVD]
Affzo [M:ZGTAR2]5
End



$LLENAR_REJILLA
O=1
Filter [F:SPL] Where PLICRD=[M:ZGTAR1]PLICRD(L) Order By PLICRD;PLILIN
For [F:SPL]
  Gosub DATOS
  Gosub CONTAR
  If ZOK=0 Break Endif
Next
Filter [F:SPL]
If ZOK=1 Gosub FILAS_BORRADAS Endif
Return


$FILAS_BORRADAS
Filter [F:WZTVD] Where [F:WZTVD]ZGEN<>2 and [F:WZTVD]PLICRD=[M:ZGTAR1]PLICRD(L) and [F:WZTVD]ESTADO<>"M"
For [F:WZTVD]
  F=[M:ZGTAR2]NBLIG
  [M:ZGTAR2]PLI(F)      =[F:WZTVD]PLI
  [M:ZGTAR2]PLICRD(F)   =[F:WZTVD]PLICRD
  [M:ZGTAR2]PLICRI(F)   =[F:WZTVD]PLICRI
  [M:ZGTAR2]ITMREF(F)   =[F:WZTVD]ITMREF
  [M:ZGTAR2]CUR(F)      =[F:WZTVD]CUR
  [M:ZGTAR2]UOM(F)      =[F:WZTVD]UOM
  [M:ZGTAR2]PRECACTU(F) =[F:WZTVD]PRECACTU
  [M:ZGTAR2]PRECNUEVO(F)=0
  [M:ZGTAR2]ZOK(F)      =[F:WZTVD]ZOK
  [M:ZGTAR2]ZBAJA(F)    =[F:WZTVD]ZBAJA
  [M:ZGTAR2]NOTAS(F)="AVISO. Linea omitida, debido a que se BORRO de tarifa, DESPUES de fijar cįlculo"
  Gosub CONTAR
  If ZOK=0 Break Endif
Next
Return


$DATOS
F=[M:ZGTAR2]NBLIG
[M:ZGTAR2]PLI(F)      =[F:SPL]PLI
[M:ZGTAR2]PLICRD(F)   =[F:SPL]PLICRD
[M:ZGTAR2]PLICRI(F)   =[F:SPL]PLICRI
[M:ZGTAR2]ITMREF(F)   =""
[M:ZGTAR2]CUR(F)      =""
[M:ZGTAR2]UOM(F)      =""
[M:ZGTAR2]PRECACTU(F) =[F:SPL]PRI
[M:ZGTAR2]PRECNUEVO(F)=0
Gosub DATOS_PRECIO
If [M:ZGTAR2]PRECNUEVO(F)=0
  D=func SPEZGTAR0.ITM_TARIFA([F:SPL]PLI)
  [M:ZGTAR2]PRECNUEVO(F)=[F:SPL]PRI
  [M:ZGTAR2]CUR(F)      =[F:SPL]CUR
  [M:ZGTAR2]UOM(F)      =[F:SPL]UOM
  [M:ZGTAR2]ITMREF(F)   =evalue("[F:SPL]PLICRI"+D)
  If [M:ZGTAR0]ZTIPO=2
    [M:ZGTAR2]NOTAS(F)="Se asume precio actual. Linea ańadida a tarifa DESPUES de fijar cįlculo"
  Endif
Elsif R>1
  [M:ZGTAR2]NOTAS(F)="Se asume precio actual. Linea encontrada en "+num$(R)+" cįlculos pdtes. Esto NO deberķa de ocurrir !!!"
  [M:ZGTAR2]PRECNUEVO(F)=[F:SPL]PRI
Endif
[M:ZGTAR2]PRECDIF(F) =[M:ZGTAR2]PRECNUEVO(F)-[M:ZGTAR2]PRECACTU(F)
If [M:ZGTAR2]PRECACTU(F)=0
  [M:ZGTAR2]PRECDIFP(F)=100
Else
  [M:ZGTAR2]PRECDIFP(F)=arr([M:ZGTAR2]PRECDIF(F)*100/[M:ZGTAR2]PRECACTU(F),0.01)
Endif
Return

$DATOS_PRECIO

#Se llama desde  ZPEZGTAR0.src     $GENERAR_TARIFA   << O=2 >>
#         desde aqui                                 << O=1 >>
#Ver si hay cįlculo para la linea de tarifa en la fecha de calculo actual
Local Char CRITERE(255)
Raz CRITERE
CRITERE+="[F:WZTVD]PLICRD=[F:SPL]PLICRD and [F:WZTVD]PLILIN=[F:SPL]PLILIN and [F:WZTVH]CERRADO<>2" #[F:WZTVH]ZFECHA=[M:ZGTAR0]ZFECHA"
#Case O
#When 1
#If [M:ZGTAR1]ZFECINI(F)=[0/0/0]
#CRITERE+=" and [F:WZTVD]ZGEN<>2"
#Else
#CRITERE+=" and [F:WZTVD]ZGEN<>2"
#Endif
#When 2
#CRITERE+=" and [F:WZTVD]ZGEN<>2"
#Endcase
Raz R
#For [WTARF] Where [F:WZTVD]PLICRD=[F:SPL]PLICRD and [F:WZTVD]PLILIN=[F:SPL]PLILIN and [F:WZTVH]ZFECHA=[M:ZGTAR0]ZFECHA
For [WTARF] Where evalue(CRITERE)
  Case O
  When 1

    [M:ZGTAR2]ITMREF(F)   =[WTARF]ITMREF
    [M:ZGTAR2]CUR(F)      =[WTARF]CUR
    [M:ZGTAR2]UOM(F)      =[WTARF]UOM
    [M:ZGTAR2]ZOK(F)      =[WTARF]ZOK
    [M:ZGTAR2]ZBAJA(F)    =[WTARF]ZBAJA
    If [WTARF]PLICRI=[F:SPL]PLICRI
      [M:ZGTAR2]PRECNUEVO(F)=[WTARF]PRECNUEV
    Else
      [M:ZGTAR2]NOTAS(F)="Se asume precio actual. Criterio distinto("+[WTARF]PLICRI+"<>"+[F:SPL]PLICRI+")"
      [M:ZGTAR2]PRECNUEVO(F)=[F:SPL]PRI
    Endif
    [WTARF]ESTADO="M"
    Rewrite [WTARF]
  When 2
    If [WTARF]ZBAJA=2
      PRECIO=-99
    Elsif [WTARF]PLICRI=[F:SPL]PLICRI
      PRECIO=[WTARF]PRECNUEV
    Else
      Call ECR_TRACE("Se asume precio actual. Criterio distinto("+[WTARF]PLICRI+"<>"+[F:SPL]PLICRI+")",-1) From GESECRAN
    Endif
    [WTARF]ZGEN   =2
    [WTARF]ZFECGEN=date$
    Rewrite [WTARF]
  Endcase
  R+=1
Next
Return

$CONTAR
If [M:ZGTAR2]NBLIG+1>=GFLDNUM(2)
  MSG="Alcanzado mįximo de " + num$(GFLDNUM(2)+1) + " filas para mostrar DETALLE lineas de tarifa\.\Avise para que se lo aumenten"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  ZOK=0
Else
  [M:ZGTAR2]NBLIG+=1
  ZOK=1
Endif
Return

Subprog COLORES
Local Integer F
For F=0 To [M:ZGTAR2]NBLIG-1
  If [M:ZGTAR2]NOTAS(F)<>""
    Chgstl [M:ZGTAR2]NBLIG(F) With "BACKGREEN"
  Elsif [M:ZGTAR2]PRECACTU(F)<>[M:ZGTAR2]PRECNUEVO(F)
    Chgstl [M:ZGTAR2]NBLIG(F) With "BACKYELLOW"
  Else
    Chgstl [M:ZGTAR2]NBLIG(F) With ""
  Endif
Next
End


Funprog TODO_IGUAL(REVI,TARF)
Value Integer REVI
Value Char TARF
Local Integer C,TODOIGUAL
If !clalev([F:WZTVD])      :  Local File ZGTARVD [F:WZTVD]  : Endif
Filter [F:WZTVD] Where ZREVISION=REVI and [F:WZTVD]PLICRD=TARF
Raz C
For [F:WZTVD]
  If [F:WZTVD]PRECACTU<>[F:WZTVD]PRECNUEV or [F:WZTVD]ZBAJA=2 or [F:WZTVD]ZOK=2
    C+=1
  Endif
Next
Filter [F:WZTVD]
If C=0 Then TODOIGUAL=1 Else TODOIGUAL=0 Endif
Close Local File [F:WZTVD]
End TODOIGUAL
