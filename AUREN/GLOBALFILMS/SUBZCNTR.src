#<AdxTL>@(#)0.0.0.0 $Revision$
#Gestion de contenedores (Unidades de transporte)
$ACTION
#If GUSER="JMORE"
#   Infbox ACTION
#Endif
Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "TITRE"      : Gosub TITRE_S
   When "FILTRE"     : Gosub FILTRE
   When "CREATION"   : Gosub CREATION
   When "APRES_CRE"  : Gosub APRES_CRE
   When "LIENS"      : Gosub LIENS
   When "MODIF"      : Gosub MODIF
   When "APRES_MOD"  : Gosub APRES_MOD
   When "ANNULE"     : Gosub ANNULE
   When "DEFLIG"     : Gosub DEFLIG
   When "INICRE_LIG" : Gosub INICRE_LIG
   When "INIMOD_LIG" : Gosub INICRE_LIG
   When "INICRE"     : Gosub INICRE
   When "SETBOUT"    : Gosub SETBOUT
   When "EXEBOUT"    : Gosub EXEBOUT
   When "FIN_ACTION" : Gosub FIN_ACTION
   When "LIENS_LIG"  : Gosub LIENS_LIG
   When "STYLE"      : Gosub STYLE
Endcase
Return

$TITRE_S
#TIT="Unidades de transporte << EN PRUEBAS # PDTE.VALIDAR >>"
Return


$OUVRE
Local Date WFECLLEDES

Raz WFECLLEDES

Gosub DECLARE From TABLEAUX
If clalev([F:ACLX])<=0  : Local File ACLOB    [ACLX] : Endif
If clalev([F:ACLX1])<=0 : Local File ACLOB    [ACLX1] : Endif
If clalev([F:ITM])<=0  : Local File ITMMASTER [ITM]  : Endif
If clalev([F:ITP])<=0  : Local File ITMBPS    [ITP]  : Endif
If clalev([F:POH])<=0  : Local File PORDER    [POH]  : Endif
If clalev([F:POP])<=0  : Local File PORDERP   [POP]  : Endif
If clalev([F:POQ])<=0  : Local File PORDERQ   [POQ]  : Endif
If !clalev([F:ZCNTRS]) : Local File ZCONTAINS [ZCNTRS] : Endif : #Pedidos de venta asociados a UT
If !clalev([F:ZCNTRM]) : Local File ZCONTAINM [ZCNTRM] : Endif : #OF's asociadas a UT
If !clalev([F:ZCNTRX]) : Local File ZCONTAINH [ZCNTRX] : Endif : #OF's asociadas a UT
Local Decimal TKGS(3)# 0=PedCompra 1=PedVta 2=OF
Local Integer TBOB(3)# 0=PedCompra 1=PedVta 2=OF
Return

$FILTRE
Default File [ZCNTR]
Return

$CREATION
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
Return

$APRES_CRE
Gosub LIENS From TABLEAUX
If GOK < 1 : Return : Endif
Return

$LIENS
Gosub LIENS From TABLEAUX
Raz [F:ACLX]

Read [ACLX]ACB0="CO_ZCNTR";[M:ZCNTR0]NUMCNTR;"";"1"
[M:ZCNTR1]OBSERV=[F:ACLX]CLOB
Affzo [M:ZCNTR1]OBSERV
Gosub CARGA_PEDVTA
Gosub CARGA_OF
WFECLLEDES=[M:ZCNTR1]FECLLEDES
Gosub MOSTRAR_KGS
Return

$MODIF
Gosub MODIF From TABLEAUX
If GOK < 1 : Return : Endif
Gosub MAJ_CNTR
If len([M:ZCNTR0]MATRICULA)>0
   Filter [ZCNTRX] Where MATRICULA=[M:ZCNTR0]MATRICULA
   For [ZCNTRX]
       If [F:ZCNTRX]NUMCNTR<>[M:ZCNTR0]NUMCNTR
          [F:ZCNTRX]BL      =[M:ZCNTR0]BL
          [F:ZCNTRX]FECHABL =[M:ZCNTR0]FECHABL
          [F:ZCNTRX]SITCNTR =[M:ZCNTR0]SITCNTR
          [F:ZCNTRX]BPTNUM  =[M:ZCNTR1]BPTNUM
          [F:ZCNTRX]CODNAV  =[M:ZCNTR1]CODNAV
          [F:ZCNTRX]FFWNUM  =[M:ZCNTR1]FFWNUM
          [F:ZCNTRX]MDL     =[M:ZCNTR1]MDL
          [F:ZCNTRX]NUMFAC  =[M:ZCNTR1]NUMFAC
          [F:ZCNTRX]FECPRESAL=[M:ZCNTR1]FECPRESAL
          [F:ZCNTRX]FECPRELLE=[M:ZCNTR1]FECPRELLE
          [F:ZCNTRX]FLGRCPDOC=[M:ZCNTR1]FLGRCPDOC
          [F:ZCNTRX]FECRCPDOC=[M:ZCNTR1]FECRCPDOC
          [F:ZCNTRX]FECREASAL=[M:ZCNTR1]FECREASAL
          [F:ZCNTRX]FECLLEPUE=[M:ZCNTR1]FECLLEPUE
          [F:ZCNTRX]FECLLEDES=[M:ZCNTR1]FECLLEDES
          [F:ZCNTRX]COSTE1   =[M:ZCNTR1]COSTE1
          [F:ZCNTRX]COSTE2   =[M:ZCNTR1]COSTE2
          Rewrite [ZCNTRX]
          If fstat
             Infbox "Error modificando contenedor [ZCNTRX] - fstat: "+num$(fstat)+" "+[F:ZCNTRX]NUMCNTR
             GOK=0
             Return
          Endif
          #Raz [F:ACLX1]
          #Read [ACLX1]ACB0="CO_ZCNTR";[F:ZCNTRX]NUMCNTR;"";"1"
          #If fstat
          #    [F:ACLX1]
          #Endif

       Endif
   Next
   Filter [ZCNTRX]
Endif
Return

$MAJ_CNTR
Local Integer I,MAXLIN

#Borramos y creamos pedidos de venta
Delete [ZCNTRS] Where NUMCNTR=[M:ZCNTR0]NUMCNTR
If fstat
   Infbox "Error borrando [ZCNTRS] - fstat: "+num$(fstat)
   GOK=0
   Return
Endif
MAXLIN=0
For I=0 To [M:ZCNTR3]NBLIG2-1
   MAXLIN=MAXLIN+1000
   [F:ZCNTRS]NUMCNTR =[M:ZCNTR0]NUMCNTR
   [F:ZCNTRS]NUMLIN =MAXLIN
   [F:ZCNTRS]POHNUM =[M:ZCNTR3]POHNUM(I)
   [F:ZCNTRS]POPLIN =[M:ZCNTR3]POPLIN(I)
   [F:ZCNTRS]POQSEQ =[M:ZCNTR3]POQSEQ(I)
   [F:ZCNTRS]SOHNUM =[M:ZCNTR3]SOHNUM(I)
   [F:ZCNTRS]SOPLIN =[M:ZCNTR3]SOPLIN(I)
   [F:ZCNTRS]SOQSEQ =[M:ZCNTR3]SOQSEQ(I)
   [F:ZCNTRS]BOBASI =[M:ZCNTR3]BOBASI(I)
   Write [ZCNTRS]
   If fstat
      GOK=0
      Infbox "Error grabando linea [ZCNTRS] - fstat: "+num$(fstat)
      Return
   Endif
Next

#Borramos y creamos OF's
Delete [ZCNTRM] Where NUMCNTR=[M:ZCNTR0]NUMCNTR
If fstat
   Infbox "Error borrando [ZCNTRM] - fstat: "+num$(fstat)
   GOK=0
   Return
Endif
MAXLIN=0
For I=0 To [M:ZCNTR4]NBLIG2-1
   MAXLIN=MAXLIN+1000
   [F:ZCNTRM]NUMCNTR =[M:ZCNTR0]NUMCNTR
   [F:ZCNTRM]NUMLIN =MAXLIN
   [F:ZCNTRM]POHNUM =[M:ZCNTR4]POHNUM(I)
   [F:ZCNTRM]POPLIN =[M:ZCNTR4]POPLIN(I)
   [F:ZCNTRM]POQSEQ =[M:ZCNTR4]POQSEQ(I)
   [F:ZCNTRM]MFGNUM =[M:ZCNTR4]MFGNUM(I)
   [F:ZCNTRM]MFGLIN =[M:ZCNTR4]MFGLIN(I)
   [F:ZCNTRM]BOBASI =[M:ZCNTR4]BOBASI(I)
   Write [ZCNTRM]
   If fstat
      GOK=0
      Infbox "Error grabando linea [ZCNTRM] - fstat: "+num$(fstat)
      Return
   Endif
Next

#If GUSER="ADMIN"
#   Infbox [M:ZCNTR0]NUMCNTR+" - "+[F:ZCNTR]NUMCNTR+" - "+num$(WFECLLEDES)+" - "+num$([M:ZCNTR1]FECLLEDES)
#Endif
#Actualizar la fecha de recepcion prevista de la linea de pedido de compra se se ha modificado
#la fecha de llegada a destino
If WFECLLEDES<>[M:ZCNTR1]FECLLEDES and [M:ZCNTR1]FECLLEDES<>[0/0/0]
   For I=0 To [M:ZCNTR2]NBLIG
       If [M:ZCNTR2]POHNUM(I)<>""
          Update [POQ] Where POHNUM=[M:ZCNTR2]POHNUM(I) and POPLIN=[M:ZCNTR2]POPLIN(I)
&                With EXTRCPDAT=[M:ZCNTR1]FECLLEDES
       Endif
       Break
   Next
Endif
Return

$APRES_MOD
Gosub LIENS From TABLEAUX
Return

$ANNULE
Gosub ANNULE From TABLEAUX
If GOK < 1 : Return : Endif
Return

##############################################################################
$DEFLIG
#--------------------------------------#
# Definición del fichero de líneas     #
# CRIT = Criterio de lectura           #
# FICLIG = Nombre del fichero          #
# ABLIG  = Abreviatura del fichero     #
# ZONLIG = Campo número de línea       #
#--------------------------------------#
 Default Mask [ZCNTR2]
 Default File [ZCNTRP]
 CRIT   = '[F:ZCNTRP]NUMCNTR="'+[M:ZCNTR0]NUMCNTR+'"'
 FICLIG = "ZCONTAINP"
 ABLIG  = "ZCNTRP"
 ZONLIG = "NUMLIN"
Return
###############################################################################
$INICRE_LIG
[F:ZCNTRP]NUMCNTR = [M:ZCNTR0]NUMCNTR

Return

$INICRE
Local Char NUMERO(25)
Local Integer STAT

If len(GFCYDEF)=0
   Infbox "Sin planta asignada"
   GOK = 0 : Return
Endif
Call NUMERO ("ZCNTR",GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
If STAT = 0
   [F:ZCNTR]NUMCNTR = NUMERO
Else
   GOK = 0 : Return
Endif
[M:ZCNTR0]NUMCNTR=[F:ZCNTR]NUMCNTR
Affzo [M:ZCNTR0]NUMCNTR
Return

$SETBOUT
If  GREP = "C" or GREP = "M" or [M:ZCNTR0]NUMCNTR=""
    Call VIREBOUT(CHAINE,"123") From GOBJET
Endif
Return

$EXEBOUT

Return

$FIN_ACTION
#Infbox num$(REPONSE)+"   "+num$(GSTALIT)
# Pour forcer un réaffichage de la commande
#1101 (Botones tipo No validando)
#1801 (Botones tipo Validando)
#Infbox "SUBZCNTR - FIN_ACTION"
If REPONSE=1801
   Gosub RELIT From GOBJSUB
   Gosub CARGA_PEDVTA
Endif
If REPONSE=1802
   Gosub RELIT From GOBJSUB
   Gosub CARGA_OF
Endif
Return

$LIENS_LIG
Local Shortint NOL
Local Decimal LVOLUMEN
[M:ZCNTR1]DEMORA=abs([M:ZCNTR1]FECLLEPUE-[M:ZCNTR1]FECLLEDES)
Affzo [M:ZCNTR1]DEMORA

NOL=nolign-1
Raz [F:POP]
Read [POP]POP0=[F:ZCNTRP]POHNUM;[F:ZCNTRP]POPLIN;[F:ZCNTRP]POQSEQ
Raz [F:POQ]
Read [POQ]POQ0=[F:ZCNTRP]POHNUM;[F:ZCNTRP]POPLIN;[F:ZCNTRP]POQSEQ
Raz [F:ITM]
Read [ITM]ITM0=[F:POP]ITMREF
[M:ZCNTR2]POPLIN(NOL)   =[F:POP]POPLIN
[M:ZCNTR2]POQSEQ(NOL)   =[F:POQ]POQSEQ
[M:ZCNTR2]ITMREF(NOL)   =[F:POP]ITMREF
[M:ZCNTR2]ITMDES1(NOL)  =[F:POP]ITMDES1
[M:ZCNTR2]ANCHO(NOL)    =[F:POQ]ZANCHO
[M:ZCNTR2]MANDRIL(NOL)  =[F:POQ]ZMANDRIL
[M:ZCNTR2]LONGITUD(NOL) =[F:POQ]ZLONGITUD
[M:ZCNTR2]BOBPED(NOL)   =[F:POQ]ZQTYBOB
If NOL=0
   #Infbox num$([M:ZCNTR2]BOBASI(NOL))
Endif
[M:ZCNTR2]BOBPTE(NOL)   =[F:POQ]ZQTYBOB-[M:ZCNTR2]BOBASI(NOL)

[M:ZCNTR2]BOBRES(NOL)   =0
[M:ZCNTR2]BOBNRES(NOL)   =0

Filter [ZCNTRS] Where NUMCNTR=[M:ZCNTR0]NUMCNTR and POHNUM=[M:ZCNTR2]POHNUM(NOL) and
&                     POPLIN=[M:ZCNTR2]POPLIN(NOL) and POQSEQ=[M:ZCNTR2]POQSEQ(NOL)
For [ZCNTRS]
   [M:ZCNTR2]BOBRES(NOL) +=[F:ZCNTRS]BOBASI
Next
Filter [ZCNTRS]

Filter [ZCNTRM] Where NUMCNTR=[M:ZCNTR0]NUMCNTR and POHNUM=[M:ZCNTR2]POHNUM(NOL) and
&                     POPLIN=[M:ZCNTR2]POPLIN(NOL) and POQSEQ=[M:ZCNTR2]POQSEQ(NOL)
For [ZCNTRM]
   [M:ZCNTR2]BOBRES(NOL) +=[F:ZCNTRM]BOBASI
Next
Filter [ZCNTRM]

[M:ZCNTR2]BOBNRES(NOL)   =[M:ZCNTR2]BOBASI(NOL)-[M:ZCNTR2]BOBRES(NOL)
Raz [F:POH]
Read [POH]POH0=[F:ZCNTRP]POHNUM
Raz [F:ITP]
Read [ITP]ITP0=[M:ZCNTR2]ITMREF(NOL);[F:POH]BPSNUM
LVOLUMEN=([M:ZCNTR2]ANCHO(NOL)/100)*[M:ZCNTR2]LONGITUD(NOL)*[F:ITP]ZESPESORP
[M:ZCNTR2]QTYPED(NOL)=[M:ZCNTR2]BOBPED(NOL)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)
[M:ZCNTR2]QTYASI(NOL)=[M:ZCNTR2]BOBASI(NOL)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)
[M:ZCNTR2]QTYPTE(NOL)=[M:ZCNTR2]BOBPTE(NOL)*LVOLUMEN*([F:ITP]ZDTYP*1000000/1000)

Return

$CARGA_PEDVTA
Local Shortint NOL

Filter [ZCNTRS] Where NUMCNTR=[M:ZCNTR0]NUMCNTR
Raz TKGS(1),TBOB(1),NOL
For [ZCNTRS]
   Raz[F:POQ]
   Read [POQ]POQ0=[F:ZCNTRS]POHNUM;[F:ZCNTRS]POPLIN;1
   Raz[F:POP]
   Read [POP]POP0=[F:ZCNTRS]POHNUM;[F:ZCNTRS]POPLIN;1
   Raz [F:ITM]
   Read [ITM]ITM0=[F:POQ]ITMREF
   [M:ZCNTR3]POHNUM(NOL)=[F:ZCNTRS]POHNUM
   [M:ZCNTR3]NUMLIN(NOL)=[F:ZCNTRS]NUMLIN
   [M:ZCNTR3]POPLIN(NOL)=[F:ZCNTRS]POPLIN
   [M:ZCNTR3]POQSEQ(NOL)=[F:ZCNTRS]POQSEQ
   [M:ZCNTR3]SOHNUM(NOL)=[F:ZCNTRS]SOHNUM
   [M:ZCNTR3]SOPLIN(NOL)=[F:ZCNTRS]SOPLIN
   [M:ZCNTR3]SOQSEQ(NOL)=[F:ZCNTRS]SOQSEQ
   [M:ZCNTR3]ITMREF(NOL)=[F:POQ]ITMREF
   [M:ZCNTR3]ANCHO(NOL) =[F:POQ]ZANCHO
   [M:ZCNTR3]MANDRIL(NOL)=[F:POQ]ZMANDRIL
   [M:ZCNTR3]LONGITUD(NOL)=[F:POQ]ZLONGITUD
   [M:ZCNTR3]ITMDES1(NOL)=[F:ITM]ITMDES1
   [M:ZCNTR3]BOBPED(NOL)=[F:POQ]ZQTYBOB
   [M:ZCNTR3]BOBASI(NOL)=[F:ZCNTRS]BOBASI
   If [F:POQ]ZQTYBOB<>0
   TKGS(1)+=([F:POQ]QTYSTU/[F:POQ]ZQTYBOB)*[F:ZCNTRS]BOBASI
   Endif
   TBOB(1)+=[F:ZCNTRS]BOBASI
   NOL+=1
Next
[M:ZCNTR3]NBLIG2=NOL
Filter [ZCNTRS]
Affzo [M:ZCNTR3]5
Return

$CARGA_OF
Local Shortint NOL

Filter [ZCNTRM] Where NUMCNTR=[M:ZCNTR0]NUMCNTR
Raz TKGS(2),TBOB(2),NOL
For [ZCNTRM]
   Raz[F:POQ]
   Read [POQ]POQ0=[F:ZCNTRM]POHNUM;[F:ZCNTRM]POPLIN;1
   Raz[F:POP]
   Read [POP]POP0=[F:ZCNTRM]POHNUM;[F:ZCNTRM]POPLIN;1
   Raz [F:ITM]
   Read [ITM]ITM0=[F:POQ]ITMREF
   [M:ZCNTR4]POHNUM(NOL)=[F:ZCNTRM]POHNUM
   [M:ZCNTR4]NUMLIN(NOL)=[F:ZCNTRM]NUMLIN
   [M:ZCNTR4]POPLIN(NOL)=[F:ZCNTRM]POPLIN
   [M:ZCNTR4]POQSEQ(NOL)=[F:ZCNTRM]POQSEQ
   [M:ZCNTR4]MFGNUM(NOL)=[F:ZCNTRM]MFGNUM
   [M:ZCNTR4]MFGLIN(NOL)=[F:ZCNTRM]MFGLIN
   [M:ZCNTR4]ITMREF(NOL)=[F:POQ]ITMREF
   [M:ZCNTR4]ANCHO(NOL) =[F:POQ]ZANCHO
   [M:ZCNTR4]MANDRIL(NOL)=[F:POQ]ZMANDRIL
   [M:ZCNTR4]LONGITUD(NOL)=[F:POQ]ZLONGITUD
   [M:ZCNTR4]ITMDES1(NOL)=[F:ITM]ITMDES1
   [M:ZCNTR4]BOBPED(NOL)=[F:POQ]ZQTYBOB
   [M:ZCNTR4]BOBASI(NOL)=[F:ZCNTRM]BOBASI
   If [F:POQ]ZQTYBOB<>0
   TKGS(2)+=([F:POQ]QTYSTU/[F:POQ]ZQTYBOB)*[F:ZCNTRM]BOBASI
   Endif
   TBOB(2)+=[F:ZCNTRM]BOBASI
   NOL+=1
Next
[M:ZCNTR4]NBLIG2=NOL
Filter [ZCNTRM]
Affzo [M:ZCNTR4]5
Return

$CARGA_PEDCOM
Local Shortint NOL
Raz TKGS(0),TBOB(0),NOL
For NOL=0 To [M:ZCNTR2]NBLIG-1
   Raz[F:POQ]
   Read [POQ]POQ0=[M:ZCNTR2]POHNUM(NOL);[M:ZCNTR2]POPLIN(NOL);[M:ZCNTR2]POQSEQ(NOL)
   If [F:POQ]ZQTYBOB<>0
   TKGS(0)+=([F:POQ]QTYSTU/[F:POQ]ZQTYBOB)*[M:ZCNTR2]BOBASI(NOL)
   Endif
   TBOB(0)+=[M:ZCNTR2]BOBASI(NOL)
Next
Return

$MOSTRAR_KGS
Gosub CARGA_PEDCOM
Local Shortint NOL
Raz [M:ZCNTR1]NBDAT
Effzo [M:ZCNTR1]20
NOL=[M:ZCNTR1]NBDAT
[M:ZCNTR1]CONCEPTO(NOL)="Ped compra "
[M:ZCNTR1]TKGS(NOL)    =TKGS(0)
[M:ZCNTR1]TBOB(NOL)    =TBOB(0)
[M:ZCNTR1]NBDAT+=1
NOL=[M:ZCNTR1]NBDAT
[M:ZCNTR1]CONCEPTO(NOL)="Ped venta "
[M:ZCNTR1]TKGS(NOL)    =TKGS(1)
[M:ZCNTR1]TBOB(NOL)    =TBOB(1)
[M:ZCNTR1]NBDAT+=1
NOL=[M:ZCNTR1]NBDAT
[M:ZCNTR1]CONCEPTO(NOL)="OF "
[M:ZCNTR1]TKGS(NOL)    =TKGS(2)
[M:ZCNTR1]TBOB(NOL)    =TBOB(2)
[M:ZCNTR1]NBDAT+=1
NOL=[M:ZCNTR1]NBDAT
[M:ZCNTR1]CONCEPTO(NOL)="Disponibles"
[M:ZCNTR1]TKGS(NOL)    =TKGS(0)-TKGS(1)-TKGS(2)
[M:ZCNTR1]TBOB(NOL)    =TBOB(0)-TBOB(1)-TBOB(2)
[M:ZCNTR1]NBDAT+=1
Affzo [M:ZCNTR1]20
Return

$STYLE
Local Char REQUETE(250)(2)
Local Integer I

REQUETE(0)="SELECT ZCNTP.NUMCNTR_0,ZCNTP.POHNUM_0,PID.NUM_0,PIH.BPRVCR_0 From ZCONTAINP ZCNTP LEFT OUTER JOIN"+
&          " PINVOICED PID ON PID.POHNUM_0=ZCNTP.POHNUM_0 LEFT JOIN PINVOICE PIH ON PIH.NUM_0=PID.NUM_0"
REQUETE(1)=" Where ZCNTP.POHNUM_0<>'"+""+"' and ZCNTP.NUMCNTR_0='"+[M:ZCNTR0]NUMCNTR+"'"+
&          " GROUP By ZCNTP.NUMCNTR_0,ZCNTP.POHNUM_0,PID.NUM_0,PIH.BPRVCR_0"

I=0
For (Char LNUMCNTR(25), Char LPOHNUM(25), Char LPIHNUM(25), Char LBPRVCR(25)) From '5' Sql REQUETE As [ZREQ]
   [M:ZCNTR1]CPOHNUM(I)=LPOHNUM
   [M:ZCNTR1]CPIHNUM(I)=LPIHNUM
   [M:ZCNTR1]CBPRVCR(I)=LBPRVCR
   I+=1
Next
[M:ZCNTR1]NBLIG=I
Affzo [M:ZCNTR1]15
Return
