#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "OUVRE"        : Gosub OUVRE
When "AFFMASK"      : Gosub AFFMASK
When "FERME"        : Gosub FERME
When "INICRE"       : Gosub VERIF_CRE_MOD
Endcase
Return

$OUVRE
Global Char WBD(1)
Return

$AFFMASK
WBD=func ZCOMUN.DATA_BASE_TIPO()
Return

$FERME
If dim(WBD)>0   Kill  WBD    Endif
Return

$VERIF_CRE_MOD
For F=0 To [M:SCS1]NBLIG-1
  If not func BOB_OK(F)
    Raz OK,GOK
    Break
  Endif
Next
Return




Funprog BOB_OK(F)
Value Integer F
#IMPEDIR CAMBIO DE UBICACION de bobinas que cumplan lo siguiente:
#- Estar incluidas en OF ASIGNADAS + PDTE.CERRAR  + sobrante
Local Integer WOK   :   WOK=1
Local Char    TXT(255)(10)
Local Char    BD(1)
Local Char    MSG(255)
If [M:SCS1]ITMREF(F)<>"" and [M:SCS1]LOT(F)<>""  and [M:SCS1]SLO(F)<>""
  Raz TXT
  TXT(0)="select distinct m.MFGNUM_0 "
  TXT(1)="from ZMFGLOT m "
  TXT(2)="inner join MFGHEAD c on m.MFGNUM_0=c.MFGNUM_0 "
  TXT(3)="where ALLSTA_0>1 and MFGTRKFLG_0<5 and m.ZLONGSOB_0>0 "
  TXT(4)="and ITMREF_0='"+[M:SCS1]ITMREF(F)+"' and LOT_0 ='"+[M:SCS1]LOT(F)+"' and SLO_0='"+[M:SCS1]SLO(F)+"'"
Endif
For (Char FMFG(GLONVCR)) From WBD Sql TXT As [MYT]
  WOK=0
  MSG ="IMPOSIBLE CAMBIAR DE UBICACION\.\Debido a que la bobina ("+[M:SCS1]ITMREF(F)+" # "+[M:SCS1]LOT(F)+" # "+[M:SCS1]SLO(F)+")"
  MSG+="\- Está incluida en la OF "+[MYT]FMFG+" abierta y asignada\- e ha indicado un sobrante"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  Break
Next
End WOK

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SCS1) 13/06/2017 11:34:16 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SCS1]ITMREF(nolign-1)=VALEUR
If not func BOB_OK(nolign-1)  mkstat=2   Endif
End

Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
[M:SCS1]LOT(nolign-1)=VALEUR
If not func BOB_OK(nolign-1)  mkstat=2   Endif
End

Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
[M:SCS1]SLO(nolign-1)=VALEUR
If not func BOB_OK(nolign-1)  mkstat=2   Endif
End

######################################################################################
#> AZ 70247 - bloque cantidad en cambio ubicación cuando son bobinas
Subprog C_QTYSTUDES(VALEUR)
Variable Decimal VALEUR

If !clalev([I0]) : Local File ITMMASTER [I0] : Endif

Read [I0]ITM0 = [M:SCS1]ITMREF(nolign-1)
If fstat = 0 Then
  If [I0]ZFABCOR = 2 Then
    # cantidad disponible debe ser igual al valor por campo..
    If [M:SCS1]STUDIS(nolign-1) <> VALEUR Then
      GMESSAGE = "Cantidad destino debe ser igual a la Cantidad disponible"
      mkstat = 2
    Endif
  Endif
Endif

Close Local File [I0]
End


