#<AdxTL>@(#)0.0.0.0 $Revision$
# Gesti¾n de la mßscara ZPGOFS4 (Especifico)
#LOS EVENTOS DE VENTANA SE GESTIONAN EN EL SPECIFICO INDICADO EN LA accion QUE LLAMA A LA VENTANA


Subprog RESUMEN
Onerrgo ERRORES_FIN
Call VACIAR_REJILLAS
Call PASAR_PEDIDOS
Call PASAR_PEDIDOS_COL
Call PASAR_OF_SUG
Call PASAR_JUMBOS
Call TOTALES
Call MOSTRAR_OF
Call MOSTRAR_RUTA
Onerrgo
End

Subprog MOSTRAR_RUTA
Local Char ART(GLONITM)
ART=func SPEZGOFS.ARTICULO
If !clalev([F:ITF])      :  Local File ITMFACILIT[F:ITF]  : Endif
Read [F:ITF]ITF0=ART;[M:ZGOFS0]FFCY
If fstat=0
  [M:ZGOFS4]ROUNUM=[F:ITF]MFGROU
  [M:ZGOFS4]ROUALT=[F:ITF]MFGROUALT
Endif
[M:ZGOFS4]STRDAT=date$
[M:ZGOFS4]ENDDAT=date$
Affzo [M:ZGOFS4]30 # Ruta
End

Subprog TOTALES
Local Integer F
# Materia prima
Local Integer TLNG(4)
Local Decimal TM2(3),TCST(4),TKGS(3),MRG,MER
Raz TLNG,TM2,TCST
TLNG(3)=[M:ZGOFS4]NSUG*func LARGO  # Longitud necesaria
For F=0 To [M:ZGOFS4]NMAT-1
  If [M:ZGOFS4]SSEL(F)=2
    # Determinar sobrante   
    If [M:ZGOFS4]SRESTO(F)<>0
      [M:ZGOFS4]SRESTOKGS(F)=arr(([M:ZGOFS4]SRESTO(F)*[M:ZGOFS4]SANCHO(F) /1000)*[M:ZGOFS4]ZFACTOR(F),0.0001)
    Else
      [M:ZGOFS4]SRESTOKGS(F)=0
    Endif
    TLNG(0)+= [M:ZGOFS4]SLARGO(F)
    TLNG(1)+= [M:ZGOFS4]SUSADO(F)
    TKGS(0)+= [M:ZGOFS4]QTYSTU(F)
    TKGS(1)+= [M:ZGOFS4]QTYSTU(F)-[M:ZGOFS4]SRESTOKGS(F) #arr(([M:ZGOFS4]SUSADO(F)*[M:ZGOFS4]QTYSTU(F))/[M:ZGOFS4]SLARGO(F),0.0001)
    TM2 (0)+= [M:ZGOFS4]SANCHO(F)*[M:ZGOFS4]SLARGO(F)/1000
    TM2 (1)+= [M:ZGOFS4]SANCHO(F)*[M:ZGOFS4]SUSADO(F)/1000
    TCST(1)+= [M:ZGOFS4]SIMPORTE(F)
    If [M:ZGOFS4]SMERMA(F)=2
      TLNG(2)+= [M:ZGOFS4]SRESTO(F)
      TM2 (2)+= [M:ZGOFS4]SANCHO(F)*[M:ZGOFS4]SRESTO(F)/1000
      TCST(2)+=([M:ZGOFS4]SANCHO(F)*[M:ZGOFS4]SRESTO(F)/1000)*[M:ZGOFS4]SPRECIO(F)
      TKGS(2)+=[M:ZGOFS4]SRESTOKGS(F)#arr(([M:ZGOFS4]SRESTO(F)*[M:ZGOFS4]QTYSTU(F))/[M:ZGOFS4]SLARGO(F),0.0001)
    Endif
    TCST(3)=func COSTE_ANCHOS_A
  Endif
Next
[M:ZGOFS4]LNGSEL=TLNG(0)
[M:ZGOFS4]LNGUSA=TLNG(1)
[M:ZGOFS4]LNGMER=TLNG(2)
[M:ZGOFS4]LNGRES=TLNG(0)-TLNG(1)-TLNG(2)
Affzo [M:ZGOFS4]LNGSEL
Affzo [M:ZGOFS4]LNGUSA
Affzo [M:ZGOFS4]LNGMER
Affzo [M:ZGOFS4]LNGRES
[M:ZGOFS4]M2SEL =TM2 (0)
[M:ZGOFS4]M2USA =TM2 (1)
[M:ZGOFS4]M2MER =TM2 (2)
[M:ZGOFS4]M2RES =TM2 (0)-TM2 (1)-TM2 (2)
Affzo [M:ZGOFS4]M2SEL
Affzo [M:ZGOFS4]M2USA
Affzo [M:ZGOFS4]M2MER
Affzo [M:ZGOFS4]M2RES
[M:ZGOFS4]KGSSEL=TKGS(0)
[M:ZGOFS4]KGSUSA=TKGS(1)
[M:ZGOFS4]KGSMER=TKGS(2)
[M:ZGOFS4]KGSRES=TKGS(0)-TKGS(1)-TKGS(2)
Affzo [M:ZGOFS4]KGSSEL
Affzo [M:ZGOFS4]KGSUSA
Affzo [M:ZGOFS4]KGSMER
Affzo [M:ZGOFS4]KGSRES
# Valor pedidos & Margen
Local Decimal TVTA
Raz TVTA
For F=0 To [M:ZGOFS4]NCTE-1
  TVTA+=[M:ZGOFS4]PIMPORTE(F)
Next
MRG=TVTA+TCST(3)-TCST(1)-TCST(2)
# Determinar % Merma Ancho
#Infbox "Dbgaff   DEBUG  $TOTALES"
MER=func TOT_MERMA_ANCHO
[M:ZGOFS4]IMPPED=format$("N:15.2",TVTA)    + "      " + vireblc(format$("N:15.2",TCST(3)),2)
[M:ZGOFS4]IMPUSA=format$("N:15.2",TCST(1)) + "      (" + vireblc(format$("N:15.2",MER*[M:ZGOFS4]SPRECIO(0)),2)
If TLNG(1)<>0    # Se asume que LongNecesaria=LongUsada
  [M:ZGOFS4]IMPUSA+=+ " - " + vireblc(format$("N:3.2",MER*100/TLNG(1)),2) + "%"
Elsif TLNG(3)<>0 # Se asume que LongNecesaria=LongUsada
  [M:ZGOFS4]IMPUSA+=+ " - " + vireblc(format$("N:3.2",MER*100/TLNG(3)),2) + "%"
Endif
[M:ZGOFS4]IMPUSA+=")"
[M:ZGOFS4]IMPMER=format$("N:15.2",TCST(2))
[M:ZGOFS4]IMPMARGEN=format$("N:15.2",MRG)
If TVTA<>0
  [M:ZGOFS4]IMPMARGEN+="    " + format$("N:3.2",MRG*100/TVTA) + "%"
Endif
Affzo [M:ZGOFS4]IMPPED
Affzo [M:ZGOFS4]IMPUSA
Affzo [M:ZGOFS4]IMPMER
Affzo [M:ZGOFS4]IMPMARGEN
End

Subprog PASAR_PEDIDOS
Local Integer L,F,BOBPED,BOBCLC
Local Decimal CANT
For L=0 To [M:ZGOFS1]NPED-1
  If [M:ZGOFS1]PEDSEL(L)=2
    # Que el largo de bobina estķ marcado para cßlculo  (Agrupar)
    If func LARGO_INCLUIDO([M:ZGOFS1]PLARGO(L))
      F=[M:ZGOFS4]NCTE
      [M:ZGOFS4]PFECENT(F)   =[M:ZGOFS1]PFECENT(L)
      [M:ZGOFS4]PSOHNUM(F)   =[M:ZGOFS1]PSOHNUM(L)
      [M:ZGOFS4]PCTE(F)      =[M:ZGOFS1]PCTE(L)
      [M:ZGOFS4]PSOPLIN(F)   =[M:ZGOFS1]PSOPLIN(L)
      [M:ZGOFS4]PSOQSEQ(F)   =[M:ZGOFS1]PSOQSEQ(L)
      [M:ZGOFS4]PLARGO(F)    =[M:ZGOFS1]PLARGO(L)
      [M:ZGOFS4]PANCHO(F)    =[M:ZGOFS1]PANCHO(L)
      [M:ZGOFS4]PBOBINAS(F)  =[M:ZGOFS1]PBOBINASC(L)
      [M:ZGOFS4]PBOBINASOF(F)=[M:ZGOFS4]PBOBINAS(F)-func BOBINAS_PDTE([M:ZGOFS4]PLARGO(F),[M:ZGOFS4]PANCHO(F),[M:ZGOFS4]PBOBINAS(F))
      [M:ZGOFS4]PPRECIO(F)   =[M:ZGOFS1]PPRECIO(L)
      [M:ZGOFS4]SAU(F)       =[M:ZGOFS1]SAU(L)
      BOBPED=[M:ZGOFS1]PBOBINAS(L)
      BOBCLC=[M:ZGOFS4]PBOBINASOF(F)
      Case [M:ZGOFS1]SAU(L)
      When "KG"
        CANT=arr((BOBCLC*[M:ZGOFS1]ZQTYKG(L))/BOBPED,0.0001)
      When "M2"
        CANT=arr((BOBCLC*[M:ZGOFS1]PM2LIN(L))/BOBPED,1)
      When Default
        Infbox "Revise pedido "+FSOHNUM+" "+num$(FSOPLIN)+" Unidad venta NO contemplada ("+ FSAU +")"
      Endcase
      [M:ZGOFS4]QTY(F)       =CANT
      [M:ZGOFS4]PIMPORTE(F)  =CANT*[M:ZGOFS4]PPRECIO(F)
      [M:ZGOFS4]NCTE+=1
    Endif
  Endif
Next
Affzo [M:ZGOFS4]15
End

Funprog LARGO_INCLUIDO(LAR)
Value Integer LAR
Local Integer OK,F
OK=0
For F=0 To [M:ZGOFS2]NLAR-1
  If [M:ZGOFS2]LAGRUPAR(F)=2 and [M:ZGOFS2]LLARGO(F)=LAR
    OK=1
    Break
  Endif
Next
End OK

Subprog PASAR_PEDIDOS_COL
Local Integer F
For F=0 To [M:ZGOFS4]NCTE-1
  If [M:ZGOFS4]PBOBINASOF(F)<>[M:ZGOFS4]PBOBINAS(F)
    Chgstl [M:ZGOFS4]NCTE(F) With "BACKRED"
  Endif
Next
End

Funprog TOT_MERMA_ANCHO
Local Decimal MERMA
Local Integer F
Raz MERMA
For F=0 To [M:ZGOFS2]NSUG-1
  MERMA+=[M:ZGOFS4]SDIFA(F)*[M:ZGOFS4]SANCHOJ(F)/1000
Next
End MERMA

Subprog PASAR_OF_SUG
Local Integer L,F
For L=0 To [M:ZGOFS2]NSUG-1
  If  [M:ZGOFS2]SSEL(L)=2
    F=[M:ZGOFS4]NSUG
    [M:ZGOFS4]SANCHOJ(F) =[M:ZGOFS2]SANCHOJ(L)
    [M:ZGOFS4]SOPCION(F) =[M:ZGOFS2]SOPCION(L)
    [M:ZGOFS4]SLARGOB(F) =func SPEZGOFS1.LARGO_SEL
    [M:ZGOFS4]SCOMBI(F)  =[M:ZGOFS2]SCOMBI(L)
    [M:ZGOFS4]SANADIR(F) =[M:ZGOFS2]SANADIR(L)
    [M:ZGOFS4]SDIFA(F)   =[M:ZGOFS2]SDIF(L)
    [M:ZGOFS4]SDIFAT(F)  =[M:ZGOFS2]SDIFT(L)
    [M:ZGOFS4]STROZOSA(F)=[M:ZGOFS2]STROZOS(L)
    [M:ZGOFS4]SDIFTRZA(F)=[M:ZGOFS2]SDIFTRZ(L)
    [M:ZGOFS4]SCOMBIS(F) =func AGRUPAR_ANCHOS(L)
    [M:ZGOFS4]NSUG+=1
  Endif
Next F
Sorta [M:ZGOFS4]NSUG [M:ZGOFS4]NSUG Order By [M:ZGOFS4]SANCHOJ(indice),[M:ZGOFS4]SCOMBIS(indice)  #,[M:ZGOFS4]SCOMBI(indice),[M:ZGOFS4]SANADIR(indice)
Affzo [M:ZGOFS4]20
Chgtzn [M:ZGOFS4]LNGUSA With "Long Usada (Necesaria " + num$([M:ZGOFS4]NSUG*func LARGO) + ")"
End

Funprog AGRUPAR_ANCHOS(L)
Value Integer L
Local Integer ANC(50),F,Z
Local Char A(255)
Raz ANC,A,Z
# Saco los anchos que hay
If [M:ZGOFS4]SCOMBI(L)<>""
  For F=1 To len([M:ZGOFS4]SCOMBI(L)) Step 5
    ANC(Z)=val(mid$([M:ZGOFS4]SCOMBI(L),F,4))
    Z+=1
  Next
Endif
If [M:ZGOFS4]SANADIR(L)<>""
  For F=1 To len([M:ZGOFS4]SANADIR(L)) Step 5
    ANC(Z)=val(mid$([M:ZGOFS4]SANADIR(L),F,4))
    Z+=1
  Next
Endif
# Los ordeno
Sorta ANC
# Monto string
For F=0 To dim(ANC)-1
  If ANC(F)>0
    If A<>""
      A+="-"
    Endif
    A+=format$("N0:4",ANC(F))
  Endif
Next
End A

Funprog COSTE_ANCHOS_A
Local Decimal IMP,PREC
Local Integer F,I,ANC,LAR,L
Local Char T(255),M(10)(2)
LAR=func SPEZGOFS1.LARGO_SEL
IMP=0
For F=0 To [M:ZGOFS2]NSUG-1
  # Si es cero, es porque no hay materia prima suficiente para su fabriaci¾n
  If [M:ZGOFS4]SASIGNADA(F)>0
    T=[M:ZGOFS4]SANADIR(F)
    For I=1 To len(T) Step 5
      ANC=val(mid$(T,I,4))
      Call SASIGNADA([M:ZGOFS4]SASIGNADA(F),M)  # En [M:ZGOFS4]SASIGNADA(F) estß la fila correspondiente al Jumbo asignado
      L=val(M(0))-1
      # En los jumbos el precio es PRECIO/KG, lo convertimos a PRECIO/M2
      # De haber varios jumbos, nos quedamos con el precio del 1║
      PREC=([M:ZGOFS4]SPRECIO(L)*[M:ZGOFS4]QTYSTU(L))/([M:ZGOFS4]SANCHO(L)*[M:ZGOFS4]SLARGO(L)/1000)       
      IMP+=(LAR*ANC/1000)*PREC
    Next
  Endif
Next
End IMP


Subprog PASAR_JUMBOS
Local Integer L,F,A,Q,RQ
Local Integer LONG_TOT,LAR,LNG,RESTO_BOB, PDTE_BOB_ANT
Local Integer USADO_TOT  # USADO_TOT   =  Largo usado total
Local Integer USADO_EMP  # USADO_EMP   =  Largo usado de bobinas empalmadas
Local Integer USADO_BOB  # USADO_BOB   =  Largo usado de bobina en la que estemos....Si no se empalma entonces  USA_TOT = USA_BOB
Local Integer AR # Para saber fila que tendrß 2 jumbos por empalmes...Solo se contempla un mßximo de 2 jumbos
# Borrar rejilla
Raz [M:ZGOFS4]NMAT
Effzo [M:ZGOFS4]5
LAR=func SPEZGOFS1.LARGO_SEL
#LONG_TOT=LAR*[M:ZGOFS4]NSUG
# Pasar jumbos y marcarlos por FIFO + Long.....Rejilla ordenada por Ancho + FIFO + Long
# Damos la opcion de que se pueda variar   SEL + EMPALMAR

# Recorrer rejilla opcion sugerida, la cual estß ordenada por ANCHO_JUMBO + COMBINACION
# Para contemplar caso de que haya varios anchos de jumbo implicados

# LONG_TOT    =  Largo total x ancho de jumbo
For Q=0 To [M:ZGOFS4]NSUG-1
  If RQ<>[M:ZGOFS4]SANCHOJ(Q)
    RQ=[M:ZGOFS4]SANCHOJ(Q)
    LONG_TOT=func PASAR_JUMBOS_LONG_JUMBO(RQ,LAR)
    #
    Raz USADO_TOT, RESTO_BOB, PDTE_BOB_ANT, USADO_BOB, USADO_EMP
    A =-1  # Para recorrer rejilla opciones sugeridas
    AR=-1
    For F=0 To [M:ZGOFS1]NSTO-1
      #Paso los seleccionados
      If [M:ZGOFS1]SSEL(F)=2 and [M:ZGOFS1]SANCHO(F)=RQ
        # Determino cantidad de bobina usar. Cada fila serß de la longitud indicada = LAR
        # Me situo en primera fila de combinaciones, cuyo ancho de jumbo sea el indicado RQ
        A+=1
        While A<=[M:ZGOFS2]NSUG-1 and [M:ZGOFS4]SANCHOJ(A)<>RQ
          A+=1
        Wend
        #
        If [M:ZGOFS1]EMPALMAR(F)<>2
          USADO_EMP=0
        Endif
        USADO_BOB=0
        LNG=LAR+PDTE_BOB_ANT
        While A<=[M:ZGOFS2]NSUG-1 and [M:ZGOFS4]SANCHOJ(A)=RQ  and [M:ZGOFS4]SASIGNADA(A)=0  and USADO_TOT+LNG<=LONG_TOT and USADO_EMP+LNG<=[M:ZGOFS1]SLARGOC(F)## and USADO_BOB+LNG<=[M:ZGOFS1]SLARGO(F)
          [M:ZGOFS4]SASIGNADA(A)=[M:ZGOFS4]NMAT+1  # N║ fila correspondiente al jumbo en el que se ha incluido
          Affzo [M:ZGOFS4]SASIGNADA(A)
          # A±ado n║ fila jumbo en caso de que haya una 2¬ jumbo, es decir, por empalmes. Solo contemplamos un mßximno de 2 bobinas por Grupo de corte
          If PDTE_BOB_ANT>0 and [M:ZGOFS4]SASIGNADA(AR)<100
            [M:ZGOFS4]SASIGNADA(AR)=[M:ZGOFS4]SASIGNADA(AR)*100 + ([M:ZGOFS4]NMAT+1)
            Affzo [M:ZGOFS4]SASIGNADA(AR)
          Endif
          RESTO_BOB=[M:ZGOFS1]SLARGO(F)-USADO_BOB-PDTE_BOB_ANT
          If RESTO_BOB>LNG
            USADO_TOT+=LNG
            USADO_BOB+=LNG
            USADO_EMP+=LNG
            PDTE_BOB_ANT  =0
            AR=-1
            A+=1
          Else
  #          Infbox "Empalme"
            USADO_TOT+=RESTO_BOB
            USADO_BOB+=RESTO_BOB
            USADO_EMP+=RESTO_BOB
            PDTE_BOB_ANT  =LNG-RESTO_BOB
            AR=A
            A+=1
            Break
          Endif
          LNG=LAR+PDTE_BOB_ANT
        Wend
        A-=1
        If  USADO_BOB=0 and PDTE_BOB_ANT>0
          USADO_BOB=PDTE_BOB_ANT
          PDTE_BOB_ANT=0
          If [M:ZGOFS4]SASIGNADA(AR)<100
            [M:ZGOFS4]SASIGNADA(AR)=[M:ZGOFS4]SASIGNADA(AR)*100 + ([M:ZGOFS4]NMAT+1)
            Affzo [M:ZGOFS4]SASIGNADA(AR)
          Endif
        Endif
        If USADO_BOB>0
          L=[M:ZGOFS4]NMAT
          If USADO_BOB>0
            [M:ZGOFS4]SSEL(L)     =2
          Endif
          [M:ZGOFS4]EMPALMAR(L)   =[M:ZGOFS1]EMPALMAR(F)
          [M:ZGOFS4]SANCHO(L)     =[M:ZGOFS1]SANCHO(F)
          [M:ZGOFS4]SLARGO(L)     =[M:ZGOFS1]SLARGO(F)
          [M:ZGOFS4]SLARGOC(L)    =[M:ZGOFS1]SLARGOC(F)
          [M:ZGOFS4]SFIFO(L)      =[M:ZGOFS1]SFIFO(F)
          [M:ZGOFS4]SUSADO(L)     =USADO_BOB
          [M:ZGOFS4]SRESTO(L)     =[M:ZGOFS4]SLARGO(L)-[M:ZGOFS4]SUSADO(L)
      #    [M:ZGOFS4]SMERMA(L)     =0
          [M:ZGOFS4]SPRECIO(L)    =[M:ZGOFS1]SPRECIO(F)
          [M:ZGOFS4]SIMPORTE(L)   =arr((([M:ZGOFS4]SUSADO(L)*[M:ZGOFS1]QTYSTU(F)) /[M:ZGOFS1]SLARGO(F))*[M:ZGOFS4]SPRECIO(L),0.0001) #([M:ZGOFS4]SANCHO(L)*[M:ZGOFS4]SUSADO(L)/1000)*[M:ZGOFS4]SPRECIO(L)
          [M:ZGOFS4]SLOTE(L)      =[M:ZGOFS1]SLOTE(F)
          [M:ZGOFS4]SSLOTE(L)     =[M:ZGOFS1]SSLOTE(F)
          [M:ZGOFS4]QTYSTU(L)     =[M:ZGOFS1]QTYSTU(F)
          [M:ZGOFS4]STU(L)        =[M:ZGOFS1]STU(F)
          [M:ZGOFS4]STOCOU(L)     =[M:ZGOFS1]STOCOU(F)
          [M:ZGOFS4]SMANDRIL(L)   =[M:ZGOFS1]SMANDRIL(F)
          [M:ZGOFS4]ZPROVEEDOR(L) =[M:ZGOFS1]ZPROVEEDOR(F)
          [M:ZGOFS4]ZFACTOR(L)    =[M:ZGOFS1]ZFACTOR(F)
          [M:ZGOFS4]NMAT+=1
          # Nos salimos en cuanto alcanzemos la longitud del ancho en el que estemos
          If USADO_TOT=LONG_TOT
            Break
          Endif
        Endif
      Endif
    Next
  Endif
Next
Affzo [M:ZGOFS4]5
End

Funprog PASAR_JUMBOS_LONG_JUMBO(RQ,LAR)
Value Integer RQ,LAR
Local Integer F,L
Raz L
For F=0 To [M:ZGOFS4]NSUG-1
  If [M:ZGOFS4]SANCHOJ(F)=RQ
    L+=1
  Endif
Next
End L*LAR


Subprog MOSTRAR_OF
Local Integer I0     
Local Integer RJ    # Para controlar el ancho de jumbo con el que trabajo...pueden haber diferentes en la OF cuando marcamos opcion Combinar jumbos
Local Integer GC    # Para ir numerando los Grupos de Corte
Local Integer FILAS # Saber cuantas repeticiones hay de la combinacion (D)
Local Char D(255)   # Monto la combinacion de la opcion  (Pedidos + Stock)
Local Char RD(255)  # Saber cuando cambia la combinaci¾n
Local Char M(10)(2),MP(255)  # Para guardar la asignacion de Materia Prima
# Para guardarme anchos de pedidos, para llevar un control al asignarlos a pedidos
Local Integer Z   :   Z=-1
Local Char RDP(4)(0..)

# Recorremos la rejilla, que estß ordenada por SANCHOJ+SCOMBIS    SCOMBIS = SCOMBI+SANADIR ordenadas por anchos
Raz RD,RDP,MP,FILAS,RJ,GC
For F=0 To [M:ZGOFS4]NSUG-1
  D=[M:ZGOFS4]SCOMBIS(F)
#  D=[M:ZGOFS4]SCOMBI(F)
#  If [M:ZGOFS4]SANADIR(F)<>""
#    If D<>"":D+="-":Endif
#    D+=[M:ZGOFS4]SANADIR(F)
#  Endif
  If RD<>D or RJ<>[M:ZGOFS4]SANCHOJ(F)
    Gosub ANADIR_GC
    RD=D
    RJ=[M:ZGOFS4]SANCHOJ(F)
    Raz RDP, MP
    Z=-1
  Endif
  # cuento filas iguales para determinar <<Repeticiones largo>>
  FILAS+=1
  # Acumulo anchos de pedidos, para llevar un control al asignarlos a pedidos
  If [M:ZGOFS4]SCOMBI(F)<>""
#    If RDP<>"":RDP+="-":Endif
#    RDP+=[M:ZGOFS4]SCOMBI(F)
    For I0=1 To len([M:ZGOFS4]SCOMBI(F)) Step 5
      Z+=1
      RDP(Z)=mid$([M:ZGOFS4]SCOMBI(F),I0,4)
    Next
  Endif
  # Acumulo asignaciones de Materia Prima
  Call SASIGNADA([M:ZGOFS4]SASIGNADA(F),M)
  If instr(1,MP,M(0))<1 and M(0)<>""
    If MP<>"" : MP+="-" : Endif
    MP+=M(0)
  Endif
  If instr(1,MP,M(1))<1 and M(1)<>""
    If MP<>"" : MP+="-" : Endif
    MP+=M(1)
  Endif
Next F
Gosub ANADIR_GC
Affzo [M:ZGOFS4]25 # GC
Affzo [M:ZGOFS4]15 # Pedidos
Affzo [M:ZGOFS4]5  # Materia prima
End


$ANADIR_GC
#If GUSER<>"ADMIN":End:Endif
Local Integer ANC(50),ANCR(50),ANCP(50),ANCRP(50),BOBIBP
Local Integer I,A,NA,NAPP,ESTA,ELE,LAR,LAR_R,PDTE_GC
If RD="": Return : Endif
Raz ANC,ANCR,NA
Raz ANCP,ANCRP,NAPP
LAR=func LARGO
# Acumular n║ de veces que aparece el ancho en la combinacion, para determinar <<Repeticiones Ancho>>
Call CONTAR_ANCHOS_COMB  (RD,5,ANC ,ANCR ,NA)
Call CONTAR_ANCHOS_COMB_M(RDP ,ANCP,ANCRP,NAPP)
# Montar GC, donde habrß tantas lineas como (Anchos+Largos) haya
GC+=1
For A=0 To NA-1
  Call DETERMINAR_BOB_PED(ANC(A),ANCR(A),ANCP,ANCRP,BOBIBP)
  Call ANADIR_GC_MARCAR_PED (ANC(A),ANCR(A),LAR,RD,RJ,FILAS,GC,BOBIBP,MP)
#  JLPR 25.10   Lo comento, pues habrß una sola linea por Ancho+Largo, indicando el stock en la columna GBOBSTK=Total bobinas-Bobinas asignadas a pedidos
#  # Despues de asignar contra pedidos, lo que quede sera STOCK / anchos A
#  PDTE_GC= func ANADIR_GC_PDTE(GC,ANC(A),ANCR(A)*FILAS,LAR)
#  If PDTE_GC>0
#    # Determinar forma de a±adir el stock = "AnchosA+Anchos sin pedidos a±adidos manualmente)
#    Local Integer P_DIVRA
#    If PDTE_GC=ANCR(A)*FILAS
#      P_DIVRA=ANCR(A)
#    Else
#      P_DIVRA=int(PDTE_GC/ANCR(A))
#      If P_DIVRA>=ANCR(A)
#        P_DIVRA=ANCR(A)
#      Endif
#    Endif
#    Local Integer P_DIVRL
#    P_DIVRL=1
#    If P_DIVRA>0
#      P_DIVRL=int(PDTE_GC/P_DIVRA)
#    Endif
#    # Determinar largo restante para el GC y Ancho
#    LAR_R=func LARGO_RESTO(GC,ANC(A),ANCR(A),LAR)
#    # A±adir Resto, en caso de que no sea multiplo  Ej Pdte.Bob=7, con un divisor de 4 (250x4=1000), se quedaria un resto de 3 + 1 fila x 4
#    Local Integer P_RESTA
#    P_RESTA=PDTE_GC-(P_DIVRA*P_DIVRL)
#    If P_RESTA>0
#      FILAS=1
#      Call ANADIR_GC_FILA (ANC(A),P_RESTA,LAR,GC,RD,RJ,LAR_R,FILAS,-1,FILAS*P_RESTA)
#    Endif
#    # A±adir filas completas
#    If P_DIVRA*P_DIVRL>0
#      FILAS=P_DIVRL
#      Call ANADIR_GC_FILA (ANC(A),P_DIVRA,LAR,GC,RD,RJ,LAR_R,FILAS,-1,FILAS*P_DIVRA)
#    Endif
#    # Ajustar filas seg·n cantidad bobinas asignadas
#    Call ANADIR_GC_AJUSTAR_CANT_GC_CON_PEDIDOS(GC,LAR,ANC(A),ANCR(A))
#  Endif
  PDTE_GC= func ANADIR_GC_PDTE(GC,ANC(A),ANCR(A)*FILAS,LAR)
  If PDTE_GC>0
    # Estamos en el caso de que todas las bobinas de un ancho son para stock, pues de lo contrario, se habrĒa a±adido fila con los pedidos
    Call ANADIR_GC_FILA (ANC(A),ANCR(A),LAR,GC,RD,RJ,LAR,FILAS,-1,PDTE_GC,MP)
  Endif
Next
#
FILAS=0
Return

Subprog CONTAR_ANCHOS_COMB(RD,L,ANC,ANCR,NA)
Value Char RD
Value Integer L
Variable Integer ANC,ANCR,NA
Local Integer I,ELE  #,ESTA,A
Raz ANC,ANCR
# Acumular n║ de veces que aparece el ancho en la combinacion, para determinar <<Repeticiones Ancho>>
# Siempre se combina de 4 en 4 en alguna de las siguientes 2 formas
# Forma 1 025003001000
# Forma 2 0250-0300-1000
For I=1 To len(RD) Step L #5
  ELE=val(mid$(RD,I,4))
  Call CONTAR_ANCHOS_COMB_ANADIR(ELE,ANC,ANCR,NA)
#  ESTA=0
#  For A=0 To NA-1
#    If ANC(A)=ELE
#      ESTA=1
#      ANCR(A)+=1
#    Endif
#  Next
#  If not ESTA
#    ANC(NA)=ELE
#    ANCR(NA)=1
#    NA+=1
#  Endif
Next
End

Subprog CONTAR_ANCHOS_COMB_M(RD,ANC,ANCR,NA)
Value Char RD
Variable Integer ANC,ANCR,NA
Local Integer I
For I=0 To dim(RD)-1
  If RD(I)=""
    Break
  Else
    Call CONTAR_ANCHOS_COMB_ANADIR(val(RD(I)),ANC,ANCR,NA)
  Endif
Next
End

Subprog CONTAR_ANCHOS_COMB_ANADIR(ELE,ANC,ANCR,NA)
Value Integer ELE
Variable Integer ANC,ANCR,NA
Local Integer ESTA,A
ESTA=0
For A=0 To NA-1
  If ANC(A)=ELE
    ESTA=1
    ANCR(A)+=1
  Endif
Next
If not ESTA
  ANC(NA)=ELE
  ANCR(NA)=1
  NA+=1
Endif
End

