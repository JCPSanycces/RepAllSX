Funprog ANADIR_GC_PDTE(GC,ANC,ANCR,LAR)
Value Integer GC,ANC,ANCR,LAR
Local Integer PDTE,BOB
Raz BOB
# Determino cantidad bobinas asignadas
For I=0 To [M:ZGOFS4]NGRC-1
  If [M:ZGOFS4]GRUPOC(I)=GC and [M:ZGOFS4]GANCHO(I)=ANC
    BOB+= (func SUMAR_DET([M:ZGOFS4]GPEDB(I),4) / int((LAR/[M:ZGOFS4]GLARGO(I))))
  Endif
Next
PDTE=ANCR-BOB
End PDTE

Subprog ANADIR_GC_MARCAR_PED(ANC,ANCR,LAR,RD,RJ,FILAS,GC,BOBIBP,MP)
Value Integer ANC,ANCR,LAR,RJ,FILAS,GC,BOBIBP
Value Char RD,MP
Local Integer F,PDTE_PED
For F=0 To [M:ZGOFS4]NCTE-1
  # Sacar pedidos pdtes del ancho indicado...Rejilla ordenada por    (ITM+Largo+Ancho)
  PDTE_PED=[M:ZGOFS4]PBOBINASOF(F)-func SUMAR_DET([M:ZGOFS4]PGCBOB(F),4)
  If PDTE_PED>BOBIBP:      PDTE_PED=BOBIBP   :     Endif
  If [M:ZGOFS4]PANCHO(F)=ANC and PDTE_PED>0
    Call ANADIR_GC_FILA (ANC,ANCR,LAR,GC,RD,RJ,[M:ZGOFS4]PLARGO(F),FILAS,F,PDTE_PED,MP)
    BOBIBP-=PDTE_PED
  Endif
Next
#Call ANADIR_GC_AJUSTAR_CANT_GC_CON_PEDIDOS(GC,LAR,ANC,ANCR)
End


Subprog ANADIR_GC_FILA(ANC,ANCR,LAR,GC,RD,RJ,LAR_PED,FILAS,F,PDTE_PED,MP)
Value Integer ANC,ANCR,LAR,GC,RJ,LAR_PED,FILAS,F,PDTE_PED
Value Char RD,MP
Local Integer I,L,EXISTE,LARPR

LARPR=int(LAR/LAR_PED) # Si LARPR>1 el largo del pedido es un multiplo del largo seleccionado para la OF

# Ver si existe GC+Ancho+Lng
EXISTE=0
For I=0 To [M:ZGOFS4]NGRC-1
  If [M:ZGOFS4]GRUPOC(I)=GC and   [M:ZGOFS4]GANCHO(I)=ANC
#    If [M:ZGOFS4]GLARGO(I)=LAR_PED and (F>0 or (F=-1 and [M:ZGOFS4]GPEDF(I)="000"))
    If [M:ZGOFS4]GLARGO(I)=LAR_PED
      EXISTE =1
      Break
    Endif
  Endif
Next
# A±adir si no existe. Ancho + Largo seleccionado........Largos inferiores se a±aden
If not EXISTE
  I=[M:ZGOFS4]NGRC
  [M:ZGOFS4]GRUPOC(I)  =GC
  [M:ZGOFS4]GANCHO(I)  =ANC
  [M:ZGOFS4]GANCHOR(I) =ANCR
  [M:ZGOFS4]GLARGO(I)  =LAR_PED
  [M:ZGOFS4]GLARGOR(I) =FILAS*LARPR
  [M:ZGOFS4]GCANT(I)   =[M:ZGOFS4]GANCHOR(I)*[M:ZGOFS4]GLARGOR(I)
  #
  [M:ZGOFS4]GLARGOT(I) =(LAR_PED*LARPR)
  [M:ZGOFS4]GLARGOD(I) =LAR-GLARGOT(I)
  #
  [M:ZGOFS4]GANCHOT(I) = func SUMAR_DET(RD,5)
  [M:ZGOFS4]GANCHOD(I) =RJ-GANCHOT(I)
  [M:ZGOFS4]GJUMF(I)   =MP
  [M:ZGOFS4]NGRC+=1
Endif
# Ver si tengo bobinas por asignar del GC
PDTE_GC= [M:ZGOFS4]GCANT(I) - func SUMAR_DET([M:ZGOFS4]GPEDB(I),4)
If PDTE_GC>0
  # Determinar bobinas
  If PDTE_PED<=PDTE_GC # (ANCR*LARPR*FILAS)
    BOB=PDTE_PED
  Else
    BOB=PDTE_GC # (ANCR*LARPR*FILAS)
  Endif
  # Actualizar en rejilla GC   -  Bobinas asignadas
  If [M:ZGOFS4]GPEDB(I)<>""
    [M:ZGOFS4]GPEDB(I)+="-"
  Endif
  [M:ZGOFS4]GPEDB(I)+=format$("N0:3",BOB)
  # Actualizar en rejilla GC   -  Pedidos asignados (N║ fila)
  If [M:ZGOFS4]GPEDF(I)<>""
    [M:ZGOFS4]GPEDF(I)+="-"
  Endif
  [M:ZGOFS4]GPEDF(I)+=format$("N0:3",F+1)
  # Indicar bobinas stock
  If F<0
    [M:ZGOFS4]GBOBSTK(I)=BOB
  Endif

  If F>=0
    # Marcar en rejilla pedidos  -  GC
    If [M:ZGOFS4]PGC(F)<>""
      [M:ZGOFS4]PGC(F)+="-"
    Endif
    [M:ZGOFS4]PGC(F)+=format$("N0:3",GC)
    # Marcar en rejilla pedidos  -  GC Bobinas asignadas
    If [M:ZGOFS4]PGCBOB(F)<>""
      [M:ZGOFS4]PGCBOB(F)+="-"
    Endif
    [M:ZGOFS4]PGCBOB(F)+=format$("N0:3",BOB)
  Endif
Endif
End

Subprog DETERMINAR_BOB_PED(ANC,ANCR,ANCP,ANCRP,BOBIBNASP)
Value Integer ANC,ANCR,ANCP,ANCRP
Variable Integer BOBIBNASP
Local Integer F
Raz BOBIBNASP
# Cuando el ancho que estoy montando coincida con el ancho de los pedidos, me quedo con las bobinas de los pedidos
For F=0 To dim(ANCP)-1
  If ANCP(F)=ANC
    BOBIBNASP=ANCRP(F)
    Break
  Endif
Next
End

Funprog SUMAR_DET(T,L)
Value Char T  #   Ej. T    001-002-003......n║ bobinas asignadas en el GC indicado
Value Integer L  #   Longitud a sumar  Ej. 4, se asume que vienen separados por -
Local Integer I,B
Raz B
For I=1 To len(T) Step L
  B+=val(mid$(T,I,L-1))
Next
End B

Funprog LARGO
Local Integer LAR
LAR=[M:ZGOFS4]SLARGOB(0)
If LAR=0
  LAR= [M:ZGOFS2]LLARGO(0)
Endif
End LAR

Funprog BOBINAS_PDTE(LAR,ANC,CANT)
Value Integer LAR,ANC,CANT
Local Integer PDTE,F,PDTO
Raz PDTE
# Buscar en rejilla si quedan bobinas pdtes de fabricar, pendientes de descontar de pedidos
For F=0 To [M:ZGOFS3]NLNG-1
  If [M:ZGOFS3]LARGO(F)=LAR and [M:ZGOFS3]ANCHO(F)=ANC
    PDTO=[M:ZGOFS3]CANTP(F) - [M:ZGOFS3]CANTPDTO(F)
    If PDTO>0
      If CANT>PDTO
        PDTE=PDTO
      Else
        PDTE=CANT
      Endif
      # Actualizo rejilla con cantidad descontada
      [M:ZGOFS3]CANTPDTO(F)+=PDTE
    Endif
    Break
  Endif
Next
End PDTE

Subprog SASIGNADA(V,M)
Value Integer V
Variable Char M
Raz M
If V<100
  M(0)=format$("N0:3",V)
Else
  M(0)=format$("N0:3",int(V/100))
  M(1)=format$("N0:3",V- val(M(0))*100)
Endif
End


Funprog JUMBOS_SIN_EMPALMAR
Local Char TXT(255)
Local Integer F,RJ
Local Integer NF # n║ filas con sobrante
Raz TXT,RJ,NF
For F=0 To [M:ZGOFS4]NMAT-1
  If RJ<>[M:ZGOFS4]SANCHO(F)
    If NF>1
      If TXT<>"" :  TXT+="\"  :  Endif
      TXT+=num$(RJ) + " hay "+num$(NF)+" jumbos con sobrante"
    Endif
    RJ=[M:ZGOFS4]SANCHO(F)
    Raz NF
  Endif
  If [M:ZGOFS4]SRESTO(F)>0
    NF+=1
  Endif
Next
If NF>1
  If TXT<>"" :  TXT+="\"  :  Endif
  TXT+=num$(RJ) + " hay "+num$(NF)+" jumbos con sobrante"
Endif
If TXT<>""
  TXT="Estß seguro de NO EMPALMAR estos jumbos, para evitar el tener tantos trozos\"+TXT
Endif
End TXT

Funprog GC_EXCEDIDOS
Local Integer F,J,N
Raz N
For F=0 To [M:ZGOFS4]NSUG-1
  For J=0 To [M:ZGOFS2]NJUM-1
    If [M:ZGOFS4]SANCHOJ(F)=[M:ZGOFS2]JANCHO(J) and [M:ZGOFS4]SDIFA(F)> [M:ZGOFS2]JMERMAC(J)
      N+=1
    Endif
  Next
Next
End N


Subprog VACIAR_REJILLAS
Raz [M:ZGOFS4]
Effzo [M:ZGOFS4]5
Effzo [M:ZGOFS4]15
Effzo [M:ZGOFS4]20
Effzo [M:ZGOFS4]25
Raz [M:ZGOFS4]LNGSEL, [M:ZGOFS4]LNGUSA, [M:ZGOFS4]LNGMER, [M:ZGOFS4]LNGRES
Affzo [M:ZGOFS4]LNGSEL
Affzo [M:ZGOFS4]LNGUSA
Affzo [M:ZGOFS4]LNGMER
Affzo [M:ZGOFS4]LNGRES
Raz [M:ZGOFS4]M2SEL , [M:ZGOFS4]M2USA , [M:ZGOFS4]M2MER , [M:ZGOFS4]M2RES
Affzo [M:ZGOFS4]M2SEL
Affzo [M:ZGOFS4]M2USA
Affzo [M:ZGOFS4]M2MER
Affzo [M:ZGOFS4]M2RES
Raz [M:ZGOFS4]KGSSEL, [M:ZGOFS4]KGSUSA, [M:ZGOFS4]KGSMER, [M:ZGOFS4]KGSRES
Affzo [M:ZGOFS4]KGSSEL
Affzo [M:ZGOFS4]KGSUSA
Affzo [M:ZGOFS4]KGSMER
Affzo [M:ZGOFS4]KGSRES
Raz [M:ZGOFS4]IMPPED, [M:ZGOFS4]IMPUSA, [M:ZGOFS4]IMPMER, [M:ZGOFS4]IMPMARGEN
Affzo [M:ZGOFS4]IMPPED
Affzo [M:ZGOFS4]IMPUSA
Affzo [M:ZGOFS4]IMPMER
Affzo [M:ZGOFS4]IMPMARGEN
End

