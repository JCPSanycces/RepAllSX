#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "DEBUT":         Case GACTION
                              When "SAIMFGALL" : Gosub DEBUT_MFGALL
                          Endcase
    When Default
Endcase
Return

$DEBUT_MFGALL
#FJCP - Inicio
# Se asume que solo hay un componente
 If [M:MFG2]ZFABCOR(0)<>2
  Return
 Endif
Local Decimal LNG
LNG=[M:MFG2]ZLONGITUD(0)
Call AM_ZLONGITUD(LNG) From SPEMFG2
#FJCP - Fin

Return
