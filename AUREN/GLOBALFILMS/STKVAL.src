################################################################################
# ECRTRACE : Ecriture dans le fichier de trace ouvert selon paramÃĻtre stock STOTRACE
#            ( Cf. ECR_TRACE de GESECRAN )
#            !!!!!!! UtilisÃĐe dans STKVAL et SUBCGVB !!!!!!!!!
################################################################################
# PMES : Message Ã  enregistrer
# PERR : Code message (0=info , 1=Erreur)
################################################################################
Subprog ECRTRACE( PMES, PERR )
Value Char PMES
Value Integer PERR
    If GTRACE<>""
&    & (  GSTOTRACE=2 & PERR=1
&       | GSTOTRACE>2 )
        Call ECR_TRACE( PMES, PERR ) From GESECRAN
    Endif
End

########################################################################
# DEFCPR         Routine calcul prix de revient pour calcul marge
########################################################################
# ParamÃĻtres E : LITM       = RÃĐfÃĐrence article
#                LFCY       = Site de stock
#                LVCRTYP    = Type de document (menu local 701)
#                LVCRNUM    = No de document
#                LVCRLIN    = No de ligne
#                LNOL       = No ligne ÃĐcran (nolign-1) uniquement si avoir
#                LDAT       = Date de rÃĐfÃĐrence
#                LQTE       = QuantitÃĐ pour sorties FIFO (>0)
#            S : LPRI       = Prix du mouvement
#                LRET       = Code retour (0=Ok, 1=Erreur dans le calcul)
#                                                2=Article-site non trouvÃĐ !)
#                                                3=MÃĐthode valorisation non trouvÃĐe !)
#                                                4=Prix nul non autorisÃĐ !)
########################################################################
Subprog DEFCPR(LITM,LFCY,LVCRTYP,LVCRNUM,LVCRLIN,LNOL,LDAT,LQTY,LPRI,LRET)
Value    Char    LITM
Value    Char    LFCY
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LNOL
Value    Date    LDAT
Value    Decimal LQTY
Variable Decimal LPRI
Variable Integer LRET

#----- Variables locales -----#
Local    Libelle WVLT, WVLT2
Local    Integer WMET, WVCRTYP, WVCRLIN, WWSTOSEQ
Local    Char LTCM(GLONTCM), WVCRNUM(GLONVCR)
Local    Integer LACTDECCST : LACTDECCST = func ASYRFNC.ACTIV("SPD")

#-----
Raz LPRI, LRET
#----- Par sÃĐcuritÃĐ, ne devrait pas ÃŠtre nÃĐcessaire -----#
If !clalev([F:TCM])  Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF] : Endif
If !clalev([F:ITM])  Local File ITMMASTER  [ITM] : Endif
If !clalev([F:TCU])  Local File TABCUR     [TCU] : Endif
#----- Lecture article-site si nÃĐcessaire -----#
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
  Read [ITF] ITF0=LITM;LFCY
  If fstat  LRET=2 : End : Endif
Endif

If [F:ITM]ITMREF<>LITM
  Read [ITM] ITM0=LITM
  If fstat  LRET=2 : End : Endif
Endif

#----- Lecture table mÃĐthode de valorisation -----#
Call GETTCM(LITM, LFCY, LTCM, LRET)
If LRET | LTCM="" : End : Endif

[L]WVLT =[F:TCM]PFMCLCBAS
[L]WVLT2=[F:TCM]PFMCLC2

#These functions have been converted to use full Syracuse mode
# need to instantiate the class and then copy from class back to mask at the end
Local Instance STKVAL Using C_STKVAL
STKVAL = NewInstance C_STKVAL AllocGroup null

#----- Calcul prix avec le code valorisation -----#
[L]WMET = [L]WVLT
Case [L]WVLT
  When 1 : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,"","",LDAT,0,0)     # Standard
  When 2 : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,"","",LDAT,0,0) # Revised Standard
  When 3 : LPRI = fmet STKVAL.GET_LAST_PRICE(LITM,LFCY)                       # Last price
  When 4 : LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)                              # Average Cost
  When 5 : LPRI = fmet STKVAL.GET_FIFO(LITM,LFCY,LQTY,0)                      # FIFO
  When 6 :                    # Prix moyen lot
           If [F:ITM]LOTMGTCOD = 1 # Issue X3-140484 - 2019-05-31 by SGE : If product not lot-managed, go back to average cost calculation.
             LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)
           Elsif LVCRTYP=5 & dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2
             Case [M:SIH1]SIHORI
                When 1 : # Avoir direct, avec mvt stock et article gÃĐrÃĐ en stock
                         If [M:SIH1]STOMVTFLG=2 & [M:SIH4]STOMGTCOD(LNOL)>1
                           Gosub TRT_PMLOT_ENTW
                         Endif
                When 4 : # Avoir sur facture, avec mvt stock et flag retour stock
                         If [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(LNOL)=2
                           Gosub TRT_PMLOT_ENTW
                         Endif
                When 6 : # Avoir sur retour (ligne directe ou non)
                         If [M:SIH4]SRHNUM(LNOL)=""
                           Gosub TRT_PMLOT_ENTW
                         Else
                             WVCRTYP = 13
                             WVCRNUM = [M:SIH4]SRHNUM(LNOL)
                             WVCRLIN = [M:SIH4]SRDLIN(LNOL)
                             Gosub TRT_PMLOT_STJ
                         Endif
             Endcase
           Elsif LVCRNUM<>"" & LVCRLIN<>0 & LNOL<0
               Gosub TRT_PMLOT
           Else
               Gosub TRT_PMLOT_SOW
           Endif
  When 8 : LPRI = fmet STKVAL.GET_LIFO(LITM,LFCY,LQTY,0)                      # LIFO
  When 9 : LPRI = fmet STKVAL.GET_LAST_PUR(LITM,LFCY)                         # Last purchase price

Endcase
# CCC (21/01/08) Bug 45080 : S'il n'y a pas assez de stock en FIFO, ou que le coÃŧt standard n'est pas dÃĐfini pour la date...
# Ce n'est pas la peine de dÃĐclencher une erreur en calcul de marge (utilisÃĐ en commande) on utilise donc la valeur de repli
#If LRET<>0  End : Endif
If LRET : LRET=0 : Endif

#----- Si prix nul, calcul prix avec le code valorisation repli -----#
If LPRI=0
  [L]WMET = [L]WVLT2
  Case [L]WMET
    When 1 : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,"","",LDAT,0,0)     # Standard
    When 2 : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,"","",LDAT,0,0) # Revised Standard
    When 3 : LPRI = fmet STKVAL.GET_LAST_PRICE(LITM,LFCY)                       # Last price
    When 4 : LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)                              # Average Cost
    When 5 : LPRI = fmet STKVAL.GET_FIFO(LITM,LFCY,LQTY,0)                      # FIFO
    When 6 :                    # Prix moyen lot
             If [F:ITM]LOTMGTCOD = 1 # Issue X3-140484 - 2019-05-31 by SGE : If product not lot-managed, go back to average cost calculation.
               LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)
             Elsif LVCRTYP=5 & dim([M:SIH0]INVTYP)>0 & [M:SIH0]INVTYP=2
               Case [M:SIH1]SIHORI
                  When 1 : # Avoir direct, avec mvt stock et article gÃĐrÃĐ en stock
                           If [M:SIH1]STOMVTFLG=2 & [M:SIH4]STOMGTCOD(LNOL)>1
                             Gosub TRT_PMLOT_ENTW
                           Endif
                  When 4 : # Avoir sur facture, avec mvt stock et flag retour stock
                           If [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(LNOL)=2
                             Gosub TRT_PMLOT_ENTW
                           Endif
                  When 6 : # Avoir sur retour (ligne directe ou non)
                           If [M:SIH4]SRHNUM(LNOL)=""
                             Gosub TRT_PMLOT_ENTW
                           Else
                             WVCRTYP = 13
                             WVCRNUM = [M:SIH4]SRHNUM(LNOL)
                             WVCRLIN = [M:SIH4]SRDLIN(LNOL)
                             Gosub TRT_PMLOT_STJ
                           Endif
               Endcase
             Elsif LVCRNUM<>"" & LVCRLIN<>0 & LNOL<0
                Gosub TRT_PMLOT
             Else
                Gosub TRT_PMLOT_SOW
             Endif
    When 8 : LPRI = fmet STKVAL.GET_LIFO(LITM,LFCY,LQTY,0)                      # LIFO
    When 9 : LPRI = fmet STKVAL.GET_LAST_PUR(LITM,LFCY)                         # Last purchase price
  Endcase
Endif

# Copy back from the class to the mask if it exists
If clalev([M:SDP])
  # Copy the data back from the class to the screen
  Call COPYSTKVAL_SDP(STKVAL,"SDP")
Endif
FreeGroup STKVAL
STKVAL = null

End

#----------------------------------------------------#
# Calcul du prix moyen lot Ã  partir des allocations  #
#----------------------------------------------------#
$TRT_PMLOT
Local    Decimal WQTY, WMNT
Raz WQTY, WMNT

If !clalev([F:STA])  Local File STOALL [STA] : Endif
If !clalev([F:STO])  Local File STOCK  [STO] : Endif

# On vÃĐrifie qu'il existe des allocations
Filter [STA] Where VCRTYP=LVCRTYP & VCRNUM=LVCRNUM
&                 & VCRLIN=LVCRLIN & ALLTYP=2
&                 & ITMREF=LITM
Look [STA]STA1 First
If !fstat
    For [STA]STA1
       # Lecture du stock
       Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
       If !fstat
          LLOT = [F:STO]LOT
          LSLO = [F:STO]SLO
          LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)
          If LRET=0
             WMNT += LPRI*[F:STA]QTYSTU
             WQTY += [F:STA]QTYSTU
          Endif
       Endif
    Next
Else
    # sinon, cela veut dire que le doc est validÃĐ => on cherche dans les stojou
    WVCRTYP = 0
    WVCRNUM = LVCRNUM
    WVCRLIN = LVCRLIN
    Gosub TRT_PMLOT_STJ
Endif
Filter [STA]
If WQTY<>0 LPRI=WMNT/WQTY Endif
Return

#----------------------------------------------------#
# Calcul du prix moyen lot Ã  partir des mouvements   #
#----------------------------------------------------#
$TRT_PMLOT_STJ
Local    Decimal WQTY, WMNT
Raz WQTY, WMNT

If !clalev([F:STJ])  Local File STOJOU [STJ] : Endif

For [STJ]STJ1 Where STOFCY=LFCY & (WVCRTYP=0 | VCRTYP=WVCRTYP) & VCRNUM=WVCRNUM
&                 & VCRLIN=WVCRLIN
&                 & ITMREF=LITM
   LLOT = [F:STJ]LOT
   LSLO = [F:STJ]SLO
   LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)
   If LRET=0
      WMNT += LPRI*[F:STJ]QTYSTU
      WQTY += [F:STJ]QTYSTU
   Endif
Next
If WQTY<>0 LPRI=WMNT/WQTY Endif
Return

#-----------------------------------------------------#
# Calcul du prix moyen lot Ã  partir de l'ÃĐcran [ENTW] #
#-----------------------------------------------------#
$TRT_PMLOT_ENTW
Local    Decimal WQTY, WMNT
Local    Integer I
Raz WQTY, WMNT

For I=0 To [M:ENTW]NBLIG-1
   # La ligne de l'ÃĐcran de travail concerne cette ligne de document
   If [M:ENTW]WSTOSEQ(I)=[M:SIH4]WSTOSEQ(LNOL)
      LLOT = [M:ENTW]LOT([M:ENTW]NUMLIGLOT(I))
      LSLO = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
      LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)
      If LRET=0
         WMNT += LPRI*[M:ENTW]QTYSTU(I)
         WQTY += [M:ENTW]QTYSTU(I)
      Endif
   Endif
Next
If WQTY<>0 LPRI=WMNT/WQTY Endif
Return

#-----------------------------------------------------#
# Calcul du prix moyen lot Ã  partir de l'ÃĐcran [ENTW] #
#-----------------------------------------------------#
$TRT_PMLOT_SOW
Local    Decimal WQTY, WMNT
Local    Integer I
Raz WQTY, WMNT

Raz WWSTOSEQ
If LVCRTYP=5 : WWSTOSEQ=[M:SIH4]WSTOSEQ(LNOL) : Endif
If LVCRTYP=4 : WWSTOSEQ=[M:SDH1]WSTOSEQ(LNOL) : Endif
If !clalev([F:STO]) : Local File STOCK [STO] : Endif

If WWSTOSEQ=0
    Return
Endif
For I=0 To [M:SOW]NBLIG-1
   # La ligne de l'ÃĐcran de travail concerne cette ligne de document
   If [M:SOW]WSTOSEQ(I)=WWSTOSEQ
      Raz [F:STO]
      Filter [STO] Where STOCOU = [M:SOW]WSTOCOU(I)
      Read [STO] First
      Filter [STO]
      LLOT = [F:STO]LOT
      LSLO = [F:STO]SLO
      LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)
      If LRET=0
         WMNT += LPRI*[M:SOW]WQTYSTU(I)
         WQTY += [M:SOW]WQTYSTU(I)
      Endif
   Endif
Next
If WQTY<>0 LPRI=WMNT/WQTY Endif
Return

######################################################################
# VALVCR : renvoie la somme des VARVAL des mouvements d'une piÃĻce
######################################################################
# ParamÃĻtres E : PFCY    = site
#                PVCRTYP = type de document (m. 701)
#                PVCRNUM = nÂ° de piÃĻce
#                PVCRLIN = nÂ° ligne de piÃĻce (facultatif)
#            S : PVAL    = valeur des mouvements du document
######################################################################
Subprog VALVCR(PFCY,PVCRTYP,PVCRNUM,PVCRLIN,PVAL,PRET)
Value    Char    PFCY
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Variable Decimal PVAL
Variable Integer PRET

Local Decimal LVAL, LQTY
Local Integer LRET

Call VALVCR2(PFCY,PVCRTYP,PVCRNUM,PVCRLIN,LVAL,LQTY,LRET)
PVAL = LVAL
PRET = LRET

End

######################################################################
# VALVCR2 : renvoie la somme des VARVAL et ACTQTY des mouvements d'une piÃĻce
######################################################################
# ParamÃĻtres E : PFCY    = site
#                PVCRTYP = type de document (m. 701)
#                PVCRNUM = nÂ° de piÃĻce
#                PVCRLIN = nÂ° ligne de piÃĻce (facultatif)
#            S : PVAL    = valeur des mouvements de la ligne de document
#                PQTYACT = quantitÃĐ des mouvements de la ligne de document
######################################################################
Subprog VALVCR2(PFCY,PVCRTYP,PVCRNUM,PVCRLIN,PVAL,PQTYACT,PRET)
Value    Char    PFCY
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Variable Decimal PVAL
Variable Decimal PQTYACT
Variable Integer PRET

If !clalev([STJ4]) : Local File STOJOU [STJ4] : Endif
Raz PVAL, PQTYACT, PRET

If PVCRLIN = 0
    Filter [STJ4] Where STOFCY = PFCY
&                     & VCRTYP = PVCRTYP
&                     & VCRNUM = PVCRNUM
Else
    Filter [STJ4] Where STOFCY = PFCY
&                     & VCRTYP = PVCRTYP
&                     & VCRNUM = PVCRNUM
&                     & VCRLIN = PVCRLIN
Endif

Columns [STJ4] (VARVAL, ACTQTY)
For [STJ4]STJ1
    PVAL += [F:STJ4]VARVAL
    PQTYACT += [F:STJ4]ACTQTY
Next
Filter [STJ4]
Columns [STJ4]
End


###############################################################
# Charge l'ÃĐcran SDP Ã  partir du fichier spÃĐcifiÃĐ
# !!! Attention !!! On fait une addition pour le cas de la pile FIFO
###############################################################
Subprog LOADSDP(PFIC, PREFIX, PCOE)
Value Char PFIC
Value Char PREFIX
Value Decimal PCOE

Call LOADSDPX2("SDP",PFIC, PREFIX, "CST", PCOE)

End

Subprog LOADSDPX(PABR,PFIC, PREFIX, PCOE)
Value Char PABR
Value Char PFIC
Value Char PREFIX
Value Decimal PCOE

Call LOADSDPX2(PABR,PFIC, PREFIX, "CST", PCOE)

End

Subprog LOADSDPX2(PABR,PFIC, PREFIX, SUFFIX, PCOE)
Value Char PABR
Value Char PFIC
Value Char PREFIX
Value Char SUFFIX
Value Decimal PCOE

Local Char LOSUFFIX(len(SUFFIX))

# Pour pouvoir charger le coÃŧt standard du niveau
If SUFFIX="LEVCST"
    LOSUFFIX = "LEV"
Elsif PREFIX="DEV"
    LOSUFFIX = ""
Else
    LOSUFFIX = SUFFIX
Endif

Local Integer I
#---- MatiÃĻre ----#
For I=0 To GACTMAT-1
    Assign "[M:"+PABR+"]MATCST(I)" With evalue("[M:"+PABR+"]MATCST(I)") + evalue(PFIC+PREFIX+"MAT"+SUFFIX+"(I)")*PCOE
Next
If I>0 & evalue("dim([M:"+PABR+"]NBMAT)")>0
    Assign "[M:"+PABR+"]NBMAT" With I-1
Endif

If evalue("dim("+PFIC+PREFIX+"OVEMAT"+LOSUFFIX+")")>0
    Assign "[M:"+PABR+"]OVEMATCST" With evalue("[M:"+PABR+"]OVEMATCST") + evalue(PFIC+PREFIX+"OVEMAT"+LOSUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMATTOT)")>0
    Assign "[M:"+PABR+"]OVEMATCST" With evalue("[M:"+PABR+"]OVEMATCST") + evalue(PFIC+PREFIX+"OVEMATTOT")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMAT)")>0    # Issue 79517 - 2012-02-09 by CCC
    Assign "[M:"+PABR+"]OVEMATCST" With evalue("[M:"+PABR+"]OVEMATCST") + evalue(PFIC+PREFIX+"OVEMAT")*PCOE
Endif

#---- Machine ----#
For I=0 To GACTMAC-1
    Assign "[M:"+PABR+"]MACCST(I)" With evalue("[M:"+PABR+"]MACCST(I)") + evalue(PFIC+PREFIX+"MAC"+SUFFIX+"(I)")*PCOE
Next
If I>0 & evalue("dim([M:"+PABR+"]NBMAC)")>0
    Assign "[M:"+PABR+"]NBMAC" With I-1
Endif

If evalue("dim("+PFIC+PREFIX+"OVEMAC"+LOSUFFIX+")")>0
    Assign "[M:"+PABR+"]OVEMACCST" With evalue("[M:"+PABR+"]OVEMACCST") + evalue(PFIC+PREFIX+"OVEMAC"+LOSUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMACTOT)")>0
    Assign "[M:"+PABR+"]OVEMACCST" With evalue("[M:"+PABR+"]OVEMACCST") + evalue(PFIC+PREFIX+"OVEMACTOT")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMAC)")>0    # Issue 79517 - 2012-02-09 by CCC
    Assign "[M:"+PABR+"]OVEMACCST" With evalue("[M:"+PABR+"]OVEMACCST") + evalue(PFIC+PREFIX+"OVEMAC")*PCOE
Endif

#---- Main d'oeuvre ----#
For I=0 To GACTLAB-1
    Assign "[M:"+PABR+"]LABCST(I)" With evalue("[M:"+PABR+"]LABCST(I)") + evalue(PFIC+PREFIX+"LAB"+SUFFIX+"(I)")*PCOE
Next
If I>0 & evalue("dim([M:"+PABR+"]NBLAB)")>0
    Assign "[M:"+PABR+"]NBLAB" With I-1
Endif

If evalue("dim("+PFIC+PREFIX+"OVELAB"+LOSUFFIX+")")>0
    Assign "[M:"+PABR+"]OVELABCST" With evalue("[M:"+PABR+"]OVELABCST") + evalue(PFIC+PREFIX+"OVELAB"+LOSUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVELABTOT)")>0
    Assign "[M:"+PABR+"]OVELABCST" With evalue("[M:"+PABR+"]OVELABCST") + evalue(PFIC+PREFIX+"OVELABTOT")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVELAB)")>0    # Issue 79517 - 2012-02-09 by CCC
    Assign "[M:"+PABR+"]OVELABCST" With evalue("[M:"+PABR+"]OVELABCST") + evalue(PFIC+PREFIX+"OVELAB")*PCOE
Endif

#---- /s-traitance ----#
If evalue("dim("+PFIC+PREFIX+"SCO"+SUFFIX+")")>0
    Assign "[M:"+PABR+"]SCOCST" With evalue("[M:"+PABR+"]SCOCST") + evalue(PFIC+PREFIX+"SCO"+SUFFIX+"")*PCOE
    Assign "[M:"+PABR+"]SCOTOT" With evalue("[M:"+PABR+"]SCOTOT") + evalue(PFIC+PREFIX+"SCO"+SUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"SCOTOT)")>0
    Assign "[M:"+PABR+"]SCOCST" With evalue("[M:"+PABR+"]SCOCST") + evalue(PFIC+PREFIX+"SCOTOT")*PCOE
    Assign "[M:"+PABR+"]SCOTOT" With evalue("[M:"+PABR+"]SCOTOT") + evalue(PFIC+PREFIX+"SCOTOT")*PCOE
Endif
If evalue("dim("+PFIC+PREFIX+"OVESCO"+LOSUFFIX+")")>0
    Assign "[M:"+PABR+"]OVESCOCST" With evalue("[M:"+PABR+"]OVESCOCST") + evalue(PFIC+PREFIX+"OVESCO"+LOSUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVESCOTOT)")>0
    Assign "[M:"+PABR+"]OVESCOCST" With evalue("[M:"+PABR+"]OVESCOCST") + evalue(PFIC+PREFIX+"OVESCOTOT")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVESCO)")>0    # Issue 79517 - 2012-02-09 by CCC
    Assign "[M:"+PABR+"]OVESCOCST" With evalue("[M:"+PABR+"]OVESCOCST") + evalue(PFIC+PREFIX+"OVESCO")*PCOE
Endif

#---- /s-traitance ----#
If evalue("dim("+PFIC+PREFIX+"INVDTA"+SUFFIX+")")>0
    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") + evalue(PFIC+PREFIX+"INVDTA"+SUFFIX+"")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTACST)")>0
    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") + evalue(PFIC+PREFIX+"INVDTACST")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTATOT)")>0
    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") + evalue(PFIC+PREFIX+"INVDTATOT")*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTA)")>0    # Issue 79517 - 2012-02-09 by CCC
    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") + evalue(PFIC+PREFIX+"INVDTA")*PCOE
Endif
End

###############################################################
# Copy SDP data from the STKVAL class back to the specified screen
###############################################################
Subprog COPYSTKVAL_SDP(PSTKVAL,PABR)
Variable  Instance  PSTKVAL Using OBJECT
Value     Char      PABR

  Local Integer I,IDX,MAXIDX

  Assign "[M:"+PABR+"]ITMREF"     With PSTKVAL.ITMREF
  Assign "[M:"+PABR+"]STOFCY"     With PSTKVAL.STOFCY
  Assign "[M:"+PABR+"]PRI"        With PSTKVAL.PRI
  Assign "[M:"+PABR+"]SCOCST"     With PSTKVAL.SCOCST
  Assign "[M:"+PABR+"]SCOTOT"     With PSTKVAL.SCOTOT
  Assign "[M:"+PABR+"]INVDTACST"  With PSTKVAL.INVDTACST
  Assign "[M:"+PABR+"]OVEMATCST"  With PSTKVAL.OVEMATCST
  Assign "[M:"+PABR+"]OVEMACCST"  With PSTKVAL.OVEMACCST
  Assign "[M:"+PABR+"]OVELABCST"  With PSTKVAL.OVELABCST
  Assign "[M:"+PABR+"]OVESCOCST"  With PSTKVAL.OVESCOCST

  #---- Material ----#
  Raz MAXIDX
  For I=1 To maxtab(PSTKVAL.MATERIAL)
    IDX = PSTKVAL.MATERIAL(I).MATIDX
    MAXIDX = max(IDX,MAXIDX)
    Assign "[M:"+PABR+"]MATCST("+num$(IDX)+")"  With PSTKVAL.MATERIAL(I).MATCST
  Next
  Assign "[M:"+PABR+"]NBMAT" With MAXIDX

  #---- Machine ----#
  Raz MAXIDX
  For I=1 To maxtab(PSTKVAL.MACHINE)
    IDX = PSTKVAL.MACHINE(I).MACIDX
    MAXIDX = max(IDX,MAXIDX)
    Assign "[M:"+PABR+"]MACCST("+num$(IDX)+")" With PSTKVAL.MACHINE(I).MACCST
  Next
  Assign "[M:"+PABR+"]NBMAC" With MAXIDX

  #---- Labor ----#
  Raz MAXIDX
  For I=1 To maxtab(PSTKVAL.LABOR)
    IDX = PSTKVAL.LABOR(I).LABIDX
    MAXIDX = max(IDX,MAXIDX)
    Assign "[M:"+PABR+"]LABCST("+num$(IDX)+")" With PSTKVAL.LABOR(I).LABCST
  Next
  Assign "[M:"+PABR+"]NBLAB" With MAXIDX

End

#############################################################
# DEFPRIMKI : Renvoie le prix d'ordre Ã  attribuer Ã  une dÃĐclaration de production
#############################################################
# ParamÃĻtre  E : PWSTOSEQ = Lien entre le la ligne document et la ligne de prix
#
# Les fichiers MFG, MFI et MKI doivent ÃŠtre positionnÃĐs
#############################################################
Funprog DEFPRIMKI(PWSTOSEQ)
Value Integer PWSTOSEQ

Local Decimal LPRI
Local Integer YEA_MFG, LRET, I

Local Char LECCMAJ(GLONICVVAL)
Local Char LECCMIN(GLONICVVAL)

If !clalev([F:MFC]) Local File MFGCOST     [MFC] Endif
If !clalev([F:MCN]) Local File MFCNAT      [MCN] Endif
# Issue 80846 - 2012-05-15 by CCC : Utilisation de la classe [F:MKI]
## MFG et MFI doivent etre en ligne

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif

Raz [M:SDP]

# Get the version number of first movement in order to
I=find(PWSTOSEQ,[M:ENTW]WSTOSEQ)
If I<>0
    If [M:ENTW]NUMLIGLOT>0 & dim([M:ENTW]ECCVALMAJ)>0  # Issue GA 07/2015
        LECCMAJ = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT)
        LECCMIN = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT)
    Else
        Raz LECCMAJ,LECCMIN
    Endif
Endif

If [F:MKI]ITMTYP=2
    If !clalev([F:TCM]) : Local File TABCOSTMET [F:TCM] : Endif
    Call GETTCM([F:MKI]ITMREF, [F:MKI]MFGFCY, GBIDC1, LRET) From STKVAL
    If !LRET
        Call GETPRI([F:MKI]ITMREF,LECCMAJ,LECCMIN,[F:MKI]MFGFCY,[F:MKI]IPTDAT,[F:MKI]CPLQTY,"","",[F:TCM]ISSVLTCOD,LPRI,LRET) From STKVAL
    Else
        LPRI=0
    Endif
# Issue 85669 - 2012-11-16 by CCC : Les FG qui peuvent exister dans la valeur du sous-produit
#                                   sont conservÃĐs pour valoriser le mouvement
#    # Issue 85187 - 2012-10-17 by CCC : On enlÃĻve les FG du sous-produit qui sont supportÃĐs par le produit
#    [M:SDP]PRI -= [M:SDP]OVEMATCST+[M:SDP]OVEMACCST+[M:SDP]OVELABCST+[M:SDP]OVESCOCST
#    Raz [M:SDP]OVEMATCST,[M:SDP]OVEMACCST,[M:SDP]OVELABCST,[M:SDP]OVESCOCST
Else
    YEA_MFG = year([F:MFG]CREDAT) : # date 1er suivi ou date crÃĐation OF

    # ou YEA_MFG = year(date$) # ou date de la dÃĐclaration en cours ! si <> date CP ThÃĐorique

    # recherche du prix de l'ordre selon paramÃĐtrage
    # GCSTRCPORD peut prendre la valeur 1 ou 2 : CPT ou CPL
    Read [MFC]MFC0=[F:MKI]MFGFCY;[F:MKI]ITMREF;10;[F:MKI]MFGNUM;[F:MKI]MFGLIN;GCSTRCPORD;0
    If !fstat
      LPRI = [F:MFC]CSTTOT+[F:MFC]OVETOT
      If GACTDECCST
        [M:SDP]PRI = LPRI
        For I=0 To GACTMAT-1
            [M:SDP]MATCST(I) = [F:MFC]MATCPNCST(I)
        Next
        [M:SDP]OVEMATCST = [F:MFC]OVEMATCPN+[F:MFC]OVEMATCST

        For I=0 To GACTMAC-1
            [M:SDP]MACCST(I) = [F:MFC]MACCPNCST(I)+[F:MFC]MACCST(I)
        Next
        [M:SDP]OVEMACCST = [F:MFC]OVEMACCPN+[F:MFC]OVEMACCST

        For I=0 To GACTLAB-1
            [M:SDP]LABCST(I) = [F:MFC]LABCPNCST(I)+[F:MFC]LABCST(I)
        Next
        [M:SDP]OVELABCST = [F:MFC]OVELABCPN+[F:MFC]OVELABCST

        [M:SDP]SCOTOT    = [F:MFC]SCOCPNCST+[F:MFC]SCOCST
        [M:SDP]OVESCOCST = [F:MFC]OVESCOCPN+[F:MFC]OVESCOCST

        [M:SDP]INVDTACST = [F:MFC]INVDTACPN+[F:MFC]INVDTACST

        # Issue 82631 - 2012-06-04 by CCC  :RÃĐcupÃĐration des natures
        For [MCN] Where STOFCY=[F:MFC]STOFCY
&                     & ITMREF=[F:MFC]ITMREF
&                     & VCRTYP=[F:MFC]VCRTYP
&                     & VCRNUM=[F:MFC]VCRNUM
&                     & VCRLIN=[F:MFC]VCRLIN
&                     & MFCTYP=[F:MFC]MFCTYP
&                     & UID   =0
            [M:SDP]OVENAT([M:SDP]NBONA) = [F:MCN]OVENAT
            [M:SDP]ONAAMT([M:SDP]NBONA) = [F:MCN]NATAMTLEV + [F:MCN]NATAMTSSE
            # Renseigner ONATYP nÃĐcessiterait d'avoir TYPCST dans la clÃĐ de SJO
            [M:SDP]NBONA+=1
        Next
      Endif
    Else
      LPRI = 0
    Endif
Endif
If !GACTDECCST
    Call SETNEWPRI([F:MKI]ITMREF, LECCMAJ, LECCMIN, [F:MKI]MFGFCY,[F:MKI]IPTDAT,PWSTOSEQ, LPRI,"")
Endif
I = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
If I<0
    I = [M:VALW]NBLIG
    [M:VALW]WSTOSEQ([M:VALW]NBLIG) = PWSTOSEQ
    [M:VALW]NBLIG += 1
Endif
If I>=0 & PWSTOSEQ=0    # Cela se produit dans une dÃĐclaration de fab auto
    [M:VALW]NBLIG += 1
Endif

Call COPSDP2VALW(I,"VALW","SDP") From SUBSDPCOM

GPOINT = "DEFPRIMKI" : Gosub ENTREE From EXEFNC

End LPRI

#############################################################
# DEFPRISCI : Renvoie le prix d'ordre Ã  attribuer Ã  une dÃĐclaration de production EO
#############################################################
# ParamÃĻtre  E : PWSTOSEQ = Lien entre le la ligne document et la ligne de prix
#
# Les lignes [F:SCO], [F:SCI] sont dÃĐjÃ  en mÃĐmoire
#############################################################
Funprog DEFPRISCI(PWSTOSEQ)
Value Integer PWSTOSEQ
Local Decimal LPRI : LPRI=0
Local Integer LRET, I
If !clalev([F:MFC]) Local File MFGCOST     [MFC] Endif
If !clalev([F:MCN]) Local File MFCNAT      [MCN] Endif

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP]
# recherche du prix de l'ordre selon paramÃĐtrage
# GCSTRCPORD peut prendre la valeur 1 ou 2 : CPT ou CPL
Read [MFC]MFC0=[F:SCI]PRHFCY;[F:SCI]ITMREF;36;[F:SCI]SCONUM;[F:SCI]SCILIN;GCSTEORORD;0
If !fstat
  LPRI = [F:MFC]CSTTOT+[F:MFC]OVETOT
  If GACTDECCST
    [M:SDP]PRI = LPRI
    For I=0 To GACTMAT-1
# Issue 83937 - 2012-08-06 by CCC : Suite Ã  correction 78112 : la matiÃĻre fournie pas ss-traitant est dÃĐjÃ  dans MATCPNCST
## Issue 74879 - 2011-07-08 by CCC
##        [M:SDP]MATCST(I) = [F:MFC]MATCPNCST(I)
#        [M:SDP]MATCST(I) = [F:MFC]MATCPNCST(I) + [F:MFC]BPSMATCST(I)
        [M:SDP]MATCST(I) = [F:MFC]MATCPNCST(I)
    Next
    [M:SDP]OVEMATCST = [F:MFC]OVEMATCPN+[F:MFC]OVEMATCST

    For I=0 To GACTMAC-1
        [M:SDP]MACCST(I) = [F:MFC]MACCPNCST(I)+[F:MFC]MACCST(I)
    Next
    [M:SDP]OVEMACCST = [F:MFC]OVEMACCPN+[F:MFC]OVEMACCST

    For I=0 To GACTLAB-1
        [M:SDP]LABCST(I) = [F:MFC]LABCPNCST(I)+[F:MFC]LABCST(I)
    Next
    [M:SDP]OVELABCST = [F:MFC]OVELABCPN+[F:MFC]OVELABCST

    [M:SDP]SCOTOT    = [F:MFC]SCOCPNCST+[F:MFC]SCOCST
    [M:SDP]OVESCOCST = [F:MFC]OVESCOCPN+[F:MFC]OVESCOCST

    [M:SDP]INVDTACST = [F:MFC]INVDTACPN+[F:MFC]INVDTACST

        # Issue 82631 - 2012-06-04 by CCC  :RÃĐcupÃĐration des natures
        For [MCN] Where STOFCY=[F:MFC]STOFCY
&                     & ITMREF=[F:MFC]ITMREF
&                     & VCRTYP=[F:MFC]VCRTYP
&                     & VCRNUM=[F:MFC]VCRNUM
&                     & VCRLIN=[F:MFC]VCRLIN
&                     & MFCTYP=[F:MFC]MFCTYP
&                     & UID   =0
            [M:SDP]OVENAT([M:SDP]NBONA) = [F:MCN]OVENAT
            [M:SDP]ONAAMT([M:SDP]NBONA) = [F:MCN]NATAMTLEV + [F:MCN]NATAMTSSE
            [M:SDP]NBONA+=1
        Next
  Endif
Else
  LPRI = 0
Endif

If !GACTDECCST
    # La date n'est nÃĐcessaire que si GACTDECCST<>0
    If dim([F:SCI]ECCVALMAJ)>0  # Issue GA 07/2015
      Call SETNEWPRI([F:SCI]ITMREF, [F:SCI]ECCVALMAJ, [F:SCI]ECCVALMIN, [F:SCI]PRHFCY,[0/0/0],PWSTOSEQ, LPRI,"")
    Else
      Call SETNEWPRI([F:SCI]ITMREF, "", "", [F:SCI]PRHFCY,[0/0/0],PWSTOSEQ, LPRI,"")
    Endif
Endif
I = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
If I<0
    I = [M:VALW]NBLIG
    [M:VALW]WSTOSEQ([M:VALW]NBLIG) = PWSTOSEQ
    [M:VALW]NBLIG += 1
Endif
If I>=0 & PWSTOSEQ=0    # Cela se produit dans une dÃĐclaration de fab auto
    [M:VALW]NBLIG += 1
Endif

Call COPSDP2VALW(I,"VALW","SDP") From SUBSDPCOM

End LPRI


#######################################
# SETNEWPRI : alimente le masque [M:VALW] avec le prix passÃĐ en paramÃĻtre
#             en dÃĐcomposant selon le prix de sortie
#######################################
# ParamÃĻtres : PITM = article
#              PFCY = site
#              PDAT = date du mouvement
#              PWSTOSEQ = nÂ° de sÃĐquence (lien entre ligne de doc et ENTW)
#              PNEWPRI = nouveau prix unitaire de la ligne de document
#              PSUP     = options ("M" = pour une nouvelle ligne, ne pas rÃĐpartir selon la mÃĐthode de sortie)
#                                 ("O" = ne pas tenir compte des FG pour la rÃĐpartition et les mettre Ã  0   )
#                                 ("I" = mettre les ÃĐlÃĐments de facturation Ã  0)
#######################################
Subprog SETNEWPRI(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, PSUP)
Value Char    PITM
Value Char    PECCMAJ
Value Char    PECCMIN
Value Char    PFCY
Value Date    PDAT
Value Integer PWSTOSEQ
Value Decimal PNEWPRI
Value Char    PSUP

Local Decimal LDIFPRI
Local Integer LLIGW, LSDPOPEN
Local Integer LRET
Local Char    LTCM(GLONTCM)
Local Decimal LQTY, LPRI

If PWSTOSEQ<=0 : End : Endif

If !clalev([M:VALW])
# : Infbox "VALW pas ouvert!!!"
 : End : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif

Raz LSDPOPEN
If !clalev([M:SDP]) : Local Mask SAIDECPRI : LSDPOPEN=1 : Endif
Raz [M:SDP]
LLIGW = find(PWSTOSEQ,[M:VALW]WSTOSEQ)

If LLIGW<=0
    LLIGW=[M:VALW]NBLIG
    [M:VALW]WSTOSEQ(LLIGW) = PWSTOSEQ
    [M:VALW]NBLIG += 1
    If GACTDECCST & PNEWPRI<>0    # On prÃĐ-charge avec la mÃĐthode de sortie pour rÃĐpartir de la mÃŠme maniÃĻre
        If instr(1,PSUP,"M")=0
            Call GETTCM(PITM, PFCY, LTCM, LRET) From STKVAL
            If find([F:TCM]ISSVLTCOD,5,8) #Fifo ou lifo
                If !clalev([F:STP]) : Local File STOCOST [STP] : Endif
                Filter [STP] Where ITMREF=PITM & STOFCY=PFCY
                Read [STP] Last
                Filter [STP]
                LQTY = [F:STP]QTYSTUACT
            Else
                LQTY = 0
            Endif
            Call GETPRI(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, LQTY,"","",[F:TCM]ISSVLTCOD,LPRI,LRET) From STKVAL    # SDP ouvert => rempli par getpri
            If instr(1,PSUP,"O")<>0
                # On efface les FG
                Raz [M:SDP]OVEMATCST,[M:SDP]OVEMACCST,[M:SDP]OVELABCST,[M:SDP]OVESCOCST
            Endif
            If instr(1,PSUP,"I")<>0
                # On efface les ÃĐlÃĐments de facturation
                Raz [M:SDP]INVDTACST
            Endif
        Endif
# Issue 92701 - 2013-10-23 by CCC : On arrondi le plus tard possible
#  + CAL_TOT (appelÃĐ dans ARRSDP) se base sur les natures pour calculer le total FG => on attend REPARTIR
#        Call ARRSDP("SDP", 10^-GDECPRI) From SUBSDPCOM
        LDIFPRI = PNEWPRI - [M:SDP]PRI
    Else
        LDIFPRI = PNEWPRI
    Endif
Else
    LLIGW-=1
    Call LOAD_VAL(LLIGW) From SUBSDP
    [M:SDP]PRI = [M:VALW]PRI(LLIGW)
    LDIFPRI = PNEWPRI - [M:VALW]PRI(LLIGW)
Endif

# Issue 112827 - 2016-04-21 by CCC : Even if there is no diffrence, call REPARTIR to get overhead category "ZZZ"
#If LDIFPRI<>0
    Gosub REPARTIR From SUBSDP
#Endif

Call ARRSDP("SDP",10^-GDECPRI) From SUBSDPCOM

Gosub ENR From SUBSDP

If LSDPOPEN=1 : Close Mask [M:SDP] : Endif

End



#############################################################
# GETOVE : Renvoie le code FG correspondant au couple article/type de mouvement
#############################################################
# ParamÃĻtres E : PITM = article
#                PFCY = site
#                PTRS = type de mouvement
#                PRET = code retour (0= OK positionnement correct)
#                                   (1= Pas de code FG)
#                                   (2= Erreur lecture fichier)
#
# Les fichier ITM, ITF, ITG et OVE doivent ÃŠtre ouverts
#############################################################
Funprog GETOVE( PITM, PFCY, PTRS, PRET )
Value    Char    PITM
Value    Char    PFCY
Value    Integer PTRS
Variable Integer PRET

Local Char LOVE(GLONOVE) : Raz LOVE
Local Integer I, LTRS
LTRS=PTRS

If [F:ITF]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
    Read [ITF]ITF0=PITM;PFCY
    If fstat
        Raz [F:ITF]
        PRET = 2
        End ""
    Endif
Endif
I = find (LTRS,[F:ITF]OTRSTYP)
If I>0
    LOVE = [F:ITF]OVECOD(I-1)

# Chercher les FG dans la catÃĐgorie de l'article : DÃĐsactivÃĐ
#Else
#    If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
#    If [F:ITM]ITMREF<>PITM
#        Read [ITM]ITM0=PITM
#        If fstat
#            Call FSTA("ITM") From GLOCK
#            PRET = 2
#            End LOVE
#        Endif
#    Endif
#    If [F:ITG]TCLCOD<>[F:ITM]TCLCOD | [F:ITG]STOFCY<>PFCY
#        Read [ITG]ITG0=PFCY;[F:ITM]TCLCOD
#    Endif
#    I = find (ltrs,[F:ITG]OTRSTYP)
#    If I>0
#        LOVE = [F:ITG]OVECOD(I-1)
#    Else
#        Read [ITG]ITG1=[F:ITM]TCLCOD;""
#        If fstat
#            Call FSTA("ITG") From GLOCK
#            PRET = 2
#            End LOVE
#        Endif
#        I = find (ltrs,[F:ITG]OTRSTYP)
#        If I>0
#            LOVE = [F:ITG]OVECOD(I-1)
#        Endif
#    Endif
Endif

End LOVE

#############################################################
# LECOVE : se positionne sur le code FG ([F:OVE]) correspondant au couple article/type de mouvement
#############################################################
# ParamÃĻtres E : PITM = article
#                PFCY = site
#                PTRS = type de mouvement
#            S : PRET = code retour (0= OK positionnement correct)
#                                   (1= Pas de code FG)
#                                   (2= Erreur lecture fichier)
#
# Les fichier ITM, ITF, ITG et OVE doivent ÃŠtre ouverts
#############################################################
Subprog LECOVE( PITM, PFCY, PTRS, PRET )
Value    Char    PITM
Value    Char    PFCY
Value    Integer PTRS
Variable Integer PRET

Local Char LOVE(GLONOVE)
Local Char LITM(GLONITM),LFCY(GLONFCY)
Local Integer LTRS, LRET

Raz LRET

LITM = PITM
LFCY = PFCY
LTRS = PTRS

LOVE = func GETOVE( LITM, LFCY, LTRS, LRET )

PRET = LRET
If LOVE<>""
    If [F:OVE]OVECOD<>LOVE
        Read [OVE]OVE0=LOVE
        If fstat
            Call FSTA("OVE") From GLOCK
            PRET = 2
            End
        Endif
    Endif
Else
    PRET = 1
    Raz [F:OVE]
Endif

End

#############################################################
# SETNEWPRIOVE : idem SETNEWPRI mais calcule les FG au lieu de les rÃĐcupÃĐrer
#############################################################
# ParamÃĻtres E : PITM = article
#                PFCY = site
#                PDAT = date du mouvement
#                PWSTOSEQ = nÂ° de sÃĐquence (lien entre ligne de doc et ENTW)
#                PNEWPRI = nouveau prix unitaire de la ligne de document
#                PTRS = type de mouvement
#                PTYPORI = Type de doc d'origine
#                PVCRORI = NÂ° de doc d'origine
#                PLINORI = Ligne de doc d'origine
#                PSEQORI = SÃĐq de doc d'origine
#                PQTY = QuantitÃĐ (pour calcul prix unitaire et FG)
#                PSUP = Option
#            S : PRET = code retour (0= OK)
#                                   (1= Pas de code FG)
#                                   (2= Erreur lecture fichier)
#                                   (3= WSTOSEQ n'a pas ÃĐtÃĐ trouvÃĐ dans VALW)
#                                   (4= Trop de nature, dimension du tableau Fg de VALW dÃĐpassÃĐe)
#                                   (5= Erreur paramÃĻtre, PQTY=0 --> on peut calculer un prix unitaire)
#############################################################
Subprog SETNEWPRIOVE(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, PTRS, PQTY, PSUP, PRET)
Value    Char    PITM
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Char    PFCY
Value    Date    PDAT
Value    Integer PWSTOSEQ
Value    Decimal PNEWPRI
Value    Integer PTRS
Value    Decimal PQTY
Value    Char    PSUP
Variable Integer PRET

    Call SETNEWPRIOVE2(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, 0, PTRS, 0,"",0,0,PQTY, PSUP, PRET)
End

Subprog SETNEWPRIOVE2(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, PINVDTA, PTRS, PTYPORI,PNUMORI,PLINORI,PSEQORI,PQTY, PSUP, PRET)
Value    Char    PITM
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Char    PFCY
Value    Date    PDAT
Value    Integer PWSTOSEQ
Value    Decimal PNEWPRI
Value    Decimal PINVDTA
Value    Integer PTRS
Value    Integer PTYPORI
Value    Char    PNUMORI
Value    Integer PLINORI
Value    Integer PSEQORI
Value    Decimal PQTY
Value    Char    PSUP
Variable Integer PRET

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, LRET, LLIGW, LIND1
Local Decimal LOVEAMT(4)
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LBASQTY, LBASAMT, LCOE

If PQTY=0
    PRET=5
    End
Endif

LRET = 1


#---- Gestion des FG sur le type de mouvement en cours ----#
#---- et valeur des FG matiÃĻre nulle => calcul FG      ----#
    If func STKVALPAR.WITHOVE(PTRS,-1)
        If !clalev ([F:OVE]) : Local File OVERHEAD [OVE] : Endif
        Call LECOVE(PITM,PFCY,PTRS,LRET) From STKVAL
    Endif

    If !LRET
        # Issue 90837 - 2013-07-03 by CCC : le prix saisi est hors FG puisqu'ils sont calculÃĐs aprÃĻs
        LLIGW = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
        If LLIGW>=0
            Raz [M:VALW]OOVEMATCST(LLIGW), [M:VALW]OOVEMACCST(LLIGW), [M:VALW]OOVELABCST(LLIGW), [M:VALW]OOVESCOCST(LLIGW)
        Endif

        # Pour les rÃĐceptions, on ne garde pas la partie "ÃĐlÃĐment de facturation" car elle vient aprÃĻs
        Call SETNEWPRI(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, "MO"+string$(PTRS=3,"I"))
        LLIGW = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
        If LLIGW<0
            PRET=3
            End
        Endif

        LBASQTY = PQTY
        LBASAMT = PNEWPRI*PQTY

        # Issue 100192 - 2014-06-23 by CCC
        GPOINT="BASFGSETPRI"
        Gosub ENTREE From EXEFNC

        Call CALOVELIN(PITM, PFCY, PTRS, PTYPORI,PNUMORI,PLINORI,PSEQORI,LBASQTY, LBASAMT, "", LTABNAT, LTABTYP, LTABFXD, LTABVAR, PRET)

        For I=0 To [M:VALW]NBONA-1
            If [M:VALW]OWSTOSEQ(I) = PWSTOSEQ
                [M:VALW]OWSTOSEQ(I) = 0
            Endif
        Next

        Raz [M:VALW]OOVEMATCST(LLIGW), [M:VALW]OOVEMACCST(LLIGW), [M:VALW]OOVELABCST(LLIGW), [M:VALW]OOVESCOCST(LLIGW)
        For I=0 To dim(LTABNAT)-1
            If LTABNAT(I)=""
                Break
            Endif
            If [M:VALW]NBONA=dim([M:VALW]OVENAT)
                LRET=4
                Break
            Endif
            [M:VALW]OVENAT  ([M:VALW]NBONA) = LTABNAT(I)
            [M:VALW]OWSTOSEQ([M:VALW]NBONA) = PWSTOSEQ
            # Issue 88646 - 2013-03-28 by CCC
            #[M:VALW]ONAAMT  ([M:VALW]NBONA) = arr((LTABFXD(I)+LTABVAR(I))/PQTY,10^-GDECPRI)#100678.o MJH 11/8/2016
            [M:VALW]ONAAMT  ([M:VALW]NBONA) = (LTABFXD(I)+LTABVAR(I))/PQTY#100678.n MJH 11/8/2016
            [M:VALW]ONATYP  ([M:VALW]NBONA) = LTABTYP(I)
            # Somme des ONAAMT pour WSTOSEQ=PWSTOSEQ en fonction des types de nature (Le type de nature "selon contexte" alimente les FG matiÃĻre)
            Case [M:VALW]ONATYP([M:VALW]NBONA)
                When 1,2 : [M:VALW]OOVEMATCST(LLIGW) += [M:VALW]ONAAMT([M:VALW]NBONA)
                When 3   : [M:VALW]OOVEMACCST(LLIGW) += [M:VALW]ONAAMT([M:VALW]NBONA)
                When 4   : [M:VALW]OOVELABCST(LLIGW) += [M:VALW]ONAAMT([M:VALW]NBONA)
                When 5   : [M:VALW]OOVESCOCST(LLIGW) += [M:VALW]ONAAMT([M:VALW]NBONA)
            Endcase
# Issue 88646 - 2013-03-28 by CCC
#            # Issue 82631 - 2012-06-04 by CCC  : prix unitaire (comme pour les autres valeurs de VALW)
#            [M:VALW]ONAAMT([M:VALW]NBONA) /= PQTY
            [M:VALW]NBONA +=1
        Next
        #----- Calcul du prix unitaire des FG
        # Somme des ONAAMT pour WSTOSEQ=PWSTOSEQ en fonction des types de nature (Le type de nature "selon contexte" alimente les FG matiÃĻre)
        # LIND1 = indice de la 1ÃĻre ligne de nature renseignÃĐe pour ce WSTOSEQ
# Issue 88646 - 2013-03-28 by CCC : arrondir sans perte
#        [M:VALW]OOVEMATCST(LLIGW) /= PQTY
#        [M:VALW]OOVEMACCST(LLIGW) /= PQTY
#        [M:VALW]OOVELABCST(LLIGW) /= PQTY
#        [M:VALW]OOVESCOCST(LLIGW) /= PQTY

#        [M:VALW]OOVEMATCST(LLIGW) = arr([M:VALW]OOVEMATCST(LLIGW),10^-GDECPRI)
#        [M:VALW]OOVEMACCST(LLIGW) = arr([M:VALW]OOVEMACCST(LLIGW),10^-GDECPRI)
#        [M:VALW]OOVELABCST(LLIGW) = arr([M:VALW]OOVELABCST(LLIGW),10^-GDECPRI)
#        [M:VALW]OOVESCOCST(LLIGW) = arr([M:VALW]OOVESCOCST(LLIGW),10^-GDECPRI)


        [M:VALW]PRI(LLIGW) += [M:VALW]OOVEMATCST(LLIGW)+[M:VALW]OOVEMACCST(LLIGW)+[M:VALW]OOVELABCST(LLIGW)+[M:VALW]OOVESCOCST(LLIGW)
    Elsif LRET=1    # Pas de code FG
        # Issue X3-148272 - 2019-08-23 by MJH : PSUP is declared but never used.
        #Call SETNEWPRI(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, string$(PTRS=3,"I"))
        Call SETNEWPRI(PITM, PECCMAJ, PECCMIN, PFCY, PDAT, PWSTOSEQ, PNEWPRI, PSUP + string$(PTRS=3,"I"))
        Raz LRET
        LLIGW = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
        If LLIGW<0
            PRET=3
            End
        Endif
    Endif


If [M:VALW]ZONPRIORD<>"" & evalue("dim("+[M:VALW]ZONPRIORD+")")>nolign-1
    Assign [M:VALW]ZONPRIORD+"(nolign-1)" With [M:VALW]PRI(LLIGW)
Endif

PRET = LRET

End

##############################################
# CALOVELIN : Calcule les FG pour un type de mouvement
##############################################
# ParamÃĻtres E : PITM = Article
#                PFCY = Site
#                PTRS = Type mouvement (m. 704)
#                PTYPORI = type de doc origine (m. 701)
#                PNUMORI = nÂ° doc origine
#                PLINORI = nÂ° ligne doc origine
#                PSEQORI = nÂ° seq doc origine
#                PBASQTY = QuantitÃĐ
#                PBASAMT = Montant
#                PSUP = Option
#            S : PTABNAT() = Natures
#                PTABTYP() = Type de frais gÃĐnÃĐraux (mat, mac, mo ou stt)
#                PTABFXD() = Valeur des frais fixes par nature
#                PTABVAR() = Valeur des frais variables par nature
#                PRET = Code retour (0=OK)
##############################################
Subprog CALOVELIN(PITM, PFCY, PTRS, PTYPORI,PNUMORI,PLINORI,PSEQORI,PBASQTY, PBASAMT, PSUP, PTABNAT, PTABTYP, PTABFXD, PTABVAR, PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Integer PTRS
Value    Integer PTYPORI
Value    Char    PNUMORI
Value    Integer PLINORI
Value    Integer PSEQORI
Value    Decimal PBASQTY
Value    Decimal PBASAMT
Value    Char    PSUP
Variable Char    PTABNAT()
Variable Integer PTABTYP()
Variable Decimal PTABFXD()
Variable Decimal PTABVAR()
Variable Integer PRET

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, LRET, LIND
Local Decimal LOVEAMT
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Integer LNBNAT
Local Decimal LBAS, LCOE
Local Char    LCOL(1)

If PBASQTY=0
    PRET=5
    End
Endif

LRET = 1

If func STKVALPAR.WITHOVE(PTRS,-1)
    Call LECOVE(PITM,PFCY,PTRS,LRET) From STKVAL
Endif

If !LRET
    If [F:OVE]FORBASIS=1    # Base montant
        LBAS = PBASAMT
    Else                    # Base quantitÃĐ
        LBAS = PBASQTY
    Endif

    Raz PTABNAT,PTABFXD,PTABVAR,PTABTYP
    Raz LTABNAT,LTABFXD,LTABVAR,LTABTYP, LNBNAT

    Call PARAM(PFCY,"OVECOLSTK",LCOL) From ADOVAL
    GOVECOLSTK = val(LCOL)

    #--- FG document ---#
    Call CLCOVE(LBAS, [F:OVE]OVECOD, mid$("ABCD",GOVECOLSTK,1), 1, LTABNAT, LTABTYP, LTABFXD, LTABVAR) From TRTCST

    For I=0 To dim(LTABNAT)-1
        If LTABNAT(I)=""
            Break
        Endif
        If LNBNAT=dim([M:VALW]OVENAT)
            LRET=4
            Break
        Endif
        PTABNAT(LNBNAT) = LTABNAT(I)
        PTABVAR(LNBNAT) = LTABVAR(I)
        PTABFXD(LNBNAT) = LTABFXD(I)
        PTABTYP(LNBNAT) = LTABTYP(I)
        LNBNAT +=1
    Next

    #--- FG document origine ---#
    If func STKVALPAR.ISORIOVE(PTYPORI)
        Raz LBAS, LCOE
        Case PTYPORI
            When 14:    # commande achat
                If !clalev([F:POQ]) : Local File PORDERQ [POQ] : Endif
                If !clalev([F:POP]) : Local File PORDERP [POP] : Endif
                # Issue 82703 - 2013-06-07 by SR : FCC sur commande
                Raz fstat
                If [F:POQ]POHNUM <> PNUMORI | [F:POQ]POPLIN <> PLINORI | [F:POQ]POQSEQ <> PSEQORI
                  Read [POQ]POQ0=PNUMORI;PLINORI;PSEQORI
                  If fstat : Raz [F:POQ] : Endif
                Endif
                # fin Issue 82703
                If !fstat
                    If [F:OVE]FORBASIS=1    # Base montant
                        If [F:POQ]POHTYP<>2
                            Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
                        Else
                            Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
                            Read [POP]POP1 First
                            Filter [POP]
                        Endif
                        If fstat : Raz [F:POP] : Endif
                        LBAS = [F:POQ]QTYSTU*[F:POP]NETPRI
                    Else                    # Base quantitÃĐ
                        LBAS = [F:POQ]QTYSTU
                    Endif
                    If [F:POQ]QTYSTU<>0
                        # On proratise sur la quantitÃĐ rÃĐceptionnÃĐe
                        LCOE = PBASQTY/[F:POQ]QTYSTU
                    Endif
                Endif
        Endcase

        Raz LTABNAT,LTABFXD,LTABVAR,LTABTYP

        Call CLCOVE(LBAS, [F:OVE]OVECOD, mid$("ABCD",GOVECOLSTK,1), 2, LTABNAT, LTABTYP, LTABFXD, LTABVAR) From TRTCST
        For I=0 To dim(LTABNAT)-1
            If LTABNAT(I)=""
                Break
            Endif
            LIND = find(LTABNAT(I), PTABNAT)
            If LIND>0
                LIND -= 1
            Else
                If LNBNAT=dim(LTABNAT)
                    LRET=4
                    Break
                Endif
                LIND = LNBNAT
                PTABNAT(LIND) = LTABNAT(I)
                PTABTYP(LIND) = LTABTYP(I)
                LNBNAT +=1
            Endif
            PTABVAR(LIND) += LTABVAR(I)*LCOE
            PTABFXD(LIND) += LTABFXD(I)*LCOE
        Next
    Endif
Endif

PRET = LRET

End

################################################################
# SETINVDTA : Alimente la valeur des ÃĐlÃĐments de facturation dans [M:VALW]
################################################################
# Parameters E : PINVDTA = Valeur des ÃĐlÃĐments de facturation
#                PWSTOSEQ = nÂ° de sÃĐquence (lien entre ligne de doc et ENTW)
################################################################
Subprog SETINVDTA(PINVDTA, PWSTOSEQ)
Value Decimal PINVDTA
Value Integer PWSTOSEQ

Local Integer LLIGW

LLIGW = find(PWSTOSEQ,[M:VALW]WSTOSEQ)-1
If LLIGW<0
    End
Endif
[M:VALW]OINVDTACST(LLIGW)=PINVDTA
[M:VALW]PRI(LLIGW)+=PINVDTA
End

#####################################################################
# CALCPROP :  Calcule la rÃĐpartition de variables selon des coef
#####################################################################
# ParamÃĻtres E : PNBKEY  = nomre d'identifiants/coefficients
#                PTABREF = liste des coefficients
#                PNBVAR  = nombre de variables
#                PTABVAR = liste des variables
#                PARR    = arrondi Ã  appliquer (-1=pas d'arrondi)
#            S : PTABVAL = tableau des valeurs rÃĐparties
#####################################################################
# Exemple:
# PTABVAR(0) = "[F:XXX]TOTAL1"
# PTABVAR(1) = "[L]TOTAL2"
#
#         | [F:XXX]TOTAL1       | [L]TOTAL2
#         |      100            |   200
#         +-------------------------------------------
#         |                  PTABVAL
# PTABREF +-------------------------------------------
#    1    | 100*1/(1+2+3+4)=10  | 200*1/(1+2+3+4)=20
#    2    | 100*2/(1+2+3+4)=20  | 200*2/(1+2+3+4)=40
#    3    | 100*3/(1+2+3+4)=30  | 200*3/(1+2+3+4)=60
#    4    | 100*4/(1+2+3+4)=40  | 200*4/(1+2+3+4)=80
#
#####################################################################
Subprog CALCPROP(PNBKEY, PTABREF, PNBVAR, PTABVAR, PARR, PTABVAL)
Value Integer PNBKEY
Value Decimal PTABREF()
Value Integer PNBVAR
Value Char    PTABVAR()
Value Decimal PARR
Variable Decimal PTABVAL(,)

Raz PTABVAL

Local Integer K, V, LINDMAX
Local Decimal LTOTREF, LVAL, LMAX
LTOTREF = sum(PTABREF)

If LTOTREF=0 : End : Endif

For V=0 To PNBVAR-1
    LVAL = evalue(PTABVAR(V))
    Raz LMAX, LINDMAX
    If LVAL<>0
        For K=0 To PNBKEY-1
            PTABVAL(K,V) = LVAL * PTABREF(K) / LTOTREF
            If PARR>=0
                PTABVAL(K,V) = arr(PTABVAL(K,V),PARR)
            Endif
            If LMAX<abs(PTABVAL(K,V))
                LMAX=abs(PTABVAL(K,V))
                LINDMAX=K
            Endif
        Next
        PTABVAL(LINDMAX,V) += LVAL-sum(PTABVAL(0..PNBKEY-1,V))
    Endif
Next
End

# Issue 91384 - 2013-08-02 by CCC
############################################################
# WAITISSADJ : indicates if an issue adjustment is waiting
############################################################
# Parametres E : PFCY = Site
#                PITM = Item
#                PTYP = document's type
#                PNUM = document's number
#                PLIN = document's line
#            S : 0 = no issue adjustment waiting
#                1 = FIFO/LIFO adjustment waiting
############################################################
Funprog WAITISSADJ(PFCY, PITM, PTYP, PNUM, PLIN)
Value Char PFCY
Value Char PITM
Value Integer PTYP
Value Char PNUM
Value Integer PLIN

Local Char REQ(250)(5), LTCM(GLONTCM)
Local Integer IREQ, LRET

If clalev([F:TCM])=0 : Local File TABCOSTMET [TCM] : Endif
Call GETTCM(PITM, PFCY, LTCM, LRET) From STKVAL
If ! ( [F:TCM]PRIREGS=2
&    & ( find([F:TCM]ISSVLTCOD(0),5,8)
&      | find([F:TCM]ISSVLTCOD(1),5,8) ) )
    End 0
Endif

# For an issue document, looking for receipts linked by FIFO key
# If a receipt has AMTDEV<>0 => issue can't be modified
Call ADDCRIT(REQ, IREQ, "", "SELECT 1", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "From", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "(SELECT sum(AMTDEV_0) DEV, sum(ACTQTY_0) QTY", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "From "+nomap+".STOJOU STJ, (SELECT CSTDAT_0, CSTTIM_0, CSTCOU_0, ITMREF_0, STOFCY_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "From "+nomap+".STOMVTCOST", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "Where VCRTYP_0="+num$(PTYP), " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and VCRNUM_0  ='"+PNUM+"'", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and VCRLIN_0  ="+num$(PLIN), " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and ITMREF_0  ='"+PITM+"'", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STOFCY_0  ='"+PFCY+"'", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     ") SMC", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "Where STJ.CSTCOU_0 = SMC.CSTCOU_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STJ.CSTTIM_0 = SMC.CSTTIM_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STJ.CSTDAT_0 = SMC.CSTDAT_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STJ.ITMREF_0 = SMC.ITMREF_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STJ.STOFCY_0 = SMC.STOFCY_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "and STJ.UPDCOD_0 = 2", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     "GROUP By STJ.VCRTYP_0, STJ.VCRNUM_0, STJ.VCRLIN_0, STJ.ITMREF_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     ") ENT", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "Where ENT.QTY>0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "and ENT.DEV <>0", " ") From GOBJSUB

LRET = 0
For (Integer FLAG) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    LRET=1
Next

End LRET

#**----------------------------------------------------------------<br/>
#* GETDOCLINQTY : Get active quantity of a document line
#**<br/>----------------------------------------------------------------<br/>
#* @param PSTOFCY = Site
#* @param PVCRTYP = Document type
#* @param PVCRNUM = Document number
#* @param PVCRLIN = Document line
#* @param PITMREF = Item
#**<br/>----------------------------------------------------------------
#*!
Funprog GETDOCLINQTY(PSTOFCY,PVCRTYP,PVCRNUM,PVCRLIN,PITMREF)
Value Char    PSTOFCY
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Char    PITMREF

Local Decimal LQTY

If clalev([F:STJ])=0 : Local File STOJOU [STJ] : Endif

Columns [STJ] (ACTQTY)
For [STJ] Where STOFCY=PSTOFCY
&             & VCRTYP=PVCRTYP
&             & VCRNUM=PVCRNUM
&             & VCRLIN=PVCRLIN
&             & ITMREF=PITMREF
    LQTY+=[F:STJ]ACTQTY
Next
Columns [STJ]

End LQTY

# Issue 113876 - 2016-02-01 by CCC :  need to get receipt's invoicing elements
#                                     to have calculate value of the receipt
# This function has been written by using SUBPTHB.CALCUL_MTELT as template
#**----------------------------------------------------------------<br/>
#* GETPTDINVDTA : Returns value of invoicing elements for a receipt
#**<br/>----------------------------------------------------------------<br/>
#* @param PNUM = receipt number
#* @param PLIN = receipt line number
#**<br/>----------------------------------------------------------------
#*!
Funprog GETPTDINVDTA(PNUM,PLIN)
Value Char PNUM
Value Integer PLIN

If clalev([F:PTH])=0 : Local File PRECEIPT  [PTH] : Endif
If clalev([F:PTD])=0 : Local File PRECEIPTD [PTD] : Endif
If clalev([F:PFI])=0 : Local File PFOOTINV  [PFI] : Endif

Local Decimal WMTELT

Local    Integer WSTAT,I,J
If [F:PTH]PTHNUM<>PNUM
    Read [PTH]PTH0=PNUM
    If fstat : End 0 : Endif
Endif
If [F:PTD]PTHNUM<>PNUM | [F:PTD]PTDLIN<>PLIN
    Read [PTD]PTD0=PNUM;PLIN
    If fstat : End 0 : Endif
Endif

Call GETDEV([F:PTH]PRHFCY) From DEVSUB

#----- Elements from the foot of the receipt -----#
Raz WMTELT
For I=1 To 9
  If [F:PTH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]NPRVLT=2
      WMTELT+=evalue("[F:PTD]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I

#----- Conversion if necessary of the company currency amount -----#
If [F:PTD]NETCUR<>GLOCALDEV
  If GPTHCURDAT<>2 & [F:PTD]POHNUM<>""
    Read [POH] POH0=[F:PTD]POHNUM
    If fstat
        Raz [F:POH] : [F:POH]ORDDAT=[F:PTH]RCPDAT : [F:POH]CHGTYP=[F:PTH]CHGTYP
    Endif
    Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                  WMTELT,WMTELT,WSTAT) From TRTDEV
  Else
    If [F:PTH]CHGCOE=0
      Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WMTELT,WMTELT,WSTAT) From TRTDEV
    Else
      WMTELT=WMTELT*[F:PTH]CHGCOE
    Endif
  Endif
Endif

#----- part of invoicing elements has to be calculated for unit stock -----#
If [F:PTD]UOM<>[F:PTD]STU
  If [F:PTD]UOMSTUCOE=0  [F:PTD]UOMSTUCOE=1 : Endif
  WMTELT=arr(WMTELT/[F:PTD]UOMSTUCOE,10^-GDECPRI)
Else
  WMTELT=arr(WMTELT,10^-GDECPRI)
Endif

End WMTELT
