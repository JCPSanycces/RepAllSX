######################################################################
# Traitement STKVAL - Librairie de valorisation stock             V6 #
######################################################################
#<gen>
# GETTCM : Recherche le code de la mÃĐthode de valo associÃĐe Ã  un article-site
#          + Si la table TABCOSTMET [TCM] est ouverte on se positionne dessus
# GETTVM : Recherche la mÃĐthode de valorisation d'un type de mouvement
#          Si les tables TABCOSTMET [TCM] et TABCOSTMVT [TVM] sont ouvertes
#          elles sont positionnÃĐes
# GETPRITAR : renvoie le prix tarif
# GETPRI Renvoie le prix d'un article
#        pour une certaine quantitÃĐ et une mÃĐthode de valo donnÃĐe
# GETPRISTD Renvoie le coÃŧt standard d'un article
# DEFPRI         Routine calcul prix par dÃĐfaut des mvts de stock
# DEFPRI2         Idem DEFPRI avec des options supplÃĐmentaires
# ECRTRACE : Ecriture dans le fichier de trace ouvert selon paramÃĻtre stock STOTRACE
#            ( Cf. ECR_TRACE de GESECRAN )
#            !!!!!!! UtilisÃĐe dans STKVAL et SUBCGVB !!!!!!!!!
# DEFCPR         Routine calcul prix de revient pour calcul marge
# VALVCR : renvoie la somme des VARVAL des mouvements d'une piÃĻce
# VALVCR2 : renvoie la somme des VARVAL et ACTQTY des mouvements d'une piÃĻce
# LOADSDP : Charge l'ÃĐcran SDP Ã  partir du fichier spÃĐcifiÃĐ
# !!! Attention !!! On fait une addition pour le cas de la pile FIFO
# LOADSDPX : ?
# DEFPRIMKI : Renvoie le prix d'ordre Ã  attribuer Ã  une dÃĐclaration de production
# DEFPRISCI : Renvoie le prix d'ordre Ã  attribuer Ã  une dÃĐclaration de production EO
# SETNEWPRI : alimente le masque [M:VALW] avec le prix passÃĐ en paramÃĻtre
#             en dÃĐcomposant selon le prix de sortie
# GETOVE : Renvoie le code FG correspondant au couple article/type de mouvement
# LECOVE : se positionne sur le code FG ([F:OVE]) correspondant au couple article/type de mouvement
# SETNEWPRIOVE : idem SETNEWPRI mais calcule les FG au lieu de les rÃĐcupÃĐrer
# SETNEWPRIOVE2 : ?
# CALOVELIN : Calcule les FG pour un type de mouvement
#</gen>
########################################################################
#**#######################################################################
#** GETTCM : Recherche le code de la mÃĐthode de valo associÃĐe Ã  un article-site
#*          + Si la table TABCOSTMET [TCM] est ouverte on se positionne dessus
#*#######################################################################
# ParamÃĻtres E : PITM    = article
#                PFCY    = site
#            S : PTCM    = Code mÃĐthode de valorisation
#                PRET    = Code erreur (0 : OK
#                                       2 : Erreur lecture article
#                                       3 : Pas de mÃĐthode de valorisation )
########################################################################
Subprog GETTCM(PITM, PFCY, PTCM, PRET)
Value    Char PITM
Value    Char PFCY
Variable Char PTCM
Variable Integer PRET

Raz PTCM, PRET

If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif

#----- Lecture article-site si nÃĐcessaire -----#
If [F:ITF]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
    Read [ITF] ITF0=PITM;PFCY
    If fstat : PRET = 2 : End : Endif
Endif

#MJH X3-102842. Do not use VLTCOD from product catagory. It is now required on product site.
#If [F:ITF]VLTCOD=""
#    If [F:ITM]ITMREF<>PITM
#        Read [ITM]ITM0=PITM
#        If fstat : PRET = 2 : End : Endif
#    Endif
#    If [F:ITG]STOFCY<>PFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
#        Read [ITG]ITG0=PFCY;[F:ITM]TCLCOD
#    Endif
#    If fstat | [F:ITG]VLTCOD=""
#        Read [ITG]ITG0="";[F:ITM]TCLCOD
#        If fstat : PRET = 2 : End : Endif
#        If [F:ITG]VLTCOD=""
#            PRET=3
#            End
#        Endif
#    Endif
#    PTCM = [F:ITG]VLTCOD
#Else
#    PTCM = [F:ITF]VLTCOD
#Endif

PTCM = [F:ITF]VLTCOD

# Issue X3-193183 - 2020-07-30 by MIHAL : the previous change lost the ability to know when the valuation method was blank
#                                         this an oversight caused issues with products not stock tracked but had price lists such as subcontract services.
If PTCM=""
  PRET=3
  End
Endif

If clalev([F:TCM])
    Read [TCM]TCM0=PTCM
Endif

End

########################################################################
# GETTVM : Recherche la mÃĐthode de valorisation d'un type de mouvement
#          Si les tables TABCOSTMET [TCM] et TABCOSTMVT [TVM] sont ouvertes
#          elles sont positionnÃĐes
########################################################################
# ParamÃĻtres E : PITM    = article
#                PFCY    = site
#                PTRSTYP = Type de mouvement (m. 704)
#                PTRSCOD = Code mouvement
########################################################################
Funprog GETTVM(PITM, PFCY, PTRSTYP, PTRSCOD)
Value Char    PITM
Value Char    PFCY
Value Integer PTRSTYP
Value Char    PTRSCOD

If !find(func STKLIB.SENSTRS(PTRSTYP),1,-2) | find(PTRSTYP,14,28)
    End 0
Endif

If !clalev([F:TCM]) : Local File TABCOSTMET : Endif
If !clalev([F:TVM]) : Local File TABCOSTMVT : Endif

Local Char LTCM(GLONTCM)
Local Integer LRET, LRES

Call GETTCM(PITM,PFCY, LTCM, LRET)
If LRET : End 0 : Endif

Read [TVM]TVM0=LTCM;PTRSTYP;PTRSCOD
If fstat & PTRSCOD<>""
    Read [TVM]TVM0=LTCM;PTRSTYP;""
Endif
If !fstat
    LRES = [F:TVM]MVTVLT
Else
    LRES = [F:TCM]RCPVLTCOD
Endif

End LRES


########################################################################
# LOATCM : Charge l'enregistrement de la table TABCOSTMET [TCM]
#          correspondant Ã  l'article-site et de la table TABCOSTMVT [TVM]
#          s'il y a lieu.
# ParamÃĻtres E : PITM       = RÃĐfÃĐrence article
#                PFCY       = Site de stock
#                PTYP       = Type du mouvement (menu local 704)
#                PCOD       = Code mouvement
# ParamÃĻtres S : PRET       = Code retour (0=Ok,
#                                          2=Article-site non trouvÃĐ !)
#                                          3=MÃĐthode valorisation non trouvÃĐe !)
#                                          4=Table TCM non ouverte !)
########################################################################
Subprog LOATCM(PITM, PFCY, PTYP, PCOD, PRET)
Value    Char    PITM
Value    Char    PFCY
Value    Integer PTYP
Value    Char    PCOD
Variable Integer PRET

Raz PRET

If !clalev([F:TCM])
    PRET=4
    End
Endif

If !clalev ([F:TVM]) : Local File TABCOSTMVT [TVM] : Endif

Local Char LTCM(GLONTCM)

Call GETTCM(PITM,PFCY,LTCM,PRET)
If PRET
    End
Endif

Raz [F:TVM]
Read [TVM] TVM0=LTCM;PTYP;PCOD
If fstat & PCOD<>""
    Read [TVM] TVM0=LTCM;PTYP;""
Endif

If !fstat
    [F:TCM]RCPVLTCOD =[F:TVM]MVTVLT
    [F:TCM]RCPVLT2   =[F:TVM]MVTVLT2
    [F:TCM]NULPRI    =[F:TVM]MVTNUL
    [F:TCM]PRIREG    =[F:TVM]PRIREGX
Endif
End

########################################################################
# GETPRITAR : renvoie le prix tarif
########################################################################
# ParamÃĻtres E : PITM    = article
#                PPOHFCY = site d'achat
#                PPRHFCY = site de rÃĐception
#                PQTY    = quantitÃĐ en unitÃĐ de stock
#                PDAT    = date pour recherche tarif
#                PRCPDAT = date prÃĐvue de rÃĐception
#                PBPS    = fournisseur (si vide: fournisseur prÃĐfÃĐrentiel)
#                PPJT    = nÂ° affaire (facultatif)
#            S : La composante de prix matiÃĻre dans SDP est chargÃĐe
########################################################################
Funprog GETPRITAR(PITM,PECCMAJ,PECCMIN,PPOHFCY,PPRHFCY,PQTY,PDAT,PRCPDAT,PBPS,PPJT)
Value Char    PITM
Value Char    PECCMAJ
Value Char    PECCMIN
Value Char    PPOHFCY
Value Char    PPRHFCY
Value Decimal PQTY
Value Date    PDAT
Value Date    PRCPDAT
Value Char    PBPS
Value Char    PPJT

Local Decimal LPRI, LQTYPUU

    If !clalev([F:PSH]) : Local File PREQUIS    [PSH] : Endif
    If !clalev([F:PSD]) : Local File PREQUISD   [PSD] : Endif
    If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
    If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
    If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
    If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
    If !clalev([F:ITS]) : Local File ITMSALES   [ITS] : Endif
    If !clalev([F:ITP]) : Local File ITMBPS     [ITP] : Endif
    If !clalev([F:PPK]) : Local File PPRICLINK  [PPK] : Endif
    If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif

    Local Char LBPS(GLONBPS)
    # Recherche du fournisseur prÃĐfÃĐrentiel si non renseignÃĐ en paramÃĻtre
    Raz [F:ITP]
    If PBPS=""
        #----- Recherche fournisseur selon prioritÃĐ -----#
        For [ITP] ITP1 Where ITMREF=PITM
             Break
        Next
        LBPS = [F:ITP]BPSNUM
    Else
        LBPS = PBPS
        Read [ITP] ITP0=PITM;LBPS
    Endif
    If [F:ITM]ITMREF<>PITM
        Read [ITM]ITM0=PITM
    Endif

    # Calcul de la qtÃĐ en unitÃĐ d'achat
    If [F:ITP]PUUSTUCOE<>0
        LQTYPUU = PQTY / [F:ITP]PUUSTUCOE
        [F:PSD]PUU = [F:ITP]PUU
    Elsif [F:ITM]PUUSTUCOE<>0
        LQTYPUU = PQTY / [F:ITM]PUUSTUCOE
        [F:PSD]PUU = [F:ITM]PUU
    Else
        LQTYPUU = PQTY
        [F:PSD]PUU = [F:ITM]STU
    Endif

    # Recherche tarif
    [F:PSH]PSHFCY = PPOHFCY    # Site d'achat
    [F:PSH]PRQDAT = PDAT       # Date pour recherche tarif
    Call GETDEV([F:PSH]PSHFCY) From DEVSUB
    If GFINRSP="" : GFINRSP=GFCY : Endif

    [F:PSD]ITMREF = PITM
    If dim([F:SCI]ECCVALMAJ)>0  # Issue GA 07/2015
      [F:PSD]ECCVALMAJ = PECCMAJ
      [F:PSD]ECCVALMIN = PECCMIN
    Endif
    [F:PSD]BPSNUM = LBPS
    [F:PSD]QTYPUU = LQTYPUU
    [F:PSD]CUR    = GLOCALDEV
    [F:PSD]CHGTYP = GCHGTYP
    [F:PSD]LINBUY = ""         # Code acheteur
    [F:PSD]EXTRCPDAT = PRCPDAT
    [F:PSD]PJT = PPJT
    [F:PSD]PRHFCY = PPRHFCY
    Read [BPS] BPS0=[F:PSD]BPSNUM
    If fstat Raz [F:BPS] : Endif
    GPLISTC=[F:BPS]PLISTC
    Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
    Call TARIFCHGT(6)                From TRTPRICE
    Call RECH_TARIF("PSM",0)         From TRTACHTAR1

    # Issue 81896 - 2012-06-29 by CCC : Le prix est renvoyÃĐ en PUU, il faut donc le transformer en STU
    LPRI = [F:PSD]NETPRI
    If PQTY<>0
        LPRI*=LQTYPUU/PQTY
    Endif

    If clalev([M:SDP])
        Raz [M:SDP]
        [M:SDP]PRI = LPRI
        [M:SDP]MATCST(min(max(0,[F:ITM]BRDCOD-1),GACTMAT-1)) = [M:SDP]PRI
    Endif

End LPRI





########################################################################
# GETPRI Renvoie le prix d'un article
#        pour une certaine quantitÃĐ et une mÃĐthode de valo donnÃĐe
########################################################################
Subprog GETPRI(LITM,LECCMAJ,LECCMIN,LFCY,LDAT,LQTY,LLOT,LSLO,LVLT,LPRI,LRET)
Value    Char    LITM
Value    Char    LECCMAJ
Value    Char    LECCMIN
Value    Char    LFCY
Value    Date    LDAT
Value    Decimal LQTY
Value    Char    LLOT
Value    Char    LSLO
Value    Integer LVLT
Variable Decimal LPRI
Variable Integer LRET

Local Integer LSDP # Indicates if SDP screen exists and if using SDP or SDP2
Local Integer WMET : WMET = LVLT

  Raz LRET

  If dim(LNUMVLT)>0 & LNUMVLT=1
    If clalev([M:SDP2])
      Raz [M:SDP2]
      LSDP = 2
    Endif
  Else
    If clalev([M:SDP])
      Raz [M:SDP]
      LSDP = 1
    Endif
  Endif

  # We will be calling out to a new Syracused version of this function.
  #Data will be loaded into the class and copied back into the screen at the end
  Local Instance STKVAL Using C_STKVAL
  STKVAL = NewInstance C_STKVAL AllocGroup null

#FJCP-Inicio Punto de entrada - AURENV12
GPE=0
GPOINT="ZGETPRI"
Gosub ENTREE From EXEFNC
#FJCP-Fin Punto de entrada - AURENV12

  Case [L]WMET
    When 1 : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0)     # Standard
    When 2 : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0) # Revised Standard
    When 3 : LPRI = fmet STKVAL.GET_LAST_PRICE(LITM,LFCY)                       # Last price
    When 4 : LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)                              # Average Cost
    When 5 : LPRI = fmet STKVAL.GET_FIFO(LITM,LFCY,LQTY,0)                      # FIFO
    When 6 : LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)                    # Average Lot Cost
    When 7 : LPRI = LORDPRI                                                     # Order price
    When 8 : LPRI = fmet STKVAL.GET_LIFO(LITM,LFCY,LQTY,0)                      # LIFO
    When 9 : LPRI = fmet STKVAL.GET_LAST_PUR(LITM,LFCY)                         # Last purchase price
    When 10: LPRI = fmet STKVAL.GET_STD_BUD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0) # Budgeted Standard
    When 11: LPRI = fmet STKVAL.GET_STD_SIM(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0) # Simulated Standard
  Endcase


  #If SDP screen existed before, copy class back to screen
  Case LSDP
    When 1 : Call COPYSTKVAL_SDP(STKVAL,"SDP")
    When 2 : Call COPYSTKVAL_SDP(STKVAL,"SDP2")
  Endcase

  # We are done with the class now - release the memory
  FreeGroup STKVAL
  STKVAL = null

End

########################################################################
# GETPRISTD Renvoie le coÃŧt standard d'un article
########################################################################
# ParamÃĻtres E : LITM       = RÃĐfÃĐrence article
#                LFCY       = Site de stock
#                LDAT       = Date de rÃĐfÃĐrence
#                LUID       = NÂ° de process Ã  respecter pour la recherche de coÃŧt
#                LTYP       = Type de coÃŧt
#            S : LPRI       = Prix du mouvement
#                LRET       = Code retour (0=Ok, 1=Erreur dans le calcul)
#                                                2=Article-site non trouvÃĐ !)
#                                                3=MÃĐthode valorisation non trouvÃĐe !)
#                                                4=Prix nul non autorisÃĐ !)
########################################################################
Subprog GETPRISTD(LITM,LECCMAJ,LECCMIN,LFCY,LDAT,LUID,LTYP,LPRI,LRET)
Value    Char    LITM
Value    Char    LECCMAJ
Value    Char    LECCMIN
Value    Char    LFCY
Value    Date    LDAT
Value    Integer LUID
Value    Integer LTYP
Variable Decimal LPRI
Variable Integer LRET

Call GETPRISTD2(LITM,LECCMAJ,LECCMIN,LFCY,LDAT,LUID,LTYP,0,LPRI,LRET)

End

########################################################################
# GETPRISTD2 Renvoie le coÃŧt standard d'un article
########################################################################
# Idem GETPRISTD
# + ParamÃĻtre LDETVAL : 1=avoir le dÃĐtail du coÃŧt standard dans [SDP] quelque soit la valeur de SPD
########################################################################
Subprog GETPRISTD2(LITM,LECCMAJ,LECCMIN,LFCY,LDAT,LUID,LTYP,LDETVAL,LPRI,LRET)
Value    Char    LITM
Value    Char    LECCMAJ
Value    Char    LECCMIN
Value    Char    LFCY
Value    Date    LDAT
Value    Integer LUID
Value    Integer LTYP
Value    Integer LDETVAL
Variable Decimal LPRI
Variable Integer LRET

Local Integer LACTDECCST : LACTDECCST = func ASYRFNC.ACTIV("SPD")
Local Integer LSDP # Indicates if SDP screen exists and if using SDP or SDP2
Local Integer WMET : WMET = LTYP

  Raz LRET

  If dim(LNUMVLT)>0 & LNUMVLT=1
    If clalev([M:SDP2])
      Raz [M:SDP2]
      LSDP = 2
    Endif
  Else
    If clalev([M:SDP])
      Raz [M:SDP]
      LSDP = 1
    Endif
  Endif

  # We will be calling out to a new Syracused version of this function.
  #Data will be loaded into the class and copied back into the screen at the end
  Local Instance STKVAL Using C_STKVAL
  STKVAL = NewInstance C_STKVAL AllocGroup null

  #MJH X3-105229 Standard cost inquiry uses 3 and 4 for budgeted and simulated costs
  Case [L]WMET
    When 1     : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,LUID,LDETVAL)     # Standard
    When 2     : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,LUID,LDETVAL) # Revised Standard
    When 10, 3 : LPRI = fmet STKVAL.GET_STD_BUD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,LUID,LDETVAL) # Budgeted Standard
    When 11, 4 : LPRI = fmet STKVAL.GET_STD_SIM(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,LUID,LDETVAL) # Simulated Standard
  Endcase

  #If SDP screen existed before, copy class back to screen
  Case LSDP
    When 1 : Call COPYSTKVAL_SDP(STKVAL,"SDP")
    When 2 : Call COPYSTKVAL_SDP(STKVAL,"SDP2")
  Endcase

  # We are done with the class now - release the memory
  FreeGroup STKVAL
  STKVAL = null

End

########################################################################
# DEFPRI         Routine calcul prix par dÃĐfaut des mvts de stock
########################################################################
# ParamÃĻtres E : LITM       = RÃĐfÃĐrence article
#                LFCY       = Site de stock
#                LTYP       = Type du mouvement (menu local 704)
#                             Mettre 0 pour traiter la base calcul de marge
#                LCOD       = Code du mouvement (table diverse 14)
#                LLOT       = NumÃĐro de lot
#                LSLO       = Sous-lot
#                LDAT       = Date de rÃĐfÃĐrence
#                LQTYTOT    = QuantitÃĐ lignes document
#                             (pour sorties FIFO (>0) et inventaires)
#                LQTYMVT    = QuantitÃĐ mouvement
#                LORDPRI    = Prix de l'ordre (rÃĐception, suivi OF)
#            S : LPRINAT    = Nature de prix
#                LPRI       = Prix du mouvement
#                LRET       = Code retour (0=Ok, 1=Erreur dans le calcul)
#                                                2=Article-site non trouvÃĐ !)
#                                                3=MÃĐthode valorisation non trouvÃĐe !)
#                                                4=Prix nul non autorisÃĐ !)
#                                                5=Tables Stocks et prix FIFO dÃĐsynchronisÃĐes !)
########################################################################
Subprog DEFPRI(LITM,LECCMAJ,LECCMIN,LFCY,LTYP,LCOD,LLOT,LSLO,LDAT,LQTYTOT,LQTYMVT,LORDPRI,LPRINAT,LPRI,LRET)
Value    Char    LITM
Value    Char    LECCMAJ
Value    Char    LECCMIN
Value    Char    LFCY
Value    Integer LTYP
Value    Char    LCOD
Value    Char    LLOT
Value    Char    LSLO
Value    Date    LDAT
Value    Decimal LQTYTOT
Value    Decimal LQTYMVT
Value    Decimal LORDPRI
Variable Integer LPRINAT
Variable Decimal LPRI
Variable Integer LRET

  Call DEFPRI2(LITM,LECCMAJ,LECCMIN,LFCY,LTYP,LCOD,LLOT,LSLO,LDAT,LQTYTOT,LQTYMVT,LORDPRI,LPRINAT,LPRI,-1,"",LRET)

End

########################################################################
# DEFPRI2         Idem DEFPRI avec des options supplÃĐmentaires
########################################################################
# ParamÃĻtres E : LLIGW      = Indice dans le masque STOVALW [VALW] pour rÃĐcupÃĐrer le prix de l'ordre
#                LSUP       = "R" : impose l'utilisation de la mÃĐthode d'entrÃĐe
#                             "I" : impose l'utilisation de la mÃĐthode de sortie
#                             "O" : indique que LQTYTOT est un offset
########################################################################
Subprog DEFPRI2(LITM,LECCMAJ,LECCMIN,LFCY,LTYP,LCOD,LLOT,LSLO,LDAT,LQTYTOT,LQTYMVT,LORDPRI,PPRINAT,PPRI,LLIGW,LSUP,LRET)
Value    Char    LITM
Value    Char    LECCMAJ
Value    Char    LECCMIN
Value    Char    LFCY
Value    Integer LTYP
Value    Char    LCOD
Value    Char    LLOT
Value    Char    LSLO
Value    Date    LDAT
Value    Decimal LQTYTOT
Value    Decimal LQTYMVT
Value    Decimal LORDPRI
Variable Integer PPRINAT()
Variable Decimal PPRI()
Value    Integer LLIGW
Value    Char    LSUP
Variable Integer LRET

#----- Variables locales -----#
Local    Libelle WVLT, WVLT2, WNUL
Local    Integer WMET
Local    Decimal LQTY
Local    Decimal LQTYOFF
Local    Char    LTCM(GLONTCM)
Local    Integer LNUMVLT
Local    Decimal LPRI
Local    Integer LACTDECCST : LACTDECCST = func ASYRFNC.ACTIV("SPD")
Local    Integer SDPACT, SDP2ACT
Local    Integer LDEF7
  #-----
  Raz PPRINAT, PPRI, LRET
  #----- Par sÃĐcuritÃĐ, ne devrait pas ÃŠtre nÃĐcessaire -----#
  If !clalev([F:TCM])  Local File TABCOSTMET [TCM] : Endif
  If !clalev([F:TVM])  Local File TABCOSTMVT [TVM] : Endif
  If !clalev([F:ITF])  Local File ITMFACILIT [ITF] : Endif
  If !clalev([F:ITM])  Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITG])  Local File ITMCATEG   [ITG] : Endif
  If !clalev([F:TCU])  Local File TABCUR     [TCU] : Endif

  #----- Lecture article-site si nÃĐcessaire -----#
  If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF] ITF0=LITM;LFCY
    If fstat  LRET=2 : End : Endif
  Endif

  Call GETTCM(LITM, LFCY, LTCM, LRET)
  If LRET | LTCM=""
    End
  Endif

  If instr(1,LSUP,"O")
    LQTY = LQTYMVT
    LQTYOFF = LQTYTOT
  Else
    LQTY = LQTYTOT
    LQTYOFF = 0
  Endif

  If clalev ([M:SDP])
    Raz [M:SDP] : SDPACT = 1
  Endif
  If clalev ([M:SDP2])
    Raz [M:SDP2]: SDP2ACT = 1
  Endif

  For LNUMVLT=0 To (dim([F:TCM]ISSVLTCOD)>1 & [F:TCM]ISSVLTCOD(1)>0 & clalev([M:SDP2]))
    LDEF7 = [V]CST_ANO

    #---- DÃĐtermination des mÃĐthodes Ã  utiliser ---#
    Gosub DETVLT

    # Issue 95942 - 2014-02-25 by CCC : LQTY can be negative for counts but for FIFO value, LQTY has to be positive
    LQTY=abs(LQTY)

    # CCC (31/08/04) Bug 24463 : La recherche du prix standard actualisÃĐ doit aussi se baser sur la date de calcul
    #                            Ce point d'entrÃĐe permet entre autre de conserver le fonctionnement prÃĐcÃĐdent
    GPE  = 0
    GPOINT="DEFPRI"
    Gosub ENTREE From EXEFNC
    If !GPE

      Local Instance STKVAL Using C_STKVAL
      STKVAL = NewInstance C_STKVAL AllocGroup null

      #----- Calcul prix avec le code valorisation -----#
      [L]WMET = [L]WVLT
      Case [L]WVLT
        When 1 : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0)     # Standard
        When 2 : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0) # Revised Standard
        When 3 : LPRI = fmet STKVAL.GET_LAST_PRICE(LITM,LFCY)                       # Last price
        When 4 : LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)                              # Average Cost
        When 5 : LPRI = fmet STKVAL.GET_FIFO(LITM,LFCY,LQTY,LQTYOFF)                # FIFO
        When 6 : LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)                    # Average Lot Cost
        When 7 : Gosub TRT_DEF7 : If clalev([M:SDP]) & [M:SDP]PRI <> 0 : LDEF7 = [V]CST_AYES : Endif  # Order price
        When 8 : LPRI = fmet STKVAL.GET_LIFO(LITM,LFCY,LQTY,LQTYOFF)                # LIFO
        When 9 : LPRI = fmet STKVAL.GET_LAST_PUR(LITM,LFCY)                         # Last purchase price
      Endcase
      If LRET<>0  End : Endif

      PPRINAT(LNUMVLT)=[L]WVLT+1
      #----- Si prix nul, calcul prix avec le code valorisation repli -----#
      If LPRI=0
        # Si la mÃĐthode principale est PM lot, il ne faut pas tenir compte de toute la qtÃĐ pour le calcul en FIFO
        # mais uniquement de la quantitÃĐ du mouvement
        If find([L]WVLT2,5,8) & [L]WVLT=6
          LQTY = abs(LQTYMVT)
        Endif
        [L]WMET = [L]WVLT2
        Case [L]WVLT2
          When 1 : LPRI = fmet STKVAL.GET_STD(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0)     # Standard
          When 2 : LPRI = fmet STKVAL.GET_STD_REV(LITM,LFCY,LECCMAJ,LECCMIN,LDAT,0,0) # Revised Standard
          When 3 : LPRI = fmet STKVAL.GET_LAST_PRICE(LITM,LFCY)                       # Last price
          When 4 : LPRI = fmet STKVAL.GET_AVC(LITM,LFCY)                              # Average Cost
          When 5 : LPRI = fmet STKVAL.GET_FIFO(LITM,LFCY,LQTY,LQTYOFF)                # FIFO
          When 6 : LPRI = fmet STKVAL.GET_ALC(LITM,LFCY,LLOT,LSLO)                    # Average Lot Cost
          When 7 : Gosub TRT_DEF7 : If clalev([M:SDP]) & [M:SDP]PRI <> 0 : LDEF7 = [V]CST_AYES : Endif  # Order price
          When 8 : LPRI = fmet STKVAL.GET_LIFO(LITM,LFCY,LQTY,LQTYOFF)                # LIFO
          When 9 : LPRI = fmet STKVAL.GET_LAST_PUR(LITM,LFCY)                         # Last purchase price
        Endcase
        If !LRET
          #----- Teste si prix nul autorisÃĐ ? -----#
          If LPRI=0 & [L]WNUL<>2 & LTYP<>13
            LRET=4 : Break
          Elsif LPRI=0
            PPRINAT(LNUMVLT)=[L]WVLT+1
          Else
            PPRINAT(LNUMVLT)=[L]WVLT2+1
          Endif
        Else
          Break
        Endif
      Endif
      If LDEF7 = [V]CST_ANO
        # Copy the data back from the class to correct screen
        If LNUMVLT=0 & SDPACT  : Call COPYSTKVAL_SDP(STKVAL,"SDP") : Endif
        If LNUMVLT=1 & SDP2ACT : Call COPYSTKVAL_SDP(STKVAL,"SDP2"): Endif
      Endif
      FreeGroup STKVAL
      STKVAL = null

    Endif
    PPRI(LNUMVLT) = LPRI
  Next
End

###################################################
# Alimente les variables WVLT, WVLT2 et WNUL
###################################################
$DETVLT
    #----- Lecture table valorisation mouvement -----#
    Raz [F:TVM]
    If LTYP<>13
        If LTYP=10    # RÃĐception transfert inter-sites (inactif)    -> valeur temporaire utilisÃĐe dans STKVALMAJ pour diffÃĐrencier l'entrÃĐe de la sortie
            Read [TVM] TVM1=LTCM;LNUMVLT+1;14;LCOD
            If fstat & LCOD<>""
              Read [TVM] TVM1=LTCM;LNUMVLT+1;14;""
            Endif
        Else
            Read [TVM] TVM1=LTCM;LNUMVLT+1;LTYP;LCOD
            If fstat & LCOD<>""
              Read [TVM] TVM1=LTCM;LNUMVLT+1;LTYP;""
            Endif
        Endif
    Endif
    If !fstat & [F:TVM]MVTVLT<>0 & (!instr(1,LSUP,"R") | !instr(1,LSUP,"I"))
      [L]WVLT =[F:TVM]MVTVLT
      [L]WVLT2=[F:TVM]MVTVLT2
      [L]WNUL =[F:TVM]MVTNUL
    Else
      #----- Lecture table mÃĐthode de valorisation -----#
      Read [TCM] TCM0=LTCM
      If fstat  LRET=3 : End : Endif
      # Si valo entrÃĐe forcÃĐe ou inventaire avec prix d'ordre renseingnÃĐ et mÃĐthode d'entrÃĐe au prix de l'ordre
      # => on prend la valo d'entrÃĐe
      If instr(1,LSUP,"R") | LTYP=13 & LORDPRI<>0 & [F:TCM]RCPVLTCOD(LNUMVLT)=7
          [L]WVLT =[F:TCM]RCPVLTCOD(LNUMVLT)
          [L]WVLT2=[F:TCM]RCPVLT2(LNUMVLT)
          [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
      Elsif instr(1,LSUP,"I")
          [L]WVLT =[F:TCM]ISSVLTCOD(LNUMVLT)
          [L]WVLT2=[F:TCM]ISSVLT2(LNUMVLT)
          [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
      Else
          Case func STKLIB.SENSTRS(LTYP)
            When -2,1          : # Sorties- et EntrÃĐes
              [L]WVLT =[F:TCM]RCPVLTCOD(LNUMVLT)
              [L]WVLT2=[F:TCM]RCPVLT2(LNUMVLT)
              [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
            When 2,-1          : # Sorties et EntrÃĐes-
              [L]WVLT =[F:TCM]ISSVLTCOD(LNUMVLT)
              [L]WVLT2=[F:TCM]ISSVLT2(LNUMVLT)
              [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
            When Default :
                Case LTYP
                  When 13 :                      # Inventaires
                      # Le code mouvement "SNX" est passÃĐ lors de la crÃĐation d'un inventaire
                      # afin de valoriser le stock comme en sortie (-> donne une valeur indicative du stock)
                      If LCOD="SNX"
                        [L]WVLT =[F:TCM]ISSVLTCOD(LNUMVLT)
                        [L]WVLT2=[F:TCM]ISSVLT2(LNUMVLT)
                        [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
                      Elsif LQTYMVT>=0    #CCC (05/10/04) Bug 25509 : Inversion de la valorisation des ÃĐcarts d'inventaire
                        [L]WVLT =[F:TCM]CUNPOS(LNUMVLT)
                        [L]WVLT2=[F:TCM]CUNPOS2(LNUMVLT)
                        [L]WNUL =1    # permet d'utiliser la valeur de repli au cas oÃđ
                      Else
                        [L]WVLT =[F:TCM]CUNNEG(LNUMVLT)
                        [L]WVLT2=[F:TCM]CUNNEG2(LNUMVLT)
                        [L]WNUL =1    # permet d'utiliser la valeur de repli au cas oÃđ
                      Endif
                  When 7,8,9,17,18,20 :                    # Changements stock et contrÃīle qualitÃĐ, Transferts inter-site, Livraisons et retour de prÃŠt
                       # Issue X3-54040 - 2017-10-12 by ERMIL : Value Subcontract delivery if value internal is yes (added 20 to the When above)
                      [L]WVLT =[F:TCM]ISSVLTCOD(LNUMVLT)
                      [L]WVLT2=[F:TCM]ISSVLT2(LNUMVLT)
                      [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
                  When 14 :  # EntrÃĐe transfert inter-sites (pour la sortie, le param LSUP="I")
                      [L]WVLT =[F:TCM]RCPVLTCOD(LNUMVLT)
                      [L]WVLT2=[F:TCM]RCPVLT2(LNUMVLT)
                      [L]WNUL =[F:TCM]NULPRI(LNUMVLT)
                Endcase
          Endcase
      Endif
    Endif
Return

$PRI2SDP
    Local Char LSAVITM : Raz LSAVITM
    If [F:ITM]ITMREF<>LITM
        LSAVITM = [F:ITM]ITMREF
        Read [ITM]ITM0 = LITM
    Endif
    Assign "[M:SDP"+string$(dim(LNUMVLT)>0&LNUMVLT=1,"2")+"]MATCST(max(0,[F:ITM]BRDCOD-1))" With LPRI
    If LSAVITM<>""
        Read [ITM]ITM0 = LSAVITM
    Endif
Return

#MJH 120183.sn
#Returns the average price of an item for all lots
Funprog GLOBAL_LOT_PRI(PITMREF,PSTOFCY)
  Value Char PITMREF
  Value Char PSTOFCY

  Local Decimal AMT
  Local Decimal QTY
  Local Decimal PRICE

  If !clalev([F:SLF]) : Local File STOLOTFCY  [SLF] : Endif

  Filter [SLF] Where ITMREF = PITMREF & STOFCY = PSTOFCY & AVCBASQTY>0

  For [SLF]
    AMT += [F:SLF]AVCBASAMT
    QTY += [F:SLF]AVCBASQTY
  Next
  Filter [SLF]
  If QTY = 0 : End 0 : Endif
  PRICE = AMT/QTY

End PRICE
#MJH 120183.en

#-----------------------#
# Prix d'ordre          #
#-----------------------#
$TRT_DEF7
    LPRI=LORDPRI
    If clalev([M:SDP])
        If clalev([M:SDP2]) & dim(LNUMVLT)>0 & LNUMVLT=1
            Raz [M:SDP2]
        Else
            Raz [M:SDP]
        Endif
    Endif
    If evalue("clalev([M:SDP"+string$(dim(LNUMVLT)>0&LNUMVLT=1,"2")+"])")
        Assign "[M:SDP"+string$(dim(LNUMVLT)>0&LNUMVLT=1,"2")+"]PRI" With LORDPRI
        If GACTDECCST & LLIGW>=0
            Call LOAD_VALX("SDP"+string$(dim(LNUMVLT)>0&LNUMVLT=1,"2"),LLIGW) From SUBSDP
        Else
            Gosub PRI2SDP
        Endif
    Endif
Return

