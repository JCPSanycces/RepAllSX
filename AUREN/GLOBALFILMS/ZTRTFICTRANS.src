#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Tratamiento para generacion de fichero interface para comunicacion expedicion a transportista y su software de etiquetado.
#Actualmente TSB y Gallastegui
$ACTION
#Infbox ACTION
Case ACTION
   When "INIT"        : Gosub INIT
   When "CONTROLE"    : Gosub CONTROLE
   When "EXEC"        : Gosub EXEC
   When Default
Endcase
Return

#PARAM(1) - Numero de entrega
#PARAM(2) - Boton pulsado (1-TSB / 2-Gallastegui)
$INIT
Local Char NUMDOC(25)
Local Integer TIPFIC
Local Char FICSRV(250), FICCLI(250), NOMFIC(250)
Local Char DIRAPL(250)

#Recuperamos el directorio de la aplicación
DIRAPL=filpath("","","","","",adxmac(0))

NUMDOC=PARAM(1)
TIPFIC=val(PARAM(2))
#Infbox NUMDOC+" "+num$(TIPFIC)

If clalev([F:SDHX])<=0  :  Local File SDELIVERY  [SDHX]  :  Endif
If clalev([F:ZTDX])<=0  :  Local File ZTEXDOC    [ZTDX]  :  Endif
If clalev([F:BPTX])<=0  :  Local File BPCARRIER  [BPTX]  :  Endif
If clalev([F:BPRX])<=0  :  Local File BPARTNER   [BPRX]  :  Endif
If clalev([F:SOHX])<=0  :  Local File SORDER     [SOHX]  :  Endif
If clalev([F:ICTDX])<=0 :  Local File INCOTERMD  [ICTDX] :  Endif
If clalev([F:CNTX])<=0  :  Local File CONTACT    [CNTX]  :  Endif
If clalev([F:AINX])<=0  :  Local File CONTACTCRM [AINX]  :  Endif
If clalev([F:FCYX])<=0  :  Local File FACILITY   [FCYX]  :  Endif
If clalev([F:CPYX])<=0  :  Local File COMPANY    [CPYX]  :  Endif
If clalev([F:BPAPX])<=0 :  Local File BPADDRESS  [BPAPX] :  Endif : #Direccion planta
If clalev([F:BPACX])<=0 :  Local File BPADDRESS  [BPACX] :  Endif : #Direccion cliente
Return

$CONTROLE
Local Integer OK, STAT

OK=1
Raz [F:SDHX]
Read [SDHX]SDH0=NUMDOC
If fstat
   Infbox "Problema recuperación datos Entrega. fstat: "+num$(fstat)
   OK=0
Endif

Raz [F:BPTX]
Read [BPTX]BPT0=[F:SDHX]BPTNUM
If fstat
   Infbox "Trasnportista no informado. fstat: "+num$(fstat)
   OK=0
Endif
If len([F:BPTX]ZDIREXP)=0
   Infbox "Directorio expediciones no informado"
   OK=0
Endif

If len([F:SDHX]EECICT)=0
   Infbox "Incoterm no informado"
   OK=0
Endif

Raz [F:BPRX]
Read [BPRX]BPR0=[F:SDHX]BPCORD
If fstat
   Infbox "Problema recuperacion datos cliente. fstat: "+num$(fstat)
   OK=0
Endif

Raz [F:CPYX]
Read [CPYX]CPY0=[F:SDHX]CPY
If fstat
   Infbox "Problema recuperacion datos sociedad. fstat: "+num$(fstat)
   OK=0
Endif

Raz [F:FCYX]
Read [FCYX]FCY0=[F:SDHX]SALFCY
If fstat
   Infbox "Problema recuperacion datos planta. fstat: "+num$(fstat)
   OK=0
Endif

If !OK
   FIN=1
Endif
Return

#TIPFIC -> 1 - TSB (TRANS-SABADELL)
#          2 - Gallastegui
$EXEC
Local Integer WRESP

#Wrnbox "Continuar? " Using WRESP

#If WRESP<>1
#   Return
#Endif

Case TIPFIC
   When 1  :  Gosub TRT_TSB
   When 2  :  Gosub TRT_GALLAS
Endcase
Return

#Generacion fichero expedicion TransSabadell (TSB)
$TRT_TSB
Local Char CENREM(4), NIFBPC(20), PERCON(100), TELCON(50), TIPPOR(1)
Local Char TKMAILIDIO(5), TKMAIL(120), OBSERV(250)
Local Char WZFECAPL, WZFECMAX

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

Raz CENREM
#Hasta ahora 30/01/2017
#If [F:SDHX]BPDCRY="ES" or [F:SDHX]BPDCRY="PT"
#   CENREM=[F:BPTX]ZCODCEN1
#Else
#   CENREM=[F:BPTX]ZCODCEN2
#Endif

#A partir de ahora 30/01/2017
#If GUSER="ADMIN"
#   If [F:FCYX]CRY="ES" or [F:FCYX]CRY="PT" or [F:FCYX]CRY="AD"
#      CENREM="01"
#   Else
#      If [F:FCYX]CRY="IT"
#         CENREM="03"
#      Else
#         CENREM="02"
#      Endif
#   Endif
#Endif

#JLPR 20-02-17 INI   Tras hablar con Marta se acuerda
Case [F:FCYX]CRY
When "ES"
  If [F:SDHX]BPDCRY="ES"
    CENREM="01"
  Else
    CENREM="02"
Endif
When "IT"
  CENREM="03"
When Default
  Infbox "Avise al programador...No se acordó valor para los envios desde pais "+[F:FCYX]CRY
  Return
Endcase
#JLPR 20-02-17 FIN

Raz NIFBPC
If len([F:BPRX]CRN)<>0
   NIFBPC=[F:BPRX]CRN
Else
   NIFBPC=[F:BPRX]EECNUM
Endif

#Persona de contacto destinatario
Raz PERCON
Raz TELCON
Raz TKMAILIDIO
Raz TKMAIL
Raz [F:CNTX]
Filter [CNTX] Where BPATYP=1 and BPANUM=[F:SDHX]BPCORD and CNTFNC=6 : #CNTFNC:Tarifas
For [CNTX]
    Raz [F:AINX]
    Read [AINX]AIN0=[F:CNTX]CCNCRM
    PERCON=[F:AINX]CNTFNA+" "+[F:AINX]CNTLNA
    TELCON=[F:CNTX]TEL
    TKMAILIDIO=[F:AINX]CNTLAN
    TKMAIL=[F:CNTX]WEB
    Break
Next
Filter [CNTX]

Raz [F:ICTDX]
Read [ICTDX]ICTD0=[F:SDHX]EECICT;6 :#6-Transporte principal (Naturaleza gasto)

Raz TIPPOR
If [F:ICTDX]CSTPYR=2
   #2 -> Comprador
   TIPPOR="D"
Else
   #1,3,4 -> Vendedor
   TIPPOR="P"
Endif

Raz [F:SOHX]
Read [SOHX]SOH0=[F:SDHX]SOHNUM

Raz [F:ZTDX]
#Read [ZTDX]ZTDOC0=4;[F:SDHX]SDHNUM : #4 -> Entrega
Read [ZTDX]ZTDOC0=2;[F:SDHX]SOHNUM : #2 -> Pedido de venta

#Direccion de la planta
Raz [F:BPAPX]
Read [BPAPX]BPA0=3;[F:SDHX]STOFCY

#Direccion del cliente
Raz [F:BPACX]
Read [BPACX]BPA0=1;[F:SDHX]BPCORD

Raz OBSERV
OBSERV=[F:ZTDX]LINTEX7+" "+[F:ZTDX]LINTEX8+" "+[F:ZTDX]LINTEX9

Call OUVRE_TRACE("Generación fichero expedición TSB ") From LECFIC
Call ECR_TRACE("Generación fichero TSB",0) From GESECRAN

Call ECR_TRACE("Número Entrega: "+NUMDOC,0) From GESECRAN
Call ECR_TRACE("Origen: "+[F:FCYX]CRY+" Destino:"+[F:SDHX]BPDCRY+"  Centro facturación TSB:"+CENREM,0) From GESECRAN
NOMFIC="TSB_"+NUMDOC+"_"+format$("D:YYYYMMDD",date$)

#&        [F:SDHX]SOHNUM,format$("D:DD/MM/YYYY",[F:SDHX]ZFECENTAPL),format$("D:DD/MM/YYYY",
#[F:SDHX]ZFECENTMAX),

WZFECAPL = "          "
WZFECMAX = "          "

If [F:SDHX]ZFECENTAPL > [01/01/1900]  :   WZFECAPL = format$("N0:2X",day([F:SDHX]ZFECENTAPL))+ '/' + format$("N0:2X",month([F:SDHX]ZFECENTAPL))+ '/' + format$("N0:4X",year([F:SDHX]ZFECENTAPL))   :   Endif

If [F:SDHX]ZFECENTMAX > [01/01/1900]   :   WZFECMAX = format$("N0:2X",day([F:SDHX]ZFECENTMAX))+ '/' + format$("N0:2X",month([F:SDHX]ZFECENTMAX))+ '/' + format$("N0:4X",year([F:SDHX]ZFECENTMAX))   :   Endif

Openo filpath("ZTRAN\"+[F:BPTX]ZDIREXP,NOMFIC,"TXT"),0 Using [FIC]
   Wrseq [F:SDHX]SDHNUM,[F:BPTX]ZCODCLITRA,CENREM,[F:SDHX]BPDNAM(0),[F:SDHX]BPDADDLIG(0),
&        [F:SDHX]BPDCRY,[F:SDHX]BPDPOSCOD,[F:SDHX]BPDCTY,NIFBPC,PERCON,TELCON,
&        num$([F:SDHX]PACNBR),num$([F:SDHX]GROWEI),num$([F:SDHX]VOL),TIPPOR,
&        OBSERV,
&        [F:SDHX]SOHNUM,
&        WZFECAPL, 
&        WZFECMAX,
&        [F:SDHX]ZAGRUEXP,"","","","","","","","","",TKMAILIDIO,TKMAIL,"","" Using [FIC]

Openo Using [FIC]

Call ECR_TRACE("Fin generación fichero expedición TSB ",0) From GESECRAN
Call FERME_TRACE From LECFIC

#FICSRV=DIRAPL+"\"+[F:BPTX]ZDIREXP+"\"+NOMFIC+".TXT"
#FICCLI="C:\TEMP\"+NOMFIC+".TXT"
#Call COPCLI(FICSRV,FICCLI,STAT) From ORDSYS
#  If STAT=1
#   # Fichier non copié sur le poste client
#   #STA = -1 : Call ERREUR(mess(164,141,1)) From GESECRAN
#   Call ECR_TRACE("Fichero no copiado: "+NOMFIC,1) From GESECRAN
#  Endif
TRA = 1
Return

#Generacion fichero expedicion Gallastegui
$TRT_GALLAS
Local Char CENREM(4), NIFBPC(20), PERCON(100), TELCON(50), TIPPOR(1)
Local Char CODPAIREM(3), CODPAIDES(3)
Local Char TKMAILIDIO(5), TKMAIL(120), OBSERV(250)

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

#En Gallastegui no se diferencia el centro de facturacion del remitente, por tanto sera ZCODCEN1 siempre
Raz CENREM
If [F:SDHX]BPDCRY="ES" or [F:SDHX]BPDCRY="PT"
   CENREM=[F:BPTX]ZCODCEN1
Else
   CENREM=[F:BPTX]ZCODCEN1
Endif
Raz NIFBPC
If len([F:BPRX]CRN)<>0
   NIFBPC=[F:BPRX]CRN
Else
   NIFBPC=[F:BPRX]EECNUM
Endif

#Persona de contacto destinatario
Raz PERCON
Raz TELCON
Raz TKMAILIDIO
Raz TKMAIL
Raz [F:CNTX]
Filter [CNTX] Where BPATYP=1 and BPANUM=[F:SDHX]BPCORD and CNTFNC=6 : #CNTFNC:Tarifas
For [CNTX]
    Raz [F:AINX]
    Read [AINX]AIN0=[F:CNTX]CCNCRM
    PERCON=[F:AINX]CNTFNA+" "+[F:AINX]CNTLNA
    TELCON=[F:CNTX]TEL
    TKMAILIDIO=[F:AINX]CNTLAN
    TKMAIL=[F:CNTX]WEB
    Break
Next
Filter [CNTX]

Raz [F:ICTDX]
Read [ICTDX]ICTD0=[F:SDHX]EECICT;6 :#6-Transporte principal (Naturaleza gasto)

Raz TIPPOR
If [F:ICTDX]CSTPYR=2
   #2 -> Comprador
   TIPPOR="D"
Else
   #1,3,4 -> Vendedor
   TIPPOR="P"
Endif

Raz [F:SOHX]
Read [SOHX]SOH0=[F:SDHX]SOHNUM

Raz [F:ZTDX]
#Read [ZTDX]ZTDOC0=4;[F:SDHX]SDHNUM : #4 -> Entrega
Read [ZTDX]ZTDOC0=2;[F:SDHX]SOHNUM : #2 -> Pedido de venta

#Direccion de la planta
Raz [F:BPAPX]
Read [BPAPX]BPA0=3;[F:SDHX]STOFCY

#Direccion del cliente
Raz [F:BPACX]
Read [BPACX]BPA0=1;[F:SDHX]BPCORD

Raz OBSERV
OBSERV=[F:ZTDX]LINTEX7+" "+[F:ZTDX]LINTEX8+" "+[F:ZTDX]LINTEX9

Raz CODPAIREM
Raz CODPAIDES

CODPAIREM="011" :# ESPAŃA
If [F:SDHX]BPDCRY="ES"
   CODPAIDES="011" :# ESPAŃA
Endif

Call OUVRE_TRACE("Generación fichero expedición Gallastegui ") From LECFIC
Call ECR_TRACE("Generación fichero Gallastegui",0) From GESECRAN

Call ECR_TRACE("Número Entrega: "+NUMDOC,0) From GESECRAN

NOMFIC="GALL_"+NUMDOC+"_"+format$("D:YYYYMMDD",date$)
Openo filpath([F:BPTX]ZDIREXP,NOMFIC,"TXT"),0 Using [FIC]
   Wrseq [F:BPTX]ZCODCLITRA,[F:CPYX]CPYNAM,CENREM,"",[F:BPTX]ZCODCLITRA,[F:CPYX]CPYNAM,[F:BPAPX]BPAADDLIG(0),
&        CODPAIREM,mid$([F:BPAPX]POSCOD,1,5),[F:BPAPX]CTY,[F:FCYX]CRN,[F:BPAPX]TEL(0),[F:SDHX]BPCORD,
&        [F:SDHX]BPDNAM(0),[F:SDHX]BPDADDLIG(0),CODPAIDES,[F:SDHX]BPDPOSCOD,[F:SDHX]BPDCTY,
&        NIFBPC,[F:BPACX]TEL(0),mid$(OBSERV,1,70),mid$(OBSERV,71,70),
&        num$([F:SDHX]PACNBR),num$(format$("N:17",[F:SDHX]GROWEI)),num$(format$("N:17",[F:SDHX]VOL)),
&        [F:SDHX]SDHNUM,"0","900","0","0","0","0","0","1",
&        TIPPOR  Using [FIC]

Openo Using [FIC]

Call ECR_TRACE("Fin generación fichero expedición Gallastegui ",0) From GESECRAN
Call FERME_TRACE From LECFIC

FICSRV=DIRAPL+"\"+[F:BPTX]ZDIREXP+"\"+NOMFIC+".TXT"
FICCLI="C:\TEMP\"+NOMFIC+".TXT"
Call COPCLI(FICSRV,FICCLI,STAT) From ORDSYS
  If STAT=1
   # Fichier non copié sur le poste client
   #STA = -1 : Call ERREUR(mess(164,141,1)) From GESECRAN
   Call ECR_TRACE("Fichero no copiado: "+NOMFIC ,1) From GESECRAN
  Endif
TRA = 1
Return


