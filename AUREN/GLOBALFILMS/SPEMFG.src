#    Gosub CALCULA_ANCHOMINIMO
#    Gosub CALCULA_LONGITUDTOTAL
#    Gosub CALCULA_MERMA
#    mkstat=4
  Call RECALCULAR(NOL)
  Gosub CALCULO_A_PRODUCIR  #  Codigo comun tras ańadir & Modificar
  [M:MFG1]ZACTU = 2 # Para impedir que cargue pedidos en SETBOUT
Endif
ZGMODLINCOR=0
Return

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer NOL, NOLX
NOL=nolign-1
If [F:ITM]ZFABCOR=2 Then
   If ZGMODLINCOR=0 : mkstat=2:  End : Endif
   [M:MFG1]ZFABCOR(NOL)=[F:ITM]ZFABCOR
   ZGMODLINCOR=0
Else
   [M:MFG1]ZFABCOR(NOL)=1
   [M:MFG1]ZANCHO(NOL)=0
   [M:MFG1]ZLONGITUD(NOL)=0
   [M:MFG1]ZNTIRADAS(NOL)=0
   [M:MFG1]ZNRANCHO(NOL)=0
   [M:MFG1]ZSUPERFICE(NOL)=0
   [M:MFG1]ZQTYBOB(NOL)=0
   Affzo [M:MFG1]ZFABCOR(NOL)
   Affzo [M:MFG1]ZANCHO(NOL)
   Affzo [M:MFG1]ZLONGITUD(NOL)
   Affzo [M:MFG1]ZNTIRADAS(NOL)
   Affzo [M:MFG1]ZNRANCHO(NOL)
   Affzo [M:MFG1]ZSUPERFICE(NOL)
   Affzo [M:MFG1]ZQTYBOB(NOL)
   End
Endif

[M:MFG1]ZUBICACTE(NOL)= "GENERAL1"
[M:MFG1]ZUBICASTK(NOL)= "PTEUBICA"
Affzo [M:MFG1]ZUBICACTE(NOL)
Affzo [M:MFG1]ZUBICASTK(NOL)
If [F:ITM]ZFACTOR <>0
   [M:MFG1]ZFACTOR(NOL)      = [F:ITM]ZFACTOR
Else
   [M:MFG1]ZFACTOR(NOL)       = 1
Endif
Affzo [M:MFG1]ZFACTOR(NOL)
# Grupo corte
# Valor el anterior grupo corte
If [M:MFG1]ZGRPCOR(NOL)=0 Then
   NOLX=NOL
   While  NOLX>0 and [M:MFG1]ZGRPCOR(NOLX-1)=0  :  NOLX-=1 : Wend

    If [M:MFG1]ZFABCOR(NOL)=2 Then
       If NOLX = 0 : [M:MFG1]ZGRPCOR(NOL)=1 : Else :[M:MFG1]ZGRPCOR(NOL)=[M:MFG1]ZGRPCOR(NOLX-1) :  Endif
    Else
      [M:MFG1]ZGRPCOR(NOL)=0
   Endif
   Affzo [M:MFG1]ZGRPCOR(NOL)
 Endif

#Flag pedido cliente
If [M:MFG1]ZPEDCLI(NOL)<>2 Then [M:MFG1]ZPEDCLI(NOL)=1 : Affzo [M:MFG1]ZPEDCLI(NOL) : Endif
Local Decimal  LSUPERFICIE
Local Shortint LQTYBOB,LANCHO,LNRANCHO,LNTIRADAS
Local Integer LLONGITUD
Local Integer NOL
Local Char LUOM (5)

NOL=nolign-1
If [M:MFG1]ZFABCOR(NOL)=1 : End : Endif


LNTIRADAS=[M:MFG1]ZNTIRADAS(NOL)
LNRANCHO=[M:MFG1]ZNRANCHO(NOL)
#LQTYBOB=[M:MFG1]ZQTYBOB(NOL)
LANCHO=[M:MFG1]ZANCHO(NOL)
LLONGITUD=[M:MFG1]ZLONGITUD(NOL)


Gosub CALCULA_SUPERFICIE
Gosub CALCULA_ANCHOMINIMO

Gosub CALCULA_LONGITUDTOTAL
Gosub CALCULA_MERMA
End


Subprog AS_ZGRPCOR(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

NOL=nolign-1
If [M:MFG1]ZFABCOR(NOL)=1 or [M:MFG1]ITMTYP(NOL) = 2 :  VALEUR=0:  mkstat=2 : Endif
mkstat=2
End

Subprog AM_ZGRPCOR(VALEUR)
Variable Decimal VALEUR

# Recalcula

Gosub CALCULA_ANCHOMINIMO
Gosub CALCULA_LONGITUDTOTAL
End

Subprog C_ZGRPCOR(VALEUR)
Variable Decimal VALEUR

Local Integer NOL, NOLX
NOL=nolign-1
NOLX=NOL

Local Integer LULGR


# Valor siguiente al último grupo corte
While  NOLX>0 and [M:MFG1]ZGRPCOR(NOLX-1)=0  :  NOLX-=1 : Wend
If NOLX = 0 : LULGR=1 : Else : LULGR=[M:MFG1]ZGRPCOR(NOLX-1) :  Endif
If VALEUR=0 Then
  VALEUR=LULGR
Elsif VALEUR > LULGR + 1
  VALEUR=LULGR + 1
Endif

End


