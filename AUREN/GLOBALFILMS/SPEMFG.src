Subprog COMPROBAR_MFG1
Local Integer F
Local Decimal FACTOR,LSUPERFICIE
For F=0 To [M:MFG1]NBLIG-1
  FACTOR=func RECALCULAR_FACTOR([M:MFG1]ZGRPCOR(F))
  If FACTOR<>[M:MFG1]ZFACTOR(F)
    If [M:MFG1]ALLSTA>1
#      Infbox "Articulo lanzado nş "+ num$(F+1) +  " Factor actual<>Factor MP  ("+num$(FACTOR)+"<>"+num$([M:MFG1]ZFACTOR(F)) + " Deberá DESASIGNAR y Refrescar para poder actualizar el dato"
    Else
      LSUPERFICIE=([M:MFG1]ZANCHO(F)*[M:MFG1]ZLONGITUD(F)/1000)*[M:MFG1]ZQTYBOB(F)
#      If [M:MFG1]STU(F)="M2"
#         [M:MFG1]EXTQTY(F)   =LSUPERFICIE
#      Else
#         [M:MFG1]EXTQTY(F)   =LSUPERFICIE*FACTOR
#      Endif
#      [M:MFG1]ZFACTOR(F)  = FACTOR
#      [M:MFG1]UOMEXTQTY(F)=[M:MFG1]EXTQTY(F)
#      mkstat=4
    Endif
  Endif
Next
Affzo [M:MFG1]5
End


