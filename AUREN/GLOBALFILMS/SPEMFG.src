$BB12_NBLIG
Local Integer I
Local Integer NOL
NOL=nolign-1

If ZGMODLINCOR=0 : mkstat=0: Return : Endif : # Salimos sin cambios

If ZGMODLINCOR=2
    ZGMODLINCOR=0
    Local Decimal  LSUPERFICIE
    Local Shortint LQTYBOB,LANCHO,LNRANCHO,LNTIRADAS
    Local Integer LLONGITUD
    Local Char LUOM (5)

    LNTIRADAS=[M:MFG1]ZNTIRADAS(NOL)
    LNRANCHO=[M:MFG1]ZNRANCHO(NOL)
    LQTYBOB=[M:MFG1]ZQTYBOB(NOL)
    LANCHO=[M:MFG1]ZANCHO(NOL)
    LLONGITUD=[M:MFG1]ZLONGITUD(NOL)

#    #Calculo de cantidad a producir
#    [M:MFG1]MFGEXTQTY=0
#    For I=0 To [M:MFG1]NBLIG-1
#       [M:MFG1]MFGEXTQTY=[M:MFG1]MFGEXTQTY+[M:MFG1]EXTQTY(I)
