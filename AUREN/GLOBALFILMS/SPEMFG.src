[M:MFG1]ZNRANCHO(J) =[M:MFG1]ZLANRANCHO(L)
[M:MFG1]ZNTIRADAS(J)=[M:MFG1]ZLANTIRADAS(L)
[M:MFG1]ZFACTOR(J)  =[M:MFG1]ZLAFACTOR(L)
[M:MFG1]ZSUPERFICIE(J)=[M:MFG1]ZLASUPERFICI(L)
[M:MFG1]ZPROVEEDOR(J)=[M:MFG1]ZLAPROVEEDOR(L)
[M:MFG1]ZNCORTES(J)=[M:MFG1]ZLANCORTES(L)
[M:MFG1]ZLOC(J)    =[M:MFG1]ZLALOC(L)
[M:MFG1]ZUBICACTE(J)= "GENERAL1"
[M:MFG1]ZUBICASTK(J)= "PTEUBICA"
[M:MFG1]ZCOSFAB(J) =2
[M:MFG1]ZFABCOR(J) =2
[M:MFG1]UOM(J)     =[M:MFG1]ZLAUOM(L)
[M:MFG1]STU(J)     =[M:MFG1]ZLASTU(L)
[M:MFG1]UOMSTUCOE(J) =[M:MFG1]ZLAUOMSTUCOE(L)
[M:MFG1]UOMEXTQTY(J) =[M:MFG1]ZLAUOMEXTQTY(L)
[M:MFG1]EXTQTY(J)   =[M:MFG1]ZLAEXTQTY(L)
[M:MFG1]ITMTYP(J)   =[M:MFG1]ZLAITMTYP(L)
[M:MFG1]BOMALT(J)   =[M:MFG1]ZLABOMALT(L)
[M:MFG1]ZFABCOR(J)  =[M:MFG1]ZLAFABCOR(L)
#JLPR 02-12 llamo a procedimineto para recalcular valores de columnas  ZFACTOR y ZSUPERFICIE
Call RECALCULAR(J)


#Las siguientes lineas se inicializan tal y como se hace en AM_ITMREF del tratamiento estandar
[M:MFG1]TCLCOD(J)     = [F:ITM]TCLCOD
[M:MFG1]ABCCLS(J)     = [F:ITF]ABCCLS
[M:MFG1]PLANNER(J)    = [F:ITF]PLANNER

If dim([M:MFG1]TSICOD1(J))>0 [M:MFG1]TSICOD1(J)=[F:ITM]TSICOD(0) : Endif
If dim([M:MFG1]TSICOD2(J))>0 [M:MFG1]TSICOD2(J)=[F:ITM]TSICOD(1) : Endif
If dim([M:MFG1]TSICOD3(J))>0 [M:MFG1]TSICOD3(J)=[F:ITM]TSICOD(2) : Endif
If dim([M:MFG1]TSICOD4(J))>0 [M:MFG1]TSICOD4(J)=[F:ITM]TSICOD(3) : Endif
If dim([M:MFG1]TSICOD5(J))>0 [M:MFG1]TSICOD5(J)=[F:ITM]TSICOD(4) : Endif

If [F:MTS]UOMSAI = 1 : [M:MFG1]UOMSTUCOE(J) = 1 : Endif

If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] :  Endif

# si pas de gestion de lot, on sort
If [F:ITM]LOTMGTCOD = 1 : End : Endif

# Lecture de la rčgle de gestion ŕ utiliser
Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB

# gestion lot
# 10.05 32769
If [F:ITM]LOTCOU = ""
   If !WRET & [F:SRU]LOTSUPINH=3
      [M:MFG1]GESLOT(J)    = "V"
   Endif
Else
  [M:MFG1]GESLOT(J)       = "C"
Endif
If [F:MTS]LOTAFF > 1 & [F:ITM]LOTMGTCOD > 2 : [M:MFG1]LOT(J) = mess(62,193,1) : Endif        # 05.05 29221
Return


Subprog RECALCULAR(J)
Value Integer J
# Actualizo todas las lineas de un mismo GC, siempre y cuando no se indicara peso exacto de bobina
Local Integer F,GC
GC=[M:MFG1]ZGRPCOR(J)
For F=0 To [M:MFG1]NBLIG-1
  If [M:MFG1]ZGRPCOR(F)=GC and [M:MFG1]ZQTYBOBUNI(F)=0
    [M:MFG1]ZFACTOR(F)  =func RECALCULAR_FACTOR(GC)
    [M:MFG1]ZSUPERFICIE(F)=([M:MFG1]ZANCHO(F)*[M:MFG1]ZLONGITUD(F)/1000)*[M:MFG1]ZQTYBOB(F)
  Endif
Next
End

Funprog RECALCULAR_FACTOR(GC)
Value Integer GC
#Calcular FACTOR x GrupoCorte, según media de los lotes asignados. Despues de indicar el sobrante, se calculará según este factor
#Si GC=0 entonces calculamos la media de todo la OF, se usa en SPEMFG2.src   $ADD_MATERIAL
Local Integer F,N
Local Decimal FACT(2),TF,FACTOR
Raz FACT,FACTOR
#JLPR 14-12-16 Tras comentarlo con Cerda y Tachi se acuerda que el factor a indicar en el Producto terminado sea el indicado en el articulo por:
#                                         - Hacerlo coincidir con el de los pedidos de venta
#                                         - Dicho factor es de conocimiento público, es decir, que está disponible para los clientes y cualquiera que desee consultarlo
#              Al indicar un peso real de la bobina, obviamente dicho factor variará pero al asignar se hace que KgsPedido=KgsStock.
If GC=0
  # Factor del producto consumido / Materia Prima
  # Si hay un solo factor, cojo ese
  Raz N,FACTOR
  For F=0 To [M:MFG2]ZNBLOT - 1
    If F=0
      FACTOR=[M:MFG2]ZLTFACTOR(F)
    Elsif FACTOR<>[M:MFG2]ZLTFACTOR(F)
      N=1
      Break
    Endif
  Next
  # De lo contrario
  # Determino suma de Lotes
  # Calculo factor  Kgs/ M2
  If [M:MFG2]ZTM2(2)=0
    Call CALCULA_SOBRANTE From SPEMFG2
  Endif
  If N=1 and [M:MFG2]ZTM2(2)<>0
    FACTOR=arr([M:MFG2]ZTKGS(2)/[M:MFG2]ZTM2(2),0.000001)
  Endif
Else
  # Factor del producto fabricado
  Read[F:ITM]ITM0=[M:MFG1]ITMREF(0)
  FACTOR=arr([F:ITM]ZFACTOR,0.000001)
Endif


##1ş Saco el factor de Componentes...a título informativo....he comprobado que se asignaba a pińon el factor del artioculo en lugar del medio resultante de las bobinas usadas
#Raz TF,N
#For F=0 To [M:MFG2]NBLIG-1
#  If [M:MFG2]ZFABCOR(F)=2
#    TF+=[M:MFG2]ZFACTOR(F)
#    N+=1
#  Endif
#Next
#If TF>0
#  FACT(0)=TF/N
#Endif
##2ş Saco el factor medio de las bobinas asignadas
#Raz TF,N
#For F=0 To [M:MFG2]ZNBLOT-1
#  If ([M:MFG2]ZLTGRPCOR(F)=GC and GC>0)  or  GC=0
#  TF+=[M:MFG2]ZLTFACTOR(F)
#  N+=1
#  Endif
#Next
#If TF>0
#  FACT(1)=TF/N
#Endif
## Se supone que me he de quedar con el factor medio de las bobinas asignadas
#If FACT(1)>0
##  If abs(FACT(0)-FACT(1))<0.001
##    FACTOR=FACT(0)
##  Else
##    FACTOR=FACT(1)
##  Endif
#  FACTOR=FACT(1)
#Else
##3ş Si no hay bobinas asignadas, devuelvo el teorico del artículo
#  FACTOR=[F:ITM]ZFACTOR
#Endif
#FACTOR=func ZCOMUN.REDONDEAR_R(FACTOR,6,0)
End FACTOR

Subprog C_NBLIG
Local Integer T
If [M:MFG1]NBLIG > 0
  If status=65 or status=68 or status=83 Then
    Qstbox "BORRANDO articulo a producir",".","Está seguro de borrarlo?",".","De hacerlo deberá revisar     <Materia Prima>   asi como   <Pedidos asignados>", ".",
& "No REGISTRE en caso de no tenerlo claro"
& Using T
    If T=2 Then:  mkstat=2:  Endif
  Endif
Endif
End

Subprog AS_ZQTYBOBUNI(VALEUR)
Variable Decimal VALEUR
Local Integer YN,F
Local Decimal PESO
Local Char TXT(255)(4),MSG(255)
Raz PESO,TXT

If [M:MFG1]MFGTRKFLG>=5   #]ALLSTA>1
  MSG="OF saldada\Imposible variar peso unitario bobina"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif

If [M:MFG1]ZQTYBOBUNI(nolign-1)=0
  If [M:MFG1]ITMREF(nolign-1)<>"" and [M:MFG1]ZANCHO(nolign-1)>0 and [M:MFG1]ZLONGITUD(nolign-1)>0
    # Ver si ya tenemos un peso en esta OF
    For F=0 To [M:MFG1]NBLIG-1
      If F<>nolign-1  and [M:MFG1]ZQTYBOBUNI(F)>0 and [M:MFG1]ZANCHO(F)=[M:MFG1]ZANCHO(nolign-1) and [M:MFG1]ZLONGITUD(F)=[M:MFG1]ZLONGITUD(nolign-1)
        PESO=[M:MFG1]ZQTYBOBUNI(F)
        PESO=func ZCOMUN.REDONDEAR(PESO,4)
        MSG= "Desea recuperar el peso bobina introducido en otras lineas de esta OF\" + num$(PESO)
        Break
      Endif
    Next
    # Sacar peso de última OF creada
    If PESO=0
      TXT(0)="select top 1 ZQTYBOBUNI_0,MFGNUM_0,MFGLIN_0 "
      TXT(1)="from MFGITM "
      TXT(2)="where ZQTYBOBUNI_0>0 and ITMREF_0='"+[M:MFG1]ITMREF(nolign-1)+"' and ZANCHO_0 =" + num$([M:MFG1]ZANCHO(nolign-1)) + " and ZLONGITUD_0 ="+num$([M:MFG1]ZLONGITUD(nolign-1)) +" "
      TXT(3)="order by CREDATTIM_0 desc"
      For (Decimal FPESO, Char FNUM(GLONVCR),Integer FLIN) From func ZCOMUN.DATA_BASE_TIPO Sql TXT As [MYT]
        PESO=func ZCOMUN.REDONDEAR(PESO,4)
        MSG= "Desea recuperar ultimo peso bobina introducido en OF "+FNUM+" lŞ " + num$(FLIN)+"\" + num$(PESO)
        Break
      Next
    Endif
    # Calcularlo en función de datos actuales
    If PESO=0 and [M:MFG1]ZQTYBOB(nolign-1)>0
      PESO=[M:MFG1]UOMEXTQTY(nolign-1)/[M:MFG1]ZQTYBOB(nolign-1)
      PESO=func ZCOMUN.REDONDEAR(PESO,4)
      MSG= "Desea recuperar peso teórico (Total peso bobinas/nş bobinas)\" + num$(PESO)
    Endif
  Endif
  If PESO>0
    YN=2  # Por defecto SI
    Call OUINON(MSG, YN) From GESECRAN
    If YN=2
      VALEUR=PESO
    Endif
  Endif
Endif
End

Subprog AM_ZQTYBOBUNI(VALEUR)
Variable Decimal VALEUR
Local Decimal LQTY,LTEORICO
Local Integer YN,TODO,R_NOLIGN,T
Local Char MSG(255)
TODO=0
If VALEUR<=0
  YN=1
  LTEORICO=([M:MFG1]ZANCHO(nolign-1)*[M:MFG1]ZLONGITUD(nolign-1)/1000)*func RECALCULAR_FACTOR([M:MFG1]ZGRPCOR(nolign-1)) * [M:MFG1]ZQTYBOB(nolign-1)
  LTEORICO=func ZCOMUN.REDONDEAR(LTEORICO,4)
  MSG= "Está seguro de NO indicar el peso de una bobina\Se asumirá el teórico "+ num$(LTEORICO)+"\Ancho de " + num$([M:MFG1]ZANCHO(nolign-1)) + " y largo de "+num$([M:MFG1]ZLONGITUD(nolign-1))
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    mkstat=2
    End
  Endif
Else
  VALEUR=func ZCOMUN.REDONDEAR(VALEUR,4)
  T=0
  For F=0 To [M:MFG1]NBLIG-1
    If F<>nolign-1 and [M:MFG1]ZQTYBOBUNI(F)=0 and [M:MFG1]ZANCHO(F)=[M:MFG1]ZANCHO(nolign-1) and [M:MFG1]ZLONGITUD(F)=[M:MFG1]ZLONGITUD(nolign-1)
      T+=[M:MFG1]ZQTYBOB(F)
    Endif
  Next
  If T>0
    YN=1
    MSG= "Desea asignar el peso indicado de " + num$(VALEUR)+" Kgs al resto de " + num$(T) + " bobinas de esta OF que todavia no tiene peso"
    Call OUINON(MSG, YN) From GESECRAN
    If YN=2
      TODO=1
    Endif
  Endif
Endif
# Actualizar filas de rejilla
R=nolign
For F=0 To [M:MFG1]NBLIG-1
  If F=R-1 or (F<>R-1 and TODO and [M:MFG1]ZQTYBOBUNI(F)=0 and [M:MFG1]ZANCHO(F)=[M:MFG1]ZANCHO(R-1) and [M:MFG1]ZLONGITUD(F)=[M:MFG1]ZLONGITUD(R-1))
    nolign=F+1 # Para asegurarnos de que se usa el valor correcto en     AM_UOMEXTQTY
    [M:MFG1]ZQTYBOBUNI(F)=VALEUR
    If [M:MFG1]ZQTYBOBUNI(F)>0
      LQTY = [M:MFG1]ZQTYBOBUNI(F) * [M:MFG1]ZQTYBOB(F)
    Else
      LQTY = LTEORICO
    Endif
    Call AM_UOMEXTQTY(LQTY) From SUBMFG
    If mkstat Then : Break : Endif
    [M:MFG1]UOMEXTQTY(F)=LQTY
    [M:MFG1]ZFACTOR(F)  =arr(LQTY / [M:MFG1]ZSUPERFICIE(F),0.000001)
    Affzo [M:MFG1]UOMEXTQTY(F)
    Affzo [M:MFG1]ZQTYBOBUNI(F)
  Endif
Next
nolign=R
End


