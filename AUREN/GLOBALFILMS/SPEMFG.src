   GBOUT2 = ""
Endif
If [M:MFG1]ZSOHNUM(nolign-1)=""
   GBOUT4 = ""
Else
   GBOUT4 = "Pedido "+[M:MFG1]ZSOHNUM(nolign-1)
Endif
End

# Click en el botón
Subprog B2_ZNBLP
Local Integer NOL, T
Qstbox "BORRANDO PEDIDO","","Está seguro de borrar este pedido" Using T
If T=2: End : Endif

NOL = nolign - 1
# Borrado Pedido
If [M:MFG1]ZNBLP>0
   Dela NOL,1 [M:MFG1]ZNCORTES(NOL)
#   Dela NOL,
#&        [M:MFG1]ZMFGLIN,    [M:MFG1]ZSOHNUM,     [M:MFG1]ZANCHOP,    [M:MFG1]ZMANDRILP, [M:MFG1]ZLONGITUDP,
#&        [M:MFG1]ZQTYBOBASI, [M:MFG1]ZDLVDAT,     [M:MFG1]ZBPCNAM,    [M:MFG1]ZNETPRI,
#&        [M:MFG1]ZCOSPRV,    [M:MFG1]ZMARGEN,     [M:MFG1]ZSOPLIN,    [M:MFG1]ZSOQSEQ
  [M:MFG1]ZNBLP-= 1
  Affzo [M:MFG1]35
  mkstat=4
Endif
End


Subprog CALCULA_COSTES(FCY,NUM) #
#JLPR 14-03-17 Hay un parametro CLCWOCAUT (GPA / COS) - Costes previsionales auto = "En creación y modificación OF"
#              Lo dejamos a = No, pues segúnh Fco.Cerda habia casos en los que no lo calculaba y se decidió por provocarlo

Value Char FCY,NUM
## JLPR 12-12  Lo pongo a "1" para impedir que se ejecute por una 2Ş vez en   SPEMCC.src    CONTROLE
#[M:MFG0]ZSTA="1"
## JLPR 12-12
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION

  # Parámetros de la accion   TRTMFCCLC    -    Cálculo Precio de coste
  Local Char PARBOUT(250)(1..20)  ,  VALBOUT(250)
# Local Char PARAM_CLC(250)(1..14),  VAL_CLC(250)  ==> definicion en APRES_MOD de SUBMFGA.src

  PARBOUT(1) = FCY                                       # SITE     #  Planta
  PARBOUT(2) = NUM                                       # MFGNUM   #  Orden de fabricación
  PARBOUT(3) = ""                                        # ART      #  Articulo
  PARBOUT(4) = num$(1)                                   # MAJ      #  Actualización
  PARBOUT(5) = num$(4)                                   # COLFG    #  Columna Gastos Gen. cálc. PCF
  PARBOUT(6) = num$("0")                                 # ORIDEV   #  Origen cálculo desv.
  PARBOUT(7) = num$("0")                                 # FLXBUD   #  Presupuesto flexible
  PARBOUT(8) = num$(1)                                   # MFCTYP   #  Teórico/Lanzamiento/Producción
  PARBOUT(9) = num$(num$(2-mod([F:MTS]MCCIMPMOD,2)))     # PRN      #  Impresión
  PARBOUT(10) = ""                                       # FILMFG   #  Filtro OF
  PARBOUT(11) = ""                                       # FILMFI   #  Filtro artículo lanzado
  PARBOUT(12) = num$(4)                                  # AUTO     #  Automática
  PARBOUT(13) = num$(num$(([F:MTS]MCCIMPMOD>=3)+1))      # TRACE    #  Traza
  PARBOUT(14) = num$(10)                                 # VCRTYP   #  Tipo documento
  FLGEXE = 1
  GACTION = "TRTMFCCLC"
  Call TRAITE_CHAR(VALBOUT,PARBOUT  ,"","SUBMCC","DMFCCLC",3,"SPEMCC") From GTRAITE
# Parametro   CLCWOCAUT (capit.GPA Grupo COS) se ha puesto a NO, pues el standar lo llama sin  "DMFCCLC" y GACTION="" en lugar de GACTION = "TRTMFCCLC"
#If GCLCWOCAUT = 3
# Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC",""       ,3,""      ) From GTRAITE  ==> llamada en APRES_MOD de SUBMFGA.src
#Endif


GACTION = SAVACT
End

Funprog SOBRANTE_OK()
Local Integer OK  :  OK=1
Local Integer YN  :  YN=1 # Por defecto NO
Local Integer LNG_TEOR_SOB,DIF
Local Char MSG(255)
LNG_TEOR_SOB=[M:MFG1]ZLONGMAT-[M:MFG1]ZMAXLONG
DIF = [M:MFG2]ZSLONG-LNG_TEOR_SOB
If DIF<>0
  MSG+="ESTA SEGURO DE CONTINUAR\Hay una difŞ de " + num$(DIF)
  MSG+="\Entre longitud sobrante indicada ("+num$([M:MFG2]ZSLONG) +") y la teórica ("
  MSG+=num$(LNG_TEOR_SOB)+"="+num$([M:MFG1]ZLONGMAT)+"-"+num$([M:MFG1]ZMAXLONG)+")"
  Call OUINON(MSG,YN) From GESECRAN
  If YN=1
    OK=0
  Endif
Endif
End OK

