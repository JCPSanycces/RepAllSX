Subprog COLORES
Local Integer I
For I=0 To [M:MFG1]NBLIG-1
  If [M:MFG1]ZAUTOMA(I)=2
    Chgstl [M:MFG1]ITMREF(I) With "BACKYELLOW"
  Else
    Chgstl [M:MFG1]ITMREF(I) With ""
  Endif
Next
#
For I=0 To [M:MFG2]ZNBLOT-1
  [M:MFG2]ZLTGCANCHO(I)  =func SPEMFG2.ANCHO_GRUPO_CORTE([M:MFG2]ZLTGRPCOR(I))
  Affzo [M:MFG2]ZLTGCANCHO(I)
  If [M:MFG2]ZLTGCANCHO(I)<>[M:MFG2]ZLTANCHO(I)
    Chgstl [M:MFG2]ZLTGCANCHO(I) With "BACKYELLOW"
    Chgstl [M:MFG2]ZLTANCHO(I)   With "BACKYELLOW"
  Else
    Chgstl [M:MFG2]ZLTGCANCHO(I) With ""
    Chgstl [M:MFG2]ZLTANCHO(I)   With ""
  Endif
Next
##
#If dim([M:MFG2]ZTLNG(5))>0 and  [M:MFG2]ZTLNG(5)<>0
#  Chgstl [M:MFG2]ZTLNG(5)  With "BACKYELLOW"
#Endif
End

