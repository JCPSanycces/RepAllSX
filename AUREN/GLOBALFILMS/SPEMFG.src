Subprog IB_NBLIG
 GBOUT8 = ""
 GBOUT12 = ""
 GBOUT13 = ""
If [M:MFG1]ALLSTA = 1
   GBOUT8="Ańadir un subproducto"
   If [M:MFG1]ITMREF(nolign-1)<>"" : GBOUT12 = "Modificar Linea Corte OF" : Endif
   GBOUT13 = "Ańadir Linea Corte OF"
Endif
End




