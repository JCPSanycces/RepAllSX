#Limpiamos la zona auxiliar de lineas
nolign=[M:MFG1]NBLIG
If GMODIF=2 & [M:MFG1]NBLIG=0
    [M:MFG1]MFGSTU=[F:ITM]STU
    [M:MFG2]MFGSTU=[F:ITM]STU
Endif
For I=0 To 99
   Raz [M:MFG1]ZLANUMLIN(I)
