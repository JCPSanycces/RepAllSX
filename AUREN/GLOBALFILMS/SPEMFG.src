Subprog APRES_NBLIG

Gosub CALCULA_ANCHOMINIMO
Gosub CALCULA_LONGITUDTOTAL
Gosub CALCULA_MERMA
Gosub ACT_PEDASI
End



$CALCULA_SUPERFICIE
Local Decimal LQTY
#Unidad FJCP 28/12/2015 - se abandona la unidad Lanzamiento MT2 para corencia con el resto
#If [F:ITM]STU<>"M2" and [M:MFG1]UOM(NOL)<>"MT2" Then
# # Ajustamos Unidad Lanzamiento a MT2
# Local Char LUOM (5)
#    LUOM="MT2"
#    Call C_UOM(LUOM) From SUBMFG
#    If mkstat Then : Return : Endif
#    Call AM_UOM(LUOM) From SUBMFG
#    [M:MFG1]UOM(NOL)=LUOM
#    Affzo [M:MFG1]UOM(NOL)
#Endif

#Calculo Bobinas
#Infbox "CALCULA_SUPERFICIE cv"
LQTYBOB=LNTIRADAS*LNRANCHO
#Calculo Superficie

LSUPERFICIE=arr((LANCHO/1000)*LLONGITUD*LQTYBOB,0.0001)
#Infbox num$(LSUPERFICIE)
If [F:ITM]STU="M2"
  LQTY=LSUPERFICE
Else
  LQTY=arr(LSUPERFICIE*[M:MFG1]ZFACTOR(NOL),0.0001)
Endif
#Infbox "CALCULA_SUPERFICE_LQTY" - num$(LQTY)
## Cantidad de Lanzamiento
#JLPR 21.09.16    INICIO
nolign=NOL+1 # Para asegurarnos de que se usa el valor correcto en     AM_UOMEXTQTY
#JLPR 21.09.16    FIN
Call AM_UOMEXTQTY(LQTY) From SUBMFG
If mkstat Then : Return : Endif
[M:MFG1]ZSUPERFICIE(NOL)=LSUPERFICIE
Affzo [M:MFG1]ZSUPERFICIE(NOL)
[M:MFG1]ZQTYBOB(NOL)=LQTYBOB
Affzo [M:MFG1]ZQTYBOB(NOL)
[M:MFG1]UOMEXTQTY(NOL)=LQTY
Affzo [M:MFG1]UOMEXTQTY(NOL)
Return




$CALCULA_ANCHOMINIMO
# JLPR 13.07.16, comenta y ańade para sacar ANCHO MINIMO en lugar de MAXIMO
Local Shortint LN1,LGR, LMAXANCH, LGRANCHO
LGR=0
LGRANCHO=0
LMAXANCH=32767 #LMAXANCH=0
# Se asume que la rejilla está ordenada por GC, es decir, que todas las lineas de un mismo GC iran seguidas
For LN1= 0 To [M:MFG1]NBLIG -1
  If [M:MFG1]ZFABCOR(LN1)=2 and [M:MFG1]ITMTYP(LN1)=1
    If [M:MFG1]ZGRPCOR(LN1)=LGR and [M:MFG1]ZGRPCOR(LN1)<>0
       LGRANCHO+=([M:MFG1]ZANCHO(LN1)*[M:MFG1]ZNRANCHO(LN1))
    Else
#       If LGRANCHO>LMAXANCH :  LMAXANCH=LGRANCHO : Endif
       If LGRANCHO<LMAXANCH and LGR>0 :  LMAXANCH=LGRANCHO : Endif
       LGR=[M:MFG1]ZGRPCOR(LN1)
       LGRANCHO=([M:MFG1]ZANCHO(LN1)*[M:MFG1]ZNRANCHO(LN1))
    Endif
  Endif
Next
#If LGRANCHO>LMAXANCH : LMAXANCH=LGRANCHO : Endif
If LGRANCHO<LMAXANCH and LGR>0 : LMAXANCH=LGRANCHO : Endif
If LMAXANCH=32767:   LMAXANCH=0:   Endif
[M:MFG1]ZMINANCHO=LMAXANCH
Affzo [M:MFG1]ZMINANCHO
Return


$CALCULA_LONGITUDTOTAL
Local Shortint LN1,LGR,LN2,LE
Local Integer LLONGTOTAL, LLONGITM, LLONGGRP

#LGR=[M:MFG1]ZGRPCOR(0)
#LLONGTOTAL=0
#LLONGITM=0
#LLONGGRP=0
##Infbox "CALCULA_LONGITUDTOTA: NBLIG" - num$([M:MFG1]NBLIG)
## 1ş) Ordeno rejilla por GrupoCorte+LŞ
#Sorta [M:MFG1]NBLIG [M:MFG1]NBLIG Order By [M:MFG1]ZGRPCOR(indice),[M:MFG1]NOLIG(indice)
#For LN1= 0 To [M:MFG1]NBLIG -1
#  If [M:MFG1]ZFABCOR(LN1)=2 and ([M:MFG1]ITMTYP(LN1)=1 or [M:MFG1]ITMTYP(LN1)=2)
#    If [M:MFG1]ITMTYP(LN1)=2 : # Si  subproducto
#       LLONGTOTAL+=([M:MFG1]ZLONGITUD(LN1)*[M:MFG1]ZNTIRADAS(LN1))
#    Else  # Si Producto
#      LLONGITM=([M:MFG1]ZLONGITUD(LN1)*[M:MFG1]ZNTIRADAS(LN1))
#      If [M:MFG1]ZGRPCOR(LN1)=LGR
#         If LLONGITM>LLONGGRP Then LLONGGRP=LLONGITM Endif
#      Else
#       LLONGTOTAL+=LLONGGRP # Acumulo Longitud Grupo Anterior
#       LLONGGRP=LLONGITM
#     Endif
#     LGR=[M:MFG1]ZGRPCOR(LN1)
#    Endif
#   # Infbox "CALCULA_LONGITUDTOTA: LLONGTTOAL" - num$(LLONGTOTAL) - num$(LN1)
#  Endif
#Next
## 2ş) Vuelvo a ordenar rejilla por LŞ
#Sorta [M:MFG1]NBLIG [M:MFG1]NBLIG Order By [M:MFG1]NOLIG(indice)
#Affzo [M:MFG1]5
##
#LLONGTOTAL+=LLONGGRP  : # Longitud último grupo
##Infbox "CALCULA_LONGITUDTOTA: LLONGTTOAL" - num$(LLONGTOTAL) - num$(LN1)
#[M:MFG1]ZMAXLONG=LLONGTOTAL
#Affzo [M:MFG1]ZMAXLONG
Call CALCULALONGITUDTOTAL

#Calculo de cantidad a producir
[M:MFG1]MFGEXTQTY=0
For I=0 To [M:MFG1]NBLIG-1
   [M:MFG1]MFGEXTQTY=[M:MFG1]MFGEXTQTY+[M:MFG1]EXTQTY(I)
   Affzo [M:MFG1]MFGEXTQTY
Next
If [M:MFG1]MFGEXTQTY<>0
   Local Decimal WLROUALT, WMFGEXTQTY
   Local Integer LIG
   WLROUALT=[M:MFG1]ROUALT

   #FJCG (inicio) - Este codigo esta provocando un mal funcionamiento, por lo menos de las variables FRCXXXX
   # FUERZO CAMBIO ALTERNATIVA DE RUTA
   #[M:MFG1]ROUALT=0
   #Call C_ROUALT(WLROUALT) From SUBMFG
   #[M:MFG1]ROUALT=WLROUALT
   #Affzo [M:MFG1]ROUALT
   #FJCG (fin) - Este codigo esta provocando un mal funcionamiento, por lo menos de las variables FRCXXXX


   #FJCG (inicio) - El codigo siguiente para calcular la cantidad y tiempos debería hacerse para cada operacion,
   #                de momento se hace para una operacion

   LIG=0
   #LIG = [M:MFG3]NBLIG
   WMFGEXTQTY    = [M:MFG1]MFGEXTQTY

   Read [ROO]ROO0=[M:MFG0]MFGFCY;[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG3]OPENUM(0);0
   Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire

   Call CAL_OPE_TIME("MFG3", WMFGEXTQTY, LIG, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE) From MFGLIBO

   #FJCG (fin) - calcular cantidad y tiempos

Endif
Return

Subprog CALCULALONGITUDTOTAL
Local Integer LLONGTOTAL, LLONGITM, LLONGGRP
Raz LLONGTOTAL,LLONGITM,LLONGGRP
Local Integer ZGRN(50),ZGRL(50),F,G,H
Raz ZGRN,ZGRL,G
#  Los Grupos de corte, no tienen por que ir correlativos
#  1ş) Saca los GC involucrados
#  2ş) Determino longitud total de cada GC
For F=0 To [M:MFG1]NBLIG -1
  If [M:MFG1]ZFABCOR(F)=2 and ([M:MFG1]ITMTYP(F)=1 or [M:MFG1]ITMTYP(F)=2)
    If find([M:MFG1]ZGRPCOR(F),ZGRN)=0
      ZGRN(G)=[M:MFG1]ZGRPCOR(F)
      G+=1
    Endif
  Endif
Next
# Por cada GC determino su longitud
For H=0 To G-1
  Raz LLONGGRP
  For F=0 To [M:MFG1]NBLIG -1
    If [M:MFG1]ZGRPCOR(F)=ZGRN(H)
      Gosub CALCULALONGITUDTOTAL_CALCULO
    Endif
  Next
  LLONGTOTAL+=LLONGGRP # Acumulo Longitud Grupo Anterior
Next
# Actualizo datos en pantalla
[M:MFG1]ZMAXLONG=LLONGTOTAL
Affzo [M:MFG1]ZMAXLONG
End

$CALCULALONGITUDTOTAL_CALCULO
If [M:MFG1]ITMTYP(F)=2
  # Si  Subproducto
  LLONGGRP+=([M:MFG1]ZLONGITUD(F)*[M:MFG1]ZNTIRADAS(F))
Else
  # Si  Producto
  LLONGITM=([M:MFG1]ZLONGITUD(F)*[M:MFG1]ZNTIRADAS(F))
 If LLONGITM>LLONGGRP Then LLONGGRP=LLONGITM Endif
Endif
Return

$CALCULA_MERMA
Local Shortint LN1,LN2,LANCHOMAT
Local Decimal LSUPERFITM,LSUPERFNEC,LSUPERFMAT,LSUPTOTLOT,LSUPLOTSOB
Local Integer LLONGMAT

LSUPERFITM=0
LSUPERFNEC=[M:MFG1]ZMAXLONG*[M:MFG1]ZMINANCHO/1000
For LN1=0 To [M:MFG1]NBLIG - 1
   If [M:MFG1]ZFABCOR(LN1)=2 and [M:MFG1]ITMTYP(LN1)=1
      LSUPERFITM+=[M:MFG1]ZSUPERFICIE(LN1)
   Endif
Next

LSUPERFMAT=0
For LN1=0 To [M:MFG2]NBLIG - 1
   If [M:MFG2]ZFABCOR(LN1)=2 and [M:MFG2]MATSTA(LN1)<>4
      LSUPERFMAT+=[M:MFG2]ZSUPERFICIE(LN1)
   Endif
Next
# Calculo Longitud /Ancho Material Pre Asignado
LLONGMAT=0
LANCHOMAT=0
For LN1=0 To [M:MFG2]ZNBLOT - 1
   # Bobinas pueden estar repetidas en grupos de corte diferente
   LE=0
   For LN2=0 To LN1 - 1
      If [M:MFG2]ZLTLOT(LN2)=[M:MFG2]ZLTLOT(LN1) &
&        [M:MFG2]ZLTSLO(LN2)=[M:MFG2]ZLTSLO(LN1) &
&        [M:MFG2]ZLTITMREF(LN2)=[M:MFG2]ZLTITMREF(LN1) Then
         LE=1  # Encontrada bobina ya procesada
         Break
      Endif
   Next
   If !LE Then
      LLONGMAT+=[M:MFG2]ZLTLONGITUD(LN1)
      If [M:MFG2]ZLTANCHO(LN1)>LANCHOMAT : LANCHOMAT=[M:MFG2]ZLTANCHO(LN1) : Endif
   Endif
Next

[M:MFG1]ZLONGMAT=LLONGMAT
[M:MFG1]ZANCHOMAT=LANCHOMAT

# Si no existe longitud sobrante introducida por el usuario se aplica la teorica.
If [M:MFG2]ZSLONG>0 Then
  [M:MFG1]ZLONGSOB=[M:MFG2]ZSLONG
Else
  [M:MFG1]ZLONGSOB=LLONGMAT-[M:MFG1]ZMAXLONG
Endif

LSUPTOTLOT=0
LSUPLOTSOB=0
For LN1=0 To [M:MFG2]ZNBLOT - 1
   # Bobinas pueden estar repetidas en grupos de corte diferente
   LE=0
   For LN2=0 To LN1 - 1
      If [M:MFG2]ZLTLOT(LN2)=[M:MFG2]ZLTLOT(LN1) &
&        [M:MFG2]ZLTSLO(LN2)=[M:MFG2]ZLTSLO(LN1) &
&        [M:MFG2]ZLTITMREF(LN2)=[M:MFG2]ZLTITMREF(LN1) Then
         LE=1  # Encontrada bobina ya procesada
         Break
      Endif
   Next
#   #JLPR 26.07.16   << INICIO >>
#   If !LE Then
#      LSUPLOTSOB=0
#      If [M:MFG2]ZLTSOBRANTE(LN1)=2
#         LSUPLOTSOB=([M:MFG2]ZLTANCHO(LN1)/1000*[M:MFG1]ZLONGSOB)
#      Endif
##      LSUPTOTLOT+=([M:MFG2]ZLTANCHO(LN1)/1000*[M:MFG2]ZLTLONGITUD(LN1))
#      LSUPTOTLOT+=[M:MFG2]ZLTSUPERF(LN1)
#   Endif
   If !LE Then
      LSUPLOTSOB=0
      # Si lote marcado como Sobrante. ACUMULO sobrante
      If [M:MFG2]ZLTSOBRANTE(LN1)=2
         LSUPLOTSOB+=([M:MFG2]ZLTANCHO(LN1)/1000*[M:MFG2]ZLTLONGSOB(LN1))
      Endif
      LSUPTOTLOT+=[M:MFG2]ZLTSUPERF(LN1)  #  ACUMULO superficie
   Endif
#   #JLPR 26.07.16   << FIN >>
Next

#   #JLPR 26.07.16   << INICIO >>
#[M:MFG1]ZSUPERFITM=LSUPERFITM
#[M:MFG1]ZSUPERFMAT=LSUPTOTLOT#-LSUPLOTSOB
#[M:MFG1]ZMERMA=[M:MFG1]ZSUPERFMAT-LSUPERFITM
[M:MFG1]ZSUPERFITM=LSUPERFITM
[M:MFG1]ZSUPERFMAT=LSUPTOTLOT
[M:MFG1]ZMERMA=[M:MFG1]ZSUPERFMAT-LSUPERFITM#-LSUPLOTSOB
#   #JLPR 26.07.16   << FIN >>
Affzo [M:MFG1] ZSUPERFITM,ZMERMA,ZANCHOMAT,ZLONGMAT,ZSUPERFMAT,ZLONGSOB
Return


#################################################################################
### Subprogramas y rutinas para la gestion de los pedidos Asignados

### Borrar pedidos asignados a una linea de producto
### en la pantalla MFG1 lista de pedidos asignados
Subprog BORRAR_PEDASI(WMFGLIN)
Value Integer WMFGLIN
Local Integer WLI

WLI=[M:MFG1]ZNBLP-1
While WLI>=0
 If [M:MFG1]ZMFGLIN(WLI)=WMFGLIN
    Dela WLI,1 [M:MFG1]ZNBLP(WLI)
#    Dela WLI,1 [M:MFG1]ZMFGLIN,[M:MFG1]ZSOHNUM,[M:MFG1]ZSOPLIN,[M:MFG1]ZSOQSEQ,[M:MFG1]ZQTYBOBASI,
#&        [M:MFG1]ZNETPRI, [M:MFG1]ZDLVDAT, [M:MFG1]ZBPCNAM, [M:MFG1]ZCOSPRV
    [M:MFG1]ZNBLP -=1
 Endif
 WLI -=1
Wend

End

### Grabar en tabla ZMFGSOQ (Pedidos Asignados OF)
$GUARDAR_PEDASI
Local Integer WLI
Delete  [F:ZMSQ] Where MFGNUM=[F:MFG]MFGNUM
If fstat
      GOK=0
      Call FSTA("ZMSQ") From GLOCK
      Return
Endif
Raz[F:ZMSQ]
[F:ZMSQ]=[F:MFG]
For WLI = 0 To [M:MFG1]ZNBLP - 1
   [F:ZMSQ]MSQLIN=WLI
   [F:ZMSQ]MFGLIN=[M:MFG1]ZMFGLIN(WLI)
   [F:ZMSQ]SOHNUM=[M:MFG1]ZSOHNUM(WLI)
   [F:ZMSQ]SOPLIN=[M:MFG1]ZSOPLIN(WLI)
   [F:ZMSQ]SOQSEQ=[M:MFG1]ZSOQSEQ(WLI)
   [F:ZMSQ]ZQTYBOBASI=[M:MFG1]ZQTYBOBASI(WLI)
   Write [F:ZMSQ]
   If fstat
      GOK=0
      Call FSTA("ZMSQ") From GLOCK
      Break
   Endif
#FJCG: Ya no se modifica la fecha de fabricacion en el pedido al programar se debe hacer al planificar
#   Local Date ENDDAT
#   ENDDAT=[M:MFG1]ENDDAT
#   Gosub GUARDAR_PEDASI_ACTUALIZAR_PED_CAB
#   If GOK=0  :  Break  :  Endif
Next
Return

# JLPR 15.11 Lo comento a raiz del error y del comentario de FJCG arriba indicado
#$GUARDAR_PEDASI_ACTUALIZAR_PED_CAB
# # JLPR 27.10 La llamo desde <<Propuesta OF>> SPEZGOFS.src, tras grabar [F:ZMSQ]
# # Antes de llamar asignar valor a variable    << ENDDAT >>
# Raz [F:SOHX]
# Read [F:SOHX]SOH0=[F:ZMSQ]SOHNUM
# If fstat
#   GOK=0
#   Call FSTA("SOHX") From GLOCK
#   Return
# Endif
# Raz [F:SOQX]
# Read [F:SOQX]SOQ0=[F:ZMSQ]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
# If fstat
#   GOK=0
#   Call FSTA("SOQX") From GLOCK
#   Return
# Endif
# #Tomado de AM_EXTDLVDAT (SUBSOH)
# #Local Date WDSHIDAT
# #WDSHIDAT=[F:SOQX]SHIDAT
# #Call CALC_SHIDAT(ENDDAT, [F:SOQX]DAYLTI, [F:SOQX]STOFCY, 1, 1, [F:SOHX]ORDDAT, WDSHIDAT) From TRTVENDAT
# #If [F:SOQX]SHIDAT<>WDSHIDAT
#    [F:SOQX]ZFECFINFAB=[M:MFG1]ENDDAT
#    #[F:SOQX]SHIDAT=WDSHIDAT
#    Rewrite [F:SOQX]
#    If fstat
#       GOK=0
#       Call FSTA("SOQX") From GLOCK
#    Endif
# #Endif
#Return


$BORRA_PEDASI
Delete  [F:ZMSQ] Where MFGNUM=[M:MFG0]MFGNUM
If fstat
      GOK=0
      Call FSTA("ZMSQ") From GLOCK
      Return
Endif
Return

$LEER_PEDASI
Local Integer WLI
Local Decimal WMARGEN

Filter [F:ZMSQ] Where MFGNUM=[M:MFG0]MFGNUM Order By MSQLIN
WLI=0
For  [F:ZMSQ]
   [M:MFG1]ZMFGLIN(WLI)=[F:ZMSQ]MFGLIN
   [M:MFG1]ZSOHNUM(WLI)=[F:ZMSQ]SOHNUM
   [M:MFG1]ZSOPLIN(WLI)=[F:ZMSQ]SOPLIN
   [M:MFG1]ZSOQSEQ(WLI)=[F:ZMSQ]SOQSEQ
   [M:MFG1]ZQTYBOBASI(WLI)=[F:ZMSQ]ZQTYBOBASI
   Raz [F:SOHX],[F:SOPX],[F:SOQX], [F:BPCX]
   Read [F:SOHX]SOH0=[F:ZMSQ]SOHNUM
   If fstat
      Infbox "Problema recuperando pedido: "+[F:ZMSQ]SOHNUM+" - fstat: "+num$(fstat)
   Else
     Read [F:SOPX]SOP0=[F:ZMSQ]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
     If fstat
        Infbox "Problema recuperando linea pedido (P): "+[F:ZMSQ]SOHNUM+" "+num$([F:ZMSQ]SOPLIN)+" - fstat: "+num$(fstat)
     Else
       Read [F:SOQX]SOQ0=[F:ZMSQ]SOHNUM;[F:ZMSQ]SOPLIN;[F:ZMSQ]SOQSEQ
       If fstat
          Infbox "Problema recuperando linea pedido (Q): "+[F:ZMSQ]SOHNUM+" " +num$([F:ZMSQ]SOPLIN)+" "+num$([F:ZMSQ]SOQSEQ)+" - fstat: "+num$(fstat)
       Endif
     Endif
   Endif
   [M:MFG1]ZANCHOP(WLI)=[F:SOQX]ZANCHO
   [M:MFG1]ZMANDRILP(WLI)=[F:SOQX]ZMANDRIL
   [M:MFG1]ZLONGITUDP(WLI)=[F:SOQX]ZLONGITUD
   Raz  [F:MFC]
#   Filter [F:MFC] Where MFCTYP=2 & VCRTYP=10 &  VCRNUM=[M:MFG0]MFGNUM & VCRLIN= [F:ZMSQ]MFGLIN
   Filter [F:MFC] Where VCRTYP=10 &  VCRNUM=[M:MFG0]MFGNUM & VCRLIN= [F:ZMSQ]MFGLIN Order By MFCTYP
   For [F:MFC]
#      Break
     [M:MFG1]ZCOSPRV(WLI)=[F:MFC]CSTTOT
   Next
   Filter [F:MFC]
   [M:MFG1]ZBPCNAM(WLI)=[F:SOHX]BPCNAM
   If [F:SOPX]SAUSTUCOE<>0
      [M:MFG1]ZNETPRI(WLI)=[F:SOPX]NETPRI/[F:SOPX]SAUSTUCOE
   Else
      [M:MFG1]ZNETPRI(WLI)=[F:SOPX]NETPRI
   Endif
   [M:MFG1]ZDLVDAT(WLI)=[F:SOQX]SHIDAT
#   [M:MFG1]ZCOSPRV(WLI)=[F:MFC]CSTTOT
   If [M:MFG1]ZNETPRI(WLI)<>0
      WMARGEN=100-(([M:MFG1]ZCOSPRV(WLI)*100)/[M:MFG1]ZNETPRI(WLI))
      [M:MFG1]ZMARGEN(WLI)=WMARGEN
   Endif
   If [F:SOQX]ZQTYBOB<>0
     [M:MFG1]ZKGS(WLI)  =arr(([F:SOQX]QTYSTU/[F:SOQX]ZQTYBOB)*[F:ZMSQ]ZQTYBOBASI,0.0001)
     [M:MFG1]ZIMPOF(WLI)=[M:MFG1]ZKGS(WLI)*[M:MFG1]ZNETPRI(WLI)
     [M:MFG1]ZIMPED(WLI)=([F:SOQX]QTY   /[F:SOQX]ZQTYBOB)*[F:ZMSQ]ZQTYBOBASI*[F:SOPX]NETPRI
   Endif
   #JLPR 07-08-17 10:50
   # Comento, pues las notas indicadas en ficha cliente, pueden cambiarse durante la grabación de pedidos venta
   # Motivo por el cual asigno las notas del pedido en cuestion
   [M:MFG1]ZORDTEX(WLI)=[F:SOHX]SOHTEX1
#   Raz [F:BPCX]
#   Read [BPCX]BPC0=[F:SOHX]BPCORD
#   If fstat=0
#      [M:MFG1]ZORDTEX(WLI)=[F:BPCX]ORDTEX
#   Endif
   Read [F:BPA]BPA0=1;[F:SOHX]BPCORD;[F:SOHX]BPAADD
   If fstat=0
      [M:MFG1]ZBPCADD(WLI)=[F:BPA]BPADES
   Endif
   WLI += 1
Next
Filter [F:ZMSQ]
[M:MFG1]ZNBLP=WLI
Affzo[M:MFG1]35
Return

Subprog LEER_PEDASI_COL
Local Integer WLI
For WLI=0 To [M:MFG1]ZNBLP-1
   If [M:MFG1]ZANCHOP(WLI)=0 and [M:MFG1]ZLONGITUDP(WLI)=0
     Chgstl [M:MFG1]ZNBLP(WLI) With "BACKRED"
   Else
     Chgstl [M:MFG1]ZNBLP(WLI) With ""
   Endif
Next
End

# Despues de actulizar una linea compruebo si se ha borrado
$ACT_PEDASI

Local Integer WLI,WLK, WMFGLIN, WLENC
WLI = 0
While WLI<[M:MFG1]ZNBLP
  WMFGLIN=[M:MFG1]ZMFGLIN(WLI)
  If WMFGLIN>0 Then
    WLENC =0
    # BUSCA SI EXISTE MFGLIN en las lineas
    For WLK = 0 To [M:MFG1]NBLIG - 1
      If WMFGLIN=[M:MFG1]MFGLIN(WLK): WLENC=1: Break : Endif
    Next
    # SI no encuentra borra la linea
    If WLENC = 0 Then
      Dela WLI,1 [M:MFG1]ZNBLP(WLI)
#      Dela WLI,1 [M:MFG1]ZMFGLIN,[M:MFG1]ZSOHNUM,[M:MFG1]ZSOPLIN,[M:MFG1]ZSOQSEQ,[M:MFG1]ZQTYBOBASI
      [M:MFG1]ZNBLP -= 1
      WLI -= 1  # Decremento para volver analizar la misma psosicion ya que el borrado desplaza las componentes de los array.
    Endif
  Endif
  WLI += 1
  #Infbox "ZNBLP:" - num$([M:MFG1]ZNBLP)
Wend

Affzo [M:MFG1]35
Return
