#Recorremos la tabla auxiliar que se ha llendo con la ultima introduccion de grupos de corte para
#pasar esos grupos a las lineas de articulos a fabricar.

NBRLIN=[M:MFG1]ZNBLAUX-1
For NLIN=0 To NBRLIN
   If [M:MFG1]ZLAITMREF(NLIN)<>""
      #status=73 -> insercion linea
      nolign=[M:MFG1]NBLIG+1
      status=73 : Call INSERE("MFGLIN") From TABLEAUX : If mkstat End : Endif
      Call AVANT_NBLIG From SUBMFG
      NOL=[M:MFG1]NBLIG
      Insa NOL,1,[M:MFG1]NBLIG [M:MFG1]NBLIG
      [M:MFG1]NBLIG+=1
      J=NOL : L=NLIN : Gosub COPIA_LIG
      status=0
      #MAXLIN=MAXLIN+1000
      #[M:MFG1]MFGLIN(J)=MAXLIN
      #[M:MFG1]MFGLIN(J)=(J+1)*1000
      #Call APRES_NBLIG From SUBMFG
   Endif
Next

##Calculo de cantidad a producir
