$CALCULA_BOBINAS
  Local Char WFILTRO(250)
  Local Char MSG(250),TXT(250)(10), W(250)(2)
  Local Integer F
  Local Char BD_TIPO(1)

  BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()

  WFILTRO = "MFGNUM_0 = '" + [M:MFG0]MFGNUM + "'"

  TXT(0)="SELECT MFGLIN_0, sum(ZQTYBOBASI_0) As QTYBOB  From ZMFGSOQ "
  TXT(1)="Where " + WFILTRO
  TXT(2)=" GROUP By MFGLIN_0 Order By MFGLIN_0"

  #### las siguientes instrucciones crean un fichero en la carpeta tmp donde esta la sentencia de SQL para poder depurar
  #Local Char FICSRV(250)
  #Local Integer YN
  #Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
  #Call OUINON(FICSRV, YN) From GESECRAN
  #If YN=1
  #  Return
  #Endif

  For (Integer FMFGLIN,Decimal FQTYBOB)
&     From BD_TIPO Sql TXT As [MYT]

      Read [MFI]MFI0 = [M:MFG0]MFGNUM; FMFGLIN
      [MFI]ZBOBCTE = FQTYBOB
      If FQTYBOB > [MFI]ZQTYBOB
        [MFI]ZBOBSTK = 0
      Else
        [MFI]ZBOBSTK = [MFI]ZQTYBOB - FQTYBOB
      Endif

      Rewrite[MFI]

  Next

  # Recorremos las lineas de la OF que no se han filtrado por pedidos y le asignamos todas las bobinas a stock
  Filter [MFI] Where MFGNUM = [M:MFG0]MFGNUM and ZBOBCTE = 0
  For [MFI]
      [MFI]ZBOBSTK = [MFI]ZQTYBOB
      Rewrite[MFI]
  Next
  Filter [MFI]

Return

$APRES_CRE
# Se llama desde APRES_CRE  +  APRES_MOD !!!!!
Update [MFM] Where MFGNUM=[M:MFG0]MFGNUM With MFGLIN=0
If fstat
   Infbox "Error udpate [MFM] (SPEMFG) - fstat: "+num$(fstat)
Else
   [M:MFG2]MFGLIN(0)=0
   [M:MFG2]MFGLINK  =1
Endif
#
Update [MFI] Where MFGNUM=[M:MFG0]MFGNUM and LOT="(Calculado)" With LOT=""
If fstat
   Infbox "Error udpate [MFI] (SPEMFG) - fstat: "+num$(fstat)
Endif
#If GUSER='ADMIN' : Infbox "HOLA" : Endif
# FJCP 28/11/2016   # Forzamos lanzamiento calculo de costes previstos.
Call CALCULA_COSTES([M:MFG0]MFGFCY ,[M:MFG0]MFGNUM)
Gosub CALCULA_BOBINAS
Return

