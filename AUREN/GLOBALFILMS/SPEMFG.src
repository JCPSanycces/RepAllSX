Affzo [M:MFG1]40
mkstat=4 : #Activacion boton "Registrar"
Return

$COPIA_LIG
Local Integer WRET
[M:MFG1]MFGLIN(J)  =[M:MFG1]ZLANUMLIN(L)
[M:MFG1]ITMREF(J)  =[M:MFG1]ZLAITMREF(L)
[M:MFG1]ITMDES1(J) =[M:MFG1]ZLAITMDES1(L)
[M:MFG1]ITMDES1(J) =[M:MFG1]ZLAITMDES1(L)
[M:MFG1]ITMSTA(J)  =1
[M:MFG1]ZQTYBOB(J) =[M:MFG1]ZLAQTYBOB(L)
[M:MFG1]ZANCHO(J)  =[M:MFG1]ZLAANCHO(L)
[M:MFG1]ZLONGITUD(J)=[M:MFG1]ZLALONGITUD(L)
[M:MFG1]ZMANDRIL(J)=[M:MFG1]ZLAMANDRIL(L)
