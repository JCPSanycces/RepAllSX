#<AdxTL>@(#)0.0.0.0 $Revision$
#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
  When "OUVRE"       :  Gosub OUVRE
  When "TITRE"       :  Gosub TITRE_S
  When "DEBUT"       :  Gosub DEBUT
  When "SETBOUT"     :  Gosub SETBOUT

  When "BOUTON"      :  Gosub BOUTON
  When "APRES_MODIF" :  Gosub APRES_MODIF

  When "END"         :  Gosub FIN_S
  When "FIN"
    Call LIBERAR

  When "AVANT_LIS"
    If [M:ZINV0]FLDCHR(3) = ""
      FOK=0
      GMESSAGE="Imposible imprimir\No se ha seleccionado una sesión de inventario"
      GERR=1
    Endif
  When "LIS"

Endcase
Return


$FIN_S
Return

$TITRE_S
TIT="INVENTARIOS"# << EN PRUEBAS # PDTE.VALIDAR >>"
Return

$OUVRE
Local Char BD_TIPO(1),ZMSG(255),WTX(255)
Local Integer YN,FLG_OK
Local Datetime FECHA_CALCULO
Local Integer IF_TRANS   # Se usa para saber si estamos dentro de una transaccion.......18_11_16 En este src será que no

If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS[F:ZINV]  : Endif
If !clalev([F:ITM])      :  Local File ITMMASTER   [F:ITM]   : Endif
If clalev([F:WZINVD])<=0 :  Local File ZINVENTD    [F:WZINVD]: Endif

## Tope de filas en rejilla
#Local Integer TFILAS
#TFILAS=func ZCOMUN.FILAS_GRID("ZPINVE1","NBLIG")
#########################################
### PARAMETROS    son de tipo CHAR     ##
###      nombre parametro máximo 10    ##
#########################################
#Local Char TMP(255)
##Cliente para facturas TPV
#Local Char CTEFRASTPV(GLONBPR)
#Call PARAM("","ZCTEFRASTP",CTEFRASTPV) From ADOVAL
Return


$DEBUT
# Valores por defecto
Gosub BORRA_PANTALLA
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
# Guardo valores
[M:ZINV0]FLDNUM(0) = func ZCOMUN.FILAS_GRID("ZPINVE1","NBLIG")
[M:ZINV0]FLDNUM(1) = 0    # Guardo la fila del cálculo que se está mostrando en Subprog AS_NCALC de fuente SPEZINV0
[M:ZINV0]FLDNUM(2) = 500  # Guardo valor del codigo de actividad para tope filas rejilla Salidas/Entradas varias. Lo bajo de 800 a 500
[M:ZINV0]FLDNUM(3) = 900  # Guardo valor de dimension WSTOSEQ2 en STKIMP.src....Asumo que es el nş de lineas de stock/bobinas..Lo bajo de 1000 a 900
#
[M:ZINV0]FLDCHR(0) = BD_TIPO
[M:ZINV0]FLDCHR(1) = "" # Guardo fecha inventario en      Subprog MOSTRAR_INV
[M:ZINV0]FLDCHR(2) = "" # Guardo estatus linea rejilla
[M:ZINV0]FLDCHR(3) = "" # Guardo fecha inventario en formato CRYSTAL REPORT  aaaa-mm-dd hh:mm:ss
[M:ZINV0]FLDCHR(4) = "" # Guardo titulo listado
[M:ZINV0]FLDCHR(5) = "" # Guardo fecha procesamiento inventario
[M:ZINV0]FLDCHR(6) = "" # Guardo titulo listado fecha
# Valores por defecto
[M:ZINV0]ZMOSTRAR=10
RPROCESO=1 #
Return



$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
#If    COUZON="FEMPALME" and CZ="2"
#    Chgstl [M:ZINV0]FEMPALME With "BACKRED"
#Elsif COUZON="FEMPALME" and CZ="1"
#    Chgstl [M:ZINV0]FEMPALME With ""
#Endif

Case maskcou
When "ZPINVE0"
  # Criterios de seleccion de pedidos
  Call VACIAR_REJILLA
  Case COUZON
  When "ZPROCESO"
    Case CZ
    When "1"
      Actzo [M:ZINV0]5
    When "2","3","4"
      Diszo [M:ZINV0]5
    Endcase
    Raz [M:ZINV0]FARTINI,[M:ZINV0]FARTFIN
    Raz [M:ZINV0]FANCINI,[M:ZINV0]FANCFIN
    Raz [M:ZINV0]FLONINI,[M:ZINV0]FLONFIN
    Raz [M:ZINV0]FMANFIN
  When "FARTINI"
    If [M:ZINV0]FARTFIN<CZ
      [M:ZINV0]FARTFIN=CZ
      Affzo [M:ZINV0]FARTFIN
    Endif
  When "FANCINI"
    If [M:ZINV0]FANCFIN<val(CZ)
      [M:ZINV0]FANCFIN=val(CZ)
      Affzo [M:ZINV0]FANCFIN
    Endif
  When "FLONINI"
    If [M:ZINV0]FLONFIN<val(CZ)
      [M:ZINV0]FLONFIN=val(CZ)
      Affzo [M:ZINV0]FLONFIN
    Endif
  When "FLOCINI"
    If [M:ZINV0]FLOCFIN<CZ
      [M:ZINV0]FLOCFIN=CZ
      Affzo [M:ZINV0]FLOCFIN
    Endif
  Endcase
When "ZPINVE1"
  # Resultados
  Case COUZON
  When "PEDSEL","PBOBINASC"
  Endcase
Endcase
Return



$SETBOUT
# BOTONES, ańadidos a la derecha.    Por defecto SI habilitados
# MENUS  , ańadidos a la derecha.    Por defecto NO habilitados
Gosub ESTADO
Call MOSTRAR_INV_COLOR
Return

$BOUTON
#If date$>=[13/02/2018]     Call ERREURT("Datos licencia insuficientes",1) From GESECRAN     :    Return     Endif
FLG_OK=1
Case BOUT
  When "1"
    WTX="mostrar"
    Gosub MOSTRAR
  When "2"
    WTX="FIJAR"
    Gosub REGISTRAR
    If [M:ZINV0]ZPROCESO=3     Gosub FIN From GSAISIE  Endif
  When "3"
    Gosub BORRAR
Endcase
Return



#===================================
#Subrutinas propias
#===================================
$BORRAR
If [M:ZINV0]ZPROCESO=2 and [M:ZINV0]ZPROCES<>2
  ZMSG="Está seguro de BORRAR esta sesión de inventario\.\Recuerde que NO se borraran las lineas << procesadas >>"
  YN=1 # Por defecto es NO
  Call OUINON(ZMSG, YN) From GESECRAN
  If YN=1
    Return
  Endif
  Call BORRARS
Endif
Return

$MOSTRAR
If [M:ZINV0]ZPROCESO=1
  Raz ZMSG
  If [M:ZINV0]FARTINI="" and [M:ZINV0]FARTFIN=""
    ZMSG+="\Articulo"
  Endif
  If [M:ZINV0]FLOCINI="" and [M:ZINV0]FLOCFIN="" and [M:ZINV0]FLOT="" and [M:ZINV0]FANCINI=0 and [M:ZINV0]FLONINI=0
    ZMSG+="\Ubicación"
  Endif
  If ZMSG<>""
    ZMSG="Está seguro de "+WTX+" un inventario SIN INDICAR"+ZMSG
    YN=1 # Por defecto es NO
    Call OUINON(ZMSG, YN) From GESECRAN
    If YN=1
      FLG_OK=-1
      Return
    Endif
  Endif
  Call MOSTRAR_INV(FLG_OK)
  Call MOSTRAR_INV_COLOR
Endif
Return


$REGISTRAR
Case [M:ZINV0]ZPROCESO
When 1  #  FIJANDO
  If [M:ZINV0]FERR=2 : Return : Endif
  Gosub MOSTRAR
  If FLG_OK=-1
    Return
  Elsif not FLG_OK
    ZMSG= "Imposible continuar, debido al error anterior\Superado limite de filas"
    Call ERREURT(ZMSG,0) From GESECRAN   #0-Informativo, 1-Error
    Return
  Endif
  # No pueden haber albaranes de salida SIN VALIDAR
  ZMSG=func ENT_PDTES
  If ZMSG<>""
      ZMSG= "Imposible fijar inventario hasta validar las siguientes entregas\"+ZMSG
      Call ERREURT(ZMSG,1) From GESECRAN   #0-Informativo, 1-Error
      Return
  Endif
  #
#  ZMSG="Está seguro de fijar estos datos (excepto lineas rojas)\.\ASEGURESE de haber registrado en X3 las entradas !!!!"
#  YN=1 # Por defecto es NO
#  Call OUINON(ZMSG, YN) From GESECRAN
#  If YN=1
#    Return
#  Endif
  Call FIJAR(FLG_OK)
  ZMSG= "Lineas fijadas\Excepto lineas en rojo, por error indicado en columna <<Mensaje>>\.\Siguiente paso, contar e introducirlo"
  Call ERREURT(ZMSG,0) From GESECRAN   #0-Informativo, 1-Error
  Call VACIAR_REJILLA

When 2  # Introducir cuenteo
  If  [M:ZINV0]ZPROCES<>2
    ZMSG="Está seguro de registrar los datos introducidos\Para su posterior procesamiento"
    YN=1 # Por defecto es NO
    Call OUINON(ZMSG, YN) From GESECRAN
    If YN=1
      Return
    Endif
    Call FIJAR(FLG_OK)
    Call VACIAR_REJILLA
  Endif

When 3  # Procesar diferencias
  If  [M:ZINV0]ZPROCES<>2
    ZMSG="Está seguro de PROCESAR los datos introducidos\.\Solo las lineas pdtes de procesar (verde)"
    YN=1 # Por defecto es NO
    Call OUINON(ZMSG, YN) From GESECRAN
    If YN=1
      Return
    Endif
#    If GUSER="ADMIN"
#Infbox "EN PROCESO  27-01-17 10:57"

    Call PROCESAR(FLG_OK)
    Call MOSTRAR_CALCULOS
#    Else
#    ZMSG= "16-01-17 08:00\Proceso pdte consensuar con AZETA"
#    Call ERREURT(ZMSG,0) From GESECRAN   #0-Informativo, 1-Error
#    Endif
  Endif

When 4  # Consultar
Endcase
Return

$BORRA_PANTALLA
Raz [M:ZINV0],[M:ZINV1]
If dim(RPROCESO)>=0
  [M:ZINV0]ZPROCESO=RPROCESO
Endif
Gosub ESTADO
Affzo [M:ZINV0]
Affzo [M:ZINV1]
Affzo [M:ZINV2]
Return

$ESTADO
If GUSER<>"ADMIN"
Chgfmt [M:ZINV0]FSLO With "-"
Endif
Chgfmt [M:ZINV0]FMANINI With "-"
Chgfmt [M:ZINV0]STA     With "-"
Local Char MOSTRAR(1)
Case [M:ZINV0]ZPROCESO
When 1       #  Fijar inventario
  MOSTRAR="-" #"K:10"
  # Rejilla INTOCABLE
When 2,3,4   #  2-Introducir  3-Ajustar
  If [M:ZINV0]ZMOSTRAR<1
    [M:ZINV0]ZMOSTRAR=10
  Endif
  MOSTRAR="+" # Ocultar
  If [M:ZINV0]ZPROCESO=2
    # Puedo ańadir filas a la rejilla
  Else
    # Rejilla INTOCABLE
  Endif
Endcase
Chgfmt [M:ZINV0]ZMOSTRAR With MOSTRAR
Chgfmt [M:ZINV0]ZPROCES  With MOSTRAR
Chgfmt [M:ZINV0]NCALC    With MOSTRAR
Chgfmt [M:ZINV0]CHORA    With MOSTRAR
Chgfmt [M:ZINV0]CFECHA   With MOSTRAR
Affzo [M:ZINV0]
Return



#===================================
#Procedimientos y funciones PROPIOS
#===================================
Subprog PROCESAR(FLG_OK)
Variable Integer FLG_OK
#If GUSER<>"ADMIN"
#Call ERREURT("12-01-17 17:00  JLPR   EN PROCESO ",1) From GESECRAN   #0-Informativo, 1-Error
#End
#Endif
# Determino fecha procesamiento inventario
[M:ZINV0]FLDCHR(5)=format$("D:YYYY[-]MM[-]DD",date$)+"T"+num$(time$)+"Z"
Call OUVRE_TRACE("Incio generación ENT/SAL inventario") From LECFIC
Call ECR_TRACE("Generación ENT/SAL inventario",0) From GESECRAN
Call GENERAR(1,FLG_OK)
Call GENERAR(2,FLG_OK)
Call FEC_PROCES(0,FLG_OK) # STK=CONT
Call VACIAR_REJILLA
Raz [M:ZINV0]FLDCHR(5)
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog GENERAR(MVTO,FLG_OK)
Variable Integer FLG_OK
Value Integer MVTO     #                      1=Salidas     2=Entradas
Local Char MVTO_TYP(2) # Tipo Mvto fic.impor 20=Salidas    19=Entradas
Local Integer F        # Filas de la rejilla
Local Integer DF       # DifŞ=Stk-Cnt        >0=Salidas    <0=Entradas
Local Integer C        # Contador de Mvtos
Local Char X1(5)       # Componer nombre fichero
Local Char ART_LOT(255)# Para sacar ultimo Lote por Articulo/Lote....Rejilla ordenada por
Local Integer ULTSLO   # Guardar el último nş de S/Lote
Local Char RART(GLONITM)
Local Integer TBOB
# Variables para tratamiento fichero
Local Char WDIR(250),WNOM(20),WJOB(10),WXML(250),WOUT(250),WFICH(250),TMP(255)
# Variable para generacion contenido fichero
Local Char LDESMOV(25),LSTOFCY(GLONFCY),LITMREF(GLONITM),LARTAUX(GLONITM)
Local Decimal LNUMLIN, LQTYTOT
Local Char LSLOT(GLONSLO)(500),LSTAT(1)(500),LPCU(GLONUOM)(500)
Local Decimal LQTYSTU(500)

# Valores comunes
LDESMOV="INV."+func ZCOMUN.REPLACE([M:ZINV0]FLDCHR(6)," a las "," ",1,F)
LSTOFCY=[M:ZINV0]FFCY
#
If MVTO=1
  X1="_SAL_"
  WNOM="GFESMO"
  MVTO_TYP="20"
Else
  X1="_ENT_"
  WNOM="GFESMR"
  MVTO_TYP="19"
Endif
Raz LARTAUX,C,RART,TBOB
FLG_OK=1
#If GUSER="PALAU"   Infbox "Depurar   Subprog GENERAR(MVTO,FLG_OK)      SPEZINVE.src"    Endif
For F=0 To [M:ZINV1]NBLIG-1
  If [M:ZINV1]PROCESADO(F)<2 and ([M:ZINV1]ERR(F)<2 or GUSER="PALAU") and [M:ZINV1]OK(F)=2
    DF=[M:ZINV1]BOBCUENTA(F)-[M:ZINV1]BOBSTK(F)
    If DF<0 and MVTO=1
      Gosub DET_CK
      Gosub GENERAR_GRABAR_SAL
      C+=1
    Elsif DF>0 and MVTO=2
      Gosub DET_CK
      Gosub GENERAR_GRABAR_ENT
      C+=1
    Endif
  Endif
Next
# Fin
Gosub $FIN_IMPORT
End

$DET_CK
If C+1>=[M:ZINV0]FLDNUM(2) or RART<>[M:ZINV1]ITMREF(F) or TBOB+abs(DF)>=[M:ZINV0]FLDNUM(3)
  Gosub $FIN_IMPORT
  Raz C,TBOB
  RART=[M:ZINV1]ITMREF(F)
Endif
If C=0
  Gosub ABRIR_FIC
  Gosub GENERAR_GRABAR_CAB
Endif
TBOB+=abs(DF)
Return

$FIN_IMPORT
If C<1    Return     Endif
Openo Using [TIF]   #Cerramos el fichero XML generado
If C>0 and FLG_OK
  # Lanzamos importación
  Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
  # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
  WFICH = filpath(WDIR,WXML,"txt.err")
  If filinfo(WFICH,0) > 0 Then
      MSG= "Hubieron Problemas en la importacion del fichero\"+WXML
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
  Else
    # Actualizo sesion inventario
    Call FEC_PROCES(MVTO,FLG_OK)
    Call ECR_TRACE("=======================================================================================",0) From GESECRAN
    Call ECR_TRACE("=======================================================================================",0) From GESECRAN
  Endif
Endif
Return

$GENERAR_GRABAR_ENT
Local Decimal WTKG,WKG
Gosub LEER_ITM
If [M:ZINV1]NUEVA(F)=2
  WKG  =[M:ZINV1]KGSSTK(F)
Else
  WKG  =arr([M:ZINV1]KGSSTK(F)/[M:ZINV1]BOBSTK(F),0.0001)*abs(DF)
Endif
# <<  Lineas  >>
Call ECR_TRACE(num$(DF)+" Bobinas "+num$([M:ZINV1]ANCHO(F))+"-"+num$([M:ZINV1]LONGITUD(F))+"-"+num$([M:ZINV1]MANDRIL(F))+" Lote: "+[M:ZINV1]LOT(F)+" Ubic.: "+[M:ZINV1]LOC(F),0) From GESECRAN
LNUMLIN+=1000
#Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBENT),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYENT),[F:ITM]STU,num$(LQTYENT),num$(1.9748)
# Using [ZENT]
Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(abs(DF)),num$([M:ZINV1]ANCHO(F)),num$([M:ZINV1]MANDRIL(F)),num$([M:ZINV1]LONGITUD(F)),"",[F:ITM]STU,num$(WKG),[F:ITM]STU,num$(WKG),num$([M:ZINV1]
& PRELOT(F)) Using [TIF]
# << Lineas Det  >>
If ART_LOT<>LARTAUX+[M:ZINV1]LOT(F)
  ART_LOT = LARTAUX+[M:ZINV1]LOT(F)
  ULTSLO  = func ULTSLO(LARTAUX,[M:ZINV1]LOT(F))
Endif
#Raz WTKG
If [M:ZINV1]NUEVA(F)=2
  WKG  =arr([M:ZINV1]KGSSTK(F)/[M:ZINV1]BOBCUENTA(F),0.0001)
Else
  WKG  =arr([M:ZINV1]KGSSTK(F)/[M:ZINV1]BOBSTK(F),0.0001)
Endif
For J=1 To abs(DF)
  ULTSLO+=1
#  If J<abs(DF)
#   WKG  =arr([M:ZINV1]KGSSTK(F)/abs(DF),0.0001)
#    WTKG+=WKG
#  Else
#    WKG=[M:ZINV1]KGSSTK(F)-WTKG
#  Endif
#      Wrseq "S",[F:ITM]STU,num$(LKGTEOBOB),"",[F:ZINVE]LOTE,LNUESLO,[F:ZINVE]LOTEORI,[F:ZINVE]UBICACION,"A" Using [ZENT]
  Wrseq "S",[F:ITM]STU,num$(WKG),"",[M:ZINV1]LOT(F),format$("N0:5",ULTSLO),"",[M:ZINV1]LOC(F),"A" Using [TIF]
Next
Return

$GENERAR_GRABAR_SAL
Local Integer J,WJ
Gosub LEER_ITM
# <<  Lineas  >>
Call ECR_TRACE(num$(DF)+" Bobinas "+num$([M:ZINV1]ANCHO(F))+"-"+num$([M:ZINV1]LONGITUD(F))+"-"+num$([M:ZINV1]MANDRIL(F))+" Lote: "+[M:ZINV1]LOT(F)+" Ubic.: "+[M:ZINV1]LOC(F),0) From GESECRAN
Call BOB_SALIDAS(LPCU,LQTYSTU,LSLOT,LSTAT,LQTYTOT,abs(DF),F)
LNUMLIN+=1000
#Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBSAL),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYSAL),[F:ITM]STU,num$(LQTYSAL) Using [ZSAL]
Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(abs(DF)),num$([M:ZINV1]ANCHO(F)),num$([M:ZINV1]MANDRIL(F)),num$([M:ZINV1]LONGITUD(F)),"",[F:ITM]STU,num$(LQTYTOT),[F:ITM]STU,num$(LQTYTOT) Using [
& TIF]
# << Lineas Det  >>
Raz WJ
For J=0 To dim(LPCU)-1
  If LPCU(J)<>""
    If LPCU(J)=[F:ITM]STU
  #   Wrseq "S",[F:STO]PCU,num$(0-[F:STO]QTYPCU),[F:STO]LOT,[F:STO]SLO,[F:STO]LOC,[F:STO]STA Using [ZSAL]
      Wrseq "S",LPCU(J),num$(0-LQTYSTU(J)),[M:ZINV1]LOT(F),LSLOT(J),[M:ZINV1]LOC(F),LSTAT(J) Using [TIF]
    Else
      MSG= "Aviso GRAVE\La bobina a dar de baja(SubLote="+LSLOT(J)+")\Tiene una unidad de stock("+LPCU(J)+")diferente a la indicada en ficha articulo"+[F:ITM]STU +"\Vea los detalles en traza"
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error"
      Call ECR_TRACE(MSG,1) From GESECRAN
      FLG_OK=0
    Endif
    WJ+=1
  Else
    If WJ<>abs(DF)
      MSG= "Aviso GRAVE\De las "+num$(DF)+" bobinas a dar de baja, solo "+num$(WJ)+" se encontraron en STOCK\Vea los detalles en traza"
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error"
      Call ECR_TRACE(MSG,1) From GESECRAN
      FLG_OK=0
    Endif
    Break
  Endif
Next
Return

$LEER_ITM
If LARTAUX<>[M:ZINV1]ITMREF(F)
  LARTAUX=[M:ZINV1]ITMREF(F)
  Call ECR_TRACE("Art.: "+LARTAUX,0) From GESECRAN
  Raz [F:ITM]
  Read [ITM]ITM0=[M:ZINV1]ITMREF(F)
  If fstat
    MSG= "Error leyendo artículo "+[M:ZINV1]ITMREF(F)+"\fstat: "+num$(fstat)
    Call ERREURT(MSG,1)   From GESECRAN   #0-Informativo, 1-Error
    Call ECR_TRACE(MSG,1) From GESECRAN
  Endif
Endif
Return

$GENERAR_GRABAR_CAB
Raz LNUMLIN
# << Cabecera >>
# Wrseq "E","20","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZSAL]
# Wrseq "E","19","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZENT]
  Wrseq "E",MVTO_TYP,"",LSTOFCY,format$("DDMMYYYY",gdatetime$([M:ZINV0]FLDCHR(5))),LDESMOV,"","" Using [TIF]
Return


Funprog ULTSLO(ART,LOT)
Value Char ART,LOT
Local Char TXT(255)(10),BD_TIPO(1)
Local Integer SLO
BD_TIPO=[M:ZINV0]FLDCHR(0)
Raz TXT,SLO
TXT(0)="select max(cast(SLO_0 as decimal)) "
TXT(1)="from STOLOT "
TXT(2)="where ITMREF_0='"+ART+"' and LOT_0='"+LOT+"'"
For (Decimal WFSLO) From BD_TIPO Sql TXT As [MYT]
  SLO=WFSLO
  Break
Next
End SLO


Subprog BOB_SALIDAS(LPCU,LQTYSTU,LSLOT,LSTAT,LQTYTOT,BOB,F)
Variable Decimal LQTYSTU(),LQTYTOT
Variable Char LPCU(),LSLOT(),LSTAT()
Value Integer BOB,F
Local Char TXT(255)(10),BD_TIPO(1)
Local Integer L
Raz LPCU,LQTYSTU,LSLOT,LSTAT,LQTYTOT,L,TXT
BD_TIPO=[M:ZINV0]FLDCHR(0)
TXT(0)="select top "+num$(BOB)+" s.PCU_0,s.QTYSTU_0,s.SLO_0,s.STA_0 "
TXT(1)="from STOCK s left join STOALL a on s.STOFCY_0=a.STOFCY_0 and s.ITMREF_0=a.ITMREF_0 and s.STOCOU_0=a.STOCOU_0 "
TXT(2)="where a.STOFCY_0 is null and s.STOFCY_0='"+[M:ZINV0]FFCY+"' and s.ITMREF_0='"+[M:ZINV1]ITMREF(F)+"' "
TXT(3)="and s.LOT_0='"+[M:ZINV1]LOT(F)+"' and s.LOC_0='"+[M:ZINV1]LOC(F)+"' and ZANCHO_0="+num$([M:ZINV1]ANCHO(F))+" "
TXT(4)="and ZLONGITUD_0="+num$([M:ZINV1]LONGITUD(F))+" and ZMANDRIL_0="+num$([M:ZINV1]MANDRIL(F))
If [M:ZINV0]FSLO<>""
  TXT(4)+="and s.SLO_0='" + [M:ZINV0]FSLO + "' "
Endif
For (Char WFPCU(GLONUOM),Double WFQTYSTU,Char WFSLO(GLONSLO),Char WFSTA(5)) From BD_TIPO Sql TXT As [MYT]
  LPCU(L)   =WFPCU
  LQTYSTU(L)=WFQTYSTU
  LSLOT(L)  =WFSLO
  LSTAT(L)  =WFSTA
  LQTYTOT  +=WFQTYSTU
  L+=1
Next
End

$ABRIR_FIC
# Tambien se llama desde ZBAJASTK.src
# Comprobar directorio y crearlo en caso de que no exista
WDIR="ZIMPEXP\IMPOR"
TMP=filpath("","","","","",adxmac(0)) +"\" + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
# Montar nombre Fichero
#WNOM="GFESMO"    #   Modelo de importación
WJOB = num$(time)
WXML = WNOM+X1+format$("D:YYYYMMDD",date$)+"_"+WJOB
WOUT = filpath(WDIR,WXML,"txt")
# Abrir fichero
adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII
Openo WOUT,0 Using [TIF]
Return

Subprog LIBERAR
Local Datetime FEC
If [M:ZINV0]FLDCHR(1)<>"" and [M:ZINV0]ZPROCESO<>4
  FEC=gdatetime$([M:ZINV0]FLDCHR(1))
  If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS [F:ZINV] : Endif
  Update [F:ZINV] Where FECHA=FEC and LOCKUSU<>"" With LOCKUSU=""
  If fstat<>0
    FLG_OK=0
    MSG= "No fue posible actualizar\Subprog LIBERAR\(Update [F:ZINV] Where FECHA=FEC With LOCKUSU=GUSER)"
    Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
  Endif
Endif
End

Subprog FEC_PROCES(M,FLG_OK)
Value Integer M  #  0=Iguales    1=Salidas    2=Entradas
Variable Integer FLG_OK
Local Char X1(255)
Local Datetime FEC,FEC2
FEC2=gdatetime$([M:ZINV0]FLDCHR(5))
FEC=gdatetime$([M:ZINV0]FLDCHR(1))
If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS [F:ZINV] : Endif
Case M
When 0 # Iguales
  X1="Stock correcto"
  Update [F:ZINV] Where FECHA=FEC and ERR<2 and PROCESADO<2 and OK=2 and BOBSTK=BOBCUENTA  With PROCESADO=2,PROCESFEC=FEC2
When 1 # Salidas
  X1="Salidas"
  Update [F:ZINV] Where FECHA=FEC and ERR<2 and PROCESADO<2 and OK=2 and BOBSTK>BOBCUENTA  With PROCESADO=2,PROCESFEC=FEC2
When 2 # Entradas
  X1="Entradas"
  Update [F:ZINV] Where FECHA=FEC and ERR<2 and PROCESADO<2 and OK=2 and BOBSTK<BOBCUENTA  With PROCESADO=2,PROCESFEC=FEC2
Endcase
If fstat<>0
  FLG_OK=0
  MSG= "AVISE AL PROGRAMADOR !!!!\.\No fue posible actualizar\Subprog FEC_PROCES(M)\"+X1+"\(Update [F:ZINV] Where FECHA=FEC......)"
  Call ECR_TRACE(MSG,1) From GESECRAN
  Call ERREURT(MSG,0)   From GESECRAN   #0-Informativo, 1-Error
Else
  FLG_OK=1
  Call ECR_TRACE("Fin procesamiento.   Lineas procesadas ("+X1+"): "+num$([S]adxuprec),0) From GESECRAN
Endif
End

Subprog BORRARS
Local Datetime DT
DT=gdatetime$([M:ZINV0]FLDCHR(1))
If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS [F:ZINV] : Endif
Delete [F:ZINV] Where FECHA=DT and [F:ZINV]PROCESFEC=[0/0/0]
Call VACIAR_REJILLA
Call MOSTRAR_CALCULOS
End

Subprog MOSTRAR_INV_FIC(WF)
Value Integer WF
Local Integer FLG_OK,YN
Local Char MSG(255),WFILT(255)
FLG_OK=1
#Variables para llenar rejilla
Local Char FITM(GLONITM),FUBI(GLONLOC),FLOT(GLONLOT),FZLOT(GLONLOT)
Local Double FANC, FFAC, FKGS, FBOB, FSTK
Local Integer FLNG
Local Shortint FMAN
#Variable comunes con Subprog MOSTRAR_INV
Local Integer BOB(2),F,TF,M2
Local Decimal KGS(2),PREC(3),DF
Local Char RART(GLONITM),MSG(255),DT(50)
BD_TIPO=[M:ZINV0]FLDCHR(0)
TF     =[M:ZINV0]FLDNUM(0)
#
Call VACIAR_REJILLA
Local Datetime FEC
[M:ZINV0]FLDCHR(1)=format$("D:YYYY[-]MM[-]DD",[M:ZINV0]CFECHA(WF))+"T"+[M:ZINV0]CHORA(WF)+"Z"
[M:ZINV0]FLDCHR(3)=format$("D:YYYY[-]MM[-]DD",[M:ZINV0]CFECHA(WF))+" "+[M:ZINV0]CHORA(WF)
[M:ZINV0]FLDCHR(6)=format$("D:DD[-]MM[-]YYYY",[M:ZINV0]CFECHA(WF)) +" a las "+[M:ZINV0]CHORA(WF)
[M:ZINV0]FLDCHR(4)="LISTADO SESION INVENTARIO DEL "+[M:ZINV0]FLDCHR(6)
FEC=gdatetime$([M:ZINV0]FLDCHR(1))
If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS [F:ZINV] : Endif
[M:ZINV0]STA="F"
If [M:ZINV0]ZPROCESO=2
  Filter [F:ZINV] Where FECHA=FEC Order With "NUEVA;LOC;ITMREF;LOT;ANCHO;LONGITUD;MANDRIL"
Elsif [M:ZINV0]ZPROCESO=3
  # Ordeno por articulo, para agrupar x articulo al generar Mvtos   y sacar ultimo nş SLO x ART+LOT
  Filter [F:ZINV] Where FECHA=FEC and PROCESADO<2 Order With "ITMREF;LOT;ANCHO;LONGITUD;MANDRIL;LOC"
Else
  Filter [F:ZINV] Where FECHA=FEC Order With "ITMREF;ANCHO;LONGITUD;MANDRIL;LOC;LOT"
Endif
For [F:ZINV]
  #Comprobar si está en uso por otro usuario
  If [M:ZINV0]ZPROCESO<>4 and [F:ZINV]LOCKUSU<>"" and [F:ZINV]LOCKUSU<>GUSER and GUSER<>"ADMIN"
    If clalev([F:ZAUS])<=0   :  Local File AUTILIS [F:ZAUS] : Endif
    Read [F:ZAUS]CODUSR=[F:ZINV]LOCKUSU
    MSG="Imposible acceder a la sesión seleccionda\El usuario   "+[F:ZINV]LOCKUSU+"="+toupper([F:ZAUS]NOMUSR)+"    está trabajando con ella"
    Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
    FLG_OK=0
    Break
  Else
    If [F:ZINV]LOCKUSU<>"" and [M:ZINV1]NBLIG=0
      If GUSER="ADMIN"
        If [M:ZINV0]ZPROCESO=4
          MSG="AVISO !!!!\Los datos podrias ser cambiados\.\El usuario   "+[F:ZINV]LOCKUSU+"    está trabajando con esta sesión de inventario"
          Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
        Else
          MSG="AVISO para usuario  ADMIN\.\Imposible acceder a la sesión seleccionda\El usuario   "+[F:ZINV]LOCKUSU+"    está trabajando con ella\.\Está seguro de continuar"
          YN=1 # Por defecto es NO
          Call OUINON(MSG, YN) From GESECRAN
          If YN=1
            FLG_OK=0
            Break
          Endif
        Endif
      Elsif [F:ZINV]LOCKUSU=GUSER
        MSG="Está sesion de inventario está bloqueada por usted\No debería de continuar en caso de tenerla abierta en otra pantalla !!!\.\Está seguro de continuar"
        YN=1 # Por defecto es NO
        Call OUINON(MSG, YN) From GESECRAN
        If YN=1
          FLG_OK=0
          Break
        Endif
      Endif
    Endif
    [M:ZINV0]FFCY=[F:ZINV]FCY
    FITM =[F:ZINV]ITMREF
    FUBI =[F:ZINV]LOC
    FLOT =[F:ZINV]LOT
    FANC =[F:ZINV]ANCHO
    FLNG =[F:ZINV]LONGITUD
    FMAN =[F:ZINV]MANDRIL
    FFAC =[F:ZINV]FACTORART
    FKGS =[F:ZINV]KGSSTK
    FSTK =[F:ZINV]FACTORSTK
    FBOB =[F:ZINV]BOBSTK
    FZLOT=[F:ZINV]ZLOTORI
    Gosub PASAR_A_M_ZINV1
    If FLG_OK=0
      Break
    Endif
  Endif
Next
Filter [F:ZINV]
Affzo  [M:ZINV0]FFCY
If FLG_OK
  Call RESUMEN
  If [M:ZINV0]ZPROCESO<>4
    Update [F:ZINV] Where FECHA=FEC With LOCKUSU=GUSER
    If fstat<>0
      FLG_OK=0
      MSG= "No fue posible actualizar\Subprog MOSTRAR_INV_FIC(WF)\(Update [F:ZINV] Where FECHA=FEC With LOCKUSU=GUSER)"
      Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
    Endif
  Endif
Else
  Raz [M:ZINV0]FLDCHR(1),[M:ZINV0]FLDCHR(3),[M:ZINV0]FLDCHR(4)
  Call VACIAR_REJILLA
Endif
Filter [F:ZINV]
Affzo [M:ZINV1]
[M:ZINV0]STA=""
End

Subprog RESUMEN
Local Integer RBOB(2),F,B
Local Decimal RKGS(2),RIMP(2)
Raz RBOB,RKGS,RIMP
Call VACIAR_REJILLA2
For F=0 To [M:ZINV1]NBLIG-1
  If [M:ZINV1]OK(F)=2 and [M:ZINV1]IGNORAR(F)<2
    DF=[M:ZINV1]BOBCUENTA(F)-[M:ZINV1]BOBSTK(F)
    # Determinar Kgs bobina = TotalKgsStock / Bobinas Stock ó Contadas
    If [M:ZINV1]NUEVA(F)=2
      B=[M:ZINV1]BOBCUENTA(F)
    Else
      B=[M:ZINV1]BOBSTK(F)
    Endif
    KGS=([M:ZINV1]KGSSTK(F)/B)*DF
    #
    If DF<0
      RBOB(0)+=DF
      RKGS(0)+=KGS
      RIMP(0)+=KGS*[M:ZINV1]PRELOT(F)
    Elsif DF>0
      RBOB(1)+=DF
      RKGS(1)+=KGS
      RIMP(1)+=KGS*[M:ZINV1]PRELOT(F)
    Endif
  Endif
Next
F=[M:ZINV2]NBLIG
[M:ZINV2]RTIPO(F)="Salidas"
[M:ZINV2]RBOB(F) =RBOB(0)
[M:ZINV2]RKGS(F) =RKGS(0)
[M:ZINV2]RIMPO(F)=RIMP(0)
If [M:ZINV2]RKGS(F)<>0
[M:ZINV2]RPREC(F)=arr([M:ZINV2]RIMPO(F)/[M:ZINV2]RKGS(F),0.0001)
Endif
[M:ZINV2]NBLIG+=1
F=[M:ZINV2]NBLIG
[M:ZINV2]RTIPO(F)="Entradas"
[M:ZINV2]RBOB(F) =RBOB(1)
[M:ZINV2]RKGS(F) =RKGS(1)
[M:ZINV2]RIMPO(F)=RIMP(1)
If [M:ZINV2]RKGS(F)<>0
[M:ZINV2]RPREC(F)=arr([M:ZINV2]RIMPO(F)/[M:ZINV2]RKGS(F),0.0001)
Endif
[M:ZINV2]NBLIG+=1
F=[M:ZINV2]NBLIG
[M:ZINV2]RTIPO(F)="Resultado"
[M:ZINV2]RBOB(F) =RBOB(0)+RBOB(1)
[M:ZINV2]RKGS(F) =RKGS(0)+RKGS(1)
[M:ZINV2]RIMPO(F)=RIMP(0)+RIMP(1)
If [M:ZINV2]RKGS(F)<>0
[M:ZINV2]RPREC(F)=arr([M:ZINV2]RIMPO(F)/[M:ZINV2]RKGS(F),0.0001)
Endif
[M:ZINV2]NBLIG+=1
Affzo [M:ZINV2]
End

Subprog FIJAR(FLG_OK)
Variable Integer FLG_OK
Local Integer F
Local Datetime DT
DT=gdatetime$([M:ZINV0]FLDCHR(1))
If clalev([F:ZINV])<=0   :  Local File ZINVENTARIOS [F:ZINV] : Endif
Trbegin [F:ZINV]
#Si introduciendo cuenteo, borrar 1ş
If [M:ZINV0]ZPROCESO=2
  Delete [F:ZINV] Where FECHA=DT
Endif
#Grabar rejilla
For F=0 To [M:ZINV1]NBLIG-1
  If (GUSER="PALAU" or [M:ZINV1]ERR(F)=1) or [M:ZINV0]ZPROCESO=2
    Raz [F:ZINV]
    Gosub PASAR_A_ZINV
    Write [F:ZINV]
    If fstat<>0
      MSG="NO fue posible fijar inventario\debido al error (fstat="+num$(fstat)+") en fila nş "+num$(F+1)+"\"+[M:ZINV1]ITMREF(F)+"-"+num$([M:ZINV1]ANCHO(F))+"-"+num$([M:ZINV1]LONGITUD(F))+"-"+num$([M:
& ZINV1]MANDRIL(F))+" Lot:"+[M:ZINV1]LOT(F)+"  Ubic:"+[M:ZINV1]LOC(F)+"\Probablemente sea debido a que hay diferentes LOTE ORIGEN para un mismo lote\Compruébelo mediuante opción MOSTRAR "
      Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
      FLG_OK=0
      Break
    Endif
  Endif
Next
If FLG_OK
  Commit
Else
  Rollback
Endif
End

$PASAR_A_ZINV
[F:ZINV]FECHA    =DT
[F:ZINV]ZHORA    =format$("D:hh[:]mm[:]ss",DT)
[F:ZINV]FCY      =[M:ZINV0]FFCY
[F:ZINV]ITMREF   =[M:ZINV1]ITMREF(F)
[F:ZINV]ANCHO    =[M:ZINV1]ANCHO(F)
[F:ZINV]LONGITUD =[M:ZINV1]LONGITUD(F)
[F:ZINV]MANDRIL  =[M:ZINV1]MANDRIL(F)
[F:ZINV]LOT      =[M:ZINV1]LOT(F)
[F:ZINV]LOC      =[M:ZINV1]LOC(F)
[F:ZINV]BOBCUENTA=[M:ZINV1]BOBCUENTA(F)
[F:ZINV]OK       =[M:ZINV1]OK(F)
[F:ZINV]BOBSTK   =[M:ZINV1]BOBSTK(F)
[F:ZINV]BOBASIPED=[M:ZINV1]BOBASIPED(F)
[F:ZINV]BOBASIOF =[M:ZINV1]BOBASIOF(F)
[F:ZINV]FACTORART=[M:ZINV1]FACTORART(F)
[F:ZINV]FACTORSTK=[M:ZINV1]FACTORSTK(F)
[F:ZINV]KGSSTK   =[M:ZINV1]KGSSTK(F)
[F:ZINV]PRECOS   =[M:ZINV1]PRECOS(F)
[F:ZINV]PREMED   =[M:ZINV1]PREMED(F)
[F:ZINV]PRELOT   =[M:ZINV1]PRELOT(F)
[F:ZINV]NUEVA    =[M:ZINV1]NUEVA(F)
[F:ZINV]MENSAJE  =[M:ZINV1]MENSAJE(F)
[F:ZINV]ERR      =[M:ZINV1]ERR(F)
[F:ZINV]PROCESADO=[M:ZINV1]PROCESADO(F)
[F:ZINV]ERR      =[M:ZINV1]ERR(F)
[F:ZINV]IGNORAR  =[M:ZINV1]IGNORAR(F)
[F:ZINV]ZLOTORI  =[M:ZINV1]ZLOTORI(F)
If [M:ZINV1]PROCESFECHA(F)<>""
[F:ZINV]PROCESFEC=gdatetime$([M:ZINV1]PROCESFECHA(F))
[F:ZINV]PROCESADO=2   # Por asegurar
Endif
Return

Subprog MOSTRAR_INV(FLG_OK)
Variable Integer FLG_OK
Local Char T(255),W(255),TXT(255)(10),BD_TIPO(1)
#Variables para llenar rejilla
Local Char FITM(GLONITM),FUBI(GLONLOC),FLOT(GLONLOT),FZLOT(GLONLOT)
Local Double FANC, FFAC, FKGS, FBOB, FSTK
Local Integer FLNG
Local Shortint FMAN
#Variable comunes con Subprog MOSTRAR_INV_FIC
Local Integer BOB(2),F,TF,M2
Local Decimal KGS(2),PREC(3),DF
Local Char RART(GLONITM),MSG(255),DT(50)
BD_TIPO=[M:ZINV0]FLDCHR(0)
TF     =[M:ZINV0]FLDNUM(0)
Raz T,TXT,RART
W=func SQL_WHERE
W=func ZCOMUN.REPLACE(W, "ITMREF_0"  , "s.ITMREF_0"  , 2, F)
W=func ZCOMUN.REPLACE(W, "ZMANDRIL_0", "s.ZMANDRIL_0", 1, F)
Call VACIAR_REJILLA
TXT(0)="select s.ITMREF_0,ZANCHO_0,ZLONGITUD_0,s.ZMANDRIL_0,LOC_0,LOT_0,a.ZFACTOR_0,ZLOTORI_0,sum(QTYSTU_0) as Kgs, count(SLO_0) AS Bob, avg(s.ZFACTOR_0) as FactStk "
TXT(1)="from STOCK s inner join ITMMASTER a on s.ITMREF_0=a.ITMREF_0 "
TXT(2)="where STOFCY_0='"+[M:ZINV0]FFCY+"' "
If W<>""
  TXT(2)+=W
  If [M:ZINV0]FSLO<>""
    TXT(2)+="and SLO_0='" + [M:ZINV0]FSLO + "' "
  Endif
Endif
TXT(3)="group by s.ITMREF_0,ZANCHO_0,ZLONGITUD_0,s.ZMANDRIL_0,LOC_0,LOT_0,a.ZFACTOR_0,ZLOTORI_0 "
TXT(4)="order by   ITMREF_0,ZANCHO_0,ZLONGITUD_0,  ZMANDRIL_0,LOC_0,LOT_0"
#Bloqueo la tabla STOCK, para evitar interferencias
If clalev([F:STO]) <=0   :  Local File STOCK        [F:STO]  : Endif
Lock [F:STO] With lockwait=5
If fstat<>0
  MSG="Algún proceso está usando el STOCK\Fué imposible bloquear la tabla de STOCK\Revise los procesos y vuélvalo a intentar"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  FLG_OK=0
  Return
Endif
# Determino fecha fijación inventario
[M:ZINV0]FLDCHR(1)=format$("D:YYYY[-]MM[-]DD",date$)+"T"+num$(time$)+"Z"
#If GUSER="ADMIN"
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Local Integer YN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  End
#Endif
#Endif
[M:ZINV0]STA="F"
For (Char FITM(GLONITM),Double FANC,Integer FLNG,Shortint FMAN,Char FUBI(GLONLOC),Char FLOT(GLONLOT),Double FFAC,Char FZLOT(GLONLOT),Double FKGS,Double FBOB,Double FSTK) From BD_TIPO Sql TXT As [MYT]
  FITM =[MYT]FITM
  FANC =[MYT]FANC
  FLNG =[MYT]FLNG
  FMAN =[MYT]FMAN
  FUBI =[MYT]FUBI
  FLOT =[MYT]FLOT
  FFAC =[MYT]FFAC
  FZLOT=[MYT]FZLOT
  FKGS =[MYT]FKGS
  FSTK =[MYT]FSTK
  FBOB =[MYT]FBOB
  Gosub PASAR_A_M_ZINV1
  If FLG_OK=0
    Break
  Endif
Next
Unlock [F:STO]
Affzo [M:ZINV1]
[M:ZINV0]STA=""
End


$PASAR_A_M_ZINV1
Raz MSG
Local Integer BOBI,BOB_DISP
If [F:ZINV]NUEVA=2
  BOBI=[F:ZINV]BOBCUENTA
Else
  BOBI=FBOB
Endif
M2=(FANC*FLNG/1000)*BOBI
If M2<=0 : M2=1 : Endif
If RART<>FITM
  Call PRECIOS([M:ZINV0]FFCY,FITM,PREC)
  RART=FITM
Endif
If [M:ZINV0]ZPROCESO<>4
Call CTAD_ASIG(FFCY,FITM,FANC,FLNG,FMAN,"PED","",FLOT,FUBI,KGS(0),BOB(0)) From ZCNSSFCSTD
Call CTAD_ASIG(FFCY,FITM,FANC,FLNG,FMAN,"OF" ,"",FLOT,FUBI,KGS(1),BOB(1)) From ZCNSSFCSTD
Endif
F=[M:ZINV1]NBLIG
If [M:ZINV0]ZPROCESO=1
  [M:ZINV1]NUEVA(F)      =1
Else
  [M:ZINV1]NUEVA(F)      =[F:ZINV]NUEVA
  [M:ZINV1]PROCESADO(F)  =[F:ZINV]PROCESADO
  DT=format$("D:DD[-]MM[-]YYYY[ ]hh[:]mm[:]ss",[F:ZINV]PROCESFEC)
  If vireblc(DT,4)<>"--::"
  [M:ZINV1]PROCESFECHA(F)=DT
  Endif
#  If [F:ZINV]PROCESFEC<>[0/0/0]
#  [M:ZINV1]PROCESFECHA(F)=format$("D:DD[-]MM[-]YYYY[ ]hh[:]mm[:]ss",[F:ZINV]PROCESFEC)
#  Endif
  [M:ZINV1]IGNORAR(F )   =[F:ZINV]IGNORAR
  [M:ZINV1]OK(F)         =[F:ZINV]OK
  [M:ZINV1]BOBCUENTA(F ) =[F:ZINV]BOBCUENTA
  [M:ZINV1]PRELOT(F)     =[F:ZINV]PRELOT
  [M:ZINV1]ERR(F)        =[F:ZINV]ERR
  [M:ZINV1]BOBASIPED(F)  =[F:ZINV]BOBASIPED
  [M:ZINV1]BOBASIOF(F)   =[F:ZINV]BOBASIOF
  [M:ZINV1]MENSAJE(F)    =[F:ZINV]MENSAJE
#  MSG=[F:ZINV]MENSAJE
Endif
[M:ZINV1]ITMREF(F)     =FITM
[M:ZINV1]ANCHO(F)      =FANC
[M:ZINV1]LONGITUD(F)   =FLNG
[M:ZINV1]MANDRIL(F)    =FMAN
[M:ZINV1]LOT(F)        =FLOT
[M:ZINV1]LOC(F)        =FUBI
[M:ZINV1]BOBSTK(F)     =FBOB
[M:ZINV1]ZLOTORI(F)    =FZLOT
If [M:ZINV0]ZPROCESO=1
  [M:ZINV1]BOBASIPED(F)=BOB(0)
  [M:ZINV1]BOBASIOF(F) =BOB(1)
Else
  If [M:ZINV1]PROCESADO(F)<2 and [M:ZINV0]ZPROCESO<>4
#    If [M:ZINV1]NUEVA(F)<2
#      If FUBI="13272100" and FLOT="033176004" and FANC=670 and FLNG=5300
#        Infbox "Depurar"
#      Endif
      DF=func BOB_STK(F)
      #Ver si ahora YA NO ESTAN  ASIGNADAS las bobinas que habia
      BOB_DIF=[F:ZINV]BOBCUENTA-[M:ZINV1]BOBSTK(F)   # Determino bobinas a SACAR/SALIDA
      If BOB_DIF<0 and [F:ZINV]BOBCUENTA<([F:ZINV]BOBASIPED+[F:ZINV]BOBASIOF) and [F:ZINV]BOBCUENTA>=(BOB(0)+BOB(1)) and DF>=abs(BOB_DIF) and [F:ZINV]ERR=2
        nolign=F+1
        Call BOB_ASI_MSG("") From SPEZINV1
        [M:ZINV1]BOBASIPED(F)=BOB(0)
        [M:ZINV1]BOBASIOF(F) =BOB(1)
#        [M:ZINV1]BOBSTK(F)   =DF
      Else
        If DF<>FBOB
          MSG+="Ha cambiado Stk.Fisico Ahora "+num$(DF)+"<>"+num$(FBOB)+"Fijación)#"
        Endif
        If [F:ZINV]OK=2 and [F:ZINV]BOBCUENTA<([F:ZINV]BOBASIPED+[F:ZINV]BOBASIOF)
          MSG+="Bob Contadas inferior a Asignadas#"
        Endif
        If DF-BOB(0)+BOB(1)<>FBOB-[F:ZINV]BOBASIPED+[F:ZINV]BOBASIOF
          MSG+="Ha cambiado Stk.Disp Ahora "+num$(DF-BOB(0)-BOB(1))+"<>"+num$(FBOB-[F:ZINV]BOBASIPED-[F:ZINV]BOBASIOF)+"Fijación)#"
        Endif
      Endif
#    Endif
  Endif
Endif
[M:ZINV1]BOBDISP(F)    =[M:ZINV1]BOBSTK(F)-[M:ZINV1]BOBASIPED(F)-[M:ZINV1]BOBASIOF(F)
[M:ZINV1]FACTORART(F)  =arr(FFAC   ,0.0000001)
[M:ZINV1]FACTORSTK(F)  =arr(FKGS/M2,0.0000001)  #FACTOR =KGS / M2      KGS = FACTOR * M2
[M:ZINV1]KGSSTK(F)     =FKGS
[M:ZINV1]LNGSTK(F)     =FLNG*BOBI
If FSTK<>0 and FANC<>0
[M:ZINV1]LNGTEO(F)     =arr((FKGS/FSTK)/FANC*1000,1)   #arr((FKGS/[M:ZINV1]FACTORSTK(F))/FANC*1000,1)
Endif
[M:ZINV1]PRECOS(F)     =PREC(0)
[M:ZINV1]PREMED(F)     =PREC(1)
If [M:ZINV0]ZPROCESO=1
  [M:ZINV1]PRELOT(F)     =func PRECIOS_LOT ([M:ZINV0]FFCY,FITM,FLOT,FUBI)
Endif
# Errores
If [M:ZINV0]ZPROCESO<>4
  DF=[M:ZINV1]LNGSTK(F)-[M:ZINV1]LNGTEO(F)
  If abs(DF)>5
    MSG+="Revise stock hay una difŞ de "+num$(DF)+" entre Lng stk y teórica#"
  Elsif [M:ZINV0]ZPROCESO=1
    MSG+=func INVENTARIO_EN_CURSO(F)
  Endif
  [M:ZINV1]MENSAJE(F)   =MSG
  #If [M:ZINV0]ZPROCESO=1
  If MSG=""
    [M:ZINV1]ERR(F)       =1
    If [M:ZINV0]ZPROCESO=3 and [F:ZINV]ERR=2
    #  Infbox "Depurar"
#      [F:ZINV]MENSAJE     =MSG
      [F:ZINV]ERR      =1
      [F:ZINV]BOBASIPED=BOB(0)
      [F:ZINV]BOBASIOF =BOB(1)
#      [F:ZINV]BOBSTK(F)   =DF
      Rewrite [F:ZINV]
    Endif
  Else
    [M:ZINV1]ERR(F)       =2
Endif
#Endif
Endif

If [M:ZINV0]FERR=1 or ([M:ZINV0]FERR=2 and [M:ZINV1]ERR(F)=2)
  If [M:ZINV1]NBLIG+1>=TF
    MSG="Alcanzado máximo de " + num$(TF+1) + " filas para inventario\.\Ajuste los filtros"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    FLG_OK=0
  Else
    [M:ZINV1]NBLIG+=1
  Endif
Endif
Return

Funprog BOB_STK(F)
Value Integer F
Local Integer BOB
Local Char TXT(255)(10),BD_TIPO(1)
BD_TIPO=[M:ZINV0]FLDCHR(0)
Raz BOB,TXT
TXT(0)="select count(*) as Bob "
TXT(1)="from STOCK "
TXT(2)="where STOFCY_0='"+[M:ZINV0]FFCY+"' and ITMREF_0='"+[M:ZINV1]ITMREF(F)+"' and ZANCHO_0="+num$([M:ZINV1]ANCHO(F))+" "
TXT(3)="and ZMANDRIL_0="+num$([M:ZINV1]MANDRIL(F))+" and ZLONGITUD_0="+num$([M:ZINV1]LONGITUD(F))+" and LOC_0='"+[M:ZINV1]LOC(F)+"' and LOT_0='"+[M:ZINV1]LOT(F)+"' "
If [M:ZINV0]FSLO<>""
  TXT(3)+="and SLO_0='" + [M:ZINV0]FSLO + "' "
Endif
For (Integer WFBOB) From BD_TIPO Sql TXT As [WYZ]
  BOB=WFBOB
Next
End BOB


Subprog MOSTRAR_INV_COLOR
Local Integer F
For F=0 To [M:ZINV1]NBLIG-1
  If [M:ZINV1]PROCESADO(F)    =2
    Chgstl [M:ZINV1]NBLIG(F) With "BACKYELLOW"
  Elsif [M:ZINV1]ERR(F)       =2
    Chgstl [M:ZINV1]NBLIG(F) With "BACKRED"
  Elsif [M:ZINV1]OK(F)        =2
    Chgstl [M:ZINV1]NBLIG(F) With "BACKGREEN"
  Else
    Chgstl [M:ZINV1]NBLIG(F) With ""
  Endif
  If [M:ZINV1]NUEVA(F)=2
    Chgstl [M:ZINV1]ITMREF(F) With "AMKCUR"
    Chgstl [M:ZINV1]NUEVA(F)  With "AMKCUR"
    Chgstl [M:ZINV1]BOBSTK(F) With "AMKCUR"
  Endif
Next
End

Funprog INVENTARIO_EN_CURSO(F)
Value Integer F
Local Char M(255),TXT(255)(4),BD_TIPO(1)
Raz M,TXT
BD_TIPO=[M:ZINV0]FLDCHR(0)
TXT(0)="select FECHA_0 "
TXT(1)="from ZINVENTARIOS "
TXT(2)="where ERR_0=1 and PROCESADO_0=1 and FCY_0='"+[M:ZINV0]FFCY+"' and ITMREF_0 ='"+[M:ZINV1]ITMREF(F)+"' and ANCHO_0="+num$([M:ZINV1]ANCHO(F))+" and LONGITUD_0="+num$([M:ZINV1]LONGITUD(F))
TXT(3)=" and MANDRIL_0="+num$([M:ZINV1]MANDRIL(F))+" and LOC_0='"+[M:ZINV1]LOC(F)+"' and LOT_0='"+[M:ZINV1]LOT(F)+"' "
For (Datetime WFFEC) From BD_TIPO Sql TXT As [MYT]
  M="En proceso inventario el "+format$("D:DD[-]MM[-]YYYY[ ]hh[:]mm[:]ss",WFFEC)
Next
End M

Subprog PRECIOS(FCY,ART,PREC)
Value Char FCY,ART
Variable Decimal PREC()
Local Char TXT(255)(4),BD_TIPO(1)
Raz PREC
BD_TIPO=[M:ZINV0]FLDCHR(0)
#Precio Coste
Raz TXT
TXT(0)="select CSTTOT_0 "
TXT(1)="from ITMCOST "
TXT(2)="where STOFCY_0='"+FCY+"' and ITMREF_0 ='"+ART+"' and  CSTTYP_0=1"
For (Double WFPRE) From BD_TIPO Sql TXT As [MYT0]
  PREC(0)=[MYT0]WFPRE
Next
#Precio Medio
Raz TXT
TXT(0)="select AVC_0 "
TXT(1)="from ITMMVT "
TXT(2)="where STOFCY_0='"+FCY+"' and ITMREF_0 ='"+ART+"' "
For (Double WFPRE) From BD_TIPO Sql TXT As [MYT1]
  PREC(1)=[MYT1]WFPRE
Next
End

Funprog PRECIOS_LOT(FCY,ART,LOT,LOC)
Value Char FCY,ART,LOT,LOC
#Precio medio Lotes
Local Decimal PREC
Local Char TXT(255)(4),BD_TIPO(1)
If clalev([F:WZINVD])<=0   :  Local File ZINVENTD     [F:WZINVD] : Endif
If dim (GFLDCHR(0))>0
BD_TIPO=GFLDCHR(0)
Else
BD_TIPO=[M:ZINV0]FLDCHR(0)
Endif
Raz TXT,PREC
TXT(0)="select avg(AVC_0) Media,min(l.LASRCPDAT_0) FecEnt "
TXT(1)="from STOCK s inner join STOLOTFCY l on s.STOFCY_0=l.STOFCY_0 and s.ITMREF_0=l.ITMREF_0 and s.LOT_0=l.LOT_0 and s.SLO_0=l.SLO_0 "
TXT(2)="where s.STOFCY_0='"+FCY+"' and s.ITMREF_0 ='"+ART+"' and s.LOT_0='"+LOT+"' "
If LOC<>""
TXT(2)+="and LOC_0='"+LOC+"'"
Endif
For (Double WFPRE,Date WFEC) From BD_TIPO Sql TXT As [MYT2]
  PREC=[MYT2]WFPRE
  If WFEC<=[01/08/2017]
    # Sacar datos de inventario anterior, para bobinas que entraron antes del 01-08-17
    Filter [F:WZINVD]
    Filter [F:WZINVD] Where ITMREF=ART and LOT=FLOT and left$(CLAVE,3)=FCY Order By Key ZINV0 Desc
    For [F:WZINVD]
      PREC=[F:WZINVD]PRENUEVO
      Break
    Next
    Filter [F:WZINVD]
  Endif
Next
End PREC


Funprog SQL_WHERE
Local Char W(255)
Raz W
If [M:ZINV0]FARTINI<>""
  W+="and ITMREF_0>='" + [M:ZINV0]FARTINI + "' "
Endif
If [M:ZINV0]FARTFIN<>""
  W+="and ITMREF_0<='" + [M:ZINV0]FARTFIN + "' "
Endif
If [M:ZINV0]FMANFIN>0
  W+="and ZMANDRIL_0=" + num$([M:ZINV0]FMANFIN) + " "
Endif
If [M:ZINV0]FANCINI>0
  W+="and ZANCHO_0>=" + num$([M:ZINV0]FANCINI) + " "
Endif
If [M:ZINV0]FANCFIN>0
  W+="and ZANCHO_0<=" + num$([M:ZINV0]FANCFIN) + " "
Endif
If [M:ZINV0]FLONINI>0
  W+="and ZLONGITUD_0>=" + num$([M:ZINV0]FLONINI) + " "
Endif
If [M:ZINV0]FLONFIN>0
  W+="and ZLONGITUD_0<=" + num$([M:ZINV0]FLONFIN) + " "
Endif
If [M:ZINV0]FLOCINI<>""
  W+="and LOC_0>='" + [M:ZINV0]FLOCINI + "' "
Endif
If [M:ZINV0]FLOCFIN<>""
  W+="and LOC_0<='" + [M:ZINV0]FLOCFIN + "' "
Endif
If [M:ZINV0]FLOT<>""
  If GUSER="PALAU"
  W+="and LOT_0<='"+ [M:ZINV0]FLOT + "' "
  Else
  W+="and LOT_0='" + [M:ZINV0]FLOT + "' "
  Endif
Endif
End W

Funprog ENT_PDTES
Local Char T(255),W(255),TXT(255)(10),BD_TIPO(1)
Raz T,TXT
BD_TIPO=[M:ZINV0]FLDCHR(0)
W=func SQL_WHERE
TXT(0)="select distinct c.SDHNUM_0 "
TXT(1)="from SDELIVERY c inner join SDELIVERYD l on c.SDHNUM_0=l.SDHNUM_0 "
TXT(2)="where c.STOFCY_0='"+[M:ZINV0]FFCY+"' and INVFLG_0=1 and CFMFLG_0=1 "
If W<>""
  TXT(2)+=W
Endif
TXT(3)="order by c.SDHNUM_0"
For (Char WFENT(GLONVCR)) From BD_TIPO Sql TXT As [MYT]
  If T<>""
    T+="\"
  Endif
  T+=WFENT
Next
End T

Subprog VACIAR_REJILLA
Call LIBERAR
# Lineas
Raz [M:ZINV1]NBLIG
Effzo [M:ZINV1]5
Call VACIAR_REJILLA2
End

Subprog VACIAR_REJILLA2
# Valoraciones
Raz [M:ZINV2]NBLIG
Effzo [M:ZINV2]5
End


Subprog MOSTRAR_CALCULOS
Local Char DT(50),TXT(255)(10),BD_TIPO(1)
Local Integer F
BD_TIPO=[M:ZINV0]FLDCHR(0)
Raz [M:ZINV0]NCALC,TXT
Effzo [M:ZINV0]20  # Calculos
TXT(0)="select top " +num$([M:ZINV0]ZMOSTRAR) +" FECHA_0,FCY_0 "
TXT(1)="from ZINVENTARIOS "
If [M:ZINV0]ZPROCES<>2
  TXT(2)="where PROCESADO_0=1 "
Endif
TXT(3)="group by FECHA_0,FCY_0 "
TXT(4)="order by FECHA_0 desc"
For (Datetime WFFEC,Char WFCY(GLONFCY)) From BD_TIPO Sql TXT As [MYT]
  F=[M:ZINV0]NCALC
  DT=format$("D:DD[-]MM[-]YYYY[ ]hh[:]mm[:]ss",WFFEC)
  [M:ZINV0]CFECHA(F)=func ZCOMUN.CHAR_TO_DATE(left$ (DT,10))
  [M:ZINV0]CHORA(F) =right$(DT,12)
  [M:ZINV0]CFCY(F)  =WFCY
  [M:ZINV0]CART(F)  =func MOSTRAR_CALCULOS_ART(DT)
  [M:ZINV0]NCALC+=1
Next
End

Funprog MOSTRAR_CALCULOS_ART(FEC)
Value Char FEC
Local Char T(100),TXT(255)(10),BD_TIPO(1)
BD_TIPO=[M:ZINV0]FLDCHR(0)
Raz T,TXT
TXT(0)="select distinct ITMREF_0 "
TXT(1)="from ZINVENTARIOS "
TXT(2)="where FECHA_0='" + FEC +"' "
TXT(3)="order by ITMREF_0"
#If GUSER="ADMIN"
#Infbox "FEC = "+FEC
For (Char WFART(GLONITM)) From BD_TIPO Sql TXT As [MYT]
  T+=WFART+"#"
Next
#Endif
End T

