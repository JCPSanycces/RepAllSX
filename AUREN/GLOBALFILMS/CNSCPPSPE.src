#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta CPP (Lineas pedidos compra)
$ACTION
Case ACTION
   When "OUVRE"     :   Gosub OUVRE
   When "FILTRE"    :   Gosub FILTRE
   When "AV_AFFICHE"    : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:POQX])= 0 : Local File PORDERQ   [POQX] : Endif
Return

$FILTRE
Raz [M:CPP1]ZTOTBOB
Raz [M:CPP1]ZTOTKG
Raz [M:CPP1]ZTOTM2
Raz [M:CPP1]ZTOTIMPAI
Raz [M:CPP1]ZTOTIMPII
Affzo [M:CPP1]ZTOTBOB
Affzo [M:CPP1]ZTOTKG
Affzo [M:CPP1]ZTOTM2
Affzo [M:CPP1]ZTOTIMPAI
Affzo [M:CPP1]ZTOTIMPII

If [M:CPP1]ZRCPDATDEB<>[0/0/0]
   WFIL2+="&[F:POQ]EXTRCPDAT>=[M:CPP1]ZRCPDATDEB"
Endif
If [M:CPP1]ZRCPDATFIN<>[0/0/0]
   WFIL2+="&[F:POQ]EXTRCPDAT<=[M:CPP1]ZRCPDATFIN"
Endif
If [M:CPP1]ZANCHODEB>0
   WFIL2+="&[F:POQ]ZANCHO>="+num$([M:CPP1]ZANCHODEB)
Endif
If [M:CPP1]ZANCHOEND>0
   WFIL2+="&[F:POQ]ZANCHO<="+num$([M:CPP1]ZANCHOEND)
Endif
If [M:CPP1]ZLONGITUDDEB>0
   WFIL2+="&[F:POQ]ZLONGITUD>="+num$([M:CPP1]ZLONGITUDDEB)
Endif
If [M:CPP1]ZLONGITUDEND>0
   WFIL2+="&[F:POQ]ZLONGITUD<="+num$([M:CPP1]ZLONGITUDEND)
Endif
#If [M:CPP1]ZMANDRIL>0
#   WFIL2+="&[F:POQ]ZMANDRIL="+num$([M:CPP1]ZMANDRIL)
#Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif

For F=0 To [M:CPP2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CPP2]ITMREF(F)
   Raz [F:POQX]
   Read [POQX]POQ0(2)=[M:CPP2]POHNUM(F);[M:CPP2]POPLIN(F)
   If [F:POQX]UOM="M2"
      [M:CPP2]ZQTYKG(F)=arr([F:POQX]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPP2]ZQTYM2(F)=arr([F:POQX]QTYPUU,0.01)
   Endif
   If [F:POQX]UOM="KG"
      [M:CPP2]ZQTYKG(F)=arr([F:POQX]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPP2]ZQTYM2(F)=arr([F:POQX]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPP2]ZQTYM2(F)=0
      Endif
Endif
Next
Return

$CAL_CUMUL
Raz [M:CPP1]ZTOTBOB
Raz [M:CPP1]ZTOTKG
Raz [M:CPP1]ZTOTM2
Raz [M:CPP1]ZTOTIMPAI
Raz [M:CPP1]ZTOTIMPII
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key POQ0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:POQ]ITMREF

   [M:CPP1]ZTOTBOB+=[F:POQ]ZQTYBOB
   If [F:POQ]PUU="M2"
      [M:CPP1]ZTOTKG+=arr([F:POQ]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPP1]ZTOTM2+=arr([F:POQ]QTYPUU,0.01)
   Endif
   If [F:POQ]PUU="KG"
      [M:CPP1]ZTOTKG+=arr([F:POQ]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPP1]ZTOTM2+=arr([F:POQ]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPP1]ZTOTM2+=0
      Endif
   Endif
   [M:CPP1]ZTOTIMPAI+=[F:POQ]LINAMT
   [M:CPP1]ZTOTIMPII+=[F:POQ]LINATI
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CPP1]ZTOTBOB
Affzo [M:CPP1]ZTOTKG
Affzo [M:CPP1]ZTOTM2
Affzo [M:CPP1]ZTOTIMPAI
Affzo [M:CPP1]ZTOTIMPII
Return
