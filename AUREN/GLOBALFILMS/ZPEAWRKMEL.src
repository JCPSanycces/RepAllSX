#<AdxTL>@(#)0.0.0.0 $Revision$
#EMAIL -> PE para cambiar la direccion email "From:" cuando se trata de:
#         1.- Envio fichero OLI
#         2.- Envio tarifas
#         3.- Facturacion electronica
$ACTION
If GUSER="ADMIN"
   #Infbox "ACTION: "+ACTION+" -GACTION:"+GACTION+" -GFONCTION: "+GFONCTION+" -GFONCTION1: "+GFONCTION1
Endif
Case ACTION
  When "EMAIL"    :   Gosub EMAIL
Endcase
Return

$EMAIL
If GFONCTION="GESSOH" and GACTION="ZFIOLIGEN"
   #Envio fichero OLI
   EXP_MAIL='pedidos@globalfilms.es'
Endif
If GACTION="CONSZETC"
   #Envio tarifas
   EXP_MAIL='tarifas@globalfilms.es'
   #Infbox EXP_MAIL
Endif
If GACTION="XX02CONSXM"
   #Facturacion electronica
   EXP_MAIL='administracion1@globalfilms.es'
Endif
#If GFONCTION="GESSOH" and GACTION<>"ZFIOLIGEN"
#   EXP_MAIL='pedidos@globalfilms.es'
#Endif
Return
