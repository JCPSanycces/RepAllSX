#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "INIT"            : Gosub INIT
   When "INIT_DIA"        : Gosub INIT_DIA
When Default
Endcase
Return

$INIT
 If !clalev([F:TXC])   : Local File TEXCLOB   [TXC]  : Endif
Return

#PARAM(1) -> Tipo texto
#            ARCC -> Texto ARC cliente
#PARAM(2) -> Codigo texto
$INIT_DIA
Raz [F:TXC]
Read [TXC]TXC0=PARAM(2)
[M:ZVOBS]CLOB=[F:TXC]TEXTE
Return
