#Asignacion de pedidos de venta con producto de fabricacion lanzada desde seguimiento de fabricacion
#GOK=0 - Rechaza stock
If GFONCTION="GESMTK" and GACTION="TRTAUTALL"
   If !clalev ([F:STJX]) : Local File STOJOU  [STJX]  : Endif
   GOK=0
   Call ECR_TRACE(" PE PECSTOALG ZPESTKALL - ZGQTYBOB: "+num$(ZGQTYBOB)+" ZQTYBOBASI: "+num$([F:ZMSQ]ZQTYBOBASI)+
&                    " DOC: "+[M:ALP]VCRNUM+"-"+num$([M:ALP]VCRLIN)+" LOT: "+[M:ALP]WLOT(J)+"-"+[M:ALP]WSLO(J)+" - "+GFONCTION,0) From GESECRAN
   If ZGQTYBOB<[F:ZMSQ]ZQTYBOBASI
      #Si se ha superado el numero de bobinas del pedido asignandas a la OF se rechaza el stock
      Filter [STJX] Where STOFCY=[M:MTK0]MFGFCY and VCRTYP=15 and VCRNUM=[M:MTK0]MFGTRKNUM and
&                         LOT=[M:ALP]WLOT(J) and SLO=[M:ALP]WSLO(J) and (LOC="GENERAL" or LOC="GENERAL1")
      For [STJX]
         ZGQTYBOB+=1
         GOK=1
         Break
      Next
      Filter [STJX]
   Endif
   Return
Endif

# Especifico de carga de lineas PEDRO
#Asignacion PERSONALIZADA de LOTES previamente cargados en la tabla ZCARITM en la opcion de MULTISELECCION PRODUCTOS.
If GFONCTION="GESSOH" and GACTION="TRTAUTALL"
   If !clalev ([F:ZCAR]) : Local File ZCARITM  [ZCAR] : Endif
   If !clalev ([F:STJX]) : Local File STOJOU   [STJX] : Endif
   Filter [ZCAR] Where CREUSR =GUSER and ITMREF =[M:ALP]ITMREF and LOT=[M:ALP]WLOT(J) #and ZPROVEEDOR=[F:SOQ]ZPROVEEDOR
   GOK=0
   For [ZCAR]
       GOK=1
       Break
   Next
   Filter [ZCAR]
   #Return
Endif

If GFONCTION="GESMFG" or GFONC1="GESMFG" or GFONCTION="GESMTK" or GFONCTION="ZFGOFS"
   Local Decimal WLSUPSOB
   If  !clalev([F:ZMFLX]) : Local File ZMFGLOT [ZMFLX] : Endif
   If  [F:MFM]ZFABCOR = 2 Then  : # Fabricacion por Corte
       Filter [F:ZMFLX] Where 1=1
       Filter [F:ZMFLX] Where MFGNUM=[M:ALP]VCRNUM and STOFCY=[M:ALP]STOFCY and ITMREF=[M:ALP]ITMREF and LOT=[M:ALP]WLOT(J) and SLO=[M:ALP]WSLO(J)
       # Solo se permiten lotes/sublotes pre-asignados a la OF
       GOK=0
       For [F:ZMFLX]
          If [F:ZMFLX]ZLONGSOB<>0 Then
               WLSUPSOB = arr([F:ZMFLX]ZLONGSOB*[F:ZMFLX]ZANCHO/1000*[F:ZMFLX]ZFACTOR,0.0001)
              [M:ALP]WQTYSTUAVA(J)-=WLSUPSOB
              [M:ALP]WQTYACTAVA(J)-=WLSUPSOB
          Endif
          If [M:ALP]WQTYSTUAVA(J)>0 and [M:ALP]TYPQTY=1
              GOK=1
          Endif
          If [M:ALP]WQTYACTAVA(J)>0 and [M:ALP]TYPQTY=2
              GOK=1
          Endif
          Break
       Next
      Filter [F:ZMFLX]
   Endif
   Return
Else
   # Rechazo asignacion si stock pre-asignado a una OF
   If  !clalev([F:ZMFLX]) : Local File ZMFGLOT [ZMFLX] : Endif
   If  !clalev([F:MFGX])  : Local File MFGHEAD [MFGX]  : Endif
   Filter [F:ZMFLX] Where STOFCY=[M:ALP]STOFCY and ITMREF=[M:ALP]ITMREF and LOT=[M:ALP]WLOT(J) and SLO=[M:ALP]WSLO(J)
   For [F:ZMFLX]
       Read [F:MFGX]MFG0=[F:ZMFLX]MFGNUM
       If !fstat and [F:MFGX]MFGSTA<>4
            # Rechazar stock pre-asignado a una OF
            # Existe Lote Pre-asignado y la Orden no está cerrada
         GOK=0
         Break
      Endif
   Next
   Filter [F:ZMFLX]
   If GOK=0 : Return : Endif
Endif

#Si se trata de asignacion automatica lanzada en batch solamente se asignan bobinas que esten en la
#ubicacion "RESER". Se trata del lanzamiento de la asignacion tras el seguimiento de producción.
#If GSERVEUR and GFONCTION="FUNAUTALL"
#   If [M:ALP]WLOC(J)<>"0RESERVA"
#      GOK=0
#      Return
#   Endif
#Endif

#Se ejecuta para tantas lineas de stock se hayan recogido para completar la asignacion de la linea de documento
#Cuando el numero de bobinas asignadas (lote-sublote) es mayor al del pedido se rechaza para no asginar picos.

#Infbox "PECSTOALG: "+GFONC1+" "+GFONCTION+" "+num$([M:ALP]TRSTYP)+" "+num$([M:ALP]VCRTYP)+" "+
#&      num$([M:ALP]QTY)+" "+ num$([M:ALP]WQTYSTUAVA)+" "+num$(ZGNBRBOB)
ZGNBRBOB+=1
If GFONCTION="GESSOH" or GFONC1="GESSOH"
   If [F:ITM]ZFABCOR=2
      #Call ECR_TRACE("STOCOU: "+num$(num$([M:ALP]WSTOCOU(J)))+" WQTYSTU: "+num$([M:ALP]WQTYSTU(J))+" WQTYSTUAVA: "+num$([M:ALP]WQTYSTUAVA(J))+" QTY: "+num$([M:ALP]QTY),0) From GESECRAN
      If ZGNBRBOB>[F:SOQ]ZQTYBOB
         GOK=0
      Endif
      If [M:ALP]QTY<[M:ALP]WQTYSTUAVA(J)
         GOK=0
      Endif
   Endif
Endif
Return

$FILSTO
#Infbox "PE FILSTO: "+GFONC1+" "+GFONCTION+" "+num$([M:ALP]TRSTYP)+" "+num$([M:ALP]VCRTYP)+" LIN: "+num$([F:SOQ]SOPLIN)
#Se ejecuta una vez por linea de documento
Local Integer I
Local Char TXT(255)(3),BD_TIPO(1),FILTRO(255),D(255)
ZGNBRBOB=0
If [M:ALP]VCRTYP=2 : #Pedido
   [M:ALP]FILSTO="[F:STO1]ZANCHO="+num$([F:SOQ]ZANCHO)+" &[F:STO1]ZMANDRIL="+num$([F:SOQ]ZMANDRIL)+" &[F:STO1]ZLONGITUD="+num$([F:SOQ]ZLONGITUD)+""
Endif
If [M:ALP]VCRTYP=4 : #Entrega
   If GFONC1="GESSOH"
      [M:ALP]FILSTO="[F:STO1]ZANCHO="+num$([F:SOQ]ZANCHO)+""
      If [F:SOQ]ZPROVEEDOR<>""
         WCRITLOT+='&[F:STO1]ZPROVEEDOR="'+[F:SOQ]ZPROVEEDOR+'"'
      Endif
   Endif
Endif
#Infbox "FJCP" - GFONC1 - num$([F:MFM]ZANCHO)
#Infbox "Depurar"
If [M:ALP]VCRTYP=10 : #OF
#JLPR 04.11    INI
#   If GFONC1="GESMFG"
#      [M:ALP]FILSTO="[F:STO1]ZANCHO>="+num$([M:MFG1]ZMINANCHO)+""
      #Ańado filtros para que solo coja los lotes indicados  <<<< 01-12-16   Se comenta, pues el STOCOU puede cambiar y se pierde enlace entre ZMFGLOT y STOCK
#      TXT(0)="select distinct STOCOU_0 "
#      TXT(1)="from ZMFGLOT "
#      TXT(2)="where MFGNUM_0='"+[M:ALP]VCRNUM+"'"
      BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
#      Raz FILTRO
#      For (Decimal FSTOCOU)From BD_TIPO Sql TXT As [MYT]
#        Raz D
#        If FILTRO<>"" :  D="|"   :   Endif
#        D+="[F:STO1]STOCOU="+num$(FSTOCOU)
#        #If len(FILTRO+D)>100
#        #  Infbox "longitud filtro supera los 100 caracteres de [M:ALP]FILSTO....Se quedaran lotes sin incluir...(ZPESTKALL.src / $FILSTO)"
#        #  Break
#        #Endif
#        FILTRO+=D
#      Next
#      If len(FILTRO)<=100
#        [M:ALP]FILSTO=FILTRO
#      Else
        TXT(0)="select min(ZANCHO_0), max(ZANCHO_0) "
        TXT(1)="from ZMFGLOT "
        TXT(2)="where MFGNUM_0='"+[M:ALP]VCRNUM+"'"
        Raz FILTRO
        For (Decimal FMIN,Decimal FMAX)From BD_TIPO Sql TXT As [MYT]
          FILTRO="[F:STO1]ZANCHO>="+num$(FMIN) + " & [F:STO1]ZANCHO<="+num$(FMAX)
        Next
        [M:ALP]FILSTO=FILTRO
#      Endif
#   Endif
#JLPR 04.11    FIN
Endif
Return



#PE para cambiar la ordenacion de la las lineas de stock cargadas en la mascara
#de stocks asignados [ALP].
$RECHALL
Local Integer WLI,WLJ,WLK,WPOS, WLBOB, ESTASTOCOU, BOBSOB(0..500)

If [M:ALP]VCRTYP<>10 and [M:ALP]VCRTYP<>12
   Return
Endif
#Buscamos si se ha determiando una bobina sobrante y nos quedamos con su STOCOU
If clalev([ZMFLX])<=0 : Local File ZMFGLOT [ZMFLX] : Endif
Raz BOBSOB
Filter [ZMFLX] Where MFGNUM=[M:ALP]VCRNUM and  ZSOBRANTE=2
WLBOB=0
For [ZMFLX]
   For WLK=0 To WLBOB-1
      ESTASTOCOU=1
      If BOBSOB(WLK)=[F:ZMFLX]STOCOU
         ESTASTOCOU=2
         Break
      Endif
   Next
   If ESTASTOCOU=1
      BOBSOB(WLBOB)=[F:ZMFLX]STOCOU
      WLBOB+=1
   Endif
Next
WLBOB-=1
Filter [ZMFLX]

If WLBOB>=0
   #Hay bobinaS sobranteS, entonces se reordena el grid de asignaciones
   For WLK=0 To WLBOB
      WLJ=-1
      For WLI=0 To [M:ALP]NBLIG-1
         If [M:ALP]WSTOCOU(WLI)=BOBSOB(WLK)
            WLJ=WLI
            Break
         Endif
      Next
      If WLJ<>-1
         #A la posicion encontrada se le asigna la ulitma posicion y
         #a la ultima posicion se le asigna la posicion encontrada,
         #es decir, invertimos las posioiones, de forma que la bobina
         #sobrante este en la ultima posicion
         WPOS=[M:ALP]NBLIG-1-WLK
         If WPOS>0 and WPOS>WLJ
            [M:ALP]NLIG(WLJ)=WPOS
            [M:ALP]NLIG(WPOS)=WLJ
         Endif
      Endif
   Next
Endif
#Codigo que se utilizaba cuando solo se consideraba una unica bobina sobrante
#If WLBOB>=0
#   WLJ=-1
#   #Hay bobina sobrante, entonces se reordena el grid de asignaciones
#   For WLI=0 To [M:ALP]NBLIG-1
#      If [M:ALP]WSTOCOU(WLI)=BOBSOB
#         WLJ=WLI
#         Break
#      Endif
#   Next
#   If WLJ<>-1
#      #A la posicion encontrada se le asigna la ulitma posicion y
#      #a la ultima posicion se le asigna la posicion encontrada,
#      #es decir, invertimos las posioiones, de forma que la bobina
#      #sobrante este en la ultima posicion
#      [M:ALP]NLIG(WLJ)=[M:ALP]NBLIG-1
#      [M:ALP]NLIG([M:ALP]NBLIG-1)=WLJ
#   Endif
#Endif
Return
