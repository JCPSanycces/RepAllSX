#<AdxTL>@(#)0.0.0.0 $Revision$
#Tramiento especifico consulta cabecera pedidos compras
$ACTION
Case ACTION
  When "AV_AFFICHE"    : Gosub AV_AFFICHE
  When Default
Endcase
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$CAL_CUMUL
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
Raz [M:CPO1]ZTOTKG
Raz [M:CPO1]ZTOTM2
Raz [M:CPO1]ZTOTIMPAI
Raz [M:CPO1]ZTOTIMPII
Filter [POH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key POH0
For [POH]
   [M:CPO1]ZTOTIMPAI+=[F:POH]TOTORD
   [M:CPO1]ZTOTIMPII+=[F:POH]TTVORD
   Filter [POQ] Where POHNUM=[F:POH]POHNUM
   For [POQ]
      Raz [F:ITM]
      Read [ITM]ITM0=[F:POQ]ITMREF
      If [F:POQ]UOM="M2"
         [M:CPO1]ZTOTKG+=arr([F:POQ]QTYPUU*[F:ITM]ZFACTOR,0.01)
         [M:CPO1]ZTOTM2+=arr([F:POQ]QTYPUU,0.01)
      Endif
      If [F:POQ]UOM="KG"
         [M:CPO1]ZTOTKG+=arr([F:POQ]QTYPUU,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CPO1]ZTOTM2+=arr([F:POQ]QTYPUU/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CPO1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [POQ]
Next
Filter [POH]
Return

$AFF_CUMUL
Affzo [M:CPO1]ZTOTKG
Affzo [M:CPO1]ZTOTM2
Affzo [M:CPO1]ZTOTIMPAI
Affzo [M:CPO1]ZTOTIMPII
Return
