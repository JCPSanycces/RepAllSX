#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "INICRE_LIG"  :  Gosub INICM_LIG
   When "INIMOD_LIG"  :  Gosub INICM_LIG
Endcase
Case ACTION
 When "AB2_NBLIG"    : Gosub AB2_NBLIG
 When "BB2_NBLIG"    : Gosub BB2_NBLIG
Endcase
Return

$INICM_LIG
Local Integer NOL
NOL=nolign-1

#Infbox "INICM: "+[M:PPLW]ZPPLTEX(NOL)
[F:PPL]ZPPLTEX = [M:PPLW]ZPPLTEX(NOL)
Return

$AB2_NBLIG
Local Integer NOL
Global Char SAV_ZPPLTEX(25)
NOL=nolign-1

Raz SAV_ZPPLTEX
SAV_ZPPLTEX=[M:PPLW]ZPPLTEX(NOL)

Return

$BB2_NBLIG
Local Integer NOL
NOL=nolign-1

If [M:PPLW]ZPPLTEX(NOL)<>""
   If left$([M:PPLW]ZPPLTEX(NOL),3)="PPL"
      Call CRE_CLOB([M:PPLW]ZPPLTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
Endif
If SAV_ZPPLTEX<>"" and [M:PPLW]ZPPLTEX(NOL)=""
   Call SUP_CLOB(SAV_ZPPLTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
Endif
Affzo [M:PPLW]ZPPLTEX(NOL)
Return
