#<AdxTL>@(#)0.0.0.0 $Revision$
#ENTW_ENT -> PE de TRTSTOENTA
$ACTION
#If GUSER="ADMIN"
#Infbox ACTION+"/"+"ZPETRTSTOENTA"+ [M:MTK2]ZLPNNUM
#Endif
Case ACTION
   When "ENTW_ENT"     :   Gosub ENTW_ENT
   When "ENT_ENTW"     :   Gosub ENT_ENTW
   When "CHG_STOENT"   :   Gosub CHG_STOENT
Endcase
Return

$ENTW_ENT
#Infbox "ENTW_ENT (ZPETRTSOTENT)"
 [M:ENT]ZANCHO(LLIG) = [M:ENTW]ZANCHO(I)
 [M:ENT]ZMANDRIL(LLIG) = [M:ENTW]ZMANDRIL(I)
 [M:ENT]ZLONGITUD(LLIG) = [M:ENTW]ZLONGITUD(I)
 If LTYP=13
    #Devolucion cliente
    [M:ENT]ZLONGITUD(LLIG) = [M:SRH1]ZLONGITUD(LLIGDOC)
 Endif
 [M:ENT]ZPROVEEDOR(LLIG) = [M:ENTW]ZPROVEEDOR(I)
 [M:ENT]ZFACTOR(LLIG) = [M:ENTW]ZFACTOR(I)
 [M:ENT]ZNCORTES(LLIG) = [M:ENTW]ZNCORTES(I)
 [M:ENT]ZMFGDATE(LLIG) = [M:ENTW]ZMFGDATE(I) #Z0001
 [M:ENT]ZEMPALME(LLIG) = [M:ENTW]ZEMPALME(I) #Z0001
 If LABR="MTK2"
 #Z0001.ini
  [M:ENT]LPNNUM(LLIG) = [M:MTK2]LPNNUM(nolign-1)
  [M:ENT]TCTRNUM(LLIG) = [M:MTK2]TCTRNUM(nolign-1)
  [M:ENT]ZMFGDATE(LLIG) = [M:MTK2]ZMFGDATE(nolign-1)
  [M:ENT]ZEMPALME(LLIG) = [M:MTK2]ZEMPALME(nolign-1)
 #Z0001.fin
 Endif
Return

$ENT_ENTW
#Infbox "ENT_ENTW (ZPETRTSOTENT)"
 [M:ENTW]ZANCHO(LLIG) = [M:ENT]ZANCHO(I)
 [M:ENTW]ZMANDRIL(LLIG) = [M:ENT]ZMANDRIL(I)
 [M:ENTW]ZLONGITUD(LLIG) = [M:ENT]ZLONGITUD(I)
 [M:ENTW]ZPROVEEDOR(LLIG) = [M:ENT]ZPROVEEDOR(I)
 [M:ENTW]ZFACTOR(LLIG) = [M:ENT]ZFACTOR(I)
 [M:ENTW]ZNCORTES(LLIG) = [M:ENT]ZNCORTES(I)
 [M:ENTW]ZMFGDATE(LLIG) = [M:ENT]ZMFGDATE(I) #Z0001
 [M:ENTW]ZEMPALME(LLIG) = [M:ENT]ZEMPALME(I) #Z0001

Return

$CHG_STOENT
If LABR="SRH1"
Endif
Return
