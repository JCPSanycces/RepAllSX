############################################################################
# Script name : SPEZPICKVP
# Description : Picking Salida VP
# Module      : Ventas
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espa˝a
# Created date: 27/07/2022
############################################################################
# Z0001-1 - JC.21072022.Trazabilidad
##############################################################################################

################################################################
$ACTION
#Infbox ACTION
  Case ACTION
   When "OUVRE"             : Gosub OUVRE
   When "SETBOUT"           : Gosub SETBOUT
   When "BOUTON"            : Gosub BOUTON
   When "AVANT_BOUTON"      : Gosub AVANT_BOUTON
   When "FIN"    : Gosub FIN
   When Default
  Endcase
Return

######################################################################################
$OUVRE
######################################################################################
If !clalev([F:PRH])    : Local File STOPREH    [PRH]  : Endif
If !clalev([F:ZPRE])    : Local File STOPRED    [ZPRE]  : Endif
If !clalev([F:ZPRE2])    : Local File STOPRED    [ZPRE2]  : Endif
If !clalev([F:ZSOQ])    : Local File SORDERQ    [ZSOQ]  : Endif
If !clalev([F:ZSTA])    : Local File STOALL    [ZSTA]  : Endif
If !clalev([F:ZSTO])    : Local File STOCK    [ZSTO]  : Endif
If !clalev([F:ZPICKVP])    : Local File ZPICKVP    [ZPICKVP]  : Endif
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif
If !clalev([F:ZLPNCMP]) Local File ZLPNCMP [ZLPNCMP] Endif
Global Integer TMPBUL : Raz TMPBUL
Global Char TMPPCK(5) : Raz TMPPCK
Global Char TMPPED(20) : Raz TMPPED
Return

######################################################################################
$SETBOUT
######################################################################################

  Raz CHMEN
  CHMEN += "1"

  If !clalev([F:PRH1]) Then : Local File STOPREH  [F:PRH1]  : Endif
  Read [F:PRH1]PRH0 = [M:ZPICKVP]PRHNUM
  If !fstat Then
    If [F:PRH1]ZPREPSTA = 3 and [M:ZPICKVP]PRHNUM <> '' Then
      # botˇn EMPAQUETADO
      CHMEN += "2"
    Elsif [F:PRH1]DLVFLG = 2 and [F:PRH1]ZPREPSTA = 4 and [M:ZPICKVP]PRHNUM <> '' Then
      # botˇn ENTREGA
      CHMEN += "3"
    Endif
  Endif

Return

######################################################################################
$BOUTON
######################################################################################
Local Integer YESNO
Case BOUT
  When "1"
    Gosub CIERRE_VP
  When "2"
    YESNO = 2
    Call OUINON("Se procederß al empaquetado del documento de preparaciˇn. ┐Continuar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      GBIDC2="G": Gosub AUTORIS_OPT From CONTX3
      Gosub PCK_PRH
    Endif
  When "3" :
    YESNO = 2
    Call OUINON("Se procederß a generar la entraga del documento de preparaciˇn. ┐Continuar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      Gosub GEN_SDH
    Endif
  When Default
Endcase
Unlock ="PRH"+[M:ZPICKVP]PRHNUM
Raz [M:ZPICKVP]
Affzo [M:ZPICKVP]
Return

######################################################################################
$FIN
######################################################################################
Unlock ="PRH"+[M:ZPICKVP]PRHNUM
Unlock = TMPPED
Return

######################################################################################
$AVANT_BOUTON
# Z0001-1.ini
  If (GREP="M" & !ACTMOD) GCONSDIA=2 Endif

#  Case BOUT
#    When Default
#  Endcase
# Z0001-1.fin

Return

######################################################################################
$CIERRE_VP
######################################################################################
Local Integer FVP,FVPE : Raz FVP,FVPE
Filter [F:ZSTA]
For IK=0 To  [M:ZPICKVP]NBLIG-1
  If [M:ZPICKVP]ZPICKED(IK)<>2 :FVP=1 Endif
  If [M:ZPICKVP]PCK(IK)="" or [M:ZPICKVP]ZNROBULT(IK) = 0 :FVPE=1 Endif
  Read [F:ZSTA]STA0=[M:ZPICKVP]STOFCY(IK);[M:ZPICKVP]ITMREF(IK);[M:ZPICKVP]STOCOU(IK);[M:ZPICKVP]SEQ(IK)
  If !fstat
    [F:ZSTA]ZPICKED=[M:ZPICKVP]ZPICKED(IK)
    [F:ZSTA]ZNROBULT=[M:ZPICKVP]ZNROBULT(IK)
    [F:ZSTA]ZPCK=[M:ZPICKVP]PCK(IK)
    Rewrite [F:ZSTA]
    If fstat
      Call FSTA('STOALL') From GLOCK
    Endif
  Endif
Next
Read [F:PRH]PRH0 = [M:ZPICKVP]PRHNUM
If !fstat
  If FVPE=0
    [F:PRH]ZPREPSTA = 3
  Else
    [F:PRH]ZPREPSTA = 2
  Endif
  If FVP=0
    [F:PRH]DLVFLG=2
    Filter [F:ZPRE] Where [F:ZPRE]PRHNUM = [M:ZPICKVP]PRHNUM
    For [F:ZPRE]
      Read [F:ZSOQ]SOQ0=[F:ZPRE]ORINUM;[F:ZPRE]ORILIN;[F:ZPRE]ORISEQ
      If !fstat
        [F:ZSOQ]PREQTY=[F:ZSOQ]OPRQTY
        [F:ZSOQ]PREQTYSTU=[F:ZSOQ]OPRQTYSTU
        [F:ZSOQ]OPRQTY=0
        [F:ZSOQ]OPRQTYSTU=0
        Rewrite [F:ZSOQ]
        If fstat
          Call FSTA('SORDERQ') From GLOCK
        Endif
      Endif
    Next
    Filter [F:ZPRE]
    Infbox "Picking finalizado"
  Else
    [F:PRH]DLVFLG=1
    Infbox "Picking aun en curso"
  Endif
  Rewrite [F:PRH]
  If fstat
   Call FSTA(' STOPREH') From GLOCK
  Endif
Endif
Unlock ="PRH"+[M:ZPICKVP]PRHNUM
Unlock = TMPPED
Return


######################################################################################
## Etiqueta a˝adida por el supervisor (pantalla ZPICKVP) 28/07/2022 03:15:36 (ADMIN)
######################################################################################
Subprog C_PRHNUM(VALEUR)
Variable Char    VALEUR()
# JC.08082022.Si estßn estos controles no se puede generar la entrega desde la pantalla
Read [F:PRH]PRH0 = VALEUR
If !fstat
#  If [F:PRH]DLVFLG >= 2 and [F:PRH]ZPREPSTA>3
#    Errbox "Estado de Vale incorrecto"
#    mkstat = 2
#    End
#  Endif

Else
  Errbox "Valor incorrecto"
  mkstat=2
Endif
End

Subprog AM_PRHNUM(VALEUR)
Variable Char    VALEUR()
Effzo [M:ZPICKVP]15
Unlock ="PRH"+[M:ZPICKVP]PRHNUM
Lock = "PRH"+VALEUR
If fstat <> 0
  Errbox "Vale en uso"
  mkstat=2
  End
Endif
Read [F:PRH]PRH0=VALEUR
If !fstat
  Filter [F:ZPRE] Where [F:ZPRE]PRHNUM=VALEUR
  Read [F:ZPRE] First
  If !fstat
    TMPPED = "SOH"+[F:ZPRE]ORINUM
    Lock = TMPPED
    If fstat
      Filter [F:ZPRE]
      Errbox "Pedido "+[F:ZPRE]ORINUM+" en uso"
      mkstat=2
      End
    Endif
  Endif
  Filter [F:ZPRE]
Endif
Read [F:TXC]TXC0=[F:PRH]PRPTEX1
If !fstat
  [M:ZPICKVP]ZTXTPREP=func ZTRTTDOC.F_RTF2TEXT([F:TXC]TEXTE)
  Affzo [M:ZPICKVP]ZTXTPREP
Endif
Link [F:ZSTA] With [F:ZSTO]STO0~=[F:ZSTA]STOFCY;[F:ZSTA]STOCOU As [LNKPICK] Order By VCRNUM;VCRLIN Asc
Filter [F:ZSTA] Where [F:ZSTA]VCRNUM=VALEUR
For [LNKPICK]
  I=[M:ZPICKVP]NBLIG
  [M:ZPICKVP]VCRLIN(I)=[F:ZSTA]VCRLIN
  [M:ZPICKVP]ITMREF(I)=[F:ZSTA]ITMREF
  [M:ZPICKVP]LOC(I)=[F:ZSTO]LOC
  [M:ZPICKVP]LOT(I)=[F:ZSTO]LOT
  [M:ZPICKVP]LPNNUM(I)=[F:ZSTO]LPNNUM
  [M:ZPICKVP]PCK(I)=[F:ZSTA]ZPCK
  [M:ZPICKVP]SLO(I)=[F:ZSTO]SLO
  [M:ZPICKVP]ZNROBULT(I)=[F:ZSTA]ZNROBULT
  [M:ZPICKVP]ZPICKED(I)=[F:ZSTA]ZPICKED
  [M:ZPICKVP]STOFCY(I)=[F:ZSTA]STOFCY
  [M:ZPICKVP]STOCOU(I)=[F:ZSTA]STOCOU
  [M:ZPICKVP]ZSTOCOU(I)=[F:ZSTA]STOCOU
  [M:ZPICKVP]SEQ(I)=[F:ZSTA]SEQ
  If val([F:ZSTO]SLO)=1
    [M:ZPICKVP]LOTSLO(I)=[F:ZSTO]LOT
  Else
    [M:ZPICKVP]LOTSLO(I)=[F:ZSTO]LOT+[F:ZSTO]SLO
  Endif
  Read [F:ZLPNCMP]ZLPN0 = [F:ZSTA]VCRNUM;[F:ZSTO]LPNNUM
  If !fstat
    [M:ZPICKVP]ZPICKPALL(I) = [F:ZLPNCMP]FLPN
  Endif
  [M:ZPICKVP]NBLIG+=1
Next
Filter [F:ZSTA]
Affzo [M:ZPICKVP]15
End

Subprog S_PRHNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
#Filter [F:PRH] Where [F:PRH]DLVFLG < 2 and [F:PRH]ZPREPSTA<3 #Esto dice la definicion pero creo que no es correcto
Filter [F:PRH] Where [F:PRH]DLVFLG < 3
PARMSK(1) = "PRH"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [F:PRH]
[M:ZPICKVP]PRHNUM=VALEUR
Affzo [M:ZPICKVP]PRHNUM
End

Subprog C_ZBOBPALL(VALEUR)
Variable Char VALEUR
End

Subprog AM_ZBOBPALL(VALEUR)
Variable Char VALEUR
Local Integer IX : Raz IX

IX=instr(1,VALEUR,"-GF")
If IX>0
  Local Char LOTPROD(35) :Raz LOTPROD
  Local Integer TX,TS : Raz TX,TS

  LOTPROD=left$(VALEUR,IX-1)+right$(VALEUR,IX+3)
  If LOTPROD <> ""
    IX = find (LOTPROD,[M:ZPICKVP]LOTSLO(0..([M:ZPICKVP]NBLIG-1)))
    If IX>0
      [M:ZPICKVP]ZPICKED(IX-1)=2
      If TMPBUL<>0 : [M:ZPICKVP]ZNROBULT(IX-1)=TMPBUL: Affzo [M:ZPICKVP]ZNROBULT(IX-1) Endif
      If TMPPCK <> "" : [M:ZPICKVP]PCK(IX-1)=TMPPCK : Affzo [M:ZPICKVP]PCK(IX-1) Endif
      Affzo [M:ZPICKVP]ZPICKED(IX-1)
    Endif
  Else
    Errbox "El lote " +left$(VALEUR,I-1)+"/"+right$(VALEUR,I+3)+" no se encuentra en este Vale"
  Endif
Else
  IX =find (VALEUR,[M:ZPICKVP]LOTSLO(0..([M:ZPICKVP]NBLIG-1)))
  If IX>0
    [M:ZPICKVP]ZPICKED(IX-1)=2
    If TMPBUL<>0 : [M:ZPICKVP]ZNROBULT(IX-1)=TMPBUL: Affzo [M:ZPICKVP]ZNROBULT(IX-1) Endif
    If TMPPCK <> "" : [M:ZPICKVP]PCK(IX-1)=TMPPCK : Affzo [M:ZPICKVP]PCK(IX-1) Endif
    Affzo [M:ZPICKVP]ZPICKED(IX-1)
  Else
    IJ =find (VALEUR,[M:ZPICKVP]LPNNUM(0..([M:ZPICKVP]NBLIG-1)))
    If IJ>0 and [M:ZPICKVP]ZPICKPALL(IJ-1)=2
      For I=0 To [M:ZPICKVP]NBLIG-1
        If [M:ZPICKVP]LPNNUM(I)=VALEUR
          [M:ZPICKVP]ZPICKED(I)=2
          If TMPBUL<>0 : [M:ZPICKVP]ZNROBULT(I)=TMPBUL: Affzo [M:ZPICKVP]ZNROBULT(I) Endif
          If TMPPCK <> "" : [M:ZPICKVP]PCK(I)=TMPPCK : Affzo [M:ZPICKVP]PCK(I) Endif
          Affzo [M:ZPICKVP]ZPICKED(I)
        Endif
      Next
    Else
      Errbox "El lote/Contenedor "+VALEUR+" no existe en este vale"
    Endif
  Endif
Endif
If VALEUR<>[M:ZPICKVP]ZBOBPALL
  VALEUR = ""
  zonsui = "[M:ZPICKVP]ZBOBPALL"
Endif
End


######################################################################
$PCK_PRH
# Z0001-1.ini
Local   Char    VALBOUT(250) , PARBOUT(250)(1..20)
Global  Char    GZPCK(25)
Global  Decimal GZSTOCOU(1..)
Local   Integer LCONT : LCONT = 1

  PARBOUT(1) = "3"
  PARBOUT(2) = "DEC"
  FLGEXE     = 1
  If !clalev([F:ACT1]) Then   : Local File ACTION       [F:ACT1]  : Endif
  If !clalev([F:ZVPS0]) Then  : Local File ZVPTHSTOALL  [F:ZVPS0] : Endif
  If !clalev([F:ZPRH0]) Then  : Local File STOPREH      [F:ZPRH0] : Endif

  # VP entregable
  Read [F:ZPRH0]PRH0 = [M:ZPICKVP]PRHNUM
  If !fstat Then
    [F:ZPRH0]DLVFLG = 2
    Trbegin [F:ZPRH0]
    Rewrite [F:ZPRH0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Else
    Call ERREUR("No existe el documento de preparaciˇn") From GESECRAN
    Return
  Endif

  Filter [F:ZVPS0] Where VCRNUM = [M:ZPICKVP]PRHNUM
  For [ZVPS0]
    Link [F:ZSTA] With [F:ZSTO]STO0~=[F:ZSTA]STOFCY;[F:ZSTA]STOCOU As [LNKPICK]
&     Where
&       [F:ZSTA]VCRNUM    = [F:ZVPS0]VCRNUM     and
&       [F:ZSTA]ZNROBULT  = [F:ZVPS0]ZNROBULT   and
&       [F:ZSTA]ZPCK      = [F:ZVPS0]ZPCK
&     Order By VCRNUM;VCRLIN Asc
    Raz GZSTOCOU
    LCONT = 1
    For [F:LNKPICK]
      GZSTOCOU(LCONT) = [F:ZSTA]STOCOU
      LCONT += 1
    Next
    # empaquetado declarativo
    GACTION   = "ZPICKVP"
    GZPCK     = [F:ZVPS0]ZPCK
    Read [F:ACT1]ACTION=GACTION
    If fstat
      Raz [F:ACT1]
    Endif
    Call SAISIE_CHAR(VALBOUT,PARBOUT,"FPKD","FUNPKD",[F:ACT1]SPETRT) From GSAISIE
  Next
  Filter [F:ZVPS0]

#  If !clalev([F:STA2]) Then  : Local File STOALL [F:STA2] : Endif
#  Local Integer LC : LC=1
#  Raz GZSTOCOU
#  Filter [F:STA2] Where VCRNUM = [M:ZPICKVP]PRHNUM and ZNROBULT = [M:ZPICKVP]ZNROBULT(0) and ZPCK = [M:ZPICKVP]PCK(0)
#  For [STA2]
#    GZSTOCOU(LC) = [F:STA2]STOCOU
#    LC += 1
#  Next
#  # empaquetado declarativo
#  GACTION   = "ZPICKVP"
#  GZPCK     = [F:STA2]ZPCK
#  Read [F:ACT1]ACTION=GACTION
#  If fstat
#    Raz [F:ACT1]
#  Endif
#  Call SAISIE_CHAR(VALBOUT,PARBOUT,"FPKD","FUNPKD",[F:ACT1]SPETRT) From GSAISIE

  # sin error
  If FOK <> 0 Then
    Read [F:ZPRH0]PRH0 = [M:ZPICKVP]PRHNUM
    If !fstat Then
      [F:ZPRH0]ZPREPSTA = 4
      Trbegin [F:ZPRH0]
      Rewrite [F:ZPRH0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Call MESSAGE("Documento procesado") From GESECRAN
  Endif

  If dim(VALBOUT)   > 0   Then : Kill VALBOUT   : Endif
  If dim(PARBOUT)   > 0   Then : Kill PARBOUT   : Endif
  If dim(GZPCK)     > 0   Then : Kill GZPCK     : Endif
  If dim(GZSTOCOU)  > 0   Then : Kill GZSTOCOU  : Endif
  If dim(LCONT)     > 0   Then : Kill LCONT     : Endif

# Z0001-1.fin
Return

######################################################################
# Z0001-1.ini
$GEN_SDH
Local Integer FORI :Raz FORI
Filter [F:ZPRE2] Where [F:ZPRE2]PRHNUM=[M:ZPICKVP]PRHNUM
Read [F:ZPRE2] First
If !fstat
  Lock = "SOH"+[F:ZPRE2]ORINUM
  If fstat <> 0
    Errbox "Pedido "+[F:ZPRE2]ORINUM+" en uso, no se puede generar la entrega"
    FORI=1
  Else
    Unlock = "SOH"+[F:ZPRE2]ORINUM
  Endif
Else
  Errbox "No se pudo leer las lÝneas del vale"
  FORI=1
Endif
Filter [F:ZPRE2]
If FORI = 1 :Return Endif

Gosub CRE_SDH From ZPRHCRESDH
Return

