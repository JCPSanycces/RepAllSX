######################################################################################
## Etiqueta a˝adida por el supervisor (pantalla ZPICKVP) 31/08/2022 08:10:11 (ADMIN)
######################################################################################
Subprog AM_ZNROBULT(VALEUR)
Variable Decimal VALEUR
#If nolign-1 >0
