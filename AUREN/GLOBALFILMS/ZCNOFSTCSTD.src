#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZCNOFSTC1
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return

$AUTORIS
Global Integer INICIO

INICIO=1

Return

$FERME
Return

$OUVRE
[M:ZCNOFST1]DESDEFECHA=date$
[M:ZCNOFST1]HASTAFECHA=date$

Return

$DEB_CRIT
Return

$LECTURE
If INICIO=0 Then
    Gosub CARGAR
Endif

Return

$SETBOUT
INICIO=0

Return

$EXEBOUT
Return

$AP_MAGNETO
Return

$CLECUR
Return


$CARGAR
Local Char REQUEST(255)(9)
Local Char FILTRO(255)(5)
Local Integer FILAS

Raz [M:ZCNOFST2]

nolign=0

##############################################################################
# MONTAMOS LOS FILTROS
##############################################################################
If [M:ZCNOFST1]ITMREF<>"" and [M:ZCNOFST1]FCY<>"" and [M:ZCNOFST1]ITMREFEND<>"" Then
    FILTRO(0) = " WHERE (MFGITM.ITMREF_0 >='"+[M:ZCNOFST1]ITMREF+"' AND MFGITM.ITMREF_0 <='"+[M:ZCNOFST1]ITMREFEND+"') AND MFGITM.PLNFCY_0='"+[M:ZCNOFST1]FCY+"' "
Elsif [M:ZCNOFST1]ITMREF<>"" and [M:ZCNOFST1]ITMREFEND<>"" and [M:ZCNOFST1]FCY="" Then
    FILTRO(0) = " WHERE (MFGITM.ITMREF_0 >='"+[M:ZCNOFST1]ITMREF+"' AND MFGITM.ITMREF_0<='"+[M:ZCNOFST1]ITMREFEND+"') "
Elsif [M:ZCNOFST1]ITMREF="" and [M:ZCNOFST1]ITMREFEND="" and [M:ZCNOFST1]FCY<>"" Then
    FILTRO(0) = " WHERE MFGITM.PLNFCY_0 ='"+[M:ZCNOFST1]FCY+"' "
Elsif [M:ZCNOFST1]ITMREF="" and [M:ZCNOFST1]ITMREFEND="" and [M:ZCNOFST1]FCY="" Then
    FILTRO(0) = " WHERE MFGITM.ITMREF_0 <>'' AND MFGITM.PLNFCY_0<>'' "
Elsif [M:ZCNOFST1]ITMREF<>"" and [M:ZCNOFST1]ITMREFEND="" and [M:ZCNOFST1]FCY="" Then
    FILTRO(0) = " WHERE MFGITM.ITMREF_0 >='"+[M:ZCNOFST1]ITMREF+"' AND MFGITM.PLNFCY_0<>'' "
Elsif [M:ZCNOFST1]ITMREF="" and [M:ZCNOFST1]ITMREFEND<>"" and [M:ZCNOFST1]FCY="" Then
    FILTRO(0) = " WHERE MFGITM.ITMREF_0 <='"+[M:ZCNOFST1]ITMREFEND+"' AND MFGITM.PLNFCY_0<>'' "
Elsif [M:ZCNOFST1]ITMREF<>"" and [M:ZCNOFST1]ITMREFEND="" and [M:ZCNOFST1]FCY<>"" Then
    FILTRO(0) = " WHERE MFGITM.ITMREF_0 >='"+[M:ZCNOFST1]ITMREF+"' AND MFGITM.PLNFCY_0<>'"+[M:ZCNOFST1]FCY+"'"
Elsif [M:ZCNOFST1]ITMREF="" and [M:ZCNOFST1]ITMREFEND<>"" and [M:ZCNOFST1]FCY<>"" Then
    FILTRO(0) = " WHERE MFGITM.ITMREF_0 <='"+[M:ZCNOFST1]ITMREFEND+"' AND MFGITM.PLNFCY_0<>'"+[M:ZCNOFST1]FCY+"'"
Endif

If ([M:ZCNOFST1]ANCHODEB<>0) and ([M:ZCNOFST1]ANCHOEND<>0) Then
    FILTRO(1)=" AND (MFGITM.ZANCHO_0>="+num$([M:ZCNOFST1]ANCHODEB)+" AND MFGITM.ZANCHO_0<="+num$([M:ZCNOFST1]ANCHOEND)+")"
Elsif ([M:ZCNOFST1]ANCHODEB<>0) and ([M:ZCNOFST1]ANCHOEND=0) Then
    FILTRO(1)=" AND MFGITM.ZANCHO_0>="+num$([M:ZCNOFST1]ANCHODEB)
Elsif ([M:ZCNOFST1]ANCHODEB=0) and ([M:ZCNOFST1]ANCHOEND<>0) Then
    FILTRO(1)=" AND MFGITM.ZANCHO_0<="+num$([M:ZCNOFST1]ANCHOEND)
Endif
If ([M:ZCNOFST1]LONGITUDDEB<>0) and ([M:ZCNOFST1]LONGITUDEND<>0) Then
    FILTRO(2)=" AND (MFGITM.ZLONGITUD_0>="+num$([M:ZCNOFST1]LONGITUDDEB)+" AND MFGITM.ZLONGITUD_0<="+num$([M:ZCNOFST1]LONGITUDEND)+")"
Elsif ([M:ZCNOFST1]LONGITUDDEB<>0) and ([M:ZCNOFST1]LONGITUDEND=0) Then
    FILTRO(2)=" AND MFGITM.ZLONGITUD_0>="+num$([M:ZCNOFST1]LONGITUDDEB)
Elsif ([M:ZCNOFST1]LONGITUDDEB=0) and ([M:ZCNOFST1]LONGITUDEND<>0) Then
    FILTRO(2)=" AND MFGITM.ZLONGITUD_0<="+num$([M:ZCNOFST1]LONGITUDEND)
Endif
If ([M:ZCNOFST1]MANDRIL<>0) Then
    FILTRO(2)=" AND MFGITM.ZMANDRIL_0>="+num$([M:ZCNOFST1]MANDRIL)
Endif
FILTRO(2)=" AND MFGITM.ZBOBSTK_0>"+num$(0)
FILTRO(4)=" AND (MFGHEAD.ENDDAT_0>='"+[M:ZCNOFST1]DESDEFECHA+"' AND MFGHEAD.ENDDAT_0<='"+[M:ZCNOFST1]HASTAFECHA+"') "



##############################################################################
# ABRIMOS LA QUERY
##############################################################################
REQUEST(0)="SELECT MFGITM.PLNFCY_0 AS [Planta],FACILITY.FCYNAM_0 AS [Nom.Planta],MFGITM.ITMREF_0 AS [Artículo],ITMMASTER.ITMDES1_0 AS [Descripción],"
REQUEST(1)="MFGITM.ZANCHO_0 AS [Ancho],MFGITM.ZLONGITUD_0 AS [Longitud],MFGITM.ZMANDRIL_0 AS [Mandril],MFGHEAD.ENDDAT_0, MFGHEAD.MFGNUM_0, ZQTYBOB_0 AS [Bobinas] "
REQUEST(2)="FROM MFGITM INNER JOIN MFGHEAD ON MFGITM.MFGNUM_0=MFGHEAD.MFGNUM_0 INNER JOIN ITMMASTER ON ITMMASTER.ITMREF_0=MFGITM.ITMREF_0 INNER JOIN FACILITY ON MFGITM.PLNFCY_0=FACILITY.FCY_0 "
REQUEST(3)=FILTRO(0)
REQUEST(4)=FILTRO(1)
REQUEST(5)=FILTRO(2)
REQUEST(6)=FILTRO(3)
REQUEST(7)=FILTRO(4)

Raz [M:ZCNOFST2]NBLIG
Effzo [M:ZCNOFST2]5
For (Char PLANTA(15),Char NOMPLANTA(15), Char ARTICULO(20),Char DESARTI(30),Shortint ANCHO,Integer LONGITUD,Integer MANDRIL,Date FECHA,Char NUMOF(25),Double CANTBOBINAS) From "5" Sql REQUEST As [XXX]
      FILAS=[M:ZCNOFST2]NBLIG
      [M:ZCNOFST2]STOFCY(FILAS)=[F:XXX]PLANTA
      [M:ZCNOFST2]ZANCHO(FILAS)=[F:XXX]ANCHO
      [M:ZCNOFST2]ZLONGITUD(FILAS)=[F:XXX]LONGITUD
      [M:ZCNOFST2]FCYSHO(FILAS)=[F:XXX]NOMPLANTA
      [M:ZCNOFST2]ZMANDRIL(FILAS)=[F:XXX]MANDRIL
      [M:ZCNOFST2]ITMREF(FILAS)=[F:XXX]ARTICULO
      [M:ZCNOFST2]ITMDES1(FILAS)=DESARTI
      [M:ZCNOFST2]ZFECHA(FILAS)=FECHA
      [M:ZCNOFST2]ZNUMOF(FILAS)=NUMOF
      [M:ZCNOFST2]ZQTYBOB(FILAS)=CANTBOBINAS

      [M:ZCNOFST2]NBLIG+=1
      If [M:ZCNOFST2]NBLIG>=3000 Then
          Infbox("La consulta devuelve demasiados registros. Se visualizarán los 3000 primeros")
          Break
      Endif
Next

Gosub CALCULAR_TOTALES
Affzo [M:ZCNOFST2]5

Return

$CALCULAR_TOTALES
Local Integer I

FILAS=[M:ZCNOFST2]NBLIG

[M:ZCNOFST2]STOFCY(FILAS) = "***"
[M:ZCNOFST2]FCYSHO(FILAS) = toupper(mess(142,124,1))
Raz [M:ZCNOFST2]ZANCHO(FILAS)
Raz [M:ZCNOFST2]ZLONGITUD(FILAS)
Raz [M:ZCNOFST2]ZMANDRIL(FILAS)
Raz [M:ZCNOFST2]ZFECHA(FILAS)

For I=0 To [M:ZCNOFST2]NBLIG-1
    [M:ZCNOFST2]ZQTYBOB(FILAS)+=[M:ZCNOFST2]ZQTYBOB(I)
Next

[M:ZCNOFST2]NBLIG+=1
Return


######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCNOFSTC1) 21/02/2016 00:47:32 (ADMIN)
######################################################################################
Subprog IB_ITMREF
End

Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_QTYTYP(VALEUR)
Variable Integer VALEUR
End

Subprog C_DETFLG(VALEUR)
Variable Integer VALEUR
End

Subprog C_CUMFLG(VALEUR)
Variable Integer VALEUR
End

Subprog IB_NBLIG
End

