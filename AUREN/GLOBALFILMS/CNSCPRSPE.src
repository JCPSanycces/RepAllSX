#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento especifico consulta recepciones
$ACTION
Case ACTION
  When "FILTRE"        : Gosub FILTRE
  When "AV_AFFICHE"    : Gosub AV_AFFICHE
  When Default
Endcase
Return

$FILTRE
Raz [M:CPR1]ZTOTKG
Raz [M:CPR1]ZTOTM2
Raz [M:CPR1]ZTOTIMPAI
Raz [M:CPR1]ZTOTIMPII
Affzo [M:CPR1]ZTOTKG
Affzo [M:CPR1]ZTOTM2
Affzo [M:CPR1]ZTOTIMPAI
Affzo [M:CPR1]ZTOTIMPII
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$CAL_CUMUL
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
Raz [M:CPR1]ZTOTKG
Raz [M:CPR1]ZTOTM2
Raz [M:CPR1]ZTOTIMPAI
Raz [M:CPR1]ZTOTIMPII
Filter [PTH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key PTH0
For [PTH]
   [M:CPR1]ZTOTIMPAI+=[F:PTH]TOTAMTNOT
   [M:CPR1]ZTOTIMPII+=[F:PTH]TOTAMTATI
   Filter [PTD] Where PTHNUM=[F:PTH]PTHNUM
   For [PTD]
      Raz [F:ITM]
      Read [ITM]ITM0=[F:PTD]ITMREF
      If [F:PTD]UOM="M2"
         [M:CPR1]ZTOTKG+=arr([F:PTD]QTYPUU*[F:ITM]ZFACTOR,0.01)
         [M:CPR1]ZTOTM2+=arr([F:PTD]QTYPUU,0.01)
      Endif
      If [F:PTD]UOM="KG"
         [M:CPR1]ZTOTKG+=arr([F:PTD]QTYPUU,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CPR1]ZTOTM2+=arr([F:PTD]QTYPUU/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CPR1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [PTD]
Next
Filter [PTH]
Return

$AFF_CUMUL
Affzo [M:CPR1]ZTOTKG
Affzo [M:CPR1]ZTOTM2
Affzo [M:CPR1]ZTOTIMPAI
Affzo [M:CPR1]ZTOTIMPII
Return
