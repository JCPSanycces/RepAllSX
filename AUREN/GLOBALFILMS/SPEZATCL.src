# Gestión de la máscara ZATCL0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZATCL0) 18/11/2015 12:33:03 (ADMIN)
######################################################################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()


Read [BPR1]BPR0 = VALEUR
If fstat = 0
  #[M:ZATCL] = [F:BPR1]
  [M:ZATCL0]BPCNAM = [F:BPR1]BPRNAM
  Affzo [M:ZATCL0]BPCNAM
Endif


#Read [BPADR1]BPA0=1;[F:BPR1]BPRNUM;[F:BPR1]BPAADD
#Read [BPADR1]BPATYP=1;[F:BPR1]BPRNUM;[F:BPR1]BPAADD

Read [BPADR1]BPA0=1;[F:BPC]BPCNUM;[F:BPC]BPAADD

#If fstat=0
  #Infbox([F:BPADR1]BPAADDLIG)
  [M:ZATCL1]STREET = [F:BPADR1]BPAADDLIG
  Affzo [M:ZATCL1]STREET

  [M:ZATCL1]COUNTRY = [F:BPADR1]CRYNAM
  Affzo [M:ZATCL1]COUNTRY

  [M:ZATCL1]CITY = [F:BPADR1]CTY
  Affzo [M:ZATCL1]CITY

  [M:ZATCL1]ZIPCOD = [F:BPADR1]POSCOD
  Affzo [M:ZATCL1]ZIPCOD

  [M:ZATCL1]TEL = [F:BPADR1]TEL(0)
  Affzo [M:ZATCL1]TEL
  #Infbox([M:ZATCL1]TEL)

  [M:ZATCL1]FAX = [F:BPADR1]FAX(0)
  Affzo [M:ZATCL1]FAX

  [M:ZATCL1]MOB = [F:BPADR1]MOB(0)
  Affzo [M:ZATCL1]MOB

  #Infbox([M:ZATCL1]STREET)
#Endif

End


