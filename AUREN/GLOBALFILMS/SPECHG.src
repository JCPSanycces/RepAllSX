######################################################################################
#> AZ 70247 - bloque cantidad en cambio ubicaciÛn cuando son bobinas
Subprog C_QTYPCUDES(VALEUR)
Variable Decimal VALEUR

If !clalev([I0]) : Local File ITMMASTER [I0] : Endif

Read [I0]ITM0 = [M:SCD]ITMREF
If fstat = 0 Then
  If [I0]ZFABCOR = 2 Then
    # cantidad disponible debe ser igual al valor por campo..
    If [M:SCD]QTYPCUDES(nolign-1) <> VALEUR Then
      GMESSAGE = "Cantidad a tratar debe ser igual a la Cantidad US tratada"
      mkstat = 2
    Endif
  Endif
Endif

Close Local File [I0]
End
#< AZ 70247


