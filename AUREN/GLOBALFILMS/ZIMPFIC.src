#<AdxTL>@(#)0.0.0.0 $Revision$
# Genera modelo importacion ZAIN para importar los email de los clientes
# Fichero .csv   CTE;RAZONSOCIAL;EMAIL
$IMPORTAR_CONTACTOS
Local Char XDIR(250),FSRVTMP(250)
XDIR="tmp"
FSRVTMP=filpath(XDIR,"CtesMail_1","csv","","",adxmac(0))
If filinfo(FSRVTMP,7)<0
  Infbox "No se encontró el fichero "+FSRVTMP
  End
Endif

Local Integer YN : YN=1
Call OUINON("Está seguro de importar el fichero\"+FSRVTMP, YN) From GESECRAN
If YN=1
  End
Endif

#If !clalev([F:BPA])      :  Local File BPADDRESS   [F:BPA]  : Endif
If !clalev([F:BPCW])      :  Local File BPCUSTOMER    [F:BPCW]  : Endif


# Fichero de ENTRADA
Openi FSRVTMP Using [FIC2]
Iomode adxifs  ";"  Using [FIC2]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC2]
Iomode adxium  50 Using [FIC2] #  50 = ASCII  0 = UTF8

Local Char MSG(255)
Local Char FCTE(GLONBPA),FNOM(GLONNAM),FMAI(255)
Local Integer H
Raz H
Repeat
  Rdseq FCTE,FNOM,FMAI Using [FIC2]
  FCTE=vireblc(FCTE,2)
  FNOM=vireblc(FNOM,2)
  FMAI=vireblc(FMAI,2)
  If not (FCTE="" or FNOM="" or FMAI="")
    Gosub GRABAR
  Endif
Until fstat <> 0
Openi Using [FIC2]
If H<=0
  Infbox "No se importó dato alguno"
Else
  # Fin
  Call XML_FIN(WNOM) From ZXML
  Openo Using [TIF]   #Cerramos el fichero XML generado
  # Lanzamos importación
  Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
  # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
  WFICH = filpath("ZIMPEXP\IMPOR",WXML,"XML.err")
  If filinfo(WFICH,0) > 0 Then
      MSG= "Hubieron Problemas en la importacion del fichero\"+WXML
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
  Else
#      Call ANADIR_REL
  Endif
  Infbox "Se han importado "+num$(H)+" contactos"
Endif
Return


$GRABAR
Local Char WEMA(GLONMAI)(0..)
Local Integer EXISTE : EXISTE=0
Local Integer F,FN,LEER_CTE
Local Char WCTE(GLONBPR)
WCTE=format$("N0:5",val(FCTE))
Call ARRAY(FMAI,",",WEMA) From ZCOMUN
# El cliente no debe tener ese email en la funcion 6-Tarifas ó 7-Comercial
LEER_CTE=1
For F=0 To dim(WEMA)
  If WEMA(F)=""
    Break
  Else
    For FN=7 To 7
      If not func EXISTE_EMAIL(WCTE,WEMA(F),FN)
        Gosub ANADIR
      Endif
    Next
  Endif
Next
If LEER_CTE=0
  Call XML_CIERRA_ETIQUETA("B") From ZXML
Endif
Return

$ANADIR
If H=0
  Gosub ABRIR_IMP
Endif
H+=1
If LEER_CTE
  Raz [F:BPCW]#,[F:BPA]
  Read [F:BPCW]BPC0=WCTE
  If fstat<>0
    Infbox "Cliente "+WCTE+" NO EXISTE"
    Return
  Endif
#  #select * from BPADDRESS where BPANUM_0='01055' and BPAADDFLG_0=2
#  Filter [F:BPA]
#  Filter [F:BPA] Where BPANUM=WCTE and BPAADDFLG=2
#  Read [F:BPA] First
#  If fstat<>0
#    Infbox "Cliente "+WCTE+" NO tiene direccion por defecto, no se pasará informacion de dirección al contacto"
#  Endif
  Call XML_ABRE_ETIQUETA("B") From ZXML
  Call XML_LINEA("BPC_BCGCOD",[F:BPCW]BCGCOD)       From ZXML
  Call XML_LINEA("BPC_BPCNUM",WCTE)                 From ZXML
  Call XML_LINEA("BPC_CUR",[F:BPCW]CUR)             From ZXML
  Call XML_LINEA("BPC_BPCINV",[F:BPCW]BPCINV)       From ZXML
  Call XML_LINEA("BPC_BPCPYR",[F:BPCW]BPCPYR)       From ZXML
  Call XML_LINEA("BPC_BPCRSK",[F:BPCW]BPCRSK)       From ZXML
  Call XML_LINEA("BPC_BPCGRU",[F:BPCW]BPCGRU)       From ZXML
  Call XML_LINEA("BPC_VACBPR",[F:BPCW]VACBPR)       From ZXML
  Call XML_LINEA("BPC_PTE",[F:BPCW]PTE)             From ZXML
  Call XML_LINEA("BPC_ACCCOD",[F:BPCW]ACCCOD)       From ZXML
  #
  LEER_CTE=0
Endif
Call XML_ABRE_ETIQUETA("C") From ZXML
Call XML_LINEA("CNT_CCNCRM","")                  From ZXML       # Cod.Interlocutor
Call XML_LINEA("AIN_CNTLNA",[F:BPCW]BPCNAM)      From ZXML       # Apellidos
Call XML_LINEA("CNT_WEB",vireblc(WEMA(F),2))     From ZXML       # Dirección email
Call XML_LINEA("CNT_CNTFNC",num$(FN))            From ZXML       # Funcion
Call XML_CIERRA_ETIQUETA("C") From ZXML
Return


