Funprog EXISTE_EMAIL(FCTE,EMAIL,FN)
Value Char FCTE,EMAIL
Value Integer FN
Local Integer EXISTE
EXISTE=0
If !clalev([F:CNTW])      :  Local File CONTACT   [F:CNTW]  : Endif
Filter [F:CNTW] Where BPATYP=1 and BPANUM=FCTE and CNTFNC=FN
For [F:CNTW]
  If [F:CNTW]WEB=vireblc(EMAIL,2)
    EXISTE=1
    Break
  Endif
Next
Filter [F:CNTW]
End EXISTE



$ABRIR_IMP
# Variables para XML
Local Char WNOM(20),WJOB(10),WXML(250),WOUT(250),WDIR(250),WFICH(250)
# Comprobar directorio y crearlo en caso de que no exista
WDIR="ZIMPEXP\IMPOR"
WOUT=filpath("","","","","",adxmac(0)) +"\" + WDIR
If filinfo(WOUT,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + WOUT + '"',"",STAT) From ORDSYS
Endif
# Abrir fichero
WNOM="ZBPC" #"ZAIN"    #   Modelo de importación
WJOB = num$(time)
WXML = WNOM+"_"+format$("D:YYYYMMDD",date$)+"_"+WJOB
WOUT = filpath(WDIR,WXML,"xml")
Openo WOUT,0 Using [TIF]
# Inicio
Call XML_INICIO("UTF") From ZXML
Call XML_INICIO_NOMBRE(WNOM) From ZXML
Return
