#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AVANT_ENR"  :  Gosub AVANT_ENR
Endcase
Return

$AVANT_ENR
Local Integer WLINEA
For WLINEA=0 To [M:SOM]NBLIG-1
   If [M:SOM]AVAQTYSTU(WLINEA)<>[M:SOM]QTYSTU(WLINEA)
      Infbox "No se permite dejar restos (1) - linea: "+num$(WLINEA+1)+" - "+num$([M:SOM]AVAQTYSTU(WLINEA))+" - "+num$([M:SOM]QTYSTU(WLINEA))
      FOK=0
      Break
   Endif
Next
If FOK=0
   GPE=1
   Return
Endif
Return
