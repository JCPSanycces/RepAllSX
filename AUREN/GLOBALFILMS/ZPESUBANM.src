#<AdxTL>@(#)0.0.0.0 $Revision$
#PE NUMERO -> PE utilizado para intervenir la varible COMP de la gestion de contadores para el caso del contador de lotes
#PE NUMEROCHG -> PE utilizado para cambiar el valor del contador devuelto para el contador de lotes
$ACTION
Case ACTION
   When "NUMERO"    :   Gosub NUMERO
   When "NUMEROCHG" :   Gosub NUMEROCHG
Endcase
Return

$NUMERO
Local Char NUMLOT(6)

If COMPTEUR="LOT"
   #Infbox [M:PTH0]PTHNUM
   #GPE=1
   If GFONCTION="GESPTH"
      #VALEUR=format$("D:YYMMDD",[M:PTH0]RCPDAT)
      COMP=format$("D:YYMMDD",[M:PTH0]RCPDAT)
   Endif
   If GFONCTION="GESMTK"
      #Infbox COMP+" - "+num$([F:MFG]ENDDAT)

      COMP=format$("D:YYMMDD",date$)
   Endif
   If GTRACE<>""
      Call ECR_TRACE(" PE NUMERO (SUBANM) - "+GFONCTION+" - COMP: "+COMP,0) From GESECRAN
   Endif
Endif
Return

$NUMEROCHG
Local Char NUMLOT(6)

If COMPTEUR="LOT"
   If GTRACE<>""
      Call ECR_TRACE(" PE NUMEROCHG (SUBANM) - "+GFONCTION+" - VALEUR: "+VALEUR,0) From GESECRAN
   Endif
   If GFONCTION="GESPTH"
      #Infbox [M:PTH0]PTHNUM
      VALEUR=mid$(VALEUR,7,12)+[F:PTD]ZPROVEEDOR
   Endif
   If GFONCTION="GESMTK"
      #Cambiamos el contador por la fecha de fin OF y la secuencia que tenia asignada
      Call CONV_NUMOF_LOTE ([F:MFG]MFGNUM,NUMLOT)
      VALEUR=NUMLOT+mid$(VALEUR,13,3)
   Endif
   If GFONCTION="GESSMR"
      VALEUR=mid$(VALEUR,7,12)+[F:SMD]ZPROVEEDOR
   Endif
Endif
Return

Subprog CONV_NUMOF_LOTE(WNUMOF,WNUMLOT)
Value Char WNUMOF
Variable Char WNUMLOT

Local Integer LONCAD, I, J
Local Char CADORI(12),CADNUM(12),CADFIN(12),NUMERO(10)

CADORI=WNUMOF
NUMERO="0123456789"
#Se eliminan las letras de la cadena (solo nos quedamos con los numeros)
LONCAD=len(CADORI)
For I=1 To LONCAD
   If instr(1,NUMERO,mid$(CADORI,I,1))
      CADNUM+=mid$(CADORI,I,1)
   Endif
Next

#Nos quedamos con los 6 ultimos digitos
LONCAD=len(CADNUM)
If len(CADNUM)>6
   CADFIN=mid$(CADNUM,LONCAD-6+1,6)
Else
   CADFIN=CADNUM
Endif
WNUMLOT=CADFIN
End
