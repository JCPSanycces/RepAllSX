#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para la asginacion de pedidos de venta a contenedor
$ACTION
#Infbox "ZCNTRAS: "+ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
If !clalev([F:SOH])    : Local File SORDER     [SOH] : Endif
If !clalev([F:SOP])    : Local File SORDERP    [SOP] : Endif
If !clalev([F:SOQ])    : Local File SORDERQ    [SOQ] : Endif
If !clalev([F:POH])    : Local File PORDER     [POH] : Endif
If !clalev([F:POP])    : Local File PORDERP    [POP] : Endif
If !clalev([F:POQ])    : Local File PORDERQ    [POQ] : Endif
If !clalev([F:ITM])    : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ZCNTR])  : Local File ZCONTAINH  [ZCNTR]  : Endif
If !clalev([F:ZCNTRP]) : Local File ZCONTAINP  [ZCNTRP] : Endif
If !clalev([F:ZCNTRS]) : Local File ZCONTAINS  [ZCNTRS] : Endif
Return

$DEBUT
Local Char LNUMCNTR(25), LPOHNUM(25)

LNUMCNTR=PARAM(1)
Raz [M:ZCNTRAS]
Raz [M:ZCNTRAS]SOHNUMSTR
[M:ZCNTRAS]SOHNUMSTR=PARAM(2)
Affzo [M:ZCNTRAS]SOHNUMSTR
[M:ZCNTRAS]STOFCY=PARAM(3)
Affzo [M:ZCNTRAS]STOFCY

Filter [ZCNTRP] Where NUMCNTR=LNUMCNTR Order By Key ZCNTRP2
LPOHNUM=""
For [ZCNTRP]
   If LPOHNUM<>[F:ZCNTRP]POHNUM
      If LPOHNUM=""
         [M:ZCNTRAS]FILPOH="(POHNUM='"+[F:ZCNTRP]POHNUM+"'"
      Else
         [M:ZCNTRAS]FILPOH+=" or POHNUM='"+[F:ZCNTRP]POHNUM+"'"
      Endif
      LPOHNUM=[F:ZCNTRP]POHNUM
   Endif
Next
If len([M:ZCNTRAS]FILPOH)<>0
   [M:ZCNTRAS]FILPOH+=")"
Endif
Affzo [M:ZCNTRAS]FILPOH
#Gosub CARGAR
Return

$SETBOUT
If [M:ZCNTRAS]NBLIG1=0
    Call VIREBOUT(CHMEN,"2") From GOBJET
Endif
Return

$BOUTON
Local Integer LRET
Case BOUT
    When "1" :  Gosub CARGARS :  Gosub CARGARP
    When "2" :  Gosub ASIGNAR :  Gosub CARGARP: Gosub CARGARS
Endcase
Return

$APRES_MODIF
If COUZON="SOHNUMSTR"
   [M:ZCNTRAS]SOHNUMSTR=CZ
   Gosub CARGARS
Endif
If COUZON="POHNUMSTR"
   [M:ZCNTRAS]POHNUMSTR=CZ
   Gosub CARGARP
Endif
Return

$CARGARS
Local Decimal LBOBASI, LBOBAASI
Local Decimal LVOLUMEN

Filter [SOH] Where SOHNUM=[M:ZCNTRAS]SOHNUMSTR
nolign=0
For [SOH]
   #Filtro para mostrar aquellas lineas con ZCORTE=3 - Compra
   #Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM and ZCORTE=3
   Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM and ZCORTE=3
   For [SOQ]
      Filter [ZCNTRS] Where SOHNUM=[F:SOQ]SOHNUM and SOPLIN=[F:SOQ]SOPLIN
      LBOBASI=0
      For [ZCNTRS]
          LBOBASI+=[F:ZCNTRS]BOBASI
      Next
      Filter [ZCNTRS]

      LBOBAASI=[F:SOQ]ZQTYBOB-LBOBASI

      If LBOBAASI<>0
         Raz [F:SOP]
         Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
         Raz [F:ITM]
         Read [ITM]ITM0=[F:SOQ]ITMREF
         [M:ZCNTRAS]NUMLNKS(nolign) =0
         [M:ZCNTRAS]SOHNUM(nolign)  =[F:SOQ]SOHNUM
         [M:ZCNTRAS]SOPLIN(nolign)  =[F:SOQ]SOPLIN
         [M:ZCNTRAS]SOQSEQ(nolign)  =[F:SOQ]SOQSEQ
         [M:ZCNTRAS]ITMREF(nolign)  =[F:SOQ]ITMREF
         [M:ZCNTRAS]ANCHO(nolign)   =[F:SOQ]ZANCHO
         [M:ZCNTRAS]MANDRIL(nolign) =[F:SOQ]ZMANDRIL
         [M:ZCNTRAS]LONGITUD(nolign) =[F:SOQ]ZLONGITUD
         [M:ZCNTRAS]ITMDES1(nolign) =[F:SOP]ITMDES1
         [M:ZCNTRAS]BOBPED(nolign)  =[F:SOQ]ZQTYBOB
         [M:ZCNTRAS]BOBASI(nolign)  =LBOBASI
         [M:ZCNTRAS]BOBPTE(nolign)  =LBOBAASI
         LVOLUMEN=([F:SOQ]ZANCHO/100)*[F:SOQ]ZLONGITUD*[F:ITM]ZESPESOR
         [M:ZCNTRAS]QTYPED(nolign)=[M:ZCNTRAS]QTYPED(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAS]QTYASI(nolign)=[M:ZCNTRAS]QTYASI(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAS]QTYPTE(nolign)=[M:ZCNTRAS]QTYPTE(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         nolign+=1
      Endif
   Next
   Filter [SOQ]
   [M:ZCNTRAS]NBLIG1=nolign
Next
[M:ZCNTRAS]BPCORD=[F:SOH]BPCORD
Filter [SOH]
Affzo [M:ZCNTRAS]10
Return

$CARGARP
Local Decimal LBOBASI, LBOBAASI
Local Decimal LVOLUMEN
Local Char CRITERIO(250)

CRITERIO='1=1'
If [M:ZCNTRAS]POHNUMSTR<>''
   CRITERIO+=' and [POH]POHNUM="'+[M:ZCNTRAS]POHNUMSTR+'"'
Endif
If [M:ZCNTRAS]ITMREFSTR<>''
   CRITERIO+=' and [POQ]ITMREF="'+[M:ZCNTRAS]ITMREFSTR+'"'
Endif
If [M:ZCNTRAS]ANCHOSTR<>0
   CRITERIO+=' and [POQ]ZANCHO>='+num$([M:ZCNTRAS]ANCHOSTR)
Endif

Link [POH] With [POQ]POQ0(1)=POHNUM As [LNK] Where evalue (CRITERIO)

Filter [LNK]
nolign=0
For [LNK]
      Filter [ZCNTRS] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
      LBOBASI=0
      For [ZCNTRS]
          LBOBASI+=[F:ZCNTRS]BOBASI
      Next
      Filter [ZCNTRS]

      LBOBAASI=[F:POQ]ZQTYBOB-LBOBASI

      If LBOBAASI<>0
         Raz [F:POP]
         Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
         Raz [F:ITM]
         Read [ITM]ITM0=[F:POQ]ITMREF
         [M:ZCNTRAS]NUMLNKP(nolign) =0
         [M:ZCNTRAS]POHNUM(nolign)  =[F:POQ]POHNUM
         [M:ZCNTRAS]POPLIN(nolign)  =[F:POQ]POPLIN
         [M:ZCNTRAS]POQSEQ(nolign)  =[F:POQ]POQSEQ
         [M:ZCNTRAS]PITMREF(nolign)  =[F:POQ]ITMREF
         [M:ZCNTRAS]PANCHO(nolign)   =[F:POQ]ZANCHO
         [M:ZCNTRAS]PMANDRIL(nolign) =[F:POQ]ZMANDRIL
         [M:ZCNTRAS]PLONGITUD(nolign) =[F:POQ]ZLONGITUD
         [M:ZCNTRAS]PITMDES1(nolign) =[F:POP]ITMDES1
         [M:ZCNTRAS]PBOBPED(nolign)  =[F:POQ]ZQTYBOB
         [M:ZCNTRAS]PBOBASI(nolign)  =LBOBASI
         [M:ZCNTRAS]PBOBPTE(nolign)  =LBOBAASI
         LVOLUMEN=([F:POQ]ZANCHO/100)*[F:POQ]ZLONGITUD*[F:ITM]ZESPESOR
         [M:ZCNTRAS]PQTYPED(nolign)=[M:ZCNTRAS]QTYPED(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAS]PQTYASI(nolign)=[M:ZCNTRAS]QTYASI(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAS]PQTYPTE(nolign)=[M:ZCNTRAS]QTYPTE(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         nolign+=1
         If nolign>=1999
            Infbox "Cuadro Ped. Compra completo (hay mas resultados)"
            Break
         Endif
      Endif
Next
[M:ZCNTRAS]NBLIG2=nolign
[M:ZCNTRAS]BPSNUM=[F:POH]BPSNUM
Filter [POH]
Affzo [M:ZCNTRAS]15
Return

$ASIGNAR
Local Integer LOK,I,J,MAXLIN

MAXLIN=0
Filter [ZCNTRS] Where POHNUM=[M:ZCNTRAS]POHNUMSTR
For [F:ZCNTRS]
   If [F:ZCNTRS]NUMLIN>MAXLIN
      MAXLIN=[F:ZCNTRS]NUMLIN
   Endif
Next
Filter [ZCNTRS]

LOK=1
Trbegin [ZCNTRS]
For I=0 To [M:ZCNTRAS]NBLIG2-1
   For J=0 To [M:ZCNTRAS]NBLIG1-1
      If [M:ZCNTRAS]NUMLNKS(J)<>0 or [M:ZCNTRAS]NUMLNKP(I)<>0
         If [M:ZCNTRAS]NUMLNKS(J)=[M:ZCNTRAS]NUMLNKP(I)
            MAXLIN=MAXLIN+1000
            [F:ZCNTRS]NUMCNTR =LNUMCNTR
            [F:ZCNTRS]NUMLIN =MAXLIN
            [F:ZCNTRS]POHNUM =[M:ZCNTRAS]POHNUM(I)
            [F:ZCNTRS]POPLIN =[M:ZCNTRAS]POPLIN(I)
            [F:ZCNTRS]POQSEQ =[M:ZCNTRAS]POQSEQ(I)
            [F:ZCNTRS]SOHNUM =[M:ZCNTRAS]SOHNUM(J)
            [F:ZCNTRS]SOPLIN =[M:ZCNTRAS]SOPLIN(J)
            [F:ZCNTRS]SOQSEQ =[M:ZCNTRAS]SOQSEQ(J)
            [F:ZCNTRS]BOBASI =[M:ZCNTRAS]BOBPTE(J)
            Write [ZCNTRS]
            If fstat
               LOK=0
               Infbox "Error grabando linea [ZCNTRS] - fstat: "+num$(fstat)
               Break
            Endif
         Endif
      Endif
   Next
Next
If LOK
   Commit
Else
   Rollback
Endif
Return
