#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LIENS"   :  Gosub LIENS
Endcase
Return

$LIENS
If [M:MFC0]VCRTYP=10 and [F:MFC]MFCTYP=2
   Gosub CAL_MERMA
Endif
Return

$CAL_MERMA
Local Decimal WTOTMATKG, WTOTMERKG, WPREUNI

If clalev([MFG1])>0
   #Se controla la accesibilidad a la clase porque esta funcion se puede llegar desde la consulta de costes previsionales sin
   #que se vengan des de la OF
   If [M:MFG1]ZMERMA<>0
   #Infbox "SPEMFC - "+num$([M:MFG1]ZMERMA)+" "+num$([F:ITM]ZFACTOR)
      WTOTMATKG=[M:MFG1]ZSUPERFMAT*[F:ITM]ZFACTOR
      WTOTMERKG=[M:MFG1]ZMERMA*[F:ITM]ZFACTOR
      [M:MFC1]ZMATTOT=WTOTMATKG*[M:MFC1]MATTOT
      [M:MFC1]ZMERTOT=WTOTMERKG*[M:MFC1]MATTOT
      Affzo [M:MFC1]ZMATTOT
      Affzo [M:MFC1]ZMERTOT
   Else
      [M:MFC1]ZMATTOT=0
      [M:MFC1]ZMERTOT=0
   Endif
Endif
Return
