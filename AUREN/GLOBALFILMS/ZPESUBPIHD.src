#<AdxTL>@(#)0.0.0.0 $Revision$
#PE CPRFAC -> que se llama desde SUBPIHD
#             el calculo del coste de la entrada
$ACTION
Case ACTION
When "CPRFAC"     :   Gosub CPRFAC
Endcase
Return

#
$CPRFAC
# Sacar Coste Stock Unitario de la recepcion
# Tabla abierta en OUVRE de SPEPIH.src
#If GUSER="ADMIN" Infbox "Depurar CPRFAC   ZPESUBPIHD.src"  Endif
If GFONCTION="GESPIH" and [M:PIH3]TYPORI(NOL)=2 and [M:PIH3]NUMORI(NOL)<>""
  Read [F:ZPTD]PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
  If fstat=0
    [F:PID]CPR=[F:ZPTD]CPR
  Endif
Endif
Return

