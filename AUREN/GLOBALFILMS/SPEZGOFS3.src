#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPGOFS3 (Especifico)
#LOS EVENTOS DE VENTANA SE GESTIONAN EN EL SPECIFICO INDICADO EN LA accion QUE LLAMA A LA VENTANA

Subprog ACTU_REJILLA(LAR)
Value Integer LAR
Local Integer F
Local Decimal D,C,P
# Desmarcar el resto de largos
Local Integer F
For F=0 To [M:ZGOFS3]NLNG-1
  If [M:ZGOFS3]LARGO(F)=LAR
    [M:ZGOFS3]SEL(F)=2
    Chgstl [M:ZGOFS3]NLNG(F) With "AEXPEXC1"
  Elsif [M:ZGOFS3]LARGO(F)<LAR
    [M:ZGOFS3]SEL(F)=1
    Chgstl [M:ZGOFS3]NLNG(F) With ""
  Else
    [M:ZGOFS3]SEL(F)=1
    Chgstl [M:ZGOFS3]NLNG(F) With "TDB01"
  Endif
Next
# Actualizar campos calculados en rejilla
For F=0 To [M:ZGOFS3]NLNG-1
  If [M:ZGOFS3]LARGO(F)<=LAR
    D=LAR/[M:ZGOFS3]LARGO(F)
    [M:ZGOFS3]DIVISOR(F)=D
    C=int([M:ZGOFS3]CANT(F)/D)
    If C<1
      [M:ZGOFS3]CANTD(F)  =[M:ZGOFS3]CANT(F) #C*int(D)
    Else
      [M:ZGOFS3]CANTD(F)  =C*int(D)
    Endif
    [M:ZGOFS3]CANTP(F)  =[M:ZGOFS3]CANT(F)-[M:ZGOFS3]CANTD(F)
    C=int([M:ZGOFS3]CANTD(F)/D)
    P=[M:ZGOFS3]CANTD(F)-(int(D)*C)
    R=[M:ZGOFS3]CANTD(F)-(C*D)
    [M:ZGOFS3]RESTO(F)  =(LAR-[M:ZGOFS3]LARGO(F))*R
#    P=(int(D)*[M:ZGOFS3]CANTD(F))
#    If P<0
#      [M:ZGOFS3]CANTP(F)  =0
#      [M:ZGOFS3]RESTO(F)  =LAR+(P*[M:ZGOFS3]LARGO(F))
#    Else
#      [M:ZGOFS3]CANTP(F)  =P
#      [M:ZGOFS3]RESTO(F)  =LAR-(int(D)*[M:ZGOFS3]LARGO(F))
#    Endif
    # Avisar si hay pedidos sin servir
    If [M:ZGOFS3]CANTP(F)<>0
      Chgstl [M:ZGOFS3]CANTP(F) With "BACKRED"
    Endif
    # Avisar si hay resto
    If [M:ZGOFS3]RESTO(F)
      Chgstl [M:ZGOFS3]DIVISOR(F) With "BACKRED"
      Chgstl [M:ZGOFS3]RESTO(F)   With "BACKRED"
      If P<0
        Chgstl [M:ZGOFS3]CANT(F) With "BACKRED"
      Endif
    Endif
  Else
    [M:ZGOFS3]DIVISOR(F)=0
    [M:ZGOFS3]CANTD(F)  =0
    [M:ZGOFS3]CANTP(F)  =0
    [M:ZGOFS3]RESTO(F)  =0
  Endif
Next
Affzo [M:ZGOFS3]5
End


Subprog AV_SEL(VALEUR)
Variable Integer VALEUR
# No entramos si hay un solo largo o marcamos uno ya seleccionado, pues por defecto solo puedo haber uno
If [M:ZGOFS0]STA="" and [M:ZGOFS3]NLNG<2
  mkstat=2
Endif
End

Subprog AM_SEL(VALEUR)
Variable Integer VALEUR
If [M:ZGOFS3]NLNG<2 or VALEUR<>2
  [M:ZGOFS3]SEL(nolign-1)=2
  Affzo [M:ZGOFS3]SEL(nolign-1)
  End
Endif
# Actualizar campos calculados en rejilla
Call ACTU_REJILLA ([M:ZGOFS3]LARGO(nolign-1))
End

