#<AdxTL>@(#)0.0.0.0 $Revision$
#STKALL (asignacion automatica)
#PECSTOALG -> PE de STKALL para intervenir la asignacion y rechazar el stock segun criterio especifico
#FISLTO    -> PE de STKALL para intervenir el filtro de los stocks a asignar
#RECHALL   -> PE de STKALL para reordenar los stocks a asignar
$ACTION
Case ACTION
   When "PECSTOALG"     :   Gosub PECSTOALG
   When "FILSTO"        :   Gosub FILSTO
   When "RECHALL"       :   Gosub RECHALL
Endcase
Return

$PECSTOALG
Local Integer PEDTRAS
Local Integer OKLIN
#Asignacion de pedidos traspasados
PEDTRAS=1
#Infbox GFONCTION+" - "+GFONC1
If GFONCTION="FUNAUTALL" :#and GSERVEUR
   If clalev([F:ZASP])<=0 : Local File ZASIPED [ZASP] : Endif
   If clalev([F:SOPX])<=0 : Local File SORDERP [SOPX] : Endif
   #Call ECR_TRACE(" PE PECSTOALG (STKALL) (1) - : ",0) From GESECRAN
   Filter [ZASP] Where VCRTYP=[M:ALP]VCRTYP and VCRNUM=[M:ALP]VCRNUM
   For [ZASP]
      PEDTRAS=2
      GOK=0
      #Call ECR_TRACE(" PE PECSTOALG (STKALL) (2) - : "+num$([M:ALP]VCRLIN)+" "+[M:ALP]WLOT(J)+" "+[M:ALP]WLOC(J),0) From GESECRAN

      Filter [SOPX] Where SOHNUM=[M:ALP]VCRNUM and ZSOPLIN=[F:ZASP]VCRLIN
      OKLIN=0
      For [SOPX]
         Call ECR_TRACE(" PE PECSTOALG (STKALL) (3) - : "+num$([M:ALP]VCRLIN)+" "+[M:ALP]WLOT(J)+" "+[M:ALP]WLOC(J)+" "+num$([F:SOPX]SOPLIN)+" "+num$([F:SOPX]ZSOPLIN),0) From GESECRAN
         OKLIN=1
      Next
      Filter [SOPX]
#      If [F:ZASP]LOT=[M:ALP]WLOT(J) and [F:ZASP]LOC=[M:ALP]WLOC(J) and
#&        [F:ZASP]VCRLIN=[M:ALP]VCRLIN :#and [F:ZASP]SLO=[M:ALP]WSLO(J)
      If [F:ZASP]LOT=[M:ALP]WLOT(J) and [F:ZASP]LOC=[M:ALP]WLOC(J) and
&        [F:ZASP]VCRLIN=[F:SOPX]ZSOPLIN
         Call ECR_TRACE(" PE PECSTOALG (STKALL) (4) - : "+num$([M:ALP]VCRLIN)+" "+[M:ALP]WLOT(J)+" "+[M:ALP]WLOC(J),0) From GESECRAN
         GOK=1
         Break
      Endif
   Next
   Filter [ZASP]
Endif
If PEDTRAS=2
   Return
Endif
If GFONCTION="GESMFG" or GFONC1="GESMFG" or GFONCTION="GESMTK"
   If  !clalev([F:ZMFL]) : Local File ZMFGLOT [ZMFL] : Endif
   If  [F:MFM]ZFABCOR = 2 Then  : # Fabricacion por Corte
       Filter [F:ZMFL]
       Filter [F:ZMFL] Where MFGNUM=[M:ALP]VCRNUM and STOFCY=[M:ALP]STOFCY and ITMREF=[M:ALP]ITMREF and LOT=[M:ALP]WLOT(J) and SLO=[M:ALP]WSLO(J)
       # Solo se permiten lotes/sublotes pre-asignados a la OF
       GOK=0
       For [F:ZMFL]
          GOK=1
          Break
       Next
      Filter [F:ZMFL]
   Endif
   Return
Else
   # Rechazo asignacion si stock pre-asignado a una OF
   If  !clalev([F:ZMFL]) : Local File ZMFGLOT [ZMFL] : Endif
   If  !clalev([F:MFG]) : Local File MFGHEAD [MFG] : Endif
   Filter [F:ZMFL] Where STOFCY=[M:ALP]STOFCY and ITMREF=[M:ALP]ITMREF and LOT=[M:ALP]WLOT(J) and SLO=[M:ALP]WSLO(J)
   For [F:ZMFL]
       Read [F:MFG]MFG0=[F:ZMFL]MFGNUM
       If !fstat and [F:MFG]MFGSTA<>4
            # Rechazar stock pre-asignado a una OF
            # Existe Lote Pre-asignado y la Orden no está cerrada
         GOK=0
         Break
      Endif
   Next
   Filter [F:ZMFL]
   If GOK=0 : Return : Endif
Endif

#Si se trata de asignacion automatica lanzada en batch solamente se asignan bobinas que esten en la
#ubicacion "RESER". Se trata del lanzamiento de la asignacion tras el seguimiento de producción.
If GSERVEUR and GFONCTION="FUNAUTALL"
   If [M:ALP]WLOC(J)<>"0RESERVA"
      GOK=0
      Return
   Endif
Endif

#Se ejecuta para tantas lineas de stock se hayan recogido para completar la asignacion de la linea de documento
#Cuando el numero de bobinas asignadas (lote-sublote) es mayor al del pedido se rechaza para no asginar picos.

#Infbox "PECSTOALG: "+GFONC1+" "+GFONCTION+" "+num$([M:ALP]TRSTYP)+" "+num$([M:ALP]VCRTYP)+" "+
#&      num$([M:ALP]QTY)+" "+ num$([M:ALP]WQTYSTUAVA)+" "+num$(ZGNBRBOB)
ZGNBRBOB+=1
If GFONCTION="GESSOH" or GFONC1="GESSOH"
   If [F:ITM]ZFABCOR=2
      #Call ECR_TRACE("STOCOU: "+num$(num$([M:ALP]WSTOCOU(J)))+" WQTYSTU: "+num$([M:ALP]WQTYSTU(J))+" WQTYSTUAVA: "+num$([M:ALP]WQTYSTUAVA(J))+" QTY: "+num$([M:ALP]QTY),0) From GESECRAN
      If ZGNBRBOB>[F:SOQ]ZQTYBOB
         GOK=0
      Endif
      If [M:ALP]QTY<[M:ALP]WQTYSTUAVA(J)
         GOK=0
      Endif
   Endif
Endif
Return

$FILSTO
#Infbox "PE FILSTO: "+GFONC1+" "+GFONCTION+" "+num$([M:ALP]TRSTYP)+" "+num$([M:ALP]VCRTYP)+" LIN: "+num$([F:SOQ]SOPLIN)
#Se ejecuta una vez por linea de documento
ZGNBRBOB=0
If [M:ALP]VCRTYP=2 : #Pedido
   [M:ALP]FILSTO="[F:STO1]ZANCHO="+num$([F:SOQ]ZANCHO)+" &[F:STO1]ZMANDRIL="+num$([F:SOQ]ZMANDRIL)+" &[F:STO1]ZLONGITUD="+num$([F:SOQ]ZLONGITUD)+""
Endif
If [M:ALP]VCRTYP=4 : #Entrega
   If GFONC1="GESSOH"
      [M:ALP]FILSTO="[F:STO1]ZANCHO="+num$([F:SOQ]ZANCHO)+""
      If [F:SOQ]ZPROVEEDOR<>""
         WCRITLOT+='&[F:STO1]ZPROVEEDOR="'+[F:SOQ]ZPROVEEDOR+'"'
      Endif
   Endif
Endif
#Infbox "FJCP" - GFONC1 - num$([F:MFM]ZANCHO)
If [M:ALP]VCRTYP=10 : #OF
   If GFONC1="GESMFG"
     [M:ALP]FILSTO="[F:STO1]ZANCHO>="+num$([M:MFG1]ZMINANCHO)+""
   Endif
Endif
Return

#PE para cambiar la ordenacion de la las lineas de stock cargadas en la mascara
#de stocks asignados [ALP].
$RECHALL
Local Integer WLI,WLJ, BOBSOB

If [M:ALP]VCRTYP<>10 and [M:ALP]VCRTYP<>12
   Return
Endif
#Buscamos si se ha determiando una bobina sobrante y nos quedamos con su STOCOU
If clalev([ZMFL])<=0 : Local File ZMFGLOT [ZMFL] : Endif
BOBSOB=0
Filter [ZMFL] Where MFGNUM=[M:ALP]VCRNUM and  ZSOBRANTE=2
For [ZMFL]
  BOBSOB=[F:ZMFL]STOCOU
Next
Filter [ZMFL]

If BOBSOB<>0
   WLJ=-1
   #Hay bobina sobrante, entonces se reordena el grid de asignaciones
   For WLI=0 To [M:ALP]NBLIG-1
      If [M:ALP]WSTOCOU(WLI)=BOBSOB
         WLJ=WLI
         Break
      Endif
   Next
   If WLJ<>-1
      #A la posicion encontrada se le asigna la ulitma posicion y
      #a la ultima posicion se le asigna la posicion encontrada,
      #es decir, invertimos las posioiones, de forma que la bobina
      #sobrante este en la ultima posicion
      [M:ALP]NLIG(WLJ)=[M:ALP]NBLIG-1
      [M:ALP]NLIG([M:ALP]NBLIG-1)=WLJ
   Endif
Endif
Return
