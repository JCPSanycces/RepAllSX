#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "SETBOUT"   :   Gosub SETBOUT
   When "APRES_CRE"  :   Gosub APRES_CRE
   When "APRES_MOD"  :   Gosub APRES_MOD
Endcase
Return

$SETBOUT
CHMEN += "É"
Gosub SET_BOUT_SPE From GSAISIE
Return

$APRES_CRE
If [M:BPC1]ZSAUM2=2
   Call ZGENITU([M:BPC0]BPCNUM)
Endif
If [M:BPC1]ZSAUM2=1
   Call ZBORITU([M:BPC0]BPCNUM)
Endif
Return

$APRES_MOD
If [M:BPC1]ZSAUM2=2
   Call ZGENITU([M:BPC0]BPCNUM)
Endif
If [M:BPC1]ZSAUM2=1
   Call ZBORITU([M:BPC0]BPCNUM)
Endif
Return

Subprog ZGENITU(LBPCNUM)
Value Char LBPCNUM

#Dbgaff
If clalev([F:ITMX])<=0 : Local File ITMMASTER [ITMX] : Endif
If clalev([F:ITSX])<=0 : Local File ITMSALES  [ITSX] : Endif
If clalev([F:ITUX])<=0 : Local File ITMBPC    [ITUX] : Endif
Filter [ITSX] Where 1=1
For [ITSX]
   Raz [F:ITMX]
   Read [ITMX]ITM0=[F:ITSX]ITMREF
   If fstat=0 & [F:ITMX]SAU<>"M2"
      Raz [F:ITUX]
      Read [ITUX]ITU0=[F:ITSX]ITMREF;LBPCNUM
      If fstat
         [F:ITUX]BPCNUM=LBPCNUM
         [F:ITUX]ITMREF=[F:ITSX]ITMREF
         [F:ITUX]ITMREFBPC=LBPCNUM+[F:ITSX]ITMREF
         [F:ITUX]SAU   ="M2"
         [F:ITUX]SAUSTUCOE=[F:ITMX]ZFACTOR
         [F:ITUX]ENAFLG=2
         [F:ITUX]CREDAT=date$
         [F:ITUX]CREUSR=GUSER
         Write [ITUX]
      Else
         Update [ITUX] Where ITMREF=[F:ITSX]ITMREF and BPCNUM=LBPCNUM
&               With SAU="M2", SAUSTUCOE=[F:ITMX]SAUSTUCOE, UPDDAT=date$, UPDUSR=GUSER
      Endif
   Endif
Next
Filter [ITSX]
End

Subprog ZBORITU(LBPCNUM)
Value Char LBPCNUM
Local Shortint LRESP
Local Integer LNBR

If clalev([F:ITUX])<=0 : Local File ITMBPC    [ITUX] : Endif

Filter [ITUX] Where BPCNUM=LBPCNUM
LNBR=0
For [ITUX]
   LNBR+=1
Next
Filter [ITUX]

If LNBR>0
   Wrnbox "Eliminar registros articulo-cliente para: "+LBPCNUM Using LRESP
   If LRESP=1
      Delete [ITU] Where BPCNUM=LBPCNUM
   Endif
Endif
End
