## Etiqueta añadida por el supervisor (pantalla STOENT) 27/12/2018 14:07:56 (ADMIN)
######################################################################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR

Local Integer LLIN : LLIN = nolign-1
Local Integer LOK
########################################
## PARAMETROS    son de tipo CHAR     ##
##      nombre parametro máximo 10    ##
########################################
Local Char TMP(255)
#Tope 1, a partir del cual avisamos y NO dejamos continuar
Local Decimal ZTOP1 : Call PARAM("","ZTOP1",TMP) From ADOVAL : ZTOP1=val(TMP)
#Tope 2, a partir del cual avisamos y SI dejamos continuar
Local Decimal ZTOP2 : Call PARAM("","ZTOP2",TMP) From ADOVAL : ZTOP2=val(TMP)

# ejecutamos el control si está en recepciones
If GFONC1 = "GESPTH" Then
  Call CONTROL_FACTOR(LLIN, VALEUR, ZTOP1, ZTOP2)
Endif
End

#**
#* Controla que la cantidad modificada este dentro de unos márgenes establecidos
#*
#* @param F  -> línea de la entrada a modificar
#* @param PQTY -> es el VALEUR de la cantidad modificada
#* @param DIF1 -> parámetro ZTOP1
#* @param DIF2 -> parámetro ZTOP2
#*!
Subprog CONTROL_FACTOR(F,PQTY,DIF1,DIF2)
Value Integer F
Value Decimal PQTY
Value Decimal DIF1,DIF2
Local Integer OK : OK=1
Local Integer YN : YN=1  # Por defecto es NO
Local Decimal FACTOR,FACTOR_ART,LM2,LANCHO,DIF,DIF_POR,QTY_ORI
Local Char STU(GLONUOM),MSG(255)
Raz FACTOR,FACTOR_ART,STU,MSG,QTY_ORI

If clalev([F:ITMW])<=0   :  Local File ITMMASTER [F:ITMW] : Endif

QTY_ORI=[M:ENT]QTYPCU(F) # lo que habia antes de modificar el Valor

Raz [F:ITMW]
Read [F:ITMW]ITM0=[M:ENT]ITMREF
FACTOR_ART=arr([F:ITMW]ZFACTOR,0.000001)
STU=[F:ITMW]STU


If STU="KG" and QTY_ORI<>PQTY
  LANCHO    = func SPESOH.MODIFICA_ANCHO_DIVISOR([M:ENT]ITMREF,[M:ENT]ZANCHO(F))
  LM2       = (LANCHO/1000)*[M:ENT]ZLONGITUD(F)*1  # siempre es 1 bobina
  If LM2=0
    FACTOR=1
  Else
    FACTOR=arr(PQTY/LM2,0.000001)
  Endif

  DIF=arr(FACTOR-FACTOR_ART,0.000001)
  DIF_POR=arr(DIF*100/FACTOR_ART,0.01)
  MSG+="En la linea "+num$(F+1)+"\hay una difª de "+num$(DIF)+" que es un "+num$(DIF_POR)+"%"
  MSG+="\respecto factor del articulo ("+num$(FACTOR_ART)+")\y el resultante ("+num$(FACTOR)+") de Kgs/M2 introducidos ("+num$([M:ENT]QTYSTU(F))+"/"+num$(int(LM2))+")"


  If abs(DIF_POR)>=DIF1
    mkstat = 2
    GMESSAGE = "IMPOSIBLE CONTINUAR\"+MSG
  Elsif abs(DIF_POR)>=DIF2
    Call OUINON("ESTA SEGURO DE CONTINUAR\"+MSG, YN) From GESECRAN
    If YN=1
      mkstat = 2
    Endif
  Endif
Endif

End
