#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZMSKU
# Description : Mantenimiento SKU.
# Module      : Datos base
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espańa
# Created date: 30/06/2022
############################################################################
Call UPD_SKU
End
################################################################
$ACTION

  Case ACTION
    When "OUVRE"            :Gosub OUVRE
    When "DEBUT"            :Gosub DEBUT
    When "OK"               :Gosub OK
    When "SEL_TABLE"        :Gosub SEL_TABLE
   When Default
  Endcase
Return

################################################################
$OUVRE
If !clalev([F:ZMSKU]) : Local File ZMSKU [ZMSKU] : Endif
Return

################################################################
$SEL_TABLE
Case TABLE
 When "SELSKU" : Gosub SELSKU
Endcase
Return
################################################################
$SELSKU
OBJET="ZSELSKU"

Return

################################################################

$OK
Delete [F:ZMSKU] Where [F:ZMSKU]ITMREF=[F:ITM]ITMREF
For I=0 To [M:ZMSKU]NBLIG-1
  Raz [F:ZMSKU]
  [F:ZMSKU]ITMREF=[F:ITM]ITMREF
  [F:ZMSKU]ANCHO=[M:ZMSKU]ANCHO(I)
  [F:ZMSKU]LONG=[M:ZMSKU]LONG(I)
  [F:ZMSKU]MANDRIL=[M:ZMSKU]MANDRIL(I)
  [F:ZMSKU]SKU=[M:ZMSKU]SKU(I)
  Write [F:ZMSKU]
Next
Return

$DEBUT
Raz [M:ZMSKU]
For [F:ZMSKU] Where [F:ZMSKU]ITMREF = [F:ITM]ITMREF
  I = [M:ZMSKU]NBLIG
  [M:ZMSKU]ITMREF(I)=[F:ITM]ITMREF
  [M:ZMSKU]ANCHO(I)=[F:ZMSKU]ANCHO
  [M:ZMSKU]LONG(I)=[F:ZMSKU]LONG
  [M:ZMSKU]MANDRIL(I)=[F:ZMSKU]MANDRIL
  [M:ZMSKU]SKU(I)=[F:ZMSKU]SKU
  [M:ZMSKU]NBLIG+=1
Next
Affzo [M:ZMSKU]
Return
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMSKU) 01/07/2022 02:22:38 (ADMIN)
######################################################################################
Subprog APRES_NBLIG
[M:ZMSKU]SKU(nolign-1) = format$("N0:4",val([M:ZMSKU]ITMREF(nolign-1)))+format$("N0:5",[M:ZMSKU]LONG(nolign-1))+format$("N0:4",[M:ZMSKU]ANCHO(nolign-1))+format$("N0:3",[M:ZMSKU]MANDRIL(nolign-1))
Affzo [M:ZMSKU]SKU(nolign-1)
End


######################################################################################

Subprog UPD_SKU()
If !clalev([F:ZMLONG]) : Local File ZMLONG [ZMLONG] : Endif
If !clalev([F:ZMSKU]) : Local File ZMSKU [ZMSKU] : Endif
If !clalev([F:ZSTJ]) : Local File STOJOU [ZSTJ] : Endif
If !clalev([F:ZITM]) : Local File ITMMASTER [ZITM] : Endif

Local Char WSQL_CMD(250)(1..4)

Raz WSQL_CMD
WSQL_CMD(1) ="select STJ.ITMREF_0,ZML.LONG_0,STJ.ZANCHO_0,STJ.ZMANDRIL_0 FROM [x3v12].[GLOBALMIG1].[STOJOU] STJ "
WSQL_CMD(2) ="left join [x3v12].[GLOBALMIG1].[ZMLONG] ZML on STJ.ITMREF_0= ZML.ITMREF_0 "
WSQL_CMD(3) ="where ZML.LONG_0 is not null and ZML.LONG_0 <> 0 and STJ.ZANCHO_0 <> 0 group by STJ.ITMREF_0,ZML.LONG_0,STJ.ZANCHO_0,STJ.ZMANDRIL_0 "
WSQL_CMD(4) = "order by ZML.LONG_0,STJ.ZANCHO_0,STJ.ZMANDRIL_0"

For (Char ITMREF,Integer LONG,Integer ZANCHO,Integer ZMANDRIL) From num$((GTYPDBA*2)+1)  Sql WSQL_CMD As [SQL_SKU]
  Raz [F:ZMSKU]
  [F:ZMSKU]ITMREF=[SQL_SKU]ITMREF
  [F:ZMSKU]ANCHO=[SQL_SKU]ZANCHO
  [F:ZMSKU]LONG=[SQL_SKU]LONG
  [F:ZMSKU]MANDRIL=[SQL_SKU]ZMANDRIL
  [F:ZMSKU]SKU = format$("N0:4",val([SQL_SKU]ITMREF))+format$("N0:5",[SQL_SKU]LONG)+format$("N0:4",[SQL_SKU]ZANCHO)+format$("N0:3",[SQL_SKU]ZMANDRIL)
  Write [F:ZMSKU]
Next

End
