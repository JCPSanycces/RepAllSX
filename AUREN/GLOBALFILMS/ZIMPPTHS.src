#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "VALID"        : Gosub VALID
  When "SAIMSK"       : Gosub SAIMSK
  When "RAZCRE"       : Gosub RAZCRE
  When "AP_IMPORT"    : Gosub AP_IMPORT
  When "IMP_FERME"    : Gosub IMP_FERME
  When Default
Endcase

Return

$AP_IMPORT
  If [F:STJ]ZMFGDATE <> [00/00/0000]
    GMFGDATE=vireblc(num$([F:STJ]ZMFGDATE),4) : GMFGDATE = mid$(GMFGDATE,7,4)+mid$(GMFGDATE,4,2)+mid$(GMFGDATE,1,2)
#    Infbox GMFGDATE
#    Infbox "entra ap_import"
  Endif
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
Global Char GMFGDATE(25)
  Gosub OUVRE From IMPPTHS
Return

##############################################################
$VALID
  Gosub VALID From IMPPTHS
Return

##############################################################
$SAIMSK
  Gosub SAIMSK From IMPPTHS
Return

##############################################################
$RAZCRE
  Gosub RAZCRE From IMPPTHS
Return

##############################################################
$IMP_FERME
  # relaciona la UT con la recepciˇn y la deja como RECEPCIONABLE
  [F:ZCNTR]PTHNUM   = [F:PTH]PTHNUM
  [M:ZCNTR0]PTHNUM  = [F:PTH]PTHNUM
  Rewrite [F:ZCNTR]
  Affzo [M:ZCNTR0]PTHNUM
  Call MESSAGE("Recepciˇn creada:"-[F:PTH]PTHNUM) From GESECRAN
Return

