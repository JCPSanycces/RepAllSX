#PE CALCREDIT -> Punto de entrada para no bloquear pedidos de Italia ni de Agencia.
$ACTION
Case ACTION
   When "CALCREDIT"  :  Gosub CALCREDIT
Endcase
Return

$CALCREDIT
If GFONCTION="GESSOH"
   If [M:SOH0]SALFCY="200" or [M:SOH0]SALFCY="901"
      CDTSTA=1
   Endif
Endif
Return
