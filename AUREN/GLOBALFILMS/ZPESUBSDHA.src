#<AdxTL>@(#)0.0.0.0 $Revision$
#Estos puntos de entrada actuan cuando se modifica la entrega
#MAJ_COLISAGE (SUBSDHA) -> Para calcular el volumen en funcion de campos especificos y el factor
#                          de conversion del transportista (el factor no debe influir)
#CALPORT -> PE para calcular el importe del porte
$ACTION

Case ACTION
    When "MAJ_COLISAGE"   :   Gosub MAJ_COLISAGE
    When "CALPORT"        :   Gosub CALPORT
Endcase
Return

$MAJ_COLISAGE
GPE=1
        Call COLISAGE_ORIGINE([F:SDH]STOFCY,4,[F:SDH]SDHNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
        If GOK = 0 | LRET <> 0
          GMESSAGE=mess(1,137,1) : Return
        Endif
        # réécriture entete livraison
        [F:SDH]PACFLG = LPACFLG
        [F:SDH]PACNBR = LPACNBR
        [F:SDH]NETWEI = LNETWEI
        [F:SDH]GROWEI = LGROWEI
        #[F:SDH]VOL    = LVOL
        LVOL=arr(LVOL/1000000,0.001)
        Raz [F:BPT]
        Read [F:BPT]BPT0=[F:SDH]BPTNUM
        If [F:BPT]COEWEIVOL<>0
           #[F:SDH]VOL=LVOL*[F:BPT]COEWEIVOL
        Endif
        If [F:SDH]VOU = ""
          [F:SDH]VOU = LVOU
        Endif
        Rewrite [SDH]

Return

$CALPORT
Local Char BPTAUX(15)(1..500)
Local Decimal LAMTFREAUX(1..500)
Local Decimal AMTOPT
Local Char BPTOPT(15)

Local Shortint I, J

#Raz [F:BPD]
#Read [BPD]BPD0=[M:SDH0]BPCORD;[M:SDH0]BPAADD
If [M:SDH2]BPTNUM=""
   #Si el clinete no tiene transportista asociado se busca el optimo
   If clalev([F:BPTX])<=0 : Local File BPCARRIER [F:BPTX] : Endif

   Raz BPTAUX
   Raz LAMTFREAUX
   Raz AMTOPT
   Raz BPTOPT
   I=0
   For [BPTX] Where ZFCYCAL=[M:SDH0]STOFCY
      Call TRANSPORT([F:BPTX]BPTNUM,[M:SDH0]BPCORD,[M:SDH0]STOFCY,WCRY,WCTY,WPOSCOD,
&                    [M:SDH1]CUR,[M:SDH0]CHGTYP,date$,[M:SDH1]DLVNOT,[M:SDH2]WEU,
&                    [M:SDH2]GROWEI,[M:SDH2]VOU,[M:SDH2]VOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                    From TRTPRICE
      If LAMTFRE<>0
         I+=1
         BPTAUX(I)=[F:BPTX]BPTNUM
         LAMTFREAUX(I)=LAMTFRE
      Endif
   Next
   If I>0
      For J=1 To I
         If J=1
            AMTOPT=LAMTFREAUX(J)
            BPTOPT=BPTAUX(J)
         Endif
         If LAMTFREAUX(J)<AMTOPT and LAMTFREAUX(J)<>0
            AMTOPT=LAMTFREAUX(J)
            BPTOPT=BPTAUX(J)
         Endif
      Next
      #WPOINT_ENTREEE = 1 para que no ejecute en el estandar la llamada al subprograma TRANSPORT
      #STAT=10 para que no ejecute en el estandar la asignacion del importe calculado al elemento de
      #facturacion "Portes". Se necesita tener definido este elemento de facturacion para que se
      #realice el calculo de los portes.
      STAT=10
      WPOINT_ENTREE = 1
      LAMTFRE=AMTOPT
      [M:SDH2]BPTNUM=BPTOPT
      [M:SDH2]ZIMPPORCAL=LAMTFRE
   Endif
Else
   #Si ya se tiene transportista indicado
   Call TRANSPORT([M:SDH2]BPTNUM,[M:SDH0]BPCORD,[M:SDH0]STOFCY,WCRY,WCTY,WPOSCOD,
&                 [M:SDH1]CUR,[M:SDH0]CHGTYP,date$,[M:SDH1]DLVNOT,[M:SDH2]WEU,
&                 [M:SDH2]GROWEI,[M:SDH2]VOU,[M:SDH2]VOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                 From TRTPRICE
   STAT=10
   WPOINT_ENTREE = 1
   [M:SDH2]ZIMPPORCAL=LAMTFRE
Endif

Return
