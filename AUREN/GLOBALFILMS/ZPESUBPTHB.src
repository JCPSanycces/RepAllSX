#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "XALIPTHPOH"  :   Gosub XALIPTHPOH
Endcase
Return

$XALIPTHPOH
# Comprobar que bobinas recepcionadas se corresponde con Cantidad recepcionada del standard
#[M:PTH1]ZQTYBOB   (NOL)=[F:POQ]ZQTYBOB-[F:POQ]ZRCPQTYBOB
#[M:PTH1]ZQTYBOBORI(NOL)=[M:PTH1]ZQTYBOB(NOL)
#[M:PTH1]NBSLO(NOL)  =[M:PTH1]ZQTYBOB(NOL)
#Call STKCTRNBSLO([M:PTH1]NBSLO(NOL), [M:PTH1]UOM(NOL), [M:PTH1]QTYUOM(NOL)) From STKACT
Gosub COMPROBAR_BOBINAS_RECEPCIONADAS
Return

$COMPROBAR_BOBINAS_RECEPCIONADAS
Local Decimal KGS_BOB
Local Decimal BOB_REC
KGS_BOB=arr([F:POQ]QTYSTU/[F:POQ]ZQTYBOB,0.00000001)
BOB_REC=arr([F:POQ]RCPQTYSTU/KGS_BOB,1)
[M:PTH1]ZQTYBOB   (NOL)=[F:POQ]ZQTYBOB-BOB_REC
[M:PTH1]ZQTYBOBORI(NOL)=[M:PTH1]ZQTYBOB(NOL)
If [F:POQ]ZRCPQTYBOB<>BOB_REC
#  Local Char    PED(GLONVCR)  :  PED=[F:POQ]POHNUM
#  Local Integer LIN           :  LIN=[F:POQ]POPLIN
#  Update [F:POQ] Where [F:POQ]POHNUM=PED and [F:POQ]POPLIN=LIN With [F:POQ]ZRCPQTYBOB=BOB_REC

 #> MA - si cantidad recepcionada es superior a la teórica, manda las bobinas de la línea de la recepción
  #[F:POQ]ZRCPQTYBOB=BOB_REC
  [F:POQ]ZRCPQTYBOB=[M:PTH1]ZQTYBOB(NOL)
 #< MA
  Rewrite [F:POQ]
  If fstat<>0
    Call ERREURT("AVISO!!!!\No se pudo actualizar lŞpedido con bobinas recepcionadas="+num$(BOB_REC)+"\"+PED+"-"+num$(LIN),1) From GESECRAN   #0-Informativo, 1-Error
  Endif
Endif
Return
