#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta SDE (Stock detallado)
$ACTION
Case ACTION
   When "FILTRE"   :   Gosub FILTRE
Endcase
Return

$FILTRE
If [M:SDE1]ZANCHODEB>0
   WFILSPE+="&[F:STO1]ZANCHO>="+num$([M:SDE1]ZANCHODEB)
Endif
If [M:SDE1]ZANCHOEND>0
   WFILSPE+="&[F:STO1]ZANCHO<="+num$([M:SDE1]ZANCHOEND)
Endif
If [M:SDE1]ZLONGITUDDEB>0
   WFILSPE+="&[F:STO1]ZLONGITUD>="+num$([M:SDE1]ZLONGITUDDEB)
Endif
If [M:SDE1]ZLONGITUDEND>0
   WFILSPE+="&[F:STO1]ZLONGITUD<="+num$([M:SDE1]ZLONGITUDEND)
Endif
Return
