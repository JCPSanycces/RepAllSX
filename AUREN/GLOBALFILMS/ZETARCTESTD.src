#<AdxTL>@(#)0.0.0.0 $Revision$
#Envio tarifas cliente por email
$ACTION

Case ACTION
   When "OUVRE"   : Gosub OUVRE
   When "TITRE"   : Gosub TITRE_S
   When "LECTURE" : Gosub LECTURE
   When "SETBOUT" : Gosub SETBOUT
   When "EXEBOUT" : Gosub EXEBOUT
Endcase

Return

$TITRE_S
TIT="Envio tarifas clientes << EN PRUEBAS # PDTE.VALIDAR >>"
Return


$OUVRE
# Declaración de variables
Local Char    CRITERE(250), AUXLNK(100)
Local Char    ININUM(GLONVCR), FINNUM(GLONVCR)
Local Integer ICRIT
Local Integer XX: XX=0

If !clalev([CNT]): Local File CONTACT    [CNT] : Endif
If !clalev([BPC]): Local File BPCUSTOMER [BPC] : Endif

# Valores por defecto
If [M:ZETC0]SALFCY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
   [M:ZETC0]SALFCY = GFCYDEF
Endif
Return


$LECTURE
#Chgfmt [M:ZETC0]ZNADA With "-"
    Gosub CHANGE_MSK From GCONSULT
    If CHGPAG<0 : NOL = MAXLIG : Endif
    If XX=0: XX=1: Return: Endif  ## 0605
    Gosub LOAD_FILTER

    # ------------------------------------------------------- #
    # CHGPAG = 1    :    Búsqueda                             #
    # ------ = 2    :    Siguiente                            #
    #        = 3    :    F5 (Actualización de página)         #
    # CHGPAG = -1   :    Último                               #
    # ------ = -2   :    Anterior (Page precedente)           #
    # ------------------------------------------------------- #

    If CHGPAG > 0
        SUITE=1
        If CHGPAG = 1
            RETOUR = 1
        Elsif CHGPAG = 2
            RETOUR = 2
        Endif

    Else
        RETOUR=1
        If CHGPAG = -1
            SUITE = 1
        Else
            SUITE = 2
        Endif
    Endif

    Link [ZTACH] With [BPC]BPC0=[F:ZTACH]BPCNUM As [LNK]
    Filter [LNK] Where evalue(CRITERE) Order By Key ZTACH0

    If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:ZETC1] : Endif

    For [LNK] With Nohint
        Gosub CARGA_ZETAC1
        If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
            Break
        Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
            Break
        Endif
    Next

Return

######################################################################################
$LOAD_FILTER
    Raz CRITERE, ICRIT

    CRITERE+="[F:ZTACH]SALFCY=[M:ZETC0]SALFCY & [F:BPC]BPCSTA=2 & [F:ZTACH]CREUSR=GUSER"
    # Autorización planta
    If GUSRFCY(1)<>"\" & ([M:ZETC0]SALFCY<>"") & GNBAUZ<>GNBSITE
       CRITERE+=" & find([M:ZETC0]SALFCY,GUSRFCY(1..GNBAUZ))"
    Endif

    # Terceros
#    If [M:ZETC0]BPCNUMSTR<>""
#       CRITERE+="&[F:ZTACH]BPCNUM>=[M:ZETC0]BPCNUMSTR"
#    Endif
#    If [M:ZETC0]BPCNUMEND<>""
#       CRITERE+="&[F:ZTACH]BPCNUM<=[M:ZETC0]BPCNUMEND"
#    Endif
#    If [M:ZETC0]REPNUMSTR<>""
#       CRITERE+="&[F:BPC]REP(0)>=[M:ZETC0]REPNUMSTR"
#    Endif
#    If [M:ZETC0]REPNUMEND<>""
#       CRITERE+="&[F:BPC]REP(0)<=[M:ZETC0]REPNUMEND"
#    Endif
#    If [M:ZETC0]TSCCOD0STR<>""
#       CRITERE+="&[F:BPC]TSCCOD(0)>=[M:ZETC0]TSCCOD0STR"
#    Endif
#    If [M:ZETC0]TSCCOD0END<>""
#       CRITERE+="&[F:BPC]TSCCOD(0)<=[M:ZETC0]TSCCOD0END"
#    Endif
#
#    Case CHGPAG
#        When 3 : # Actualización de página
#            AUXLNK=ININUM
#            CRITERE+='&[F:ZTACH]BPCNUM>="'+AUXLNK+'"'
#        When 2 : # Siguiente
#            AUXLNK=FINNUM
#            CRITERE+='&[F:ZTACH]BPCNUM>"'+AUXLNK+'"'
#        When -2 : # Anterior
#            AUXLNK=ININUM
#            CRITERE+='&[F:ZTACH]BPCNUM<"'+AUXLNK+'"'
#    Endcase
#    Infbox CRITERE
    If [M:ZETC0]NCTE>0
       CRITERE+="& find([F:ZTACH]BPCNUM,[M:ZETC0]BPCNUM)<>0"
    Endif
    If [M:ZETC0]NREP>0
       CRITERE+="& find([F:BPC]REP(0),[M:ZETC0]REP)<>0"
    Endif
    If [M:ZETC0]NTIP>0
       CRITERE+="& find([F:BPC]TSCCOD(0),[M:ZETC0]TSCCOD)<>0"
    Endif

Return

$CARGA_ZETAC1
    If NBLU = 1
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:ZETC1] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0
        If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
        NOL    += 1
        If NOL=0
            ININUM     = [F:ZTACH]BPCNUM
        Endif
        FINNUM     = [F:ZTACH]BPCNUM
    Else
        If NOL <= 0 : RETOUR=2 : Return : Endif
        NOL    -= 1
        If NOL=MAXLIG-1
            FINNUM     = [F:ZTACH]BPCNUM
        Endif
        ININUM     = [F:ZTACH]BPCNUM
    Endif

    nolign = NOL+1
    [M:ZETC1]=[F:ZTACH]
    [M:ZETC1]CTEMAIL(nolign-1)=func EMAIL_CTE([F:ZTACH]BPCNUM)
    [M:ZETC1]REPMAIL(nolign-1)=func EMAIL_REP_CTE([F:ZTACH]BPCNUM)
    [M:ZETC1]TARIFAS(nolign-1)=func HAY_TARIFAS([F:ZTACH]BPCNUM)
    #[M:ZETC1]ENVIO=2
Return

$SETBOUT
If [M]NBLIG=0
   Call VIREBOUT(CHAINE,"XY") From GOBJET
Endif
#JLPR 11-05-17 Se acuerda deshabilitar botón SELECCION ARTICULOS, pues incluimos una rejilla
Call VIREBOUT(CHAINE,"S") From GOBJET
Return

$EXEBOUT
Case BOUT
   When "X" Gosub TRT_ENVTAR
   When "Y" Gosub TRT_IMPTAR
Endcase
Return

$TRT_IMPTAR
Local Integer X, TOTENV, NBENV, INTERRUPT
Local Char    TBPAR(20)(1..6)  # 0205
Local Char    TBVAL(30)(1..6)  # 0205

TOTENV=0
NBENV=0
INTERRUPT=0

If [M:ZETC0]IMPRESORA=""
   Infbox "Impresora no indicada"
Endif

For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
      TOTENV+=1
   Endif
Next

Call OUVRE_BOITE("Envío tarifas a impresora",TOTENV) From GESECRAN : # Intégration données
Call SET_BOITE("",TOTENV) From GESECRAN

If [M:ZETC0]IMPRESORA<>""
   For X=0 To [M:ZETC1]NBLIG-1
      If [M:ZETC1]ENVIO(X)=2
         NBENV=NBENV+1
         TBPAR(1)="sitedeb"   : TBVAL(1) = [M:ZETC0]SALFCY
         TBPAR(2)="sitefin"   : TBVAL(2) = [M:ZETC0]SALFCY
         TBPAR(3)="clientdeb" : TBVAL(3) = [M:ZETC1]BPCNUM(X)
         TBPAR(4)="clientfin" : TBVAL(4) = [M:ZETC1]BPCNUM(X)
         TBPAR(5)="usr" : TBVAL(5) = GUSER
         TBPAR(6)="impselections" : TBVAL(6) = num$(1)
         #Call ETAT("ZCARTARIF","",TBPAR,TBVAL) From ETAT
         Call ETAT("ZCARTARIF",[M:ZETC0]IMPRESORA,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
         Call AFF_BOITE([M:ZETC1]BPCNUM(X),NBENV,INTERRUPT) From GESECRAN
      Endif

   Next
Endif
Call FERME_BOITE From GESECRAN
Infbox "Enviadas "-num$(NBENV)-" tarifas"
Return


$TRT_ENVTAR
Local Integer STAT, X, TOTENV, NBENV, INTERRUPT
Local Char NOMFICH(50), NOMFICH1(50)

If [M:ZETC1]ASUNTO=""
   Infbox "Asunto no indicado"
   Return
Endif

TOTENV=0
NBENV=0
INTERRUPT=0

For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
      TOTENV+=1
   Endif
Next

Call OUVRE_BOITE("Envío por mail de tarifas",TOTENV) From GESECRAN : # Intégration données
Call SET_BOITE("",TOTENV) From GESECRAN

For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
      NOMFICH1="TAR_"+[M:ZETC1]BPCNUM+"_"+format$("D:YYMMDD",date$)+"_"+GUSER
#      NOMFICH1="TAR"+[M:ZETC1]BPCNUM#+format$("D:YYMMDD",date$)+GUSER
      Call ENVTARIF([M:ZETC0]SALFCY,[M:ZETC1]BPCNUM(X),[M:ZETC1]ASUNTO,[M:ZETC1]TEXTO1,STAT,NOMFICH,NOMFICH1,[M:ZETC1]REPMAIL(X)) From ZETARCTESTD       ## Fichero en formato PDF
      #$ESPERA2  ##2604
      #If filinfo(filpath("ZTAR",NOMFICH1,"PDF"),7)<=0: Goto ESPERA2 : Endif ## 2604
      NBENV+=1
      Call AFF_BOITE([M:ZETC1]BPCNUM(X),NBENV,INTERRUPT) From GESECRAN
   Endif

Next

Call FERME_BOITE From GESECRAN
Infbox "Enviadas "-num$(NBENV)-" tarifas"
Return



Subprog ENVTARIF(SALFCY,NUMBPC,ASUNTO,TEXTO1,STAT,NOMFICH,FICHERO,REP_EMAIL)
Value Char    SALFCY()
Value Char    NUMBPC()
Value Char    ASUNTO()
Value Char    TEXTO1()
Value Integer STAT
Variable Char NOMFICH()
Value Char    FICHERO()
Value Char    REP_EMAIL


Local Char    TBPAR(20)(1..5)  # 0205
Local Char    TBVAL(30)(1..5)  # 0205
Global Char   GNUMCLI(20)
Global Char   GFICHERO(250)
Local Char INFORME(15)
Local Char VALCLI(250)
Local Shortint FUNCNT

Call PARCLI("ClientRootDir",VALCLI) From GLOBVAR
VALCLI+="rts\temp\"

GNUMCLI=NUMBPC

Read [BPC]BPC0=NUMBPC
NOMFICH=FICHERO+".PDF"

  Case GOS(1)
     When "unix"  : GFICHERO = filpath("ZTAR","","") + "/" + NOMFICH
     When Default : GFICHERO = filpath("ZTAR","","") + "\" + NOMFICH
  Endcase
 # GFICHERO=VALCLI+NOMFICH

TBPAR(1)="sitedeb"   : TBVAL(1) = SALFCY
TBPAR(2)="sitefin"   : TBVAL(2) = SALFCY
TBPAR(3)="clientdeb" : TBVAL(3) = NUMBPC
TBPAR(4)="clientfin" : TBVAL(4) = NUMBPC
TBPAR(5)="impselections" : TBVAL(5) = num$(1)
#Call ETAT("ZCARTARIFE","",TBPAR,TBVAL) From ETAT
Call ETAT("ZCARTARIFE","PDF",GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
#FUNCNT: 6 - Tarifas
FUNCNT=6
Call ENVMAIL(NUMBPC,FUNCNT,ASUNTO,TEXTO1,NOMFICH,REP_EMAIL)
#$ESPERA
#If filinfo(GFICHERO,0)<0: Sleep 4: Goto ESPERA: Endif
End

Subprog ENVMAIL(NUMBPR,FUNCNT,ASUNTO,TEXTO1,FICHADJ,REP_EMAIL)
Value Char NUMBPR()
Value Shortint FUNCNT
Value Char ASUNTO()
Value Char TEXTO1()
Value Char FICHADJ()
Value Char REP_EMAIL

Local Integer TYPMES
Local Integer REQREC
Local Integer REQIMP
Local Char    USER(15)
Local Char    MAIL(50)
Local Char    OBJJOI(10)
Local Char    CLEOBJ(80)
Local Char    CHRONO(25)
Local Integer ERD
Local Char    USR_EMAIL(50)(5)
Local Integer USR_ENVOI(5)
Local Integer USR_SUIVI(5)
Local Integer USR_NB
Local Clbfile TEXCLB(5)
Local Char    TEXOBJ(80)
Local Char    PCEJOI(200)(5)
Local Integer NBJOI
Local Char    TYPJOI(10)
Local Integer CATJOI
Local Char    CONTXT(50)

Filter [CNT] Where BPANUM=NUMBPR and BPATYP=1 and CNTFNC=FUNCNT
#Read [CNT]CNT0 First
#If fstat or [F:CNT]WEB="": Goto NEXT_BPC Endif

TYPMES=2 : #Servidor
USER=GUSER
Local Integer NB
Local Char WEMA(GLONMAI)(0..1)
Raz NB
For [CNT]
   If [F:CNT]WEB<>""
#      If GUSER="ADMIN"
#      USR_EMAIL(0)="pedro.torregrosa@grupoazeta.com"
#      USR_ENVOI(0)=2
#      USR_EMAIL(1)="joseluis.palau@grupoazeta.com"
#      USR_ENVOI(1)=2
#      USR_NB=2
#      Else
#      USR_EMAIL(0)=[F:CNT]WEB
#      USR_ENVOI(0)=2
##      USR_EMAIL(1)=func EMAIL_REP_CTE(NUMBPR)
##      USR_ENVOI(1)=2
#      USR_NB=1
#      Endif
      USR_EMAIL(NB)=[F:CNT]WEB
      USR_ENVOI(NB)=2
      NB+=1
      If REP_EMAIL<>""
        Call ARRAY(REP_EMAIL,";",WEMA) From ZCOMUN
        USR_EMAIL(NB)=WEMA(0)
        USR_ENVOI(NB)=2
        NB+=1
        If WEMA(1)<>""
          USR_EMAIL(NB)=WEMA(1)
          USR_ENVOI(NB)=2
          NB+=1
        Endif
      Endif
      USR_NB=NB

      Raz TEXOBJ
      TEXOBJ=ASUNTO

      Raz TEXCLB
      TEXCLB=[M:ZETC1]TEXTO1 #vireblc(TEXTO1,2)+chr$(13)+chr$(10)

      If GTYPMES=2
         Case GOS(1)
            When "unix"  : PCEJOI(0) = filpath("ZTAR","","") + "/" + FICHADJ
            When Default : PCEJOI(0) = filpath("ZTAR","","") + "\" + FICHADJ
         Endcase
      Else
         PCEJOI(0) = VALCLI + FICHADJ  ##2604
      Endif
      NBJOI=1
#      Infbox "ZETARCTESTD: "+USR_EMAIL(0) + " #  " + USR_EMAIL(1)
      If func ZCOMUN.FICHERO_OK(FICHADJ)
      Call ENVOI_MAIL(TYPMES,REQREC, REQIMP,USER,MAIL,OBJJOI,CLEOBJ,CHRONO,ERD
&                     ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                     ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT) From AWRKMEL
      Else
        Infbox "Fichero no enviado debido a error durante su impresion....Inténtelo de nuevo "+FICHADJ
      Endif
   Endif
Next
Filter [CNT]

#For YY=0 To 14
#   If [YFO]TEXTOMAIL(YY)<>""
#      TEXCLB+=evalue([YFO]TEXTOMAIL(YY))+chr$(13)+chr$(10)
#   Else
#      TEXCLB+=chr$(13)+chr$(10)
#   Endif
#Next YY

$NEXT_BPC
End

Subprog B1_NBLIG
#----------#
# Bouton 1 #
#----------#
Local Integer I
For I=0 To [M]NBLIG-1
 If [M]TARIFAS(I)=2
  [M]ENVIO(I) = 2
 Endif
Next I
Affzo [M]ENVIO
End

Subprog B2_NBLIG
#----------#
# Bouton 2 #
#----------#
Local Integer I
For I=0 To [M]NBLIG-1
 [M]ENVIO(I) = 1
Next I
Affzo [M]ENVIO
End

Funprog EMAIL_REP_CTE(CTE)
Value Char CTE
Local Char EMAIL(255)
Raz EMAIL
If !clalev([F:BPCW]): Local File BPCUSTOMER [F:BPCW] : Endif
If !clalev([F:BPAW]): Local File BPADDRESS  [F:BPAW] : Endif
Filter [F:BPCW] Where BPCNUM=CTE
For [F:BPCW]
  Filter [F:BPAW] Where BPANUM=[F:BPCW]REP(0) and [F:BPAW]BPAADDFLG=2
  For [F:BPAW]
    EMAIL=[F:BPAW]WEB(0)
    If [F:BPAW]WEB(1)<>""
      EMAIL+=";"+[F:BPAW]WEB(1)
    Endif
    Break 2
  Next
Next
Filter [F:BPCW]
Filter [F:BPAW]
End EMAIL


Funprog EMAIL_CTE(CTE)
Value Char CTE
Local Char EMAIL(GLONMAI)
#If !clalev([F:BPC]): Local File BPCUSTOMER [F:BPC] : Endif
If !clalev([F:CNT]): Local File CONTACT    [F:CNT] : Endif
Raz EMAIL
#Link [BPC] With  [CNT]CNT0(2)=[BPC]BPCNUM As [LNK]
#Filter [LNK] Where [F:BPC]BPCNUM=CTE and [F:CNT]BPATYP=1 and [F:CNT]CNTFNC=6
Filter [F:CNT] Where BPANUM=CTE and BPATYP=1 and CNTFNC=6
For [F:CNT]
  EMAIL=[F:CNT]WEB
Next
Filter [F:CNT]
End EMAIL

Funprog HAY_TARIFAS(CTE)
Value Char CTE
Local Integer SN  : SN=1
If clalev([F:ZTACD])<=0 : Local File ZTARCTED    [F:ZTACD] : Endif  : #Detalle
Filter [F:ZTACD] Where [F:ZTACD]SALFCY=[M:ZETC0]SALFCY and [F:ZTACD]BPCNUM=CTE
If rowcount([F:ZTACD])>0
  SN=2
Endif
Filter [F:ZTACD]
End SN


Subprog AM_ENVIO(VALEUR)
Variable Integer VALEUR
Local Integer YN   :  YN=1  # Por defecto NO
Local Char MSG(255)
Raz MSG
If VALEUR=2
    If [M:ZETC1]TARIFAS(nolign-1)<2
      MSG="Imposible marcar cliente, pues no tiene tarifas\Recuerde que estas se generan desde opcion\VENTAS#Tarifas#Generación tarifas clientes"
      Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
      VALEUR=1
    Else
      If [M:ZETC1]CTEMAIL(nolign-1)=""
        MSG+="\Cliente, al no tener este un contacto con <Funcion=Tarifas> y una direccion de email"
      Endif
      If [M:ZETC1]REPMAIL(nolign-1)=""
        MSG+="\Representante al no tener éste indicado una direccion de email"
      Endif
      If MSG<>""
        MSG="Observe que NO se enviará email al"+MSG
        Call OUINON("ESTA SEGURO DE CONTINUAR\.\"+MSG, YN) From GESECRAN
        If YN=1
          VALEUR=1
        Endif
      Endif
    Endif
Endif
End
