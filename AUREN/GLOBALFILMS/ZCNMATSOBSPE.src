Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""    : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
End

Subprog AM_ANCHODEB(VALEUR)
Variable Decimal VALEUR
If [M]ANCHOEND = 0     : [M]ANCHOEND = VALEUR : Affzo [M]ANCHOEND : Endif
If [M]ANCHOEND < VALEUR : [M]ANCHOEND = VALEUR : Affzo [M]ANCHOEND : Endif
End

Subprog AM_LONGITUDDEB(VALEUR)
Variable Decimal VALEUR
If [M]LONGITUDEND = 0     : [M]LONGITUDEND = VALEUR : Affzo [M]LONGITUDEND : Endif
If [M]LONGITUDEND < VALEUR : [M]LONGITUDEND = VALEUR : Affzo [M]LONGITUDEND : Endif
End
