#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog COMBINAR_3(TOPEJ,TOPE_DIF,RPDTE)
Value Integer TOPEJ,TOPE_DIF
Variable Integer RPDTE
# En este planateamineto, montamos OPCIONES POSIBLES, en lugar de combinaciones
#
##############################################################################################
##    Evaluar posibilidad de:
##    Paso 1ŗ   Ordenar por nŗ repeticiones + Ancho
##    Paso 2ŗ   Con el fin de hacer el mayor nŗ de tiradas iguales
##              Ańadir repeticiones para ver de llegar al mismo nŗ  Ej  6x200 + 6x300 + 5x500...ańadimos una de 500, para hacer 5 tiradas
##    Paso 3ŗ   Combinar los anchos que tengan el mismo nŗ de repeticiones
##              Tener en cuenta que podemos repetir anchos en caso de que el nŗ de repet.sean multiplo...Ej 6x.... = 1x6 ó 2x3 ó 3x2
##              Proponer Anchos A en caso de superar el desperdicio mįximo permitido
##############################################################################################


Local Integer TOPE    # Ancho jumbo - Merma mķnima
Local Integer TELE    # Total bobinas a fabricar
Local Integer TANC    # Total ancho combinación en curso
Local Integer NPOS    # Posicion 1er elemento
Local Integer NORD    # Posicion comienzo para integrar con NPOS
Local Integer NELE    # Elemento a integrar en combinación, a partir de NORD
Local Integer ELEP    # Ancho a integrar
Local Char COMB(255)  # Combinacion pedidos en curso
Local Char COMBA(255) # Combinacion stock   en curso
Local Char CMP(255)(100)# Combinaciones originales de pedidos.......Mįximo de 100 x cįlculo
Local Char CMF(255)(100)# Combinaciones finales    pedidos+stock
Local Char CMS(255)(100)# Combinaciones finales    solo stock, para asegurarnos de que solo se repite una vez los mismos anchos de stock
Local Integer CMO(100)  # Combinaciones originales de pedidos
#                             0=OK
#                             1=No cogerla, pues son todos para stock, al no quedar pedidos
#                             2=No cogerla, en caso de que se repitan los anchos de stock
Local Integer FE,F0,FIN,PDTES_B
Local Char PDTES_D(255)
 # Para controlar si entramos en un bucle sin fin
Local Char BCMB(255),BCMBA(255)
Raz BCMB,BCMBA,RPDTE

If clalev( [M:ZGOFSX])  = 0 : Local Mask  ZGOFS2       [M:ZGOFSX]  : Endif

Onerrgo ERRORES_FIN
TOPE=TOPEJ-[M:ZGOFS2]SMERMA
TELE=[M:ZGOFS2]NELE-1

# Realizar todas las posibles combinaciones, teniendo en cuenta que:
#      - No pueden superar el desperdicio mįximo permitido
#      - Completar con anchos A el trozo sobrante, pero SIN sustituir
# Montar posibles soluciones en base a las combinacinoes anteriores y pasar las que cumplan:
#      - Incluir todos los elementos
#      - Su desperdicio sea menor y a igual desperdicio el que genere menor nŗ de trozos
Raz NORD,CMP,CMF,CMO,CMS,FIN
For FE=0 To TELE
  NORD=FE+1  # habrį tantas combinaciones como bobinas a fabricar
  Call QUITAR_MARCAS(0) From SPEZGOFS1
  Raz COMB,TANC,COMBA
  While func SPEZGOFSB.HAY_PDTES(FE,PDTES_D)>0
    For F0=FE To TELE
      If [M:ZGOFS2]ASIGNADA(F0)=0
        ELEO=[M:ZGOFS2]ANCHO(F0)
        If TANC+ELEO>TOPE
          Gosub COMBINAR_GUARDAR_COMBI_3
#          Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
        Endif
        Call COMBINAR_2_ACUMULAR(F0,TANC,COMB) From SPEZGOFSB
      Endif
    Next
    If RPDTE=-1
      Break 2
    Endif
  Wend
Next
Onerrgo
End

$COMBINAR_GUARDAR_COMBI_3
# Definición variables copiada de SPEZGOFSB.src  $COMBINAR_GUARDAR_COMBI_2
Local Integer A0,A1,A2,A3,A4
Local Integer ANC(50),ANCR(50),NA
Local Integer RANC(50),RREP(50),RDIF(50)
Local Integer DIF_ANC
Local Integer OK_STOCK,OK_CMBX
Local Decimal DIF_OPC,DIF_MENOR
Local Integer F,SOLO_A
Local Char RCOMB(255),RCOMBA(255) # Para guardarmelas
Local Char CMBX(255)
# Estamos realizando todas las posibles combinaciones de los elementos
# No sustituimos pedidos....solo vemo de completar con stock los trozos sobrantes
DIF_ANC=TOPE-TANC
If DIF_ANC >0
  Gosub COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A From SPEZGOFSB
  Gosub COMBINAR_AJUSTAR_CON_ANCHOS_A From SPEZGOFSB
  If COMBA<>"" and  ((DIF_ANC>TOPE_DIF and [M:ZGOFS2]SMINSTK=2) or  (DIF_ANC>0 and [M:ZGOFS2]SMINRES=2))
    SOLO_A=1
    Call ECR_TRACE("Veo si es posible buscar una combinacion mas optima para el stock "+COMBA,0)   From GESECRAN
    RCOMB =COMB  :  RCOMBA=COMBA
    COMB  =COMBA :  COMBA=""
    Gosub COMBINAR_AJUSTAR_CON_ANCHOS_A From SPEZGOFSB
    If COMB<>"" and COMBA<>""
      COMBA=COMB+"-"+COMBA
    Else
      COMBA=COMB+COMBA
    Endif
    COMB=RCOMB
    TANC=func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMB,COMBA,5)
    DIF_ANC=TOPE-TANC
    Call ECR_TRACE("Resultado de ver si es posible buscar una combinacion mas optima para el stock "+COMBA,0)   From GESECRAN
  Endif
Endif
If COMB<>""
  F=[M:ZGOFS2]NCOM
  [M:ZGOFS2]CANCHOJ(F)= TOPEJ
  [M:ZGOFS2]POS(F)    = NPOS
  [M:ZGOFS2]ORD(F)    = NORD
  [M:ZGOFS2]COMBI(F)  = COMB
  [M:ZGOFS2]COMBA(F)  = COMBA
  [M:ZGOFS2]CANCHO(F) = func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMB,COMBA,5)
  [M:ZGOFS2]CDIF(F)   = TOPE-[M:ZGOFS2]CANCHO(F)
  [M:ZGOFS2]CNUM(F)   = F+1
  [M:ZGOFS2]CANCHOA(F)= func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMBA,"",5)
  [M:ZGOFS2]NCOM+=1
  If [M:ZGOFS2]NCOM>=8000
    Infbox "Se ha superado el limite de combinaciones posibles ([M:ZGOFS2]NCOM>=8000)"
  Endif
  Call ECR_TRACE("Combinación hecha nŗ " + num$(F+1) + "     Tope-Ancho=DifŖ  (" + num$(TOPE)+"-"+num$([M:ZGOFS2]CANCHO(F))+"="+num$([M:ZGOFS2]CDIF(F))+")" ,0)   From GESECRAN
  Call ECR_TRACE("Pedidos=" + COMB + "   Stock="+COMBA,0)   From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#    If F+1=36
#      Infbox "Depurar"
#    Endif
  #Marcar bobinas como incluidas
  Call QUITAR_MARCAS (NORD) From SPEZGOFS1
Endif

# Controlar que no entramos en un bucle sin fin
PDTES_B=func HAY_PDTES(0,PDTES_D)
Call ECR_TRACE("Anterior Bobinas pdtes="+num$(RPDTE) + "   Ped="+BCMB +"   Stock="+BCMBA ,0)   From GESECRAN
Call ECR_TRACE("Actual   Bobinas pdtes="+num$(PDTES_B)+"   Ped="+COMB +"   Stock="+COMBA ,0)   From GESECRAN
If BCMB=""
  BCMB=COMB
  BCMBA=COMBA
  RPDTE=PDTES_B
Elsif BCMB=COMB and BCMBA=COMBA and RPDTE=PDTES_B
    Call ECR_TRACE("Hemos entrado en un bucle sin fin     RCOMB=COMB and RCOMBA=COMBA and RPDTE=PDTES_B " ,0)   From GESECRAN
    RPDTE=-1
Else
  BCMB=COMB
  BCMBA=COMBA
  RPDTE=PDTES_B
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Raz COMB,TANC,COMBA
Return


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End
