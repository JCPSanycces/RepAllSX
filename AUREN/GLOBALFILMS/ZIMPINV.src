#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
    Case ACTION
        When "OUVRE" : Gosub OUVRE
        When "EXEC" : Gosub EXEC
        When "OK"   : Gosub OK
        When "SORTIE"  : Gosub FIN
        When "CONTROLE" : Gosub CONTROLE
        When Default
    Endcase
Return

$OUVRE

    Global Char WNOM(250)
    Global Integer WEXE

    WEXE = 0

    If !clalev([F:ZINV]) : Local File ZINVE [ZINV] : Endif



Return

$FIN
    TRA=1
    Kill WNOM
    Kill WEXE
Return

$ABRIR
    If !clalev([F:ZINV]) : Local File ZINVE [ZINV] : Endif
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
    If !clalev([F:STO]) : Local File STOCK [STO] : Endif
    If !clalev([F:STA]) : Local File STOALL [STA] : Endif
    If !clalev([F:STC]) : Local File STOLOC [STC] : Endif

   # Local Mask ZIMPINV [ZII0]


    Local Char A(250)(1..110)
    Local Char TIPOUBI(20)
    Local Char NUMENT(25)
    Local Integer WLINEA
    Local Integer WGERROR   #ERROR Global
    Local Integer WERROR    #ERROR DE RECUPERACION
    #Separadores de campo
    adxifs=";"
    adxirs=chr$(13)+chr$(10)
    adxium=50 # ASCII

Return

$OK
    WEXE = 1
    WNOM = [M:ZSF]NOMFIC(0)
Return


$CONTROLE
    TMP = 1
    TIT = "Importación en curso"
Return

$CERRAR

 Close File [ZINV]

Return


$EXEC

    If WEXE = 1
        Gosub ABRIR



     Call OUVRE_TRACE("Importación de Inventario ") From LECFIC
     Call ECR_TRACE(" Importación de Inventario ",0) From GESECRAN


        #WNOM = mid$(WNOM,7,len(WNOM))


         # WNOM = filpath("BQT",WNOM,"")
         WNOM = "E:\Sage\X3V8\folders\GLOBAL\BQT\"+WNOM
         Openi WNOM Using [TIE]
         Trbegin [ZINV]

         Delete  [ZINV] Where 1=1

         WLINEA=0
         WGERROR = 0
         WERROR = 0
         Gosub LEER_REGISTRO
         Gosub LEER_REGISTRO
         While !fstat
             Gosub IMPORTAR
             If WGERROR Then
                Break
             Endif
             WLINEA+=1
             Gosub LEER_REGISTRO
         Wend

         If WGERROR = 0
             Commit
            # Gosub CALCULAR_IMPORTES
             Call ECR_TRACE(num$(WLINEA)+ " Lineas Procesadas ",0) From GESECRAN
         Else
             Rollback
              Call ECR_TRACE( "Error en la Importacion",0) From GESECRAN
         Endif

         Openi Using [TIE]
         Gosub CERRAR

        Call ECR_TRACE(" Finaliza la importación de Inventario ",0) From GESECRAN
        Call FERME_TRACE From LECFIC
        TRA = 1

    Endif
Return

$IMPORTAR
    Local Char WPLANTA(10)
    Local Char WARTICULO(20)
    Local Char WLOTE(20)
    Local Char WLOTEORI(20)
    Local Char WMANDRILC(20)
    Local Integer WMANDRIL
    Local Char WUBICACION(20)
    Local Integer WANCHO
    Local Decimal WLONGITUD
    Local Integer WCONT
    Local Integer WXLSBOB, WXLSBOBN, WXLSBOBRSV, WXLSBOBRSVN
    Local Decimal WXLSCTD, WXLSCTDN, WXLSCTDASIG, WXLSCTDASIGN
    Local Char WMENSAJE(250)
    Local Char WPROCESADO(1): # N-Pendiente / E-rror / S-Terminado
    Local Char WACCION(2)   : # EN-trada / SA-lida  / EA-Eror Articulo / ES - Error Salida / ER - Error / OK
    Local Integer WX3BOB , WX3BOBASI
    Local Decimal WX3QTY , WX3QTYASI
    Local Integer WDIF
    Local Char WIDEXCEL(10)
    Local Decimal WPRECOS

    WERROR = 0 #INICILAIZAMOS EL ERROR A 0
    # BUSCAR Registro clave unica para incrementar contador
    WFACTOR=0
    WPLANTA="100"
    WIDEXCEL=vireblc(A(1),2)
    WARTICULO=vireblc(A(4),2)
    WLOTE=vireblc(A(8),2)
    WLOTEORI=vireblc(A(10),2)
    WUBICACION=left$(vireblc(A(3),2),8)
    WANCHO=val(vireblc(A(6),2))
    WLONGITUD=val(ctrans(ctrans(vireblc(A(12),2),".",""),",","."))
    WMANDRILC=vireblc(A(14),2)
    WMANDRIL=val(WMANDRILC)
    If WMANDRIL=0 Then
      If  pat(WMANDRILC,"*152*") Then
       WMANDRIL=152
      Elsif  pat(WMANDRILC,"*60*") Then
        WMANDRIL=60
      Else
        WMANDRIL=76
      Endif
    Endif

    WLONGITUDN=val(ctrans(ctrans(vireblc(A(12),2),".",""),",","."))
    WXLSBOB=val(vireblc(A(15),2))
    WXLSBOBN=val(vireblc(A(16),2))
    WXLSBOBRSV=val(vireblc(A(17),2))
    WXLSBOBRSVN=val(vireblc(A(18),2))
    WXLSCTD=val(ctrans(ctrans(vireblc(A(19),2),".",""),",","."))

    Raz [F:ZINV]
    Filter [F:ZINV] Where PLANTA=WPLANTA & ARTICULO=WARTICULO &
&                         LOTE=WLOTE & UBICACION=WUBICACION & ANCHO=WANCHO & LONGITUD=WLONGITUD &
&                         MANDRIL=WMANDRIL
# & LOTEORI=WLOTEORI
    Read [F:ZINV]ZINVE0 Last
    If fstat=0
       WCONT=[F:ZINV]CONT+1
       WFACTOR=[F:ZINV]FACTOR
    Else
       WCONT=1
    Endif
    Filter [F:ZINV]

    WMENSAJE=""
    WACCION=""
    WPROCESADO="N"
    WX3BOB = 0
    WX3BOBASI = 0
    WX3QTY = 0
    WX3QTYASI = 0
    Gosub BUSCAR_DATOSX3
    If [F:STC]LOC="" Then
       WACCION="EU"
       WMENSAJE="UBICACION no existe:" - WUBICACION
       WPROCESADO="E"
       Goto IMPORTAR_GRABAR
    Endif

    If [F:ITM]ITMREF="" Then
       WACCION="EA"
       WMENSAJE="Articulo no existe:" - WARTICULO
       WPROCESADO="E"
       Goto IMPORTAR_GRABAR
    Endif

    # Si no hay diferencias en el fichero No procesar
  #  WDIF = (WXLSBOB+WXLSBOBRSV) - (WXLSBOBN+WXLSBOBRSVN)
#    WDIF = (WXLSBOB+WXLSBOBRSV) - (WXLSBOBN+WXLSBOBRSVN)
#    If WDIF = 0
#       WACCION="OK"
#       WPROCESADO="S"
#       Goto IMPORTAR_GRABAR
#    Endif
#
 #   WDIF = (WX3BOB+WX3BOBASI) - (WXLSBOBN+WXLSBOBRSVN)
    WDIF = (WXLSBOB+WXLSBOBRSV) - (WXLSBOBN+WXLSBOBRSVN)
    If WDIF = 0
       WACCION="OK"
       WPROCESADO="S"
       Goto IMPORTAR_GRABAR
    Endif




    # Si stock Total descuadra en X3 con respecto al Stock origen de la Excel ==> ERROR
#    If (WX3BOB+WX3BOBASI)<>(WXLSBOB+WXLSBOBRSV) Then
#       WACCION="ER"
#       WMENSAJE="Stock Incorrecto: art:" - WARTICULO - "Lote: " - WLOTE - "An: " - num$(WANCHO) - "Lon: " - num$(WLONGITUD)
#&                   - "Man:" - num$(MANDRIL) - "L. Ori:" - WLOTEORI - "Bob Excel:" - num$(WXLSBOB+WXLSBOBRSV) - "Bob X3:" - num$(WX3BOB) - "ID EXCEL:" - WIDEXCEL
#       WPROCESADO="E"
#       Goto IMPORTAR_GRABAR
#    Endif






    #WXLSDIFRSV = (WXLSBOBRSV) - (WXLSBOBRSVN)
    WXLSDIFRSV = (WX3BOBASI+WX3BOB) - (WXLSBOBN+WXLSBOBRSVN)
    WXLSDIFRSV = (WXLSBOB+WXLSBOBRSV) - (WXLSBOBN+WXLSBOBRSVN)
    # Si hay diferencias en el stock reservado ==> Error
    If WXLSDIFRSV>0 & (WX3BOBASI>0) & WXLSDIFRSV>WX3BOB
       WACCION="EA"
       WMENSAJE="Stock Reservado X3: art:" - WARTICULO - "Lote: " - WLOTE - "An: " - num$(WANCHO) - "Lon: " - num$(WLONGITUD)
&                   - "Man:" - num$(MANDRIL) - "L. Ori:" - WLOTEORI - "Bob. Salida:" - num$(WXLSDIFRSV) - "Bob Rsv x3:" - num$(WX3BOBASI) - "ID EXCEL:" - WIDEXCEL
       WPROCESADO="E"
       Goto IMPORTAR_GRABAR
    Endif


   # WXLSDIF = (WXLSBOB) - (WXLSBOBN)
    #WXLSDIF = (WX3BOBASI+WX3BOB) - (WXLSBOBN+WXLSBOBRSVN)
    WXLSDIF = (WXLSBOB+WXLSBOBRSV) - (WXLSBOBN+WXLSBOBRSVN)

    If WXLSDIF < 0 # Si tengo menos bobinas que las contadas => EN-trada
       WACCION="EN"
       Goto IMPORTAR_GRABAR
    Endif

    If WXLSDIF > 0 # Si tengo mas bobinas que las contadas => SA-lida
       WACCION="SA"
       If WXLSDIF>(WX3BOBASI+WX3BOB)
          WACCION="ES"
          WMENSAJE="Stock Insuficiente " - "Art:" - WARTICULO - "Lote: " - WLOTE - "An: " - num$(WANCHO) - "Lon: " - num$(WLONGITUD)
&                   - "Man:" - num$(MANDRIL) - "L. Ori:" - WLOTEORI - "Bob Sal:" - num$(WXLSDIF) - "Bob Stock:" - num$(WX3BOB) - "ID EXCEL:" - WIDEXCEL
          WPROCESADO="E"
       Endif
       Goto IMPORTAR_GRABAR
    Endif
    WACCION="OK"
    WPROCESADO="S"





$IMPORTAR_GRABAR
    [F:ZINV]PLANTA=WPLANTA
    [F:ZINV]ARTICULO=WARTICULO
    [F:ZINV]LOTE=WLOTE
    [F:ZINV]UBICACION=WUBICACION
    [F:ZINV]ANCHO=WANCHO
    [F:ZINV]LONGITUD=WLONGITUD
    [F:ZINV]MANDRIL=WMANDRIL
    [F:ZINV]LOTEORI=WLOTEORI
    [F:ZINV]LONGITUDN=WLONGITUDN
    [F:ZINV]CONT=WCONT
    [F:ZINV]FACTOR=WFACTOR

    [F:ZINV]BOBINAS=WXLSBOB
    [F:ZINV]BOBINASN=WXLSBOBN
    [F:ZINV]BOBINASASIG=WXLSBOBRSV
    [F:ZINV]BOBINASASIGN=WXLSBOBRSVN

    [F:ZINV]CANTIDAD=WXLSCTD
    [F:ZINV]CANTIDADN=arr((WXLSBOBN * WLONGITUD *  (WANCHO / 1000) * WFACTOR),0.001)
    [F:ZINV]CANTIDADASIG=arr((WXLSBOBRSVN * WLONGITUD *  (WANCHO / 1000) * WFACTOR),0.001)

    [F:ZINV]BOBX3=WX3BOB
    [F:ZINV]BOBX3ASI=WX3BOBASI
    [F:ZINV]QTYX3=WX3QTY
    [F:ZINV]QTYX3ASI=WX3QTYASI

    [F:ZINV]PRECOS=WPRECOS
    [F:ZINV]MENSAJE=WMENSAJE
    [F:ZINV]ACCION=WACCION
    [F:ZINV]PROCESADO=WPROCESADO
    [F:ZINV]IDEXCEL=WIDEXCEL

    Write [F:ZINV]
    If fstat<>0 Then
       WGERROR = 1
       Return
    Endif
    If WPROCESADO="E"
       Call ECR_TRACE(WMENSAJE,0) From GESECRAN
    Endif

Return


$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return


$BUSCAR_DATOSX3
Local Integer WFOUND
Raz [F:STC]
Read [F:STC]STC0=WPLANTA;WUBICACION
If fstat Then
   # Return
Endif

Raz [F:ITM]
Read [F:ITM]ITM0=WARTICULO
If fstat Then
    #Return
Endif

If WFACTOR=0

   WFACTOR=[F:ITM]ZFACTOR
Endif
If WCONT =1
Raz [F:STO]
Filter [F:STO] Where STOFCY=WPLANTA & ITMREF=WARTICULO & LOT=WLOTE & LOC=WUBICACION &
&                    ZANCHO=WANCHO & ZLONGITUD=WLONGITUD & ZMANDRIL=WMANDRIL
# & ZLOTORI=WLOTEORI

For [F:STO]

 Raz [F:STA]
  Filter [F:STA] Where STOFCY=[F:STO]STOFCY & ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU
  WFOUND=1
  For [F:STA]
     WFOUND=2
     Break
  Next
   Filter [F:STA]


 #  If [F:STO]CUMALLQTY <> 0
  If WFOUND=2 Then
      WX3BOBASI+=1
      WX3QTYASI+=[F:STO]CUMALLQTY
  Else
      WX3BOB+=1
      WX3QTY+=[F:STO]QTYSTU
  Endif
  WFACTOR=[F:STO]ZFACTOR
Next
Filter [F:STO]
Endif

WPRECOS=func PRECOS(WPLANTA,WARTICULO,WLOTE,WANCHO,WLONGITUD,WMANDRIL)
#Infbox "PRECIO COSTE" - num$(WPRECOS)

Return



Funprog PRECOS(WPLANTA,WARTICULO,WLOTE,WANCHO,WLONGITUD,WMANDRIL)
Value Char WPLANTA
Value Char WARTICULO
Value Char WLOTE
Value Integer WANCHO
Value Decimal WLONGITUD
Value Integer WMANDRIL


Local Decimal WPRECOS
Local Integer WLONG
WLONG=WLONGITUD

If !clalev([F:XSTJ]) : Local File STOJOU [XSTJ] : Endif
If !clalev([F:XITV]) : Local File ITMMVT [XITV] : Endif

   Raz [F:XITV]
   Read [F:XITV]ITV0=WARTICULO;WPLANTA
   If !fstat Then
        WPRECOS=[F:XITV]AVC
   Else
       WPRECOS=0
   Endif
#If 1<>1 Then
#   Raz [F:XSTJ]
#   Filter [F:XSTJ] Where STOFCY=WPLANTA & ITMREF=WARTICULO & LOT=WLOTE & ZANCHO=WANCHO & ZLONGITUD=WLONG
#   &                     & ZMANDRIL=WMANDRIL & PRIREGFLG=1 & PRIVAL<>0
#
#Read [F:XSTJ]STJ4 First
#If fstat Then
#   Raz [F:XITV]
#   Read [F:XITV]ITV0=WARTICULO;WPLANTA
#   If !fstat Then
#        WPRECOS=[F:XITV]AVC
#   Else
#       WPRECOS=0
#   Endif
#Else
#   WPRECOS=[F:XSTJ]PRIVAL
#Endif
#Endif
End WPRECOS
