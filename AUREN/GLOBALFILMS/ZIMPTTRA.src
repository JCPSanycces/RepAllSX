#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para la importacion de tarifas del trasnportista indicado por el usuario en pantalla.
#El fichero debe tener una linea de cabecera indicando el peso (a partir de la cuarta columna) y
#tantas lineas como areas con el importe segun peso.
#Las tres primeras columnas indican el area, el pais y el codigo postal

$ACTION
#Infbox ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "OK"          : Gosub OK
  When Default
Endcase
Return

$CONTROLE
TMP = 1
TIT = "Importación en curso"
Return

$OUVRE
Global Char WNOMFIC(250)
Global Char WSTOFCY(10)
Global Char WBPTNUM(15)
Global Integer WEXE
Local Char TIT(80)

WEXE = 0
WBPTNUM = ""
WSTOFCY = ""
TIT = "Importacion tarifas transportista"
Return

$INIT
Local Mask ZSELFICTTRA [M:ZSTTRA]

Raz [M:ZSTTRA]
[M:ZSTTRA]STOFCY=GFCYDEF(3)
Return

$DEBUT
Affzo [M:ZSTTRA]5
Return

$OK
WEXE = 1
WSTOFCY = [M:ZSTTRA]STOFCY
WNOMFIC = [M:ZSTTRA]NOMFIC(0)
WBPTNUM = [M:ZSTTRA]BPTNUM
Return

$EXEC
If WEXE=1
   Gosub PROCESA
Endif
Return

$PROCESA
Local Char A(30)(1..150)
Local Decimal RANPES(150)
Local Char WOUT(250)
Local Char WJOB(10)

Local Integer WOK
Local Integer NBRPES, WORDARE
Local Integer LINNUM
Local Char AREAUX(5)

If clalev([ZTTRH])<=0  : Local File ZTARTRAH   [ZTTRH]   : Endif
If clalev([ZTTRD])<=0  : Local File ZTARTRAD   [ZTTRD]   : Endif
If clalev([BPT])<=0    : Local File BPCARRIER  [BPT]     : Endif
If clalev([CAA])<=0    : Local File CARAREA    [CAA]     : Endif
If clalev([CAP])<=0    : Local File CARPRICE   [CAP]     : Endif

Call OUVRE_TRACE("Importación de tarifas transportistas ") From LECFIC
Call ECR_TRACE(" Importación de tarifas transportista: "+WBPTNUM+" Planta: "+WSTOFCY,0) From GESECRAN

Call ECR_TRACE(" Inicio importación tarifas trasnportista ",0) From GESECRAN

#Borrado e insercion en tablas auxiliares de transportistas
WOK=1
Delete [ZTTRH] Where 1=1
If fstat
   Call ECR_TRACE("   Error borrando cabecera [ZTTRH] - fstat: "+num$(fstat),1) From GESECRAN
   WOK=0
   Goto FIN
Endif
Delete [ZTTRD] Where 1=1
If fstat
   Call ECR_TRACE("   Error borrando lineas [ZTTRD] - fstat: "+num$(fstat),1) From GESECRAN
   WOK=0
   Goto FIN
Endif

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

#lectura de fichero

WNOMFIC = mid$(WNOMFIC,7,len(WNOMFIC))
WNOMFIC = filpath("BQT","","") +"\" +WNOMFIC

Openi WNOMFIC Using [TIE]

#NBRPES - Contendra el numero de pesos contemplados en tarifa
#RANPES - Contendra los diferentes pesos contemplados
Raz RANPES
Gosub LEER_REGISTRO   :#primera linea de rango de pesos, excepto la CINCO primeras componentes
For I=4 To 154
#For I=6 To 154
   If val(A(I))=0
      Break
   Endif
   #Quitamos el separador decimal para los rangos de peso
   RANPES(I-3)=val(ctrans(A(I),".",""))
   #RANPES(I-5)=val(ctrans(A(I),".",""))
Next

NBRPES=I-4
#NBRPES=I-6
Gosub LEER_REGISTRO

Raz WORDARE

Trbegin [ZTTRH], [ZTTRD]

While !fstat
   If len(vireblc(A(1),2))>0
      Call ECR_TRACE("Procesando:  "+vireblc(A(1),2)+" "+vireblc(A(2),2)+" "+vireblc(A(3),2),0) From GESECRAN
      WORDARE += 1
      If WORDARE=1
         #Primera iteracion, grabamos cabecera [ZTTRH]
         Raz [F:ZTTRH]
         [F:ZTTRH]STOFCY=WSTOFCY
         [F:ZTTRH]BPTNUM=WBPTNUM
         [F:ZTTRH]FECIMP=date$
         [F:ZTTRH]CREUSR=GUSER
         [F:ZTTRH]CREDAT=date$
         Write [ZTTRH]
         If fstat
            Call ECR_TRACE("   Error grabando cabecera [ZTTRH] - fstat: "+num$(fstat)+ " FCY: "+WSTOFCY+" "+" TRANSP.: "+WBPTNUM,1) From GESECRAN
            WOK=0
            Break
         Endif
      Endif

      Raz [F:ZTTRD]
      [F:ZTTRD]STOFCY=[F:ZTTRH]STOFCY
      [F:ZTTRD]BPTNUM=[F:ZTTRH]BPTNUM
      [F:ZTTRD]FECIMP=[F:ZTTRH]FECIMP
      [F:ZTTRD]ORDARE=WORDARE
      [F:ZTTRD]BPTARE=vireblc(A(1),2)
      [F:ZTTRD]CRY   =vireblc(A(2),2)
      [F:ZTTRD]POSCOD=vireblc(A(3),2)
      [F:ZTTRD]CREDAT=date$
      [F:ZTTRD]CREUSR=GUSER
      #[F:ZTTRD]ZDIASTRMIN=vireblc(A(4),2)
      #[F:ZTTRD]ZDIASTRSTD=vireblc(A(5),2)
      For I=4 To NBRPES+4
      #For I=6 To NBRPES+6
         [F:ZTTRD]NUMLIN=I-3
         #[F:ZTTRD]NUMLIN=I-5
         If I=4
         #If I=6
            #Primera iteracion
            [F:ZTTRD]DESDE =0
         Else
            #Siguientes iteraciones
            [F:ZTTRD]DESDE =RANPES(I-4)
            #[F:ZTTRD]DESDE =RANPES(I-6)
         Endif
         [F:ZTTRD]HASTA =RANPES(I-3)
         #[F:ZTTRD]HASTA =RANPES(I-5)
         [F:ZTTRD]PRECIO=val(ctrans(ctrans(A(I),".",""),",","."))

         Write [ZTTRD]
         If fstat
            Call ECR_TRACE("   Error grabando detalle tarifa [ZTTRD] - fstat:  "+num$(fstat)+" AREA: " +
&                          [F:ZTTRD]BPTARE+" Hasta: "+num$([F:ZTTRD]HASTA),1) From GESECRAN
            WOK=0
         Endif
      Next
   Endif

   Gosub LEER_REGISTRO
   If !WOK
      Break
   Endif
Wend
Openi Using [TIE]

If !OK
   Rollback
Else
   Commit
Endif

If OK
   #Borrado, modificacion e insercion en tablas definitivas de transportistas
   #CARAREA  [CAA] Regiones transportistas
   #CARPRICE [CAP] Tarifas transportistas
   Trbegin [BPT], [CAA], [CAP]

   Delete [CAA] Where BPTNUM=WBPTNUM
   If fstat
      Call ECR_TRACE("   Error borrando areas transp. [CAA] - fstat: "+num$(fstat),1) From GESECRAN
      OK=0
   Endif
   Delete [CAP] Where BPTNUM=WBPTNUM
   If fstat
      Call ECR_TRACE("   Error borrando tarifas transp. [CAP] - fstat: "+num$(fstat),1) From GESECRAN
      OK=0
   Endif

   Read [F:BPT]BPT0=WBPTNUM
   For I=1 To NBRPES
      [F:BPT]PLIMAX(I-1)   =RANPES(I)
      [F:BPT]PLIUOMRND(I-1)=1
   Next
   [F:BPT]NBPLI=NBRPES

   Rewrite [F:BPT]
   If fstat
      Call ECR_TRACE("   Error modificando transportista [BPT] - fstat: "+num$(fstat),1) From GESECRAN
      OK=0
   Endif

   Link [ZTTRD] With [ZTTRH]ZTTRH0(2)=WSTOFCY;WBPTNUM As [LNK] Where [ZTTRH]BPTNUM=WBPTNUM
&       Order By Key ZTTRD0
   Filter [LNK]
   LINNUM=0
   AREAUX="XXXXX"
   For [LNK]
      If AREAUX<>[F:ZTTRD]BPTARE
         AREAUX=[F:ZTTRD]BPTARE
         LINNUM=LINNUM+1000
         Raz [F:CAA]
         [F:CAA]BPTNUM=[F:ZTTRH]BPTNUM
         [F:CAA]STOFCY=[F:ZTTRH]STOFCY
         [F:CAA]LINNUM=LINNUM
         [F:CAA]CRY   =[F:ZTTRD]CRY
         [F:CAA]POSCOD=[F:ZTTRD]POSCOD
         [F:CAA]BPTARE=[F:ZTTRD]BPTARE
         [F:CAA]CREUSR=GUSER
         [F:CAA]CREDAT=date$
         Write [F:CAA]
         If fstat
            Call ECR_TRACE("   Error creando area transportista [CAA] - fstat: "+num$(fstat)+" "+[F:CAA]BPTNUM+" "+
&                [F:CAA]BPTARE+" "+[F:CAA]POSCOD+" "+[F:CAA]CRY,1) From GESECRAN
            OK=0
            Break
         Endif
      Endif
      Raz [F:CAP]
      [F:CAP]BPTNUM=[F:ZTTRH]BPTNUM
      [F:CAP]BPTARE=[F:ZTTRD]BPTARE
      [F:CAP]RANG  =[F:ZTTRD]NUMLIN
      [F:CAP]MINQTY=[F:ZTTRD]DESDE
      [F:CAP]MAXQTY=[F:ZTTRD]HASTA
      [F:CAP]PRI   =[F:ZTTRD]PRECIO
      [F:CAP]WEIRND=1
      [F:CAP]CREUSR=GUSER
      [F:CAP]CREDAT=date$
      Write [F:CAP]
      If fstat
         Call ECR_TRACE("   Error creando tarifa transportista [CAP] - fstat: "+num$(fstat)+" "+[F:CAP]BPTNUM+" "+
&             [F:CAP]BPTARE+" "+num$([F:CAP]RANG)+" "+num$([F:CAP]MINQTY)+" "+num$([F:CAP]MAXQTY),1) From GESECRAN
         OK=0
         Break
      Endif

   Next
   If !OK
      Rollback
   Else
      Commit
   Endif
Endif

$FIN

If !OK
   Call ECR_TRACE(" Fin proceso importacion tarifas transportistas con error",1) From GESECRAN
Else
   Call ECR_TRACE(" Fin proceso importacion tarifas transportistas ",0) From GESECRAN
   Call ECR_TRACE(" Fin importación tarifas trasnportistas: "+num$(WORDARE),0) From GESECRAN
Endif

Call FERME_TRACE From LECFIC
TRA = 1
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110),
& A(111), A(112), A(113), A(114), A(115), A(116), A(117), A(118), A(119), A(120) Using [TIE]
Return

$TERMINE
TRA = 1
Return
