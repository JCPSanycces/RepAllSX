$ACTION
#Infbox ACTION
Case ACTION
   When "LOASUPMFI" : Gosub LOADSUPMFI
   When "LOADSUPP"  : Gosub LOADSUPP
Endcase
Return

$LOADSUPMFI
Local Integer FABCLI :#Fabricacion para cliente o para stock

If clalev([ZMSQ])<=0 : Local File ZMFGSOQ [ZMSQ] : Endif

[M:MTK2]ZQTYBOB(N)    = [F:MFI]ZQTYBOB
[M:MTK2]ZANCHO(N)     = [F:MFI]ZANCHO
[M:MTK2]ZLONGITUD(N)  = [F:MFI]ZLONGITUD
[M:MTK2]ZFACTOR(N)    = [F:MFI]ZFACTOR
[M:MTK2]ZFABCOR(N)    = [F:MFI]ZFABCOR
[M:MTK2]ZSUPERREAL(N) = [F:MFI]ZSUPERFICIE
[M:MTK2]ZMANDRIL(N)   = [F:MFI]ZMANDRIL
[M:MTK2]ZPROVEEDOR(N) = [F:MFI]ZPROVEEDOR
[M:MTK2]ZNCORTES(N)   = [F:MFI]ZNCORTES
[M:MTK2]ZMFGDATE(N)   = [F:MFI]ZMFGDATE
[M:MTK2]ZEMPALME(N)   = [F:MFI]ZEMPALME

#Siempre se da como saldad la linea de producto porque no se permiten seguimientos parciales.
[M:MTK2]CLEFLG(N)   = 2

#Infbox "SUBMTKB"+" "+[F:MFI]ZLOC
#Cargamos Ubicacion y tipo de Ubicacion segun la fabricacion haya sido para cliente o para stock, de forma que
#si la linea de producto esta asociada a un pedido de venta la ubiación sera GENERAL1, y si no lo esta entonces es una
#linea de stock y se inicializa a la ubicacion que venga de la propia linea si esta informada y si no se dara de
#entrada a la que este parametrizada segun el estandar de X3
FABCLI=1
Filter [ZMSQ] Where MFGNUM=[F:MFI]MFGNUM and MFGLIN=[F:MFI]MFGLIN
For [ZMSQ]
   FABCLI=2
   Break
Next
Filter [ZMSQ]
If FABCLI=2
   [M:MTK2]LOCTYP(N)="GEN"
   If [F:MFI]ZUBICACTE <> ""
      [M:MTK2]LOC(N) = [F:MFI]ZUBICACTE
   Else
      [M:MTK2]LOC(N) = "GENERAL1"
   Endif
   #[M:MTK2]LOC(N)="GENERAL1"
Else
    If [F:MFI]ZUBICASTK <> ""
      [M:MTK2]LOCTYP(N)="GEN"
      [M:MTK2]LOC(N)=[F:MFI]ZUBICASTK
    Endif
#   If [F:MFI]ZLOC<>""
#      [M:MTK2]LOCTYP(N)="GEN"
#      [M:MTK2]LOC(N)=[F:MFI]ZLOC
#   Endif
Endif

#If [F:MFI]ZLOC<>"" Then
#  If !clalev([F:LOC]) : Local File STOLOC [LOC] : Endif
#  Raz [F:LOC]
#  If [F:MFI]ZLOC<>""
#     Read [F:LOC]STC0=[M:MTK0]MFGFCY;[F:MFI]ZLOC
#     [M:MTK2]LOC(N)     = [F:MFI]ZLOC
#     [M:MTK2]LOCTYP(N)   = [F:LOC]LOCTYP
#  Endif
#Endif
Return

$LOADSUPP
[M:MTK3]ZQTYBOB(M)    = [F:MFM]ZQTYBOB
[M:MTK3]ZANCHO(M)     = [F:MFM]ZANCHO
[M:MTK3]ZLONGITUD(M)  = [F:MFM]ZLONGITUD
[M:MTK3]ZFACTOR(M)    = [F:MFM]ZFACTOR
[M:MTK3]ZFABCOR(M)    = [F:MFM]ZFABCOR
[M:MTK3]ZSUPERFICIE(M)= [F:MFM]ZSUPERFICIE
[M:MTK3]ZSUPCONS(M)   = [F:MFM]ZSUPCONS
[M:MTK3]ZMANDRIL(M)   = [F:MFM]ZMANDRIL
[M:MTK3]ZPROVEEDOR(M) = [F:MFM]ZPROVEEDOR
[M:MTK3]ZNCORTES(M)   = [F:MFM]ZNCORTES
[M:MTK3]ZMANDFLG(M)   = [F:MFM]ZMANDFLG
[M:MTK3]ZMFGDATE(M)   = [F:MFM]ZMFGDATE
[M:MTK3]ZEMPALME(M)   = [F:MFM]ZEMPALME
Return
