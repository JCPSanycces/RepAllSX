#<AdxTL>@(#)0.0.0.0 $Revision$
#ULT_PRECOS -> Retorna el ultiimo precio de coste
#MAIL_CNT -> Retorna el mail del contacto del tercero y funcion pasada como parametro
#USRCRESOH -> Retorna el usuario creacion del pedido de venta

Funprog MAIL_CNT(LTIPTER,LBPR,LFUNC)
Value Integer LTIPTER
Value Char LBPR
Value Integer LFUNC
Local Char LMAILCNT(80)

If !clalev([F:CNTX]) : Local File CONTACT  [F:CNTX]: Endif
Raz LMAILCNT
Filter [CNTX] Where BPATYP=LTIPTER and BPANUM=LBPR and CNTFNC=LFUNC
For [CNTX]
   LMAILCNT=[F:CNTX]WEB
   Break
Next
End LMAILCNT

Funprog USRCRESOH(LNUMSOH)
Value Char LNUMSOH
Local Char LUSRCRE(10)

If !clalev([F:SOHX]) : Local File SORDER  [F:SOHX]: Endif
Raz LUSRCRE
Raz [SOHX]
Read [SOHX]SOH0=LNUMSOH
LUSRCRE=[F:SOHX]CREUSR
End LUSRCRE

Funprog ULT_PRECOS(LFCY,LITMREF)
Value Char LFCY
Value Char LITMREF
Local Decimal LPRECOS

If !clalev([F:PTHX]) : Local File PRECEIPT  [F:PTHX]: Endif
If !clalev([F:PTDX]) : Local File PRECEIPTD [F:PTDX]: Endif

Link [PTDX] With [PTHX]PTH0=[F:PTDX]PTHNUM As [LNK] Where [PTDX]PRHFCY=LFCY and [PTDX]ITMREF=LITMREF
&                Order By Key CLE=[PTHX]RCPDAT Desc
LPRECOS=0
For [LNK]
   LPRECOS=[F:PTDX]CPR
   Break
Next

End LPRECOS

Funprog STOUBI(WSTOFCY,WITMREF,ANCHO,MANDRIL,LONGITUD,PROVEEDOR,WLOT,WLOC,WSTA)

 Value Char WITMREF,WSTOFCY,WLOC,WSTA,PROVEEDOR,WLOT
 Value Integer ANCHO, MANDRIL, LONGITUD
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STOX]) : Local File STOCK [F:STOX]: Endif

 If PROVEEDOR <> ""
    WEVAL += " AND [F:STOX]ZPROVEEDOR = PROVEEDOR"
 Endif
 If WLOC <> ""
    WEVAL += " AND [F:STOX]LOC = WLOC"
 Endif
 If WSTA <> ""
   WEVAL += " AND LEFT$([F:STOX]STA,1) = '"+WSTA+"'"
 Endif

 Filter [F:STOX] Where ITMREF = WITMREF and STOFCY = WSTOFCY and ZANCHO=ANCHO and ZMANDRIL=MANDRIL
&       and ZLONGITUD=LONGITUD and ZPROVEEDOR=PROVEEDOR and LOT=WLOT and evalue(WEVAL)
 For [F:STOX]
     WQTY+=1
     #WQTY += [F:STO]QTYSTU-[F:STO]CUMALLQTY
 Next
 Filter [F:STOX]

End WQTY

Funprog DOCASI(LFCY,LITMREF,LSTOCOU)
Value Char LFCY
Value Char LITMREF
Value Decimal LSTOCOU
Local Char LDOCU(25)

Raz LDOCU
If !clalev([F:STAX]): Local File STOALL [STAX] : Endif
Filter [STAX] Where STOFCY=LFCY and ITMREF=LITMREF and STOCOU=LSTOCOU
For [STAX]
   LDOCU=[F:STAX]VCRNUM
   Break
Next
Filter [STAX]
End LDOCU

Funprog TEXTO(TABLA,ZONA,IDENT1,IDENT2)

  Value Char TABLA,ZONA,IDENT1,IDENT2
  Local Char WTEXTO(75)

  Raz WTEXTO

  If !clalev([F:AXX]): Local File ATEXTRA [AXX] : Endif

  Read [AXX]AXX0 = TABLA;ZONA;"SPA";IDENT1;IDENT2
  WTEXTO = [AXX]TEXTE

End WTEXTO

Funprog BOBDISP(LSTOFCY,LITMREF,LANCHO,LMANDRIL,LLONGITUD,LDOCUME)
Value Char LSTOFCY, LITMREF, LDOCUME
Value Integer LANCHO, LMANDRIL, LLONGITUD
Local Integer BOBDIS
Local Integer BOBSTO, BOBASI, BOBASIDOC

If clalev([F:STOX])<=0 : Local File STOCK  [STOX] : Endif
If clalev([F:STAX])<=0 : Local File STOALL [STAX] : Endif
BOBSTO=0
BOBASI=0
LBOBASIDOC=0
Filter [STOX] Where ITMREF=LITMREF and STOFCY=LSTOFCY and ZANCHO=LANCHO and ZMANDRIL=LMANDRIL and ZLONGITUD=LLONGITUD
For [STOX]
   BOBSTO+=1
   Filter [STAX] Where STOFCY=LSTOFCY and ITMREF=LITMREF and STOCOU=[F:STOX]STOCOU
   For [STAX]
      BOBASI+=1
      If [F:STAX]VCRNUM=LDOCUME
          LBOBASIDOC+=1
      Endif
      Break
   Next
   Filter [STAX]
Next
Filter [STOX]
BOBDIS=BOBSTO-BOBASI+LBOBASIDOC
End BOBDIS

Funprog BOBOF(LMFGNUM)
Value Char LMFGNUM
Local Integer LBOBQTY
If clalev([MFIX])<=0 : Local File MFGITM [MFIX] : Endif

LBOBQTY=0
Filter [MFIX] Where MFGNUM=LMFGNUM
For [MFIX]
   LBOBQTY+=[F:MFIX]ZQTYBOB
Next
Filter [MFIX]
End LBOBQTY


Funprog DATLINPOQ(LPOHNUM,LPOPLIN)
Value Char LPOHNUM
Value Integer LPOPLIN
Local Char LDATLIN(30)

If clalev([F:POQX])<=0 : Local File PORDERQ  [POQX] : Endif

Raz LDATLIN
Filter [POQX] Where POHNUM=LPOHNUM and POPLIN=LPOPLIN
LDATLIN=LPOHNUM+" "+num$(LPOPLIN)
For [POQX]
LDATLIN="BUCLE"
   LDATLIN=[F:POQX]ITMREF+"_"+num$([F:POQX]ZANCHO)+"_"+num$([F:POQX]ZLONGITUD)+"_"+num$([F:POQX]ZMANDRIL)
   Break
Next
Filter [POQX]
End LDATLIN

######################################################################################################
#    Funcion llamada desde formula  Tipo=Rutas operativas  Código=SM0    Descripción=Superficie ML   #
#                      func ZLIBCONS.MFG_FORMULA_A                                                   #
######################################################################################################
Funprog MFG_FORMULA_A
Local Decimal VALOR
If GIMPORT
  VALOR=[M:MFGK]ZIMPLNG  / [M:MFGK]ZIMPKGS
Else
  VALOR=[M:MFG1]ZMAXLONG / [M:MFG1]MFGEXTQTY
Endif
End VALOR
######################################################################################################
#    Funcion llamada desde formula  Tipo=Rutas operativas  Código=SM0    Descripción=Unidades        #
#                      func ZLIBCONS.MFG_FORMULA_B                                                   #
######################################################################################################
Funprog MFG_FORMULA_B
Local Decimal VALOR
If GIMPORT
  VALOR=func ZLIBCONS.BOBOF([M:MFGK]MFGNUM)/[M:MFGK]ZIMPKGS
Else
  VALOR=func ZLIBCONS.BOBOF([M:MFG0]MFGNUM)/[M:MFG1]MFGEXTQTY
Endif
End VALOR
