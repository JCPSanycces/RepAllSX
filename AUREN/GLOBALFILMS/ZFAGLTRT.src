#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
# When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
# When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$DEBUT
Raz [M:ZFAGL0]
[M:ZFAGL0]ZFCYORG="901"
[M:ZFAGL0]ZFCYORGH="901"
[M:ZFAGL0]ZFECORG=addmonth(eomonth(date$)+1,-1)
[M:ZFAGL0]ZFECORGH=eomonth(date$)
[M:ZFAGL0]ZFACTUR=1
[M:ZFAGL0]ZFACTURH=2
[M:ZFAGL0]FCY='100'
[M:ZFAGL0]ACCDAT=eomonth(date$)
Affzo [M:ZFAGL0]
Return

$OUVRE
If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
If !clalev([F:SID]) : Local File SINVOICED [SID] : Endif
If !clalev([F:ZFAPR]) : Local File ZFAGPRVCOM [ZFAPR] : Endif
If !clalev([F:ZFALQ]) : Local File ZFAGLIQCOM [ZFALQ] : Endif

If !clalev([F:XBPR]) : Local File BPARTNER [XBPR] : Endif
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
Return

$BOUTON
Case BOUT
    When "B" :  Gosub BUSCAR

    When "G" : Gosub GENERAR
Endcase
Return

$BUSCAR
Local Char WLCRITERIO (250)
Local Char WLCRITERI2 (250)
Local Integer WLNOL : WLNOL = 0
# Definicion variables
Local Decimal WLPCTCOB, WLIMPCOB, WLIMPLIQDO, WLIMPALIQ, WLIMPFAC, WLIMPCOM, WLIMPCOMCOB

WLCRITERIO="2=2"
If [M:ZFAGL0]FCY <> "" :  WLCRITERIO -= "& (FCY=[M:ZFAGL0]FCY)" : Endif
If [M:ZFAGL0]ZFCYORG <> "" : WLCRITERIO -= "& (FCYORG>=[M:ZFAGL0]ZFCYORG)" : Endif
If [M:ZFAGL0]ZFCYORGH <> "" : WLCRITERIO -= "& (FCYORG<=[M:ZFAGL0]ZFCYORGH)" : Endif
If [M:ZFAGL0]ZFECORG <> [0/0/0] : WLCRITERIO -= "& (ACCDAT>=[M:ZFAGL0]ZFECORG)" : Endif
If [M:ZFAGL0]ZFECORGH <> [0/0/0] : WLCRITERIO -= "& (ACCDAT<=[M:ZFAGL0]ZFECORGH)" : Endif
#If [M:ZFAGL0]ZFACTUR <>0 : WLCRITERIO -= "& (ZFACTUR>=[M:ZFAGL0]ZFACTUR)" : Endif
#If [M:ZFAGL0]ZFACTURH <>0 : WLCRITERIO -= "& (ZFACTUR<=[M:ZFAGL0]ZFACTURH)" : Endif
If [M:ZFAGL0]ZBPCREPD <> "" : WLCRITERIO -= "& (BPCREP>=[M:ZFAGL0]ZBPCREPD)" : Endif
If [M:ZFAGL0]ZBPCREPH <> "" : WLCRITERIO -= "& (BPCREP<=[M:ZFAGL0]ZBPCREPH)" : Endif

Filter [F:ZFAPR] Where evalue (WLCRITERIO)
For [F:ZFAPR]
   [M:ZFAGL0]ZSEL(WLNOL)=1
   [M:ZFAGL0]BPCREP(WLNOL)=[F:ZFAPR]BPCREP


  # Leer tercero representado
   Raz [F:XBPR]
   Read [F:XBPR]BPR0=[F:ZFAPR]BPCREP
   [M:ZFAGL0]BPCREPNAM(WLNOL)=[F:XBPR]BPRNAM  # Nombre Representado

   [M:ZFAGL0]FCYORG(WLNOL)=[F:ZFAPR]FCYORG
   [M:ZFAGL0]DOCORG(WLNOL)=[F:ZFAPR]DOCORG
   [M:ZFAGL0]FECORG(WLNOL)=[F:ZFAPR]FECORG
   [M:ZFAGL0]IMPORTE(WLNOL)=[F:ZFAPR]IMPORTE
   [M:ZFAGL0]FACTUR(WLNOL)=0

   Raz [F:SIH]
   Read [F:SIH]SIH0=[F:ZFAPR]DOCORG
   [M:ZFAGL0]BPCNAM(WLNOL)=[F:SIH]BPRNAM
   [M:ZFAGL0]IMPORG(WLNOL)=[F:SIH]AMTATI
    [M:ZFAGL0]REFDOCORG(WLNOL)=[F:SIH]ZFAGNUMFAC # Nş Factura Representado

  # Leer Fecha Vencimiento
    Raz [F:DUD]
    Filter [F:DUD] Where NUM=[F:SIH]NUM
    For [F:DUD]
       [M:ZFAGL0]FECVTO(WLNOL)=[F:DUD]DUDDAT  # Fecha Vencimiento
       Break
    Next
    Filter [F:DUD]

   # Calculo Importe comision Liquidado
   WLIMPLIQDO = func COM_LIQADO([F:ZFAPR]DOCORG)

   [M:ZFAGL0]IMPORTELIQ(WLNOL)=WLIMPLIQDO


   #WLIMPCOM=[F:ZFAPR]IMPORTE
   WLIMPCOM=[F:SIH]ZFAGIMPCOM
   WLIMPFAC=[F:SIH]AMTATI
   # Calculos
   If WLIMPCOM<>0
       WLPCTCOB=WLIMPLIQDO/WLIMPCOM              # Calculo porcentaje cobrado segun importe liquidado con respecto al importe comision
       If WLPCTCOB>1 : WLPCTCOB = 1 : Endif        # Si Porcentaje cobrado mayor que 1 se ajusta a 1
       WLIMPCOB= arr(WLPCTCOB * WLIMPFAC,0.01)     # Total Cobrado segun porcentaje cobro ESTIMACION
   Else
       WLPCTCOB=1
       WLIMPCOB=WLIMPFAC
   Endif
   [M:ZFAGL0]IMPCOB(WLNOL)=WLIMPCOB
   [M:ZFAGL0]PCTCOB(WLNOL)=WLPCTCOB
   [M:ZFAGL0]IMPALIQ(WLNOL)=0

   WLNOL+=1
Next
Filter [F:ZFAPR]
[M:ZFAGL0]NBLIG=WLNOL
Affzo [M:ZFAGL0]15
Return





# Funcion que devuelve el importe de comision liquidado de un documento
Funprog COM_LIQADO(WNDOC)
Value Char WNDOC
Local Decimal WTOTLIQ
If !clalev([F:ZFALQ]) : Local File ZFAGLIQCOM [ZFALQ] : Endif
  WTOTLIQ=0

Filter [F:ZFALQ] Where DOCORG=WNDOC
For [F:ZFALQ]
  WTOTLIQ+=[F:ZFALQ]IMPORTE
Next
Filter [F:ZFALQ]

End WTOTLIQ
$GENERAR
Local Integer WLI
Trbegin [F:ZFALQ], [F:SIH]
GOK=1
For WLI=0 To [M:ZFAGL0]NBLIG - 1
   If [M:ZFAGL0]ZSEL(WLI)=2
    # If GUSER = 'ADMIN' : Dbgaff : Endif
     Raz [F:SIH]
     Read [F:SIH]SIH0=[M:ZFAGL0]DOCORG(WLI)
     If !fstat Then
        Raz [F:ZFALQ]
        [F:ZFALQ]BPCREP=[M:ZFAGL0]BPCREP(WLI)
        [F:ZFALQ]FCY=[M:ZFAGL0]FCY
        [F:ZFALQ]ACCDAT=[M:ZFAGL0]ACCDAT
        [F:ZFALQ]BPCREP=[M:ZFAGL0]BPCREP(WLI)
        [F:ZFALQ]FCYORG=[M:ZFAGL0]FCYORG(WLI)
        [F:ZFALQ]DOCORG=[M:ZFAGL0]DOCORG(WLI)
        [F:ZFALQ]NUMLIQ=func ULT_NUMLIQ([F:ZFALQ]DOCORG)
        [F:ZFALQ]FECORG=[M:ZFAGL0]FECORG(WLI)
        [F:ZFALQ]IMPORTE=[M:ZFAGL0]IMPALIQ(WLI)
        [F:ZFALQ]FACTUR=1
        [F:ZFALQ]DESCRI= [M:ZFAGL0]REFDOCORG(WLI) - [M:ZFAGL0]BPCNAM(WLI)
        [F:ZFALQ]CREUSR=GUSER
        [F:ZFALQ]CREDATTIM=datetime$
        [F:ZFALQ]UPDDATTIM=[F:ZFALQ]CREDATTIM
        Write [F:ZFALQ]
        If fstat
           Call FSTA("F:ZFALQ") From GLOCK
           GOK=0
           Break
        Else
        #Raz [F:SIH]
        #Read [F:SIH]SIH0=[F:ZFALQ]DOCORG
        #If !fstat

            [F:SIH]ZFAGIMPLIQ+=[F:ZFALQ]IMPORTE

        # Si el importe liquidado es mayor o igual que el importe de comision a liquidar
        # se marca la factura como liquidada totalmente en otro caso la liquidacion es parcial.

            If  [F:SIH]ZFAGIMPLIQ>=[M:ZFAGL0]IMPORTE(WLI) Then
               [F:SIH]ZFAGSTL=3
            Else
              [F:SIH]ZFAGSTL=2
            Endif
            [F:SIH]ZFAGFECLIQ=[F:ZFALQ]ACCDAT
            Rewrite [F:SIH]
            If fstat
               Call FSTA("SIH") From GLOCK
               GOK=0
               Break
            Endif
        Endif
     Else
        Call FSTA("SIH") From GLOCK
        GOK=0
        Break
     Endif
   Endif
Next
If GOK Then
   Commit
   Gosub $BUSCAR
Else
   Rollback
Endif
Return


Funprog ULT_NUMLIQ(WNDOC)
Value Char WNDOC
Local Integer WNUMLIQ
If !clalev([F:ZFALQ]) : Local File ZFAGLIQCOM [ZFALQ] : Endif
  WNUMLIQ=0

Filter [F:ZFALQ] Where DOCORG=WNDOC Order By NUMLIQ
For [F:ZFALQ]
  WNUMLIQ=[F:ZFALQ]NUMLIQ
Next
Filter [F:ZFALQ]
WNUMLIQ+=1

End WNUMLIQ


#### GESTION PANTALL [M:ZFAGL0]


Subprog AS_ZSEL(VALEUR)
Variable Integer VALEUR
End

Subprog AM_ZSEL(VALEUR)
Variable Integer VALEUR
Local Integer NOL: NOL = nolign - 1
# Definicion variables
Local Decimal WLPCTCOB, WLIMPCOB, WLIMPLIQDO, WLIMPALIQ, WLIMPFAC, WLIMPCOM, WLIMPCOMCOB
WLIMPFAC=[M:ZFAGL0]IMPORG(NOL)
WLIMPLIQDO=[M:ZFAGL0]IMPORTELIQ(NOL)
WLIMPCOM=[M:ZFAGL0]IMPORTE(NOL)
If VALEUR = 2
    WLIMPALIQ=WLIMPCOM-WLIMPLIQDO
    If WLIMPALIQ<0
       WLIMPALIQ=0
    Else
       WLPCTCOB=1
       WLIMPCOB=WLIMPFAC
    Endif

Endif

If VALEUR = 1
   WLIMPALIQ=0
   # Calculos
   If WLIMPCOM<>0
       WLPCTCOB=WLIMPLIQDO/WLIMPCOM             # Calculo porcentaje cobrado segun importe liquidado con respecto al importe comision
       If WLPCTCOB>1 : WLPCTCOB = 1 : Endif        # Si Porcentaje cobrado mayor que 1 se ajusta a 1
       WLIMPCOB= arr(WLPCTCOB * WLIMPFAC,0.01)     # Total Cobrado segun porcentaje cobro
   Else
       WLPCTCOB=1
       WLIMPCOB=WLIMPFAC
   Endif

Endif
    # Refrescos pantalla
    [M:ZFAGL0]PCTCOB(NOL)=WLPCTCOB
    [M:ZFAGL0]IMPCOB(NOL)=WLIMPCOB
    [M:ZFAGL0]IMPALIQ(NOL)=WLIMPALIQ
    Affzo [M:ZFAGL0]PCTCOB(NOL)
    Affzo [M:ZFAGL0]IMPCOB(NOL)
    Affzo [M:ZFAGL0]IMPALIQ(NOL)
End

Subprog AS_IMPALIQ(VALEUR)
Variable Decimal VALEUR
End

Subprog C_IMPALIQ(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_IMPALIQ(VALEUR)
Variable Decimal VALEUR
Local Integer NOL: NOL = nolign - 1
# Definicion variables
Local Decimal WLPCTCOB, WLIMPCOB, WLIMPLIQDO, WLIMPALIQ, WLIMPFAC, WLIMPCOM, WLIMPCOMCOB
WLIMPFAC=[M:ZFAGL0]IMPORG(NOL)
WLIMPLIQDO=[M:ZFAGL0]IMPORTELIQ(NOL)
WLIMPCOM=[M:ZFAGL0]IMPORTE(NOL)
WLIMPALIQ=VALEUR
# Calculos
If WLIMPCOM<>0
   WLIMPCOMCOB = WLIMPALIQ +  WLIMPLIQDO        # Total Comision contando lo liquidado anteriormente
   WLPCTCOB=WLIMPCOMCOB/WLIMPCOM                # Calculo porcentaje cobrado segun importe al liquidar con respecto al importe comision
   If WLPCTCOB>1 : WLPCTCOB = 1 : Endif         # Si Porcentaje cobrado mayor que 1 se ajusta a 1
   WLIMPCOB = arr(WLPCTCOB * WLIMPFAC,0.01)     # Total Cobrado segun porcentaje cobro
Else
   WLPCTCOB=1
   WLIMPCOB=WLIMPFAC
Endif
# Refrescos pantalla
[M:ZFAGL0]PCTCOB(NOL)=WLPCTCOB
[M:ZFAGL0]IMPCOB(NOL)=WLIMPCOB
Affzo [M:ZFAGL0]PCTCOB(NOL)
Affzo [M:ZFAGL0]IMPCOB(NOL)
If VALEUR<>0
   [M:ZFAGL0]ZSEL(NOL)=2
Else
   [M:ZFAGL0]ZSEL(NOL)=1
Endif
Affzo [M:ZFAGL0]ZSEL(NOL)
End

Subprog AM_IMPCOB(VALEUR)
Variable Decimal VALEUR
Local Integer NOL: NOL = nolign - 1
# Definicion variables
Local Decimal WLPCTCOB, WLIMPCOB, WLIMPLIQDO, WLIMPALIQ, WLIMPFAC, WLIMPCOM, WLIMPCOMCOB

WLIMPFAC=[M:ZFAGL0]IMPORG(NOL)
WLIMPLIQDO=[M:ZFAGL0]IMPORTELIQ(NOL)
WLIMPCOM=[M:ZFAGL0]IMPORTE(NOL)
WLIMPCOB=VALEUR
# Calculos
If WLIMPFAC<>0
   WLPCTCOB=WLIMPCOB/WLIMPFAC                   # Calculo porcentaje cobrado
   If WLPCTCOB>1 : WLPCTCOB = 1 : Endif         # Si Porcentaje cobrado mayor que 1 se ajusta a 1
   WLIMPCOMCOB = arr(WLPCTCOB * WLIMPCOM,0.01)  # Total a liquidar segun cobrado
   WLIMPALIQ = WLIMPCOMCOB - WLIMPLIQDO         # Total a liquidar descontando lo liquidado anteriormente
   If WLIMPALIQ<0 : WLIMPALIQ=0 : Endif         # Si comision a liquidar menor que cero, la comision a liquidar es cero.
Else
   WLPCTCOB=1
   WLIMPALIQ=0
Endif
# Refrescos pantalla
[M:ZFAGL0]PCTCOB(NOL)=WLPCTCOB
[M:ZFAGL0]IMPALIQ(NOL)=WLIMPALIQ
Affzo [M:ZFAGL0]PCTCOB(NOL)
Affzo [M:ZFAGL0]IMPALIQ(NOL)
If [M:ZFAGL0]IMPALIQ(NOL)<>0
   [M:ZFAGL0]ZSEL(NOL)=2
Else
   [M:ZFAGL0]ZSEL(NOL)=1
Endif
Affzo [M:ZFAGL0]ZSEL(NOL)
End

