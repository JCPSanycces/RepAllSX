#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIMIR_DOCUMENTO()
If dim([M:ZEM0]DOCUMENTO)>0 and [M:ZEM0]DOCUMENTO<>""
  Call IMPRIMIR_DOCUMENTO_P([M:ZEM0]ORIGEN,[M:ZEM0]DOCUMENTO,"","","")
Else
  Infbox "Imposible Imprimir mediante <IMPRIMIR_DOCUMENTO()> sin haber indicado valores a [M:ZEM0]DOCUMENTO"
Endif
End

Subprog IMPRIMIR_DOCUMENTO_P(ORIGENP,DOCUMENTOP,FORMATOP,DESTINOP,IDIOMAP)
Value Char ORIGENP,DOCUMENTOP,FORMATOP,DESTINOP,IDIOMAP

  Local Char    TBPAR(20)(1..20) , TBVAL(20)(1..20)
  Local Integer NBPAR
  Local Char FORMATO(30),DESTINO(GLONAIM),IDIOMA(GLONLAN)
  Local Char    TIMPUT(30)(1..20) , TFECHAS(30)(1..20)
  Local Char TARMIN(15),TARMAX(15)
  Local Char FECMIN(8),FECMAX(8)
  Local Date DATFECMIN,DATFECMAX

  FORMATO=vireblc(FORMATOP,2)
  DESTINO=vireblc(DESTINOP,2)
  IDIOMA =vireblc(IDIOMAP,2)
  If DESTINO=""
    # Cogemos el primero que sea previsualizacion en formato pdf
    #select * from APRINTER where PRT_0=1 and ENAFLG_0=2 and PRTSRV_0<>'' and PRTFMT_0=29
    If clalev ([F:AIM])<=0   :  Local File APRINTER     [F:AIM]  : Endif
    Filter [F:AIM]
    Filter [F:AIM] Where PRT=1 and ENAFLG=2 and PRTSRV<>"" and PRTFMT=29
    For [F:AIM]
      DESTINO=COD
      Break
    Next
    Filter [F:AIM]
    If DESTINO=""
      Infbox "IMPOSIBLE IMPRIMIR. No se indicó DESTINO y tampoco existe ninguno marcado como PDF+VistaPreliminar"
      End
    Endif
  Endif
  If IDIOMA="" :  IDIOMA ="SPA    " : Endif

##############################
#
# AVISO !!!
# Para formato PDF, debe existir punto de entrada     ZPEAIMP3.src      ACTION=PARAM
# Comprobar parametros usados en   $PARAM, para asegurarnos de que existe el que corresponda con WNUMDOC
# Ańadir parámetro    ZDIRDOCWEB    para indicar carpeta donde se generaran los PDF    VALORES PARAMETROS / SUP supervisor / Varios / ZDIRDOCWEB
#
##############################
  Case ORIGENP
    When "ZCONPROTEC" # Consulta imputaciones tecnicos
      If FORMATO="" : FORMATO = "ZPARTES" : Endif
      Read[F:ZPT]ZPT1 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "appeldeb"    : TBVAL(NBPAR) = [F:ZPT]PRONUM
      NBPAR += 1 : TBPAR(NBPAR) = "appelfin"    : TBVAL(NBPAR) = [F:ZPT]PRONUM
      NBPAR += 1 : TBPAR(NBPAR) = "datdeb"      : TBVAL(NBPAR) = date$ - 365
#     NBPAR += 1 : TBPAR(NBPAR) = "datefin"     : TBVAL(NBPAR) = [F:ZPT]FINALIZADAT
      NBPAR += 1 : TBPAR(NBPAR) = "bpdeb"       : TBVAL(NBPAR) = [F:ZPT]TECNICOT
      NBPAR += 1 : TBPAR(NBPAR) = "bpfin"       : TBVAL(NBPAR) = [F:ZPT]TECNICOT
      NBPAR += 1 : TBPAR(NBPAR) = "ccptdeb"     : TBVAL(NBPAR) = [F:ZPT]IDTAREA
      NBPAR += 1 : TBPAR(NBPAR) = "ccptfin"     : TBVAL(NBPAR) = [F:ZPT]IDTAREA
    When "GESMFG" # Orden de producción
      If FORMATO="" : FORMATO = "ZRECETTE" : Endif
      If clalev ([F:MFG])<=0   :  Local File MFGHEAD     [F:MFG]  : Endif
      Read[F:MFG]MFG0 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "mfgfcydeb"   : TBVAL(NBPAR) = [F:MFG]MFGFCY
      NBPAR += 1 : TBPAR(NBPAR) = "mfgfcyfin"   : TBVAL(NBPAR) = [F:MFG]MFGFCY
      NBPAR += 1 : TBPAR(NBPAR) = "mfgnumdeb"   : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "mfgnumfin"   : TBVAL(NBPAR) = DOCUMENTOP
#     NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:POH]PRNFLG )
      NBPAR += 1 : TBPAR(NBPAR) = "strdatdeb"   : TBVAL(NBPAR) = [F:MFG]STRDAT
      NBPAR += 1 : TBPAR(NBPAR) = "strdatfin"   : TBVAL(NBPAR) = [F:MFG]ENDDAT
    When "GESPOH" # Pedido Compra
      If FORMATO="" : FORMATO = "BONCDE2" : Endif
      Read[F:POH]POH0 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "commandedeb" : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "commandefin" : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:POH]PRNFLG )
      NBPAR += 1 : TBPAR(NBPAR) = "datedeb"     : TBVAL(NBPAR) = [F:POH]ORDDAT
      NBPAR += 1 : TBPAR(NBPAR) = "datefin"     : TBVAL(NBPAR) = [F:POH]ORDDAT
    When "GESSQH"   # Presupuesto
      If FORMATO="" : FORMATO = "PRESUPUESTO" : Endif
      Read[F:SQH]SQH0 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "devisdeb"    : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:SQH]QUOPRN)
      NBPAR += 1 : TBPAR(NBPAR) = "datedeb"     : TBVAL(NBPAR) = [F:SQH]QUODAT
      NBPAR += 1 : TBPAR(NBPAR) = "datefin"     : TBVAL(NBPAR) = [F:SQH]QUODAT
    When "GESSOH"   # Pedido
      If FORMATO="" : FORMATO = "ARCCLIENT2" : Endif
      Read[F:SOH]SOH0 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "commandedeb" : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "commandefin" : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:SOH]OCNPRN)
      NBPAR += 1 : TBPAR(NBPAR) = "datedeb"     : TBVAL(NBPAR) = [F:SOH]ORDDAT
      NBPAR += 1 : TBPAR(NBPAR) = "datelivdeb"  : TBVAL(NBPAR) = [F:SOH]DEMDLVDAT
    When "GESSDH"   # Entrega
      If FORMATO="" : FORMATO = "BONLIV2" : Endif
      Read[F:SDH]SDH0 = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "livraisondeb": TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:SDH]NDEFLG)
      NBPAR += 1 : TBPAR(NBPAR) = "datedeb"     : TBVAL(NBPAR) = [F:SDH]SHIDAT
    When "GESSIH"   # Factura
      If FORMATO="" : FORMATO = "ZSBONFAC2" : Endif
      Read[F:SIH]SIH0 = DOCUMENTOP
      Read[F:SID]SID0 >= DOCUMENTOP;0
      NBPAR += 1 : TBPAR(NBPAR) = "facturedeb"  : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "facturefin"  : TBVAL(NBPAR) = DOCUMENTOP
      NBPAR += 1 : TBPAR(NBPAR) = "codimp"      : TBVAL(NBPAR) = num$([F:SIH]STARPT)
      NBPAR += 1 : TBPAR(NBPAR) = "datedeb"     : TBVAL(NBPAR) = [F:SID]INVDAT
      NBPAR += 1 : TBPAR(NBPAR) = "datefin"     : TBVAL(NBPAR) = [F:SID]INVDAT
  Endcase

  If FORMATO<>"" Then
      If clalev ([F:ARP])<=0   :  Local File AREPORT     [F:ARP]  : Endif
      Read [F:ARP]ARP0=FORMATO
      If fstat<>0
        Infbox "IMPOSIBLE IMPRIMIR. Informe inexistente   "+FORMATO
      Else
      ##### Subprog ETAT(WETAT,IMPRIMANTE,LANGUE,TRACE,MESSAGE,TBPAR,TBVAL)
      #Call ETAT("ACTION","PREVISU","FRA",1,"MON commentaire",TBPAR(1..NBPAR),TBVAL(1..NBPAR))
      #Call ETAT("ZBONLIV2","ZDOCWEB","SPA",0,"",TBPAR(1..NBPAR),TBVAL(1..NBPAR)) From AIMP3
      Call ETAT(FORMATO,DESTINO,IDIOMA,0,"",TBPAR(1..NBPAR),TBVAL(1..NBPAR)) From AIMP3
      Endif
  Else
      Infbox "IMPOSIBLE IMPRIMIR. No se indicó INFORME a usar"
  Endif
End
