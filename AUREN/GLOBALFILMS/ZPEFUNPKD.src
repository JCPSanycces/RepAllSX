#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
If GUSER="ADMIN"
#Infbox ACTION
Endif
Case ACTION
   When "AF_TABTOPKD1" :   Gosub AF_TABTOPKD1
   When "PCKCAP"       :   Gosub PCKCAP
   When "BEFWRISPH"    :   Gosub BEFWRISPH
   When "TOT_GROWEI"   :   Gosub TOT_GROWEI
Endcase
Return

$AF_TABTOPKD1
Local Integer II

#JLPR 16-02-17 INI
Local Decimal KG_BOB
Local Integer RLIN   : RLIN=0
# Si vendo en KGS y ZCTDREAL<>QTY entonces:
#   - Saco peso bobina
#   - Uso ese peso para determinar peso NETWEI
#   - En la 1ˆ bobina pongo la difˆ del redondeo, motivo por el cual:
#           - Asumo que NO SE PUEDE ENVIAR PARTE DE UNA LINEA
#           - Ordeno rejilla por VCRLIN, para saber cuando cambio de lˆ
Sorta [M:PKD1]NBLIG [M:PKD1]NBLIG Order By [M:PKD1]VCRLIN(indice)
#JLPR 16-02-17  FIN

If clalev([F:SDDX]) = 0 Local File SDELIVERYD [SDDX] Endif
For II=0 To [M:PKD1]NBLIG
   Raz [SDDX]
   Read [SDDX]SDD0=[F:SDH]SDHNUM;[M:PKD1]VCRLIN(II)
   [M:PKD1]ZANCHO(II)    = [F:SDDX]ZANCHO
   [M:PKD1]ZLONGITUD(II) = [F:SDDX]ZLONGITUD
   [M:PKD1]ZMANDRIL(II)  = [F:SDDX]ZMANDRIL
#   Affzo [M:PKD1]ZANCHO(II)
#   Affzo [M:PKD1]ZLONGITUD(II)
#   Affzo [M:PKD1]ZMANDRIL(II)
   #JLPR 16-02-17 INI
#   If GUSER="ADMIN"
   If [F:SDDX]SAU="KG" and [F:SDDX]ZCTDREAL <>[F:SDDX]QTY
      KG_BOB= [F:SDDX]ZCTDREAL/[F:SDDX]ZQTYBOB
      Call QTEARR([M:PKD1]QTYSTU(II), [F:SDDX]SAU) From TRTDIV
      If RLIN<>[M:PKD1]VCRLIN(II)
        KG_BOB+=[F:SDDX]ZCTDREAL-(KG_BOB*[F:SDDX]ZQTYBOB)
        RLIN=[M:PKD1]VCRLIN(II)
      Endif
      [M:PKD1]QTY(II)       = KG_BOB
      [M:PKD1]QTYSTU(II)    = [M:PKD1]QTY(II) * [M:PKD1]PCUSTUCOE(II)
      Call QTEARR([M:PKD1]QTYSTU(II), [F:SDDX]STU) From TRTDIV
      [M:PKD1]NETWEI(II)    = [M:PKD1]QTYSTU(II) * [F:ITM]ITMWEI
      [M:PKD1]NETWEIPCK(II) = [M:PKD1]QTYSTU(II) * GWUNTWEI
      Gosub TOT_GROCAP From FUNPKD
   Endif
#   Endif
   #JLPR 16-02-17 FIN
Next
Affzo [M:PKD1]20
Return

$PCKCAP
Return

$BEFWRISPH
[F:SPH]ZPCKLEN=[M:PKD1]ZPCKLEN
[F:SPH]ZPCKWID=[M:PKD1]ZPCKWID
[F:SPH]ZPCKHEI=[M:PKD1]ZPCKHEI
[F:SPH]ZPCKWEI=[M:PKD1]ZPCKWEI
[F:SPH]VOL=arr([M:PKD1]ZPCKLEN*[M:PKD1]ZPCKWID*[M:PKD1]ZPCKHEI/1000000,0.001)

[F:SPH]PCKWEI=[M:PKD1]ZPCKWEI
Return

$TOT_GROWEI

Return
