$ACTION
If 1=1 Then Return Endif
If clalev([M:SDH1]) Then
 # If nolign > 0
     Infbox "ACTION" - ACTION  - "Precio Neto F/M" - num$([M:SDH1]DLVINVNOT) - num$([M:SDH1]DLVNOT)
 # Else
  #   Infbox "ACTION" - ACTION  - "Precio Neto F/M" - num$([F:SDD]NETPRI)
  # Endif
Else
  Infbox "ACTION" - ACTION
Endif
Return
