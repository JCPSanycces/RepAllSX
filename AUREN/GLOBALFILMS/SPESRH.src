#> MA 20181204 - ocurre que hacen un pickin de una lÚnea de entrega completa, hacen la entrada manual de los sublotes y seguidamente
#       modifican el nºmero de bobinas por la lÚnea de la devoluciµn pero esta no borra lo anterior
#       para ello deben borrar los sublotes por entrada manual y luego poner el mismo nºmero de bobinas que sublotes indicados
# si el lote de la lÚnea es $, significa que estÃn poniendo varios lotes y sublotes en una misma lÚnea de entrega
#**
#* Comprueba que nºmero bobinas sea igual a numero de sublotes
#*!
$VERIF_BOBINAS
Local Integer LLIN

For LLIN=0 To [M:SRH1]NBLIG-1
  # bobinas y sublotes deben coincidir y todas sus lÚneas sean del mismo lote
  If [M:SRH1]ZQTYBOB(LLIN) <> [M:SRH1]NBSLO(LLIN) and [M:SRH1]LOT(LLIN) <> "$" Then
    GERR=1
    GMESSAGE = "Debe ajustar las bobinas de la lÚnea "+num$(LLIN+1)+"\N¤ de bobinas ("+num$([M:SRH1]ZQTYBOB(LLIN))+") no coincide con el N¤ de sublotes registrados ("+num$([M:SRH1]NBSLO(LLIN))+")"
    OK=0
    GPE=1
    Break
  Endif

  # no permite registrar lÚneas con 0 bobinas (restos)
  If [M:SRH1]ZQTYBOB(LLIN) = 0 Then
    GERR=1
    GMESSAGE = "Revisar la lÚnea "+num$(LLIN+1)+"\No se permite registrar lÚneas con 0 bobinas"
    OK=0
    GPE=1
    Break
  Endif

  # en modo creaciµn, obligamos a marcar como "SÚ" el campo ZREVLOT, asÚ obligamos a que salte la pantalla de entrada modificaciµn de cantidades
  If [M:SRH1]CREFLG(LLIN)=0 and [M:SRH1]ZREVLOT(LLIN) <> 2 Then
    GERR=1
    GMESSAGE = "Revisar la lÚnea "+num$(LLIN+1)+"\Debe marcar el campo 'Rev. lote' a SÚ y registrar los sublotes de la lÚnea."
    OK=0
    GPE=1
    Break
  Endif

Next



Return
#< MA
