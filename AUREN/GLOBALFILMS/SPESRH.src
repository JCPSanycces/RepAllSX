Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
Local Char MSG(255)
Local Integer BOB_ENT,BOB_DEV
If [M:SRH1]DETSDHNUM(nolign-1)<>''
  BOB_ENT=func BOB_ENT([M:SRH1]DETSDHNUM(nolign-1),[M:SRH1]SDDLIN(nolign-1))
  BOB_DEV=func BOB_DEV([M:SRH1]DETSDHNUM(nolign-1),[M:SRH1]SDDLIN(nolign-1))
Endif
#> FC 20181129 - Aþadimos [M:SRH1]ZQTYBOB(nolign-1) a la comprobaciµn

If [M:SRH1]CREFLG(nolign-1) = 0 Then
  If [M:SRH1]DETSDHNUM(nolign-1)<>'' and VALEUR>(BOB_ENT-BOB_DEV)
    MSG= "Imposible devolver mas bobinas de las entregadas\"+num$(BOB_ENT)+" Bobinas Entregadas\"+num$(BOB_DEV)+" Bobinas Devueltas\"+num$(BOB_ENT-BOB_DEV)+" Bobinas a devolver"
    Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Else
    [M:SRH1]ZQTYBOB(nolign-1)=VALEUR
    Call CALCULAQTY(nolign-1)
  Endif
Else
  #If [M:SRH1]DETSDHNUM(nolign-1)<>'' and VALEUR>(BOB_ENT-BOB_DEV)
  If [M:SRH1]DETSDHNUM(nolign-1)<>'' and VALEUR>(BOB_ENT-BOB_DEV+[M:SRH1]ZQTYBOB(nolign-1))
  #< FC 20181129
    MSG= "Imposible devolver mas bobinas de las entregadas\"+num$(BOB_ENT)+" Bobinas Entregadas\"+num$(BOB_DEV)+" Bobinas Devueltas\"+num$(BOB_ENT-BOB_DEV)+" Bobinas a devolver"
    Call ERREURT(MSG,0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Else
    [M:SRH1]ZQTYBOB(nolign-1)=VALEUR
    Call CALCULAQTY(nolign-1)
  Endif
Endif
#Local Integer NOL
#Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
#
#If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
#Raz [F:ITP]
