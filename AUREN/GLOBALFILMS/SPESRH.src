#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestiµn de la mÃscara SRH1 (Especifico)
$ACTION
Case ACTION
   When "SETBOUT"     :   Gosub SETBOUT
   When "INICRE_LIG"  :   Gosub INICRE_LIG
   When "INIMOD_LIG"  :   Gosub INICRE_LIG
   When "VERIF_CRE"   :   Gosub VERIF_CRE   #> MA
   When "VERIF_MOD"   :   Gosub VERIF_MOD   #> MA
   When Default
Endcase
Return


$SETBOUT
Local Integer LI

If clalev([F:SRDX])<=0 : Local File SRETURND [SRDX] : Endif

Filter [SRDX] Where SRHNUM=[M:SRH0]SRHNUM
For [SRDX]
   [M:SRH1]ZSIHNUM=[F:SRDX]SIHNUM
Next
Filter [SRDX]

[M:SRH1]ZIMPDOCAI=0
For LI=0 To [M:SRH1]NBLIG-1
   If [M:SRH1]NETPRI(LI)<>0
   [M:SRH1]ZIMPLIN(LI)=arr([M:SRH1]QTY(LI)*[M:SRH1]NETPRI(LI),0.01)
   Else
   [M:SRH1]ZIMPLIN(LI)=arr([M:SRH1]QTY(LI)*[M:SRH1]ZPRIREAL(LI),0.01)
   Endif
   [M:SRH1]ZIMPDOCAI=[M:SRH1]ZIMPDOCAI+[M:SRH1]ZIMPLIN(LI)
   Affzo [M:SRH1]ZIMPLIN(LI)

  #[M:SRH1]SAUSTUCOE(LI) = arr([M:SRH1]SAUSTUCOE(LI), 0.01)
  #Affzo [M:SRH1]SAUSTUCOE(LI)
Next
Affzo [M:SRH1]ZSIHNUM
Affzo [M:SRH1]ZIMPDOCAI
Return

$INICRE_LIG
[F:SRD]ZQTYKG=0
[F:SRD]ZQTYM2=0
If [F:SRD]SAU="M2"
   [F:SRD]ZQTYKG=[F:SRD]QTYSTU
# No tiene sentido alguno / QTY ya estÃ en M2 FJCP 28-12-2018
# If [F:SRD]SAUSTUCOE<>0
#      [F:SRD]ZQTYM2=arr([F:SRD]QTY/[F:SRD]SAUSTUCOE,0.01)
#   Endif
   [F:SRD]ZQTYM2=[F:SRD]QTY
Endif
If [F:SRD]SAU="KG"
   [F:SRD]ZQTYKG=[F:SRD]QTY
   [F:SRD]ZQTYM2=[F:SRD]QTY*[F:SRD]SAUSTUCOE
Endif
Return



Subprog C_NBLIG
Local Integer NOL
#Local Decimal LIMPORTE_NUEVO, LPRECIO_NUEVO, LPRECIO_NETO
#If 1=1 : End : Endif
  NOL = nolign-1
  If clalev([F:BPCX])<=0  : Local File BPCUSTOMER [F:BPCX]  : Endif

  Read [F:BPCX]BPC0 = [M:SRH0]BPCORD

  #Si el Cliente Factura por M2 bloqueamos la cantidad real para que no se pueda modificar, y recalculamos el precio.
  #JLPR 13-02-17 Si M2 bloqueamos CANTIDADES, pues estas son el resultado de ANCHO*LONG*BOB
  Diszo [M:SRH1]SAU(NOL)
  If [F:BPCX]ZSAUM2 = 2 or [M:SRH1]SAU(NOL) ="M2" Then
    Diszo [M:SRH1]ZCTDREAL(NOL)
    Diszo [M:SRH1]EXTQTY(NOL)
    Diszo [M:SRH1]QTY(NOL)
    Diszo [M:SRH1]SAUSTUCOE(NOL)
  Endif
#  #Recalculamos precio
#  If [M:SRH1]ITMREF(NOL) <> "" Then
#    Call AM_ZCTDREAL([M:SRH1]ZCTDREAL(NOL))
#  Endif

#> MA 20181204 - ocurre que hacen un pickin de una lÚnea de entrega completa, hacen la entrada manual de los sublotes y seguidamente
#       modifican el nºmero de bobinas por la lÚnea de la devoluciµn pero esta no borra lo anterior
#       para ello deben borrar los sublotes por entrada manual y luego poner el mismo nºmero de bobinas que sublotes indicados
# si el lote de la lÚnea es $, significa que estÃn poniendo varios lotes y sublotes en una misma lÚnea de entrega
  If [M:SRH1]ZQTYBOB(NOL) <> [M:SRH1]NBSLO(NOL) and [M:SRH1]LOT(NOL) <> "$" Then
    Call ERREURT("Debe ajustar las bobinas de la lÚnea "+num$(NOL+1)+"\N¤ de bobinas ("+num$([M:SRH1]ZQTYBOB(NOL))+") no coincide con el N¤ de sublotes registrados ("+num$([M:SRH1]NBSLO(NOL))+")",1)
& From GESECRAN   #0-Informativo, 1-Error

    #[M:SRH1]ZQTYBOB(NOL)=[M:SRH1]NBSLO(NOL) : Affzo [M:SRH1]ZQTYBOB(NOL)
    #Call CALCULAQTY(NOL)
#< MA
  Endif
End

Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
If [M:SRH1]SAU(nolign-1) ="M2" Then
  mkstat=2
Endif
End

Subprog AM_ZCTDREAL(VALEUR)
Variable Decimal VALEUR
#Local Integer NOL
#Local Decimal LIMPORTE_NUEVO, LPRECIO_NUEVO, LPRECIO_NETO, LCTD_REAL
#If 1=1 : End : Endif
End


