Subprog CALCULAQTY(NOL)
Value Integer NOL
Local Decimal LKGS, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]


If [F:ITM]ZFABCOR=2
   LESPESOR=0
   If [F:ITP]ZESPESORP<>0
      LESPESOR=[F:ITP]ZESPESORP
   Else
      LESPESOR=[F:ITM]ZESPESOR
   Endif
   LDENSIDAD=0
   If [F:ITP]ZDTYP<>0
      LDENSIDAD=[F:ITP]ZDTYP
   Else
      LDENSIDAD=[F:ITM]DTY
   Endif
   LDENSIDAD=(LDENSIDAD*1000000/1000)
   LFACTOR=0
   If [F:ITM]ZFACTOR=0
      LFACTOR=LDENSIDAD*LESPESOR
   Else
      LFACTOR=[F:ITM]ZFACTOR
   Endif

   LSUPERFICIE=([M:SRH1]ZANCHO(NOL)/1000)*[M:SRH1]ZLONGITUD(NOL)
   LKGS       =LSUPERFICIE*LFACTOR

   If [M:SRH1]ZQTYBOB(NOL)<>0
      If [M:SRH1]SAU(NOL)="KG"
        [M:SRH1]EXTQTY(NOL)=arr([M:SRH1]ZQTYBOB(NOL)*LKGS,0.0001)
        [M:SRH1]QTY(NOL)=[M:SRH1]EXTQTY(NOL)

#> 70007
        #Si viene de una entrega, la cantidad viene de ahÚ y no calculada. Se elimina el if (1=2) porque si que hay que
        #recalcular las cantidades
        #If [M:SRH1]DETSDHNUM(NOL) <> "" and [M:SRH1]SDDLIN(NOL) <> 0 and 1=2 Then
        #  If !clalev([ZD]) : Local File SDELIVERYD [ZD] : Endif
        #  Read [ZD]SDD0 = [M:SRH1]DETSDHNUM(NOL);[M:SRH1]SDDLIN(NOL)
        #  If !fstat Then
        #    [M:SRH1]EXTQTY(NOL)=arr(([M:SRH1]ZQTYBOB(NOL)*[ZD]QTY)/[ZD]ZQTYBOB,0.0001)
        #    [M:SRH1]QTY(NOL)=[M:SRH1]EXTQTY(NOL)
        #  Endif
        #  Close Local File [ZD]
        #Endif
#< 70007

      Endif
      If [M:SRH1]SAU(NOL)="M2"
         [M:SRH1]EXTQTY(NOL)=arr([M:SRH1]ZQTYBOB(NOL)*LSUPERFICIE,0.01)
         [M:SRH1]QTY(NOL)=[M:SRH1]EXTQTY(NOL)
      Endif
      #Gosub CAL_QTYPUU From SUBPTHB
      Affzo [M:SRH1]EXTQTY(NOL)
      Affzo [M:SRH1]QTY(NOL)
      Gosub CALCULA_QTY
   Endif
   #Affzo [M:SRH1]ZFACTOR(NOL)
Endif
End

$CALCULA_QTY
    [M:SRH1]ZCTDREAL(NOL)=[M:SRH1]QTY(NOL)
    Affzo [M:SRH1]ZCTDREAL(NOL)

#> MA 20181204 - solo actualizo este campo si estoy en modo creaciµn de lÚnea...
    If [M:SRH1]CREFLG(NOL) = 0 Then
        [M:SRH1]NBSLO(NOL)=[M:SRH1]ZQTYBOB(NOL)
        Affzo [M:SRH1]NBSLO(NOL)
    Endif
#< MA 20181204

    Call STKCTRNBSLO([M:SRH1]NBSLO(NOL), [M:SRH1]SAU(NOL), [M:SRH1]QTY(NOL)) From STKACT
    # -- calcul quantitÕ en US
    Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE
    # -- alimentation du dÕduit facture
    If [M]XQTY(NOL) = 0 & [M]QTY(NOL) <> 0
       [M]RTNINVUPD(NOL) = 1
       If [M]DETSDHNUM(NOL) <> "" & [M]SIHNUMFAC(NOL) = ""
#          [M]RTNINVUPD(NOL) = 2
          If GDLVRTNCNO=1
             # Pas d'avoir si la livraison n'est pas facturÕe, ce sera dÕduit de la facture
             [M]RTNCNOFLG(NOL) = 1
             [M]RTNINVUPD(NOL) = 2
          Else
             # Avoir si la livraison n'est pas facturÕe, ce ne sera pas dÕduit de la facture
             [M]RTNCNOFLG(NOL) = 2
             [M]RTNINVUPD(NOL) = 1
          Endif
       Endif
    Endif
    Affzo [M]RTNINVUPD(NOL), RTNCNOFLG(NOL)
    Affzo [M]QTYSTU(NOL)

#> MA 20181213 - recalculamos QTYSTU cuando son M2
  If [M:SRH1]SAU(NOL)="M2" Then
    [M:SRH1]QTYSTU(NOL) = arr((arr([M:SRH1]QTYSTU(NOL)/[M:SRH1]ZQTYBOB(NOL),0.0001)*[M:SRH1]ZQTYBOB(NOL)),0.0001)
    Affzo [M:SRH1]QTYSTU(NOL)
  Endif
Return

Funprog LINEAS_SD2(ART)
Value Char ART
Infbox ART
#[F:SDD]ITMREF-'_'-num$([F:SDD]ZANCHO)-'_'-num$([F:SDD]ZLONGITUD)-' '-mess(72,191,1)-num$([F:SDD]QTY)-[F:SDD]SAU-' '-mess(73,191,1)-num$([F:SDD]RTNQTY)-' Bob.'-num$([F:SDD]ZQTYBOB)
#func SPESRH.LINEAS_SD2([F:SDD]ITMREF)
Local Char TXT(255)
Raz TXT
TXT-=[F:SDD]ITMREF-'_'-num$([F:SDD]ZANCHO)-'_'-num$([F:SDD]ZLONGITUD)
TXT-=' '-mess(72,191,1)-' '-num$([F:SDD]ZQTYBOB)-' Bob '
If [F:SDD]SAU="M2"
TXT-=num$(arr([F:SDD]QTY,0.01))
Else
TXT-=num$(arr([F:SDD]QTY,0.0001))
Endif
If [F:SDD]RTNQTY<>0
TXT-='  '-mess(73,191,1)-' '-num$(func BOB_DEV([F:SDD]SDHNUM,[F:SDD]SDDLIN))-' Bob '
If [F:SDD]SAU="M2"
TXT-=num$(arr([F:SDD]RTNQTY,0.01))
Else
TXT-=num$(arr([F:SDD]RTNQTY,0.0001))
Endif
Endif
TXT-=[F:SDD]SAU
End TXT

Funprog BOB_ENT(ENT,LIN)
Value Char ENT
Value Integer LIN
Local Integer BOB
Local Char TXT(255)(10),BD_TIPO(1)
Raz TXT,BOB
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
TXT(0)="select sum(ZQTYBOB_0) "
TXT(1)="from SDELIVERYD "
TXT(2)="where SDHNUM_0='"+ENT+"' and SDDLIN_0="+num$(LIN)
For (Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
  BOB=FBOB
  Break
Next
End BOB

Funprog BOB_DEV(ENT,LIN)
Value Char ENT
Value Integer LIN
Local Integer BOB
Local Char TXT(255)(10),BD_TIPO(1)
Raz TXT,BOB
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
TXT(0)="select sum(ZQTYBOB_0) "
TXT(1)="from SRETURND "
TXT(2)="where SDHNUM_0='"+ENT+"' and SDDLIN_0="+num$(LIN)
For (Decimal FBOB) From BD_TIPO Sql TXT As [MYT]
  BOB=FBOB
  Break
Next
End BOB
End


######################################################################################
#> 70281
Subprog AM_RTNSTOUPD(VALEUR)
Variable Integer VALEUR

# si seleccionan si debemos introducir el mismo nºmero de bobinas en el nºmero de sublotes
If VALEUR = 2 Then
  [M:SRH1]NBSLO(nolign-1) = [M:SRH1]ZQTYBOB(nolign-1)
  Affzo [M:SRH1]NBSLO(nolign-1)
Endif

End

######################################################################################
#> 70281
Subprog AS_NBSLO(VALEUR)
Variable Decimal VALEUR

  # el mismo nºmero de bobinas en el nºmero de sublotes
  VALEUR = [M:SRH1]ZQTYBOB(nolign-1)
  Affzo [M:SRH1]NBSLO(nolign-1)
End

######################################################################################
#> 70281
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR

# no puede tener un nºmero diferente de sublotes y bobinas
If VALEUR <> [M:SRH1]ZQTYBOB(nolign-1) Then
  GERR=1
  GMESSAGE = "Debe tener el mismo nºmero de bobinas"
  mkstat = 2
Endif

End


