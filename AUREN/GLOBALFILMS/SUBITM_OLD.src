######################################################################################
Subprog C_EANCOD(VALEUR)
Variable Char    VALEUR()
# Issue 86722 - 2013-01-07 by MAE : the EANCOD unicity is not controlled by import
#--- Issue 95240
#If VALEUR <>"" &  VALEUR <> [F:ITM]EANCOD & !GIMPORT
If VALEUR <>"" &  (VALEUR <> [M:ITM1]EANCOD | GREP="D") & !GIMPORT
#---
  Filter [ITM3] Where EANCOD=VALEUR
  If rowcount([F:ITM3]) > 0
    mkstat=2
    GMESSAGE=mess(61,127,1)
  Endif
Endif
End


