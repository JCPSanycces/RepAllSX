Subprog AS_RCPFLG(VALEUR)
#------------------#
# Flag réceptionné #
#------------------#
Variable Integer  VALEUR
# Issue 112878 - 2015-12-11 by MAE : Avant saisie remplacé par un message en VERIF_CRE
#If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
#    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
#Endif
## code réception forcément ŕ OUI pour art géré en stock ou Sous-traitance
#If [M:ITM2]STOMGTCOD > 1 | [F:ITG]SCSFLG = 2 VALEUR=2 : mkstat=2 : Endif
End


Subprog AV_PRQFLG(VALEUR)
#---------#
# Flag DA #
#---------#
Variable Integer VALEUR
If VALEUR=0 VALEUR=1 : Endif
End

Subprog C_PRQFLG(VALEUR)
#---------#
# Flag DA #
#---------#
Variable Integer VALEUR
If [M:ITS]CTMFLG=2 & VALEUR=2
   GMESSAGE=mess(163,196,1) : VALEUR=1 : mkstat=2 : End
Endif

# gestion des affectations v6 (llc)
If find(GREP,"C","D") | VALEUR <> 2 : End : Endif

If clalev ([F:PTO])  = 0 : Local File PARMTO     [PTO]  : Endif
If clalev ([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif

For [ITF]ITF0 Where ITMREF = [M:ITM0]ITMREF
    If [F:ITF]PTOCOD <> ""
        If [F:PTO]PTOCOD <> [F:ITF]PTOCOD
            Read [PTO]PTO0=[F:ITF]PTOCOD
            If fstat : Raz [PTO] : Endif
        Endif
        # FGR 09/02/2010 : X3SUIVI60986
        #If [F:PTO]PTODIR = 2 : GMESSAGE=mess(945,196,1) : VALEUR=1 : mkstat=2 : End : Endif
        If [F:PTO]PTODIR = 2 : GMESSAGE=mess(945,196,1) : VALEUR=1 : mkstat=2 : Break : Endif
    Endif
Next
# FGR 09/02/2010 : X3SUIVI60986
If mkstat Then
  End
Endif
End

Subprog AS_VACITM(VALEUR)
#-------------#
# Niveau taxe #
#-------------#
Variable Char     VALEUR
#MAE, bg71720, on enléve le test, si catégorie acheté ou vendu, le niveau de taxe doit ętre accessible
#If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
#    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
#Endif
#If [F:ITG]MFGFLG = 2 & [F:ITG]SALFLG<2 mkstat = 2 Endif
End

Subprog C_VACITM(VALEUR)
#-------------#
# Niveau taxe #
#-------------#
Variable Char     VALEUR
# fantôme non vendu : pas de controle  # Bug 11655  (26/11/01)
If [F:ITG]MFGFLG = 2  & [F:ITG]SALFLG<2 End Endif
Local Integer TYP_OK
TYP_OK = 1
# "le 1er niveau doit correspondre ŕ une taxe de type TVA"
# Issue 109807 - 2015-07-28 by SR : Afficher le libellé évalué dans le message
If indice = 0 & VALEUR = "" : mkstat=2 : GMESSAGE=mess(210,183,1)-num$(indice+1)+":"-  mess(10,123,1) : Endif
If indice = 0 & VALEUR <> ""
   If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif
# recherche de tous les régimes combinés ŕ ce niveau de taxe
   For [TVC] Where VACITM = VALEUR
        If [F:TVC]VATTYP<>1  TYP_OK=0 : Break  Endif
   Next
   If TYP_OK = 0 : mkstat=2 : GMESSAGE = mess(133,199,1) : Endif
Endif
End





######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
If [F:ITG]ITMREFCOU="" & VALEUR=""
    mkstat=2
Endif
# Issue X3-133036 - 2019-05-17 by MAE : ajout du controle sur le format pour les web service
If GWEBSERV
  If len(vireblc(format$("K:20c",VALEUR),2))=0
    GMESSAGE = mess(149,100,1)
    mkstat =2
  Endif
Endif
# End issue X3-133036
End

