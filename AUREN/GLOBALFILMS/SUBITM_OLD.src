Subprog AM_SHL(VALEUR)
Variable Decimal VALEUR
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
LCOD = [M:ITM2]EXYMGTCOD
LSHL = VALEUR
LUOM = [M:ITM2]SHLUOM
LDLU = [M:ITM2]DLU
Gosub CALDLULTI
[M:ITM2]DLULTI = WDLULTI
Affzo [M:ITM2]DLULTI
LDLU = [M:ITU]DLUBPC
Gosub CALDLULTI
[M:ITU]DLULTI  = WDLULTI
[M:ITU]XDLULTI = WDLULTI
Affzo [M:ITU]XDLULTI
End

Subprog AM_SHLUOM(VALEUR)
Variable Integer VALEUR
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
LCOD = [M:ITM2]EXYMGTCOD
LUOM = VALEUR
LSHL = [M:ITM2]SHL
LDLU = [M:ITM2]DLU
Gosub CALDLULTI
[M:ITM2]DLULTI = WDLULTI
Affzo [M:ITM2]DLULTI
LDLU = [M:ITU]DLUBPC
Gosub CALDLULTI
[M:ITU]DLULTI  = WDLULTI
[M:ITU]XDLULTI = WDLULTI
Affzo [M:ITU]XDLULTI

End

Subprog AM_DLU(VALEUR)
Variable Decimal VALEUR
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
LCOD = [M:ITM2]EXYMGTCOD
LSHL = [M:ITM2]SHL
LUOM = [M:ITM2]SHLUOM
LDLU = VALEUR
Gosub CALDLULTI
[M:ITM2]DLULTI = WDLULTI
Affzo [M:ITM2]DLULTI
LDLU = [M:ITU]DLUBPC
Gosub CALDLULTI
[M:ITU]DLULTI  = WDLULTI
[M:ITU]XDLULTI = WDLULTI
Affzo [M:ITU]XDLULTI


End


######################################################################################

$CALDLULTI
Local    Decimal WJOU
Raz WDLULTI
If LCOD = 3 | LCOD = 4 | LCOD < 2
   Return
Endif
If LUOM = 1
   WJOU = LSHL
Elsif LUOM  = 2
   WJOU = LSHL*30
Endif
WJOU  = (WJOU * LDLU) + 0.5
WDLULTI = WJOU
Return
