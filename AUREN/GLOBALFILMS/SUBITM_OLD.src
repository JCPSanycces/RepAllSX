######################################################################################
Subprog AM_ITMCPRCOE(VALEUR)
Variable Decimal VALEUR
Local Integer OK: OK=1
# Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
#If [M:ITM4]ITMSTCNUM <> "" & !GIMPORT
If [M:ITM4]ITMSTCNUM <> ""
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  # Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
  If GIMPORT
    OK = 2
  Endif
  If OK=1
    VALEUR = 1
  Else
    [M:ITM4]ITMSTCNUM = ""
    Affzo [ITM4]ITMSTCNUM
  Endif
Endif
End

Subprog AM_ITMCPRAMT(VALEUR)
Variable Decimal VALEUR
Local Integer OK : OK=1
# Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
#If [M:ITM4]ITMSTCNUM <> "" & !GIMPORT
If [M:ITM4]ITMSTCNUM <> ""
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  # Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
  If GIMPORT
    OK = 2
  Endif
  If OK = 1
    VALEUR = 0
  Else
    [M:ITM4]ITMSTCNUM=""
    Affzo [ITM4]ITMSTCNUM
  Endif
Endif
End

Subprog C_ITMSTCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET
If VALEUR <> ""
  If [F:STCH]STCNUM<>VALEUR
    Read [STCH]STCH0=VALEUR
  #Look [STCH] STCH0=VALEUR
    If fstat GMESSAGE=mess(1119,196,1) : mkstat=2 : Endif
  Endif
  If !mkstat & [F:STCH]ENAFLG=1
    GMESSAGE=mess(2,126,1)
    mkstat=2
  Endif
Endif

End

Subprog AM_ITMSTCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK : OK=1
# Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
#If ([M:ITM4]ITMCPRAMT<> 0 | [M:ITM4]ITMCPRCOE <> 1) & !GIMPORT
If ([M:ITM4]ITMCPRAMT<> 0 | [M:ITM4]ITMCPRCOE <> 1)
  Call OUINON(mess(602,199,1), OK) From GESECRAN  # "un coeff ou coűt est paramétré"
  # Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
  If GIMPORT
    OK = 2
  Endif
  If OK=1
    VALEUR =""
  Else
    [M:ITM4]ITMCPRCOE = 1 : [M:ITM4]ITMCPRAMT = 0
    Affzo [ITM4]ITMCPRCOE, ITMCPRAMT
  Endif
Endif
End

######################################################################################
Subprog AV_ALG(VALEUR)
Variable Char    VALEUR()

# 98144 - food allergens
# Disable entry if product is Manufactured
If [M:ITM1]MFGFLG=2 & func AFNC.ACTIV("FOA")
    Diszo [M:ITM2]ALG
Else
    Actzo [M:ITM2]ALG
Endif

End

######################################################################################
Subprog C_ALG(VALEUR)
Variable Char    VALEUR()

# 98144 - food allergens.sn
Local    Integer I_COUNT,I_TIMES,I
Local    Char    A_ALG(1)(1..50)  # Declare array of 50 one char values
Local    Char    C_VALEUR(20) : C_VALEUR = vireblc(VALEUR,4)
Local    Char    C_ONE(1)

If C_VALEUR="" : End : Endif

If !clalev([F:ADI]) : Local File ATABDIV    [ADI] : Endif  # Miscellaneous Tables

# Load all valid constraint codes
For [ADI] Where NUMTAB=404
  I_COUNT += 1
  A_ALG(I_COUNT) = [F:ADI]CODE
Next

# Check for any non-valid codes
For I_COUNT=1 To len(C_VALEUR)
  C_ONE = mid$(C_VALEUR,I_COUNT,1)

  #Check for valid entries
  If !(find(C_ONE,A_ALG(1..50)))
    GMESSAGE=mess(3,3501,1)
    mkstat=2 : Break
  Endif

  #Check for dupes
  Raz I,I_TIMES
  Repeat I=instr(I+1,C_VALEUR,C_ONE) : If I<>0 : I_TIMES+=1 : Endif : Until I=0
  If I_TIMES>1
    GMESSAGE=mess(4,3501,1)
    mkstat=2 : Break
  Endif

Next

[M:ITM2]ALGDAT = date$
# 98144 - food allergens.en

End

