Subprog AM_TRKCOD(VALEUR)
Variable Integer VALEUR
# Attention valeur incohérente  : gestion série "entrée - sortie" et tracabilité "agrégée" !

#--- Issue X3-38364
#If dim([M:ITM2]SERMGTCOD)>0
##--- Issue 110327
#  #If VALEUR = 3 & [M:ITM2]SERMGTCOD = 3
#  If VALEUR = 3 & [M:ITM2]SERMGTCOD >= 3
#  #---
#   Call MESSAGE(mess(553,199,1)) From GESECRAN
#  Endif
#Endif
#---
#--- Bug 55665
If dim([M:ITM2]TRKLEV)>0
   If VALEUR=1
      [M:ITM2]TRKLEV=1
      Diszo [M:ITM2]TRKLEV
   Else
      Actzo [M:ITM2]TRKLEV
   Endif
   Affzo [M:ITM2]TRKLEV
Endif
#---

End

#--- Bug 55665
Subprog C_TRKLEV(VALEUR)
Variable Integer VALEUR
If [M:ITM2]TRKCOD<2
   VALEUR=1
Endif
# Si niveau = série et pas de gestion de série E/S
#--- Issue 110327
#If VALEUR=4 & [M:ITM2]SERMGTCOD<>3
If VALEUR=4 & [M:ITM2]SERMGTCOD<3
#---
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
# Si niveau = s-lot et pas de gestion de s-lot
If VALEUR=3 & [M:ITM2]LOTMGTCOD<>4
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
# Si niveau = lot et pas de gestion de lot
If VALEUR=2 & [M:ITM2]LOTMGTCOD<2
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
End
#---

