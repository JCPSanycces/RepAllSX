Subprog AM_SHLLTI(VALEUR)
Variable Decimal VALEUR
If VALEUR  = 0
   Raz [M:ITM2]NEWLTISTA
   Raz [M:ITM2]SHLLTIUOM
   Affzo [M:ITM2]NEWLTISTA
   Affzo [M:ITM2]SHLLTIUOM
   Diszo [M:ITM2]NEWLTISTA
   Diszo[M:ITM2]SHLLTIUOM
Else
   Actzo [M:ITM2]NEWLTISTA
   Actzo [M:ITM2]SHLLTIUOM
Endif
End

Subprog C_NEWLTISTA(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:ITM2]SHLLTI <> 0
   GMESSAGE = mess(10,123,1) #"valeur obligatoire "
   mkstat = 2
Endif
If [M:ITM2]SHLLTI <> 0 & instr(1,"AQR",VALEUR) = 0
 GMESSAGE = mess(21,199,1)
 mkstat = 2
Endif

End

Subprog C_DLU(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0 | VALEUR = 0
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
Endif
End

