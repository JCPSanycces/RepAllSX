Subprog AP_FLGFAS(VALEUR)
Variable Integer VALEUR
  If VALEUR <> 2
    Effzo [M:ITM5]ACGGRP
    Grizo [M:ITM5]NBFAM
  Else
    Actzo [M:ITM5]NBFAM
  Endif
  Affzo [M:ITM5]NBFAM
End

######################################################################################
# FQ110703
Subprog AS_ACGGRP(VALEUR)
Variable Char    VALEUR()

  If ( GLEGACT = G_OUI)  # Issue 114412 Si on gčre le multi-législation
  # Pour la sélection
    If dim([M]LEGGRP)>0  # Issue 114412
      GCURLEG = [M]LEGGRP(nolign-1)
    Endif
  Endif

End
######################################################################################

Subprog C_ACGGRP(VALEUR)
Variable Char    VALEUR()
Local    Integer STAT
Local    Char    MESSA

If VALEUR="" : End : Endif

# X3-54381
If (GLEGACT = G_OUI) Then
# FQ110703
  If clalev([F:FAM])=0  : Local File FASFAM   [FAM]  : Endif
  Read [FAM]FAM0 = VALEUR
  If fstat = 0
    If func TRTFAS.IS_LEG_ACGGRP_OK(GCURLEG, VALEUR) = 0 Then
      GERR= 1
      GMESSAGE = mess(683, GML_MSGFAS, 1) - " " - GCURLEG
      mkstat = 2
    Endif
  Endif
Endif

End

