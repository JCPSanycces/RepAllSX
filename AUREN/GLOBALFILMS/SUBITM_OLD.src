######################################################
#  Actions sur champs ecran                          #
######################################################

#------------#
# Ecran ITM0 #
#------------#

Subprog C_TCLCOD(VALEUR)
#--------------------#
# Contrôle catégorie #
#--------------------#
Variable Char     VALEUR
If (find(GREP,"C","D") | [M:ITM0]ITMREF <> "") & VALEUR = ""
   mkstat = 2 : # rendre la catégorie obligatoire (bug 4510)
   GMESSAGE = mess(10,123,1) #"valeur obligatoire "
Endif

# Issue X3-129492 - 2019-06-07 by WHA : Check if the new categoy is phantom and exits in sub-contracted BOM, if yes, error message will be displayd
If([F:ITG]PHAFLG=2)
   Filter [BOMD] Where evalue("[F:BOMD]CPNITMREF=[F:ITM]ITMREF&[F:BOMD]BOMALTTYP=3") Order By Key BOD0

   If rowcount([BOMD])>=1
      Read [BOMD] First
      GMESSAGE=" "+[F:ITM]ITMREF+" "+" - "-mess(709,199,1)+ " : "-num$([F:BOMD]ITMREF)+" / "-num$([F:BOMD]BOMALT)
      GERR=1
      mkstat = 2
   Endif

   Filter [BOMD]

Endif
# End X3-129492 number

## SAM 119958 Control: non deliverable product associated to a fixed kit type product
Read [ITG]ITG1=VALEUR;""
If !fstat and [F:ITG]DLVFLG<>2
   If [M:ITS]ITMTYP=3
      mkstat = 2
      GMESSAGE = mess(544,192,1) # Type not allowed for this product with a non deliverable service category type
   Endif
Endif
End


Subprog AM_TCLCOD(VALEUR)
#-----------------------#
# Apres modif catégorie #
#-----------------------#
Variable Char     VALEUR
Local Integer ITS_FLG, OK, I
Local Integer S_QUAFLG, S_STOMGTCOD, S_SERMGTCOD
# Issue 70985 - 2012-03-09 by SR
Local Decimal WWMNTORG
Local Decimal WWMNTDES
Local Integer WSTAT
#[L]S_QUAFLG    =[M:ITM2]QUAFLG        # hcb V6CQ
[L]S_STOMGTCOD =[M:ITM2]STOMGTCOD
If dim([M:ITM2]SERMGTCOD)>0
    [L]S_SERMGTCOD =[M:ITM2]SERMGTCOD
Endif

# v 140 : ŕ la création, charger les vpd de la catégorie
#-- Si on ne fait pas "Fichier nouveau", le grep est positionné
#-- Aprčs la saisie des deux zones de clé de la table
#-- Ce qui signifie que les valeurs par défaut ne sont pas chargées
Read [ITG]ITG1=VALEUR;""
If !fstat
   [M:ITM1]SALFLG=[F:ITG]SALFLG
   [M:ITM1]PURFLG=[F:ITG]PURFLG
   [M:ITM1]MFGFLG=[F:ITG]MFGFLG
   [M:ITM1]SCPFLG=[F:ITG]SCPFLG
   [M:ITM1]SCSFLG=[F:ITG]SCSFLG
   [M:ITM1]PHAFLG=[F:ITG]PHAFLG
   [M:ITM1]GENFLG=[F:ITG]GENFLG
   [M:ITM1]TOOFLG=[F:ITG]TOOFLG
   [M:ITM1]DLVFLG=[F:ITG]DLVFLG
   [M:ITM1]INTFLG=[F:ITG]INTFLG
   If find(GREP,"C","D")
       Call INIITG(VALEUR)
   Endif
#MAE, le 21/07/08, bg 48307
# Issue 116175 - 2016-10-10 by MAE : si le statut de l'article est différent de actif ou en élaboration, il n'est pas touché par le changement de catégorie
    If find([F:ITG]ITMCREMOD, 1,2) & find([M:ITM0]ITMSTA,1,2)
       [M:ITM0]ITMSTA = [F:ITG]ITMCREMOD
    Endif
Endif


# Issue 59757 - 2017-10-23 by MAE : service et vendu => unités de vente accessible
#If !GIMPORT & [M:ITM1]SCSFLG = 2                       # hcb 103984
#   Grizo [M:ITM3]SAU, SAUSTUCOE, DACSAUCOE             # hcb 103984
#Endif                                                  # hcb 103984

# Catégorie non achetée: avertir que les Art-fourn seront supprimés
If [F:ITG]PURFLG = 1 & [F:ITG]SCPFLG = 1 & [F:ITG]SCSFLG = 1 & [F:ITG]GENFLG = 1 & [F:ITG]TOOFLG = 1
   Look [ITP]ITP0(2) = [M:ITM0]ITMREF
   If !fstat : GMESSAGE = mess(108,199,1) : GERR=2 Endif
   # Issue 70985 - 2012-03-09 by SR
   If find(GREP,"C","D")
       [M:ITM4]PURBASPRI = 0
       [M:ITM4]ITMCPRAMT = 0
       [M:ITM4]ITMCPRCOE = 1
       [M:ITM4]ITMSTCNUM = ""
   Endif
   If !GIMPORT
     Grizo [ITM4]
     Affzo [M:ITM4]
     If dim([M:ITP]NBITP) > 0
       Grizo [ITP]
     Endif
   Endif
Else
   If find(GREP,"C","D")
      # Issue 70985 - 2012-03-09 by SR : Récupération du coeff d'approche et du cout forfaitaire
      WWMNTORG = [F:ITG]CPRAMT
      Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WWMNTORG,WWMNTDES,WSTAT) From TRTDEV
      If !WSTAT  [M:ITM4]ITMCPRAMT = arr(WWMNTDES,10^-GDECPRI) : Endif
      [M:ITM4]ITMCPRCOE = [F:ITG]CPRCOE
      If [M:ITM4]ITMCPRCOE = 0 : [M:ITM4]ITMCPRCOE = 1 : Endif
      [M:ITM4]ITMSTCNUM = [F:ITG]STCNUM
   Endif
   If !GIMPORT
     Actzo [ITM4]1-99
     Affzo [M:ITM4]ITMCPRAMT,ITMCPRCOE,ITMSTCNUM
     If dim([M:ITP]NBITP) > 0
       Actzo [ITP]1-99
     Endif
   Endif
Endif
# Catégorie non vendue: avertir que les Art-clients seront supprimés
If [F:ITG]SALFLG = 1
   If [F:ITG]DLVFLG = 1                    # hcb 28874
      Look [ITS]ITS0 = [M:ITM0]ITMREF
      If !fstat : ITS_FLG = 1 : Endif
   Endif                                   # hcb 28874
   Look [ITU]ITU0(1) = [M:ITM0]ITMREF
   If !fstat | ITS_FLG GMESSAGE += "\" +mess(109,199,1) : GERR=2 Endif
   If !GIMPORT
     Grizo [ITS]
     If dim([M:ITU]NBITU) > 0
       Grizo [ITU]
     Endif
   Endif
Else
   If !GIMPORT
     Actzo [ITS]1-99
     # Issue 10401 - 2013-04-25 by MUARN : prix de base vente en fonction prix base achat
     If [M:ITS]BASPRIORI = 2
      Diszo [M:ITS]BASPRI
     Else
      Diszo [M:ITS]PURPRIPRC
     Endif
     # fin Issue 10401 - 2013-04-25 by MUARN : prix de base vente en fonction prix base achat
     If dim([M:ITU]NBITU) > 0
       Actzo [ITU]1-99
     Endif
   Endif
Endif

# 107888 : Scheduled invoices (LD:04/12/15)
# Invoice term accessible only for Service/Generic category and type of flow sales and not deliverable
If GMODU(5)=2
    If ([M:ITM1]SCSFLG=2 | [M:ITM1]GENFLG=2) & [M:ITM1]GENFLG=2 & [M:ITM1]DLVFLG=1
       Actzo [M:ITS]INVCND
    Else
       Diszo [M:ITS]INVCND
    Endif
Endif
# 107888 : Scheduled invoices (LD:03/12/15)

If [F:ITG]SCSFLG  = 2 | [F:ITG]GENFLG = 2
   If [M:ITM2]STOMGTCOD > 1
      If !clalev([F:STO1])  Local File STOCK [STO1]  Endif
      For [STO1]STO3 Where ITMREF=[M:ITM0]ITMREF
         mkstat=2 : GMESSAGE=mess(928,196,1)+"\"+mess(68,188,1)
         Break
      Next
      If mkstat=2 End Endif
   Endif
Endif

[M:ITM0]TCLCOD = VALEUR

#Modif CRM 5/9/2003
If GMODU(12) = 2
 If GIHDKACTCTL
   If clalev([M:ITAV])
      [M:ITAV]TPLCONGUA = ""
      [M:ITAV]TPLCONSRV = ""
      Gosub SETGRAY From SUBITMCRM
   Endif
 Endif
Endif

# Issue X3-171048 - 2019-11-28 by MAE : Oubli du DIM
# Issue X3-121038 - 2019-06-26 by CLPON : Disable MIN version counter when not needed
If dim([M:ITM2]ECCSTO)>0
  If [M:ITM2]ECCSTO < 3
    Diszo [M:ITM2]ECCMIN
    If [M:ITM2]ECCSTO < 2
      Diszo [M:ITM2]ECCMAJ
    Else
      Actzo [M:ITM2]ECCMAJ
    Endif
  Else
    Actzo [M:ITM2]ECCMIN
  Endif
# End issue X3-121038
Endif

End



Subprog AS_ITMSTA(VALEUR)
#---------------------#
# Avant saisie statut #
#---------------------#
Variable Integer  VALEUR
If GREP = "C" | GREP = "D"
 If [F:ITG]ITMCREMOD = 2 : VALEUR = 2 : mkstat = 2 : Endif
Endif
# hcb V6CQ
#If GREP = "M" | GREP = ""
#  Autorisation de modif selon profil gestionnaire Qualité
# Read [ACC]CODACC=GUSER;[M:ITM2]QUAACS
# If !fstat & [F:ACC]MODIF = 1
#   mkstat = 2
# Endif
#Endif
# hcb V6CQ
End

Subprog AS_ITMREF(VALEUR)
#-------------------------#
# Avant référence article #
#-------------------------#
Variable Char     VALEUR
# Si un compteur est associé ŕ la catégorie de l'article
# la référence article n'est pas saisie et sera affectée ŕ la création
# En duplic il faut effacer la référence rémanente
# ATTENTION en GRAPHIQUE GREP est mis ŕ D apres la modif de la réference !
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
If [F:ITG]ITMREFCOU <> ""
 If GREP = "C" | GREP = "D"
    mkstat = 2
 Endif
Endif
End


Subprog AV_DES1AXX(VALEUR)
#---------------------#
# Avant zone désign 1 #
#---------------------#
Variable Char    VALEUR()

If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Pour permettre de dupliquer un art numéroté : effacer la réf qui vient d'ętre saisie
# !!! ATTENTION !!!! apparemment non compatible avec un gosub RELIT  !!! Attention !!!!
If GREP = "D" & [F:ITG]ITMREFCOU <> "" & [F:ITM]ITMREF <> [M:ITM0]ITMREF           # hcb 31324
  If !GIMPORT
     Effzo [M:ITM0]ITMREF
  Endif
Endif
End

Subprog C_DES1AXX(VALEUR)
#-------------------#
# Controle désign 1 #
#-------------------#
Variable Char    VALEUR()
If VALEUR=""
  mkstat=2
  Setmok [ITM1] With 0
  Setmok [ITM2] With 0
  Setmok [ITM3] With 0
  Setmok [ITM5] With 0
  Setmok [ITS]  With 0
  Setmok [ITAV] With 0
  Setmok [ITU]  With 0
  Setmok [ITM4] With 0
  Setmok [ITP]  With 0
Endif

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
#If VALEUR <> [M]DES1AXX & func AFNC.ACTIV("KPO")
# Issue 117346 - 2016-07-13 by RMA : Can't compare screen field with value on import
If GLANGUE = "POR" & func AFNC.ACTIV("KPO") & (VALEUR <> [M]DES1AXX | (GIMPORT = 1 & GREP = 'M'))
  Call DES_CONTROL([M:ITM0]ITMREF,1,1) From PORLEGLIB
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

End

#------------#
# Ecran ITM1 #
#------------#

Subprog IB_CFGLIN
#------------------------------#
# init bouton ligne de produit #
#------------------------------#
If [M:ITM1]CFGLIN = "" Raz GBOUT2 Endif
End

#------------#
# Ecran ITM2 #
#------------#

Subprog AS_STOMGTCOD(VALEUR)
#----------------------------#
# Avant saisie gestion stock #
#----------------------------#
Variable Integer  VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Désactivation provisoire gestion en UI
GMENLOC(4) = 1
If dim([M:ITM2]DEFPOT) < 0
   GMENLOC(3) = 1 : GMENLOC(4) = 1
Endif
# sr 10.02 demande 16134    si module stock absent, alors non géré en Stock
If GMODU(7) <> 2
   VALEUR = 1
   mkstat = 2
   End
Endif
# types Générique et Sous-traitance : Non géré en stock
If [F:ITG]SCSFLG  = 2 | [F:ITG]GENFLG = 2
   VALEUR = 1
   mkstat = 2
   End
Endif
End

Subprog C_STOMGTCOD(VALEUR)
#------------------------#
# Contrôle gestion stock #
#------------------------#
Variable Integer  VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Pas de gestion titre pour des articles vendus
If [F:ITG]SALFLG = 2 & VALEUR = 3
  mkstat = 2
  GMESSAGE = mess(211,199,1)
  End
Endif
#-- L'article ne peut ętre géré en titre et en numéro de série

If VALEUR=3 &  dim([M:ITM2]SERMGTCOD) > 0  & [M:ITM2]SERMGTCOD>1
  GMESSAGE=mess(494,199,1)
  mkstat=2 : End
Endif
# Test pas de gestion stock autorisé (mouvements existent)
If VALEUR = 1 & [M:ITM2]STOMGTCOD > 1
  If !clalev([F:STO1])  Local File STOCK [STO1]  Endif
  For [STO1]STO3 Where ITMREF=[M:ITM0]ITMREF
     mkstat=2 : GMESSAGE=mess(68,188,1)
     Break
  Next
  If mkstat=2 End Endif
Endif
End

Subprog AM_STOMGTCOD(VALEUR)
#---------------------------#
# Apres modif gestion stock #
#---------------------------#
Variable Integer  VALEUR
# Art non géré en stock --> remise aux valeurs par défaut

Gosub WARNING_MVT
If dim([M:ITM2]DEFPOT) > 0
 Case VALEUR
  When 1 : [M:ITM2]DEFPOT = 0
           [M:ITM2]STDFLG = 1
  When 2 : [M:ITM2]DEFPOT = 0
  When 3
  When 4 : [M:ITM2]DEFPOT = 0
 Endcase
 Affzo [M:ITM2]DEFPOT
Endif
If VALEUR>1 [M:ITM4]RCPFLG=2 : Endif
Affzo [M:ITM2]STDFLG
Affzo [M:ITM4]RCPFLG

If VALEUR=1
  If !GIMPORT
    #-- Raz des zones réservées aux articles gérés en stock
    If dim([M:ITM2]JOUCAL) > 0
       Raz [M:ITM2]JOUCAL
    Endif
#    Raz [M:ITM2]STDFLG, QLYCRD       # hcb V6CQ
    Raz [M:ITM2]STDFLG                # hcb V6CQ
    If dim([M:ITM2]EXYSTA)>0
      Raz [M:ITM2]EXYSTA, SHL, NEWLTISTA, SHLLTI
      [M:ITM2]DLU       = 1   # hcb V6PER
      [M:ITM2]SHLUOM    = 1   # hcb V6PER
      [M:ITM2]SHLLTIUOM = 1   # hcb V6PER
    Endif
    If dim([M:ITM2]DEFPOT)>0
      Raz [M:ITM2]DEFPOT
    Endif
    Grizo [M:ITM2]STDFLG,NEGSTO,RPLITM, BRDCOD
    If dim([M:ITM2]TRKCOD)>0                 # hcb 69389 deb
       #--- Bug 55665
       #If dim([M:ITM2]SERMGTCOD) > 0
       #   If [M:ITM2]SERMGTCOD <> 3
       #      Grizo [ITM2]TRKCOD
       #   Else
       #      Actzo [ITM2]TRKCOD
       #   Endif
       #Endif
       [M:ITM2]TRKCOD=1
       Grizo [M:ITM2]TRKCOD
       If dim([M:ITM2]TRKLEV)>0
          [M:ITM2]TRKLEV=1
          Grizo [M:ITM2]TRKLEV
       Endif
       #---
    Endif                                    # hcb 69389 fin
    [M:ITM2]BRDCOD=1
    If dim([M:ITM2]LOTMGTCOD) > 0             # bug 9604 25/06/01
       Raz [M:ITM2]LOTMGTCOD, LOTCOU
       Grizo [ITM2]LOTMGTCOD,LOTCOU
    Endif
    If dim([M:ITM2]SERMGTCOD) > 0             # bug 9604 25/06/01
       Grizo [ITM2]SERMGTCOD,SERCOU
    Endif

    Grizo [ITM2]25 # ne pas griser le contrat service :
   # Grizo [ITM2]QUAFLG, QUAACS, QLYCRD            # hcb V6CQ
    If clalev([M:ITVA])<>0
        Actzo [ITAV]TPLCONSRV
    Endif
  Endif
Else
  If !GIMPORT
      Actzo [ITM2]1-99
      # FGR 29/04/2008 : X3SUIVI47160 : Cette rubrique a été rendue accessible en 140. Pas de raison de l'effacer.
      #If clalev([M:ITAV])
      #   Raz [M:ITAV]TPLCONSRV
      #Endif
  Endif
Endif
If dim([M:ITM2]DEFPOT)>0
    If VALEUR=3
       Actzo [ITM2]DEFPOT
    Else
       Grizo [ITM2]DEFPOT
    Endif
Endif
[M:ITM2]STOMGTCOD = VALEUR
#Modif CRM 5/9/2003
If GMODU(12) = 2
 If GIHDKACTCTL
  Gosub SETGRAY From SUBITMCRM
 Endif
Endif
Affzo [M:ITM2]1-99
#MAE, le 03/02/09, bg 42932
#MAE, bg 79754, affichage du message si on est en modif
#If GREP = "M"
If GREP<>"C" & GREP<>"D"
   If [M:ITM2]STOMGTCOD <>  [F:ITM]STOMGTCOD
      Call MESSAGE(mess(261,184,1)) From GESECRAN
   Endif
Endif
# Issue X3-121038 - 2019-01-15 by MAE
If dim([M:ITM2]ECCFLG)>0
  If dim([M:ITM2]LOTMGTCOD)>0 & [M:ITM2]LOTMGTCOD>2
    Actzo [M:ITM2]ECCFLG
  Else
    Diszo [M:ITM2]55
  Endif
Endif
# End issue X3-121038

End

Subprog AS_NEGSTO(VALEUR)
#------------------------#
# Avant saisie stock neg #
#------------------------#
Variable Integer  VALEUR
If [M:ITM2]STOMGTCOD = 1 mkstat = 2 Endif
End

#                                                                  # TS 110327 deb
Subprog C_NEGSTO(VALEUR)
Variable Integer VALEUR
# Issue X3-144547 - 2019-06-28 by WHA : check if SERMGTCOD exists
If dim([M:ITM2]SERMGTCOD) > 0 & VALEUR=2 & [M:ITM2]SERMGTCOD=4
  GMESSAGE=mess(1190,196,1)            # serie en globale les stocks négatifs ne sont pas autorisés
  mkstat=2
Endif
End
# End issue X3-144547
#                                                                  # TS 110327 fin


Subprog D_STDFLG(VALEUR)
#----------------------#
# Init mode de gestion #
#----------------------#
Variable Integer  VALEUR
If [M:ITM2]STOMGTCOD = 1
  VALEUR = 1
Else
  VALEUR = 3
Endif
End

Subprog AS_STDFLG(VALEUR)
#---------------------------#
# Avant saisie mode gestion #
#---------------------------#
Variable Integer  VALEUR
GMENLOC(2) = 1       #  ŕ l'affaire : pas géré mais testé dans calcul CBN (?)
If [M:ITM2]STOMGTCOD > 1
  GMENLOC(1) = 1
Else
  VALEUR = 1 : # rajouté 09/12/99
  mkstat = 2
Endif
End

Subprog AM_STDFLG(VALEUR)
#-----------------------------#
# Apres-modif mode de gestion #
#-----------------------------#
Variable Integer VALEUR
Gosub WARNING_MVT
End


Subprog AS_RPLITM(VALEUR)
#----------------------------#
# Avant saisie article rempl #
#----------------------------#
Variable Char     VALEUR
If [M:ITM2]STOMGTCOD = 1 mkstat = 2 Endif
End

Subprog C_RPLITM(VALEUR)
#------------------------#
# Contrôle article rempl #
#------------------------#
Variable Char     VALEUR
# NE PAS METTRE LE TYPE ITM SUR CETTE ZONE, SINON LES AUTOMATISMES CASSENT LA
# CLASSE [F:ITM] en cours !!!!!
Local File ITMMASTER [ITM2] # pour ne pas écraser le buffer
If VALEUR = [M:ITM0]ITMREF & VALEUR <> ""
   mkstat = 1 : End
Endif

If !GIMPORT   : # Bug 75300 : Action interactive ŕ ne pas executer en import
  # Bug 41465
  Local Shortint STAT
  Local Char     WITM
  WITM = VALEUR
  Call CONTSEL("ITM","!$",WITM,"",STAT) From CONTOBJ
  VALEUR = WITM
Endif

If VALEUR <> ""
 Look [ITM2]ITM0 = VALEUR
 If fstat
    mkstat = 2
    GMESSAGE = mess(23,100,1) # Fiche inexistante
 Endif
# 01.05 27574
# While fstat = 0 & [F]RPLITM <> ""
#  If [F]RPLITM = [M:ITM0]ITMREF
#   GMESSAGE = [M:ITM0]ITMREF - mess(28,101,1) - [F]ITMREF
#   mkstat = 2
#   Break
#  Endif
#  Read [ITM]ITM0 = [F]RPLITM
# Wend
Endif
End

Subprog AM_RPLITM(VALEUR)
#---------------------------#
# Apres modif article rempl #
#---------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
   #Call LECTEXTRA([M:ITM2]RPLITMDES,"ITMMASTER","DES1AXX",VALEUR,"") From ATEXTRA
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,VALEUR,[M:ITM2]RPLITMDES, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
   Affzo [M:ITM2]RPLITMDES
Else
   Effzo [M:ITM2]RPLITMDES
Endif
End

Subprog AS_LOTMGTCOD(VALEUR)
#--------------------------#
# Avant saisie gestion lot #
#--------------------------#
Variable Integer  VALEUR
If [M:ITM2]STOMGTCOD = 1
   mkstat = 2 : End
Endif
# Si pas de gestion de sous-lot
If GSLOACTIV<>2 GMENLOC(4)=1 Endif
End

Subprog C_LOTMGTCOD(VALEUR)
#----------------------#
# Contrôle gestion lot #
#----------------------#
Variable Integer VALEUR
If [M:ITM2]STOMGTCOD=3 & VALEUR<=2 & GREP <> "C"
    GERR=1
    GMESSAGE=mess(489,199,1)
    mkstat=2
Endif
# Test modification autorisée (pas de lot existants)
If VALEUR = 1 & [M:ITM2]LOTMGTCOD > 1
  If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
  Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&                     LOT    <> ""              &
&                     QTYSTU <> 0
&               Order By Key STO3
  For [STO1]
    GERR = 2  # des enregistrements de stock existent pour cet article (non bloquant en 140)
    GMESSAGE = mess(68,188,1)
    Break
  Next
  Filter [STO1]
Endif
# Test modification autorisée (pas de lot vide existants)
If VALEUR > 1 & [M:ITM2]LOTMGTCOD = 1
  If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
  Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&                     LOT    =  ""              &
&                     QTYSTU <> 0
&               Order By Key STO3
  For [STO1]
    GERR = 2                  # non bloquant en 140
    GMESSAGE = mess(68,188,1)
    Break
  Next
  Filter [STO1]
Endif

#                                                              # hcb 71276 deb 37
# Test modification autorisée si gestion version
If dim([M:ITM2]ECCSTO) > 0
   If VALEUR < 3 & [M:ITM2]ECCSTO > 1
      If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
      Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&                   LOT    <>  ""              &
&                   QTYSTU <> 0
&             Order By Key STO3
      For [STO1]
        GERR = 2
        GMESSAGE = mess(68,188,1)  # des enregistrement de stocks existent
        Break
      Next
   Filter [STO1]
  Endif
Endif
#                                                              # hcb 71276 fin

End


Subprog AM_LOTMGTCOD(VALEUR)
#-------------------------#
# Apres modif gestion lot #
#-------------------------#
# Remises ŕ blanc en cas de modif
Variable Integer  VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Gosub WARNING_MVT                                    # hcb 71276
If VALEUR < 2
   Raz [M:ITM2]LOTCOU
   If !GIMPORT Grizo [ITM2]LOTCOU : Affzo [ITM2]LOTCOU : Endif
   #MAE, bg 69389
#   Diszo [M:ITM2]TRKCOD : [M:ITM2]TRKCOD = 1 : Affzo [M:ITM2]TRKCOD  # hcb 69389 deb
   If dim([M:ITM2]TRKCOD)>0
      If dim([M:ITM2]SERMGTCOD) > 0
          #--- Issue 110327
          #If [M:ITM2]SERMGTCOD <> 3
          If [M:ITM2]SERMGTCOD < 3
             Diszo [M:ITM2]TRKCOD
             [M:ITM2]TRKCOD = 1
              Affzo [M:ITM2]TRKCOD
             #--- Bug 55665
             If dim([M:ITM2]TRKLEV)>0
                [M:ITM2]TRKLEV=1
                Diszo [M:ITM2]TRKLEV
             Endif
             #---
          Else
             Actzo [ITM2]TRKCOD
             #--- Bug 55665
             If dim([M:ITM2]TRKLEV)>0
                If [M:ITM2]TRKCOD<2
                   [M:ITM2]TRKLEV=1
                   Diszo [M:ITM2]TRKLEV
                Else
                   Actzo [M:ITM2]TRKLEV
                   # Si niveau lot ou s-lot --> par défaut
                   If find([M:ITM2]TRKLEV,2,3)
                      [M:ITM2]TRKLEV=1
                   Endif
                Endif
             Endif
             #---
          Endif
          #--- Bug 55665
          If dim([M:ITM2]TRKLEV)>0 : Affzo [M:ITM2]TRKLEV : Endif
          #---
       Endif
    Endif                                    # hcb 69389 fin
Else
   Actzo [ITM2]LOTCOU
   If [M:ITM2]LOTCOU = ""
     #--- Issue 171114 by TS
     #If [F:ITG]LOTCOU<> ""
     #    [M:ITM2]LOTCOU = [F:ITG]LOTCOU
     #Else
     #   [M:ITM2]LOTCOU = GSTKCPT(7)
     #Endif
     [M:ITM2]LOTCOU = [F:ITG]LOTCOU
     #---
     Affzo [ITM2]LOTCOU
   Endif
   #MAE, bg 69389
#  If [ITM2]SERMGTCOD = 3                                   # hcb 69389
#     Actzo [M:ITM2]TRKCOD  : Affzo [M:ITM2]TRKCOD
#  Else
#     Diszo [M:ITM2]TRKCOD : [M:ITM2]TRKCOD = 1 :  Affzo [M:ITM2]TRKCOD
#  Endif
   If dim([M:ITM2]TRKCOD)>0
      Actzo [ITM2]TRKCOD
      #--- Bug 55665
      If dim([M:ITM2]TRKLEV)>0
         If [M:ITM2]TRKCOD<2
            [M:ITM2]TRKLEV=1
            Diszo [M:ITM2]TRKLEV
         Else
            Actzo [M:ITM2]TRKLEV
            # Si gestion lot facultatif ou obligatoire et niveau s-lot
            # --> niveau lot
            If find(VALEUR,2,3) & [M:ITM2]TRKLEV=3
               [M:ITM2]TRKLEV=2
            Endif
         Endif
         Affzo [M:ITM2]TRKLEV
      Endif
      #---
   Endif                                    # hcb 69389 fin
Endif

If dim([M:ITM2]EXYMGTCOD) > 0             # bug 9604 25/06/01
   If VALEUR = 1
      If dim([M:ITM2]EXYMGTCOD)>0
          Raz [M:ITM2]EXYMGTCOD, [M:ITM2]EXYSTA,[M:ITM2]SHL
          Raz [M:ITM2]NEWLTISTA, [M:ITM2]SHLLTI
          [M:ITM2]DLU       = 1   # hcb V6PER
          [M:ITM2]SHLUOM    = 1   # hcb V6PER
          [M:ITM2]SHLLTIUOM = 1   # hcb V6PER
          If !GIMPORT
             Affzo  [M:ITM2]EXYMGTCOD
             Affzo  [M:ITM2]EXYSTA
             Affzo  [M:ITM2]SHL
             Affzo  [M:ITM2]SHLUOM     # hcb V6PER
             Affzo  [M:ITM2]NEWLTISTA  # hcb V6PER
             Affzo  [M:ITM2]SHLLTI     # hcb V6PER
             Affzo  [M:ITM2]SHLLTIUOM  # hcb V6PER
             Affzo  [M:ITM2]DLU        # hcb V6PER
             Grizo [ITM2]EXYMGTCOD, EXYSTA, SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU   # hcb V6PER
          Endif
      Endif
   Else
      If dim([M:ITM2]EXYMGTCOD)>0
          Actzo [ITM2]EXYMGTCOD
      Endif
   Endif
Endif
# Issue X3-121038 - 2019-01-15 by MAE
If dim([M:ITM2]ECCFLG) >0
  If VALEUR>2
    Actzo [M:ITM2]ECCFLG
  Else
    Diszo [M:ITM2]55
  Endif
Endif
# End issue X3-121038
End

Subprog AS_SERMGTCOD(VALEUR)
#------------------------------------#
# Avant saisie gestion des num série #
#------------------------------------#
Variable Integer  VALEUR
#MAE: désactivation de la gestion en entrée sortie globale
#GMENLOC(4) = 1
#-- Si pas de gestion de stock
If [M:ITM2]STOMGTCOD=1 : mkstat=2 : End : Endif
#-- Si gestion des titres
If [M:ITM2]STOMGTCOD=3 : mkstat=2 : End : Endif

End

#                                                                  # TS 110327 deb
# serie en globale les stocks négatifs ne sont pas autorisés
Subprog C_SERMGTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=4 & [M:ITM2]NEGSTO=2
  GMESSAGE=mess(1190,196,1)
  mkstat=2
Endif
End
#                                                                  # TS 110327 fin

Subprog AM_SERMGTCOD(VALEUR)
#-----------------------------------#
# Apres modif gestion des num série #
#-----------------------------------#
Variable Integer VALEUR

#                                                                  # hcb 110327 deb
#          Passage option 1 ou 2 ou 3 ŕ 4 interdit si stock present
If GREP <> "C" & GREP <> "D"
   If  VALEUR  = 4 & find([M:ITM2]SERMGTCOD,1,2,3)
       If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
       Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&             QTYSTU <> 0
&             Order By Key STO3
       For [STO1]
           GMESSAGE = mess(437,192,1)-":"-mess(68,188,1)
           GERR = 2 # des enregistrements de stock existent pour cet article
           Break
       Next
       Filter [STO1]
   Endif
   If GERR = 2
     mkstat = 2
     End
   Endif
#          Passage option 3  ŕ 4 interdit si mouvements presents
   If  (VALEUR  = 4 & find([M:ITM2]SERMGTCOD,3)) | (VALEUR  = 3 & find([M:ITM2]SERMGTCOD,4))
        If clalev([F:STJ]) = 0 : Local File STOJOU [STJ] : Endif
        For [STJ]STJ2 Where UPDCOD=2 & ITMREF = [M:ITM0]ITMREF
            GERR = 2
            Break
        Next
        If GERR < 2
           For [STJ]STJ2 Where UPDCOD=1 & ITMREF = [M:ITM0]ITMREF
               GERR = 2
               Break
           Next
        Endif
        If GERR = 2
           GMESSAGE = mess(437,192,1)-":"-mess(68,188,1)
           mkstat = 2
           End
        Endif
   Endif
Endif
#                                                                  # hcb 110327 fin
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
Gosub WARNING_MVT
If VALEUR > 1
   Actzo [M:ITM2]SERCOU
   # initialiser le compteur comme dans la catégorie
   If [M:ITM2]SERCOU = ""
     #MAE, le 23/03/2009, bg 53605, le compteur série est toujours recopié depuis la catégorie.
     #If [F:ITG]SERCOU <> ""
        [M:ITM2]SERCOU = [F:ITG]SERCOU
     #Else
     #   [M:ITM2]SERCOU = GSTKCPT(12)
     #Endif
     Affzo [ITM2]SERCOU
   Endif
Else
   Effzo [M:ITM2]SERCOU
   Grizo [M:ITM2]SERCOU
Endif

# Attention valeur incohérente  : gestion série "entrée - sortie" et tracabilité "agrégée" !
#--- Issue 110327
#If VALEUR = 3 & (dim([M:ITM2]TRKCOD)> 0 & [M:ITM2]TRKCOD = 3)       # hcb 69389
If VALEUR >= 3 & (dim([M:ITM2]TRKCOD)> 0 & [M:ITM2]TRKCOD = 3)       # hcb 69389
   Call MESSAGE(mess(553,199,1)) From GESECRAN
Endif
#MAE, bg 69389
If dim([M:ITM2]TRKCOD)>0       # hcb 69389 deb
   If VALEUR = 3
      Actzo [M:ITM2]TRKCOD
      Affzo [M:ITM2]TRKCOD
      #--- Bug 55665
      If dim([M:ITM2]TRKLEV)>0
         If [M:ITM2]TRKCOD<2
            [M:ITM2]TRKLEV=1
            Diszo [M:ITM2]TRKLEV
         Else
            Actzo [M:ITM2]TRKLEV
         Endif
      Endif
      #---
   Else
      If dim([ITM2]LOTMGTCOD) > 0
         If [ITM2]LOTMGTCOD  < 2
            Diszo [M:ITM2]TRKCOD
            [M:ITM2]TRKCOD = 1
            Affzo [M:ITM2]TRKCOD
            #--- Bug 55665
            If dim([M:ITM2]TRKLEV)>0
               [M:ITM2]TRKLEV=1
               Diszo [M:ITM2]TRKLEV
            Endif
            #---
         Else
            Actzo [M:ITM2]TRKCOD
            #--- Bug 55665
            If dim([M:ITM2]TRKLEV)>0
               If [M:ITM2]TRKCOD<2
                  [M:ITM2]TRKLEV=1
                  Diszo [M:ITM2]TRKLEV
               Else
                  Actzo [M:ITM2]TRKLEV
                  # Si niveau = série --> par défaut
                  If [M:ITM2]TRKLEV=4
                     [M:ITM2]TRKLEV=1
                  Endif
               Endif
            Endif
            #---
         Endif
         #--- Bug 55665
         If dim([M:ITM2]TRKLEV)>0 : Affzo [M:ITM2]TRKLEV : Endif
         #---
      Endif
   Endif
Endif                           # hcb 69389 fin
End

Subprog AS_LOTCOU(VALEUR)
#---------------------------#
# Avant saisie compteur lot #
#---------------------------#
Variable Char     VALEUR
If [M:ITM2]LOTMGTCOD < 2 mkstat = 2 Endif
End

Subprog C_LOTCOU(VALEUR)
#------------------------#
# Contrôle  compteur lot #
#------------------------#
Variable Char     VALEUR
# contrôle par rapport au type de donné
If VALEUR <> ""
  Read [ANM]ANM0=VALEUR : If fstat : Raz [F:ANM] : Endif
  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONLOT
    GMESSAGE=VALEUR-mess(223,199,1)
    mkstat = 2
  Endif
Endif
End

Subprog C_SERCOU(VALEUR)
#--------------------------#
# Contrôle  compteur serie #
#--------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
  Read [ANM]ANM0=VALEUR : If fstat : Raz [F:ANM] : Endif
  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONSER
    GMESSAGE=VALEUR-mess(223,199,1)
    mkstat = 2
  Endif
Endif
End

