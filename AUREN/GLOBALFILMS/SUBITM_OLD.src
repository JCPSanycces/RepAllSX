Subprog C_PCU(VALEUR)
#--------------------------------#
# Contrôle unité conditionnement #
#--------------------------------#
Variable Char     VALEUR
Call UNICITE(VALEUR,[M:ITM3]PCU(0..[M:ITM3]BASTAB-1)) From OBJDIV
If [M:ITM3]PCU(nolign-1) <> "" & VALEUR = ""
  mkstat = 2 : GMESSAGE = mess(217,199,1)
Endif
# PCU ne doit pas ętre l'unité de stock. rajout 21/06/02
If VALEUR = [M:ITM3]STU
  mkstat=2
Endif
End

Subprog AM_PCU(VALEUR)
#-----------------------------------#
# Apres modif unité conditionnement #
#-----------------------------------#
Variable Char    VALEUR()
Call MODUNIT(VALEUR,[M:ITM3]STU,[M:ITM3]PCUSTUCOE(nolign-1))
Affzo [M:ITM3]PCUSTUCOE(nolign-1)
End

Subprog D_PCUSTUCOE(VALEUR)
#--------------------#
# Init PCU-STU coeff #
#--------------------#
Variable Decimal VALEUR
# si l'UC correspond ŕ l'UA ou ŕ l'UV, reprendre le coeff
If [M:ITM3]PCU(nolign-1) = [M:ITM3]PUU
  VALEUR = [M:ITM3]PUUSTUCOE
Endif
If [M:ITM3]PCU(nolign-1) = [M:ITM3]SAU
  VALEUR = [M:ITM3]SAUSTUCOE
Endif
End

Subprog AS_PCUSTUCOE(VALEUR)
#----------------------------#
# Avant saisie PCU-STU coeff #
#----------------------------#
Variable Decimal  VALEUR
Call COEFCNV([M:ITM3]PCU(nolign-1),[M:ITM3]STU,VALEUR)
# lignes rajoutées ici car l'Init ne se fait pas aprčs AM_PCU !:
# si l'UC correspond ŕ l'UA ou ŕ l'UV, reprendre le coeff
If [M:ITM3]PCU(nolign-1) = [M:ITM3]PUU
  VALEUR = [M:ITM3]PUUSTUCOE
Endif
If [M:ITM3]PCU(nolign-1) = [M:ITM3]SAU
  VALEUR = [M:ITM3]SAUSTUCOE
Endif
End

