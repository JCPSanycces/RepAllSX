## Etiquette ajoutée par le superviseur (écran ITM2) 13/02/2009 09:48:11 (VPO)
######################################################################################
Subprog C_PLMITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & func AFNC.ACTIV("PLM")
    Local File ITMMASTER [ITM2] # pour ne pas écraser le buffer
    Read [ITM2]ITM5=VALEUR
    If !fstat
        If [F:ITM2]ITMREF<>[M:ITM0]ITMREF
            mkstat = 2
            GMESSAGE = mess(23,7710,1)-[F:ITM2]ITMREF # Référence article PLM déjŕ utilisée sur un autre article
        Endif
    Endif
Else
    Call C_PLMITMREF(VALEUR) From PRDINFLIB  # DF 79831
Endif
End

$GRIZEBUTPLM
If dim([M:ITM1]PLMITMREF)>0
    If [M:ITM1]PLMATTURL=""
        Grizo [M:ITM1]BUTATTURL
    Else
        Actzo [M:ITM1]BUTATTURL
    Endif
Endif
If dim([M:ITM1]PLMHISURL)>0
    If [M:ITM1]PLMHISURL=""
        Grizo [M:ITM1]BUTHISURL
    Else
        Actzo [M:ITM1]BUTHISURL
    Endif
Endif
If dim([M:ITM1]BUTHISURL)>0
    If [M:ITM1]BUTHISURL=""
       [M:ITM1]BUTHISURL="63"
       Affzo [M:ITM1]BUTHISURL
    Endif
Endif
If dim([M:ITM1]BUTATTURL)>0
    If [M:ITM1]BUTATTURL=""
       [M:ITM1]BUTATTURL="63"
       Affzo [M:ITM1]BUTATTURL
    Endif
Endif
Return

Subprog AS_BUTATTURL(VALEUR)
Variable Char    VALEUR()
If [M:ITM1]PLMATTURL=""
    [S]mkstat=2
Endif
End

Subprog CL_BUTATTURL(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("PLM")
  Local Char RETOUR (250) : Raz RETOUR
  Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
&   "UILocalDir="+chr$(1) + "HTTP",
&   "UILocalFile="+ chr$(1) + [M:ITM1]PLMATTURL
Else
  Call BUTPRDINF([M:ITM1]PLMATTURL) From PRDINFLIB  # DF 79831
Endif
End

Subprog AS_BUTHISURL(VALEUR)
Variable Char    VALEUR()
If [M:ITM1]PLMHISURL=""
    [S]mkstat=2
Endif
End

Subprog CL_BUTHISURL(VALEUR)
Variable Char    VALEUR()
Local Char RETOUR (250) : Raz RETOUR
Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+chr$(1) + "HTTP",
& "UILocalFile="+ chr$(1) +[M:ITM1]PLMHISURL
End


