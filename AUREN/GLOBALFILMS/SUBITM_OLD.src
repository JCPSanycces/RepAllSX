$AB1_DESAXX
If func AFNC.ACTIV("KPO")
  Local Char DESIG_POR(80),LANG_POR(3)
  Call SAVE_TRAD([M:ITM0]ITMREF,[L]DESIG_POR,[L]LANG_POR,ACTION) From PORLEGLIB
Endif
