Subprog AS_EXYMGTCOD(VALEUR)
#----------------------#
# Avant saisie gestion #
#----------------------#
Variable Integer  VALEUR
If (dim([M:ITM2]LOTMGTCOD) > 0 & [M:ITM2]LOTMGTCOD = 1) |  [M:ITM2]STOMGTCOD = 1
   mkstat = 2 : VALEUR = 1
Endif
End


Subprog C_EXYMGTCOD(VALEUR)
Variable Integer  VALEUR
#If VALEUR = 1  & [M:ITM2]ISSMGTCOD=2 ## oté v 140
#  mkstat = 2
#  GMESSAGE = mess(234,199,1)
#Endif
End


Subprog AM_EXYMGTCOD(VALEUR)
#----------------------------#
# Apres_modif saisie gestion #
#----------------------------#
Variable Integer  VALEUR
If VALEUR = 1
# [M:ITM2]EXYSTA = ""
# [M:ITM2]SHL = 0
   Raz [M:ITM2]EXYSTA, SHL, NEWLTISTA, SHLLTI          # hcb dlu
  [M:ITM2]SHLUOM    = 1   # hcb V6PER
  [M:ITM2]SHLLTIUOM = 1   # hcb V6PER                  # hcb dlu
  If !GIMPORT
      Grizo [ITM2]EXYSTA,SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM       # hcb dlu
  Endif
Elsif !GIMPORT
    Actzo [ITM2]EXYSTA,SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU    # hcb dlu
Endif

# hcb dlu deb
If VALEUR = 1 | VALEUR  = 3 | VALEUR = 4
   Raz [M:ITM2]DLULTI
   [M:ITM2]DLU       = 1
   # Issue 119820
   If dim([M:ITU]XDLUBPC)>0
    [M:ITU]XDLUBPC    = 1
    Affzo [M:ITU]XDLUBPC
   Endif
   Affzo [M:ITM2]DLU
   Affzo [M:ITM2]DLULTI
   If !GIMPORT
      Grizo [ITM2]DLU
      # Issue 119820
      If dim([M:ITU]XDLUBPC)>0 Grizo [M:ITU]XDLUBPC Endif
   Endif
Else
   [M:ITM2]DLU = 1
    # Issue 119820
   If dim([M:ITU]XDLUBPC)>0   [M:ITU]XDLUBPC = 1 Endif
   If !GIMPORT
      Affzo [M:ITM2]DLU
       # Issue 119820
      If dim([M:ITU]XDLUBPC)>0
        Affzo [M:ITU]XDLUBPC
        Actzo [M:ITU]XDLUBPC
      Endif
      Actzo [ITM2]DLU
   Endif
Endif
# hcb dlu fin

Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
LCOD = VALEUR
LSHL = [M:ITM2]SHL
LUOM = [M:ITM2]SHLUOM
LDLU = [M:ITM2]DLU
Gosub CALDLULTI
[M:ITM2]DLULTI = WDLULTI
Affzo [M:ITM2]DLULTI


If dim([M:ITU]NBITU) > 0
  For nolign = 1 To [M:ITU]NBITU
        [M:ITU]DLUBPC(nolign-1)   = 1
  Next
Endif
End

Subprog AS_EXYSTA(VALEUR)
#-----------#
# As statut #
#-----------#
Variable Char     VALEUR
If [M:ITM2]EXYMGTCOD = 1 | [M:ITM2]STOMGTCOD = 1 mkstat = 2 Endif
End


Subprog C_EXYSTA(VALEUR)
#-----------------#
# Contrôle statut #
#-----------------#
Variable Char     VALEUR
If [M:ITM2]EXYMGTCOD <> 1 & VALEUR = ""
   mkstat = 2
   GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
If [M:ITM2]EXYMGTCOD <> 1 & instr(1,"AQR",VALEUR) = 0
 GMESSAGE = mess(21,199,1)
 mkstat = 2
Endif
End

Subprog AS_SHL(VALEUR)
#--------------------#
# Avant saisie Délai #
#--------------------#
Variable Decimal  VALEUR
If [M:ITM2]EXYMGTCOD = 1 | [M:ITM2]STOMGTCOD = 1 mkstat = 2 Endif
End

Subprog C_SHL(VALEUR)
#----------------#
# Contrôle Délai #
#----------------#
Variable Decimal  VALEUR
# Issue 139024 - 2019-07-08 by CLPON : Change control to set the lead time
# to mandatory if it's management is set to manual
If VALEUR = 0 & [M:ITM2]EXYMGTCOD <> 1 & [M:ITM2]EXYMGTCOD <> 6
# End issue 139024
 mkstat = 1
 GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
End

Subprog AS_DEFPOT(VALEUR)
#------------#
# AS titre % #
#------------#
Variable Decimal  VALEUR
If [M:ITM2]STOMGTCOD <> 3 mkstat = 2 Endif
End

Subprog C_DEFPOT(VALEUR)
#------------------#
# Contrôle titre % #
#------------------#
Variable Decimal  VALEUR
If VALEUR = 0 & [M:ITM2]STOMGTCOD = 3
   mkstat = 2
   GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
If VALEUR>100 & [M:ITM2]STOMGTCOD = 3
    mkstat = 2
    GMESSAGE = mess(83,123,1)
Endif
End

Subprog AS_BRDCOD(VALEUR)
#-----------------#
# AS Famille coűt #
#-----------------#
Variable Integer  VALEUR
If [M:ITM2]STOMGTCOD = 1 mkstat = 2 Endif # ! c'est un ML ; et STOMGTCOD est saisi sur ITM2

  #X3-103640 MJH. Only allow to display up to the maximum defined by GACTMAT
  Raz GMENLOC
  For I = 20 To GACTMAT+1 Step -1
    GMENLOC(I) = 1
  Next

End

Subprog C_BRDCOD(VALEUR)
#-----------------------#
# Contrôle Famille coűt #
#-----------------------#
Variable Integer VALEUR
Local    Char    WTCM(GLONTCM)
Local    Integer WRET
If clalev ([F:ITF2])  = 0 : Local File ITMFACILIT [ITF2]  : Endif
If clalev ([F:ITV2])  = 0 : Local File ITMMVT     [ITV2]  : Endif
If clalev ([F:TCM])  = 0 : Local File TABCOSTMET [TCM]  : Endif
If clalev ([F:ITC2])  = 0 : Local File ITMCOST    [ITC2]  : Endif
If clalev ([F:ITV2])  = 0 : Local File ITMMVT     [ITV2]  : Endif

# "Modification interdite : des enregistrements de coűts existent déjŕ pour cet article"
#If VALEUR <> [M:ITM2]BRDCOD & (GREP = "M" | GREP = "")
    #Local File ITMCOST [ITC2]
#    For [ITC2] Where ITMREF = [M:ITM0]ITMREF
#      GERR = 3  # avertissement au lieu de mkstat = 2 (26/11/01)
#      GMESSAGE = mess(207,199,1)
#      Break
#    Next
#Endif

# 82144 mm 05.12
If VALEUR <> [M:ITM2]BRDCOD & (GREP = "M" | GREP = "")
 If GACTDECCST
  For [ITF2] Where ITMREF = [M:ITM0]ITMREF
    Call GETTCM([M:ITM0]ITMREF, [F:ITF2]STOFCY, WTCM, WRET) From STKVAL
    If WTCM<>""
      If find([F:TCM]ISSVLTCOD,4,5,6)
        Read [ITV2]ITV0 = [F:ITF2]ITMREF;[F:ITF2]STOFCY
        If !fstat
          If [F:ITV2]AVCBASQTY <> 0
            mkstat = 2 : GERR = 1
            GMESSAGE = mess(594,199,1)
            Break
          Endif
         Endif
      Endif
    Endif
  Next
  If mkstat
    VALEUR = [M:ITM2]BRDCOD
    Affzo [M:ITM2]BRDCOD : End
  Endif
 Endif

 For [ITC2] Where ITMREF = [M:ITM0]ITMREF  & find([F:ITC2]CSTTYP,1,2) & [F:ITC2]ITCENDDAT >= date$
    For [ITF2] Where ITMREF = [M:ITM0]ITMREF
      Call GETTCM([M:ITM0]ITMREF, [F:ITF2]STOFCY, WTCM, WRET) From STKVAL
      If WTCM<>""
        If find([F:TCM]ISSVLTCOD,1,2)
           GERR = 3
           GMESSAGE = mess(207,199,1)-"."-mess(592,199,1)
           Break 2
        Endif
      Endif
    Next
    GERR = 3
    GMESSAGE = mess(207,199,1)
 Next
Endif

End

#------------#
# Ecran ITM3 #
#------------#

Subprog C_STU(VALEUR)
#-------------#
# Contrôle US #
#-------------#
Variable Char     VALEUR
Local    Integer  OK
# Interdire la modif si des mvts existent déjŕ
If (GREP="M" | GREP="") & VALEUR <> [M:ITM3]STU  # au lieu de [F:ITM]STU  Bug 9923
#   If clalev([F:ITV]) = 0 : Local File ITMMVT [ITV] : Endif
#   Look [ITV]ITV0(1) = [M:ITM0]ITMREF          ## Corr bug 8335
   If clalev([F:STO]) = 0 : Local File STOCK [STO] : Endif
   Look [STO]STO3(1) = [M:ITM0]ITMREF
      If !fstat
          mkstat = 2
          GMESSAGE = mess(57,199,1)
          End                         # (19/12/01)
      Endif
Endif
If dim([M:ITM2]SERMGTCOD) > 0
   If VALEUR<>[M:ITM3]STU & [M:ITM2]SERMGTCOD>1
      If [F:TUN]UOMDEC<>0
        If !GIMPORT Then # FGR 18/12/2009 : X3SUIVI61022
          OK=2
          Call AVERTIR(mess(484,199,1),OK) From GESECRAN
          If OK=1 mkstat=2 : End Endif
        Endif
      Endif
   Endif
Endif

#--- Issue X3-156573
# si présence dans BOMD, message d'avertissement
If VALEUR<>[M:ITM3]STU & !GIMPORT
   If !clalev([F:BOD1]) : Local File BOMD [F:BOD1] : Endif
   Filter [F:BOD1] Where find(BOMALTTYP,2,3) & CPNITMREF=[M:ITM0]ITMREF
   For [F:BOD1]BOD1
      OK=2
      Call AVERTIR(mess(710,199,1),OK) From GESECRAN
      If OK=1 : mkstat=2 : Endif
      Break
   Next
   Filter [F:BOD1]
   If mkstat=2 : End : Endif
Endif
#---

If VALEUR <> [M:ITM3]STU & [M:ITM3]STU <> "" & !GIMPORT # bug 12046 (19/12/01)
  GMESSAGE = mess(307,199,1) : GERR=2 # "vérifiez les coeff rattachés" (sauf 1er passage)
Endif
End


Subprog AM_STU(VALEUR)
#-----------------#
# Apres-modif stu #
#-----------------#
Variable Char VALEUR()
If GIMPORT
  If GREP="M"
   GMESSAGE = mess(307,199,1) : GERR=2 # "vérifiez les coeff rattachés" (sauf 1er passage)
  Endif
###Elsif [M:ITM3]STU <> ""
###  GMESSAGE = mess(307,199,1) : GERR=2 # mis en C_ pour le cas de zone initialisée (12046)
Endif
#MAE, bg 86513
If [M:ITM3]SAU = VALEUR
  [M:ITM3]DACSAUCOE=1
  Affzo [M:ITM3]DACSAUCOE
Endif
# Issue 89214 - 2013-05-02 by MAE : vérification que l'unité de stock choisie ne fait pas partie des unités de conditionnement
If [M:ITM3]BASTAB >0
  For I=0 To [M:ITM3]BASTAB-1
    If [M:ITM3]PCU(I) = VALEUR
      GMESSAGE = mess(620,199,1) : mkstat=2 # "L'unité de stock doit ętre différente de l'unité de conditionnement" (sauf 1er passage)
     Endif
  Next
Endif
End

Subprog AS_WEU(VALEUR)
#--------------------------#
# Avant saisie unité poids #
#--------------------------#
Variable Char     VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# interdit pour un article de sous-traitance
If [F:ITG]SCSFLG = 2
 VALEUR = ""
 mkstat = 2
Endif
End

Subprog AS_ITMWEI(VALEUR)
#---------------#
# Poids de l'US #
#---------------#
Variable Decimal  VALEUR
If [M:ITM3]WEU = "" mkstat = 2 Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITM3) 14/02/2006 11:19:59 (CCC)
######################################################################################
Subprog AS_VOU(VALEUR)
Variable Char    VALEUR()
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# interdit pour un article de sous-traitance
If [F:ITG]SCSFLG = 2
 VALEUR = ""
 mkstat = 2
Endif
End

Subprog AS_ITMVOU(VALEUR)
Variable Decimal VALEUR
If [M:ITM3]VOU = "" mkstat = 2 Endif
End


Subprog D_PUU(VALEUR)
#---------#
# Init UA #
#---------#
Variable Char     VALEUR
VALEUR = [M:ITM3]STU
End

Subprog AS_PUU(VALEUR)
#-----------------#
# Avant saisie UA #
#-----------------#
Variable Char     VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# pour article fantôme pas d'unité d'achat
# Issue X3-153275 - 2019-07-26 by MAE : si fantôme et pas acheté, unité achat inaccessible
#If [F:ITG]PHAFLG  = 2
If [F:ITG]PHAFLG  = 2 & [F:ITG]PURFLG<>2
 VALEUR ="" : mkstat = 2 : Endif
End

Subprog C_PUU(VALEUR)
#-------------#
# Contrôle UA #
#-------------#
Variable Char     VALEUR
If [F:ITG]PURFLG = 2  & VALEUR = ""
   mkstat = 2
   GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
End

Subprog AM_PUU(VALEUR)
#----------------#
# Apres modif UA #
#----------------#
Variable Char    VALEUR()
Local Integer OK
#MAE, bg 56967
If !GIMPORT
    OK=1 : Call AVERTIR(mess(389,194,1),OK) From GESECRAN
    If OK<>2  mkstat=2 : End : Endif
Endif
Call MODUNIT(VALEUR,[M:ITM3]STU,[M:ITM3]PUUSTUCOE)
Affzo [M:ITM3]PUUSTUCOE
# Issue 70985 - 2012-05-30 by MUARN : landed cost ajout UA sur onglet achat/vente
If VALEUR <> [M:ITM3]PUU & [M:ITM3]PUU <> "" &
& ([M:ITM4]ITMCPRCOE <> 1 | [M:ITM4]ITMCPRAMT<>0 | [M:ITM4]ITMSTCNUM<> "") & !GIMPORT
  GMESSAGE = mess(593,199,1) : GERR=2 # "vérifiez les frais d'approche"
Endif
[M:ITM4]ITMPUU = VALEUR
Affzo [M:ITM4]1-99
End

Subprog AS_PUUSTUCOE(VALEUR)
#----------------------------#
# Avant saisie coeff puu-stu #
#----------------------------#
Variable Decimal  VALEUR
Call COEFCNV([M:ITM3]PUU,[M:ITM3]STU,VALEUR)
End

Subprog C_PUUSTUCOE(VALEUR)
#------------------------#
# Contrôle coeff puu-stu #
#------------------------#
Variable Decimal  VALEUR
If VALEUR = 0 & [M:ITM3]PUU <> ""
 mkstat = 1
 GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
End

Subprog AM_PUUSTUCOE(VALEUR)
#--------------------------#
# Aprčs modif coef PUU-STU #
#--------------------------#
Variable Decimal  VALEUR
Local Integer OK

  If !GIMPORT Then # FGR 18/12/2009 : X3SUIVI61022
    OK=1 : Call AVERTIR(mess(389,194,1),OK) From GESECRAN
    If OK<>2  mkstat=2 : End : Endif
  Endif
End

Subprog D_SAU(VALEUR)
#-------------------#
# Initialisation UV #
#-------------------#
Variable Char    VALEUR()
VALEUR = [M:ITM3]STU
#[M:ITG3]SAUSTUCOE = 1        # hcb 103984
[M:ITM3]SAUSTUCOE = 1        # Issue 118400 - 2016-09-08 by MAE

End

Subprog AS_SAU(VALEUR)
#-----------------#
# Avant saisie UV #
#-----------------#
Variable Char     VALEUR
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Issue 59757 - 2017-10-27 by MAE : erreur uniquement si article non vendu et non livrable
#If [F:ITG]SCSFLG = 2 | [F:ITG]SALFLG <> 2
If [F:ITG]SALFLG <> 2  & [F:ITG]DLVFLG <> 2
   mkstat =2
Endif
End

Subprog C_SAU(VALEUR)
#-------------#
# Contrôle UV #
#-------------#
Variable Char     VALEUR
# obligatoire si Catégorie d'articles vendus
If VALEUR = "" & [F:ITG]SALFLG = 2
   mkstat = 2
   GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif

#--- Issue X3-156573
# si présence dans BOMD, message d'avertissement
If VALEUR<>[M:ITM3]SAU & !GIMPORT
   Local Integer OK
   If !clalev([F:BOD1]) : Local File BOMD [F:BOD1] : Endif
   Filter [F:BOD1] Where BOMALTTYP=1 & CPNITMREF=[M:ITM0]ITMREF
   For [F:BOD1]BOD1
      OK=2
      Call AVERTIR(mess(710,199,1),OK) From GESECRAN
      If OK=1 : mkstat=2 : Endif
      Break
   Next
   Filter [F:BOD1]
   If mkstat=2 : End : Endif
Endif
#---

End

Subprog AM_SAU(VALEUR)
#-------------------------#
# Aprčs modif unité vente #
#-------------------------#
Variable Char    VALEUR()
Call MODUNIT(VALEUR,[M:ITM3]STU,[M:ITM3]SAUSTUCOE)
Affzo [M:ITM3]SAUSTUCOE
If GIMPORT | GMODU(12)<>2 | clalev([M:ITAV])=0 : End : Endif
#Modif CRM 4 juin 2003
#Propose des valeurs d'unité de temps par défaut.
If [M:ITAV]HDKITMTYP = 3
    If VALEUR <> ""
        Read [UOT] UOT0 = VALEUR
        If !fstat
            Case [F:UOT]TYPUOM
                When 2
                    If [M:ITAV]DAYUOM = ""
                        [M:ITAV]DAYUOM = VALEUR
                    Endif
                    If [M:ITAV]HOUUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 3 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]HOUUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif
                    If [M:ITAV]MNTUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 4 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]MNTUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif

                When 3
                    If [M:ITAV]DAYUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 2 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]DAYUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif
                    If [M:ITAV]HOUUOM = ""
                        [M:ITAV]HOUUOM = VALEUR
                    Endif
                    If [M:ITAV]MNTUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 4 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]MNTUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif

                When 4
                    If [M:ITAV]DAYUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 2 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]DAYUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif
                    If [M:ITAV]HOUUOM = ""
                        Filter [UOT] Where [F:UOT]TYPUOM = 3 Order By [F:UOT]UOM Asc
                        For [UOT]
                            [M:ITAV]HOUUOM = [F:UOT]UOM
                            Break
                        Next
                        Filter [UOT]
                    Endif
                    If [M:ITAV]MNTUOM = ""
                       [M:ITAV]MNTUOM = VALEUR
                    Endif
                Endcase
        Endif
    Endif
Endif
#MAE, bg 86513
If VALEUR = [M:ITM3]STU | VALEUR=""
  [M:ITM3]DACSAUCOE=1
  Affzo [M:ITM3]DACSAUCOE
Endif
End


