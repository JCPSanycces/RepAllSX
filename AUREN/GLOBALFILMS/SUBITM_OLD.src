#                                                  # hcb 71276 deb 37
Subprog C_ECCSTO(VALEUR)
Variable Integer VALEUR


# Test modification autorisée (pas de lot existants)
If VALEUR <> [F:ITM]ECCSTO
  If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
  Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&                     LOT    <> ""              &
&                     QTYSTU <> 0
&               Order By Key STO3
  For [STO1]
    GERR = 2  # des enregistrements de stock existent pour cet article (non bloquant)
    GMESSAGE = mess(68,188,1)
    Break
  Next
  Filter [STO1]
Endif


End

Subprog C_ECCFLG(VALEUR)
Variable Integer VALEUR
# Test modification autorisée (pas de lot existants)
If VALEUR <> [M:ITM2]ECCFLG & [M:ITM2]ECCSTO > 1
  If clalev([F:STO1]) = 0 : Local File STOCK [STO1] : Endif
  Filter [STO1] Where ITMREF =  [M:ITM0]ITMREF  &
&                     LOT    <> ""              &
&                     QTYSTU <> 0
&               Order By Key STO3
  For [STO1]
    GERR = 2  # des enregistrements de stock existent pour cet article (non bloquant)
    GMESSAGE = mess(68,188,1)
    Break
  Next
  Filter [STO1]
Endif

End



Subprog AS_ECCSTO(VALEUR)
Variable Integer VALEUR
# Issue X3-70921 - 2018-03-05 by MAE : possibilité dans les catégories d'avoir la version stock a non => harmonisation sur les articles
#GMENLOC(1) = 1

End
#                                                  # hcb 71276 fin

#                                                              # hcb 71276 deb
Subprog AP_STOMGTCOD(VALEUR)
Variable Integer VALEUR
If dim([M:ITM2]ECCFLG)>0 & [M:ITM2]ECCFLG = 2      # hcb X3-38370 2018-10-09
#                                                              # hcb 71276 43 deb
#  # recherche si l article est present dans les nomencltures
   Local Integer WFIND
   Raz WFIND
   If [M:ITM0]ITMREF <> AVOID.ACHAR   # Issue X3-38370 - 2018-09-14 by MAE : Vérification dans les nomenclatures si article renseigné
    If !clalev([F:BOH1]) : Local File BOM [F:BOH1] : Endif
#   si présence dans BOM bloc versions non modifiable
    Filter [F:BOH1] Where find(BOMALTTYP,2,3) & ITMREF=[M:ITM0]ITMREF
      For [F:BOH1]BOH0
          WFIND = 2
          Break
      Next
    Filter [F:BOH1]
    If WFIND = 0
#   si présence dans BOMD bloc versions non modifiable
      If !clalev([F:BOD1]) : Local File BOMD [F:BOD1] : Endif
      Filter [F:BOD1] Where find(BOMALTTYP,2,3) & CPNITMREF=[M:ITM0]ITMREF
         For [F:BOD1]BOD0
             WFIND = 2
             Break
         Next
      Filter [F:BOD1]
    Endif
#   Issue 104937 - 2015-11-12 by GH : Versioning for routing
    If WFIND = 0 & dim([M:ITM2]ECCROUFLG)>0 & [M:ITM2]ECCROUFLG=2
      If clalev([F:ROH])=0 : Local File ROUTING    [ROH] : Endif
      Look [ROH]ROH0(1) = [M:ITM0]ITMREF
      If !fstat : WFIND=2 : Endif
    Endif
#
    If WFIND = 2
      # Issue X3-38370 - 2018-09-12 by MAE : si article géré dans nomenclature, pas de lot impossible
        If VALEUR=1
          mkstat = 2
          GMESSAGE = mess(703,199,1)
        Endif
      # End issue X3-38370
        End
    Endif
Endif     # Issue X3-38370 - 2018-09-14 by MAE
#                                                              # hcb 71276 43 fin
   If VALEUR = 1
      Raz   [M:ITM2]ECCFLG
      Raz   [M:ITM2]ECCSTO
      Raz   [M:ITM2]ECCMIN
      Raz   [M:ITM2]ECCMAJ
      [M:ITM4]LOAECCFLG = 1
      [M:ITP]XLOAECCFLG = 1
      [M:ITS]LOAECCFLG = 1        # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      [M:ITU]XLOAECCFLG = 1  Endif      # FGR 23/04/2015 : X3SUIVI105605
      Affzo [M:ITM2]ECCFLG
      Affzo [M:ITM2]ECCSTO
      Affzo [M:ITM2]ECCMIN
      Affzo [M:ITM2]ECCMAJ
      Affzo [M:ITM4]LOAECCFLG
      Affzo [M:ITP]XLOAECCFLG
      Affzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      Affzo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
      Diszo [M:ITM2]ECCFLG
      Diszo [M:ITM2]ECCSTO
      Diszo [M:ITM2]ECCMIN
      Diszo [M:ITM2]ECCMAJ
      Diszo [M:ITM4]LOAECCFLG
      Diszo [M:ITP]XLOAECCFLG
      Diszo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      Diszo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
      If dim([M:ITM2]ECCROUFLG)>0    # Issue 104937 - 2015-11-12 by GH : Versioning for routing
         Effzo [ITM2]ECCROUFLG : Diszo [ITM2]ECCROUFLG
      Endif
   Else
      # Issue X3-121038 - 2019-01-14 by MAE : comment
      #If dim([ITM2]LOTMGTCOD) > 0 & [ITM2]LOTMGTCOD > 1
      If dim([ITM2]LOTMGTCOD) > 0 & [ITM2]LOTMGTCOD > 3
         Actzo [M:ITM2]ECCFLG
      Endif
   Endif
Endif

End

Subprog AP_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
If dim([M:ITM2]ECCFLG)>0 & [M:ITM2]ECCFLG = 2      # hcb X3-38370 2018-10-09
#                                                              # hcb 71276 43 deb
#  # recherche si l article est present dans les nomencltures
   Local Integer WFIND
   Raz WFIND
   If [M:ITM0]ITMREF <> AVOID.ACHAR   # Issue X3-38370 - 2018-09-14 by MAE : Vérification dans les nomenclatures si article renseigné
    If !clalev([F:BOH1]) : Local File BOM [F:BOH1] : Endif
    #  si présence dans BOM bloc versions non modifiable
    Filter [F:BOH1] Where find(BOMALTTYP,2,3) & ITMREF=[M:ITM0]ITMREF
      For [F:BOH1]BOH0
          WFIND = 2
          Break
      Next
    Filter [F:BOH1]
    If WFIND = 0
    #  si présence dans BOMD bloc versions non modifiable
      If !clalev([F:BOD1]) : Local File BOMD [F:BOD1] : Endif
      Filter [F:BOD1] Where find(BOMALTTYP,2,3) & CPNITMREF=[M:ITM0]ITMREF
         For [F:BOD1]BOD0
             WFIND = 2
             Break
         Next
      Filter [F:BOD1]
     Endif
  # Issue 104937 - 2015-11-12 by GH : Versioning for routing
    If WFIND = 0 & dim([M:ITM2]ECCROUFLG)>0 & [M:ITM2]ECCROUFLG=2
      If clalev([F:ROH])=0 : Local File ROUTING    [ROH] : Endif
      Look [ROH]ROH0(1) = [M:ITM0]ITMREF
      If !fstat : WFIND=2 : Endif
     Endif
#
   If WFIND = 2
      # Issue X3-38370 - 2018-09-12 by MAE : si article géré dans nomenclature, pas de lot impossible
      If VALEUR<3
        mkstat = 2
        GMESSAGE = mess(703,199,1)
       Endif
      # End issue X3-38370
      End
   Endif
Endif    # Issue X3-38370 - 2018-09-14 by MAE : comment
#                                                              # hcb 71276 43 fin
   If VALEUR < 3
      Diszo [M:ITM2]ECCFLG                  # hcb 110739 deb
      [M:ITM2]ECCFLG = 1
      Affzo [M:ITM2]ECCFLG
#      Actzo [M:ITM2]ECCFLG                 # hcb 110739 fin
      [M:ITM2]ECCSTO = 1
      Diszo [M:ITM2]ECCSTO
      Affzo [M:ITM2]ECCSTO
      [M:ITM4]LOAECCFLG = 1
      [M:ITP]XLOAECCFLG = 1
      [M:ITS]LOAECCFLG = 1        # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      [M:ITU]XLOAECCFLG = 1  Endif      # FGR 23/04/2015 : X3SUIVI105605
      Diszo [M:ITM4]LOAECCFLG
      Diszo [M:ITP]XLOAECCFLG
      Diszo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      Diszo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
      Raz   [M:ITM2]ECCMIN                 # hcb 110739
      Raz   [M:ITM2]ECCMAJ                 # hcb 110739
      Affzo [M:ITM2]ECCMIN                 # hcb 110739
      Affzo [M:ITM2]ECCMAJ                 # hcb 110739
      Diszo [M:ITM2]ECCMIN                 # hcb 110739
      Diszo [M:ITM2]ECCMAJ                 # hcb 110739
      If dim([M:ITM2]ECCROUFLG)>0    # Issue 104937 - 2015-11-12 by GH : Versioning for routing
         Effzo [ITM2]ECCROUFLG : Diszo [ITM2]ECCROUFLG
      Endif
   Else
      Actzo [M:ITM2]ECCFLG
      If [M:ITM2]ECCFLG = 2
         Actzo [M:ITM2]ECCSTO
      Endif
   Endif
Endif

End

Subprog AP_ECCFLG(VALEUR)
Variable Integer VALEUR
   If VALEUR = 1
      Raz   [M:ITM2]ECCSTO
      Raz   [M:ITM2]ECCMIN
      Raz   [M:ITM2]ECCMAJ
      [M:ITM4]LOAECCFLG = 1
      [M:ITP]XLOAECCFLG = 1
      [M:ITS]LOAECCFLG = 1        # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      [M:ITU]XLOAECCFLG = 1  Endif      # FGR 23/04/2015 : X3SUIVI105605
      Affzo [M:ITM2]ECCSTO
      Affzo [M:ITM2]ECCMIN
      Affzo [M:ITM2]ECCMAJ
      Affzo [M:ITM4]LOAECCFLG
      Affzo [M:ITP]XLOAECCFLG
      Affzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      Affzo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
      Diszo [M:ITM2]ECCSTO
      Diszo [M:ITM2]ECCMIN
      Diszo [M:ITM2]ECCMAJ
      Diszo [M:ITM4]LOAECCFLG
      Diszo [M:ITP]XLOAECCFLG
      Diszo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
       # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0      Diszo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
   Else
      If [M:ITM2]LOTMGTCOD < 3
         [M:ITM2]ECCSTO    = 1
         Affzo [M:ITM2]ECCSTO
         Diszo [M:ITM2]ECCSTO
         Diszo [M:ITM4]LOAECCFLG
         Diszo [M:ITP]XLOAECCFLG
         Diszo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
          # Issue 119820
         If dim([M:ITU]XLOAECCFLG)>0         Diszo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
         # Issue X3-121038 - 2019-01-15 by MAE : les compteurs version ne sont pas accessibles si version stock ŕ non
         #Actzo [M:ITM2]ECCMIN
         #Actzo [M:ITM2]ECCMAJ
         Diszo [M:ITM2]ECCMIN
         Diszo [M:ITM2]ECCMAJ
      Else
         Actzo [M:ITM2]ECCSTO
         Actzo [M:ITM2]ECCMIN
         Actzo [M:ITM2]ECCMAJ
         Actzo [M:ITM4]LOAECCFLG
         Actzo [M:ITP]XLOAECCFLG
         Actzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
         # Issue 119820
          If dim([M:ITU]XLOAECCFLG)>0         Actzo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
      Endif
   Endif
   If dim([M:ITM2]ECCROUFLG)>0    # Issue 104937 - 2015-11-12 by GH : Versioning for routing
      If varmode([M:ITM2]ECCMAJ) & !varmode([M:ITM2]ECCROUFLG)
         Effzo [ITM2]ECCROUFLG : Diszo [ITM2]ECCROUFLG
      Elsif !varmode([M:ITM2]ECCMAJ) & varmode([M:ITM2]ECCROUFLG)
         Actzo [ITM2]ECCROUFLG
      Endif
   Endif
End

Subprog AP_ECCSTO(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  # Issue X3-121038 - 2019-01-15 by MAE : compteurs maj et min pas accessible si pas version stock
   #Actzo [M:ITM2]ECCMIN
   #Actzo [M:ITM2]ECCMAJ
   Raz   [M:ITM2]ECCMIN
   Affzo [M:ITM2]ECCMIN
   Diszo [M:ITM2]ECCMIN
   Raz   [M:ITM2]ECCMAJ
   Affzo [M:ITM2]ECCMAJ
   Diszo [M:ITM2]ECCMAJ
   # End issue X3-121038
   [M:ITM4]LOAECCFLG = 1
   [M:ITP]XLOAECCFLG = 1
   [M:ITS]LOAECCFLG = 1        # FGR 23/04/2015 : X3SUIVI105605
   # Issue 119820
   If dim([M:ITU]XLOAECCFLG)>0   [M:ITU]XLOAECCFLG = 1  Endif      # FGR 23/04/2015 : X3SUIVI105605
   Affzo [M:ITM4]LOAECCFLG
   Affzo [M:ITP]XLOAECCFLG
   Affzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
   # Issue 119820
   If dim([M:ITU]XLOAECCFLG)>0   Affzo [M:ITU]XLOAECCFLG  Endif     # FGR 23/04/2015 : X3SUIVI105605
   Diszo [M:ITM4]LOAECCFLG
   Diszo [M:ITP]XLOAECCFLG
   Diszo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
   # Issue 119820
   If dim([M:ITU]XLOAECCFLG)>0   Diszo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
    # Issue 71276 - 2015-03-20 by SR : Versions
   [M:ITM2]ECSMGT = ""
   Grizo [M:ITM2]ECSMGT
   Affzo [M:ITM2]ECSMGT
Elsif VALEUR = 2
   Raz   [M:ITM2]ECCMIN
   Affzo [M:ITM2]ECCMIN
   Diszo [M:ITM2]ECCMIN
   Actzo [M:ITM2]ECCMAJ
   Actzo [M:ITM4]LOAECCFLG
   Actzo [M:ITP]XLOAECCFLG
   Actzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
   # Issue 119820
   If dim([M:ITU]XLOAECCFLG)>0   Actzo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
Else  VALEUR = 3
   Actzo [M:ITM2]ECCMAJ
   Actzo [M:ITM2]ECCMIN
   Actzo [M:ITM4]LOAECCFLG
   Actzo [M:ITP]XLOAECCFLG
   Actzo [M:ITS]LOAECCFLG      # FGR 23/04/2015 : X3SUIVI105605
   # Issue 119820
   If dim([M:ITU]XLOAECCFLG)>0   Actzo [M:ITU]XLOAECCFLG  Endif    # FGR 23/04/2015 : X3SUIVI105605
Endif
If dim([M:ITM2]ECCROUFLG)>0    # Issue 104937 - 2015-11-12 by GH : Versioning for routing
   If !varmode([M:ITM2]ECCMAJ) & varmode([M:ITM2]ECCROUFLG)
      Actzo [ITM2]ECCROUFLG
   Endif
Endif
End

Subprog C_ECCMIN(VALEUR)
Variable Char    VALEUR()
If [M:ITM2]ECCSTO = 3 & VALEUR = ""
   GMESSAGE = mess(10,123,1)   : # Zone obligatoire
   mkstat = 2
   End
Endif

End
#                                                              # hcb 71276 fin

######################################################################################
## Section automatically added (screen ITM2) 29/06/2015 16:23:45 (BRBAN)
######################################################################################
Subprog AS_INVPRODTYP(VALEUR)
Variable Integer VALEUR

GMENLOC(5) = 1

End


######################################################################################
# Issue 104937 - 2015-11-12 by GH : Versioning for routing
Subprog AS_ECCROUFLG(VALEUR)
Variable Integer VALEUR
If [M:ITM2]ECCMAJ=""
   mkstat=1
Else
   If clalev([F:ROH])=0 : Local File ROUTING    [ROH] : Endif
   Look [ROH]ROH0(1) = [M:ITM0]ITMREF
   If !fstat : mkstat=2 : Endif
Endif
End

######################################################################################
Subprog C_ECCROUFLG(VALEUR)
Variable Integer VALEUR
    If func CTLECCROULNK([M:ITM0]ITMREF,[M:ITM2]ECCROUFLG,VALEUR)
        mkstat=2
    Endif
End


#**----------------------------------------------------------------<br/>
#* CTLECCROULNK : Control route links between a product and others if ECCROUFLG changes
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM = Product code
#* @param FLG1 = old value of ECCROUFLG
#* @param FLG2 = new value of ECCROUFLG
#* @return 0= OK<br/>
#* 1= A route version exists<br/>
#* 2= A link exists on a site with another route<br/>
#* 3= The route is used by an other product-site <br/>
#* + GMESSAGE assigned
#**<br/>----------------------------------------------------------------
#*!
Funprog CTLECCROULNK(ITM, FLG1, FLG2)
Value Char ITM
Value Integer FLG1, FLG2

Local Integer LRET

Local Char REQ(250)(3)
Local Integer I

Raz GMESSAGE

# ECCROUFLG can be equal to 0 or 1 but it means the same
FLG1=max(1,FLG1)
FLG2=max(1,FLG2)
If FLG1=FLG2 : End 0 : Endif

If clalev([F:RVV])=0 : Local File RVMVAL [RVV] : Endif

If FLG2=1
    # If a route with version exists, don't allow to disable route version management
    Look [RVV]RVV0(1)=ITM
    Filter [RVV]
    If !fstat
        GMESSAGE = mess(336,193,1) # A route version exists
        LRET=1
        End LRET
    Endif
Endif
# Check if the product ITM is using another route
Call ADDCRIT(REQ,I,"","SELECT DISTINCT ITF.STOFCY_0, ITM.ITMREF_0"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","FROM  ITMMASTER ITM, ITMFACILIT ITF"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","WHERE ITF.ITMREF_0='"+ITM+"'"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"",  "AND ITF.ITMREF_0 NOT IN (' ',ITF.MFGROU_0, ITF.CSTROU_0, ITF.RCCROU_0)"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"",  "AND ITM.ITMREF_0 IN (ITF.MFGROU_0, ITF.CSTROU_0, ITF.RCCROU_0)"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"",  "AND ITM.ECCROUFLG_0<>"+num$(FLG2)," ") From GOBJSUB

For (Char STOFCY, Char ITMREF) From num$(GTYPDBA*2+1) Sql REQ As [RITF]
    GMESSAGE = func AFNC.MES2(mess(337,193,1),[F:RITF]STOFCY,[F:RITF]ITMREF) # A link exists for site $1$ with route $2$
    GMESSAGE += "\"+mess(176,115,1) # Delete the link
    LRET=2
    Break
Next

If LRET : End LRET : Endif

# Check if this product is used by another product for its route
Raz REQ, I
Call ADDCRIT(REQ,I,"","SELECT DISTINCT ITF.STOFCY_0, ITF.ITMREF_0"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","FROM ITMMASTER ITM, ITMFACILIT ITF"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","WHERE '"+ITM+"' IN (ITF.MFGROU_0, ITF.CSTROU_0, ITF.RCCROU_0)"," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","AND ITM.ECCROUFLG_0<>"+num$(FLG2)," ") From GOBJSUB
Call ADDCRIT(REQ,I,"","AND ITM.ITMREF_0=ITF.ITMREF_0"," ") From GOBJSUB
For (Char STOFCY, Char ITMREF) From num$(GTYPDBA*2+1) Sql REQ As [RITF]
    GMESSAGE = func AFNC.MES2(mess(338,193,1),[F:RITF]ITMREF,[F:RITF]STOFCY) # The route is used by product-site $1$-$2$
    GMESSAGE += "\"+mess(176,115,1) # Delete the link
    LRET=3
    Break
Next

End LRET

Subprog C_ECCMAJ(VALEUR)
Variable Char    VALEUR()
If [M:ITM2]ECCSTO > 1 & VALEUR = ""
   GMESSAGE = mess(10,123,1)   : # Zone obligatoire
   mkstat = 2
   End
Endif

End


