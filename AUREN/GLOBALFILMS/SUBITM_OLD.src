#<AdxTL>@(#)3.0.0.0 $Revision$
Call OBJET("ITM", GBIDC1, GBIDC2) From GOBJET
End

$ACTION
#--- Dem 74959
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---
Case ACTION
 When "OUVRE"       Gosub OUVRE
 When "FERME"       Gosub FERME
 When "SETBOUT"     Gosub SETBOUT
 When "AVANTBOUT"   Gosub AVANTBOUT
 When "AVANT_MOD"   Gosub AVANT_MOD
 When "AVANT_MODFIC"   Gosub AVANT_MODFIC          # hcb dlu
 When "EXEBOUT"     Gosub EXEBOUT
 When "STATUT"      Gosub TEXTE
 When "FILTRE"      Gosub FILTRE
 When "INICRE"      Gosub INICRE
 When "INIMOD"      Gosub INIMOD
 When "RAZCRE"      Gosub RAZCRE
 When "RAZDUP"      Gosub RAZDUP
 When "VERIF_CRE"   Gosub VERIF_CRE
 When "VERIF_MOD"   Gosub VERIF_CRE
 When "CREATION"    Gosub TR_CRE
 When "APRES_CRE"   Gosub APRES_CRE
 When "APRES_MOD"   Gosub APRES_MOD
 When "MODIF"       Gosub TR_MOD
 When "LIENS"       Gosub LIENS
 When "APRES_CHOI"  Gosub APRES_CHOI
 When "APRES_MODIF" Gosub APRES_MODIF
 When "ANNULE"      Gosub ANNULE
 When "ABANDON"     Gosub ABANDON
 When "EFFMASK"     Gosub EFFMASK
 When "ACL_ECSMGT"  Gosub ACL_ECSMGT          # Issue 71276 - 2015-03-20 by SR : Versions
 When "BCL_ECSMGT"  Gosub BCL_ECSMGT          # Issue 71276 - 2015-03-20 by SR : Versions
 When "AB1_DES1AXX" Gosub AB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When "BB1_DES1AXX" Gosub BB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When "AB1_DES2AXX" Gosub AB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When "BB1_DES2AXX" Gosub BB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When "AB1_DES3AXX" Gosub AB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When "BB1_DES3AXX" Gosub BB1_DESAXX          # Issue X3-126821 - 2019-03-06 by VAVIL
 When Default
Endcase
Return

#                          # hcb dlu deb
$AVANT_MODFIC
If dim([M:ITM2]EXYMGTCOD)>0
   If [F:ITM]EXYMGTCOD = [M:ITM2]EXYMGTCOD
      Return
   Endif
   If find([F:ITM]EXYMGTCOD,2,5,6) & find([M:ITM2]EXYMGTCOD,1,3,4)
      Filter [ITF] Where [F:ITF]ITMREF=[M:ITM0]ITMREF
             For [ITF]ITF0
                 [F:ITF]DLU = 1
                 Rewrite [ITF]
             Next
      Filter [ITF]
   Endif
Endif
Return
#                          # hcb dlu fin
$OUVRE
#-------------------------------------------------------#
# Ouvre : Début de traitement avant ouverture du masque #
#-------------------------------------------------------#
Global Integer GTLPBOUT  # pour btn Ligne de produit 21/12/00 TB
Local Decimal WMNTORG(0..2)
Local Decimal WMNTDES(0..2)
Local Integer SPSTAT
Local Char    WITMREFSSTRT    #référence article sous traité
Local Char    WITMCPNI        #référence matičre pour sous traitance
#MAE, bug 108956
Local Integer GCONSULT_SAV

Local Char OBJET(GLONAOB)

If clalev([F:ITS]) : Close Local File [ITS] : Endif
Local File ITMSALES [ITS]
If clalev([F:ITU]) : Close Local File [ITU] : Endif
Local File ITMBPC [ITU]
If clalev([F:ITP]) : Close Local File [ITP] : Endif
Local File ITMBPS [ITP]
If clalev([F:ADI]) : Close Local File [ADI] : Endif
Local File ATABDIV [ADI]
If clalev([F:ITA]) : Close Local File [ITA] : Endif
Local File ITMACGGRP [ITA]

If !clalev([F:ITM2]) : Local File ITMMASTER [ITM2] : Endif  # FGR 30/06/2009 : X3SUIVI56189
If !clalev([F:ITM3]) : Local File ITMMASTER [ITM3] : Endif  # MAE, bg 78849
If !clalev([ECS]) : Local File ECCSTA [ECS] : Endif   # hcb 71276
If !clalev([EVL]) : Local File ECCVAL [EVL] : Endif   # hcb 71276

# Issue X3-88081 - 2018-05-29 by USA : BEGIN
  If !clalev([F:DRS]) : Local File DEFBPS [DRS] : Endif
  If !clalev([F:DBS]) : Local File DEFCTMBPS [DBS] : Endif
# Issue X3-88081 - 2018-05-29 by USA : END

If clalev([F:STCH])=0 Local File COSTSTCH    [STCH] Endif # Issue 84130 - 2012-09-18 by MUARN : landed cost SDC
If clalev([F:STCF])=0 Local File COSTSTCF    [STCF] Endif # Issue 90991 - 2013-11-08 by MAE : landed cost SDC

# Issue X3-129492 - 2019-06-03 by WHA : Open Table Detail BOMs
If clalev([F:BOMD])=0 Local File BOMD [BOMD] Endif
# End issue number

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB


#---- Chargement de GCUR
Call CHARGE_GCUR() From TRTX3
#---- Ouverture table code activité
If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
If dim(GSLOACTIV) <1
    Global Integer GSLOACTIV
Endif
Read [ACV] CODACT = "SLO"
If !fstat & [F:ACV]FLACT=2
   GSLOACTIV=2
Else
   GSLOACTIV=1
Endif

  #---------------------------------------------------#
  #Modif CRM 09/02/2004
  #Vérification de l'activation de la gestion des jetons
  If dim(GITAVTITTOK) < 1 Then
    Global Char GITAVTITTOK(50)
  Endif

  Raz GITAVTITTOK
  If GMODU(12) = 2 Then
    # FGR 23/01/2009 : X3SUIVI41698
    If func CRMUTIL150.GET_CODE_ACTIVITE("HDK") = 2 Then
      # Le code activité "HDK" détermine la présence de cette écran
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 and func CRMUTIL150.GET_CODE_ACTIVITE("TOK") = 2 Then
        #Gestion des points et jetons
        Call TEXTE(24301, GITAVTITTOK) From OBJDIV
      Elsif func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        #Gestion des points
        Call TEXTE(22384, GITAVTITTOK) From OBJDIV
      Endif
    Endif
  Endif
  #---------------------------------------------------#

#Vérification de l'activation du module Support client
If dim(GIHDKACTCTL) <1
    Global Integer GIHDKACTCTL
Endif
GIHDKACTCTL = 0
Read [ACV] CODACT = "HDK"
If fstat
    GIHDKACTCTL = 0
Else
    If [F:ACV]FLACT = 2
        GIHDKACTCTL = 1
    Else
        GIHDKACTCTL = 0
    Endif
Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:FCY]) =0   Local File FACILITY   [FCY]   Endif       # hcb 42541
#MAE, 08/09/08
If clalev([F:CAC])=0  Local File GACCCODE   [CAC]  Endif
#MAE, bg 78225
If clalev([F:ITF])<=0 : Local File ITMFACILIT  [ITF] : Endif
#MAE, bg 79041
If !clalev([F:ITMS])  Local File ITMMASTER  [ITMS]  : Endif

Return

$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESITM" Raz GFONC1 : Endif
If GFONCTION1="GESITM"
    If dim(GSLOACTIV)>0
        Kill GSLOACTIV
    Endif
    If dim(GITAVTITTOK)>0
        Kill GITAVTITTOK
    Endif
    If dim(GIHDKACTCTL)>0
        Kill GIHDKACTCTL
    Endif
Endif
If dim(GFLTITM)>0 Raz GFLTITM Endif
Return

$FILTRE
If dim(GFLTITM)>0 & GFLTITM<>""
   FILTSUP = "ITMREF = GFLTITM"      # hcb 66592
Endif
Return

$SETBOUT
#-------------------------------------------------------------------------#
# Activation / désactivation des menus (ToolBar) et boutons (bas d'écran) #
# ------------------------------------+-----------------------------------#
# A  Menu texte                       ! Boutons de bas d'écran            #
#      AF : Texte achat               !                                   #
#      AG : Texte production          !      1  : Article-Site            #
#      AH : Texte vente               !      2  : Article-coűt            #
#      AI : Texte bon préparation     !      3  : Tarif vente             #
#      AM : Product notes             !                                   #
# B  Menu fonction                    |      4  : Tarif achat             #
#      BP : Associer articles concur. !                                   #
#      BQ : Débits de points          !                                   #
#      B? : Nomenclature commerciale  !                                   #
#      B/ : Nomenclature production   !                                   #
#      BS : Nomenclature s/traitance  !                                   #
#      BR : Gamme                     !                                   #
#      Ba : Recette   (STANT evol ergo)                                   #
#      BU : Creation article site (42541)                                 #
#      BE : Cas d'emploi (MAE, Evol_Ergo)                                 #
# C   Menu Consultation                                                   #
#      CB : En cours article                                              #
#      CO : Consultation de parc                                          #
#      CV : Menu Ventes                                                   #
#        CVJ : Ligne devis                                                #
#        CVL : Ligne commande                                             #
#        CVN : Ligne de livraison                                         #
#        CVT : Ligne facture                                              #
#        CV^ : Ligne retour                                               #
#      CA : Menu Achats                                                   #
#        CA, : Ligne commande                                             #
#        CA§ : Ligne reception                                            #
#        CAV : Ligne facture                                              #
#        CAX : Ligne retour                                               #
#        CA0 : conso sous traitance                                       #
#      CG : Production                                                    #
#        CG~ : Déclaration production                                     #
#        CG# : Consommation matičre                                       #
#        CG{ : Prix de revient                                            #
#        CG[ : Historique prix de revient                                 #
#        CG@ : Consulation OF                                             #
#      CS : Menu stock                                                    #
#        CSK : Stock par site                                             #
#        CS} : Stock projeté                                              #
#        CS% : Stock disponible                                           #
#        CSů : Stock ŕ date                                               #
#        CS] : Mouvements                                                 #
# D   MENU COűTS                                                          #
#      DZ : Coűts standard                                                #
#      DY : Coűts standard actualisé                                      #
#      D( : Coűts standard budget                                         #
#      D) : Coűts standard simulé                                         #
#-------------------------------------+-----------------------------------#


If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD & [M:ITM0]TCLCOD<>""
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
Local Integer WMFGFLG, WDLVFLG, WSCPFLG
# Chgt de clé non autorisé car dans certaines tables le LIEN est fait sur ITMFACILIT !
Call VIREBOUT(CHAINE,"H") From GOBJET
# Pour éviter Tunnel de tunnel en boucle ! : (rajout TB le 10/03/99)
If GFONC1 = "GESITF" | find("GESITF",GNAVIG(1..GPILNAV))
   Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

If CLECUR1 <> ""
#  Autorisation de modif selon profil gestionnaire
#MAE, bg 77059, si l'utilisateur n'a pas le code d'acces, il n'a pas le droit de modifier
  If [M:ITM1]PLAACS <> ""
    Read [ACC]CODACC=GUSER;[M:ITM1]PLAACS
      If fstat | [F:ACC]MODIF = 1
        Call VIREBOUT(CHAINE,"MA") From GOBJET
      Endif
  Endif

 #Virer le bouton Tarifs Achats si article de catégorie Fabriqué ou Fantôme
 # ou si le module Achat n'est pas présent (rajouté le 08/06/99)
 If ([M:ITM1]PURFLG = 1 & [M:ITM1]SCPFLG = 1 & [M:ITM1]SCSFLG = 1 & [M:ITM1]GENFLG = 1 & [M:ITM1]TOOFLG = 1 ) | GMODU(6) <> 2
   Call VIREBOUT(CHAINE,"4") From GOBJET
 Endif
 # Griser Tarif vente si le module Vente n'est pas présent (rajouté le 08/06/99)
 If GMODU(5) <> 2 | [F:ITG]SALFLG <> 2
   Call VIREBOUT(CHAINE,"3") From GOBJET
 Endif
Endif

# If CLECUR1 = "" reste renseigné si on créé aprčs avoir visualisé un enreg
If CLECUR = 0 | GREP <> ""
    Call VIREBOUT(CHAINE,"1234") From GOBJET
Endif

If GREP<>"D" & GREP<>"C" & CLECUR=0
Else
   CHMEN += "G"
   If [M:ITM1]SALFLG = 2
      CHMEN += "HI"
   Elsif [M:ITM1]DLVFLG = 2
      CHMEN += "I"
   Endif
   If ([M:ITM1]PURFLG = 2 | [M:ITM1]SCPFLG = 2 | [M:ITM1]SCSFLG = 2 | [M:ITM1]GENFLG = 2 | [M:ITM1]TOOFLG = 2 )
      CHMEN += "F"
   Endif
Endif

If GREP = ""  # test rajouté le 24/10/01
  #Modif CRM 23 juin 2000
  If GMODU(13) = 2
    CHMEN += "P"
  Endif
  If GMODU(12) = 2
    If GIHDKACTCTL
    CHMEN += "O"
    If clalev([M:ITAV])
       If [M:ITAV]TPLCONSRV = ""
          CHMEN += "Q"
       Endif
    Endif
    Endif
  Endif
  #MAE, le 11/02/08 EVOL_ERGO, ajout des encours article et des cas d'emploi
  CHMEN += "B"
  # MHB 19/12/08 : on ne laisse le menu Cas d'emploi que si on n'a pas déjŕ
  # ouvert un cas d'emploi. Sinon, erreur "Fonction non appelable dans le contexte"
  Local Integer I, CAS_EMPLOI_OUV
  CAS_EMPLOI_OUV=G_NON
  For I=1 To GNBMASKOUV
    If instr(1,GMASKOUV(I),"BOWH")>0 Then
      CAS_EMPLOI_OUV=G_OUI
      Break
    Endif
  Next
  If CAS_EMPLOI_OUV=G_NON Then
    CHMEN += "E"
  Endif
  #consultation des documents vente : devis, commande, livraison, facture
  # SEGAY DemandesErgonomieX314102008
  #consultation des documents vente : devis, commande, livraison, facture, retour
  CHMEN += "JLNT^"
  #consultation des documents achat : commande, réception, retour, facture
  #consultation demande "d" DemandesErgonomieX314102008 01/12/08
  #MAE, bg 103541
  #CHMEN += "AV§Xd"
  CHMEN += ",V§Xd"
  #consultation des documents GPAO :  consommation, prix de revient, histo prix de revient
  CHMEN += "#{[@"
  # bug 53423 STANT 12/03/09 déclaration fab
  If [F:ITG]MFGFLG = 2  Then
    CHMEN +="~"
  Endif
  # demande 4948 : Stock par site (K)
  #consultation des stocks
  # SYMEU le 21/10/2008 ajout du stock disponible (%) et du stock ŕ date (ů)
  CHMEN += "K})%ů"
Endif

# hcb 59448  remplacement "M" en "/"  et "C" en "?"
If GREP = "" & [M:ITM0]ITMREF <> ""  & GFONC1 <> "GESBOD"   # 05.06 demande 6195
  # FGR 30/04/2009 : X3SUIVI18919 : Si modif sur "C", "M", "S" le signaler a FGR pour report dans SUBMAC
  If clalev([F:BOH2])<=0 : Local File BOM        [BOH2] : Endif
  Filter [F:BOH2] Where  ITMREF = [M:ITM0]ITMREF & BOMALTTYP = 1
  Look [F:BOH2]BOH0 First
  If !fstat Then
    If !find("GESBOD",GNAVIG(1..GPILNAV)) Then
      CHMEN += "?"                                # hcb 59448
    Endif
  Endif
  Filter [F:BOH2] Where  ITMREF = [M:ITM0]ITMREF & BOMALTTYP = 2
  Look [F:BOH2]BOH0 First
  If !fstat Then
    If !find("GESBOD",GNAVIG(1..GPILNAV)) Then
      CHMEN += "/"                                # hcb 59448
    Endif
  Endif
  Filter [F:BOH2] Where  ITMREF = [M:ITM0]ITMREF & BOMALTTYP = 3
  Look [F:BOH2]BOH0 First
  If !fstat : CHMEN += "S" : Endif
  Close Local File [BOH2]

  # STANT 05/11/08  on active le bouton Recette que si une nomenclature existe
  If instr(1,CHMEN,"?") or instr(1,CHMEN,"/") or instr(1,CHMEN,"S")Then              # hcb 59448
    If !clalev([M:VBOR]) Then
      CHMEN +="a"
    Endif
  Endif

  # s'il n'existe aucune nomenclature pour cet article on propose d'en créer une en fonction de la catégorie article.
  # STANT 23/10/08
  If !instr(1,CHMEN,"?") or !instr(1,CHMEN,"/") or !instr(1,CHMEN,"S") Then          # hcb 59448
    If [F:ITG]SALFLG = 2 Then
      If !find("GESBOD",GNAVIG(1..GPILNAV)) Then
        CHMEN+="?"                                                                   # hcb 59448
      Endif
    Endif
    If ([F:ITG]MFGFLG = 2 or [F:ITG]PHAFLG =2) and [F:ITG]SCSFLG <> 2 Then
      If !find("GESBOD",GNAVIG(1..GPILNAV)) Then
        CHMEN += "/"                                                                 # hcb 59448
      Endif
    Endif
    If [F:ITG]SCPFLG = 2 Then
      CHMEN += "S"
    Endif
  Endif
#46080 ajout du test sur le module GPAO

   If GMODU(8) = 2
#     If clalev([F:ROH2])<=0 : Local File ROUTING        [ROH2] : Endif
#       Filter [F:ROH2] Where  ITMREF = [M:ITM0]ITMREF
#       Look [F:ROH2] First
#       If !fstat : CHMEN += "R" : Endif
#       Close Local File [ROH2]
# STANT 12/03/09 On ajoute le bouton des gamme que pour les articles fabriqués.
# Bug 53206
    If !find("GESROU",GNAVIG(1..GPILNAV)) and [F:ITG]MFGFLG = 2  Then
      CHMEN+= "R"
    Endif
   Endif

   CHMEN += "U"                 # hcb 42541  creation article site

Endif

# Menu Coűts
# CHMEN +="ZY]("    # std - std act - std bud - std sim
CHMEN +="!ZY]("    # std - std act - std bud - std sim  # SYMEU le 21/10/2008 : Articles-Coűts passe de bouton "2" ŕ menu "!"
#consultation consommation sous traitance sauf pour les services
If [F:ITG]SCSFLG <> 2
    CHMEN += "0"
Endif

Return

$AVANTBOUT
Local Char     ALTALP(3) : # alternative format alpha pour appel action objet
Local Integer  NBTRO
Local Char     WGAMME,WITMREF, WFCY    : # utilisé en param de l'action objet sur fenetre

#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
#      1  : Article-Site            #
#      2  : Article-coűt            #
#      3  : Tarif vente             #
#      4  : Tarif achat             #
#-----------------------------------#
Case BOUT
    When "!", "Z", "Y", "]", "(" : # SYMEU le 21/10/2008 : Articles-Coűts passe de bouton "2" ŕ menu "!"
               # FQ 51659 GA 01/2010 ajout de l'option "c" pour habilitation fonctionnelle sur Article-Cout
               GBIDC2="c" : Raz GFCY : Gosub AUTORIS_OPT From CONTX3
               If !GBIDI2
                 GERR=1 : GMESSAGE=mess(7,104,1) : Return
               Endif
               GFLTITM = [M:ITM0]ITMREF
    When "1"
               #MAE, deb bug 78225
              Local Char     WCLE1(15)
              Local Integer  NBITF, WOK
              GFLTITM = [M:ITM0]ITMREF
              Filter [ITF] Where [F:ITF]ITMREF=[M:ITM0]ITMREF
              For [ITF]ITF0
                  WOK = 1
                 If WOK
                   NBITF += 1
                  Endif
              Next
              #
              Filter [ITF]
              If NBITF = 1
                If !fstat
                   WCLE1 = [F:ITF]STOFCY
                Endif #MAE, bg 73823: clé primaire de BOH
              #--- Bug 80949
              Elsif GFCYDEF(9)<>""
                Read [ITF]ITF0=[M:ITM0]ITMREF;GFCYDEF(9)
                If !fstat
                  WCLE1 = [F:ITF]STOFCY
                Endif
              #---
              Else Raz WCLE1 : Endif
              #MAE, fin bug 78225 + modif fen OITM
              #MAE, bug 108956
              GCONSULT_SAV = GCONSULT
              If GCONSULT=2 GCONSULT=1 Endif
    When "3","4" :
               GBIDC2="T" : Raz GFCY : Gosub AUTORIS_OPT From CONTX3
               If !GBIDI2
                 GERR=1 : GMESSAGE=mess(7,104,1) : Return
               Endif
               GFLTITM = [M:ITM0]ITMREF
               GVISUTAR = 2
    When "?" :#Local Char     WCLE1(GLONITM)                 # hcb 59448
              Local Char     WCLE1(15)  #MAE, bg 73823, clé prim de BOH : BOMALT
              Local Char     WCLE2(30)  #clé sec de BOH : ITMREF~BOMALTTYP
              #Local Integer  NBTBO, WOK, NBBOH
              # FGR 30/04/2009 : X3SUIVI18919 : Si modif sur "C", "M", "S" le signaler a FGR pour report dans SUBMAC
              #WCLE1=[M:ITM0]ITMREF : #MAE, bg 73823
              WCLE2=[M:ITM0]ITMREF : WCLE2 +="~1" #Clé secondaire de BOH

              #   sélectionner les alt. de nomenclature compatibles
              # si décliné par société, il faudra filtrer aussi sur le site
              #For [TBO]TBO0 Where BOMALTTYP=1
              #    GBOMALT(NBTBO) = [F:TBO]BOMALT
              #    NBTBO += 1
              #Next
              #
              #  FILTRE sur article parent
              # FQ50304 - MABON 16/11/09 - "Close Local File" plutôt que "Close File" pour éviter
              # les fermetures de tables quand on repart d'un tunnel
              # If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
              If clalev([F:BOH]) > 0 : Close Local File [BOH] : Endif
              #MAE, bg 103322
              #Local File BOM [BOH]
              #Filter [F:BOH] Where find(BOMALT,GBOMALT) & ITMREF=[M:ITM0]ITMREF & BOMALTTYP = 1
              # GH 10/09/2015 bug 101834
              Local File BOM [BOH] Where ITMREF=[M:ITM0]ITMREF & BOMALTTYP=1
              #MAE, bg 73823
              #Read [F:BOH]BOH0 First
              #If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif
              For [BOH]BOH0
                #NBBOH += 1 : # GH 10/09/2015 bug 101834 optimisation
                If WCLE1<>"" : WCLE1="" : Break : Endif
                WCLE1 = num$([F:BOH]BOMALT)
              Next
              #If NBBOH = 1
              #  If !fstat : WCLE1 = num$([F:BOH]BOMALT) : Endif #MAE, bg 73823: clé primaire de BOH
              #Else Raz WCLE1 : Endif
              GFONCTION = "GESBODC"
              GFONBOD="BOMC"
              GDATEREF=date$

    When "/" : #Local Char     WCLE1(GLONITM)                     # hcb 59448
              Local Char     WCLE1(15)  #MAE, bg 73823, clé prim de BOH : BOMALT
              Local Char     WCLE2(30)  #clé sec de BOH : ITMREF~BOMALTTYP              Local Integer  NBTBO, WOK
              Local Integer  NBTBO : #, WOK, NBBOH
              # FGR 30/04/2009 : X3SUIVI18919 : Si modif sur "C", "M", "S" le signaler a FGR pour report dans SUBMAC
              #WCLE1=[M:ITM0]ITMREF : #MAE, bg 73823
              WCLE2=[M:ITM0]ITMREF : WCLE2 +="~2" #Clé secondaire de BOH

              #   sélectionner les alt. de nomenclature compatibles
              # si décliné par société, il faudra filtrer aussi sur le site
              For [TBO]TBO0 Where MFGUSE=2 & BOMALTTYP=2
                  GBOMALT(NBTBO) = [F:TBO]BOMALT
                  NBTBO += 1
              Next
              #
              # FQ50304 - MABON 16/11/09 - "Close Local File" plutôt que "Close File" pour éviter
              # les fermetures de tables quand on repart d'un tunnel
              # If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
              If clalev([F:BOH]) > 0 : Close Local File [BOH] : Endif
              #  FILTRE sur article parent
              #MAE, bg 103322
              #Local File BOM [BOH]
              #Filter [F:BOH] Where find(BOMALT,GBOMALT) & ITMREF=[M:ITM0]ITMREF & BOMALTTYP = 2
              # GH 10/09/2015 bug 101834
              Local File BOM [BOH] Where find(BOMALT,GBOMALT(0..NBTBO-1))<>0 & ITMREF=[M:ITM0]ITMREF & BOMALTTYP=2
              #MAE, bg 73823
              #Read [F:BOH]BOH0 First
              #If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif
              For [BOH]BOH0
                #NBBOH += 1 : # GH 10/09/2015 bug 101834 optimisation
                If WCLE1<>"" : WCLE1="" : Break : Endif
                WCLE1 = num$([F:BOH]BOMALT)
              Next
              #If NBBOH = 1
              #  If !fstat : WCLE1 = num$([F:BOH]BOMALT) : Endif #MAE, bg 73823: clé primaire de BOH
              #Else Raz WCLE1 : Endif
              GFONCTION = "GESBODP"
              GFONBOD="BOMP"
              GDATEREF=date$

    When "S" :#Local Char     WCLE1(GLONITM)
              Local Char     WCLE1(15)  #MAE, bg 73823, clé prim de BOH : BOMALT
              Local Char     WCLE2(30)  #clé sec de BOH : ITMREF~BOMALTTYP
              #Local Integer  NBTBO, WOK, NBBOH
              # FGR 30/04/2009 : X3SUIVI18919 : Si modif sur "C", "M", "S" le signaler a FGR pour report dans SUBMAC
              #WCLE1=[M:ITM0]ITMREF : #MAE, bg 73823
              WCLE2=[M:ITM0]ITMREF : WCLE2 +="~3" #Clé secondaire de BOH

              #   sélectionner les alt. de nomenclature compatibles
              # si décliné par société, il faudra filtrer aussi sur le site ---> A FAIRE
              #For [TBO]TBO0 Where BOMALTTYP=3
              #    GBOMALT(NBTBO) = [F:TBO]BOMALT
              #    NBTBO += 1
              #Next
              #
              # FQ50304 - MABON 16/11/09 - "Close Local File" plutôt que "Close File" pour éviter
              # les fermetures de tables quand on repart d'un tunnel
              # If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
              If clalev([F:BOH]) > 0 : Close Local File [BOH] : Endif
              #  FILTRE sur article parent
              #MAE, bg 103322
              #Local File BOM [BOH]
              #Filter [F:BOH] Where find(BOMALT,GBOMALT) & ITMREF=[M:ITM0]ITMREF & BOMALTTYP = 3
              # GH 10/09/2015 bug 101834
              Local File BOM [BOH] Where ITMREF=[M:ITM0]ITMREF & BOMALTTYP=3
              #MAE, bg 73823
              #Read [F:BOH]BOH0 First
              #If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif
              For [BOH]BOH0
                #NBBOH += 1 : # GH 10/09/2015 bug 101834 optimisation
                If WCLE1<>"" : WCLE1="" : Break : Endif
                WCLE1 = num$([F:BOH]BOMALT)
              Next
              #If NBBOH = 1
              #  If !fstat : WCLE1 = num$([F:BOH]BOMALT) : Endif #MAE, bg 73823: clé primaire de BOH
              #Else Raz WCLE1 : Endif
              GFONCTION = "GESBODS"
              GFONBOD="BOMS"
              GDATEREF=date$
     When "R":
             # GH 23/11/12 bug 85678
              #WGAMME = [M:ITM0]ITMREF
              #If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
              #Filter [ITF] Where ITMREF = [M:ITM0]ITMREF
              #Read [ITF] First
              #If fstat : Raz [ITF] : Endif
              #Filter [ITF]
              #If [F:ITF]MFGROU <> ""
              #    WGAMME  = [F:ITF]MFGROU+"~"+[F:ITF]STOFCY
              #    WITMREF = [F:ITF]MFGROU
              #    WFCY    = [F:ITF]STOFCY
              #    ALTALP  = num$([F:ITF]MFGROUALT)
              #Endif
              ## FQ50304 - MABON 16/11/09 - "Close Local File" plutôt que "Close File" pour éviter
              ## les fermetures de tables quand on repart d'un tunnel
#             # If clalev([F:ROH]) > 0 : Close File [ROH] : Endif
              #If clalev([F:ROH]) > 0 : Close Local File [ROH] : Endif
              ## table réouverte systématiquement pour filtre !
              #If ALTALP <> ""
              #  Local File ROUTING [ROH] Where ROUALT = val(ALTALP) & ITMREF=WITMREF & FCY =WFCY
              #Else
              #  Local File ROUTING [ROH] Where ITMREF=WGAMME
              #Endif

              If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
              If clalev([F:ROH])=0 : Local File ROUTING    [ROH] : Endif

              Raz ALTALP, WFCY, I : WITMREF = [M:ITM0]ITMREF
              For [ITF] Where ITMREF = [M:ITM0]ITMREF
                  If [F:ITF]MFGROU=""
                     Look [ROH]ROH1(2) = [F:ITF]STOFCY;[F:ITF]ITMREF
                     If fstat<=2 : WGAMME=[F:ITF]ITMREF : Else WGAMME="" : Endif
                  Else
                     WGAMME = [F:ITF]MFGROU
                  Endif
                  If WGAMME<>""
                      If !I
                         WITMREF = WGAMME
                         If [F:ITF]MFGROU<> ""
                            ALTALP  = num$([F:ITF]MFGROUALT)
                         Endif
                         WFCY=[F:ITF]STOFCY
                      Else
                         If !find(WITMREF,"",WGAMME): WITMREF="" : Endif
                         If [F:ITF]MFGROU<>"" & ALTALP<>"" & [F:ITF]MFGROUALT<>val(ALTALP) : ALTALP="" : Endif
                         WFCY=""
                      Endif
                      I+=1
                  Endif
              Next

              Close Local File [ROH]
              If WITMREF=""
                 Local File ROUTING [ROH]
              Elsif ALTALP <> "" & WFCY<>""
                 Local File ROUTING [ROH] Where ROUALT = val(ALTALP) & ITMREF=WITMREF & FCY=WFCY
              Elsif ALTALP <> ""
                 Local File ROUTING [ROH] Where ROUALT = val(ALTALP) & ITMREF=WITMREF
              Else
                 Local File ROUTING [ROH] Where ITMREF=WITMREF
              Endif
     When "D" :
             Local Char WALT
             Local Integer  NBTBO,WOK
             Filter [TBO] Where [F:TBO]BOMALTTYP=3
             For [TBO]TBO0
               WOK = 1
               If WOK  GBOMALT (NBTBO) = [F:TBO]BOMALT
                 NBTBO += 1
               Endif
             Next
             Filter [TBO]
             # FQ50304 - MABON 16/11/09 - "Close Local File" plutôt que "Close File" pour éviter
             # les fermetures de tables quand on repart d'un tunnel
             # If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
             If clalev([F:BOH]) > 0 : Close Local File [BOH] : Endif
             #  FILTRE sur article parent
             #MAE, bg 103322
             Local File BOM [F:BOH]
             Filter [F:BOH] Where find(BOMALT, GBOMALT) & ITMREF=[M:ITM0]ITMREF # & BOMALTTYP = 3
             Read [F:BOH]BOH0 First
             If !fstat : WALT = num$([F:BOH]BOMALT) : Endif
              #
              #GFONCTION = "GESBODS"
              GDATEREF=date$
     # GH 21/01/2014 bug 95091
     #When "a" : # recette
     #       GFONCTION = "VISUBOMROU"
     When "0" :
            If [F:ITG]SCPFLG = 2
                WITMREFSSTRT = [M]ITMREF
                WITMCPNI = ""
            Else
                WITMREFSSTRT = ""
                WITMCPNI = [M]ITMREF
            Endif
  Endcase
Return

$EXEBOUT
#------------------------------------#
# Aprčs exécution des boutons du bas #
# ---------------------------------- #
#      1  : Article-Site             #
#      2  : Article-coűt             #
#      3  : Tarif vente              #
#      4  : Tarif achat              #
#------------------------------------#
Case REP
 When "1"
    GFLTITM = ""
    #MAE, bug 108956
    GCONSULT = GCONSULT_SAV
 When "3", "4"
    GFLTITM = ""
    GVISUTAR = 0
 When "C","M","S" : Filter [F:BOH]
Endcase
Return

$TEXTE
#-------------------------------------------#
# Aprčs exécution des boutons de la ToolBar #
#-------------------------------------------#
Local Char    SGBOITE
SGBOITE=GBOITE
GBOITE =""
GFONCTION = "GESITM"
If [M:ITM0]ITMREF = "" : Return : Endif

WRETOUR = 0
Case BOUT
  When "!", "Z", "Y", "]", "(" # SYMEU le 21/10/2008 : Articles-Coűts passe de bouton "2" ŕ menu "!"
             #   Tunnel vers article-cout ; chargement de la clé complčte
             #   ATTENTION aux var globales pour le prochain filtre !
             If GFONC1 = "GESITM" | find(GFONC1,"STD","CUT","BUD","SIM")
                GFLTITM = ""
             Endif
             Default File [ITM] : # pour rétablir la classe [F] par defaut
  When "F" : If mkstat=4 & GREP=""
                #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If [M:ITM4]PURTEX <> ""
                   [M:ITM4]WPURTEX = 2
             Else
                   [M:ITM4]WPURTEX = 1
             Endif
             Affzo [M:ITM4]WPURTEX
  When "G" : If mkstat=4 & GREP=""
                #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If dim([M:ITM1]MFGTEX)>0
                If [M:ITM1]MFGTEX <> ""
                   [M:ITM1]WMFGTEX = 2
                Else
                   [M:ITM1]WMFGTEX = 1
                Endif
                Affzo [M:ITM1]WMFGTEX
             Endif
  When "H" : If mkstat=4 & GREP=""
                #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If [M:ITS]ITSTEX <> ""
                   [M:ITS]WITSTEX = 2
             Else
                   [M:ITS]WITSTEX = 1
             Endif
             Affzo [M:ITS]WITSTEX
  When "I" : If mkstat=4 & GREP=""
                #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If [M:ITM1]ITPTEX  <> ""
                   [M:ITM1]WITPTEX = 2
             Else
                   [M:ITM1]WITPTEX = 1
             Endif
             Affzo [M:ITM1]WITPTEX

#MAE, bg 69810, si on vient des nomenclatures, on restaure les droits pour GESITM
    When "?", "/", "S"
        Call AUTORIS From EXEFNC
        #MAE, bg 74202, on ferme BOH pour enlever le filtre qu'il y a dessus
        If clalev([F:BOH]) > 0 : Close Local File [BOH] : Endif
    When "R"
        If clalev([F:ROH]) > 0 : Close Local File [ROH] : Endif


Endcase
GBOITE=SGBOITE
Return

$AVANT_MOD
# Issue 87375 - 2013-02-04 by MAE : Sauvegarde des désignations traduisibles
[M:ITM0]SAVDES1AXX = [M:ITM0]DES1AXX
[M:ITM1]SAVDES2AXX = [M:ITM1]DES2AXX
[M:ITM1]SAVDES3AXX = [M:ITM1]DES3AXX
# Issue 90991 - 2013-11-08 by MAE : En création, griso du bouton
# Issue 116245 - 2016-05-02 by MAE
If dim([M:ITP]STCNUMITF)>0
  Grizo [M:ITP]STCNUMITF
Endif
Return


$VERIF_CRE
# hcb 32499 deb
If [M:ITM0]TCLCOD = ""
   GMESSAGE = mess(338,199,1)
   OK = 0
   Return
Endif
# hcb 32499 fin
#                                                       # hcb 71276 deb
If ACTION = "VERIF_CRE"
   Local Integer WCREVERSION
   Raz WCREVERSION
   # Issue 118661 - 2016-09-28 by MAE : pas de créaqtion de version si l'article n'est pas acheté
   #If dim([M:ITM2]ECCSTO) > 0 & [M:ITM2]ECCSTO >  1 & [M:ITM2]ECCMAJ <> ""
   If dim([M:ITM2]ECCSTO) > 0 & [M:ITM2]ECCSTO >  1 & [M:ITM2]ECCMAJ <> "" & [F:ITG]PURFLG = 2
      Case [M:ITM2]ECCSTO
           When 2
             Call OUINON(mess(638,199,1),WCREVERSION) From GESECRAN
           When 3
             Call OUINON(mess(639,199,1),WCREVERSION) From GESECRAN
           When Default
       Endcase
   Endif
Endif
#                                                      # hcb 71276 fin




#---------------------------#
# Vérifications en création #
#---------------------------#
# vérification des tableaux Article-fournisseurs et article-client ŕ cause d'un
# eventuel clic sur le tableau alors que les zones obligatoires sont encore vides !!
# Le controle global ne fait pas les ctrl en arričre (tableau = bloc1 !)
# Attention cette  étiquette est appelée aussi en VERIF_MOD !
Local Integer WRET  # Issue 90991 - 2013-10-29 by MAE : déplacement

If dim([M:ITP]NBITP) > 0
  For nolign = 1 To [M:ITP]NBITP
    If [M:ITP]IPCUPUUCOE(nolign-1) = 0 & [M:ITP]ITPPCU(nolign-1) <> ""
&     | [M:ITP]ITPPUU(nolign-1) = "" | [M:ITP]IPUUSTUCOE(nolign-1) = 0
      # "Valeur obligatoire Article-fournisseur xxxxx "
        GMESSAGE = mess(10,123,1) - mess(23,198,1) - [M:ITP]BPSNUM(nolign-1)
        OK = 0 : Break
    Endif
    # Controle clé secondaire SANS homonyme  (Suggestion 3661 : 08/12/99)
    # ŕ moins qu'on ait enlevé 'Sans homonymes' : bug 16248     17/02/03
    If [G:ITP]keyuniq(2) = 1
      Read [ITP]ITP2 = [M:ITP]BPSNUM(nolign-1);[M:ITP]ITMREFBPS(nolign-1)
      If !fstat & (ACTION = "VERIF_CRE" | [F:ITP]ITMREF <> [M:ITM0]ITMREF)
      # "La combinaison Fournisseur - Référence existe déjŕ"
        #MAE, dde 57638
        If [M:ITP]ITMREFBPS(nolign-1) <> ""
         GMESSAGE = mess(267,199,1)-":"- [M:ITP]BPSNUM(nolign-1)- [M:ITP]ITMREFBPS(nolign-1)
        Else
         GMESSAGE = mess(267,199,1)-":"- [M:ITP]BPSNUM(nolign-1)-" "- mess(23,147,1)-"\"-mess(958,196,1)
        Endif
         OK = 0 : Break
      Endif
    Endif
  Next
  If OK = 0 Return Endif
Endif

If dim([M:ITU]NBITU) > 0
  For nolign = 1 To [M:ITU]NBITU
    If [M:ITU]PCUSAUCOE1(nolign-1) = 0 & [M:ITU]PCU1(nolign-1) <> ""
&     | ([M:ITU]PCUSAUCOE2(nolign-1) = 0 & [M:ITU]PCU2(nolign-1) <> "")
        GMESSAGE = mess(10,123,1) - mess(87,198,1) - [M:ITU]BPCNUM(nolign-1)
        OK = 0 : Break
    Endif
    # Controle clé secondaire SANS homonyme  (Suggestion 3661 : 08/12/99)
    # ŕ moins qu'on ait enlevé 'Sans homonymes' : bug 16248     17/02/03
    If [G:ITU]keyuniq(1) = 1
      Read [ITU]ITU1 = [M:ITU]BPCNUM(nolign-1);[M:ITU]ITMREFBPC(nolign-1)
      If !fstat & (ACTION = "VERIF_CRE" | [F:ITU]ITMREF <> [M:ITM0]ITMREF)
      # "La combinaison Client - Référence existe déjŕ"
         GMESSAGE = mess(268,199,1)-":"- [M:ITU]BPCNUM(nolign-1)- [M:ITU]ITMREFBPC(nolign-1)
         OK = 0 : Break
      Endif
    Endif
  Next
Endif

#Modif CRM 4 Juin 2003
If !GIMPORT
  If GMODU(12) = 2
     If GIHDKACTCTL
        Gosub CHECKITAV From SUBITAV
     Endif
  Endif
Endif

#MAE, le 03/02/09, bg 42932, code déplacé en am_stomgtcod
#If GREP = "M"
#   If [M:ITM2]STOMGTCOD <>  [F:ITM]STOMGTCOD
#      Call MESSAGE(mess(261,184,1)) From GESECRAN
#   Endif
#Endif
If [M:ITM1]SALFLG = 2  | [M:ITM1]DLVFLG = 2
    #  unite de vente = "" alors unite de vente = unite de stock
    If [M:ITM3]SAU        = ""
       [M:ITM3]SAU        = [M:ITM3]STU
    Endif
    If [M:ITM3]SAUSTUCOE  = 0
       [M:ITM3]SAUSTUCOE  = 1
    Endif
Endif
If dim([M:ITM2]DLU) > 0
   If [M:ITM2]DLU = 0
      [M:ITM2]DLU = 1
   Endif
Endif

Local Integer WRET
#MAE, le 10/09/10, bg 55319, si article géré en titre, gestion de lot obligatoire
If [M:ITM2]STOMGTCOD=3 & [M:ITM2]LOTMGTCOD=1
   Call OUINON(mess(489,199,1)+"\"+mess(205,100,1),WRET) From GESECRAN
   If WRET=1 : OK = 0 : Endif
Endif

# Issue 112878 - 2015-12-11 by MAE : message qui remplace l'avant saisie
If ([F:ITG]SCSFLG = 2 | [F:ITG]SCPFLG = 2 | [M:ITM2]STOMGTCOD > 1 )  & [M:ITM4]RCPFLG <> 2
  # Issue 128500 - 2019-06-05 by CLPON : Remplacement du texte incohérent (catégories)
  # par un autre plus adapté (articles).
  Call OUINON(mess(708,199,1),WRET) From GESECRAN
  # End issue 128500
  If WRET=1 : OK = 0 : Endif
Endif

#MAE, bg 79041 sauvegarde de la classe F:ITM
[F:ITMS]=[F:ITM]
Return

$APRES_MODIF
#------------------------------------#
# Aprčs modification de chaque champ #
#------------------------------------#
# Pour positionner ŕ la zone suivante en WEB aprčs saisie du code client/fourn
Case COUZON
 When "BPCNUM"  : SUIZON = "XITMREFBPC"
 When "BPSNUM"  : SUIZON = "XITMREFBPS"
 #MAE, bg 71988
 # Issue 10401 - 2013-05-17 by MUARN : pirx de base achat ajout "PURPRIPRC"
 When "THEPRI", "MINPRI","BASPRI","PURPRIPRC" : [M:ITS]WMODPRI = 1
Endcase
Return

$ANNULE
#------------------------------------#
# Supression des textes article      #
#------------------------------------#
Local Integer WRET

If [M:ITM4]PURTEX<>""
   Call SUP_CLOB([M:ITM4]PURTEX,WRET) From TRTX3TEX
Endif
If dim([M:ITM1]MFGTEX)>0 & [M:ITM1]MFGTEX<>""
   Call SUP_CLOB([M:ITM1]MFGTEX,WRET) From TRTX3TEX
Endif
If [M:ITS]ITSTEX<>""
   Call SUP_CLOB([M:ITS]ITSTEX,WRET) From TRTX3TEX
Endif
If [M:ITS]ITPTEX<>""
   Call SUP_CLOB([M:ITS]ITPTEX,WRET) From TRTX3TEX
Endif
# suppression des textes traduisibles (v 140)
Delete [AXX] Where CODFIC="ITMMASTER" & IDENT1=[M:ITM0]ITMREF
Delete [CBB] Where CODBLB="ITM" & IDENT1=[M:ITM0]ITMREF

Return

$TR_CRE

Local Integer WRETOUR
# Mise ŕ jour table ITMSALES (pour les articles vendus ou livrable)
# Attention [F:ITM]ITMREF est chargé par
#         - [M:ITM0]ITMREF dans le cas normal
#         - le numero généré (en INICRE) dans le cas de compteur
If [M:ITM1]SALFLG = 2 | [M:ITM1]DLVFLG = 2                             # hcb 28874
  [F:ITS]       = [F:ITM]
  [F:ITS]       = [M:ITS]
  [F:ITS]ITPTEX = [M:ITM1]ITPTEX

  # FGR 21/04/2015 : X3SUIVI105605 (début)
  If func AFNC.ACTIV("ECC") Then
    If [M:ITS]LOAECCFLG <> [V]CST_ANO and [M:ITS]LOAECCFLG <> [V]CST_AYES Then
      [F:ITS]LOAECCFLG = [V]CST_ANO
    Endif
  Else
    [F:ITS]LOAECCFLG = [V]CST_ANO
  Endif
  # FGR 21/04/2015 : X3SUIVI105605 (fin)

  # Réalimentation des mnts saisis en dev soc dans [M] pour stockage en dev dossier dans [F]
  WMNTORG(0) = [M:ITS]MINPRI
  WMNTORG(1) = [M:ITS]THEPRI
  WMNTORG(2) = [M:ITS]BASPRI
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITS]MINPRI = WMNTDES(0) : Endif
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITS]THEPRI = WMNTDES(1) : Endif
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(2),WMNTDES(2),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITS]BASPRI = WMNTDES(2) : Endif
  Write [ITS]
  If fstat
    GOK = 0 : Call FSTA("ITS") From GLOCK : Goto FINCREMOD
  Endif
Endif
Raz GPE                         # hcb 84818
GPOINT = "CREITF"               # hcb 84818
Gosub  ENTREE From EXEFNC       # hcb 84818
If GPE =  0                     # hcb 84818
# hcb deb 42541
# creation article site si un seul site de type stock dans FACILITY
   Local Char LFCY(GLONFCY)
   Raz LFCY
   Filter [FCY] Where WRHFLG=2
&            Order By Key FCY0
   For [FCY]
       If  LFCY = ""
           LFCY = [F:FCY]FCY
       Else
           Raz LFCY
           Break
       Endif
   Next
   Filter [FCY]
   If LFCY <> ""
      # chargement des droits pour la fonction GESITF
      Local Char OFONCTION(20)
      OFONCTION=GFONCTION
      GFONCTION="GESITF" : Call AUTORIS From EXEFNC
      Call CONTFCY([F:FCY]FCY) From CPTSUB # controle habilitation
      If !mkstat
         Gosub CRE_ITMFACILIT
      Endif
      # chargement des droits initiaux
      GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
   Endif
If GOK = 0 Goto FINCREMOD Endif
Endif                           # hcb 84818

# hcb fin 42541
#                                          # hcb 71276 deb
If dim(WCREVERSION)> 0 & WCREVERSION = 2 & !GIMPORT      # hcb 115086
   Gosub CRE_VERSION
Endif
#                                          # hcb 71276 fin

# Mise ŕ jour table ITMBPS et ITMBPC
Goto SUBCREMOD



$TR_MOD
  Local Integer WRET, WRETOUR, LEXI
  Local Char CLE_TO_DEL(GLONITM)
  CLE_TO_DEL = [M:ITM0]ITMREF    # ligne déplacée ici
  If [M:ITM1]SALFLG = 2  |  [M:ITM1]DLVFLG = 2    # hcb 28874
      Readlock [ITS]ITS0 = [M:ITM0]ITMREF
      Case fstat
          When 0 : LEXI = 1
          When 1 : GOK=0 : Call FSTA("ITS") From GLOCK : Goto FINCREMOD
          When Default : LEXI = 0
      Endcase
      # Mise ŕ jour table ITMSALES
      [F:ITS]       = [F:ITM] : # au lieu de charger zone ŕ zone (17/06/99)
      #MAE, bg 71988, on récupére ce qu'il y a dans la classe F dans les montants, puis on les remet dans la classe F
      #pares le transclasse si il y une modif avec un utilisateur dont la devise de ref est différente
      WMNTORG(0) = [F:ITS]MINPRI
      WMNTORG(1) = [F:ITS]THEPRI
      WMNTORG(2) = [F:ITS]BASPRI
      [F:ITS]       = [M:ITS]
      [F:ITS]MINPRI = WMNTORG(0)
      [F:ITS]THEPRI = WMNTORG(1)
      [F:ITS]BASPRI = WMNTORG(2)
      [F:ITS]ITPTEX = [M:ITM1]ITPTEX

        # --------------------------------------
        # FGR 21/04/2015 : X3SUIVI105605 (début)
        If func AFNC.ACTIV("ECC") Then
          If [M:ITS]LOAECCFLG <> [V]CST_ANO and [M:ITS]LOAECCFLG <> [V]CST_AYES Then
            [F:ITS]LOAECCFLG = [V]CST_ANO
          Endif
        Else
          [F:ITS]LOAECCFLG = [V]CST_ANO
        Endif
        # FGR 21/04/2015 : X3SUIVI105605 (fin)
        # --------------------------------------

        #MAE, bg 71988, mise ŕ jour de ITMSALES uniquement si l'un des montants a été modifié
        If [M:ITS]WMODPRI = 1
          # Réalimentation des mnts saisis en dev soc dans [M] pour stockage en dev dossier dans [F]
          WMNTORG(0) = [M:ITS]MINPRI
          WMNTORG(1) = [M:ITS]THEPRI
          WMNTORG(2) = [M:ITS]BASPRI
          Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
          If !SPSTAT  [F:ITS]MINPRI = WMNTDES(0) : Endif
          Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
          If !SPSTAT  [F:ITS]THEPRI = WMNTDES(1) : Endif
          Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(2),WMNTDES(2),SPSTAT) From TRTDEV
          If !SPSTAT  [F:ITS]BASPRI = WMNTDES(2) : Endif
         Endif #fin MAE
      # Création au cas oů l'enregistrement n'existe pas encore
      # et seulement si c'est un article vendu
      If !LEXI
        Write [ITS]
        If fstat
          GOK = 0 : Call FSTA("ITS") From GLOCK : Goto FINCREMOD
        Endif
      Else
        Rewrite [ITS]
        If fstat : GOK = -1 : Endif
      Endif
      Unlock[ITS]
  Endif
  # Mise ŕ jour table ITMBPS
  If dim([M:ITP]NBITP) > 0
       For [ITP]ITP0 Where ITMREF = [M:ITM0]ITMREF
         # Suppression des textes des articles fournisseur supprimés
         If !find([F:ITP]BPSNUM,[M:ITP]BPSNUM(0..[M:ITP]NBITP-1))
            If [F:ITP]TEX <> ""
               Call SUP_CLOB([F:ITP]TEX,WRET) From TRTX3TEX
            Endif
         Endif
         Delete [ITP]
      #  Vérifier si un enregistrement est locké : si oui : Fin
         If fstat = 1
            GOK = -1
            Call RSTA("ITP",CLE_TO_DEL) From GLOCK : Break
         Endif
       Next
  Endif
  If GOK < 0 Goto FINCREMOD Endif

  # Mise ŕ jour table ITMBPC
  If dim([M:ITU]NBITU) > 0
      For [ITU]ITU0 Where ITMREF = [M:ITM0]ITMREF
         # Suppression des textes des articles clients supprimés
         If !find([F:ITU]BPCNUM,[M:ITU]BPCNUM(0..[M:ITU]NBITU-1))
            If [F:ITU]ITSTEX <> ""
               Call SUP_CLOB([F:ITU]ITSTEX,WRET) From TRTX3TEX
            Endif
            If [F:ITU]ITPTEX <> ""
               Call SUP_CLOB([F:ITU]ITPTEX,WRET) From TRTX3TEX
            Endif
         Endif
         Delete [ITU]
      #  Vérifier si un enregistrement est locké : si oui : Fin
         If fstat = 1
            GOK = -1
            Call RSTA("ITU",CLE_TO_DEL) From GLOCK : Break
         Endif
      Next
  Endif
  If GOK < 0 Goto FINCREMOD Endif

  $SUBCREMOD
  If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
      Read [ITG]ITG1=[M:ITM0]TCLCOD;""
  Endif
  # "Recréation" des art-fourn
  If ([F:ITG]PURFLG = 2 | [F:ITG]SCPFLG = 2 | [F:ITG]SCSFLG = 2 | [F:ITG]GENFLG = 2 | [F:ITG]TOOFLG = 2 ) &
&   dim([M:ITP]NBITP) > 0

   For  nolign = 1 To [M:ITP]NBITP
     [F:ITP] = [M:ITP]
     [F:ITP]ITMREF    = [F:ITM]ITMREF
     # Chargement des zones ayant des codes identiques ŕ celles d'ITM
     [F:ITP]PCU       = [M:ITP]ITPPCU(nolign-1)
     [F:ITP]PUU       = [M:ITP]ITPPUU(nolign-1)
     [F:ITP]PCUPUUCOE = [M:ITP]IPCUPUUCOE(nolign-1)
     [F:ITP]PUUSTUCOE = [M:ITP]IPUUSTUCOE(nolign-1)
     [F:ITP]QUAFLG    = [M:ITP]ITPQUAFLG(nolign-1)
     [F:ITP]QLYCRD    = [M:ITP]ITPQLYCRD(nolign-1)   # hcb V6CQ
     [F:ITP]QUAFRY    = [M:ITP]ITPQUAFRY(nolign-1)   # hcb V6CQ
     [F:ITP]QUANUM    = [M:ITP]ITPQUANUM(nolign-1)   # hcb V6CQ
  #                                                  # hcb 71276 deb
     If dim([M:ITP]LOAECCFLG)>0
        If [M:ITM2]ECCFLG < 2
           [F:ITP]LOAECCFLG = 1
        Else
           [F:ITP]LOAECCFLG = [M:ITP]LOAECCFLG(nolign-1)
        Endif
     Endif
  #                                                  # hcb 71276 fin
     # Issue 70985 - 2012-03-09 by SR
     WMNTORG(1) = [M:ITP]CPRAMT(nolign-1)
     Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
     If !SPSTAT  [F:ITP]CPRAMT = WMNTDES(1) : Endif
     If [F:ITP]CPRCOE = 0 [F:ITP]CPRCOE = 1 : Endif
     #--- Bug 55665
     #[F:ITP]MATTOL    = [M:ITP]ITPMATTOL(nolign-1)   # Three Way Matching
     If dim([M:ITP]ITPMATTOL)>0 [F:ITP]MATTOL=[M:ITP]ITPMATTOL(nolign-1) Endif   # Three Way Matching
     #---
     If [F:ITP]CREUSR  = ""                          #hcb 030505 29658
        [F:ITP]CREUSR    = GUSER
        [F:ITP]CREDAT    = date$
        Raz [F:ITP]UPDUSR                            #hcb 030505 29658
        Raz [F:ITP]UPDDAT                            #hcb 030505 29658
     Endif
     # FGR 03/02/2011 : X3SUIVI70453 (début)
     If [M:ITP]FLMOD(nolign-1) = 1 Then
       #Raz [F:ITP]UPDSTP
       Raz [F:ITP]UPDUSR
     Endif
     # FGR 03/02/2011 : X3SUIVI70453 (fin)
     Look [ITP]ITP0=[F:ITP]ITMREF;[F:ITP]BPSNUM
     If fstat
         Write [ITP]
     Else
         Rewrite [ITP]
     Endif
     If fstat
      GOK = 0 : Call FSTA("ITP") From GLOCK : Break
     Endif

     # Création ou mise ŕ jour des textes des articles fournisseur
     If [M:ITP]TEX(nolign-1)<>""
        Call CRE_CLOB([M:ITP]TEX(nolign-1),GOK) From TRTX3TEX
        If GOK<1 Break Endif
     Endif
     #MAE, bg 98389
     # Contrôle cohérence structure de coűt d'article/fournisseur
     If [M:ITP]STCNUM(nolign-1) <>""
       Call CONTROL_CSTSTC([M:ITP]STCNUM(nolign-1),"ITP",WRET) From STCCTL
       If WRET : GOK=0 : Break : Endif # Issue 90991 - 2013-10-29 by MAE : message bloquant
     Endif

   Next nolign
  Endif
  # "Recréation" des art-clients
  If [F:ITG]SALFLG = 2 & dim([M:ITU]NBITU) > 0
   For  nolign = 1 To [M:ITU]NBITU
     [F:ITU] = [M:ITU]
     [F:ITU]ITMREF    = [F:ITM]ITMREF
     # Chargement des zones ayant des codes identiques ŕ celles d'ITM
     [F:ITU]SAU       = [M:ITU]ISAU(nolign-1)
     [F:ITU]SAUSTUCOE = [M:ITU]ISAUSTUCOE(nolign-1)
     # --------------------------------------
     # FGR 21/04/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       If [F:ITU]LOAECCFLG <> [V]CST_AYES and [F:ITU]LOAECCFLG <> [V]CST_ANO Then
         [F:ITU]LOAECCFLG = [V]CST_ANO
       Endif
     Else
       [F:ITU]LOAECCFLG = [V]CST_ANO
     Endif
     # FGR 21/04/2015 : X3SUIVI105605 (fin)
     # --------------------------------------

     If [F:ITU]CREUSR  = ""                          #hcb 030505 29658
        [F:ITU]CREUSR    = GUSER
        [F:ITU]CREDAT    = date$
        Raz [F:ITU]UPDUSR                            #hcb 030505 29658
        Raz [F:ITU]UPDDAT                            #hcb 030505 29658
     Endif
     # FGR 03/02/2011 : X3SUIVI70453 (début)
     If [M:ITU]FLMOD(nolign-1) = 1 Then
       #Raz [F:ITU]UPDSTP
       Raz [F:ITU]UPDUSR
     Endif
     # FGR 03/02/2011 : X3SUIVI70453 (fin)
     Write [ITU]
     If fstat
       GOK = 0 : Call FSTA("ITU") From GLOCK : Break
     Endif

     # Création ou mise ŕ jour des textes des articles client
     If [M:ITU]ITSTEX(nolign-1)<>""
        Call CRE_CLOB([M:ITU]ITSTEX(nolign-1),GOK) From TRTX3TEX
        If GOK<1 Break Endif
     Endif
     If [M:ITU]ITPTEX(nolign-1)<>""
        Call CRE_CLOB([M:ITU]ITPTEX(nolign-1),GOK) From TRTX3TEX
        If GOK<1 Break Endif
     Endif

   Next nolign
  Endif

   # Ecriture des familles comptables
  If dim([M:ITM5]NBFAM) > 0
   Local Integer N_I
   Local Char    LLEGGRP
   For N_I = 0 To [M:ITM5]NBFAM-1
     If dim([M:ITM5]LEGGRP)>0
      LLEGGRP=[M:ITM5]LEGGRP(N_I)
     Else
      LLEGGRP=""
     Endif
     Read [F:ITA]ITA0=[M]ITMREF;LLEGGRP          #[M:ITM1]LEGGRP(N_I)
     If fstat and [M:ITM5]ACGGRP(N_I) <> ""
       [F:ITA]ITMREF = [M]ITMREF
       [F:ITA]LEG    = LLEGGRP                   #[M:ITM1]LEGGRP(N_I)
       [F:ITA]ACGGRP = [M:ITM5]ACGGRP(N_I)
       Write [F:ITA]
     Elsif !fstat
       If [M:ITM5]ACGGRP(N_I) = ""
         Delete [F:ITA] Curr
         If fstat : GOK = 0 : Call FSTA("ITA") From GLOCK : Break : Endif
       Else
         [F:ITA]ACGGRP = [M:ITM5]ACGGRP(N_I)
         Rewrite [F:ITA] Curr
         If fstat : GOK = 0 : Call FSTA("ITA") From GLOCK : Break : Endif
       Endif
     Endif
   Next
  Endif
  #MAE, bg 98389, controle de la STC sur l'article
  # Contrôle cohérence structure de coűt sur article
  If [M:ITM4]ITMSTCNUM <> ""
    Call CONTROL_CSTSTC([M:ITM4]ITMSTCNUM,"ITM",WRET) From STCCTL
    #If WRET : GOK=0   : Endif  # Issue 90991 - 2013-10-29 by MAE : message bloquant
    If WRET : GOK=0   : Goto FINCREMOD Endif  #ISSUE X3-88081 - 2018-05-29 By USA
  Endif

  Call SETDEFSUPPLIER() #ISSUE X3-88081 - 2018-05-29 By USA
$FINCREMOD
  # Retour de la CREATION et de la MODIF
Return

Subprog SETDEFSUPPLIER() #ISSUE X3-88081 - 2018-05-29 By USA
    Read [DRS] = [M:ITM0]ITMREF
    If !fstat Then
      #there is record from [DRS]
        Read [F:ITP]ITP0 = [DRS]ITMREF;[DRS]BPSNUM #in [ITP] find Product with Supplier according to record from [DRS]
        Update[F:ITP] Where [F:ITP]ITMREF = [DRS]ITMREF and [F:ITP]DEFBPSFLG <> CST_ANO  With [F:ITP]DEFBPSFLG = CST_ANO #set NO for all supplires
        If !fstat Then
          Update[F:ITP] Where [F:ITP]ITMREF = [DRS]ITMREF and [F:ITP]BPSNUM = [DRS]BPSNUM With [F:ITP]DEFBPSFLG = CST_AYES #set YES for default supplier
          If fstat Then GOK = 0 : GMESSAGE = mess(695,199,1) : End : Endif
        Else
         GOK = 0
         GMESSAGE = mess(695,199,1)
         End
        Endif
    Else
      #no record from [DRS]
        Update[F:ITP] Where [F:ITP]ITMREF = [M:ITM0]ITMREF and [F:ITP]DEFBPSFLG <> CST_ANO  With [F:ITP]DEFBPSFLG = CST_ANO #set NO for all supplires
        If fstat Then GOK = 0 : GMESSAGE = mess(695,199,1) : End : Endif
    Endif

    Read [DBS] = [M:ITM0]ITMREF
    If !fstat Then
      #there is record from [DBS]
        Read [F:ITP]ITP0 = [DBS]ITMREF;[DBS]BPSNUM #in [ITP] find Product with Supplier according to record from [DBS]
        Update[F:ITP] Where [F:ITP]ITMREF = [DBS]ITMREF and [F:ITP]DEFCTMBPSFLG <> CST_ANO  With [F:ITP]DEFCTMBPSFLG = CST_ANO #set NO for all btb supplires
        If !fstat Then
          Update[F:ITP] Where [F:ITP]ITMREF = [DBS]ITMREF and [F:ITP]BPSNUM = [DBS]BPSNUM With [F:ITP]DEFCTMBPSFLG = CST_AYES #set YES for default btb supplier
          If fstat Then GOK = 0 : GMESSAGE = mess(701,199,1) : End : Endif
        Else
         GOK = 0
         GMESSAGE = mess(701,199,1)
         End
        Endif
    Else
      #no record from [DBS]
        Update[F:ITP] Where [F:ITP]ITMREF = [M:ITM0]ITMREF and [F:ITP]DEFCTMBPSFLG <> CST_ANO  With [F:ITP]DEFCTMBPSFLG = CST_ANO #set NO for all btb supplires
        If fstat Then GOK = 0 : GMESSAGE = mess(701,199,1) : End : Endif
    Endif
End

$INICRE
#---------------------------#
# Chargement avant le Write #
#---------------------------#
Local Integer STAT, WRET
Local Char    NUMERO(GLONITM)
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
#---------------------------------------------------------#
# Point d'entrée ITMNUM pour charger la référence article #
# Le résultat sera chargé dans [F:ITM]ITMREF              #
# --------------------------------------------------------#
GPOINT="ITMNUM" : Gosub ENTREE From EXEFNC
If GOK=0 : Return : Endif
If NUMERO<>"" [F:ITM]ITMREF=NUMERO : Endif

# si la référence est déterminée par un compteur
If [F:ITM]ITMREF = ""
  # FGR 17/12/2009 : X3SUIVI60196
  #--- ŕ activer en 6.20
  #Call NUMERO([F:ITG]ITMREFCOU,GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
  Call NUMCLE ([F:ITG]ITMREFCOU,GFCYDEF(9),datesyst,"","ITM",NUMERO,STAT) From SUBANM
  #---
  #MAE, le 07/10/08, bg 49305
  #NUMERO = vireblc(NUMERO, 4)  # FGR 17/12/2009 : X3SUIVI60196 : plus la peine NUMCLE vérifie tout
  If STAT = 0
    [F:ITM]ITMREF = NUMERO
  Else
    GOK = 0 : Return
  Endif
Endif

# Création des textes articles
If [M:ITM4]PURTEX<>""
   Call CRE_CLOB([M:ITM4]PURTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:ITM]PURTEX = [M:ITM4]PURTEX
Endif
If dim([M:ITM1]MFGTEX)>0 & [M:ITM1]MFGTEX<>""
   Call CRE_CLOB([M:ITM1]MFGTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:ITM]MFGTEX = [M:ITM1]MFGTEX
Endif
If [M:ITS]ITSTEX<>""
   If [F:ITG]SALFLG=2
      Call CRE_CLOB([M:ITS]ITSTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:ITS]ITSTEX = [M:ITS]ITSTEX
   Else
      Call SUP_CLOB([M:ITS]ITSTEX,WRET) From TRTX3TEX
   Endif
Endif
#MAE, bg 77269, remplacement de [M:ITS] par [M:ITM1]
If [M:ITM1]ITPTEX<>""
   If [F:ITG]SALFLG=2 | [F:ITG]DLVFLG=2
      Call CRE_CLOB([M:ITM1]ITPTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:ITS]ITPTEX = [M:ITM1]ITPTEX
   Else
      Call SUP_CLOB([M:ITM1]ITPTEX,WRET) From TRTX3TEX
   Endif
Endif


# Initialisation de zones désactivées (TB - 02/07/99)
If dim([M:ITM2]LOTMGTCOD) < 0
    [F:ITM]LOTMGTCOD = 1
Endif
If dim([M:ITM2]SERMGTCOD) < 0
    [F:ITM]SERMGTCOD = 1
Endif
If dim([M:ITM2]EXYMGTCOD) < 0
    [F:ITM]EXYMGTCOD = 1
Endif
If dim([M:ITM2]SHL) < 0
    [F:ITM]SHL = 0
Endif
#                          hcb V6PER deb
If dim([M:ITM2]EXYSTA) < 0
    Raz [F:ITM]EXYSTA
Endif
If dim([M:ITM2]SHLUOM) < 0
    [F:ITM]SHLUOM = 1
Endif
If dim([M:ITM2]SHLLTI) < 0
    [F:ITM]SHLLTI = 0
Endif
If dim([M:ITM2]SHLLTIUOM) < 0
    [F:ITM]SHLLTIUOM = 1
Endif
If dim([M:ITM2]NEWLTISTA) < 0
    Raz [F:ITM]NEWLTISTA
Endif
If dim([M:ITM2]DLU) < 0
    [F:ITM]DLU = 1
Endif
#                          hcb V6PER fin
#                                  # hcb 71276 deb
If dim([M:ITM4]LOAECCFLG)>0
   [F:ITM]LOAECCFLG =   [M:ITM4]LOAECCFLG
Else
   [F:ITM]LOAECCFLG =  1
Endif
#                                  # hcb 71276 fin

Gosub MAJ_AXX

If len([M:ITM1]IMG)<>0
    Raz [F:CBB]
    [F:CBB]CODBLB = "ITM"
    [F:CBB]IDENT1 = [F:ITM]ITMREF
    [F:CBB]TYPBLB = 3
    [F:CBB]BLOB = [M:ITM1]IMG
    Call ECRCBB From TRTX3BLB
    If fstat
        GOK=0
    Endif
Endif

# Issue 70985 - 2012-02-14 by MUARN : Coef frais approche
# Issue 70985 - 2012-03-09 by SR
If [F:ITM]PURFLG = 2
  [F:ITM]CPRCOE = [M:ITM4]ITMCPRCOE
  [F:ITM]STCNUM = [M:ITM4]ITMSTCNUM
  If [F:ITM]CPRCOE = 0 : [F:ITM]CPRCOE = 1 : Endif
  WMNTORG(0) = [M:ITM4]PURBASPRI
  WMNTORG(1) = [M:ITM4]ITMCPRAMT
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITM]PURBASPRI = WMNTDES(0) : Endif
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITM]CPRAMT = WMNTDES(1) : Endif
# Issue 108660 - 2015-06-05 by MUARN : init CPRCOE si non acheté
Else
  If [F:ITM]CPRCOE = 0 : [F:ITM]CPRCOE = 1 : Endif
Endif

Return

#-------------------------------------------#
# mise ŕ jour des textes traduisibles v 140 #
#-------------------------------------------#
$MAJ_AXX
#--- Creation / Modif de ATEXTRA
# la clé est reprise de [F] ŕ cause du cas des compteurs
# Issue 87375 - 2013-02-04 by MAE : mise ŕ jour des désignations traduisibles uniquement si elles ont été modifiées
If ([M:ITM0]SAVDES1AXX<>[M:ITM0]DES1AXX) | GREP = "C" | GREP = "D" #MAE, bg 98899 traduction aussi en duplication
  Call MAJTEXTRA ([M:ITM0]DES1AXX,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
Endif
If ([M:ITM1]SAVDES2AXX<>[M:ITM1]DES2AXX) | GREP = "C" | GREP = "D" #MAE, bg 98899 traduction aussi en duplication
  Call MAJTEXTRA ([M:ITM1]DES2AXX,"ITMMASTER","DES2AXX",[F:ITM]ITMREF,"") From ATEXTRA
Endif
If ([M:ITM1]SAVDES3AXX<>[M:ITM1]DES3AXX) | GREP = "C" | GREP = "D" #MAE, bg 98899 traduction aussi en duplication
  Call MAJTEXTRA ([M:ITM1]DES3AXX,"ITMMASTER","DES3AXX",[F:ITM]ITMREF,"") From ATEXTRA
Endif

# conservation de ITMDES1,2,3 par sécurité (quelle que soit la langue)
# et en attendant d'avoir vérifié (et pu résoudre) tous les 250 cas d'emploi...
[F:ITM]ITMDES1 = [M:ITM0]DES1AXX # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
[F:ITM]ITMDES2 = [M:ITM1]DES2AXX # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
[F:ITM]ITMDES3 = [M:ITM1]DES3AXX # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
Return

$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Création ou mise ŕ jour des textes articles
If [M:ITM4]PURTEX<>""
   Call CRE_CLOB([M:ITM4]PURTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:ITM]PURTEX = [M:ITM4]PURTEX
Endif
If dim([M:ITM1]MFGTEX)>0 & [M:ITM1]MFGTEX<>""
   Call CRE_CLOB([M:ITM1]MFGTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:ITM]MFGTEX = [M:ITM1]MFGTEX
Endif
If [M:ITS]ITSTEX<>""
   If [F:ITG]SALFLG=2
      Call CRE_CLOB([M:ITS]ITSTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:ITS]ITSTEX = [M:ITS]ITSTEX
   Else
      Call SUP_CLOB([M:ITS]ITSTEX,GOK) From TRTX3TEX
   Endif
Endif
If [M:ITM1]ITPTEX<>""
   If [F:ITG]SALFLG=2 | [F:ITG]DLVFLG=2
      Call CRE_CLOB([M:ITM1]ITPTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:ITS]ITPTEX = [M:ITM1]ITPTEX
   Else
      Call SUP_CLOB([M:ITM1]ITPTEX,WRET) From TRTX3TEX
   Endif
Endif
Gosub MAJ_AXX

[F:ITM]CREUSR = [M:ITM0]CREUSR   #hcb 31383
[F:ITM]CREDAT = [M:ITM0]CREDAT   #hcb 31383

If len([M:ITM1]IMG)<>0
    Readlock [CBB]CBB0="ITM";[F:ITM]ITMREF;""
    Case fstat
        When 0 :
            [F:CBB]BLOB = [M:ITM1]IMG
            Call REWCBB From TRTX3BLB
        When 5 :
            Raz [F:CBB]
            [F:CBB]CODBLB = "ITM"
            [F:CBB]IDENT1 = [F:ITM]ITMREF
            [F:CBB]TYPBLB = 3
            [F:CBB]BLOB = [M:ITM1]IMG
            Call ECRCBB From TRTX3BLB
    Endcase
Else
    Delete [CBB] Where CODBLB="ITM" & IDENT1=[F:ITM]ITMREF
Endif
If fstat
    GOK=0
Endif
#MAE, bg 79041, remise en place des champs de travail sauvegardé
#Si des champs de travail sont rajoutés dans les tables : les rajouter ici
#[F:ITM]CRESTP = [F:ITMS]CRESTP
#[F:ITM]IDTSGL = [F:ITMS]IDTSGL

# Issue 70985 - 2012-02-14 by MUARN : Coef frais approche
# Issue 70985 - 2012-03-09 by SR
If [F:ITM]PURFLG = 2
  [F:ITM]CPRCOE = [M:ITM4]ITMCPRCOE
  [F:ITM]STCNUM = [M:ITM4]ITMSTCNUM
  If [F:ITM]CPRCOE = 0 : [F:ITM]CPRCOE = 1 : Endif
  WMNTORG(0) = [M:ITM4]PURBASPRI
  WMNTORG(1) = [M:ITM4]ITMCPRAMT
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITM]PURBASPRI = WMNTDES(0) : Endif
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITM]CPRAMT = WMNTDES(1) : Endif
  [F:ITM]CPRAMT = [M:ITM4]ITMCPRAMT
# Issue 108660 - 2015-06-05 by MUARN : init CPRCOE si non acheté
Else
  If [F:ITM]CPRCOE = 0 : [F:ITM]CPRCOE = 1 : Endif
Endif
#                                  # hcb 71276 deb
If dim([M:ITM4]LOAECCFLG)>0
   [F:ITM]LOAECCFLG =   [M:ITM4]LOAECCFLG
Else
   [F:ITM]LOAECCFLG =  1
Endif
#                                  # hcb 71276 fin

Return

$APRES_CRE
#----------------#
# Apres écriture #
#----------------#

# "L'article a été créé avec la référence ...(/compteur) "
If [M:ITM0]ITMREF = ""
   GMESSAGE = mess(5,196,1) - [F:ITM]ITMREF
   GERR=2  # bug 10388 07/09/01  Avertissement !
Endif
[M:ITM0]ITMREF = [F:ITM]ITMREF
If !GIMPORT Affzo [M:ITM0]ITMREF Endif

#Modif CRM 4 juin 2003
If GMODU(12) = 2
 If GIHDKACTCTL
  If !GIMPORT
    If clalev([M:ITAV])
       If [M:ITAV]HDKITMTYP = 3
          Call SREC_COE([M:ITM0]ITMREF, "", [M:ITAV]HOUUOM, [M:ITAV]DAYUOM, [M:ITAV]COEHOUDAY) From TRTVENQTE
       Else
         [M:ITAV]COEHOUDAY = 0
       Endif
       Affzo [M:ITAV]COEHOUDAY
    Endif
    Local Integer IERRPIT
    IERRPIT = 0
    Call SAVEPIT([M:ITM0]ITMREF, IERRPIT) From SUBITMCRM
    If IERRPIT
        GMESSAGE = mess(IERRPIT,182,1)
        GERR = 1
        Return
    Endif
  Endif
  #Modif CRM   5/9/2003
  Gosub SETGRAY From SUBITMCRM
 Endif
Endif


If !GIMPORT
    Gosub RELIT From GOBJSUB
Endif

Return

$APRES_MOD
#Modif CRM 4 juin 2003
  If GMODU(12) = 2
   If GIHDKACTCTL
    If !GIMPORT
      If clalev([M:ITAV])
         If [M:ITAV]HDKITMTYP = 3
            Call SREC_COE([M:ITM0]ITMREF, "", [M:ITAV]HOUUOM, [M:ITAV]DAYUOM, [M:ITAV]COEHOUDAY) From TRTVENQTE
         Endif
         Affzo [M:ITAV]COEHOUDAY
      Endif
      Local Integer IERRPIT
      IERRPIT = 0
      Call SAVEPIT([M:ITM0]ITMREF, IERRPIT) From SUBITMCRM
      If IERRPIT
          GMESSAGE = mess(IERRPIT,182,1)
          GERR = 1
          Return
      Endif
    Endif
    #Modif CRM   5/9/2003
    Gosub SETGRAY From SUBITMCRM
   Endif
  Endif
  If !GIMPORT
      Gosub RELIT From GOBJSUB
  Endif

Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
#MAE, bg 71988
[M:ITS]WMODPRI = 0
Actzo [ITM0]1-99
Actzo [ITM1]1-99
Raz   [M:ITM1]
Actzo [ITM2]1-99
Raz   [M:ITM2]
Actzo [ITM3]1-99
Raz   [M:ITM3]
Actzo [ITM5]1-99
Raz   [M:ITM5]
Actzo [ITS]1-99
Raz   [M:ITS]
If clalev([M:ITAV])
 Actzo [ITAV]1-99
 Raz [M:ITAV]
Endif
Raz [F:ITM]
If dim([M:ITM2]DLU) > 0
   [M:ITM2]DLU = 1
Endif
#If dim([M:ITM0]SOC)>0 & [M:ITM0]SOC<>""
#    GSOCIETE = [M:ITM0]SOC
#Else
#    GSOCIETE = GDEFSOC
#Endif
# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB
[M:ITM4]WPURTEX = 1 : [M:ITM4]PURTEX = ""
If dim([M:ITM1]WMFGTEX) > 0
    [M:ITM1]WMFGTEX = 1 : [M:ITM1]MFGTEX = ""
Endif
[M:ITS]WITSTEX   = 1 : [M:ITS]ITSTEX  = ""
[M:ITM1]WITPTEX  = 1 : [M:ITM1]ITPTEX  = ""
[M:ITS]CUR = GCUR

# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ITS]LOAECCFLG = [V]CST_ANO
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------

# Issue 70985 - 2012-03-09 by SR : Coef frais approche
[M:ITM4]CUR2      = GCUR
[M:ITM4]ITMCPRCOE = 1
If dim([M:ITM2]EXYMGTCOD) > 0
   [M:ITM2]JOUCAL = mess(1,291,1)
Endif
[M:ITM3]DACPUUCOE=1 : # Coef UA-US non modifiable !
[M:ITM4]JOURS1 = mess(1,291,1)
If !GIMPORT
    # Issue 106596 - 2018-08-31 by MAE : responsive UI
    #Affzo [M:ITM1]15
    Affzo [M:ITM1]20
    Affzo [M:ITM4]5
    Affzo [M:ITM5]30
    Affzo [M:ITS]25
Endif
Raz GTLPBOUT
#Modif CRM   5/9/2003
If GMODU(12) = 2
 If GIHDKACTCTL
  Gosub SETGRAY From SUBITMCRM
 Endif
Endif

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#

If dim([M:ITM5]NBAXE)>0
#  If dim([M:ITM0]SOC)>0 & [M:ITM0]SOC<>""
#    Call INIT_DIE(1,[M:ITM0]SOC,"ITM5","NBAXE") From TRTX3CPT
#  Else
    Call INIT_DIE(1,"","ITM5","NBAXE") From TRTX3CPT
#  Endif
Endif

#VPO 20/03/09
Gosub GRIZEBUTPLM

If [M:ITM0]TCLCOD<>""
    Call INIITG([M:ITM0]TCLCOD)
Else
    zonsui = "TCLCOD"
Endif
Return

# Initialise les zones avec la catégorie en fin de RAZCRE
Subprog INIITG(PTCL)
Value Char PTCL
If PTCL = "" : End : Endif
#-- Si on ne fait pas "Fichier nouveau", le grep est positionné
#-- Aprčs la saisie des deux zones de clé de la table
#-- Ce qui signifie que les valeurs par défaut ne sont pas chargées
Local Integer S_QUAFLG, S_STOMGTCOD, S_SERMGTCOD
#[L]S_QUAFLG    =[M:ITM2]QUAFLG         # hcb V6CQ
[L]S_STOMGTCOD =[M:ITM2]STOMGTCOD
If dim([M:ITM2]SERMGTCOD)>0
    [L]S_SERMGTCOD =[M:ITM2]SERMGTCOD
Endif
Read [ITG]ITG1=PTCL;""
If !fstat
    [M:ITM1] = [F:ITG]
    [M:ITM2] = [F:ITG]
    [M:ITM3] = [F:ITG]
    [M:ITM4] = [F:ITG]
    [M:ITM5] = [F:ITG]
    [M:ITS]  = [F:ITG]
    #MAE, le 05/02/09, bg 52179
    [M:ITS]MINRMNPRC = [F:ITG]SALRMNPRC


#    If [L]S_QUAFLG<>[M:ITM2]QUAFLG        # hcb V6CQ
#      Call AM_QUAFLG([M:ITM2]QUAFLG)      # hcb V6CQ
#    Endif                                 # hcb V6CQ
    If [L]S_STOMGTCOD<>[M:ITM2]STOMGTCOD
      Call AM_STOMGTCOD([M:ITM2]STOMGTCOD)
    Endif
    If dim([M:ITM2]SERMGTCOD)>0
       If [L]S_SERMGTCOD<>[M:ITM2]SERMGTCOD
          Call AM_SERMGTCOD([M:ITM2]SERMGTCOD)
       Endif
    Endif

    For I=0 To dim([F:ITG]PCU)-1
        If [F:ITG]PCU(I)<>""
            [M:ITM3]PCU(I)       = [F:ITG]PCU(I)
            [M:ITM3]PCUSTUCOE(I) = [F:ITG]PCUSTUCOE(I)
            [M:ITM3]DACPCUCOE(I) = [F:ITG]DACPCUCOE(I)
            [M:ITM3]LBEFMT(I)    = [F:ITG]LBEFMT(I)
            [M:ITM3]PCURUL(I)    = [F:ITG]PCURUL(I)

# hcb debut  11 01 05  27474
            If !GIMPORT & !GWEBSERV      # hcb 100727
               [M:ITM3]BASTAB      += 1
            Else
                If GSTK_PCUFLG = 0
                   [M:ITM3]BASTAB      += 1
                Endif
            Endif
# hcb fin  11 01 05  27474
        Else
            Break
        Endif
    Next

# hcb debut  11 01 05  27474
    If !GWEBSERV                         # hcb 100727
       If GIMPORT & GSTK_PCUFLG = 1
          For I=0 To dim([F:ITG]PCU)-1
              If [M:ITM3]PCU(I)<> ""
                 Raz [M:ITM3]PCU(I)
                 Raz [M:ITM3]PCUSTUCOE(I)
                 Raz [M:ITM3]DACPCUCOE(I)
                 Raz [M:ITM3]LBEFMT(I)
                 Raz [M:ITM3]PCURUL(I)
              Else
                 Break
              Endif
          Next
       Endif
    Endif                                # hcb 100727

# hcb fin  11 01 05  27474

    # Issue 70985 - 2012-05-30 by MUARN : landed cost ajout UA sur onglet achat/vente
    [M:ITM4]ITMPUU = [M:ITM3]PUU

    Affzo [M:ITM1]1-99
    Affzo [M:ITM2]1-99
    Affzo [M:ITM3]1-99
    Affzo [M:ITM4]1-99
    Affzo [M:ITM5]1-99
    Affzo [M:ITS]1-99

    # Issue 10401 - 2013-04-25 by MUARN : prix base vente en fonction prix base achat
    If [M:ITS]BASPRIORI = 2
      [M:ITS]BASPRI = [M:ITM4]PURBASPRI * (1+[M:ITS]PURPRIPRC/100)
      Affzo [M:ITS]BASPRI
      Diszo [M:ITS]BASPRI
    Else
      [M:ITS]PURPRIPRC = 0
      Diszo [M:ITS]PURPRIPRC
    Endif

Endif
 # Issue X3-121038 - 2019-01-14 by MAE : si gestion de lot <3, pas de version
 # Issue X3-141128 - 2019-05-27 by MAE : oubli du >0
    #If dim([M:ITM2]LOTMGTCOD) & [M:ITM2]LOTMGTCOD < 3
    If dim([M:ITM2]LOTMGTCOD)>0 & [M:ITM2]LOTMGTCOD < 3
# Issue X3-145492 - 2019-06-20 by CLPON : Adds > 0 to prevent: 'Variable Non-existent ECCFLG'
      # If dim([M:ITM2]ECCFLG)
      If dim([M:ITM2]ECCFLG) > 0
# End issue X3-145492
        [M:ITM2]ECCFLG = 1
        Diszo [M:ITM2]55
      Endif
    Endif
    # End issue X3-121038
End

$RAZDUP
#-------------------#
# Avant duplication #
#-------------------#
#MAE, bg 71988
[M:ITS]WMODPRI = 0
Local Integer WRET
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB
# Dupplication des textes pour le nouvel article
If [M:ITM4]PURTEX<>""
   Call DUP_CLOB("ITM",[M:ITM4]PURTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M:ITM4]PURTEX Endif
Endif
If dim([M:ITM1]MFGTEX)>0 & [M:ITM1]MFGTEX<>""
   Call DUP_CLOB("ITM",[M:ITM1]MFGTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M:ITM1]MFGTEX Endif
Endif
If [M:ITS]ITSTEX<>""
   Call DUP_CLOB("ITS",[M:ITS]ITSTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M:ITS]ITSTEX Endif
Endif
If [M:ITM1]ITPTEX<>""
   Call DUP_CLOB("ITS",[M:ITM1]ITPTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M:ITM1]ITPTEX Endif
Endif

# Dupplication des textes pour les nouveaux articles fournisseur et client
If dim([M:ITP]NBITP) > 0
 For nolign=1 To [M:ITP]NBITP
  Raz [M:ITP]ITPQUANUM(nolign-1)
  If [M:ITP]TEX(nolign-1)<>""
     Call DUP_CLOB("ITP",[M:ITP]TEX(nolign-1),WRET) From TRTX3TEX
     If WRET<1 Raz [M:ITP]TEX(nolign-1) Endif
  Endif
 Next
Endif
If dim([M:ITU]NBITU) > 0
 For nolign=1 To [M:ITU]NBITU
  If [M:ITU]ITSTEX(nolign-1)<>""
     Call DUP_CLOB("ITU",[M:ITU]ITSTEX(nolign-1),WRET) From TRTX3TEX
     If WRET<1 Raz [M:ITU]ITSTEX(nolign-1) Endif
  Endif
  If [M:ITU]ITPTEX(nolign-1)<>""
     Call DUP_CLOB("ITU",[M:ITU]ITPTEX(nolign-1),WRET) From TRTX3TEX
     If WRET<1 Raz [M:ITU]ITPTEX(nolign-1) Endif
  Endif
 Next
Endif

If [F:ITG]ITMREFCOU <> "" & [M:ITM0]ITMREF <> ""
# "La référence article va ętre effacée et affectée par compteur"
# combinée avec l'Avant-zone d'ITMDES1 : fonctionne bien !
   GMESSAGE = mess(14,196,1) : GERR = 2
Endif
Raz GTLPBOUT
# correction bug 17586  (duplication d'article créé avec le config 10/03/03)
If dim([M:ITM1]CFGVCRNUM)>0
  Raz [M:ITM1]CFGVCRNUM,CFGBPRNUM,CFGBPRREF,CFGITMREF,CFGDELDAT
Endif
# correction bug 16494   (Validation forcée) (04/12/02)
If [F:ITG]ITMCREMOD = 2
   [M:ITM0]ITMSTA = 2
   Affzo [M:ITM0]ITMSTA
Endif

#raz des 3 zones de PLM
If dim([M:ITM1]PLMITMREF)>0
Raz [M:ITM1]PLMITMREF : Affzo [M:ITM1]PLMITMREF
Raz [M:ITM1]PLMATTURL : Affzo [M:ITM1]PLMATTURL
Endif
If dim([M:ITM1]PLMHISURL)>0
Raz [M:ITM1]PLMHISURL : Affzo [M:ITM1]PLMHISURL
Endif
#VPO 20/03/09
Gosub GRIZEBUTPLM

Raz [M:ITP]XQUANUM

# 98144 - food allergens
# Disable entry if product is Manufactured
If func AFNC.ACTIV("FOA")
  If [M:ITM1]MFGFLG=2
    Raz [M:ITM2]ALG,ALGBOM,ALGDAT : Affzo [M:ITM2]ALG,ALGBOM,ALGDAT
  Else
    [M:ITM2]ALGDAT = date$        : Affzo [M:ITM2]ALGDAT
  Endif
Endif

Return

$LIENS
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
#------------#
# Chargement #
#------------#
If [F:ITG]TCLCOD<>[M:ITM0]TCLCOD
    Read [ITG]ITG1=[M:ITM0]TCLCOD;""
Endif
#MAE, bg 71988
[M:ITS]WMODPRI = 0
#If dim([M:ITM0]SOC)>0 & [M:ITM0]SOC<>""
#    GSOCIETE = [M:ITM0]SOC
#Else
#    GSOCIETE = GDEFSOC
#    [M:ITM0]SOC = GSOCIETE
#Endif
Raz GTLPBOUT
# Raz des zones mémoire de stockage des textes
If GFONCTION1="GESITM" Call RAZ_CLOB From ACLOB Endif

[M:ITM4]WPURTEX = 2
If [M:ITM4]PURTEX = "" [M:ITM4]WPURTEX = 1 Endif
If dim([M:ITM1]WMFGTEX) > 0
    [M:ITM1]WMFGTEX = 2
    If [M:ITM1]MFGTEX = "" [M:ITM1]WMFGTEX = 1 Endif
Endif

# Issue 70985 - 2012-02-14 by MUARN : Coef frais approche
If [M:ITM1]PURFLG = 2
  WMNTORG(0) = [F:ITM]PURBASPRI
  WMNTORG(1) = [F:ITM]CPRAMT
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
  If !SPSTAT  [M:ITM4]PURBASPRI = arr(WMNTDES(0),10^-GDECPRI) : Endif
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
  If !SPSTAT  [M:ITM4]ITMCPRAMT = arr(WMNTDES(1),10^-GDECPRI) : Endif
  [M:ITM4]ITMCPRCOE = [F:ITM]CPRCOE
  If [M:ITM4]ITMCPRCOE = 0 : [M:ITM4]ITMCPRCOE = 1 : Endif
  [M:ITM4]ITMSTCNUM = [F:ITM]STCNUM
# Issue 108660 - 2015-06-05 by MUARN : init CPRCOE si non acheté
Else
  If [M:ITM4]ITMCPRCOE = 0 : [M:ITM4]ITMCPRCOE = 1 : Endif
Endif
# tableau des unités de conditionnement    >> ou stocker le nb de PCU en table (?)
If dim([M:ITM3]PCU)>0
   If find("",[M:ITM3]PCU(0.. dim([M:ITM3]PCU)-1)) > 0
      [M:ITM3]BASTAB = find("",[M:ITM3]PCU(0.. dim([M:ITM3]PCU)-1)) -1
   Else
      [M:ITM3]BASTAB = dim([M:ITM3]PCU)
   Endif
Endif

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#

If dim([M:ITM5]NBAXE)>0
#  If dim([M:ITM0]SOC)>0 & [M:ITM0]SOC<>""
#    Call CHARG_DIE(1,[M:ITM0]SOC,"ITM5","NBAXE") From TRTX3CPT
#  Else
    Call CHARG_DIE(1,"","ITM5","NBAXE") From TRTX3CPT
#  Endif
Endif

If dim([M:ITM2]EXYMGTCOD) > 0
   [M:ITM2]JOUCAL = mess(1,291,1)
Endif
[M:ITM4]JOURS1 = mess(1,291,1)

[M:ITM1]SALFLG=[F:ITG]SALFLG
[M:ITM1]PURFLG=[F:ITG]PURFLG
[M:ITM1]MFGFLG=[F:ITG]MFGFLG
[M:ITM1]SCPFLG=[F:ITG]SCPFLG
[M:ITM1]SCSFLG=[F:ITG]SCSFLG
[M:ITM1]PHAFLG=[F:ITG]PHAFLG
[M:ITM1]GENFLG=[F:ITG]GENFLG
[M:ITM1]TOOFLG=[F:ITG]TOOFLG
[M:ITM1]DLVFLG=[F:ITG]DLVFLG
[M:ITM1]INTFLG=[F:ITG]INTFLG

Read [CBB]CBB0="ITM";[F:ITM]ITMREF;""
If !fstat
    [M:ITM1]IMG = [F:CBB]BLOB
Endif


If !GIMPORT
    If [F:ITG]SALFLG < 2  : # art non vendu => ecran ITS et ITU grisés
       Grizo [ITS]
       If dim([M:ITU]NBITU) > 0
        Grizo [ITU]
       Endif
    Else
       Actzo [ITS]1-99
       If dim([M:ITU]NBITU) > 0
        Actzo [ITU]1-99
       Endif
    Endif
    If ([F:ITG]PURFLG = 1 & [F:ITG]SCPFLG = 1 & [F:ITG]SCSFLG = 1 & [F:ITG]GENFLG = 1 & [F:ITG]TOOFLG = 1 )
       Grizo [ITM4]
       If dim([M:ITP]NBITP) > 0
        Grizo [ITP]
       Endif
    Else
       Actzo [ITM4]1-99
       If dim([M:ITP]NBITP) > 0
        Actzo [ITP]1-99
       Endif
    Endif

    # désactiver/réactiver les zones de ITM2
    If [M:ITM2]STOMGTCOD=1
       Grizo [M:ITM2]STDFLG,NEGSTO,RPLITM
       If dim([M:ITM2]TRKCOD)>0 Grizo [ITM2]TRKCOD : Endif
       If dim([M:ITM2]LOTMGTCOD) > 0             # bug 9604 25/06/01
         Grizo [ITM2]LOTMGTCOD,LOTCOU
       Endif
       If dim([M:ITM2]SERMGTCOD) > 0
         Grizo [ITM2]SERMGTCOD,SERCOU
       Endif
       Grizo [ITM2]25 # ne pas griser le contrat garantie :
      # Grizo [ITM2]QUAFLG, QUAACS, QLYCRD                 # hcb V6CQ
       If GMODU(12) = 2
         If GIHDKACTCTL
          Actzo [ITAV]TPLCONSRV
         Endif
       Endif
    Else
       Actzo [ITM2]1-99
       If GMODU(12) = 2
         If GIHDKACTCTL
            Grizo [ITAV]TPLCONSRV
         Endif
       Endif
    Endif

    If dim([M:ITM2]LOTMGTCOD) > 0             # bug 9604 25/06/01
       If [M:ITM2]LOTMGTCOD < 2      # 4 choix en 140
          Grizo [ITM2]LOTCOU
       Else
          Actzo [ITM2]LOTCOU
       Endif
       If dim([M:ITM2]EXYMGTCOD) > 0             # bug 9604 25/06/01
          If dim([M:ITM2]LOTMGTCOD)>0
              If [M:ITM2]LOTMGTCOD = 1
                 Grizo [ITM2]EXYMGTCOD, EXYSTA, SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU   # hcb V6PER
              Else
                 Actzo [ITM2]EXYMGTCOD, EXYSTA, SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU   # hcb V6PER
              Endif
          Endif
          LCOD = [M:ITM2]EXYMGTCOD
          LSHL = [M:ITM2]SHL
          LUOM = [M:ITM2]SHLUOM
          LDLU = [M:ITM2]DLU
          Gosub CALDLULTI
          [M:ITM2]DLULTI = WDLULTI
          Affzo [M:ITM2]DLULTI
       Endif
    Endif

#                                                       # hcb 71276 deb
#                                                       Issue 71276 - 2015-03-20 by SR : Versions
   If dim([M:ITM2]ECCFLG)>0
      If [M:ITM2]LOTMGTCOD < 3
         Grizo [M:ITM2]ECCSTO
         Grizo [M:ITM2]ECCFLG                  # hcb 110739
      Endif
      [M:ITM2]ECSMGT = "210"
      Actzo [M:ITM2]ECSMGT
      If [M:ITM2]LOTMGTCOD < 2 & [M:ITM2]STOMGTCOD = 1
         Grizo [M:ITM2]ECCFLG
         Grizo [M:ITM2]ECCSTO
         Grizo [M:ITM2]ECCMIN
         Grizo [M:ITM2]ECCMAJ
         Grizo [M:ITM4]LOAECCFLG
         Grizo [M:ITP]XLOAECCFLG
         Grizo [M:ITM2]ECSMGT
      Else
         If [M:ITM2]ECCFLG < 2
            Grizo [M:ITM2]ECCSTO
            Grizo [M:ITM2]ECCMIN
            Grizo [M:ITM2]ECCMAJ
            Grizo [M:ITM4]LOAECCFLG
            Grizo [M:ITP]XLOAECCFLG
            Grizo [M:ITM2]ECSMGT
         Else
            If [M:ITM2]ECCSTO = 1
                Grizo [M:ITM4]LOAECCFLG
                Grizo [M:ITP]XLOAECCFLG
                Grizo [M:ITM2]ECSMGT
            Endif
            If [M:ITM2]ECCSTO = 2
               Grizo [M:ITM2]ECCMIN
            Endif
            Call STKINIECC([F:ITM]ITMREF,"","ITM2",1,1,0,2,"","ECCVALMAJ","ECCVALMIN","","",0,"") From STKACT
            If [M:ITM2]ECCVALMAJ <> ""
               Read [ECS]ECS0=[F:ITM]ITMREF;[M:ITM2]ECCVALMAJ
               If fstat
                  Raz [F:ECS]
               Endif
               [M:ITM2]ECCSTA = [F:ECS]ECCSTA
            Endif
         Endif
      Endif
#                                                              # hcb 71276 43 deb
      Local Integer WFIND
      Raz WFIND
#     # recherche si l article est present dans les nomencltures
      If !clalev([F:BOH1]) : Local File BOM [F:BOH1] : Endif
#     si présence dans BOM bloc versions non modifiable
      Filter [F:BOH1] Where find(BOMALTTYP,2,3) & ITMREF=[M:ITM0]ITMREF
         For [F:BOH1]BOH0
             WFIND = 2
             Break
         Next
      Filter [F:BOH1]
      If WFIND = 0
#     si présence dans BOMD bloc versions non modifiable
         If !clalev([F:BOD1]) : Local File BOMD [F:BOD1] : Endif
         Filter [F:BOD1] Where find(BOMALTTYP,2,3) & CPNITMREF=[M:ITM0]ITMREF
            For [F:BOD1]BOD0
                WFIND = 2
                Break
            Next
         Filter [F:BOD1]
         If WFIND = 2
            Grizo [M:ITM2]55
         Endif
      Endif
      If WFIND=0 & dim([M:ITM2]ECCROUFLG)>0 : # Issue 104937 - 2015-11-12 by GH : Versioning for routing
         If clalev([F:ROH])=0 : Local File ROUTING    [ROH] : Endif
         Look [ROH]ROH0(1) = [M:ITM0]ITMREF
         If !fstat
            WFIND=2
         Endif
      Endif
# article sans gestion de version et présent dans les nomenclatures interdiction de passer en gestion version
      If [M:ITM2]ECCFLG < 2 & WFIND = 2
         Grizo [M:ITM2]55
      Else
# article avec gestion version
         Case [M:ITM2]ECCSTO
              When 2
#                 gestion majeure : interdiction de passer en mineure ou sans gestion
                  If WFIND = 2
                     Grizo [M:ITM2]55
                     Actzo [M:ITM2]ECCMAJ
                     Actzo [M:ITM2]ECSMGT
                  Else
                     Actzo [M:ITM2]55
                     # Issue X3172453 - 2020-01-06 by MAE, compteur mineure non accessible
                     Grizo [M:ITM2]ECCMIN
                  Endif
              When 3
#                 gestion mineure : interdiction de passer en majeure ou sans gestion
                  If WFIND = 2
                     Grizo [M:ITM2]55
                     Actzo [M:ITM2]ECCMAJ
                     Actzo [M:ITM2]ECCMIN
                     Actzo [M:ITM2]ECSMGT
                  Else
                     Actzo [M:ITM2]55
                  Endif
         Endcase
      Endif

      If dim([M:ITM2]ECCROUFLG) > 0 : # Issue 104937 - 2015-11-12 by GH : Versioning for routing
           If varmode([M:ITM2]ECCMAJ)
               Grizo [ITM2]ECCROUFLG
           Else
               Actzo [ITM2]ECCROUFLG
          Endif
      Endif
   Endif
#                                                              # hcb 71276 43 fin
#                                                       # hcb 71276 fin

    If dim([M:ITM2]SERMGTCOD) > 0  # v 140
       If [M:ITM2]SERMGTCOD < 2
          Grizo [ITM2]SERCOU
       Else
          Actzo [ITM2]SERCOU
       Endif
    Endif

    If dim([M:ITM2]EXYMGTCOD) > 0             # bug 9604 25/06/01
       If [M:ITM2]EXYMGTCOD= 1
          Grizo [ITM2]EXYSTA,SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU   # hcb V6PER
       Else
          Actzo [ITM2]EXYSTA,SHL, SHLUOM, NEWLTISTA, SHLLTI, SHLLTIUOM, DLU   # hcb V6PER
       Endif
       If [M:ITM2]EXYMGTCOD= 3 | [M:ITM2]EXYMGTCOD= 4            # hcb dlu
          Grizo [M:ITM2]DLU
       Endif
    Endif
    If [M:ITM2]RPLITM <> ""
     #Call LECTEXTRA([M:ITM2]RPLITMDES,"ITMMASTER","DES1AXX",[M:ITM2]RPLITM,"") From ATEXTRA
     Read [ITM2]ITM0=[M:ITM2]RPLITM                                                                   # FGR 30/06/2009 : X3SUIVI56189
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:ITM2]RPLITM,[M:ITM2]RPLITMDES, "[F:ITM2]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif

    If dim([M:ITM1]EECGES) > 0  # hcb 58657
       If [M:ITM1]EECGES < 2
          Grizo [M:ITM1]CUSREF
       Else
          Actzo [M:ITM1]CUSREF
       Endif
    Endif
    #MAE, bg 69389
    If dim([M:ITM2]TRKCOD)>0
       #--- Bug 55665
       #If (dim([M:ITM2]LOTMGTCOD)>0 & [M:ITM2]LOTMGTCOD<2) & (dim([M:ITM2]SERMGTCOD)>0 & [M:ITM2]SERMGTCOD<>3)    # hcb 69389
       #    Diszo [M:ITM2]TRKCOD
       #Else
       #    Actzo [M:ITM2]TRKCOD
       #Endif
       #--- Issue 110327 : remplacement de [M:ITM2]SERMGTCOD<>3 par [M:ITM2]SERMGTCOD<3
       If (dim([M:ITM2]LOTMGTCOD)<0 | (dim([M:ITM2]LOTMGTCOD)>0 & [M:ITM2]LOTMGTCOD<2))
&       & (dim([M:ITM2]SERMGTCOD)<0 | (dim([M:ITM2]SERMGTCOD)>0 & [M:ITM2]SERMGTCOD<3))
          [M:ITM2]TRKCOD=1
          Diszo [M:ITM2]TRKCOD
          If dim([M:ITM2]TRKLEV)>0
             [M:ITM2]TRKLEV=1
             Diszo [M:ITM2]TRKLEV
          Endif
       Else
          Actzo [M:ITM2]TRKCOD
          If dim([M:ITM2]TRKLEV)>0
             If [M:ITM2]TRKLEV=0 : [M:ITM2]TRKLEV=1 : Endif
             If [M:ITM2]TRKCOD<2
                Diszo [M:ITM2]TRKLEV
             Else
                Actzo [M:ITM2]TRKLEV
             Endif
          Endif
       Endif
       #---
    Endif
    # Issue 90991 - 2013-11-08 by MAE : En création, griso du bouton
    # Issue 116245 - 2016-05-02 by MAE
    If dim([M:ITP]STCNUMITF)>0
      Actzo [M:ITP]STCNUMITF
    Endif
    # Issue 59757 - 2017-10-23 by MAE : Service et vendu => unités de vente accessibles
#    If [M:ITM1]SCSFLG = 2                                  # hcb 103984
#       Grizo [M:ITM3]SAU, SAUSTUCOE, DACSAUCOE             # hcb 103984
#    Endif                                                  # hcb 103984

Endif



# Chargement ecran ITMSALES
Raz [M:ITS]
Read [ITS]ITS0 = [M:ITM0]ITMREF
If !fstat
  [M:ITS]          = [F:ITS]
  [M:ITM1]ITPTEX   = [F:ITS]ITPTEX
  [M:ITS]WITSTEX   = 2
  If [M:ITS]ITSTEX = "" [M:ITS]WITSTEX = 1 Endif
  [M:ITM1]WITPTEX  = 2
  If [M:ITM1]ITPTEX = "" [M:ITM1]WITPTEX = 1 Endif
  # Alimentation des mnts stockés en dev dossier dans [F] pour saisie en dev soc dans [M]
  WMNTORG(0) = [F:ITS]MINPRI
  WMNTORG(1) = [F:ITS]THEPRI
  WMNTORG(2) = [F:ITS]BASPRI
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
  #MAE, le 11/12/08, bg 50926
  #If !SPSTAT  [M:ITS]MINPRI = arr(WMNTDES(0),0.0001) : Endif
  If !SPSTAT  [M:ITS]MINPRI = arr(WMNTDES(0),10^-GDECPRI) : Endif
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
  #MAE, le 11/12/08, bg 50926
  #If !SPSTAT  [M:ITS]THEPRI = arr(WMNTDES(1),0.0001) : Endif
  If !SPSTAT  [M:ITS]THEPRI = arr(WMNTDES(1),10^-GDECPRI) : Endif
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(2),WMNTDES(2),SPSTAT) From TRTDEV
  #MAE, le 11/12/08, bg 50926
  #If !SPSTAT  [M:ITS]BASPRI = arr(WMNTDES(2),0.0001) : Endif
  If !SPSTAT  [M:ITS]BASPRI = arr(WMNTDES(2),10^-GDECPRI) : Endif
  If [M:ITS]SBSITM <> ""
   #Call LECTEXTRA([M:ITS]SBSITMDES,"ITMMASTER","DES1AXX",[M:ITS]SBSITM,"") From ATEXTRA
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:ITS]SBSITM,[M:ITS]SBSITMDES, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Endif
Endif
[M:ITS]CUR = GCUR
# Issue 70985 - 2012-03-09 by SR
[M:ITM4]CUR2 = GCUR
# Issue 10401 - 2013-04-25 by MUARN : origine prix de base vente possibilité % achat
Affzo [M:ITS]1-99
If [M:ITS]BASPRIORI = 1
  Diszo [M:ITS]PURPRIPRC
  Actzo [M:ITS]BASPRI
Else
  Actzo [M:ITS]PURPRIPRC
  Diszo [M:ITS]BASPRI
Endif

# 107888 : Scheduled invoices (LD:03/12/15)
# Invoice term accessible only for Service/Generic category and type of flow sales and not deliverable
If GMODU(5)=2
    If ([M:ITM1]SCSFLG=2 | [M:ITM1]GENFLG=2) & [M:ITM1]SALFLG=2 & [M:ITM1]DLVFLG=1
      Actzo [M:ITS]INVCND
    Else
      Diszo [M:ITS]INVCND
    Endif
Endif
# 107888 : Scheduled invoices (LD:03/12/15)

# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  If [M:ITM2]LOTMGTCOD < 2 & [M:ITM2]STOMGTCOD = 1 Then
    Grizo [M:ITS]LOAECCFLG
    # Issue 119820
    If dim([M:ITU]XLOAECCFLG)>0  Grizo [M:ITU]XLOAECCFLG Endif
  Else
    If [M:ITM2]ECCFLG < 2 Then
      Grizo [M:ITS]LOAECCFLG
      # Issue 119820
      If dim([M:ITU]XLOAECCFLG)>0     Grizo [M:ITU]XLOAECCFLG  Endif
    Else
      If [M:ITM2]ECCSTO = 1 Then
        Grizo [M:ITS]LOAECCFLG
        # Issue 119820
        If dim([M:ITU]XLOAECCFLG)>0  Grizo [M:ITU]XLOAECCFLG  Endif
      Endif
    Endif
  Endif
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------



# fin Issue 10401 - 2011-12-12 by MUARN : origine prix de base vente possibilité % achat
# Issue 70985 - 2012-05-30 by MUARN : landed cost ajout UA sur onglet achat/vente
[M:ITM4]ITMPUU = [M:ITM3]PUU

# Chargement ecran ITMBPS (tableau)
If dim([M:ITP]NBITP) > 0
  Raz [M:ITP]
  nolign = 0
  For [ITP] Where ITMREF = [M:ITM0]ITMREF
     nolign += 1
     [M:ITP] = [F:ITP]
     [M:ITP]XQUALIB  = mess(714,197,1)     # hcb V6cq
    # Noms de zones différent dans le mask pour éviter écrasement de ITM
     [M:ITP]ITPPCU(nolign-1)     = [F:ITP]PCU
     [M:ITP]ITPPUU(nolign-1)     = [F:ITP]PUU
     [M:ITP]ITPQUAFLG(nolign-1)  = [F:ITP]QUAFLG
     [M:ITP]ITPQLYCRD(nolign-1)  = [F:ITP]QLYCRD    # hcb V6CQ
     [M:ITP]ITPQUAFRY(nolign-1)  = [F:ITP]QUAFRY    # hcb V6CQ
     [M:ITP]ITPQUANUM(nolign-1)  = [F:ITP]QUANUM    # hcb V6CQ
     If dim([M:ITP]LOAECCFLG)>0
        [M:ITP]LOAECCFLG(nolign-1)  = [F:ITP]LOAECCFLG # hcb 71276
     Endif
     # Issue 70985 - 2012-03-09 by SR
     If [M:ITP]CPRCOE(nolign-1) = 0 : [M:ITP]CPRCOE(nolign-1) = 1 : Endif
     WMNTORG(1) = [F:ITP]CPRAMT
     Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
     If !SPSTAT  [M:ITP]CPRAMT(nolign-1) = arr(WMNTDES(1),10^-GDECPRI) : Endif
     #--- Bug 55665
     #[M:ITP]ITPMATTOL(nolign-1)  = [F:ITP]MATTOL    # Three Way Matching
     If dim([M:ITP]ITPMATTOL)>0 [M:ITP]ITPMATTOL(nolign-1)=[F:ITP]MATTOL Endif   # Three Way Matching
     #---
     [M:ITP]IPCUPUUCOE(nolign-1) = [F:ITP]PCUPUUCOE
     [M:ITP]IPUUSTUCOE(nolign-1) = [F:ITP]PUUSTUCOE
    # Lecture du tiers pour voir s'il est inter-site
     If [F:BPR]BPRNUM<>[M:ITP]BPSNUM(nolign-1)
         Read [BPR]BPR0=[M:ITP]BPSNUM(nolign-1)
         If fstat Raz [F:BPR] : Endif
     Endif
     [M:ITP]BETFCY(nolign-1)   =[F:BPR]BETFCY
     [M:ITP]DESBPSNUM(nolign-1)=[F:BPR]BPRNAM
  Next
  [M:ITP]NBITP  = nolign
  # Chargement des zones ŕ saisir
  If [M:ITP]NBITP > 0
     [M:ITP]XBPSNUM            = [M:ITP]BPSNUM(0)
     [M:ITP]XDESBPSNUM         = [M:ITP]DESBPSNUM(0)
     [M:ITP]XITMREFBPS         = [M:ITP]ITMREFBPS(0)
     [M:ITP]XITMDESBPS         = [M:ITP]ITMDESBPS(0)
     [M:ITP]XEANCODBPS         = [M:ITP]EANCODBPS(0)
     [M:ITP]XDOUFLG            = [M:ITP]DOUFLG(0)
     [M:ITP]XPURMINQTY         = [M:ITP]PURMINQTY(0)
     [M:ITP]XCPRCOE            = [M:ITP]CPRCOE(0)
     [M:ITP]XCPRAMT            = [M:ITP]CPRAMT(0) # Issue 70985 - 2012-02-14 by MUARN : Coef frais approche
     [M:ITP]XSTCNUM            = [M:ITP]STCNUM(0) # Issue 84130 - 2012-09-14 by MUARN : landed csot structure cout
     [M:ITP]CUR3               = GCUR
     [M:ITP]XQLYMRK            = [M:ITP]QLYMRK(0)
     [M:ITP]XQUAFLG            = [M:ITP]ITPQUAFLG(0)
     [M:ITP]XQLYCRD            = [M:ITP]ITPQLYCRD(0)   # V6CQ
     [M:ITP]XQUAFRY            = [M:ITP]ITPQUAFRY(0)   # V6CQ
     [M:ITP]XQUANUM            = [M:ITP]ITPQUANUM(0)   # V6CQ
     If dim([M:ITP]XEECINCRAT)>0
        [M:ITP]XEECINCRAT      = [M:ITP]EECINCRAT(0)
     Endif
     [M:ITP]XPUU               = [M:ITP]ITPPUU(0)
     [M:ITP]XPUUSTUCOE         = [M:ITP]IPUUSTUCOE(0)
     [M:ITP]XPCU               = [M:ITP]ITPPCU(0)
     If dim([M:ITP]LOAECCFLG)>0                          # hcb 71276
        [M:ITP]XLOAECCFLG      = [M:ITP]LOAECCFLG(0)
     Endif
     [M:ITP]XPCUPUUCOE         = [M:ITP]IPCUPUUCOE(0)
     [M:ITP]XTEX               = [M:ITP]TEX(0)
     [M:ITP]XPIO               = [M:ITP]PIO(0)
     [M:ITP]XCTMBPSFLG         = [M:ITP]CTMBPSFLG(0)
     [M:ITP]XBOMALT            = [M:ITP]BOMALT(0)   : # ajout V6 sous-traitance
     [M:ITP]XSCOLTI            = [M:ITP]SCOLTI(0)   : # ajout V6 sous-traitance
     # Issue X3-126315 - 2019-02-19 by SR :
     #[M:ITP]WTEX = 2
     [M:ITP]WTEXFLG = 2
     #--- Bug 55665
     #[M:ITP]XMATTOL            = [M:ITP]ITPMATTOL(0)  # Three Way Matching
     If dim([M:ITP]ITPMATTOL)>0 [M:ITP]XMATTOL=[M:ITP]ITPMATTOL(0) Endif   # Three Way Matching
     #---
     # Issue X3-126315 - 2019-02-19 by SR :
     #If [M:ITP]XTEX = "" [M:ITP]WTEX = 1 Endif
     If [M:ITP]XTEX = "" [M:ITP]WTEXFLG = 1 Endif
     [M:ITP]XBETFCY            = [M:ITP]BETFCY(0)
     # Issue 105707 - 2015-02-05 by SR : comment
     If [M:ITP]XQUAFLG = 1
        Grizo [M:ITP]XQLYCRD
        Grizo [M:ITP]XQUAFRY
     # Issue 122447 - 2017-04-13 by MAE : comment
     Else
        Actzo [M:ITP]XQLYCRD
        Actzo [M:ITP]XQUAFRY
     Endif
     #Inicio - FJCG - AURENV12
     [M:ITP]XZESPESORP = [M:ITP]ZESPESORP(0)
     [M:ITP]XZDTYP     = [M:ITP]ZDTYP(0)
     [M:ITP]XZFACTORP  = [M:ITP]ZFACTORP(0)
     #Fin  - FJCG - AURENV12
  Endif
Endif


# Chargement ecran ITMBPC (tableau)
If dim([M:ITU]NBITU) > 0
  Raz [M:ITU]
  nolign = 0
  For [ITU] Where ITMREF = [M:ITM0]ITMREF
    nolign += 1
    [M:ITU] = [F:ITU]
    # Noms de zones différent dans le mask pour éviter écrasement de ITM
    [M:ITU]ISAU(nolign-1)        = [F:ITU]SAU
    [M:ITU]ISAUSTUCOE(nolign-1)  = [F:ITU]SAUSTUCOE
    If [M:ITU]ISAU(nolign-1)=""
       [M:ITU]ISAU(nolign-1)=[M:ITM3]SAU
       [M:ITU]ISAUSTUCOE(nolign-1)=[M:ITM3]SAUSTUCOE
    Endif
    # Lecture du tiers pour voir s'il est inter-site
    If [F:BPR]BPRNUM<>[M:ITU]BPCNUM(nolign-1)
        Read [BPR]BPR0=[M:ITU]BPCNUM(nolign-1)
        If fstat Raz [F:BPR] : Endif
    Endif
    [M:ITU]BETFCY(nolign-1)=[F:BPR]BETFCY
  Next
  [M:ITU]NBITU  = nolign
  # Chargement des zones ŕ saisir
  If [M:ITU]NBITU > 0
      [M:ITU]XBPCNUM            = [M:ITU]BPCNUM(0)
      [M:ITU]XITMREFBPC         = [M:ITU]ITMREFBPC(0)
      [M:ITU]XITMDESBPC         = [M:ITU]ITMDESBPC(0)
      [M:ITU]XSAU               = [M:ITU]ISAU(0)
      [M:ITU]XSAUSTUCOE         = [M:ITU]ISAUSTUCOE(0)
      [M:ITU]XPCU1              = [M:ITU]PCU1(0)
      [M:ITU]XPCUSAUCO1         = [M:ITU]PCUSAUCOE1(0)
      [M:ITU]XPCU2              = [M:ITU]PCU2(0)
      [M:ITU]XPCUSAUCO2         = [M:ITU]PCUSAUCOE2(0)
      [M:ITU]XPCK               = [M:ITU]PCK(0)
      [M:ITU]XPCKCAP            = [M:ITU]PCKCAP(0)
      [M:ITU]XITSTEX            = [M:ITU]ITSTEX(0)
      [M:ITU]XITPTEX            = [M:ITU]ITPTEX(0)
      [M:ITU]WITSTEX = 2
      If [M:ITU]XITSTEX = "" [M:ITU]WITSTEX = 1 Endif
      [M:ITU]WITPTEX = 2
      If [M:ITU]XITPTEX = "" [M:ITU]WITPTEX = 1 Endif
      [M:ITU]XBETFCY            = [M:ITU]BETFCY(0)
      [M:ITU]XDLUBPC            = [M:ITU]DLUBPC(0)
      # --------------------------------------
      # FGR 21/04/2015 : X3SUIVI105605 (début)
      If func AFNC.ACTIV("ECC") Then
        [M:ITU]XLOAECCFLG = [M:ITU]LOAECCFLG(0)
      Endif
      # FGR 21/04/2015 : X3SUIVI105605 (fin)
      # --------------------------------------
#                                                   # hcb dlu deb
      If dim([M:ITM2]EXYMGTCOD)>0
         LCOD = [M:ITM2]EXYMGTCOD
         LSHL = [M:ITM2]SHL
         LUOM = [M:ITM2]SHLUOM
         LDLU = [M:ITU]XDLUBPC
         Gosub CALDLULTI
         [M:ITU]DLULTI  = WDLULTI
         [M:ITU]XDLULTI = WDLULTI
      Endif
#                                                   # hcb dlu fin
      # Issue 113815 - 2016-01-19 by MAE
#      LCOD = [M:ITM2]EXYMGTCOD
#      LSHL = [M:ITM2]SHL
#      LUOM = [M:ITM2]SHLUOM
#      LDLU = [M:ITU]XDLUBPC
#      Gosub CALDLULTI
#      [M:ITU]DLULTI  = WDLULTI
#      [M:ITU]XDLULTI = WDLULTI
      # Bug 27121 - TS le 16/12/04
      If [M:ITU]XSAU=[M:ITM3]STU
         Diszo [M:ITU]XSAUSTUCOE
      Else
         Actzo [M:ITU]XSAUSTUCOE
      Endif

  Endif
  # Issue 119820
  If dim([M:ITM2]EXYMGTCOD)>0
   If [M:ITM2]EXYMGTCOD = 1 | [M:ITM2]EXYMGTCOD= 3 | [M:ITM2]EXYMGTCOD= 4
      [M:ITU]XDLUBPC = 1
      Diszo [M:ITU]XDLUBPC
   Else
      Actzo [M:ITU]XDLUBPC
   Endif
Endif
Endif
# hcb dlu deb
# Issue 119820 - 2016-11-17 by MAE : déplacé dans le if
#If dim([M:ITM2]EXYMGTCOD)>0
#   If [M:ITM2]EXYMGTCOD = 1 | [M:ITM2]EXYMGTCOD= 3 | [M:ITM2]EXYMGTCOD= 4
#      [M:ITU]XDLUBPC = 1
#      Diszo [M:ITU]XDLUBPC
#   Else
#      Actzo [M:ITU]XDLUBPC
#   Endif
#Endif
# hcb dlu fin

#Modif CRM   5/9/2003
If GMODU(12) = 2
 If GIHDKACTCTL
  Gosub SETGRAY From SUBITMCRM
  If !GIMPORT
    Call LOADPIT([M:ITM0]ITMREF) From SUBITMCRM
  Endif
 Endif
Endif

# Chargement des familles comptables par législation
If dim([M:ITM5]NBFAM) > 0
 If dim([M:ITM5]LEGGRP) < 0
  # Une seule famille
  Read [ITA]ITA0=[M]ITMREF;""
  If fstat : Raz [F:ITA] : Endif
  [M:ITM5]ACGGRP(0)  = [F:ITA]ACGGRP
  [M:ITM5]NBFAM = 1
 Else
  For [ADI]CODE Where NUMTAB=909
   Read [ITA]ITA0=[M]ITMREF;[F:ADI]CODE
   If fstat : Raz [F:ITA] : Endif

   [M:ITM5]LEGGRP([M:ITM5]NBFAM) = [F:ADI]CODE
   [M:ITM5]ACGGRP([M:ITM5]NBFAM) = [F:ITA]ACGGRP

   [M:ITM5]NBFAM += 1
  Next
 Endif

 If [M:ITM5]FLGFAS = 2
  Actzo [M:ITM5]NBFAM
 Else
  Grizo [M:ITM5]NBFAM
 Endif
Endif

#-----------------------------------#
# Désignations traduisibles (début) #
#-----------------------------------#
Local Char WITMDES(GLONDES)

  Call CHARGE_ITMDES("DES1AXX",GLANGUE,[M:ITM0]ITMREF,WITMDES) From TRTX3 # FGR 03/07/2009 : X3SUIVI56319
  If WITMDES = "" and [F:ITM]ITMDES1 <> "" Then                           # FGR 03/07/2009 : X3SUIVI56319
    [M:ITM0]DES1AXX = [F:ITM]ITMDES1                                      # FGR 03/07/2009 : X3SUIVI56319 : si la désignation n'a pas été traduite, on affiche celle qu'il y a.
    # Attention elle n'est pas enregistrée : On l'affiche en NTRANSLATE pour le différencier
    Chgstl [M:ITM0]DES1AXX With "NTRANSLATE"
  Else
    Chgstl [M:ITM0]DES1AXX With ""
  Endif
  Call CHARGE_ITMDES("DES2AXX",GLANGUE,[M:ITM0]ITMREF,WITMDES) From TRTX3 # FGR 03/07/2009 : X3SUIVI56319
  If WITMDES = "" and [F:ITM]ITMDES2 <> "" Then                           # FGR 03/07/2009 : X3SUIVI56319
    [M:ITM1]DES2AXX = [F:ITM]ITMDES2                                      # FGR 03/07/2009 : X3SUIVI56319 : si la désignation n'a pas été traduite, on affiche celle qu'il y a.
    # Attention elle n'est pas enregistrée : On l'affiche en NTRANSLATE pour le différencier
    Chgstl [M:ITM1]DES2AXX With "NTRANSLATE"
  Else
    Chgstl [M:ITM1]DES2AXX With ""
  Endif
  Call CHARGE_ITMDES("DES3AXX",GLANGUE,[M:ITM0]ITMREF,WITMDES) From TRTX3 # FGR 03/07/2009 : X3SUIVI56319
  If WITMDES = "" and [F:ITM]ITMDES3 <> "" Then                           # FGR 03/07/2009 : X3SUIVI56319
    [M:ITM1]DES3AXX = [F:ITM]ITMDES3                                      # FGR 03/07/2009 : X3SUIVI56319 : si la désignation n'a pas été traduite, on affiche celle qu'il y a.
    # Attention elle n'est pas enregistrée : On l'affiche en NTRANSLATE pour le différencier
    Chgstl [M:ITM1]DES3AXX With "NTRANSLATE"
  Else
    Chgstl [M:ITM1]DES3AXX With ""
  Endif
#-----------------------------------#
# Désignations traduisibles (fin)   #
#-----------------------------------#

#VPO 20/03/09
Gosub GRIZEBUTPLM


Return


$APRES_CHOI
Return


$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Integer WRET

If !GIMPORT
  Actzo [ITM2]1-99
Endif

If GREP = "D"
   # Suppression des textes articles
   If [M:ITM4]PURTEX<>""
      Call SUP_CLOB([M:ITM4]PURTEX,WRET) From TRTX3TEX
   Endif
   If dim([M:ITM1]MFGTEX)>0 & [M:ITM1]MFGTEX<>""
      Call SUP_CLOB([M:ITM1]MFGTEX,WRET) From TRTX3TEX
   Endif
   If [M:ITS]ITSTEX<>""
      Call SUP_CLOB([M:ITS]ITSTEX,WRET) From TRTX3TEX
   Endif
   If [M:ITM1]ITPTEX<>""
      Call SUP_CLOB([M:ITM1]ITPTEX,WRET) From TRTX3TEX
   Endif

   If dim([M:ITU]NBITU) > 0
      For nolign = 1 To [M:ITU]NBITU
         If [M:ITU]ITSTEX(nolign-1)<>""
            Call SUP_CLOB([M:ITU]ITSTEX(nolign-1),WRET) From TRTX3TEX
         Endif
         If [M:ITU]ITPTEX(nolign-1)<>""
            Call SUP_CLOB([M:ITU]ITPTEX(nolign-1),WRET) From TRTX3TEX
         Endif
      Next
   Endif
   If dim([M:ITP]NBITP) > 0
      For nolign = 1 To [M:ITP]NBITP
         If [M:ITP]TEX(nolign-1)<>""
            Call SUP_CLOB([M:ITP]TEX(nolign-1),WRET) From TRTX3TEX
         Endif
      Next
   Endif
Endif

# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB
Return

$EFFMASK
#VPO 20/03/09
Gosub GRIZEBUTPLM
Return

#######################################################
# SOUS-PROGRAMME DE RECHERCHE DE COEFF. DE CONVERSION #
# appelé en avant-saisie des coeff :                  #
#######################################################
Subprog COEFCNV(U1,U2,COEF)
Value Char U1,U2
Variable Decimal COEF
If U1 = "" | U2 = ""  : COEF = 0 : mkstat=2 : End : Endif
If U1 = U2 : COEF = 1 : mkstat=2 : End : Endif
End

#######################################################
# SOUS-PROGRAMME DE RECHERCHE DE COEFF. DE CONVERSION #
# appelé en aprčs-modif des unités : (05/03/01)       #
#######################################################
Subprog MODUNIT(U1,U2,COEF)
Value Char U1,U2
Variable Decimal COEF
If U1 = "" | U2 = ""  : COEF = 0 : End : Endif
If U1 = U2 : COEF = 1 : End : Endif
# Chargement du coeff de la table
If clalev([F:TCO])=0 : Local File TABCOEFF [TCO] : Endif
Read [TCO]TCO0=U1;U2
If !fstat : COEF = [F:TCO]COEUOM : Endif
End

########################################
$WARNING_MVT
# bug 6685 Avertir si des mvts de stock existent
If GREP <> "C" & GREP <> "D"
  If clalev([F:STJ]) = 0 : Local File STOJOU [STJ] : Endif
  # modif pour performances (conditions correspondant ŕ une clé) 29/04/02
  For [STJ]STJ2 Where UPDCOD=2 & ITMREF = [M:ITM0]ITMREF
    GERR = 2 : GMESSAGE = mess(68,188,1)
    Break
  Next
  If GERR < 2
    For [STJ]STJ2 Where UPDCOD=1 & ITMREF = [M:ITM0]ITMREF
      GERR = 2 : GMESSAGE = mess(68,188,1)
      Break
    Next
  Endif
Endif
Return

#-------------------------------------------------------------
# creation article site  hcb 42541
#-------------------------------------------------------------
$CRE_ITMFACILIT

#---- Ouverture table article site
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif

Read [ITG]ITG1=[F:ITM]TCLCOD;LFCY
If fstat
  Read [ITG]ITG1=[F:ITM]TCLCOD;""
Endif
If fstat : Return : Endif


Raz [F:ITF]
#MAE, bug 79754, inversion des trans classes
#[F:ITF] = [F:ITM]
#[F:ITF] = [F:ITG]
[F:ITF] = [F:ITG]
[F:ITF] = [F:ITM]

If [F:ITF]STOMGTCOD<2
   [F:ITF]LOCMGTCOD=1 :  # Si pas géré en stock pas d'emplacement
Endif
If [F:ITF]STOMGTCOD>1 & [F:ITF]LOCMGTCOD>1
    Raz I
    While I < dim([F:ITF]LOCNUM) & [F:ITG]LOCDES(I) > 0
    [F:ITF]LOCNUM(I) = [F:ITG]LOCDES(I)
    If [F:ITF]DEFLOCTYP(I) = ""
       [F:ITF]DEFLOCTYP(I) = "*"
    Endif
    I += 1
    Wend
Endif

#MAE, bg 74030, si la catégorie site a écrasé l'acheteur et qu'il y en a un ds l'article
#On remet celui de l'article sur l'article site
If [F:ITM]BUY <> "" & [F:ITF]BUY <> [F:ITM]BUY
  [F:ITF]BUY=[F:ITM]BUY
Endif
#męme chose sur PLANNER
If [F:ITM]PLANNER <> "" & [F:ITF]PLANNER <> [F:ITM]PLANNER
  [F:ITF]PLANNER=[F:ITM]PLANNER
Endif

#MAE, bg 68556
#Controle sur l'article site
#Controle sur REOMINQTY
# Politique de réappro : Qté mini avec ou sans arrondi
If [F:ITF]REOPOL <> ""
    If !clalev([F:TRP]) : Local File TABREOPOL [TRP] : Endif
    Read [TRP]TRP0=[F:ITF]REOPOL
    If fstat
        Raz [F:TRP]
    Endif
Endif

If [F:ITF]REOPOL <> "" & [F:TRP]REOQTYCOD > 1 & [F:ITF]REOMINQTY = 0
   If GTRACE <> ""
       Call ECR_TRACE(mess(100,141,1)+" "+mess(3,45,1)+" : "+LFCY+" "+mess(275,199,1),1) From GESECRAN
   Else
       GMESSAGE = mess(275,199,1)
   Endif
   mkstat = 2
   Return
Endif

#contrôle sur BUY
# si gestionnaire renseigné au niveau article, zone obligatoire (llc v130)
If [F:ITF]BUY = "" & [F:ITF]BUY <> [F:ITM]BUY
    If GTRACE <> ""
        Call ECR_TRACE(mess(100,141,1)+" "+mess(3,45,1)+" : "+LFCY+" "+mess(285,199,1),1) From GESECRAN
    Else
        GMESSAGE = mess(285,199,1)
    Endif
    mkstat = 2
    Return
Endif

#contrôle sur PLANNER
# si gestionnaire renseigné au niveau article, zone obligatoire (llc v130)
If [F:ITF]PLANNER = "" & [F:ITF]PLANNER <> [F:ITM]PLANNER
    If GTRACE <> ""
        Call ECR_TRACE(mess(100,141,1)+" "+mess(3,45,1)+" : "+LFCY+" "+mess(285,199,1),1) From GESECRAN
    Else
        GMESSAGE = mess(285,199,1)
    Endif
    mkstat = 2
    Return
Endif
#Fin MAE bg 68556


[F:ITF]STOFCY    = LFCY
[F:ITF]CUNFLG    = 1
[F:ITF]REDMODFLG = 1
[F:ITF]WIPPRO    = 1
[F:ITF]RELSCATIA = 2
[F:ITF]CREDAT    = date$
[F:ITF]CREUSR    = GUSER
[F:ITF]NQA       = 12    # hcb 63722
[F:ITF]SMPMOD    = 3     # hcb 63722
[F:ITF]SMPTYP    = 1     # hcb 63722
[F:ITF]GENLEVINS = 4     # hcb 63722
[F:ITF]EXPNUM    = [C]EXPORT   # hcb 81071

#MAE, bg76914
If FILROLE <>""
  If !evalue(FILROLE) & GTRACE <> ""
    Call ECR_TRACE(mess(97,126,1)+":"+mess(3,45,1)+ "-"+[F:ITF]STOFCY,1) From GESECRAN
    mkstat = 2
    Return
  Endif
Endif
#Fin bg76914

GPOINT = "BEFWRIITF"
Gosub ENTREE From EXEFNC
If dim(GSIMCREITF) < 0
  Write [ITF]
  If fstat
     GOK = 0
     Call FSTA("ITF") From GLOCK
  Endif
Endif

If GWRHACT=2
   # Création des articles dépôts
   If [F:ITF]STOMGTCOD>1 & [F:ITF]LOCMGTCOD=2
      Call GENITW(2,[F:ITF]STOFCY,[F:ITF]ITMREF) From STKWRH
   Endif
Endif
If [F:ITF]STOMGTCOD > 1                                                  # 58822
   If !clalev([F:ITV]) Local File ITMMVT    [ITV] Endif
   Local Integer WRET
   Local Integer WCUNCOD                                                              # hcb x3-83354
   WCUNCOD = [F:ITF]CUNCOD                                                            # hcb x3-83354
   Call LECITV([F:ITF]STOFCY,[F:ITF]ITMREF,"",WRET) From STKLIB
   If WRET < 2                                                                        # hcb x3-83354
      Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,[F:ITF]CREDAT,WCUNCOD) From STKINV  # hcb x3-83354
      Rewrite [ITV]                                                                   # hcb x3-83354
   Endif                                                                              # hcb x3-83354
Endif

#MAE, bg 68556
If GTRACE <> ""
    Call ECR_TRACE(mess(85,151,1)+" "+mess(157,100,1)+" "+mess(3,45,1)+" : "+LFCY,0) From GESECRAN
Endif


Return


#                                                               # hcb 71276 deb
#-------------------------------------------------------------
# creation ECCVAL ECCSTA
#-------------------------------------------------------------
$CRE_VERSION

Local Integer WRET
Local Integer WSTA
Local Char    WLASTECC(GLONECS)

# création ECCSTA  Statuts versions majeures
$CRE_ECCSTA
Raz WLASTECC
Raz [F:ECS]

Call CALCUL([F:ITM]ECCMAJ, WLASTECC, [F:ECS]ECCVALMAJ, GMESSAGE, WSTA) From SUBICV
If WSTA <> 0
   GOK      = 0
   Return
Endif
[F:ECS]ITMREF    = [F:ITM]ITMREF
[F:ECS]ECCSTA    = 4 : # ŕ activer
[F:ECS]EXNFLG    = 1
[F:ECS]SPSFLG    = 1
GPOINT = "CRE_ECCSTA" : Gosub ENTREE From EXEFNC
Write [ECS]
If fstat
   GOK=0 : Call FSTA("ECS") From GLOCK : Return
Endif

#If [F:ITM]ECCSTO = 2
#   Return
#Endif

# création ECCVAL  versions

$CRE_ECCVAL
Raz WLASTECC
Raz [F:EVL]

If [F:ITM]ECCSTO = 3
  Call CALCUL([F:ITM]ECCMIN,WLASTECC,[F:EVL]ECCVALMIN,GMESSAGE,WSTA) From SUBICV
  If WSTA <> 0
    GOK      = 0
    Return
  Endif
Endif

[F:EVL]ITMREF    = [F:ITM]ITMREF
[F:EVL]ECCSEQ    = 1
[F:EVL]ECCTYP    = 4 : # stock
[F:EVL]USESTA    = 2 : # exploitation
[F:EVL]ECCVALMAJ = [F:ECS]ECCVALMAJ
[F:EVL]EXNFLG    = 1
GPOINT = "CRE_ECCVAL" : Gosub ENTREE From EXEFNC
Write [EVL]
If fstat
   GOK=0 : Call FSTA("EVL") From GLOCK : Return
Endif

Return

#                                                               # hcb 71276 fin


# Issue 71276 - 2015-03-20 by SR : Versions
$ACL_ECSMGT
If dim(GFLTITM)>0 : GFLTITM = [M:ITM0]ITMREF : Endif
Return

$BCL_ECSMGT
If dim(GFLTITM)>0 : Raz GFLTITM : Endif
Filter [F:ECS]
If [F:ITM]ITMREF <> [M:ITM0]ITMREF
  Read [F:ITM]ITM0 = [M:ITM0]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
Raz [M:ITM2]ECCVALMAJ
Call STKINIECC([F:ITM]ITMREF,"","ITM2",1,1,0,2,"","ECCVALMAJ","ECCVALMIN","","",0,"") From STKACT
If [M:ITM2]ECCVALMAJ <> ""
   Read [ECS]ECS0=[F:ITM]ITMREF;[M:ITM2]ECCVALMAJ
   If fstat
      Raz [F:ECS]
   Endif
   [M:ITM2]ECCSTA = [F:ECS]ECCSTA
Endif
