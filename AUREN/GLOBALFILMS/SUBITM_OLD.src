Subprog AM_PURBASPRI(VALEUR)
Variable Decimal VALEUR
If [M:ITS]BASPRIORI = 2
  [M:ITS]BASPRI = VALEUR * (1 + [M:ITS]PURPRIPRC/100)
  [M:ITS]WMODPRI = 1
  Affzo [M:ITS]BASPRI
Endif
End


