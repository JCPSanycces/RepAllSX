#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes d‚j… saisies  #
#-----------------------------------------------------------------------#
# GBOXSD3 : livraison
# GBOXPR2 : preparation

Case currbox
 When GBOXSD3 : For I=0 To [M:PKD1]NBLIG-1
                    # Ligne issue d'un picking colis
                    Read [SDD]SDD0=[M:PKD0]VCRNUM;[M:PKD1]VCRLIN(I)
                    If    WPICK=1 Gosub DEPICK From GSAISIE
                    Elsif WPICK=2
                        #  If [F:SDD]QTYSTU = [F:SDD]PACQTYSTU    # hcb 95402
                             Gosub REPICK From GSAISIE
                        #  Endif                                  # hcb 95402
                    Endif
                Next I
#                                                                 # hcb 110327 deb
                If [F:SDH]SDHNUM <> [M:PKD0]VCRNUM
                   Read [SDH]SDH0 = [M:PKD0]VCRNUM
                   If fstat
                      Raz [F:SDH]
                   Endif
                Endif
#                                                                 # hcb 110327 fin
 When GBOXPR2 : For I=0 To [M:PKD1]NBLIG-1
                    # Ligne issue d'un picking colis
                    Read [PRE]PRE0=[M:PKD0]VCRNUM;[M:PKD1]VCRLIN(I)
                    If    WPICK=1 Gosub DEPICK From GSAISIE
                    Elsif WPICK=2
                         # If [F:PRE]QTYSTU = [F:PRE]PACQTYSTU     # hcb 104087 2
                              Gosub REPICK From GSAISIE
                         # Endif                                   # hcb 104087 2
                    Endif
                Next I
#                                                                 # hcb 110327 deb
                If [F:PRH]PRHNUM <> [M:PKD0]VCRNUM
                   Read [PRH]PRH0 = [M:PKD0]VCRNUM
                   If fstat
                      Raz [F:PRH]
                   Endif
                Endif
#                                                                 # hcb 110327 fin

 When Default
Endcase
Return

Subprog APRES_NBLIG
Gosub TOT_GROWEI From FUNPKD
End

Subprog C_NBLIG
Local Integer I
# --> Suppression de lignes interdites si le colis n est pas créé
If find(status,65,68,83) & [M:PKD1]PACNUM = ""      # hcb 107548/X3-38236
   mkstat= 2
   End
Endif
If find(status,65,68,83)
   GSUPLIG = status
Else
   Raz GSUPLIG
Endif
# annulation d une ligne
If status=65
   [M:PKD1]NETWEI (nolign-1) = 0
   [M:PKD1]QTY    (nolign-1) = 0
   If [M:PKD1]PACFLG(nolign-1) = 2
      Gosub ENR_COLISAGE
      [M:PKD0]PACNBR = LPACNBR
      Affzo [M:PKD0]PACNBR
      If LPACNBR = 0
         Raz [M:PKD1]PACNUM
         Affzo [M:PKD1]PACNUM
         Actzo [M:PKD1]PACNUM
      Endif
   Endif
  Gosub TOT_GROWEI From FUNPKD
Endif

# annulation d'un groupe de lignes impossible   # hcb 60766
#If find(status,68,83)
#   For I=nolign-1 To nolign1-1
#       [M:PKD1]NETWEI (nolign-1) = 0
#       [M:PKD1]QTY    (nolign-1) = 0
#   Next
#   Gosub TOT_GROWEI From FUNPKD
#Endif

End


Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""  &  [F:TPA]PCK <> VALEUR
   Read [TPA]TPA0=VALEUR
   If fstat
      Raz [F:TPA]
   Endif
Endif

[M:PKD1]       = [F:TPA]
If GVCRTYP = 4 & [F:TPA]LBLFMT = ""
   [M:PKD1]LBLFMT = GDOCNAM
Endif

# recalcul du poids des lignes
If [M:PKD1]NBLIG <> 0
   Gosub CAL_NETWEI From FUNPKD
Endif


Affzo [M:PKD1]10

Gosub TOT_GROWEI From FUNPKD

End

Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
If VALEUR  > [M:PKD1]QTYPCU(nolign-1)
   mkstat = 2
   End
Endif
End
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local Char     WSERNUM (GLONSER)                           # hcb 110327-pck
Local Char     WSERNUMF(GLONSER)                           # hcb 110327-pck
Local Integer  LRET                                        # hcb 110327-pck
[M:PKD1]QTYSTU(nolign-1) = VALEUR * [M:PKD1]PCUSTUCOE(nolign-1)
Call QTEARR([M:PKD1]QTYSTU(nolign-1), [F:ITM]STU) From TRTDIV
[M:PKD1]NETWEI   (nolign-1) = [M:PKD1]QTYSTU(nolign-1)  *  [M:PKD1]UNTWEI   (nolign-1)
Call QTEARR([M:PKD1]NETWEI(nolign-1), [M:PKD1]LIGWEU(nolign-1)) From TRTDIV                               # hcb 119241

[M:PKD1]NETWEIPCK(nolign-1) = [M:PKD1]QTYSTU(nolign-1)  *  [M:PKD1]LIGUNTWEI(nolign-1)
Call QTEARR([M:PKD1]NETWEIPCK(nolign-1), [M:PKD1]LIGWEU(nolign-1)) From TRTDIV                            # hcb 119241

Affzo [M:PKD1]NETWEI(nolign-1)

Affzo [M:PKD1]QTYSTU(nolign-1)

#                                                                              # hcb 110327-pck deb
#      si g‚r‚ en serie global et colisage d‚tail serie … oui
#      si la quantit‚ trait‚e et differente de la quantit‚ … coliser
#      uniquement en creation de colis et que la quantit‚ trait‚e saisie soit inf‚rieure … la quantit‚ trait‚e initiale
#      et que le no serie debut = no serie debut de la ligne de document origine : recalcul du no serie fin
 If [M:PKD1]SERMGTCOD (nolign-1) = 4 & [M:PKD1]PCKSERFLG (nolign-1) = 2
     If [M:PKD1]QTYINI (nolign-1) = [M:PKD1]QTYPCU (nolign-1) &  [M:PKD1]SERNUM (nolign-1) = [M:PKD1]SERORIDEB (nolign-1)
         WSERNUM = [M:PKD1]SERNUM (nolign-1)
         Call PLUS_NB(WSERNUM,abs(VALEUR),WSERNUMF,LRET) From STKLIB
         [M:PKD1]SERFIN(nolign-1) = WSERNUMF
         Affzo [M:PKD1]SERFIN(nolign-1)
     Else
         Raz   [M:PKD1]SERNUM(nolign-1)
         Raz   [M:PKD1]SERFIN(nolign-1)
         Affzo [M:PKD1]SERNUM(nolign-1)
         Affzo [M:PKD1]SERFIN(nolign-1)
     Endif
Endif
#                                                                              # hcb 110327-pck fin

End

Subprog C_GROWEI(VALEUR)
Variable Decimal VALEUR
If VALEUR < (sum([M:PKD1]NETWEIPCK(0..max([M:PKD1]NBLIG-1,nolign-1))) +  [M:PKD1]PCKWEI)
   mkstat = 2
   End
Endif
End


Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
# mis en commentaire car en reaffichage de colis on ne sait pas determiner le manquant
#     sinon   mettre un code dans SPACKD ou relire STOALL ....
# si manquant = > vert

pcolor=GCOUL(0)              # hcb 62874

If [M:PKD1]WSTOCOU  (nolign-1) = 1  &
&  [M:PKD1]STOMGTCOD(nolign-1) > 1  &
&  [M:PKD1]PCKSTKFLG(nolign-1) = 2  &
&  [M:PKD1]ITMREF(nolign-1) <> ""
   pcolor=GCOUL(2)
Else
   pcolor=GCOUL(0)
Endif

Gosub PKDCOLOR                # hcb 62874

End


Subprog AM_PACNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
Raz WOK

Read [SPH]SPH0=[M:PKD0]VCRTYP;[M:PKD0]VCRNUM;VALEUR;1
If fstat
   GMESSAGE =mess(270,184,1)  # Num‚ro de colis inexistant!
   mkstat = 2
   End
Endif
If [F:SPH]PCK  <> ""  &  [F:TPA]PCK <> [F:SPH]PCK
   Read [TPA]TPA0=[F:SPH]PCK
   If fstat
      Raz [F:TPA]
   Endif
Endif
Gosub DEB_PIC      From FUNPKD
If [F:SPH]PACNUM <> ""
   Gosub CHARGE_COLIS From FUNPKD
   GSAIPACNUM = 1   # pour rafraichissement picking
Endif
End

########################################################################
# codification des nø colis norme SSCC (Serial Shipping Container Code)
# numero colis = WPACNUM
#-----------------------------------------------------------------------
#            E : LFCY   = Nom du site
#                LITM   = R‚f‚rence article
#            S : LNUM   = Num‚ro colis
#              : LRET   = Code Erreur
########################################################################
Subprog NUMERO_SSCC(LFCY,LITM,LNUM,LRET)
Value    Char     LFCY
Value    Char     LITM
Variable Char     LNUM
Variable Integer  LRET

Local Char WVCRNUM(10)
Local Integer WVALEUR
Local Integer I  # nombre de chiffre
Local Integer P  # position
Local Integer WCLE
Raz LRET

# si la racine est non renseign‚ alors pas de gestion du code SSCC
If GSSCCROOT = ""
   End
Endif
If GSSCCCOU = ""
   End
Endif

# calcul  numero s‚quentiel 7/10chiffres
Call NUMERO(GSSCCCOU,LFCY,date$,LITM,WVCRNUM,LRET) From SUBANM
If LRET = 1
   Call ERREUR(mess(939,196,1)) From GESECRAN    # Compteur SSCC absent ! v‚rifiez le parametre GSSCCCOU
   Return
Endif
If LRET = 2
   Call ERREUR(mess(30,196,1)) From GESECRAN
   Return
Endif

LNUM = GSSCCROOT     # racine
LNUM += WVCRNUM      # numero sequentiel
I = len(LNUM)

# hcb correction calcul demande 68050

# somme position impaire *3
For P = 1 To I Step 2
    WVALEUR += val(mid$(LNUM,P,1))
Next P
WVALEUR = WVALEUR * 3

# somme position pair
For P = 2 To I Step 2
    WVALEUR += val(mid$(LNUM,P,1))
Next P

If mod(WVALEUR,10) = 0
   WCLE = 0
Else
   WCLE = 10 - mod(WVALEUR,10)
Endif

LNUM += num$(WCLE)
If len(LNUM) <> 18
   Raz LNUM
   LRET = 3
   Call ERREUR(mess(272,184,1)) From GESECRAN
Endif

End

########################################################################
# codification des nø colis num‚ro interne
# numero colis = lnum
#-----------------------------------------------------------------------
#            E : LFCY   = Nom du site
#                LDAT   = Date du jour
#            S : LNUM   = Num‚ro colis
Subprog NUM_PAC(LFCY,LDAT,LNUM)
Variable Char    LFCY
Variable Date    LDAT
Variable Char    LNUM
Local    Integer VS
Raz GPE
# hcb 62840
GPOINT = "NUM_PAC"
Gosub  ENTREE From EXEFNC
If GPE = 0
   Call NUMERO(GSTKCPT(24),LFCY,LDAT,"",LNUM,VS) From SUBANM
   If VS = 1
      LNUM = ""
   Endif
Endif
End

########################################################################
# Mise … jour document suite … enregistrement ou suppression d colisage
# numero colis = WPACNUM
#-----------------------------------------------------------------------
#            E : LFCY    = Nom du site
#                LTYP    = Type document
#                LNUM    = Num‚ro document
#                LOPT    = Option
#            S : LPACNBR = nombre de colis
#            S : LPACFLG = Flag colisage 2 = document entierement colise
#            S : LNETWEI = poids net du document
#            S : LGROWEI = poids brut du document
#            S : LWEU    = Unit‚ poids du document (preparation)
#            S : LVOL    = volume du document
#            S : LVOU    = Unite de volume du document si non renseign‚
#              : LRET    = Code Erreur
########################################################################

Subprog COLISAGE_ORIGINE(LFCY,LTYP,LNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,LOPT,LRET)
Value    Char     LFCY
Value    Integer  LTYP
Variable Char     LNUM
Variable Integer  LPACNBR
Variable Integer  LPACFLG
Variable Decimal  LNETWEI
Variable Decimal  LGROWEI
Variable Char     LWEU
Variable Decimal  LVOL
Variable Char     LVOU
Value    Integer  LOPT

Variable Integer  LRET

Local Char    WPACNUM
Local Integer WVCRLIN
Local Decimal WQTYSTU   # hcb 71375
Local Decimal WVOL
Local Decimal WPCKWEI
Local Decimal WNETWEI
Raz WPACNUM
Raz WVCRLIN
Raz WQTYSTU
Raz WVOL
Raz WPCKWEI
Raz WNETWEI

Raz LPACNBR
# calcul nombre de colis
Filter [SPD] Where STOFCY = LFCY & VCRTYP = LTYP & VCRNUM = LNUM
&      Order By Key CLE = STOFCY;VCRTYP;VCRNUM;PACNUM
Columns [SPD] (PACNUM)
For [SPD]
    If WPACNUM <> [F:SPD]PACNUM
       WPACNUM =  [F:SPD]PACNUM
       LPACNBR += 1
    Endif
Next
Filter  [SPD]
Columns [SPD]

# calcul et maj qte colis‚ par ligne


# m a j quantit‚ colis‚e sur ligne detail
If LOPT = 0
   If LTYP = 4
      Filter [SDD] Where SDHNUM = LNUM & [F:SDD]PCKFLG = 2
      For [SDD]
          Readlock [SDD] Curr
          If fstat
             LRET = 1
             Call FSTA("SDD") From GLOCK
             Break
          Endif
          Raz WQTYSTU
          Filter [SPD] Where STOFCY = LFCY & VCRTYP = LTYP & VCRNUM = LNUM & VCRLIN = [F:SDD]SDDLIN
&                Order By Key CLE = STOFCY;VCRTYP;VCRNUM;VCRLIN
                 Columns [SPD] (VCRNUM, VCRLIN, QTYPCU, PCUSTUCOE,PCU)   # hcb 100874

          For [SPD]
#               WQTYSTU +=  [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE          # hcb x3-70246
               WQTYSTU +=  [F:SPD]QTYPCU                              # hcb x3-70246
#               Call QTEARR(WQTYSTU, [F:SPD]PCU) From TRTDIV          # hcb x3-70246
          Next
          Filter  [SPD]
          Columns [SPD]
          [F:SDD]PACQTYSTU = WQTYSTU
          Rewrite [SDD]
      Next
      Filter [SDD]
   Else
      Filter [PRE] Where PRHNUM = LNUM & [F:PRE]PCKFLG = 2
      For [PRE]
          Readlock [PRE] Curr
          If fstat
             LRET = 1
             Call FSTA("PRE") From GLOCK
             Break
          Endif
          Raz WQTYSTU
          Filter [SPD] Where STOFCY = LFCY & VCRTYP = LTYP & VCRNUM = LNUM & VCRLIN = [F:PRE]PRELIN
&                Order By Key CLE = STOFCY;VCRTYP;VCRNUM;VCRLIN
                 Columns [SPD] (VCRNUM, VCRLIN, QTYPCU, PCUSTUCOE)

          For [SPD]
               WQTYSTU +=  [F:SPD]QTYPCU                        # hcb X3-131897
 #             WQTYSTU +=  [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE    # hcb X3-131897
               Call QTEARR(WQTYSTU, [F:PRE]STU) From TRTDIV    # hcb 77324
          Next
          Filter  [SPD]
          Columns [SPD]
          [F:PRE]PACQTYSTU = WQTYSTU
          Rewrite [PRE]
      Next
      Filter [PRE]
   Endif
Endif
If LRET = 1
   End
Endif
# recherche si ligne non colis‚e completement
# Point d'entr‚e CRITPACFLG : (Hcb demande 63350)
Local Char CRITPACFLG(250)
Raz CRITPACFLG

Local Char CRITSPHFLG(250)    # hcb 92216
Raz CRITSPHFLG                # hcb 92216


GPOINT = "CRITPACFLG" : Gosub ENTREE From EXEFNC
If CRITPACFLG = ""
   CRITPACFLG = "1=1"
Endif

If CRITSPHFLG = ""            # hcb 92216
   CRITSPHFLG = "1=1"         # hcb 92216
Endif


LPACFLG = 1
If LTYP = 4
   Filter [SDD] Where SDHNUM = LNUM & QTYSTU > PACQTYSTU & PCKFLG = 2 & evalue(CRITPACFLG)     # hcb 68230
   Look [SDD]SDD0 First
   Filter [SDD]
   If fstat
      LPACFLG = 2
   Endif
Else
   Filter [PRE] Where PRHNUM = LNUM & QTYSTU > PACQTYSTU & PCKFLG = 2 & evalue(CRITPACFLG)     # hcb 68230
   Look [PRE]PRE0 First
   Filter [PRE]
   If fstat
      LPACFLG = 2
   Endif
Endif


# calcul poids net , brut et volume du document
Local Integer CGROWEI   # hcb 68230
Local Integer CVOL      # hcb 68230
Raz   CGROWEI           # hcb 68230
Raz   CVOL              # hcb 68230
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
If LTYP = 4
   If [F:SDH]SDHNUM  <>  LNUM
      Read [SDH]SDH0 =   LNUM
      If fstat
         Raz [F:SDH]
         LRET = 1
         End
      Endif
   Endif
   If LPACFLG = 2       # colisage complet calcul des poids selon le colisage
      #FJCG - Inicio - AURENV12
      If GTRACE<>""
      Call ECR_TRACE(" If LPACFLG: "+num$(LPACFLG),0) From GESECRAN
      Endif
      #FJCG - Fin - AURENV12
      Raz   CGROWEI           # hcb 68230
      Raz   CVOL              # hcb 68230
# hcb 92216  rajout :  & evalue(CRITSPHFLG)

      Filter [SPH] Where  VCRTYP   = LTYP  &
&                         VCRNUM   = LNUM  & evalue(CRITSPHFLG)
&                  Order By Key SPH0
      For [SPH]
# Incr‚mentation poids net et brut de la livraison
          If [F:SPH]WEU    <> "" & [F:SDH]WEU <> ""
             If [F:SPH]WEU  = [F:SDH]WEU
                LNETWEI    += [F:SPH]NETWEI
                LGROWEI    += [F:SPH]NETWEI  + [F:SPH]PCKWEI
             Else
      # Conversion poids unitaire de unit‚ poids colis en unit‚ poids entˆte liv
                WNETWEI  = [F:SPH]NETWEI       # hcb 68230
                Call SCONV_TCO([F:SPH]WEU,[F:SDH]WEU,WNETWEI) From TRTVENQTE
                LNETWEI += WNETWEI
                WPCKWEI  = [F:SPH]PCKWEI
                Call SCONV_TCO([F:SPH]WEU,[F:SDH]WEU,WPCKWEI) From TRTVENQTE
                If [F:SPH]PCKWEI <> 0 & WPCKWEI = 0   # hcb 68230
                   CGROWEI = 9                        # hcb 68230
                Endif                                 # hcb 68230
                LGROWEI += WNETWEI + WPCKWEI
             Endif
          Endif
# Incr‚mentation volume de la livraison
          If [F:SPH]VOU <> ""
             If [F:SDH]VOU = ""
                [F:SDH]VOU = [F:SPH]VOU
                LVOU       = [F:SPH]VOU
             Endif
             If [F:SPH]VOU =    [F:SDH]VOU
                LVOL += [F:SPH]VOL
                #FJCG - Inicio - AURENV12
                If GTRACE<>""
                Call ECR_TRACE(" Suma volumen if. Vol.: "+num$(LVOL)+" Un.vol.: "+[F:SDH]VOU+"-"+[F:SPH]VOU,0) From GESECRAN
                Endif
                #FJCG - Fin - AURENV12
             Else
      # Conversion volume colis en unit‚ volume entˆte liv
                If [F:TPA]PCK <> [F:SPH]PCK                   # hcb 68230 deb
                   Read [TPA]TPA0=[F:SPH]PCK
                   If fstat
                      Raz [F:TPA]
                   Endif
                Endif
                WVOL = [F:TPA]VOL                             # hcb 68230 fin
                Call SCONV_TCO([F:SPH]VOU,[F:SDH]VOU,WVOL) From TRTVENQTE
                If [F:TPA]VOL <> 0 & WVOL = 0   # hcb 68230
                   CVOL = 9                     # hcb 68230
                Endif                           # hcb 68230
                LVOL += WVOL
                #FJCG - Inicio - AURENV12
                If GTRACE<>""
                Call ECR_TRACE(" Suma volumen else. Vol.: "+num$(LVOL),0) From GESECRAN
                Endif
                #FJCG - Fin - AURENV12
             Endif
          Endif
      Next
      Filter [SPH]
      #FJCG - Inicio - AURENV12
      If GTRACE<>""
      Call ECR_TRACE(" Fin bucle [SPH]. Vol.: "+num$(LVOL),0) From GESECRAN
      Endif
      #FJCG - Fin - AURENV12

   Else                # colisage non complet calcul des poids selon les lignes de livraison (theorique)
      #FJCG - Inicio - AURENV12
      If GTRACE<>""
      Call ECR_TRACE(" else LPACFLG: "+num$(LPACFLG),0) From GESECRAN
      Endif
      #FJCG - Fin - AURENV12
      Filter [SDD] Where  SDHNUM = LNUM & PCKFLG = 2
&                  Order By Key SDD0
      For [SDD]
# Incr‚mentation poids net et brut de la livraison
          If [F:SDD]WEU    <> "" & [F:SDH]WEU <> ""
             If [F:SDD]WEU  = [F:SDH]WEU
                LNETWEI    += [F:SDD]UNTWEI * [F:SDD]QTY
                LGROWEI    =  LNETWEI
             Else
      # Conversion poids unitaire de unit‚ poids colis en unit‚ poids entˆte liv
                Call SCONV_TCO([F:SDD]WEU,[F:SDH]WEU,WNETWEI) From TRTVENQTE
                LNETWEI += WNETWEI * [F:SDD]QTY
                LGROWEI =  LNETWEI
             Endif
          Endif
      Next
      Filter [SDD]
   Endif


Else
   If [F:PRH]PRHNUM  <>  LNUM
      Read [PRH]PRH0 =   LNUM
      If fstat
         Raz [F:PRH]
         LRET = 1
         End
      Endif
   Endif
   LWEU = [F:PRH]WEU
   If LPACFLG = 2       # colisage complet calcul des poids selon le colisage
      Raz   CGROWEI           # hcb 68230
      Raz   CVOL              # hcb 68230
# hcb 92216  rajout :  & evalue(CRITSPHFLG)

      Filter [SPH] Where  VCRTYP   = LTYP  &
&                         VCRNUM   = LNUM  & evalue(CRITSPHFLG)
&                  Order By Key SPH0
      For [SPH]
# Incr‚mentation poids net et brut de la preparation
          If LWEU = ""
             LWEU = [F:SPH]WEU
          Endif
          If [F:SPH]WEU    <> ""
             If [F:SPH]WEU  = LWEU
                LNETWEI    += [F:SPH]NETWEI
                LGROWEI    += [F:SPH]NETWEI  + [F:SPH]PCKWEI
             Else
      # Conversion poids unitaire de unit‚ poids colis en unit‚ poids entˆte liv
                WNETWEI    += [F:SPH]NETWEI                                # hcb 68230
                Call SCONV_TCO([F:SPH]WEU,LWEU,WNETWEI) From TRTVENQTE
                LNETWEI += WNETWEI
                WPCKWEI  = [F:SPH]PCKWEI
                Call SCONV_TCO([F:SPH]WEU,LWEU,WPCKWEI) From TRTVENQTE
                If [F:SPH]PCKWEI <> 0 & WPCKWEI = 0   # hcb 68230
                   CGROWEI = 9                        # hcb 68230
                Endif                                 # hcb 68230
                LGROWEI += WNETWEI + WPCKWEI
             Endif
          Endif
      Next
      Filter [SPH]
   Endif
Endif

# hcb 68230 deb
If CVOL = 9
   Raz LVOL
Endif
If CGROWEI = 9
   Raz LNETWEI
   Raz LGROWEI
Endif
# hcb 68230 end


End

Subprog IB_VCRNUM
# Suppression colisage du document
GBOUT2 = mess(291,184,1)

If GVCRTYP = 4
   If [F:SDH]PACNBR = 0
      GBOUT2 = ""
   Endif
Else
   If [F:PRH]PACNBR = 0
      GBOUT2 = ""
   Endif
Endif
If GCONSULT = 2
   GBOUT2 = ""
Endif
End

Subprog B1_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Char NUM
GCONSULT = 2
Case [M:PKD0]VCRTYP
When 3       # preparation
      NUM = num$([M:PKD0]VCRTYP)
      Call OBJET("PRH",[M:PKD0]VCRNUM,NUM) From GOBJET
When 4       # livraison
      Call OBJET("SDH",[M:PKD0]VCRNUM,NUM) From GOBJET
Endcase
GCONSULT = 0

End



Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
Call OUINON(mess(275,184,1),WOK) From GESECRAN
If WOK <> 2
   End
Endif


[M:PKD1]PACNUM = ""
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]

Gosub ANU_COLISAGE
If GOK = 1
   GANU_COLISAGE = 1
   Commit
Endif
Raz [M:PKD1]
[M:PKD0]PACNBR = 0
Affzo [M:PKD0]PACNBR
[M:PKD1]BPTNUM = [M:PKD0]BPTNUM
[M:PKD1]BPTSHO = [M:PKD0]BPTSHO
If GVCRTYP = 4
   [M:PKD1]LBLFMT = GDOCNAM
Endif
Affzo [M:PKD1]

End


Subprog AS_NETWEI(VALEUR)
Variable Decimal VALEUR
If [M:PKD1]LIGWEU(nolign-1) = ""
   mkstat = 2
Endif
End

Subprog AM_NETWEI(VALEUR)
Variable Decimal VALEUR

#                                              hcb 93364 deb
GWUNTWEI = VALEUR
If [M:PKD1]LIGWEU(nolign-1) <> [M:PKD1]GROWEU   # hcb 102756
   Call SCONV_TCO([M:PKD1]LIGWEU(nolign-1),[M:PKD1]GROWEU,GWUNTWEI) From TRTVENQTE
Endif                                           # hcb 102756
[M:PKD1]NETWEIPCK(nolign-1) =  GWUNTWEI
#                                              hcb 93364 fin

End

#                                                                     # hcb 110327-pck deb
Subprog IB_NBLIG
# No s‚rie … coliser
GBOUT1 = mess(663,199,1)

# l article ne gŠre pas les s‚ries "globale"  pas de saisie des num‚ros de s‚ries
If [M:PKD1]PCKSERFLG(nolign-1)  <> 2 | [M:PKD1]QTY(nolign-1) = 0
   GBOUT1 = ""
Endif
End
#                                                                     # hcb 110327-pck fin
#                                                                     # hcb 110327-pck deb bug

Subprog AS_PCK(VALEUR)
Variable Char    VALEUR()
If [M:PKD1]PACNUM <> ""
   mkstat = 2
Endif
End
#                                                                     # hcb 110327-pck fin bug


