#<AdxTL>@(#)0.0.0.0 $Revision$ Colisage déclaratif
##################################################################################
#    GESTION DU COLISAGE                                                         #
#--------------------------------------------------------------------------------#
#  - Traitement        : FUNPKD                                                  #
#  - Action            : TRTPPKD    (Trt standard)                               #
#                        SAIPKD     (Saisie fenˆtre)                             #
#  Dans le cas d appel depuis un document (Livraison  / pr‚paration ..)          #
#       alimenter la global GPKGTYP dans le traitement du document            #
#       afin de g‚rer la s‚lection des transactions colisage                     #
#       filtr‚e sur le type le cas ‚ch‚ant                                       #
#################################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions li‚es au traitement standard
Case ACTION
 When "INIT"        : Case GACTION
                       When "TRTPKD" : Gosub INIT_TRTPKD
                      Endcase
 When "INIT_DIA"    : Case GACTION
                       When "TRTPKD" : Gosub INIT_DIA_TRTPKD
                      Endcase
 When "TERMINE"     : Case GACTION
                       When "TRTPKD" : Gosub TERMINE_TRTPKD
                      Endcase
 When Default
Endcase

#--- Actions li‚es … la fenˆtre de saisie
Case ACTION

 When "OUVRE"       : Case GACTION
                       When "TRTPKD", "SAIPKD" : Gosub OUVRE_TRTPKD
                      Endcase
 When "OUVRE_BOITE"  : Case GACTION
                       When "TRTPKD", "SAIPKD" : Gosub OUVRE_BOITE_TRTPKD
                      Endcase
 When "TITRE"        : Case GACTION
                       When "TRTPKD", "SAIPKD" : Gosub TITRE_TRTPKD
                      Endcase


 When "SETBOUT"     : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub SETBOUT_TRTPKD
                      Endcase
 When "DEBUT"       : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub DEBUT_TRTPKD
                      Endcase
 When "AP_CHOIX"    : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AP_CHOIX_TRTPKD
                      Endcase
 When "APRES_MODIF" : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub APRES_MODIF
                      Endcase
 When "AVANT_ENR"   : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AVANT_ENR_TRTPKD
                      Endcase
 When "ENR"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub ENR_TRTPKD
                      Endcase
 When "SUP"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub SUP_TRTPKD
                      Endcase
 When "AVANT_FIR"   : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AVANT_PREMIER_TRTPKD
                      Endcase
 When "FIR"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub PREMIER_TRTPKD
                      Endcase
 When "AVANT_LAS"   : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AVANT_DERNIER_TRTPKD
                      Endcase
 When "LAS"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub DERNIER_TRTPKD
                      Endcase
 When "AVANT_SUI"   : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AVANT_SUI_TRTPKD
                      Endcase

 When "SUI"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub SUI_TRTPKD
                      Endcase
 When "AVANT_PRE"   : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub AVANT_PRE_TRTPKD
                      Endcase
 When "PRE"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub PRE_TRTPKD
                      Endcase
 When "MEN"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub MEN_TRTPKD
                      Endcase
 When "NEW"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub NEW_TRTPKD
                      Endcase
 When "FIN"         : Case GACTION
                           When "TRTPKD", "SAIPKD" : Gosub FIN_TRTPKD
                      Endcase
 When "ABA"          : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub ABA_TRTPKD
                      Endcase

 When "FINSAI"      : Case GACTION
                      Endcase


 When "GAU"          : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub GAUCHE
                      Endcase
 When "AP_FILGAUCHE"    : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub AP_FILGAUCHE
                      Endcase
 When "FILGAUCHE"    : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub FILGAUCHE
                      Endcase
 When "DEB_PIC"       : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub DEB_PIC
                      Endcase
 When "CRE_PIC"       : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub CRE_PIC
                      Endcase
 When "FIN_PIC"     : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub FIN_PIC
                      Endcase
 When "ANU_PIC"       : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub ANU_PIC
                      Endcase
 When "TIR"           : Case GACTION
                            When "TRTPKD", "SAIPKD" : WAFFPICK=1
                      Endcase
 When "HINT"           : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub HINT_KEY
                      Endcase
 When "RAF"           : Case GACTION
                            When "TRTPKD", "SAIPKD" : Gosub GAUCHE
                      Endcase

Endcase

#--- Actions li‚es au traitement divers
Case ACTION
 When "TRT_DIV"     : Case TRAIT
                       When "PKDCOLOR"   : Gosub PKDCOLOR            # hcb 62874
                      Endcase
 When Default
Endcase

Return

$HINT_KEY
Return


#########################################################################
# D‚tail des actions li‚es au picking                                   #
#########################################################################
$TITRE_TRTPKD
# R‚cup‚ration des noms de currbox des tiroirs
Global Char  GBOXSD3(10),GBOXPR2(10),GBOXSP1(10)
GBOXSD3 = "GAU_CHE"+num$(find("SD3",OBJLIS(1..8)))
GBOXPR2 = "GAU_CHE"+num$(find("PR2",OBJLIS(1..8)))
GBOXSP1 = "GAU_CHE"+num$(find("SP1",OBJLIS(1..8)))
Call LECTEXTRA(TIT,"STKTRS","DESAXX","11",GPKDNUM) From ATEXTRA
If !clalev([F:AWI]) : Local File AWINDOW : Endif
Read [AWI]AWI0=BOITE
Call TEXTE([F:AWI]DES,GBIDC3) From OBJDIV
TIT = GBIDC3-GPKDNUM-":"-TIT
Return

Return

# selection browser selection colis
$GAUCHE
If currbox= GBOXSP1 | ACTION = "RAF"
      If [M:PKD1]PACNUM <> "" & GMODPAC = 1
         Call ERREUR(mess(273,184,1)) From GESECRAN    # un colis est deja charg‚ !
         Return
      Endif
      Read [SPH]SPH0=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM;1
      If fstat
         Raz [F:SPH]
         Return
      Endif
      If [F:SPH]PCK  <> ""  &  [F:TPA]PCK <> [F:SPH]PCK
         Read [TPA]TPA0=[F:SPH]PCK
         If fstat
            Raz [F:TPA]
         Endif
      Endif
      Gosub DEB_PIC      From FUNPKD
      Gosub CHARGE_COLIS From FUNPKD
Endif

Return

$AP_FILGAUCHE
WPICK=2
Gosub RAFFRAICHI

Return


$FILGAUCHE

Case currbox
 When GBOXSD3 : Gosub FILGAUCHE_LIV
 When GBOXPR2 : Gosub FILGAUCHE_PRE
 When GBOXSP1 : Gosub FILGAUCHE_SPH
 When Default : Return
Endcase
Return

$FILGAUCHE_LIV
Raz FILGAUSUP(1)
If GVCRTYP = 4
   If GRAPPAC  = 0
      FILGAUSUP(0)='[F:SDD]SDHNUM=[M:PKD0]VCRNUM & [F:SDD]PACQTYSTU <> [F:SDD]QTYSTU & [F:SDD]PCKFLG = 2'
    Else
      FILGAUSUP(0)='[F:SDD]SDHNUM=[M:PKD0]VCRNUM & [F:SDD]PCKFLG = 2'
   Endif
   If GPCKFLT = 2 & [M:PKD1]PCK <> ""
      FILGAUSUP(0) = FILGAUSUP(0) + '& ([F:SDD]PCK = [M:PKD1]PCK | [F:SDD]PCK = "")'
   Endif

Else
   FILGAUSUP(0)='[F:SDD]SDHNUM= "###############"'
Endif

Return

$FILGAUCHE_PRE

Raz FILGAUSUP(1)
If GVCRTYP = 3
   If GRAPPAC  = 0
      FILGAUSUP(0)='[F:PRE]PRHNUM=[M:PKD0]VCRNUM & [F:PRE]PACQTYSTU <> [F:PRE]QTYSTU & [F:PRE]PCKFLG = 2'
    Else
      FILGAUSUP(0)='[F:PRE]PRHNUM=[M:PKD0]VCRNUM & [F:PRE]PCKFLG = 2'
   Endif
   If GPCKFLT = 2 & [M:PKD1]PCK <> ""
      FILGAUSUP(0) = FILGAUSUP(0) + '& ([F:PRE]PCK = [M:PKD1]PCK | [F:PRE]PCK = "")'
   Endif

Else
   FILGAUSUP(0)='[F:PRE]PRHNUM= "###############"'
Endif

Return

$FILGAUCHE_SPH
Raz FILGAUSUP(1)
FILGAUSUP(0)='[F:SPH]VCRNUM=[M:PKD0]VCRNUM & [F:SPH]VCRTYP=GVCRTYP'

Return

$DEB_PIC
Local Char    WNUM
Local Integer WLIN
Local Integer WTYP
Local Char    WFCY
Local Char    WFILSTA(20)
Local Char    AGR_RUPTURE(130)
Local Char    AGR_LECTURE(130)
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WSER(GLONSER)
Local Char    WPAL(GLONPAL)
Local Char    WCTR(GLONCTR)
Local Char    WITM
Local Integer I
Local Integer WI

Return

$TIROIR


ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
If WAFFPICK<>0
   WPICK=2
   Gosub RAFFRAICHI
Endif

Return

$CRE_PIC
Raz AGR_RUPTURE
Raz AGR_LECTURE
Raz WLOT
Raz WSLO
Raz WSER
Raz WPAL
Raz WCTR
Raz WITM
Raz WFILSTA

If GVCRTYP = 4
   Read [SDD]SDD0=[F:SDD]SDHNUM;[F:SDD]SDDLIN
   If fstat
      Call RSTA ("SDD",[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK
      FOK=0
      Return
   Endif
   If [F:SDD]PACQTYSTU >= [F:SDD]QTYSTU
      GMESSAGE = mess(266,184,1)   # ligne entierement colis‚ !
      FOK  = 0
      GERR = 1
      Return
   Endif
Else
   Read [PRE]PRE0=[F:PRE]PRHNUM;[F:PRE]PRELIN
   If fstat
      Call RSTA ("PRE",[F:PRE]PRHNUM-num$([F:PRE]PRELIN)) From GLOCK
      FOK=0
      Return
   Endif
   If [F:PRE]PACQTYSTU >= [F:PRE]QTYSTU
      GMESSAGE = mess(266,184,1)   # ligne entierement colis‚ !
      FOK  = 0
      GERR = 1
      Return
   Endif
Endif


#                                                       # hcb 104087 2 deb
If GPCKFLT = 2 & [M:PKD1]NBLIG = 0 &  [M:PKD1]PCK = ""
   If GVCRTYP = 4
      If [F:SDD]PCK <> "" &  [M:PKD1]PCK = ""
         [M:PKD1]PCK    =  [F:SDD]PCK
         [M:PKD1]VCRLIN(0) = [F:SDD]SDDLIN
         [M:PKD0]VCRNUM    = [F:SDD]SDHNUM
      Endif
   Else
      If [F:PRE]PCK <> "" &  [M:PKD1]PCK = ""
         [M:PKD1]PCK    =  [F:PRE]PCK
         [M:PKD1]VCRLIN(0) = [F:PRE]PRELIN
         [M:PKD0]VCRNUM    = [F:PRE]PRHNUM
      Endif
   Endif
   WPICK    = 2
   WAFFPICK = 1
   [M:PKD1]NBLIG = 1
   Gosub TIROIR From FUNPKD
   Raz [M:PKD1]NBLIG
   Raz [M:PKD1]PCK
   Raz [M:PKD1]PCKCAP
Endif
#                                                       # hcb 104087 2 fin





Gosub CHARGE_COLIS_DETAIL
Return

$CHARGE_COLIS_DETAIL

# si code SCCCOD non renseign‚ initialisation par la racine si pas d identifiant compteur
#If [M:PKD1]SCCCOD = "" & GSSCCCOU = ""    # hcb 55525
#   [M:PKD1]SCCCOD = GSSCCROOT
#Endif

If GVCRTYP = 4
   WNUM = [F:SDD]SDHNUM
   WLIN = [F:SDD]SDDLIN
   WITM = [F:SDD]ITMREF
   WTYP = GVCRTYP
   WFCY = [F:SDD]STOFCY
   If [F:ITM]ITMREF <> [F:SDD]ITMREF
      Read [ITM]ITM0=[F:SDD]ITMREF
      If fstat
         Raz [F:ITM]
      Endif
   Endif
# hcb 55862 deb
   If [F:SDD]PCK = "" &  [M:PKD1]PCK = ""
      GMESSAGE = mess(286,184,1)   # code emballage non renseign‚ !
      FOK  = 0
      GERR = 1
      Return
   Endif
# hcb 55862 deb

# si code emballage de la ligne de livraison est renseign‚ on le prend !
   Raz GPE                      # hcb 111912
   GPOINT = "PCKCAP"            # hcb 111912
   Gosub  ENTREE From EXEFNC    # hcb 111912
   If GPE =  0                  # hcb 111912
      If [F:SDD]PCK <> "" &  [M:PKD1]PCK = ""   # hcb 55862
         [M:PKD1]PCK    =  [F:SDD]PCK
         [M:PKD1]PCKCAP =  [F:SDD]PCKCAP        # hcb 62874
      Endif
   Endif                        # hcb 111912
   If [F:TPA]PCK <> [M:PKD1]PCK
      Read [TPA]TPA0=[M:PKD1]PCK
      If fstat
         Raz [F:TPA]
      Endif
   Endif
   [M:PKD1]       = [F:TPA]
   If GVCRTYP = 4 & [F:TPA]LBLFMT = ""
     [M:PKD1]LBLFMT = GDOCNAM
   Endif
   Raz GWUNTWEI
   Raz GWUNT
   Raz GWWEU
   GWUNTWEI = [F:SDD]UNTWEI/[F:SDD]SAUSTUCOE   # poids de l US / colis
   GWUNT    = [F:SDD]UNTWEI/[F:SDD]SAUSTUCOE   # poids de l US
   GWWEU    = [F:SDD]WEU
   If [F:SDD]WEU <> "" & [F:TPA]WEU <> ""
      If [F:SDD]WEU <> [F:TPA]WEU
        # Conversion poids unitaire de unit‚ poids liv en unit‚ poids colis
         Call SCONV_TCO([F:SDD]WEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
      Endif
   Endif
   Gosub CHARGE_LIGNE
Else
   WNUM = [F:PRE]PRHNUM
   WLIN = [F:PRE]PRELIN
   WITM = [F:PRE]ITMREF
   WTYP = GVCRTYP
   WFCY = [M:PKD0]STOFCY
   If [F:ITM]ITMREF <> [F:PRE]ITMREF
       Read [ITM]ITM0=[F:PRE]ITMREF
       If fstat
          Raz [F:ITM]
       Endif
   Endif
# hcb 55862 deb
   If [F:PRE]PCK = "" &  [M:PKD1]PCK = ""
      GMESSAGE = mess(286,184,1)   # code emballage non renseign‚ !
      FOK  = 0
      GERR = 1
      Return
   Endif
# hcb 55862 deb

# si code emballage de la ligne de preparation est renseign‚ on le prend !
   Raz GPE                      # hcb 111912
   GPOINT = "PCKCAP"            # hcb 111912
   Gosub  ENTREE From EXEFNC    # hcb 111912
   If GPE =  0                  # hcb 111912
      If [F:PRE]PCK <> "" &  [M:PKD1]PCK = "" # hcb 55862
         [M:PKD1]PCK    =  [F:PRE]PCK
         [M:PKD1]PCKCAP =  [F:PRE]PCKCAP        # hcb 62874
      Endif
   Endif                        # hcb 111912
   If [M:PKD1]PCK <> ""  &  [F:TPA]PCK <> [M:PKD1]PCK
      Read [TPA]TPA0=[M:PKD1]PCK
      If fstat
         Raz [F:TPA]
      Endif
   Endif
   [M:PKD1]       = [F:TPA]
   Raz GWUNTWEI
   Raz GWUNT
   GWUNTWEI = [F:ITM]ITMWEI  # poids de l us / colis
   GWUNT    = [F:ITM]ITMWEI  # poids de l us
   GWWEU    = [F:ITM]WEU     # unite de poids

   If [F:ITM]WEU <> "" & [F:TPA]WEU <> ""
       If [F:ITM]WEU <> [F:TPA]WEU
         # Conversion poids unitaire de unit‚ poids liv en unit‚ poids colis
           Call SCONV_TCO([F:ITM]WEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
       Endif
   Endif
   Gosub CHARGE_LIGNE
Endif

Actzo [M:PKD1]
If GSSCCROOT <> "" & GSSCCCOU <> ""
   Diszo [M:PKD1]SCCCOD
Endif

GMODPAC = 1

Return

$CHARGE_LIGNE
# si livraison
#    si valid‚ on lit les stojou
#    si pas valid‚ on les stoall puis le stock
# si preparation
#    si allou‚ en detail  on lit stoall puis le stock
Local Shortint  WNBLIG
Raz WNBLIG
WNBLIG = [M:PKD1]NBLIG

Local Char     WSERNUM (GLONSER)                                                                   # hcb 110327-pck
Local Char     WSERNUMF(GLONSER)                                                                   # hcb 110327-pck
Local Char     WCRITSPD(250)                                                                       # hcb 110327-pck
Local Integer  WEXISTE                                                                             # hcb 110327-pck
Local Integer WSTOMGTCOD
Local Integer WPCKSTKFLG
Raz WPCKSTKFLG
WSTOMGTCOD = [F:ITM]STOMGTCOD
# v‚rification gestion stock
If WFCY <>"" & [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD
   If [F:ITF]STOFCY <> WFCY | [F:ITF]ITMREF <> WITM
      Read [ITF]ITF0 = WITM;WFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
   WSTOMGTCOD = [F:ITF]STOMGTCOD
   WPCKSTKFLG = [F:ITF]PCKSTKFLG
Endif

# si g‚r‚ en stock et gestion du colisage detail stock on lit STOJOU ou STOALL

If WSTOMGTCOD > 1  & WPCKSTKFLG = 2
   # Issue X3-69499 - 2018-06-13 by TS
   #If GVCRTYP = 4 & [F:SDH]CFMFLG = 2
   # Ajout test sur LINCFMFLG par sécurité car normalement inutile,
   # les livraisons partiellement validées étant filtrées (non chargées)
   If GVCRTYP=4 & ([F:SDH]CFMFLG=2 | [F:SDD]LINCFMFLG=2)
   # End issue X3-69499
      Local Char CRITSTJ(250)                           # hcb 89412
      CRITSTJ = "1=1"                                   # hcb 89412
      GPOINT="CRITSTJSPE" : Gosub ENTREE From EXEFNC    # hcb 89412
#   rajour test sur SERFIN                                                                         # hcb 110327-pck
      Filter [STJ] Where STOFCY=WFCY & VCRTYP=WTYP & VCRNUM=WNUM & VCRLIN=WLIN
&                      & UPDCOD=2 & REGFLG<>2 & QTYPCU < 0 & evalue(CRITSTJ)
&     Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
      For [STJ]
            I =sigma(0,[M:PKD1]NBLIG-1,(indcum+1)*((dim([M:PKD1]LOT)<= 0 | [M:PKD1]LOT(indcum) = [F:STJ]LOT) &
&                                      (dim([M:PKD1]SLO)<=0  | [M:PKD1]SLO(indcum) = [F:STO]SLO) &
&                                      (dim([M:PKD1]SERNUM)<= 0 | [M:PKD1]SERNUM(indcum) = [F:STJ]SERNUM) &
&                                      (dim([M:PKD1]SERFIN)<= 0 | [M:PKD1]SERFIN(indcum) = [F:STJ]SERFIN) &
&                                      (dim([M:PKD1]PALNUM)<= 0 | [M:PKD1]PALNUM(indcum) = [F:STJ]PALNUM) &
&                                      (dim([M:PKD1]CTRNUM)<= 0 | [M:PKD1]CTRNUM(indcum) = [F:STJ]CTRNUM) &
&                                      ([M:PKD1]VCRLIN(indcum)    = WLIN)        &
&                                      ([M:PKD1]PCU(indcum)       = [F:STJ]PCU) &
&                                      ([M:PKD1]PCUSTUCOE(indcum) = [F:STJ]PCUSTUCOE)))
            If I = 0
               If [M:PKD1]NBLIG  >  dim ([M:PKD1]ITMREF)
                  Call MESSAGE(mess(527,199,1)) From GESECRAN
                  Break
               Endif
               I = [M:PKD1]NBLIG
               [M:PKD1]QTYPCU(I)      += ([F:STJ]QTYPCU * -1)
#              [M:PKD1]QTY(I)          = [M:PKD1]QTYPCU(I)     # hcb 104087
               [M:PKD1]VCRLIN(I)       = WLIN
               [M:PKD1]ITMREF(I)       = [F:STJ]ITMREF
               [M:PKD1]PCU(I)          = [F:STJ]PCU
               [M:PKD1]SAU(I)          = [F:SDD]SAU            # hcb 93756
               [M:PKD1]PCUSTUCOE(I)    = [F:STJ]PCUSTUCOE
#               Gosub CAL_QTY_DETAIL                             # hcb 104087
               If dim([M:PKD1]LOT)>0
                  [M:PKD1]LOT(I)       = [F:STJ]LOT
               Endif
               If dim([M:PKD1]SLO)>0
                  [M:PKD1]SLO(I)       = [F:STJ]SLO
               Endif
             [M:PKD1]PCKSERFLG(I) = [F:ITF]PCKSERFLG                                               # hcb 110327-pck
             [M:PKD1]SERMGTCOD(I) = [F:ITM]SERMGTCOD                                               # hcb 110327-pck
               If dim([M:PKD1]SERNUM)>0
                  If [M:PKD1]SERMGTCOD(I) = 4 & [M:PKD1]PCKSERFLG(I) = 2                           # hcb 110327-pck
                     [M:PKD1]SERNUM   (I) = [F:STJ]SERDEB                                          # hcb 110327-pck
                     [M:PKD1]SERFIN   (I) = [F:STJ]SERFIN                                          # hcb 110327-pck
                     Raz [M:PKD1]SERCOLDEB(I)                                                      # hcb 110327-pck
                     Raz [M:PKD1]SERCOLFIN(I)                                                      # hcb 110327-pck
                     [M:PKD1]SERORIDEB(I) = [F:STJ]SERDEB                                          # hcb 110327-pck
                     [M:PKD1]SERORIFIN(I) = [F:STJ]SERFIN                                          # hcb 110327-pck
                  Else                                                                             # hcb 110327-pck
                     [M:PKD1]SERNUM(I)    = [F:STJ]SERNUM
                     [M:PKD1]SERFIN(I)    = [F:STJ]SERNUM                                          # hcb 110327-pck
                  Endif                                                                            # hcb 110327-pck
               Endif
               If dim([M:PKD1]PALNUM)>0
                  [M:PKD1]PALNUM(I)    = [F:STJ]PALNUM
               Endif
               If dim([M:PKD1]CTRNUM)>0
                  [M:PKD1]CTRNUM(I)    = [F:STJ]CTRNUM
               Endif
              #[M:PKD1]ITMDES1(I)       = [F:ITM]ITMDES1
              Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKD1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
              [M:PKD1]STOMGTCOD(I)     = WSTOMGTCOD
              [M:PKD1]PCKSTKFLG(I)     = WPCKSTKFLG
              [M:PKD1]STU (I)          = [F:ITM]STU
#              [M:PKD1]QTYSTU (I)       = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)   # hcb 104087
#              Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV             # hcb 104087
              [M:PKD1]LIGWEU(I)        = GWWEU
              [M:PKD1]UNTWEI(I)        = GWUNT
              [M:PKD1]LIGUNTWEI(I)     = GWUNTWEI
#              [M:PKD1]NETWEI(I)        = [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI       # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#              [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI           # hcb 104087
              [M:PKD1]WSTOCOU(I)       = 0

              [M:PKD1]NBLIG +=1
            Else
               I -= 1
               [M:PKD1]QTYPCU(I)      += ([F:STJ]QTYPCU * -1)
#              [M:PKD1]QTY(I)          = [M:PKD1]QTYPCU(I)      # hcb 62874
#               Gosub CAL_QTY_DETAIL                             # hcb 104087

#               [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I) # hcb 104087
#               Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV          # hcb 104087
#               [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI   # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#               [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI        # hcb 104087
            Endif
#            Gosub TOT_GROCAP       # hcb 62874                                 # hcb 104087
      Next
      Filter [STJ]
   Else
      WI = [M:PKD1]NBLIG
# Si origine = livraison / preparation on recupere les allocation detail‚es et manquant 2 / 4
      Local Char CRITSTA(250)                           # hcb 89412
      CRITSTA = "1=1"                                   # hcb 89412
      GPOINT="CRITSTASPE" : Gosub ENTREE From EXEFNC    # hcb 89412
      WFILSTA = 'find(ALLTYP,2,4)<>0'

      For [STA]STA1 Where VCRTYP=WTYP & VCRNUM=WNUM &  VCRLIN=WLIN &
&                         ITMREF=WITM & evalue(WFILSTA) & evalue(CRITSTA)
# Si allocation d‚taill‚e
      If [F:STA]ALLTYP=2
         Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
         If fstat                                     # hcb ctr
            Call RSTA("STO",[F:STA]STOFCY-num$([F:STA]STOCOU)) From GLOCK
            Break
         Endif
#         Rajout  [F:ITM]SERMGTCOD = 4                                               # hcb
            I =sigma(0,[M:PKD1]NBLIG-1,(indcum+1)*((dim([M:PKD1]LOT)<= 0 | [M:PKD1]LOT(indcum) = [F:STO]LOT) &
&                                      (dim([M:PKD1]SLO)<=0  | [M:PKD1]SLO(indcum) = [F:STO]SLO) &
&                                      (dim([M:PKD1]SERNUM)<= 0 | [M:PKD1]SERNUM(indcum) = [F:STO]SERNUM) &
&                                      ([F:ITM]SERMGTCOD = 4 & [M:PKD1]SERNUM(indcum) = [F:STA]SERNUM | [F:ITM]SERMGTCOD <> 4) &
&                                      (dim([M:PKD1]PALNUM)<= 0 | [M:PKD1]PALNUM(indcum) = [F:STO]PALNUM) &
&                                      (dim([M:PKD1]CTRNUM)<= 0 | [M:PKD1]CTRNUM(indcum) = [F:STO]CTRNUM) &
&                                      ([M:PKD1]VCRLIN(indcum)    = WLIN)        &
&                                      ([M:PKD1]PCU(indcum)       = [F:STO]PCU) &
&                                      ([M:PKD1]WSTOCOU(indcum)   = 2) &
&                                      ([M:PKD1]PCUSTUCOE(indcum) = [F:STO]PCUSTUCOE)))
            If I = 0
               If [M:PKD1]NBLIG  >  dim ([M:PKD1]ITMREF)
                  Call MESSAGE(mess(527,199,1)) From GESECRAN
                  Break
               Endif
               I = [M:PKD1]NBLIG
               [M:PKD1]QTYPCU(I)       = [F:STA]QTYSTU/[F:STO]PCUSTUCOE
#              [M:PKD1]QTY(I)          = [F:STA]QTYSTU/[F:STO]PCUSTUCOE   # hcb 104087
               [M:PKD1]VCRLIN(I)       = WLIN
               [M:PKD1]ITMREF(I)       = [F:STO]ITMREF
               #[M:PKD1]ITMDES1(I)      = [F:ITM]ITMDES1
               Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKD1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
               [M:PKD1]STOMGTCOD(I)    = WSTOMGTCOD
               [M:PKD1]PCKSTKFLG(I)    = WPCKSTKFLG
               [M:PKD1]PCUSTUCOE(I)    = [F:STO]PCUSTUCOE
#               Gosub CAL_QTY_DETAIL                                      # hcb 104087
               [M:PKD1]STU(I)          = [F:ITM]STU
#               [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I) # hcb 104087
               Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV
               [M:PKD1]LIGWEU(I)       = GWWEU
               [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
               [M:PKD1]UNTWEI(I)        = GWUNT
#               [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI  # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#               [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI       # hcb 104087
               [M:PKD1]PCU(I)          = [F:STO]PCU
               If GVCRTYP = 4                                     # hcb 93756
                  [M:PKD1]SAU(I)          = [F:SDD]SAU            # hcb 93756
               Else                                               # hcb 93756
                  [M:PKD1]SAU(I)          = [F:PRE]PCU            # hcb 93756
               Endif                                              # hcb 93756
               [M:PKD1]WSTOCOU(I)      = 2
               If dim([M:PKD1]LOT)>0
                  [M:PKD1]LOT(I)       = [F:STO]LOT
               Endif
               If dim([M:PKD1]SLO)>0
                  [M:PKD1]SLO(I)       = [F:STO]SLO
               Endif
               [M:PKD1]PCKSERFLG(I)    = [F:ITF]PCKSERFLG                                          # hcb 110327-pck
               [M:PKD1]SERMGTCOD(I)    = [F:ITM]SERMGTCOD                                          # hcb 110327-pck

               If dim([M:PKD1]SERNUM)>0
                  If [M:PKD1]SERMGTCOD(I) = 4 & [M:PKD1]PCKSERFLG(I) = 2 & [F:STA]SERNUM<>""       # hcb 110327-pck
                     [M:PKD1]SERNUM(I)    = [F:STA]SERNUM                                          # hcb 110327-pck
                     If abs([F:STA]QTYSTU)= 1                                                      # hcb 110327-pck
                        [M:PKD1]SERFIN(I) = [F:STA]SERNUM                                          # hcb 110327-pck
                     Else                                                                          # hcb 110327-pck
                        WSERNUM = [F:STA]SERNUM                                                    # hcb 110327-pck
                        Call PLUS_NB(WSERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB         # hcb 110327-pck
                        [M:PKD1]SERFIN(I) = WSERNUMF                                               # hcb 110327-pck
                     Endif                                                                         # hcb 110327-pck
                     Raz [M:PKD1]SERCOLDEB(I)                                                      # hcb 110327-pck
                     Raz [M:PKD1]SERCOLFIN(I)                                                      # hcb 110327-pck
                     [M:PKD1]SERORIDEB(I) = [M:PKD1]SERNUM(I)                                      # hcb 110327-pck
                     [M:PKD1]SERORIFIN(I) = [M:PKD1]SERFIN(I)                                      # hcb 110327-pck
                  Else                                                                             # hcb 110327-pck
                     [M:PKD1]SERNUM(I)    = [F:STO]SERNUM
                     [M:PKD1]SERFIN(I)    = [F:STO]SERNUM                                          # hcb 110327-pck
                  Endif                                                                            # hcb 110327-pck
               Endif
               If dim([M:PKD1]PALNUM)>0
                  [M:PKD1]PALNUM(I)    = [F:STO]PALNUM
               Endif
               If dim([M:PKD1]CTRNUM)>0
                  [M:PKD1]CTRNUM(I)    = [F:STO]CTRNUM
               Endif
               [M:PKD1]NBLIG +=1
            Else
               I -= 1
               [M:PKD1]QTYPCU(I)      += [F:STA]QTYSTU/[M:PKD1]PCUSTUCOE(I)
#              [M:PKD1]QTY(I)         += [F:STA]QTYSTU/[M:PKD1]PCUSTUCOE(I)       # hcb 104087
#               Gosub CAL_QTY_DETAIL                                               # hcb 104087
#               [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)    # hcb 104087
#               Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV             # hcb 104087
               [M:PKD1]LIGWEU(I)       = GWWEU
               [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
               [M:PKD1]UNTWEI(I)        = GWUNT
#               [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI      # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#               [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI           # hcb 104087
         Endif
       Else
             I = [M:PKD1]NBLIG
             [M:PKD1]QTYPCU(I)       = [F:STA]QTYSTU
#            [M:PKD1]QTY(I)          = [M:PKD1]QTYPCU(I)                          # hcb 104087
             [M:PKD1]VCRLIN(I)       = WLIN
             [M:PKD1]ITMREF(I)       = [F:STA]ITMREF
             #[M:PKD1]ITMDES1(I)      = [F:ITM]ITMDES1
             Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKD1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
             [M:PKD1]STOMGTCOD(I)    = WSTOMGTCOD
             [M:PKD1]PCKSTKFLG(I)    = WPCKSTKFLG
             [M:PKD1]STU(I)          = [F:ITM]STU
             [M:PKD1]PCUSTUCOE(I)    = 1
#             Gosub CAL_QTY_DETAIL                            # hcb 104087
#             [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I)        # hcb 104087
             [M:PKD1]LIGWEU(I)       = GWWEU
             [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
             [M:PKD1]UNTWEI(I)       = GWUNT
#             [M:PKD1]NETWEI(I)       =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI   # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#             [M:PKD1]NETWEIPCK(I)    =  [M:PKD1]QTYSTU(I) * GWUNTWEI        # hcb 104087
             [M:PKD1]PCU(I)          = [F:ITM]STU
               If GVCRTYP = 4                                     # hcb 93756
                  [M:PKD1]SAU(I)          = [F:SDD]SAU            # hcb 93756
               Else                                               # hcb 93756
                  [M:PKD1]SAU(I)          = [F:PRE]PCU            # hcb 93756
               Endif                                              # hcb 93756
             [M:PKD1]WSTOCOU(I)      = 1
             If dim([M:PKD1]LOT)>0
                [M:PKD1]LOT(I)       = [F:STA]LOT
             Endif
             If dim([M:PKD1]SLO)>0
                [M:PKD1]SLO(I)       = [F:STA]SLO
             Endif
             [M:PKD1]PCKSERFLG(I) = [F:ITF]PCKSERFLG                                               # hcb 110327-pck
             [M:PKD1]SERMGTCOD(I) = [F:ITM]SERMGTCOD                                               # hcb 110327-pck
             If dim([M:PKD1]SERNUM)>0
                If [M:PKD1]SERMGTCOD(I) = 4 & [M:PKD1]PCKSERFLG(I) = 2 & [F:STA]SERNUM<>""         # hcb 110327-pck
                   [M:PKD1]SERNUM(I)    = [F:STA]SERNUM                                            # hcb 110327-pck
                   If abs([F:STA]QTYSTU)=1                                                         # hcb 110327-pck
                      [M:PKD1]SERFIN(I) = [F:STA]SERNUM                                            # hcb 110327-pck
                   Else                                                                            # hcb 110327-pck
                      WSERNUM = [F:STA]SERNUM                                                      # hcb 110327-pck
                      Call PLUS_NB(WSERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB           # hcb 110327-pck
                      [M:PKD1]SERFIN(I) = WSERNUMF                                                 # hcb 110327-pck
                   Endif                                                                           # hcb 110327-pck
                   Raz [M:PKD1]SERCOLDEB(I)                                                        # hcb 110327-pck
                   Raz [M:PKD1]SERCOLFIN(I)                                                        # hcb 110327-pck
                   [M:PKD1]SERORIDEB(I) = [M:PKD1]SERNUM(I)                                        # hcb 110327-pck
                   [M:PKD1]SERORIFIN(I) = [M:PKD1]SERFIN(I)                                        # hcb 110327-pck
                Else                                                                               # hcb 110327-pck
                   [M:PKD1]SERNUM(I)    = [F:STA]SERNUM
                   [M:PKD1]SERFIN(I)    = [F:STA]SERNUM                                            # hcb 110327-pck
                Endif                                                                              # hcb 110327-pck
             Endif
             [M:PKD1]NBLIG +=1
       Endif
#       Gosub TOT_GROCAP       # hcb 104087

       Next
       Filter [STA]

   Endif
# recherche si colisage existant

  For I=0 To [M:PKD1]NBLIG-1

#       If [M:PKD1]VCRLIN(I) = WLIN            # hcb 104087
         [M:PKD1]QTYINI(I) =  [M:PKD1]QTYPCU(I)                                                    # hcb 110327-pck
         WCRITSPD = "1=1"                                                                          # hcb 110327-pck
         Raz      WSER                                                                             # hcb 110327-pck
          If dim([M:PKD1]LOT)>0
              WLOT = [M:PKD1]LOT(I)
          Endif
          If dim([M:PKD1]SLO)>0
              WSLO = [M:PKD1]SLO(I)
          Endif
          If dim([M:PKD1]SERNUM)>0
             If  [M:PKD1]SERMGTCOD(I) <> 4                                                         # hcb 110327-PCK
                 WSER = [M:PKD1]SERNUM(I)                                                          # hcb 110327-PCK
                 WCRITSPD = "1=1"                                                                  # hcb 110327-pck
             Else                                                                                  # hcb 110327-PCK
                 WCRITSPD = "SERDEB >= [M:PKD1]SERNUM(I)  & SERDEB <= [M:PKD1]SERFIN(I)"           # hcb 110327-PCK
             Endif                                                                                 # hcb 110327-PCK
          Endif
          If dim([M:PKD1]PALNUM)>0
             WPAL = [M:PKD1]PALNUM(I)
          Endif
          If dim([M:PKD1]CTRNUM)>0
              WCTR = [M:PKD1]CTRNUM(I)
          Endif
          Raz WEXISTE                                                                              # hcb 110327-PCK
#                                                                                                        #  hcb 104087
#                     rajout evalue(WCRITSPD)                             # hcb 110327-PCK
          Filter [SPD] Where STOFCY = WFCY & VCRTYP = WTYP & VCRNUM = WNUM & VCRLIN = [M:PKD1]VCRLIN(I)
&                          & LOT    = WLOT & SLO    = WSLO & SERNUM = WSER & PALNUM = WPAL
&                          & CTRNUM = WCTR & PCU    = [M:PKD1]PCU(I)  & PCUSTUCOE = [M:PKD1]PCUSTUCOE(I)
&                          & evalue(WCRITSPD)
&                          & [M:PKD1]VCRLIN(I)      = WLIN
&         Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
          For [SPD]
#             [M:PKD1]QTY(I)         -= [F:SPD]QTYPCU                              # hcb 104087
#              [M:PKD1]QTYPCU(I)      -= [F:SPD]QTYPCU                                          # hcb x3-70246
              [M:PKD1]QTYPCU(I)      -= [F:SPD]QTY                                              # hcb x3-70246
#             [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)      # hcb 104087
#             Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV               # hcb 104087
#             [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:SPD]ITMWEI        # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#             [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * [M:PKD1]LIGUNTWEI(I) # hcb 104087
              WEXISTE = 1                                                                          # hcb 110327-pck
          Next
          #                                                                                        # hcb 110327-PCK deb
          If [M:PKD1]SERMGTCOD(I) = 4 & WEXISTE = 1
             Raz [M:PKD1]SERNUM(I)
             Raz [M:PKD1]SERFIN(I)
          Endif
#                                                                                                  # hcb 110327-PCK fin
          Filter [SPD]
#       Endif                                                                       # hcb 104087
   Next
Else                # si pas g‚re en sock on charge directement suivant la ligne document
   If GVCRTYP = 4
         I =sigma(0,[M:PKD1]NBLIG-1,(indcum+1)*(([M:PKD1]VCRLIN(indcum)    = WLIN) &
&                                      ([M:PKD1]PCU(indcum)       = [F:SDD]SAU) &
&                                      ([M:PKD1]PCUSTUCOE(indcum) = [F:SDD]SAUSTUCOE)))
         If I = 0
            If [M:PKD1]NBLIG  >  dim ([M:PKD1]ITMREF)
               Call MESSAGE(mess(527,199,1)) From GESECRAN
               Return
            Endif
            I = [M:PKD1]NBLIG
            [M:PKD1]PCKSERFLG(I)    = [F:ITF]PCKSERFLG                                             # hcb 110327-pck
            [M:PKD1]SERMGTCOD(I)    = [F:ITM]SERMGTCOD                                             # hcb 110327-pck
            [M:PKD1]QTYPCU(I)       = [F:SDD]QTY
#           [M:PKD1]QTY(I)          = [F:SDD]QTY                             # hcb 104087
            [M:PKD1]VCRLIN(I)       = WLIN
            [M:PKD1]ITMREF(I)       = [F:SDD]ITMREF
            [M:PKD1]PCU(I)          = [F:SDD]SAU
            [M:PKD1]SAU(I)          = [F:SDD]SAU            # hcb 93756
            [M:PKD1]PCUSTUCOE(I)    = [F:SDD]SAUSTUCOE
#            Gosub CAL_QTY_DOC                                                # hcb 104087
            #[M:PKD1]ITMDES1(I)       = [F:ITM]ITMDES1
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKD1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:PKD1]STOMGTCOD(I)    = WSTOMGTCOD
            [M:PKD1]PCKSTKFLG(I)    = WPCKSTKFLG
            [M:PKD1]STU (I)         = [F:ITM]STU
#            [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I) # hcb 104087
#            Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV          # hcb 104087
            [M:PKD1]LIGWEU(I)       = GWWEU
            [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
            [M:PKD1]UNTWEI(I)        = GWUNT
#            [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI  # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#            [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI       # hcb 104087
            [M:PKD1]NBLIG +=1
         Else
            I -= 1
            [M:PKD1]QTYPCU(I)      += [F:SDD]QTY
#           [M:PKD1]QTY(I)         += [F:SDD]QTY                                  # hcb 104087
#            Gosub CAL_QTY_DOC                                                     # hcb 104087
#            [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)       # hcb 104087
#            Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV                # hcb 104087
            [M:PKD1]LIGWEU(I)       = GWWEU
            [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
            [M:PKD1]UNTWEI(I)        = GWUNT
#            [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI         # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#            [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI              # hcb 104087
         Endif
   Else
         I =sigma(0,[M:PKD1]NBLIG-1,(indcum+1)*(([M:PKD1]VCRLIN(indcum)    = WLIN) &
&                                      ([M:PKD1]PCU(indcum)       = [F:PRE]STU) &
&                                      ([M:PKD1]PCUSTUCOE(indcum) = 1)))
         If I = 0
            If [M:PKD1]NBLIG  >  dim ([M:PKD1]ITMREF)
               Call MESSAGE(mess(527,199,1)) From GESECRAN
               Return
            Endif
            I = [M:PKD1]NBLIG
            [M:PKD1]PCKSERFLG(I)    = [F:ITF]PCKSERFLG                                             # hcb 110327-pck
            [M:PKD1]SERMGTCOD(I)    = [F:ITM]SERMGTCOD                                             # hcb 110327-pck
            [M:PKD1]QTYPCU(I)       = [F:PRE]QTYSTU
#           [M:PKD1]QTY(I)          = [F:PRE]QTYSTU                                # hcb 104087
            [M:PKD1]VCRLIN(I)       = WLIN
            [M:PKD1]ITMREF(I)       = [F:PRE]ITMREF
            [M:PKD1]PCU(I)          = [F:PRE]STU
            [M:PKD1]SAU(I)          = [F:PRE]PCU            # hcb 93756
            [M:PKD1]PCUSTUCOE(I)    = 1
#            Gosub CAL_QTY_DOC                                                      # hcb 104087
            #[M:PKD1]ITMDES1(I)      = [F:ITM]ITMDES1
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKD1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:PKD1]STOMGTCOD(I)    = WSTOMGTCOD
            [M:PKD1]PCKSTKFLG(I)    = WPCKSTKFLG
            [M:PKD1]STU (I)         = [F:ITM]STU
#           [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I)        # hcb 104087
            [M:PKD1]LIGWEU(I)       = GWWEU
            [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
            [M:PKD1]UNTWEI(I)       = GWUNT

#            [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI   # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#            [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI        # hcb 104087
            [M:PKD1]NBLIG +=1
         Else
            I -= 1
            [M:PKD1]QTYPCU(I)      += [F:PRE]QTYSTU
#           [M:PKD1]QTY(I)         += [F:PRE]QTYSTU                          # hcb 104087
#            Gosub CAL_QTY_DOC                                                # hcb 104087
            [M:PKD1]PCUSTUCOE(I)    = 1                                      # hcb 104087
#            [M:PKD1]QTYSTU (I)     = [M:PKD1]QTY(I)                          # hcb 104087
#            Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV           # hcb 104087
            [M:PKD1]LIGWEU(I)       = GWWEU
            [M:PKD1]LIGUNTWEI(I)    = GWUNTWEI
            [M:PKD1]UNTWEI(I)        = GWUNT
#            [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI    # hcb 104087
 # Calcul poids de la ligne  en unite de l emballage
#            [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI         # hcb 104087
         Endif
   Endif

   If WI <> [M:PKD1]NBLIG
      Raz WLOT
      Raz WSLO
      Raz WSER
      Raz WPAL
      Raz WCTR
      For I=WI To [M:PKD1]NBLIG-1
           [M:PKD1]QTYINI(I) =  [M:PKD1]QTYPCU(I)                                                  # hcb 110327-pck
#                                                                                                       # hcb 104087
# recherche si ligne deja colis‚e
           Filter [SPD] Where STOFCY = WFCY & VCRTYP = WTYP & VCRNUM = WNUM & VCRLIN = [M:PKD1]VCRLIN(I)
&                           & LOT    = WLOT & SLO    = WSLO & SERNUM = WSER & PALNUM = WPAL
&                           & CTRNUM = WCTR & PCU    = [M:PKD1]PCU(I)  & PCUSTUCOE = [M:PKD1]PCUSTUCOE(I)
&                           & [M:PKD1]VCRLIN(I)      = WLIN
&          Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
           For [SPD]
#               [M:PKD1]QTYPCU(I)      -= [F:SPD]QTYPCU                                       # hcb x3-70246
               [M:PKD1]QTYPCU(I)      -= [F:SPD]QTY                                           # hcb x3-70246
#              [M:PKD1]QTY(I)         -= [F:SPD]QTYPCU                          # hcb 104087
#              [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)  # hcb 104087
#              Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV           # hcb 104087
#              [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI    # hcb 104087
   # Calcul poids de la ligne  en unite de l emballage
#              [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI         # hcb 104087
           Next
           Filter [SPD]
      Next
   Endif
Endif

#                                                 hcb 104087 deb
# calcul capacit‚ emballage
Local Decimal WNB                   # hcb 109393
For I=0 To [M:PKD1]NBLIG-1
    If [M:PKD1]QTYSTU (I)   = 0
       If [M:PKD1]PCKCAP <>  0
          Raz WNB
          Raz [M:PKD1]QTY(I)
          If [M:PKD1]PCKCAP >= (( [M:PKD1]QTYPCU(I) * [M:PKD1]PCUSTUCOE(I)) + [M:PKD1]GROCAP)
             [M:PKD1]QTY(I) +=  [M:PKD1]QTYPCU(I)
          Else
             If [M:PKD1]PCKCAP > [M:PKD1]GROCAP
#                WNB   = int(([M:PKD1]PCKCAP   - [M:PKD1]GROCAP)/[M:PKD1]PCUSTUCOE(I))  # hcb 109393
#                WNB   = ([M:PKD1]PCKCAP   - [M:PKD1]GROCAP)/[M:PKD1]PCUSTUCOE(I)           # hcb x3-70246
                WNB   = ([M:PKD1]PCKCAP   - [M:PKD1]GROCAP)                                 # hcb x3-70246
                [M:PKD1]QTY(I) +=  WNB
             Endif
          Endif
       Else
          [M:PKD1]QTY(I) +=  [M:PKD1]QTYPCU(I)
       Endif
       [M:PKD1]QTYSTU (I)      = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)
       Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV
       #--- Issue X3-200634 by TS
       #[M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [F:ITM]ITMWEI
       [M:PKD1]NETWEI(I)        =  [M:PKD1]QTYSTU(I) * [M:PKD1]UNTWEI(I)
       #---
       [M:PKD1]NETWEIPCK(I)     =  [M:PKD1]QTYSTU(I) * GWUNTWEI
#                                                                                                  # hcb 110327-pck deb
#       If [M:PKD1]QTY    (I) = 0                                                              # hcb X3-123074
#          [M:PKD1]QTYPCU (I) = 0                                                              # hcb X3-123074
#       Else                                                                                   # hcb X3-123074
#      si g‚r‚ en serie global et colisage d‚tail serie … oui
#      si la quantit‚ trait‚e et differente de la quantit‚ … coliser : recalcul du no serie fin
       If [M:PKD1]QTY (I) <> 0 & [M:PKD1]SERMGTCOD (I) = 4 & [M:PKD1]PCKSERFLG (I) = 2 &  [M:PKD1]QTYPCU (I) <> [M:PKD1]QTYSTU (I)   # hcb X3-123074
              WSERNUM = [M:PKD1]SERNUM (I)
              Call PLUS_NB(WSERNUM,abs([M:PKD1]QTYSTU (I)),WSERNUMF,LRET) From STKLIB
              [M:PKD1]SERFIN(I) = WSERNUMF
#          Endif                                                                                 # hcb X3-123074
       Endif
#                                                                                                  # hcb 110327-pck fin
       Gosub TOT_GROCAP
    Endif
Next
#                                                 hcb 104087 fin



GPOINT="AF_TABTOPKD1" : Gosub ENTREE From EXEFNC    # hcb 70421


# suppression des lignes qui ont quantit‚ … coliser = 0 dans le cas d un picking de ligne
# et non dans le cas d un rappel colis
Local Integer J
Raz I,J
If [M:PKD1]NBLIG <> 0
   For I=0 To [M:PKD1]NBLIG - 1
       If I > [M:PKD1]NBLIG
              [M:PKD1]NBLIG = I
          Break
       Else
         If [M:PKD1]QTY(I) = 0 & [M:PKD1]QTYPCU(I) = 0    # hcb 62874
             Dela I,1 [M:PKD1]NBLIG
             I             -= 1
             [M:PKD1]NBLIG -= 1
          Endif
       Endif
   Next I
Endif

# affichage poids total
If [M:PKD1]NBLIG = WNBLIG & [M:PKD1]ITMREF(WNBLIG) <> ""
   [M:PKD1]NBLIG +=1
Endif
Gosub TOT_GROWEI From FUNPKD

Return


$FIN_PIC
Affzo [M:PKD1]

Return

$ANU_PIC
Raz I,J
OK = 0
If [M:PKD1]NBLIG <> 0
   # Le d‚pick d'une ligne de livraison / preparation peut entraŒner la suppression
   # de plusieurs lignes de [PKD1] (mˆme xxxLIN )
      While OK <> 1
        If GVCRTYP = 4
           I = find([F:SDD]SDDLIN,[M:PKD1]VCRLIN(J..[M:PKD1]NBLIG-1))
        Else
           I = find([F:PRE]PRELIN,[M:PKD1]VCRLIN(J..[M:PKD1]NBLIG-1))
        Endif
        If I<>0
            NOL = J+I-1
            J   = NOL
            Dela NOL,1,[M:PKD1]NBLIG-1 [M:PKD1]NBLIG
            [M:PKD1]NBLIG -= 1
            If J>[M:PKD1]NBLIG-1 OK=1 Endif
         Else
           OK=1
         Endif
      Wend
Endif

# hcb 60766 deb
If [M:PKD1]NBLIG <> 0
# affichage poids total
   Gosub TOT_GROWEI From FUNPKD
Else
   Gosub ABA_TRTPKD
Endif
# hcb 60766 fin

Return



#########################################################################
# D‚tail des actions li‚es au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTPKD
TIT = mess(320,198,1)

# C'est une fonction vente qui travaille sur un site d'exp‚dition
# On surcharge donc le site par d‚faut du module avec celui d'exp‚dition
# pour que les contr“les d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

If clalev([F:SDH]) = 0 Local File SDELIVERY  [SDH] Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD [SDD] Endif
If clalev([F:PRH]) = 0 Local File STOPREH    [PRH] Endif
If clalev([F:PRE]) = 0 Local File STOPRED    [PRE] Endif
If clalev([F:SRT]) = 0 Local File STKTRS     [SRT] Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD] Endif
If clalev([F:SPH]) = 0 Local File SPACK      [SPH] Endif
If clalev([F:SPD]) = 0 Local File SPACKD     [SPD] Endif
If clalev([F:TPA]) = 0 Local File TABPACKAGE [TPA] Endif
If clalev([F:STJ]) = 0 Local File STOJOU     [STJ] Endif
If clalev([F:BPT]) = 0 Local File BPCARRIER  [BPT] Endif
If clalev([F:STA]) = 0 Local File STOALL     [STA] Endif
If clalev([F:STO]) = 0 Local File STOCK      [STO] Endif

Call GLOBVAR(GFCYDEF(7)) From WWGLOBSTO

Return

#########################################################################
$INIT_DIA_TRTPKD
Raz [M:PKS1]

[M:PKS1]SSTOFCY = GFCYDEF(7)
[M:PKS1]SSHIDAT = date$
[M:PKS1]SVCRTYP = 4
[M:PKS1]SCOL    = 1
[M:PKS1]SNONVAL = 2
[M:PKS1]SVAL    = 1
[M:PKS1]SINV    = 1
[M:PKS1]PKGTYP  = 1
[M:PKS1]OBJET   = "SDH"
[M:PKS1]PREUSR  = GUSER
GFLAG           = ""

# lecture de la premiere transaction Colisage declaratif
#               de la validation des listes ...
Filter [SRT] Where SRTTYP=11 & ENAFLG=2 & PKGTYP = [M:PKS1]PKGTYP
   Read [SRT] First
Filter [SRT]
If fstat
   Raz [F:SRT]
Endif
[M:PKS1]SRTNUM  = [F:SRT]SRTNUM
[M:PKS1]SRTTYP  = [F:SRT]SRTTYP
GFLAG           = [F:SRT]SRTNUM
GSRTNUM         = GFLAG
GPKDNUM         = GFLAG
Diszo [M:PKS1]SINV
Return

#########################################################################
$TERMINE_TRTPKD

Return


#########################################################################
# D‚tail des actions li‚es … la saisie fenˆtre                          #
#########################################################################


$OUVRE_BOITE_TRTPKD

Global Integer    GVCRTYP
Global Integer    GDOCFLG
Global Integer    GPCKFLT
Global Char       GDOCNAM
Global Char       GSAVGFLAG

If dim(GPKD_BOITE)<1
   Global Char GPKD_BOITE(10)
Endif
If GACTION = "TRTPKD"
   GVCRTYP    = [M:PKS1]SVCRTYP
Else
   GSAVGFLAG  = GFLAG
   GVCRTYP    =  val(PARAM(1))
   GFLAG      = PARAM(2)
   If GFLAG   = ""
      Local Char PARMSK(250)(1..16)
      PARMSK(1) = "SPK"
      PARMSK(2) = "B"
      If dim([M]PKGTYP) > 0
         [M]PKGTYP = GPKGTYP
      Endif
      Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
      GFLAG = VALEUR
     # lecture de la premiere transaction Colisage si pas de selection
     #               de la validation des listes ...
      If GFLAG = ""
         Filter [SRT] Where SRTTYP=11 & ENAFLG=2 & PKGTYP = GPKGTYP
             Read [SRT] First
         Filter [SRT]
         If fstat
            Raz [F:SRT]
         Endif
         GFLAG           = [F:SRT]SRTNUM
      Endif
   Endif

   Read [SRT] SRT0=11;GFLAG
   If fstat | [F:SRT]ENAFLG=1
      Raz GFLAG
   Endif
   GSRTNUM = GFLAG
   GPKDNUM = GFLAG
Endif
GPKD_BOITE = "WOPKD"+GPKDNUM

GGRPFCY = [F:SRT]GFY
GDOCFLG = [F:SRT]DOCFLG
GDOCNAM = [F:SRT]DOCNAM
GPCKFLT = [F:SRT]PCKFLT

Case GVCRTYP
     When 3   : GBIDC1  = mess( 3,701,1)       # Preparation
                Raz GBIDC2
     When 4   : GBIDC1  = mess( 4,701,1)       # livraison
                GBIDC2  = mess( 2,407,1)       # Date livraison
Endcase

If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
If dim(GPKD_BOITE)>0
   If GPKD_BOITE <> ""
      BOITE = GPKD_BOITE
   Endif
   Kill GPKD_BOITE
Endif

Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="FPKD"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif

Gosub CHANGE_AWI From FUNPKD


Global Decimal GNBRLIG  # rubrique pour activer le bouton Suppression
                        # aliment‚e dans CHARGE_COLIS si nombre de detail > 1  GNBRLIG = 1

Global Decimal GWUNTWEI # poids de l Us par rapport … l emballage
Global Decimal GWUNT    # poids de l us article
Global Char    GWWEU    # unite de poids SDD si livraison , ITM si pr‚paration
Global Integer GMODPAC  # pour gerer le bouton enregistrement / abandon
Global Integer GRAPPAC  # pour gerer le bouton abandon : cas rappel colis

# D‚finition des critŠres de s‚lection des livraisons
#--- depuis le menu colisage
If GACTION = "TRTPKD"
   CRIT= "1=1"
   If [M:PKS1]SVCRTYP = 4
#                             criteres Livraison  (SDH)
      If [M:PKS1]SNUMDEB<>""
         CRIT -= '& SDHNUM>="'+[M:PKS1]SNUMDEB+'"'
      Endif
      If [M:PKS1]SNUMFIN<>""
         CRIT -= '& SDHNUM<="'+[M:PKS1]SNUMFIN+'"'
      Endif
      If [M:PKS1]SSTOFCY<>""
         CRIT -= '& STOFCY="'+[M:PKS1]SSTOFCY+'"'
      Endif
      If [M:PKS1]SSHIDAT<>[0/0/0]
         CRIT -= "& SHIDAT<=["+format$(GFMD,[M:PKS1]SSHIDAT)+"]"
      Endif
      If [M:PKS1]SBPCORDDEB<>""
         CRIT -= '& BPCORD>="'+[M:PKS1]SBPCORDDEB+'"'
      Endif
      If [M:PKS1]SBPCORDFIN<>""
         CRIT -= '& BPCORD<="'+[M:PKS1]SBPCORDFIN+'"'
      Endif
      If [M:PKS1]SBPAADDDEB<>""
         CRIT -= '& BPAADD>="'+[M:PKS1]SBPAADDDEB+'"'
      Endif
      If [M:PKS1]SBPAADDFIN<>""
         CRIT -= '& BPAADD<="'+[M:PKS1]SBPAADDFIN+'"'
      Endif
      If [M:PKS1]SCOL<>2
         CRIT -= "& PACFLG<>2"
      Endif
      If [M:PKS1]SNONVAL<>2
         CRIT -= "& CFMFLG=2"
      Endif
      If [M:PKS1]SVAL<>2
         CRIT -= "& CFMFLG<>2"
      Endif
      If [M:PKS1]SINV<>2
         CRIT -= "& INVFLG<>2"
      Endif

   Else
#                             criteres Pr‚paration  (PRH)
      If [M:PKS1]SNUMDEB<>""
         CRIT -= '& PRHNUM>="'+[M:PKS1]SNUMDEB+'"'
      Endif
      If [M:PKS1]SNUMFIN<>""
         CRIT -= '& PRHNUM<="'+[M:PKS1]SNUMFIN+'"'
      Endif
      If [M:PKS1]SSTOFCY<>""
         CRIT -= '& STOFCY="'+[M:PKS1]SSTOFCY+'"'
      Endif
      If [M:PKS1]SSHIDAT<>[0/0/0]
         CRIT -= "& SHIDAT<=["+format$(GFMD,[M:PKS1]SSHIDAT)+"]"
      Endif
      If [M:PKS1]SBPCORDDEB<>""
         CRIT -= '& BPCORD>="'+[M:PKS1]SBPCORDDEB+'"'
      Endif
      If [M:PKS1]SBPCORDFIN<>""
         CRIT -= '& BPCORD<="'+[M:PKS1]SBPCORDFIN+'"'
      Endif
      If [M:PKS1]SBPAADDDEB<>""
         CRIT -= '& BPAADD>="'+[M:PKS1]SBPAADDDEB+'"'
      Endif
      If [M:PKS1]SBPAADDFIN<>""
         CRIT -= '& BPAADD<="'+[M:PKS1]SBPAADDFIN+'"'
      Endif
      If [M:PKS1]SCOL<>2
         CRIT -= "& PACFLG<>2"
      Endif
      CRIT -= "& DLVFLG = 2"

   Endif
Endif

#--- depuis la gestion des livraisons : preparation
If GACTION = "SAIPKD"
   If GCONSULT = 2 & dim(GVCRNUMCOL) > 0 & GVCRNUMCOL <> ""
      If GVCRTYP = 4
         CRIT = "SDHNUM=GVCRNUMCOL"
      Else
         CRIT = "PRHNUM=GVCRNUMCOL & DLVFLG = 2 "
      Endif
   Else
      If GVCRTYP = 4
         CRIT = "SDHNUM=[M:SDH0]SDHNUM"
      Else
         CRIT = "PRHNUM=[M:PRH0]PRHNUM & DLVFLG = 2 "
      Endif
   Endif
Endif
Return

########################################################################
# CHANGE_AWI                               chargement traitement fenetre
########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenˆtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenˆtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

$OUVRE_TRTPKD
Global Integer  GSUPLIG        : # Pour identifier que l'on supprime une ligne
Global Integer  GSAIPACNUM     : # Pour maj picking si no document saisis
Global Integer  GANU_COLISAGE  : # Pour maj picking suite suppression colisage

Local  Integer  FINCOL, NBLIV, VOK : VOK = 1

Global Char     GWCLECUR
Global Char     GSAVGFLAG
Local  Char     SYMBOLE
Local  Integer  I, J, K, NOL
Local  Integer  WPICK
Local  Integer  WAFFPICK        : # 0=pas d'alimentation picking
Raz GSAIPACNUM
Raz GANU_COLISAGE
Raz WAFFPICK
Raz WPICK
#---------------------------------------------------------------------#
# Variables utilisables par le point d'entr‚e                         #
#                                                                     #
# WCODTRT     : Traitement effectu‚ "C" (Cr‚ation), "A" (Annulation)  #
#---------------------------------------------------------------------#
Local Char WPOINT_CODTRT
Global  Char  CRIT(250)
TIT = mess(156,195,1)
If clalev([F:ARP])  = 0 Local File AREPORT    [ARP] Endif
If clalev([F:SPH])  = 0 Local File SPACK      [SPH] Endif
If clalev([F:SPD])  = 0 Local File SPACKD     [SPD] Endif
If clalev([F:TPA])  = 0 Local File TABPACKAGE [TPA] Endif
If clalev([F:ITF])  = 0 Local File ITMFACILIT [ITF] Endif
If clalev([F:STO])  = 0 Local File STOCK      [STO] Endif
If clalev([F:STA])  = 0 Local File STOALL     [STA] Endif
If clalev([F:STJ])  = 0 Local File STOJOU     [STJ] Endif
If clalev([F:SDH1]) = 0 Local File SDELIVERY [SDH1] Endif
If clalev([F:SDH])  = 0 Local File SDELIVERY [SDH]  Endif                                          # hcb 110327-pk bug
If clalev([F:PRH1]) = 0 Local File STOPREH   [PRH1] Endif
If clalev([F:BPT])  = 0 Local File BPCARRIER [BPT] Endif                  # hcb 107175

# Issue X3-69499 - 2018-06-12 by TS
If clalev([F:ACV]) = 0 Local File ACTIV      [ACV] Endif
Global Integer GVALIDLIN  : # Niveau de validation de la livraison
                            #   1 = Ligne de livraison
                            #   0 = Livraison complète
GVALIDLIN=0
# Complète Delivery Validation "CDV"
Read [ACV] CODACT = "CDV"
If !fstat & [F:ACV]FLACT<>2
  GVALIDLIN=1
Endif
# End issue X3-69499

# Compteur colisage
Local Integer LRET
# R‚cup‚ration des codes compteur
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(24) = [F:TCA]MANCOU(24) # Compteur colisage
GSTKCPT   (24) = [F:TCA]CODNUM(24)

Return

#########################################################################
$SETBOUT_TRTPKD
#  =   : raffraichir
#  S   : suppression
#  E   : enregistrer
#  A   : abandon
#  N   : nouveau

If !find("=",CHBOU) CHBOU+="=" Endif

# si nombre de ligne > 0 au chargement du colis -> bouton suppression

If GNBRLIG > 0 & GCONSULT <> 2
   CHBOU+="S"
Else
   Call VIREBOUT(CHBOU,"S") From GOBJET
Endif

Call VIREBOUT(CHBOU,"EA") From GOBJET

# si picking ou modif boutons enregistrer abandon
If GMODPAC = 1
   CHBOU+="E"
   CHBOU+="A"
Endif

# si rappel colis existant  bouton Abandon
If GRAPPAC = 1
   CHBOU+="A"
Endif

# si le document est completement coliser : bouton nouveau gris‚
If GVCRTYP = 4
   If [F:SDH]PACFLG = 2
      Call VIREBOUT(CHBOU,"N") From GOBJET
   Endif
Else
   If [F:PRH]PACFLG = 2
      Call VIREBOUT(CHBOU,"N") From GOBJET
   Endif
Endif
#Bouton Etiquette  absent si nombre de colis = 0
If [M:PKD0]PACNBR  = 0
   Call VIREBOUT(CHMEN,"a") From GOBJET
Endif

# Pas de menu "texte colis" si pas de numero de colis
If [M:PKD1]PACNUM = "" & [M:PKD1]NBLIG = 0
   Call VIREBOUT(CHMEN,"E") From GOBJET
Endif

# # pas de menu suivant precedent premier dernier si  action <> de la fonction de colisage
If GACTION <>  "TRTPKD"
   Call VIREBOUT(CHBOU,"<>09") From GOBJET
Else
# pas de menu suivant precedent premier dernier si un seul document est selectionn‚
   If [M:PKS1]SNUMDEB<> "" & [M:PKS1]SNUMDEB = [M:PKS1]SNUMFIN
      Call VIREBOUT(CHBOU,"<>09") From GOBJET
   Endif
Endif

If GCONSULT = 2
   Call VIREBOUT(CHBOU,"SEAN") From GOBJET
Endif
Return


#########################################################################

$APRES_MODIF
# Raffraichissement du picking suite … saisie du numeros de colis
If GSAIPACNUM = 1
   WAFFPICK = 1
   Gosub TIROIR From FUNPKD
   Affzo [M:PKD1]
Endif
Raz GSAIPACNUM
If COUZON <> "PACNUM"
   GMODPAC = 1
   If COUZON = "PCK" & GPCKFLT = 2 & [M:PKD1]NBLIG = 0
      WAFFPICK = 1
      Gosub TIROIR From FUNPKD
   Endif
Endif
# Si suppression d'une ligne, raffraichissement du picking
If GSUPLIG=65                                      # hcb 60766
#If GSUPLIG=65 & [M:PKD1]PACFLG(nolign-1) = 2      # hcb 60766
   If GVCRTYP = 4
        Read [SDD]SDD0=[M:PKD0]VCRNUM;[M:PKD1]VCRLIN(nolign-1)
        Gosub DEPICK From GSAISIE
   Else
        Read [PRE]PRE0=[M:PKD0]VCRNUM;[M:PKD1]VCRLIN(nolign-1)
        Gosub DEPICK From GSAISIE
   Endif
#                                                  hcb 60766 deb

#  WAFFPICK = 1
#  Gosub TIROIR From FUNPKD
   If [M:PKD1]NBLIG-1 =  0
      Raz [M:PKD1]
      [M:PKD1]BPTNUM = [M:PKD0]BPTNUM
      [M:PKD1]BPTSHO = [M:PKD0]BPTSHO
      If dim([M:PKS1]PREUSR) > 0
         [M:PKD1]PREUSR = [M:PKS1]PREUSR
      Endif
      If  GVCRTYP = 4
          [M:PKD1]LBLFMT = GDOCNAM
      Endif
      Affzo [M:PKD1]
      If GCONSULT <> 2
         Actzo [M:PKD1]PACNUM
      Endif
      GMODPAC = 0
      GRAPPAC = 0
      GNBRLIG = 0
   Endif
#                                                   hcb 60766 fin
   Raz GSUPLIG
Endif


Return
#########################################################################

$MEN_TRTPKD
Case BOUT
 When "E"     : GMODPAC = 1
Endcase


Return


#########################################################################
$DEBUT_TRTPKD

GMODPAC = 0
GRAPPAC = 0
GNBRLIG = 0
Raz NBLIV

If GVCRTYP = 4
# Filtre sur les livraisons … traiter
   Filter [SDH] Where evalue (CRIT)
   Read [SDH]SDH0 First
   If !fstat
      # Issue X3-69499 - 2018-06-12 by TS
      If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
        Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
        If rowcount([SDD])>0
          Filter [SDD]
          Goto NEXT_SDH
        Endif
        Filter [SDD]
      Endif
      # End issue X3-69499
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_SDH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
   Goto SUITE_SDH
$NEXT_SDH
   Read [SDH]SDH0 Next
   If !fstat
      # Issue X3-69499 - 2018-06-12 by TS
      If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
        Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
        If rowcount([SDD])>0
          Filter [SDD]
          Goto NEXT_SDH
        Endif
        Filter [SDD]
      Endif
      # End issue X3-69499
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_SDH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
$SUITE_SDH
   Gosub CHARGE_ENTETE
Else
# Filtre sur les preparations … traiter
   Filter [PRH] Where evalue (CRIT)
   Read [PRH]PRH0 First
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_PRH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
   Goto SUITE_PRH
$NEXT_PRH
   Read [PRH]PRH0 Next
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_PRH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
$SUITE_PRH
   Gosub CHARGE_ENTETE
Endif
Affzo [M:PKD1]BPTNUM
Affzo [M:PKD1]BPTSHO

Raz WAFFPICK
Gosub TIROIR From FUNPKD

Affzo [M:PKD0]
Affzo [M:PKD1]
Return

###################################################################
# Chargement de l'‚cran de colisage de la livraison / preparation #
###################################################################
$CHARGE_ENTETE

Local Integer I, J, OK, REPONSE
Local Integer WLIGCOL       : # Nb lignes ‚crans d‚j… colis‚es
Local Decimal WQTECOL       : # Qt‚ d‚j… colis‚e sur une ligne de liv
Local Decimal WQTACOL       : # Qt‚ … coliser en automatique sur une ligne de liv
Local Integer WDACDLV       : # No ‚l‚ment facturation dans livraison pour colisage
Raz [M:PKD0]
Raz [M:PKD1]
Diszo [M:PKD0]VCRNUM # diszo pour conserver les menus contextuels
If GCONSULT <> 2
   Actzo [M:PKD1]PACNUM
Endif

nolign = 0
If GVCRTYP = 4
   [M:PKD0]       = [F:SDH]
   [M:PKD0]VCRTYP = 4
   [M:PKD0]VCRNUM = [F:SDH]SDHNUM
   [M:PKD0]PACNBR = [F:SDH]PACNBR
   [M:PKD0]BPCORD = [F:SDH]BPCORD
   [M:PKD0]BPAADD = [F:SDH]BPAADD
   [M:PKD1]LBLFMT = GDOCNAM
   [M:PKD1]BPTNUM = [F:SDH]BPTNUM
   If [F:SDH]BPTNUM <> [F:BPT]BPTNUM
      Read [BPT]BPT0 = [F:SDH]BPTNUM
         If fstat
            Raz [F:BPT]
         Endif
   Endif
   [M:PKD1]BPTSHO = [F:BPT]BPTSHO

   If [F:SDH]BPDNAM(0) <> ""

      [M:PKD0]BPDNAM = [F:SDH]BPDNAM(0)
   Else
      If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD
         Read [BPD]BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
         If fstat
            Raz [F:BPD]
         Endif
      Endif
      [M:PKD0]BPDNAM = [F:BPD]BPDNAM
   Endif
Else
   [M:PKD0]       = [F:PRH]
   [M:PKD0]VCRTYP = 3
   [M:PKD0]VCRNUM = [F:PRH]PRHNUM
   [M:PKD0]PACNBR = [F:PRH]PACNBR
   [M:PKD0]BPCORD = [F:PRH]BPCORD
   [M:PKD0]BPAADD = [F:PRH]BPAADD
#                                         hcb 107175 deb
   [M:PKD1]BPTNUM = [F:PRH]BPTNUM
   If [F:PRH]BPTNUM <> [F:BPT]BPTNUM
      Read [BPT]BPT0 = [F:PRH]BPTNUM
         If fstat
            Raz [F:BPT]
         Endif
   Endif
   [M:PKD1]BPTSHO = [F:BPT]BPTSHO
#                                         hcb 107175 fin

   If [F:BPD]BPCNUM <> [F:PRH]BPCORD | [F:BPD]BPAADD <> [F:PRH]BPAADD
      Read [BPD]BPD0 = [F:PRH]BPCORD;[F:PRH]BPAADD
      If fstat
         Raz [F:BPD]
      Endif
   Endif
   [M:PKD0]BPDNAM = [F:BPD]BPDNAM
   If dim([F:PRH]PREUSR) > 0
      [M:PKD1]PREUSR = [F:PRH]PREUSR
   Endif
Endif
[M:PKD0]BPTNUM = [M:PKD1]BPTNUM
[M:PKD0]BPTSHO = [M:PKD1]BPTSHO

If [M:PKD1]PREUSR = ""
   If dim([M:PKS1]PREUSR) > 0
      [M:PKD1]PREUSR = [M:PKS1]PREUSR
   Endif
Endif

Call GLOBVAR([M:PKD0]STOFCY) From WWGLOBSTO


If GSSCCROOT <> ""
   If GSSCCCOU = ""
      [M:PKD0]SSCCGES = mess(271,184,1)     # Code SSCC partielle
   Else
      [M:PKD0]SSCCGES = mess(274,184,1)     # Code SSCC automatique
   Endif
Endif
If GCONSULT = 2
   Grizo [M:PKD0]
   Grizo [M:PKD1]
Endif

Return



# Verrouillage de la livraison / preparation
$VERROU
# on ne verrouille pas si action <> de la fonction de colisage , cela se fait par la fonction appelant
If GACTION <>  "TRTPKD"
   Return
Endif
If GVCRTYP = 4
   SYMBOLE = "SDH"+[F:SDH]SDHNUM

   Lock = SYMBOLE With lockwait = 0
   If fstat = 1

      Call ECR_TRACE([F:SDH]SDHNUM-mess(10,100,1),1) From GESECRAN
      VOK = 1
   Elsif fstat
      Call ECR_TRACE(mess(150,199,1)-"$SDELIVERY",1) From GESECRAN
      VOK = 0
   Endif
Else
   SYMBOLE = "PRH"+[F:PRH]PRHNUM
   Lock = SYMBOLE With lockwait = 0
   If fstat = 1
      Call ECR_TRACE([F:PRH]PRHNUM-mess(10,100,1),1) From GESECRAN
      VOK = 1
   Elsif fstat
      Call ECR_TRACE(mess(150,199,1)-"$STOPREH",1) From GESECRAN
      VOK = 0
   Endif
Endif

Return

# D‚verrouillage de la livraison / preparation
$DEVERROU
# on ne deverrouille pas si action <> de la fonction de colisage , cela se fait par la fonction appelant
If GACTION <>  "TRTPKD"
   Return
Endif
Unlock = SYMBOLE
Return

#########################################################################
$AP_CHOIX_TRTPKD

Raz FINCOL

Return

#########################################################################
$AVANT_ENR_TRTPKD
#                                                                                                  # hcb 110327-pck deb
For I=0 To [M:PKD1]NBLIG-1
    If [M:PKD1]SERMGTCOD(I) =  4  & [M:PKD1]PCKSERFLG(I) = 2 &
&      [M:PKD1]QTYSTU   (I) <> 0  & [M:PKD1]SERNUM   (I) = ""
        GERR=1   : GMESSAGE=mess(3,40,1)-num$(I+1)-mess(246,199,1)
        GOK=0    : Break
     Endif
Next
#                                                                                                  # hcb 110327-pck end
Return

#########################################################################

#########################################################################
$ENR_TRTPKD
Char GSVG_GACTION

# 101090 - Verify changes if BOL attached to shipment
Local Integer OK : OK = 2
Call VERIF_BOLMOD(OK) From SUBSDHB
If OK<>2 : GOK=0 : Return : Endif

Gosub ENR_COLISAGE
Gosub DEVERROU
GMODPAC = 0
GRAPPAC = 0
If LPACFLG = 2
   #--- si impression auto … oui on chaine sur l impression des ‚tiquettes ----#
   If GDOCFLG = 2  & !GIMPORT & !GWEBSERV
      Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
      WPARAM(1) = num$([M:PKD0]VCRTYP)
      WPARAM(2) = [M:PKD0]VCRNUM
      GSVG_GACTION = GACTION
      GACTION = "SAIPKE"
      Call TRAITE_CHAR(WVALEUR,WPARAM,"FPKE","FUNPKE","",4,"SPEPKE") From GTRAITE
      GACTION = GSVG_GACTION
    Endif
Endif
WPICK=2
Gosub RAFFRAICHI
Raz [M:PKD1]PCKCAP                                                                                 # hcb 110327-pck bug
Affzo [M:PKD1]        # hcb 92799
[M:PKD0]PACNBR = LPACNBR
Affzo [M:PKD0]PACNBR
Return
#########################################################################
$ABA_TRTPKD
#########################################################################
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes d‚j… saisies    #
# effacement ecran pkd1                                                 #
#-----------------------------------------------------------------------#
Raz [M:PKD1]
[M:PKD1]BPTNUM = [M:PKD0]BPTNUM
[M:PKD1]BPTSHO = [M:PKD0]BPTSHO
If dim([M:PKS1]PREUSR) > 0                    # hcb 60766
   [M:PKD1]PREUSR = [M:PKS1]PREUSR            # hcb 60766
Endif                                         # hcb 60766

If GVCRTYP = 4
   [M:PKD1]LBLFMT = GDOCNAM
Endif

Affzo [M:PKD1]
If GCONSULT <> 2
   Actzo [M:PKD1]PACNUM
Endif
GMODPAC = 0
GRAPPAC = 0
GNBRLIG = 0
# pour reinitialiser la liste gauche
Raz WAFFPICK
Gosub TIROIR From FUNPKD

Return

#####################################################
# Enregistrement du colisage                        #
#####################################################
$ENR_COLISAGE
Local Integer NOL, WONE,  WSTAT
Local Char    WVOU(3)      : # Unit‚ volume
Local Char    WITMREF
Local Integer WVCRLIN
Raz WITMREF
Raz WVCRLIN
WONE = 2

Sorta [M:PKD1]NBLIG [M:PKD1]NBLIG Order By [M:PKD1]VCRLIN(indice)

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]
# dans le cas d une modification d un colisage existant on vire le colis
If GNBRLIG > 0
   Delete [SPH] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM & PACNUM = [M:PKD1]PACNUM
   Delete [SPD] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM & PACNUM = [M:PKD1]PACNUM
Endif


#----------------------------------------------------------------------------#
# Ecriture du detail du colis                               ecriture SPACKD  #
#----------------------------------------------------------------------------#

#----------------------------------------------------------------------------#
#   Point d'entree … la mise … jour d'un d‚tail colis         Pe  PACKDETMAJ #
#----------------------------------------------------------------------------#
WPOINT_CODTRT="A"
GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
If GOK < 1 Goto ABORT : Endif
Local Integer WLIN
Local Integer  LRET
Local Integer  LPACFLG   # flag colisage  2 = complet
Local Integer  LPACNBR   # nombre de colis
Local Decimal  LNETWEI   # Poids net du document
Local Decimal  LGROWEI   # Poids brut du document
Local Char     LWEU      # Unit‚ de poids du document
Local Decimal  LVOL      # Volume du document
Local Char     LVOU      # Unit‚ de volume du document
Local Integer  WOK
Local Date     LDAT      # date
Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
LDAT = date$

If [M:PKD1]PACNUM = ""
   Call NUM_PAC([M:PKD0]STOFCY,LDAT,[M:PKD1]PACNUM) From FUNPKD
   If [M:PKD1]PACNUM = ""
      Call ERREUR(mess(272,184,1)) From GESECRAN  # erreur codification numero colis
      Gosub ABORT
      Return
   Endif
   Call NUMERO_SSCC([M:PKD0]STOFCY,[M:PKD1]ITMREF(0),[M:PKD1]SCCCOD,LRET) From FUNPKD
   If LRET <> 0
      Gosub ABORT
      Return
   Endif
   Affzo [M:PKD1]PACNUM
   If [M:PKD1]SCCCOD <> ""
      Affzo [M:PKD1]SCCCOD
   Endif
Endif
Raz GNBRLIG
For nolign=1 To [M:PKD1]NBLIG
   # La ligne n'est pas colis‚e
    If [M:PKD1]QTY(nolign-1) = 0
       Goto NEXT_NOLIGN
    Endif
    GNBRLIG += 1
    If WVCRLIN <> [M:PKD1]VCRLIN(nolign-1)
       WVCRLIN =  [M:PKD1]VCRLIN(nolign-1)
       Raz WLIN
#recherche dernier rang
       Filter [SPD] Where  VCRTYP     = [M:PKD0]VCRTYP            &
&                          VCRNUM     = [M:PKD0]VCRNUM            &
&                          VCRLIN     = [M:PKD1]VCRLIN(nolign-1)  &
&                          PACNUM     = [M:PKD1]PACNUM
&                          Order By Key SPD0 Desc
       Read [SPD] First
       If fstat
          Raz [F:SPD]
       Endif
       WLIN = [F:SPD]PACIND
       Filter [SPD]
    Endif
    WLIN += 1
   # Ecriture du d‚tail colis
    [F:SPD]       = [M:PKD1]
#                                                                                                  # hcb 110327-pck deb
    If [M:PKD1]SERMGTCOD(nolign-1) = 4
       [F:SPD]SERDEB    = [M:PKD1]SERNUM   (nolign-1)          # Serie du colis
       [F:SPD]SERFIN    = [M:PKD1]SERFIN   (nolign-1)          # Serie du colis
       [F:SPD]SERORIDEB = [M:PKD1]SERORIDEB(nolign-1)          # Serie origine du document
       [F:SPD]SERORIFIN = [M:PKD1]SERORIFIN(nolign-1)          # Serie origine du document
       Raz [F:SPD]SERNUM
    Endif
#                                                                                                  # hcb 110327-pck fin
#    [F:SPD]QTYPCU = [F:SPD]QTY                                              # hcb x3-70246
    [F:SPD]QTYPCU = [M:PKD1]QTYSTU(nolign-1)                                 # hcb x3-70246
    [F:SPD]VCRTYP = [M:PKD0]VCRTYP
    [F:SPD]VCRNUM = [M:PKD0]VCRNUM
    [F:SPD]WEU    = [M:PKD1]LIGWEU(nolign-1)
    [F:SPD]ITMWEI = [M:PKD1]UNTWEI(nolign-1)
    [F:SPD]PACIND = WLIN
    [F:SPD]CPY    = GSOCIETE
    [F:SPD]STOFCY = [M:PKD0]STOFCY
    [F:SPD]CREDAT = date$
    [F:SPD]CREUSR = GUSER
    [F:SPD]EXPNUM = [C]EXPORT
    [F:SPD]PACSEQ = 1
#----------------------------------------------------------------------------#
#   Point d'entree … la mise … jour d'un d‚tail colis         Pe  PACKDETMAJ #
#----------------------------------------------------------------------------#
    WPOINT_CODTRT="C"
    GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
    If GOK < 1
       Break
    Endif

    Write [SPD]
    If fstat Call FSTA("SPD") From GLOCK : GOK=0 : Break Endif
    [M:PKD1]PACFLG(nolign-1) = 2
    If WITMREF = ""
       WITMREF = [F:SPD]ITMREF
    Endif
    If [F:SPD]ITMREF <> WITMREF
        WONE = 1
    Endif

$NEXT_NOLIGN
Next nolign

If GOK  = 0
   Gosub ABORT
   Return
Endif

If WLIN <>  0

#----------------------------------------------------------------------------#
# Ecriture de entete  colis                                 ecriture SPACK   #
#----------------------------------------------------------------------------#

   [F:SPH]       = [F:SPD]
   [F:SPH]       = [F:TPA]

   If GVCRTYP = 4
# Conversion prix emballage
      If [F:SDH]CUR <> GSYSCUR
         Call CONVERT(GSYSCUR,[F:SDH]CUR,GSYSCUR,[F:SDH]CHGTYP,date$,
&                     [F:TPA]PCKPRI,[F:SPH]PCKPRI,WSTAT) From TRTDEV
      Endif
     [F:SPH]CUR       = [F:SDH]CUR
     [F:SPH]CHGTYP    = [F:SDH]CHGTYP
   Else
     [F:SPH]CUR       = GSYSCUR
     [F:SPH]CHGTYP    = 1
   Endif
   [F:SPH]PKGTYP    = 1                 # declaratif
   [F:SPH]CPY       = GSOCIETE
   Raz [F:SPH]NETWEI
   If [M:PKD1]GROWEI > [M:PKD1]PCKWEI
      [F:SPH]NETWEI  = ([M:PKD1]GROWEI - [M:PKD1]PCKWEI)
   Endif
   [F:SPH]ONEITMFLG = WONE
   [F:SPH]LBLFMT    = [M:PKD1]LBLFMT
   [F:SPH]SPHTEX    = [M:PKD1]SPHTEX    # texte
   [F:SPH]PREUSR    = [M:PKD1]PREUSR    # pr‚parateur
   [F:SPH]SCCCOD    = [M:PKD1]SCCCOD    # code SSCC
   [F:SPH]BPCORD    = [M:PKD0]BPCORD    # client livr‚
   [F:SPH]PACSEQ    = 1
   [F:SPH]CREDAT    = date$             # hcb 60067
   [F:SPH]CREUSR    = GUSER
   #MAE, bg 83369
   [F:SPH]UPDUSR   = [F:SPD]UPDUSR
   [F:SPH]UPDDAT   = [F:SPD]UPDDAT
   [F:SPH]EXPNUM    = [C]EXPORT
   GPOINT = "BEFWRISPH"                 # hcb 73603
   Gosub ENTREE From EXEFNC             # hcb 73603
   Write [SPH]
   If fstat
      GOK = 0 : Call FSTA("SPH") From GLOCK : Return
   Endif
   If [F:SPH]SPHTEX <>""
      Call CRE_CLOB([F:SPH]SPHTEX ,GOK) From TRTX3TEX
      If GOK<1
         Return
      Endif
   Endif
Endif
#----------------------------------------------------------------------------#
#  calcul cumuls et  maj entˆte livraison  / preparation                     #
#----------------------------------------------------------------------------#
#  calcul cumuls et  maj entˆte livraison               reecriture SDELIVERY #


#FJCG - Inicio - AURENV12
Call OUVRE_TRACE("Problema volumen expedición: "+[M:PKD0]VCRNUM) From LECFIC
Call ECR_TRACE(" Problema volumen expedición: "+[M:PKD0]VCRNUM,0) From GESECRAN
#FJCG - Fin - AURENV12
Call COLISAGE_ORIGINE([M:PKD0]STOFCY,GVCRTYP,[M:PKD0]VCRNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
If GOK = 0 | LRET <> 0
   Gosub ABORT
   Return
Endif
If GVCRTYP = 4
# R‚‚criture de la livraison
   Readlock [SDH]SDH0=GWCLECUR
   If fstat
      GOK = 0 : Call RSTA("SDH",GWCLECUR) From GLOCK : Goto ABORT
   Endif

   Local Integer IJL
   IJL=sum(([F:SDH]GROWEI <> LGROWEI),
&          ([F:SDH]VOL    <> LVOL),
&          ([F:SDH]BPTNUM <> [M:PKD1]BPTNUM))

   [F:SDH]PACFLG = LPACFLG
   [F:SDH]PACNBR = LPACNBR
   [F:SDH]BPTNUM = [M:PKD1]BPTNUM

   [F:SDH]NETWEI = LNETWEI
   [F:SDH]GROWEI = LGROWEI
   [F:SDH]VOL    = LVOL
   If [F:SDH]VOU = ""
      [F:SDH]VOU = LVOU
   Endif
   #FJCG - Inicio - AURENV12
   If GTRACE<>""
   Call ECR_TRACE(" Antes RECH_TARIF. Vol.: "+num$(LVOL),0) From GESECRAN
   Endif
   #FJCG - Fin - AURENV12
# si livraison non valid‚e on calcul le tarif transporteur
   If [F:SDH]CFMFLG <> 2 & IJL
       Gosub RECH_TARIF_TRSP From TRTVENLIV
   Endif
# si livraison valid‚e on calcul le tarif transporteur … la demande
   If [F:SDH]CFMFLG = 2 & IJL
      Call OUINON(mess(279,184,1),WOK) From GESECRAN
      If WOK = 2
         Gosub RECH_TARIF_TRSP From TRTVENLIV
      Endif
   Endif
   #FJCG - Inicio - AURENV12
   If GTRACE<>""
   Call ECR_TRACE(" Después RECH_TARIF. Vol.: "+num$(LVOL)+" - "+num$([F:SDH]VOL),0) From GESECRAN
   Endif
   #FJCG - Fin - AURENV12

   Rewrite [SDH]

#  calcul cumuls et  maj entˆte preparation             reecriture STOPREH  #

Else
# R‚‚criture de la preparation
   Readlock [PRH]PRH0=GWCLECUR
   If fstat
      GOK = 0 : Call RSTA("PRH",GWCLECUR) From GLOCK : Goto ABORT
   Endif
   [F:PRH]PACFLG = LPACFLG
   [F:PRH]PACNBR = LPACNBR
   [F:PRH]BPTNUM = [M:PKD1]BPTNUM

   [F:PRH]NETWEI = LNETWEI
   [F:PRH]GROWEI = LGROWEI
   [F:PRH]WEU    = LWEU

   Rewrite [PRH]

Endif

Commit

#FJCG - Inicio - AURENV12
Call ECR_TRACE(" Fin problema volumen expedición: "+[M:PKD0]VCRNUM,0) From GESECRAN
Call FERME_TRACE From LECFIC
#FJCG - Fin - AURENV12
Return
Return


# Rollback suite … erreur
$ABORT
Rollback

Return

#########################################################################
$SUP_TRTPKD

Local Integer WOK

# confirmation de la suppression du colisage dans le cas ou l utilisateur n est pas parametre en confimation suppression
If GCONF (1) <> 2
   Call OUINON(mess(376,184,1),WOK) From GESECRAN
   If WOK <> 2
      Return
   Endif
Endif

# 101090 - Verify changes if BOL attached to shipment
Local Integer OK : OK = 2
Call VERIF_BOLMOD(OK) From SUBSDHB
If OK<>2 : GOK=0 : Return : Endif

Call DEBTRANS From GLOCK
GOK = 1

Trbegin [SPH]
Gosub ANU_COLISAGE
If GOK = 1
   Commit
Endif
Gosub ABA_TRTPKD         # sinon on rafraichi
Return


####################################################################
# Chargement d un colis suite saisie rubrique No colis             #
#                             selection browser "selection colis"  #
#                             selection rubrique No colis          #
####################################################################
$CHARGE_COLIS
If clalev([F:SPD1]) = 0 Local File SPACKD     [SPD1] Endif
Raz [PKD1]
# chargement entete

Local Integer I
Local Integer WSTOMGTCOD

# chargement bloc emballage
[M:PKD1]       = [F:TPA]
# chargement bloc colis
[M:PKD1]LBLFMT = [F:SPH]LBLFMT    # etiquette
[M:PKD1]PACNUM = [F:SPH]PACNUM    # nø colis
[M:PKD1]SPHTEX = [F:SPH]SPHTEX    # nø texte
[M:PKD1]BPTNUM = [M:PKD0]BPTNUM
[M:PKD1]BPTSHO = [M:PKD0]BPTSHO
[M:PKD1]PREUSR = [F:SPH]PREUSR    # pr‚parateur
[M:PKD1]SCCCOD = [F:SPH]SCCCOD    # code SSCC

Raz GWUNTWEI
Raz GWUNT
Raz GWWEU

# chargement detail
Filter [SPD1] Where[F:SPD1]VCRTYP    = [F:SPH]VCRTYP &
&                  [F:SPD1]VCRNUM    = [F:SPH]VCRNUM &
&                  [F:SPD1]PACNUM    = [F:SPH]PACNUM
&             Order By Key SPD0

For [SPD1]
    Raz AGR_RUPTURE
    Raz AGR_LECTURE
    If GVCRTYP = 4
       Read [SDD]SDD0=[F:SPD1]VCRNUM;[F:SPD1]VCRLIN
       If fstat
          Call RSTA ("SDD",[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK
          FOK=0
          Break        # hcb ctr
       Endif
    Else
       Read [PRE]PRE0=[F:SPD1]VCRNUM;[F:SPD1]VCRLIN
       If fstat
          Call RSTA ("PRE",[F:PRE]PRHNUM-num$([F:PRE]PRELIN)) From GLOCK
          FOK=0
          Break        # hcb ctr
       Endif
    Endif
    I = [M:PKD1]NBLIG
    If [F:ITM]ITMREF <> [F:SPD1]ITMREF
       Read [ITM]ITM0=[F:SPD1]ITMREF
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    WSTOMGTCOD = [F:ITM]STOMGTCOD
    GWUNTWEI = [F:SPD1]ITMWEI  # poids de l us
    GWUNT    = [F:SPD1]ITMWEI  # poids de l us
    GWWEU    = [F:SPD1]WEU     # unite de poids

    If GWWEU <> "" & [F:TPA]WEU <> ""
       If GWWEU <> [F:TPA]WEU
         # Conversion poids unitaire de unit‚ poids liv en unit‚ poids colis
          Call SCONV_TCO([F:ITM]WEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
       Endif
   Endif
# v‚rification gestion stock
    If [F:SPD1]STOFCY <>"" & [F:ITM]STOMGTCOD > 1                                                  # hcb 110327-pck    bug
#lecture ITMFACILIT  pour recuperer STOMGTCOD
       If [F:ITF]STOFCY <> [F:SPD1]STOFCY | [F:ITF]ITMREF <> [F:SPD1]ITMREF
          Read [ITF]ITF0 = [F:SPD1]ITMREF;[F:SPD1]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif
       WSTOMGTCOD = [F:ITF]STOMGTCOD
    Endif
    [M:PKD1]VCRLIN(I)           = [F:SPD1]VCRLIN
    [M:PKD1]ITMREF(I)           = [F:SPD1]ITMREF
    [M:PKD1]ITMDES1(I)          = [F:SPD1]ITMDES1
    If dim([M:PKD1]LOT)>0
           [M:PKD1]LOT(I)       = [F:SPD1]LOT
    Endif
    If dim([M:PKD1]SLO)>0
           [M:PKD1]SLO(I)       = [F:SPD1]SLO
    Endif
    [M:PKD1]PCKSERFLG(I)        = [F:ITF]PCKSERFLG                                                 # hcb 110327-pck
    [M:PKD1]SERMGTCOD(I)        = [F:ITM]SERMGTCOD                                                 # hcb 110327-pck
    If dim([M:PKD1]SERNUM)>0
       If [M:PKD1]SERMGTCOD(I) = 4                                                                 # hcb 110327-pck
          [M:PKD1]SERNUM   (I) = [F:SPD1]SERDEB     # serie du colis                               # hcb 110327-pck
          [M:PKD1]SERFIN   (I) = [F:SPD1]SERFIN     # serie du colis                               # hcb 110327-pck
          [M:PKD1]SERCOLDEB(I) = [F:SPD1]SERDEB     # serie du colis                               # hcb 110327-pck
          [M:PKD1]SERCOLFIN(I) = [F:SPD1]SERFIN     # serie du colis                               # hcb 110327-pck
          [M:PKD1]SERORIDEB(I) = [F:SPD1]SERORIDEB  # serie origine du document                    # hcb 110327-pck
          [M:PKD1]SERORIFIN(I) = [F:SPD1]SERORIFIN  # serie origine du document                    # hcb 110327-pck
       Else                                                                                        # hcb 110327-pck
          [M:PKD1]SERNUM(I)    = [F:SPD1]SERNUM
      Endif                                                                                        # hcb 110327-pck
    Endif
    If dim([M:PKD1]PALNUM)>0
           [M:PKD1]PALNUM(I)    = [F:SPD1]PALNUM
    Endif
    If dim([M:PKD1]CTRNUM)>0
           [M:PKD1]CTRNUM(I)    = [F:SPD1]CTRNUM
    Endif
#    [M:PKD1]QTYPCU    (I)       = [F:SPD1]QTYPCU                       # hcb x3-70246
    [M:PKD1]QTYPCU    (I)       = [F:SPD1]QTY                           # hcb x3-70246
    [M:PKD1]PCU       (I)       = [F:SPD1]PCU
    [M:PKD1]SAU       (I)       = [F:SPD1]SAU            # hcb 93756
    [M:PKD1]PCUSTUCOE (I)       = [F:SPD1]PCUSTUCOE
    [M:PKD1]STU       (I)       = [F:ITM]STU
    [M:PKD1]QTY       (I)       = [F:SPD1]QTY
    [M:PKD1]QTYSTU    (I)       = [M:PKD1]QTY(I) * [M:PKD1]PCUSTUCOE(I)
    Call QTEARR([M:PKD1]QTYSTU(I), [F:ITM]STU) From TRTDIV
    [M:PKD1]NETWEI    (I)       = [F:SPD1]NETWEI

   # Calcul poids de la ligne  en unite de l emballage
    [M:PKD1]NETWEIPCK(I)        = [M:PKD1]QTYSTU(I) * GWUNTWEI
    [M:PKD1]LIGUNTWEI(I)        = GWUNTWEI
    [M:PKD1]LIGWEU    (I)       = [F:SPD1]WEU
    [M:PKD1]UNTWEI    (I)       = GWUNT
    [M:PKD1]WSTOCOU   (I)       = [F:SPD1]WSTOCOU
    [M:PKD1]PCKSTKFLG (I)       = [F:SPD1]PCKSTKFLG
    [M:PKD1]PACFLG    (I)       = 2

    [M:PKD1]STOMGTCOD (I)       = WSTOMGTCOD
    [M:PKD1]NBLIG              += 1
Next

Filter [SPD1]

If GSSCCROOT <> ""
   If GSSCCCOU = ""
      [M:PKD0]SSCCGES = mess(271,184,1)     # Code SSCC partielle
   Else
      [M:PKD0]SSCCGES = mess(274,184,1)     # Code SSCC automatique
   Endif
Endif
[M:PKD1]GROWEI = [F:SPH]NETWEI + [F:SPH]PCKWEI
[M:PKD1]GROWEU = [F:SPH]WEU

Affzo [M:PKD0]
Affzo [M:PKD1]
If  [M:PKD1]NBLIG <> 0
    GNBRLIG = 1
    If [M:PKD1]PCK <> ""
       Grizo [M:PKD1]PCK
    Endif
    If [M:PKD1]PACNUM <> ""
       Grizo [M:PKD1]PACNUM
    Endif
Else
    GNBRLIG = 0
Endif

If GCONSULT = 2
   Grizo [M:PKD0]
   Grizo [M:PKD1]
Endif

GRAPPAC = 1
Close Local File [SPD1]
Return


#####################################################
# Annulation du colisage                            #
#####################################################
$ANU_COLISAGE
Local Integer  LRET
Local Integer  LPACFLG   # flag colisage  2 = complet
Local Integer  LPACNBR   # nombre de colis
Local Decimal  LNETWEI   # Poids net du document
Local Decimal  LGROWEI   # Poids brut du document
Local Char     LWEU      # Unit‚ de poids du document
Local Decimal  LVOL      # Volume du document
Local Char     LVOU      # Unit‚ de volume du document

Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
Raz LRET

If [M:PKD1]PACNUM <> ""
# Suppression d un colis
   If [F:SPH]SPHTEX <> ""
      If left$([F:SPH]SPHTEX,3)="SPH"
         Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
      Endif
   Endif
   Raz LRET
   Delete [SPH] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM & PACNUM = [M:PKD1]PACNUM
   Delete [SPD] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM & PACNUM = [M:PKD1]PACNUM
Else
   Filter [SPH] Where  VCRTYP   = GVCRTYP           &
&                      VCRNUM   = [M:PKD0]VCRNUM
&               Order By Key SPH0
   For [SPH]
       If [F:SPH]SPHTEX <> ""
          If left$([F:SPH]SPHTEX,3)="SPH"
             Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
          Endif
       Endif
   Next
   Filter [SPH]
   Raz LRET
# Suppression de tous les colis d un document
   Delete [SPH] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM
   Delete [SPD] Where VCRTYP = GVCRTYP  & VCRNUM = [M:PKD0]VCRNUM
Endif
Call COLISAGE_ORIGINE([M:PKD0]STOFCY,GVCRTYP,[M:PKD0]VCRNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
If GOK = 0 | LRET <> 0
   Gosub ABORT
   Return
Endif
If GVCRTYP = 4
# R‚‚criture de la livraison
   Readlock [SDH1]SDH0=[M:PKD0]VCRNUM
   If fstat
      GOK = 0 : Call RSTA("SDH1",[M:PKD0]VCRNUM) From GLOCK : Goto ABORT
   Endif
   Local Integer IJL
   IJL=sum(([F:SDH1]GROWEI <> LGROWEI),
&          ([F:SDH1]VOL    <> LVOL),
&          ([F:SDH1]BPTNUM <> [M:PKD1]BPTNUM))

   [F:SDH1]PACFLG = LPACFLG
   [F:SDH1]PACNBR = LPACNBR
   [F:SDH1]BPTNUM = [M:PKD1]BPTNUM

   [F:SDH1]NETWEI = LNETWEI
   [F:SDH1]GROWEI = LGROWEI
   [F:SDH1]VOL    = LVOL
   If [F:SDH1]VOU = ""
      [F:SDH1]VOU = LVOU
   Endif
# si livraison non valid‚e on calcul le tarif transporteur
   If [F:SDH1]CFMFLG <> 2 & IJL
       Gosub RECH_TARIF_TRSP From TRTVENLIV
   Endif
   Rewrite [SDH1]
   [F:SDH]PACFLG = LPACFLG    # 80235
   [F:SDH]PACNBR = LPACNBR    # hcb 83982
Else
# R‚‚criture de la pr‚paration
   Readlock [PRH1]PRH0=[M:PKD0]VCRNUM
   If fstat
      GOK = 0 : Call RSTA("PRH1",[M:PKD0]VCRNUM) From GLOCK : Goto ABORT
   Endif
   [F:PRH1]PACNBR = LPACNBR
   [F:PRH1]PACFLG = LPACFLG

   [F:PRH1]NETWEI = LNETWEI
   [F:PRH1]GROWEI = LGROWEI
   If LGROWEI = 0
      Raz LWEU
   Endif
   [F:PRH1]WEU    = LWEU
   Rewrite [PRH1]
   [F:PRH]PACFLG = LPACFLG    # 80235
   [F:PRH]PACNBR = LPACNBR    # hcb 83982
Endif
[M:PKD0]PACNBR = LPACNBR   # hcb 83982
Affzo [M:PKD0]PACNBR       # hcb 83982

Return

#########################################################################
$AVANT_PREMIER_TRTPKD

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif
Return

$PREMIER_TRTPKD
If GVCRTYP = 4
   Read [SDH]SDH0 First
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
   GWCLECUR = [F:SDH]SDHNUM   # hcb 83982
Else
   Read [PRH]PRH0 First
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
   GWCLECUR = [F:PRH]PRHNUM   # hcb 83982
Endif

Gosub CHARGE_ENTETE
Affzo [M:PKD1]BPTNUM
Affzo [M:PKD1]BPTSHO
Raz WAFFPICK
Gosub TIROIR From FUNPKD
Affzo [M:PKD0]
Affzo [M:PKD1]

Return

#########################################################################
$AVANT_DERNIER_TRTPKD

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return


$DERNIER_TRTPKD
If GVCRTYP = 4
   Read [SDH]SDH0 Last
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
   GWCLECUR = [F:SDH]SDHNUM   # hcb 83982
Else
   Read [PRH]PRH0 Last
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
   GWCLECUR = [F:PRH]PRHNUM   # hcb 83982
Endif

Gosub CHARGE_ENTETE
Affzo [M:PKD1]BPTNUM
Affzo [M:PKD1]BPTSHO
Raz WAFFPICK
Gosub TIROIR From FUNPKD
Affzo [M:PKD0]
Affzo [M:PKD1]

Return




#########################################################################
$AVANT_SUI_TRTPKD

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return

#########################################################################
$SUI_TRTPKD
GMODPAC = 0
GRAPPAC = 0
GNBRLIG = 0
Gosub DEVERROU
If GVCRTYP = 4
   Gosub NEXT_SDH
Else
   Gosub NEXT_PRH
Endif
If FIN = 1
   Call MESSAGE(mess(11,100,1)) From GESECRAN
   FIN = 0
Endif
Return

#########################################################################
$AVANT_PRE_TRTPKD

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return

#########################################################################
$PRE_TRTPKD
GMODPAC = 0
GRAPPAC = 0
GNBRLIG = 0
Gosub DEVERROU

If GVCRTYP = 4
   Read [SDH]SDH0 Prev
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto PREV_SDH
      Elsif VOK=0
         Gosub FIN_PRE_TRTPKD
         Return
      Endif
   Else
      Gosub FIN_PRE_TRTPKD
      Return
   Endif
$PREV_SDH
   Gosub CHARGE_ENTETE
Else
   Read [PRH]PRH0 Prev
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto PREV_PRH
      Elsif VOK=0
         Gosub FIN_PRE_TRTPKD
         Return
      Endif
   Else
      Gosub FIN_PRE_TRTPKD
      Return
   Endif
$PREV_PRH
   Gosub CHARGE_ENTETE
Endif
Raz WAFFPICK
Gosub TIROIR From FUNPKD

Affzo [M:PKD0]
Affzo [M:PKD1]

Return

$FIN_PRE_TRTPKD
Call MESSAGE(mess(11,100,1)) From GESECRAN
Return


#########################################################################

$NEW_TRTPKD
Raz [M:PKD1]
#If [F:TPA]PCK <> ""                           55924
#   [M:PKD1]       = [F:TPA]
#    Gosub TOT_GROWEI From FUNPKD
#Endif

[M:PKD1]BPTNUM = [M:PKD0]BPTNUM
[M:PKD1]BPTSHO = [M:PKD0]BPTSHO

If dim([M:PKS1]PREUSR) > 0                    # hcb 57408
   [M:PKD1]PREUSR = [M:PKS1]PREUSR            # hcb 57408
Endif                                         # hcb 57408

If GVCRTYP = 4
   [M:PKD1]LBLFMT = GDOCNAM
Endif
Affzo [M:PKD1]
Actzo [M:PKD1]
If GSSCCROOT <> "" & GSSCCCOU <> ""
   Diszo [M:PKD1]PACNUM
Else
   Actzo [M:PKD1]PACNUM
Endif

# pour reinitialiser la liste gauche
Raz WAFFPICK
GRAPPAC = 0
Gosub TIROIR From FUNPKD

# GMODPAC = 1
GMODPAC = 0          # 55924
GNBRLIG = 0          # 55924


Return

#########################################################################
$FIN_TRTPKD
If NBLIV = 0
   Call MESSAGE(mess(104,199,1)) From GESECRAN
Endif

Gosub DEVERROU
If GVCRTYP = 4
   Filter [SDH]
Else
   Filter [PRH]
Endif
If GACTION = "SAIPKD"
   GFLAG   = GSAVGFLAG
Endif

Return


###########################################################
# calcul poids du colis
###########################################################

$TOT_GROWEI
Raz [M:PKD1]GROWEI
Raz [M:PKD1]GROWEU

If [M:PKD1]PCK <> ""
   [M:PKD1]GROWEI  = sum([M:PKD1]NETWEIPCK(0..max([M:PKD1]NBLIG-1,nolign-1)))
   [M:PKD1]GROWEI += [M:PKD1]PCKWEI
   [M:PKD1]GROWEU  = [M:PKD1]WEU
Endif
Affzo [M:PKD1]GROWEI                                        # hcb 119241
Gosub TOT_GROCAP      # hcb 62874

GPOINT="TOT_GROWEI"         # hcb 99469
Gosub ENTREE From EXEFNC    # hcb 99469



Return

#                          # hcb 62874 deb
###########################################################
# calcul capacit‚ emballage du colis
###########################################################

$TOT_GROCAP

Raz [M:PKD1]GROCAP

If [M:PKD1]PCKCAP <> 0
   [M:PKD1]GROCAP  = sum([M:PKD1]QTYSTU(0..max([M:PKD1]NBLIG-1,nolign-1)))
Endif
Affzo [M:PKD1]GROCAP

Return

###########################################################
# Avant zone : Colorisation des lignes non colis‚es
###########################################################
$PKDCOLOR
pcolor = GCOUL(0)
If [M:PKD1]QTY   (nolign-1) =  0  & [M:PKD1]QTYSTU(nolign-1) =  0 & [M:PKD1]QTYPCU(nolign-1) <> 0
   pcolor = GCOUL(1)
Endif
Return
#                          # hcb 62874 fin



###########################################################
# calcul poids d une ligne
###########################################################

$CAL_NETWEI
If [M:PKD1]PCK = ""
   Return
Endif
For I = 0 To [M:PKD1]NBLIG-1
   If [M:PKD1]ITMREF(I) <> "" & [M:PKD1]LIGWEU(I) <> ""
      GWUNTWEI = [M:PKD1]UNTWEI(I)                                             # hcb 54843
      If [M:PKD1]LIGWEU(I) <> [F:TPA]WEU
        # Conversion poids unitaire de unit‚ poids liv en unit‚ poids colis
         Call SCONV_TCO([M:PKD1]LIGWEU(I),[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
      Endif
      [M:PKD1]NETWEIPCK(I) = [M:PKD1]QTYSTU(I) * GWUNTWEI
      [M:PKD1]LIGUNTWEI(I) = GWUNTWEI
   Endif
Next

Return

#                                                                                # hcb 104087 deb
