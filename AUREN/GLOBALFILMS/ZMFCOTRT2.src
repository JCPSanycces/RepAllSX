$ACTION
Return


# Gestión de la máscara ZMFGCOR3 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMFGCOR3) 01/03/2016 08:20:31 (ADMIN)
######################################################################################
Subprog IB_NBLOT
If [M:MFG1]ALLSTA = 1
   GBOUT2 = "Borrar Materia"
Else
   GBOUT2 = ""
Endif
End

Subprog B2_NBLOT
Local Integer NOL: NOL = nolign - 1
If [M:ZMFC3]NBLOT>0
# Borrado Lote
#
   Dela NOL,1 [M:ZMFC3]ITMREF,[M:ZMFC3]LOT,[M:ZMFC3]SLO,[M:ZMFC3]ZANCHO,[M:ZMFC3]ZLONGITUD,[M:ZMFC3]ZMANDRIL,
&        [M:ZMFC3]ZNCORTES, [M:ZMFC3]ZPROVEEDOR, [M:ZMFC3]QTYSTU, [M:ZMFC3]ZQTYSTUREAL, [M:ZMFC3]STU, [M:ZMFC3]LOC,
&        [M:ZMFC3]ZGRPCOR, [M:ZMFC3]ZSOBRANTE ,[M:ZMFC3]ZLONGSOB, [M:ZMFC3]STOCOU

    [M:ZMFC3]NBLOT -= 1
    Affzo [M:ZMFC3]10
Endif
Call SUMA_QTYREAL
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMFGCOR3) 31/03/2016 09:36:59 (ADMIN)
######################################################################################
Subprog IB_ZLONGITUD
End


######################################################################################



Subprog C_ZQTYSTUREAL(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 : mkstat = 2 : End : Endif
Call SUMA_QTYREAL
End

Subprog SUMA_QTYREAL
[M:ZMFC3]ZSELQTYSTU=0
[M:ZMFC3]ZSELQTYBOB = 0
[M:ZMFC3]ZSELQTYSTU = 0
[M:ZMFC3]ZSELSUPERF = 0
[M:ZMFC3]ZSELLONG   = 0
For I = 0 To [M:ZMFC3]NBLOT - 1
   If I=0 Then
          [M:ZMFC3]ZSELSTU=[M:MFG2]ZLTSTU(I)
   Endif
   [M:ZMFC3]ZSELQTYSTU += [M:ZMFC3]ZQTYSTUREAL(I)
   [M:ZMFC3]ZSELQTYBOB += 1
   [M:ZMFC3]ZSELSUPERF += ([M:ZMFC3]ZLONGITUD(I)*[M:ZMFC3]ZANCHO(I) / 1000)
   [M:ZMFC3]ZSELLONG   += [M:ZMFC3]ZLONGITUD(I)
Next
Affzo [M:ZMFC3]5
End
######################################################################################
