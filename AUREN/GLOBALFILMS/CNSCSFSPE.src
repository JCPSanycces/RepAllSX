#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTRE -> Para construir filtro especifico para la consulta CSF (Lineas de entregas)
$ACTION
Case ACTION
   When "OUVRE"    :   Gosub OUVRE
   When "FILTRE"   :   Gosub FILTRE
   When "AV_AFFICHE"    : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:SDDX])= 0 : Local File SDELIVERYD [SDDX] : Endif
Return

$FILTRE
Raz [M:CSF1]ZTOTBOB
Raz [M:CSF1]ZTOTKG
Raz [M:CSF1]ZTOTM2
Raz [M:CSF1]ZTOTIMP
Affzo [M:CSF1]ZTOTBOB
Affzo [M:CSF1]ZTOTKG
Affzo [M:CSF1]ZTOTM2
Affzo [M:CSF1]ZTOTIMP

If [M:CSF1]ZREPDEB<>""
   WFIL2+="&[F:SDD]REP1>='"+[M:CSF1]ZREPDEB+"'"
Endif
If [M:CSF1]ZREPFIN<>""
   WFIL2+="&[F:SDD]REP1<='"+[M:CSF1]ZREPFIN+"'"
Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif

For F=0 To [M:CSF2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CSF2]ITMREF(F)
   Raz [F:SDDX]
   Read [SDDX]SDD0=[M:CSF2]SDHNUM(F);[M:CSF2]SDDLIN(F)
   If [F:SDDX]SAU="M2"
      [M:CSF2]ZQTYKG(F)=arr([F:SDDX]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSF2]ZQTYM2(F)=arr([F:SDDX]QTY,0.01)
   Endif
   If [F:SDDX]SAU="KG"
      [M:CSF2]ZQTYKG(F)=arr([F:SDDX]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSF2]ZQTYM2(F)=arr([F:SDDX]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSF2]ZQTYM2(F)=0
      Endif
   Endif
Next
Return

$CAL_CUMUL
Raz [M:CSF1]ZTOTBOB
Raz [M:CSF1]ZTOTKG
Raz [M:CSF1]ZTOTM2
Raz [M:CSF1]ZTOTIMP
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDD0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:SDD]ITMREF

   [M:CSF1]ZTOTBOB+=[F:SDD]ZQTYBOB
   If [F:SDD]SAU="M2"
      [M:CSF1]ZTOTKG+=arr([F:SDD]QTY*[F:ITM]ZFACTOR,0.01)
      [M:CSF1]ZTOTM2+=arr([F:SDD]QTY,0.01)
   Endif
   If [F:SDD]SAU="KG"
      [M:CSF1]ZTOTKG+=arr([F:SDD]QTY,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CSF1]ZTOTM2+=arr([F:SDD]QTY/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CSF1]ZTOTM2+=0
      Endif
   Endif
   [M:CSF1]ZTOTIMP+=[F:SDD]QTY*[F:SDD]NETPRINOT
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CSF1]ZTOTBOB
Affzo [M:CSF1]ZTOTKG
Affzo [M:CSF1]ZTOTM2
Affzo [M:CSF1]ZTOTIMP
Return
