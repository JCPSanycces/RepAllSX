#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta CSD (Lista de entregas)
$ACTION
Case ACTION
   When "OUVRE"    :   Gosub OUVRE
   When "FILTRE"   :   Gosub FILTRE
   When "AV_AFFICHE"    : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:SDD])= 0 : Local File SDELIVERYD [SDD] : Endif
If clalev([F:ITM])= 0 : Local File ITMMASTER  [ITM] : Endif
Return

$FILTRE
Raz [M:CSD1]ZTOTKG
Raz [M:CSD1]ZTOTM2
Raz [M:CSD1]ZTOTIMPAI
Raz [M:CSD1]ZTOTIMPII
Affzo [M:CSD1]ZTOTKG
Affzo [M:CSD1]ZTOTM2
Affzo [M:CSD1]ZTOTIMPAI
Affzo [M:CSD1]ZTOTIMPII

If [M:CSD1]ZSHIDATDEB<>[0/0/0]
   WFIL2+="&[F:SDH]SHIDAT>=[M:CSD1]ZSHIDATDEB"
Endif
If [M:CSD1]ZSHIDATFIN<>[0/0/0]
   WFIL2+="&[F:SDH]SHIDAT<=[M:CSD1]ZSHIDATFIN"
Endif
If [M:CSD1]ZREPDEB<>""
   WFIL2+="&[F:SDH]REP(0)>=[M:CSD1]ZREPDEB"
Endif
If [M:CSD1]ZREPFIN<>""
   WFIL2+="&[F:SDH]REP(0)<=[M:CSD1]ZREPFIN"
Endif
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$CAL_CUMUL
Raz [M:CSD1]ZTOTKG
Raz [M:CSD1]ZTOTM2
Raz [M:CSD1]ZTOTIMPAI
Raz [M:CSD1]ZTOTIMPII
Filter [SDH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDH0
For [SDH]
   [M:CSD1]ZTOTIMPAI+=[F:SDH]DLVNOT
   [M:CSD1]ZTOTIMPII+=[F:SDH]DLVATI
   Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM
   For [SDD]
      Raz [F:ITM]
      Read [ITM]ITM0=[F:SDD]ITMREF
      If [F:SDD]SAU="M2"
         [M:CSD1]ZTOTKG+=arr([F:SDD]QTY*[F:ITM]ZFACTOR,0.01)
         [M:CSD1]ZTOTM2+=arr([F:SDD]QTY,0.01)
      Endif
      If [F:SDD]SAU="KG"
         [M:CSD1]ZTOTKG+=arr([F:SDD]QTY,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CSD1]ZTOTM2+=arr([F:SDD]QTY/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CSD1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [SDD]
Next
Filter [SDH]
Return

$AFF_CUMUL
Affzo [M:CSD1]ZTOTKG
Affzo [M:CSD1]ZTOTM2
Affzo [M:CSD1]ZTOTIMPAI
Affzo [M:CSD1]ZTOTIMPII
Return
