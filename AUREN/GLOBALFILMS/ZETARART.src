#<AdxTL>@(#)0.0.0.0 $Revision$
#BUSCAR_ART -> Llena el primer grid con los articulos que cumplen el criterio
#ANADIR_ART -> Pasa los articulos selccionados en el primer grid al segundo
#GRABAR_ART -> Inserta en la tabla de trabajo ZETARART
#CARGAR_ART -> Cargar el segundo grid con el contenido de la tabla de trabajo ZETARART
#BORRAR_ART -> Borrar la tabla de trabajo utilizada para el envio de tarifas
$ACTION
#--- Actions liťes au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "FINSAI"    : Gosub FINSAI
 When "BOUTON"   :
    Case BOUT :
        When "B" : Gosub BUSCAR_ART
        When "A" : Gosub ANADIR_ART
        When "G" : Gosub GRABAR_ART
        When "C" : Gosub CARGAR_ART
        When "D" : Gosub BORRAR_ART
        When "I" : Call SELECT_ALL(2)
        When "E" : Call SELECT_ALL(1)
    Endcase
Endcase

Return

$OUVRE
If clalev([F:ITM])<=0   : Local File ITMMASTER   [ITM]  :  Endif
If clalev([F:ZCIT])<=0  : Local File ZBPCITMTAR  [ZCIT]  :  Endif
If clalev([F:ZTACD])<=0 : Local File ZTARCTED    [ZTACD] : Endif
If clalev([F:ZETA])<=0  : Local File ZETARART    [ZETA] :  Endif
Return


$SETBOUT
If !find( 2, [M:ZETA]FLG(0..[M:ZETA]NBLIG1-1))
   Call VIREBOUT(CHMEN,"A") From GOBJET
Endif
Return

$FINSAI
Return

$DEBUT
Raz [M:ZETA]
Affzo [M:ZETA]1-99
Call ERREURT (ACTION+"\15-05-17 JLPR\Proceso en desuso", 1) From GESECRAN   #0-Informativo, 1-Error
FIN=1
Return

$BUSCAR_ART
Local Integer I, LMAXART
Local Char CRITERE(250)

LMAXART=600

CRITERE="1=1"
If [M:ZETA]ITMREFDEB<>""
   CRITERE-="& [F:ITM]ITMREF>='"+[M:ZETA]ITMREFDEB+"'"
Endif
If [M:ZETA]ITMREFFIN<>""
   CRITERE-="& [F:ITM]ITMREF<='"+[M:ZETA]ITMREFFIN+"'"
Endif
If [M:ZETA]TSICOD0DEB<>""
   CRITERE-="& [F:ITM]TSICOD(0)>='"+[M:ZETA]TSICOD0DEB+"'"
Endif
If [M:ZETA]TSICOD0FIN<>""
   CRITERE-="& [F:ITM]TSICOD(0)<='"+[M:ZETA]TSICOD0FIN+"'"
Endif

Filter [ITM] Where evalue(CRITERE)
I=0
For [ITM]
   [M:ZETA]FLG(I)    =1
   [M:ZETA]ITMREF1(I)=[F:ITM]ITMREF
   I+=1
   If I>=LMAXART
      Break
   Endif
Next
Filter [ITM]
[M:ZETA]NBLIG1=I
Affzo [M:ZETA]10
Return

$ANADIR_ART
Local Integer I, J, CL, YAESTA

For I=0 To [M:ZETA]NBLIG1-1
   For CL=0 To [M:ZETC1]NBLIG-1
      If [M:ZETA]FLG(I)=2
         YAESTA=1
         For J=0 To [M:ZETA]NBLIG2-1
            If [M:ZETA]ITMREF1(I)=[M:ZETA]ITMREF2(J)
               YAESTA=2
               Break
            Endif
         Next
         If YAESTA=1
            [M:ZETA]ITMREF2([M:ZETA]NBLIG2)=[M:ZETA]ITMREF1(I)
            [M:ZETA]NBLIG2+=1
            If [M:ZETA]NBLIG2>=2000
               Break
            Endif
         Endif
      Endif
   Next
Next
Affzo [M:ZETA]15
Return

$BORRAR_ART
Local Integer WRESP

Wrnbox "Seguro? " Using WRESP
If WRESP<>1
   Return
Endif

Delete [F:ZETA] Where CREUSR=GUSER
If fstat
   Infbox "Error borrando [ZETA] - fstat: "+num$(fstat)
Endif
Return

#Se graban en la tabla todas las combinaciones de los clientes y articulos seleccionados.
$GRABAR_ART
Local Integer I, J
For I=0 To [M:ZETC1]NBLIG-1
   For J=0 To [M:ZETA]NBLIG2-1
      If len([M:ZETA]ITMREF2(J))>0
         [F:ZETA]SALFCY=[M:ZETC0]SALFCY
         [F:ZETA]BPCNUM=[M:ZETC1]BPCNUM(I)
         [F:ZETA]ITMREF=[M:ZETA]ITMREF2(J)
         [F:ZETA]CREUSR=GUSER
         [F:ZETA]CREDAT=date$
         #  [ZCIT] ZBPCITMTAR   NO ES MULTIPLANTA pues su PK = BPCNUM+ITMREF+LONGITUD, habrŪa que aŮadir SALFCY para que lo fuera
         Filter [ZCIT] Where BPCNUM=[F:ZETA]BPCNUM and ITMREF=[F:ZETA]ITMREF #and SALFCY=[F:ZETA]SALFCY
         For [ZCIT]
            [F:ZETA]PLI       = [F:ZCIT]PLI
            [F:ZETA]ZLONGITUD = [F:ZCIT]ZLONGITUD
            Raz [F:ZTACD]
            Read [ZTACD]ZTACD0=[F:ZETA]SALFCY;[F:ZETA]BPCNUM;[F:ZETA]ITMREF;[F:ZETA]ZLONGITUD#;[F:ZETA]PLI
            [F:ZETA]PRI  = [F:ZTACD]PRI
            Write [F:ZETA]
#            When 3 # Clave duplicada, significa que ya se indiců un precio para ese Cte+Art+Long. No tener sentido, debido a que es la primera que generamos........Antes era la ķltima
            Case fstat
            When 0
            When Default
                  Infbox "Error grabando [ZETA] - fstat: "+num$(fstat)+" Cte.: "+[F:ZETA]BPCNUM+" Art.: "+[M:ZETA]ITMREF2(J)+
&                        " Tar.: "+[F:ZETA]PLI+" Long.: "+num$([M:ZETA]ZLONGITUD)
            Endcase
#            If fstat
#               If fstat<>3
#                  Infbox "Error grabando [ZETA] - fstat: "+num$(fstat)+" Cte.: "+[F:ZETA]BPCNUM+" Art.: "+[M:ZETA]ITMREF2(J)+
#&                        " Tar.: "+[F:ZETA]PLI+" Long.: "+num$([M:ZETA]ZLONGITUD)
#               Endif
#            Endif
         Next
         Filter [ZCIT]
      Endif
   Next
Next
Return

#Lee la tabla ZETARART y carga el grid de los articulos a enviar tarifa, solo una linea por artŪculo
$CARGAR_ART
Local Integer I, J, YAESTA

#Se inicializa primero el grid
Raz [M:ZETA]ITMREF2
Raz [M:ZETA]NBLIG2
Affzo [M:ZETA]15

#Se carga el grid
Filter [ZETA] Where CREUSR=GUSER Order By ITMREF
I=0
For [ZETA]
   YAESTA=1
   For J=0 To I
      If [M:ZETA]ITMREF2(J)=[F:ZETA]ITMREF
         YAESTA=2
         Break
      Endif
   Next
   If YAESTA=1
      [M:ZETA]ITMREF2(I)=[F:ZETA]ITMREF
      I+=1
   Endif
Next
Filter [ZETA]

[M:ZETA]NBLIG2=I
Affzo [M:ZETA]15
Return

Subprog SELECT_ALL(PON)
Value Integer PON

Local Integer I
For I=0 To [M:ZETA]NBLIG1-1
    If PON=2
       [M:ZETA]FLG(I) = 2
    Else
       [M:ZETA]FLG(I) = 1
    Endif
Next I
Affzo [M:ZETA]FLG
End
