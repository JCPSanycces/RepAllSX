#<AdxTL>@(#)0.0.0.0 $Revision$
#ALISCRSLP -> PE para inicializar el numero de etiquetas a imprimir al numero de bobinas      ...viene de fuente SUBSLPB.src
#MAJ_LBP   -> PE para grabar campos especificos en tabla   LABELPRN                           ...viene de fuente SUBSLPB.src
#RELOAD    -> PE para evitar que se cargue la rejilla despues de la impresión de las etiquetas...viene de fuente SUBSLPA.src
#BEFFILSPR -> PE para ańadir filtros a la seleccion de registros                              ...viene de fuente SUBSLPB.src
#SORTASLP  -> PE justo antes de empezar la impresión  Subprog PRINT(PRET)                     ...viene de fuente SUBSLPB.src

$ACTION
#Infbox "HOLA DESDE ZPESUBSLPB      action="+ACTION
   Case ACTION
      When "BEFFILSPR"   :   Gosub BEFFILSPR
      When "ALISCRSLP"   :   Gosub ALISCRSLP
      When "MAJ_LBP"     :   Gosub MAJ_LBP
      When "SORTASLP"    :   Gosub SORTASLP

      When "RELOAD"
        GPE=1
   Endcase
Return

$SORTASLP
If [M:SLP]ZSTAT="R"
  Infbox "NO IMPRIMA !!!!     FALTAN BOBINAS !!!!       Superado limite de "+num$([M:SLP]ZFLD)+" bobinas x OF"
  Raz [M:SLP]NBLIG
Endif
Return


$BEFFILSPR
#Ańadir filtros a la seleccion de registros
#If [M:SLP]ZANCHOF>0
#  FILSUP += " & ZANCHO=[M:SLP]ZANCHOF"
#Endif
#If [M:SLP]ZLARGO>0
#  FILSUP += " & ZLONGITUD=[M:SLP]ZLARGO"
#Endif
Return

$ALISCRSLP
# Llenado de la rejilla
Onerrgo ERRORES_FIN
Case [M:SLP]LBEVCRTYP
When 10
  Gosub DEC_OF
When 15
  Gosub DEC_PROD
Endcase
Onerrgo
Return

$ DEC_OF
Local Integer BOB,PED,F,L,INI,FIN,IMPLOGO
Local Char LOT(GLONLOT),SLOT(GLONSLO),LOTORI(GLONLOT),MSG(255),CTEPED(40),TREXT(80),TRINT(80),VALOR(GLONID1)(2),CTEDES(GLONDES)
#
If [M:SLP]ZTRATINT + [M:SLP]ZTRATEXT = ""
  Call AM_VCRNUMSTR([M:SLP]VCRNUM(nolign-1)) From SPESLP
  [M:SLP]ZTIPETI=1
Endif
#
#If GFONCTION="GESMFG"
#  If nolign-1<=0
#    Call AM_ZTIPETI([M:SLP]ZTIPETI) From SPESLP
#  Endif
#Elsif [M:SLP]NBLIG-1<=0
#    Call AM_ZTIPETI([M:SLP]ZTIPETI) From SPESLP
#Endif
If nolign-1<=0
    Call AM_ZTIPETI([M:SLP]ZTIPETI) From SPESLP
    [M:SLP]ZFLD=func ZCOMUN.FILAS_GRID("STOLBEIMP", "NBLIG")
Else
  [M:SLP]LBEFMT(nolign-1)   = [M:SLP]LBEFMT(nolign-2)
  [M:SLP]PRT(nolign-1)      = [M:SLP]PRT(nolign-2)
  [M:SLP]SERIMP(nolign-1)   = [M:SLP]SERIMP(nolign-2)
  [M:SLP]DEFIMP(nolign-1)   = [M:SLP]DEFIMP(nolign-2)
Endif
# Determino textos para tratamiento interior y exterior
VALOR(0)="23"
VALOR(1)=[M:SLP]ZTRATINT
TRINT=func ZCOMUN.TRADUCIR_VALOR_CAMPO("ATABDIV", VALOR, GLANGUE, 3)
VALOR(0)="22"
VALOR(1)=[M:SLP]ZTRATEXT
TREXT=func ZCOMUN.TRADUCIR_VALOR_CAMPO("ATABDIV", VALOR, GLANGUE, 3)


# Saco lotes y sublotes del GC...puede haber mas de uno por los empalmes....Mostramos el 1ş
Call LOTE_ORIGEN([F:MFI]MFGNUM,[F:MFI]MFGLIN,[M:SLP]STOFCY,0,LOT,SLOT,LOTORI) From SPESLP

# Una linea por cada bobina
BOB=[F:MFI]ZQTYBOB
INI=nolign-1 # Me guardo fila inicial
# Ańado para siguiente una linea
For F=1 To BOB
  # Completo la que viene de SUBSLPB.src
  [M:SLP]LBENBR(nolign-1)   = 1
  [M:SLP]ZFECPROD(nolign-1) = [M:SLP]ZENDDAT
  [M:SLP]ZTRATINTR(nolign-1)= TRINT
  [M:SLP]ZTRATEXTR(nolign-1)= TREXT
  [M:SLP]ZLOT(nolign-1)     = LOT
  [M:SLP]ZSLOT(nolign-1)    = SLOT
  [M:SLP]ZLOTORI(nolign-1)  = LOTORI
#  [M:SLP]ZLOTPT(nolign-1)   = ""   # Su valor se asigna en SPESLP.BOUTON
  If F=1
    If [F:MFI]ZQTYBOBUNI>0
      [M:SLP]QTYSTU(nolign-1) = [F:MFI]ZQTYBOBUNI
    Else
      [M:SLP]QTYSTU(nolign-1) = [M:SLP]QTYSTU(nolign-1)/[F:MFI]ZQTYBOB
    Endif
  Endif
  [M:SLP]ZNBLIG(nolign-1)    = nolign-1
  If F<BOB
    If nolign>=[M:SLP]ZFLD
      If [M:SLP]ZSTAT=""
        Infbox "NO IMPRIMA !!!!     FALTAN BOBINAS !!!!       Superado limite de "+num$([M:SLP]ZFLD)+" bobinas x OF"
      Endif
      [M:SLP]ZSTAT="R"
      Break
    Else
      nolign+=1
      #Igualo valores de resto columnas en nueva fila con la anterior
      [M:SLP]TRT(nolign-1)      = 2 #[M:SLP]TRT(nolign-2)
      [M:SLP]VCRNUM(nolign-1)   = [M:SLP]VCRNUM(nolign-2)
      [M:SLP]VCRLIN(nolign-1)   = [M:SLP]VCRLIN(nolign-2)
      [M:SLP]ITMREF(nolign-1)   = [M:SLP]ITMREF(nolign-2)
      [M:SLP]ZGRPCOR(nolign-1)  = [M:SLP]ZGRPCOR(nolign-2)
      [M:SLP]ZANCHO(nolign-1)   = [M:SLP]ZANCHO(nolign-2)
      [M:SLP]ZLONGITUD(nolign-1)= [M:SLP]ZLONGITUD(nolign-2)
      [M:SLP]ZMANDRIL(nolign-1) = [M:SLP]ZMANDRIL(nolign-2)
      [M:SLP]QTYSTU(nolign-1)   = [M:SLP]QTYSTU(nolign-2)
      [M:SLP]STU(nolign-1)      = [M:SLP]STU(nolign-2)
      [M:SLP]PCU(nolign-1)      = [M:SLP]PCU(nolign-2)
      [M:SLP]LBEFMT(nolign-1)   = [M:SLP]LBEFMT(nolign-2)
      [M:SLP]PRT(nolign-1)      = [M:SLP]PRT(nolign-2)
      [M:SLP]SERIMP(nolign-1)   = [M:SLP]SERIMP(nolign-2)
      [M:SLP]DEFIMP(nolign-1)   = [M:SLP]DEFIMP(nolign-2)
      [M:SLP]PRTDRV(nolign-1)   = [M:SLP]PRTDRV(nolign-2)
      [M:SLP]PRTPOR(nolign-1)   = [M:SLP]PRTPOR(nolign-2)
      [M:SLP]PRTDES(nolign-1)   = [M:SLP]PRTDES(nolign-2)
      [M:SLP]TYPIMP(nolign-1)   = [M:SLP]TYPIMP(nolign-2)
      [M:SLP]TRSTYP(nolign-1)   = [M:SLP]TRSTYP(nolign-2)
      [M:SLP]ZMFGDATE(nolign-1) = [M:SLP]ZMFGDATE(nolign-2)
      [M:SLP]ZEMPALME(nolign-1) = [M:SLP]ZEMPALME(nolign-2)
    Endif
  Endif
Next F
FIN=nolign-1 # Me guardo fila final

If [M:SLP]ZSTAT="R"
#  GOK=0
Else
  # Ańado pedidos & Ctes
  Filter [F:ZMSQ] Where MFGNUM=[F:MFI]MFGNUM and MFGLIN=[F:MFI]MFGLIN Order By SOHNUM;SOPLIN
  For [F:ZMSQ]
    BOB=0
    For L=1 To [F:ZMSQ]ZQTYBOBASI
      For F=INI To FIN
        If [M:SLP]ZBPC(F)=""
          BOB+=1
          [M:SLP]ZSOH(F)       = [F:ZMSQ]SOHNUM
          [M:SLP]ZBPC(F)       = func SPESLP.CTE_PED([F:ZMSQ]SOHNUM,CTEPED,[F:ZMSQ]SOPLIN,[F:ZMSQ]SOQSEQ)
          [M:SLP]ZBPCPED(F)    = CTEPED
          [M:SLP]ZBPCREF(F)    = func SPESLP.CTE_REF([F:MFI]ITMREF,[M:SLP]ZBPC(F),[M:SLP]ZANCHO(F),CTEDES)
          [M:SLP]ZBPCREFDES(F) = CTEDES
          Read [F:BPC]BPC0 =[M:SLP]ZBPC(F)
          If fstat=0
            [M:SLP]ZBPCLOGO(F) = [F:BPC]ZIMPLOGO
            [M:SLP]ZMONOLOTE(F)= [F:BPC]ZMONOLOTE
          Endif
          Break
        Endif
      Next
    Next
    If BOB<>[F:ZMSQ]ZQTYBOBASI
    MSG="Revise los datos de GC=" + num$([F:MFI]ZGRPCOR) +" Ancho="+num$([F:MFI]ZANCHO)+" Largo="+num$([F:MFI]ZLONGITUD)+"\Bobinas asignadas al pedido [F:ZMSQ] " + [F:ZMSQ]SOHNUM + " LŞ " + num$([F:
& ZMSQ]SOPLIN) + " <> Bobinas indicadas en la OF\" + num$([F:ZMSQ]ZQTYBOBASI) + " <> " +  num$(BOB)
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    Endif
  Next
  Filter [F:ZMSQ]
Endif
Return


$DEC_PROD
Local Shortint NBRPED

If [M:SLP]ZTIPETI<1
  [M:SLP]ZTIPETI=1
Endif
If [M:SLP]ZTIPETI=1
   #Bolsa
   [M:SLP]LBEFMT(nolign-1)=[F:ITM]STULBEFMT
Else
   #Caja
   [M:SLP]LBEFMT(nolign-1)=[F:ITM]ZSTULBEFMT1
Endif

Filter [ZMSQ] Where MFGNUM=[M:SLP]VCRNUMORI(nolign-1) and MFGLIN=[M:SLP]VCRLINORI(nolign-1)
NBRPED=0
For [ZMSQ]
   NBRPED+=1
Next
Filter [ZMSQ]

Raz [M:SLP]ZBPC(nolign-1)
If NBRPED=1
   Raz [F:SOHX]
   Read [SOHX]SOH0=[F:ZMSQ]SOHNUM
   [M:SLP]ZBPC(nolign-1)=[F:SOHX]BPCORD
Endif
[M:SLP]LBENBR(nolign-1) = 1
Return



$MAJ_LBP
# Grabacion de la tabla que se utilizará por Crystal para la impresión
[F:LBP]STOFCY    = [M:SLP]STOFCY
[F:LBP]ITMREF    = [M:SLP]ITMREF(I)
[F:LBP]ZQTYSTU   = [M:SLP]QTYSTU(I)
[F:LBP]ZPCU      = [M:SLP]PCU(I)
[F:LBP]ZFECPROD  = [M:SLP]ZFECPROD(I)
[F:LBP]ZANCHO    = [M:SLP]ZANCHO(I)
[F:LBP]ZLONGITUD = [M:SLP]ZLONGITUD(I)
[F:LBP]ZMANDRIL  = [M:SLP]ZMANDRIL(I)
[F:LBP]ZLOT      = [M:SLP]ZLOT(I)
[F:LBP]ZSLOT     = [M:SLP]ZSLOT(I)
[F:LBP]ZLOTPT    = [M:SLP]ZLOTPT(I)
[F:LBP]ZLOTORI   = [M:SLP]ZLOTORI(I)
[F:LBP]ZBPC      = [M:SLP]ZBPC(I)
[F:LBP]ZBPCPED   = [M:SLP]ZBPCPED(I)
[F:LBP]ZBPCREF   = [M:SLP]ZBPCREF(I)
[F:LBP]ZBPCREFDES= [M:SLP]ZBPCREFDES(I)
[F:LBP]ZIMPLOGO  = [M:SLP]ZBPCLOGO(I)
[F:LBP]ZMONOLOTE = [M:SLP]ZMONOLOTE(I)
[F:LBP]ZTRATINT  = [M:SLP]ZTRATINTR(I)
[F:LBP]ZTRATEXT  = [M:SLP]ZTRATEXTR(I)
[F:LBP]ZSOH      = [M:SLP]ZSOH(I)
[F:LBP]ZMFGDATE  = [M:SLP]ZMFGDATE(I)
[F:LBP]ZEMPALME  = [M:SLP]ZEMPALME(I)
Return


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End
