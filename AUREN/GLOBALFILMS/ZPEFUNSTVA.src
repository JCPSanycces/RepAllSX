#<AdxTL>@(#)0.0.0.0 $Revision$
#PE BEFWRISTV -> PE utilizado para intervenir el proceso de valoracion de inventario para que si se pide inventario
#                retroactivo y en esa fecha existe un cambio de valor se tome el precio de ese cambio como el PMP para
#                esa fecha
$ACTION
  Case ACTION
     When "BEFWRISTV"   :   Gosub BEFWRISTV
  Endcase
Return

$BEFWRISTV
If [M:SVAL]REFDAT <> date$
   If WCSTCOD=4
      #PMP
      If clalev([STJW])<=0 : Local File STOJOU [STJW] : Endif
      Filter [STJW] Where STOFCY=[F:STV]STOFCY and UPDCOD=2 and ITMREF=[F:STV]ITMREF and IPTDAT=[F:STV]REFDAT and VCRTYP=30
      For [STJW]
         [F:STV]CST=[F:STJW]PRIORD
         [F:STV]AMT=[F:STV]QTYSTU*[F:STV]CST
         Break
      Next
      Filter [STJW]
   Endif
Endif
Return
