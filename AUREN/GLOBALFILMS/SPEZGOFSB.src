#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog COMBINAR_2(TOPEJ,TOPE_DIF,RPDTE)
Value Integer TOPEJ,TOPE_DIF
Variable Integer RPDTE
# En este planateamineto, montamos OPCIONES POSIBLES, en lugar de combinaciones
#
##############################################################################################
##    Evaluar posibilidad de:
##    Paso 1ş   Combinar sin tener en cuenta Anchos A
##    Paso 2ş   Ajustar lineas que sobrepasen el máximo
##    ??????
##############################################################################################


Local Integer TOPE    # Ancho jumbo - Merma mínima
Local Integer TELE    # Total bobinas a fabricar
Local Integer TANC    # Total ancho combinación en curso
Local Integer NPOS    # Posicion 1er elemento
Local Integer NORD    # Posicion comienzo para integrar con NPOS
Local Integer NELE    # Elemento a integrar en combinación, a partir de NORD
Local Integer ELEP    # Ancho a integrar
Local Char COMB(255)  # Combinacion pedidos en curso
Local Char COMBA(255) # Combinacion stock   en curso
Local Char CMP(255)(100)# Combinaciones originales de pedidos.......Máximo de 100 x cálculo
Local Char CMF(255)(100)# Combinaciones finales    pedidos+stock
Local Char CMS(255)(100)# Combinaciones finales    solo stock, para asegurarnos de que solo se repite una vez los mismos anchos de stock
Local Integer CMO(100)  # Combinaciones originales de pedidos
#                             0=OK
#                             1=No cogerla, pues son todos para stock, al no quedar pedidos
#                             2=No cogerla, en caso de que se repitan los anchos de stock
Local Integer FE,F0,FIN,PDTES_B
Local Char PDTES_D(255)
 # Para controlar si entramos en un bucle sin fin
Local Char BCMB(255),BCMBA(255)
Raz BCMB,BCMBA,RPDTE

Onerrgo ERRORES_FIN

TOPE=TOPEJ-[M:ZGOFS2]SMERMA
TELE=[M:ZGOFS2]NELE-1
# Se asume que los elementos nos vienen ordenados  ASC
# Por cada elemento vamos combinando hasta que superamos el tope
# Vamos marcando elementos incluidos para llevar un control
# La idea es
#    - Empezar con primer  elemento y combinarlo con el resto
#    - Empezar con segundo elemento y combinarlo con el resto y asi sucesivamente
#
#    - En una 1Ş vuelta empezamos a partir de siguiente elemento
#    - Al llegar al final, comenzamos desde principio

Raz NORD,CMP,CMF,CMO,CMS,FIN
For FE=0 To 0 # Vamos a probar con una sola vuelta     TELE
  NORD=FE+1  # habrá tantas combinaciones como bobinas a fabricar
  Call QUITAR_MARCAS(0) From SPEZGOFS1
  Raz COMB,TANC,COMBA

  # 1Ş vuelta a partir del elemento que toque
  While func HAY_PDTES(FE,PDTES_D)>0
  For F0=FE To TELE
    If [M:ZGOFS2]ASIGNADA(F0)=0
      ELEO=[M:ZGOFS2]ANCHO(F0)
      If TANC+ELEO>TOPE
        Gosub COMBINAR_GUARDAR_COMBI_2
        Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
      Endif
      Call COMBINAR_2_ACUMULAR(F0,TANC,COMB)
    Endif
  Next
  If RPDTE=-1
    Break 2
  Endif
  Wend

#  # Al llegar al final, 2Ş vuelta, desde el principio, por si quedara alguna bobina
#  # Tiene sentido a partir de no comenzar con el primer elemento, para combinar con los anteriores
#  While func HAY_PDTES(0,PDTES_D)>0
#  For F0=0 To TELE
#    If [M:ZGOFS2]ASIGNADA(F0)=0
#      ELEO=[M:ZGOFS2]ANCHO(F0)
#      If TANC+ELEO>TOPE
#        Gosub COMBINAR_GUARDAR_COMBI_2
#        Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
#      Endif
#      Call COMBINAR_2_ACUMULAR(F0,TANC,COMB)
#    Endif
#  Next
#  Wend
  # Guardar resto, ultima combinacion para completar produccion
  While TANC>0
    Gosub COMBINAR_GUARDAR_COMBI_2
    While func HAY_PDTES(0,PDTES_D)>0
    For F0=0 To TELE
      If [M:ZGOFS2]ASIGNADA(F0)=0
        ELEO=[M:ZGOFS2]ANCHO(F0)
        If TANC+ELEO>TOPE
          Gosub COMBINAR_GUARDAR_COMBI_2
          Break  # Nos salimos pues es posible que se hayan desmarcado anchos y ańadidos otros, para minimizar restos
        Endif
        Call COMBINAR_2_ACUMULAR(F0,TANC,COMB)
      Endif
    Next
    If RPDTE=-1
      Break 3
    Endif
    Wend
    Call ECR_TRACE("Hemos combinado todos los elementos   (FIN=1) " + COMB,0)   From GESECRAN
    FIN=1
  Wend

Next

Affzo [M:ZGOFS2]20
Onerrgo
End

Subprog COMBINAR_2_ACUMULAR(F,TANC,COMB)
Value Integer F
Variable Integer TANC
Variable Char COMB

Local Integer ELE
Local Char TXT(255)
ELE=[M:ZGOFS2]ANCHO(F)
TXT=format$("N0:4",ELE)
[M:ZGOFS2]ASIGNADA(F)=-1
TANC+=ELE
If len(COMB+TXT)+int(255/5)>=255
  Infbox "Avise al programador...Superado limite de " + num$(int(255/5)) + " anchos posibles (Subprog COMBINAR_2_ACUMULAR)"
Else
  If COMB<>""
    COMB+="-"
  Endif
  COMB+=TXT  # Recordar que ningun elemento puede ser superior al TOPE
Endif
End


$COMBINAR_GUARDAR_COMBI_2
Local Integer A0,A1,A2,A3,A4
Local Integer ANC(50),ANCR(50),NA
Local Integer RANC(50),RREP(50),RDIF(50)
Local Integer DIF_ANC
Local Integer OK_STOCK,OK_CMBX
Local Decimal DIF_OPC,DIF_MENOR
Local Integer F,SOLO_A
Local Char RCOMB(255),RCOMBA(255) # Para guardarmelas
Local Char CMBX(255)

OK_CMBX=0
If COMB=""
  Infbox "Avise al programador    COMB vacio...(COMBINAR_GUARDAR_COMBI_2)"
Elsif TANC>TOPE
  Infbox "Avise al programador    TANC>TOPE   "+ num$(TANC) + ">"+num$(TOPE) + "...(COMBINAR_GUARDAR_COMBI_2)"
Else
  Call ECR_TRACE("Combinacion bobinas pedidos " + COMB,0)   From GESECRAN
  RCOMB=COMB
  OK_CMBX=1
  SOLO_A=0
  If not func COMBI_YA_HECHA(CMF,COMB)
#    #  19.10  Lo comento para evitar que se repita     func COMBI_EXISTE(CMP,CMF,CMO,COMB)
    Raz CMBX
#    If not FIN
#      CMBX=func COMBI_EXISTE(CMP,CMF,CMO,COMB)
#      If CMBX<>""
#        Call ECR_TRACE("Combinacion pedidos se hizo antes y dio lugar a " + CMBX,0)   From GESECRAN
#        # Comparo con actual, por si hubiera que desmarcar o marcar anchos de pedidos
#        Call AJUSTAR(COMB,COMBA,CMBX,OK_CMBX)
#        Call ECR_TRACE("Tras ajustar dicha combinacion con bobinas pdtes a fabricar se queda    PEDIDOS="+COMB+" EXCESO="+COMBA,0)   From GESECRAN
#        # Descartar si todo para stock. Esto ocurre cuando ya no quedan mas bobinas de pedidos pdtes   o    Stock no válido
#        If COMB=""
#          Call ECR_TRACE("Se descarta al ser todo STOCK",0)   From GESECRAN
#        Endif
#        If not OK_CMBX
#          Call ECR_TRACE("Se descarta al haber anchos de exceso NO incluidos en ANCHOS A",0)   From GESECRAN
#        Endif
#        If COMB="" or not OK_CMBX
#          Call COMBI_ANULAR(CMP,CMO,1,RCOMB)
#        Endif
#      Endif
#    Endif
    If CMBX=""
      DIF_ANC=TOPE-TANC
      If DIF_ANC >0
        Gosub COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_PED
        DIF_MENOR=9999.999
  #      If [M:ZGOFS2]SMINSTK=2
          Gosub COMBINAR_AJUSTAR_CON_ANCHOS_PED
          Gosub COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A
          Gosub COMBINAR_AJUSTAR_CON_ANCHOS_A
          If COMBA<>"" and  ((DIF_ANC>TOPE_DIF and [M:ZGOFS2]SMINSTK=2) or  (DIF_ANC>0 and [M:ZGOFS2]SMINRES=2))
            SOLO_A=1
            Call ECR_TRACE("Veo si es posible buscar una combinacion mas optima para el stock "+COMBA,0)   From GESECRAN
#            Call ECR_TRACE("1ş)Me guardo COMB, COMBA      2ş)COMB=COMBA y COMBA=''    3ş)Llamo a COMBINAR_AJUSTAR_CON_ANCHOS_A     4ş)COMB=RCOMB y COMBA=COMB+COMBA",0)   From GESECRAN
            RCOMB =COMB  :  RCOMBA=COMBA
            COMB  =COMBA :  COMBA=""
            Gosub COMBINAR_AJUSTAR_CON_ANCHOS_A
            If COMB<>"" and COMBA<>""
              COMBA=COMB+"-"+COMBA
            Else
              COMBA=COMB+COMBA
            Endif
            COMB=RCOMB
            TANC=func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMB,COMBA,5)
            DIF_ANC=TOPE-TANC
            Call ECR_TRACE("Resultado de ver si es posible buscar una combinacion mas optima para el stock "+COMBA,0)   From GESECRAN
          Endif
  #      Else
  #        Gosub COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A
  #        Gosub COMBINAR_AJUSTAR_CON_ANCHOS_A
  #        Gosub COMBINAR_AJUSTAR_CON_ANCHOS_PED
  #      Endif
      Endif
#      Infbox "Antes    COMB " + COMB + "    COMBA "+COMBA
      COMB  = func COMB_ORDENADA(COMB)
      COMBA = func COMB_ORDENADA(COMBA)
#      Infbox "Despues  COMB " + COMB + "    COMBA "+COMBA
      Call COMBI_GUARDAR(CMP,CMF,CMS,RCOMB,COMB,COMBA)
    Endif
  Else
    Call ECR_TRACE("Combinacion pedidos coincide con una combinacion final anterior, luego hacemos lo mismo " + COMB,0)   From GESECRAN
  Endif
  If COMB<>"" and OK_CMBX
    F=[M:ZGOFS2]NCOM
    [M:ZGOFS2]CANCHOJ(F)= TOPEJ
    [M:ZGOFS2]POS(F)    = NPOS
    [M:ZGOFS2]ORD(F)    = NORD
    [M:ZGOFS2]COMBI(F)  = COMB
    [M:ZGOFS2]COMBA(F)  = COMBA
    [M:ZGOFS2]CANCHO(F) = func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMB,COMBA,5)
    [M:ZGOFS2]CDIF(F)   = TOPE-[M:ZGOFS2]CANCHO(F)
    [M:ZGOFS2]CNUM(F)   = F+1
    [M:ZGOFS2]CANCHOA(F)= func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMBA,"",5)
    [M:ZGOFS2]NCOM+=1
    If [M:ZGOFS2]NCOM>=8000
      Infbox "Se ha superado el limite de combinaciones posibles ([M:ZGOFS2]NCOM>=8000)"
    Endif
    Call ECR_TRACE("Combinación hecha nş " + num$(F+1) + "     Tope-Ancho=DifŞ  (" + num$(TOPE)+"-"+num$([M:ZGOFS2]CANCHO(F))+"="+num$([M:ZGOFS2]CDIF(F))+")" ,0)   From GESECRAN
    Call ECR_TRACE("Pedidos=" + COMB + "   Stock="+COMBA,0)   From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#    If F+1=36
#      Infbox "Depurar"
#    Endif
    #Marcar bobinas como incluidas
    Call QUITAR_MARCAS (NORD) From SPEZGOFS1
  Endif
Endif
# Controlar que no entramos en un bucle sin fin
PDTES_B=func HAY_PDTES(0,PDTES_D)
Call ECR_TRACE("Anterior Bobinas pdtes="+num$(RPDTE) + "   Ped="+BCMB +"   Stock="+BCMBA ,0)   From GESECRAN
Call ECR_TRACE("Actual   Bobinas pdtes="+num$(PDTES_B)+"   Ped="+COMB +"   Stock="+COMBA ,0)   From GESECRAN
If BCMB=""
  BCMB=COMB
  BCMBA=COMBA
  RPDTE=PDTES_B
Elsif BCMB=COMB and BCMBA=COMBA and RPDTE=PDTES_B
    Call ECR_TRACE("Hemos entrado en un bucle sin fin     RCOMB=COMB and RCOMBA=COMBA and RPDTE=PDTES_B " ,0)   From GESECRAN
    RPDTE=-1
Else
  BCMB=COMB
  BCMBA=COMBA
  RPDTE=PDTES_B
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Raz COMB,TANC,COMBA
Return



Subprog AJUSTAR(COMB,COMBA,CMBX,OK)
Variable Char COMB,COMBA
Variable Integer OK
Value Char CMBX
Local Integer F,G,EXISTE,PASADAS
Local Char COMBP(255),ELE(255)
COMBP=COMB
Raz COMB,COMBA
# 1ş)Por cada elemento de combinacion actual pedidos, busco nş de coincidencias en combinación que se hizo
For F=1 To len(COMBP) Step 5
  ELE=mid$(COMBP,F,4)
  Raz EXISTE
  For G=1 To len(CMBX) Step 5
    If ELE=mid$(CMBX,G,4)
      EXISTE+=1
    Endif
  Next
  # Compruebe que no se pase a pedidos mas veces de las necesaraias, pues el mismos ancho, en  podria ser para pedidos y stock
  If EXISTE>0
    Raz PASADAS
    For G=1 To len(COMB) Step 5
      If ELE=mid$(COMB,G,4)
        PASADAS+=1
      Endif
    Next
    If PASADAS>=EXISTE
      EXISTE=0
    Endif
  Endif
 # si no existe desmarco ancho de pedidos
  If EXISTE=0
    Call DESMARCAR_ANCHO_PED(val(ELE))
  Else
    If COMB<>""
      COMB+="-"
    Endif
    COMB+=ELE
  Endif
Next
# 2ş) Paso resto anchos de combi actual
Raz COMB,COMBA
For F=1 To len(CMBX) Step 5
  ELE=mid$(CMBX,F,4)
  Raz EXISTE
  For G=1 To len(COMBP) Step 5
    If ELE=mid$(COMBP,G,4)
      EXISTE+=1
    Endif
  Next
  # Compruebe que no se pase a pedidos mas veces de las necesaraias, pues el mismos ancho, en  podria ser para pedidos y stock
  If EXISTE>0
    Raz PASADAS
    For G=1 To len(COMB) Step 5
      If ELE=mid$(COMB,G,4)
        PASADAS+=1
      Endif
    Next
    If PASADAS>=EXISTE
      EXISTE=0
    Endif
  Endif
  # si existe lo paso a pedidos, de lo contrario a stock
  If EXISTE=0
    If COMBA<>""
      COMBA+="-"
    Endif
    COMBA+=ELE
  Else
    If COMB<>""
      COMB+="-"
    Endif
    COMB+=ELE
  Endif
Next
# 3ş) Compruebo que los anchos de stock son validos, de lo contrario no cogeremos la combinacion
For F=1 To len(COMBA) Step 5
  ELE=mid$(COMBA,F,4)
  If not func ANCHO_STOCK_OK(val(ELE))
    OK=0
    #Dejar bobinas libres para próximo cálculo
    Call QUITAR_MARCAS (-1) From SPEZGOFS1
    Break
  Endif
Next
End

Subprog COMBI_GUARDAR(CMP,CMF,CMS,RCOMB,COMB,COMBA)
Variable Char CMP,CMF,CMS
Value Char RCOMB,COMB,COMBA
Local Integer F
Local Char CMB(255)
CMB=COMB
If COMBA<>""
  If CMB<>""
    CMB+="-"
  Endif
  CMB+=COMBA
Endif
For F=0 To dim(CMP)-1
  If CMP(F)=RCOMB
    #Combinación ya existe, pero se marcó como anulada en posteriores cálculos
    Break
  Elsif CMP(F)=""
    CMP(F)=RCOMB
    CMF(F)=CMB
    CMS(F)=COMBA
    Break
  Endif
Next
End

Funprog COMBI_EXISTE(CMP,CMF,CMO,COMB)
Value Char CMP,CMF,COMB
Value Integer CMO
Local Integer F
Local Char CMBX(255)
Raz CMBX
For F=0 To dim(CMP)-1
  If CMP(F)=COMB and CMO(F)=0
    CMBX=CMF(F)
    Break
  Endif
Next
End CMBX

Funprog COMBI_YA_HECHA(CMF,COMB)
Value Char CMF,COMB
Local Integer F,HECHA
HECHA=0
For F=0 To dim(CMF)-1
  If CMF(F)=COMB
    HECHA=1
    Break
  Endif
Next
End HECHA

Subprog COMBI_ANULAR(CMP,CMO,V,COMB)
Value Char CMP,COMB
Value Integer V
Variable Integer CMO
Local Integer F
For F=0 To dim(CMP)-1
  If CMP(F)=COMB
    CMO(F)=V
    Break
  Endif
Next
End



$COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A
If DIF_ANC<=0
  Return
Endif
Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A",0)   From GESECRAN
Call ANADIR_STOCK (DIF_ANC,COMBA) From SPEZGOFSA
Call QUITAR_CHAR(COMBA,"-")
TANC=func SPEZGOFSA.SUMAR_ANCHOS_COMB(COMB,COMBA, 5)
DIF_ANC=TOPE-TANC
Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_A  -  Se han metido "+COMBA,0)   From GESECRAN
Return

$COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_PED
If DIF_ANC<=0
  Return
Endif
# Partiendo del principio, ver si entra algun ancho, inferior.....esto ocurre cuando partimos de elementos posteriores al primero
# Empezamos desde el elemento del que se está partiendo hacia abajo, para ver de meter los anchos mayores posibles
Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_PED",0)   From GESECRAN
For F=FE To 0 Step -1
  If [M:ZGOFS2]ASIGNADA(F)=0
    ELEO=[M:ZGOFS2]ANCHO(F)
    If TANC+ELEO<=TOPE
      Call COMBINAR_2_ACUMULAR(F,TANC,COMB)
    Endif
  Endif
Next
DIF_ANC=TOPE-TANC
Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_VER_SI_ENTRAN_ANCHOS_PED",0)   From GESECRAN
Return

$COMBINAR_AJUSTAR_CON_ANCHOS_A
A4=1
# Basicamente funciona igual que COMBINAR_AJUSTAR_CON_ANCHOS_PED, excepto por
#   - Ańadiremos tantos de stock como sean necesarias, por lo que no controlamos
#         - Si bobina asignada o no, en lugar de ello debe estar marcada para  tenerla en cuenta
#         - Si hay bobinas suficientes, motivo por el cual nos quedamos con los decimales para determinar mejor opcion
#   - De no desear un ancho en concreto, lo desmarcaremos y repetiremos calculo

# Si hemos seleccionado MINIMIZAR STOCK y resto dentro de limites, no nos paramos a ver  si ańadiendo anchos A podriamos bajarlo
If DIF_ANC<=TOPE_DIF and [M:ZGOFS2]SMINSTK=2
  Return
Endif
# Salir si difŞ=0   o  no quedan mas elementos con los que combinar
If DIF_ANC<=0#  or func HAY_PDTES(0,PDTES_D)<1
  Return
Endif
## De haber un solo elemento, no podemos sustituirlo por stock, pues se quedaria todo para stock
## Luego comprobamos que si queda un solo ancho, no se sustiyan todas sus repeticiones
#If len(COMB)<=5
#  Return
#Endif
#

Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_CON_ANCHOS_A    (MONTAR_RESTOS_POSIBLES)",0)   From GESECRAN
Call ECR_TRACE("De entre los anchos A, busco el sustituto mas optimo de entre los existentes  ("+COMB+")",0)   From GESECRAN

Gosub MONTAR_RESTOS_POSIBLES
#If NA=1
#  Infbox  "Comprobar If not (NA=1 and int(DIF_OPC)>=func ANCHO_REPETICIONES(RANC(A1),ANC,ANCR)) "
#Endif
# A2 = indice con la mejor opcion de resto posible
# A3 = indice con la mejor opcion de ancho posible
# 1ş) A FABRICAR - Quedarme con la mejor opción del resto de bobinas a producir o si cero
A2=-1
A3=-1
For A1=0 To dim(RDIF)-1
  If RANC(A1)=0
    Break
  Endif
  For A0=0 To [M:ZGOFS2]NTIA-1
    # La rejilla de anchos está ordenada por Anchos ASC
    If RDIF(A1)<[M:ZGOFS2]NANCHO(A0)
      Break
    Elsif [M:ZGOFS2]NSEL(A0)=2
      # Cuando haya un solo ancho(NA=1), DESPRECIAR la opcion que sustituya todas sus repeticiones  (Ej.230-230...podriamos sustituir uno, pero no los 2, pues se haría todo para stock
      # Excepto si    SOLO_A=1, lo que significa que estamos buscando mejorar la actual combinacion de anchos A
      If SOLO_A=1 or not (NA=1 and RREP(A1)>=func ANCHO_REPETICIONES(RANC(A1),ANC,ANCR))
        DIF_OPC=RDIF(A1)/[M:ZGOFS2]NANCHO(A0)
        # Terminamos en cuanto encontremos la primera opcion SIN restos. >>>En anchos A, De no desearla, que la desmarquen
        If DIF_OPC=int(DIF_OPC) # and func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC)
          A2=A1
          A3=A0
          DIF_MENOR=DIF_OPC
          Break 2
        Elsif DIF_OPC-int(DIF_OPC)<DIF_MENOR-int(DIF_MENOR) # and func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC)
          # Y sea mas optima que  la actual
          If int(DIF_OPC)*[M:ZGOFS2]NANCHO(A0)>RDIF(A1)-DIF_ANC
            A2=A1
            A3=A0
            DIF_MENOR=DIF_OPC
          Endif
        Endif
      Endif
    Endif
  Next
Next
If A2<>-1
  Gosub COMBINAR_AJUSTAR_CON_ANCHOS_
Endif
Return


$COMBINAR_AJUSTAR_CON_ANCHOS_PED
# Si vengo de ajustar con Stock y difŞ por debajo, vuelvo
If DIF_ANC<TOPE_DIF and A4=-1
  Return
Endif
# Salir si difŞ=0   o  no quedan mas elementos con los que combinar
If DIF_ANC<=0 or func HAY_PDTES(0,PDTES_D)<1
  Return
Endif

Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_CON_ANCHOS_PED    (MONTAR_RESTOS_POSIBLES)",0)   From GESECRAN
Call ECR_TRACE("De entre los anchos pendientes de pedido, busco el sustituto mas optimo de entre los existentes  ("+COMB+")",0)   From GESECRAN
Call ECR_TRACE("Aprovecho y si el ancho está entre los A, lo ańado como stock, en caso de que me sobren",0)   From GESECRAN
A4=0
Gosub MONTAR_RESTOS_POSIBLES

# A2 = indice con la mejor opcion de resto posible
# A3 = indice con la mejor opcion de ancho posible
# 1ş) A FABRICAR - Quedarme con la mejor opción del resto de bobinas a producir o si cero
A2=-1
A3=-1
For A1=0 To dim(RDIF)-1
  If RANC(A1)=0
    Break
  Endif
  # Coger ancho pedido para stock si opcion MINIMIZAR DESPERDICIO y ancho pedido está en ANCHOS A
  OK_STOCK=func ANCHO_STOCK_OK(RANC(A1))
  For A0=0 To [M:ZGOFS2]NELE-1
    # La rejilla de anchos está ordenada por Anchos ASC
    If RDIF(A1)<[M:ZGOFS2]ANCHO(A0)
      Break
    # Bobina libre y que no sea igual a la que provocó la ruptura   O   Minimizar desperdicio y Ancho en STOCK A
    Elsif ([M:ZGOFS2]ASIGNADA(A0)=0 and not (ELEO=RANC(A1)and RREP(A1)=1 and RANC(A1)=[M:ZGOFS2]ANCHO(A0))) or (OK_STOCK and RANC(A1)=[M:ZGOFS2]ANCHO(A0))
      DIF_OPC=RDIF(A1)/[M:ZGOFS2]ANCHO(A0)
      # Terminamos en cuanto encontremos la primera opcion SIN restos. >>>En anchos A, De no desearla, que la desmarquen
      If DIF_OPC=int(DIF_OPC) and (func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC) or OK_STOCK)
        A2=A1
        A3=A0
        DIF_MENOR=DIF_OPC
        Break 2
      # Nos quedamos con la opción que tenga menor desperdicio (parte decimal), siempre y cuando haya bobinas en pedidos
      Elsif DIF_OPC-int(DIF_OPC)<DIF_MENOR-int(DIF_MENOR) and (func BOBINAS_PEDTES_PED([M:ZGOFS2]ANCHO(A0))>=int(DIF_OPC) or OK_STOCK)
        # Y sea mas optima que  la actual
        If int(DIF_OPC)*[M:ZGOFS2]ANCHO(A0)>RDIF(A1)-DIF_ANC
          A2=A1
          A3=A0
          DIF_MENOR=DIF_OPC
        Endif
      Endif
    Endif
  Next
Next
If A2=-1
  Return
Endif
$COMBINAR_AJUSTAR_CON_ANCHOS_
Local Integer BOB,V,OK_MARCAR
If DIF_MENOR<9999 and A2<>-1
#  #Quito de la combinacion el "resto posible"
#  For A0=1 To RREP(A2)
#    COMB=func ZCOMUN.REPLACE(COMB, format$("N0:4",RANC(A2)), "", 1)
#    TANC-=RANC(A2)
#    Call DESMARCAR_ANCHO_PED(RANC(A2))
#  Next
  #Quito de la combinacion el "resto posible"....  1şStocks   2şPedidos
  For A0=1 To RREP(A2)  #   Comprobar que int(DIF_MENOR)=RREP(A2)
    COMBA=func ZCOMUN.REPLACE(COMBA, format$("N0:4",RANC(A2)), "", 1,V)
    If V>0
      COMBA=func ZCOMUN.REPLACE(COMBA, "--", "-", 1,V)
      Call QUITAR_CHAR(COMBA,"-")
      TANC-=RANC(A2)
    Else
      # De haber un solo ancho, imposible sustiturlos todos, pues se quedaria todo como stock...EXCEPTO si  SOLO_A=1
      COMB=func ZCOMUN.REPLACE(COMB, format$("N0:4",RANC(A2)), "", 1,V)
      If V=0
        Infbox "Error grave. No se pudo suprimir ancho " + RANC(A2) + "    SPEZGOFSB.COMBINAR_AJUSTAR_CON_ANCHOS_"
      Endif
      COMB=func ZCOMUN.REPLACE(COMB, "--", "-", 1,V)
      Call QUITAR_CHAR(COMB,"-")
      If not SOLO_A
        Call DESMARCAR_ANCHO_PED(RANC(A2))
      Endif
      TANC-=RANC(A2)
    Endif
  Next
  #Ańado a la combinacion el "ancho posible"
  For A0=1 To int(DIF_MENOR)
    If A4=0 # De pedidos
      BOB=[M:ZGOFS2]ANCHO(A3)
      Call MARCAR_ANCHO_PED([M:ZGOFS2]ANCHO(A3),OK_MARCAR)
      If OK_MARCAR
        If COMB<>""
          COMB+="-"
        Endif
        COMB+=format$("N0:4",BOB)
      Else
      # Estamos en el caso de que podemos cambiar un ancho de pedido por mas de uno, pero no quedan suficientes bobinas de pedidos
      # por lo que el resto las ponemos para stock, asumiendo que se ha marcado opcion Minimizar desperdicio
        If COMBA<>""
          COMBA+="-"
        Endif
        COMBA+=format$("N0:4",BOB)
      Endif
    Else
      BOB=[M:ZGOFS2]NANCHO(A3)
      If COMBA<>""
        COMBA+="-"
      Endif
      COMBA+=format$("N0:4",BOB)
    Endif
    TANC+=BOB
  Next
Endif
DIF_ANC=TOPE-TANC
Call ECR_TRACE("DifŞ Ancho "+ num$(DIF_ANC)+"  COMBINAR_AJUSTAR_CON_ANCHOS_     (Parte comun para _PED y _A)",0)   From GESECRAN
Call ECR_TRACE("Pedidos=" + COMB + "   Stock="+COMBA,0)   From GESECRAN
Return


Funprog ANCHO_EN_STOCK_A(ANC)
Value Integer ANC
Local Integer I
Raz I
For F=0 To [M:ZGOFS2]NTIA-1
  If [M:ZGOFS2]NANCHO(F)=ANC and [M:ZGOFS2]NSEL(F)=2
    I+=1
  Endif
Next
End I

Funprog ANCHO_STOCK_OK(ANC)
Value Integer ANC
# Coger ancho pedido para stock si opcion MINIMIZART DESPERDICIO y ancho pedido está en ANCHOS A
Local Integer OK
OK=0
OK=[M:ZGOFS2]SMINRES=2 and func ANCHO_EN_STOCK_A(ANC)
End OK

Subprog DESMARCAR_ANCHO_PED(ANC)
Value Integer ANC
Local Integer F
#Empiezo por el final, mas que nada por desmarcar las últimas marcadas
For F=[M:ZGOFS2]NELE-1 To 0 Step -1
  If [M:ZGOFS2]ASIGNADA(F)=-1 and [M:ZGOFS2]ANCHO(F)=ANC
    [M:ZGOFS2]ASIGNADA(F)=0
    Break
  Endif
Next
End

Subprog MARCAR_ANCHO_PED(ANC,OK)
Value Integer ANC
Variable Integer OK
Local Integer F
OK=0
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0 and [M:ZGOFS2]ANCHO(F)=ANC
    [M:ZGOFS2]ASIGNADA(F)=-1
    OK=1
    Break
  Endif
Next
End


Funprog BOBINAS_PEDTES_PED(ANC)
Value Integer ANC
Local Integer BOB,F
Raz BOB
For F=0 To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0 and [M:ZGOFS2]ANCHO(F)=ANC
    BOB+=1
  Endif
Next
End BOB

$MONTAR_RESTOS_POSIBLES
Raz ANC,ANCR,NA,RANC,RREP,RDIF
# Acumular nş de veces que aparece el ancho en la combinacion, para determinar <<Repeticiones Ancho>>
Call CONTAR_ANCHOS_COMB(COMB,5,ANC,ANCR,NA) From SPEZGOFS4
# Montar restos posibles de la combinación
A2=0
For A0=0 To NA
  For A1=1 To ANCR(A0)
    RANC(A2)=ANC(A0)
    RREP(A2)=A1
    RDIF(A2)=A1*ANC(A0)+DIF_ANC
    A2+=1
  Next
Next
Return

Funprog ANCHO_REPETICIONES(A,ANC,ANCR)
Value Integer A,ANC,ANCR
Local Integer F,R
Raz R
For F=0 To dim(ANC)-1
  If ANC(F)=A
    R=ANCR(F)
    Break
  Endif
Next
End R

Subprog QUITAR_CHAR(TXT,C)
Variable Char TXT
Value Char C
If left$(TXT,1)=C
  TXT=mid$(TXT,1+len(C),255)
Endif
If right$(TXT,len(TXT)-len(C)+1)=C
  TXT=left$(TXT,len(TXT)-len(C))
Endif
End

Funprog HAY_PDTES(INI,D)
Value Integer INI
Variable Char D
Local Integer F,C
Raz C,D
For F=INI To [M:ZGOFS2]NELE-1
  If [M:ZGOFS2]ASIGNADA(F)=0
    C+=1
    If D<>"":D+="-":Endif
    D+=format$("N0:4",[M:ZGOFS2]ANCHO(F))
  Endif
Next
End C

Funprog COMB_ORDENADA(COMB)
Value Char COMB
Local Char OK(255)
Local Integer ANC(50),ANCR(50),NA
Local Integer ANCB(50)
Local Integer F,G,X
Call CONTAR_ANCHOS_COMB(COMB,5,ANC,ANCR,NA) From SPEZGOFS4
# Copio y ordeno array de apoyo
For F=0 To dim(ANCB)-1
  ANCB(F)=ANC(F)
Next
Sorta ANCB
# Monto la combinación
Raz OK
For F=0 To dim(ANCB)-1
  If ANCB(F)>0
    # Saco nş repeticiones del ancho
    For G=0 To NA
      If ANC(G)=ANCB(F)
        # Monto combinación
        For X=1 To ANCR(G)
          If OK<>"":OK+="-":Endif
          OK+=format$("N0:4", ANC(G))
        Next
        Break
      Endif
    Next
  Endif
Next
End OK


$ERRORES_FIN
Errbox "Error " + errmes$(errn) + " en linea " + num$(errl) + "  fuente: " + trtcou
End
