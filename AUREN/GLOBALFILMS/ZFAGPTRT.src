#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
# When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
# When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase

Return

$DEBUT
Raz [M:ZFAGP0]
[M:ZFAGP0]ZFCYORG="901"
[M:ZFAGP0]ZFCYORGH="901"
[M:ZFAGP0]ZDOCORG=addmonth(eomonth(date$)+1,-1)
[M:ZFAGP0]ZDOCORGH=eomonth(date$)
[M:ZFAGP0]ZESTADO=1
[M:ZFAGP0]ZESTADOH=1
[M:ZFAGP0]FCY='100'
[M:ZFAGP0]ACCDAT=eomonth(date$)
Affzo [M:ZFAGP0]
Return

$OUVRE
If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
If !clalev([F:SID]) : Local File SINVOICED [SID] : Endif
If !clalev([F:ZFAPR]) : Local File ZFAGPRVCOM [ZFAPR] : Endif

If !clalev([F:XBPR]) : Local File BPARTNER [XBPR] : Endif
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
Return

$BOUTON
Case BOUT
    When "B" :  Gosub BUSCAR

    When "G" : Gosub GENERAR
Endcase

Return



$BUSCAR
Local Char WLCRITERIO (250)
Local Char WLCRITERI2 (250)
Local Integer WLNOL : WLNOL = 0

WLCRITERIO="ZFAGFLG=2"
If [M:ZFAGP0]ZFCYORG <> "" : WLCRITERIO -= "& (FCY>=[M:ZFAGP0]ZFCYORG)" : Endif
If [M:ZFAGP0]ZFCYORGH <> "" : WLCRITERIO -= "& (FCY<=[M:ZFAGP0]ZFCYORGH)" : Endif
If [M:ZFAGP0]ZDOCORG <> [0/0/0] : WLCRITERIO -= "& (ACCDAT>=[M:ZFAGP0]ZDOCORG)" : Endif
If [M:ZFAGP0]ZDOCORGH <> [0/0/0] : WLCRITERIO -= "& (ACCDAT<=[M:ZFAGP0]ZDOCORGH)" : Endif
If [M:ZFAGP0]ZESTADO <>0 : WLCRITERIO -= "& (ZFAGSTP>=[M:ZFAGP0]ZESTADO)" : Endif
If [M:ZFAGP0]ZESTADOH <>0 : WLCRITERIO -= "& (ZFAGSTP<=[M:ZFAGP0]ZESTADOH)" : Endif
#Infbox WLCRITERIO
Filter [F:SIH] Where evalue (WLCRITERIO)
For [F:SIH]
   [M:ZFAGP0]ZSEL(WLNOL)=1
   [M:ZFAGP0]BPCREP(WLNOL)=[F:SIH]ZFAGREPRES

  # Leer tercero representado
   Raz [F:XBPR]
   Read [F:XBPR]BPR0=[F:SIH]ZFAGREPRES
   [M:ZFAGP0]BPCREPNAM(WLNOL)=[F:XBPR]BPRNAM  # Nombre Representado


   [M:ZFAGP0]FCYORG(WLNOL)=[F:SIH]FCY
   [M:ZFAGP0]DOCORG(WLNOL)=[F:SIH]NUM
   [M:ZFAGP0]FECORG(WLNOL)=[F:SIH]ACCDAT
   [M:ZFAGP0]IMPDOC(WLNOL)=[F:SIH]AMTNOT

    [M:ZFAGP0]REFDOCORG(WLNOL)=[F:SIH]ZFAGNUMFAC # Nş Factura Representado

  # Leer Fecha Vencimiento
    Raz [F:DUD]
    Filter [F:DUD] Where NUM=[F:SIH]NUM
    For [F:DUD]
       [M:ZFAGP0]FECVTO(WLNOL)=[F:DUD]DUDDAT  # Fecha Vencimiento
       Break
    Next
    Filter [F:DUD]

   [M:ZFAGP0]IMPORTE(WLNOL)=0  # Calcular Importe comision
   [M:ZFAGP0]ZFAGSTP(WLNOL)=[F:SIH]ZFAGSTP
   If [M:ZFAGP0]ZFAGSTP(WLNOL)=0 : [M:ZFAGP0]ZFAGSTP(WLNOL)=1 : Endif
   Gosub CALCULA_IMPORTE
   [M:ZFAGP0]BPCNAM(WLNOL)=[F:SIH]BPRNAM
   WLNOL+=1
Next
Filter [F:SIH]
[M:ZFAGP0]NBLIG=WLNOL
Affzo [M:ZFAGP0]15
Return


$CALCULA_IMPORTE

Local Decimal WLIMPCOMTOT : WLIMPCOMTOT=0
If  [M:ZFAGP0]ZFAGSTP(WLNOL)=1 Then
#    FJCP - el importe se guardda en SINVOICE y puede ser modificado manualmente.
#    Filter [F:SID] Where NUM=[F:SIH]NUM
#
#   For [F:SID]
#      WLIMPCOMTOT+=[F:SID]REPAMT2
#   Next
#
#    Filter [F:SID]
#    [M:ZFAGP0]IMPORTE(WLNOL)=WLIMPCOMTOT

    [M:ZFAGP0]IMPORTE(WLNOL)=[F:SIH]ZFAGIMPCOM  # Recoge el importe de la comision de la cabecera de factura (SINVOICE)
Else
   Raz [F:ZFAPR]
   Filter [F:ZFAPR] Where DOCORG=[F:SIH]NUM
   Read [F:ZFAPR]ZFAPR0 First
   If !fstat Then
      [M:ZFAGP0]IMPORTE(WLNOL)=[F:ZFAPR]IMPORTE
   Endif
   Filter [F:ZFAPR]
Endif
Return


$GENERAR
Local Integer WLI
Trbegin [F:ZFAPR], [F:SIH]
GOK=1
For WLI=0 To [M:ZFAGP0]NBLIG - 1
   If [M:ZFAGP0]ZSEL(WLI)=2
     Raz [F:SIH]
     Read [F:SIH]SIH0=[M:ZFAGP0]DOCORG(WLI)
     If !fstat
        Raz [F:ZFAPR]
        [F:ZFAPR]BPCREP=[M:ZFAGP0]BPCREP(WLI)
        [F:ZFAPR]FCY=[M:ZFAGP0]FCY
        [F:ZFAPR]ACCDAT=[M:ZFAGP0]ACCDAT
        [F:ZFAPR]BPCREP=[M:ZFAGP0]BPCREP(WLI)
        [F:ZFAPR]FCYORG=[M:ZFAGP0]FCYORG(WLI)
        [F:ZFAPR]DOCORG=[M:ZFAGP0]DOCORG(WLI)
        [F:ZFAPR]FECORG=[M:ZFAGP0]FECORG(WLI)
        [F:ZFAPR]IMPORTE=[M:ZFAGP0]IMPORTE(WLI)
        [F:ZFAPR]CONTAB=1
        [F:ZFAPR]DESCRI=[F:SIH]ZFAGNUMFAC + ", " +  [M:ZFAGP0]BPCNAM(WLI)
        [F:ZFAPR]CREUSR=GUSER
        [F:ZFAPR]CREDATTIM=datetime$
        [F:ZFAPR]UPDDATTIM=[F:ZFAPR]CREDATTIM
        Write [F:ZFAPR]
        If fstat
           Call FSTA("ZFAPR") From GLOCK
           GOK=0
           Break
        Else
            [F:SIH]ZFAGSTP=2
            [F:SIH]ZFAGFECPRV=[F:ZFAPR]ACCDAT
            Rewrite [F:SIH]
            If fstat
               Call FSTA("SIH") From GLOCK
               GOK=0
               Break
            Endif
        Endif
     Endif
   Endif
Next
If GOK Then
   Commit
   Gosub $BUSCAR
Else
   Rollback
Endif
Return
# Gestión de la máscara ZFAGP0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZFAGP0) 13/04/2016 12:46:13 (ADMIN)
######################################################################################
Subprog AS_ZSEL(VALEUR)
Variable Integer VALEUR
Local Shortint NOL : NOL =nolign - 1
If [M:ZFAGP0]ZFAGSTP(NOL)>1
   mkstat=2
Endif
End

Subprog AM_ZSEL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
   [M:ZFAGP0]NSEL+=1
Else
   [M:ZFAGP0]NSEL-=1
Endif
Affzo [M:ZFAGP0]NSEL
End


######################################################################################
