# Gestión de la máscara PKD1 (Especifico)
# 06.348.298 19/05/2022 ML Mejoras especifico sub-lotes/empaquetado
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PKD1) 26/01/2016 12:15:11 (ADMIN)
######################################################################################
$ACTION
#If GUSER="ADMIN"   Infbox ACTION Endif
Case ACTION
When Default
Endcase
Return



Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Read [TPA]TPA0=VALEUR
   If fstat
      Raz [F:TPA]
   Endif
   [M:PKD1]ZPCKLEN= [F:TPA]PCKLEN
   [M:PKD1]ZPCKWID= [F:TPA]PCKWID
   [M:PKD1]ZPCKHEI= [F:TPA]PCKHEI
   [M:PKD1]ZPCKWEI= [F:TPA]PCKWEI
   Affzo [M:PKD1]ZPCKLEN
   Affzo [M:PKD1]ZPCKWID
   Affzo [M:PKD1]ZPCKHEI
   Affzo [M:PKD1]ZPCKWEI
Endif
End
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PKD1) 27/09/2016 10:16:22 (ADMIN)
######################################################################################
Subprog C_GROWEI(VALEUR)
Variable Decimal VALEUR
If VALEUR < (sum([M:PKD1]NETWEIPCK(0..max([M:PKD1]NBLIG-1,nolign-1)))  )
   mkstat = 2
   End
Endif
# Recalculo de la tara
 [M:PKD1]ZPCKWEI=VALEUR - (sum([M:PKD1]NETWEIPCK(0..max([M:PKD1]NBLIG-1,nolign-1))))
 [M:PKD1]PCKWEI=[M:PKD1]ZPCKWEI
 Affzo [M:PKD1]ZPCKWEI
 Affzo [M:PKD1]PCKWEI

End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PKD1) 27/09/2016 11:32:19 (ADMIN)
######################################################################################
Subprog AM_ZPCKWEI(VALEUR)
Variable Decimal VALEUR
 [M:PKD1]PCKWEI=VALEUR
 Affzo [M:PKD1]PCKWEI
 Gosub TOT_GROWEI From FUNPKD
End


######################################################################################
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PKD1) 23/08/2017 10:05:45 (ADMIN)
######################################################################################
Subprog C_NBLIG
# JLPR 23-08-17 No se permite modificar dato alguno de la linea, pues se supone que:
# Venta en M2, no tiene sentido cambiar pesos,
# Venta en KG, el peso de las bobinas se debe de haber establecido antes de llegar aqui
#If GUSER="ADMIN"   Infbox "Depurar   (Subprog C_NBLIG    SPEPKD.src)"    Endif
Diszo [M:PKD1]QTY(nolign-1)
Diszo [M:PKD1]NETWEI(nolign-1)
End

######################################################################################
# 06.348.298.ini
Funprog FIND_PACK(VCRN,VCRL,LO,SL)
Value Char VCRN
Value Integer VCRL
Value Char LO
Value Char SL
Local Integer RTN :RTN=0
If clalev ([F:ZSPD])<=0  : Local File SPACKD     [ZSPD]  : Endif
If [M:PKD1]PACNUM<>""
  Filter [F:ZSPD] Where [F:ZSPD]VCRNUM=VCRN and [F:ZSPD]VCRLIN=VCRL and [F:ZSPD]LOT=LO and [F:ZSPD]SLO = SL and [F:ZSPD]PACNUM<>[M:PKD1]PACNUM
Else
  Filter [F:ZSPD] Where [F:ZSPD]VCRNUM=VCRN and [F:ZSPD]VCRLIN=VCRL and [F:ZSPD]LOT=LO and [F:ZSPD]SLO = SL
Endif

If rowcount([F:ZSPD])>0 : RTN=1 Endif
Filter [F:ZSPD]
End RTN
# 06.348.298.fin
