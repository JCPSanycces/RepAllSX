#<AdxTL>@(#)0.0.0.0 $Revision$
# CNSCPNSPE   Consulta cabecera devoluciones COMPRAS  M:CPN1 + M:CPN2   F:PNH
# FILTER -> Para construir filtro especifico
# Tipo ventana  CONSULTA # INQUIRY
$ACTION
#Infbox ACTION
Case ACTION
   When "OUVRE"    :   Gosub OUVRE
   When "FILTRE"   :   Gosub FILTRE
   When "FERME"    :   Gosub FIN
   When "TITRE"    :   Gosub INI_VALORES
   When "APRES_MODIF"  : Gosub LIMPIAR
   When "AV_AFFICHE"   : Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:PND])= 0 : Local File PRETURND  [PND] : Endif
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$FILTRE
Local Char TMP(200)
Local Integer T

Raz [M:CPN1]ZTOTKG
Raz [M:CPN1]ZTOTM2
Raz [M:CPN1]ZTOTIMPAI
Raz [M:CPN1]ZTOTIMPII
Affzo [M:CPN1]ZTOTKG
Affzo [M:CPN1]ZTOTM2
Affzo [M:CPN1]ZTOTIMPAI
Affzo [M:CPN1]ZTOTIMPII

TMP=""
If [M:CPN1]ZPRECOG=2 Then Call MONTAR_TMP(TMP,1):Endif
If [M:CPN1]ZPREVIS=2 Then Call MONTAR_TMP(TMP,2):Endif
If [M:CPN1]ZPFIRMA=2 Then Call MONTAR_TMP(TMP,3):Endif
If [M:CPN1]ZPABONO=2 Then Call MONTAR_TMP(TMP,4):Endif
If [M:CPN1]ZACEPTA=2 Then Call MONTAR_TMP(TMP,5):Endif
If [M:CPN1]ZNOACEP=2 Then Call MONTAR_TMP(TMP,6):Endif

If TMP<>"" Then
  TMP+=')'
  WFIL2+="&" + TMP
Endif
Return

Subprog MONTAR_TMP(TMP_P, VALOR_P)
Variable Char TMP_P
Value Integer VALOR_P
  If TMP_P ="" Then
    TMP_P+='('
  Else
    TMP_P+=' |'
  Endif
  TMP_P+='[F:PNH]ZSITFLG=' + num$(VALOR_P)
End


$LIMPIAR
  [M:CPN2]NBLIG=0:      Affzo [M:CPN2]
  [M:CPN1]ZTOTIMPII=0:  Affzo [M:CPN1]ZTOTIMPII
  [M:CPN1]ZTOTIMPII=0:  Affzo [M:CPN1]ZTOTIMPII
Return

$INI_VALORES
  [M:CPN1]ZACEPTA=2:Affzo[M:CPN1]ZACEPTA
  [M:CPN1]ZNOACEP=2:Affzo[M:CPN1]ZNOACEP
  [M:CPN1]ZPABONO=2:Affzo[M:CPN1]ZPABONO
  [M:CPN1]ZPFIRMA=2:Affzo[M:CPN1]ZPFIRMA
  [M:CPN1]ZPRECOG=2:Affzo[M:CPN1]ZPRECOG
  [M:CPN1]ZPREVIS=2:Affzo[M:CPN1]ZPREVIS
Return


$FIN
  If GPE=1 Then GPE=0:Endif
Return

$CAL_CUMUL
Raz [M:CPN1]ZTOTKG
Raz [M:CPN1]ZTOTM2
Raz [M:CPN1]ZTOTIMPAI
Raz [M:CPN1]ZTOTIMPII
Link [PNH] With [PND]PND0(0)=[F:PNH]PNHNUM As [LNK]
&     Order By Key PNH0
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
For [LNK]
   [M:CPN1]ZTOTIMPAI+=[F:PND]LINAMT
   [M:CPN1]ZTOTIMPII+=[F:PND]LINATIAMT
   Filter [PND] Where PNHNUM=[F:PNH]PNHNUM
   For [PND]
      Raz [F:ITM]
      Read [ITM]ITM0=[F:PND]ITMREF
      If [F:PND]UOM="M2"
         [M:CPN1]ZTOTKG+=arr([F:PND]QTYPUU*[F:ITM]ZFACTOR,0.01)
         [M:CPN1]ZTOTM2+=arr([F:PND]QTYPUU,0.01)
      Endif
      If [F:PND]UOM="KG"
         [M:CPN1]ZTOTKG+=arr([F:PND]QTYPUU,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CPN1]ZTOTM2+=arr([F:PND]QTYPUU/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CPN1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [PND]
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CPN1]ZTOTKG
Affzo [M:CPN1]ZTOTM2
Affzo [M:CPN1]ZTOTIMPAI
Affzo [M:CPN1]ZTOTIMPII
Return
