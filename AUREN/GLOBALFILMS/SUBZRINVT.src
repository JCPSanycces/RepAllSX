#<AdxTL>@(#)0.0.0.0 $Revision$
# Al entrar              OUVRE      #   OUVRE_BOITE #   TITRE   #     DEBUT  #    SETBOUT   #  AV_CHOIX
# OK                     AP_CHOIX   #   AVANT_OK    #   OK      #     FIN    #    FINSAI
# Salir de la funcion    AV_CHOIX   #   AP_CHOIX    #   END     #     FIN    #    FINSAI
# Click en boton         AP_CHOIX   #   AVANT_BOUTON#   BOUTON  #     SETBOUT#  AV_CHOIX
$ACTION
Case ACTION
When "OUVRE"        : Gosub OUVRE
When "TITRE"        : Gosub TITRE_
When "DEBUT"        : Gosub DEBUT
When "BOUTON"       : Gosub BOUTON
When "FIN"          : Gosub FIN
Endcase
Return

$FIN
If GFONCTION<>"GESZINVT"
  If dim(GFLDCHR)>0  Kill GFLDCHR   Endif
  If dim(GFLDNUM)>0  Kill GFLDNUM   Endif
Endif
Return

$OUVRE
If GFONCTION<>"GESZINVT"
  Global Char    GFLDCHR(80)(5)
  Global Decimal GFLDNUM(5)
Endif
If !clalev([F:MFG])      :  Local File MFGHEAD   [F:MFG]  : Endif
If !clalev([F:PTH])      :  Local File PRECEIPT  [F:PTH]  : Endif
Return

$TITRE_
TIT="CUADRE EXISTENCIAS  << EN PRUEBAS # PDTE.VALIDAR >>"
Return

$DEBUT
Chgfmt [M:ZRINVT0]ZNADA With "-"
# Guardo valores
GFLDCHR(0) = func ZCOMUN.DATA_BASE_TIPO()
## Tope de filas en rejilla
GFLDNUM(3) = func ZCOMUN.FILAS_GRID("ZRINVT1","NBLIG")
GFLDNUM(4) = func ZCOMUN.FILAS_GRID("ZRINVT2","NBLIG")

If GFONCTION="GESZINVT"
  [M:ZRINVT0]FCY   =[M:ZINVT0]FCY
  [M:ZRINVT0]FECINI=gdat$(1,[M:ZINVT0]ZMES,[M:ZINVT0]ZANO)
  [M:ZRINVT0]FECFIN=eomonth([M:ZRINVT0]FECINI)
  [M:ZRINVT0]ITMREF=[M:ZINVT0]FITM
  [M:ZRINVT0]LOT   =[M:ZINVT0]FLOT
  [M:ZRINVT0]RECEPC=[M:ZINVT0]FRECEPN
  Call AM_RECEPC([M:ZRINVT0]RECEPC) From SPEZRINVT0
  [M:ZRINVT0]OF    =[M:ZINVT0]FOFN
  Call AM_OF([M:ZRINVT0]OF) From SPEZRINVT0
  Affzo [M:ZRINVT0]5
#If GUSER="PALAU"   Call ACTU_ENVASADO([M:BOH0]ITMREF,[M:BOH0]ECCSEQ) From SUBZEXTR    Endif
  Call BUSCAR
Else
#  [M:ZRINVT0]FCY   =[M:ZINVT0]FCY
  [M:ZRINVT0]FECINI=gdat$(1,month(date$),year(date$))
  [M:ZRINVT0]FECFIN=eomonth([M:ZRINVT0]FECINI)
  Affzo [M:ZRINVT0]5
Endif
Return

$BOUTON
Case BOUT
When "1"    Call BUSCAR
Endcase
Return

Subprog BUSCAR
Call VACIAR_REJILLAS
Call LEER_MVTOS
End

Subprog VACIAR_REJILLAS
Raz   [M:ZRINVT1]NBLIG
Effzo [M:ZRINVT1]5
Raz [M:ZRINVT2]NBLIG
Effzo [M:ZRINVT2]5
End

Subprog LEER_MVTOS
Local Integer ZOK    :   ZOK=1
#Sacar mvtos
Local Char    PESTA(80)
Local Char    DET(GLONITM+GLONLOT+GLONSLO),RDET(GLONITM+GLONLOT+GLONSLO)
Local Decimal PRECT,TQTY,DIF,TIMP,IMP(8),ASIG,PREDOC
Local Char    FITM(GLONITM),FSTU(GLONUOM)
Local Char    RITM(GLONITM),FILT(255)
If clalev([F:WSTJ1]) <=0   :  Local File STOJOU     [F:WSTJ1]  : Endif
#
# Sacar articulos con Existencia inicial + Mvtos en perido !!!
#     FALTA Ex.Inicial !!!!
FILT="[F:WSTJ1]STOFCY=[M:ZINVT0]FCY & [F:WSTJ1]IPTDAT>=[M:ZRINVT0]FECINI & [F:WSTJ1]IPTDAT<=[M:ZRINVT0]FECFIN"
If [M:ZRINVT0]ITMREF<>""   FILT=FILT+" & [F:WSTJ1]ITMREF=[M:ZRINVT0]ITMREF"   Endif
If [M:ZRINVT0]LOT<>""      FILT=FILT+" & [F:WSTJ1]LOT=[M:ZRINVT0]FLOT"        Endif
# Para ver cuadre bobinas OBTENIDAS en OF, preguntamos por 16-Declaracion propduccion y ORI=OF
If [M:ZRINVT0]OF<>""       FILT=FILT+" & [F:WSTJ1]VCRTYP=16 & [F:WSTJ1]VCRNUMORI=[M:ZRINVT0]OF"        Endif
If [M:ZRINVT0]RECEPC<>""   FILT=FILT+" & [F:WSTJ1]VCRTYP=7  & [F:WSTJ1]VCRNUM=[M:ZRINVT0]RECEPC"       Endif
Filter [F:WSTJ1] Where evalue (FILT) Order By Key STJ4 #Order By ITMREF;LOT;SLO;IPTDAT
Raz RDET,RITM,TQTY
For [F:WSTJ1]
  If RITM<>[F:WSTJ1]ITMREF
    RITM=[F:WSTJ1]ITMREF
    Call DATOS_ART(RITM,[F:WSTJ1]STU,ZOK)
    If not ZOK   End   Endif
  Endif
Next
Affzo [M:ZRINVT1]5
Affzo [M:ZRINVT2]5
End

Subprog DATOS_ART(ART,STU,ZOK)
Value    Char ART,STU
Variable Integer ZOK
Local Integer F
F=[M:ZRINVT1]NBLIG
If F+1>=GFLDNUM(3)
  MSG="FALTAN DATOS !!!\Alcanzado máximo de " + num$(GFLDNUM(3)+1) + " filas para mostrar Cantidad\.\Avise para que se lo aumenten"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  ZOK=0
Endif
[M:ZRINVT1]ITMREF(F)=ART
[M:ZRINVT1]UNIDAD(F)=STU
[M:ZRINVT1]NBLIG+=1
End



#  DET=[F:WSTJ1]ITMREF+"#"+[F:WSTJ1]LOT+"#"+[F:WSTJ1]SLO
#  If RDET<>DET
#    Gosub DETALLE
#    RDET=DET
#    Raz TQTY,TIMP
#    FTIP=-1
#    If not ZOK Break Endif
#  Endif
#  #Guardo datos
#  FITM=[F:WSTJ1]ITMREF
#  If [F:WSTJ1]STU<>""     FSTU=[F:WSTJ1]STU    Endif
#  Gosub ACUMULA_CANT_VAL  From SUBZINVT
#Next

$DETALLE
ZOK=1
If RDET="" or TQTY=0 Return Endif
If RITM<>left$(RDET,instr(1,RDET,"#")-1)
  RITM=left$(RDET,instr(1,RDET,"#")-1)
Endif
Return


Subprog EXINI
End

