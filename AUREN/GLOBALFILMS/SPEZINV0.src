Subprog AM_ZPROCESO(VALEUR)
Variable Integer VALEUR
[M:ZINV0]ZPROCESO=VALEUR
Affzo [M:ZINV0]ZPROCESO
Call VACIAR_REJILLA From SPEZINVE
If VALEUR>1
  [M:ZINV0]FERR=1
  Affzo [M:ZINV0]FERR
  Call MOSTRAR_CALCULOS  From SPEZINVE
Else
  Raz [M:ZINV0]FLDCHR(1),[M:ZINV0]FLDCHR(3),[M:ZINV0]FLDCHR(4)
Endif
End

Subprog AM_ZMOSTRAR(VALEUR)
Variable Decimal VALEUR
If VALEUR<1
  VALEUR=10
Endif
[M:ZINV0]ZMOSTRAR=VALEUR
Affzo [M:ZINV0]ZMOSTRAR
Call MOSTRAR_CALCULOS From SPEZINVE
End

Subprog AM_ZPROCES(VALEUR)
Variable Integer VALEUR
If VALEUR =2
  Chgstl [M:ZINV0]ZPROCES With "BACKYELLOW"
Else
  Chgstl [M:ZINV0]ZPROCES With ""
Endif
[M:ZINV0]ZPROCES=VALEUR
Affzo [M:ZINV0]ZPROCES
Call MOSTRAR_CALCULOS From SPEZINVE
End

Subprog AM_FERR(VALEUR)
Variable Integer VALEUR
If VALEUR =2
  Chgstl [M:ZINV0]FERR With "BACKRED"
Else
  Chgstl [M:ZINV0]FERR With ""
Endif
End


Subprog AS_NCALC
Local Integer F
F=nolign-1
[M:ZINV0]FLDNUM(1)=F
If [M:ZINV0]CFECHA(F) <>[0/0/0] and F>=0 and [M:ZINV0]ZPROCESO>1
  Call MOSTRAR_INV_FIC(F) From SPEZINVE
  Call MOSTRAR_INV_COLOR  From SPEZINVE
Endif
End
