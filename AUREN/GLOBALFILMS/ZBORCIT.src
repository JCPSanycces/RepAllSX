#<AdxTL>@(#)0.0.0.0 $Revision$
#JLPR 11-05-17 Revision
#Proceso para borrar segun criterios las asignaciones de tarifas a clientes
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_BORCIT
  When "TERMINE"        : Gosub TERMINE_BORCIT
  When "INIT_DIA"       : Gosub INIT_DIA_BORCIT
  When "OK"             : Gosub OK_BORCIT
  When "END"            : Gosub END_BORCIT
Endcase
Return

$TRT_INI
If clalev([F:ZFTRA])<=0 : Local File ZBPCITMTAR   [F:ZCIT] : Endif
Return

$EXEC_BORCIT
If !GSERVEUR
  Local Integer YN   :  YN=1
  If [M:ZBCIT]BORRAR=2
    Call OUINON("Está seguro de BORRAR estos registros\Recuerde es preferible marcarlos como ANULADOS", YN) From GESECRAN
  Else
    Call OUINON("Está seguro de marcar estos registros como ANULADOS", YN) From GESECRAN
  Endif
  If YN=1   Return    Endif
Endif

Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Borrado cliente-articulo-tarifa",0) From GESECRAN
Else
  Call OUVRE_TRACE("Inicio borrado cliente-articulo-tarifa") From LECFIC
Endif

WMSG = "Borrado cliente-articulo-tarifa"
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZBORCIT","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

Gosub BORCIT
Return

$BORCIT
Local Char CRITERIO(250)(2),MSG(250)(3)
Local Integer OK

Raz CRITERIO
CRITERIO(0)='[F:ZCIT]ZLONGITUD>='+num$([M:ZBCIT]LONSTR)+' & [F:ZCIT]ZLONGITUD<='+num$([M:ZBCIT]LONEND)

If [M:ZBCIT]FECINI<>[0/0/0]
   CRITERIO(0)+=' & [F:ZCIT]PLISTRDAT>=['+format$(GFMD,[M:ZBCIT]FECINI)+"]"
Endif
If [M:ZBCIT]FECFIN<>[0/0/0]
   CRITERIO(0)+=' & [F:ZCIT]PLISTRDAT<=['+format$(GFMD,[M:ZBCIT]FECFIN)+"]"
Endif

If [M:ZBCIT]BPCSTR<>''
   CRITERIO(0)+=' & [F:ZCIT]BPCNUM>="'+[M:ZBCIT]BPCSTR+'"'
Endif
If [M:ZBCIT]BPCEND<>''
   CRITERIO(0)+=' & [F:ZCIT]BPCNUM<="'+[M:ZBCIT]BPCEND+'"'
Endif

If [M:ZBCIT]ITMSTR<>''
   CRITERIO(1)+=' & [F:ZCIT]ITMREF>="'+[M:ZBCIT]ITMSTR+'"'
Endif
If [M:ZBCIT]ITMEND<>''
   CRITERIO(1)+=' & [F:ZCIT]ITMREF<="'+[M:ZBCIT]ITMEND+'"'
Endif

If [M:ZBCIT]PLISTR<>''
   CRITERIO(1)+=' & [F:ZCIT]PLI>="'+[M:ZBCIT]PLISTR+'"'
Endif
If [M:ZBCIT]PLIEND<>''
   CRITERIO(1)+=' & [F:ZCIT]PLI<="'+[M:ZBCIT]PLIEND+'"'
Endif


OK=1
Trbegin [F:ZCIT]
If [M:ZBCIT]BORRAR=2
  Delete [F:ZCIT] Where evalue(CRITERIO)
  MSG(0)="BORRANDO"
  MSG(1)="BORRADOS"
Else
  Update [F:ZCIT] Where evalue(CRITERIO) With ANULADO=2,FECANU=date$
  MSG(0)="ANULANDO"
  MSG(1)="MARCADOS COMO ANULADOS"
Endif
If fstat
   MSG(2)="Error "+MSG(0)+" cliente-articulo-tarifa - fstat: "+num$(fstat)
   Call ECR_TRACE(MSG(2),1) From GESECRAN
#   Call ERREURT  (MSG,1) From GESECRAN   #0-Informativo, 1-Error
   OK=0
Else
   If [M:ZBCIT]BORRAR=2
     MSG(2)=num$(adxdlrec)+" registros "+MSG(1)
   Else
     MSG(2)=num$(adxuprec)+" registros "+MSG(1)
   Endif
   Call ECR_TRACE(MSG(2),0) From GESECRAN
Endif

If OK
   Commit
Else
   Rollback
Endif
Return

$INIT_DIA_BORCIT
#Call ERREURT ("10-05-17 JLPR\Proceso en desuso", 1) From GESECRAN   #0-Informativo, 1-Error
#FIN=1
#Local Mask ZBORCIT [ZBCIT]
#Raz [M:ZBCIT]
#[M:ZBCIT]SALFCY = GFCYDEF(0)
[M:ZBCIT]ANULAR=2
[M:ZBCIT]BORRAR=1
Return

$TERMINE_BORCIT
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3
Endif
Return

$OK_BORCIT
#Raz [M:ZBCIT]
#FIN  = 1
Return

$END_BORCIT
#Raz [M:ZBCIT]
#FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End



Subprog AM_BPCSTR(VALEUR)
Variable Char    VALEUR()
If [M:ZBCIT]BPCEND < VALEUR : [M:ZBCIT]BPCEND = VALEUR : Affzo [M:ZBCIT]BPCEND : Endif
End

Subprog AM_ITMSTR(VALEUR)
Variable Char    VALEUR()
If [M:ZBCIT]ITMEND < VALEUR : [M:ZBCIT]ITMEND = VALEUR : Affzo [M:ZBCIT]ITMEND : Endif
End

Subprog AM_PLISTR(VALEUR)
Variable Char    VALEUR()
If [M:ZBCIT]PLIEND < VALEUR : [M:ZBCIT]PLIEND = VALEUR : Affzo [M:ZBCIT]PLIEND : Endif
End

Subprog AM_LONSTR(VALEUR)
Variable Decimal VALEUR
If [M:ZBCIT]LONEND < VALEUR : [M:ZBCIT]LONEND = VALEUR : Affzo [M:ZBCIT]LONEND : Endif
End

Subprog AM_ANULAR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZBCIT]BORRAR=1
Else
  [M:ZBCIT]BORRAR=2
Endif
Affzo [M:ZBCIT]BORRAR
End

Subprog AM_BORRAR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:ZBCIT]ANULAR=1
Else
  [M:ZBCIT]ANULAR=2
Endif
Affzo [M:ZBCIT]ANULAR
End

Subprog AM_FECINI(VALEUR)
Variable Date    VALEUR
If [M:ZBCIT]FECFIN < VALEUR : [M:ZBCIT]FECFIN = VALEUR : Affzo [M:ZBCIT]FECFIN : Endif
End
