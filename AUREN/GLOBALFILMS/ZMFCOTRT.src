######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMFGCOR0) 28/02/2016 18:21:28 (ADMIN)
######################################################################################
Subprog C_ZANCHO(VALEUR)
Variable Decimal VALEUR
If [M:ZMFC1]ZSELANCHO<>0 and VALEUR<>[M:ZMFC1]ZSELANCHO
    [M:ZMFC0]ZANCHO=[M:ZMFC1]ZSELANCHO
    Affzo [M:ZMFC0]ZANCHO
   GMESSAGE="Debe quitar primero los pedidos seleccionados"
   mkstat=2
Endif
End

Subprog C_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
If [M:ZMFC1]ZSELLONG<>0 and VALEUR<>[M:ZMFC1]ZSELLONG
   # [M:ZMFC0]ZLONGITUD=[M:ZMFC1]ZSELLONG
   # Affzo [M:ZMFC0]ZLONGITUD
   #GMESSAGE="Debe quitar primero los pedidos seleccionados"
   #mkstat=2
Endif
End

Subprog C_ZMANDRIL(VALEUR)
Variable Decimal VALEUR
If [M:ZMFC1]ZSELMANDRIL<>0 and VALEUR<>[M:ZMFC1]ZSELMANDRIL
   # [M:ZMFC0]ZMANDRIL=[M:ZMFC1]ZSELMANDRIL
   # Affzo [M:ZMFC0]ZMANDRIL
   #GMESSAGE="Debe quitar primero los pedidos seleccionados"
   #mkstat=2
Endif
End


#Ańadir linea a MFG1, no utilizada
$ANADIR_LIN_BAK
Local Integer I, WLLIG, MFGLINMAX

If [M:ZMFC0]ITMREF="" or [M:ZMFC0]ZANCHO=0 or [M:ZMFC0]ZNRANCHO=0 or [M:ZMFC0]ZMANDRIL=0 or [M:ZMFC0]ZLONGITUD=0 or
&  [M:ZMFC0]ZSUPERFICIE=0 or [M:ZMFC0]ZNTIRADAS=0
   Infbox "Datos insuficientes: "+[M:ZMFC0]ITMREF+" A: "+num$([M:ZMFC0]ZANCHO)+" R: "+num$([M:ZMFC0]ZNRANCHO)+" M: "+num$([M:ZMFC0]ZMANDRIL)+
&         " L: "+num$([M:ZMFC0]ZLONGITUD)+" T: "+num$([M:ZMFC0]ZNTIRADAS)+" S: "+num$([M:ZMFC0]ZSUPERFICIE)

   Return
Endif

MFGLINMAX=0
For I=0 To [M:MFG1]NBLIG
   If MFGLINMAX<[M:MFG1]MFGLIN(I)
      MFGLINMAX=[M:MFG1]MFGLIN(I)
   Endif
Next

nolign=[M:MFG1]NBLIG

WLLIG=[M:MFG1]NBLIG

#Pasar datos a Lineas
[M:MFG1]MFGLIN(WLLIG)=MFGLINMAX+1000
[M:MFG1]ITMREF(WLLIG)=[M:ZMFC0]ITMREF
[M:MFG1]ZANCHO(WLLIG)=[M:ZMFC0]ZANCHO
[M:MFG1]ZLONGITUD(WLLIG)=[M:ZMFC0]ZLONGITUD
[M:MFG1]ZMANDRIL(WLLIG)=[M:ZMFC0]ZMANDRIL
[M:MFG1]ZGRPCOR(WLLIG)=[M:ZMFC0]ZGRPCOR
[M:MFG1]ZNRANCHO(WLLIG)=[M:ZMFC0]ZNRANCHO
[M:MFG1]ZNTIRADAS(WLLIG)=[M:ZMFC0]ZNTIRADAS
[M:MFG1]ZFACTOR(WLLIG)=[M:ZMFC0]ZFACTOR
[M:MFG1]ZQTYBOB(WLLIG)=[M:ZMFC0]ZQTYBOB
[M:MFG1]ZSUPERFICIE(WLLIG)=[M:ZMFC0]ZSUPERFICIE
[M:MFG1]ZPROVEEDOR(WLLIG)=[M:ZMFC0]ZPROVEEDOR
[M:MFG1]ZNCORTES(WLLIG)=[M:ZMFC0]ZNCORTES
[M:MFG1]ZLOC(WLLIG)=[M:ZMFC0]ZLOC
[M:MFG1]ZFABCOR(WLLIG)=2
Affzo [M:MFG1]ITMREF(WLLIG)
Affzo [M:MFG1]ZANCHO(WLLIG)
Affzo [M:MFG1]ZLONGITUD(WLLIG)
Affzo [M:MFG1]ZMANDRIL(WLLIG)
Affzo [M:MFG1]ZQTYBOB(WLLIG)
Affzo [M:MFG1]ZNRANCHO(WLLIG)
Affzo [M:MFG1]ZNTIRADAS(WLLIG)
Affzo [M:MFG1]ZFACTOR(WLLIG)
Affzo [M:MFG1]ZSUPERFICIE(WLLIG)
Affzo [M:MFG1]ZPROVEEDOR(WLLIG)
Affzo [M:MFG1]ZGRPCOR(WLLIG)
Affzo [M:MFG1]ZNCORTES(WLLIG)
Affzo [M:MFG1]ZLOC(WLLIG)
# Pasar Pedidos a Mascara MFG1

Local Integer WNLPED, WLI
# Borrar cualquier asignacion previa de pedidos a linea.
Call BORRAR_PEDASI([M:MFG1]MFGLIN(WLLIG)) From SPEMFG
WNLPED=[M:MFG1]ZNBLP
If [M:ZMFC1]ZSELITM<>""
   [M:MFG1]ZPEDCLI(WLLIG)=2
   # Asigna pedidos seleccionados a mascara de pedidos detalle
  WNLPED=[M:MFG1]ZNBLP
  For WLI = 0 To [M:ZMFC1]NBLIG - 1
    If [M:ZMFC1]ZQTYBOBASI(WLI)<>0
       [M:MFG1]ZMFGLIN(WNLPED)=[M:MFG1]MFGLIN(WLLIG)
       [M:MFG1]ZSOHNUM(WNLPED)=[M:ZMFC1]SOHNUM(WLI)
       [M:MFG1]ZSOPLIN(WNLPED)=[M:ZMFC1]SOPLIN(WLI)
       [M:MFG1]ZSOQSEQ(WNLPED)=[M:ZMFC1]SOQSEQ(WLI)
       [M:MFG1]ZQTYBOBASI(WNLPED)=[M:ZMFC1]ZQTYBOBASI(WLI)
       Raz [F:SOHX]
       Read [F:SOHX]SOH0=[M:ZMFC1]SOHNUM(WLI)
       If fstat
          Infbox "Problema recuperando pedido (3): "+[M:ZMFC1]SOHNUM(WLI)+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOPX]
       Read [F:SOPX]SOP0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (P3): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOQX]
       Read [F:SOQX]SOQ0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (Q3): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" "+num$([M:ZMFC1]SOQSEQ(WLI))+" - fstat: "+num$(fstat)
       Endif
       [M:MFG1]ZANCHOP(WNLPED)=[F:SOQX]ZANCHO
       [M:MFG1]ZMANDRILP(WNLPED)=[F:SOQX]ZMANDRIL
       [M:MFG1]ZLONGITUDP(WNLPED)=[F:SOQX]ZLONGITUD
       [M:MFG1]ZBPCNAM(WNLPED)=[F:SOHX]BPCNAM
       [M:MFG1]ZNETPRI(WNLPED)=[F:SOPX]NETPRI
       [M:MFG1]ZDLVDAT(WNLPED)=[F:SOQX]EXTDLVDAT
       WNLPED +=1
    Endif
  Next
  [M:MFG1]ZNBLP=WNLPED

Else  # No hay pedidos asignados
  [M:MFG1]ZPEDCLI(WLLIG)=1
Endif

#Inicio FJCG
   #Call AM_ITMREF([M:MFG1]ITMREF(WLLIG)) From SUBMFG
   [M:MFG1]ITMTYP(WLLIG)     = 1
   Read [ITM]ITM0=[M:ZMFC0]ITMREF
   [M:MFG1]ITMDES1(WLLIG)=[F:ITM]ITMDES1

   [M:MFG1]BOMALT(WLLIG)=40
   Call LECTEXTRA([M:MFG1]TBOSHO(WLLIG),"TABBOMALT","TBOSHOAXX",num$(2),num$([M:MFG1]BOMALT(WLLIG))) From ATEXTRA
   #Gosub RECH_NOM From SUBMFGA

   [M:MFG1]UOM(WLLIG)=[F:ITM]STU
   [M:MFG1]STU(WLLIG)=[F:ITM]STU
   Affzo [M:MFG1]ITMDES1(WLLIG)
   Affzo [M:MFG1]UOM(WLLIG)
   Affzo [M:MFG1]STU(WLLIG)

    Case [M:MFG1]UOM(WLLIG)
        When [F:ITM]STU: [M:MFG1]UOMSTUCOE(WLLIG) = 1
        When [F:ITM]PUU: [M:MFG1]UOMSTUCOE(WLLIG) = [F:ITM]PUUSTUCOE
        When [F:ITM]SAU: [M:MFG1]UOMSTUCOE(WLLIG) = [F:ITM]SAUSTUCOE
        When Default:    For I = 0 To dim([F:ITM]PCU)-1
                             If [M:MFG1]UOM(WLLIG) = [F:ITM]PCU(I)
                                 [M:MFG1]UOMSTUCOE(WLLIG) = [F:ITM]PCUSTUCOE(I)
                             Endif
                         Next I
    Endcase

   #Call AM_UOMEXTQTY([M:ZMFC0]ZUOMEXTQTY) From SUBMFG
   #If mkstat : Return : Endif

   Local Decimal WQTY
   WQTY = [M:ZMFC0]ZUOMEXTQTY * [M:MFG1]UOMSTUCOE(WLLIG)
   Call QTEARR(WQTY,[M:MFG1]STU(WLLIG)) From TRTDIV
   [M:MFG1]EXTQTY(WLLIG) = WQTY

   [M:MFG1]UOMEXTQTY(WLLIG)=[M:ZMFC0]ZUOMEXTQTY
   Affzo [M:MFG1]ZCOSFAB(WLLIG)
   Affzo [M:MFG1]ITMSTA(WLLIG)
   Affzo [M:MFG1]UOMEXTQTY(WLLIG)
   Affzo [M:MFG1]UOMSTUCOE(WLLIG)
   Affzo [M:MFG1]EXTQTY(WLLIG)
   Affzo [M:MFG1]BOMALT(WLLIG)
   Affzo [M:MFG1]TBOSHO(WLLIG)
   Affzo [M:MFG1]PJT(WLLIG)
   Affzo [M:MFG1]BPCTYPDEN(WLLIG)
   Affzo [M:MFG1]BPCNUM(WLLIG)
   Affzo [M:MFG1]BPCDES(WLLIG)
   Affzo [M:MFG1]ITMTYP(WLLIG)
   Affzo [M:MFG1]SHR(WLLIG)
   Affzo [M:MFG1]PLANNER(WLLIG)
   Affzo [M:MFG1]XFMI(WLLIG)

   [M:MFG1]MFGEXTQTY=[M:MFG1]MFGEXTQTY+[M:MFG1]EXTQTY(WLLIG)
   #[M:MFG1]SCDFLG=1
   Affzo [M:MFG1]MFGEXTQTY
   #Affzo [M:MFG1]SCDFLG

   [M:MFG1]NBLIG+=1

#Fin FJCG

Affzo [M:MFG1]ZPEDCLI(WLLIG)
Affzo [M:MFG1]35

# Pasar Bobinas a Mascara MFG2
  Gosub GC_GUARDABOBINAS
  Gosub CALCULA_LONGITUDTOTAL From SPEMFG
  Gosub CALCULA_MERMA From SPEMFG
Return

$ESTADO_INICIAL
  #JLPR 17.05.16
  #[M:ZMFC0]ZGC_ULT=0:[M:ZMFC0]ZGC_ACT=0
  If GACTION="ZMFCORA" Then
    Actzo [M:ZMFC0]ZGRPCOR
  Else
#    Grizo [M:ZMFC0]ZGRPCOR
    Diszo [M:ZMFC0]ZGRPCOR
  Endif
  Affzo [M:ZMFC0]ZGRPCOR
  #
  Gosub GC_CARGABOBINAS
Return
