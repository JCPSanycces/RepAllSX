$GC_CARGABOBINAS
Local Integer WLNOL : WLNOL = 0
Local Integer WLI, WLLOTUSADO

If clalev([F:STOX])<=0 : Local File STOCK [STOX] : Endif

Raz [M:ZMFC3]
For WLI=0 To  [M:MFG2]ZNBLOT - 1
   If [M:MFG2]ZLTGRPCOR(WLI)=[M:ZMFC0]ZGRPCOR Then
      Raz [F:STOX]
      Read  [STOX]STO0=[M:MFG0]MFGFCY;[M:MFG2]ZLTSTOCOU(WLI)
      [M:ZMFC3]LOC(WLNOL)=[F:STOX]LOC
      [M:ZMFC3]ITMREF(WLNOL)=[M:MFG2]ZLTITMREF(WLI)
      [M:ZMFC3]LOT(WLNOL)=[M:MFG2]ZLTLOT(WLI)
      [M:ZMFC3]SLO(WLNOL)=[M:MFG2]ZLTSLO(WLI)
      [M:ZMFC3]ZGRPCOR(WLNOL)=[M:MFG2]ZLTGRPCOR(WLI)
      [M:ZMFC3]ZANCHO(WLNOL)=[M:MFG2]ZLTANCHO(WLI)
      [M:ZMFC3]ZMANDRIL(WLNOL)=[M:MFG2]ZLTMANDRIL(WLI)
      [M:ZMFC3]ZLONGITUD(WLNOL)=[M:MFG2]ZLTLONGITUD(WLI) : #FJCG
      [M:ZMFC3]ZPROVEEDOR(WLNOL)=[M:MFG2]ZLTPROVEEDOR(WLI)
      [M:ZMFC3]ZNCORTES(WLNOL)=[M:MFG2]ZLTNCORTES(WLI)
      [M:ZMFC3]ZSOBRANTE(WLNOL)=[M:MFG2]ZLTSOBRANTE(WLI)
      [M:ZMFC3]ZLONGSOB(WLNOL)=[M:MFG2]ZLTLONGSOB(WLI)
      [M:ZMFC3]QTYSTU(WLNOL)=[M:MFG2]ZLTQTYSTUASI(WLI)
      [M:ZMFC3]ZQTYSTUREAL(WLNOL)=[M:MFG2]ZLTQTYSTUREA(WLI)
      [M:ZMFC3]STOCOU(WLNOL)=[M:MFG2]ZLTSTOCOU(WLI)
      [M:ZMFC3]STU(WLNOL)=[M:MFG2]ZLTSTU(WLI)
      If WLI=0 Then
#         [M:ZMFC3]ZSELITM=[M:MFG2]ZLTITMREF(WLI)
#         [M:ZMFC3]ZSELANCHO=[M:MFG2]ZLTANCHO(WLI)
#         [M:ZMFC3]ZSELMANDRIL=[M:MFG2]ZLTMANDRIL(WLI)
          [M:ZMFC3]ZSELSTU=[M:MFG2]ZLTSTU(WLI)
     Endif
      [M:ZMFC3]ZSELQTYBOB += 1
      [M:ZMFC3]ZSELQTYSTU += [M:ZMFC3]ZQTYSTUREAL(WLNOL)
      [M:ZMFC3]ZSELSUPERF += ([M:ZMFC3]ZLONGITUD(WLNOL)*[M:ZMFC3]ZANCHO(WLNOL) / 1000)
      [M:ZMFC3]ZSELLONG   += [M:ZMFC3]ZLONGITUD(WLNOL)

      WLNOL +=1
      If WLNOL>499 : #FJCG
         Break
      Endif
   Endif
Next


[M:ZMFC3]NBLOT=WLNOL
Affzo [M:ZMFC3]10
Affzo [M:ZMFC3]5
Return

#FJCP 12/02/2016 Transfiere Lotes presasignados a pantalla MFG2
$GC_GUARDABOBINAS
Local Integer WLI,WLJ
Local Integer WLLONGASI,WLSUPERFASI
Local Decimal WLQTYASI

Call MFG2_BORRAR_LOTASI([M:ZMFC0]ZGRPCOR) From SPEMFG2
WLJ=[M:MFG2]ZNBLOT

For WLI = 0 To [M:ZMFC3]NBLOT - 1
      #[M:MFG2]ZLTMFGLIN(WLJ)=[M:MFMW]MFGLIN(WLI)
      WLLONGASI=[M:ZMFC3]ZLONGITUD(WLI)
       # Calculamos cantidades a asignar
      WLSUPERFASI=[M:ZMFC3]ZANCHO(WLI)*WLLONGASI/1000
      #WLQTYASI=WLSUPERFASI*[M:ZMFC0]ZFACTOR
      [M:MFG2]ZLTMFGLIN(WLJ)=0
      [M:MFG2]ZLTGRPCOR(WLJ)=[M:ZMFC0]ZGRPCOR
      [M:MFG2]ZLTITMREF(WLJ)=[M:ZMFC3]ITMREF(WLI)
      [M:MFG2]ZLTANCHO(WLJ)=[M:ZMFC3]ZANCHO(WLI)
      [M:MFG2]ZLTLONGITUD(WLJ)=WLLONGASI
      [M:MFG2]ZLTMANDRIL(WLJ)= [M:ZMFC3]ZMANDRIL(WLI)
      [M:MFG2]ZLTSTOFCY(WLJ)=[M:MFG0]MFGFCY
      [M:MFG2]ZLTSTOCOU(WLJ)=[M:ZMFC3]STOCOU(WLI)
      [M:MFG2]ZLTLOT(WLJ)=[M:ZMFC3]LOT(WLI)
      [M:MFG2]ZLTSLO(WLJ)=[M:ZMFC3]SLO(WLI)
      #[M:MFG2]ZLTQTYSTUASI(WLJ)=WLQTYASI
      [M:MFG2]ZLTQTYSTUASI(WLJ)=[M:ZMFC3]QTYSTU(WLI)
      [M:MFG2]ZLTQTYSTUREA(WLJ)=[M:ZMFC3]ZQTYSTUREAL(WLI)
      [M:MFG2]ZLTSTU(WLJ)=[M:ZMFC3]STU(WLI)
      [M:MFG2]ZLTPROVEEDOR(WLJ)=[M:ZMFC3]ZPROVEEDOR(WLI)
      [M:MFG2]ZLTNCORTES(WLJ)=[M:ZMFC3]ZNCORTES(WLI)
      [M:MFG2]ZLTSOBRANTE(WLJ)=[M:ZMFC3]ZSOBRANTE(WLI)
      [M:MFG2]ZLTLONGSOB(WLJ)=[M:ZMFC3]ZLONGSOB(WLI)
      [M:MFG2]ZLTSUPERF(WLJ)=WLSUPERFASI
      #[M:MFG2]ZLTFACTOR(WLJ)=[M:ZMFC0]ZFACTOR
      #FJCG - Para redondear por lo menos a 6 decimals 06-12-16
      #[M:MFG2]ZLTFACTOR(WLJ)=[M:ZMFC3]QTYSTU(WLI)/WLSUPERFASI
      [M:MFG2]ZLTFACTOR(WLJ)=arr([M:ZMFC3]QTYSTU(WLI)/WLSUPERFASI,0.000001)
      Call MFG2_LEER_LOTASI_R(WLJ) From SPEMFG2

      WLJ +=1
      If WLJ=500 : Break : Endif
Next
[M:MFG2]ZNBLOT=WLJ
Affzo [M:MFG2]15
#If WLJ>0 Then
#   [M:MFG1]ZMANDMAT=[M:ZMFC0]ZMANDRIL
#   Affzo [M:MFG1]ZMANDMAT
#Endif
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMFGCOR0) 04/02/2016 10:26:14 (ADMIN)
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
#    Lecture article et article/site
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat
      GMESSAGE = mess(134,100,1)
      mkstat = 2
      End
    Endif
Endif
#    Lecture article/site
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
    Read [ITF]ITF0=VALEUR;[M:MFG0]MFGFCY
    If fstat
      GMESSAGE = mess(45,193,1)
      mkstat = 2
      End
    Endif
Endif
If  [F:ITM]ZFABCOR<>2
    GMESSAGE =  'Articulo no Fabricado por corte'
    mkstat = 2
    End
Endif
End

Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:MFG1]ITMREF(0)
   [M:ZMFC0]ITMREF=VALEUR
   Affzo [M:ZMFC0]ITMREF
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer  I,NOLX
NOLX=[M:ZMFC0]ZNOL

#Inicio FJCG
If [M:MFG1]NBLIG>0
   For I=0 To [M:MFG1]NBLIG-1
      If VALEUR<>[M:MFG1]ITMREF(I)
         Infbox "Articulo diferente al ya cargado"
         mkstat=2
         End
      Endif
   Next
Endif
#Fin FJCG
Raz [F:ITM]
Read [ITM]ITM0=VALEUR
If [F:ITM]ZFACTOR<>0
   [M:ZMFC0]ZFACTOR  = [F:ITM]ZFACTOR
Else
   [M:ZMFC0]ZFACTOR  = 1
Endif
Affzo [M:ZMFC0]ZFACTOR

#JLPR 18.05 Se comenta porque si entramos por:
#        Modificar   no se permite cambiarlo
#        Ańadir      se asume que será el siguiente al ultimo existente
## Grupo corte
## Valor el anterior grupo corte
#
#While  NOLX>0 and [M:MFG1]ZGRPCOR(NOLX-1)=0  :  NOLX-=1 : Wend
#
#If NOLX = 0 : [M:ZMFC0]ZGRPCOR=1 : Else :[M:ZMFC0]ZGRPCOR=[M:MFG1]ZGRPCOR(NOLX-1) :  Endif
#
#Affzo [M:ZMFC0]ZGRPCOR

If GACTION="ZMFCORM"
   #Flag pedido cliente
   If [M:ZMFC0]ZPEDCLI<>2 Then [M:ZMFC0]ZPEDCLI=1 : Affzo [M:ZMFC0]ZPEDCLI : Endif
Endif

[M:ZMFC0]ITMREF=VALEUR
#Gosub BUSCAR_PEDIDOS
End

Subprog AS_ZGRPCOR(VALEUR)
Variable Decimal VALEUR
Local Integer I, LULGR, MAND

#If GACTION="ZMFCORM"
#   mkstat=2 : End
#Endif
If GACTION="ZMFCORA"
   LULGR=0:MAND=0
   For I=0 To [M:MFG1]NBLIG-1
      If [M:MFG1]ZGRPCOR(I)<>0
         LULGR=[M:MFG1]ZGRPCOR(I)
      Endif
      If [M:MFG1]ZGRPCOR(I)<>0
      Endif
   Next
   For I=0 To [M:MFG1]ZNBLAUX-1
      If [M:MFG1]ZLAGRPCOR(I)<>0
         LULGR=[M:MFG1]ZLAGRPCOR(I)
      Endif
   Next
   If VALEUR>=LULGR+1
      VALEUR=LULGR+1
   Else
      VALEUR=LULGR
   Endif
Endif
End

Subprog C_ZGRPCOR(VALEUR)
Variable Decimal VALEUR
Local Integer LULGR
Local Integer I, NOLX
NOLX=[M:ZMFC0]ZNOL

# Valor siguiente al último grupo corte

#While  NOLX>0 and [M:MFG1]ZGRPCOR(NOLX-1)=0  :  NOLX-=1 : Wend
#If NOLX = 0 : LULGR=1 : Else : LULGR=[M:MFG1]ZGRPCOR(NOLX-1) :  Endif
#If VALEUR=0 Then
#VALEUR=LULGR
#Elsif VALEUR > LULGR + 1
#VALEUR=LULGR + 1
#Endif

LULGR=0
#If GACTION="ZMFCORA"
   For I=0 To NOLX-1
      If [M:MFG1]ZGRPCOR(I)<>0
         LULGR=[M:MFG1]ZGRPCOR(I)
      Endif
   Next
   For I=0 To [M:MFG1]NBLIG-1
      If [M:MFG1]ZGRPCOR(I)>LULGR
         LULGR=[M:MFG1]ZGRPCOR(I)
      Endif
   Next
#Endif
If GACTION="ZMFCORA"
   For I=0 To [M:MFG1]ZNBLAUX-1
      If [M:MFG1]ZLAGRPCOR(I)<>0
         LULGR=[M:MFG1]ZLAGRPCOR(I)
      Endif
   Next
Endif
If VALEUR>=LULGR+1
   VALEUR=LULGR+1
Else
   If GACTION="ZMFCORM"
      VALEUR=LULGR
   Endif
Endif
End

Subprog AM_ZGRPCOR(VALEUR)
Variable Decimal VALEUR
[M:ZMFC0]ZGRPCOR=VALEUR
Gosub GC_CARGABOBINAS
End

