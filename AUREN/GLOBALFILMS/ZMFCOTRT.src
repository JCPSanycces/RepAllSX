Subprog ZMFCO_BORRAR_LOTASI()
# FJCP 12/02/2016 Cambio Lotes presasignados a lineas de productos y no de materiales.
#Local Integer WLI
#
#For WLI= 0 To [M:MFG2]ZNBLOT-1
