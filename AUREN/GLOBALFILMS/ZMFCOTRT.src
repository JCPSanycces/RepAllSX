######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZMFGCOR1) 04/02/2016 10:57:34 (ADMIN)
######################################################################################
Subprog AVANT_NBLIG
Local Integer F
F=nolign-1
If [M:ZMFC1]ITMREF(F)<>"" and ( [M:ZMFC1]ZSELQTYBOB=0 or ([M:ZMFC1]ZSELQTYBOB>0 and [M:ZMFC1]ZSELLONG =[M:ZMFC1]ZLONGITUD(F)) )
  If [M:ZMFC0]ZANCHO<>[M:ZMFC1]ZANCHO(F) or [M:ZMFC0]ZLONGITUD<>[M:ZMFC1]ZLONGITUD(F) or [M:ZMFC0]ZMANDRIL<>[M:ZMFC1]ZMANDRIL(F)
    [M:ZMFC0]ZANCHO    =[M:ZMFC1]ZANCHO(F)
    [M:ZMFC0]ZLONGITUD =[M:ZMFC1]ZLONGITUD(F)
    [M:ZMFC0]ZMANDRIL  =[M:ZMFC1]ZMANDRIL(F)
    Affzo [M:ZMFC0]ZANCHO
    Affzo [M:ZMFC0]ZLONGITUD
    Affzo [M:ZMFC0]ZMANDRIL
    [M:ZMFC1]ZSTA="L"
  Endif
Endif
End

Subprog APRES_NBLIG
Local Integer NOL : NOL = nolign -1
Local Shortint WLI

If [M:ZMFC1]ZSELITM = "" and [M:ZMFC1]ZQTYBOBASI(NOL)<>0
  [M:ZMFC1]ZSELITM = [M:ZMFC1]ITMREF(NOL)
  [M:ZMFC1]ZSELANCHO = [M:ZMFC1]ZANCHO(NOL)
  [M:ZMFC1]ZSELLONG = [M:ZMFC1]ZLONGITUD(NOL)
  [M:ZMFC1]ZSELMANDRIL = [M:ZMFC1]ZMANDRIL(NOL)
  Affzo [M:ZMFC1]5
Endif

[M:ZMFC1]ZSELQTYBOB=0
For WLI=0 To [M:ZMFC1]NBLIG - 1
   [M:ZMFC1]ZSELQTYBOB+=[M:ZMFC1]ZQTYBOBASI(WLI)
Next
Affzo [M:ZMFC1]ZSELQTYBOB

If [M:ZMFC1]ZSELQTYBOB=0
  [M:ZMFC1]ZSELITM = ""
  [M:ZMFC1]ZSELANCHO = 0
  [M:ZMFC1]ZSELLONG = 0
  [M:ZMFC1]ZSELMANDRIL = 0
  Affzo [M:ZMFC1]5
Endif
###  Asigna Ancho longitud y  Mandril Pedido
If [M:ZMFC1]ZSELANCHO <> 0 and [M:ZMFC0]ZANCHO = 0 Then
     [M:ZMFC0]ZANCHO = [M:ZMFC1]ZSELANCHO
     Affzo [M:ZMFC0]ZANCHO
Endif

If [M:ZMFC1]ZSELLONG <> 0 and [M:ZMFC0]ZLONGITUD = 0 Then
     [M:ZMFC0]ZLONGITUD = [M:ZMFC1]ZSELLONG
     Affzo [M:ZMFC0]ZLONGITUD
Endif
If [M:ZMFC1]ZSELMANDRIL <> 0 and [M:ZMFC0]ZMANDRIL = 0 Then
     [M:ZMFC0]ZMANDRIL = [M:ZMFC1]ZSELMANDRIL
     Affzo [M:ZMFC0]ZMANDRIL
Endif

# Si la cantidad introducida esta por debajo de la cantidad seleccionada en Bobinas en pedidos
# se recalcula las bobinas
#If [M:ZMFC0]ZQTYBOB<[M:ZMFC1]ZSELQTYBOB Then
### Asigna Bobinas Seleccionadas y Nş tiradas
#   If [M:ZMFC0]ZNRANCHO=0 : [M:ZMFC0]ZNRANCHO=1 : Endif
#      If [M:ZMFC0]ZNRANCHO=1
#         [M:ZMFC0]ZNTIRADAS=[M:ZMFC1]ZSELQTYBOB
#         [M:ZMFC0]ZQTYBOB=[M:ZMFC1]ZSELQTYBOB
#      Elsif mod([M:ZMFC1]ZSELQTYBOB,[M:ZMFC0]ZNRANCHO)=0
#         [M:ZMFC0]ZNTIRADAS=[M:ZMFC1]ZSELQTYBOB/[M:ZMFC0]ZNRANCHO
#         [M:ZMFC0]ZQTYBOB=[M:ZMFC1]ZSELQTYBOB
#      Else
#         [M:ZMFC0]ZNRANCHO=1
#         [M:ZMFC0]ZNTIRADAS=[M:ZMFC1]ZSELQTYBOB
#         [M:ZMFC0]ZQTYBOB=[M:ZMFC1]ZSELQTYBOB
#     Endif
#Endif
#Affzo [M:ZMFC0] ZNRANCHO,ZNTIRADAS,ZQTYBOB
End

Subprog AS_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign -1
#& | [M:ZMFC1]ZSELLONG<>[M:ZMFC1]ZLONGITUD(NOL)
If [M:ZMFC1]ZSELITM <> "" & ([M:ZMFC1]ZSELITM <> [M:ZMFC1]ITMREF(NOL)
& | [M:ZMFC1]ZSELANCHO<>[M:ZMFC1]ZANCHO(NOL)
& | [M:ZMFC1]ZSELMANDRIL<>[M:ZMFC1]ZMANDRIL(NOL))
  mkstat = 2
Endif

End

Subprog C_ZQTYBOBASI(VALEUR)
Variable Decimal VALEUR
# Controla que la cantidad seleccionada coincida con el articulo , ancho, corte, y longitud a cortar.
Local Integer NOL : NOL = nolign -1
If VALEUR<>0
#& | ([M:ZMFC0]ZLONGITUD<>[M:ZMFC1]ZLONGITUD(NOL) & [M:ZMFC0]ZLONGITUD<>0)
If ([M:ZMFC0]ITMREF <> [M:ZMFC1]ITMREF(NOL) & [M:ZMFC0]ITMREF<>"")
& | ([M:ZMFC0]ZANCHO<>[M:ZMFC1]ZANCHO(NOL) & [M:ZMFC0]ZANCHO<>0)
& | ([M:ZMFC0]ZMANDRIL<>[M:ZMFC1]ZMANDRIL(NOL) & [M:ZMFC0]ZMANDRIL<>0)
  [M:ZMFC1]ZQTYBOBASI(NOL)=0
  Affzo [M:ZMFC1]ZQTYBOBASI(NOL)
  mkstat = 2
Endif
Endif
End

Subprog AM_ZQTYBOBASI(VALEUR)
  Variable Decimal VALEUR
  Local Integer NOL : NOL = nolign -1

  [M:ZMFC1]ZQTYBOBASI(NOL)= VALEUR

  If func CONTROLA_BOBINAS_ASIGNADAS()
     mkstat = 2
  Else
    Affzo [M:ZMFC1]ZQTYBOBASI(NOL)
  Endif
End

#Controla que no se meten bobinas asignadas incorrectas
Funprog CONTROLA_BOBINAS_ASIGNADAS
   Local Integer NOL
   Local Integer ERRO1
   Local Integer TOTBOBPED

   ERROR = 0
   TOTBOBPED = 0

   For NOL = 0 To [M:ZMFC1]NBLIG - 1
       If [M:ZMFC1]ZQTYBOBASI(NOL) > [M:ZMFC1]ZQTYBOB(NOL)
          ERROR = 1
          Break
       Elsif [M:ZMFC1]ZQTYBOBASI(NOL)>0 and [M:ZMFC1]ZLONGITUD(NOL)<>[M:ZMFC0]ZLONGITUD
          ERROR = 1
          Break
       Endif
      TOTBOBPED = TOTBOBPED + [M:ZMFC1]ZQTYBOBASI(NOL)
   Next

   If [M:ZMFC0]ZQTYBOB > 0 and TOTBOBPED > [M:ZMFC0]ZQTYBOB
      ERROR = 1
   Endif

End ERROR

$CALCULA_SUPERFICIE
Local Decimal LQTY
#Calculo Bobinas

LQTYBOB=LNTIRADAS*LNRANCHO
#Calculo Superficie
LSUPERFICIE=arr((LANCHO/1000)*LLONGITUD*LQTYBOB,0.001)
If [F:ITM]STU="M2"
  LQTY=LSUPERFICE
Else
  LQTY=arr(LSUPERFICIE*[M:ZMFC0]ZFACTOR,0.001)
Endif


[M:ZMFC0]ZSUPERFICIE=LSUPERFICIE
Affzo [M:ZMFC0]ZSUPERFICIE
[M:ZMFC0]ZQTYBOB=LQTYBOB
Affzo [M:ZMFC0]ZQTYBOB


#Inicio FJCG
[M:ZMFC0]ZUOMEXTQTY=LQTY
Affzo [M:ZMFC0]ZUOMEXTQTY
Return

$BUSCAR_PEDIDOS
Local Char WLCRITERIO (250)
Local Integer WLNOL : WLNOL = 0
Local Integer WLI, NOL
Local Decimal WLQTYBOBASI, WLQTYBOBASI2
Raz [M:ZMFC1]
[M:ZMFC1]NBLIG=0
Affzo [M:ZMFC1]
NOL = [M:ZMFC0]ZNOL
WLCRITERIO  = " (SOQSTA < 3) & (ZCORTE = 2) "
WLCRITERIO -= " & (STOFCY = '"+[M:MFG0]MFGFCY+"')"
WLCRITERIO -= " & (QTY-ALLQTY >= QTY/ZQTYBOB) "


If [M:ZMFC0]ITMREF <> ""  : WLCRITERIO -= "& (ITMREF = '" + [M:ZMFC0]ITMREF + "')" : Endif
If [M:ZMFC0]ZANCHO <> 0   : WLCRITERIO -= "& (ZANCHO = " + num$([M:ZMFC0]ZANCHO) + ")" : Endif
#If [M:ZMFC0]ZLONGITUD <> 0 : WLCRITERIO -= "& (ZLONGITUD = " + num$([M:ZMFC0]ZLONGITUD) + ")" : Endif
If [M:ZMFC0]ZMANDRIL <> 0 : WLCRITERIO -= "& (ZMANDRIL = " + num$([M:ZMFC0]ZMANDRIL) + ")" : Endif

Filter [F:SOQX]
Filter [F:SOQX] Where  evalue (WLCRITERIO)
For [F:SOQX]
   Read [F:SOHX]SOH0 = [F:SOQX]SOHNUM
   If !fstat Then
#      # Buscar Cantidad ya asignada en tablas en otras OF u otras lineas de esta OF
#      WLQTYBOBASI=0
#      Filter [F:ZMSQ] Where SOHNUM=[F:SOQX]SOHNUM and SOPLIN=[F:SOQX]SOPLIN and SOQSEQ=[F:SOQX]SOQSEQ and MFGNUM<>[M:MFG0]MFGNUM
#      For [F:ZMSQ]
#        WLQTYBOBASI+=[F:ZMSQ]ZQTYBOBASI
#      Next
#      Filter [F:ZMSQ]
      WLQTYBOBASI=func SPEZGOFS.BOBINAS_EN_CURSO([F:SOQX]SOHNUM,[F:SOQX]SOPLIN,func ZCOMUN.DATA_BASE_TIPO(),[M:MFG0]MFGNUM)
      ##  BUSCAR en el cuadro de la mascara la Cantidad ya ASIGNADA a esta linea de producto de la OF en curso y descontar lo de otras lineas
      WLQTYBOBASI2=0
      For WLI=0 To [M:MFG1]ZNBLP - 1
         If [M:MFG1]ZSOHNUM(WLI)=[F:SOQX]SOHNUM and [M:MFG1]ZSOPLIN(WLI)=[F:SOQX]SOPLIN and [M:MFG1]ZSOQSEQ(WLI)=[F:SOQX]SOQSEQ
#           If [M:MFG1]ZMFGLIN(WLI)=[M:MFG1]MFGLIN(NOL)
            If GACTION="ZMFCORM" and [M:MFG1]ZMFGLIN(WLI)=[M:MFG1]MFGLIN(WLLIG)
#               If GACTION="ZMFCORM"
                  WLQTYBOBASI2 +=[M:MFG1]ZQTYBOBASI(WLI) # en la propia linea de la OF
#               Endif
            Else
               WLQTYBOBASI +=[M:MFG1]ZQTYBOBASI(WLI) # en otras lineas de la OF
            Endif
        Endif
      Next
      If [F:SOQX]ZQTYBOB>WLQTYBOBASI or WLQTYBOBASI2>0
         [M:ZMFC1]ITMREF(WLNOL)=[F:SOQX]ITMREF
         [M:ZMFC1]ZANCHO(WLNOL)=[F:SOQX]ZANCHO
         [M:ZMFC1]ZLONGITUD(WLNOL)=[F:SOQX]ZLONGITUD
         [M:ZMFC1]ZMANDRIL(WLNOL)=[F:SOQX]ZMANDRIL
         [M:ZMFC1]ZQTYBOB(WLNOL)=[F:SOQX]ZQTYBOB-WLQTYBOBASI
         [M:ZMFC1]SOHNUM(WLNOL)=[F:SOQX]SOHNUM
         [M:ZMFC1]SOPLIN(WLNOL)= [F:SOQX]SOPLIN
         [M:ZMFC1]SOQSEQ(WLNOL)=[F:SOQX]SOQSEQ
         [M:ZMFC1]ORDDAT(WLNOL)=[F:SOQX]ORDDAT
         [M:ZMFC1]BPCNAM(WLNOL)=[F:SOHX]BPCNAM
         [M:ZMFC1]EXTDLVDAT(WLNOL)=[F:SOQX]EXTDLVDAT
         # Si modifcacion reconstruimos cantidades ya asignadas en esta OF
         If GACTION="ZMFCORM"
            [M:ZMFC1]ZQTYBOBASI(WLNOL)=WLQTYBOBASI2
         Endif
         If [M:ZMFC1]ZQTYBOBASI(WLNOL)<>0 Then
           [M:ZMFC1]ZSELITM = [M:ZMFC1]ITMREF(WLNOL)
           [M:ZMFC1]ZSELANCHO = [M:ZMFC1]ZANCHO(WLNOL)
           [M:ZMFC1]ZSELLONG = [M:ZMFC1]ZLONGITUD(WLNOL)
           [M:ZMFC1]ZSELMANDRIL = [M:ZMFC1]ZMANDRIL(WLNOL)
           [M:ZMFC1]ZSELQTYBOB+=[M:ZMFC1]ZQTYBOBASI(WLNOL)
         Endif
         WLNOL +=1
       Endif
   Endif
Next
Filter [F:SOQX]
[M:ZMFC1]NBLIG=WLNOL
Affzo [M:ZMFC1]
Return

