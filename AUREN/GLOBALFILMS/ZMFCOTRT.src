#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZMFGCOR0 (Especifico)

$ACTION
#Infbox GFONCTION - GACTION - ACTION
# Entrando AVANT_OUVRE   OUVRE   OUVRE_BOITE  TITRE   DEBUT (se ve la pantalla)     SETBOUT    AV_CHOIX
# Click en MateriaPrima       APRES_MODIF   SETBOUT     AP_CHOIX     AVANT_BOUTON  (Se muestra pantalla)
        # Al volver a la pantalla  BOUTON   SETBOUT     AV_CHOIX
# Tecla INTRO                      AP_CHOIX    AVANT_OK    OK    FIN     FINSAI
# click en "Salir de la función"   AP_CHOIX    END               FIN     FINSAI
Case ACTION
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"
    Case GACTION
       When "ZMFCORM": Gosub DEBUT_M
       When "ZMFCORA": Gosub DEBUT_A
    Endcase
    Gosub DEBUT_R
 When "BOUTON"       : Gosub BOUTON
 When "SETBOUT"      : Gosub SETBOUT
 When "OK"           : Gosub OK

# When "CONTROLE"    : Gosub CONTROLE
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_OK"     : Gosub AVANT_OK
 When "TITRE"        : Gosub TITRE_

 When "END"          : Gosub END_
 When "FIN"          : Gosub FIN
Endcase

## When "APRES_MODIF"  : Gosub APRES_MODIF
##
## When Default
Return

$FIN
#Infbox "OK=" + num$(OK) + "  FIN=" + num$(FIN) + "  GERR=" + num$(GERR) + "    FOK=" + num$(FOK)
#OK=0
#FIN=0
#Infbox "OK=" + num$(OK) + "  FIN=" + num$(FIN) + "  GERR=" + num$(GERR) + "    FOK=" + num$(FOK)
Return

$TITRE_
If GACTION="ZMFCORA"
    TIT="AŃADIENDO LINEA DE CORTE"
Else
    TIT="MODIFICANDO LINEA DE CORTE"
Endif
Return

$AP_CHOIX
Return

$AVANT_OK
If func CONTROLA_BOBINAS_ASIGNADAS()
    FOK=0
    GMESSAGE="Bobinas asignadas > Producidas"
    GERR=1  # No ejecutará ACCION  "OK"
    FIN=0
Else
  Local Integer OK_
  Local Char TXT(250)
  OK_=1
  TXT=""
  If [M:ZMFC3]NBLOT<1
    TXT+=" # Seleccionado Materia prima alguna"
    OK_=0
  Endif
  If [M:ZMFC4]NBLIG<1
    TXT+=" # Ańadido linea alguna a Fabricar"
    OK_=0
  Endif
  If OK_=0 and WLLIG<0
    FOK=0
    GMESSAGE="Observe que no ha " + TXT
    GERR=1  # No ejecutará ACCION  "OK"
  Endif
Endif
Return


$END_
ZGMODLINCOR=0
Return

$OUVRE
Local Integer WLLIG
Local Shortint WLMINANCHO : WLMINANCHO=[M:MFG1]ZMINANCHO
Local Integer WTEST : WTEST =0

WLLIG = val(PARAM(1))

If !clalev([F:ITM])   : Local File ITMMASTER [ITM] : Endif
If !clalev([F:ITF])   : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:SOHX])  : Local File SORDER    [SOHX] : Endif
If !clalev([F:SOPX])  : Local File SORDERP   [SOPX] : Endif
If !clalev([F:SOQX])  : Local File SORDERQ   [SOQX] : Endif
If !clalev ([F:ZMSQ]) : Local File ZMFGSOQ   [ZMSQ] : Endif
If !clalev ([F:MFC])  : Local File MFGCOST   [MFC]  : Endif
If !clalev ([F:BPCX]) : Local File BPCUSTOMER [BPCX] : Endif

If !clalev([F:STO]) : Local File STOCK [STO] : Endif
If !clalev([F:ZMFL]): Local File ZMFGLOT [ZMFL] : Endif
If !clalev([F:ITMX]): Local File ITMMASTER [ITMX] : Endif
If !clalev([F:MFGX]): Local File MFGHEAD [MFGX] : Endif
Return

$DEBUT_A
Local Integer LINAUX, MAXLIN,ULT

LINAUX=0:ULT=0
Raz [M:ZMFC0]
Raz [M:ZMFC1]
Raz [M:ZMFC3]
#Obtener ultimo MFGLIN
MAXLIN=0

For I=0 To [M:MFG1]NBLIG-1
   If [M:MFG1]MFGLIN(I)>MAXLIN
      MAXLIN=[M:MFG1]MFGLIN(I)
   Endif
   # JLPR Obtener ultimo Grupo de corte, para mostrar el siguiente
   If [M:MFG1]ZGRPCOR(I)>ULT: ULT=[M:MFG1]ZGRPCOR(I):   Endif
Next
MAXLIN+=1000
[M:ZMFC0]ZGRPCOR=ULT+1:Affzo [M:ZMFC0]ZGRPCOR
#CARgAr bobina en casp de que existan + BD  Guarda

Gosub ESTADO_INICIAL #JLPR
Return

$DEBUT_M
Local Integer WTESTPED : WTESTPED =0
Local Shortint WLI
Raz [M:ZMFC0]
Raz [M:ZMFC1]

# Si Modificamos linea corte
# M
# Si HAY ASIGNACION DE PEDIDOS
   # Buscamos Asignamos campos Seleccion Pedidos
   If  [M:MFG1]ZPEDCLI(WLLIG)=2 Then
      For WLI=0 To [M:MFG1]ZNBLP - 1
        If [M:MFG1]ZMFGLIN(WLI)=[M:MFG1]MFGLIN(WLLIG)
           [M:ZMFC1]ZSELITM = [M:MFG1]ITMREF(WLLIG)
           [M:ZMFC1]ZSELANCHO = [M:MFG1]ZANCHO(WLLIG)
           [M:ZMFC1]ZSELLONG = [M:MFG1]ZLONGITUD(WLLIG)
           [M:ZMFC1]ZSELMANDRIL = [M:MFG1]ZMANDRIL(WLLIG)
           Affzo [M:ZMFC1]5
           Break
        Endif
      Next
   Endif

   [M:ZMFC0]ITMREF=[M:MFG1]ITMREF(WLLIG)
   [M:ZMFC0]ZANCHO=[M:MFG1]ZANCHO(WLLIG)
   [M:ZMFC0]ZLONGITUD=[M:MFG1]ZLONGITUD(WLLIG)
   [M:ZMFC0]ZMANDRIL=[M:MFG1]ZMANDRIL(WLLIG)
   [M:ZMFC0]ZGRPCOR=[M:MFG1]ZGRPCOR(WLLIG)
   [M:ZMFC0]ZNRANCHO=[M:MFG1]ZNRANCHO(WLLIG)
   [M:ZMFC0]ZNTIRADAS=[M:MFG1]ZNTIRADAS(WLLIG)
   [M:ZMFC0]ZFACTOR=[M:MFG1]ZFACTOR(WLLIG)
   [M:ZMFC0]ZQTYBOB=[M:MFG1]ZQTYBOB(WLLIG)
   [M:ZMFC0]ZSUPERFICIE=[M:MFG1]ZSUPERFICIE(WLLIG)
   [M:ZMFC0]ZPROVEEDOR=[M:MFG1]ZPROVEEDOR(WLLIG)
   [M:ZMFC0]ZNCORTES=[M:MFG1]ZNCORTES(WLLIG)
   [M:ZMFC0]ZLOC=[M:MFG1]ZLOC(WLLIG)
   If [M:ZMFC1]ZSELITM = "" Then
      [M:MFG1]ZPEDCLI(WLLIG)=1
   Else
      [M:ZMFC0]ZPEDCLI=[M:MFG1]ZPEDCLI(WLLIG)
   Endif
   [M:ZMFC0]ZPEDCLI=[M:MFG1]ZPEDCLI(WLLIG)
   [M:ZMFC0]ZNOL=WLLIG

    LNTIRADAS=[M:ZMFC0]ZNTIRADAS
    LNRANCHO=[M:ZMFC0]ZNRANCHO
    #LQTYBOB=[M:ZMFC0]ZQTYBOB
    #LANCHO=[M:ZMFC0]ZANCHO
    LLONGITUD=[M:ZMFC0]ZLONGITUD
    LANCHO=[M:ZMFC0]ZANCHO
    Gosub CALCULA_SUPERFICIE

Affzo [M:ZMFC0]
Affzo [M:ZMFC1]

Gosub BUSCAR_PEDIDOS

If [M:ZMFC0]ITMREF<>""
    Read [F:ITM]ITM0=[M:ZMFC0]ITMREF
  #  Gosub BUSCAR_LOTES
    [M:ZMFC0]ZFACTOR  = [F:ITM]ZFACTOR
    Affzo [M:ZMFC0]ZFACTOR
    Diszo [M:ZMFC0]ITMREF
Endif
#If ZGMODLINCOR=2
#     # Carga Bobinas asignadas al grupo de corte
#      Gosub GC_CARGABOBINAS
#Endif
Gosub ESTADO_INICIAL #JLPR   Se cargan las bobinas tanto si Ańadimos como si modificamos
Return

$DEBUT_R
Local Integer H
# Llenar rejilla [M:ZMFC4] con valores existentes en [M:MFG1]5 => Rejilla "Articulos lanzados"
Raz [M:ZMFC4]
For H=0 To [M:MFG1]NBLIG-1
  [M:ZMFC4]ITMREF(H)=[M:MFG1]ITMREF(H)
  [M:ZMFC4]ITMDES1(H)=[M:MFG1]ITMDES1(H)
  [M:ZMFC4]ZCOSFAB(H)=[M:MFG1]ZCOSFAB(H)
  [M:ZMFC4]ITMSTA(H)=[M:MFG1]ITMSTA(H)
  [M:ZMFC4]ZGRPCOR(H)=[M:MFG1]ZGRPCOR(H)
  [M:ZMFC4]ZLOC(H)=[M:MFG1]ZLOC(H)
  [M:ZMFC4]ZPROVEEDOR(H)=[M:MFG1]ZPROVEEDOR(H)
  [M:ZMFC4]ZNCORTES(H)=[M:MFG1]ZNCORTES(H)
  [M:ZMFC4]ZANCHO(H)=[M:MFG1]ZANCHO(H)
  [M:ZMFC4]ZNRANCHO(H)=[M:MFG1]ZNRANCHO(H)
  [M:ZMFC4]ZLONGITUD(H)=[M:MFG1]ZLONGITUD(H)
  [M:ZMFC4]ZNTIRADAS(H)=[M:MFG1]ZNTIRADAS(H)
  [M:ZMFC4]ZQTYBOB(H)=[M:MFG1]ZQTYBOB(H)
  [M:ZMFC4]ZMANDRIL(H)=[M:MFG1]ZMANDRIL(H)
  [M:ZMFC4]NBLIG+=1
Next
Affzo [M:ZMFC4]
Return


$SETBOUT
If GACTION="ZMFCORA"
    Call VIREBOUT(CHBOU,"O") From GOBJET
    Gosub SET_BOUT_STD From GSAISIE
Endif
If GACTION="ZMFCORM"
    Call VIREBOUT(CHMEN,"2") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
Endif
If [M:MFG1]ALLSTA<>1 Then
   Call VIREBOUT(CHMEN,"1") From GOBJET
   Gosub SET_BOUT_SPE From GSAISIE
Endif
If [M:ZMFC1]ZSTA="L"
  Raz [M:ZMFC1]ZSTA
  Gosub BUSCAR_PEDIDOS
Endif
Return

$BOUTON
Case BOUT
    When "2" :  Gosub ANADIR_LIN
Endcase
Return

$APRES_MODIF
# maskcou nombre de la pantalla, para cuando hay varias en una misma ventana
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
  Case COUZON
When "ITMREF","ZANCHO","ZLONGITUD","ZMANDRIL"
  Gosub BUSCAR_PEDIDOS
  Return
Endcase
Return

$ANADIR_LIN
Local Integer I, WLLIG
Local Decimal WQTY
Local Decimal WMARGEN

If [M:ZMFC0]ITMREF="" or [M:ZMFC0]ZANCHO=0 or [M:ZMFC0]ZNRANCHO=0 or [M:ZMFC0]ZMANDRIL=0 or [M:ZMFC0]ZLONGITUD=0 or
&  [M:ZMFC0]ZSUPERFICIE=0 or [M:ZMFC0]ZNTIRADAS=0
   Infbox "Datos insuficientes: "+[M:ZMFC0]ITMREF+" A: "+num$([M:ZMFC0]ZANCHO)+" R: "+num$([M:ZMFC0]ZNRANCHO)+" M: "+num$([M:ZMFC0]ZMANDRIL)+
&         " L: "+num$([M:ZMFC0]ZLONGITUD)+" T: "+num$([M:ZMFC0]ZNTIRADAS)+" S: "+num$([M:ZMFC0]ZSUPERFICIE)

   Return
Endif

If LINAUX=99
   Infbox "No se permiten mas lineas"
   Return
Endif

[M:MFG1]ZLANUMLIN(LINAUX)=MAXLIN
[M:MFG1]ZLAGRPCOR(LINAUX)=[M:ZMFC0]ZGRPCOR
[M:MFG1]ZLAITMREF(LINAUX)=[M:ZMFC0]ITMREF
[M:MFG1]ZLAANCHO(LINAUX)=[M:ZMFC0]ZANCHO
[M:MFG1]ZLANRANCHO(LINAUX)=[M:ZMFC0]ZNRANCHO
[M:MFG1]ZLALONGITUD(LINAUX)=[M:ZMFC0]ZLONGITUD
[M:MFG1]ZLANTIRADAS(LINAUX)=[M:ZMFC0]ZNTIRADAS
[M:MFG1]ZLAQTYBOB(LINAUX)=[M:ZMFC0]ZQTYBOB
[M:MFG1]ZLAMANDRIL(LINAUX)=[M:ZMFC0]ZMANDRIL
[M:MFG1]ZLAPROVEEDOR(LINAUX)=[M:ZMFC0]ZPROVEEDOR
[M:MFG1]ZLANCORTES(LINAUX)=[M:ZMFC0]ZNCORTES
[M:MFG1]ZLASUPERFICI(LINAUX)=[M:ZMFC0]ZSUPERFICIE
[M:MFG1]ZLAFACTOR(LINAUX)=[M:ZMFC0]ZFACTOR
[M:MFG1]ZLALOC(LINAUX)=[M:ZMFC0]ZLOC
[M:MFG1]ZLALOCTYP(LINAUX)=[M:ZMFC0]ZLOCTYP
[M:MFG1]ZLALOCSEQ(LINAUX)=[M:ZMFC0]ZLOCSEQ
[M:MFG1]ZLAITMTYP(LINAUX)= 1
Raz [F:ITM]
Read [ITM]ITM0=[M:ZMFC0]ITMREF
[M:MFG1]ZLAITMDES1(LINAUX)=[F:ITM]ITMDES1

#Se llamada a CTLPLNFLT porque se hace en el AM_ITMREF estandar, dentro se lee [ITF],
#pero no hacemos caso del mensaje que se devuelve para controlar el acceso del usuario
Call CTLPLNFLT([M:MFG0]MFGFCY, [M:ZMFC0]ITMREF, GUSER) From MFGLIB

[M:MFG1]ZLABOMALT(LINAUX)=40
Call LECTEXTRA([M:MFG1]TBOSHO(LINAUX),"TABBOMALT","TBOSHOAXX",num$(2),num$([M:MFG1]BOMALT(LINAUX))) From ATEXTRA
#Gosub RECH_NOM From SUBMFGA

[M:MFG1]ZLAUOM(LINAUX)=[F:ITM]STU
[M:MFG1]ZLASTU(LINAUX)=[F:ITM]STU
[M:MFG1]MFGSTU=[F:ITM]STU
Case [M:MFG1]ZLAUOM(LINAUX)
        When [F:ITM]STU: [M:MFG1]ZLAUOMSTUCOE(LINAUX) = 1
        When [F:ITM]PUU: [M:MFG1]ZLAUOMSTUCOE(LINAUX) = [F:ITM]PUUSTUCOE
        When [F:ITM]SAU: [M:MFG1]ZLAUOMSTUCOE(LINAUX) = [F:ITM]SAUSTUCOE
        When Default:    For I = 0 To dim([F:ITM]PCU)-1
                             If [M:MFG1]ZLAUOM(LINAUX) = [F:ITM]PCU(I)
                                 [M:MFG1]ZLAUOMSTUCOE(LINAUX) = [F:ITM]PCUSTUCOE(I)
                             Endif
                         Next I
Endcase
If [M:ZMFC1]ZSELITM<>""
   [M:MFG1]ZLAPEDCLI(LINAUX)=2
Else
   [M:MFG1]ZLAPEDCLI(LINAUX)=1
Endif
[M:MFG1]ZLAUOMEXTQTY(LINAUX)=[M:ZMFC0]ZUOMEXTQTY
WQTY = [M:ZMFC0]ZUOMEXTQTY * [M:MFG1]ZLAUOMSTUCOE(LINAUX)
Call QTEARR(WQTY,[M:MFG1]ZLASTU(LINAUX)) From TRTDIV
[M:MFG1]ZLAEXTQTY(LINAUX) = WQTY
[M:MFG1]ZLAFABCOR(LINAUX)=2
# Ańadir a Mascara  [M:ZMFC4]   <<JLPR>>
Local Integer H
H=[M:ZMFC4]NBLIG
[M:ZMFC4]ITMREF(H)=[M:MFG1]ZLAITMREF(LINAUX)
[M:ZMFC4]ITMDES1(H)=[M:MFG1]ZLAITMDES1(LINAUX)
[M:ZMFC4]ZCOSFAB(H)=2
#[M:ZMFC4]ITMSTA(H)=""
[M:ZMFC4]ZGRPCOR(H)=[M:MFG1]ZLAGRPCOR(LINAUX)
[M:ZMFC4]ZLOC(H)=[M:MFG1]ZLALOC(LINAUX)
[M:ZMFC4]ZPROVEEDOR(H)=[M:MFG1]ZLAPROVEEDOR(LINAUX)
[M:ZMFC4]ZNCORTES(H)=[M:MFG1]ZLANCORTES(LINAUX)
[M:ZMFC4]ZANCHO(H)=[M:MFG1]ZLAANCHO(LINAUX)
[M:ZMFC4]ZNRANCHO(H)=[M:MFG1]ZLANRANCHO(LINAUX)
[M:ZMFC4]ZLONGITUD(H)=[M:MFG1]ZLALONGITUD(LINAUX)
[M:ZMFC4]ZNTIRADAS(H)=[M:MFG1]ZLANTIRADAS(LINAUX)
[M:ZMFC4]ZQTYBOB(H)=[M:MFG1]ZLAQTYBOB(LINAUX)
[M:ZMFC4]ZMANDRIL(H)=[M:MFG1]ZLAMANDRIL(LINAUX)
[M:ZMFC4]NBLIG+=1
Affzo [M:ZMFC4]
#
LINAUX=LINAUX+1
[M:MFG1]ZNBLAUX=LINAUX


#Asignar pedidos
Local Integer WNLPED, WLI
# Borrar cualquier asignacion previa de pedidos a linea.
Call BORRAR_PEDASI(MAXLIN) From SPEMFG

$ANADIR_LIN_PED
WNLPED=[M:MFG1]ZNBLP
If [M:ZMFC1]ZSELITM<>""
   # Asigna pedidos seleccionados a mascara de pedidos detalle
  WNLPED=[M:MFG1]ZNBLP
  For WLI = 0 To [M:ZMFC1]NBLIG - 1
    If [M:ZMFC1]ZQTYBOBASI(WLI)<>0
       [M:MFG1]ZMFGLIN(WNLPED)=MAXLIN
       [M:MFG1]ZSOHNUM(WNLPED)=[M:ZMFC1]SOHNUM(WLI)
       [M:MFG1]ZSOPLIN(WNLPED)=[M:ZMFC1]SOPLIN(WLI)
       [M:MFG1]ZSOQSEQ(WNLPED)=[M:ZMFC1]SOQSEQ(WLI)
       [M:MFG1]ZQTYBOBASI(WNLPED)=[M:ZMFC1]ZQTYBOBASI(WLI)
       Raz [F:SOHX]
       Read [F:SOHX]SOH0=[M:ZMFC1]SOHNUM(WLI)
       If fstat
          Infbox "Problema recuperando pedido (1): "+[M:ZMFC1]SOHNUM(WLI)+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOPX]
       Read [F:SOPX]SOP0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (P1): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOQX]
       Read [F:SOQX]SOQ0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (Q1): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" "+num$([M:ZMFC1]SOQSEQ(WLI))+" - fstat: "+num$(fstat)
       Endif
       Raz  [F:MFC]
       Filter [F:MFC] Where MFCTYP=2 & VCRTYP=10 &  VCRNUM=[M:MFG0]MFGNUM & VCRLIN= [M:MFG1]ZMFGLIN(WNLPED)
       For [F:MFC]
          Break
       Next
       Filter [F:MFC]
       [M:MFG1]ZANCHOP(WNLPED)=[F:SOQX]ZANCHO
       [M:MFG1]ZMANDRILP(WNLPED)=[F:SOQX]ZMANDRIL
       [M:MFG1]ZLONGITUDP(WNLPED)=[F:SOQX]ZLONGITUD
       [M:MFG1]ZBPCNAM(WNLPED)=[F:SOHX]BPCNAM
       If [F:SOPX]SAUSTUCOE<>0
          [M:MFG1]ZNETPRI(WNLPED)=[F:SOPX]NETPRI/[F:SOPX]SAUSTUCOE
       Endif
       [M:MFG1]ZDLVDAT(WNLPED)=[F:SOQX]EXTDLVDAT
       [M:MFG1]ZCOSPRV(WNLPED)=[F:MFC]CSTTOT
       If [M:MFG1]ZNETPRI(WNLPED)<>0
          WMARGEN=100-(([M:MFG1]ZCOSPRV(WNLPED)*100)/[M:MFG1]ZNETPRI(WNLPED))
          [M:MFG1]ZMARGEN(WNLPED)=WMARGEN
       Endif
       Raz [F:BPCX]
       Read [BPCX]BPC0=[F:SOHX]BPCORD
       If fstat=0
          [M:MFG1]ZORDTEX(WNLPED)=[F:BPCX]ORDTEX
       Endif
       WNLPED +=1
    Endif
  Next
  [M:MFG1]ZNBLP=WNLPED
Endif

#Pasar Bobinas a Mascara MFG2
Gosub GC_GUARDABOBINAS
#Gosub COMPR_LOTE_SOBR From SPEMFG2
Call CALCULA_SOBRANTE From SPEMFG2
Gosub ACT_MFGENDDAT

MAXLIN+=1000

##Volvemos a cargar pedidos
#Gosub BUSCAR_PEDIDOS

[M:ZMFC0]ZLINANA+=1
Affzo [M:ZMFC0]ZLINANA

Raz [M:ZMFC0]ZANCHO,[M:ZMFC0]ZLONGITUD,[M:ZMFC0]ZNRANCHO,[M:ZMFC0]ZNTIRADAS,[M:ZMFC0]ZMANDRIL
Affzo [M:ZMFC0]ZANCHO
Affzo [M:ZMFC0]ZLONGITUD
Affzo [M:ZMFC0]ZNRANCHO
Affzo [M:ZMFC0]ZNTIRADAS
Affzo [M:ZMFC0]ZMANDRIL
#Volvemos a cargar pedidos
Gosub BUSCAR_PEDIDOS
Return


$OK
Local Char TXT(250)
Local Decimal WQTY

TXT=""
If [M:ZMFC3]NBLOT<1
  TXT+=" # Seleccionado Materia prima alguna"
Endif
If [M:ZMFC4]NBLIG<1
  TXT+=" # Ańadido linea alguna a Fabricar"
Endif
If TXT<>""
  Infbox "Observe que no ha " + TXT
Endif


#If WLLIG<0 : End : Endif

#Pasar datos a Lineas
[M:MFG1]ITMREF(WLLIG)=[M:ZMFC0]ITMREF
[M:MFG1]ZANCHO(WLLIG)=[M:ZMFC0]ZANCHO
[M:MFG1]ZLONGITUD(WLLIG)=[M:ZMFC0]ZLONGITUD
[M:MFG1]ZMANDRIL(WLLIG)=[M:ZMFC0]ZMANDRIL
[M:MFG1]ZGRPCOR(WLLIG)=[M:ZMFC0]ZGRPCOR
[M:MFG1]ZNRANCHO(WLLIG)=[M:ZMFC0]ZNRANCHO
[M:MFG1]ZNTIRADAS(WLLIG)=[M:ZMFC0]ZNTIRADAS
[M:MFG1]ZFACTOR(WLLIG)=[M:ZMFC0]ZFACTOR
[M:MFG1]ZQTYBOB(WLLIG)=[M:ZMFC0]ZQTYBOB
[M:MFG1]ZSUPERFICIE(WLLIG)=[M:ZMFC0]ZSUPERFICIE
[M:MFG1]ZPROVEEDOR(WLLIG)=[M:ZMFC0]ZPROVEEDOR
[M:MFG1]ZNCORTES(WLLIG)=[M:ZMFC0]ZNCORTES
[M:MFG1]ZLOC(WLLIG)=[M:ZMFC0]ZLOC
[M:MFG1]ZFABCOR(WLLIG)=2
Affzo [M:MFG1]ITMREF(WLLIG)
Affzo [M:MFG1]ZANCHO(WLLIG)
Affzo [M:MFG1]ZLONGITUD(WLLIG)
Affzo [M:MFG1]ZMANDRIL(WLLIG)
Affzo [M:MFG1]ZQTYBOB(WLLIG)
Affzo [M:MFG1]ZNRANCHO(WLLIG)
Affzo [M:MFG1]ZNTIRADAS(WLLIG)
Affzo [M:MFG1]ZFACTOR(WLLIG)
Affzo [M:MFG1]ZSUPERFICIE(WLLIG)
Affzo [M:MFG1]ZPROVEEDOR(WLLIG)
Affzo [M:MFG1]ZGRPCOR(WLLIG)
Affzo [M:MFG1]ZNCORTES(WLLIG)
Affzo [M:MFG1]ZLOC(WLLIG)
#
[M:MFG1]UOMEXTQTY(WLLIG)   =[M:ZMFC0]ZUOMEXTQTY
[M:MFG1]ZLAUOMEXTQTY(WLLIG)=[M:ZMFC0]ZUOMEXTQTY
WQTY = [M:ZMFC0]ZUOMEXTQTY * [M:MFG1]ZLAUOMSTUCOE(WLLIG)
Call QTEARR(WQTY,[M:MFG1]ZLASTU(WLLIG)) From TRTDIV
[M:MFG1]ZLAEXTQTY(WLLIG)   = WQTY
Affzo [M:MFG1]UOMEXTQTY(WLLIG)
Affzo [M:MFG1]ZLAUOMEXTQTY(WLLIG)
Affzo [M:MFG1]ZLAEXTQTY(WLLIG)

#[M:MFG1]UOMEXTQTY(NJL)
# Pasar Pedidos a Mascara MFG1
Local Integer WNLPED, WLI
# Borrar cualquier asignacion previa de pedidos a linea.
Call BORRAR_PEDASI([M:MFG1]MFGLIN(WLLIG)) From SPEMFG
WNLPED=[M:MFG1]ZNBLP
If [M:ZMFC1]ZSELITM<>""
   [M:MFG1]ZPEDCLI(WLLIG)=2
   # Asigna pedidos seleccionados a mascara de pedidos detalle
  WNLPED=[M:MFG1]ZNBLP
  For WLI = 0 To [M:ZMFC1]NBLIG - 1
    If [M:ZMFC1]ZQTYBOBASI(WLI)<>0
       [M:MFG1]ZMFGLIN(WNLPED)=[M:MFG1]MFGLIN(WLLIG)
       [M:MFG1]ZSOHNUM(WNLPED)=[M:ZMFC1]SOHNUM(WLI)
       [M:MFG1]ZSOPLIN(WNLPED)=[M:ZMFC1]SOPLIN(WLI)
       [M:MFG1]ZSOQSEQ(WNLPED)=[M:ZMFC1]SOQSEQ(WLI)
       [M:MFG1]ZQTYBOBASI(WNLPED)=[M:ZMFC1]ZQTYBOBASI(WLI)
       Raz [F:SOHX]
       Read [F:SOHX]SOH0=[M:ZMFC1]SOHNUM(WLI)
       If fstat
          Infbox "Problema recuperando pedido (2): "+[M:ZMFC1]SOHNUM(WLI)+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOPX]
       Read [F:SOPX]SOP0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (P2): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" - fstat: "+num$(fstat)
       Endif
       Raz [F:SOQX]
       Read [F:SOQX]SOQ0=[M:ZMFC1]SOHNUM(WLI);[M:ZMFC1]SOPLIN(WLI);[M:ZMFC1]SOQSEQ(WLI)
       If fstat
          Infbox "Problema recuperando linea pedido (Q2): "+[M:ZMFC1]SOHNUM(WLI)+" "+num$([M:ZMFC1]SOPLIN(WLI))+" "+num$([F:ZMSQ]SOQSEQ)+" - fstat: "+num$(fstat)
       Endif
       [M:MFG1]ZANCHOP(WNLPED)=[F:SOQX]ZANCHO
       [M:MFG1]ZMANDRILP(WNLPED)=[F:SOQX]ZMANDRIL
       [M:MFG1]ZLONGITUDP(WNLPED)=[F:SOQX]ZLONGITUD
       [M:MFG1]ZBPCNAM(WNLPED)=[F:SOHX]BPCNAM
       If [F:SOPX]SAUSTUCOE<>0
          [M:MFG1]ZNETPRI(WNLPED)=[F:SOPX]NETPRI/[F:SOPX]SAUSTUCOE
       Endif
       [M:MFG1]ZDLVDAT(WNLPED)=[F:SOQX]EXTDLVDAT
       Raz  [F:MFC]
       Filter [F:MFC] Where MFCTYP=2 & VCRTYP=10 &  VCRNUM=[M:MFG0]MFGNUM & VCRLIN=[M:MFG1]MFGLIN(WLLIG)
       For [F:MFC]
          Break
       Next
       Filter [F:MFC]
       [M:MFG1]ZCOSPRV(WNLPED)=[F:MFC]CSTTOT

       Raz [F:BPCX]
       Read [BPCX]BPC0=[F:SOHX]BPCORD
       If fstat=0
          [M:MFG1]ZORDTEX(WNLPED)=[F:BPCX]ORDTEX
       Endif

       WNLPED +=1
    Endif
  Next
  [M:MFG1]ZNBLP=WNLPED

Else  # No hay pedidos asignados
   [M:MFG1]ZPEDCLI(WLLIG)=1
Endif
Affzo [M:MFG1]ZPEDCLI(WLLIG)
Affzo [M:MFG1]35

# Pasar Bobinas a Mascara MFG2
  #Gosub ZMFCO_GUARDAR_LOTASI
  Gosub GC_GUARDABOBINAS
  #Gosub COMPR_LOTE_SOBR From SPEMFG2
  Call CALCULA_SOBRANTE From SPEMFG2
  Gosub CALCULA_ANCHOMINIMO From SPEMFG
  Gosub CALCULA_LONGITUDTOTAL From SPEMFG
  Gosub CALCULA_MERMA From SPEMFG
  Gosub ACT_MFGENDDAT
Return

