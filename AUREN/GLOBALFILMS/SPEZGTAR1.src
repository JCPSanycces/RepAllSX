#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZGTAR1 (Especifico)

Subprog C_NBLIG
#Infbox "C_NBLIG"
#If [M:ZGTAR1]ZGEN(nolign-1)=2 or [M:ZGTAR0]CERRADO=2
#  mkstat=2
#Endif
End

Subprog IB_NBLIG
#Infbox "IB_NBLIG"
Local Integer F
F=nolign-1
Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4
If [M:ZGTAR1]ZGEN(F)<>2
  If [M:ZGTAR1]ZFECINI(F)<>[0/0/0]
    GBOUT1="Asignar fecha "+format$("D:DD[/]MM[/]YYYY",[M:ZGTAR1]ZFECINI(F))
  Endif
  Case [M:ZGTAR1]SEL(F)
  When 2
    GBOUT3="Desmarcar"
  When Default
    GBOUT2="Marcar"
    GBOUT4="Todo"
  Endcase
Endif
Call MOSTRAR_TARIFA_NUEVA(nolign-1) From SPEZGTAR2
Call COLORES  From SPEZGTAR2
End

Subprog B1_NBLIG
Local Integer L
Local Date VALEUR
L=-1
VALEUR=[M:ZGTAR1]ZFECINI(nolign-1)
Gosub CAMBIAR_FECINI
End

Subprog B2_NBLIG
#Marcar
Local Integer F,L,V
L=nolign-1
V=2
Gosub CAMBIAR_SEL
End

Subprog B3_NBLIG
#Desmarcar
Local Integer F,L,V
L=nolign-1
V=1
Gosub CAMBIAR_SEL
End

Subprog B4_NBLIG
#Marcar TODO
Local Integer F,L,V
L=-1
V=2
Gosub CAMBIAR_SEL
End


Subprog AS_NBLIG
#Infbox "AS_NBLIG"
If [M:ZGTAR1]ZGEN(nolign-1)=2 or [M:ZGTAR0]CERRADO=2
  mkstat=2
Endif
# Llenar rejilla en [ZGTAR2]
#Infbox "Llenar rejilla en [ZGTAR2]"
#Call MOSTRAR_TARIFA_NUEVA(nolign-1) From SPEZGTAR2
#Call COLORES  From SPEZGTAR2
End

Subprog AM_ZFECINI(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
  If VALEUR<=date$
    MSG="Fecha inicio tarifa debe ser posterior al dia de hoy"
    Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Endif
Endif
Local Integer L
L=nolign-1
Gosub CAMBIAR_FECINI
End

Subprog AM_ZPORBASE(VALEUR)
Variable Decimal VALEUR
Local Decimal RVAL
Local Integer L
L=nolign-1
RVAL=[M:ZGTAR1]ZPORBASE(L)
Gosub CAMBIAR_ZPORBASE
Call VACIAR_REJILLA2 From SUBZGTAR
End

Subprog AM_ZPOR(VALEUR)
Variable Decimal VALEUR
[M:ZGTAR1]ZPOR(nolign-1)=VALEUR
Call CALCULAR(nolign-1) From SPEZGTAR0
Call VACIAR_REJILLA2 From SUBZGTAR
End

Subprog AM_ZFIJO(VALEUR)
Variable Decimal VALEUR
[M:ZGTAR1]ZFIJO(nolign-1)=VALEUR
Call CALCULAR(nolign-1) From SPEZGTAR0
Call VACIAR_REJILLA2 From SUBZGTAR
End

Subprog AM_ZOK(VALEUR)
Variable Integer VALEUR
If VALEUR=2 and [M:ZGTAR1]PRECDIF(nolign-1)<>0   VALEUR=1   Endif
End

Subprog AM_ZBAJA(VALEUR)
Variable Integer VALEUR
#If VALEUR=2 and [M:ZGTAR1]PRECDIF(nolign-1)<>0   VALEUR=1   Endif
End


$CAMBIAR_ZPORBASE
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]PRECACTU(F)=[M:ZGTAR1]PRECACTU(L) and ([M:ZGTAR1]ZPORBASE(F)=0)# or [M:ZGTAR1]ZPORBASE(F)=RVAL)
    [M:ZGTAR1]ZPORBASE(F)=VALEUR
    Call CALCULAR(F) From SPEZGTAR0
    Affzo [M:ZGTAR1]ZPORBASE(F)
    Gosub LINEA_CAMBIADA From SPEZGTAR0
  Endif
Next
Return

$CAMBIAR_FECINI
For F=0 To [M:ZGTAR1]NBLIG-1
  If [M:ZGTAR1]ZFECINI(F)<>VALEUR and ((L=-1 and [M:ZGTAR1]ZFECINI(F)=[0/0/0]) or (L<>-1 and [M:ZGTAR1]PLI(F)=[M:ZGTAR1]PLI(L)))
    [M:ZGTAR1]ZFECINI(F)=VALEUR
    Affzo [M:ZGTAR1]ZFECINI(F)
    Gosub LINEA_CAMBIADA From SPEZGTAR0
  Endif
Next
Return

$CAMBIAR_SEL
For F=0 To [M:ZGTAR1]NBLIG-1
  If L=-1 or ([M:ZGTAR1]PLI(F)=[M:ZGTAR1]PLI(L) and [M:ZGTAR0]ZTIPO=1) or ([M:ZGTAR1]PLICRD(F)=[M:ZGTAR1]PLICRD(L) and [M:ZGTAR0]ZTIPO=2)
    If V<>2 or (V=2 and [M:ZGTAR1]ZGEN(F)<>2 and not func SPEZGTAR2.TODO_IGUAL([M:ZGTAR0]ZREVISION,[M:ZGTAR1]PLICRD(F)))
      [M:ZGTAR1]SEL(F)=V
      Affzo [M:ZGTAR1]SEL(F)
    Endif
  Endif
Next
Return

Funprog LINEAS_CAMBIADAS()
End

