#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para la asignacion de OF a contenedor
$ACTION
#Infbox "ZCNTRAM: "+ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
If !clalev([F:MFG])    : Local File MFGHEAD    [MFG] : Endif
If !clalev([F:MFM])    : Local File MFGMAT     [MFM] : Endif
If !clalev([F:POH])    : Local File PORDER     [POH] : Endif
If !clalev([F:POP])    : Local File PORDERP    [POP] : Endif
If !clalev([F:POQ])    : Local File PORDERQ    [POQ] : Endif
If !clalev([F:ITM])    : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ZCNTR])  : Local File ZCONTAINH  [ZCNTR]  : Endif
If !clalev([F:ZCNTRP]) : Local File ZCONTAINP  [ZCNTRP] : Endif
If !clalev([F:ZCNTRS]) : Local File ZCONTAINS  [ZCNTRS] : Endif
If !clalev([F:ZCNTRM]) : Local File ZCONTAINM  [ZCNTRM] : Endif
Return

$DEBUT
Local Char LNUMCNTR(25), LPOHNUM(25)

LNUMCNTR=PARAM(1)
Raz [M:ZCNTRAM]
Raz [M:ZCNTRAM]MFGNUMSTR
[M:ZCNTRAM]MFGNUMSTR=PARAM(2)
Affzo [M:ZCNTRAM]MFGNUMSTR
[M:ZCNTRAM]STOFCY=PARAM(3)
Affzo [M:ZCNTRAM]STOFCY

Filter [ZCNTRP] Where NUMCNTR=LNUMCNTR Order By Key ZCNTRP2
LPOHNUM=""
For [ZCNTRP]
   If LPOHNUM<>[F:ZCNTRP]POHNUM
      If LPOHNUM=""
         [M:ZCNTRAM]FILPOH="(POHNUM='"+[F:ZCNTRP]POHNUM+"'"
      Else
         [M:ZCNTRAM]FILPOH+=" or POHNUM='"+[F:ZCNTRP]POHNUM+"'"
      Endif
      LPOHNUM=[F:ZCNTRP]POHNUM
   Endif
Next
If len([M:ZCNTRAM]FILPOH)<>0
   [M:ZCNTRAM]FILPOH+=")"
Endif
Affzo [M:ZCNTRAM]FILPOH
#Gosub CARGAR
Return

$SETBOUT
If [M:ZCNTRAM]NBLIG1=0
    Call VIREBOUT(CHMEN,"2") From GOBJET
Endif
Return

$BOUTON
Local Integer LRET
Case BOUT
    When "1" :  Gosub CARGARM :  Gosub CARGARP
    When "2" :  Gosub ASIGNAR :  Gosub CARGARP: Gosub CARGARM
Endcase
Return

$APRES_MODIF
If COUZON="MFGNUMSTR"
   [M:ZCNTRAM]MFGNUMSTR=CZ
   Gosub CARGARM
Endif
If COUZON="POHNUMSTR"
   [M:ZCNTRAM]POHNUMSTR=CZ
   Gosub CARGARP
Endif
Return

#Hay que tener en cuenta que solamente hay una linea de material en la OF
$CARGARM
Local Decimal LBOBASI, LBOBAASI
Local Decimal LVOLUMEN

Filter [MFG] Where MFGNUM=[M:ZCNTRAM]MFGNUMSTR
nolign=0
For [MFG]
   Filter [MFM] Where MFGNUM=[F:MFG]MFGNUM
   For [MFM]
      Filter [ZCNTRM] Where MFGNUM=[F:MFM]MFGNUM
      LBOBASI=0
      For [ZCNTRM]
          LBOBASI+=[F:ZCNTRM]BOBASI
      Next
      Filter [ZCNTRM]

      If LBOBASI<>0
         LBOBAASI=LBOBASI
      Else
         LBOBAASI=1
      Endif

      If LBOBAASI<>0
         Raz [F:ITM]
         Read [ITM]ITM0=[F:MFM]ITMREF
         [M:ZCNTRAM]NUMLNKS(nolign) =0
         [M:ZCNTRAM]MFGNUM(nolign)  =[F:MFM]MFGNUM
         [M:ZCNTRAM]MFGLIN(nolign)  =[F:MFM]MFGLIN
         [M:ZCNTRAM]ITMREF(nolign)  =[F:MFM]ITMREF
         [M:ZCNTRAM]ANCHO(nolign)   =[F:MFM]ZANCHO
         [M:ZCNTRAM]MANDRIL(nolign) =[F:MFM]ZMANDRIL
         [M:ZCNTRAM]LONGITUD(nolign) =[F:MFM]ZLONGITUD
         [M:ZCNTRAM]ITMDES1(nolign) =[F:ITM]ITMDES1
         [M:ZCNTRAM]BOBPED(nolign)  =LBOBASI
         [M:ZCNTRAM]BOBASI(nolign)  =LBOBASI
         [M:ZCNTRAM]BOBPTE(nolign)  =LBOBAASI
         LVOLUMEN=([F:MFM]ZANCHO/100)*[F:MFM]ZLONGITUD*[F:ITM]ZESPESOR
         [M:ZCNTRAM]QTYPED(nolign)=[M:ZCNTRAM]QTYPED(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAM]QTYASI(nolign)=[M:ZCNTRAM]QTYASI(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAM]QTYPTE(nolign)=[M:ZCNTRAM]QTYPTE(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         nolign+=1
      Endif
      If nolign>=200
         Break
      Endif
   Next
   Filter [MFM]
   [M:ZCNTRAM]NBLIG1=nolign
   If nolign>=200
      Break
   Endif
Next
Filter [MFG]
Affzo [M:ZCNTRAM]10
Return

$CARGARP
Local Decimal LBOBASI, LBOBAASI
Local Decimal LVOLUMEN
Local Char CRITERIO(250)

CRITERIO='1=1'
If [M:ZCNTRAM]POHNUMSTR<>''
   CRITERIO+=' and [POH]POHNUM="'+[M:ZCNTRAM]POHNUMSTR+'"'
Endif
If [M:ZCNTRAM]ITMREFSTR<>''
   CRITERIO+=' and [POQ]ITMREF="'+[M:ZCNTRAM]ITMREFSTR+'"'
Endif
If [M:ZCNTRAM]ANCHOSTR<>0
   CRITERIO+=' and [POQ]ZANCHO>='+num$([M:ZCNTRAM]ANCHOSTR)
Endif

Link [POH] With [POQ]POQ0(1)=POHNUM As [LNK] Where evalue (CRITERIO)

Filter [LNK]
nolign=0
For [LNK]
      #Recuperamos las cantidades ya asignadas por pedidos de venta
      Filter [ZCNTRS] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
      LBOBASI=0
      For [ZCNTRS]
          LBOBASI+=[F:ZCNTRS]BOBASI
      Next
      Filter [ZCNTRS]

      LBOBAASI=[F:POQ]ZQTYBOB-LBOBASI

      #Recuperamos las cantidades ya asignadas por OF's
      Filter [ZCNTRM] Where POHNUM=[F:POQ]POHNUM and POPLIN=[F:POQ]POPLIN
      LBOBASI=0
      For [ZCNTRM]
          LBOBASI+=[F:ZCNTRM]BOBASI
      Next
      Filter [ZCNTRM]
      LBOBAASI=LBOBAASI-LBOBASI

      If LBOBAASI<>0
         Raz [F:POP]
         Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
         Raz [F:ITM]
         Read [ITM]ITM0=[F:POQ]ITMREF
         [M:ZCNTRAM]NUMLNKP(nolign) =0
         [M:ZCNTRAM]POHNUM(nolign)  =[F:POQ]POHNUM
         [M:ZCNTRAM]POPLIN(nolign)  =[F:POQ]POPLIN
         [M:ZCNTRAM]POQSEQ(nolign)  =[F:POQ]POQSEQ
         [M:ZCNTRAM]PITMREF(nolign)  =[F:POQ]ITMREF
         [M:ZCNTRAM]PANCHO(nolign)   =[F:POQ]ZANCHO
         [M:ZCNTRAM]PMANDRIL(nolign) =[F:POQ]ZMANDRIL
         [M:ZCNTRAM]PLONGITUD(nolign) =[F:POQ]ZLONGITUD
         [M:ZCNTRAM]PITMDES1(nolign) =[F:POP]ITMDES1
         [M:ZCNTRAM]PBOBPED(nolign)  =[F:POQ]ZQTYBOB
         [M:ZCNTRAM]PBOBASI(nolign)  =LBOBASI
         [M:ZCNTRAM]PBOBPTE(nolign)  =LBOBAASI
         LVOLUMEN=([F:POQ]ZANCHO/100)*[F:POQ]ZLONGITUD*[F:ITM]ZESPESOR
         [M:ZCNTRAM]PQTYPED(nolign)=[M:ZCNTRAM]QTYPED(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAM]PQTYASI(nolign)=[M:ZCNTRAM]QTYASI(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         [M:ZCNTRAM]PQTYPTE(nolign)=[M:ZCNTRAM]QTYPTE(nolign)*LVOLUMEN*([F:ITM]DTY*1000000/1000)
         nolign+=1
      Endif
      If nolign>=200
         Break
      Endif
Next
[M:ZCNTRAM]NBLIG2=nolign
[M:ZCNTRAM]BPSNUM=[F:POH]BPSNUM
Filter [POH]
Affzo [M:ZCNTRAM]15
Return

$ASIGNAR
Local Integer LOK,I,J,MAXLIN

MAXLIN=0
Filter [ZCNTRM] Where POHNUM=[M:ZCNTRAM]POHNUMSTR
For [F:ZCNTRM]
   If [F:ZCNTRM]NUMLIN>MAXLIN
      MAXLIN=[F:ZCNTRM]NUMLIN
   Endif
Next
Filter [ZCNTRM]

LOK=1
Trbegin [ZCNTRM]
For I=0 To [M:ZCNTRAM]NBLIG2-1
   For J=0 To [M:ZCNTRAM]NBLIG1-1
      If [M:ZCNTRAM]NUMLNKS(J)<>0 or [M:ZCNTRAM]NUMLNKP(I)<>0
         If [M:ZCNTRAM]NUMLNKS(J)=[M:ZCNTRAM]NUMLNKP(I)
            MAXLIN=MAXLIN+1000
            [F:ZCNTRM]NUMCNTR =LNUMCNTR
            [F:ZCNTRM]NUMLIN =MAXLIN
            [F:ZCNTRM]POHNUM =[M:ZCNTRAM]POHNUM(I)
            [F:ZCNTRM]POPLIN =[M:ZCNTRAM]POPLIN(I)
            [F:ZCNTRM]POQSEQ =[M:ZCNTRAM]POQSEQ(I)
            [F:ZCNTRM]MFGNUM =[M:ZCNTRAM]MFGNUM(J)
            [F:ZCNTRM]MFGLIN =[M:ZCNTRAM]MFGLIN(J)
            [F:ZCNTRM]BOBASI =[M:ZCNTRAM]BOBPTE(J)
            Write [ZCNTRM]
            If fstat
               LOK=0
               Infbox "Error grabando linea [ZCNTRM] - fstat: "+num$(fstat)
               Break
            Endif
         Endif
      Endif
   Next
Next
If LOK
   Commit
Else
   Rollback
Endif
Return
