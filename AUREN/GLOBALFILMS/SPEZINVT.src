# Gestión de la máscara ZINVT0 (Especifico)
$ACTION
Return

######################################################################################

$COMPLETAR
[M:ZINVT0]CLAVE=[M:ZINVT0]FCY+num$([M:ZINVT0]ZANO)+format$("N0:2",[M:ZINVT0]ZMES)
#Infbox "GREP="+GREP
#If GREP="C"
#  If clalev([F:WZINV]) <=0   :  Local File ZINVENTH     [F:WZINV]  : Endif
#  Read [F:WZINV]ZINV0=[M:ZINVT0]CLAVE
#  If fstat=0
#    GMESSAGE = "Ya existe el inventario indicado"
#    mkstat = 1 : End
#  Endif
#Endif
Return

Subprog RECALCULAR(TIPO)
Value Integer TIPO
Local Integer F
#If GUSER="ADMIN"   Infbox "Depurar   (Subprog RECALCULAR(TIPO))"   Endif
For F=0 To [M:ZINVT1]NBLIG-1
  If TIPO=2 and [M:ZINVT1]PRENUEVO(F)>0
    [M:ZINVT1]VALOR(F)   =[M:ZINVT1]PRENUEVO(F)*[M:ZINVT1]QTYSTU(F)
  Else
    [M:ZINVT1]VALOR(F)   =[M:ZINVT1]PRELOT(F)  *[M:ZINVT1]QTYSTU(F)
  Endif
  Gosub LINEA_CAMBIADA From SUBZINVT
Next
Affzo [M:ZINVT1]10
Raz [M:ZINVT2]NBLIG
Effzo [M:ZINVT2]10
Call SACAR_INVT_RES From SUBZINVT
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZINVT0) 27/04/2017 19:07:07 (ADMIN)
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If [M:ZINVT0]FCY<>VALEUR and (GREP="C" or GREP="D")
  [M:ZINVT0]FCY=VALEUR
  Call SIGUIENTE_INVT From SUBZINVT
Endif
[M:ZINVT0]FCY=VALEUR
Gosub COMPLETAR
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
#If GREP="C" or GREP="D"
#  [M:ZINVT0]FCY=VALEUR
#  Call SIGUIENTE_INVT From SUBZINVT
#Endif
End

Subprog C_ZANO(VALEUR)
Variable Decimal VALEUR
[M:ZINVT0]ZANO=VALEUR
Gosub COMPLETAR
End

Subprog C_ZMES(VALEUR)
Variable Integer VALEUR
[M:ZINVT0]ZMES=VALEUR
Gosub COMPLETAR
End

Subprog IB_NBLIG
Local Integer NOL   :   NOL=nolign-1
Raz GBOUT3,GBOUT4,GBOUT5,GBOUT6,GBOUT7
Raz [M:ZINVT0]ZFRA
[M:ZINVT0]ZNOL=-1
Case [M:ZINVT1]ORIGEN(NOL)
When 1  # Entrada varia
When 3  # Recepción proveedor
  If [M:ZINVT1]VCRNUM(NOL)<>""
    GBOUT3="Recepción "+[M:ZINVT1]VCRNUM(NOL)+" lŞ "+num$([M:ZINVT1]VCRLIN(NOL))
  Endif
When 5  # Entrada OF
  If [M:ZINVT1]VCRNUM(NOL)<>""
    GBOUT4="OF "       +[M:ZINVT1]VCRNUM(NOL)+" lŞ "+num$([M:ZINVT1]VCRLIN(NOL))
  Endif
When 12 # Devolucion entrega
Endcase
If [M:ZINVT1]FRA(NOL)<>""
  GBOUT5="Fra "       +[M:ZINVT1]FRA(NOL)    +" lŞ "+num$([M:ZINVT1]FRALIN(NOL))
  GBOUT6="Margen Fra "+[M:ZINVT1]FRA(NOL)
  [M:ZINVT0]ZFRA=[M:ZINVT1]FRA(NOL)
Else
  GBOUT7="Origen bobina "
  [M:ZINVT0]ZNOL=NOL
Endif
End

Subprog AM_FRECEPN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Raz   [M:ZINVT0]FOFN
  Diszo [M:ZINVT0]FOFN
Else
  Actzo [M:ZINVT0]FOFN
Endif
End

Subprog AM_FOFN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Raz   [M:ZINVT0]FRECEPN
  Diszo [M:ZINVT0]FRECEPN
Else
  Actzo [M:ZINVT0]FRECEPN
Endif
End

Subprog AM_FDIA(VALEUR)
Variable Decimal VALEUR
Local Integer ULTIMO_DIA_MES
ULTIMO_DIA_MES=day(eomonth(gdat$(1,[M:ZINVT0]ZMES,[M:ZINVT0]ZANO)))
If VALEUR>ULTIMO_DIA_MES     VALEUR=ULTIMO_DIA_MES   Endif
End

Subprog AM_RECALCULO(VALEUR)
Variable Integer VALEUR
If [M:ZINVT1]NBLIG>0   Call RECALCULAR(VALEUR)   Endif
End

