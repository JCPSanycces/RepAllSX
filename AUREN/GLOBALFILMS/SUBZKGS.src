#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
  When "OUVRE"       :  Gosub OUVRE
  When "TITRE"       :  Gosub TITRE_S
  When "DEBUT"       :  Gosub DEBUT
#  When "SETBOUT"     :  Gosub SETBOUT

  When "BOUTON"      :  Gosub BOUTON
  When "APRES_MODIF" :  Gosub APRES_MODIF

  When "END"         :  Gosub FIN_S
  When "FIN"

  When "AVANT_LIS"
#    If [M:ZKGS]FLDCHR(3) = ""
#      FOK=0
#      GMESSAGE="Imposible imprimir\No se ha seleccionado una sesión de inventario"
#      GERR=1
#    Endif
  When "LIS"

Endcase
Return


$FIN_S
Return

$TITRE_S
TIT="AJUSTAR KGS LOTES S/FACTOR ARTICULO"
Return

$OUVRE
Local Char BD_TIPO(1),ZMSG(255)
Local Integer YN,FLG_OK
Local Integer IF_TRANS   # Se usa para saber si estamos dentro de una transaccion.......18_11_16 En este src será que no

If !clalev([F:STO])      :  Local File STOCK        [F:STO]  : Endif
If !clalev([F:ITM])      :  Local File ITMMASTER    [F:ITM]  : Endif

# Tope de filas en rejilla
Local Integer TFILAS
TFILAS=func ZCOMUN.FILAS_GRID("ZPINVKGS","NBLIG")
########################################
## PARAMETROS    son de tipo CHAR     ##
##      nombre parametro máximo 10    ##
########################################
Local Char TMP(255)
##Cliente para facturas TPV
#Local Char CTEFRASTPV(GLONBPR)
#Call PARAM("","ZCTEFRASTP",CTEFRASTPV) From ADOVAL
Return


$DEBUT
Raz [M:ZKGS]
# Valores por defecto
#Gosub BORRA_PANTALLA
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
# Guardo valores
[M:ZKGS]FLDNUM(0) = TFILAS
[M:ZKGS]FLDNUM(1) = 0  # Guardo la fila del cálculo que se está mostrando en Subprog AS_NCALC de fuente SPEZINV0
#
[M:ZKGS]FLDCHR(0) = BD_TIPO
# Valores por defecto
Return



$APRES_MODIF
## COUZON nombre del campo
## COUIND indice en caso de ser un campo del grid
## CZ     valor del campo
##If    COUZON="FEMPALME" and CZ="2"
##    Chgstl [M:ZKGS]FEMPALME With "BACKRED"
##Elsif COUZON="FEMPALME" and CZ="1"
##    Chgstl [M:ZKGS]FEMPALME With ""
##Endif
#Case maskcou
#When "ZPINVKGS"
Call VACIAR_REJILLA
#  Case COUZON
#  Endcase
#Endcase
Return



#$SETBOUT
## BOTONES, añadidos a la derecha.    Por defecto SI habilitados
## MENUS  , añadidos a la derecha.    Por defecto NO habilitados
#Gosub ESTADO
#Return

$BOUTON
FLG_OK=1
Case BOUT
  When "1"
    Call CONSULTAR(FLG_OK)
  When "2"
    Gosub AJUSTAR
Endcase
Return



#===================================
#Subrutinas propias
#===================================
#$BORRA_PANTALLA
#Raz [M:ZKGS]
#Gosub ESTADO
#Affzo [M:ZKGS]
#Return

$ESTADO
Return



$AJUSTAR
MSG="Está seguro de PROCESAR los registros mostrados\Se aumentará o disminuirá el peso de los lotes\según lo indicado en columna KGS DIFª"
YN=1 # Por defecto es NO
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  Return
Endif
#Bloqueo la tabla STOCK, para evitar interferencias
If clalev([F:STO]) <=0   :  Local File STOCK        [F:STO]  : Endif
Lock [F:STO] With lockwait=5
If fstat<>0
  MSG="Algún proceso está usando el STOCK\Fué imposible bloquear la tabla de STOCK\Revise los procesos y vuélvalo a intentar"
  Call ERREURT(MSG, 0) From GESECRAN   #0-Informativo, 1-Error
  FLG_OK=0
  Return
Endif
Call CONSULTAR(FLG_OK)
If FLG_OK
  Call PROCESAR(FLG_OK)
Endif
Call VACIAR_REJILLA
Unlock [F:STO]
Return





#===================================
#Procedimientos y funciones PROPIOS
#===================================
Subprog VACIAR_REJILLA
If [M:ZKGS]NBLIG<1      End      Endif
Raz [M:ZKGS]NBLIG
Effzo [M:ZKGS]5
Raz [M:ZKGS]TKGS,[M:ZKGS]TIMP
#Affzo [M:ZKGS]5,15
End

Subprog CONSULTAR(FLG_OK)
Variable Integer FLG_OK
Local Char TXT(255)(10),BD_TIPO(1)
Local Decimal TKG,TIM
BD_TIPO=[M:ZKGS]FLDCHR(0)
TF     =[M:ZKGS]FLDNUM(0)
#
Call VACIAR_REJILLA
If [M:ZKGS]FDIF<=0
    TXT="Debe indicar un % difª"
    Call ERREURT(TXT,1) From GESECRAN   #0-Informativo, 1-Error
    End
Endif
Raz TXT
#select s.STOFCY_0,s.ITMREF_0,LOC_0,LOT_0,
# SLO_0,ZLOTORI_0,ZANCHO_0,ZLONGITUD_0,s.ZMANDRIL_0,QTYSTU_0,CUMALLQTY_0,round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)KgsArt,round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)-QTYSTU_0 KgsDif
# ,round(QTYSTU_0/(ZANCHO_0*ZLONGITUD_0/1000),6) FctCalc,s.ZFACTOR_0,a.ZFACTOR_0,a.ZFACTOR_0-s.ZFACTOR_0 Dif, round((a.ZFACTOR_0-s.ZFACTOR_0)*100/a.ZFACTOR_0,2) '%Dif',
#round((round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)-QTYSTU_0)*100/QTYSTU_0,2) '%DifKgs'
#from GLOBAL.STOCK s inner join GLOBAL.ITMMASTER a on s.ITMREF_0=a.ITMREF_0
#where round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)-QTYSTU_0>0 and (ZANCHO_0*ZLONGITUD_0/1000)>0 and a.ZFACTOR_0>0 and CUMALLQTY_0<=0  and  round(abs(a.ZFACTOR_0-s.ZFACTOR_0)*100/a.ZFACTOR_0,2)>3
# --abs(round((round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)-QTYSTU_0)*100/QTYSTU_0,2))>3   --
#order by round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)-QTYSTU_0 desc, s.ITMREF_0,ZANCHO_0,ZLONGITUD_0
TXT(0)="select s.STOFCY_0,s.ITMREF_0,LOC_0,s.LOT_0,s.SLO_0,ZLOTORI_0,ZANCHO_0,ZLONGITUD_0,s.ZMANDRIL_0,QTYSTU_0,CUMALLQTY_0,s.ZFACTOR_0,a.ZFACTOR_0,l.AVC_0,s.STA_0,s.BPSLOT_0,s.PALNUM_0,s.CTRNUM_0 "
TXT(1)="from STOCK s inner join ITMMASTER a on s.ITMREF_0=a.ITMREF_0 inner join STOLOTFCY l on s.STOFCY_0=l.STOFCY_0 and s.ITMREF_0=l.ITMREF_0 and s.LOT_0=l.LOT_0 and s.SLO_0=l.SLO_0 "
TXT(2)="where CUMALLQTY_0<=0 and (ZANCHO_0*ZLONGITUD_0/1000)>0 and a.ZFACTOR_0>0 and round(abs(a.ZFACTOR_0-s.ZFACTOR_0)*100/a.ZFACTOR_0,2)>="+num$([M:ZKGS]FDIF)+" "
If [M:ZKGS]FFCY<>""
  TXT(3)+="and s.STOFCY_0='"+[M:ZKGS]FFCY+"' "
Endif
If [M:ZKGS]FITM<>""
  TXT(3)+="and s.ITMREF_0='"+[M:ZKGS]FITM+"' "
Endif
If [M:ZKGS]FLOT<>""
  TXT(3)+="and s.LOT_0='"+[M:ZKGS]FLOT+"' "
Endif
TXT(4)="order by s.STOFCY_0,s.ITMREF_0,ZANCHO_0,ZLONGITUD_0,s.LOT_0,s.SLO_0"
#If GUSER="ADMIN"
#Local Char FICSRV(250)
#Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#Local Integer YN
#Call OUINON(FICSRV, YN) From GESECRAN
#If YN=1
#  End
#Endif
#Endif
Raz TKG,TIM
For (Char FFCY(GLONFCY),Char FITM(GLONITM),Char FLOC(GLONLOC),Char FLOT(GLONLOT),Char FSLO(GLONSLO),Char FZLOT(GLONLOT),Integer FANC,Integer FLNG,Shortint FMAN,Decimal FKGS,Decimal FKGSA,Decimal FSTK,
& Decimal FART,Decimal FPRE,Char FSTA(3),Char FLPR(GLONLOT),Char FPAL(GLONPAL),Char FCTR(GLONCTR)) From BD_TIPO Sql TXT As [MYT]
  F=[M:ZKGS]NBLIG
  [M:ZKGS]FCY(F)      =[MYT]FFCY
  [M:ZKGS]ITMREF(F)   =[MYT]FITM
  [M:ZKGS]LOC(F)      =[MYT]FLOC
  [M:ZKGS]ANCHO(F)    =[MYT]FANC
  [M:ZKGS]LONGITUD(F) =[MYT]FLNG
  [M:ZKGS]MANDRIL(F)  =[MYT]FMAN
  [M:ZKGS]LOT(F)      =[MYT]FLOT
  [M:ZKGS]SLO(F)      =[MYT]FSLO
  [M:ZKGS]ZLOTORI(F)  =[MYT]FZLOT
  [M:ZKGS]FACTORART(F)=[MYT]FART
  [M:ZKGS]KGSTEO(F)   =arr(([MYT]FANC*[MYT]FLNG/1000)*[MYT]FART,0.0001) # round((ZANCHO_0*ZLONGITUD_0/1000)*a.ZFACTOR_0,4)KgsArt,
  [M:ZKGS]FACTORSTK(F)=[MYT]FSTK
  [M:ZKGS]KGSSTK(F)   =[MYT]FKGS
  [M:ZKGS]KGSDIF(F)   =[M:ZKGS]KGSTEO(F)-[M:ZKGS]KGSSTK(F)
  [M:ZKGS]KGSDIFP(F)  =arr(([MYT]FART-[MYT]FSTK)*100/[MYT]FART,0.01)    # round((a.ZFACTOR_0-s.ZFACTOR_0)*100/a.ZFACTOR_0,2) '%Dif'
  [M:ZKGS]PRELOT(F)   =[MYT]FPRE
  [M:ZKGS]IMPORTE(F)  =[MYT]FPRE*[M:ZKGS]KGSDIF(F)
  [M:ZKGS]STA(F)      =[MYT]FSTA
  [M:ZKGS]BPSLOT(F)   =[MYT]FLPR
  [M:ZKGS]PALNUM(F)   =[MYT]FPAL
  [M:ZKGS]CTRNUM(F)   =[MYT]FCTR
  TKG+=[M:ZKGS]KGSDIF(F)
  TIM+=[M:ZKGS]IMPORTE(F)
  If GUSER="ADMIN" and  [M:ZKGS]NBLIG+1>=250
    [M:ZKGS]NBLIG+=1
    Infbox "Aviso para ADMIN  FALTAN DATOS   REPITALO TRAS AJUSTAR ESTOS"
    Break
  Elsif [M:ZKGS]NBLIG+1>=TF
    MSG="Alcanzado máximo de " + num$(TF+1) + " filas para inventario\.\Ajuste los filtros"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    FLG_OK=0
  Else
    [M:ZKGS]NBLIG+=1
  Endif
Next
[M:ZKGS]TKGS=TKG
[M:ZKGS]TIMP=TIM
Affzo [M:ZKGS]5,15
End

Subprog PROCESAR(FLG_OK)
Variable Integer FLG_OK
Local Char RFCY(GLONFCY)
#If GUSER<>"ADMIN"
#Call ERREURT("12-01-17 17:00  JLPR   EN PROCESO ",1) From GESECRAN   #0-Informativo, 1-Error
#End
#Endif
# Determino fecha procesamiento inventario
[M:ZKGS]FLDCHR(5)=format$("D:YYYY[-]MM[-]DD",date$)+"T"+num$(time$)+"Z"
Call OUVRE_TRACE("Inicio generación ENT/SAL por ajuste Kgs lotes") From LECFIC
Raz RFCY
For F=0 To [M:ZKGS]NBLIG-1
  If RFCY<>[M:ZKGS]FCY(F)
    RFCY=[M:ZKGS]FCY(F)
    Call ECR_TRACE("Generación ENT/SAL inventario Planta "+RFCY,0) From GESECRAN
    Call GENERAR(1,FLG_OK,RFCY)
    Call GENERAR(2,FLG_OK,RFCY)
  Endif
Next
Raz [M:ZKGS]FLDCHR(5)
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog GENERAR(MVTO,FLG_OK,RFCY)
Variable Integer FLG_OK
Value Char RFCY        # Planta
Value Integer MVTO     #                      1=Salidas     2=Entradas
Local Char MVTO_TYP(2) # Tipo Mvto fic.impor 20=Salidas    19=Entradas
Local Integer F        # Filas de la rejilla
Local Integer DF       # Difª=Stk-Cnt        >0=Salidas    <0=Entradas
Local Integer C        # Contador de Mvtos
Local Char X1(5)       # Componer nombre fichero
Local Char ART_LOT(255)# Para sacar ultimo Lote por Articulo/Lote....Rejilla ordenada por
# Variables para tratamiento fichero
Local Char WDIR(250),WNOM(20),WJOB(10),WXML(250),WOUT(250),WFICH(250),TMP(255)
# Variable para generacion contenido fichero
Local Char LDESMOV(25),LSTOFCY(GLONFCY),LITMREF(GLONITM),LARTAUX(GLONITM)
Local Decimal LNUMLIN, LQTYTOT
Local Char LSLOT(GLONSLO)(500),LSTAT(1)(500),LPCU(GLONUOM)(500)
Local Decimal LQTYSTU(500)

# Valores comunes
LDESMOV="Ajuste kgs lotes"
LSTOFCY=RFCY
#
If MVTO=1
  X1="_SAL_"
  WNOM="GFESMO"
  MVTO_TYP="20"
Else
  X1="_ENT_"
  WNOM="ZGFESMR" #"GFESMR"
  MVTO_TYP="19"
Endif
Raz LARTAUX,C
FLG_OK=1
For F=0 To [M:ZKGS]NBLIG-1
  If [M:ZKGS]FCY(F)=RFCY
    If [M:ZKGS]KGSDIF(F)<0 and MVTO=1
      If C=0
        Gosub ABRIR_FIC
        Gosub GENERAR_GRABAR_CAB
      Endif
      Gosub GENERAR_GRABAR_SAL
      C+=1
    Elsif [M:ZKGS]KGSDIF(F)>0 and MVTO=2
      If C=0
        Gosub ABRIR_FIC
        Gosub GENERAR_GRABAR_CAB
      Endif
      Gosub GENERAR_GRABAR_ENT
      C+=1
    Endif
  Endif
Next
# Fin
Openo Using [TIF]   #Cerramos el fichero XML generado
If C>0 and FLG_OK
  # Lanzamos importación
  Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
  # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
  WFICH = filpath(WDIR,WXML,"txt.err")
  If filinfo(WFICH,0) > 0 Then
      MSG= "Hubieron Problemas en la importacion del fichero\"+WXML
      Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
  Else
    Call ECR_TRACE("=======================================================================================",0) From GESECRAN
    Call ECR_TRACE("=======================================================================================",0) From GESECRAN
  Endif
Endif
End

$GENERAR_GRABAR_ENT
Local Decimal WKG
Gosub LEER_ITM
# <<  Lineas  >>
Call ECR_TRACE("Art "+LARTAUX+"  "+num$([M:ZKGS]ANCHO(F))+"-"+num$([M:ZKGS]LONGITUD(F))+"-"+num$([M:ZKGS]MANDRIL(F))+" Lote: "+[M:ZKGS]LOT(F)+" S/Lote: "+[M:ZKGS]SLO(F)+" Kgs "+num$
& ([M:ZKGS]KGSDIF(F)),0) From GESECRAN
If ART_LOT<>[M:ZKGS]ITMREF(F)+[M:ZKGS]LOT(F)+num$([M:ZKGS]ANCHO(F))+num$([M:ZKGS]LONGITUD(F))+num$([M:ZKGS]MANDRIL(F))
  ART_LOT = [M:ZKGS]ITMREF(F)+[M:ZKGS]LOT(F)+num$([M:ZKGS]ANCHO(F))+num$([M:ZKGS]LONGITUD(F))+num$([M:ZKGS]MANDRIL(F))
  LNUMLIN+= 1000
  #Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBENT),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYENT),[F:ITM]STU,num$(LQTYENT),num$(1.9748)
  # Using [ZENT]
  WKG=func KGS_ENT(MVTO,F,DF)
  Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(DF),num$([M:ZKGS]ANCHO(F)),num$([M:ZKGS]MANDRIL(F)),num$([M:ZKGS]LONGITUD(F)),"",[F:ITM]STU,num$(WKG),[F:ITM]STU,num$(WKG),num$([M:
& ZKGS]PRELOT(F)) Using [TIF]
Endif
# << Lineas Det  >>
WKG=[M:ZKGS]KGSDIF(F)
Wrseq "S",[F:ITM]STU,num$(WKG),[M:ZKGS]BPSLOT(F),[M:ZKGS]LOT(F),[M:ZKGS]SLO(F),"",[M:ZKGS]LOC(F),[M:ZKGS]STA(F),[M:ZKGS]PALNUM(F),[M:ZKGS]CTRNUM(F) Using [TIF]
Return

$GENERAR_GRABAR_SAL  # 100   011   161014046IN
Local Integer J,WJ
Gosub LEER_ITM
# <<  Lineas  >>
Call ECR_TRACE(num$(DF)+" Bobinas "+num$([M:ZKGS]ANCHO(F))+"-"+num$([M:ZKGS]LONGITUD(F))+"-"+num$([M:ZKGS]MANDRIL(F))+" Lote: "+[M:ZKGS]LOT(F)+" Ubic.: "+[M:ZKGS]LOC(F),0) From GESECRAN
If ART_LOT<>[M:ZKGS]ITMREF(F)+[M:ZKGS]LOT(F)+num$([M:ZKGS]ANCHO(F))+num$([M:ZKGS]LONGITUD(F))+num$([M:ZKGS]MANDRIL(F))
  ART_LOT = [M:ZKGS]ITMREF(F)+[M:ZKGS]LOT(F)+num$([M:ZKGS]ANCHO(F))+num$([M:ZKGS]LONGITUD(F))+num$([M:ZKGS]MANDRIL(F))
  LNUMLIN+=1000
  #Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBSAL),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYSAL),[F:ITM]STU,num$(LQTYSAL) Using [ZSAL]
  WKG=func KGS_ENT(MVTO,F,DF)
  Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(abs(DF)),num$([M:ZKGS]ANCHO(F)),num$([M:ZKGS]MANDRIL(F)),num$([M:ZKGS]LONGITUD(F)),"",[F:ITM]STU,num$(WKG),[F:ITM]STU,num$(WKG) Using [TIF]
Endif
# << Lineas Det  >>
WKG=[M:ZKGS]KGSDIF(F)
Wrseq "S",LPCU(J),num$(WKG),[M:ZKGS]LOT(F),[M:ZKGS]SLO(F),[M:ZKGS]LOC(F),[M:ZKGS]STA(F) Using [TIF]
Return

$GENERAR_GRABAR_CAB
Raz LNUMLIN
# << Cabecera >>
# Wrseq "E","20","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZSAL]
# Wrseq "E","19","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZENT]
  Wrseq "E",MVTO_TYP,"",LSTOFCY,format$("DDMMYYYY",gdatetime$([M:ZKGS]FLDCHR(5))),LDESMOV,"","" Using [TIF]
Return

$LEER_ITM
If LARTAUX<>[M:ZKGS]ITMREF(F)
  LARTAUX=[M:ZKGS]ITMREF(F)
  Call ECR_TRACE("Art.: "+LARTAUX,0) From GESECRAN
  Raz [F:ITM]
  Read [ITM]ITM0=[M:ZKGS]ITMREF(F)
  If fstat
    MSG= "Error leyendo artículo "+[M:ZKGS]ITMREF(F)+"\fstat: "+num$(fstat)
    Call ERREURT(MSG,1)   From GESECRAN   #0-Informativo, 1-Error
    Call ECR_TRACE(MSG,1) From GESECRAN
  Endif
Endif
Return


Funprog KGS_ENT(MVTO,L,BOB)
Value Integer MVTO,L
Variable Integer BOB
Local Decimal K
Local Integer F
Raz K,BOB
For F=L To [M:ZKGS]NBLIG-1
  If [M:ZKGS]ITMREF(F)=[M:ZKGS]ITMREF(L) and [M:ZKGS]LOT(F)=[M:ZKGS]LOT(L) and [M:ZKGS]ANCHO(F)=[M:ZKGS]ANCHO(L) and [M:ZKGS]LONGITUD(F)=[M:ZKGS]LONGITUD(L) and [M:ZKGS]MANDRIL(F)=[M:ZKGS]MANDRIL(L)
    If    MVTO=1 and [M:ZKGS]KGSDIF(F)<0 # Salidas
      K+  =abs([M:ZKGS]KGSDIF(F))
      BOB+=1
    Elsif MVTO=2 and [M:ZKGS]KGSDIF(F)>0 # Entradas
      K+=abs([M:ZKGS]KGSDIF(F))
      BOB+=1
    Endif
  Else
    Break
  Endif
Next
End K

$ABRIR_FIC
# Comprobar directorio y crearlo en caso de que no exista
WDIR="ZIMPEXP\IMPOR"
TMP=filpath("","","","","",adxmac(0)) +"\" + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
# Montar nombre Fichero
#WNOM="GFESMO"    #   Modelo de importación
WJOB = num$(time)
WXML = WNOM+X1+"_KGS_"+format$("D:YYYYMMDD",date$)+"_"+WJOB
WOUT = filpath(WDIR,WXML,"txt")
# Abrir fichero
adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII
Openo WOUT,0 Using [TIF]
Return

