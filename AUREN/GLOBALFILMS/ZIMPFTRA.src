#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento que dado el fichero de facturas del trasnportista seleccionado por el usuario,
#las inserta en la tabla ZIMPFTRA (Fras. de transportista importadas) para su posterior tratamiento

$ACTION
#Infbox ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "OK"          : Gosub OK
  When Default
Endcase
Return

$CONTROLE
TMP = 1
TIT = "Importación en curso"
Return

$OUVRE
Global Char WNOMFIC(250)
Global Char WSALFCY(10)
Global Char WBPTNUM(15)
Global Integer WEXE
Local Char TIT(80)

WEXE = 0
WBPTNUM = ""
WSALFCY = ""
TIT = "Importacion facturas transportista"
Return

$INIT
Local Mask ZSELFICFTRA [M:ZSFTRA]

Raz [M:ZSFTRA]
[M:ZSFTRA]SALFCY=GFCYDEF(3)
Return

$DEBUT
Affzo [M:ZSFTRA]5
Return

$OK
WEXE = 1
WSALFCY = [M:ZSFTRA]SALFCY
WNOMFIC = [M:ZSFTRA]NOMFIC(0)
WBPTNUM = [M:ZSFTRA]BPTNUM
Return

$EXEC
If WEXE=1
   Gosub PROCESA
Endif
Return

$PROCESA
Local Char A(250)(1..110)
Local Char WOUT(250)
Local Char WJOB(10)

Local Integer WOK
Local Integer CONT

If clalev([ZFTRA])<=0  : Local File ZFRATRA    [ZFTRA]   : Endif
If clalev([BPT])<=0    : Local File BPCARRIER  [BPT]     : Endif
If clalev([BPC])<=0    : Local File BPCUSTOMER [BPC]     : Endif
If clalev([SDH])<=0    : Local File SDELIVERY  [SDH]     : Endif

Call OUVRE_TRACE("Importación de facturas transportistas ") From LECFIC
Call ECR_TRACE(" Importación de facturas transportista: "+WBPTNUM+" Planta: "+WSALFCY,0) From GESECRAN

Call ECR_TRACE(" Inicio importación facturas trasnportista ",0) From GESECRAN

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

#lectura de fichero

WNOMFIC = mid$(WNOMFIC,7,len(WNOMFIC))
WNOMFIC = filpath("BQT","","") +"\" +WNOMFIC

Openi WNOMFIC Using [TIE]

Gosub LEER_REGISTRO   :#fichero viene con cabecera de los campos
Gosub LEER_REGISTRO

Raz CONT

WOK=1
Trbegin [ZFTRA]

While !fstat
   Call ECR_TRACE("Procesando:  "+vireblc(A(1),2),0) From GESECRAN
   CONT += 1
   #A(1) --> Numero factura
   #A(2) --> Fecha factura
   #A(3) --> Expedicion
   #A(4) --> Fecha expedicion
   #A(5) --> Referencia (numero packing)
   #A(6) --> Destinatario
   #A(7) --> Codigo pais destinatario
   #A(8) --> Codigo postal destinatario
   #A(9) --> Poblacion destinatario
   #A(10) --> Bultos
   #A(11) --> Volumen
   #A(12) --> Peso bruto
   #A(13) --> Importe portes
   #A(14) --> Importe seguro
   #A(15) --> Importe reenvio
   #A(17) --> Base imponible

   Raz [F:ZFTRA]
   [F:ZFTRA]SALFCY=WSALFCY
   [F:ZFTRA]BPTNUM=WBPTNUM
   [F:ZFTRA]NUMFRA=vireblc(A(1),2)
   [F:ZFTRA]FECFRA=gdat$(val(mid$(vireblc(A(2),2),1,2)),val(mid$(vireblc(A(2),2),4,2)),val(mid$(vireblc(A(2),2),7,4)))
   [F:ZFTRA]NUMEXP=vireblc(A(3),2)
   [F:ZFTRA]FECEXP=gdat$(val(mid$(vireblc(A(4),2),1,2)),val(mid$(vireblc(A(4),2),4,2)),val(mid$(vireblc(A(4),2),7,4)))
   [F:ZFTRA]REFERE=vireblc(A(5),2)
   [F:ZFTRA]DESTINAT=vireblc(A(6),2)
   [F:ZFTRA]CODPAIDES=vireblc(A(7),2)
   [F:ZFTRA]CODPOSDES=vireblc(A(8),2)
   [F:ZFTRA]POBDES=vireblc(A(9),2)
   [F:ZFTRA]BULTOS=val(ctrans(ctrans(A(10),".",""),",","."))
   [F:ZFTRA]VOLUMEN=val(ctrans(ctrans(A(11),".",""),",","."))
   [F:ZFTRA]PESBRU=val(ctrans(ctrans(A(12),".",""),",","."))
   [F:ZFTRA]IMPPOR=val(ctrans(ctrans(A(13),".",""),",","."))
   [F:ZFTRA]IMPSEG=val(ctrans(ctrans(A(14),".",""),",","."))
   [F:ZFTRA]IMPREE=val(ctrans(ctrans(A(15),".",""),",","."))
   [F:ZFTRA]BASIMP=val(ctrans(ctrans(A(16),".",""),",","."))
   [F:ZFTRA]CREDAT=date$
   [F:ZFTRA]CREUSR=GUSER

   Raz [F:BPT]
   Read [F:BPT]BPT0=WBPTNUM

   Raz [F:SDH]
   Read [F:SDH]SDH0=[F:ZFTRA]REFERE
   If fstat
      Call ECR_TRACE("   Entrega no encontrada:  "+[F:ZFTRA]REFERE,0) From GESECRAN
      #WOK=0
   Endif

   Raz [F:BPC]
   Read [F:BPC]BPC0=[F:SDH]BPCORD
   If fstat
      Call ECR_TRACE("   Cliente no encontrado:  "+[F:SDH]BPCORD,0) From GESECRAN
      #WOK=0
   Endif

   [F:ZFTRA]BPCNUM=[F:BPC]BPCNUM

   Write [ZFTRA]
   If fstat
      Call ECR_TRACE("   Error grabando factura [ZFTRA] - fstat:  "+num$(fstat)+" Fra.:" +[F:ZFTRA]NUMFRA,1) From GESECRAN
      WOK=0
   Endif
   Gosub LEER_REGISTRO
   If !WOK
      Break
   Endif
Wend
Openi Using [TIE]

If !OK
   CONT=0
   Rollback
Else
   Commit
Endif
Call ECR_TRACE(" Fin proceso importacion facturas transportistas ",0) From GESECRAN


Call ECR_TRACE(" Fin importación facturas trasnportistas: "+num$(CONT),0) From GESECRAN
Call FERME_TRACE From LECFIC
TRA = 1
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return

$TERMINE
TRA = 1
Return
