$ACTION
#Infbox "ACTION = " + ACTION + "      GFONCTION= " + GFONCTION +  "     GACTION " + GACTION
#   EXEC        (se muestra ventana Operacion en curso y se lanza listado)
#   DEBUT       (se muestra ventana, SIN DATOS)
#   CLE_GAUCHE  (Ya hay datos)
# Entrando                    INIT          AVANT_PAR     OUVRE       OUVRE_BOITE  TITRE   DEBUT      CLE_GAUCHE   SETBOUT    AV_CHOIX
# clik  imprimir              AP_CHOIX      AVANT_BOUTON  BOUTON      FIN          FINSAI  CONTROLE   EXEC         TERMINE    SORTIE
# click "Salir funciµn"       AP_CHOIX                    END         FIN          FINSAI  CONTROLE   EXEC         TERMINE    SORTIE

Case ACTION
When "TITRE"
  Case GACTION
  When "ZAINVE"
    TIT="LISTADO PARA RECUENTO INVENTARIO"
  Endcase
When ""
Endcase
Return
