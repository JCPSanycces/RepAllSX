#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
If GUSER="ADMIN"
#   Infbox ACTION
Endif
Case ACTION
When "RAZCRE"    : Gosub RAZCRE
When "LIENS"     : Gosub LIENS
When "TITRE"     : Gosub TITRE_S

#Acciones control flujo CREACION       RAZCRE + VERIF_CRE + INICRE    + CREATION  + APRES_CRE   + AB_CREATION
#Acciones control flujo MODIFICACION   LIENS  + STYLE     + AVANT_MOD + VERIF_MOD + AVANT_MOFIC + INIMOD      + MODIF + APRES_MODIF + AB_MODIF
When "VERIF_CRE" : Gosub VERIF_CRE
When "VERIF_MOD" : Gosub VERIF_MOD
When "STYLE"     : Gosub STYLE

#Accion tras hacer click en un boton ańadido
When "EXEBOUT"   : Gosub EXEBOUT


When "AFFMASK"   : Gosub AFFMASK
When "AVANT_MOD" : Gosub AVANT_MOD
When "SETBOUT"   : Gosub SETBOUT
When "AVANT_DEVERROU" : Gosub AVANT_DEVERROU
Endcase
Return


$STYLE
If [M:ZCIT0]ANULADO=2
  Chgtzn[M:ZCIT0]ANULADO With "Anulado ("+format$("D:DD[-]MM[-]YYYY",[M:ZCIT0]FECANU)+")"
Else
  Chgtzn[M:ZCIT0]ANULADO With "Anulado"
Endif
Return


$VERIF_MOD
Call ERREURT("No se permite modificación\Tan solo Crear ó borrar\Haga click en Salir para continuar", 1) From GESECRAN   #0-Informativo, 1-Error
OK=0
Return

$VERIF_CRE
#Comprobaciones
If [M:ZCIT0]PRECIOTARIFA<=0
  Call ERREURT("No hay precio definido en dicha tarifa", 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
  Return
Endif
If not func CTE_ACTIVO([M:ZCIT0]BPCNUM)
  OK=0
  Return
Endif
Return

$AFFMASK
Chgfmt [M:ZCIT0]ZNADA  With "-"
Chgfmt [M:ZCIT0]ZNADA1 With "-"
Chgfmt [M:ZCIT0]ZNADA2 With "-"
Local Integer YN
# Guardo valores
Global Char GFLDCHR(80)(5)
Global Decimal GFLDNUM(5)
GFLDCHR(0) = func ZCOMUN.DATA_BASE_TIPO()
#GFLDCHR(1) = "Precios_14_01_17"
## Tope de filas en rejilla
GFLDNUM(0) = func ZCOMUN.FILAS_GRID("ZCIT1","NBLIG")
GFLDNUM(1) = 0 # Para saber si asigno valores en TARIFA_CTE
GFLDNUM(2) = 0 # Para saber si coloreamos en SETBOUT
Return

$FERME
If GFONCTION=GFONCTION1
  Kill GFLDCHR,GFLDNUM
Endif
Return

$TITRE_S
TIT="Asignar tarifa x Cte+Articulo << EN PRUEBAS # PDTE.VALIDAR >>"
Return


$RAZCRE
Raz [M:ZCIT0]SALFCY   # No tiene sentido indicar la planta en la asignacion de tarifa a cliente !!!!!
#Grizo [M:ZCIT0]ANULADO
#[M:ZCIT0]SALFCY="100"
#Affzo [M:ZCIT0]SALFCY
Return

$LIENS
Gosub EXTRAER_PRECIOTARIFA
Call LLENAR_REJILLA
Return

$AVANT_MOD
#No permitimos modificacion, pues no hay nada que modificar
#Se entra en este modo al cambiar campo auxiliar FECTARIFA, para ver los precios de la tarifa en funcion de la fecha indicada....x defecto dia de hoy
#OK=0
Return

$SETBOUT
#No permitimos modificacion, pues no hay nada que modificar
#Se entra en este modo al cambiar campo auxiliar FECTARIFA, para ver los precios de la tarifa en funcion de la fecha indicada....x defecto dia de hoy
If GREP="C" or GREP="D" or GREP="M"
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

If [M:ZCIT0]ANULADO=2
  Call VIREBOUT(CHAINE,"2") From GOBJET
Else
  Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

If GFLDNUM(2)=1
  Raz GFLDNUM(2)
  Call COLOREAR
Endif
Return

$AVANT_DEVERROU
#OK=0
Return

$EXEBOUT
Case BOUT
When "1"
  Call BORRAR
  Gosub RELIT From GOBJSUB  #Refrescar registro en pantalla
When "2"
  Call ANULAR
  Gosub RELIT From GOBJSUB  #Refrescar registro en pantalla
When "3"
  Call ACTIVAR
  Gosub RELIT From GOBJSUB  #Refrescar registro en pantalla
Endcase
Return



