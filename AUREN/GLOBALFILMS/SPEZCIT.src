Return


Funprog TARIFA_PREC(FEC_P,CTE_P,ART_P,LON_P,TAR_P,FCY_P,TARD_P,LIN_P)
Value Date       FEC_P
Value Char       CTE_P
Value Char       ART_P
Value Integer    LON_P
Value Char       TAR_P
Value Char       FCY_P
Variable Char    TARD_P
Variable Integer LIN_P
#
Local Decimal PREC
Local Char    WCRIT(255)
#
If !clalev([F:WSPL]) :  Local File SPRICLIST  [F:WSPL] : Endif
If !clalev([F:WSPC]) :  Local File SPRICCONF  [F:WSPC] : Endif
Read [F:WSPC]SPC0=TAR_P
Filter [F:WSPL]
Raz PREC,FCY_P,TARD_P,LIN_P,WCRIT
#
Local Char TIPO(GLONADI)
Local Char SUBTIPO(GLONADI)
Local Char PAIS(GLONCRY)
Call CTE_DATOS(CTE_P,PAIS,TIPO,SUBTIPO)
#
CRIT="PLI=TAR_P and "
If TAR_P='101'
  CRIT+="PLICRI2=PAIS and PLICRI3=CTE_P and PLICRI4=ART_P"
  If FCY_P<>""  CRIT+=" and PLICRI1=FCY_P"   Endif
Elsif [F:WSPC]PRIREN=19  # Tarifa longitud
  # Los precios por longitud, SON COMUNES a todas las plantas !!!!!.....Hay un máximo de 5 parametros al definir tarifas !!!!
  CRIT+="PLICRI1=PAIS and PLICRI2=TIPO and PLICRI3=SUBTIPO and PLICRI4=ART_P and PLICRI5=num$(LON_P)"
Else
  CRIT+="PLICRI2=PAIS and PLICRI3=TIPO and PLICRI4=SUBTIPO and PLICRI5=ART_P"
  If FCY_P<>""  CRIT+=" and PLICRI1=FCY_P"   Endif
Endif
CRIT+=" and PLISTRDAT<=FEC_P and [F:WSPL]PLIENDDAT>=FEC_P"
Filter [F:WSPL] Where evalue(CRIT)
Read [F:WSPL] First
If fstat=0
  PREC  =[F:WSPL]PRI
#  If TAR_P='101' or LON_P=0   FCY_P=[F:WSPL]PLICRI1   Endif
  TARD_P=[F:WSPL]PLICRD
  LIN_P =[F:WSPL]PLILIN
Endif
Filter [F:WSPL]
Case GFONCTION
When "GESZCIT"
  If dim(GFLDNUM)>0 and GFLDNUM(1)=1
    [M:ZCIT0]PAIS=PAIS
    [M:ZCIT0]TIPO=TIPO
    [M:ZCIT0]SUBTIPO=SUBTIPO
    [M:ZCIT0]PRECIOTARIFA=PREC
    [M:ZCIT0]SAU =[F:WSPL]UOM
    Affzo [M:ZCIT0]PAIS
    Affzo [M:ZCIT0]TIPO
    Affzo [M:ZCIT0]SUBTIPO
    Affzo [M:ZCIT0]PRECIOTARIFA
    Affzo [M:ZCIT0]SAU
  Endif
Endcase
End PREC

Subprog CTE_DATOS(CTE_P,PAIS,TIPO,SUBTIPO)
Value Char    CTE_P
Variable Char PAIS,TIPO,SUBTIPO
#
If !clalev([F:BPC]) : Local File BPCUSTOMER [F:BPC] : Endif
If !clalev([F:BPR]) : Local File BPARTNER   [F:BPR] : Endif
Raz PAIS,TIPO,SUBTIPO
#
Read [F:BPC]BPC0 = CTE_P
If fstat=0
    TIPO    = [F:BPC]TSCCOD(0)
    SUBTIPO = [F:BPC]TSCCOD(1)
Endif
#
Read [F:BPR]BPR0 =CTE_P
If fstat=0  PAIS=[F:BPR]CRY   Endif
End

Funprog TARIFA_CTE(FEC_P,CTE_P,ART_P,LON_P)
Value Date    FEC_P
Value Char    CTE_P
Value Char    ART_P
Value Integer LON_P
#
Local Char TARIF(GLONSPC)
Local Char CRITERE(255)
If !clalev([F:WZCIT]) : Local File ZBPCITMTAR  [F:WZCIT] : Endif
Raz TARIF,[F:WZCIT]
Filter [F:WZCIT]
Filter [F:WZCIT] Where ANULADO<>2 and PLISTRDAT<=FEC_P and BPCNUM=CTE_P and ITMREF=ART_P and ZLONGITUD=LON_P Order By PLISTRDAT Desc
If rowcount([F:WZCIT])>0
   Read [F:WZCIT] First
Else
   Filter [F:WZCIT]
   Filter [F:WZCIT] Where ANULADO<>2 and PLISTRDAT<=FEC_P and BPCNUM=CTE_P and ITMREF=ART_P and ZLONGITUD=0  Order By PLISTRDAT Desc
   If rowcount([F:WZCIT])>0 Read[F:WZCIT] First Endif
Endif
Filter [F:WZCIT]
TARIF=[F:WZCIT]PLI
End TARIF

Subprog BORRAR
Local Integer YN   :  YN=1
Call OUINON("Está seguro de eliminar este registro\Recuerde es preferible marcarlo como ANULADO", YN) From GESECRAN
If YN=1   End    Endif
If !clalev([F:WZCIT]) : Local File ZBPCITMTAR  [F:WZCIT] : Endif
Delete [F:WZCIT] Where PLISTRDAT=[M:ZCIT0]PLISTRDAT and BPCNUM=[M:ZCIT0]BPCNUM and ITMREF=[M:ZCIT0]ITMREF and ZLONGITUD=[M:ZCIT0]ZLONGITUD
If fstat
   Call ERREURT("Error borrando cliente-articulo-tarifa - fstat: "+num$(fstat), 1) From GESECRAN   #0-Informativo, 1-Error
Endif
End

Subprog ANULAR
Local Integer YN   :  YN=1
Call OUINON("Está seguro de marcar como ANULADO esta asignacion de tarifa", YN) From GESECRAN
If YN=1   End    Endif
If !clalev([F:WZCIT]) : Local File ZBPCITMTAR  [F:WZCIT] : Endif
Read [F:WZCIT]ZCIT0=[M:ZCIT0]PLISTRDAT;[M:ZCIT0]BPCNUM;[M:ZCIT0]ITMREF;[M:ZCIT0]ZLONGITUD
[F:WZCIT]ANULADO=2
[F:WZCIT]FECANU=date$
Rewrite [F:WZCIT]
End

Subprog ACTIVAR
Local Integer YN   :  YN=1
Call OUINON("Está seguro de ACTIVAR esta asignacion de tarifa", YN) From GESECRAN
If YN=1   End    Endif
If !clalev([F:WZCIT]) : Local File ZBPCITMTAR  [F:WZCIT] : Endif
Read [F:WZCIT]ZCIT0=[M:ZCIT0]PLISTRDAT;[M:ZCIT0]BPCNUM;[M:ZCIT0]ITMREF;[M:ZCIT0]ZLONGITUD
[F:WZCIT]ANULADO=1
[F:WZCIT]FECANU=[0/0/0]
Rewrite [F:WZCIT]
End

Subprog LLENAR_REJILLA
Local Integer F
Local Char FCY(GLONFCY),ZCRD(GLONVCR)
Local Integer ZLIN,C
#Vaciar rejilla
Raz [M:ZCIT1]NBLIG
Effzo [M:ZCIT1]5
#
If !clalev([F:WZCIT]) : Local File ZBPCITMTAR  [F:WZCIT] : Endif
If !clalev([F:WSPL])  : Local File SPRICLIST   [F:WSPL]  : Endif
If !clalev([F:WSPC])  : Local File SPRICCONF   [F:WSPC]  : Endif
#
Filter [F:WZCIT]
Filter [F:WZCIT] Where BPCNUM=[M:ZCIT0]BPCNUM and ITMREF=[M:ZCIT0]ITMREF Order By PLISTRDAT Desc;ZLONGITUD
For [F:WZCIT]
  # Sacar los últimos 3 precios de la tarifa
  Gosub MOSTRAR
Next
Filter [F:WZCIT]
Affzo [M:ZCIT1]5
GFLDNUM(2)=1
End

$MOSTRAR
Read [F:WSPC]SPC0=[F:WZCIT]PLI
If [F:WZCIT]PLI='101'
  #   Planta en PLICRI1
  Filter [F:WSPL] Where PLI=[F:WZCIT]PLI and                  PLICRI2=PAIS and PLICRI3=[M:ZCIT0]BPCNUM and PLICRI4=[M:ZCIT0]ITMREF
& Order By PLISTRDAT;PLICRI1 Desc
Elsif [F:WSPC]PRIREN=19  # Tarifa longitud
    # Los precios por longitud, SON COMUNES a todas las plantas !!!!!.....Hay un máximo de 5 parametros al definir tarifas !!!!
  Filter [F:WSPL] Where PLI=[F:WZCIT]PLI and PLICRI1=PAIS and  PLICRI2=TIPO and PLICRI3=SUBTIPO        and PLICRI4=[M:ZCIT0]ITMREF and PLICRI5=num$([F:WZCIT]ZLONGITUD)
& Order By PLISTRDAT Desc
Else
  Filter [F:WSPL] Where PLI=[F:WZCIT]PLI and                  PLICRI2=PAIS and PLICRI3=TIPO            and PLICRI4=SUBTIPO         and PLICRI5=[M:ZCIT0]ITMREF
& Order By PLISTRDAT;PLICRI1 Desc
Endif
If rowcount([F:WSPL])<1
  Gosub MOSTRAR_COMUN
Else
  Raz C
  For [F:WSPL]
    Gosub MOSTRAR_COMUN
    [M:ZCIT1]DPRE(F)=[F:WSPL]PRI
    [M:ZCIT1]DAL(F) =[F:WSPL]PLISTRDAT
    [M:ZCIT1]DCRD(F)=[F:WSPL]PLICRD
    If [F:WZCIT]PLI='101' or [F:WSPC]PRIREN<>19
    [M:ZCIT1]DFCY(F)=[F:WSPL]PLICRI1
    Endif
    C+=1
    If C>=4 Break Endif
  Next
Endif
Return

$MOSTRAR_COMUN
F=[M:ZCIT1]NBLIG
[M:ZCIT1]DFEC(F)=[F:WZCIT]PLISTRDAT
[M:ZCIT1]DTAR(F)=[F:WZCIT]PLI
[M:ZCIT1]DLON(F)=[F:WZCIT]ZLONGITUD
If [M:ZCIT1]NBLIG+2>=GFLDNUM(0)
  MSG="FALTAN DATOS !!!\Alcanzado máximo de " + num$(GFLDNUM(0)+1) + " filas para mostrar historial\.\Avise para que se lo aumenten"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
Else
  [M:ZCIT1]NBLIG+=1
Endif
Return

Subprog COLOREAR
Local Integer F
For F=0 To [M:ZCIT1]NBLIG-1
  If [M:ZCIT1]DPRE(F)<=0
    Chgstl [M:ZCIT1]NBLIG(F) With "BACKRED"
  Endif
Next
End

Funprog CTE_ACTIVO(CTE)
Value Char CTE
Local Integer OK
If !clalev([F:BPC])      :  Local File BPCUSTOMER [F:BPC]  : Endif
Read  [F:BPC]BPC0=CTE
If  [F:BPC]BPCSTA<>2
  Call ERREURT("Cliente NO activo", 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
Else
  OK=1
Endif
End OK

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZCIT0) 09/05/2017 11:05:25 (ADMIN)
######################################################################################
Subprog AM_FECTARIFA(VALEUR)
Variable Date    VALEUR
[M:ZCIT0]FECTARIFA=VALEUR
Gosub EXTRAER_PRECIOTARIFA
Call LLENAR_REJILLA
End

Subprog AM_PLI(VALEUR)
Variable Char    VALEUR()
[M:ZCIT0]PLI=VALEUR
Gosub EXTRAER_PRECIOTARIFA
End

Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
If not func CTE_ACTIVO(VALEUR)
  mkstat=2
  End
Endif
[M:ZCIT0]BPCNUM=VALEUR
Gosub EXTRAER_PRECIOTARIFA
Call LLENAR_REJILLA
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:ZCIT0]ITMREF=VALEUR
Gosub EXTRAER_PRECIOTARIFA
Call LLENAR_REJILLA
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
[M:ZCIT0]ZLONGITUD=VALEUR
Gosub EXTRAER_PRECIOTARIFA
End

