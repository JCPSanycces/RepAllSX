If [M:ZCIT0]PLISTRDAT=[0/0/0]
  [M:ZCIT0]PLISTRDAT=date$
  Affzo [M:ZCIT0]PLISTRDAT
Endif
GFLDNUM(1)=1
Local Decimal PREC
Local Char    ZFCY(GLONFCY),ZCRD(GLONVCR)
Local Integer ZLIN
PREC=func TARIFA_PREC([M:ZCIT0]PLISTRDAT,[M:ZCIT0]BPCNUM,[M:ZCIT0]ITMREF,[M:ZCIT0]ZLONGITUD,[M:ZCIT0]PLI,ZFCY,ZCRD,ZLIN)
GFLDNUM(1)=0
#Local Char TARIF(GLONSPC)
