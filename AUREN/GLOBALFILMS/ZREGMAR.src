#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso para regenerar margenes de documentos de venta en funcion del coste estandar
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_REGMAR
  When "TERMINE"        : Gosub TERMINE_REGMAR
  When "INIT"           : Gosub INIT_DIA_REGMAR
  When "OK"             : Gosub OK_REGMAR
  When "END"            : Gosub END_REGMAR
Endcase
Return

$TRT_INI
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITC])<=0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:SOP])<=0 : Local File SORDERP    [SOP] : Endif
If clalev([F:SDD])<=0 : Local File SDELIVERYD [SDD] : Endif
If clalev([F:SID])<=0 : Local File SINVOICED  [SID] : Endif
If clalev([F:SOH])<=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SDH])<=0 : Local File SDELIVERY  [SDH] : Endif
If clalev([F:SIH])<=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ZIOC])<=0 : Local File ZINVOCT   [ZIOC] : Endif
Return

$EXEC_REGMAR
Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Regeneración margenes",0) From GESECRAN
Else
  Call OUVRE_TRACE("Inicio regeneración margenes") From LECFIC
Endif

WMSG = "Inicio regeneración margenes"
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZREGMAR","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

Gosub REGMAR
Return

$REGMAR
Local Decimal LCOS
Local Char CRITERIO(250)
Local Char TXT(255)(3)

CRITERIO='1=1'
If [M:ZRGMA]VCRTYP=2
   #2->Pedidos de venta
   If [M:ZRGMA]SALFCY<>''
      CRITERIO+=' & [SOH]SALFCY="'+[M:ZRGMA]SALFCY+'"'
   Endif
   If [M:ZRGMA]FECSTR<>[0/0/0]
      CRITERIO+=' & [SOH]ORDDAT>=[M:ZRGMA]FECSTR'
   Endif
   If [M:ZRGMA]FECEND<>[0/0/0]
      CRITERIO+=' & [SOH]ORDDAT<=[M:ZRGMA]FECEND'
   Endif
   If [M:ZRGMA]SOHTYP<>''
      CRITERIO+=' & [SOH]SOHTYP=[M:ZRGMA]SOHTYP'
   Endif
   Link [SOP] With [SOH]SOH0=[F:SOP]SOHNUM As [LNK]
Endif
If [M:ZRGMA]VCRTYP=4
   #4->Entregas
   If [M:ZRGMA]SALFCY<>''
      CRITERIO+=' & [SDH]SALFCY="'+[M:ZRGMA]SALFCY+'"'
   Endif
   If [M:ZRGMA]FECSTR<>[0/0/0]
      CRITERIO+=' & [SDH]SHIDAT>=[M:ZRGMA]FECSTR'
   Endif
   If [M:ZRGMA]FECEND<>[0/0/0]
      CRITERIO+=' & [SDH]SHIDAT<=[M:ZRGMA]FECEND'
   Endif
   Link [SDD] With [SDH]SDH0=[F:SDD]SDHNUM As [LNK]
Endif
If [M:ZRGMA]VCRTYP=5
   #5->Factura de venta
   If [M:ZRGMA]SALFCY<>''
      CRITERIO+=' & [SID]SALFCY="'+[M:ZRGMA]SALFCY+'"'
   Endif
   If [M:ZRGMA]FECSTR<>[0/0/0]
      CRITERIO+=' & [SIH]ACCDAT>=[M:ZRGMA]FECSTR'
   Endif
   If [M:ZRGMA]FECEND<>[0/0/0]
      CRITERIO+=' & [SIH]ACCDAT<=[M:ZRGMA]FECEND'
   Endif
   #CRITERIO+='& [SID]NUM="F100-16005668"'
   Link [SID] With [SIH]SIH0=[F:SID]NUM As [LNK]
Endif
If [M:ZRGMA]VCRTYP=2
   #2->Pedidos de venta
   #Se regeneran los pedidos solamente para el caso de la planta 901 (Pedidos de agencia)
   For [LNK] Where evalue(CRITERIO)
      Raz [F:ITV]
      Read [ITV]ITV0=[F:SOQ]ITMREF;[F:SOQ]STOFCY
      Raz [F:ITM]
      Read [F:ITM]ITM0=[F:SOP]ITMREF
      #If [F:ITM]STOMGTCOD>1
         #Gestionado en stock
#         Raz [F:ITC]
#         Filter [ITC] Where STOFCY=[F:SOP]STOFCY and ITMREF=[F:SOP]ITMREF and CSTTYP=1 Order By Key ITC0
#         Read [ITC]Last
#         Filter [ITC]
#         LCOS=[F:ITC]CSTTOT

#         Raz [F:ZIOC]
#         Filter [ZIOC] Where ITMREF=[F:SOP]ITMREF Order By Key ZIOC0
#         Read [ZIOC]ZIOC0 First
#         Filter [ZIOC]
#         LCOS=[F:ZIOC]PMASI

         TXT(0)="select PMASI_0 "
         TXT(1)="From ZINVOCT "
         TXT(2)="Where ITMREF_0='" +[F:SOP]ITMREF+"'"

         LCOS=0
         For (Decimal LCOSTE) From "5" Sql TXT As [XXX]
             LCOS=LCOSTE
         Next
         If [M:ZRGMA]TIPPRE=1
            LCOS=LCOSTE
         Endif
         If [M:ZRGMA]TIPPRE=4
            LCOS=[F:ITV]AVC
         Endif
         If LCOS>0
            If [F:SOP]SAU=[F:SOP]STU
               [F:SOP]CPRPRI=LCOS
               [F:SOP]PFM   =[F:SOP]NETPRI-[F:SOP]CPRPRI
            Else
               [F:SOP]CPRPRI=LCOS*[F:ITM]ZFACTOR
               [F:SOP]PFM   =[F:SOP]NETPRI-[F:SOP]CPRPRI
            Endif
            Rewrite [SOP]
            If fstat
               Call ECR_TRACE("Error modificando Ped.: "+[F:SOH]SOHNUM+"-"+num$([F:SOP]SOPLIN)+" Art.: "+[F:SOP]ITMREF,1) From GESECRAN
            Else
               Call ECR_TRACE("Ped.:"+[F:SOH]SOHNUM+"-"+num$([F:SOP]SOPLIN)+" Art.: "+[F:SOP]ITMREF+" Pr.vta.: "+num$([F:SOP]NETPRI)+
&                             " UV: "+[F:SOP]SAU+" US: "+[F:SOP]STU+
&                             " Pr.cos: "+num$([F:SOP]CPRPRI)+" Margen: "+num$([F:SOP]PFM)+" C.std.: "+num$(LCOS)+
&                             " "+num$(arr(LCOS*[F:ITM]ZFACTOR,0.0001)),0) From GESECRAN
            Endif
         Endif

      #Endif
   Next
Endif
If [M:ZRGMA]VCRTYP=4
   #4->Entregas
   For [LNK] Where evalue(CRITERIO)
      Raz [F:ITV]
      Read [ITV]ITV0=[F:SDD]ITMREF;[F:SDD]STOFCY
      Raz [F:ITM]
      Read [F:ITM]ITM0=[F:SDD]ITMREF
      If [F:ITM]STOMGTCOD>1
         #Gestionado en stock
         Raz [F:ITC]
         Filter [ITC] Where STOFCY=[F:SDD]STOFCY and ITMREF=[F:SDD]ITMREF and CSTTYP=1 Order By Key ITC0
         Read [ITC]Last
         Filter [ITC]
         LCOS=[F:ITC]CSTTOT

         If LCOS>0
            If [F:SDD]SAU=[F:SDD]STU
               [F:SDD]CPRPRI=LCOS
               [F:SDD]PFM   =[F:SDD]NETPRI-[F:SDD]CPRPRI
            Else
               [F:SDD]CPRPRI=LCOS*[F:ITM]ZFACTOR
               [F:SDD]PFM   =[F:SDD]NETPRI-[F:SDD]CPRPRI
            Endif
            #Rewrite [SDD]
            If fstat
               Call ECR_TRACE("Error modificando Ped.: "+[F:SDH]SDHNUM+"-"+num$([F:SDD]SDDLIN)+" Art.: "+[F:SDD]ITMREF,1) From GESECRAN
            Else
               Call ECR_TRACE("Ent.:"+[F:SDH]SDHNUM+"-"+num$([F:SDD]SDDLIN)+" Art.: "+[F:SDD]ITMREF+" Pr.vta.: "+num$([F:SDD]NETPRI)+
&                             " UV: "+[F:SDD]SAU+" US: "+[F:SDD]STU+
&                             " Pr.cos: "+num$([F:SDD]CPRPRI)+" Margen: "+num$([F:SDD]PFM)+" C.std.: "+num$(LCOS)+
&                             " "+num$(arr(LCOS*[F:ITM]ZFACTOR,0.0001)),0) From GESECRAN
            Endif
         Endif
      Endif
   Next
Endif
If [M:ZRGMA]VCRTYP=5
   #5->Facturas de venta
   For [LNK] Where evalue(CRITERIO)
      Raz [F:ITV]
      Read [ITV]ITV0=[F:SID]ITMREF;[F:SID]STOFCY
      Raz [F:ITM]
      Read [F:ITM]ITM0=[F:SID]ITMREF
      If [F:ITM]STOMGTCOD>1
         #Gestionado en stock
         Raz [F:ITC]
         Filter [ITC] Where STOFCY=[F:SID]SALFCY and ITMREF=[F:SID]ITMREF and CSTTYP=1 Order By Key ITC0
         Read [ITC]ITC0 Last
         Filter [ITC]

         Raz [F:ZIOC]
         Filter [ZIOC] Where ITMREF=[F:SID]ITMREF Order By Key ZIOC0
         Read [ZIOC]ZIOC0 First
         Filter [ZIOC]
         If [M:ZRGMA]TIPPRE=1
            #LCOS=[F:ITC]CSTTOT
            LCOS=[F:ZIOC]PMASI
         Endif
         If [M:ZRGMA]TIPPRE=4
            LCOS=[F:ITV]AVC
         Endif
         If LCOS>0
            If [F:SID]SAU=[F:SID]STU
               [F:SID]CPRPRI=LCOS
               [F:SID]PFM   =[F:SID]NETPRI-[F:SID]CPRPRI
            Else
               [F:SID]CPRPRI=LCOS*[F:ITM]ZFACTOR
               [F:SID]PFM   =[F:SID]NETPRI-[F:SID]CPRPRI
            Endif
            Rewrite [SID]
            If fstat
               Call ECR_TRACE("Error modificando Fra.: "+[F:SIH]NUM+"-"+num$([F:SID]SIDLIN)+" Art.: "+[F:SID]ITMREF,1) From GESECRAN
            Else
               Call ECR_TRACE("Fra.:"+[F:SIH]NUM+"-"+num$([F:SID]SIDLIN)+" Art.: "+[F:SID]ITMREF+" Pr.vta.: "+num$([F:SID]NETPRI)+
&                             " UV: "+[F:SID]SAU+" US: "+[F:SID]STU+
&                             " Pr.cos: "+num$([F:SID]CPRPRI)+" Margen: "+num$([F:SID]PFM)+" C.std.: "+num$(LCOS)+
&                             " "+num$(arr(LCOS*[F:ITM]ZFACTOR,0.0001)),0) From GESECRAN
            Endif
         Endif
      Endif
   Next
Endif
Return

$INIT_DIA_REGMAR
Local Mask ZREGMAR [ZRGMA]
Raz [M:ZRGMA]
[M:ZRGMA]SALFCY = GFCYDEF(0)
[M:ZRGMA]FECSTR = date$
[M:ZRGMA]FECEND = date$
Return

$TERMINE_REGMAR
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

Return

$OK_REGMAR
Raz [M:ZRGMA]
FIN  = 1
Return

$END_REGMAR
Raz [M:ZRGMA]
FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Raz [F:FCY]
Read [FCY]FCY0=VALEUR
[M:ZRGMA]CPY=[F:FCY]LEGCPY
End
