#<AdxTL>@(#)0.0.0.0 $Revision$
#Tratamiento para generacion de fichero interface para comunicacion a Operador Logistico Italia (OLI) de preparacion de pedido.
$ACTION
#Infbox ACTION
Case ACTION
   When "INIT"        : Gosub INIT
   When "CONTROLE"    : Gosub CONTROLE
   When "EXEC"        : Gosub EXEC
   When Default
Endcase
Return

#PARAM(1) - Numero de pedido
#PARAM(2) - Boton pulsado (1-Fichero interface OLI)
$INIT
Local Char NUMDOC(25)
Local Integer TIPFIC
Local Char FICSRV(250), FICCLI(250), NOMFIC(250)
Local Char DIRAPL(250)

#Recuperamos el directorio de la aplicación
DIRAPL=filpath("","","","","",adxmac(0))

NUMDOC=PARAM(1)
TIPFIC=val(PARAM(2))
#Infbox NUMDOC+" "+num$(TIPFIC)

If clalev([F:SOHX])<=0  :  Local File SORDER     [SOHX]  :  Endif
If clalev([F:SOQX])<=0  :  Local File SORDERQ    [SOQX]  :  Endif
If clalev([F:STAX])<=0  :  Local File STOALL     [STAX]  :  Endif
If clalev([F:STOX])<=0  :  Local File STOCK      [STOX]  :  Endif
If clalev([F:ZTDX])<=0  :  Local File ZTEXDOC    [ZTDX]  :  Endif
If clalev([F:BPSX])<=0  :  Local File BPSUPPLIER [BPSX]  :  Endif
If clalev([F:CNTSX])<=0 :  Local File CONTACT    [CNTSX] :  Endif
If clalev([F:BPRX])<=0  :  Local File BPARTNER   [BPRX]  :  Endif
If clalev([F:BPTX])<=0  :  Local File BPCARRIER  [BPTX]  :  Endif
If clalev([F:ICTDX])<=0 :  Local File INCOTERMD  [ICTDX] :  Endif
If clalev([F:CNTX])<=0  :  Local File CONTACT    [CNTX]  :  Endif
If clalev([F:AINX])<=0  :  Local File CONTACTCRM [AINX]  :  Endif
If clalev([F:FCYX])<=0  :  Local File FACILITY   [FCYX]  :  Endif
If clalev([F:CPYX])<=0  :  Local File COMPANY    [CPYX]  :  Endif
If clalev([F:BPAPX])<=0 :  Local File BPADDRESS  [BPAPX] :  Endif : #Direccion planta
If clalev([F:BPACX])<=0 :  Local File BPADDRESS  [BPACX] :  Endif : #Direccion cliente
If clalev([F:CPYX])<=0  :  Local File COMPANY    [CPYX]  :  Endif
If clalev([F:CPYAX])<=0 :  Local File BPADDRESS  [CPYAX] :  Endif : #Direccion empresa
If clalev([F:AUSX])<=0  :  Local File AUTILIS    [AUSX]  :  Endif : #Usuario
Return


$CONTROLE
Local Integer OK, STAT
Local Char BPSOLI(15)
Local Shortint FUNCNT

OK=1

Raz [F:SOHX]
Read [SOHX]SOH0=NUMDOC
If fstat
   Infbox "Problema recuperación datos Pedido. fstat: "+num$(fstat)
   OK=0
Endif
If !OK
   FIN=1
   Return
Endif

If [F:SOHX]CPY<>'002'
#   OK=0
Endif
If !OK
   FIN=1
   Return
Endif

Raz BPSOLI
Call PARAM([F:SOHX]SALFCY,"ZBPSOLI",BPSOLI) From ADOVAL
Read [F:BPSX]BPS0=BPSOLI
If fstat
   Infbox "Problema recuperación datos OLI. fstat: "+num$(fstat)
   OK=0
Endif

#Contacto del operador logístico con la función producción (4)
FUNCNT=4
Raz [F:CNTSX]
Filter [CNTSX] Where BPATYP=1 and BPANUM=[F:BPSX]BPSNUM and CNTFNC=FUNCNT : #CNTFNC:Producción
Read [CNTSX] First
If fstat
   Infbox "Sin contacto en OLI para envio mail. fstat: "+num$(fstat)
Endif
Filter [CNTSX]

Raz [F:BPTX]
Read [BPTX]BPT0=[F:SOHX]BPTNUM
If fstat
   Infbox "Transportista no informado. fstat: "+num$(fstat)
   OK=0
Endif
If len([F:BPTX]ZDIREXP)=0
   #Infbox "Directorio expediciones no informado"
   #OK=0
Endif

If len([F:SOHX]EECICT)=0
   Infbox "Incoterm no informado"
   OK=0
Endif

Raz [F:BPRX]
Read [BPRX]BPR0=[F:SOHX]BPCORD
If fstat
   Infbox "Problema recuperacion datos cliente. fstat: "+num$(fstat)
   OK=0
Endif

Raz [F:CPYX]
Read [CPYX]CPY0=[F:SOHX]CPY
If fstat
   Infbox "Problema recuperacion datos sociedad. fstat: "+num$(fstat)
   OK=0
Endif

#Direccion de la empresa
Raz [F:CPYAX]
Read [CPYAX]BPA0=2;[F:SOHX]CPY
If fstat
   Infbox "Problema recuperacion direccion sociedad. fstat: "+num$(fstat)
   OK=0
Endif


Raz [F:FCYX]
Read [FCYX]FCY0=[F:SOHX]SALFCY
If fstat
   Infbox "Problema recuperacion datos planta. fstat: "+num$(fstat)
   OK=0
Endif

If !OK
   FIN=1
Endif
Return

#TIPFIC -> 1 - FIOLI
$EXEC
Local Integer WRESP
Local Char ASUNTO(80), TEXTO1(80), TEXTO2(80)

#Wrnbox "Continuar? " Using WRESP

#If WRESP<>1
#   Return
#Endif

ASUNTO=mess(2,6120,1)
TEXTO1=mess(5,6120,1)
TEXTO2=mess(6,6120,1)
Case TIPFIC
   When 1  :  Gosub TRT_FIOLI
Endcase
Return

#Generacion fichero expedicion TransSabadell (TSB)
$TRT_FIOLI
Local Char NIFBPC(20), PERCON(100), TELCON(50), TIPPOR(1)
Local Char TKMAILIDIO(5), TKMAIL(120), OBSERV(250)
Local Integer I, LQTYBOB
Local Char LOTAUX(25)

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

Raz NIFBPC
If len([F:BPRX]CRN)<>0
   NIFBPC=[F:BPRX]CRN
Else
   NIFBPC=[F:BPRX]EECNUM
Endif

#Persona de contacto destinatario
Raz PERCON
Raz TELCON
Raz TKMAILIDIO
Raz TKMAIL

Raz [F:CNTX]
Filter [CNTX] Where BPATYP=1 and BPANUM=BPSOLI and CNTFNC=3 : #CNTFNC:Compras
For [CNTX]
    Raz [F:AINX]
    Read [AINX]AIN0=[F:CNTX]CCNCRM
    PERCON=[F:AINX]CNTFNA+" "+[F:AINX]CNTLNA
    TELCON=[F:CNTX]TEL
    TKMAILIDIO=[F:AINX]CNTLAN
    TKMAIL=[F:CNTX]WEB
    Break
Next
Filter [CNTX]

Raz [F:ICTDX]
Read [ICTDX]ICTD0=[F:SOHX]EECICT;6 :#6-Transporte principal (Naturaleza gasto)

Raz TIPPOR
If [F:ICTDX]CSTPYR=2
   #2 -> Comprador
   TIPPOR="D"
Else
   #1,3,4 -> Vendedor
   TIPPOR="P"
Endif

Raz [F:ZTDX]
Read [ZTDX]ZTDOC0=2;[F:SOHX]SOHNUM : #2 -> Pedido venta

#Direccion de la planta
Raz [F:BPAPX]
Read [BPAPX]BPA0=3;[F:SOHX]STOFCY

#Direccion del cliente
Raz [F:BPACX]
Read [BPACX]BPA0=1;[F:SOHX]BPCORD

Raz OBSERV
OBSERV=[F:ZTDX]LINTEX7+" "+[F:ZTDX]LINTEX8+" "+[F:ZTDX]LINTEX9

Call OUVRE_TRACE("Generación fichero OLI ") From LECFIC
Call ECR_TRACE("Generación fichero OLI",0) From GESECRAN

Call ECR_TRACE("Número Pedido: "+NUMDOC,0) From GESECRAN
NOMFIC="OLI_"+NUMDOC+"_"+format$("D:YYYYMMDD",date$)

adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII

Local Char FICORI(255),FICDST(255)
FICORI=filpath("BQT",NOMFIC,"csv")
FICDST=filpath("ZOLPRO",NOMFIC,"csv")
Openo FICORI,0 Using [FIC]

For I=0 To [M:SOH4]NBLIG-1
   Raz [F:SOQX]
   Read [SOQX]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(I);[M:SOH4]SOPLIN(I)
   Filter [STAX] Where ITMREF=[F:SOQX]ITMREF and VCRTYP=2 and VCRNUM=[F:SOQX]SOHNUM and VCRLIN=[F:SOQX]SOPLIN and
&                      VCRSEQ=[F:SOQX]SOQSEQ
   LOTAUX=""
   LQTYBOB=0
   For [STAX]
      Raz [F:STOX]
      Read [STOX]STO0=[F:STAX]STOFCY;[F:STAX]STOCOU
      If LOTAUX<>[F:STOX]LOT
         If LOTAUX<>""
            Gosub GRABAR
#           Wrseq [F:SOHX]SOHNUM,format$(GFMDAT,[F:SOQX]SHIDAT),[F:SOHX]BPDNAM(0),[F:SOHX]BPDADDLIG(0),
#&                 [F:SOHX]BPDCTY,[F:SOHX]BPDPOSCOD,[F:SOHX]BPDCRY,
#&                 [M:SOH4]ITMREF(I)+"-"+num$([M:SOH4]ZANCHO(I))+"-"+num$([M:SOH4]ZMANDRIL(I))+"-"+num$([M:SOH4]ZLONGITUD(I)),LOTAUX,
#&                 num$(LQTYBOB-[M:SOH4]ZDLVQTYBOB(I)),num$([M:SOH4]ALLQTYSTU(I)),
#&                 TKMAIL,TELCON,OBSERV,[F:BPTX]BPTNAM,
#&                 [F:CPYX]CPYNAM,[F:CPYAX]BPAADDLIG(0),
#&                 [F:CPYAX]CTY,[F:CPYAX]POSCOD,[F:CPYAX]CRY Using [FIC]
         Endif
         LOTAUX=[F:STOX]LOT
         LQTYBOB=0
      Endif
      LQTYBOB+=1
   Next
   Filter [STAX]
   If LQTYBOB>0
      Gosub GRABAR
#     Wrseq [F:SOHX]SOHNUM,format$(GFMDAT,[F:SOQX]SHIDAT),[F:SOHX]BPDNAM(0),[F:SOHX]BPDADDLIG(0),
#&           [F:SOHX]BPDCTY,[F:SOHX]BPDPOSCOD,[F:SOHX]BPDCRY,
#&           [M:SOH4]ITMREF(I)+"-"+num$([M:SOH4]ZANCHO(I))+"-"+num$([M:SOH4]ZMANDRIL(I))+"-"+num$([M:SOH4]ZLONGITUD(I)),LOTAUX,
#&           num$(LQTYBOB-[M:SOH4]ZDLVQTYBOB(I)),num$([M:SOH4]ALLQTYSTU(I)),
#&           TKMAIL,TELCON,OBSERV,[F:BPTX]BPTNAM,
#&           [F:CPYX]CPYNAM,[F:CPYAX]BPAADDLIG(0),
#&           [F:CPYAX]CTY,[F:CPYAX]POSCOD,[F:CPYAX]CRY Using [FIC]
   Endif
Next

Openo Using [FIC]

NOMFIC=vireblc(NOMFIC,2)+".csv"

#If GUSER="ADMIN"
#
#Else
Call ENVMAIL([F:SOHX]BPCORD,FUNCNT,ASUNTO,TEXTO1,TEXTO2,NOMFIC)

Update [SOH] Where SOHNUM=[M:SOH0]SOHNUM
&      With ZFOLIGEN=2, ZFOLIFECGEN=date$
If fstat
   Call ECR_TRACE("Error modificando estado OLI pedido. - fstat: "+num$(fstat),1) From GESECRAN
Else
   [M:SOH2]ZFOLIGEN=2
   [M:SOH2]ZFOLIFECGEN=date$
   Affzo [M:SOH2]ZFOLIGEN
   Affzo [M:SOH2]ZFOLIFECGEN
   [F:SOH]ZFOLIGEN=[M:SOH2]ZFOLIGEN
   [F:SOH]ZFOLIFECGEN=[M:SOH2]ZFOLIFECGEN
Endif
#Endif

Call ECR_TRACE("Fin generación fichero expedición OLI ",0) From GESECRAN
Call FERME_TRACE From LECFIC

#FICSRV=DIRAPL+"\"+[F:BPTX]ZDIREXP+"\"+NOMFIC+".TXT"
#FICCLI="C:\TEMP\"+NOMFIC+".TXT"
#Call COPCLI(FICSRV,FICCLI,STAT) From ORDSYS
#  If STAT=1
#   # Fichier non copié sur le poste client
#   #STA = -1 : Call ERREUR(mess(164,141,1)) From GESECRAN
#   Call ECR_TRACE("Fichero no copiado: "+NOMFIC,1) From GESECRAN
#  Endif
Call MOVE (FICORI,FICDST,STAT) From ORDSYS
TRA = 1
Return

$GRABAR
Local Char WLOTE(GLONLOT)
WLOTE=left$(LOTAUX,6)+right$(LOTAUX,10)
If GUSER="ADMIN"
#Infbox "LOTAUX="+LOTAUX+"   WLOTE="+WLOTE
Endif
Wrseq [F:SOHX]SOHNUM+"-"+num$([M:SOH4]SOPLIN(I)),format$(GFMDAT,[F:SOQX]SHIDAT),[F:SOHX]BPDNAM(0),[F:SOHX]BPDADDLIG(0),
&     [F:SOHX]BPDCTY,[F:SOHX]BPDPOSCOD,[F:SOHX]BPDCRY,
&     [M:SOH4]ITMREF(I)+"-"+num$([M:SOH4]ZANCHO(I))+"-"+num$([M:SOH4]ZMANDRIL(I))+"-"+num$([M:SOH4]ZLONGITUD(I)),WLOTE,
&     num$(LQTYBOB-[M:SOH4]ZDLVQTYBOB(I)),num$([M:SOH4]ALLQTYSTU(I)),
&     TKMAIL,TELCON,OBSERV,[F:BPTX]BPTNAM,
&     [F:CPYX]CPYNAM,[F:CPYAX]BPAADDLIG(0),
&     [F:CPYAX]CTY,[F:CPYAX]POSCOD,[F:CPYAX]CRY Using [FIC]
Return


Subprog ENVMAIL(NUMBPR,FUNCNT,ASUNTO,TEXTO1,TEXTO2,FICHADJ)
Value Char NUMBPR()
Value Shortint FUNCNT
Value Char ASUNTO()
Value Char TEXTO1()
Value Char TEXTO2()
Value Char FICHADJ()

Local Integer TYPMES
Local Integer REQREC
Local Integer REQIMP
Local Char    USER(15)
Local Char    MAIL(50)
Local Char    OBJJOI(10)
Local Char    CLEOBJ(80)
Local Char    CHRONO(25)
Local Integer ERD
Local Char    USR_EMAIL(50)(1..5)
Local Integer USR_ENVOI(1..5)
Local Integer USR_SUIVI(1..5)
Local Integer USR_NB
Local Clbfile TEXCLB(5)
Local Char    TEXOBJ(80)
Local Char    PCEJOI(200)(1..5)
Local Integer NBJOI
Local Char    TYPJOI(10)
Local Integer CATJOI
Local Char    CONTXT(50)
Local Char VALCLI(250)

Call PARCLI("ClientRootDir",VALCLI) From GLOBVAR
VALCLI+="rts\temp\"

Filter [CNTSX] Where BPANUM=NUMBPR and BPATYP=1 and CNTFNC=FUNCNT
#Read [CNTSX]CNT0 First
#If fstat or [F:CNTSX]WEB="": Goto NEXT_BPC Endif

TYPMES=2 : #Servidor
USER=GUSER

If [F:CNTSX]WEB<>""
    USR_EMAIL(1)=[F:CNTSX]WEB
    USR_EMAIL(1)="mmarti@globalfilms.es"
    USR_ENVOI(1)=2
    USR_NB=1

    Call ECR_TRACE("Email: "+USR_EMAIL(1),0) From GESECRAN

    Raz [F:AUSX]
    Read [AUSX]CODUSR="OLGA"
    USR_EMAIL(2)=[F:AUSX]ADDEML
    Call ECR_TRACE("Email: "+USR_EMAIL(2),0) From GESECRAN
    USR_ENVOI(2)=3
    USR_NB+=1

    Raz [F:AUSX]
    Read [AUSX]CODUSR="MMART"
    USR_EMAIL(3)=[F:AUSX]ADDEML
    Call ECR_TRACE("Email: "+USR_EMAIL(3),0) From GESECRAN
    USR_ENVOI(3)=3
    USR_NB+=1

    Raz TEXOBJ
    TEXOBJ=ASUNTO+" "+[F:SOH]SOHNUM

    Raz TEXCLB
    TEXCLB=TEXTO1+chr$(13)+chr$(10)
    TEXCLB+=chr$(13)+chr$(10)
    TEXCLB+=mess(7,6120,1)+": "+[F:BPRX]BPRNAM+chr$(13)+chr$(10)+mess(3,6120,1)+": "+[F:SOHX]CUSORDREF+chr$(13)+chr$(10)+mess(4,6120,1)+": "+[F:SOH]SOHNUM+chr$(13)+chr$(10)
    TEXCLB+=chr$(13)+chr$(10)
    TEXCLB+=TEXTO2+chr$(13)+chr$(10)

    If GTYPMES=2
       Case GOS(1)
       When "unix"  : PCEJOI(1) = filpath("BQT","","") + "/" + FICHADJ
       When Default : PCEJOI(1) = filpath("BQT","","") + "\" + FICHADJ
       Endcase
    Else
       PCEJOI(1) = VALCLI + FICHADJ  ##2604
    Endif
    NBJOI=1
    #Infbox USR_EMAIL(1)+" - "+USR_EMAIL(2)
    Call ENVOI_MAIL(TYPMES,REQREC, REQIMP,USER,MAIL,OBJJOI,CLEOBJ,CHRONO,ERD
&                   ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                   ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT) From AWRKMEL
Else
    Call ECR_TRACE("Email Oper. Log. Italia vacio: "+[F:CNTSX]WEB,1) From GESECRAN
Endif
#$NEXT_BPC
End
