#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "SETBOUT"          : Gosub SETBOUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SETBOUT
Local Integer LCON
  Case [M:PKE1]VCRTYP
    When 4
      If [M:PKE1]STOFCY='200'
        For LCON=0 To [M:PKE1]NBLIG
          [M:PKE1]LBLFMT(LCON) = "ZSETICOL"
        Next
      Elsif [M:PKE1]STOFCY='100'
        For LCON=0 To [M:PKE1]NBLIG
          [M:PKE1]LBLFMT(LCON) = "ZSETICOLGF"
        Next
      Endif
  Endcase
  Affzo [M:PKE1]10
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

