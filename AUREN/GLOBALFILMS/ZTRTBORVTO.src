#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso para borrar facturas, vencimientos y asientos de los vtos. traspasados con destino a 431000
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_BOR
  When "TERMINE"        : Gosub TERMINE_BOR
  When "INIT"           : Gosub INIT_DIA_BOR
  When "OK"             : Gosub OK_BOR
  When "END"            : Gosub END_BOR
Endcase
Return

$OUVRE_BATCH
Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Incio borrado vencimientos",0) From GESECRAN
Else
  Call OUVRE_TRACE("Inicio borrado vencimientos") From LECFIC
Endif
Call ECR_TRACE("Borrado",0) From GESECRAN
Call ECR_TRACE("Borrado",-1) From GESECRAN
Call PRTSCR("ZBORVTOS","","",0,1) From ATRTX3
Call ECR_TRACE("Borrado",-1) From GESECRAN
Return

$TRT_INI
If !clalev([HAE])    : Local File GACCENTRY   [HAE] : Endif
If !clalev([DAE])    : Local File GACCENTRYD  [DAE] : Endif
If !clalev([DAA])    : Local File GACCENTRYA  [DAA] : Endif
If !clalev([DUD])    : Local File GACCDUDATE  [DUD] : Endif
If !clalev([HDU])    : Local File HISTODUD    [HDU] : Endif
If !clalev([SVV])    : Local File SVCRVAT     [SVV] : Endif
If !clalev([SIH])    : Local File SINVOICE    [SIH] : Endif
If !clalev([SIL])    : Local File BPCINVLIG   [SIL] : Endif
If !clalev([SIA])    : Local File BPCINVLIGA  [SIA] : Endif
If !clalev([TVD])    : Local File TRCVCRDOC   [TVD] : Endif
Return

$TERMINE_BOR
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif
Return

$INIT_DIA_BOR
Local Mask ZBORVTOS [ZBVTO]
Raz [M:ZBVTO]
[M:ZBVTO]FECVTO = date$
Return

$OK_BOR
FIN  = 1
Return

$END_BOR
Raz [M:ZBVTO]
FIN = 1
Return

$EXEC_BOR
Local Integer I, J, WCONT
Local Char LTYP(5),LNUM(25)
Gosub TRT_INI

If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Incio borrado vencimientos traspaso",0) From GESECRAN
Else
  Call OUVRE_TRACE("Incio borrado vencimientos traspaso") From LECFIC
Endif
Call ECR_TRACE("Borrado vencimientos traspaso",0) From GESECRAN
Call ECR_TRACE("Borrado vencimientos traspaso",-1) From GESECRAN
Call PRTSCR("ZBORVTOS","","",0,1) From ATRTX3
Call ECR_TRACE("Borrado vencimientos traspaso",-1) From GESECRAN

Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM,[DUD]DUD0(2)=[F:DAE]TYP;[F:DAE]NUM As [LNK]
&    Where [DAE]TYP="FCVTO" and [DUD]DUDDAT<=[M:ZBVTO]FECVTO and [DAE]ACC="431000"
&      Order By Key DAE0

Filter [LNK]
For [LNK]
   WCONT+=1
   LTYP=[F:DUD]TYP
   LNUM=[F:DUD]NUM
   Call ECR_TRACE("TYP: "+LTYP+" - "+LNUM+" CUENTA: "+[F:DAE]ACC+" TERCERO: "+[F:DAE]BPR+" FEC.VTO.: "+
&                 format$("DDMMYYYY",[F:DUD]DUDDAT),0) From GESECRAN

   Delete [HAE] Where TYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado asiento [HAE] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [DAE] Where TYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado asiento [DAE] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [DAA] Where TYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado asiento [DAA] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [SIH] Where SIVTYP="FVT" and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado asiento [SIH] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [DUD] Where TYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado vencimiento [DUD] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [HDU] Where TYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado vencimiento [HDU] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [SVV] Where VCRTYP=LTYP and NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado ivas [SVV] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [SIL] Where NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado ivas [SIL] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [SIA] Where NUM=LNUM
   If fstat
      Call ECR_TRACE("Error borrado ivas [SIA] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif
   Delete [TVD] Where TYPVCR=LTYP and NUMVCR=LNUM
   If fstat
      Call ECR_TRACE("Error borrado ivas [TVD] - fstat: "+num$(fstat)+" ASIENTO: "+LNUM,1) From GESECRAN
   Endif

Next
Filter [LNK]
Call ECR_TRACE("Fin borrado vencimientos traspaso",0) From GESECRAN
Call ECR_TRACE("Vtos. procesados: "+num$(WCONT),0) From GESECRAN

Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
