#BEFWRISTJ -> PE de STKLIB
$ACTION
Case ACTION
   When "BEFREWSTJ"     :   Gosub STJ_CALCULOS  : Gosub COMPRUEBA_UBI_STJ
   When "BEFWRISTJ"     :   Gosub STJ_CALCULOS  : Gosub COMPRUEBA_UBI_STJ
   When "BEFWRISTO"     :   Gosub BEFWRISTO     : Gosub COMPRUEBA_UBI_STO
   When "BEFREWSTO"     :   Gosub BEFREWSTO     : Gosub COMPRUEBA_UBI_STO
Endcase
Return

$STJ_CALCULOS
#04.10.16 JLPR-INI
Gosub SACAR_LOT_ORI_STJ
#04.10.16 JLPR-FIN
#Dbgaff
# Calcula Longitud y Factor
Local Decimal WLLONG
Local Decimal WLSUPERF
Local Decimal WLANCHO
Local Decimal WLFACTOR
Local Decimal WLQTYSTU
If [F:STJ]ZANCHO<>0 Then
  WLANCHO=[F:STJ]ZANCHO/1000
  WLQTYSTU=abs([F:STJ]QTYSTU)
  Case [F:STJ]VCRTYP
    When 12: WLLONG=0
    When Default : WLLONG=[F:STJ]ZLONGITUD
   Endcase
   If WLLONG=0
     # Calculamos longitud en funcion del factor
     If [F:STJ]STU="M2" Then
         WLSUPERF=WLQTYSTU
         WLFACTOR=1
     Else
         If [F:STJ]ZFACTOR=0
           If [F:ITM]ZFACTOR<>0 : WLFACTOR=[F:ITM]ZFACTOR
           Else : WLFACTOR=1  : # Factor por Defecto
           Endif
         Else : WLFACTOR=[F:STJ]ZFACTOR
         Endif
         WLSUPERF=WLQTYSTU/WLFACTOR
     Endif
     WLLONG=arr(WLSUPERF/WLANCHO,1)
   Else
     # Calculo Factor
     WLSUPERF=WLANCHO*WLLONG
     If [F:ITM]STU="M2" : WLFACTOR=1
     Else : WLFACTOR=WLQTYSTU/WLSUPERF
     Endif
   Endif
   #Infbox "Longitud: " - num$(WLLONG)
   [F:STJ]ZLONGITUD=arr(WLLONG,1)
   [F:STJ]ZFACTOR=arr(WLFACTOR,0.000001)
Endif
Return



$BEFREWSTO
#04.10.16 JLPR-INI
Gosub SACAR_LOT_ORI_STO
#04.10.16 JLPR-FIN

Local Decimal WLLONG
Local Decimal WLSUPERF
Local Decimal WLANCHO
Local Decimal WLFACTOR
Local Decimal WLLONGSOB
#JLPR 01-02-17 Ańado << or GFONCTION="GESSMO" >> para contemplar posibilidad de que GUSER=ADMIN pueda restar kilos a una bobina mediante "Salida varia"
If GFONCTION="GESPTH" or GFONCTION="GESPTH2" or GFONCTION="GESSMR" or GFONCTION="GESSRH" or GFONCTION="GESSCS" or
&  GFONCTION="GESSOH" or GFONCTION="GESSDH" or (GFONCTION="GESMTK" and [M:STW]TRSTYP=5)  or GFONCTION="GESSMO" or GFONCTION="GESSIS" # 06.333.351
   #Si se trata de una entrada o modificacion del stock por alguna de estas vias no se hace ningun recalculo
   # Recalculo del FACTOR
   WLFACTOR=1
   If [F:ITM]ZFABCOR=2 and [F:STO]ZANCHO<>0  and [F:STO]ZLONGITUD<>0
      If [F:ITM]STU="M2" Then
          WLSUPERF=[F:STO]QTYSTU
      Else
          WLSUPERF=[F:STO]ZANCHO*[F:STO]ZLONGITUD/1000
      Endif
      WLFACTOR=arr([F:STO]QTYSTU/WLSUPERF,0.000001)
   Endif
   [F:STO]ZFACTOR=WLFACTOR
   Return
Endif
If GFONCTION="GESMTK" and [M:STW]TRSTYP=6 and [F:ITM]ZFABCOR=2
  If !clalev([F:ZMLX]) : Local File ZMFGLOT [ZMLX] : Endif
  Raz [F:ZMLX]
# Filter [F:ZMLX] Where STOFCY=[F:STO]STOFCY and MFGNUM=[M:STW]VCRNUMORI and STOCOU=[F:STO]STOCOU
  Filter [F:ZMLX] Where STOFCY=[F:STO]STOFCY and MFGNUM=[M:STW]VCRNUMORI and ITMREF=[F:STO]ITMREF and LOT=[F:STO]LOT and SLO=[F:STO]SLO
  Raz [F:ZMLX]
  #JLPR 29-11-16
  If GACTION="SAISTOSORM"
    # Si anulamos un seguimiento, hemos de ańadir la longitud de la OF como resultado de BOBINA-SOBRANTE
    WLLONGSOB=0
    For [F:ZMLX]
        WLLONGSOB=[F:STO]ZLONGITUD + ([F:ZMLX]ZLONGITUD-[F:ZMLX]ZLONGSOB)
       Break
    Next
  Else
    # solo recalculo longitud en seguimientos Y SALIDAS DE OF
    # Busco si el lote tiene longitud sobrante
    WLLONGSOB=0
    For [F:ZMLX]
       If [F:ZMLX]ZSOBRANTE=2
          WLLONGSOB=[F:ZMLX]ZLONGSOB
       Endif
       Break
    Next
  Endif
  Filter [ZMLX]
  # Recalculo
  If WLLONGSOB >0
    #JLPR 26-01-17 Comento lineas pues:
    #  1ş) El factor debe ser el mismo, no tiene porque cambiar
    #  2ş) Pero además, el cálculo no es correcto, pues habria que restar a [F:STO]QTYSTU los kilos correspondientes del sobrante, de lo contrario se dividen los Kgs totales entre la superficie
    #      sobrante, dando lugar a un factor MAYOR
   [F:STO]ZLONGITUD=WLLONGSOB
    #If [F:ITM]ZFABCOR=2 and [F:STO]ZANCHO<>0  and [F:STO]ZLONGITUD<>0 and [F:STO]QTYSTU<>0
       #If [F:ITM]STU="M2" Then
       #    WLSUPERF=[F:STO]QTYSTU
       #Else
       #    WLSUPERF=[F:STO]ZANCHO*WLLONGSOB/1000
       #Endif
       #WLFACTOR=arr([F:STO]QTYSTU/WLSUPERF,0.000001)
       #[F:STO]ZLONGITUD=WLLONGSOB
       #[F:STO]ZFACTOR=WLFACTOR
    #Endif
  Endif
Endif
Return

# FJCP Comentado - Nuevo procedimiento para buscar la longitud sobrante del lote y recalcular factor.

