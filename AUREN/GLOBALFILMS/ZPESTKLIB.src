# Else
#  If [F:ITM]ZFABCOR=2 and [F:STO]ZANCHO<>0 and [F:ITM]ZFACTOR<>0
#   #WLANCHO=val([F:STO]PALNUM)/1000
#   WLANCHO=[F:STO]ZANCHO/1000
#   If WLANCHO=0 : WLANCHO=0.001 : Endif
#  # Calculamos loongitud
#     If [F:ITM]STU="M2" Then
#         WLSUPERF=[F:STO]QTYSTU
#         WLFACTOR=1
#     Else
#         If [F:ITM]ZFACTOR<>0
