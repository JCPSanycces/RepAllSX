#Local Char LOT(GLONLOT),SLOT(GLONSLO),LOTORIP(GLONSLO)
## Saco lotes y sublotes del GC...puede haber mas de uno por los empalmes....Mostramos el 1ş
#Call LOTE_ORIGEN([F:STJ]VCRNUMORI,[F:STJ]VCRLINORI,[F:STJ]STOFCY,0,LOT,SLOT,LOTORIP) From SPESLP
##
#[F:STJ]ZLOTORI=LOTORIP
#Return

Funprog LOTEORIGEN_BOBINAMADRE(LFCY,LITMREF,LLOT)
#Devuelve Lote origen asumiendo que este se ha ido traspasando desde el inicio
Value Char LFCY
Value Char LITMREF
Value Char LLOT
Local Char LLOTORI(GLONLOT)

Raz LLOTORI
If clalev([F:STJX])<=0 : Local File STOJOU [STJX] : Endif
If clalev([F:STOX])<=0 : Local File STOCK  [STOX] : Endif

Raz [F:STOX]
Filter [STOX] Where STOFCY=LFCY and ITMREF=LITMREF and LOT=LLOT and len(ZLOTORI)>0 and ZLOTORI<>"###"
Read [STOX] First
If fstat=0
   LLOTORI=[F:STOX]ZLOTORI
Else
   Filter [STJX] Where STOFCY=LFCY and ITMREF=LITMREF and LOT=LLOT and len(ZLOTORI)>0 and ZLOTORI<>"###"
   # 06.333.351.ini
   If GFONCTION="GESSIS"
    Filter [STJX] Where ITMREF=LITMREF and LOT=LLOT and len(ZLOTORI)>0 and ZLOTORI<>"###"
   Endif
   # 06.333.351.fin
   Read [STJX] First
   If fstat=0
     LLOTORI=[F:STJX]ZLOTORI
  Else
     LLOTORI="###"
  Endif
Endif
End LLOTORI

$SACAR_LOT_ORI_STJ
 If [F:STJ]VCRTYP=6
    #Recepcion               =>   Lote origen = lote recepcion
    [F:STJ]ZLOTORI=[F:STJ]LOT
 Elsif [F:STJ]VCRTYP=15
    #Declaracion produccion  =>   Lote origen = lote origen de MateriaPrima usada
    Local Char LOTP(GLONLOT),SLOTP(GLONSLO),LOTORIP(GLONLOT)
    # Saco lotes y sublotes del GC...puede haber mas de uno por los empalmes....Mostramos el 1ş
    Call LOTE_ORIGEN([F:STJ]VCRNUMORI,[F:STJ]VCRLINORI,[F:STJ]STOFCY,0,LOTP,SLOTP,LOTORIP) From SPESLP
    [F:STJ]ZLOTORI=LOTORIP
 Else
    #Resto de casos          =>   Lote origen = lote origen de lote usado
    [F:STJ]ZLOTORI=func ZPESTKLIB.LOTEORIGEN_BOBINAMADRE([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT)
 Endif
Return

$SACAR_LOT_ORI_STO
 If GFONCTION="GESPTH" or GFONCTION="GESPTH2"
    #Recepcion               =>   Lote origen = lote recepcion
    [F:STO]ZLOTORI=[F:STO]LOT
 Elsif GFONCTION="GESMTK" and [M:STW]TRSTYP=5  #[M:STW]VCRTYP=15
    #Declaracion produccion  =>   Lote origen = lote origen de MateriaPrima usada
    Local Char LOTP(GLONLOT),SLOTP(GLONSLO),LOTORIP(GLONLOT)
    # Saco lotes y sublotes del GC...puede haber mas de uno por los empalmes....Mostramos el 1ş
    Call LOTE_ORIGEN([M:STW]VCRNUMORI,[M:STW]VCRLINORI,[F:STO]STOFCY,0,LOTP,SLOTP,LOTORIP) From SPESLP
    If LOTORIP<>""
      [F:STO]ZLOTORI=LOTORIP
    Endif
 Else
    #Resto de casos          =>   Lote origen = lote origen de lote usado
    LOTORIP=func ZPESTKLIB.LOTEORIGEN_BOBINAMADRE([F:STO]STOFCY,[F:STO]ITMREF,[F:STO]LOT)
    If LOTORIP<>""
      [F:STO]ZLOTORI=LOTORIP
    Endif
 Endif
Return

#**
#* MA - 20181204
#* Comprobar que la LOCTYP y WRH sean iguales y corresponen a la ubicación en tabla STOCK
#*!
$COMPRUEBA_UBI_STO

# reescribir esos valores
If !clalev([ZLOC]) : Local File STOLOC [ZLOC] : Endif
Read [ZLOC]STC0 = [F:STO]STOFCY;[F:STO]LOC
If !fstat Then
  [F:STO]LOCTYP = [ZLOC]LOCTYP
  [F:STO]WRH    = [ZLOC]WRH
Endif
Close Local File [ZLOC]

Return

#**
#* MA - 20181204
#* Comprobar que la WRH sean iguales y corresponen a la ubicación en tabla STOJOU
#*!
$COMPRUEBA_UBI_STJ

# reescribir esos valores
If !clalev([ZLOC]) : Local File STOLOC [ZLOC] : Endif
Read [ZLOC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
If !fstat Then
  [F:STJ]WRH    = [ZLOC]WRH
Endif
Close Local File [ZLOC]

Return
