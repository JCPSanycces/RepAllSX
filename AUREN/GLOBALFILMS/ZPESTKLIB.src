#Endif
#Return

$BEFWRISTO
#04.10.16 JLPR-INI
Gosub SACAR_LOT_ORI_STO
#04.10.16 JLPR-FIN

Local Decimal WLLONG
Local Decimal WLSUPERF
Local Decimal WLANCHO
Local Decimal WLFACTOR
If GFONCTION="GESPTH" or GFONCTION="GESPTH2" or GFONCTION="GESSMR" or GFONCTION="GESSRH" or GFONCTION="GESSCS" or
&  GFONCTION="GESSOH" or GFONCTION="GESSDH" or (GFONCTION="GESMTK" and [M:STW]TRSTYP=5) # 06.333.351
   #Si se trata de una entrada o modificacion del stock por alguna de estas vias no se hace ningun recalculo
   # Recalculo del FACTOR
   WLFACTOR=1
   If [F:ITM]ZFABCOR=2 and [F:STO]ZANCHO<>0  and [F:STO]ZLONGITUD<>0
      If [F:ITM]STU="M2" Then
          WLSUPERF=[F:STO]QTYSTU
      Else
          WLSUPERF=[F:STO]ZANCHO*[F:STO]ZLONGITUD/1000
      Endif
      WLFACTOR=arr([F:STO]QTYSTU/WLSUPERF,0.000001)
   Endif
   [F:STO]ZFACTOR=WLFACTOR
   Return
Endif
If [F:ITM]ZFABCOR=2 and [F:STO]ZANCHO<>0 Then
  WLLONG=0
  WLANCHO=0
 # WLANCHO=val([F:STO]PALNUM)/1000
   WLANCHO=[F:STO]ZANCHO/1000
  #[F:STO]ZMANDRIL=val([F:STO]CTRNUM)
       # When 2 : WLANCHO=[F:SOQ]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:SOQ]ZMANDRIL :[F:STO]ZPROVEEDOR=[F:SOQ]ZPROVEEDOR
       # When 4 : WLANCHO=[F:SDD]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:SDD]ZMANDRIL :[F:STO]ZPROVEEDOR=[F:SDD]ZPROVEEDOR
       # When 12 : WLANCHO=[F:MKM]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:MKM]ZMANDRIL

  Case [M:STW]VCRTYP
      When 6  : WLLONG=[F:PTD]ZLONGITUD : WLANCHO=[F:PTD]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:PTD]ZMANDRIL
              [F:STO]ZPROVEEDOR=[F:PTD]ZPROVEEDOR
      When 13 : WLLONG=[F:SRD]ZLONGITUD : WLANCHO=[F:SRD]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:SRD]ZMANDRIL
      When 15 : WLLONG=[F:MKI]ZLONGITUD : WLANCHO=[F:MKI]ZANCHO/1000 : [F:STO]ZMANDRIL=[F:MKI]ZMANDRIL
                [F:STO]ZPROVEEDOR=[F:MKI]ZPROVEEDOR : [F:STO]ZNCORTES=[F:MKI]ZNCORTES
      When Default
   Endcase
   If WLANCHO=0
    WLANCHO=0.001
   Endif
   If WLLONG=0
     # Calculamos longitud
     If [F:ITM]STU="M2" Then
         WLSUPERF=[F:STO]QTYSTU
         WLFACTOR=1
     Else
         If [F:ITM]ZFACTOR<>0
            WLFACTOR=[F:ITM]ZFACTOR
         Else
            WLFACTOR=1  # Factor por Defecto
         Endif
         WLSUPERF=[F:STO]QTYSTU/WLFACTOR
     Endif
     WLLONG=arr(WLSUPERF/WLANCHO,1)
   Endif
   WLSUPERF=WLANCHO*WLLONG
   If WLSUPERF>0
     If [F:ITM]STU="M2" Then
       WLFACTOR=1
     Else
       WLFACTOR=[F:STO]QTYSTU/WLSUPERF
     Endif
   Endif
   #Infbox "Longitud: " - num$(WLLONG)
   [F:STO]ZLONGITUD=arr(WLLONG,1)
   [F:STO]ZANCHO=arr(WLANCHO*1000,1)  : # Paso a mm
   [F:STO]ZFACTOR=arr(WLFACTOR,0.000001)
Endif
Return

$OBTENER_DATOSLOTE
Return

