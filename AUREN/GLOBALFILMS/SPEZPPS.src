## Después de modificar el campo 'Nş semanas' (pantalla ZCONSPPS1) 17/11/2022 12:36:51 (ADMIN)
######################################################################################
Subprog AM_ZNUMSEM(VALEUR)
Variable Decimal VALEUR
  [M:ZPPS1]ZDUDDATFIN = gdat$(day([M:ZPPS1]ZDUDDATINI)+VALEUR*7,month([M:ZPPS1]ZDUDDATINI),year([M:ZPPS1]ZDUDDATINI))
  Affzo [M:ZPPS1]ZDUDDATFIN
End

