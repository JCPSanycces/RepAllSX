#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox "SUBZCNTR: "+ACTION
#If dim([M:ZCNTR3]NBLIG2)>0
   #Infbox ACTION+" "+num$([M:ZCNTR3]NBLIG2)
#Endif
Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "FILTRE"     : Gosub FILTRE
   When "CREATION"   : Gosub CREATION
   When "APRES_CRE"  : Gosub APRES_CRE
   When "LIENS"      : Gosub LIENS
   When "MODIF"      : Gosub MODIF
   When "APRES_MOD"  : Gosub APRES_MOD
   When "ANNULE"     : Gosub ANNULE
   When "DEFLIG"     : Gosub DEFLIG
   When "INICRE_LIG" : Gosub INICRE_LIG
   When "INIMOD_LIG" : Gosub INICRE_LIG
   When "INICRE"     : Gosub INICRE
   When "SETBOUT"    : Gosub SETBOUT
   When "EXEBOUT"    : Gosub EXEBOUT
   When "FIN_ACTION" : Gosub FIN_ACTION
   When "LIENS_LIG"  : Gosub LIENS_LIG
Endcase
Return

$OUVRE
Gosub DECLARE From TABLEAUX
Return

$FILTRE
Default File [ZBPCRH]
Return

$CREATION
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
Return

$APRES_CRE
Gosub LIENS From TABLEAUX
If GOK < 1 : Return : Endif
Return

$LIENS
Gosub LIENS From TABLEAUX
Return

$MODIF
Gosub MODIF From TABLEAUX
If GOK < 1 : Return : Endif
Return

$APRES_MOD
Gosub LIENS From TABLEAUX
Return

$ANNULE
Gosub ANNULE From TABLEAUX
If GOK < 1 : Return : Endif
Return

##############################################################################
$DEFLIG
#--------------------------------------#
# Definici¾n del fichero de lĒneas     #
# CRIT = Criterio de lectura           #
# FICLIG = Nombre del fichero          #
# ABLIG  = Abreviatura del fichero     #
# ZONLIG = Campo n·mero de lĒnea       #
#--------------------------------------#
 Default Mask [ZBPCR1]
 Default File [ZBPCRD]
 CRIT   = '[F:ZBPCRD]BPCNUM="'+[M:ZBPCR0]BPCNUM+'" & [F:ZBPCRD]ITMREF="'+[M:ZBPCR0]ITMREF+'"'
 FICLIG = "ZBPCREFD"
 ABLIG  = "ZBPCRD"
 ZONLIG = "LINEA"
Return
###############################################################################
$INICRE_LIG
[F:ZBPCRD]BPCNUM = [M:ZBPCR0]BPCNUM
[F:ZBPCRD]ITMREF = [M:ZBPCR0]ITMREF
Return

$INICRE
Return
$INICRE2
Local Char NUMERO(25)
Local Integer STAT

If len(GFCYDEF)=0
   Infbox "Sin planta asignada"
   GOK = 0 : Return
Endif
Call NUMERO ("ZCNTR",GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
If STAT = 0
   [F:ZCNTR]NUMCNTR = NUMERO
Else
   GOK = 0 : Return
Endif
[M:ZCNTR0]NUMCNTR=[F:ZCNTR]NUMCNTR
Affzo [M:ZCNTR0]NUMCNTR
Return

$SETBOUT
Return

$EXEBOUT
Return

$FIN_ACTION
Return

$LIENS_LIG
Return
