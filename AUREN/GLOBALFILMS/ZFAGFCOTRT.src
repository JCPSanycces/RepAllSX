#<AdxTL>@(#)0.0.0.0 $Revision$
# ZFAG - Facturacion Comisiones Agencia
# Facturacion
# FJCP 05/09/2016

$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub INIT
  When "INIT"          : Gosub INIT
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
  When "INIT_DIA"           : Gosub INIT_DIA
  When "OK"             : Gosub OK
  When "END"            : Gosub FIN
Endcase
Return


$INIT
If clalev([F:ZFALQ])<=0 : Local File ZFAGLIQCOM   [ZFALQ] : Endif
If clalev([F:SIH])<=0 : Local File SINVOICE    [SIH] : Endif
If clalev([F:BPC])<=0 : Local File BPCUSTOMER    [BPC] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY [FCY] : Endif
Return

$EXEC
Local Integer NASI
Local Char    BORNUM(20), MESSA(80)
Local Integer STAT
# Variables para determinar la tasa
Local Char WTASA(5)

Default Mask [M:ZFAGF]

Local Char CRITERIO(250)
Local Char WREPRES(20)  # Variable
Local Char WCAB(1)
Local Char WNFICH(250), WMSG(250)

#Local Integer OK
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Facturacion Comisiones Agencia",0) From GESECRAN
Else
  Call OUVRE_TRACE("Facturacion Comisiones Agencias") From LECFIC
Endif
Call ECR_TRACE("Facturacion Comisiones Agencias",0) From GESECRAN
Call ECR_TRACE("-------------------------------",0) From GESECRAN

Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZFAGCP","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

# Montar criterio busqueda sobre liquidaciones
# pendientes de facturar

CRITERIO='[F:ZFALQ]FACTUR=1'
If [M:ZFAGF]FCY<>''
   CRITERIO+=' & [F:ZFALQ]FCY="'+[M:ZFAGF]FCY+'"'
Endif
If [M:ZFAGF]BPCREP<>''
   CRITERIO+=' & [F:ZFALQ]BPCREP>="'+[M:ZFAGF]BPCREP+'"'
Endif
If [M:ZFAGF]BPCREPH<>''
   CRITERIO+=' & [F:ZFALQ]BPCREP<="'+[M:ZFAGF]BPCREPH+'"'
Endif

If [M:ZFAGF]ACCDAT<>[0/0/0]
   CRITERIO+=' & [F:ZFALQ]ACCDAT>=[M:ZFAGF]ACCDAT'
Endif
If [M:ZFAGF]ACCDATH<>[0/0/0]
   CRITERIO+=' & [F:ZFALQ]ACCDAT<=[M:ZFAGF]ACCDATH'
Endif
#Infbox CRITERIO

# Bucle agrupado Representada, Fecha Liquidacion
Filter [F:ZFALQ] Where evalue(CRITERIO)

For [F:ZFALQ]ZFALQ1(3)
   Call ECR_TRACE("Representada: " - [F:ZFALQ]BPCREP,0) From GESECRAN

   # Genera fichero importacion
   # Nombre Fichero
   WNFICH = "XFRT"+ num$(timestamp$) # Nombre del fichero
   Openo filpath("tmp",WNFICH,""),0 Using [ZFIC]
   #
   WCAB="1"
   For [F:ZFALQ]ZFALQ1
      Call ECR_TRACE("Documento Origen: " - [F:ZFALQ]DOCORG + "/" + num$([F:ZFALQ]NUMLIQ),0) From GESECRAN
      If WCAB="1" Then

         # Genera cabecera
         Gosub ZFIC_GENCAB
         WCAB="0"
      Endif
      # Genera Linea
      Gosub ZFIC_GENLIN
   Next
   Openo Using [ZFIC]
   # importación Sileciosa
   # Lanzamos importación
   Call IMPORTSIL("ZFAGBIC",filpath("tmp",WNFICH,"")) From GIMPOBJ
    # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
    If filinfo(filpath("ZIMPEXP/ERRIMP",WNFICH,".err"),0) > 0 Then
      WMSG= "Errores en importacion del fichero: " + WNFICH
      Call ERREURT(WMSG,1) From GESECRAN   #0-Informativo, 1-Error
      Return
    Endif
Next
# Fin Bucle


If NASI>0
   Call ECR_TRACE("-------------------------------",0) From GESECRAN
   Call ECR_TRACE(" \"+num$(NASI)-"Facturas Generadas",0) From GESECRAN
Endif
TRA=1
Return

$ZFIC_GENCAB

# Leer Cliente
Raz [F:BPC]
Read [F:BPC]BPC0=[F:ZFALQ]BPCREP

# Leer Planta
Raz [F:FCY]
Read [F:FCY]FCY0=[F:ZFALQ]FCY

# Determinar Tasa
WTASA=func GET_TASA([F:FCY]LEG,[F:FCY]LEGCPY,[F:BPC]VACBPR,"NOR")

Wrseq "T"; Using [ZFIC]                     # Ident Registro
Wrseq ";"; Using [ZFIC]
Wrseq "FAC"; Using [ZFIC]                   # Tipo Factura
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]                      # Numero
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]BPCREP; Using [ZFIC]         # Cliente
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]FCY; Using [ZFIC]            # Planta
Wrseq ";"; Using [ZFIC]
Wrseq format$("YYYYMMDD",[M:ZFAGF]ACCDATH); Using [ZFIC]        # Fecha
Wrseq ";"; Using [ZFIC]
Wrseq "EUR"; Using [ZFIC]                   # Moneda
Wrseq ";"; Using [ZFIC]
Wrseq "1"; Using [ZFIC]                     # Tipo de cambio
Wrseq ";"; Using [ZFIC]
Wrseq chr$(13) Using [ZFIC]                 # Fin Registro
Return

$ZFIC_GENLIN
# Detalle Factura
Wrseq "D"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "1"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]FCY; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "SPA"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "430900"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]BPCREP; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq num$([F:ZFALQ]IMPORTE); Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq WTASA; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]DESCRI; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq [F:ZFALQ]DOCORG; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq num$([F:ZFALQ]NUMLIQ); Using [ZFIC]
Wrseq chr$(13) Using [ZFIC]                 # Fin Registro


## Detalle Analitico


Wrseq "A"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "1"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "PRD"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "CLI"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "PRV"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "UDN"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq "AUX"; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq ""; Using [ZFIC]
Wrseq ";"; Using [ZFIC]
Wrseq num$([F:ZFALQ]IMPORTE); Using [ZFIC]
Wrseq chr$(13) Using [ZFIC]                 # Fin Registro
Return

Funprog GET_TASA(WLEG,WGRP,WREG,WNIV)
Value Char WLEG,WGRP,WREG,WNIV
Local Char WTASA(10)

WTASA=""

Local File TABVAC [TVC]

   Filter [F:TVC] Where LEG = WLEG & GRP=WGRP & VACBPR=WREG & VACITM=WNIV & ENAFLG=2 & VATTYP=1
   For [F:TVC]
      WTASA=[F:TVC]VAT
      Break
   Next
   Filter [F:TVC]
   If WTASA=""
      Filter [F:TVC] Where LEG = WLEG & GRP="" & VACBPR=WREG & VACITM=WNIV & ENAFLG=2 & VATTYP=1
      For [F:TVC]
         WTASA=[F:TVC]VAT
         Break
      Next
      Filter [F:TVC]
   Endif

LogicClose File [TVC]
End WTASA


$INIT_DIA
Local Mask ZFAGFC [ZFAGF]
Raz [M:ZFAGF]
[M:ZFAGF]FCY = GFCYDEF(0)
Return

$TERMINE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

Return

$OK
Raz [M:ZFAGF]
FIN  = 1
Return

$FIN
Raz [M:ZFAGF]
FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
