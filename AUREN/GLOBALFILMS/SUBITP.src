Funprog CHECK_PIO_ON_SCRN(PNUM) # Issue X3-96018 - 2018-06-14 by APL
    Value Decimal PNUM
    Local Integer OK : OK = [V]CST_AYES
    Local Integer J,J
    J = sigma(I=0,[M:ITP]NBITP-1,([M]PIO(I)=PNUM)*([M]BPSNUM(I) <> [M:ITP]XBPSNUM))
    If J
       Call OUINON(mess(698,199,1),OK) From GESECRAN
    Endif
  End [L]OK

# Issue X3-116274 - 2018-11-09 by SR : Control not more than 99 (possible in Import)
######################################################################################
Subprog C_XPIO(VALEUR)
Variable Decimal VALEUR
If VALEUR > 99 : GMESSAGE = mess(357,199,1) : mkstat = 2 : End : Endif
End


