Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
If [F:BPR]BPRNUM<>VALEUR
    Read [BPR]BPR0=VALEUR
    If fstat Raz [F:BPR] : Endif
Endif
[M]XBETFCY=[F:BPR]BETFCY
[M]BETFCY([M]XNUMLIG)=[M]XBETFCY
Affzo [M]XBETFCY
End

Subprog AS_XPUUSTUCOE(VALEUR)
Variable Decimal  VALEUR
If [M:ITM3]PUU = [M]XPUU & VALEUR = 0
    VALEUR = [M:ITM3]PUUSTUCOE
Endif
Call COEFCNV([M]XPUU,[M:ITM3]STU,VALEUR) From SUBITM
# ATTENTION SI MKSTAT VAUT 2 LE COEFF N'EST PAS SAISI ET L'AM_ PAS FAIT !!!

If mkstat = 2 [M]IPUUSTUCOE([M]XNUMLIG) = VALEUR : Endif
End

Subprog C_XPUUSTUCOE(VALEUR)
Variable Decimal  VALEUR
If [M]XPUU <> "" & VALEUR = 0
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
#If [M:ITM3]PUU = [M]XPUU & VALEUR <>[M:ITM3]PUUSTUCOE
#    VALEUR = [M:ITM3]PUUSTUCOE  # forcer la mÍme valeur que dans ITM3 (140)
#Endif
End

Subprog AS_XPCUPUUCOE(VALEUR)
Variable Decimal  VALEUR
Local Integer J
Call COEFCNV([M]XPCU,[M]XPUU,VALEUR) From SUBITM
# si l'UC est parmi les UC de l'article : voir si elle est modifiable v 140
If dim([M:ITM3]PCU)>0
  J = find([M]XPCU,[M:ITM3]PCU(0.. dim([M:ITM3]PCU)-1))
  If J > 0
    ##VALEUR = [M:ITM3]PCUSTUCOE(J-1) / [M]XPUUSTUCOE #dÈjý mise par AM_XPCU
    If [M:ITM3]DACPCUCOE(J-1) < 2
      mkstat = 2 # non modifiable
    Endif
  Endif
Endif

If mkstat = 2 [M]IPCUPUUCOE([M]XNUMLIG) = VALEUR : Endif
End

Subprog C_XPCUPUUCOE(VALEUR)
Variable Decimal  VALEUR
If [M]XPCU <> "" & VALEUR =0
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
End

