#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FILTRE" : Gosub FILTRE
 When "LIENS"  : Gosub LIENS
 When Default
Endcase
Return

# MHB 30/10/08 : ce filtre sert lorsqu'on vient de la fiche fournisseur, bouton "Articles-Fournisseurs"
# Cela permet de filtrer sur le fournisseur, qui n'est qu'en 2nde position dans la clÈ 0 de la table ITMBPS
$FILTRE
  If CLE2<>"" and CLE1="" Then
    CRITERE = "BPSNUM='" + CLE2 + "'"
  Endif
Return

# MHB 04/11/08 : renseignement de ces zones qui ne font pas partie des champs de la table ITMBPS
$LIENS
  If clalev([M:ITPB]) Then
    [M:ITPB]QUALIB  = mess(714,197,1)
    # Issue X3-126315 - 2019-02-19 by SR :
    #[M:ITPB]WTEX    = 2
    #If [M:ITPB]TEX  = "" Then [M:ITPB]WTEX = 1 Endif
    [M:ITPB]WTEXFLG    = 2
    If [M:ITPB]TEX  = "" Then [M:ITPB]WTEXFLG = 1 Endif
    # End issue X3-126315

    If clalev([F:BPRP])=0 : Local File BPARTNER [BPRP] : Endif
    # Issue X3-55891/X3-110788 - 2018-10-03 by SR :
#    Read [BPRP]BPR0=[M:ITPB]XBPSNUM                  # hcb 95177
#    [M:ITPB]BETFCY     = [F:BPRP]BETFCY
#    [M:ITPB]XBPSNUM    = [M:ITPB]XBPSNUM             # hcb 95177
#    [M:ITPB]XDESBPSNUM = [F:BPRP]BPRNAM(0)
    If clalev([M:BPS0]) > 0
     Read [BPRP]BPR0=[M:BPS0]BPSNUM
     [M:ITPB]BETFCY     = [F:BPRP]BETFCY
     [M:ITPB]XBPSNUM    = [M:BPS0]BPSNUM
     [M:ITPB]XDESBPSNUM = [F:BPRP]BPRNAM(0)
     [M:ITPB]CUR        = GCUR #Issue X3-114255 - 2018-10-24 by APL
    Endif
  Endif
Return

$CHARGE_ITP
# Chargement des zones ý saisir
######If [M:ITP]NBITP > 0 (otÈ le 22/12/99 : empechait l'effacemt lors des suppressions de lignes)

 If [M:ITP]ITPQUAFLG(NOL) = 0
    [M:ITP]ITPQUAFLG(NOL) = [F:ITG]QUAFLG
 Endif
 If [M:ITP]ITPQLYCRD(NOL) = ""
    [M:ITP]ITPQLYCRD(NOL) = [F:ITG]QLYCRD
 Endif
 [M:ITP]XBPSNUM            = [M:ITP]BPSNUM(NOL)
 [M:ITP]XDESBPSNUM         = [M:ITP]DESBPSNUM(NOL)
 [M:ITP]XITMREFBPS         = [M:ITP]ITMREFBPS(NOL)
 [M:ITP]XITMDESBPS         = [M:ITP]ITMDESBPS(NOL)
 [M:ITP]XEANCODBPS         = [M:ITP]EANCODBPS(NOL)
 [M:ITP]XDOUFLG            = [M:ITP]DOUFLG(NOL)
 [M:ITP]XPURMINQTY         = [M:ITP]PURMINQTY(NOL)
 [M:ITP]XCPRCOE            = [M:ITP]CPRCOE(NOL)
 [M:ITP]XCPRAMT            = [M:ITP]CPRAMT(NOL)       #70985 frais approche
 [M:ITP]XSTCNUM            = [M:ITP]STCNUM(NOL)       #84130 landed cost SDC
 [M:ITP]XQLYMRK            = [M:ITP]QLYMRK(NOL)
 [M:ITP]XQUAFLG            = [M:ITP]ITPQUAFLG(NOL)
 [M:ITP]XQLYCRD            = [M:ITP]ITPQLYCRD(NOL)    # V6CQ
 [M:ITP]XQUAFRY            = [M:ITP]ITPQUAFRY(NOL)    # V6CQ
 [M:ITP]XQUANUM            = [M:ITP]ITPQUANUM(NOL)    # V6CQ
 If GREP ="D"
    Raz   [M:ITP]XQUANUM
 Endif
 If dim([M:ITP]XEECINCRAT)>0
  [M:ITP]XEECINCRAT  = [M:ITP]EECINCRAT(NOL)
 Endif
 If [M:ITP]ITPPUU(NOL)     = ""
    [M:ITP]ITPPUU(NOL)     = [M:ITM3]PUU # sert d'initialisation
    [M:ITP]IPUUSTUCOE(NOL) = [M:ITM3]PUUSTUCOE    # hcb 64488
 Endif

 [M:ITP]XMATTOL            = [M:ITP]ITPMATTOL(NOL)  # Three Way Matching
 [M:ITP]XPUU               = [M:ITP]ITPPUU(NOL)
 [M:ITP]XPUUSTUCOE         = [M:ITP]IPUUSTUCOE(NOL)
 [M:ITP]XPCU               = [M:ITP]ITPPCU(NOL)
 If dim([M:ITP]XLOAECCFLG)>0                          # hcb 71276
    [M:ITP]XLOAECCFLG      = [M:ITP]LOAECCFLG(NOL)
 Endif
 [M:ITP]XPCUPUUCOE         = [M:ITP]IPCUPUUCOE(NOL)
 [M:ITP]XBOMALT            = [M:ITP]BOMALT(NOL)   : # ajout V6 sous-traitance
 [M:ITP]XSCOLTI            = [M:ITP]SCOLTI(NOL)   : # ajout V6 sous-traitance
 If [M:ITP]CTMBPSFLG(NOL)=0 : [M:ITP]CTMBPSFLG(NOL)=1 : Endif
 [M:ITP]XCTMBPSFLG         = [M:ITP]CTMBPSFLG(NOL)
 [M:ITP]XTEX               = [M:ITP]TEX(NOL)
 [M:ITP]XPIO               = [M:ITP]PIO(NOL)
 # Issue X3-126315 - 2019-02-19 by SR :
 #[M:ITP]WTEX = 2
 #If [M:ITP]XTEX = "" [M:ITP]WTEX = 1 Endif
 [M:ITP]WTEXFLG = 2
 If [M:ITP]XTEX = "" [M:ITP]WTEXFLG = 1 Endif
 # End issue X3-126315
 [M:ITP]XBETFCY            = [M:ITP]BETFCY(NOL)
 # Issue 70985 - 2012-03-13 by SR
 [M:ITP]CUR3               = GCUR
######Endif
# Issue 105707 - 2015-02-05 by SR
If [M:ITP]XQUAFLG = 1
    Grizo [M:ITP]XQLYCRD
    Grizo [M:ITP]XQUAFRY
# Issue 122447 - 2017-04-13 by MAE : comment
Else
    Actzo [M:ITP]XQLYCRD
    Actzo [M:ITP]XQUAFRY
Endif
#inicio - FJCG - AURENV12
[M:ITP]XZESPESORP           = [M:ITP]ZESPESORP(NOL)
[M:ITP]XZDTYP               = [M:ITP]ZDTYP(NOL)
[M:ITP]XZFACTORP            = [M:ITP]ZFACTORP(NOL)
#Fin - FJCG - AURENV12
If !GIMPORT
#   Affzo [M:ITP]10-30
   Affzo [M:ITP]10-99 #X3-102255 by APL
Endif
Return

########################################
Subprog AS_NBITP
  Local Integer NOL

  # Issue 90991 - 2013-11-08 by MAE : comment
  If  find(GREP,"M","C")
    Grizo [M:ITP]STCNUMITF
  Else
    Actzo [M:ITP]STCNUMITF
  Endif

  # FGR 08/10/2009 : X3SUIVI57805 (dÈbut)
    Call CTRL_TABLEAU_SAISI("ITP", "NBITP") From TRTX3FNC
    If mkstat = 2 Then
      End
    Endif
  # FGR 08/10/2009 : X3SUIVI57805 (fin)

  If [F:ITG]PURFLG = 1 & [F:ITG]SCPFLG = 1 & [F:ITG]SCSFLG = 1 & [F:ITG]GENFLG = 1 & [F:ITG]TOOFLG = 1
      mkstat = 2 : End
  Endif
  NOL = nolign-1
  [M]XNUMLIG = nolign-1
  Gosub CHARGE_ITP

  Raz GBOUT1
  # Bouton texte
  If [M:ITP]BPSNUM(NOL) <> ""
    GBOUT1 = mess(38,198,1)
  Endif
End

Subprog C_NBITP
  # Issue X3-93803 - 2018-06-27 by USA : Begin. Check supplier before deletion
    If status = 65 or status = 83
      Local Integer NUML: NUML = 0
      If status = 65 : nolign1 = nolign : Endif
      If !clalev([ITPF]) : Local File ITMBPSFCY [ITPF] : Endif
      For NUML = nolign To nolign1
        Look [ITPF]ITPF0(2) >= [M:ITM0]ITMREF;[M:ITP]BPSNUM(NUML-1)
        If !fstat
          GMESSAGE = [F:ITPF]BPSNUM - mess(700,199,1)
          mkstat = 2
          Break
        Endif
      Next
      If mkstat = 2 Then End Endif
    Endif
  # Issue X3-93803 - 2018-06-27 by USA : End

  If !GIMPORT
     GERR=4  : GMESSAGE=[M:ITP]BPSNUM(nolign-1)
  Endif
  If status=65 or status = 83
    Local Integer NUMLI: NUMLI = 0
    If status = 65 : nolign1 = nolign : Endif
    Trbegin [STCF]
    For NUMLI = nolign To nolign1
      Delete[STCF] Where [STCF]ITMREF = [M:ITM0]ITMREF & [STCF]BPSNUM = [M:ITP]BPSNUM(NUMLI-1)
      If fstat = 1
         GOK = -1
         Call RSTA("STCF", [M:ITM0]ITMREF + "~" + [M:ITP]BPSNUM(NUMLI-1)) From GLOCK
         Break
      Endif
    Next
    If GOK = -1 Then Rollback  Else Commit Endif
  Endif

#  #MAE, 90991
#  Trbegin [STCF]
#  # essai pour afficher en bas le fourn o˘ on Ètait positionnÈ :
#  If !GIMPORT
#     GERR=4  : GMESSAGE=[M:ITP]BPSNUM(nolign-1)
#  Endif
#  If status=65
#    Delete[STCF] Where [STCF]ITMREF = [M:ITM0]ITMREF & [STCF]BPSNUM = [M:ITP]BPSNUM(nolign-1)
#    If fstat = 1
#       GOK = -1
#       Call RSTA("STCF",CLE_TO_DEL) From GLOCK
#    Endif
#  Endif
#  Commit
End

Subprog APRES_NBITP
  # SpÈcifique ý l'import --> Recharger indice pour sortir de la boucle de saisie
  If GIMPORT nolign = [M]NBITP Endif     : # V140
End

Subprog C_BPSNUM(VALEUR)
  Variable Char     VALEUR
  Local Integer NOL

  Call UNICITE(VALEUR,[M]BPSNUM(0..NBITP-1)) From OBJDIV
  If mkstat : End : Endif
  NOL = nolign -1
End

Subprog AM_XITMREFBPS(VALEUR)
Variable Char VALEUR
[M]ITMREFBPS([M]XNUMLIG) = VALEUR
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

