Subprog AP_BPSNUM(VALEUR)
Variable Char VALEUR
# Issue 70985 - 2012-03-09 by SR
Local Decimal WWMNTORG
Local Decimal WWMNTDES
Local Integer WSTAT
# Si modif penser ý vÈrifier IMPITM
#  + initialiser les zones par dÈfaut pour nouvelle ligne
NOL = nolign - 1
If [M]BPSNUM(NOL) = ""
#  [M]ITPQUAFLG(NOL) = [M:ITM2]QUAFLG  # hcb V6CQ
  [M]ITPPUU(NOL)    = [M:ITM3]PUU
  If dim([M:ITM4]LOAECCFLG) > 0
     [M]LOAECCFLG(NOL) = [M:ITM4]LOAECCFLG  # hcb 71276
  Endif
  [M]DOUFLG(NOL)    = 1
  [M]IPUUSTUCOE(NOL)    = [M:ITM3]PUUSTUCOE :# rajoutÈ le 22/12/99
  [M]ITPMATTOL(NOL)     = [M:ITM4]MATTOL     # Three Way Matching
  # Issue 70985 - 2012-03-09 by SR
  [M]CPRCOE(NOL) = [M:ITM4]ITMCPRCOE
  [M]CPRAMT(NOL) = [M:ITM4]ITMCPRAMT
  [M]STCNUM(NOL) = [M:ITM4]ITMSTCNUM
  Gosub CHARGE_ITP
Endif
If !GIMPORT
  zonsui = "XITMREFBPS"
  GERR=4 : GMESSAGE = VALEUR : # pour indiquer dans la barre le fournisseur courant
Endif
End

############################################################################
## Etiquette ajoutÈe par le superviseur (Ècran ITP) 02/11/2005 09:36:42 (TS)
## V6 sous-traitance
############################################################################
Subprog AM_XBOMALT(VALEUR)
Variable Decimal VALEUR
[M]BOMALT([M]XNUMLIG) = VALEUR
[M]UPDDAT([M]XNUMLIG) = date$
[M]UPDUSR([M]XNUMLIG) = GUSER
If VALEUR = 0 : End : Endif
If clalev([F:BOH])=0 : Local File BOM [BOH] : Endif
If [F:BOH]BOMALT<>VALEUR | [F:BOH]ITMREF<>[F:ITP]ITMREF | [F:BOH]BOMALTTYP <> 3
    Read [BOH]BOH0=[M:ITM0]ITMREF;VALEUR;3
  # Nomenclature inexistante !
    If fstat : GMESSAGE=mess(95,193,1) : mkstat=2 : Endif
Endif
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XSCOLTI(VALEUR)
Variable Decimal VALEUR
[M]SCOLTI([M]XNUMLIG) = VALEUR
[M]UPDDAT([M]XNUMLIG) = date$
[M]UPDUSR([M]XNUMLIG) = GUSER
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

