Subprog AM_XPIO (VALEUR)
  Variable Decimal VALEUR

  If func CHECK_PIO_ON_SCRN(VALEUR) = 2 #APL 14/06/2018 : X3-96018
    [M]PIO      ([M]XNUMLIG) = VALEUR
    [M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
    [M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
    [M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
    Affzo [M]PIO
   Else
    [M]XPIO = [M]PIO([M]XNUMLIG)
    Affzo[M]XPIO
  Endif
End

