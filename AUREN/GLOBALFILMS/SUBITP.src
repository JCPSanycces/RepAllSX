## Etiquette ajoutÈe par le superviseur (Ècran ITP) 17/05/2013 13:31:44 (MUARN)
## Issue 70985 - 2012-02-14 by MUARN : frais d'approche
######################################################################################
Subprog AM_XCPRAMT(VALEUR)
Variable Decimal VALEUR

# Issue 84130 - 2012-09-14 by MUARN : landed cost SDC
Local Integer OK : OK=1
# Issue 115743 - 2016-14-07 by MUARN : import zones landed cost
#If [M:ITP]XSTCNUM <> "" & !GIMPORT
If [M:ITP]XSTCNUM <> "" & VALEUR <> 0
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramÈtrÈe"
  # Issue 115743 - 2016-14-07 by MUARN : import zones landed cost
  If GIMPORT
    OK = 2
  Endif
  If OK = 1
    VALEUR = 0
  Else
    [M:ITP]XSTCNUM=""
    Affzo [ITP]XSTCNUM
  Endif
Endif

[M]CPRAMT   ([M]XNUMLIG) = VALEUR
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453

# Issue 84130 - 2012-09-18 by MUARN : landed cost structure de cout
[M]CPRCOE   ([M]XNUMLIG) = [M]XCPRCOE
[M]STCNUM   ([M]XNUMLIG) = [M]XSTCNUM
End

Subprog C_XSTCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET

If VALEUR <>""
  If [F:STCH]STCNUM<> VALEUR
    Read [STCH]STCH0=VALEUR
    If fstat GMESSAGE=mess(1119,196,1) : mkstat=2 : Endif
  Endif
  If !mkstat & [F:STCH]ENAFLG = 1
    GMESSAGE=mess(2,126,1)
    mkstat=2
  Endif
Endif

End

Subprog AM_XSTCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK : OK=1
# Issue 115743 - 2016-14-07 by MUARN : import zones landed cost
#If ([M:ITP]XCPRAMT<> 0 | [M:ITP]XCPRCOE <> 1) & !GIMPORT
If ([M:ITP]XCPRAMT<> 0 | [M:ITP]XCPRCOE <> 1) & VALEUR <> ""
  Call OUINON(mess(602,199,1), OK) From GESECRAN  # "un coeff ou co˚t est paramÈtrÈ"
  # Issue 115743 - 2016-14-07 by MUARN : import zones landed cost
  If GIMPORT
    OK = 2
  Endif
  If OK=1
    VALEUR =""
  Else
    [M:ITP]XCPRCOE = 1 : [M:ITP]XCPRAMT = 0
    Affzo [ITP]XCPRCOE, XCPRAMT
  Endif
Endif

[M]STCNUM   ([M]XNUMLIG) = VALEUR
[M]UPDDAT    ([M]XNUMLIG) = date$
[M]UPDUSR    ([M]XNUMLIG) = GUSER
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1
[M]CPRCOE   ([M]XNUMLIG) = [M]XCPRCOE
[M]CPRAMT   ([M]XNUMLIG) = [M]XCPRAMT
End

