Subprog C_XPUU (VALEUR)
Variable Char VALEUR
If [M]BPSNUM([M]XNUMLIG) <>"" & VALEUR = ""
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
End

Subprog AM_XPUU (VALEUR)
Variable Char VALEUR
Local Integer OK
If !GIMPORT   # hcb 62459
   OK=1 : Call AVERTIR(mess(389,194,1),OK) From GESECRAN
   If OK<>2  mkstat=2 : End : Endif
Endif
# correction bug 8214  (05/03/01) Attention les zones s'initialisent (par AS_) mÍme sans code fourn !
Call MODUNIT(VALEUR,[M:ITM3]STU,[M:ITP]XPUUSTUCOE) From SUBITM
[M:ITP]XPUU=VALEUR
Affzo [M:ITP]XPUUSTUCOE, XPUU2
[M]IPUUSTUCOE([M]XNUMLIG)= [M:ITP]XPUUSTUCOE

[M]ITPPUU   ([M]XNUMLIG) = VALEUR
If [M]BPSNUM([M]XNUMLIG) <>""
   GMESSAGE = mess(307,199,1) : GERR=2   # "vÈrifiez les coeff rattachÈs"
Endif
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XPCU (VALEUR)
Variable Char VALEUR
Local Integer J
# correction bug 8214  (05/03/01)
Call MODUNIT(VALEUR,[M:ITP]XPUU,[M:ITP]XPCUPUUCOE) From SUBITM

# si l'UC est parmi les UC de l'article : reprendre le coeff du tableau de PCU
# et passer par le coeff intermÈdiaire  (rajoutÈ pour v 140)
J = find(VALEUR,[M:ITM3]PCU)
If J > 0
  [M:ITP]XPCUPUUCOE = [M:ITM3]PCUSTUCOE(J-1) / [M]XPUUSTUCOE
Endif

Affzo [M:ITP]XPCUPUUCOE
[M]IPCUPUUCOE([M]XNUMLIG)= [M:ITP]XPCUPUUCOE

[M]ITPPCU   ([M]XNUMLIG) = VALEUR
If VALEUR = ""
   If !GIMPORT
      Effzo XPCUPUUCOE
   Endif
   [M]IPCUPUUCOE([M]XNUMLIG)= 0
Endif
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XPUUSTUCOE (VALEUR)
Variable Decimal VALEUR
Local Integer OK
If !GIMPORT   # hcb 62459
   OK=1 : Call AVERTIR(mess(389,194,1),OK) From GESECRAN
   If OK<>2  mkstat=2 : End : Endif
Endif
[M]IPUUSTUCOE([M]XNUMLIG)= VALEUR
[M:ITP]XPUUSTUCOE=VALEUR : Affzo [M:ITP]XPCUSTUCOE
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

