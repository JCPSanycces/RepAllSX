Subprog AM_XQUAFLG (VALEUR)
Variable Integer VALEUR
[M]ITPQUAFLG([M]XNUMLIG) = VALEUR
[M]UPDDAT    ([M]XNUMLIG) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XNUMLIG) = GUSER                #hcb 030505 29658
## hcb V6QQ
If VALEUR  < 2
   Effzo [M]XQLYCRD
   Grizo [M]XQLYCRD
   # Issue   105707- 2015-01-27 by SR
   Effzo [M]ITPQLYCRD([M]XNUMLIG)
Else
   Actzo [M]XQLYCRD
Endif
If VALEUR = 4
   Actzo [M]XQUAFRY
Else
   Effzo [M]XQUAFRY
   Effzo [M]XQUANUM
   Grizo [M]XQUAFRY
   # Issue   105707- 2015-01-27 by SR
   Effzo [M]ITPQUAFRY([M]XNUMLIG)
   Effzo [M]ITPQUANUM([M]XNUMLIG)
Endif
[M:ITP]FLMOD([M:ITP]XNUMLIG) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

