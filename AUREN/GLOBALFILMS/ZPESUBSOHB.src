#<AdxTL>@(#)0.0.0.0 $Revision$
#MODQTEALL -> PE de SUBSOHB para intervenir sobre la cantidad a asignar para que de una cantidad mayor
#             a la pedida para asegurarnos de que se va a asignar igual o más de lo pedido.
#             Este PE se llama desde boton Asignacion desde ventana de pedidos
#MAJSOQALL -> PE de SUBSOHB (No utilizado)
$ACTION
Case ACTION
   When "MODQTEALL"     :   Gosub MODQTEALL
   When "MAJSOQALL"     :   Gosub MAJSOQALL
Endcase
Return

$MODQTEALL
Local Shortint LI,LQYTBOB
Local Decimal LALLAUX

Call ECR_TRACE(" PE MODQTEALL ZPESUBSOHB - WALLSTU: "+num$(WALLSTU)+" ZFABCOR: "+num$([F:ITM]ZFABCOR)+" - "+GFONCTION,0) From GESECRAN
If WALLSTU>0
   If [F:ITM]ZFABCOR=2
      If clalev([F:STOX])<=0 : Local File STOCK [STOX] : Endif

      Filter [STOX] Where ITMREF=[M:SOH4]ITMREF(I) and STOFCY=[M:SOH4]DSTOFCY(I) and
&            ZANCHO=[M:SOH4]ZANCHO(I) and ZMANDRIL=[M:SOH4]ZMANDRIL(I) and ZLONGITUD=[M:SOH4]ZLONGITUD(I) and
&            CUMALLQTY=0
      LALLAUX=0
      LI=0
      For [STOX]
         LI+=1
         LALLAUX+=[F:STOX]QTYSTU
         If LI=[M:SOH4]ZQTYBOB(I)
            Break
         Endif
      Next
      Filter [STOX]
      Call ECR_TRACE(" PE MODQTEALL ZPESUBSOHB - LALLAUX: "+num$(LALLAUX),0) From GESECRAN
      #Call ECR_TRACE("ESPIA: "+" "+num$(WALLSTU)+" "+num$(LALLAUX)+" "+num$(LI)+" "+num$([M:SOH4]ZQTYBOB(I)),0) From GESECRAN
      #Read [ITM]ITM0=[M:SOH4]ITMREF(I)
      #If WALLSTU<LALLAUX
         #WALLSTU+=0.001
         WALLSTU=LALLAUX
      #Endif
   Endif
Endif
Return

$MAJSOQALL
#No utilizado
If GUSER="ADMIN" and 1=2
#Dbgaff
If WTRTLIG<>"A"
   If [F:SOP]SAUSTUCOE<>0
      If [F:SOQ]QTY<>0
         [F:SOP]SAUSTUCOE=[F:SOQ]ALLQTYSTU/[F:SOQ]QTY
         Rewrite [SOP]
         If fstat
            GOK=0
            Call FSTA("SOP") From GLOCK
         Endif
      Endif
   Endif
Endif
Endif
Return

#   When "SOHALLSEL"     :   Gosub SOHALLSEL
$SOHALLSEL
#Codigo obtenido de SUBSOHB para obtener la cantidad a asignar de forma que si es un articulo de
#corte no permita asignar una linea cuyo peso no sea el minimo que pueda tener una bobina
            WALLSTU = 0
            WSHTSTU = [M:SOH4]SHTQTYSTU(I)
#           Calcul de la qté ŕ allouer
            If WSHTFLG = 1 | (find([M:SOH2]DME, 2,3) & WALLPAR = 1)
                If [M:SOH4]TALLQTYSTU(I) + WSHTSTU < [M:SOH4]QTYSTU(I)
                    WALLSTU = [M:SOH4]QTYSTU(I) - ([M:SOH4]TALLQTYSTU(I) + WSHTSTU)
                Endif
            Endif

Return
