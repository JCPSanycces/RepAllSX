#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
# When "SETBOUT"      : Gosub SETBOUT
#  When "BOUTON"       : Gosub BOUTON
# When "APRES_MODIF"  : Gosub APRES_MODIF
 When "OK"           : Gosub OK
 When Default
Endcase
Return

$DEBUT
Local Shortint HAYDOC, EXISTE_TEX
Raz [M:ZTDOC]
EXISTE_TEX=1
If GFONCTION="GESSOH"
   If len([M:SOH0]SOHNUM)=0
      FIN=1
   Endif
   [M:ZTDOC]VCRTYP=2
   [M:ZTDOC]NUMDOC=[M:SOH0]SOHNUM
   Raz [F:ZTDOC]
   Read [F:ZTDOC]ZTDOC0=[M:ZTDOC]VCRTYP;[M:ZTDOC]NUMDOC
   If fstat=0
      EXISTE_TEX=2
      [M:ZTDOC]LINTEX1=[F:ZTDOC]LINTEX1
      [M:ZTDOC]LINTEX2=[F:ZTDOC]LINTEX2
      [M:ZTDOC]LINTEX3=[F:ZTDOC]LINTEX3
      [M:ZTDOC]LINTEX4=[F:ZTDOC]LINTEX4
      [M:ZTDOC]LINTEX5=[F:ZTDOC]LINTEX5
      [M:ZTDOC]LINTEX6=[F:ZTDOC]LINTEX6
      [M:ZTDOC]LINTEX7=[F:ZTDOC]LINTEX7
      [M:ZTDOC]LINTEX8=[F:ZTDOC]LINTEX8
      [M:ZTDOC]LINTEX9=[F:ZTDOC]LINTEX9
   Endif
Endif
Affzo [M:ZTDOC]5
Return

$OUVRE
If !clalev([F:ZTDOC]) : Local File ZTEXDOC [ZTDOC] : Endif
Return

$OK
[F:ZTDOC]VCRTYP=[M:ZTDOC]VCRTYP
[F:ZTDOC]NUMDOC=[M:ZTDOC]NUMDOC
[F:ZTDOC]LINTEX1=[M:ZTDOC]LINTEX1
[F:ZTDOC]LINTEX2=[M:ZTDOC]LINTEX2
[F:ZTDOC]LINTEX3=[M:ZTDOC]LINTEX3
[F:ZTDOC]LINTEX4=[M:ZTDOC]LINTEX4
[F:ZTDOC]LINTEX5=[M:ZTDOC]LINTEX5
[F:ZTDOC]LINTEX6=[M:ZTDOC]LINTEX6
[F:ZTDOC]LINTEX7=[M:ZTDOC]LINTEX7
[F:ZTDOC]LINTEX8=[M:ZTDOC]LINTEX8
[F:ZTDOC]LINTEX9=[M:ZTDOC]LINTEX9
If len([M:ZTDOC]NUMDOC)>0
   If EXISTE_TEX=1
      Write [F:ZTDOC]
      If fstat
         Call FSTA("ZTDOC") From GLOCK
      Endif
   Else
      Rewrite [F:ZTDOC]
      If fstat
         Call FSTA("ZTDOC") From GLOCK
      Endif
   Endif
Endif

Return
