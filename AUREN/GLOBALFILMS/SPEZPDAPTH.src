#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Script name : SPEZPDAPTH
# Description : Recepciµn y ubicaciµn
# Module      : Compras
# Version     : 1
# Created by  : Miguel Llaja
# Company     : Auren Espaþa
# Created date: 11/07/2022
############################################################################
################################################################
$ACTION
  Case ACTION
   When "OUVRE"    : Gosub OUVRE
   When "BOUTON"    : Gosub BOUTON
   When "DEBUT"    : Gosub DEBUT
   When "FIN"    : Gosub FIN
   When Default
  Endcase
Return

################################################################
$OUVRE
If !clalev([F:ZCNTR])    : Local File ZCONTAINH    [ZCNTR]  : Endif
If !clalev([F:ZCNTR2])    : Local File ZCONTAINH    [ZCNTR2]  : Endif
If clalev([F:TST])=0: Local File TABSTASTO [TST]: Endif
If clalev([F:ZAXX])=0: Local File ATEXTRA [ZAXX]: Endif
If clalev([F:WRH])=0: Local File WAREHOUSE [WRH]: Endif
If clalev([F:STC])=0: Local File STOLOC [STC]: Endif
If clalev([F:TLO])=0: Local File TABLOCTYP [TLO]: Endif
If clalev([F:POH])=0: Local File PORDER [POH]: Endif
If !clalev([F:ZUTPOHD])   : Local File ZUTPOHD      [ZUTPOHD] : Endif
If !clalev([F:ZUTPOHD2])   : Local File ZUTPOHD      [ZUTPOHD2] : Endif

Return

################################################################
$FIN
Unlock ="ZCNTR~"+[M:ZPDAPTH]NUMCNTR

Return

################################################################
$BOUTON
Local Integer OKFLG : Raz OKFLG
Case BOUT
  When "1"
    Gosub VERIF_UT
    If OKFLG>0 :Gosub UPD_UT Endif
  When "2"
    Gosub ADD_PALLET
Endcase
Return

################################################################
$ADD_PALLET
If [M:ZPDAPTH]STA ="" or [M:ZPDAPTH]WRH="" or [M:ZPDAPTH]LOC = "" or [M:ZPDAPTH]LOCTYP = "" or [M:ZPDAPTH]PALLET = ""
  Errbox "Valores incompletos"
  zonsui = "[M:ZPDAPTH]PALLET"
  Return
Endif

Read [F:WRH]WRH1 = [F:POH]POHFCY;[M:ZPDAPTH]WRH
If fstat
  Errbox "Almacen incorrecto"
  zonsui = "[M:ZPDAPTH]WRH"
  Return
Endif

Read [F:TST]TST0 = [M:ZPDAPTH]STA
If fstat
  Errbox "Estado incorrecto"
  zonsui = "[M:ZPDAPTH]STA"
  Return
Endif

Read [F:TLO]TLO0 = [F:POH]POHFCY;[M:ZPDAPTH]LOCTYP
If fstat
  Errbox "Tipo ubicaciµn incorrecto"
  zonsui = "[M:ZPDAPTH]LOCTYP"
  Return
Endif

Read [F:STC]STC0 =[F:POH]POHFCY;[M:ZPDAPTH]LOC
If fstat
  Errbox "Ubicaciµn incorrecta"
  zonsui = "[M:ZPDAPTH]LOC"
  Return
Endif

I = [M:ZPDAPTH]NBLIG
[M:ZPDAPTH]NBLIG+=1
[M:ZPDAPTH]XSTA(I)=[M:ZPDAPTH]STA
[M:ZPDAPTH]XLOC(I)=[M:ZPDAPTH]LOC
[M:ZPDAPTH]XLOCTYP(I)=[M:ZPDAPTH]LOCTYP
[M:ZPDAPTH]XPALLET(I)=[M:ZPDAPTH]PALLET
[M:ZPDAPTH]XWRH(I)=[M:ZPDAPTH]WRH
Affzo [M:ZPDAPTH]XSTA(I)
Affzo [M:ZPDAPTH]XLOC(I)
Affzo [M:ZPDAPTH]XLOCTYP(I)
Diszo [M:ZPDAPTH]XPALLET(I)
Affzo [M:ZPDAPTH]XPALLET(I)
Affzo [M:ZPDAPTH]XWRH(I)
Raz [M:ZPDAPTH]STA,[M:ZPDAPTH]LOC,[M:ZPDAPTH]LOCTYP,[M:ZPDAPTH]WRH,[M:ZPDAPTH]PALLET
Affzo [M:ZPDAPTH]STA
Affzo [M:ZPDAPTH]LOC
Affzo [M:ZPDAPTH]LOCTYP
Affzo [M:ZPDAPTH]PALLET
Affzo [M:ZPDAPTH]WRH
zonsui = "[M:ZPDAPTH]PALLET"
Return

################################################################
$VERIF_UT
If [M:ZPDAPTH]NBLIG<1 : Return Endif
Filter [F:ZUTPOHD] Where [F:ZUTPOHD]NUMCNTR = [M:ZPDAPTH]NUMCNTR
J=[M:ZPDAPTH]NBLIG
For [F:ZUTPOHD]
  If find ([F:ZUTPOHD]PALLET,[M:ZPDAPTH]XPALLET(0..J))=0
    OKFLG = 2
    Filter [F:ZUTPOHD]
    Break
  Endif
Next
Filter [F:ZUTPOHD]
Local Integer FRESP
If OKFLG =2
  Qstbox "Existen Pallets no registrados, quiere guardar la UT con estado EN CURSO de UBICACION" Using FRESP
  If FRESP=2
    OKFLG=0
    Return
  Endif
Else
  OKFLG =1
Endif
Return

################################################################
$DEBUT
Affzo [M:ZPDAPTH]
Diszo [M:ZPDAPTH]XPALLET
Return

################################################################
$UPD_UT
If [M:ZPDAPTH]NBLIG>0
  Read [F:ZCNTR]ZCNTR0 = [M:ZPDAPTH]NUMCNTR
  If !fstat
    #[F:ZCNTR]RCPDAT=[M:ZPDAPTH]RCPDAT
    [F:ZCNTR]BPSNDE=[M:ZPDAPTH]BPSNDE
    [F:ZCNTR]NDEDAT=date$ #[M:ZPDAPTH]NDEDAT
    [F:ZCNTR]ZORICRY=[M:ZPDAPTH]ZORICRY
    [F:ZCNTR]ZPROVEEDOR=[M:ZPDAPTH]ZPROVEEDOR
    If OKFLG = 2
      [F:ZCNTR]ZPKNLIST=3
    Elsif OKFLG = 1
      If [F:ZCNTR]ZPORGTOSARA <> 0 or [F:ZCNTR]ZGTOSEXT<>0 or [F:ZCNTR]ZGTOSNOR <> 0 or [F:ZCNTR]ZFLGCST=2
        [F:ZCNTR]ZPKNLIST=5
      Else
        [F:ZCNTR]ZPKNLIST=4
      Endif
    Endif
    Rewrite [F:ZCNTR]
    If fstat
      Call FSTA('ZCONTAINH') From GLOCK
      Return
    Endif
    For I = 0 To [M:ZPDAPTH]NBLIG-1
      Update [F:ZUTPOHD] Where [F:ZUTPOHD]NUMCNTR=[M:ZPDAPTH]NUMCNTR and [F:ZUTPOHD]PALLET=[M:ZPDAPTH]XPALLET(I)
&     With  [F:ZUTPOHD]LOC=[M:ZPDAPTH]XLOC(I),[F:ZUTPOHD]LOCTYP=[M:ZPDAPTH]XLOCTYP(I),
&         [F:ZUTPOHD]STA=[M:ZPDAPTH]XSTA(I),[F:ZUTPOHD]WRH=[M:ZPDAPTH]XWRH(I),
&         [F:ZUTPOHD]ZREGDAT=date$,[F:ZUTPOHD]ZUSER=GUSER
    Next
  Endif
Endif
Unlock ="ZCNTR~"+[M:ZPDAPTH]NUMCNTR
Raz [M:ZPDAPTH]
Affzo [M:ZPDAPTH]

Return


Subprog S_STA(VALEUR)
Variable Char    VALEUR()


Filter [F:ZAXX] Where [F:ZAXX]CODFIC = "TABSTASTO" and [F:ZAXX]ZONE = "STAAXX" and [F:ZAXX]LANGUE = "SPA"
 Choose [F:ZAXX]
& Using [F:ZAXX]IDENT1 Titled "Estado",
&[F:ZAXX]TEXTE Titled "Descripciµn" Titled "Selecciµn estado de stock"
Filter [F:ZAXX]
Case status
  When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
  When 7
  When Default : VALEUR = [F:ZAXX]IDENT1
Endcase
End


Subprog S_WRH(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
Filter [F:WRH] Where [F:WRH]STOFCY = [F:POH]POHFCY
PARMSK(1) = "WRH"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [F:WRH]
End

Subprog S_LOCTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
Filter [F:TLO] Where [F:TLO]STOFCY = [F:POH]POHFCY
PARMSK(1) = "TLO"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [F:TLO]
End

Subprog S_LOC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
Filter [F:STC] Where [F:STC]STOFCY = [F:POH]POHFCY and [F:STC]LOCTYP = [M:ZPDAPTH]LOCTYP and [F:STC]WRH = [M:ZPDAPTH]WRH
PARMSK(1) = "LOC"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [F:STC]
End


######################################################################################
######################################################################################
## Etiqueta aþadida por el supervisor (pantalla ZPDAPTH) 11/07/2022 16:40:39 (ADMIN)
######################################################################################
Subprog AM_NUMCNTR(VALEUR)
Variable Char    VALEUR()
Unlock ="ZCNTR~"+[M:ZPDAPTH]NUMCNTR
Lock = "ZCNTR~"+VALEUR
If fstat <> 0
  Errbox "Unidad de Trasnsporte en uso"
  mkstat=2
  End
Endif
Read [F:ZCNTR]ZCNTR0 = VALEUR
If !fstat
  Read [F:POH]POH0 = [F:ZCNTR]PEDNUM
  If fstat
    Errbox "Sin pedido"
    mkstat = 2
    End
  Endif
Endif
[M:ZPDAPTH]BPSNDE=[F:ZCNTR]BPSNDE
#[M:ZPDAPTH]NDEDAT=[F:ZCNTR]NDEDAT
[M:ZPDAPTH]ZORICRY=[F:ZCNTR]ZORICRY
[M:ZPDAPTH]ZPROVEEDOR=[F:ZCNTR]ZPROVEEDOR
Affzo [M:ZPDAPTH]BPSNDE
Affzo [M:ZPDAPTH]NDEDAT
Affzo [M:ZPDAPTH]ZORICRY
Affzo [M:ZPDAPTH]ZPROVEEDOR

Filter [F:ZUTPOHD] Where [F:ZUTPOHD]NUMCNTR = VALEUR Order By [F:ZUTPOHD]PALLET
Raz [M:ZPDAPTH]NBLIG
Local Char TMPPALLET(20): Raz TMPPALLET
For [F:ZUTPOHD]
  If [F:ZUTPOHD]PALLET<>TMPPALLET and [F:ZUTPOHD]LOC<>""
    TMPPALLET=[F:ZUTPOHD]PALLET
    I = [M:ZPDAPTH]NBLIG
    [M:ZPDAPTH]NBLIG+=1
    [M:ZPDAPTH]XLOC(I)=[F:ZUTPOHD]LOC
    [M:ZPDAPTH]XLOCTYP(I)=[F:ZUTPOHD]LOCTYP
    [M:ZPDAPTH]XPALLET(I)=[F:ZUTPOHD]PALLET
    [M:ZPDAPTH]XSTA(I)=[F:ZUTPOHD]STA
    [M:ZPDAPTH]XWRH(I)=[F:ZUTPOHD]WRH
    Affzo [M:ZPDAPTH]XSTA(I)
    Affzo [M:ZPDAPTH]XLOC(I)
    Affzo [M:ZPDAPTH]XLOCTYP(I)
    Diszo [M:ZPDAPTH]XPALLET(I)
    Affzo [M:ZPDAPTH]XPALLET(I)
    Affzo [M:ZPDAPTH]XWRH(I)
  Endif
Next


End

######################################################################################
######################################################################################
## Etiqueta aþadida por el supervisor (pantalla ZPDAPTH) 12/07/2022 00:54:19 (ADMIN)
######################################################################################
Subprog C_PALLET(VALEUR)
Variable Char VALEUR
Filter [F:ZUTPOHD2] Where [F:ZUTPOHD2]NUMCNTR = [M:ZPDAPTH]NUMCNTR and [F:ZUTPOHD2]PALLET=VALEUR
If rowcount([F:ZUTPOHD2])<1 and VALEUR <> ""
  Errbox "Pallet no encontrado en esta UT"
  Filter [F:ZUTPOHD2]
  mkstat =2
  End
Endif
Filter [F:ZUTPOHD2]

If [M:ZPDAPTH]NBLIG>0
  For I = 0 To [M:ZPDAPTH]NBLIG-1
    If [M:ZPDAPTH]XPALLET(I) = VALEUR
      Errbox "Pallet ya incluido"
      mkstat=2
      Break
      End
    Endif
  Next
Endif
End


######################################################################################
######################################################################################
## Etiqueta aþadida por el supervisor (pantalla ZPDAPTH) 12/07/2022 04:20:43 (ADMIN)
######################################################################################
Subprog AM_LOC(VALEUR)
Variable Char    VALEUR()
Read [F:STC]STC0 =[F:POH]POHFCY;VALEUR
If fstat
  Errbox "Ubicaciµn incorrecta"
  mkstat=2
  End
Endif
zonsui = "[M:ZPDAPTH]PALLET"
End


######################################################################################
######################################################################################
## Etiqueta aþadida por el supervisor (pantalla ZPDAPTH) 12/07/2022 06:01:37 (ADMIN)
######################################################################################
Subprog S_NUMCNTR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
Filter [F:ZCNTR] Where ([F:ZCNTR]ZPKNLIST = 2 or [F:ZCNTR]ZPKNLIST=3) #and [F:ZCNTR]BPSNDE<>"" and [F:ZCNTR]ZORICRY<>"" #and [F:ZCNTR]NDEDAT<>[0/0/0]
PARMSK(1) = "ZCNTR"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [F:ZCNTR]
End


######################################################################################
######################################################################################
## Etiqueta aþadida por el supervisor (pantalla ZPDAPTH) 12/07/2022 06:05:31 (ADMIN)
######################################################################################
Subprog C_NUMCNTR(VALEUR)
Variable Char    VALEUR()
Local Char TMPMES(100) : Raz TMPMES
Read [F:ZCNTR]ZCNTR0 = VALEUR
If !fstat
  If [F:ZCNTR]ZPKNLIST <> 2 and [F:ZCNTR]ZPKNLIST <> 3
    Errbox "Estado de UT incorrecto"
    mkstat = 2
    End
  Endif
  If [F:ZCNTR]BPSNDE=""
    TMPMES+= "UT sin Nro do. entrega proveedor. "
  Endif
  If [F:ZCNTR]ZORICRY=""
    TMPMES+= "UT sin Pais origen. "
  Endif
  If [F:ZCNTR]RCPDAT=[0/0/0]
    TMPMES+= "UT sin Fecha recepciµn. "
  Endif
  If TMPMES<>""
    Errbox TMPMES
    mkstat = 2
    End
  Endif
  Read [F:POH]POH0 = [F:ZCNTR]PEDNUM
  If fstat
    Errbox "Sin pedido"
    mkstat = 2
    End
  Endif
Else
  Errbox "Valor incorrecto"
  mkstat=2
  End
Endif

End
