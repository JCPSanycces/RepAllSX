#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTRE -> Para construir filtro especifico para la consulta SAD (Asignaciones detalladas)
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FILTRE"     : Gosub FILTRE
Endcase
Return

$OUVRE
If clalev([F:STO3])=0 : Local File STOCK      [STO3] : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:SOH])=0  : Local File SORDER     [SOH]  : Endif
If clalev([F:SDH])=0  : Local File SDELIVERY  [SDH]  : Endif
Return

$FILTRE
If [M:SAD1]ZANCHODEB>0
   WFILSPE+="&[F:STO3]ZANCHO="+num$([M:SAD1]ZANCHODEB)
Endif
If [M:SAD1]ZMANDRILDEB>0
   WFILSPE+="&[F:STO3]ZMANDRIL="+num$([M:SAD1]ZMANDRILDEB)
Endif
If [M:SAD1]ZLONGITUDDEB>0
   WFILSPE+="&[F:STO3]ZLONGITUD="+num$([M:SAD1]ZLONGITUDDEB)
Endif
If [M:SAD1]ZLOCDEB<>""
   WFILSPE+="&[F:STO3]LOC='"+[M:SAD1]ZLOCDEB+"'"
Endif
Return
