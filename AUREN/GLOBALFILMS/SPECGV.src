#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "OUVRE_BOITE" : Gosub  OUVRE
When "DEBUT"       : Gosub  DEBUT
When "OK"          : Gosub  OK
Endcase
Return

$OUVRE
If clalev([F:ZCGV]) <=0   :  Local File ZCAMBIOVALOR     [F:ZCGV]  : Endif
Global Integer ZRGT
Return

$DEBUT
Raz ZRGT
Return

$OK
If [M:CGV]ZIGUALAR=2 and [M:CGV]REPFLG<=1
    GMESSAGE = "Imposible indicar <<Igualar Lotes>> si  <<Distribuion=No>>"
    GERR = 1
    Return
Endif
If ZRGT=1
  Local Integer YN
  MSG="Est· seguro de PROCESAR los registros mostrados\Se aumentar· o disminuir· el peso de los lotes\seg˙n lo indicado en columna KGS DIF™"
  YN=1 # Por defecto es NO
  Call OUINON("Est· seguro de generar el cambio de valor con fecha "+[M:CGV]IPTDAT, YN) From GESECRAN
  If YN=1
    GMESSAGE="Proceso abortado"
    GERR = 1
    Return
  Endif
  Raz ZRGT
  Update [F:ZCGV] Where ITMREF=[M:CGV]ITMREF and PROCESADO<>2 With PROCESADO=2#,AVC=CPR
  If adxuprec<1
    GMESSAGE = "ERROR GRAVE !!!.   Avise al programador\No se marcaron registros como procesados\SPECGV.src\Update [F:ZCGV] Where ITMREF=[M:CGV]ITMREF and PROCESADO<>2 With PROCESADO=2)"
    GERR = 1
    Return
  Endif
Endif
Return

Funprog TOTAL_LOT(FCY,ART)
Value Char FCY,ART
Local Char TXT(255)(3),BD_TIPO(1)
Local Decimal IMP
Raz IMP
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
TXT(0)="select sum(AVCBASAMT_0) "
TXT(1)="from STOLOTFCY "
TXT(2)="where ITMREF_0='"+ART+"' and STOFCY_0='"+FCY+"'"
For (Decimal FIMP) From BD_TIPO Sql TXT As [MYT]
  IMP=FIMP
Next
End IMP
######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla CHGVAL) 04/07/2017 16:22:39 (ADMIN)
######################################################################################
Subprog IB_NBLOT
Local Integer R
Raz GBOUT2
# Abilitar si hay mvtos pdtes
Filter [F:ZCGV]
Filter [F:ZCGV] Where STOFCY=[M:CGV]STOFCY and ITMREF=[M:CGV]ITMREF and PROCESADO<>2
R=rowcount([F:ZCGV])
If R>0    GBOUT2="Actualizar "+num$(R)+" precios"    Endif
End

Subprog B2_NBLOT
Local Integer F
Filter [F:ZCGV]
Filter [F:ZCGV] Where ITMREF=[M:CGV]ITMREF and PROCESADO<>2
For [F:ZCGV]
  For F=0 To [M:CGV]NBLOT-1
    If [M:CGV]STOFCY=[F:ZCGV]STOFCY and [M:CGV]ITMREF=[F:ZCGV]ITMREF and [M:CGV]WLOT(F)=[F:ZCGV]LOT and [M:CGV]SLO(F)=[F:ZCGV]SLO
      [M:CGV]LOTAVC(F) = arr([F:ZCGV]CPR,0.000001)
      [M:CGV]LOTCST(F) = arr([F:ZCGV]CPR*[M:CGV]LOTQTYACT(F),0.000001)
      Affzo [M:CGV]LOTAVC(F)
      Affzo [M:CGV]LOTCST(F)
      nolign=F+1
      Call APRES_NBLOT From SUBCGV
      Break
    Endif
  Next
Next
ZRGT=1
End


