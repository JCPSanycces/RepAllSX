#<AdxTL>@(#)0.0.0.0 $Revision$
#FILTER -> Para construir filtro especifico para la consulta CPS (lineas recepciones)
$ACTION
Case ACTION
   When "OUVRE"       :   Gosub OUVRE
   When "FILTRE"      :   Gosub FILTRE
   When "AV_AFFICHE"  :   Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:ITM])= 0  : Local File ITMMASTER [ITM]    : Endif
If clalev([F:PTDX])= 0 : Local File PRECEIPTD [PTDX]   : Endif
If clalev([F:POHX])= 0 : Local File PORDER    [F:POHX] : Endif
Return

$FILTRE
Raz [M:CPS1]ZTOTBOB
Raz [M:CPS1]ZTOTKG
Raz [M:CPS1]ZTOTM2
Raz [M:CPS1]ZTOTIMPAI
Raz [M:CPS1]ZTOTIMPII
Affzo [M:CPS1]ZTOTBOB
Affzo [M:CPS1]ZTOTKG
Affzo [M:CPS1]ZTOTM2
Affzo [M:CPS1]ZTOTIMPAI
Affzo [M:CPS1]ZTOTIMPII
If [M:CPS1]ZANCHODEB>0
   WFIL2+="&[F:PTD]ZANCHO>="+num$([M:CPS1]ZANCHODEB)
Endif
If [M:CPS1]ZANCHOEND>0
   WFIL2+="&[F:PTD]ZANCHO<="+num$([M:CPS1]ZANCHOEND)
Endif
If [M:CPS1]ZLONGITUDDEB>0
   WFIL2+="&[F:PTD]ZLONGITUD>="+num$([M:CPS1]ZLONGITUDDEB)
Endif
If [M:CPS1]ZLONGITUDEND>0
   WFIL2+="&[F:PTD]ZLONGITUD<="+num$([M:CPS1]ZLONGITUDEND)
Endif
Return

$AV_AFFICHE
Local Integer F
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif

For F=0 To [M:CPS2]NBLIG-1
   Raz [F:ITM]
   Read [ITM]ITM0=[M:CPS2]ITMREF(F)
   Raz [F:PTDX]
   Read [PTDX]PTD0=[M:CPS2]PTHNUM(F);[M:CPS2]PTDLIN(F)
   If [F:PTDX]PUU="M2"
      [M:CPS2]ZQTYKG(F)=arr([F:PTDX]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPS2]ZQTYM2(F)=arr([F:PTDX]QTYPUU,0.01)
   Endif
   If [F:PTDX]PUU="KG"
      [M:CPS2]ZQTYKG(F)=arr([F:PTDX]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPS2]ZQTYM2(F)=arr([F:PTDX]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPS2]ZQTYM2(F)=0
      Endif
   Endif
   # JLPR 06-06-17 Determinar difŞ dias entre Recepcion y Pedido
   If [M:CPS2]POHNUM(F)<>""
     Read [F:POHX]POH0= [M:CPS2]POHNUM(F)
     If fstat=0
      [M:CPS2]ORDDAT(F)=[F:POHX]ORDDAT
      [M:CPS2]ZDIAS(F) =[M:CPS2]RCPDAT(F)-[F:POHX]ORDDAT
     Endif
   Endif
Next
Return

$CAL_CUMUL
Raz [M:CPS1]ZTOTBOB
Raz [M:CPS1]ZTOTKG
Raz [M:CPS1]ZTOTM2
Raz [M:CPS1]ZTOTIMPAI
Raz [M:CPS1]ZTOTIMPII
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key PTD0
For [LNK]
   Raz [F:ITM]
   Read [ITM]ITM0=[F:PTD]ITMREF

   [M:CPS1]ZTOTBOB+=[F:PTD]ZQTYBOB
   If [F:PTD]PUU="M2"
      [M:CPS1]ZTOTKG+=arr([F:PTD]QTYPUU*[F:ITM]ZFACTOR,0.01)
      [M:CPS1]ZTOTM2+=arr([F:PTD]QTYPUU,0.01)
   Endif
   If [F:PTD]PUU="KG"
      [M:CPS1]ZTOTKG+=arr([F:PTD]QTYPUU,0.01)
      If [F:ITM]ZFACTOR<>0
         [M:CPS1]ZTOTM2+=arr([F:PTD]QTYPUU/[F:ITM]ZFACTOR,0.01)
      Else
         [M:CPS1]ZTOTM2+=0
      Endif
   Endif
   [M:CPS1]ZTOTIMPAI+=[F:PTD]LINAMT
   [M:CPS1]ZTOTIMPII+=[F:PTD]LINATIAMT
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CPS1]ZTOTBOB
Affzo [M:CPS1]ZTOTKG
Affzo [M:CPS1]ZTOTM2
Affzo [M:CPS1]ZTOTIMPAI
Affzo [M:CPS1]ZTOTIMPII
Return

