#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPAPRO0 (Especifico)

Funprog FECHATOPE(INI)
Value Date INI
Local Date TOPE
Raz TOPE
If INI<>[0/0/0]
  TOPE=eomonth(func ZCOMUN.CHAR_TO_DATE("01/" + format$("D:MM[/]YYYY",addmonth(INI,11))))
  If TOPE>date$
    TOPE=eomonth(date$)
  Endif
Endif
End TOPE

Subprog AM_FECINI(VALEUR)
Variable Date    VALEUR
# Se coge el primer dia del mes indicado
[M:ZPAPR0]FECINI      =func ZCOMUN.CHAR_TO_DATE("01/" + format$("D:MM[/]YYYY",VALEUR))
# Por defecto, fecha fin será los 12 siguientes
[M:ZPAPR0]FECFIN      =func FECHATOPE([M:ZPAPR0]FECINI)
Affzo [M:ZPAPR0]10
End

Subprog AM_FECFIN(VALEUR)
Variable Date    VALEUR
##No se permite modificar fecha fin, pues esta serán 12 meses despues de la incial
#VALEUR=[M:ZPAPR0]FECFIN
# Se coge el último dia del mes indicado
If VALEUR=[0/0/0] or VALEUR<[M:ZPAPR0]FECINI
  VALEUR=func FECHATOPE([M:ZPAPR0]FECINI)
Else
  VALEUR=eomonth(VALEUR)
Endif
End

Subprog AM_PRESENTACION(VALEUR)
Variable Integer VALEUR
If [M:ZPAPR1]NBLIG>0
  [M:ZPAPR0]PRESENTACION=VALEUR
  Call MOSTRAR From SPEZAPRO
Endif
End

Subprog AM_MOSTRAR(VALEUR)
Variable Integer VALEUR
If [M:ZPAPR1]NBLIG>0
  [M:ZPAPR0]MOSTRAR=VALEUR
  Call MOSTRAR From SPEZAPRO
Endif
End

