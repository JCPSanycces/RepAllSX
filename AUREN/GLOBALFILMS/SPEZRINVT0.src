#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog AM_FECINI(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]   VALEUR=gdat$(1,month(date$),year(date$))   Endif
[M:ZRINVT0]FECFIN=eomonth(VALEUR)
Affzo [M:ZRINVT0]FECFIN
End

Subprog AM_FECFIN(VALEUR)
Variable Date    VALEUR
If [M:ZRINVT0]FECINI=[0/0/0]   [M:ZRINVT0]FECINI=gdat$(1,month(date$),year(date$)):Affzo [M:ZRINVT0]FECINI   Endif
If VALEUR=[0/0/0]              VALEUR=eomonth([M:ZRINVT0]FECINI)                     Endif
End

Subprog AM_RECEPC(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  Actzo [M:ZRINVT0]FECINI,FECFIN,FCY,OF
Else
  Read [F:PTH]PTH0=VALEUR
  [M:ZRINVT0]FECINI=gdat$(1,month([F:PTH]RCPDAT),year([F:PTH]RCPDAT))
  [M:ZRINVT0]FECFIN=eomonth(date$)
  [M:ZRINVT0]FCY   =[F:PTH]PRHFCY
  [M:ZRINVT0]OF    =""
  Affzo [M:ZRINVT0]FECINI,FECFIN,FCY,OF
  Diszo [M:ZRINVT0]FECINI,FECFIN,FCY,OF
Endif
End

Subprog AM_OF(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  Actzo [M:ZRINVT0]FECINI,FECFIN,FCY,RECEPC
Else
  Read [F:MFG]MFG0=VALEUR
  [M:ZRINVT0]FECINI=gdat$(1,month([F:MFG]STRDAT),year([F:MFG]STRDAT))
  [M:ZRINVT0]FECFIN=eomonth(date$)
  [M:ZRINVT0]FCY   =[F:MFG]MFGFCY
  [M:ZRINVT0]RECEPC=""
  Affzo [M:ZRINVT0]FECINI,FECFIN,FCY,RECEPC
  Diszo [M:ZRINVT0]FECINI,FECFIN,FCY,RECEPC
Endif
End

