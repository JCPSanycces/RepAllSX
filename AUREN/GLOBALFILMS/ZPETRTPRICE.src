#PE AVRECHTAR -> PARA DESACTIVAR LAS TARIFAS QUE NO CUMPLAN LAS CONDICIONES ESPECIFICAS.
$ACTION
Case ACTION
When  "AVRECHTAR"   :   Gosub AVRECHTAR
When  "TARIFVEN"    :   Gosub TARIFVEN
#When "ALIPLK"      :   Gosub ALIPLK
Endcase
Return


$TARIFVEN
If GUSER="ADMIN"
#  Infbox "Depurar $TARIFVEN  ZPETRTPRICE.src"
Endif
Return

$AVRECHTAR
#El valor de GZTARIFA viene inicializado del punto de entrada RECHTARIF (TRTVENTAR-ZPETRTVENTAR)
Local Integer I
#MODULE: 5-Ventas / 6-Compras
#PLITYP: 1-est·ndar / 2-agrupada / 3-prohibida / 4-componente
If MODULE=5 and PLITYP=1 and TRAIT="SOH"
  For I=0 To GPLINBR-1
    If GPLI(I)<>"101"  #Tarifa precios especiales
      If GPLI(I)<>GZTARIFA
         GPLITYP(I)=9
      Endif
    Endif
  Next
Endif
Return



