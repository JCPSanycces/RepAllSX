#<AdxTL>@(#)7.0.0.0 $Revision$
# (Fonction CALMFGCOST)   ** Traitement SUBMCC **  
# Calcul de COUT PREVISIONNEL d'OF
  # 1: "coût prévisionnel théorique"       CPT
  # 2: "coût prévisionnel de lancement"    CPL
  # 3: "coût prévisionnel de production"   CPP
# (Le calcul PRIX DE REVIENT DE FABRICATION se fait par FUNWIPMFC :Finalisation encours)
# Ce même traitement sert aussi à la VALORISATION DE L'ENCOURS :
# (fonction ORDPROVAL)  (GFONC1 = "PROVAL") ATTENTION zones [M] testées !
# Ces 2 fonctions peuvent aussi se lancer en batch
# ! Toute modif sur les valeurs opératoires réalisées doit être reportée 
# sur le traitement MWIPLIB (génération des Wipcost pour l'interface) !
#
# Points d'entrée :
# SOUSTRAIT (sous-traitance) ; APRESCALC (après màj) ; APRESVALO (fin valoris cpn)
# CODFGPROD ; BASFGPROD ; BASFGPROD2 (avant appel calcul FG du produit fini)
# CALCFG (calculer les frais/nature dans le sous-pro)
# CUSCTLMFG pour exclure des OF du calcul en masse (MFG ET MFI en ligne)

$ACTION
Case ACTION
 When "INIT"        Gosub INIT From SUBMCCA
 When "AVANT_PAR"   Gosub AVANT_PAR From SUBMCCA
 When "INIT_DIA"    Gosub INIT_DIA From SUBMCCA
 When "OUVRE_BATCH" Local File MFGHEAD     [MFG]
                    Local File MFGITM      [MFI]
                    Local File MFGCOST     [MFC]
                    # tables nécessaires depuis la requête batch
 When "CONTROLE"    Gosub CONTROLE From SUBMCCA
 When "EXEC"        Gosub EXEC From SUBMCCA
 When "TERMINE"     Gosub TERMINE From SUBMCCA
 When "SORTIE"      If GFONC1 = "PROVAL" : Raz GFONC1 : Endif

 ## GH 10/01/2013 Dm 77455
 # pour sélectionner sur la table seule, et plus la table + les tables liées via l'objet
 # pour que les mémos éventuels ne pertubent pas la gestion objet MFG
 When "AB2_VCRNUM"  PARMSK(4)="MFGITM"
 When "BB2_VCRNUM"  If PARMSK(3)="1" : [M]FILMFI=PARMSK(2) : Else [M]FILMFI="" : Endif
 When "AB3_VCRNUM"  PARMSK(4)="MFGHEAD"
 When "BB3_VCRNUM"  If PARMSK(3)="1" : [M]FILMFG=PARMSK(2) : Else [M]FILMFG="" : Endif
Endcase
Return

#####################################################
# Zones de l'écran de sélection MFCCLC0 ou ORDPROVAL#
#####################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GFONC1="GESMFG" mkstat=2 Endif # (04/12/01)
End

########################################

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Call GLOBVAR(VALEUR) From WWGLOBGPA : # pour charger les valeurs de paramètres
End

########################################

Subprog AS_VCRNUM(VALEUR)
Variable Char    VALEUR()
If GFONC1="GESMFG" mkstat=2 Endif # (04/12/01)
End

########################################

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Call CONTROLE("MFG","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
  If [F:MFG]MFGFCY <> [M]STOFCY
    mkstat = 2
    GMESSAGE = mess(82,116,1)  : # site incorrect
    End
  Endif
  If [F:MFG]MFGTRKFLG < 4
  ###  >>> oter le blocage si on veut calculer un PRF prévu seulement !!  (12/01)
    If [M]MFCTYP > 2 # à mettre en C_MFCTYP si MFCTYP est saisi après
      GERR=2 : # au lieu de mkstat = 2  13402  (20/06/02)
      GMESSAGE = mess(84,193,1) : #"cet ordre n'a pas encore fait l'objet de suivi"
    Endif
#oté v 140 :  Elsif [F:MFG]CPLQTY = 0 & GFONC1 <> "PROVAL"      # (03/12/01 - bug 11757)
#    mkstat = 2
#    GMESSAGE = mess(171,197,1) :# qté réalisée nulle  (07/08/01)
  Elsif [F:MFG]MFGTRKFLG = 5 & GFONC1 = "PROVAL"
    mkstat = 2
    GMESSAGE = mess(103,193,1) : #"Cet ordre de fabrication est soldé"
  Elsif [F:MFG]MFGSTA = 4 & ([M]MFGTYP=1 & GFONC1 <> "PROVAL")
    mkstat = 2
    GMESSAGE = mess(114,193,1) : #"Cet ordre de fabrication est clos"
  Elsif [F:MFG]MFGSTA < 4 & ([M]MFGTYP=2 & GFONC1 <> "PROVAL")
    mkstat = 2
    GMESSAGE = mess(115,193,1) : #"Cet ordre de fabrication n'est pas clos"
  Elsif [F:MFG]MFGTRKFLG = 6
    ##### mkstat = 2
    GERR = 2 # pour permettre de recalculer le PRF (v 130  07/03/01)
    GMESSAGE = mess(85,193,1) : #"Le prix de revient a déjà été calculé pour cet ordre"
  Endif
#Elsif ([M]FILMFI = "" & ([M]MFGTYP=1 | GFONC1="PROVAL")) | ([M]FILMFG="" & [M]MFGTYP=2)
Elsif [M]FILMFI = "" & [M]FILMFG=""
  mkstat = 2
Endif

If VALEUR <> "" & !mkstat
  [M]FILMFI = ""
  [M]FILMFG = ""
Endif
End

########################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer EXIST
If VALEUR <> "" 
  For [MFC] Where STOFCY = [M]STOFCY & VCRTYP=10 & VCRNUM = VALEUR & UID<>0
    EXIST = 1
    Break
  Next
# "des enregistrements provisoires de PRF existent déjà"
  If EXIST = 1 GMESSAGE=mess(89,193,1) : GERR=2 Endif
# v 140 > préalimenter MFCTYP (et les 2 zones associées) en fct de ceux qui existent déjà (?)
Endif
End

########################################
Subprog AM_MFGTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    [M]PRNCOD = 2 : Affzo PRNCOD
Endif
End

########################################
Subprog AS_PRNCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
If [M]MFGTYP = 1 & [M]MFCTYP=4
   GMENLOC(1) = 1 # PRF provisoire pas màj > état nécessaire !
Endif
End

########################################
Subprog AV_FILFLG(VALEUR)
Variable Integer  VALEUR
VALEUR = ([M]FILMFG<>"" | [M]FILMFI<>"")+1
End

########################################
Subprog C_MFCTYP(VALEUR)
Variable Integer VALEUR
# si l'OF est saisi avant le type :
If [M:MCC0]VCRNUM <> ""
  If [F:MFG]MFGNUM <> [M:MCC0]VCRNUM
    Read [MFG]MFG0=[M:MCC0]VCRNUM
  Endif
  If [F:MFG]MFGTRKFLG = 5 & VALEUR < 3
      GMESSAGE = mess(103,193,1) # "OF déjà soldé!"
      GERR = 2
  Endif
  # voir si l'OF est soldé pour calculer le type 3
  If VALEUR > 2
    If [F:MFG]CPLQTY = 0 
      GMESSAGE = mess(171,197,1) :# qté réalisée nulle 
      mkstat = 2
    Elsif [F:MFG]MFGTRKFLG < 5
      GMESSAGE = mess(212,193,1) # "OF pas encore soldé!"
      mkstat = 2
    Endif
  Endif
  If !mkstat
    # avertissement si coût déjà calculé
    For [MFC]MFC0 Where STOFCY=[M:MCC0]STOFCY & VCRTYP=10 & VCRNUM=[M:MCC0]VCRNUM & MFCTYP=VALEUR & UID=0
      If GMESSAGE<>"" GMESSAGE += "\" Endif
      GERR = 2
      Case VALEUR
        When 1 : GMESSAGE += mess(209,193,1) # "coût prévisionnel théorique déjà calculé"
        When 2 : GMESSAGE += mess(210,193,1) # "coût prévisionnel de lancement déjà calculé."
        When 3 : GMESSAGE += mess(211,193,1) # "coût prévisionnel de production déjà calculé."
      Endcase
      Break
    Next
  Endif
Endif
End

########################################
Subprog AM_MFCTYP(VALEUR)
Variable Integer VALEUR
# forcer les paramètres associés au type choisi
Case   VALEUR
  When 1 : [M:MCC0]ORIDEVCLC = 1  # standard
           [M:MCC0]FLXBUD    = 1
  When 2 : [M:MCC0]ORIDEVCLC = 2  # données de l'OF
           [M:MCC0]FLXBUD    = 1
  When 3 : [M:MCC0]ORIDEVCLC = 2  # données de l'OF
           [M:MCC0]FLXBUD    = 2  # budget flexible
Endcase
Affzo [MCC0]ORIDEVCLC, FLXBUD  
End

########################################
Subprog AS_FLXBUD(VALEUR)
Variable Integer VALEUR
If [M:MCC0]MFCTYP < 4 mkstat=2 Endif
End

########################################
Subprog AS_ORIDEVCLC(VALEUR)
Variable Integer VALEUR
If [M:MCC0]MFCTYP < 4 mkstat=2 Endif
End

######################################################################################
## GH 10/01/2013 Dm 77455
######################################################################################
Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()
If [M]MFGTYP = 2
   [M]FILSELMFG = "[MFG]MFGSTA=4"
Else
   [M]FILSELMFG = "[MFG]MFGSTA<4"
Endif
End

######################################################################################
Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()
If [M]FILMFI<>"" : VALEUR="" : Endif
Affzo FILFLG
End

######################################################################################
Subprog B3_VCRNUM(VALEUR)
Variable Char    VALEUR()
If [M]FILMFG<>"" : VALEUR="" : Endif
Affzo FILFLG
End

