Funprog DIR_ENV_FRA(CTE)
Value Char CTE
Local Char DIR(GLONBPD)
Local Char TXT(255)(3),BD_TIPO(1)
BD_TIPO=func DATA_BASE_TIPO()
TXT(0)="select BPAADD_0 "
TXT(1)="from BPADDRESS "
TXT(2)="where BPANUM_0='"+CTE+"' and BPAADDFLG_0=2"
Raz DIR
For (Char FDIR(GLONBPD)) From BD_TIPO Sql TXT As [MYT]
  DIR=FDIR
Next
End DIR

