Funprog EMAIL_REP_CTE(CTE)
Value Char CTE
Local Char EMAIL(255)
If !clalev([F:BPC]): Local File BPCUSTOMER  [F:BPC] : Endif
Read [F:BPC]BPC0=CTE
EMAIL=func EMAIL_REP([F:BPC]REP(0))
End EMAIL

Funprog EMAIL_REP(REP)
Value Char REP
# Se llama  ==>  EMAIL_REP=func ZCOMUN.EMAIL_REP([F:BPC]REP(0))
# Devuelve los 2 primeros emails   WEB(0);WEB(1)
Local Char EMAIL(255)
Raz EMAIL
If !clalev([F:BPAW]): Local File BPADDRESS  [F:BPAW] : Endif
Filter [F:BPAW] Where [F:BPAW]BPAADDFLG=2 and BPANUM=REP
For [F:BPAW]
  If [F:BPAW]WEB(0)<>""   EMAIL=[F:BPAW]WEB(0)    Endif
  If [F:BPAW]WEB(1)<>""
    If EMAIL<>""  EMAIL+=";"    Endif
    EMAIL+=[F:BPAW]WEB(1)
  Endif
  Break
Next
Filter [F:BPAW]
End EMAIL


Funprog ML_TXT(ML,LIN,LAN)
Value Integer ML,LIN
Value Char    LAN
Local Char TXT(80)
If clalev([F:AST])<=0  :  Local File APLSTD  [F:AST] : Endif
Raz TXT
Read [F:AST]CLE=ML;LIN;LAN
If fstat=0  TXT=[F:AST]LANMES    Endif
End TXT

#select LANMES_0 from APLSTD where LANCHP_0=339 and LANNUM_0=6 and LAN_0 ='SPA'
Funprog DIGITOCONTROL(NUMERO)
Value Char NUMERO
Local Integer DC,X,H,SUMA1,SUMA2,VALOR
Raz DC,X,H,SUMA1,SUMA2,VALOR
For H=len(NUMERO) To 1 Step -1
  X+=1
  If mod(X, 2) = 0
    SUMA2+=val(mid$(NUMERO,H,1))
  Else
    SUMA1+=val(mid$(NUMERO,H,1))
  Endif
Next
VALOR=(SUMA1*3)+SUMA2
While mod(VALOR,10)<>0
  DC+=1
  VALOR+=1
Wend
End DC


Subprog DIR_NOM(WDIR)
Variable Char WDIR
If right$(WDIR,len(WDIR))<>"\"
  WDIR=WDIR+"\"
Endif
If instr(1,WDIR,":")<1 and left$(WDIR,1)<>"\"
  WDIR="\"+WDIR
Endif
End

Subprog CREAR_DIR(WDIR)
Variable Char WDIR
Call DIR_NOM(WDIR)
Local Char TMP(255)
TMP=filpath("","","","","",adxmac(0)) + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
End

Funprog FICHERO_OK(FICHADJ)
Value Char FICHADJ
Local Integer NB_ATTEMPTS,OK
Local Decimal SIZE,RSIZE
NB_ATTEMPTS=0
OK=0
Repeat
   SIZE=filinfo(FICHADJ,7)
   If NB_ATTEMPTS=0 or SIZE<1 or (NB_ATTEMPTS>0 and SIZE<>RSIZE)
     NB_ATTEMPTS+=1
     RSIZE=SIZE
    Sleep 1
   Else
    OK=1
    Break
   Endif
Until NB_ATTEMPTS>10
End OK


Subprog ARRAY(STR,SEP,MAT)
Value Char STR,SEP
Variable Char MAT
Local Char TXT(255)
Local Integer I,P,E
Raz E,MAT
I=1
P=instr(I,STR,SEP)
While P>0
  MAT(E)=mid$(STR,I,P-I)
  I=P+len(SEP)
  E+=1
  P=instr(I,STR,SEP)
Wend
If P=0 and I<=len(STR)
  MAT(E)=right$(STR,I)
Endif
End

Funprog REPLACE(TXT1,ACT,NUEVO,REP,V)
Value Char TXT1,ACT,NUEVO
Value Integer REP
Variable Integer V
Local Integer F,P
Raz V
TXT=TXT1
P=instr(1,TXT,ACT)
While P>0
  TXT=left$(TXT,P-1)+NUEVO+right$(TXT,1+(P-1)+len(ACT))
  V+=1
  If V>=REP
    Break
  Endif
  P=instr(P+len(NUEVO),TXT,ACT)
Wend
End TXT

Funprog FILAS_GRID(PANTA,NBLIG)
# PANTA    tipo Char(GLONAMK)
# NBLIG    tipo Char(GLONAVA)
Value Char PANTA,NBLIG
Local Integer F,T
Raz T
If clalev([F:AMK])<=0    :  Local File AMSK  [F:AMK]  : Endif
Read [F:AMK]CODMSK=PANTA
If fstat<>0
  Call FSTA("AMK") From GLOCK
Else
  For F=0 To 14
    If [F:AMK]BASPAG(F)=NBLIG
      If [F:AMK]NBLIGT(F)>0
        T=[F:AMK]NBLIGT(F)
      Elsif [F:AMK]ACTBLOC(F)<>""
        If clalev([F:ACV])<=0    :  Local File ACTIV [F:ACV]  : Endif
        Read [F:ACV]ACV0=[F:AMK]ACTBLOC(F)
        T=[F:ACV]DIME
      Endif
      Break
    Endif
  Next
Endif
End T


Funprog INFORME(USR_P,RPT_P,SRV,NAM)
Value Char USR_P,RPT_P
Variable Char SRV,NAM
Local Char DEST(GLONAIM)
If clalev([F:WAIA]) <=0 : Local File APRTAUS     [F:WAIA]  : Endif
If clalev([F:AIM])  <=0 : Local File APRINTER    [F:AIM]  : Endif
Raz SRV,NAM,DEST
Filter [F:WAIA] Where USR=USR_P and RPTCOD=RPT_P
Read [F:WAIA] First
If fstat=0
  DEST=[F:WAIA]PRT
  Read [F:AIM]AIM0=DEST
  If fstat=0
    SRV=[F:AIM]PRTSRV
    NAM=[F:AIM]PRTNAM
  Endif
Endif
Close Local File [F:WAIA]
End DEST


