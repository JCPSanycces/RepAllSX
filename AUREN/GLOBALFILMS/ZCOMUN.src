Funprog ART_COSTE(FCY,ITM,LOT,SLOT,FIFO)
Value Char FCY,ITM,LOT,SLOT
Variable Date FIFO
Local Char TXT(255)(3),BD_TIPO(1)
Local Decimal COSTE_UNITARIO
Raz COSTE_UNITARIO,FIFO,TXT
## 1º intento sacar el precio de compra del lote
#BD_TIPO=func DATA_BASE_TIPO()
#TXT(0)="select CST_0/QTYSTUACT_0, CSTDAT_0 "
#TXT(1)="from STOCOST c inner join STOLOT l on c.VCRNUM_0=l.VCRNUM_0 and c.VCRLIN_0 =l.VCRLIN_0 and c.VCRTYP_0 =l.VCRTYP_0 "
#TXT(2)="where c.ITMREF_0='" + ITM + "' and LOT_0='" + LOT + "' and SLO_0='" + SLOT + "'"
#For (Decimal PREC, Date CSTDAT) From BD_TIPO Sql TXT As [MYT]
#  COSTE_UNITARIO=PREC
#  FIFO=CSTDAT
#Next
# 2º De no lograrlo, saco el precio medio
If FIFO=[0/0/0]
  If clalev([F:SLF])<=0   :  Local File STOLOTFCY    [F:SLF] : Endif
  Read [F:SLF]SLF0=ITM;LOT;SLOT;FCY
  If fstat=0
    COSTE_UNITARIO=[F:SLF]AVC # Precio medio ponderado PMP
    FIFO=[F:SLF]LASRCPDAT     # Fecha última entrada
  Endif
Endif
End COSTE_UNITARIO



