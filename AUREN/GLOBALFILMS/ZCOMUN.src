Funprog CONTINUAR
Local Integer YN,CONT
Local Char MSG(255)
YN = 1 :# By default points on No
MSG= "DESEA CONTINUAR"
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  CONT=0
Else
  CONT=1
Endif
End CONT

Funprog PROVINCIA_ESP(CODPOS, PAIS)
# Parametros de entrada
#  CODPOS      Tipo POS => Código Postal
#  PAIS        Tupo CRY => Pais
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción
Value Char CODPOS(), PAIS()
Local Char TXT(100)
Local Char PROV(GLONSAT), VALOR(GLONID1)(2)

If clalev([F:ATU])<=0  :  Local File TABSUBDIV  [F:ATU] : Endif

Raz TXT
PROV=left$(CODPOS,2)
Read [F:ATU]ATU0=PAIS; 3; PROV
If fstat=0
  VALOR(0)=[F:ATU]CRYTYP
  VALOR(1)=PROV
  TXT= func ZCOMUN.TRADUCIR_VALOR_CAMPO("TABSUBDIV", VALOR, "SPA", 3)
Endif
End TXT

Funprog TRADUCIR_VALOR_CAMPO(TABLA,VALOR,IDIOMA,TIPO)
# Parametros de entrada
#  TABLA       Tipo ATB => Nombre de la tabla
#  VALOR       Tipo ID1 => Valor del campo a traducir. matriz de 2  VALOR(0) + VALOR(1)
#  IDIOMA      Tipo LAN => Idioma cuya traduccion se desea
#  TIPO        TIPO AVA => Tipo de descripcion a devolver, SI TIPO = 3, devolver primer valor existente según orden Corta, Larga, Columna
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción

Value Char TABLA,VALOR,IDIOMA
Value Integer TIPO
Local Char TXT(100), ZONE(GLONAVA)
If clalev([F:AXX])<=0  :  Local File ATEXTRA    [F:AXX] : Endif

# Controlar valores especiales de columna ZONE
Case TABLA
When "TABSUBDIV"
  TIPO=-1
When "ATABDIV"
  TIPO=-2
Endcase

Raz TXT
Case TIPO
When -1 # Especial tabla    TABSUBDIV
  ZONE="INTIT"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When -2 # Especial tabla    ATABDIV
  ZONE="LNGDES"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 0  #  Descripción corta
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 1  #  Descripción larga
  ZONE="DESTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 2  #  Descripción columna
  ZONE="COLHEA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When Default
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="DESTRA"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
    If TXT="" or TXT="#"
      ZONE="COLHEA"
      Gosub TRADUCIR_VALOR_CAMPO_LEER
    Endif
  Endif
Endcase
End TXT

$TRADUCIR_VALOR_CAMPO_LEER
  Read [F:AXX]AXX0=TABLA;ZONE;IDIOMA;VALOR(0);VALOR(1)
  If fstat=0
    TXT=[F:AXX]TEXTE
  Else
    TXT="#"
  Endif
Return

Subprog PEDIRFICHERO (FICSRV,OK,FICCLI)
  Variable Char  FICSRV(),FICCLI()
  Variable Integer OK
  Local Integer STAT

  FICCLI=""
  FICSRV= filpath("tmp",num$(timestamp$),"")     # Nombre del fichero de destino en el servidor
  Call SET_NAMCLI(FICCLI) From ORDSYS
  Call COPSRV(FICCLI,FICSRV,STAT) From ORDSYS    # Funcion que abre la selecciÃ³n del fichero en el puesto de cliente
  If STAT
      Call ERREUR(mess(12,139,1)) From GESECRAN : # Copie non rÃ©alisÃ©e
      OK=0
  Else
      OK=1
  Endif
End

Subprog GRABARFICHERO(MSG,FICSRV)
Value Char MSG
Variable Char FICSRV
Local Integer H
Onerrgo ERRORES
FICSRV= filpath("tmp",num$(timestamp$),"txt")     # Nombre del fichero de destino en el servidor
Openo FICSRV Using [FIC1]                         # Lo abre para escritura
Iomode adxifs  ";"  Using [FIC1]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC1]
#Iomode adxium  50 Using [FIC1] #  50 = ASCII  0 = UTF8
For H=0 To dim(MSG)-1
 Wrseq MSG(H) Using [FIC1]                        # Graba texto
Next
Openo Using [FIC1]                                # Lo cierra
Onerrgo
End


Funprog DATA_BASE_TIPO
# 13.06.16 Sacado de http://www.greytrix.com/blogs/sagex3/2016/06/04/find-the-database-type-to-execute-the-sql-query-from-sage-x3/
If !clalev([XADS]) : Local File ADOSSIER [XADS] : Endif
Read [XADS] = nomap
Local Char DATABASE_TYPE(1)
If !fstat
   Case [F:XADS]TYPDBA
  When 1 :  DATABASE_TYPE="3"
  When 2 :  DATABASE_TYPE="5"
   Endcase
Endif
If clalev([XADS]) : Close File [XADS] : Endif
#  Local Integer DBTYPE
#  Local Char DATABASE_TYPE(10)
#  DBTYPE = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,"","TYPDBA")
#  DATABASE_TYPE=string$(DBTYPE=1,"O")+string$(DBTYPE=2,"S")

#  DATABASE_TYPE=func GETDBTYP
End DATABASE_TYPE


Funprog CHAR_TO_DATE(TXT_FEC)
Value Char TXT_FEC
Local Date FEC
Local Char XDATE(10),D(10)
Raz FEC,XDATE
Call DATEVALIDATE(TXT_FEC,XDATE,0) From ZCOMUN
If TXT_FEC <> "" and XDATE = ""
Else
  D=format$("DD2",TXT_FEC)
  FEC=gdat$(val(mid$(D,1,2)),val(mid$(D,4,2)),val(mid$(D,7,4)))
Endif
End FEC


Subprog DATEVALIDATE(VALEUR, XDATE, AVISO)
Value Char VALEUR
Variable Char XDATE
Value Integer AVISO  # 0=NO  1=SI
Local Char LC2(10):LC2=""
XDATE = format$("DD2",VALEUR)
LC2= format$("DD2","gfdbf")
#Infbox "VALEUR " + VALEUR +"   XDATE " + XDATE + "    LC2 " + LC2
If XDATE = LC2
 If VALEUR<>"" and AVISO=1 : Infbox "Fecha errónea" : Endif
 XDATE = ""
Endif
End

Funprog FECHA_INI_FIN(INI,FIN)
Value Date INI,FIN
Local Integer Z_OK,OK
Z_OK=0:OK=1
If INI<>[0/0/0] Then Z_OK+=1:Endif
If FIN<>[0/0/0] Then Z_OK+=1:Endif
#Infbox "valor Z_OK=" + num$(Z_OK) + chr$(13) + INI + chr$(13) + FIN
If Z_OK=2 Then
  If INI>FIN Then
    Infbox "Fecha INICIAL no puede ser mayor que FINAL"
    OK=0
  Endif
Endif
End OK





