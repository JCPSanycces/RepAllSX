Funprog REDONDEAR_R(NUM,POS,REDONDEAR)
Value Decimal NUM
Value Integer POS,REDONDEAR
Local Decimal N
If REDONDEAR
  N=func REDONDEAR(NUM,POS)
Else
  Local Integer F
  If POS=0 :    F=1  :  Else   :    F=10^POS  :  Endif
  N=int(NUM*F)/F
Endif
End N

Funprog REDONDEAR(NUM,POS)
Value Decimal NUM
Value Integer POS
Local Decimal N
Local Integer F
#int(3.375*100+0.5)/100
  If POS=0 :    F=1  :  Else   :    F=10^POS  :  Endif
N=int(NUM*F+0.5)/F
End N
