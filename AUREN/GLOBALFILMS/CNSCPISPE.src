#<AdxTL>@(#)0.0.0.0 $Revision$
#Tramiento especifico consulta cabecera facturas compras
$ACTION
Case ACTION
  When "FILTRE"       :   Gosub FILTRE
  When "AV_AFFICHE"   : Gosub AV_AFFICHE
  When Default
Endcase
Return

$FILTRE
Raz [M:CPI1]ZTOTKG
Raz [M:CPI1]ZTOTM2
Raz [M:CPI1]ZTOTIMPAI
Raz [M:CPI1]ZTOTIMPII
Affzo [M:CPI1]ZTOTKG
Affzo [M:CPI1]ZTOTM2
Affzo [M:CPI1]ZTOTIMPAI
Affzo [M:CPI1]ZTOTIMPII
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$CAL_CUMUL
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
Raz [M:CPI1]ZTOTKG
Raz [M:CPI1]ZTOTM2
Raz [M:CPI1]ZTOTIMPAI
Raz [M:CPI1]ZTOTIMPII
Filter [PIH] Where evalue(WFIL) & evalue(WFIL1) Order By Key PIH0
For [PIH]
   [M:CPI1]ZTOTIMPAI+=[F:PIH]AMTNOT
   [M:CPI1]ZTOTIMPII+=[F:PIH]AMTATI
   Filter [PID] Where NUM=[F:PIH]NUM
   For [PID]
      Raz [F:ITM]
      Read [ITM]ITM0=[F:PID]ITMREF
      If [F:PID]UOM="M2"
         [M:CPI1]ZTOTKG+=arr([F:PID]QTYPUU*[F:ITM]ZFACTOR,0.01)
         [M:CPI1]ZTOTM2+=arr([F:PID]QTYPUU,0.01)
      Endif
      If [F:PID]UOM="KG"
         [M:CPI1]ZTOTKG+=arr([F:PID]QTYPUU,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CPI1]ZTOTM2+=arr([F:PID]QTYPUU/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CPI1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [PID]
Next
Filter [PIH]
Return

$AFF_CUMUL
Affzo [M:CPI1]ZTOTKG
Affzo [M:CPI1]ZTOTM2
Affzo [M:CPI1]ZTOTIMPAI
Affzo [M:CPI1]ZTOTIMPII
Return
