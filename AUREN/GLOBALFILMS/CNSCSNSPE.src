#<AdxTL>@(#)0.0.0.0 $Revision$
# CNSCPNSPE   Consulta cabecera devoluciones VENTAS  M:CSN1 + M:CSN2    F:SRH
# FILTER -> Para construir filtro especifico
# Tipo ventana  CONSULTA # INQUIRY
$ACTION
#Infbox ACTION
Case ACTION
   When "OUVRE"         :   Gosub OUVRE
   When "FILTRE"        :   Gosub FILTRE
   When "FERME"         :   Gosub FIN
   When "TITRE"         :   Gosub INI_VALORES
   When "APRES_MODIF"   :   Gosub LIMPIAR
   When "AV_AFFICHE"    :   Gosub AV_AFFICHE
Endcase
Return

$OUVRE
If clalev([F:SRD])= 0 : Local File SRETURND  [SRD] : Endif
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
Local Char WFILF(250) : WFILF = "1=1"
Return

$FILTRE
Local Char TMP(200)
Local Integer T

Raz [M:CSN1]ZTOTKG
Raz [M:CSN1]ZTOTM2
Raz [M:CSN1]ZTOTIMPAI
Raz [M:CSN1]ZTOTIMPII
Affzo [M:CSN1]ZTOTKG
Affzo [M:CSN1]ZTOTM2
Affzo [M:CSN1]ZTOTIMPAI
Affzo [M:CSN1]ZTOTIMPII

TMP=""
If [M:CSN1]ZPRECOG=2 Then Call MONTAR_TMP(TMP,1):Endif
If [M:CSN1]ZPREVIS=2 Then Call MONTAR_TMP(TMP,2):Endif
If [M:CSN1]ZPFIRMA=2 Then Call MONTAR_TMP(TMP,3):Endif
If [M:CSN1]ZPABONO=2 Then Call MONTAR_TMP(TMP,4):Endif
If [M:CSN1]ZACEPTA=2 Then Call MONTAR_TMP(TMP,5):Endif
If [M:CSN1]ZNOACEP=2 Then Call MONTAR_TMP(TMP,6):Endif
If TMP<>"" Then
  TMP+=')'
  WFIL2+="&" + TMP
Endif
Return

Subprog MONTAR_TMP(TMP_P, VALOR_P)
Variable Char TMP_P
Value Integer VALOR_P
  If TMP_P ="" Then
    TMP_P+='('
  Else
    TMP_P+=' |'
  Endif
  TMP_P+='[F:SRH]ZSITFLG=' + num$(VALOR_P)
End


$LIMPIAR
  [M:CSN2]NBLIG=0:      Affzo [M:CSN2]
  [M:CSN1]ZTOTIMPAI=0:  Affzo [M:CSN1]ZTOTIMPAI
  [M:CSN1]ZTOTIMPII=0:  Affzo [M:CSN1]ZTOTIMPII
Return

$INI_VALORES
  [M:CSN1]ZACEPTA=2:Affzo[M:CSN1]ZACEPTA
  [M:CSN1]ZNOACEP=2:Affzo[M:CSN1]ZNOACEP
  [M:CSN1]ZPABONO=2:Affzo[M:CSN1]ZPABONO
  [M:CSN1]ZPFIRMA=2:Affzo[M:CSN1]ZPFIRMA
  [M:CSN1]ZPRECOG=2:Affzo[M:CSN1]ZPRECOG
  [M:CSN1]ZPREVIS=2:Affzo[M:CSN1]ZPREVIS
  Return


$FIN
  If GPE=1 Then GPE=0:Endif
Return

$AV_AFFICHE
If  CHGPAG=1
   Gosub CAL_CUMUL
   Gosub AFF_CUMUL
Endif
Return

$CAL_CUMUL
Raz [M:CSN1]ZTOTKG
Raz [M:CSN1]ZTOTM2
Raz [M:CSN1]ZTOTIMPAI
Raz [M:CSN1]ZTOTIMPII
Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&            Order By Key SRH0
For [LNK]
   Filter [SRD] Where SRHNUM=[F:SRH]SRHNUM
   For [SRD]
      [M:CSN1]ZTOTIMPAI+=[F:SRD]DLVQTY*[F:SRD]NETPRI
      [M:CSN1]ZTOTIMPII+=[F:SRD]DLVQTY*[F:SRD]NETPRIATI
      Raz [F:ITM]
      Read [ITM]ITM0=[F:SRD]ITMREF
      If [F:SRD]SAU="M2"
         [M:CSN1]ZTOTKG+=arr([F:SRD]DLVQTY*[F:ITM]ZFACTOR,0.01)
         [M:CSN1]ZTOTM2+=arr([F:SRD]DLVQTY,0.01)
      Endif
      If [F:SRD]SAU="KG"
         [M:CSN1]ZTOTKG+=arr([F:SRD]QTY,0.01)
         If [F:ITM]ZFACTOR<>0
            [M:CSN1]ZTOTM2+=arr([F:SRD]QTY/[F:ITM]ZFACTOR,0.01)
         Else
            [M:CSN1]ZTOTM2=0
         Endif
      Endif
   Next
   Filter [SRD]
Next
Filter [LNK]
Return

$AFF_CUMUL
Affzo [M:CSN1]ZTOTKG
Affzo [M:CSN1]ZTOTM2
Affzo [M:CSN1]ZTOTIMPAI
Affzo [M:CSN1]ZTOTIMPII
Return
