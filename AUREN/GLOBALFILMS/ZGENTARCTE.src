#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso que recorre genera un registro en la tabla de cabecera (ZTARCTEH) por planta y cliente con tantas
#lĒneas de detalle segun articulos se encuentren en las tarifas.
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_GTARCTE
  When "TERMINE"        : Gosub TERMINE_GTARCTE
  When "INIT"           : Gosub INIT_DIA_GTARCTE
  When "OK"             : Gosub OK_GTARCTE
  When "END"            : Gosub END_GTARCTE
Endcase
Return


$TRT_INI
If clalev([F:ZTACH])<=0 : Local File ZTARCTEH    [ZTACH] : Endif  : #Cabecera
If clalev([F:ZTACD])<=0 : Local File ZTARCTED    [ZTACD] : Endif  : #Detalle
If clalev([F:ZCIT])<=0 : Local File ZBPCITMTAR  [ZCIT] : Endif
If clalev([F:BPC])<=0  : Local File BPCUSTOMER  [BPC]  : Endif
If clalev([F:BPR])<=0  : Local File BPARTNER    [BPR]  : Endif
If clalev([F:SPL])<=0  : Local File SPRICLIST   [SPL]  : Endif
If clalev([F:SPC])<=0  : Local File SPRICCONF   [SPC]  : Endif
If clalev([F:FCY])<=0  : Local File FACILITY    [FCY]  : Endif
If clalev([F:CPY])<=0  : Local File COMPANY     [CPY]  : Endif
Return

$EXEC_GTARCTE
Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE("Inicio generar tarifas",0) From GESECRAN
Else
  Call OUVRE_TRACE("Inicio generar tarifas") From LECFIC
Endif

WMSG = "Generaci¾n tarifas"
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("ZGTARCTE","","",0,1)  From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

Gosub GTARCTE
Return

$GTARCTE
Local Char CRITERIO(250)
Local Integer HAYPRETAR, OK,WERR
#Conversi¾n
Local Char WUNID(GLONUOM)
Local Decimal WPREC

CRITERIO='SALFCY=[M:ZGTC]SALFCY & CREUSR=GUSER'
If [M:ZGTC]BPCNUMSTR<>''
   CRITERIO+=' & BPCNUM>="'+[M:ZGTC]BPCNUMSTR+'"'
Endif
If [M:ZGTC]BPCNUMEND<>''
   CRITERIO+=' & BPCNUM<="'+[M:ZGTC]BPCNUMEND+'"'
Endif

OK=1
#Trbegin [ZTACH], [ZTACD]
#Delete [ZTACH] Where SALFCY=[M:ZGTC]SALFCY
Delete [ZTACH] Where evalue(CRITERIO)
If fstat
   Call ECR_TRACE("Error borrando generaci¾n anterior [ZTACH]",1) From GESECRAN
   OK=0
Endif

#Delete [ZTACD] Where SALFCY=[M:ZGTC]SALFCY
Delete [ZTACD] Where evalue(CRITERIO)
If fstat
   Call ECR_TRACE("Error borrando generaci¾n anterior [ZTACD]",1) From GESECRAN
   OK=0
Endif

If !OK
   Return
Endif



CRITERIO='1=1'
If [M:ZGTC]BPCNUMSTR<>''
   CRITERIO+=' & [BPC]BPCNUM>="'+[M:ZGTC]BPCNUMSTR+'"'
Endif
If [M:ZGTC]BPCNUMEND<>''
   CRITERIO+=' & [BPC]BPCNUM<="'+[M:ZGTC]BPCNUMEND+'"'
Endif

Raz [F:FCY]
Read [FCY]FCY0=[M:ZGTC]SALFCY
OK=1
Trbegin [ZTACH], [ZTACD]
Filter [BPC] Where evalue (CRITERIO) Order By Key BPC0
For [BPC]
   Raz [F:BPR]
   Read [BPR]BPR0=[F:BPC]BPCNUM

   Call ECR_TRACE("Planta: "+[M:ZGTC]SALFCY+" Clte: "+[F:BPC]BPCNUM+" Pais: "+[F:BPR]CRY+" Est.1: "+[F:BPC]TSCCOD(0)+" Est.2: "+[F:BPC]TSCCOD(1),0) From GESECRAN

   Raz [F:ZTACH]
# JLPR 09-02-17 Comento y a±ado  <<INI>>
#  Read [F:ZTACH]ZTACH0=[M:ZGTC]SALFCY;[F:ZCIT]BPCNUM
   Read [F:ZTACH]ZTACH0=[M:ZGTC]SALFCY;[F:BPC]BPCNUM
   If fstat
      [F:ZTACH]SALFCY=[M:ZGTC]SALFCY
#     [F:ZTACH]BPCNUM=[F:ZCIT]BPCNUM
      [F:ZTACH]BPCNUM=[F:BPC]BPCNUM
# JLPR 09-02-17 Comento y a±ado  <<FIN>>
      [F:ZTACH]FECACT=date$
      [F:ZTACH]CREUSR=GUSER
      Write [ZTACH]
      If fstat
            Call ECR_TRACE("Error grabando [ZTACH]- fstat: "+num$(fstat),1) From GESECRAN
            OK = 0
            Break
      Endif
   Endif
   # Las tarifas que se aplican a un cliente estan definidas en tabla    ZBPCITMTAR  (PK=Cte+Art+Long)....De no existir aqui, se supone que no se aplicarßn, pues mediante punto de entrada se
# desestiman los registros/tarifas que no esten aqui
   Filter [ZCIT] Where BPCNUM=[F:BPC]BPCNUM Order By Key ZCIT0
   For [ZCIT]
      #JLPR 16-03-17 El orden que habia era   Generales +Longitud+Especiales
      #              Se cambia por            Especiales+Longitud+Generales
      #ZTARCTEH         PK = SALFCY+BPCNUM
      #ZTARCTED         PK cambiada de   SALFCY+BPCNUM+ITMREF+LONGITUD+PLI
      #                              a   SALFCY+BPCNUM+ITMREF+LONGITUD
      #                 Para evitar que haya mas de un precio x  SALFCY+BPCNUM+ITMREF+LONGITUD
      Call ECR_TRACE("   Articulo: "+[F:ZCIT]ITMREF,0) From GESECRAN
      Gosub TARIFAS_ESPECIALES
      If not OK : Break  : Endif
      Gosub TARIFAS_LONGITUD
      If not OK : Break  : Endif
      Gosub TARIFAS_GENERALES
      If not OK : Break  : Endif
      Call ECR_TRACE("====================================",0) From GESECRAN
   Next
   Filter [ZCIT]
Next
Filter [BPC]
If OK
   Commit
Else
   Rollback
Endif
Return

$TARIFAS_GENERALES
#Call ECR_TRACE("Tarifas generales",0) From GESECRAN
#Recorremos primero las tarifas generales
Filter [SPL] Where PLI=[F:ZCIT]PLI and PLICRI1=[M:ZGTC]SALFCY and PLICRI2=[F:BPR]CRY and PLICRI3=[F:BPC]TSCCOD(0) and
&                  PLICRI4=[F:BPC]TSCCOD(1) and PLICRI5=[F:ZCIT]ITMREF and PLISTRDAT<=[M:ZGTC]FECREF and PLIENDDAT>=[M:ZGTC]FECREF
HAYPRETAR=1
For [SPL]
#  Call ECR_TRACE("   Articulo(1): "+[F:ZCIT]ITMREF,0) From GESECRAN
  HAYPRETAR=2
  Break
Next
Filter [SPL]
If HAYPRETAR=2
  Call PRECIO_TAR([F:ZCIT]ITMREF,[F:ZCIT]BPCNUM,[F:SPL]UOM,[F:SPL]PRI,WUNID,WPREC)
  Raz [F:ZTACD]
  [F:ZTACD]SALFCY   =[M:ZGTC]SALFCY
  [F:ZTACD]BPCNUM   =[F:ZCIT]BPCNUM
  [F:ZTACD]ITMREF   =[F:ZCIT]ITMREF
  [F:ZTACD]LONGITUD =[F:ZCIT]ZLONGITUD
  [F:ZTACD]PLI      =[F:ZCIT]PLI
  [F:ZTACD]PLICRD   =[F:SPL]PLICRD
  [F:ZTACD]PLICRI   =[F:SPL]PLICRI
  [F:ZTACD]CUR      =[F:SPL]CUR
  [F:ZTACD]PRI      =WPREC #[F:SPL]PRI
  [F:ZTACD]UOM      =WUNID #[F:SPL]UOM
  [F:ZTACD]FECREF   =[M:ZGTC]FECREF
  [F:ZTACD]PLISTRDAT=[F:SPL]PLISTRDAT
  [F:ZTACD]PLIENDDAT=[F:SPL]PLIENDDAT
  [F:ZTACD]FECACT   =date$
  [F:ZTACD]CREUSR   =GUSER
  Write [F:ZTACD]
  Case fstat
  When 3 # Clave duplicada, significa que ya se indic¾ un precio para ese Cte+Art+Long
  When 0
    Call ECR_TRACE("Tarifa general "+[F:SPL]PLI+"#"+[F:SPL]PLICRD +"  Criterio "+[F:SPL]PLICRI+" Precio "+num$(WPREC)+" "+WUNID,0) From GESECRAN
  When Default
    Call ECR_TRACE("Error grabando [ZTACD] (1-Tarifas Generales) - fstat: "+num$(fstat)+" Planta: "+[F:ZTACD]SALFCY+" CTE: "+[F:ZCIT]BPCNUM+" ART: "+
&                  [F:ZCIT]ITMREF+" LONG.: "+num$([F:ZTACD]LONGITUD)+" TAR: "+[F:ZCIT]PLI,1) From GESECRAN
    OK = 0
  Endcase
Endif
Return


$TARIFAS_LONGITUD
#Call ECR_TRACE("Tarifas de longitud",0) From GESECRAN
#Recorremos ahora las tarifas de longitud
Link [SPL] With [SPC]SPC0=[F:SPL]PLI As [LNK]
Filter [LNK] Where [F:SPL]PLI=[F:ZCIT]PLI and [F:SPC]FLD(4)="ZLONGITUD" and [F:SPC]PLICPY=[F:FCY]LEGCPY and [F:SPL]PLICRI1=[F:BPR]CRY and
&                  [F:SPL]PLICRI2=[F:BPC]TSCCOD(0) and [F:SPL]PLICRI3=[F:BPC]TSCCOD(1) and
&                  [F:SPL]PLICRI4=[F:ZCIT]ITMREF and [F:SPL]PLICRI5=num$([F:ZCIT]ZLONGITUD) and [F:SPL]PLISTRDAT<=[M:ZGTC]FECREF and [F:SPL]PLIENDDAT>=[M:ZGTC]FECREF
HAYPRETAR=1
For [LNK]
#  Call ECR_TRACE("   Articulo(2): "+[F:ZCIT]ITMREF,0) From GESECRAN
  HAYPRETAR=2
  Break
Next
Filter [LNK]
If HAYPRETAR=2
  Call PRECIO_TAR([F:ZCIT]ITMREF,[F:ZCIT]BPCNUM,[F:SPL]UOM,[F:SPL]PRI,WUNID,WPREC)
  Raz [F:ZTACD]
  [F:ZTACD]SALFCY   =[M:ZGTC]SALFCY
  [F:ZTACD]BPCNUM   =[F:ZCIT]BPCNUM
  [F:ZTACD]ITMREF   =[F:ZCIT]ITMREF
  [F:ZTACD]LONGITUD =val([F:SPL]PLICRI5)
  [F:ZTACD]PLI      =[F:SPL]PLI
  [F:ZTACD]PLICRD   =[F:SPL]PLICRD
  [F:ZTACD]PLICRI   =[F:SPL]PLICRI
  [F:ZTACD]CUR      =[F:SPL]CUR
  [F:ZTACD]PRI      =WPREC #[F:SPL]PRI
  [F:ZTACD]UOM      =WUNID #[F:SPL]UOM
  [F:ZTACD]FECREF   =[M:ZGTC]FECREF
  [F:ZTACD]PLISTRDAT=[F:SPL]PLISTRDAT
  [F:ZTACD]PLIENDDAT=[F:SPL]PLIENDDAT
  [F:ZTACD]FECACT   =date$
  [F:ZTACD]CREUSR   =GUSER
  Write [F:ZTACD]
  Case fstat
  When 3 # Clave duplicada, significa que ya se indic¾ un precio para ese Cte+Art+Long
  When 0
    Call ECR_TRACE("Tarifa de longitud "+[F:SPL]PLI+"#"+[F:SPL]PLICRD +"  Criterio "+[F:SPL]PLICRI+" Precio "+num$(WPREC)+" "+WUNID,0) From GESECRAN
  When Default
    Call ECR_TRACE("Error grabando [ZTACD] (2-Tarifas Longitud) - fstat: "+num$(fstat)+" Planta: "+[F:ZTACD]SALFCY+" CTE: "+
&                  [F:ZCIT]BPCNUM+" ART: "+[F:ZCIT]ITMREF+" LONG.: "+num$([F:ZTACD]LONGITUD)+" TAR: "+[F:ZCIT]PLI, 1) From GESECRAN
    OK = 0
  Endcase
Endif
Return

$TARIFAS_ESPECIALES
#Recorremos ahora las tarifas especiales
#Call ECR_TRACE("   Articulo(3): "+[F:ZCIT]ITMREF,0) From GESECRAN
Filter [SPL] Where PLI="101" and PLICRI1=[M:ZGTC]SALFCY and PLICRI2=[F:BPR]CRY and PLICRI3=[F:BPC]BPCNUM and
&                  PLICRI4=[F:ZCIT]ITMREF and PLISTRDAT<=[M:ZGTC]FECREF and [SPL]PLIENDDAT>=[M:ZGTC]FECREF
For [SPL]
  Call PRECIO_TAR([F:SPL]PLICRI4,[F:BPC]BPCNUM,[F:SPL]UOM,[F:SPL]PRI,WUNID,WPREC)
  Raz [F:ZTACD]
  [F:ZTACD]SALFCY   =[M:ZGTC]SALFCY
  [F:ZTACD]BPCNUM   =[F:BPC]BPCNUM
  [F:ZTACD]ITMREF   =[F:SPL]PLICRI4
  [F:ZTACD]LONGITUD =0
  [F:ZTACD]PLI      =[F:SPL]PLI
  [F:ZTACD]PLICRD   =[F:SPL]PLICRD
  [F:ZTACD]PLICRI   =[F:SPL]PLICRI
  [F:ZTACD]CUR      =[F:SPL]CUR
  [F:ZTACD]PRI      =WPREC #[F:SPL]PRI
  [F:ZTACD]UOM      =WUNID #[F:SPL]UOM
  [F:ZTACD]FECREF   =[M:ZGTC]FECREF
  [F:ZTACD]PLISTRDAT=[F:SPL]PLISTRDAT
  [F:ZTACD]PLIENDDAT=[F:SPL]PLIENDDAT
  [F:ZTACD]FECACT   =date$
  [F:ZTACD]CREUSR   =GUSER
  Write [F:ZTACD]
# JLPR 16-03-17 comento al no tener sentido, debido a que es la primera que generamos........Antes era la ·ltima
#  If fstat<>0
#    If fstat=3
#       WERR=-1
#    Else
#       OK = 0
#       WERR=1
#    Endif
#   Call ECR_TRACE("Error grabando [ZTACD] (3-Tarifa especial) - fstat: "+num$(fstat)+" CTE: "+[F:ZCIT]BPCNUM+" ART: "+[F:ZTACD]ITMREF+
#&                 " LON: "+num$([F:ZTACD]LONGITUD)+" TAR: "+[F:SPL]PLI,WERR) From GESECRAN
#    Break
#  Endif
  Case fstat
  When 3 # Clave duplicada, significa que ya se indic¾ un precio para ese Cte+Art+Long. No tener sentido, debido a que es la primera que generamos........Antes era la ·ltima
    Call ECR_TRACE("CLAVE DUPLICADA  - Error grabando [ZTACD] (3-Tarifa especial) - fstat: "+num$(fstat)+" CTE: "+[F:ZCIT]BPCNUM+" ART: "+[F:ZTACD]ITMREF+
&                 " LON: "+num$([F:ZTACD]LONGITUD)+" TAR: "+[F:SPL]PLI,1) From GESECRAN
    OK = 0
#    Break
  When 0
    Call ECR_TRACE("Tarifa especial "+[F:SPL]PLI+"#"+[F:SPL]PLICRD +"  Criterio "+[F:SPL]PLICRI+" Precio "+num$(WPREC)+" "+WUNID,0) From GESECRAN
  When Default
    Call ECR_TRACE("Error grabando [ZTACD] (3-Tarifa especial) - fstat: "+num$(fstat)+" CTE: "+[F:ZCIT]BPCNUM+" ART: "+[F:ZTACD]ITMREF+
&                 " LON: "+num$([F:ZTACD]LONGITUD)+" TAR: "+[F:SPL]PLI,1) From GESECRAN
    OK = 0
#    Break
  Endcase
Next
Filter [SPL]
Return


$INIT_DIA_GTARCTE
Call ERREURT ("10-05-17 JLPR\Proceso en desuso", 1) From GESECRAN   #0-Informativo, 1-Error
FIN=1
Local Mask ZGTARCTE [ZGTC]
Raz [M:ZGTC]
[M:ZGTC]SALFCY = GFCYDEF(0)
Return

$TERMINE_GTARCTE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

Return

$OK_GTARCTE
Raz [M:ZGTC]
FIN  = 1
Return

$END_GTARCTE
Raz [M:ZGTC]
FIN = 1
Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

Subprog PRECIO_TAR(ART,CTE,TAR_UNID,TAR_PREC,WUNID,WPREC)
Value Char       ART,CTE,TAR_UNID
Value Decimal    TAR_PREC
Variable Char    WUNID
Variable Decimal WPREC
Local Char MSG(255)
If clalev([F:ITM])<=0   :  Local File ITMMASTER [F:ITM] : Endif
If clalev([F:ITU])<=0   :  Local File ITMBPC    [F:ITU] : Endif
WUNID=TAR_UNID
WPREC=TAR_PREC
Read [F:ITU]ITU0=ART;CTE
If fstat=0
  WUNID=[F:ITU]SAU
  If TAR_UNID<>WUNID
    Read [F:ITM]ITM0=ART
    If fstat=0
      WPREC=arr(TAR_PREC*[F:ITM]ZFACTOR,0.0001)
    Else
      MSG="Se asume precio de "+num$(WPREC)+" en "+WUNID+" debido a que fue imposible sacar ZFACTOR del artĒculo "+ART+", por no existir"
      Call ECR_TRACE(MSG,1) From GESECRAN
    Endif
  Endif
Else
#  MSG="Se asume precio de "+num$(WPREC)+" en "+WUNID+" debido a que no se ha indicado nada para el artĒculo "+ART+" y cliente "+CTE +"  (ITMBPC)"
#  Infbox MSG
#  Call ECR_TRACE(MSG,-1) From GESECRAN
Endif
End






Subprog GENERAR_TARIFAS(FCY_P,FEC_P,CTE_P,ART_P,ZOK)
Value Char       FCY_P
Value Date       FEC_P
Value Char       CTE_P
Value Char       ART_P
Variable Integer ZOK
Local Integer    BORRAR_CAB   :    BORRAR_CAB=1
Call GENERAR_TARIFAS_1(FCY_P,FEC_P,CTE_P,ART_P,BORRAR_CAB,ZOK)
End

Subprog GENERAR_TARIFAS_1(FCY_P,FEC_P,CTE_P,ART_P,BORRAR_CAB_P,ZOK)
Value Char       FCY_P
Value Date       FEC_P
Value Char       CTE_P
Value Char       ART_P
Value Integer    BORRAR_CAB_P
Variable Integer ZOK
#
Local Char    CRITERIO(250)(2),MSG(250),ZCRD(GLONVCR),WUNID(GLONUOM) # ,ZFCY(GLONFCY)
Local Integer CAB,ZLIN
Local Decimal PREC,WPREC
#
ZOK=1
#
Gosub TAR_ABRIR_TABLAS
Gosub TAR_BORRAR
If !ZOK    End  Endif
Gosub TAR_GENERAR
End



$TAR_GENERAR
# Inicio transaccion
Trbegin [F:ZTACH], [F:ZTACD]
## Saco tarifas para todas las plantas donde se venda SALFLG=2
#Filter [F:FCY]
#Filter [F:FCY] Where SALFLG=2 Order By Key FCY0
#For [F:FCY]
#  Gosub TAR_GENERAR_CTE
#Next
#Filter [F:FCY]
# PAra dar un precio, es OBLIGATORIO saber PLANTA Y FECHA
Gosub TAR_GENERAR_CTE
# Fin transaccion
If ZOK
  Commit
Else
  Rollback
  MSG="Proceso generacion tarifas ABORTADO"
  Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
Endif
Return


$TAR_GENERAR_CTE
If CTE_P<>""
  Filter [F:BPC]
  Filter [F:BPC] Where[BPC]BPCNUM=CTE_P
Else
  Filter [F:BPC] Order By Key BPC0
Endif
For [F:BPC]
  Raz [F:BPR]
  Read [BPR]BPR0=[F:BPC]BPCNUM
  CAB=1
  # Las tarifas que se aplican a un cliente estan definidas en tabla    ZBPCITMTAR  (PK=Fec+Cte+Art+Long)....De no existir aqui, se supone que no se aplicarßn, pues mediante punto de entrada se
  # desestiman los registros/tarifas que no esten aqui
#  Infbox "Depurar"
  Filter [F:ZCIT]
  If ART_P=""
    Filter [F:ZCIT] Where ANULADO<>2 and BPCNUM=[F:BPC]BPCNUM and FEC_P>=PLISTRDAT Order By PLISTRDAT Desc #Key ZCIT0
  Else
    Filter [F:ZCIT] Where ANULADO<>2 and BPCNUM=[F:BPC]BPCNUM and FEC_P>=PLISTRDAT and ITMREF=ART_P Order By PLISTRDAT Desc #Key ZCIT0
  Endif
  #######################
  #   << IMPORTANTE >>  #
  #Las tarifas se ordenan por fecha inicio DESCENDENTE, de modo que el primer precio que se grabe sea el ·ltimo, despreciandose los siguientes
  #######################
  For [F:ZCIT]
    PREC=func SPEZCIT.TARIFA_PREC(FEC_P,[F:ZCIT]BPCNUM,[F:ZCIT]ITMREF,[F:ZCIT]ZLONGITUD,[F:ZCIT]PLI,FCY_P,ZCRD,ZLIN)
    If PREC>0 # and (ZFCY="" or ZFCY=FCY_P)
      If CAB
        Gosub TAR_CAB
        If not ZOK   Break 2  Endif
      Endif
      Gosub TAR_DET
      If not ZOK   Break 2  Endif
    Endif
  Next
Next
Filter [F:ZCIT]
Filter [F:BPC]
Return

$TAR_DET
Read [F:SPL]SPL0=[F:ZCIT]PLI;ZCRD;ZLIN
If FEC_P>=[F:SPL]PLISTRDAT and FEC_P<=[F:SPL]PLIENDDAT
  Call TAR_PRECIO([F:ZCIT]ITMREF,[F:ZCIT]BPCNUM,[F:SPL]UOM,[F:SPL]PRI,WUNID,WPREC)
  Raz [F:ZTACD]
  Read [F:ZTACD]ZTACD0=GUSER;FCY_P;[F:ZCIT]BPCNUM;GFONCTION;[F:ZCIT]ITMREF;[F:ZCIT]ZLONGITUD
  If fstat=0
##############
#    25-05-17 JLPR Comento estas lineas, pues las tarifas prevalecen por fecha inicio vigencia, es decir, que una tarifa 101 puede ser sustituda por otra a partir de una fecha
#                  por ese motivo se ordenan ==>   <<< Order By PLISTRDAT Desc  >>>
##############
#    If [F:ZCIT]PLI="101" and [F:ZTACD]PLI<>[F:ZCIT]PLI #Las tarifas 101 prevalecen sobre las otras
#      [F:ZTACD]PLI      =[F:ZCIT]PLI
#      [F:ZTACD]PLICRD   =ZCRD
#      [F:ZTACD]PLICRI   =[F:SPL]PLICRI
#      [F:ZTACD]CUR      =[F:SPL]CUR
#      [F:ZTACD]PRI      =WPREC
#      [F:ZTACD]UOM      =WUNID
#      [F:ZTACD]FECREF   =FEC_P
#      [F:ZTACD]PLISTRDAT=[F:SPL]PLISTRDAT
#      [F:ZTACD]PLIENDDAT=[F:SPL]PLIENDDAT
#      [F:ZTACD]FECACT   =date$
#      Rewrite [F:ZTACD]
#      If fstat<>0
#        MSG="Error actualizando datos de tarifa "+[F:ZCIT]PLI+" grabando [ZTACD]- fstat: "+num$(fstat)
#        Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
#        ZOK=0
#      Endif
#    Endif
  Else
    [F:ZTACD]SALFCY   =FCY_P
    [F:ZTACD]BPCNUM   =[F:ZCIT]BPCNUM
    [F:ZTACD]ITMREF   =[F:ZCIT]ITMREF
    [F:ZTACD]LONGITUD =[F:ZCIT]ZLONGITUD
    [F:ZTACD]PLI      =[F:ZCIT]PLI
    [F:ZTACD]PLICRD   =ZCRD
    [F:ZTACD]PLICRI   =[F:SPL]PLICRI
    [F:ZTACD]CUR      =[F:SPL]CUR
    [F:ZTACD]PRI      =WPREC
    [F:ZTACD]UOM      =WUNID
    [F:ZTACD]FECREF   =FEC_P
    [F:ZTACD]PLISTRDAT=[F:SPL]PLISTRDAT
    [F:ZTACD]PLIENDDAT=[F:SPL]PLIENDDAT
    [F:ZTACD]CODINT   =GFONCTION
    [F:ZTACD]FECACT   =date$
    Write [F:ZTACD]
    If fstat<>0
      MSG="Error a±adiendo datos de tarifa "+[F:ZCIT]PLI+" grabando [ZTACD]- fstat: "+num$(fstat)
      Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
      ZOK=0
    Endif
  Endif
Endif
Return

$TAR_CAB
Raz CAB
Read [F:ZTACH]ZTACH0=GUSER;FCY_P;[F:BPC]BPCNUM;GFONCTION
If fstat=0
  [F:ZTACH]FECACT=FEC_P
  Rewrite [ZTACH]
Else
  [F:ZTACH]SALFCY=FCY_P
  [F:ZTACH]BPCNUM=[F:BPC]BPCNUM
  [F:ZTACH]FECACT=FEC_P
  [F:ZTACH]CODINT=GFONCTION
  Write [ZTACH]
Endif
If fstat<>0
  MSG="Error grabando [ZTACH]- fstat: "+num$(fstat)
  Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  ZOK=0
Endif
Return

Subprog TAR_PRECIO(ART,CTE,TAR_UNID,TAR_PREC,WUNID,WPREC)
Value Char       ART,CTE,TAR_UNID
Value Decimal    TAR_PREC
Variable Char    WUNID
Variable Decimal WPREC
Local Char MSG(255)
If clalev([F:ITM])<=0   :  Local File ITMMASTER [F:ITM] : Endif
If clalev([F:ITU])<=0   :  Local File ITMBPC    [F:ITU] : Endif
WUNID=TAR_UNID
WPREC=TAR_PREC
Read [F:ITU]ITU0=ART;CTE
If fstat=0
  WUNID=[F:ITU]SAU
  If TAR_UNID<>WUNID
    Read [F:ITM]ITM0=ART
    If fstat=0
      WPREC=arr(TAR_PREC*[F:ITM]ZFACTOR,0.0001)
    Endif
  Endif
Endif
End


$TAR_BORRAR
Raz CRITERIO
CRITERIO(0)="CREUSR=GUSER & SALFCY=FCY_P & CODINT=GFONCTION"
If CTE_P<>"" CRITERIO(0)+=" & BPCNUM=CTE_P"  Endif
If ART_P<>"" CRITERIO(1) =" & ITMREF=ART_P"  Endif
Delete [F:ZTACD] Where evalue(CRITERIO)
If fstat
  MSG="Error borrando precios anteriores (ZTARCTED)\Planta "+FCY_P+"  cliente "+CTE_P+" articulo "+ART_P+"   [F:ZTACD]   (fstat="+num$(fstat)+")"
  Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  ZOK=0
Endif
If BORRAR_CAB_P
  Delete [F:ZTACH] Where evalue(CRITERIO(0))
  If fstat
    MSG="Error borrando precios anteriores (ZTARCTEH)\Planta "+FCY_P+"  cliente "+CTE_P+"   [F:ZTACH]   (fstat="+num$(fstat)+")"
    Call ERREURT (MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    ZOK=0
  Endif
Endif
Return

$TAR_ABRIR_TABLAS
If clalev([F:ZTACH])<=0 : Local File ZTARCTEH   [F:ZTACH] : Endif  : #Cabecera
If clalev([F:ZTACD])<=0 : Local File ZTARCTED   [F:ZTACD] : Endif  : #Detalle
If clalev([F:ZCIT])<=0  : Local File ZBPCITMTAR [F:ZCIT]  : Endif
If clalev([F:BPC])<=0   : Local File BPCUSTOMER [F:BPC]   : Endif
If clalev([F:BPR])<=0   : Local File BPARTNER   [F:BPR]   : Endif
If clalev([F:SPL])<=0   : Local File SPRICLIST  [F:SPL]   : Endif
If clalev([F:SPF])<=0   : Local File SPRICFICH  [F:SPF]   : Endif
If clalev([F:SPC])<=0   : Local File SPRICCONF  [F:SPC]   : Endif
If clalev([F:FCY])<=0   : Local File FACILITY   [F:FCY]   : Endif
If clalev([F:CPY])<=0   : Local File COMPANY    [F:CPY]   : Endif
Return

