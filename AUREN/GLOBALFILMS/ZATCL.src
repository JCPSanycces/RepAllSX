#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$DEBUT
Return

$OUVRE
If !clalev([M:ZATCL0]) : Local Mask ZATCL0 [ZATCL0] : Endif
If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

If !clalev([M:ZATCL1]) : Local Mask ZATCL1 [ZATCL1] : Endif
If !clalev([F:BPADR1]) : Local File BPADDRESS [BPADR1] : Endif
Return

$SETBOUT
Return

$BOUTON
Return

$APRES_MODIF
Return
