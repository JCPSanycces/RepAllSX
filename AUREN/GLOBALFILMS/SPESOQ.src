$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_ZQTYBOB(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_ZANCHO(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_ZLONGITUD(VALEUR)
Variable Decimal VALEUR
Local Decimal LVOLUMEN, LESPESOR, LDENSIDAD, LSUPERFICIE, LFACTOR
Local Integer NOL
Local Integer LPOHENCNTR, LSOHENCNTR
Local Char LNUMCNTR(25)

If clalev([F:ITP])<=0 : Local File ITMBPS [ITP] : Endif
Raz [F:ITP]

NOL=nolign-1

LESPESOR=0
If [F:ITP]ZESPESORP<>0
   LESPESOR=[F:ITP]ZESPESORP
Else
   LESPESOR=[F:ITM]ZESPESOR
Endif
LDENSIDAD=0
If [F:ITP]ZDTYP<>0
   LDENSIDAD=[F:ITP]ZDTYP
Else
   LDENSIDAD=[F:ITM]DTY
Endif
LDENSIDAD=(LDENSIDAD*1000000/1000)
LFACTOR=0
If [F:ITM]ZFACTOR=0
   LFACTOR=LDENSIDAD*LESPESOR
Else
   LFACTOR=[F:ITM]ZFACTOR
Endif

LSUPERFICIE=([M:SOQ1]ZANCHO(NOL)/1000)*VALEUR
LVOLUMEN=([M:SOQ1]ZANCHO(NOL)/1000)*VALEUR*LFACTOR

If [M:SOQ1]ZQTYBOB(NOL)<>0 and [M:SOQ1]ZANCHO(NOL)<>0 and [M:SOQ1]ZMANDRIL(NOL)<>0 and VALEUR<>0
   If [M:SOQ1]SAU="M2"
      [M:SOQ1]QTY(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
   Endif
   If [M:SOQ1]SAU="KG"
      [M:SOQ1]QTY(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LVOLUMEN,0.001)
   Endif
Else
   [M:SOQ1]QTY(NOL)=[M:SOQ1]ZQTYBOB(NOL)
Endif

Affzo [M:SOQ1]QTY(NOL)

#[M:SOQ1]ZQTYALT(NOL)=0
[M:SOQ1]ZQTYKG(NOL)=0
[M:SOQ1]ZQTYM2(NOL)=0
#If [M:SOQ1]SAU="M2"
#   [M:SOQ1]ZQTYALT(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LVOLUMEN,0.001)
#Endif
#If [M:SOQ1]SAU="KG"
#   [M:SOQ1]ZQTYALT(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
#Endif
[M:SOQ1]ZQTYKG(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LVOLUMEN,0.001)
[M:SOQ1]ZQTYM2(NOL)=arr([M:SOQ1]ZQTYBOB(NOL)*LSUPERFICIE,0.001)
#Affzo [M:SOQ1]ZQTYALT(NOL)
Affzo [M:SOQ1]ZQTYKG(NOL)
Affzo [M:SOQ1]ZQTYM2(NOL)

End


######################################################################################
