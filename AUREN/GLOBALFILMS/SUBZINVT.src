$ACTION
Case ACTION
When "OUVRE"         : Gosub OUVRE
When "FILTRE"        : Gosub FILTRE
When "DEFLIG"        : Gosub DEFLIG
When "LIENS"         : Gosub LIENS
When "LIENS_LIG"     : Gosub LIENS_LIG
When "INICRE_LIG"    : Gosub INICRE_LIG
When "INIMOD_LIG"    : Gosub INIMOD_LIG
When "VALLIG"        : Gosub VALLIG
When "CREATION"      : Gosub CREATION
When "ANNULE"        : Gosub ANNULE
When "MODIF"         : Gosub MODIF
When "APRES_MOD"     : Gosub APRES_MOD
When "APRES_CRE"     : Gosub APRES_CRE

When "TITRE"         : Gosub TITRE_S
When "AFFMASK"       : Gosub AFFMASK
When "EFFMASK"       : Gosub EFFMASK
When "SETBOUT"       : Gosub SETBOUT
When "FERME"         : Gosub FERME
When "APRES_MODIF"   : Gosub APRES_MODIF
When "APRES_CHOI"    : Gosub APRES_CHOI
When "ABANDON"       : Gosub ABANDON
#Acciones control flujo CREACION       RAZCRE + VERIF_CRE + INICRE + CREATION + APRES_CRE + AB_CREATION
When "RAZCRE"        : Gosub RAZCRE
When "VERIF_CRE"     : Gosub VERIF_CRE
When "INICRE"        : Gosub INICRE
#Acciones control flujo MODIFICACION   LIENS + STYLE + AVANT_MOD + VERIF_MOD + AVANT_MOFIC + INIMOD + MODIF + APRES_MODIF + AB_MODIF
When "STYLE":        : Gosub STYLE
When "INIMOD":       : Gosub INIMOD
#Acciones control flujo BORRADO        AV_VERF_ANU + AP_VERF_ANU + VERF_ANU + AV_ANNULE + ANNULE + AP_ANNULE
#Accion tras hacer click en un boton predefinido
When "EXEACT"        : Gosub EXEACT
#Accion tras hacer click en un boton ańadido
When "EXEBOUT"       : Gosub EXEBOUT
Endcase
Return



$ABANDON
If ZFLG<>-3  ZFLG=-2    Endif
Return

$OUVRE
If clalev([F:WZINV]) <=0   :  Local File ZINVENTH     [F:WZINV]  : Endif
If clalev([F:WZINVD])<=0   :  Local File ZINVENTD     [F:WZINVD] : Endif
If clalev([F:WSID])  <=0   :  Local File SINVOICED    [F:WSID]   : Endif
If clalev([F:WSTJ])  <=0   :  Local File STOJOU       [F:WSTJ]   : Endif

#
