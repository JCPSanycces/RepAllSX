FICLIG = "ZINVENTD"
ABLIG  = "ZINVD"
ZONLIG = "NUMLIN"
Return

$LIENS
If GUSER="ADMIN"    Infbox "ZFLG="+num$(ZFLG)    Endif
Case ZFLG
When 1   # Modo AŃADIR
  Gosub ANADIR
When -3  # Salir de pantalla
  # No hago nada, ????
When -1  # ABANDON + CREATION
  Gosub LIENS From TABLEAUX
When Default
  Call OCULTAR1("-")
  Chgfmt [M:ZINVT0]FFRA  With "-"
  #Imposible modificar
  Grizo [M:ZINVT0]
  #Grizo [M:ZINVT0]FCY
  #Grizo [M:ZINVT0]ZMES
  #Grizo [M:ZINVT0]ZANO
  #Affzo [M:ZINVT1]5-10
  Gosub LIENS From TABLEAUX
Endcase
Raz ZFLG
Return

$LIENS_LIG
Return

$INIMOD_LIG
Gosub INI_LIG
Return

$INICRE_LIG
