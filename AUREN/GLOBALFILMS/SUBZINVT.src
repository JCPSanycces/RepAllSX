$TITRE_S
TIT="Inventario valorado"# <<EN PRUEBAS # PDTE.VALIDAR>>"
Return

$APRES_CHOI
Case REPONSE
When GSTAEND
  ZFLG=-3
Endcase
Return

$VERIF_CRE
#Comprobaciones If [M:ZINVT0]FRECEP=2
Raz MSG
If GFLG_VENTAS=1
   MSG+="Con datos de VENTAS\"
Else
  If [M:ZINVT0]FDIA<>0
    MSG+="A un dia determinado\"
  Endif
  If [M:ZINVT0]FITM<>""
    MSG+="De un articulo\"
  Endif
  If [M:ZINVT0]FLOT<>""
    MSG+="SOLO de un Lote\"
  Endif
  If [M:ZINVT0]FDIF<>0
    MSG+="SOLO de lineas con %Dif>=\"+num$([M:ZINVT0]FDIF)
  Endif

  If [M:ZINVT0]FAGRU=2
    MSG+="AGRUPANDO bobinas x Lote+Precio\"+num$([M:ZINVT0]FDIF)
  Endif
  If [M:ZINVT0]FRECEP=2 or [M:ZINVT0]FRECEPN<>""
    MSG+="De una recpecion o recepciones del periodo\"
  Endif
  If [M:ZINVT0]FOF=2 or [M:ZINVT0]FOFN<>""
    MSG+="De la produccion de una OF o producciones del periodo\"
  Endif
  If [M:ZINVT0]FASIGNA<>3
    MSG+="SOLO de lo asignado o sin asignar\"
  Endif
  If [M:ZINVT0]FSOLODIF=2
    MSG+="SOLO con las diferencias en precio\"
  Endif
  If [M:ZINVT1]NBLIG<=0
    MSG+="No hay lineas de inventario. Haga click en   << Consultar >>\"
  Endif
  If func ZCOMUN.ESTADO_PERIODO (gdat$(1,[M:ZINVT0]ZMES,[M:ZINVT0]ZANO),func ZCOMUN.CPY_FCY([M:ZINVT0]FCY),2)<>4
    MSG+="Sin haber cerrado perido de stock\"
  Endif
  Read [F:WZINV]ZINV0=[M:ZINVT0]CLAVE
  If fstat=0
    MSG+= "Ya existe inventario al final de "+func ZCOMUN.ML_TXT(961,[M:ZINVT0]ZMES,"SPA")+"-"+num$([M:ZINVT0]ZANO)
  Endif
Endif
If MSG<>""
  MSG="Imposible crear inventario...\"+MSG
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
  Return
Endif
# Imposible crear inventario si hay filas<>OK
Raz MSG
For F=0 To [M:ZINVT1]NBLIG-1
  If ([M:ZINVT1]ESTADO(F)<>"OK" and [M:ZINVT1]ESTADO(F)<>"SIN Materia Prima !!!") or [M:ZINVT1]VALOR(F)<0 or  [M:ZINVT1]QTYSTU(F)<0
    MSG+=num$(F+1)+"#"
  Endif
Next
If MSG<>""
  MSG="Imposible crear inventario...\Las siguientes lineas corresponden a bobinas cuya OF está pdte.Coste ó Valor (-)"+MSG
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  OK=0
  Return
Endif
# Imposible CREAR inventario si el anterior no existe
If clalev([F:WZINVH]) <=0   :  Local File ZINVENTH  [F:WZINVH]  : Endif
Filter [F:WZINVH] Where FCY=[M:ZINVT0]FCY
If rowcount([F:WZINVH])>0
  Local Date WF
  WF=addmonth(gdat$(1,[M:ZINVT0]ZMES, [M:ZINVT0]ZANO),-1)
  Filter [F:WZINVH] Where FCY=[M:ZINVT0]FCY and ZMES=month(WF) and ZANO=year(WF)
  If rowcount([F:WZINVH])<1
    Call ERREURT("Antes debe crear el inventario de "+month$(WF)+" del "+num$(year(WF)), 1) From GESECRAN   #0-Informativo, 1-Error
    OK=0
    Return
  Endif
Endif
#
YN=1
Call OUINON("Está seguro de fijar este inventario\Recuerde que su cantidad es la que se llevaria a CONTABILIDAD como Ext.Final", YN) From GESECRAN
If YN=1
  OK=0
  Return
Endif
Return

$SETBOUT
#Call ESTADO
# BOTONES, ańadidos a la derecha.    Por defecto SI habilitados
# MENUS  , ańadidos a la derecha.    Por defecto NO habilitados

#Solo consultamos cuando estamos creando
If not (GREP="C" or GREP="D")
  Call VIREBOUT(CHAINE,"1,2") From GOBJET
Endif
##Solo ajustamos despues de haber consultado Ventas
#If GFLG_VENTAS=0 or [M:ZINVT1]NBLIG<1
#  Call VIREBOUT(CHAINE,"3") From GOBJET
#Endif

#Solo podemos borrar el último inventario
If not (GREP="C" or GREP="D") and [M:ZINVT0]CLAVE<>func ULTIMO_INVT
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif

#Colorear
If GFLDNUM(2)=1
  Raz GFLDNUM(2)
  Call COLOREAR
Endif
Return

