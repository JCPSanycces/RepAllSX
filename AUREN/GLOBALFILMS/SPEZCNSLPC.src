Subprog AM_POHNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:ZCLPC]POHNUMEND=[M:ZCLPC]POHNUMSTR | [M:ZCLPC]POHNUMEND<VALEUR
   [M:ZCLPC]POHNUMEND = VALEUR
   Affzo [M:ZCLPC]POHNUMEND
Endif
End


