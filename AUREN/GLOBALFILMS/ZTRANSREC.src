#CONSULTA TRANSPORTISTAS RECOMENDADOS
# PEDRO 29/09/2016


$ACTION
 #Infbox ACTION
 Case ACTION
     When "OUVRE"       : Gosub OUVRE
     When "DEBUT"       : Gosub DEBUT
     When "BOUTON"      : Gosub EJECUTA
  Endcase
Return

########################################################################################################

$OUVRE

  If clalev([F:SOH]) = 0 Local File SORDER      [F:SOH]: Endif
  If clalev([F:SOQ]) = 0 Local File SORDERQ     [F:SOQ]: Endif
  If clalev([F:SOP]) = 0 Local File SORDERP     [F:SOP]: Endif
  If clalev([F:ITM]) = 0 Local File ITMMASTER   [F:ITM]: Endif
  If clalev([F:BPT]) = 0 Local File BPCARRIER   [F:BPT]: Endif
  If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [F:BPC]: Endif
  If clalev([F:CAA]) = 0 Local File CARAREA     [F:CAA]: Endif

Return

########################################################################################################

$EJECUTA
  Case BOUT
      When "1" :  Gosub CARGAR     # BOTON BUSCAR
  Endcase
Return

########################################################################################################

$DEBUT
  Raz [M:ZTRREC]
  Affzo [M:ZTRREC]
Return

#######################################################################################################

$CARGAR

    Local Char WFILTRO(250)
    Local Char MSG(250),TXT(250)(10), W(250)(2)
    Local Integer F
    Local Char BD_TIPO(1)
    Local Char LPEDIDOS(250)
    Local Integer LMINIMO
    Local Integer LSTANDAR

    Local Char LBPTOPT(15)
    Local Decimal LAMTOPT

    BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()

    Raz MSG,TXT,W,F

    [M:ZTRREC]NBLIG=0

    Affzo [M:ZTRREC]

    WFILTRO = "SORQ.STOFCY_0 = " +  num$([M:ZTRREC]STOFCYSTR)

    If [M:ZTRREC]FECEXPSTR <> [0/0/0] Then # DESDE FECHA
       WFILTRO = "SORQ.SHIDAT_0 >= '" + [M:ZTRREC]FECEXPSTR + "' AND " + WFILTRO
    Endif

    If [M:ZTRREC]FECEXPEND <> [0/0/0] Then # HASTA FECHA
        WFILTRO = "SORQ.SHIDAT_0 <= '" + [M:ZTRREC]FECEXPEND + "' AND " + WFILTRO
    Endif

    TXT(0)="SELECT SORQ.STOFCY_0,SORQ.SHIDAT_0,SORQ.BPCORD_0,SORQ.BPTNUM_0,SORQ.BPAADD_0,BPA.POSCOD_0,BPA.CRY_0,BPA.CTY_0,SOR.CUR_0,CHGTYP_0,ITM.WEU_0,ITM.VOU_0, "
    TXT(1)="SUM(QTY_0 * SORP.NETPRI_0) AS TOTIMP, SUM(ZQTYBOB_0) AS TOTBOB,SUM(QTY_0) AS TOTKGS , SUM(QTYSTU_0) As TOTM2, SUM(QTY_0) AS TOTPESO, SUM(QTYSTU_0) AS TOTVOL  "
    TXT(2)="From SORDERQ SORQ INNER JOIN ITMMASTER ITM ON ITM.ITMREF_0 = SORQ.ITMREF_0 INNER JOIN BPADDRESS BPA ON BPA.BPANUM_0 = SORQ.BPCORD_0 AND BPA.BPAADD_0 = SORQ.BPAADD_0  "
    TXT(3)="INNER JOIN SORDER SOR ON SOR.SOHNUM_0 = SORQ.SOHNUM_0 INNER JOIN SORDERP SORP ON SORP.SOHNUM_0 = SORQ.SOHNUM_0 AND SORP.SOPLIN_0 = SORQ.SOPLIN_0 "
    TXT(4)="Where " + WFILTRO
    TXT(5)="GROUP By SORQ.STOFCY_0,SORQ.SHIDAT_0,SORQ.BPCORD_0,SORQ.BPTNUM_0,SORQ.BPAADD_0,BPA.POSCOD_0,BPA.CRY_0,BPA.CTY_0,SOR.CUR_0,CHGTYP_0,ITM.WEU_0,ITM.VOU_0 "
    TXT(6)="Order By SORQ.STOFCY_0,SORQ.SHIDAT_0,SORQ.BPCORD_0,SORQ.BPTNUM_0,SORQ.BPAADD_0,BPA.POSCOD_0,BPA.CRY_0,BPA.CTY_0,SOR.CUR_0,CHGTYP_0,ITM.WEU_0,ITM.VOU_0"

    #### las siguientes instrucciones crean un fichero en la carpeta tmp donde esta la sentencia de SQL para poder depurar
#    Local Char FICSRV(250)
#    Local Integer YN
#    Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#    Call OUINON(FICSRV, YN) From GESECRAN
#    If YN=1
#      Return
#    Endif

    For (Char FSTOFCY(GLONFCY),Date FSHIDAT,Char FBPCORD(GLONBPC),Char FBPTNUM(GLONBPT),Char FBPAADD(5),Char FPOSCOD(5),Char FCRY(GLONCRY),Char FCTY(GLONCTY),Char FCUR(GLONCUR),
&        Integer FCHGTYP,Char FWEU(3),Char FVOU(3),Decimal FTOTIMP,Decimal FTOTBOB,Decimal FTOTKGS,Decimal FTOTM2,Decimal FTOTPESO,Decimal FTOTVOL)
&     From BD_TIPO Sql TXT As [MYT]

          F = [M:ZTRREC]NBLIG

          [M:ZTRREC]FECEXP(F)=FSHIDAT
          [M:ZTRREC]BPCNUM(F)=FBPCORD
          Read [F:BPC]BPC0  = FBPCORD
          [M:ZTRREC]BPCNAM(F)=[F:BPC]BPCNAM

          Call AVERIGUA_PEDIDOS(FSTOFCY,FSHIDAT,FBPCORD,FBPTNUM,FBPAADD,LPEDIDOS)
          [M:ZTRREC]SOHNUM(F)=LPEDIDOS

          [M:ZTRREC]BOBPED(F)=FTOTBOB
          [M:ZTRREC]QTYPED(F)=FTOTKGS
          [M:ZTRREC]QTYPEDM2(F)=FTOTM2
          [M:ZTRREC]PESO(F)=FTOTPESO

          If FBPTNUM = ""
              #Si la entrega no tiene transportista asociado se busca el optimo
              LBPTOPT = ""
              Call AVERIGUA_TRANSPORTISTA(FSTOFCY,FBPCORD,FPOSCOD,FCRY,FCTY,FCUR,FCHGTYP,FTOTIMP,FWEU,FTOTPESO,FVOU,FTOTVOL,LBPTOPT,LAMTOPT)
              FBPTNUM = LBPTOPT
          Endif

          Raz [F:BPT]
          [M:ZTRREC]BPTNUM(F)=FBPTNUM
          Read [F:BPT]BPT0  = FBPTNUM
          [M:ZTRREC]BPTNAM(F)=[F:BPT]BPTNAM

          #### Averiguamos los datos de la region del transportista
          Raz [F:CAA]
          Read [F:CAA]CAA1 = FBPTNUM;FSTOFCY;FCRY;left$(FPOSCOD,2)

          [M:ZTRREC]REGION(F) = [F:CAA]BPTARE
          [M:ZTRREC]ZDIASTRMIN(F)=[F:CAA]ZDIASTRMIN
          [M:ZTRREC]ZDIASTRSTD(F)=[F:CAA]ZDIASTRSTD

         # Call COLISAGE_ORIGINE(FSTOFCY,4,[F:SDH]SDHNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
#        If GOK = 0 | LRET <> 0
#          GMESSAGE=mess(1,137,1) : Return
#        Endif
#        # réécriture entete livraison
#        [F:SDH]PACFLG = LPACFLG
#        [F:SDH]PACNBR = LPACNBR
#        [F:SDH]NETWEI = LNETWEI
#        [F:SDH]GROWEI = LGROWEI
#        #[F:SDH]VOL    = LVOL
#        Read [F:BPT]BPT0=[F:SDH]BPTNUM
#        If [F:BPT]COEWEIVOL<>0
#           [F:SDH]VOL=LVOL*[F:BPT]COEWEIVOL
#        Endif
#        If [F:SDH]VOU = ""
#          [F:SDH]VOU = LVOU
#        Endif
#        Rewrite [SDH]

          [M:ZTRREC]NBLIG+=1

    Next

    # Ordeno el grid
    #Sorta [M:ZCITM]NBLIG Order By [M:ZCITM]ANCHO(indice),[M:ZCITM]LARGO(indice)



    Affzo [M:ZTRREC]

Return

#########################################################################################################

Subprog AVERIGUA_PEDIDOS(FSTOFCY,FSHIDAT,FBPCORD,FBPTNUM,FBPAADD,LPEDIDOS)
    Value Char FSTOFCY
    Value Date FSHIDAT
    Value Char FBPCORD
    Value Char FBPTNUM
    Value Char FBPAADD
    Variable Char LPEDIDOS
    Local Char WPEDIDO(200)

    LPEDIDOS = ""

    Filter [F:SOQ] Where [F:SOQ]STOFCY = FSTOFCY and [F:SOQ]SHIDAT = FSHIDAT and [F:SOQ]BPCORD = FBPCORD and [F:SOQ]BPAADD = FBPAADD Order By [F:SOQ]SOHNUM Asc
    For [F:SOQ]
        If WPEDIDO <> [F:SOQ]SOHNUM
            If LPEDIDOS = ""
                LPEDIDOS = [F:SOQ]SOHNUM
            Else
                LPEDIDOS = LPEDIDOS + " : " + [F:SOQ]SOHNUM
            Endif

            WPEDIDO = [F:SOQ]SOHNUM
        Endif
    Next
    Filter [F:SOQ]
End

#########################################################################################################
#Si la entrega no tiene transportista asociado se busca el optimo
Subprog AVERIGUA_TRANSPORTISTA(FSTOFCY,FBPCORD,FPOSCOD,FCRY,FCTY,FCUR,FCHGTYP,FTOTIMP,FWEU,FTOTPESO,FVOU,FTOTVOL,LBPTOPT,LAMTOPT)
    Value Char FSTOFCY
    Value Char FBPCORD
    Value Char FPOSCOD
    Value Char FCRY
    Value Char FCTY
    Value Char FCUR
    Value Integer FCHGTYP
    Value Decimal FTOTIMP
    Value Char FWEU
    Value Decimal FTOTPESO
    Value Char FVOU
    Variable Char LBPTOPT
    Value Decimal FTOTVOL
    Variable Decimal LAMTOPT

    Local Char BPTAUX(15)(1..500)
    Local Decimal LAMTFREAUX(1..500)
    Local Decimal AMTOPT
    Local Char BPTOPT(15)

    Local Char LBPTARE(15)
    Local Decimal LAMTFRE
    Local Char FRELIB(15)
    Local Integer STAT


   If clalev([F:BPTX])<=0 : Local File BPCARRIER [F:BPTX] : Endif

   Raz BPTAUX
   Raz LAMTFREAUX
   Raz AMTOPT
   Raz BPTOPT
   Raz LBPTOPT
   Raz LAMTOPT
   I=0
   For [BPTX] Where ZFCYCAL=FSTOFCY
      Call TRANSPORT([F:BPTX]BPTNUM,FBPCORD,FSTOFCY,FCRY,FCTY,FPOSCOD,
&                    FCUR,FCHGTYP,date$,FTOTIMP,FWEU,
&                    FTOTPESO,FVOU,FTOTVOL,LBPTARE,LAMTFRE,FRELIB,STAT)
&                    From TRTPRICE
      If LAMTFRE<>0
         I+=1
         BPTAUX(I)=[F:BPTX]BPTNUM
         LAMTFREAUX(I)=LAMTFRE
      Endif
   Next
   If I>0
      For J=1 To I
         If J=1
            AMTOPT=LAMTFREAUX(J)
            BPTOPT=BPTAUX(J)
         Endif
         If LAMTFREAUX(J)<AMTOPT and LAMTFREAUX(J)<>0
            AMTOPT=LAMTFREAUX(J)
            BPTOPT=BPTAUX(J)
         Endif
      Next


      LBPTOPT=BPTOPT
      LAMTOPT=AMTOPT

   Endif
End
