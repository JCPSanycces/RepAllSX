$ACTION
Case ACTION
Endcase
Return
######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla PER1) 05/05/2017 08:46:36 (ADMIN)
######################################################################################
Subprog AM_PERSTOSTA(VALEUR)
Variable Integer VALEUR
  Local Integer NOL : NOL=nolign-1
Case VALEUR
When 4 # Prohibido / Cerrado
  If not func CERRAR_OK(NOL)
    GMESSAGE="Debe cerrar el periodo anterior"
    mkstat=2
    End
  Endif
When Default # ... / Abrirlo
  If not func ABRIR_OK (NOL)
    mkstat=2
    End
  Endif
Endcase
End

Funprog CERRAR_OK(NOL)
Value Integer NOL
Local Date FEC
Local Integer OK
OK=1
# Los periodos anteriores deben estar cerrados
If NOL>0
  If [M:PER1]PERSTOSTA(NOL-1)<>4 OK=0 Endif
Else
  FEC=[M:PER1]PERSTR(NOL)
  If clalev([F:WPER])=0   : Local File PERIOD     [F:WPER]   : Endif
  Filter [F:WPER]
  Filter [F:WPER] Where CPY=[M:PER1]CPY and PERSTR<FEC and PERSTOSTA<>4
  If rowcount([F:WPER])>0
    OK=0
  Endif
Endif
End OK

Funprog ABRIR_OK(NOL)
Value Integer NOL
Local Date FEC
Local Integer OK
Local Char FC(GLONFCY)(10)
OK=1
# Solo se puede abrir si es el ˙ltimo y no hay inventario fijado
FEC=[M:PER1]PERSTR(NOL)
# 1∫) Que sea el ˙ltimo cerrado
If NOL+1<=[M:PER1]BASTAB-1
  If  [M:PER1]PERSTOSTA(NOL+1)=4
    GMESSAGE="Imposible abrir periodo\Hay periodos posteriores cerrados\Tan solo puede REABRIR el ultimo cerrado"
    OK=0
  Endif
Else
  If clalev([F:WPER])=0   : Local File PERIOD     [F:WPER]   : Endif
  Filter [F:WPER]
  # select PERSTOSTA_0,* from GLOBAL.PERIOD where CPY_0='001' and PERSTR_0>'01-05-2017' and PERSTOSTA_0=4
  Filter [F:WPER] Where CPY=[M:PER1]CPY and PERSTR>FEC and PERSTOSTA=4
  If rowcount([F:WPER])>0
    GMESSAGE="Imposible abrir periodo\Hay periodos posteriores cerrados\Tan solo puede REABRIR el ultimo cerrado"
    OK=0
  Endif
Endif
# 2∫) Que no haya inventario fijado
If OK
  Call PLANTAS_CPY([M:PER1]CPY,FC) From ZCOMUN
  If clalev([F:WZINVH])=0 : Local File ZINVENTH   [F:WZINVH] : Endif
  Filter [F:WZINVH]
  Filter [F:WZINVH] Where find (FCY,FC) and ZMES=month(FEC) and ZANO=year(FEC)
  If rowcount([F:WZINVH])>0
    GMESSAGE="Imposible abrir periodo\Hay inventarios fijados en las plantas\Deber· borrarlos antes de REABRIR el periodo"
    OK=0
  Endif
Endif
End OK
