#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "BEFORE_STW"  :  Gosub BEFORE_STW
   When "ENTW_STW"    :  Gosub ENTW_STW
   When "SOW_STW"     :  Gosub SOW_STW
Endcase
Return

$BEFORE_STW
#Infbox "PE STKINT - BEFORE_STW: "+num$(LORI)
Return

$ENTW_STW
#Infbox "PE STKINT - ENTW_STW: "+num$(LORI)
Case LORI
   When 2,9 : [M:STW]ZANCHO(NOL) = [M:ENTW]ZANCHO(I)
              [M:STW]ZMANDRIL(NOL) = [M:ENTW]ZMANDRIL(I)
              [M:STW]ZLONGITUD(NOL) = [M:ENTW]ZLONGITUD(I)
              [M:STW]ZPROVEEDOR(NOL) = [M:ENTW]ZPROVEEDOR(I)
              [M:STW]ZFACTOR(NOL) = [M:ENTW]ZFACTOR(I)
              [M:STW]ZNCORTES(NOL) = [M:ENTW]ZNCORTES(I)
              [M:STW]ZMFGDATE(NOL) = [M:ENTW]ZMFGDATE(I)
              [M:STW]ZEMPALME(NOL) = [M:ENTW]ZEMPALME(I)
#              If [F:ITM]STU="M2"
#                 [M:STW]ZFACTOR(NOL) = 1
#              Else
#              #PDTE CALCULAR FACTOR
#                 [M:STW]ZFACTOR(NOL) = [F:ITM]ZFACTOR
#              Endif

   When 4 :   [M:STW]ZANCHO(NOL) = [M:ENM]ZANCHO(I)
              [M:STW]ZMANDRIL(NOL) = [M:ENM]ZMANDRIL(I)
              [M:STW]ZLONGITUD(NOL) = [M:ENM]ZLONGITUD(I)
              [M:STW]ZPROVEEDOR(NOL) = [M:ENM]ZPROVEEDOR(I)
              [M:STW]ZFACTOR(NOL) = [M:ENM]ZFACTOR(I)
              [M:STW]ZNCORTES(NOL) = [M:ENM]ZNCORTES(I)
              [M:STW]ZMFGDATE(NOL) = [M:ENM]ZMFGDATE(I)
              [M:STW]ZEMPALME(NOL) = [M:ENM]ZEMPALME(I)

Endcase
Return

$SOW_STW
#Infbox "PE STKINT - ENTW_STW: "+num$(LORI)
Return
