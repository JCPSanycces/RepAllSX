#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "OUINON"     :   Gosub OUINON
   When "AVERTIR"    :   Gosub AVERTIR
Endcase
Return

$OUINON
#SAISTOALL -> Asignación manual
If GACTION="SAISTOALL"
   #¿Generación de un ruptura?
   #Se responde "No"
   If TEX=mess(451,196,1)
      OK=1
      GPE=1
   Endif
   #La cantidad seleccionada no corresponde con la cantidad a asignar. ¿Desea continuar registrando?
   #Se responde "Si"
   If TEX=mess(449,196,1)
      OK=2
      GPE=1
   Endif
   #Total asignado/entregado superior a la Ctd pedida
   #
   #Se responde "Si"
   If TEX=mess(449,196,1)
      OK=2
      GPE=1
   Endif
Endif
Return

$AVERTIR
#SAISTOALL -> Asignación manual
If GACTION="SAISTOALL"
   #Total asignado/entregado superior a la Ctd pedida
   #
   #Se responde "Si"
   If TEX=mess(19,191,1)
      OK=2
      GPE=1
   Endif
Endif
Return
