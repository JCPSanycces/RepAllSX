#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso integracion tickets lanzado mediante tarea programada en batch.
$ACTION
#Infbox ACTION
Case ACTION
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
Endcase
Return


$TERMINE
# Cierro traza
If !GSERVEUR
  TRA=1
  Call FERME_TRACE From LECFIC
#  Call LEC_TRACE   From LECFIC
Endif
Return


$EXEC
If !GSERVEUR
  Local Integer YN : YN=1
  Call OUINON("Estį seguro de generar salidas de RESTOS", YN) From GESECRAN
  If YN=1
    Return
  Endif
Endif

# JLPR 27-02-17   Hasta que averiguemos el origen de los restos
# Este proceso generar SALIDAS VARIAS con los dichos restos
#   1ŗ) Saco del STOCK los registros con difŖ
#   2ŗ) Hago las siguientes comprobaciones
#         - Si en la śltima OF que se USO se indico que SOBRANTE=0 entonces darlo de baja
#         - Si en la śltima asignacion
Local Integer C,I,OK,LNG_SOB,V
Local Char RFCY(GLONFCY)
Local Char TXT(255)(12),TX(255)(12),BD_TIPO(1)
Raz TXT,C,I
BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()
#
Gosub DEF_VAR
If GSERVEUR
  Onerrgo ERRBATCH
Else
  Call OUVRE_TRACE("Inicio salidas varias de restos") From LECFIC
Endif
Call ECR_TRACE("Inicio salidas varias de restos",0) From GESECRAN
#
TXT(0)="select s.STOFCY_0,s.ITMREF_0,LOT_0, SLO_0,QTYSTU_0,s.ZMANDRIL_0,ZANCHO_0,ZLONGITUD_0,a.ITMDES1_0,a.STU_0,s.LOC_0,s.STA_0 "
TXT(1)="from STOCK s inner join ITMMASTER a on s.ITMREF_0=a.ITMREF_0 "
TXT(2)="where CUMALLQTY_0<=0 and s.ITMREF_0<>'323' and s.ITMREF_0<>'900' and ZANCHO_0<>0 and s.ZFACTOR_0<>0 and ("
TXT(3)="abs(ZLONGITUD_0-case when s.ZFACTOR_0=0 or ZANCHO_0=0 then 0 else round((QTYSTU_0/s.ZFACTOR_0)/cast(ZANCHO_0 as decimal)*1000,0) end)>10 or "
TXT(4)="abs(QTYSTU_0-round((ZANCHO_0*ZLONGITUD_0/1000)*s.ZFACTOR_0,3))>10) "
TXT(5)="order by s.STOFCY_0,s.ITMREF_0,ZANCHO_0,ZLONGITUD_0"
For (Char WFCY(GLONFCY),Char WITM(GLONITM),Char WLOT(GLONLOT),Char WSLO(GLONSLO),Decimal WQTY,Integer WMAN,Integer WANC,Integer WLNG,Char WDES(GLONDES),Char WSTU(GLONUOM),Char WLOC(GLONLOC),Char WSTA(
& 1)) From BD_TIPO Sql TXT As [MYT]
  If RFCY<>[MYT]WFCY
    Gosub FIN
    RFCY=[MYT]WFCY
    C=0
  Endif
  Gosub PROCESAR
Next
Gosub FIN
Return


$PROCESAR
Call ECR_TRACE("Art.: "+[MYT]WITM+" Lote:"+[MYT]WLOT+" Slo:"+[MYT]WSLO+" "+num$([MYT]WANC)+"-"+num$([MYT]WLNG)+" QTYSTU:"+num$([MYT]WQTY),0) From GESECRAN
Gosub OK_BAJA
If not OK : Return     :  Endif
If C=0    : Gosub INI  :  Endif
# <<  Lineas  >>
LNUMLIN+=1000
#Wrseq "L",num$(LNUMLIN),LARTAUX,[F:ITM]ITMDES1,num$(LBOBSAL),num$([F:ZINVE]ANCHO),num$([F:ZINVE]MANDRIL),num$([F:ZINVE]LONGITUD),"",[F:ITM]STU,num$(LQTYSAL),[F:ITM]STU,num$(LQTYSAL) Using [ZSAL]
Wrseq "L",num$(LNUMLIN),[MYT]WITM,[MYT]WDES,num$([MYT]WQTY),num$([MYT]WANC),num$([MYT]WMAN),num$([MYT]WLNG),"",[MYT]WSTU,num$([MYT]WQTY),[MYT]WSTU,num$([MYT]WQTY) Using [TIF]
# << Lineas Det  >>
Wrseq "S",[MYT]WSTU,num$(0-[MYT]WQTY),[MYT]WLOT,[MYT]WSLO,[MYT]WLOC,[MYT]WSTA Using [TIF]
Return

$OK_BAJA
# Solo doy de baja stock que fue usado en OF con sobrante=0
# Saco sobrante de la śltima OF saldada  (c.MFGTRKFLG_0>=5)
Raz TX,LNG_SOB
TX(0)="select m.ZLONGSOB_0,QTYSTUASI_0,m.MFGNUM_0,c.TRKLAST_0 "
TX(1)="from ZMFGLOT m inner join MFGHEAD c on m.MFGNUM_0=c.MFGNUM_0 "
TX(2)="where c.MFGTRKFLG_0>=5 and ITMREF_0='"+[MYT]WITM+"' and LOT_0 ='"+[MYT]WLOT+"' and SLO_0='"+[MYT]WSLO+"' "
TX(3)="order by c.TRKLAST_0 desc,m.ROWID desc"
OK=1
LNG_SOB=-1
For (Decimal WSOB,Decimal WQAS,Char WOF(GLONVCR),Date WSEG) From BD_TIPO Sql TX As [MYT2]
  Call ECR_TRACE("OF: "+[MYT2]WOF+" Se indicó una longitud sobrante de:"+num$([MYT2]WSOB)+" consumiendose "+num$([MYT2]WQAS)+" Kgs en seguimiento del "+num$([MYT2]WSEG),-1) From GESECRAN
  LNG_SOB=[MYT2]WSOB
  If LNG_SOB>0
    OK=0
    If LNG_SOB<>[MYT]WLNG
      Call ECR_TRACE("Se omite pues la longitud sobrante<>stock",1) From GESECRAN
    Else
      Call ECR_TRACE("Se omite pues la longitud sobrante=stock",1) From GESECRAN
    Endif
  Endif
  Break
Next
If not OK:  Return :  Endif
If LNG_SOB=-1
  TX(2)=func ZCOMUN.REPLACE(TX(2), "_0>=5", "_0<5", 1, V)
  For (Decimal WSOB,Decimal WQAS,Char WOF(GLONVCR),Date WSEG) From BD_TIPO Sql TX As [MYT2]
    LNG_SOB=-2
    Call ECR_TRACE("Se omite por estar actualmente incluida en la OF en curso "+[MYT2]WOF,1) From GESECRAN
    OK=0
    Break
  Next
  If LNG_SOB=-1
    Call ECR_TRACE("No se incluyó en OF alguna (ni cerrada, ni en curso)",-1) From GESECRAN
    #Ver si lote se incluyó en una Entrega valida
    Raz TX
    TX(0)="select VCRNUM_0,VCRLIN_0,QTYSTU_0,IPTDAT_0 "
    TX(1)="from STOJOU "
    TX(2)="where VCRTYP_0=4 and ITMREF_0='"+[MYT]WITM+"' and LOT_0 ='"+[MYT]WLOT+"' and SLO_0='"+[MYT]WSLO+"'"
    For (Char WENT(GLONVCR),Integer WLIN,Decimal WQEN,Date WFEC) From BD_TIPO Sql TX As [MYT2]
      LNG_SOB=-2
      Call ECR_TRACE("Bobina entregada en "+[MYT2]WENT+"-"+num$(WLIN)+" por "+num$([MYT2]WQEN)+" Kgs de fecha "+num$([MYT2]WFEC),-1) From GESECRAN
    Next
    If LNG_SOB=-1
      OK=0
      Call ECR_TRACE("Se omite por no haberse incluido en entrega alguna (STOJOU)",1) From GESECRAN
    Endif
  Endif
Endif
Return

$INI
C=1
# Valores comunes
LDESMOV="Restos "
LSTOFCY=[MYT]WFCY
#
X1="_RESTO_"
WNOM="GFESMO"
MVTO_TYP="20"
#
Gosub ABRIR_FIC From SPEZINVE
Raz LNUMLIN
# << Cabecera >>
# Wrseq "E","20","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZSAL]
# Wrseq "E","19","",[F:ZINVE]PLANTA,format$("DDMMYYYY",[M:ZIGSM]FECMOV),LDESMOV,"","" Using [ZENT]
  Wrseq "E",MVTO_TYP,"",LSTOFCY,format$("DDMMYYYY",date$),LDESMOV,"","" Using [TIF]
Return
Return


$FIN
If C=0
  Return
Endif
#Importo
Openo Using [TIF]   #Cerramos el fichero XML generado
# Lanzamos importación
Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
# De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
WFICH = filpath(WDIR,WXML,"txt.err")
If filinfo(WFICH,0) > 0 Then
    MSG= "Hubieron Problemas en la importacion del fichero\"+WXML
    Call ERREURT(MSG,1) From GESECRAN   #0-Informativo, 1-Error
Endif
Return


$DEF_VAR
# Variables para tratamiento fichero
Local Char WDIR(250),WNOM(20),WJOB(10),WXML(250),WOUT(250),WFICH(250),TMP(255)
# Variable para generacion contenido fichero
Local Char LDESMOV(25),LSTOFCY(GLONFCY),LITMREF(GLONITM),LARTAUX(GLONITM)
Local Decimal LNUMLIN, LQTYTOT
Local Char LSLOT(GLONSLO)(500),LSTAT(1)(500),LPCU(GLONUOM)(500)
Local Decimal LQTYSTU(500)
Return



$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
