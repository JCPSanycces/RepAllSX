#===================================
#Subrutinas EVENTOS ventana
#===================================

$ACTION
#Infbox "Action " + ACTION +  "     Gaction " + GACTION
# Entrando                    AVANT_OUVRE   OUVRE     OUVRE_BOITE  TITRE   DEBUT (se ve pantalla)     SETBOUT    AV_CHOIX
# Click y mostrar ventana     APRES_MODIF   SETBOUT   AP_CHOIX     AVANT_BOUTON  (Se ve pantalla)
        # Al volver           BOUTON        SETBOUT   AV_CHOIX
# Tecla INTRO o click en OK   AP_CHOIX    AVANT_OK    OK          FIN     FINSAI
# click "Salir función"       AP_CHOIX                END         FIN     FINSAI
Case ACTION
  When "OUVRE"       :  Gosub OUVRE
  When "TITRE"       :  Gosub TITRE_S
  When "DEBUT"       :  Gosub DEBUT

  When "SETBOUT"     :  Gosub SETBOUT

  When "BOUTON"      :  Gosub BOUTON
  When "APRES_MODIF" :  Gosub APRES_MODIF

  Endcase
Return

$OUVRE
Global Char   GFICHERO(250)
# Declaración de variables
Local Char    CRITERE(250)
Local Integer F,TF,ZOK #,GENERAR

If !clalev([F:CNT])     : Local File CONTACT    [F:CNT]   : Endif
If !clalev([F:BPC])     : Local File BPCUSTOMER [F:BPC]   : Endif
If clalev([F:ZCIT])<=0  : Local File ZBPCITMTAR [F:ZCIT]  : Endif  : #Asignaciones de tarifas a clientes
If clalev([F:ZTACH])<=0 : Local File ZTARCTEH   [F:ZTACH] : Endif  : #Trabajo Cabecera
If clalev([F:ZTACD])<=0 : Local File ZTARCTED   [F:ZTACD] : Endif  : #Trabajo Detalle

TF=func ZCOMUN.FILAS_GRID("ZETARCTE1","NBLIG")
Return

$TITRE_S
TIT="Envio tarifas clientes << EN PRUEBAS # PDTE.VALIDAR >>"
Return

$DEBUT
Effzo [M:ZETC0]10-20
Raz [M:ZETC0]NCTE,[M:ZETC0]NREP,[M:ZETC0]NTIP
Raz [M:ZETC1]
# Valores por defecto
#Raz GENERAR
If [M:ZETC0]SALFCY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
   [M:ZETC0]SALFCY = GFCYDEF
   Affzo [M:ZETC0]SALFCY
Endif
[M:ZETC0]IMPRESORA="PREVISU"
Affzo [M:ZETC0]IMPRESORA
[M:ZETC0]FECHA=date$
Affzo [M:ZETC0]FECHA
[M:ZETC1]ASUNTO="TARIFAS VENTA"
Affzo [M:ZETC1]ASUNTO
Return


$APRES_MODIF
# COUZON nombre del campo
# COUIND indice en caso de ser un campo del grid
# CZ     valor del campo
Return

$SETBOUT
#If [M:ZETC1]NBLIG=0
#   Call VIREBOUT(CHAINE,"XY") From GOBJET
#Endif
##JLPR 11-05-17 Se acuerda deshabilitar botón SELECCION ARTICULOS, pues incluimos una rejilla
#Call VIREBOUT(CHAINE,"S") From GOBJET
Return

$BOUTON
Case BOUT
When "B" Gosub MOSTRAR_CTES
When "X" Gosub TRT_ENVTAR
When "Y" Gosub TRT_IMPTAR #From ZETARCTESTD
Endcase
Return

$MOSTRAR_CTES
Local Char RCTE(GLONBPC)
Local Integer ZOK

Raz CRITERE
CRITERE+="[F:BPC]BPCSTA=2 & [F:ZCIT]PLISTRDAT<=[" +format$(GFMD,[M:ZETC0]FECHA)+"]"
# Autorización planta
If GUSRFCY(1)<>"\" & ([M:ZETC0]SALFCY<>"") & GNBAUZ<>GNBSITE
   CRITERE+=" & find([M:ZETC0]SALFCY,GUSRFCY(1..GNBAUZ))"
Endif
If [M:ZETC0]NCTE>0
   CRITERE+="& find([F:ZCIT]BPCNUM,[M:ZETC0]BPCNUM)<>0"
Endif
If [M:ZETC0]NREP>0
   CRITERE+="& find([F:BPC]REP(0),[M:ZETC0]REP)<>0"
Endif
If [M:ZETC0]NTIP>0
   CRITERE+="& find([F:BPC]TSCCOD(0),[M:ZETC0]TSCCOD)<>0"
Endif
Link [F:ZCIT] With [F:BPC]BPC0=[F:ZCIT]BPCNUM As [LNK]
Filter [LNK] Where evalue(CRITERE) Order By [F:ZCIT]BPCNUM;[F:ZCIT]PLISTRDAT Desc #Key ZTACH0
Call VACIAR_REJILLA
Raz RCTE  :  ZOK=1
For [LNK]
  #Un cliente puede tener diferentes asignaciones, solo se muestra una vez
  If RCTE<>[F:ZCIT]BPCNUM
    RCTE=[F:ZCIT]BPCNUM
    Gosub DATOS
    If not ZOK    Break     Endif
  Endif
Next
Affzo [M:ZETC1]5
Return

$DATOS
F=[M:ZETC1]NBLIG
[M:ZETC1]BPCNUM(F) =[F:ZCIT]BPCNUM
[M:ZETC1]REP(F)    =[F:BPC]REP(0)
[M:ZETC1]CTEMAIL(F)=func EMAIL_CTE([F:ZCIT]BPCNUM)
[M:ZETC1]REPMAIL(F)=func ZCOMUN.EMAIL_REP([F:BPC]REP(0))
[M:ZETC1]TARIFAS(F)=2 # Los clientes salen de la tabal de asignaciones, luego siempre habrá tarifas, salvo que todas las asignaciones apuntes a taifas borradas
                      #func HAY_TARIFAS([F:ZCIT]BPCNUM)
If [M:ZETC1]NBLIG+1>=TF
  MSG="FALTAN DATOS !!!!\Alcanzado máximo de " + num$(TF) + " filas para mostrar clientes\.\Ajuste los filtros"
  Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
  Raz ZOK
Else
  [M:ZETC1]NBLIG+=1
Endif
Return

