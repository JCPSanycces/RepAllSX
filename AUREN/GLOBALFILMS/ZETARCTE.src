Funprog EMAIL_CTE(CTE)
Value Char CTE
Local Char EMAIL(GLONMAI)
#If !clalev([F:BPC]): Local File BPCUSTOMER [F:BPC] : Endif
If !clalev([F:CNT]): Local File CONTACT    [F:CNT] : Endif
Raz EMAIL
#Link [F:BPC] With  [CNT]CNT0(2)=[F:BPC]BPCNUM As [LNK]
#Filter [LNK] Where [F:BPC]BPCNUM=CTE and [F:CNT]BPATYP=1 and [F:CNT]CNTFNC=6
Filter [F:CNT] Where BPANUM=CTE and BPATYP=1 and CNTFNC=6
For [F:CNT]
  EMAIL=[F:CNT]WEB
Next
Filter [F:CNT]
End EMAIL

Funprog HAY_TARIFAS(CTE)
Value Char CTE
Local Integer SN  : SN=1
If clalev([F:ZTACD])<=0 : Local File ZTARCTED    [F:ZTACD] : Endif  : #Detalle
Filter [F:ZTACD] Where [F:ZTACD]SALFCY=[M:ZETC0]SALFCY and [F:ZTACD]BPCNUM=CTE
If rowcount([F:ZTACD])>0
  SN=2
Endif
Filter [F:ZTACD]
End SN


Subprog GENERAR_PRECIOS(ZOK)
Value Integer ZOK
Local Integer F,A,BORRAR_CAB_P
Local Char    CRITERIO(250)(2)
Local Char    CTE_P(GLONBPC),ART_P(GLONITM),FCY_P(GLONFCY)
ZOK=1
For F=0 To [M:ZETC1]NBLIG-1
  If [M:ZETC1]ENVIO(F) = 2
    If [M:ZETC0]NART<1
      Call GENERAR_TARIFAS([M:ZETC0]SALFCY,[M:ZETC0]FECHA,[M:ZETC1]BPCNUM(F),"",ZOK) From ZGENTARCTE
      If not ZOK  Break    Endif
    Else
      FCY_P       =[M:ZETC0]SALFCY
      CTE_P       =[M:ZETC1]BPCNUM(F)
      ART_P       =""
      BORRAR_CAB_P=1
      Gosub TAR_BORRAR From ZGENTARCTE
      If not ZOK  Break    Endif
      For A=0 To [M:ZETC0]NART-1
        If [M:ZETC0]ITMREF(A)<>""
          Call GENERAR_TARIFAS_1([M:ZETC0]SALFCY,[M:ZETC0]FECHA,[M:ZETC1]BPCNUM(F),[M:ZETC0]ITMREF(A),0,ZOK) From ZGENTARCTE
          If not ZOK  Break    Endif
        Endif
      Next
    Endif
  Endif
Next
If not ZOK
  Call ERREURT ("Proceso abortado por error anterior", 1) From GESECRAN   #0-Informativo, 1-Error
Endif
End

