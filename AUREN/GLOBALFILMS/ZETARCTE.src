## Etiqueta ańadida por el supervisor (pantalla ZETARCTE1) 11/05/2017 16:50:59 (ADMIN)
######################################################################################
Subprog IB_NBLIG
Raz GBOUT4,GBOUT5
If [M:ZETC1]BPCNUM(nolign-1)<>""
  GBOUT3="Tarifas cte "+[M:ZETC1]BPCNUM(nolign-1)
  GBOUT4="Cliente "+[M:ZETC1]BPCNUM(nolign-1)
Endif
If [M:ZETC1]REP(nolign-1)<>""
  GBOUT5="Rep. "+[M:ZETC1]REP(nolign-1)
Endif
End

Subprog B1_NBLIG
Local Integer I
For I=0 To [M:ZETC1]NBLIG-1
 If [M:ZETC1]TARIFAS(I)=2
  [M:ZETC1]ENVIO(I) = 2
 Endif
Next I
Affzo [M:ZETC1]ENVIO
[M:ZETC0]FLDNUM(0)=1 # Para activar recalculo tarifa
End

Subprog B2_NBLIG
Local Integer I
For I=0 To [M:ZETC1]NBLIG-1
 [M:ZETC1]ENVIO(I) = 1
Next I
Affzo [M:ZETC1]ENVIO
End

Subprog AM_NCTE
Call VACIAR_REJILLA
End

Subprog AM_NREP
Call VACIAR_REJILLA
End

Subprog AM_NTIP
Call VACIAR_REJILLA
End

Subprog AM_NART
[M:ZETC0]FLDNUM(0)=1 # Para activar recalculo tarifa
End

Subprog AM_ENVIO(VALEUR)
Variable Integer VALEUR
[M:ZETC0]FLDNUM(0)=1 # Para activar recalculo tarifa
End

