Subprog VACIAR_REJILLA
Raz [M:ZETC1]NBLIG
Effzo [M:ZETC1]5
#GENERAR=1
End



$TRT_IMPTAR
Local Integer X, TOTENV, NBENV, INTERRUPT
Local Char    TBPAR(20)(1..7)  # 0205
Local Char    TBVAL(30)(1..7)  # 0205
Local Char    NUMBPC(GLONBPC)
Local Char    IMPRE(15),NOMFICH(250)
TOTENV=0
NBENV=0
INTERRUPT=0

If [M:ZETC0]IMPRESORA=""
   Infbox "Impresora no indicada"
   Return
Endif
IMPRE =[M:ZETC0]IMPRESORA
For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
      TOTENV+=1
   Endif
Next

If TOTENV<1
  Infbox "No hay clientes seleccionados"
  Return
Endif


If [M:ZETC0]FLDNUM(0)=1
  Raz [M:ZETC0]FLDNUM(0)
  Call GENERAR_PRECIOS(ZOK)
  If not ZOK   Return    Endif
Endif

#Call OUVRE_BOITE("Envío tarifas a impresora",TOTENV) From GESECRAN : # Intégration données
#Call SET_BOITE("",TOTENV) From GESECRAN

If [M:ZETC0]IMPRESORA<>""
   For X=0 To [M:ZETC1]NBLIG-1
      If [M:ZETC1]ENVIO(X)=2
         NBENV=NBENV+1
         NUMBPC=[M:ZETC1]BPCNUM(X)
         If IMPRE="PDF"  Gosub PDF_NOMFIC   Endif
         Gosub PARAM_LST
#         Call AFF_BOITE([M:ZETC1]BPCNUM(X),NBENV,INTERRUPT) From GESECRAN
      Endif

   Next
Endif
#Call FERME_BOITE From GESECRAN
#Infbox "Enviadas "-num$(NBENV)-" tarifas"
Return

$PARAM_LST
TBPAR(1)="sitedeb"       : TBVAL(1) = [M:ZETC0]SALFCY
TBPAR(2)="sitefin"       : TBVAL(2) = [M:ZETC0]SALFCY
TBPAR(3)="clientdeb"     : TBVAL(3) = NUMBPC
TBPAR(4)="clientfin"     : TBVAL(4) = NUMBPC
TBPAR(5)="usr"           : TBVAL(5) = GUSER
TBPAR(6)="impselections" : TBVAL(6) = num$(1)
TBPAR(7)="codint"        : TBVAL(7) = GFONCTION
#Call ETAT("ZCARTARIF","",TBPAR,TBVAL) From ETAT
#GLOBAL;SERVIDOR;1807;150;SPA
#Call ETAT("ZCARTARIF",IMPRE,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3

#TBPAR(1)="sitedeb"   : TBVAL(1) = SALFCY
#TBPAR(2)="sitefin"   : TBVAL(2) = SALFCY
#TBPAR(3)="clientdeb" : TBVAL(3) = NUMBPC
#TBPAR(4)="clientfin" : TBVAL(4) = NUMBPC
#TBPAR(5)="impselections" : TBVAL(5) = num$(1)
#Call ETAT("ZCARTARIFE","PDF",GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
If IMPRE="PDF"
  Call ETAT("ZCARTARIFE",IMPRE,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
Else
  Call ETAT("ZCARTARIF" ,IMPRE,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
Endif
Return


$TRT_ENVTAR
Local Integer STAT, X, TOTENV, NBENV, INTERRUPT
Local Char NOMFICH(250)#, NOMFICH1(50)

Raz TOTENV,NBENV,INTERRUPT

If [M:ZETC1]ASUNTO=""
   Infbox "Asunto no indicado"
   Return
Endif

For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
      TOTENV+=1
   Endif
Next

If TOTENV<1
  Infbox "No hay clientes seleccionados"
  Return
Endif

If GUSER="ADMIN"
#  Infbox "Depurar   (TRT_ENVTAR)"
Endif

If [M:ZETC0]FLDNUM(0)=1
  Raz [M:ZETC0]FLDNUM(0)
  Call GENERAR_PRECIOS(ZOK)
  If not ZOK   Return    Endif
Endif


#Call OUVRE_BOITE("Envío por mail de tarifas",TOTENV) From GESECRAN : # Intégration données
#Call SET_BOITE("",TOTENV) From GESECRAN

For X=0 To [M:ZETC1]NBLIG-1
   If [M:ZETC1]ENVIO(X)=2
#      NOMFICH1="TAR_"+[M:ZETC1]BPCNUM+"_"+format$("D:YYMMDD",date$)+"_"+GUSER
#      NOMFICH1="TAR"+[M:ZETC1]BPCNUM#+format$("D:YYMMDD",date$)+GUSER
#      Call ENVTARIF([M:ZETC1]BPCNUM(X),[M:ZETC1]ASUNTO,[M:ZETC1]TEXTO1,STAT,NOMFICH,NOMFICH1,[M:ZETC1]REPMAIL(X))   ## Fichero en formato PDF
      Call ENVTARIF([M:ZETC1]BPCNUM(X),[M:ZETC1]ASUNTO,[M:ZETC1]TEXTO1,STAT,NOMFICH,[M:ZETC1]REPMAIL(X))   ## Fichero en formato PDF
      #$ESPERA2  ##2604
      #If filinfo(filpath("ZTAR",NOMFICH1,"PDF"),7)<=0: Goto ESPERA2 : Endif ## 2604
      NBENV+=1
#      Call AFF_BOITE([M:ZETC1]BPCNUM(X),NBENV,INTERRUPT) From GESECRAN
   Endif

Next

#Call FERME_BOITE From GESECRAN
#Infbox "Enviadas "-num$(NBENV)-" tarifas"
Return



Subprog ENVTARIF(NUMBPC,ASUNTO,TEXTO1,STAT,NOMFICH,REP_EMAIL)
Value Char    NUMBPC()
Value Char    ASUNTO()
Value Char    TEXTO1()
Value Integer STAT
Value Char    REP_EMAIL
Variable Char NOMFICH()


Local Char    TBPAR(20)(1..7)  # 0205
Local Char    TBVAL(30)(1..7)  # 0205
Global Char   GNUMCLI(20)
Global Char   GFICHERO(250)
Local Char    INFORME(15),IMPRE(20)
Local Char    VALCLI(250), MSG(255)
Local Shortint FUNCNT
Local Integer ZIMP,YN

Call PARCLI("ClientRootDir",VALCLI) From GLOBVAR
VALCLI+="rts\temp\"

GNUMCLI=NUMBPC

Read [F:BPC]BPC0=NUMBPC

IMPRE="PDF"
Gosub PDF_NOMFIC
Gosub PARAM_LST

ZIMP=func ZCOMUN.FICHERO_OK(GFICHERO)
While ZIMP=0
  YN=0 # Por defecto es SI
  MSG="(ENVTARIF)  Fichero no enviado debido a error ó retraso durante su impresion\"+NOMFICH+"\.\Desea comprobarlo nuevamente"
  Call OUINON(MSG, YN) From GESECRAN
  If YN=1
    Break
  Endif
  ZIMP=func ZCOMUN.FICHERO_OK(GFICHERO)
Wend
If ZIMP
  #FUNCNT: 6 - Tarifas
  FUNCNT=6
  Call ENVMAIL(NUMBPC,FUNCNT,ASUNTO,TEXTO1,NOMFICH,REP_EMAIL)
Endif
End




$PDF_NOMFIC
#NOMFICH="TAR_"+NUMBPC+"_"+format$("D:YYMMDD",date$)+"_"+GUSER+".PDF"
#Case GOS(1)
#When "unix"  : GFICHERO = filpath("ZTAR","","") + "/" + NOMFICH
#When Default : GFICHERO = filpath("ZTAR","","") + "\" + NOMFICH
#Endcase
# GFICHERO=VALCLI+NOMFICH
NOMFICH="TAR_"+NUMBPC+"_"+format$("D:YYMMDD",date$)+"_"+GUSER
GFICHERO=filpath("ZTAR",NOMFICH,"pdf")
If filinfo(GFICHERO,0) > 0 and Delfile(GFICHERO)<>0
  Call ERREURT(NOMFICH+"\AVISO !!!!!\No se pudo borrar fichero existente, para su reemplazo", 0) From GESECRAN   #0-Informativo, 1-Error
Endif
Return


Subprog ENVMAIL(NUMBPR,FUNCNT,ASUNTO,TEXTO1,FICHADJ,REP_EMAIL)
Value Char NUMBPR()
Value Shortint FUNCNT
Value Char ASUNTO()
Value Char TEXTO1()
Value Char FICHADJ()
Value Char REP_EMAIL

Local Integer TYPMES
Local Integer REQREC
Local Integer REQIMP
Local Char    USER(15)
Local Char    MAIL(50)
Local Char    OBJJOI(10)
Local Char    CLEOBJ(80)
Local Char    CHRONO(25)
Local Integer ERD
Local Char    USR_EMAIL(50)(5)
Local Integer USR_ENVOI(5)
Local Integer USR_SUIVI(5)
Local Integer USR_NB
Local Clbfile TEXCLB(5)
Local Char    TEXOBJ(80)
Local Char    PCEJOI(200)(5)
Local Integer NBJOI
Local Char    TYPJOI(10)
Local Integer CATJOI
Local Char    CONTXT(50)
Local Integer NB
Local Char    WEMA(GLONMAI)(0..1)
Raz NB
#
#08-06-17  JLPR  Se acuerda con Yolanda, enviar un solo email con copia a todos los posibles destinatarios
#
#      If GUSER="ADMIN"
#      USR_EMAIL(0)="pedro.torregrosa@grupoazeta.com"
#      USR_ENVOI(0)=2
#      USR_EMAIL(1)="joseluis.palau@grupoazeta.com"
#      USR_ENVOI(1)=2
#      USR_NB=2
#      Else
#      USR_EMAIL(0)=[F:CNT]WEB
#      USR_ENVOI(0)=2
##      USR_EMAIL(1)=func EMAIL_REP_CTE(NUMBPR)
##      USR_ENVOI(1)=2
#      USR_NB=1
#      Endif

#      USR_EMAIL(0)="joseluis.palau@grupoazeta.com"
#      USR_ENVOI(0)=2
#      USR_NB=1

# 1ş) Ańadir las 2 posibles direcciones del representante
If REP_EMAIL<>""
  Call ARRAY(REP_EMAIL,";",WEMA) From ZCOMUN
  USR_EMAIL(NB)=WEMA(0)
  USR_ENVOI(NB)=2
  NB+=1
  If WEMA(1)<>""
    USR_EMAIL(NB)=WEMA(1)
    USR_ENVOI(NB)=2
    NB+=1
  Endif
Endif

# 2ş) Ańadir las direcciones de email de todos los contactos marcados con la funcion indicada en variable   FUNCNT
Filter [F:CNT] Where BPANUM=NUMBPR and BPATYP=1 and CNTFNC=FUNCNT and WEB<>""
For [F:CNT]
  If NB>dim(USR_EMAIL)
    Infbox "Alcanzado máximo de "+num$(NB)+" destinatarios, para el cliente "+NUMBPR
    Break
  Else
    USR_EMAIL(NB)=[F:CNT]WEB
    USR_ENVOI(NB)=2
    NB+=1
  Endif
Next
Filter [F:CNT]

# 3ş) Envio del email
TYPMES=2 : #Servidor
USER  =GUSER
USR_NB=NB
TEXOBJ=ASUNTO
TEXCLB=[M:ZETC1]TEXTO1 #vireblc(TEXTO1,2)+chr$(13)+chr$(10)
If GTYPMES=2
#         Case GOS(1)
#            When "unix"  : PCEJOI(0) = filpath("ZTAR","","") + "/" + FICHADJ
#            When Default : PCEJOI(0) = filpath("ZTAR","","") + "\" + FICHADJ
#         Endcase
   PCEJOI(0) = GFICHERO
Else
   PCEJOI(0) = VALCLI + FICHADJ  ##2604
Endif
NBJOI=1
#      Infbox "ZETARCTESTD: "+USR_EMAIL(0) + " #  " + USR_EMAIL(1)
If func ZCOMUN.FICHERO_OK(PCEJOI(0))
  Call ENVOI_MAIL(TYPMES,REQREC, REQIMP,USER,MAIL,OBJJOI,CLEOBJ,CHRONO,ERD
&                ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT) From AWRKMEL
Else
  Infbox "(ENVMAIL)  Fichero no enviado debido a error durante su impresion....Inténtelo de nuevo "+FICHADJ
Endif
#For YY=0 To 14
#   If [YFO]TEXTOMAIL(YY)<>""
#      TEXCLB+=evalue([YFO]TEXTOMAIL(YY))+chr$(13)+chr$(10)
#   Else
#      TEXCLB+=chr$(13)+chr$(10)
#   Endif
#Next YY
End

