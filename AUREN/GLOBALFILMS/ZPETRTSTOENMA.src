#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN"
#Infbox "ZPETRTSTOENMA - "+ACTION
#Endif
   Case ACTION
      When "STJ_ENM"  :  Gosub STJ_ENM
      When "BEF_MAJ_DOC"  :  Gosub BEF_MAJ_DOC #Z0001
   Endcase
Return

$STJ_ENM
 [M:ENM]ZMANDRIL(LLIG)=[F:STJ]ZMANDRIL
 [M:ENM]ZLONGITUD(LLIG)=[F:STJ]ZLONGITUD
 [M:ENM]ZANCHO(LLIG)=[F:STJ]ZANCHO
 [M:ENM]ZPROVEEDOR(LLIG)=[F:STJ]ZPROVEEDOR
 [M:ENM]ZFACTOR(LLIG)=[F:STJ]ZFACTOR
 [M:ENM]ZNCORTES(LLIG)=[F:STJ]ZNCORTES
 [M:ENM]ZMFGDATE(LLIG)=[F:STJ]ZMFGDATE #Z0001
 [M:ENM]ZEMPALME(LLIG)=[F:STJ]ZEMPALME #Z0001
Return

$BEF_MAJ_DOC
#Z0001.ini
If LTYP=15
  If LQTYSTU=0 and [M:MTK0]MFGFCY="100"
    If !clalev([F:ZTMPSLO])  : Local File ZTMPSLO    [ZTMPSLO] : Endif
    Update [F:ZTMPSLO] Where [F:ZTMPSLO]MFGNUM=[M:MTK2]MFGNUMIT(LLIGDOC) and [F:ZTMPSLO]MFGLIN=[M:MTK2]MFGLIN(LLIGDOC) and [F:ZTMPSLO]MFGTRKNUM=[M:MTK0]MFGTRKNUM
&   With  [F:ZTMPSLO]USED=1,[F:ZTMPSLO]MFGTRKNUM=""
  Endif
Endif
#Z0001.fin
Return
