#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
# UTIVEN30    Utilitaire de reprise d'alimentation de la société sur   Module VENTE  #
#              les commandes ouvertes inter site/société                             #
# X3SUIVI102969                                                                      #
######################################################################################
  Call MAJ_UTIVEN30
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN30
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN30 - Update Sales Orders SORDER.CPY field") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN30 : Update Sales Orders SORDER.CPY field") From LECFIC
    Call EXE_UTIVEN30(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN30(DOSSIER)
Value Char    DOSSIER

  Call ECR_TIME("UTIVEN30 : Start folder's process"-DOSSIER) From DOSSUB
  #----- Chargement globale GMAXUPDTRS -----#
  If dim([V]GMAXUPDTRS) < 1 Then
    Global Integer GMAXUPDTRS
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW] ADW0="";"";"MAXUPDTRS"
  If fstat Then
    Raz [F:ADW]
  Endif
  If val([F:ADW]VALEUR) > 0 Then
    GMAXUPDTRS = val([F:ADW]VALEUR)
  Else
    GMAXUPDTRS = 1000
  Endif
  Close Local File [ADW]
  #----- Début mise à jour -----#
  Gosub TRT_SOH
  #----- Fin mise à jour -----#
$FIN_UTIVEN30
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVEN30 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions vente              #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Transactions vente                                             #
#-------------------------------------------------------------------------------#
$TRT_SOH
Local Shortint INDIC

  If filinfo(filpath("FIL","SORDER","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIVEN30 Sales Transactions Process : Update SORDER") From DOSSUB
  Local File =DOSSIER+".SORDER" [SOH]
  Local File =DOSSIER+".FACILITY" [FCY]
  #
  Call ECR_TIME("UTIVEN30 Sales Orders Process") From DOSSUB
  Gosub FILE_SORDER
  #
  Close Local File [SOH]
  Close Local File [FCY]
Return

#-------------------------------------------------------------------------------#
# Commandes                                                                     #
#-------------------------------------------------------------------------------#
$FILE_SORDER
  Trbegin [SOH]
  Raz [F:FCY]
  For [SOH]SOH0 Where CPY = ""
    INDIC = 0
    If [F:FCY]FCY <> [F:SOH]SALFCY Then
      Read [F:FCY]FCY0=[F:SOH]SALFCY
      If fstat Then
        Raz [F:FCY]
      Endif
    Endif
    [F:SOH]CPY = [F:FCY]LEGCPY
    INDIC = 1
    If INDIC = 1 Then
      Rewrite [SOH]
      If fstat Then
        Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN30(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN30(APPLI)
End

