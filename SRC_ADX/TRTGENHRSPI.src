$ACTION
  Case ACTION
    When "END"               :    Gosub END_DEC
    When "TERMINE"           :    Gosub TERMINE
    When "EXEC"              :    Gosub OK_DEC
    When "OK"                :    Gosub EXEC
    When "DEBUT"             :    Gosub DEBUT
    When Default
  Endcase

Return

$DEBUT
  Grizo [M:HRSPI0]DTAFIL

Return

$EXEC
  Call TEMPON(mess(46,11706,1)) From GESECRAN #DEHEN : 2016-08-22 : Replaced text with Message

Local Mask GENHRSPI0[HRSPI0]
Local Integer LPERIODE
Local Char  SLPERIODE

  LPERIODE=val(format$("N0:6X",format$("D:YYYYMM", [M:HRSPI0]ENDDAT)))

  Gosub OPEN_FILE

#######################
Local Integer A,B,C,D,E
Local Char ENREG(250)
Local Char ENREG1(241)
Local Char TYP(250)
Local Date XDATPAY
Local Integer LNUMAFFIL
Local Integer I
Local Integer MM
Local Integer AAAA

Local Decimal REVERS ,REL , PLAF  ########variable  bloc B02
Local Char PATH (250)
Local Integer XTRV : Raz [L]XTRV


  # ---- Chemin de fichier importe / File Path matter-----#
Local Char XFIL(255)

  #If [M:HRSPI0]TYPEXP=2 Then
  #   XFIL = [M:HRSPI0]DTAFIL
  #Endif

  #####  Ouvrir le fichier / Open the file

#DEHEN - Check placed for file upload - START
  If [M:HRSPI0]TYPEXP = 1
    Gosub FINDFILE
    Openi [M:HRSPI0]DTAFIL
  Endif
  If [M:HRSPI0]DTAFIL <> ""
    Openi [M:HRSPI0]DTAFIL
  Else
    GMESSAGE = mess(00154,00117,1)
    Return
  Endif

#DEHEN - Check placed for file upload - END
  adxirs =  chr$(10)
  ##############DECOUPAGE FICHIER ENTREE########################

  Repeat
    Rdseq ENREG, ENREG1
    TYP= left$(ENREG,3)
    Case TYP
    When "A00" :
                  Call SUPPRIMER([L]LPERIODE,val(mid$(ENREG,4,7)))
                  [HRSDM1]RECTYP="A00"
                  [HRSDM1]LBLTRF=mid$(ENREG,4,14)
                  [HRSDM1]CAT=mid$(ENREG,18,2)
                  [HRSDM1]RSVFLD=space$(241)
                  [HRSDM1]PER=[L]LPERIODE
                  [HRSDM1]CPYAFFNUM=val(mid$(ENREG,4,7))

                  Write[HRSDM1]

    When "A01" :
                  [HRSSA1]RGTTYP="A01"
                  [HRSSA1]CPYAFFNUM=val(mid$(ENREG,4,7))
                  [HRSSA1]PER=[L]LPERIODE
                  [HRSSA1]CPYNAM=mid$(ENREG,17,40)
                  [HRSSA1]ACT=mid$(ENREG,57,40)
                  [HRSSA1]ADD=mid$(ENREG,97,120)
                  [HRSSA1]CTY=mid$(ENREG,217,20)
                  [HRSSA1]POSCOD=mid$(ENREG,237,6)
                  [HRSSA1]SSCFDS=mid$(ENREG,243,2)
                  [HRSSA1]DATISS=mid$(ENREG+ENREG1,245,8)
                  [HRSSA1]DATRET=mid$(ENREG+ENREG1,253,8)
                  Read [HRSSA1]HRSSA0=val(mid$(ENREG,17,9));[L]LPERIODE
                  If fstat  Then
                       Write[HRSSA1]
                  Endif
                  Filter[F:HRSSA1]

    When "A02" :  [HRSSC1]RGTTYP="A02"
                  [HRSSC1]CPYAFFNUM=val(mid$(ENREG,4,7))
                  [HRSSC1]PER=[L]LPERIODE
                  [HRSSC1]SSCNUM=val(mid$(ENREG,17,9))
                  [HRSSC1]NAM=mid$(ENREG,26,60)
                  [HRSSC1]NUMCHD=val(mid$(ENREG,86,2))
                  [HRSSC1]ALF=val(mid$(ENREG,88,6))
                  [HRSSC1]ALFDED=val(mid$(ENREG,94,6))
                  [HRSSC1]NETPAY=val(mid$(ENREG,100,6))
                  [HRSSC1]RSVFLD=mid$(ENREG,106,155)

                  #[L]XTRV=0             #Correction 29/05/2015 richbond
                  #For[F:XIP]Where [F:XIP]XG_NUMSC=[HRSSC1]SSCNUM & [F:XIP]XG_AFFCNSS=2 #Correction 29/05/2015 richbond
                  #   [L]XTRV=2 : Break  #Correction 29/05/2015 richbond
                  #Next                  #Correction 29/05/2015 richbond
                  #Filter[F:XIP]         #Correction 29/05/2015 richbond+

                  Filter[F:HRSSC1]
                  Read [HRSSC1]HRSSC0=val(mid$(ENREG,17,9));[L]LPERIODE
                  If fstat Then          #and [L]XTRV=2 #Correction 29/05/2015 richbond
                       Write[HRSSC1]
                       If fstat Then Infbox "SSCNUM duplicate : "+(num$([HRSSC1]SSCNUM)) : Endif #If FSTAT <> 0, error on [HRSSC1]SSCNUM
                  Endif
                  Filter[F:HRSSC1]

    When "A03" :  [HRSSB1]RGTTYP="A03"
                  [HRSSB1]CPYAFFNUM=val(mid$(ENREG,4,7))
                  [HRSSB1]PER=[L]LPERIODE
#JASMI - 2017-07-10 - X3-40847 - START
                  ##[HRSSB1]NUMEMP=val(mid$(ENREG,17,6))
                  [HRSSB1]NUMEMP=val(mid$(ENREG,17,6))
#JASMI - 2017-07-10 - X3-40847 - END
                  [HRSSB1]TOTCHD=val(mid$(ENREG,23,6))
                  [HRSSB1]TOTINC=val(mid$(ENREG,29,12))
                  [HRSSB1]TOTDED=val(mid$(ENREG,41,12))
                  [HRSSB1]TOTNET=val(mid$(ENREG,53,12))
                  ##[HRSSB1]NUMMAT=val(mid$(ENREG,65,15))

                  Read [HRSSB1]HRSSB0=val(mid$(ENREG,17,9));[L]LPERIODE
                  If fstat  Then
                       Write[HRSSB1]
                  Endif
                  Filter[F:HRSSB1]

    When Default
    Endcase
  Until fstat <> 0

  Openo
  Openi

  Call TEMPOFF From GESECRAN

Return

$OK_DEC

  FIN=1

Return

################################################################################
$END_DEC
  Raz [M:HRSPI0]
  FIN=1

Return

$TERMINE
  End

Return

############################
$OPEN_FILE
  If clalev([F:HRSDM1])=0 : Local File HRSTADLM [HRSDM1] : Endif
  If clalev([F:HRSSA1])=0 : Local File HRSOCSECSET1 [HRSSA1] : Endif
  If clalev([F:HRSSC1])=0 : Local File HRSOCSECSET3 [HRSSC1] : Endif
  If clalev([F:HRSSB1])=0 : Local File HRSOCSECSET2 [HRSSB1] : Endif
  If clalev([F:HRSIB1])=0 : Local File HRSOCSECINC2 [HRSIB1] : Endif
  If clalev([F:HRSIA1])=0 : Local File HRSOCSECINC1 [HRSIA1] : Endif
  If clalev([F:HRSSS1])=0 : Local File HRSOCSECSETS [HRSSS1] : Endif
  If clalev([F:ID]) =0 : Local File ATABDIV [ID] : Endif
  If clalev([F:XIP])=0 : Local File EMPLOID [XIP] : Endif

Return

#DEHEN - Added code for Client side file upload
$SETTYPVAL
  [M]TYPEXP=1
  If [M]TYPEXP=1
   Call SET_NAMCLI([M]DTAFIL) From ORDSYS
   Grizo [M]DTAFIL
  Else
   [M]DTAFIL= filpath("tmp","","",nomap,"","")
   Actzo [M]DTAFIL
  Endif
Return

############################
Subprog SUPPRIMER(LPERIODE,NUMAFFIL)
Value Integer LPERIODE
Value Integer NUMAFFIL

  #######Supprimer les tables
  For[HRSDM1]
    Delete[HRSDM1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

  For[HRSSA1]
    Delete[HRSSA1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

  For[HRSSC1]
    Delete[HRSSC1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

  For[HRSSB1]
    Delete[HRSSB1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

  For[HRSIB1]
    Delete[HRSIB1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

  For[HRSIA1]
    Delete[HRSIA1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next
  For[HRSSS1]
    Delete[HRSSS1] Where PER=[L]LPERIODE and CPYAFFNUM=[L]NUMAFFIL
  Next

End

######################################################################################
## Section automatically added (screen GENHRSPI0) 01/11/2016 09:29:58 (DEHEN)
######################################################################################
Subprog C_DTAFIL(VALEUR)
Variable Char    VALEUR()
    If clalev([F:HRSSA])=0 : Local File HRSOCSECSET1 [HRSSA] : Endif
    If clalev([F:HRSDM])=0 : Local File HRSTADLM [HRSDM]     : Endif
    If clalev([F:HRSSC])=0 : Local File HRSOCSECSET3 [HRSSC] : Endif
    If clalev([F:HRSSB])=0 : Local File HRSOCSECSET2 [HRSSB] : Endif
    If clalev([F:HRSIB])=0 : Local File HRSOCSECINC2 [HRSIB] : Endif
    If clalev([F:HRSIA])=0 : Local File HRSOCSECINC1 [HRSIA] : Endif
    If clalev([F:HRSSS])=0 : Local File HRSOCSECSETS [HRSSS] : Endif

For [HRSDM]
Delete [HRSDM]
Next

For [HRSSA]
Delete [HRSSA]
Next

For [HRSSC]
Delete [HRSSC]
Next

For [HRSSB]
Delete [HRSSB]
Next

For [HRSIB]
Delete [HRSIB]
Next

For [HRSIA]
Delete [HRSIA]
Next

For [HRSSS]
Delete [HRSSS]
Next

End

######################################################################################

######################################################################################
## Section automatically added (screen GENHRSPI0) 04/06/2016 13:26:34 (DEHEN)
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
  If VALEUR = 1
    Grizo [M:HRSPI0]DTAFIL
  Else
    Actzo [M:HRSPI0]DTAFIL
  Endif

End

$FINDFILE
Local Char FPATH(250)
Local Char FNAME(250)
Local Char URL(250)
Local Integer STAT
 FPATH = [M:HRSPI0]DTAFIL
 FNAME = [M:HRSPI0]DTAFIL
 #Call SET_FICNAM(FNAME,FPATH,URL) From ORDSYS #** Determination of the name of a file on the server to copy on the client
 Call COPSRV(FNAME,FPATH,STAT) From ORDSYS #Copying a client file to the server
#STAT = 1 : # upload canceled
#STAT = 0 : # upload OK
 If STAT : FIN = 0 : Return : Endif
 GFICPATH = FNAME
 [M:HRSPI0]DTAFIL = FPATH

Return

