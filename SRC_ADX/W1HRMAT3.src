$ON_DISRSN
Onevent INIT_AREA Call D_DISRSN(zc) From W1HRMAT3
Onevent CONTROL Call C_DISRSN(zc) From W1HRMAT3
Onevent BEFORE_INPUT Call AS_DISRSN(zc) From W1HRMAT3
Onevent AFTER_CHANGE Gosub AMM_DISRSN From W1HRMAT3
Return

Subprog D_DISRSN(VALEUR)
Variable Char    VALEUR()
If varinit([M]DISRSN,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11670","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_DISRSN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11670") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DISRSN(zc) From W1HRMAT3
Onkey   2 Titled GBOUTS Call S_DISRSN(zc) From W1HRMAT3
Onkey 144 Titled GBOUTP Call P_DISRSN(zc) From W1HRMAT3
Onkey 146 Titled GBOUTA Call SA_DISRSN(zc) From W1HRMAT3
If VALEUR="" : Call INIADI(VALEUR,"11670") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_DISRSN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"11670","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"11670",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DISRSN
Call AM_DISRSN(zc)
If !mkstat & GOBJET
 zoncou = "DISRSN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DISRSN(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZDISRSN)")>indice
 [M]DISRSN(indice) = VALEUR
 Affzo ZDISRSN(indice)
Endif
Gosub _AFF
End

Subprog S_DISRSN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11670"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DISRSN(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11670") From GOBJET
Gosub _AFF
End

Subprog SA_DISRSN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11670"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DISRSN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11670"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDISRSN
Onevent BEFORE_AREA Gosub AV_ZDISRSN From W1HRMAT3
Return

$AV_ZDISRSN
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11670",num$([M]DISRSN(indice))) From ATEXTRA
Gosub _AFF
Return

