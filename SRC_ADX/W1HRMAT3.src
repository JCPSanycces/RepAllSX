#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:41"
A_USER  = "DOC"
A_STAMP = "20181109230441"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBHDC"
  If [M]NBHDC=0
  Endif
 When "NBRPAS"
  If [M]NBRPAS=0
  Endif
 When "NBRCHEF"
  If [M]NBRCHEF=0
  Endif
 When "ITMNBR"
  If [M]ITMNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT3 [EMP3]
Gosub HORODAT
Local Inpbox "HRMAT3" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP3] As [SIM_]
Grizo [EMP3]10
Grizo [EMP3]20
Grizo [EMP3]22
Grizo [EMP3]25
Grizo [EMP3]35
Grizo [EMP3]40
Grizo [EMP3]60
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=50 : Y1(0)=1 : Y2(0)=8
X1(1)=1 : X2(1)=50 : Y1(1)=9 : Y2(1)=13
X1(2)=51 : X2(2)=138 : Y1(2)=1 : Y2(2)=8
X1(3)=51 : X2(3)=138 : Y1(3)=9 : Y2(3)=13
X1(4)=1 : X2(4)=138 : Y1(4)=16 : Y2(4)=16
X1(5)=1 : X2(5)=138 : Y1(5)=14 : Y2(5)=15
X1(7)=1 : X2(7)=138 : Y1(7)=17 : Y2(7)=23
Return

$ON_PFLTEL
Onevent BEFORE_AREA Gosub AV_PFLTEL From W1HRMAT3
Onevent CONTROL Call C_PFLTEL(zc) From W1HRMAT3
Onevent AFTER_CHANGE Gosub AMM_PFLTEL From W1HRMAT3
Return

$AV_PFLTEL
## Action FMTTELPAY
Call FMTTELPAY([M:EMP1]CRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]PFLTEL(indice) With "K:"+GFMT
Else
 Chgfmt [M]PFLTEL(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_PFLTEL(VALEUR)
Variable Char    VALEUR()
## Action ACNTTEL
Call CONTTEL(VALEUR,[M:EMP1]CRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "PFLTEL" : GZNUM = 289 : Endif
Gosub _AFF
End

$AMM_PFLTEL
Call AM_PFLTEL(zc)
If !mkstat & GOBJET
 zoncou = "PFLTEL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PFLTEL(VALEUR)
Variable Char    VALEUR()
## Action ACNTTELMOD
Call CONTTELMOD(VALEUR,[M:EMP1]CRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "PFLTEL" : GZNUM = 289 : Endif
Gosub _AFF
End

