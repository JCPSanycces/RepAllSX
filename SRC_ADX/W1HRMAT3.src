Return

Subprog C_PASNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_PASNUM(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "PASNUM" : GZNUM = 1120 : Endif
Gosub _AFF
End

$ON_PASDTE
Onevent BEFORE_AREA Gosub AV_PASDTE From W1HRMAT3
Return

$AV_PASDTE
Chgfmt [M]PASDTE(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_PASCRY
Onevent CONTROL Call C_PASCRY(zc) From W1HRMAT3
Onevent BEFORE_INPUT Call AS_PASCRY(zc) From W1HRMAT3
Onevent INIT_AREA Call D_PASCRY(zc) From W1HRMAT3
Return

Subprog D_PASCRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]PASCRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PASCRY(zc) From W1HRMAT3
Onkey   2 Titled GBOUTS Call S_PASCRY(zc) From W1HRMAT3
Onkey 144 Titled GBOUTP Call P_PASCRY(zc) From W1HRMAT3
Onkey 146 Titled GBOUTA Call SA_PASCRY(zc) From W1HRMAT3
Gosub _AFF
End

Subprog C_PASCRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PASCRY" : GZNUM = 263 : Endif
Gosub _AFF
End

Subprog S_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_PASCRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_EXPDAT
Onevent BEFORE_AREA Gosub AV_EXPDAT From W1HRMAT3
Return

$AV_EXPDAT
Chgfmt [M]EXPDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_PASAMD
Onevent INIT_AREA Call D_PASAMD(zc) From W1HRMAT3
Return

Subprog D_PASAMD(VALEUR)
Variable Integer VALEUR
If varinit([M]PASAMD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

