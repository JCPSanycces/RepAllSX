Endif
Return

Subprog AM_DATSTRHDC(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_DATSTRHDC(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "DATSTRHDC" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_DATENDHDC
Onevent CONTROL Call C_DATENDHDC(zc) From W1HRMAT3
Onevent AFTER_CHANGE Gosub AMM_DATENDHDC From W1HRMAT3
Onevent BEFORE_AREA Gosub AV_DATENDHDC From W1HRMAT3
Return

$AV_DATENDHDC
Chgfmt [M]DATENDHDC(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATENDHDC(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_DATENDHDC(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "DATENDHDC" : GZNUM = 1806 : Endif
Gosub _AFF
End

$AMM_DATENDHDC
Call AM_DATENDHDC(zc)
If !mkstat & GOBJET
 zoncou = "DATENDHDC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DATENDHDC(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_DATENDHDC(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "DATENDHDC" : GZNUM = 1806 : Endif
Gosub _AFF
End

$ON_PASNUM
