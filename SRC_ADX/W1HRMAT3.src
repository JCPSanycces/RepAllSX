Subprog AS_PFLEML(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PFLEML(zc) From W1HRMAT3
Gosub _AFF
End

Subprog S_PFLEML(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ASELEMAIL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ASELEMAIL"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMAIL","TRTBPA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

