#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGSPA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SPABPCTSD
mkstat = 0
zoncou = "SPABPCTSD"
indice = 0
If varmode([M]SPABPCTSD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPABPCTSD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPABPSTSD
mkstat = 0
zoncou = "SPABPSTSD"
indice = 0
If varmode([M]SPABPSTSD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPABPSTSD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPAYEATSD
mkstat = 0
zoncou = "SPAYEATSD"
indice = 0
If varmode([M]SPAYEATSD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAYEATSD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FMTCUR
mkstat = 0
zoncou = "FMTCUR"
indice = 0
If varinit([M]FMTCUR,indice)=0
 [M]FMTCUR = "N+:13.2"
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGSPA"
Return

