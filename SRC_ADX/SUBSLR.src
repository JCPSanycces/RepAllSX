#<AdxTL>@(#)209.0.0.0 $Revision$
Call OBJET ("SLR",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLR : Transactions de saisie des retours clients    EB  03/12/97 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLR]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération d' 1 écran de saisie à partir de l'écran de base  SRH1   #
#                                                                     #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                4 -    livraisons                    #
#                                5 -    factures                      #
#                                6 -    retours client                #
#                                7 -    retours prêt                  #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1                                    #
#######################################################################
$ACTION
Case ACTION
 When "APRES_CRE"   : Gosub ESSAI
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=6
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "EFFMASK"     : [M]STRTYP = 6
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "LIENS"       : [M:ETR2]STACOD=[F:SLT]AQRCOD : # Particularité pour les retours : Statut
                      [M:ETR2]STASCR=[F:SLT]AQRSCR : # Particularité pour les retours : Statut
                      If dim([M:SLR1]WRHCOD) >0    : # Dépôt
                         If [M:SLR1]WRHCOD=0  [M:SLR1]WRHCOD=3  Endif
                         If [M:SLR1]WRHOBY = 2
                            Grizo [M:SLR1]WRHCOD
                         Else
                            Actzo [M:SLR1]WRHCOD
                         Endif
                      Endif
                      Gosub LIENS From SUBSLX : Gosub TRT_DIETRS From SUBDST
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : # Particularité pour les retours : Statut
                      If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0
                        [F:SLT]AQRCOD=[M:ETR2]STACOD
                        [F:SLT]AQRSCR=[M:ETR2]STASCR
                        If [F:SLT]AQRSCR=0 [F:SLT]AQRSCR=1: Endif
                        If [F:SLT]AQRCOD=0 [F:SLT]AQRCOD=1: Endif
                      Endif
                      Gosub INICRE From SUBSLX
 When "INIMOD"      : # Particularité pour les retours : Statut
                      If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0
                        [F:SLT]AQRCOD=[M:ETR2]STACOD
                        [F:SLT]AQRSCR=[M:ETR2]STASCR
                        If [F:SLT]AQRSCR=0 [F:SLT]AQRSCR=1: Endif
                        If [F:SLT]AQRCOD=0 [F:SLT]AQRCOD=1: Endif
                      Endif
                      Gosub INICRE From SUBSLX
 When "SEL_TABLE"   : Gosub SEL_TABLE  : # Sélection sur code pièce auto
 When Default
Endcase
Return

$ESSAI
Call DEBTRANS From GLOCK
Trbegin ADOVAL
Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
Return


#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char APPLI
APPLI=nomap
# Pour génération des écrans et fenêtres de stock
Local Char WMODU(2) : WMODU="K"
Local Char WNOMOBJ(GLONAOB)
Local Char WNOMTRS(GLONTRS)
Local Char WACSCOD(GLONACS)
Local Char WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Return


#-------------------------------------------------------#
# Ne traiter que les transactions de type retour        #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=6"
Return

#---------------------------------#
# Désactivation des boutons       #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur les boutons         #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$RAZCRE
[M:SLR0]ENAFLG = 2
If dim([M:SLR1]WRHCOD)>0 [M:SLR1]WRHCOD=3 Endif

# Pour génération des écrans et fenêtres de stock
WMODU+=num$([M:SLR0]STRTYP)
Gosub RAZCRE From SUBETR

Return

$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "ENTCOD"   : # Pièce auto de sortie stock
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(WMODU)<0 Local Char    WMODU(3) : Endif
If dim(APPLI)<0 Local Char    APPLI    : Endif
If dim(OK)<0    Local Integer OK       : Endif
If APPLI=""     APPLI=nomap      : Endif
If WMODU=""     WMODU="K"        : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON
# Local Char    BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées
#------------------------- écran SRH1 -------------------------#
MFROM="SRH1"
WMODU+=num$([M:SLR0]STRTYP)                # hcb 106376
MTO="WK"+num$([M:SLR0]STRTYP)+[M:SLR0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- client facture
     If   [M:SLR2]BPCINVCOD > 1 TZONE(IZON)="BPCINV"
                                TMOD(IZON) =[M:SLR2]BPCINVCOD
                                IZON+=1
     Endif
     #---- inter-sites
     If   [M:SLR1]BETFCYCOD<>2  TZONE(IZON)="BETFCY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- date retour prévue
     If   [M:SLR2]EXTRTNCOD > 1 TZONE(IZON)="EXTRTNDAT"
                                TMOD(IZON) =[M:SLR2]EXTRTNCOD
                                IZON+=1
     Endif
     #---- inter-sociétés
     If   [M:SLR1]BETCPYCOD<>2  TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- Réception à quai
     If   [M:SLR1]SRGWAIFLG<>2  TZONE(IZON)="SRGLOCDEF" : # Si autorisée => champ emplacement quai par défaut
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- Dépôt entête
     If dim([M:SLR1]WRHCOD) >0
        If [M:SLR1]WRHCOD > 1   TZONE(IZON)="WRHE"
                                TMOD(IZON) =[M:SLR1]WRHCOD
                                IZON+=1
        Endif
     Else
        # Bug 63618
        # Gestion des dépots désactivée (Code activité WRH inactif) : Forcer le champ WRHE invisible
        TZONE(IZON)="WRHE"
        TMOD(IZON) =3
        IZON+=1
        # Bug 63618
     Endif
     #---- désignation traduite de l'article
     If   [M:SLR2]ITMDESCOD > 1 TZONE(IZON)="ITMDES"
                                TMOD(IZON) =[M:SLR2]ITMDESCOD
                                IZON+=1
     Endif
     If   [M:SLR2]ITMDESCOD = 1 | [M:SLR2]ITMDESCOD = 2
        ZT="ITMDESSCR" : ZM="ITMDES" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- désignation standard de l'article
     If   [M:SLR2]ITMDES1COD> 1 TZONE(IZON)="ITMDES1"
                                TMOD(IZON) =[M:SLR2]ITMDES1COD
                                IZON+=1
     Endif
     If   [M:SLR2]ITMDES1COD = 1 | [M:SLR2]ITMDES1COD = 2
        ZT="ITMDES1SCR" : ZM="ITMDES1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- quantité retour prévue
     If   [M:SLR2]EXTQTYCOD > 1 TZONE(IZON)="EXTQTY"
                                TMOD(IZON) =[M:SLR2]EXTQTYCOD
                                IZON+=1
     Endif
     If   [M:SLR2]EXTQTYCOD = 1 | [M:SLR2]EXTQTYCOD = 2
        ZT="EXTQTYSCR" : ZM="EXTQTY" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- qté livrée
     If   [M:SLR1]DLVQTYCOD = 1 TZONE(IZON)="DLVQTY"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="DLVQTYSCR" : ZM="DLVQTY" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- prix net
     If   [M:SLR1]NETPRICOD = 1 TZONE(IZON)="NETPRI"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="CUR"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="NETPRISCR" : ZM="NETPRI" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="NETPRISCR" : ZM="CUR"    : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- motif retour
     If   [M:SLR2]RTNRENCOD > 1 TZONE(IZON)="RTNREN"
                                TMOD(IZON) =[M:SLR2]RTNRENCOD
                                IZON+=1
     Endif
     If   [M:SLR2]RTNRENCOD = 1 | [M:SLR2]RTNRENCOD = 2
        ZT="EXTQTYSCR" : ZM="RTNREN" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- date retour
     If   [M:SLR2]RTNDATCODD > 1 TZONE(IZON)="DETRTNDAT"
                                TMOD(IZON) =[M:SLR2]RTNDATCODD
                                IZON+=1
     Endif
     If   [M:SLR2]RTNDATCODD = 1 | [M:SLR2]RTNDATCODD = 2
        ZT="EXTQTYSCR" : ZM="DETRTNDAT" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- commande réactivée
     If   [M:SLR2]ORDUPDCOD > 1 TZONE(IZON)="ORDUPD"
                                TMOD(IZON) =[M:SLR2]ORDUPDCOD
                                IZON+=1
     Endif
     If   [M:SLR2]ORDUPDCOD = 1 | [M:SLR2]ORDUPDCOD = 2
        ZT="ORDUPDSCR" : ZM="ORDUPD" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- deduit fact
     If   [M:SLR1]INVUPDCOD = 1 TZONE(IZON)="RTNINVUPD"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="INVUPDSCR" : ZM="RTNINVUPD" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- objet avoir
     If   [M:SLR2]CNOFLGCOD > 1 TZONE(IZON)="RTNCNOFLG"
                                TMOD(IZON) =[M:SLR2]CNOFLGCOD
                                IZON+=1
     Endif
     If   [M:SLR2]CNOFLGCOD = 1 | [M:SLR2]CNOFLGCOD = 2
        ZT="CNOFLGSCR" : ZM="RTNCNOFLG" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- no avoir
     If   [M:SLR1]CNONUMCOD = 1 TZONE(IZON)="SIHNUM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="SIDLIN"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="CNONUMSCR" : ZM="SIHNUM" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="CNONUMSCR" : ZM="SIDLIN" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # 71065 : PJT
     #---- Affaire à la ligne
     If   [M:SLR2]PJTCODD >1 TZONE(IZON)="DPJT"
                                TMOD(IZON) =[M:SLR2]PJTCODD
                                IZON+=1
     Endif
     If   [M:SLR2]PJTCODD = 1 | [M:SLR2]PJTCODD = 2
        ZT="PJTSCRD" : ZM="DPJT" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # 71065 : PJT
     #---- no livraison
     If   [M:SLR1]DLVNUMCOD = 1 TZONE(IZON)="DETSDHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="DLVNUMSCR" : ZM="DETSDHNUM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- no retour fournisseur
     If   [M:SLR1]PNHNUMCOD = 1 TZONE(IZON)="PNHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="PNHNUMSCR" : ZM="PNHNUM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif


     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

     #--- Pour génération des écrans et fenêtres de stock
     Gosub TRT_CHAMP_DOC From SUBETR
     OPT1 = 2
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX
     #---- suppression du masque
Else OPT1=9
Endif
Local Char NBRC_MSK   (GLONAMK) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (GLONAVA) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SRH2 -------------------------#
MFROM="SRH2"
MTO="WK"+num$([M:SLR0]STRTYP)+[M:SLR0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- date expiration du retour
     If   [M:SLR2]EXYDATCOD > 1 TZONE(IZON)="EXYDAT"
                                TMOD(IZON) =[M:SLR2]EXYDATCOD
                                IZON+=1
     Endif
     #---- opérateur autorisé
     If   [M:SLR2]AUZUSRCOD > 1 TZONE(IZON)="AUZUSR"
                                TMOD(IZON) =[M:SLR2]AUZUSRCOD
                                IZON+=1
     Endif
     #---- famille mouvement
     If   [M:SLR2]TRSFAMCOD > 1 TZONE(IZON)="TRSFAM"
                                TMOD(IZON) =[M:SLR2]TRSFAMCOD
                                IZON+=1
     Endif
     # --------------------------------------
     # FGR 07/07/2014 : X3SUIVI91606 (début)
     #---- matricule
     If   [M:SLR2]LICPLATCOD > 1 TZONE(IZON)="LICPLATER"
                                TMOD(IZON) =[M:SLR2]LICPLATCOD
                                IZON+=1
     Endif
     #---- matricule remorque
     If   [M:SLR2]TRAPLTCOD > 1 TZONE(IZON)="TRLLICPLATER"
                                TMOD(IZON) =[M:SLR2]TRAPLTCOD
                                IZON+=1
     Endif
     #---- date départ
     If   [M:SLR2]DPEDATCOD > 1 TZONE(IZON)="DPEDATR"
                                TMOD(IZON) =[M:SLR2]DPEDATCOD
                                IZON+=1
     Endif
     #---- date arrivée
     If   [M:SLR2]ARVDATCOD > 1 TZONE(IZON)="ARVDATR"
                                TMOD(IZON) =[M:SLR2]ARVDATCOD
                                IZON+=1
     Endif
     #---- heure départ
     If   [M:SLR2]ETDCOD     > 1 TZONE(IZON)="ETDR"
                                TMOD(IZON) =[M:SLR2]ETDCOD
                                IZON+=1
     Endif
     #---- heure arrivée
     If   [M:SLR2]ETACOD     > 1 TZONE(IZON)="ETAR"
                                TMOD(IZON) =[M:SLR2]ETACOD
                                IZON+=1
     Endif
     # FGR 07/07/2014 : X3SUIVI91606 (fin)
     # --------------------------------------
     # 71065 : PJT
     #---- Affaire en-tête
     If   [M:SLR2]PJTCOD > 1    TZONE(IZON)="PJT"
                                TMOD(IZON) =[M:SLR2]PJTCOD
                                IZON+=1
     Endif
     # 71065 : PJT
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        # ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
        #TBLOC(3)=2 :# TBLOC(2)=2 :#--CPO 105136 New block added in screen definition +1 for block index
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        TBLOC(3)=1 :# TBLOC(2)=1 :#--CPO 105136 New block added in screen definition +1 for block index
     Endif

     OPT1 = 2
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- visualisation du masque généré
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif
Local Char NBRC_MSK   (GLONAMK) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (GLONAVA) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

Gosub NBR_COL_AP From SUBSLX   : If GOK<1 Return Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif
#----
#--- Génération des écrans et fenêtres de stock
WNOMOBJ="SRH"
WNOMTRS=[M:SLR0]STRNUM
WACSCOD=[M:SLR0]ACSCOD
# WLIBEL =[M:SLR0]STRDES
Local Char WLIBEL (40)
Call LECTEXTRA (WLIBEL,"SALTRS","DESAXX",num$([M:SLR0]STRTYP),[M:SLR0]STRNUM) From ATEXTRA
WENAFLG=[M:SLR0]ENAFLG
WNUM   =2
Gosub TRT_ECRAN_STO From SUBETR
Return
########################################
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation transactions retours depuis génération des patchs
Call GENPATCH(6,APPLI) From FUNSALTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions vente à partir du dico des types de transaction
Call GENDOS(6,APPLI) From FUNSALTRS

End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=5
Local Integer TYP       : TYP=6
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran SLR1) 23/09/2009 10:58:43 (TS)
######################################################################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:SLR1]WRHCOD = 1
    Grizo [M:SLR1]WRHCOD
Else
    Actzo [M:SLR1]WRHCOD
Endif
Affzo [M:SLR1]WRHCOD
End

######################################################################################

