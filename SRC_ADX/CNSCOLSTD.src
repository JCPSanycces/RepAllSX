[M]FLG = 0
End

Subprog C_SPDFLG(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
   Grizo [M]ITMREF
   Grizo [M]LOT
   Grizo [M]SERNUM
   Raz   [M]ITMREF
   Raz   [M]LOT
   Raz   [M]SERNUM
   Affzo [M]ITMREF
   Affzo [M]LOT
   Affzo [M]SERNUM
Else
   Actzo [M]ITMREF
   Actzo [M]LOT
   Actzo [M]SERNUM
Endif

End

#########################################################################
# Bouton "Colisage"
#########################################################################
Subprog B1_NBLIG
Local  Char VALBOUT(250) , PARBOUT(250)(1..20)
Global Char GVCRNUMCOL(GLONVCR)
Raz GVCRNUMCOL
PARBOUT(1) = num$([M]VCRTYP(nolign-1))
PARBOUT(2) = ""
FLGEXE     = 1
GCONSULT   = 2
GPKGTYP    = [M:COL2]PKGTYP1(nolign-1)
GVCRNUMCOL = [M:COL2]VCRNUM (nolign-1)
[M:COL1]PKGTYP = [M:COL2]PKGTYP1(nolign-1)
If !clalev([F:ACT1]) : Local File ACTION [ACT1] : Endif                                   # hcb 72959

# 1=Colisage déclaratif / 2=Post-Colisage
Case [M:COL1]PKGTYP
 When 1 : GACTION = "SAIPKD"
          Read [F:ACT1]ACTION=GACTION                                                      # hcb 72959
          If fstat
             Raz [F:ACT1]
          Endif
          Call SAISIE_CHAR(VALBOUT,PARBOUT,"FPKD","FUNPKD",[F:ACT1]SPETRT) From GSAISIE    # hcb 72959
 When 2 : GACTION = "SAIPKP"
          Read [F:ACT1]ACTION=GACTION                                                      # hcb 72959
          If fstat
             Raz [F:ACT1]
          Endif
          Call SAISIE_CHAR(VALBOUT,PARBOUT,"FPKP","FUNPKP",[F:ACT1]SPETRT) From GSAISIE    # hcb 72959
Endcase
GCONSULT = 0
End

#########################################################################
# Bouton "Document origine"
#########################################################################
Subprog B2_NBLIG
Local Char NUM
GCONSULT = 2
Case [M:COL2]VCRTYP(nolign-1)
When 3       # preparation
      NUM = num$([M:COL2]VCRTYP(nolign-1))
      Call OBJET("PRH",[M:COL2]VCRNUM(nolign-1),NUM) From GOBJET
When 4       # livraison
      Call OBJET("SDH",[M:COL2]VCRNUM(nolign-1),NUM) From GOBJET
Endcase
GCONSULT = 0
End




