#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque CONSSAR2
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : [M:CCOL]   = [M:COL1]
                      Gosub DEB_CRIT                             # hcb 110327-pck
  When "FIN_CRIT"   : [M]FLG = 0
                      [M:COL1]   = [M:CCOL]
  When Default
Endcase
Return
############################################################
$AUTORIS
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:SPH]) = 0 : Local File SPACK      [SPH] : Endif
If clalev([F:SPD]) = 0 : Local File SPACKD     [SPD] : Endif
If clalev([F:SDH]) = 0 : Local File SDELIVERY  [SDH] : Endif
If clalev([F:SDD]) = 0 : Local File SDELIVERYD [SDD] : Endif
If clalev([F:PRH]) = 0 : Local File STOPREH    [PRH] : Endif
If clalev([F:PRE]) = 0 : Local File STOPRED    [PRE] : Endif
If clalev([F:BPT]) = 0 : Local File BPCARRIER  [BPT] : Endif
If clalev([F:AUS]) = 0 : Local File AUTILIS    [AUS] : Endif
If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:TPA]) = 0 : Local File TABPACKAGE [TPA] : Endif
If clalev([F:SRT]) = 0 : Local File STKTRS     [SRT] : Endif
If clalev([F:BPD]) = 0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:BPT]) = 0 : Local File BPCARRIER  [BPT] : Endif
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:STS]) = 0 : Local File STOSER     [STS] : Endif                  # hcb 110327-pck

Return
############################################################
$OUVRE
Local  Char    WPAR
Local  Char    WFILSPH  (250)
Local  Char    WFILSPD  (250)
Local  Char    WFILSDH  (250)
Local  Char    WFILPRH  (250)
Local  Char    WFILFOR  (250)
Local  Char    WFILSPE  (250)
Local  Char    WCRITTR1 (20)
Local  Char    WCRITTR2 (20)
Local  Char    WCRITTR3 (20)
Local  Integer WFSTAT, WREAD, WSKIP, WLIG
Local  Integer WGCONSULT : WGCONSULT = GCONSULT
Local  Char    WLOT(GLONLOT)
Local  Char    WSLO(GLONSLO)

Local Char    DITM(GLONITM), FITM(GLONITM)
Local Char    DLOT(GLONLOT), FLOT(GLONLOT)
Local Char    DSLO(GLONSLO), FSLO(GLONSLO)
Local Char    DPCU(GLONUOM), FPCU(GLONUOM)
Local Char    DCTR(GLONCTR), FCTR(GLONCTR)
Local Char    DPAL(GLONPAL), FPAL(GLONPAL)
Local Char    WLOT1(GLONLOT)
Local Char    WSLO1(GLONSLO)
Local Char    WPAL1(GLONPAL)
Local Char    WCTR1(GLONCTR)

Local Integer WAGR

#
Local Integer I, J, L, M
#
Gosub LOAD_SCREEN
NAVIG="CONSCOL"
SUITE  = 1
RETOUR = 1
nolign = 1
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:COL1]FCY      = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
         [M:COL1]PACNUM    = PARAM(I)
      Endif
    When 4 :
      If PARAM(I) <> ""
         [M:COL1]BPCORD    = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) <> ""
         [M:COL1]PREUSR    = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
         [M:COL1]VCRTYP    = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> ""
         [M:COL1]VCRNUMSTR = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) <> ""
         [M:COL1]VCRNUMEND = PARAM(I)
      Endif
    #CHECK UNUSED_BEGIN
    When 9 :
      If PARAM(I) <> ""
         [M:COL1]DATDEB    = PARAM(I)
      Endif
    When 10 :
      If PARAM(I) <> ""
         [M:COL1]DATFIN    = PARAM(I)
      Endif
    #CHECK UNUSED_END
  Endcase
Next I
If clalev([M:CCOL]) <> 0 & [M:CCOL]MEMO = "STD"
  [M:COL1] = [M:CCOL]
Endif
If [M:COL1]OBJET   = ""
   [M:COL1]OBJET   = "SDH"          # livraison
Endif
[M:COL1]FLGTYP     = 1              # tous documents
[M:COL1]SPDFLG     = 1              # détail colis
[M:COL1]VCRTYP     = 4              # type document : livraison
[M:COL1]VCRTYPS    = 4              # type document : livraison
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
#                                                           # hcb 110327-pck deb
$DEB_CRIT
If [M:COL1]SPDFLG  <> 2
   Grizo [M:CCOL]ITMREF
   Grizo [M:CCOL]LOT
   Grizo [M:CCOL]SERNUM
   Raz   [M:CCOL]ITMREF
   Raz   [M:CCOL]LOT
   Raz   [M:CCOL]SERNUM
   Affzo [M:CCOL]ITMREF
   Affzo [M:CCOL]LOT
   Affzo [M:CCOL]SERNUM
Endif
Return
#                                                           # hcb 110327-pck fin

$LECTURE

If [M:COL1]FCY = ""
   NBLU = 0
   Return
Endif
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
        If nolign <= MAXLIG
           Gosub LOA_LIGNE
           NBLU    = 2
           nolign += 1
           NOL    += 1
        Else
              Break
        Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
        If WLIG >= WSKIP
           If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2
              nolign += 1
              NOL    += 1
           Else
                Break
           Endif
        Else
           WLIG += 1
        Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:COL2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
         If WLIG >= WSKIP
            If nolign <= MAXLIG
               Gosub LOA_LIGNE
               NBLU    = 2
               nolign += 1
               NOL    -= 1
            Else
                  Break
            Endif
         Else
            WLIG += 1
         Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
        If WLIG >= WSKIP
           If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2
              nolign += 1
           Else
                 Break
           Endif
        Else
           WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:COL1]FLG = 0
   [M:COL1]FLG = 1
   Raz [M:COL2]
   Gosub LOAD_FILTER
   WFILSPE="1=1"
   If PROGSPE<>""
      ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
   Endif
   WCRITTR1  = "1=1"
# SQL serveur plante si les criteres ont 1=1   hcb 81803
   WCRITTR2  = "[F:SPH]STOFCY"
   WCRITTR3  = "[F:SPH]CREDAT"
   Case [M]SRTKEY
        When 1 : WCRITTR1=  "[F:SPH]VCRTYP"
                 WCRITTR2=  "[F:SPH]VCRNUM"
                 WCRITTR3=  "[F:SPH]PACNUM"

        When 2 : WCRITTR1=  "[F:SPH]PACNUM"

        When 3 : WCRITTR1=  "[F:SPH]BPCORD"
                 WCRITTR2=  "[F:SPH]PACNUM"

        When 4 : WCRITTR1=  "[F:SPH]PREUSR"
                 WCRITTR2=  "[F:SPH]PACNUM"

   Endcase

   If [M]SPDFLG = 2
      If [M]FLGTYP = 2
         Onerrgo ERR_FORM10
         Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM,[PRH]PRH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM
&             As    [LNK]
&             Where evalue(WFILSPH)                 &
&                   evalue(WFILSPD)                 &
&                  (evalue(WFILSDH)                 |
&                   evalue(WFILPRH))                &
&                   evalue(WFILFOR)                 &
&                   evalue(WFILSPE)
&             Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
         Onerrgo
      Else
         If [M:COL1]VCRTYP = 4
            Onerrgo ERR_FORM20
            Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM
&                As    [LNK]
&                Where evalue(WFILSDH)                 &
&                      evalue(WFILSPH)                 &
&                      evalue(WFILSPD)                 &
&                      evalue(WFILFOR)                 &
&                      evalue(WFILSPE)
&                Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
            Onerrgo
         Else
            Onerrgo ERR_FORM30
            Link [SPH] With [PRH]PRH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM
&                As    [LNK]
&                Where evalue(WFILSPH)                 &
&                      evalue(WFILSPD)                 &
&                      evalue(WFILPRH)                 &
&                      evalue(WFILFOR)                 &
&                      evalue(WFILSPE)
&               Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
            Onerrgo
         Endif
      Endif
   Else
      If [M]FLGTYP = 2
         Onerrgo ERR_FORM1
         Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM,[PRH]PRH0=[F:SPH]VCRNUM
&             As    [LNK]
&             Where evalue(WFILSPH)                 &
&                  (evalue(WFILSDH)                 |
&                   evalue(WFILPRH))                &
&                   evalue(WFILFOR)                 &
&                   evalue(WFILSPE)
&            Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
         Onerrgo
      Else
         If [M:COL1]VCRTYP = 4
            Onerrgo ERR_FORM2
            Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM
&                 As    [LNK]
&                 Where evalue(WFILSDH)                 &
&                       evalue(WFILSPH)                 &
&                       evalue(WFILFOR)                 &
&                       evalue(WFILSPE)
&              Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
            Onerrgo
         Else
            Onerrgo ERR_FORM3
            Link [SPH] With [PRH]PRH0=[F:SPH]VCRNUM
&                 As    [LNK]
&                 Where evalue(WFILSPH)                 &
&                       evalue(WFILPRH)                 &
&                       evalue(WFILFOR)                 &
&                       evalue(WFILSPE)
&                 Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
            Onerrgo
         Endif
      Endif
   Endif
Endif
Return
############################################################
$ERR_FORM1
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM;[PRH]PRH0=[F:SPH]VCRNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILSPH)           &
&          evalue(WFILPRH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume

$ERR_FORM2
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILSPH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume

$ERR_FORM3
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [SPH] With [PRH]PRH0=[F:SPH]VCRNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILPRH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume
$ERR_FORM10
Call MESSAGE (mess(65,106,1)) From GESECRAN
     Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM,[PRH]PRH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM;[F:SPH]PACNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILSPH)           &
&          evalue(WFILSPD)           &
&          evalue(WFILPRH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume

$ERR_FORM20
Call MESSAGE (mess(65,106,1)) From GESECRAN
     Link [SPH] With [SDH]SDH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM;[F:SPH]PACNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILSPD)           &
&          evalue(WFILSPH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume

$ERR_FORM30
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [SPH] With [PRH]PRH0=[F:SPH]VCRNUM,[F:SPD]SPD3=[F:SPH]VCRTYP;[F:SPH]VCRNUM;[F:SPH]PACNUM;[F:SPH]PACNUM
&    As    [LNK]
&    Where evalue(WFILSDH)           &
&          evalue(WFILSPD)           &
&          evalue(WFILPRH)
&    Order By Key CLE = evalue(WCRITTR1);evalue(WCRITTR2);evalue(WCRITTR3)
Resume


############################################################
$LOA_LIGNE
#
[M:COL2]                      = [F:SPH]
[M:COL2]PKGTYP1   (nolign-1)  = [F:SPH]PKGTYP
[M:COL2]NETWEI    (nolign-1)  = [F:SPH]NETWEI       # hcb  89584
[M:COL2]NETWEI    (nolign-1) += [F:SPH]PCKWEI       # hcb  89584

If [M]SPDFLG = 2
   [M:COL2]                      = [F:SPD]
   [M:COL2]NETWEI    (nolign-1)  = [F:SPH]NETWEI    # hcb  89584
   [M:COL2]NETWEI    (nolign-1) += [F:SPH]PCKWEI    # hcb  89584
   [M:COL2]WEI       (nolign-1)  = [F:SPD]NETWEI
   [M:COL2]QTYSTU    (nolign-1)  = [F:SPD]QTY
#                                                                       # hcb 110327-pck deb
   If dim([M:COL2]SERNUM) > 0 & [F:SPD]SERFIN <> ""
      [M:COL2]SERNUM    (nolign-1) = [F:SPD]SERDEB
      [M:COL2]SERFIN    (nolign-1) = [F:SPD]SERFIN
   Else
      [M:COL2]SERFIN    (nolign-1) = [M:COL2]SERNUM    (nolign-1)
   Endif
#                                                                       # hcb 110327-pck fin
Endif

If [M:COL2]VCRTYP (nolign-1)  = 4
   [M:COL2]DLVDAT (nolign-1)  = [F:SDH]DLVDAT
   [M:COL2]BPTNUM (nolign-1)  = [F:SDH]BPTNUM
Else
   [M:COL2]DLVDAT (nolign-1)  = [F:PRH]DLVDAT
   [M:COL2]BPTNUM (nolign-1)  = [F:PRH]BPTNUM
Endif

If [M:COL2]PCK (nolign-1)  <> ""  &  [F:TPA]PCK <> [M:COL2]PCK (nolign-1)
   Read [TPA]TPA0=[M:COL2]PCK (nolign-1)
   If fstat
      Raz [F:TPA]
   Endif
Endif

Call GET_ATEXTRA("TABPACKAGE","SHOAXX",GLANGUE,[M:COL2]SHOAXX (nolign-1)) From TRTX3TEX    # 55845


If [M:COL2]ITMREF (nolign-1) <> ""
   If [M:COL2]ITMREF (nolign-1) <> [F:ITM]ITMREF
      Read [F:ITM]ITM0=[M:COL2]ITMREF (nolign-1)
      If fstat
         Raz [F:ITM]
      Endif
   Endif
Else
    Raz [F:ITM]
Endif
#[M:COL2]ITMDES1 (nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:COL2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:COL2]STU     (nolign-1) = [F:ITM]STU

If [M:COL2]PREUSR (nolign-1) <> ""
   If [M:COL2]PREUSR (nolign-1) <> [F:AUS]USR
      Read [F:AUS]CODUSR=[M:COL2]PREUSR (nolign-1)
      If fstat
         Raz [F:AUS]
      Endif
   Endif
Else
    Raz [F:AUS]
Endif
[M:COL2]NOMUSR     (nolign-1) = [F:AUS]NOMUSR

If [M:COL2]BPCORD (nolign-1) <> ""
   If [M:COL2]BPCORD (nolign-1) <> [F:BPC]BPCNUM
      Read [F:BPC]BPC0=[M:COL2]BPCORD (nolign-1)
      If fstat
         Raz [F:BPC]
      Endif
   Endif
Else
    Raz [F:BPC]
Endif
[M:COL2]BPCSHO (nolign-1) = [F:BPC]BPCSHO

If [M:COL2]BPTNUM (nolign-1) <> ""
   If [M:COL2]BPTNUM (nolign-1) <> [F:BPT]BPTNUM
      Read [F:BPT]BPT0=[M:COL2]BPTNUM (nolign-1)
      If fstat
         Raz [F:BPT]
      Endif
   Endif
Else
    Raz [F:BPT]
Endif
[M:COL2]BPTSHO (nolign-1) = [F:BPT]BPTSHO
Raz WLOT
Raz WSLO
If dim([M:COL2]LOT) > 0 & [M:COL2]LOT(nolign-1) <> ""
   WLOT = [M:COL2]LOT(nolign-1)
   If dim([M:COL2]SLO) > 0 & [M:COL2]SLO(nolign-1) <> ""
      WSLO = [M:COL2]SLO(nolign-1)
   Endif
Endif

If [F:ITM]LOTMGTCOD=4 & WSLO <> ""
   Read [STL]STL0 = [M:COL2]ITMREF(nolign-1);WLOT;WSLO
Else
   Read [STL]STL0(2) = [M:COL2]ITMREF(nolign-1);WLOT
Endif
If fstat = 0
  If dim([M:COL2]SHLDAT) > 0
     [M:COL2]SHLDAT(nolign-1)= [F:STL]SHLDAT
  Endif
  If dim([M:COL2]DLUDAT) > 0
     [M:COL2]DLUDAT(nolign-1)= [F:STL]DLUDAT
  Endif
  If dim([M:COL2]NEWLTIDAT) > 0
     [M:COL2]NEWLTIDAT(nolign-1)= [F:STL]NEWLTIDAT
  Endif
  #MAE, Evol 71276_ECC
  If dim([M:COL2]ECCVALMAJ) > 0
     [M:COL2]ECCVALMAJ(nolign-1)= [F:STL]ECCVALMAJ
  Endif
  #Fin MAE, Evol 71276_ECC
Endif



Return
############################################################
$LOAD_FILTER
#
#                                                                                Préparation filtre [SPH]
WFILSPH = "1=1"
WFILSPH = "[F:SPH]STOFCY=[M]FCY"                                                   # Site stockage
If [M]PACNUM <> ""
   WFILSPH = WFILSPH+"&[F:SPH]PACNUM=[M]PACNUM"                                    # N° colis
Endif
If [M]BPCORD <> ""
   WFILSPH = WFILSPH+"&[F:SPH]BPCORD=[M]BPCORD"                                    # Client livré
Endif
If [M]PREUSR <> ""
   WFILSPH = WFILSPH+"&[F:SPH]PREUSR=[M]PREUSR"                                    # Préparateur
Endif
If [M]FLGTYP <> 2
   WFILSPH = WFILSPH+"&[F:SPH]VCRTYP=[M]VCRTYP"                                    # Type document
Endif
If [M]SCCCOD <> ""
   WFILSPH = WFILSPH+"&[F:SPH]SCCCOD=[M]SCCCOD"                                    # Code scccod
Endif
If [M]VCRNUMSTR <> "" | [M]VCRNUMEND <> ""
   WFILSPH = WFILSPH+"&[F:SPH]VCRNUM>=[M]VCRNUMSTR&[F:SPH]VCRNUM<=[M]VCRNUMEND"    # Document
Endif

#                                                                                Préparation filtre [SPD]
WFILSPD = "1=1"
If [M]SPDFLG = 2
   If [M]ITMREF <> ""
      WFILSPD = WFILSPD+"&[F:SPD]ITMREF=[M]ITMREF"                                 # Article
   Endif
   If [M]LOT    <> ""
      WFILSPD = WFILSPD+"&[F:SPD]LOT   =[M]LOT"                                    # Lot
   Endif
   If [M]SERNUM <> ""
      WFILSPD = WFILSPD+"&([F:SPD]SERNUM=[M]SERNUM | ([M]SERNUM >= [F:SPD]SERDEB & [M]SERNUM <= [F:SPD]SERFIN))" # Série     # hcb 110327-pck
   Endif
Endif

#                                                                                 Préparation filtre [SDH]
WFILSDH = "1=1"
If [M]DLVDATSTR <> [0/0/0] | [M]DLVDATEND <> [0/0/0]
   WFILSDH = WFILSDH+"&[F:SDH]DLVDAT>=[M]DLVDATSTR&[F:SDH]DLVDAT<=[M]DLVDATEND"    # Date livraison
Endif
If [M]BPTNUMSTR <> ""      | [M]BPTNUMEND <> ""
   WFILSDH = WFILSDH+"&[F:SDH]BPTNUM>=[M]BPTNUMSTR&[F:SDH]BPTNUM<=[M]BPTNUMEND"    # Transporteur
Endif
#                                                                                 Préparation filtre [PRH]
WFILPRH = "1=1"
If [M]DLVDATSTR <> [0/0/0] | [M]DLVDATEND <> [0/0/0]
   WFILPRH = WFILPRH+"&[F:PRH]DLVDAT>=[M]DLVDATSTR&[F:PRH]DLVDAT<=[M]DLVDATEND"    # Date livraison
Endif
If [M]BPTNUMSTR <> ""      | [M]BPTNUMEND <> ""
   WFILPRH = WFILPRH+"&[F:PRH]BPTNUM>=[M]BPTNUMSTR&[F:PRH]BPTNUM<=[M]BPTNUMEND"    # Transporteur
Endif
#                                                                                 Filtre formule
WFILFOR = "1=1"
If [M]SELFOR <> ""
  Read [TFO]TFO0=33;[M]SELFOR
  If fstat = 0
      WFILFOR = [F:TFO]FORFOR
  Endif
Endif
#
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
