Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    If !find(I,3,4)
        GMENLOC(I) = 1
    Endif
Next

If [M]FLGTYP = 2
   mkstat = 2
Endif
End

Subprog AP_VCRTYP(VALEUR)
Variable Integer VALEUR
[M]VCRTYP  = VALEUR
[M]VCRTYPS = VALEUR
If VALEUR = 4  | [M]FLGTYP = 2
   [M]OBJET   = "SDH"          # livraison
Else
   [M]OBJET   = "PRH"          # preparation
Endif
End

