Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Read [STS]STS0=[M:CCOL]ITMREF;VALEUR
   If fstat
      GMESSAGE= mess(43,196,1) # numéro de série inexistant
      mkstat = 2
      End
   Endif
Endif
End
