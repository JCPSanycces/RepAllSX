# Superviseur
## CRUD-CLASSE ## CCMCRORIGE
# 2018-10-19 07:50:21 051


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGE

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_CCMCRORIGE

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGE
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_CCMCRORIGE
Else
 Gosub ADELETE_CCMCRORIGE
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(CCMCRORIGE,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If CCMCRORIGE.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGE.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_CCMCRORIGE
Trbegin [F:CCMCROE]
 Gosub ADELETE_CCMCRORIGE
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_CCMCRORIGE
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(CCMCRORIGE,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGE._MAJSQL_CCMCRORIGE(CCMCRORIGE))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If CCMCRORIGE.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGE.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGE.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



