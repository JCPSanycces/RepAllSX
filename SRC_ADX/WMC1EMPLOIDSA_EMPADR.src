Return

$INIT_ADDSTA
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDSTA"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.ADDSTA=0 and fmet this.AGETATTRIBUTE("ADDSTA","$isMandatory")="true"
 this.ADDSTA = 1
Endif
Return
 
$CONTROL_ADDSTA
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDSTA"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_ADDSTA                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_ADDSTA                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_ADDSTA
[L]CURPRO = "ADDSTA"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.ADDSTA=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ADDSTA
[L]CURPRO = "ADDSTA"
If this.ADDSTA<0 or this.ADDSTA>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.ADDSTA)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_ADDSTA
[L]CURPRO = "ADDSTA"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ADDSTA
[L]CURPRO = "ADDSTA"
Return

$PROPAGATE_ADDSTA
this.isReadonly = 0
[L]CURPRO = "ADDSTA"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ADDSTA
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDSTA"
$_LNKPRO_ADDSTA
Return




