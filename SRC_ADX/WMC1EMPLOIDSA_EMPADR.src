#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## ACLA-CLASSE ## EMPLOIDSA_EMPADR
# 2018-11-06 07:05:51 293


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : ADDPRI Priority ( Field C 1)
####################################################################

$SET_ADDPRI
If [L]_AOLDVAL<>this.ADDPRI
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_ADDPRI
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.ADDPRI
 Gosub PROPAGATE_ADDPRI
Endif
Return

$INIT_ADDPRI
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDPRI"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_ADDPRI
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDPRI"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_ADDPRI                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_ADDPRI                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_ADDPRI
[L]CURPRO = "ADDPRI"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.ADDPRI=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ADDPRI
[L]CURPRO = "ADDPRI"
Return

$_AOTHERS_ADDPRI
[L]CURPRO = "ADDPRI"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ADDPRI
[L]CURPRO = "ADDPRI"
Return

$PROPAGATE_ADDPRI
this.isReadonly = 0
[L]CURPRO = "ADDPRI"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ADDPRI
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDPRI"
$_LNKPRO_ADDPRI
Return


####################################################################
# 2 : ADDTYP Type ( Field Local menu number 11651)
####################################################################

$SET_ADDTYP
If [L]_AOLDVAL<>this.ADDTYP
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_ADDTYP
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.ADDTYP
 Gosub PROPAGATE_ADDTYP
Endif
Return

$INIT_ADDTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.ADDTYP=0 and fmet this.AGETATTRIBUTE("ADDTYP","$isMandatory")="true"
 this.ADDTYP = 1
Endif
Return
 
$CONTROL_ADDTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_ADDTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_ADDTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_ADDTYP
[L]CURPRO = "ADDTYP"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.ADDTYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ADDTYP
[L]CURPRO = "ADDTYP"
If this.ADDTYP<0 or this.ADDTYP>len(mess(0,11651,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"11651 ->"-num$(this.ADDTYP)-mess(99,123,1)):  Return : # Local menu "11651 -> Invalid option
Endif
Return

$_AOTHERS_ADDTYP
[L]CURPRO = "ADDTYP"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ADDTYP
[L]CURPRO = "ADDTYP"
Return

$PROPAGATE_ADDTYP
this.isReadonly = 0
[L]CURPRO = "ADDTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ADDTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
[L]CURPRO = "ADDTYP"
$_LNKPRO_ADDTYP
Return


