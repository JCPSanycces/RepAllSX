########################################
Subprog AVANT_NBLIG
  If status=75 | status=82
    If dim([M:RCL0]CTNTHETAR)>0 & [M:RCL0]CTN<>"" : [M:RCL0]CTNCUMWEI = func CALC_CUMUL_WEI : Affzo [M:RCL0]CTNCUMWEI : Endif
  Endif
End

########################################
Subprog APRES_NBLIG
  If status=65
    If dim([M:RCL0]CTNTHETAR)>0 & [M:RCL0]CTN<>"" : [M:RCL0]CTNCUMWEI = func CALC_CUMUL_WEI : Affzo [M:RCL0]CTNCUMWEI : Endif
  Endif
End
# CATUA X3-68685.en

######################################################################################
## Etiquette ajoutée par le superviseur (écran RCL0) 31/05/2011 09:25:14 (MM)
######################################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
  [M:RCL0]MFGFCY=VALEUR

  Gosub CHARGE_PARAM

  If [V]GRECONCIL=2 # Reconcile by phase
    Actzo[M:RCL0]BOMOPE0
  # CATUA X3-68685.sn
    Raz[M:RCL0]CTN
    Grizo[M:RCL0]CTN
  Elsif [V]GRECONCIL=3 # Reconcile by container
    Actzo[M:RCL0]CTN
    Raz[M:RCL0]BOMOPE0
    Grizo[M:RCL0]BOMOPE0
  # CATUA X3-68685.en
  Else
    Raz[M:RCL0]BOMOPE0
    Grizo[M:RCL0]BOMOPE0
    # CATUA X3-68685.sn
    Raz[M:RCL0]CTN
    Grizo[M:RCL0]CTN
    # CATUA X3-68685.en
  Endif
End


########################################
Subprog AM_SAISIE(VALEUR)
Variable Integer VALEUR
Local Integer NOL   : [L]NOL=nolign-1
#DT-18/06/2010
If VALEUR=1
    Raz[M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    #Diszo[M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    Actzo[M:RCL0]MFGTRKNUM(NOL)
    zonsui = "MFGTRKNUM(" + num$(NOL) + ")"
Else
    Raz[M:RCL0]MFGTRKNUM(NOL)
#RDH18022011
#    Diszo[M:RCL0]MFGTRKNUM(NOL)
    Grizo[M:RCL0]MFGTRKNUM(NOL)

    Actzo[M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    zonsui = "ITMREF(" + num$(NOL) + ")"
Endif

End
########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Integer NOL : [L]NOL=nolign-1

#DT-18/06/2010
If [M:RCL0]SAISIE(NOL)=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Else
    If [M:RCL0]NBLIG<>0 & VALEUR<>""
        For K=0 To [M:RCL0]NBLIG-1
            If K<>[L]NOL & [M:RCL0]MFGTRKNUM(K)=VALEUR
                GMESSAGE = mess(43,2324,1)-num$([L]K+1) : GERR =2 : mkstat = 2 : Break
            Endif
        Next K
    Endif
Endif

End
########################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
  Gosub ETI_MFGTRKNUM
End

########################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal VALEUR
If [M:RCL0]BOMOPE0<>0
    VALEUR = [M:RCL0]BOMOPE0
Endif
End

