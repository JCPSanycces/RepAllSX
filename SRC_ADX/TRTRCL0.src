#<AdxTL>@(#)5.0.0.0 $Revision$
#                         T R T R C L 0
# sr 09.03 revu pour exclure de la réconciliation les MP pesées en fabrication demande L'oréal commande L 030590
#          + réconcilier un OF complet et pas phase par phase
#          + faire saisir systématiquement la quantité pesée

##########################################################################

#######################################################################################
# Fonction réconciliation           pesée           GPAO                              #
# Paramètre général Réconciliation qui permet 2 valeurs : "1: Par OF"; "2: Par Phase" #                                            #
# LFCY  = Site de production: "" = tous sites                                         #
#######################################################################################
#CHECK UNUSED_BEGIN
Local Char PARAM(50)(1..20) , SAVACT(10)
Local Char VALEUR

PARAM(1) = ""
SAVACT = GACTION : GACTION = "SAIRCL0"
Call SAISIE_CHAR(VALEUR,PARAM,"FRCL0","TRTRCL0") From GSAISIE
End
#CHECK UNUSED_END

########################################################################
# trtrcl0   : RECONCILIATION                        GPAO  HCB   09/01    #
# trtrcl0   : RECONCILIATION PAR OF & PAR PHASE     GPAO  DT  24/09/2010 #
########################################################################
# FGR 14/01/2010 : X3SUIVI60986
#Subprog TRTRCL0(LFCY)
#Value Char     LFCY

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


#########################################################
$OUVRE

Global Integer GHCBWCPT
Global Integer GHCBWCPTART
Global Char    GHCBIVALEUR (GLONVCR)
Global Char    GHCBLMFGNUM (GLONVCR)
Global Char    GHCBLITMREF (GLONITM)  # mm 05.08
Global Integer GHCBLBOMOPE
Global Integer GHCBLMFGLIN
Global Integer GHCBLBOMSEQ
Global Date    GHCBLCBTDAT
Global Integer GHCBLMVTSEQ
Global Integer GHCBWBOUT
Global Integer GHCBWCPTENR # Number of materials to reconcile diplayed at [M:RCL0]WCPTENR
Global Integer GHCBLWGGSTA # Weighing Situation status (MFG.WGGSTA) displayed at [M:RCL0]WGGSTA
Global Integer GHCBLRECONCIL # 0-Reconciliation not complete , 1-Reconciliation complete and weighing table updated
Global Char    GHCBLCTN (8) #CATUA X3-68685.sn
# Issue 82935 - 2012-06-15 by SR
Global Integer GHCBMAX

# lreconcil = 0 pas de reconciliation de faite
# lwggsta = ancien code wggsta
GHCBLWGGSTA = 0
GHCBLRECONCIL = 0
GHCBLMFGNUM = ""
GHCBWBOUT = 5
GHCBWCPT = 0
GHCBWCPTENR = 0
# Issue 82935 - 2012-06-15 by SR
GHCBMAX = 0

# Ouverture des fichiers utilisés
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  = 0 : Local File WEIGHING    [WGG]  : Endif
If clalev([F:WGG1]) = 0 : Local File WEIGHING    [WGG1] : Endif   :#DT

Return


#########################################################
$SETBOUT

If GHCBWBOUT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 7
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 8
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 9
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif

Return

#########################################################
$OUVRE_BOITE
Return

#########################################################
$DEBUT
# Issue 82935 - 2012-06-15 by SR
GHCBMAX = dim([M:RCL0]ITMREF)     # mémorisation nombre de ligne maxi
Gosub TRT_ORDRE
Return

#########################################################
$AV_CHOIX
Return

#########################################################
AP_CHOIX
Return

#########################################################
$AVANT_BOUTON
Case BOUT
     When "a"
      # Issue 82948 - 2012-06-15 by SR
      Gosub CALCUL
      If [M:RCL0]NBLIG <> GHCBWCPTENR
        GMESSAGE  = mess(52,2324,1)-num$(GHCBWCPTENR-[M:RCL0]NBLIG)
        GERR = 1
        Return
      Endif
Endcase
Return

#########################################################
$FINSAI
# Issue 82348 - 2012-06-18 by SR dissocier par Of  de par phase
  Kill GHCBWCPT
  Kill GHCBWCPTART
  Kill GHCBIVALEUR
  Kill GHCBLMFGNUM
  Kill GHCBLITMREF
  Kill GHCBLBOMOPE
  Kill GHCBLMFGLIN
  Kill GHCBLBOMSEQ
  Kill GHCBLCBTDAT
  Kill GHCBLMVTSEQ
  Kill GHCBWBOUT
  Kill GHCBWCPTENR
  Kill GHCBLWGGSTA
  Kill GHCBLRECONCIL
  # Issue 82935 - 2012-06-15 by SR
  Kill GHCBMAX
  GBIDC1 = ""

  #Nettoie l'écran avant de partir.
   Raz [M:RCL0]
Return

#########################################################
$FIN
Gosub TRT_FIN
Return

#########################################################
$ABANDON
Return

#########################################################
$APRES_MODIF
Return

#########################################################
$BOUTON

Case BOUT

     When "a" Gosub TRT_ENREGISTREMENT #Save
     When "b" Gosub TRT_SUPPRIMER #Delete
     When "c" Gosub TRT_ABANDON #Cancel
     When Default
Endcase
Return

#########################################################
$ONMENU
Return


#########################################################
# Sous-programmes bouton
#########################################################
$TRT_FIN
If GHCBLRECONCIL <> 0

  Call ERREUR(mess(87,2324,1)) From GESECRAN # CATUA X3-68685 changed from 21

# suppression réconciliation
   Gosub TRT_SUPPRIME
Endif

GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD

Return





#########################################################
$TRT_ABANDON
If GHCBLRECONCIL <> 0
    OK=1
    Call OUINON(mess(87,2324,1),OK) From GESECRAN # CATUA X3-68685 changed from 21
    If OK <> 2 : mkstat=2 : Return : Endif
Endif
# suppression réconciliation
Gosub TRT_SUPPRIME
# retour saisie ordre
GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD
Gosub TRT_ORDRE

GHCBWCPT = 0
ACTION = "ABANDON" : Gosub ACTION
Return

$TRT_SUPPRIMER
# Confirmation de la suppression
OK=1

#CATUA X3-68685.sn
# Call OUINON(mess(20,2324,1),OK) From GESECRAN
If GRECONCIL=2 # Reconcile by phase
  Call OUINON(mess(84,2324,1),OK) From GESECRAN
Elsif GRECONCIL=3 # Reconcile by container
  Call OUINON(mess(85,2324,1),OK) From GESECRAN
Else
  Call OUINON(mess(86,2324,1),OK) From GESECRAN
Endif
#CATUA X3-68685.en

If OK <> 2 : mkstat=2 : Return : Endif
# suppression réconciliation
Gosub TRT_SUPPRIME
# retour saisie ordre
Gosub TRT_ORDRE
Return



#########################################################
$TRT_ENREGISTREMENT #Save
#  lecture historique
Local Integer J

#  lecture historique
If [M:RCL0]NBLIG <> 0

    #DT-21/06/2010
    For J=0 To [M:RCL0]NBLIG-1
        GHCBLMFGLIN = [M:RCL0]MFGLIN([L]J)
        GHCBLBOMSEQ = [M:RCL0]BOMSEQ([L]J)
        GHCBLCBTDAT = [M:RCL0]CBTDAT([L]J)
        GHCBLMVTSEQ = [M:RCL0]MVTSEQ([L]J)
        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock [WGG]WGG0 = [M:RCL0]MFGNUM;[M:RCL0]BOMOPE([L]J);[M:RCL0]ITMREF([L]J);GHCBLMFGLIN;GHCBLBOMSEQ;GHCBLCBTDAT;GHCBLMVTSEQ
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL :  Break                                        # FQ 69909 Ctrl des sources avant Return
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK :  Gosub TRT_ROLL :  Break                                # FQ 69909 Ctrl des sources avant Return
        Endif

        [F:WGG]RCLCOD = 2
        [F:WGG]RCLDAT = date$
        # Issue number 82926- 2012-06-14 by SR
        [F:WGG]RCLUSR = GUSER
        [F:WGG]RCLTIM =  mid$(time$,1,2)+mid$(time$,4,2)
        GHCBLRECONCIL = 1
        Rewrite [F:WGG]
        If fstat
           GOK = 0 : Call FSTA("WGG") From GLOCK : Break                                        # FQ 69909 Ctrl des sources avant Return
        Endif
        Commit

        #DT-22/06/2010
        Gosub CALCUL

        If GHCBWCPTENR = 0
            OK=1

            #CATUA X3-68685.sn
            #Call OUINON(mess(18,2324,1),OK) From GESECRAN
            If GRECONCIL=2 # Reconcile by phase
              Call OUINON(mess(18,2324,1),OK) From GESECRAN
            Elsif GRECONCIL=3 # Reconcile by container
              Call OUINON(mess(83,2324,1),OK) From GESECRAN
            Else
              Call OUINON(mess(82,2324,1),OK) From GESECRAN
            Endif
             #CATUA X3-68685.en

            If OK <> 2
              GHCBWBOUT = 9 #CATUA X3-100033 Enable Save / Disable Delete
              Gosub TRT_SUPPRIME
              Gosub CALCUL #CATUA X3-68685 Need to recalculate number of records to reconcile
            Else
              Gosub TRT_VALIDATION
              # Issue 82948 - 2012-06-18 by SR
              If WOK = 6
                #If GRECONCIL<>2
                #  GHCBIVALEUR = ""
                #  Gosub TRT_ORDRE
                #Else
                #  GHCBLRECONCIL = 0
                #  Effzo [M:RCL0]15
                #  Raz [M:RCL0]NBLIG
                #  Raz [M:RCL0]BOMOPE0,WCPTENR
                #  Actzo [M:RCL0]BOMOPE0
                #  Affzo [M:RCL0]BOMOPE0,WCPTENR
                #  zonsui = "[M:RCL0]BOMOPE0"
                #Endif
                #CATUA X3-68685.sn
                GHCBWBOUT = 1 #CATUA X3-100033 Disable Save / Disable Delete
                If GRECONCIL=2 # Reconcile by phase
                  GHCBLRECONCIL = 0
                  Effzo [M:RCL0]15
                  Raz [M:RCL0]NBLIG
                  Raz [M:RCL0]BOMOPE0,WCPTENR
                  Actzo [M:RCL0]BOMOPE0
                  Affzo [M:RCL0]BOMOPE0,WCPTENR
                  zonsui = "[M:RCL0]BOMOPE0"
                Elsif GRECONCIL=3 # Reconcile by container
                  GHCBLRECONCIL = 0
                  Effzo [M:RCL0]15
                  Raz [M:RCL0]NBLIG
                  Raz [M:RCL0]CTN,WCPTENR
                  Actzo [M:RCL0]CTN
                  Affzo [M:RCL0]CTN,WCPTENR
                  zonsui = "[M:RCL0]CTN"
                Else
                  GHCBIVALEUR = ""
                  Gosub TRT_ORDRE
                Endif
                #CATUA X3-68685.en
              Endif
            Endif
        Else

             GHCBWBOUT = 1
             If [M:RCL0]WEU([L]J) <> ""
                    If GHCBLRECONCIL = 1 GHCBWBOUT = 8
                    Else
                                         GHCBWBOUT = 9
                    Endif
             Else
                    If GHCBLRECONCIL = 1 GHCBWBOUT = 7
                    Endif
             Endif
            ACTION = "SETBOUT" : Gosub ACTION
            If  J=[M:RCL0]NBLIG-1
                Call MESSAGE (mess(52,2324,1)-num$(GHCBWCPTENR)) From GESECRAN
            Endif
        Endif
    Next J   :# DT-21/06/2010
Endif  :# DT-21/06/2010

Return

########################################################################
# sous programme
########################################################################

$TRT_VALIDATION
# verification que la réconciliation soit faite sur toutes les matieres pesées
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 03.02 ainsi que les mouvements de type "fin de contenant"
# sr 01.03 ainsi que les mouvements de type "Inventaire"
# sr 09.03 ainsi que les matières pesée en fabrication (code à servir 3,5,7)
#          En fait on garde les PCK : 2,4,6
GOK=1

For [MFM]MFM0 Where MFGFCY = [M:RCL0]MFGFCY     &
&                   MFGNUM = [M:RCL0]MFGNUM     &
&                   MATSTA <> 4                 &
&                   WGGSTA = 3                  &
&                   find([F:MFM]PKC,2,4,6)      &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:RCL0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:RCL0]CTN)  ) # CATUA X3-68685
#&    ([V]GRECONCIL<>2 | BOMOPE = [M:RCL0]BOMOPE0)

WOK = 0
     For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM     &
&                        MFGLIN = [F:MFM]MFGLIN      &
&                        ITMREF = [F:MFM]ITMREF      &
&                        BOMSEQ = [F:MFM]BOMSEQ      &
&                        BOMOPE = [F:MFM]BOMOPE      &
&                        WEIWEI <> 0                 &
&                        WEIFLG <> 4                 &
&                        WEIFLG <> 5
         If [F:WGG]RCLCOD <> 2 WOK = 9 : Break : Endif             # 04.02
         If [F:WGG]RCLCOD =  2 WOK = 1 : Endif                     # 04.02
     Next

    If WOK = 1
              Call DEBTRANS From GLOCK
              Trbegin [MFM]

              Readlock [F:MFM] Curr
              If fstat=1     GOK=-1 : GLOCK="$MFM"-GHCBLMFGNUM : Gosub  TRT_ROLL : Break             # FQ 69909 Ctrl des sources avant Return
              Elsif fstat GOK=0  : Call RSTA("MFM",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break  # FQ 69909 Ctrl des sources avant Return
              Endif

              [F:MFM]WGGSTA = 5
              Rewrite [F:MFM]
              If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break :  Endif # FQ 69909 Ctrl des sources avant Return
              Commit
    Endif

Next
If GOK<=0 Return Endif # FQ 69909 Ctrl des sources Ligne ajoutée  + mm 05.11


# verification que toutes les matieres soient réconciliées (wggsta = 5)
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 09.03 on ne traite que les PKC = 2,4,6

# WOK = 6
# All subjects MUST be reconciled to change the status of the header
# mm 05.11 - l'ensemble des matières doivent être réconciliées pour modifier le statut de l'entête.
For [MFM]MFM0 Where MFGFCY = [M:RCL0]MFGFCY     &
&                   MFGNUM = [M:RCL0]MFGNUM     &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
WOK = 6
If [F:MFM]WGGSTA <> 5  WOK = 9 : Break : Endif
Next

# If reconciled by phase: no update [MFG] if all the materials are not reconciled
# si engagement par phase : pas de mise à jour [MFG] si l'ensemble des matières ne sont pas réconciliées

# CATUA X3-68685.sn
If find(GRECONCIL,2,3) & WOK=9
  If GRECONCIL=2 # Reconcile by phase
    Call MESSAGE (mess(22,2324,1)) From GESECRAN
  Elsif GRECONCIL=3 # Reconcile by container
    Call MESSAGE (mess(79,2324,1)) From GESECRAN
  Endif
  WOK = 6 : Return
Endif
# CATUA X3-68685.en

If WOK = 6
  GHCBLWGGSTA = 8 #Total Weighing Completed
  [M:RCL0]WGGSTA = 8
  Call MAJ_FICHIERS ("MFG",6,GHCBLWGGSTA,[M:RCL0]MFGNUM,"",0,0) From SCALEXCHAN #(MFG.WGGFLG(6)-Reconciled, MFG.WGGSTA(8)-Total Weighing Completed)

  # CATUA X3-68685.sn
  #Call MESSAGE (mess(22,2324,1)) From GESECRAN
  If GRECONCIL=2 # Reconcile by phase
    Call MESSAGE (mess(22,2324,1)) From GESECRAN
  Elsif GRECONCIL=3 # Reconcile by container
    Call MESSAGE (mess(79,2324,1)) From GESECRAN
  Else
    Call MESSAGE (mess(81,2324,1)) From GESECRAN
  Endif
  # CATUA X3-68685.en

# if there are still weighed materials in production not yet weighed,
# we submit the OF in the weighing plan and "end of box weighing" status
# si il reste des matières pesées en fabrication non encore pesées,
# on remet l'OF dans le plan de pesée et statut "fin de pesée en box"

  For [F:MFM]MFM0 Where MFGFCY = [M:RCL0]MFGFCY     &
&                       MFGNUM = [M:RCL0]MFGNUM     &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,3,5,7)
      If [F:MFM]WGGSTA < 3
         Call MAJ_FICHIERS ("MFG",3,3,[M:RCL0]MFGNUM,"",0,0) From SCALEXCHAN #(MFG.WGGFLG(3)-Weighing Plan, MFG.WGGSTA(3)-Weighing in Station Completed)
         [M:RCL0]WGGSTA = 3
         GHCBLWGGSTA    = 3
      Endif
  Next
Endif

Return


#########################################################
$TRT_ROLL
Rollback
Return

#########################################################
$TRT_SUPPRIME

For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM     &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD =  2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:RCL0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:RCL0]CTN)  ) # CATUA X3-68685

    Call DEBTRANS From GLOCK
    Trbegin [WGG]

    Readlock Curr
    If fstat=1 GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Break
    Elsif fstat GOK=0 : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break
    Endif

        [F:WGG]RCLCOD = 1
        [F:WGG]RCLDAT = [0/0/0]
        [F:WGG]RCLUSR = ""
        Raz [F:WGG]RCLTIM
        Rewrite [F:WGG]
        If fstat GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub TRT_ROLL : Break
        Endif
        Commit
Next

Return


#########################################################
$TRT_ORDRE
  Actzo  [M:RCL0]MFGFCY
  Actzo  [M:RCL0]MFGNUM
  Raz [M:RCL0]
  Affzo [M:RCL0]

  GHCBLRECONCIL = 0
  GHCBWBOUT     = 1
  GHCBWCPT      = 0

  If [M:RCL0]MFGFCY<>""
    Gosub CHARGE_PARAM

    If [V]GRECONCIL=2 # Reconcile by phase
      Actzo[M:RCL0]BOMOPE0
    # CATUA X3-68685.sn
      Raz[M:RCL0]CTN
      Grizo[M:RCL0]CTN
    Elsif [V]GRECONCIL=3 # Reconcile by container
      Actzo[M:RCL0]CTN
      Raz[M:RCL0]BOMOPE0
      Grizo [M:RCL0]BOMOPE0
    # CATUA X3-68685.en
    Else
      Raz[M:RCL0]BOMOPE0
      Grizo [M:RCL0]BOMOPE0
      # CATUA X3-68685.sn
      Raz[M:RCL0]CTN
      Grizo[M:RCL0]CTN
      # CATUA X3-68685.en
    Endif
  Endif
Return


#########################################################
$TRT_ITMREF
Actzo  [M:RCL0]ITMREF(nolign-1)
Gosub TRT_RAZITMREF

GHCBLRECONCIL = 0
GHCBWBOUT     = 1

Return


#########################################################
$TRT_RAZITMREF

[M:RCL0]BOMOPE(nolign-1)  = 0
[M:RCL0]LOT(nolign-1)     = ""
[M:RCL0]WEU(nolign-1)     = ""
[M:RCL0]WEIWEI(nolign-1)  = 0

Affzo [M:RCL0]ITMREF(nolign-1)
Affzo [M:RCL0]LOT(nolign-1)
Affzo [M:RCL0]WEIWEI(nolign-1)
Affzo [M:RCL0]WEU(nolign-1)
Affzo [M:RCL0]BOMOPE(nolign-1)
Return

#########################################################
$TRT_RAZORDRE
[M:RCL0]MFGNUM  = ""
[M:RCL0]WCPTENR = 0
Affzo [M:RCL0]MFGNUM
Affzo [M:RCL0]WCPTENR
Return


########################################################################
# calcul nombre de pesée à reconcilier pour un of
########################################################################
$CALCUL

GHCBWCPTENR = 0

Gosub CHARGE_PARAM

For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM     &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&                   find([F:WGG]PKC,2,4,6)      &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:RCL0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:RCL0]CTN)  ) # CATUA X3-68685
#&   ([V]GRECONCIL=2 & (BOMOPE = [M:RCL0]BOMOPE0)|([V]GRECONCIL<>2 & [M:RCL0]BOMOPE0=0))  #DT - mm 05.11

GHCBWCPTENR += 1

Next

[M:RCL0]WCPTENR = GHCBWCPTENR
Affzo  [M:RCL0]WCPTENR

Return

########################################################################
# recherche element article à réconcilier
########################################################################
$CRTHISTART
GHCBWCPTART = 0

For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM     &
&                   BOMOPE = GHCBLBOMOPE        &
&                   ITMREF = GHCBLITMREF        &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&                   find([F:WGG]PKC,2,4,6)


GHCBWCPTART += 1
Break
Next

Return

########################################################################
# recherche element à réconcilier N° pesée
########################################################################
$CRTHIST_PESEE
GHCBWCPT = 0

# mm 05.11 - RCLDAT peut être =2 si pesée annulée # RCLCOD    <> 2
For [WGG]WGG0 Where  MFGNUM    = [M:RCL0]MFGNUM              &
&                            MFGTRKNUM = VALEUR              &
&                            WEIWEI    <> 0                  &
&                            CCLDAT    = [0/0/0]             &
&                            RCLDAT    = [0/0/0]             &
&                            WEIFLG    <> 4                  &
&                            WEIFLG    <> 5                  &
&                            find([F:WGG]PKC,2,4,6)          &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:RCL0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:RCL0]CTN)  ) # CATUA X3-68685
#&   ([V]GRECONCIL<>2 | BOMOPE = [M:RCL0]BOMOPE0)          :#DT

            GHCBWCPT += 1
            If GHCBWCPT > 1 Break : Endif
Next
Return

########################################################################
# recherche element à réconcilier lot
########################################################################
$CRTHISTLOT
GHCBWCPT = 0

#DT-21/06/2010
Raz[M:RCL0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM     &
&                   BOMOPE = [M:RCL0]BOMOPE(nolign-1)      &
&                   WEIWEI <> 0                 &
&                   ITMREF = [M:RCL0]ITMREF(nolign-1)      &
&                   LOT    = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5

  GHCBWCPT += 1
  If GHCBWCPT > 1 Break : Endif
Next

If GHCBWCPT = 1 GHCBLMFGLIN = [F:WGG]MFGLIN
            GHCBLBOMSEQ = [F:WGG]BOMSEQ
            GHCBLCBTDAT = [F:WGG]CBTDAT
            GHCBLMVTSEQ = [F:WGG]MVTSEQ
            #DT-21/06/2010
            [M:RCL0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
            [M:RCL0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
            [M:RCL0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
            [M:RCL0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
            [M:RCL0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM
Endif


Return

########################################################################
# recherche element à réconcilier lot + montant
########################################################################
$CRTHISTWEI
Local Integer CTR_PS

#DT-21/06/2010
Raz[M:RCL0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

GHCBWCPT = 0

For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM                 &
&                   BOMOPE = [M:RCL0]BOMOPE(nolign-1)       &
&                   WEIWEI <> 0                             &
&                   ITMREF = [M:RCL0]ITMREF(nolign-1)       &
&                   LOT    = [M:RCL0]LOT(nolign-1)          &
&                   WEIWEI = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5

    GHCBWCPT += 1
    GHCBLMFGLIN = [F:WGG]MFGLIN
    GHCBLBOMSEQ = [F:WGG]BOMSEQ
    GHCBLCBTDAT = [F:WGG]CBTDAT
    GHCBLMVTSEQ = [F:WGG]MVTSEQ

    [M:RCL0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
    [M:RCL0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
    [M:RCL0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
    [M:RCL0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
    [M:RCL0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM

    Raz[L]CTR_PS
    Gosub CTR_PESEE
    If [L]CTR_PS =0
        Break
    Endif
Next

If [L]CTR_PS<>0
    GMESSAGE = mess(43,2324,1)-num$([L]CTR_PS) : GERR =2 : mkstat = 2
Elsif GHCBWCPT <>0
    GHCBWCPT =1
Endif

Return





########################################################################
# mise à jour MFGHEAD
########################################################################
$MAJ_MFGHEAD
If GHCBLMFGNUM <> ""
   Call MAJ_FICHIERS ("MFG",0,GHCBLWGGSTA,GHCBLMFGNUM,"",0,0) From SCALEXCHAN  #(MFG.WGGFLG(0)-No)
Endif
If GHCBIVALEUR <> ""
  GHCBLMFGNUM = GHCBIVALEUR
  Call MAJ_FICHIERS ("MFG",0,10,GHCBIVALEUR,"",0,0) From SCALEXCHAN   #(MFG.WGGSTA(10)-Order Blocked for Reconciliation)
  GHCBLWGGSTA = [M:RCL0]WGGSTA
Endif

Return

#########################################################################
#       sous prog ETIQUETTES
#########################################################################

$ETI_MFGNUM
# Lecture MFGHEAD
# sr 01.03 faire un readlock ici (pour être sûr de pouvoir aller jusqu'à la fin sans qu'une
# autre session ne nous prenne l'entête ???

Read [MFG]MFG0 = VALEUR
If fstat :             GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG <  3  GMESSAGE = mess(13,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA =  10 GMESSAGE = mess(14,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA =  9  GMESSAGE = mess(15,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
#If [F:MFG]WGGFLG =  6  GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

# CATUA X3-68685.sn
#If [V]GRECONCIL<>2 & [F:MFG]WGGFLG=6
#    GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
#Elsif [V]GRECONCIL=2 & [F:MFG]WGGFLG =7
#    GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
#Endif
If [F:MFG]WGGFLG=6
  If [V]GRECONCIL=2 # Reconcile by phase
    GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Elsif [V]GRECONCIL=3 # Reconcile by container
    GMESSAGE = mess(80,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Else
    GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Endif
Endif
# CATUA X3-68685.en

#WGGFLG
#1-NO
#2-TO WEIGH
#3-WEIGHING PLAN
#4-BEING WEIGHED
#5-WEIGHED
#6-RECONCILED
#7-COMMITTED
#8-WEIGHING UNDER PROGRESS BY PRODUCT

#WGGSTA
#1-NOT WEIGHED
#2-WEIGHING IN STATION UNDER PROGESS
#3-WEIGHING IN STATION COMPLETED
#4-WEIGHING IN PRODUCTION UNDER PROGESS
#5-IN PRODUCTION
#6-END OF PRODUCTION
#7-RECONCILIATION CONTROL
#8-TOTAL WEIGHING COMPLETED
#9-ORDER BLOCKED FOR WEIGHING
#10-ORDER BLOCKED FOR RECOCILIATION CONTROL
#11-ORDER BLOCKED FOR PROCESS START CONTROL

If [F:MFG]MFGSTA =  4  GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

# verification that all materials are weighed (wggsta = 3)
# are excluded from reconciliation rectification phases and QSPs

# verification que toutes les matieres soient pesées (wggsta = 3)
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)

WOK = 0
For [MFM]MFM0 Where MFGFCY = [M:RCL0]MFGFCY     &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
    WOK = 1
    # CATUA X3-68685.sn
    If [V]GRECONCIL<2
      If [F:MFM]WGGSTA = 7 WOK = 7 : Break : Endif  # Already committed
      If [F:MFM]WGGSTA = 5 WOK = 8 : Break : Endif  # Already reconciled
      If [F:MFM]WGGSTA < 3 WOK = 9 : Break : Endif # Some materials are not weighed
    Endif
    # CATUA X3-68685.en
Next

#MFGMAT.WGGSTA
#1-NOT WEIGHED
#2-IN WEIGHING PROCESS
#3-WEIGHING
#4-RECONCILIATION CONTROL
#5-RECONCILED
#6-PROCESS START CONTROL
#7-PROCESS STARTED
#8-CONSUMED

#WOK
#0-ELEMENT DOES NOT EXIST
#7-ALREADY COMMITTED
#8-ALREADY RECONCILED
#9-SOME MATERIALS ARE NOT WEIGHED

If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 8  GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return : Endif # CATUA X3-68685 changed from 27
If WOK = 7  GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return : Endif # CATUA X3-68685 changed from 46

#Total number of weighing calculation
# mm 05.11 : calcul du nombre total de pesée à engager pour un of

# CATUA X3-68685.sn
#If WOK = 1 & [V]GRECONCIL<>2
If [V]GRECONCIL<2
  #Calculate number of records to process if reconcile by WO
  [M:RCL0]MFGNUM = VALEUR
  Gosub CALCUL
  If WOK = 1
     If GHCBWCPTENR = 0  GMESSAGE = mess(81,2324,1) : GERR =2 : mkstat = 2 : Raz [M:RCL0]MFGNUM # CATUA X3-68685 changed from 22
     Elsif GHCBWCPTENR > GHCBMAX
           GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:RCL0]MFGNUM
     Else
        Grizo  [M:RCL0]MFGFCY
        Grizo  [M:RCL0]MFGNUM
     Endif
  Endif
Endif

Return

#########################################################
$ETI_BOMOPE
#DT-22/06/2010
# Lecture MFGMAT

If [V]GRECONCIL=2
    # Réconciliation par phase
    WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:RCL0]MFGFCY     &
&                       MFGNUM = [M:RCL0]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
      WOK = 1
      If [F:MFM]WGGSTA =  5  WOK = 8 : Break : Endif
      If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
         [M:RCL0]BOMOPE0 = VALEUR
         Gosub CALCUL
         If GHCBWCPTENR = 0  GMESSAGE = mess(22,2324,1) : GERR =2 : mkstat = 2 : Raz [M:RCL0]BOMOPE0
         # Issue 82935 - 2012-06-15 by SR
         Elsif GHCBWCPTENR > GHCBMAX
               GMESSAGE =  mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:RCL0]BOMOPE0
         Endif
    Endif
    Actzo[M:RCL0]BOMOPE0
Else
    Raz [M:RCL0]BOMOPE0
#    Diszo[M:RCL0]BOMOPE0
    Grizo [M:RCL0]BOMOPE0

Endif
Return

# CATUA X3-68685.sn
#########################################################
$ETI_CTN

  If [V]GRECONCIL=3
    # Reconciliation by container
    WOK = 0

    For [MFM]MFM0 Where [F:MFM]MFGFCY = [M:RCL0]MFGFCY     &
&                       [F:MFM]MFGNUM = [M:RCL0]MFGNUM     &
&                       [F:MFM]CTN = VALEUR                &
&                       [F:MFM]MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
        WOK = 1
        If [F:MFM]WGGSTA =  5  WOK = 8 : Break : Endif
        If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(80,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
      [M:RCL0]CTN = VALEUR
      Gosub CALCUL
      If GHCBWCPTENR = 0  GMESSAGE = mess(79,2324,1) : GERR =2 : mkstat = 2 : Raz [M:RCL0]CTN

      Elsif GHCBWCPTENR > GHCBMAX
        GMESSAGE =  mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:RCL0]CTN
      Endif
    Endif
    Actzo [M:RCL0]CTN
  Else
    Raz [M:RCL0]CTN
    Grizo [M:RCL0]CTN
  Endif
Return
# CATUA X3-68685.en

#########################################################
$ETI_MFGTRKNUM
Local Integer NOL   : [L]NOL=nolign-1

Local Char    ITM
Local Char    LOT
Local Char    WEU
Local Decimal OPE
Local Decimal WEI
Gosub CRTHIST_PESEE

If GHCBWCPT <>0

    Filter[F:WGG1] Where MFGNUM=[M:RCL0]MFGNUM & FCY=[M:RCL0]MFGFCY & MFGTRKNUM=VALEUR &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:RCL0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:RCL0]CTN)  ) # CATUA X3-68685
#&     ([V]GRECONCIL<>2|BOMOPE=[M:RCL0]BOMOPE0)


    Read[F:WGG1]WGG0 First
    If !fstat

        [L]ITM = [F:WGG1]ITMREF
        [L]OPE = [F:WGG1]BOMOPE
        [L]LOT = [F:WGG1]LOT
        [L]WEI = [F:WGG1]WEIWEI
        [L]WEU = [F:WGG1]WEU


        [M:RCL0]ITMREF(NOL) = [F:WGG1]ITMREF
        [M:RCL0]BOMOPE(NOL) = [F:WGG1]BOMOPE
        [M:RCL0]LOT(NOL)    = [F:WGG1]LOT
        [M:RCL0]WEIWEI(NOL) = [F:WGG1]WEIWEI
        [M:RCL0]WEU(NOL)    = [F:WGG1]WEU
        Affzo[M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

        #----- DT 0/07/2010 --------#
        If [M:RCL0]SAISIE(NOL)=1 : # Par pesée
           [M:RCL0]MFGLIN(NOL) = [F:WGG1]MFGLIN
           [M:RCL0]BOMSEQ(NOL) = [F:WGG1]BOMSEQ
           [M:RCL0]CBTDAT(NOL) = [F:WGG1]CBTDAT
           [M:RCL0]MVTSEQ(NOL) = [F:WGG1]MVTSEQ
           Affzo[M:RCL0]MFGLIN(NOL),BOMSEQ(NOL),CBTDAT(NOL),MVTSEQ(NOL)
        Endif
        #---------------------------#


        If mkstat = 0  Call C_ITMREF([L]ITM)     Endif
        If mkstat = 0  Call C_BOMOPE([L]OPE)     Endif
        If mkstat = 0  Call AM_BOMOPE([L]OPE)    Endif
        If mkstat = 0  Call C_LOT([L]LOT)        Endif
        If mkstat = 0  Call AM_LOT([L]LOT)       Endif
        If mkstat = 0  Call C_WEIWEI([L]WEI)     Endif
        If mkstat = 0  Call AM_WEIWEI([L]WEI)    Endif

        If mkstat=0
            [M:RCL0]WEIWEI(NOL) = [F:WGG1]WEIWEI
            [M:RCL0]WEU(NOL)    = [F:WGG1]WEU
#RDH18022011
#            Diszo[M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
            Grizo [M:RCL0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

        Else
            zonsui = "MFGTRKNUM(" + num$(NOL) + ")"
            GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
        Endif

    Else
        VALEUR =""
    Endif
    Filter[F:WGG1]
Else
    GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_LOT
#DT-21/06/2010
If [M:RCL0]SAISIE(nolign-1)=1 : # Par pesée
   Return
Endif
#
Gosub CRTHISTLOT
[M:RCL0]WEIWEI(nolign-1) = 0
[M:RCL0]WEU(nolign-1)    = ""

# sr 09.03 mis en commentaire suite à demande de Céline Charron : ils doivent aussi confirmer la quantité même si une seule pesée
#If GHCBWCPT > 1 Actzo [M:RCL0]WEIWEI
#Else Grizo [M:RCL0]WEIWEI
#Endif

If GHCBWCPT = 1 [M:RCL0]WEU(nolign-1)      = [F:WGG]WEU
Elsif GHCBWCPT = 0 : GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_WEIWEI
Gosub CRTHISTWEI
[M:RCL0]WEU(nolign-1)     = ""
If GHCBWCPT = 1  [M:RCL0]WEU(nolign-1)     = [F:WGG]WEU
Elsif GHCBWCPT = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_ITMREF
Gosub CRTHISTART
If GHCBWCPTART = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Endif
Return

###########################################################
$CTR_PESEE
Local Integer K
Local Integer NOL1: NOL1=nolign-1

If [M:RCL0]NBLIG<>0
  For K=0 To [M:RCL0]NBLIG-1
     If K<>[L]NOL1 & ([M:RCL0]BOMOPE(K)=[M:RCL0]BOMOPE(NOL1) & [M:RCL0]MFGLIN(K)=[M:RCL0]MFGLIN(NOL1))
        If  [M:RCL0]ITMREF(K)=[M:RCL0]ITMREF(NOL1) & [M:RCL0]BOMSEQ(K)=[M:RCL0]BOMSEQ(NOL1)
          If [M:RCL0]CBTDAT(K)=[M:RCL0]CBTDAT(NOL1) & [M:RCL0]MVTSEQ(K)=[M:RCL0]MVTSEQ(NOL1)
             If [M:RCL0]MFGTRKNUM1(K)=[M:RCL0]MFGTRKNUM1(NOL1)
                 [L]CTR_PS=K+1
                 Break
             Endif
          Endif
       Endif
     Endif
  Next K
Endif
Return

# CATUA X3-68685.sn
#Show display only fields 'container calculated tare' and 'container expected weight'
###########################################################
Subprog DISP_CTN_FLDS(CTNCODE)
Value Char CTNCODE
  Local Integer ISEMPTY
  Local Decimal TOTWEI

  Raz TOTWEI
  ISEMPTY=1

  If clalev ([F:CTN])=0  Local File CONTAINERS [CTN] Endif
  If CTNCODE<>""
    Read [CTN]CTN0=CTNCODE
    If !fstat
      ISEMPTY=0
      If CTNCODE<>GHCBLCTN
        [M:RCL0]CTNTHETAR = [CTN]CTNTHETAR
        For [WGG]WGG0 Where MFGNUM = [M:RCL0]MFGNUM & CTN = CTNCODE & WEIWEI <> 0
          TOTWEI += [WGG]WEIWEI
        Next
        [M:RCL0]CTNEXPWEI = TOTWEI

        GHCBLCTN = CTNCODE
      Endif
    Endif
  Endif

  If ISEMPTY
    Raz GHCBLCTN
    Raz [M:RCL0]CTNTHETAR
    Raz [M:RCL0]CTNEXPWEI
    Raz [M:RCL0]CTNCUMWEI
  Endif

  Affzo [M:RCL0]CTNTHETAR
  Affzo [M:RCL0]CTNEXPWEI
  Affzo [M:RCL0]CTNCUMWEI
End

#Calculate total weight from the grid
###########################################################
Funprog CALC_CUMUL_WEI
Local Integer I
Local Decimal OWEI

  Raz OWEI

  If [M:RCL0]NBLIG<>0
    For I=0 To [M:RCL0]NBLIG-1
      OWEI +=  [M:RCL0]WEIWEI(I)
    Next
  Endif

#  If nolign<>0
#    For I=0 To nolign-1
#      OWEI +=  [M:RCL0]WEIWEI(I)
#    Next
#  Endif

End OWEI
# CATUA X3-68685.en

#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
$CHARGE_PARAM
Local Char VALPAR(20)
Call PARAM([M:RCL0]MFGFCY,"RECONCIL",[L]VALPAR) From ADOVAL
[V]GRECONCIL = val([L]VALPAR)
# Issue 82948 - 2012-06-15 by SR : comment
Call PARAM([M:RCL0]MFGFCY,"SELWGG",[L]VALPAR) From ADOVAL
[V]GSELWGG = val([L]VALPAR)
Return

########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
# Issue 82948 - 2012-06-15 by SR
If VALEUR = [M:RCL0]MFGNUM : End : Endif
Gosub ETI_MFGNUM
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
  Local Integer WOK

  If find([V]GRECONCIL,2,3) : Raz [M:RCL0]WCPTENR : Endif  # CATUA X3-68685

  Raz [M:RCL0]BOMOPE0
  Raz [M:RCL0]CTN # CATUA X3-68685
  Raz [M:RCL0]NBLIG

  Filter [F:MFM] Where MFGNUM = VALEUR & MATSTA = 4
  Look [F:MFM]MFM0 First
  If !fstat
    Filter [F:MFM]
    WOK=1
    Call OUINON(mess(39,2324,1),WOK) From GESECRAN
    If WOK <> 2 : mkstat=2 : End : Endif
  Endif
  Filter [F:MFM]

  GHCBIVALEUR = VALEUR
  [M:RCL0]WGGSTA = [F:MFG]WGGSTA

  Affzo [M:RCL0]WGGSTA,BOMOPE0,WCPTENR,CTN # CATUA X3-68685
  Affzo [M:RCL0]15
  Gosub MAJ_MFGHEAD
End

########################################
Subprog S_MFGNUM(VALEUR)
Variable Char    VALEUR()
########################################
#                              WGGFLG >2  > une peser doit etre faite
#                              WGGSTA <>7 > en reconciliation
#                              WGGSTA <>9 > bloqué en peser
#                              WGGFLG <>6 > reconcilié

Filter [F:MFG] Where MFGFCY = [M:RCL0]MFGFCY &  WGGFLG > 2 & WGGFLG < 6 & WGGSTA <> 9
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]

End

########################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR

#DT-21/06/2010
If [V]GRECONCIL=2 & VALEUR <> [M:RCL0]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Else
    GHCBLBOMOPE = VALEUR
    Gosub ETI_ITMREF
Endif

End

########################################
Subprog AM_BOMOPE(VALEUR)
Variable Decimal VALEUR
GHCBLBOMOPE = VALEUR
End

########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Gosub ETI_LOT

GHCBWBOUT = 1

If [M:RCL0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif



End

########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
LLOT = VALEUR
#Gosub ETI_LOT

Affzo  [M:RCL0]WEIWEI(nolign-1)
Affzo  [M:RCL0]WEU(nolign-1)

GHCBWBOUT = 1


If [M:RCL0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif



End

