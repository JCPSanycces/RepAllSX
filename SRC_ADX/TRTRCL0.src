Subprog AV_CTN(VALEUR)
Variable Char    VALEUR()

  If [V]GRECONCIL=3 & [M:RCL0]NBLIG=0
    Actzo[M:RCL0]CTN
  Else
    Grizo[M:RCL0]CTN
  Endif

  If [V]GRECONCIL=3
    If dim([M:RCL0]CTNTHETAR)>0 : Call DISP_CTN_FLDS(VALEUR) : Endif
  Endif
End

