#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet TFC
######################################################################################
# Fichier trésorerie
#   Paramétrage des formules à évaluer pour les flux des échéances.
#   Fichier TABFILCASH : table commune aux formules des 2 flux (échéances et règlements)
#
#  Structure du fichiers
#    MODULE : Toujours Tronc commun (=9) pour le flux des règlements
#    MODULE : Tiers (3), Ventes (5) ou Achats (6) pour le flux des échéances
#    
#    CODCAS : Zone Sage-Concept-Trésorerie pour le flux des règlements => 2671
#    CODCAS : Zone Sage-Concept-Trésorerie pour le flux des échéances  => 2672
#    CODCAS : Zone Trésorerie-1000 pour le flux des règlements => 2674
#    CODCAS : Zone Trésorerie-1000 pour le flux des échéances  => 2675
#
#    CODPAR : Type de Transaction pour le flux des règlement
#    CODPAR : Type de pièce pour le flux des échéances.
#
#    CLCFOR : Formules à évaluer
#
######################################################################################
Raz GPILOBJ
Call OBJET("TFC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "FILTRE"    : Gosub FILTRE
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF

 When "SEL_LISTE" : Gosub SEL_LISTE

 When "SETBOUT"   : Gosub SETBOUT
 When default
Endcase
Return


######################################################################################
$FILTRE
FILTSUP = 'MODULE<>9'     # On s'intérresse uniquement aux paramètrages des flux des échéances
Return

$LIENS
Return
Local Integer NOL : Raz NOL
Filter [TFC] Where MODULE=[M:TFC]MODULE and CODCAS=[M:TFC]CODCAS
For [TFC]
 NOL+=1 
 [M:TFC]CODPAR(NOL-1) = [F:TFC]CODPAR
 [M:TFC]CLCFOR(NOL-1) = [F:TFC]CLCFOR
Next
Filter [TFC]
[M:TFC]NBTFC = NOL
Return

$CREATION
$MODIF
Return
Local Integer INDPRC

Delete [TFC] Where MODULE=[M:TFC]MODULE and CODCAS=[M:TFC]CODCAS
If fstat=1
 GOK = -1 : GLOCK = "$TABFILCASH"-[M:FTC]CODCAS: Return
Endif
For INDPRC=0 To [M:TFC]NBTFC-1
 [F:TFC]MODULE=[M:TFC]MODULE
 [F:TFC]CODCAS=[M:TFC]CODCAS
 [F:TFC]CODPAR=[M:TFC]CODPAR(INDPRC)
 [F:TFC]CLCFOR=[M:TFC]CLCFOR(INDPRC)
 Write [TFC]
 If fstat
  GOK = 0 : Call FSTA("TFC") From GLOCK
 Endif
Next INDPRC
Return

$SEL_LISTE
If !clalev([F:AST]) : Local File APLSTD [AST] : Endif
TIT = mess(12,123,1) :# Choix 
NBTEX = 0 

If func AFNC.ACTIV("SFRPT")
 Filter [AST] Where LANCHP=2685 & LAN=GLANGUE & LANNUM>0
Elsif func AFNC.ACTIV("T1000")
 Filter [AST] Where LANCHP=2675 & LAN=GLANGUE & LANNUM>0
Else
 Filter [AST] Where LANCHP=2672 & LAN=GLANGUE & LANNUM>0
Endif
For [AST]
 NBTEX += 1
 TEX(NBTEX)   = [F:AST]LANMES
 TEXTE(NBTEX) = [F:AST]LANMES
Next
Filter [AST]
Return

$SETBOUT
If REP = ""
 CHAINE += "A"
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

Return
######################################################################################
Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
Local Integer I
Raz GMENLOC
For I=1 To len(mess(0,14,1))
 If !find(I,3,5,6)
  GMENLOC(I) = 1 
 Endif
Next I
If GMODU(5)<>2 : GMENLOC(5) = 1 : Endif
If GMODU(6)<>2 : GMENLOC(6) = 1 : Endif
End

######################################################################################
Subprog C_CODCAS(VALEUR)
Variable Char    VALEUR()
If !clalev([F:AST]) : Local File APLSTD [AST] : Endif

If func AFNC.ACTIV("SFRPT")
 Filter [AST] Where LANCHP=2685 & LAN=GLANGUE & LANNUM>0 & LANMES=VALEUR
Elsif func AFNC.ACTIV("T1000") 
 Filter [AST] Where LANCHP=2675 & LAN=GLANGUE & LANNUM>0 & LANMES=VALEUR
Else
 Filter [AST] Where LANCHP=2672 & LAN=GLANGUE & LANNUM>0 & LANMES=VALEUR
Endif
Read [AST]First
If fstat
 # Code incorrect
 GMESSAGE = mess(25,126,1)
 mkstat=2 : End
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FILCASH) 12/12/2006 12:19:06 (CP)
######################################################################################
Subprog AS_CLCFOR(VALEUR)
Variable Char    VALEUR()
# Filtre sur les tables & écrans

[M]TAB1(1) = "GACCDUDATE"
[M]TAB1(2) = "GACCENTRY"
[M]TAB1(3) = "GACCENTRYD"
[M]TAB1(4) = "GACCENTRYA"
[M]TAB1(5) = "PINVOICE"
[M]TAB1(6) = "SINVOICE"
[M]TAB1(7) = "BPARTNER"
[M]TAB1(8) = "BPCUSTOMER"
[M]TAB1(9) = "BPSUPPLIER"

Case num$([M]MODULE)
 When "5" : If GMODU(5)=2 : [M]TAB2(1) = "SINVOICEV" : Endif
 When "6" : If GMODU(6)=2 : [M]TAB2(1) = "PINVOICEV" : Endif
Endcase

[M]TAB3 = ""
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FILCASH) 25/06/2010 14:32:13 (CP)
######################################################################################
Subprog C_CODPAR(VALEUR)
Variable Char    VALEUR()
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
Filter [GTE] Where DUDCASFLG=2
Read [GTE]GTE0(1) = VALEUR
If fstat
 GMESSAGE = mess(21,173,1) : # Type de pièce interdit en trésorerie
 mkstat = 2
Endif
Filter [GTE]
End


######################################################################################

