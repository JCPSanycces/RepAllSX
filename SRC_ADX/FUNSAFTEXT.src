######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "INIT"       Gosub INIT
  When "INIT_DIA"   Gosub INIT_DIA
  When "CONTROLE"   Gosub CONTROLE
  When "EXEC"       Gosub EXEC
Endcase

Return
######################################################################################
######################################################################################
$INIT

Gosub COMMON_DECLARE

Local Integer TRA, TMP
Local Char    LEGTRT(12)

Raz GFICPATH

Local Mask    SAFT [SAFT]
Local Char    NAM(GDIMFIC), FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), CRITSPE(250)
Local Char    FICDON(GDIMFIC),URL(GDIMFIC), PIHBPS(60)
# Issue X3-27059 - 2017-03-30 by MANOW
Local Integer STAT, SAFTDET
# End issue X3-27059
Local Char    NOMFIC(GDIMFIC)

TRA = 1
TMP = 1
Raz [M:SAFT]

[M]TYPEXP=2
Call AM_TYPEXP([M]TYPEXP)

If [M]VOLFIL="" & !GBATCH
  [M]VOLFIL = "[TMP]"
Endif
Actzo [M]VOLFIL

Return
######################################################################################
######################################################################################
$COMMON_DECLARE

Local Char    LEG(GLONADI), SOC(GLONCPY), COMMENT(255), FILEPATH(GDIMFIC), PIHBPS(GLONBPS), FICHIER(255)
Local Integer SAFTTYPE, FILDESTYP, EVRDOCTYP, DOCTYP, VERSION
Local Date    STRDATE, ENDDATE

Return
######################################################################################
######################################################################################
$INIT_DIA

Raz   [M]
Affzo [M]

[M:SAFT]TYPEXP=2
Call AM_TYPEXP([M:SAFT]TYPEXP)
Return
######################################################################################
######################################################################################
$CONTROLE

#get the legislation of the chosen company
[L]LEG    = func FUNSAFTEXT.GETLEG([M:SAFT]CPY)
If [L]LEG = ""
  OK       = 0
  GERR     = 1
  GMESSAGE = mess(2,45,1) - [M:SAFT]CPY + ":" - tolower(mess(218,107,1)) - mess(42,9003,1)
  Return
Endif

#SAF-T generation process name, legislation dependent
[L]LEGTRT = "SAFTGEN"+[L]LEG

#check if SAF-T generation process exists for the chosen legislation
Call EXISTE_ADX("","",[L]LEGTRT,OK) From ORDSYS
If !OK
  GERR     = 1
  GMESSAGE = func AFNC.MES2(mess(17,7711,1),"SAF-T",[L]LEG)
  Return
Endif

#variables representing the entered data in the screen
[L]SOC       = [M:SAFT]CPY
[L]COMMENT   = [M:SAFT]COMMENT
[L]STRDATE   = [M:SAFT]STRDAT
[L]ENDDATE   = [M:SAFT]ENDDAT
[L]FILEPATH  = [M:SAFT]VOLFIL
[L]SAFTTYPE  = [M:SAFT]SAFTTYP
[L]FILDESTYP = [M:SAFT]TYPEXP
[L]EVRDOCTYP = [M:SAFT]EVRDOCTYP
[L]DOCTYP    = [M:SAFT]DOCTYP
[L]PIHBPS    = [M:SAFT]BPSNUM
[L]FICHIER   = [M:SAFT]FIC
# Issue X3-27059 - 2017-03-30 by MANOW
[L]SAFTDET   = [M:SAFT]SAFTDET
# End issue X3-27059
[L]VERSION   = [M:SAFT]VERSION

#run the CONTROLE action for the chosen legislation
Gosub ACTION From =LEGTRT

Return
######################################################################################
######################################################################################
$EXEC

#lock this function for the chosen company
If dim ([L]SYMBOLE)<0 : Local Char SYMBOLE(100) : Endif
[L]SYMBOLE = GFONCTION + [L]SOC
Lock = [L]SYMBOLE
If fstat
  OK       = 0
  GERR     = 1
  GMESSAGE = func AFNC.MES1(mess(18,7711,1),[L]SOC)
  Return
Endif

#run the EXEC action for the chosen legislation
Gosub ACTION From =[L]LEGTRT

Unlock = [L]SYMBOLE

Return
######################################################################################
######################################################################################
###
###                                  OTHER
###
######################################################################################
######################################################################################
###--------------------------------------------------------------------------------###
######################################################################################
### Control program for parameters (SAFTPGROU)
######################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK

Case [L]PARAM
  When "SAFTPGROU"
    Local Integer STIVAL
    STIVAL = func AFNC.ACTIV("STI")
    If val([L]VALEUR) < 1 or val([L]VALEUR) > STIVAL
      GMESSAGE = mess(226,9151,1)+"."-mess(15,9097,1)-num$(STIVAL) #Incorrect value. Must lie between 1 and x
      OK       = 0
      End
    Endif
Endcase

End
######################################################################################
######################################################################################
###
###                                 REUSABLE PROGRAMS
###
######################################################################################
######################################################################################
###--------------------------------------------------------------------------------###
######################################################################################
### returns the legislation of a given company
######################################################################################
Funprog GETLEG(CPY)
Value Char CPY

Local Char LEG(GLONADI) : [L]LEG = ""

If [L]CPY = "" : Goto ENDGETLEG : Endif

Local File COMPANY [CPY]

Read [F:CPY]CPY0 = [L]CPY
If fstat : Raz [F:CPY] : Endif

[L]LEG = [F:CPY]LEG

$ENDGETLEG
End [L]LEG
######################################################################################
### check file
######################################################################################
$CONTFIC
Local Char    NAM(GDIMFIC) , SUF(30)
Local Integer ER, I
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(GDIMFIC)

If NOMFIC=""
 GMESSAGE = mess(35,126,1) : # Filename incorrect
 mkstat=1 : Return
Elsif left$(NOMFIC,1)="#"
 GMESSAGE = mess(162,141,1) : # The directory must be specified on a server
 mkstat = 2 : Return
Elsif instr(1,NOMFIC,"#")
 Return
Endif

Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Non-existent Machine
 mkstat = 2 : Return
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # The directory must be specified on a server
  mkstat = 2 : Return
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Directory inaccessible
  mkstat = 2 : Return
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Directory inaccessible
  mkstat = 2 : Return
 Endif
Endif
Call EXISTE(NOMFIC,ER) From ORDSYS
Case ER
 When 2
  #GMESSAGE = mess(55,141,1) : # This file is a directory
  #mkstat = 2 : Return
  If OS="unix"
    If right$(NOMFIC,len(NOMFIC))<>"/"
      NOMFIC += "/"
    Endif
  Else
    If right$(NOMFIC,len(NOMFIC))<>"\"
      NOMFIC += "\"
    Endif
  Endif
 When 0
#  GMESSAGE = mess(87,100,1)+tolower(mess(4,95,1)) : # Non-existent file
#  mkstat = 2 : Return
Endcase

Return
######################################################################################
######################################################################################
###
###                                 FIELD ACTIONS
###
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

Local Char LEG(GLONADI)
Local Integer OK

#get the legislation of the chosen company
[L]LEG    = func FUNSAFTEXT.GETLEG(VALEUR)
If [L]LEG = ""
  GMESSAGE = mess(2,45,1) - [M:SAFT]CPY + ":" - tolower(mess(218,107,1)) - mess(42,9003,1)
  mkstat = 2
  End
Endif

#check if SAF-T generation process exists for the chosen legislation
Call EXISTE_ADX("","","SAFTGEN"+[L]LEG,OK) From ORDSYS
If !OK
  GMESSAGE = func AFNC.MES2(mess(17,7711,1),"SAF-T",[L]LEG)
  mkstat = 2
  End
Endif

End
######################################################################################
Subprog AS_SAFTTYP(VALEUR)
Variable Integer VALEUR

Local Char LEG(GLONADI)
[L]LEG = func FUNSAFTEXT.GETLEG([M:SAFT]CPY)

Local Integer I

Raz GMENLOC
Case [L]LEG
    When "POR"
        If GMODU(2)<>2 & GMODU(5) <>2 & GMODU(6) <>2
          For I=2 To dim(GMENLOC)-1
            GMENLOC(I) = 1
          Next
        Else
          GMENLOC(1) = 1
        Endif

        If GMODU(6) <> 2 #check if Purchase module is present
          GMENLOC(5) = 1
          GMENLOC(7) = 1
        Endif
        If GMODU(5) <>2 #check if Sales module is present
          GMENLOC(2) = 1
          GMENLOC(3) = 1
          GMENLOC(6) = 1
          GMENLOC(8) = 1
        Endif
        If GMODU(2) <>2 #check if Accouting module is present
          GMENLOC(2) = 1
          GMENLOC(4) = 1
        Endif

    When Default
        For I = 1 To dim(GMENLOC)-1
            GMENLOC(I) = 1
        Next
Endcase

End
######################################################################################
## Section automatically added (screen SAFT) 07/17/2014 12:51:12 (RICAR)
######################################################################################
Subprog AM_STRFCY(VALEUR)
Variable Char    VALEUR()
If [M]ENDFCY = ""
  [M]ENDFCY = VALEUR
  Affzo [M]ENDFCY
Endif
End

Subprog AM_EVRDOCTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Diszo [M]DOCTYP
  Diszo [M]DOCNUMSTR
  Diszo [M]DOCNUMEND
Else
  Actzo [M]DOCTYP
  Actzo [M]DOCNUMSTR
  Actzo [M]DOCNUMEND
Endif
End

Subprog AS_DOCNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]EVRDOCTYP = 2
  mkstat = 2
  Diszo [M]DOCNUMSTR
Endif
End

Subprog AM_DOCNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]DOCNUMEND = ""
  [M]DOCNUMEND = VALEUR
  Affzo [M]DOCNUMEND
Endif
End

Subprog AS_DOCNUMEND(VALEUR)
Variable Char    VALEUR()
If [M]EVRDOCTYP = 2
  mkstat = 2
  Diszo [M]DOCNUMEND
Endif

End

Subprog AS_DOCTYP(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1)=1
If func AFNC.ACTIV('TRSNE')<1
  GMENLOC(10)=1
Endif
End

Subprog AP_SAFTTYP(VALEUR)
Variable Integer VALEUR

# Issue 27059 - 2017-03-21 by MRDAB : As an accountant I wan't to have the possibility of generating SAFT detailed by BP
If find(VALEUR,2,4)
  Actzo [M:SAFT]SAFTDET
  Affzo [M:SAFT]SAFTDET
Else
  [M:SAFT]SAFTDET = 0
  Diszo [M:SAFT]SAFTDET
  Affzo [M:SAFT]SAFTDET
Endif
# End issue 27059

If find(VALEUR,5,7)
    Actzo [M:SAFT]BPSNUM
    Affzo [M:SAFT]BPSNUM
Else
    [M:SAFT]BPSNUM = ""
    Diszo [M:SAFT]BPSNUM
    Affzo [M:SAFT]BPSNUM
Endif

If VALEUR = 8
    Actzo [M:SAFT]STRFCY
    Actzo [M:SAFT]ENDFCY
    Actzo [M:SAFT]DOCTYP
    Actzo [M:SAFT]DOCNUMSTR
    Actzo [M:SAFT]DOCNUMEND
    Actzo [M:SAFT]EVRDOCTYP
Else
    [M:SAFT]STRFCY    = ""
    [M:SAFT]ENDFCY    = ""
    [M:SAFT]DOCTYP    = 0
    [M:SAFT]DOCNUMSTR = ""
    [M:SAFT]DOCNUMEND = ""
    [M:SAFT]EVRDOCTYP = 1
    Diszo [M:SAFT]STRFCY
    Diszo [M:SAFT]ENDFCY
    Diszo [M:SAFT]DOCTYP
    Diszo [M:SAFT]DOCNUMSTR
    Diszo [M:SAFT]DOCNUMEND
    Diszo [M:SAFT]EVRDOCTYP

Endif
End

Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
End


######################################################################################
######################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Actzo [M]VOLFIL
Endif
End
######################################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If GBATCH & VALEUR=1
 # Le poste client est inaccessible en batch
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif

End
######################################################################################
######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Raz [M:SAFT]VOLFIL
 Grizo [M:SAFT]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:SAFT]VOLFIL
Endif
Affzo [M:SAFT]VOLFIL

End
######################################################################################
######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End
######################################################################################
Subprog D_SAFTTYP(VALEUR)
Variable Integer VALEUR
# Issue 27059 - 2017-03-21 by MRDAB : As an accountant I wan't to have the possibility of generating SAFT detailed by BP
If find(VALEUR,2,4)
  Actzo [M:SAFT]SAFTDET
  Affzo [M:SAFT]SAFTDET
Else
  Diszo [M:SAFT]SAFTDET
  Affzo [M:SAFT]SAFTDET
Endif
# End issue 27059
End
