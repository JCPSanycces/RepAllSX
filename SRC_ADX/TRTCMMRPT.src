#<AdxTL>@(#)0.0.0.0 $Revision$
###################################
#   Trt des états d'engagements   #
###################################

$ACTION
Gosub ACTION From CPTRPT
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([CMM])=0 : Local File GCOMMIT  [CMM] : Endif
If clalev([CMD])=0 : Local File GCOMMITD [CMD] : Endif
If clalev([CMX])=0 : Local File GCOMMITX [CMX] : Endif
If clalev([LED])=0 : Local File GLED     [LED] : Endif


####################################################
## Récup paramètres
####################################################
Local Integer TYPETAT
Local Char    PARAM(30) , ETAT(GLONARP), NOM_ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer K,I,J

Local Char    SOCIETE(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    NUMDEB(20) , NUMFIN(20)
Local Date    DATDEB , DATFIN
Local Integer TOUREF,REFERENTIEL
Local Integer ENG,PREENG
Local Char    TIERSDEB(GLONBPR), TIERSFIN(GLONBPR)

Local Char FILTRE(250),FILTRE2(250)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
NUMREQ = val(PARAM)

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM) From ETAT
K = instr(1,PARAM,".")
If K : PARAM = left$(PARAM,K-1) : Endif
ETAT = PARAM

Call GETPARAM("societe",NBPAR,PARAMETRE,[L]SOCIETE) From ETAT
Read [CPY]CPY0 = SOCIETE
If !fstat & [F:CPY]CPYLEGFLG<>2
 # XXXX : Cette société n'est pas une société juridique
 Call ECR_TRACE(SOCIETE+":"-mess(12,199,1),1) From GESECRAN
 GOK = 0 : End
Endif

Call GETPARAM("sitedeb",NBPAR,PARAMETRE,[L]SITDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,[L]SITFIN) From ETAT
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT : [L]DATDEB=PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT : [L]DATFIN=PARAM
Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM) From ETAT  : [L]REFERENTIEL = val(PARAM)
Call GETPARAM("engage",NBPAR,PARAMETRE,PARAM) From ETAT      : [L]ENG = val(PARAM)
Call GETPARAM("preengage",NBPAR,PARAMETRE,PARAM) From ETAT  : [L]PREENG = val(PARAM)

If ETAT="COMMITMENT"
 Call GETPARAM("touref",NBPAR,PARAMETRE,PARAM) From ETAT      : [L]TOUREF = val(PARAM)
Else
 [L]TOUREF=2
Endif

FILTRE = 'CPY="'+[L]SOCIETE+'"'
#FILTRE-= '& FCY>="'+[L]SITDEB+'" & FCY<="'+[L]SITFIN+'"'
#FILTRE-= '& ACCDAT>=['+format$(GFMD,[L]DATDEB)+'] & ACCDAT<=['+format$(GFMD,[L]DATFIN)+']'
FILTRE2 = 'ACCDAT>=['+format$(GFMD,[L]DATDEB)+'] & ACCDAT<=['+format$(GFMD,[L]DATFIN)+']'

Case [L]ENG+[L]PREENG
 When 1 :
  If [L]ENG=1
   #Engagement
   FILTRE -= '& TYP=2'
  Else
   #Pre-engagement
   FILTRE -= '& TYP=1'
  Endif
Endcase

Call DEBTRANS From GLOCK
Trbegin [CMX]
#Raz GCOMMITX
 Delete [CMX] Where 1=1
 If fstat=1 | fstat>5
  GOK = 0
  Call RSTA("CMX","") From GLOCK
  Rollback
 Endif
Commit
If !GOK : Return : Endif

#------------------------------

Call DEBTRANS From GLOCK
Trbegin [CMX]
Filter [CMM] Where evalue(FILTRE)
Local Integer OK : OK=1
For [CMM]CMM0
 For [F:CMD]CMD0 Where NUM=[F:CMM]NUM & evalue(FILTRE2)
  If [L]TOUREF=1  
   For I=0 To dim([F:CMD]LEDTYP)-1
    If [F:CMD]LEDTYP(I)<>0
     Gosub TR1
     If !OK : Break 2 :  Goto ROLL_TR1 : Endif
    Endif
   Next
  Else
   I=REFERENTIEL-1   
   If [F:CMD]LEDTYP(I)<>0
    Gosub TR1   
    If !OK : Break 2 :  Goto ROLL_TR1 : Endif
   Endif
  Endif
 Next 
Next
Filter [CMM]
Commit
End

$TR1
Raz [F:CMX]
#
[F:CMX]SNS = [F:CMM]SNS
[F:CMX]TYP = [F:CMM]TYP
[F:CMX]BPR = [F:CMM]BPR
[F:CMX]FCY = [F:CMM]FCY
# 
[F:CMX] = [F:CMD]
[F:CMX]LEDTYP = [F:CMD]LEDTYP(I)
[F:CMX]AMTLED = [F:CMD]AMTLED(I)
[F:CMX]CURLED = [F:CMD]CURLED(I)
[F:CMX]LED    = [F:CMD]LED(I)
[F:CMX]COA    = [F:CMD]COA(I)
[F:CMX]ACC    = [F:CMD]ACC(I)
#
Read [LED]LED0 = [F:CMD]LED(I)
If !fstat
 K=0
 For J=0 To dim([F:LED]DIE)-1
  X=find([F:LED]DIE(J),[F:CMD]DIE(0..dim([F:CMD]DIE)-1))
  If X
   [F:CMX]DIE(J) = [F:CMD]DIE(X-1)
   [F:CMX]CCE(J) = [F:CMD]CCE(X-1)
  Endif
 Next
Endif
Write [CMX]  
If fstat : OK=0 : Call FSTA("CMX") From GLOCK : Endif  
Return 
 
$ROLL_TR1
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1 
Rollback 
Return 

