#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Case ACTION
  When "DEBUT" : Gosub DEBUT
Endcase
#94635 RICAR 2014/04/21 - CASH VAT - END
Return

$DEBUT
#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
[M:PAYS]CASHVATNUM  = [F:PYH]CASHVATNUM
[M:PAYS]VATSTA      = [F:PYH]VATSTA
[M:PAYS]CSHVATRGM   = [F:PYH]CSHVATRGM
[M:PAYS]COMDAT      = [F:PYH]COMDAT

If !clalev([F:PAYV]) : Local File PAYVAT [PAYV] : Endif
Filter [F:PAYV] Where PAYNUM = [F:PYH]NUM & PAYMENTSTA = 2
Read [F:PAYV] First
If !fstat
  [M:PAYS]PAYMENTSTA  = [F:PAYV]PAYMENTSTA
Else
  Filter [F:PAYV] Where PAYNUM = [F:PYH]NUM & PAYMENTSTA = 1
  Read [F:PAYV] First
  If !fstat
    [M:PAYS]PAYMENTSTA  = [F:PAYV]PAYMENTSTA
  Endif
Endif

Filter [F:PAYV]
#94635 RICAR 2014/04/21 - CASH VAT - END
Return
