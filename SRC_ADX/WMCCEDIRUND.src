If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLDNOLIB From WMC1EDIRUND : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLDNOLIB From WMC1EDIRUND : Gosub TESTALLSTAT :  Endif
