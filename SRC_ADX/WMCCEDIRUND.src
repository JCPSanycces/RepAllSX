If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NUM From WMC1EDIRUND : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NUM From WMC1EDIRUND : Gosub TESTALLSTAT :  Endif
