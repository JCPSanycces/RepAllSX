$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 3383: RES='Table des Devises'
   When 323: RES='Devise'
  Endcase
 When "ENG":
  Case _ID
   When 3383: RES='Currency table'
   When 323: RES='Currency'
  Endcase
 When "ITA":
  Case _ID
   When 3383: RES='Tabella delle valute'
   When 323: RES='Valuta'
  Endcase
 When "POR":
  Case _ID
   When 3383: RES='Tabela das Divisas'
   When 323: RES='Divisa'
  Endcase
 When "SPA":
  Case _ID
   When 3383: RES='Tabla de Divisas'
   When 323: RES='Divisa'
  Endcase
 When "BRI":
  Case _ID
   When 3383: RES='Currencies'
   When 323: RES='Currency'
  Endcase
 When "GER":
  Case _ID
   When 3383: RES='Währungstabelle'
   When 323: RES='Währung'
  Endcase
 When "POL":
  Case _ID
   When 3383: RES='Waluty'
   When 323: RES='Waluta'
  Endcase
 When "CHI":
  Case _ID
   When 3383: RES='货币'
   When 323: RES='货币'
  Endcase
 When "ARB":
  Case _ID
   When 3383: RES='جدول العملات'
   When 323: RES='العملة'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
