#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Etape 4 de la définition d'un mailing                             Module CRM          29 novembre 2000 #
##########################################################################################################
# Résultat de la sélection
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "RAF"          : Gosub REFRESH
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "SUP"          : Gosub SUP    # FGR 30/06/2016 : X3SUIVI117416
    When Default
  Endcase
Return

##########################################################################################################
$SUP
  Gosub ONDEL
Return

##########################################################################################################
$REFRESH
  Call LOADRESULT(1,0)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$PREMIER
  If [M:MAI4]NBQSND <= dim([M:MAI4]BPRNAM) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADRESULT(1,0)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$PRECEDENT
  If [M:MAI4]NBQSND <= dim([M:MAI4]BPRNAM) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADRESULT(2,0)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$SUIVANT
  If [M:MAI4]NBQSND <= dim([M:MAI4]BPRNAM) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADRESULT(3,0)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$DERNIER
  If [M:MAI4]NBQSND <= dim([M:MAI4]BPRNAM) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADRESULT(4,0)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$OUVRE
Global Char GSZCNTTTR(75)
Global Char GSZWNDADD
Global Char GSZPROGADD
Global Char GSZVWNDADD
Global Char GSZVPROGADD
Global Integer GIMAI4NOL
#Gestion des boutons magnétos
Global Char GSZMAI4FCRY
Global Char GSZMAI4FSAT
Global Char GSZMAI4FZIP
Global Char GSZMAI4FCTY
Global Char GSZMAI4FBPR
Global Char GSZMAI4FREC
Global Char GSZMAI4LCRY
Global Char GSZMAI4LSAT
Global Char GSZMAI4LZIP
Global Char GSZMAI4LCTY
Global Char GSZMAI4LBPR
Global Char GSZMAI4LREC

  GSZMAI4FCRY = ""
  GSZMAI4FSAT = ""
  GSZMAI4FZIP = ""
  GSZMAI4FCTY = ""
  GSZMAI4FBPR = ""
  GSZMAI4FREC = ""
  GSZMAI4LCRY = ""
  GSZMAI4LSAT = ""
  GSZMAI4LZIP = ""
  GSZMAI4LCTY = ""
  GSZMAI4LBPR = ""
  GSZMAI4LREC = ""
  #---------------------------------------------------#
  GIMAI4NOL = 0
  GSZCNTTTR = ""
  GSZTYPSEA = ""
  GSZWNDADD = ""
  GSZPROGADD = ""
  GSZVWNDADD = ""
  GSZVPROGADD = ""
  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:LDS]) : Local File LEAD [LDS] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Affiche le titre de l'opération mailing
  Case GSZWIZCOD
    When "MAILING"
      Read [OMM]OMM0=GSZOPGNUM
      If !fstat Then
        [M:MAI4]OPGDES = [F:OMM]DES
      Endif
    When "PHONING"
      Read [OMP]OMP0=GSZOPGNUM
      If !fstat Then
        [M:MAI4]OPGDES = [F:OMP]DES
      Endif
    When "TRADESHOW"
    When Default
  Endcase
  Read [SEC]SEC0=GSZOPGNUM;"CCN"
  If fstat Then
    Return
  Endif
  GSZCNTTTR = [F:SEC]CNTTTR
  GSZXMLCNTTTR = [F:SEC]CNTTTR
  GIDEFADD = [F:SEC]DEFADD
  GIHIEBPR=  [F:SEC]HIEBPR
  If [F:SEC]USEQUR = 2 Then
    #on a des ciblages CCN
    GSZTYPSEA = "CCN"
    GSZWNDADD = "FMAX3"
    GSZPROGADD = "TRTMAX3"
    GSZVWNDADD = "FMAX3V"
    GSZVPROGADD = "TRTMAX3V"
  Else
    GSZTYPSEA = "BPR"
    GSZWNDADD = "FMAY3"
    GSZPROGADD = "TRTMAY3"
    GSZVWNDADD = "FMAY3V"
    GSZVPROGADD = "TRTMAY3V"
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" or GNAVIG(GPILNAV-1) = "GESOMP" Then
      Call LOADRESULT(1,1)
    Else
      Call SORTPANEL
      Call LOADRESULT(1,1)
    Endif
  Else
    Call SORTPANEL
    Call LOADRESULT(1,1)
  Endif
  #LSE 28/11/2006
  Diszo [M:MAI4]NBQADD
  Diszo [M:MAI4]NBQEMA
  Diszo [M:MAI4]NBQFAX
  Diszo [M:MAI4]NBQBAN
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:MAI4]
  Kill GSZCNTTTR
  Kill GSZWNDADD
  Kill GSZPROGADD
  Kill GSZVWNDADD
  Kill GSZVPROGADD
  Kill GIMAI4NOL
  Kill GSZMAI4FCRY
  Kill GSZMAI4FSAT
  Kill GSZMAI4FZIP
  Kill GSZMAI4FCTY
  Kill GSZMAI4FBPR
  Kill GSZMAI4FREC
  Kill GSZMAI4LCRY
  Kill GSZMAI4LSAT
  Kill GSZMAI4LZIP
  Kill GSZMAI4LCTY
  Kill GSZMAI4LBPR
  Kill GSZMAI4LREC
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  If BOUT = "E" Then
    Gosub ONCONFIRM
  Endif
Return

##########################################################################################################
$ONMENU
  Case BOUT
    When "L"
      Gosub ONNEGATIVE
    When Default
  Endcase
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONDEL
  Call TEMPON("F") From GESECRAN
  If GSZTYPSEA = "CCN" Then
    If GIMAI4NOL >= 0 Then
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                    and [F:SCL]RECTYP = "CCN"
&                    and [F:SCL]RECNUM = [M:MAI4]KEYREC(GIMAI4NOL)
&                    and [F:SCL]BPRNUM = [M:MAI4]KEYBPRREC(GIMAI4NOL)
&                    and [F:SCL]BPAADD = [M:MAI4]KEYBPAREC(GIMAI4NOL)
      For [SCL]SCL2
        Call DEBTRANS From GLOCK
        Trbegin [SCL]
        Delete [SCL]Curr
        If fstat Then
          GMESSAGE = mess(425,196,1) #Erreur lors de la suppression du destinataire. Opération refusée.
          GERR = 1
          Unlock [SCL]
          Rollback
          # FGR 08/02/2010 : X3SUIVI60986
          #Return
          Break
        Else
          Commit
          Unlock [SCL]
        Endif
      Next
      Filter [SCL]
      # FGR 08/02/2010 : X3SUIVI60986
      If GERR Then
        Call TEMPOFF From GESECRAN   # FGR 08/02/2010 : X3SUIVI60986
        Return
      Endif
    Else
      Call TEMPOFF From GESECRAN   # FGR 08/02/2010 : X3SUIVI60986
      GMESSAGE = mess(426,196,1) #Erreur lors de la sélection du destinataire. Opération refusée.
      GERR = 2
      Return
    Endif
  Elsif GSZTYPSEA = "BPR" Then
    If GIMAI4NOL >= 0 Then
      Readlock [SCL]SCL1=GSZOPGNUM;"BPR";[M:MAI4]KEYREC(GIMAI4NOL)
      If !fstat Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL]
        Delete [SCL]Curr
        If fstat Then
          Call TEMPOFF From GESECRAN   # FGR 08/02/2010 : X3SUIVI60986
          GMESSAGE = mess(425,196,1) #Erreur lors de la suppression du destinataire. Opération refusée.
          GERR = 1
          Unlock [SCL]
          Rollback
          Return
        Else
          Commit
          Unlock [SCL]
        Endif
      Endif
    Else
      Call TEMPOFF From GESECRAN   # FGR 08/02/2010 : X3SUIVI60986
      GMESSAGE = mess(426,196,1) #Erreur lors de la sélection du destinataire. Opération refusée.
      GERR = 2
      Return
    Endif
  Endif
  Call TEMPOFF From GESECRAN
  Call LOADRESULT(1,1)
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
$ONCONFIRM
  #Prépare les données de fusion du mailing.
  If GSZWIZCOD = "MAILING" Then
    Call PREMRGDAT
    Call NBSNDINF
  Elsif GSZWIZCOD = "PHONING" Then
    #Affecte les informations utiles pour l'extraction XML éventuelle.
    Call DEBTRANS From GLOCK
    Trbegin [OMP]
    Readlock [OMP]OMP0 = GSZOPGNUM
    #Il s'agit d'un nouvel enregistrement
    If !fstat Then
      [F:OMP]DEFADD = GIDEFADD
      [F:OMP]HIEBPR = GIHIEBPR
      [F:OMP]TYPSEA = GSZTYPSEA
      [F:OMP]CNTTTR = GSZXMLCNTTTR
      Rewrite [OMP]
      If fstat Then
        GMESSAGE = mess(101,141,1) #Erreur modification
        GERR = 1
        Unlock [OMP]
        Rollback
        End
      Else
        Commit
        Unlock [OMP]
      Endif
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

##########################################################################################################
$CANCELSTEP
  If GSZWIZCOD = "MAILING" Then
    Call RAZOMMRES
  Endif
Return

##########################################################################################################
# Charge la fenêtre de consultation des cibles
###################################################################
Subprog LOADRESULT(IWHATTODO, ICPTNBREC)
Value Integer IWHATTODO
Value Integer ICPTNBREC

  Gosub VARFEEDMAI4LINE
  Gosub RAZVARFEEDMAI4LINE

Local Integer ITER
Local Integer IZ
Local Integer IFEEDMGC1
Local Integer IFIRLOOP
Local Integer IPRECNT
Local Integer ICANFOR
Local Integer IOUTOFMAI4
Local Char SZBPTYP

  IFEEDMGC1 = 1
  IFIRLOOP = 0
  IPRECNT = 0
  ICANFOR = 0
  IZ = 0
  ITER = 0
  IOUTOFMAI4 = 0
  SZBPTYP = ""
  If ICPTNBREC Then
    Raz [M:MAI4]NBQSND
    Raz [M:MAI4]NBQADD
    Raz [M:MAI4]NBQEMA
    Raz [M:MAI4]NBQFAX
    Raz [M:MAI4]NBQBAN
  Endif
  Call RAZRESULT
  Call TEMPON("L") From GESECRAN
  If IWHATTODO = 1 Then    #Premier
    If GSZTYPSEA = "CCN" Then
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN"
&               Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
    Elsif GSZTYPSEA = "BPR" Then
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
&               Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
    Endif
    For [SCL] Hint Key SCL0
      If ITER < dim([M:MAI4]BPRNAM) Then
        IOUTOFMAI4 = 0
        If ITER = 0 Then
          GSZMAI4FCRY = [F:SCL]SCLCRY
          GSZMAI4FSAT = [F:SCL]SCLSAT
          GSZMAI4FZIP = [F:SCL]SCLZIP
          GSZMAI4FCTY = [F:SCL]SCLCTY
          GSZMAI4FBPR = [F:SCL]BPRNUM
          GSZMAI4FREC = [F:SCL]RECNUM
        Endif
        GSZMAI4LCRY = [F:SCL]SCLCRY
        GSZMAI4LSAT = [F:SCL]SCLSAT
        GSZMAI4LZIP = [F:SCL]SCLZIP
        GSZMAI4LCTY = [F:SCL]SCLCTY
        GSZMAI4LBPR = [F:SCL]BPRNUM
        GSZMAI4LREC = [F:SCL]RECNUM
        #On remplit la ligne
        Gosub MAI4LINESCREEN
        ITER += 1
        [M:MAI4]NBCCN += 1
      Else
        If ICPTNBREC Then
          IOUTOFMAI4 = 1
          Gosub MAI4LINESCREEN
        Else
          Break
        Endif
      Endif
    Next
    Filter [SCL]
  Elsif IWHATTODO = 2   #Précédent
    While IFEEDMGC1
      If IFIRLOOP = 0 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]RECNUM <= GSZMAI4FREC
&                        and [F:SCL]BPRNUM = GSZMAI4FBPR
&                        and [F:SCL]SCLCTY = GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]RECNUM <= GSZMAI4FREC
&                        and [F:SCL]BPRNUM = GSZMAI4FBPR
&                        and [F:SCL]SCLCTY = GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 1 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]BPRNUM < GSZMAI4FBPR
&                        and [F:SCL]SCLCTY = GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]BPRNUM < GSZMAI4FBPR
&                        and [F:SCL]SCLCTY = GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 2 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCTY < GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCTY < GSZMAI4FCTY
&                        and [F:SCL]SCLZIP = GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 3 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLZIP < GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLZIP < GSZMAI4FZIP
&                        and [F:SCL]SCLSAT = GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 4 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLSAT < GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLSAT < GSZMAI4FSAT
&                        and [F:SCL]SCLCRY = GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 5 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCRY < GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCRY < GSZMAI4FCRY
&                   Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
        Endif
        IFIRLOOP += 1
        IFEEDMGC1 = 0
      Endif
      If !ICANFOR Then
        IFEEDMGC1 = 1
        For [SCL]
          If ITER >= dim([M:MAI4]BPRNAM)-1 Then
            ICANFOR = 1
            IFIRLOOP = 0
            Break
          Endif
          ITER += 1
        Next
        IPRECNT += 1
        If IPRECNT >= 6 Then
          ICANFOR = 1
          IFIRLOOP = 0
        Endif
      Else
        For [SCL] Hint Key SCL0
          If ITER >= 0 Then
            If [M:MAI4]NBCCN = 0 Then
              GSZMAI4LCRY = [F:SCL]SCLCRY
              GSZMAI4LSAT = [F:SCL]SCLSAT
              GSZMAI4LZIP = [F:SCL]SCLZIP
              GSZMAI4LCTY = [F:SCL]SCLCTY
              GSZMAI4LBPR = [F:SCL]BPRNUM
              GSZMAI4LREC = [F:SCL]RECNUM
            Endif
            GSZMAI4FCRY = [F:SCL]SCLCRY
            GSZMAI4FSAT = [F:SCL]SCLSAT
            GSZMAI4FZIP = [F:SCL]SCLZIP
            GSZMAI4FCTY = [F:SCL]SCLCTY
            GSZMAI4FBPR = [F:SCL]BPRNUM
            GSZMAI4FREC = [F:SCL]RECNUM
            #On remplit la ligne
            Gosub MAI4LINESCREEN
            ITER -= 1
            IZ += 1
            [M:MAI4]NBCCN += 1
          Else
            Break
          Endif
        Next
      Endif
      Filter [SCL]
      If ITER < 0 Then
        Break
      Endif
      If IZ >= dim([M:MAI4]BPRNAM) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 3 Then  #Suivant
    While IFEEDMGC1
      If IFIRLOOP = 0 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]RECNUM >= GSZMAI4LREC
&                        and [F:SCL]BPRNUM = GSZMAI4LBPR
&                        and [F:SCL]SCLCTY = GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]RECNUM >= GSZMAI4LREC
&                        and [F:SCL]BPRNUM = GSZMAI4LBPR
&                        and [F:SCL]SCLCTY = GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 1 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]BPRNUM > GSZMAI4LBPR
&                        and [F:SCL]SCLCTY = GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]BPRNUM > GSZMAI4LBPR
&                        and [F:SCL]SCLCTY = GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 2 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCTY > GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCTY > GSZMAI4LCTY
&                        and [F:SCL]SCLZIP = GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 3 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLZIP > GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLZIP > GSZMAI4LZIP
&                        and [F:SCL]SCLSAT = GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 4 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLSAT > GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLSAT > GSZMAI4LSAT
&                        and [F:SCL]SCLCRY = GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 5 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCRY > GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCRY > GSZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;[F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
        IFEEDMGC1 = 0
      Endif
      For [SCL] Hint Key SCL0
        If ITER < dim([M:MAI4]BPRNAM) Then
          If ITER = 0 Then
            GSZMAI4FCRY = [F:SCL]SCLCRY
            GSZMAI4FSAT = [F:SCL]SCLSAT
            GSZMAI4FZIP = [F:SCL]SCLZIP
            GSZMAI4FCTY = [F:SCL]SCLCTY
            GSZMAI4FBPR = [F:SCL]BPRNUM
            GSZMAI4FREC = [F:SCL]RECNUM
          Endif
          GSZMAI4LCRY = [F:SCL]SCLCRY
          GSZMAI4LSAT = [F:SCL]SCLSAT
          GSZMAI4LZIP = [F:SCL]SCLZIP
          GSZMAI4LCTY = [F:SCL]SCLCTY
          GSZMAI4LBPR = [F:SCL]BPRNUM
          GSZMAI4LREC = [F:SCL]RECNUM
          #On remplit la ligne
          Gosub MAI4LINESCREEN
          ITER += 1
          [M:MAI4]NBCCN += 1
        Else
          Break
        Endif
      Next
      Filter [SCL]
      If ITER >= dim([M:MAI4]BPRNAM) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 4 Then    #Dernier
    If GSZTYPSEA = "CCN" Then
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN"
&               Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
    Elsif GSZTYPSEA = "BPR" Then
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
&               Order By [F:SCL]SCLCRY Desc; [F:SCL]SCLSAT Desc; [F:SCL]SCLZIP Desc;[F:SCL]SCLCTY Desc; [F:SCL]BPRNUM Desc; [F:SCL]RECNUM Desc
    Endif
    ITER = dim([M:MAI4]BPRNAM)-1
    For [SCL] Hint Key SCL0
      If ITER >= 0 Then
        If [M:MAI4]NBCCN = 0 Then
          GSZMAI4LCRY = [F:SCL]SCLCRY
          GSZMAI4LSAT = [F:SCL]SCLSAT
          GSZMAI4LZIP = [F:SCL]SCLZIP
          GSZMAI4LCTY = [F:SCL]SCLCTY
          GSZMAI4LBPR = [F:SCL]BPRNUM
          GSZMAI4LREC = [F:SCL]RECNUM
        Endif
        GSZMAI4FCRY = [F:SCL]SCLCRY
        GSZMAI4FSAT = [F:SCL]SCLSAT
        GSZMAI4FZIP = [F:SCL]SCLZIP
        GSZMAI4FCTY = [F:SCL]SCLCTY
        GSZMAI4FBPR = [F:SCL]BPRNUM
        GSZMAI4FREC = [F:SCL]RECNUM
        #On remplit la ligne
        Gosub MAI4LINESCREEN
        ITER -= 1
        [M:MAI4]NBCCN += 1
      Else
        Break
      Endif
    Next
    Filter [SCL]
  Endif
  If ICPTNBREC Then
    Gosub RESETOPGNBQ
  Endif
  Call TEMPOFF From GESECRAN
End

##########################################################################################################
# Variable nécessaire pour renseigne une ligne de résultat
###############################################################
$VARFEEDMAI4LINE
Local Char SZEMAIL(GLONMAI)  # FGR 15/06/2015 : Manquait la longueur (GLONMAI)
Local Char SZFAX
Local Char SZTEL

Local Char SZADD(50)(3)
Local Char SZZIP
Local Char SZCTY (50)
Local Char SZCRY (50)
Local Char SZSAT (50)

Local Char SZRECNUM
Local Char SZKEYREC
Local Char SZKEYBPRREC
Local Char SZKEYBPAREC
Local Char SZCNTFULNAM(50)
Local Char SZBPRNAM(50)
Local Char SZCNTTTL

Local Integer IBADRESSE
Local Integer IBAIN_OK
Local Integer IBBPR_OK

Local Integer IBADR_OK
Local Integer IBFAX_OK
Local Integer IBTEK_OK
Local Integer IBEMAIL_OK
Local Integer IBLOADCNT
Local Integer IBCNTBANALISE
# FGR 23/06/2008 : X3SUIVI46709 : Opposition marketing (publipostage)
Local Integer SFBDMAG
Return

##########################################################################################################
# Réinit des variables nécessaire pour renseigne une ligne de résultat
###############################################################
$RAZVARFEEDMAI4LINE
  Raz SZADD
  Raz SZZIP
  Raz SZCTY
  Raz SZCRY
  Raz SZSAT

  Raz SZEMAIL
  Raz SZFAX

  Raz SZRECNUM
  Raz SZKEYREC
  Raz SZKEYBPRREC
  Raz SZKEYBPAREC
  Raz SZCNTFULNAM
  Raz SZBPRNAM
  Raz SZCNTTTL

  IBADRESSE = 0
  IBAIN_OK = 0
  IBBPR_OK = 0
  IBADR_OK = 0
  IBFAX_OK = 0
  IBTEL_OK = 0
  IBEMAIL_OK = 0
  IBLOADCNT = 0
  IBCNTBANALISE = 0
  # FGR 23/06/2008 : X3SUIVI46709 : Opposition marketing (publipostage)
  SFBDMAG = 0
Return

##########################################################################################################
# Renseigne une ligne de résultat
###############################################################
$FEEDMAI4LINE
  Gosub RAZVARFEEDMAI4LINE
  #Remplit le tableau des destinataires
  If GSZTYPSEA = "CCN" Then
    If [F:SCL]RECNUM <> "" Then
      Read [AIN]AIN0=[F:SCL]RECNUM
      If fstat = 0 Then
        IBAIN_OK = 1
        #On stocke les informations
        SZKEYREC = [F:SCL]RECNUM
        SZKEYBPRREC = [F:SCL]BPRNUM
        SZKEYBPAREC = [F:SCL]BPAADD
        Call BUILDFULNAM("AIN", SZCNTFULNAM) From CRMUTIL140
        Call GET_LIBM(231, [F:AIN]CNTTTL, GLANGUE, SZCNTTTL) From CRM_UTIL
        #
        # FGR 23/06/2008 : X3SUIVI46709 : Opposition marketing (publipostage)
        #                  Si on est au niveau CCN c'est celui là qui est utilisé, quelle que soit la valeur au niveau BPARTNER
        #                  Note pour moi : on ne fais que le charger ici. Il ne sera utilisé que si on est en publipostage
        SFBDMAG = [F:AIN]CNTFBDMAG
      Endif
      If [F:SCL]BPRNUM <> "" Then            #Un tiers peut être mentionné dans le tableau.
        Read [BPR]BPR0=[F:SCL]BPRNUM
        If fstat = 0 Then
          IBBPR_OK = 1
          #On stocke les informations
          SZBPRNAM = [F:BPR]BPRNAM
        Endif
      Endif
      #Traitements de l'adresse / Numero fax / email
      If GIDEFADD = 2 and  IBAIN_OK = 1 and [F:AIN]CNTTYP = 1 Then
        #Les informations doivent provenir de l'interloculeur
        SZTEL= [F:AIN]CNTETS
        SZFAX= [F:AIN]CNTFAX
        SZEMAIL= [F:AIN]CNTEMA
        SZADD(0) = [F:AIN]ADD(0)
        SZADD(1) = [F:AIN]ADD(1)
        SZADD(2) = [F:AIN]ADD(2)
        SZZIP = [F:AIN]ZIP
        SZCTY = [F:AIN]CTY
        SZCRY = [F:AIN]CRY
        SZSAT = [F:AIN]SAT
        Call ADRESSEVIDE ( SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
        If IBADRESSE = 1 Then
          IBADR_OK = 1
        Endif
        If SZTEL <> "" Then
          IBTEL_OK = 1
        Endif
        If SZFAX <> "" Then
          IBFAX_OK = 1
        Endif
        If SZEMAIL <> "" Then
          IBEMAIL_OK = 1
        Endif
      Endif
      If [F:AIN]CNTTYP = 1 and(IBADR_OK = 0 or IBFAX_OK = 0 or IBEMAIL_OK = 0 or IBTEL_OK = 0) and GIDEFADD = 2 and GIHIEBPR = 2 and IBBPR_OK = 1 and IBAIN_OK = 1 Then
        #Cas de infos interlocuteur mais tous n'est pas rempli et recherche hiérarchique à vrai
        IBLOADCNT = 1
      Endif
      If GIDEFADD = 1 and [F:AIN]CNTTYP = 1 Then
        #cas recherche par tiers
        IBLOADCNT = 1
      Endif
      If IBLOADCNT = 1 and [F:AIN]CNTTYP = 1 Then
        #on recherche sur le contact
        Read [CNT]CNT0=1;[F:BPR]BPRNUM;[F:AIN]CNTNUM
        If fstat = 0 Then
          If IBTEL_OK = 0 Then
            SZTEL = [F:CNT]TEL
            If SZTEL <> "" Then
              IBTEL_OK = 1
            Endif
          Endif
          If IBFAX_OK = 0 Then
            SZFAX = [F:CNT]FAX
            If SZFAX <> "" Then
              IBFAX_OK = 1
            Endif
          Endif
          If IBEMAIL_OK = 0 Then
            SZEMAIL = [F:CNT]WEB
            If SZEMAIL <> "" Then
              IBEMAIL_OK = 1
            Endif
          Endif
          If IBADR_OK = 0 or IBFAX_OK = 0 or IBEMAIL_OK = 0 or IBTEL_OK = 0 Then
            If [F:CNT]BPAADD <> "" Then
              Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:CNT]BPAADD
              If fstat = 0 Then
                If IBADR_OK = 0 Then
                  SZADD(0) = [F:BPA]BPAADDLIG(0)
                  SZADD(1) = [F:BPA]BPAADDLIG(1)
                  SZADD(2) = [F:BPA]BPAADDLIG(2)
                  SZZIP = [F:BPA]POSCOD
                  SZCTY = [F:BPA]CTY
                  SZSAT = [F:BPA]SAT
                  SZCRY = [F:BPA]CRY
                  Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
                  If IBADRESSE = 1 Then
                    IBADR_OK = 1
                  Endif
                Endif
                If IBTEL_OK = 0 Then
                  SZTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
                  If SZTEL <> "" Then
                    IBTEL_OK = 1
                  Endif
                Endif
                If IBFAX_OK = 0 Then
                  SZFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
                  If SZFAX <> "" Then
                    IBFAX_OK = 1
                  Endif
                Endif
                If IBEMAIL_OK = 0 Then
                  SZEMAIL = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
                  If SZEMAIL <> "" Then
                    IBEMAIL_OK = 1
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
        If (IBADR_OK = 0 or IBFAX_OK = 0 or IBEMAIL_OK = 0 or IBTEL_OK = 0) and GIHIEBPR = 2 Then
          #On n'a pas encore toutes les infos, on prend l'adresse pas défaut
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
          If fstat = 0 Then
            If IBADR_OK = 0 Then
              SZADD(0) = [F:BPA]BPAADDLIG(0)
              SZADD(1) = [F:BPA]BPAADDLIG(1)
              SZADD(2) = [F:BPA]BPAADDLIG(2)
              SZZIP = [F:BPA]POSCOD
              SZCTY = [F:BPA]CTY
              SZSAT = [F:BPA]SAT
              SZCRY = [F:BPA]CRY
              Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
              If IBADRESSE = 1 Then
                IBADR_OK = 1
              Endif
            Endif
            If IBTEL_OK = 0 Then
              SZTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
              If SZTEL <> "" Then
                IBTEL_OK = 1
              Endif
            Endif
            If IBFAX_OK = 0 Then
              SZFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
              If SZFAX <> "" Then
                IBFAX_OK = 1
              Endif
            Endif
            If IBEMAIL_OK = 0 Then
              SZEMAIL = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
              If SZEMAIL <> "" Then
                IBEMAIL_OK=1
              Endif
            Endif
          Endif
        Endif
      Endif
      If IBAIN_OK = 1 and [F:AIN]CNTTYP = 2 Then
        Read [LDS]LDS0=[F:SCL]RECNUM
        If fstat = 0 Then
          Read [BPA]BPA0=6;[F:LDS]PSTNUM;[F:LDS]BPAADD
          If fstat = 0 Then
            SZTEL = [F:BPA]TEL(0)    # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
            SZFAX = [F:BPA]TEL(1)    # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
            SZEMAIL = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
            SZADD(0) = [F:BPA]BPAADDLIG(0)
            SZADD(1) = [F:BPA]BPAADDLIG(1)
            SZADD(2) = [F:BPA]BPAADDLIG(2)
            SZZIP = [F:BPA]POSCOD
            SZCTY = [F:BPA]CTY
            SZCRY = [F:BPA]CRY
            SZSAT = [F:BPA]SAT
            Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
            If IBADRESSE = 1 Then
              IBADR_OK = 1
            Endif
            If SZTEL <> "" Then
              IBTEL_OK = 1
            Endif
            If SZFAX <> "" Then
              IBFAX_OK = 1
            Endif
            If SZEMAIL <> "" Then
              IBEMAIL_OK = 1
            Endif
          Endif
          If GIHIEBPR = 2 Then
            If IBADR_OK = 0 Then
              SZADD(0) = [F:AIN]ADD(0)
              SZADD(1) = [F:AIN]ADD(1)
              SZADD(2) = [F:AIN]ADD(2)
              SZZIP = [F:AIN]ZIP
              SZCTY = [F:AIN]CTY
              SZCRY = [F:AIN]CRY
              SZSAT = [F:AIN]SAT
              Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
              If IBADRESSE = 1 Then
                IBADR_OK = 1
              Endif
            Endif
            If IBTEL_OK = 0 and GIHIEBPR = 2 Then
              SZTEL = [F:AIN]CNTETS
              If SZTEL <> "" Then
                IBTEL_OK = 1
              Endif
            Endif
            If IBFAX_OK = 0 Then
              SZFAX = [F:AIN]CNTFAX
              If SZFAX <> "" Then
                IBFAX_OK = 1
              Endif
            Endif
            If IBEMAIL_OK = 0 Then
              SZEMAIL = [F:AIN]CNTEMA
              If SZEMAIL <> "" Then
                IBEMAIL_OK = 1
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If [F:SCL]BPRNUM <> "" Then
        #On a un contact banalise
        #On stocke les informations
        SZKEYREC  = [F:SCL]RECNUM
        SZKEYBPRREC = [F:SCL]BPRNUM
        SZKEYBPAREC = [F:SCL]BPAADD
        SZCNTFULNAM = GSZCNTTTR
        IBCNTBANALISE = 1
        Read [BPR]BPR0=[F:SCL]BPRNUM
        If fstat = 0 Then
          IBBPR_OK = 1
          SZBPRNAM = [F:BPR]BPRNAM
          #On charge l'adresse par défaut
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
          If fstat = 0 Then
            SZADD(0) = [F:BPA]BPAADDLIG(0)
            SZADD(1) = [F:BPA]BPAADDLIG(1)
            SZADD(2) = [F:BPA]BPAADDLIG(2)
            SZZIP = [F:BPA]POSCOD
            SZCTY = [F:BPA]CTY
            SZSAT = [F:BPA]SAT
            SZCRY = [F:BPA]CRY
            Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
            If IBADRESSE = 1 Then
              IBADR_OK = 1
            Endif
            SZTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
            If SZTEL <> "" Then
              IBTEL_OK = 1
            Endif
            SZFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
            If SZFAX <> "" Then
              IBFAX_OK = 1
            Endif
            SZEMAIL = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
            If SZEMAIL <> "" Then
              IBEMAIL_OK = 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Elsif GSZTYPSEA = "BPR" Then
    #On stocke les informations
    SZKEYREC = [F:SCL]RECNUM
    SZCNTFULNAM = GSZCNTTTR
    IBCNTBANALISE = 1
    Read [BPR]BPR0=[F:SCL]RECNUM
    If fstat = 0 Then
      #On stocke les informations
      # FGR 23/06/2008 : X3SUIVI46709 : Opposition marketing (publipostage)
      #                  Si on est au niveau BPR c'est forcément celui là qui est utilisé.
      #                  Note pour moi : on ne fais que le charger ici. Il ne sera utilisé que si on est en publipostage
      SFBDMAG = [F:BPR]BPRFBDMAG
      #
      SZBPRNAM = [F:BPR]BPRNAM
      Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
      If fstat = 0 Then
        SZADD(0) = [F:BPA]BPAADDLIG(0)
        SZADD(1) = [F:BPA]BPAADDLIG(1)
        SZADD(2) = [F:BPA]BPAADDLIG(2)
        SZZIP = [F:BPA]POSCOD
        SZCTY = [F:BPA]CTY
        SZSAT = [F:BPA]SAT
        SZCRY = [F:BPA]CRY
        Call ADRESSEVIDE(SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
        If IBADRESSE = 1 Then
          IBADR_OK = 1
        Endif
        SZTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
        If SZTEL <> "" Then
          IBTEL_OK = 1
        Endif
        SZFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
        If SZFAX <> "" Then
          IBFAX_OK = 1
        Endif
        SZEMAIL = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
        If SZEMAIL <> "" Then
          IBEMAIL_OK = 1
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Renseigne une ligne de résultat
###############################################################
$MAI4LINESCREEN
  Gosub FEEDMAI4LINE
  #On a fait toutes les possibilités, on affiche
  If ICPTNBREC Then
    If IBADR_OK = 0 Then
      [M:MAI4]NBQADD += 1
    Endif
    If IBEMAIL_OK = 0 Then
      [M:MAI4]NBQEMA += 1
    Endif
    If IBFAX_OK = 0 Then
      [M:MAI4]NBQFAX += 1
    Endif
  Endif
  If !IOUTOFMAI4 Then
    #On affiche les informations
    [M:MAI4]KEYREC(ITER) = SZKEYREC
    [M:MAI4]KEYBPRREC(ITER) = SZKEYBPRREC
    [M:MAI4]KEYBPAREC(ITER) = SZKEYBPAREC
    [M:MAI4]CNTFULNAM(ITER) = SZCNTFULNAM
    [M:MAI4]BPRNAM(ITER) = SZBPRNAM
    [M:MAI4]ADD1(ITER) = SZADD(0)
    [M:MAI4]ADD2(ITER) = SZADD(1)
    [M:MAI4]ADD3(ITER) = SZADD(2)
    [M:MAI4]ZIP(ITER) = SZZIP
    [M:MAI4]CTY(ITER) = SZCTY
    [M:MAI4]SAT(ITER) = SZSAT
    [M:MAI4]CRY(ITER) = SZCRY
    [M:MAI4]EMA(ITER) = SZEMAIL
    [M:MAI4]FAX(ITER) = SZFAX
  Endif
  If ICPTNBREC Then
    [M:MAI4]NBQSND += 1
  Endif
Return

##########################################################################################################
#Test si une adresse est vide
#############################
Subprog ADRESSEVIDE (SZADD, SZZIP, SZCTY, SZCRY, SZSAT, IBADRESSE)
Value Char SZADD()()
Value Char SZZIP()()
Value Char SZCTY()()
Value Char SZCRY()()
Value Char SZSAT()()

Variable Integer IBADRESSE

  IBADRESSE = 0
  If SZADD(0) <> "" Then
    IBADRESSE = 1
  Endif
  If SZADD(1) <> "" Then
    IBADRESSE = 1
  Endif
  If SZADD(2) <> "" Then
    IBADRESSE = 1
  Endif
  If SZZIP <> "" Then
    IBADRESSE = 1
  Endif
  If SZCTY <> "" Then
    IBADRESSE = 1
  Endif
End

##########################################################################################################
# Réaffecte le nombre d'enregistrement de l'opération
################################################################
$RESETOPGNBQ
  Readlock [SEC]SEC0=GSZOPGNUM;"CCN"
  If !fstat Then
    If [F:SEC]USEQUR = 2 Then
      Call DEBTRANS From GLOCK
      Trbegin [SEC]
      [F:SEC]SELREC = [M:MAI4]NBQSND
      Rewrite [SEC]
      If fstat Then
        GMESSAGE = mess(101,141,1) #Erreur modification
        GERR = 1
        Unlock [SEC]
        Rollback
        Call TEMPOFF From GESECRAN
        End
      Else
        Commit
        Unlock [SEC]
      Endif
    Else
      Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
      For [SEC]
        SZBPTYP = [F:SEC]SELTBL
        Break
      Next
      Filter [SEC]
      Readlock [SEC]SEC0=GSZOPGNUM;SZBPTYP
      If !fstat Then
        Call DEBTRANS From GLOCK
        Trbegin [SEC]
        [F:SEC]SELREC = [M:MAI4]NBQSND
        Rewrite [SEC]
        If fstat Then
          GMESSAGE = mess(101,141,1) #Erreur modification
          GERR = 1
          Unlock [SEC]
          Rollback
          Call TEMPOFF From GESECRAN
          End
        Else
          Commit
          Unlock [SEC]
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Vide la masque MAI4
###################################################################
Subprog RAZRESULT
  Raz [M:MAI4]NBCCN
  Raz [M:MAI4]CNTFULNAM
  Raz [M:MAI4]BPRNAM
  Raz [M:MAI4]ADD1
  Raz [M:MAI4]ADD2
  Raz [M:MAI4]ADD3
  Raz [M:MAI4]ZIP
  Raz [M:MAI4]CTY
  Raz [M:MAI4]SAT
  Raz [M:MAI4]CRY
  Raz [M:MAI4]EMA
  Raz [M:MAI4]FAX
End

##########################################################################################################
# Supprime les destinataires sans addresse postale, e-mail ou fax
###################################################################
Subprog DELEMPADD(SZTYPDEL)
Value Char SZTYPDEL

Local Integer IJ
Local Integer IPERF
Local Integer IPBL
Local Integer INTR

Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)

Local Char SZRECNUMLOOP
Local Char SZBPRNUMLOOP

Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  Gosub VARFEEDMAI4LINE
  Gosub RAZVARFEEDMAI4LINE

Local Integer IBDELETE

  IBDELETE = 0
  ICUT3 = 2750
  STOPLOOP = 0
  LOOPCRIT = ""
  ICLECOUNT3 = 0
  SZRECNUMLOOP = ""
  SZBPRNUMLOOP = ""
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  IPBL = 0
  INTR = 0
  IJ = 0
  #Suppression en cours.
  Call TEMPON(mess(794,196,1)) From GESECRAN
  #Remplit le tableau des destinataires
  If GSZTYPSEA = "CCN" Then
    $SNAPLOOP2

    If STOPLOOP = 1 Then
      STOPLOOP = 2
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"' + " and [F:SCL]RECNUM = SZRECNUMLOOP and [F:SCL]BPRNUM > SZBPRNUMLOOP"
    Elsif STOPLOOP = 2 Then
      STOPLOOP = 0
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"' + " and [F:SCL]RECNUM > SZRECNUMLOOP"
    Else
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"'
    Endif
    ICLECOUNT3 = 0
    Filter [SCL] Where evalue(LOOPCRIT) Order By [F:SCL]RECNUM Asc; [F:SCL]BPRNUM Asc
    For [SCL] Hint Key SCL0
      Gosub DELETESCL
      If GERR = 1 Then
        Break
      Endif
      ICLECOUNT3 += 1
      If ICLECOUNT3 >= ICUT3 Then
        SZRECNUMLOOP = [F:SCL]RECNUM
        SZBPRNUMLOOP = [F:SCL]BPRNUM
        STOPLOOP = 1
        Break
      Endif
    Next
    If STOPLOOP Then
      Goto SNAPLOOP2
    Endif
  Elsif GSZTYPSEA = "BPR" Then
    While ILOOPCLECOUNT >= ILOOPCUT
      ILOOPCLECOUNT = 0
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM & [F:SCL]RECTYP <> "CCN" & [F:SCL]RECNUM > SZLOOPCLE Order By [F:SCL]RECNUM Asc
      For [SCL] Hint Key SCL1
        SZLOOPCLE = [F:SCL]RECNUM
        Gosub DELETESCL
        If GERR = 1 Then
          Break
        Endif
        ILOOPCLECOUNT += 1
        If ILOOPCLECOUNT >= ILOOPCUT Then
          Break
        Endif
      Next
      If GERR Then
        Break
      Endif
    Wend
  Endif
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL]
  Call TEMPOFF From GESECRAN
  Call LOADRESULT(1,1)
  Affzo [M:MAI4]1-99
End

##########################################################################################################
# Traite la suppression d'un ligne de SLC pour les destinataires sans addresse postale, e-mail ou fax
###################################################################
$DELETESCL
  IBDELETE = 0
  Gosub FEEDMAI4LINE
  If SZTYPDEL = "ALL" Then    #Suppression de tous les contacts
    IBDELETE=1
  Elsif SZTYPDEL = "ADD" Then  #Suppression d'un contact sans code postal
    If SZZIP = "" Then
      IBDELETE = 1
    Endif
  Elsif SZTYPDEL = "EMA" Then  #Suppression d'un contact sans email
    If SZEMAIL = "" Then
      IBDELETE = 1
    Endif
  Elsif SZTYPDEL = "FAX" Then  #Suppression d'un contact sans fax
    If SZFAX = "" Then
      IBDELETE = 1
    Endif
  Elsif SZTYPDEL = "BAN" Then  #Suppression d'un contact banalisé
    If IBCNTBANALISE = 1 Then
      IBDELETE = 1
    Endif
  Endif
  If IBDELETE = 1 Then
    #On doit supprimer la ligne
    If IPERF = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SCL]
      INTR = 1
    Endif
    Delete [SCL] Curr
    If fstat Then
      #Erreur lors de la suppression de l'échantillon
      GMESSAGE = mess(788,196,1)
      GERR = 1
      Rollback
      INTR = 0
      IPBL = 1
      STOPLOOP = 0
    Else
      If IPERF >= 500 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Prépare les données de fusion pour le mailing
###################################################################
Subprog PREMRGDAT
Local Char SZFNC
Local Integer IFNC

  Gosub VARFEEDMAI4LINE
  Gosub RAZVARFEEDMAI4LINE

Local Integer IPERF
Local Integer IPBL
Local Integer INTR
Local Integer ICOUNTX
Local Integer COK
Local Char SZREPCOD
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
Local Char SZRECNUMLOOP
Local Char SZBPRNUMLOPP
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  ICUT3 = 2750
  STOPLOOP = 0
  LOOPCRIT = ""
  ICLECOUNT3 = 0
  SZRECNUMLOOP = ""
  SZBPRNUMLOOP = ""
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  ICOUNTX = 1
  COK = 1
  IPERF = 0
  IPBL = 0
  INTR = 0
  If !clalev([F:MRE]) : Local File OMMRESULT [MRE] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If GINTRA Then
    Call TEMPON("E") From GESECRAN
  Else
    Call OUVRE_BOITE(mess(392,196,1), [M:MAI4]NBQSND) From GESECRAN   #Préparation des données de fusion.
  Endif
  #Efface les éventuels enregistrements déjà créés
  Call RAZOMMRES
  #Remplit le tableau des destinataires
  If GSZTYPSEA = "CCN" Then
    $SNAPLOOP1

    If STOPLOOP = 1 Then
      STOPLOOP = 2
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"' + " and [F:SCL]RECNUM = SZRECNUMLOOP and [F:SCL]BPRNUM > SZBPRNUMLOOP"
    Elsif STOPLOOP = 2 Then
      STOPLOOP = 0
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"' + " and [F:SCL]RECNUM > SZRECNUMLOOP"
    Else
      LOOPCRIT = "[F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = " + '"' + "CCN" + '"'
    Endif
    ICLECOUNT3 = 0
    Filter [SCL] Where evalue(LOOPCRIT) Order By [F:SCL]RECNUM Asc; [F:SCL]BPRNUM Asc
    For [SCL] Hint Key SCL0
      Gosub WRITEMRE
      If GERR = 1 Then
        Break
      Endif
      If !GINTRA Then
        Call AFF_BOITE (mess(392,196,1), ICOUNTX, COK) From GESECRAN
      Endif
      ICOUNTX += 1
      If ICOUNTX >= 99999999 Then
        Break
      Endif
      ICLECOUNT3 += 1
      If ICLECOUNT3 >= ICUT3 Then
        SZRECNUMLOOP = [F:SCL]RECNUM
        SZBPRNUMLOOP = [F:SCL]BPRNUM
        STOPLOOP = 1
        Break
      Endif
    Next
    If STOPLOOP Then
      Goto SNAPLOOP1
    Endif
  Elsif GSZTYPSEA = "BPR" Then
    While ILOOPCLECOUNT >= ILOOPCUT
      ILOOPCLECOUNT = 0
      Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]RECNUM > SZLOOPCLE Order By [F:SCL]RECNUM Asc
      For [SCL] Hint Key SCL1
        SZLOOPCLE = [F:SCL]RECNUM
        Gosub WRITEMRE
        If GERR = 1 Then
          Break
        Endif
        If !GINTRA Then
          Call AFF_BOITE (mess(392,196,1), ICOUNTX, COK) From GESECRAN
        Endif
        ICOUNTX += 1
        If ICOUNTX >= 99999999 Then
          Break
        Endif
        ILOOPCLECOUNT += 1
        If ILOOPCLECOUNT >= ILOOPCUT Then
          Break
        Endif
      Next
    Wend
  Endif
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL]
  If GINTRA Then
    Call TEMPOFF From GESECRAN
  Else
    Call FERME_BOITE From GESECRAN
  Endif
End

##########################################################################################################
# Traitement d'un enregistrement dans MRE
###############################################
$WRITEMRE
  Raz SZREPCOD
  Raz [F:MRE]  # FGR 08/12/2008 : X3SUIVI50485
  Gosub  FEEDMAI4LINE
  # FGR 03/02/2010 : X3SUIVI62209 : ça doit être plus bas.
  #If IPERF = 0 Then
  #  Call DEBTRANS From GLOCK
  #  Trbegin [MRE]
  #  INTR = 1
  #Endif
  # FGR 23/06/2008 : X3SUIVI46709 : Opposition marketing (publipostage)
  If SFBDMAG <> 2 Then
    If IPERF = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [MRE]
      INTR = 1
    Endif
    # Si l'indicateur "Interdit mailing" n'est pas coché
    [F:MRE]OPGNUM = GSZOPGNUM
    [F:MRE]F599 = "@F599@"
    [F:MRE]F501 = "@F501@"
    [F:MRE]MRENUM = num$(ICOUNTX)
    [F:MRE]CLSNUM = ICOUNTX
    [F:MRE]CNTTTL = SZCNTTTL
    [F:MRE]CNTNAM = SZCNTFULNAM
    # FGR 08/12/2008 : X3SUIVI50485 (debut)
    If [F:SCL]RECTYP = "CCN" Then
      [F:MRE]CCNNUM = [F:SCL]RECNUM
      [F:MRE]BPRNUM = [F:SCL]BPRNUM
    Else
      [F:MRE]BPRNUM = [F:SCL]RECNUM
    Endif
    # FGR 08/12/2008 : X3SUIVI50485 (fin)
    [F:MRE]BPRNAM = SZBPRNAM
    [F:MRE]TEL = SZTEL
    [F:MRE]WEB = SZEMAIL
    [F:MRE]FAX = "@F211 " + SZFAX + '@'
    [F:MRE]ADD1 = SZADD(0)
    [F:MRE]ADD2 = SZADD(1)
    [F:MRE]ADD3 = SZADD(2)
    [F:MRE]ZIP = SZZIP
    [F:MRE]CTY = SZCTY
    [F:MRE]SAT = SZSAT
    If SZCRY<>"" Then
      Read [TCY]TCY0=SZCRY
      If fstat = 0 Then
        Call LECTEXTRA([F:MRE]CRY,"TABCOUNTRY","CRYDES",SZCRY,"") From ATEXTRA
      Endif
    Endif
    #Traitement du représentant
    If [F:SCL]BPRNUM <> "" Then
      Read [BPC]BPC0=[F:SCL]BPRNUM
      If fstat = 0 Then
        If [F:BPC]REP(0) = "" Then
          If [F:BPC]REP(1) <> "" Then
            SZREPCOD = [F:BPC]REP(1)
          Endif
        Else
          SZREPCOD = [F:BPC]REP(0)
        Endif
      Endif
    Else
      Filter [CNT] Where [F:CNT]CCNCRM = [F:SCL]RECNUM and [F:CNT]BPATYP = 1
      For [CNT] CNT1
        Read [BPC]BPC0=[F:CNT]BPANUM
        If fstat = 0 Then
          If [F:BPC]REP(0) = "" Then
            If [F:BPC]REP(1) <> "" Then
              SZREPCOD = [F:BPC]REP(1)
            Endif
          Else
            SZREPCOD = [F:BPC]REP(0)
          Endif
        Endif
        If SZREPCOD <> "" Then
          Break
        Endif
      Next
      Filter [CNT]
    Endif
    #
    If SZREPCOD <> "" Then
      Read [REP]REP0=SZREPCOD
      If fstat = 0 Then
        [F:MRE]REPNAM = [F:REP]REPNAM
        If [F:MRE]REPNAM <> "" Then
          Read [AUS]CODUSR=[F:REP]AUSNUM
          If fstat = 0 Then
            SZFNC = ""
            IFNC = 0
            Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
            If SZFNC = "" Then
              IFNC = 1
            Else
              IFNC = val(SZFNC)
            Endif
            Call GET_LIBM(3022, IFNC, GLANGUE, [F:MRE]REPFNC) From CRM_UTIL
          Endif
        Endif
      Endif
    Endif
    # FGR 22/10/2012 : X3SUIVI84347 : PE pour champs supplémentaires
    Gosub PE_WRITEMRE From TRTCRMPE
    # ---------
    Write [MRE]
    If fstat Then
      IPBL = 1
      #Erreur lors de la génération du fichier de fusion.
      GMESSAGE = mess(793,196,1)
      GERR = 1
      Rollback
      INTR = 0
    Else
      If IPERF >= 500 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Supprime les enregistrements de l'opération
###################################################################
Subprog RAZOMMRES
  If !clalev([F:MRE]) : Local File OMMRESULT [MRE] : Endif
  Call DEBTRANS From GLOCK
  Trbegin [MRE]
  Delete [MRE] Where [F:MRE]OPGNUM = GSZOPGNUM
  If fstat Then
    Rollback
    End
  Endif
  Commit
End

##########################################################################################################
# Supprime les enregistrements de l'opération
###################################################################
$RAZ2OMMRES
  If !clalev([F:MRE]) : Local File OMMRESULT [MRE] : Endif
  Delete [MRE] Where [F:MRE]OPGNUM = GSZOPGNUM
  If fstat Then
    GOK = 0
    Call FSTA("MRE") From GLOCK
    Return
  Endif
Return

##########################################################################################################
# Enregistre le nombre d'envoi de l'opération Mailing
###################################################################
Subprog NBSNDINF
  #Défini les informations d'expédition.
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=GSZOPGNUM
  If fstat Then
    Rollback
    End
  Else
    [F:OMM]NBQSND = [M:MAI4]NBQSND
    Rewrite [OMM]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [OMM]
      Rollback
      End
    Else
      Commit
      Unlock [OMM]
    Endif
  Endif
End

##########################################################################################################
# Trie l'échantillon selon Pays, Etat, Code postal, Ville et Nom
#####################################################################
Subprog SORTPANEL
  Gosub VARFEEDMAI4LINE
  Gosub RAZVARFEEDMAI4LINE

Local Integer ILOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT
Local Integer IPERF
Local Integer IPBL
Local Integer INTR

  IPERF = 0
  IPBL = 0
  INTR = 0
  ILOOPCLE = -1
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  #Contrôle de l'échantillon
  Call TEMPON(mess(790,196,1)) From GESECRAN
  If GSZTYPSEA = "CCN" Then
    While ILOOPCLECOUNT >= ILOOPCUT
      ILOOPCLECOUNT = 0
      Filter [SCL] Where [F:SCL]CLSNUM > ILOOPCLE and [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" Order By [F:SCL]CLSNUM Asc
      For [SCL] Hint Key SCL0
        ILOOPCLE = [F:SCL]CLSNUM
        Gosub REWRITESCL
        If GERR = 1 Then
          Break
        Endif
        ILOOPCLECOUNT += 1
        If ILOOPCLECOUNT >= ILOOPCUT Then
          Break
        Endif
      Next
      Filter [SCL]
      If GERR Then
        Break
      Endif
    Wend
  Elsif GSZTYPSEA = "BPR" Then
    While ILOOPCLECOUNT >= ILOOPCUT
      ILOOPCLECOUNT = 0
      Filter [SCL] Where [F:SCL]CLSNUM > ILOOPCLE and [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" Order By [F:SCL]CLSNUM Asc
      For [SCL] Hint Key SCL0
        ILOOPCLE = [F:SCL]CLSNUM
        Gosub REWRITESCL
        If GERR = 1 Then
          Break
        Endif
        ILOOPCLECOUNT += 1
        If ILOOPCLECOUNT >= ILOOPCUT Then
          Break
        Endif
      Next
      Filter [SCL]
      If GERR Then
        Break
      Endif
    Wend
  Endif
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If GERR Then
    End
  Endif
  Call TEMPOFF From GESECRAN
End

##########################################################################################################
# Traitement d'un enregistrement dans SCL
###############################################
$REWRITESCL
  Gosub  FEEDMAI4LINE
  If IPERF = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
    INTR = 1
  Endif
  [F:SCL]SCLCRY = SZCRY
  [F:SCL]SCLSAT = SZSAT
  [F:SCL]SCLZIP = SZZIP
  [F:SCL]SCLCTY = SZCTY
  Rewrite [SCL]
  If fstat Then
    IPBL = 1
    #Erreur lors du tri de l'échantillon.
    GMESSAGE = mess(791,196,1)
    GERR = 1
    Rollback
    INTR = 0
  Else
    If IPERF >= 500 Then
      Commit
      IPERF = 0
      INTR = 0
    Else
      IPERF += 1
    Endif
  Endif
Return

##########################################################################################################
# Création de la négation d'un échantillon.
###############################################################
$ONNEGATIVE
  Local File SELCMGLIS [SCL1]
  Local File SELCMGLIS [SCL2]

  Call TEMPON("C") From GESECRAN
  If GSZTYPSEA = "CCN" Then
    Call UNIONXCCN(GSZOPGNUM) From TRTMAX4
  Elsif GSZTYPSEA = "BPR" Then
    Call UNIONXBPR(GSZOPGNUM) From TRTMAX4
  Endif
  Call TEMPOFF From GESECRAN
  Close Local File [SCL1]
  Close Local File [SCL2]
  Call LOADRESULT(1,1)
  Affzo [M:MAI4]1-99
Return

