#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UTITC11   Table BOM les désignations deviennent              Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 01/10/2009 : X3SUIVI57935
##########################################################################
Local Char DOSSIER(30)

  If 1=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC11(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" and [F:ADS]DOSSIER <> "DEMOAVV" and [F:ADS]DOSSIER <> "DEMOFRA" and [F:ADS]DOSSIER <> "DEMOTEST" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC11(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC11(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC11: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table BOM
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "BOM", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".BOM" [BOH]
    If dim([F:BOH]BOMDES) > 0 Then
      Trbegin [BOH], [AXX]
      For [BOH]BOH0
        IUPDATE = 0
        If dim([F:BOH]BOMDES) > 0 Then
          If [F:BOH]BOMDES <> "" Then
            Call MAJTEXTRA([F:BOH]BOMDES, "BOM", "BOMDESAXX", [F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA BOM-BOMDESAXX" - [F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT)-"/"-num$([F:BOH]BOMALTTYP) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:BOH]BOMDES = ""
          Else
            Call LECTEXTRA(WCHAINE,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "BOM", "BOMDESAXX", [F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
            Endif
          Endif
         # Pour le moment le moteur ne sait pas faire un link avec une chaîne concaténée. Obligé de faire comme ça
         [F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
         IUPDATE = 1
        Endif
        If IUPDATE = 1 Then
          Rewrite [BOH]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [BOH]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "BOD"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
        #
        Call VALID("O" + WOBJET + "P", SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET + "P", 1) From GESECRAN
        Endif
        #
        Call VALID("O" + WOBJET + "S", SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET + "S", 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC11 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"BOM") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC11(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"BOM") : End : Endif
  Call MAJ_UTITC11(APPLI)
End

