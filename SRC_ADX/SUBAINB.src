#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "FERME"        : Gosub FERME
    When "RAZDUP"       : Gosub RAZDUP
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "VERF_ANU"     : Gosub VERF_ANU
    When "ANNULE"       : Gosub ANNULE
    When "AP_ANNULE"    : Gosub AP_ANNULE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "AB_CREATION"  : Gosub AB_CREATION
    When "AB_MODIF"     : Gosub AB_MODIF
    When "ABANDON"      : Gosub ABANDON
    When "FILTRE"       : Gosub FILTRE
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When "STATUT"      : Gosub EXEBOUT
  Endcase
Return

##########################################################################################################
$OUVRE
  Gosub OBJET
  If GMODU(13) = 2 Then
    Gosub OUVRE_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$LIENS
  Gosub OBJET
  If GMODU(13) = 2 Then
    Gosub LIENS_CRM From SUBAINCRM
  Endif
Return


##########################################################################################################
$FERME
  If GMODU(13) = 2 Then
    Gosub FERME_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$RAZDUP
  If GMODU(13) = 2 Then
    Gosub RAZDUP_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$VERIF_CRE
Return

##########################################################################################################
$VERIF_MOD
Return

##########################################################################################################
$CREATION
  If GMODU(13) = 2 Then
    Gosub CREATION_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$MODIF
  If GMODU(13) = 2 Then
    Gosub MODIF_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$APRES_CRE
  #Modif CRM 2/12/2003
  #Gosub CREHCODE From SUBAINCRM
Return

##########################################################################################################
$APRES_MOD
  #Modif CRM 2/12/2003
  #Gosub UPDHCODE From SUBAINCRM
Return

##########################################################################################################
$VERF_ANU
Return

##########################################################################################################
$ANNULE
  # FGR 26/11/2013 : X3SUIVI94714 : Ajout du test module
  If GMODU(13) = 2 Then
    Gosub ANNULE_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$AP_ANNULE
  #Modif CRM 2/12/2003
  #Gosub DELHCODE From SUBAINCRM
Return

##########################################################################################################
$OBJET
  #LSE 23/02/2005 rajout de l'entité Tiers
  #[M:AIN0]TBOBJ(1) = ""
  [M:AIN0]TBOBJ(1) = "BPR"
  [M:AIN0]TBOBJ(2) = "CPY"
  [M:AIN0]TBOBJ(3) = "FCY"
  [M:AIN0]TBOBJ(4) = "AUS"
  [M:AIN0]TBOBJ(5) = "GAC"
Return

##########################################################################################################
$AVANT_CHOI
  If GMODU(13) = 2 Then
    Gosub AVANT_CHOI_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$RAZCRE
  Gosub OBJET
  If GMODU(13) = 2 Then
    Gosub RAZCRE_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$AB_CREATION
  If GMODU(13) = 2 Then
    Gosub AB_CREATION_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$AB_MODIF
  If GMODU(13) = 2 Then
    Gosub AB_MODIF_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$ABANDON
  If GMODU(13) = 2 Then
    Gosub ABANDON_CRM From SUBAINCRM
  Endif
Return

##########################################################################################################
$FILTRE
  Default File [AIN]
  #FILTSUP += "CNTTYP=1"
Return

##########################################################################################################
$SETBOUT
  CHMEN += "1"
Return

##########################################################################################################
$EXEBOUT
  Case BOUT
    When "1"
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      #
      PARBOUT(1) = [M:AIN0]CNTNUM
      FLGEXE = 1
      GACTION = "SAILDSAIN"
      Call SAISIE_CHAR(VALBOUT,PARBOUT,"FLDSAIN","TRTLDSAIN","XWLDSAIN") From GSAISIE
  Endcase
Return
