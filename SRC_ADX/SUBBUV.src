#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("BUV",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
$ACTION
Case ACTION
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
Endcase
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"BUDVER","DESTRA",[M]BUD,[M]VER) From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"BUDVER","SHOTRA",[M]BUD,[M]VER) From ATEXTRA
Call LECTURE("BUP",[F:BUV]BUD,"") From CONTOBJ
If [F:BUP]GDDFLG=2
 Grizo [M]VER, STA, CTL, DEF
Else
 Actzo [M]
Endif
Return

$INICRE
$INIMOD
If dim([F:BUV]DES)>0
 [F:BUV]DES = [M]DESTRA
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub BUDDEF
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub BUDDEF
Return

$BUDDEF
If [M]DEF=2
 Update [BUV] Where BUD=[M]BUD & VER<>[M]VER With DEF=1
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("BUDVER","DESTRA",CLECUR2,CLECUR1,"BUDVER","DESTRA",[M]BUD,[M]VER)  From ATEXTRA
 Call DUPTEXTRA("BUDVER","SHOTRA",CLECUR2,CLECUR1,"BUDVER","SHOTRA",[M]BUD,[M]VER)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"BUDVER","DESTRA",[M]BUD,[M]VER) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"BUDVER","SHOTRA",[M]BUD,[M]VER) From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("BUDVER","DESTRA",[M]BUD,[M]VER,[M]BUD,NCODE) From ATEXTRA
Call CHGTEXTRA("BUDVER","SHOTRA",[M]BUD,[M]VER,[M]BUD,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("BUDVER","DESTRA",[M]BUD,[M]VER) From ATEXTRA
Call SUPTEXTRA("BUDVER","SHOTRA",[M]BUD,[M]VER) From ATEXTRA
Return

######################################################################################
## Ecran BUV1
######################################################################################
Subprog C_VER(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VER) From OBJDIV
If mkstat : End : Endif
End

######################################################################################
## Gestion des versions de budget
######################################################################################
$SEL_LISTE
Local Char VERDES(80)
TIT = mess(126,105,1) : # Version
If clalev([F:BUV])=0  : Local File BUDVER [BUV]  : Endif
For [BUV] Where BUD=PARAM(1) & (STA<>2 | (GFONCTION<>"GESBDO" & GFONCTION<>"GESBUC"))
 NBTEX += 1
 TEX  (NBTEX)  = [F:BUV]VER
 Call LECTEXTRA([L]VERDES,"BUDVER","DESTRA",[F:BUV]BUD,[F:BUV]VER) From ATEXTRA
 TEXTE(NBTEX)  = format$("K:"+num$(GLONBUV+1)+"X",TEX(NBTEX))+[L]VERDES
Next
Return

##################################################
Subprog CONTVER(AZC,BUDG)
Variable Char    AZC()
Value    Char    BUDG

If find(GFONCTION,"GESBUV","GESBUP") : End : Endif
If BUDG=""
 End
Endif
If GABREV="BUC" : # Calcul de budget, on autorise les variables
 If left$(AZC,2)="V_" : End : Endif
Endif

If clalev([F:BUV])=0  : Local File BUDVER [BUV]  : Endif
Read [BUV]BUV0 = BUDG;AZC
If fstat
 GMESSAGE = mess(144,111,1) : # Version inexistante
 mkstat = 2
Endif
End

##################################################
Subprog INIVER(AZC,BUDG)
Variable Char    AZC()
Value    Char    BUDG
If AZC=""
 If clalev([F:BUV])=0  : Local File BUDVER [BUV]  : Endif
 Filter [BUV] Where BUD=BUDG & DEF=2
 Read [BUV]BUV0 First
 AZC = [F:BUV]VER
 Filter [BUV]
Endif
End

Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
If GREP="C" | GREP="D" | VALEUR<>[M]BUD
 Call LECTURE("BUP",VALEUR,"") From CONTOBJ
 Local File BUDVER [BUV]
 Look [BUV]BUV0 = VALEUR;"1"
 If !fstat & [F:BUP]GDDFLG=2
  #Il existe déjà une version pour ce budget opérationnel
  Call MESSAGE(mess(144,108,1)) From GESECRAN
  mkstat=0
  [M]VER="1"
  Grizo [M]VER
  Affzo [M]
 Endif
Endif
End

Subprog C_CTL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local File BUDVER [BUV]
 For [BUV]BUV0 Where BUD=[M]BUD
  #If [F:BUV]CTL=2 FQ122517
  If [F:BUV]CTL=2 and [F:BUV]VER<>[M]VER
   #Il existe déjà une version en statut définitif pour ce budget
   Call MESSAGE(mess(73,108,1)) From GESECRAN
   VALEUR=1
   Grizo [M]CTL
   Affzo [M]
   mkstat=0
   Break
  Else
   Actzo [M]CTL
  Endif
 Next
Endif
End


######################################################################################

