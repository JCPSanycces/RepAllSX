    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_BUDGET_HEADER([M:PJBU0]LINBUD) From PJMACTBUD
  Endif
  [M:PJBU0]PARKEY([M:PJBU0]LINBUDTBL-1) = VALEUR
  Affzo [M:PJBU0]PARKEY([M:PJBU0]LINBUDTBL-1)
End

