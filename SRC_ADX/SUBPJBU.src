###################################################################################################
Subprog EXTRACT_ALL_10_20()

  # Issue X3-106111 - 2018-05-28 by ALMON
  Call EXTRACT_ALL_10() From SUBPJMA
  Call EXTRACT_ALL_20() From SUBPJMA
  Call DISPLAY_10_20()
  Call SET_STYLES_10_20()
End

###################################################################################################
Subprog DISPLAY_10_20()

  # Issue X3-106111 - 2018-05-28 by ALMON
  Call DISPLAY_10()
  Call DISPLAY_20()
End

###################################################################################################
Subprog DISPLAY_10()

  # Issue X3-106111 - 2018-05-28 by ALMON
  Local File PJMFINOVRRPT [PJMRPT]
  # -------------------------
  Filter [F:PJMRPT] Where [F:PJMRPT]KEYEXT = func SUBPJMA.GET_KEYEXT_10() and [F:PJMRPT]OPPNUM = GZINSPJM.OPPNUM and [F:PJMRPT]PBUCOD = [M:PJBU0A]PBUCOD and [F:PJMRPT]PCCCOD = AVOID.ACHAR
  For [F:PJMRPT]
    [M:PJBU2E] = [F:PJMRPT]
    [M:PJBU2E]EXTDAT = gdat$(day([F:PJMRPT]CREDATTIM),month([F:PJMRPT]CREDATTIM),year([F:PJMRPT]CREDATTIM))
    [M:PJBU2E]PSCU = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [M:PJBU0A]PBUFCY, "UNITWORK")
    Break
  Next
  Filter [F:PJMRPT]
  # -------------------------
  If [M:PJBU2E]EXTDAT = [0/0/0] Then
    Chgstl [M:PJBU2E]EXTDAT With "BACKYELLOW"
  Elsif [M:PJBU2E]EXTDAT = date$ Then
    Chgstl [M:PJBU2E]EXTDAT With ""
  Elsif [M:PJBU2E]EXTDAT = date$-7 Then
    Chgstl [M:PJBU2E]EXTDAT With "BACKORANGE"
  Else
    Chgstl [M:PJBU2E]EXTDAT With "BACKRED"
  Endif
  # -------------------------
  Affzo [M:PJBU2E]1-99
End

###################################################################################################
Subprog DISPLAY_20()

  # Issue X3-106111 - 2018-05-28 by ALMON
  Local File PJMFINOVRRPT [PJMRPT]
  # -------------------------
  Filter [F:PJMRPT] Where [F:PJMRPT]KEYEXT = func SUBPJMA.GET_KEYEXT_20() and [F:PJMRPT]OPPNUM = GZINSPJM.OPPNUM and [F:PJMRPT]PBUCOD = [M:PJBU0A]PBUCOD and [F:PJMRPT]PCCCOD = AVOID.ACHAR
  For [F:PJMRPT]
    [M:PJBU2R] = [F:PJMRPT]
    [M:PJBU2R]PSCU = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [M:PJBU0A]PBUFCY, "UNITWORK")
    Break
  Next
  Filter [F:PJMRPT]
  Affzo [M:PJBU2R]1-99
End

