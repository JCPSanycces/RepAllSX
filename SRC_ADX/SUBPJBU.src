###################################################################################################
Subprog SET_STYLES_10()

  # Issue X3-106111 - 2018-05-28 by ALMON
  # PJMBUD     (pink)
  Chgstl [M:PJBU2E]PSCBUDQTY   With "PJMBUD"
  Chgstl [M:PJBU2E]PSCBUDAMT   With "PJMBUD"
  # PJMEXPENSE (green)
  Chgstl [M:PJBU2E]PSCQTY1     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCAMT1     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCQTY2     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCAMT2     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCQTY3     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCAMT3     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCQTY4     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCAMT4     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCQTY5     With "PJMEXPENSE"
  Chgstl [M:PJBU2E]PSCAMT5     With "PJMEXPENSE"
  # PJMREMAINS (yellow)
  Chgstl [M:PJBU2E]PSCREMQTY   With "PJMREMAINS"
  Chgstl [M:PJBU2E]PSCREMAMT   With "PJMREMAINS"
  Chgstl [M:PJBU2E]PSCWIPQTY   With "PJMREMAINS"
  Chgstl [M:PJBU2E]PSCWIPAMT   With "PJMREMAINS"
  # PJMTOTAL   (orange)
  Chgstl [M:PJBU2E]PSCTOTQTY   With "PJMTOTAL"
  Chgstl [M:PJBU2E]PSCTOTAMT   With "PJMTOTAL"
  # Issue X3-106658 - 2018-09-05 by ALMON : START : Apply specific display styles for POS and NEG values
  If [M:PJBU2E]PSCMARGQTY < 0 Then
    Chgstl [M:PJBU2E]PSCMARGQTY  With "PJMTOTVARR"
  Else
    Chgstl [M:PJBU2E]PSCMARGQTY  With "PJMTOTVARG"
  Endif
  If [M:PJBU2E]PSCMARGAMT < 0 Then
    Chgstl [M:PJBU2E]PSCMARGAMT  With "PJMTOTVARR"
  Else
    Chgstl [M:PJBU2E]PSCMARGAMT  With "PJMTOTVARG"
  Endif
  If [M:PJBU2E]PSCPCTMQTY < 0 Then
    Chgstl [M:PJBU2E]PSCPCTMQTY  With "PJMTOTVARR"
  Else
    Chgstl [M:PJBU2E]PSCPCTMQTY  With "PJMTOTVARG"
  Endif
  If [M:PJBU2E]PSCPCTMAMT < 0 Then
    Chgstl [M:PJBU2E]PSCPCTMAMT  With "PJMTOTVARR"
  Else
    Chgstl [M:PJBU2E]PSCPCTMAMT  With "PJMTOTVARG"
  Endif
  # Issue X3-106658 - 2018-09-05 by ALMON : END
End

###################################################################################################
Subprog SET_STYLES_20()

  # Issue X3-106111 - 2018-05-28 by ALMON
  # PJMREVENUE ("TBA")
  Chgstl [M:PJBU2R]PSCFREEC6A  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC6B  With "PJMREVENUE"
  # Issue X3-106658 - 2018-09-05 by ALMON : START : Apply specific display styles for POS and NEG values
  If [M:PJBU2R]PSCMARGBUD6 < 0 Then
    Chgstl [M:PJBU2R]PSCMARGBUD6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJBU2R]PSCMARGBUD6  With "PJMFINPOSV"
  Endif
  If [M:PJBU2R]PSCPCTMBUD6 < 0 Then
    Chgstl [M:PJBU2R]PSCPCTMBUD6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJBU2R]PSCPCTMBUD6  With "PJMFINPOSV"
  Endif
  If [M:PJBU2R]PSCMARGTOT6 < 0 Then
    Chgstl [M:PJBU2R]PSCMARGTOT6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJBU2R]PSCMARGTOT6  With "PJMFINPOSV"
  Endif
  If [M:PJBU2R]PSCPCTMTOT6 < 0 Then
    Chgstl [M:PJBU2R]PSCPCTMTOT6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJBU2R]PSCPCTMTOT6  With "PJMFINPOSV"
  Endif
  # Issue X3-106658 - 2018-09-05 by ALMON : END
  Chgstl [M:PJBU2R]PSCFREEC7A  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC7B  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC8A  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC8B  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC9A  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC9B  With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC10A With "PJMREVENUE"
  Chgstl [M:PJBU2R]PSCFREEC10B With "PJMREVENUE"
End

