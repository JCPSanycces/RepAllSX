###################################################################################################
Subprog CL_REFRESH(VALEUR)
Variable Char    VALEUR()

  # Issue X3-106111 - 2018-05-28 by ALMON : Refresh but Not allowed in create mode
  If [M:PJBU0]REP <> "C" Then
    Call EXTRACT_ALL_10_20()
  Endif
End

