###################################################################################################
# PJBU1
###################################################################################################
Subprog C_NBLIGNE

Local Integer IRET
Local Integer IBUDLIN

  If status = 82 or status = 73 Then
    # Add a new line
    If [M:PJBU1]PLBSEQ(nolign-1) = 0 Then
      IBUDLIN = fmet GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).ADDLINE("BUDLIG", [V]CST_ALASTPOS)
      If IBUDLIN <> [V]CST_ANOTDEFINED Then
        Call SHOW_BUDGET_LINE(IBUDLIN) From PJMACTBUD
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJBU1]10
      Grizo [M:PJBU1]BTNAFFECT(nolign-1)
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PJBU1]COLLIN(nolign-1) > 0 Then
      IRET = fmet GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).ADELLINE("BUDLIG", GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG([M:PJBU1]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GOK = 0
        GERR = 1
        mkstat = 2
      Endif
    Else
      GMESSAGE = mess(375,2260,1)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

