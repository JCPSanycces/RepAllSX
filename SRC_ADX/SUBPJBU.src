###################################################################################################
# Gestion du masque PJMBUDA
###################################################################################################
$ACTION
  Case ACTION
    When "BCL_BTNDC"                   Gosub BCL_BTNDC
    When "BCL_BTBLIG"                  Gosub BCL_BTBLIG
    When "BB1_NBLIG"                   Gosub BB1_NBLIG
    When "BB2_NBLIG"                   Gosub BB2_NBLIG
    When "BB3_NBLIG"                   Gosub BB3_NBLIG
    When "BB4_NBLIG"                   Gosub BB4_NBLIG
    When "BB6_NBLIG"                   Gosub BB6_NBLIG
    When Default
  Endcase
Return

###################################################################################################
$BCL_BTNDC
#  If   GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUDESTEX <> GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).snapshot.PBUDESTEX
#&  or  GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUCOMTEX <> GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).snapshot.PBUCOMTEX
    If REP = "" Then
      mkstat = 4
      REP = "M"
      [M:PJBU0]REP = REP
    Endif
#  Endif
Return

###################################################################################################
$BCL_BTBLIG
Local Integer ILINE
  ILINE = [M:PJBU1]COLLIN(nolign-1)
#  If   GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ILINE).PLBDESTEX <> GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ILINE).snapshot.PLBDESTEX
#&  or  GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ILINE).PLBCOMTEX <> GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ILINE).snapshot.PLBCOMTEX
    If REP = "" Then
      mkstat = 4
      REP = "M"
      [M:PJBU0]REP = REP
    Endif
#  Endif
Return

###################################################################################################
$BB1_NBLIG
Local Char STUNBUD(GLONPBU)

  If nolign > 0 Then
    STUNBUD = [M:PJBU0]KEYBUD(nolign-1)
  Else
    Raz STUNBUD
  Endif
  Gosub RELIT_GZINSPJM From SUBPJMA
  Gosub LOAD_PAGE From PJMACTBUD
Return

