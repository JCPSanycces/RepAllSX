###################################################################################################
# PJBU0
###################################################################################################
Subprog AS_NBLIG

  If nolign <= [M:PJBU0]NBLIG and [M:PJBU0]CLAROW(nolign-1) > 0 Then
    [M:PJBU0]LINBUD = [M:PJBU0]CLAROW(nolign-1)
    [M:PJBU0]LINBUDTBL = nolign
    Call SHOW_BUDGET([M:PJBU0]LINBUD) From PJMACTBUD
  Endif
End

###################################################################################################
Subprog IB_NBLIG

  If nolign-1 = 0 Then
    # The first line is the project
    Raz GBOUT1
    Raz GBOUT4
  Endif
  If [M:PJBU0]REP <> AVOID.ACHAR Then
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
    Raz GBOUT5
  Endif
  # -------------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If GBOUT1 <> AVOID.ACHAR Then
    # Change status
    If func SUBPJMA.GET_AUTHORIZATION("2") = [V]CST_ANO Then
      Raz GBOUT1
    Endif
  Endif
  If GBOUT2 <> AVOID.ACHAR Then
    # 2-Budget automation
    If func SUBPJMA.GET_AUTHORIZATION("5") = [V]CST_ANO Then
      Raz GBOUT2
    Endif
  Endif
  If GBOUT3 <> AVOID.ACHAR Then
    # 3-Saleable products
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("6") = [V]CST_ANO Then
      Raz GBOUT3
    Endif
  Endif
  If GBOUT4 <> AVOID.ACHAR Then
    # 4-Budget updates
    If func SUBPJMA.GET_AUTHORIZATION("M") = [V]CST_ANO Then
      Raz GBOUT4
    Endif
  Endif
  If GBOUT5 <> AVOID.ACHAR Then
    # Financial overview
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
      Raz GBOUT5
    Endif
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
End

###################################################################################################
# PJBU0A
###################################################################################################
Subprog AM_PBUFCY(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUFCY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUFCY = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).snapshot.PBUFCY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_BUDGET_HEADER([M:PJBU0]LINBUD) From PJMACTBUD
  Endif
End

###################################################################################################
