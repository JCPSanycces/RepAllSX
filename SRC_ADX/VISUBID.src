#<AdxTL>@(#)6.0.0.0 $Revision$

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA","END"   : Gosub ABANDON
Endcase
Return

$SET_VII
Call ACTIV("VII",OK) From SUBACV
If OK
 [M:PYB] = [F:BID]
 [M:PYB]FLGMOD = 2
 [F:PYH] = [M:PYB]
Endif 
Return

$OUVRE
If !clalev([F:BID]) : Local File BID[BID] : Endif
Return

$DEBUT
Local Char PAB3(35), PAB4(35),BICCOD(11)
Local Char MIDPAB1(35), MIDPAB2(35), MIDPAB3(35), MIDPAB4(35), MIDBICCOD(11), MIDCRY(GLONCRY)
Affzo [M:PYB]
[L] = [M:PYB]
Return

$OK
If [L]PAB3<>[M:PYB]PAB3 | [L]PAB4<>[M:PYB]PAB4 | [L]BICCOD<>[M:PYB]BICCOD | 
& [L]MIDPAB1<>[M:PYB]MIDPAB1 | [L]MIDPAB2<>[M:PYB]MIDPAB2 | [L]MIDPAB3<>[M:PYB]MIDPAB3 | 
& [L]MIDPAB4<>[M:PYB]MIDPAB4 | [L]MIDBICCOD<>[M:PYB]MIDBICCOD | [L]MIDCRY<>[M:PYB]MIDCRY
 [M:PYB]FLGMOD = 2
 mkstat = 4
Else
 [M:PYB]FLGMOD = 1
Endif
Return

$APRES_MODIF
REP="M"
Return

$ABANDON
# Abandon : Rechargement classe écran avec les anciennes valeurs
[M:PYB] = [L]
[M:PYB]FLGMOD = 1
REP = ""
Affzo [M:PYB]
Return
