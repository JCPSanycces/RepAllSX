#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "OK"           : Gosub OK
  Endcase
Return

$OUVRE
  If clalev([F:EMPALO]) = 0   : Local File HREMPALO  [EMPALO]   : Endif
  If clalev([F:HRPEOD]) = 0   : Local File HRPEODET  [HRPEOD]   : Endif
  If clalev([F:HRPEOH]) = 0   : Local File HRPEOHEA  [HRPEOH]   : Endif
  If clalev([F:HRPEOH2]) = 0  : Local File HRPEOHEA  [HRPEOH2]  : Endif

Return

$DEBUT
Local Char STAXEND(9), TMP_TAXENDDAT(12)
Local Date DTAXEND
Local Integer VTAXMONTH, NUMMONTHS, I
STAXEND     = "TAXENDDAT"
NUMMONTHS   = 12

Raz [M:EMPALO0]
Raz [M:EMPALO1]
[M:EMPALO0]CPY        = [M:CPY0]CPY
[M:EMPALO0]CPYNAM     = [M:CPY0]CPYNAM
[M:EMPALO0]CPYSHO     = [M:CPY0]CPYSHO
[M:EMPALO0]LEG        = [F:CPY]LEG

Call PARAM([M:EMPALO0]CPY, STAXEND, TMP_TAXENDDAT) From ADOVAL
If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
DTAXEND = gdat$(TMP_TAXENDDAT)

Filter [F:EMPALO] Where CPY = [M:CPY0]CPY
Read [EMPALO] First
If fstat
  Return
Endif

nolign = 0
For I = 1 To NUMMONTHS
  If [F:EMPALO]TAXMON(I-1) <> 0
    nolign += 1
    [M:EMPALO1]EMPALO(nolign-1)     = [F:EMPALO]EMPALO(I-1)
    [M:EMPALO1]EMPALOLFT(nolign-1)  = [F:EMPALO]EMPALOLFT(I-1)
    [M:EMPALO1]EMPNITOT(nolign-1)   = [F:EMPALO]EMPNITOT(I-1)
    [M:EMPALO1]TAXMON(nolign-1)     = [F:EMPALO]TAXMON(I-1)
    [M:EMPALO1]TAXYEA(nolign-1)     = [F:EMPALO]TAXYEA(I-1)
  Endif
Next I

Assign "[M:EMPALO1]NBEMPALO" With nolign


Affzo [M:EMPALO0]
Affzo [M:EMPALO1]


Return

$OK
Filter [F:EMPALO]

Trbegin [EMPALO]

Delete [F:EMPALO] Where [F:EMPALO]CPY=[M:EMPALO0]CPY
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("EMPALO",[M:EMPALO0]CPY) From GLOCK : Return
Endif

Raz [F:EMPALO]
[F:EMPALO] = [M:EMPALO0]

For nolign = 1 To [M:EMPALO1]NBEMPALO
  [F:EMPALO]EMPALO(nolign-1)        = [M:EMPALO1]EMPALO(nolign-1)
  [F:EMPALO]EMPALOLFT(nolign-1)     = [M:EMPALO1]EMPALOLFT(nolign-1)
  [F:EMPALO]EMPNITOT(nolign-1)      = [M:EMPALO1]EMPNITOT(nolign-1)
  [F:EMPALO]TAXMON(nolign-1)        = [M:EMPALO1]TAXMON(nolign-1)
  [F:EMPALO]TAXYEA(nolign-1)        = [M:EMPALO1]TAXYEA(nolign-1)
Next

Write [F:EMPALO]
If fstat
  GOK=0 #: Call FSTA("EMPALO") From GLOCK : Break
Endif

Commit
If !GOK : Goto AB_TR1 : Return : Endif

Return

$AB_TR1
  Rollback
  Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction

Return


#Calculation - Action - Button
Subprog EMLALOCALC
#Local variable declarations
Local Date CPYALLSTART, DTAXSTR, DTAXEND, DISPDATE, PERSTR, PEREND
Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
Local Char TMP_TAXSTRDAT(12), TMP_TAXENDDAT(12), VCPY(50), EMPALLCHAR(20), PERCODE(20)
Local Integer VAL_TAXYEA, VAL_TAXMON, FINMONTH, PERCOUNT, TAXMONTH, TXMONYEAR
Local Integer EXTPERYEAR, EXTPERNUM, I
Local Decimal EMPALL

#Get Employee allowance : Parameter
Call PARAM([M:EMPALO0]CPY, "EMPALLUK", EMPALLCHAR) From ADOVAL
EMPALL = val(EMPALLCHAR)

#Open tables
If clalev([F:EMPALO])=0 : Local File HREMPALO [EMPALO]      : Endif
If clalev([F:CPYUKI])=0 : Local File HRCOMPANYUKI [CPYUKI]  : Endif

#Manage Tax Dates - START
  #Start Date
  Call PARAM([M:EMPALO0]CPY, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
  DTAXSTR = gdat$(TMP_TAXSTRDAT)

  #End Date
  Call PARAM([M:EMPALO0]CPY, STAXEND, TMP_TAXENDDAT) From ADOVAL
  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
  DTAXEND = gdat$(TMP_TAXENDDAT)
#Manage Tax Dates - END

#Getting data from Legal data
Filter [F:CPYUKI] Where CPY = [M:EMPALO0]CPY  & CLMEMPALL = 2 & EMPALLDAT <> [0/0/0] & EMPALLDAT <= DTAXEND
Read [CPYUKI] First
If !fstat
  #TODO: FRLAA Changes 2017-04-24 - Start
  VCPY          = [F:CPYUKI]CPY
  CPYALLSTART   = [F:CPYUKI]EMPALLDAT
  #TODO: FRLAA Changes 2017-04-24 - End
Else
  Filter [CPYUKI] :End
Endif


#Calculations run
#TODO: FRLAA Changes 2017-04-24 - Start
#We don't need this check anymore - we will get all extraction periods based on the values from the tax year

#Filter [HRPEOH] Where [F:HRPEOH]LEG = 'BRI' and [F:HRPEOH]CYCSTRDAT =  DTAXSTR and [F:HRPEOH]FLGENA = 2
#Read [F:HRPEOH] First
#If !fstat
#  PERCODE = [F:HRPEOH]PERCOD
#Else
#  Filter [HRPEOH] : End
#Endif
#Filter [HRPEOH]
#TODO: FRLAA Changes 2017-04-24 - End


nolign = 0

#TODO: FRLAA Changes 2017-04-24 - Start
#The first month of tax year will always be 1 - we will use this as the base together with the tax year obtained from the Tax end parameter
#Set the tax month and number of months
VAL_TAXMON  = 1
TXMONYEAR   = 12

#Set the UK Tax month/date values based of the tax start date
DISPDATE = DTAXSTR

For I = VAL_TAXMON To TXMONYEAR
  #Check if the allowance was enabled before the period
  If eomonth(DISPDATE)>= eomonth(CPYALLSTART) Then
    If eomonth(DISPDATE) <= eomonth(GMOIPAY) Then #TODO : DEHEN - GMOIPAY date might change. Example Tax month (GMONTHPAY)
      nolign += 1
      VAL_TAXYEA    = year(DTAXEND)
      TAXMONTH      = I
      EXTPERYEAR    = year(DTAXSTR)
      EXTPERNUM     = I

      [M:EMPALO1]TAXYEA(nolign-1)   = VAL_TAXYEA
      [M:EMPALO1]TAXMON(nolign-1)   = TAXMONTH
      [M:EMPALO1]EMPALO(nolign-1)   =  EMPALL

      [M:EMPALO1]EMPNITOT(nolign-1) = func UK_FUNCTIONS.GET_PAYSLIP_VALUES_MONYEA(VCPY,month(DISPDATE), year(DISPDATE),"NI")
      [M:EMPALO1]EMPNITOT(nolign-1) = [M:EMPALO1]EMPNITOT(nolign-1) + func UK_FUNCTIONS.GET_PAYSLIP_VALUES_MONYEA(VCPY,month(DISPDATE), year(DISPDATE),"NI_DIR")

      If [M:EMPALO1]EMPALO(nolign-1) - [M:EMPALO1]EMPNITOT(nolign-1)  < 0 Then
        [M:EMPALO1]EMPALOLFT(nolign-1) = 0
      Else
        [M:EMPALO1]EMPALOLFT(nolign-1) = [M:EMPALO1]EMPALO(nolign-1) - [M:EMPALO1]EMPNITOT(nolign-1)
      Endif
      EMPALL = [M:EMPALO1]EMPALOLFT(nolign-1)
    Endif
  Endif
  DISPDATE = addmonth(DISPDATE,1)
Next



#Filter [F:HRPEOD] Where [F:HRPEOD]PERCOD = PERCODE and [F:HRPEOD]PEREND >= [F:CPYUKI]EMPALLDAT and [F:HRPEOD]PERSTR >= DTAXSTR Order By [F:HRPEOD]PERSTR Desc
##Filter [F:HRPEOD] Where [F:HRPEOD]PEREND >= [F:CPYUKI]EMPALLDAT and [F:HRPEOD]PERSTR >= DTAXSTR Order By [F:HRPEOD]PERSTR Desc
#For [F:HRPEOD]
#  If eomonth([F:HRPEOD]PERSTR) <= eomonth(GMOIPAY)
#    nolign += 1
#    VAL_TAXYEA    = year(DTAXEND)
#    TAXMONTH      = [F:HRPEOD]TAXMON
#    PERSTR        = [F:HRPEOD]PERSTR
#    PEREND        = [F:HRPEOD]PEREND
#    EXTPERYEAR    = [F:HRPEOD]PERYEA
#    EXTPERNUM     = [F:HRPEOD]PERNUM
#
#    [M:EMPALO1]TAXYEA(nolign-1)   = VAL_TAXYEA
#    [M:EMPALO1]TAXMON(nolign-1)   = TAXMONTH
#    [M:EMPALO1]EMPALO(nolign-1)   =  EMPALL
#    [M:EMPALO1]EMPNITOT(nolign-1) = func UK_FUNCTIONS.GET_PAYSLIP_VALUES_WPC(VCPY,EXTPERYEAR, EXTPERNUM,"NI_ER_MTD",PERCODE)
#    If [M:EMPALO1]EMPALO - [M:EMPALO1]EMPNITOT < 0 Then
#      [M:EMPALO1]EMPALOLFT(nolign-1) = 0
#    Else
#      [M:EMPALO1]EMPALOLFT(nolign-1) = [M:EMPALO1]EMPALO - [M:EMPALO1]EMPNITOT
#    Endif
#  Endif
#Next

#TODO: FRLAA Changes 2017-04-24 - Start

If nolign > 0
  Assign "[M:EMPALO1]NBEMPALO" With nolign
Endif
Affzo [M:EMPALO0]
Affzo [M:EMPALO1]
End

#DEHEN - 2017-04-04 - X3-31054 + X3-31055 - END

