#<AdxTL>@(#)9.0.0.0 $Revision$
$CHARGE_GRAPHE
Local Integer I

Raz [M:ICM1]NBLIG1,[M:ICM2]NBLIG2,[M:ICM3]NBLIG3,[M:ICM4]NBLIG4

If [M:ICM0]AFFZER=2 | [M:ICM1]COST1(0)<>0 | [M:ICM1]COST2(0)<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(1,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]COST1(0)
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]COST2(0)
    [M:ICM1]NBLIG1 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM1]COST1(1)<>0 | [M:ICM1]COST2(1)<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(3,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]COST1(1)
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]COST2(1)
    [M:ICM1]NBLIG1 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM1]COST1(2)<>0 | [M:ICM1]COST2(2)<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(5,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]COST1(2)
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]COST2(2)
    [M:ICM1]NBLIG1 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM1]COST1(3)<>0 | [M:ICM1]COST2(3)<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(7,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]COST1(3)
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]COST2(3)
    [M:ICM1]NBLIG1 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM1]INVDTA1<>0 | [M:ICM1]INVDTA2<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(7,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]INVDTA1
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]INVDTA2
    [M:ICM1]NBLIG1 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM1]COST1(4)<>0 | [M:ICM1]COST2(4)<>0
    [M:ICM1]LBL([M:ICM1]NBLIG1) = mess(13,379,1)
    [M:ICM1]CST1([M:ICM1]NBLIG1) = [M:ICM1]COST1(4)
    [M:ICM1]CST2([M:ICM1]NBLIG1) = [M:ICM1]COST2(4)
    [M:ICM1]NBLIG1 += 1
Endif

Affzo [M:ICM1]

For I=0 To GACTMAT-1
    If [M:ICM0]AFFZER=2 | [M:ICM2]MATCST1(I)<>0 | [M:ICM2]MATCST2(I)<>0
        [M:ICM2]LBL([M:ICM2]NBLIG2) = mess(I+1,325,1)
        [M:ICM2]CST1([M:ICM2]NBLIG2) = [M:ICM2]MATCST1(I)
        [M:ICM2]CST2([M:ICM2]NBLIG2) = [M:ICM2]MATCST2(I)
        [M:ICM2]NBLIG2 += 1
    Endif
Next
If [M:ICM0]AFFZER=2 | [M:ICM2]SCOTOT1<>0 | [M:ICM2]SCOTOT2<>0
    [M:ICM2]LBL([M:ICM2]NBLIG2) = mess(7,379,1)
    [M:ICM2]CST1([M:ICM2]NBLIG2) = [M:ICM2]SCOTOT1
    [M:ICM2]CST2([M:ICM2]NBLIG2) = [M:ICM2]SCOTOT2
    [M:ICM2]NBLIG2 += 1
Endif

Affzo [M:ICM2]

For I=0 To GACTMAC-1
    If [M:ICM0]AFFZER=2 | [M:ICM3]MACCST1(I)<>0 | [M:ICM3]MACCST2(I)<>0
        [M:ICM3]LBL([M:ICM3]NBLIG3) = mess(1,313,1)+"-"+mess(I+1,316,1)
        [M:ICM3]CST1([M:ICM3]NBLIG3) = [M:ICM3]MACCST1(I)
        [M:ICM3]CST2([M:ICM3]NBLIG3) = [M:ICM3]MACCST2(I)
        [M:ICM3]NBLIG3 += 1
    Endif
Next

For I=0 To GACTLAB-1
    If [M:ICM0]AFFZER=2 | [M:ICM3]LABCST1(I)<>0 | [M:ICM3]LABCST2(I)<>0
        [M:ICM3]LBL([M:ICM3]NBLIG3) = mess(2,313,1)+"-"+mess(I+1,316,1)
        [M:ICM3]CST1([M:ICM3]NBLIG3) = [M:ICM3]LABCST1(I)
        [M:ICM3]CST2([M:ICM3]NBLIG3) = [M:ICM3]LABCST2(I)
        [M:ICM3]NBLIG3+=1
    Endif
Next
Affzo [M:ICM3]

Raz [M:ICM4]NBLIG4

If [M:ICM0]AFFZER=2 | [M:ICM4]COST1(0)<>0 | [M:ICM4]COST2(0)<>0
    [M:ICM4]LBL([M:ICM4]NBLIG4) = mess(8,379,1)
    [M:ICM4]CST1([M:ICM4]NBLIG4) = [M:ICM4]COST1(0)
    [M:ICM4]CST2([M:ICM4]NBLIG4) = [M:ICM4]COST2(0)
    [M:ICM4]NBLIG4 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM4]COST1(1)<>0 | [M:ICM4]COST2(1)<>0
    [M:ICM4]LBL([M:ICM4]NBLIG4) = mess(9,379,1)
    [M:ICM4]CST1([M:ICM4]NBLIG4) = [M:ICM4]COST1(1)
    [M:ICM4]CST2([M:ICM4]NBLIG4) = [M:ICM4]COST2(1)
    [M:ICM4]NBLIG4 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM4]COST1(2)<>0 | [M:ICM4]COST2(2)<>0
    [M:ICM4]LBL([M:ICM4]NBLIG4) = mess(10,379,1)
    [M:ICM4]CST1([M:ICM4]NBLIG4) = [M:ICM4]COST1(2)
    [M:ICM4]CST2([M:ICM4]NBLIG4) = [M:ICM4]COST2(2)
    [M:ICM4]NBLIG4 += 1
Endif

If [M:ICM0]AFFZER=2 | [M:ICM4]COST1(3)<>0 | [M:ICM4]COST2(3)<>0
    [M:ICM4]LBL([M:ICM4]NBLIG4) = mess(11,379,1)
    [M:ICM4]CST1([M:ICM4]NBLIG4) = [M:ICM4]COST1(3)
    [M:ICM4]CST2([M:ICM4]NBLIG4) = [M:ICM4]COST2(3)
    [M:ICM4]NBLIG4 += 1
Endif

Affzo [M:ICM4]

Return

