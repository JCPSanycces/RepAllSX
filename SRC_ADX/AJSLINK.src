#<AdxTL>@(#)9.0.0.0 $Revision$
# AJSLINK   FGR 08/04/2011 : Initialisation linking SDATA
# -------------------------------------------------------
End

#---------------------------------------------------------------------------------
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : Gosub ONOK
    When "FIN"         : Gosub FIN
  Endcase
Return

#---------------------------------------------------------------------------------
$OUVRE
  Local File ATABLE [ATB]
  Local File ATABZON [ATZ]
Return

#---------------------------------------------------------------------------------
$DEBUT
Local Integer NI

  NI = 0
  For [ATB]CODFIC Where [F:ATB]AUDSDA = 2
    NI += 1
    [M:AJK0]CODFIC(NI-1) = [F:ATB]CODFIC
    [M:AJK0]INILNK(NI-1) = 1
  Next
  [M:AJK0]NBTAB = NI-0
  Affzo [M:AJK0]1-99
Return

#---------------------------------------------------------------------------------
$FIN
  Inftxt "" At 2
Return

#---------------------------------------------------------------------------------
$ONOK
  Gosub INIT_SDATA
  FIN = 0
Return

#---------------------------------------------------------------------------------
$INIT_SDATA
Local Integer NI
Local Integer NBREC
Local Integer NBERROR
Local Integer STAT
Local Char ORDSYS(250)(1..2)
Local Char TABLE(GLONATB)

  Call OUVRE_TRACE(mess(88,143,1)) From LECFIC  # "Initialisation synchronisation SDATA"
  #
  If [M:AJK0]RAZAUDTBL = 2 Then
    Call ECR_TRACE(mess(89,143,1), 0) From GESECRAN  # Initialisation de la table d'audit SDATA
    #
    For TABLE = "AJSAUDIT", "AJSSYNC"
      Call ECR_TRACE(mess(89,143,1) - ":" - TABLE, 0) From GESECRAN  # Initialisation de la table d'audit SDATA
      #
      Read [ATB]CODFIC=TABLE
      If fstat Then
        Raz [F:ATB]
      Endif
      #
      ORDSYS(1) = "valfil -s -z"
      If [F:ATB]FLG130 = 2 Then # Version 130
       ORDSYS(1) -= "-a"
      Endif
      ORDSYS(1) -= nomap-TABLE
      ORDSYS(2) = GTRACE
      #
      Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
      If STAT <> 0 Then
        Call ECR_TRACE("    =>" + mess(96,143,1) - ":" - TABLE, 1) From GESECRAN  # Erreur lors de l'initialisation de la table d'audit SDATA
        # On ne fait pas le reste
        Break
      Endif
    Next
    If STAT <> 0 Then
      # On ne fait pas le reste
      Goto FIN_INIT_SDATA
    Endif
  Endif
  #
  NBERROR = 0
  For NI = 0 To [M:AJK0]NBTAB-1
    Raz [M:AJK0]RES(NI)
    If [M:AJK0]INILNK(NI) = 2 Then
      Call ECR_TRACE(mess(90,143,1) - ":" - [M:AJK0]CODFIC(NI), 0) From GESECRAN  # Initialisation table
      #
      STAT = func INIT_TABLE([M:AJK0]CODFIC(NI), NBREC)
      If STAT Then
        # Erreur sur la table [M:AJK0]CODFIC(NI)
        NBERROR += 1
        Call ECR_TRACE("    =>" + mess(91,143,1) - ":" - [M:AJK0]CODFIC(NI), 1) From GESECRAN  #ERREUR lors de l'initialisation de la table
        [M:AJK0]RES(NI) = mess(21,7,1)
      Else
        # Initialisation valide sur la table [M:AJK0]CODFIC(NI)
        Call ECR_TRACE("    =>" + mess(92,143,1) - num$(NBREC) - mess(93,143,1), 0) From GESECRAN  # Linking initialisé.  # mis à jour.
        [M:AJK0]RES(NI) = num$(NBREC) - mess(93,143,1)
      Endif
    Endif
    Affzo [M:AJK0]RES(NI)
  Next NI
  #
  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("---" + mess(94,143,1) + "---", 0) From GESECRAN  # Fin initialisation synchronisation SDATA
  If NBERROR > 0 Then
    Call ECR_TRACE("    =>" - num$(NBERROR) - mess(95,143,1), 0) From GESECRAN
  Endif
  #
$FIN_INIT_SDATA
  #
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

#---------------------------------------------------------------------------------
Funprog INIT_TABLE(STABLE, NBREC)
Value Char STABLE
Variable Integer NBREC

Local Integer STAT
Local Char SZONE(GLONAVA)
Local Char OTRP(type([S]ADXTRP)-10)
Local Char OTRL(type([S]ADXTRL)-10)

  STAT = 0
  NBREC = 0
  Inftxt STABLE At 2
  # ----------------------
  For [ATZ]CODZONE Where [F:ATZ]CODFIC = STABLE and ([F:ATZ]CODZONE = "CRESTP" or [F:ATZ]CODZONE = "UPDSTP" or [F:ATZ]CODZONE = "IDTSGL")
    SZONE = [F:ATZ]CODZONE
    Break
  Next
  # ----------------------
  If dim([S]ADXTRP) > 0 and dim([S]ADXTRL) > 0 Then
    OTRP = [S]ADXTRP
    OTRL = [S]ADXTRL
    [S]ADXTRP = ""
    [S]ADXTRL = ""
  Endif
  # ----------------------
  Local File =STABLE [AAA]
  Trbegin [AAA]
  Case SZONE
    When "CRESTP"
      Update [AAA] With [F:AAA]CRESTP = [F:AAA]CRESTP
    When "UPDSTP"
      Update [AAA] With [F:AAA]UPDSTP = [F:AAA]UPDSTP
    When "IDTSGL"
      Update [AAA] With [F:AAA]IDTSGL = [F:AAA]IDTSGL
  Endcase
  If fstat = 0 Then
    NBREC = [S]adxuprec
    Commit
  Else
    STAT = 1
    Rollback
  Endif
  # ----------------------
  If dim([S]ADXTRP) > 0 and dim([S]ADXTRL) > 0 Then
    [S]ADXTRP = OTRP
    [S]ADXTRL = OTRL
  Endif
  # ----------------------
End STAT
