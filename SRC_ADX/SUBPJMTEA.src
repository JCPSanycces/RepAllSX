#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Objet PJM  SUBPJMTEA
###################################################################################################
$OUVRE
Global Instance GZINSPJMTH Using C_PJMTIMEMPH   # Hybrid part

  Gosub DECLARE_FILES
  # Hybrid part (begin)
  ANOWRITE = 1
  # Hybrid part (end)
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
$DEBUT
  # 1) The user has to be authorised for PJM
  Read [PAUS]PAUS=GUSER
  If !fstat Then
    [M:PTEH]CLB = GUSER
    If [F:PAUS]ENAFLG = [V]CST_ANO Then
      GMESSAGE = func AFNC.MES1(mess(353,2260,1), GUSER)
      GERR = 1
      FIN = 1
      Return
    Endif
    If [F:PAUS]PAUSPA <> [V]CST_AYES Then
      If [F:PAUS]PAUSTT = [V]CST_AYES Then
        Diszo [M:PTEH]CLB
        Chgfmt [M:PTED]CLBPCC With "-K:" + num$(GLONPJCC) + "X"
        Chgfmt [M:PTED]PJMCST With "-N3zF:" + "11.2"
        Chgfmt [M:PTED]CLBCST With "-N3zF:" + "11.2"
        Chgfmt [M:PTED]CUR With "-K:" + num$(GLONCUR) + "X"
        #Chgfmt [M:PTED]PTEVAL With "-K:" + num$(GLONADI) + "X" # Issue X3-66487 - 2018-05-04 by SINGC
      Else
        GMESSAGE = func AFNC.MES1(mess(353,2260,1), GUSER)
        GERR = 1
        FIN = 1
        Return
      Endif
    Endif
    Call LECTEXTRA([M:PTEH]PTENAM, "AUTILIS", "INTUSR", [M:PTEH]CLB, "") From ATEXTRA
  Else
    GMESSAGE = func AFNC.MES1(mess(353,2260,1), GUSER)
    GERR = 1
    FIN = 1
    Return
  Endif
  Call LOAD_ASSIGNMENTS()
  Call DISPLAY_WITH_STYLE()
  Affzo [M:PTEH]1-99
  Affzo [M:PTEAFF]1-99
Return

###################################################################################################
$SETBOUT
  # Issue X3-94962 - 2018-06-18 by FGR : BEGIN
  #Call VIREBOUT(CHMEN,"2") From GOBJET          # Not existing !
  If GREP <> "" or [M:PTEH]CLB = "" Then
    Call VIREBOUT(CHMEN,"*") From GOBJET         # Issue X3-94962 - 2018-06-18 by FGR : Activate the time inquiry
  Endif
  # Issue X3-94962 - 2018-06-18 by FGR : END
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "1"       : Gosub SEARCH
  Endcase
Return

###################################################################################################
$APRES_MODIF
  If REP = "" Then
    REP = "M"
    GREP = REP
    Raz GBOUT1
  Endif
Return

###################################################################################################
$ABANDON
  REP = ""
  GREP = REP
  Call INIT_GZINSPJMTH(GZINSPJMTH)
  Gosub SEARCH
Return

###################################################################################################
$FERME
  # Hybrid part (begin)
  If GZINSPJMTH <> null Then
    Raz [M:PTEH]
    Raz [M:PTED]
    Raz [M:PTEAFF]
    FreeGroup GZINSPJMTH
  Endif
  Kill GZINSPJMTH
  # Hybrid part (end)
Return

###################################################################################################
$ENR
Local Integer MY_STATUS  # Hybrid part

  If GZINSPJMTH = null Then
    GMESSAGE = mess(167,2260,1)
    GERR = 1
    Return
  Endif
  # ----------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
#  Dbgaff
  # Validate if first time entries for user
  If GZINSPJMTH.ASTALIN = [V]CST_ANEW Then
    [L]MY_STATUS = fmet GZINSPJMTH.AINSERT()
  Elsif GZINSPJMTH.ASTALIN = [V]CST_AUPD Then
    [L]MY_STATUS = fmet GZINSPJMTH.AUPDATE()
  Endif
  Affzo [M:PTED]1-99
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(317,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # Hybrid part (end)
  # ----------------------------------
  # Reload data saved
  Gosub SEARCH
  REP = ""
  GREP = REP
Return

###################################################################################################
# PJMTIMD - Subroutines
###################################################################################################
$SEARCH
  # ----------------------------------
  [M:PTEDIE]SEARCH = [V]CST_AYES       # Issue X3-66474 - 2018-02-08 by SINGC/FGR
  # ----------------------------------
  If GZINSPJMTH <> null Then
    FreeGroup GZINSPJMTH
    Raz GZINSPJMTH
  Endif
  Call INIT_GZINSPJMTH(GZINSPJMTH)
  If GERR = 1 Then
    Return
  Endif
  Effzo [M:PTED]5
  [M:PTEH]CLB = GZINSPJMTH.CLB
  Call SHOW_TIMENTH()
  Affzo [M:PTEH]1-99
  Affzo [M:PTED]1-99
  Affzo [M:PTEAFF]1-99
  # ----------------------------------
  # Issue X3-66474 - 2018-02-08 by SINGC/FGR : BEGIN
  Effzo [M:PTEDIE]5          # Issue X3-81871 - 2018-03-27 by FGR
  [M:PTEDIE]SEARCH = [V]CST_ANO
  If [M:PTED]NBLIG > 0 Then
    Call SHOW_CDIE([M:PTED]COLLIN(0))
  Endif
  # Issue X3-66474 - 2018-02-08 by SINGC/FGR : END
  # ----------------------------------
  REP = ""
  GREP = REP
Return

###################################################################################################
$DECLARE_FILES
  If !clalev([F:PTEH])  : Local File PJMTIMEMPH [PTEH]   : Endif
  If !clalev([F:PTED])  : Local File PJMTIMEMP  [PTED]   : Endif
  If !clalev([F:PIM])   : Local File PIMPL      [PIM]    : Endif
  If !clalev([F:PJTA])  : Local File PJMTSK     [PJTA]   : Endif
  If !clalev([F:PTC])   : Local File PJMTSKCAT  [PTC]    : Endif
  If !clalev([F:PTKO])  : Local File PJMTSKOPE  [PTKO]   : Endif
  If !clalev([F:PJOA])  : Local File PJMOPEAFF  [PJOA]   : Endif
  If !clalev([F:PAUS])  : Local File PJMAUS     [PAUS]   : Endif
  If !clalev([F:TCU])   : Local File TABCUR     [TCU]    : Endif
  If !clalev([F:AUS])   : Local File AUTILIS    [AUS]    : Endif
  If !clalev([F:OPPPJM]): Local File OPPORPJM   [OPPPJM] : Endif
Return

###################################################################################################
$CLEARFIELDS
  Raz [M:PTEH]
  Raz [M:PTED]
  Raz [M:PTEAFF]
  Raz [M:PTEDIE] # Issue X3-66474 - 2018-02-08 by SINGC/FGR
Return

###################################################################################################
Subprog SHOW_TIMENTH()

Local Char SFILTER(255)
Local Char KEYCONCAT(250)

  Local File OPPORPJM   [OPPPJM]
  Local File PJMTIMEMP  [PTED]
  # ----------------------------------
  If [M:PTEH]OPPNUM <> AVOID.ACHAR and [M:PTEH]ISOPEN = [V]CST_AYES Then
    Read [OPPPJM]OPPPJM0=[M:PTEH]OPPNUM
    If [F:OPPPJM]OPPSTATE <> 2 Then
      GMESSAGE = func AFNC.MES1(mess(38,2260,1), [M:PTEH]OPPNUM)
      GERR = 1
      End
    Endif
  Endif
  SetInstance [M:PTEH] With GZINSPJMTH
  # Build filter
  SFILTER += "[F:PTED]CLB = [M:PTEH]CLB"
  SFILTER -= "& ([F:PTED]PTESTA = 1 or [F:PTED]PTESTA = 2)"
  If [M:PTEH]OPPNUM <> AVOID.ACHAR Then
    SFILTER -= "& [F:PTED]OPPNUM = [M:PTEH]OPPNUM"
  Endif
  If [M:PTEH]TSDATE <> [0/0/0] Then
    SFILTER -= "& [F:PTED]PTEDAT >= [M:PTEH]TSDATE"
  Endif
  If [M:PTEH]TEDATE <> [0/0/0]
    SFILTER -= "& [F:PTED]PTEDAT <= [M:PTEH]TEDATE"
  Endif
  If [M:PTEH]STAVAL = [V]CST_AYES Then
    SFILTER -= "& [F:PTED]PTESTA = 1"
  Endif
  Effzo [M:PTED]1-99
  Filter [F:PTED] Where evalue(SFILTER)
  nolign = 0
  For [F:PTED]PTE3 # Issue X3-99916 - 2018-07-17 by FGR : index was missing
    If [M:PTEH]ISOPEN = [V]CST_AYES Then
      Read [OPPPJM]OPPPJM0=[F:PTED]OPPNUM
      If [F:OPPPJM]OPPSTATE = 2 Then
        nolign += 1
        [M:PTED] = [F:PTED]
        [M:PTED]COLLIN(nolign-1) = fmet GZINSPJMTH.TIMENT_GET_INDEX([M:PTED]PTESEQ(nolign-1))
      Endif
    Else
      nolign += 1
      [M:PTED] = [F:PTED]
      [M:PTED]COLLIN(nolign-1) = fmet GZINSPJMTH.TIMENT_GET_INDEX([M:PTED]PTESEQ(nolign-1))
    Endif
    KEYCONCAT = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).KEYCONCAT
    [M:PTED]BTBLIG(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJMTH.ACTX,
&                                                                        func PJMTIMEMP_CSTD_PROGS.PTEDESTEX_EXIST(GZINSPJMTH.ACTX, KEYCONCAT) = [V]CST_AYES or
&                                                                        func PJMTIMEMP_CSTD_PROGS.PTECOMTEX_EXIST(GZINSPJMTH.ACTX, KEYCONCAT) = [V]CST_AYES)
  Next
  [M:PTED]NBLIG = nolign
  Filter [F:PTED]
  # ------------------------------------
  Call CALC_TOTAL_QTY()
  Call CALC_TOTAL_LOADS()
  Call LOAD_ASSIGNMENTS()
  Call DISABLE_BUDGET()
  Call DISPLAY_WITH_STYLE()
End

###################################################################################################
Subprog SHOW_TIMENT_LINE(VNLINE)
Value Integer VNLINE

Local Char SOPPNUM(GLONPIM)
Local Char STASCOD(GLONTAC)
Local Char SPBUCOD(GLONPBU)
Local Integer IOPENUM

  SOPPNUM = [M:PTED]OPPNUM(nolign-1)
  If GZINSPJMTH.TIMENT(VNLINE).PIMTASCOD <> AVOID.ACHAR Then
    STASCOD = [M:PTED]TASCOD(nolign-1)
    IOPENUM = [M:PTED]OPENUM(nolign-1)
  Endif
  If GZINSPJMTH.TIMENT(VNLINE).PIMPBUCOD <> AVOID.ACHAR Then
    SPBUCOD = [M:PTED]PBUCOD(nolign-1)
  Endif
  SetInstance [M:PTED]5 With GZINSPJMTH.TIMENT(VNLINE)
  [M:PTED]COLLIN(nolign-1) = VNLINE    # Line index in the collection
  GFCY = [M:PTED]FCY(nolign-1)         # Issue X3-99928 - 2018-08-24 by FGR : needed for Authorizations
  If [M:PTED]OPPNUM(nolign-1) = AVOID.ACHAR or [M:PTED]PBUCOD(nolign-1) = AVOID.ACHAR Then
    [M:PTED]OPPNUM(nolign-1) = SOPPNUM
    [M:PTED]TASCOD(nolign-1) = STASCOD
    [M:PTED]PBUCOD(nolign-1) = SPBUCOD
    [M:PTED]OPENUM(nolign-1) = IOPENUM
  Endif
  Affzo [M:PTED]1-99
  Call SHOW_CDIE(VNLINE) From SUBPJMTEA
End

##########################################################################################################
Subprog SHOW_CDIE(VNLINE)
Value Integer VNLINE

Local Integer NI

  # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  [M:PTEDIE]TIMENTLIN = VNLINE
  Effzo [M:PTEDIE]5
  nolign = 0
  If [M:PTEDIE]TIMENTLIN > 0 Then
    For NI = 1 To maxtab(GZINSPJMTH.TIMENT([M:PTEDIE]TIMENTLIN).CDIE)
      If GZINSPJMTH.TIMENT([M:PTEDIE]TIMENTLIN).CDIE(NI) <> null and find(GZINSPJMTH.TIMENT([M:PTEDIE]TIMENTLIN).CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        nolign += 1
        Call SHOW_CDIE_LINE(NI)
      Endif
    Next NI
  Endif
  [M:PTEDIE]NBRDIE = nolign
  Affzo [M:PTEDIE]5
End

##########################################################################################################
Subprog SHOW_CDIE_LINE(VNLINE)
Value Integer VNLINE

  # Issue X3-66474 - 2018-02-02 by SINGC
  SetInstance [M:PTEDIE]5 With GZINSPJMTH.TIMENT([M:PTEDIE]TIMENTLIN).CDIE(VNLINE)
  [M:PTEDIE]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

###################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer NI
Local Integer ILINE
Local Integer MY_STATUS

  For NI = 1 To maxtab(GZINSPJMTH.TIMENT)
    If GZINSPJMTH.TIMENT(NI) <> null and find(GZINSPJMTH.TIMENT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(NI, [M:PTED]COLLIN(0..[M:PTED]NBLIG-1))       # Check if exist in the first grid
      If ILINE <= 0 Then
        ILINE = find(NI, [M:PTEAFF]COLLIN(0..[M:PTEAFF]NBLIG-1)) # If not, check if exist in the second grid
        If ILINE <= 0 Then
          # If new line is not on first and second grid : user did Esc => Delete the line in the collection
          [L]MY_STATUS = fmet GZINSPJMTH.ADELLINE("TIMENT", GZINSPJMTH.TIMENT(NI).AORDER)
          If [L]MY_STATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
            GOK = 0
            GERR = 1
            Break
          Endif
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

###################################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTE)
Variable Instance GZINSPJMTE Using C_PJMTIMEMPH

Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSPJMTE, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  # -------------------------
  # To help debug process : write a classic log file with all errors in class.
  If GERR <> 0 Then
    If GTRACE = AVOID.ACHAR Then
      Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
      IOPEN_TRACE = [V]CST_AYES
    Endif
    Call ECR_TRACE("->", 0) From GESECRAN
    Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GZINSPJMTE) From SYRSTACKTOOLS
    If IOPEN_TRACE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
    Endif
  Endif
  # -------------------------
  [L]MY_STATUS = fmet GZINSPJMTE.PTE_RESET_ERRORS()
End

###################################################################################################
Subprog INIT_GZINSPJMTH(GZINSPJMTH)
Variable Instance GZINSPJMTH Using C_PJMTIMEMPH

Local Integer MY_STATUS

  If GZINSPJMTH = null Then
    Local File PJMTIMEMPH [PTEH]
    # ----------------------------------
    GZINSPJMTH = NewInstance C_PJMTIMEMPH AllocGroup null
    Read [PTEH]PTEH0=[M:PTEH]CLB
    If fstat Then
      # The user is not existing in time entries
      [L]MY_STATUS = fmet GZINSPJMTH.AINIT()
      If GZINSPJMTH.CLB <> [M:PTEH]CLB Then
        GZINSPJMTH.CLB = [M:PTEH]CLB
      Endif
    Else
      # The user is existing in time entries
      [L]MY_STATUS = fmet GZINSPJMTH.AREAD([M:PTEH]CLB)
      If [L]MY_STATUS >= [V]CST_AERROR Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
        GOK = 0
        GERR = 1
        End
      Endif
    Endif
  Endif
End

###################################################################################################
Subprog LOAD_ASSIGNMENTS()

Local Char SFILTER(255)

  Local File PJMOPEAFF  [PJOA]
  Local File OPPORPJM   [OPPPJM]
  Local File PJMTSK     [PJTA]
  Local File PJMTSKCAT  [PTC]
  Local File PJMTSKOPE  [PTKO]
  # ----------------------------------
  # Build filter
  SFILTER += "[F:PJOA]POACLB = [M:PTEH]CLB"
  If [M:PTEH]OPPNUM <> AVOID.ACHAR Then
    SFILTER -= "& [F:PJOA]OPPNUM = [M:PTEH]OPPNUM"
  Endif
  If [M:PTEH]TSDATE <> [0/0/0] Then
    SFILTER -= "& [F:PJOA]POASTR >= [M:PTEH]TSDATE"
  Endif
  If [M:PTEH]TEDATE <> [0/0/0] Then
    SFILTER -= "& [F:PJOA]POAEND <= [M:PTEH]TEDATE"
  Endif
  # Load the second grid
  Call INIT_GZINSPJMTH(GZINSPJMTH)
  #
  Effzo [M:PTEAFF]
  nolign = 0
  Filter [PJOA] Where evalue(SFILTER)
  For [PJOA]
    Read [OPPPJM]OPPPJM0=[F:PJOA]OPPNUM
    If [F:OPPPJM]OPPSTATE = 2 Then
      Read [PJTA]PTA0=[F:PJOA]OPPNUM;[F:PJOA]TASCOD
      If [PJTA]TASTYP = 2 Then
        Read [PTC]CTA0=[PJTA]TCACOD
        If [PTC]TASTYP = 2 or [PTC]TASTYP = 3 Then
          Read [PTKO]PTKO0=[F:PJOA]OPPNUM;[F:PJOA]TASCOD;[F:PJOA]OPENUM;[F:PJOA]OPESPLNUM
          If [PTKO]OPESTA = 4 Then
            nolign += 1
            [M:PTEAFF] = [F:PJOA]
            [M:PTEAFF]PTEUOM(nolign-1) = [F:PJOA]POUOM
            [M:PTEAFF]CSMQTY(nolign-1) = [F:PJOA]POACSMQTY
            [M:PTEAFF]RMNQTY(nolign-1) = [F:PJOA]POARMNQTY
            [M:PTEAFF]STDQTY(nolign-1) = [F:PJOA]POASTDQTY
            [M:PTEAFF] = [F:PJTA]
            [M:PTEAFF]FCY(nolign-1) = [F:PJTA]TASFCY
            [M:PTEAFF]PTEDESAXX(nolign-1) = func PJMOPEAFF_CSTD_PROGS.GET_POADES(GZINSPJMTH.ACTX, func SUBPJMTEAFF.GET_KEYCONCAT_SCREEN_PJMTIMDAFF())
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [PJOA]
  [M:PTEAFF]NBLIG = nolign
  Affzo [M:PTEAFF]1-99
  Grizo [M:PTEAFF]BTLIGAFF
End

###################################################################################################
Subprog DISPLAY_WITH_STYLE()

Local Integer NI

  Affzo [M:PTED]5
  For NI = 0 To [M:PTED]NBLIG-1
    If [M:PTED]STDQTY(NI) > [M:PTED]CSMQTY(NI) Then
      Chgstl [M:PTED]CSMQTY(NI) With "BACKGREEN"
    Elsif [M:PTED]STDQTY(NI) < [M:PTED]CSMQTY(NI) Then
      Chgstl [M:PTED]CSMQTY(NI) With "BACKRED"
    Endif
  Next NI
  Affzo [M:PTEAFF]5
  For NI = 0 To [M:PTEAFF]NBLIG-1
    If [M:PTEAFF]STDQTY(NI) > [M:PTEAFF]CSMQTY(NI) Then
      Chgstl [M:PTEAFF]CSMQTY(NI) With "BACKGREEN"
    Elsif [M:PTEAFF]STDQTY(NI) < [M:PTEAFF]CSMQTY(NI) Then
      Chgstl [M:PTEAFF]CSMQTY(NI) With "BACKRED"
    Endif
  Next NI
End

###################################################################################################
Subprog DISABLE_BUDGET()

Local Integer NI

  Affzo [M:PTED]5
  For NI = 0 To [M:PTED]NBLIG-1
    If [M:PTED]TASCOD(NI) <> AVOID.ACHAR Then
      Diszo [M:PTED]PBUCOD(NI)
    Else
      Actzo [M:PTED]PBUCOD(NI)
    Endif
  Next NI
End

###################################################################################################
Funprog GET_KEYCONCAT_SCREEN_PJMTIMD()

Local Char SARENDRE(250)

  #SARENDRE = func PJMTIMEMP_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PTEH]CLB, [M:PTED]OPPNUM(nolign-1), [M:PTED]PTEDAT(nolign-1), [M:PTED]PTESEQ(nolign-1)) # Issue X3-69372 - 2018-04-18 by SINGC
  SARENDRE = func PJMTIMEMP_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PTEH]CLB, [M:PTED]PTESEQ(nolign-1))                                                      # Issue X3-69372 - 2018-04-18 by SINGC
End SARENDRE

###################################################################################################
Funprog FMD2(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)
Local Char SPREFIX(1)

  # Manage the MD2 format as show or not for the 2 DCB fields
  If [F:PAUS]PAUS <> GUSER Then
    Read [PAUS]PAUS=GUSER
  Endif
  If [F:TCU]CUR <> [M:PTED]CUR(INDEX) Then
    Read [TCU]TCU0=[M:PTED]CUR(INDEX)
  Endif
  Raz SPREFIX
  If [F:PAUS]PAUSPA <> [V]CST_AYES and [F:PAUS]PAUSTT = [V]CST_AYES Then
    # Hide the amount
    SPREFIX = "-"
  Endif
  SARENDRE = SPREFIX + "N3zF:" + [F:TCU]CURFMT2
End SARENDRE

###################################################################################################
Subprog CALC_TOTAL_QTY()

Local Integer NI
Local Integer CURRENT_WEEK
Local Integer CURRENT_MONTH
Local Integer CURRENT_YEAR
Local Decimal DQTY
Local Decimal TOTALQTY
Local Decimal TOTALDAILY
Local Decimal TOTALWEEKLY
Local Decimal TOTALMONTHLY
Local Char STIMUOM(GLONUOM)
Local Char SFCY(GLONFCY)

  SFCY = func OPPOR_CSTD_PROGS_COM.GET_DEF_SITE_PROFIL(GACTX, 9)
  STIMUOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, SFCY, "UNITWORK")
  [M:PTEH]TIMU  = STIMUOM
  CURRENT_WEEK  = week(date$)
  CURRENT_MONTH = month(date$)
  CURRENT_YEAR  = year(date$)
  Affzo [M:PTED]5
  For NI = 0 To [M:PTED]NBLIG-1
    If [M:PTED]PTEUOM(NI) <> STIMUOM Then
      DQTY = [M:PTED]PTEQTY(NI)
      Call CONVERT_QTY(GZINSPJMTH.ACTX, [M:PTED]PTEUOM(NI), STIMUOM, DQTY) From TRTX3_SYRA
      # Calculate totals
      TOTALQTY += DQTY
      If CURRENT_YEAR = year([M:PTED]PTEDAT(NI)) Then
        # Calculate daily total
        If [M:PTED]PTEDAT(NI) = date$ Then
          TOTALDAILY += DQTY
        Endif
        # Calculate weekly total
        If CURRENT_WEEK = week([M:PTED]PTEDAT(NI)) Then
          TOTALWEEKLY += DQTY
        Endif
        # Calculate monthly total
        If CURRENT_MONTH = month([M:PTED]PTEDAT(NI)) Then
          TOTALMONTHLY += DQTY
        Endif
      Endif
    Else
      # Calculate totals
      TOTALQTY += [M:PTED]PTEQTY(NI)
      If CURRENT_YEAR = year([M:PTED]PTEDAT(NI)) Then
        # Calculate daily total
        If [M:PTED]PTEDAT(NI) = date$ Then
          TOTALDAILY += [M:PTED]PTEQTY(NI)
        Endif
        # Calculate weekly total
        If CURRENT_WEEK = week([M:PTED]PTEDAT(NI)) Then
          TOTALWEEKLY += [M:PTED]PTEQTY(NI)
        Endif
        # Calculate monthly total
        If CURRENT_MONTH = month([M:PTED]PTEDAT(NI)) Then
          TOTALMONTHLY += [M:PTED]PTEQTY(NI)
        Endif
      Endif
    Endif
  Next NI
  [M:PTEH]PTETOT = TOTALQTY
  [M:PTEH]TODAY  = TOTALDAILY
  [M:PTEH]TWEEK  = TOTALWEEKLY
  [M:PTEH]PTEMON = TOTALMONTHLY
End

###################################################################################################
Subprog CALC_TOTAL_LOADS()

Local Integer NI

  Local File PIMPL     [PIM]
  Local File PJMOPEAFF [PJOA]
  # -------------------------------
  Affzo [M:PTED]5
  For NI = 0 To [M:PTED]NBLIG-1
    If [M:PTED]OPENUM(NI) <> 0 Then
      Read [PIM]PIM0=[M:PTED]PIMTASCOD(NI)
      Filter [PJOA] Where OPPNUM = [F:PIM]OPPNUM and TASCOD = [F:PIM]TASCOD and OPENUM = [M:PTED]OPENUM((NI)) and OPESPLNUM = [M:PTED]OPESPLNUM((NI)) and POACLB = [M:PTEH]CLB
      For [PJOA]
        [M:PTED]POANUM(NI) = [F:PJOA]POANUM
        [M:PTED]STDQTY(NI) = [F:PJOA]POASTDQTY
        [M:PTED]CSMQTY(NI) = [F:PJOA]POACSMQTY
        [M:PTED]RMNQTY(NI) = [F:PJOA]POARMNQTY
        [M:PTED]POUOM(NI)  = [F:PJOA]POUOM
        Break
      Next
      Filter [PJOA]
      If [M:PTED]POANUM(NI) = 0 Then
        Read [PTKO]PTKO0 = [F:PIM]OPPNUM;[F:PIM]TASCOD;[M:PTED]OPENUM((NI));[M:PTED]OPESPLNUM((NI))
        [M:PTED]STDQTY(NI) = [F:PTKO]EXTQTY
        [M:PTED]CSMQTY(NI) = [F:PTKO]CSMQTY
        [M:PTED]RMNQTY(NI) = [F:PTKO]RMNQTY
        [M:PTED]POUOM(NI)  = [F:PTKO]OPEUOM2
      Endif
    Endif
  Next NI
End

