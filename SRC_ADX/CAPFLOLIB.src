#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
######################################################################################
Subprog AS_CAPFLOTYP(VALEUR)
Variable Char VALEUR

#Called in SUBGA0 to control if the CAPFLOTYP field should be available or not depending on the account
#only available for accounts with prefix defined in miscellaneous table 390 and periods rather than 0

Gosub SET_CFT_VAR # declare and set variables for capital flow controls (main general ledger account entered)

If [L]INDLEG <> 0
    Case [M:HAEF]TYPENT
        When 1 
            Gosub IS_CFT_ACC                # check if entered account is a eligible account (it's referenced on 390 miscellaneous table) 
        When 2
            If [M]LEDTYP(nolign-1)=GTYPGEN  # check if entered account is a eligible account (it's referenced on 390 miscellaneous table) 
                Gosub IS_CFT_ACC 
            Endif
    Endcase
Endif

If !K | [F:GTE]PER=2 # if it's not, or period it's 0, the user cannot enter the field
    mkstat = 2 
    VALEUR = "" 
    End
Endif 

End
######################################################################################
######################################################################################
$SET_CFT_VAR

Local Integer I, K, INDLEG, MAXCOL
Local Char    ACCPREF(GLONGAC), ACCLEG(GLONGAC)

[L]K      = 0
[L]MAXCOL = 11  # the report has 11 columns

Case [M:HAEF]TYPENT
    When 1 
        [L]INDLEG = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
        If [L]INDLEG <> 0
            [L]ACCLEG = evalue("[M]ACC"+num$(INDLEG)+"("+num$(nolign-1)+")")
        Endif
    When 2
        If [M]LEDTYP(nolign-1)=GTYPGEN
            [L]INDLEG = 1 
            [L]ACCLEG = [M]ACC1(nolign-1) 
        Endif
Endcase

Return
######################################################################################
######################################################################################
$IS_CFT_ACC

For [L]I = 1 To [L]MAXCOL

#    [L]ACCPREF = func AFNC.INTFLD("ATABDIV","A1","390~"+num$(I))
    [L]ACCPREF = func CAPFLOLIB.GETACCPREADI(format$("N0:2",[L]I),GCURLEG)

    If [L]ACCPREF <> ""
        If pat([M]ACC1(nolign-1),[L]ACCPREF+"*") = 1 : [L]K = 1 : Break : Endif
    Endif

Next

Return
######################################################################################
######################################################################################
Subprog C_CAPFLOTYP(VALEUR)
Variable Char VALEUR

#Called in SUBGA0 to control if the CAPFLOTYP field should be mandatory or not depending on the account
#it's mandatory for accounts with prefix defined in miscellaneous table 390

If VALEUR <> ""
    End
Endif

Gosub SET_CFT_VAR # declare and set variables for capital flow controls (main general ledger account entered)

If [L]INDLEG<>0
    Case [M:HAEF]TYPENT
        When 1 
            Gosub IS_CFT_ACC                # check if entered account is a eligible account (it's referenced on 390 miscellaneous table) 
        When 2
            If [M]LEDTYP(nolign-1)=GTYPGEN  # check if entered account is a eligible account (it's referenced on 390 miscellaneous table) 
                Gosub IS_CFT_ACC 
            Endif
    Endcase
Endif

If K & [F:GTE]PER<>2  # if it is, field is mandatory
    mkstat   = 2 
    GMESSAGE = mess(10,123,1) 
Endif 

End
######################################################################################
######################################################################################
$FIELD_GDE

#Called in SUBGDE to include the new CAPFLOTYP field description in journal entries transactions
If func AFNC.ACTIV("KPO")  
  I += 1 : [M:GDE3]FLD(I) = "CAPFLOTYP"  : [M:GDE3]FLDDES(I) = mess(212,105,1) : # Capital flow
Endif

Return
######################################################################################
######################################################################################
$UPD_HAEW

#Called in SUBGASB to include the new CAPFLOTYP field in GACCENT2
If dim([M]CAPFLOTYP) > 0
  [M:HAEW]CAPFLOTYP(NBLIN)    = [M]CAPFLOTYP(NOL)
Endif

Return
######################################################################################
######################################################################################
Funprog GETACCPREADI(COLUMN,LEG)
Value Char COLUMN
Value Char LEG

#Gets the value of account prefix for a given column (ADI 390)
#Called also in PCAPFLO
Local File ATABDIV [ADI] 
Local Char RETVAL  (250) : RETVAL = ""

Filter [F:ADI] Where [F:ADI]NUMTAB = 390 & [F:ADI]CODE = COLUMN & [F:ADI]LEG = [L]LEG
Read [F:ADI] First
If !fstat
    RETVAL  = [F:ADI]A1
Endif
Filter [F:ADI]

End RETVAL
######################################################################################
######################################################################################


