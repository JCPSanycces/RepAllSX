#<AdxTL>@(#)0.0.0.0 $Revision$

#**
#* Find or create numero of text
#*
#* @param VALEUR
#* @param NUM
#*!
Subprog NUMBER(VALEUR,NUM,WCLA)
Value    Char    VALEUR
Variable Integer NUM
Variable Instance WCLA Using OBJECT

Local Integer PREM , DERN , NOLAN ,ASTATUS
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
If VALEUR="" : NUM = 0 : End : Endif
If dim(WCLA.ACTX.LAN)<0 or WCLA.ACTX.LAN="" : NUM = 0 : End : Endif
Read [ATX]TEXTE = WCLA.ACTX.LAN;VALEUR
If fstat=0
 NUM = [F:ATX]NUMERO
Else
 If !adxlog
  Gosub TR_NUM
 Else
  Gosub MAJ_NUM
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : NUM=0 : Endif
Endif
End

$TR_NUM
[L]ASTATUS = 0
Trbegin [ATX]
 Gosub MAJ_NUM
 If [L]ASTATUS>=[V]CST_AERROR: Goto AB_TR_NUM : Endif
Commit
Return

$AB_TR_NUM
Rollback
Return

$MAJ_NUM
Local Char MESSAGE(250)
Local Integer PRODUIT
Lock [ATX]
If fstat
 [L]ASTATUS=[V]CST_AERROR  : Return : # G LOCK = "$ATEXTE" todo
Endif
If dim([V]GADONIX)>0 & GADONIX<>2
 PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
Else
 PREM = 0 : DERN = GMAXTXTSTD
Endif
If dim([F:ATX]LANORI)>0
 Gosub SET_TBLAN
Endif
If DERN = GMAXTXTSTD & fmet WCLA.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,WCLA.ACTX.AFOLDER,"ATXTSRV")=2 :#115210/6
 PRODUIT=fmet WCLA.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,WCLA.ACTX.AFOLDER,"TYPDOS")-1
 [L]ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(PRODUIT,WCLA.ACTX.LAN,TBLAN,VALEUR, "",NUM,MESSAGE)
 If [L]ASTATUS<>[V]CST_AOK
  [L]ASTATUS = fmet WCLA.ASETERROR(MESSAGE,[V]CST_AERROR)
  Return
 Endif
Else
 Filter [ATX] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
 Read [ATX] Last
 Filter [ATX]
 If fstat : NUM = PREM+1 : Else : NUM = [F:ATX]NUMERO+1 : Endif
Endif
Raz [F:ATX]
[F:ATX]NUMERO = NUM
[F:ATX]TEXTE  = VALEUR
[F:ATX]LONG   = 30
[F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
[F:ATX]LAN = WCLA.ACTX.LAN
# 100735
[F:ATX]CREUSR = WCLA.ACTX.USER
[F:ATX]CREDAT = date$
[F:ATX]CREDATTIM = datetime$
[F:ATX]AUUID = getUuid
Write [ATX]
If fstat
 Call FSTA("ATX",WCLA,[L]ASTATUS) From ASYRSUB
Endif
If dim([F:ATX]LANORI)>0
 For NOLAN=1 To NBLAN
  Readlock [ATX]NUMERO = TBLAN(NOLAN);NUM
  If fstat
   Read [ATX]NUMERO = WCLA.ACTX.LAN;NUM
   [F:ATX]LAN = TBLAN(NOLAN)
   [F:ATX]LANORI = WCLA.ACTX.LAN
   Write [ATX]
   If fstat
    Call FSTA("ATX",WCLA,[L]ASTATUS) From ASYRSUB
   Endif
  Elsif !fstat & [F:ATX]LANORI<>""
   [F:ATX]TEXTE = VALEUR
   [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
   [F:ATX]LANORI = WCLA.ACTX.LAN
   # 100735
   [F:ATX]UPDUSR = WCLA.ACTX.USER
   [F:ATX]UPDDAT = date$
   [F:ATX]UPDDATTIM = datetime$
   [F:ATX]AUUID =   getUuid
   Rewrite [ATX]
   If fstat
    Call FSTA("ATX",WCLA,[L]ASTATUS) From ASYRSUB : Break
   Endif
  Endif
 Next NOLAN
 If [L]ASTATUS=0 : Return : Endif
Endif
Return

$SET_TBLAN
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN
Raz NBLAN , TBLAN
For [ATX]NUMERO(1) Where LAN<>"" & LAN<>"XXX" & LAN<>WCLA.ACTX.LAN & NUMERO<100
 NBLAN += 1
 TBLAN(NBLAN) = [F:ATX]LAN
Next ATX
Return

#109897
Funprog NEED_PRIMARY_SERVER(TASK,FCT)
Value Char TASK,FCT
If FCT<>"" & find(FCT,
& "ADSVAL",
& "GESADS",
& "CREHISTO",
& "APATCH",
& "APATCHA",
& "PATCH",
& "ABICREUNV",
& "ABIVALBAS",
& "ABIVALTOT",
& "ABIMAJBAS",
& "ABIMOVETA")
 End 2
Endif
If TASK<>"" & find(TASK,"ZZVPOMAIN") & GACTX.AFOLDER="SUPERV" : #VVVVV
 End 2
Endif
End 1

