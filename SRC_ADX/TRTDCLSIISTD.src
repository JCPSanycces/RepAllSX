  If VALEUR <>2
    Actzo [M:DSII]VCRSTA
  Else
    Grizo [M:DSII]VCRSTA
  Endif
  GMODCRI=1
  Affzo [M:DSII]VCRSTA
End

##################################################
Subprog AM_ALLCOM(VALEUR)
Variable Integer    VALEUR()
  If VALEUR <>2
    Actzo [M:DSII]TYPCOM
  Else
    Grizo [M:DSII]TYPCOM
  Endif
  GMODCRI=1
  Affzo [M:DSII]TYPCOM
End

##################################################
Subprog AS_TYPCOM(VALEUR)
Variable Integer   VALEUR()
  If [M:DSII]ALLCOM=2: Grizo [M:DSII]TYPCOM: Else Actzo [M:DSII]TYPCOM Endif
  Affzo [M:DSII]TYPCOM
End

