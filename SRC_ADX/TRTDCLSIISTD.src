          For K=0 To [M:DSII7]NBLIGM-1
            If [M:DSII7]STADOC(K)=1: [M:DSII7]FLGSEL(K)=1: Endif
          Next
          Affzo [M:DSII7]1-99
        When 8: #Bienes consigna DAFER X3-212589 11-11-2020
          For K=0 To [M:DSIIBC]NBLIGBC-1
            If [M:DSIIBC]STADOC(K)=1: [M:DSIIBC]FLGSEL(K)=1: Endif
          Next
          Affzo [M:DSIIBC]1-99
      Endcase
    Next
  Endif
End

##################################################
Subprog NIFNOCEN
  Local Integer YESNO, I, K
  WMSG=mess(17,2124,1) #¿Quiere reactivar los registros rechazados de los NIF de clientes no censados?\Reactivate the rejected records of unregistered customers?
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Local File DCLSII [DSIIX]
    Trbegin  [DSIIX]
    For K=0 To [M:DSII1]NBLIG-1
      If [M:DSII1]VCRSTA(K)=4
        Case [M:DSII1]VCRERRNUM(K)
          When "1116", "1117"
            If [M:DSII1]CRY(K)="ES" and (val([M:DSII1]NIP(K))>0 or mid$([M:DSII1]NIP(K),1,1)='X' or mid$([M:DSII1]NIP(K),1,1)='Y'
&             or mid$([M:DSII1]NIP(K),1,1)='Z' or mid$([M:DSII1]NIP(K),1,1)='M')
              [M:DSII1]FLGSEL(K)=2
              [M:DSII1]STADOC(K)=1
              [M:DSII1]VCRSTA(K)=1
              [M:DSII1]TYPCOM(K)=1
              [M:DSII1]FLGNIFREC(K)=2
            Endif
        Endcase
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSIIX]DSII0=[M:DSII]CPY;1;[M:DSII1]GTE(K);[M:DSII1]VCRNUM(K);1
        Else
          Read [DSIIX]DSII2=[M:DSII]CPY;[M:DSII]FCY;1;[M:DSII1]GTE(K);[M:DSII1]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK:
          [F:DSIIX]FLGSEL=[M:DSII1]FLGSEL(K)
          [F:DSIIX]STADOC=[M:DSII1]STADOC(K)
          [F:DSIIX]VCRSTA=[M:DSII1]VCRSTA(K)
          [F:DSIIX]TYPCOM=[M:DSII1]TYPCOM(K)
          [F:DSIIX]FLGNIFREC=[M:DSII1]FLGNIFREC(K)
          Rewrite
        Endif
      Else
        [M:DSII1]FLGNIFREC(K)=1
      Endif
    Next
    Affzo [M:DSII1]1-99

    For K=0 To [M:DSII7]NBLIGM-1
      If [M:DSII7]VCRSTA(K)=4
        Case [M:DSII7]VCRERRNUM(K)
          When "1116", "1117"
            If [M:DSII7]CRY(K)="ES" and (val([M:DSII7]NIP(K))>0 or mid$([M:DSII7]NIP(K),1,1)='X' or mid$([M:DSII7]NIP(K),1,1)='Y'
&             or mid$([M:DSII1]NIP(K),1,1)='Z' or mid$([M:DSII1]NIP(K),1,1)='M')
              [M:DSII7]FLGSEL(K)=2
              [M:DSII7]STADOC(K)=1
              [M:DSII7]VCRSTA(K)=1
              [M:DSII7]TYPCOM(K)=1
              [M:DSII7]FLGNIFREC(K)=2
            Endif
        Endcase
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSIIX]DSII0=[M:DSII]CPY;1;[M:DSII7]GTE(K);[M:DSII7]VCRNUM(K);1
        Else
          Read [DSIIX]DSII2=[M:DSII]CPY;[M:DSII]FCY;1;[M:DSII7]GTE(K);[M:DSII7]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK:
          [F:DSIIX]FLGSEL=[M:DSII7]FLGSEL(K)
          [F:DSIIX]STADOC=[M:DSII7]STADOC(K)
          [F:DSIIX]VCRSTA=[M:DSII7]VCRSTA(K)
          [F:DSIIX]TYPCOM=[M:DSII7]TYPCOM(K)
          [F:DSIIX]FLGNIFREC=[M:DSII7]FLGNIFREC(K)
          Rewrite
        Endif
      Else
        [M:DSII7]FLGNIFREC(K)=1
      Endif
    Next
    Commit
    Affzo [M:DSII7]1-99

    Close File [DSIIX]
  Endif
End

##################################################
Subprog REACT_ALL
  Local Integer YESNO, I, K
  WMSG=mess(18,2124,1) #¿Quiere reactivar los registros de este error?\Reactivate the records of this error?
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Local File DCLSII [DSII]
    Trbegin  [DSII]
    #Emitidas
    For K=0 To [M:DSII1]NBLIG-1
      If [M:DSII1]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII1]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII1]FLGSEL(K)=2
        [M:DSII1]STADOC(K)=1
        [M:DSII1]FLGNIFREC=1
        If [M:DSII1]VCRSTA(K)=3
          [M:DSII1]TYPCOM(K)=2
        Else
          [M:DSII1]TYPCOM(K)=1
        Endif
        [M:DSII1]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;1;[M:DSII1]GTE(K);[M:DSII1]VCRNUM(K);1
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;1;[M:DSII1]GTE(K);[M:DSII1]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII1]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII1]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII1]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII1]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII1]1-99

    #Recibidas
    For K=0 To [M:DSII2]NBLIGR-1
      If [M:DSII2]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII2]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII2]FLGSEL(K)=2
        [M:DSII2]STADOC(K)=1
        If [M:DSII2]VCRSTA(K)=3
          [M:DSII2]TYPCOM(K)=2
        Else
          [M:DSII2]TYPCOM(K)=1
        Endif
        [M:DSII2]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;2;[M:DSII2]GTE(K);[M:DSII2]VCRNUM(K);1
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;2;[M:DSII2]GTE(K);[M:DSII2]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII2]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII2]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII2]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII2]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII2]1-99

    #Operaciones CEE
    For K=0 To [M:DSII3]NBLIGC-1
      If [M:DSII3]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII3]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII3]FLGSEL(K)=2
        [M:DSII3]STADOC(K)=1
        If [M:DSII3]VCRSTA(K)=3
          [M:DSII3]TYPCOM(K)=2
        Else
          [M:DSII3]TYPCOM(K)=1
        Endif
        [M:DSII3]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;3;[M:DSII3]GTE(K);[M:DSII3]VCRNUM(K);1
        Else
          Read [DSII]DSII2=[M:DSII]CPY;3;[M:DSII3]GTE(K);[M:DSII3]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII3]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII3]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII3]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII3]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII3]1-99

    #Inmovilizado
    For K=0 To [M:DSII4]NBLIGI-1
      If [M:DSII4]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII4]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII4]FLGSEL(K)=2
        [M:DSII4]STADOC(K)=1
        If [M:DSII4]VCRSTA(K)=3
          [M:DSII4]TYPCOM(K)=2
        Else
          [M:DSII4]TYPCOM(K)=1
        Endif
        [M:DSII4]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;4;[M:DSII4]GTE(K);[M:DSII4]VCRNUM(K);1
         Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;4;[M:DSII4]GTE(K);[M:DSII4]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII4]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII4]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII4]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII4]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII4]1-99

    #Cobros caja
    For K=0 To [M:DSII5]NBLIGCA-1
      If [M:DSII5]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII5]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII5]FLGSEL(K)=2
        [M:DSII5]STADOC(K)=1
        If [M:DSII5]VCRSTA(K)=3
          [M:DSII5]TYPCOM(K)=2
        Else
          [M:DSII5]TYPCOM(K)=1
        Endif
        [M:DSII5]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;5;[M:DSII5]GTE(K);[M:DSII5]VCRNUM(K);[M:DSII5]VCRLIN(K)
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;5;[M:DSII5]GTE(K);[M:DSII5]VCRNUM(K);[M:DSII5]VCRLIN(K)
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII5]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII5]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII5]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII5]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII5]1-99

    #Pagos caja
    For K=0 To [M:DSII6]NBLIGPA-1
      If [M:DSII6]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII6]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII6]FLGSEL(K)=2
        [M:DSII6]STADOC(K)=1
        If [M:DCII6]VCRSTA(K)=3
          [M:DSII6]TYPCOM(K)=2
        Else
          [M:DSII6]TYPCOM(K)=1
        Endif
        [M:DSII6]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;6;[M:DSII6]GTE(K);[M:DSII6]VCRNUM(K);[M:DSII6]VCRLIN(K)
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;6;[M:DSII6]GTE(K);[M:DSII6]VCRNUM(K);[M:DSII6]VCRLIN(K)
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII6]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII6]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII6]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII6]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII6]1-99

    #Operaciones anuales
    For K=0 To [M:DSII7]NBLIGM-1
      If [M:DSII7]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSII7]VCRERRNUM(K), VCRERRDES(K)
        [M:DSII7]FLGSEL(K)=2
        [M:DSII7]STADOC(K)=1
        [M:DSII7]FLGNIFREC=1
        If [M:DSII7]VCRSTA(K)=3
          [M:DSII7]TYPCOM(K)=2
        Else
          [M:DSII7]TYPCOM(K)=1
        Endif
        [M:DSII7]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;7;[M:DSII7]GTE(K)+[M:DSII7]VCRNUM(K);1
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;7;[M:DSII7]GTE(K);[M:DSII7]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSII7]FLGSEL(K)
          [F:DSII]STADOC=[M:DSII7]STADOC(K)
          [F:DSII]VCRSTA=[M:DSII7]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSII7]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSII7]1-99

    #Bienes consigna DAFER X3-212589 11-11-2020
    For K=0 To [M:DSIIBC]NBLIGBC-1
      If [M:DSIIBC]VCRERRNUM(K)=[M:DSII]VCRERRNUM
        Raz [M:DSIIBC]VCRERRNUM(K), VCRERRDES(K)
        [M:DSIIBC]FLGSEL(K)=2
        [M:DSIIBC]STADOC(K)=1
        If [M:DSIIBC]VCRSTA(K)=3
          [M:DSIIBC]TYPCOM(K)=2
        Else
          [M:DSIIBC]TYPCOM(K)=1
        Endif
        [M:DSIIBC]VCRSTA(K)=1
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [DSII]DSII0=[M:DSII]CPY;3;[M:DSIIBC]GTE(K);[M:DSIIBC]VCRNUM(K);1
        Else
          Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;3;[M:DSIIBC]GTE(K);[M:DSIIBC]VCRNUM(K);1
        Endif
        If fstat=[V]CST_AOK
          Raz [F:DSII]VCRERRNUM, VCRERRDES
          [F:DSII]FLGSEL=[M:DSIIBC]FLGSEL(K)
          [F:DSII]STADOC=[M:DSIIBC]STADOC(K)
          [F:DSII]VCRSTA=[M:DSIIBC]VCRSTA(K)
          [F:DSII]TYPCOM=[M:DSIIBC]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:DSIIBC]1-99
    Commit
    Close File [DSII]
  Endif
End

######################################################################################
$REV_CLAVEOPEMET
  Local Integer NBDIM

  NBDIM=max(nolign,[M:DSII7]NBLIGM)

  For I=0 To NBDIM-1
    If [M:DSII7]VCRNUM(nolign-1)=[M:DSII7]VCRNUM(I): J+=1: Endif
    If J>2: Break: Endif
  Next

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla DCLSII1) 25/01/2017 15:15:49 (ADMIN)
######################################################################################
Subprog IB_NBLIG
  Local Integer NOL : NOL = nolign-1
  GBOUT1=mess(145,117,1)
  Case maskcou
    When "DCLSII1"
      If [M:DSII1]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:DSII1]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII1]STADOC(NOL)<>1 and [M:DSII1]VCRNUM(NOL)<>"": Grizo [M:DSII1]FLGSEL(NOL) Endif
    When "DCLSII2"
      If [M:DSII2]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:DSII2]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII2]STADOC(NOL)<>1 and [M:DSII2]VCRNUM(NOL)<>"": Grizo [M:DSII2]FLGSEL(NOL) Endif
    When "DCLSII3"
      If [M:DSII3]VCRNUM(NOL)="":  Raz GBOUT1, GBOUT2, GBOUT3
        Actzo [M:DSII3]GTE(NOL): Actzo [M:DSII3]VCRNUM(NOL)
        Affzo [M:DSII3]GTE(NOL): Affzo [M:DSII3]VCRNUM(NOL)
      Endif
      If [M:DSII3]GTE(NOL)="": Raz GBOUT1: Endif
      If [M:DSII3]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII3]STADOC(NOL)<>1 and [M:DSII3]VCRNUM(NOL)<>"": Grizo [M:DSII3]FLGSEL(NOL), GTE(NOL), VCRNUM(NOL): Endif
    When "DCLSII4"
      If [M:DSII4]VCRNUM(NOL)=""  Raz GBOUT1, GBOUT2, GBOUT3
        Actzo [M:DSII4]GTE(NOL): Actzo [M:DSII4]VCRNUM(NOL)
        Affzo [M:DSII4]GTE(NOL): Affzo [M:DSII4]VCRNUM(NOL)
      Endif
      If [M:DSII4]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII4]STADOC(NOL)<>1 and GSIIEXTAP=1 and [M:DSII4]VCRNUM(NOL)<>"": Grizo [M:DSII4]FLGSEL(NOL),GTE(NOL), VCRNUM(NOL): Endif
    When "DCLSII5"
      If [M:DSII5]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:DSII5]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII5]STADOC(NOL)<>1 and [M:DSII5]VCRNUM(NOL)<>"": Grizo [M:DSII5]FLGSEL(NOL) Endif
    When "DCLSII6"
      If [M:DSII6]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:DSII6]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII6]STADOC(NOL)<>1 and [M:DSII6]VCRNUM(NOL)<>"": Grizo [M:DSII6]FLGSEL(NOL) Endif
    When "DCLSII7"
      Raz GBOUT1
      If [M:DSII7]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSII7]STADOC(NOL)<>1 and [M:DSII7]VCRNUM(NOL)<>"": Grizo [M:DSII7]FLGSEL(NOL) Endif
      If GSIIEXTAP=2 and [M:DSII7]VCRERRNUM(nolign-1)="" and [M:DSII7]NBLIGM=0
        Grizo [M:DSII7]NBLIGM
      Endif
    When "DCLSIIBC" # Bienes consigna DAFER X3-212589 11-11-2020
      If [M:DSIIBC]VCRNUM(NOL)="":  Raz GBOUT1, GBOUT2, GBOUT3
        Actzo [M:DSIIBC]GTE(NOL): Actzo [M:DSIIBC]VCRNUM(NOL)
        Affzo [M:DSIIBC]GTE(NOL): Affzo [M:DSIIBC]VCRNUM(NOL)
      Endif
      If [M:DSIIBC]GTE(NOL)="": Raz GBOUT1: Endif
      If [M:DSIIBC]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:DSIIBC]STADOC(NOL)<>1 and [M:DSIIBC]VCRNUM(NOL)<>"": Grizo [M:DSIIBC]FLGSEL(NOL), GTE(NOL), VCRNUM(NOL): Endif
  Endcase
  If GSIIEXTAP=2: Raz GBOUT1: Endif
End

