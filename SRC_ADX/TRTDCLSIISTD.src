Subprog AM_TYPCOM(VALEUR)
Variable Integer    VALEUR()
  If VALEUR <>[M:DSII]TYPCOM
    GMODCRI=1
  Endif
End

##################################################
Subprog AM_FLGSEL(VALEUR)
Variable Integer VALEUR()
Local Integer NOL: NOL=nolign-1

  Case maskcou
    When "DCLSII2"
      If [M:DSII2]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:DSII2]FLGSEL(NOL)=1
        Affzo [M:DSII2]FLGSEL(NOL)
        GMESSAGE=mess(3,2124,1) #Número de factura proveedor vacío. Use la opción de mofificación para alimentarlo
        mkstat=2                #Empty invoice number. Use the modification option to update it.
      Endif
    When "DCLSII4"
      If [M:DSII4]VCRNUM(NOL)<>"" and [M:DSII4]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:DSII4]FLGSEL(NOL)=1
        Affzo [M:DSII4]FLGSEL(NOL)
        GMESSAGE=mess(3,2124,1) #Número de factura proveedor vacío. Use la opción de mofificación para alimentarlo"
        mkstat=2                #Empty invoice number. Use the modification option to update it.
      Endif
    When "DCLSII6"
      If [M:DSII6]VCRNUM(NOL)<>"" and [M:DSII6]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:DSII6]FLGSEL(NOL)=1
        Affzo [M:DSII6]FLGSEL(NOL)
        GMESSAGE=mess(4,2124,1) #Documento origen vacío. Use la opción de mofificación para alimentarlo"
        mkstat=2                #Empty source document number. Use the update it.
      Endif
   Endcase
End

##################################################
Subprog AM_BPR(VALEUR)
Variable Char   VALEUR()
  Local Integer I, J, NOL: NOL=nolign-1
  Local Char WNIP(60)
  Local File BPARTNER [BPR]

  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    If maskcou="DCLSII7"
      Read [BPR]BPR0=VALEUR
      If fstat=[V]CST_AOK
        [M:DSII7]NIP(NOL)   =[F:BPR]CRN
        [M:DSII7]BPRNAM(NOL)=[F:BPR]BPRNAM
        [M:DSII7]CRY(NOL)   =[F:BPR]CRY
        [M:DSII7]VCRNUM(NOL)=[F:BPR]CRN+"-"+num$(year([M:DSII]DATINI))+"-"+[M:DSII7]TYPANUAL(NOL)+[M:DSII7]CLAVEOPE(NOL)

        Affzo [M:DSII7]VCRNUM(NOL),NIP(NOL),BPRNAM(NOL), CRY(NOL)
      Endif
      If NOL>0 and [M:DSII7]TYPANUAL(NOL)<>"M"
        WNIP=[M:DSII7]NIP(NOL)
        Gosub REV_CLAVEOPEMET
        If J>1
          Raz [M:DSII7]NIP(NOL), [M:DSII7]BPRNAM(NOL)
          GMESSAGE=mess(6,2124,1) #Tercero ya existe para este tipo de operación\This BP already exists for this operation type.
          Affzo [M:DSII7]NIP(NOL), BPRNAM(NOL)
          mkstat=2: End
        Endif
      Endif
    Elsif maskcou="DCLSII3"
      Read [BPR]BPR0=VALEUR
      If fstat=[V]CST_AOK
        [M:DSII3]NIP(NOL)   =[F:BPR]CRN
        [M:DSII3]BPRNAM(NOL)=[F:BPR]BPRNAM
        [M:DSII3]CRY(NOL)   =[F:BPR]CRY
        Affzo [M:DSII3]NIP(NOL),BPRNAM(NOL), CRY(NOL)
      Endif
    Elsif maskcou="DCLSIIBC" #Bienes consigna DAFER X3-212589 11-11-2020
      Read [BPR]BPR0=VALEUR
      If fstat=[V]CST_AOK
        [M:DSIIBC]NIP(NOL)   =[F:BPR]CRN
        [M:DSIIBC]BPRNAM(NOL)=[F:BPR]BPRNAM
        [M:DSIIBC]CRY(NOL)   =[F:BPR]CRY
        Affzo [M:DSIIBC]NIP(NOL),BPRNAM(NOL), CRY(NOL)
      Endif
    Endif
  Endif
  Close File [BPR]
End

##################################################
Subprog C_NIP(VALEUR)
Variable Char   VALEUR()
  Local Integer J, NOL: NOL=nolign-1
  Local Char WNIP(60)

  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    [M:DSII7]VCRNUM(NOL)=VALEUR+"-"+num$(year([M:DSII]DATINI))+"-"+[M:DSII7]TYPANUAL(NOL)+[M:DSII7]CLAVEOPE(NOL)
    If [M:DSII7]TYPANUAL(NOL)<>"M"
      WNIP=VALEUR
      Gosub REV_CLAVEOPEMET
      If J>1
        GMESSAGE=mess(6,2124,1) #Tercero ya existe para este tipo de operación"
        mkstat=2: End           #This BP already exists for this operation type.'
      Endif
    Endif

    Local File BPARTNER [BPR]
    Filter [BPR] Where CRN=VALEUR
    Read [BPR]BPR0 First
    If fstat=[V]CST_AOK
      [M:DSII7]BPRNAM(NOL)=[F:BPR]BPRNAM
      [M:DSII7]CRY(NOL)   =[F:BPR]CRY
      Affzo [M:DSII7]BPRNAM(NOL), CRY(NOL)
    Endif
    Affzo [M:DSII7]VCRNUM(NOL)
    Close File [BPR]
  Endif

End

##################################################
Subprog AM_NIP(VALEUR)
Variable Char   VALEUR()
  Local Integer J, NOL: NOL=nolign-1
  Local Char WNIP(60)

  If VALEUR<>"" and [M:DSII7]NIP(NOL)<>"" and [M:DSII7]AMTATI(NOL)<>0 : Gosub DEL_SEGURO: Endif
End

##################################################
Subprog S_VCRNUM(VALEUR)
Variable Char  VALEUR()

  If [M:DSII4]GTE(nolign-1)="": End: Endif

  Local Integer K, NBVCR, NOL: NOL=nolign-1
  Local Integer CHOICE: CHOICE=0
  Local Char    TEX(40)(1..,1..2),TIT(GLONDES)(0..2)

  Local File DCLSII [XYSII]
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Filter [XYSII] Where year(DATOPE)=year([M:DSII]DATINI) and TYPENV=2 and GTE=[M:DSII4]GTE(NOL)
  Else
    Filter [XYSII] Where year(DATOPE)=year([M:DSII]DATINI) and TYPENV=2 and GTE=[M:DSII4]GTE(NOL) and FCY=[M:DSII4]FCY(NOL)
  Endif
  For [XYSII]
    If [F:XYSII]BPRVCR<>""
      NBVCR += 1
      TEX(NBVCR,1) = mess(2,2115,1)
      TEX(NBVCR,2) = [F:XYSII]VCRNUM
    Endif
  Next

  TIT(0) = mess(8,31,1)       # Selección
  TIT(1) = mess(77,2124,1)  # Tipo libro
  TIT(2) = mess(2,176,1)      # Número documento

  If NBVCR > 0
    Call SAITEX_COL_MAX(NBVCR,TEX,CHOICE,TIT,80,50) From GESECRAN
    If status<>7 & CHOICE<>0
      VALEUR = TEX(CHOICE,2)
    Endif
  Else
    GMESSAGE=mess(7,2124,1)  #Esta factura no existe en el libro de facturas recibidas
    mkstat=2                  #This invoice does not exist in the received invoice book
  Endif
End

##################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char  VALEUR()
  Local Integer NOL: NOL=nolign-1
  Local Char WMSG(250)

  If VALEUR="": GMESSAGE=mess(472,192,1) #Valor obligatorio\mandatory value
    mkstat=2: End
  Endif

  J=find(VALEUR+"_"+num$(year([M:DSII]DATINI)),[M:DSII4]VCRNUM(0..[M:DSII4]NBLIGI-1))
  If J<>0
    GMESSAGE=mess(8,2124,1) #Ya existe registro para este año\A record already exists for this year.
    mkstat=2
    End
  Endif

  Local File DCLSII [XYSII]
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Read [XYSII]DSII0=[M:DSII]CPY;2;[M:DSII4]GTE(NOL);VALEUR;1
   Else
    Read [XYSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;2;[M:DSII4]GTE(NOL);VALEUR;1
  Endif
  If fstat=[V]CST_AOK
    Local Datetime WORIDAT, WDVSDAT
    # Alimentamos pantalla con los valores si existe
    [M:DSII4]FLGSEL(NOL)=2
    [M:DSII4]STADOC(NOL)=1
    [M:DSII4]TYPCOM(NOL)=1
    [M:DSII4]VCRNUM(NOL)=VALEUR+"_"+num$(year([M:DSII]DATINI))
    [M:DSII4]BPRVCR(NOL)=[F:XYSII]BPRVCR
    [M:DSII4]DATOPE(NOL)=[F:XYSII]DATOPE
    [M:DSII4]AMTATI(NOL)=[F:XYSII]AMTATI
    [M:DSII4]CUR(NOL)   ="EUR"
    [M:DSII4]BPR(NOL)   =[F:XYSII]BPR
    [M:DSII4]BPRNAM(NOL)=[F:XYSII]BPRNAM
    [M:DSII4]NIP(NOL)   =[F:XYSII]NIP
    [M:DSII4]CRY(NOL)   =[F:XYSII]CRY
    [M:DSII4]VCRSTA(NOL)=1
    [M:DSII4]VCRLIN(NOL)=1
    [M:DSII4]NBLIGI=NOL
    Affzo [M:DSII4]1-99
    WORIDAT=[F:XYSII]DATDVS
    WDVSDAT=[F:XYSII]DATVCRORI

    # creamos el nuevo tipo 4
    Trbegin [F:XYSII]
      [F:XYSII]CPY=[M:DSII]CPY
      [F:XYSII]FCY=[M:DSII]FCY  # X3-237572 SII Monitor by site by DAFER 2021-06-16
      [F:XYSII]STADOC=1
      [F:XYSII]TYPENV=4
      [F:XYSII]TYPCOM=1
      [F:XYSII]GTE   =[M:DSII4]GTE(NOL)
      [F:XYSII]VCRNUM=[M:DSII4]VCRNUM(NOL)
      [F:XYSII]VCRLIN=1
      [F:XYSII]VCRSTA=1
      [F:XYSII]DATOPE=[M:DSII4]DATOPE(NOL)
      [F:XYSII]BPRVCR=[M:DSII4]BPRVCR(NOL)
      [F:XYSII]AMTATI=[M:DSII4]AMTATI(NOL)
      [F:XYSII]BPR   =[M:DSII4]BPR(NOL)
      [F:XYSII]BPRNAM=[M:DSII4]BPRNAM(NOL)
      [F:XYSII]NIP   =[M:DSII4]NIP(NOL)
      [F:XYSII]CRY   =[M:DSII4]CRY(NOL)
      [F:XYSII]TYPREC=""
       If GSIIFCY=1 or GSIIEXTAP=2 #SII v4 planta
        [F:XYSII]DKEY=[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
      Else
        [F:XYSII]DKEY=[F:XYSII]CPY+[F:XYSII]FCY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
      Endif
      [F:XYSII]DATDVS=WDVSDAT
      [F:XYSII]DATVCRORI=WORIDAT
      Write
    Commit
    [M:DSII4]FLGSEL(NOL)=2
    VALEUR=VALEUR+"_"+num$(year([M:DSII]DATINI))
  Else
    VALEUR=VALEUR+"_"+num$(year([M:DSII]DATINI))
    [M:DSII4]FLGSEL(NOL)=2
    Raz [M:DSII4]STADOC(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
    [M:DSII4]DATOPE(NOL)=date$
  Endif
  Affzo [M:DSII4]1-99
  Close File [XYSII]
End

##################################################
Subprog AM_VCRERRNUM(VALEUR)
Variable Char VALEUR()
  If VALEUR<>[M:DSII]VCRERRNUM
    GMODCRI=1
  Endif
  If VALEUR<>""
    If [M:DSII]STAALL=1: [M:DSII]STAALL=2: Affzo [M:DSII]STAALL : Endif
  Endif
End

#####################################################################################
Subprog C_TYPANUAL(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2
    GMESSAGE=mess(9,2124,1) #Inserción manual no permitida si origen de datos no es X3.
    mkstat=2                #Manual insertion is not allowed when the data source is not X3.
    End
  Endif

  VALEUR=toupper(VALEUR)

  If VALEUR<>"V" and VALEUR<>"S"
    GMESSAGE=mess(10,2124,1)+": V, S" #Sólo estos valores están permitidos
    mkstat=2                          #Only these values are allowed
  Endif
  If VALEUR="S" and [M:DSII]TERCPY="("+mess(6,2108,1)+")"    #Canarias no usa tipo seguros
    GMESSAGE=mess(13,2124,1)  #Seguros anuales no utilizados en Canarias
    mkstat=2                  #Annual insurances are not used in the Canary Islands
  Endif
End

#####################################################################################
Subprog AM_TYPANUAL(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If [M:DSII7]TYPANUAL(NOL)<>"" and VALEUR<>[M:DSII7]TYPANUAL(NOL) and [M:DSII7]NIP(NOL)<>""
    GMESSAGE=mess(14,2124,1) #Modificación no permitida. Si no es correcto use modificación para cancelar la línea
    mkstat=2: End            #Modification is not allowed. If this value is not correct, use the modification option to cancel the line.
  Endif

  If VALEUR="V"
    Raz [M:DSII7]CLAVEOPE(NOL)
    Grizo [M:DSII7]CLAVEOPE(NOL)
    Affzo [M:DSII7]CLAVEOPE(NOL)
  Elsif VALEUR="S"
    Actzo [M:DSII7]CLAVEOPE(NOL)
    [M:DSII7]CLAVEOPE(NOL)="A"
    Affzo [M:DSII7]CLAVEOPE(NOL)
  Endif
End

#####################################################################################

###################################################################################### Ini DAFER 04-11-20 Bienes consigna
Subprog C_CLADECCON(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1
  VALEUR=toupper(VALEUR)
  If VALEUR<>"A" and VALEUR<>"V"
    GMESSAGE="Debe ser A o V": mkstat=2
  Endif

End
###################################################################################### Ini DAFER 04-11-20 Bienes consigna

Subprog C_TYPOPE(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If VALEUR<>"A" and VALEUR<>"B"
    GMESSAGE=mess(10,2124,1)+": A, B" #Sólo estos valores están permitidos
    mkstat=2                          #Only these values are allowed
  Endif
End

######################################################################################
Subprog C_CLAVDEC(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If VALEUR<>"D" and VALEUR<>"R"
    GMESSAGE=mess(10,2124,1)+": D, R" #Sólo estos valores están permitidos
    mkstat=2                          #Only these values are allowed
  Endif
End

######################################################################################
Subprog AM_CLAVEOPE(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1
Local Char WNIP(60)

  VALEUR=toupper(VALEUR)
  If VALEUR<>"A" and VALEUR<>"B"
    GMESSAGE=mess(10,2124,1)+": A, B" #Sólo estos valores están permitidos
    mkstat=2                          #Only these values are allowed
  Endif

  If NOL>0 and [M:DSII7]TYPANUAL(NOL)<>"M" and [M:DSII7]NIP(NOL)<>""
    WNIP=[M:DSII7]NIP(NOL)
    [M:DSII7]VCRNUM(NOL)=[M:DSII7]NIP(NOL)+"-"+num$(year([M:DSII]DATINI))+"-"+[M:DSII7]TYPANUAL(NOL)+VALEUR
    Gosub REV_CLAVEOPEMET
    If J>1
      GMESSAGE=mess(6,2124,1) #Tercero ya existe para este tipo de operación"
      mkstat=2: End           #This BP already exists for this operation type.
    Endif
  Endif

End

##################################################
Subprog AM_AMTATI(VALEUR)
Variable Decimal   VALEUR()
  Local Integer NOL: NOL=nolign-1
  Local Decimal WAMT:  WAMT=3005.06
  If VALEUR <=WAMT
    GMESSAGE=mess(5,2124,1)-num$(WAMT)-"€" #El importe tiene que ser superior a \The amount must be greater than
    mkstat=2: End
  Endif

  If [M:DSII7]STADOC(NOL)=2
    [M:DSII7]FLGSEL(NOL)=2
    [M:DSII7]STADOC(NOL)=1
    [M:DSII7]TYPCOM(NOL)=2
    [M:DSII7]VCRSTA(NOL)=1
    Affzo [M:DSII7]FLGSEL(NOL),STADOC(NOL), TYPCOM(NOL),VCRSTA(NOL)
    Actzo [M:DSII7]FLGSEL(NOL)

    If [M:DSII7]TYPANUAL(NOL)<>"M"
      If [M:DSII7]STADOC(NOL)=1 and [M:DSII7]VCRNUM(NOL)<>""
        Local File DCLSII [XYSII]
        If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Readlock [F:XYSII]DSII0 = [M:DSII]CPY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
        Else
          Readlock [F:XYSII]DSII2 = [M:DSII]CPY;[M:DSII]FCY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
        Endif
        If fstat=[V]CST_AOK
          Trbegin [F:XYSII]
            [F:XYSII]FLGSEL=[M:DSII7]FLGSEL(NOL)
            [F:XYSII]STADOC=[M:DSII7]STADOC(NOL)
            [F:XYSII]VCRSTA=[M:DSII7]VCRSTA(NOL)
            [F:XYSII]TYPCOM=[M:DSII7]TYPCOM(NOL)
            Rewrite
          Commit
        Endif
      Endif
    Endif
  Endif

End

######################################################################################
Subprog AM_AFTMODERR(VALEUR)
Variable Char VALEUR()
  If VALEUR<>[M:DSII]VCRERRNUM
    GMODCRI=1
  Endif
  If VALEUR<>""
    If [M:DSII]STAALL=1: [M:DSII]STAALL=2: Affzo [M:DSII]STAALL: Endif
  Endif
End


######################################################################################
$DEL_SEGURO
  Local Integer YESNO, I, K
  Local Char WNUM(200)
  #You are changing the identifier. Do you want to delete the current record of this identifier and create a new one?
  WMSG=mess(12,2124,1) #Estas cambiado el identificador ¿Quiere borrar el actual registro de este identificador y crear uno nuevo

  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Local File DCLSII [XDCL]
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Read [XDCL]DSII0=[M:DSII]CPY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
    Else
      Read [XDCL]DSII2=[M:DSII]CPY;[M:DSII]FCY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
    Endif
    WNUM=[M:DSII7]NIP(NOL)+"-"+num$(year([M:DSII]DATINI))+"-"+[M:DSII7]TYPANUAL(NOL)+[M:DSII7]CLAVEOPE(NOL)
    If fstat=[V]CST_AOK
      Trbegin  [XDCL]
        Delete Curr
      Commit
    Endif
    Close File [XDCL]
  Else
    [M:DSII7]NIP(NOL)=VALEUR
    Affzo [M:DSII7]NIP(NOL)
    Call APRES_NBLIGM
    Gosub ACT_OPEANU
  Endif
Return

######################################################################################
$ACT_EMI
  Raz [M:DSII1]
  Local Char CRITCAR (250)
  Local Integer WNL, GRP
  Local File DCLSII [YXSIE]
  CRITCAR="1=1"
  If [M:DSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIE]FCY="'+[M:DSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:DSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'find([F:YXSIE]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  # BPs
  If [M:DSII]BPR<>""
    Call ADDCRIT(CRITCAR, ICRIT,"BPR",'[F:YXSIE]BPR="'+[M:DSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:DSII]LOT<>""
    Call ADDCRIT(CRITCAR, ICRIT,"LOT",'[F:YXSIE]LOTNUM="'+[M:DSII]LOT+'"'," & ") From GOBJSUB
   Endif

  # Error number
  If [M:DSII]VCRERRNUM<>""
    Call ADDCRIT(CRITCAR, ICRIT,"VCRERRNUM",'[F:YXSIE]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:DSII]ALLCOM<>2
    Case [M:DSII]TYPCOM
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=1'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=3'," & ")  From GOBJSUB
    Endcase
  Endif

 # Document status
  If [M:DSII]STAALL<>2
    Case [M:DSII]VCRSTA
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA<2'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=3'," & ")  From GOBJSUB
      When 4: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=4'," & ")  From GOBJSUB
    Endcase
  Endif

  Filter [YXSIE] Where TYPENV=1 and [F:YXSIE]DATOPE>=[M:DSII]DATINI and  [F:YXSIE]DATOPE<=[M:DSII]DATEND and [F:YXSIE]CPY=[M:DSII]CPY and evalue(CRITCAR)
  For [YXSIE]
    [M:DSII1]FLGSEL(WNL)    =[F:YXSIE]FLGSEL
    [M:DSII1]GTE(WNL)       =[F:YXSIE]GTE
    [M:DSII1]VCRNUM(WNL)    =[F:YXSIE]VCRNUM
    [M:DSII1]STADOC(WNL)    =[F:YXSIE]STADOC
    [M:DSII1]VCRSTA(WNL)    =[F:YXSIE]VCRSTA
    [M:DSII1]TYPCOM(WNL)    =[F:YXSIE]TYPCOM
    [M:DSII1]DATOPE(WNL)    =[F:YXSIE]DATOPE
    [M:DSII1]AMTATI(WNL)    =[F:YXSIE]AMTATI
    [M:DSII1]CRY(WNL)       =[F:YXSIE]CRY
    [M:DSII1]BPR(WNL)       =[F:YXSIE]BPR
    [M:DSII1]BPRNAM(WNL)    =[F:YXSIE]BPRNAM
    [M:DSII1]NIP(WNL)       =[F:YXSIE]NIP
    [M:DSII1]VCRERRNUM(WNL) =[F:YXSIE]VCRERRNUM
    [M:DSII1]VCRLIN(WNL)    =[F:YXSIE]VCRLIN
    WNL+=1
    If WNL=dim([M:DSII1]FLGSEL): Break: Endif
  Next
  [M:DSII1]NBLIG=WNL
  Affzo [M:DSII1]1-99
  Close File [YXSIE]
Return

######################################################################################
$ACT_REC
  Raz [M:DSII2]
  Local Char CRITCAR (250)
  Local Integer WNL, GRP
  Local File DCLSII [YXSIR]
  CRITCAR="1=1"
  If [M:DSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIR]FCY="'+[M:DSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:DSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'find([F:YXSIR]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  # BPs
  If [M:DSII]BPR<>""
    Call ADDCRIT(CRITCAR, ICRIT,"BPR",'[F:YXSIR]BPR="'+[M:DSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:DSII]LOT<>""
    Call ADDCRIT(CRITCAR, ICRIT,"LOT",'[F:YXSIR]LOTNUM="'+[M:DSII]LOT+'"'," & ") From GOBJSUB
   Endif

  # Error number
  If [M:DSII]VCRERRNUM<>""
    Call ADDCRIT(CRITCAR, ICRIT,"VCRERRNUM",'[F:YXSIR]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:DSII]ALLCOM<>2
    Case [M:DSII]TYPCOM
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIR]TYPCOM=1'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIR]TYPCOM=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIR]TYPCOM=3'," & ")  From GOBJSUB
    Endcase
  Endif

 # Document status
  If [M:DSII]STAALL<>2
    Case [M:DSII]VCRSTA
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIR]VCRSTA<2'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIR]VCRSTA=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIR]VCRSTA=3'," & ")  From GOBJSUB
      When 4: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIR]VCRSTA=4'," & ")  From GOBJSUB
    Endcase
  Endif

  Filter [YXSIR] Where TYPENV=2 and [F:YXSIR]DATOPE>=[M:DSII]DATINI and  [F:YXSIR]DATOPE<=[M:DSII]DATEND and [F:YXSIR]CPY=[M:DSII]CPY and evalue(CRITCAR)
  For [YXSIR]
    [M:DSII2]FLGSEL(WNL)    =[F:YXSIR]FLGSEL
    [M:DSII2]GTE(WNL)       =[F:YXSIR]GTE
    [M:DSII2]VCRNUM(WNL)    =[F:YXSIR]VCRNUM
    [M:DSII2]STADOC(WNL)    =[F:YXSIR]STADOC
    [M:DSII2]VCRSTA(WNL)    =[F:YXSIR]VCRSTA
    [M:DSII2]TYPCOM(WNL)    =[F:YXSIR]TYPCOM
    [M:DSII2]DATOPE(WNL)    =[F:YXSIR]DATOPE
    [M:DSII2]AMTATI(WNL)    =[F:YXSIR]AMTATI
    [M:DSII2]CRY(WNL)       =[F:YXSIR]CRY
    [M:DSII2]BPR(WNL)       =[F:YXSIR]BPR
    [M:DSII2]BPRVCR(WNL)    =[F:YXSIR]BPRVCR
    [M:DSII2]BPRNAM(WNL)    =[F:YXSIR]BPRNAM
    [M:DSII2]NIP(WNL)       =[F:YXSIR]NIP
    [M:DSII2]VCRERRNUM(WNL) =[F:YXSIR]VCRERRNUM
    [M:DSII2]VCRLIN(WNL)    =[F:YXSIR]VCRLIN
    WNL+=1
    If WNL=dim([M:DSII2]FLGSEL): Break: Endif
  Next
  [M:DSII2]NBLIGR=WNL
  Affzo [M:DSII2]1-99
  Close File [YXSIR]
Return

######################################################################################
$ACT_CEE
  Raz [M:DSII3]
  Local Char CRITCAR (250)
  Local Integer WNL, GRP
  Local File DCLSII [YXSIM]
  CRITCAR="1=1"
  If [M:DSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIM]FCY="'+[M:DSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:DSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'find([F:YXSIM]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  # BPs
