Subprog AVANT_BIENCON
Local Integer NOL: NOL=nolign-1

  If ((GSIIEXTAP=2 and [M:DSIIBC]VCRNUM(NOL)<>""))
    Grizo  [M:DSIIBC]VCRNUM(NOL), GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),VALBIEN(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSIIBC]DATOPE(NOL),BPRVCR(NOL), TYPOPECON(NOL), CLADECCON(NOL), VCRTYP(NOL), VALBASIMP(NOL), DATOPEDEC(NOL)
    End
  Else
    Actzo[M:DSIIBC]VCRNUM(NOL)
  Endif

  If [M:DSIIBC]STADOC(NOL)>1
    Grizo  [M:DSIIBC]VCRNUM(NOL), GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),VALBIEN(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSIIBC]DATOPE(NOL),BPRVCR(NOL), TYPOPECON(NOL), CLADECCON(NOL), VCRTYP(NOL), VALBASIMP(NOL), DATOPEDEC(NOL)
  Else
    Actzo  [M:DSIIBC]VCRNUM(NOL), GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),VALBIEN(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Actzo  [M:DSIIBC]DATOPE(NOL),BPRVCR(NOL), TYPOPECON(NOL), CLADECCON(NOL), VCRTYP(NOL), VALBASIMP(NOL), DATOPEDEC(NOL)
    [M:DSIIBC]VCRLIN(NOL)=1
  Endif

  If GSIIFCY=2: [M:DSIIBC]FCY(NOL)=[M:DSII]FCY: Else : Raz [M:DSIIBC]FCY(NOL): Endif :  # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Affzo [M:DSIIBC]1-99
End

################################################## End DAFER 04-11-20 Bienes consigna

################################################## Ini DAFER 04-11-20 Bienes consigna

Subprog APRES_BIENCON

Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2 or [M:DSII]TERCPY="("+mess(6,2108,1)+")"  :End: Endif  #Canarias. CEE no se usa para Canarias
  Local Char WMSG(250)
  If [M:DSIIBC]STADOC(NOL)=1 and [M:DSIIBC]VCRNUM(NOL)<>""
    Local File DCLSII [XYSII]
    If  [M:DSIIBC]GTE(NOL)=""
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Readlock [F:XYSII]DSII0 = [M:DSII]CPY;8;[M:DSIIBC]GTE(NOL);[M:DSIIBC]VCRNUM(NOL);1
      Else
        Readlock [F:XYSII]DSII2 = [M:DSII]CPY;[M:DSII]FCY;8;[M:DSIIBC]GTE(NOL);[M:DSIIBC]VCRNUM(NOL);1
      Endif
      If fstat=[V]CST_AOK
        Trbegin [F:XYSII]
          #borramos registro anterior
          Delete Curr
        Commit
      Endif
      Trbegin [F:XYSII]
        # creamos el nuevo tipo 8
        [F:XYSII]FLGSEL=[M:DSIIBC]FLGSEL(NOL)
        [F:XYSII]CPY=[M:DSII]CPY
        [F:XYSII]STADOC=1
        [F:XYSII]TYPENV=8
        [F:XYSII]TYPCOM=1
        [F:XYSII]GTE   =[M:DSIIBC]GTE(NOL)
        [F:XYSII]VCRNUM=[M:DSIIBC]VCRNUM(NOL)
        [F:XYSII]VCRLIN=1
        [F:XYSII]VCRSTA=1
        [F:XYSII]DATOPE=[M:DSIIBC]DATOPE(NOL)
        [F:XYSII]BPRVCR=[M:DSIIBC]BPRVCR(NOL)
        [F:XYSII]BPR   =[M:DSIIBC]BPR(NOL)
        [F:XYSII]BPRNAM=[M:DSIIBC]BPRNAM(NOL)
        [F:XYSII]NIP   =[M:DSIIBC]NIP(NOL)
        [F:XYSII]CRY   =[M:DSIIBC]CRY(NOL)
        [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
        [F:XYSII]TYPOPECON=[M:DSIIBC]TYPOPECON(NOL)
        [F:XYSII]CLADECCON=[M:DSIIBC]CLADECCON(NOL)
        [F:XYSII]NIFREPC =[M:DSIIBC]NIFREPC(NOL)
        [F:XYSII]VALBIEN =[M:DSIIBC]VALBIEN(NOL)
        [F:XYSII]ORICRY  =[M:DSIIBC]ORICRY(NOL)
        [F:XYSII]DESCRY  =[M:DSIIBC]DESCRY(NOL)
        [F:XYSII]EXPDAT  =[M:DSIIBC]EXPDAT(NOL)
        [F:XYSII]RECDAT  =[M:DSIIBC]RECDAT(NOL)
        [F:XYSII]QTY     =[M:DSIIBC]QTY(NOL)
        [F:XYSII]EJEREXPINI =[M:DSIIBC]EJEREXPINI(NOL)
        [F:XYSII]PEREXPINI  =[M:DSIIBC]PEREXPINI(NOL)
        [F:XYSII]IDEXPINI  =[M:DSIIBC]IDEXPINI(NOL)
        [F:XYSII]UNIPRI    =[M:DSIIBC]UNIPRI(NOL)
        [F:XYSII]VALBASIMP =[M:DSIIBC]VALBASIMP(NOL)
        [F:XYSII]DATOPEDEC  =[M:DSIIBC]DATOPEDEC(NOL)
        [F:XYSII]DESBIENES  =[M:DSIIBC]DESBIENES(NOL)
        [F:XYSII]DIRECOPE   =[M:DSIIBC]DIRECOPE(NOL)
        Write
      Commit
    Endif
    Close File [XYSII]
    If [M:DSIIBC]DESCRY(NOL) ="" or [M:DSIIBC]DESBIENES(NOL) ="" or [M:DSIIBC]DIRECOPE(NOL)=""
      Call IB6_NBLIGBC
    Endif
  Endif

End


##################################################

Subprog AVANT_NBLIGM

Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2
    Grizo  [M:DSII7]STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII7]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
    If [M:DSII7]AMTATI(NOL)<>0
      Grizo [M:DSII7]TYPANUAL(NOL)
    Else
      Affzo [M:DSII7]TYPANUAL(NOL)
    Endif
    Affzo [M:DSII7]1-99: End
  Endif

  If [M:DSII7]TYPANUAL(NOL)="M"
    Grizo  [M:DSII7]STADOC(NOL),TYPCOM(NOL),TYPANUAL(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII7]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
  Else
    If [M:DSII7]VCRNUM(NOL)=""
      [M:DSII7]FLGSEL(NOL)=2
      [M:DSII7]DATOPE(NOL)= gdat$(31,12,year([M:DSII]DATINI))
      [M:DSII7]TYPANUAL(NOL)="S":   [M:DSII7]CLAVEOPE(NOL)="A"
      [M:DSII7]VCRLIN(NOL)=1
      Actzo  [M:DSII7]1-99
    Elsif [M:DSII7]STADOC(NOL)=1 and [M:DSII7]TYPCOM(NOL)=2
      Grizo  [M:DSII7]STADOC(NOL),TYPCOM(NOL),TYPANUAL(NOL),VCRNUM(NOL),DATOPE(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
      Grizo  [M:DSII7]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
    Endif
  Endif

  If [M:DSII7]STADOC(NOL)>1
    Grizo [M:DSII7]FLGSEL(NOL)
  Else
    Actzo [M:DSII7]FLGSEL(NOL)
  Endif
  If GSIIFCY=2 and [M:DSII7]TYPANUAL(NOL)<>"M": [M:DSII7]FCY(NOL)=[M:DSII]FCY: Else: Raz [M:DSII7]FCY(NOL): Endif # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Affzo [M:DSII7]1-99
End

##################################################
Subprog APRES_NBLIGM
  Local Integer NOL: NOL=nolign-1
  Local Char WMSG(250)
  Local Char WMAN(2): WMAN="00"

  If GSIIEXTAP=2:End:Endif
  If [M:DSII7]TYPANUAL(NOL)<>"M"
    If [M:DSII7]STADOC(NOL)=1 and [M:DSII7]VCRNUM(NOL)<>""
      Local File DCLSII [XYSII]
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Readlock [F:XYSII]DSII0 = [M:DSII]CPY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
      Else
        Readlock [F:XYSII]DSII2 = [M:DSII]CPY;[M:DSII]FCY;7;[M:DSII7]GTE(NOL);[M:DSII7]VCRNUM(NOL);1
      Endif
      If fstat=[V]CST_AOK
        Trbegin [F:XYSII]
        #borramos registro anterior
          Delete Curr
        Commit
      Endif

      Trbegin [F:XYSII]
        # creamos el nuevo tipo 7
        [F:XYSII]FLGSEL=[M:DSII7]FLGSEL(NOL)
        [F:XYSII]CPY=[M:DSII]CPY
        [F:XYSII]STADOC=1
        [F:XYSII]TYPENV=7
        [F:XYSII]TYPCOM=[M:DSII7]TYPCOM(NOL)
        [F:XYSII]GTE   =[M:DSII7]GTE(NOL)
        [F:XYSII]VCRNUM=[M:DSII7]VCRNUM(NOL)
        [F:XYSII]VCRLIN=1
        [F:XYSII]VCRSTA=1
        [F:XYSII]DATOPE=[M:DSII7]DATOPE(NOL)
        [F:XYSII]BPR   =[M:DSII7]BPR(NOL)
        [F:XYSII]AMTATI=[M:DSII7]AMTATI(NOL)
        [F:XYSII]BPRNAM=[M:DSII7]BPRNAM(NOL)
        [F:XYSII]NIP   =[M:DSII7]NIP(NOL)
        [F:XYSII]CRY   =[M:DSII7]CRY(NOL)
        [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
        [F:XYSII]TYPANUAL=[M:DSII7]TYPANUAL(NOL)
        [F:XYSII]CLAVEOPE=[M:DSII7]CLAVEOPE(NOL)
        Write
      Commit
      Close File [XYSII]
    Endif
  Endif

End

##################################################
Subprog AVANT_NBLIGC
Local Integer NOL: NOL=nolign-1

  If ((GSIIEXTAP=2 and [M:DSII3]VCRNUM(NOL)<>""))
    Grizo  [M:DSII3]VCRNUM(NOL), GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII3]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
    End
  Else
    Actzo[M:DSII3]VCRNUM(NOL)
  Endif

  If [M:DSII3]STADOC(NOL)>1
    Grizo  [M:DSII3]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII3]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
  Else
    Actzo  [M:DSII3]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Actzo  [M:DSII3]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
    [M:DSII3]VCRLIN(NOL)=1
  Endif

  If GSIIFCY=2: [M:DSII3]FCY(NOL)=[M:DSII]FCY: Else: Raz [M:DSII3]FCY(NOL): Endif # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Affzo [M:DSII3]1-99
End

##################################################
Subprog APRES_NBLIGC
Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2 or [M:DSII]TERCPY="("+mess(6,2108,1)+")"  :End: Endif  #Canarias. CEE no se usa para Canarias
  Local Char WMSG(250)
  If [M:DSII3]STADOC(NOL)=1 and [M:DSII3]VCRNUM(NOL)<>""
    Local File DCLSII [XYSII]
    If  [M:DSII3]GTE(NOL)=""
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Readlock [F:XYSII]DSII0 = [M:DSII]CPY;3;[M:DSII3]GTE(NOL);[M:DSII3]VCRNUM(NOL);1
      Else
        Readlock [F:XYSII]DSII2 = [M:DSII]CPY;[M:DSII]FCY;3;[M:DSII3]GTE(NOL);[M:DSII3]VCRNUM(NOL);1
      Endif
      If fstat=[V]CST_AOK
        Trbegin [F:XYSII]
          #borramos registro anterior
          Delete Curr
        Commit
      Endif
      Trbegin [F:XYSII]
        # creamos el nuevo tipo 3
        [F:XYSII]FLGSEL=[M:DSII3]FLGSEL(NOL)
        [F:XYSII]CPY=[M:DSII]CPY
        [F:XYSII]STADOC=1
        [F:XYSII]TYPENV=3
        [F:XYSII]TYPCOM=1
        [F:XYSII]GTE   =[M:DSII3]GTE(NOL)
        [F:XYSII]VCRNUM=[M:DSII3]VCRNUM(NOL)
        [F:XYSII]VCRLIN=1
        [F:XYSII]VCRSTA=1
        [F:XYSII]DATOPE=[M:DSII3]DATOPE(NOL)
        [F:XYSII]BPRVCR=[M:DSII3]BPRVCR(NOL)
        [F:XYSII]BPR   =[M:DSII3]BPR(NOL)
        [F:XYSII]BPRNAM=[M:DSII3]BPRNAM(NOL)
        [F:XYSII]NIP   =[M:DSII3]NIP(NOL)
        [F:XYSII]CRY   =[M:DSII3]CRY(NOL)
        [F:XYSII]TYPREC=[M:DSII3]TYPREC(NOL)
        [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
        [F:XYSII]TYPOPE=[M:DSII3]TYPOPE(NOL)
        [F:XYSII]CLAVDEC    =[M:DSII3]CLAVDEC(NOL)
        [F:XYSII]ESTMIEMBRO =[M:DSII3]ESTMIEMBRO(NOL)
        [F:XYSII]DESBIENES  =[M:DSII3]DESBIENES(NOL)
        [F:XYSII]DIRECOPE   =[M:DSII3]DIRECOPE(NOL)
        [F:XYSII]PLAZOOPE   =[M:DSII3]PLAZOOPE(NOL)
        [F:XYSII]FACDOC     =[M:DSII3]FACDOC(NOL)
        Write
      Commit
    Endif
    Close File [XYSII]
    If [M:DSII3]ESTMIEMBRO(NOL) ="" or [M:DSII3]DESBIENES(NOL) ="" or [M:DSII3]DIRECOPE(NOL)=""
      Call IB4_NBLIGC
    Endif
  Endif

End

#####################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2
    GMESSAGE=mess(9,2124,1) #Inserción manual no permitida si origen de datos no es X3.
    mkstat=2                #Manual insertion is not allowed when the data source is not X3.
    End
  Endif
End

##################################################
Subprog AVANT_NBLIGI
Local Integer NOL: NOL=nolign-1

  If GSIIEXTAP=2 and [M:DSII4]VCRNUM(NOL)<>""
    Grizo  [M:DSII4]VCRNUM(NOL),FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII4]BPRVCR(NOL),VCRTYP(NOL)
    End
  Else
    Actzo[M:DSII4]VCRNUM(NOL)
  Endif

  If [M:DSII4]STADOC(NOL)>1
    Grizo  [M:DSII4]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:DSII4]BPRVCR(NOL),VCRTYP(NOL)
  Else
    Actzo  [M:DSII4]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Actzo  [M:DSII4]BPRVCR(NOL),VCRTYP(NOL)
   [M:DSII4]FLGSEL(NOL)=2: [M:DSII4]VCRLIN(NOL)=1
  Endif

  If GSIIFCY=2: [M:DSII4]FCY(NOL)=[M:DSII]FCY: Else: Raz [M:DSII4]FCY(NOL): Endif :  # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Affzo [M:DSII4]1-99
End


##################################################
Subprog APRES_NBLIGI
Local Integer NOL: NOL=nolign-1
Local Char WMSG(250)

  If GSIIEXTAP=2 :End: Endif
  If [M:DSII4]STADOC(NOL)=1 and [M:DSII4]VCRNUM(NOL)<>""
    Local File DCLSII [XYSII]
    Trbegin [F:XYSII]
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Readlock [F:XYSII]DSII0 = [M:DSII]CPY;4;[M:DSII4]GTE(NOL);[M:DSII4]VCRNUM(NOL);1
      Else
        Readlock [F:XYSII]DSII2 = [M:DSII]CPY;[M:DSII]FCY;4;[M:DSII4]GTE(NOL);[M:DSII4]VCRNUM(NOL);1
      Endif
      If fstat<>[V]CST_AOK
        # creamos el nuevo tipo 4
        Gosub FIL_INM
        Write
      Else
        Gosub FIL_INM
        Rewrite
      Endif
    Commit
    Close File [XYSII]
  Endif
End

$FIL_INM
  [F:XYSII]FLGSEL=[M:DSII4]FLGSEL(NOL)
  [F:XYSII]CPY=[M:DSII]CPY
  [F:XYSII]STADOC=1
  [F:XYSII]TYPENV=4
  [F:XYSII]TYPCOM=1
  [F:XYSII]GTE   =[M:DSII4]GTE(NOL)
  [F:XYSII]VCRNUM=[M:DSII4]VCRNUM(NOL)
  [F:XYSII]VCRLIN=1
  [F:XYSII]VCRSTA=1
  [F:XYSII]AMTATI=[M:DSII4]AMTATI(NOL)
  [F:XYSII]DATOPE=[M:DSII4]DATOPE(NOL)
  [F:XYSII]BPRVCR=[M:DSII4]BPRVCR(NOL)
  [F:XYSII]BPR   =[M:DSII4]BPR(NOL)
  [F:XYSII]BPRNAM=[M:DSII4]BPRNAM(NOL)
  [F:XYSII]NIP   =[M:DSII4]NIP(NOL)
  [F:XYSII]CRY   =[M:DSII4]CRY(NOL)
  [F:XYSII]TYPREC=[M:DSII4]TYPREC(NOL)
  [F:XYSII]VCRTYP=[M:DSII4]VCRTYP(NOL)
  [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+"1"
Return

##################################################
$CRE_TAXFREE
  Local File DCLSII [XTXF]
  Local Char WORIDOC (100)
  Local Decimal WVATRAT

  Gosub LEC_VATRAT

  Trbegin [XTXF]
    WORIDOC=[F:DSII]VCRNUM
    [F:XTXF]=[F:DSII]
    [F:XTXF]TYPENV=1
    [F:XTXF]VCRNUM=[F:XTXF]BPRVCR
    [F:XTXF]GTE=""
    [F:XTXF]DKEY  =[F:XTXF]CPY+num$([F:XTXF]TYPENV)+[F:XTXF]GTE+[F:XTXF]VCRNUM+"1"
    [F:XTXF]BPRVCR=WORIDOC
    [F:XTXF]AMTATI=[F:DVS]AMTATIL # X3-237572 SII Monitor by site by DAFER 2021-06-16 DER
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Read [XTXF]DSII0 = [F:XTXF]CPY;1;[F:XTXF]GTE;[F:XTXF]VCRNUM;1
    Else
      Read [XTXF]DSII2 = [F:XTXF]CPY;[F:XTXF]FCY;1;[F:XTXF]GTE;[F:XTXF]VCRNUM;1
    Endif
    If fstat=[V]CST_AOK
      Rewrite [XTXF]
    Else
      Write [XTXF]
      If fstat : GOK=0 : Call FSTA("DSII") From GLOCK : Endif
    Endif

    If GOK<0   : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif

  Commit
  Close File [XTXF]
Return

##################################################
$CHG_TAXFREE  #gestión tax-free
  Local File DCLSII [XTXF]
  Local Decimal WVATRAT
  Gosub LEC_VATRAT
  Trbegin [XTXF]
    If GSIIFCY=1 or GSIIEXTAP=2 #SII v4 planta
      Read [XTXF]DSII0 = [F:XTXF]CPY;1;[F:XTXF]GTE;[F:XTXF]VCRNUM;1
    Else
      Read [XTXF]DSII2 = [F:XTXF]CPY;[F:XTXF]FCY;1;[F:XTXF]GTE;[F:XTXF]VCRNUM;1
    Endif
    If fstat=[V]CST_AOK
      If [F:XTXF]STADOC=2: [F:XTXF]TYPCOM=2 : Endif  # Modification
      If [F:XTXF]VCRSTA=4: [F:XTXF]TYPCOM=1 : Endif # Alta si Rechazada
      [F:XTXF]STADOC=1: [F:XTXF]FLGSEL=2: [F:XTXF]VCRSTA=1
      [F:XTXF]AMTATI=[F:DVS]AMTATIL  # X3-237572 SII Monitor by site by DAFER 2021-06-16 DER
      Rewrite [XTXF]
    Endif

    If GOK<0   : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif

  Commit
  Close File [XTXF]
Return

##################################################
$LEC_VATRAT
  If clalev([F:TRA])=0 : Local File TABRATVAT  [TRA] : Endif # Tax rates

  Filter [TRA] Where VAT=[F:DVS]VAT & CPY=[F:DVS]CPY & STRDAT<=[F:DVS]ACCDAT & LEG="SPA"
    Read [TRA]TRA0 Last
    If !fstat
      WVATRAT = [F:TRA]VATRAT
    Else
      Filter [F:TRA] Where VAT=[F:DVS]VAT & CPY="" & STRDAT<=[F:DVS]ACCDAT & LEG="SPA"
      Read [TRA]TRA0 Last
      If !fstat
        WVATRAT = [F:TRA]VATRAT
      Endif
    Endif
  Close File [TRA]

Return

##################################################
$CONTROL_IVA  # Controling if Spanish declaration is locked
  If [M:DSII]CPY=""
    BLOQUEOIVA="DCLVATSPA~"+""+"~"+ num$(year([M:DSII]DATINI))
    Lock =BLOQUEOIVA With lockwait=0
    If fstat
      GMESSAGE= mess(00071,00107,1)-"(SPA)."-mess(30,100,1)   # Tax declaration (SPA). The record is used by an other user
      GERR=2 : FIN=1 : Return
    Endif
  Else
    BLOQUEOIVA="DCLVATSPA~"+""+"~"+ num$(year([M:DSII]DATINI))
    Lock =BLOQUEOIVA With lockwait=0
    If fstat
      GMESSAGE= mess(00071,00107,1)-"(SPA)."-mess(30,100,1)   # Tax declaration (SPA). The record is used by an other user
      GERR=2 : FIN=1 : Return
    Else
      Unlock =BLOQUEOIVA
      BLOQUEOIVA="DCLVATSPA~"+[M:DSII]CPY+"~"+ num$(year([M:DSII]DATINI))
      Lock =BLOQUEOIVA With lockwait=0
      If fstat
        GMESSAGE= mess(00071,00107,1)-"(SPA)."-mess(30,100,1)   # Tax declaration (SPA). The record is used by an other user
        GERR=2 : FIN=1 : Return
      Endif
    Endif
  Endif
Return

##################################################
$LECT_PARAM # X3-237572 SII Monitor by site by DAFER 2021-06-16
  Local Char   WVAL(1), WDAT(15)
  Call PARAML(VALEUR,"SIIMETSII",WVAL) From ADOVAL
  GMETSII=val(WVAL)

  Call PARAM(VALEUR,"SIIFECSII",WDAT) From ADOVAL
  If WDAT<>"" : GFECSII = gdat$(WDAT) : Endif

  Call PARAML(VALEUR,"TERDECSP",WVAL) From ADOVAL
  If val(WVAL)=0 : WVAL="1": Endif

  [M:DSII]TERCPY="("+mess(val(WVAL),2108,1)+")"
  Affzo [M:DSII]TERCPY
Return

