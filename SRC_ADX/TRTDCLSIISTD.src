#<AdxTL>@(#)%I% KSP
#########################################
# SII process script  JUCON 2020-07-15 #
#########################################
$RES_DVS
  Local Integer WTRT : WTRT=0
  Call PARAML([M:DSII]CPY,"SIIDVSR",WRECSII) From ADOVAL
  If val(WRECSII)=2
    WMSG=mess(1,2124,1) #"¿Quiere resincronizar la tabla de impuestos (IVA y metálico)?\Do you want to resynchronize the tax table (VAT and cash)?"
    Call OUINON (WMSG, YESNO) From GESECRAN
    If YESNO = 2 : # 2 = YES
      ### VAT resincronization
      Gosub OUVRE     From DCLVATSPA
      # inicializating DCLVATSPA mask
      Local Mask DCLVATSPA [DIA]
      Raz [M:DIA]
      [M:DIA]YEA=year([M:DSII]DATINI)
      [M:DIA]ALLCPY=1
      [M:DIA]ALLFCY=1
      [M:DIA]CPY=[M:DSII]CPY
      If [M:DIA]FCY<>""
        [M:DIA]FCY=[M:DSII]FCY
      Else
        [M:DIA]ALLFCY=2
      Endif

      If  val([M:DSII]DATINI)>val(GFECSII)
        [M:DIA]STRDAT=[M:DSII]DATINI
        [M:DIA]ENDDAT=[M:DSII]DATEND
        WTRT=1
      Else
        If val([M:DSII]DATEND)>val(GFECSII)
          [M:DIA]STRDAT=GFECSII+1
          [M:DIA]ENDDAT=[M:DSII]DATEND
          WTRT=1
        Endif
      Endif

      If WTRT=1
        [M:DIA]RESINCRONI=2
        If GMETSII=2
          [M:DIA]CASH=2
        Else
          [M:DIA]CASH=1
        Endif
        Gosub CONTROLE  From DCLVATSPA
        Gosub EXEC      From DCLVATSPA
        Gosub TERMINE   From DCLVATSPA
        Close Mask [DIA]
      Endif
    Endif
  Endif
  GXX=2
Return

$READ_IVA
# Por rango de fechas revisa los registros de IVA a  tratar. Si no está tratado se crea en las tablas
# Si se ha gestionado se debe comprobar si se ha modifiado. Si no modificado NADA A HACER
# Si modificado se elimina  y se crea como modificado en las tablas

# By date range check the VAT records to be processed If not processed it is created in the tables
# If it has been managed, check if it has been modified. If not modified NOTHING TO DO
# If modified, it is deleted and created as modified in the tables
  If clalev([F:DSII])=0 : Local File DCLSII  [DSII] : Endif

  Local Integer WVCRLIN, WTYPCOM, WRETEN, WTRT, WCAJA
  WTRT=0
  Local Date WSTRDAT, WSTREND
  Raz CRITERE
  Local Datetime WDATVCRORI
  Local Char WCRYORI(40)
#  Local Decimal WRCG, WAMTATI
  Local Decimal WRCG, WAMTATI, WAMTATIFMOSS #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
  CRITERE = '[F:DVS]CPY="'+[M:DSII]CPY+'"'
  If [M:DSII]FCY<>""
    CRITERE -= '& [F:DVS]FCY="'+[M:DSII]FCY+'"'
  Endif

  If [M:DSII]BPR<>""
    CRITERE -= '& [F:DVS]BPRNUM="'+[M:DSII]BPR+'"'
  Endif

  WDATE=[M:DSII]DATINI

  If val(WDATE)=0: WDATE=date$: Endif

  If [M:DSII]DATINI=[0/0/0]: [M:DSII]DATINI=gdat$(1,month(WDATE),year(WDATE))  Endif
  If [M:DSII]DATEND=[0/0/0]: [M:DSII]DATEND=gdat$(eomonth(WDATE))  Endif

  WSTRDAT=[M:DSII]DATINI
  WSTREND=[M:DSII]DATEND

  If  val([M:DSII]DATINI)>val(GFECSII)
    WTRT=1
  Else
    If val([M:DSII]DATEND)>val(GFECSII)
      WSTRDAT=GFECSII+1
      WTRT=1
    Endif
  Endif

  CRITERE -= '& [F:DVS]ACCDAT>=['+format$(GFMD,WSTRDAT)+']'
  CRITERE -= '& [F:DVS]ACCDAT<=['+format$(GFMD,WSTREND)+']'

  GPOINT = "AFTDEFCRI":  Gosub ENTREE From EXEFNC

  If WTRT<>1 : Return: Endif

  Read [CPY]CPY0=[M:DSII]CPY
  If fstat=[V]CST_AOK # Si no hay recargo en el periodo no se penaliza rendimiento\
    Filter [DVS] Where evalue(CRITERE) and VATTYP=2  #If there is no surcharge in the period, there is no performance penalty
    If rowcount([DVS])>0: WRETEN=1: Else WRETEN=0: Endif
    Filter [DVS]

    Filter [DVS] Where evalue(CRITERE) and REGTYP>10    #Si no hay IVA de caja no se penaliza rendimiento
    If rowcount([DVS])>0: WCAJA=1: Else WCAJA=0: Endif  #If there is no Cash VAT there is no performance penalty
    Filter [DVS]

    For [F:DVS]DVS1 Where evalue(CRITERE)
      Raz  WFLGMOD, WTYPCOM, OKK # (WFLGMOD: 1-ya existe; 0-modificado o nuevo) (1-already exist; 0.modified or new)
      If [F:DVS]VATTYP<>2
        Local File DCLVATSPA [WYDVS]
        Raz WRCG, WAMTATI, WAMTATIFMOSS #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
        For [WYDVS] Where NUM=[F:DVS]NUM & VATTYP=1 & TAXTYP=[F:DVS]TAXTYP & TYP=[F:DVS]TYP & REGTYP<4
         If [F:DVS]CODOPE="P" or [F:DVS]CODOPE="I" and [F:DVS]ACCDAT>=[01/01/2020] #importe total sin tasa en factura en CEE e ISP 20/11/19
           WAMTATI+=[F:WYDVS]AMTNOTL
         Else
           WAMTATI+=[F:WYDVS]AMTNOTL+[F:WYDVS]AMTTAXL
         Endif
         #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
         If [F:DVS]SPAMOSS: WAMTATIFMOSS+=[F:WYDVS]AMTNOTL : Endif
        Next
        If WRETEN=1  #calculamos recargo
          For [WYDVS] Where NUM=[F:DVS]NUM & VATTYP=2 & TAXTYP=[F:DVS]TAXTYP & TYP=[F:DVS]TYP & REGTYP<4
            WRCG+=[F:WYDVS]AMTTAXL
          Next
        Endif
        Close File [WYDVS]
      Endif

      #### Pagos y cobros c.c.\PAyments in cash VAT criteria
      If [F:DVS]REGTYP>10
        Raz WRCG, WAMTATI, WAMTATIFMOSS #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
        If WCAJA=1
          Local File DCLVATSPA [WYDVS]
          Raz WRCG, WAMTATI, WAMTATIFMOSS #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
          For [WYDVS] Where NUM=[F:DVS]NUM & REGTYP>10 & REGTYP=[F:DVS]REGTYP
            If [F:DVS]CODOPE="P" or [F:DVS]CODOPE="I" and [F:DVS]ACCDAT>=[01/01/2021]
              WAMTATI+=[F:WYDVS]AMTNOTL
            Else
              WAMTATI+=[F:WYDVS]AMTNOTL+[F:WYDVS]AMTTAXL
            Endif
          Next
          Close File [WYDVS]
        Else
          If [F:DVS]CODOPE="P" or [F:DVS]CODOPE="I" and [F:DVS]ACCDAT>=[01/01/2020]
            WAMTATI+=[F:WYDVS]AMTNOTL
          Else
            WAMTATI=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
          Endif
        Endif
      Endif
      #### Fin Pagos y cobros\ End payments

      Case [F:DVS]TAXTYP
        When "R":   # Emitidas\ issued invoices
          # Comprobamos si existe en SII \ ckecking exist or not in SII
          If [F:DVS]REGTYP<11
            WTYPENV=1
            WVCRLIN=1
          Else
            WTYPENV=5
            WVCRLIN=[F:DVS]REGTYP-10
          Endif
          If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
            Read [DSII]DSII0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;WVCRLIN
          Else
            Read [DSII]DSII2=[F:DVS]CPY;[F:DVS]FCY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;WVCRLIN
          Endif
          If fstat=[V]CST_AOK and [F:DVS]VATTYP=1  #solo tratamos tipo 1
            WFLGMOD=1
            #Comprobamos si hay cambio \ckecking the modifications
            Gosub CHK_MODIF    # WFLGMOD=0 SI NO HAY CAMBIO\ if not modifications
          Else
            Gosub READ_DATVCRORI
          Endif
          If WFLGMOD=0
            Gosub WRI_SII
            OKK=2
          Endif
        When "S":  # Recibidas\received invoices
          # Comprobamos si existe en SII \ ckecking exist or not in SII
          If [F:DVS]REGTYP<11
            WTYPENV=2
            WVCRLIN=1
          Else
            WTYPENV=6
            WVCRLIN=[F:DVS]REGTYP-10
          Endif
          Read [DSII]DSII0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;WVCRLIN
          If fstat=[V]CST_AOK  and [F:DVS]VATTYP=1  #solo tratamos tipo 1 \ only type 1 is traited
            WFLGMOD=1
            #Comprobamos si hay cambio\ckecking the modifications
            Gosub CHK_MODIF    # WFLGMOD=0 SI NO HAY CAMBIO\ if not modifications
          Else
            Gosub READ_DATVCRORI
          Endif
          If WFLGMOD=0
            Gosub WRI_SII
            OKK=2
          Endif
      Endcase
    Next
  Endif
Return

#------------------------------------------------------------------------------#
$READ_CPS
  Local Char WBPRCRN(40), WBPRNAM(80), WBPR(20), WCRY(5),WCRN (40)
  Local Decimal WAMTCSH, WAMTORICAJ
  Local Integer I,J, WNCRN

  If clalev([F:CPS])=0    : Local File CASHPAYSPA [CPS]  : Endif
  If clalev([F:BPR])=0    : Local File BPARTNER   [BPR]  : Endif
  If clalev([F:SIV])=0    : Local File SINVOICEV  [SIV]  : Endif
  If clalev([F:DSIIC])=0  : Local File CSHWRT     [DSIIC]: Endif

  Gosub CALMET

  WTYPENV=7

  If WUPDATE=0
    Trbegin [DSIIC]
      For [DSIIC]
        Raz [F:DSIIC]
        Filter [CPS] Where ACCNUM(0)=[F:DSIIC]ACCNUM
        Read [CPS] First
        If fstat=[V]CST_AOK
          If [F:CPS]INVNUM<>""
            Read [SIV]SIV0=[F:CPS]INVNUM
            If fstat=[V]CST_AOK
              If dim([F:SIV]BPIEECNUM)>0
                If [F:SIV]BPIEECNUM<>""
                  [F:DSIIC]NIP    =[F:SIV]BPIEECNUM
                  [F:DSIIC]BPRNAM =[F:SIV]BPINAM
                Endif
              Endif
            Endif
          Endif
          If [F:DSIIC]NIP=""
            Read[BPR]BPR0=[F:CPS]BPRNUM
            If fstat=[V]CST_AOK
              [F:DSIIC]NIP=[F:BPR]CRN
            Endif
          Endif
          If [F:DSIIC]NIP="":  [F:DSIIC]NIP="SIN_NIF": Endif
          [F:DSIIC]IMPORTE=[F:CPS]AMOUNT
          [F:DSIIC]BPRNUM=[F:CPS]BPRNUM
          Rewrite [DSIIC]
        Endif
      Next
    Commit
  Endif

  Raz WBPRCRN

  For [DSIIC]DSIIC1
    If WBPRCRN <> [F:DSIIC]NIP  and WBPRCRN <>"" : Gosub CHK_WRI:  Raz WAMTCSH:  Endif
    WAMTCSH+=[F:DSIIC]IMPORTE
    WBPR=[F:DSIIC]BPRNUM
    WBPRCRN=[F:DSIIC]NIP
    WBPRNAM=[F:DSIIC]BPRNAM
    Read[BPR]BPR0=[F:DSIIC]BPRNUM
    If fstat=[V]CST_AOK
      If WBPRNAM=""
        WBPRNAM=[F:BPR]BPRNAM(0)
      Endif
      WCRY=[F:BPR]CRY
    Else
      Raz WBPRNAM, WCRY
    Endif
  Next

  If WBPRCRN <>"": Gosub CHK_WRI:  Raz WAMTCSH, WBPRCRN:  Endif

  Gosub MNG_CANCEL_CASH

  Trbegin [DSIIC]
     Delete [DSIIC] Where ACCNUM>=0
  Commit

  Close File [CPS], [BPR], [DSIIC], [SIV]
$NOTRAIT
Return

#------------------------------------------------------------------------------#
$CHK_WRI
  If WAMTCSH>=6000
    Gosub WRI_CASH
  Else
   ##buscar si cancelación\ searching for cancellation
    Gosub CHK_PROFLG_CASH
  Endif

Return

#------------------------------------------------------------------------------#
$MNG_CANCEL_CASH
  If GSIIEXTAP=1
    If GSIIFCY=1 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Filter [DSII] Where CPY=[M:DSII]CPY and TYPENV=7 and TYPANUAL="M" and year(DATOPE)=year([M:DSII]DATINI)
    Else
      Filter [DSII] Where CPY=[M:DSII]CPY and FCY=[M:DSII]FCY and TYPENV=7 and TYPANUAL="M" and year(DATOPE)=year([M:DSII]DATINI)
    Endif
    For [F:DSII]
      Read [DSIIC]DSIIC1=[F:DSII]NIP
      If fstat<>[V]CST_AOK
        # Cancelación \ cacellation
        If [F:DSII]STADOC=1
          # borramos registro \ deleting record
          Trbegin  [DSII]
            Delete Curr
          Commit
        Endif
        If [F:DSII]STADOC=2 and [F:DSII]TYPCOM<3
          Gosub CHG_STATUS
        Endif
      Endif
    Next
  Endif
Return

#------------------------------------------------------------------------------#
$MNG_CANCEL
  Local Integer WDEL: WDEL=0
  Local Integer WTRT: WTRT=0
  Local Date WSTRDAT, WSTREND
  Local Decimal WAMTORICAJ

  If GSIIEXTAP=1
    Local Char  CRITCAN (250)

    WSTRDAT=[M:DSII]DATINI
    WSTREND=[M:DSII]DATEND

    If  val([M:DSII]DATINI)>val(GFECSII)
      WTRT=1
    Else
      If val([M:DSII]DATEND)>val(GFECSII)
        WSTRDAT=GFECSII+1
        WTRT=1
      Endif
    Endif

    If WTRT<>1 : Return: Endif

    CRITCAN="1=1"
    If [M:DSII]STAALL<>2      : CRITCAN -= ' & [F:DSII]VCRSTA='+num$([M:DSII]VCRSTA)       : Endif
    If [M:DSII]ALLCOM<>2      : CRITCAN -= ' & [F:DSII]TYPCOM='+num$([M:DSII]TYPCOM)       : Endif
    If [M:DSII]BPR<>""        : CRITCAN -= ' & [F:DSII]BPR="'+[M:DSII]BPR+'"'              : Endif
    If [M:DSII]LOT<>""        : CRITCAN -= ' & [F:DSII]LOTNUM="'+[M:DSII]LOT+'"'           : Endif
    If [M:DSII]VCRERRNUM<>""  : CRITCAN -= ' & [F:DSII]VCRERRNUM="'+[M:DSII]VCRERRNUM+'"'  : Endif

    Local File DCLVATSPA [WYDVS]
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Filter [DSII] Where CPY=[M:DSII]CPY and TYPENV<=2 and DATOPE>=WSTRDAT and DATOPE<=WSTREND & evalue(CRITCAN)
    Else
      Filter [DSII] Where CPY=[M:DSII]CPY and FCY=[M:DSII]FCY and TYPENV<=2 and DATOPE>=WSTRDAT and DATOPE<=WSTREND & evalue(CRITCAN)
    Endif
    For [F:DSII]
      If [F:DSII]STADOC=1 and [F:DSII]TYPCOM=3 : Goto PEN_CANCEL: Endif
      Filter [WYDVS]
        If [F:DSII]TYPENV=1
        Read [WYDVS]DVS5="R";[F:DSII]NIP;[F:DSII]GTE;[F:DSII]VCRNUM
        If fstat<>[V]CST_AOK
          Filter [WYDVS] Where CPY=[M:DSII]CPY and TAXTYP="R" and TYP=[F:DSII]GTE and NUM=[F:DSII]VCRNUM
          If REGTYP<11
            Read [WYDVS] First
          Else
            WAMTORICAJ=[F:DSII]AMTATI
            Read [WYDVS] First
          Endif
        Endif
      Elsif [F:DSII]TYPENV=2
        Read [WYDVS]DVS5="S";[F:DSII]NIP;[F:DSII]GTE;[F:DSII]VCRNUM
        If fstat<>[V]CST_AOK
          Filter [WYDVS] Where CPY=[M:DSII]CPY and TAXTYP="S" and TYP=[F:DSII]GTE and NUM=[F:DSII]VCRNUM # and REGTYP<11
          If REGTYP<11
            Read [WYDVS] First
          Else
            WAMTORICAJ=[F:DSII]AMTATI
            Read [WYDVS] First
          Endif
        Endif
      Endif
      If fstat<>[V]CST_AOK
        WDEL=1
        #gestión tax-free 4/12/19
        If [F:DSII]CODOPE="0"
          Filter [WYDVS] Where TAXTYP="R" and NUM=[F:DSII]BPRVCR # and CRN=[F:DSII]NIP # X3-237572 SII Monitor by site by DAFER 2021-06-16
          Read [WYDVS]DVS0 First
          If fstat=[V]CST_AOK: WDEL=0: Endif
          Filter [WYDVS]
        Endif
      Endif
      $PEN_CANCEL
      Gosub CHK_PROFLG
    Next
    Close File [WYDVS]
  Endif
Return

#------------------------------------------------------------------------------#
$CHK_PROFLG
  If [F:WYDVS]PROFLG=1 or WDEL=1
    If [F:DSII]STADOC=1
      # borramos registro \deleting record
      Trbegin [DSII]
        Delete Curr
      Commit
    Endif
    If [F:DSII]STADOC=2 and [F:DSII]TYPCOM<3
      # pasarla a cancelada\ changing to cancellation
      Gosub CHG_STATUS
    Endif
  Endif
  Raz WDEL
Return

#------------------------------------------------------------------------------#
$CHK_PROFLG_CASH
  Local Char WVCRNUM(60)
  If WBPRCRN="": WBPRCRN=[F:DSIIC]NIP: Endif
  WVCRNUM=WBPRCRN+"-"+num$(year([M:DSII]DATINI))+"-M"
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Read [DSII]DSII0=[M:DSII]CPY;7;"";WVCRNUM;1
  Else
    Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;7;"";WVCRNUM;1
  Endif
  #Read [DSII]DSII1=[M:DSII]CPY+"7"+WVCRNUM+"1"
  If fstat=[V]CST_AOK
    If [F:DSII]STADOC=1
    # borramos registro \deleting record
      Trbegin [DSII]
        Delete Curr
      Commit
    Endif
    If [F:DSII]STADOC=2 and [F:DSII]TYPCOM<3
      # pasarla a cancelada \changing to cancellation
     Gosub CHG_STATUS
     Endif
  Endif
Return

#------------------------------------------------------------------------------#
$CHG_STATUS
  Trbegin [DSII]
    If WAMTORICAJ<>0
      [F:DSII]TYPCOM=1
      [F:DSII]AMTATI=[F:DSII]AMTATI*-1
      [F:DSII]AMTATIORI=WAMTORICAJ
    Else
      [F:DSII]TYPCOM=3
    Endif
    [F:DSII]STADOC=1
    [F:DSII]VCRSTA=1
    Raz [F:DSII]VCRERRNUM, VCRERRDES, LOTNUM, TIMESTAMP
    Rewrite
  Commit
Return

#------------------------------------------------------------------------------#
$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#------------------------------------------------------------------------------#
$WRI_SII
  GOK = 1 : OKK=1
  Local Integer  NBREC, WRITEOK
  Local Char  WFATYP(2)
  WRITEOK=1
  AUXINT=1
  If WTYPCOM=0 : WTYPCOM=1:  Endif
  Filter [F:DSII]

  Trbegin [F:DSII]
  Raz [F:DSII]
  If [F:DVS]TAXTYP="R" and [F:DVS]ORIMOD<>2
    If !clalev([F:SIH]): Local File SINVOICE: Endif
    Read [F:SIH]SIH2=[F:DVS]TYP;[F:DVS]NUM
    If fstat<>[V]CST_AOK :AUXINT=0: Endif
  Endif

  If [F:DVS]REGTYP=4 : AUXINT=0  : Endif      ## Excluimos retenciones\ retentions are excluded
  If [F:DVS]VATTYP=2 : AUXINT=0  : Endif      ## Excluimos recargos \Surcharges are excluded
  If [F:DVS]TAXTYP="S" and [F:DVS]REGTYP=1 : WTYPENV=2 : Endif
  If [F:DVS]REGTYP>10   #payments Cash VAT
    If [F:DVS]TAXTYP="S": WTYPENV=6 Else WTYPENV=5: Endif
  Endif      # Cobros y pagos caja


  If WTYPENV=5 or WTYPENV=6
    If year([F:DVS]BPRDAT)<2017: AUXINT=0: Endif
  Endif

  #Buscamos rectificativa si es abono \searching rctification if it is a credit note
  Raz [F:DSII]TYPREC

  If [F:DVS]TAXTYP="S"
    Local File DCLVATSPA [WYDVS]
    If [F:DVS]INVTYP=2
      Filter [WYDVS] Where INVTYP=1 and BPRNUM=[F:DVS]BPRNUM and (BPRVCR=[F:DVS]BPRVCR & [F:DVS]BPRVCR<>"") and BPRDAT=[F:DVS]BPRDAT
      Read First
      If fstat=[V]CST_AOK
        AUXINT=0    ## No escribimos el abono \Credit note is not write
      Else
        [F:DSII]TYPREC="I"    ## Es por diferencias \It is by different
      Endif
    Else
      Filter [WYDVS] Where INVTYP=2 and BPRNUM=[F:DVS]BPRNUM and (BPRVCR=[F:DVS]BPRVCR & [F:DVS]BPRVCR<>"") and BPRDAT=[F:DVS]BPRDAT
      Read First
      If fstat=[V]CST_AOK
        [F:DSII]TYPREC="S"    ## Es por sustitución \It is by sustitution
      Else
        [F:DSII]TYPREC=""
      Endif
    Endif
    Close File [WYDVS]
  Else
    If [F:DVS]INVTYP=2
      [F:DSII]TYPREC="I"    ## Es por diferencias siempre en Ventas \ allways by differents in Sales
    Endif
  Endif

  ## Escritura de registros\ Writting records
  If AUXINT=1
    If WTYPENV<>5 and WTYPENV<>6
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Read [DSII]DSII0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;"1"
      Else
        Read [DSII]DSII2=[F:DVS]CPY;[F:DVS]FCY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM+"1"
      Endif
    Else
      If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
        Read [DSII]DSII0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;([F:DVS]REGTYP-10):
       Else
        Read [DSII]DSII2=[F:DVS]CPY;[F:DVS]FCY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;([F:DVS]REGTYP-10)
      Endif
    Endif
    If fstat<>[V]CST_AOK

      [F:DSII]FLGSEL=2
      If WTYPENV=2 and [F:DVS]BPRVCR="": [F:DSII]FLGSEL=1: Endif
      If WTYPENV=6 and [F:DVS]BPRVCR="": [F:DSII]FLGSEL=1: Endif
      [F:DSII]TYPENV=WTYPENV
      [F:DSII]STADOC=1
      [F:DSII]TYPCOM=WTYPCOM
      [F:DSII]GTE=[F:DVS]TYP
      [F:DSII]VCRNUM=[F:DVS]NUM
      If WTYPENV=5 or  WTYPENV=6
        [F:DSII]VCRLIN=[F:DVS]REGTYP-10
      Else
        [F:DSII]VCRLIN=1
      Endif
      [F:DSII]CPY=[F:DVS]CPY
      [F:DSII]FCY=[F:DVS]FCY
      [F:DSII]DATOPE= [F:DVS]ACCDAT

      Local Integer INVKSP: INVKSP=0
      Local File SINVOICE [KSIH]
      If dim([F:KSIH]INVTYPSPA)>0 and WTYPENV=1 # Only uses in issue invoice for the momment
        Read[KSIH]SIH0=[F:DVS]NUM
        If fstat=[V]CST_AOK
          [F:DSII]VCRTYP=[F:KSIH]INVTYPSPA
          INVKSP=1
        Endif
      Endif
      Close File [KSIH]

      If INVKSP=0
        If [F:DVS]INVTYP=1
          [F:DSII]VCRTYP=1
          If [F:DVS]TCKNUM>0 or [F:DVS]CODOPE="J": [F:DSII]VCRTYP=2: Endif
          If [F:DVS]CODOPE="O": [F:DSII]VCRTYP=8: Endif
          If [F:DSII]TYPREC="S" and [F:DSII]VCRTYP=2: [F:DSII]VCRTYP=8: Endif
          If [F:DSII]TYPREC="S" and [F:DSII]VCRTYP=1
            If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
              Call PARAML([F:DSII]CPY,"SIIABTYP",WFATYP) From ADOVAL
            Else
              Call PARAML([F:DSII]FCY,"SIIABTYP",WFATYP) From ADOVAL
            Endif
            If val(WFATYP)<>0: [F:DSII]VCRTYP=val(WFATYP): Else [F:DSII]VCRTYP =6 Endif
          Endif
        Elsif [F:DVS]INVTYP=2
          If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
            Call PARAML([F:DSII]CPY,"SIIABTYP",WFATYP) From ADOVAL
          Else
            Call PARAML([F:DSII]FCY,"SIIABTYP",WFATYP) From ADOVAL
          Endif
          If val(WFATYP)<>0: [F:DSII]VCRTYP=val(WFATYP): Else [F:DSII]VCRTYP =6 Endif
          If [F:DVS]TCKNUM>0 or [F:DVS]CODOPE="J": [F:DSII]VCRTYP=7: Endif
        Endif
        If [F:DVS]CODOPE="A" or [F:DVS]CODOPE="B": [F:DSII]VCRTYP=9: Endif
        If [F:DVS]CODOPE="X" and [F:DVS]INVTYP=1: [F:DSII]VCRTYP=11:  Endif

        If [F:DVS]INVTYP=1
          If [F:DVS]TAXTYP="S" and [F:DVS]REGTYP=3 and [F:DVS]DOCTYP=6
            Local File TABCOUNTRY [TCY]
            Read [TCY]TCY0=[F:DVS]CRY
            If fstat=[V]CST_AOK and [F:TCY]EECFLG<>2
              [F:DSII]VCRTYP=11
            Endif
            Close File [TCY]
          Endif
          If [F:DVS]CODOPE<>"P" and [F:DVS]SCDREF=""
            Local File TABVAT     [TVT]
            Local File TABVACBPR  [TVB]
            Read [TVT]TVT0=[F:DVS]VAT;"SPA"
              If fstat=[V]CST_AOK # Factura CEE con iva local X3-237572 SII Monitor by site by DAFER 2021-06-16
                If [F:TVT]SPASPETAX=2 and [F:TVB]SPAEXEOPE<>2
                  [F:DSII]VCRTYP=11
                Elsif [F:TVT]SPASPETAX=2 and [F:TVB]SPAEXEOPE=2
                  [F:DSII]VCRTYP=1
                Endif
              Else
                Read [TVT]TVT0=[F:DVS]VAT
                If fstat=[V]CST_AOK  # Factura CEE con iva local X3-237572 SII Monitor by site by DAFER 2021-06-16
                  If [F:TVT]SPASPETAX=2 and [F:TVB]SPAEXEOPE<>2
                    [F:DSII]VCRTYP=11
                  Elsif [F:TVT]SPASPETAX=2 and [F:TVB]SPAEXEOPE=2
                    [F:DSII]VCRTYP=1
                  Endif
                Endif
              Endif
            Close File [TVT], [TVB]
          Endif
        Endif
      Endif

      [F:DSII]BPR=[F:DVS]BPRNUM
      [F:DSII]BPRNAM=[F:DVS]BPRNAM
      [F:DSII]CRY=[F:DVS]CRY
      If WCRYORI<>"": [F:DSII]CRY=WCRYORI: Endif
      [F:DSII]CODOPE=[F:DVS]CODOPE
      [F:DSII]NIP=[F:DVS]CRN

      If [F:DVS]SCDREF<>"" and [F:DVS]IMPORT=1
        Local File COMPANY [WCPY]
        Read [WCPY]CPY0=[M:DSII]CPY
        [F:DSII]VCRTYP=10
        [F:DSII]BPRVCR=[F:DVS]NUM
        [F:DSII]DATOPE= [F:DVS]DCLDAT
        [F:DSII]BPR=[F:WCPY]CPY
        [F:DSII]BPRNAM=[F:WCPY]CPYNAM
        [F:DSII]NIP=[F:WCPY]CRN
        [F:DSII]CRY=[F:WCPY]CRY
        Close File [WCPY]
      Else
        [F:DSII]BPRVCR=[F:DVS]BPRVCR
      Endif
      #INI X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
      If [F:DVS]SPAMOSS=2 and ([F:DSII]VCRTYP=2 or [F:DSII]VCRTYP=9)
        [F:DSII]AMTATI=WAMTATIFMOSS+WRCG
      Else
        [F:DSII]AMTATI=WAMTATI+WRCG #añadimos recargo si lo hay\ adding surcharge
      Endif
      #END X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
      If [F:DSII]CODOPE="0" and dim([F:DVS]SPADERNUM)>0 #X3-233758 DER number in Tax Free Management (JUCON 2021-02-01)
        If [F:DVS]SPADERNUM<>"":[F:DSII]BPRVCR=[F:DVS]SPADERNUM: Endif
      Endif

      [F:DSII]DKEY=[F:DSII]CPY+num$([F:DSII]TYPENV)+[F:DSII]GTE+[F:DSII]VCRNUM+num$([F:DSII]VCRLIN)
      [F:DSII]VCRSTA=1
      [F:DSII]DATDVS=gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP([F:DVS]BPRDAT, 0)))

      [F:DSII]DATVCRORI=WDATVCRORI
      [F:DSII]VCRERRNUM=""
      [F:DSII]VCRERRDES=""
      [F:DSII]FLGNIFREC=1
      GPOINT = "BEFWRISII":  Gosub ENTREE From EXEFNC
      Raz WCRYORI
      If WRITEOK
        Write [F:DSII]
        If fstat : GOK=0 : Call FSTA("DSII") From GLOCK : Endif
      Endif
    Elsif (WTYPENV=5 or WTYPENV=6) and [F:DSII]BPRNAM<>[F:DVS]BPRNAM
      [F:DSII]BPRNAM=[F:DVS]BPRNAM
      Rewrite [F:DSII]
    Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit
  # gestión tax-free \tax-free management
  If [F:DSII]CODOPE="0" and dim([F:DVS]SPADERNUM)>0  #X3-233758 DER number in Tax Free Management (JUCON 2021-02-01)
    If [F:DVS]SPADERNUM<>""
      Gosub CRE_TAXFREE
    Endif
  Endif

  Raz [F:DSII]
Return

$WRI_CASH
  GOK = 1 : OKK=1
  Local Integer  NBREC, WTYPCOM, WRITEOK, WVCRLIN
  Local Char WCSHDOC(60)
  Local Decimal WAMTORI
  WRITEOK=1
  WTYPCOM=1
  WCSHDOC=WBPRCRN+"-"+num$(year([M:DSII]DATINI))+"-M"

  # updating previous records when exist (modified)
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Read [DSII]DSII0=[M:DSII]CPY;WTYPENV;"";WCSHDOC;1
  Else
    Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;WTYPENV;"";WCSHDOC;1
  Endif
  If fstat=[V]CST_AOK
    If [F:DSII]AMTATI<>0
      Gosub CHK_MODIF_CSH
    Endif
  Endif

  Trbegin [DSII]
  AUXINT=1
  ## Writting records
  If AUXINT=1
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Read [DSII]DSII0=[M:DSII]CPY;WTYPENV;"";WCSHDOC;1
    Else
      Read [DSII]DSII2=[M:DSII]CPY;[M:DSII]FCY;WTYPENV;"";WCSHDOC;1
    Endif
    If fstat=[V]CST_AOK
      #nothing to do
    Else
      [F:DSII]FLGSEL=2
      [F:DSII]TYPENV=WTYPENV
      [F:DSII]STADOC=1
      [F:DSII]TYPCOM=WTYPCOM
      [F:DSII]GTE=""
      [F:DSII]TYPANUAL="M"
      [F:DSII]VCRNUM=WCSHDOC
      [F:DSII]VCRLIN=1
      [F:DSII]CPY=[M:DSII]CPY
      [F:DSII]FCY=[M:DSII]FCY # X3-237572 SII Monitor by site by DAFER 2021-06-16
      [F:DSII]VCRTYP =1
      [F:DSII]BPR=WBPR
      [F:DSII]BPRNAM=WBPRNAM
      [F:DSII]TYPCOM=WTYPCOM
      [F:DSII]CRY=WCRY
      [F:DSII]NIP=WBPRCRN
      [F:DSII]DATOPE= gdat$(31,12,year([M:DSII]DATINI))
      [F:DSII]AMTATIORI=WAMTORI
      If [F:DSII]AMTATIORI<>0
        [F:DSII]AMTATI=[F:DSII]AMTATIORI-WAMTCSH
        [F:DSII]AMTATIORI=WAMTCSH
      Else
        [F:DSII]AMTATI=WAMTCSH    # Amount in EUR
      Endif
      [F:DSII]DKEY=[F:DSII]CPY+num$([F:DSII]TYPENV)+[F:DSII]GTE+[F:DSII]VCRNUM+num$([F:DSII]VCRLIN)
      [F:DSII]VCRSTA=1
      [F:DSII]VCRERRNUM=""
      [F:DSII]VCRERRDES=""

      GPOINT = "BEFWRICSH":  Gosub ENTREE From EXEFNC

      If WRITEOK
        Write [F:DSII]
        If fstat : GOK=0 : Call FSTA("DSII") From GLOCK : Endif
      Endif
    Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit

  Raz [F:DSII]
Return

##########################################
$WRI_BIENCO #Bienes consigna DAFER X3-212589 11-11-2020
  Local File DCLSII [XDSII]
  Trbegin [XDSII]
  ## Writting records
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Read [XDSII]DSII0=[F:SDH]CPY;WTYPENV;""+[F:SDH]SDHNUM;WVCRLIN
  Else
    Read [XDSII]DSII2=[F:SDH]CPY;[F:SDH]SALFCY;WTYPENV;"";[F:SDH]SDHNUM;num$(WVCRLIN)
  Endif
  If fstat<>[V]CST_AOK
    [F:XDSII]FLGSEL=2
    [F:XDSII]TYPENV=WTYPENV
    [F:XDSII]GTE=""
    [F:XDSII]STADOC=1
    [F:XDSII]TYPCOM=1
    [F:XDSII]VCRNUM=[F:SDH]SDHNUM
    [F:XDSII]VCRLIN=WVCRLIN
    [F:XDSII]CPY=[F:SDH]CPY
    [F:XDSII]FCY=[F:SDH]SALFCY
    [F:XDSII]DATOPE= [F:SDH]DLVDAT
    [F:XDSII]VCRTYP=1
    [F:XDSII]BPR=[F:SDH]BPCORD
    [F:XDSII]BPRNAM=[F:SDH]BPDNAM
    [F:XDSII]CRY=[F:SDH]BPDCRY
    Read [FCY]FCY0=[F:SDH]SALFCY
    If fstat=[V]CST_AOK
      [F:XDSII]ORICRY=[F:FCY]CRY
    Endif
    [F:XDSII]DESCRY=[F:SDH]BPDCRY
    [F:XDSII]TYPOPECON=1
    [F:XDSII]NIP=[F:SDH]BPIEECNUM
    [F:XDSII]VALBIEN=[F:SDD]NETPRIATI*[F:SDD]QTY
    [F:XDSII]EXPDAT=[F:XDSII]DATOPE
    [F:XDSII]CLADECCON="V"
    [F:XDSII]QTY=[F:SDD]QTY
    [F:XDSII]UNIPRI=[F:SDD]GROPRI
    [F:XDSII]DESBIENES=[F:SDD]ITMDES
    [F:XDSII]VALBASIMP=[F:SDD]NETPRINOT*[F:SDD]QTY
    [F:XDSII]DIRECOPE=[F:SDH]BPDADDLIG(0)+[F:SDH]BPDADDLIG(1)+"."-[F:SDH]BPDCTY+"."-[F:SDH]BPDPOSCOD-[F:SDH]BPDCRYNAM
    [F:XDSII]DKEY=[F:XDSII]CPY+num$([F:XDSII]TYPENV)+[F:XDSII]GTE+[F:XDSII]VCRNUM+num$([F:XDSII]VCRLIN)
    [F:XDSII]VCRSTA=1
    [F:XDSII]DATDVS=gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP([F:SDH]DLVDAT, 0)))
    [F:XDSII]VCRERRNUM=""
    [F:XDSII]VCRERRDES=""
    [F:XDSII]FLGNIFREC=1
    Write [F:XDSII]
    If fstat : GOK=0 : Call FSTA("XDSII") From GLOCK : Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit
  Close File [XDSII]
Return

###################################
$WRI_BIENCO_RE # Bienes consigna DAFER X3-212589 11-11-2020
  ## Writting records
  Local File DCLSII [XDSII]
  Trbegin [XDSII]
  If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
    Read [XDSII]DSII0=[F:SRD]CPY;WTYPENV;"";[F:SRD]SRHNUM;WVCRLIN
  Else
    Read [XDSII]DSII2=[F:SRD]CPY;[F:SRD]STOFCY;WTYPENV;"";[F:SRD]SRHNUM;WVCRLIN
  Endif
  If fstat<>[V]CST_AOK
    [F:XDSII]FLGSEL=2
    [F:XDSII]TYPENV=WTYPENV
    [F:XDSII]GTE=""
    [F:XDSII]STADOC=1
    [F:XDSII]TYPCOM=1
    [F:XDSII]VCRNUM=[F:SRD]SRHNUM
    [F:XDSII]BPRVCR=[F:SDH]SDHNUM
    [F:XDSII]VCRLIN=WVCRLIN
    [F:XDSII]CPY=[F:SRD]CPY
    [F:XDSII]FCY=[F:SRD]STOFCY
    [F:XDSII]DATOPE= [F:SRD]RTNDAT
    [F:XDSII]VCRTYP=1
    [F:XDSII]BPR=[F:SDH]BPCORD
    [F:XDSII]BPRNAM=[F:SDH]BPDNAM
    [F:XDSII]CRY=[F:SDH]BPDCRY
    [F:XDSII]ORICRY=[F:SDH]BPDCRY
    Read [FCY]FCY0=[F:SDH]SALFCY
    If fstat=[V]CST_AOK
      [F:XDSII]DESCRY=[F:FCY]CRY
    Endif
    [F:XDSII]TYPOPECON=9
    [F:XDSII]NIP=[F:SDH]BPIEECNUM
    [F:XDSII]VALBIEN=[F:SRD]NETPRIATI*[F:SRD]QTY
    [F:XDSII]EXPDAT=[F:XDSII]DATOPE
    [F:XDSII]CLADECCON="A"
    [F:XDSII]QTY=[F:SRD]QTY
    [F:XDSII]VALBASIMP=[F:XDSII]QTY*[F:SRD]NETPRINOT
    [F:XDSII]UNIPRI=[F:SDD]GROPRI
    [F:XDSII]DESBIENES=[F:SDD]ITMDES
    [F:XDSII]DIRECOPE=[F:SDH]BPIADDLIG(0)+[F:SDH]BPIADDLIG(1)+"."-[F:SDH]BPICTY+"."-[F:SDH]BPIPOSCOD-[F:SDH]BPICRYNAM
    [F:XDSII]DKEY=[F:XDSII]CPY+num$([F:XDSII]TYPENV)+[F:XDSII]GTE+[F:XDSII]VCRNUM+num$([F:XDSII]VCRLIN)
    [F:XDSII]VCRSTA=1
    [F:XDSII]DATDVS=gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP([F:SDH]DLVDAT, 0)))
    [F:XDSII]VCRERRNUM=""
    [F:XDSII]VCRERRDES=""
    [F:XDSII]FLGNIFREC=1
    Write [F:XDSII]
    If fstat : GOK=0 : Call FSTA("XDSII") From GLOCK : Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit
  Close File [XDSII]
Return

#------------------------------------------------------------------------------#
$CHK_MODIF
  Local Integer WCHG, WORIMOD
  Raz WCHG
  If [F:DVS]REGTYP=4: Return: Endif

  If [M:DSII]BPR<>""       & [F:DSII]BPR<>[M:DSII]BPR             : Return: Endif
  If [M:DSII]VCRERRNUM<>"" & [F:DSII]VCRERRNUM<>[M:DSII]VCRERRNUM : Return: Endif
  If [M:DSII]LOT<>""       & [F:DSII]LOTNUM<>[M:DSII]LOT          : Return: Endif

  If [F:DVS]CODOPE<>[F:DSII]CODOPE |([F:DVS]BPRNAM(0)<>[F:DSII]BPRNAM & [F:DSII]VCRTYP<>10)|([F:DSII]DATOPE<>[F:DVS]ACCDAT & [F:DSII]VCRTYP<>10)
    WCHG=1
  Endif

  If WCHG=0
    If [F:DSII]AMTATI <>WAMTATI+WRCG : WCHG=1: Endif
    If [F:DVS]SPAMOSS=2 and ([F:X025SI]VCRTYP=2 or [F:X025SI]VCRTYP=9) #X3-255939 Amount displayed in SII monitor for MOSS invoices (JUCON 2021-08-25)
      If [F:X025SI]AMTATI <>WAMTATIFMOSS+WRCG : WCHG=1: Else WCHG=0: Endif
    Endif
  Endif

  If WCHG=0 & len([F:DVS]CRN)>9 and [F:DSII]VCRTYP<>10
    If [F:DVS]CRY<>[F:DSII]CRY & len([F:DVS]CRN)<>len([F:DSII]NIP)  & right$([F:DVS]CRN,len([F:DVS]CRN)-8)<>[F:DSII]NIP
      WCHG=1
    Endif
  Endif
  If [F:DSII]TYPCOM=3 and [F:DSII]STADOC=1: WCHG=1: Endif
  If WCHG=1
    WFLGMOD=0
#    If [F:DSII]CODOPE="0": Gosub CHG_TAXFREE: Endif   #tax-free
    If [F:DSII]CODOPE="0" and dim([F:DVS]SPADERNUM)>0 : Gosub CHG_TAXFREE: Endif   #X3-233758 DER number in Tax Free Management (JUCON 2021-02-01)

    If [F:DSII]STADOC=2
      If [F:DVS]PROFLG=1
        WTYPCOM=3    # Cancelation
      Else
        WTYPCOM=2   # Modification
      Endif
      If [F:DSII]VCRSTA=4 :WTYPCOM=1: Endif # Alta si Rechazada\ creation if rejected
      If [F:DSII]TYPENV=5 or [F:DSII]TYPENV=6:   WTYPCOM=1: Return:  Endif
    Elsif [F:DSII]STADOC=1 and [F:DSII]TYPCOM>1
       If [F:DSII]TYPCOM=3: WTYPCOM=3 Else :  WTYPCOM=2: Endif
    Endif
    Trbegin [DSII]
      Delete Curr
    Commit
    Gosub READ_DATVCRORI
  Endif

Return

#------------------------------------------------------------------------------#
$READ_DATVCRORI
  Local Char WRESGAS(1)
  # Reading the date from original document
  If [F:DVS]PROFLG=1 : WFLGMOD=1: Return : Endif

  WORIMOD=[F:DVS]ORIMOD
  If WORIMOD=3 and [F:DVS]TAXTYP="R": WORIMOD=5: Endif
  If WORIMOD=3 and [F:DVS]TAXTYP="S": WORIMOD=6: Endif

  Case WORIMOD
    When 2: # Finantial
      Local File GACCENTRY [WGAC]
      Read [WGAC]HAE0=[F:DVS]TYP;[F:DVS]NUM
      If fstat=[V]CST_AOK| [F:WGAC]UPDDATTIM<>[F:DSII]DATVCRORI
        WDATVCRORI=[F:WGAC]CREDATTIM
      Endif
      Close File  [WGAC]
    When 5: # Sales
      Local File SINVOICE [WSIH]
      Read [WSIH]SIH2=[F:DVS]TYP;[F:DVS]NUM
      If fstat=[V]CST_AOK
        WDATVCRORI=[F:WSIH]CREDATTIM
        WCRYORI=[F:WSIH]CRY
      Endif
      Close File  [WSIH]
    When 6: # Purchasing
      Local File PINVOICE [WPIH]
      If [F:DVS]IMPORT=1 and [F:DVS]SCDREF<>""
        Local Integer A,B
        Local Char WNUMDUA(40)
        A=1+len([F:DVS]TYP)
        B=1+len([F:DVS]VAT)
        WNUMDUA=seg$([F:DVS]INDLNK,A+1,len([F:DVS]INDLNK)-B)
        Read [WPIH]PIH2=[F:DVS]TYP;WNUMDUA
        If fstat=[V]CST_AOK
          WDATVCRORI=[F:WPIH]CREDATTIM
        Endif
      Else
        Read [WPIH]PIH2=[F:DVS]TYP;[F:DVS]NUM
        If fstat=[V]CST_AOK
          WDATVCRORI=[F:WPIH]CREDATTIM
        Endif
      Endif
      Close File  [WPIH]
  Endcase

#  If WTYPENV=2
    If WTYPENV=2 & WORIMOD=6 # X3-233342 Miscellanous update in SII integrated into the core (JUCON 2021-01-28)
    If GSIIFCY=1 or GSIIEXTAP=2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Call PARAML([M:DSII]CPY,"SIIFGAS",WRESGAS) From ADOVAL
    Else
      Call PARAML([M:DSII]FCY,"SIIFGAS",WRESGAS) From ADOVAL
    Endif
    If val(WRESGAS)=2#
      Local File GACCENTRY [WGAC]
      If[F:DVS]SCDREF<>"":
        Read [WGAC]HAE0=[F:DVS]TYP;WNUMDUA
      Else
        Read [WGAC]HAE0=[F:DVS]TYP;[F:DVS]NUM
      Endif
      If fstat=[V]CST_AOK| [F:XGAC]UPDDATTIM<>[F:DSII]DATVCRORI
        WDATVCRORI=[F:WGAC]CREDATTIM
      Endif
      Close File  [WGAC]
    Endif
  Endif

Return

#------------------------------------------------------------------------------#
$CHK_MODIF_CSH
  If [F:DSII]AMTATI<>WAMTCSH | [F:DSII]BPR<>[F:CPS]BPRNUM | [F:DSII]BPRNAM<>WBPRNAM | [F:DSII]NIP<>WBPRCRN
    If [F:DSII]STADOC=2
      WTYPCOM=2
      WAMTORI=[F:DSII]AMTATIORI
    Elsif [F:DSII]STADOC=1
      WTYPCOM=1
    Endif
    AUXINT=1
    Trbegin [DSII]
      Delete Curr
   Commit
  Else
    AUXINT=0
  Endif

Return

#------------------------------------------------------------------------------#
$CALMET        # Cash payment. Recovering ACCNUM to trait in READ_CPS
  Local Integer WUPDATE: WUPDATE=0
  Local Integer WTRAIT: WTRAIT=2
  Local Char CRITMET (255)

  WDATE=[M:DSII]DATINI

  If val(WDATE)=0: WDATE=date$: Endif

  WDAT1=gdat$(1,1,year(WDATE))
  WDAT2=gdat$(31,12,year(WDATE))

  If dim([F:CPS]CPY)>0: WUPDATE=1: Endif

  If WUPDATE=0 # versión no actualizada se mantine el cálculo anterior
    Local File PAYMENTH   [XYPYH]
    Local File PAYMENTD   [XYPYD]
    Local File PAYACCNUM  [XYPAN]
    Local File TABPAYTYP  [XYTPY]

    CRITMET-='[F:XYPYH]CPY= [M:DSII]CPY'
    If GSIIFCY=2  # X3-237572 SII Monitor by site by DAFER 2021-06-16
      If [M:DSII]FCY<>"": CRITMET-='& [F:XYPYH]FCY= [M:DSII]FCY': Endif
    Endif

    CRITMET -= '& [F:XYPYH]ACCDAT>=['+format$(GFMD,WDAT1)+']'
    CRITMET -= '& [F:XYPYH]ACCDAT<=['+format$(GFMD,WDAT2)+']'

    If [M:DSII]BPR<>"": CRITMET-='& [F:XYPYH]BPR= [M:DSII]BPR' : Endif
    GPOINT = "AFTCRIMET":  Gosub ENTREE From EXEFNC

    If WTRAIT=2
    # Search for cash payment
      If [M:DSII]BPR=""
        Link [XYPYD] With [XYPYH]PYH0=[F:XYPYD]NUM, [XYTPY]TPY0=[F:XYPYH]PAYTYP As [PYHX] Order By Key KEY1=[XYPYH]BPR
      Else
        Link [XYPYD] With [XYPYH]PYH0=[F:XYPYD]NUM, [XYTPY]TPY0=[F:XYPYH]PAYTYP As [PYHX] Order By Key KEY1=[M:DSII]BPR
      Endif
      Filter [PYHX] Where year([F:XYPYH]ACCDAT)=year(WDATE) & [F:XYPYH]SNS=2 & [F:XYTPY]SPACSH=2 & evalue (CRITMET)

      Trbegin [DSIIC]
        For [PYHX]KEY1
          Filter [XYPAN] Where TYPNUM=3 and STA=3 and NUM=[F:PYHX]NUM and RVSACCNUM=0
          Read [XYPAN]PAN0 First
          Filter [XYPAN]
          If fstat=[V]CST_AOK
            [F:DSIIC]ACCNUM=[F:CPS]ACCNUM
            Write [DSIIC]
          Endif
        Next
      Commit
    Endif

    Close File [XYPYH], [XYPYD], [XYPAN], [XYTPY]

  Else   # WUPDATE=1 : Lectura en la nueva estructura actualizada

    CRITMET-='[F:CPS]CPY= [M:DSII]CPY'
    If GSIIFCY=2  # X3-237572 SII Monitor by site by DAFER 2021-06-16
      If [M:DSII]FCY<>"": CRITMET-='& [F:CPS]FCY= [M:DSII]FCY': Endif
    Endif

    CRITMET -= '& [F:CPS]DATGAS>=['+format$(GFMD,WDAT1)+']'
    CRITMET -= '& [F:CPS]DATGAS<=['+format$(GFMD,WDAT2)+']'

    If [M:DSII]BPR<>"": CRITMET-='& [F:CPS]BPRNUM= [M:DSII]BPR' : Endif
    GPOINT = "AFTCRIMET":  Gosub ENTREE From EXEFNC

    If WTRAIT=2
      Trbegin [DSIIC]
        If [M:DSII]BPR=""
          Filter [CPS] Where evalue (CRITMET) Order By Key CPS2
        Else
          Filter [CPS] Where evalue (CRITMET)
        Endif
        For [CPS]
          Raz [F:DSIIC]
          [F:DSIIC]ACCNUM=[F:CPS]ACCNUM
          [F:DSIIC]LIN=[F:CPS]LIN
          If [F:CPS]INVNUM<>""
            Read [SIV]SIV0=[F:CPS]INVNUM
            If fstat=[V]CST_AOK
              If dim([F:SIV]BPIEECNUM)>0
                If [F:SIV]BPIEECNUM<>""
                  If left$([F:SIV]BPIEECNUM,2)="ES"
                    [F:DSIIC]NIP    =mid$([F:SIV]BPIEECNUM,3,9)
                  Else
                    [F:DSIIC]NIP    =[F:SIV]BPIEECNUM
                  Endif
                  [F:DSIIC]BPRNAM =[F:SIV]BPINAM
                Endif
              Endif
            Endif
          Endif
          If [F:DSIIC]NIP=""
            Read[BPR]BPR0=[F:CPS]BPRNUM
            If fstat=[V]CST_AOK
              [F:DSIIC]NIP=[F:BPR]CRN
            Endif
          Endif
          If [F:DSIIC]NIP="":  [F:DSIIC]NIP="SIN_NIF": Endif
          [F:DSIIC]IMPORTE=[F:CPS]AMOUNT
          [F:DSIIC]BPRNUM=[F:CPS]BPRNUM
          Write [DSIIC]
        Next
      Commit
    Endif
  Endif

  If WTRAIT=1: Goto NOTRAIT:  Endif

Return

#------------------------------------------------------------------------------#
$READ_BIENCON #Bienes consigna DAFER X3-212589 11-11-2020
  Local Char CRITERE(250), WBIEN(1)  #Bienes consigna DAFER X3-212589 11-11-2020
  Local Integer WVCRLIN, WTYPCOM, WTRT
  Local Date WDATE, WSTRDAT, WSTREND
  Raz CRITERE

  WDATE=[M:DSII]DATINI

  If val(WDATE)=0: WDATE=date$: Endif

  If [M:DSII]DATINI=[0/0/0]: [M:DSII]DATINI=gdat$(1,month(WDATE),year(WDATE))  Endif
  If [M:DSII]DATEND=[0/0/0]: [M:DSII]DATEND=gdat$(eomonth(WDATE))  Endif

  WSTRDAT=[M:DSII]DATINI
  WSTREND=[M:DSII]DATEND

  If  val([M:DSII]DATINI)>val(GFECSII)
    WTRT=1
  Else
    If val([M:DSII]DATEND)>val(GFECSII)
      WSTRDAT=GFECSII+1
    Endif
  Endif

  Call PARAML([M:DSII]CPY,"DCLBIENCO",WBIEN) From ADOVAL #Bienes consigna DAFER X3-212589 11-11-2020
  If val(WBIEN)<>2: WTRT=0: Endif

  If WTRT=0: Return: Endif

  CRITERE = '[F:SDH]CPY="'+[M:DSII]CPY+'"'
  If [M:DSII]FCY<>""
    CRITERE -= '& [F:SDH]SALFCY="'+[M:DSII]FCY+'"'
  Endif

  If [M:DSII]BPR<>""  # mejora rendimiento carga monitor
    CRITERE -= '& [F:SDH]BPCORD="'+[M:DSII]BPR+'"'
  Endif

  CRITERE -= '& [F:SDH]DLVDAT>=['+format$(GFMD,WSTRDAT)+']'
  CRITERE -= '& [F:SDH]DLVDAT<=['+format$(GFMD,WSTREND)+']'

  Local File SDELIVERY  [SDH]
  Local File SDELIVERYD [SDD]
  Local File TABCOUNTRY [TCX]

  Raz WVCRLIN
  Filter [SDH] Where evalue(CRITERE) and SDHCAT=2 and CFMFLG=2 and BPDCRY<>"ES"
  For [SDH]
    Read [TCX]TCY0=[F:SDH]BPDCRY
    If fstat=[V]CST_AOK
      If [F:TCX]EECFLG<>2: Goto NO_UE: Endif
    Endif
    For [SDD] Where SDHNUM=[F:SDH]SDHNUM
      WTYPENV=8
      WVCRLIN+=1
      Gosub WRI_BIENCO
      If [F:SDD]RTNQTY<>0
        Local File SRETURND [SRD]
        Read [SRD]SRD1=[F:SDD]SDHNUM;[F:SDD]SDDLIN
        If fstat=[V]CST_AOK
          If[F:SRD]RTNDAT>=WSTRDAT and [F:SRD]RTNDAT<=WSTREND
            Gosub WRI_BIENCO_RE
          Endif
        Endif
        Close File [SRD]
      Endif
      OKK=2
    Next
    $NO_UE
  Next
  Filter [SDH]
  Close File [SDH],[SDD],[TCX]
Return

#------------------------------------------------------------------------------#
$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto WRI_SII : Endif

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla DCLSII) 12/01/2017 10:42:09 (ADMIN)
######################################################################################
Subprog AV_CPY(VALEUR)
Variable Char  VALEUR()
  If GUSRFCY(1)<>"\" and GNBAUZ=1
    If [M:DSII]FCY=""
       [M:DSII]FCY=GUSRFCY(1)
    Endif
    Read [F:FCY]FCY0=[M:DSII]FCY
    If fstat : Raz [F:FCY] : Endif
    VALEUR=[F:FCY]LEGCPY
    Diszo [M:DSII]CPY, FCY
  Endif
End

##################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
  Local Char   WVAL(1), WDAT(15)

  If VALEUR<>""
    Read [F:CPY]CPY0=VALEUR
    If fstat <>[V]CST_AOK: Raz [F:CPY]
    Else GCURLEG=[F:CPY]LEG
    Endif

    If GCURLEG<>"SPA"
      GMESSAGE=mess(249,107,1) # La legislación de la sociedad debe ser "SPA" \ The legislation of the company must be SPA.
      mkstat=2: End
    Endif

    Call PARAML(VALEUR,"SIIFCY",WVAL) From ADOVAL
    GSIIFCY=val(WVAL)
    If GSIIFCY<>2: GSIIFCY=1: Endif

    Call PARAML(VALEUR,"SIIEXTAP",WVAL) From ADOVAL
    GSIIEXTAP=val(WVAL)
    If GSIIEXTAP<>2: GSIIEXTAP=1: Endif
    If GSIIEXTAP=2: GSIIFCY=1: Endif

    If GSIIFCY=1
      Gosub LECT_PARAM # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Raz [M:DSII]FCY
      Grizo [M:DSII]FCY
    Else
      Actzo [M:DSII]FCY
    Endif
    Affzo [M:DSII]FCY

#    Call PARAML(VALEUR,"SIIMETSII",WVAL) From ADOVAL
#    GMETSII=val(WVAL)

#    Call PARAM(VALEUR,"SIIFECSII",WDAT) From ADOVAL
#    If WDAT<>"" : GFECSII = gdat$(WDAT) : Endif

#    Call PARAML(VALEUR,"TERDECSP",WVAL) From ADOVAL
#    If val(WVAL)=0 : WVAL="1": Endif

#    [M:DSII]TERCPY="("+mess(val(WVAL),2108,1)+")"
#    Affzo [M:DSII]TERCPY

 # If Site group, don´t select a site
    If [F:CPY]CPYLEGFLG<2 : mkstat=2 : End: Endif

    If [M:DSII]TERCPY="("+mess(6,2108,1)+")"  #Canarias. CEE no se usa para Canarias\ UE tab is not use in Canarian
        Grizo [M:DSII3]NBLIGC
      Else
        Actzo [M:DSII3]NBLIGC: Affzo [M:DSII3]1-99
      Endif

  Endif
End

##################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  If VALEUR <>""
    BLOQUEO="DCLSII~"+[M:DSII]CPY+"~"+num$(month([M:DSII]DATINI))+num$(year([M:DSII]DATINI))
    BLOQUEOIVA="DCLVATSPA~"+[M:DSII]CPY+"~"+ num$(year([M:DSII]DATINI))
    Unlock =BLOQUEO
    Unlock =BLOQUEOIVA
    Raz [M:DSII]FCY: Affzo [M:DSII]FCY
    Raz [M:DSII1], [M:DSII2], [M:DSII3], [M:DSII4], [M:DSII5], [M:DSII6], [M:DSII7]
    Affzo [M:DSII1]: Affzo [M:DSII2]: Affzo [M:DSII3]: Affzo [M:DSII4]: Affzo [M:DSII5]: Affzo [M:DSII6]: Affzo [M:DSII7]
    GXX=1
  Endif
End

##################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
  If VALEUR <>""
    Raz [M:DSII1], [M:DSII2], [M:DSII3], [M:DSII4], [M:DSII5], [M:DSII6], [M:DSII7]
    Affzo [M:DSII1]: Affzo [M:DSII2]: Affzo [M:DSII3]: Affzo [M:DSII4]: Affzo [M:DSII5]: Affzo [M:DSII6]: Affzo [M:DSII7]
    GXX=1
    If GSIIFCY=2 and GSIIEXTAP<>2 # X3-237572 SII Monitor by site by DAFER 2021-06-16
      Gosub LECT_PARAM
    Endif
  Endif
End

##################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
    If VALEUR <> ""
        If [F:FCY]FCY<>VALEUR
            Read [F:FCY]FCY0=VALEUR
            If fstat : Raz [F:FCY] : Endif
        Endif
        If [M:DSII]CPY<>[F:FCY]LEGCPY
            [M:DSII]CPY = [F:FCY]LEGCPY
            Affzo [M:DSII]CPY
        Endif
    Else
        Call CONTALLFCY([M:DSII]CPY) From CPTSUB
    Endif
    If GSIIFCY=2 and VALEUR="" : GMESSAGE=mess(472,192,1) #Valor obligatorio\mandatory value
      mkstat=2: End
    Endif
End

##################################################
Subprog AM_DATINI(VALEUR)
Variable Date   VALEUR()
  If VALEUR<>[0/0/0]
    [M:DSII]DATEND=gdat$(eomonth(VALEUR),month(VALEUR),year(VALEUR))
    Affzo [M:DSII]DATEND
    GXX=1
  Endif
  GMODCRI=1
End

##################################################
Subprog AM_DATEND(VALEUR)
Variable Date   VALEUR()
  If VALEUR<>[0/0/0]: GXX=1:  Endif
  GMODCRI=1
End

##################################################
Subprog C_DATEND(VALEUR)
Variable Date VALEUR()

  If VALEUR=[0/0/0] and [M:DSII]DATINI=[0/0/0] : End : Endif
  If VALEUR<[M:DSII]DATINI
    GMESSAGE=mess(99,177,1) - num$([M:DSII]DATINI)  # La fecha fin no debe ser inferior a la fecha inicio.
    mkstat=2
  Endif

  If month(VALEUR)<>month([M:DSII]DATINI)
    GMESSAGE=mess(32,7711,1) - num$([M:DSII]DATINI)  # Deben estar en el mismo mes.
    mkstat=2
  Endif

  If year(VALEUR)<>year([M:DSII]DATINI)
    GMESSAGE=mess(2,2124,1) - num$([M:DSII]DATINI)
    mkstat=2
  Endif

  If month(VALEUR)<>month([M:DSII]DATEND) # anulamos bloqueo y creamos nuevo
    If [M:DSII]CPY<>""
      BLOQUEO="DCLSII~"+[M:DSII]CPY+"~"+num$(month([M:DSII]DATINI))+num$(year([M:DSII]DATINI))
      Unlock =BLOQUEO
      Gosub CONTROLE From CNSDCSIISTD
    Endif
  Endif


End

##################################################
Subprog C_BPR(VALEUR)
Variable Char VALEUR()

  If GSIIEXTAP=2: End: Endif ## Aplicación externa

  If VALEUR<>""
    Local File BPARTNER  [BPR]
    Read [BPR]BPR0=VALEUR
    If fstat<>[V]CST_AOK
      GMESSAGE=mess(1128,196,1) # Tercero no válido
      mkstat=2
    Endif
    Close File [BPR]
  Endif
  If VALEUR<>[M:DSII]BPR
    GMODCRI=1
  Endif
End

##################################################
Subprog AM_LOT(VALEUR)
Variable Char VALEUR()
  If VALEUR<>[M:DSII]LOT
    GMODCRI=1
  Endif
End

##################################################
Subprog AS_VCRSTA(VALEUR)
Variable Integer    VALEUR()
  If [M:DSII]STAALL=2: Grizo [M:DSII]VCRSTA Else :Actzo [M:DSII]VCRSTA :Endif
  Affzo [M:DSII]VCRSTA
End

