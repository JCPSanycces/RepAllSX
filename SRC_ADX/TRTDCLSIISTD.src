    [M:DSIIBC]FLGSEL(WNL)    =[F:YXSIM]FLGSEL
    [M:DSIIBC]GTE(WNL)       =[F:YXSIM]GTE
    [M:DSIIBC]VCRNUM(WNL)    =[F:YXSIM]VCRNUM
    [M:DSIIBC]STADOC(WNL)    =[F:YXSIM]STADOC
    [M:DSIIBC]VCRSTA(WNL)    =[F:YXSIM]VCRSTA
    [M:DSIIBC]TYPCOM(WNL)    =[F:YXSIM]TYPCOM
    [M:DSIIBC]DATOPE(WNL)    =[F:YXSIM]DATOPE
    [M:DSIIBC]AMTATI(WNL)    =[F:YXSIM]AMTATI
    [M:DSIIBC]CRY(WNL)       =[F:YXSIM]CRY
    [M:DSIIBC]BPR(WNL)       =[F:YXSIM]BPR
    [M:DSIIBC]BPRVCR(WNL)    =[F:YXSIM]BPRVCR
    [M:DSIIBC]BPRNAM(WNL)    =[F:YXSIM]BPRNAM
    [M:DSIIBC]NIP(WNL)       =[F:YXSIM]NIP
    [M:DSIIBC]VCRERRNUM(WNL) =[F:YXSIM]VCRERRNUM
    [M:DSIIBC]VCRLIN(WNL)    =[F:YXSIM]VCRLIN
    WNL+=1
    If WNL=dim([DSIIBC]FLGSEL): Break: Endif
  Next
  [M:DSIIBC]NBLIGBC=WNL
  Affzo [M:DSIIBC]1-99
  Close File [YXSIM]
Return

######################################################################################
$RIN_MSK
  Case maskcou
    When "DCLSII1"
      Raz [M:DSII1]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL),CUR(NOL)
      Affzo [M:DSII1]1-99
    When "DCLSII2"
      Raz [M:DSII2]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),BPRVCR(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL), DATREGCON(NOL), AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL)
      Raz [M:DSII2]CUR(NOL)
      Affzo [M:DSII2]1-99
    When "DCLSII3"
      Raz [DSII3]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [DSII3]1-99
    When "DCLSII4"
      Raz [M:DSII4]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:DSII4]1-99
    When "DCLSII5"
      Raz [M:DSII5]FLGSEL(NOL),STADOC(NOL),BPRVCR(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:DSII5]1-99
    When "DCLSII6"
      Raz [M:DSII6]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL),CUR(NOL)
      Affzo [M:DSII6]1-99
    When "DCLSII7"
      Raz [M:DSII7]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL)
      Raz [M:DSII7]TYPANUAL(NOL), CLAVEOPE(NOL): : Affzo [M:DSII7]1-99
    When "DCLSIIBC"  #Bienes consigna DAFER X3-212589 11-11-2020
      Raz [M:DSIIBC]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:DSIIBC]1-99

  Endcase
Return

######################################################################################
Subprog SELREG
  Local Integer YESNO, I, K
  WMSG=mess(15,2124,1) #"¿Quiere seleccionar todos los registros?\Select all records?
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
#    For I=1 To 7 Bienes consigna DAFER X3-212589 11-11-2020
    For I=1 To 8
      Case I
        When 1:
          For K=0 To [M:DSII1]NBLIG-1
            If [M:DSII1]STADOC(K)=1: [M:DSII1]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSII1]1-99
        When 2:
          For K=0 To [M:DSII2]NBLIGR-1
            If [M:DSII2]STADOC(K)=1 and [M:DSII2]BPRVCR(K)<>"" : [M:DSII2]FLGSEL(K)=2
            Else [M:DSII2]FLGSEL(K)=1
            Endif
          Next
          Affzo [M:DSII2]1-99
        When 3:
          For K=0 To [DSII3]NBLIGC-1
            If [DSII3]STADOC(K)=1: [DSII3]FLGSEL(K)=2: Endif
          Next
          Affzo [DSII3]1-99
        When 4:
          For K=0 To [M:DSII4]NBLIGI-1
            If [M:DSII4]STADOC(K)=1: [M:DSII4]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSII4]1-99
        When 5:
          For K=0 To [M:DSII5]NBLIGCA-1
            If [M:DSII5]STADOC(K)=1: [M:DSII5]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSII5]1-99
        When 6:
          For K=0 To [M:DSII6]NBLIGPA-1
            If [M:DSII6]STADOC(K)=1 and [M:DSII6]BPRVCR(K)<>"" : [M:DSII6]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSII6]1-99
        When 7:
          For K=0 To [M:DSII7]NBLIGM-1
            If [M:DSII7]STADOC(K)=1: [M:DSII7]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSII7]1-99
        When 8:  #Bienes consigna DAFER X3-212589 11-11-2020
          For K=0 To [M:DSIIBC]NBLIGBC-1
            If [M:DSIIBC]STADOC(K)=1: [M:DSIIBC]FLGSEL(K)=2: Endif
          Next
          Affzo [M:DSIIBC]1-99
      Endcase
    Next
  Endif
End

##################################################
