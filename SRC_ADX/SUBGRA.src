#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier GRPAUTACE
Raz GBIDC1, GBIDC2
Call OBJET("GRA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "FIN_ACTION"  : Gosub FIN_ACTION
Endcase
Return

$FIN_ACTION
Case REPONSE
 When GSTALIT : Gosub RELIT From GOBJSUB : SUIZON="CODACE"
Endcase
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
Return

$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto 
Return

$SEL_TABLE
Case TABLE
 When "SELAUTACE"
  OBJET   = "GAU"
  START   = "COD"
  TIT(0)  = mess(109,105,1)
  CRITERE = "1=1"
 Endcase
Return

$FILTRE
Return


$LIENS
Call LECTEXTRA([M]DESTRA,"GRPAUTACE","DESTRA",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GRPAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
Raz nolign
For [GRM]GRM0 Where COD=[M]COD
 nolign += 1
 [M:GRA1] = [F:GRM]
Next
[M]NBLIG = nolign
Return

$INICRE
If dim([F:GRA]DES)>0
 [F:GRA]DES = [M:GRA1]DESTRA
Endif
Return

$INIMOD
If dim([F:GRA]DES)>0
 [F:GRA]DES = [M:GRA1]DESTRA
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub MODCRE
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Delete [GRM] Where COD=[M:GRA1]COD
If fstat=1
 GOK = -1 : Call RSTA("GRA",CLECUR1) From GLOCK : Return
Endif
Gosub MODCRE
Return

$MODCRE
For nolign=1 To [M]NBLIG
 If [M]CODACE1(nolign-1)<>""
  Raz [F:GRM]
  [F:GRM] = [M:GRA1]
  [F:GRM]NUMORD = nolign
  Write [GRM]
  If fstat
   GOK = 0 : Call FSTA("GRM") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GRPAUTACE","DESTRA",CLECUR1,"","GRPAUTACE","DESTRA",[M]COD,"")  From ATEXTRA
 Call DUPTEXTRA("GRPAUTACE","SHOTRA",CLECUR1,"","GRPAUTACE","SHOTRA",[M]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GRPAUTACE","DESTRA",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GRPAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("GRPAUTACE","DESTRA",[M]COD,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GRPAUTACE","SHOTRA",[M]COD,"",NCODE,"") From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("GRPAUTACE","DESTRA",[M]COD,"") From ATEXTRA
Call SUPTEXTRA("GRPAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
Return


###########################################################
## Etiquettes du masque GRPAUTACE [GRA1]                 ##
###########################################################
Subprog AS_CODACE(VALEUR)
Variable Char    VALEUR()
If indice>0 & [M]CODACE(indice-1) = ""
 mkstat = 2 : End
Endif
End

Subprog C_CODACE(VALEUR)
Variable Char    VALEUR()
If clalev([F:GAU])=0 : Local File GAUTACE [GAU] : Endif
Local Integer I
If VALEUR<>""
 I = find(VALEUR,[M]CODACE(0..indice-1),[M]CODACE(indice+1..dim([M]CODACE)-1))
 If I
  If I>indice
   I += 1
  Endif
  GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
  mkstat=2 : End
 Endif
Elsif VALEUR="" & indice<dim([M]CODACE)-1 & [M]CODACE(indice+1)<>""
 For I = indice+1 To dim([M]CODACE)-1
  If [M]CODACE(I)<>""
   If I=indice + 1
    VALEUR = [M]CODACE(I)
   Else
    [M]CODACE(I-1) = [M]CODACE(I)
   Endif
   [M]CODACE(I)   = ""
   Call LECTURE("GAU",[M]CODACE(I-1),"") From CONTOBJ
   [M]ZCODACE(I-1) = [F:GAU]DES
   [M]ZCODACE(I) = ""
  Endif
 Next
Affzo
Endif
End

Subprog AM_CODACE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]NBLIG>0 & [M]CODACE(indice)=[M]CODACE1([M]NBLIG-1)
 Dela [M]NBLIG-1 [M]NBLIG
 [M]NBLIG-=1
Endif
For NOL=0 To [M]NBLIG-1
 If [M]CODACE1(NOL) = [M]CODACE(indice)
  [M]CODACE1(NOL) = VALEUR
 Endif
 If [M]CODACE2(NOL)<>"" & [M]CODACE2(NOL) = [M]CODACE(indice)
  [M]CODACE2(NOL) = VALEUR
 Endif
Next
Affzo CODACE1, CODACE2
End

Subprog AS_CODACE1(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If NOL>0 & [M]CODACE1(NOL-1) = ""
 mkstat = 2 : End
Endif
End

Subprog C_CODACE1(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Gosub SETNOL
OK = 1 : Gosub CONTPCE
If !OK : mkstat = 2  : End : Endif
End

$CONTPCE
If !find(VALEUR,[M]CODACE(0..dim([M]CODACE)-1))
 # Pièce non définie dans le groupe
 GMESSAGE = mess(103,105,1)
 OK = 0 : Return
Endif
Return

Subprog AS_LIG1(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M]CODACE1(NOL) = ""
 mkstat = 1 : End
Endif
Call LECTURE("GAU",[M]CODACE1(NOL),"") From CONTOBJ : # Pour la sélection...
End

Subprog C_LIG1(VALEUR)
Variable Decimal VALEUR
Local Char PCEAUTO(GLONGAU)
Local Integer OK
Gosub SETNOL
OK = 1 : PCEAUTO = [M]CODACE1(NOL)
Gosub CONTLIGPCE
If !OK : mkstat = 2 : End : Endif
End

$CONTLIGPCE
# Contrôle que la ligne de pièce auto existe
Read [GAD]GAD0 = PCEAUTO ; VALEUR
If fstat
 # Ligne de pièce inexistante
 GMESSAGE = mess(149,105,1)
 OK = 0 : Return
Endif
# Contrôle que la ligne de pièce auto n'est pas déjà lettrée
Local Char    CHAINE(15)
Local Char    TABLIGPCE(15)(0..dim([M]CODACE1)-1+dim([M]CODACE2))
Local Integer NOL2, I, W
CHAINE = PCEAUTO+num$(VALEUR)
NOL2 = 0 : I = 0
While NOL2<dim([M]CODACE1) & [M]CODACE1(NOL2)<>""
 If NOL2<>NOL
  I += 1
  TABLIGPCE(I) = [M]CODACE1(NOL2)+num$([M]LIG1(NOL2))
  If [M]CODACE2(NOL2)<>""
   I += 1
   TABLIGPCE(I) = [M]CODACE2(NOL2)+num$([M]LIG2(NOL2))
  Endif
 Endif
 NOL2+=1
Wend
If I>0
 W = find(CHAINE,TABLIGPCE(0..I))
 #If W
  # Lettrage déjà défini pour cette ligne de pièce
 # GMESSAGE = mess(104,105,1)
 # OK = 0 : Return
 #Endif
Endif
Return

Subprog AS_CODACE2(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]CODACE1(NOL) = "" | [M]CODACE3(NOL)<>"" | [M]INVMTC(NOL)=2
 mkstat = 1 : End
Endif
End

Subprog C_CODACE2(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer OK
Gosub SETNOL
OK = 1 : Gosub CONTPCE
If !OK : mkstat = 2 : End : Endif
End

Subprog AS_LIG2(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]CODACE2(NOL) = ""
 mkstat = 1 : End
Endif
Call LECTURE("GAU",[M]CODACE2(NOL),"") From CONTOBJ : # Pour la sélection...
End

Subprog C_LIG2(VALEUR)
Variable Decimal VALEUR
Local Char PCEAUTO(GLONGAU)
Local Integer OK
Gosub SETNOL
If [M]CODACE2(NOL)<>""
 OK = 1 : PCEAUTO = [M]CODACE2(NOL)
 Gosub CONTLIGPCE
 If !OK : mkstat = 2 : End : Endif
Endif
End


Subprog AS_CODACE3(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]CODACE1(NOL) = "" | [M]CODACE2(NOL)<>"" | [M]INVMTC(NOL)=2
 mkstat = 1 : End
Endif
End

Subprog C_CODACE3(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Gosub SETNOL
Call CONTROLE("GAU","!",[M]CODACE3(NOL),"",mkstat) From CONTOBJ
End

Subprog AS_LIG3(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]CODACE3(NOL) = ""
 mkstat = 1 : End
Endif
Call LECTURE("GAU",[M]CODACE3(NOL),"") From CONTOBJ : # Pour la sélection...
End

Subprog C_LIG3(VALEUR)
Variable Decimal VALEUR
Local Char PCEAUTO(GLONGAU)
Local Integer OK
Gosub SETNOL
If [M]CODACE3(NOL)<>""
 OK = 1 : PCEAUTO = [M]CODACE3(NOL)
 # Contrôle que la ligne de pièce auto existe
 Read [GAD]GAD0 = PCEAUTO ; VALEUR
 If fstat
  # Ligne de pièce inexistante
  OK = 0 : GMESSAGE = mess(149,105,1)
 Endif
 If !OK : mkstat = 2 : End : Endif
Endif
End


Subprog AS_INVMTC(VALEUR)
Variable Integer VALEUR()
Gosub SETNOL
If [M]CODACE1(NOL) = "" | [M]CODACE2(NOL) <> "" | [M]CODACE3(NOL) <> ""
 mkstat = 1 : End
Endif
End

Subprog C_NBLIG
Gosub SETNOL
Case status
 When 82 : # Reprise
  If [M]CODACE1(NOL)<>"" & [M]CODACE2(NOL)="" & [M]INVMTC(NOL)=1
   GMESSAGE = "Lettrage incorrect"
   mkstat = 2 : End
  Endif
Endcase
End


###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File GRPAUTACE [GRA1]
 Local File GRPACEMTC [GRM1]
 Local File ATEXTRA  [AXX1] 
Else 
 Local File =[M]DOSORG+".GRPAUTACE" [GRA1]
 Local File =[M]DOSORG+".GRPACEMTC" [GRM1] 
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File GRPAUTACE  [GRA2]
 Local File GRPACEMTC  [GRM2]
 Local File ATEXTRA  [AXX2] 
Else 
 Local File =[M]DOSDES+".GRPAUTACE" [GRA2]
 Local File =[M]DOSDES+".GRPACEMTC" [GRM2] 
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2] 
Endif 
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GRA1], [GRM1], [GRA2], [GRM2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [GRA2] , [GRM2]
 Delete [GRA2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GRPAUTACE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GRA2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [GRM2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GRPACEMTC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GRM2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GRA1] Where COD=TABLE
  [F:GRA2] = [F:GRA1]
  Call COPTEXTRA("GRPAUTACE","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("GRPAUTACE","SHOTRA",TABLE,"") From ATEXTRA
  If dim([F:GRA2]UPDUSR)>0 : [F:GRA2]UPDUSR = GUSER : Endif
  If dim([F:GRA2]UPDDAT)>0 : [F:GRA2]UPDDAT = date$ : Endif
  Write [GRA2]
  If fstat
   GOK = 0 : Call FSTA("GRA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [GRM1] Where COD=TABLE
  [F:GRM2] = [F:GRM1]
  Write [GRM2]
  If fstat
   GOK = 0 : Call FSTA("GRM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

