#######################################################################################
$AREAD_AFTER
Local Integer IRET
Local Integer NI
Local Integer NE
Local Integer NZ

  IRET = fmet this.TCHIMPORT.INIT()
  IRET = fmet this.TCHMODULE.INIT()
  IRET = fmet this.TCHISPJM.INIT()
  # ---------------------------------
  this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "LEGCPY")
  # ---------------------------------
  # CRM part
  [L]ASTATUS = max([L]ASTATUS, fmet this.CRM_INIT_TECH_PROP())
  # ---------------------------------
  # PJM part
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null Then
    # ---------------------------------
    # Mandatory to do that from here. It's not possible to use AREAD_AFTER at each level because AREAD_AFTER
    # if going from the lower level to the upper lever. And in this case, the need is the opposite.
    # Maybe there is another way to do that, but I don't know it. :-(
    # ---------------------------------
    [L]ASTATUS = max([L]ASTATUS, fmet this.PJM_PROPAGATE_TECH_PROP())
  Endif
  [L]ASTATUS = max([L]ASTATUS, fmet this.COM_LOAD_OPPMCNNAM())    # Issue X3-80586 - 2018-04-11 by FGR
  # ---------------------------------
Return

#######################################################################################
$AINSERT_CONTROL_BEFORE
Local Integer IRET
Local Integer IERROR
Local Integer IMANUAL
Local Char SMESSAGE(250)
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(type(this.OPPNUM)-10)

  # ---------------------------------
  Call READ_COUNTER(this.ACTX, 9, 7, this.CPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR))
    Return
  Endif
  # ---------------------------------
  If SCOMPTEUR <> AVOID.ACHAR Then  # Issue X3-5460/119223 - 2016-10-26 by FGR : only if SCOMPTEUR is not empty
    # Appel du compteur de numérotation
    If IMANUAL = [V]CST_ANO or vireblc(this.OPPNUM,2) = "" Then
      IRET = func ANM_TOOL.NUMERO(this.ACTX, SCOMPTEUR, this.SALFCY, date$, "", SNUMERO, SMESSAGE)
      If IRET = [V]CST_AERROR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(22,7770,1) - "(" + SCOMPTEUR + ") :" - SMESSAGE, [V]CST_AERROR))
        Return
      Endif
      this.OPPNUM = SNUMERO
    Endif
  Endif
  # ---------------------------------
  If this.CRM(1) <> null Then
    this.CRM(1).OPPNUM = this.OPPNUM
  Endif
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null Then
    this.PJM(1).OPPNUM = this.OPPNUM
    # ---------------------------------
    this.PIMPL.OPPSTATE = this.PJM(1).OPPSTATE
  Endif
  # ---------------------------------
  this.CREHOU = left$(time$,2) + mid$(time$,4,2)
  # ---------------------------------
Return

#######################################################################################
$AINSERT_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.COM_MANAGE_LCM_CREATE())
Return

#######################################################################################
$AUPDATE_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.COM_MANAGE_LCM_UPDATE())
Return

#######################################################################################
$ADELETE_CONTROL_AFTER
  # FLORENT ICI : voir s'il y a des contrôles à faire pour interdire la suppression ?
  If fmet this.COM_IS_CRM_OPPOR = [V]CST_ATRUE Then
    Gosub ADELETE_CONTROL_AFTER From OPPOR_CSTD_METHODS_CRM
  Endif
  #
  If this.TCHISPJM = [V]CST_ATRUE and fmet this.COM_IS_PJM_OPPOR = [V]CST_ATRUE Then
    Gosub ADELETE_CONTROL_AFTER From OPPOR_CSTD_METHODS_PJM
  Endif
Return

#######################################################################################
$ADELETE_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.COM_MANAGE_LCM_DELETE())
Return

#######################################################################################
$ACONTROL
Local Integer IBOBLOGATOIRE
Local Integer NI
Local Integer NE

  # -------------------------------------
  If find(this.PIMPL.PIMTYP,1,2,3) = 0 Then
    # Developper's bug in this case
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1175,196,1) - "(" + num$(this.PIMPL.PIMTYP) - mess(this.PIMPL.PIMTYP,2254,1) + ")", [V]CST_AERROR))
  Endif
  # -------------------------------------
  IBOBLOGATOIRE = [V]CST_ANO
  Case this.OPPORI
    When 2
      IBOBLOGATOIRE = [V]CST_AYES
    When 3
      IBOBLOGATOIRE = [V]CST_AYES
    When 4
      IBOBLOGATOIRE = [V]CST_AYES
    When 5
      IBOBLOGATOIRE = [V]CST_AYES
    When 6
      IBOBLOGATOIRE = [V]CST_AYES
    When 7
      IBOBLOGATOIRE = [V]CST_AYES
    When Default
  Endcase
  If IBOBLOGATOIRE = [V]CST_AYES Then
    If this.OPPORIVCR = "" Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(442,177,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------------------
  # Controle unicité
  For NI = 1 To maxtab(this.SBB)
    If this.SBB(NI) <> null and find(this.SBB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NE = NI+1 To maxtab(this.SBB)
        If this.SBB(NE) <> null and find(this.SBB(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.SBB(NI).SBBPJT = this.SBB(NE).SBBPJT Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SBBPJT", mess(1172,196,1) - "(" + mess(29,100,1) - num$(NE) + ")", [V]CST_AERROR))
          Endif
        Endif
      Next NE
    Endif
  Next NI
  #
  For NI = 1 To maxtab(this.CPP)
    If this.CPP(NI) <> null and find(this.CPP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NE = NI+1 To maxtab(this.CPP)
        If this.CPP(NE) <> null and find(this.CPP(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.CPP(NI).CPP = this.CPP(NE).CPP Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CPP", mess(1173,196,1) - "(" + mess(29,100,1) - num$(NE) + ")", [V]CST_AERROR))
          Endif
        Endif
      Next NE
    Endif
  Next NI
  # -------------------------------------
Return

#######################################################################################
$CRM_ACONTROL
  # -------------------------------------
  If this.APARENT.OPPDATOPN <> [00/00/00] and this.OPPCDA <> [00/00/00] Then
    If this.APARENT.OPPDATOPN > this.OPPCDA Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(458,177,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------------------
Return

#######################################################################################
$CRM_ADDLINE_AFTER
  [L]ASTATUS = fmet this.INIT_FIRST_STEP()
Return

#######################################################################################
# Issue X3-96497 - 2018-06-27 by FGR : BEGIN
$CRM_STPSTB_ADELLINE_BEFORE
Local Integer NI
Local Integer IFOUND

  # Deletion of detection stage is prohibited, excepted if it stay another detection stage in the collection
  If this.APARENT.TCHIMPORT = [V]CST_ANO Then
    Local File ATABDIV [ADI]
    Read [ADI]CODE=400;this.STPSTB([L]ALINE).STE
    If [F:ADI]N2 = 2 Then
      IFOUND = [V]CST_ANO
      For NI = 1 To maxtab(this.STPSTB([L]ALINE))
        If NI <> [L]ALINE Then
          If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            Read [ADI]CODE=400;this.STPSTB(NI).STE
            If [F:ADI]N2 = 2 Then
              IFOUND = [V]CST_AYES
              Break
            Endif
          Endif
        Endif
      Next NI
      If IFOUND = [V]CST_ANO
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(660,177,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

#$CRM_STPSTB_ADELLINE_BEFORE
#  If this.APARENT.TCHIMPORT = [V]CST_ANO Then
#    Local File ATABDIV [ADI]
#    Read [ADI]CODE=400;this.STPSTB([L]ALINE).STE
#    If [F:ADI]N2 = 2 Then
#      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(660,177,1), [V]CST_AERROR))
#    Endif
#  Endif
#Return
# Issue X3-96497 - 2018-06-27 by FGR : END

#######################################################################################
$PJM_ACONTROL
  # -------------------------------------
  If fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "SEPARCODE") = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SEPARCODE", mess(416,2260,1), [V]CST_AERROR))
  Endif
  # -------------------------------------
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHCHGTYP <> this.APARENT.CHGTYP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHCHGTYP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.SALFCY <> this.APARENT.SALFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SALFCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.CPY <> this.APARENT.CPY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CPY", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # -------------------------------------
  If this.OPPSTATE <> this.APARENT.PIMPL.OPPSTATE Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.PIMPL.SETERROR("OPPSTATE", mess(18,9804,1) - "(" + num$(this.OPPSTATE) - num$(this.APARENT.PIMPL.OPPSTATE) + ")", [V]CST_AERROR))
  Endif
  # -------------------------------------
Return

#######################################################################################
$PJM_ADDLINE_BEFORE
  If fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "SEPARCODE") = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SEPARCODE", mess(416,2260,1), [V]CST_AERROR))
  Endif
  # -------------------------------------
  If fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT") = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("HOURLYUNIT", func AFNC.MES1(mess(478,2260,1), "HOURLYUNIT"), [V]CST_AERROR))
  Endif
  # -------------------------------------
Return

#######################################################################################
$PJM_ADDLINE_AFTER
  # -------------------------------------
  this.APARENT.PIMPL.TCHACTION = "STATUS"
  this.APARENT.PIMPL.OPPSTATE = this.OPPSTATE
  # -------------------------------------
  this.CUR = this.APARENT.CUR
  this.OPPCMP = this.APARENT.OPPCMP
  this.TCHCHGTYP = this.APARENT.CHGTYP
  this.SALFCY = this.APARENT.SALFCY
  this.OPEDEFFCY = this.APARENT.SALFCY
  this.CPY = this.APARENT.CPY
  # -------------------------------------
Return

#######################################################################################
$CPP_ACONTROL
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$CPP_ADDLINE_AFTER
  this.CUR = this.APARENT.CUR
Return

#######################################################################################
$CPP_AREAD_AFTER
  this.CUR = this.APARENT.CUR
Return

#######################################################################################
$PIMPL_ACONTROL
  If this.PIMTYP <> 1 and this.PIMTYP <> 2 and  this.PIMTYP <> 3 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTYP", mess(205,2260,1) - "(" + mess(this.PIMTYP,2254,1) + ")", [V]CST_AERROR))
  Endif
Return

