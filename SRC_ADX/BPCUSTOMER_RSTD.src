#<AdxTL>@(#)5.0.0.0 $Revision$
# Classe BPCUSTOMER
End

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER"         :  Gosub AREAD_AFTER
        When "AQUERY_TRANS_AFTER"  :  Gosub AQUERY_TRANS_AFTER
        When Default
    Endcase
   When "BPC.BPD"
    Case [L]AEVENT
        When "AREAD_AFTER"         :  Gosub AREAD_AFTER_BPD
        When Default
    Endcase
   When Default
Endcase
Return
#######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]CURPTH
   When ""
      Case [L]AMETHOD
        When Default
      Endcase
    When Default
  Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Return

#######################################################################################
$AREAD_AFTER
Local Integer IRET
Local Shortint IOSTCTL

  #--Chargement de l'En-cours
  IRET = func BPCUSTOMER_PROG.LOAD_OST(this.BPC.BPCNUM, this.ACTX, "", "", this.REPCUR, IOSTCTL, this.OSTAUZ, this.OST, this.CDTISR, this.CDTISRDAT, this.ORDMINAMT)
  If IRET <> 0 Then
    # Traiter le cas de l'erreur ici FLORENT ICI
  Endif
  this.BPC.OSTCTL = IOSTCTL  # Obligé de passer par une variable intermédiaire à cause du type de données.
  # ------------------------------------------------
  #--Chargement des libellés des adresses
  Gosub LOAD_ADDNAM
Return


#######################################################################################
$AQUERY_TRANS_AFTER
  ASTATUS = func LIBSYR_REP_BP._FILL_MAILMERGE_PROPERTIES(this, this.BPC.BPCNUM, this.BPC.BPAADD, this.BPC.CNTNAM) #Gbn-97999
  #JOJAC - 2018-07-10 - X3-99108 - START
  Gosub LOAD_PTE_LEG
  #JOJAC - 2018-07-10 - X3-99108 - END
Return

#######################################################################################
$AREAD_AFTER_BPD
Local Integer IRET

  If this.APARENT=null Return Endif
  Local File BPADDRESS [BPA]
  #--Libellé code adresse client livré
  If this.BPAADD<>"" and this.BPCNUM<>"" and this.APARENT.BPCTYP>0
  Read [F:BPA]BPA0=this.APARENT.BPCTYP;this.BPCNUM;this.BPAADD
  If fstat : Raz [F:BPA] Endif
  this.BPAADDNAM = [F:BPA]BPADES
  Endif
Return

