#######################################################################################
$LOAD_ADDNAM
  Local File BPADDRESS [BPA]
  #--Libellé code adresse tiers facture
  If this.BPC.BPAINV<>"" and this.BPC.BPCINV<>"" and this.BPC.BPCTYP>0
  Read [F:BPA]BPA0=this.BPC.BPCTYP;this.BPC.BPCINV;this.BPC.BPAINV
  If fstat : Raz [F:BPA] Endif
  this.BPAINVNAM = [F:BPA]BPADES
  Endif
  #--Libellé code adresse tiers payeur
  If this.BPC.BPAPYR<>"" and this.BPC.BPCPYR<>"" and this.BPC.BPCTYP>0
  Read [F:BPA]BPA0=this.BPC.BPCTYP;this.BPC.BPCPYR;this.BPC.BPAPYR
  If fstat : Raz [F:BPA] Endif
  this.BPAPYRNAM = [F:BPA]BPADES
  Endif
Return

#JOJAC - 2018-07-10 - X3-99108 - START
$LOAD_PTE_LEG
If this.BPC.PTE="" Return Endif

Local Integer IRET
Local Char LEG

If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif

If func AFNC.ACTIV("LEG")=0
 [L]LEG = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"GDOSLEG")
Elsif LEG="" & dim(this.BPC.LEG)>0 : # Legislation present in the class
  If this.BPC.LEG<>"" : [L]LEG = this.BPC.LEG : Endif
Endif

If [L]LEG<>""
 Read [TPT]TPT0=this.BPC.PTE;[L]LEG;1
 If fstat
  Read [TPT]TPT0=this.BPC.PTE;"";1
 Endif
Else
 Read [TPT]TPT0(1)=this.BPC.PTE
Endif
If !fstat
  [L]LEG = [F:TPT]LEG
Endif

this.BPC.PTE_LEG = [L]LEG

Return
#JOJAC - 2018-07-10 - X3-99108 - END

