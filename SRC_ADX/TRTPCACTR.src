#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------
# TRTPCACTR : Génération de caisse par contrat
#----------------------------------------------
# (C) PROSPER 13/07/10 : P06 / 66101
#----------------------------------------------

Local Char VALEUR(250), PARMSK(250)(1..20), SAVACT(20)
SAVACT = GACTION : GACTION = "TRTPCACTR"
PARMSK(1) = "EMP"
PARMSK(2) = "URSSAF"
PARMSK(3) = "1"
PARMSK(4) = "FRA"

Call SAISIE_CHAR(VALEUR,PARMSK,"TRTPCACTR","TRTPCACTR","XYTRTPCACTR") From GSAISIE
GACTION = SAVACT

End

$ACTION
Case [L]ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub TRAITEMENT
    When "FIN"   : Gosub FIN
    When Default
Endcase
Return

##############################
$OUVRE

Local Mask TRTPCACTR [DIA]

If !clalev([F:ID])    : Local File EMPLOID   [ID]   : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:HRPOA])   : Local File POPULA   [HRPOA]   : Endif
If !clalev([F:PCA])   : Local File CAISSE   [PCA]   : Endif
If !clalev([F:ORA])   : Local File ORGAFFIL [ORA]   : Endif

Local Integer TYPE_TRAITEMENT, NBMAXCTR, OK, FLG, I, J

[L]NBMAXCTR = dim([M:DIA]CTRNUM)

Local Char TREFNUM([V]GLONEML) (0..[L]NBMAXCTR)
Local Char TCTRNUM([V]GLONHRCTR) (0..[L]NBMAXCTR)

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Raz [M:DIA]

# Récupération des paramètres de l'action
# PARAM(1) = code population
# PARAM(2) = type de traitement d'origine, 1 = affectation, 2 = affiliation

[M:DIA]POP = [L]PARAM(1)
[M:DIA]ORG = [L]PARAM(2)
[L]TYPE_TRAITEMENT = val([L]PARAM(3))

If dim([M:DIA]LEG)>=0 : [M:DIA]LEG=PARAM(4) : Endif
GCURLEG=PARAM(4)
Return

##############################
$DEBUT

# Selon le traitement d'origine on grise certaines possibilités

Case [L]TYPE_TRAITEMENT
    When 1
        # Affectation oui, affiliation non mais sélectionnable
        [M:DIA]PCAFLG = 2 : [M:DIA]ORAFLG = 1
        Grizo [M:DIA]PCAFLG
    When 2
        # Affectation non, affiliation oui
        [M:DIA]PCAFLG = 1 : [M:DIA]ORAFLG = 2
        Grizo [M:DIA]PCAFLG
        Grizo [M:DIA]ORAFLG
    When Default
        # Ah ben bien ....
        [M:DIA]PCAFLG = 1 : [M:DIA]ORAFLG = 1
        Grizo [M:DIA]PCAFLG
        Grizo [M:DIA]ORAFLG
Endcase

# Chargement de la population
# On récupère les contrats dont la date de sortie est vide ( i.e. contrat actif )
# ou dont la date de fin de contrat est postérieure à la date courante ( fin de cdd saisie par avance )

Link [HRCTR] With
&    [HRPOA]POA0 ~= [M:DIA]POP;[F:HRCTR]REFNUM ,
&    [ID]ID0 = [F:HRCTR]REFNUM
&    As [LNK]
&    Where ( ( [F:HRCTR]XITDAT = [0/0/0]) or ([F:HRCTR]XITDAT >= datesyst) )
&    & [F:ID]ENAFLG = 2
&    Order By Key CLE = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT

Raz nolign, [M:DIA]NBLIG

For [F:LNK]CLE(2)

    # On ne prends qu'une occurence d'un contrat quelle que soit la date de contrat donnée
    # En effet dans la table des CAISSES, on ne stocke que le numéro de contrat
    # pour un "LEV" = 6 = contrat.
    # NB : même le numéro d'employé n'est pas stocké donc bien faire attention si on modifie
    # la définition du numéro de compteur des contrats.

    # Contrôle d'accès au salarié / contrat.

    Call CONTROLE([F:HRCTR]REFNUM, datesyst, [F:HRCTR]CTRNUM, "", [L]OK, 1) From DIVPAYE

    If [L]OK

        [L]OK = 1

        If [L]TYPE_TRAITEMENT = 2
            # Origine affiliation, on ne montre que les contrats ayant un paramétrage défini dans CAISSE
            # pour l'organisme demandé.
            Read [F:PCA]PCA0 = 6 ; GCURLEG ; "" ; "" ; "" ; "" ; [F:HRCTR]CTRNUM
            If fstat = 0 & find([M:DIA]ORG, [F:PCA]ORG)
                [L]OK = 2
            Endif
        Else
            [L]OK = 2
        Endif


        If [L]OK = 2

            If nolign >= dim([M:DIA]CTRNUM)
                # mess(26,100,1) = > Tableau plein
                Call ERREUR(mess(26,100,1)) From GESECRAN
                Break
            Endif

            nolign += 1

            [M:DIA] = [F:HRCTR]
            [M:DIA] = [F:ID]

            # Case présence de l'élément (affectation ou affiliation) ?

            [M:DIA]EXIFLG(nolign-1) = 1

            If [L]TYPE_TRAITEMENT = 1
                Look [F:PCA]PCA0 = 6 ; GCURLEG ; "" ; "" ; "" ; "" ; [F:HRCTR]CTRNUM
                If fstat = 0
                    [M:DIA]EXIFLG(nolign-1) = 2
                Endif
            Elsif [L]TYPE_TRAITEMENT = 2
                Look [F:ORA]ORA0 = 6 ; "" ; "" ; "" ; "" ; [F:HRCTR]CTRNUM ; GCURLEG ; [M:DIA]ORG
                If fstat = 0
                    [M:DIA]EXIFLG(nolign-1) = 2
                Endif
            Endif

        Endif

    Endif

Next

[M:DIA]NBLIG = nolign

Affzo [M:DIA]

Return

########################################
$TRAITEMENT

Raz [L]TREFNUM, [L]TCTRNUM, [L]I, [L]J

For [L]I = 0 To [M:DIA]NBLIG - 1
    If [M:DIA]SELFLG([L]I) = 2
        [L]TREFNUM([L]J) = [M:DIA]REFNUM([L]I)
        [L]TCTRNUM([L]J) = [M:DIA]CTRNUM([L]I)
        [L]J += 1
    Endif
Next

# Génération des enregistrements en affectation / affiliation

Call GENERE_PCAORA([M:DIA]PCAFLG, [M:DIA]ORAFLG, [M:DIA]TYPOPE,
&                  [L]J, [L]TREFNUM, [L]TCTRNUM, [M:DIA]POP, [M:DIA]ORG, 1)
&                 From TRTPCACTR

Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#########################################################################
# GENERE_PCAORA : Subprog de génération des affectations / affiliations #
#########################################################################
Subprog GENERE_PCAORA(PCAFLG, ORAFLG, TYPE_OPERATION ,
&                        NBCTR, TREFNUM, TCTRNUM, POPULATION_MODELE, ORGANISME, SILENCE)
Value Integer PCAFLG, ORAFLG, TYPE_OPERATION, NBCTR
Value Char TREFNUM()(), TCTRNUM()(), POPULATION_MODELE(), ORGANISME()
Value Integer SILENCE

# PCAFLG : affectation (1 non, 2 oui)
# ORAFLG : affiliation (1 non, 2 oui)
# TYPE_OPERATION : 1 = création / mise à jour, 2 = suppression

Local Integer OK_TR, I
Local Char REFNUM([V]GLONEML), CTRNUM([V]GLONHRCTR)
Local Char MESSAGE(250), CRITERE_ORGANISME(250)

If !clalev([F:PCA])  : Local File CAISSE       [PCA] : Endif
If !clalev([F:PCAW]) : Local File CAISSE      [PCAW] : Endif
If !clalev([F:ORA])  : Local File ORGAFFIL     [ORA] : Endif
If !clalev([F:ORAW]) : Local File ORGAFFIL    [ORAW] : Endif
#72148
If !clalev([F:FCY])  : Local File FACILITY     [FCY] : Endif

If [L]ORGANISME = ""
    [L]CRITERE_ORGANISME = "1"
Else
    [L]CRITERE_ORGANISME = "[F]ORG = [L]ORGANISME"
Endif

# mess(162,10702,1) : Génération des affectations et affiliations
Call OUVRE_TRACE(mess(162,10702,1)) From LECFIC

Repeat
    [L]OK_TR = 2

    Call DEBTRANS From GLOCK
    Trbegin [PCA], [PCAW]
    [V]GOK = 1

    If [L]PCAFLG = 2
        Gosub AFFECTATION
    Endif

    If [V]GOK = 1
        If [L]ORAFLG = 2
            Gosub AFFILIATION
        Endif
    Endif

    If [V]GOK = 1 &
&        ( [L]TYPE_OPERATION = 2 or ( [L]TYPE_OPERATION = 1 & [L]ORAFLG = 2 ) )
        Gosub COHERENCE_PCAORA
    Endif

    If [V]GOK < 1
        Rollback
        If [V]GOK = -1
            Call ROLL From GLOCK
            If not [V]GROLL : [L]OK_TR = 1 : Endif
        Endif
    Else
        Commit
    Endif
Until [L]OK_TR = 2

Call FERME_TRACE From LECFIC

If [L]SILENCE <> 2
    Call LEC_TRACE From LECFIC
Endif

End


##################################
$AFFECTATION

Read [F:PCAW]PCA0 = 2 ; GCURLEG ; [L]POPULATION_MODELE ; "" ; "" ; "" ; ""
If fstat <> 0
    # Aie, pas de modèle ....
    [V]GOK = 0
    Call RSTA("PCAW", "2;"+[L]POPULATION_MODELE+";'';'';''") From GLOCK
    Return
Endif

# mess(163,10702,1) : Affectation des organismes
# mess(164,10702,1) : Population modèle

Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN
Call ECR_TRACE(mess(163,10702,1)-"-"-mess(164,10702,1)-":"-[L]POPULATION_MODELE, 0) From GESECRAN
Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN

For [L]I = 0 To [L]NBCTR - 1

    # Pour tous les contrats à traiter, récupération de l'affectation contrat

    [L]CTRNUM = [L]TCTRNUM([L]I)

    If [L]CTRNUM <> ""    : # Sécurité ceinture & bretelles ...

    Readlock [F:PCA]PCA0 = 6 ; GCURLEG ; "" ; "" ; "" ; "" ; [L]CTRNUM
    If fstat = 1
        [V]GOK = -1
        [V]GLOCK = "$CAISSE"
        Break
    Elsif fstat = 0
        # Contrat déjà existant, on le supprime dans tous les cas
        Delete [F:PCA]
        If fstat <> 0 & fstat <> 4
            [V]GOK = 0
            Call FSTA("PCA") From GLOCK
            Break
        Endif
    Endif

    If [L]TYPE_OPERATION = 1
        # Si création (ou mise à jour), on créé l'élément ... Si suppression, il a déjà sauté :)
        Raz [F:PCA]
        [F:PCA] = [F:PCAW]
        [F:PCA]LEV = 6            : # Enregistrement affectation de niveau 6 = contrat
        [F:PCA]POP = ""           : # Suppression de la "population" modèle
        [F:PCA]CTR = [L]CTRNUM    : # Le contrat
        [F:PCA]LEG = GCURLEG
        Write [F:PCA]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("PCA") From GLOCK
            Break
        Endif
    Endif

    Endif    : # Fin de ceinture & bretelles

    # mess(165,10702,1) : Traitement du contrat
    Call ECR_TRACE(mess(165,10702,1)-":"-[L]CTRNUM, 0) From GESECRAN

Next
If [V]GOK < 1 : Return : Endif

Return

##################################
$AFFILIATION


# mess(166,10702,1) : Affiliation des organismes
# mess(164,10702,1) : Population modèle
Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN
Call ECR_TRACE(mess(166,10702,1)-"-"-mess(164,10702,1)-":"-[L]POPULATION_MODELE, 0) From GESECRAN
If [L]ORGANISME <> ""
    # mess(167,10702,1) : Traitement restreint à l'organisme
    Call ECR_TRACE(mess(167,10702,1)-":"-[L]ORGANISME, 0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN

For [L]I = 0 To [L]NBCTR - 1

    # Récupération du contrat ( du premier qu'on trouve dans le cas de multi contrat
    # avec le même numéro mais des dates différentes ... ), cela va nous permettre de
    # récupérer les données d'affiliation de la population pour le site concerné.

    [L]REFNUM = [L]TREFNUM([L]I) : [L]CTRNUM = [L]TCTRNUM([L]I)

    Read [F:HRCTR]CTR0(2) = [L]REFNUM ; [L]CTRNUM
    If !fstat
     # On met en ligne les affectations de notre contrat, on ne reprendra que des
     # affiliations pour des caisses présentes à la fois dans notre modèle de niveau 2=population
     # et présente cependant sur notre contrat
      #72148
      Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
      If !fstat
       Read [F:PCA]PCA0 = 6 ; GCURLEG ; "" ; "" ; "" ; "" ; [L]CTRNUM
        If !fstat
            # On va récupérer les enregistrements modèle de niveau population pour le site ou
            # est affecté notre contrat

            # ORA0 : LEV+POP+CPY+FCY+REFNUM+CTR+ORG

            #72148 : Add filters : << | ([F:ORA]CPY = [F:FCY]LEGCPY & [F:ORA]FCY = "") >>
            Filter [F:ORA] Where [F:ORA]LEV = 2 & [F:ORA]LEG=GCURLEG
&                        & [F:ORA]POP = [L]POPULATION_MODELE
&                        & (([F:ORA]CPY = "" & [F:ORA]FCY = [F:HRCTR]ETRFCY) | ([F:ORA]CPY = [F:FCY]LEGCPY & [F:ORA]FCY = ""))
&                        & [F:ORA]REFNUM = ""
&                        & [F:ORA]CTR = ""
&                        & evalue([L]CRITERE_ORGANISME)

            For [F:ORA]ORA0

                # On a un enregistrement modèle, on va propager ses valeurs sur un enregistrement
                # de niveau 6 = contrat

                # Effacement d'un enregistrement préexistant : on efface que les affiliation présentes
                # dans le modèle d'affiliation choisi

                Delete [F:ORAW] Where [F:ORAW]LEV = 6
&                        & [F:ORAW]POP = ""
&                        & [F:ORAW]CPY = ""
&                        & [F:ORAW]FCY = ""
&                        & [F:ORAW]REFNUM = ""
&                        & [F:ORAW]CTR = [L]CTRNUM
&                        & [F:ORAW]LEG = GCURLEG
&                        & [F:ORAW]ORG = [F:ORA]ORG

                If fstat <> 0 & fstat <> 4
                    [V]GOK = 0
                    Call FSTA("ORAW") From GLOCK
                    Break 2
                Endif

                If [L]TYPE_OPERATION = 1 & find([F:ORA]ORG, [F:PCA]ORG)
                    Raz [F:ORAW]
                    [F:ORAW] = [F:ORA]
                    [F:ORAW]LEV = 6
                    [F:ORAW]POP = "" : [F:ORAW]CPY = "" : [F:ORAW]FCY = "" : [F:ORAW]REFNUM = ""
                    [F:ORAW]CTR = [L]CTRNUM
                    [F:ORAW]LEG = GCURLEG
                    Write [F:ORAW]
                    If fstat <> 0
                        [V]GOK = 0
                        Call FSTA("ORAW") From GLOCK
                        Break 2
                    Endif

                Endif

            Next

            Filter [F:ORA]

            # mess(165,10702,1) : Traitement du contrat
            Call ECR_TRACE(mess(165,10702,1)-":"-[L]CTRNUM, 0) From GESECRAN

        Endif
       Endif

    Endif

Next

If [V]GOK < 1 : Return : Endif

Return

########################################
$COHERENCE_PCAORA

# Passe de cohérence : on va contrôler qu'il n'existe pas d'affiliation sur organismes non présent sur
# les affectations du contrat
# Ce cas peut se produire si on fait la chose suivante :
# - Affectation / Affiliation d'une caisse
# - Modification du paramétrage du modele
# - Affectation / Affiliation à nouveau => l'ancienne caisse n'est plus dans les valeurs modèle du contrat
#                                          donc on ne la traite pas au niveau effacement affiliation
# Ce cas peut aussi se produire suite à l'opération d'effacement des affectations spécifiques
# contrat ( plus d'enregistrement PCA au contrat ), on effectue donc cette passe y compris si
# on ne demande pas le traitement d'affiliation.

For [L]I = 0 To [L]NBCTR - 1

    [L]CTRNUM = [L]TCTRNUM([L]I)

    Filter [F:ORAW] Where [F:ORAW]LEV = 6
&        & [F:ORAW]POP = ""
&        & [F:ORAW]CPY = ""
&        & [F:ORAW]FCY = ""
&        & [F:ORAW]REFNUM = ""
&        & [F:ORAW]CTR = [L]CTRNUM
&        & [F:ORAW]LEG = GCURLEG
&        & evalue([L]CRITERE_ORGANISME)

    For [F:ORAW]ORA0
        If [L]TYPE_OPERATION = 2 or
&           ( [L]TYPE_OPERATION = 1 & not find([F:ORAW]ORG, [F:PCA]ORG) )
            Delete [F:ORAW]
            If fstat <> 0 & fstat <> 4
                [V]GOK = 0
                Call FSTA("ORAW") From GLOCK
                Break 2
            Endif
        Endif
    Next

    Filter [F:ORAW]

Next

If [V]GOK < 1 : Return : Endif

Return

Subprog C_ORAFLG(VALEUR)
Variable Integer VALEUR
Local Integer OK
If [L]VALEUR = 2
    # Vérification qu'il existe bien au moins un enregistrement population modèle
    # Vérification de principe car on aurait besoin de le tester plus avant (site)
    Look [F:ORA]ORA0(2) = 2 ; [M:DIA]POP
    If fstat <> 0
        # mess(168,10702,1) : Pas de modèle d'affilitation pour cette population
        Call AVERTIR(mess(168,10702,1), [L]OK) From GESECRAN
        If [L]OK = 1 : mkstat = 2 : Endif
    Endif
Endif
End



#########################################
# Gadgets de saisie : selection en masse
#########################################

# Tout à oui (bouton 1)
Subprog B1_NBLIG
Local Integer I
For [L]I = 0 To [M:DIA]NBLIG - 1
    [M:DIA]SELFLG([L]I) = 2
Next
Affzo [M:DIA]

End

# Tout à non (bouton 2)
Subprog B2_NBLIG
Local Integer I
For [L]I = 0 To [M:DIA]NBLIG - 1
    [M:DIA]SELFLG([L]I) = 1
Next
Affzo [M:DIA]
End

# Inversion (bouton 3)
Subprog B3_NBLIG
Local Integer I
For [L]I = 0 To [M:DIA]NBLIG - 1
    If [M:DIA]SELFLG([L]I) = 2
        [M:DIA]SELFLG([L]I) = 1
    Else
        [M:DIA]SELFLG([L]I) = 2
    Endif
Next
Affzo [M:DIA]
End

# Recopie des existants (bouton 4)
Subprog B4_NBLIG
Local Integer I
For [L]I = 0 To [M:DIA]NBLIG - 1
    If [M:DIA]EXIFLG([L]I) = 2
        [M:DIA]SELFLG([L]I) = 2
    Else
        [M:DIA]SELFLG([L]I) = 1
    Endif
Next
Affzo [M:DIA]
End
