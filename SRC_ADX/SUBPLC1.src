######################################################################################
## Etiquette ajoutée par le superviseur (écran PCRITLCC) 16/03/2015 15:46:35 (MAE)
######################################################################################
Subprog IB_WFCY
GBOUT1=mess(3,45,1) : # Site
End

Subprog AM_WFCY(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  #----- affichage nom du site -----#
  If [F:FCY]FCY<>[M:PLC1]WFCY
    Read [FCY] FCY0= VALEUR : If fstat Raz [F:FCY] : Endif
  Endif
  [M:PLC1]WFCYNAM=[F:FCY]FCYNAM
Else
  Raz [M:PLC1]WFCYNAM
Endif
Affzo [PLC1]WFCYNAM
End

Subprog IB_WBPSNUM
#-----------------------------#
# Avant saisie du fournisseur #
#-----------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(73,198,1) : # Fournisseur
End


Subprog AM_WBPSNUM(VALEUR)
#----------------------------#
# Après modif du fournisseur #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  #----- affichage nom du fournisseur -----#
  If [F:BPS]BPSNUM<>[M:PLC1]WBPSNUM
    Read [BPS] BPS0= VALEUR : If fstat Raz [F:BPS] : Endif
  Endif
  [M:PLC1]WBPSNAM=[F:BPS]BPSNAM
Else
  Raz [M:PLC1]WBPSNAM
Endif
Affzo [PLC1]WBPSNAM
End


#------------------------------------------------#
#------------------------------------------------#
Subprog IB_WITMREF
GBOUT1=mess(22,198,1) : # Articles
End


#------------------------------------------------#
#------------------------------------------------#
Subprog AM_WITMREF(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR <> ""
   Read [ITM] ITM0=VALEUR
   If fstat
     If instr(1,VALEUR,'*')|instr(1,VALEUR,'?')|instr(1,VALEUR,'#')|instr(1,VALEUR,'?')
       #- optimisation pour le temps de réponse -#
       Filter [ITM] Where pat(ITMREF,VALEUR)
       Read [ITM] ITM0 First : If fstat  Raz [F:ITM] : Endif
       Filter [ITM]
       If fstat
         mkstat=2
       Endif
     Else
       Raz [F:ITM] : mkstat=2
     Endif
   Else
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PLC1]WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Affzo [PLC1]WITMDES
  Endif
Endif
End
#------------------------------------------------#
Subprog IB_WPOHNUM
GBOUT1 = mess(48,198,1)
End
