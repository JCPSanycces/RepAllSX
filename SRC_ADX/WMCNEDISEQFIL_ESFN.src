# Supervisor
## ACLA-CLASSE ## EDISEQFIL_ESFN
# 2018-11-06 07:05:04 893

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDISEQFIL_ESFN
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_COMTYP From WMC1EDISEQFIL_ESFN : Gosub TESTALLSTAT
Gosub INIT_COMVAL From WMC1EDISEQFIL_ESFN : Gosub TESTALLSTAT
Gosub INIT_FORMAT From WMC1EDISEQFIL_ESFN : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDISEQFIL_ESFN : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDISEQFIL_ESFN
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDISEQFIL_ESFN
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



