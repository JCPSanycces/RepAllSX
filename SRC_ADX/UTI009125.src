#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI009119  Creation period and termination period dates    #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Creation period and termination period dates") From LECFIC

  Call MAJ_UTI009125(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTI009125(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR
Local Char CPYNAME(200)
Local Char GCURLEG(200)

CPYNAME = func AFNC.PARAMDOS(nomap,"TAXRECCPY")
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Filter [CPY] Where CPY=CPYNAME
Read [CPY]CPY0 Last
Filter [CPY]
If !fstat
  GCURLEG=[F:CPY]LEG
Endif



If clalev([F:HRCTR])>0  : Close Local File [HRCTR]  : Endif
Local File =DOSSIER+".EMPLOCTR" [HRCTR]

If clalev([F:FCY])>0  : Close Local File [FCY]  : Endif
Local File =DOSSIER+".FACILITY" [FCY]


If clalev([F:HRCTR5])>0  : Close Local File [HRCTR5]  : Endif
Local File =DOSSIER+".EMPLOCTR" [HRCTR5]

Call ECR_TRACE("UTI009125 : Reset of tax cycle dates on contracts : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#

Raz COMPTEUR
Call DEBTRANS From GLOCK



If func DIVPAYE.IS_KZA(GCURLEG) Then
  If clalev([F:CTRSA])>0  : Close Local File [CTRSA]  : Endif
  Local File =DOSSIER+".EMPLOCTRSA" [CTRSA]


  If clalev([F:CTRSA5])>0  : Close Local File [CTRSA5]  : Endif
  Local File =DOSSIER+".EMPLOCTRSA" [CTRSA5]


  If clalev([F:ETR])>0  : Close Local File [ETR]  : Endif
  Local File =DOSSIER+".EMPLOTAXREC" [ETR]


  Trbegin [HRCTR], [CTRSA],[ETR]
  Gosub MAJACVKZA
Endif



If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then
  If clalev([F:CTRAFR])>0  : Close Local File [CTRAFR]  : Endif
  Local File =DOSSIER+".EMPLOCTRAFR" [CTRAFR]

  If clalev([F:CTRAFR5])>0  : Close Local File [CTRAFR5]  : Endif
  Local File =DOSSIER+".EMPLOCTRAFR" [CTRAFR5]


  If clalev([F:ETA])>0  : Close Local File [ETA]  : Endif
  Local File =DOSSIER+".EMPLOTAXAFR" [ETA]

  Trbegin [HRCTR], [CTRAFR],[ETA]
  Gosub MAJACVKAQ
Endif



If !GOK
  Raz COMPTEUR
  Rollback
Else
  Commit
Endif

Close Local File [HRCTR]

Call ECR_TRACE("UTI009125 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

$MAJACVKAQ


Local Integer MYFLG,THISTAXYEAR
Local Date STRDAT,ENDDAT
Local Integer VARCONTRACT

STRDAT=func AFNC.PARAM("TAXSTRDAT",GCURLEG)
ENDDAT=func AFNC.PARAM("TAXENDDAT",GCURLEG)

THISTAXYEAR = year(ENDDAT)


If CPYNAME <> "" Then

    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK9]
&   Where   ([HRCTR]CTRDAT<=ENDDAT & ([HRCTR]XITDAT>=STRDAT| [HRCTR]XITDAT=[0/0/0]))
& &         [FCY]LEGCPY=CPYNAME
Else
  Call ECR_TRACE("UTI009125 : No company specified : "+DOSSIER,0) From GESECRAN
  End

Endif

VARCONTRACT = 0


For [LNK9]

VARCONTRACT = 0

  MYFLG=0

If [F:HRCTR]CTRDAT<=ENDDAT & ([F:HRCTR]XITDAT>=STRDAT | [F:HRCTR]XITDAT=[0/0/0]) Then


  Filter [F:CTRAFR]  Where  [CTRAFR]REFNUM=[HRCTR]REFNUM  and [CTRAFR]CTRNUM=[HRCTR]CTRNUM and [CTRAFR]CTRDAT=[HRCTR]CTRDAT
  Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT

If (!fstat) Then

  MYFLG=1

  Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT and TAXYEA= [L]THISTAXYEAR
  Read [F:ETA]ETA0 Last

  If (!fstat) Then
    [F:CTRAFR] =[F:ETA]
    [F:ETA]YEAENDRUNIND=1
    Rewrite  [F:ETA]
  Endif

    Filter [CTRAFR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM
    Filter [HRCTR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM

  If rowcount([CTRAFR5]) > 1 Then

        For [HRCTR5]CTR0
             If [HRCTR5]FLGVAR = 2 Then
                VARCONTRACT = 1
             Endif
        Next

          If VARCONTRACT = 1 Then
                Read [CTRAFR5]CTRAFR1 First
                Read [HRCTR5]CTR1 First

               [F:CTRAFR]TAXSTRDAT=max(STRDAT, [HRCTR5]CTRDAT)
               [F:CTRAFR]TAXENDDAT =  [HRCTR5]XITDAT

          Else

                Read [CTRAFR5]CTRAFR1 First
                Read [HRCTR5]CTR1 First

               [F:CTRAFR]TAXSTRDAT=max(STRDAT, [HRCTR5]CTRDAT)


                Filter [CTRAFR5]
                Filter [HRCTR5]

                Filter [CTRAFR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM
                Filter [HRCTR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM

                Read [CTRAFR5]CTRAFR1 Last
                Read [HRCTR5]CTR1 Last

                If [HRCTR5]XITDAT <> [00/00/00]
                   If [HRCTR5]XITDAT < ENDDAT and [HRCTR5]XITFNL= 2 Then
                       [F:CTRAFR]TAXENDDAT =  [HRCTR5]XITDAT
                    Else
                       [F:CTRAFR]TAXENDDAT=ENDDAT
                    Endif
                Else
                     [F:CTRAFR]TAXENDDAT=ENDDAT
                Endif
          Endif
  Else

      Read [CTRAFR5]CTRAFR1 First
      Read [HRCTR5]CTR1 First

     [F:CTRAFR]TAXSTRDAT=max(STRDAT, [HRCTR]CTRDAT)
      If [HRCTR]XITDAT <> [00/00/00]
         If [HRCTR]XITDAT < ENDDAT and [HRCTR]XITFNL= 2 Then
             [F:CTRAFR]TAXENDDAT =  [HRCTR]XITDAT
          Else
             [F:CTRAFR]TAXENDDAT=ENDDAT
          Endif
      Else
           [F:CTRAFR]TAXENDDAT=ENDDAT
      Endif

  Endif


Filter [F:ETA]
Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA > THISTAXYEAR


If rowcount([F:ETA]) > 0 Then
  Delete [F:ETA] Where CTRNUM = [HRCTR]CTRNUM & REFNUM = [HRCTR]REFNUM and TAXYEA > THISTAXYEAR
Endif


Endif

Endif


If MYFLG
    Rewrite [F:CTRAFR]
    If fstat
      GOK = 0 : Call FSTA("CTRAFR") From GLOCK
      Break
    Endif
    COMPTEUR += 1
  Endif
Next


#
#-----------------End-Dev--------------------------#

Return

##############################
$MAJACVKZA
##-----------------Start-Dev------------------------#
#Do you all entries here
#!!!Remember to set COMPTEUR as shown in the example!!!
#Example
Local Integer MYFLG,THISTAXYEAR
Local Date STRDAT,ENDDAT
Local Integer VARCONTRACT

STRDAT=func AFNC.PARAM("TAXSTRDAT",GCURLEG)
ENDDAT=func AFNC.PARAM("TAXENDDAT",GCURLEG)
THISTAXYEAR = year(ENDDAT)




If CPYNAME = "" Then

Call ECR_TRACE("UTI009125 : No company specified : "+DOSSIER,0) From GESECRAN
End
Else


    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK9]
&   Where   ([HRCTR]CTRDAT<=ENDDAT & [FCY]LEGCPY=CPYNAME & ([HRCTR]XITDAT>=STRDAT| [HRCTR]XITDAT=[0/0/0]))

Endif



VARCONTRACT = 0

For [LNK9]
  MYFLG=0
VARCONTRACT = 0



  Filter [F:CTRSA]  Where  [CTRSA]REFNUM=[HRCTR]REFNUM  and [CTRSA]CTRNUM=[HRCTR]CTRNUM and [CTRSA]CTRDAT=[HRCTR]CTRDAT
  Read [F:CTRSA]CTRSA0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT

If (!fstat) Then

   MYFLG=1


  Filter [F:ETR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT and TAXYEA= [L]THISTAXYEAR
  Read [F:ETR]ETR0 Last

  If (!fstat) Then
    [F:CTRSA] =[F:ETR]
    [F:ETR]YEAENDRUNIND=1
    Rewrite  [F:ETR]
  Endif

    Filter [CTRSA5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM
    Filter [HRCTR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM

  If rowcount([CTRSA5]) > 1 Then

        For [HRCTR5]CTR0
             If [HRCTR5]FLGVAR = 2 Then
                VARCONTRACT = 1
             Endif
        Next


          If VARCONTRACT = 1 Then
                Read [CTRSA5]CTRSA1 First
                Read [HRCTR5]CTR1 First

               [F:CTRSA]IRPSTRDAT=max(STRDAT, [HRCTR5]CTRDAT)
               [F:CTRSA]IRPENDDAT =  [HRCTR5]XITDAT

          Else

                Read [CTRSA5]CTRSA1 First
                Read [HRCTR5]CTR1 First

               [F:CTRSA]IRPSTRDAT=max(STRDAT, [HRCTR5]CTRDAT)


                Filter [CTRSA5]
                Filter [HRCTR5]

                Filter [CTRSA5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM
                Filter [HRCTR5] Where REFNUM=[HRCTR]REFNUM & CTRNUM=[HRCTR]CTRNUM

                Read [CTRSA5]CTRSA1 Last
                Read [HRCTR5]CTR1 Last

                If [HRCTR5]XITDAT <> [00/00/00]
                   If [HRCTR5]XITDAT < ENDDAT and [HRCTR5]XITFNL= 2 Then
                       [F:CTRSA]IRPENDDAT =  [HRCTR5]XITDAT
                    Else
                       [F:CTRSA]IRPENDDAT=ENDDAT
                    Endif
                Else
                     [F:CTRSA]IRPENDDAT=ENDDAT
                Endif
          Endif


  Else

      Read [CTRSA5]CTRSA1 First
      Read [HRCTR5]CTR1 First

     [F:CTRSA]IRPSTRDAT=max(STRDAT, [HRCTR]CTRDAT)
      If [HRCTR]XITDAT <> [00/00/00]
         If [HRCTR]XITDAT < ENDDAT and [HRCTR]XITFNL= 2 Then
             [F:CTRSA]IRPENDDAT =  [HRCTR]XITDAT
          Else
             [F:CTRSA]IRPENDDAT=ENDDAT
          Endif
      Else
           [F:CTRSA]IRPENDDAT=ENDDAT
      Endif

  Endif


Filter [F:ETR]
Filter [F:ETR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA > THISTAXYEAR


If rowcount([F:ETR]) > 0 Then
  Delete [F:ETR] Where CTRNUM = [HRCTR]CTRNUM & REFNUM = [HRCTR]REFNUM and TAXYEA > THISTAXYEAR
Endif



Endif



If MYFLG
    Rewrite [F:CTRSA]
    If fstat
      GOK = 0 : Call FSTA("CTRAFR") From GLOCK
      Break
    Endif
    COMPTEUR += 1
  Endif
Next


#
#-----------------End-Dev--------------------------#


Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTI009125(APPLI)
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
# On  regarde si le module est à "Oui"
If [F:ADS]MODULE(8) <> 2 : End : Endif

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
#-----------------End-Dev--------------------------#
Call MAJ_UTI009125(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif                                 : # 1= Paie

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTI009125(APPLI)
End

