#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:27"
A_USER  = "DOC"
A_STAMP = "20181109230627"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBJOU"
  If [M]NBJOU=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SIPAR5 [SIP5]
Gosub HORODAT
Local Inpbox "SIPAR5" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP5] As [SIM_]
Grizo [SIP5]5
Grizo [SIP5]10
Grizo [SIP5]15
Grizo [SIP5]20
Grizo [SIP5]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIP5]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=92 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=43 : Y1(1)=3 : Y2(1)=13
X1(2)=44 : X2(2)=92 : Y1(2)=3 : Y2(2)=4
X1(3)=44 : X2(3)=92 : Y1(3)=5 : Y2(3)=13
X1(4)=1 : X2(4)=92 : Y1(4)=14 : Y2(4)=16
Return

$ON_STRPER
Onevent INIT_AREA Call D_STRPER(zc) From W1SIPAR5
Onevent CONTROL Call C_STRPER(zc) From W1SIPAR5
Onevent BEFORE_INPUT Call AS_STRPER(zc) From W1SIPAR5
Onevent BEFORE_AREA Gosub AV_STRPER From W1SIPAR5
Return

Subprog IB_STRPER(VALEUR)
Variable Date    VALEUR
## Action STD
Call IB_STRPER From SUBSIP
Gosub _AFF
End

$AV_STRPER
Chgfmt [M]STRPER(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog D_STRPER(VALEUR)
Variable Date    VALEUR
If varinit([M]STRPER,indice)=0
 ## Action STD
 Call D_STRPER(VALEUR) From SUBSIP
Endif
Gosub _AFF
End

Subprog AS_STRPER(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUT1) From OBJDIV
Call IB_STRPER(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_STRPER(zc) From W1SIPAR5
Gosub _AFF
End

Subprog C_STRPER(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_STRPER(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "STRPER" : GZNUM = 9567 : Endif
Gosub _AFF
End

Subprog B1_STRPER(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_STRPER(VALEUR) From SUBSIP
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ACM
Onevent BEFORE_AREA Gosub AV_ACM From W1SIPAR5
Onevent INIT_AREA Call D_ACM(zc) From W1SIPAR5
Onevent CONTROL Call C_ACM(zc) From W1SIPAR5
Onevent BEFORE_INPUT Call AS_ACM(zc) From W1SIPAR5
Onevent AFTER_CHANGE Gosub AMM_ACM From W1SIPAR5
Return

$AV_ACM
## Action STD
Call AV_ACM(zc) From SUBSIP
Gosub _AFF
Return

Subprog D_ACM(VALEUR)
Variable Char    VALEUR()
If varinit([M]ACM,indice)=0
 ## Action STD
 Call D_ACM(VALEUR) From SUBSIP
Endif
Gosub _AFF
End

Subprog AS_ACM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(27516,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ACM(zc) From W1SIPAR5
Onkey   2 Titled GBOUTS Call S_ACM(zc) From W1SIPAR5
Onkey 144 Titled GBOUTP Call P_ACM(zc) From W1SIPAR5
Onkey 146 Titled GBOUTA Call SA_ACM(zc) From W1SIPAR5
Gosub _AFF
End

Subprog C_ACM(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("GCM","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "ACM" : GZNUM = 27516 : Endif
If !mkstat
 ## Action STD
 Call C_ACM(VALEUR) From SUBSIP
 If mkstat : GERR = 1 : GZONE = "ACM" : GZNUM = 27516 : Endif
Endif
Gosub _AFF
End

$AMM_ACM
Call AM_ACM(zc)
If !mkstat & GOBJET
 zoncou = "ACM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZACM)")>indice
 [M]ACM(indice) = VALEUR
 Affzo ZACM(indice)
Endif
Gosub _AFF
End

Subprog S_ACM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "GCM"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ACM(VALEUR)
Variable Char    VALEUR()
Call OBJET("GCM",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_ACM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "GCM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("GCM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZACM
Onevent BEFORE_AREA Gosub AV_ZACM From W1SIPAR5
Return

$AV_ZACM
Call LECTEXTRA(zc,"GACM","DESTRA",num$([M]ACM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_COA
Return

$ON_ZCOA
Onevent BEFORE_AREA Gosub AV_ZCOA From W1SIPAR5
