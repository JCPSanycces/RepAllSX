Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUT1) From OBJDIV
Call IB_NBJOU
## Action STD
Call AS_NBJOU From SUBSIP
Onkey 129 Titled GBOUT1 Call B1_NBJOU From W1SIPAR5
Gosub _AFF
End

Subprog B1_NBJOU
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBJOU From SUBSIP
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_JOU
Return

$ON_GTE
Onevent CONTROL Call C_GTE(zc) From W1SIPAR5
Onevent BEFORE_INPUT Call AS_GTE(zc) From W1SIPAR5
Return

Subprog AS_GTE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5152,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_GTE(zc) From W1SIPAR5
Onkey   2 Titled GBOUTS Call S_GTE(zc) From W1SIPAR5
Onkey 144 Titled GBOUTP Call P_GTE(zc) From W1SIPAR5
Onkey 146 Titled GBOUTA Call SA_GTE(zc) From W1SIPAR5
Gosub _AFF
End

Subprog C_GTE(VALEUR)
Variable Char    VALEUR()
## Action CONTGTE
Call CONTGTE(VALEUR,"","") From SUBGTE
If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
 If !mkstat
  ## Action STD
  Call C_GTE(VALEUR) From SUBSIP
  If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_GTE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELGTE
 Call SELGTE(VALEUR,"",0,"") From SUBGTE
Endif
Gosub _AFF
End

Subprog B1_GTE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNGTE
 Call TUNGTE(VALEUR,"") From SUBGTE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_GTE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "GTE"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_GTE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("GTE",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

