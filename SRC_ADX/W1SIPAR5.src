Onevent AFTER_CHANGE Gosub AMM_ACCTMP From W1SIPAR5
Return

$AV_ACCTMP
## Action INIACCFMT
Call INIACCFMT(num$([M:SIP5]COA)) From SETGLBCOA
If GFMTACC<>""
 Chgfmt [M]ACCTMP(indice) With "K:"+GFMTACC
Else
 Chgfmt [M]ACCTMP(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog D_ACCTMP(VALEUR)
Variable Char    VALEUR()
If varinit([M]ACCTMP,indice)=0
 ## Action STD
 Call D_ACCTMP(VALEUR) From SUBSIP
Endif
Gosub _AFF
End

Subprog AS_ACCTMP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ACCTMP(zc) From W1SIPAR5
Onkey 144 Titled GBOUTP Call P_ACCTMP(zc) From W1SIPAR5
Onkey 146 Titled GBOUTA Call SA_ACCTMP(zc) From W1SIPAR5
Gosub _AFF
End

Subprog C_ACCTMP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GACCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GACCHOICE"
 PARMSK(1) = num$([M:SIP5]COA)
 Call S_TAB_CHAR(VALEUR,PARMSK,"GACCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCTMP" : GZNUM = 32440 : Endif
Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTCPT
  Call CONTCPT(VALEUR,num$([M:SIP5]COA)) From CPTSUB
  If mkstat : GERR = 1 : GZONE = "ACCTMP" : GZNUM = 32440 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("GAC","!G",VALEUR,num$([M:SIP5]COA),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACCTMP" : GZNUM = 32440 : Endif
Endif
Gosub _AFF
End

$AMM_ACCTMP
Call AM_ACCTMP(zc)
If !mkstat & GOBJET
 zoncou = "ACCTMP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

