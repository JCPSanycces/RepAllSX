Subprog AS_DACDIAGEN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(38323,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DACDIAGEN(zc) From W1SIPAR5
Onkey   2 Titled GBOUTS Call S_DACDIAGEN(zc) From W1SIPAR5
Onkey 144 Titled GBOUTP Call P_DACDIAGEN(zc) From W1SIPAR5
Onkey 146 Titled GBOUTA Call SA_DACDIAGEN(zc) From W1SIPAR5
Gosub _AFF
End

Subprog C_DACDIAGEN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("GDE","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
 If !mkstat
  ## Action STD
  Call C_DACDIAGEN(VALEUR) From SUBSIP
  If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DACDIAGEN
Call AM_DACDIAGEN(zc)
If !mkstat & GOBJET
 zoncou = "DACDIAGEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

