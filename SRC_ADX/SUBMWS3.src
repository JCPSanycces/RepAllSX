#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION 
Endcase
Return

########################################################################### 
## Lecture des lignes 
######################################################################### 
$LIENS 
Local Integer I : I=0 
# 

[M:MWS3]NBLIG = 0
Read [RPW]RPW0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat : Return : Endif
For I = 0 To 24
    If [F:RPW]RPLWST(I) ="" : Break : Endif
    [M:MWS3]RPLWST(I)    =[F:RPW]RPLWST(I)
    [M:MWS3]RPLWSTDES(I) =[F:RPW]RPLWSTDES(I)
    [M:MWS3]PIO(I)       =[F:RPW]PIO(I)
    [M:MWS3]RPLWCR(I)    =[F:RPW]WCR(I)
    [M:MWS3]RPLWSTTYP(I) =[F:RPW]WSTTYP(I)
Next I

[M:MWS3]NBLIG = I 

Return

######################################################################### 
$CHARG_LIB
Read [AMZ] CODE="MWS3";GBIDC3 : If fstat Raz [F:AMZ] : Endif
Call TEXTE([F:AMZ]INTIT,GBIDC3) From OBJDIV
Return


######################################################################### 
$VERIF_MOD
# tri le tableau en fontion de l'ordre de priorité des postes
Sorta [M:MWS3]NBLIG [M:MWS3]NBLIG Order By [M:MWS3]PIO(indice)
Affzo [M:MWS3]5
Return

########################################################################### 
## Création des lignes 
######################################################################### 
$CREATION    
Local Integer I 

# Pour tri
Gosub VERIF_MOD
[F:RPW]WST = [M:MWS0]WST
[F:RPW]WCRFCY = [M:MWS0]WCRFCY

For I=0 To [M:MWS3]NBLIG-1
    [F:RPW]RPLWST(I)    =[M:MWS3]RPLWST(I)
    [F:RPW]RPLWSTDES(I) =[M:MWS3]RPLWSTDES(I)
    [F:RPW]PIO(I)       =[M:MWS3]PIO(I)
    [F:RPW]WCR(I)       =[M:MWS3]RPLWCR(I)
    [F:RPW]WSTTYP(I)    =[M:MWS3]RPLWSTTYP(I)
Next I

[F:RPW]CREDAT = date$
[F:RPW]CREUSR = GUSER
[F:RPW]EXPNUM = [C]EXPORT



Write [RPW]
If fstat : GOK = 0 : Call FSTA ("RPW") From GLOCK : Endif

Return


########################################################################### 
## Modification des lignes 
######################################################################### 
$MODIF 
Local Integer I

Readlock [RPW]RPW0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat=1 : GOK=-1 : GLOCK="$"+"RPLWST"+num$(I) : Return : Endif

For I=0 To 24
    If I<[M:MWS3]NBLIG
        [F:RPW]RPLWST(I)    = [M:MWS3]RPLWST(I)
        [F:RPW]RPLWSTDES(I) = [M:MWS3]RPLWSTDES(I)
        [F:RPW]PIO(I)       = [M:MWS3]PIO(I)
        [F:RPW]WCR(I)       = [M:MWS3]RPLWCR(I)
        [F:RPW]WSTTYP(I)    = [M:MWS3]RPLWSTTYP(I)
    Else
        [F:RPW]RPLWST(I)    =""
        [F:RPW]RPLWSTDES(I) =""
        [F:RPW]PIO(I)       =0 
        [F:RPW]WCR(I)       =""
        [F:RPW]WSTTYP(I)    =0
    Endif
Next I
If fstat= 0 : 
   [F:RPW]UPDDAT = date$
   [F:RPW]UPDUSR = GUSER
   [F:RPW]EXPNUM = [C]EXPORT
   Rewrite [RPW]
Elsif fstat=5
   [F:RPW]WST     = [M:MWS0]WST
   [F:RPW]WCRFCY  = [M:MWS0]WCRFCY
   [F:RPW]CREDAT  = date$
   [F:RPW]CREUSR  = GUSER
   [F:RPW]EXPNUM  = [C]EXPORT
   Write [RPW]
Endif

# Pour tri
Gosub VERIF_MOD
Return


###########################################################################  
## Annulation des lignes  
#########################################################################  
$ANNULE    
Local Integer WRETOUR ,I
Local Char    WNUMTEX (12)

Readlock [RPW]RPW0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat=1 : GOK=-1 : GLOCK="$"+"RPLWST"-num$(I) : Return : Endif

Delete [RPW]

Return

########################################################################### 
## Etiquettes 
#########################################################################
########################################
Subprog S_RPLWST(VALEUR)
Variable Char    VALEUR()
Variable Char    VALEUR()
Local    Char    LIB(20)(5)
If clalev([F:AMZ])<=0 Local File AMSKZON [AMZ] : Endif


GBIDC3="WST"       : Gosub CHARG_LIB : LIB(0)=GBIDC3
GBIDC3="WCR"       : Gosub CHARG_LIB : LIB(1)=GBIDC3
GBIDC3="WCRFCY"    : Gosub CHARG_LIB : LIB(2)=GBIDC3
GBIDC3="RPLWSTTYP" : Gosub CHARG_LIB : LIB(3)=GBIDC3
GBIDC3="RPLWSTDES" : Gosub CHARG_LIB : LIB(4)=GBIDC3
$CHOIX_RPLWST
Choose [MWS2] Where WST >=VALEUR & WCRFCY = [M:MWS0]WCRFCY 
&             Using WST Titled LIB(0),WCR Titled LIB(1),
&                   WCRFCY Titled LIB(2),  WSTTYP Titled LIB(3),
&                   WSTDES Titled LIB(4)
&             Sized (96,160) Titled mess(200,195,1)
If status=GSTASRA Goto CHOIX_RPLWST : Endif
If status=0
  Call MESSAGE(mess(71,197,1)) From GESECRAN : Raz [F:MWS2]
Elsif status=7    
  Raz [F:MWS2]
  mkstat= 1
  End
Endif
VALEUR=[F:MWS2]WST
If VALEUR="": mkstat=1 : End : Endif
[M:MWS3]RPLWCR(nolign-1)     =[F:MWS2]WCR
[M:MWS3]RPLWSTTYP(nolign-1)  =[F:MWS2]WSTTYP
#[M:MWS3]RPLWSTDES(nolign-1)  =[F:MWS2]WSTDES
#LECTURE du libellé traduisible
Call LECTEXTRA([M:MWS3]RPLWSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[F:MWS2]WST,[F:MWS2]WCRFCY) From ATEXTRA
If !GIMPORT : Affzo [M:MWS3]RPLWSTDES(nolign-1), RPLWCR(nolign-1), RPLWSTTYP(nolign-1) : Endif

End



########################################
Subprog C_RPLWST(VALEUR)
Variable Char    VALEUR()
Local Integer I

If VALEUR = "" :  End : Endif
Read [MWS2]WST0 = VALEUR;[M:MWS0]WCRFCY
If fstat 
   # FGR 13/01/2010 : X3SUIVI60986 WOMWS
   #Gosub TIT From GESMWS : GMESSAGE=TIT-":"- VALEUR +"\"+mess(133,193,1) 
   Gosub TIT From WOMWS : GMESSAGE=TIT-":"- VALEUR +"\"+mess(133,193,1) 
   mkstat = 2 
Endif 
If VALEUR = [M:MWS0]WST 
    GMESSAGE = mess(92,193,1) : mkstat = 1 : End 
Endif 

# poste rpl déjà dans liste ?
For I=0 To [M:MWS3]NBLIG-1
  If ([M:MWS3]RPLWST(I)=VALEUR & I<>(nolign-1))
     GMESSAGE = mess(24,123,1)-num$(I+1) : mkstat = 2
  Endif
Next I

End

########################################
Subprog AM_RPLWST(VALEUR)
Variable Char    VALEUR()


Read [MWS2]WST0 = VALEUR;[M:MWS0]WCRFCY 
If !fstat 
#    [M:MWS3]RPLWSTDES(nolign-1) = [F:MWS2]WSTDES  
    #LECTURE du libellé traduisible
    Call LECTEXTRA([M:MWS3]RPLWSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[F:MWS2]WST,[F:MWS2]WCRFCY) From ATEXTRA
    [M:MWS3]RPLWCR(nolign-1)    = [F:MWS2]WCR  
    [M:MWS3]RPLWSTTYP(nolign-1) = [F:MWS2]WSTTYP  
    #  "Attention, les types sont différents"   (03/02/00  TB)
    If [F:MWS2]WSTTYP <> [M:MWS0]WSTTYP
        Call MESSAGE(mess(129,193,1)) From GESECRAN 
    Endif         
Else  
    Raz VALEUR
    Raz [M:MWS3]RPLWSTDES(nolign-1),RPLWCR(nolign-1),RPLWSTTYP(nolign-1),PIO(nolign-1)
Endif
If !GIMPORT 
    Affzo [M:MWS3]RPLWSTDES(nolign-1), RPLWCR(nolign-1), RPLWSTTYP(nolign-1),PIO(nolign-1)
Endif

End



########################################
Subprog C_PIO(VALEUR)
Variable Decimal VALEUR
Local Integer I

For I=0 To NBLIG-1
    If ([M:MWS3]PIO(I)=VALEUR & I<>(nolign-1))
         GMESSAGE = mess(24,123,1)-num$(I+1) : mkstat = 2
    Endif
Next I

End






