# Class CCMIMPSOD SALES Order IMPACT ANALYSIS 'detail'

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "SET_STAGE"     : Gosub SET_STAGE
      Endcase
  Endcase
Return

# --------------------------------------------------
# Function Type: Method
# Function Name: SET_STAGE
# Function Description: Populate the STAGE property.
# If
$SET_STAGE

  If ((this.ODLQTYSTU > 0) or
&     (this.DLVQTY > 0 and this.DLVQTY < this.QTY))
    this.STAGE = 3                                    # Delivery ...
  Elsif (this.OPRQTYSTU > 0 or this.PREQTYSTU > 0)
    this.STAGE = 2                                    # Preparation ...
  Else
    this.STAGE = 1                                    # Order ...
  Endif

Return


$PROPERTIES
  Case CURPRO
  Endcase
Return


