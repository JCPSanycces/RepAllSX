##=========================================================================
#  Ce s/p permet de charger les nouveaux biens par BCO à éclater
#  on vient de cliquer.
#=========================================================================
Subprog LOAD_NEW_BCO(PNOLIGN)
Value Integer PNOLIGN
Local Char    MASQUE
Local Integer RC
Local Char CRITSEL(255)
Local Integer SAV_NOLIGN, I
Local Integer ERR_BCO

If !(clalev([F:TMP2])) : Local File TMPMASFAS [TMP2] : Endif


CRITSEL='TRTNUM=NUMACT & AASIND ="N" & OBJREFO=[M:MFS0]OBJREF(PNOLIGN-1)'

 Filter [TMP2] Where evalue(CRITSEL) Order By Key MFS3 # Issue 109496
 SAV_NOLIGN=nolign
 Raz nolign
 ERR_BCO = 0
 For [TMP2]
  nolign+=1
  [M:MFS0]OBJREFN(nolign-1)     = [F:TMP2]OBJREF
  [M:MFS0]OBJREFO(nolign-1)     = [F:TMP2]OBJREFO
  [M:MFS0]AASDES1N(nolign-1)    = [F:TMP2]AASDES1
  [M:MFS0]AASINDN(nolign-1)     = [F:TMP2]AASIND
  [M:MFS0]AASDES2N(nolign-1)    = [F:TMP2]AASDES2
  [M:MFS0]ACGGRPN(nolign-1)     = [F:TMP2]ACGGRP
  [M:MFS0]ACCCODN(nolign-1)     = [F:TMP2]ACCCOD
  [M:MFS0]GACN(nolign-1)        = [F:TMP2]GAC
  [M:MFS0]IASACCN(nolign-1)     = [F:TMP2]IASACC
  [M:MFS0]AASQTYN(nolign-1)     = [F:TMP2]AASQTY
  [M:MFS0]ACGETRNOTN(nolign-1)  = [F:TMP2]ACGETRNOT
  [M:MFS0]IASETRNOTN(nolign-1)  = [F:TMP2]IASETRNOT
  [M:MFS0]BRDPRCN(nolign-1)     = [F:TMP2]BRDPRC
  [M:MFS0]USRFLDM1N(nolign-1)   = [F:TMP2]USRFLDM1
  [M:MFS0]USRFLDM2N(nolign-1)   = [F:TMP2]USRFLDM2
  [M:MFS0]USRFLDM3N(nolign-1)   = [F:TMP2]USRFLDM3
  [M:MFS0]USRFLDM4N(nolign-1)   = [F:TMP2]USRFLDM4
  [M:MFS0]USRFLDM5N(nolign-1)   = [F:TMP2]USRFLDM5
  [M:MFS0]USRFLDM6N(nolign-1)   = [F:TMP2]USRFLDM6
  [M:MFS0]FLGERRN(nolign-1)     = [F:TMP2]FLGERR
  [M:MFS0]FLGMODN(nolign-1)     = [F:TMP2]FLGMOD
  If [F:TMP2]FLGERR=G_OUI : ERR_BCO=1 : Endif
  #-> On active la ligne si le flag FLGMOD est à G_OUI
  If [F:TMP2]FLGMOD=G_OUI
    Call AFFICHE_LIGNE("ACTZO",MASQUE,"MFS0",2,nolign-1,RC) From SUBMAS
  Else
    #-> On grise la ligne si le flag FLGMOD est à G_NON
     Call AFFICHE_LIGNE("DISZO",MASQUE,"MFS0",2,nolign-1,RC) From SUBMAS
  Endif
 Next

 [M:MFS0]NBOBJN = nolign
 Affzo [M:MFS0]10
 nolign=SAV_NOLIGN

Filter [TMP2]

End
#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#========================================================================
#
Subprog CHGACTPARM()
#
# En après modif de chaque  champ de paramètre de l'action métier.
# Permet, si un paramètre a déjà été appliqué à la population sélectionnée,
#   de demander si on veut prendre en compte le nouveau paramètre
#      - Si oui, on nettoie tout ce qui avait été calculé à partir des  paramètres précédents et on
# revient à l'étape d'application des nouveaux paramètres
#     - Si non, on retourne en saisie sur le champ
# ------------------------------------------------------------------------------
If ACTSTATUS<>STA_DEBUT
  Local Integer POK,ERR,NBDLREC
  Local Char    MES
  # "Vous avez modifié un paramètre. Le résultat de l'éclatement va changer.Voulez-vous continuer ?"
  Call OUINON (mess(546,GML_MSGFAS,1),POK) From GESECRAN
  Case POK
   When G_OUI
    ACTSTATUS=STA_DEBUT
   #=> Unlock la population
    Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM
   #=> Vider les tables de travail
    Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM             #=> On vide la table temporaire principale
    If ACTGESPLN=G_OUI
     Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM         #=> On vide la table temporaire par plan
    Endif
   When Default
    mkstat = 2 : End
  Endcase
Endif

End

################################################################################
# Traitement de gestion de la trace - informations particulières à  l'action    #
################################################################################

#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#

#---------------------------------------------------------------------
# Emission de l'en-tête société dans la trace
#---------------------------------------------------------------------
Subprog ET_COMPTE_RENDU(PCPY)
Value Char PCPY

Local Char LIGNE(115)

If FLGDET=G_OUI & ACTSILENCE<>G_OUI

 Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3

 LIGNE = string$(115,"=")
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

 LIGNE =space$(2)
 LIGNE+=left$(mess(002,3141,1)+space$(21),21)+"! "
 LIGNE+=left$(mess(251,GML_MSGFAS,1)+space$(20),20)
 LIGNE+=space$(max(0,15-len(mess(214,GML_MSGFAS,1))))+mess(214,GML_MSGFAS,1)
 LIGNE+=space$(max(0,13-len(mess(243,GML_MSGFAS,1))))+mess(243,GML_MSGFAS,1)+space$(2)
 LIGNE+=space$(max(0,13-len(mess(245,GML_MSGFAS,1))))+mess(245,GML_MSGFAS,1)
 LIGNE+=space$(max(0,25-len(mess(550,GML_MSGFAS,1))))+mess(550,GML_MSGFAS,1)
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

 LIGNE = string$(115,"=")
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

Endif

End

######################################################################
# Sous-pro et routines communes
######################################################################
#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)= GTAMMAS             # Massif / unitaire
     PARAM(2)= "FASSPLM"           # Nom de l'action métier
     PARAM(3)= num$(GVML_OMBIEN)   # Objet métier de référence
     PARAM(4)= num$(G_OUI)         # Mono société
     PARAM(5)= num$(G_NON)         # Plan d'amortissement
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASSPLM","FASSPLM",4,"") From GTRAITE
   When Default
  Endcase
End
#--------------------------------------------------------------#
# Emission d'un séparateur dans la trace                       #
#--------------------------------------------------------------#
Subprog SEP_COMPTE_RENDU(PCPY)
Value Char PCPY
Local Char LIGNE(115)

 LIGNE = string$(115,"-")
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

End
#--------------------------------------------------------------#
# Emission de la ligne  référence BCO / désignation dans la    #
# trace                                                        #
#--------------------------------------------------------------#
Subprog BCO_COMPTE_RENDU(PCPY,PREF,PDES,PSTATUS,PMES)
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PSTATUS
Value Char PMES

If ACTSILENCE=G_OUI : End : Endif

Local Char LIGNE(115)

 LIGNE ="  "
 LIGNE+=PREF
 LIGNE+=space$(20-len(PREF))
 LIGNE+=" ! "
 LIGNE+=PMES
 LIGNE+=space$(115-len(PMES))
 If    PSTATUS="1"
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 Elsif PSTATUS="0"
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,1,1) From TRACEABX3
 Endif

End

################################################################################
# Traitement de gestion du compte-rendu- informations particulières à l'action    #
################################################################################
$GESTRACE

     # "Eclatement: traitement massif" (547)
     # Référence Clé de ventilation (553)
     # Clé de répartition (548)

If !(clalev([F:BRD]))   : Local File BRDKEY    [BRD]   : Endif  # table des clés de répartition

Case TRTYP
When 1
  # Ouverture
  If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
  Call OUVRE_TRACE (mess(547,GML_MSGFAS,1),1) From TRACEABX3
When 20

   Local Char LCPY
   LCPY =[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)
   Call ECR_TRACE("",GTRC_PARAM,left$(mess(553,GML_MSGFAS,1)+space$(32),32)+":"-[M:SPLM]BRDREF,0,1) From TRACEABX3
   Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
   Read [BRD]BRD1=LCPY;[M:SPLM]BRDREF
   If fstat = 0
      Call ECR_TRACE("",GTRC_PARAM,left$(mess(548,GML_MSGFAS,1)+space$(32),32)+":"-(mess([F:BRD]DSPKEY,3122,1)),0,1) From TRACEABX3
      Call ECR_TRACE("",GTRC_PARAM,left$(mess(554,GML_MSGFAS,1)+space$(32),32)+":",0,1) From TRACEABX3
      If [F:BRD]CHAMP1 > 0
         Call ECR_TRACE("",GTRC_PARAM,space$(35)+left$(mess([F:BRD]CHAMP1,3129,1)+space$(32),32),0,1) From TRACEABX3
      Endif
      If [F:BRD]CHAMP2 > 0
         Call ECR_TRACE("",GTRC_PARAM,space$(35)+left$(mess([F:BRD]CHAMP2,3129,1)+space$(32),32),0,1) From TRACEABX3
      Endif
      If [F:BRD]CHAMP3 > 0
         Call ECR_TRACE("",GTRC_PARAM,space$(35)+left$(mess([F:BRD]CHAMP3,3129,1)+space$(32),32),0,1) From TRACEABX3
      Endif
   Endif
When Default
Endcase

Return
#################
Subprog EXPLOITE_CODE_COMPTABLE (PACCCOD)
Value Char PACCCOD
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
Local Integer I, PLIGNE


 Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, PACCCOD, GGACIMMO, GIASIMMO,
&                                LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
 If ( LGACACN = 0 and LIASACN  = 0 )
     # Code comptable invalide
     [F:TMP2]FLGERR  = G_OUI
     [F:TMP2]MSGERR     =  mess(39,GML_MSGFAS,1)
 Endif
 If ( LGACACN = 0 )
     # Le compte d'immobilisation PCG est invalide pour le code comptable <Code comptable>
     [F:TMP2]FLGERR  = G_OUI
     [F:TMP2]MSGERR    =  mess(516,GML_MSGFAS,1)-PACCCOD
 Endif
 If ( GCNXPROIAS = G_OUI and LIASACN = 0 )
     # Le compte d'immobilisation IFRS est invalide pour le code comptable <Code comptable>
     [F:TMP2]FLGERR  = G_OUI
     [F:TMP2]MSGERR     = mess(517,GML_MSGFAS,1)-PACCCOD
 Endif
 #Fq-67460 Raz [F:TMP2]GACACN, GAC
 Raz [F:TMP2]GACACN
 Raz [F:TMP2]GAC

 If ( LGACACN <> 0 )
   [F:TMP2]GACACN = LGACACN
   [F:TMP2]GAC    = LGAC
 Endif
 #Fq-67460 Raz [F:TMP2]IASACN, IASACC
 Raz [F:TMP2]IASACN
 Raz [F:TMP2]IASACC

 If ( GCNXPROIAS = G_OUI and LIASACN <> 0 )
   [F:TMP2]IASACN = LIASACN
   [F:TMP2]IASACC = LIASACC
 Endif

End
#-------Non utilisé dans la version 1 ------------------------------------------------------------------------
$DECLENCHE_ASSOCIATION
Local Integer PLAN, LALW, LFLGRAT, RERROR, LERROR, LPRA
Local Char    LDPM, LVEH, SOC, FAM, ACCCOD
Local Decimal LDUR, LRAT, LACL
Local Decimal LRAT2

SOC    = [F:DEP]CPY
PLAN   = [F:DEP]DPRPLN
ACCCOD = [F:TMPA]ACCCOD
FAM    = [F:TMPA]ACGGRP
RERROR = 0
LERROR = 0

#Call DETER_VAL_NEW_PLAN_F(SOC, FAM, ACCCOD, PLAN, LDPM, LDUR, LRAT, LRAT2, LALW, LVEH, RERROR) From TRTASSO
Call DETER_VAL_NEW_PLAN_F(SOC, FAM, ACCCOD, PLAN, LDPM, LDUR, LRAT, LRAT2, LALW, LVEH, LPRA, LACL, RERROR) From TRTASSO

If RERROR <>  0
    Return
Endif
If LRAT > 0
  LFLGRAT=G_OUI
Else
 LFLGRAT=G_NON
Endif


If LDPM <> ""  :      [F:DEPN]DPM       = LDPM      :    Endif
If LDUR > 0    :      [F:DEPN]DPRDUR    = LDUR      :    Endif
If LRAT > 0    :      [F:DEPN]DPRRAT    = LRAT      :    Endif
If LRAT2 > 0   :      [F:DEPN]DPRRAT2   = LRAT2     :    Endif
If LALW > 0    :      [F:DEPN]ALWCOD    = LALW      :    Endif
If LVEH <> ""  :      [F:DEPN]CRBVEHCOD = LVEH      :    Endif


#Call CONTROLE_METHODE ([F:DEPN]DPM, [F:DEPN]DPRPLN, [F:DEPN]CPY, 0, LFLGRAT, [F:DEPN]DPRRAT,  [F:DEPN]DPRDUR, 1, 1, [F:DEPN]CRBVEHCOD, [F:DEPN]ALWCOD, LERROR) From TRTFAS
#If ( LERROR )  :  LOK = G_NON : Return : Endif


Return
