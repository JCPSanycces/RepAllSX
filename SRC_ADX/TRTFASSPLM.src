$SEL_TABKEY

  # SEL_TABCOE : liste des tables de référence dans la table RVACOEH
  Local Char CODFIC    : CODFIC = "BRDKEY"

  OBJET = "BRD"
    CRITERE = ' CPY=[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)'
  Default File [BRD]
  Affzo [M:SPLM]
