#=====================================================================
$TERMINE                 # (Massif interactif et batch)

Gosub ACTION From =TRTMODACT

#==> Suppression des globales nécessaires à la fonction
If dim(GCONTROLE)          >0        : Kill GCONTROLE   : Endif
If dim(GZMAJ1)             >0        : Kill GZMAJ1      : Endif
If dim(GZMAJ2)             >0        : Kill GZMAJ2      : Endif
If dim(GZMAJ3)             >0        : Kill GZMAJ3      : Endif
If dim(G_INCR)             >0        : Kill G_INCR      : Endif
If dim(G_TRF_PCG)          >0        : Kill G_TRF_PCG   : Endif
If dim(G_TRF_IAS)          >0        : Kill G_TRF_IAS   : Endif
If dim(GLOK)               >0        : Kill GLOK        : Endif


Return
#=====================================================================
$SORTIE                   # (Massif interactif et batch)

 Gosub ACTION From =TRTMODACT

Return
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
#
######################################################################

$ACTMET
 Case ACTMET

  When "AM_FLGCPY"           :   Gosub AM_FLGCPY           # M - pour pouvoir prendre la main en cas de changement de société
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à  l'action métier
  When "SET_TRACE_NAME"     :   Gosub SET_TRACE_NAME       # M  - Alimentation de TRACE_NAME : titre de la trace

# Locker
  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à  sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à  l'enr en ligne de la population

# Charger
  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp
  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Applique_dirt Mise à  jour directe (massif uniquement)
  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à  jour directe des tables de données avec les paramètres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fermeture

# reporter
  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM  - Fermeture

# Fin traitement
  When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       # UM - Traitement de fin unitaire ou de MAJ indirecte
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Traitement de fin de MAJ directe

  When Default

 Endcase

Return
#=====================================================================
# Massif : pour prendre la main et remettre le mask à blanc dans le cas
# d'un changement de société
$AM_FLGCPY

Raz [M:SPLM]
Affzo [M:SPLM]

Return
#=====================================================================
# Massif : Alimentation / modification de la variable TRACE_NAME
$SET_TRACE_NAME

# TRACE_NAME="Eclatement massif"
# Eclatement  :  Traitement Massif
TRACE_NAME= mess(547,403,1)     #FQ-54343

Return
#=====================================================================
# Unitaire / massif : Critère de sélection particulier à  l'action métier
$SET_CRITACT

# CRITACT contient les critères de sélection suppplémentaires à  appliquer à  la population à  sélectionner
## Les biens modèles ou ceux ayant fait l'objet d'une sortie "réelle" sont exclus de la sélection
# les biens classés pour vente
# les biens qui sont composants sont exclus de la sélection FQ67615

# Issue 112875 - 2016-01-11 by CBO : exclude GVML_TDCBAIL and GVML_TDCONCE
# Use of num$ for having a shorter string (pb of length)

#CRITACT  = "( OWNTYP<>GVML_TDMODEL &((ISSDAT=[0/0/0])  or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI))"
#CRITACT += "& SALCLSDAT = [0/0/0]" : # FQ95754_3
#CRITACT += "& (CMPSTA =GVML_SBAUTON or CMPSTA=GVML_SBLVA or CMPSTA =GVML_SBPRINC ))"

CRITACT  = "(("
CRITACT += "OWNTYP<>" + num$(GVML_TDMODEL)
CRITACT -= "& OWNTYP<>" + num$(GVML_TDCBAIL)
CRITACT -= "& OWNTYP<>" + num$(GVML_TDCONCE)
CRITACT += ")"
CRITACT += "& (ISSDAT=[0/0/0]  or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI))"
CRITACT += "& SALCLSDAT = [0/0/0]"
CRITACT += "& ("
CRITACT += "CMPSTA=" + num$(GVML_SBAUTON)
CRITACT += "| CMPSTA=" + num$(GVML_SBLVA)
CRITACT += "| CMPSTA=" + num$(GVML_SBPRINC)
CRITACT += "))"
# End Issue 112875
Return
#=====================================================================
# Unitaire et massif : Sert à  ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK

  Gosub OUVRE_TABLES

Return
#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

Local Integer I_VAL
I_VAL=0

Read [BRD]BRD1=[F:MAS1]CPY;[M:SPLM]BRDREF
If fstat : Return : Endif
Case  [F:BRD]DSPKEY
  When  GVML_CLEFAM
     I_VAL=find ([F:MAS1]ACGGRP, [F:BRD]VALKEY(0..[F:BRD]NBVAL-1))
     If I_VAL=0
         GOK  = 0
         Return
     Endif
  When  GVML_CLECCO
     I_VAL=find ([F:MAS1]ACCCOD, [F:BRD]VALKEY(0..[F:BRD]NBVAL-1))
     If I_VAL=0
         GOK  = 0
         Return
     Endif
  When  GVML_CLEGAC
     I_VAL=find ([F:MAS1]GAC, [F:BRD]VALKEY(0..[F:BRD]NBVAL-1))
     If I_VAL=0
         GOK  = 0
         Return
     Endif
  When GVML_CLEIASC
     I_VAL=find ([F:MAS1]IASACC, [F:BRD]VALKEY(0..[F:BRD]NBVAL-1))
     If I_VAL=0 :
         GOK  = 0
         Return
     Endif
  When Default
Endcase

Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à  l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE

Return
#=====================================================================
# Unitaire / massif : Sert à  ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1

Gosub OUVRE_TABLES

Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1

Local  Date    RCNXDAT(1..5)
Local  Integer CRET

# Alimentation des tables temporaires
#**************************
Raz [F:TMP1]
Raz [F:TMPC]    #FQ-54343

[F:TMP1]FLGERR = G_NON
[F:TMP1]FLGMOD = G_OUI
[F:TMP1]MSGERR    = ""
#-----------------------------------------------------------------------------------------------------
# Si un bien "Principal" possède au moins un composant : demande de confirmation de continuation
#------------------------------------------------------------------------------------------------------
If [F:MAS1]CMPSTA = GVML_SBPRINC
   If !clalev([F:FAS2]) : Local File FXDASSETS [FAS2] : Endif
   Look [FAS2]FAS5=[F:MAS1]AASREF
   If (fstat = 0)
      If (GLOK <> G_OUI)
          #*545 : "Un bien principal possède déjà un ou plusieurs composants, souhaitez-vous poursuivre ce traitement ?"
          OK = 1    :   Call OUINON(mess(545,GML_MSGFAS,1),OK) From GESECRAN
          RMES="abandon du traitement"
          If OK=1  :  GOK=0       : Return
          Else     :  GLOK=G_OUI  : Endif
      Endif
      # "Bien principal avec composant"
      [F:TMP1]MSGERR    = mess(555,GML_MSGFAS,1)
   Endif
Endif
#-----------------------------------------------------------------------------------------------------
# Si un bien est sorti dans un exercice antérieur, il n'est pas sélectionné
#------------------------------------------------------------------------------------------------------
If [F:MAS1]ISSDAT <> [0/0/0] &  EXTISSFLG = G_NON
# Issue 109496
#  Call GET_CNX_DAT([F:MAS1]CPY,G300CPFI,RCNXDAT,CRET) From GLOBIENS
#  If [F:MAS1]ISSDAT < RCNXDAT(1)
  If [F:MAS1]ISSDAT < GT_CNXDAT(G300CPFI, 1)
# End Issue 109496
     GOK=0 : Return
  Endif
Endif
#---------------------------
[F:TMP1]        = [F:MAS1]
# Chargement table temporaire TMPMASFAS [F:TMP1] avec infos du bien comptable [F:MAS1]
[F:TMP1]TRTNUM     = NUMACT
[F:TMP1]OBJREF     = [F:MAS1]AASREF
[F:TMP1]OBJREFO    = [F:MAS1]AASREF
[F:TMP1]AASIND     = "A"
Write [TMP1]
If (fstat) Then
 Case fstat
   When 1
     # Erreur technique - Entrée sortie.
     RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
     GOK=-1
   When 3
     # Erreur technique - Tentative d'écriture en double
     RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
     GOK=0
   When Default
 Endcase
 Return
Else
   NBTMP+=1
Endif

#FQ-54343
   [F:TMPC]        = [F:MAS1]
   # Chargement table temporaire TMPMASFA2 [F:TMPC] avec infos complémentaires du bien comptable [F:MAS1]
   [F:TMPC]TRTNUM     = NUMACT
   [F:TMPC]OBJREF     = [F:MAS1]AASREF
   [F:TMPC]OBJREFO    = [F:MAS1]AASREF
   [F:TMPC]AASIND     = "A"
   Write [TMPC]
   If (fstat) Then
    Case fstat
      When 1
        # Erreur technique - Entrée sortie.
        RMES=mess(104,403,1)-"TMPMASFA2"-mess(105,403,1)-"05"-mess(106,403,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
        GOK=-1
      When 3
        # Erreur technique - Tentative d'écriture en double
        RMES=mess(129,403,1)-num$(NUMACT)+"/"+[F:TMPC]OBJREF
        GOK=0
      When Default
    Endcase
    Return
   Endif
 #FQ-54343


Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1

# Ouverture de tables liées à  explorer ou à  mettre à  jour  par l'action massive
If !(clalev([F:MAS1]))   : Local File FXDASSETS   [MAS1]   : Endif

 #=> Pose du filtre sur la table maître pour sqlserver
 # obligé de repositionner le filtre pour ne sélectionner que les biens d'origine dans la boucle "Applique"
 # et que sous sqlserver on ne se retrouve pas à essayer de lire dans FIXDASSETS des biens qui n'existent
 # que dans TMPMASFAS
 Filter [TMP1] Where (TRTNUM=NUMACT) and AASIND="A"

Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

Local Integer LOK
Local Integer LCDRET
Local Char    LMESSAGE
Local Char    WSAASREF, WAASREFN
Local Integer WNUM
Local Char    WVALKEY

If dim(RMESS) <= 0 # Issue 109496B)
  Global Char RMESS(250)
Endif

If ( ACTTYPGES = GTAMMAS and ACTSTATUS = 8 ) :   Return : Endif

If !(clalev([F:TMP2]))   : Local File TMPMASFAS    [TMP2]   : Endif  # table temporaire pour nouveaux biens
If !(clalev([F:TMP3]))  : Local File TMPMASFA2    [TMP3]  : Endif  #FQ-54343 table temporaire bis pour nouveaux biens


If [M:SPLM]BRDREF <> ""
   If dim(ACTMODIF)>0 & ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
Endif

LOK = G_OUI
RMES           = ""

[F:TMP1]FLGMOD = G_OUI
#--------
If (LOK = G_OUI)
    # Lecture du bien dans MAS1
    Read [MAS1]FAS0=[F:TMP1]OBJREF
    WSAASREF = [F:TMP1]OBJREF
    If (fstat) Then : GOK= 0 : Return : Endif
    [F:TMP1]AASIND     = "A"

    Call CALCUL_ECLATEMENT ( )

    If ( GOK <> 1 )
      # Erreur sur bien
      LOK = G_NON
      RMES            = mess(LERRBCO,GML_MSGFAS,1)
      [F:TMP1]MSGERR  = mess(LERRBCO,GML_MSGFAS,1)
      [F:TMP1]FLGMOD  = G_NON
      NBCPYERR +=1
    Else
      NBCPYMAJ +=1
    Endif
Endif
#--------

Return
#=============================
Subprog CALCUL_ECLATEMENT( )
Local  Integer    WNUM
Local  Decimal    WMRESTE, WMONTANT, NMNT
Local  Char       CHAMP_MAS1
Local  Char       CHAMP_TMP2, CHAMP_TMP3 #FQ-54343
Local  Char       PCLASSEO        # Classe origine
Local  Char       PCLASSED        # Classe destination
Local  Char       PCLASSEC        ##FQ-54343 Classe origine
Local  Char       PCLASSEC2       ##FQ-54343 Classe destination
Local  Char       RACCCOD
Local  Integer    I, J, K
Local  Char       WNOMVAR
Local  Decimal    WCUMPRC
#Fq-67460 Local Decimal    WRESTPRC
Global Decimal    WRESTPRC
Local  Integer    RFLGASS, RUPDFLG, RFRCFLG
Global Integer    GFLGASS

WNUM     = 1
WCUMPRC  = 0
WMRESTE  = 0
WMONTANT = 0

Raz  [F:TMP2]
Raz  [F:TMP3] #FQ-54343
# FQ99648 Ajout point d'entrée pour ajout de clé de répartition autre que std
# + test avec SREQUETE dans le If dessous
Local Char        SREQUETE(250)
SREQUETE = "1=2"
GPOINT="LECT_BRDKEY" : Gosub ENTREE From EXEFNC

Read [BRD]BRD0=[M:SPLM]BRDREF
For I = 0 To [F:BRD]NBVAL-1
   If [F:BRD]DSPKEY=GVML_CLEFAM  and  [F:BRD]VALKEY(I) = [F:MAS1]ACGGRP or
&     [F:BRD]DSPKEY=GVML_CLECCO  and  [F:BRD]VALKEY(I) = [F:MAS1]ACCCOD or
&     [F:BRD]DSPKEY=GVML_CLEGAC  and  [F:BRD]VALKEY(I) = [F:MAS1]GAC    or
&     [F:BRD]DSPKEY=GVML_CLEIASC and  [F:BRD]VALKEY(I) = [F:MAS1]IASACC or
&     evalue (SREQUETE)

      Raz  [F:TMP2]
      [F:TMP2]           = [F:MAS1]
      [F:TMP2]FLGERR     = G_NON
      [F:TMP2]FLGMOD     = G_OUI
      [F:TMP2]MSGERR     = ""
      [F:TMP2]TRTNUM     = NUMACT
      [F:TMP2]OBJREFO    = [F:MAS1]AASREF
      #<FQ-54343
      Raz  [F:TMP3]
      [F:TMP3]          = [F:MAS1]
      [F:TMP3]FLGERR    = G_NON
      [F:TMP3]FLGMOD    = G_OUI
      [F:TMP3]MSGERR    = ""
      [F:TMP3]TRTNUM    = NUMACT
      [F:TMP3]OBJREFO   = [F:MAS1]AASREF
      #FQ-54343>
      Repeat
         WAASREFN = sum(num$([F:MAS1]AASREF),num$("-"),num$(WNUM))
         Read [FAS]FAS0=WAASREFN
         WNUM+=1
       Until fstat = 5
       [F:TMP2] = [F:MAS1]
       [F:TMP3] = [F:MAS1]    #FQ-54343
       [F:TMP2]OBJREFN     = WAASREFN   :   [F:TMP3]OBJREFN     = WAASREFN
       [F:TMP2]OBJREF      = WAASREFN   :   [F:TMP3]OBJREF      = WAASREFN
       [F:TMP2]AASIND      = "N"   :   [F:TMP3]AASIND      = "N"
       #<FQ-54343
          #[F:TMP2]AASDES1     = [F:MAS1]AASDES1
          #[F:TMP2]AASDES2     = [F:MAS1]AASDES2
          #[F:TMP2]ACCCOD      = [F:MAS1]ACCCOD
          #[F:TMP2]ACGGRP      = [F:MAS1]ACGGRP
          #[F:TMP2]USRFLDA1    = [F:MAS1]USRFLDA1
          #[F:TMP2]USRFLDA2    = [F:MAS1]USRFLDA2
          #[F:TMP2]USRFLDA3    = [F:MAS1]USRFLDA3
          #[F:TMP2]USRFLDA4    = [F:MAS1]USRFLDA4
          #[F:TMP2]USRFLDA5    = [F:MAS1]USRFLDA5
          #[F:TMP2]USRFLDA6    = [F:MAS1]USRFLDA6
          #[F:TMP2]USRFLDA7    = [F:MAS1]USRFLDA7
          #[F:TMP2]USRFLDA8    = [F:MAS1]USRFLDA8
          #[F:TMP2]USRFLDA9    = [F:MAS1]USRFLDA9
          #[F:TMP2]USRFLDA10   = [F:MAS1]USRFLDA10
       #FQ-54343>
      #--------------------------------------------
      Case GZMAJ1
         When  GVML_ZMAJDE1    :  [F:TMP2]AASDES1     = [F:BRD]VAL1(I)
         When  GVML_ZMAJDE2    :  [F:TMP2]AASDES2     = [F:BRD]VAL1(I)
         When  GVML_ZMAJFAM    :  [F:TMP2]ACGGRP      = [F:BRD]VAL1(I)
         When  GVML_ZMAJCCO    :  [F:TMP2]ACCCOD      = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI2    :  [F:TMP2]USRFLDA2    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI3    :  [F:TMP2]USRFLDA3    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI4    :  [F:TMP2]USRFLDA4    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI5    :  [F:TMP2]USRFLDA5    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI6    :  [F:TMP2]USRFLDA6    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI7    :  [F:TMP2]USRFLDA7    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI8    :  [F:TMP2]USRFLDA8    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLI9    :  [F:TMP2]USRFLDA9    = [F:BRD]VAL1(I)
         When  GVML_ZMAJLID    :  [F:TMP2]USRFLDA10   = [F:BRD]VAL1(I)
       Endcase

      Case GZMAJ2
         When  GVML_ZMAJDE1    :  [F:TMP2]AASDES1     = [F:BRD]VAL2(I)
         When  GVML_ZMAJDE2    :  [F:TMP2]AASDES2     = [F:BRD]VAL2(I)
         When  GVML_ZMAJFAM    :  [F:TMP2]ACGGRP      = [F:BRD]VAL2(I)
         When  GVML_ZMAJCCO    :  [F:TMP2]ACCCOD      = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI2    :  [F:TMP2]USRFLDA2    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI3    :  [F:TMP2]USRFLDA3    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI4    :  [F:TMP2]USRFLDA4    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI5    :  [F:TMP2]USRFLDA5    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI6    :  [F:TMP2]USRFLDA6    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI7    :  [F:TMP2]USRFLDA7    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI8    :  [F:TMP2]USRFLDA8    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLI9    :  [F:TMP2]USRFLDA9    = [F:BRD]VAL2(I)
         When  GVML_ZMAJLID    :  [F:TMP2]USRFLDA10   = [F:BRD]VAL2(I)
       Endcase

      Case GZMAJ3
         When  GVML_ZMAJDE1    :  [F:TMP2]AASDES1     = [F:BRD]VAL3(I)
         When  GVML_ZMAJDE2    :  [F:TMP2]AASDES2     = [F:BRD]VAL3(I)
         When  GVML_ZMAJFAM    :  [F:TMP2]ACGGRP      = [F:BRD]VAL3(I)
         When  GVML_ZMAJCCO    :  [F:TMP2]ACCCOD      = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI1    :  [F:TMP2]USRFLDA1    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI2    :  [F:TMP2]USRFLDA2    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI3    :  [F:TMP2]USRFLDA3    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI4    :  [F:TMP2]USRFLDA4    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI5    :  [F:TMP2]USRFLDA5    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI6    :  [F:TMP2]USRFLDA6    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI7    :  [F:TMP2]USRFLDA7    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI8    :  [F:TMP2]USRFLDA8    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLI9    :  [F:TMP2]USRFLDA9    = [F:BRD]VAL3(I)
         When  GVML_ZMAJLID    :  [F:TMP2]USRFLDA10   = [F:BRD]VAL3(I)
       Endcase

      If [F:TMP2]ACGGRP <> [F:MAS1]ACGGRP
          Call DETER_ACCCOD_FORCE([F:TMP2]ACGGRP, [F:MAS1]CPY, RACCCOD, RFRCFLG) From TRTASSO
      Endif

      If (RFRCFLG=G_OUI)  &   (RACCCOD <> "")    &  (RACCCOD <> [F:TMP2]ACCCOD)
         [F:TMP2]ACCCOD = RACCCOD
      Endif

      # Récupération  Compte et Nature PCG/IAS à partir du code comptable
      Call EXPLOITE_CODE_COMPTABLE ([F:TMP2]ACCCOD)
      If [F:TMP2]GAC <> [F:MAS1]GAC   or       [F:TMP2]IASACC <> [F:MAS1]IASACC
         [F:TMP2]MSGERR     =  "Compte PCG/IFRS  modifiés "
         [F:TMP2]FLGERR     =  G_NON
         [F:TMP3]MSGERR   =   [F:TMP2]MSGERR
         [F:TMP3]FLGERR   =   [F:TMP2]FLGERR
      Endif
      J=0
      PCLASSEO     =      "[F:MAS1]"
      PCLASSED     =      "[F:TMP2]"
      PCLASSEA     =      "[F:TMP1]"
      PCLASSEC2    =      "[F:TMP3]"   #FQ-54343
      PCLASSEC     =      "[F:TMPC]"    #FQ-543432

# Issue 109496 change [ATZ] by an array
#      Filter [ATZ] Where (CODFIC="FXDASSETS" & CODTYP="MD1" )
#      For [ATZ]
#        WNOMVAR = [F:ATZ]CODZONE
# End Issue 109496
      For WI_COD = 1 To GNB_COD_FAS
        WNOMVAR = GTCOD_FAS(WI_COD)

        CHAMP_MAS1   =      PCLASSEO+WNOMVAR
        If  evalue("dim([F:TMP2]"+WNOMVAR+") > 0")  #FQ-54343
        CHAMP_TMP1   =      PCLASSEA+WNOMVAR
           CHAMP_TMP2   =      PCLASSED+WNOMVAR
        WMONTANT = (evalue(PCLASSEO+WNOMVAR) * ([F:BRD]BRDPRC(I)/100))
        Call GET_MNT_ARRONDI (WMONTANT ,[F:TMP2]ACGCUR, NMNT) From GLOBIENS
        Assign  (CHAMP_TMP2) With NMNT
        WMRESTE = (evalue(PCLASSEA+WNOMVAR))
        WMRESTE -= NMNT
        Assign  (CHAMP_TMP1) With WMRESTE
        Else
        #FQ-54343
           If  evalue("dim([F:TMP3]"+WNOMVAR+") > 0")
              CHAMP_TMPC    =      PCLASSEC+WNOMVAR
              CHAMP_TMP3   =      PCLASSEC2+WNOMVAR
              WMONTANT = (evalue(PCLASSEO+WNOMVAR) * ([F:BRD]BRDPRC(I)/100))
              Call GET_MNT_ARRONDI (WMONTANT ,[F:TMP2]ACGCUR, NMNT) From GLOBIENS
              Assign  (CHAMP_TMP3) With NMNT
              WMRESTE = (evalue(PCLASSEC+WNOMVAR))
              WMRESTE -= NMNT
              Assign  (CHAMP_TMPC) With WMRESTE
           Endif    #FQ-54343
        Endif
      Next
#      Filter [ATZ]

      [F:TMP2]BRDPRC   = [F:BRD]BRDPRC(I)
      WCUMPRC         += [F:BRD]BRDPRC(I)

      # Point d'entrée avant création du flux période
      # --------------------------------------------- FQ74725
      GPOINT="CREAT_SPL_FA" : Gosub ENTREE From EXEFNC : #CHECK IGNORE_LINE

      If dim (CHAMP_TMP2) > 0
      Write [TMP2]
        If (fstat)
          Case fstat
            When 1
              # Erreur technique - Entrée sortie.
              RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
              GOK=-1
            When 3
              # Erreur technique - Tentative d'écriture en double
              RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP2]OBJREF
              GOK=0
            When Default
          Endcase
          End # Issue 109496B
        Else
          NBTMP+=1
        Endif
      Else
      #FQ-54343
         Write [TMP3]
         If (fstat)
            Case fstat
               When 1
                 # Erreur technique - Entrée sortie.
                 RMES=mess(104,403,1)-"TMPMASFA2"-mess(105,403,1)-"05"-mess(106,403,1)-num$(NUMACT)+"/"+[F:TMPC]OBJREF
                 GOK=-1
               When 3
                 # Erreur technique - Tentative d'écriture en double
                 RMES=mess(129,403,1)-num$(NUMACT)+"/"+[F:TMP3]OBJREF
                 GOK=0
               When Default
             Endcase
             End # Issue 109496B
         Endif  #FQ-54343
   Endif
   Endif
Next I

WRESTPRC=100-WCUMPRC
Call REECRIT_TMP1 ()

End
#=============================
Subprog REECRIT_TMP1()
Local Integer WNUM

[F:TMP1]BRDPRC = WRESTPRC
# FQ67615
If ([F:TMP1]CMPSTA <> GVML_SBLVA) Then
  [F:TMP1]CMPSTA = GVML_SBPRINC
Endif
# Bien à recalculer
[F:TMP1]FLGCLC   = G_OUI
# Issue 109496
#For [CNX] Where CPY=[F:TMP1]CPY
#   #Fq-84472 [F:MAS2]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
#   [F:TMP1]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
#Next
For I = 1 To GWNB_CNX
  [F:TMP1]FLGCNXCLC(GTCNX(I) - 1) = G_OUI
Next I
# End Issue 109496
Rewrite [TMP1]
If (fstat)
  Case fstat
    When 1
      # Erreur technique - Entrée sortie.
      RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
      GOK=-1
    When 3
      # Erreur technique - Tentative d'écriture en double
      RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
      GOK=0
    When Default
  Endcase
  Return
Else
   NBCPYMAJ+=1
   NBCPYTRT+=1
Endif
Rewrite [TMPC]
If (fstat)
  Case fstat
    When 1
      # Erreur technique - Entrée sortie.
      RMES=mess(104,403,1)-"TMPMASFA2"-mess(105,403,1)-"05"-mess(106,403,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
      GOK=-1
    When 3
      # Erreur technique - Tentative d'écriture en double
      RMES=mess(129,403,1)-num$(NUMACT)+"/"+[F:TMPC]OBJREF
      GOK=0
    When Default
  Endcase
  Return
Endif

End
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à  1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à  1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
Return
#=====================================================================
# Massif : Sert à  ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT

Gosub OUVRE_TABLES
# Société courante : rupture société pour émission en-tête trace
Local Char    TRC_CPY   : Raz TRC_CPY

Return
#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à  jour directe
$MAS1_APPL_DIRT
#------------------------------------------
# -----   GOK = 0 : Erreur provoquant l'arrêt de la procédure : DEP et MAS1 subissent un rollback
# -----   MAS1 contient les informations du bien
# -----   DEPW  contient les anciennes valeurs du plan
# -----   DEP   contient les nouvelles valeurs du plan
# -----   La mise à  jour des données dans MAS1 et DEP est à  la charge du programme (rewrite).
# La table DEPREC située à  l'intérieur d'un trbegin subit également un rollback en cas d'erreur

Local Integer LCDRET, LERRBCO, LOK, LCOUR, I_PLN, LERROR
Local Char    LCDINT(10)
Local Char    PARAM(250)
Local Char    LMESSAGE
Local Integer I_ERREUR

# Initialisation des indicateurs
LOK = G_OUI : LERROR = 0
G_INCR = G_OUI : # Erreur à n'incrémenter qu'une seule fois

 #-> A rupture société on émet un en-tête dans la trace et le séparateur de la société précédente
If [F:MAS1]CPY<>TRC_CPY
   If TRC_CPY<>""
      Call SEP_COMPTE_RENDU(TRC_CPY)
   Endif
   Call ET_COMPTE_RENDU([F:MAS1]CPY)
   TRC_CPY=[F:MAS1]CPY
   # Issue 109496
   If GCPY_SPL <> TRC_CPY
     GCPY_SPL = TRC_CPY
     Gosub CHARGE_PLAN_CNX
   Endif
   # End Issue 109496
Endif

 Return
#=====================================================================
# Massif : Fermeture
$CLOS_APPL_DIRT

#==> Suppression des globales nécessaires à la fonction
If dim(GZMAJ1)     >0        : Kill GZMAJ1      : Endif
If dim(GZMAJ2)     >0        : Kill GZMAJ2      : Endif
If dim(GZMAJ3)     >0        : Kill GZMAJ3      : Endif
If dim(G_INCR)     >0        : Kill G_INCR      : Endif
If dim(G_TRF_PCG)  >0        : Kill G_TRF_PCG   : Endif
If dim(G_TRF_IAS)  >0        : Kill G_TRF_IAS   : Endif

Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE

Gosub OUVRE_TABLES
# Société courante : rupture société pour émission en-tête trace
Local Char TRC_CPY   : Raz TRC_CPY

Return
#=====================================================================
$OUVRE_TABLES

# Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
If !(clalev([F:MAS2]))  : Local File FXDASSETS [MAS2]  : Endif  # Pour les Nouveaux biens
If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif  # les contextes
If !(clalev([F:FIS]))   : Local File FISCYEAR  [FIS]   : Endif  # les exercices
If !(clalev([F:DEP]))   : Local File DEPREC    [DEP]   : Endif  # les plans d'amortissement
If !(clalev([F:DEPN]))  : Local File DEPREC    [DEPN]  : Endif  # plans nouveaux biens après éclatement
If !(clalev([F:DEPO]))  : Local File DEPREC    [DEPO]  : Endif  # plans bien origine avant éclatement
If !(clalev([F:DEPA]))  : Local File DEPREC    [DEPA]  : Endif  # plans bien origine après éclatement
# Suppression de la table EVEFAS 31/10/2014
#If !(clalev([F:EFS]))   : Local File EVEFAS    [EFS]   : Endif  # tables des événements
If !(clalev([F:BRD]))   : Local File BRDKEY    [BRD]   : Endif  # table des clés de répartition
If !(clalev([F:ATZ]))   : Local File ATABZON   [ATZ]   : Endif  # table champs d'une table

If clalev([F:TCUB])=0 : Local File TABCUR     [TCUB] : Endif # Issue 109496
Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE

Local Integer LOK, LERROR
Local Char    LCDINT(10)
Local Char    PCLASSEO, PCLASSED
Local Char    CHAMP_DEPO, CHAMP_DEPD
Local Integer I_PLN
Local Integer L_CNX, L_PLNGERE, CDRET
#Fq-67460  Local Date    L_CNXDAT(1..5)
Global Date    L_CNXDAT(1..5)
Local Decimal WMONTANT, NMNT
Local Decimal WRESTE

# Pour chaque bien de la table TMPMASFAS,
# transfert des infos de TMPMASFAS [TMP1] dans la table FXDASSETS [MAS1]
# Pas de rewrite : la mise à  jour est prise en charge par le traitement standard
  GOK=1
#-> A rupture société on émet un en-tête dans la trace

If [F:TMP1]CPY<>TRC_CPY & ACTTYPGES=GTAMMAS
   If TRC_CPY<>""
      Call SEP_COMPTE_RENDU(TRC_CPY)
   Endif
   Call ET_COMPTE_RENDU([F:TMP1]CPY)
   TRC_CPY=[F:TMP1]CPY
   # Issue 109496
   If GCPY_SPL <> TRC_CPY
     GCPY_SPL = TRC_CPY
     Gosub CHARGE_PLAN_CNX
   Endif
   # End Issue 109496
Endif

If ( [F:TMP1]FLGERR <>  G_OUI )
   If  [F:TMP1]AASIND =  "A"
      [F:MAS1] = [F:TMP1]
      [F:MAS1]UPDDAT = date$
      # FQ-81297
      [F:MAS1]FLGSPL = G_OUI
      [F:MAS1]AASREF = [F:TMP1]OBJREF
  Endif
Endif

Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de données annexe
$TPF1_ALIM_TABLE

# Transfert des zones [TPF1] dans l'enregistrement de la table choisie à  mettre à  jour
# rewrite de la table choisie. Utiliser GOK pour interrompre le traitement.
# Pour chaque bien de la table TMPPLNFAS,
# transfert des infos de TMPPLNFAS [TPF1] dans la table DEPREC [DEP]
# Rewrite à  effectuer : la mise à  jour n'est pas prise en charge par le traitement standard

Return
#=====================================================================
$END_ALIM_TABLE
Local Integer LERROR, RERROR

# Issue 109496 : le where est reporté dans le filter et indexe MFS3
#If !(clalev([F:TMPN]))   : Local File TMPMASFAS [TMPN] Where  [TMPN]AASIND="N" : Endif  # Nouveaux biens
If !(clalev([F:TMPN]))   : Local File TMPMASFAS [TMPN]  : Endif  # Nouveaux biens
# End Issue 109496

# Initialisation des indicateurs
LOK    = G_OUI : LERROR = 0
G_INCR = G_OUI : # Erreur à n'incrémenter qu'une seule fois
GOK    = 1

# Issue 109496 : indexe MFS2
#Filter [TMP1] Where (TRTNUM=NUMACT) &  (AASIND ="A") Order By OBJREF Asc
Filter [TMP1] Where (TRTNUM=NUMACT &  AASIND ="A") Order By Key MFS2
# End Issue 109496
For [TMP1]
   If ( [F:TMP1]FLGERR <>  G_OUI )
      Local Char LIGNE(115)
      # Construction de la ligne à émettre dans la trace
      #TRACE1
      LIGNE = string$(115,"-")
      Call ECR_TRACE([F:TMP1]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
      LIGNE =space$(1)
      LIGNE+=left$([F:TMP1]OBJREF+ string$(20,' '), 20)+" ! "
      LIGNE+=left$([F:TMP1]AASDES1+ string$(25,' '), 25)+" "
      LIGNE+=left$([F:TMP1]ACGGRP+ string$(15,' '), 15)+ " "
      LIGNE+=left$([F:TMP1]GAC+ string$(15,' '), 15)+ "  "
      LIGNE+=left$([F:TMP1]IASACC+ string$(15,' '), 15)+ " "
      LIGNE+= format$('N:'+GFMT3,[F:TMP1]ACGETRNOT )
      Call ECR_TRACE([F:TMP1]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
   Endif

# Issue 109496
#   Filter [TMPN] Where ((TRTNUM=NUMACT) &  (OBJREFO=[F:TMP1]OBJREF)) Order By OBJREFO Asc
   Filter [TMPN] Where (TRTNUM=NUMACT & AASIND="N" & OBJREFO=[F:TMP1]OBJREF) Order By Key MFS3
# End Issue 109496
   For[TMPN]
      # Report des informations des nouveaux biens
      [F:MAS2] = [F:TMP1]
      [F:MAS2] = [F:TMPN]
      [F:MAS2]AASREF       = [F:TMPN]OBJREF
      # FQ67615
      If ([F:MAS2]CMPSTA <> GVML_SBLVA) Then
        [F:MAS2]CMPSTA       = GVML_SBCOMPO
      Endif
      [F:MAS2]CMP          = [F:TMPN]OBJREFO
      [F:MAS2]ENAFAS       = G_OUI
      [F:MAS2]AASDES1      = [F:TMPN]AASDES1
      [F:MAS2]AASDES2      = [F:TMPN]AASDES2
      [F:MAS2]ACGGRP       = [F:TMPN]ACGGRP
      [F:MAS2]SET          = [F:TMPN]OBJREF
      [F:MAS2]ACCCOD       = [F:TMPN]ACCCOD
      [F:MAS2]GAC          = [F:TMPN]GAC
      [F:MAS2]AASQTY       = [F:TMPN]AASQTY
      [F:MAS2]IASACC       = [F:TMPN]IASACC
      [F:MAS2]ACGETRNOT    = [F:TMPN]ACGETRNOT
      [F:MAS2]IASETRNOT    = [F:TMPN]IASETRNOT
      [F:MAS2]USRFLDM1     = [F:TMPN]USRFLDM1
      [F:MAS2]USRFLDM2     = [F:TMPN]USRFLDM2
      [F:MAS2]USRFLDM3     = [F:TMPN]USRFLDM3
      [F:MAS2]USRFLDM4     = [F:TMPN]USRFLDM4
      [F:MAS2]USRFLDM5     = [F:TMPN]USRFLDM5
      [F:MAS2]USRFLDM6     = [F:TMPN]USRFLDM6
      [F:MAS2]CREORI       = GVML_COECLAT
      [F:MAS2]CREDAT       = date$
      [F:MAS2]CREUSR      = GUSER
       NBCPYMAJ+=1
      ################################################
      # Fq-84515  Point d'entrée                     #
      # Modifications spécifiques sur                #
      # l'enregistrement MAS2(FAS nouveaux biens)    #
      ################################################
      GPOINT = "SPLM_WRIFAS" : Gosub ENTREE From EXEFNC
      #### Point d'entrée - Fin ######################
      ################################################
      #------------------
      # on n'est pas en simulation
      #------------------
      If ( FLGSIM=G_NON )
         # Bien à recalculer
         [F:MAS2]FLGCLC   = G_OUI
# Issue 109496
#         For [CNX] Where CPY=[F:MAS2]CPY
#            [F:MAS2]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
#         Next
        For I = 1 To GWNB_CNX
          [F:MAS2]FLGCNXCLC(GTCNX(I) - 1) = G_OUI
        Next I
# End Issue 109496
         # FQ-81297
         [F:MAS2]FLGSPL = G_NON
         Write [MAS2]
         If (fstat)
            Case fstat
               When 1
                  # Erreur technique - Entrée sortie.
                  RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
                  GOK=-1
               When 3
                  # Erreur technique - Tentative d'écriture en double
                  RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
                  GOK=0
               When Default
            Endcase
            Break 2
         Endif
      Endif
     #----------------------------------------------------
     # Construction de la ligne à émettre dans la trace
     #TRACE2
       Local Char LIGNE(115)
       LIGNE =space$(3)
       LIGNE+=left$([F:MAS2]AASREF+ string$(19,' '), 19)+"! "
       LIGNE+=left$([F:MAS2]AASDES1+ string$(25,' '), 25)+" "
       LIGNE+=left$([F:MAS2]ACGGRP+ string$(15,' '), 15)+ " "
       LIGNE+=left$([F:MAS2]GAC+ string$(15,' '), 15)+ "  "
       LIGNE+=left$([F:MAS2]IASACC+ string$(15,' '), 15)+ " "
       LIGNE+= format$('N:'+GFMT3,[F:MAS2]ACGETRNOT )
       Call ECR_TRACE([F:TMP1]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    Next
    Filter [TMPN]
 Next
 Filter [TMP1]

If (GOK)

   Gosub ECLATER_PLANS
   If LOK=G_NON
      GERR     = 1
      Call ECR_TRACE_ERREUR([F:TMPN]CPY, [F:TMPN]OBJREF, [F:DEPN]DPRPLN, G_OUI, mess(124,GML_MSGFAS,1)) From TRCPROCOM
      #RMES=mess(124,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMPN]OBJREF+"/"+ num$([F:DEPN]DPRPLN)
      FIN      = 0  :   Return
   Endif

   Call ECLATER_EVENEMENTS(LERROR)
   If LERROR
      GERR     = 1
      GMESSAGE = mess(14,7772,1) : # Echec lors de l'enregistrement de l'éclatement
      FIN      = 0 : Return
   Endif

   Call ECLATER_FLUX(LERROR)
   If LERROR
      GERR     = 1
      GMESSAGE = mess(14,7772,1) : # Echec lors de l'enregistrement de l'éclatement
      FIN      = 0 : Return
   Endif

Endif

Return
#=====================================================================
$ECLATER_PLANS
Local Decimal WMONTANT
Local Decimal WMRESTE
Local Decimal NMNT
Local Char    PCLASSEO, PCLASSEN, PCLASSEA
Local Char    CHAMP_DEPO, CHAMP_DEPN, CHAMP_DEPA
Local Integer I_PLN, L_CNX, L_PLNGERE
Local Integer LCDRET, CDRET, RCRET
#Fq-67460  Local Date    L_CNXDAT(1..5)
Global Date    L_CNXDAT(1..5)
#-------------------------------------
Local Integer  I, J # Issue 109496
Local Integer  WPLAN
Local Char     RDPM
Local Decimal  RDUR
Local Decimal  RRAT
Local Decimal  RRAT2
Local Integer  RALW
Local Char     RVEH
Local Char WCUR(GLONCUR) # Issue 109496
#-------------------------------------

#Infbox "FASSPLM : $ECLATER_PLANS"

If !(clalev([F:DEP]))   : Local File DEPREC    [DEP]   : Endif  # les plans d'amortissement
If !(clalev([F:DEPN]))  : Local File DEPREC    [DEPN]  : Endif  # plans nouveaux biens après éclatement
If !(clalev([F:DEPO]))  : Local File DEPREC    [DEPO]  : Endif  # plans bien origine avant éclatement
If !(clalev([F:DEPA]))  : Local File DEPREC    [DEPA]  : Endif  # plans bien origine après éclatement
If !(clalev([F:DEPW]))  : Local File DEPREC    [DEPW]  : Endif  # plans nouveaux biens pour evt de transfert imputation
If !(clalev([F:TMPN]))  : Local File TMPMASFAS [TMPN]  : Endif  # biens générés par éclatement
If !(clalev([F:TMPA]))  : Local File TMPMASFAS [TMPA]  : Endif  # biens générés
If clalev([F:TCUB])=0   : Local File TABCUR    [TCUB]  : Endif

GOK=1
PCLASSEO     =      "[F:DEPO]"
PCLASSEN     =      "[F:DEPN]"
PCLASSEA     =      "[F:DEPA]"
WPLAN=0

Filter [TMP1] Where (TRTNUM=NUMACT) &  (AASIND ="A") Order By Key MFS2 # Issue 109496
For [TMP1]
   # Sauvegarde des valeurs d'origine du bien
   # nécessaires à  la génération de l'événement changement d'imputation
   G_OWNTYP = [F:MAS1]OWNTYP
   G_ACGGRP = [F:TMP1]ACGGRP
   G_ACCCOD = [F:TMP1]ACCCOD
   G_GACACN = [F:TMP1]GACACN
   G_GAC    = [F:TMP1]GAC
   G_IASACN = [F:TMP1]IASACN
   G_IASACC = [F:TMP1]IASACC
   WMRESTE = 0
   # éclatement des montants des plans d'amortissement
   Filter [DEP] Where AASREF=[F:TMP1]OBJREF Order By DPRPLN
   For [DEP] With Stability
      If [F:DEP]DPRPLN <> WPLAN
         WPLAN = [F:DEP]DPRPLN
         # Issue 109496
         WCUR = func GET_CUR_DU_PLAN(WPLAN)
         If WCUR = ""
           WCUR=[F:MAS1]ACGCUR
         Endif
#         Call GET_CNX_FROM_PLAN ([F:DEP]CPY,WPLAN, L_CNX) From GLOBIENS
#         If L_CNX > 0
#            Read [CNX]CNX0=[F:DEP]CPY;L_CNX
#            If fstat
#               WCUR=[F:MAS1]ACGCUR
#            Else
#               WCUR = [F:CNX]CUR
#            Endif
#         Endif
#         Call GET_CNX_DAT([F:TMP1]CPY,L_CNX,L_CNXDAT,RCRET) From GLOBIENS
         L_CNX = func GET_CNX_DU_PLAN(WPLAN)
         # End Issue 109496
      Endif

      WMRESTE = 0
      [F:DEPO] = [F:DEP]
      [F:DEPN] = [F:DEP]
      [F:DEPA] = [F:DEP]

      # Issue 109496
#      Filter [TMPN] Where (TRTNUM=NUMACT) &  (AASIND ="N") &  (OBJREFO =[F:TMP1]OBJREF) Order By OBJREFO Asc
      Filter [TMPN] Where (TRTNUM=NUMACT) &  (AASIND ="N") &  (OBJREFO =[F:TMP1]OBJREF) Order By Key MFS3
      # End Issue 109496
      For [TMPN]
           # Changement d'imputation PCG ?
           If G_GAC  = [F:TMPN]GAC
                G_TRF_PCG = G_NON
           Else
                G_TRF_PCG = G_OUI
           Endif
           # Changement d'imputation IAS ?
           If G_IASACC  = [F:TMPN]IASACC
             G_TRF_IAS = G_NON
           Else
             G_TRF_IAS = G_OUI
           Endif

  # Issue 109496 : change [ATZ] by an array
  #         Filter [ATZ] Where (CODFIC="DEPREC" & CODTYP="MD1")
  #         For [ATZ]
  #            WNOMVAR=[F:ATZ]CODZONE
  # End Issue 109496
           For WI_COD = 1 To GNB_COD_DEP
              WNOMVAR = GTCOD_DEP(WI_COD)
              CHAMP_DEPO   =   PCLASSEO+WNOMVAR
              CHAMP_DEPN   =   PCLASSEN+WNOMVAR
              CHAMP_DEPA   =   PCLASSEA+WNOMVAR
              WMONTANT = (evalue(PCLASSEO+WNOMVAR)* ([F:TMPN]BRDPRC/100))
              Call GET_MNT_ARRONDI(WMONTANT,WCUR,NMNT) From GLOBIENS
              Assign  (CHAMP_DEPN) With NMNT
              WMRESTE = (evalue(PCLASSEA+WNOMVAR))
              WMRESTE -= NMNT
              Assign  (CHAMP_DEPA) With WMRESTE
            Next
  #          Filter [ATZ] # Issue 109496
            ##------------------------------------------------------
            ## Déclenchement association dans un second temps
            ##  Gosub DECLENCHE_ASSOCIATION
            ##------------------------------------------------------
            If (LOK = G_OUI)   & (FLGSIM = G_NON)
               [F:DEPN]AASREF=[F:TMPN]OBJREF
              # Issue 109496
  #            If ([F:DEPN]FIYENDDAT > L_CNXDAT(2)) or ([F:DEPN]FIYENDDAT = L_CNXDAT(2) & [F:DEPN]PERENDDAT = L_CNXDAT(4))
              If ([F:DEPN]FIYENDDAT > GT_CNXDAT(L_CNX, 2)) or
&                ([F:DEPN]FIYENDDAT = GT_CNXDAT(L_CNX, 2) & [F:DEPN]PERENDDAT = GT_CNXDAT(L_CNX, 4))
              # End Issue 109496
                 [F:DEPN]DEPSTA = GVML_SCNOCAL    #  statut = "Non calculé"
              Endif

              # Point d'entrée avant création du DEPREC
              # --------------------------------------- FQ74725
              GPOINT="CREAT_SPL_DP" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE

              [F:DEPW] = [F:DEPN]
              Write [DEPN]
              If (fstat)
                # Issue 109496
                If fstat = 3
                  # Erreur technique - Tentative d'écriture en double
                  RMES = mess(129, GML_MSGFAS, 1) - [F:DEPN]AASREF
                Else
                  # Erreur technique - Entrée sortie.
                  RMES = mess(104, GML_MSGFAS, 1) - "DEPREC" - mess(105, GML_MSGFAS, 1) - "51" - mess(106,GML_MSGFAS,1) - [F:DEPN]AASREF
                Endif
                # End Issue 109496

                GOK=0
                Break 3
              Endif
              #-----------------------------------------------------------------------------------
              # Transfert d'imputation comptable si Famille ou code comptable ou compte différent
              #-----------------------------------------------------------------------------------
               If  ( G_TRF_PCG = G_OUI & [F:DEPN]DPRPLN <> G301IAS ) or
&                    ( G_TRF_IAS = G_OUI & [F:DEPN]DPRPLN =  G301IAS )
                 # Issue 109496
                 If (GT_CNXDAT(L_CNX, 3) <> [0/0/0] & [F:DEPN]PERSTRDAT = GT_CNXDAT(L_CNX, 3)) or
&                      (GT_CNXDAT(L_CNX, 3) =  [0/0/0] & [F:DEPN]FIYSTRDAT = GT_CNXDAT(L_CNX, 1))
                    If  (GT_CNXDAT(L_CNX, 3) <> [0/0/0])
                       GDATREF = GT_CNXDAT(L_CNX, 3)
                    Else
                       GDATREF = GT_CNXDAT(L_CNX, 1)
                    Endif
                   # End Issue 109496
                   Gosub GENERER_EVT_TRFC
                 Endif
               Endif
               #-------------------------------------
            Endif
        #---------
      Next
      Filter[TMPN]
      If (LOK = G_OUI)   & (FLGSIM = G_NON)
        Call REECRIT_DEP
      Endif
   Next
   Filter [DEP]
Next
Filter [TMP1]

Return
#=============================
Subprog REECRIT_DEP( )
Local Integer WNUM

If ([F:DEPA]FIYENDDAT > L_CNXDAT(2)) or ([F:DEPA]FIYENDDAT = L_CNXDAT(2) & [F:DEPA]PERENDDAT = L_CNXDAT(4))
   [F:DEPA]DEPSTA = GVML_SCNOCAL    #  statut = "Non calculé"
Endif
[F:DEP] = [F:DEPA]
 Rewrite [DEP]
   If (fstat)
     Case fstat
       When 1
         # Erreur technique - Entrée sortie.
         RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEPA]AASREF
         GOK=-1
       When 3
         # Erreur technique - Tentative d'écriture en double
         RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF
         GOK=0 : End
       When Default
     Endcase
     Return
   Endif

End
#=============================
$GENERER_EVT_TRFC

Local Integer LCDRET
Local Char    LCDINT
Local Integer S_OWNTYP, S_GACACN, S_IASACN
Local Char    S_ACGGRP, S_ACCCOD, S_GAC, S_IASACC

# on sauvegarde  MAS1
S_OWNTYP =  [F:MAS1]OWNTYP
S_ACGGRP =  [F:MAS1]ACGGRP
S_ACCCOD =  [F:MAS1]ACCCOD
S_GACACN =  [F:MAS1]GACACN
S_GAC    =  [F:MAS1]GAC
S_IASACN =  [F:MAS1]IASACN
S_IASACC =  [F:MAS1]IASACC

If !clalev([M:FASC]) : Local Mask FASTRFC[FASC] : Endif
# pour alimenter correctement les nouvelles valeurs des biens dans l'évenement FASTRFC
# il faut renseigner les champs dans {F:MAS1]
[F:MAS1]OWNTYP   =   [F:TMPN]OWNTYP
[F:MAS1]ACGGRP   =   [F:TMPN]ACGGRP
[F:MAS1]ACCCOD   =   [F:TMPN]ACCCOD
[F:MAS1]GACACN   =   [F:TMPN]GACACN
[F:MAS1]GAC      =   [F:TMPN]GAC
[F:MAS1]IASACN   =   [F:TMPN]IASACN
[F:MAS1]IASACC   =   [F:TMPN]IASACC
[M:FASC]MVTTYP   =   "CPST"
G_PERENDDPE      =   [F:DEPW]PERENDDPE
G_PERDPRCUM2     =   [F:DEPW]PERCLOCUM
G_PERENDDPE2     =   [F:DEPW]PERENDDPE
G_DERSLDEX       =   0
G_DERSLDPC       =   0
G_DERSLDPS       =   0


#LCDINT= "FASTRFC"+num$([F:DEPN]DPRPLN)
#LCDINT= "FASCHGIMP"+num$([F:DEPN]DPRPLN)# FQ112873
LCDINT = "FASCHGIC" + num$([F:DEPN]DPRPLN)  # FQ112873
EVTPRINC = G_OUI # FQ112873
Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:TMPN]OBJREF,0,LCDINT,GDATREF,[0/0/0],LCDRET) From GENEVE
If (LCDRET > 20 ) Then
  RMES= mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
  GOK = 0
Endif

# on ré-alimente MAS1 avec les bonnes valeurs du bien d'origine
[F:MAS1]OWNTYP   =   S_OWNTYP
[F:MAS1]ACGGRP   =   S_ACGGRP
[F:MAS1]ACCCOD   =   S_ACCCOD
[F:MAS1]GACACN   =   S_GACACN
[F:MAS1]GAC      =   S_GAC
[F:MAS1]IASACN   =   S_IASACN
[F:MAS1]IASACC   =   S_IASACC

Return
########################################
Subprog ECLATER_EVENEMENTS (LERROR)
Variable Integer LERROR

Local Integer I
Local Char    PCLASSEO, PCLASSEN, PCLASSEM, WNOMVAR(30)
Local Char    CHAMP_EFSO, CHAMP_EFSN, CHAMP_EFSM
Local Decimal MNTEVTN
Local Decimal WMONTANT, WMRESTE
Local Char    TAB_NOMZON(10)(40)
Local Integer TAB_ORDZON(40)
Local Integer TAB_STATUS(40)
Local Integer CODRET

Local Integer I_EVT, I_PLN


#If clalev([F:ADI])=0     : Local File ATABDIV     [ADI]   : Endif    # tables diverses # Issue 109496
If clalev([F:TMP1]) = 0  : Local File TMPMASFAS   [TMP1]  : Endif  # Biens d'origine
If clalev([F:TMPN]) = 0  : Local File TMPMASFAS   [TMPN]  : Endif  # Nouveaux biens

# Issue 109496
#For [ADI] Where NUMTAB = GTD_EVENT & N2 = GVML_OMBIEN
   #Fq-64994 If [F:ADI]CODE<>"FASCNL" | [F:ADI]CODE<>"LOFCNL" | [F:ADI]CODE<>"GRTCNL" | [F:ADI]CODE<>"LEACNL"
   # FQ109496 erreur booleenne : <> au lieu de =
#   If [F:ADI]CODE = "FASCNL" or [F:ADI]CODE = "LOFCNL" or [F:ADI]CODE = "GRTCNL" or
#&     [F:ADI]CODE = "LEACNL" or [F:ADI]CODE = "FASCCNCNL"
#    Goto $NEXT_EVT
#   Endif
#   # FQ59900
#   If !find([F:ADI]A2,GTABEVT)
#    Goto $NEXT_EVT
#   Endif

  For I_EVT = 1 To GNB_EVT
    If clalev([F:EFSA]) : Close Local File [F:EFSA] : Endif
    If clalev([F:EFSO]) : Close Local File [F:EFSO] : Endif
    If clalev([F:EFSN]) : Close Local File [F:EFSN] : Endif
    If clalev([F:EFSM]) : Close Local File [F:EFSM] : Endif

#   Local File =[F:ADI]A2 [EFSA]
#   Local File =[F:ADI]A2 [EFSO]
#   Local File =[F:ADI]A2 [EFSN]
#   Local File =[F:ADI]A2 [EFSM]

    Local File =GTAB_NOMTAB_EVT(I_EVT) [EFSA]
    Local File =GTAB_NOMTAB_EVT(I_EVT) [EFSO]
    Local File =GTAB_NOMTAB_EVT(I_EVT) [EFSN]
    Local File =GTAB_NOMTAB_EVT(I_EVT) [EFSM]

    Filter [TMP1] Where (TRTNUM=NUMACT) &  (AASIND ="A")  Order By Key MFS2
# End Issue 109496
    For [TMP1]
      # Lecture des événements existants sur le bien d'origine
      Filter[EFSA] Where (REF=[F:TMP1]OBJREF)
      For [EFSA]EVE0  With Stability
        Raz [F:EFSO]
        Raz [F:EFSN]
        Raz [F:EFSM]
        [F:EFSO] = [F:EFSA]
        [F:EFSN] = [F:EFSA]
        [F:EFSM] = [F:EFSA]
        PCLASSEO     =      "[F:EFSO]"
        PCLASSEN     =      "[F:EFSN]"
        PCLASSEM     =      "[F:EFSM]"

        # Issue 109496
        Filter [TMPN] Where (TRTNUM=NUMACT) &  (AASIND ="N") &  (OBJREFO =[F:TMP1]OBJREF) Order By Key MFS3
        For [TMPN]
#         Call GET_PRORATA_STATUS(2,[F:TMP1]CPY,[F:ADI]CODE,[F:EFSO]DPRPLN,TAB_NOMZON,TAB_ORDZON,TAB_STATUS,CODRET)
#&             From GENEVE
         #--------------------------------
          For I=1 To 99
#           If TAB_NOMZON(I) <> ""
            If GTAB_NOMZON(I_EVT, [F:EFSO]DPRPLN, I) = ""
              Break
            Endif
#           WNOMVAR = TAB_NOMZON(I)
            WNOMVAR = GTAB_NOMZON(I_EVT, [F:EFSO]DPRPLN, I)
            # End Issue 109496

            CHAMP_EFSO   =   PCLASSEO+WNOMVAR
            CHAMP_EFSN   =   PCLASSEN+WNOMVAR
            CHAMP_EFSM   =   PCLASSEM+WNOMVAR

            WMONTANT = (evalue(PCLASSEO+WNOMVAR)* ([F:TMPN]BRDPRC/100))
            Call GET_MNT_ARRONDI (WMONTANT ,[F:EFSO]CUR, MNTEVTN) From GLOBIENS
            Assign  (CHAMP_EFSN) With MNTEVTN
            WMRESTE = (evalue(PCLASSEM+WNOMVAR))
            WMRESTE -= MNTEVTN
            Assign  (CHAMP_EFSM) With WMRESTE
          Next I

          [F:EFSN]REF = [F:TMPN]OBJREF
          [F:EFSN]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EFSN]CREDAT, [F:EFSN]CRETIM)

          # Ecriture nouveaux événements
          If (FLGSIM = G_NON)
            Write [F:EFSN]
            If fstat
              RCOD = 90
              Infbox "Error creating event /"-num$(RERROR)-"\"-[F:EFSA]CPY-"-"-[F:EFSA]EVT-"-"-num$([F:EFSA]PLN)-"-"-[F:EFSA]REF
              GOK    = 0
              # Issue 109496
              If fstat = 3
                # Erreur technique - Tentative d'écriture en double
                RMES = mess(129, GML_MSGFAS, 1) - [F:EFSN]REF # - [F:DEPN]AASREF
              Else
                # Erreur technique - Entrée sortie.
                RMES = mess(104, GML_MSGFAS, 1) - "EVT" - mess(105, GML_MSGFAS, 1) - "52"# - mess(106,GML_MSGFAS,1) - [F:DEPN]AASREF
              Endif
              # End Issue 109496

            Endif
          Endif
        Next
        Filter [TMPN]

        # ré-écriture événements origine
        If (FLGSIM = G_NON)
          [F:EFSA] = [F:EFSM]
          Rewrite[F:EFSA]
          If fstat
            RERROR = fstat
            Infbox "Error updating event /"-num$(RERROR)-"\"-[F:EFSA]CPY-"-"-GTAB_NOMEVT(I_EVT)-"-"-num$([F:EFSA]PLN)-"-"-[F:EFSA]REF
            GOK  = 0
          Endif
        Endif

        If GOK=0
          Break 3
        Endif
      Next
      Filter[EFSA]
    Next
    Filter[TMP1]
#    $NEXT_EVT
 Next

End
########################################
Subprog ECLATER_FLUX (LERROR)
Variable Integer LERROR
Local Integer    I_PLN, K, J
Local Integer    RCONTX      #*V5 , L_PLNGERE
Local Date       RCNXDAT(1..5)
Local Integer    RCRET
Local Decimal    MNTFLUN
Local Decimal    WMONTANT, WMRESTE
Local Char       WNOMVAR

If clalev([F:FLU])   = 0  : Local File FXDLIFL      [FLU]   : Endif : # Suivi des flux
If clalev([F:FLUO])  = 0  : Local File FXDLIFL      [FLUO]  : Endif : # Suivi des flux origine
If clalev([F:FLUM])  = 0  : Local File FXDLIFL      [FLUM]  : Endif : # Suivi des flux modifiés
If clalev([F:FLUN])  = 0  : Local File FXDLIFL      [FLUN]  : Endif : # Création flux s/nouveaux biens
If clalev([F:TMP1])  = 0  : Local File TMPMASFAS    [TMP1]  : Endif   # Biens d'origine
If clalev([F:TMPN])  = 0  : Local File TMPMASFAS    [TMPN]  : Endif   # Nouveaux biens

# Issue 109496
Filter [TMP1] Where (TRTNUM=NUMACT) &  (AASIND ="A") Order By Key MFS2
For [TMP1]
   For I_PLN =1 To G301MAX-1
#      Call GET_CNX_FROM_PLAN ([F:TMP1]CPY,I_PLN, RCONTX) From GLOBIENS
      RCONTX = func GET_CNX_DU_PLAN(I_PLN)

      If RCONTX > 0
# End Issue 109496
#         Read [F:CNX]CNX0=[F:TMP1]CPY;RCONTX# FQ109496
         #*V5 Call IS_PLAN_GERE (I_PLN, L_PLNGERE) From GLOCALC3
         #*V5 If L_PLNGERE=G_OUI
         Filter[FLU] Where (AASREF=[F:TMP1]OBJREFO) and DPRPLN=I_PLN
         For [FLU]FLU0  With Stability
            Raz [F:FLUO]
            Raz [F:FLUN]
            Raz [F:FLUM]
            [F:FLUO] = [F:FLU]
            [F:FLUN] = [F:FLU]
            [F:FLUM] = [F:FLU]
            # éclatement des montants des flux
            J=0
            PCLASSEO     =      "[F:FLUO]"
            PCLASSED     =      "[F:FLUN]"
            PCLASSEM     =      "[F:FLUM]"

# Issue 109496 : CHANGE [ATZ] By AN ARRAY ET MFS3
            Filter [TMPN] Where (TRTNUM=NUMACT) &  (AASIND ="N") &  (OBJREFO =[F:TMP1]OBJREF) Order By Key MFS3
            For [TMPN]
#               Filter [ATZ] Where (CODFIC="FXDLIFL" & CODTYP="MD1")
#               For [ATZ]
#                  WNOMVAR = [F:ATZ]CODZONE
               For WI_COD = 1 To GNB_COD_FLU
                  WNOMVAR = GTCOD_FLU(WI_COD)
# End Issue 109496
                  #Infbox "Wnomvar="-num$(WNOMVAR)
                  CHAMP_FLUO   =      PCLASSEO+WNOMVAR
                  CHAMP_FLUN   =      PCLASSED+WNOMVAR
                  CHAMP_FLUM   =      PCLASSEM+WNOMVAR
                  WMONTANT = (evalue(PCLASSEO+WNOMVAR)* ([F:TMPN]BRDPRC/100))
                  # FQ109496 GT_CUR(RCONTX) remplace [F:CNX]CUR
                  Call GET_MNT_ARRONDI (WMONTANT , GT_CUR(RCONTX), MNTFLUN) From GLOBIENS
                  Assign  (CHAMP_FLUN) With MNTFLUN
                  WMRESTE = evalue(PCLASSEM+WNOMVAR)
                  WMRESTE -= MNTFLUN
                  Assign  (CHAMP_FLUM) With WMRESTE
               Next
#               Filter [ATZ]
               #----------------------------
               # Ecriture nouveaux flux
               If (FLGSIM = G_NON)
                  [F:FLUN]AASREF=[F:TMPN]OBJREF
                  Write [FLUN]
                  If (fstat)
                     GOK=0
                     # Issue 109496
                     If fstat = 3
                       # Erreur technique - Tentative d'écriture en double
                       RMES = mess(129, GML_MSGFAS, 1) - [F:TMPN]OBJREF
                     Else
                       # Erreur technique - Entrée sortie.
                       RMES = mess(104, GML_MSGFAS, 1) - "FLUX" - mess(105, GML_MSGFAS, 1) - "53" - mess(106,GML_MSGFAS,1) - [F:TMPN]OBJREF
                     Endif
                     # End Issue 109496

                     Break 4
                  Endif
               Endif
            Next
            Filter [TMPN]
            #----------------------------
            # ré-écriture flux origine
            If (FLGSIM = G_NON)
               [F:FLU] = [F:FLUM]
               Rewrite[F:FLU]
               If fstat
                 RERROR = fstat
                 Infbox "Error creating flows /"-num$(RERROR)-"\"-[F:FLUM]CPY-"-"-[F:FLUM]AASREF-"-"-num$([F:FLUM]DPRPLN)
                     # Issue 109496
                     If fstat = 3
                       # Erreur technique - Tentative d'écriture en double
                       RMES = mess(129, GML_MSGFAS, 1) - [F:FLUM]AASREF
                     Else
                       # Erreur technique - Entrée sortie.
                       RMES = mess(104, GML_MSGFAS, 1) - "FLUX" - mess(105, GML_MSGFAS, 1) - "54" - mess(106,GML_MSGFAS,1) - [F:FLUM]AASREF
                     Endif
                     # End Issue 109496

                 GOK  = 0
               Endif
            Endif
            If GOK=0 : Break 3 : Endif
         Next
         Filter [FLU]
      Endif      # RCONTX > 0
   Next I_PLN
Next
Filter [TMP1]

End
#=====================================================================
$END_APPL_DIRT

Return
#=====================================================================
# Massif : Fermeture
$CLOS_ALIM_TABLE

#==> Suppression des globales nécessaires à la fonction
If dim(GZMAJ1)        >0   : Kill GZMAJ1         : Endif
If dim(GZMAJ2)        >0   : Kill GZMAJ2         : Endif
If dim(GZMAJ3)        >0   : Kill GZMAJ3         : Endif
If dim(G_INCR)        >0   : Kill G_INCR         : Endif
If dim(GDATREF)       >0   : Kill GDATREF        : Endif
If dim(G_TRF_PCG)     >0   : Kill G_TRF_PCG      : Endif
If dim(G_TRF_IAS)     >0   : Kill G_TRF_IAS      : Endif
If dim(G_OWNTYP)      >0   : Kill G_OWNTYP       : Endif
If dim(G_GACACN)      >0   : Kill G_GACACN       : Endif
If dim(G_IASACN)      >0   : Kill G_IASACN       : Endif
If dim(G_ACGGRP)      >0   : Kill G_ACGGRP       : Endif
If dim(G_ACCCOD)      >0   : Kill G_ACCCOD       : Endif
If dim(G_GAC)         >0   : Kill G_GAC          : Endif
If dim(G_IASACC)      >0   : Kill G_IASACC       : Endif
If dim(G_PERDPRCUM2)  >0   : Kill G_PERDPRCUM2   : Endif
If dim(G_PERENDDPE2)  >0   : Kill G_PERENDDPE2   : Endif
If dim(G_PERENDDPE)   >0   : Kill G_PERENDDPE    : Endif
If dim(G_DERSLDEX)    >0   : Kill G_DERSLDEX     : Endif
If dim(G_DERSLDPC)    >0   : Kill G_DERSLDPC     : Endif
If dim(G_DERSLDPS)    >0   : Kill G_DERSLDPS     : Endif

Return
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
# Traitement du ou des masques de paramètres de l'action massive               #
# -----> PARAMETRES  FASMTC, FASMTCP                                           #
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP

#===========================================#
# Actions de contrôle sur champ  FASSPLM    #
#===========================================#
#
##########################################################################
Subprog AM_BRDREF(VALEUR)
Variable Char    VALEUR

Local Char LCPY
LCPY =[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)
Read [BRD]BRD1=LCPY;VALEUR
If fstat = 0
 GZMAJ1 = [F:BRD]CHAMP1
 GZMAJ2 = [F:BRD]CHAMP2
 GZMAJ3 = [F:BRD]CHAMP3
Endif

# Si la référence clé de répartition  est modifiés et que l'on est déjà passé par Contrôler
If ( ACTTYPGES = GTAMMAS and ACTSTATUS = 8 )
   Call ACTCHGCRIT From TRCPROCOM
   # Si abandon sur ACTCHGCRIT mkstat= 2 mais pas de return. Il faut donc le gérer.
   If ( mkstat <> 0 ) Then : End : Endif
Endif

End

#====================
$ALIM_ENR_MAS1
Return
#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR
# Points d'entrée objet de reprise
#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
$LIENS_MFS

 Gosub LOADPLN

Return
#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à  l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN

# Chargement du masque tableau des infos "spécifiques" par plan suite à  clique sur bien
# Appelée pour chaque enreg de la table temporaire
# Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign
If !(clalev([F:TMPS])) : Local File TMPMASFAS [TMPS] : Endif

If [F:TMPS]AASIND = "N"  and  [F:TMPS]OBJREFO=[M:MFS0]OBJREF(nolign-1)
   [M:MFS0]OBJREFN(nolign-1)     = [F:TMPS]OBJREF
   [M:MFS0]OBJREFO(nolign-1)     = [F:TMPS]OBJREFO
   [M:MFS0]AASDES1N(nolign-1)    = [F:TMPS]AASDES1
   [M:MFS0]AASINDN(nolign-1)     = [F:TMPS]AASIND
   [M:MFS0]AASDES2N(nolign-1)    = [F:TMPS]AASDES2
   [M:MFS0]ACGGRPN(nolign-1)     = [F:TMPS]ACGGRP
   [M:MFS0]ACCCODN(nolign-1)     = [F:TMPS]ACCCOD
   [M:MFS0]GACN(nolign-1)        = [F:TMPS]GAC
   [M:MFS0]IASACCN(nolign-1)     = [F:TMPS]IASACC
   [M:MFS0]AASQTYN(nolign-1)     = [F:TMPS]AASQTY
   [M:MFS0]ACGETRNOTN(nolign-1)  = [F:TMPS]ACGETRNOT
   [M:MFS0]IASETRNOTN(nolign-1)  = [F:TMPS]IASETRNOT
   [M:MFS0]BRDPRCN(nolign-1)     = [F:TMPS]BRDPRC
   [M:MFS0]USRFLDM1N(nolign-1)   = [F:TMPS]USRFLDM1
   [M:MFS0]USRFLDM2N(nolign-1)   = [F:TMPS]USRFLDM2
   [M:MFS0]USRFLDM3N(nolign-1)   = [F:TMPS]USRFLDM3
   [M:MFS0]USRFLDM4N(nolign-1)   = [F:TMPS]USRFLDM4
   [M:MFS0]USRFLDM5N(nolign-1)   = [F:TMPS]USRFLDM5
   [M:MFS0]USRFLDM6N(nolign-1)   = [F:TMPS]USRFLDM6
   [M:MFS0]FLGERRN(nolign-1)     = [F:TMPS]FLGERR
   [M:MFS0]FLGMODN(nolign-1)     = G_OUI
Endif

Affzo [M:MFS0]NBOBJN

Return
#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à  mettre à  jour.                          #
# Table temporaire -> [F:TMPS]   | Pour les BCO                #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
Subprog SAVE_BCO()

Local Integer SAV_NOLIGN, I

If !([M:MFS0]NBOBJN=0)
   SAV_NOLIGN=nolign
   Raz nolign
   For I=1 To [M:MFS0]NBOBJN
      Read[MFS]MFS0= NUMACT;[M:MFS0]OBJREFN(I-1)
      If fstat = 0
         [F:MFS]= [M:MFS0]
         [F:MFS]FLGERR      =   [M:MFS0]FLGERRN(I-1)
         [F:MFS]FLGMOD      =   [M:MFS0]FLGMODN(I-1)
         [F:MFS]AASDES1     =   [M:MFS0]AASDES1N(I-1)
         [F:MFS]AASDES2     =   [M:MFS0]AASDES2N(I-1)
         [F:MFS]AASQTY      =   [M:MFS0]AASQTYN(I-1)
         [F:MFS]ACGGRP      =   [M:MFS0]ACGGRPN(I-1)
         [F:MFS]ACCCOD      =   [M:MFS0]ACCCODN(I-1)
         #-------------------------------------------------#
         Rewrite [MFS]
         If fstat
            # ? Qu'est ce-qu'on fait si ça se plante ??????
         Endif
      Endif
   Next I
   nolign=SAV_NOLIGN
Endif


End
#=====================================================================
$SAVEBCO

   Read [MFS]MFS0=NUMACT;[M:MFS0]OBJREF(nolign-1)
   If fstat = 0
       [F:MFS]OBJREF        =    [M:MFS0]OBJREF(nolign-1)
       [F:MFS]AASDES1       =    [M:MFS0]AASDES1(nolign-1)
       [F:MFS]AASDES2       =    [M:MFS0]AASDES2(nolign-1)
       [F:MFS]AASQTY        =    [M:MFS0]AASQTY(nolign-1)
      #-------------------------------------------------#
      Rewrite [MFS]
      If fstat
         # ? Qu'est ce-qu'on fait si ça se plante ??????
      Endif
   Endif

Return
#=====================================================================
$SAVEBCN

   Read [MFS]MFS0=NUMACT;[M:MFS0]OBJREFN(nolign-1)
   If fstat = 0
       [F:MFS]AASDES1       =    [M:MFS0]AASDES1N(nolign-1)
       [F:MFS]AASDES2       =    [M:MFS0]AASDES2N(nolign-1)
       [F:MFS]AASQTY        =    [M:MFS0]AASQTYN(nolign-1)
      #-------------------------------------------------#
      Rewrite [MFS]
      If fstat
         # ? Qu'est ce-qu'on fait si ça se plante ??????
      Endif
   Endif

Return
######################################################################
# Points d'entrée objet de reprise
######################################################################
#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
$MFS_LIENS0

Local Char CRITSEL(255)

If !(clalev([F:TMPR])) : Local File TMPMASFAS [TMPR] : Endif

CRITSEL='TRTNUM=NUMACT  & AASIND ="A"'
Filter [TMPR] Where evalue(CRITSEL)

Return
#=====================================================================
$MFS_LIENS2

Local Integer RNBNEWSUP
Local Integer FIN         # Booléen de fin de recherche
Local Integer I_NEW, I, J # Indice de nouveau bien trouvé
Local Integer SAV_NOLIGN # Indice de nouveau bien trouvé

FIN         = 0
RNBNEWSUP   = 0
J           = 0

 Sorta [M:MFS0]NBOBJ [M:MFS0]NBOBJ Order By [M:MFS0]AASIND([S]indice), [M:MFS0]OBJREF([S]indice)

 SAV_NOLIGN = [M:MFS0]NBOBJ

 Repeat
  I=find("N",[M:MFS0]AASIND)
  If I= 0
    FIN=1
  Else
      [M:MFS0]OBJREFN(J)     = [M:MFS0]OBJREF(I-1)
      [M:MFS0]OBJREFO(J)     = [M:MFS0]OBJREFO(I-1)
      [M:MFS0]AASDES1N(J)    = [M:MFS0]AASDES1N(I-1)
      [M:MFS0]AASINDN(J)     = [M:MFS0]AASIND(I-1)
      [M:MFS0]AASDES2N(J)    = [M:MFS0]AASDES2N(I-1)
      [M:MFS0]ACGGRPN(J)     = [M:MFS0]ACGGRP(I-1)
      [M:MFS0]ACCCODN(J)     = [M:MFS0]ACCCOD(I-1)
      [M:MFS0]GACN(J)        = [M:MFS0]GAC(I-1)
      [M:MFS0]IASACCN(J)     = [M:MFS0]IASACC(I-1)
      [M:MFS0]AASQTYN(J)     = [M:MFS0]AASQTYN(I-1)
      [M:MFS0]ACGETRNOTN(J)  = [M:MFS0]ACGETRNOT(I-1)
      [M:MFS0]IASETRNOTN(J)  = [M:MFS0]IASETRNOT(I-1)
      [M:MFS0]BRDPRCN(J)     = [M:MFS0]BRDPRC(I-1)
      [M:MFS0]USRFLDM1N(J)   = [M:MFS0]USRFLDM1(I-1)
      [M:MFS0]USRFLDM2N(J)   = [M:MFS0]USRFLDM2(I-1)
      [M:MFS0]USRFLDM3N(J)   = [M:MFS0]USRFLDM3(I-1)
      [M:MFS0]USRFLDM4N(J)   = [M:MFS0]USRFLDM4(I-1)
      [M:MFS0]USRFLDM5N(J)   = [M:MFS0]USRFLDM5(I-1)
      [M:MFS0]USRFLDM6N(J)   = [M:MFS0]USRFLDM6(I-1)
      J+=1
      Dela I-1 [M:MFS0]NBOBJ
      #Infbox "J"-num$(J)
      SAV_NOLIGN-=1
      RNBNEWSUP+=1
   Endif
  Until FIN


 [M:MFS0]NBOBJ = SAV_NOLIGN
 [M:MFS0]NBOBJN = J


  Affzo [M:MFS0]NBOBJ
  Affzo [M:MFS0]NBOBJN

Return



Funprog IS_PE_USED(PPOINT)
Value Char PPOINT()

Local Integer WBOK
WBOK = [V]CST_AFALSE
  If PPOINT = "" or dim(GNBENTREE) <= 0
    End WBOK
  Endif

Local Integer IEXEPRG , NPE , RPE(1..)
Local Char    EXEPRG(250) , TPE(30)(1..)

  # nom pgm sans truc...
  EXEPRG = adxpno(0)

  Repeat
    IEXEPRG = instr(1,EXEPRG,"/")
    If IEXEPRG
      EXEPRG = right$(EXEPRG,IEXEPRG+1)
    Endif
  Until !IEXEPRG

  IEXEPRG = instr(1,EXEPRG,"$")
  If IEXEPRG
    EXEPRG = left$(EXEPRG,IEXEPRG-1)
  Endif

  IEXEPRG = instr(1,EXEPRG,"@")
  If IEXEPRG
    EXEPRG = right$(EXEPRG,IEXEPRG+1)
  Endif

  IEXEPRG = instr(1,EXEPRG,".")
  If IEXEPRG
    EXEPRG = right$(EXEPRG,IEXEPRG+1)
  Endif

  If EXEPRG="EXEFNC2"
    EXEPRG = "EXEFNC"
  Endif

  IEXEPRG = find(EXEPRG, GENTSTD(1..GNBENTREE))
  If IEXEPRG = 0
    End WBOK
  Endif


  If dim(GENTRNG)>0
    Raz NPE , RPE , TPE
    For IPE=1 To GNBENTREE
      If GENTSTD(IPE) = EXEPRG
        NPE += 1
        RPE(NPE) = GENTRNG(IPE)
        TPE(NPE) = GENTSPE(IPE)
      Endif
    Next IPE
    If NPE>1
      # On trie d'après le rang
      Sorta NPE RPE,TPE Order By RPE(indice+1)
    Endif
  Else
    NPE = 1
    TPE(NPE) = GENTSPE(IEXEPRG)
  Endif

  If NPE
    WBOK = WBOK = [V]CST_ATRUE
  Endif

#  If dim([V]GPOINTTRA)>0 & GPOINTTRA=1
#    Call ECR_TRACE(mess(118,133,1)-":"-EXEPRG- PPOINT,0) From GESECRAN
#    # Appel du point d'entrée
#  Endif
#
#  Local Char    SAVACTPE(20)
#  If dim([L]ACTION)>0
#    SAVACTPE = ACTION
#  Else
#    Local Char ACTION(20)
#  Endif
#
#  For IPE=1 To NPE
##    ACTION = GPOINT
##    Gosub ACTION From =TPE(IPE)
#WBOK = [V]CST_ATRUE
#Break
#  Next IPE
#  If SAVACTPE<>""
#    ACTION = SAVACTPE
# Endif

End WBOK










################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> FASSPLM                                                              #
################################################################################
##########################################################################
## Gestion du masque MFASSPL [M:MFS0]
##########################################################################
#-> Avant zone sur la variable de bas de tableau
Subprog AV_NBOBJ_MFS

# Infbox "TRTFASSPLM :AV_NBOBJ_MFS"

If  (status=1 | status=71 |  status=31) & !(nolign>[M:MFS0]NBOBJ)
   Call LOAD_NEW_BCO(nolign)
Endif

End
#==============================================================#
#-> Après ligne sur la variable de bas de tableau
Subprog APRES_NBOBJ_MFS

End
#==============================================================#
#-> Avant zone sur la variable de bas de tableau
Subprog AV_NBOBJN_MFS

# Infbox "TRTFASSPLM :AV_NBOBJN_MFS"

 If status=71
  Disable GSTAANU
 Endif

End
#==============================================================#
#-> Après ligne sur la variable de bas de tableau
Subprog APRES_NBOBJN_MFS

 If  status = 75
   Call SAVE_BCO()
 Endif

End
#==============================================================#
#-> Contrôle sur la variable de bas de tableau
Subprog C_NBOBJ_MFS

Local Integer NBR_BCO_SUP

  If status=65
    Local Integer NBR_CMP_SUP
    Call SUPPRIME_BCO([M:MFS0]OBJREF(nolign-1),NBR_BCO_SUP)
    If NBR_BCO_SUP
       Gosub MFS_LIENS2
    Endif
  Endif

End

#---------------------------------------------------------------------
# Dans un tableau listant les BCO, recherche et suppression des lignes
# correspondant aux composants d'un BCO principal passé en paramétre
#---------------------------------------------------------------------
Subprog SUPPRIME_BCO(PAASREF,RNBCOSUP)
Value Char PAASREF          # Référence du BCO principal dont il faut supprimer les biens éclatés
Variable Integer RNBCOSUP # Nombre de composants supprimés

Local Integer FIN    # Booléen de fin de recherche
Local Integer I_BCO  # Indice du composant trouvé
Local Integer POK,ERR,NBDELREC

FIN         = 0
NBR_BCO_SUP = 0

 Call SUPPRIME_TMP1(NUMACT, "TMPMASFAS", PAASREF, NBDELREC,ERR)
 RNBCOSUP = NBDELREC

End
#========================================================================
#
Subprog SUPPRIME_TMP1(PNUMACT,PTMPTAB, POBJREF, RNBDLREC,RERR)
#
# Sous-programme permettant de vider les tables de travail des enregistrements
# de l'action en cours identifiée par le numéro de traitement
# retournés sont les suivants :
# 0    Pas d'erreur
# ------------------------------------------------------------------------------
Value    Integer PNUMACT  # Numéro de traitement
Value    Char    PTMPTAB  # Nom de la table temporaire principale
Value    Char    POBJREF  # Référence du bien à supprimmer
Variable Integer RNBDLREC # Nombre d'enregistrements détruits
Variable Integer RERR     # Code retour du sous-programme

#=> Débranchement vers traitement ERREUR_SP  # Erreur sous-programme
 Onerrgo ERREUR_SP From TRCPROCOM

 If !clalev([F:MFS]) : Local File =nomap+'.'+PTMPTAB   [MFS] : Endif
 If !GTRANS
  Call DEBTRANS From GLOCK
  Trbegin [MFS]
 Endif
 Delete [MFS] Where (TRTNUM=PNUMACT and OBJREFO=POBJREF)
 RNBDLREC=adxdlrec
 If !GTRANS : Commit : Endif
 Close Local File [MFS]

Onerrgo

End


