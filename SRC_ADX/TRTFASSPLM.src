#   CREATION       : MDJ - 08/2006                                                                                 #
#   MODIFICATIONS  : MDJ - 24/10/2007 (V5)
#
#       CBO - 27.01.2016  FQ112873  : pas d'evt de chg d'imputation
#       CBO - 11.01.2016  FQ112875  : Les biens en crédit-bail ou concession deviennent non sélectionnables
#       CBO - 28.10.2015  FQ109496  : Performance : optimisation
#       MWA - 10.09.2014  FQ95754_3 : Classement pour vente (Sprint 38 - US 3) Opération interdite pour un bien classé pour vente
#       CBO - 19.05.2014 (FQ 99648) : Ajout entry point LECT_BRDKEY
#       GLE - 22.07.2013 (FQ 91317) : Problème si utilisation de la sélection étendue - suppression du subprog AP_BRDREF
#       MWA - 04.10.2012 (FQ 67615) : Low value assets
#       MDJ - 02.10.2012 (FQ 84515) : Ajout point d'entree SPLM_WRIFAS
#       MDJ - 26.09.2012 (FQ 84472) : Non maj flag FLGCNXCLC sur bien père lors d'un éclatement
#       MWA - 16.04.2012 (FQ 81297) : Mise à jour de FLGSPL
#       GLE - 01.07.2011 (FQ 74725) : Ajout point d'entree CREAT_SPL_FA et CREAT_SPL_DP
#       MDJ - 22.12.2010 (FQ 70141) : Vérification de sources (interne)
#       MDJ - 24.09.2010 (FQ 67460) : suite FQ-67275 : variable déclarées Global au lieu de Local
#                                     REECRIT_TMP1 : GOSUB remplacé par Call
#       GBO - 16.09.2010 (FQ 67275) : Abréviation TMPC2 trop longue remplacée par TMP3. Appel à REECRIT_DEP et
#                                     REECRIT_TMP1 : GOSUB remplacé par Call
#       MDJ - 26.05.2010 (FQ 64994) : Evénement FASCCNCNL exclu de l'éclatement
#       MDJ - 19.04.2010 (FQ 64122) : TEMPO_EVT : étiquette supprimée en V5...
#       MDJ - 18/11/2009 (FQ 54343) : Ajout éclatement mts concessions (portés par la nouvelle table TMPMASFA2)
#       GLE - 16/11/2009 (FQ 59900) : Gestion des codes activités dans la table diverse des tables d'événements 952
####################################################################################################################
# GTAMMAS massif
 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action métier FASSPL                 #
#==============================================================#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

#Infbox "TRTFASSPLM /"-ACTION

If dim(ORIACT)>0 & ORIACT<>""
   Case ORIACT
   When "TRTOBJ"
    Case ACTION
          When "LIENS0"             :  Gosub MFS_LIENS0
          When "LIENS2"             :  Gosub MFS_LIENS2
          When "APRES_CHOI"         :  Gosub MFS_APRES_CHOI
          When "EXEBOUT"            :  Gosub MFS_BOUTON
          When "SETBOUT"            :  Gosub MFS_SETBOUT
     When Default
    Endcase
   When Default
   Endcase
Else
   Case ACTION
    When "INIT"         : Gosub INIT
    When "INIT_DIA"     : Gosub INIT_DIA
    When "AVANT_PAR"    : Gosub AVANT_PAR
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
    When "DEBUT"        : Gosub DEBUT
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "SETBOUT"      : Gosub SETBOUT
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "BOUTON"       : Gosub BOUTON
    When "END"          : Gosub END_BOITE
    When "OK"           : Gosub OK
    When "ABA"          : Gosub ABA
    When "EXEC"         : Gosub EXEC
    When "CONTROLE"     : Gosub CONTROLE
    When "FIN"          : Gosub FIN
    When "TERMINE"      : Gosub TERMINE
    When "SORTIE"       : Gosub SORTIE
    When "SELTABKEY"    : Gosub SEL_TABKEY
    When "SEL_TABLE"    : Gosub SEL_TABKEY
    When Default
   Endcase
Endif

Return
#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)

Gosub ACTION From =TRTMODACT
Gosub OUVRE_TABLES

Return
#=====================================================================
$INIT_DIA                # (Massif - Saisie des paramètres)

If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)

If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
##### EXEC - Ouverture manuelle des masques de la fenêtre.
##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
##### d'un écran de critère.
Local Char WINACT : WINACT=ACTMETNAM
Local Integer I_MSK
If !clalev([F:AWI]) : Local File AWINDOW : Endif
If !clalev([F:AMK]) : Local File AMSK    : Endif
Read [AWI]AWI0=WINACT
If !fstat
 Local Mask =[F:AWI]MSKENT
 For I_MSK=0 To [F:AWI]NBMSK
   Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
   Local Mask =[F:AMK]CODMSK
 Next I_MSK
Endif

#-> Initialisation des paramètres de l'action
Raz [M:SPLM]BRDREF

#--> Réaffichage du masque paramètre et positionnement à  non valide pour forcer tous les contrà´les
Affzo  [M:SPLM]
Setmok [M:SPLM] With 0

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

If dim(TRTMODACT)<0
Global Char TRTMODACT
TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
Endif

Gosub ACTION From =TRTMODACT

#==> Ouverture des tables
 Gosub OUVRE_TABLES

#==> Déclaration des globales
 Global Integer GLOK
 Global Integer GZMAJ1
 Global Integer GZMAJ2
 Global Integer GZMAJ3
 Global Integer G_REPORT, G_TRACE, G_INCR
 Global Integer G_OWNTYP, G_GACACN, G_IASACN
 Global Char    G_ACGGRP, G_ACCCOD, G_GAC, G_IASACC
 Global Integer G_TRF_PCG, G_TRF_IAS
 Global Decimal G_PERDPRCUM2, G_PERENDDPE2, G_PERENDDPE
 Global Decimal G_DERSLDEX, G_DERSLDPC, G_DERSLDPS
 Global Date    GDATREF

 # FQ112873
 Global Decimal G_PSTIML      : G_PSTIML    = 0
 Global Decimal G_PSTIMLRVE   : G_PSTIMLRVE = 0
 Global Decimal G_PSTDPE      : G_PSTDPE    = 0
 Global Decimal G_PSTEXC      : G_PSTEXC    = 0
 Global Decimal G_PSTDER      : G_PSTDER    = 0
 Global Decimal G_PSTDERRVE   : G_PSTDERRVE = 0
 Global Decimal G_PSTRVETRF   : G_PSTRVETRF = 0
 Global Decimal G_PSTRVACRB   : G_PSTRVACRB = 0
 Global Date    G_SALCLSDAT
 Global Integer EVTPRINC
# FQ112873


Return
#=====================================================================
$DEBUT                 # (Massif et Unitaire)

Gosub ACTION From =TRTMODACT

If !GBATCH
  #-> Effacement du masque paramètre
  Effzo [M:SPLM]

  #-> Initialisation de la date de l'éclatement, du motif de l'éclatement
  Raz [M:SPLM]BRDREF

Endif

#--> On rend le masque invalide pour faire tous les contrôles
Affzo  [M:SPLM]
Setmok [M:SPLM] With 0

Gosub CHARGE_ATABZON # Issue 109496

Return

# Issue 109496 beginning of optimisation (load general infos) _____________________________________
#**
#* load in arrays Field's table prorata
#*!
$CHARGE_ATABZON

Global Char GCPY_SPL(GLONCPY)
Local Integer NB_FIELDS
  NB_FIELDS = 200
Global Char GTCOD_FAS(20)(1..NB_FIELDS) # Field's table prorata for FXDASSETS
Global Char GTCOD_DEP(20)(1..NB_FIELDS) # Field's table prorata for DEPREC
Global Char GTCOD_FLU(20)(1..NB_FIELDS) # Field's table prorata for FXDLIFL

Global Integer GNB_COD_FAS, GNB_COD_DEP, GNB_COD_FLU, WI_COD # counter for each table

  Raz GTCOD_FAS, GTCOD_DEP, GTCOD_FLU, GNB_COD_FAS, GNB_COD_DEP, GNB_COD_FLU

  Filter [ATZ] Where (CODFIC = "FXDASSETS" and CODTYP = "MD1")
  For [ATZ]
    GNB_COD_FAS += 1
    GTCOD_FAS(GNB_COD_FAS) = [F:ATZ]CODZONE
  Next
  Filter [ATZ]

  Filter [ATZ] Where (CODFIC = "DEPREC" and CODTYP = "MD1")
  For [ATZ]
    GNB_COD_DEP += 1
    GTCOD_DEP(GNB_COD_DEP) = [F:ATZ]CODZONE
  Next
  Filter [ATZ]

  Filter [ATZ] Where (CODFIC = "FXDLIFL" and CODTYP = "MD1")
  For [ATZ]
    GNB_COD_FLU += 1
    GTCOD_FLU(GNB_COD_FLU) = [F:ATZ]CODZONE
  Next
  Filter [ATZ]

Return

#**
#* load informations for CONTEXT (Context and deprec-plan)
#*!
$CHARGE_PLAN_CNX

Global Integer GTPLAN(1..G301MAX), TCNXDUPLAN(1..G301MAX), GTCNX(1..G301MAX), GWNB_CNX, GNB_PLN
Global Date GT_CNXDAT(0..G301MAX,1..5)
Global Char GT_CUR(GLONCUR)(G301MAX)

Local Date WCNXDAT(1..5)
Local Integer I, J, K, WRET

If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif

  J = 0
  K = 0
  For [CNX] Where CPY = GCPY_SPL
    For I = 0 To [F:CNX]NBPLC - 1
      If [F:CNX]PLNCAA(I) > 0
        J += 1
        GTPLAN(J) = [F:CNX]PLNCAA(I)
        TCNXDUPLAN(J) = [F:CNX]CNX
      Endif
    Next I
    K += 1
    GTCNX(K)= [F:CNX]CNX

    GT_CUR([F:CNX]CNX) = [F:CNX]CUR

    Call GET_CNX_DAT(GCPY_SPL, [F:CNX]CNX, WCNXDAT, WRET) From GLOBIENS
    # WCNXDAT(1) = [F:FIS]DATSTRFIY
    # WCNXDAT(2) = [F:FIS]DATENDFIY
    # WCNXDAT(3) = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
    # WCNXDAT(4) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    # WCNXDAT(5) = WCNXDAT(3)-1
    For I = 1 To 5
      GT_CNXDAT([F:CNX]CNX, I) = WCNXDAT(I)
    Next I
  Next
  GWNB_CNX = K
  GNB_PLN = J

  Gosub CHARGE_ECLATER_EVENEMENTS

Return

#**
#* Charge les infos utiles des plans et des contextes
#* après avoir troubé la société sélectionnée
#*!
$CHARGE_PLAN_CNX_BY_FLGCPY

Local Integer I

  I = 0
  While [M:MHC]CPY(I) <> AVOID.ACHAR
    If [M:MHC]FLGCPY(I) = G_OUI
      GCPY_SPL =[M:MHC]CPY(I)
      Break
    Endif
    I += 1
  Wend
  If GCPY_SPL <> AVOID.ACHAR
    Gosub CHARGE_PLAN_CNX
  Endif

Return

$CHARGE_ECLATER_EVENEMENTS

Global Char GTAB_NOMEVT(20)(1..30), GTAB_NOMTAB_EVT(20)(1..30)
Global Char GTAB_NOMZON(20)(1..30, 1..G301MAX, 1..100)
            # 1st indice : event
            # 2nd indice : deprec plan
            # 3rd indice : field
Global Integer GNB_EVT

Local Integer I, J, K, L, WPLN

Local Char    TAB_NOMZON(10)(40), WTRTEVTINT(30)
Local Integer TAB_ORDZON(40)
Local Integer TAB_STATUS(40)
Local Integer CODRET

  If clalev([F:ADI]) = 0
    Local File ATABDIV     [ADI]
  Endif

  GNB_EVT = 0
  For [ADI] Where NUMTAB = GTD_EVENT & N2 = GVML_OMBIEN and CODE <> AVOID.ACHAR

    If [F:ADI]CODE = "FASCNL" or [F:ADI]CODE = "LOFCNL" or [F:ADI]CODE = "GRTCNL" or
&     [F:ADI]CODE = "LEACNL" or [F:ADI]CODE = "FASCCNCNL" or
&     find([F:ADI]A2, GTABEVT) = 0
      # Do not split

    Else
      GNB_EVT += 1
      GTAB_NOMEVT(GNB_EVT) = [F:ADI]CODE
      GTAB_NOMTAB_EVT(GNB_EVT) = [F:ADI]A2

      If [F:ADI]N1 = 2      # Evt géré par plan
        For  J = 1 To GNB_PLN
          WPLN = GTPLAN(J)
          Gosub CHARGE_PRORATA
        Next J
      Else
        J = 1
        WPLN = G301AUC
        Gosub CHARGE_PRORATA
      Endif
      If CODRET
        mkstat = 2
        Break
      Endif
    Endif
  Next
  Close File [ADI]

Return
#**
#* load in an array the fields which must be prorated
#* they're in a generated traitment (GVFASCRT1...)
#*!
$CHARGE_PRORATA

Local Integer EXISTE_ADX

  WTRTEVTINT = "GV"
  Case [F:ADI]CODE
    When "FASAFFAGE" : WTRTEVTINT += "FASAFF"
    When "FASCHGIMP" : WTRTEVTINT += "FASCHGIC"
    When "FASREEVAL" : WTRTEVTINT += "FASRVA"
    When Default     : WTRTEVTINT += [F:ADI]CODE
  Endcase

  If WPLN <> G301AUC
    WTRTEVTINT += num$(WPLN)
  Endif

  Call EXISTE_ADX("", "", WTRTEVTINT, EXISTE_ADX) From ORDSYS
  If EXISTE_ADX = 0
    Return
  Endif

  Raz TAB_NOMZON
  Call GET_PRORATA_STATUS(GVML_OMBIEN, GCPY_SPL, [F:ADI]CODE, WPLN,
&           TAB_NOMZON, TAB_ORDZON, TAB_STATUS, CODRET)
&           From GENEVE

  L = 0
  For K = 0 To dim(TAB_NOMZON)-1
    If TAB_NOMZON(K) = AVOID.ACHAR
      Break
    Endif
    L += 1
    GTAB_NOMZON(GNB_EVT, WPLN, L) = TAB_NOMZON(K)
  Next K

Return


Funprog GET_CUR_DU_PLAN(PPLAN)
Value Integer PPLAN()

Local Char WCUR(GLONCUR)
Local Integer I

  WCUR = AVOID.ACHAR
  I = find(PPLAN, GTPLAN)
  If I
    WCUR = GT_CUR(TCNXDUPLAN(I))
  Endif

End WCUR

Funprog GET_CNX_DU_PLAN(PPLAN)
Value Integer PPLAN()

Local Integer I
  I = find(PPLAN, GTPLAN)
  If I
    End TCNXDUPLAN(I)
  Endif
End I
# End Issue 109496 beginning of optimisation (load general infos) _____________________________________


