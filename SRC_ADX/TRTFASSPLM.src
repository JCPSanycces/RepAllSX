$CONTROLE

If ACTSTATUS=STA_DEBUT & ACTTYPGES=GTAMMAS  & GSERVEUR # Massif batch (exécution)
  # Issue 112875 - 2016-01-11 by CBO : exclude CBAIL and CONCE
  #CRITACT= "( OWNTYP<>GVML_TDMODEL &((ISSDAT=[0/0/0])  or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI))& ( CMPSTA =GVML_SBAUTON or CMPSTA=GVML_SBLVA or CMPSTA=GVML_SBPRINC ))"
  Gosub SET_CRITACT
  # End Issue 112875
Endif

