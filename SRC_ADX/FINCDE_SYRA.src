#<AdxTL>@(#)6.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT DEFAULT DIMENSIONS
#############################################################################################################
# Private routines :
# _INI_CCE : returns the analytical dimension for a given company, a given default dimension code and a given dimension type
# _GET_ABREV : returns the result of string which is the code of an abbreviation (class, mask...)
# _GET_IDENT : returns the result of string (Identifier)  without the key word "_INS." (Key word defines an instante)
##############################################################################################################

#####################################################################################################################
## _INI_CCE
#####################################################################################################################
#**
#* Returns the analytical dimension for a given company, a given default dimension code and a given dimension type
#*
#* @private
#*
#* @param ACTX              Context
#* @param INST
#* @param COMPANY           Company
#* @param DEFAULT_DIMENSION Default dimension
#* @param DIE               Dimension Type
#* @param CCE               Analytical dimension
#* @param ERRMES            Error message
#*!
Funprog _INI_CCE(ACTX,INST,COMPANY,DEFAULT_DIMENSION,DIE,CCE,ERRMES)
Variable Instance ACTX       Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance INST       Using OBJECT
Value    Char     COMPANY             : # Company
Value    Char     DEFAULT_DIMENSION   : # Default dimension
Value    Char     DIE                 : # Dimension Type
Variable Char     CCE                 : # Analytical dimension
Variable Char     ERRMES()            : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Raz CCE

#-----  Declaration of Variables
Local Char    AXE(GLONDIE)    :  AXE    = DIE  :  # Available variable for the Entry Point.
Local Char    VALEUR(GLONCCE) :  VALEUR = CCE  :  # Available variable for the Entry Point.

Local Integer NBRLINCDE                  : # Number of lines of the default dimension (Chapter 693)
NBRLINCDE = len(mess(0,693,1))

Local Integer  INDDIE                    : # Indice of Dimension Type
Local Integer  NBRDIEMAX                 : # Number of Dimension Types (max 20)
Local Integer  ISYRA                     : # ISYRA=1 : The formula of identifier is with KEY word "INS"
Local Char     LEGCPY(GLONADI)           : # Company Legislation

Local Integer  TAB, I, IND, XX, XY, ICPY, RE_READ, ICPYDIE
Local Char     IDENT(30), IDENT2(30), WIDENT(30), ZONE(10), ABREV(GLONABR), WABREV(15), WAXE(GLONDIE), WCCE(GLONCCE), WOLDID1(30), WOLDID2(30)
Local Char     FLDCCE(GLONAVA)

#--------------- Opening of files  -----#
If adxtyp=33 | !clalev([F:CDE]) : Local File CACCEDEF [CDE] : Endif
If adxtyp=33 | !clalev([F:CCE]) : Local File CACCE    [CCE] : Endif

If COMPANY<>""
 ICPY = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
 If ICPY = [V]CST_ANOTDEFINED
  [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
 Endif
 NBRDIEMAX = fmet ACTX.ACACHE.ACPY.AGETVALNUM(COMPANY,"NBRDIE")
 LEGCPY = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"LEG")
Else
 If adxtyp=33 | !clalev([F:ACV]) : Local File ACTIV    [ACV] : Endif
 Local Integer FLGANA
 Call LEC_ACV("ANA",FLGANA) From CPTLEC
 NBRDIEMAX = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
 LEGCPY = ""
Endif

Call LEC_CDE(DEFAULT_DIMENSION,COMPANY) From CPTLEC
If fstat<>[V]CST_AOK : Raz VALEUR : End [L]ASTATUS :  Endif

INDDIE = find(DIE,[F:CDE]DIE(0..dim([F:CDE]DIE)-1))
If INDDIE
 For I=1 To [F:CDE]NBLIG

  TAB = evalue("[F:CDE]CCE"+num$(INDDIE)+"("+num$(I-1)+")")

  If adxtyp=33
   GPOINT="INISEC" : Gosub ENTREE From EXEFNC
   If VALEUR<>"" : Break : Endif
  Endif

  Gosub IDENT
  If VALEUR<>"" : Break : Endif

 Next I
Endif

CCE = VALEUR
End [L]ASTATUS


#####################################################################################################################
## _GET_ABREV
#####################################################################################################################
#**
#* Returns the result of string which is the code of an abbreviation (class, mask...)
#*
#* @private
#* @param STRVAR
#* @param ABREV
#*!
Subprog _GET_ABREV(STRVAR,ABREV)
Value    Char STRVAR
Variable Char ABREV

Local Integer K1, K2
ABREV  = ""
STRVAR = toupper(STRVAR)
K1 = instr(1,STRVAR,":")
If !K1 : End : Endif
K2 = instr(1,STRVAR,"]")
ABREV = mid$(STRVAR,K1+1,K2-(K1+1))

If instr(1,STRVAR,"[F")
 If ABREV<>""
  ABREV = "[F:"+ABREV+"]"
 Else
  ABREV  = "[F]"
 Endif
Elsif instr(1,STRVAR,"[M")
 If ABREV<>""
  ABREV = "[M:"+ABREV+"]"
 Else
  ABREV = "[M]"
 Endif
Endif
End


#####################################################################################################################
## _GET_IDENT
#####################################################################################################################
#**
#* Returns the result of string (Identifier)  without the keyword "_INS." (Keyword defines an instance)
#*
#* @private
#* @param STRVAR
#* @param WSTRVAR
#* @param SYRA
#*!
Subprog _GET_IDENT(STRVAR,WSTRVAR,SYRA)
Value    Char    STRVAR
Variable Char    WSTRVAR
Variable Integer SYRA

Local Integer K
SYRA = 0 : WSTRVAR = STRVAR

K = instr(1,STRVAR,"_INS.")
If K
 SYRA = 1 : WSTRVAR = right$(STRVAR,K+5)
Endif
End

$IDENT
# 1  = Product
# 2  = Customer
# 3  = Supplier
# 4  = Sales rep
# 5  = Buyer
# 6  = Document
# 7  = Company
# 8  = Site
# 9  = Currency
# 10 = Tax
# 11 = Sales footer
# 12 = Discount
# 13 = Bank
# 14 = Account
# 15 = Fixed asset
# 16 = Purchase footer
# 17 = Miscellaneous business partner
# 18 = Costing dimensions
# 19 = Overhead costs
# 20 = Origin document
# 21 = Previous dimensions
# 22 = Requester
# 23 = Purchase costs
# 24 = None

If TAB=6 or TAB=20
 Gosub INI_DOCUMENT  # Particular Case => Document or Origin Document
Elsif TAB=21
 Gosub INI_PREDIE    # Particular Case => Previous dimensions
Else
 Gosub INI_STD       # Standard Case
Endif
Return

$ERREUR
Resume

$INI_STD
If TAB>0 & TAB<>NBRLINCDE & [F:CDE]FLD(TAB-1)<>"" : # NBRLINCDE = None
 Call _GET_IDENT([F:CDE]FLD(TAB-1),WIDENT,ISYRA)
 Onerrgo ERREUR
 If    ISYRA : IDENT = evalue("INST."+WIDENT)
 Else        : IDENT = evalue(WIDENT)
 Endif
 Onerrgo
Endif
If IDENT<>""
 ABREV  = ""
 ZONE   = "CCE"
 IDENT2 = ""
 IND    = 0
 Case TAB
  When 1  : ABREV = "ITM" : TABLE = "ITMMASTER"
  When 2  : ABREV = "BPC" : TABLE = "BPCUSTOMER"
  When 3  : ABREV = "BPS" : TABLE = "BPSUPPLIER"
  When 4  : ABREV = "REP" : TABLE = "SALESREP"
  When 5  : ABREV = "AUS" : TABLE = "AUTILIS"
  When 6  : # Document, already done
  When 7  : ABREV = "CPY" : TABLE = "COMPANY"
  When 8  : ABREV = "FCY" : TABLE = "FACILITY"
  When 9  : ABREV = "TCU" : TABLE = "TABCUR"
  When 10 : ABREV = "TVT" : TABLE = "TABVAT"
  When 11 : ABREV = "SFI" : TABLE = "SFOOTINV"
  When 12 : ABREV = "TDA" : TABLE = "TABDEPAGIO"
  When 13 : ABREV = "BAN" : TABLE = "BANK"
  When 14 : ABREV = "GAC" : TABLE = "GACCOUNT"  :  ZONE = "CCEDEF"
                                                   If dim([F:GAC]COA)>0 : IDENT2 = [F:GAC]COA : Endif
  When 15 : ABREV = "FAS" : TABLE = "FXDASSETS"
  When 16 : ABREV = "PFI" : TABLE = "PFOOTINV"
  When 17 : ABREV = "BPR" : TABLE = "BPARTNER"
  When 18 : ABREV = "MWC" : TABLE = "WORKCOST" :
                                                  Onerrgo ERREUR
                                                  Call _GET_IDENT([F:CDE]FLD(7),WIDENT,ISYRA)
                                                  If    ISYRA  : IDENT = evalue("INST."+WIDENT)
                                                  Else         : IDENT = evalue(WIDENT)
                                                  Endif
                                                  Call _GET_IDENT([F:CDE]FLD(TAB-1),WIDENT,ISYRA)
                                                  If    ISYRA  : IDENT2 = evalue("INST1."+WIDENT)
                                                  Else         : IDENT2 = evalue(WIDENT)
                                                  Endif
                                                  Onerrgo
  When 19 : ABREV = "ONA" : TABLE = "OVENAT"
  When 20 : # Origin document, already done
  When 21 : # Previous dimensions, already done
  When 22 : ABREV = "AUS" : TABLE = "AUTILIS"
  When 23 : ABREV = "FCS" : TABLE = "FRECST"
 Endcase
 If ABREV<>""
  If adxtyp=33 | evalue("clalev([F:"+ABREV+"])")=0
   RE_READ = 0
   Local File =TABLE
  Else
   RE_READ = 1 : Raz WOLDID1, WOLDID2
   Case TAB
     When 1  : WOLDID1 = [F:ITM]ITMREF
     When 2  : WOLDID1 = [F:BPC]BPCNUM
     When 3  : WOLDID1 = [F:BPS]BPSNUM
     When 4  : WOLDID1 = [F:REP]REPNUM
     When 5  : WOLDID1 = [F:AUS]USR
     When 7  : WOLDID1 = [F:CPY]CPY
     When 8  : WOLDID1 = [F:FCY]FCY
     When 9  : WOLDID1 = [F:TCU]CUR
     When 10 : WOLDID1 = [F:TVT]VAT
     When 11 : WOLDID1 = num$([F:SFI]SFINUM)
     When 12 : WOLDID1 = [F:TDA]DEP
     When 13 : WOLDID1 = [F:BAN]BAN
     When 14 : WOLDID1 = [F:GAC]ACC          : WOLDID2 = [F:GAC]COA
     When 15 : WOLDID1 = [F:FAS]AASREF
     When 16 : WOLDID1 = num$([F:PFI]PFINUM)
     When 17 : WOLDID1 = [F:BPR]BPRNUM
     When 18 : WOLDID1 = [F:MWC]VLTFCY       : WOLDID2 = [F:MWC]VLTCCE
     When 19 : WOLDID1 = [F:ONA]OVENAT
     When 22 : WOLDID1 = [F:AUS]USR
     When 23 : WOLDID1 = [F:FCS]FCSCOD
    Endcase
   Endif
 Endif
 Case ABREV
   When "ITM" : fstat=[V]CST_AOK
                If [F:ITM]ITMREF<>IDENT :  Read [ITM]ITM0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "BPC" : Call LEC_BPC(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "BPS" : Call LEC_BPS(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "REP" : fstat=[V]CST_AOK
                If [F:REP]REPNUM<>IDENT :  Read [REP]REP0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "AUS" : fstat=[V]CST_AOK
                If [F:AUS]USR<>IDENT : Read [AUS]CODUSR = IDENT : Endif
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "CPY" : Call LEC_CPY(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "FCY" : Call LEC_FCY(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "TCU" : Call LEC_TCU(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "TVT" : Call LEC_TVT_LEG(LEGCPY,IDENT) From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "SFI" : fstat=[V]CST_AOK
                If num$([F:SFI]SFINUM)<>IDENT :  Read [SFI]SFI0 = val(IDENT) : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "TDA" : Call LEC_TDA(LEGCPY,IDENT) From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "GAC" : If IDENT2<>""
                 Call LEC_GAC(IDENT,IDENT2) From CPTLEC
                 If fstat = [V]CST_AOK : Gosub INI_SEC : Endif
                Endif
   When "FAS" : fstat=[V]CST_AOK
                If [F:FAS]AASREF<>IDENT : Read [FAS]FAS0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "PFI" : fstat=[V]CST_AOK
                If num$([F:PFI]PFINUM)<>IDENT :  Read [PFI]PFI0 = val(IDENT) : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "MWC" : fstat=[V]CST_AOK
                If [F:MWC]VLTCCE<>IDENT or [F:MWC]VLTFCY<>IDENT2 : Read [MWC]WCT0 = IDENT;IDENT2 : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "ONA" : fstat=[V]CST_AOK
                If [F:ONA]OVENAT<>IDENT :  Read [ONA]ONA0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "FCS" : fstat=[V]CST_AOK
                If [F:FCS]FCSCOD<>IDENT :  Read [FCS]FCS0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When "BPR" : ## Used if dimensions have been added in Specific
                Call LEC_BPR(IDENT)From CPTLEC
                If fstat=[V]CST_AOK :  Gosub INI_SEC : Endif
   When "BAN" : ## Used if dimensions have been added in Specific
                fstat=[V]CST_AOK
                If [F:BAN]BAN0<>IDENT :  Read [BAN]BAN0 = IDENT : Endif
                If fstat=[V]CST_AOK : Gosub INI_SEC : Endif
   When Default
          #     Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
          #     If fstat=0 :  Gosub INI_SEC : Endif
 Endcase
 If RE_READ
  Case ABREV
   When "ITM" : If [F:ITM]ITMREF<>WOLDID1 :  Read [ITM]ITM0 = WOLDID1 : Endif
   When "BPC" : Call LEC_BPC(WOLDID1)From CPTLEC
   When "BPS" : Call LEC_BPS(WOLDID1)From CPTLEC
   When "REP" : If [F:REP]REPNUM<>WOLDID1 :  Read [REP]REP0 = WOLDID1 : Endif
   When "AUS" : If [F:AUS]USR<>WOLDID1 : Read [AUS]CODUSR = WOLDID1 : Endif
   When "CPY" : Call LEC_CPY(WOLDID1)From CPTLEC
   When "FCY" : Call LEC_FCY(WOLDID1)From CPTLEC
   When "TCU" : Call LEC_TCU(WOLDID1)From CPTLEC
   When "TVT" : Call LEC_TVT_LEG(LEGCPY,WOLDID1) From CPTLEC
   When "SFI" : If num$([F:SFI]SFINUM)<>WOLDID1 :  Read [SFI]SFI0 = val(WOLDID1) : Endif
   When "TDA" : Call LEC_TDA(LEGCPY,WOLDID1) From CPTLEC
   When "GAC" : If WOLDID2<>"" : Call LEC_GAC(WOLDID1,WOLDID2) From CPTLEC : Endif
   When "FAS" : If [F:FAS]AASREF<>WOLDID1 : Read [FAS]FAS0 = WOLDID1 : Endif
   When "PFI" : If num$([F:PFI]PFINUM)<>WOLDID1 :  Read [PFI]PFI0 = val(WOLDID1) : Endif
   When "MWC" : If [F:MWC]VLTCCE<>WOLDID1 or [F:MWC]VLTFCY<>WOLDID2 : Read [MWC]WCT0 = WOLDID1;WOLDID2 : Endif
   When "ONA" : If [F:ONA]OVENAT<>WOLDID1 :  Read [ONA]ONA0 = WOLDID1 : Endif
   When "FCS" : If [F:FCS]FCSCOD<>WOLDID1 :  Read [FCS]FCS0 = WOLDID1 : Endif
   When "BPR" : Call LEC_BPR(WOLDID1)From CPTLEC
   When "BAN" : If [F:BAN]BAN0<>WOLDID1 :  Read [BAN]BAN0 = WOLDID1 : Endif
  Endcase
 Else
  Case ABREV
   When "ITM" : Close Local File [ITM]
   When "BPC" : Close Local File [BPC]
   When "BPS" : Close Local File [BPS]
   When "REP" : Close Local File [REP]
   When "AUS" : Close Local File [AUS]
   When "CPY" : Close Local File [CPY]
   When "FCY" : Close Local File [FCY]
   When "TCU" : Close Local File [TCU]
   When "TVT" : Close Local File [TVT]
   When "SFI" : Close Local File [SFI]
   When "TDA" : Close Local File [TDA]
   When "GAC" : Close Local File [GAC]
   When "FAS" : Close Local File [FAS]
   When "PFI" : Close Local File [PFI]
   When "MWC" : Close Local File [MWC]
   When "ONA" : Close Local File [ONA]
   When "FCS" : Close Local File [FCS]
   When "BPR" : Close Local File [BPR]
   When "BAN" : Close Local File [BAN]
  Endcase
 Endif
Endif
Return

$INI_DOCUMENT
If instr(1,[F:CDE]FLD(TAB-1),"func") | instr(1,[F:CDE]FLD(TAB-1),"evalue")
 If [F:CDE]FLD(TAB-1)<>""
  Onerrgo ERREUR
  VALEUR = evalue([F:CDE]FLD(TAB-1))
  Onerrgo
 Endif
Else
 Call _GET_IDENT([F:CDE]FLD(TAB-1),WIDENT,ISYRA)
 If !ISYRA
  Call _GET_ABREV([F:CDE]FLD(TAB-1),WABREV)
  Raz IND
  For XX=1 To NBRDIEMAX
   If DIE = evalue(WABREV+"DIE("+num$(XX-1)+")") : IND=XX : Break :  Endif
  Next
  If IND>0
   Onerrgo ERREUR
   VALEUR = evalue([F:CDE]FLD(TAB-1)+"("+num$(IND-1)+")")
   Onerrgo
  Endif
 Else
  Onerrgo ERREUR
  Raz IND
  For XX=1 To evalue("maxtab(inst."+WIDENT+")")
   If DIE = evalue("INST."+WIDENT+"("+num$(XX)+").DIE") : IND=XX : Break :  Endif
  Next
  If IND>0
   VALEUR = evalue("INST."+WIDENT+"("+num$(IND)+").CCE")
  Endif
  Onerrgo
 Endif
Endif
Return


$INI_PREDIE   # Previous dimensions

# A la différence des "Pièces" ou "Document d'origne", l'utilitaire boucle sur le tableau jusqu'à trouver une valeur.
# L’identifiant sera le nom du champ section et non sa valeur et pourra être saisi sous forme « CCE# ».

WOLDID1 = [F:CCE]CCE
WOLDID2 = [F:CCE]DIE
ABREV   = "CCE"

Call _GET_IDENT([F:CDE]FLD(TAB-1),WIDENT,ISYRA)

If !ISYRA
 Call _GET_ABREV([F:CDE]FLD(TAB-1),WABREV)
 Onerrgo ERREUR
 For XX=1 To NBRDIEMAX
  If evalue("dim("+WABREV+"DIE)")>0
   WAXE = evalue(WABREV+"DIE("+num$(XX-1)+")")
  Elsif COMPANY<>""
   ICPYDIE = fmet ACTX.ACACHE.CPYDIE.AGETINDEX(COMPANY)
   If ICPYDIE = [V]CST_ANOTDEFINED : Break : Endif
   WAXE = fmet ACTX.ACACHE.CPYDIE.AGETVALCHAR(COMPANY,"DIE"+num$(XX))
  Else
   WAXE = ""
  Endif
  WCCE = ""
  If WAXE <> ""
   FLDCCE="CCE"
   K =  instr(1,[F:CDE]FLD(TAB-1),"]")
   If K : FLDCCE = right$([F:CDE]FLD(TAB-1),K+1) : Endif
   K = instr(1,FLDCCE,"#")
   If K
    FLDCCE = left$(FLDCCE,K-1)
    WCCE = evalue(WABREV+FLDCCE+num$(XX)+"("+num$(nolign-1)+")")
   Else
    WCCE = evalue(WABREV+FLDCCE+"("+num$(XX-1)+")")
   Endif
  Endif
  If WCCE  <>"" : Gosub INICCE_PREDIE : Endif
  If VALEUR<>"" : Break : Endif
 Next
 Onerrgo
Else
 Onerrgo ERREUR
 For XX=1 To evalue("maxtab(inst."+WIDENT+")")
  WAXE = evalue("INST."+WIDENT+"("+num$(XX)+").DIE")
  WCCE = ""
  If WAXE <> ""
   WCCE = evalue("INST."+WIDENT+"("+num$(XX)+").CCE")
  Endif
  If WCCE<>"" : Gosub INICCE_PREDIE : Endif
  If VALEUR<>"" : Break : Endif
 Next
 Onerrgo
Endif
Call LEC_CCE(WOLDID1,WOLDID2) From CPTLEC
Return

$INICCE_PREDIE
Call LEC_CCE(WCCE,WAXE) From CPTLEC
If fstat=[V]CST_AOK
 Raz IND
 For XY=1 To dim([F:CCE]OTHDIE)-1
  WAXE = evalue("[F:CCE]OTHDIE("+num$(XY-1)+")")
  If WAXE="" : Break : Endif
  If DIE=WAXE : IND=XY : Break : Endif
 Next
 If IND>0 : VALEUR = evalue("[F:CCE]DEFCCE("+num$(IND-1)+")") : Endif
Endif
Return

######################################################################################################
$INI_SEC
Onerrgo ERREUR
Raz IND
For XX=1 To NBRDIEMAX
 If DIE=evalue("[F:"+ABREV+"]DIE("+num$(XX-1)+")") : IND=XX : Break : Endif
Next
If IND>0 : VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(IND-1)+")") : Endif
Onerrgo
Return

