#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque RCPLBE2

########################################################################
# Impression des étiquettes de stocks                      #
# -------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'écran STOLBEIMP                    #
# Action  : STKLBEIMP (GTRAITE)                                        #
# Fenêtre : ISTOLBE                                                    #
# Traitement de l'action : SUBSLPA                                     #
# Gosub autres           : SUBSLPB                                     #
# -------------------------------------------------------------------- #
########################################################################
$OUVRE
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
Global Integer GWNUMREQ
If !clalev([F:ITM])  : Local File ITMMASTER    [ITM]  : Endif
If !clalev([F:ITF])  : Local File ITMFACILIT   [ITF]  : Endif
If !clalev([F:ARP])  : Local File AREPORT      [ARP]  : Endif
If !clalev([F:AIM])  : Local File APRINTER     [AIM]  : Endif
If !clalev([F:AID])  : Local File APRINTDES    [AID]  : Endif
If !clalev([F:LBP])  : Local File LABELPRN     [LBP]  : Endif
If !clalev([F:ACV])  : Local File ACTIV        [ACV]  : Endif
If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif
If !clalev([F:TFO])  : Local File TABFOR       [TFO]  : Endif

Return

$DEBUT
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
Raz [M:LPB1]
[M:LPB0]LPNSTAT1    = 2       # libre
[M:LPB0]LPNSTAT2    = 2       # En stock
[M:LPB0]PRTFLG1     = 2       # Imprimé
#[M:LPB0]PRTFLG2     = 2       # Non imprimé
[M:LPB0]PRTFLG2     = 1       # Non imprimé
[M:LPB0]MONITMFLG1  = 2       # Mono aticle
[M:LPB0]MONITMFLG2  = 2       # Multi articles
[M:LPB0]MONLOTFLG1  = 2       # Mono lot
[M:LPB0]MONLOTFLG2  = 2       # Multi lots
Affzo [M:LPB0]
Return

$SETBOUT
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#

If [M:LPB1]NBLIG=0
   Call VIREBOUT(CHBOU,"2") From GOBJET
Endif

Return

$BOUTON
#------------------------#
# Traitement des boutons #
#------------------------#
Local Integer LRET
Case BOUT
    When "1" :
       Call RELOADLPN From SUBLPNLBEB
    When "2" :
       Call PRINTLPN(LRET) From SUBLPNLBEB
     When Default
Endcase
 Raz GPE
 GPOINT = "RELOADLPB"
 Gosub  ENTREE From EXEFNC
 If GPE =  0
    Call RELOADLPN From SUBLPNLBEB
 Endif
Return

