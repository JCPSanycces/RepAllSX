#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
 Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
  When "FIN"   : Gosub ACTEND
  When Default
 Endcase
Return

#------------------------------------------------
$OUVRE
 If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
 If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif
 Local Char LCPY : LCPY=PARAM(1)
 Gosub SET_CPY_AUTO 
Return

#------------------------------------------------
$DEBUT
 Effzo [M:CPI]
 If LCPY=""
  Actzo [M:CPI]CPYIFF
 Else
  [M:CPI]CPYIFF=LCPY
  Gosub LOAD_CNX_TAB
  Grizo [M:CPI]CPYIFF
 Endif
Return

#------------------------------------------------
$ACTEND
 If [M:CPI]SELDAT<>[0/0/0] : VALEUR=[M:CPI]SELDAT : Endif
Return

#------------------------------------------------
$LOAD_CNX_TAB
 For [CNX] Where CPY=LCPY
  Local Integer LEXISTCNX
  Read [F:FIS]FIY1=LCPY;[F:CNX]CNX;GVML_TECOURA
  If fstat
  Else
   [M:CPI]CNX([M:CPI]NBCNX)      =[F:CNX]CNX
   [M:CPI]FIYSTRDAT([M:CPI]NBCNX)=[F:FIS]DATSTRFIY
   [M:CPI]FIYENDDAT([M:CPI]NBCNX)=[F:FIS]DATENDFIY
   [M:CPI]PERSTRDAT([M:CPI]NBCNX)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
   [M:CPI]PERENDDAT([M:CPI]NBCNX)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
   [M:CPI]CUR([M:CPI]NBCNX)      =[F:CNX]CUR
   [M:CPI]NBCNX+=1
  Endif
 Next
 If dim(LEXISTCNX)<0
  Errbox mess(121,7770,1)
 Else
  Kill LEXISTCNX  
 Endif
 Affzo [M:CPI] 
Return

#-----------------------------------------------
$SET_CPY_AUTO
 If PARAM(1)="" & dim([M]CPY)>0 & [M]CPY<>""
  LCPY=[M]CPY  
 Endif
Return

#------------------------------------------------
Subprog AM_CPYIFF(VALEUR)
Variable Integer    VALEUR()
 Effzo [M:CPI]10 : LCPY=VALEUR : Gosub LOAD_CNX_TAB
End

