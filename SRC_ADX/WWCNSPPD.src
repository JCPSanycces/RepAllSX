$FERME_MSK
Case MA
 When -1 : If clalev([M:CPPD])>0 : Close Local Mask [CPPD] : Endif
 When  0 : If clalev([M:PPD1])>0 : Close Local Mask [PPD1] : Endif
 When  1 : If clalev([M:PPD2])>0 : Close Local Mask [PPD2] : Endif
Endcase
Return

$SETMASK
