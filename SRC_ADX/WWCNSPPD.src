 When -1 : Local Mask =CNOMMSK   [CPPD]
 When  0 : Local Mask =NOMMSK(0) [PPD1]
 When  1 : Local Mask =NOMMSK(1) [PPD2]
Endcase
Return

$GRISE_MSK
