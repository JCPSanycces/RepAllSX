#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# PTRTTAR : Impression des tarifs achats                                #
# --------------------------------------------------------------------- #
# Chargement des paramètres                                             #
#########################################################################

$ACTION
Case ACTION
  When "CONT1" : Gosub CONT1
Endcase
Return

$CONT1
If left$([M]RPTCOD,5)="PPRIC" & nolign=1
  If !clalev([F:PPC])  Local File PPRICCONF [PPC] : Endif
  Read [PPC] PPC0=VALEUR
  If !fstat & clalev([F:ARD])
    If [F:PPC]PLIBPRCNR=2  GMESSAGE=mess(342,194,1) : mkstat=1 : Return : Endif
    Read [ARD] ARD0=[M]RPTCOD;2
    If !fstat
      Case [F:ARD]PARCOD
        When "crit1deb" : [M]PARDES(1)=mess(2,253,1)-[F:PPC]CRIDES(0)
        When "crit2deb" : [M]PARDES(1)=mess(2,253,1)-[F:PPC]CRIDES(1)
        When "crit3deb" : [M]PARDES(1)=mess(2,253,1)-[F:PPC]CRIDES(2)
        When "crit4deb" : [M]PARDES(1)=mess(2,253,1)-[F:PPC]CRIDES(3)
        When "crit5deb" : [M]PARDES(1)=mess(2,253,1)-[F:PPC]CRIDES(4)
      Endcase
      Affzo [M]PARDES(1)
      nolign=1
    Endif
  Endif
Endif
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE,1)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE,IMPR)
Value Integer  IMPR
Variable Integer NBPAR
Variable Char    PARAMETRE()()
#-----
Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
  If J
   [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  #[L]VALEUR = right$([L]PARAMETRE(I),J+1)
   Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
   If [L]PARAM = "codetarif" : WCODE = [L]VALEUR : Endif  
  Else : Break 
  Endif
Next
# On est positionné sur la première ligne vide
# On va rajouter les paramètres pour les libellés des critères et des colonnes
#------------  Récupération des noms des critères -----------#
Read [PPC] PPC0 = WCODE
If fstat : GOK = 0 : End : Endif
# Issue 81870 - 2012-05-11 by SR 
Local Char LCRIDES(20)
Local Integer J
For J=0 To 4
 Call CHARCRIDES([F:PPC]FIL(J),[F:PPC]FLD(J),LCRIDES) From TRTPARAM
 [L]PARAMETRE(I) = "Lblcrit"+num$(J+1)+"="+ LCRIDES : I+= 1
Next J
#[L]PARAMETRE(I) = "Lblcrit1="+ left$([F:PPC]CRIDES(0),20) : I+= 1
#[L]PARAMETRE(I) = "Lblcrit2="+ left$([F:PPC]CRIDES(1),20) : I+= 1 
#[L]PARAMETRE(I) = "Lblcrit3="+ left$([F:PPC]CRIDES(2),20) : I+= 1 
#[L]PARAMETRE(I) = "Lblcrit4="+ left$([F:PPC]CRIDES(3),20) : I+= 1 
#[L]PARAMETRE(I) = "Lblcrit5="+ left$([F:PPC]CRIDES(4),20) : I+= 1 
Read [PRS] PRS0 = 2;[F:PPC]PLISTC
If fstat : GOK = 0 : NBPAR = I : End : Endif
#------------ Récupération des noms des colonnes ------------#
For J = 1 To 9
    If [F:PPC]DISCRGPRO(J-1) = 1
        K+=1
        Read [AXX] AXX0 = "PRICSTRUCT";"SHOAXX("+num$(J-1)+")";GLANGUE;num$([F:PRS]BPCBPS);[F:PRS]PLISTC 
        If !fstat 
            [L]PARAMETRE(I) = "Lbltit"+ num$(K) + "=" + left$([F:AXX]TEXTE,10)
            I+=1        
            [L]PARAMETRE(I) = "col"+ num$(K) + "=" + num$(J)
            I+=1
        Else
            [L]PARAMETRE(I) = "Lbltit"+ num$(K) + "=" + "-"+num$(J)+"-"
            I+= 1        
            [L]PARAMETRE(I) = "col"+ num$(K) + "=" + num$(J) 
            I+=1
        Endif
    Endif
Next J
If K < 9
    For J = K+1 To 9
        K+=1
        [L]PARAMETRE(I) = "Lbltit"+ num$(K) + "=" + " "
        I+=1        
        [L]PARAMETRE(I) = "col"+ num$(K) + "=" + "0" 
        I+=1
    Next J
Endif
NBPAR = I 
End

########################################################################### 
 
$OUVRE 
Local File  PRICSTRUCT [PRS] , PPRICCONF [PPC], ATEXTRA [AXX]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP), WCODE(GLONPLI)
Local Integer I, J, K
Return 
