#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUDLIG
###################################################################################################
$TCHACTION
  Case [L]ARULE
    When "CONTROL"   : Gosub TCHACTION_CONTROL
  Endcase
Return

$TCHACTION_CONTROL
  If this.TCHACTION <> "" and this.TCHACTION <> "BUD_AUTOMATION" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHACTION", func AFNC.MES1(mess(390,2260,1), this.TCHACTION), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$TCHFINOVSESS
  Case [L]ARULE
    When "INIT"      : Gosub TCHFINOVSESS_INIT
  Endcase
Return

$TCHFINOVSESS_INIT
  this.TCHFINOVSESS = 0
Return

###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  # Issue X3-68131 - 2018-02-12 by FGR : BEGIN
  #this.KEYCONCAT = this.OPPNUM + "~" + this.PBUCOD
  this.KEYCONCAT = func PJMBUDLIG_CSTD_PROGS.GET_KEYCONCAT(this.ACTX, this.OPPNUM, this.PBUCOD)
  # Issue X3-68131 - 2018-02-12 by FGR : END
Return

###################################################################################################
$ORI
  Case [L]ARULE
    When "INIT"      : Gosub ORI_INIT
    When "CONTROL"   : Gosub ORI_CONTROL
  Endcase
Return

$ORI_INIT
  this.ORI = 1
Return

$ORI_CONTROL
  If this.ORI <> 1 and this.ORI <> 2 and this.ORI <> 3 and this.ORI <> 6 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(126,143,1) - ":" - num$(this.ORI), [V]CST_AERROR))
  Endif
  If this.TCHACTION = "" Then
    If this.ASTALIN = [V]CST_ANEW Then
      If this.ORI <> 1 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Elsif this.ASTALIN = [V]CST_AUPD Then
      If this.ORI <> this.snapshot.ORI Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Elsif this.TCHACTION = "BUD_AUTOMATION" Then
    If this.ASTALIN = [V]CST_ANEW Then
      If this.ORI <> 2 and this.ORI <> 3 and this.ORI <> 6 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Elsif this.ASTALIN = [V]CST_AUPD Then
      If this.ORI <> this.snapshot.ORI and (this.snapshot.ORI <> 0 and this.snapshot.ORI <> 2 and this.snapshot.ORI <> 3 and this.snapshot.ORI <> 6) Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$PLBU
  Case [L]ARULE
    When "CONTROL"   : Gosub PLBU_CONTROL
    When "PROPAGATE" : Gosub PLBU_PROPAGATE
  Endcase
Return

$PLBU_CONTROL
Local Integer IUOMTYP

  If this.PLBU <> "" Then
    IUOMTYP = fmet this.ACTX.ACACHE.ATUN.AGETVALNUM(this.PLBU, "UOMTYP")
    If IUOMTYP <> 5 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBU", mess(190,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

$PLBU_PROPAGATE
  If this.ASTALIN = [V]CST_AUPD and this.PLBU <> this.snapshot.PLBU Then
    If this.PLBU <> AVOID.ACHAR and this.snapshot.PLBU <> AVOID.ACHAR Then
      If this.PLBQTY <> 0 Then
        Call CONVERT_QTY(this.ACTX, this.snapshot.PLBU, this.PLBU, this.PLBQTY) From TRTX3_SYRA
      Endif
      If this.PLBPRI <> 0 Then
        # The objective is to convert PLBPRI from the original unit (this.snapshot.PLBU) to the modified unit (this.STIMUOM)
        # Swapping the units will give me the correct price since I'm not working out the quantity
        Call CONVERT_QTY(this.ACTX, this.PLBU, this.snapshot.PLBU, this.PLBPRI) From TRTX3_SYRA
      Endif
    Endif
  Endif
Return

###################################################################################################
$PCCCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PCCCOD_CONTROL
    When "PROPAGATE" : Gosub PCCCOD_PROPAGATE
  Endcase
Return

$PCCCOD_CONTROL
  Local File PJMCOSTCTR [PJCC]
  # -------------------------
  Read [PJCC]PCC0=this.PCCCOD
  If [F:PJCC]PCCPROV = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD", mess(231,2260,1), [V]CST_AERROR))
  Endif
Return

$PCCCOD_PROPAGATE
Local Char SCUR(GLONCUR)
Local Char SUOM(GLONUOM)
Local Decimal WRATE
Local Integer ISTAT

  Call GETRATE_FROMDATE(this.PCCCOD, this.TCHPBUSTRDT, SUOM, SCUR, WRATE) From PJMCOSTCTR_CSTD_PROGS
  If SCUR <> AVOID.ACHAR Then
    # If nothing is done by the subroutine, nothing have to be do in this part
    this.PLBU = SUOM
    If SCUR = this.CUR Then
      this.PLBPRI = WRATE
      this.PLBPRIFRC = [V]CST_ANO      # Issue X3-105813 - 2018-08-29 by FGR : if new PCCCOD unforce the unit price
      this.PLBPRIREM = WRATE
    Else
      Call CONVERT(this.ACTX, SCUR, this.CUR, this.CUR, this.TCHCHGTYP, this.TCHPBUSTRDT, WRATE, WRATE, ISTAT) From TRTDEV_SYRA
      If ISTAT = 0 Then
        this.PLBPRI = arr(WRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
        this.PLBPRIFRC = [V]CST_ANO    # Issue X3-105813 - 2018-08-29 by FGR : if new PCCCOD unforce the unit price
        this.PLBPRIREM = arr(WRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
      Else
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD 3", mess(236,2260,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
  this.PLBDESAXX = func PJMCOSTCTR_CSTD_PROGS.GET_DESAXX(this, this.PCCCOD)
Return

###################################################################################################
$PLBQTY
  Case [L]ARULE
    When "CONTROL"   : Gosub PLBQTY_CONTROL
  Endcase
Return

$PLBQTY_CONTROL
  If this.PLBQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PLBPRI
  Case [L]ARULE
    When "CONTROL"   : Gosub PLBPRI_CONTROL
    When "PROPAGATE" : Gosub PLBPRI_PROPAGATE    # Issue X3-105813 - 2018-08-29 by FGR
  Endcase
Return

$PLBPRI_CONTROL
  If this.PLBPRI < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBPRI", mess(234,2260,1), [V]CST_AERROR))
  Endif
Return

$PLBPRI_PROPAGATE
  # Issue X3-105813 - 2018-08-29 by FGR
  this.PLBPRIFRC = [V]CST_AYES
Return

