#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Swiss Localization
# File          : SUBPAY3SWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 21.05.15
######################################################################################################
# Module        : Accounting
# Description   : Swiss specific initializations for payments
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
 # 24.06.15 |Bader |U9     |Don't check parameter GSWIPAYBVR in OUVRE as company is not yet known
 # 25.07.18 |Bader |2018.R?|X3-99013: LIENS: init GSWIPAYQR
######################################################################################################

#*****************************************************************************************************
# OUVRE: Ouverture des fichiers nécessaire à la localisation
#*****************************************************************************************************
$OUVRE
  If !clalev([F:TPTX]) : Local File TABPAYTERM [TPTX]      : Endif
  If !clalev([F:BPSX]) : Local File BPSUPPLIER [BPSX]      : Endif
  If !clalev([F:DUDX]) : Local File GACCDUDATE [DUDX]      : Endif
Return
#*****************************************************************************************************


$FERME
  If clalev([F:TPTX]) : Close Local File [TPTX]      : Endif
  If clalev([F:BPSX]) : Close Local File [BPSX]      : Endif
  If clalev([F:DUDX]) : Close Local File [DUDX]      : Endif
Return
#*****************************************************************************************************


$LIENS
   If dim(GSWIPAYBVR) > 0 : GSWIPAYBVR = int(val(func AFNC.PARAM("SWIPAYBVR", [M]FCY))) : Endif
# X3-99013 2018-07-25 Bader begin
   If dim(GSWIPAYQR) > 0  : GSWIPAYQR  = int(val(func AFNC.PARAM("SWIPAYQR", [M]FCY))) : Endif
# X3-99013 2018-07-25 Bader end
Return
#*****************************************************************************************************


#*****************************************************************************************************
# RAZCRE_: Avant la saisie en création
#*****************************************************************************************************
$RAZCRE
If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 : # parameter "Swiss checks in payments" = yes?
  Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC  # read payment entry type
  # X3-29237
  If find([F:TPY]SWIPAYTYP,2,3,4)    # DTA/EZAG/ISO payment?
    [M:PAY1]SWISUP3=int(val(func AFNC.PARAM("DEFBANCRG", ""))) # assign default bank charge bearer
    Affzo [M:PAY1]SWISUP3
  Endif
Endif
Return
#*****************************************************************************************************

