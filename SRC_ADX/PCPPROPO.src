#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("PCP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub PROPOSITION
Endcase
Return


$INIT
If !clalev([F:CPY])    : Local File COMPANY     [CPY]  : Endif
If !clalev([F:BAN])    : Local File BANK        [BAN]  : Endif
If !clalev([F:BPR])    : Local File BPARTNER    [BPR]  : Endif
If !clalev([F:BPC])    : Local File BPCUSTOMER  [BPC]  : Endif
If !clalev([F:RLT2])   : Local File RELMT940    [RLT2] : Endif
If !clalev([F:TPY])    : Local File TABPAYTYP   [TPY]  : Endif
If !clalev([F:RLD2])   : Local File RELMT940D   [RLD2] : Endif
If !clalev([F:RLD3])   : Local File RELMT940D   [RLD3] : Endif
If !clalev([F:SIH])    : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:TPY])    : Local File TABPAYTYP   [TPY]  : Endif

Local Char    TEXTE(100)(0..dim([F:RLD2]FREREF)-1)
Local Char    CRITERE(250), CRITERE2(250)
Local Char    PREFIX(10), CHAINE(15), CHAINE2(20)
Local Char    BPRP(GLONBPR), BPRF(GLONBPR)
Local Char    NUMFAC(GLONVCR)
Local Char    XNUMECH(20) 
Local Char    PTE(GLONPTE)
Local Integer OKECH, TYPCOURS, STAT, NOLI, IND, K, OKLEC
Local Integer LNG_MIN, LNG_MAX
Local Integer VU
Local Decimal DIFF_REG
Local Decimal SLDECH, SLDECHLOC
Return


$CONTROLE
Return

$PROPOSITION
[L]PREFIX = [M:DIA]PREFIXE
Call LEC_CPY([M:PCP]CPY) From CPTLEC
For NOLI=0 To [M:PCP]NBLIG-1
 Raz NUMFAC
 If [M:PCP]FLGCRE(NOLI)<>2 & [M:PCP]NUM(NOLI)=""
  Read [RLD3]RLD0 = [M:PCP]FILNUM ; [M:PCP]TRFNUM ; [M:PCP]SEQNUM(NOLI) ; [M:PCP]LIN(NOLI)
  ## On essaye de trouver l'échéance grâce au préfixe échéance renseigné dans l'écran de critères 
  If [M:DIA]PREFIXE<>""
   CHAINE = "*"+[M:DIA]PREFIXE+"*"
   For I=0 To dim([F:RLD3]FREREF)-1
    If [F:RLD3]FREREF(I)<>""
     TEXTE(I) = [F:RLD3]FREREF(I)
     If pat(TEXTE(I),CHAINE)
      ## Il y a le préfixe dans la ligne de référence => on analyse la chaîne...
      Gosub RECHFAC
      If OKLEC : Break
      Else : Raz NUMFAC
      Endif
     Endif
    Endif
   Next  
  Endif
  ## Si pas de numéro d'échéance trouvé, on essaye de trouver l'échéance grâce à la "Chaîne précédent l'échéance"
  ## éventuellement saisi dans l'écran de critères
  If [L]NUMFAC="" & [M:DIA]PREDUD<>""
   CHAINE2 = "*"+toupper([M:DIA]PREDUD)+"*"
   For I=0 To dim([F:RLD3]FREREF)-1
    If [F:RLD3]FREREF(I)<>""
     TEXTE(I) = vireblc(toupper([F:RLD3]FREREF(I)),4)
     If pat(TEXTE(I),CHAINE2)
      ## On a trouvé la "chaîne précédant l'échéance" saisie dans l'écran de critères => 
      ## On regarde ce qui suit cette chaîne pour trouver l'échéance
      Gosub RECHFAC2
      If OKLEC : Break
      Else : Raz NUMFAC
      Endif
     Endif
    Endif
   Next
  Endif

  Gosub CRITERE
 
  ## Recherche de l'échéance qui se rapproche le plus...
  DIFF_REG = 0
  For [DUD] Where evalue(CRITERE) & evalue(CRITERE2)
   SOLDECH = [F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR

   ## On regarde si l'échéance n'a pas déjà été affectée dans le tableau
   [L]XNUMECH = num$([F:DUD]ACCNUM)+"/"+num$([F:DUD]DUDLIG)
   VU =  find([L]XNUMECH,[M:PCP]NUMECH(0..[M:PCP]NBLIG-1))
   If !VU

    ## 1/ On a un n° de facture et le tiers qui correspondent et un tiers
    If [L]NUMFAC<>"" & [L]NUMFAC=[F:DUD]NUM & [M:PCP]BPRPAY(NOLI)=[F:DUD]BPRPAY
     ## Correspondance parfaite : n° échéance et tiers identiques. Montant échéance égal au montant de l'ordre.
     If [L]SOLDECH=[M:PCP]AMTCUR(NOLI) & [F:DUD]BPRPAY=[M:PCP]BPRPAY(NOLI)
      Gosub AFFECT_ECH
      [M:PCP]LET(NOLI) = "A"
      Break
     ## N° échéance et tiers identiques. Montant échéance Ok par rapport à l'écart autorisé.
     ## Pour autant on ne break pas : on continue pour trouver peut-être une échéance avec montant identique
     ## où avec un écart plus petit...
     Elsif [L]SOLDECH>=[M:PCP]AMTCUR(NOLI)
      If [M:PCP]LET(NOLI)<>"" & (DIFF_REG=0 | DIFF_REG>=[L]SOLDECH-[M:PCP]AMTCUR(NOLI)) : # On a trouvé une échéance avec écart inférieur...
       Gosub AFFECT_ECH
       [M:PCP]LET(NOLI) = "A"
       DIFF_REG = [L]SOLDECH-[M:PCP]AMTCUR(NOLI)
       ## Pas de break... On continue au cas où... 
      Endif
     Endif

    ## 2/ On a un n° de facture qui existe dans X3 mais pas le tiers : on peut déduire le tiers de l'échéance 
    ## mais on associera le code 'B' (probabilité) 
    Elsif [L]NUMFAC<>"" & [L]NUMFAC=[F:DUD]NUM & [M:PCP]BPRPAY(NOLI)<>[F:DUD]BPRPAY
     If [L]SOLDECH=[M:PCP]AMTCUR(NOLI)
      Gosub AFFECT_ECH
      [M:PCP]LET(NOLI) = "B"
      Break
     Elsif [L]SOLDECH>=[M:PCP]AMTCUR(NOLI)
      If [M:PCP]LET(NOLI)<>"" & (DIFF_REG=0 | DIFF_REG>=[L]SOLDECH-[M:PCP]AMTCUR(NOLI)) : # On a trouvé une échéance avec écart inférieur...
       Gosub AFFECT_ECH
       [M:PCP]LET(NOLI) = "B"
       DIFF_REG = [L]SOLDECH-[M:PCP]AMTCUR(NOLI)
       ## Pas de break... On continue au cas où... 
      Endif
     Endif

    ## 3/ Pas de numéro de facture... Si on a le tiers, on essaye de trouver dans la base une échéance avec
    ## une correspondance probable par rapport au montant
    ## On ne fait cela que si par de préfixe saisi pour éviter d'affecter une échéance à un ordre de paiement
    ## qui comporte un numéro de facture dans ses zones libres mais avec un préfixe différent (qui sera
    ## renseigné par l'utilisateur pour la prochaine recherche...). De même, on ne fait cela que si
    ## pas de "Chaîne précédant l'échéance" renseigné dans l'écran de critères pour la même raison : éviter
    ## d'affecter une échéance alorsque le numéro de facture se trouve dans les zones libres mais avec
    ## une chaîne précédant l'échéance complétement différente.
    Elsif [L]NUMFAC="" & [M:DIA]PREFIXE="" & [M:DIA]PREDUD=""
     If [L]SOLDECH=[M:PCP]AMTCUR(NOLI) & [F:DUD]BPRPAY=[M:PCP]BPRPAY(NOLI)
      Gosub AFFECT_ECH
      [M:PCP]LET(NOLI) = "B"
      Break : # On arrête car on ne trouvera pas mieux...
     Elsif [L]SOLDECH>=[M:PCP]AMTCUR(NOLI)
      If [M:PCP]LET(NOLI)<>"" & (DIFF_REG=0 | DIFF_REG>=[L]SOLDECH-[M:PCP]AMTCUR(NOLI)) : # On a trouvé une échéance avec écart inférieur...
       Gosub AFFECT_ECH
       [M:PCP]LET(NOLI) = "B"
       DIFF_REG = [L]SOLDECH-[M:PCP]AMTCUR(NOLI)
       ## Pas de break... On continue au cas où... 
      Endif
     Endif
    Endif
   Endif
  Next

  ## On a rien trouvé... on met la lettre "C"
  If [M:PCP]NUM(NOLI) = ""
   [M:PCP]LET(NOLI) = "C"
   If [M:PCP]BPRPAY(NOLI)<>""
    Call LECTURE("BPC",[M:PCP]BPRPAY(NOLI),"") From CONTOBJ
    [L]BPRP = [M:PCP]BPRPAY(NOLI)
    If [M:PCP]BPRINV(NOLI)<>""
     [L]BPRF = [M:PCP]BPRINV(NOLI)
    Else
     [L]BPRF = [M:PCP]BPRPAY(NOLI)
    Endif
    Call INIPTE([L]BPRP,[L]BPRF,"C",[L]PTE) From TRTX3
    Call LEC_TPT_LEG([F:CPY]LEG,[L]PTE,1) From CPTLEC
    If !fstat
     [M:PCP]PAM(NOLI) = [F:TPT]PAM
    Endif
    If [M:PCP]PAYTYP(NOLI)=""
     Call RECH_PAYTYP([M:PCP]SIGN(NOLI),[M:PCP]PAM(NOLI),[M:PCP]PAYTYP(NOLI))
    Endif
   Endif
  Endif

 Endif
Next
Affzo [M:PCP]
Return

$AFFECT_ECH
[M:PCP]TYP(NOLI)    = [F:DUD]TYP
[M:PCP]NUM(NOLI)    = [F:DUD]NUM
[M:PCP]BPRINV(NOLI) = [F:DUD]BPR
[M:PCP]DUDDAT(NOLI) = [F:DUD]DUDDAT
[M:PCP]DUDNUM(NOLI) = [F:DUD]ACCNUM
[M:PCP]DUDLIG(NOLI) = [F:DUD]DUDLIG
[M:PCP]FCYLIN(NOLI) = [F:DUD]FCY
[M:PCP]PAM(NOLI)    = [F:DUD]PAM
[M:PCP]NUMECH(NOLI) = num$([F:DUD]ACCNUM)+"/"+num$([F:DUD]DUDLIG)
If [M:PCP]BPRPAY(NOLI) = ""
 [M:PCP]BPRPAY(NOLI) = [F:DUD]BPRPAY
Endif
If [M:PCP]PAYTYP(NOLI)=""
 Call RECH_PAYTYP([M:PCP]SIGN(NOLI),[M:PCP]PAM(NOLI),[M:PCP]PAYTYP(NOLI))
Endif
Return



$RECHFAC
OKLEC = 0
PREFIX = toupper(PREFIX)
IND = instr(1,TEXTE(I),PREFIX)
If [M:DIA]LNGMIN=0
 LNG_MIN=len(PREFIX)
 NUMFAC = PREFIX
Else
 LNG_MIN=[M:DIA]LNGMIN
 NUMFAC = mid$(TEXTE(I),IND,LNG_MIN)
Endif
If [M:DIA]LNGMAX=0 : LNG_MAX=len(TEXTE(I)) : Else : LNG_MAX=[M:DIA]LNGMAX : Endif

## On essaye...
Read [SIH]SIH0 = [L]NUMFAC
If !fstat & [F:CPY]CPY = [F:SIH]CPY
 OKLEC = 1 : Return
Endif
## On continue...
For K=LNG_MIN To [L]LNG_MAX
 [L]NUMFAC = mid$(TEXTE(I),IND,K)
 Read [SIH]SIH0 = [L]NUMFAC
 If !fstat : OKLEC = 1 : Break : Endif
Next
Return


$RECHFAC2
OKLEC = 0 : NUMFAC = ""
LNG_MIN=[M:DIA]LNGMIN
If [M:DIA]LNGMAX=0 : GLONVCR : Else : LNG_MAX=[M:DIA]LNGMAX : Endif

IND = instr(1,TEXTE(I),toupper([M:DIA]PREDUD))
For K = IND+len([M:DIA]PREDUD)-1 To (IND+len([M:DIA]PREDUD)-1)+GLONVCR
 If mid$(TEXTE(I),K+1,1)<>""
  [L]NUMFAC += mid$(TEXTE(I),K+1,1)
  Read [SIH]SIH0 = [L]NUMFAC
  If !fstat & [F:CPY]CPY = [F:SIH]CPY
   OKLEC = 1 : Break
  Endif
 Endif
Next
Return


$CRITERE
CRITERE = "1=1"
CRITERE -= "& DUDSTA=2"
CRITERE -= "& TYPDUD=2"
CRITERE -= "& CUR='"+[M:PCP]CUR+"'"
If [M:DIA]FLGAMT = 2 : # Analogie Montant
 CRITERE -= "& AMTCUR-PAYCUR-TMPCUR = [M:PCP]AMTCUR(NOLI)" 
Else
 ## Si pas analogie montant, on sélectionnera les échéances pour lequel le solde de l'échéance (=reste règler)
 ## déduit du montant de l'ordre de paiement est inférieur ou égal à l'écart autorisé   
 CRITERE -= "& (AMTCUR-PAYCUR-TMPCUR)-([M:PCP]AMTCUR(NOLI))<=[M:DIA]ECART" 
Endif
If [M:DIA]FLGBPR = 2 : # Analogie Tiers
 CRITERE -= "& BPRPAY='"+[M:PCP]BPRPAY(NOLI)+"'" 
Endif
CRITERE2 = "1=1"
If [L]NUMFAC<>"" : # On a trouvé un numéro de facture dans les zones libres et qui existe dans X3
 CRITERE2 -= "& NUM='"+[L]NUMFAC+"'" 
Endif
Return


Subprog RECH_PAYTYP(SENS,MODREG,TYPREG)
Value    Integer SENS
Value    Char    MODREG()
Variable Char    TYPREG()
Local Char MODREG(GLONADI)
If !clalev([F:TPY]) : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:CPY]) : Local File COMPANY  [CPY]  : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Case SENS
 When -1 : # Dépenses (Avoirs clients)
  Filter [TPY] Where LEG=[F:CPY]LEG & [F:TPY]ENAFLG=2 & [F:TPY]SNS=1 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
 When 1 : # Recettes (Factures clients)
  Filter [TPY] Where LEG=[F:CPY]LEG & [F:TPY]ENAFLG=2 & [F:TPY]SNS=2 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
Endcase
Read [TPY]TPY0 First
Filter [TPY]
If !fstat
 TYPREG = [F:TPY]PAYTYP
Endif
End


######################################################################################
## Etiquettes masque PCPCRIT [DIA]
######################################################################################
Subprog AS_ECART(VALEUR)
Variable Decimal VALEUR
If [M]FLGAMT=2
 mkstat = 1 : End
Endif
End

Subprog AM_PREFIXE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M:DIA]LNGMIN = len(VALEUR)
 Affzo LNGMIN
Endif
End



