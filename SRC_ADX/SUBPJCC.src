##########################################################################################################
Subprog C_NBPCC
Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJCC]PCCDATCST(nolign-1) = [0/0/0] Then
      ILINE = fmet GZINSPJCC.ADDLINE("DATRATE", [V]CST_ALASTPOS)
      # ------------------------------------
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_DATRATE_LINE(ILINE)
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJCC]15
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJCC.ADELLINE("DATRATE", GZINSPJCC.DATRATE([M:PJCC]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

