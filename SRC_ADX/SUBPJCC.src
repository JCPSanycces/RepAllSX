#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Objet PJCC
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"             : Gosub OUVRE
    When "LIENS"             : Gosub LIENS
    When "RAZCRE"            : Gosub RAZCRE
    When "CREATION"          : Gosub CREATION
    When "APRES_CRE"         : Gosub APRES_CRE
    When "MODIF"             : Gosub MODIF
    When "APRES_MOD"         : Gosub APRES_MOD
    When "AV_ANNULE"         : Gosub AV_ANNULE
    When "ANNULE"            : Gosub ANNULE
    When "FERME"             : Gosub FERME
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Instance GZINSPJCC Using C_PJMCOSTCTR          # Hybrid part

  ANOWRITE = 1
  # ------------------------------------
  If !clalev([F:PJCC]) : Local File PJMCOSTCTR    [PJCC] : Endif
  If !clalev([F:LED])  : Local File GLED          [LED]  : Endif
  If !clalev([F:CAC])  : Local File GACCCODE      [CAC]  : Endif # Issue X3-66481 - 2018-05-28 by SINGC
  # ------------------------------------
Return

##########################################################################################################
$FERME
  If GZINSPJCC <> null Then
    FreeGroup GZINSPJCC
  Endif
  Kill GZINSPJCC
Return

##########################################################################################################
$LIENS
Local Integer MY_STATUS                          # Hybrid part

  # ------------------------------------
  # Hybrid part (begin)
  If GZINSPJCC <> null Then
    FreeGroup GZINSPJCC
  Endif
  # ------------------------------------
  GZINSPJCC = NewInstance C_PJMCOSTCTR AllocGroup null
  [L]MY_STATUS = fmet GZINSPJCC.AREAD([M:PJCC0]PCCCOD)
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # ------------------------------------
  Call COPY_CLASS_TO_SCREEN()
  # ------------------------------------
  # Sauvegarde données courant
  GFCY = [M:PJCC0]PCCFCY
  Call GETDEV(GFCY) From DEVSUB
  # ------------------------------------
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  # ------------------------------------
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
  Affzo [PJCC1]1-99
Return

##########################################################################################################
$RAZCRE
Local Integer MY_STATUS                          # Hybrid part

  # ------------------------------------
  # Hybrid part (begin)
  If GZINSPJCC <> null Then
    FreeGroup GZINSPJCC
  Endif
  # ------------------------------------
  GZINSPJCC = NewInstance C_PJMCOSTCTR AllocGroup null
  [L]MY_STATUS = fmet GZINSPJCC.AINIT()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # ------------------------------------
  Call COPY_CLASS_TO_SCREEN()
  If GERR = 1 Then
    Return
  Endif
  # Hybrid part (end)
  # ------------------------------------
  # It initializes the site
  GFCY = [M:PJCC0]PCCFCY
  Call GETDEV(GFCY) From DEVSUB
  # ------------------------------------
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  # ------------------------------------
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
Return

##########################################################################################################
$CREATION
Local Char    MSG(250)
Local Integer L_PJTAUTCRE
Local Integer IANSWER
Local Integer MY_STATUS                          # Hybrid part

  # ------------------------------------
  If fmet GZINSPJCC.CDIE_COUNT() > 0 Then
    L_PJTAUTCRE = fmet GZINSPJCC.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, GZINSPJCC.ACTX.AFOLDER, "PCCAUTCRE")
    If find(L_PJTAUTCRE,1,2) = 0 Then
      L_PJTAUTCRE = 2      # Confirmation / Toujours
    Endif
    If L_PJTAUTCRE = 2 Then
       # Confirmation
       IANSWER = GZINSPJCC.TCHREPDIECCE
       MSG = func ASYRFNC.MES2(mess(115,103,1), [F:PJCC]PCCCOD, "")
       Call YESNO_CHX(MSG, mess(114,103,1), mess(2,1,1), mess(1,1,1), IANSWER) From GESECRAN
       GZINSPJCC.TCHREPDIECCE = IANSWER
    Endif
  Endif
  # ------------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJCC.AINSERT()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # ----------------------------------
  SetInstance [F:PJCC] With GZINSPJCC    # IMPORTANT NOT TO LOST THE CURRENT RECORD IN OBJECT GESTION
  [M:PJCC0] = [F:PJCC]
  [M:PJCC] = [F:PJCC]
  [M:PJCD] = [F:PJCC]  # Issue number - 2018-06-14 by FGR : PJCD nt PJCC now
  # Hybrid part (end)
  # ------------------------------------
Return

##########################################################################################################
$APRES_CRE
  Gosub RELIT From GOBJSUB
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
Return

##########################################################################################################
$MODIF
Local Integer MY_STATUS                          # Hybrid part

  # ------------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJCC.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # Hybrid part (end)
  # ------------------------------------
Return

##########################################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
Return

##########################################################################################################
$AV_ANNULE
Local Integer ANOWRITE  # Hybrid part

  # ------------------------------------
  # Hybrid part (begin)
  ANOWRITE = 1
  # Hybrid part (end)
  # ------------------------------------
Return

##########################################################################################################
$ANNULE
Local Integer MY_STATUS                          # Hybrid part

  # ------------------------------------
  # Hybrid part (begin)
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJCC.ADELETE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # Hybrid part (end)
  # ------------------------------------
Return

##########################################################################################################
##########################################################################################################
# SUBROUTINES
##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer MY_STATUS
Local Integer NI
Local Integer ILINE

  # ------------------------------------
  For NI = 1 To maxtab(GZINSPJCC.DATRATE)
    If GZINSPJCC.DATRATE(NI) <> null and find(GZINSPJCC.DATRATE(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJCC.DATRATE(NI).AUUID), [M:PJCC]AUUID(0..[M:PJCC]NBPCC-1))
      If ILINE = 0 Then
        ILINE = find(GZINSPJCC.DATRATE(NI).PCCDATCST, [M:PJCC]PCCDATCST(0..[M:PJCC]NBPCC-1))
      Endif
      If ILINE = 0 Then
        [L]MY_STATUS = fmet GZINSPJCC.ADELLINE("DATRATE", GZINSPJCC.DATRATE(NI).AORDER)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------------------------
  For NI = 1 To maxtab(GZINSPJCC.COSTGRP)
    If GZINSPJCC.COSTGRP(NI) <> null and find(GZINSPJCC.COSTGRP(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJCC.COSTGRP(NI).AUUID), [M:PJCC1]AUUID(0..[M:PJCC1]NBPCG-1))
      If ILINE = 0 Then
        ILINE = find(func GET_KEYCONCAT_VALUE(GZINSPJCC.COSTGRP(NI).PCGTYP, GZINSPJCC.COSTGRP(NI).PCGGRPMAT, GZINSPJCC.COSTGRP(NI).PCGGRPLAB, GZINSPJCC.COSTGRP(NI).PCGGRPMAC),
&                    [M:PJCC1]KEYCONCAT(0..[M:PJCC1]NBPCG-1))
      Endif
      If ILINE = 0 Then
        [L]MY_STATUS = fmet GZINSPJCC.ADELLINE("COSTGRP", GZINSPJCC.COSTGRP(NI).AORDER)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------------------------
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN()

Local Integer MY_STATUS
Local Integer NI
Local Integer INOLIGN

  # ------------------------------------
  Call SHOW_HEADER()
  # ------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJCC.DATRATE)
    # ------------------------------------
    If GZINSPJCC.DATRATE(NI) <> null and find(GZINSPJCC.DATRATE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_DATRATE_LINE(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:PJCC]NBPCC = nolign
  # ------------------------------------
  [L]MY_STATUS = func CDIE_CLASS_TO_SCREEN(GZINSPJCC, "PJCD", "NBRDIE", "SUBPJCC", INOLIGN)  # Issue number - 2018-06-14 by FGR : PJCD nt PJCC now
  [M:PJCD]NBRDIE = INOLIGN
  # ------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJCC.COSTGRP)
    # ------------------------------------
    If GZINSPJCC.COSTGRP(NI) <> null and find(GZINSPJCC.COSTGRP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_COSTGRP_LINE(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:PJCC1]NBPCG = nolign
  # ------------------------------------
End

##########################################################################################################
Subprog SHOW_HEADER()

  SetInstance [M:PJCC0] With GZINSPJCC
  SetInstance [M:PJCC] With GZINSPJCC
End

##########################################################################################################
Subprog SHOW_DATRATE_LINE(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJCC]15 With GZINSPJCC.DATRATE(VNLINE)
  [M:PJCC]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_COSTGRP_LINE(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJCC1]15 With GZINSPJCC.COSTGRP(VNLINE)
  Call LOAD_KEYCONCAT(nolign-1, [M:PJCC1]PCGTYP(nolign-1), [M:PJCC1]PCGGRPMAT(nolign-1), [M:PJCC1]PCGGRPLAB(nolign-1), [M:PJCC1]PCGGRPMAC(nolign-1))
  [M:PJCC1]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  Call MANAGE_COST_GROUPS(nolign-1)
  Affzo [PJCC1]1-99
End

##########################################################################################################
$CDIE_TRANS_SCREEN_TO_CLASS
  SetInstance POBJECT.CDIE(ILINE) With [M:PJCD]35  # Issue number - 2018-06-14 by FGR : PJCD nt PJCC now
Return

##########################################################################################################
$CDIE_TRANS_CLASS_TO_SCREEN
  SetInstance [M:PJCD]35 With POBJECT.CDIE(ILINE)  # Issue number - 2018-06-14 by FGR : PJCD nt PJCC now
Return

##########################################################################################################
Subprog MANAGE_COST_GROUPS(INOLIGN)
Value Integer INOLIGN

  Case [M:PJCC1]PCGTYP(INOLIGN)
    When 1
      Actzo [M:PJCC1]PCGGRPMAT(INOLIGN)
      Diszo [M:PJCC1]PCGGRPLAB(INOLIGN)
      Diszo [M:PJCC1]PCGGRPMAC(INOLIGN)
    When 2
      Diszo [M:PJCC1]PCGGRPMAT(INOLIGN)
      Actzo [M:PJCC1]PCGGRPLAB(INOLIGN)
      Diszo [M:PJCC1]PCGGRPMAC(INOLIGN)
    When 3
      Diszo [M:PJCC1]PCGGRPMAT(INOLIGN)
      Diszo [M:PJCC1]PCGGRPLAB(INOLIGN)
      Actzo [M:PJCC1]PCGGRPMAC(INOLIGN)
  Endcase
End

##########################################################################################################
Subprog LOAD_KEYCONCAT(INOLIGN, IPCGTYP, IPCGGRPMAT, IPCGGRPLAB, IPCGGRPMAC)
Value Integer INOLIGN
Value Integer IPCGTYP
Value Integer IPCGGRPMAT
Value Integer IPCGGRPLAB
Value Integer IPCGGRPMAC

  [M:PJCC1]KEYCONCAT(INOLIGN) = func GET_KEYCONCAT_VALUE(IPCGTYP, IPCGGRPMAT, IPCGGRPLAB, IPCGGRPMAC)
End

##########################################################################################################
Funprog GET_KEYCONCAT_VALUE(IPCGTYP, IPCGGRPMAT, IPCGGRPLAB, IPCGGRPMAC)
Value Integer IPCGTYP
Value Integer IPCGGRPMAT
Value Integer IPCGGRPLAB
Value Integer IPCGGRPMAC

Local Char SARENDRE(250)

  SARENDRE = num$(IPCGTYP) + "~" + num$(IPCGGRPMAT) + "~" + num$(IPCGGRPLAB) + "~" + num$(IPCGGRPMAC)
End SARENDRE

##########################################################################################################
Funprog CDIE_CLASS_TO_SCREEN(POBJECT, VAMK, VABS, VSCRIPT, INOLIGN)
Variable Instance POBJECT Using OBJECT
Value Char VAMK
Value Char VABS
Value Char VSCRIPT
Variable Integer INOLIGN

Local Integer ARENDRE
Local Char SABRAMK(250)
Local Char SFIELD(250)
Local Integer ISVNOLIGN
Local Integer ILINE
Local Integer ISTEP

  # Call in $LIENS
  ARENDRE = [V]CST_AOK
  # ------------------------------------
  If dim(POBJECT.CDIE) > 0 and VAMK <> "" and VABS <> "" Then
    # There is a collection of analytical axes in the class
    # ------------------------------------------------------
    If left$(VAMK,1) = "[" Then
      SABRAMK = VAMK
    Else
      SABRAMK = "[M:" + VAMK + "]"
    Endif
    # ------------------------------------
    SFIELD = SABRAMK + VABS
    ISVNOLIGN = nolign
    # ------------------------------------------------------
    nolign = 0
    For ILINE = 1 To maxtab(POBJECT.CDIE)
      # ------------------------------------
      If POBJECT.CDIE(ILINE) <> null and find(POBJECT.CDIE(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        nolign += 1
        # ------------------------------------
        If VSCRIPT <> "" and 0=1 Then
          Gosub CDIE_TRANS_CLASS_TO_SCREEN From =VSCRIPT
        Else
          Assign SABRAMK + "DIE(" + num$(nolign-1) + ")" With POBJECT.CDIE(ILINE).DIE
          Assign SABRAMK + "CCE(" + num$(nolign-1) + ")" With POBJECT.CDIE(ILINE).CCE
          Assign SABRAMK + "CHX(" + num$(nolign-1) + ")" With POBJECT.CDIE(ILINE).CHX   # Issue X3-4848/119127 - 2016-10-14 by FGR
          Assign SABRAMK + "COLLIN(" + num$(nolign-1) + ")" With ILINE
        Endif
        # ------------------------------------
      Endif
      # ------------------------------------
    Next ILINE
    # ------------------------------------
    If nolign-1 >= 0 Then
      Assign SFIELD With nolign-1
    Else
      Assign SFIELD With 0
    Endif
    # ------------------------------------------------------
    INOLIGN = nolign
    nolign = ISVNOLIGN
  Endif
End ARENDRE

##########################################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
Variable Instance GZINSPJCC Using C_PJMCOSTCTR

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE

  # ------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSPJCC, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  MY_STATUS = fmet GZINSPJCC.ADELETERRORALL()
  # Hybrid part (end)
  # ------------------------------------
End

##########################################################################################################
##########################################################################################################
# Screens fields
##########################################################################################################
# PJCC0
##########################################################################################################
##########################################################################################################
Subprog AM_PCCFCY(VALEUR)
Variable Char    VALEUR()

  # -----------------------------
  GZINSPJCC.PCCFCY = VALEUR
  # -----------------------------
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
  # -----------------------------
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call COPY_CLASS_TO_SCREEN()
  Endif
  # -----------------------------
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCD]1-99   # Issue X3-4848/119127 - 2016-10-14 by FGR
  Affzo [M:PJCC]1-99
End

##########################################################################################################
Subprog AP_PCCFCY(VALEUR)
Variable Char    VALEUR()

Local Integer ISTATUT

  # -----------------------------
  # To manage the case of PCCFCY empty when create a new cost type
  If GREP = "C" Then
    If (VALEUR = AVOID.ACHAR and [M:PJCC0]PCCFCY = AVOID.ACHAR) Then
      GZINSPJCC.PCCFCY = VALEUR
      # -----------------------------
      GZINSPJCC.TCHNODIEEXE = [V]CST_ANO
      ISTATUT = fmet GZINSPJCC.CDIE_ERASE_COLLECTION()
      If ISTATUT = [V]CST_AOK Then
        ISTATUT = fmet GZINSPJCC.CDIE_INIT()
      Endif
      # -----------------------------
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
      # -----------------------------
      If GERR = 1 Then
        GERR = 1
        mkstat = 2
        End
      Else
        Call COPY_CLASS_TO_SCREEN()
      Endif
      # -----------------------------
      Affzo [M:PJCC0]1-99
      Affzo [M:PJCD]1-99   # Issue X3-4848/119127 - 2016-10-14 by FGR
      Affzo [M:PJCC]1-99
    Endif
  Endif
End

##########################################################################################################
Subprog AM_PCCGRP(VALEUR)
Variable Char    VALEUR()

  GZINSPJCC.PCCGRP = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_HEADER()
  Endif
  # ------------------------------------
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
End

