##########################################################################################################
Subprog AM_PCCCUR(VALEUR)
Variable Char    VALEUR()

Local Integer IRET

  GZINSPJCC.PCCCUR = VALEUR
  IRET = fmet GZINSPJCC.DATRATE_CONVERT()
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_HEADER()
  Endif
  # -----------------------------
  Affzo [M:PJCC0]1-99
  Affzo [M:PJCC]1-99
End

