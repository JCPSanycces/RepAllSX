##########################################################################################################
# PJCC1
##########################################################################################################
##########################################################################################################
Subprog C_NBPCG
Local Integer IRET
Local Integer ILINE

  # ------------------------------------
  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJCC1]PCGTYP(nolign-1) = 0 Then
      ILINE = fmet GZINSPJCC.ADDLINE("COSTGRP", [V]CST_ALASTPOS)
      # ------------------------------------
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_COSTGRP_LINE(ILINE)
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJCC1]
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJCC.ADELLINE("COSTGRP", GZINSPJCC.COSTGRP([M:PJCC1]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJCC)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_PCGTYP(VALEUR)
Variable Integer VALEUR

  GZINSPJCC.COSTGRP([M:PJCC1]COLLIN(nolign-1)).PCGTYP = VALEUR
  # -----------------------------
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJCC)
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_COSTGRP_LINE([M:PJCC1]COLLIN(nolign-1))
  Endif
  Call LOAD_KEYCONCAT(nolign-1, VALEUR, [M:PJCC1]PCGGRPMAT(nolign-1), [M:PJCC1]PCGGRPLAB(nolign-1), [M:PJCC1]PCGGRPMAC(nolign-1))
  Call MANAGE_COST_GROUPS(nolign-1)
End

