#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ARCHGENTRT","ARCHGENTRT",3,"XYARCHGENTRT") From GTRAITE
End

#----------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "EXEC"        : Gosub EXEC
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#----------------------------------------#
$INIT
Local Char    MACHINE(250) , APPLI(250) , HISDOS(250) , APPGEN(250) , DOSGEN(250) , REPERT(250)
Local Char    TRTADX(GLONADC)(1..30000)
Local Integer NBTRTADX , NBTRTSTC
Local Char    MESSAGE(250) , ORDSYS(250)(1..2) , VERSION(20) , VERCUR(20) , COMMAND(250)
Local Integer STAT , K , OK , ER , SRVBAT
Gosub OUVRE_FIC
TMP = 1
TRA = 1
Return

#----------------------------------------#
$OUVRE_FIC
$OUVRE_BATCH
#109897
#Local File ABATPAR [ABP] , ADOSSIER [ADS]
Local File ADOSSIER [ADS]
Return

#----------------------------------------#
$CONTROLE
$CONT_BATCH
If [M]DOSSIER="" : SAI = 1 : Return : Endif

Return

#----------------------------------------#
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(216,139,1)-[M]DOSSIER) From LECFIC : # Génération de l'archive
Endif

# Vérification numéro de version
Call VERSACH([M]DOSSIER,VERSION) From SUBADC
Call VERSACH(nomap,VERCUR) From SUBADC
If VERCUR<>VERSION
 If !GSERVEUR
  # La version de l'archive du dossier # est différente du celle du dossier courant
  # Voulez-vous passer de $1$ à $2$
  Call AVERTIR(func AFNC.MES(mess(197,115,1),[M]DOSSIER)+"\"+func AFNC.MES2(mess(198,115,1),VERSION,VERCUR),OK) From GESECRAN
  If OK<>2 : Goto FIN : Endif
 Else
  # La version de l'archive du dossier # est différente du celle du dossier courant
  Call ECR_TRACE(func AFNC.MES(mess(197,115,1),[M]DOSSIER),1) From GESECRAN
  Goto FIN
 Endif
Endif

Local Char WVALEUR(250) : [L]WVALEUR = [M]DOSSIER
Gosub DEFDOSX3

# Est-ce l'appli serveur batch ?
SRVBAT = 0
#109897
#Read [ABP] First
#If !fstat & [F:ABP]APPLI<>"" & [F:ABP]APPLI=[M]DOSSIER
# If filinfo(filpath("TRT","","",[F:ABP]APPLI),0)>0
#  Read [ADS]DOSSIER=[F:ABP]APPLI
#  If fstat
#   APPLI = [M]DOSSIER
#   MACHINE = ""
#   SRVBAT = 1
#  Endif
# Endif
#Endif
If !SRVBAT
 Call MACHINE([M]DOSSIER,MACHINE,APPLI) From ORDSYS
 If APPLI<>nomap or MACHINE<>adxmac(0)
  Call MONO([M]DOSSIER,OK) From DOSSUB
 Else
  Call MONO(OK) From AX3MONO
 Endif
 If !OK : Goto FIN : Endif
Endif

# Présence d'un dossier histo
If !SRVBAT
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat
  HISDOS  = [F:ADW]VALEUR
 Endif
Endif

For APPGEN=APPLI,HISDOS

 If APPGEN="" : Break : Endif

 If MACHINE<>""
  DOSGEN = MACHINE+"@"+APPGEN
 Else
  DOSGEN = APPGEN
 Endif

 #  Création du répertoire STC si inexistant
 CHEMIN = filpath("STC","","",DOSGEN)
 If filinfo(CHEMIN,0)<=0
  Call MACHINE(CHEMIN,MACHINE,REPERT) From ORDSYS
  If MACHINE<>""
   ORDSYS = MACHINE+"@"
  Else
   ORDSYS = ""
  Endif
  ORDSYS += 'ae_mkdir'-'"'+REPERT+'"'
  System COMMAND=ORDSYS
  If filinfo(CHEMIN,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+CHEMIN,1) From GESECRAN
  Endif
 Endif

 # Vérification existence stc
 ORDSYS(1) = "lsadx -a "+APPGEN+" STC adx"
 Call SYSTEME2(MACHINE,ORDSYS,"",NBTRTSTC,TRTADX) From ORDSYS

 # Vérification existence adx
 ORDSYS(1) = "lsadx -a "+APPGEN+" TRT adx"
 Call SYSTEME2(MACHINE,ORDSYS,"",NBTRTADX,TRTADX) From ORDSYS

 # Trace ordre système
 ORDSYS(2) = filpath("tmp","archive_gen","tra",APPGEN,"",MACHINE)

 # Suppression de l'archive
 Call ECR_TRACE("folder"-APPGEN-":"-mess(161,7900,1),0) From GESECRAN : # # Suppression de l'archive
 Call EFFACE(filpath("","atx","ind",APPGEN,"",MACHINE),STAT) From ORDSYS
 If filinfo(filpath("","atx","ind",APPGEN,"",MACHINE),0)>0
  # mb 29.2.12 Sous windows, ce fichier est ouvert en écriture dès l'ouverture de session et il ne peut pas être supprimé
  Openo filpath("","atx","ind",APPGEN,"",MACHINE),0 Using [OUT_]
  Wrseq "" Using [OUT_]
  Openo Using [OUT_]
 Endif

 # Création version de l'archive
 ORDSYS(1) = 'archive -n -f -d'-APPGEN
 Call EFFACE(ORDSYS(2),STAT) From ORDSYS
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS

 # Création de l'archive des traitements
 Call ECR_TRACE("folder"-APPGEN-":"-mess(264,139,1)-"("+mess(44,115,1)+")",0) From GESECRAN : # Intégration dans l'archive
 ORDSYS(1) = 'archive -d'-APPGEN-'-t'-'-c "*"'
 Call EFFACE(ORDSYS(2),STAT) From ORDSYS
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Gosub ERREUR

 # Création de l'archive des classes
 Call ECR_TRACE("folder"-APPGEN-":"-mess(264,139,1)-"("+mess(8,140,1)+")",0) From GESECRAN : # Intégration dans l'archive
 ORDSYS(1) = 'archive -d'-APPGEN-'-o'-'-c "*"'
 Call EFFACE(ORDSYS(2),STAT) From ORDSYS
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Gosub ERREUR

 # Visualisation version
 Call VERSACH(DOSGEN,MESSAGE) From SUBADC
 Call ECR_TRACE("folder"-APPGEN-":"-MESSAGE,(VERSION<>VERSION)*-1) From GESECRAN

 # Résultat
 Call ECR_TRACE("folder"-APPGEN-":"-num$(NBTRTADX)-mess(44,115,1),0) From GESECRAN : # Traitement (adx)
 Call ECR_TRACE("folder"-APPGEN-":"-num$(NBTRTSTC)-mess(8,140,1),0) From GESECRAN : # Classe (stc)

Next APPGEN

If !SRVBAT
 If APPLI<>nomap or MACHINE<>adxmac(0)
  Call MULTI([M]DOSSIER) From DOSSUB
 Else
  Call MULTI(OK) From AX3MONO
 Endif
Endif

If DOSARC=DOSX3
 Call ECR_TRACE(mess(00213,00125,1),-1) From GESECRAN : # CES MODIFICATIONS NE SERONT PRISES EN COMPTE QU’APRÈS RECONNEXION À CE DOSSI
Endif

#----------------------------------------#
$FIN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#----------------------------------------#
$ERREUR
Openi ORDSYS(2) Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Iomode adxium GUTF8 Using [TR_]
K = 0
Rdseq MESSAGE Using [TR_]
While !fstat
 If !K
  Call ECR_TRACE(mess(6,123,1)-"|"+ORDSYS(1),1) From GESECRAN : # Erreur
  K = 1
 Endif
 Call ECR_TRACE(MESSAGE,0) From GESECRAN
 Rdseq MESSAGE Using [TR_]
Wend
Openi Using [TR_]
Return

####################################################################################
# Mise à jour archive dossiers historisés sur validation de dossier
####################################################################################

Subprog VALARCHIVE_HISTO(DOSSIER)
Value Char DOSSIER

Local Integer STAT
Local Char    HISAPP(250) , MACHINE(80) , APPLI(50) , DOSHIS(250)
Local Char    CHEMIN(250) , REPERT(250) , ORDSYS(250)(1..2) , COMMAND(250) , REP(10)

# Présence d'un dossier histo
HISAPP = ""
Local File =DOSSIER+".ADOVAL" [ADWX_]
Read [ADWX_]ADW0 = "";"";"HISDOS"
If !fstat
 HISAPP  = [F:ADWX_]VALEUR
Endif
If HISAPP=""
 End
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
If MACHINE<>""
 DOSHIS = MACHINE+"@"+HISAPP
Else
 DOSHIS = HISAPP
Endif

ORDSYS(1) = 'archive -d'-HISAPP-'-o'-'-e "*"'
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
ORDSYS(1) = 'archive -d'-HISAPP-'-t'-'-e "WM*"'
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS

#  Supp/Création du répertoire STC
For REP="STC","TRT"
 CHEMIN = filpath(REP,"","",DOSHIS)
 Call MACHINE(CHEMIN,MACHINE,REPERT) From ORDSYS
 If filinfo(CHEMIN,0)>0 & REP="STC"
  If MACHINE<>""
   ORDSYS = MACHINE+"@"
  Else
   ORDSYS = ""
  Endif
  ORDSYS += 'ae_rmdir'-'"'+REPERT+'"'
  System COMMAND=ORDSYS
 Endif
 If filinfo(CHEMIN,0)<=0
  If MACHINE<>""
   ORDSYS = MACHINE+"@"
  Else
   ORDSYS = ""
  Endif
  ORDSYS += 'ae_mkdir'-'"'+REPERT+'"'
  System COMMAND=ORDSYS
  If filinfo(CHEMIN,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+CHEMIN,1) From GESECRAN
  Else
   Call ECR_TRACE(mess(11,125,1)-"|"+CHEMIN,0) From GESECRAN : # Création du répertoire
  Endif
 Endif
Next REP

Call CRE_CLASS_OBJECT(DOSHIS) From DOSAPL

End

#----------------------------------------#
$TRACE
Openi ORDSYS(2) Using [TR_]
Openo filpath("TRA",GTRACE,"tra") Using [TW_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Iomode adxium GUTF8 Using [TR_]
Iomode adxifs "" Using [TW_]
Iomode adxirs chr$(10) Using [TW_]
Iomode adxium GUTF8 Using [TW_]
Rdseq MESSAGE Using [TR_]
While !fstat
 Wrseq MESSAGE Using [TW_]
 Rdseq MESSAGE Using [TR_]
Wend
Openi Using [TR_]
Openo Using [TW_]
Return

#----------------------------------------#
$SEL_LISTE
Case LISTE
 When "ASELARCH"
  Gosub SEL_ADS From SUBADS
#109897
#  If clalev([F:ABP])=0 : Local File ABATPAR  [ADP] : Endif
#  Read [ABP] First
#  If !fstat & [F:ABP]APPLI<>"" & filinfo(filpath("TRT","","",[F:ABP]APPLI),0)>0
#   If !find([F:ABP]APPLI,TEX(1..NBTEX))
#    NBTEX += 1
#    TEX(NBTEX) = [F:ABP]APPLI
#    TEXTE(NBTEX,2) = mess(0,134,1) : # Serveur batch
#   Endif
#  Endif
Endcase
Return

#----------------------------------------#
Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
GMODIF = 0
End

Subprog AS_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

$DEFDOSX3
Local Char    MACARC(GDIMFIC) , DOSARC(GDIMFIC)
Local Char     DOSX3(GLONADS)
Local Integer K , OK , SRVBAT
K = instr(1,WVALEUR,"@")
If K
 MACARC = left$(WVALEUR,K-1)
 DOSARC = right$(WVALEUR,K+1)
Else
 MACARC = ""
 DOSARC = WVALEUR
Endif
If MACARC=""
 DOSX3 = GDOSX3
Else
 Local File =WVALEUR+".ADOVAL" [ADW_]
 Read [ADW_]ADW0="";"";"SUPDOS"
 If !fstat : DOSX3 = [F:ADW_]VALEUR : Endif
 Close Local File [ADW_]
Endif
Return

Subprog C_DOSSIER(VALEUR)
Variable Char VALEUR
Local Char WVALEUR(250) : WVALEUR = VALEUR
Gosub DEFDOSX3
If DOSARC=DOSX3
 # Dossier racine\Voulez-vous continuer ?
 Call AVERTIR(VALEUR-":"-mess(222,139,1)+"\"+mess(205,100,1),OK) From GESECRAN
 If OK<>2 : mkstat = 1 : End : Endif
Elsif DOSARC=nomap
 Call ERREUR(VALEUR-":"-mess(112,125,1)) From GESECRAN : # Opération impossible sur ce dossier
 mkstat = 1  : End
Endif
SRVBAT = 0
#109897
#Read [ABP] First
#If !fstat & [F:ABP]APPLI<>"" & [F:ABP]APPLI=VALEUR
# If filinfo(filpath("TRT","","",[F:ABP]APPLI),0)>0
#  Read [ADS]DOSSIER=[F:ABP]APPLI
#  If fstat
#   SRVBAT = 1
#  Endif
# Endif
#Endif
If !SRVBAT
 Call C_DOSSIER(VALEUR) From DOSCONT
 If mkstat : End : Endif
 Local Char    PARAM(250)(1..2)
 PARAM(1) = VALEUR
 PARAM(2) = GUSER
 Call SAISIE_CHAR(VALEUR,PARAM,"APASSWD","APASSWD","") From GSAISIE
Endif
End

Subprog AS_OPTION(VALEUR)
Variable Integer VALEUR
If [M]DOSSIER="" : zonsui = "DOSSIER" : Endif
End

