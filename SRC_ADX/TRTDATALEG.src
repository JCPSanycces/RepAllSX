#<AdxTL>@(#)2.0.0.0 $Revision$

#------------------------------------------------------------#
# Subprog DATALEG
#
# Used to define legal datas for each localisation
#
# This action is called in the following functions:
# -GESCPY Companies
# -GESTVB BP Tax rule
# -GESTVT Taxes
#
#------------------------------------------------------------#

Subprog DATALEG(LEG,COD)
Value    Char    LEG
Value    Char    COD

If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif

Local Integer GOON : GOON=0
Local Integer NBRW : NBRW=0
Local Char LSTW(GLONFEN)(0..GNBLEG-1)

Local Char TABVAL(GLONAX3)(0..GNBLEG-1,1..4)
Local Char INTIT(GLONAX3)

Local Integer X
Local Char SV(50) :# Search Value

Local Char WINLEG(GLONFEN)
Local Char PROGLEG(GLONADC)

Case  GFONCTION
  When "GESCPY" :
  Call LEC_CPY([L]COD) From CPTLEC
  If [F:CPY]CPYLEGFLG=1
   #------------- AGF Group AGC -------------
   SV="[F:ADI]A7"
   If clalev([F:AGC])=0  : Local File AGRPCPY [AGC]  : Endif
     If clalev([F:CPY2])=0 : Local File COMPANY [CPY2] : Endif
   Filter [AGC] Where GRP=[L]COD
   Read [AGC]AGC0 First
   If !fstat
    Read [CPY2]CPY0 = [F:AGC]CPY
    If !fstat
     [L]LEG=[F:CPY2]LEG
    Endif
   Endif
   Filter [AGC]
  Else
   #------------- CPY -------------
   SV="[F:ADI]A1"
  Endif
  When "GESTVT" : SV="[F:ADI]A3"
  When "GESTVB" : SV="[F:ADI]A5"
Endcase

If [L]LEG<>""
 fstat = 0
 If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>[L]LEG
  Read [ADI]CODE = 959;[L]LEG
 Endif
 If !fstat
  If [F:AWI]WIN<>evalue(SV)
   Read [AWI]AWI0 = evalue(SV)
  Endif
  If !fstat
   GOON = 1
   LSTW(NBRW)=evalue(SV)
   NBRW = 1
  Endif
 Endif
Else
 # When you come from GESTVB or GESTVT, LEG can be empty
 # then you have to use an existing window of another legislation
 # set in the miscelleanous table 959. So we provide here  a screen to
 # choose a LEG/Window, meaning the fields you want to set-up...

 Filter [ADI] Where NUMTAB=959 & evalue(SV)<>""
 For [ADI]CODE
  fstat = 0
  If [F:AWI]WIN<>evalue(SV)
   Read [AWI]AWI0 = evalue(SV)
  Endif
  If !fstat
   X = find(evalue(SV),LSTW(0..NBRW))
   If !X
    TABVAL(NBRW,1)=[F:ADI]CODE
    Call LECTEXTRA(INTIT,"ATABDIV","LNGDES","909",[F:ADI]CODE) From ATEXTRA
    TABVAL(NBRW,2)=INTIT
    TABVAL(NBRW,3)=evalue(SV)
    LSTW(NBRW)=evalue(SV)
    NBRW+=1
   Else
    TABVAL(X-1,1)+="/"+[F:ADI]CODE
    #mess(00034,00190,1) : Multiple
    #mess(218,107,1) : # Législation
    TABVAL(X-1,2)=mess(34,190,1)-mess(218,107,1)+"s"
   Endif
  Endif
 Next
 Filter [ADI]
 If NBRW>=1
  GOON=1
 Endif
Endif

If GOON
 If NBRW=1
  WINLEG  = LSTW(0)
  PROGLEG = "TRT"+LSTW(0)
 Elsif  NBRW>1

  Local Char TIT(20)(1..4)
  Local Integer CHOICE

  TIT(1)=mess(218,107,1) : # Législation
  TIT(2)=mess(218,107,1) : # Législation
  TIT(3)=mess(30,109,1)  : # Intitulé
  TIT(4)=mess(14,126,1)  : # Fenêtre
  Call SAITEX_COL_MAX(NBRW,TABVAL,CHOICE,TIT,100,50) From GESECRAN
  If CHOICE
   WINLEG  = LSTW(CHOICE-1)
   PROGLEG = "TRT"+LSTW(CHOICE-1)
  Else
   #Cancel/Annuler => Quit
   End
  Endif
 Endif

 If WINLEG<>""
  Local Char PARAM(20)(1..2) , VALEUR(10)
  PARAM(1)=[L]LEG
  PARAM(2)=[L]COD
  Call SAISIE_CHAR(VALEUR,PARAM,WINLEG,PROGLEG,"") From GSAISIE
 Endif
Endif
End

