#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################################
# UTIVEN16                                                                  Module VENTE            #
#                                                                             28/02/2013            #
# Concerne le bug 88325 :                                                                           #
# Création d'un devis avec ACTSAD=1 :                                                               #
#    Si GACTSAD=1, le champ BPAORD (code adresse du client commande) n'est pas alimenté						  #
#		 en création de devis.																																					#
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Si le champ BPAORD est vide, il sera initialisé avec le code adresse par défaut du client cde  #
#                                                                                                   #
#####################################################################################################



Call MAJ_UTIVEN16
End


Subprog MAJ_UTIVEN16
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVEN16 - Sales Quote Process : Update SQUOTE") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN16 - Sales Quote Process : Update SQUOTE") From LECFIC
  Call EXE_UTIVEN16(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVEN16(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIVEN16 : Start folder's process"-DOSSIER) From DOSSUB

#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#
Gosub TRT_SQH    : # Traitement des devis
#----- Fin du traitement -----#

$FIN_UTIVEN16
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIVEN16 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Initialisation BPAORD code adresse du client commande        #
# -------------------------------------------------------------- #
# Table SQUOTE   - Entête devis                                  #
#   BPAORD         Code adresse client commande (BPCORD)         #
#----------------------------------------------------------------#
$TRT_SQH
If filinfo(filpath("FIL","SQUOTE","fde", DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UTIVEN16 : Sales Quote Process : Update SQUOTE") From DOSSUB
Local File =DOSSIER+".SQUOTE"     [SQH]
Local File =DOSSIER+".BPCUSTOMER" [BPC]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(GLONSQH), CRITERE(100)

$B_TRT_SQH
If  STOP=1
    CRITERE = '[F:SQH]BPAORD="" & [F:SQH]SQHNUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "[F:SQH]BPAORD=''"
Endif
# Pour test
GMAXUPDTRS=5
#CRITERE = 'find(SQHNUM,"S1NM1012SQH00000003","S1NM1012SQH00000002")'

Raz COMPTEUR

Trbegin [SQH]
  For [SQH] SQH0 Where evalue(CRITERE)

    Read [BPC]BPC0=[F:SQH]BPCORD
    If fstat Raz [F:BPC] Endif
    [F:SQH]BPAORD=[F:BPC]BPAADD
    Rewrite [SQH]
    If fstat
        Call ECR_TRACE("File SQUOTE"-[F:SQH]SQHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    NBENR+=1 : COMPTEUR+=1

    If COMPTEUR>GMAXUPDTRS CLE1=[F:SQH]SQHNUM : STOP=1 : Break : Endif
  Next
#Rollback :#--Test
Commit
If STOP Goto B_TRT_SQH : Endif

Close Local File [SQH]

Call ECR_TIME("UTIVEN16 : Sales Quote Process : Ended :"+"("-num$(NBENR)-")") From DOSSUB
Return


Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("UTIVEN16 - Sales Quote Process : Update SQUOTE",0) From GESECRAN
  Call EXE_UTIVEN16(DOSSIER)
Endif
#-----
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
Call EXE_UTIVEN16(APPLI)
Endif
End
