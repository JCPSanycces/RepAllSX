#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# SUBPQH : Gestion des appels d'offre demandes              HN 11/2002  #
# --------------------------------------------------------------------- #
# Création / Modification / Suppression des demandes d'appel d'offre    #
# Traitement des actions "Gosub" de l'objet "PQH"                       #
# Traitements sur champ  "Call"  de l'objet "PQH"                       #
#########################################################################
Raz GPILOBJ
Call OBJET("PQH",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
#---------------------------------#
# Actions de l'objet PQH (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"    : Gosub DEFTRANS       From SUBPQHA
 When "VARIANTE"    : Gosub VARIANTE       From SUBPQHA
 When "SETTRANS"    : Gosub SETTRANS       From SUBPQHA
 When "FILTRE"      : Gosub FILTRE         From SUBPQHA
 When "AV_IMPRIME"  : Gosub AV_IMPRIME     From SUBPQHA
 When "AP_IMPRIME"  : Gosub AP_IMPRIME     From SUBPQHA
 When "OUVRE"       : Gosub OUVRE          From SUBPQHA
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE    From SUBPQHA
 When "EXEACT"      : Gosub EXEACT         From SUBPQHA
 When "SETBOUT"     : Gosub SETBOUT        From SUBPQHA
 When "AVANTBOUT"   : Gosub AVANTBOUT      From SUBPQHA
 When "STATUT"      : Gosub STATUT         From SUBPQHA
 When "FILGAUCHE"   : Gosub FILGAUCHE      From SUBPQHA
 When "AP_FILGAUCHE": Gosub AP_FILGAUCHE   From SUBPQHA
#When "TIROIR"      : Gosub TIROIR         From SUBPQHA
 When "DEB_PICK"    : Gosub DEB_PICK       From SUBPQHA
 When "PICKE"       : Gosub PICKE          From SUBPQHA
 When "DEPICK"      : Gosub DEPICK         From SUBPQHA
 When "FIN_PICK"    : Gosub FIN_PICK       From SUBPQHA
 When "APRES_MODIF" : Gosub APRES_MODIF    From SUBPQHA
 When "DEFLIG"      : Gosub DEFLIG         From SUBPQHA
 When "LIENS_LIG"   : Gosub LIENS_LIG      From SUBPQHA
 When "INICRE_LIG"  : Gosub INICRE_LIG     From SUBPQHA
 When "INIMOD_LIG"  : Gosub INIMOD_LIG     From SUBPQHA
 When "VALLIG"      : Gosub VALLIG         From SUBPQHA
 When "RAZCRE"      : Gosub RAZCRE         From SUBPQHA
 When "RAZDUP"      : Gosub RAZDUP         From SUBPQHA
 When "LIENS"       : Gosub LIENS          From SUBPQHA
 When "VERIF_CRE"   : Gosub VERIF          From SUBPQHA
 When "VERIF_MOD"   : Gosub VERIF          From SUBPQHA
 When "INICRE"      : Gosub INICRE         From SUBPQHA
 When "CREATION"    : Gosub CREATION       From SUBPQHA
 When "APRES_CRE"   : Gosub APRES_CRE      From SUBPQHA
 When "AVANT_MODFIC": Gosub AVANT_MODFIC   From SUBPQHA
 When "INIMOD"      : Gosub INIMOD         From SUBPQHA
 When "MODIF"       : Gosub MODIF          From SUBPQHA
 When "APRES_MOD"   : Gosub APRES_MOD      From SUBPQHA
 When "ANNULE"      : Gosub ANNULE         From SUBPQHA
 When "AP_ANNULE"   : Gosub AP_ANNULE      From SUBPQHA
 When "ABANDON"     : Gosub ABANDON        From SUBPQHA
 When "FIN_ACTION"  : Gosub FIN_ACTION     From SUBPQHA
 When "FERME"       : Gosub FERME          From SUBPQHA
 When "AB4_NBLIG"   : Gosub SAUV_NBFOU
 When "BB4_NBLIG"   : Gosub ACTIV_GSTAENR
 When "AB3_NBFOU"   : Gosub AB3_NBFOU
 When "BB3_NBFOU"   : Gosub BB3_NBFOU
 When "AB4_NBFOU"   : Gosub AB4_NBFOU
 When "BB4_NBFOU"   : Gosub BB4_NBFOU
 When "AB5_NBFOU"   : Gosub SAUV_NBFOU
 When "BB5_NBFOU"   : Gosub ACTIV_GSTAENR
 When Default
Endcase
Return

######################################## ACTION SUR CHAMPS ####################################

Subprog AM_PQHFCY(VALEUR)
#---------------------------------------#
# Site non modifiable si réponse existe #
#---------------------------------------#
Variable Char    VALEUR()
If GREP <> "C" & GREP <> "D"
  If [F:PQH]RSPNBR <> 0
    GERR=1 : GMESSAGE=mess(35,194,1)
    mkstat=1
    End
  Endif
Endif
Local Char ANCSOC(GLONCPY) : ANCSOC=GSOCIETE
If GFCY<>VALEUR
  GFCY=VALEUR
  Gosub CHARG_PARAM From SUBPQHA
  If GMESSAGE<>""
    GSOCIETE=ANCSOC : GFCY=[M:PQH1]PQHFCY
    Gosub CHARG_PARAM From SUBPQHA
    GERR=1 : mkstat=1 : End
  Endif
Endif
#-- Remplissage du tableau liste fournisseurs de l'écran PQH1 si changement société --#
If GSOCIETE<>ANCSOC & [M:PQH1]NBFOU>0
  For I=0 To [M:PQH1]NBFOU-1
    Call CTLBPRCPY([M:PQH1]BPSNUM(I),GFCY) From CONTX3
    If mkstat
      # Tiers non autorisé pour cette société
      GERR=1 : GMESSAGE=[M]BPSNUM(I)-mess(29,104,1)
      GSOCIETE=ANCSOC : GFCY=[M:PQH1]PQHFCY
      Gosub CHARG_PARAM From SUBPQHA
      mkstat=1 : Break
    Endif
  Next
  If mkstat  End : Endif
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPQHA
End

Subprog AS_PQHNUM(VALEUR)
#---------------------------#
# Avant saisie numéro d'AOF #
#---------------------------#
Variable Char     VALEUR
If (GREP = "C" | GREP = "D") & GMANCOU <> 2 : mkstat = 2 : Endif
End

Subprog C_PQHNUM(VALEUR)
#---------------------------#
# Contrôle sur numéro d'AOF #
#---------------------------#
Variable Char    VALEUR()
#-------- Compteur manuel, numéro obligatoire ! --------#
# If GMANCOU=2 & VALEUR="" GMESSAGE=mess(182,199,1) : mkstat=1 : End : Endif
#----- Rien d'affiché, vérif si un enregistrement existe -----#
If [M:PQH1]PQHNUM="" & GREP<>"C"
   Look [PQH] PQH0=VALEUR
   If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
#----- En création ou dupli et cteur manuel, contrôle si no existe déja -----#
If (GREP<>"C" & GREP<>"D") | GMANCOU<>2 End : Endif
VALEUR=vireblc(VALEUR,2)
Look [PQH] PQH0=VALEUR
If fstat End : Endif
GMESSAGE=mess(22,100,1) : mkstat=1
End

Subprog AM_RSPDEA(VALEUR)
#--------------------------------------------------#
# Contrôle date limite                             #
# Ne doit pas être inférieure à la date de demande #
#--------------------------------------------------#
Variable Date    VALEUR
If VALEUR < [M:PQH1]PQHDAT
 mkstat = 1
 GMESSAGE = mess(1,104,1)
Endif
End

Subprog C_REQUSR(VALEUR)
#--------------------------------#
# Contrôle demandeur ou acheteur #
#--------------------------------#
Variable Char    VALEUR()
If GPQHBUY=2 & GBUYFLT=2 & VALEUR="" mkstat=1 : Endif
End

Subprog IB_NBLIG
#----------------------------#
# initialisation des boutons #
#----------------------------#
Local Integer NOL : NOL=nolign-1
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
Raz [F:PSD]
GBOUT9 = mess(164,198,1)               : # Situation ligne
If [M:PQH1]NBLIG = 0 | [M:PQH1]ITMREF(NOL) = "" : End : Endif
If GPQH_VERROU | GREP="C"
  GBOUT2 = mess (388,198,1)    : # Duplication ligne
Endif
GBOUT3 = mess (38,198,1)                      : # Texte
Filter [ITP] Where ITMREF=[M:PQH1]ITMREF(NOL) & BPSNUM<>""
Read [ITP]ITP0 First
Filter [ITP]
If !fstat
  GBOUT4 = mess (243,194,1)-[M:PQH1]ITMREF(NOL) : # Fournisseur de l'article
Else
  Raz GBOUT4
Endif
If [M:PQH1]RETQTYSTU(NOL)>0 & [M:PQH1]PSHNUM(NOL)<>""
  GBOUT5=mess(448,198,1)                      : # Visualisation DA pickées
Endif
If find(GREP,"C","D") or find("CONSPIA",GNAVIG(1..GPILNAV)) Then Raz GBOUT8 Endif # SYMEU 09/12/2008 : branchement traçabilité pièces
End

Subprog AVANT_NBLIG
#-------------#
# Avant NBLIG #
#-------------#
Local Integer NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If dim([M:PQH1]ITMREF)<nolign+1
  GERR = 1 : GMESSAGE = mess(122,199,1) : mkstat = 1 : End
Endif
#----- Si suppression d'une ligne -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  If [M:PQH1]CREFLG(NOL)=0 & left$([M:PQH1]LINTEX(NOL),3)="PQD"
    Call SUP_CLOB([M:PQH1]LINTEX(NOL),GBIDI1) From TRTX3TEX
  Endif
  #----- Pour actualisation liste de gauche -----#
  If !GIMPORT
    Local Shortint WPICK, I
    [L]WPICK=1 : I=nolign-1 : Gosub MARQUAGE_LIGNE From SUBPQHA
  Endif
  #----- Effacement ou suppression de la prise en compte DA -----#
  If [M:PQH1]RETQTYSTU(NOL)<>0
    Local Char WPWOCRIT(50)
    WPWOCRIT="PRONUM=adxuid(2) & LINNUM=[M:PQH1]PQHLIN(NOL)"
    Gosub MAJZERO_PWO From SUBPQHA
  Endif
  #-----
  [M:PQH1]PCLFLG=1
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog AS_NBLIG
#----------------------#
# Conditions de saisie #
#----------------------#
If [M:PQH1]NBLIG = 1
  Diszo [PQH1]PQHFCY
Elsif [M:PQH1]NBLIG = 0
  Actzo [PQH1]PQHFCY
Endif
End

Subprog B2_NBLIG
#--------------------------------------------------------------#
# Duplication d'une ligne                                      #
# Si ligne vide on duplique la précédente(sauf sur 1ere ligne) #
# sinon on duplique la ligne courante                          #
#--------------------------------------------------------------#
If [M:PQH1]NBLIG=0  End : Endif
If dim([M:PQH1]ITMREF)<[M:PQH1]NBLIG+2
  GMESSAGE=mess(122,199,1) : mkstat=2
Endif
If [M:PQH1]ITMREF(nolign-1)<>"" : nolign+= 1 : Endif
status=73 : Call INSERE("PQDLIN") From TABLEAUX
Call AVANT_NBLIG From SUBPQH : If mkstat End : Endif
Local Shortint NOL, I, J, K, L : NOL=nolign-1
Insa NOL,1,[M:PQH1]NBLIG [M:PQH1]NBLIG : [M:PQH1]NBLIG+=1
J=NOL : L=NOL-1 : Gosub COPIE_LIG From SUBPQHA
status=0 : Call LINNUM("PQDLIN") From TABLEAUX
Affzo [PQH1]10
mkstat=4
End

Subprog C_NBLIG
#-----------------------------------------------------------------#
# Si supp controle qu'il n'existe pas de réponse pour cet article #
# Si insertion controle que le tableau n'est pas plein            #
#-----------------------------------------------------------------#
Local Integer NOL : NOL=nolign-1
Local Char    WPWOCRIT(100)
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#----- Activation/désactivation du champ code acheteur -----#
If !GIMPORT
  If [M:PQH1]NBLIG=1 & GPQHBUY>1 & GBUYFLT>1
    Diszo [PQH1]REQUSR : Affzo [PQH1]REQUSR
  Elsif [M:PQH1]NBLIG=0
    Actzo [PQH1]REQUSR : Affzo [PQH1]REQUSR
  Endif
Endif
#-----
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#Case status
Case WSTATUS
  When 68,83                      : # Annulation multiple
    For I=NOL To nolign1-1
      If [M:PQH1]LINRSPNBR(I)<>0
        GMESSAGE=mess(37,194,1) : mkstat=1 : Break
      Endif
    Next I
  When 65                         : # Annulation ligne
    If [M:PQH1]LINRSPNBR(NOL)<>0
      GMESSAGE=mess(37,194,1)  : mkstat=1
    Endif
  When 73,82                      : # Insersion
    If dim([M:PQH1]ITMREF)<[M:PQH1]NBLIG+2
      GMESSAGE=mess(122,199,1) : mkstat=2
    Endif
  When Default
Endcase
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog AM_NBLIG
#---------------------------------------------#
# A chaque fois que le nombre de ligne change #
#---------------------------------------------#
#----- Test si modif ligne existante par saisie ou click droit -----#
If status<>75 & status<>131
  [M:PQH1]PCLFLG=9 : # Pour actualisation éventuelle des listes de picking
Endif
End

Subprog APRES_NBLIG
#-------------#
# Après ligne #
#-------------#
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#----- Si suppression, on se tire -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If (status=65 | status=68 | status=83)
If (WSTATUS=65 | WSTATUS=68 | WSTATUS=83)
  [M:PQH1]PCLFLG=1
  End
Endif
#----- Abandon de la saisie ligne par escape ou click sur listes de gauche -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=6 | status=7 | status=27 | status=28 | [M:PQH1]PUU(nolign-1)=""
If WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28 | [M:PQH1]PUU(nolign-1)=""
  #-- Si on a pické une DA par clique droit, il faut supprimer le fichier
  #-- de travail
  If [M:PQH1]PQDLIN(nolign-1)=0 & [M:PQH1]PICDA<>0
    [M:PQH1]PQHLIN(nolign-1)=[M:PQH1]PICDA
    Local Integer NOL           : NOL=nolign-1
    Local Char    WPWOCRIT(100) : Raz WPWOCRIT
    WPWOCRIT="PRONUM=adxuid(2) & LINNUM=[M:PQH1]PQHLIN(nolign-1)"
    Gosub MAJZERO_PWO  From SUBPQHA
    Raz [M:PQH1]PQHLIN(nolign-1),[M:PQH1]PICDA,
&       [M:PQH1]ITMREF(nolign-1),[M:PQH1]ITMDES(nolign-1),[M:PQH1]PQDPJT (nolign-1),
&       [M:PQH1]RCPDAT(nolign-1),[M:PQH1]ITMDES1(nolign-1),
&       [M:PQH1]PSHNUM(nolign-1),[M:PQH1]PSDLIN(nolign-1)
    Gosub RAZ_CCE
  Endif
  Raz [M:PQH1]UPDFLG(nolign-1)
Endif
#----- Actualisation listes gauche -----#
If [M:PQH1]PCLFLG=9
  If !GIMPORT
    Local Shortint WPICK, I
    [L]WPICK=2 : [L]I=nolign-1 : Gosub MARQUAGE_LIGNE From SUBPQHA
  Endif
Endif
[M:PQH1]PCLFLG=1
Raz [M:PQH1]PICDA
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog IB_ITMREF
#---------------------#
# Init bouton réf art #
#---------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
GBOUT1=mess(22,198,1)
GBOUT2=mess(61,198,1)
End

Subprog AV_ITMREF(VALEUR)
#----------------------------------------#
# Mettre en couleur la référence         #
# si l'article fait l'objet d'un contrat #
# ou d'une commande                      #
#----------------------------------------#
Variable Char     VALEUR
Local    Libelle  IND
#----- Vérifier que article n'a pas fait l'objet d'une cde ouverte -----#
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
Look [POC] POC2 First
Filter [POC]
If !fstat
  IND=1
#Else
#  #----- Vérifier que article n'a pas fait l'objet d'une cde -----#
#  Look [POP] POP3=VALEUR;1
#  If !fstat IND=1 : Endif
Endif
If IND=0
  pcolor=GCOUL(0) : # Noir
Else
  pcolor=GCOUL(3) : # Bleu
Endif
End

Subprog AS_ITMREF(VALEUR)
#-----------------------#
# Avant saisie article  #
#-----------------------#
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Raz [F:PSD]
#----- Interdiction de modifier la référence article -----#
If [M:PQH1]CREFLG(NOL)<>0 | [M:PQH1]UPDFLG(NOL)<>0 | [M:PQH1]PSHNUM(NOL)<>""
  mkstat=2 : End
Endif
End

Subprog C_ITMREF(VALEUR)
#-------------------#
# Controle article  #
#-------------------#
Variable Char     VALEUR
#If VALEUR="" mkstat=1 : Endif
End

Subprog AM_ITMREF(VALEUR)
#--------------------------------------------#
# Après modification de la référence article #
#--------------------------------------------#
Variable Char    VALEUR()
Local    Integer NOL : NOL=nolign-1
Local    Integer OK
VALEUR=toupper(VALEUR)
#----- Lecture de l'article -----#
Read [ITM] ITM0=VALEUR
If fstat
  #----- Avertissement article non référencé ! -----#
  Raz [F:ITM]                                                    # FGR 30/06/2009 : X3SUIVI56189
  Raz [M:PQH1]ITMDES(NOL),[M:PQH1]ITMDES1(NOL),[M:PQH1]PUU(NOL)  # FGR 30/06/2009 : X3SUIVI56189
  OK=2 : Call AVERTIR(VALEUR-mess(483,199,1),OK) From GESECRAN
  If OK<>2  Raz VALEUR : mkstat=1 : End : Endif
Else
  #----- Article inactif ! -----#
  If !find([F:ITM]ITMSTA,1,2) : # On accepte les articles en "élaboration"
    Call ERREUR(mess(258,199,1)) From GESECRAN
    mkstat=1 : End
  Endif
  #----- Article non acheté interdit ! -----#
  If [F:ITM]PURFLG<>2
    Call ERREUR(mess(176,194,1)) From GESECRAN
    mkstat=1 : End
  Endif
  #----- Article obsolète (fin de vie) -----#
  If [F:ITM]LIFENDDAT<>[0/0/0] & [F:ITM]LIFENDDAT<[M:PQH1]PQHDAT
    Call ERREUR(mess(12,318,1)) From GESECRAN
    mkstat=1 : End
  Endif
  #----- Contrôle code acheteur sur article ou article-site -----#
  If GPQHBUY=2 & GBUYFLT=2
    Call CTLITMBUY(VALEUR,[M:PQH1]REQUSR,mkstat) From TRTACHCTL1
    If mkstat  GERR=1 : End : Endif
  Endif
  #----- Vérifier que article n'a pas fait l'objet d'une cde ouverte -----#
  Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
  Look [POC] POC2 First
  Filter [POC]
  If !fstat
    OK=2 : Call AVERTIR(VALEUR-mess(1,194,1),OK) From GESECRAN
    If OK<>2  Raz VALEUR : mkstat=1 : End : Endif
  Endif
Endif
#----- Colorisation en bleu si l'article fait l'objet d'une commande -----#
[M:PQH1]ITMREF(NOL)=VALEUR : Affzo [PQH1]ITMREF(NOL)
#-----
If [M:PQH1]PSHNUM(NOL)=""
  Raz [F:PSD] : Gosub CHARG_LIG_ART From SUBPQHA
Endif
End


Subprog IB_ITMDES
#----------------------------------#
# Initialisation bouton "Articles" #
#----------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End

Subprog IB_ITMDES1
#----------------------------------#
# Initialisation bouton "Articles" #
#----------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End


Subprog AS_PUU(VALEUR)
#----------------------------#
# Avant saisie unité d'achat #
#----------------------------#
Variable Char    VALEUR
Local Integer NOL : NOL=nolign-1
If GREP = "C" | GREP = "D" : End : Endif
If [M:PQH1]LINRSPNBR(NOL)<>0 mkstat=2 : Endif
End

Subprog AM_PUU(VALEUR)
#--------------------------------#
# Apres modif de l'unité d'achat #
#--------------------------------#
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Local Decimal WQTY
If [M:PQH1]QTYPUU(NOL)<>0
  Call PCAL_QTY([M:PQH1]QTYPUU(NOL),[M:PQH1]PUU(NOL),[L]WQTY,VALEUR,
&             [M:PQH1]ITMREF(NOL),"",1,GBIDD1)  From TRTACHQTE1
  [M:PQH1]QTYPUU(NOL)=[L]WQTY
  Affzo [PQH1]QTYPUU(NOL)
Endif
End

Subprog AS_QTYPUU(VALEUR)
#---------------------------------------------------------#
# En modif on interdit la modification de la qté demandée #
# si des réponses ont été enregistrées                    #
#---------------------------------------------------------#
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign-1
If GREP = "C" | GREP = "D" : End : Endif
If [M:PQH1]LINRSPNBR(NOL)<>0 mkstat=2 : Endif
End

Subprog AM_QTYPUU(VALEUR)
#-----------------------------#
# Apres modif de la quantité  #
#-----------------------------#
Variable Decimal VALEUR
Local Decimal WQTY
Local Integer NOL : NOL=nolign-1
If [M:PQH1]RETQTYSTU(NOL)<>0
  Call PCAL_QTY([M:PQH1]RETQTYSTU(NOL),STU(NOL),[L]WQTY,[M:PQH1]PUU(NOL),
&             [M:PQH1]ITMREF(NOL),"",1,GBIDD1)  From TRTACHQTE1
  If VALEUR<[L]WQTY
    GMESSAGE=mess(303,194,1)-format$("N:15F",[M:PQH1]RETQTYSTU(NOL))-[M:PQH1]STU(NOL)
    Call MESSAGE(GMESSAGE) From GESECRAN
   #CH le 01/12/2003 préfère un message
   #GERR=1 : mkstat=2
  Endif
Endif
End

Subprog AS_LTI(VALEUR)
#----------------------------------------------#
# Zone non modifiable si des réponses existent #
# ou si date renseignée                        #
#----------------------------------------------#
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign-1
If [M:PQH1]RCPDAT(NOL) <> [00/00/0000] : mkstat = 2 : End : Endif
If GREP <> "M" : End : Endif
If [M:PQH1]LINRSPNBR(NOL)<>0 mkstat=2 : Endif
End

Subprog AS_RCPDAT(VALEUR)
#---------------------------------------------------------------#
# Si le délai a été saisi on ne saisit pas la date de réception #
# Idem si des réponses existent                                 #
#---------------------------------------------------------------#
Variable Date    VALEUR
Local Integer NOL : NOL=nolign-1
If  [M:PQH1]LTI(NOL) <> 0 : mkstat = 2 : End : Endif
If GREP = "C" | GREP = "D" : End : Endif
If [M:PQH1]LINRSPNBR(NOL)<>0 mkstat=2 : Endif
End

Subprog AM_RCPDAT(VALEUR)
#---------------------------------------------------#
# Après modification de la date de réception prévue #
#---------------------------------------------------#
Variable Date    VALEUR
#----- Date de réception prévue inférieure à la date limite de l'appel d'offre ! -----#
If VALEUR<[M:PQH1]RSPDEA
  Local Integer OK
  OK=2 : Call AVERTIR(mess(308,194,1),OK) From GESECRAN
  If OK=1  mkstat=1 : End : Endif
Endif
End

Subprog D_CCE1(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=1 : Gosub D_CCEX
End

