$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"PQH","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:PQH1]PQHDAT) From TRTX3CPT
Return

Subprog IB_NBFOU
#-------------------------------------------------------------------#
# GBOUT1 : Tunnel fournisseur                                       #
# GBOUT2 : Sélection avancée fournisseur                            #
# GBOUT3 : Visu des réponses                                        #
# GBOUT4 : Adresse fournisseur                                      #
# GBOUT5 : Sélection des fournisseurs référencés                    #
#-------------------------------------------------------------------#
Local Integer NOL : NOL=nolign-1
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
GBOUT1 = mess(73,198,1)
If GPQH_VERROU | GREP="C"
  If [M:PQH1]BPSNUM(NOL)<>""  GBOUT2=mess(17,7,1)-[M:PQH1]BPSNUM(nolign-1) : Endif : # Tunnel fournisseur
  If [M:PQH1]NBLIG<>0
    GBOUT5=mess(244,194,1)  : # Fournisseurs des articles
  Endif
Endif
If [M:PQH1]RSPNBR(NOL)<>0
  GBOUT3=mess(445,198,1)    : # Visu des réponses
Endif
If [M:PQH1]BPSNUM(NOL)<>""
  Raz [M:AD60]
  GBOUT4=mess(27,198,1)     : # Adresse
Endif
End

Subprog AVANT_NBFOU
#--------------#
# Avant ligne  #
#--------------#
Local Integer NOL : NOL=nolign-1
If status=73
  Actzo [PQH1]BPSNUM(NOL)
Endif
#----- Avant ligne : Si suppression ligne, suppression détail ligne -----#
If status=65 | status=68 | status=83
  #----- Pour actualisation liste de gauche -----#
  If !GIMPORT
    Local Shortint WPICK, I
    WPICK=1 : I=nolign-1 : Gosub MARQUAGE_LIGNE From SUBPQHA
  Endif
  [M:PQH1]PCLFLG=1
Endif
End

Subprog APRES_NBFOU
#-------------#
# Après ligne #
#-------------#
#----- Si suppression, on se tire -----#
If (status=65 | status=68 | status=83)
  [M:PQH1]PCLFLG=1
  End
Endif
#----- Si abandon d'une nouvelle ligne par "Escape" -----#
If status=6 & [M:PQH1]BPSNUM(nolign-1)=""
  #----- Abandon d'une insertion -----#
  If nolign<[M:PQH1]NBFOU
    If [M:PQH1]BPSNBR=[M:PQH1]NBFOU  [M:PQH1]BPSNBR-=1 : Affzo [PQH1]BPSNBR : Endif
  #----- Abandon d'un ajout -----#
  Else
    If [M:PQH1]BPSNBR>[M:PQH1]NBFOU  [M:PQH1]BPSNBR-=1 : Affzo [PQH1]BPSNBR : Endif
  Endif
Endif
#----- Actualisation listes gauche -----#
If [M:PQH1]PCLFLG=9
  If !GIMPORT
    Local Shortint WPICK, I
    WPICK=2 : I=nolign-1 : Gosub MARQUAGE_LIGNE From SUBPQHA
  Endif
Endif
[M:PQH1]PCLFLG=1
End

Subprog C_NBFOU
#------------------------------#
# Controle sur numéro de ligne #
#------------------------------#
Local Integer NOL : NOL=nolign-1
If status=65
  If [M:PQH1]RSPNBR(NOL)<>0
    GMESSAGE = mess(37,194,1)
    Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
    mkstat=1 : End
  Endif
  [M:PQH1]BPSNBR-=1
  Affzo [PQH1]BPSNBR
Elsif status=68 | status=83
  For I = nolign-1 To nolign1-1
    If [M:PQH1]RSPNBR(I)<>0
      GMESSAGE = mess(37,194,1)
      Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
      mkstat = 1 : Break
    Endif
  Next I
  If mkstat = 1 : End : Endif
  For I=nolign-1 To nolign1-1
    If [M:PQH1]BPSNUM(I)<>"" [M:PQH1]BPSNBR-=1 : Endif
  Next I
  Affzo [PQH1]BPSNBR
Endif
End

Subprog AM_NBFOU
#---------------------------------------------#
# A chaque fois que le nombre de ligne change #
#---------------------------------------------#
#----- Test si modif ligne existante par saisie ou click droit -----#
If status<>75 & status<>131
  [M:PQH1]PCLFLG=9 : # Pour actualisation éventuelle des listes de picking
Endif
End


$AB3_NBFOU
#----------------------------------#
# Avant exécution du bouton Tunnel #
#----------------------------------#
Local Char WSCLE2(20)(0..1)
Local Integer NOL  : NOL=nolign-1
Filter [PPH] Where [F:PPH]PQHFCY=[M:PQH1]PQHFCY & [F:PPH]PQHNUM = [M:PQH1]PQHNUM &
&                  [F:PPH]BPSNUM=[M:PQH1]BPSNUM(NOL)
Read [PPH]PPH0 First
Filter [PPH]
If fstat Raz [F:PPH] : Return : Endif
GFLTBPS   = [M:PQH1]BPSNUM(NOL)
GFLTPQH   = [M:PQH1]PQHNUM
[L]WSCLE2(0) = GFLTBPS
[L]WSCLE2(1) = num$([F:PPH]PQDLIN)
Return

$BB3_NBFOU
#----------------------------------#
# Apres exécution du bouton Tunnel #
#----------------------------------#
nolign=NOL+1
Raz GFLTBPS, GFLTPQH
Return

$AB4_NBFOU
#-----------------------------------#
# Avant exécution du bouton Adresse #
#-----------------------------------#
Local Integer NOL : NOL=nolign-1
Raz [M:AD60]
If [M:PQH1]CREFLG1(NOL)<>0 & [M:PQH1]UPDFLG1(NOL)=0
  Read [PQF]PQF0=[M:PQH1]PQHNUM;[M:PQH1]BPSNUM(NOL)
  If !fstat & ([F:PQF]CRY<>"" | [F:PQF]CTY<>"")
     [M:AD60]       = [F:PQF]
     [M:AD60]ADBBPR = [F:PQF]BPSNUM
     [M:AD60]ADBFLG = 2
  Else
    Raz [F:PWF], [M:AD60]
    [M:AD60]BPAADD = [M:PQH1]BPAADD(NOL)
    [M:AD60]ADBBPR = [M:PQH1]BPSNUM(NOL)
    [M:AD60]BPRNAM = [M:PQH1]BPSNAM(NOL)
  Endif
Else
  #-- Lecture du fichier de travail pour alim du mask
  Read [PWF] PWF0=adxuid(2);[M:PQH1]BPSNUM(NOL)
  If !fstat & ([F:PWF]CRY<>"" | [F:PWF]CTY<>"")
    [M:AD60]=[F:PWF]
    [M:AD60]ADBBPR = [M:PQH1]BPSNUM(NOL)
    [M:AD60]ADBFLG = 2
  Else
    Raz [F:PWF], [M:AD60]
    [M:AD60]BPAADD = [M:PQH1]BPAADD(NOL)
    [M:AD60]ADBBPR = [M:PQH1]BPSNUM(NOL)
    [M:AD60]BPRNAM = [M:PQH1]BPSNAM(NOL)
  Endif
Endif
If !GPQH_VERROU & GREP<>"C" GBIDI3=GCONSULT : GCONSULT=1 : Return : Endif
Return


$BB4_NBFOU
#-----------------------------------#
# Apres exécution du bouton Adresse #
#-----------------------------------#
nolign=[L]NOL+1 : # Restitution de nolign
If !GPQH_VERROU & GREP<>"C"  GCONSULT=GBIDI3 : Return : Endif
If [M:AD60]ADBFLG<>2
  Gosub DEL_PWF
Else
  Gosub MAJ_ADR
Endif
#-----
If [M:PQH1]BPAADD(NOL)<>[M:AD60]BPAADD
  [M:PQH1]BPAADD(NOL)=[M:AD60]BPAADD
  Affzo [PQH1]BPAADD(NOL)
  mkstat=4 : [M:PQH1]UPDFLG1(NOL)=1
Endif
If [M:PQH1]BPSNAM(NOL)<>[M:AD60]BPRNAM(0)
  [M:PQH1]BPSNAM(NOL)=[M:AD60]BPRNAM(0)
  Affzo [PQH1]BPSNAM(NOL)
  mkstat=4 : [M:PQH1]UPDFLG1(NOL)=1
Endif
Return

Subprog AS_BPSNUM(VALEUR)
#--------------------------#
# Avant-saisie fournisseur #
#--------------------------#
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
If [M:PQH1]BPSNUM(NOL)<>"" mkstat= 2 : End : Endif
If [M:PQH1]RSPNBR(NOL)<>0
  GMESSAGE = mess(37,194,1)
  mkstat = 2
Endif
End

Subprog AM_BPSNUM(VALEUR)
#-------------------------#
# Après-modif fournisseur #
#-------------------------#
Variable Char    VALEUR()
Local Char WBPSNUM(GLONBPS)
Raz mkstat
If find(VALEUR,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
  GMESSAGE=VALEUR-mess(175,194,1) : mkstat=1 : End
Endif
#----- Lecture fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : Endif
Endif
#----- Avertissement si fournisseur en litige -----#
If [F:BPS]DOUFLG>1
  Local Integer OK
  OK=2 : Call AVERTIR(VALEUR-mess(4,194,1),OK) From GESECRAN
  If OK<>2  mkstat=1 : End : Endif
Endif
#-----
[L]WBPSNUM=VALEUR
Gosub CHARG_LIG_BPS From SUBPQHA
Affzo [PQH1]BPSNAM(nolign-1),BPSTYP(nolign-1),BPAADD(nolign-1),BPSNBR
End

Subprog AS_BPAADD(VALEUR)
#----------------------#
# Avant saisie adresse #
#----------------------#
Variable Char    VALEUR()
End

Subprog C_BPAADD(VALEUR)
#-----------------------#
# Contrôle code adresse #
#-----------------------#
Variable Char    VALEUR()
Read [BPA] BPA0=1;[M:PQH1]BPSNUM(nolign-1);VALEUR
If fstat  Raz [F:BPA] : GMESSAGE=mess(6,199,1) : mkstat=1 : End : Endif
End

Subprog AM_BPAADD(VALEUR)
#------------------------------------#
# Après modification du code adresse #
#------------------------------------#
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
#----- Modification interdite si des réponses existent ! -----#
If [M:PQH1]RSPNBR(nolign-1)<>0
  GMESSAGE=mess(35,194,1) : mkstat=1 : End
Endif
#----- Vérification existence d'une adresse spécifique -----#
If [M:PQH1]CREFLG1(NOL)<>0 & [M:PQH1]UPDFLG1(NOL)=0
  Read [PQF] PQF0=[M:PQH1]PQHNUM;[M:PQH1]BPSNUM(NOL)
  If !fstat  [F:PWF]=[F:PQF]  Else  Raz [F:PWF], [F:PQF] : Endif
Else
  Read [PWF] PWF0=adxuid(2);[M:PQH1]BPSNUM(NOL)
  If fstat  Raz [F:PWF] : Endif
Endif
If !fstat
  If [F:BPR]BPRNUM<>[M:PQH1]BPSNUM(NOL)
    Read [BPR] BPR0=[M:PQH1]BPSNUM(NOL)
    If fstat  Raz [F:BPR] : Endif
  Endif
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:BPR]BPRNUM | [F:BPA]BPAADD<>[F:PQF]BPAADD
    Read [BPA] BPA0=1;[F:BPR]BPRNUM;[F:PQF]BPAADD
    If fstat Raz [F:BPA] : Endif
  Endif
  If [F:PWF]CRY<>"" | [F:PWF]CTY<>""
    If [F:PWF]BPRNAM(0)    <> [F:BPR]BPRNAM(0)    |
&      [F:PWF]BPRNAM(1)    <> [F:BPR]BPRNAM(1)    |
&      [F:PWF]BPAADDLIG(0) <> [F:BPA]BPAADDLIG(0) |
&      [F:PWF]BPAADDLIG(1) <> [F:BPA]BPAADDLIG(1) |
&      [F:PWF]BPAADDLIG(2) <> [F:BPA]BPAADDLIG(2) |
&      [F:PWF]CRY          <> [F:BPA]CRY          |
&      [F:PWF]SAT          <> [F:BPA]SAT          |
&      [F:PWF]POSCOD       <> [F:BPA]POSCOD       |
&      [F:PWF]CTY          <> [F:BPA]CTY
      Local Integer OK
      OK=2  : Call AVERTIR(mess(309,194,1),OK) From GESECRAN
      If OK<>2  mkstat=1 : End : Endif
    Endif
  Endif
Endif
Gosub DEL_PWF : # Effacement fichier travail des adresses
[M:PQH1]UPDFLG1(NOL)=1
End


$SAUV_NBFOU
#-------------------------------#
# Sauvegarde du nombre de ligne #
# Avant execution action        #
# Sélection fournisseur         #
#-------------------------------#
Local Shortint SVGNBFOU : [L]SVGNBFOU=[M:PQH1]NBFOU
Return

$ACTIV_GSTAENR
#-------------------------------#
# Apres execution action        #
# Sélection fournisseur         #
# Positionnement du bout ENR    #
#-------------------------------#
If [M:PQH1]NBFOU=[L]SVGNBFOU : End : Endif
Affzo [PQH1]BPSNBR
mkstat=4
Return


$MAJ_ADR
#---------------------------#
# Mise à jour de l'adresse  #
# NOL doit exister et être  #
# renseigné                 #
#---------------------------#
Call DEBTRANS From GLOCK
$TR_MAJPWF
GOK=1
Trbegin [PWF]
  Readlock [PWF] PWF0=adxuid(2);[M:PQH1]BPSNUM(NOL)
  If fstat
    Raz [F:PWF]
    [F:PWF]=[M:AD60] : [F:PWF]PRONUM=adxuid(2) : [F:PWF]BPSNUM=[M:PQH1]BPSNUM(NOL)
    Write [PWF]
    If fstat GOK=0 : Call FSTA("PWF") From GLOCK : Goto AB_MAJPWF : Endif
  Else
    [F:PWF]=[M:AD60]
    Rewrite [PWF]
    If fstat GOK=0 : Call FSTA("PWF") From GLOCK : Goto AB_MAJPWF : Endif
  Endif
Commit
$FIN_MAJPWF
[M:PQH1]UPDFLG1(NOL)=1
Return

$AB_MAJPWF
Rollback : Goto FIN_MAJPWF
$ROLL_MAJPWF
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_MAJPWF : Endif : Goto FIN_MAJPWF


$DEL_PWF
#--------------------------------#
# Effacement fichiers de travail #
#--------------------------------#
Call DEBTRANS From GLOCK
$TR_DELPWF
GOK=1
Trbegin [PWF]
  Delete [PWF] Where PRONUM=adxuid(2) & BPSNUM=[M:PQH1]BPSNUM(NOL)
  If fstat=1  GOK=-1 : GLOCK="$PWRKPQF"-num$(adxuid(2))
              Goto ROLL_DELPWF
  Elsif fstat GOK=0  : Call RSTA("PWF",num$(adxuid(2))) From GLOCK
              Goto AB_DELPWF
  Endif
Commit
Return

$AB_DELPWF
Rollback : Return
$ROLL_DELPWF
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_DELPWF : Endif : Return


$RAZ_CCE
#---------------------------------------------------------#
# Effacement des sections analytiques de la ligne contrat #
#---------------------------------------------------------#
If dim(J)<1  Local Integer J : Endif
For J=1 To GNBDIE
  Case J
    When  1 : Raz [M:PQH1]CCE1 (NOL)
    When  2 : Raz [M:PQH1]CCE2 (NOL)
    When  3 : Raz [M:PQH1]CCE3 (NOL)
    When  4 : Raz [M:PQH1]CCE4 (NOL)
    When  5 : Raz [M:PQH1]CCE5 (NOL)
    When  6 : Raz [M:PQH1]CCE6 (NOL)
    When  7 : Raz [M:PQH1]CCE7 (NOL)
