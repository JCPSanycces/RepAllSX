#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT ACCOUNTS
##############################################################################################################
# GETTING BACK AN ACCOUNT
# GET_COAFMT     : Returns the account format for a chart of accounts
# GET_COACOLHEA  : Returns the column header for a chart of accounts
# GET_MAIACC     : Returns the main general or analytical or IAS account defined in the list of accounts
# GET_MISACC     : Returns a miscellaneaous account defined in the Chart of Account for a company and a ledger type
# GET_MAICOA     : Returns the chart of account for a company and a type of main ledger (1=General 2=Analytical 3=IAS)
# GET_LEDCOA     : Returns the chart of account for a company and a type of ledger
# GET_DENACC     : Returns the default account from an origin account used as parameter
#
# CONTROLLING AN ACCOUNT
# CTL_ACC       : Controls the account. Calls _CTL_ACC
# CTL_BPRTYPACC : Controls the account and the B-Partner linked to the account. Calls _CTL_ACC
# CTL_ISACC     : Controls the account - or its short account - exists
# CTL_CLSACC    : Controls that the account class does not belong to an exceptional account class category
# CTL_IPTACC    : Controls that the imputation of the account is right on the charts of accounts (COA)
# CTL_OBYIPTACC : Checks if the imputation of a given target chart of account on the origin account is mandatory or optional

#
# Private routines :
# _CTL_ACC
##############################################################################################################

#####################################################################################################################
## GET_COAFMT
#####################################################################################################################
#**
#* Returns the account format for a chart of accounts used as parameter (COA)
#*
#* @param ACTX   Context
#* @param COA    Chart of accounts
#* @param COAFMT Account format
#* @param ERRMES Error message
#*!
Funprog GET_COAFMT(ACTX,COA,COAFMT,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COA()
Variable Char     COAFMT()
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer ICOA

ICOA = fmet ACTX.ACACHE.COA.AGETINDEX(COA)
If ICOA = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COA-mess(110,102,1) : End [L]ASTATUS
Endif
COAFMT = fmet ACTX.ACACHE.COA.AGETVALCHAR(COA,"COAFMT")
If instr(1,COAFMT,"#")
 If fmet ACTX.ACACHE.COA.AGETVALNUM(COA,"COALEN")<>AVOID.ADEC
  COAFMT = num$(fmet ACTX.ACACHE.COA.AGETVALNUM(COA,"COALEN"))+"c"
 Elsif fmet ACTX.ACACHE.COA.AGETVALNUM(COA,"COALEN")=AVOID.ADEC
  COAFMT = mid$(COAFMT,1,len(COAFMT)-1)+"c"
 Endif
Endif
If COAFMT = AVOID.ACHAR  : COAFMT = "15c" : Endif
#If GUSER="PP" : ERRMES = "erreur sur format de compte" : ASTATUS = [V]CST_AERROR : Endif
End [L]ASTATUS


#####################################################################################################################
## GET_COACOLHEA
#####################################################################################################################
#**
#* Returns the column header for a chart of accounts used as parameter (COA)
#*
#* @param ACTX      Context
#* @param COA       Chart of accounts
#* @param COACOLHEA Column header
#* @param ERRMES    Error message
#*!
Funprog GET_COACOLHEA(ACTX,COA,COACOLHEA,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COA()
Variable Char     COACOLHEA()
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer ICOA

ICOA = fmet ACTX.ACACHE.COA.AGETINDEX(COA)
If ICOA = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COA-mess(110,102,1) : End [L]ASTATUS
Endif
COACOLHEA = fmet ACTX.ACACHE.COA.AGETVALCHAR(COA,"COLHEA")
End [L]ASTATUS


#####################################################################################################################
## GET_MAIACC
#####################################################################################################################
#**
#* Returns the main general account OR main analytical account OR main IAS account defined in the list
#* of accounts used as parameters (ACC(1..)).<br>
#* This sub-program can be used in the some documents or in the journals generation when we must to read
#* the general account in doer to retrieve the tax code, for example...
#*
#* @param ACTX    Context
#* @param ACCTYP  Account type
#* @param COMPANY Company
#* @param NBRLED  Number of ledger types (max 10)
#* @param LEDTYP  Ledger Types
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param MAICOA  Main Chart of accounts (general, analytical or IAS depending on the ACCTYP Parameter)
#* @param MAIACC  Main Account (general, analytical or IAS depending on the ACCTYP Parameter)
#* @param ERRMES  Error message
#*!
Funprog GET_MAIACC(ACTX,ACCTYP,COMPANY,NBRLED,LEDTYP,COA,ACC,MAICOA,MAIACC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  ACCTYP        : # 1:General   2:Analytical  3:IAS
Value    Char     COMPANY       : # Company
Value    Integer  NBRLED        : # Number of ledger types (max 10)
Value    Tinyint  LEDTYP(1..)   : # Ledger Types
Value    Char     COA()(1..)    : # Chart of accounts
Value    Char     ACC()(1..)    : # Accounts
Variable Char     MAICOA()      : # Main Chart of account (general, analytical or IAS depending on the ACCTYP Parameter)
Variable Char     MAIACC()      : # Main Account (general, analytical or IAS depending on the ACCTYP Parameter)
Variable Char     ERRMES()      : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    LEDCOD(GLONLED)         : # Ledger Code
Local Char    LEDCUR(GLONCUR)         : # Ledger Currency
Local Char    FLDFLG(GLONAVA)         : # Name of the flags in the 'In Cache' Class
Local Integer INDLED, ILED
Local Tinyint LEDTYPGEN, LEDTYPANA, LEDTYPIAS, MAILEDTYP

If adxtyp=33 | !clalev([F:LED]) : Local File GLED      [LED] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

[L]ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(ACTX,COMPANY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Case ACCTYP
 When 1 : MAILEDTYP = LEDTYPGEN : FLDFLG = 'LEDFLGGEN'
 When 2 : MAILEDTYP = LEDTYPANA : FLDFLG = 'LEDFLGANA'
 When 3 : MAILEDTYP = LEDTYPIAS : FLDFLG = 'LEDFLGIAS'
Endcase

Raz MAICOA, MAIACC, INDLED
INDLED = find(MAILEDTYP,LEDTYP(1..NBRLED))
If INDLED
 MAICOA = COA(INDLED)
 MAIACC = ACC(INDLED)
Endif
If MAIACC=""
 For INDLED=1 To NBRLED
  If LEDTYP(INDLED)<>MAILEDTYP
   [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYP(INDLED),LEDCOD,LEDCUR,ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
   If ILED & fmet ACTX.ACACHE.LED.AGETVALNUM(LEDCOD,FLDFLG)=2
    MAICOA = COA(INDLED)
    MAIACC = ACC(INDLED)
    If MAIACC<>"" : Break : Endif
   Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
Endif
If MAIACC<>""
 Call LEC_GAC(MAIACC,MAICOA) From CPTLEC
Endif
End [L]ASTATUS


#####################################################################################################################
## GET_MISACC
#####################################################################################################################
#**
#* Returns a miscellaneaous account defined in the chart of accounts for a company and a ledger type used as parameter
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param LEDTYP  Ledger type
#* @param ACCTYP  Account type
#* @param MISACC  Miscellaneous account
#* @param ERRMES  Error message
#*!
Funprog GET_MISACC(ACTX,COMPANY,LEDTYP,ACCTYP,MISACC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY    : # Company
Value    Tinyint  LEDTYP     : # Ledger Type
Value    Integer  ACCTYP     : # Type of miscellaneous account (Local Menu 2649)
Variable Char     MISACC()   : # Miscellaneous account
Variable Char     ERRMES()   : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:COA]) : Local File GCOA      [COA] : Endif

Local Char    LEDCOD(GLONLED), LEDCUR(GLONCUR)
Local Char    COA(GLONCOA)
Local Integer ILED

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYP,LEDCOD,LEDCUR,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
If ILED
 COA = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD,"LEDCOA")
 Call LEC_COA(COA) From CPTLEC
 MISACC = [F:COA]ACCMIS(ACCTYP-1)
Endif
End [L]ASTATUS


#####################################################################################################################
## GET_MAICOA
#####################################################################################################################
#**
#* Returns the chart of accounts for a given company and a given type of main ledger (1=General 2=Analytical 3=IAS)
#*
#* @param ACTX    Context
#* @param CAS     1=General 2=Analytical 3=IAS
#* @param COMPANY Company
#* @param COA     Chart of accounts
#* @param ERRMES  Error message
#*!
Funprog GET_MAICOA(ACTX,CAS,COMPANY,COA,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  CAS       : # 1=General 2=Analytical 3=IAS
Value    Char     COMPANY() : # Company
Variable Char     COA()     : # Chart of accounts
Variable Char     ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Tinyint LEDTYPGEN       : # Main General Ledger Type
Local Tinyint LEDTYPANA       : # Main Analytical Ledger Type
Local Tinyint LEDTYPIAS       : # Main IAS Ledger Type
Local Char    LEDCOD(GLONLED) : # Ledger code
Local Char    LEDCUR(GLONCUR) : # Currency of the ledger code
Local Integer ILED            : # Local index in in LED class


[L]ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(ACTX,COMPANY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Case CAS
 When 1 : [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPGEN,LEDCOD,LEDCUR,ERRMES)
 When 2 : [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPANA,LEDCOD,LEDCUR,ERRMES)
 When 3 : [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPIAS,LEDCOD,LEDCUR,ERRMES)
Endcase

If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
If ILED = [V]CST_ANOTDEFINED
# X3-88118 Bader begin
# [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LEDCOD(I)-mess(23,100,1)
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LEDCOD-mess(23,100,1)
# X3-88118 Bader end
 End [L]ASTATUS
Endif

COA = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD,"LEDCOA")

End [L]ASTATUS


#####################################################################################################################
## GET_LEDCOA
#####################################################################################################################
#**
#* Returns the chart of accounts for a given company and a given ledger type
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param LEDTYP  Ledger type
#* @param COA     Chart of accounts
#* @param ERRMES  Error message
#*!
Funprog GET_LEDCOA(ACTX,COMPANY,LEDTYP,COA,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY() : # Company
Value    Tinyint  LEDTYP()  : # Ledger type
Variable Char     COA()     : # Chart of accounts
Variable Char     ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    LEDCOD(GLONLED) : # Ledger code
Local Char    LEDCUR(GLONCUR) : # Currency of the ledger code
Local Integer ILED            : # Local index in LED class

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYP,LEDCOD,LEDCUR,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD)
If ILED = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LEDCOD-mess(23,100,1)
 End [L]ASTATUS
Endif

COA = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD,"LEDCOA")

End [L]ASTATUS


#####################################################################################################################
## GET_DENACC
#####################################################################################################################
#**
#* Returns the destination/default account & the screening from an origin account used as parameter
#*
#* @param ACTX       Context
#* @param ORICOA     Origin chart of account
#* @param ORIACC     Origin account
#* @param DENCOA     Destination chart of accounts
#* @param DENACC     Destination Account (Default Account)
#* @param DENACCSCR  Destination Account Screening
#* @param ERRMES     Error messsage
#*!
Funprog GET_DENACC(ACTX,ORICOA,ORIACC,DENCOA,DENACC,DENACCSCR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     ORICOA()      : # Origin Chart of Account
Value    Char     ORIACC()      : # Origin Account
Value    Char     DENCOA()      : # Destination Chart of Account
Variable Char     DENACC()      : # Destination Account (Default Account)
Variable Char     DENACCSCR()   : # Destination Account Screening
Variable Char     ERRMES()      : # Error messsage

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer FOUND

If DENCOA = "" : End [L]ASTATUS : Endif

If ORICOA = DENCOA
 DENACC = ORIACC : End [L]ASTATUS
Endif

[L]ASTATUS = func CTL_ISACC(ACTX,ORICOA,ORIACC,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 End [L]ASTATUS
Else
 FOUND = find(DENCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
 If FOUND
  DENACC    = [F:GAC]DEFACC(FOUND-1)
  DENACCSCR = [F:GAC]SCRACC(FOUND-1)
 Endif
Endif
End [L]ASTATUS


#####################################################################################################################
## CTL_ACC
#####################################################################################################################
#**
#* Controls the account
#*
#* @param ACTX   Context
#* @param LEDTYP Ledger type
#* @param COA    Chart of accounts
#* @param ACC    Account
#* @param FCY    Site
#* @param CUR    Currency
#* @param DAT    Date
#* @param CAT    Accounting journal category (1=Actual ; 2=Active simulation ; 3=Inactive simulation ; 4=Off-balance sheet ; 5=Template)
#* @param FCTGAS 1 = If the funprog is called from GESGAS / 0 = otherwise
#* @param ERRMES Error message
#*!
Funprog CTL_ACC(ACTX,LEDTYP,COA,ACC,FCY,CUR,DAT,CAT,FCTGAS,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Tinyint  LEDTYP   : # Ledger type
Value    Char     COA      : # Chart of accounts
Value    Char     ACC      : # Account
Value    Char     FCY      : # Site
Value    Char     CUR      : # Currency
Value    Date     DAT      : # Date
Value    Integer  CAT      : # Accounting journal category (Actual/Active simulation/Inactive simulation/Off-balance sheet/Template)
Value    Integer  FCTGAS   : # 1 = If the funprog is called from GESGAS / 0 = otherwise
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
Local Integer APPCASE : APPCASE = 0 # Application case


[L]ASTATUS = func _CTL_ACC(ACTX,APPCASE,LEDTYP,COA,ACC,FCY,CUR,DAT,CAT,FCTGAS,ERRMES)

End [L]ASTATUS


#####################################################################################################################
## CTL_BPRTYPACC
#####################################################################################################################
#**
#* Controls the account associated with a BP. This program is the same as CTL_ACC but it allows to add a control
#* for account with BP through the parameter BPRTYP. It is set to C (for Customer) and S (for Supplier)
#*
#* @param ACTX   Context
#* @param LEDTYP Ledger type
#* @param COA    Chart of accounts
#* @param ACC    Account
#* @param FCY    Site
#* @param CUR    Currency
#* @param DAT    Date
#* @param CAT    Accounting journal category (1=Actual ; 2=Active simulation ; 3=Inactive simulation ; 4=Off-balance sheet ; 5=Template)
#* @param FCTGAS 1 = If the funprog is called from GESGAS ; 0 = otherwise
#* @param BPRTYP Partner type: C=Customer ; S=Suplier
#* @param ERRMES Error message
#*!
Funprog CTL_BPRTYPACC(ACTX,LEDTYP,COA,ACC,FCY,CUR,DAT,CAT,FCTGAS,BPRTYP,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Tinyint  LEDTYP   : # Ledger type
Value    Char     COA      : # Chart of accounts
Value    Char     ACC      : # Account
Value    Char     FCY      : # Site
Value    Char     CUR      : # Currency
Value    Date     DAT      : # Date
Value    Integer  CAT      : # Accounting journal category (Actual/Active simulation/Inactive simulation/Off-balance sheet/Template)
Value    Integer  FCTGAS   : # 1 = If the funprog is called from GESGAS / 0 = otherwise
Value    Char     BPRTYP   : # C=Customer S=Supplier
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
Local Integer APPCASE : APPCASE = 1*(BPRTYP="C") + 2*(BPRTYP="S") # Application case


[L]ASTATUS = func _CTL_ACC(ACTX,APPCASE,LEDTYP,COA,ACC,FCY,CUR,DAT,CAT,FCTGAS,ERRMES)

End [L]ASTATUS


#####################################################################################################################
## CTL_ISACC
#####################################################################################################################
#**
#* Checks that the account (or its short code) exists in the chart of accounts
#*
#* @param ACTX   Context
#* @param COA    Chart of accounts
#* @param ACC    Account
#* @param ERRMES Error message
#*!
Funprog CTL_ISACC(ACTX,COA,ACC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COA      : # Chart of accounts
Value    Char     ACC      : # Account
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
[L]ASTATUS = [V]CST_AOK

Call LEC_GAC(ACC,COA) From CPTLEC
If fstat
 fstat = 0
 If [F:GAC]COA<>COA or [F:GAC]ACCSHO<>ACC
  Read [GAC]GAC1 = COA;ACC
 Endif
Endif
If fstat
 [L]ASTATUS = [V]CST_AERROR
 ERRMES = ACC-"("+COA+")"-mess(38,106,1)
Endif
End [L]ASTATUS


#####################################################################################################################
## CTL_CLSACC
#####################################################################################################################
#**
#* Checks that the account class does not belong to an exceptional account class category. If it is the case
#* the document type must be off balance-sheet
#*
#* @param ACTX   Context
#* @param COA    Chart of accounts
#* @param ACC    Account
#* @param CAT    Accounting journal category (1=Actual ; 2=Active simulation ; 3=Inactive simulation ; 4=Off-balance sheet ; 5=Template)
#* @param ERRMES Error message
#*!
Funprog CTL_CLSACC(ACTX,COA,ACC,CAT,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COA      : # Chart of accounts
Value    Char     ACC      : # Account
Value    Integer  CAT      : # Accounting journal category (1=Actual/2=Active simulation/3=Inactive simulation/4=Off-balance sheet/5=Template)
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
[L]ASTATUS = [V]CST_AOK

Call LEC_COA(COA) From CPTLEC
Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
If CAT<>AVOID.AINT
 If ([F:CLS]TYP=2 & CAT<>4) | ([F:CLS]TYP<>2 & CAT=4)
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = mess(57,106,1)
 Endif
Elsif [F:CLS]TYP=2 : # Case of the Batch entry or the BP invoices entry....
 [L]ASTATUS = [V]CST_AERROR
 ERRMES = mess(57,106,1)
Endif
End [L]ASTATUS


#####################################################################################################################
## CTL_IPTACC
#####################################################################################################################
#**
#* Controls that the imputation of the accounts is correct by checking the list of the accounts (ACC)
#* matching the list of the charts of accounts (COA)
#*
#* @param ACTX    Context
#* @param NBRCOA  Number of charts of accounts
#* @param COA     Array of charts of accounts
#* @param ACC     Array of accounts
#* @param FCTCAC  1 = If the funprog is called from GESCAC ; 0 = otherwise
#* @param ERRMES  Error message
#*!
Funprog CTL_IPTACC(ACTX,NBRCOA,COA,ACC,FCTCAC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  NBRCOA     : # Number of charts of accounts
Value    Char     COA()(1..) : # Array of charts of accounts
Value    Char     ACC()(1..) : # Array of accounts
Value    Integer  FCTCAC     : # 1 = If the funprog is called from GESCAC / 0 = otherwise
Variable Char     ERRMES()   : # Error message

Local Integer ASTATUS
Local Integer ICOA1, ICOA2
Local Integer ICOAORG, ICOADES
Local Char    COAORG(GLONCOA), COADES(GLONCOA) : # Chart of account origin / destination
Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC) : # Account origin / destination

If adxtyp=33 | !clalev([F:GAC1]) : Local File GACCOUNT [GAC1] : Endif
If adxtyp=33 | !clalev([F:GAC2]) : Local File GACCOUNT [GAC2] : Endif

[L]ASTATUS = [V]CST_AOK

For ICOA1=1 To NBRCOA
 COAORG = evalue("[L]COA("+num$(ICOA1)+")")
 ACCORG = evalue("[L]ACC("+num$(ICOA1)+")")
 If ACCORG<>AVOID.ACHAR & ([F:GAC1]COA<>COAORG or [F:GAC1]ACC<>ACCORG)
  Read [GAC1]GAC0 = COAORG ; ACCORG
 Endif
 For ICOA2=ICOA1+1 To NBRCOA
  COADES = evalue("[L]COA("+num$(ICOA2)+")")
  ACCDES = evalue("[L]ACC("+num$(ICOA2)+")")
  If COAORG<>COADES
   If ACCDES<>AVOID.ACHAR & ([F:GAC2]COA<>COADES or [F:GAC2]ACC<>ACCDES)
    Read [GAC2]GAC0 = COADES ; ACCDES
   Endif
   ICOAORG = find(COAORG,[F:GAC2]OTHCOA(0..dim([F:GAC2]OTHCOA)-1))
   ICOADES = find(COADES,[F:GAC1]OTHCOA(0..dim([F:GAC1]OTHCOA)-1))
   If ACCORG<>AVOID.ACHAR & ACCDES<>AVOID.ACHAR
    Gosub CONTACCDESORG
    If [L]ASTATUS >= [V]CST_AERROR
     Break 2
    Endif
   Elsif ACCORG<>AVOID.ACHAR & ACCDES=AVOID.ACHAR
    If ICOADES & [F:GAC1]OBYIPT(ICOADES-1)=2
     [L]ASTATUS = [V]CST_AERROR
     ERRMES = mess(45,102,1)-COAORG-ACCORG-":"-mess(117,102,1)-COADES : Break 2
    Endif
   Elsif ACCORG=AVOID.ACHAR & ACCDES<>AVOID.ACHAR
    If ICOAORG & [F:GAC2]OBYIPT(ICOAORG-1)=2
     [L]ASTATUS = [V]CST_AERROR
     ERRMES = mess(45,102,1)-COADES-ACCDES-":"-mess(117,102,1)-COAORG : Break 2
    Endif
   Endif
  Endif
 Next

Next
End [L]ASTATUS

$CONTACCDESORG
If !ICOADES
 If FCTCAC=1 : # Called from GESCAC function
  ## In the accounting codes function (GESCAC), we do have the possibility to enter account of a chart of account that is not linked
  ## It is the case when we use an accounting code transaction multi legislation
  ## In this case, the control of the imputation on the chart of accounts only sends a warning message
  If ICOA2=NBRCOA
   [L]ASTATUS = fmet ACTX.ASETERROR("",mess(45,102,1)-COAORG-ACCORG-":"-mess(118,102,1)-COADES,[V]CST_AWARNING)
  Endif
 Else
   ERRMES = mess(45,102,1)-COAORG-ACCORG-":"-mess(118,102,1)-COADES
   [L]ASTATUS = [V]CST_AERROR
   Return
 Endif
Elsif !ICOAORG
 If FCTCAC=1 : # Called from GESCAC function
  If ICOA2=NBRCOA
   [L]ASTATUS = fmet ACTX.ASETERROR("",mess(45,102,1)-COADES-ACCDES-":"-mess(118,102,1)-COAORG,[V]CST_AWARNING)
  Endif
 Else
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = mess(45,102,1)-COADES-ACCDES-":"-mess(118,102,1)-COAORG
  Return
 Endif
Endif

If ICOADES>AVOID.AINT
 If ([F:GAC1]DEFACC(ICOADES-1)<>AVOID.ACHAR & [F:GAC1]SCRACC(ICOADES-1)=AVOID.ACHAR & ACCDES<>[F:GAC1]DEFACC(ICOADES-1))
& | ([F:GAC1]SCRACC(ICOADES-1)<>AVOID.ACHAR & pat(ACCDES,[F:GAC1]SCRACC(ICOADES-1))=AVOID.AINT)
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = mess(45,102,1)-COADES-ACCDES-":"-tolower(mess(112,102,1))-COAORG-ACCORG : Return
 Endif
Endif

If ICOAORG>AVOID.AINT
 If ([F:GAC2]DEFACC(ICOAORG-1)<>AVOID.ACHAR & [F:GAC2]SCRACC(ICOAORG-1)=AVOID.ACHAR & ACCORG<>[F:GAC2]DEFACC(ICOAORG-1))
& | ([F:GAC2]SCRACC(ICOAORG-1)<>AVOID.ACHAR & pat(ACCORG,[F:GAC2]SCRACC(ICOAORG-1))=AVOID.AINT)
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = mess(45,102,1)-COAORG-ACCORG-":"-tolower(mess(112,102,1))-COADES-ACCDES : Return
 Endif
Endif
Return


#####################################################################################################################
## CTL_OBYIPTACC
#####################################################################################################################
#**
#* Checks if the imputation of the target chart of accounts on the origin account used as parameters is mandatory or optional
#*
#* @param ACTX   Context
#* @param ORICOA Origin Chart of accounts
#* @param ORIACC Origin account
#* @param DENCOA Destination chart of accounts
#* @param OBYFLG 0=Optional ; 1=Mandatory
#* @param ERRMES Error message
#*!
Funprog CTL_OBYIPTACC(ACTX,ORICOA,ORIACC,DENCOA,OBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     ORICOA()    : # Origin Chart of Account
Value    Char     ORIACC()    : # Origin Account
Value    Char     DENCOA()    : # Destination Chart of Account
Variable Integer  OBYFLG      : # 0:Optional  1:Mandatory
Variable Char     ERRMES()   : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer FOUND

OBYFLG = 0

If DENCOA = "" : End [L]ASTATUS : Endif

[L]ASTATUS = func CTL_ISACC(ACTX,ORICOA,ORIACC,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 End [L]ASTATUS
Else
 FOUND = find(DENCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
 If FOUND
  If [F:GAC]OBYIPT(FOUND-1) = 2
   OBYFLG = 1
  Else
   OBYFLG = 0
  Endif
 Endif
Endif
End [L]ASTATUS


#####################################################################################################################
## _CTL_ACC
#####################################################################################################################
#**
#* @private
#*
#* @param ACTX    Context
#* @param APPCASE Application use
#* @param LEDTYP  Ledger type
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param FCY     Site
#* @param CUR     Currency
#* @param DAT     Date
#* @param CAT     Accounting journal category (1=Actual ; 2=Active simulation ; 3=Inactive simulation ; 4=Off-balance sheet ; 5=Template)
#* @param FCTGAS  1 = If the funprog is called from GESGAS ; 0 = otherwise
#* @param ERRMES  Error message
#*!
Funprog _CTL_ACC(ACTX,APPCASE, LEDTYP,COA,ACC,FCY,CUR,DAT,CAT,FCTGAS,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  APPCASE  : # Application use
Value    Tinyint  LEDTYP   : # Ledger type
Value    Char     COA      : # Chart of accounts
Value    Char     ACC      : # Account
Value    Char     FCY      : # Site
Value    Char     CUR      : # Currency
Value    Date     DAT      : # Date
Value    Integer  CAT      : # Accounting journal category (Actual/Active simulation/Inactive simulation/Off-balance sheet/Template)
Value    Integer  FCTGAS   : # 1 = If the funprog is called from GESGAS / 0 = otherwise
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS
Local Char    LEDCOD(GLONLED)
Local Char    LEDCUR(GLONCUR)


If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If adxtyp=33 | !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If adxtyp=33 | !clalev([F:COA]) : Local File GCOA     [COA] : Endif
If adxtyp=33 | !clalev([F:CLS]) : Local File GACCCLS  [CLS] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif

[L]ASTATUS = [V]CST_AOK
If ACC=AVOID.ACHAR : End [L]ASTATUS : Endif

# Checks that the account exists
[L]ASTATUS = func CTL_ISACC(ACTX,COA,ACC,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES -= "("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
Endif

# Checks the BP authorization of the account because the account is associated with a BP
If (APPCASE=1 & [F:GAC]AUZBPR(0)<>[V]CST_AYES) or (APPCASE=2 & [F:GAC]AUZBPR(1)<>[V]CST_AYES)
 [L]ASTATUS = [V]CST_AERROR
 ERRMES = mess(45,106,1) : End [L]ASTATUS
Endif

# Checks the class of the account
[L]ASTATUS = func CTL_CLSACC(ACTX,COA,ACC,CAT,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES -= "("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
Endif

Call LEC_FCY(FCY) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC

# Checks that the site matches the account site
If FCY<>AVOID.ACHAR # The site is not mandatory (Cf BUO)
 [L]ASTATUS = func CDACFY_SYRA.CTL_SITE(ACTX,[F:GAC]FCY,FCY,ACC,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR
  ERRMES = ERRMES-"("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
 Endif
Endif

#--- Checks the currency of the account
If CUR<>AVOID.ACHAR & [F:GAC]CUR<>AVOID.ACHAR & [F:GAC]CUR<>CUR
 [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,[F:CPY]CPY,LEDTYP,LEDCOD,LEDCUR,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 If CUR<>LEDCUR
  [L]ASTATUS = [V]CST_AERROR
  ERRMES = ACC-mess(13,106,1)-[F:GAC]CUR-"("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
 Else
  If FCTGAS=1 : # Only in the journal entry
   [L]ASTATUS = [V]CST_AWARNING
   ERRMES = ACC-mess(13,106,1)-[F:GAC]CUR : End [L]ASTATUS
  Endif
 Endif
Endif

#--- Checks the validity period of the account
If DAT<>AVOID.ADATE
 [L]ASTATUS = func FINMIS_SYRA.CTL_VLYDAT(ACTX,DAT,[F:GAC]VLYSTR,[F:GAC]VLYEND,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR
  ERRMES = ACC-ERRMES-"("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
 Endif
Endif

#--- Checks the access code of the account
[L]ASTATUS = func FINMIS_SYRA.CTL_EXE(ACTX,[F:GAC]ACS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ACC-ERRMES-"("+mess(LEDTYP,2644,1)+")" : End [L]ASTATUS
Endif

End [L]ASTATUS

