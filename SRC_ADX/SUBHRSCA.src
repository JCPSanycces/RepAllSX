Subprog AM_AFF_LEVDES(VALEUR)
Variable Clbfile VALEUR
[M]LEVDES([M]NUMLIG) = VALEUR
Affzo LEVDES([M]NUMLIG)
#ADNGO - 2017-03-13 - X3-29385 - START
# segay 06/12/12 78468 comme le champ de saisie est un clob et que la sauvegarde est alpha de 250
VALEUR = [M]LEVDES([M]NUMLIG)
[M]AFF_LEVDES = VALEUR
Affzo [M]AFF_LEVDES
#ADNGO - 2017-03-13 - X3-29385 - END
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCA) 19/08/2010 15:41:44 (JML)
######################################################################################
Subprog AV_NBRLIG
Local Integer L_NOL : L_NOL = nolign-1
[M]AFF_LEVDES = [M]LEVDES(L_NOL)
[M]NUMLIG     = L_NOL
Affzo AFF_LEVDES
End

