#<AdxTL>@(#)0.0.0.0 $Revision$
# JML 27/07/10 New table SCALED
Call OBJET("HRSCA",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "RAZCRE"    : Gosub RAZCRE
 When "OUVRE"     : Gosub OUVRE #ADNGO - 2017-03-13 - X3-29385
 When "FERME"     : Gosub FERME #ADNGO - 2017-03-13 - X3-29385
Endcase
Return

#ADNGO - 2017-03-13 - X3-29385 - START
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return
#ADNGO - 2017-03-13 - X3-29385 - END
$LIENS
#ADNGO - 2017-03-13 - X3-29385 - START
If dim([M:SCA]LEG)>0 & [M:SCA]LEG <> ""
  GCURLEG = [M:SCA]LEG
Endif
#ADNGO - 2017-03-13 - X3-29385 - END
For I=0 To dim([F:HRSCA]LEV(I))-1
 If I<=dim([M]LEV)-1 & [F:HRSCA]LEV(I)<>""
  [M]LEV(I)    = [F:HRSCA]LEV(I)
  [M]LEVREF(I) = [F:HRSCA]LEVREF(I)
  [M]OLDLEV(I) = [F:HRSCA]LEV(I)
 Else
  Break
 Endif
Next
[M]NBRLIG = I
# JML 27/07/10 New table SCALED
For nolign=1 To [M]NBRLIG
 Read [HRSDD]SDD0=[M]COD;nolign
 If !fstat
  [M] = [F:HRSDD]
 Endif
Next nolign
Return
#ADNGO - 2017-03-13 - X3-29385 - START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#ADNGO - 2017-03-13 - X3-29385 - END
Return
$VERIF_CRE
$VERIF_MOD
 Sorta [M]NBRLIG [M]NBRLIG Order By [M]LEVREF ([S]indice)
 Affzo [M]10
Return

$MODIF
#ADNGO - 2017-03-13 - X3-29385 - START
Gosub UPDATE_SCALENIV
#ADNGO - 2017-03-13 - X3-29385 - END
# Si le libellé du niveau est modifié il faut répercuter cette modification dans les tables
# qui contiennent le niveau. Attention 2 échelles peuvent avoir le niveau XXX. Quand on modifie
# XXX en YYY il faut répercuter la modif uniquement sur l'échelle.

Gosub DECLARE

For I=0 To [M]NBRLIG-1
 If [M]LEV(I)<>[M]OLDLEV(I)
  # Recherche des champs de type niveau
  Filter [ATZ1] Where CODTYP="NIV" & CODFIC<>"SCALE" & CODFIC<>"TMPMOB"
  For [ATZ1]CODTYP
   FIC    = [F:ATZ1]CODFIC
   NOMZON = [F:ATZ1]CODZONE
   # Recherche de la compétence associée au niveau à modifier
   # Si l'échelle de la compétence est la même que celle du niveau => modifier
   Filter [ATZ2] Where CODFIC=FIC & NUMLIG<[F:ATZ1]NUMLIG & CODTYP="CPC"
   Read [ATZ2]NUMLIG Last
   Filter [ATZ2]
   If !fstat
    NOMCPC = [F:ATZ2]CODZONE
    Local File =FIC [F1]
    Filter [F1] Where find([M]OLDLEV(I),evalue(NOMZON))
    For [F1]
     For J=0 To evalue("dim([F:F1]"+NOMZON+")")-1
      If [M]OLDLEV(I)=evalue(NOMZON+"("+num$(J)+")")
       Call LECTURE("CPC",evalue(NOMCPC+"("+num$(J)+")"),"") From CONTOBJ
       If [F:CPC]CODSCA=[M]COD
        Readlock [F1] Curr
        If fstat=1
         GOK = -1 : GLOCK = "$"-FIC-[M]OLDLEV(I) : Break 4
        Elsif fstat
         GOK = 0 : Call RSTA("F1",[M]OLDLEV(I)) From GLOCK : Break 4
        Endif
        Assign "[F1]"+NOMZON+"("+num$(J)+")" With [M]LEV(I)
        Rewrite [F1]
       Endif
      Endif
     Next
    Next
    Filter [F1]
    Close Local File [F1]
   Endif
  Next
  Filter [ATZ1]
 Endif
Next
# JML 27/07/10 New table SCALED
Gosub CREATION
If GOK<1 : Return : Endif
Return

$DECLARE
Local Integer I, J
Local Char    FIC (GLONATB)
Local Char    NOMZON (GLONAVA)
Local Char    NOMCPC (GLONAVA)
If clalev([F:ATZ1])=0 : Local File ATABZON    [ATZ1] : Endif
If clalev([F:ATZ2])=0 : Local File ATABZON    [ATZ2] : Endif
If clalev([F:CPC])=0  : Local File COMPETENCE [CPC]  : Endif
Return

$RAZCRE
#LIPET - 2017-05-26 - X3-41970 - START
  #29/06/12 - DKA - Default LEG value to users LEGFIL when creating a record
#  If dim([M:SCA]LEG)>0 Then
#    [M:SCA]LEG=GLEGFIL
#    Affzo [M:SCA]LEG
#  Endif
Raz GCURLEG
#LIPET - 2017-05-26 - X3-41970 - END
Return

######################################################################################
# JML 27/07/10 New table SCALED
$CREATION
#ADNGO - 2017-03-13 - X3-29385 - START
Gosub UPDATE_SCALENIV
#ADNGO - 2017-03-13 - X3-29385 - END
Delete [HRSDD] Where [F:HRSDD]COD=[M]COD
If fstat=1
 GOK = -1 : GLOCK = "$SCALED"-[M]COD : Return
Endif
For nolign=1 To [M]NBRLIG
 # JML We write even when it's empty for Crystal report !
 Raz [F:HRSDD]
 [F:HRSDD] = [M]
 [F:HRSDD]NUMLIG = nolign
 Write [HRSDD]
 If fstat
  GOK = 0 : Call FSTA("HRSDD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

#ADNGO - 2017-03-13 - X3-29385 - START
$UPDATE_SCALENIV
#This is to update duplicate table for use in SOA development
If clalev([F:SCN])=0    : Local File SCALENIV [SCN]  : Endif
Delete [SCN] Where [F:SCN]COD=[M:SCA]COD
If fstat=1
 GOK = -1 : GLOCK = "$SCALENIV"-[M:SCA]COD: Return
Endif
For nolign=1 To [M]NBRLIG
 Raz [F:SCN]
 [F:SCN]COD     = [M:SCA]COD
 [F:SCN]DES     = [M:SCA]DES
 [F:SCN]LEV     = [M:SCA]LEV(nolign-1)
 [F:SCN]LEVREF  = [M:SCA]LEVREF(nolign-1)

 Write [SCN]
 If fstat
  GOK = 0 : Call FSTA("SCN") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return
#ADNGO - 2017-03-13 - X3-29385 - END

######################################################################################
######################################################################################
## Etiquettes écran SCA
######################################################################################

# On interdit la suppression d'un niveau si le niveau est déjà utilisé

Subprog C_NBRLIG
Gosub DECLARE
If (status=65 | status=68)
 I = nolign-1
 # Recherche des champs de type niveau
 Filter [ATZ1] Where CODTYP="NIV" & CODFIC<>"SCALE" & CODFIC<>"TMPMOB"
 For [ATZ1]CODTYP
  FIC    = [F:ATZ1]CODFIC
  NOMZON = [F:ATZ1]CODZONE
  # Recherche de la zone compétence associée au niveau.
  # Si la compétence fait référence a la même échelle => suppression impossible
  Filter [ATZ2] Where CODFIC=FIC & NUMLIG<[F:ATZ1]NUMLIG & CODTYP="CPC"
  Read [ATZ2]NUMLIG Last
  Filter [ATZ2]
  If !fstat
   NOMCPC = [F:ATZ2]CODZONE
   Local File =FIC [F1]
   Filter [F1] Where find([M]OLDLEV(I),evalue(NOMZON))
   For [F1]
    For J=0 To evalue("dim([F:F1]"+NOMZON+")")-1
     If [M]OLDLEV(I)=evalue(NOMZON+"("+num$(J)+")")
      Call LECTURE("CPC",evalue(NOMCPC+"("+num$(J)+")"),"") From CONTOBJ
      If [F:CPC]CODSCA=[M]COD
       # Suppression impossible : ce niveau a déjà été saisi dans la table xxxx compétence yyyy
       GMESSAGE = mess(36,10720,1)-FIC-mess(37,10720,1)-[F:CPC]COD
       mkstat = 2 : Break 3
      Endif
     Endif
    Next
   Next
   Filter [F1]
   Close Local File [F1]
  Endif
 Next
 Filter [ATZ1]
Endif
End

Subprog C_LEV(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]LEV(0..[M]NBRLIG-1)) From OBJDIV
End

Subprog C_LEVREF(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR,[M]LEVREF(0..[M]NBRLIG-1)) From OBJDIV
End

