#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPSOL","UTIRECSOL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE 
Endcase
Return

$OUVRE
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:MVS])=0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
Return

$INIT
Gosub OUVRE
TMP = 1
Return 

$INIT_DIA
Return

$EXEC
If [M:DIA]TRACE<>2
 [M:DIA]TRACE=1
Endif
Call RECUPSOL([M:DIA]SOCIETE,[M:DIA]CLI,[M:DIA]FOU,[M:DIA]SOL,[M:DIA]POR,GSERVEUR,0,[M:DIA]TRACE)
TRA = 1
Return

## (appelé depuis CNVEURO)

Subprog RECUPSOL(SOC,CLI,FOU,SOL,POR,BATCH,DIRECT,TRACE)
Value    Char    SOC
Value    Integer CLI
Value    Integer FOU
Value    Integer SOL
Value    Integer POR
Value    Integer BATCH
Value    Integer DIRECT    : # Paramètres de récup non saisis 
Value    Integer TRACE     : # Paramètres de trace

Gosub OUVRE 

Local Integer OK , I , J , K , ARRET, STAT
Local Integer MAXPER , PREMEX
Local Decimal SOLDE, SOLDE_LED
Local Char    SOCIETE(GLONCPY)
Local Char    TIERS(GLONBPR), TIERS_RSK(GLONBPR)
Local Char    DEVISE(GLONCUR)
Local Decimal PORTEFEUILLE(0..2), PORTEFEUILLE_LED(0..2), PORTEFEUILLE_RPT(0..2)
Local Char    CRITERE(250)
Local Char    DEVLED(GLONCUR)
Local Libelle TYPGEN, TYPANA

If [L]TRACE
 If !(BATCH | DIRECT)
  Call OUVRE_TRACE(mess(112,116,1)) From LECFIC : # Récupération des soldes
 Endif
 Call ECR_TRACE(mess(112,116,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If !DIRECT
 Call MONOCPY(SOC, OK) From AX3MONO
 If !OK : Goto FIN : Endif
Endif

If CLI=2
 If SOL=2
  #Resynchronisation des soldes Client
  If [L]TRACE : Call ECR_TRACE(mess(112,116,1)-mess(1,644,1),0) From GESECRAN : Endif
  Gosub REC_SOL_CLI
  If [L]TRACE : Call ECR_TRACE(string$(70,"-"),0) From GESECRAN : Endif
 Endif
 If POR=2
  #Resynchronisation du portefeuille Client
  If [L]TRACE : Call ECR_TRACE(mess(120,116,1)-mess(1,644,1),0) From GESECRAN : Endif
  Gosub REC_POR_CLI
  If [L]TRACE : Call ECR_TRACE(string$(70,"-"),0) From GESECRAN : Endif
 Endif
Endif
If FOU=2
 If SOL=2
  #Resynchronisation des soldes Fournisseur
  If [L]TRACE : Call ECR_TRACE(mess(112,116,1)-mess(2,644,1),0) From GESECRAN : Endif
  Gosub REC_SOL_FOU
  If [L]TRACE : Call ECR_TRACE(string$(70,"-"),0) From GESECRAN : Endif
 Endif
 If POR=2
  #Resynchronisation du portefeuille Fournisseur
  If [L]TRACE : Call ECR_TRACE(mess(120,116,1)-mess(2,644,1),0) From GESECRAN : Endif
  Gosub REC_POR_FOU
  If [L]TRACE : Call ECR_TRACE(string$(70,"-"),0) From GESECRAN : Endif
 Endif
Endif

$FIN
If !DIRECT
 Call MULTICPY(SOC) From AX3MONO # <JFL>
Endif
If [L]TRACE & !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC 
Endif
End

#############################################
##                Client                   ##
#############################################

#############################################
$REC_SOL_CLI
If SOC<>""
 For [CPY] Where CPYLEGFLG=2 & CPY=SOC
  SOCIETE = [F:CPY]CPY : Gosub CLISOC
 Next
Else
 For [CPY] Where CPYLEGFLG=2
  SOCIETE = [F:CPY]CPY : Gosub CLISOC
 Next
Endif
Return

$CLISOC
If [L]TRACE : Call ECR_TRACE(mess(2,45,1)-":"-SOCIETE,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR0
If GOK=1
 # 
 Call SETMAINREF(SOCIETE,TYPGEN,TYPANA) From CPTDIV
 Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]TYPGEN & FIYSTA=2
 Read [FIY]FIY0 First
 PREMEX = [F:FIY]FIYNUM
 Filter [FIY]
 #
 Call SETCUR(1,SOCIETE,DEVLED) From CPTDIV
 #
 Link [BAL] With [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC As [LNK]
 Filter [LNK] Where [F:BAL]LEDTYP = [L]TYPGEN & [F:BAL]CPY=SOCIETE & [F:BAL]FCY="" & [F:BAL]BPR<>"" & [F:GAC]UPDBLC=2 & [F:BAL]FIY>=PREMEX
&  Order By Key CLE = [F:BAL]BPR;[F:BAL]CUR;[F:BAL]FIY
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [LNK]
Endif
If [L]TRACE=2
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

$TR0
GOK = 1
Trbegin [MVC]
 Update [MVC] Where CPY=SOCIETE With BLCC=0, BLCL=0, BLCR=0
Commit
Return

$TR1
GOK = 1
Trbegin [MVC]
 For [LNK]CLE(1)
  TIERS = [F:BAL]BPR
  # On recherche d'abord le tiers risque lié au client 
  If [F:BPC]BPCNUM<>TIERS 
   Read [BPC]BPC0 = TIERS  : If fstat Raz [F:BPC] Endif
  Endif
  If [F:BPC]BPCRSK<>""
   TIERS_RSK = [F:BPC]BPCRSK
   For [LNK]CLE(2)
    DEVISE    = [F:BAL]CUR
    SOLDE     = 0
    SOLDE_LED = 0
    For [LNK]CLE
     Call NBPER([F:BAL]CPY,[L]TYPGEN,[F:BAL]FIY,MAXPER) From CPTSUB  
     If [F:BAL]FIY=PREMEX
      SOLDE += sum([F:BAL]DEB(0..MAXPER))-sum([F:BAL]CDT(0..MAXPER))
      SOLDE_LED += sum([F:BAL]DEBLED(0..MAXPER))-sum([F:BAL]CDTLED(0..MAXPER))
     Else
      SOLDE += sum([F:BAL]DEB(1..MAXPER))-sum([F:BAL]CDT(1..MAXPER))
      SOLDE_LED += sum([F:BAL]DEBLED(1..MAXPER))-sum([F:BAL]CDTLED(1..MAXPER))
     Endif
    Next
    Readlock [MVC]MVC0 = TIERS_RSK;SOCIETE;TIERS;DEVISE
    If fstat=1
     GOK = -1 : GLOCK = "$BPCUSTMVT"-TIERS_RSK-SOCIETE-TIERS-DEVISE : Break 2
    Elsif fstat=0
     [F:MVC]BLCC   = SOLDE
     [F:MVC]BLCL   = SOLDE_LED
     If dim([F:MVC]UPDDAT)>0 : [F:MVC]UPDDAT = date$     : Endif
     If dim([F:MVC]UPDUSR)>0 : [F:MVC]UPDUSR = GUSER     : Endif
     If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif
     Rewrite [MVC]
    Elsif SOLDE<>0
     Raz [F:MVC]
     [F:MVC]BPCRSK  = TIERS_RSK
     [F:MVC]CPY     = SOCIETE
     [F:MVC]BPCNUM  = TIERS
     [F:MVC]CUR     = DEVISE
     If dim([F:MVC]CREDAT)>0 : [F:MVC]CREDAT = date$     : Endif
     If dim([F:MVC]CREUSR)>0 : [F:MVC]CREUSR = GUSER     : Endif
     If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif
     [F:MVC]BLCC   = SOLDE
     [F:MVC]BLCL   = SOLDE_LED
     [F:MVC]ACCCUR = [L]DEVLED
     Write [MVC]
    Else
     fstat = 0
    Endif
    If [L]TRACE=2
     If DEVISE=DEVLED
      Call ECR_TRACE(mess(1,644,1)-TIERS-":"-num$(SOLDE)-DEVISE,0) From GESECRAN
     Else
      Call ECR_TRACE(mess(1,644,1)-TIERS-":"-num$(SOLDE)-DEVISE-"("+num$(SOLDE_LED)-DEVLED+")",0) From GESECRAN
     Endif 
    Endif
    If fstat
     GOK = 0 : Call FSTA("MVC") From GLOCK : Break 3
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
########################################
$REC_POR_CLI
If SOC<>""
 For [CPY] Where CPYLEGFLG=2 & CPY=SOC
  SOCIETE = [F:CPY]CPY : Gosub POR_CLI
 Next
Else
 For [CPY] Where CPYLEGFLG=2
  SOCIETE = [F:CPY]CPY : Gosub POR_CLI
 Next
Endif
Return

$POR_CLI
If [L]TRACE : Call ECR_TRACE(mess(2,45,1)-":"-SOCIETE,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR30
If GOK=1
 Link [PYH] With [TPY]TPY0 = [F:PYH]PAYTYP As [LNK]
 CRITERE  = '[F:PYH]CPY="'+SOCIETE+'" & [F:PYH]BPR<>""'
 CRITERE -= '& [F:TPY]UPDBIL>1 & [F:PYH]AMTNYTBIL<>0 & [F:PYH]BPRTYP=1 & [F:PYH]SNS<>1'
 CRITERE -= '& [F:PYH]STAFLG(9)<>2 & [F:PYH]STAFLG(2)=2'
 Filter [LNK] Where evalue(CRITERE) Order By Key CLE = BPR;CUR
 Call DEBTRANS From GLOCK
 Gosub TR31
 Close Local File [LNK]
Endif
If [L]TRACE=2
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

$TR30
GOK = 1
Trbegin [MVC]
 Update [MVC] Where CPY=SOCIETE With NYTBILC=0, NYTBILL=0, NYTBILR=0
Commit
Return

$AB_TR30
Rollback
Return

$TR31
GOK = 1
Trbegin [MVC]
 Call SETCUR(1,SOCIETE,DEVLED) From CPTDIV
 For [LNK]CLE(1)
  TIERS = [F:PYH]BPR
  # On recherche d'abord le tiers risque lié au client 
  If [F:BPC]BPCNUM<>TIERS 
   Read [BPC]BPC0 = TIERS  : If fstat Raz [F:BPC] Endif
  Endif
  If [F:BPC]BPCRSK<>""
   TIERS_RSK = [F:BPC]BPCRSK
   For [LNK]CLE(2)
    DEVISE = [F:PYH]CUR
    Raz PORTEFEUILLE, PORTEFEUILLE_LED, PORTEFEUILLE_RPT
    For [LNK]CLE
     I = [F:TPY]UPDBIL-2
     PORTEFEUILLE_LED(I) += [F:PYH]AMTNYTBIL 
    Next
    # Conversion des montants en devise de règlement
    For I=0 To 2
     If PORTEFEUILLE_LED(I)<>0
      Call COURMNT(DEVLED,DEVISE,DEVLED,0,[F:PYH]ACCDAT,1,PORTEFEUILLE_LED(I),PORTEFEUILLE(I),0,STAT) From TRTDEV
     Endif
    Next
    If DEVISE=GCURSHR 
     For I=0 To 2
      PORTEFEUILLE_RPT(I) = PORTEFEUILLE(I)
     Next
    Elsif DEVLED=GCURSHR
     For I=0 To 2
      PORTEFEUILLE_RPT(I) = PORTEFEUILLE_LED(I)
     Next
    Else
     For I=0 To 2
      If PORTEFEUILLE_LED(I)<>0
       Call COURMNT(DEVISE,GCURSHR,DEVLED,0,[F:PYH]ACCDAT,1,PORTEFEUILLE(I),PORTEFEUILLE_RPT(I),0,STAT) From TRTDEV
      Endif
     Next
    Endif

    Readlock [MVC]MVC0 = TIERS_RSK;SOCIETE;TIERS;DEVISE
    If fstat=1
     GOK = -1 : GLOCK = "$BPCUSTMVT"-TIERS_RSK-SOCIETE-TIERS-DEVISE : Break 2
    Elsif fstat=0
     For I=0 To dim([F:MVC]NYTBILC)-1
      [F:MVC]NYTBILC(I) = PORTEFEUILLE(I)
      [F:MVC]NYTBILL(I) = PORTEFEUILLE_LED(I)
      [F:MVC]NYTBILR(I) = PORTEFEUILLE_RPT(I)
     Next I
     If dim([F:MVC]UPDDAT)>0 : [F:MVC]UPDDAT = date$     : Endif
     If dim([F:MVC]UPDUSR)>0 : [F:MVC]UPDUSR = GUSER     : Endif
     If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif
     Rewrite [MVC]
     If fstat
      GOK = 0 : Call FSTA("MVC") From GLOCK : Break 2
     Endif
    Else
     Raz [F:MVC]
     [F:MVC]BPCRSK  = TIERS_RSK
     [F:MVC]CPY     = SOCIETE
     [F:MVC]BPCNUM  = TIERS
     [F:MVC]CUR     = DEVISE
     [F:MVC]ACCCUR  = [L]DEVLED
     If dim([F:MVC]CREDAT)>0 : [F:MVC]CREDAT = date$     : Endif
     If dim([F:MVC]CREUSR)>0 : [F:MVC]CREUSR = GUSER     : Endif
     If dim([F:MVC]EXPNUM)>0 : [F:MVC]EXPNUM = [C]EXPORT : Endif
     For I=0 To dim([F:MVC]NYTBILC)-1
      [F:MVC]NYTBILC(I) = PORTEFEUILLE(I)
      [F:MVC]NYTBILL(I) = PORTEFEUILLE_LED(I)
      [F:MVC]NYTBILR(I) = PORTEFEUILLE_RPT(I)
     Next I
     Write [MVC]
     If fstat
      GOK = 0 : Call FSTA("MVC") From GLOCK : Break 2
     Endif
    Endif
    If [L]TRACE=2
     For I=0 To dim([F:MVC]NYTBILC)-1
      If PORTEFEUILLE(I)<>0 
       If DEVISE<>DEVLED & DEVISE<>GCURSHR & DEVLED<>GCURSHR
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE-"("+num$(PORTEFEUILLE_LED(I))-DEVLED+","-num$(PORTEFEUILLE_RPT(I))-GCURSHR+")",0) From GESECRAN
       Elsif DEVISE<>DEVLED 
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE-"("+num$(PORTEFEUILLE_LED(I))-DEVLED+")",0) From GESECRAN
       Else
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE,0) From GESECRAN
       Endif
      Endif
     Next I
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR31
 Elsif !GOK : Goto AB_TR31
 Endif
Commit
Return

$AB_TR31
Rollback
Return

$ROLL_TR31
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR31 : Endif


#############################################
##              Fournisseur                ##
#############################################

#################################################
$REC_SOL_FOU
If SOC<>""
 For [CPY] Where CPYLEGFLG=2 & CPY=SOC
  SOCIETE = [F:CPY]CPY : Gosub FOUSOC
 Next
Else
 For [CPY] Where CPYLEGFLG=2
  SOCIETE = [F:CPY]CPY : Gosub FOUSOC
 Next
Endif
Return

$FOUSOC
If [L]TRACE : Call ECR_TRACE(mess(2,45,1)-":"-SOCIETE,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR40
If GOK=1
 #
 Call SETMAINREF(SOCIETE,TYPGEN,TYPANA) From CPTDIV
 Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]TYPGEN & FIYSTA=2
 Read [FIY]FIY0 First
 PREMEX = [F:FIY]FIYNUM
 Filter [FIY]
 #
 Call SETCUR(1,SOCIETE,DEVLED) From CPTDIV
 #
 Link [BAL] With [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC As [LNK]
 Filter [LNK] Where [F:BAL]LEDTYP = [L]TYPGEN & [F:BAL]CPY=SOCIETE & [F:BAL]FCY="" & [F:BAL]BPR<>"" & [F:GAC]UPDBLC=3 & [F:BAL]FIY>=PREMEX
&  Order By Key CLE = [F:BAL]BPR;[F:BAL]CUR;[F:BAL]FIY
 Call DEBTRANS From GLOCK
 Gosub TR41
 Close Local File [LNK]
Endif
If [L]TRACE=2
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

$TR40
GOK = 1
Trbegin [MVS]
 Update [MVS] Where CPY=SOCIETE With BLCAMTC=0,BLCAMTL=0,BLCAMTR=0
Commit
Return

$TR41
GOK = 1
Trbegin [MVS]
 For [LNK]CLE(1)
  TIERS = [F:BAL]BPR
  # On recherche d'abord le tiers risque lié au fournisseur 
  If [F:BPS]BPSNUM<>TIERS
   Read [BPS] BPS0=TIERS : If fstat  Raz [F:BPS] : Endif
  Endif
  If [F:BPS]BPSRSK<>""
   TIERS_RSK = [F:BPS]BPSRSK
   For [LNK]CLE(2)
    DEVISE = [F:BAL]CUR
    SOLDE     = 0
    SOLDE_LED = 0
    For [LNK]CLE
     Call NBPER([F:BAL]CPY,[L]TYPGEN,[F:BAL]FIY,MAXPER) From CPTSUB  
     If [F:BAL]FIY=PREMEX
      SOLDE += sum([F:BAL]DEB(0..MAXPER))-sum([F:BAL]CDT(0..MAXPER))
      SOLDE_LED += sum([F:BAL]DEBLED(0..MAXPER))-sum([F:BAL]CDTLED(0..MAXPER))
     Else
      SOLDE += sum([F:BAL]DEB(1..MAXPER))-sum([F:BAL]CDT(1..MAXPER))
      SOLDE_LED += sum([F:BAL]DEBLED(1..MAXPER))-sum([F:BAL]CDTLED(1..MAXPER))
     Endif
    Next
    Readlock [MVS]MVS0 = TIERS_RSK;SOCIETE;TIERS;DEVISE
    If fstat=1
     GOK = -1 : GLOCK = "$BPSUPPMVT"-TIERS_RSK-SOCIETE-TIERS-DEVISE : Break 2
    Elsif fstat=0
     [F:MVS]BLCAMTC = -SOLDE
     [F:MVS]BLCAMTL = -SOLDE_LED
     If dim([F:MVS]UPDDAT)>0 : [F:MVS]UPDDAT = date$     : Endif
     If dim([F:MVS]UPDUSR)>0 : [F:MVS]UPDUSR = GUSER     : Endif
     If dim([F:MVS]EXPNUM)>0 : [F:MVS]EXPNUM = [C]EXPORT : Endif
     Rewrite [MVS]
    Elsif SOLDE<>0
     Raz [F:MVS]
     [F:MVS]BPSRSK  = TIERS_RSK
     [F:MVS]CPY     = SOCIETE
     [F:MVS]BPSNUM  = TIERS
     [F:MVS]CUR     = DEVISE
     [F:MVS]ACCCUR  = [L]DEVLED
     [F:MVS]BLCAMTC = -SOLDE
     [F:MVS]BLCAMTL = -SOLDE_LED
     If dim([F:MVS]CREDAT)>0 : [F:MVS]CREDAT = date$     : Endif
     If dim([F:MVS]CREUSR)>0 : [F:MVS]CREUSR = GUSER     : Endif
     If dim([F:MVS]EXPNUM)>0 : [F:MVS]EXPNUM = [C]EXPORT : Endif
     Write [MVS]
    Else
     fstat = 0
    Endif
    If [L]TRACE=2
     If DEVISE=DEVLED
      Call ECR_TRACE(mess(2,644,1)-TIERS-":"-num$(-SOLDE)-DEVISE,0) From GESECRAN
     Else
      Call ECR_TRACE(mess(2,644,1)-TIERS-":"-num$(-SOLDE)-DEVISE-"("-num$(+SOLDE_LED)-DEVLED+")",0) From GESECRAN
     Endif 
    Endif
    If fstat
     GOK = 0 : Call FSTA("MVS") From GLOCK : Break 2
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR41
 Elsif !GOK : Goto AB_TR41
 Endif
Commit
Return

$AB_TR41
Rollback
Return

$ROLL_TR41
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR41 : Endif
Return

########################################
$REC_POR_FOU
If SOC<>""
 For [CPY] Where CPYLEGFLG=2 & CPY=SOC
  SOCIETE = [F:CPY]CPY : Gosub POR_FOU
 Next
Else
 For [CPY] Where CPYLEGFLG=2
  SOCIETE = [F:CPY]CPY : Gosub POR_FOU
 Next
Endif
Return

$POR_FOU
If [L]TRACE : Call ECR_TRACE(mess(2,45,1)-":"-SOCIETE,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR50
If GOK=1
 Link [PYH] With [TPY]TPY0 = [F:PYH]PAYTYP As [LNK]
 CRITERE  = '[F:PYH]CPY="'+SOCIETE+'" & [F:PYH]BPR<>""'
 CRITERE -= '& [F:TPY]UPDBIL>1 & [F:PYH]AMTNYTBIL<>0 & [F:PYH]BPRTYP=2 & [F:PYH]SNS=1'
 CRITERE -= '& [F:PYH]STAFLG(9)<>2 & [F:PYH]STAFLG(2)=2'
 Filter [LNK] Where evalue(CRITERE) Order By Key CLE = BPR;CUR
 Call DEBTRANS From GLOCK
 Gosub TR51
 Close Local File [LNK]
Endif
If [L]TRACE=2
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

$TR50
GOK = 1
Trbegin [MVS]
 Update [MVS] Where CPY=SOCIETE With BILAMTC=0, BILAMTL=0, BILAMTR=0
Commit
Return

$AB_TR50
Rollback
Return

$TR51
GOK = 1
Trbegin [MVS]
 Call SETCUR(1,SOCIETE,DEVLED) From CPTDIV
 For [LNK]CLE(1)
  TIERS = [F:PYH]BPR
  # On recherche d'abord le tiers risque lié au fournisseur 
  If [F:BPS]BPSNUM<>TIERS
   Read [BPS] BPS0=TIERS : If fstat  Raz [F:BPS] : Endif
  Endif
  If [F:BPS]BPSRSK<>""
   TIERS_RSK = [F:BPS]BPSRSK
   For [LNK]CLE(2)
    DEVISE = [F:PYH]CUR
    Raz PORTEFEUILLE, PORTEFEUILLE_LED, PORTEFEUILLE_RPT
    For [LNK]CLE
     I = [F:TPY]UPDBIL-2
     PORTEFEUILLE_LED(I) += [F:PYH]AMTNYTBIL 
    Next
    # Conversion des montants en devise de règlement
    For I=0 To 2
     If PORTEFEUILLE_LED(I)<>0
      Call COURMNT(DEVLED,DEVISE,DEVLED,0,[F:PYH]ACCDAT,1,PORTEFEUILLE_LED(I),PORTEFEUILLE(I),0,STAT) From TRTDEV
     Endif
    Next
    If DEVISE=GCURSHR 
     For I=0 To 2
      PORTEFEUILLE_RPT(I) = PORTEFEUILLE(I)
     Next
    Elsif DEVLED=GCURSHR
     For I=0 To 2
      PORTEFEUILLE_RPT(I) = PORTEFEUILLE_LED(I)
     Next
    Else
     For I=0 To 2
      If PORTEFEUILLE_LED(I)<>0
       Call COURMNT(DEVISE,GCURSHR,DEVLED,0,[F:PYH]ACCDAT,1,PORTEFEUILLE(I),PORTEFEUILLE_RPT(I),0,STAT) From TRTDEV
      Endif
     Next
    Endif

    Readlock [MVS]MVS0 = TIERS_RSK;SOCIETE;TIERS;DEVISE
    If fstat=1
     GOK = -1 : GLOCK = "$BPSUPPMVT"-TIERS_RSK-SOCIETE-TIERS-DEVISE : Break 2
    Elsif fstat=0
     For I=0 To dim([F:MVS]BILAMTC)-1
      [F:MVS]BILAMTC(I) = PORTEFEUILLE(I)
      [F:MVS]BILAMTL(I) = PORTEFEUILLE_LED(I)
      [F:MVS]BILAMTR(I) = PORTEFEUILLE_RPT(I)
     Next I
     If dim([F:MVS]UPDDAT)>0 : [F:MVS]UPDDAT = date$     : Endif
     If dim([F:MVS]UPDUSR)>0 : [F:MVS]UPDUSR = GUSER     : Endif
     If dim([F:MVS]EXPNUM)>0 : [F:MVS]EXPNUM = [C]EXPORT : Endif
     Rewrite [MVS]
     If fstat
      GOK = 0 : Call FSTA("MVS") From GLOCK : Break 2
     Endif
    Else
     Raz [F:MVS]
     [F:MVS]BPSRSK  = TIERS_RSK
     [F:MVS]CPY     = SOCIETE
     [F:MVS]BPSNUM  = TIERS
     [F:MVS]CUR     = DEVISE
     [F:MVS]ACCCUR  = [L]DEVLED
     For I=0 To dim([F:MVS]BILAMTC)-1
      [F:MVS]BILAMTC(I) = PORTEFEUILLE(I)
      [F:MVS]BILAMTL(I) = PORTEFEUILLE_LED(I)
      [F:MVS]BILAMTR(I) = PORTEFEUILLE_RPT(I)
     Next I
     If dim([F:MVS]CREDAT)>0 : [F:MVS]CREDAT = date$     : Endif
     If dim([F:MVS]CREUSR)>0 : [F:MVS]CREUSR = GUSER     : Endif
     If dim([F:MVS]EXPNUM)>0 : [F:MVS]EXPNUM = [C]EXPORT : Endif
     Write [MVS]
     If fstat
      GOK = 0 : Call FSTA("MVS") From GLOCK : Break 2
     Endif
    Endif
    If [L]TRACE=2
     For I=0 To dim([F:MVS]BILAMTC)-1
      If PORTEFEUILLE(I)<>0 
       If DEVISE<>DEVLED & DEVISE<>GCURSHR & DEVLED<>GCURSHR
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE-"("+num$(PORTEFEUILLE_LED(I))-DEVLED+","-num$(PORTEFEUILLE_RPT(I))-GCURSHR+")",0) From GESECRAN
       Elsif DEVISE<>DEVLED 
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE-"("+num$(PORTEFEUILLE_LED(I))-DEVLED+")",0) From GESECRAN
       Else
        Call ECR_TRACE(mess(1,644,1)-TIERS-mess(I+2,680,1)-":"-num$(PORTEFEUILLE(I))-DEVISE,0) From GESECRAN
       Endif
      Endif
     Next I
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR51
 Elsif !GOK : Goto AB_TR51
 Endif
Commit
Return

$AB_TR51
Rollback
Return

$ROLL_TR51
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR51 : Endif
