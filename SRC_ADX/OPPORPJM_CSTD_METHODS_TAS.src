##Variable Instance LOGFILE Using C_ALOG : #
##Local Integer ARET_VALUE
#
#Local Integer ILINE
#
#  # -------------------
#  If this.TCHACTION <> "TIMEENTRY" Then
#    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
#    Return
#  Endif
#  # -------------------
#  If PJMTIMEMP.PIMTASCOD = AVOID.ACHAR Then
#    # Nothing to do this is not linked to a task
#    Return
#  Endif
#  # -------------------
#  ILINE = fmet this.TAS_GET_INDEX(PJMTIMEMP.TASCOD)
#  If ILINE < 1 Then
#    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), PJMTIMEMP.TASCOD), [V]CST_AERROR)
#    Return
#  Endif
#  # -------------------
#  If this.TAS(ILINE).TASSTATE = 4 or this.TAS(ILINE).TASSTATE = 9 Then
#    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR)
#    Return
#  Endif
#  # -------------------
#  this.TAS(ILINE).TCHACTION = "TIMEENTRY"
#  # -------------------
#  [L]ARET_VALUE = fmet this.TAS(ILINE).TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE)
#  # -------------------
#Return
# Issue X3-69372 - 2018-04-03 by FGR/SINGC : END

###################################################################################################
$TAS_PROGRESS_ALL_TASKS
#Value char UOM ()
#Local Decimal ARET_VALUE

Local Decimal NCSMTOT
Local Decimal NRMNTOT
Local Decimal IRET
Local Decimal NI

  [L]ARET_VALUE = 0
  # -------------------
  NCSMTOT = fmet this.TAS_COMPUTE_CSMQTY_ALL_TASKS(UOM)
  NRMNTOT = fmet this.TAS_COMPUTE_RMNQTY_ALL_TASKS(UOM)
  # -------------------
  If NCSMTOT <> 0 Then
    [L]ARET_VALUE = ar2(NCSMTOT / (NCSMTOT + NRMNTOT) * 100)
  Endif
Return

###################################################################################################
$TAS_PROGRESS
#Value char COD ()
#Local Decimal ARET_VALUE

Local Decimal NCSMTOT
Local Decimal NRMNTOT
Local Decimal IRET

  [L]ARET_VALUE = 0
  # ----------------------------------------
  If fmet this.TAS_GET_INDEX(COD) > 0 Then
    NCSMTOT = 0
    NRMNTOT = 0
    IRET = fmet this._TAS_PROGRESS(COD, NCSMTOT, NRMNTOT)
    If NCSMTOT <> 0 Then
      [L]ARET_VALUE = ar2(NCSMTOT / (NCSMTOT + NRMNTOT) * 100)
    Endif
  Endif
  # ----------------------------------------
Return

###################################################################################################
$_TAS_PROGRESS
#Value Char COD ()
#Variable decimal NCSMTOT
#Variable decimal NRMNTOT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer NI
Local Integer NI1
Local Integer IRET
Local Decimal NLCSMTOT
Local Decimal NLRMNTOT

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  NLCSMTOT = 0
  NLRMNTOT = 0
  # ----------------------------------------
  ILINE = fmet this.TAS_GET_INDEX(COD)
  If ILINE > 0 Then
    IRET = fmet this.TAS(ILINE).RTKO_GET_PROGRESS(NLCSMTOT, NLRMNTOT)
    NCSMTOT += NLCSMTOT
    NRMNTOT += NLRMNTOT
    # ----------------------------------------
    NI = find(COD, this.TAS(1..maxtab(this.TAS)).TASPAE)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_PROGRESS(this.TAS(NI).TASCOD, NCSMTOT, NRMNTOT))
        If [L]ARET_VALUE <> [V]CST_AOK Then
          Break
        Endif
      Endif
      NI1 = NI
      NI = find(COD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
  # ----------------------------------------
Return

###################################################################################################
$_TASK_RITT_SOQQTY
#Variable Instance TECSOQITM Using C_TECSOQITM : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer ITASLINE
Local Integer IITMLINE
Local Decimal NQTY

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If this.TCHACTION <> "SOQQTY" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # ------------------------------------
  For NI = 1 To maxtab(TECSOQITM.SOQ)
    If TECSOQITM.SOQ(NI) <> null and find(TECSOQITM.SOQ(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ITASLINE = fmet this.TAS_GET_INDEX(TECSOQITM.SOQ(NI).TASCOD)
      IITMLINE = fmet this.TAS(ITASLINE).RITT_GET_INDEX_ITMREF(TECSOQITM.SOQ(NI).ITMREF)
      NQTY = fmet this.TAS(ITASLINE).RITT(IITMLINE).SUM_SOQ_QTYSTU(TECSOQITM.SOQ(NI).PJT, TECSOQITM.SOQ(NI).ITMREF)
      If this.TAS(ITASLINE).RITT(IITMLINE).SOQQTY <> NQTY Then
        this.TAS(ITASLINE).RITT(IITMLINE).TCHACTION = "SOQQTY"
        this.TAS(ITASLINE).RITT(IITMLINE).SOQQTY = NQTY
      Endif
    Endif
  Next NI
  # ------------------------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    # Need to do this test before, because TAS_RITT_STKALL_CHGALL is in its own database transaction.
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_RITT_STKALL_CHGALL(TECSOQITM))
  Endif
Return

#######################################################################################
$_TASK_RITT_ALLOCATION
#Variable Instance TECALLITM Using C_TECALLITM : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer ITASLINE
Local Integer IITMLINE
Local Decimal NQTY

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If this.TCHACTION <> "ALLOC" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # ------------------------------------
  For NI = 1 To maxtab(TECALLITM.RITT)
    If TECALLITM.RITT(NI) <> null and find(TECALLITM.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ITASLINE = fmet this.TAS_GET_INDEX(TECALLITM.RITT(NI).TASCOD)
      IITMLINE = fmet this.TAS(ITASLINE).RITT_GET_INDEX_ITMREF(TECALLITM.RITT(NI).ITMREF)
      #
      this.TAS(ITASLINE).RITT(IITMLINE).TCHACTALLOC = "ALLOC"
      Case TECALLITM.RITT(NI).CALLER
        When "SALES"
          this.TAS(ITASLINE).RITT(IITMLINE).ODLQTY += TECALLITM.RITT(NI).ODLQTY
          this.TAS(ITASLINE).RITT(IITMLINE).DLVQTY += TECALLITM.RITT(NI).DLVQTY
          this.TAS(ITASLINE).RITT(IITMLINE).ALLQTY -= TECALLITM.RITT(NI).ALLQTY
        When "MANUF"
          this.TAS(ITASLINE).RITT(IITMLINE).ALLQTY += TECALLITM.RITT(NI).ALLQTY
        When "MANUAL"
          this.TAS(ITASLINE).RITT(IITMLINE).ALLQTY  = TECALLITM.RITT(NI).ALLQTY
          this.TAS(ITASLINE).RITT(IITMLINE).SHTQTY  = TECALLITM.RITT(NI).SHTQTY
      Endcase
    Endif
  Next NI
  # ------------------------------------
Return

#######################################################################################
$TAS_COMPUTE_EXTQTY_ALL_TASKS
#Variable Char UOM ()
#Local Decimal ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI).TASPAE = AVOID.ACHAR Then
        [L]ARET_VALUE += fmet this.TAS_COMPUTE_EXTQTY(this.TAS(NI).TASCOD, UOM)
      Endif
    Endif
  Next NI
Return

#######################################################################################
$TAS_COMPUTE_EXTQTY
#Value Char TAS ()
#Value Char UOM ()
#Local Decimal ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = 0
  # ------------------------
  If TAS <> AVOID.ACHAR Then
    ILINE = fmet this.TAS_GET_INDEX(TAS)
    If ILINE > 0 Then
      [L]ARET_VALUE = fmet this._TAS_COMPUTE_EXTQTY(TAS, UOM)
    Endif
  Endif
Return

#######################################################################################
$_TAS_COMPUTE_EXTQTY
#Value Char TAS ()
#Value Char UOM ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = 0
  # ------------------------
  ILINE = fmet this.TAS_GET_INDEX(TAS)
  If ILINE > 0 Then
    IISPARENT = fmet this.TAS_IS_PARENT(TAS)
    If IISPARENT = [V]CST_AYES Then
      NI = find(TAS, this.TAS(1..maxtab(this.TAS)).TASPAE)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._TAS_COMPUTE_EXTQTY(this.TAS(NI).TASCOD, UOM)
        Endif
        NI1 = NI
        NI = find(TAS, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # ----------------------------------------
    [L]ARET_VALUE += fmet this.TAS(ILINE).RTKO_COMPUTE_EXTQTY(UOM)
    # ----------------------------------------
  Endif
Return

