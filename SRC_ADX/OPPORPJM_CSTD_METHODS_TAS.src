#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORPJM
#######################################################################################
# METHODS linked to TAS collection                                                    #
#######################################################################################
#######################################################################################
$TAS_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If this.TAS(LIN) <> null Then
    this.TAS(LIN).CUR = this.CUR
    this.TAS(LIN).OPPCMP = this.OPPCMP
    this.TAS(LIN).TCHCHGTYP = this.TCHCHGTYP
    this.TAS(LIN).TASBUDAUT = [V]CST_ANO         # Technical property given by the parent only for a new task. Not on READ
  Endif
Return

#######################################################################################
$TAS_GET_INDEX
#Value char COD

  [L]ARET_VALUE = 0
  # ------------------------
  If COD <> AVOID.ACHAR Then
    [L]ARET_VALUE = find(COD,this.TAS(1..maxtab(this.TAS)).TASCOD)
  Endif
Return

#######################################################################################
$TAS_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

#######################################################################################
$TAS_DISABLE_ALL
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI).PIMPL.PIMSTA = [V]CST_AYES Then
        this.TAS(NI).PIMPL.TCHACTION = "STATUS"
        this.TAS(NI).PIMPL.PIMSTA = [V]CST_ANO
      Endif
    Endif
  Next NI
Return

#######################################################################################
$TAS_ENABLE_ALL
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI).PIMPL.PIMSTA = [V]CST_ANO Then
        If fmet this.TAS_IS_PARENT(this.TAS(NI).TASCOD) = [V]CST_ANO Then
          If this.TAS(NI).TASSTATE <> 4 and this.TAS(NI).TASSTATE <> 9 and (this.OPPSTATE = 2 or this.OPPSTATE = 3) Then
            this.TAS(NI).PIMPL.TCHACTION = "STATUS"
            this.TAS(NI).PIMPL.PIMSTA = [V]CST_AYES
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

#######################################################################################
$TAS_IS_PARENT
#Value Char COD ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------
  If COD <> AVOID.ACHAR Then
    NI = find(COD, this.TAS(1..maxtab(this.TAS)).TASPAE)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = [V]CST_AYES
        Break
      Else
        NI1 = NI
        NI = find(COD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Endif
    Wend
  Endif
Return

#######################################################################################
$TAS_CHECK_TASPAE_VALID
#Value Char COD ()
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IINDEX

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If COD = AVOID.ACHAR Then
    # If COD is empty nothing to do
    Return
  Endif
  # --------------------------------
  ILINE = fmet this.TAS_GET_INDEX(COD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("TASCOD", func AFNC.MES1(mess(245,2260,1), COD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  If this.TAS(ILINE).TASPAE = AVOID.ACHAR Then
    # If the budget line haven't a parent code, there is nothing to do
    Return
  Endif
  # --------------------------------
  If this.TAS(ILINE).TASCOD = this.TAS(ILINE).TASPAE Then
    # the parent code must be different of the budget code
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("TASPAE", func AFNC.MES2(mess(238,2260,1), this.TAS(ILINE).TASPAE, this.TAS(ILINE).TASCOD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  IINDEX = fmet this.TAS_GET_INDEX(this.TAS(ILINE).TASPAE)
  If IINDEX < 0 Then
    # the parent budget code must exist as a budget
    [L]ASTATUS = max([L]ARET_VALUE, fmet this.SETERROR("TASCOD", func AFNC.MES2(mess(161,2260,1), this.TAS(ILINE).TASCOD, this.TAS(ILINE).TASPAE), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  # Recursive method which check that the curent parent is not parent of a lower level
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CHECK_TASPAE_VALID(this.TAS(ILINE).TASCOD, this.TAS(ILINE).TASPAE))
  # --------------------------------
Return

#######################################################################################
# Recursive method which check that the PARENT budget code given is not a parent on a lower level
$_TAS_CHECK_TASPAE_VALID
#Value Char COD ()
#Value Char PARENT ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If COD = AVOID.ACHAR Then
    # If COD is empty nothing to do
    Return
  Endif
  NI = find(COD, this.TAS(1..maxtab(this.TAS)).TASPAE)
  While NI > 0
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If fmet this.TAS_IS_PARENT(this.TAS(NI).TASCOD) = [V]CST_AYES Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CHECK_TASPAE_VALID(this.TAS(NI).TASCOD, PARENT))
        If [L]ARET_VALUE <> [V]CST_AOK Then
          Break
        Endif
      Endif
      If this.TAS(NI).TASPAE = PARENT Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(240,2260,1), PARENT), [V]CST_AERROR))
        Break
      Endif
    Endif
    NI1 = NI
    NI = find(COD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
    If NI > 0 Then
      NI += NI1
    Endif
  Wend
Return

#######################################################################################
$TAS_GET_EFFECTIVE_DATE
#Value Char TASCOD ()
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Value Integer ITTSEQ
#Variable Date RETDATE
#Local Integer ARET_VALUE

Local Integer ITASLINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Raz RETDATE
  ITASLINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ITASLINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  If OPENUM <> 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ITASLINE).RTKO_GET_EFFECTIVE_DATE(OPENUM, OPESPLNUM, RETDATE))
  Endif
  If ITTSEQ <> 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ITASLINE).RITT_GET_EFFECTIVE_DATE(RETDATE)) # Issue X3-63079 - 2017-11-14 by ALMON : Start : ITTSEQ not required
  Endif
Return

#######################################################################################
$TAS_GET_COST_EFFECTIVE_RATE
#Value Char TASCOD ()
#Value Char OPEITM ()
#Value Char OPENUM ()
#Value Char OPESPLNUM ()
#Value Char ITTSEQ ()
#Variable Char CUR ()
#Variable Char UOM ()
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Integer ITASLINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Raz CUR
  Raz UOM
  Raz RATE
  # --------------------------------
  ITASLINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ITASLINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ITASLINE).RTKO_GET_COST_EFFECTIVE_RATE(OPENUM, OPESPLNUM, 0,CUR, UOM, RATE))
  # --------------------------------
Return

#######################################################################################
$TAS_GET_COST_TYPE
#Value Char TASCOD ()
#Value Char OPENUM ()
#Value Char OPESPLNUM ()
#Value Char ITTSEQ
#Variable Char CUR ()
#Variable Char UOM ()
#Variable Decimal PCCCOD()
#Local Integer ARET_VALUE

Local Integer ITASLINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Raz CUR
  Raz UOM
  Raz PCCCOD
  # --------------------------------
  ITASLINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ITASLINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ITASLINE).RTKO_GET_COST_TYPE(OPENUM, OPESPLNUM, CUR, UOM, PCCCOD))
  # --------------------------------
Return

#######################################################################################
$TAS_GET_PARENTS
#Value Char CODE ()
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer INBTAB

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Raz STBCODE
  INBTAB = 0
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(CODE)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), CODE), [V]CST_AERROR))
  Endif
  # -------------------
  If ILINE > 0 Then
    INBTAB += 1
    STBCODE(INBTAB) = this.TAS(ILINE).TASCOD
    If this.TAS(ILINE).TASPAE <> AVOID.ACHAR Then
      Repeat
        ILINE = fmet this.TAS_GET_INDEX(this.TAS(ILINE).TASPAE)
        If ILINE > 0 Then
          INBTAB += 1
          STBCODE(INBTAB) = this.TAS(ILINE).TASCOD
        Endif
      Until ILINE = 0
    Endif
  Endif
  # -------------------
Return

#######################################################################################
$TAS_GET_FAMILY
#Value Char CODE ()
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer INBTAB

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Raz STBCODE
  INBTAB = 0
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(CODE)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), CODE), [V]CST_AERROR))
  Endif
  # -------------------
  If ILINE > 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_GET_FAMILY(CODE, INBTAB, STBCODE))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_GET_FAMILY
#Value Char CODE ()
#Variable Integer INBTAB
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  ILINE = fmet this.TAS_GET_INDEX(CODE)
  # -------------------
  If ILINE > 0 Then
    IISPARENT = fmet this.TAS_IS_PARENT(CODE)
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(CODE, this.TAS(1..maxtab(this.TAS)).TASPAE)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_GET_FAMILY(this.TAS(NI).TASCOD, INBTAB, STBCODE))
        Endif
        NI1 = NI
        NI = find(CODE, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # -------------------
    INBTAB += 1
    STBCODE(INBTAB) = CODE
    # -------------------
  Endif
Return

#######################################################################################
$TAS_PLANNED
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT

  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "TASK_PLANNED" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  If this.TAS(ILINE).TASSTATE <> 1 or this.TAS(ILINE).TASSTATE = 2 or this.TAS(ILINE).TASSTATE = 4 or this.TAS(ILINE).TASSTATE = 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  If IISPARENT = [V]CST_ANO Then
    If this.TAS(ILINE).PIMPL.PIMTYP <> 6 and this.TAS(ILINE).PIMPL.PIMTYP <> 7 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(436,2260,1), mess(this.TAS(ILINE).PIMPL.PIMTYP,2254,1)), [V]CST_AERROR))
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_PLANNED(TASCOD, LOGFILE, TECOPPACT))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_PLANNED
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If this.TCHACTION <> "TASK_PLANNED" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  # -------------------
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  # -------------------
  If IISPARENT = [V]CST_ANO Then
    If this.TAS(ILINE).TASSTARTDT = [0/0/0] or this.TAS(ILINE).TASENDDT = [0/0/0] Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(310,2260,1), TASCOD), [V]CST_AERROR))
    Endif
    If this.TAS(ILINE).PBUCOD = AVOID.ACHAR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(312,2260,1), TASCOD), [V]CST_AERROR))
    Endif
    If [L]ARET_VALUE <> [V]CST_AOK Then
      Return
    Endif
  Endif
  # -------------------
  If IISPARENT = [V]CST_AYES Then
    NI = find(TASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_PLANNED(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT))
        If [L]ARET_VALUE <> [V]CST_AOK Then
          Break
        Endif
      Endif
      NI1 = NI
      NI = find(TASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    If IISPARENT = [V]CST_ANO Then
      If this.TAS(ILINE).PIMPL.PIMTYP = 6 or this.TAS(ILINE).PIMPL.PIMTYP = 7 Then
        If this.TAS(ILINE).TASSTATE = 1 Then
          # -------------------
          this.TAS(ILINE).TCHACTION = "PLANNED"
          this.TAS(ILINE).TASSTATE = 5
          If TECOPPACT.EVTDAT = [0/0/0] Then
            this.TAS(ILINE).TASDATP = date$
          Else
            this.TAS(ILINE).TASDATP = TECOPPACT.EVTDAT
          Endif
          this.TAS(ILINE).TASCOMTEX = TECOPPACT.COMTEX
          # Only for operationals tasks
          this.TAS(ILINE).TASTYP = 2       # Operational
          # Not necessary to loop on RITT : Propagated on TASSTATE is doing it to force update
        Endif
      Endif
    Endif
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_PARENT_NEW(TASCOD, LOGFILE, TECOPPACT))
  Endif
Return

#######################################################################################
$TAS_LAUNCH
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  # Preliminary checkes
  # -------------------
  If this.TCHACTION <> "TASK_LAUNCH" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  If (this.TAS(ILINE).TASSTATE <> 1 and this.TAS(ILINE).TASSTATE <> 5) or this.TAS(ILINE).TASSTATE = 4 or this.TAS(ILINE).TASSTATE = 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_LAUNCH(TASCOD, LOGFILE, TECOPPACT))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_LAUNCH
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "TASK_LAUNCH" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  # -------------------
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  # -------------------
  If IISPARENT = [V]CST_ANO Then
    If this.TAS(ILINE).TASSTARTDT = [0/0/0] or this.TAS(ILINE).TASENDDT = [0/0/0] Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(310,2260,1), TASCOD), [V]CST_AERROR))
    Endif
    If this.TAS(ILINE).PBUCOD = AVOID.ACHAR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(312,2260,1), TASCOD), [V]CST_AERROR))
    Endif
    If [L]ARET_VALUE <> [V]CST_AOK Then
      Return
    Endif
    # -------------------
    For NI = 1 To maxtab(this.TAS(ILINE).RTKO)
      If this.TAS(ILINE).RTKO(NI) <> null and find(this.TAS(ILINE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TAS(ILINE).RTKO(NI).OPESTR = [0/0/0] Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("OPESTR", func AFNC.MES3(mess(447,2260,1), TASCOD, num$(this.TAS(ILINE).RTKO(NI).OPENUM), num$(this.TAS(ILINE).RTKO(NI).OPESPLNUM)) ,
&                                                               [V]CST_AERROR))
        Endif
        If this.TAS(ILINE).RTKO(NI).OPEEND = [0/0/0] Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("OPEEND", func AFNC.MES3(mess(448,2260,1), TASCOD, num$(this.TAS(ILINE).RTKO(NI).OPENUM), num$(this.TAS(ILINE).RTKO(NI).OPESPLNUM)) ,
&                                                               [V]CST_AERROR))
        Endif
        # --------------------
        For NI1 = 1 To maxtab(this.TAS(ILINE).RTKO(NI).RAFFT)
          If this.TAS(ILINE).RTKO(NI).RAFFT(NI1) <> null and find(this.TAS(ILINE).RTKO(NI).RAFFT(NI1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(ILINE).RTKO(NI).RAFFT(NI1).POASTR = [0/0/0] Then
              [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("POASTR", func AFNC.MES4(mess(460,2260,1), TASCOD, num$(this.TAS(ILINE).RTKO(NI).OPENUM),
&                                                                             num$(this.TAS(ILINE).RTKO(NI).OPESPLNUM), this.TAS(ILINE).RTKO(NI).RAFFT(NI1).POACLB) , [V]CST_AERROR))
            Endif
            If this.TAS(ILINE).RTKO(NI).RAFFT(NI1).POAEND = [0/0/0] Then
              [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("POAEND", func AFNC.MES4(mess(461,2260,1), TASCOD, num$(this.TAS(ILINE).RTKO(NI).OPENUM),
&                                                                             num$(this.TAS(ILINE).RTKO(NI).OPESPLNUM), this.TAS(ILINE).RTKO(NI).RAFFT(NI1).POACLB) , [V]CST_AERROR))
            Endif
          Endif
        Next NI1
        # --------------------
      Endif
    Next NI
  Endif
  # -------------------
  If IISPARENT = [V]CST_AYES Then
    NI = find(TASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_LAUNCH(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT))
        If [L]ARET_VALUE <> [V]CST_AOK Then
          Break
        Endif
      Endif
      NI1 = NI
      NI = find(TASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    If this.TAS(ILINE).TASSTATE = 1 or this.TAS(ILINE).TASSTATE = 5 Then
      # -------------------
      this.TAS(ILINE).TCHACTION = "LAUNCH"
      this.TAS(ILINE).TASSTATE = 2
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.TAS(ILINE).TASDATL = date$
      Else
        this.TAS(ILINE).TASDATL = TECOPPACT.EVTDAT
      Endif
      this.TAS(ILINE).TASCOMTEX = TECOPPACT.COMTEX
      If IISPARENT = [V]CST_ANO and this.TAS(ILINE).PIMPL.PIMTYP <> 8 Then
        # Only for operationals tasks
        this.TAS(ILINE).TASTYP = 2               # Operational
        this.TAS(ILINE).TASTLA = [V]CST_ANO
        this.TAS(ILINE).PIMPL.TCHACTION = "STATUS"
        this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_AYES
        # -------------------
        For NI = 1 To maxtab(this.TAS(ILINE).RTKO)
          If this.TAS(ILINE).RTKO(NI) <> null and find(this.TAS(ILINE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            this.TAS(ILINE).RTKO(NI).TCHACTION = "IN_PROGRESS"
            this.TAS(ILINE).RTKO(NI).OPESTA = 4
          Endif
        Next NI
        # ------------------
        # Boucle sur la collection article
        # For NI = 1 To maxtab(this.TAS(ILINE).RITT)
        #  pour chaque article appel modif MTP ==> MTF
        #  Si erreur break +
        # Next NI
        # ------------------
      Endif
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_PARENT_NEW(TASCOD, LOGFILE, TECOPPACT))
    Endif
  Endif
Return

#######################################################################################
$_TAS_PARENT_NEW
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer ILINECUR
Local Integer ILINEPAE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "TASK_PLANNED" and this.TCHACTION <> "TASK_LAUNCH" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  # -------------------
  If this.TAS(ILINE).TASPAE <> AVOID.ACHAR Then
    ILINECUR = ILINE
    Repeat
      ILINEPAE = fmet this.TAS_GET_INDEX(this.TAS(ILINECUR).TASPAE)
      If this.TAS(ILINEPAE).TASSTATE = 1 Then
        this.TAS(ILINEPAE).TCHACTION = "STARTED"
        # -------------------
        this.TAS(ILINEPAE).TASSTATE = 3
        If TECOPPACT.EVTDAT = [0/0/0] Then
          this.TAS(ILINEPAE).TASDATB = date$
        Else
          this.TAS(ILINEPAE).TASDATB = TECOPPACT.EVTDAT
        Endif
        this.TAS(ILINEPAE).TASCOMTEX = TECOPPACT.COMTEX
        # -------------------
      Endif
      # -------------------
      If this.TAS(ILINEPAE).TASPAE <> AVOID.ACHAR Then
        ILINECUR = ILINEPAE
      Else
        ILINECUR = -1
      Endif
    Until ILINECUR = -1
  Endif
Return

#######################################################################################
$TAS_CLOSING
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  # Preliminary checkes
  # -------------------
  If this.TCHACTION <> "TASK_CLOSING" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  #If this.TAS(ILINE).TASSTATE <> 2 and this.TAS(ILINE).TASSTATE <> 3 and this.TAS(ILINE).TASSTATE <> 5 Then                                    # Issue X3-85933 - 2018-06-19 by FGR : "New" allowed
  If this.TAS(ILINE).TASSTATE <> 1 and this.TAS(ILINE).TASSTATE <> 2 and this.TAS(ILINE).TASSTATE <> 3 and this.TAS(ILINE).TASSTATE <> 5 Then   # Issue X3-85933 - 2018-06-19 by FGR : "New" allowed
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1) - "(" + TASCOD + ")"), [V]CST_AERROR))
  Endif
  # -------------------
  # Issue X3-101833 - 2018-08-02 by FGR : BEGIN
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_RITT_CLOSE_RELEASE_UNDER(TASCOD, AVOID.ACHAR))
  # Issue X3-101833 - 2018-08-02 by FGR : END
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CLOSING(TASCOD, LOGFILE, TECOPPACT))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_CLOSING
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "BUDGET_CLOSING" and this.TCHACTION <> "TASK_CLOSING" and this.TCHACTION <> "CLOSING" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  If this.TCHACTION = "TASK_CLOSING" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(TASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CLOSING(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE > [V]CST_AWARNING Then          # Issue X3-101833 - 2018-07-30 by FGR : If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(TASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    If (this.TCHACTION = "TASK_CLOSING" and
&      (this.TAS(ILINE).TASSTATE = 1 or this.TAS(ILINE).TASSTATE = 2 or this.TAS(ILINE).TASSTATE = 3 or this.TAS(ILINE).TASSTATE = 5)) or
&     ((this.TCHACTION = "CLOSING" or this.TCHACTION = "BUDGET_CLOSING") and this.TAS(ILINE).TASSTATE <> 4)
&   Then # Issue X3-85933 - 2018-06-19 by FGR : "New" allowed
      # -------------------
      this.TAS(ILINE).TCHACTION = "CLOSING"
      # -------------------
      this.TAS(ILINE).TASSTATE = 4
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.TAS(ILINE).TASDATS = date$
      Else
        this.TAS(ILINE).TASDATS = TECOPPACT.EVTDAT
      Endif
      this.TAS(ILINE).TASCOMTEX = TECOPPACT.COMTEX
      this.TAS(ILINE).PRCCPL = 100
      # -------------------
      # Only for operationals tasks
      If this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_AYES Then
        this.TAS(ILINE).PIMPL.TCHACTION = "STATUS"
        this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_ANO
      Endif
      # -------------------
      If IISPARENT = [V]CST_ANO Then
        For NI = 1 To maxtab(this.TAS(ILINE).RTKO)
          If this.TAS(ILINE).RTKO(NI) <> null and find(this.TAS(ILINE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(ILINE).RTKO(NI).OPESTA <> 5 Then
              this.TAS(ILINE).RTKO(NI).TCHACTION = "CLOSING"
              this.TAS(ILINE).RTKO(NI).OPESTA = 5
              this.TAS(ILINE).RTKO(NI).RMNQTY = 0
              If TECOPPACT.EVTDAT = [0/0/0] Then
                this.TAS(ILINE).RTKO(NI).OPEDATS = date$
              Else
                this.TAS(ILINE).RTKO(NI).OPEDATS = TECOPPACT.EVTDAT
              Endif
            Endif
          Endif
        Next NI
      Endif
    Endif
  Endif
Return

#######################################################################################
$TAS_SUSPENSION
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  # Preliminary checkes
  # -------------------
  If this.TCHACTION <> "TASK_SUSPENSION" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  If this.TAS(ILINE).TASSTATE = 4 and this.TAS(ILINE).TASSTATE = 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_SUSPENSION(TASCOD, LOGFILE, TECOPPACT))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_SUSPENSION
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "BUDGET_SUSPENSION" and this.TCHACTION <> "TASK_SUSPENSION" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  If this.TCHACTION = "TASK_SUSPENSION" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(TASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_SUSPENSION(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(TASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    If this.TAS(ILINE).TASSTATE <> 4 and this.TAS(ILINE).TASSTATE <> 9 Then
      # -------------------
      this.TAS(ILINE).TCHACTION = "SUSPENSION"
      this.TAS(ILINE).TASSTATE = 9
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.TAS(ILINE).TASDATH = date$
      Else
        this.TAS(ILINE).TASDATH = TECOPPACT.EVTDAT
      Endif
      this.TAS(ILINE).TASCOMTEX = TECOPPACT.COMTEX
      # -------------------
      # Only for operationals tasks
      If this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_AYES Then
        this.TAS(ILINE).PIMPL.TCHACTION = "STATUS"
        this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_ANO
      Endif
      # -------------------
      If IISPARENT = [V]CST_ANO Then
        For NI = 1 To maxtab(this.TAS(ILINE).RTKO)
          If this.TAS(ILINE).RTKO(NI) <> null and find(this.TAS(ILINE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(ILINE).RTKO(NI).OPESTA <> 5 Then
              this.TAS(ILINE).RTKO(NI).TCHACTION = "SUSPENSION"
              this.TAS(ILINE).RTKO(NI).OPESTA = 1
              If TECOPPACT.EVTDAT = [0/0/0] Then
                this.TAS(ILINE).RTKO(NI).OPEDATH = date$
              Else
                this.TAS(ILINE).RTKO(NI).OPEDATH = TECOPPACT.EVTDAT
              Endif
            Endif
          Endif
        Next NI
      Endif
    Endif
  Endif
Return

#######################################################################################
$TAS_REACTIVATE
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IBUDLINE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  # Preliminary checkes
  # -------------------
  If this.TCHACTION <> "TASK_REACTIVATE" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), TASCOD), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  If this.TAS(ILINE).TASSTATE <> 4 and this.TAS(ILINE).TASSTATE <> 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------
  IBUDLINE = fmet this.BUD_GET_INDEX(this.TAS(ILINE).PBUCOD)
  If IBUDLINE > 0 Then
    If this.BUD(IBUDLINE).PBUSTATE <> 2 and this.BUD(IBUDLINE).PBUSTATE <> 3 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES3(mess(472,2260,1), this.TAS(ILINE).PBUCOD, mess(this.BUD(IBUDLINE).PBUSTATE,2251,1), this.TAS(ILINE).PBUCOD),
&                                                          [V]CST_AERROR))
    Endif
  Else
    If fmet this.TAS_IS_PARENT(TASCOD) = [V]CST_ANO Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(218,2260,1), this.TAS(ILINE).PBUCOD, this.OPPNUM), [V]CST_AERROR))
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_REACTIVATE(TASCOD, LOGFILE, TECOPPACT))
  Endif
  # -------------------
Return

#######################################################################################
$_TAS_REACTIVATE
#Value Char TASCOD ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1
Local Integer IBUDLINE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "TASK_REACTIVATE" and this.TCHACTION <> "BUDGET_REACTIVATE" and this.TCHACTION <> "REACTIVATE" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
  If this.TCHACTION = "TASK_REACTIVATE" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(TASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_REACTIVATE(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(TASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    # -------------------
    IBUDLINE = fmet this.BUD_GET_INDEX(this.TAS(ILINE).PBUCOD)
    If IBUDLINE = 0 or
&      (IBUDLINE > 0 and (this.BUD(IBUDLINE).PBUSTATE = 1 or this.BUD(IBUDLINE).PBUSTATE = 2 or this.BUD(IBUDLINE).PBUSTATE = 3))
&   Then
      If this.TAS(ILINE).TASSTATE = 4 or this.TAS(ILINE).TASSTATE = 9 Then
        # -------------------
        this.TAS(ILINE).TCHACTION = "REACTIVATE"
        # -------------------
        If this.TAS(ILINE).TASDATS <> [0/0/0] Then
          Raz this.TAS(ILINE).TASDATS
        Endif
        If this.TAS(ILINE).TASDATH <> [0/0/0] Then
          Raz this.TAS(ILINE).TASDATH
        Endif
        # -------------------
        If this.TAS(ILINE).TASDATH <> [0/0/0] Then
          this.TAS(ILINE).TASSTATE = 9
        Elsif this.TAS(ILINE).TASDATB <> [0/0/0] Then
          this.TAS(ILINE).TASSTATE = 3
        Elsif this.TAS(ILINE).TASDATL <> [0/0/0] Then
          this.TAS(ILINE).TASSTATE = 2
        Elsif this.TAS(ILINE).TASDATP <> [0/0/0] Then
          this.TAS(ILINE).TASSTATE = 5
        Else
          this.TAS(ILINE).TASSTATE = 1
          If this.TAS(ILINE).TASTYP = 2 Then
            this.TAS(ILINE).TASTYP = 1
          Endif
        Endif
        this.TAS(ILINE).TASCOMTEX = TECOPPACT.COMTEX
        If IISPARENT = [V]CST_ANO Then
          # Only for operationals tasks
          If this.TAS(ILINE).TASSTATE <> 1 and this.TAS(ILINE).TASSTATE <> 5 and this.TAS(ILINE).PIMPL.PIMTYP <> 8 Then  # Issue X3-5293/119288 - 2016-10-20 by FGR
            If this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_ANO Then
              this.TAS(ILINE).PIMPL.TCHACTION = "STATUS"
              this.TAS(ILINE).PIMPL.PIMSTA = [V]CST_AYES
            Endif
          Endif
          For NI = 1 To maxtab(this.TAS(ILINE).RTKO)
            If this.TAS(ILINE).RTKO(NI) <> null and find(this.TAS(ILINE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              this.TAS(ILINE).RTKO(NI).TCHACTION = "REACTIVATE"
              If this.TAS(ILINE).RTKO(NI).OPEDATS = [0/0/0] Then
                this.TAS(ILINE).RTKO(NI).OPESTA = 1
              Else
                this.TAS(ILINE).RTKO(NI).OPESTA = 4
              Endif
              If this.TAS(ILINE).RTKO(NI).OPEDATH <> [0/0/0] Then
                Raz this.TAS(ILINE).RTKO(NI).OPEDATH
              Endif
            Endif
          Next NI
        Endif
      Endif
    Endif
  Endif
Return

###################################################################################################
$TAS_IS_BUDGET_USED
#Value Char BUDGET ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_ANO
  # -------------------
  If BUDGET <> AVOID.ACHAR Then
    NI = find(BUDGET, this.TAS(1..maxtab(this.TAS)).PBUCOD)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = [V]CST_AYES
        Break
      Else
        NI1 = NI
        NI = find(BUDGET, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
        If NI > 0 Then
          NI += NI1
        Endif
      Endif
    Wend
  Endif
Return

# Issue X3-69372 - 2018-04-03 by FGR/SINGC : BEGIN
###################################################################################################
$TAS_TIMEENTRY
#Variable Instance PJMTIMEMP Using C_PJMTIMEMP : #
#Variable Instance TECPTETAS Using C_TECPTETAS : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.TCHACTION <> "TIMEENTRY" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  If TECPTETAS.IACTION = [V]CST_ADEL Then
    If PJMTIMEMP.snapshot.PIMTASCOD = AVOID.ACHAR Then
      # Nothing to do this is not linked to a task
      Return
    Endif
    ILINE = fmet this.TAS_GET_INDEX(PJMTIMEMP.snapshot.TASCOD)
    If ILINE < 1 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), PJMTIMEMP.snapshot.TASCOD), [V]CST_AERROR))
      Return
    Endif
    If this.TAS(ILINE).snapshot.TASSTATE = 4 or this.TAS(ILINE).snapshot.TASSTATE = 9 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).snapshot.TASSTATE,2250,1)), [V]CST_AERROR))
      Return
    Endif
  Else
    If PJMTIMEMP.PIMTASCOD = AVOID.ACHAR Then
      # Nothing to do this is not linked to a task
      Return
    Endif
    ILINE = fmet this.TAS_GET_INDEX(PJMTIMEMP.TASCOD)
    If ILINE < 1 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), PJMTIMEMP.TASCOD), [V]CST_AERROR))
      Return
    Endif
    If this.TAS(ILINE).TASSTATE = 4 or this.TAS(ILINE).TASSTATE = 9 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR))
      Return
    Endif
  Endif
  this.TAS(ILINE).TCHACTION = "TIMEENTRY"
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ILINE).TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE))
Return

#$TAS_TIMEENTRY
