    # -------------------
  Endif
Return

###################################################################################################
$TAS_START_DATE
#Local Date ARET_VALUE

Local Integer NI

  Raz [L]ARET_VALUE
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If [L]ARET_VALUE = [0/0/0] Then
        [L]ARET_VALUE = this.TAS(NI).TASSTARTDT
      Else
        If this.TAS(NI).TASSTARTDT <> [0/0/0] and this.TAS(NI).TASSTARTDT < [L]ARET_VALUE Then
          [L]ARET_VALUE = this.TAS(NI).TASSTARTDT
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$TAS_END_DATE
#Local Date ARET_VALUE

Local Integer NI

  Raz [L]ARET_VALUE
  # ------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If [L]ARET_VALUE = [0/0/0] Then
        [L]ARET_VALUE = this.TAS(NI).TASENDDT
      Else
        If this.TAS(NI).TASENDDT <> [0/0/0] and this.TAS(NI).TASENDDT > [L]ARET_VALUE Then
          [L]ARET_VALUE = this.TAS(NI).TASENDDT
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$TAS_START_END_DATE
#Value Char BUD ()
#Variable Char STRDAT ()
#Variable Char ENDDAT ()
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IRED

  [L]ARET_VALUE = [V]CST_AOK
  # ----------------------------------------
  Raz STRDAT
  Raz ENDDAT
  If BUD = AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(555,2260,1), [V]CST_AERROR))
  Else
    ILINE = fmet this.BUD_GET_INDEX(BUD)
    If ILINE < 1 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUD), [V]CST_AERROR))
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_START_END_DATE(BUD, STRDAT, ENDDAT))
    Endif
  Endif
Return

#######################################################################################
$_TAS_START_END_DATE
#Value Char BUD ()
#Variable Char STRDAT ()
#Variable Char ENDDAT ()
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # ----------------------------------------
  ILINE = fmet this.BUD_GET_INDEX(BUD)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUD)
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUD, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_START_END_DATE(this.BUD(NI).PBUCOD, STRDAT, ENDDAT))
          If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(BUD, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # ----------------------------------------
    NI = find(BUD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If STRDAT = [0/0/0] or this.TAS(NI).TASSTARTDT < STRDAT Then
          STRDAT = this.TAS(NI).TASSTARTDT
        Endif
        If ENDDAT = [0/0/0] or this.TAS(NI).TASENDDT > ENDDAT Then
          ENDDAT = this.TAS(NI).TASENDDT
        Endif
      Endif
      NI1 = NI
      NI = find(BUD, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
Return

###################################################################################################
$TAS_GET_PIMDESAXX
#Value Char TASCOD ()
#Local Char ARET_VALUE(250)

Local Integer NI

  Raz [L]ARET_VALUE
  # -------------------
  NI = fmet this.TAS_GET_INDEX(TASCOD)
  If NI > 0 Then
    [L]ARET_VALUE = this.TAS(NI).PIMPL.PIMDESAXX
  Endif
  # -------------------
Return

###################################################################################################
$TAS_MIN_STRDAT
# Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # -------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If [L]ARET_VALUE = 0 and this.TAS(NI).TASSTARTDT <> AVOID.ADATE Then
        [L]ARET_VALUE = NI
      Else
        If this.TAS(NI).TASSTARTDT <> AVOID.ADATE and this.TAS(NI).TASSTARTDT < this.TAS([L]ARET_VALUE).TASSTARTDT Then
          [L]ARET_VALUE = NI
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$TAS_MAX_ENDDAT
# Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # -------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If [L]ARET_VALUE = 0 and this.TAS(NI).TASENDDT <> AVOID.ADATE Then
        [L]ARET_VALUE = NI
      Else
        If this.TAS(NI).TASENDDT <> AVOID.ADATE and this.TAS(NI).TASENDDT > this.TAS([L]ARET_VALUE).TASENDDT Then
          [L]ARET_VALUE = NI
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$TAS_CHECK_MANUF_INVENTORY
#Value Char STASCOD ()
#Variable Char SLSTTXT ()
#Local Integer ARET_VALUE

Local Integer ILINE

  # Issue X3-101833 - 2018-07-30 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Raz SLSTTXT
  ILINE = fmet this.TAS_GET_INDEX(STASCOD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), STASCOD), [V]CST_AERROR))
  Endif
  If ILINE > 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CHECK_MANUF_INVENTORY(STASCOD, SLSTTXT))
  Endif
  If [L]ARET_VALUE > [V]CST_AWARNING Then
    Raz SLSTTXT
  Endif
Return

###################################################################################################
$_TAS_CHECK_MANUF_INVENTORY
#Value Char STASCOD ()
#Variable Char SLSTTXT ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1
Local Integer ILINE
Local Integer IISPARENT

  # Issue X3-101833 - 2018-07-30 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  ILINE = fmet this.TAS_GET_INDEX(STASCOD)
  IISPARENT = fmet this.TAS_IS_PARENT(STASCOD)
  If IISPARENT = [V]CST_AYES Then
    NI = find(STASCOD, this.TAS(1..maxtab(this.TAS)).TASPAE)
    While NI > 0
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TAS_CHECK_MANUF_INVENTORY(this.TAS(NI).TASCOD, SLSTTXT))
        If [L]ARET_VALUE > [V]CST_AWARNING Then
          Break
        Endif
      Endif
      NI1 = NI
      NI = find(STASCOD, this.TAS(NI+1..maxtab(this.TAS)).TASPAE)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
  If [L]ARET_VALUE > [V]CST_AWARNING Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS(ILINE).RITT_CHECK_MANUF_INVENTORY(AVOID.ACHAR, SLSTTXT))
  Endif
Return

