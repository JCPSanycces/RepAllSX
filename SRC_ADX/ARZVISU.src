#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(10)(1..4) , VALEUR(10)
Local Integer OK
PARAM(1) = "POSCOD"
PARAM(2) = "POSCOD"
PARAM(3) = "1"
Call S_AFF_CHAR(VALEUR,PARAM,"NEWVER","ARZVISU","") From GACTION
#Call TRAITE_CHAR(VALEUR,PARAM,"ARZVISU","ARZVISU","",1,"") From GTRAITE
End

#-----------------------------#
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "FIN"     : Gosub FIN
 When "TRT_DIV" : Gosub TRT_DIV
Endcase
Return

#-----------------------------#
$OUVRE
Local Integer T , VER , FUL
Local Char    PATNAM(30) , CODPAR(GLONARZ)
If clalev([F:ARA])=0 : Local File AREPORTA [ARA] : Endif
[L]PATNAM = PARAM(1)
[L]CODPAR = PARAM(2)
[L]VER    = val(PARAM(3))
Return

#-----------------------------#
$DEBUT
[M:ARA0]PATNAM = [L]PATNAM
[M:ARA0]CODPAR = [L]CODPAR
[M:ARA0]VER    = [L]VER
Read [ARA]ARA2(2)=[M]PATNAM;[M]VER
If fstat : Raz [F:ARA] : Endif
[M:ARA0]TYPPAT = [F:ARA]TYPPAT

T = [F:ARA]TIMSTP
[M:ARA0]TIMSTP = func SUBADC.CNVTIM(T)

Affzo [ARA0]

FUL = 0
nolign = 0
[M:ARA1]NBE = 0
[M:ARA4]NBM = 0
For [ARA]ARA0 Where PATNAM=[M]PATNAM & TIMSTP=[L]T & TYP=1
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  If [M:ARA0]TYPPAT=1 : # Parsing
   If nolign>=dim([M:ARA1]LIG)
    FUL = nolign+1 : Break
   Endif  
   nolign += 1
   [M:ARA1]LIG(nolign-1) = [F:ARA]LIG(I)
   [M:ARA1]NBE = nolign
  Else
   If nolign>=dim([M:ARA4]LIG)
    FUL = nolign+1 : Break
   Endif  
   nolign += 1
   [M:ARA4]LIG(nolign-1) = [F:ARA]LIG(I)
   [M:ARA4]NBM = nolign
  Endif
 Next I
Next ARA 
Affzo [ARA1]
Affzo [ARA4]

nolign = 0
For [ARA]ARA0 Where PATNAM=[M]PATNAM & TIMSTP=[L]T & TYP=2
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  If nolign>=dim([M:ARA2]LIG)
   FUL = nolign+1 : Break
  Endif  
  nolign += 1
  [M:ARA2]LIG(nolign-1) = [F:ARA]LIG(I)
 Next I
Next ARA 
[M:ARA2]NBL = nolign
Affzo [ARA2]

nolign = 0
For [ARA]ARA0 Where PATNAM=[M]PATNAM & TIMSTP=[L]T & TYP=3
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  If nolign>=dim([M:ARA2]LIG)
   FUL = nolign+1 : Break
  Endif  
  nolign += 1
  [M:ARA3]LIG(nolign-1) = [F:ARA]LIG(I)
 Next I
Next ARA 
[M:ARA3]NBP = nolign
Affzo [ARA3]

If FUL
 Call MESSAGE(mess(161,115,1)-'('+num$(FUL)+')') From GESECRAN : # Trop de lignes
Endif
Return

#-----------------------------#
$FIN
PARAM(3) = num$([M]VER)
Return

#-------------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "NEWVER" : Gosub NEWVER
Endcase
Return

#-----------------------------#
$NEWVER
Local Integer TIMSTP , VER , TYPPAT , OLDVER
Local Char    PATNAM(30) , CODPAR(GLONARZ) , MESSAGE(250) , VALCAR(10)

If clalev([F:ARA])=0 : Local File AREPORTA [ARA] : Endif

[L]PATNAM = PARAM(1)
[L]CODPAR = PARAM(2)
[L]VER    = val(PARAM(3))
Call VERIF_VERSION([L]PATNAM,[L]TIMSTP,OK)
Read [ARA]ARA0(1)=[L]PATNAM
If !fstat
 [L]OLDVER = [F:ARA]VER
 [L]TYPPAT = [F:ARA]TYPPAT
Else
 Call SAICAR(VALCAR,"",mess(36,143,1),"M",7869,10,"",OK) From GESECRAN : # Type de pattern
 If !OK : Return : Endif
 [L]TYPPAT = val(VALCAR)
 OLDVER = 0
Endif
Call ECLATEMENT([L]PATNAM,[L]CODPAR,[L]TYPPAT,[L]TIMSTP,MESSAGE,OK)
If !OK
 Call ERREUR(MESSAGE) From GESECRAN
Else
 Read [ARA]ARA0(2)=[L]PATNAM;[L]TIMSTP
 [L]VER = [F:ARA]VER
Endif
If OLDVER<>[L]VER
 PARAM(3) = num$([L]VER)
 Call MESSAGE(num$([L]VER)-":"-mess(50,143,1)) From GESECRAN : # Nouvelle version
 If clalev([M:ARZ1])>0
  [M:ARZ1]VER = [L]VER : Affzo [M:ARZ1]VER
 Endif
Else
 Call MESSAGE(mess(51,143,1)) From GESECRAN : # Pas de nouvelle version
Endif
Return

#------------------------------------------------------------#
Subprog ECLATEMENT(PATNAM,CODPAR,TYPPAT,TIMSTP,MESSAGE,OK)
Value    Char    PATNAM
Value    Char    CODPAR
Value    Integer TYPPAT , TIMSTP
Variable Char    MESSAGE
Variable Integer OK

Local    Char    LIGNE(250) , FICHIER(250)
Local    Integer DFR , FMEND , LIG , NBDATA , NBHEAD , NBFOOT
Local    Integer XAD , XZD , XAF , XZF , VER

If clalev([F:ARA])=0 : Local File AREPORTA [ARA] : Endif
If clalev([F:ARZ])=0 : Local File AREPORTZ [ARZ] : Endif

FICHIER = filpath("PAT",[L]PATNAM,"PAT")
If filinfo(FICHIER,0)<=0
 MESSAGE = "|"+FICHIER+"|\"+mess(32,143,1) : # Fichier pattern inexistant
 OK = 0 : End
Endif

Openi FICHIER Using [PATT]
Iomode adxifs "" Using [PATT]
Iomode adxirs chr$(10) Using [PATT]
Iomode adxium GASCII Using [PATT]

Call DEBTRANS From GLOCK
Case [L]TYPPAT
 When 1 : Gosub TR1 : # Parsing
 When 2 : Gosub TR2 : # Masque
Endcase
If GOK=1
 OK = 1
Else
 MESSAGE = mess(35,110,1) : # Erreur transactionnelle
 OK = 0
Endif

Openi Using [PATT]

Close Local File [ARA] , [ARZ]
End

#---------------#
# Parsing
#---------------#

$TR1
Trbegin [ARA]
 Read [ARA]ARA0(2)=[L]PATNAM;[L]TIMSTP
 If !fstat
  [L]VER = [F:ARA]VER
  Delete [ARA] Where PATNAM=[L]PATNAM & TIMSTP=[L]TIMSTP
  If fstat
   GOK=0 : Call FSTA("ARA") From GLOCK : Goto AB_TR1
  Endif
 Else
  # On recherche le plus grand numéro de version pour ce pattern
  Read [ARA]ARA1(1)=[L]PATNAM
  If fstat
   Raz [F:ARA]
  Endif
  [L]VER = [F:ARA]VER+1
 Endif

 Raz NBDATA, NBHEAD, NBFOOT
 Raz [F:ARA]
 Rdseq [L]LIGNE Using [PATT]
 While !fstat
  [L]LIG += 1
  If ![L]FMEND
   If [L]NBHEAD=0
    [F:ARA]PATNAM  = [L]PATNAM
    [F:ARA]TIMSTP  = [L]TIMSTP : # Provient du Call VERIF_VERSION
    [F:ARA]TYPPAT  = 1         : # Parsing
    [F:ARA]VER     = [L]VER    : # Permet la sélection de la version à imprimer
    [F:ARA]TYP     = 1
    [F:ARA]SEQ     = 1
    Raz [F:ARA]LIG
    [F:ARA]CREUSR  = GUSER
    [F:ARA]CREDAT  = date$
   Elsif [L]NBHEAD>=dim([F:ARA]LIG)
    # Nouveau n° de séquence
    Write [F:ARA]
    If fstat
     GOK=0 : Call FSTA("ARA") From GLOCK : Break
    Endif
    [F:ARA]SEQ += 1
    Raz [F:ARA]LIG
    [L]NBHEAD = 0
   Endif
   [F:ARA]LIG([L]NBHEAD) = [L]LIGNE
   [L]NBHEAD += 1
  Else
   # Le format a été recopié, on passe maintenant aux data
   If instr(1,[L]LIGNE,"^XA")
    If [L]XAD=0
     [L]XAD = [L]LIG
    Elsif [L]XAF=0
     [L]XAF = [L]LIG
    Endif
   Elsif instr(1,[L]LIGNE,"^XZ")
    If [L]XZD=0
     [L]XZD = [L]LIG
    Elsif [L]XZF=0
     [L]XZF = [L]LIG
    Endif
   Endif
   # Composition du tableau des lignes liées aux données
   If [L]XAD<>0 and ([L]XZD=0 or [L]LIG<=[L]XZD)
    If [L]NBDATA=0
     Write [F:ARA] : # On écrit l'enreg HEAD et on initialise l'enreg DATA
     If fstat
      GOK=0 : Call FSTA("ARA") From GLOCK : Break
     Endif
     [F:ARA]TYP = 2
     [F:ARA]SEQ = 1
     Raz [F:ARA]LIG            
    Elsif [L]NBDATA>=dim([F:ARA]LIG)
     # Nouveau n° de séquence
     Write [F:ARA]
     If fstat
      GOK=0 : Call FSTA("ARA") From GLOCK : Break
     Endif
     [F:ARA]SEQ += 1
     Raz [F:ARA]LIG
     [L]NBDATA = 0
    Endif
    [F:ARA]LIG([L]NBDATA) = [L]LIGNE
    [L]NBDATA += 1
    # Composition du tableau des lignes liées au pied du pattern
   Elsif [L]XAF<>0 and ([L]XZF=0 or [L]LIG<=[L]XZF)
    If [L]NBFOOT=0
     Write [F:ARA] : # On écrit l'enreg DATA et on initialise l'enreg FOOT
     If fstat
      GOK=0 : Call FSTA("ARA") From GLOCK : Break
     Endif
     [F:ARA]TYP = 3
     [F:ARA]SEQ = 1
     Raz [F:ARA]LIG            
    Elsif [L]NBFOOT>=dim([F:ARA]LIG)
     # Nouveau n° de séquence
     Write [F:ARA]
     If fstat
      GOK=0 : Call FSTA("ARA") From GLOCK : Break
     Endif
     [F:ARA]SEQ += 1
     Raz [F:ARA]LIG
     [L]NBFOOT = 0
    Endif
    [F:ARA]LIG([L]NBFOOT) = [L]LIGNE
    [L]NBFOOT += 1
   Endif
  Endif
  If ![L]DFR
   [L]DFR = instr(1,[L]LIGNE,"^DFR")
  Elsif ![L]FMEND
   [L]FMEND = instr(1,[L]LIGNE,"^XZ")
  Endif
  Rdseq [L]LIGNE Using [PATT]
 Wend
 If GOK<>1 : Goto AB_TR1 : Endif
 If [L]NBFOOT>0
  # On écrit l'enreg FOOT
  Write [F:ARA]
  If fstat
   GOK=0 : Call FSTA("ARA") From GLOCK : Goto AB_TR1
  Endif
 Endif

 # Mise à jour de la zone numéro de version du pattern de la fiche paramétrage
 Read [ARZ]ARZ0 = [L]CODPAR
 If !fstat & [F:ARZ]VER=0
  [F:ARZ]VER = [L]VER
  Rewrite [F:ARZ]
  If fstat
   GOK=0 : Call FSTA("ARZ") From GLOCK : Goto AB_TR1
  Endif
 Endif

Commit
Return

#------------#
$AB_TR1
Rollback
Return

#---------------#
# Masque
#---------------#

$TR2
Trbegin [ARA]
 Read [ARA]ARA0(2)=[L]PATNAM;[L]TIMSTP
 If !fstat
  [L]VER = [F:ARA]VER
  Delete [ARA] Where PATNAM=[L]PATNAM & TIMSTP=[L]TIMSTP
  If fstat
   GOK=0 : Call FSTA("ARA") From GLOCK : Goto AB_TR2
  Endif
 Else
  # On recherche le plus grand numéro de version pour ce pattern
  Read [ARA]ARA1(1)=[L]PATNAM
  If fstat
   Raz [F:ARA]
  Endif
  [L]VER = [F:ARA]VER+1
 Endif

 Raz NBDATA, NBHEAD
 Raz [F:ARA]
 Rdseq [L]LIGNE Using [PATT]
 While !fstat
  [L]LIG += 1
  If [L]FMEND=0
   If [L]NBHEAD=0
    [F:ARA]PATNAM  = [L]PATNAM
    [F:ARA]TIMSTP  = [L]TIMSTP : # Provient du Call VERIF_VERSION
    [F:ARA]TYPPAT  = 2         : # Masque
    [F:ARA]VER     = [L]VER    : # Permet la sélection de la version à imprimer
    [F:ARA]TYP     = 1
    [F:ARA]SEQ     = 1
    Raz [F:ARA]LIG
    [F:ARA]CREUSR  = GUSER
    [F:ARA]CREDAT  = date$
   Elsif [L]NBHEAD>=dim([F:ARA]LIG)
    # Nouveau n° de séquence
    Write [F:ARA]
    If fstat
     GOK=0 : Call FSTA("ARA") From GLOCK : Break
    Endif
    [F:ARA]SEQ += 1
    Raz [F:ARA]LIG
    [L]NBHEAD = 0
   Endif
   [F:ARA]LIG([L]NBHEAD) = [L]LIGNE
   [L]NBHEAD += 1
  Else
   # Composition du tableau des lignes liées aux données
   If [L]NBDATA=0
    Write [F:ARA] : # On écrit l'enreg HEAD et on initialise l'enreg DATA
    If fstat
     GOK=0 : Call FSTA("ARA") From GLOCK : Break
    Endif
    [F:ARA]TYP = 2
    [F:ARA]SEQ = 1
    Raz [F:ARA]LIG            
   Elsif [L]NBDATA>=dim([F:ARA]LIG)
    # Nouveau n° de séquence
    Write [F:ARA]
    If fstat
     GOK=0 : Call FSTA("ARA") From GLOCK : Break
    Endif
    [F:ARA]SEQ += 1
    Raz [F:ARA]LIG
    [L]NBDATA = 0
   Endif
   [F:ARA]LIG([L]NBDATA) = [L]LIGNE
   [L]NBDATA += 1
  Endif
  If ![L]FMEND
   [L]FMEND = instr(1,[L]LIGNE,"^XZ")
  Endif
  Rdseq [L]LIGNE Using [PATT]
 Wend
 If GOK<>1 : Goto AB_TR2 : Endif
 If [L]NBDATA>0 or [L]NBHEAD>0
  Write [F:ARA]
  If fstat
   GOK=0 : Call FSTA("ARA") From GLOCK : Goto AB_TR2
  Endif
 Endif

 # Mise à jour de la zone numéro de version du pattern de la fiche paramétrage
 Read [ARZ]ARZ0 = [L]CODPAR
 If !fstat & [F:ARZ]VER=0
  [F:ARZ]VER = [L]VER
  Rewrite [F:ARZ]
  If fstat
   GOK=0 : Call FSTA("ARZ") From GLOCK : Goto AB_TR2
  Endif
 Endif

Commit
Return

#------------#
$AB_TR2
Rollback
Return

#-----------------------------------------------------------------#
Subprog VERIF_VERSION(PATNAM,TIMSTP,OK)
Value    Char    PATNAM
Variable Integer TIMSTP
Variable Integer OK

If clalev([F:ARA])=0 : Local File AREPORTA [ARA] : Endif

# On regarde si la table des formats est bien à jour par rapport au pattern déposé sur le serveur
# On en profite pour vérifier qu'il existe bien !

[L]TIMSTP = filinfo(filpath("PAT",[L]PATNAM,"PAT"),9)
If [L]TIMSTP<0
 [L]OK = 0
Else
 Look [ARA]ARA0(2)=[L]PATNAM;[L]TIMSTP
 If !fstat
  [L]OK = 1
 Else
  [L]OK = 0
 Endif
Endif

End

