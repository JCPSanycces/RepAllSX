#<AdxTL>@(#)3.0.0.0 $Revision$
##################################################################################
# DOSMAJ6 : Mises à jour à effectuer lors du passage à la version 132 (Release 6) 
# moulinette avant la version 135 
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

Onerrgo
End


###################################################################################
###################################################################################
###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR

# recupération dernier patch pour avoir une idée de la version installée chez le client
# lecture table APATCH du dossier en cours de validation
Local Shortint WPATCH
WPATCH = 0

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif


Filter [ZAP] Where TYP = "P"
Read [ZAP] Last 
If fstat 
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]


Filter [ZAX] Where TYP = "P"
Read [ZAX] Last 
If fstat 
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = max ([F:ZAP]PATNUM,[F:ZAX]PATNUM)

Close Local File



# pas possible de tester le GVERSION car le dossier X3 est déja a jour de la version
# ici c'est trop tard


# module VENTE
If [F:ADS]MODULE(4) = 2
    If WPATCH < 35
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIVEN02
    Endif
Endif

# module ACHAT
If [F:ADS]MODULE(5) = 2
    If WPATCH < 23
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH5
    Endif
    # UTIACH7 n'a pas été écrite pour être executer depuis n'importe quel fichier
    # les fichiers sont ouverts en local - donc pas correct
    # donc on ne lance pas en automatique
    #If WPATCH < 31
    #    Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH7
    #Endif
Endif



# si le client est patché 7 alors la moulinette a déja était executée 
# si le dossier X3 est patché > 6 et que le dossier a valider est patché < 7  on considere quand même
# que le dossier est a jour car il a pu etre valider entre temps et les différentes moulinettes ont pu etre passées
# module stock
If [F:ADS]MODULE(6)=2
        If WPATCH < 7
            Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO02
        Endif
Endif

# module GPAO
If [F:ADS]MODULE(7) = 2
        If WPATCH < 9
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA02
        Endif
        If WPATCH < 38
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA03
        Endif
Endif


# module TC
If [F:ADS]MODULE(8) = 2 
    If WPATCH < 23
        Call UTI_MOUL([F:ADS]DOSSIER) From TRTBPPA
    Endif
Endif

# module CRM
If [F:ADS]MODULE(12) = 2
    If WPATCH < 23
        Call UTI_MOUL([F:ADS]DOSSIER) From TRTMST
    Endif
    If WPATCH < 28
        Call UTI_MOUL([F:ADS]DOSSIER) From TRTLIBDOO
    Endif

Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN 
# Erreur...ligne no...
Resume 



