#######################################################################################
$_CALC_TOTAUX
  Local File TABCUR[TCU]
  Local Decimal WLINAMT,WDECIMAL, WQTYWEU, WQTYVOU
  Local Integer WSTAT
 #conversion du poids
  WQTYWEU = this.QTYWEU
  Call CONVERT_QTY(this.LINWEU,this.APARENT.DSPWEU,WQTYWEU)From TRTX3
  this.APARENT.TOTLINWEU += WQTYWEU
  #conversion du volume
  WQTYVOU = this.QTYVOU
  Call CONVERT_QTY(this.LINVOU,this.APARENT.DSPVOU,WQTYVOU)From TRTX3
  this.APARENT.TOTLINVOU += WQTYVOU
  #Calcul du taux de remplissage
  If this.APARENT.USFVOL <> AVOID.ADEC
    this.APARENT.TXWOU = this.APARENT.TOTLINVOU *100 / this.APARENT.USFVOL
    this.APARENT.TXWOU2 = this.APARENT.TXWOU
  Endif
  #conversion en devise société pour les totaux
  WDEVSOC = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.LEGCPY,"ACCCUR")
  WLINAMT = AVOID.ADEC
  Call CONVERT(this.ACTX,this.NETCUR,WDEVSOC,WDEVSOC,this.CHGTYP, date$, this.LINAMT,WLINAMT,WSTAT) From TRTDEV_SYRA
  this.APARENT.TOTLINAMT += WLINAMT
  this.APARENT.CUR = WDEVSOC
  Read [TCU]TCU0=WDEVSOC
  If !fstat WDECIMAL = [F:TCU]CURRND Endif
  this.APARENT.TOTLINAMT = arr(this.APARENT.TOTLINAMT,WDECIMAL)
Return

