#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("COA",GBIDC1,GBIDC2) From GOBJET
End

###############################################################################
$ACTION
Case ACTION
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC 
 When "TERMINE"  : Gosub FIN
Endcase
Return

##########################################################################
$CONTROLE
TMP = 1 : # Pour afficher des tempon/tempoff
Return

##########################################################################
$FIN
TRA = 1 : # Pour lire la trace
Return

##########################################################################
$EXEC
Call OUVRE_VLC(mess(4,105,1),"","") From GESECRAN
Call AFF_VLC(mess(8,104,1),"") From GESECRAN
Call OUVRE_TRACE(mess(4,105,1)) From LECFIC : # Paramètrage codes reporting
Gosub STR_TRA 
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Gosub END_TRA
Call FERME_TRACE From LECFIC
Call FERME_VLC From GESECRAN
Return

$TR_EXEC
Local Char    LIBACC(GLONAX3)
Local Integer NBTR
GOK = 1
Trbegin [GAC]
 Lock [GAC]
 If fstat
  GOK=-1 : GLOCK="$GACCOUNT" : Goto ROLL_EXEC
 Endif
 Filter [GAC] Where COA=[M:COA0]COA : #TYP=1 | TYP=3
 For [GAC]GAC0
  OK = 0
  Call AFF_VLC(mess(8,104,1),[F:GAC]ACC) From GESECRAN
  If [M:DIA]AFFECT=2 | ([F:GAC]RPTCODDEB([M:COA4]NUM-1)="" & [F:GAC]RPTCODCDT([M:COA4]NUM-1)="")
   For I=[M:COA4]NBLIG-1 To 0 Step -1
    L = len([M:COA4]ACCSTR(I))
    If left$([F:GAC]ACC,L)=[M:COA4]ACCSTR(I)
     [F:GAC]RPTCODDEB([M:COA4]NUM-1) = [M:COA4]CODDEB(I)
     [F:GAC]RPTCODCDT([M:COA4]NUM-1) = [M:COA4]CODCDT(I)
     OK = 1 : Break
    Endif
   Next I
   If OK=0 & [M:DIA]RAZACC=2
    [F:GAC]RPTCODDEB([M:COA4]NUM-1) = ""
    [F:GAC]RPTCODCDT([M:COA4]NUM-1) = ""
    OK = 1
   Endif
  Endif
  If OK=1
   Call LECTEXTRA([L]LIBACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   Call ECR_TRACE("("+num$(I+1)+")"-[F:GAC]ACC-[L]LIBACC-":"-[F:GAC]RPTCODDEB([M:COA4]NUM-1)
&            -"/"-[F:GAC]RPTCODCDT([M:COA4]NUM-1),0) From GESECRAN
   If [M:DIA]SIMUL<>2
    NBTR += 1
    Rewrite [GAC]
    If fstat
     GOK = 0 : Call FSTA("GAC") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If !GOK : Goto AB_EXEC : Endif
Commit
Return

$AB_EXEC
Rollback
Return

$ROLL_EXEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXEC : Endif
Return

$STR_TRA
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(36,113,1)-[M:COA0]COA,0) From GESECRAN
Call ECR_TRACE(mess(17,104,1)-num$([M:COA4]NUM),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Onerrgo ERREUR From CONTROLE
 If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0
Else
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Local Char    LIBZON(80)
 Read [AMZ]CODE = "SAIPARBSE";"AFFECT"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]AFFECT,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Read [AMZ]CODE = "SAIPARBSE";"RAZACC"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]RAZACC,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Call ECR_TRACE(mess(27,107,1)-":"-mess([M]SIMUL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

$END_TRA
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
# Nombre de lignes traitées durant l'exécution
Call ECR_TRACE(mess(14,153,1)-":"-num$(NBTR),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return
