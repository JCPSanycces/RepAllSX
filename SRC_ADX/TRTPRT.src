#####################################
# TRTPRT : fonctions pour le portail
#####################################

  Infbox(func TRTPRT.DOC_PATH())
End

#####################################
# Chemin de la documentation
Funprog DOC_PATH()

 Local Char VALEUR(250), NOEUD(250), FILTRE(250), DOCPATH(250), SEP(1)

 # récupération du chemin
 NOEUD   = 'doc.files.accesspath'
 FILTRE  = 'family="DOC"'
 Call RECH_NOEUD_SOL("",NOEUD,FILTRE,VALEUR) From ASELSIMP
 DOCPATH = VALEUR

 If left$(DOCPATH,1) = '\'
   SEP = '\'
 Else
   SEP = '/'
 Endif

 If right$(DOCPATH,len(DOCPATH)) <> SEP
   DOCPATH += SEP
 Endif

 # Ajout de la langue
 DOCPATH += GLANGUE + SEP

 # Ajout du fichier d'entrée
 DOCPATH += 'index.htm'

End DOCPATH

#####################################
# Date de début de l'exercice courant
Funprog STRDAT_EXE_CUR(PCPY,PCNX)
Value Char    PCPY
Value Integer PCNX

 Local Date RDATE

 If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

 Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA

 If !fstat
   RDATE=[F:WFIS]DATSTRFIY
 Else
   RDATE=[0/0/0]
 Endif

 Close File [WFIS]

End RDATE

#####################################
# Date de fin de l'exercice courant
Funprog ENDDAT_EXE_CUR(PCPY,PCNX)
Value Char    PCPY
Value Integer PCNX

 Local Date RDATE

 If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

 Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA

 If !fstat
   RDATE=[F:WFIS]DATENDFIY
 Else
   RDATE=[0/0/0]
 Endif

 Close File [WFIS]

End RDATE

#####################################
# Date de début de la période courante
Funprog STRDAT_PER_CUR(PCPY,PCNX)
Value Char    PCPY
Value Integer PCNX

 Local Date RDATE

 If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

 Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA

 If !fstat
   RDATE=[F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
 Else
   RDATE=[0/0/0]
 Endif

 Close File [WFIS]

End RDATE

#####################################
# Date de fin de la période courante
Funprog ENDDAT_PER_CUR(PCPY,PCNX)
Value Char    PCPY
Value Integer PCNX

 Local Date RDATE

 If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

 Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA

 If !fstat
   RDATE=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)
 Else
   RDATE=[0/0/0]
 Endif

 Close File [WFIS]

End RDATE

