#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################
# SUBSOT : Transactions de saisie des sorties diverses                #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base SOT     #
#                                                                     #
# Nom des écrans générés : WT2yyy                                     #
#                          yyy = nom de la transaction (SRTNUM)       #
#                                                                     #
#######################################################################
Call OBJET("SOT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=2
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SOT0]SRTTYP = 2
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"        : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return

$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

############################################################

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Integer  WNUM             : WNUM = 2
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)

Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE

    FILTSUP = "SRTTYP=2"

Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
    If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
Local Integer I

#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:SOT0]ENAFLG=0 [M:SOT0]ENAFLG=2         : Endif

#** Onglet général
If [M:SOT1]PJTCOD=0     [M:SOT1]PJTCOD=3     : Endif : # Affaire (invisible)
If [M:SOT1]TRSFAMCOD=0  [M:SOT1]TRSFAMCOD=1  : Endif : # Famille mouvement
If dim([M:SOT1]WRHCOD)>0
  If [M:SOT1]WRHCOD=0   [M:SOT1]WRHCOD=3     : Endif : # Dépôt (invisible)
Endif


WMODU +=format$("N0:2",[M:SOT0]SRTTYP)


If [M:SOT1]UOMSAIFLG=0     [M:SOT1]UOMSAIFLG=2  : Endif : # Saisie UC

#--- TS 106217
If dim([M:SOT1]ECCCOD)>0 &  [M:SOT1]ECCCOD=0
    [M:SOT1]ECCCOD=1
    [M:SOT1]ECCSCR=1
Endif
If dim([M:SOT1]ECCCODMIN)>0 &  [M:SOT1]ECCCODMIN=0
    [M:SOT1]ECCCODMIN=1
    [M:SOT1]ECCSCRMIN=1
Endif
#---

#--- Issue X3-53322
If dim([M:SOT1]LPNCOD)>0
    If [M:SOT1]LPNCOD=0    [M:SOT1]LPNCOD=1     : Endif : # LPN (saisie)
Endif
#---
If dim([M:SOT1]LOTCOD)>0
    If [M:SOT1]LOTCOD=0    [M:SOT1]LOTCOD=1     : Endif : # Numéro lot (saisie)
Endif
If dim([M:SOT1]SLOCOD)>0
    If [M:SOT1]SLOCOD=0    [M:SOT1]SLOCOD=3     : Endif : # Numéro S-Lot
Endif
If [M:SOT1]STACOD=0        [M:SOT1]STACOD=3     : Endif : # Statut (invisible)
If dim([M:SOT1]LOCCOD)>0
    If [M:SOT1]LOCCOD=0    [M:SOT1]LOCCOD=3     : Endif : # Emplacement (invisible)
Endif
If dim([M:SOT1]SERCOD)>0
    If [M:SOT1]SERCOD=0    [M:SOT1]SERCOD=3     : Endif : # Numéro série (invisible)
    If [M:SOT1]SERECOD=0   [M:SOT1]SERECOD=2    : Endif : # Numéro série fin (invisible)
Endif
If [M:SOT1]MVTDESCOD=0     [M:SOT1]MVTDESCOD=3  : Endif : # Désignation mouvement (invisible)
If dim([M:SOT1]WRHCOD1)>0
    If [M:SOT1]WRHCOD1=0     [M:SOT1]WRHCOD1=3  : Endif : # Dépôt (invisible)
Endif
If dim([M:SOT1]IDECOD01)>0
    If [M:SOT1]IDECOD01=0  [M:SOT1]IDECOD01=3   : Endif : # identifiant 1 (invisible)
    If [M:SOT1]IDECOD02=0  [M:SOT1]IDECOD02=3   : Endif : # identifiant 2 (invisible)
Endif

Gosub GRISAGE

Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
Local Integer I
[M:SOT0]ENAFLG=2
#** Onglet général
[M:SOT1]PJTCOD=3         : # Affaire (invisible)
[M:SOT1]TRSFAMCOD=3      : # Famille du mouvement (invisible)
If dim([M:SOT1]WRHCOD)>0
    If [M:SOT1]WRHOBY = 2
       [M:SOT1]WRHCOD=1  : # Dépôt (saisi)
    Else
       [M:SOT1]WRHCOD=3  : # Dépôt (invisible)
    Endif
Endif

[M:SOT1]CFMCOD=1         : # Pas de validation


WMODU += format$("N0:2",[M:SOT0]SRTTYP)

[M:SOT1]UOMSAIFLG=2      : # Saisie en UC

#--- TS 106217
If dim([M:SOT1]ECCCOD)>0
  [M:SOT1]ECCCOD=1
  [M:SOT1]ECCSCR=1
Endif
If dim([M:SOT1]ECCCODMIN)>0
  [M:SOT1]ECCCODMIN=1
  [M:SOT1]ECCSCRMIN=1
Endif
#---
#--- Issue X3-53322
If dim ([M:SOT1]LPNCOD)>0
  [M:SOT1]LPNCOD=1       : # LPN (saisie)
  [M:SOT1]LPNSCR=1
Endif
#---
If dim ([M:SOT1]LOTCOD)>0
  [M:SOT1]LOTCOD=1       : # Numéro lot (saisie)
  [M:SOT1]LOTSCR=1
Endif
If dim ([M:SOT1]SLOCOD)>0
  [M:SOT1]SLOCOD=3       : # Numéro sous-lot (invisible)
  [M:SOT1]SLOSCR=1
Endif
If dim([M:SOT1]LOCCOD)>0
  [M:SOT1]LOCCOD=3       : # Emplacement (invisible)
  [M:SOT1]LOCSCR=1
Endif
[M:SOT1]STACOD=3         : # Statut (invisible)
[M:SOT1]STASCR=1
If dim([M:SOT1]SERCOD)>0
  [M:SOT1]SERCOD=3       : # Numéro série (invisible)
  [M:SOT1]SERSCR=1
  [M:SOT1]SERECOD=2      : # Numéro série fin (invisible)
  [M:SOT1]SERESCR=1
Endif
[M:SOT1]MVTDESCOD=3      : # Désignation mouvement (invisible)
[M:SOT1]MVTDESSCR=1

If dim([M:SOT1]WRHCOD1)>0 & dim([M:SOT1]WRHSCR1)>0
  #--- Dem 60616
  #If dim([M:SOT1]WRHOBY)>0
  #  If [M:SOT1]WRHOBY = 2
  #      [M:SOT1]WRHCOD1=2      : # Dépôt (affiché)
  #  Else
        [M:SOT1]WRHCOD1=3      : # Dépôt (invisible)
        [M:SOT1]WRHSCR1=1
  #  Endif
  #Endif
  #---
Endif


If dim([M:SOT1]IDECOD01)>0                              # hcb 27200
   [M:SOT1]IDECOD01=3      # identifiant 1 (invisible)  # hcb 27200
   [M:SOT1]IDECOD02=3      # identifiant 2 (invisible)  # hcb 27200
   [M:SOT1]IDESCR01=1                                   # hcb 27200
   [M:SOT1]IDESCR02=1                                   # hcb 27200
Endif                                                   # hcb 27200

Gosub GRISAGE

Gosub PE_STKTRS

Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "ECCCOD"          #--- TS 106217
       If val(CZ) = 2 & [M:SOT1]ECCCODMIN=1
           [M:SOT1]ECCCODMIN = 2
           If !GIMPORT Affzo [SOT1]ECCCODMIN : Endif
       Endif
       If val(CZ)=3
         [M:SOT1]ECCSCR=1
         [M:SOT1]ECCCODMIN=3
         [M:SOT1]ECCSCRMIN=1
         If !GIMPORT Affzo [SOT1]ECCSCR,ECCCODMIN,ECCSCRMIN : Grizo [SOT1]ECCSCR,ECCCODMIN,ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [SOT1]ECCSCR,ECCCODMIN,ECCSCRMIN
       Endif
  When "ECCCODMIN"       #--- TS 106217
       If val(CZ)=3
         [M:SOT1]ECCSCRMIN=1
         If !GIMPORT Affzo [SOT1]ECCSCRMIN : Grizo [SOT1]ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [SOT1]ECCSCRMIN
       Endif
  When "LPNCOD"                                   : #--- Issue X3-53322
       If val(CZ)=3
         [M:SOT1]LPNSCR=1
         If !GIMPORT Affzo [SOT1]LPNSCR : Grizo [SOT1]LPNSCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]LPNSCR
       Endif
  When "LOTCOD"                                   : # Lot doc
       If val(CZ)=3
         [M:SOT1]LOTSCR=1
         If !GIMPORT Affzo [SOT1]LOTSCR : Grizo [SOT1]LOTSCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]LOTSCR
       Endif
  When "SLOCOD"                                   : # Sous-lot doc
       If val(CZ)=3
         [M:SOT1]SLOSCR=1
         If !GIMPORT Affzo [SOT1]SLOSCR : Grizo [SOT1]SLOSCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]SLOSCR
       Endif
  When "STACOD"                                   : # Statut doc
       If val(CZ)=3
         [M:SOT1]STASCR=1
         If !GIMPORT Affzo [SOT1]STASCR : Grizo [SOT1]STASCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]STASCR
       Endif
  When "LOCCOD"                                   : # Emplacement doc
       If val(CZ)=3
         [M:SOT1]LOCSCR=1
         If !GIMPORT Affzo [SOT1]LOCSCR : Grizo [SOT1]LOCSCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]LOCSCR
       Endif
  When "SERCOD"                                   : # Numéro série doc
       If val(CZ)=3
         [M:SOT1]SERSCR=1
         [M:SOT1]SERECOD=2
         [M:SOT1]SERESCR=1
         If !GIMPORT Affzo [SOT1]SERSCR, SERECOD, SERESCR
                     Grizo [SOT1]SERSCR, SERECOD, SERESCR
         Endif
       Elsif !GIMPORT
         Actzo [SOT1]SERSCR, SERECOD, SERESCR
       Endif
  When "SERECOD"                                  : # Numéro série fin doc
       If val(CZ)=2
         [M:SOT1]SERESCR=1
         If !GIMPORT Affzo [SOT1]SERESCR : Grizo [SOT1]SERESCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]SERESCR
       Endif
  When "MVTDESCOD"                                : # Des mouvement doc
       If val(CZ)=3
         [M:SOT1]MVTDESSCR=1
         If !GIMPORT Affzo [SOT1]MVTDESSCR : Grizo [SOT1]MVTDESSCR : Endif
       Elsif !GIMPORT
         Actzo [SOT1]MVTDESSCR
       Endif
  When "WRHCOD1"                                : # Dépôt
       If val(CZ)=3
         [M:SOT1]WRHSCR1=1
         If !GIMPORT Affzo [SOT1]WRHSCR1 : Grizo [SOT1]WRHSCR1 : Endif
       Elsif !GIMPORT
         Actzo [SOT1]WRHSCR1
       Endif


  When "IDECOD01"                                : # Identifiant 1
       If val(CZ)=3
         [M:SOT1]IDESCR01 =1
         If !GIMPORT Affzo [SOT1]IDESCR01  : Grizo [SOT1]IDESCR01  : Endif
       Elsif !GIMPORT
         Actzo [SOT1]IDESCR01
       Endif
  When "IDECOD02"                                : # Identifiant 1
       If val(CZ)=3
         [M:SOT1]IDESCR02 =1
         If !GIMPORT Affzo [SOT1]IDESCR02  : Grizo [SOT1]IDESCR02  : Endif
       Elsif !GIMPORT
         Actzo [SOT1]IDESCR02
       Endif
  When Default
       Gosub PE_STKTRS
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SOT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SOT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU : Endif
If APPLI=""    APPLI=nomap      : Endif
If dim(OK)<0  : Local Integer OK : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK


If WMODU=""
    WMODU = "T"+format$("N0:2",[M:SOT0]SRTTYP)
Endif

#---------------- Noms fenêtres et traitement entrées diverses ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="OSMO"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOSMO"+[M:SOT0]SRTNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
#-------------------------- écran en-tête ---------------------------#
MFROM="SMO0"
MTO="W"+WMODU+[M:SOT0]SRTNUM+"0"
NOMMSKENT=MTO
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SOT1]PJTCOD>1     TZONE(IZON)="PJT"                : # Affaire
                           TMOD(IZON) =[M:SOT1]PJTCOD
                           IZON+=1
   Endif
   If [M:SOT1]TRSFAMCOD>1  TZONE(IZON)="TRSFAM"             : # Famille mouvement
                           TMOD(IZON) =[M:SOT1]TRSFAMCOD
                           IZON+=1
   Endif
   If dim([M:SOT1]WRHCOD)>0
       If [M:SOT1]WRHCOD>1 TZONE(IZON)="WRHE"               : # Dépôt
                           TMOD(IZON) =[M:SOT1]WRHCOD
                           IZON+=1
       Endif
   Endif

   OPT1=2
   Gosub PE_STKTRS
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif


#-------------------------- 1er écran ---------------------------#
MFROM="SMO1"
MTO="W"+WMODU+[M:SOT0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"

  If [M:DST]CCESCR>1
     For I=0 To 19
       TZONE(IZON)="CCE"+num$(I+1)
       TMOD(IZON) =9
       TINT(IZON) =num$([M:DST]CCESCR)
       IZON+=1
     Next I
   Endif
   If [M:SOT1]UOMSAIFLG=1 TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="PCU"                : # Coeff pcustu
                           TMOD(IZON) =2
                           IZON+=1

                           TZONE(IZON)="STU"                : # Unité de stock
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="QTYSTU"             : # Quantité en unité de stock
                           TMOD(IZON) =3
                           IZON+=1
    Endif
   #--- TS 106217
   If dim([M:SOT1]ECCCOD)>0
      If [M:SOT1]ECCCOD>1 TZONE(IZON)="ECCVALMAJ"
                          TMOD(IZON) =[M:SOT1]ECCCOD
                          IZON+=1
      Endif
      If [M:SOT1]ECCSCR>1  TZONE(IZON)="ECCVALMAJ"
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SOT1]ECCSCR)
                           IZON+=1
      Endif
      If [M:SOT1]ECCCODMIN>1  TZONE(IZON)="ECCVALMIN"
                              TMOD(IZON) =[M:SOT1]ECCCODMIN
                              IZON+=1
      Endif
      If [M:SOT1]ECCSCRMIN>1  TZONE(IZON)="ECCVALMIN"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SOT1]ECCSCRMIN)
                              IZON+=1
      Endif
   Endif
   #--- Issue X3-53322
   If dim([M:SOT1]LPNCOD)>0
     If [M:SOT1]LPNCOD>1     TZONE(IZON)="LPNNUM"             : # LPN
                             TMOD(IZON) =[M:SOT1]LPNCOD
                             IZON+=1
     Endif
     If [M:SOT1]LPNSCR>1     TZONE(IZON)="LPNNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]LPNSCR)
                             IZON+=1
     Endif
   Endif
   #---
   If dim([M:SOT1]LOTCOD)>0
     If [M:SOT1]LOTCOD>1     TZONE(IZON)="LOT"                : # Lot fournisseur
                             TMOD(IZON) =[M:SOT1]LOTCOD
                             IZON+=1
     Endif
     If [M:SOT1]LOTSCR>1     TZONE(IZON)="LOT"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]LOTSCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:SOT1]SLOCOD)>0
     If [M:SOT1]SLOCOD>1     TZONE(IZON)="SLO"                : # Sous-Lot
                             TMOD(IZON) =[M:SOT1]SLOCOD
                             IZON+=1
     Endif
     If [M:SOT1]SLOSCR>1     TZONE(IZON)="SLO"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]SLOSCR)
                             IZON+=1
     Endif
   Endif
   If [M:SOT1]STACOD>1     TZONE(IZON)="STA"                  : # Statut
                           TMOD(IZON) =[M:SOT1]STACOD
                           IZON+=1
   Endif
   If [M:SOT1]STASCR>1     TZONE(IZON)="STA"                  : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SOT1]STASCR)
                           IZON+=1
   Endif
   If dim([M:SOT1]LOCCOD)>0
     If [M:SOT1]LOCCOD>1     TZONE(IZON)="LOCTYP"             : # Type Emplacement
                             TMOD(IZON) =[M:SOT1]LOCCOD
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Emplacement
                             TMOD(IZON) =[M:SOT1]LOCCOD
                             IZON+=1
     Endif
     If [M:SOT1]LOCSCR>1     TZONE(IZON)="LOCTYP"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]LOCSCR)
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]LOCSCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:SOT1]SERCOD)>0
     If [M:SOT1]SERCOD>1     TZONE(IZON)="SERNUM"             : # Numéro de série
                             TMOD(IZON) =[M:SOT1]SERCOD
                             IZON+=1
     Endif
     If [M:SOT1]SERSCR>1     TZONE(IZON)="SERNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]SERSCR)
                             IZON+=1
     Endif
     If [M:SOT1]SERECOD>1    TZONE(IZON)="SERNUMF"            : # Numéro série fin
                             TMOD(IZON) =3
                             IZON+=1
     Endif
     If [M:SOT1]SERESCR>1    TZONE(IZON)="SERNUMF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]SERESCR)
                             IZON+=1
     Endif
   Endif
     If [M:SOT1]MVTDESCOD>1  TZONE(IZON)="MVTDES"             : # Désignation mouvement
                             TMOD(IZON) =[M:SOT1]MVTDESCOD
                             IZON+=1
     Endif
     If [M:SOT1]MVTDESSCR>1  TZONE(IZON)="MVTDES"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]MVTDESSCR)
                             IZON+=1
     Endif
    If dim([M:SOT1]WRHCOD1)>0
       If [M:SOT1]WRHCOD1>1  TZONE(IZON)="WRH"                : # Dépôt
                             TMOD(IZON) =[M:SOT1]WRHCOD1
                             IZON+=1
       Endif
       If [M:SOT1]WRHSCR1>1  TZONE(IZON)="WRH"                : # dépôt
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SOT1]WRHSCR1)
                             IZON+=1
      Endif
    Endif

# hcb 27200 deb

   If dim([M:SOT1]IDECOD01)>0
      If [M:SOT1]IDECOD01>1   TZONE(IZON)="PALNUM"             : # Identifiant 1
                              TMOD(IZON) =[M:SOT1]IDECOD01
                              IZON+=1
      Endif
      If [M:SOT1]IDESCR01>1   TZONE(IZON)="PALNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SOT1]IDESCR01)
                              IZON+=1
      Endif
   Endif
   If dim([M:SOT1]IDECOD02)>0
      If [M:SOT1]IDECOD02>1   TZONE(IZON)="CTRNUM"             : # Identifiant 2
                              TMOD(IZON) =[M:SOT1]IDECOD02
                              IZON+=1
      Endif
      If [M:SOT1]IDESCR02>1   TZONE(IZON)="CTRNUM"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SOT1]IDESCR02)
                              IZON+=1
      Endif
   Endif
# hcb 27200 fin



   OPT1=2
   Gosub PE_STKTRS
Else
    OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
#If [M:SRT1]STAFLG=1
#   Gosub RESTAUR_ECRAN : If GOK<1 Return : Endif
#Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN
If [M:SOT0]ENAFLG=1  : Return : Endif
#----- Génération fenêtre pour réception si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
  I=find("SMO1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SOT0]ACSCOD
  [F:AWI]LIBEL     = [M:SOT0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SOT0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
GOK = !!OK
Return



#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0
    Local File =APPLI+".AMSK"    [AMK]
Endif
Read [AMK] CODMSK=WNOMMSK
If fstat
    Raz [F:AMK]
    WFLGMSK=2
    Return
Endif

WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
    If [F:AMK]TYPBLOC(I)<>5
        WFLGMSK=2
        Break
    Endif
Next I

Return


#########################################################################
#                   Actions sur champs écran [M:SRT1]                   #
#########################################################################

########################################
Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
    [M:SOT0]SRTTYP = 2
End


$GRISAGE

#-- Grisage des zones si besoin
#** Onglet Général
If dim([M:SOT1]WRHCOD)>0
  If [M:SOT1]WRHOBY = 2
    Grizo [M:SOT1]WRHCOD
  Else
    Actzo [M:SOT1]WRHCOD
  Endif
Endif

#** Onglet Lignes

#--- TS 106217
If dim([M:SOT1]ECCCOD)>0
  If [M:SOT1]ECCCOD=3  Grizo [SOT1]ECCSCR  Else Actzo [SOT1]ECCSCR  : Endif
Endif
If dim([M:SOT1]ECCCODMIN)>0
  If [M:SOT1]ECCCODMIN=3  Grizo [SOT1]ECCSCRMIN  Else Actzo [SOT1]ECCSCRMIN  : Endif
Endif
#---
#--- Issue X3-53322
If dim([M:SOT1]LPNCOD)>0
  If [M:SOT1]LPNCOD=3     Grizo [SOT1]LPNSCR     Else Actzo [SOT1]LPNSCR     : Endif
Endif
#---
If dim([M:SOT1]LOTCOD)>0
  If [M:SOT1]LOTCOD=3     Grizo [SOT1]LOTSCR     Else Actzo [SOT1]LOTSCR     : Endif
Endif
If dim([M:SOT1]SLOCOD)>0
  If [M:SOT1]SLOCOD=3     Grizo [SOT1]SLOSCR     Else Actzo [SOT1]SLOSCR     : Endif
Endif
If dim([M:SOT1]LOCCOD)>0
  If [M:SOT1]LOCCOD=3     Grizo [SOT1]LOCSCR     Else Actzo [SOT1]LOCSCR    : Endif
Endif
If [M:SOT1]STACOD=3       Grizo [SOT1]STASCR     Else Actzo [SOT1]STASCR    : Endif
If dim([M:SOT1]SERCOD)>0
  If [M:SOT1]SERCOD=3     Grizo [SOT1]SERSCR     Else Actzo [SOT1]SERSCR    : Endif
  If [M:SOT1]SERECOD=2    Grizo [SOT1]SERESCR    Else Actzo [SOT1]SERESCR   : Endif
Endif
If [M:SOT1]MVTDESCOD=3  Grizo [SOT1]MVTDESSCR  Else Actzo [SOT1]MVTDESSCR   : Endif
If dim([M:SOT1]WRHCOD1)>0
  #--- Dem 60616
  #If [M:SOT1]WRHOBY = 2
  #  Grizo [M:SOT1]WRHCOD1 : Grizo [M:SOT1]WRHSCR1
  #Else
    Actzo [M:SOT1]WRHCOD1
    If [M:SOT1]WRHCOD1=3  Grizo [SOT1]WRHSCR1  Else Actzo [SOT1]WRHSCR1   : Endif
  #Endif
  #---
Endif
If dim([M:SOT1]IDECOD01)>0                                                           # hcb 27200
  If [M:SOT1]IDECOD01=3   Grizo [SOT1]IDESCR01   Else Actzo [SOT1]IDESCR01  : Endif  # hcb 27200
  If [M:SOT1]IDECOD02=3   Grizo [SOT1]IDESCR02   Else Actzo [SOT1]IDESCR02  : Endif  # hcb 27200
Endif                                                                                # hcb 27200

# Issue 110121 - 2015-08-10 by MUARN : ajout rang
Affzo [M:SOT0]1-99
Affzo [M:SOT1]1-99

Return

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(2,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(2,APPLI) From FUNSTKTRS

End

#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 2;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 2 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=2;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
## Etiquette ajoutée par le superviseur (écran SOT1) 09/06/2009 16:21:04 (MAE)
######################################################################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
#--- Dem 60616
#If VALEUR = 2
#    [M:SOT1]WRHCOD = 1
#    [M:SOT1]WRHCOD1 = 2
#    [M:SOT1]WRHSCR1 = 1
#    Grizo [M:SOT1]WRHCOD
#    Grizo [M:SOT1]WRHCOD1
#    Grizo [M:SOT1]WRHSCR1
#Else
#    Actzo [M:SOT1]WRHCOD
#    Actzo [M:SOT1]WRHCOD1
#    If [M:SOT1]WRHCOD1=3
#        Grizo [M:SOT1]WRHSCR1
#    Else
#        Actzo [M:SOT1]WRHSCR1
#    Endif
#Endif
If VALEUR = 2
   [M:SOT1]WRHCOD = 1
   Grizo [M:SOT1]WRHCOD
   If [M:SOT1]WRHCOD1=1
      [M:SOT1]WRHCOD1=3
      [M:SOT1]WRHSCR1=1
   Endif
   If [M:SOT1]WRHCOD1=3
      Grizo [M:SOT1]WRHSCR1
   Else
      Actzo [M:SOT1]WRHSCR1
   Endif
Else
   Actzo [M:SOT1]WRHCOD
Endif
#---
Affzo [M:SOT1]WRHCOD
Affzo [M:SOT1]WRHCOD1
Affzo [M:SOT1]WRHSCR1
End

######################################################################################
#--- Dem 60616
Subprog AS_WRHCOD1(VALEUR)
Variable Integer VALEUR
If [M:SOT1]WRHOBY=2 GMENLOC(1)=1 Endif
End
#---

#--- TS 106217
Subprog AS_ECCCODMIN(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
If [M:SOT1]ECCCOD = 2 : GMENLOC(1) = 1 : Endif
End
