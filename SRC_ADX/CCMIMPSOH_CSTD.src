#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPSOH - SALES ORDERS IMPACT ANALYSIS 'header'
# Issue 109096/2 - 2015-11-24 by BAKHA : For non-conformance, send email to actioners

$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AINIT"                         : Gosub INITIALISE
        When "CREATE_SALES_ORDERS_BATCH"     : Gosub CREATE_SALES_ORDERS_BATCH
        When "CREATE_SALES_ORDERS"           : Gosub CREATE_SALES_ORDERS
        When "CREATE_SALES_ORDERS_LINES"     : Gosub CREATE_SALES_ORDERS_LINES
        When "VALIDATE_IMPLEMENT"            : Gosub VALIDATE_IMPLEMENT
        When "UPDATE_STATUS"                 : Gosub UPDATE_STATUS
        When "AUPDATE_AFTER"                 : Gosub NOTIFY_ACTIONER
      Endcase
  Endcase
Return

# --------------------------------------------------
# Initialise 'header' properties ...
$INITIALISE

  Local Integer LINES

  this.HOLD       = 1
  this.IMPLEMENT  = 1
  this.SOHCUST    = 0
  this.SOHORDERS  = 0
  this.SOHQTY     = 0
  this.SOHAMT     = 0
  this.SOHAMTEX   = 0
  this.TOTALLINES = 0
  this.SOHPLASTA  = 4

  this.IMPACTANAL = 0

  # Folder currency ...
  this.FOLDCUR = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "RTZCUR")


Return

# ------------------------------------------------------
# Operation: CREATE_SALES_ORDERS_BATCH
#
# Called from Impact Analysis summary links.
# Instantiate Batch Server process, Task: CCMIMPBATT.
#
$CREATE_SALES_ORDERS_BATCH

  Local Integer LOCAL_STATUS
  Local Instance IMPSOH Using C_CCMIMPSOH
  IMPSOH = NewInstance C_CCMIMPSOH AllocGroup null

  Local Char    AFOLDER(30)
  Local Char    USER(30)
  Local Char    TASKNAME(30)
  Local Date    DAT
  Local Char    TIM(5)
  Local Char    TBPAR(30)(1..10)
  Local Char    TBVAL(250)(1..10)
  Local Integer NBPAR
  Local Integer TASKID
  Local Char    TASKMESSAGE(250)

  Local Integer LTIME
  Local Char    CTIME(4)

  # Read impact header
  LOCAL_STATUS = fmet IMPSOH.AREAD(CRID)

  ASTATUS = CST_AOK

  If (IMPSOH.IMPACTANAL <> 1)

    LTIME = time : CTIME = format$("N00:2", int(LTIME/3600)) +format$("N00:2", int((LTIME -(int(LTIME/3600) *3600)) /60))

    USER       = IMPSOH.ACTX.USER
    TASKNAME  = "CCMIMPBATT"
    DAT       = date$
    TIM       = CTIME
    NBPAR = 1  : TBPAR(NBPAR) = "CRID"        : TBVAL(NBPAR) = CRID
    NBPAR += 1 : TBPAR(NBPAR) = "TRANSACTION" : TBVAL(NBPAR) = "10"

    # Impact Analysis 'Created' flag = "No" ...
    IMPSOH.IMPACTANAL = 1
    LOCAL_STATUS = fmet IMPSOH.AUPDATE()

    ASTATUS = func ASYRMNGTREQ.CRERQT(IMPSOH.ACTX,
&                              IMPSOH.ACTX.AFOLDER,
&                              USER,
&                              TASKNAME,
&                              DAT,
&                              TIM,
&                              TBPAR,
&                              TBVAL,
&                              NBPAR,
&                              TASKID,
&                              TASKMESSAGE)

  Endif

  FreeGroup IMPSOH
  ARET_VALUE = ASTATUS

Return

# -------------------------------------------------------------------------------
# Custom Operation ...
#
# Called from (a) Change Request - change of status to "In review", and
#             (b) Impact Analysis Sales Quotes - refresh.
#
$CREATE_SALES_ORDERS

  Local Integer LOCSTATUS, I, LINES, COUNT, FOUND
  Local File CCMIMPSOD [CCMSOD]
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  Local Instance SELIMPSOH Using C_CCMIMPSOH

  # Begin a Database Transaction ...
  Local Integer TRANSACTION_PENDING
  TRANSACTION_PENDING = adxlog
  If (adxlog = 0)
    Trbegin [CCMSOD]
  Endif

 # Read CHANGE REQUEST
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  LOCSTATUS = fmet SELCHGREQ.AREAD(CRID)

  # Read sales order header
  SELIMPSOH = NewInstance C_CCMIMPSOH AllocGroup null
  LOCSTATUS = fmet SELIMPSOH.AREAD(CRID)

  # If request in review, and refresh can be done
  If (LOCSTATUS = [V]CST_AOK and SELCHGREQ.CRSTATUS = 2 and SELIMPSOH.HOLD <> 2)

    # Clear detail collection rows and reset header totals ...

    Delete [CCMSOD] Where CRID = SELIMPSOH.CRID

    # Folder currency ...
    SELIMPSOH.FOLDCUR = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "RTZCUR")

    SELIMPSOH.HOLD = 1      # No
    SELIMPSOH.IMPLEMENT = 1 # No
    SELIMPSOH.SOHCUST = 0
    SELIMPSOH.SOHORDERS = 0
    SELIMPSOH.SOHQTY = 0
    SELIMPSOH.SOHAMT = 0
    SELIMPSOH.SOHAMTEX = 0
    SELIMPSOH.TOTALLINES = 0

    LOCSTATUS = fmet SELIMPSOH.CREATE_SALES_ORDERS_LINES (SELIMPSOH.CRID, SELCHGREQ.PRODUCT, SELCHGREQ.ECCVALMAJ, SELCHGREQ.ECCVALMIN)

  Endif

    # If lines (i.e. unique quotes) then set status to 5 (No actions) else set to 4 (None) ...
    If (SELIMPSOH.SOHORDERS >= 1)
      SELIMPSOH.SOHPLASTA = 1
    Else
      SELIMPSOH.SOHPLASTA = 4
      # If Plan Status is 4 (None) then Implement flag is always ticked ...
      SELIMPSOH.IMPLEMENT = 2
    Endif

    SELIMPSOH.IMPACTANAL = 2

    LOCSTATUS= fmet SELIMPSOH.AUPDATE()

  # Commit or Rollback the Database Transaction ...
  If (TRANSACTION_PENDING = 0)
    If (ASTATUS <= [V]CST_AINFO)
      Commit
    Else
      Rollback
    Endif
  Endif

  Close Local File [CCMSOD]
  FreeGroup SELIMPSOH
  FreeGroup SELCHGREQ

Return

# -------------------------------------------------------------------------------
# Custom Method ...
#
# Called from $CREATE_SALES_ORDERS (above).
#
$CREATE_SALES_ORDERS_LINES

  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  Local Char CRITERIA(250)
  Local Integer I, LOCSTATUS, BLANK_VERSION
  Local Integer LINE_NUMBER     : LINE_NUMBER = 0
  Local Char MYBPCNUM (GLONBPC)(0..)
  Local Integer NO_CUST   : NO_CUST = 0
  Local Char MYSOHNUM (GLONSOH)(0..)
  Local Integer NO_ORDERS : NO_ORDERS = 0

  #MGG X3-38337_Product_Code_length_GLONITM_function
  Local Char LAST_ITMREF(GLONITM) : LAST_ITMREF = ""
  #END MGG X3-38337_Product_Code_length_GLONITM_function

  Local Date    WDATREF             : WDATREF=AVOID.ADATE
  Local Integer WLSTTYP             : WLSTTYP=3     # 1=first level, 2=last level, 3= multi-level
  Local Integer WALTTYPSTR          : WALTTYPSTR=1  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTTYPEND          : WALTTYPEND=3  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTSTR             : WALTSTR=0     # From alt number : 0=all alternatives
  Local Integer WALTEND             : WALTEND=0     # From alt number : 0=all alternatives
  Local Char    MYCRIT(250)         : MYCRIT="1=1"  # No particular Where criteria
  Local Char    MYFOR (GLONFOR)     : MYFOR=""      # Reference of a Formula in table TABFOR [F:TFO] with FORTYP=31
  Local Integer WRET

  Local File ITMMASTER [ITM]
  Local File ITMCATEG [ITG]

  #CATUA X3-38562.sn Set Product Code length to GLONITM
  Local Char SUB_LINES_PRODUCT(GLONITM)
  #CATUA X3-38562.en
  Local Char SUB_ECCVALMAJ(10)
  Local Char SUB_ECCVALMIN(10)

  # Create lines for Change Request Product ...
  BLANK_VERSION = CST_ATRUE
  SUB_LINES_PRODUCT = PRODUCT
  SUB_ECCVALMAJ = MAJOR_VERSION
  SUB_ECCVALMIN = MINOR_VERSION
  Gosub CREATE_SALES_ORDERS_SUB_LINES

  # Check for semi-finished goods ...
  Read [ITM]ITM0 = PRODUCT
  If (fstat = 0)

    Read [ITG]ITG1 = [F:ITM]TCLCOD; ""
    If (fstat = 0 and
&       [F:ITG]SALFLG = 2)


      # CCM ...
      Local File BOMWUS [BOW]
      Call CALCULATE_WHERE_USED_ECC(this.ACTX,
&                               PRODUCT,
&                               MAJOR_VERSION,
&                               MINOR_VERSION,
&                               WDATREF,
&                               WLSTTYP,
&                               WALTTYPSTR,
&                               WALTTYPEND,
&                               WALTSTR,
&                               WALTEND,
&                               MYCRIT,
&                               MYFOR,
&                               WRET) From SUBBOW_SYRA

      Filter [BOW] Where CREUSR = this.ACTX.USER and
&                        BOWUID = adxuid(1)
&                  Order By ITMREF
      For [BOW]
        If ([F:BOW]ITMREF <> LAST_ITMREF)
          SUB_LINES_PRODUCT = [F:BOW]ITMREF
          # if version managed

          If (fmet SELCHGREQ.IS_PRODUCT_VERSION_MANAGED(SUB_LINES_PRODUCT) > 1)
            Local File ECCVAL [EVL]
            # for each version, create lines
            CRITERIA = " 1=1 "
            If [F:BOW]BOMSTRDAT<>[0/0/0]
              CRITERIA+=" & STRDAT>=["+format$(GFMD,[F:BOW]BOMSTRDAT)+"]"
            Endif
            If [F:BOW]BOMENDDAT<>[0/0/0]
              CRITERIA+=" & STRDAT<=["+format$(GFMD,[F:BOW]BOMENDDAT)+"]"
            Endif

            BLANK_VERSION = CST_ATRUE
            For [EVL] Where ITMREF=[F:BOW]ITMREF & ECCTYP=[F:BOW]BOMALTTYP & BOMALT=[F:BOW]BOMALT  & evalue(CRITERIA)
              SUB_ECCVALMAJ = [F:EVL]ECCVALMAJ
              SUB_ECCVALMIN = [F:EVL]ECCVALMIN
              Gosub CREATE_SALES_ORDERS_SUB_LINES
              If (BLANK_VERSION = CST_ATRUE)
                BLANK_VERSION = CST_AFALSE
              Endif
            Next
            Close Local File [EVL]
          Else
            BLANK_VERSION = CST_AFALSE
            SUB_ECCVALMAJ = ""
            SUB_ECCVALMIN = ""
            Gosub CREATE_SALES_ORDERS_SUB_LINES
          Endif
          LAST_ITMREF = [F:BOW]ITMREF
        Endif
      Next
      # CCM ...
      Delete [BOW] Where CREUSR = this.ACTX.USER and BOWUID = adxuid(1)

      Close Local File [BOW]

    Endif
  Endif
#  ALOG_RET = fmet ALOG.AENDLOG()
  # Update summary totals ...
  this.SOHCUST = NO_CUST
  this.SOHORDERS = NO_ORDERS
  this.TOTALLINES = LINE_NUMBER

  Close Local File [ITM]
  Close Local File [ITG]
  FreeGroup SELCHGREQ

Return


# -------------------------------------------------------------------------------
$CREATE_SALES_ORDERS_SUB_LINES
  Local Integer LOCSTATUS
  Local Integer STAT, FOUND, COUNT
  Local Decimal WMNTCALC
  Local Decimal AMNTCALC
  Local File SORDER [SOH]
  Local File SORDERQ [SOQ]
  Local File SORDERP [SOP]
  Local Char CRITERIA(250)

  Local Instance CCMIMPSOD Using C_CCMIMPSOD
  CCMIMPSOD = NewInstance C_CCMIMPSOD AllocGroup null

  # Create new sales order lines
  CRITERIA = " 1=1 "
  If (SUB_ECCVALMAJ <> "")
    If (BLANK_VERSION = CST_ATRUE)
      CRITERIA += " and [F:SOQ]ECCVALMAJ = '' or [F:SOQ]ECCVALMAJ = SUB_ECCVALMAJ"
    Else
      CRITERIA += " and [F:SOQ]ECCVALMAJ = SUB_ECCVALMAJ"
    Endif

    If (SUB_ECCVALMIN <>  "")
      If (BLANK_VERSION = CST_ATRUE)
        CRITERIA += " and [F:SOQ]ECCVALMIN = '' or [F:SOQ]ECCVALMIN = SUB_ECCVALMIN"
      Else
        CRITERIA += " and [F:SOQ]ECCVALMIN = SUB_ECCVALMIN"
      Endif
    Endif
  Endif

  Filter [SOQ] Where [F:SOQ]ITMREF = SUB_LINES_PRODUCT and
&        [F:SOQ]SOQSTA <> 3 and [F:SOQ]DEMSTA <> 4 and
&        evalue(CRITERIA)

  For [SOQ]SOQ0

      LOCSTATUS = fmet CCMIMPSOD.AINIT()

      LINE_NUMBER += 1

      CCMIMPSOD.CRID = CRID
      CCMIMPSOD.LINENO = LINE_NUMBER
      CCMIMPSOD.SORTSEQ = LINE_NUMBER
      CCMIMPSOD.SOHNUM = [F:SOQ]SOHNUM
      CCMIMPSOD.SOPLIN = [F:SOQ]SOPLIN
      CCMIMPSOD.SOQSEQ = [F:SOQ]SOQSEQ
      CCMIMPSOD.ITMREF = SUB_LINES_PRODUCT
      CCMIMPSOD.ECCVALMAJ = [F:SOQ]ECCVALMAJ
      CCMIMPSOD.ECCVALMIN = [F:SOQ]ECCVALMIN
      CCMIMPSOD.BPCORD = [F:SOQ]BPCORD
      CCMIMPSOD.SALFCY = [F:SOQ]SALFCY
      CCMIMPSOD.QTY = [F:SOQ]QTY
      CCMIMPSOD.SOQSTA = [F:SOQ]SOQSTA
      CCMIMPSOD.DEMSTA = [F:SOQ]DEMSTA
      CCMIMPSOD.BLOCK = 1       # 1 = No
      CCMIMPSOD.TRANTYPE = 10    # 10 = Sales order
      CCMIMPSOD.LINESTATUS = 1   # 1 = Pending
      CCMIMPSOD.STARTDATE= AVOID.ADATE
      CCMIMPSOD.ENDDATE= AVOID.ADATE
      CCMIMPSOD.COMPLETEDATE= AVOID.ADATE
      CCMIMPSOD.ACTIONID = ""
      CCMIMPSOD.ACTIONER = ""
      CCMIMPSOD.COMMENT = ""

      CCMIMPSOD.OPRQTYSTU = [F:SOQ]OPRQTYSTU
      CCMIMPSOD.PREQTYSTU = [F:SOQ]PREQTYSTU
      CCMIMPSOD.ODLQTYSTU = [F:SOQ]ODLQTYSTU
      CCMIMPSOD.DLVQTY    = [F:SOQ]DLVQTY
      LOCSTATUS = fmet CCMIMPSOD.SET_STAGE()

      # get line amount + tax
      WMNTCALC = 0.00
      Read [SOP]SOP0 = [F:SOQ]SOHNUM ;[F:SOQ]SOPLIN ;[F:SOQ]SOQSEQ
      If fstat = 0
        WMNTCALC = [F:SOQ]QTY * [F:SOP]NETPRIATI

        Read [SOH]SOH0 = [F:SOQ]SOHNUM
        If fstat=0 and [F:SOH]CUR <> ""
          Call ARRDEV (WMNTCALC,  [F:SOH]CUR) From TRTDIV
        Endif
      Endif

      # Get line amount - tax
      AMNTCALC = 0.00
      Read [SOP]SOP0 = [F:SOQ]SOHNUM ;[F:SOQ]SOPLIN ;[F:SOQ]SOQSEQ
      If fstat = 0
        AMNTCALC = [F:SOQ]QTY * [F:SOP]NETPRINOT

      Read [SOH]SOH0 = [F:SOQ]SOHNUM
      If fstat=0 and [F:SOH]CUR <> ""
        Call ARRDEV (AMNTCALC,  [F:SOH]CUR) From TRTDIV
      Endif

      CCMIMPSOD.NETPRIATI = WMNTCALC
      CCMIMPSOD.NETPRINOT = AMNTCALC
      CCMIMPSOD.SOHCUR = [F:SOH]CUR
      CCMIMPSOD.FOLDCUR = this.FOLDCUR

      # Convert line amount - tax to folder currency
      If CCMIMPSOD.SOHCUR <> CCMIMPSOD.FOLDCUR
        Call CONVERT (this.ACTX, CCMIMPSOD.SOHCUR, CCMIMPSOD.FOLDCUR, CCMIMPSOD.FOLDCUR,
&       [F:SOH]CHGTYP, [F:SOH]ORDDAT, CCMIMPSOD.NETPRINOT, CCMIMPSOD.CONAMNT, STAT) From TRTDEV_SYRA
      Else
        CCMIMPSOD.CONAMNT = CCMIMPSOD.NETPRINOT
      Endif

      Endif

      LOCSTATUS = fmet CCMIMPSOD.AINSERT()

      # Maintain unique customer and order arrays / totals:
      #
      # Customer ...
      FOUND = CST_AFALSE
      For COUNT = 0 To NO_CUST
        If (CCMIMPSOD.BPCORD = MYBPCNUM(COUNT))
          FOUND = CST_ATRUE
          Break
        Endif
      Next
      If (FOUND = CST_AFALSE)
        MYBPCNUM(NO_CUST) = CCMIMPSOD.BPCORD
        NO_CUST = NO_CUST +1
      Endif

      # Order ...
      FOUND = CST_AFALSE
      For COUNT = 0 To NO_ORDERS
        If (CCMIMPSOD.SOHNUM = MYSOHNUM(COUNT))
          FOUND = CST_ATRUE
          Break
        Endif
      Next
      If (FOUND = CST_AFALSE)
        MYSOHNUM(NO_ORDERS) = CCMIMPSOD.SOHNUM
        NO_ORDERS = NO_ORDERS +1
      Endif

      # Increment summary totals ...
      this.SOHQTY += CCMIMPSOD.QTY
      this.SOHAMTEX += CCMIMPSOD.CONAMNT

  Next

  LogicClose File [SOH]
  LogicClose File [SOQ]
  LogicClose File [SOP]

  FreeGroup CCMIMPSOD

Return

# SLL
# -------------------------------------------------------------------------------
# Update Sales Oreder Detail Plan 'header' status.
#
# Set status to:
#
# 4 'Not applicable'  ... if (No sales order lines) or (No actionable sales order lines and Planning complete),
# 3 'Complete'        ... if (All actionable sales order lines are complete),
# 2 'Implement'       ... if (Actionable sales order lines and Planning complete),
# 1 'Plan'            ... if (Planning is not complete).

$UPDATE_STATUS

  Local Integer STAT, ACTIONLINES, LINESCOMP

#Start the profile ...
#Local Char WFICTRACE(60)
#STAT = func ASYRTIMING.START("",1)

  # Count number of action lines ...
  Local File CCMIMPSOD [CCMSOD]
  Filter [CCMSOD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMSOD])

  # Count number of action lines completed ...
  Filter [CCMSOD] Where CRID = this.CRID and LINESTATUS = 3
  LINESCOMP = rowcount([CCMSOD])

  Filter [CCMSOD]
  LogicClose File [CCMSOD]

  If (this.SOHORDERS = 0) or
&    (ACTIONLINES = 0 and this.IMPLEMENT = 2)
    this.SOHPLASTA = 4
  Elsif (ACTIONLINES <> 0 and ACTIONLINES = LINESCOMP)
    this.SOHPLASTA = 3
  Elsif (this.IMPLEMENT = 2)
    this.SOHPLASTA = 2
  Else
    this.SOHPLASTA = 1
  Endif

#End the profile ...
#STAT = func ASYRTIMING.STOP(GACTX,"",1,WFICTRACE)

  ARET_VALUE = CST_ATRUE

Return


# -------------------------------------------------------------------------------
# "Planning complete" flag validation ...
$VALIDATE_IMPLEMENT

  Local Integer ACTIONLINES, LOCSTATUS

  ASTATUS = CST_AOK

  # count number of action lines
  Local File CCMIMPSOD [CCMSOD]
  Filter [CCMSOD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMSOD])
  LogicClose File [CCMSOD]

  If (this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
    If (this.TOTALLINES > ACTIONLINES)
#      LOCSTATUS = fmet this.ASETERROR ("IMPLEMENT", mess(62,2038,1), CST_AINFO)
      LOCSTATUS = fmet this.ASETERROR ("", mess(62,2038,1), CST_AINFO)
    Endif
  Endif

 ARET_VALUE = ASTATUS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_ACTIONER
# FUNCTION DESCRIPTION: Notify Actioner
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_ACTIONER

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local File CCMIMPSOD [SOD]
  Local Char LAST_ACTIONER(5)
  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)
  Local Integer AC_EMAIL : AC_EMAIL = CST_AFALSE
# Issue 109096/2 - send e-mails to actioners
  Local Integer SENDEMAIL : SENDEMAIL = CST_AFALSE
  STAT = fmet CHANGE_REQUEST.AREAD(this.CRID)

  If (CHANGE_REQUEST.NCSREC = 2)
    # Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS
#    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "NCSEMAILAC") <> 1 and
#&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
#
#      SENDEMAIL = CST_ATRUE
#      EMAIL_TYPE = 3713  # Actioner
#      BODY(0) = AVOID.ACLOB
#      OTHER_BODY(0) = AVOID.ACLOB
#      Append OTHER_BODY, mess(10,2039,1) +chr$(10)
#      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "NCSPLASOH")
#    Endif
    # End issue X3-76268
  Else
# End issue 109096/2

    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAC") <> 1 and
&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)

      SENDEMAIL = CST_ATRUE
      EMAIL_TYPE = 2066  # Actioner
      BODY(0) = AVOID.ACLOB
      OTHER_BODY(0) = AVOID.ACLOB
      Append OTHER_BODY, mess(10,2039,1) +chr$(10)
      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "CCMPLASOH")
    Endif
# Issue 109096/2
  Endif

  If (SENDEMAIL = CST_ATRUE)
# End issue 109096/2

    Filter [SOD] Where CRID = this.CRID and ACTIONER <> "" Order By ACTIONER
    For [SOD]
      If ([F:SOD]ACTIONER <> LAST_ACTIONER and
&         [F:SOD]ACTIONER <> this.ACTX.USER)

        STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, [F:SOD]ACTIONER, "", SUBJECT, BODY)

        If (STAT = CST_AOK)
          AC_EMAIL = CST_ATRUE
        Endif

        LAST_ACTIONER = [F:SOD]ACTIONER

      Endif
    Next

    If (AC_EMAIL = CST_ATRUE)
      ASTATUS = fmet this.ASETERROR("", mess(60,2038,1), CST_AINFO)
    Endif

  Endif

  LogicClose File [SOD]
  FreeGroup CHANGE_REQUEST

Return

$PROPERTIES
  Case CURPRO
  Endcase
Return


