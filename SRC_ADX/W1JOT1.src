$ON_WMIS
Return

$ON_MIS
Onevent BEFORE_INPUT Call AS_MIS(zc) From W1JOT1
Onevent CONTROL Call C_MIS(zc) From W1JOT1
Onevent AFTER_AREA Call AP_MIS(zc) From W1JOT1
Onevent AFTER_CHANGE Gosub AMM_MIS From W1JOT1
Return

Subprog AS_MIS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16225,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_MIS(VALEUR) From SUBJOT
If mkstat=2
 [M]MIS(INDIC) = VALEUR
 Affzo MIS(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_MIS(zc) From W1JOT1
Onkey   2 Titled GBOUTS Call S_MIS(zc) From W1JOT1
Onkey 144 Titled GBOUTP Call P_MIS(zc) From W1JOT1
Onkey 146 Titled GBOUTA Call SA_MIS(zc) From W1JOT1
Gosub _AFF
End

Subprog C_MIS(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("MIS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
If !mkstat
 ## Action STD
 Call C_MIS(VALEUR) From SUBJOT
 If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
Endif
Gosub _AFF
End

Subprog AP_MIS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_MIS(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
Gosub _AFF
End

$AMM_MIS
Call AM_MIS(zc)
If !mkstat & GOBJET
 zoncou = "MIS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MIS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_MIS(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZMIS)")>indice
 [M]MIS(indice) = VALEUR
 Affzo ZMIS(indice)
Endif
Gosub _AFF
End

Subprog S_MIS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELMISLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELMISLEG"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELMISLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_MIS(VALEUR)
Variable Char    VALEUR()
Call OBJET("MIS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_MIS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "MIS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_MIS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("MIS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZMIS
Onevent BEFORE_AREA Gosub AV_ZMIS From W1JOT1
Return

$AV_ZMIS
If clalev([F:MIS])=0 : Local File MISSION [MIS] : Endif
Call LECTURE("MIS",num$([M]MIS(indice)),"") From CONTOBJ
zc = [F:MIS]DES
Gosub _AFF
Return

