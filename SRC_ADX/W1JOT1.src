#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque JOT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:15"
A_USER  = "DOC"
A_STAMP = "20181109230515"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRMIS"
  If [M]NBRMIS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask JOT1 [JOT1]
Gosub HORODAT
Local Inpbox "JOT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT1] As [SIM_]
Grizo [JOT1]5
Grizo [JOT1]10
Grizo [JOT1]15
Grizo [JOT1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [JOT1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=80 : Y1(1)=5 : Y2(1)=17
X1(2)=1 : X2(2)=80 : Y1(2)=18 : Y2(2)=21
X1(3)=1 : X2(3)=80 : Y1(3)=22 : Y2(3)=24
Return

$ON_DATSTRVLY
Onevent BEFORE_AREA Gosub AV_DATSTRVLY From W1JOT1
Return

$AV_DATSTRVLY
Chgfmt [M]DATSTRVLY(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATENDVLY
Onevent CONTROL Call C_DATENDVLY(zc) From W1JOT1
Onevent BEFORE_AREA Gosub AV_DATENDVLY From W1JOT1
Return

$AV_DATENDVLY
Chgfmt [M]DATENDVLY(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATENDVLY(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]DATSTRVLY) From EXEFNC
If mkstat : GERR = 1 : GZONE = "DATENDVLY" : GZNUM = 51340 : Endif
Gosub _AFF
End

$ON_DESSHO
Onevent INIT_AREA Call D_DESSHO(zc) From W1JOT1
Onevent BEFORE_INPUT Call AS_DESSHO(zc) From W1JOT1
Return

Subprog IB_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESSHO(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESSHO,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"JOBTYP","DESSHO",COD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESSHO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESSHO(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESSHO(zc) From W1JOT1
Gosub _AFF
End

Subprog B1_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESSHO" : PROGSUB = "SUBJOT" : PROGSPE = "SPEJOT0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "JOBTYP"
 PARMSK(2) = "DESSHO"
 PARMSK(3) = COD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESSHO" : PROGSUB = "SUBJOT" : PROGSPE = "SPEJOT0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_MISWEIFLG
Onevent AFTER_CHANGE Gosub AMM_MISWEIFLG From W1JOT1
Onevent INIT_AREA Call D_MISWEIFLG(zc) From W1JOT1
Onevent BEFORE_INPUT Call AS_MISWEIFLG(zc) From W1JOT1
Return

Subprog D_MISWEIFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]MISWEIFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MISWEIFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_MISWEIFLG
Call AM_MISWEIFLG(zc)
If !mkstat & GOBJET
 zoncou = "MISWEIFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MISWEIFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_MISWEIFLG(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "MISWEIFLG" : GZNUM = 1001671 : Endif
Gosub _AFF
End

