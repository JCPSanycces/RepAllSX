#<AdxTL>@(#)0.0.0.0 $Revision$
$SDELIVERY
Gosub OPEN_LNK_SDH From SAFTGENPORMG
Raz [L]MGRATCUR
For [MGT1]
  If [F:PTDK2]RATCUR<>0
    [L]MGRATCUR = [F:PTDK2]RATCUR
  Else
    Gosub SET_SDH_RATCUR
  Endif
  Gosub RAZVAR_MG From SAFTGENPORMG
  Call LEC_TSD_LEG([F:PTFCY]LEG, [F:PTSDH]SDHTYP, STAT) From TRTLECLEG
  If [L]SAFTTYPE = 8
    If ctrans([F:PTSDH]BPDADDLIG(0)+[F:PTSDH]BPDADDLIG(1)+[F:PTSDH]BPDADDLIG(2)," ","")<>''
      [L]MGCOUNTRY_ST = vireblc([F:PTSDH]BPDCRY,2)
    Else
      Call ADDRESS(1,[F:PTSDH]BPCORD,[F:PTSDH]BPAADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
    Endif
    If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Goto NEXTSDH2 : Endif

    Call ADDRESS(3,[F:PTSDH]STOFCY,[F:PTFCY]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
    If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Goto NEXTSDH2 : Endif

    If [F:PTSDH]GLBDOCNUM<>'' | !find([F:PTDK2]RECTYP,1)  : Goto NEXTSDH2 : Endif

    If !STAT & [F:PTDK2]SAFTTRNTYP = 3 :  : Endif

    # BRBAN 09/04/2015 #107599
    If func PORLEGLIB1.CTRL_COMDAT([F:PTSDH]STOFCY,[F:PTSDH]DPEDAT,[F:PTSDH]ETD)<>1 : Goto NEXTSDH2 : Endif
    # -
  Endif
  Gosub FEED_VARS
  $NEXTSDH2
Next
Gosub CLOSE_LNK_SDH From SAFTGENPORMG
Return

$FEED_VARS
#DocumentNumber
#Se encontrar dksdocnum com espaço na dksdata, introduzo esse. Se não introduz-se como esta
Call PTNUMDOC([F:PTSDH]SDHTYP,[F:PTSDH]SDHNUM,[L]MGDOCNUMB) From SAFTGENPORMG

#ATCUD
[L]MGATCUD = "0"

#MovementStatus
[L]MGMOVSTAT = 'N'
If [L]SAFTWAY=1
  If [L]SAFTTYPE <> 6
    If [F:PTSDH]SIHNUM<>'' & [F:PTSDH]INVFLG=2
      Filter [F:SIH]
      Filter [F:SIH] Where evalue([L]FACCRITER)
      Read [F:SIH]SIH0=[F:PTSDH]SIHNUM
      If !fstat
        [L]MGMOVSTAT = 'F'
        #Issue X3-92404 – 2018-06-18 by MADOR - 2018.R5 - SourceIDtag from SAFT incorrect - movementofgoods
        #SourceID -> DocumentStatus
        [L]MGUPDUSER = [F:SIH]CREUSR
        #MovementStatusDate
        Read [F:DKD]DKD0="SAFT-PT";[F:SIH]SIVTYP;[F:SIH]NUM
        If !fstat
          If [F:DKD]VALIDDAT=[0/0/0]
            [L]MGMOVSTDT = format$("D:YYYY[-]MM[-]DD",[F:SIH]ACCDAT)+"T"+[F:DKD]VALIDTIM
          Else
            [L]MGMOVSTDT = format$("D:YYYY[-]MM[-]DD",[F:DKD]VALIDDAT)+"T"+[F:DKD]VALIDTIM
          Endif
        Endif
        Filter [F:DKD]
        #Issue X3-92404 end
      Else
        [L]MGMOVSTAT = 'N'
      Endif
      Filter [F:SIH]
    Else
      [L]MGMOVSTAT = 'N'
    Endif
  Else
    [L]MGMOVSTAT = 'N'
  Endif
Endif
#SystemEntryDate, Reason, SourceID(Modification), Hash, HashControl, SourceID(Creation), ATDocCodeID, SourceBilling
# Issue 105227 - 2015-08-21 by BRBAN :[L]MGMOVTYPE - MovementType must come from DKSDATA
If [F:PTDK2]RECTYP=4 #External document
  Call DOCSTAT([F:PTSDH]SDHTYP,[F:PTSDH]SDHNUM,[F:PTSDH]SHIDAT,2,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Else #Other
  Call DOCSTAT([F:PTSDH]SDHTYP,[F:PTSDH]SDHNUM,[F:PTSDH]SHIDAT,1,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Endif

#MovementType
# Issue 105227 - 2015-08-21 by BRBAN : If it's null, then fill with [F:TSD]SAFTTRNTYP
# RMA * Do not change, this is for previous cases when we didn't have SAFTTRNTYP on DKSDATA
If [L]MGMOVTYPE=''
  Call MANDOC_TEXT_GT([F:TSD]RECTYP,[F:TSD]SAFTTRNTYP,[L]MGMOVTYPE) From PORLEGLIB
Endif

#SourceID(Creation) - When there isn't any record on DKSDATA
If [L]MGCREUSER = ''
  [L]MGCREUSER = [F:PTSDH]CREUSR
Endif

#Period
[L]MGPERIODE  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:PTSDH]CPY, [F:PTSDH]SHIDAT)

#MovementDate
[L]MGMOVEDAT  = format$("D:YYYY[-]MM[-]DD",[F:PTSDH]SHIDAT)
#Issue X3-92404 – 2018-06-18 by MADOR - 2018.R5 - SourceIDtag from SAFT incorrect - movementofgoods
If [L]MGMOVSTAT <> 'F'
  #MovementStatusDate
  [L]MGMOVSTDT = [L]MGSYSENTD
  #SourceID -> DocumentStatus
  [L]MGUPDUSER = [L]MGCREUSER
Endif
#Issue X3-92404 end
#TransactionID
If [L]SAFTTYPE=2
  Filter [F:PTSTJ] Where VCRNUM=[F:PTSDH]SDHNUM & STOFCY= [F:PTSDH]STOFCY
  Read [F:PTSTJ] First
  If !fstat
    Read [F:HAE]HAE0 = [F:PTSTJ]GTE;[F:PTSTJ]NUMVCR
    If !fstat
      If len([F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/",""))>20
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + ctrans([F:HAE]NUM,"_-.\/","")
      Else
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + [F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/","")
      Endif
    Endif
  Endif
  Filter [F:PTSTJ]
Endif

#CustomerID
[L]MGCUSTOID = [F:PTSDH]BPCORD
If [F:PTSDH]BPIEECNUM <> ""
   Read [F:PTBPR]BPR0 = [F:PTSDH]BPCORD
   If !fstat
      If [F:PTSDH]BPIEECNUM <> [F:PTBPR]EECNUM & [F:PTSDH]BPIEECNUM <> ""
         [L]MGCUSTOID = "D"+toupper([F:PTSDH]BPIEECNUM)
      Endif
   Endif
Endif

#SupplierID
[L]MGSUPPLID = ""
#MovementComments
[L]MGCOMMENT = ""
#DeliveryID
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
[L]MGDELIVID = vireblc([F:PTSDH]LICPLATE-[F:PTSDH]TRLLICPLATE, 2)
If [L]MGDELIVID = ""
  [L]MGDELIVID = "Desconhecido"
Endif
#Issue X3-90614 end
#Issue X3-31864 – 2017-04-12 by MANOW
[L]DELIVNUM = [F:PTSDH]SDHNUM

[L]MGATCUD = "0"
[L]MGIECAM = 0

#Issue X3-31864 end
#DeliveryDate
[L]MGDELIVDT = [F:PTSDH]DLVDAT
#LocationID
[L]MGLOCATID = ""
#BuildingNumber
[L]MGBUIDNBR = "Desconhecido"
#ShipTo
#WarehouseID
[L]MGWAREHID_ST = ""

#StreetName,AddressDetail,City,PostalCode,Region
If ctrans([F:PTSDH]BPDADDLIG(0)+[F:PTSDH]BPDADDLIG(1)+[F:PTSDH]BPDADDLIG(2)," ","")<>''
  [L]MGSTREETN_ST = ''
  [L]MGADDDETA_ST = vireblc([F:PTSDH]BPDADDLIG(0)-[F:PTSDH]BPDADDLIG(1)-[F:PTSDH]BPDADDLIG(2),2)
  [L]MGCITY_ST    = vireblc([F:PTSDH]BPDCTY,2)
  [L]MGPOSTCOD_ST = vireblc([F:PTSDH]BPDPOSCOD,2)
  [L]MGCOUNTRY_ST = vireblc([F:PTSDH]BPDCRY,2)
  [L]MGREGION_ST  = vireblc([F:PTSDH]BPDSAT,2)
Else
  Call ADDRESS(1,[F:PTSDH]BPCORD,[F:PTSDH]BPAADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
Endif

If [L]MGADDDETA_ST  = '' : [L]MGADDDETA_ST  = 'Desconhecido' : Endif
If [L]MGCITY_ST     = '' : [L]MGCITY_ST     = 'Desconhecido' : Endif
If [L]MGPOSTCOD_ST  = '' : [L]MGPOSTCOD_ST  = '0000000'      : Endif
If [L]MGREGION_ST   = '' : [L]MGREGION_ST   = 'Desconhecido' : Endif
If [L]MGCOUNTRY_ST  = '' : [L]MGCOUNTRY_ST  = 'PT'           : Endif

If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

If len([L]MGPOSTCOD_ST) = 7 & [L]MGCOUNTRY_ST = 'PT'
  [L]MGPOSTCOD_ST = format$("K:4#[-]3#", [L]MGPOSTCOD_ST)
Endif

#ShipFrom
#WarehouseID
[L]MGWAREHID_SF = [F:PTSDH]STOFCY

#StreetName,AddressDetail,City,PostalCode,Region
Call ADDRESS(3,[F:PTSDH]STOFCY,[F:PTFCY]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

#MovementEndTime
If [F:PTSDH]ARVDAT<>[0/0/0] & [F:PTSDH]ETA<>"0000"
  [L]MGMOVENDT = format$("D:YYYY[-]MM[-]DD",[F:PTSDH]ARVDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSDH]ETA,":","")+"00")
Endif
#MovementStartTime
If [F:PTSDH]DPEDAT<>[0/0/0] & [F:PTSDH]ETD<>"0000"
  [L]MGMOVSTRT = format$("D:YYYY[-]MM[-]DD",[F:PTSDH]DPEDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSDH]ETD,":","")+"00")
Else
  Call ECR_TRACE (mess(4,701,1)-[F:PTSDH]SDHNUM -mess(236,7711,1), 1) From GESECRAN
Endif

Gosub SET_TZ From PORLEGLIB1

#VEHICLEID
[L]VEHICLEID = [F:PTSDH]LICPLATE+[F:PTSDH]TRLLICPLATE

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_H From SAFTGENPORMG
Endif

Gosub GET_TAX_ARRAY #Array footer elements

# Issue X3-105529 by MRDAB: fixed KIT communication in SAF-T
#For [F:PTSDD] Where [F:PTSDD]SDHNUM=[F:PTSDH]SDHNUM
For [F:PTSDD] Where [F:PTSDD]SDHNUM = [F:PTSDH]SDHNUM and ([L]SAFTPRDKITACTIVE = "2" | ([L]SAFTPRDKITACTIVE = "1" and find([F:PTSDD]LINTYP, 3,4,5,7,8,9) = 0))
# Issue end X3-105529
  Gosub RAZVAR_MG_D From SAFTGENPORMG
  #LineNumber
  #[L]MGDLINNBR = [F:PTSDD]SDDLIN
  [L]MGDLINNBR +=1
  #OriginatingON,OrderDate
  [L]MGDORIGIN  = ""

  If [F:PTSDH]GLBDOCNUM<>''
    [L]MGDORIGIN=[F:PTSDH]GLBDOCNUM
    If !instr(1,[L]MGDORIGIN," ")
        Call SET_ORIGON([L]MGDORIGIN) From SAFTGENPORMG
    Endif
    [L]MGDORDDAT=[F:PTSDH]GLBDOCDAT
  Endif

  #ProductCode
  [L]MGDPRODUC = [F:PTSDD]ITMREF
  #ProductDescription
  If [F:PTSDD]ITMDES1<>""
    [L]MGDPRODES = [F:PTSDD]ITMDES
  Else
    [L]MGDPRODES = "Desconhecido"
  Endif
  #Quantity
  [L]MGDQUANTI  = [F:PTSDD]QTY
  #UnitOfMeasure
  [L]MGDUOM    = [F:PTSDD]SAU
  #UnitPrice
  [L]MGDNETPRI = abs([F:PTSDD]NETPRINOT*[L]MGRATCUR)
  #Description
  If [F:PTSDD]ITMDES1<>""
    [L]MGDLINDES = [F:PTSDD]ITMDES1
  Else
    [L]MGDLINDES = "Desconhecido"
  Endif

  #SettlementAmount
  [L]MGDSETAMT  =   (([F:PTSDD]GROPRI-[F:PTSDD]NETPRINOT)*[L]MGRATCUR)*[F:PTSDD]QTY

  #Footer elements
  Call FOOTER_ELEMENT([F:PTSDD]VAT(0),ARRAY_VAT,ARRAY_VATNET,DIMSVV,ARRAY_FOOTVAT,ARRAY_FOOTNET,DIMSVF,SAFPRIRND,[L]MGDQUANTI,[L]MGDNETPRI,[L]MGDSETAMT)

  #DebitAmount/CreditAmount
  If [F:PTSDD]NETPRINOT<0
    [L]MGDDEBAMT = abs([L]MGDQUANTI * ([L]MGDNETPRI*[L]MGRATCUR))
  Else
    [L]MGDCREAMT = abs([L]MGDQUANTI * ([L]MGDNETPRI*[L]MGRATCUR))
  Endif

  If abs([F:PTSDD]NETPRINOT)<>0
    #TaxType,TaxCountryRegion,TaxCode,TaxPercentage,TaxExemptionReason
    For YC = 0 To 0  #Alterar?
     If [F:PTSDD]VAT(YC)<>""
        #Issue X3-31864 – 2017-04-11  by MANOW
        Call GETTAX([L]SOC,[F:PTSDD]VAT(YC),[F:PTSDH]SHIDAT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXAMO,[L]MGDTAXEXA,[L]MGDTAXEXAC,[L]VENEXEFLG) From SAFTGENPORVAT
        #Issue X3-31864 end
        If [L]VENEXEFLG = 2 : [L]MGDTAXPER = 0.0 : Endif
     Endif
    Next
  Endif

  If [F:ITM]ITMREF <> [F:PTSDD]ITMREF
    Read [F:ITM]ITM0 = [F:PTSDD]ITMREF
  Endif
  If !fstat
    If [F:ITM]SERMGTCOD > 1
      For [F:STJ]STJ1 Where [F:STJ]STOFCY = [F:PTSDH]STOFCY & [F:STJ]VCRTYP = 4 & [F:STJ]VCRNUM = [F:PTSDH]SDHNUM & [F:STJ]VCRLIN = [F:PTSDD]SDDLIN & [STJ]SERNUM <> ""
        [L]SDLSERNUM(maxtab([L]SDLSERNUM)+1)=[STJ]SERNUM
      Next
    Endif
  Endif

  If [L]SAFTWAY=1
    Gosub WRITE_MOVEG_D From SAFTGENPORMG
  Else
    Gosub FEED_VAR_WS From PORLEGLIB1
  Endif
Next

#Footer elements
For [F:PTSVF] Where [F:PTSVF]VCRNUM=[F:PTSDH]SDHNUM
 Raz [L]MGDORIGIN,[L]MGDORDDAT,[L]MGDPRODUC,[L]MGDPRODES,[L]MGDQUANTI,[L]MGDUOM,[L]MGDNETPRI
 #Issue X3-31864 – 2017-04-11  by MANOW
 Raz [L]MGDLINDES,[L]MGDDEBAMT,[L]MGDCREAMT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXAMO,[L]MGDTAXEXA,[L]MGDTAXEXAC
 #Issue X3-31864 end
 Raz [L]MGDSETAMT,[L]STOJOUQTY,[L]STOJOUVAL,[L]PCUSTUCOE
 For I=0 To 9
   If (!find([F:PTSVF]DTAVAT(I),[L]CTRLVAT(1..[L]COUNTVAT)) & [F:PTSVF]DTAVATNOT(I) <> 0) | [F:PTSVF]DTAVATNOT(I) > 0
     Read [F:VCL]VCL0=[L]SOC;[F:PTSVF]DTAVAT(I)
     If !fstat
       #[L]MGDLINNBR  += 1000
       [L]MGDLINNBR  += 1
       [L]MGDQUANTI   = 1
       [L]MGDNETPRI   = abs([F:PTSVF]DTAVATNOT(I))
       [L]MGDUOM      = "UN"
       [L]MGDPRODUC   = "ELEMFACT"
       [L]MGDPRODES   = "Elementos de Facturação"
       # Issue X3-99026 by MRDAB
       Call LECTEXTRA_POR([L]MGDLINDES,"SFOOTINV","DESAXX",num$([F:PTSVF]DTA),"") From SAFTGENPOR
       # Issue X3-99026 end
       If [F:PTSVF]DTAVATNOT(I)>0
         [L]MGDDEBAMT=abs([F:PTSVF]DTAVATNOT(I))
       Else
         [L]MGDCREAMT=abs([F:PTSVF]DTAVATNOT(I))
       Endif
       #Issue X3-31864 – 2017-04-11  by MANOW
       Call GETTAX([L]SOC,[F:PTSVF]DTAVAT(I),[F:PTSDH]SHIDAT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXAMO,[L]MGDTAXEXA,[L]MGDTAXEXAC,[L]VENEXEFLG) From SAFTGENPORVAT
       #Issue X3-31864 end
       If [L]VENEXEFLG = 2 : [L]MGDTAXPER = 0.0 : Endif
       If [L]SAFTWAY=1
         Gosub WRITE_MOVEG_D From SAFTGENPORMG
       Else
         Gosub FEED_VAR_WS From PORLEGLIB1
       Endif
      Endif
    Endif
  Next
Next
#-

#TaxPayable
[L]MGTTAXPAY = [F:PTSDH]DLVINVATIL-[F:PTSDH]DLVINVNOTL
#NetTotal
[L]MGTNETTOT = [F:PTSDH]DLVINVNOTL
#GrossTotal
[L]MGTGROTOT = [F:PTSDH]DLVINVATIL
#CurrencyAmount
[L]MGTCURAMT = [F:PTSDH]DLVINVATI

If [F:PTSDH]CUR <>'EUR'
  #CurrencyCode
  #[L]MGTCURCOD = [F:PTSDH]CUR
  #ExchangeRate
  [L]MGTEXCRAT = [L]MGRATCUR
  If [F:TCU]CUR <> [F:PTSDH]CUR
    Read [F:TCU]TCU0 = [F:PTSDH]CUR
  Endif
  [L]MGTCURCOD = [F:TCU]ISOCOD
Endif

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_T From SAFTGENPORMG
Endif

Return
#############################################################################################
#############################################################################################
$SET_SDH_RATCUR

[L]MGRATCUR = [F:PTSDH]CHGRAT
If [L]MGRATCUR = 0 : [L]MGRATCUR = 1 : Endif

Return
#############################################################################################
#############################################################################################
$GET_TAX_ARRAY
Raz[L]CTRLVAT : [L]COUNTVAT =1
Raz ARRAY_VAT, ARRAY_VATNET, ARRAY_FOOTVAT, ARRAY_FOOTNET,[L]SDL1

#Tax
Filter [F:SVV] Where [F:SVV]VCRNUM = [F:PTSDH]SDHNUM & [F:SVV]VATTYP = 1 Order By [F:SVV]VAT Asc
For [F:SVV]
  [L]CTRLVAT([L]COUNTVAT) = [F:SVV]VAT  : [L]COUNTVAT + = 1
  ARRAY_VAT([L]SDL1)      = [F:SVV]VAT
  ARRAY_VATNET([L]SDL1)   += [F:SVV]VATNET
  [L]SDL1 += 1
Next
Filter [F:SVV]

#Footer  elements
Raz [L]SDL1
For [F:SVF] Where [F:SVF]VCRNUM=[F:PTSDH]SDHNUM
  Gosub SET_IS_WITHHOLDINGTAX From DKSLIB
  If ![L]ISWITHHOLDINGTAX
    For I=0 To 9
      Raz FOOT_RAT, FLG
      If [F:SVF]DTAVATNOT(I) >= 0 : Goto NEXT_TAX   : Endif

      If [F:SVF]AMTCOD = 1 #percentagem
        K = find([F:SVF]DTAVAT(I),ARRAY_FOOTVAT(0..SDL1))
        If K
          ARRAY_FOOTNET(K-1) += abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
        Else
          For K = 0 To SDL1
            If ARRAY_FOOTVAT(K)<>""
              If left$(ARRAY_FOOTVAT(K),len([F:SVF]DTAVAT(I)))=[F:SVF]DTAVAT(I)
                FOOT_RAT = val(seg$(ARRAY_FOOTVAT(K),instr(0,ARRAY_FOOTVAT(K),"~")+1,len(ARRAY_FOOTVAT(K))))
                FOOT_RAT += [F:SVF]DTAAMT
                ARRAY_FOOTVAT(K) = [F:SVF]DTAVAT(I)+"~"+num$(FOOT_RAT)
                ARRAY_FOOTNET(K) += abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
                FLG = 1
                Break
              Endif
            Endif
          Next
          If FLG = 0
            ARRAY_FOOTVAT(SDL1) = [F:SVF]DTAVAT(I)+"~"+num$([F:SVF]DTAAMT)
            ARRAY_FOOTNET(SDL1) = abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
            SDL1+=1
          Endif
        Endif
      Else #montante
        K = find([F:SVF]DTAVAT(I),ARRAY_FOOTVAT(0..SDL1))
        If K
          ARRAY_FOOTNET(K-1) += abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
        Else
          For K = 0 To SDL1
            If ARRAY_FOOTVAT(K)<>""
              If left$(ARRAY_FOOTVAT(K),len([F:SVF]DTAVAT(I)))=[F:SVF]DTAVAT(I)
                ARRAY_FOOTVAT(K) = [F:SVF]DTAVAT(I)
                ARRAY_FOOTNET(K) += abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
                FLG = 1
                Break
              Endif
            Endif
          Next
          If FLG = 0
            ARRAY_FOOTVAT(SDL1) = [F:SVF]DTAVAT(I)
            ARRAY_FOOTNET(SDL1) = abs([F:SVF]DTAVATNOT(I)*[L]MGRATCUR)
            SDL1+=1
          Endif
        Endif
      Endif
     $NEXT_TAX
    Next
  Endif
Next

Return
######################################################################################
######################################################################################
Subprog FOOTER_ELEMENT(VAT,ARRAY_VAT,ARRAY_VATNET,DIMSVV,ARRAY_FOOTVAT,ARRAY_FOOTNET,DIMSVF,SAFPRIRND,MGDQUANTI,MGDNETPRI,MGDSETAMT)
Value Char       VAT, ARRAY_VAT
Value Decimal    ARRAY_VATNET
Value Integer    DIMSVV
Value Char       ARRAY_FOOTVAT
Value Decimal    ARRAY_FOOTNET
Value Integer    DIMSVF
Value Decimal    SAFPRIRND, MGDQUANTI
Variable Decimal MGDNETPRI,MGDSETAMT

If VAT = "" : End : Endif

Local Integer I, MODE
Local Decimal FOOT_AMT, FOOT_RAT, VAT_AMT, LIN_AMT, UN_DISC_AMT

For I = 0 To DIMSVF-1
  If ARRAY_FOOTVAT(I)<>""
    If left$(ARRAY_FOOTVAT(I),len(VAT))=VAT
      If instr(0,ARRAY_FOOTVAT(I),"~")
        MODE     = 1
        FOOT_RAT = val(seg$(ARRAY_FOOTVAT(I),instr(0,ARRAY_FOOTVAT(I),"~")+1,len(ARRAY_FOOTVAT(I))))
      Else
        MODE     = 2
        FOOT_AMT = ARRAY_FOOTNET(I)
      Endif
      Break
    Endif
  Endif
Next

If MODE = 0 : End : Endif

If MODE = 1
  MGDSETAMT += arr(MGDNETPRI-(MGDNETPRI * (100-FOOT_RAT)/100), [L]SAFPRIRND)*MGDQUANTI
  MGDNETPRI *= arr((100-FOOT_RAT)/100, [L]SAFPRIRND)
Else
  #VAT amount
  I = find(VAT,ARRAY_VAT(0..DIMSVV-1))
  If I = 0 : End : Endif
  [L]VAT_AMT = ARRAY_VATNET(I-1)

  #Line amount
  LIN_AMT = abs(arr(([L]MGDNETPRI*[L]MGDQUANTI), [L]SAFPRIRND))

  #Unit discount amount
  If[L]VAT_AMT <> 0 & MGDQUANTI <> 0
    UN_DISC_AMT = arr(((LIN_AMT / [L]VAT_AMT)*[L]FOOT_AMT)/MGDQUANTI, [L]SAFPRIRND)
  Endif

  [L]MGDNETPRI -= UN_DISC_AMT
  [L]MGDSETAMT += UN_DISC_AMT*MGDQUANTI
Endif

End

