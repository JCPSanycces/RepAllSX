#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return

$OUVRE
#Manage Localisations
Call MANAGE_LOCALISATION("ESSHREXSV") From DIVPAYE
Return

$DEBUT

#-------------------------------Hybrid----------------------------------#
Local Char VPARAM1(100)
Local Char VPARAM2(100)
Local Char VPARAM3(100)

VPARAM1 = PARAM(1)
VPARAM2 = PARAM(2)
VPARAM3 = PARAM(3)

If PARAM(6)="ESSWRKEXS"
  Gosub SET_EXSPARAM
  Gosub UPDATE_FROM_EXPESSAWS
Else
  Gosub UPDATE_FROM_EXPENSESESS
Endif

#Setting GCURLEG
[V]GCURLEG = [M:ESEXV]LEG

#Save paramaters for other actions
[M:ESEXV]DEST      = PARAM(4)
[M:ESEXV]CHRONO    = PARAM(5)


#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSHREXSVHIDE
Call SHOW_LEGACTCALLS From WESSHREXSVSHOW

Affzo [M:ESEXV]1-99

Return

$UPDATE_FROM_EXPENSESESS
#Read the data from the class and transfer to the mask (Default Values)
Local Integer MY_STATUS
Local Instance I_EXPENSESESS Using C_EXPENSESESS

If I_EXPENSESESS <> null Then
  FreeGroup I_EXPENSESESS
Endif

I_EXPENSESESS = NewInstance C_EXPENSESESS AllocGroup null
[L]MY_STATUS = fmet I_EXPENSESESS.AREAD(VPARAM1,val(VPARAM3),VPARAM2)

If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

#Update Header
Gosub UPDATE_ESEXV

#Update collections
Gosub UPDATE_ESEXR_COST

#Update collections
Gosub UPDATE_ESEXR_TOTAL


#-------------------------------Hybrid----------------------------------#

Return

$UPDATE_FROM_EXPESSAWS
If clalev([F:EXSH1])    = 0 : Local File EXPENSESHEA     [EXSH1]     : Endif


Filter [F:EXSH1] Where REFNUM = VPARAM1 and EXSNUM = val(VPARAM3) and CTRNUM = VPARAM2
If rowcount([F:EXSH1])=0
  Filter [F:EXSH1]
  Return
Endif


#Read the data from the class and transfer to the mask (Default Values)
Local Integer MY_STATUS
Local Instance I_EXPESSAWS Using C_EXPESSAWS

If I_EXPESSAWS <> null Then
  FreeGroup I_EXPESSAWS
Endif

I_EXPESSAWS = NewInstance C_EXPESSAWS AllocGroup null
[L]MY_STATUS = fmet I_EXPESSAWS.AREAD(VPARAM1,val(VPARAM3),VPARAM2)

If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC_EWS(I_EXPESSAWS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

#Update Header
Gosub UPDATE_ESEXV_EWS

#Update collections
Gosub UPDATE_ESEXR_COST_EWS

#Update collections
Gosub UPDATE_ESEXR_TOTAL_EWS

#-------------------------------Hybrid----------------------------------#

Return


SET_EXSPARAM
If clalev([F:AWS1])    = 0 : Local File AWRKHISSUI     [AWS1]     : Endif
Read [AWS1]AWS0 = PARAM(5);PARAM(4)
If !fstat
  VPARAM1 = [F:AWS1]VALCTX1
  VPARAM2 = [F:AWS1]VALCTX4
  VPARAM3 = [F:AWS1]VALCTX2
Endif
Return

$UPDATE_ESEXV
#Load the data from the class to the screen
SetInstance [M:ESEXV] With I_EXPENSESESS
[M:ESEXV]NAMSRN  = I_EXPENSESESS.TCH_NAMSRN

Return

$UPDATE_ESEXR_COST
Local Integer NI
nolign = 0
If I_EXPENSESESS.HREXPENSES <> null
  For NI = 1 To maxtab(I_EXPENSESESS.HREXPENSES)
    If I_EXPENSESESS.HREXPENSES(NI) <> null and find(I_EXPENSESESS.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      SetInstance [M:ESEXV]20 With  I_EXPENSESESS.HREXPENSES(NI)
      [M:ESEXV]UOMDES(nolign-1)   = I_EXPENSESESS.HREXPENSES(NI).TCH_UOMDES

      [M:ESEXV]LIN(nolign-1) = NI
    Endif
  Next NI
  [M:ESEXV]NBLIG = nolign
Endif
Return

$UPDATE_ESEXR_TOTAL
Local Decimal TOTPAY
Local Decimal RFUPAY
Local Integer I

If I_EXPENSESESS.HREXPENSES <> null
  For NI = 1 To maxtab(I_EXPENSESESS.HREXPENSES)
    If I_EXPENSESESS.HREXPENSES(NI) <> null and find(I_EXPENSESESS.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If I_EXPENSESESS.HREXPENSES(NI).TCH_SNS="+" : I=1 : Else I=-1 : Endif
      TOTPAY+=I_EXPENSESESS.HREXPENSES(NI).PAYSHR
      RFUPAY+=I_EXPENSESESS.HREXPENSES(NI).RFUSHR
    Endif
  Next NI
  [M:ESEXV]TOTPAY = TOTPAY
  [M:ESEXV]TOTRFU = RFUPAY
Endif
Return

$UPDATE_ESEXV_EWS
#Load the data from the class to the screen
SetInstance [M:ESEXV] With I_EXPESSAWS
[M:ESEXV]NAMSRN  = I_EXPESSAWS.TCH_NAMSRN

Return

$UPDATE_ESEXR_COST_EWS
Local Integer NI
nolign = 0
If I_EXPESSAWS.HREXPENSES <> null
  For NI = 1 To maxtab(I_EXPESSAWS.HREXPENSES)
    If I_EXPESSAWS.HREXPENSES(NI) <> null and find(I_EXPESSAWS.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      SetInstance [M:ESEXV]20 With  I_EXPESSAWS.HREXPENSES(NI)
      [M:ESEXV]UOMDES(nolign-1)   = I_EXPESSAWS.HREXPENSES(NI).TCH_UOMDES
      [M:ESEXV]LIN(nolign-1) = NI
    Endif
  Next NI
  [M:ESEXV]NBLIG = nolign
Endif
Return

$UPDATE_ESEXR_TOTAL_EWS
Local Decimal TOTPAY
Local Decimal RFUPAY
Local Integer I

If I_EXPESSAWS.HREXPENSES <> null
  For NI = 1 To maxtab(I_EXPESSAWS.HREXPENSES)
    If I_EXPESSAWS.HREXPENSES(NI) <> null and find(I_EXPESSAWS.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If I_EXPESSAWS.HREXPENSES(NI).TCH_SNS="+" : I=1 : Else I=-1 : Endif
      TOTPAY+=I*I_EXPESSAWS.HREXPENSES(NI).PAYSHR
      RFUPAY+=I*I_EXPESSAWS.HREXPENSES(NI).RFUSHR
    Endif
  Next NI
  [M:ESEXV]TOTPAY = TOTPAY
  [M:ESEXV]TOTRFU = RFUPAY
Endif
Return


Subprog RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
Variable Instance I_EXPENSESESS Using C_EXPENSESESS

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_EXPENSESESS, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_EXPENSESESS) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_EXPENSESESS.ADELETERRORALL()
End

Subprog RECOVERS_ERROR_IN_CLASSIC_EWS(I_EXPESSAWS)
Variable Instance I_EXPESSAWS Using C_EXPESSAWS

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_EXPESSAWS, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#

# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_EXPESSAWS) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_EXPESSAWS.ADELETERRORALL()
End

