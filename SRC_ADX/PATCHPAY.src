# Zones "protégées" pour l'utilisateur
#JASMI - 2017-02-15 - START
# Call LECTEXTRA([F:DCH]DESDCC,"DECCHARGE","DESDCC",GCURLEG,[F:DCH2]CODDCC) From ATEXTRA
#JASMI - 2017-02-15 - END
 [F:DCH]DESEDT    = [F:DCH2]DESEDT
 If dim([F:DCH]UPDDAT)>0 : [F:DCH]UPDDAT = date$ : Endif
 If dim([F:DCH]UPDUSR)>0 : [F:DCH]UPDUSR = GUSER : Endif
 If dim([F:DCH]UPDTIM)>0 : [F:DCH]UPDTIM = time  : Endif
