###################################################
## Intégration des cumuls
###################################################
$CUMUL
FICHIER = "CUMUL" : ABR = "CUM"
Read [CUM]CUM0 = GCURLEG;NOMOBJ
If fstat
 NEWOBJ = 1
Elsif [F:CUM]CODACT<>"" & !find([F:CUM]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(14,115,1)-[F:CUM]CODACT,0) From GESECRAN : # Code activité
 Gosub FIN_OBJ From PATCHP
 Return
Else
 NEWOBJ = 0
 [F:CUM2] = [F:CUM]
Endif
Call DEBTRANS From GLOCK
Gosub TR_CUM
Return

$TR_CUM
Local Char VTITLE(GLONAX3)
Trbegin [CUM]
 Repeat
  Gosub LIRE From PATCHP
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "CUM"   : Gosub CUM1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
Call LECTEXTRA([L]VTITLE,"CUMUL","CUMDES",[F:CUM]LEG,[F:CUM]CUMCOD) From ATEXTRA
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ-[L]VTITLE,0) From GESECRAN : # Validation
Return

$CUM1
Repeat
 Gosub LIRE_ZONE From PATCHP
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCHP
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
 Filter [CUM2] Where LEG=GCURLEG
 Read [CUM2]CUM1 Last
 Filter [CUM2]
 If fstat>2
  [F:CUM]CUMROW = 1
 Else
  [F:CUM]CUMROW = [F:CUM2]CUMROW+1
 Endif
 If dim([F:CUM]CREDAT)>0 : [F:CUM]CREDAT = date$ : Endif
 If dim([F:CUM]CREUSR)>0 : [F:CUM]CREUSR = GUSER : Endif
 If dim([F:CUM]CRETIM)>0 : [F:CUM]CRETIM = time  : Endif
 Write [CUM]
Else
#JASMI - 2017-02-15 - START
# Call LECTEXTRA([F:CUM]CUMDES,"CUMUL","CUMDES",GCURLEG,[F:CUM2]CUMCOD) From ATEXTRA
# Call LECTEXTRA([F:CUM]CUMSHO,"CUMUL","CUMSHO",GCURLEG,[F:CUM2]CUMCOD) From ATEXTRA
#JASMI - 2017-02-15 - END
# Zones "protégées" pour l'utilisateur
 [F:CUM]CUMROW    = [F:CUM2]CUMROW
 [F:CUM]CUMPRN    = [F:CUM2]CUMPRN
 [F:CUM]CODACC    = [F:CUM2]CODACC
 #[F:CUM]CUMNUM    = [F:CUM2]CUMNUM
 [F:CUM]CUMNUMADI = [F:CUM2]CUMNUMADI
 [F:CUM]PRNFLG(0) = [F:CUM2]PRNFLG(0)
 [F:CUM]PRNFLG(1) = [F:CUM2]PRNFLG(1)
 [F:CUM]PRNFLG(2) = [F:CUM2]PRNFLG(2)
 [F:CUM]PRNFLG(3) = [F:CUM2]PRNFLG(3)
 [F:CUM]PRNFLG(4) = [F:CUM2]PRNFLG(4)
 If dim([F:CUM]UPDDAT)>0 : [F:CUM]UPDDAT = date$ : Endif
 If dim([F:CUM]UPDUSR)>0 : [F:CUM]UPDUSR = GUSER : Endif
 If dim([F:CUM]UPDTIM)>0 : [F:CUM]UPDTIM = time  : Endif
 #59176
 [F:CUM]CODGRP    = [F:CUM2]CODGRP
 #70350
 [F:CUM]RAZCUM    = [F:CUM2]RAZCUM
 Rewrite [CUM]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "CUMUL"-NOMOBJ : Return
Endif
Return

###################################################
## Intégration des exonérations
###################################################
$EXO
FICHIER = "EXOPAY" : ABR = "EXO"
Read [EXO]EXO0(2) = GCURLEG;NOMOBJ
If fstat
 NEWOBJ = 1
Elsif [F:EXO]CODACT<>"" & !find([F:EXO]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(14,115,1)-[F:EXO]CODACT,0) From GESECRAN : # Code activité
 Gosub FIN_OBJ From PATCHP
 Return
Else
 NEWOBJ = 0
 [F:EXO2] = [F:EXO]
Endif
Call DEBTRANS From GLOCK
Gosub TR_EXO
Return

$TR_EXO
Trbegin [EXO]
 Repeat
  Gosub LIRE From PATCHP
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "EXO"   : Gosub EXO1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ-[F:EXO]COD,0) From GESECRAN : # Validation
Return

$EXO1
Repeat
 Gosub LIRE_ZONE From PATCHP
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCHP
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
 If dim([F:EXO]CREDAT)>0 : [F:EXO]CREDAT = date$ : Endif
 If dim([F:EXO]CREUSR)>0 : [F:EXO]CREUSR = GUSER : Endif
 If dim([F:EXO]CRETIM)>0 : [F:EXO]CRETIM = time  : Endif
 Write [EXO]
Else
 If [F:EXO]NUMLIG=1
  EXODES    = [F:EXO2]DES
  EXOSHO    = [F:EXO2]SHO
  EXOCODACC = [F:EXO2]CODACC
  Delete [EXO2] Where COD=[F:EXO]COD
 Endif
# Zones "protégées" pour l'utilisateur
 [F:EXO]DES       = EXODES
 [F:EXO]SHO       = EXOSHO
 [F:EXO]CODACC    = EXOCODACC
 Write [EXO]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "EXOPAY"-NOMOBJ : Return
Endif
Return

###################################################
## Intégration du traitement
###################################################
$TRAITEMENT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMOBJ,"src",APPLI)
If filinfo(FICSRC,0)>=0
 FICOLD = filpath("TRT",NOMOBJ,"old",APPLI)
 Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
Endif
Openi FICPATCH , SAVPOS
Openo FICSRC , 0
Rdseq CHAINE
While fstat=0 & CHAINE<>string$(10,"*")
 Wrseq CHAINE
 Rdseq CHAINE
Wend
If fstat
 ER = 33 : Return
Endif
Openo
SAVPOS = adxseek(0)
Openi
Call SYSTEME(adxmac(0),"valtrt"-APPLI-NOMOBJ,"",STAT) From ORDSYS
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Openi FICPATCH , SAVPOS
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif
PROGRAMME = NOMOBJ
Return

###################################################
## Lecture commentaires
###################################################
$COMMENT
NBLIG = val(CHAMP(2))
If NBLIG
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Openo filpath("TRA",GTRACE,"tra",0), -1
 SAVIFS = adxifs
 adxifs = ""
 For I=1 To NBLIG
  Getseq 64,LIG64
  Wrseq LIG64;
 Next I
 Wrseq
 Openo
 adxifs = SAVIFS
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
Rdseq LIG64
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif
Return

