 [F:VRA]PAGFCY    = [F:VRA2]PAGFCY
 [F:VRA]ROWFCY    = [F:VRA2]ROWFCY
 [F:VRA]PAGEMP    = [F:VRA2]PAGEMP
 [F:VRA]ROWEMP    = [F:VRA2]ROWEMP
