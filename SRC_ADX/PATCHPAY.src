###################################################
## Intégration des param TDS
###################################################
$TDS
FICHIER = "HRFILTDS" : ABR = "FTD"
#Read [FTD]FTD0 = NOMOBJ
Read [FTD]FTD0 = val(NOMOBJ)
If fstat
 NEWOBJ = 1
Elsif dim([F:FTD]CODACT)>0 & [F:FTD]CODACT<>"" & !find([F:FTD]CODACT,ACTIV(1..NBACT))
