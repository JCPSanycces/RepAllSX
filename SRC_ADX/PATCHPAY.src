#<AdxTL>@(#)5.0.0.0 $Revision$
###################################################
## Intégration des rubriques
###################################################
$RUBRIQUE
RUBAVT = CHAMP(3)
RUBAPR = CHAMP(4)
FICHIER = "RUBRIQUE" : ABR = "RUB"
Read [RUB]RUB0 = GCURLEG;NOMOBJ
If fstat
 NEWOBJ = 1
Elsif [F:RUB]CODACT<>"" & !find([F:RUB]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(14,115,1)-[F:RUB]CODACT,0) From GESECRAN : # Code activité
 Gosub FIN_OBJ From PATCHP
 Return
Else
 NEWOBJ = 0
 [F:RUB2] = [F:RUB]
Endif
Call DEBTRANS From GLOCK
Gosub TR_RUB
Return

$TR_RUB
Trbegin [RUB]
 Repeat
  Gosub LIRE From PATCHP
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "RUB"   : Gosub RUB1
     When "CRB"   : Gosub RUB2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-num$([F:RUB]ROW)-NOMOBJ-[F:RUB]COD,0) From GESECRAN : # Validation
If MESSA<>""
 Call ECR_TRACE("---"-"("+MESSA+")",0) From GESECRAN
Endif
Return

$RUB1
Repeat
 Gosub LIRE_ZONE From PATCHP
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCHP
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# Le pb du rang
MESSA = ""
If NEWOBJ
 RANG = 0
 If RANG=0 & RUBAPR<>""
  Read [RUB3]RUB0 = GCURLEG;RUBAPR
  If !fstat
   RANG1 = [F:RUB3]ROW
   Filter [RUB3] Where LEG=GCURLEG and ROW>RANG1
   Read [RUB3]RUB1 First
   Filter [RUB3]
   If fstat>2
    RANG2 = 9999
   Else
    RANG2 = [F:RUB3]ROW
   Endif
   If RANG2>RANG1+1
    If RANG2>=RANG1+10
     RANG = RANG1+5
    Else
     RANG = int((RANG1+RANG2)/2)
    Endif
    MESSA = mess(120,10702,1)-RUBAPR : # Insertion après la rubrique
   Endif
  Endif
 Endif
 If RANG=0 & RUBAVT<>""
  Read [RUB3]RUB0 = GCURLEG;RUBAVT
  If !fstat
   RANG1 = [F:RUB3]ROW
   Filter [RUB3] Where LEG=GCURLEG and ROW<RANG1
   Read [RUB3]RUB1 Last
   Filter [RUB3]
   If fstat>2
    RANG2 = 1
   Else
    RANG2 = [F:RUB3]ROW
   Endif
   If RANG2<>RANG1-1
    If RANG2<=RANG1-10
     RANG = RANG1-5
    Else
     RANG = int((RANG1+RANG2)/2)
    Endif
    MESSA = mess(121,10702,1)-RUBAVT : # Insertion avant la rubrique
   Endif
  Endif
 Endif
Else
 RANG = [F:RUB2]ROW
Endif
If RANG=0
 Read [RUB3]RUB1 = [F:RUB]LEG;[F:RUB]ROW
 If fstat : RANG = [F:RUB]ROW : Endif
Endif
If RANG=0
 If RUBAPR<>"" & RUBAVT<>""
  MESSA = RUBAVT-"<=>"-RUBAPR
 Elsif RUBAPR<>""
  MESSA = "=>"-RUBAPR
 Elsif RUBAVT<>""
  MESSA = "<="-RUBAVT
 Else
  MESSA = num$([F:RUB]ROW)
 Endif
 Call ECR_TRACE(mess(119,10702,1)-"("+MESSA+")",1) From GESECRAN : # Insertion rubrique impossible
 ER = 33 : Return
Else
 [F:RUB]ROW = RANG
Endif
If NEWOBJ
 If dim([F:RUB]CREDAT)>0 : [F:RUB]CREDAT = date$ : Endif
 If dim([F:RUB]CREUSR)>0 : [F:RUB]CREUSR = GUSER : Endif
 If dim([F:RUB]CRETIM)>0 : [F:RUB]CRETIM = time  : Endif
 Write [RUB]
Else
# Zones "protégées" pour l'utilisateur
#JASMI - 2017-02-15 - START
# Call LECTEXTRA([F:RUB]DES,"RUBRIQUE","DES",GCURLEG,[F:RUB2]COD) From ATEXTRA
# Call LECTEXTRA([F:RUB]DESSHO,"RUBRIQUE","DESSHO",GCURLEG,[F:RUB2]COD) From ATEXTRA
#JASMI - 2017-02-15 - END
 [F:RUB]CODACC    = [F:RUB2]CODACC
 [F:RUB]LFEBEF    = [F:RUB2]LFEBEF
 [F:RUB]LFEAFT    = [F:RUB2]LFEAFT
 [F:RUB]PRNFLG(0) = [F:RUB2]PRNFLG(0)
 [F:RUB]PRNFLG(1) = [F:RUB2]PRNFLG(1)
 [F:RUB]PRNFLG(2) = [F:RUB2]PRNFLG(2)
 [F:RUB]PRNFLG(3) = [F:RUB2]PRNFLG(3)
 [F:RUB]PRNFLG(4) = [F:RUB2]PRNFLG(4)
 [F:RUB]NBRACC    = [F:RUB2]NBRACC
 #43194
 #For I=0 To dim([F:RUB]SAC)
 For I=0 To dim([F:RUB]SAC)-1
  [F:RUB]SAC(I)    = [F:RUB2]SAC(I)
  [F:RUB]ACC(I)    = [F:RUB2]ACC(I)
  [F:RUB]TYPAMT(I) = [F:RUB2]TYPAMT(I)
  [F:RUB]SNS(I)    = [F:RUB2]SNS(I)
  [F:RUB]DETEMP(I) = [F:RUB2]DETEMP(I)
 Next I
 #[F:RUB]CUMNUM    = [F:RUB2]CUMNUM
 [F:RUB]CUMNUMADI = [F:RUB2]CUMNUMADI
 [F:RUB]DESPRN    = [F:RUB2]DESPRN
 If dim([F:RUB]UPDDAT)>0 : [F:RUB]UPDDAT = date$ : Endif
 If dim([F:RUB]UPDUSR)>0 : [F:RUB]UPDUSR = GUSER : Endif
 If dim([F:RUB]UPDTIM)>0 : [F:RUB]UPDTIM = time  : Endif
 #59176
 [F:RUB]CODGRP    = [F:RUB2]CODGRP
 [F:RUB]TYPMAS    = [F:RUB2]TYPMAS
 #66392
 If dim([F:RUB]FLGRET)>0 : [F:RUB]FLGRET = [F:RUB2]FLGRET : Endif
 Rewrite [RUB]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "RUBRIQUE"-NOMOBJ : Return
Endif
If !NEWOBJ & [F:RUB]ROW<>[F:RUB2]ROW
 For [CRB]CRB0 Where COD=[F:RUB]COD & LEG=[F:RUB]LEG
  [F:CRB]ROW = [F:RUB]ROW
  Rewrite [CRB]
  If fstat
   GOK = 0 : ER = 99 : ERFIC = "CALRUB"-[F:CRB]PRFCOD-[F:CRB]COD-[F:CRB]LEG : Break
  Endif
 Next
Endif
Return

$RUB2
#52239 : On met à jour les profils uniquement si cela a été demandé ou que c'est une nouvelle rubrique...
If MAJPRF<>2 & !NEWOBJ : Return : Endif

Read [PRF]PRF0 = [F:RUB]LEG;CHAMP(2)
If !fstat
 Read [CRB]CRB0 = [F:RUB]COD;CHAMP(2);[F:RUB]LEG
 If fstat
  If CHAMP(3)="" or val(CHAMP(3))<>0
   [F:CRB]COD    = [F:RUB]COD
   [F:CRB]LEG    = [F:RUB]LEG
   [F:CRB]ROW    = [F:RUB]ROW
   [F:CRB]PRFCOD = CHAMP(2)
   Write [CRB]
  Endif
 Elsif CHAMP(3)<>"" & val(CHAMP(3))=0
  Delete [CRB]
 Endif
Endif
Return

$ABORT
Rollback
Return

