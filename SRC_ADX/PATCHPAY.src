 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCHP
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
 If dim([F:FTD]CREDAT)>0 : [F:FTD]CREDAT = date$ : Endif
 If dim([F:FTD]CREUSR)>0 : [F:FTD]CREUSR = GUSER : Endif
 If dim([F:FTD]CRETIM)>0 : [F:FTD]CRETIM = time  : Endif
 Write [FTD]
Else
# Zones "protégées" pour l'utilisateur
 [F:FTD]DESREC    = [F:FTD2]DESREC
 If dim([F:FTD]UPDDAT)>0 : [F:FTD]UPDDAT = date$ : Endif
 If dim([F:FTD]UPDUSR)>0 : [F:FTD]UPDUSR = GUSER : Endif
 If dim([F:FTD]UPDTIM)>0 : [F:FTD]UPDTIM = time  : Endif
 Rewrite [FTD]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "HRFILTDS"-NOMOBJ : Return
Endif
Return

