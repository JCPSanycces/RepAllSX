Return

$TR_FTD
Trbegin [FTD]
 Repeat
  Gosub LIRE From PATCHP
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "FTD"   : Gosub FTD1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ-[F:FTD]DESREC,0) From GESECRAN : # Validation
Return

$FTD1
