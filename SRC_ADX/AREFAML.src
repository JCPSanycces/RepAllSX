#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AREFAML","",2,"") From GTRAITE
End
################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUV_VISUETA
 When "TITRE"       : Gosub TITRE_VISUETA
 When "DEBUT"       : Gosub DEB_VISUETA
 When "FINSAI"      : Gosub FINSAI_VISUETA
 When "AVANT_PAR"     : TIT = mess(211,100,1)
 When "EXEC"          : Call FUNREFAML
Endcase
Return

#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETA
Local Integer    WNUM     : WNUM = val(PARAM(1))

Local Integer    SVGNOL   : SVGNOL=nolign
Local Integer    TEST
Local Char       WFIL(250)
Local Char       WDES (50)

Local File AREFAML   [ZAT] 
Local File ATABLE    [ZATB] 
Local File AMSK      [ZAMK] 
Local File AMSKZON   [ZAMZ] 
 


#----- Variables locales -----#
Local Shortint I,J
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETA
# recherche du libelle du chapitre
If WNUM = 0
    WDES = "????"
Else
    WDES = func APLSTD.TITMEN(nomap,WNUM)
Endif
TIT="Detail for text number : "+num$(WNUM)+" "+WDES

Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETA
Raz [M]

[M]WNUM = WNUM
If WNUM = 0
    WDES = "????"
Else
    WDES = func APLSTD.TITMEN(nomap,WNUM)
Endif
[M]WLIB = WDES

WDES = ""

nolign=1

WFIL='NOLIB=WNUM'

For [ZAT]ARN0 Where evalue(WFIL)

    [M]NOLIB (nolign-1)  = [F:ZAT]NOLIB
    [M]NUM (nolign-1)    = [F:ZAT]NUM
    [M]CODZON (nolign-1) = [F:ZAT]CODZON
    [M]CODMSK (nolign-1) = [F:ZAT]CODMSK
    [M]CLES (nolign-1)   = [F:ZAT]CLES
    [M]MODULE (nolign-1) = [F:ZAT]MODULE
    [M]ICO (nolign-1) = "260"
    # recuperation du titre de l'objet en question
    # si ecran table ou fenetre sinon on laisse blanc
    Gosub AFF_DESOBJ
    nolign += 1
    If nolign = dim([M]NOLIB) 
            Break
    Endif
Next

[M]NBTXT = nolign-1
If [M]NBTXT = 0
  FIN = 1 : GERR = 2 : GMESSAGE ="Aucune aide trouvée" : Return
Endif
Affzo [M]1-99


Return



#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETA
nolign=SVGNOL

Close Local File

Return

###################################################################
# designation de l'objet dans la fenetre
###################################################################
$AFF_DESOBJ

WDES = ""

#-------------------
#  lecture pour recuperation de la designation de l'ecran
WCLE  = [M]CODMSK(nolign-1) 
Read [ZAMK]CODMSK = WCLE
If fstat  = 0
       Call TEXTE([F:ZAMK]INTMSK,WDES) From OBJDIV
       [M]MODULE (nolign-1) = [F:ZAMK]MODULE
Endif
[M]DESOBJ (nolign-1)  = WDES 

WDES = ""
Read [ZAMZ]CODE = WCLE;[M]CODZON(nolign-1)
If fstat = 0
       Call TEXTE([F:ZAMZ]INTIT,WDES) From OBJDIV
Endif
[M]LIBEL (nolign-1)  = WDES 

Return


###########################################################
############################################################
############################################################

# Sous programme de regénération de la table de référence croisées
# pour les menus locaux -- uniquement les ref avec les ecrans 

Subprog FUNREFAML
Local Integer WNUMAREFAML
Local Integer SAVGIMPORT
#
#
If !GSERVEUR
  Call OUVRE_TRACE(mess(211,100,1)) From LECFIC
Endif

#--------------------------------------------------#
# Purge ancien traitement 
# forcage import pour suppression message OUI/NON

SAVGIMPORT = GIMPORT
GIMPORT = 1
Call RAZFIC("AREFAML",1) From VALDIC
GIMPORT = SAVGIMPORT
If GOK <> 1
       Goto FUNREFAML_FIN
Endif


#-----------------------------------------------#
# Ouverture tables
Local File AMSKZON  [ZAMZ] 
Local File AMSK     [ZAMK] 
Local File AREFAML  [ZAT]  

#-----------------------------------------------#
# Recherche 

WNUMREFAML = 0
Filter [ZAMZ] Where CODTYP = "M" or CODTYP = "MM" Order By Key CODE
For [ZAMZ]
    Trbegin [ZAT]
        WNUMAREFAML +=1
        Raz [ZAT]
        [F:ZAT]CODMSK = [F:ZAMZ]CODMSK
        [F:ZAT]CODZON = [F:ZAMZ]CODZON
        [F:ZAT]NOLIB = [F:ZAMZ]NOLIB
        Read [ZAMK]CODMSK=[F:ZAMZ]CODMSK
        If fstat = 0
            [F:ZAT]MODULE = [F:ZAMK]MODULE
        Else
            [F:ZAT]MODULE = 0
        Endif
        [F:ZAT]UPDDAT = date$
        [F:ZAT]NUM    = WNUMAREFAML
        Write [ZAT]

    Commit
Next

Filter [ZAMZ]

GOK = 1
WNUMAREFTXT = 0

#-----------------------#
# Fin de traitement
$FUNREFAML_FIN
#

# fermetures tables
Close Local File [ZAMZ] 
Close Local File [ZAMK] 
Close Local File [ZAT]  


If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

$FIN
End



#############################################################################################
#   etiquettes ecrans
##############################################################################################

Subprog CL_ICO(VALEUR)
Variable Char     VALEUR


Local Char WCLE(50)
Local Integer WIND

Local Integer SAVGCONSULT
SAVGCONSULT = GCONSULT

#---------------------
#  tunnel sur gesamk
If [M]CODMSK(nolign-1)  <> ""
    WCLE  = [M]CODMSK(nolign-1) 
    GBIDC1 = WCLE
    GBIDC2 =""
    Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
Endif
GCONSULT = SAVGCONSULT


End

################################################
