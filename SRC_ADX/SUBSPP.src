#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier SPPRTCONF
########################################################################
# SUBSPP                                           JL - Janvier 2001   #
#                                                                      #
#    GENERATION CATALOGUES TARIFS VENTE                                #
#                                                                      #
#    - Action e_commerce : GOBJET                                      #
#----------------------------------------------------------------------#
# Table mise à jour  : SPPRTCONF [F:SPP] Paramétrage du catalogue      #
#                      SPRICPRTQ [F:SPQ] Catalogues tarifs             #
# Attention : Ce traitement contient                                   #
#   - une action standard de création du catalogue à la validation du  #
#     paramétrage (action exécutée également par le bouton Validation) #
#   - action de copie (ACOPIE)                                         #
########################################################################
# Issue 120532 - 20170303 by LD : Price catalog considers price lists for customers group

Call OBJET("SPP",GBIDC1,GBIDC2) From GOBJET
End
#########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "RAZCRE"       : Gosub RAZCRE
 When "LIENS"        : Gosub LIENS
 When "APRES_CRE"    : Gosub MES_CREMOD    : # controle filtre client + validation (o/n)
                       Gosub GEN_CAT
                       Default File [SPP]
 When "APRES_MOD"    : Gosub MES_CREMOD    : # controle filtre client + validation (o/n)
                       Gosub DEL_CAT
                       Gosub GEN_CAT
                       Default File [SPP]
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INICRE
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"     : Call CHANGE_AXX ("SPPRTCONF", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#########################################################################
############################# ACTIONS ###################################
#########################################################################
$OUVRE

Local Char VALIDATION (1) : VALIDATION="O"
#---
If clalev([M:SOH0])=0 : Local Mask SOH0      [SOH0] : Raz [M:SOH0] : Endif
If clalev([M:SOH1])=0 : Local Mask SOH1      [SOH1] : Raz [M:SOH1] : Endif
If clalev([M:SOH2])=0 : Local Mask SOH2      [SOH2] : Raz [M:SOH2] : Endif
If clalev([M:SOH3])=0 : Local Mask SOH3      [SOH3] : Raz [M:SOH3] : Endif
If clalev([M:SOH4])=0 : Local Mask SOH4      [SOH4] : Raz [M:SOH4] : Endif

Default Mask [SOH4]
Default Mask [SOH3]
Default Mask [SOH2]
Default Mask [SOH1]
Default Mask [SOH0]

#---
If clalev([F:ITU])=0 : Local File ITMBPC    [ITU] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF  [TCO] : Endif

If clalev([F:TVC])=0 : Local File TABVAC    [TVC] : Endif
If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT   [TUN] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
#--- Classe [F] de sauvegarde du dernier enr. cree pour eviter enr. identiques
If clalev([F:SPW])=0 : Local File SPRICPRTQ [SPW] : Endif

#Call GETDEV(GFCYDEF(5)) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
Call GETCPY(GFCYDEF(5),"",0,"") From TRTX3CPT
#---
Gosub SIM_SPC_FILE      From TRTPRICE
Gosub SIM_SPC_GLOB      From TRTPRICE

GPLISTC="néant" : # Pour forcer la récupération de la structure
Gosub ALIPLISTC : # Récupération des données liées à la structure

Return

#########################################################################
# Récupération de la structure tarif de la société                      #
# Garnissage des variables globales nécessaire à la recherche tarif     #
# Lecture de la structure tarif                                         #
#########################################################################
$ALIPLISTC

If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif

# Bug 68837
# Lit la structure, garnit des globales utiles à la recherche tarif
# Fait systématiquement : La liste des tarifs actifs est dépendante de la structure mais aussi de la société
#If [F:CPY]PLISTC<>GPLISTC
    GPLISTC=[F:CPY]PLISTC
    Call TARIFCHGT(5)  From TRTPRICE
    Read [F:PRS]PRS0=1;GPLISTC
    If fstat : Return : Endif
#Endif
# Ini SAM 116189  To fill the global value used for the process for the rounded
  For NBLIN=0 To 8
    GFMTCOL(NBLIN)=[F:PRS]FMTCOL(NBLIN)
  Next
# End SAM 116189
Return

#########################################################################
$RAZCRE

[M:SPP1]CUR=GLOCALDEV
[M:SPP1]DAT=date$
[M:SPP1]SALFCY=GFCYDEF(5)
[M:SPP1]STOFCY=GFCYDEF(7)

#Call GETDEV(GFCYDEF(5)) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
Call GETCPY(GFCYDEF(5),"",0,"") From TRTX3CPT
Gosub ALIPLISTC
[M:SPP1]PLISTC=GPLISTC

[M:SPP1]FLTBPC="find(ABRFIC,'BPC')"
[M:SPP1]FLTBPR="find(ABRFIC,'BPR')"
[M:SPP1]FLTITM="find(ABRFIC,'ITM')"
[M:SPP1]FLTITS="find(ABRFIC,'ITS')"
Affzo [M:SPP1]
Return

#########################################################################
$LIENS

# Bug 68837
GFCY = [M:SPP1]SALFCY
# --> Chargement globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Gosub ALIPLISTC
# Lit la structure, garnit des globales utiles à la recherche tarif
# Fait systématiquement : La liste des tarifs actifs est dépendante de la structure mais aussi de la société
#If [M:SPP1]PLISTC<>GPLISTC
#    GPLISTC=[M:SPP1]PLISTC
#    Call TARIFCHGT(5)  From TRTPRICE
#    Read [F:PRS]PRS0=1;GPLISTC
#    If fstat : Return : Endif
#Endif
# Bug 68837

[M:SPP1]FLTBPC="find(ABRFIC,'BPC')"
[M:SPP1]FLTBPR="find(ABRFIC,'BPR')"
[M:SPP1]FLTITM="find(ABRFIC,'ITM')"
[M:SPP1]FLTITS="find(ABRFIC,'ITS')"

Actzo [M:SPP1]CUR, PRITYP, CHGTYP

If [M:SPP1]FLGCUR=2    : Raz [M:SPP1]CUR  : Grizo [M:SPP1]CUR    : Endif
If [M:SPP1]FLGPRITYP=2 : [M:SPP1]PRITYP=1 : Grizo [M:SPP1]PRITYP : Endif
If [M:SPP1]FLGCHGTYP=2 : [M:SPP1]CHGTYP=1 : Grizo [M:SPP1]CHGTYP : Endif

Return

#########################################################################
$SETBOUT

#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET

#--- désactivation bouton  Validation/ Copie
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#########################################################################
$EXEBOUT

#--- Après appui sur bouton "Validation"
Case BOUT
  When "1" : Gosub MES_VALID   : # controle filtre client + validation (o/n)
             Gosub DEL_CAT
             Gosub GEN_CAT
             Default File [SPP]
  When Default
Endcase
Return

#########################################################################
$INICRE
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:SPP1]DESAXX,"SPPRTCONF","DESAXX",[M:SPP1]COD,"") From ATEXTRA

#    SOS libellés
If dim([F:SPP]LANDESSHO)>0
   [F:SPP]LANDESSHO=GLANGUE+"~"+[M:SPP1]DESAXX
Endif

Return

#########################################################################
$ANNULE

#--- Suppression d'un paramétrage de catalogue = Suppression du catalogue
Delete [F:SPQ] Where COD=[M:SPP1]COD
If fstat=1 : GOK=-1 : GLOCK="$SPRIPRTQ"-[M:SPP1]COD : Endif

Delete [AXX]Where CODFIC="SPPRTCONF" & IDENT1=[F:SPP]COD

Return


#########################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran SPPRT) 12/01/2006 17:30:29 (LD)
######################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Gosub ALIPLISTC
[M:SPP1]PLISTC=GPLISTC

End


########################################
Subprog AM_FLGCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]CUR : Grizo [M]CUR
Else
  Actzo [M]CUR
Endif
Affzo [M]CUR
End

########################################
Subprog AM_FLGPRITYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]PRITYP=1 : Grizo [M]PRITYP
Else
  Actzo [M]PRITYP
Endif
Affzo [M]PRITYP
End

########################################
Subprog AM_FLGCHGTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]CHGTYP=1 : Grizo [M]CHGTYP
Else
  Actzo [M]CHGTYP
Endif
Affzo [M]CHGTYP
End

########################################
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If [M]FLGCUR=1 & VALEUR="" : mkstat=2 : Endif
End

########################################
Subprog AM_BPCSTR(VALEUR)
Variable Char    VALEUR()
If [M:SPP1]BPCEND="" : [M:SPP1]BPCEND=VALEUR : Affzo [M:SPP1]BPCEND : Endif
End

########################################
Subprog AM_ITMSTR(VALEUR)
Variable Char    VALEUR()
If [M:SPP1]ITMEND="" : [M:SPP1]ITMEND=VALEUR : Affzo [M:SPP1]ITMEND : Endif
End


#########################################################################
# Messages pour Validation du catalogue
#########################################################################

#--- Si creation ou modif
$MES_CREMOD
Local Integer OK
OK=2 : VALIDATION="O"
If [M]BPCSTR="" & [M]BPCEND="" & [M]BPCCRI="" & [M]BPRCRI=""
  Call AVERTIR (mess(300,199,1),OK) From GESECRAN
Endif
If OK=2
  Call OUINON (mess(394,196,1),OK) From GESECRAN
Endif
If OK=1  VALIDATION="N"  Else  VALIDATION="O"  Endif
Return

#--- Si uniquement Validation
$MES_VALID
Local Integer OK
OK=2 : VALIDATION="O"
If [M]BPCSTR="" & [M]BPCEND="" & [M]BPCCRI="" & [M]BPRCRI=""
  Call OUINON (mess(300,199,1)+"\"+mess(205,100,1),OK) From GESECRAN
Endif
If OK=1  VALIDATION="N"  Else  VALIDATION="O"  Endif
Return

#########################################################################
# Création du catalogue
#########################################################################

$GEN_CAT
If VALIDATION="N" : Return : Endif
#-- donnees pour appel recherche tarif
Local Integer  MODULE       : MODULE  =5           : # 5=ventes
Local Date     DATREF       : DATREF =[F:SPP]DAT   : # date de validite
Local Integer  TYPRECH      : TYPRECH =1           : # 1=normal
Local Char     ITMREF                              : # nécessaire pour PE RECHTARIF
Local Integer  NLIG                                : # nécessaire pour PE RECHTARIF
Local Decimal  QTY                                 : # nécessaire pour PE RECHTARIF
Local Char     TYPALI       : TYPALI ="SOH"
Local Decimal  GROPRI                              : # nécessaire pour PE RECHTARIF
Local Char     LSAU (GLONUOM)
Local Integer  LCHGTYP
Local Char     LCUR (GLONCUR)
Local Integer  LPRITYP
Local Char     VAT (GLONVAT) (3)
#---- Paramètres complementaires appel recherche tarifs
Local  Char    PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US : # indice 1 = régime de taxe
Local Decimal  MONTANT (0..10)
Local Shortint MOTIF (0..10)
Local Shortint PRIORITE (0..10)
Local Char     PLI (6) (0..10)
Local Char     PLICRD (30) (0..10)
Local Integer  PLILIN (0..10)
Local Char     FOCITMREF (30)
Local Decimal  FOCQTY
Local Char     FOCUOM (GLONUOM)
Local Shortint FOCMOTIF
Local Date     PLISTRDAT
Local Date     PLIENDDAT
Local Libelle  INTERDIT
Local Libelle  ERR
Local Integer  STAT
Local Decimal  LGROPRI

#-- données pour filtres
Local Char    FLTBPCSTR (50)         : # filtre borne inferieure client
Local Char    FLTBPCEND (50)         : # filtre borne superieure client
Local Char    FLTBPCSUP (100)        : # filtre supplementaire   client
Local Char    FLTBPRSUP (100)        : # filtre supplementaire   tiers
Local Char    FLTITMSTR (50)         : # filtre borne inferieure article
Local Char    FLTITMEND (50)         : # filtre borne superieure article
Local Char    FLTITMSUP (100)        : # filtre supplementaire   article
Local Char    FLTITSSUP (100)        : # filtre supplementaire   article/vente

#-- données pour table des qtés à rechercher
Local Integer IJ, IJ0, IJ1, IJ2, IJ3
Local Integer NOL

# Bug 69651 : Dimensionner en fonction du nbre maxi de tarifs actifs
#Local Char    TJ_PLI (12)  (0..100)  : # tarifs actifs utilisant les données client/articles
#Local Char    TJ_CRI (200) (0..100)  : # critères de recherche de des lignes de tarifs
#Local Decimal TJ_QTY       (0..100)
Local Char    TJ_PLI (12)  (0..max(100,GPLINBRMAX)-1)  : # tarifs actifs utilisant les données client/articles
Local Char    TJ_CRI (200) (0..max(100,GPLINBRMAX)-1)  : # critères de recherche de des lignes de tarifs
Local Decimal TJ_QTY       (0..max(100,GPLINBRMAX)-1)

Local Decimal LG_QTY
Local Char    Z_FLD (25)
Local Char    Z_CRI (25)
Local Decimal COEFUNITE
Local Char    LPLICRI (250)
Local Char    LUOM (GLONUOM)

Call TEMPON("V") From GESECRAN

# --- ouverture sous autres abbrev pour boucle for
If clalev ([F:BPRJ])=0 : Local File BPARTNER   [BPRJ] : Endif
If clalev ([F:BPCJ])=0 : Local File BPCUSTOMER [BPCJ] : Endif
If clalev ([F:BPDJ])=0 : Local File BPDLVCUST  [BPDJ] : Endif
If clalev ([F:ITMJ])=0 : Local File ITMMASTER  [ITMJ] : Endif
If clalev ([F:ITSJ])=0 : Local File ITMSALES   [ITSJ] : Endif
If clalev ([F:ITUJ])=0 : Local File ITMBPC     [ITUJ] : Endif
If clalev ([F:ITF])=0  : Local File ITMFACILIT [ITF]  : Endif    : # Bug 72588

# --- creation de la table des tarifs normaux actifs
#     pour chaque tarif generation instruction de filtre pour les critères articles
#     avec les critères articles et clients du parametrage

For [SPC] Hint Key SPC1 Where PLITYP=1 & PLIENAFLG=2 & PLISTC=[M]PLISTC
    Raz Z_CRI, Z_FLD
    For IJ0=0 To dim([F:SPC]ABB)-1
        If find([F:SPC]ABB(IJ0),"ITM","ITS","ITU","BPR","BPC","BPD")
           Z_CRI     ="PLICRI"+num$(IJ0+1)
           Z_FLD     ="[F:"+[F:SPC]ABB(IJ0)+"]"+[F:SPC]FLD(IJ0)+"("+num$([F:SPC]CRIIND(IJ0))+")"
           If evalue("dim("+Z_FLD+") >0")
              TJ_PLI(IJ1)=[F:SPC]PLI
              If len(TJ_CRI(IJ1))>0 : TJ_CRI(IJ1) += " & " : Endif
              TJ_CRI(IJ1) += Z_CRI+"=num$("+Z_FLD+")"
           Endif
        Endif
    Next IJ0
    If TJ_CRI(IJ1)<>"" : IJ1 +=1 : Endif
Next

Read [TCU]TCU0=[F:SPP]CUR

FLTBPCSTR="1=1" : FLTBPCEND="1=1" : FLTBPCSUP="1=1" : FLTBPRSUP="1=1"
FLTITMSTR="1=1" : FLTITMEND="1=1" : FLTITMSUP="1=1" : FLTITSSUP="1=1"

If [F:SPP]BPCSTR<>"" : FLTBPCSTR="BPCNUM>='"+[F:SPP]BPCSTR+"'" : Endif
If [F:SPP]BPCEND<>"" : FLTBPCEND="BPCNUM<='"+[F:SPP]BPCEND+"'" : Endif
If [F:SPP]BPCCRI<>""
  IJ=0
  FLTBPCSUP=[F:SPP]BPCCRI
  Repeat IJ=instr(1,FLTBPCSUP,":BPC")
    If IJ : FLTBPCSUP=left$(FLTBPCSUP,IJ-1)+right$(FLTBPCSUP,IJ+4) : Endif
  Until IJ=0
Endif
If [F:SPP]BPRCRI<>""
  FLTBPRSUP=[F:SPP]BPRCRI
  IJ=0
  Repeat IJ=instr(1,FLTBPRSUP,":BPR")
    If IJ : FLTBPRSUP=left$(FLTBPRSUP,IJ-1)+right$(FLTBPRSUP,IJ+4) Endif
  Until IJ=0
Endif

If [F:SPP]ITMSTR<>"" : FLTITMSTR="ITMREF>='"+[F:SPP]ITMSTR+"'" : Endif
If [F:SPP]ITMEND<>"" : FLTITMEND="ITMREF<='"+[F:SPP]ITMEND+"'" : Endif
If [F:SPP]ITMCRI<>""
  FLTITMSUP=[F:SPP]ITMCRI
  IJ=0
  Repeat IJ=instr(1,FLTITMSUP,":ITM")
    If IJ : FLTITMSUP=left$(FLTITMSUP,IJ-1)+right$(FLTITMSUP,IJ+4) Endif
  Until IJ=0
Endif
If [F:SPP]ITSCRI<>""
  FLTITSSUP=[F:SPP]ITSCRI
  IJ=0
  Repeat IJ=instr(1,FLTITSSUP,":ITS")
    If IJ : FLTITSSUP=left$(FLTITSSUP,IJ-1)+right$(FLTITSSUP,IJ+4) Endif
  Until IJ=0
Endif

#---
Local Integer SAUVGPE : SAUVGPE=GPE : GPE=0
GPOINT="SPPGENSEL" : Gosub ENTREE From EXEFNC
If GPE   GPE=SAUVGPE : Goto GEN_CAT_FIN   Else   GPE=SAUVGPE   Endif
#---

Filter [BPCJ] Where evalue(FLTBPCSTR) & evalue(FLTBPCEND) & evalue (FLTBPCSUP)
For [BPCJ]
  Filter [BPRJ] Where BPRNUM=[F:BPCJ]BPCNUM & evalue(FLTBPRSUP)
  Read [BPRJ]BPR0 First
  If !fstat
    [F:BPC]=[F:BPCJ] : [F:BPR]=[F:BPRJ]
   Filter [ITMJ] Where evalue(FLTITMSTR) & evalue(FLTITMEND) & evalue(FLTITMSUP)
    For [ITMJ]
      Filter [ITSJ] Where ITMREF=[F:ITMJ]ITMREF & evalue(FLTITSSUP)
      Read [ITSJ]ITS0 First
      If !fstat
        [F:ITM]=[F:ITMJ] : [F:ITS]=[F:ITSJ]
#        Raz [F:MVC]
#        Read [F:MVC]MVC0=[F:BPC]BPCNUM;GFINRSP
        Raz [F:ITU]
        Read [F:ITU]ITU0=[F:ITM]ITMREF;[F:BPC]BPCNUM
#---    creation de toutes les lignes du couple client/article
        Gosub TAR_CLIART
      Endif
      Filter [ITSJ]
    Next
    Filter [ITMJ]
  Endif
  Filter [BPRJ]
Next
Filter [BPCJ]

$GEN_CAT_FIN

Raz GFMTCOL()   # SAM 116189
Call TEMPOFF From GESECRAN

Return

#------------------------------------------------------------------------
# recherche de tous les tarifs valables pour le couple client/article
#------------------------------------------------------------------------
$TAR_CLIART

#-- chargement des ecrans SOH0, SOH1, SOH2, SOH3, SOH4
[M:SOH0]=[F:SPP] : [M:SOH1]=[F:SPP] : [M:SOH2]=[F:SPP] : [M:SOH3]=[F:SPP]
[M:SOH0]BPCORD     = [F:BPC]BPCNUM
[M:SOH1]VACBPR     = [F:BPC]VACBPR    : # 91414 (LD-30/07/13)

# Issue 120532
#If [F:BPRJ]BETFCY=2 & GSOCSITE(find([F:SPP]SALFCY,GSITE))<>GSOCSITE(find([F:BPRJ]FCY,GSITE)) : [M:SOH1]BETCPY=2 : Endif #Fq76004
[M:SOH1]BETFCY=[F:BPRJ]BETFCY
[M:SOH1]BETCPY=1
If [F:BPRJ]BETFCY=2 & GSOCSITE(find([F:SPP]SALFCY,GSITE))<>GSOCSITE(find([F:BPRJ]FCY,GSITE)) : [M:SOH1]BETCPY=2 : Endif #Fq76004
# End issue 120532

[M:SOH2]DEMDLVDAT  = [F:SPP]DAT
[M:SOH4]DDEMDLVDAT = [F:SPP]DAT(0)
[M:SOH4]ITMREF(0)  = [F:ITM]ITMREF
[M:SOH4]DSTOFCY(0) = [F:SPP]STOFCY
#[M:SOH4]DBPAADD(0) = [M:SOH1]BPAADD  : # 101390
[M:SOH4]DBPAADD(0) = [F:BPC]BPDADD    : # 101390
[M:SOH4]VACITM1(0) = [F:ITM]VACITM(0)
[M:SOH4]VACITM2(0) = [F:ITM]VACITM(1)
[M:SOH4]VACITM3(0) = [F:ITM]VACITM(2)
#Call ALITAXEV ([F:BPC]VACBPR,[F:ITM]VACITM, [L]VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SOH0]BPCORD,[M:SOH4]ITMREF(0),"SOH4",0,[L]VAT) From TRTX3
[M:SOH4]VAT1(0)=VAT(0) : [M:SOH4]VAT2(0)=VAT(1) : [M:SOH4]VAT3(0)=VAT(2) :

If [F:SPP]FLGCUR=1      LCUR   =[F:SPP]CUR     Else  LCUR   =[F:BPC]CUR     Endif
If [F:SPP]FLGPRITYP=1   LPRITYP=[F:SPP]PRITYP  Else  LPRITYP=[F:BPC]PRITYP  Endif
If [F:SPP]FLGCHGTYP=1   LCHGTYP=[F:SPP]CHGTYP  Else  LCHGTYP=[F:BPC]CHGTYP  Endif

If [F:ITU]SAU<>""       LSAU   =[F:ITU]SAU     Else  LSAU   =[F:ITM]SAU     Endif
Read [TUN]TUN0=LSAU

Case [F:TUN]UOMDEC
     When 0     QTY=1
     When 1     QTY=0.1
     When 2     QTY=0.01
     When 3     QTY=0.001
     When 4     QTY=0.0001
     When 5     QTY=0.00001
     When 6     QTY=0.000001
Endcase

[M:SOH0]CUR        = LCUR       : [M:SOH1]CUR = LCUR
[M:SOH0]CHGTYP     = LCHGTYP
[M:SOH1]PRITYP     = LPRITYP
[M:SOH4]SAU(0)     = LSAU
[M:SOH4]QTY(0)     = QTY

# Bug 72588 : Lecture de l'article-site
Read [ITF]ITF0=[M:SOH4]ITMREF(0);[M:SOH4]DSTOFCY(0)
If fstat Raz [F:ITF] : Endif
# Lecture du client livré
Read [BPD]BPD0=[M:SOH0]BPCORD;[M:SOH4]DBPAADD(0)
If fstat Raz [F:BPD] : Endif

PARAM_T(1)=[F:BPC]VACBPR

NOL=nolign-1 : nolign=1
Call ALIPLK ("SOH") From TRTPRICE

# Issue 120532
# Bug 67022 : Application des tarifs Hors groupe / Groupe
# Dans le cas du catalogue, il faut avoir tous les tarifs Hors groupe et Groupe
#If dim([F:SPK]PLIBPRCNR)>0 [F:SPK]PLIBPRCNR=3 Endif
# End issue 120532

# --- Recherche si interdit

Raz MONTANT, MOTIF, PRIORITE, PLI, PLICRD, PLILIN
Raz FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF
Raz PLISTRDAT, PLIENDDAT, INTERDIT, ERR
Call TARIFRECH(5, 3, "SOH", DATREF, QTY, LSAU, LCHGTYP,
&             LCUR, LPRITYP, VAT, PARAM_T,
&             MONTANT, MOTIF, PRIORITE,
&             PLI, PLICRD, PLILIN,
&             FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF,
&             PLISTRDAT, PLIENDDAT, INTERDIT, ERR) From TRTPRICE
If INTERDIT=1 : Return : Endif

NLIG=0   : ITMREF=[F:ITM]ITMREF

Gosub PE_RECHTARIF From TRTVENTAR
#GPOINT="RECHTARIF" : Gosub ENTREE From EXEFNC

# --- Création de la table des seuils quantités pour le couple client / article

#     il faut au moins un seuil de base correspondant à la qté mini en unité de vente
#     (si absence de tarif ligne catalogue avec prix de base)
Raz TJ_QTY : IJ2=1
Case [F:TUN]UOMDEC
     When 0     TJ_QTY(0)=1
     When 1     TJ_QTY(0)=0.1
     When 2     TJ_QTY(0)=0.01
     When 3     TJ_QTY(0)=0.001
     When 4     TJ_QTY(0)=0.0001
     When 5     TJ_QTY(0)=0.00001
     When 6     TJ_QTY(0)=0.000001
Endcase

#     initialisation du buffer de comparaison (ne pas ecrire les lignes identiques)
Raz [F:SPW]
For IJ0=0 To dim(TJ_PLI)-1
    If TJ_PLI(IJ0)="" : Break : Endif
    Filter [SPL] Where PLI=TJ_PLI(IJ0) & evalue(TJ_CRI(IJ0))
    For [SPL]
       COEFUNITE=1
       If [F:SPL]UOM<>LSAU & [F:SPL]UOM<>""
           Call SREC_COE ([F:ITM]ITMREF,[F:BPC]BPCNUM,[F:SPL]UOM,LSAU,COEFUNITE) From TRTVENQTE
       Endif
       If COEFUNITE=0 : COEFUNITE=1 : Endif

      # gestion borne mini
       LG_QTY=[F:SPL]MINQTY/COEFUNITE
       If LG_QTY=0
          Case [F:TUN]UOMDEC
               When 0     LG_QTY =1
               When 1     LG_QTY =0.1
               When 2     LG_QTY =0.01
               When 3     LG_QTY =0.001
               When 4     LG_QTY =0.0001
               When 5     LG_QTY =0.00001
               When 6     LG_QTY =0.000001
          Endcase
       Endif

       If !find (LG_QTY,TJ_QTY)
          If IJ2<dim(TJ_QTY) : TJ_QTY(IJ2)=LG_QTY : Endif
          IJ2 +=1
       Endif

       # gestion borne maxi --> creer la borne mini suivante
       LG_QTY=[F:SPL]MAXQTY/COEFUNITE
       Case [F:TUN]UOMDEC
            When 0     LG_QTY +=1
            When 1     LG_QTY +=0.1
            When 2     LG_QTY +=0.01
            When 3     LG_QTY +=0.001
            When 4     LG_QTY +=0.0001
            When 5     LG_QTY +=0.00001
            When 6     LG_QTY +=0.000001
       Endcase
       If !find (LG_QTY,TJ_QTY)
          If IJ2<dim(TJ_QTY) : TJ_QTY(IJ2)=LG_QTY : Endif
          IJ2 +=1
       Endif

    Next
    Filter [SPL]

Next IJ0

#-- tri des seuils par quantité
Sorta IJ2 TJ_QTY

#-- suppression du dernier seuil (issu de borne maxi 9999...)
IJ0=find(0,TJ_QTY)
If IJ0>2 : TJ_QTY(IJ0-2)=0 : Endif

#-- creation des enr. catalogue pour le couple client/article
Raz IJ0, IJ1,IJ2

Call DEBTRANS From GLOCK
Trbegin [SPQ]
For IJ0=0 To dim(TJ_QTY)-1
    If TJ_QTY(IJ0)=0 : Break : Endif
    QTY=TJ_QTY(IJ0)

    Raz MONTANT, MOTIF, PRIORITE, PLI, PLICRD, PLILIN
    Raz FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF
    Raz PLISTRDAT, PLIENDDAT, INTERDIT, ERR

    Gosub PE_RECHTARIF From TRTVENTAR      : # GPOINT="RECHTARIF"

    Call TARIFRECH(5, TYPRECH, "SOH", DATREF, QTY, LSAU, LCHGTYP,
&                  LCUR, LPRITYP, VAT, PARAM_T,
&                  MONTANT, MOTIF, PRIORITE,
&                  PLI, PLICRD, PLILIN,
&                  FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF,
&                  PLISTRDAT, PLIENDDAT, INTERDIT, ERR) From TRTPRICE
    #--- si prix brut=0 on prend le prix de base article
    If MONTANT(0) = 0 & MOTIF(0) = 0
       If LSAU <> [F:ITM]SAU
          Call SREC_COE([F:ITM]ITMREF,[F:BPC]BPCNUM,[F:ITM]SAU,LSAU,GBIDD1) From TRTVENQTE
          If GBIDD1 <> 0
             MONTANT(0) = [F:ITS]BASPRI * GBIDD1
          Endif
        Else
          MONTANT(0) = [F:ITS]BASPRI
       Endif

       #--- si catalogue avec prix en TTC, il faut passer le prix de base (HT) en TTC
       If LPRITYP=2
          Call CLCTAXEPRIV(MONTANT(0),VAT,1,GSOCIETE,DATREF,QTY,PARAM_T(1),0,0,MONTANT(0)) From TRTX3
       Endif

       If LCUR <> GSYSCUR & MONTANT(0) <> 0
          Call CONVERT2(GSYSCUR,LCUR,GLOCALDEV,LCHGTYP,DATREF,MONTANT(0),LGROPRI,STAT) From TRTDEV
          MONTANT(0) = LGROPRI
       Endif

       MONTANT(0) = arr(MONTANT(0),10^-GDECPRI)
       MOTIF(0)   = GUPDPRISAL

    Endif

#   --- chargement de la classe [M] pour utilisation du PE RECHTARIF1
    [M:SOH4]GROPRI(0)=MONTANT(0) : [M:SOH4]PRIREN(0)=MOTIF(0)
    For IJ1 = 1 To 9
        If evalue ("dim([M:SOH4]DISCRGVAL"+num$(IJ1)+"(0))") > 0
            Assign "[M:SOH4]DISCRGVAL"+num$(IJ1)+"(0)" With MONTANT(IJ1)
            Assign "[M:SOH4]DISCRGREN"+num$(IJ1)+"(0)" With MOTIF(IJ1)
        Endif
    Next IJ1
    [M:SOH4]REPCOE(0)=MONTANT(10)

    Gosub PE_RECHTARIF1 From TRTVENTAR      : # GPOINT="RECHTARIF1"

    MONTANT(0)=[M:SOH4]GROPRI(0) : MOTIF(0)=[M:SOH4]PRIREN(0)
    For IJ1 = 1 To 9
        If evalue ("dim([M:SOH4]DISCRGVAL"+num$(IJ1)+"(0))") > 0
            MONTANT(IJ1)=evalue("[M:SOH4]DISCRGVAL"+num$(IJ1)+"(0)")
            MOTIF(IJ1)  =evalue("[M:SOH4]DISCRGREN"+num$(IJ1)+"(0)")
        Endif
    Next IJ1
    MONTANT(10)=[M:SOH4]REPCOE(0)
#   ---

    Raz [F:SPQ]
    [F:SPQ]COD       = [F:SPP]COD       : # code catalogue
    [F:SPQ]DAT       = [F:SPP]DAT       : # date validite du catalogue
    [F:SPQ]BPCORD    = [F:BPC]BPCNUM    : # client
    [F:SPQ]ITMREF    = [F:ITM]ITMREF    : # article
    [F:SPQ]SPQLIN    = (IJ0+1)*100      : # ligne
    [F:SPQ]SALFCY    = [F:SPP]SALFCY    : # site de vente
    [F:SPQ]STOFCY    = [F:SPP]STOFCY    : # site expedition
    [F:SPQ]UOM       = LSAU             : # unite vente
    [F:SPQ]CUR       = LCUR             : # Devise
    [F:SPQ]PRITYP    = LPRITYP          : # Type prix (1=HT/2=TTC)
    [F:SPQ]MINQTY    = QTY              : # seuil (correspond a qte min du tarif)
    [F:SPQ]GROPRI    = MONTANT(0)       : # prix brut

    #--- frais/remises 1 a 9
    For IJ1=0 To 8
        If dim(MONTANT(IJ1+1))>0 : [F:SPQ]DCGVAL(IJ1)=MONTANT(IJ1+1) : Endif
    Next IJ1

    #--- prix net
#    Call CALNET(1,"",[F:SPQ]GROPRI,[F:SPQ]DCGVAL,[F:SPQ]MINQTY,[F:SPQ]NETPRI,[F:SPQ]CUR) From TRTPRICE
    If dim(GCALNETABR)>0 : GCALNETABR="[F:SPQ]"   : Endif
    Call CALNET(1,[M]PLISTC, [F:SPQ]GROPRI,[F:SPQ]DCGVAL,[F:SPQ]MINQTY,[F:SPQ]NETPRI,[F:SPQ]CUR) From TRTPRICE

#    [F:SPQ]NETPRI    = arr([F:SPQ]NETPRI,[F:TCU]CURRND)  : # bug 29236

    #--- si le seuil=qté mini de l'unité --> mettre 0 pour les impressions
    Case [F:TUN]UOMDEC
         When 0     If [F:SPQ]MINQTY=1        [F:SPQ]MINQTY=0  Endif
         When 1     If [F:SPQ]MINQTY=0.1      [F:SPQ]MINQTY=0  Endif
         When 2     If [F:SPQ]MINQTY=0.01     [F:SPQ]MINQTY=0  Endif
         When 3     If [F:SPQ]MINQTY=0.001    [F:SPQ]MINQTY=0  Endif
         When 4     If [F:SPQ]MINQTY=0.0001   [F:SPQ]MINQTY=0  Endif
         When 5     If [F:SPQ]MINQTY=0.00001  [F:SPQ]MINQTY=0  Endif
         When 6     If [F:SPQ]MINQTY=0.000001 [F:SPQ]MINQTY=0  Endif
    Endcase

    [F:SPQ]LTI       = 0                 : # donnée achats
    [F:SPQ]FOCITMREF = FOCITMREF         : # article gratuit
    [F:SPQ]FOCQTY    = FOCQTY            : # qte gratuite
    [F:SPQ]FOCUOM    = FOCUOM            : # unite vente article gratuit
    [F:SPQ]COMCOE    = MONTANT(10)

    #--- Tarifs utilises
    #    0 pour prix / 1 a 9 pour remises / 10 pour com.rep
    For IJ1=0 To 10
        If dim(PLI(IJ1))>0 : [F:SPQ]PLI(IJ1)=PLI(IJ1) : Endif
    Next IJ1
    For IJ1=0 To 10
        If dim(PLICRD(IJ1))>0 : [F:SPQ]PLICRD(IJ1)=PLICRD(IJ1) : Endif
    Next IJ1
    For IJ1=0 To 10
        If dim(PLILIN(IJ1))>0 : [F:SPQ]PLILIN(IJ1)=PLILIN(IJ1) : Endif
    Next IJ1

    #--- Motifs
    #    0  prix / 1 a 9 remises / 10 com.rep / 11 article gratuit
    For IJ1=0 To 10
        If dim(MOTIF(IJ1))>0 : [F:SPQ]PLIREN(IJ1)=MOTIF(IJ1) : Endif
    Next IJ1
    [F:SPQ]PLIREN(11)= FOCMOTIF

    [F:SPQ]CREUSR    = GUSER
    [F:SPQ]CREDAT    = date$

    #--- Ecrire uniquement les enregistrements significatifs
    #    et si les valeurs sont differentes du seuil précédent
    If sum([F:SPQ]GROPRI, [F:SPQ]DCGVAL, [F:SPQ]NETPRI, [F:SPQ]LTI, [F:SPQ]FOCQTY)
       IJ1=0
       If [F:SPQ]GROPRI<>[F:SPW]GROPRI : IJ1=1 : Endif
       For IJ2=0 To dim([F:SPQ]DCGVAL)-1
           If [F:SPQ]DCGVAL(IJ2)<>[F:SPW]DCGVAL(IJ2) : IJ1=1 : Break : Endif
       Next IJ2
       If [F:SPQ]LTI<>[F:SPW]LTI       : IJ1=1 : Endif
       If [F:SPQ]FOCQTY<>[F:SPW]FOCQTY : IJ1=1 : Endif

       GPOINT="SPPGENWRT" : Gosub ENTREE From EXEFNC

       If IJ1
          Write [SPQ]
          If fstat
             GOK=0 : Call FSTA ("SPQ") From GLOCK : Break
          Endif
          [F:SPW]=[F:SPQ]
       Endif
   Endif

Next IJ0
If GOK=0  Rollback  Else  Commit  Endif
Return

#------------------------------------------------------------------------


#########################################################################
# Création du catalogue
#########################################################################
$DEL_CAT
If VALIDATION="N" : Return : Endif
Call DEBTRANS From GLOCK
Trbegin [SPQ]
Delete [F:SPQ] Where COD=[M:SPP1]COD
If fstat=1 : GOK=-1 : GLOCK="$SPRIPRTQ"-[M:SPP1]COD : Rollback : Return : Endif
Commit
Return

######################################################################
# Traitement de la copie un paramétrage tarif
# TABLE = Clé de l'enregistrement à copier
#         (si la cle est numerique val(TABLE)
######################################################################
$TRTCOP
If [M]DOSORG=nomap
  Local File SPPRTCONF [SPP1]
Else
  Local File =[M]DOSORG+".SPPRTCONF" [SPP1]
Endif
If [M]DOSDES=nomap
  Local File SPPRTCONF [SPP2]
Else
  Local File =[M]DOSDES+".SPPRTCONF" [SPP2]
Endif
Look [SPP2] SPP0=TABLE
If !fstat
   OK= 1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK=1 : Return : Endif
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Return

#---------------------------------------------------------------------
$TR_COP

GOK=1
Trbegin [SPP2]
  Delete [SPP2] Where COD=TABLE
  If fstat=1  GOK=-1 : GLOCK="$"+[M]DOSDES+".SPPRTCONF"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("SPP2",TABLE) From GLOCK          : Goto AB_TR_COP
  Endif
  Read [SPP1] SPP0=TABLE
  If !fstat
    [F:SPP2]=[F:SPP1]

    Call COPTEXTRA("SPPRTCONF","DESAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif

    Write [SPP2]
    If fstat GOK=0 : Call FSTA("SPP2") From GLOCK : Goto AB_TR_COP : Endif
  Endif
Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SPPRT) 03/05/2006 13:49:58 (JL)
######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
# --- contrôle si site d'expédition ( de stockage )
Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
If mkstat End : Endif
# --- le site doit être sur la même société juridique que site de vente
If [F:FCY]LEGCPY<>GSOCIETE   GMESSAGE=mess(2,194,1)  : mkstat=1 : End : Endif
End

######################################################################################

