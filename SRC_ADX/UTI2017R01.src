##########################################################################
# UTI2017R01 UTI process for 2017R1 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017r1 
#
#      correction utility to be done at the end of the patch
#   
##########################################################################
Infbox "only update folder by patch"
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R01 (APPLI)  

End

###################################################
Subprog EXE_UTI2017R01(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R01-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti.. 
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx.. 
#-------------------------------------------------------------#

#  Call PATCH  (LDOSSIER) From UTIXXX


Call ECR_TRACE("END : UTI2017R01-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R01
End










