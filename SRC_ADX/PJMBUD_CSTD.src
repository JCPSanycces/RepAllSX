#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUD
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PJMBUD_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PJMBUD_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PJMBUD_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PJMBUD_CSTD_EVENTS
      Endcase
    When "BUDLIG"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub BUDLIG_ACONTROL                 From PJMBUD_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub BUDLIG_ADDLINE_BEFORE           From PJMBUD_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub BUDLIG_ADDLINE_AFTER            From PJMBUD_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub BUDLIG_ADELLINE_BEFORE          From PJMBUD_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub BUDLIG_AUPDATE_CONTROL_BEFORE   From PJMBUD_CSTD_EVENTS       # Issue X3-59687 - 2017-10-13 by FGR
      Endcase
    When "PIMPL"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub PIMPL_ACONTROL                  From PJMBUD_CSTD_EVENTS
      Endcase
    When "SPLD"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub SPLD_ACONTROL                   From PJMBUD_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub SPLD_ADDLINE_BEFORE             From PJMBUD_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub SPLD_ADDLINE_AFTER              From PJMBUD_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub SPLD_ADELLINE_BEFORE            From PJMBUD_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PJMBUD_CSTD_METHODS  # Issue X3-51863 - 2017-08-07 by FGR
    #
    When "BUDLIG_INIT_TECH_PROP"       : Gosub BUDLIG_INIT_TECH_PROP           From PJMBUD_CSTD_METHODS
    When "BUDLIG_COUNT"                : Gosub BUDLIG_COUNT                    From PJMBUD_CSTD_METHODS
    When "BUDLIG_DEL_ALL_LINES"        : Gosub BUDLIG_DEL_ALL_LINES            From PJMBUD_CSTD_METHODS
    When "BUDLIG_COMPUTE_MNTBUD"       : Gosub BUDLIG_COMPUTE_MNTBUD           From PJMBUD_CSTD_METHODS
    When "BUDLIG_COMPUTE_QTYBUD"       : Gosub BUDLIG_COMPUTE_QTYBUD           From PJMBUD_CSTD_METHODS
    When "BUDLIG_COMPUTE_MNTREMBUD"    : Gosub BUDLIG_COMPUTE_MNTREMBUD        From PJMBUD_CSTD_METHODS
    When "BUDLIG_GET_INDEX"            : Gosub BUDLIG_GET_INDEX                From PJMBUD_CSTD_METHODS
    When "BUDLIG_GET_INDEX_FROM_PCCCOD": Gosub BUDLIG_GET_INDEX_FROM_PCCCOD    From PJMBUD_CSTD_METHODS
    #
    When "SPLD_INIT_TECH_PROP"         : Gosub SPLD_INIT_TECH_PROP             From PJMBUD_CSTD_METHODS
    When "SPLD_DEL_ALL_LINES"          : Gosub SPLD_DEL_ALL_LINES              From PJMBUD_CSTD_METHODS
    When "SPLD_GET_INDEX"              : Gosub SPLD_GET_INDEX                  From PJMBUD_CSTD_METHODS
    When "SPLD_EXISTING"               : Gosub SPLD_EXISTING                   From PJMBUD_CSTD_METHODS
    #
    When "COPY"                        : Gosub COPY                            From PJMBUD_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"        : Gosub COPY_LOAD_PROPERTIES            From PJMBUD_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "PBUCOD"                      : Gosub PBUCOD                          From PJMBUD_CSTD_PROPERTIES # Issue X3-52534 - 2017-08-17 by FGR
    When "PBUFCY"                      : Gosub PBUFCY                          From PJMBUD_CSTD_PROPERTIES
    When "PBUSTATE"                    : Gosub PBUSTATE                        From PJMBUD_CSTD_PROPERTIES
    When "PBUELE"                      : Gosub PBUELE                          From PJMBUD_CSTD_PROPERTIES
    When "PBUIMP"                      : Gosub PBUIMP                          From PJMBUD_CSTD_PROPERTIES
    When "PBUDATS"                     : Gosub PBUDATS                         From PJMBUD_CSTD_PROPERTIES
    When "PBUDATH"                     : Gosub PBUDATH                         From PJMBUD_CSTD_PROPERTIES
    When "KEYCONCAT"                   : Gosub KEYCONCAT                       From PJMBUD_CSTD_PROPERTIES # Issue X3-29531 - 2017-04-21 by FGR
    When "ORIPBU"                      : Gosub ORIPBU                          From PJMBUD_CSTD_PROPERTIES # Issue X3-43754 - 2017-07-03 by EUHAV
  Endcase
Return

