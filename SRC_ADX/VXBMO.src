#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: VXBMO
# Description : ADC Miscellaneous Issues
# Author      : TS
# Date        : March, 2008
####################################################################################

########################################################
# Miscellaneous Issue
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, ITMREF, QTYSTU, STU, QTYPCU, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# WSTOSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No
#
#
########################################################

########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Gosub OUVRE_SMO From ENVADC

Local Mask STOCOUW [STCW]

Return

########################################################
$DEBUT

Local Integer WOK, WRET, WCPT
Local Integer WORISVG
Local Char    WNIVERR(10)

# GFLAG contains the miscellaneous receipt transaction
GFLAG = func ENVADC.SETTRANS(2)

[M:XBMO]SRTNUM = GFLAG

Gosub DEBUT_SMO From ENVADC

Gosub INIT_SCREEN

# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 1 : Return
Endif

Return

########################################################
$SETBOUT

If !find("1",CHMEN) CHMEN+="1" Endif

Return

########################################################
$OK
# Pour interdire la navigation
GREP="C"
FIN = 0

# Alimentation  STOSORW
Call CHGSOW_SMO("XBMO",[M:XBMO]QTYSTU,WRET) From STKADC
If WRET<>0 GERR=1 Endif

WORISVG = [M:XBMO]ORI

[L]WCPT = [M:XBMO]WCPT
Effzo [M:XBMO]1-99
[M:XBMO]WCPT   = [L]WCPT+1
[M:XBMO]STOFCY = [M:SMO0]STOFCY
[M:XBMO]SRTNUM = GFLAG
[M:XBMO]ORI = WORISVG
Affzo [M:XBMO]1-99

zonsui = "[M:XBMO]ITMREF"

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA

If [M:SMO1]NBLIG > 0
    Call DELSTOSORW(-1,-1,"SMO1",[M:SMO0]STOFCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif

Gosub INIT_SCREEN
GREP = ""
zonsui = "[M:XBMO]ITMREF"

Return

########################################################
$CRE


If [M:STCW]NBLIG<>0
   # Alimentation  STOSORW
   Call CHGSOW_SMO("XBMO",[M:XBMO]QTYSTU,WRET) From STKADC
   If WRET<>0 Return Endif
Endif

If [M:SMO1]NBLIG=0
   Call ERREUR(mess(17,7750,1)) From GESECRAN
   zonsui="[M:XBMO]ITMREF" : Return
Endif

# Création
Call CRE_SMO From ENVADC

GPROGRAMME = "GSAISIE"
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From= WINPROG
GREP="" : REP=""
GNOLIG = 0

Gosub INIT_SCREEN

GREP = ""
zonsui = "[M:XBMO]ITMREF"

Return

########################################################
$CHECK

If [M:SMO1]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XBMO]ITMREF" : Return
   Endif
Endif

Return

########################################################
$FIN

Gosub FIN_SMO From ENVADC

Raz [M:STCW]

GVTMOD=0

Return

########################################################
$INIT_SCREEN

Default Mask [SMO0]

Raz [M:SMO0]
Raz [M:SMO1]

# set post date and site
[M:SMO0]IPTDAT = date$
[M:SMO0]STOFCY = GXAFCY

WORISVG = [M:XBMO]ORI

Raz [M:XBMO]
Raz [M:STCW]

Gosub RAZCRE   From SUBSMOA

#--- Bug 67961
# Chargement du paramétrage lié au site
If GFCY<>[M:SMO0]STOFCY
   GFCY=[M:SMO0]STOFCY
   Gosub CHARG_PARAM From SUBSMOA
Endif
#---

[M:XBMO]STOFCY = [M:SMO0]STOFCY
[M:XBMO]SRTNUM = GFLAG
[M:XBMO]ORI    = WORISVG

Affzo [M:XBMO]1-99
nolign=0

MA=1
Gosub SETMASK From=WINPROG
Default Mask [M:XBMO]

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran VXBMO) 12/03/2008 17:07:27 (TS)
######################################################################################

Subprog AM_SRTNUM(VALEUR)
Variable Char    VALEUR()
GFLAG   = VALEUR
#--- Bug 90080
GSMONUM = VALEUR
[M:SMO0]TRSCOD = [F:SRT]TRSCOD
[M:SMO0]TRSFAM = [F:SRT]TRSFAMDEF
[M:SMO0]ENTCOD = [F:SRT]ENTCOD
End

Subprog AS_ORI(VALEUR)
Variable Integer VALEUR
If dim([M]LOT)   <0 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1 : Endif
If dim([M]SLO)   <0 : GMENLOC(1)=1 : GMENLOC(3)=1 : Endif
If dim([M]SERNUM)<0 : GMENLOC(5)=1 : GMENLOC(6)=1 : Endif
If dim([M]LOC)   <0 : GMENLOC(7)=1 : GMENLOC(8)=1 : Endif
If dim([M]PALNUM)<0 : GMENLOC(9)=1 : GMENLOC(10)=1 : Endif
End

Subprog C_ORI(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When  1 : If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Actzo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  2 : If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Actzo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  3 : Grizo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Grizo [M]ECCVALMAJ Endif    : # TS 106217
          If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  4 : Grizo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Grizo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  5 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Actzo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  6 : Grizo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Grizo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  7 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Actzo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  8 : Grizo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Grizo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  9 : Actzo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Actzo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
 When 10 : Grizo [M]ITMREF
           If dim([M]ECCVALMAJ)>0 Grizo [M]ECCVALMAJ Endif    : # TS 106217
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
Endcase
End

Subprog AM_ORI(VALEUR)
Variable Integer VALEUR
Raz [M]ITMREF
If dim([M]LOT)   >0 Raz [M]LOT    Endif
If dim([M]SLO)   >0 Raz [M]SLO    Endif
If dim([M]SERNUM)>0 Raz [M]SERNUM Endif
If dim([M]LOC)   >0 Raz [M]LOC    Endif
If dim([M]PALNUM)>0 Raz [M]PALNUM Endif
#--- TS 106217
If dim([M]ECCVALMAJ)>0 Raz [M]ECCVALMAJ Endif
End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,5,7) & VALEUR="" mkstat=2 Endif
End

#--- TS 106217
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET
Call CTLECCVAL(VALEUR,[M:XBMO]STOFCY,[M:XBMO]ITMREF,
&             [M:SMO0]TRSTYP,[M:SMO0]TRSCOD,[M:SMO0]IPTDAT,LRET) From STKSOR
If LRET>0 mkstat=2 Endif
End
#---

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,7,8) & VALEUR=""     mkstat=2 Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,3,4) & VALEUR="" mkstat=2 Endif
End

Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,3) & VALEUR=""     mkstat=2 Endif
End

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,5,6) & VALEUR=""     mkstat=2 Endif
End

Subprog C_PALNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI=9,10) & VALEUR=""    mkstat=2 Endif
End

Subprog AS_QTYSTU(VALEUR)
Variable Decimal VALEUR()
Local    Decimal WQTY, WQTA
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER)
Local    Char    WSERF(GLONSER)   # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
#--- Issue 103217
Local    Char    WPCU(GLONUOM)
Local    Decimal WPCUSTUCOE
#---
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]SERNUMF)>0 WSERF=[M]SERNUMF Endif   # Issue 110327
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
# Issue 110327 - 2016-10-13 by MAE : pas d'appel au RECSTO si SERMGTCOD = 4
If [F:ITM]SERMGTCOD <> 4 | ([M]ORI <> 5 & [M]ORI <> 6)
  #--- Issue 103217 : ajout WPCU et WPCUSTUCOE
  Call RECSTO(1,[F:SRT]TRSCOD,[M]ORI,[M]STOFCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
  VALEUR = WQTY
  If WQTY=0
    Call ERREUR(mess(314,184,1)) From GESECRAN
    zonsui = "[M:XBMO]ITMREF"
    End
  Endif
Endif

If [M]ITMREF<>"" Affzo [M]ITMREF Endif
If dim([M]LOT)>0
   [M]LOT=WLOT : Affzo [M]LOT
   If dim([M]SLO)>0
      [M]SLO=WSLO : Affzo [M]SLO
   Endif
Endif
If dim([M]SER)>0
   [M]SER=WSER : Affzo [M]SER
Endif
If dim([M]LOC)>0
   [M]LOC=WLOC : Affzo [M]LOC
Endif

End

Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
# Issue 110327
Local    Decimal WQTY, WQTA
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER)
Local    Char    WSERF(GLONSER)   # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
Local    Char    WPCU(GLONUOM)
Local    Decimal WPCUSTUCOE
Local    Decimal LQTYF
# End issue 110327
If VALEUR=0 mkstat=2 Endif
# Issue 110327
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]SERNUMF)>0 WSERF=[M]SERNUMF Endif   # Issue 110327
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
# Issue 110327 - 2016-10-13 by MAE : gestion de SERMGTCOD= 4
If [F:ITM]SERMGTCOD = 4 &  ([M]ORI = 5 | [M]ORI = 6)
    [M:ALP]TRSTYP     = [M:SMO0]TRSTYP
    [M:ALP]TRSCOD     = [M:SMO0]TRSCOD
    [M:ALP]STOFCY     = [M]STOFCY
    [M:ALP]ITMREF     = [F:ITM]ITMREF
    [M:ALP]BESDAT     = [M:SMO0]IPTDAT
    [M:ALP]DLVDAT     = [M:SMO0]IPTDAT
    [M:ALP]PECINTLOC  = 2
    [M:ALP]PECSCOLOC  = 1
    [M:ALP]PECPLFLOC  = 2
    [M:ALP]STA        = "*"
    # Détermination no série fin
    Call CTLSORSER("SMO",0,[M]SERNUM,VALEUR,WSERF,LQTYF) From STKSOR
    If LQTYF=0
      Raz VALEUR, [M]SERNUMF
    Else
      [M]SERNUMF=WSERF
    Endif
    WQTY = VALEUR
    Call RECSTO(1,[F:SRT]TRSCOD,[M]ORI,[M]STOFCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
    If WQTY=0
      Call ERREUR(mess(314,184,1)) From GESECRAN
      zonsui = "[M:XBMO]ITMREF"
      End
     Else
      If dim([M]LOT)   >0  [M]LOT = WLOT  : Affzo [M]LOT  Endif
      If dim([M]SLO)   >0  [M]SLO = WSLO  : Affzo [M]SLO   Endif
      If dim([M]LOC)   >0  [M]LOC = WLOC   : Affzo [M]LOC Endif
      If dim([M]PALNUM)>0  [M]PALNUM = WPAL : Affzo [M]PALNUM Endif
    Endif
Else
  If VALEUR>[M]QTYSTU
   mkstat=2 : Call ERREUR(mess(446,196,1)) From GESECRAN
  Endif
Endif
End

######################################################################################
# Issue 110327
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXBMO) 07/03/2017 13:33:07 (MAE)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer LAFF
LAFF=1
Call LECFICSOR(VALEUR,[M:SMO0]STOFCY,[M:SMO0]TRSTYP,[M:SMO0]TRSCOD,LAFF) From STKECR
If mkstat End Endif
If [F:ITM]SERMGTCOD>1 & !find([M]ORI,5,6)
  Call ERREUR(mess(89,182,1)) From GESECRAN
  mkstat = 2
Endif
End

Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
If [F:ITM]SERMGTCOD = 0
   Filter [STS] Where SERNUM = VALEUR and STOFCY = [M]STOFCY
   Read [STS]First
   If fstat
      Call ERREUR(mess(43,196,1)) From GESECRAN
      mkstat=2 : End
   Endif
   LAFF=1
   Call LECFICSOR([F:STS]ITMREF,[M:SMO0]STOFCY,[M:SMO0]TRSTYP,[M:SMO0]TRSCOD,LAFF) From STKECR
   If mkstat End Endif
   Filter [STS]
Endif
End
######################################################################################
# End issue 110327

