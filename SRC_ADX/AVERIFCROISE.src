#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################
#  Traitement de vûˋrification des refs croisûˋes :
#  
#  recherche si un traitement est utilisûˋ par d'autres traitements
#  et en sort la liste
#
#-----------------------------------------------------------------------------------------------------------#
 
Subprog AVERIFCROISE(CHEMINTRA, PATCH, SRCPATCH, NOMTRT, DOSSIER, PMODULE, OWNER, EXCLSUP,
&       PORT, MACHINE, CHEMINTRAW, PDEMANDEUR, PBLISTETRT, PLIBVERIF)

Value Char CHEMINTRA    :  # Chemin oû¿ seront crûˋûˋs les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vûˋrifie que les traitement modifiûˋs
Value Char SRCPATCH     :  # Si patch, chemin oû¿ sont les traitements patchûˋs
Value Char NOMTRT       :  # Nom du source û  analyser (jokers autorisûˋs)
Value Char DOSSIER      :  # Si non patch, dossier analysûˋ

Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Value Integer PDEMANDEUR : # niveau indus, dev, distri, spe...
Variable Integer PBLISTETRT
Variable Char PLIBVERIF


Local Char NOMPROG(20), NOMCALL(20)
Local Char TXTERR(200)
Local Integer NBCROISE

Local Char DOSSIER2(100)

Local Integer IP, IQ, IQ2PTS, WIGNWRSEQ, WIGNWRTRT, NSK, NSKLEC, IS

Local Integer NBTRAITES, NLIG

Local Shortint SAUVEMODULE

Local Integer BCHAINELEC, FST, WMIGRATE
Local Char WFILE(10), WABREV(5), ZADXIFS, ZADXIRS

Local Clbfile CHAINE(3), CHAINE1(3), CHAINELEC(3), CHAININS(3), CHAINECPT(3)

Local Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
Local Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
Local Char SPACEN(37) : SPACEN=space$(len(ALPHAN))

# ----------------------------------------------------------------------------------------------------------

    ZADXIFS=adxifs
    ZADXIRS=adxirs
    adxifs=chr$(0):adxirs=chr$(10)

    Call TEMPON("VERIFCROISE Initialisation du traitement...") From GESECRAN
    SAUVEMODULE = -1
    
    If MACHINE = ""
        DOSSIER2 = DOSSIER
    Else
        DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
    Endif
    
    
    If clalev ([F:ADC])
        Close File [ADC]
    Endif
    If clalev ([F:AST])
        Close File [AST]
    Endif
    
    Local File = DOSSIER2 + ".ADICTRT"   [ADC] : # table des traitements 
    Local File = DOSSIER2 + ".APLSTD"    [AST]

    
    Openo CHEMINTRA, -1
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------###" - PLIBVERIF - "###-----------------------------------------"
    Wrseq
    Wrseq

    Openo
    Openo CHEMINTRA, -1  Using [FER]

#--------------------------------#
# Tableau des traitements adx
#--------------------------------#

    If NOMTRT = ""
        End
    Endif
    
    If PBLISTETRT = 0
        Call LISTETRT(PDEMANDEUR, PORT, MACHINE, DOSSIER) From AVERIFSRC
        PBLISTETRT = 1
    Endif


    Wrseq "Traitement" - NOMTRT - "ûˋtudiûˋ" Using [FER]
    Wrseq "" Using [FER]
    Wrseq "" Using [FER]


    For NF=1 To GNBTRTADX
        If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
          Gosub ANALYSE
        Endif
    Next NF

    adxifs=ZADXIFS
    adxirs=ZADXIRS
    
    Wrseq Using [FER]
    Wrseq Using [FER]

    Wrseq "le traitement" - NOMTRT - "est appelûˋ par" - num$(NBCROISE) - "traitements (sur" - num$(GNBTRTADX) + ")" Using [FER]
    Wrseq Using [FER]
    Wrseq "Fin de " - PLIBVERIF + "." - time$ Using [FER]
    Wrseq Using [FER]

    Openo  Using [FER]

    Call TEMPOFF From GESECRAN

    Close File [ADC]
    Close File [AST]

    Goto FINCALL
#------------------------------------------------------------------------------------------------------------------------#


$ANALYSE

    If mod(NF,100) = 0
        Call TEMPON("VERIFCROISE :" - num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&        "nb :" - num$(NBCROISE)) From GESECRAN
    Endif    

    If func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), "", DOSSIER2, PMODULE, EXCLSUP, PATCH, SRCPATCH,
&           OWNER, TXTERR, PDEMANDEUR)
        Return
    Endif

    NBTRAITES += 1
    
    If PATCH <>"" and filinfo(SRCPATCH+"/"+GTTRAITEMENTS(NF)+".src",0) > 0
       Openi SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0
    Else
       Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    Endif
    
    Raz WIGNWRSEQ, WIGNWRTRT
    FST=0
    NLIG = -1
    CHAINELEC = ""
    BCHAINELEC = 0
    
    
    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC

        Call VIRECOMCHK (CHAINE, 0, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            Return
        Endif

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)

        While CHAINE <> ""

            CHAINECPT = CHAINE
            If pat(CHAINE, "*Call*")
                Gosub ANACALL
            Elsif pat(CHAINE, "*Func*")
                Gosub ANAFUNC
            Elsif pat(CHAINE, "*Gosub*")
                Gosub ANAGOSUB
            Endif
            # on a trouvûˋ (donc ok pour ce traitement)
            If NLIG = -5
                Break(2)
            Endif

            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        Wend
    Wend 
 
Return



$ANACALL

    IP = instr(1,CHAINE, 'Call')

    CHAINE = right$(CHAINE, IP + len("Call "))
    IQ = instr(1, CHAINE, "From")
    If IQ = 0
        Return
    Endif
    
    NOMCALL = vireblc(left$(CHAINE, IQ - 1), 4)
    CHAINE1 = vireblc(right$(CHAINE, IQ + len("From")), 2)
    If instr(1, ALPHA, left$(CHAINE1, 1))
        IS = len(CHAINE1) - len(vireblc(ctrans(CHAINE1,ALPHAN,SPACEN),0))
        NOMPROG = vireblc(vireblc(left$(CHAINE1,IS),2),3)

        Call ECRIREREF(1, NOMTRT, NOMCALL, NOMPROG, GTTRAITEMENTS(NF), NBCROISE, NLIG)
    Endif
    
Return

$ANAFUNC

    While CHAINE <> ""

        IP = instr(1, CHAINE, 'func')     #CHECK IGNORE_LINE
        If IP = 0
            Break
        Endif
    
        IQ = instr(1, CHAINE, '.')
        If IQ = 0
            Break
        Endif
        
        IQ2PTS = instr(1,CHAINE, '..')
        If IQ2PTS = IQ
            CHAINE = right$(CHAINE, IQ2PTS + 2)
        Else
        
            # si le . est aprû´s ( ce n'est pas un nomprog.fc (param)  
            IQ2PTS = instr(1,CHAINE1, '(')
            If IQ2PTS > 0 and IQ2PTS < IQ
                CHAINE = right$(CHAINE, IQ2PTS + 1)
            Else

                NOMPROG = left$(CHAINE, IQ - 1)
                NOMPROG = right$(CHAINE, IP + 4) 
                NOMPROG = vireblc(CHAINE, 4)

                NOMCALL = right$(CHAINE, IQ + 1)

                Call ECRIREREF(2, NOMTRT, NOMCALL, NOMPROG, GTTRAITEMENTS(NF), NBCROISE, NLIG)
                If NLIG = -5
                    Break
                Endif
                CHAINE = right$(CHAINE, IQ + 1) 
            Endif
        Endif
    Wend

Return


$ANAGOSUB

    IP = instr(1, CHAINE, 'Gosub')

    CHAINE = right$(CHAINE, IP + len("Gosub"))
    IQ = instr(1, CHAINE, "From")
    If IQ = 0
        Return
    Endif

    NOMCALL = vireblc(left$(CHAINE, IQ - 1), 4)
    CHAINE = vireblc(right$(CHAINE, IQ + len("From")),2)
    
    If instr(1, CHAINE, "=")
        Return
    Endif
    CHAINE = vireblc(CHAINE, 0)
    
    If instr(1, ALPHA, left$(CHAINE, 1))
        IS = len(CHAINE) - len(vireblc(ctrans(CHAINE, ALPHAN, SPACEN),0))
        NOMPROG = vireblc(vireblc(left$(CHAINE, IS), 2), 3)
        
        Call ECRIREREF(3, NOMTRT, NOMCALL, NOMPROG, GTTRAITEMENTS(NF), NBCROISE, NLIG)
    Endif

Return



$FINCALL

End

   
#------------------------------------------------------------------------------------------------------------------------#
# si PTRAITCROISE <=> call PNOMCALL from PTRAITTROUVE dans le traitement PTRAITETUDIE
Subprog ECRIREREF(PORIG, PTRAITCROISE, PNOMCALL, PTRAITTROUVE, PTRAITETUDIE, NBCROISE, NLIG)
Value Integer PORIG
Variable Char PTRAITCROISE, PNOMCALL, PTRAITTROUVE, PTRAITETUDIE
Variable Integer NBCROISE, NLIG

Local Char WTEXTE(200)
Local Integer I

    If PTRAITTROUVE <> PTRAITCROISE
        End
    Endif

    NBCROISE += 1

    PNOMCALL = vireblc(PNOMCALL, 3)
    I = instr(1, PNOMCALL, '(')
    If I
        PNOMCALL = left$(PNOMCALL, I - 1)
    Endif


    WTEXTE =  PTRAITETUDIE - "appele le traitement (par"       
    If PORIG = 1
        WTEXTE =  WTEXTE - "Call"
    Elsif PORIG = 2
        WTEXTE =  WTEXTE - "Func"
    Else
        WTEXTE =  WTEXTE - "Gosub"
    Endif

    Wrseq WTEXTE - PNOMCALL + ") û  la ligne" - num$(NLIG) Using [FER]
    NLIG = -5

End
