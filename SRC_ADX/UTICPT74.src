#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT74   UTI process                                    Module CPT   #
# Update COA field in BUDAPP BUDAPPDET BUDREV BUDREVDET
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif
  If [F:ADS]MODULE(1)<>2 : End : Endif
  If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
  Read [ADA]ADA0=WDOSSIER;"GDD"
  If fstat | [F:ADA]FLACT<>2 : End : Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update COA field in BUDAPP BUDAPPDET BUDREV BUDREVDET") From LECFIC
  Call MAJ_UTICPT74(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT74(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR, NB, STOP
Local Char    TABKEY0(30)
Local Char    TABKEY1(30)
Local Char    CRITERE(250)

Call ECR_TRACE("UTICPT74 : Start of process on : "+DOSSIER,0) From GESECRAN

Raz WCOMPTEUR

If filinfo(filpath("FIL","BUD","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"BUD")=0
 If clalev([F:BUD])  =0  Local File =DOSSIER+".BUD"      [BUD] : Endif
 Columns [BUD] (ACCNUM,COA)
Else
 End
Endif

################ Update COA in BUDAPP
If filinfo(filpath("FIL","BUDAPP","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"BUDAPP")=0
 If clalev([F:BOA])  =0  Local File =DOSSIER+".BUDAPP"   [BOA] : Endif
 Raz STOP

$LOOP_BOA
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:BOA]NUM>'"+TABKEY0+"'"
Else
 CRITERE = "1=1"
Endif

Link [BOA] With [F:BUD]BUD1~=[F:BOA]ACCNUM
& As [LNK]
& Where  [F:BOA]ACC<>"" & [F:BOA]COA="" & evalue(CRITERE)

Call DEBTRANS From GLOCK

Trbegin [BOA]
 For [LNK]BOA0
  [F:BOA]COA = [F:BUD]COA
  Rewrite [F:BOA]
  If !fstat : NB += 1 : Endif
  If NB>GMAXUPDTRS
   TABKEY0 = [F:BOA]NUM
   STOP = 1
   Break
  Endif
 Next
Commit

WCOMPTEUR += NB
If STOP
 Goto LOOP_BOA
Endif

Close Local File [BOA]
Endif

################ Update COA in BUDAPPDET
If filinfo(filpath("FIL","BUDAPPDET","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"BUDAPPDET")=0
 If clalev([F:BAD])=0  Local File =DOSSIER+".BUDAPPDET"   [BAD] : Endif
 Raz STOP

$LOOP_BAD
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:BAD]NUMERO="+TABKEY0+" & [F:BAD]NUMAPP>'"+TABKEY1+"'"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:BAD]NUMERO>"+TABKEY0
Else
 CRITERE = "1=1"
Endif

Link [BAD] With [F:BUD]BUD1~=[F:BAD]ACCNUM
& As [LNK]
& Where  [F:BAD]ACC<>"" & [F:BAD]COA="" & evalue(CRITERE)

Call DEBTRANS From GLOCK

Trbegin [BAD]
 For [LNK]BAD0
  [F:BAD]COA = [F:BUD]COA
  Rewrite [F:BAD]
  If !fstat : NB += 1 : Endif
  If NB>GMAXUPDTRS
   TABKEY0 = num$([F:BAD]NUMERO)
   TABKEY1 = [F:BAD]NUMAPP
   STOP = 1
   Break
  Endif
 Next
Commit

WCOMPTEUR += NB
If STOP
 Goto LOOP_BAD
Endif

Close Local File [BAD]
Endif

################ Update COA in BUDREV
If filinfo(filpath("FIL","BUDREV","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"BUDREV")=0
 If clalev([F:BRV])=0  Local File =DOSSIER+".BUDREV"   [BRV] : Endif
 Raz STOP

$LOOP_BRV
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:BRV]NUM>'"+TABKEY0+"'"
Else
 CRITERE = "1=1"
Endif

Link [BRV] With [F:BUD]BUD1~=[F:BRV]ACCNUM
& As [LNK]
& Where  [F:BRV]ACC<>"" & [F:BRV]COA="" & evalue(CRITERE)

Call DEBTRANS From GLOCK

Trbegin [BRV]
 For [LNK]BRV0
  [F:BRV]COA = [F:BUD]COA
  Rewrite [F:BRV]
  If !fstat : NB += 1 : Endif
  If NB>GMAXUPDTRS
   TABKEY0 = [F:BRV]NUM
   STOP = 1
   Break
  Endif
 Next
Commit

WCOMPTEUR += NB
If STOP
 Goto LOOP_BRV
Endif

Close Local File [BRV]
Endif

################ Update COA in BUDREVDET
If filinfo(filpath("FIL","BUDREVDET","fde",DOSSIER),0)>0 & func DOSVUE.ISVIEW(DOSSIER,"BUDREVDET")=0
 If clalev([F:BVD])=0  Local File =DOSSIER+".BUDREVDET"   [BVD] : Endif
 Raz STOP

$LOOP_BVD
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:BVD]NUMERO="+TABKEY0+" & [F:BVD]NUMREV>'"+TABKEY1+"'"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:BVD]NUMERO>"+TABKEY0
Else
 CRITERE = "1=1"
Endif

Link [BVD] With [F:BUD]BUD1~=[F:BVD]ACCNUM
& As [LNK]
& Where  [F:BVD]ACC<>"" & [F:BVD]COA="" & evalue(CRITERE)

Call DEBTRANS From GLOCK

Trbegin [BVD]
 For [LNK]BVD0
  [F:BVD]COA = [F:BUD]COA
  Rewrite [F:BVD]
  If !fstat : NB+= 1 : Endif
  If NB>GMAXUPDTRS
   TABKEY0 = num$([F:BVD]NUMERO)
   TABKEY1 = [F:BVD]NUMREV
   STOP = 1
   Break
  Endif
 Next
Commit

WCOMPTEUR += NB
If STOP
 Goto LOOP_BVD
Endif

Close Local File [BVD]
Endif

Call ECR_TRACE("UTICPT74 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

Columns [BUD]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # N= module

If clalev([F:ADA])=0  : Local File ADOSACT [ADA] : Endif
Read [ADA]ADA0=APPLI;"GDD"
If fstat | [F:ADA]FLACT<>2 : End : Endif

Call MAJ_UTICPT74(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif

If filinfo(filpath("FIL","ADOSACT","fde",GDOSX3),0) <= 0 : End : Endif
If clalev([F:ADA])=0 : Local File =GDOSX3+".ADOSACT" [ADA] : Endif
Read [ADA]ADA0=APPLI;"GDD"
If fstat | [F:ADA]FLACT<>2 : End : Endif

Call MAJ_UTICPT74(APPLI)
End

