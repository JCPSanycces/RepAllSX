#<AdxTL>@(#)5.0.0.0 $Revision$
#<AdxTL>@(#)5.0.0.0 $Revision$
# Issue 79554 GA 01/2012: Correct WO subcontracted operation - after Bug 77397

Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Local Integer WOUV_TRACE
    If GTRACE = ""
        Call OUVRE_TRACE("UTIGPA32 : Process for OPESTR/OPEEND update - subcontracted WO operation") From LECFIC
        WOUV_TRACE=1
    Endif
    Call MAJ_UTIGPA32(DOSSIER)
    Call TEMPOFF     From GESECRAN
    If WOUV_TRACE=1
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE   From LECFIC
    Endif
  Endif
End



Subprog MAJ_UTIGPA32(LDOS)
Value Char LDOS


Local Mask =LDOS+".SBCK"       [SBCK]
Local Mask =LDOS+".JALK"       [JALK]
Local Mask =LDOS+".OPSK"       [OPSK]

Local File =LDOS+".FACILITY"   [FCY]
Local File =LDOS+".ITMMASTER"  [ITM]
Local File =LDOS+".ITMFACILIT" [ITF]
Local File =LDOS+".PORDERQ"    [POQ]
Local File =LDOS+".PORDER"     [POH]

Local File =LDOS+".MFGHEAD"    [MFG]
Local File =LDOS+".MFGITM"     [MFI]
Local File =LDOS+".MFGOPE"     [MFO]
Local File =LDOS+".MFGMAT"     [MFM]
Local File =LDOS+".OPERATIONS" [OPS]
Local File =LDOS+".CPTANALIN"  [CAL]
Local File =LDOS+".MFGTRS"     [MTS]
Local File =LDOS+".SCHEDULING" [SCH]
Local File =LDOS+".PARJAL"     [PJA]
Local File =LDOS+".WORKSTATIO" [MWS]
#
Local Date WRCPDAT,WORDDAT
Local Char WFCY(GLONFCY)
Local Integer WRE,ISPL,INUM
Raz WRE,ISPL,INUM

Local Integer WSIMFLG : WSIMFLG=2
Call OUINON(mess(6,115,1),WSIMFLG) From GESECRAN

Call ECR_TRACE("Start trace : MFGOPE" ,0) From GESECRAN

Trbegin [MFO]

Filter [POQ] Where VCRTYPORI=10 & VCRNUMORI<>"" Order By POHFCY
For [F:POQ] With Lock
    Read [POH]POH0=[F:POQ]POHNUM
    If fstat : Raz [F:POH] : Endif

    If [F:POH]POHFCY<>WFCY
       Gosub CHARG_PARAM
       WFCY=[F:POH]POHFCY
    Endif

    Read [F:MFG]MFG0=[F:POQ]VCRNUMORI
    If !fstat & [F:MFG]MFGSTA=1 & [F:MFG]MFGTRKFLG<5
       Gosub TRT_MFO
    Endif
    # Issue 84830 GA 10/2012
    If [F:POQ]VCRNUMORI<>[F:MFO]MFGNUM
     Call ECR_TRACE("Subcontract Operation order:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"OF="-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI)-num$([F:POQ]VCRSEQORI)
&                  -"could be modified to OF"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM),-1) From GESECRAN
       #[F:POQ]VCRNUMORI=[F:MFO]MFGNUM
       #[F:POQ]VCRLINORI=[F:MFO]OPENUM
       #[F:POQ]VCRSEQORI=[F:MFO]OPESPLNUM
       INUM+=1
    Elsif [F:POQ]VCRNUMORI=[F:MFO]MFGNUM & [F:POQ]VCRLINORI=[F:MFO]OPENUM & [F:POQ]VCRSEQORI<>[F:MFO]OPESPLNUM
     Call ECR_TRACE("Subcontract Operation order:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"OF="-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI)-num$([F:POQ]VCRSEQORI)
&                  -"will be modified to operation step"-num$([F:MFO]OPESPLNUM),0) From GESECRAN
       [F:POQ]VCRSEQORI=[F:MFO]OPESPLNUM
       ISPL+=1
    Endif
    Rewrite [F:POQ]
Next


If WSIMFLG=2
   Rollback
   Call ECR_TRACE("-MFO-"-mess(104,141,1)-" : "-num$(WRE)-"Rollbacked",0) From GESECRAN
Else
   Commit
   Call ECR_TRACE("-MFO-"-mess(104,141,1)-" : "-num$(WRE)-"Commited",0) From GESECRAN
Endif


End

$TRT_MFO
# relire MFO, et voir si maj necessaire dates selon SBCLIB,
# pour les opérations de sous-traitance commandées
#
WORDDAT    = [F:POQ]EXTRCPDAT-[F:POQ]OFS
WRCPDAT    = [F:POQ]EXTRCPDAT
Read [F:MFO]MFO1=[F:POQ]POHNUM;[F:POQ]POPLIN;1
If !fstat & [F:MFO]OPEEND <> WRCPDAT
   WRE+=1
   If WRCPDAT>=date$
     Call ECR_TRACE("Subcontracted Operation:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                  -"will be modified to"-num$(WORDDAT)-num$(WRCPDAT),0) From GESECRAN
     Gosub MAJ_SBC
   Else
     Call ECR_TRACE("Subcontracted Operation:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                  -"will be NOT modified to"-num$(WORDDAT)-num$(WRCPDAT),0) From GESECRAN
   Endif
Endif
Return

$MAJ_SBC
Local Integer STAT
#-----
# Extrait de SUPBPOHA: maj de l'opé de sous-traitance selon maj de la commande d'achat
#-----
   Raz [M:SBCK]
  [M:SBCK]MAJCOD    = "M"
  [M:SBCK]VCRNUM    = [F:POQ]POHNUM
  [M:SBCK]VCRLIN    = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ    = [F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
  [M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
  [M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
  [M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI
  [M:SBCK]BPSNUM    = [F:POQ]BPSNUM
  [M:SBCK]BPAADD    = [F:POQ]SCOADD
  If [F:POQ]LINCLEFLG<>2
     [M:SBCK]ORDQTY=[F:POQ]QTYSTU
  Elsif [F:POQ]RCPQTYSTU<>0
     [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU : # ligne cde soldée donc qté commandée = qté réceptionnée
  Else
     [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD="A"
  Endif
  [M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,STAT) From TRTDEV
  [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  [M:SBCK]OFS    = [F:POQ]OFS
  [M:SBCK]MSGFLG = 1
  [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    If [M:SBCK]VCRTYPORI=10
      GMESSAGE=mess(96,193,1)
    Elsif [M:SBCK]VCRTYPORI=36
      GMESSAGE=mess(913,196,1)
    Endif
    GERR=1 : GOK=0 : Return
  Endif
Return

$CHARG_PARAM
If GFCY<>[F:POH]POHFCY GFCY=[F:POH]POHFCY : Raz GMESSAGE : Endif
GCUR=[F:POH]CUR
Call GET_SOC(GFCY) From GLOFCYCPY
Call GET_DEV(GFCY) From GLOFCYCPY
Call GLOBVAR(GFCY) From WWGLOBACH

Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  ##### A lancer ssi nécessaire
  ##### Call MAJ_UTIGPA32(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  ##### A lancer ssi nécessaire
  ##### Call MAJ_UTIGPA32(APPLI)
End
