#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIGPA001   Moulinette pour evaluer le code activité APS               #
#            dans les tables ACTIV et ADOSACT                            #
# ---------------------------------------------------------------------- #
##########################################################################

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If clalev([F:WACV]) =0  Local File ACTIV   [WACV] : Endif
If clalev([F:ADA])  =0  Local File ADOSACT [ADA] : Endif

Call OUVRE_TRACE("Correction code activité APS") From LECFIC

For [ADS]

  Call TEMPON("O") From GESECRAN
  Call MAJ_UTIGPA001([F:ADS]DOSSIER) 
  Call TEMPOFF     From GESECRAN
Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

Subprog MAJ_UTIGPA001(PDOSSIER)
Value Char PDOSSIER

Local Integer COMPTEUR
Local Integer STAT
Local Char APPLI : APPLI = PDOSSIER

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=PDOSSIER : If fstat Raz [F:ADS] : Endif

Call ECR_TRACE("UTIGPA001: Process Start on : "+PDOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:WACV]) Close File [WACV] : Endif
If clalev([F:WACV]) =0  Local File =PDOSSIER+".ACTIV"   [WACV] : Endif
If clalev([F:ADA])  =0  Local File ADOSACT [ADA] : Endif

Call DEBTRANS From GLOCK
Gosub OUVFIC From VALMSKLEC
#----- Maj du code activité APS dans ACTIV -----#
Trbegin [WACV]
Update [WACV] Where CODACT="APS" & ACTFOR<>"ORP | ORO"
&            With FLACT=2,
&                 ACTFOR="ORP | ORO",
&                 DEP=4,
&                 TYP=1
Commit
Call ECR_TRACE("UTIGPA001 : ACTIV "+num$(adxuprec)+" records processed",0) From GESECRAN

#----- Maj du code activité APS dans ADOSACT -----#
Raz [ADA]
Read [ADA]ADA0=PDOSSIER;"ORP"
WORP=1
WORP=[F:ADA]FLACT
Raz [ADA]
Read [ADA]ADA0=PDOSSIER;"ORO"
WORO=1
WORO=[F:ADA]FLACT
If WORP=2 | WORO=2
    WAPS=2
Else
    WAPS=1
Endif
Call ECR_TRACE("UTIGPA001 : ORP="+num$(WORP)+" ORO="+num$(WORO)+" APS="+num$(WAPS),0) From GESECRAN

Trbegin [ADA]
Update [ADA] Where CODACT="APS" & [F:ADA]DOSSIER = PDOSSIER & FLACT<>WAPS
&            With FLACT=WAPS
Commit

Call ECR_TRACE("UTIGPA001 : ADOSACT "+num$(adxuprec)+" records processed",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTIGPA001(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call MAJ_UTIGPA001(APPLI)
End







