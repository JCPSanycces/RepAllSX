 [F:EVT0]RPUDAT     = [M:LEAL]RPUDAT
Return

$ECLATE_NBFLD
 LNBFLD=1
Return

$ECLATE_STATUS
  T_INTNOMZON(0)    = "RPUVAL"
Return

$INFO_EVTINT
 EVT = "LEARPU"
 LPLN= 6
Return

