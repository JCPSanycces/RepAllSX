#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET ("OMR", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "RAZCRE"       : Gosub RAZCRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "MODIF"        : Gosub MODIF
    When "LIENS"        : Gosub LIENS
    When "RAZDUP"       : Gosub RAZDUP
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When Default
  Endcase
Return

##########################################################################################################
$SETBOUT
  If GREP <> "" Then
    Call VIREBOUT(CHAINE,"1") From GOBJET  # Copie vers client
    Call VIREBOUT(CHAINE,"2") From GOBJET  # Copie vers serveur
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$EXEBOUT
  Case BOUT
    When "1"    # Copie vers client
      Gosub COPY_CLIENT
    When "2"    # Copie vers serveur
      Gosub COPY_SERVER
    When Default
  Endcase
Return

##########################################################################################################
$VERIF_CRE
  [M:OMR0]MAGTPLRPT = [M:OMR0]MAGTPL
Return

##########################################################################################################
$RAZCRE
  Raz [M:OMR0]MAGTPLRPT
Return

##########################################################################################################
$CREATION
Local Char SVGLANGUE(type(GLANGUE)-10)

  SVGLANGUE = GLANGUE
  GLANGUE = [M:OMR0]LAN
  Call MAJTEXTRA([M:OMR0]OMRSHOAX1, "OMMRPT", "OMRSHOAX1", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
  Call MAJTEXTRA([M:OMR0]OMRDESAX3, "OMMRPT", "OMRDESAX3", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
  GLANGUE = SVGLANGUE
  # --------------------------------
  # Création du RPT
  Gosub COPIE_MAGTPL
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  Gosub ICONE_VALIDE
Return

##########################################################################################################
$APRES_MOD
  Gosub ICONE_VALIDE
Return

##########################################################################################################
$RAZDUP
  Raz [M:OMR0]MAGTPLRPT
Return

##########################################################################################################
$MODIF
Local Char SVGLANGUE(type(GLANGUE)-10)

  SVGLANGUE = GLANGUE
  GLANGUE = [M:OMR0]LAN
  Call MAJTEXTRA([M:OMR0]OMRSHOAX1, "OMMRPT", "OMRSHOAX1", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
  Call MAJTEXTRA([M:OMR0]OMRDESAX3, "OMMRPT", "OMRDESAX3", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
  GLANGUE = SVGLANGUE
  # --------------------------------
  # Création du RPT s'il n'existe pas
  If filinfo(filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
    Gosub COPIE_MAGTPL
    If GOK < 1 Then
      Return
    Endif
  Endif
Return

##########################################################################################################
$LIENS
  Gosub ICONE_VALIDE
Return

##########################################################################################################
$ICONE_VALIDE
  If filinfo(filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
    [M:OMR0]ICOSTA = "127" # icone rouge
    [M:OMR0]MSGSTA = mess(1144,196,1)
  Else
    [M:OMR0]ICOSTA = "128" # icone vert
    [M:OMR0]MSGSTA = mess(1145,196,1)
  Endif
  Affzo [M:OMR0]ICOSTA
  Affzo [M:OMR0]MSGSTA
Return

##########################################################################################################
$AV_ANNULE
Local Integer ISTAT
Local Char SFILE(250)
Local Char SMESSAGE(type(GMESSAGE)-10)

  # --------------------------------
  # Suppression du RPT s'il existe
  SFILE = filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0))
  If [M:OMR0]MAGTPLRPT <> "" and filinfo(SFILE, 7) >= 0 Then
    # On regarde si le fichier existe. S'il n'existe pas, pas la peine de faire une erreur parce que la suppression échoue
    ISTAT = func ASYRSYS.DELETEFILE(SFILE, SMESSAGE)
    If ISTAT <> 1 Then
      GMESSAGE = mess(1655,9900,1) - [M:OMR0]MAGTPLRPT + ".rpt"
      GERR = 1
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$ANNULE
  Call SUPTEXTRA("OMMRPT", "OMRSHOAX1", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
  Call SUPTEXTRA("OMMRPT", "OMRDESAX3", [M:OMR0]LAN, [M:OMR0]MAGTPL) From ATEXTRA
Return

##########################################################################################################
$COPIE_MAGTPL
  If [M:OMR0]MAGTPL = "MAILING" Then
    Gosub COPIE_MAILINGX_MAGTPL
  Else
    Gosub COPIE_MAILING_MAGTPL
  Endif
Return

##########################################################################################################
$COPIE_MAILINGX_MAGTPL
Local Integer ISTAT
Local Char SMESSAGE(type(GMESSAGE)-10)

  # -----------------------------------------------------------------------------------
  # Duplication du fichier RPT selon cette règle :
  #o  On va regarder si l'état MAILINGX.rpt existe dans le répertoire
  #   REPORT/LangueDeConnexion du dossier de connexion.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas on va regarder si MAILINGX.rpt existe dans le répertoire REPORT/FRA
  #   Du dossier de connexion.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas, On va regarder si l'état MAILINGX.rpt existe dans le répertoire
  #   REPORT/LangueDeConnexion du dossier racine.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas on va regarder si MAILINGX.rpt existe dans le répertoire REPORT/FRA
  #   Du dossier de racine.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  # -----------------------------------------------------------------------------------
  # nomap(0) : Dossier courant
  # nomap(1) : Dossier mère
  # -----------------------------------------------------------------------------------
  If filinfo(filpath("REPORT\" + [M:OMR0]LAN, "MAILINGX", "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
    # Il n'existe pas dans la langue de connexion sur le dossier courant
    If filinfo(filpath("REPORT\" + "FRA", "MAILINGX", "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
      # Il n'existe pas dans la langue "FRA" sur le dossier courant
      If filinfo(filpath("REPORT\" + [M:OMR0]LAN, "MAILINGX", "rpt", nomap(1), "", adxmac(0)), 7) < 0 Then
        # Il n'existe pas dans la langue de connexion sur le dossier mère
        If filinfo(filpath("REPORT\" + "FRA", "MAILINGX", "rpt", nomap(1), "", adxmac(0)), 7) < 0 Then
          # Il n'existe pas dans la langue "FRA" sur le dossier mère
          # Là c'est une erreur
          GMESSAGE = mess(603,196,1) - mess(604,196,1) - " MAILINGX.rpt" - mess(605,196,1)
          GERR = 1
          GOK = 0
          Return
        Else
          ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + "FRA", "MAILINGX", "rpt", nomap(1), "", adxmac(0)),
&                                       filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                       SMESSAGE)
          If ISTAT <> 1 Then
            If SMESSAGE <> "" Then
              GMESSAGE = SMESSAGE
            Else
              GMESSAGE = mess(33,143,1) - "MAILINGX.rpt (d)"
            Endif
            GERR = 1
            GOK = 0
            Return
          Endif
        Endif
      Else
        ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + [M:OMR0]LAN, "MAILINGX", "rpt", nomap(1), "", adxmac(0)),
&                                     filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                     SMESSAGE)
        If ISTAT <> 1 Then
          If SMESSAGE <> "" Then
            GMESSAGE = SMESSAGE
          Else
            GMESSAGE = mess(33,143,1) - "MAILINGX.rpt (c)"
          Endif
          GERR = 1
          GOK = 0
          Return
        Endif
      Endif
    Else
      ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + "FRA", "MAILINGX", "rpt", nomap(0), "", adxmac(0)),
&                                   filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                   SMESSAGE)
      If ISTAT <> 1 Then
        If SMESSAGE <> "" Then
          GMESSAGE = SMESSAGE
        Else
          GMESSAGE = mess(33,143,1) - "MAILINGX.rpt (b)"
        Endif
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
  Else
    ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + [M:OMR0]LAN, "MAILINGX", "rpt", nomap(0), "", adxmac(0)),
&                                 filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                 SMESSAGE)
    If ISTAT <> 1 Then
      If SMESSAGE <> "" Then
        GMESSAGE = SMESSAGE
      Else
        GMESSAGE = mess(33,143,1) - "MAILINGX.rpt (a)"
      Endif
      GERR = 1
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$COPIE_MAILING_MAGTPL
Local Integer ISTAT
Local Char SMESSAGE(type(GMESSAGE)-10)

  # -----------------------------------------------------------------------------------
  # Duplication du fichier RPT selon cette règle :
  #o  On va regarder si l'état MAILING.rpt existe dans le répertoire
  #   REPORT/LangueDeConnexion du dossier de connexion.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas on va regarder si MAILING.rpt existe dans le répertoire REPORT/FRA
  #   Du dossier de connexion.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas, On va regarder si l'état MAILING.rpt existe dans le répertoire
  #   REPORT/LangueDeConnexion du dossier racine.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  #o  S'il n'existe pas on va regarder si MAILING.rpt existe dans le répertoire REPORT/FRA
  #   Du dossier de racine.
  #   S'il existe on le duplique sous le nom NOUVEAUNOM.rpt
  # -----------------------------------------------------------------------------------
  # nomap(0) : Dossier courant
  # nomap(1) : Dossier mère
  # -----------------------------------------------------------------------------------
  If filinfo(filpath("REPORT\" + [M:OMR0]LAN, "MAILING", "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
    # Il n'existe pas dans la langue de connexion sur le dossier courant
    If filinfo(filpath("REPORT\" + "FRA", "MAILING", "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
      # Il n'existe pas dans la langue "FRA" sur le dossier courant
      If filinfo(filpath("REPORT\" + [M:OMR0]LAN, "MAILING", "rpt", nomap(1), "", adxmac(0)), 7) < 0 Then
        # Il n'existe pas dans la langue de connexion sur le dossier mère
        If filinfo(filpath("REPORT\" + "FRA", "MAILING", "rpt", nomap(1), "", adxmac(0)), 7) < 0 Then
          # Il n'existe pas dans la langue "FRA" sur le dossier mère
          # Dans ce cas on tente de reprendre MAILINGX
          Gosub COPIE_MAILINGX_MAGTPL
          Return
        Else
          ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + "FRA", "MAILING", "rpt", nomap(1), "", adxmac(0)),
&                                       filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                       SMESSAGE)
          If ISTAT <> 1 Then
            If SMESSAGE <> "" Then
              GMESSAGE = SMESSAGE
            Else
              GMESSAGE = mess(33,143,1) - "MAILING.rpt (d)"
            Endif
            GERR = 1
            GOK = 0
            Return
          Endif
        Endif
      Else
        ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + [M:OMR0]LAN, "MAILING", "rpt", nomap(1), "", adxmac(0)),
&                                     filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                     SMESSAGE)
        If ISTAT <> 1 Then
          If SMESSAGE <> "" Then
            GMESSAGE = SMESSAGE
          Else
            GMESSAGE = mess(33,143,1) - "MAILING.rpt (c)"
          Endif
          GERR = 1
          GOK = 0
          Return
        Endif
      Endif
    Else
      ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + "FRA", "MAILING", "rpt", nomap(0), "", adxmac(0)),
&                                   filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                   SMESSAGE)
      If ISTAT <> 1 Then
        If SMESSAGE <> "" Then
          GMESSAGE = SMESSAGE
        Else
          GMESSAGE = mess(33,143,1) - "MAILING.rpt (b)"
        Endif
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
  Else
    ISTAT = func ASYRSYS.COPYFILE(filpath("REPORT\" + [M:OMR0]LAN, "MAILING", "rpt", nomap(0), "", adxmac(0)),
&                                 filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)),
&                                 SMESSAGE)
    If ISTAT <> 1 Then
      If SMESSAGE <> "" Then
        GMESSAGE = SMESSAGE
      Else
        GMESSAGE = mess(33,143,1) - "MAILING.rpt (a)"
      Endif
      GERR = 1
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$COPY_CLIENT
Local Integer ISTAT
Local Integer ASTATUS
Local Char SFICCLI(250)
Local Char SMESSAGE(250)

  If filinfo(filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
    GMESSAGE = mess(4,95,1) - [M:OMR0]MAGTPLRPT + ".rpt" - mess(87,100,1)
    GERR = 1
    Return
  Else
    # Copie [M:OMR0]MAGTPLRPT + "rpt" vers le poste client
    SFICCLI = [M:OMR0]MAGTPLRPT + ".rpt"
    Call COPCLI(filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), SFICCLI, ISTAT) From ORDSYS
    If ISTAT <> 0 Then
      If GMESSAGE = "" Then
        GMESSAGE = mess(19,139,1) - ":" - mess(7,21,1)
      Endif
      GERR = 1
      Return
    Endif
  Endif
Return

##########################################################################################################
$COPY_SERVER
Local Integer ISTAT
Local Integer ASTATUS
Local Char SFICCLI(250)
Local Char SFICSRV(250)

  # Copie depuis le client sur le serveur sous le nom [M:OMR0]MAGTPLRPT + "rpt"
  SFICCLI = [M:OMR0]MAGTPLRPT + ".rpt"
  SFICSRV = filpath("REPORT\" + [M:OMR0]LAN, [M:OMR0]MAGTPLRPT, "rpt", nomap(0), adxmac(0))
  Call COPSRV(SFICCLI, SFICSRV, ISTAT) From ORDSYS
  If ISTAT <> 0 Then
    If GMESSAGE = "" Then
      GMESSAGE = mess(20,139,1) - ":" - mess(7,21,1)
    Endif
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
##########################################################################################################
##########################################################################################################
Subprog D_LAN(VALEUR)
Variable Char    VALEUR()

  VALEUR = GLANGUE
End

##########################################################################################################
Subprog C_MAGTPL(VALEUR)
Variable Char    VALEUR()

  If toupper(VALEUR) = "MAILINGX" Then
    GMESSAGE = mess(92,151,1) - VALEUR - mess(127,196,1)
    mkstat = 2
    End
  Endif
  # ----------------------
  If toupper(VALEUR) <> "MAILING" Then
    # MAILING doit exister dans le dictionnaire
    Local File AREPORT [ARP]
    Read [ARP]ARP0=toupper(VALEUR)
    If !fstat Then
      GMESSAGE = mess(780,196,1) - mess(627,196,1)
      mkstat = 2
      End
    Endif
  Endif
End
