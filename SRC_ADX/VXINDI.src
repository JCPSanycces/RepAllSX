#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXINDI


$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When "OK"            : Gosub OK
  Endcase
Return
######################################################################################
$DEBUT
  Raz [M:XINDI]
  Grizo [M:XINDI]ELPFLG
  [M:XINDI]ELPFLG = 0
  Grizo [M:XINDI]DURATION
  Affzo [M:XINDI]
Return

######################################################################################
$OK

  Local Char      CHARBLANK(20)(1) # Using this for all that we don't need
  Local Integer   INTBLANK(1)      # Using this for all that we don't need
  Local Decimal   DECBLANK(1)      # Using this for all that we don't need
  Local Integer   NUMJOBS : NUMJOBS = 1

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null
  Local Integer CSTATUS

  If [M:XINDI]ELPFLG = [V]CST_AYES
    Gosub ELAPSED
  Else
    Gosub START
  Endif

  FreeGroup SFTTXN
  Kill SFTTXN

Return

######################################################################################
$ELAPSED
  Local Integer   INDTYP(1)
  Local Char      BRKCOD(3)(1), ACTTYP(3)(1)
  Local Decimal   DURATION(1)

  BRKCOD(0) = [M:XINDI]INDREF
  INDTYP(0) = [M:XINDI]INDTYP
  DURATION(0) = [M:XINDI]DURATION
  ACTTYP(0) = "EIR"
  NUMJOBS(0) = 1

  If fmet SFTTXN.TIME_TRACKING([M:XINDI]EMPNUM, [M:XINDI]FCY, BRKCOD, INDTYP,
&                                       INTBLANK, NUMJOBS, CHARBLANK, CHARBLANK,
&                                       DURATION, DECBLANK, DECBLANK, ACTTYP,
&                                       DECBLANK, INTBLANK, INTBLANK, 1)

    Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(2,2416,1)))) From GESECRAN
    Return
  Endif

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XINDI]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES1(mess(90,2422,1),tolower(mess(2,2416,1)))) From GESECRAN

Return

######################################################################################
$START

Local Char    INDREF(3) : [L]INDREF = [M:XINDI]INDREF
Local Char    BLANK_CHAR(20)(1)
Local Integer BLANK_INT(20)(1)
Local Integer INDTYP(1) : INDTYP(0) = [M:XINDI]INDTYP
Local Integer EMPTEAMNUM
Local Integer   YESNO : YESNO = [V]CST_AYES
Local Char      ERRMSG(125)
Local Integer   ERRNUM

  If [M:XINDI]INDTYP = 4 # Exclusive Indirect

    If fmet SFTTXN.BREAK_START([M:XINDI]EMPNUM, [M:XINDI]FCY, 2, [M:XINDI]INDREF, [M:XINDI]INDTYP) <> [V]CST_AOK
      Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(2,2416,1)))) From GESECRAN
      Return
    Endif
  Else # Non-exclusive Indirect

    If !clalev([SFTXNS]) : Local File SFTTXN [SFTXNS] : Endif
    # Check if employee is in a team and if he has any team activities running
    Call EMP_TEAM_NUM ([M:XINDI]EMPNUM, EMPTEAMNUM) From SFTLIB
    If EMPTEAMNUM <> 0   # Employee is part of the team
      Filter [F:SFTXNS] Where (EMPNUM = [M:XINDI]EMPNUM & TEAMNUM = EMPTEAMNUM) &
&                              SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM
      Look [F:SFTXNS] First
      If fstat = 0    # Found open team activities...
        Call OUINON(mess(107,2422,1), YESNO) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
        If YESNO <> [V]CST_AYES    # No
          mkstat = 2
          Return
        Endif

        # Stop open activities...
        Call STOP_OPEN_ACTIVITIES(EMPTEAMNUM, [M:XINDI]EMPNUM, ERRNUM, ERRMSG) From SFTLIB
        If ERRNUM
          GERR=1 : GMESSAGE = ERRMSG
          mkstat = 2
          Return
        Endif
      Endif
    Endif
    LogicClose File [SFTXNS]

  If fmet SFTTXN.OPERATION_START([M:XINDI]EMPNUM, [M:XINDI]FCY, [M:XINDI]EMPTYP, 2, datetime$, [L]INDREF, INDTYP, BLANK_INT, BLANK_CHAR, BLANK_CHAR,
&                                             BLANK_CHAR, 1, 1, 1) <> [V]CST_AOK
      Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(2,2416,1)))) From GESECRAN
      Return
    Endif
  Endif

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XINDI]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES2(mess(77,2422,1), [M:XINDI]INDREF, OTIME) ) From GESECRAN

Return
######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Local Integer EMPTYP
  Local File TABMAT [TMA]

  Read [TMA]TMA0=VALEUR
  If fstat # Check if record exists
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 1
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  LogicClose File [TMA]

  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO # Are they active
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 1
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB

  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Raz [M:XINDI]INDREF
  Raz [M:XINDI]DURATION

  Local File TABMAT [TMA]

  Read [TMA]TMA0=VALEUR

  [M:XINDI]EMPDES = [F:TMA]EMPDES
  [M:XINDI]FCY=[F:TMA]DEFFCY
  [M:XINDI]EMPTYP = [F:TMA]EMPTYP

  If [F:TMA]ELPFLG = [V]CST_AYES
    Local Char PARAMRET(4)
    Raz PARAMRET

    Call PARAM([M:XINDI]FCY,"SFTELPDEF",PARAMRET) From ADOVAL
    If val([L]PARAMRET) = [V]CST_AYES
      ELPFLG = [V]CST_AYES
      Actzo [M:XINDI]DURATION
    Else
      [M:XINDI]ELPFLG = [V]CST_ANO
      Grizo [M:XINDI]DURATION
    Endif
    [M:XINDI]WELPFLG = mess(870,197,1)
    [M:XINDI]WDURATION = mess(881,197,1)
    [M:XINDI]WUOM = mess(882,197,1)

    Actzo [M:XINDI]ELPFLG
    Affzo [M:XINDI]
  Else
    Grizo [M:XINDI]ELPFLG
    Grizo [M:XINDI]DURATION
    Raz [M:XINDI]WELPFLG
    Raz [M:XINDI]WDURATION
    Raz [M:XINDI]WUOM
    Affzo [M:XINDI]
  Endif

  LogicClose File [TMA]

End

######################################################################################
Subprog C_INDREF(VALEUR)
Variable Char    VALEUR()
  Local File SFTINDREF [SFTIR]
  Read [SFTIR]SFTAG0  = VALEUR

  If ([F:SFTIR]INDTYP <> 3 and [F:SFTIR]INDTYP <> 4)
    GMESSAGE = func AFNC.MES1(mess(81,2422,1), VALEUR)
    mkstat = 1
    End
  Endif
  LogicClose File [SFTIR]

  #CT-2253.sn Commented Out
  #Need to allow user to select the same non-exclusive indirect multiple times without error message.
  #Local File SFTTXN [SFTX]
  #Filter [SFTX] Where EMPNUM = [M:XINDI]EMPNUM and SFTTYP = 2 and FCY = [M:XINDI]FCY and INDREF = VALEUR and UTCENDDATTIM = AVOID.ADATTIM
  #Look [SFTX] First
  #If !fstat
  #  GMESSAGE = func AFNC.MES1(mess(79,2422,1), VALEUR)
  #  mkstat = 1
  #  End
  #Endif
  #LogicClose File [SFTX]
  ##CT-2253.en

End

######################################################################################
Subprog AM_INDREF(VALEUR)
Variable Char    VALEUR()

  Local File SFTINDREF [SFTIR]
  Read [SFTIR]SFTAG0 = VALEUR

  [M:XINDI]INDTYP = [F:SFTIR]INDTYP

  LogicClose File [SFTIR]
End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  Local Char PARAMRET(4)
  Raz PARAMRET
  # check if clock in is needed for this site
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:XINDI]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:XINDI]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:XINDI]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:XINDI]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:XINDI]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:XINDI]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif
End

######################################################################################
Subprog C_DURATION(VALEUR)
Variable Decimal VALEUR

  If [M:XINDI]ELPFLG = [V]CST_AYES and VALEUR = 0
    GMESSAGE = mess(92,2422,1)
    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  #CT-2297 sn
  #[M:XINDI]ELPFLG initialized to zero if employee's [TMA]ELPFLG is unchecked
  If [M:XINDI]ELPFLG <> 0

    Local Char PARAMRET(4)
    Raz PARAMRET
    Call PARAM(VALEUR,"SFTELPDEF",PARAMRET) From ADOVAL

    If val([L]PARAMRET) = [V]CST_AYES
      [M:XINDI]ELPFLG = [V]CST_AYES
      Actzo [M:XINDI]DURATION
    Else
      [M:XINDI]ELPFLG = [V]CST_ANO
      Grizo [M:XINDI]DURATION
    Endif

    Actzo [M:XINDI]ELPFLG
  Endif
  #CT-2297 en
  Affzo [M:XINDI]
End

######################################################################################
Subprog AM_ELPFLG(VALEUR)
Variable Integer    VALEUR()

  If VALEUR = [V]CST_AYES
    Actzo [M:XINDI]DURATION
  Else
    Grizo [M:XINDI]DURATION
  Endif

End

######################################################################################

