#<AdxTL>@(#)11.0.0.0 $Revision$
############################################################################
# UUMGPOSCPT11                                          Module  Accounting #
#                                                                          #
#              Post-migration of Flow for Journal Entry                    #
#                                                                          #
# Management of new field  : CAPFLOTYP                                     #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSCPT11") From LECFIC
  Endif

  #Call RAZ_UUMGPOSCPT11(DOSSIER)
  Call MAJ_UUMGPOSCPT11(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSCPT11(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSCPT11",ERR) From TRTMIG

End

###################################################################################
Subprog MAJ_UUMGPOSCPT11(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(1)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",2,ERR) From TRTMIG

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",7,ERR) From TRTMIG : End : Endif
If val(VERSION)<GMIGX3VER60 | val(VERSION)>=GMIGX3VER70
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGPOSCPT11 Journal Entry Process : Update GACCENTRYD - Fields : CAPFLOTYP") From DOSSUB
Call ECR_TRACE("UUMGPOSCPT11 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Index addition  ----------#
Call MIGINDCRE (DOSSIER,"GACCENTRYD","CPY+STT1+ACCNUM","","",0,ERR) From TRTMIG
If ERR
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",7,ERR) From TRTMIG : Goto FIN
Endif

#--------------- Opening of files  -----#
If clalev([F:DAE]) : Close File [DAE] : Endif
If clalev([F:DAE])  = 0 : Local File =DOSSIER+".GACCENTRYD"      [DAE]  : Endif

If clalev([F:CPY])  = 0 : Local File =DOSSIER+".COMPANY"    [CPY]   : Endif
If clalev([F:ADI])  = 0 : Local File =DOSSIER+".ATABDIV"    [ADI]   : Endif

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30)
Local Integer ICLE1
Local Char SAV_STT1(GLONADI)

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT11
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:DAE]CAPFLOTYP='' & [F:DAE]CPY='"+ACLE1+"' & [F:DAE]STT1='"+ACLE2+"' & [F:DAE]ACCNUM>"+num$(ICLE1)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:DAE]CAPFLOTYP='' & [F:DAE]CPY='"+ACLE1+"' & [F:DAE]STT1>'"+ACLE2+"'"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:DAE]CAPFLOTYP='' & [F:DAE]CPY>'"+ACLE1+"' & [F:DAE]STT1<>''"
Else
 CRITERE = "[F:DAE]CAPFLOTYP='' & [F:DAE]STT1<>''"
Endif

Trbegin [DAE]
GOK = 1

For [DAE]MIG(1) Where evalue(CRITERE)

 # By company
 Read [CPY]CPY0 = [F:DAE]CPY
 If fstat
  # No company... Migration isn't avaiable for journal entries
  GOK = 0 : Call ERREUR([F:DAE]CPY-mess(16,104,1),4) From DOSDIC
 Elsif [F:CPY]LEG="POR"
  For [DAE]MIG(2)
   Read [ADI]CODE = 389;[F:DAE]STT1
   If !fstat
    For [DAE]MIG
     NBLUS+=1
     [F:DAE]CAPFLOTYP =[F:ADI]CODE
     [L]SAV_STT1 = [F:DAE]STT1
     [F:DAE]STT1 =""

     Rewrite [F:DAE]
     If fstat
      Call ECR_TRACE("File GACCENTRYD(NUM/ACCNUM)"-[F:DAE]NUM+"/"+num$([F:DAE]ACCNUM)+", Error ="-num$(fstat),1) From GESECRAN
      GOK=0 : Break 2
     Endif

     NB+=1
     If NB>GMAXUPDTRS
      ACLE1 = [F:DAE]CPY
      ACLE2 = [L]SAV_STT1
      ICLE1 = [F:DAE]ACCNUM
      STOP=1
      Break 3
     Endif
    Next
   Endif
  Next
 Endif
Next

If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT11",7,ERR) From TRTMIG
Else

# Commit
Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSCPT11",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT11
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [DAE]

#--------------- Deleting an index ----------#
Call MIGINDDEL (DOSSIER,"GACCENTRYD",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSCPT11") From TRTMIG
Call ECR_TIME("UUMGPOSCPT11 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

