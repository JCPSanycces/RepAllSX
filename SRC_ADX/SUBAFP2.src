#<AdxTL>@(#)8.0.0.0 $Revision$
##------------------------------------------------------##
##        Sous programme : Ajout d'une fonction         ##
##------------------------------------------------------##
## MAJ de la table AFCTFCY par rapport AFCTFCT          ##
## (flag, ALLACS)                                       ##
##------------------------------------------------------##
Subprog CREATIONFONCTION(FCT,CURTYP,CURNBR,CUROPT)
Value Char    FCT
Value Integer CURTYP , CURNBR
Value Char    CUROPT()(0..)

Local Integer J,OK,WOK,OPTENA
Local Char OPT(23)

If clalev([F:AFF])  = 0 : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFT])  = 0 : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY  [FCY]  : Endif

# Coup de sécurité
Delete [AFF] Where [F:AFF]FNC = FCT
If fstat = 1
  GOK = -1 : Call RSTA("AFF","") From GLOCK : End
Elsif fstat
   GOK = 0  : Call FSTA("AFF") From GLOCK : End
Endif

OPTENA = func SUBAFP.OPT(FCT)

For [AFT] Where [F:AFT]ALLFCT = 2

        [L]OPT = ""
        If CURTYP = 2
         [L]OPT="CMS"
         If OPTENA : [L]OPT += "N" : Endif
        Endif
        For J = 0 To (CURNBR-1)
            [L]OPT = [L]OPT  + CUROPT(J)
        Next J
        Call TRI([L]OPT)

        For [FCY]FCY0
            Raz [F:AFF]
            [F:AFF]PRFCOD = [F:AFT]PRFCOD
            [F:AFF]FCY    = [F:FCY]FCY
            [F:AFF]FNC    = FCT
            [F:AFF]OPT    = [L]OPT

            Write [AFF]
            If fstat
                GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
            Endif
        Next

        # Création du site vide
        Look [AFF]AFF0 = "";[F:AFT]PRFCOD;FCT
        If fstat
            Raz [F:AFF]
            [F:AFF]PRFCOD = [F:AFT]PRFCOD
            [F:AFF]FCY    = ""
            [F:AFF]FNC    = FCT
            [F:AFF]OPT    = [L]OPT
            Write [AFF]
            If fstat
               GOK = 0  : Call FSTA("AFF") From GLOCK : Break
            Endif
        Endif

Next
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End

##------------------------------------------------------##
##        Sous programme : Modif d'une fonction         ##
##------------------------------------------------------##
##          MAJ de la table AFCTPRF & AFCTFCY           ##
##                                                      ##
##------------------------------------------------------##
Subprog MODIFONCTION(FCT,TYP,AUZ,NBR,OPT,CURTYP,CURAUZ,CURNBR,CUROPT)
Value Char    FCT
Value Integer TYP , AUZ , NBR
Value Char    OPT()(0..)
Value Integer CURTYP , CURAUZ , CURNBR
Value Char    CUROPT()(0..)

Local Integer I,J,EXIT,TRACE
TRACE = (GTRACE<>"" & 1=0)

If clalev([F:AFP1])  = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFF])   = 0 : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFT])   = 0 : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:FCY])   = 0 : Local File FACILITY  [FCY]  : Endif

Call TEMPON("V") From GESECRAN

## Flag TYP
If CURTYP <> TYP
    If TRACE : Call ECR_TRACE("Type accès objet de la fonction"-FCT-":"-mess(TYP,1,1),0) From GESECRAN : Endif
    Call MODIFTYP(FCT,TYP,CURNBR,CUROPT)
Endif

## Flag FCYAUZ
If CURAUZ <> AUZ
    If TRACE : Call ECR_TRACE("Autorisation site de la fonction"-FCT-":"-mess(AUZ,1,1),0) From GESECRAN : Endif
    Call MODIFAUZ(FCT,AUZ,CURTYP,CURNBR,CUROPT)
Endif

## Modification d'options
# cas d'un ajout d'options
For I = 0 To NBR-1
    EXIT = 0
    For J = 0 To CURNBR-1
        If OPT(I) = CUROPT(J)
            EXIT= 1
            Break
        Endif
    Next J
    If EXIT = 0
        If TRACE : Call ECR_TRACE("Ajout option dans la fonction"-FCT-":"-OPT(I),0) From GESECRAN : Endif
        Call AJOUTOPT(FCT,OPT(I))
    Endif
Next I
# cas d'une suppression d'options
For I = 0 To CURNBR-1
    EXIT = 0
    For J = 0 To NBR-1
        If CUROPT(I) = OPT(J)
            EXIT= 1
            Break
        Endif
    Next J
    If EXIT = 0
        If TRACE : Call ECR_TRACE("Suppression option dans la fonction"-FCT-":"-CUROPT(I),0) From GESECRAN : Endif
        Call SUPPOPT(CUROPT(I),FCT)
    Endif
Next I
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Call TEMPOFF From GESECRAN
End

#########################################################
Subprog MODIFTYP(FCT,TYP,CURNBR,CUROPT)
Value Char    FCT
Value Integer TYP , CURNBR
Value Char    CUROPT()(0..)

Local Char OPT(23)
Local Integer I,J,OK,WOK,OPTENA

OPTENA = func SUBAFP.OPT(FCT)

If TYP = 2

        # mise à jour (AFF/AFT) de la fonction dont code profil = ALLACS coché (ajout CMNS)
        For [AFT] Where [F:AFT]ALLFCT = 2

            ## mise à jour
            For [AFF]AFF1 Where [F:AFF]PRFCOD = [F:AFT]PRFCOD
&                         and [F:AFF]FNC    = FCT
                [F:AFF]OPT = "CMS" + string$(OPTENA<>0,"N")+[F:AFF]OPT
                Call TRI([F:AFF]OPT) From SUBAFP2
                Rewrite [AFF]
                If fstat
                    GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
                Endif
            Next
        Next

Else

        # mise à jour AFF&AFP (supp CMNS)
        For [F:AFT]AFT0

            # mise à jour (AFP)
            For [F:AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD
&                          and [F:AFP1]FNC    = FCT

                ## nouvelles options
                [L]OPT = ""
                For I = 1 To len([F:AFP1]OPT)
                    For J = 0 To (CURNBR-1)
                        If mid$([F:AFP1]OPT,I,1) = CUROPT(J)
                            [L]OPT = [L]OPT + CUROPT(J)
                        Endif
                    Next J
                Next I
                [F:AFP1]OPT = [L]OPT
                Call TRI([F:AFP1]OPT) From SUBAFP2
                Rewrite [AFP1]
                If fstat
                    GOK = 0  : Call FSTA("AFP") From GLOCK : Break 2
                Endif
            Next

            # mise à jour (AFF)
            For [AFF]AFF1 Where [F:AFF]PRFCOD = [F:AFT]PRFCOD
&                         and [F:AFF]FNC    = FCT

                ## nouvelles options
                [L]OPT = ""
                For I = 1 To len([F:AFF]OPT)
                    For J = 0 To (CURNBR-1)
                        If mid$([F:AFF]OPT,I,1) = CUROPT(J)
                            [L]OPT = [L]OPT + CUROPT(J)
                        Endif
                    Next J
                Next I
                [F:AFF]OPT = [L]OPT
                Call TRI([F:AFF]OPT)
                Rewrite [AFF]
                If fstat
                    GOK = 0  : Call FSTA("AFP") From GLOCK : Break 2
                Endif
            Next
        Next
Endif
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End

#########################################################
Subprog MODIFAUZ(FCT,AUZ,CURTYP,CURNBR,CUROPT)
Value Char    FCT
Value Integer AUZ , CURTYP , CURNBR
Value Char    CUROPT()(0..)

Local Char OPT(23) , PRF(30)
Local Integer J , TRACE , OPTENA
PRF   = ""
TRACE = (GTRACE<>"" & 1=0)

OPTENA = func SUBAFP.OPT(FCT)

If AUZ <> 2

    Delete [AFP1] Where [F:AFP1]FNC = FCT
    If fstat = 1
       GOK = -1 : Call RSTA("AFF","") From GLOCK : End
    Elsif fstat
       GOK = 0  : Call FSTA("AFF") From GLOCK : End
    Endif

    Delete [AFF] Where [F:AFF]FNC = FCT & [F:AFF]FCY<>""
    If fstat = 1
       GOK = -1 : Call RSTA("AFF","") From GLOCK : End
    Elsif fstat
       GOK = 0  : Call FSTA("AFF") From GLOCK : End
    Endif

Else
    If TRACE
       Call ECR_TRACE("Contenu table AFCTFCY pour la fonction/profil"-FCT-"/"+PRF,0) From GESECRAN
       For [AFF] Where FNC=[L]FCT & PRFCOD=PRF
           Call ECR_TRACE("Site"-[F:AFF]FCY,0) From GESECRAN
       Next AFF
    Endif

    For [AFT]

            ## mise à jour AFF / AFT
            If [F:AFT]ALLFCT = 2

                # Création du site vide
                Look [AFF]AFF0 = "";[F:AFT]PRFCOD;FCT
                If fstat
                    Raz [F:AFF]
                    [F:AFF]FCY    = ""
                    [F:AFF]PRFCOD = [F:AFT]PRFCOD
                    [F:AFF]FNC    = FCT
                    [L]OPT = ""
                    If CURTYP=2 : [L]OPT = "CMS" : If OPTENA : [L]OPT += "N" : : Endif : Endif
                    For J = 0 To (CURNBR-1)
                        [L]OPT = [L]OPT  + CUROPT(J)
                    Next J
                    [F:AFF]OPT = [L]OPT
                    Call TRI([F:AFF]OPT) From SUBAFP2
                    Write [AFF]
                    If fstat
                        GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
                    Endif
                Endif

                # Les autres sites
                For [FCY]FCY0
                    Look [AFF]AFF0 = [F:FCY]FCY;[F:AFT]PRFCOD;FCT
                    If fstat
                        Raz [F:AFF]
                        [F:AFF]FCY    = [F:FCY]FCY
                        [F:AFF]PRFCOD = [F:AFT]PRFCOD
                        [F:AFF]FNC    = FCT
                        [L]OPT = ""
                        If CURTYP=2 : [L]OPT = "CMS" : If OPTENA : [L]OPT += "N" : : Endif : Endif
                        For J = 0 To (CURNBR-1)
                            [L]OPT = [L]OPT  + CUROPT(J)
                        Next J
                        [F:AFF]OPT = [L]OPT
                        Call TRI([F:AFF]OPT) From SUBAFP2
                        Write [AFF]
                        If fstat
                            GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
                        Endif
                    Endif
                Next FCY
            Else
                ## mise à jour AFF / AFP
                For [AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD and
&                                  [F:AFP1]FNC    = FCT and
&                                  [F:AFP1]ACS    = 2
                    For [FCY]FCY0
                        If TRACE & [F:AFT]PRFCOD=PRF
                          Call ECR_TRACE("Ecriture dans la table AFCTFCY fonction/profil"-FCT+"/"+PRF-":"-[F:FCY]FCY,0) From GESECRAN
                        Endif
                        Look [AFF]AFF0 = [F:FCY]FCY;[F:AFT]PRFCOD;[F:AFP1]FNC : # mb 13.10.09 bug 58672
                        If fstat
                            Raz [F:AFF]
                            [F:AFF]FCY    = [F:FCY]FCY
                            [F:AFF]PRFCOD = [F:AFP1]PRFCOD
                            [F:AFF]FNC    = [F:AFP1]FNC
                            [F:AFF]OPT    = [F:AFP1]OPT
                            Call TRI([F:AFF]OPT) From SUBAFP2
                            Write [AFF]
                            If fstat
                                GOK = 0  : Call FSTA("AFF") From GLOCK : Break 3
                            Endif
                        Endif
                    Next
                Next
            Endif

    Next  AFT

Endif
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End

#########################################################
Subprog AJOUTOPT(FCT,OPT)
Value    Char FCT
Value    Char OPT

For [AFT] Where ALLFCT = 2

        ## mise à jour
        For [AFF]AFF1 Where [F:AFF]PRFCOD = [F:AFT]PRFCOD  and [F:AFF]FNC = FCT
            [F:AFF]OPT = [F:AFF]OPT + [L]OPT
            Call TRI([F:AFF]OPT)
            Rewrite [AFF]
            If fstat
                GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
            Endif
        Next
Next
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End

#########################################################
Subprog SUPPOPT(OPT,FCT)
Variable Char OPT
Value    Char FCT

Local Char NOPT(23)

For [AFT]AFT0

        # mise à jour (AFP)
        For [F:AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD
&                      and [F:AFP1]FNC    = FCT
&                      and [F:AFP1]ACS    = 2

            ## nouvelles options
            [L]NOPT = ""
            For I = 1 To len([F:AFP1]OPT)
                If mid$([F:AFP1]OPT,I,1) <> [L]OPT
                    [L]NOPT = [L]NOPT + mid$([F:AFP1]OPT,I,1)
                Endif
            Next
            [F:AFP1]OPT = [L]NOPT
            Call TRI([F:AFP1]OPT)
            Rewrite [AFP1]
            If fstat
                GOK = 0  : Call FSTA("AFP") From GLOCK : Break 2
            Endif
        Next

        # mise à jour (AFF)
        For [AFF]AFF1 Where [F:AFF]PRFCOD = [F:AFT]PRFCOD
&                     and [F:AFF]FNC    = FCT

            ## nouvelles options
            [L]NOPT = ""
            For I = 1 To len([F:AFF]OPT)
                If mid$([F:AFF]OPT,I,1) <> [L]OPT
                    [L]NOPT = [L]NOPT + mid$([F:AFF]OPT,I,1)
                Endif
            Next
            [F:AFF]OPT = [L]NOPT
            Call TRI([F:AFF]OPT)
            Rewrite [AFF]
            If fstat
                GOK = 0  : Call FSTA("AFP") From GLOCK : Break 2
            Endif
        Next
Next
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End

##------------------------------------------------------##
##              Sous programme : Tri                    ##
##------------------------------------------------------##
Subprog TRI(C)
Variable Char C

EXIT = 0
While !EXIT
    NEXIT = 0
    For I=1 To (len(C)-1)
        If mid$(C,I,1)>mid$(C,I+1,1)
            C = mid$(C,1,I-1)+ mid$(C,I+1,1) + mid$(C,I,1) + mid$(C,I+2,len(C))
            NEXIT=1
        Endif
    Next
    If NEXIT = 1 : EXIT = 0 : Else EXIT = 1 : Endif
Wend
End
