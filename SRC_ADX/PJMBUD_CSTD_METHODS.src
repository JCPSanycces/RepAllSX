#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUD
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  SLEVEL = func AFNC.MES2(mess(940,2260,1), this.OPPNUM, this.PBUCOD)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$BUDLIG_INIT_TECH_PROP
#Value Integer LIN

  If this.BUDLIG(LIN) <> null Then
    this.BUDLIG(LIN).TCHPBUSTRDT = date$         # LSEY 01-04-2016 Budgets date not managed at the moment this.APARENT.PBUSTARTDT   this.PBUSTARTDT
    this.BUDLIG(LIN).TCHCHGTYP = this.TCHCHGTYP
  Endif
Return

###################################################################################################
$BUDLIG_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
$BUDLIG_DEL_ALL_LINES
#Value Shortint LEVEL

Local Integer NI

  If this.PBUIMP = [V]CST_AYES and this.PBUSTATE <> 3 and this.PBUSTATE <> 4 and this.PBUSTATE <> 9 Then
    For NI = 1 To maxtab(this.BUDLIG)
      If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If (LEVEL = 0) or (LEVEL > 0 and this.BUDLIG(NI).ORI = LEVEL) Then
          If this.BUDLIG(NI).PLBFLGREM = [V]CST_ANO Then
            [L]ARET_VALUE = fmet this.ADELLINE("BUDLIG", this.BUDLIG(NI).AORDER)
            If [L]ARET_VALUE = [V]CST_ANOTDEFINED Then
              Break
            Endif
          Endif
        Endif
      Endif
    Next NI
  Endif
Return

###################################################################################################
$BUDLIG_COMPUTE_MNTBUD
Local Integer NI

  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += this.BUDLIG(NI).PLBAMT
    Endif
  Next NI
Return

###################################################################################################
$BUDLIG_COMPUTE_QTYBUD
#Variable Char UOM

Local Integer NI
Local Decimal CONQTY

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      CONQTY = this.BUDLIG(NI).PLBQTY
      If this.BUDLIG(NI).PLBU <> UOM Then
        Call CONVERT_QTY(this.ACTX, this.BUDLIG(NI).PLBU, UOM, CONQTY) From TRTX3_SYRA
      Endif
      [L]ARET_VALUE += CONQTY
    Endif
  Next NI
Return

###################################################################################################
$BUDLIG_COMPUTE_MNTREMBUD
#Variable Char UOM

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      #If this.BUDLIG(NI).PLBAMTREM <> -1 Then
      If this.BUDLIG(NI).PLBFLGREM = [V]CST_ANO Then
        [L]ARET_VALUE += this.BUDLIG(NI).PLBAMTREM
      Endif
    Endif
  Next NI
Return

###################################################################################################
$BUDLIG_GET_INDEX
#Value Integer SEQNUM
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUDLIG(NI).PLBSEQ = SEQNUM Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$BUDLIG_GET_INDEX_FROM_PCCCOD
#Value Char SPCCCOD ()
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUDLIG(NI).PCCCOD = SPCCCOD Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$SPLD_INIT_TECH_PROP
#Value Integer LIN

  If this.SPLD(LIN) <> null Then
    this.SPLD(LIN).OPPCMP = this.OPPCMP
    If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.PBUFCY, "WRHFLG") = [V]CST_AYES Then
      this.SPLD(LIN).STOFCY = this.PBUFCY
    Else
      this.SPLD(LIN).STOFCY = AVOID.ACHAR
    Endif
  Endif
Return

###################################################################################################
$SPLD_DEL_ALL_LINES
#Value Integer PARORI

Local Integer NI

  If this.PBUIMP = [V]CST_AYES and this.PBUSTATE <> 3 and this.PBUSTATE <> 4 and this.PBUSTATE <> 9 Then
    For NI = 1 To maxtab(this.SPLD)
      If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL, [V]CST_ANEW) = 0 Then
        If this.SPLD(NI).ORI = PARORI and this.SPLD(NI).PSONUM = AVOID.ACHAR Then
          [L]ARET_VALUE = fmet this.ADELLINE("SPLD", this.SPLD(NI).AORDER)
          If [L]ARET_VALUE = [V]CST_ANOTDEFINED Then
            Break
          Endif
        Endif
      Endif
    Next NI
  Endif
Return

#######################################################################################
$SPLD_GET_INDEX
#Value Integer SEQNUM
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.SPLD(NI).SEQNUM = SEQNUM Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$SPLD_EXISTING
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
$COPY
#Variable Instance TARGET Using C_PJMBUD : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY
Local Integer NI
Local Integer ILINE

  # Issue X3-29531 - 2017-04-21 by FGR : BEGIN
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # -----------------------------------------------------------------
  # Copy budget lines
  If TECCLA.BLIGNES = [V]CST_AYES Then # Issue X3-71717 - 2018-05-30 by FGR : Parameter was not tested
    For NI = 1 To maxtab(this.BUDLIG)
      If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ILINE = fmet TARGET.ADDLINE("BUDLIG", [V]CST_ALASTPOS)
        If ILINE <> [V]CST_ANOTDEFINED Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUDLIG(NI).COPY(TARGET.BUDLIG(ILINE), TECCLA, TECIDX))
        Endif
      Endif
    Next NI
  Endif
  # -----------------------------------------------------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  If TECCLA.BUDGET(TECIDX).PBUFCY <> this.PBUFCY Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.BUDGET(TECIDX).PBUFCY, "PBUFCY"))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUFCY", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#fmet TECCLA.GET_BUDGET_RECODIFIED(CLAFROM.PBUPAE)", "PBUPAE"))
  #
  If TECCLA.BUDGET(TECIDX).DESTCOD <> TECCLA.BUDGET(TECIDX).PBUCOD Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#fmet TECCLA.GET_BUDGET_RECODIFIED(CLAFROM.PBUCOD)", "PBUCOD"))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUCOD", ""))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUIMP", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUSOR", AVOID.ACHAR))        # Issue X3-91329 - 2018-05-31 by FGR
  #
  If TECCLA.BUDGET(TECIDX).DESTDES = "" or TECCLA.BUDGET(TECIDX).DESTDES = this.PIMPL.PIMDESAXX Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAXX", AVOID.ACHAR, "PIMPL", "PIMDESAXX", "KEYCONCAT", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAX1", AVOID.ACHAR, "PIMPL", "PIMDESAX1", "KEYCONCAT", AVOID.ACHAR))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.BUDGET(TECIDX).DESTDES, "PIMPL.PIMDESAXX"))
  Endif
  If TECCLA.BUDDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUSTARTDT", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUENDDT", AVOID.ACHAR))
  Endif
  #Copy all descriptions
  If TECCLA.BUDDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUDESTEX", AVOID.ACHAR))
  Endif
  #Copy all comments (CLOB)
  If TECCLA.BUDCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PBUCOMTEX", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">COPY", "TCHACTION"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("KEYCONCAT", "ORIPBU"))
Return

