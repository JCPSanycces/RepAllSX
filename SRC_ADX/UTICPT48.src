#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTICPT48  KC                                              Module CPT   #
# The fields DESTRA and SHOTRA of TABBUDTYP should be created in ATEXTRA # 
# with IDENT2="" and not 0 . Init correctly these fields                 #                                                 
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Fill in IDENT2 with empty of the table ATEXTRA for the CODFIC = TABBUDTYP") From LECFIC

  Call MAJ_UTICPT48(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT48(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT48 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev ([F:AXX]) =0  Local File ATEXTRA    [AXX] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [AXX]
For [AXX]AXX1 Where CODFIC="TABBUDTYP" & ZONE="DESTRA"
   Readlock [AXX] Curr    
   If !fstat
      [F:AXX]IDENT2=""
      Rewrite [AXX]
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
For [AXX]AXX1 Where CODFIC="TABBUDTYP" & ZONE="SHOTRA"
   Readlock [AXX] Curr    
   If !fstat
      [F:AXX]IDENT2=""
      Rewrite [AXX]
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [AXX]

Call ECR_TRACE("UTICPT48 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif     
Call MAJ_UTICPT48(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif   
Call MAJ_UTICPT48(APPLI)
End

