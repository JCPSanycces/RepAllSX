#<AdxTL>@(#)6.0.0.0 $Revision$
#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer ERROR : ERROR = [V]CST_AOK
ERROR = func QRY(PSYR,ARCV,ASND,PSYR.CODREP,PSYR.CODFAC)
End ERROR


#------------------------------------------------------------------#
Funprog QRY(PSYR,ARCV,ASND,REPRES,TYPREP)
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance ASND Using C_ASYRSND
Value    Char     REPRES , TYPREP

Local Integer ERROR : ERROR = [V]CST_AOK

Local Integer     NUMLIN
Local Uuident     UIDINS
Local Char        REPNAM(20)
Local Char        PRGREP(30)
Local Integer     QCOUNT
Local Char        NAMQRY(30)               : # Name query class
Local Char        PRGQRY(30)               : # Program contains subprog base access
Local Char        TBPRO(30)(1..)           : # Name of properties of representation used in where critera
Local Char        TBFIL(30)(1..)           : # Name of properties (Abbreviation & name) of files
Local Integer     TBTYP(1..)               : # Types
Local Char        TBPTH(30)(1..)           : # path
Local Char        KEYQRY(250)              : # First key for the read
Local Char        TBORDER_PRO(250)(0..)
Local Char        TBORDER_ASCDES(250)(0..)
Local Integer     OASCEND                  : # index order

Local Char        INDEXES(250)(1..2 )      : # For indexes
Local Integer     FIRSTPAG                 : # First page of query
Local Char        QKEYS(250)(0..3)         : # Keys

Local Char        ACTION(30)               : # Action in query for interface
Local Char        CURPTH(250)              : # For hierarchy
Local Char       _AFCRIGHT(GLONAFC) : # for managmeent of right

Local Char      NODESCRIPTION(5) :#114495
Local Integer   DISP_LNKPRO: DISP_LNKPRO=2 :#114495
Local Integer     LASTPAGE

#----------------------------------------------------------------#
# Open file(s) & representation
#----------------------------------------------------------------#

# Init presentation / query
PRGQRY = func SUBASW.PREFIX_QRYTRT+REPRES : # WMQRY
NAMQRY = func SUBASW.PREFIX_REP+REPRES    : # R_
PRGREP = func SUBASW.PREFIX_TRT+REPRES    : # WMREP

Local Instance PQRY     Using C_AQUERY   : # Instance containing parameters of query (From, Order; ..)
Local Instance QRY      Using =NAMQRY    : # Instance containing datas query representation
Local Instance RQRY     Using C_AREPENT  : # Representation containing metadatas (infos about representation & properties)

# Load parameter representation
REPNAM = "QRY"

PRGREP = func SUBASW.PREFIX_TRT+REPRES : # WMREP
Call DESCRIPTION_REPRESENTATION(RQRY,REPNAM) From =PRGREP

RQRY.FCT = TYPREP
[L]_AFCRIGHT = RQRY.AFCRIGHT

# Init Instance
PQRY = NewInstance C_AQUERY AllocGroup null

#----------------------------------------------------------------#
# Decode parameters
#----------------------------------------------------------------#
Raz TBPRO,TBFIL,TBTYP,TBPTH
Gosub AQUERY_DECODE_CRITERIA From =PRGQRY

PQRY.QWHERE = func ASYRMAIN.PARVAL(ARCV,"Where")
PQRY.QORDER = func ASYRMAIN.PARVAL(ARCV,"OrderBy")
Call DECODE_QORDER(PRGQRY,PQRY,TBPRO,TBFIL,TBORDER_PRO,TBORDER_ASCDES,INDEXES) From ASYRQRY

# Lines per page
PQRY.QCOUNT = val(func ASYRMAIN.PARVAL(ARCV,"Count"))

# Start key of list
KEYQRY = func ASYRMAIN.PARVAL(ARCV,"key")
Call DECODE_KEY(PRGQRY,PQRY,KEYQRY,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBTYP,LASTPAGE) From ASYRQRY

NODESCRIPTION = func ASYRMAIN.PARVAL(ARCV,"nodescription")
If NODESCRIPTION = 'true' : DISP_LNKPRO=1 : Else : DISP_LNKPRO = 2 : Endif
#----------------------------------------------------------------#
# Prepare ASND
#----------------------------------------------------------------#
Raz QKEYS
Raz QCOUNT
Raz ASND.DATA

ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+RQRY.CLA
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRES+"."+TYPREP

#----------------------------------------------------------------#
# Select properties
#----------------------------------------------------------------#
Local Integer J,K,P,OK

Local Integer NBQT , NBPT , NBPR
Local Char    TBQT(10)(1..30) , TBPT(10)(1..30) , WCHAINE(250)
Local Char    TSTRING(250)(1..),TVALUE(250)(1..),TACTION(20)(1..),TINS(250)(1..),TPRO(30)(1..),TCOD(30)(1..)
Instance      TPATT(1..) Using C_ATTRIBUTE
Instance      PATT       Using C_ATTRIBUTE
Instance      TPAXX(1..) Using C_ATXTTRA
Instance      PAXX       Using C_ATXTTRA
Instance      TPATX(1..) Using C_ATXTSUP
Instance      PATX       Using C_ATXTSUP
Local Char    INSCLA(250)
Local Char    VRB(250)
Local Char    PROPERTY_PATH(250),PROPERTY_NAME(GLONAVB)
Local Char    PRO_AUUID(250)
Local Char    PRO_UPDDATTIM(250)
Local Datetime UPDDATTIM

Local Char WARRAY(250)(1..)
Local Integer NBPRO



PROPERTY_PATH = func ASYRDATDET.PATH_PROPERTY("QRY",RQRY.ICL)

PRO_AUUID     = 'QRY.' + PROPERTY_PATH + '.AUUID'
PRO_UPDDATTIM = 'QRY.' + PROPERTY_PATH + '.UPDDATTIM'

#values
For P=1 To maxtab(RQRY.PRO)
 #If len(RQRY.PRO(P).PRO) > 0 & RQRY.PRO(P).REP=RQRY.REP & RQRY.PRO(P).QRY=2 & RQRY.FCT="$query"
 If len(RQRY.PRO(P).PRO) > 0 & RQRY.PRO(P).REP=RQRY.REP & RQRY.PRO(P).QRY=2
  INSCLA        = func ASYRDATDET.INSTANCE_CLASS(RQRY.PRO(P).TPC,"QRY","QRY."+RQRY.PRO(P).PTH)
  NBPR += 1 :
  TSTRING(NBPR)   = ',"' + RQRY.PRO(P).PRO + '":'

  TVALUE(NBPR) = "QRY."+RQRY.PRO(P).PTH
  NBPRO = func ASYRSUB.SPLIT(WARRAY,RQRY.PRO(P).PTH,".")  : # 112973
  Case RQRY.PRO(P).TYP
   When 1       : TACTION(NBPR) = "APPEND_BOOLEAN"
   When 2,3,4   : TACTION(NBPR) = "APPEND_NUMBER"
   When 5       : TACTION(NBPR) = "APPEND_DATE"
   When 6       : TACTION(NBPR) = "APPEND_TIME"
   When 7       : TACTION(NBPR) = "APPEND_STRING"
   When 25      : TACTION(NBPR) = "APPEND_ATXTSUP"
    TINS(NBPR)    = INSCLA
    TPRO(NBPR)    = WARRAY(NBPRO) : # RQRY.PRO(P).PRO : # 112973
   When 26      : TACTION(NBPR) = "APPEND_ATXTTRA"
    TINS(NBPR)    = INSCLA
    TPRO(NBPR)    =WARRAY(NBPRO) : # RQRY.PRO(P).PRO : # 112973
   When 8,9     : TACTION(NBPR) = "APPEND_EMPTY"
   When 10      : TACTION(NBPR) = "APPEND_COMBO"
   When 11      : TACTION(NBPR) = "APPEND_DATETIME"
   When Default : TACTION(NBPR) = "APPEND_EMPTY"
  Endcase

  If RQRY.PRO(P).PLK=2
   NBPR += 1 :
   TSTRING(NBPR)   = ',"' + RQRY.PRO(P).PRO + '_REF":{'
   TACTION(NBPR) = "APPEND_REF"
   TINS(NBPR)       = INSCLA
   TPRO(NBPR)    = WARRAY(NBPRO) : # RQRY.PRO(P).PRO  : # 112973
  Endif
 Endif
Next P

#----------------------------------------------------------------#
# Open table : Local File XXX
#----------------------------------------------------------------#
Gosub AQUERY_OPEN From =PRGQRY

#----------------------------------------------------------------#
#  Criteria of class
#----------------------------------------------------------------#
# Call action "SELECT" to complete the criteria
Gosub AQUERY_CRITERIA From =PRGQRY

#----------------------------------------------------------------#
# Open link
#----------------------------------------------------------------#
Gosub AQUERY_JOIN From =PRGQRY

If !clalev([LNK_]) : Goto ERR_DETAIL : Endif

Gosub AQUERY_CREATEINSTANCE From =PRGQRY


#----------------------------------------------------------------#
# Read data
#----------------------------------------------------------------#
Local Date    DVALUE
Local Clbfile SVALUE
Local Char    TEMP(250)

Local Integer POS,I
Local Integer STRINGTYPE

If PQRY.QWHERE="" : PQRY.QWHERE = "1 eq 1" : Endif
Filter [LNK_] Where evalueSData(PQRY.QWHERE,TBPRO,TBFIL) Order With INDEXES(PQRY.QASCEND)

ASND.MODE = 1 : # 1 = First
Append ASND.DATA, '{"$resources":['
Append ASND.DATA, chr$(10)
For [LNK_]
 QCOUNT += 1

 Gosub AQUERY_SETINSTANCE From =PRGQRY
 If DISP_LNKPRO = 2  : Gosub AQUERY_LNKPRO_INSTANCE  From =PRGQRY : Endif  :#114495
 If  [L]ASTATUS <> [V]CST_AERROR
  If QCOUNT > 1
   Append ASND.DATA, ","
   Append ASND.DATA, chr$(10)
  Endif
  Append ASND.DATA ,'{"$uuid":"'
  Append ASND.DATA, num$(evalue(PRO_AUUID))
  Append ASND.DATA, '","$etag":"'
  Onerrgo ERROR_UPDDATTIM
  UPDDATTIM = evalue(PRO_UPDDATTIM)
  Onerrgo
  Append ASND.DATA, num$(UPDDATTIM)
  Append ASND.DATA, '"'

  Onerrgo ERROR_VALUE
  For P=1 To NBPR
   Raz SVALUE
   Append ASND.DATA, TSTRING(P)
   Case TACTION(P)
    When "APPEND_ATXTSUP"
     STRINGTYPE = 1
     If TPATX(P) <> null
      SVALUE = TPATX(P).TEX
     Else
      For A=1 To evalue("maxtab("+TINS(P)+".ATX)")
       PATX = evalue(TINS(P)+".ATX("+num$(A)+")")
       If TPRO(P) = PATX.PRO & GACTX.LAN = PATX.LAN
        TPATX(P) = PATX
        SVALUE   = TPATX(P).TEX
        Break
       Endif
      Next A
      If TPATX(P) = null
       For A=1 To evalue("maxtab("+TINS(P)+".ATX)")
        PATX = evalue(TINS(P)+".ATX("+num$(A)+")")
        If TPRO(P) = PATX.PRO & GACTX.AFOLD.ALANGDEF = PATX.LAN
         TPATX(P) = PATX
         SVALUE   = TPATX(P).TEX
         Break
        Endif
       Next A
      Endif
     Endif
    When "APPEND_ATXTTRA"
     STRINGTYPE = 1
     If TPAXX(P) <> null
      SVALUE = TPAXX(P).TEX
     Else
      For A=1 To evalue("maxtab("+TINS(P)+".AXX)")
       PAXX = evalue(TINS(P)+".AXX("+num$(A)+")")
       If TPRO(P) = PAXX.PRO & GACTX.LAN = PAXX.LAN
        TPAXX(P) = PAXX
        SVALUE   = TPAXX(P).TEX
        Break
       Endif
      Next A
      If TPAXX(P) = null
       For A=1 To evalue("maxtab("+TINS(P)+".AXX)")
        PAXX = evalue(TINS(P)+".AXX("+num$(A)+")")
        If TPRO(P) = PAXX.PRO & GACTX.AFOLD.ALANGDEF = PAXX.LAN
         TPAXX(P) = PAXX
         SVALUE   = TPAXX(P).TEX
         Break
        Endif
       Next A
      Endif
     Endif
    When "APPEND_STRING":
     VRB = TVALUE(P)
     SVALUE     = num$(evalue(VRB))
     STRINGTYPE = 1
    When "APPEND_BOOLEAN"
     VRB = TVALUE(P)
     If evalue(VRB) = 2
      SVALUE = "true"
     Else
      SVALUE= "false"
     Endif
     STRINGTYPE = 2
    When "APPEND_NUMBER"
     VRB = TVALUE(P)
     SVALUE     = num$(evalue(VRB))
     STRINGTYPE = 2
    When "APPEND_DATE"
     VRB = TVALUE(P)
     DVALUE = evalue(VRB)
     If DVALUE  = [0/0/0]
      SVALUE = 'null'
     Else
      TEMP   = DVALUE
      SVALUE = '"'+  left$(TEMP,4) + '-' + mid$(TEMP,5,2) + '-' + right$(TEMP,7) + '"'
     Endif
     STRINGTYPE = 2
    When "APPEND_TIME"
     VRB = TVALUE(P)
     SVALUE = evalue(VRB)
     Case len(SVALUE)
      When 0,1,2,3,4
       TEMP    = right$(num$(10000+val(SVALUE)),2)
       SVALUE  = '"'+left$(TEMP,2)+":"+right$(TEMP,3)+'"'
      When 5,6
       TEMP    = right$(num$(1000000+val(SVALUE)),2)
       SVALUE  = '"'+left$(TEMP,2)+":"+mid$(TEMP,3,2)+":"+right$(TEMP,5)+ '"'
      When Default
       SVALUE = '"00:00:00"'
     Endcase
     STRINGTYPE = 2
    When "APPEND_DATETIME"
     VRB = TVALUE(P)
     SVALUE = '"'+num$(evalue(VRB))+'"'
     STRINGTYPE = 2
    When "APPEND_EMPTY"
     SVALUE = "{}"
     STRINGTYPE = 2
    When "APPEND_ATTRIBUTE"

     If TPATT(P) <> null

      SVALUE = TPATT(P).ATT
      STRINGTYPE = 1
     Else
      STRINGTYPE = 0
      For A=1 To evalue("maxtab("+TINS(P)+".ATT)")
       PATT = evalue(TINS(P)+".ATT("+num$(A)+")")
       If TPRO(P) = PATT.PRO & TCOD(P) = PATT.COD
        TPATT(P) = PATT
        SVALUE = TPATT(P).ATT
        STRINGTYPE = 1
        Break
       Endif
      Next A
     Endif
    When "DO_NOTHING"
     STRINGTYPE = 0
    When "APPEND_REF":
     STRINGTYPE = 2
     SVALUE  = '"$title":"'
     SVALUE +=escJson(evalue('fmet '+ TINS(P)+'.AGETATTRIBUTE("'+TPRO(P)+'","$title")'))
     SVALUE +='","$description":"'
     SVALUE +=escJson(evalue('fmet '+ TINS(P)+'.AGETATTRIBUTE("'+TPRO(P)+'","$description")'))
     SVALUE +='"}'
    When "APPEND_COMBO"
     VRB = TVALUE(P)
     SVALUE =  num$(max(val(num$(evalue(VRB))),1))
     STRINGTYPE = 2
   Endcase

   If STRINGTYPE = 1
     If len(SVALUE) =0
      Append ASND.DATA, '""'
     Else
      Append ASND.DATA, '"'
      Append ASND.DATA, escJson(SVALUE)
      Append ASND.DATA, '"'
     Endif
   Elsif STRINGTYPE = 2
     Append ASND.DATA, SVALUE
   Endif
  Next P

  Append ASND.DATA ,"}"

  If QCOUNT= PQRY.QCOUNT
   Break
  Endif

  If mod(QCOUNT,100) = 0
   Call SYRSND(ASND) From ASYRCOM
  Endif
 Else
  QCOUNT -= 1
 Endif
Next LNK_
Append ASND.DATA, "]}"



Onerrgo
Filter [LNK_]

Gosub AQUERY_CLOSE From =PRGQRY

If ASND.MODE = 1
 ASND.MODE = 0
Else
 ASND.MODE = 3 : # 3 = Last
Endif

FreeGroup PQRY
FreeGroup RQRY

End ERROR

#----------------------------------------------------------------#
# Error response
#----------------------------------------------------------------#

$ERR_DETAIL
If PQRY<>null : FreeGroup PQRY : Endif
If RQRY<>null : FreeGroup RQRY : Endif
End ERROR


#---------------------------#
$ERROR_VALUE
SVALUE ='"'+"'{"+TVALUE(P)+"}'"+'<error'-errmes$(errn)+'>"'
Resume

$ERROR_UPDDATTIM
UPDDATTIM = datetime$
Resume

