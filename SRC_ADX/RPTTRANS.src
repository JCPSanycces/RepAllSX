#<AdxTL>@(#)12.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#########################################################################################################
# lancement de rpttrans (rpttrans.bat sous ebin du poste client)
# traduction des etats avec moulinette rpttrans
# s'appuie sur table ATEXTE - ATEXTEXCEP et ARPTTRANS
# ATEXTEXCEP table des doublons
# ARPTTRANS  table des erreurs
#####################################
Call RPTTRANS
End

Subprog RPTTRANS
If filinfo (filpath("FIL","ATEXTEXCEP","fde",nomap),0) < 0 : End : Endif
If filinfo (filpath("FIL","ARPTTRANS","fde",nomap),0) < 0 : End : Endif


# les rpt doivent se trouver sous <posteclient>\rts\rpttrans
# on regarde si le repertoire existe
If filinfo(filpath("!","","","","","#")+"\rpttrans",0)<0
    Errbox "Le répertoire rpttrans doit exister dans le répertoire client"-filpath("!","","","","","#")
    End
Endif
Local Char WCHEMIN (250)
WCHEMIN = filpath("!","","","","","#")

# on enleve les deux premiers caracteres
WCHEMIN = right$(WCHEMIN,3)
Local File ARPTTRANS  [ZZZ]
Local File ATEXTEXCEP [ZAA]

# on supprime le contenu du fichier des erreurs
Trbegin [ZZZ]
Delete [ZZZ] Where 1=1
Commit


# on lance le rpttrans  présent en local 
# mais avant on regarde si ce fichier de commande existe.
# les rpt doivent se trouver sous <posteclient>\rts\rpttrans
# -------------arguments a passer au rpttrans.bat
# rem # %1 C:\X3140\RTS\rpttrans
# rem # %2 FRA
# rem # %3 SPA
# rem %4 S-
# rem %5 DSN=DV140;UID=GX3APP;PWD=tiger
# -------------------

Local Shortint WNUMERO
Local Char OS(250)(1..10)
Local Char WSERVEUR 
System OS="#@rpttrans"

# une fois que la moulinette est faite. .. on enregistre les doublons dans ATEXTEXECPT
# 
# lecture dernier enreg pour recup numero 
Filter [ZAA] Where LAN = [F:ZZZ]LAN
Read [ZAA] Last
If fstat <> 0 : [F:ZAA]NUMERO = 0 : Endif
WNUMERO = [F:ZAA]NUMERO
Filter [ZAA]

#
#
#
Filter [ZZZ] Where TYP = 2
For [ZZZ]
    Read [ZAA]AEX1=[F:ZZZ]NAMREP;[F:ZZZ]DESREP;[F:ZZZ]SUBREP;[F:ZZZ]SECREP;[F:ZZZ]OBJREP;[F:ZZZ]LAN
    If fstat <> 0
         [F:ZAA] = [F:ZZZ]
         WNUMERO +=1
         [F:ZAA]NUMERO = WNUMERO
         Write [ZAA]
    Endif
Next
Filter [ZZZ]


Trbegin [ZZZ]
Delete [ZZZ] Where TYP=2
Commit


Close Local File
End
