##########################################################################################################
#  Consultation des secteur de marchés et du hors secteur              Module CRM      14 janvier 2002   #
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "FIR"          : Gosub PREMIER
 When "PRE"          : Gosub PRECEDENT
 When "SUI"          : Gosub SUIVANT
 When "LAS"          : Gosub DERNIER
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
#Global Char GSZMST7SCT
#Global Char GSZMST7LIS
#PARAM(1) = Code secteur de marché
#PARAM(2) = Ouverture pour une liste Tiers ou Interlocuteur (BPR ou CCN)
#GSZMST7SCT = PARAM(1)
#GSZMST7LIS = PARAM(2)

#If GSZMST7SCT = "" : End : Endif
#If GSZMST7LIS = "" : End : Endif

If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
Return

##########################################################################################################
$DEBUT
If PARAM(1)<>""
    [M:MST7]SCTNUM =PARAM(1)
    Gosub DISPMST7
Endif

Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return



##########################################################################################################
$PREMIER
Local Char SZREC2
Local Char SZADD2
If [M:MST7]TOTADD <= dim([M:MST7]BPRCCNNUM) : Return : Endif
SZREC2 = ""
SZADD2 = ""
Call LOADBPR(1,[M:MST7]SCTNUM, SZREC2, SZADD2)
Affzo [M:MST7]1-99

Return

##########################################################################################################
$PRECEDENT
Local Char SZREC3
Local Char SZADD3
If [M:MST7]TOTADD <= dim([M:MST7]BPRCCNNUM) : Return : Endif
SZREC3 = [M:MST7]BPRCCNNUM(0)
SZADD3 = [M:MST7]BPAADD(0)
Call LOADBPR(2,[M:MST7]SCTNUM, SZREC3, SZADD3)
Affzo [M:MST7]1-99

Return

##########################################################################################################
$SUIVANT
Local Char SZREC4
Local Char SZADD4
If [M:MST7]TOTADD <= dim([M:MST7]BPRCCNNUM) : Return : Endif
If [M:MST7]NBASS <= 0
    SZREC4 = ""
    SZADD4 = ""
Else
    SZREC4 = [M:MST7]BPRCCNNUM([M:MST7]NBASS - 1)
    SZADD4 = [M:MST7]BPAADD([M:MST7]NBASS - 1)
Endif
Call LOADBPR(3,[M:MST7]SCTNUM, SZREC4, SZADD4)
Affzo [M:MST7]1-99

Return

##########################################################################################################
$DERNIER
Local Char SZREC5
Local Char SZADD5
If [M:MST7]TOTADD <= dim([M:MST7]BPRCCNNUM) : Return : Endif
SZREC5 = ""
SZADD5 = ""
Call LOADBPR(4,[M:MST7]SCTNUM, SZREC5, SZADD5)
Affzo [M:MST7]1-99

Return


##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:MST7]
#Kill GSZMST7SCT
#Kill GSZMST7LIS
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Case BOUT
    When "A"
        If [M:MST7]SCTNUM=""
            #Il faut préciser un secteur de marché.
            GMESSAGE=mess(591,177,1)
            GERR=2
            Return
        Endif
        Call ONPREVSCT
    When "B"
        If [M:MST7]SCTNUM=""
            #Il faut préciser un secteur de marché.
            GMESSAGE=mess(591,177,1)
            GERR=2
            Return
        Endif

        Call ONNEXTSCT
    When Default
Endcase

Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
#
#  ONPREVSCT : Gestion du bouton Secteur précédent
#  ONNEXTSCT : Gestion du bouton Secteur suivant
#  DISPMST7  : Ouvre la fenêtre pour un secteur donné
#  LOADBPR   : Charge le tableau avec des enregistrements Tiers
#  COUNTREC  : Calcul le nombre de sites tiers ou d'interlocuteurs dans un secteur de marché
#
########################################################################################################

##########################################################################################################
#  ONPREVSCT : Gestion du bouton Secteur précédent
#######################################################################
Subprog ONPREVSCT
Local Char SZPRESCT
Raz SZPRESCT
#SZPRESCT = GSZMST7SCT

Filter [MST] Where [F:MST]MARSCTNUM < [M:MST7]SCTNUM Order By [F:MST]MARSCTNUM Desc

For [MST]
    SZPRESCT= [F:MST]MARSCTNUM
    Break
Next

Filter [MST]

If [M:MST7]SCTNUM= SZPRESCT or SZPRESCT=""
    GMESSAGE = mess(11,100,1) #Début/Fin de fichier
    GERR = 3
Else
    [M:MST7]SCTNUM=SZPRESCT
#    Raz [M:MST7]
    Gosub DISPMST7
Endif

End

##########################################################################################################
#  ONNEXTSCT : Gestion du bouton Secteur suivant
#######################################################################
Subprog ONNEXTSCT
Local Char SZPRESCT
Raz SZPRESCT
#SZPRESCT = GSZMST7SCT

Filter [MST] Where [F:MST]MARSCTNUM > [M:MST7]SCTNUM Order By [F:MST]MARSCTNUM

For [MST]
    SZPRESCT= [F:MST]MARSCTNUM
    Break
Next

Filter [MST]

If [M:MST7]SCTNUM = SZPRESCT or SZPRESCT =""
    GMESSAGE = mess(11,100,1) #Début/Fin de fichier
    GERR = 3
Else
    #Raz [M:MST7]
    [M:MST7]SCTNUM=SZPRESCT
    Gosub DISPMST7
Endif

End

##########################################################################################################
#  Ouvre la fenêtre pour un secteur donné
#######################################################################
$DISPMST7
Local Integer INBREC
Local Char SZREC1
Local Char SZADD1
INBREC = 0
SZREC1 = ""
SZADD1 = ""

Call TEMPON("R") From GESECRAN

#If GSZMST7LIS = "BPR"
    [M:MST7]LISTYP = mess(538, 196, 2) #Liste des sites tiers
    [M:MST7]TOTTIT = mess(540, 196, 2) #Nombre de sites tiers dans le secteur
    #Calcul le nombre de sites tiers dans le secteur
#    Call COUNTREC(GSZMST7SCT, "BPR", INBREC)
Call COUNTREC([M:MST7]SCTNUM, INBREC)
Call LOADBPR(0,[M:MST7]SCTNUM, SZREC1, SZADD1)
#Elsif GSZMST7LIS = "CCN"
#    [M:MST7]LISTYP = mess(539, 196, 2) #Liste des interlocuteurs
#    [M:MST7]TOTTIT = mess(541, 196, 2) #Nombre d'interlocuteurs dans le secteur
#    #Calcul le nombre d'interlocuteurs dans le secteur
#    Call COUNTREC(GSZMST7SCT, "CCN", INBREC)
#Endif
#
#[M:MST7]SCTNUM = GSZMST7SCT
[M:MST7]TOTADD = INBREC

Call TEMPOFF From GESECRAN
Affzo [M:MST7]1-99
Return

##########################################################################################################
# Charge le tableau avec des enregistrements Tiers
#######################################################################
Subprog LOADBPR(ITRAITEMENT, SZSECTEUR,SZREC, SZADD)
Value Integer ITRAITEMENT
Value Char SZSECTEUR
Value Char SZREC
Value Char SZADD

Local Integer ITER
Local Integer INBDISP
INBDISP = 0
#0 : Premier chargement
#1 : Premier
#2 : Précédent
#3 : Suivant
#4 : Dernier

Case ITRAITEMENT
    When 0
        Call RAZ_TAB_NBASS
        Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR Order By [F:MAD]RECORDNUM Asc; [F:MAD]RECORDADD Asc
        ITER = 0
        Gosub LOADWITHF

    When 1
        Call RAZ_TAB_NBASS
        Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR Order By [F:MAD]RECORDNUM Asc; [F:MAD]RECORDADD Asc
        ITER = 0
        Gosub LOADWITHF

    When 2
        Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR Order By Key MAD0 Desc
        Gosub LOADWITHR

    When 3
        Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR Order By Key MAD0 Asc
        Gosub LOADWITHR

    When 4
        Call RAZ_TAB_NBASS
        Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR Order By [F:MAD]RECORDNUM Desc; [F:MAD]RECORDADD Desc
        ITER = dim([M:MST7]BPRCCNNUM) - 1
        Gosub LOADWITHF
    When Default
Endcase

Filter [MAD]

[M:MST7]NBASS = INBDISP
End

##########################################################################################################
# Charge le tableau avec une boucle For
#############################################################################
$LOADWITHF
INBDISP = 0
For [MAD]
    If ITRAITEMENT= 0
        If ITER >= dim([M:MST7]BPRCCNNUM) : Break : Endif
    Elsif ITRAITEMENT= 1
        If ITER >= dim([M:MST7]BPRCCNNUM) : Break : Endif
    Elsif ITRAITEMENT= 4
        If ITER < 0 : Break : Endif
    Endif

    Gosub SETLINE

    If ITRAITEMENT= 0
        ITER += 1
    Elsif ITRAITEMENT= 1
        ITER += 1
    Elsif ITRAITEMENT= 4
        ITER -= 1
    Endif
    INBDISP += 1
Next

Return

##########################################################################################################
# Charge le tableau avec un des Read Next
#############################################################################
$LOADWITHR
Local Integer IGOBACK
Local Integer INBRECPREV
IGOBACK = 0
INBRECPREV = 0

Read [MAD] MAD0 = SZREC;SZADD;"BPR"
If fstat
    Return
Else
    If ITRAITEMENT= 2      #Précédent
        #On calcule le nombre d'enregistrements précédents
        INBRECPREV = 0
        While INBRECPREV < dim([M:MST7]BPRCCNNUM)
            Read [MAD] Next
            If fstat
                If !INBRECPREV
                    IGOBACK = 1
                Endif
                Break
            Else
                INBRECPREV += 1
            Endif
        Wend

    Elsif ITRAITEMENT= 3   #Suivant
        #On vérifie s'il y a au moins un enregistrement suivant
        Read [MAD] Next
        If fstat
            IGOBACK = 1
        Endif
    Endif

    #Il n'y a rien avant ou après. On s'en va
    If IGOBACK
        INBDISP = [M:MST7]NBASS
        Return
    Endif

    #Il y des choses à afficher
    Call RAZ_TAB_NBASS
    Read [MAD] MAD0 = SZREC;SZADD;"BPR"
    If !fstat
        If ITRAITEMENT= 2
            ITER = INBRECPREV - 1
        Elsif ITRAITEMENT= 3
            ITER = 0
        Endif

        INBDISP = 0
        While 1
            Read [MAD] Next
            If fstat
                Break
            Else
                If ITRAITEMENT= 2
                    If ITER < 0 : Break : Endif
                Elsif ITRAITEMENT= 3
                    If ITER >= dim([M:MST7]BPRCCNNUM) : Break : Endif
                Endif

                Gosub SETLINE

                If ITRAITEMENT= 2
                    ITER -= 1
                Elsif ITRAITEMENT= 3
                    ITER += 1
                Endif
                INBDISP += 1
            Endif
        Wend
    Endif
Endif
Return

##########################################################################################################
# Renseigne une ligne du tableau
###############################################################################
$SETLINE
[M:MST7]BPRCCNNUM(ITER) = [F:MAD]RECORDNUM
Read [BPC] BPC0 = [M:MST7]BPRCCNNUM(ITER)
If fstat
    [M:MST7]BPRCCNNAM(ITER) = [M:MST7]BPRCCNNUM(ITER)
Else
    [M:MST7]BPRCCNNAM(ITER) = [F:BPC]BPCNAM
    [M:MST7]REPNUM(ITER) = [F:BPC]REP(0)
    If [M:MST7]REPNUM(ITER) = ""
        [M:MST7]REPNAM(ITER) = ""
    Else
        Read [REP] REP0 = [M:MST7]REPNUM(ITER)
        If !fstat
            [M:MST7]REPNAM(ITER) = [F:REP]REPNAM
        Endif
    Endif
Endif
[M:MST7]BPAADD(ITER) = [F:MAD]RECORDADD
Read [BPA] BPA0 = 1;[M:MST7]BPRCCNNUM(ITER);[F:MAD]RECORDADD
If !fstat
    [M:MST7]ADDRESS(ITER) = [F:BPA]BPAADDLIG(0)
    [M:MST7]POSCOD(ITER) = [F:BPA]POSCOD
    [M:MST7]CTY(ITER) = [F:BPA]CTY
    [M:MST7]SAT(ITER) = [F:BPA]SAT
    [M:MST7]CRY(ITER) = [F:BPA]CRY
    [M:MST7]TEL(ITER) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
    [M:MST7]WEB(ITER) = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
Endif
[M:MST7]RECTYP(ITER) = [F:MAD]RECORDTYP
Return

##########################################################################################################
# Calcul le nombre de sites tiers dans un secteur de marché
################################################################################
#Subprog COUNTREC(SZSCT, SZTYP, ICOUNT)
Subprog COUNTREC(SZSECTEUR, ICOUNT)
Value Char SZSECTEUR
#Value Char SZTYP
Variable Integer ICOUNT

ICOUNT = 0

Filter [MAD] Where [F:MAD]MARSCTNUM = SZSECTEUR and [F:MAD]RECORDTYP = "BPR"
#&            Order By [F:MAD]MARSCTNUM Asc; [F:MAD]RECORDTYP Asc

#For [MAD]
#    ICOUNT += 1
#Next

ICOUNT=rowcount([MAD])
Filter [MAD]

End

##########################################################################################################
# Efface le contenu du tableau
################################################################################
Subprog RAZ_TAB_NBASS

Raz [M:MST7]BPRCCNNUM
Raz [M:MST7]BPRCCNNAM
Raz [M:MST7]BPAADD
Raz [M:MST7]ADDRESS
Raz [M:MST7]POSCOD
Raz [M:MST7]CTY
Raz [M:MST7]SAT
Raz [M:MST7]CRY
Raz [M:MST7]TEL
Raz [M:MST7]WEB
Raz [M:MST7]REPNAM
Raz [M:MST7]REPNUM
Raz [M:MST7]RECTYP
[M:MST7]NBASS = 0

End

