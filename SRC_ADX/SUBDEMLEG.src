############################################################
#
# Library of Legislation procedures for Training period screens
#
# Window  : ODEM
# Screens : DEM1,DEM3
#
############################################################


########################################
#21/05/12 - SBA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK
# 3 fields to hide if GCURLEG<>FRA
#block with 2 fields to hide if GCURLEG<>FRA
If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "DEM1"
Case GCURLEG
When "FRA" :
      WSIGN=""
      WDISPBLCK=1
When Default:
      WSIGN="-"
      WDISPBLCK=0
Endcase

# name block
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(4))
Endif
Chgtbk [M:DEM1]20  With WNAMEBLCK
# fields CATFRT=CATTRG in STG
Chgfmt [M:DEM1]DESNATFIS With WSIGN+"LA:10452"  #DESNATFIS = NATFIS in STG
Chgfmt [M:DEM1]DESCATACN With WSIGN+"LA:10453"  #DESCATACN = CATACN in STG
Chgfmt [M:DEM3]DESTYPFRT With WSIGN+"LA:10455"
Chgfmt [M:DEM3]CATFRT    With WSIGN+"K:20BX"     #CATFRT=CATTRG in STG
If WSIGN=""
  Affzo [M:DEM1]20
Else
  Raz [M:DEM1]DESNATFIS    #DESNATFIS = NATFIS in STG
  Raz [M:DEM1]DESCATACN    #DESCATACN = CATACN in STG
  Raz [M:DEM3]DESTYPFRT
  Raz [M:DEM3]CATFRT       #CATFRT=CATTRG in STG
Endif
End

