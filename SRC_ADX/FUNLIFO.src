############################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Effzo [M:DIA]20
Filter [FCY] Where LEGCPY = VALEUR &
&                  WRHFLG = 2
&            Order By Key FCY1
For [FCY]
  If [M:DIA]NBLIG < dim([M:DIA]SELFLG)-1
    [M:DIA]SELFLG([M:DIA]NBLIG)   = 1
    [M:DIA]STOFCY([M:DIA]NBLIG)   = [F:FCY]FCY
    [M:DIA]FCYNAM([M:DIA]NBLIG)   = [F:FCY]FCYNAM
    [M:DIA]NBLIG += 1
  Else 
    Break
  Endif
Next 
Filter [FCY]
Affzo [M:DIA]20
End
############################################################
Subprog C_SELFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Local Char    WFCY(GLONFCY)   : WFCY = [M:DIA]STOFCY(nolign-1)
  Local Integer WYEA            : WYEA = year([M:DIA]IPTDATEND)
  Local Integer WMON            : WMON = month([M:DIA]IPTDATEND)
  Local Integer WRET
If 0
  Filter [ITH] Where STOFCY = WFCY &
&                    YEA    = WYEA &
&                    MON    = WMON 
&              Order By Key ITH1
  WRET = 0
  For [ITH]
    WRET = 1
    Break
  Next
  Filter [ITH]
  If WRET = 0
    VALEUR = 1
#    mkstat = 2
    Call ERREUR(WFCY-mess(26,131,1)+"\("+num$(WMON)-num$(WYEA)+")") From GESECRAN
    End
  Endif  
Endif

# Contrôle année déja traitée
  If [M:DIA]SIMFLG <> 2
    Filter [SLI] Where STOFCY = WFCY       &
&                      YEA    = [M:DIA]YEA
&                Order By Key SLI1
    WRET = 0
    For [SLI]
      WRET = 1
      Break
    Next
    Filter [SLI]  
    If WRET <> 0
      WRET = 1
      Call AVERTIR(WFCY-mess(24,131,1),WRET) From GESECRAN
      If WRET = 1
         VALEUR = 1
         mkstat = 2
         End
      Endif
    Endif
  Endif
Endif
End
