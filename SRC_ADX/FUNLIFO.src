#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque STOCKLIFO
#CHECK UNUSED_SOURCE
############################################################
# Valorisation des stocks LIFO Localisation ITALIE
############################################################
# Traitement 130 non adapté 140 - Pas de réponse de l'Italie
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH_LIFO
  When "CONT_BATCH"     : Gosub CONTROLE_LIFO
  When "INIT"           : Gosub INIT_LIFO
  When "CONTROLE"       : Gosub CONTROLE_LIFO
  When "EXEC"           : Gosub EXEC_LIFO
  When "TERMINE"        : Gosub TERMINE_LIFO
  When "INIT_DIA"       : Gosub INIT_DIA_LIFO
  When "OK"             : Gosub OK_LIFO
  When "END"            : Gosub END_LIFO
Endcase
Return
#############################################################
$OUVRE_BATCH_LIFO
Gosub OPEN_FILE
Gosub ALLO_VARIABLES
Return
#############################################################
$INIT_LIFO
Gosub OPEN_FILE
Gosub ALLO_VARIABLES
Return
#############################################################
$CONTROLE_LIFO
If [M:DIA]SIMFLG = 2
  WTXT = mess(123,188,1)-mess(23,131,1)-num$(date$)-time$
Else
  WTXT = mess(23,131,1)-num$(date$)-time$
Endif
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(WTXT,0) From GESECRAN
  Return
Else 
  Call OUVRE_TRACE(WTXT) From LECFIC
Endif
# 
If !find(2,[M:DIA]SELFLG(0..[M:DIA]NBLIG-1))
  GERR     = 1
  GMESSAGE = mess(27,131,1)
  FIN      = 1
  Goto CONTROLE_LIFO_FIN 
Else
  If [M:DIA]PROFLG = 2
    If [M:DIA]SIMFLG = 2
      GMESSAGE = WINTSIM-WINTPRO
    Else
      GMESSAGE = WINTPRO
    Endif
    If [M:DIA]PRTFLG = 2
      GMESSAGE += "\"+WINTPRT
    Endif
  Else
    If [M:DIA]PRTFLG = 2
      GMESSAGE = WINTPRT
    Endif
  Endif
  GMESSAGE += "\"+mess(29,131,1)+"\"
  For IFCY = 0 To [M:DIA]NBLIG -1
    If [M:DIA]SELFLG(IFCY) = 2
      GMESSAGE += [M:DIA]STOFCY(IFCY)+" "
    Endif
  Next IFCY
  WRET = 2
  Call AVERTIR(GMESSAGE,WRET) From GESECRAN
  If WRET = 1
    GMESSAGE = ""
    FIN = 1
    Goto CONTROLE_LIFO_FIN
  Endif 
Endif
Call PRTSCR("STOCKLIFO","DIA","",0,1) From ATRTX3
$CONTROLE_LIFO_FIN
Return
#############################################################
$EXEC_LIFO
#
If [M:DIA]CPY <> ""
  WSYM = GFONCTION+[M:DIA]CPY
  Lock =WSYM
  If fstat
    GMESSAGE = [M:DIA]CPY+" : "+mess(25,131,1)
    If !GSERVEUR 
      GERR = 1
      FIN  = 1
    Else
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Endif
    Return
  Endif
#
  Call TEMPON("O") From GESECRAN
  If [M:DIA]PROFLG = 2
    For IFCY = 0 To [M:DIA]NBLIG -1
      If [M:DIA]SELFLG(IFCY) = 2
        WFCY = [M:DIA]STOFCY(IFCY)
        Call GETDEV(WFCY) From DEVSUB
        Gosub TRT_CALCUL
      Endif
    Next IFCY
  Endif
  If [M:DIA]PRTFLG = 2
    Gosub TRT_PRT
  Endif 
  Call TEMPOFF From GESECRAN
  Unlock =WSYM
Endif    
Return
#############################################################
$TERMINE_LIFO
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_LIFO
Raz [M:DIA]
Return
#############################################################
$OK_LIFO
FIN  = 1
Return
#############################################################
$END_LIFO
Raz [M:DIA]
FIN = 1
Return
#############################################################
$TRT_CALCUL
# Contrôle présence historique fin de mois
Call ECR_TRACE(mess(28,131,1)-WFCY-"("+num$([M:DIA]YEA)+")",0) From GESECRAN
Gosub PUR_SLI
Gosub GEN_FILTRES
If [M:DIA]SIMFLG <> 2
  WCOM = 0
  Trbegin [SLI]
  GOK  = 1
Endif
# Début traitement
Filter [ITF] Where evalue(WFILITF)
&                  Order By Key ITF1
#
For [ITF]
  Read [ITM]ITM0=[F:ITF]ITMREF
  If fstat = 0 
#    Read [ITH]ITH0=[F:ITF]ITMREF;[F:ITF]STOFCY;WYEA;WMON
#    If fstat = 0
#      WSTO = [F:ITH]PHYSTO+[F:ITH]CTLSTO+[F:ITH]REJSTO-[F:ITH]BPRSTO-[F:ITH]SCOSTO
#      If WSTO < 0
#        WSTO = 0
#      Endif
#    Else
#      WSTO = 0
#    Endif 
    Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
    If fstat = 0
      WSTO = [F:ITV]PHYSTO+[F:ITV]CTLSTO+[F:ITV]REJSTO-[F:ITV]BPRPHYSTO-[F:ITV]SCOPHYSTO
      If WSTO < 0
        WSTO = 0
      Endif
    Else
      WSTO = 0
    Endif 
    If evalue(WFILITM1) & evalue(WFILITM2)
      Gosub LEC_STJ
      If [M:DIA]SIMFLG = 2
        #WTXT = num$([M:DIA]YEA)-[F:ITF]STOFCY-[F:ITF]ITMREF-[F:ITM]ITMDES1-WINTQTY-num$(WSTO)-WINTPMP-num$(WPMP)-GLOCALDEV # FGR 30/06/2009 : X3SUIVI56189
        Local Char WITMDES(GLONDES)                                                                                 # FGR 30/06/2009 : X3SUIVI56189
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3                        # FGR 30/06/2009 : X3SUIVI56189
        WTXT = num$([M:DIA]YEA)-[F:ITF]STOFCY-[F:ITF]ITMREF-WITMDES-WINTQTY-num$(WSTO)-WINTPMP-num$(WPMP)-GLOCALDEV # FGR 30/06/2009 : X3SUIVI56189
        Call ECR_TRACE(WTXT,0) From GESECRAN
      Else
        Raz [F:SLI]
        [F:SLI]STOFCY    = [F:ITF]STOFCY
        [F:SLI]ITMREF    = [F:ITF]ITMREF
        [F:SLI]YEA       = [M:DIA]YEA
        #[F:SLI]ITMDES1   = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:SLI]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [F:SLI]STOFCY    = [F:ITF]STOFCY
        [F:SLI]YEASTOQTY = WSTO
        [F:SLI]YEAPMP    = WPMP
        [F:SLI]CUR       = GLOCALDEV
        [F:SLI]EXPNUM    = [C]EXPORT
        [F:SLI]CREUSR    = GUSER
        [F:SLI]CREDAT    = date$
        Write [SLI]
        If fstat 
          GOK = 0
          Call FSTA("SLI") From GLOCK
          Break
        Endif
        If WCOM > WCOMMAX
          If GOK = 1
            Commit
            Trbegin [SLI]
            WCOM = 0 
          Else
            Break
          Endif
        Else 
          WCOM += 1
        Endif
      Endif
    Endif
  Endif
Next
Filter [ITF]
If [M:DIA]SIMFLG <> 2
  If GOK = 1
    Commit
  Else
    Rollback
 Endif
Endif
# Fin de traitement
$TRT_CALCUL_FIN
Return
############################################################
# Constitution des filtres
$GEN_FILTRES
WFILITF  = "STOFCY=WFCY"
WFILITM1 = "1=1"
WFILITM2 = "1=1"
# Filtre sur ITF
If [M:DIA]ITMREFSTR <> "" | [M:DIA]ITMREFEND <> ""
  WFILITF += "&ITMREF>=[M:DIA]ITMREFSTR&ITMREF<=[M:DIA]ITMREFEND"
Endif
# Filtre sur ITM
If [M:DIA]TCLCODSTR <> "" | [M:DIA]TCLCODEND <> "" 
  WFILITM1 += "&[F:ITM]TCLCOD>=[M:DIA]TCLCODSTR&[F:ITM]TCLCOD<=[M:DIA]TCLCODEND" 
Endif  
#
If dim([M:DIA]TSICODSTR) > 0
  For I = 0 To dim([M:DIA]TSICODSTR)-1
    If [M:DIA]TSICODSTR(I) <> "" | [M:DIA]TSICODEND(I) <> ""  
        WFIL = "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:DIA]TSICODSTR(I)+
&              "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:DIA]TSICODEND(I)+"'"
      If len(WFILITM1) + len(WFIL) > 249
        WFILITM2 += WFIL
      Else 
        WFILITM1 += WFIL    
      Endif 
    Endif
  Next I
Endif
# Filtre sur STJ
WFILSTJ  = "STOFCY=[F:ITF]STOFCY&ITMREF=[F:ITF]ITMREF"
WFILSTJ += "&IPTDAT>=[M:DIA]IPTDATSTR&IPTDAT<=[M:DIA]IPTDATEND"
WFIL     = "&find([F:STJ]TRSTYP"
For I = 1 To 13
  If evalue("dim([M:DIA]TRSTYP"+format$("N0:3",I)+")>0&[M:DIA]TRSTYP"+format$("N0:3",I)+"=2")
    WFIL += ","+num$(I)
  Endif
Next I
If WFIL <> "&find([F:STJ]TRSTYP"
  WFILSTJ += WFIL+")"
Endif
#
If [M:DIA]TRSFAMSTR <> "" | [M:DIA]TRSFAMEND <> ""
  WFILSTJ += "&TRSFAM>=[M:DIA]TRSFAMSTR&TRSFAM<=[M:DIA]TRSFAMEND"
Endif
# Tableau des années à traiter 
For I = 0 To WMAX-1
  TANN(I) = [M:DIA]YEA-WMAX+I+1
Next I
# Tableau des sites à traiter
J = 0
For I = 0 To [M:DIA]NBLIG-1
  If [M:DIA]SELFLG(I) = 2
    J += 1
  Endif
Next I
Local Char WFILFCY(GLONFCY)(J)
J = 0
For I = 0 To [M:DIA]NBLIG-1
  If [M:DIA]SELFLG(I) = 2
    WFILFCY(J) = [M:DIA]STOFCY(I)
    J += 1
  Endif
Next I
Return
###########################################################
$LEC_STJ
WQTY = 0
WAMT = 0
Filter [STJ] Where UPDCOD = 2     &
&                  evalue(WFILSTJ)
&            Order By Key STJ0
For [STJ]
  WQTY += [F:STJ]QTYSTU
  WAMT += ([F:STJ]QTYSTU*[F:STJ]PRIORD)
Next
Filter [STJ]
If WQTY > 0
  WPMP = arr(WAMT/WQTY,0.0001)
Else 
  WPMP = 0
Endif
Return
###########################################################
# Impression 
$TRT_PRT
Gosub PUR_SLW
Gosub GEN_FILTRES
# Début traitement impression
Trbegin [SLW]
GOK  = 1
WCOM = 1
Filter [ITM] Where evalue(WFILITM1) &
&                  evalue(WFILITM2)
&            Order By Key ITM0
#
For [ITM]
  Raz J, TQTE, TVAL, TPRI, TREQ, WVAL
  Filter [SLI] Where find([F:SLI]STOFCY,WFILFCY) &
&                    ITMREF = [F:ITM]ITMREF
&                  Order By Key SLI0
  For [SLI]
    Call GETDEV([F:SLI]STOFCY) From DEVSUB
    WPMPL = [F:SLI]YEAPMP
    WPMPS = [F:SLI]YEAPMP    
    If GLOCALDEV <> GSYSCUR 
      Call COURDEV(GLOCALDEV,GSYSCUR,1,date$,WCRS,WRET) From TRTDIV
      Call CONVERT(WPMPL,GLOCALDEV,WPMPS,GSYSCUR,WCRS) From TRTDIV 
    Endif
    J = 1
    I = find([F:SLI]YEA,TANN)
    If I <> 0
#      Gosub DEBUG1
      TQTE(I-1) += [F:SLI]YEASTOQTY
      TVAL(I-1) += (WPMPS*[F:SLI]YEASTOQTY)
    Endif
  Next
  Filter [SLI] 
# Calcul PMP tous sites
  If J = 1
    For I = 0 To WMAX-1
      If TQTE(I) = 0
        TPRI(I) = 0
      Else
        TPRI(I) = arr(TVAL(I)/TQTE(I),0.001)
      Endif
    Next I
    Raz [SLW]
    [F:SLW]CPY        = [M:DIA]CPY
    [F:SLW]ITMREF     = [F:ITM]ITMREF
    [F:SLW]YEA        = [M:DIA]YEA
    #[F:SLW]ITMDES1    = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:SLW]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [F:SLW]CUR        = GSYSCUR
#     
    Call LIFO(WMAX,TQTE,TPRI,TREQ,WVAL)
    For I = 0 To WMAX-1
      [F:SLW]YEANUM   (I) = TANN(I)
      [F:SLW]YEASTOQTY(I) = TQTE(I) 
      [F:SLW]YEAPMP   (I) = TPRI(I)
      [F:SLW]YEALIFQTY(I) = TREQ(I)
    Next I
    [F:SLW]LIFAMT     = WVAL
    [F:SLW]EXPNUM     = [C]EXPORT
    [F:SLW]CREUSR     = GUSER
    [F:SLW]CREDAT     = date$
#    Gosub DEBUG
    Write [SLW]
    If fstat 
      GOK = 0
      Call FSTA("SLW") From GLOCK
      Break
    Endif
    Case GOK
      When 1 :
        If WCOM > WCOMMAX
          Commit
          Trbegin [SLW]
          WCOM = 1
        Else
          WCOM += 1
        Endif
     When Default :
        Break
    Endcase
  Endif
Next
Filter [ITM]
#
If WCOM > 0
  If GOK = 1
    Commit
  Else 
    Rollback
  Endif
Endif
# Fin de traitement impression
$TRT_PRT_FIN
Return
############################################################
$DEBUG
WTXT = [F:SLW]CPY-[F:SLW]ITMREF-[F:SLW]ITMDES1-"("
For I = 0 To WMAX-1
  If [F:SLW]YEALIFQTY(I) <> 0
    If mid$(WTXT,len(WTXT),1) <> "("
      WTXT += " + "
    Endif
    WTXT += num$([F:SLW]YEANUM(I))-":"-num$([F:SLW]YEALIFQTY(I))+" * "+num$([F:SLW]YEAPMP(I))
  Endif
Next I
WTXT += ") = "+ num$(WVAL)-[F:SLW]CUR
Call ECR_TRACE(WTXT,0) From GESECRAN
Return
############################################################
$DEBUG1
WTXT = [F:SLI]STOFCY-[F:SLI]ITMREF-num$([F:SLI]YEA)-num$([F:SLI]YEASTOQTY)-num$([F:SLI]YEAPMP)-[F:SLI]CUR
Call ECR_TRACE(WTXT,0) From GESECRAN
Return 
############################################################
Subprog LIFO(LMAX,LQTE,LPRI,LREQ,LVAL)
Value    Integer LMAX
Value    Decimal LQTE()
Value    Decimal LPRI()
Variable Decimal LREQ()
Variable Decimal LVAL
#
Local Integer I, J
Local Decimal WSTO, WREP, WQTE, WRES, WREF
#
Raz LREQ, LVAL
#
WSTO = LQTE(LMAX-1)
WREP = 0
For I = 0 To LMAX-1
  If I <> LMAX-1
    WREF = LQTE(I)
    For J = I To LMAX-1
      If LQTE(J) < WREF
        WREF = LQTE(J)
      Endif  
    Next J
    If WREF > WREP
      WQTE  = WREF - WREP
      WRES  = WSTO - WREP
      If WQTE  > WRES
        LREQ(I) = WRES
        LVAL += WRES * LPRI(I)
        Break
      Else
        LREQ(I) = WQTE
        LVAL += WQTE * LPRI(I)
        WREP += WQTE
      Endif
    Endif
  Else
    If WREP < WSTO
      LREQ(I) = WSTO-WREP
      LVAL += (WSTO-WREP) * LPRI(I)
    Endif
  Endif 
Next I
End
###########################################################
$OPEN_FILE
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITH]) = 0 : Local File ITMMVTHIS  [ITH] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:SLI]) = 0 : Local File STOLIFO    [SLI] : Endif
If clalev([F:SLW]) = 0 : Local File STOLIFOW   [SLW] : Endif
Return
############################################################
$ALLO_VARIABLES
Local Integer WCOM                     : # Compteur de transactions
Local Integer WCOMMAX : WCOMMAX = 500  : # Nombre de transactions maximum
Local Char    WSYM 
Local Char    WTXT(100)
Local Char    WFIL    (250)
Local Char    WFILITM1(250)
Local Char    WFILITM2(250) 
Local Char    WFILITF (250)
Local Char    WFILSTJ (250)
Local Char    WFCY(GLONFCY)
Local Decimal WQTY, WAMT, WPMP, WPMPL, WPMPS, WSTO
Local Integer WYEA, WMON, WRET
Local Integer IFCY, I, J, K
#
Local Integer WMAX : WMAX = 10 : # Calcul sur 10 ans
Local Integer TANN(WMAX)       : # Tableau des années
Local Decimal TQTE(WMAX)       : # Tableau des stocks fin d'année
Local Decimal TVAL(WMAX)       : # Tableau des valeur fin d'année
Local Decimal TPRI(WMAX)       : # Tableau des PMP fin d'année 
Local Decimal TREQ(WMAX)       : # Tableau des quantité calculée
Local Decimal WVAL
Local Decimal WCRS
# Intitulés écrans
Local Char    WINTQTY(20)
Local Char    WINTPMP(20)
Local Char    WINTPRO(20)
Local Char    WINTPRT(20)
Local Char    WINTSIM(20)
Call AMK_TEXTE("STOCKLIFO","DMY001",WINTQTY) 
Call AMK_TEXTE("STOCKLIFO","DMY002",WINTPMP) 
Call AMK_TEXTE("STOCKLIFO","PROFLG",WINTPRO) 
Call AMK_TEXTE("STOCKLIFO","PRTFLG",WINTPRT) 
Call AMK_TEXTE("STOCKLIFO","SIMFLG",WINTSIM) 
Return
############################################################
$PUR_SLI
Trbegin [SLI]
GOK  = 1
WCOM = 0
Filter [SLI] Where YEA    = [M:DIA]YEA    &
&                  STOFCY = WFCY 
&            Order By Key SLI1
For [SLI]
  Delete [SLI]
  If fstat
    GOK = 0
    Call FSTA("SLI") From GLOCK
    Break
  Endif
  If WCOM > WCOMMAX
    Break
  Else
    WCOM += 1
  Endif
Next
Filter [SLI]
Case GOK
  When 1 :
    Commit
    If WCOM <> 0
      Goto PUR_SLI
    Endif
  When Default :
    Rollback
Endcase
Return
############################################################
$PUR_SLW
Trbegin [SLW]
GOK  = 1
WCOM = 0
Filter [SLW] Where YEA    = [M:DIA]YEA    &
&                  CPY    = [M:DIA]CPY
&            Order By Key SLW1
For [SLW]
  Delete [SLW]
  If fstat
    GOK = 0
    Call FSTA("SLW") From GLOCK
    Break
  Endif
  If WCOM > WCOMMAX
    Break
  Else
    WCOM += 1
  Endif
Next
Filter [SLW]
Case GOK
  When 1 :
    Commit
    If WCOM <> 0
      Goto PUR_SLW
    Endif
  When Default :
    Rollback
Endcase
Return
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
############################################################
# Recherche intitulés écran
Subprog AMK_TEXTE(LMSK,LZON,LTXT)
Value    Char    LMSK
Value    Char    LZON  
Variable Char    LTXT
If clalev([F:AMZ]) = 0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE  [ATX] : Endif
Read [AMZ]CODE=LMSK;LZON
If fstat
  LTXT = ""
Else 
  Call TEXTE([F:AMZ]INTIT,LTXT) From OBJDIV
Endif
End
############################################################
# Actions écran STOCKLIFO
############################################################
Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR < year(date$)-10
  mkstat = 2
Else
  If VALEUR > year(date$)
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog AS_SIMFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]PROFLG <> 2
  VALEUR = 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_IPTDATEND(VALEUR)
Variable Date    VALEUR
If [M:DIA]PROFLG <> 2
  VALEUR = [0/0/0]
  mkstat = 2
Else
  If month([M]IPTDATSTR) = 1 & day([M]IPTDATSTR) = 1
    VALEUR = gdat$(31,12,year([M]IPTDATSTR))
  Endif
Endif
End
############################################################
Subprog C_IPTDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR< [M]IPTDATSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
############################################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" | VALEUR < [M]ITMREFSTR
  VALEUR = [M]ITMREFSTR 
Endif
End
############################################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#############################################################
Subprog AS_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" | VALEUR < [M]TCLCODSTR
  VALEUR = [M]TCLCODSTR 
Endif
End
############################################################
Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TCLCODSTR 
  GMESSAGE = mess(44,199,1) 
  mkstat = 2 
Endif 
End
############################################################
Subprog AS_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" | VALEUR < [M]TSICODSTR(indice)
  VALEUR = [M]TSICODSTR(indice)
Endif
End
############################################################
Subprog C_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TSICODSTR(indice)
 GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

############################################################
Subprog C_PRTFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]PROFLG = 1
  [M:DIA]SIMFLG = 1
  Affzo [M:DIA]SIMFLG
Endif
If VALEUR = 1 & [M]PROFLG = 1
  mkstat = 2
Endif
End

############################################################
Subprog AS_TRSTYP001(VALEUR)
Variable Integer VALEUR
If [M:DIA]PROFLG <> 2
  VALEUR = 1
  mkstat = 2
Endif
End

