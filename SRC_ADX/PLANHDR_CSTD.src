#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: PLANHDR_CSTD, Plan header
###############################################################################
# Issue X3-105283 - 2018-08-29 by BAKHA : Local menu changed to misc table for transaction type

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_BEFORE"                 : Gosub CHECK_PLAN
        When "AINIT"                        : Gosub INITIALISE
        When "AUPDATE_CONTROL_AFTER"        : Gosub AUPDATE_CONTROL_AFTER
        When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
    When "UPDATE_PLAN_STATUS"               : Gosub UPDATE_PLAN_STATUS
    When "VALIDATE_IMPLEMENT"               : Gosub VALIDATE_IMPLEMENT
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "IMPLEMENT"
      Case [L]ARULE
        When "CONTROL"
          # ????? ASTATUS = fmet this.VALIDATE_IMPLEMENT()  # sets IMPLEMENT to 1 for new and empty lines even after ESC pressed
      Endcase
  Endcase
Return
###############################################################################

#
#
# --------------------------------------------------
# FUNCTION NAME:        CHECK_PLAN
# FUNCTION DESCRIPTION: Check Plan exists, if it does not then display an error message
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
$CHECK_PLAN

    Local File PLANHDR [PLAHDR]
    Read [PLAHDR]PLAHDR_0 = PLANID
    If (fstat <> 0)
      ASTATUS = fmet this.ASETERROR ("", mess(78,2038,1), CST_AERROR)
    Endif
    Close Local File [PLAHDR]
Return

# Update Change request status
#
$AUPDATE_AFTER

  # Update NCS status: Plan / Implement ...

  Local Instance MYNCSRECENT Using C_NCSRECENT
  MYNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  LOCAL_ASTATUS = fmet MYNCSRECENT.AREAD(this.NCSID)
  If (MYNCSRECENT.NCSREC = 2)
    LOCAL_ASTATUS = fmet MYNCSRECENT.UPDATE_IMPLEMENT_STATUS(this.NCSID, CST_AFALSE)
  Endif

  FreeGroup MYNCSRECENT

Return

# --------------------------------------------------
# Custom Method
#
# Update the overall plan status.
#
$UPDATE_PLAN_STATUS

If this.PLANSTATUS < 3
    If this.IMPLEMENT = 2
        this.PLANSTATUS = 2
    Else
        this.PLANSTATUS = 1
    Endif
Else
    this.PLANSTATUS = 3
Endif

Return

# --------------------------------------------------
# Initialise the overall plan status.
$INITIALISE

  this.PLANSTATUS = 1 # Pending
Return

# --------------------------------------------------
# Actions on AUPDATE_CONTROL_AFTER, include:
# VALIDATE the high level plan, and
# Update the overall plan status.
$AUPDATE_CONTROL_AFTER

  Local Integer LOCAL_ASTATUS

  Gosub VALIDATE

  LOCAL_ASTATUS = fmet this.UPDATE_PLAN_STATUS()

Return

# --------------------------------------------------
# VALIDATE the high level plan i.e.
# Transaction type (TRANTYPE) and Action (ACTIONID).
$VALIDATE

  Local Integer LINE

  For LINE = 1 To maxtab(this.PLANDET)

    If ((this.PLANDET(LINE).ASTALIN <> CST_ADEL) and
&       (this.PLANDET(LINE).ASTALIN <> CST_ANEWDEL))

      If (this.PLANDET(LINE).TRANTYPE = "") # Issue X3-105283
        ASTATUS = fmet this.ASETERROR ("", mess(18,2038,1), [V]CST_AERROR)
        Break
      Endif
      If (this.PLANDET(LINE).TRANTYPE <> "" and this.PLANDET(LINE).ACTIONID = "") # Issue X3-105283
        ASTATUS = fmet this.ASETERROR ("", mess(62,2038,1), [V]CST_AERROR)
        Break
      Endif

    Endif

  Next LINE

Return

# --------------------------------------------------
# VALIDATE_IMPLEMENT i.e.
# Check all lines for actioner / action / complete by date.
$VALIDATE_IMPLEMENT

  Local Integer I

  ASTATUS = CST_AOK

  If (this.IMPLEMENT = 2)

    For I = 1 To maxtab(this.PLANDET)

      If ((this.PLANDET(I).ASTALIN <> CST_ADEL) and
&         (this.PLANDET(I).ASTALIN <> CST_ANEWDEL))

        If (this.PLANDET(I).ACTIONID = "" or
&           this.PLANDET(I).ACTIONER = "" or
&           this.PLANDET(I).COMPLETEDATE = AVOID.ADATE)
          ASTATUS = fmet this.ASETERROR("IMPLEMENT", mess(27,2038,1), [V]CST_AERROR)
          this.IMPLEMENT = 1  # Reset
          Break
        Endif

      Endif

    Next

  Endif

  ARET_VALUE = ASTATUS

Return

