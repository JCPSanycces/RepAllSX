If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ALLFLO From WMC1EDIRUN : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ALLFLO From WMC1EDIRUN : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLOCOD From WMC1EDIRUN : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLOCOD From WMC1EDIRUN : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLOREL From WMC1EDIRUN : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLOREL From WMC1EDIRUN : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLODES From WMC1EDIRUN : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLODES From WMC1EDIRUN : Gosub TESTALLSTAT :  Endif
