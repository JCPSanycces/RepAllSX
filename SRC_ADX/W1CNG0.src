Subprog AS_TIM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47937,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TIM(zc) From W1CNG0
Onkey   2 Titled GBOUTS Call S_TIM(zc) From W1CNG0
Onkey 144 Titled GBOUTP Call P_TIM(zc) From W1CNG0
Onkey 146 Titled GBOUTA Call SA_TIM(zc) From W1CNG0
Gosub _AFF
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 1360 : Endif
If !mkstat
 ## Action CONTHRTIM
 Call CONTHRTIM(VALEUR) From SUBHRTIM
 If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 1360 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 1360 : Endif
  If !mkstat
   ## Action STD
   Call C_TIM(VALEUR) From SUBCNG
   If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 1360 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TIM
Call AM_TIM(zc)
If !mkstat & GOBJET
 zoncou = "TIM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTIM)")>indice
 [M]TIM(indice) = VALEUR
 Affzo ZTIM(indice)
Endif
Gosub _AFF
End

Subprog S_TIM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRTIM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRTIM"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRTIM","SUBHRTIM","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TIM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRTIM
 Call TUNHRTIM(VALEUR) From SUBHRTIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_TIM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRTIM"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TIM(VALEUR)
