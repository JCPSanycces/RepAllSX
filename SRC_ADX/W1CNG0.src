Return

Subprog D_LVESEL(VALEUR)
Variable Integer VALEUR
If varinit([M]LVESEL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LVESEL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_LVESEL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LVESEL" : GZNUM = 56647 : Endif
If !mkstat
 ## Action STD
 Call C_LVESEL(VALEUR) From SUBCNG
 If mkstat : GERR = 1 : GZONE = "LVESEL" : GZNUM = 56647 : Endif
Endif
Gosub _AFF
End

$ON_LVEFOR
Onevent BEFORE_INPUT Call AS_LVEFOR(zc) From W1CNG0
Onevent CONTROL Call C_LVEFOR(zc) From W1CNG0
Return

Subprog AS_LVEFOR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]LVEFOR(INDIC) = VALEUR
  Affzo LVEFOR(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_LVEFOR(zc) From W1CNG0
Onkey 130 Titled GBOUT2 Call B2_LVEFOR(zc) From W1CNG0
Onkey 131 Titled GBOUT3 Call B3_LVEFOR(zc) From W1CNG0
Gosub _AFF
End

Subprog C_LVEFOR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LVEFOR" : GZNUM = 1699 : Endif
If !GWEBSERV
 If !mkstat
  ## Action AFRCONT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "AFRCONT"
  PARMSK(1) = ""
  Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LVEFOR" : GZNUM = 1699 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog B1_LVEFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"CNGEMP","EMPLOCTR","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_LVEFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_LVEFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = "CNGEMP"
 PARMSK(2) = "EMPLOCTR"
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

