Return

Subprog AS_CUMPRI0(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(10567,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CUMPRI0(zc) From W1CNG0
Onkey   2 Titled GBOUTS Call S_CUMPRI0(zc) From W1CNG0
Onkey 144 Titled GBOUTP Call P_CUMPRI0(zc) From W1CNG0
Onkey 146 Titled GBOUTA Call SA_CUMPRI0(zc) From W1CNG0
Gosub _AFF
End

Subprog C_CUMPRI0(VALEUR)
Variable Char    VALEUR()
## Action CONTCUM
Call CONTCUM(VALEUR) From SUBCUM
If mkstat : GERR = 1 : GZONE = "CUMPRI0" : GZNUM = 56666 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CUMPRI0" : GZNUM = 56666 : Endif
Endif
Gosub _AFF
End

$AMM_CUMPRI0
Call AM_CUMPRI0(zc)
If !mkstat & GOBJET
 zoncou = "CUMPRI0" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CUMPRI0(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CUMPRI0(VALEUR) From SUBCNG
If mkstat : GERR = 1 : GZONE = "CUMPRI0" : GZNUM = 56666 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCUMPRI0)")>indice
 [M]CUMPRI0(indice) = VALEUR
 Affzo ZCUMPRI0(indice)
Endif
Gosub _AFF
End

