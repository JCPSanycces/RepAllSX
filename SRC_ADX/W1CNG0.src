If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
If !mkstat
 ## Action STD
 Call C_YEA(VALEUR) From SUBCNG
 If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
Endif
Gosub _AFF
End

