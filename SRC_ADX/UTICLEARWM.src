#<AdxTL>@(#)2.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Clear WMCLA & WML Scripts
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Clear WMCLA & WML Scripts") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJTAB
Local Char ORDSYS(250),WMAC(250),FICHIER(250),TRT(250)
Local Char TRTFILE(250)
Local Integer ASUPP,STAT

WMAC=adxmac(0)
ORDSYS="" + WMAC +'@lsadx -a'-DOSSIER-'TRT src'+""

Local File (TRTFILE) From System ORDSYS As [SYS_]
For [SYS_] Where pat(TRTFILE,"WM*")<>0
  ASUPP=0
  TRT=[F:SYS_]TRTFILE
  If left$(TRT,3)="WML" | left$(TRT,5)="WMCLA"
    ASUPP=1
  Endif
  If ASUPP
    Call EFFACE_ADX(WMAC,DOSSIER,TRT,STAT) From ORDSYS
    FICHIER = filpath("TRT",TRT,"src",DOSSIER,"",WMAC)
    Call EFFACE(FICHIER,STAT) From ORDSYS
  Endif
Next

Return
