###################################################################################
#  GLE   02.06.2015  FQ108289  : Archive folder management
#  GLE   29.07.2013  FQ91480   : Error on break level in the TYPACE table migration
###################################################################################

Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "X3DEVV7"
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################################################
# ... MAJ40 : Changes to make when migrating to V7
#  Before validation
#         - AFASMAJ40
#  After validation
#         - FASMAJ40
#           --> Subprog TYPACEMAJ40 : Upgrade tables TYPACE, TYPACELEG and TYPACEINT
#
##########################################################################################################
#
##########################################################################################################
## Avant validation
##########################################################################################################
##  Dans les AXXMAJ, on a les anciens + les nouveaux champs dans les tables...
##-------------------------------------------------------------------------------------------------------#

##########################################################################################################
##  Module IMMOBILISATIONS
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog AFASMAJ40
##-------------------------------------------------------------------------------------------------------#
  #** Appelé depuis DOSMAJ40
  Call ECR_TRACE("Start AFASMAJ40 on"-[F:ADS]DOSSIER,0) From GESECRAN
  Onerrgo ERREUR From DOSMAJ40

  Gosub INIVAR

  If !(func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)) : # FQ108289
    # Not to perform in an archive folder (settings data)
    ##-------------------------------------------------------------------------------------------------------#
    # Données législation
    ##-------------------------------------------------------------------------------------------------------#
    #-- Initialization of multi-legislation posting types
    Call ECR_TIME(WTITLE+": TYPACE tables upgrade") From DOSSUB
    Call AMAJ_TYPACE ([F:ADS]DOSSIER)     From FASMAJ40

    # Not to perform in an archive folder (metadata)
    #-- Object selection updates
    Call ECR_TIME(WTITLE+": Object selection table updates") From DOSSUB
    Call AMAJ_AOBJLST ([F:ADS]DOSSIER)     From FASMAJ40
  Endif

  Gosub FINVAR

  Call ECR_TRACE("End AFASMAJ40",0) From GESECRAN
End
#########################################################
Subprog  AMAJ_TYPACE(PDOSSIER)
#
# - Objet  : Upgrade tables TYPACE, TYPACELEG and TYPACEINT
#
# - Règles :
#
Value Char PDOSSIER


  Onerrgo ERREUR From DOSMAJ40

  # Tables à mettre à jour ---------------------------------------
  If clalev([F:TPE]) : Close File          [TPE] : Endif  # V7-Account posting types
  Local File =PDOSSIER+".TYPACE"     [TPE]

  If clalev([F:TPI]) : Close File          [TPI] : Endif  # V7-Account Interface
  Local File =PDOSSIER+".TYPACEINT"  [TPI]

  If clalev([F:TPL]) : Close File          [TPL] : Endif  # V7-New Account posting types lines (by legislation)
  Local File =PDOSSIER+".TYPACELEG"  [TPL]

Local Integer NBCRE_TPL
Local Integer NBMAJ_TPI
Local Integer I_LEG

  Raz  NBCRE_TPL
  Raz  NBMAJ_TPI

  Call DEBTRANS From GLOCK
  GOK = 1

  Trbegin [TPI], [TPL]
  # For each account posting type (TYPACE)
  For [TPE]
     # Case of Account posting types mono-leg
     # ==> creation of one record TYPACELEG
     If [F:TPE]LEG <> ""
        Read[TPL]TPL0=[F:TPE]ACETYP;[F:TPE]LEG; [F:TPE]CPY;[F:TPE]LEG
        If fstat
           [F:TPL]=  [F:TPE]
           [F:TPL]LEGLIN =  [F:TPE]LEG
           Write [F:TPL]
           If !fstat :
              NBCRE_TPL += 1
           Else
              Call ECR_TRACE("File"-PDOSSIER+".TYPACELEG "-[F:TPL]ACETYP-[F:TPL]LEG-[F:TPL]CPY-[F:TPL]LEGLIN+", Error ="-num$(fstat),1) From GESECRAN
              GOK=0 : Break : # FQ91480
           Endif
        Endif
     Else
        # Case of Account posting types multi-leg
        # ==> creation of one record  TYPACELEG by legislation
        For I_LEG = 1 To GNBLEG
           [F:TPL]=[F:TPE]
           [F:TPL]LEGLIN = GDOSLEG(I_LEG)
           Write [F:TPL]
           If !fstat :
              NBCRE_TPL += 1
           Else
              Call ECR_TRACE("File"-PDOSSIER+".TYPACELEG "-[F:TPL]ACETYP-[F:TPL]LEG-[F:TPL]CPY-[F:TPL]LEGLIN+", Error ="-num$(fstat),1) From GESECRAN
              GOK=0 : Break 2 : # FQ91480
           Endif
         Next I_LEG
     Endif
     For[TPI] Where ACETYP = [F:TPE]ACETYP
        [F:TPI]LEG =   [F:TPE]LEG
        [F:TPI]CPY =   [F:TPE]CPY
        Rewrite  [F:TPI]
        If !fstat :
           NBMAJ_TPI += 1
        Else
           Call ECR_TRACE("File"-PDOSSIER+".TYPACEINT "-[F:TPI]ACETYP-[F:TPI]LEG-[F:TPI]CPY-[F:TPI]TMPFLD-num$([F:TPI]TMPIND)+", Error ="-num$(fstat),1) From GESECRAN
           GOK=0 : Break 2
        Endif
     Next
  Next


$COMMIT_ROLLBACK
  If GOK<1
     Rollback
  Else
     Commit
  Endif


  Close Local File [TPI], [TPL]

  Call ECR_TRACE("AMAJ_TYPACE : "+num$(NBCRE_TPL)+" TPL records created",0) From GESECRAN
  Call ECR_TRACE("AMAJ_TYPACE : "+num$(NBMAJ_TPI)+" TPI records updated",0) From GESECRAN

End

#########################################################
Subprog  AMAJ_AOBJLST(PDOSSIER)
#
# - Objet  : Update table AOBJLST with object selections from root folder
#
# - Règles :
#
Value Char PDOSSIER


  If clalev([F:AOLM]) : Close File [AOLM] : Endif  # Basic object selections in Migrated folder
  Local File =PDOSSIER+".AOBJLST"  [AOLM]

  If clalev([F:AOLR]) : Close File [AOLR] : Endif  # Basic object selections in Root folder
  Local File =GDOSX3+".AOBJLST"    [AOLR]

  Call DEBTRANS From GLOCK

  Trbegin [AOLM]

  # FLU object
  Call UPD_SEL_OBJ(PDOSSIER, "FLU") From FASMAJ40

  # RDE object
  Call UPD_SEL_OBJ(PDOSSIER, "RDE") From FASMAJ40

  # TPE object
  Call UPD_SEL_OBJ(PDOSSIER, "TPE") From FASMAJ40

  If GOK<1
     Rollback
  Else
     Commit
  Endif

  Close File [AOLM]
  Close File [AOLR]
End

Subprog UPD_SEL_OBJ(PDOSSIER, CODOBJ)
Value Char PDOSSIER : # Used for trace only
Value Char CODOBJ

  Delete [AOLM] Where ABREV=CODOBJ

  If adxdlrec > 0
    # The object was present in the migrated folder, its selection is updated
    Read [AOLR]AOL0=CODOBJ
    If fstat
      Call ECR_TRACE("File"-GDOSX3-".AOBJLST"-CODOBJ-"read error ="-num$(fstat),1) From GESECRAN
      GOK=0
    Else
      [F:AOLM]=[F:AOLR]
      Write [F:AOLM]
      If fstat
        Call ECR_TRACE("File"-PDOSSIER+".AOBJLST"-CODOBJ-"write error ="-num$(fstat),1) From GESECRAN
        GOK=0
      Endif
    Endif

    If GOK
      Call ECR_TRACE("Object"-CODOBJ-"successfully updated",0) From GESECRAN
    Endif
  Endif
End

##########################################################################################################
## Module Immobilisation : after validation
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog FASMAJ40
#** Called from  DOSMAJ40
##------------------------------------#
#         After update                #
#-------------------------------------#
  Call ECR_TRACE("Start FASMAJ40 on"-[F:ADS]DOSSIER,0) From GESECRAN
  Onerrgo ERREUR From DOSMAJ40
  #*!
  Gosub INIVAR

  Gosub FINVAR

  Call ECR_TRACE("End FASMAJ40",0) From GESECRAN
End

#
#--------------------------------------
$INIVAR
#-------------------------------------#
#        Before update                #
#-------------------------------------#

  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM


  Local Char    WTITLE

  WTITLE = "FASMAJ40 - Fixed Assets module "
  Call ECR_TRACE("**********************************",0) From GESECRAN
  Call ECR_TRACE(WTITLE,0)                               From GESECRAN
  Call ECR_TRACE("**********************************",0) From GESECRAN

  Gosub SUP_GLOBALES
  Gosub CRT_GLOBALES

# Management of translatable texts
Global Char MIGGLANMAJ(10)
Global Char MIGDOSMAJ(10)

MIGGLANMAJ = [F:ADS]LANDEF
MIGDOSMAJ  = [F:ADS]DOSSIER


Return
#--------------------------------------
$FINVAR

Kill MIGGLANMAJ
Kill MIGDOSMAJ
Return
#--------------------------------------
$CRT_GLOBALES

  Global Char G_COA

  # Indicates whether the execution is done in a transaction
  Global Integer G_TRANSAC : G_TRANSAC = adxlog

  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM

Return
#--------------------------------------
$SUP_GLOBALES


  If (dim(G_TRANSAC)   >0)  : Kill G_TRANSAC    : Endif

Return

