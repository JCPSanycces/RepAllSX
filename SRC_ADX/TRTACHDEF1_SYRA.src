# TRTACHDEF1_SYRA   12/6/2013
########################################################################
# TRTACHDEF1         Traitements valeurs par défaut       Module ACHAT #
#                         et chargement de zones                       #
# -------------------------------------------------------------------- #
# Sous-programmes :                                                    #
#   - DEFRCPFCY    : Chargement site réception GRCPFCY                 #
#   - DEFBETRCPFCY : Chargement site réception pour inter-sites        #
#   - DEFSITE      : CHARGEMENT SITE FINANCIER ET DEVISE COMPTABLE     #
#   - DEFBUD       : CHARGEMENT DE PARAMèTRES BUDGET                   #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Affichage divers GACTION)                  #
#   - DIVRECHNAT : Recherche de la nature pour visu budget             #
########################################################################


$ACTION
Case ACTION
 When "TRT_DIV"
  Case TRAIT
   When "DIVRECHNAT" : Gosub DIVRECHNAT
  Endcase
Endcase
Return


############################################################
# Recherche de la nature pour la visualisation des budgets #
# -------------------------------------------------------- #
# En entrée PARAM(1) : Code traitement appelant            #
#                      1 = Gestion demandes d'achat (PSH)  #
#                      2 = Gestion des commandes (POH)     #
#                      3 = Gestion des DL (POD)            #
#           PARAM(2) : Numéro de ligne courante (nolign-1) #
#                                                          #
# En sortie GBIDC3   : Nature                              #
#           GBIDA3   : Date du budget                      #
# Si erreur GMESSAGE : Message d'erreur                    #
#           GERR     : Code erreur = 1                     #
#           mkstat   : Code statut = 1                     #
############################################################
$DIVRECHNAT
Local Integer  I
Local Shortint NOL : NOL=val(PARAM(2))
Case PARAM(1)
  When "1"
    If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
      Call INIT_COMPTES_LIGNE(NOL)               From SUBPSH
    Endif
    Call RECH_ACC(2,"[M:PSH1]LINACC",NOL,GBIDC3) From TRTX3CPT
    If GBIDC3=""
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDA3 : mkstat=1
    Else
      If [M:PSH1]LINPURTYP(NOL)=0
        Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL)) From SUBPSH
      Endif
      GBIDA3=[M:PSH1]EXTRCPDAT(NOL)
    Endif
  When "2"
    If [M:POH2]LINACC1(NOL)="" & [M:POH2]LINACC2(NOL)="" & [M:POH2]LINACC3(NOL)=""
      # Issue 70985 - 2012-03-16 by MUARN : landed cost déplacé dans SUBPOHB nombre de lignes
      #Call INIT_COMPTES_LIGNE (NOL) From SUBPOH
      Call INIT_COMPTES_LIGNE(NOL)               From SUBPOHB
    Endif
    Call RECH_ACC(2,"[M:POH2]LINACC",NOL,GBIDC3) From TRTX3CPT
    If GBIDC3=""
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDA3 : mkstat=1
    Else
      If [M:POH2]LINPURTYP(NOL)=0
        Call D_LINPURTYP([M:POH2]LINPURTYP(NOL)) From SUBPOH
      Endif
      GBIDA3=[M:POH2]DATBUD(NOL)
    Endif
  When "3"
    If [M:POD1]LINACC(0)="" & [M:POD1]LINACC(1)="" & [M:POD1]LINACC(2)=""
      Call INIT_COMPTES_LIGNE(NOL) From SUBPOD
    Endif
    Call RECH_INDACC(2,I)          From TRTX3CPT
    If I=0
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDC3, GBIDA3 : mkstat=1
    Else
      GBIDC3=[M:POD1]LINACC(I-1)
      If [M:POD1]LINPURTYP=0
        Call INIT_LINPURTYP      From SUBPOD
      Endif
      If GPURCMMDAT=1
        GBIDA3=[M:POD1]ORDDAT Else GBIDA3=[M:POD1]EXTRCPDAT(NOL)
      Endif
    Endif
Endcase
Return


###################################################################################
# Chargement du site de réception par défaut GRCPFCY (sert pour l'initialisation) #
###################################################################################
Subprog DEFRCPFCY(WSITE,WGSITE)
Value Char WSITE
Variable Char WGSITE  # GRCPFCY
Raz WGSITE
Local File FACILITY [FCY]
If [F:FCY]FCY<>WSITE
  Read [FCY] FCY0=WSITE  : If fstat  Raz [FCY] : Endif
Endif
If [F:FCY]WRHFLG=2
  WGSITE=WSITE         : # Site passé en paramètre si site de stockage
Else
  Local File FACILITY [FCYW]
  Read [FCYW]FCY0=[FCY]IVYFCY #Read [FCYW] FCY0=GFCYDEF(7)  # 99095.n
  If fstat
    Raz [F:FCYW]
  #Elsif [F:FCYW]LEGCPY=GSOCIETE
   Elsif [F:FCYW]LEGCPY=[FCY]LEGCPY
    WGSITE=[FCYW]FCY #GFCYDEF(7)  : # Site par défaut du module stock
  Endif
  Close Local File [FCYW]
Endif
End


###################################################################################
# Chargement du site de réception par défaut GRCPFCY (sert pour l'initialisation) #
# Chargement du site d'expédition par défaut GSTOFCY                              #
# Nota : si GRCPFCY est renseigné c'est que le site de réception est déjà connu ! #
###################################################################################
Subprog DEFBETRCPFCY(WCPY,WBPCNUM,WGSTOFCY,WGRCPFCY)
Value Char WCPY # GSOCIETE
Value Char WBPCNUM
Variable Char WGSTOFCY  # GSTOFCY
Variable Char WGRCPFCY

Raz WGSTOFCY

Local File BPDLVCUST  [BPD]
Local File BPCUSTOMER [BPC]

Local File FACILITY [FCYW]
#----- Site d'expédition correspondant au site de réception déjà connu -----#
If WGRCPFCY<>""  # GRCPFCY
  For [BPD] BPD1 Where BPCNUM=WBPCNUM & RCPFCY=WGRCPFCY & ENAFLG=2  # GRCPFCY
    WGSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré  GSTOFCY
    Break
  Next
Else
  #----- Site de l'adresse par défaut du client livré -----#
  Read [BPC] BPC0=WBPCNUM : If fstat  Raz [F:BPC] : Endif
  If [F:BPC]BPDADD<>""
    Read [BPD] BPD0=WBPCNUM;[F:BPC]BPDADD
    If !fstat & [F:BPD]ENAFLG=2
      Read [FCYW] FCY0=[F:BPD]RCPFCY : If fstat  Raz [F:FCYW] : Endif
      #----- Doit appartenir à la même société que le site de commande d'achat -----#
      If [F:FCYW]LEGCPY=WCPY # GSOCIETE
        WGRCPFCY=[F:BPD]RCPFCY : # Site de réception de l'adresse client livré  GRCPFCY
        WGSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré  GSTOFCY
        Close Local File [FCYW]
        End
      Endif
    Endif
  Endif
  #----- Autres sites du client livré -----#
  For [BPD] BPD0 Where BPCNUM=WBPCNUM & RCPFCY<>"" & ENAFLG=2
    Read [FCYW] FCY0=[F:BPD]RCPFCY : If fstat  Raz [F:FCYW] : Endif
    #----- Doit appartenir à la même société que le site de commande d'achat -----#
    If [F:FCYW]LEGCPY=WCPY # GSOCIETE
      WGRCPFCY=[F:BPD]RCPFCY : # Site de réception de l'adresse client livré  GRCPFCY
      WGSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré  GSTOFCY
      Break
    Endif
  Next
Endif
Close Local File [FCYW]
End


########################################################################
# CHARGEMENT de GSOCIETE, GLOCALDEV et de GFINRSP      CG janvier 1998 #
#     - GSOCIETE  : Société courante (Sté du site)                     #
#     - GLOCALDEV : Devise de la société                               #
#     - GFINRSP   : Site financier de la société                       #
#     - GCUR      : Devise de la société (idem GLOCALDEV)              #
########################################################################
Subprog DEFSITE(WSITE)
Value Char WSITE
Call GETDEV(WSITE) From DEVSUB
If GFINRSP="" GFINRSP=WSITE : Endif
GCUR=GLOCALDEV
End


########################################################################
#  CHARGEMENT DES PARAMETRES LIéS AU BUDGET                            #
#  COMMUN POUR LES DA ET COMMANDES OUVERTES  ET CDES CLASSIQUES        #
#                                                       CG JANVIER 1998#
########################################################################
Subprog DEFBUD(TYP,WSITE)
Value Char TYP
Value Char WSITE
#----------------------------------------#
# DEFINITION DES PARAMèTRES POUR BUDGETS #
#----------------------------------------#
Local Char PARAM2(10)

#------ PARAMèTRE ACHAT : MISE à JOUR DES ENGAGEMENTS
#------ PARAMèTRE ACHAT : MISE à JOUR DES PRé-ENGAGEMENTS

GPURCMM    = 1
GPURCMMPRP = 1
GPURCMMDAT = 1
GCTLBUD    = 1
GBUDCTLPOH = 1
GBUDCTLPSH = 1
GBUDCTLPOL = 1
GBUDCTLPSL = 1

If GMODU(2)<>2 End : Endif : # Dossier sans module comptabilité

If TYP = "POH"
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMM",PARAM2)     From ADOVAL
       Else
               Call PARAM(WSITE,"PURCMM",PARAM2)    From ADOVAL
       Endif
       GPURCMM = val(PARAM2)
Else
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMMPRP",PARAM2)  From ADOVAL
       Else
             Call PARAM(WSITE,"PURCMMPRP",PARAM2) From ADOVAL
       Endif
       GPURCMMPRP = val(PARAM2)
Endif
#-------- PARAMèTRE UNIQUEMENT COMMANDE Date ENGAGEMENT
#-------- 1 Date COMMANDE OU 2 Date RECPETION PRéVUE
If TYP = "POH"
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMMDAT",PARAM2)     From ADOVAL
       Else
              Call PARAM(WSITE,"PURCMMDAT",PARAM2)    From ADOVAL
       Endif
       GPURCMMDAT = val(PARAM2)
Endif

#------ PARAMèTRE type DE CONTROLE
GCTLBUD = 0
If TYP = "POH"
     Call PARAM(GFINRSP,"BUDCNTCMM",PARAM2) From ADOVAL
Else
     Call PARAM(GFINRSP,"BUDCNTPRP",PARAM2) From ADOVAL
Endif
GCTLBUD = val(PARAM2)

If GCTLBUD = 4
     #-----------------------------------#
     # Le contrôle est selon l'opérateur #
     #-----------------------------------#
     Call PARAMUTIL("CNTBUD",PARAM2,"",GFINRSP) From SUBAUS
     If val(PARAM2)=1 GCTLBUD=0 Else GCTLBUD=val(PARAM2) : Endif
Endif

#----- PARAMèTRE CONTROLE EN CDE OU DA: OUI/NON
If TYP = "POH"
     Call PARAM(GFINRSP,"BUDCTLPOH",PARAM2) From ADOVAL
     GBUDCTLPOH = val(PARAM2)
Else
     Call PARAM(GFINRSP,"BUDCTLPSH",PARAM2) From ADOVAL
     GBUDCTLPSH = val(PARAM2)
Endif

#----- PARAMèTRE CONTROLE EN LIGNE à LIGNE : OUI/NON
If TYP = "POH"
      Call PARAM(GFINRSP,"BUDCTLPOL",PARAM2) From ADOVAL
      GBUDCTLPOL = val(PARAM2)
Else
      Call PARAM(GFINRSP,"BUDCTLPSL",PARAM2) From ADOVAL
      GBUDCTLPSL = val(PARAM2)
Endif
End
