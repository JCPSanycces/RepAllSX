#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-25054 - 2017-07-07 by JUSYN : Auditing WO components/materials
#---------------------------------------------------------#
# Auditing / Revision Work Order changes                  #
#---------------------------------------------------------#
# Entry      ABBREV   : Abbreviation of revised record    #
#                       type.                             #
#                       "MMR" = Components / Material     #
#                       "MOR" = Operations                #
#            REVC     : Revision code                     #
#                       1 = A = Add                       #
#                       2 = M = Modify                    #
#                       3 = E = Exclude                   #
#                       4 = R = Reinstate                 #
#            I        : Line number grid                  #
#            R        : Revisionreason flg                #
#                       G = take revreason from grid      #
#                       E = take standard exclusion       #
#                           revreason                     #
#---------------------------------------------------------#
# Issue X3-47100 - 2017-07-26 by BAKHA : Need to write current date/time in audit table
# Issue X3-48941 - 2017-08-18 by JUSYN : Deletion of versioned product needs a read of product (MFGITM) again as standard class
#                                        has values of last existing product. (see MFM2 treatment)
# Issue X3-28791 - 2017-08-30 by JUSYN : Treatment for versioned routings ABBREV = MOR
Subprog HISTO_REVMFG(ABBREV, REVC, I, R)
Value Char ABBREV
Value Shortint REVC
Value Integer I
Value Char R

Case ABBREV
    When "MMR"  :  Gosub HISTO_MMR
    When "MOR"  :  Gosub HISTO_MOR    # ISSUE X3-28791 JUSYN
    When Default
Endcase
End
#---------------------------------------------------------#
# Writing auditing record MFGMATREV                       #
#---------------------------------------------------------#
$HISTO_MMR
If clalev ([F:MMR]) = 0   :   Local File MFGMATREV [MMR]   :   Endif
If clalev ([F:MM2]) = 0   :   Local File MFGMATREV [MM2]   :   Endif
If clalev ([F:MFM2])= 0   :   Local File MFGMAT [MFM2]     :   Endif

If R = "G"
    Read [MFM2]MFM0=[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(I);[M:MFG2]BOMSEQ(I);[M:MFG2]ITMREF(I)
Else
    [F:MFM2] = [F:MFM]
Endif

Filter [MM2] Where MFGNUM = [F:MFM2]MFGNUM &
&                  MFGLIN = [F:MFM2]MFGLIN &
&                  BOMSEQ = [F:MFM2]BOMSEQ &
&                  ITMREF = [F:MFM2]ITMREF
&            Order By REVNUM Desc

Read [MM2] First
If fstat
    [F:MMR]REVNUM = 1
Else
    [F:MMR]REVNUM = [F:MM2]REVNUM + 1
Endif

[F:MMR] = [F:MFM2]
[F:MMR]REVCOD = REVC
[F:MMR]CREDAT = date$
[F:MMR]CREUSR = GUSER
[F:MMR]CREDATTIM = datetime$    # Issue X3-47100 - save current date/time

Case R
    When "G" : [F:MMR]REVREASON = [M:MFG2]REVREASON(I)
    When "E" : [F:MMR]REVREASON = mess(402,193,1)   # Component has been deleted
    When Default : [F:MMR]REVREASON = ""
Endcase

Write [MMR]
If fstat
    GOK = 0
    Call FSTA("MMR") From GLOCK
Endif

Filter [MM2]
Close Local File [MMR], [MM2], [MFM2]

Return

#---------------------------------------------------------#
# Writing auditing record MFGOPEREV                       #
#---------------------------------------------------------#
$HISTO_MOR
If clalev ([F:MOR]) = 0   :   Local File MFGOPEREV [MOR]   :   Endif
If clalev ([F:MO2]) = 0   :   Local File MFGOPEREV [MO2]   :   Endif
If clalev ([F:MFO2])= 0   :   Local File MFGOPE [MFO2]     :   Endif

If R = "G"
    Read [MFO2]MFO0=[M:MFG0]MFGNUM;[M:MFG3]OPENUM(I);[M:MFG3]OPESPLNUM(I)
Else
    [F:MFO2] = [F:MFO]
Endif

Filter [MO2] Where MFGNUM    = [F:MFO2]MFGNUM &
&                  OPENUM    = [F:MFO2]OPENUM &
&                  OPESPLNUM = [F:MFO2]OPESPLNUM
&            Order By REVNUM Desc

Read [MO2] First
If fstat
    [F:MOR]REVNUM = 1
Else
    [F:MOR]REVNUM = [F:MO2]REVNUM + 1
Endif

[F:MOR] = [F:MFO2]
[F:MOR]REVCOD = REVC
[F:MOR]CREDAT = date$
[F:MOR]CREUSR = GUSER
[F:MOR]CREDATTIM = datetime$

Case R
    When "G" : [F:MOR]REVREASON = [M:MFG3]REVREASON(I)
    When "E" : [F:MOR]REVREASON = mess(407,193,1)   # Operation has been deleted
    When Default : [F:MMR]REVREASON = ""
Endcase

Write [MOR]
If fstat
    GOK = 0
    Call FSTA("MOR") From GLOCK
Endif

Filter [MO2]
Close Local File [MOR], [MO2], [MFO2]

Return

