#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
#   Budget campagne                                              Module CRM          décembre 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When "RAF"          : Gosub REFRESH
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
  Gosub LOADCMG4
Return

##########################################################################################################
$OUVRE
  If PARAM(1) = "" Then
    #Aucune campagne marketing n'est précisée. L'ananlyse des retours marketing est impossible.
    GMESSAGE = mess(964,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  If PARAM(2) = "" Then
    #Aucune devise n'est précisée. La valorisation des retours marketing est impossible.
    GMESSAGE = mess(965,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCMG4"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Définition du titre
  If PARAM(1) <> "" Then
    #Budget engagé pour la campagne marketing n°XXXXXXX
    [M:CMG4]TIT = mess(501,177,1) - PARAM(1)
  Endif
  [M:CMG4]CMGNUM = PARAM(1)
  [M:CMG4]CMGCUR= PARAM(2)
  #Chargement du tableau
  Gosub LOADCMG4
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:CMG4]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
Return

##########################################################################################################
# FGR 05/10/2015 : X3SUIVI110839 (début)
$LOADCMG4
Local Integer IT_IS_OK
Local Integer ILIGNE
Local Decimal MTMONTANT
Local Decimal MTTOTAL

  Call TEMPON("L") From GESECRAN
  Gosub RAZCMG4
  # OMM : MAILING ---------------------------------------------------------------------------------
  ILIGNE = 0
  MTMONTANT = 0
  MTTOTAL = 0
  Filter [OMM] Where [F:OMM]CMGNUM = [M:CMG4]CMGNUM
  For [OMM]OMM1
    MTMONTANT = 0
    Call SETBUD([M:CMG4]CMGCUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, MTMONTANT) From TRTPLGB
    MTTOTAL = MTTOTAL + MTMONTANT
  Next
  Filter [OMM]
  [M:CMG4]TYP(ILIGNE) = 1
  [M:CMG4]LIBTYP(ILIGNE) = mess([M:CMG4]TYP(ILIGNE),969,1)
  [M:CMG4]BUDGET(ILIGNE) = MTTOTAL
  [M:CMG4]CUR(ILIGNE) = [M:CMG4]CMGCUR
  # OMP : PHONING ---------------------------------------------------------------------------------
  ILIGNE = ILIGNE + 1
  MTMONTANT = 0
  MTTOTAL = 0
  Filter [OMP] Where [F:OMP]CMGNUM = [M:CMG4]CMGNUM
  For [OMP]OMP1
    MTMONTANT = 0
    Call SETBUD([M:CMG4]CMGCUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, MTMONTANT) From TRTPLGB
    MTTOTAL = MTTOTAL + MTMONTANT
  Next
  Filter [OMP]
  [M:CMG4]TYP(ILIGNE) = 2
  [M:CMG4]LIBTYP(ILIGNE) = mess([M:CMG4]TYP(ILIGNE),969,1)
  [M:CMG4]BUDGET(ILIGNE) = MTTOTAL
  [M:CMG4]CUR(ILIGNE) = [M:CMG4]CMGCUR
  # OMT : TRADESHOW -------------------------------------------------------------------------------
  ILIGNE = ILIGNE + 1
  MTMONTANT = 0
  MTTOTAL = 0
  Filter [OMT] Where [F:OMT]CMGNUM = [M:CMG4]CMGNUM
  For [OMT] Hint Key OMT1
    MTMONTANT = 0
    Call SETBUD([M:CMG4]CMGCUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]BOOCST, MTMONTANT) From TRTPLGB
    MTTOTAL = MTTOTAL + MTMONTANT
    MTMONTANT = 0
    Call SETBUD([M:CMG4]CMGCUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]OTHCST, MTMONTANT) From TRTPLGB
    MTTOTAL = MTTOTAL + MTMONTANT
  Next
  Filter [OMT]
  [M:CMG4]TYP(ILIGNE) = 3
  [M:CMG4]LIBTYP(ILIGNE) = mess([M:CMG4]TYP(ILIGNE),969,1)
  [M:CMG4]BUDGET(ILIGNE) = MTTOTAL
  [M:CMG4]CUR(ILIGNE) = [M:CMG4]CMGCUR
  # OMN : MEDIA -----------------------------------------------------------------------------------
  ILIGNE = ILIGNE + 1
  MTMONTANT = 0
  MTTOTAL = 0
  Filter [OMN] Where [F:OMN]CMGNUM = [M:CMG4]CMGNUM
  For [OMN] Hint Key OMN1
    MTMONTANT = 0
    Call SETBUD([M:CMG4]CMGCUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, MTMONTANT) From TRTPLGB
    MTTOTAL = MTTOTAL + MTMONTANT
  Next
  Filter [OMN]
  [M:CMG4]TYP(ILIGNE) = 4
  [M:CMG4]LIBTYP(ILIGNE) = mess([M:CMG4]TYP(ILIGNE),969,1)
  [M:CMG4]BUDGET(ILIGNE) = MTTOTAL
  [M:CMG4]CUR(ILIGNE) = [M:CMG4]CMGCUR
  # -----------------------------------------------------------------------------------------------
  ILIGNE = ILIGNE + 1
  [M:CMG4]NBBUD = ILIGNE
  Call TEMPOFF From GESECRAN
  Affzo [M:CMG4]1-99
Return

