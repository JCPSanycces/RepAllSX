#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPE1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBAFF
mkstat = 0
zoncou = "NBAFF"
indice = 0
status = 1
zoncou = "NBAFF"
If varmode([M]NBAFF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBAFF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBAFF
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBAFF = nolign
   status = 75
   Call SAI_NBAFF(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBAFF From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBAFF" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBAFF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBAFF
mkstat = 0
zoncou = "NBAFF"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBAFF From SUBPJOPE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBAFF" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone POACLB
mkstat = 0
zoncou = "POACLB"
WCHAR = [M]POACLB(indice)
If varmode([M]POACLB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POACLB" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]POACLB(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PAUS","",[M]POACLB(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]POACLB(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_POACLB([M]POACLB(indice)) From SUBPJOPE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone POADES
mkstat = 0
zoncou = "POADES"
WCHAR = [M]POADES(indice)
If varinit([M]POADES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]POADES(indice),"PJMOPEAFF","POADES",[M:PJOPE1]KEYCONCAT(nolign-1),AVOID.ACHAR) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]POADES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "POADES" : Gosub ACTION From =IMPTRT
  Endif
  If WCHAR<>[M]POADES(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_POADES([M]POADES(indice)) From SUBPJOPE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POADES" : GZNUM = 282 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone BTNDES
mkstat = 0
zoncou = "BTNDES"
If varinit([M]BTNDES,indice)=0
 [M]BTNDES(indice) = "138"
Endif
If varmode([M]BTNDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTNDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone POASTR
mkstat = 0
zoncou = "POASTR"
WDATE = [M]POASTR(indice)
If varmode([M]POASTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POASTR" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]POASTR(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POASTR([M]POASTR(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POASTR" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POASTRHM
mkstat = 0
zoncou = "POASTRHM"
WCHAR = [M]POASTRHM(indice)
If varmode([M]POASTRHM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POASTRHM" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]POASTRHM(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POASTRHM([M]POASTRHM(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POASTRHM" : GZNUM = 14714 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POAEND
mkstat = 0
zoncou = "POAEND"
WDATE = [M]POAEND(indice)
If varmode([M]POAEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POAEND" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]POAEND(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POAEND([M]POAEND(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POAEND" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POAENDHM
mkstat = 0
zoncou = "POAENDHM"
WCHAR = [M]POAENDHM(indice)
If varmode([M]POAENDHM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POAENDHM" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]POAENDHM(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POAENDHM([M]POAENDHM(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POAENDHM" : GZNUM = 15114 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POASTDQTY
mkstat = 0
zoncou = "POASTDQTY"
WNUM = [M]POASTDQTY(indice)
If varmode([M]POASTDQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POASTDQTY" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]POASTDQTY(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POASTDQTY([M]POASTDQTY(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POASTDQTY" : GZNUM = 32576 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POARMNQTY
mkstat = 0
zoncou = "POARMNQTY"
WNUM = [M]POARMNQTY(indice)
If varmode([M]POARMNQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POARMNQTY" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]POARMNQTY(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_POARMNQTY([M]POARMNQTY(indice)) From SUBPJOPE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POARMNQTY" : GZNUM = 42118 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POACST
mkstat = 0
zoncou = "POACST"
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV(CUR) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]POACST(indice) : Endif

## Zone POACSTLAB
mkstat = 0
zoncou = "POACSTLAB"
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV(CUR) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]POACSTLAB(indice) : Endif

## Zone NBAFF
mkstat = 0
zoncou = "NBAFF"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMOPE1"
Return

