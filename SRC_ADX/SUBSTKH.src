#<AdxTL>@(#)5.0.0.0 $Revision$
############################################################
# Sous programme de sélection types d'ordre fichier enccours
# LTYP  = Tableau des types (de 1 à 9) selon menu 306
#         Zéro = pas de sélection pour le type
# LSTAF = Tableau des statuts Fermes 0 = pas de sélection / 1 ou 2 Sélection/défaut
# LSTAP = Tableau des statuts Planif.0 = pas de sélection / 1 ou 2 Sélection/défaut
# LSTAS = Tableau des statuts Sugg.  0 = pas de sélection / 1 ou 2 Sélection/défaut
# LSTAX = Tableau selection variable 0 = pas de sélection / 1 ou 2 Sélection/défaut
#         L'intitulé de la sélection variable doit être chargé dans GSINTV1
# En retour les sélections sont rechargées dans LSTAF, LSTAP, LSTAS
#
Subprog SELWIP(LTYP,LSTAF,LSTAP,LSTAS,LSTAX, LMRPF, LWAI,LSOS,LCTL)
Variable Integer LTYP() 
Variable Integer LSTAF() 
Variable Integer LSTAP() 
Variable Integer LSTAS() 
Variable Integer LSTAX()
Variable Integer LMRPF        # (llc 10.00 demande 6454)
Variable Integer LWAI         # (llc 05.01 9130)
Variable Integer LSOS         # (llc 09.01 9508)
Variable Integer LCTL         # (sr 08.02 demande 15316)

#
Local Integer CHOIX
Local Integer SAVOBJET
Local Char    SAVPROG
Local Integer WPRE
Local Integer WNOLIGN
Local Integer WFSTAT 
Local Integer WBOU(1..GNBBOU)  
# 
Local Integer WLID, WLIF, I
#
WNOLIGN = nolign
Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME  
GOBJET   = 0 
# 
For I = 1 To GNBBOU  
  WBOU(I) = 0  
Next I  
WBOU(GVALI) = 1
WBOU(GABAN) = 1
WBOU(GSPE1) = 1
WBOU(GSPE2) = 1
Call SETBOUT(WBOU) From GESECRAN   
#  
Local Mask STKH[STKH]
Local Mesbox Mask [STKH]
&    Button mess(64,123,1),           mess(288,198,1),
&           mess(289,198,1),          mess(5,123,1)        
&    With   left$(mess(64,123,1),1),  left$(mess(288,198,1),1),
&           left$(mess(289,198,1),1), left$(mess(5,123,1),1)
&    Coded GSTAOK, GSTABOU+1, GSTABOU+2, GSTAFIN
&    Titled mess(352,198,1)
&    As [STKH]
#
Boxact [STKH]
# Préparation du masque
Raz [M:STKH]
nolign = 0
For I = 1 To dim(LTYP)-1
  If LTYP(I) = 2
    [M:STKH]WIPTYP(nolign)  = I
    If I < dim(LSTAF)
      [M:STKH]WIPSTA1(nolign) = LSTAF(I)
    Endif
    If I < dim(LSTAP)
      [M:STKH]WIPSTA2(nolign) = LSTAP(I)
    Endif
    If I < dim(LSTAS)
      [M:STKH]WIPSTA3(nolign) = LSTAS(I)
    Endif
    If I < dim(LSTAX)
      [M:STKH]WIPSTA5(nolign) = LSTAX(I)
    Endif
    nolign += 1
  Endif
Next I
[M:STKH]MRPFLG = LMRPF    # (llc 10.00 demande 6454)
[M:STKH]WAICOD = LWAI     # (llc 05.01 demande 9130)
[M:STKH]SOSCOD = LSOS     # (llc 09.01 demande 9508)
[M:STKH]CTLCOD = LCTL     # (sr 08.02 demande 15316)  
[M:STKH]BASPAG = nolign
Affzo [M:STKH]1-99
$AFFSEL1
Boxinp [STKH] Using CHOIX
  Case CHOIX
    When GSTAOK, GSTARET :
      Goto AFFSEL2    
    When GSTABOU+1 :
      WLID = 0
      WLIF = [M:STKH]BASPAG-1
      Call MEI_LIGNE(WLID,WLIF,2) 
    When GSTABOU+2 :
      WLID = 0
      WLIF = [M:STKH]BASPAG-1
      Call MEI_LIGNE(WLID,WLIF,1) 
    When GSTAFIN, GSTAESC : 
      Goto AFFSEL3
  Endcase
Goto AFFSEL1
# Transfert des sélections
$AFFSEL2
LMRPF = [M:STKH]MRPFLG    # (llc 10.00 demande 6454)
LWAI  = [M:STKH]WAICOD    # (llc 10.00 demande 9130)
LSOS  = [M:STKH]SOSCOD    # (llc 10.00 demande 9508)
LCTL  = [M:STKH]CTLCOD    # (sr 08.02 demande 15316)

For I = 0 To [M:STKH]BASPAG-1
  If ([M:STKH]WIPTYP-1 < dim(LSTAF) & [M:STKH]WIPSTA1(I) = 2) | 
&    ([M:STKH]WIPTYP-1 < dim(LSTAP) & [M:STKH]WIPSTA2(I) = 2) |
&    ([M:STKH]WIPTYP-1 < dim(LSTAS) & [M:STKH]WIPSTA3(I) = 2) |
&    ([M:STKH]WIPTYP-1 < dim(LSTAX) & [M:STKH]WIPSTA5(I) = 2)
    Break
  Endif
Next I
If I = [M:STKH]BASPAG
  Call ERREUR(mess(28,187,1)) From GESECRAN
  Goto AFFSEL1
Else  
  For I = 0 To [M:STKH]BASPAG-1
    If [M:STKH]WIPTYP-1 < dim(LSTAF)
      LSTAF([M:STKH]WIPTYP(I)) = [M:STKH]WIPSTA1(I)
    Endif
    If [M:STKH]WIPTYP-1 < dim(LSTAP)
      LSTAP([M:STKH]WIPTYP(I)) = [M:STKH]WIPSTA2(I)
    Endif
    If [M:STKH]WIPTYP-1 < dim(LSTAS)
      LSTAS([M:STKH]WIPTYP(I)) = [M:STKH]WIPSTA3(I)
    Endif
    If [M:STKH]WIPTYP-1 < dim(LSTAX)
      LSTAX([M:STKH]WIPTYP(I)) = [M:STKH]WIPSTA5(I)
    Endif
  Next I
Endif
$AFFSEL3
#
nolign     = WNOLIGN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
Call RESTBOUT From GESECRAN
End
############################################################
Subprog AS_WIPSTA1(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_WIPSTA2(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_WIPSTA3(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_WIPSTA4(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_WIPSAT5(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_WIPSTA5(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_BASPAG
If nolign > 0
  GBOUT1 = mess(256,198,1)
  GBOUT2 = mess(257,198,1)
  GBOUT3 = mess(285,198,1)
  GBOUT4 = mess(286,198,1)
Endif
End
############################################################
Subprog B1_BASPAG
Local Integer WLID : WLID = nolign-1
Local Integer WLIF : WLIF = nolign-1
Call MEI_LIGNE(WLID,WLIF,2)
End
############################################################
Subprog B2_BASPAG
Local Integer WLID : WLID = nolign-1
Local Integer WLIF : WLIF = nolign-1
Call MEI_LIGNE(WLID,WLIF,1)
End
############################################################
Subprog B3_BASPAG
Local Integer WLID : WLID = nolign-1
Local Integer WLIF : WLIF = [M]BASPAG-1
Call MEI_LIGNE(WLID,WLIF,2)
End
############################################################
Subprog B4_BASPAG
Local Integer WLID : WLID = nolign-1
Local Integer WLIF : WLIF = [M]BASPAG-1
Call MEI_LIGNE(WLID,WLIF,1)
End
##############################################################
Subprog MEI_LIGNE(LLID,LLIF,LVAL)
Variable Integer LLID
Variable Integer LLIF
Value    Integer LVAL
Local    Integer WLID 
#
For WLID = LLID To LLIF
  If [M:STKH]WIPSTA1(WLID) <> 0 & [M:STKH]WIPSTA1(WLID) <> LVAL
    [M:STKH]WIPSTA1(WLID) = LVAL
  Endif
  If [M:STKH]WIPSTA2(WLID) <> 0 & [M:STKH]WIPSTA2(WLID) <> LVAL
    [M:STKH]WIPSTA2(WLID) = LVAL
  Endif
  If [M:STKH]WIPSTA3(WLID) <> 0 & [M:STKH]WIPSTA3(WLID) <> LVAL
    [M:STKH]WIPSTA3(WLID) = LVAL
  Endif
  If [M:STKH]WIPSTA5(WLID) <> 0 & [M:STKH]WIPSTA5(WLID) <> LVAL
    [M:STKH]WIPSTA5(WLID) = LVAL
  Endif
Next WLID
Affzo [M:STKH]1-99
End
########################################
Subprog AV_MRPFLG(VALEUR)
Variable Integer VALEUR
If !find(VALEUR,1,2,3) : VALEUR = 3 : Endif
End

