#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "ENR"       : Gosub ENR
 When "ABA"       : Gosub ABA
Endcase

Return


##########################################################################
$OUVRE

If clalev([F:FCY])=0 Local File FACILITY     [FCY]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT   [ITF]  Endif
If clalev([F:BPS])=0 Local File BPSUPPLIER   [BPS]  Endif
If clalev([F:ITP])=0 Local File ITMBPS       [ITP]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER    [ITM] Endif
If clalev([F:STCF])=0 Local File COSTSTCF    [STCF] Endif
If clalev([F:STCH])=0 Local File COSTSTCH    [STCH] Endif

# Issue 38359 - 2017-10-04 by MAE
#---- Chargement de GCUR
Call CHARGE_GCUR() From TRTX3

Local Decimal WMNTORG(0..2)
Local Decimal WMNTDES(0..2)
Local Integer SPSTAT
# End issue 38359


Return
##########################################################################
$DEBUT
[M:STCF]ITMREF = PARAM(1)
[M:STCF]BPSNUM = PARAM(2)
[M:STCF]STOFCY = PARAM(3)

If GPILNAV >1 #on vient soit des articles fournisseurs, soit des articles site => sélection non modifiable
    Grizo [M:STCF]ITMREF
    Grizo [M:STCF]BPSNUM
    Grizo [M:STCF]STOFCY
Endif

# lecture de ITP : article fournisseur
If [M:STCF]BPSNUM <> ""
  Read [ITP]ITP0 = [M:STCF]ITMREF; [M:STCF]BPSNUM
  If !fstat
    Gosub LECTURE_ITF
  Endif
   Raz [M:STCF]STOFCY
Elsif [M:STCF]STOFCY <> ""
  Read [FCY]FCY0 = [M:STCF]STOFCY
  If !fstat
    Call LECTURE_ITP([M:STCF]STOFCY)
  Endif
  Raz [M:STCF]BPSNUM
Else
  Raz [M:STCF]NBLIG
Endif
Affzo [M:STCF]1-99

Return

#########################################################################
$SETBOUT
If find(2,[M:STCF]FLGMODIF)
  If !find("A", CHBOU) : CHBOU +="A" : Endif
  If !find("E", CHBOU) : CHBOU +="E" : Endif
  Call VIREBOUT(CHMEN,"R") From GOBJET
Else
  Call VIREBOUT(CHBOU,"A") From GOBJET
  Call VIREBOUT(CHBOU,"E") From GOBJET
Endif

Return
##########################################################################
$ENR
Trbegin [STCF]
For I=0 To [M:STCF]NBLIG-1
  If ([M:STCF]STCNUM(I)<>[M:STCF]STCNUMDEF(I))|
&    ([M:STCF]CPRAMT(I)<>[M:STCF]CPRAMTDEF(I))|
&    ([M:STCF]CPRCOE(I)<>[M:STCF]CPRCOEDEF(I))
    Read[STCF]STCF0 = [M:STCF]ITMREF;[M:STCF]BPSNUMBPS(I);[M:STCF]FCY(I)
      If !fstat   #l'enregistrement existe => mise à jour
        [F:STCF]STCNUM = [M:STCF]STCNUM(I)
        # Issue 38359 - 2017-10-04 by MAE
        WMNTORG(1) = [M:STCF]CPRAMT(I)
        Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
        If !SPSTAT  [F:STCF]CPRAMT = WMNTDES(1) : Endif
        #[F:STCF]CPRAMT = [M:STCF]CPRAMT(I)
        # End issue 38359
        [F:STCF]CPRCOE = [M:STCF]CPRCOE(I)
        Rewrite [STCF]
      Else
        [F:STCF]ITMREF = [M:STCF]ITMREF
        [F:STCF]BPSNUM = [M:STCF]BPSNUMBPS(I)
        [F:STCF]ITMREFBPS = [M:STCF]ITMREFBPS(I)
        [F:STCF]STOFCY = [M:STCF]FCY(I)
        [F:STCF]STCNUM = [M:STCF]STCNUM(I)
        # Issue 38359 - 2017-10-04 by MAE
        WMNTORG(1) = [M:STCF]CPRAMT(I)
        Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
        If !SPSTAT  [F:STCF]CPRAMT = WMNTDES(1) : Endif
        #[F:STCF]CPRAMT = [M:STCF]CPRAMT(I)
        # End issue 38359
        [F:STCF]CPRCOE = [M:STCF]CPRCOE(I)
        Write [STCF]
        If fstat
          GOK = 0 : Call FSTA("STCF") From GLOCK
        Endif
      Endif
   Else
    Read[STCF]STCF0 = [M:STCF]ITMREF;[M:STCF]BPSNUMBPS(I);[M:STCF]FCY(I)
    If !fstat   #l'enregistrement existe => delete
      Delete[STCF]
    Endif
   Endif
   Raz [M:STCF]FLGMODIF(I)

  Next I
GREP=""
Commit
Return
##########################################################################
$ABA
Raz [M:STCF]FLGMODIF
If [M:STCF]BPSNUM <> ""
  Read [ITP]ITP0 = [M:STCF]ITMREF; [M:STCF]BPSNUM
  If !fstat
    Gosub LECTURE_ITF
  Endif
   Raz [M:STCF]STOFCY
Elsif [M:STCF]STOFCY <>""
  Read [FCY]FCY0 = [M:STCF]STOFCY
  If !fstat
    Call LECTURE_ITP([M:STCF]STOFCY)
  Endif
  Raz [M:STCF]BPSNUM
Endif
Affzo[M:STCF]1-99
Return
##########################################################################
$LECTURE_ITF
# Issue 38359 - 2017-10-04 by MAE : comment
Local Decimal WMNTORG(0..2)
Local Decimal WMNTDES(0..2)
Local Integer SPSTAT
# End issue 38359


Filter [ITF] Where ITMREF = [M:STCF]ITMREF
&            Order By [F:ITF]STOFCY

I = 0
For [ITF]
   [M:STCF]ITMREFBPS(I) = [F:ITP]ITMREFBPS
   [M:STCF]ITMDESBPS(I) = [F:ITP]ITMDESBPS
   # Issue X3-86034 - 2018-04-12 by SR :Dans tous les cas on récupère ITP
   #If ([F:ITP]STCNUM <> "") |([F:ITP]CPRAMT <> 0)|([F:ITP]CPRCOE <> 1)
    [M:STCF]STCNUMDEF(I) = [F:ITP]STCNUM
    # Issue 38359 - 2017-10-04 by MAE
    WMNTORG(1) = [F:ITP]CPRAMT
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If !SPSTAT  [M:STCF]CPRAMTDEF(I) = WMNTDES(1) : Endif
    #[M:STCF]CPRAMTDEF(I) = [F:ITP]CPRAMT
    # End issue 38359
    # Issue X3-84036 - 2018-04-12 by SR : Si non initialisé, mettre 1
    #[M:STCF]CPRCOEDEF(I) = [F:ITP]CPRCOE
    [M:STCF]CPRCOEDEF(I) = max([F:ITP]CPRCOE,1)
   # Issue X3-86034 - 2018-04-12 by SR : On ne prend que les données ITF
#   Else
#     Read [ITM]ITM0 = [M:STCF]ITMREF
#     [M:STCF]STCNUMDEF(I) = [F:ITM]STCNUM
#      # Issue 38359 - 2017-10-04 by MAE
#      WMNTORG(1) = [F:ITM]CPRAMT
#      Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
#      If !SPSTAT  [M:STCF]CPRAMTDEF(I) = WMNTDES(1) : Endif
#      #[M:STCF]CPRAMTDEF(I) = [F:ITM]CPRAMT
#      # End issue 38359
#     [M:STCF]CPRCOEDEF(I) = [F:ITM]CPRCOE
   #Endif
   # End issue X3-86034
   [M:STCF]BPSNUMBPS(I) = [F:ITP]BPSNUM
   [M:STCF]FCY(I)       = [F:ITF]STOFCY
   Read [FCY]FCY0 = [F:ITF]STOFCY                      #lecture du site
   [M:STCF]FCYNAM(I)    = [F:FCY]FCYNAM
   Raz [F:STCF]
   Read [F:STCF]STCF0 = [M:STCF]ITMREF;[F:ITP]BPSNUM;[F:ITF]STOFCY
   If fstat > 0   #pas d'enregistrement dans la table COSTSTCITF
    [M:STCF]STCNUM(I)  = [M:STCF]STCNUMDEF(I)
    [M:STCF]CPRAMT(I)  = [M:STCF]CPRAMTDEF(I)
    [M:STCF]CPRCOE(I)  = [M:STCF]CPRCOEDEF(I)
   Else
    [M:STCF]STCNUM(I)  = [F:STCF]STCNUM
    # Issue 38359 - 2017-10-04 by MAE
    WMNTORG(1) = [F:STCF]CPRAMT
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If !SPSTAT  [M:STCF]CPRAMT(I)  = WMNTDES(1) : Endif
    #[M:STCF]CPRAMT(I)  = [F:STCF]CPRAMT
    # End issue 38359
    If [F:STCF]CPRCOE=0 : [M:STCF]CPRCOE(I)  = 1 Else [M:STCF]CPRCOE(I)=[F:STCF]CPRCOE Endif
   Endif
   Call LECTEXTRA([M:STCF]STCDESAXX(I),"COSTSTCH","STCDESAXX",[M:STCF]STCNUM(I),"") From ATEXTRA
   [M:STCF]CUR(I) = GCUR      # Issue 38359
  If I < dim([M:STCF]ITMREFBPS)-1 : I += 1
  Else  Break  Endif
Next

Filter [ITF]
[M:STCF]NBLIG = I
Return



##########################################################################
Subprog LECTURE_ITP(LSTOFCY)  #en sous pro pour passer la valeur du site en AM de STOFCY
Variable Char LSTOFCY
# Issue 38359 - 2017-10-04 by MAE : comment
Local Decimal WMNTORG(0..2)
Local Decimal WMNTDES(0..2)
Local Integer SPSTAT
# End issue 38359

Read [FCY]FCY0 = LSTOFCY                    #lecture du site

Filter [ITP] Where ITMREF=[M:STCF]ITMREF
&            Order By [F:ITP]BPSNUM


I = 0
For [ITP]
   [M:STCF]ITMREFBPS(I) = [F:ITP]ITMREFBPS
   [M:STCF]ITMDESBPS(I) = [F:ITP]ITMDESBPS
   # Issue X3-86034 - 2018-04-12 by SR :Dans tous les cas on récupère ITP
   #If ([F:ITP]STCNUM <> "")|([F:ITP]CPRAMT <> 0)|([F:ITP]CPRCOE <> 1)
    [M:STCF]STCNUMDEF(I) = [F:ITP]STCNUM
    # Issue 38359 - 2017-10-04 by MAE
    WMNTORG(1) = [F:ITP]CPRAMT
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If !SPSTAT  [M:STCF]CPRAMTDEF(I)  = WMNTDES(1) : Endif
    #[M:STCF]CPRAMTDEF(I) = [F:ITP]CPRAMT
    # End issue 38359
    # Issue X3-86034 - 2018-04-12 by SR : Si non initialisé, mettre 1
    #[M:STCF]CPRCOEDEF(I) = [F:ITP]CPRCOE
    [M:STCF]CPRCOEDEF(I) = max([F:ITP]CPRCOE,1)
#   Else
#    Read [ITM]ITM0 = [M:STCF]ITMREF
#    [M:STCF]STCNUMDEF(I) = [F:ITM]STCNUM
#    # Issue 38359 - 2017-10-04 by MAE
#    WMNTORG(1) = [F:ITM]CPRAMT
#    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
#    If !SPSTAT  [M:STCF]CPRAMTDEF(I)  = WMNTDES(1) : Endif
#    #[M:STCF]CPRAMTDEF(I) = [F:ITM]CPRAMT
#    # End issue 38359
#    [M:STCF]CPRCOEDEF(I) = [F:ITM]CPRCOE
#   Endif
    # End issue X3-86034
   [M:STCF]BPSNUMBPS(I) = [F:ITP]BPSNUM
   [M:STCF]FCY(I)       = [F:FCY]FCY
   [M:STCF]FCYNAM(I)    = [F:FCY]FCYNAM
   Raz [F:STCF]
   Read [F:STCF]STCF0 = [M:STCF]ITMREF;[F:ITP]BPSNUM;[M:STCF]FCY(I)
   If fstat > 0   #pas d'enregistrement dans la table COSTSTCITF
    [M:STCF]STCNUM(I)  = [M:STCF]STCNUMDEF(I)
    [M:STCF]CPRAMT(I)  = [M:STCF]CPRAMTDEF(I)
    [M:STCF]CPRCOE(I)  = [M:STCF]CPRCOEDEF(I)
   Else
    [M:STCF]STCNUM(I)  = [F:STCF]STCNUM
    # Issue 38359 - 2017-10-04 by MAE
    WMNTORG(1) = [F:STCF]CPRAMT
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If !SPSTAT  [M:STCF]CPRAMT(I)  = WMNTDES(1) : Endif
    #[M:STCF]CPRAMT(I)  = [F:STCF]CPRAMT
    # End issue 38359
    If [F:STCF]CPRCOE=0 [M:STCF]CPRCOE(I)=1 Else [M:STCF]CPRCOE(I)  = [F:STCF]CPRCOE Endif
   Endif
   [M:STCF]CUR(I) = GCUR      # Issue 38359
   Call LECTEXTRA([M:STCF]STCDESAXX(I),"COSTSTCH","STCDESAXX",[M:STCF]STCNUM(I),"") From ATEXTRA
   If I < dim([M:STCF]ITMREFBPS)-1 : I += 1
  Else  Break  Endif
Next
Filter [ITP]
[M:STCF]NBLIG = I

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran STCITF) 18/10/2013 11:06:46 (MAEU)
######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char WSVGITMREF(GLONITM)    #Variable utilisé pour sauvegarder la réf de l'article lors du Raz de l'écran

Read [ITP]ITP0 = [M:STCF]ITMREF; VALEUR
If !fstat
  Gosub LECTURE_ITF
  If [M:STCF]STOFCY <> "" : Raz [M:STCF]STOFCY : Endif
   Grizo [M:STCF]STOFCY
Else
  WSVGITMREF = [M:STCF]ITMREF
  Raz[M:STCF]
  [M:STCF]ITMREF = WSVGITMREF
  Actzo [M:STCF]STOFCY
Endif
Affzo [M:STCF]15
End

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char WSVGITMREF(GLONITM)  #Variable utilisé pour sauvegarder la réf de l'article lors du Raz de l'écran

Read [ITF]ITF0 = [M:STCF]ITMREF; VALEUR
If !fstat
  Call LECTURE_ITP(VALEUR)
  If [M:STCF]BPSNUM <> "" : Raz [M:STCF]BPSNUM  : Endif
  Grizo [M:STCF]BPSNUM
Else
  WSVGITMREF = [M:STCF]ITMREF
  Raz [M:STCF]
  [M:STCF]ITMREF = WSVGITMREF
  Actzo [M:STCF]BPSNUM
Endif
Affzo [M:STCF]15
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran STCITF) 24/10/2013 11:19:52 (MAEU)
######################################################################################
Subprog AM_STCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer LRET : LRET=0
Local Integer OK : OK=1

# End issue X3-86034 CPRCOE peut être égal à 0. Doit être considéré comme non renseigné
#If [M:STCF]CPRCOE(nolign-1)<>1 | [M:STCF]CPRAMT(nolign-1)<>0
If [M:STCF]CPRCOE(nolign-1)> 1  | [M:STCF]CPRAMT(nolign-1)<>0
  Call OUINON(mess(602,199,1), LRET) From GESECRAN  # "un coeff ou coût est paramétré"
  If OK=2
    VALEUR =""
  Else
    [M:STCF]CPRCOE(nolign-1) = 1 : [M:STCF]CPRAMT(nolign-1) = 0
    Affzo [M:STCF]CPRCOE(nolign-1), CPRAMT(nolign-1)
  Endif
Endif

Call LECTEXTRA([M:STCF]STCDESAXX(nolign-1),"COSTSTCH","STCDESAXX",VALEUR,"") From ATEXTRA
#bg 96899, Lecture de l'article pour l'avoir en ligne lors du controle des unités de la structure de cout
If [F:ITM]ITMREF <> [M:STCF]ITMREF
  Read [ITM]ITM0 = [M:STCF]ITMREF
Endif
Call CONTROL_CSTSTC(VALEUR,"ITP",LRET) From STCCTL
If LRET
  mkstat = 2
Else
  [M:STCF]FLGMODIF(nolign-1) = 2
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran STCITF) 05/11/2013 14:35:07 (MAE)
######################################################################################
Subprog AM_CPRCOE(VALEUR)
Variable Decimal VALEUR
Local Integer OK : OK=1
If VALEUR <> 1 & [M:STCF]STCNUM(nolign-1)<>""
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  If OK=1
    VALEUR = 1
  Else
    [M:STCF]STCNUM(nolign-1) = ""
    [M:STCF]STCDESAXX(nolign-1) = ""
    Affzo [M:STCF]STCNUM(nolign-1),STCDESAXX(nolign-1)
  Endif
Endif
# Issue 120172 - 2016-12-16 by MAE : si la valeur saisie est différente de la précédente
#If VALEUR <> 1
If VALEUR <> [M:STCF]CPRCOE(nolign-1)
  [M:STCF]FLGMODIF(nolign-1) = 2
Endif
End

Subprog AM_CPRAMT(VALEUR)
Variable Decimal VALEUR
Local Integer OK : OK=1
If VALEUR <> 0 & [M:STCF]STCNUM(nolign-1)<>""
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  If OK=1
    VALEUR = 1
  Else
    [M:STCF]STCNUM(nolign-1) = ""
    [M:STCF]STCDESAXX(nolign-1) = ""
    Affzo [M:STCF]STCNUM(nolign-1),STCDESAXX(nolign-1)
  Endif
Endif
If VALEUR <> 1
  [M:STCF]FLGMODIF(nolign-1) = 2
Endif
End


