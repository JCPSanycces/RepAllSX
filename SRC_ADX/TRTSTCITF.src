Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [ITF]ITF0 = [M:STCF]ITMREF; VALEUR
  If fstat
    GMESSAGE=mess(14,752,1)+" "+mess(87,100,1)
    mkstat=2
  Endif
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran STCITF) 08/11/2013 14:09:41 (MAE)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Char WSVGITMREF(GLONITM)  #Variable utilisé pour sauvegarder la réf de l'article lors du Raz de l'écran
If VALEUR <> ""
  WSVGITMREF = VALEUR
  Raz [M:STCF]
  [M:STCF]ITMREF=WSVGITMREF
  Affzo [M:STCF]
Endif
End


