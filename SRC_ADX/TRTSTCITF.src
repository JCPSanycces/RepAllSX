Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
  Read [ITP]ITP0 = [M:STCF]ITMREF; VALEUR
  If fstat
    GMESSAGE=mess(28,752,1)+" "+mess(87,100,1)
    mkstat=2
  Endif
Endif

End


