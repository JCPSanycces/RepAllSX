######################################################################################
Subprog C_STCNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [STCH]STCH0 = VALEUR
  If fstat
    GMESSAGE=mess(1119,196,1)
    mkstat=2
  Endif
Endif
End


######################################################################################

