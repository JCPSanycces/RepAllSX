#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update TRT to add EVENTS,RULES ...
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update TRT to add EVENTS,RULES") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTRT
End

#-------------------#
$MAJTRT
Local File =DOSSIER+".ACLASSE"   [ACLA]
Local File =DOSSIER+".ASHW"   [ASW]

Local Char TBTRT(GLONADC)(1..),TBCODCLA(GLONADC)(1..)
Local Integer NBTRT,TISACTX(1..)

Local Char      FICSRC(250),FICNEW(250)
Local Integer   NBMERE,J,FLVALMET,FLVALPRO,OKTRT,STAT,OK,TYPAGE,FLVALEVENT,FLVALOPE,ISACTX
Local Char      TBMERE(GLONADS)(1..10),LIGNE(250)
Local Char      MACHINE(GDIMFIC), APPLI(GDIMFIC),NOMSTC(80)

Local Instance AERR(1..)   Using C_AERROR


Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

For [F:ACLA]ACLA0 Where NBRTRT>0
 For I=0 To dim([F:ACLA]CODTRT)-1
  If [F:ACLA]CODTRT(I)<>""
   NBTRT+=1 : TBTRT(NBTRT)=[F:ACLA]CODTRT(I) : TISACTX(NBTRT)=[F:ACLA]FLGACTX : TBCODCLA(NBTRT)="C_"+[F:ACLA]CODCLA
  Endif
 Next
Next
For [F:ASW]ASW0 Where NBRTRT>0
 For I=0 To dim([F:ASW]CODTRT)-1
  If [F:ASW]CODTRT(I)<>""
   NBTRT+=1 : TBTRT(NBTRT)=[F:ASW]CODTRT(I) : TISACTX(NBTRT)=0 :  : TBCODCLA(NBTRT)="R_"+[F:ASW]CODREP
  Endif
 Next
Next
Local Char CODTRT(GLONADC)
For I=1 To NBTRT
 CODTRT= TBTRT(I) : ISACTX=TISACTX(I) :  NOMSTC=TBCODCLA(I) : Gosub ADD_EVENT
Next
Close Local File [ACLA],[ASW]
Return

######################################################################
$ADD_EVENT
If DOSSIER=nomap
 FICSRC = filpath("TRT",CODTRT,"src")
Else
 FICSRC = filpath("TRT",CODTRT,"src",[L]APPLI,"",[L]MACHINE)
Endif
If filinfo(FICSRC,0)>=0
 Gosub TEST_ACTION From ACLASUB
 If FLVALMET or FLVALPRO or FLVALEVENT or FLVALOPE
  Call ECR_TRACE(mess(159,133,1)-CODTRT,0) From GESECRAN
  Gosub ADD_ACTION From ACLASUB
  Call VALID("TRT",CODTRT,ISACTX,DOSSIER,0,TYPAGE,OK,AERR) From ACLAVALSUB
 Endif
Endif
Return

