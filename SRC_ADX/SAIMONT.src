#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
GBIDC2="" : GBIDC3="" : GFLAG="" #"IASL"
Call OBJET("GAS",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "OK"      : Gosub OK   
 When Default
Endcase
Return

$OUVRE

## Déclaration des paramètres
Local Char    FLDNAM         :   # Nom de la zone courante
Local Char    CPY (GLONCPY)  :   # Socièté
Local Char    CUR (GLONCUR)  :   # Devise
Local Date    ACCDAT         :   # Date
Local Integer FLG(0..9)      :   # Flag de Montants forcés
Local Decimal AMT(0..9)      :   # Montants forcés
Local Integer TYPRAT         :   # Type de cours
Local Integer LEDTYP         :   # Type de référentiel
Local Char    LED(GLONLED)   :   # Référentiel

## Variables locales
Local Char    CURLED(GLONCUR)
Local Integer FLG1 , FLG2, FLGZ
Local Integer OK ,  STAT
Local Integer I,J, K


## Initialisation des variables
FLDNAM    = PARAM(1)
CPY       = PARAM(2)
CUR       = PARAM(3)
ACCDAT    = PARAM(4)
TYPRAT    = val(PARAM(7))
LEDTYP    = val(PARAM(8))
Call LECLED([L]CPY,[L]LEDTYP,[L]LED,[L]CURLED) From CPTDIV

For I=0 To 9
 FLG(I)=evalue(PARAM(5)+"("+num$(I)+")")
 AMT(I)=evalue(PARAM(6)+"("+num$(I)+")")
Next

Raz FLGZ
If FLDNAM="DEB" : FLGZ=1 : Endif
Gosub SETNOL
Call LECTURE("CPY",CPY,"") From CONTOBJ
Return


$DEBUT
## initialisation du masque
Raz [M:GAM]

# Masque [M:SCL] contient tous les cours à saisir pour les éventuels mouvements
# Rechercher et afficher (si nécessaire) : 
#    => le montant en devise de référentiel  (plusieurs référentiels si saisie colonne)
#    => le montant en devise du(des) référentiel(s) automatique(s)
#    => le montant en devise du(des) référentiel(s) généré(s)

Local Integer INDGCM,INDLED,WTYP,IND,AXE,NBMNT
Local Integer I,J

INDGCM = find([F:CPY]ACM,GGCM(1..GGCMNBR))

Raz NBMNT
Raz [M:HAEF]FLG

Case [M:HAEF]TYPENT
 When 1 
  # Saisie colonne
  For J=1 To GNBSTR
   If GSTRACC(J)<>""
    #---- Cours référentiel
    WTYP = GSTRTYP(J)
    If [M:SCL]LIGLED(WTYP-1)<>0
     [M:GAM]IDT(NBMNT)    =  mess(WTYP,2644,1)
     [M:GAM]LEDTYP(NBMNT) =  [M:HAEF]TYPC(WTYP-1) 
     [M:GAM]CUR(NBMNT)    =  [M:HAEF]CURC(WTYP-1) 
     NBMNT+=1
     [M:HAEF]FLG(WTYP-1)  = 2
    Endif

    #---- Cours automatiques liés au référentiel saisi.
    For I=1 To [M:HAEF]NBRC
     If GSTRLED(J)=[M:HAEF]LEDC(I-1) & [M:HAEF]AUTC(I-1)=2 
      If [M:SCL]LIGLED(I-1)<>0
       [M:GAM]IDT(NBMNT)    =  mess(I,2644,1)
       [M:GAM]LEDTYP(NBMNT) =  [M:HAEF]TYPC(I-1) 
       [M:GAM]CUR(NBMNT)    =  [M:HAEF]CURC(I-1) 
       NBMNT+=1
       [M:HAEF]FLG(I-1)  = 2
      Endif
     Endif
    Next
   Endif
  Next
     
 When 2
  # Saisie ligne

  #---- Cours référentiel
  WTYP = [L]LEDTYP
  If [M:SCL]LIGLED(WTYP-1)<>0
   [M:GAM]IDT(NBMNT)    =  mess(WTYP,2644,1)
   [M:GAM]LEDTYP(NBMNT) =  [M:HAEF]TYPC(WTYP-1) 
   [M:GAM]CUR(NBMNT)    =  [M:HAEF]CURC(WTYP-1) 
   NBMNT+=1
   [M:HAEF]FLG(WTYP-1)  = 2
  Endif

  #---- Cours automatiques liés au référentiel saisi.
  For I=1 To [M:HAEF]NBRC
   If [L]LED=[M:HAEF]LEDC(I-1) & [M:HAEF]AUTC(I-1)=2 
    If [M:SCL]LIGLED(I-1)<>0
     [M:GAM]IDT(NBMNT)    =  mess(I,2644,1)
     [M:GAM]LEDTYP(NBMNT) =  [M:HAEF]TYPC(I-1) 
     [M:GAM]CUR(NBMNT)    =  [M:HAEF]CURC(I-1) 
     NBMNT+=1
     [M:HAEF]FLG(I-1)  = 2
    Endif
   Endif
  Next

  #--- Cours générés + cours automatique liés au référentiel généré
  Call INIPRO([L]LED,NBMNT)
Endcase

[M:GAM]NBGAM=NBMNT

# Gestion de la monnaie IN
Raz [M:GAM]AUT
For I=0 To [M:GAM]NBGAM
 Call LECTURE("TCU",CUR,"") From CONTOBJ
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] or [F:TCU]EURDAT<=ACCDAT)
  Call LECTURE("TCU",[M:GAM]CUR(I),"") From CONTOBJ
  If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] or [F:TCU]EURDAT<=ACCDAT)
   [M:GAM]AUT(I)=2    # Devise de Transaction et Devise de Référentiel avec Monnaie IN, pas de saisie.
  Endif
 Endif
Next

## Recherche de l'existant
Raz [M:GAM]AMTLEDFLG, [M:GAM]AMTLED
For I=0 To [M:GAM]NBGAM-1
 J = [M:GAM]LEDTYP(I)-1
 # Affiché du montant forcé
 If [M:GAM]AUT(I)<>2 & FLG(J)<>0
  [M:GAM]AMTLEDFLG(I) = 2 
  [M:GAM]AMTLED(I) = AMT(J)
 Endif
Next

Affzo [M:GAM]
Return

Subprog INIPRO(LED,NB) 
Value    Char    LED()
Variable Integer NB

Local Integer IND,AXE, I 

For I=1 To [M:HAEF]NBRC
 If [M:HAEF]FLG(I-1)<>2
  If[M:HAEF]GENC(I-1)=2  or  ([L]LED=[M:HAEF]LEDC(I-1) and [M:HAEF]AUTC(I-1)=2)
   Call INDLED([M:HAEF]LEDC(I-1),"",IND,AXE) From CPTDIV
   If find(GLEDCOA(IND),GSTRCOA(1..GNBSTR)) 
    If [M:SCL]LIGLED(I-1)<>0 & !find([M:HAEF]TYPC(I-1),[M:GAM]LEDTYP(0..NB))
      [M:GAM]IDT(NB)    =  mess(I,2644,1)
      [M:GAM]LEDTYP(NB) =  [M:HAEF]TYPC(I-1) 
      [M:GAM]CUR(NB)    =  [M:HAEF]CURC(I-1) 
      NB+=1
    Endif
    [M:HAEF]FLG(I-1)  = 2
    Call INIPRO([M:HAEF]LEDC(I-1),NB)
   Endif
  Endif
 Endif
Next
End

$OK
For J=0 To [M:GAM]NBGAM-1
 I = [M:GAM]LEDTYP(J)-1
 If [M:GAM]AMTLEDFLG(J)=2  :  
   FLG(I)=1
   AMT(I)=[M:GAM]AMTLED(J)
 Else
   FLG(I)=0
   AMT(I)=0
 Endif
Next

# Mise à jour
For I=0 To 9
 Assign PARAM(5)+"("+num$(I)+")" With FLG(I)
 Assign PARAM(6)+"("+num$(I)+")" With AMT(I)
Next
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
Subprog AS_AMTLEDFLG(VALEUR)
Variable Integer VALEUR
If [M]AUT(nolign-1)=2
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog AS_AMTLED(VALEUR)
Variable Decimal VALEUR
If [M]AMTLEDFLG(nolign-1)<>2
 VALEUR = 0 : mkstat = 2
Endif
End


######################################################################################
$AVTMNT
For I=1 To 9
 Assign "[M]AMTFLG("+num$(I-1)+")" With evalue("[M]AMTFLG"+num$(I)+"("+num$(nolign-1)+")")
 Assign "[M]AMTFRC("+num$(I-1)+")" With evalue("[M]AMTFRC"+num$(I)+"("+num$(nolign-1)+")")
Next
Return

$APSMNT
For I=1 To 9
 Assign "[M]AMTFLG"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M]AMTFLG("+num$(I-1)+")")
 Assign "[M]AMTFRC"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M]AMTFRC("+num$(I-1)+")")
Next
Return


