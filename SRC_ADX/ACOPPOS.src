#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPPOS","ACOPPOS",3,"XYCOPPOS") From GTRAITE
End

######################################
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return
######################################
$INIT

TMP = 1
Return

$EXEC
Local Integer ABI
If filinfo(filpath("FIL","ALNKSUB","fde",[M]DOSORG),0) > 0 : ABI = 1 Else ABI = 0 : Endif
If ABI
 If filinfo(filpath("FIL","TABSUBDIV","fde",[M]DOSORG),0) > 0 : ABI = 1 Else ABI = 0 : Endif
 If ABI
  If filinfo(filpath("FIL","ALNKSUB","fde",[M]DOSDES),0) > 0 : ABI = 1 Else ABI = 0 : Endif
  If ABI
   If filinfo(filpath("FIL","TABSUBDIV","fde",[M]DOSDES),0) > 0 : ABI = 1 Else ABI = 0 : Endif
  Endif
 Endif
Endif
If ABI
 Call OUINON(mess(66,127,1),ABI) From GESECRAN : # Voulez-vous copier les subdivisions géographiques ?
 If ABI<>2 : ABI=0 : Endif
Endif
If [M]DOSORG=nomap 
 Local File POSCOD    [POS1]
 If ABI
  Local File TABSUBDIV [ATU1]
  Local File ALNKSUB   [ALB1]
  Local File ATEXTRA   [AXX1]
 Endif
Else 
 Local File =[M]DOSORG+".POSCOD"    [POS1]
 If ABI
  Local File =[M]DOSORG+".TABSUBDIV" [ATU1]
  Local File =[M]DOSORG+".ALNKSUB"   [ALB1]
  Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
 Endif
Endif 
If [M]DOSDES=nomap 
 Local File POSCOD    [POS2]
 If ABI
  Local File TABSUBDIV [ATU2]
  Local File ALNKSUB   [ALB2]
  Local File ATEXTRA   [AXX2]
 Endif
Else 
 Local File =[M]DOSDES+".POSCOD"    [POS2]
 If ABI
  Local File =[M]DOSDES+".TABSUBDIV" [ATU2]
  Local File =[M]DOSDES+".ALNKSUB"   [ALB2]
  Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
 Endif
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [POS1], [POS2] 
If ABI
 Close Local File [ATU1] , [ATU2] , [ALB1] , [ALB2] , [AXX1] , [AXX2]
Endif
Return

$TR_COP
GOK = 1
Trbegin [POS2]
Delete [POS2] Where CRY=[M]CRY
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".POSCOD" : Goto ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("POS2","") From GLOCK : Goto AB_TR_COP
Endif
If ABI
 Delete [ATU2] Where CRY=[M]CRY
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABSUBDIV" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATU2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ALB2] Where CRY=[M]CRY
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALNKSUB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALB2","") From GLOCK : Goto AB_TR_COP
 Endif
Endif
For [POS1] Where CRY=[M]CRY
 [F:POS2] = [F:POS1]
 If dim([F:POS2]UPDUSR)>0 : [F:POS2]UPDUSR = GUSER : Endif
 If dim([F:POS2]UPDDAT)>0 : [F:POS2]UPDDAT = date$ : Endif
 Write [POS2]
 If fstat
  GOK = 0 : Call FSTA("POS2") From GLOCK : Break
 Endif
Next
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
If ABI
 For [ATU1] Where CRY=[M]CRY
  [F:ATU2] = [F:ATU1]
  Call COPTEXTRA("TABSUBDIV","INTIT",[F:ATU1]CRYTYP,[F:ATU1]COD) From ATEXTRA
  If dim([F:ATU2]UPDUSR)>0 : [F:ATU2]UPDUSR = GUSER : Endif
  If dim([F:ATU2]UPDDAT)>0 : [F:ATU2]UPDDAT = date$ : Endif
  Write [ATU2]
  If fstat
   GOK = 0 : Call FSTA("ATU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALB1] Where CRY=[M]CRY
  [F:ALB2] = [F:ALB1]
  If dim([F:ATU2]UPDUSR)>0 : [F:ATU2]UPDUSR = GUSER : Endif
  If dim([F:ATU2]UPDDAT)>0 : [F:ATU2]UPDDAT = date$ : Endif
  Write [ALB2]
  If fstat
   GOK = 0 : Call FSTA("ALB2") From GLOCK : Break
  Endif
 Next
Endif
Commit
zonsui = "CRY"
SAI = 1
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
## Etiquette ajoutée par le superviseur (écran ACOPPOS) 23/10/2008 09:48:55 (CCL)
######################################################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Call CTL_DROIT_DOSSIER(VALEUR,"E") From DOSCONT
If mkstat : End : Endif
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
If mkstat : End : Endif
GDOSPATH = VALEUR
End


######################################################################################
