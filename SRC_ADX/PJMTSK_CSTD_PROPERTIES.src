###################################################################################################
# RTKO.RAFFT
###################################################################################################
$RTKO_RAFFT_POASTR
  Case [L]ARULE
    When "CONTROL"   : Gosub RTKO_RAFFT_POASTR_CONTROL
  Endcase
Return

$RTKO_RAFFT_POASTR_CONTROL
  If this.POASTR = [0/0/0] Then
    #If this.APARENT.APARENT.TASSTATE <> 1 and this.APARENT.APARENT.TASSTATE <> 5 Then                                           # Issue X3-85933 - 2018-06-20 by FGR
    If this.APARENT.APARENT.TASSTATE <> 1 and this.APARENT.APARENT.TASSTATE <> 4 and this.APARENT.APARENT.TASSTATE <> 5 Then     # Issue X3-85933 - 2018-06-20 by FGR
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POASTR", mess(449,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$RTKO_RAFFT_POAEND
  Case [L]ARULE
    When "CONTROL"   : Gosub RTKO_RAFFT_POAEND_CONTROL
  Endcase
Return

$RTKO_RAFFT_POAEND_CONTROL
  If this.POAEND = [0/0/0] Then
    #If this.APARENT.APARENT.TASSTATE <> 1 and this.APARENT.APARENT.TASSTATE <> 5 Then                                           # Issue X3-85933 - 2018-06-20 by FGR
    If this.APARENT.APARENT.TASSTATE <> 1 and this.APARENT.APARENT.TASSTATE <> 4 and this.APARENT.APARENT.TASSTATE <> 5 Then     # Issue X3-85933 - 2018-06-20 by FGR
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POAEND", mess(449,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
# RTKO.OPLNK
###################################################################################################
$RTKO_OPLNK_OPENUMLNK
  Case [L]ARULE
    When "CONTROL"       : Gosub RTKO_OPLNK_OPENUMLNK_CONTROL
  Endcase
Return

$RTKO_OPLNK_OPENUMLNK_CONTROL
Local Integer IOPELNK

  IOPELNK = fmet this.APARENT.APARENT.RTKO_GET_INDEX(this.OPENUMLNK, this.OPESPNUMLNK)
  If IOPELNK = 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUMLNK", mess(268,2260,1), [V]CST_AERROR))
  Else
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.OPENUMLNK <> this.snapshot.OPENUMLNK or this.OPESPNUMLNK <> this.snapshot.OPESPNUMLNK)) Then
      If this.APARENT.APARENT.RTKO(IOPELNK).OPESTA = 5 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUMLNK", func AFNC.MES1(mess(924,2260,1), mess(this.APARENT.APARENT.RTKO(IOPELNK).OPESTA,308,1)), [V]CST_AERROR))
      Endif
      If this.APARENT.OPENUM = this.OPENUMLNK Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUMLNK", func AFNC.MES1(mess(934,2260,1), num$(this.APARENT.OPENUM)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
# RITT
###################################################################################################
$RITT_ITMREF
  Case [L]ARULE
    When "CONTROL"   : Gosub RITT_ITMREF_CONTROL
  Endcase
Return

$RITT_ITMREF_CONTROL
Local Integer NI
Local Integer NI1

  # Issue X3-77618 - 2018-02-26 by FGR : BEGIN
  If this.ASTALIN = [V]CST_AUPD Then
    If this.APARENT.TASSTATE <> 1 and this.snapshot.ITMREF <> this.ITMREF Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES1(mess(1056,2260,1), mess(this.APARENT.TASSTATE,2250,1)), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-77618 - 2018-02-26 by FGR : END
  NI = find(this.ITMREF, this.APARENT.RITT(1..maxtab(this.APARENT.RITT)).ITMREF)
  While NI > 0
    If this.APARENT.RITT(NI) <> null and this.APARENT.RITT(NI) <> this and find(this.APARENT.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES2(mess(492,2260,1), this.ITMREF, num$(NI)), [V]CST_AERROR))
      Break
    Else
      NI1 = NI
      NI = find(this.ITMREF, this.APARENT.RITT(NI+1..maxtab(this.APARENT.RITT)).ITMREF)
      If NI > 0 Then
        NI += NI1
      Endif
    Endif
  Wend
Return

###################################################################################################
$RITT_FRCDLTALLFLG
  # Issue X3-101833 - 2018-07-30 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub RITT_FRCDLTALLFLG_CONTROL
  Endcase
Return

$RITT_FRCDLTALLFLG_CONTROL
  # Issue X3-101833 - 2018-07-30 by FGR
  If this.APARENT.TASSTATE = 1 and this.FRCDLTALLFLG <> [V]CST_ANO Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FRCDLTALLFLG", mess(18,9804,1), [V]CST_AERROR))
  Elsif this.APARENT.TASSTATE <> 5 and this.APARENT.TASSTATE <> 2 and this.APARENT.TASSTATE <> 3 Then
    If this.ASTALIN = [V]CST_AUPD Then
      If this.FRCDLTALLFLG <> this.snapshot.FRCDLTALLFLG Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FRCDLTALLFLG", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Elsif this.ASTALIN = [V]CST_ANEW Then
      If this.FRCDLTALLFLG <> [V]CST_ANO Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FRCDLTALLFLG", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

