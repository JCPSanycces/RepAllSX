#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTAS
###################################################################################################
$TASCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub TASCOD_CONTROL
  Endcase
Return

$TASCOD_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.TASCOD <> this.snapshot.TASCOD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TASFCY
  Case [L]ARULE
    When "CONTROL"   : Gosub TASFCY_CONTROL
    When "PROPAGATE" : Gosub TASFCY_PROPAGATE
  Endcase
Return

$TASFCY_CONTROL
Local Integer NI

  If this.ASTALIN = [V]CST_AUPD and this.TASFCY <> this.snapshot.TASFCY Then
    #If fmet this.RTKO_COUNT() > 0 Then                              # Issue X3-65941 - 2018-01-15 by FGR
    If fmet this.RTKO_COUNT() > 0 or fmet this.RITT_COUNT() > 0 Then # Issue X3-65941 - 2018-01-15 by FGR
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_ANEW Then
    For NI = 1 To maxtab(this.RTKO)
      If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TASFCY <> this.RTKO(NI).TASFCY Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
        Endif
        Break
      Endif
    Next NI
    # Issue X3-65941 - 2018-01-15 by FGR : BEGIN
    For NI = 1 To maxtab(this.RITT)
      If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TASFCY <> this.RITT(NI).TASFCY Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
        Endif
        Break
      Endif
    Next NI
    # Issue X3-65941 - 2018-01-15 by FGR : END
  Endif
Return

$TASFCY_PROPAGATE
  this.PIMPL.FCY = this.TASFCY
Return

###################################################################################################
$TCACOD
  Case [L]ARULE
    When "CONTROL"   : Gosub TCACOD_CONTROL
    When "PROPAGATE" : Gosub TCACOD_PROPAGATE
  Endcase
Return

$TCACOD_CONTROL
Local Integer IPYMTYP

  IPIMTYP = fmet this.GET_PIMTYP_FROM_TCACOD(this.TCACOD)
  If IPIMTYP <> 5 and IPIMTYP <> 6 and IPIMTYP <> 7 and IPIMTYP <> 8 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(169,2260,1) - ":" - this.TCACOD, [V]CST_AERROR))
  Endif
  # ------------------
  If this.ASTALIN = [V]CST_ANEW Then
    If IPIMTYP = 6 or IPIMTYP = 8 Then
      # Matière or divers
      If fmet this.RTKO_COUNT() > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(328,2260,1), [V]CST_AERROR))
      Endif
    Endif
    If IPIMTYP = 5 or IPIMTYP = 8 Then
      # Operation or divers
      If fmet this.RITT_COUNT() > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(328,2260,1), [V]CST_AERROR))
      Endif
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.TCACOD <> this.snapshot.TCACOD Then
      If this.TASSTATE = 1 Then
        # If task status is "new", can be changed as when "this.ASTALIN = [V]CST_ANEW"
        If IPIMTYP = 6 or IPIMTYP = 8 Then
          # Matière or divers
          If fmet this.RTKO_COUNT() > 0 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(328,2260,1), [V]CST_AERROR))
          Endif
        Endif
        If IPIMTYP = 5 or IPIMTYP = 8 Then
          # Operation or divers
          If fmet this.RITT_COUNT() > 0 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(328,2260,1), [V]CST_AERROR))
          Endif
        Endif
      Else
        # If greater than new categorie can't be changed.
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

$TCACOD_PROPAGATE
Local Integer IPYMTYP

  IPIMTYP = fmet this.GET_PIMTYP_FROM_TCACOD(this.TCACOD)
  If IPIMTYP = -1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCACOD", mess(169,2260,1) - ":" - this.TCACOD, [V]CST_AERROR))
  Else
    this.PIMPL.PIMTYP = IPIMTYP
  Endif
Return

###################################################################################################
$TASSTATE
  Case [L]ARULE
    When "INIT"      : Gosub TASSTATE_INIT
    When "CONTROL"   : Gosub TASSTATE_CONTROL
    When "PROPAGATE" : Gosub TASSTATE_PROPAGATE
  Endcase
Return

$TASSTATE_INIT
  this.TASSTATE = 1
Return

$TASSTATE_CONTROL
  # ----------------------
  If this.TASSTATE <> 1 and this.TASSTATE <> 2 and this.TASSTATE <> 3 and this.TASSTATE <> 4 and this.TASSTATE <> 5 and this.TASSTATE <> 9 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1), [V]CST_AERROR))
  Endif
  # ----------------------
  Case this.TCHACTION
    When "PLANNED"
      If this.TASSTATE <> 5 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "LAUNCH"
      If this.TASSTATE <> 2 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "TIMEENTRY"
      # TODO FGR not done at the moment. Check later
      If this.TASSTATE <> this.snapshot.TASSTATE and this.TASSTATE <> 3 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "CLOSING"
      If this.TASSTATE <> 4 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "SUSPENSION"
      If this.TASSTATE <> 9 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "STARTED"
      If this.TASSTATE <> 3 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
      Endif
    When "REACTIVATE"
      # TODO : FLORENT ICI : voir le controle à ce niveau
    When Default
      If this.ASTALIN = [V]CST_ANEW Then
        If this.TASSTATE <> 1 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(18,9804,1), [V]CST_AERROR))
        Endif
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.TASSTATE <> this.snapshot.TASSTATE Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(311,2260,1) - "(" + mess(this.TASSTATE,2250,1) + ")", [V]CST_AERROR))
        Endif
      Endif
  Endcase
  # ----------------------
Return

$TASSTATE_PROPAGATE
Local Integer NI

  # ----------------------
  If this.ASTALIN = [V]CST_ANEW Then
    this.PIMPL.TASSTATE = this.TASSTATE
  Else
    this.PIMPL.TCHACTION = "STATUS"
    this.PIMPL.TASSTATE = this.TASSTATE
  Endif
  # ----------------------
  # To be able to manage ORDERS class, if the status is changed, all RITT have to be at least updated
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If find(this.RITT(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
        this.RITT(NI).TCHFRCUPD = time
        this.RITT(NI).TCHTASSTATE = this.TASSTATE
      Endif
    Endif
  Next NI
  # ----------------------
Return

###################################################################################################
$TASSTARTDT
  Case [L]ARULE
    When "CONTROL"   : Gosub TASSTARTDT_CONTROL
    When "PROPAGATE" : Gosub TASSTARTDT_PROPAGATE
  Endcase
Return

$TASSTARTDT_CONTROL
  [L]ASTATUS = [V]CST_AOK
  # ----------------------
  If this.ASTALIN = [V]CST_AUPD and this.TASSTARTDT <> this.snapshot.TASSTARTDT Then
    Local File PJMTSKLNK [PTLNK]
    Local File PJMTSK [PJTA]
    Filter [PTLNK] Where [F:PTLNK]OPPNUM <> this.OPPNUM and [F:PTLNK]PIMOPPTASLNK = this.KEYCONCAT and ([F:PTLNK]TASLNKTYP = 2 or [F:PTLNK]TASLNKTYP = 4)
    For [PTLNK]
      Read [PJTA]PTA0=[F:PTLNK]OPPNUM;[F:PTLNK]TASCOD
      # ----------------------
      Case [F:PTLNK]TASLNKTYP
        When 2
          # Start to start
          If [F:PJTA]TASSTARTDT < this.TASSTARTDT Then
            Case [F:PTLNK]TASLNKCSTR
              When 1
                # Flexible
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES3(mess(914,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AWARNING))
              When 2
                # Strict
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES3(mess(913,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AERROR))
            Endcase
          Endif
        When 4
          # Start to end
          If [F:PJTA]TASENDDT < this.TASSTARTDT Then
            Case [F:PTLNK]TASLNKCSTR
              When 1
                # Flexible
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES3(mess(918,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AWARNING))
              When 2
                # Strict
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES3(mess(917,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AERROR))
            Endcase
          Endif
      Endcase
    Next
    Filter [PTLNK]
  Endif
Return

$TASSTARTDT_PROPAGATE
Local Date RDATE
Local Integer IRETURN_VALUE
Local Char SHMEMPTY(GLONHM)

  [L]ASTATUS = [V]CST_AOK
  # ----------------------
  [L]IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "TASSTARTDT", this.TASFCY, AVOID.ACHAR, AVOID.ACHAR, this.TASSTARTDT, AVOID.ACHAR, 1, RDATE, SHMEMPTY)
  [L]ASTATUS = max([L]ASTATUS, [L]IRETURN_VALUE)
  If [L]IRETURN_VALUE < [V]CST_AERROR Then
    this.TASSTARTDT = RDATE
  Endif
  # ----------------------
Return

###################################################################################################
$TASENDDT
  Case [L]ARULE
    When "CONTROL"   : Gosub TASENDDT_CONTROL
    When "PROPAGATE" : Gosub TASENDDT_PROPAGATE
  Endcase
Return

$TASENDDT_CONTROL
  [L]ASTATUS = [V]CST_AOK
  # ----------------------
  If this.ASTALIN = [V]CST_AUPD and this.TASENDDT <> this.snapshot.TASENDDT Then
    Local File PJMTSKLNK [PTLNK]
    Local File PJMTSK [PJTA]
    Filter [PTLNK] Where [F:PTLNK]OPPNUM <> this.OPPNUM and [F:PTLNK]PIMOPPTASLNK = this.KEYCONCAT and ([F:PTLNK]TASLNKTYP = 1 or [F:PTLNK]TASLNKTYP = 3)
    For [PTLNK]
      Read [PJTA]PTA0=[F:PTLNK]OPPNUM;[F:PTLNK]TASCOD
      # ----------------------
      Case [F:PTLNK]TASLNKTYP
        When 1
          # End to start
          If [F:PJTA]TASSTARTDT < this.TASENDDT Then
            Case [F:PTLNK]TASLNKCSTR
              When 1
                # Flexible
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES3(mess(912,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AWARNING))
              When 2
                # Strict
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES3(mess(911,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AERROR))
            Endcase
          Endif
        When 3
          # End to end
          If [F:PJTA]TASENDDT < this.TASENDDT Then
            Case [F:PTLNK]TASLNKCSTR
              When 1
                # Flexible
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES3(mess(916,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AWARNING))
              When 2
                # Strict
                [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES3(mess(915,2260,1), [F:PJTA]TASCOD, [F:PJTA]OPPNUM, this.TASCOD), [V]CST_AERROR))
            Endcase
          Endif
      Endcase
      # ----------------------
    Next
    Filter [PTLNK]
  Endif
  # ----------------------
Return

$TASENDDT_PROPAGATE
Local Date RDATE
Local Integer IRETURN_VALUE
Local Char SHMEMPTY(GLONHM)

  [L]ASTATUS = [V]CST_AOK
  # ----------------------
  [L]IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(this, "TASENDDT", this.TASFCY, AVOID.ACHAR, AVOID.ACHAR, this.TASENDDT, AVOID.ACHAR, 1, RDATE, SHMEMPTY)
  [L]ASTATUS = max([L]ASTATUS, [L]IRETURN_VALUE)
  If [L]IRETURN_VALUE < [V]CST_AERROR Then
    this.TASENDDT = RDATE
  Endif
  # ----------------------
Return

###################################################################################################
$PBUCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUCOD_CONTROL
    When "PROPAGATE" : Gosub PBUCOD_PROPAGATE
  Endcase
Return

$PBUCOD_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PBUCOD <> this.snapshot.PBUCOD Then
      If fmet this.SPLD_EXISTING() = [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(477,2260,1), [V]CST_AERROR))
      Endif
      # Budget can’t be changed if time entry is existing on the task.
      If func PJMTIMEMP_CSTD_PROGS.IS_PJMTEMEMP_FOR_TAS(this.OPPNUM, this.TASCOD) = [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(473,2260,1), this.TASCOD), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

$PBUCOD_PROPAGATE
  # ----------------------
  If this.ASTALIN = [V]CST_ANEW Then
    this.PIMPL.PBUCOD = this.PBUCOD
  Else
    this.PIMPL.TCHACTION = "STATUS"
    this.PIMPL.PBUCOD = this.PBUCOD
  Endif
  # ----------------------
Return

###################################################################################################
$TASTYP
  Case [L]ARULE
    When "INIT"      : Gosub TASTYP_INIT
    When "CONTROL"   : Gosub TASTYP_CONTROL
  Endcase
Return

$TASTYP_INIT
  this.TASTYP = 1
Return

$TASTYP_CONTROL
  If this.ASTALIN = [V]CST_ANEW Then
    If this.TASTYP <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASTYP", mess(18,9804,1) - "(" + mess(this.TASTYP,2258,1) + ")", [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.TCHACTION <> "PLANNED" and this.TCHACTION <> "LAUNCH" and this.TCHACTION <> "REACTIVATE" Then
      If this.TASTYP <> this.snapshot.TASTYP Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASTYP", mess(18,9804,1) - "(" + mess(this.TASTYP,2258,1) + ")", [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$TASTLA
  Case [L]ARULE
    When "INIT"      : Gosub TASTLA_INIT
  Endcase
Return

$TASTLA_INIT
  this.TASTLA = [V]CST_ANO
Return

###################################################################################################
$TASDATL
  Case [L]ARULE
    When "CONTROL"   : Gosub TASDATL_CONTROL
  Endcase
Return

$TASDATL_CONTROL
  If this.TCHACTION <> "LAUNCH" Then
    If this.TASDATL <> this.snapshot.TASDATL Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASDATL", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TASDATH
  Case [L]ARULE
    When "CONTROL"   : Gosub TASDATH_CONTROL
  Endcase
Return

$TASDATH_CONTROL
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "REACTIVATE" Then
    If this.TASDATH <> this.snapshot.TASDATH Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASDATH", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TASDATS
  Case [L]ARULE
    When "CONTROL"   : Gosub TASDATS_CONTROL
  Endcase
Return

$TASDATS_CONTROL
  If this.TCHACTION <> "CLOSING" and this.TCHACTION <> "REACTIVATE" Then
    If this.TASDATS <> this.snapshot.TASDATS Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASDATS", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TASDATB
  Case [L]ARULE
    When "CONTROL"   : Gosub TASDATB_CONTROL
  Endcase
Return

$TASDATB_CONTROL
  If this.TCHACTION <> "TIMEENTRY" and this.TCHACTION <> "STARTED" Then
    If this.TASDATB <> this.snapshot.TASDATB Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASDATB", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TCHANSREQDAT
  Case [L]ARULE
    When "INIT"      : Gosub TCHANSREQDAT_INIT
  Endcase
Return

$TCHANSREQDAT_INIT
  this.TCHANSREQDAT = 2
Return

###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  this.KEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(this.ACTX, this.OPPNUM, this.TASCOD)
Return

###################################################################################################
$ORITAS
  Case [L]ARULE
    When "CONTROL"   : Gosub ORITAS_CONTROL
  Endcase
Return

$ORITAS_CONTROL
Local Char SMESSAGE(250)
Local Integer IPIMTYP

  If this.TCHACTION <> "COPY" Then
    If this.ORITAS <> this.snapshot.ORITAS Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORITAS", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.ORITAS <> AVOID.ACHAR Then
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.ORITAS, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
    If SMESSAGE <> AVOID.ACHAR Then
      [L]ASTATUS = fmet this.SETERROR("ORITAS", SMESSAGE, [V]CST_AERROR)
    Else
      If IPIMTYP <> 5 and IPIMTYP <> 6 and IPIMTYP <> 7 and IPIMTYP <> 8 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORITAS", func AFNC.MES1(mess(450,2260,1), this.ORITAS), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$PRCCPL
  Case [L]ARULE
    When "INIT"      : Gosub PRCCPL_INIT
    When "CONTROL"   : Gosub PRCCPL_CONTROL
  Endcase
Return

$PRCCPL_INIT
  this.PRCCPL = 0
Return

$PRCCPL_CONTROL
  If this.PRCCPL < 0 or this.PRCCPL > 100 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRCCPL", mess(981,2260,1), [V]CST_AERROR))
  Endif
Return

