#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR9 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:49"
A_USER  = "DOC"
A_STAMP = "20181109230349"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBAXECPR"
  If [M]NBAXECPR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR9 [CTR9]
Gosub HORODAT
Local Inpbox "CTR9" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR9] As [SIM_]
Grizo [CTR9]5
Grizo [CTR9]10
Grizo [CTR9]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR9]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=88 : Y1(1)=3 : Y2(1)=6
X1(2)=1 : X2(2)=88 : Y1(2)=7 : Y2(2)=22
Return

$ON_FLGCTRCPT
Onevent AFTER_CHANGE Gosub AMM_FLGCTRCPT From W1CTR9
Onevent INIT_AREA Call D_FLGCTRCPT(zc) From W1CTR9
Onevent BEFORE_INPUT Call AS_FLGCTRCPT(zc) From W1CTR9
Return

Subprog D_FLGCTRCPT(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGCTRCPT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGCTRCPT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_FLGCTRCPT
Call AM_FLGCTRCPT(zc)
If !mkstat & GOBJET
 zoncou = "FLGCTRCPT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FLGCTRCPT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_FLGCTRCPT(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "FLGCTRCPT" : GZNUM = 47334 : Endif
Gosub _AFF
End

$ON_BPR
Onevent CONTROL Call C_BPR(zc) From W1CTR9
Return

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_BPR(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "BPR" : GZNUM = 46536 : Endif
Gosub _AFF
End

$ON_ACCCOD
Onevent CONTROL Call C_ACCCOD(zc) From W1CTR9
Onevent INIT_AREA Call D_ACCCOD(zc) From W1CTR9
Onevent BEFORE_INPUT Call AS_ACCCOD(zc) From W1CTR9
Onevent AFTER_CHANGE Gosub AMM_ACCCOD From W1CTR9
Return

Subprog D_ACCCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]ACCCOD,indice)=0
 If !GWEBSERV
  ## Action INITACCCOD
  Call INITACCCOD(VALEUR,35) From TRTX3
 Endif
Endif
Gosub _AFF
End

Subprog AS_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3946,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
If !GWEBSERV
 ## Action STD
 Call AS_ACCCOD(VALEUR) From SUBCTR
 If mkstat=2
  [M]ACCCOD(INDIC) = VALEUR
  Affzo ACCCOD(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_ACCCOD(zc) From W1CTR9
Onkey   2 Titled GBOUTS Call S_ACCCOD(zc) From W1CTR9
Onkey 144 Titled GBOUTP Call P_ACCCOD(zc) From W1CTR9
Onkey 146 Titled GBOUTA Call SA_ACCCOD(zc) From W1CTR9
Gosub _AFF
End

Subprog C_ACCCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTCAC
Call CONTCAC(VALEUR,"35") From SUBCAC
If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CAC","!",VALEUR,"35",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action STD
   Call C_ACCCOD(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_ACCCOD
Call AM_ACCCOD(zc)
If !mkstat & GOBJET
 zoncou = "ACCCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZACCCOD)")>indice
 [M]ACCCOD(indice) = VALEUR
 Affzo ZACCCOD(indice)
Endif
Gosub _AFF
End

Subprog S_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCAC
 Call SELCAC(VALEUR,"35") From SUBCAC
Endif
Gosub _AFF
End

Subprog B1_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNCAC
 Call TUNCAC(VALEUR,"35") From SUBCAC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CAC"
PARMSK(2) = "35"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "35"
Call VISU("CAC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZACCCOD
Onevent BEFORE_AREA Gosub AV_ZACCCOD From W1CTR9
Return

$AV_ZACCCOD
Call LECTEXTRA(zc,"GACCCODE","DESTRA","35",num$([M]ACCCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_DSP
Onevent CONTROL Call C_DSP(zc) From W1CTR9
Onevent AFTER_CHANGE Gosub AMM_DSP From W1CTR9
Onevent BEFORE_INPUT Call AS_DSP(zc) From W1CTR9
Return

Subprog AS_DSP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(4805,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DSP(zc) From W1CTR9
Onkey   2 Titled GBOUTS Call S_DSP(zc) From W1CTR9
Onkey 144 Titled GBOUTP Call P_DSP(zc) From W1CTR9
Onkey 146 Titled GBOUTA Call SA_DSP(zc) From W1CTR9
Gosub _AFF
End

Subprog C_DSP(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("DSP","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
If !mkstat
 ## Action STD
 Call C_DSP(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
 If !mkstat
  ## Action CTLDSP
  Call CTRL_DSP(VALEUR,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT) From TRTX3CPT
  If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DSP
Call AM_DSP(zc)
If !mkstat & GOBJET
 zoncou = "DSP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call AM_DSP(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
Endif
Gosub _AFF
End

Subprog S_DSP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "DSP"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_DSP(VALEUR)
Variable Char    VALEUR()
Call OBJET("DSP",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_DSP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "DSP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DSP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("DSP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DSPDES
Onevent INIT_AREA Call D_DSPDES(zc) From W1CTR9
Return

Subprog D_DSPDES(VALEUR)
Variable Char    VALEUR()
If varinit([M]DSPDES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"","","","") From ATEXTRA
Endif
Gosub _AFF
End

$ON_DIE
Return

$ON_ZDIE
Onevent BEFORE_AREA Gosub AV_ZDIE From W1CTR9
Return

$AV_ZDIE
Call LECTEXTRA(zc,"GDIE","DESTRA",num$([M]DIE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CCE
Onevent BEFORE_AREA Gosub AV_CCE From W1CTR9
Onevent CONTROL Call C_CCE(zc) From W1CTR9
Onevent BEFORE_INPUT Call AS_CCE(zc) From W1CTR9
Onevent AFTER_CHANGE Gosub AMM_CCE From W1CTR9
Return

$AV_CCE
## Action INICCEFMT
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
If GCCEFMT<>""
 Chgfmt [M]CCE(indice) With "K:"+GCCEFMT
Else
 Chgfmt [M]CCE(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3531,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CCE(VALEUR) From SUBCTR
If mkstat=2
 [M]CCE(INDIC) = VALEUR
 Affzo CCE(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CCE(zc) From W1CTR9
Onkey   2 Titled GBOUTS Call S_CCE(zc) From W1CTR9
Onkey 144 Titled GBOUTP Call P_CCE(zc) From W1CTR9
Onkey 146 Titled GBOUTA Call SA_CCE(zc) From W1CTR9
Gosub _AFF
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CCECHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CCECHOICE"
 PARMSK(1) = num$([M]DIE(nolign-1))
 Call S_TAB_CHAR(VALEUR,PARMSK,"CCECHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CCE","!",VALEUR,num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
 If !mkstat
  ## Action STD
  Call C_CCE(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
  If !GWEBSERV
   If !mkstat
    ## Action CNTCCE
    Call SECTION(VALEUR,2,[M:CTR0]ETRFCY,[0/0/0],[M]DIE(nolign-1)) From SUPCPT
    If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
   Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CCE
Call AM_CCE(zc)
If !mkstat & GOBJET
 zoncou = "CCE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CCE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCCE)")>indice
 [M]CCE(indice) = VALEUR
 Affzo ZCCE(indice)
Endif
Gosub _AFF
End

Subprog S_CCE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CCE"
PARMSK(2) = "!"
PARMSK(3) = num$([M]DIE(nolign-1))
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CCE(VALEUR)
Variable Char    VALEUR()
Call OBJET("CCE",VALEUR,num$([M]DIE(nolign-1))) From GOBJET
Gosub _AFF
End

Subprog SA_CCE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CCE"
PARMSK(2) = num$([M]DIE(nolign-1))
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CCE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$([M]DIE(nolign-1))
Call VISU("CCE",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCCE
Onevent BEFORE_AREA Gosub AV_ZCCE From W1CTR9
Return

$AV_ZCCE
Call LECTEXTRA(zc,"CACCE","DESTRA",num$([M]DIE(nolign-1)),num$([M]CCE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_INICCE
Onevent INIT_AREA Call D_INICCE(zc) From W1CTR9
Onevent BEFORE_INPUT Call AS_INICCE(zc) From W1CTR9
Onevent CONTROL Call C_INICCE(zc) From W1CTR9
Return

Subprog D_INICCE(VALEUR)
Variable Integer VALEUR
If varinit([M]INICCE,indice)=0
 VALEUR = 3
 ## Action STD
 Call D_INICCE(VALEUR) From SUBCTR
Endif
Gosub _AFF
End

Subprog AS_INICCE(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10315) From COMBOS
If !GWEBSERV
 ## Action STD
 Call AS_INICCE(VALEUR) From SUBCTR
 If mkstat=2
  [M]INICCE(INDIC) = VALEUR
  Affzo INICCE(INDIC) : mkstat = 2
 Endif
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10315,1))))
Endif
If !mkstat
 Discombo 0 From INICCE(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From INICCE(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_INICCE(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$CHG_STY
Return


