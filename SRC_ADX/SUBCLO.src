#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque CLOPER
Subprog AS_CREATGENE(VALEUR) 
Variable Integer VALEUR  
Local Integer NOL
NOL = nolign-1
If [M:DIA]FIYSTA(NOL)=1 : # LA214 Non ouvert
 VALEUR = 1 : mkstat=2 : End    
#Elsif [M:DIA]FIYSTA(NOL)=3 : # LA214 Fermé
 Elsif [M:DIA]FIYSTA(NOL)>2 : # DBA le 14/03/03  : Fermé en cpt gle ou complètement 
mkstat=2 : End    
Endif  
If [M:DIA]PERSTA(NOL)=3   :# période fermée
 mkstat=2 : End  
Elsif [M:DIA]PERSTA(NOL)=2   :# ouverte
 If nolign>1 
  If [M:DIA]CREATGENE(NOL-1)<>2 & [M:DIA]PERSTA(NOL-1)=2
   VALEUR=1 : mkstat=2 : End
  Endif
 Endif 
Endif
End 
 
Subprog C_CREATGENE(VALEUR) 
Variable Integer VALEUR   
Local Integer IJ  
If VALEUR<>2  
 For IJ=nolign To [M:DIA]NBLIG-1  
  [M:DIA]CREATGENE(IJ) = 1  
 Next IJ  
Endif 
End 

Subprog AS_CREATANA(VALEUR)  
Variable Integer VALEUR   
Local Integer NOL
NOL = nolign-1
If [M:DIA]FIYSTA(NOL)=1 : # LA214 Non ouvert
 VALEUR = 1 : mkstat=2 : End    
#Elsif [M:DIA]FIYSTA(NOL)=3 : # LA214 Fermé
 Elsif [M:DIA]FIYSTA(NOL)=4 : # DBA le 14/03/03  : Fermé complètement 
 mkstat=2 : End    
Endif  
If nolign=1
 If [M:DIA]CREATGENE(NOL)<>2 & [M:DIA]PERSTA(NOL)<>3
  VALEUR = 1 : mkstat=2 : End  
 Endif
Elsif nolign>1 
 If ([M:DIA]CREATANA(NOL-1)<>2) | ([M:DIA]CREATGENE(NOL)<>2 & [M:DIA]PERSTA(NOL)<>3)
  VALEUR = 1 : mkstat=2 : End  
 Endif
Endif 
End  

Subprog C_CREATANA(VALEUR)  
Variable Integer VALEUR   
Local Integer IJ   
If VALEUR<>2   
 For IJ=nolign To [M:DIA]NBLIG-1   
  [M:DIA]CREATANA(IJ) = 1   
 Next IJ   
Endif  
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
# A ne saisir qu'en Batch !
If [M]BATCH<>1
 mkstat=2 : End
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer  EXE_SUIV
Local Integer  I_J
If VALEUR<>[M:DIA]CPY
 [M:DIA]CPY = VALEUR
 Gosub CHARGE From CLOPER
 If !I_J
  GMESSAGE = VALEUR-mess(62,100,1)-"("-format$("D:"+GFMDAT,datesyst)-")" : # Toutes les périodes sont fermées
  [M:DIA]CPY = ""
#  GMESSAGE   = "#"  : # Pour schinter le Superviseur
  mkstat=1 : End
 Endif
 [M:DIA]NBLIG = I_J
 Affzo [DIA]
Endif
End

Subprog B2_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 2
Next I
Affzo LEDFLG
End

Subprog B3_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 1
Next I
Affzo LEDFLG
End

