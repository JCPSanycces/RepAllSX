                Read [XVP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
    Endif
Endif

If GPRODUIT = 3
    # n'existe plus en V6
    # abelx3 est dans X3......... depuis la v6
Endif





#--------------------------------------------#
# mise a jour ATEXTE de SUPERV160
# lecture dans le fichier XTS code langue FRA
# recherche du texte correspond 
# dans superv160 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 
#--------------------------------------------#

Raz WTAB_NUM
W_INDICE  =0

Filter [XUS] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XUS]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XUS]NUMERO
Next
Filter [XUS]


If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv160 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3 ou geode
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XUS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XUS]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV160_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XUS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XUS]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV160_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif



