#<AdxTL>@(#)8.0.0.0 $Revision$
##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits pour la V6
#  utilise par INDUS
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_160
Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE


#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en v5 X3 X3IND150
# il faudra aussi mettre a jour ABEIND150 car depuis v6 :  abel et x3 sont dans meme dossier
# et ensuite on regarde pour la v160
# ----------------------------------------


If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour X3IND150
    # lecture dans le fichier XVZ code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 150 pour x3 code XVZ X3IND150


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XVZ] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XVZ]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XVZ]NUMERO
    Next
    Filter [XVZ]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur X3IND150
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XVZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XVZ]COMMENT = WTEXTE_COMMENT
                Gosub X3IND150_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XVZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVZ]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif


    #---------------------------------------------
    # mise a jour ABEIND150
    #  à faire Gosub ABEIND150_TEXTE
    #  ne porte pas le même numéro 
    #  on le fait ici car dans le trt ASUPERV150 c'est fait aussi
    #  mais uniquement dans le cas d'un texte supervisuer
    # il faut aussi le faire sur un texte abel uniquement
    #---------------------------------------------


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XVY] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XVY]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XVY]NUMERO
    Next
    Filter [XVY]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur ABEIND150
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XVY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XVY]COMMENT = WTEXTE_COMMENT
                Gosub ABEIND150_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XVY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVY]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub ABEIND150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif



    #---------------------------------------------
    # mise a jour ABEIND140
    #  à faire Gosub ABEIND140_TEXTE
    #  ne porte pas le même numéro 
    #  on le fait ici car dans le trt ASUPERV140 c'est fait aussi
    #  mais uniquement dans le cas d'un texte supervisuer
    # il faut aussi le faire sur un texte abel uniquement
    #---------------------------------------------
    If GFOLDER_PRODUIT (0) <> ""
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XXY] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XXY]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XXY]NUMERO
        Next
        Filter [XXY]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur ABEIND140
            #Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XXY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XXY]COMMENT = WTEXTE_COMMENT
                    Gosub ABEIND140_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XXY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XXY]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub ABEIND140_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif
Endif

If GPRODUIT = 1
    #---------------------------------------------
    # mise a jour GOEIND150
    # lecture dans le fichier XVX code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
