Subprog IB_NBDOC
GBOUT1 = mess(202,124,1) : # Oui à tout le reste
GBOUT2 = mess(203,124,1) : # Non à tout le reste
End


Subprog B1_NBDOC
For I=nolign To [M:ATD2]NBDOC
  [M:ATD2]PROFLG(I-1)=2
Next I
Affzo [M:ATD2]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B2_NBDOC
For I=nolign To [M:ATD2]NBDOC
  [M:ATD2]PROFLG(I-1)=1
Next I
Affzo [M:ATD2]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End


