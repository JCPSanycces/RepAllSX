# ------------------------------------------------------------------------------

Subprog EXTPROCTRA(LANGO,LISTPROC,LISTLEG)
Value Char LANGO
Value Char LISTPROC()(1..)
Value Char LISTLEG()(1..)

#   Cette procédure extrait les textes des processus dans la langue LANGO
#   pour les processus/législation définis dans la liste LISTPROC / LISTLEG
#   Le fichier est produit sous le répertoire tmp du dossier courant.
#   On propose de l'exporter après production (vers le poste client)

Local Char NOMFIC(250),FIC1(200),PROCCOU,PROCF,VALL1(250),TTEXT(250)(1..30)
Local Integer NBPROC,NBTEX,NBTEXP,I,J,EXPT
Local Char HORDAT(14)
Call ENVVAR(HORDAT) From INTRUTILA
FIC1="PROC_"+HORDAT
NOMFIC=filpath("tmp",FIC1,"html")
Openo NOMFIC,0 Using [XML_]
Iomode adxifs "" Using [XML_]
Iomode adxirs "" Using [XML_]

# Export des textes des processus
Call OUVRE_TRACE(mess(252,123,1)) From LECFIC
Call ECR_TRACE(mess(239,123,1)-num$(date$)-num$(time$),0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(259,123,1)-" : "-LANGO,0) From GESECRAN     : # Langue
Call ECR_TRACE("",0) From GESECRAN


# chr$(239)+chr$(187)+chr$(191)  pour gérer le bom EF BB BF mais ne génère pas ce qu'il faut
Local Schar AA(3) : AA=chr$(239)+chr$(187)+chr$(191)
Iomode adxium GASCII Using [XML_]
Wrseq AA Using [XML_]
Iomode adxium GUTF8 Using [XML_]
Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [XML_]
Wrseq '<PROCESSUS DATEEXT="'+HORDAT+'" LANG="'+LANGO+'">' Using [XML_]
Local File APROCTEXTE [AXP]
Local Integer JJ,MM
Local Char CHAINE(250)
For I=1 To dim(LISTPROC)
   If LISTPROC(I)="" : Break 1 : Endif
   Filter [AXP] Where CODPRO=LISTPROC(I) and CODLEG=LISTLEG(I) and LANG=LANGO
   For [AXP]
   If [F:AXP]CODPRO<>PROCCOU : Gosub PROCNEW : Endif
   Setlob TTEXT With [F:AXP]CLBTEXT
   NBTEX+=1 : NBTEXP+=1
   Wrseq '<ID NO="'+[F:AXP]UNIQIDP+'">' Using [XML_]
   For J=1 To dim(TTEXT)
     If TTEXT(J)="" : Break 1 : Endif
     CHAINE = TTEXT(J)
     # CCL  115865
     JJ=instr(1,CHAINE,'\"')
     While JJ>0
        CHAINE=left$(CHAINE,JJ-1)  +'"'+right$(CHAINE,JJ+2)
        JJ=instr(1,CHAINE,'\"')
      Wend
     Wrseq CHAINE Using [XML_]
   Next J
   Wrseq '</ID>'+chr$(10) Using [XML_]
   Filter [AXP]
  Next
Next I

If PROCCOU<>""
  Wrseq '</PROC>' Using [XML_]
  Call ECR_TRACE(PROCCOU-" : "-num$(NBTEXP)-mess(258,123,1),0) From GESECRAN   : # texte(s)
Endif

Wrseq '</PROCESSUS>' Using [XML_]
Openo Using [XML_]

# Voulez vous exporter le fichier vers le poste client ?
Call OUINON(mess(268,123,1),EXPT) From GESECRAN
If EXPT=2
 Local Char RETOUR(250)
 Local Integer STAT
 Call COPCLI(NOMFIC,RETOUR,STAT) From ORDSYS

 Local Char NFIC(250) : NFIC=RETOUR
 Call SETNAM(NOMFIC,NFIC) From ORDSYS
 Call ECR_TRACE(mess(55,100,1)-":"-NFIC,0) From GESECRAN
Endif

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("-----------------------------------------------------------",0) From GESECRAN
# Nombre total de processus traités
Call ECR_TRACE(mess(256,123,1)-" : "-num$(NBPROC),0) From GESECRAN
# Nombre total de textes traités
Call ECR_TRACE(mess(257,123,1)-" : "-num$(NBTEX),0) From GESECRAN


Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC


End

$PROCNEW
If PROCCOU<>""
  Wrseq '</PROC>' Using [XML_]
  Call ECR_TRACE(PROCCOU-[F:AXP]CODLEG-" : "-num$(NBTEXP)-mess(258,123,1),0) From GESECRAN   : # texte(s)
Endif
PROCCOU=[F:AXP]CODPRO
Wrseq '<PROC NAME="'+PROCCOU+'" LEGISL="'+[F:AXP]CODLEG+'">' Using [XML_]
NBPROC+=1 : NBTEXP=0
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD2) 17/02/2009 15:31:05 (CCORA)
######################################################################################
Subprog AP_CODDEB(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]INTIT1,"APROCESSUS","INTIT1",VALEUR,"") From ATEXTRA
If VALEUR>[M]CODFIN
  [M]CODFIN=VALEUR
Endif
End

Subprog AP_CODFIN(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]INTIT2,"APROCESSUS","INTIT1",VALEUR,"") From ATEXTRA
If VALEUR<[M]CODDEB
   GMESSAGE=mess(202,100,1) : # bornes incorrectes
   mkstat=2
Endif
End


