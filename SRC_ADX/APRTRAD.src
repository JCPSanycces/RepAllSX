#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"APRTRAD","APRTRAD","SPEAPRTRAD") From GSAISIE
End


$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "BOUTON"      : Gosub BOUTON
Endcase
Return

$EXEC
$SORTIE
Return

$DEBUT
Effzo [M:ATD2]
[M]ALLMOD=2
[M]ALLCOD=2
[M]ATRAD=2
[M]TOUTLEG=2
Diszo [M:ATD2]MODULE
Diszo [M:ATD2]CODDEB
Diszo [M:ATD2]CODFIN
Diszo [M:ATD2]LEGIS
Affzo [M]
Return

$BOUTON
Case BOUT
   When "A" : Gosub RECHERCHE
   When "B" : Gosub EXPORT
Endcase
Return

$EXPORT
If [M]NBDOC=0 : Return : Endif
Local Char LISTPROC(10)(1..[M]NBDOC)
Local Char LISTLEG(10)(1..[M]NBDOC)
Local Integer I,NBELT
For I=0 To [M:ATD2]NBDOC-1
  If [M:ATD2]PROFLG(I)=2
    NBELT+=1
    LISTPROC(NBELT)=[M]COD(I)
    LISTLEG(NBELT)=[M]LEGISL(I)
  Endif
Next I
If NBELT>0
  Call EXTPROCTRA([M]LANREF,LISTPROC,LISTLEG) From APRTRAD
Endif
Return


$RECHERCHE
If clalev([F:APR])=0  : Local File APROCESSUS [APR]  : Endif
If clalev([F:AXP])=0  : Local File APROCTEXTE [AXP]  : Endif
If clalev([F:AXP1])=0 : Local File APROCTEXTE [AXP1] : Endif

Local Char FILTRE(250)
FILTRE="TYPEP=1 "
If [M]ALLCOD<>2
  Local Char CPDEB,CPFIN
  CPDEB=[M]CODDEB : If CPDEB="" : CPDEB="        " : Endif
  CPFIN=[M]CODFIN : If CPFIN="" : CPFIN="ZZZZZ" : Endif
  FILTRE+=' & CODPRO>="'+CPDEB+'" & CODPRO<="'+CPFIN+'"'
Endif
If [M]ALLMOD<>2 and MODULE<>0 : FILTRE+=' & MODULE='+num$([M]MODULE) : Endif
If [M]TOUTLEG<>2 and [M]LEGIS<>"" : FILTRE+=' & CODLEG="'+[M]LEGIS+'"' : Endif
Local Char TCODPRO(10)(0..dim([M]COD)-1),TCODLEG(10)(0..dim([M]COD)-1)
Local Date DATREF(0..dim([M]COD)-1),PDATREF,PDATLANG
Local Date DATPROC(0..dim([M]COD)-1)
Local Integer PEXIST(0..dim([M]COD)-1),PINCOMP(0..dim([M]COD)-1),PPEXIST,PPINCOMP
Local Integer NBPROC,I,ISSEL,PPT


Filter [APR] Where evalue(FILTRE)
For [APR]
  If [M]ATRAD=2
    Gosub CONTPROC
  Else
    ISSEL=1
    PPEXIST=1 : PPINCOMP=1
  Endif
  If ISSEL=1
   TCODPRO(NBPROC)=[F:APR]CODPRO
   TCODLEG(NBPROC)=[F:APR]CODLEG
   DATPROC(NBPROC)=PDATLANG
   DATREF(NBPROC)=PDATREF
   PEXIST(NBPROC)=PPEXIST
   PINCOMP(NBPROC)=PPINCOMP
   NBPROC+=1
  Endif
Next
Filter [APR]

#  Remplissage tableau

Effzo [M:ATD2]10
For I=1 To NBPROC
  [M]COD(I-1)=TCODPRO(I-1)
  [M]LEGISL(I-1)=TCODLEG(I-1)
  Call LECTEXTRA([M]TIT(I-1),"APROCESSUS","INTIT1",[M]COD(I-1),"") From ATEXTRA
  [M]VLDDAT(I-1)=DATPROC(I-1)
  [M]VLDDATREF(I-1)=DATREF(I-1)
  [M]EXIST(I-1)=PEXIST(I-1)
  [M]INCOMP(I-1)=PINCOMP(I-1)
Next I
[M]NBDOC=NBPROC
Affzo [M:ATD2]10

Return

$CONTPROC
ISSEL=0
PPEXIST=2
PPINCOMP=1
PPT=0
PDATLANG=[0/0/0]
If [F:APR]UPDDAT<>[0/0/0]
  PDATREF=[F:APR]UPDDAT
Else
  PDATREF=[F:APR]CREDAT
Endif
PDATLANG=[0/0/0]
Filter [AXP] Where CODPRO=[F:APR]CODPRO and CODLEG=[F:APR]CODLEG and LANG=[M]LANREF
For [AXP]
  Read [AXP1]AXP0=[F:APR]CODPRO;[F:APR]CODLEG;[M]LAN;[F:AXP]UNIQIDP
  If fstat<>0
    ISSEL=1 : PPINCOMP=2
  Else
   If PDATLANG=[0/0/0]
     If [F:AXP1]CREDAT<>[0/0/0] : PDATLANG=[F:AXP1]CREDAT : Endif
     If [F:AXP1]UPDDAT<>[0/0/0] : PDATLANG=[F:AXP1]UPDDAT : Endif
   Endif
   If [F:AXP]UPDDAT<>[0/0/0]
     If [F:AXP1]UPDDAT<>[0/0/0]
       If [F:AXP1]UPDDAT<[F:AXP]UPDDAT or ([F:AXP1]UPDDAT=[F:AXP]UPDDAT and [F:AXP1]UPDDATTIM<[F:AXP]UPDDATTIM)
         ISSEL=1
         If [F:AXP1]UPDDAT>PDATLANG : PDATLANG=[F:AXP1]UPDDAT : Endif
       Endif
     Else
       If [F:AXP1]CREDAT<[F:AXP]UPDDAT or ([F:AXP1]CREDAT=[F:AXP]UPDDAT and [F:AXP1]CREDATTIM<[F:AXP]UPDDATTIM)
         ISSEL=1
         If [F:AXP1]CREDAT>PDATLANG : PDATLANG=[F:AXP1]CREDAT : Endif
       Endif
     Endif
   Else
     If [F:AXP1]UPDDAT<>[0/0/0]
       If [F:AXP1]UPDDAT<[F:AXP]CREDAT or ([F:AXP1]UPDDAT=[F:AXP]CREDAT and [F:AXP1]UPDDATTIM<[F:AXP]CREDATTIM)
         ISSEL=1
         If [F:AXP1]UPDDAT>PDATLANG : PDATLANG=[F:AXP1]UPDDAT : Endif
       Endif
     Else
       If [F:AXP1]CREDAT<[F:AXP]CREDAT or ([F:AXP1]CREDAT=[F:AXP]CREDAT and [F:AXP1]CREDATTIM<[F:AXP]CREDATTIM)
         ISSEL=1
         If [F:AXP1]CREDAT>PDATLANG : PDATLANG=[F:AXP1]CREDAT : Endif
       Endif
     Endif
   Endif
  Endif
Next
Filter [AXP]
If PDATLANG=[0/0/0] : PPEXIST=1 : Endif
Return



######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD2) 02/02/2009 09:48:23 (CCORA)
######################################################################################
Subprog AM_ALLMOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:ATD2]MODULE  : Affzo [M:ATD2]MODULE : Diszo [M:ATD2]MODULE
Else
 Actzo [M:ATD2]MODULE
Endif
End

Subprog AM_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:ATD2]CODDEB = "" : [M:ATD2]INTIT1 = "" : Affzo [M:ATD2]CODDEB : Diszo [M:ATD2]CODDEB
 [M:ATD2]CODFIN = "" : [M:ATD2]INTIT2 = "" : Affzo [M:ATD2]CODFIN : Diszo [M:ATD2]CODFIN
Else
 Actzo [M:ATD2]CODDEB,CODFIN
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M:ATD2]CODFIN=""
    [M:ATD2]CODFIN=VALEUR : Affzo [M:ATD2]CODFIN
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:ATD2]CODDEB
Endif
End

Subprog AS_NBDOC
End


Subprog AM_PROFLG(VALEUR)
Variable Integer VALEUR
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD2) 02/02/2009 10:07:38 (CCORA)
######################################################################################
Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:ATD2]LANREF
    GERR = 1
    GMESSAGE = mess(54,176,1)
    mkstat=2
Else
    If VALEUR<>[M]LAN
        Effzo [M:ATD2]10
    Endif
Endif
End

Subprog AM_LANREF(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:ATD2]LAN
    GERR = 1
    GMESSAGE = mess(54,176,1)
    mkstat=2
Else
    If VALEUR<>[M]LANREF
        Effzo [M:ATD2]10
    Endif
Endif
End


