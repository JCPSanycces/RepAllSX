#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################################################################################
##         Source : SUBCIB                                                                                                ##
##         Auteur : JDE                                                                                                   ##
##         Date création : 170205                                                                                          ##
##         Parametrage de l'ajustement manuel (Cession intra-groupe)                                                      ##
############################################################################################################################
##  Modifications :
##  MDJ  10.11.2010 (FQ 69029) : Pb champs hors tableau si application du style CIG2 (cas de VINCI où nb de lignes important
##  MDJ  21/07/2006 (FQ 37132) : Calcul de la +- value                                                                      ##
##  MDJ  21/07/2006 (FQ 33838) : Interdiction de saisir un prix de cession négatif si bien avec montant positif           ##
##  MDJ  21/07/2006 (FQ 36178) : Ajout de la désignation CIG + ajout Désignation du bien                                  ##
##  MDJ  18/05/2006 (FQ 36163) : écart = total vente modifié - total vente (et non pas l'inverse)                         ##
##  MDJ  05/12/2005 (FQ 33624) : En AM_TRAITSEL on charge les bons paramètres associés à la nouvelle sélection affichée   ##
##  MDJ  28/11/2005 (FQ 33169) : Aménagement liste gauche principale et création d'une liste gauche des CIG traitées      ##
##                                                                                                                        ##
##  MDJ  11/10/2005 (FQ 32475) : Erreur sur ventilation montant vente                                                     ##
##                                                                                                                        ##
############################################################################################################################
##------------------------------------------------------------------------------------------------##
##  La fonction GESCIB permet d'inserer l'action GOBJET avec le parametre CIB dans le menu
##  L'action GOBJET appelle :
##       - La fenètre OCIB qui appelle les écrans CIB0
##       - Le traitement SUBCIB
##------------------------------------------------------------------------------------------------##
## PRINCIPALES ETIQUETTES UTILISEES                                                               ##
## $OUVRE             : avant ouverture de l'écran                                                ##
## $SETBOUT           : Affichage des boutons                                                     ##
## $EXEBOUT           : Traitement après click sur bouton                                         ##
## $VERIF_MOD         : avant enregistrement                                                      ##
## $APRES_MOD         : après enregistrement                                                      ##
## $LIENS             : affichage des infos après lecture de l'enr CIR                            ##
## $CHARGE_ENTETE_CIG : affichage des infos de la table CIG                                       ##
## $CHARGE_TRAITSEL   : affichage des infos liés à la sélection                                   ##
## $CHARGE_TABLEAU_CIB: Alimentation du tableau des postes à partir de la table CIB               ##
## $CHARGE_TOTAUX     : affichage des totalisations                                               ##
## Sous-prog REPORT_ECART : Report de l'écart. Parametre PEXLVENTMAJ = G_OUI ou G_NON :           ##
##                          Exclusion des biens dont le montant vente modifié par l'utilisateur   ##
## $STYLE                                                                                         ##
## $ECRIT_TABLE_CIB   : Ecriture des postes du tableau dans la table CIB                          ##
## $SELCIG4           : Sélection par click droit des sélection                                   ##
## $KILL_GLOBAL       : KIll de toutes les globales                                               ##
##------------------------------------------------------------------------------------------------##
## Gestion du masque CIG
#
Raz GPILOBJ
Call OBJET("CIB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
 #Infbox 'SUBCIB          action=' + ACTION

Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "LIENS"        : Gosub LIENS
    When "APRES_MOD"    : Gosub APRES_MOD
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "STYLE"        : Gosub STYLE
    When "END"          : Gosub FIN
    When "SETBOUT"      : Gosub SETBOUT     : # Gestion des boutons
    When "EXEBOUT"      : Gosub EXEBOUT     : # Traitement sur click des boutons
    When "OK"           : Gosub OK
    When "SEL_LISTE" : Gosub SEL_LISTE      : # Sélection des références de sélection CIG par click droit
When Default
Endcase

Return
###################################################################################################
## $OUVRE: avant ouverture de l'écran                                                            ##
###################################################################################################
$OUVRE
Global Decimal GDISSAMTOLD
Global Decimal GTOTISSAREP
Global Integer GIFINTABLE
Global Integer GIDEBTABLE
Global Integer GINUMPAGE
Global Integer GINUMPAGEMAX
Global Char    GCAASREFDEP (30) (9999)
Global Char    GCAASRECH
Global Integer GITRTLIENOK
Global Integer WIINFBOX

If clalev([F:CIG])  =0 : Local File CIGDEF    [CIG]          : Endif : # Définition CIG
If clalev([F:CIS])  =0 : Local File CIGREXSEL [CIS]          : Endif : # Sélection CIG
If clalev([F:CIB1]) =0 : Local File CIGFXDSOR [CIB1]         : Endif : # Biens sortis CIG
If clalev([F:CIB])  =0 : Local File CIGFXDSOR [CIB]          : Endif : # Biens sortis CIG
If clalev([F:CIR2]) =0 : Local File CIGREX    [CIR2]         : Endif : # Paramétrage CIG
If clalev([F:AMK])  =0 : Local File AMSK      [AMK]          : Endif : # Dictionnaire écran
If clalev([F:FAS])  =0 : Local File FXDASSETS [FAS]          : Endif : # Biens comptables Fq-36178

Local Mask CIB0 [CIB0]

WIINFBOX      = G_NON
GIFINTABLE    = G_NON
GIDEBTABLE    = G_OUI
GITRTLIENOK   = G_OUI
GCAASREFDEP   = ""
GINUMPAGE     = 1
GINUMPAGEMAX  = 1

Return
#-------------------------------------------------------------------------------
$OUVRE_BOITE : #*** FQ 33169
  Gosub DECLARE_TIROIRS

Return
#-------------------------------------------------------------------------------
$DECLARE_TIROIRS
  # Récupération des positions des tiroirs en fonction de leurs noms et
  # affectation dans des variables locales
  Local Char LTI_CIGTRAIT  : LTI_CIGTRAIT  = 'GAU_CHE'+num$(find('CB2',OBJLIS(1..10))) : # CIG traitées
Return
#********************************************************************
$FILGAUCHE
#***FQ 33169

#***FQ 33169 : liste gauche supplémentaire = CIG déjà traitées
If currbox = LTI_CIGTRAIT Then
    # CIG déjà traitées
    Raz FILGAUSUP
    FILGAUSUP(0) = "[F:CIG]CIGSTA = 3"
Endif

#***FQ 33169 : liste gauche principale
#CRITERE = "[F:CIG]CIGSTA =2"
FILGAUCHE = "[F:CIG]CIGSTA =2"

#***/FQ 33169
Return
####################################################################################################
## $SEL_LISTE: Affichage d'une boite de selection contenant                                       ##
##              les sélection CIG                                                                 ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
## Le champ REFSELCIG posséde une sélection appelant l'action SELCIG3                             ##
## L'action SELCIG3 (modele standard SEL_LISTE) appelle le traitement standard SUBCIB             ##
##------------------------------------------------------------------------------------------------##
$SEL_LISTE
  Case LISTE
    When "SELCIG4"    : Gosub SELCIG4
  Endcase
Return

$SELCIG4
Local Integer I
Local Char WCREFSEL

TIT = mess(159,GML_MSGCIG,1)

I = 0
For WI=0 To [F:CIR]NBRSEL - 1
  I    += 1
  WCREFSEL = [F:CIR]REFSELCIG (WI)
  TEX(I)   = WCREFSEL
  Read [F:CIS]CIS0  =  WCREFSEL
  If fstat = 0
      TEXTE(I) = TEX(I) + '        ' + [F:CIS]SELCIGDES
  Endif
Next

NBTEX = I

If NBTEX = 0
    mkstat   = 2
    GMESSAGE = mess(160,GML_MSGCIG,1) - [M:CIB0]CPYSRC: GERR=1

Endif

Return
###################################################################################################
## $OK: Recupération ref AASREF pour la recherche                                                ##
###################################################################################################
$OK

GCAASRECH = [M:CIA1]AASREF

Return
####################################################################################################
## $SETBOUT                                                                                       ##
####################################################################################################
$SETBOUT

If GIFINTABLE    = G_NON  or GREP = 'C' or GREP = 'D' or GREP = 'M' or GREP = 'A'
  Call VIREBOUT(CHAINE,"G") From GOBJET
Else
    # On affiche le bouton B : Biens suivants
    CHAINE+="G"
Endif

If GIDEBTABLE    = G_OUI  or GREP = 'C' or GREP = 'D' or GREP = 'M' or GREP = 'A'
  Call VIREBOUT(CHAINE,"B") From GOBJET
Else
    # On affiche le bouton B : Pages précédentes
    CHAINE+="B"
Endif

If GREP = 'C' or GREP = 'D' or GREP = 'M' or GREP = 'A'
  Call VIREBOUT(CHAINE,"I") From GOBJET
Else
    # On affiche le bouton I : Recherche
    CHAINE+="I"
Endif

Return
####################################################################################################
## $EXEBOUT                                                                                       ##
####################################################################################################
$EXEBOUT
# On affiche le bouton B : Pages précédentes
# On affiche le bouton G : Biens Suivants
# On affiche le bouton H : Recherche

Case BOUT

 When "B" :
   GINUMPAGE -=1
   If GINUMPAGE = 1
       GIDEBTABLE = G_OUI
   Endif
   Gosub CHARGE_TABLEAU_CIB

 When "G" :
   GINUMPAGE += 1
   GIDEBTABLE                = G_NON

   If GINUMPAGE > GINUMPAGEMAX
        GINUMPAGEMAX = GINUMPAGE
   Endif
   Gosub CHARGE_TABLEAU_CIB

 When "I" :
   If GCAASRECH <> ""
       GINUMPAGE += 2
       GCAASREFDEP(GINUMPAGE) = GCAASRECH
       GIDEBTABLE                = G_NON

       If GINUMPAGE > GINUMPAGEMAX
            GINUMPAGEMAX = GINUMPAGE
       Endif
       Gosub CHARGE_TABLEAU_CIB
   Endif

Endcase

Return
####################################################################################################
## $APRES_MOD                                                                                     ##
####################################################################################################
$APRES_MOD

If WIINFBOX = G_OUI
  Infbox 'APRES_MOD'
Endif

Gosub ECRIT_TABLE_CIB

Return
###################################################################################################
## $VERIF_MOD: avant enregsitrement                                                              ##
###################################################################################################
$VERIF_MOD
#-------------------------------------------------------------------------------------------------#
# On recalcule le bon nombre de ligne , car si on a voulu creer une ligne puis si on a annulé      #
# une ligne est cree car le NBLIG n'est pas bon                                                   #
#-------------------------------------------------------------------------------------------------#
Local Integer WI
Local Integer WINULL
Local Integer LOK

WINULL = 0

For WI = 0 To [M:CIB0]NBLIG - 1

    If [M:CIB0]AASREF(WI) = ""
       WINULL = WI
       Break
    Endif

Next

If WINULL <>  0
    [M:CIB0]NBLIG =  WI
Endif

#--------------------------------------------------------------------------------------------------#
# Message si nouveau total montant différent du total vente                                        #
#--------------------------------------------------------------------------------------------------#
If [M:CIB0]TOTECART   <> 0
    Call OUINON(mess(153,GML_MSGCIG,1), LOK) From GESECRAN
    If LOK <> G_OUI
        mkstat=2
        OK  = 0
        FIN = 1
        GOK = 0
    Endif
Endif

Return


$APRES_MODIF

Return
####################################################################################################
## $LIENS                                                                                         ##
####################################################################################################
$LIENS

Affzo [M:CIB0]

Gosub CHARGE_ENTETE_CIG

Gosub CHARGE_TRAITSEL

GCAASREFDEP   = ""
GINUMPAGE     = 1
GINUMPAGEMAX  = 1
GIFINTABLE    = G_NON
GIDEBTABLE    = G_OUI
GCAASRECH     = ""

Gosub CHARGE_TABLEAU_CIB

Gosub CHARGE_TOTAUX

Affzo [M:CIB0]

Return
####################################################################################################
## $CHARGE_TRAITSEL                                                                               ##
####################################################################################################
$CHARGE_TRAITSEL

#------------------------------------------------------------------------------------------#
# Alimentation ecran des infos provenant de la table CIR                                   #
#------------------------------------------------------------------------------------------#
Read [F:CIR2]  =  [M:CIB0]CIGCOD; [M:CIB0]CPYSRC;[M:CIB0]CPYDES
If fstat = 0
    WJ = 0
    [M:CIB0]TRAITSEL     = [F:CIR2]REFSELCIG(WJ)
    #***FQ-36178
    Read [F:CIS]CIS0= [F:CIR2]REFSELCIG(WJ)
    If fstat = 0
       [M:CIB0]SELCIGDES = [F:CIS]SELCIGDES
    Endif
    #***/FQ-36178
    [M:CIB0]GACACNWIP    = [F:CIR2]GACACNWIP(WJ)
    [M:CIB0]GACACNREA    = [F:CIR2]GACACNREA(WJ)
    [M:CIB0]OWNTYPLEA    = [F:CIR2]OWNTYPLEA(WJ)
    [M:CIB0]PURDATEFF    = [F:CIR2]PURDATEFF(WJ)
    [M:CIB0]OUTDATEFF    = [F:CIR2]OUTDATEFF(WJ)
    [M:CIB0]SALPRIMOD    = [F:CIR2]SALPRIMOD(WJ)
    [M:CIB0]SALPRI       = [F:CIR2]SALPRI(WJ)
    [M:CIB0]SALPRIPLN    = [F:CIR2]SALPRIPLN(WJ)
    [M:CIB0]SALPRIDEF    = [F:CIR2]SALPRIDEF(WJ)

    #------------------------------------------------------------------------------------------#
    # S'il y a qu'une seule sélection :  le champ est grisé --> pas de sélection               #
    #------------------------------------------------------------------------------------------#

    If [F:CIR2]REFSELCIG(1) <> "" and [M:CIB0]CIGSTA <>  GVML_CIGSTAE and [M:CIB0]CIGSTA <> GVML_CIGSTAP
        Actzo [M:CIB0]TRAITSEL
    Else
        Diszo [M:CIB0]TRAITSEL
    Endif

Endif

Return
####################################################################################################
## $CHARGE_ENTETE_CIG                                                                             ##
####################################################################################################
$CHARGE_ENTETE_CIG


Local Integer WJ
Local Decimal WDISSAMT
Local Decimal WDISSAMTNEW

CALC_MOTEUR  = G_NON
MOTEUR_ACTIF = G_NON
#------------------------------------------------------------------------------------------#
# Alimentation ecran des infos provenant de la table CIG                                   #
#------------------------------------------------------------------------------------------#
Read [F:CIG]  =  [M:CIB0]CIGCOD
If fstat = 0
    [M:CIB0]DES    = [F:CIG]DES
    [M:CIB0]EFFDAT = [F:CIG]EFFDAT
    [M:CIB0]CIGTYP = [F:CIG]CIGTYP
    [M:CIB0]CIGSTA = [F:CIG]CIGSTA
    If [F:CIG]CIGSTA = GVML_CIGSTAE
        Diszo [M:CIB0]
    Else
        Actzo [M:CIB0]
    Endif
Endif

Return
####################################################################################################
## $CHARGE_TOTAUX                                                                                 ##
####################################################################################################
$CHARGE_TOTAUX

#***FQ-32475
 Local Decimal TOTAL_ISSAMT       # Total des montants de sortie
 Local Decimal DELTA_ISSAMT       # Différence entre le total montant vente et l'enveloppe de vente
 Local Decimal TOT_ISSAMTN    # Total des montants de sortie
 Local Decimal DELT_ISSAMTN    # Différence entre le total montant de vente modifié et l'enveloppe de vente
#***FQ-32475

#------------------------------------------------------------------------------------------#
# Les totaux sont calculés à partir des infos en table (et non a partir du tableau)        #
# Car le tableau peut ne pas contenir tous les enregistrements de la table (9999 enr max)  #
#------------------------------------------------------------------------------------------#
Filter [CIB] Where [F:CIB]CIGCOD = [M:CIB0]CIGCOD & [F:CIB]CPYSRC = [M:CIB0]CPYSRC & [F:CIB]REFSELCIG = [M:CIB0]TRAITSEL
For [CIB]
    WDISSAMT     += [F:CIB]ISSAMT
    If [F:CIB]FLGAASCCL = G_NON
        If [F:CIB]ISSAMTUPD <> 0
           WDISSAMTNEW  += [F:CIB]ISSAMTUPD
        Else
           WDISSAMTNEW  += [F:CIB]ISSAMT
        Endif
    Endif
Next
Filter  [CIB]


If [M:CIB0]SALPRI <> 0 & [M:CIB0]SALPRI <> WDISSAMT  & ([M:CIB0]SALPRIMOD = GVML_CIGEVN or [M:CIB0]SALPRIMOD = GVML_CIGEVB)
  #Gosub AJUSTEMENT_TOTAUX
Endif

[M:CIB0]TOTISS    = WDISSAMT + DELTA_ISSAMT
[M:CIB0]TOTISSNEW = WDISSAMTNEW  + DELTA_ISSAMT
#*** Fq-36163 [M:CIB0]TOTECART  = [M:CIB0]TOTISS - [M:CIB0]TOTISSNEW
 [M:CIB0]TOTECART  =  [M:CIB0]TOTISSNEW - [M:CIB0]TOTISS

#Gosub CHARGE_TABLEAU_CIB

Return
#-------------------------------------------
$AJUSTEMENT_TOTAUX

#***FQ-32475
  DELTA_ISSAMT= [M:CIB0]SALPRI -WDISSAMT
  If DELTA_ISSAMT <> 0
    # On modifie le montant de sortie du dernier BCO avec le Delta détecté
    Filter [CIB] Where [F:CIB]CIGCOD = [M:CIB0]CIGCOD and [F:CIB]CPYSRC = [M:CIB0]CPYSRC and [F:CIB]REFSELCIG = [M:CIB0]TRAITSEL
    Read [CIB]CIB0 Last
    If DELTA_ISSAMT < 0
     [F:CIB]ISSAMT+=DELTA_ISSAMT
    Else
      [F:CIB]ISSAMT-=DELTA_ISSAMT
    Endif
    Rewrite [CIB]
    If fstat    # Raf - err
      # Err ???
      GOK=0
      Return
    Endif
  Endif
#***FQ-32475

Return
#-------------------------------------------
####################################################################################################
## $CHARGE_TABLEAU_CIB: Alimentation du tableau des postes à partir de la table CIB               ##
####################################################################################################
$CHARGE_TABLEAU_CIB
Local Integer I
Local Integer WI
Local Char    WCLIB
Local Integer WILIGMAX

Effzo [M:CIB0]AASREF
Effzo [M:CIB0]FLGAASCCL
Effzo [M:CIB0]ISSAMT
Effzo [M:CIB0]EPR
Effzo [M:CIB0]NVA
Effzo [M:CIB0]GAL
Effzo [M:CIB0]PURDAT
Effzo [M:CIB0]ISSDAT
Effzo [M:CIB0]ISSSAT
Effzo [M:CIB0]CMP
Effzo [M:CIB0]FLGCMP
Effzo [M:CIB0]SET

WILIGMAX = 9999

Read [F:AMK]='CIB0'
If fstat = 0 and [F:AMK]NBLIGT(2) <> 0
     WILIGMAX = [F:AMK]NBLIGT(2)
Endif

GIFINTABLE = G_NON

##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau                                                                       ##
##------------------------------------------------------------------------------------------------##
## La 1ère alimentée est la ligne avec l'indice = 0                                               ##
## La variable de bas de tableau doit avoir le nombre de ligne (indice +1)                        ##
##------------------------------------------------------------------------------------------------##
WI= 0
Filter[F:CIB1] Where [F:CIB1]CIGCOD=[M:CIB0]CIGCOD & [F:CIB1]CPYSRC=[M:CIB0]CPYSRC &
&                    [F:CIB1]REFSELCIG = [M:CIB0]TRAITSEL & [F:CIB1]AASREF >= GCAASREFDEP(GINUMPAGE)
For [F:CIB1]
     If WI > WILIGMAX-1
        GCAASREFDEP(GINUMPAGE+1)  = [M:CIB0]AASREF(WI-1)
        GIFINTABLE                = G_OUI
        Affzo [M:CIB0]
        If GINUMPAGE+1 > GINUMPAGEMAX
            GMESSAGE = mess(180,GML_MSGCIG,1)  + num$(WILIGMAX) -  mess(181,GML_MSGCIG,1)  + '\' +   mess(182,GML_MSGCIG,1)   : GERR=1
        Endif
        Break
     Else
        [M:CIB0]AASREF(WI)    = [F:CIB1]AASREF
        #***FQ-36178
        Read[FAS]FAS0= [F:CIB1]AASREF
        If fstat = 0
          [M:CIB0]AASDES1(WI) = [F:FAS]AASDES1
        Endif
        #***/FQ-36178
        [M:CIB0]FLGAASCCL(WI) = [F:CIB1]FLGAASCCL
        [M:CIB0]ISSAMT(WI)    = [F:CIB1]ISSAMT
        [M:CIB0]ISSAMTUPD(WI) = [F:CIB1]ISSAMTUPD
        [M:CIB0]EPR(WI)       = [F:CIB1]EPR
        [M:CIB0]NVA(WI)       = [F:CIB1]NVA
        [M:CIB0]GAL(WI)       = [F:CIB1]GAL
        [M:CIB0]PURDAT(WI)    = [F:CIB1]PURDAT
        [M:CIB0]ISSDAT(WI)    = [F:CIB1]ISSDAT
        [M:CIB0]ISSSAT(WI)    = [F:CIB1]ISSSAT
        [M:CIB0]CMP(WI)       = [F:CIB1]CMP
        [M:CIB0]FLGCMP(WI)    = [F:CIB1]FLGCMP
        [M:CIB0]SET(WI)       = [F:CIB1]SET
        ####################################################
        #  Point d'entrée  (FQ-67165)                      #
        # Chargement de champs spécifiques dans le tableau #
        # des biens  (CIB0)                                #
        ####################################################
        GPOINT = "CHARG_CIB" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
        #### Point d'entrée - Fin ######################
        WI +=1
    Endif
Next
Filter[F:CIB1]
##------------------------------------------------------------------------------------------------##
## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##
##------------------------------------------------------------------------------------------------##
If WI <> 0
    [M:CIB0]NBLIG = WI
Endif

Affzo [M:CIB0]

Return
####################################################################################################
## $ECRIT_TABLE_CIB: Ecriture des postes du tableau dans la table CIB                             ##
####################################################################################################
$ECRIT_TABLE_CIB
Local Integer WI

If WIINFBOX = G_OUI
  Infbox 'ecrit-t'
Endif
##------------------------------------------------------------------------------------------------##
## - Lecture du tableau                                                                           ##
##------------------------------------------------------------------------------------------------##
Affzo [M:CIB0]

For WI = 0 To [M:CIB0]NBLIG - 1
    Read [F:CIB1]=[M:CIB0]CIGCOD; [M:CIB0]CPYSRC; [M:CIB0]TRAITSEL ; [M:CIB0]AASREF(WI)
    [F:CIB1]FLGAASCCL = [M:CIB0]FLGAASCCL(WI)
    [F:CIB1]ISSAMTUPD = [M:CIB0]ISSAMTUPD(WI)
    [F:CIB1]GAL       = [M:CIB0]GAL(WI)         #***Fq-36169
    ##################################################################
    #  Point d'entrée  (FQ-67165)                                    #
    # Enregistrement  de champs spécifiques dans la table CIGFXDSOR  #
    ##################################################################
    GPOINT = "UPDCIB" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
    #### Point d'entrée - Fin ######################
    Rewrite [F:CIB1]
Next

Return
####################################################################################################
## $STYLE                                                                                         ##
####################################################################################################
$STYLE

Local Integer WI

For WI = 0 To [M:CIB0]NBLIG - 1
    #------------------------------------------------------------------------------------------#
    # Ligne en gras si annulé                                                                  #
    # Montant vente maj non modifiable si bien annulé                                          #
    #------------------------------------------------------------------------------------------#
    If [M:CIB0]FLGAASCCL(WI) = G_OUI
        #FQ-69029 Chgstl [M:CIB0]NBLIG(WI)    With "CIG2"
        Diszo [M:CIB0]ISSAMTUPD(WI)

    Else
        #FQ-69029 Chgstl [M:CIB0]NBLIG(WI) With ""
    Endif
    #------------------------------------------------------------------------------------------#
    # Montant 'vente maj' non modifiable si bien avec date achat > date d'effet                #
    #------------------------------------------------------------------------------------------#
    If [M:CIB0]EFFDAT < [M:CIB0]PURDAT(WI)
        Diszo [M:CIB0]ISSAMTUPD(WI)
    Endif
Next

Return
####################################################################################################
## $FIN :                                                                                         ##
####################################################################################################
$FIN

Gosub KILL_GLOBAL

FIN = 1 : GOK = 0
Return
####################################################################################################
## $KILL_GLOBAL : KIll de toutes les globales                                                     ##
####################################################################################################
KILL_GLOBAL

If dim(GDISSAMTOLD)     > 0      : Kill GDISSAMTOLD : Endif
If dim(GTOTISSAREP)     > 0      : Kill GTOTISSAREP : Endif
If dim(GIFINTABLE )     > 0      : Kill GIFINTABLE  : Endif
If dim(GIDEBTABLE )     > 0      : Kill GIDEBTABLE  : Endif
If dim(GCAASREFDEP)     > 0      : Kill GCAASREFDEP : Endif
If dim(GINUMPAGE  )     > 0      : Kill GINUMPAGE   : Endif
If dim(GCAASRECH  )     > 0      : Kill GCAASRECH   : Endif
If dim(GITRTLIENOK)     > 0      : Kill GITRTLIENOK : Endif
If dim(WIINFBOX)     > 0      : Kill WIINFBOX: Endif

Return
####################################################################################################
## $REPORT_ECART : Report de l'écart. Parametre PEXLVENTMAJ = G_OUI ou G_NON :                    ##
##                 Exclusion des biens dont le montant de vente a été modifié par l'utilisateur   ##
####################################################################################################
Subprog REPORT_ECART(PEXLVENTMAJ)
Value  Integer  PEXLVENTMAJ

Local Integer WL
Local Integer WK
Local Decimal WARR
Local Decimal WDTOTISSNEW
WARR         = 0.00001
WDTOTISSNEW  =  0

Local Decimal WDTOTPOURC
Local Decimal WDTOTMONT
WDTOTPOURC = 0
WDTOTMONT = 0
#------------------------------------------------------------------------------------#
# Calcul du % à appliquer                                                            #
#------------------------------------------------------------------------------------#
If GTOTISSAREP  <> 0

    For WK = 0 To [M:CIB0]NBLIG - 1

        If [M:CIB0]FLGAASCCL(WK) = G_NON
            If [M:CIB0]ISSAMTUPD(WK) <> 0
               If PEXLVENTMAJ = G_NON
                   [M:CIB0]REPECART(WK)= arr([M:CIB0]ISSAMTUPD(WK)  / GTOTISSAREP , WARR  )
               Endif
            Else
               [M:CIB0]REPECART(WK)= arr([M:CIB0]ISSAMT(WK)  / GTOTISSAREP , WARR  )
            Endif
         WDTOTPOURC += [M:CIB0]REPECART(WK)
        Endif
    Next
#------------------------------------------------------------------------------------#
# Calcul de la fraction du montant écart à ajouter                                   #
#------------------------------------------------------------------------------------#
    For WK = 0 To [M:CIB0]NBLIG - 1

        If [M:CIB0]FLGAASCCL(WK) = G_NON
            [M:CIB0]REPMONT(WK)=  ar2([M:CIB0]TOTECART    * [M:CIB0]REPECART(WK) )
             WDTOTMONT += [M:CIB0]REPMONT(WK)

            If [M:CIB0]ISSAMTUPD(WK) <> 0
               [M:CIB0]ISSAMTUPD(WK) -= [M:CIB0]REPMONT(WK)
            Else
               [M:CIB0]ISSAMTUPD(WK)  = [M:CIB0]ISSAMT(WK)    - [M:CIB0]REPMONT(WK)
            Endif


            If [M:CIB0]ISSAMTUPD(WK) <> 0
               WDTOTISSNEW   += [M:CIB0]ISSAMTUPD(WK)
            Else
               WDTOTISSNEW   += [M:CIB0]ISSAMT(WK)
            Endif

       Endif

    Next

    #Infbox 'WDTOTMONT =' + num$(WDTOTMONT)
Endif

[M:CIB0]TOTISSNEW = WDTOTISSNEW
#*** Fq-36163 [M:CIB0]TOTECART  = [M:CIB0]TOTISS - [M:CIB0]TOTISSNEW
 [M:CIB0]TOTECART  =  [M:CIB0]TOTISSNEW - [M:CIB0]TOTISS
#------------------------------------------------------------------------------------#
# Si ecart diff 0 (du a probleme arrondi) --> ajout sur 1er montant modifié          #
#------------------------------------------------------------------------------------#
  #Fq-33838 Si montant mis à jour négatif ==> montant remis à zéro
     If  [M:CIB0]ISSAMTUPD(WK) < 0
        [M:CIB0]ISSAMTUPD(WK) = 0
     Endif

If [M:CIB0]TOTECART  <> 0
   For WK = 0 To [M:CIB0]NBLIG - 1

        If [M:CIB0]ISSAMTUPD(WK) <> 0
            [M:CIB0]ISSAMTUPD(WK) +=  [M:CIB0]TOTECART
            [M:CIB0]TOTISSNEW     +=  [M:CIB0]TOTECART
            Break

        Endif
    Next
Endif

#*** Fq-36163 [M:CIB0]TOTECART  = [M:CIB0]TOTISS - [M:CIB0]TOTISSNEW
 [M:CIB0]TOTECART  =  [M:CIB0]TOTISSNEW - [M:CIB0]TOTISS
Affzo [M:CIB0]

End
######################################################################################
## Rubrique TRAITSEL: Référence sélection                                           ##
######################################################################################
Subprog AM_TRAITSEL(VALEUR)
Variable Char    VALEUR()

Local Integer WI
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
[M:CIB0]TRAITSEL = VALEUR

Gosub CHARGE_ENTETE_CIG

GCAASREFDEP   = ""
GINUMPAGE     = 1
GINUMPAGEMAX  = 1
GIFINTABLE    = 0
GIDEBTABLE    = 0
GCAASRECH     = ""

#***<FQ 33624>

Effzo TRAITSEL, GACACNWIP,  OWNTYPLEA, PURDATEFF
Effzo OUTDATEFF,SALPRIMOD,  SALPRI,    SALPRIPLN, SALPRIDEF
#------------------------------------------------------------------------------------------#
# Alimentation ecran des infos provenant de la table CIR                                   #
#------------------------------------------------------------------------------------------#
Read [F:CIR2]  =  [M:CIB0]CIGCOD; [M:CIB0]CPYSRC;[M:CIB0]CPYDES
If fstat = 0
    For WI = 0 To [F:CIR2]NBRSEL-1
      If [F:CIR2]REFSELCIG(WI)= VALEUR
        [M:CIB0]TRAITSEL     = [F:CIR2]REFSELCIG(WI)
        [M:CIB0]GACACNWIP    = [F:CIR2]GACACNWIP(WI)
        [M:CIB0]GACACNREA    = [F:CIR2]GACACNREA(WI)
        [M:CIB0]OWNTYPLEA    = [F:CIR2]OWNTYPLEA(WI)
        [M:CIB0]PURDATEFF    = [F:CIR2]PURDATEFF(WI)
        [M:CIB0]OUTDATEFF    = [F:CIR2]OUTDATEFF(WI)
        [M:CIB0]SALPRIMOD    = [F:CIR2]SALPRIMOD(WI)
        [M:CIB0]SALPRI       = [F:CIR2]SALPRI(WI)
        [M:CIB0]SALPRIPLN    = [F:CIR2]SALPRIPLN(WI)
        [M:CIB0]SALPRIDEF    = [F:CIR2]SALPRIDEF(WI)
        Break
      Endif
    Next
Endif

#***</FQ 33624>
Gosub CHARGE_TABLEAU_CIB

Gosub CHARGE_TOTAUX

Affzo [M:CIB0]

End
######################################################################################
## Rubrique ISSAMTUPD: Montant de sortie modifié                                    ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_ISSAMTUPD(VALEUR)
Variable Decimal VALEUR

GDISSAMTOLD = VALEUR
End
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_ISSAMTUPD(VALEUR)
Variable Decimal VALEUR
#------------------------------------------------------------------------------------#
# Soustraction de l'ancienne valeur                                                  #
#------------------------------------------------------------------------------------#
If GDISSAMTOLD   <> 0
    [M:CIB0]TOTISSNEW -= GDISSAMTOLD
Else
    [M:CIB0]TOTISSNEW -= [M:CIB0]ISSAMT(nolign-1)
Endif

#***Fq-33838
If (VALEUR < 0)  &  ([M:CIB0]ISSAMT(nolign-1) >= 0)
    GMESSAGE = mess(211,GML_MSGCIG,1) : GERR=1 :  mkstat=2  : End # Saisie d'un montant négatif interdite pour ce bien
Endif

#------------------------------------------------------------------------------------#
# Ajout de la nouvelle valeur                                                        #
#------------------------------------------------------------------------------------#
If  VALEUR <> 0
    [M:CIB0]TOTISSNEW += VALEUR
Else
    [M:CIB0]TOTISSNEW += [M:CIB0]ISSAMT(nolign-1)
Endif

If VALEUR > [M:CIB0]TOTISS
    GMESSAGE = mess(209,GML_MSGCIG,1) : GERR=1
Endif

#*** Fq-36163 [M:CIB0]TOTECART  = [M:CIB0]TOTISS - [M:CIB0]TOTISSNEW
 [M:CIB0]TOTECART  =  [M:CIB0]TOTISSNEW - [M:CIB0]TOTISS
##--------------------------------------------------------------------------------------------##
## +/- value                                                                                  ##
##--------------------------------------------------------------------------------------------##
#***Fq-37132
If VALEUR <> 0
  [M:CIB0]GAL(nolign-1) =  VALEUR -  [M:CIB0]NVA(nolign-1)
Else
 [M:CIB0]GAL(nolign-1) =  [M:CIB0]ISSAMT(nolign-1) -  [M:CIB0]NVA(nolign-1)
Endif
#***Fq-37132
Affzo [M:CIB0]GAL(nolign-1)
Affzo [M:CIB0]TOTISSNEW
Affzo [M:CIB0]TOTECART

End
######################################################################################
## Rubrique FLGAASCCL: Indicateur bien annulé                                       ##
######################################################################################

#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_FLGAASCCL(VALEUR)
Variable Integer VALEUR

If VALEUR = G_NON
    If [M:CIB0]ISSAMTUPD(nolign-1) <> 0
        [M:CIB0]TOTISSNEW += [M:CIB0]ISSAMTUPD(nolign-1)
    Else
        [M:CIB0]TOTISSNEW += [M:CIB0]ISSAMT(nolign-1)
    Endif
    Chgstl [M:CIB0]NBLIG(nolign-1)    With ""
    Actzo [M:CIB0]ISSAMTUPD(nolign-1)
Else
    If [M:CIB0]ISSAMTUPD(nolign-1) <> 0
        [M:CIB0]TOTISSNEW -= [M:CIB0]ISSAMTUPD(nolign-1)
    Else
        [M:CIB0]TOTISSNEW -= [M:CIB0]ISSAMT(nolign-1)
    Endif
    Chgstl [M:CIB0]NBLIG(nolign-1)    With "CIG2"
    [M:CIB0]ISSAMTUPD(nolign-1) = 0
    Affzo [M:CIB0]ISSAMTUPD(nolign-1)
    Diszo [M:CIB0]ISSAMTUPD(nolign-1)

Endif

#*** Fq-36163 [M:CIB0]TOTECART  = [M:CIB0]TOTISS - [M:CIB0]TOTISSNEW
 [M:CIB0]TOTECART  =  [M:CIB0]TOTISSNEW - [M:CIB0]TOTISS

Affzo [M:CIB0]TOTECART
Affzo [M:CIB0]TOTISSNEW

End
######################################################################################
## Rubrique NBLIG : Variable de bas de tableau                                      ##
######################################################################################
#------------------------------------------------------------------------------------#
# Bouton 1 : B1                                                                      #
# Recopie de l'écart entre le total 'vente' et le total 'vente après modification'   #
# sur tous les biens non exclu                                                       #
#------------------------------------------------------------------------------------#
Subprog B1_NBLIG

GTOTISSAREP    = [M:CIB0]TOTISSNEW

Call REPORT_ECART(G_NON)
End
#------------------------------------------------------------------------------------#
# Bouton 2 : B2                                                                      #
# Recopie de l'écart entre le total 'vente' et le total 'vente après modification'   #
# sur tous les biens non exclu et n'ayant pas de 'montant vente maj' renseigné       #
#------------------------------------------------------------------------------------#
Subprog B2_NBLIG

Local Integer WL
Local Decimal WTOTAMTUPD
#------------------------------------------------------------------------------------#
# Calcul de la somme des montants ventes de tous les biens non exclu et n'ayant      #
# pas de 'montant vente maj' renseigné : necessaire pour le calcul du prorata        #
#------------------------------------------------------------------------------------#

GTOTISSAREP    = 0

For WL = 0 To [M:CIB0]NBLIG - 1

    If [M:CIB0]FLGAASCCL(WL) = G_NON
        If [M:CIB0]ISSAMTUPD(WL) = 0
           GTOTISSAREP    += [M:CIB0]ISSAMT(WL)
        Else
           WTOTAMTUPD += [M:CIB0]ISSAMTUPD(WL)
        Endif
    Endif
Next

If WTOTAMTUPD > [M:CIB0]TOTISS
    GMESSAGE = mess(210,GML_MSGCIG,1) : GERR=1 : mkstat=2 : End
Endif

If  GTOTISSAREP <> 0
  Call REPORT_ECART(G_OUI)
Endif

#***Fq-37132
For WL = 0 To [M:CIB0]NBLIG - 1
 [M:CIB0]GAL(WL)=[M:CIB0]ISSAMT(WL) - [M:CIB0]ISSAMTUPD(WL)
  Affzo  [M:CIB0]GAL(WL)
Next
#***Fq-37132

End
######################################################################################
## Rubrique AASREF : Référence                                                      ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant-zone                                                                         #
#------------------------------------------------------------------------------------#
Subprog AV_AASREF(VALEUR)
Variable Char    VALEUR()

Diszo [M:CIB0]AASREF

End
