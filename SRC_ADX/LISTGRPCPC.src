#<AdxTL>@(#)0.0.0.0 $Revision$
# JML 02/08/10 LOT P02
Call IMPRIME("LISTGRPCPC","") From ETAT
End

####################################################
## Compétences par salarié
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP)
Local Decimal NUMREQ
Local Integer NIVDEB, NIVFIN
Local Integer L_IJ                      : # JML 02/08/10 LOT P02 It's not possible to use [HRGCD]NUMLIG for unique key

If clalev([F:ARM])=0    : Local File AREPORTM   [ARM]   : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:GCP])=0    : Local File GRPCPC     [GCP]   : Endif
If clalev([F:HRGCD])=0  : Local File GRPCPCD    [HRGCD] : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("nivdeb",NBPAR,PARAMETRE,PARAM)    : [L]NIVDEB=val(PARAM)
Call GETPARAM("nivfin",NBPAR,PARAMETRE,PARAM)    : [L]NIVFIN=val(PARAM)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call DEBTRANS From GLOCK
Gosub TR1
Call DEBTRANS From GLOCK
Gosub TR2
Call TEMPOFF From GESECRAN
End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]
 L_IJ = 1
# For [GCP]GCP0 Where LEVGRP>=NIVDEB & LEVGRP<=NIVFIN
#  For [HRGCD]GCD0 Where [HRGCD]LEVGRP=[GCP]LEVGRP & [HRGCD]UOMGRP=[GCP]UOMGRP
#&                     & [HRGCD]JOBGRP=[GCP]JOBGRP & [HRGCD]CPCFAM=[GCP]CPCFAM
  For [HRGCD]GCD0 Where LEVGRP>=NIVDEB & LEVGRP<=NIVFIN
   # GCD0 * LEVGRP+UOMGRP+JOBGRP+CPCFAM+NUMLIG
    Raz [F:ARM]
   [F:ARM]USR    = GUSER
   [F:ARM]RPTCOD = [L]ETAT
   [F:ARM]NUMREQ = [L]NUMREQ
   [F:ARM]NUMLIG = L_IJ
#   [F:ARM]CLEN1  = [F:GCP]LEVGRP
#   [F:ARM]CLEA1  = [F:GCP]UOMGRP
#   [F:ARM]CLEA2  = [F:GCP]JOBGRP
#   [F:ARM]CLEA3  = [F:GCP]CPCFAM
   [F:ARM]CLEN1  = [F:HRGCD]LEVGRP
   [F:ARM]CLEA1  = [F:HRGCD]UOMGRP
   [F:ARM]CLEA2  = [F:HRGCD]JOBGRP
   [F:ARM]CLEA3  = [F:HRGCD]CPCFAM
   [F:ARM]CLEA4  = [F:HRGCD]CPC
   Call LECTURE("CPC",[F:HRGCD]CPC,"") From CONTOBJ
#   [F:ARM]CLEA5  = [F:CPC]DES

   Call LECTEXTRA([F:ARM]CLEA5,"COMPETENCE","DES",[F:HRGCD]CPC,"") From ATEXTRA

   [F:ARM]CLEA6  = [F:HRGCD]NIV
   Write [ARM]
   If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
   Endif
   L_IJ += 1
  Next : # [HRGCD]GCD0
# Next
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

