#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPE1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:49"
A_USER  = "DOC"
A_STAMP = "20181109230549"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBAFF"
  If [M]NBAFF=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMOPE1 [PJOPE1]
Gosub HORODAT
Local Inpbox "PJMOPE1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJOPE1] As [SIM_]
Grizo [PJOPE1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJOPE1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=86 : Y1(0)=1 : Y2(0)=7
Return

$ON_NBAFF
Onevent CONTROL Call C_NBAFF From W1PJMOPE1
Return

Subprog C_NBAFF
Local Decimal BASPAG
## Action STD
Call C_NBAFF From SUBPJOPE
If mkstat : GERR = 1 : GZONE = "NBAFF" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_POANUM
Return

$ON_POACLB
Onevent AFTER_CHANGE Gosub AMM_POACLB From W1PJMOPE1
Onevent CONTROL Call C_POACLB(zc) From W1PJMOPE1
Onevent BEFORE_INPUT Call AS_POACLB(zc) From W1PJMOPE1
Return

Subprog AS_POACLB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_POACLB(zc) From W1PJMOPE1
Onkey 144 Titled GBOUTP Call P_POACLB(zc) From W1PJMOPE1
Onkey 146 Titled GBOUTA Call SA_POACLB(zc) From W1PJMOPE1
Gosub _AFF
End

Subprog C_POACLB(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PAUS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
Endif
Gosub _AFF
End

$AMM_POACLB
Call AM_POACLB(zc)
If !mkstat & GOBJET
 zoncou = "POACLB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POACLB(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POACLB(VALEUR) From SUBPJOPE
If mkstat : GERR = 1 : GZONE = "POACLB" : GZNUM = 16058 : Endif
Gosub _AFF
End

Subprog S_POACLB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "PAUS"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_POACLB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PAUS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POACLB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PAUS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_POADES
Onevent INIT_AREA Call D_POADES(zc) From W1PJMOPE1
Onevent AFTER_CHANGE Gosub AMM_POADES From W1PJMOPE1
Onevent BEFORE_INPUT Call AS_POADES(zc) From W1PJMOPE1
Return

Subprog IB_POADES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_POADES(VALEUR)
Variable Char    VALEUR()
If varinit([M]POADES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMOPEAFF","POADES",[M:PJOPE1]KEYCONCAT(nolign-1),AVOID.ACHAR) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_POADES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_POADES(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_POADES(zc) From W1PJMOPE1
Gosub _AFF
End

$AMM_POADES
Call AM_POADES(zc)
If !mkstat & GOBJET
 zoncou = "POADES" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POADES(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POADES(VALEUR) From SUBPJOPE
If mkstat : GERR = 1 : GZONE = "POADES" : GZNUM = 282 : Endif
Gosub _AFF
End

Subprog B1_POADES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_POADES" : PROGSUB = "SUBPJOPE" : PROGSPE = "SPEPJOPE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMOPEAFF"
 PARMSK(2) = "POADES"
 PARMSK(3) = [M:PJOPE1]KEYCONCAT(nolign-1)
 PARMSK(4) = AVOID.ACHAR
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_POADES" : PROGSUB = "SUBPJOPE" : PROGSPE = "SPEPJOPE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_BTNDES
Onevent BEFORE_INPUT Call AS_BTNDES(zc) From W1PJMOPE1
Onevent INIT_AREA Call D_BTNDES(zc) From W1PJMOPE1
Return

Subprog D_BTNDES(VALEUR)
Variable Char    VALEUR()
If varinit([M]BTNDES,indice)=0
 VALEUR = "138"
Endif
Gosub _AFF
End

Subprog AS_BTNDES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_BTNDES(zc) From W1PJMOPE1
Gosub _AFF
End

Subprog CL_BTNDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PJMTXTCLB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMTXTCLB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "ACL_BTNDES" : PROGSUB = "SUBPJOPE" : PROGSPE = "SPEPJOPE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJOPE1"
 PARMSK(2) = num$(nolign-1)
 Call SAISIE_CHAR(VALEUR,PARMSK,"PJMTXTCLB","SUBPJMC","") From GSAISIE
 ACTION = "BCL_BTNDES" : PROGSUB = "SUBPJOPE" : PROGSPE = "SPEPJOPE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

