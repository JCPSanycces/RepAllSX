#<AdxTL>@(#)7.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
$ACTION
Case ACTION
    When OUVRE      Gosub OUVRE
    When FIL_GAUCHE Gosub FIL_GAUCHE
 When default
Endcase
Return

$OUVRE
Local Char SAVE_LAN(3) 
SAVE_LAN=GLANGUE
[M:TRA2]LAN=GLANGUE
Return

$FIL_GAUCHE
Return

$SETBOUT 
Raz ETABOU 
ETABOU(GENRE) = 1 
ETABOU(gaban) = 1 
ETABOU(gprem) = 1 
ETABOU(gdern) = 1 
If CLECUR<>0 
 ETABOU(gsuiv) = 1 
 ETABOU(gprec) = 1 
Endif
Call SETBOUT(ETABOU) From GESECRAN 
Return 
 
########################################
Subprog AP_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End
Endif
Local Integer ETABOU(1..GNBBOU), CHAPITRE 
Local Integer VERROU , CLECUR 
OK_CHP="0"
CLECUR=1
Gosub SETBOUT 
CHAPITRE=VALEUR
# on recupere le maxi
If [M:TRA2]LANNUM=0
#    Gosub LECTURE
Endif
Read[AST]CLE=VALEUR;[M:TRA2]LANNUM;[M:TRA2]LAN
If fstat = 0   
    [M:TRA2]LANMES = [F:AST]LANMES
    If not GIMPORT
    Affzo [M:TRA2]LANMES
    OK_CHP="1"
    Endif
Else
    mkstat=2
Endif
If not GIMPORT
    Effzo [M:TRA2]ZTEXTE
Endif
End

########################################
Subprog AP_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End
Endif
If not GIMPORT
    Affzo [M:TRA2]LANCHP
Endif
Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]LAN
If fstat = 0   
    [M:TRA2]LANMES = [F:AST]LANMES
    If not GIMPORT
          Affzo [M:TRA2]LANMES
    Endif
Else
    mkstat=2
Endif
End

########################################
Subprog AP_ZLAN(VALEUR)
Variable Char    VALEUR()
If GIMPORT : End
Endif
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM;VALEUR
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
SAVE_ZLAN = VALEUR
End

