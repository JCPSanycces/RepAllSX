#<AdxTL>@(#)0.0.0.0 $Revision$ Global variables
Subprog GLOBVAR(SITE)
Value Char SITE
Onerrgo ERREUR
Local File ADOPAR [ADP]
Local File ADOVAL [ADW]
Local Char    PARAM(250)
Global Libelle  GBULCAL             : # Calendar slip
Call PARAM(SITE,"CALEND",PARAM) From ADOVAL
GBULCAL = val(PARAM)
Global Char     GNOMRPTBUL(30)      : # Name of slip status
Call PARAM(SITE,"NOMRPTBUL",PARAM) From ADOVAL
GNOMRPTBUL = PARAM
End

$ERREUR
Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)-errm) From GESECRAN
Resume

