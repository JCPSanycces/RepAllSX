##########################################################################################################
#  Gestion des hors-secteurs de marché                                 Module CRM      16 janvier 2002   #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "RAF"          : Gosub DISPMST8
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIFMST8_MODIF

  GIFMST8_MODIF = 0
  If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
  If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Gosub DISPMST8
Return

##########################################################################################################
$PREMIER
Local Char SZREC1(GLONBPN)
Local Char SZADD1(GLONADR)

  If [M:MST8]TOTASS <= dim([M:MST8]BPRCCNNUM) Then
    Return
  Endif
  SZREC1 = ""
  SZADD1 = ""
  Call LOADARRAY(1, SZREC1, SZADD1)
  Affzo [M:MST8]1-99
Return

##########################################################################################################
$PRECEDENT
Local Char SZREC2(GLONBPN)
Local Char SZADD2(GLONADR)

  If [M:MST8]TOTASS <= dim([M:MST8]BPRCCNNUM) Then
    Return
  Endif
  SZREC2 = [M:MST8]BPRCCNNUM(0)
  SZADD2 = [M:MST8]BPAADD(0)
  Call LOADARRAY(2, SZREC2, SZADD2)
  Affzo [M:MST8]1-99
Return

##########################################################################################################
$SUIVANT
Local Char SZREC3(GLONBPN)
Local Char SZADD3(GLONADR)

  If [M:MST8]TOTASS <= dim([M:MST8]BPRCCNNUM) Then
    Return
  Endif
  If [M:MST8]NBLIN <= 0 Then
    SZREC3 = ""
    SZADD3 = ""
  Else
    SZREC3 = [M:MST8]BPRCCNNUM([M:MST8]NBLIN-1)
    SZADD3 = [M:MST8]BPAADD([M:MST8]NBLIN-1)
  Endif
  Call LOADARRAY(3, SZREC3, SZADD3)
  Affzo [M:MST8]1-99
Return

##########################################################################################################
$DERNIER
Local Char SZREC4(GLONBPN)
Local Char SZADD4(GLONADR)

  If [M:MST8]TOTASS <= dim([M:MST8]BPRCCNNUM) Then Return : Endif
  SZREC4 = ""
  SZADD4 = ""
  Call LOADARRAY(4, SZREC4, SZADD4)
  Affzo [M:MST8]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  # Nettoie l'écran avant de partir.
  Raz [M:MST8]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub DISPMST8
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# LOADBPR   :  Charge le tableau avec des enregistrements Tiers avec le calcul du pourcentage
#              de sites tiers hors secteurs
# DISPMST8  :  Ouvre la fenêtre et gère le bouton Actualiser
########################################################################################################
##########################################################################################################
$DISPMST8
Local Integer INBRECTOT
Local Integer INBRECASS
Local Integer IRECPER
Local Char SZFIRBPC(GLONBPN)
Local Char SZFIRADD(GLONADR)

  SZFIRBPC = ""
  SZFIRADD = ""
  Call TEMPON("R") From GESECRAN
  If [M:MST8]NBLIN <= 0 Then
    SZFIRBPC = ""
    SZFIRADD = ""
  Else
    SZFIRBPC = [M:MST8]BPRCCNNUM(0)
    SZFIRADD = [M:MST8]BPAADD(0)
  Endif
  Raz [M:MST8]
  [M:MST8]LISTYP = mess(538,196,1) #Liste des sites tiers
  Call LOADBPR(SZFIRBPC, SZFIRADD, INBRECTOT, INBRECASS, IRECPER)
  [M:MST8]PRC = num$(IRECPER) + '%'
  [M:MST8]TOTADD = INBRECTOT
  [M:MST8]TOTASS = INBRECTOT - INBRECASS
  Call TEMPOFF From GESECRAN
  Affzo [M:MST8]1-99
Return

##########################################################################################################
# Charge le tableau avec des enregistrements Tiers avec le calcul du pourcentage de sites tiers hors secteurs
##############################################################
Subprog LOADBPR(SZBPC, SZADD, INBTOT, INBASS, IPER)
Value Char SZBPC
Value Char SZADD
Variable Integer INBTOT
Variable Integer INBASS
Variable Integer IPER

Local Integer ITER

  ITER = 0
  INBTOT = 0
  INBASS = 0
  IPER = 0
  For [BPC]
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPC]BPCNUM
    For [BPA]
      Read [MAD]MAD0=[F:BPC]BPCNUM;[F:BPA]BPAADD;"BPR"
      If fstat<>0 Then
        If ITER < dim([M:MST8]BPRCCNNUM) Then
          If [F:BPC]BPCNUM >= SZBPC Then
            If [F:BPC]BPCNUM = SZBPC Then
              If [F:BPA]BPAADD >= SZADD Then
                [M:MST8]BPRCCNNUM(ITER) = [F:BPC]BPCNUM
                [M:MST8]BPRCCNNAM(ITER) = [F:BPC]BPCNAM
                [M:MST8]REPNUM(ITER) = [F:BPC]REP(0)
                If [M:MST8]REPNUM(ITER) = "" Then
                  [M:MST8]REPNAM(ITER) = ""
                Else
                  Read [REP]REP0=[M:MST8]REPNUM(ITER)
                  If !fstat Then
                    [M:MST8]REPNAM(ITER) = [F:REP]REPNAM
                  Endif
                Endif
                [M:MST8]BPAADD(ITER) = [F:BPA]BPAADD
                [M:MST8]ADDRESS(ITER) = [F:BPA]BPAADDLIG(0)
                [M:MST8]POSCOD(ITER) = [F:BPA]POSCOD
                [M:MST8]CTY(ITER) = [F:BPA]CTY
                [M:MST8]SAT(ITER) = [F:BPA]SAT
                [M:MST8]CRY(ITER) = [F:BPA]CRY
                [M:MST8]TEL(ITER) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
                [M:MST8]WEB(ITER) = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
                [M:MST8]RECTYP(ITER) = "BPR"
                ITER += 1
              Endif
            Else
              [M:MST8]BPRCCNNUM(ITER) = [F:BPC]BPCNUM
              [M:MST8]BPRCCNNAM(ITER) = [F:BPC]BPCNAM
              [M:MST8]REPNUM(ITER) = [F:BPC]REP(0)
              If [M:MST8]REPNUM(ITER) = "" Then
                [M:MST8]REPNAM(ITER) = ""
              Else
                Read [REP]REP0=[M:MST8]REPNUM(ITER)
                If !fstat Then
                  [M:MST8]REPNAM(ITER) = [F:REP]REPNAM
                Endif
              Endif
              [M:MST8]BPAADD(ITER) = [F:BPA]BPAADD
              [M:MST8]ADDRESS(ITER) = [F:BPA]BPAADDLIG(0)
              [M:MST8]POSCOD(ITER) = [F:BPA]POSCOD
              [M:MST8]CTY(ITER) = [F:BPA]CTY
              [M:MST8]SAT(ITER) = [F:BPA]SAT
              [M:MST8]CRY(ITER) = [F:BPA]CRY
              [M:MST8]TEL(ITER) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
              [M:MST8]WEB(ITER) = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
              [M:MST8]RECTYP(ITER) = "BPR"
              ITER += 1
            Endif
          Endif
        Endif
      Else
        INBASS += 1
      Endif
      INBTOT += 1
    Next
    Filter [BPA]
  Next
  Filter [BPC]
  [M:MST8]NBLIN = ITER
  If INBTOT > 0 Then
    # FGR 22/10/2010 : X4SUIVI68433 : tester INBTOT
    IPER = 100 - ((INBASS / INBTOT) * 100)
  Endif
End

##########################################################################################################
# Charge le tableau sur action bouton magnéto
#########################################################################
Subprog LOADARRAY(IWHATTODO, SZBPCREC, SZADDREC)
Value Integer IWHATTODO
Value Char SZBPCREC
Value Char SZADDREC

Local Integer ITER
Local Integer INBDISP

  INBDISP = 0
  Case IWHATTODO
    When 1
      Call RAZARRAY
      Filter [BPC] Order By [F:BPC]BPCNUM Asc
      ITER = 0
      Gosub LOADWITHF
    When 2
      Filter [BPC] Where [F:BPC]BPCNUM <= SZBPCREC Order By [F:BPC]BPCNUM Desc
      Gosub LOADWITHR
    When 3
      Filter [BPC] Where [F:BPC]BPCNUM >= SZBPCREC Order By [F:BPC]BPCNUM Asc
      Gosub LOADWITHR
    When 4
      Call RAZARRAY
      Filter [BPC] Order By [F:BPC]BPCNUM Desc
      ITER = dim([M:MST8]BPRCCNNUM) - 1
      Gosub LOADWITHF
    When Default
  Endcase
  Filter [BPC]
  [M:MST8]NBLIN = INBDISP
End

##########################################################################################################
# Charge le tableau avec une boucle For
#############################################################################
$LOADWITHF

  For [BPC]
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPC]BPCNUM
    For [BPA]
      Read [MAD]MAD0=[F:BPC]BPCNUM;[F:BPA]BPAADD;"BPR"
      If fstat Then
        If IWHATTODO = 1 Then
          If ITER >= dim([M:MST8]BPRCCNNUM) Then
            Break
          Endif
        Elsif IWHATTODO = 4 Then
          If ITER < 0 Then
            Break
          Endif
        Endif
        Gosub SETLINE
        If IWHATTODO = 1 Then
          ITER += 1
        Elsif IWHATTODO = 4 Then
          ITER -= 1
        Endif
        INBDISP += 1
      Endif
    Next
    Filter [BPA]
  Next
Return

##########################################################################################################
# Charge le tableau pour les cas Précécent et Suivant
#############################################################################
$LOADWITHR
Local Integer IGOBACK
Local Integer INBRECPREV

  IGOBACK = 0
  INBRECPREV = 0
  If IWHATTODO = 2 Then
    #On calcule le nombre d'enregistrements précédents
    For [BPC]
      If INBRECPREV >= dim([M:MST8]BPRCCNNUM) Then
        Break
      Endif
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPC]BPCNUM
      For [BPA]
        If INBRECPREV >= dim([M:MST8]BPRCCNNUM) Then
          Break
        Endif
        Read [MAD]MAD0=[F:BPC]BPCNUM;[F:BPA]BPAADD;"BPR"
        If fstat Then
          If [F:BPC]BPCNUM <= SZBPCREC Then
            If [F:BPC]BPCNUM = SZBPCREC Then
              If [F:BPA]BPAADD < SZADDREC Then
                INBRECPREV += 1
              Endif
            Else
              INBRECPREV += 1
            Endif
          Endif
        Endif
      Next
      Filter [BPA]
    Next
    If !INBRECPREV Then
      IGOBACK = 1
    Endif
  Elsif IWHATTODO = 3 Then
    #On vérifie s'il y a au moins un enregistrement suivant
    For [BPC]
      If INBRECPREV Then
        Break
      Endif
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPC]BPCNUM
      For [BPA]
        If INBRECPREV Then
          Break
        Endif
        Read [MAD]MAD0=[F:BPC]BPCNUM;[F:BPA]BPAADD;"BPR"
        If fstat Then
          If [F:BPC]BPCNUM >= SZBPCREC Then
            If [F:BPC]BPCNUM = SZBPCREC Then
              If [F:BPA]BPAADD > SZADDREC Then
                INBRECPREV += 1
              Endif
            Else
              INBRECPREV += 1
            Endif
          Endif
        Endif
      Next
      Filter [BPA]
    Next
    If !INBRECPREV Then
      IGOBACK = 1
    Endif
  Endif
  #Il n'y a rien avant ou après. On s'en va
  If IGOBACK Then
    INBDISP = [M:MST8]NBLIN
    Return
  Endif
  #Il y des choses à afficher
  Call RAZARRAY
  If IWHATTODO = 2 Then
    ITER = INBRECPREV - 1
  Elsif IWHATTODO = 3 Then
    ITER = 0
  Endif
  For [BPC]
    If IWHATTODO = 2 Then
      If ITER < 0 Then
        Break
      Endif
    Elsif IWHATTODO = 3 Then
      If ITER >= dim([M:MST8]BPRCCNNUM) Then
        Break
      Endif
    Endif
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPC]BPCNUM
    For [BPA]
      If IWHATTODO = 2 Then
        If ITER < 0 Then
          Break
        Endif
      Elsif IWHATTODO = 3 Then
        If ITER >= dim([M:MST8]BPRCCNNUM) Then
          Break
        Endif
      Endif
      Read [MAD]MAD0=[F:BPC]BPCNUM;[F:BPA]BPAADD;"BPR"
      If fstat Then
        If IWHATTODO = 2 Then
          If [F:BPC]BPCNUM <= SZBPCREC Then
            If [F:BPC]BPCNUM = SZBPCREC Then
              If [F:BPA]BPAADD < SZADDREC Then
                Gosub SETLINE
                ITER -= 1
                INBDISP += 1
              Endif
            Else
              Gosub SETLINE
              ITER -= 1
              INBDISP += 1
            Endif
          Endif
        Elsif IWHATTODO = 3 Then
          If [F:BPC]BPCNUM >= SZBPCREC Then
            If [F:BPC]BPCNUM = SZBPCREC Then
              If [F:BPA]BPAADD > SZADDREC Then
                Gosub SETLINE
                ITER += 1
                INBDISP += 1
              Endif
            Else
              Gosub SETLINE
              ITER += 1
              INBDISP += 1
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [BPA]
  Next
Return

##########################################################################################################
# Renseigne une ligne du tableau
###############################################################################
$SETLINE
  [M:MST8]BPRCCNNUM(ITER) = [F:BPC]BPCNUM
  [M:MST8]BPRCCNNAM(ITER) = [F:BPC]BPCNAM
  [M:MST8]REPNUM(ITER) = [F:BPC]REP(0)
  If [M:MST8]REPNUM(ITER) = "" Then
    [M:MST8]REPNAM(ITER) = ""
  Else
    Read [REP]REP0=[M:MST8]REPNUM(ITER)
    If !fstat Then
      [M:MST8]REPNAM(ITER) = [F:REP]REPNAM
    Endif
  Endif
  [M:MST8]BPAADD(ITER) = [F:BPA]BPAADD
  [M:MST8]ADDRESS(ITER) = [F:BPA]BPAADDLIG(0)
  [M:MST8]POSCOD(ITER) = [F:BPA]POSCOD
  [M:MST8]CTY(ITER) = [F:BPA]CTY
  [M:MST8]SAT(ITER) = [F:BPA]SAT
  [M:MST8]CRY(ITER) = [F:BPA]CRY
  [M:MST8]TEL(ITER) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
  [M:MST8]WEB(ITER) = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
  [M:MST8]RECTYP(ITER) = "BPR"
Return

##########################################################################################################
# Efface le contenu du tableau
################################################################################
Subprog RAZARRAY
  Raz [M:MST8]BPRCCNNUM
  Raz [M:MST8]BPRCCNNAM
  Raz [M:MST8]BPAADD
  Raz [M:MST8]ADDRESS
  Raz [M:MST8]POSCOD
  Raz [M:MST8]CTY
  Raz [M:MST8]SAT
  Raz [M:MST8]CRY
  Raz [M:MST8]TEL
  Raz [M:MST8]WEB
  Raz [M:MST8]REPNAM
  Raz [M:MST8]REPNUM
  Raz [M:MST8]RECTYP
  [M:MST8]NBLIN = 0
End

