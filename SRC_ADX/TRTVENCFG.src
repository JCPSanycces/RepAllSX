#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################
#                                                                       #
#   TRTVENCFG : TRAITEMENTS LIES au CONFIGURATEUR dans les VENTES       #
#                                                                       #
#########################################################################
#                                                                       #
# Subprog GENCFG()                                                      #
#      Génération des lignes devis     si GVENCFG=1                     #
#                 des lignes commandes si GVENCFG=2                     #
#                                                                       #
#########################################################################
# Issue X3-66116 - 20180707 by LD : Configurator: quote, standard calculation cost, price list

Subprog GENCFG

Local Integer  I, NOL, NLIG, NBL, J
Local Shortint TYP, WINSA
Local Char     REP
Local Char     SVGMESSAGE(240)
Local Char     SVGMES_CFG(240)         # JPJ E21304
Local Integer  SVGERR_CFG              # JPJ E21304
Local Integer  FUNCTION              : # Bug 22592
Local Integer  WNLIG_CPS
Local Char     WITMREF_CPS (GLONITM) : # Bug 34044

# JPJ E21304 - Si mode scénario avec une erreur
If (dim(S_CFGCFG) > 0 & S_CFGCFG = 1) & GERR <> 2
    End        # fin
Endif
# JPJ E21304 - Sauvegarde du message eventuel
SVGMES_CFG=GMESSAGE : SVGERR_CFG = GERR
#
Raz GERR, GMESSAGE

GORITITCOL=1

GCONSULT=0        : # 19/11/02

# Si on ne vient pas des ventes
If dim(GVENCFG) < 0 | GVENCFG = 0 End Endif

# Pas de ligne à générer
If [M:CFW]NBLIG=0 End Endif

If clalev([F:BOH]) <= 0 Local File BOM [BOH] Endif

Case GVENCFG
 When 1 : Gosub GENCFG_DEVIS
 When 2 : Gosub GENCFG_CDES
 When Default
Endcase

# JPJ E21304 - Restauration message configurateur si pas de nouveau message
If !GERR
    GMESSAGE=SVGMES_CFG : GERR=SVGERR_CFG
Endif
End

#-------------------------------------------------------------------------------#
# Génération des lignes de devis                                                #
#-------------------------------------------------------------------------------#
$GENCFG_DEVIS

Default Mask [SQH0]
Default Mask [SQH1]
Default Mask [SQH2]
Default Mask [SQH3]

nolign=S_NOLIGN
NOL = nolign-1
indice = nolign-1

If [M:SQH2]NBLIG + [M:CFW]NBLIG >= dim([M:SQH2]ITMREF) - 1
   GERR=1 : GMESSAGE=mess(122,199,1)
   Return
Endif
# Contrôle de l'insertion
If nolign < [M:SQH2]NBLIG
   If [M:SQH2]SQDLIN(nolign) - [M:SQH2]SQDLIN(nolign-1) <= [M:CFW]NBLIG
      GERR=1 : GMESSAGE=mess(122,199,1)
      Return
   Endif
Endif

# Si on est à la fin du tableau pas de insa
#If NOL=[M:SQH2]NBLIG
#   WINSA=0
#Else
#   WINSA=1
#Endif
# Ouverture des n lignes à générer
#If WINSA=1

#[M:SQH2]NBLIG += [M:CFW]NBLIG                        : # Bug 22592
#Insa NOL,[M:CFW]NBLIG,[M:SQH2]NBLIG [M:SQH2]NBLIG    : # Bug 22592

#Endif

nolign = NOL+1

status = 0

# Issue X3-66116
Call TARIFCHGT(5) From TRTPRICE
# End issue X3-66116

Call LINNUM("SQDLIN") From TABLEAUX

# Alimentation des nouvelles lignes
NLIG = NOL
For I=0 To [M:CFW]NBLIG-1
   # Vérification sur l'article
   Gosub VERIF_ITM
   If GERR=1
      Break
   Elsif GERR=2
      Goto NEXT1_ITM
   Endif
   # Recherche des interdits
#   If dim([M]REP1(I))>0 REP=[M]REP1(I) Endif            : # Bug 22592
   If dim([M:SQH1]REP(0))>0 REP=[M:SQH1]REP(0) Endif     : # Bug 22592
   Raz mkstat
   SVGMESSAGE = GMESSAGE
#   Call RECH_INTERDIT ([M:CFW]WRKITMREF(I),[M:SQH2]DBPAADD(I),REP,1) From TRTVENTAR    : # Bug 22592
   Call RECH_INTERDIT ([M:CFW]WRKITMREF(I),[M:SQH2]DBPAADD(NLIG),REP,1) From TRTVENTAR  : # Bug 22592
   If mkstat=2
      SVGMESSAGE -= [M:CFW]WRKITMREF(I)-":"-GMESSAGE
      GMESSAGE = SVGMESSAGE
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR=1
         Break
      Else
         GERR=2
         Goto NEXT1_ITM
      Endif
   Endif

   #----------------------------------------------------------------------#
   # Point d'entree avant insertion d'une nouvelle ligne                  #
   #----------------------------------------------------------------------#
   GPOINT="BEFINSLIG" : Gosub ENTREE From EXEFNC
   If GERR=1 Break Elsif GERR=2 Goto NEXT1_ITM Endif

   nolign=NLIG+1                                        : # Bug 22592
   Insa NLIG,1,[M:SQH2]NBLIG [M:SQH2]NBLIG              : # Bug 22592
   [M:SQH2]NBLIG += 1                                   : # Bug 22592
   nolign=NLIG+1                                        : # Bug 22592

   # Alimentation de la ligne à partir de l'entête
   Call INIT_SQH(NLIG) From SUBSQHB

   # Alimentation de la ligne à partir de l'article
   [M:SQH2]ITMREF(NLIG) =[M:CFW]WRKITMREF(I)
   Call INIT_ITM(NLIG,[M:SQH2]ITMREF(NLIG)) From SUBSQHB

   # Article normal
   [M:SQH2]LINTYP(NLIG)=1
   # Composé ou composant de nomenclature
   If [M:CFW]WRKSELNUM(I)=""
      If I=0
         [M:SQH2]LINTYP(NLIG)=6
         If [F:ITS]ITMTYP=3 [M:SQH2]LINTYP(NLIG)=2 : Endif
         WNLIG_CPS=NLIG
         WITMREF_CPS=[M:CFW]WRKITMREF(I)
         If [M:CFW]WRKBOMALT<>0
            Read [BOH]BOH0=[M:CFW]WRKITMREF(I);[M:CFW]WRKBOMALT(I);1
            If fstat
               # Alternative inexistante ou non commerciale
               [M:SQH2]LINTYP(NLIG)=1
            Endif
         Endif
      Else
         [M:SQH2]LINTYP(NLIG)=7
         If [M:SQH2]LINTYP(WNLIG_CPS)=2 [M:SQH2]LINTYP(NLIG)=3 : Endif
         If [M:CFW]WRKBOMALT<>0 & [M:CFW]WRKSEQ(I)<>0
            Read [BOD]BOD0=WITMREF_CPS;[M:CFW]WRKBOMALT;[M:CFW]WRKSEQ(I);[M:CFW]WRKITMREF(I);1
            If fstat=0
               # Alternative inexistante ou non commerciale
               [M:SQH2]OCNPRNBOM(NLIG)=[F:BOD]OCNPRN
               [M:SQH2]NDEPRNBOM(NLIG)=[F:BOD]NDEPRN
               [M:SQH2]INVPRNBOM(NLIG)=[F:BOD]INVPRN
            Endif
         Endif
      Endif
   Endif
   If [M:SQH2]LINTYP(NLIG)=1 Raz GPNTITMREF
   Elsif find([M:SQH2]LINTYP(NLIG), 6,2) GPNTITMREF=[M:SQH2]ITMREF(NLIG) Endif

   # Si quantité US=0
   If [M:CFW]WRKQTYSTU(I)=0
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         Break
      Else
         Goto NEXT1_ITM
      Endif
   Endif
   If [M:CFW]WRKSAU(I)<>""
      [M:SQH2]SAU(NLIG)=[M:CFW]WRKSAU(I)
      [M:SQH2]QTY(NLIG)=[M:CFW]WRKQTYSAU(I)
   Endif
   If [M:CFW]WRKQTYSAU(I)=0
      If [M:SQH2]SAU(NLIG)=[M:CFW]WRKSTU(I)
         [M:SQH2]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)
      Else
         If [M:SQH2]SAU(NLIG)=[F:ITM]SAU
            [M:SQH2]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)/[F:ITM]SAUSTUCOE     # JPJ E19039
         Else
            J=find([M:SQH2]SAU(NLIG),[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
            If J<>0
               [M:SQH2]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)/[F:ITM]PCUSTUCOE(J-1)     # JPJ E19039
            Endif
         Endif
      Endif
      If [M:SQH2]QTY(NLIG)<>0
         Call QTEARR([M:SQH2]QTY(NLIG),[M:SQH2]SAU(NLIG)) From TRTDIV
#      Else                                                               : # 87425
      Endif                                                               : # 87425
      If [M:SQH2]QTY(NLIG)=0                                              : # 87425
         # Si composé d'un scénario, on ne génère rien
         If I=0 & [M:CFW]WRKSELNUM(I)=""
            GERR=1 : SVGMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(99,192,1) : # 87425
            GMESSAGE = SVGMESSAGE                                         : # 87425
            Break
         Else
            Goto NEXT1_ITM
         Endif
      Endif
   Endif

   [M:SQH2]CQTY(NLIG)   = [M:SQH2]QTY(NLIG)  : # 87425
   [M:SQH2]YQTY(NLIG)   = [M:SQH2]QTY(NLIG)  : # 87425

   TYP=1
   If find([M:SQH2]LINTYP(NLIG),3,4,5,7,8,9) TYP=4 Endif
   # --> Calcul des bases taxe
   Call ALICLCAMT([M:SQH2]ITMREF(NLIG),[M:SQH2]QTY(NLIG),NLIG,"SQH2",[M:SQH2]CLCAMT1(NLIG),[M:SQH2]CLCAMT2(NLIG)) From TRTX3 #Gbn-Fq79223
   # --> Recherche tarif
   Call RECH_TARIF(TYP,[M:SQH2]ITMREF(NLIG),NLIG,[M:SQH2]QTY(NLIG),"SQH",[M:SQH2]GROPRI(NLIG))
&                  From TRTVENTAR
   If [M:SQH2]GROPRI(NLIG) = 0 & [M:CFW]WRKCST(I) <> 0
      [M:SQH2]GROPRI(NLIG) = [M:CFW]WRKCST(I) * [F:ITM]SAUSTUCOE # CCC (15/12/05) Bug 33850 (le prix WRKCST est par US)
   Endif
   If [M:SQH2]GROPRI(NLIG) = 0
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR = 2 : SVGMESSAGE = mess(43,187,1)-":"-[M:SQH2]ITMREF(NLIG)-":"-mess (62,194,1)
      Endif
   Endif
   # --> Calcul du prix net sans contrôle prix mini
   GNETMAR=0
   # FQ 47040 GA 04/2008
   #Call CLCNETPRI([M:SQH2]QTY(NLIG),[M:SQH0]CUR,NLIG) From TRTVENPRI
   Call CALCNETPRI("[M:SQH2]",[M:SQH2]QTY(NLIG),[M:SQH0]CUR,NLIG) From TRTVENPRI
   # --> Calcul de la marge
   # FQ 47040 GA 04/2008
   #Call CLCPFM([M:SQH2]DSTOFCY(NLIG),[M:SQH1]PRITYP,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NLIG,2)
   Call CALCPFM("[M:SQH2]",[M:SQH2]DSTOFCY(NLIG),[M:SQH1]PRITYP,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NLIG,2)
&              From TRTVENPRI
   # Calcul des montants lignes
   Gosub CALC_QUO From SUBSQHB
   Gosub CALC_DSP From TRTVENDIV
   # Calcul du montant devis
   Call ADD_TOT(NLIG) From SUBSQHB

   #----------------------------------------------------------------------#
   # Point d'entree alimentation [M:SQH] pour maj champs spécifiques      #
   #----------------------------------------------------------------------#
   GPOINT="ALIMSKSQH" : Gosub ENTREE From EXEFNC

   # Génération de la nomenclature pour tous les articles normaux ramenés#    : # Bug 22592
   FUNCTION=1                                                                 : # Bug 22592

# Bug 30351

#   If [M:SQH2]LINTYP(NLIG)=1 Gosub CRENOM : NLIG=nolign : NLIG-=1 : Endif     : # Bug 22592
   # Génération de la nomenclature pour les articles normaux ramenés
   # ou pour les composés ramenés si les composants ne st pas ramenés (composé ramené seul ou avec d'autres composés)
   If [M:SQH2]LINTYP(NLIG)=1 | ([M:SQH2]LINTYP(NLIG)=6 & (I=[M:CFW]NBLIG-1 | [M:CFW]WRKSELNUM(I+1)<>""))
       Gosub CRENOM : NLIG=nolign : NLIG-=1
   Endif
# Bug 30351


   NLIG += 1

   GMESSAGE=SVGMESSAGE
   # Si 1ère ligne, pas sélection et ligne normal, c'est fini
   If I=0 & [M:CFW]WRKSELNUM(I)="" & [M:SQH2]LINTYP(NOL)=1
      Break
   Endif

$NEXT1_ITM
   Raz GERR
Next I

If GERR=1 Return Endif
If GMESSAGE<>"" GERR=2 Endif

# Nb ligne générées
NBL = NLIG-NOL
# Si on a généré une seule ligne, c'est forcément une ligne normale
If NBL=1 [M:SQH2]LINTYP(NOL)=1 Endif

## Suppression des lignes en trop        : # Bug 22592
#If NBL <> [M:CFW]NBLIG                  : # Bug 22592
#   # Nb lignes à supprimer              : # Bug 22592
#   NBL = [M:CFW]NBLIG - NBL             : # Bug 22592
#   nolign = NLIG                        : # Bug 22592
#   Dela nolign, NBL [M:SQH2]NBLIG       : # Bug 22592
#   [M:SQH2]NBLIG -= NBL                 : # Bug 22592
#   nolign = NOL+1                       : # Bug 22592
#Endif                                   : # Bug 22592

Call LINNUM("SQDLIN") From TABLEAUX

Affzo [M:SQH2]1-99

mkstat=4

Return

#-------------------------------------------------------------------------------#
# Génération des lignes de commandes                                            #
#-------------------------------------------------------------------------------#
$GENCFG_CDES

Default Mask [SOH0]
Default Mask [SOH1]
Default Mask [SOH2]
Default Mask [SOH3]
Default Mask [SOH4]

nolign=S_NOLIGN
NOL = nolign-1

If [M:SOH4]NBLIG + [M:CFW]NBLIG >= dim([M:SOH4]ITMREF) - 1
   GERR=1 : GMESSAGE=mess(122,199,1)
   Return
Endif
# Contrôle de l'insertion
If nolign < [M:SOH4]NBLIG
   If [M:SOH4]SOPLIN(nolign) - [M:SOH4]SOPLIN(nolign-1) <= [M:CFW]NBLIG
      GERR=1 : GMESSAGE=mess(122,199,1)
      Return
   Endif
Endif

# Si on est à la fin du tableau pas de insa
#If NOL=[M:SOH4]NBLIG
#   WINSA=0
#Else
#   WINSA=1
#Endif
# Ouverture des n lignes à générer
#If WINSA=1
#[M:SOH4]NBLIG += [M:CFW]NBLIG                        : # Bug 22592
#Insa NOL,[M:CFW]NBLIG,[M:SOH4]NBLIG [M:SOH4]NBLIG    : # Bug 22592
#Endif
nolign = NOL+1
status = 0
#Call LINNUM("SOPLIN") From TABLEAUX

Call TARIFCHGT(5) From TRTPRICE #Gbn-112102

# Alimentation des nouvelles lignes
NLIG = NOL
For I=0 To [M:CFW]NBLIG-1
   # Vérification sur l'article
   Gosub VERIF_ITM
   If GERR=1
      Break
   Elsif GERR=2
      Goto NEXT2_ITM
   Endif
   # Recherche des interdits
#   If dim([M]REP1(I))>0 REP=[M]REP1(I) Endif         : # Bug 22592
   If dim([M:SOH1]REP(0))>0 REP=[M:SOH1]REP(0) Endif  : # Bug 22592
   Raz mkstat
   SVGMESSAGE = GMESSAGE
#   Call RECH_INTERDIT ([M:CFW]WRKITMREF(I),[M:SOH4]DBPAADD(I),REP,2) From TRTVENTAR   : # Bug 22592
   Call RECH_INTERDIT ([M:CFW]WRKITMREF(I),[M:SOH4]DBPAADD(NLIG),REP,2) From TRTVENTAR : # Bug 22592
   If mkstat=2
      SVGMESSAGE -= [M:CFW]WRKITMREF(I)-":"-GMESSAGE
      GMESSAGE = SVGMESSAGE
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR=1
         Break
      Else
         GERR=2
         Goto NEXT2_ITM
      Endif
   Endif

   # Contrôle existence article-site
   Raz mkstat
   SVGMESSAGE = GMESSAGE
   Call CONTITF([M:CFW]WRKITMREF(I),[M:SOH2]STOFCY,[F:ITM]STOMGTCOD) From TRTVENCTL
   If mkstat=2
      SVGMESSAGE -= [M:CFW]WRKITMREF(I)-":"-GMESSAGE
      GMESSAGE = SVGMESSAGE
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR = 1
         Break
      Else
         GERR=2
         Goto NEXT2_ITM
      Endif
   Else
      # Si cde de prêt et article géré en stock, il doit être géré en emplacement
      If [M:SOH0]SOHCAT = 2 & [F:ITM]STOMGTCOD <> 1
         If [F:ITF]STOMGTCOD>1 & [F:ITF]LOCMGTCOD <> 2
            GMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(119,192,1)
            If I=0 & [M:CFW]WRKSELNUM(I)=""
               GERR=1 : Break
            Else
               GERR=2 : Goto NEXT2_ITM
            Endif
         Endif
      Endif
   Endif

   #----------------------------------------------------------------------#
   # Point d'entree avant insertion d'une nouvelle ligne                  #
   #----------------------------------------------------------------------#
   GPOINT="BEFINSLIG" : Gosub ENTREE From EXEFNC
   If GERR=1 Break Elsif GERR=2 Goto NEXT2_ITM Endif

   nolign=NLIG+1                           : # Bug 22592
   Insa NLIG,1,[M:SOH4]NBLIG [M:SOH4]NBLIG : # Bug 22592
   [M:SOH4]NBLIG += 1                      : # Bug 22592
   nolign=NLIG+1                           : # Bug 22592

   # Alimentation de la ligne à partir de l'entête
   Call INIT_SOH(NLIG,1) From SUBSOHB

   # Alimentation de la ligne à partir de l'article
   [M:SOH4]ITMREF(NLIG) =[M:CFW]WRKITMREF(I)
   Call INIT_ITM(NLIG,[M:SOH4]ITMREF(NLIG)) From SUBSOHB

   # Article normal
   [M:SOH4]LINTYP(NLIG)=1
   # Composé ou composant de nomenclature
   If [M:CFW]WRKSELNUM(I)=""
      If I=0
         [M:SOH4]LINTYP(NLIG)=6
         If [F:ITS]ITMTYP=3 [M:SOH4]LINTYP(NLIG)=2 : Endif
         WNLIG_CPS=NLIG
         WITMREF_CPS=[M:CFW]WRKITMREF(I)
         If [M:CFW]WRKBOMALT<>0
            Read [BOH]BOH0=[M:CFW]WRKITMREF(I);[M:CFW]WRKBOMALT(I);1
            If fstat
               # Alternative inexistante ou non commerciale
               [M:SOH4]LINTYP(NLIG)=1
            Endif
         Endif
      Else
         [M:SOH4]LINTYP(NLIG)=7
         If [M:SOH4]LINTYP(WNLIG_CPS)=2 [M:SOH4]LINTYP(NLIG)=3 : Endif
         If [M:CFW]WRKBOMALT<>0 & [M:CFW]WRKSEQ(I)<>0
            Read [BOD]BOD0=WITMREF_CPS;[M:CFW]WRKBOMALT;[M:CFW]WRKSEQ(I);[M:CFW]WRKITMREF(I);1
            If fstat=0
               # Alternative inexistante ou non commerciale
               [M:SOH4]OCNPRNBOM(NLIG)=[F:BOD]OCNPRN
               [M:SOH4]NDEPRNBOM(NLIG)=[F:BOD]NDEPRN
               [M:SOH4]INVPRNBOM(NLIG)=[F:BOD]INVPRN
            Endif
         Endif
      Endif
   Endif

   If [M:SOH4]LINTYP(NLIG)=1 Raz GPNTITMREF
   Elsif find([M:SOH4]LINTYP(NLIG), 6,2) GPNTITMREF=[M:SOH4]ITMREF(NLIG) Endif

   # Alimentation de la méthode de livraison
   Call ALIFMI([M:SOH4]ITMREF(NLIG),[M:SOH4]DSTOFCY(NLIG),[M:SOH4]FMI(NLIG)) From TRTVENCDE
   If find([M:SOH4]FMI(NLIG),3,5) [M:SOH4]DALLTYP(NLIG)=2 Endif

   # Si quantité US=0
   If [M:CFW]WRKQTYSTU(I)=0
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         Break
      Else
         Goto NEXT2_ITM
      Endif
   Endif
   If [M:CFW]WRKSAU(I)<>""
      [M:SOH4]SAU(NLIG)=[M:CFW]WRKSAU(I)
      [M:SOH4]QTY(NLIG)=[M:CFW]WRKQTYSAU(I)
   Endif
   If [M:CFW]WRKQTYSAU(I)=0
      If [M:SOH4]SAU(NLIG)=[M:CFW]WRKSTU(I)
         [M:SOH4]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)
      Else
         If [M:SOH4]SAU(NLIG)=[F:ITM]SAU
            [M:SOH4]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)/[F:ITM]SAUSTUCOE     # JPJ E19039
         Else
            J=find([M:SOH4]SAU(NLIG),[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
            If J<>0
               [M:SOH4]QTY(NLIG)=[M:CFW]WRKQTYSTU(I)/[F:ITM]PCUSTUCOE(J-1)     # JPJ E19039
            Endif
         Endif
      Endif
      If [M:SOH4]QTY(NLIG)<>0
         Call QTEARR([M:SOH4]QTY(NLIG),[M:SOH4]SAU(NLIG)) From TRTDIV
#      Else                                                               : # 87425
      Endif                                                               : # 87425
      If [M:SOH4]QTY(NLIG)=0                                              : # 87425
         # Si composé d'un scénario, on ne génère rien
         If I=0 & [M:CFW]WRKSELNUM(I)=""
            GERR=1 : SVGMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(99,192,1) : # 87425
            GMESSAGE = SVGMESSAGE                                         : # 87425
            Break
         Else
            Goto NEXT2_ITM
         Endif
      Endif
   Endif

   [M:SOH4]CQTY(NLIG)   = [M:SOH4]QTY(NLIG) : # 87425
   [M:SOH4]YQTY(NLIG)   = [M:SOH4]QTY(NLIG) : # 87425

   [M:SOH4]STU(NLIG)    = [M:CFW]WRKSTU(I)
   [M:SOH4]QTYSTU(NLIG) = [M:CFW]WRKQTYSTU(I)


   #Gbn-84255-Init des quantité à allouer
   If GINIALLORD=2 & (GAPPSOH<>2 | ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2))
    Local Decimal WSAUSTUCOE : WSAUSTUCOE=[M]SAUSTUCOE(NLIG)
    Local Integer LSAVNOL

    # Issue 116197 - 2016-09-15 by STLIG : Correct function call and script names
    #                                     (previously INIT_WALLQTYSTU1 From SUBSOH)
    LSAVNOL=NOL : NOL=NLIG : Gosub INIT_WALLQTYSTU From SUBSOH1 : NOL=LSAVNOL

   Endif

   # Si UV commande différente de UV article, raz conditionnement
   If [M:SOH4]SAU(NLIG) <> [F:ITM]SAU
      Raz [M:SOH4]PCK(NLIG), [M:SOH4]PCKCAP(NLIG)
   Endif

   TYP=1
   If find([M:SOH4]LINTYP(NLIG),3,4,5,7,8,9) TYP=4 Endif
   # --> Calcul des bases taxe
   Call ALICLCAMT([M:SOH4]ITMREF(NLIG),[M:SOH4]QTY(NLIG),NLIG,"SOH4",[M:SOH4]CLCAMT1(NLIG),[M:SOH4]CLCAMT2(NLIG)) From TRTX3 #Gbn-Fq79223
   # --> Recherche tarif
   Call RECH_TARIF(TYP,[M:SOH4]ITMREF(NLIG),NLIG,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG))
&                  From TRTVENTAR
   If [M:SOH4]GROPRI(NLIG) = 0 & [M:CFW]WRKCST(I) <> 0
      [M:SOH4]GROPRI(NLIG) = [M:CFW]WRKCST(I)
   Endif
   If [M:SOH4]GROPRI(NLIG) = 0
      # Si composé d'un scénario, on ne génère rien
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR = 2 : SVGMESSAGE = mess(43,187,1)-":"-[M:SOH4]ITMREF(NLIG)-":"-mess (62,194,1)
      Endif
   Endif
   # --> Calcul du prix net sans contrôle prix mini
   GNETMAR=0
   # FQ 47040 GA 04/2008
   #Call CLCNETPRI([M:SOH4]QTY(NLIG),[M:SOH0]CUR,NLIG) From TRTVENPRI
   Call CALCNETPRI("[M:SOH4]",[M:SOH4]QTY(NLIG),[M:SOH0]CUR,NLIG) From TRTVENPRI
   # --> Calcul de la marge
   # FQ 47040 GA 04/2008
   #Call CLCPFM([M:SOH4]DSTOFCY(NLIG),[M:SOH1]PRITYP,[M:SOH0]CHGTYP,[M:SOH0]ORDDAT,[M:SOH0]CUR,NLIG,2)
   Call CALCPFM("[M:SOH4]",[M:SOH4]DSTOFCY(NLIG),[M:SOH1]PRITYP,[M:SOH0]CHGTYP,[M:SOH0]ORDDAT,[M:SOH0]CUR,NLIG,2)
&              From TRTVENPRI
   # --> Calcul du montant cde ht et ttc de la ligne
   Gosub CALC_ORD From SUBSOHB
   Gosub CALC_DSP From TRTVENDIV
   # --> Calcul des mnts à livrer ht et ttc de la ligne
   If [M:SOH4]DEMSTA(NLIG) <> 1
      Raz [M:SOH4]LINDLRNOT(NLIG)
      Raz [M:SOH4]LINDLRATI(NLIG)
      # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:12/12/16)
      Raz [M:SOH4]LININRSCHNOT(NLIG)
      Raz [M:SOH4]LININRSCHATI(NLIG)
      # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:12/12/16)
   Else
      Gosub CALC_DLR From SUBSOHB
   Endif
   Call ADD_TOT(NLIG) From SUBSOHB

   #----------------------------------------------------------------------#
   # Point d'entree alimentation [M:SOH] pour maj champs spécifiques      #
   #----------------------------------------------------------------------#
   GPOINT="ALIMSKSOH" : Gosub ENTREE From EXEFNC

   # Génération de la nomenclature pour tous les articles normaux ramenés#    : # Bug 22592
   FUNCTION=2                                                                 : # Bug 22592

# Bug 30351
#   If [M:SOH4]LINTYP(NLIG)=1 Gosub CRENOM : NLIG=nolign : NLIG-=1 : Endif     : # Bug 22592
   # Génération de la nomenclature pour les articles normaux ramenés
   # ou pour les composés ramenés si les composants ne st pas ramenés (composé ramené seul ou avec d'autres composés)
   If [M:SOH4]LINTYP(NLIG)=1 | ([M:SOH4]LINTYP(NLIG)=6 & (I=[M:CFW]NBLIG-1 | [M:CFW]WRKSELNUM(I+1)<>""))
       Gosub CRENOM : NLIG=nolign : NLIG-=1
   Endif
# Bug 30351


   NLIG += 1

   GMESSAGE=SVGMESSAGE
   # Si 1ère ligne, pas sélection et ligne normal, c'est fini
   If I=0 & [M:CFW]WRKSELNUM(I)="" & [M:SOH4]LINTYP(NOL)=1
      Break
   Endif

$NEXT2_ITM
   Raz GERR
Next I
If GERR=1 Return Endif
If GMESSAGE<>"" GERR=2 Endif

# Nb ligne générées
NBL = NLIG-NOL
# Si on a généré une seule ligne, c'est forcément une ligne normale
If NBL=1 [M:SOH4]LINTYP(NOL)=1 Endif

## Suppression des lignes en trop              : # Bug 22592
#If NBL <> [M:CFW]NBLIG                        : # Bug 22592
#   # Nb lignes à supprimer                    : # Bug 22592
#   NBL = [M:CFW]NBLIG - NBL                   : # Bug 22592
#   nolign = NLIG                              : # Bug 22592
#   Dela nolign, NBL [M:SOH4]NBLIG             : # Bug 22592
#   [M:SOH4]NBLIG -= NBL                       : # Bug 22592
#   nolign = NOL+1                             : # Bug 22592
#Endif                                         : # Bug 22592

Call LINNUM("SOPLIN") From TABLEAUX

Affzo [M:SOH4]1-99

mkstat=4

Return

######################################################################################
#                                                                                    #
# Etiquette de création des nomenclatures                                            #
#                                                                                    #
######################################################################################
$CRENOM
Local Integer SAVNLIG, SAVNBLIG

SAVNLIG=NLIG
SAVNBLIG=[M]NBLIG
If [F:ITS]ITMREF <> [M]ITMREF(NLIG)
    Read [F:ITS]ITS0 = [M]ITMREF(NLIG)
    If fstat  Raz [F:ITS] : Return : Endif
Endif
If [F:ITS]ITMTYP=1 Return Endif
If [F:ITS]ITMTYP=2 [M]LINTYP(NLIG) = 6 : Endif
If [F:ITS]ITMTYP=3 [M]LINTYP(NLIG) = 2 : Endif

GMODIF=2
## Action TRTCRENOM
Local Decimal BASPAG
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "TRTCRENOM"
PARMSK(1) = [M]ITMREF(NLIG)
PARMSK(2) = num$(NLIG)
Case FUNCTION
    When 1 :
        PARMSK(3) = [M:SQH0]QUODAT
        PARMSK(6) = num$([M:SQH2]SQDLIN(NLIG))
    When 2 :
        PARMSK(3) = [M:SOH0]ORDDAT
        PARMSK(6) = num$([M:SOH4]SOPLIN(NLIG))
Endcase
PARMSK(4) = num$(FUNCTION)
PARMSK(5) = num$(GBIDI1)
PARMSK(7) = GBIDC1
PARMSK(8) = num$(GBIDI1)
PARMSK(9) = num$(GBIDI1)
Call TRAITE_NUM(BASPAG,PARMSK,"","TRTVENBOM","ISELBOD",4,"XYTRTVENBOM") From GTRAITE
GBIDC1 = PARMSK(7)
GBIDI1 = val(PARMSK(8))
GBIDI1 = val(PARMSK(9))
GACTION = SAVACT

If[M]LINTYP(SAVNLIG)=1 [M]NBLIG=SAVNBLIG Endif

Return

#------------------------------
# Vérification sur l'article
#------------------------------
$VERIF_ITM

Read [ITS]ITS0=[M:CFW]WRKITMREF(I)
If fstat
   GMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(5,192,1)
   # Si composé d'un scénario, on ne génère rien
   If I=0 & [M:CFW]WRKSELNUM(I)=""
      GERR=1 : Return
   Else
      GERR=2 : Return
   Endif
Endif
Read [ITM]ITM0=[M:CFW]WRKITMREF(I)
If fstat
   GMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(8,192,1)
   # Si composé d'un scénario, on ne génère rien
   If I=0 & [M:CFW]WRKSELNUM(I)=""
      GERR=1 : Return
   Else
      GERR=2 : Return
   Endif
Endif
# Contrôle du statut de l'article
If [F:ITM]ITMSTA = 6
   GMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
   # Si composé d'un scénario, on ne génère rien
   If I=0 & [M:CFW]WRKSELNUM(I)=""
      GERR=1 : Return
   Else
      GERR=2 : Return
   Endif
Endif
# Si commande de prêt, l'article doit être géré en prêt
If GVENCFG=2
   If [M:SOH0]SOHCAT = 2 & [F:ITS]LNDFLG = 1
      GMESSAGE -= [M:CFW]WRKITMREF(I)-":"-mess(34,192,1)
      If I=0 & [M:CFW]WRKSELNUM(I)=""
         GERR=1 : Return
      Else
         GERR=2 : Return
      Endif
   Endif
Endif
Return

