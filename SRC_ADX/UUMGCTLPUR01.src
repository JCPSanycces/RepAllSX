#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLPUR01   Contrôle Pre-migration DA                   Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLPUR01") From LECFIC
  Endif

  Call MAJ_UUMGCTLPUR01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLPUR01(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(5)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLPUR01 Purchase Requests Process : PREQUIS-D") From DOSSUB
Call ECR_TRACE("UUMGCTLPUR01 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1
Gosub CTL2

$FIN
Call ECR_TIME("UUMGCTLPUR01 : Purchase Requests Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PREQUIS")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PREQUISD") : Return : Endif

REQSQL(0)="SELECT PSH.PSHNUM_0 FROM "-DOSSIER+".PREQUIS PSH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PREQUISD PSD WHERE PSH.PSHNUM_0=PSD.PSHNUM_0) "
REQSQL(2)="ORDER BY PSH.PSHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PREQUIS without PREQUISD",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PSHNUM="-[BXX]VPSHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PREQUIS")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PREQUISD") : Return : Endif

REQSQL(0)="SELECT PSD.PSHNUM_0,PSD.PSDLIN_0 FROM "-DOSSIER+".PREQUISD PSD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PREQUIS PSH WHERE PSH.PSHNUM_0=PSD.PSHNUM_0) "
REQSQL(2)="ORDER BY PSD.PSHNUM_0,PSD.PSDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PREQUISD without PREQUIS",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSHNUM(50),Integer VPSDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PSHNUM/PSDLIN="-[BXX]VPSHNUM+'/'+num$([BXX]VPSDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

