#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-69118 - 2018-01-18 by JUSYN : Create scripts for GESNCSP
# Issue X3-74449 - 2018-02-02 by BAKHA : Complete button added to change Plan status to Complete
# Issue X3-72907 - 2018-02-15 by BAKHA : Add left list for my non-conformances to plan, also display site
# Issue X3-76785 - 2018-02-19 by JUSYN : Remove button 2 Replanning and its functionality
# Issue X3-74466 - 2018-02-26 by JUSYN : Line text entry for actions
# Issue X3-94378 - 2018-06-06 by JUSYN : DB structure changes to seperate NCS: CCMPLANH [CCMPH] to PLANHDR [PLAHDR];
#                                        CCMPLAND [CCMPD] to PLANDET [PLADET] ; CCMCR to NCSRC ; CCMACTION to PLANACT ; CRID to PLANID
#                                        CRSTATUS to NCSSTA
# Issue X3-85682 - 2018-08-07 by BAKHA : Add action type to plan lines
# Issue X3-105283 - 2018-08-29 by BAKHA : Get Action ID description from Action
# Issue X3-97508 - 2018-09-07 by BAKHA : Disable fields transaction type/action when in-progess

$DECL_VAR_LOCAL
#----------------------------------#
# Local variable declaration       #
#----------------------------------#

Local  Integer  I, J, K, WERR
Local  Shortint NOL, SAVNBLIG
Local  Char WMESS(250)
Local  Integer MY_STATUS, WRET
Return
#########################################################################

$OUVRE
#-------------------------------#
# before the window opening     #
#-------------------------------#

# Issue X3-72459 - 2018-02-19 by ALSHE : link ATEXTRA to be able to use the full name in the left list
If clalev([F:AXXM])=0 : Local File ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local File ATEXTRA [AXXP] : Endif
If clalev([F:AXXC])=0 : Local File ATEXTRA [AXXC] : Endif

Link [NCSPLN] With
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSPLN]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSPLN]NCSPLANNER;"",
& [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSPLN]CREUSR;""
& As [NCSPLN_]
# Issue X3-72459


#--- To use the class CRUD instead of the object CRUD
ANOWRITE = 1

Local File PLANDET  [PLADET]

#---- Local variables
Gosub DECL_VAR_LOCAL

#--- Container class : global for sub prog ANUCOD
Global Instance WPLANHDR Using C_PLANHDR

# Issue X3-97070 - 2018-06-19 by JUSYN : for check of correct plan action
If clalev([F:PLAACT])=0 : Local File PLANACT [PLAACT] : Endif
If clalev([F:AST])=0 : Local File APLSTD [ASTP] : Endif
# End issue X3-97070

Return
#########################################################################

$SETBOUT
#-----------------------------------------------------------#
# Disable buttons not needed at each status                 #
#-----------------------------------------------------------#
# NCSSTA
# 1 = New (not used to be set)
# 2 = In review
# 3 = Reject
# 4 = Plan
# 5 = Implement
# 6 = Complete
# 7 = Close

# Issue 76785 - 2018-02-19 by JUSYN : remove replanning button 2; complete becomes now 2 (from 3)
# BUTTONS
# 1 = Implement
# 2 = Complete

# when record is in change modus --> disable Implement and Replanning button
If find(GREP,"M")
    Call VIREBOUT(CHAINE,"12") From GOBJET # Issue X3-74449 - disable Complete button
Endif
# when not planner, disable buttons
If [M:NCSP0]NCSPLANNER <> GUSER
    Call VIREBOUT(CHAINE,"12") From GOBJET # Issue X3-74449 - disable Complete button
Endif
# when status <> plan, disable 'Implement" button
If find ([M:NCSP0]NCSSTA,1,2,3,5,6,7)
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
# Issue X3-74449 When CR status not 'Implement' or Plan status not Implement or HIGHLEVEL not complete, disable Complete button
# Issue X3-94378 - 2018-06-13 by JUSYN : HIGHLEVEL status (for action lines) abolished as not needed
# If ([M:NCSP0]NCSSTA <> 5 or [M:NCSP0]PLANSTATUS <> 2 or [M:NCSP1]HIGHLEVEL<3)
If ([M:NCSP0]NCSSTA <> 5 or [M:NCSP0]PLANSTATUS <> 2 ) or (find(1, [M:NCSP1]LINESTATUS(0..[M:NCSP1]NBLIG-1)))
&                                                      or (find(2, [M:NCSP1]LINESTATUS(0..[M:NCSP1]NBLIG-1)))
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
# End issue X3-94378
# End issue X3-76785

Return
###########################################################################################

$EXEBOUT
# execute function on buttons
Case BOUT
  When "1"      : Gosub PLAN_IMPLEMENT
  When "2"      : Gosub PLAN_COMPLETE   # Issue X3-74449 # Issue X3-76785 Complete gets button 2 (formerly 3) as replanning is removed
Endcase

Return

###########################################################################################
$MODIF
Local Integer LOCAL_ASTATUS
Local Instance MYNCSRECENT Using C_NCSRECENT
Local Integer NOL  # Issue X3-74466 - 2018-02-26 by JUSYN : Line text entry for actions

#--------------------------------------#
# Modification container               #
#--------------------------------------#

#--- Assign the Syracuse class with [M]class
SetInstance WPLANHDR With [M:NCSP0]
SetInstance WPLANHDR With [M:NCSP1]

# Hybrid part
Call CLEAN_UP_CLASS()
If GERR = 1 Then
  Return
Endif

# Issue X3-74466 - 2018-02-26 by JUSYN : Line text entry for actions
For nolign=1 To [M:NCSP1]NBLIG
    NOL = nolign-1
    If [M:NCSP1]LINTEX(NOL) <> ""
        If left$([M:NCSP1]LINTEX(NOL),3)="NCP"
            Call CRE_CLOB([M:NCSP1]LINTEX(NOL),GOK) From TRTX3TEX
            If GOK<1 Return Endif
        Endif
    Elsif [M:NCSP1]LINTEX(NOL) = ""
        If left$(WPLANHDR.PLANDET([M:NCSP1]LINENO(NOL)).LINTEX,3)="NCP"
            Call SUP_CLOB(WPLANHDR.PLANDET([M:NCSP1]LINENO(NOL)).LINTEX,GOK) From TRTX3TEX
            If GOK<1 Return Endif
        Endif
    Endif
    WPLANHDR.PLANDET([M:NCSP1]LINENO(nolign-1)).LINTEX = [M:NCSP1]LINTEX(NOL)
Next
# End issue X3-74466

MY_STATUS = fmet WPLANHDR.AUPDATE()
#--- AUPDATE method
If [L]MY_STATUS >= [V]CST_AERROR
    Call GET_ERRORS(WPLANHDR)
    If GMESSAGE = AVOID.ACHAR Then
        GMESSAGE = mess(128,187,1)  # Unknown error
    Endif
    If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse Class
SetInstance [M:NCSP0] With WPLANHDR
SetInstance [M:NCSP1] With WPLANHDR
[M:NCSP0]UPDDAT = func CONVERT_DATETIME_TO_DATE(WPLANHDR.UPDDATTIM)

# Update Non-conformance status to Complete
If ([M:NCSP0]PLANSTATUS = 3)
    MYNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
    LOCAL_ASTATUS = fmet MYNCSRECENT.AREAD([M:NCSP0]PLANID)
    If (LOCAL_ASTATUS = CST_AOK)
      MYNCSRECENT.NCSSTA = 6
      LOCAL_ASTATUS = fmet MYNCSRECENT.AUPDATE()
      If LOCAL_ASTATUS >= [V]CST_AERROR
          Call GET_ERRORS(MYNCSRECENT) From SUBNCSHA
          If GMESSAGE = AVOID.ACHAR Then
              GMESSAGE = mess(128,187,1)  # Unknown error
          Endif
          If GOK=0 : Return : Endif
      Endif
    Endif
    FreeGroup MYNCSRECENT
Endif
# DETAILS
Call DISPLAY_PLAN_DETAILS()

Return

##########################################################################

$APRES_MOD
Gosub RELIT From GOBJSUB
Return

##########################################################################

$AV_ANNULE
#--- Must define again ANOWRITE because of subprog ANUCOD
ANOWRITE = 1
Return

##########################################################################

$ANNULE
#--------------------------------------#
# Deletion container                   #
#--------------------------------------#
Local Integer I,MY_STATUS
#--- ADELETE method
MY_STATUS = fmet WPLANHDR.ADELETE()
If [L]MY_STATUS >= [V]CST_AERROR
    Call GET_ERRORS(WPLANHDR)
    If GMESSAGE = AVOID.ACHAR Then
        GMESSAGE = mess(128,187,1)  # Unknown error
    Endif
    If GOK=0 : Return : Endif
Endif
Return

##########################################################################

$ABANDON

#--- Update picking list
If GREP="C" & BOUT="A"
  Raz   [M:NCSP0]
  Actzo [M:NCSP0]
Endif
Return

##########################################################################

$FILTRE

Return

##########################################################################
# Issue X3-72907 - add selection for left lists
$FILGAUCHE
Default File [PLAHDR]

Case currbox
  When "GAU_CHE"  : FILGAUCHE = "[F:NCSRC]NCSREC = 2" # Issue X3-69118 - 2018-02-20 by JUSYN : moved filter criteria from $FILTRE (FILTSUP) here
  #  because of issue to display last used record when function opened again.
  When "GAU_CHE1" : FILGAUSUP(0) = "[F:NCSRC]NCSREC = 2 and [NCSRC]NCSPLANNER = GUSER and [NCSRC]NCSSTA = 4"
  When "GAU_CHE2" : Gosub FILGAUCHE2 # Issue X3-72459 - 2018-02-16 by ALSHE : set filter for left list
  When Default : Return
Endcase

Return
# Issue X3-72907 - end

##########################################################################

# Issue X3-72459 - 2018-02-19 by ALSHE : set filter to left list
$FILGAUCHE2
Default File [NCSPLN]
FILGAUSUP(0) =  "ACTIONER = GUSER"

Return

##########################################################################
# Issue X3-72459 - 2018-02-19 by ALSHE : set sort to left list
$CLE_GAUCHE
CLELISTE = "PLANID Desc"
Return

##########################################################################
# Issue X3-72459 - 2018-02-16 by ALSHE : assign selected value from left list view NCSPLN to the main class by using the primary key from NCSRC
$GAUCHE
If currbox = "GAU_CHE2"
    [F:PLAHDR]PLANID = [F:NCSPLN]PLANID
Endif
Return

$LIENS
Local Integer LRET, I
#------------------------------------#
#--- Free instance
If WPLANHDR <> null  : FreeGroup WPLANHDR :Endif
#--- class instantiation
WPLANHDR = NewInstance C_PLANHDR AllocGroup null

WPLANHDR.PLANID=[M:NCSP0]PLANID
#--- Read method
WRET = fmet WPLANHDR.AREAD([M:NCSP0]PLANID)
If WRET >= [V]CST_AERROR
    Call GET_ERRORS(WPLANHDR)
    If GMESSAGE = AVOID.ACHAR Then
         GMESSAGE = mess(128,187,1)  # Unknown error
    Endif
    If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse class
SetInstance [M:NCSP0] With WPLANHDR
SetInstance [M:NCSP1] With WPLANHDR
[M:NCSP0]UPDDAT = func CONVERT_DATETIME_TO_DATE(WPLANHDR.UPDDATTIM)

# Data from Non-conformance record
Call FILL_FROM_NCSRECENT()

# DETAILS
Call DISPLAY_PLAN_DETAILS()

# Grid fields activate/deactivate
If (!find([M:NCSP0]NCSSTA,4,5)) # Issue X3-97508 - if not Plan or Implement
  # Issue X3-74466 - 2018-02-26 by JUSYN : action menu for line needs to be open for line text
  # Grizo [M:NCSP1]
  Grizo [M:NCSP1]TRANTYPE
  Grizo [M:NCSP1]ACTIONID
  Grizo [M:NCSP1]ACTTYP         # Issue X3-85682
  Grizo [M:NCSP1]COMPLETEDATE
  Grizo [M:NCSP1]ACTIONER
  Grizo [M:NCSP1]LINESTATUS
  Grizo [M:NCSP1]COMMENT
Else
  Actzo [M:NCSP1]

  For I = 0 To [M:NCSP1]NBLIG-1

      # Issue X3-97508 - disable fields if not planner or line not in Pending
      If (GUSER <> [M:NCSP0]NCSPLANNER or [M:NCSP1]LINESTATUS(I) > 1)
          Grizo [M:NCSP1]TRANTYPE(I)
          Grizo [M:NCSP1]ACTIONID(I)
          Grizo [M:NCSP1]ACTTYP(I)
      Endif

      If GUSER <> [M:NCSP0]NCSPLANNER or [M:NCSP1]LINESTATUS(I) = 3
          Grizo [M:NCSP1]COMPLETEDATE(I)
          Grizo [M:NCSP1]ACTIONER(I)
      Endif

      # Issue X3-74449 - 2018-02-06 by JUSYN : Linestatus rework
      # LINESTATUS deactivate
      # Only active when NCS status is Implement, Plan status is Implement, and actioner
      If ([M:NCSP0]PLANSTATUS <> 2 or GUSER <> [M:NCSP1]ACTIONER(I))
          Grizo [M:NCSP1]LINESTATUS(I)
      Endif
      # End issue X3-74449

      # Issue X3-74449 - 2018-02-06 by JUSYN : Linestatus rework
      # COMMENT deactivate
      If ([M:NCSP0]PLANSTATUS = 3)
        Grizo [M:NCSP1]COMMENT(I)
      Elsif (GUSER = [M:NCSP0]NCSPLANNER or (GUSER = [M:NCSP1]ACTIONER(I) and [M:NCSP0]PLANSTATUS = 2))
        # leave field active
      Else
        Grizo [M:NCSP1]COMMENT(I)
      Endif

      # End issue X3-74449
Next I
# Issue X3-74449 - end

Endif
Return

##########################################################################

$FERME
#--- Free instance
If WPLANHDR <> null
  FreeGroup WPLANHDR
Endif
Kill WPLANHDR

# Close Files
# LogicClose File [PLAHDR]
LogicClose File [PLADET]
# Issue X3-97070 - 2018-06-19 by JUSYN : for check of correct plan action
LogicClose File [PLAACT]
LogicClose File [ASTP]
# End issue X3-97070


Return

##########################################################################

$PLAN_IMPLEMENT
# set planning complete status to "completed" --> other status groups are set by the class
[M:NCSP1]IMPLEMENT = 2
[M:NCSP0]PLANSTATUS = 2 # Issue X3-74449 - update Plan status
Gosub MODIF
Gosub APRES_MOD
Affzo [M:NCSP0]1-99
Affzo [M:NCSP1]IMPLEMENT
# Affzo [M:NCSP1]HIGHLEVEL
Return

#################################################################################
# Issue X3-74449 - set Plan status to "completed" and Non-conformance to Complete
$PLAN_COMPLETE

If ([M:NCSP0]PLANSTATUS = 2)
  [M:NCSP0]PLANSTATUS = 3

  Gosub MODIF
  Gosub APRES_MOD

  Affzo [M:NCSP0]1-99
Endif


Return

#########################################################################

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_DATE : Convert datetime type to date type
#**<br/>----------------------------------------------------------------<br/>
#* @param DATETIMETOCONV - DateTime = Date time to convert
#* @return Date portion of the datetime
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_DATETIME_TO_DATE (DATETIMETOCONV)
    Value Datetime DATETIMETOCONV
    Local Date NEWDATE
    Local Char STRINGDT(20)

    STRINGDT = num$(DATETIMETOCONV)
    NEWDATE = gdat$(val(mid$(STRINGDT, 9, 2)), val(mid$(STRINGDT,6,2)), val(left$(STRINGDT, 4)))

End NEWDATE

##########################################################################################################
Subprog DISPLAY_PLAN_DETAILS()

Local Integer NI

  # Global actions ---------------------------------------
  nolign = 0
  For NI = 1 To maxtab(WPLANHDR.PLANDET)
    # ------------------------------------
    If WPLANHDR.PLANDET(NI) <> null and find(WPLANHDR.PLANDET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_GLOBAL_ACTIONS(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:NCSP1]NBLIG = nolign
  Affzo [M:NCSP1]1-99
  # ---------------------------------------

End

##########################################################################################################
Subprog SHOW_GLOBAL_ACTIONS(VNLINE)
Value Integer VNLINE

SetInstance [M:NCSP1]10 With WPLANHDR.PLANDET(VNLINE)
[M:NCSP1]LINENO(nolign-1) = VNLINE   # Line index in the collection

If [M:NCSP1]ACTIONID(nolign-1) <> ""
    Call POPULATE_ACTIONID_DESCRIPTION(nolign-1)
Endif

# Issue X3-74466 - 2018-02-26 by JUSYN : Line text entry for actions
If [M:NCSP1]LINTEX(nolign-1) <> ""
    [M:NCSP1]TEXT(nolign-1) = 2
Else
    [M:NCSP1]TEXT(nolign-1) = 1
Endif
# End issue X3-74466

End

##########################################################################################################
Subprog CLEAN_UP_CLASS()

Local Integer NI                                 # Hybrid part
Local Integer ILINE                              # Hybrid part
Local Integer ASTATUS                            # Hybrid part
Local Integer INDEX

# ----------------------------------------------------------
# Hybrid part (begin)
# [M:NCSP0] Global actions ------------------------------------------------------------------------------------
If maxtab(WPLANHDR.PLANDET) > 0
    For NI = maxtab(WPLANHDR.PLANDET) To 1 Step -1
        If WPLANHDR.PLANDET(NI) <> null
            If find(WPLANHDR.PLANDET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
                ILINE = find(num$(WPLANHDR.PLANDET(NI).AUUID), [M:NCSP1]AUUID(0..[M:NCSP1]NBLIG-1))
                If ILINE = 0 Then
                    If left$(WPLANHDR.PLANDET(NI).LINTEX,3)="NCP"
                        Call SUP_CLOB(WPLANHDR.PLANDET(NI).LINTEX,GOK) From TRTX3TEX
                    Endif
                    If GOK < 1
                        GOK = 0
                        GERR = 1
                        Break
                    Endif
                    [L]ASTATUS = fmet WPLANHDR.ADELLINE("PLANDET",NI)
                    If [L]ASTATUS >= [V]CST_AERROR Then
                        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WPLANHDR)
                        GOK = 0
                        GERR = 1
                        Break
                    Endif
                Endif
            Else
                # Issue X3-74466 - 2018-02-26 by JUSYN : Delete Line text entry for actions if line has been deleted
                If left$(WPLANHDR.PLANDET(NI).LINTEX,3)="NCP"
                    Call SUP_CLOB(WPLANHDR.PLANDET(NI).LINTEX,GOK) From TRTX3TEX
                Endif
                If GOK < 1
                    GOK = 0
                    GERR = 1
                    Break
                Endif
                # End issue X3-74466
            Endif
        Endif
    Next NI
Endif
If GERR = 1 Then
    End
Endif

# Hybrid part (end)
End

##########################################################################################################
Subprog GET_ERRORS(WPLANHDR)
Variable Instance WPLANHDR Using C_PLANHDR

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE

  # ----------------------------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(WPLANHDR, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GERR = 2
    GMESSAGE = SMESSAGE
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GERR = 1
    GMESSAGE = SMESSAGE
    GOK = 0
  Endif

  # ----------------------------------------------------------
  # To help debug process : write a classic log file with all errors in class.
  Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG_" + GUSER) From LECFIC
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(WPLANHDR) From SYRSTACKTOOLS
  Call FERME_TRACE From LECFIC
  # ----------------------------------------------------------
  For NI = 1 To maxtab(WPLANHDR.PLANDET)
    MY_STATUS = fmet WPLANHDR.PLANDET(NI).ADELETERRORALL()
  Next NI

  MY_STATUS = fmet WPLANHDR.ADELETERRORALL()
  # Hybrid part (end)
End



##########################################################################################################
Subprog POPULATE_ACTIONID_DESCRIPTION(WLINE)
Value Integer WLINE

Local Instance PLANACT Using C_PLANACT
Local Integer LOCSTATUS

[M:NCSP1]ACTIONDESC(WLINE) = "" # Issue X3-105283

PLANACT = NewInstance C_PLANACT AllocGroup null
LOCSTATUS = fmet PLANACT.AREAD([M:NCSP1]ACTIONID(WLINE))
If (LOCSTATUS = [V]CST_AOK)
    # Issue X3-105283 - get description from Action
    Call LECTEXTRA([M:NCSP1]ACTIONDESC(WLINE),"ATABDIV","LNGDES","806", PLANACT.TRANACTION) From ATEXTRA
Endif
FreeGroup PLANACT

End

##########################################################################################################
# Populate on screen only Non-conformance data properties.
##########################################################################################################
Subprog FILL_FROM_NCSRECENT()

Local Integer LOCAL_ASTATUS
Local Instance MYNCSRECENT Using C_NCSRECENT
MYNCSRECENT = NewInstance C_NCSRECENT AllocGroup null

LOCAL_ASTATUS = fmet MYNCSRECENT.AREAD([M:NCSP0]NCSID)

If (LOCAL_ASTATUS = CST_AOK)
    [M:NCSP0]NCSSTA      = MYNCSRECENT.NCSSTA
    [M:NCSP0]PRODUCT     = MYNCSRECENT.PRODUCT
    If dim([M:NCSP0]ECCVALMAJ) > 0
        [M:NCSP0]ECCVALMAJ   = MYNCSRECENT.ECCVALMAJ
        [M:NCSP0]ECCVALMIN   = MYNCSRECENT.ECCVALMIN
    Endif
    [M:NCSP0]NCSMANAGER  = MYNCSRECENT.NCSMANAGER
    [M:NCSP0]NCSPLANNER  = MYNCSRECENT.NCSPLANNER
    [M:NCSP0]SITE        = MYNCSRECENT.SITE     # Issue X3-72907
Endif

FreeGroup MYNCSRECENT

End

