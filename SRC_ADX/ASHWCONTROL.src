#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ASHWVAL
End

#-----------------------------------------------------------------#
# Here goupe all the checks that are initially not necessay but repeated due to the fact that some classes were created
# before the screen controle was completed.
#-----------------------------------------------------------------#
Subprog VERIF_VALID_REP(DOSSIER, CODREP,RES_OK,AERR)
Value Char       DOSSIER
Value Char       CODREP
Variable Integer RES_OK
Variable  Instance  AERR(1..) Using C_AERROR

Gosub OPEN_FILE  From ASHWVALLEC

Local Char L_ERR_MSG(250), L_ERR_MSG_TYP(50)
Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..), L_PARCOL(GLONAVC)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR,ISTABLE
Gosub DEF_TAB_PARLNK From SUBASW_TOOL
Local Integer WPARNOVERIF

Local Char TABCLA(80)(1..50),TABPTR(80)(1..50),PRO(50)
Local Integer NBCLA,ISACTX,WTYPCLA

Local Char PARACT(GLONACV)

Local Char L_BLC_STD(250), L_COL_CUR(250),L_COL_CUR2(250), L_COL_PRO(250)
Local Integer FLG_HAS_ERROR, FLG_OK
#Local Integer REF_CODFLD,AS_REFKEY
Local Integer AS_LOKREFANC

Local Integer NBCLE
Local Char    CLE(GLONAVB)(1..),CHAINE(250)

RES_OK = 1

# 1 basic checks
Read [F:ASW]ASW0=[L]CODREP
If fstat
  RES_OK = 0
  Call  ADD_AERR([L]CODREP-":"-mess(15,140,1),[V]CST_AERROR,0,AERR) From ACLACONTROL :  # Référence $1$ n'EST # Représentation inexistante valide.
  Goto FIN_VERIF_VALID_REP
Elsif [F:ASW]CODACT<>""
 Read [ACV]CODACT = [F:ASW]CODACT
 If fstat or [F:ACV]FLACT<>2
  RES_OK = 0
  #91436 warning sur classe/rep inactive
  #Call  ADD_AERR([L]CODREP-":"-mess(22,140,1)-"("+[F:ACV]CODACT+")",[V]CST_AERROR,0,AERR) From ACLACONTROL : #  # Représentation inactive
  Call  ADD_AERR([L]CODREP-":"-mess(22,140,1)-"("+[F:ACV]CODACT+")",[V]CST_AWARNING,0,AERR) From ACLACONTROL : #  # Représentation inactive
  Goto FIN_VERIF_VALID_REP
 Endif
Endif

Read [F:ACLA]ACLA0 = [F:ASW]CODCLA
If fstat
  RES_OK = 0
  Call  ADD_AERR([F:ASW]CODCLA+":"-mess(4,140,1),[V]CST_AERROR,0,AERR) From ACLACONTROL : #  #  Classe inexistante
  Goto FIN_VERIF_VALID_REP
Elsif find([F:ACLA]TYPCLA,1,3,4)
   RES_OK = 0
   # Une classe technique ou système ou basic ne peut pas être utilisée dans une représentation
   Call  ADD_AERR([F:ASW]CODCLA+":"-mess(186,143,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
   Goto FIN_VERIF_VALID_REP
Elsif [F:ACLA]FLGBUFFER=2
   Call  ADD_AERR([F:ASW]CODCLA+":"-mess(274,143,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
   Goto FIN_VERIF_VALID_REP
Elsif [F:ACLA]CODACT<>""
 If fstat or [F:ACV]FLACT<>2
  Read [ACV]CODACT = [F:ACLA]CODACT
  If fstat or [F:ACV]FLACT<>2
   RES_OK = 0
   #91436 warning sur classe/rep inactive
   #Call  ADD_AERR([F:ASW]CODCLA-":"-mess(31,140,1)-"("+[F:ACLA]CODACT+")" ,[V]CST_AERROR,0,AERR)From ACLACONTROL : # Classe inactive
   Call  ADD_AERR([F:ASW]CODCLA-":"-mess(31,140,1)-"("+[F:ACLA]CODACT+")" ,[V]CST_AWARNING,0,AERR)From ACLACONTROL : # Classe inactive
   Goto FIN_VERIF_VALID_REP
  Endif
 Endif
Endif

If [F:ACLA]TYPCLA=2
 Read [F:ATB]CODFIC  = [F:ACLA]TABREF
 If fstat
  RES_OK = 0
  Call  ADD_AERR([F:ACLA]TABREF-":"-mess(124,124,1),[V]CST_AERROR,0,AERR) From ACLACONTROL : # table inexistante
  Goto FIN_VERIF_VALID_REP
 Else
  WTYPCLA =  [F:ACLA]TYPCLA
  If dim([F:ATB]ISTABLE)>0
   [L]ISTABLE = [F:ATB]ISTABLE
  Else
   [L]ISTABLE = 2
  Endif
 Endif
Endif

Read [F:ACLAT]ACLAT0=[F:ASW]CODCLA;"R"
If fstat or (!fstat and [F:ACLAT]ENAMETSTD<>2)
 Call  ADD_AERR(func AFNC.MES1(mess(92,140,1),[F:ASW]CODCLA),[V]CST_AERROR,0,AERR) From ACLACONTROL : # table inexistante
 Goto FIN_VERIF_VALID_REP
Endif

#90869
Call VERIF_CLA_RECURS([L]DOSSIER,[F:ASW]CODCLA,AERR,RES_OK) From ACLACONTROL
If RES_OK<>1
 Goto FIN_VERIF_VALID_REP
Endif

#100106 For non system representations, the authorization function is now mandatory
#101282 Make the authorization function not mandatory
#If [F:ASW]FLGSYSTEM<>2 & [F:ASW]AFCRIGHT=""
# RES_OK = 0
# Call  ADD_AERR([F:ASW]CODREP-":"-mess(282,143,1) ,[V]CST_AERROR,0,AERR)From ACLACONTROL
# Goto FIN_VERIF_VALID_REP
#Endif

If [F:ASW]TYPMSKREP<>1 & [F:ASW]FONCTION<>""
   L_ERR_MSG=func AFNC.MES1(mess(252,143,1), mess([F:ASW]TYPMSKREP,7963,1))-":"-mess(253,143,1)
   RES_OK = 0
   Call  ADD_AERR([F:ASW]CODREP-":"-L_ERR_MSG ,[V]CST_AERROR,0,AERR)From ACLACONTROL
   Goto FIN_VERIF_VALID_REP
Endif

# 2 check collection
Gosub VERIF_ASWC

# 2.1 check options
Gosub VERIF_ASWO

# 3 loop on each property and check
Gosub VERIF_ASWF

Gosub CHARGE_ASWMN # Menus (necessaires dans VERIF_ASWK)

# 4 loop on each link and check
Gosub VERIF_ASWK_ALL

# 5 exposed properties
Gosub VERIF_ASWR

# 6 Menus
Gosub VERIF_ASWMN

Gosub VERIF_FACETTE

$FIN_VERIF_VALID_REP
Gosub CLOSE_FILE  From ASHWVALLEC
If maxtab(ASWMEN)>0
 FreeGroup ASWMEN(1)
Endif
End


#----------------------------------
$VERIF_ASWC
# 2 check collection
For [ASWC] Where CODREP=[L]CODREP

 # 2.1 check activity code for MAXCOL
 If [F:ASWC]ACTCOL <> ""
  Read [ACV]CODACT = [F:ASWC]ACTCOL
  If !fstat
   If [ACV]TYP <> 2
    # Le Code activité $1$ associé au Groupe $2$ n'est pas de type Dimensionnement.
    RES_OK = 0
    Call  ADD_AERR(func AFNC.MES2( mess(111,143,1),[F:ASWC]ACTCOL,[F:ASWC]CODCOL) ,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Elsif [ACV]DIME = 0 & instr(1,[F:ASWC]CODCOL,".")=0
    # Code activité xxx : Valeur 0 impossible pour les classes représentations.
    RES_OK = 0
    Call  ADD_AERR(mess(259,126,1)-[F:ASWC]CODCOL+"/MAXCOL: "+mess(14,115,1)-[F:ASWC]ACTCOL-": "+mess(105,143,1) ,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Else
   # Code activité inexistant
   RES_OK = 0
   Call  ADD_AERR([F:ASWC]ACTCOL+": "+mess(22,150,1) ,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
 Elsif instr(1,[F:ASWC]CODCOL,".")=0 & [F:ASWC]MAXCOL<=0
  If [F:ASWC]MAXCOL = 0
   # Valeur 0 impossible pour les classes représentations.
   Call  ADD_AERR(mess(259,126,1)-[F:ASWC]CODCOL+"/MAXCOL: "+mess(105,143,1) ,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Else
   # Valeur incorrecte
   Call  ADD_AERR(mess(259,126,1)-[F:ASWC]CODCOL+"/MAXCOL: "+mess(83,123,1) ,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
  RES_OK = 0
 Endif
Next
Return


#----------------------------------
$VERIF_ASWO
# 2.1 check options
For [ASWO] Where CODREP=[L]CODREP
 If [F:ASWO]OPTFLGCLA=2
  Read [ACLAO]ACLAO0=[F:ASW]CODCLA;[F:ASWO]OPTCOD
  If fstat
   RES_OK = 0
   Call  ADD_AERR(func AFNC.MES2(mess(147,143,1), [F:ASWO]OPTCOD, [F:ASW]CODCLA ) ,[V]CST_AERROR,0,AERR)From ACLACONTROL : # Classe inactive
  Else
   If [F:ACLAO]OPTCND=""
     # Filtre xxx Erreur zone "" : Zone obligatoire
     L_ERR_MSG=mess(245,143,1)-[F:ASWO]OPTCOD-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW2","OPTCND")+'"'
     Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
   Elsif func SUBASW2.CONTROL_SDATA([F:ACLAO]OPTCND,L_ERR_MSG)=0
    Call ADD_AERR(mess(245,143,1)-[F:ACLAO]OPTCOD-":"-L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif
 Else
  If [F:ASWO]OPTCND=""
    # Filtre xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(245,143,1)-[F:ASWO]OPTCOD-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW2","OPTCND")+'"'
    Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Elsif func SUBASW2.CONTROL_SDATA([F:ASWO]OPTCND,L_ERR_MSG)=0
   Call ADD_AERR(mess(245,143,1)-[F:ASWO]OPTCOD-":"-L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
 Endif
Next

# Verification que chaque elemnt de l'index est bien en query
If [F:ASW]CODIND<>"" or  [F:ASW]DESCRIPT<>""
 Local Integer NBKEYS
 Local Char    KEYS(GLONAVB)(1..),ORDS(5)(1..),CHAINE(250),WPRO(80)
 If [F:ASW]CODIND<>""
  Read [F:ACLA]ACLA0 = [F:ASW]CODCLA
  If !fstat
   Read [F:ATI]CODIND = [F:ASW]CODREP;[F:ACLA]TABREF
   If !fstat
    CHAINE = [F:ATI]DESCRIPT
   Endif
  Endif
 Else
  CHAINE = [F:ASW]DESCRIPT
 Endif
 Call SETCLEORDER([L]NBKEYS,[L]KEYS,[L]ORDS,CHAINE) From LNKSUB
 For J=1 To [L]NBKEYS
  K=-1
  WPRO = [F:ASW]ABRCLA+"."+[L]KEYS(J)
  For [ASWR]ASWR0 Where CODREP = [L]CODREP & CODPRO=[L]WPRO
    K = 1 :    Break
  Next
  If K=-1 or  [F:ASWR]QRYPRO<>2
   Call ADD_AERR(func AFNC.MES2(mess(273,143,1),WPRO,CHAINE),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
 Next
Endif

Return

#----------------------------------
$VERIF_ASWF
# 3 loop on each property and check
For [ASWF] Where CODREP = [L]CODREP

 If [F:ASWF]ACTFLD="" or ([F:ASWF]ACTFLD<>"" and func ASYRFNC.ACTIVDOS(DOSSIER,[F:ASWF]ACTFLD)>0)


  # 3.1 property code can not be the same with a collection code (except for property of instance)
  Read [ASWC]ASWC0=[L]CODREP;[F:ASWF]CODFLD
  If !fstat
   RES_OK = 0
   # Code déjà utilisé pour une propriété ou une collection.
   Call  ADD_AERR(mess(34,140,1)-[F:ASWF]CODFLD-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-":"-mess(146,143,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  # 3.2 check the collection of the property : must have an Alias code
  If [F:ASWF]FLDGRP<>""
   Read [ASWC]ASWC0=[L]CODREP;[F:ASWF]FLDGRP
   If fstat or [F:ASWC]ALIASCOL = ""
    RES_OK = 0
    # Alias obligatoire
    Call  ADD_AERR(mess(34,140,1)-[F:ASWF]CODFLD-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-":"-func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP")-[F:ASWF]FLDGRP-":"-mess(169,143,1),[V]CST_AERROR,0,AERR)
& From ACLACONTROL
  Endif
   If instr(1,[F:ASWF]FLDGRP,".")
    #La définition de propriété de représentation sur la collection $1$ n'est pas autorisée
    Call  ADD_AERR(mess(34,140,1)-[F:ASWF]CODFLD-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-":"-func AFNC.MES1(mess(223,143,1), [F:ASWF]FLDGRP),[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif

  If [F:ASWF]INTFLD=0
   RES_OK = 0
   # Propriété xxx Erreur zone "" : Zone obligatoire
   L_ERR_MSG=mess(34,140,1)-[F:ASWF]CODFLD-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW9","AZINTFLD")+'"'
   Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  If  [F:ASWF]INTSHTFLD=0
   RES_OK = 0
   # Propriété xxx Erreur zone "" : Zone obligatoire
   L_ERR_MSG=mess(34,140,1)-[F:ASWF]CODFLD-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW9","AZINTSHTFLD")+'"'
   Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  # 3.3 check parameters/keys of properties (TYPPAR = 1)
  Raz RES_COD,RES_CLA, RES_TIT, L_ERR_MSG
  Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
  Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR,WWVALPAR
  Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
  Raz WWPARFIL,WWPARENT
  Raz  NBCLE
  Raz CLE,CHAINE

  Call LOAD_TYPE_PARAM([L]DOSSIER,[F:ASWF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC

  For I=0 To [L]RES_NBR-1
   # Only the functionnal parameters will be checked, the imposed parameters will be managed automatically at validation time.
   If !find(RES_COD(I),"AINSTANCE","APRONAME","AVALCNT","AEXIST","AVALUE","AFORMAT")
    Read [F:ASWP]ASWP0 = [L]CODREP; 1; 1;[F:ASWF]CODFLD;"";1;[L]RES_COD(I)
    If fstat & RES_COD(I)<>"AFILTER"
     RES_OK = 0
     L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(50,140,1)-'"'+[L]RES_COD(I)+'" : '+mess(141,143,1) # Valeur non définie.
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif !fstat
     If !func SUBASW_TOOL.L_CHECK_PARAMETER([F:ASWF]CODFLD,[F:ASWF]CODTYP,[F:ASWP]CODPAR,[F:ASWF]ACTFLD,[F:ASWP]VALEUR, [L]RES_TYP(I), [L]RES_MOD(I), [F:ASWF]FLDGRP,
&    [F:ASWP]CODREP, 2, 0, 0, 0,0,0,0,0, [F:ASWP]TYPAFF, L_ERR_MSG)
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWP]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(50,140,1)-'"'+[F:ASWP]CODPAR+'" : '+L_ERR_MSG
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
    Endif
   Endif
  Next

  # 3.4 check ATYPE+keys
  If [F:ASWF]CODTYP<>""
  Read [ATY]CODTYP = [F:ASWF]CODTYP
  If fstat
     RES_OK = 0
     L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(82,133,1)-[F:ASWF]CODTYP : # Type de données inexistant
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Elsif !fstat & [F:ATY]TYPSELSYR=3 & [F:ATY]TYPPROSYR=""
     #Le prototype est obligatoire pour utiliser un type de données Rich media
     RES_OK = 0
     L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(249,143,1)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Elsif !fstat & [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
    If [F:ASWF]LOBTAB="" | [F:ASWF]LOBFLD=""
     #La table et le champ du lob sont obligatoires pour un type de données Rich media avec gestion superviseur
     RES_OK = 0
     L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(180,143,1)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif [F:ASWF]LOBTAB<>""
     Read [F:ATB]CODFIC  = [F:ASWF]LOBTAB
     If fstat
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"
      Call  ADD_AERR(L_ERR_MSG-":"-mess(124,124,1)-[F:ASWF]LOBTAB,[V]CST_AERROR,0,AERR)  From ACLACONTROL : # table inexistante
     Else
      Read [ATI]NUMLIG = [F:ASWF]LOBTAB;1
      If !fstat
       Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,[L]DOSSIER,[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA

       For I=0 To [L]WWNBRPARALL-1
        Read [ASWP]ASWP0 = [L]CODREP; 1; 2;[F:ASWF]CODFLD;"";1;[L]WWCODPAR(I)
        If fstat
         RES_OK = 0
         L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(51,140,1)-'"'+[L]WWCODPAR(I)+'" : '+mess(141,143,1) # Valeur non définie.
         Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
        Else
         If !func SUBASW_TOOL.L_CHECK_PARAMETER([F:ASWF]CODFLD,[F:ASWF]CODTYP,[F:ASWP]CODPAR,[F:ASWF]ACTFLD,[F:ASWP]VALEUR, [L]WWTYPINTPAR(I), [L]WWADRVAL(I), [F:ASWF]FLDGRP,
&        [F:ASWP]CODREP, 2, 0, 0, 0,0,0,0,0, [F:ASWP]TYPAFF, L_ERR_MSG)
          RES_OK = 0
          L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWP]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(51,140,1)-'"'+[F:ASWP]CODPAR+'" : '+L_ERR_MSG
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
         Endif
        Endif
       Next
      Endif
     Endif
    Endif
 # Elsif !fstat & [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=1
 #   For J=6 To 9
 #    Read [ATYR]ATYR0=[ATY]CODTYP;J
 #    If fstat
 #      # Les règles $1$ \sont obligatoires pour le type "$2$" sans gestion superviseur
 #      RES_OK = 0
 #      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-func AFNC.MES2(mess(163,143,1),
 #&             mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1),
 #&             mess(3,7881,1))
 #      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
 #      Break
 #    Endif
 #   Next J
  Elsif !fstat & [F:ATY]CODCLA<> ""
 #  [L]REF_CODFLD=0
 #  [L]AS_REFKEY=0
  Call CHARGE_CLA_ATI_CLE([L]DOSSIER,[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
   For I=0 To [L]WWNBRPARALL-1
    Read [ASWP]ASWP0 = [L]CODREP; 1; 2;[F:ASWF]CODFLD;"";1;[L]WWCODPAR(I)
    If fstat
     RES_OK = 0
     L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(51,140,1)-'"'+[L]WWCODPAR(I)+'" : '+mess(141,143,1) # Valeur non définie.
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Else
     If !func SUBASW_TOOL.L_CHECK_PARAMETER([F:ASWF]CODFLD,[F:ASWF]CODTYP,[F:ASWP]CODPAR,[F:ASWF]ACTFLD,[F:ASWP]VALEUR, [L]WWTYPINTPAR(I), [L]WWADRVAL(I), [F:ASWF]FLDGRP,
&    [F:ASWP]CODREP, 2, 0, 0, 0,0,0,0,0, [F:ASWP]TYPAFF, L_ERR_MSG)
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWP]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(51,140,1)-'"'+[F:ASWP]CODPAR+'" : '+L_ERR_MSG
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
 #    If [F:ASWF]LOBTAB=""
 #      [L]AS_REFKEY=1
 #      If [F:ASWF]FLDGRP=""
 #        If find([F:ASWP]VALEUR,[F:ASWF]CODFLD,"=num$("+[F:ASWF]CODFLD+")","=val("+[F:ASWF]CODFLD+")")
 #          [L]REF_CODFLD=1
 #        Endif
 #      Else
 #        If find([F:ASWP]VALEUR,[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD,"=num$("+[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD+")","=val("+[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD+")")
 #          [L]REF_CODFLD=1
 #        Endif
 #      Endif
 #    Endif
    Endif
   Next
 #  If [L]REF_CODFLD=0 & [L]AS_REFKEY=1
 #    If [F:ASWF]FLDGRP=""
 #      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-func AFNC.MES1(mess(217,143,1),[F:ASWF]CODFLD)
 #    Else
 #      L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-func AFNC.MES1(mess(217,143,1),[F:ASWF]FLDGRP+"."+[F:ASWF]CODFLD)
 #    Endif
 #    RES_OK = 0
 #    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
 #  Endif
  Endif
  Elsif [F:ASWF]CODTYP="" & [F:ASWF]FLDGRP=""
   RES_OK = 0
   L_ERR_MSG = mess(34,140,1)-'"'+[F:ASWF]CODFLD+'"'-"("+mess(3,40,1)-num$([F:ASWF]NUMLIG)+")"-mess(184,143,1)
   Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
 Endif
Next
Return

#----------------------------------
$VERIF_ASWK_ALL
# 4 loop on each link and check
# ASWK0=CODREP+AFFLNK+ANCLNK+CODLNK
For [ASWK]ASWK0(3) Where CODREP=[L]CODREP and ENALNK=2 and AFFLNK<>1
 PARACT=[F:ASWK]ACVLNK
 Gosub _VERIF_ASWK
Next
Return

#----------------------------------
$VERIF_ASWK_ASWR
# 4 loop on each link and check
# ASWK0=CODREP+AFFLNK+ANCLNK+CODLNK
For [ASWK]ASWK0(3) Where CODREP=[L]CODREP and ENALNK=2 and AFFLNK=1 and [F:ASWK]ANCLNK=[F:ASWR]CODPRO
 If func AFNC.ACTIV([F:ASWK]ACVLNK)
  PARACT=[F:ASWR]ACTPRO
 Else
  PARACT=[F:ASWK]ACVLNK
 Endif
 Gosub _VERIF_ASWK
Next
Return

#----------------------------------
$_VERIF_ASWK
# 4 loop on each link and check
# ASWK0=CODREP+AFFLNK+ANCLNK+CODLNK
 L_PARCOL=""
 Case [F:ASWK]AFFLNK
  When 1: #property
   If instr(1,[F:ASWK]ANCLNK,".")
   L_PARCOL = func SUBASW_TOOL.GET_COL_FROM_PRO_PATH([F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[F:ASWK]ANCLNK,1)
   Endif
  When 2: #collection line
   L_PARCOL = [F:ASWK]ANCLNK
 Endcase
 For [ASWK]ASWK0
  [L]AS_LOKREFANC=0
  #Check link
  If [F:ASWK]REMSTDLNK<>""
    Read [ASWK2]ASWK0=[L]CODREP;[F:ASWK]AFFLNK;[F:ASWK]ANCLNK;[F:ASWK]REMSTDLNK
    If fstat
      # Code inexistant
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+[F:ASWK]REMSTDLNK-mess(84,141,1)
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif [F:ASWK2]FLGSTDLNK=2
      # Le lien de remplacement $1$ doit être non standard
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+func AFNC.MES1(mess(204,143,1),[F:ASWK]REMSTDLNK)
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif !(([F:ASWK2]TYPLNK=[F:ASWK]TYPLNK & [F:ASWK2]CMPLNK=[F:ASWK]CMPLNK)
&          |([F:ASWK]TYPLNK=1 & [F:ASWK2]TYPLNK=4)
&          |([F:ASWK]TYPLNK=4 & [F:ASWK2]TYPLNK=1))
      #Le lien de remplacement $1$ doit correspondre aux type et action du lien $2$
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+func AFNC.MES2(mess(203,143,1),[F:ASWK]REMSTDLNK,[F:ASWK]CODLNK)
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif [F:ASWK2]TARLNK=3
      #Le lien $1$ avec une cible $2$ ne peut pas être utilisé comme lien de remplacement
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+func AFNC.MES2(mess(283,143,1),[F:ASWK]REMSTDLNK,mess([F:ASWK2]TARLNK,7975,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif [F:ASWK]ENALNK=2 & [F:ASWK2]ENALNK<>2
      # Le lien de remplacement $1$ doit être actif
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+func AFNC.MES1(mess(195,143,1),[F:ASWK]REMSTDLNK)
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
  Endif
  If [F:ASWK]MENLNK<>"" & !find([F:ASWK]MENLNK,ASWMEN(1..NBMEN).CODMENU)
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   mess(84,141,1)-[F:ASWK]MENLNK
    RES_OK = 0
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Elsif [F:ASWK]MENLNK<>"" & [F:ASWK]TARLNK=3
     #Un lien avec une cible $1$ ne peut pas avoir de menu
     L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&              func AFNC.MES1(mess(285,143,1), mess([F:ASWK]TARLNK,7975,1))
     RES_OK = 0
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  If [F:ASWK]REPLNK<>""
   Read [ASW2]ASW0 = [F:ASWK]REPLNK
   If !fstat
    If [F:ASW]TYPMSKREP<>[F:ASW2]TYPMSKREP
     L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&              func AFNC.MES1(mess(252,143,1), mess([F:ASW]TYPMSKREP,7963,1))-":"-func AFNC.MES1(mess(255,143,1), mess([F:ASW2]TYPMSKREP,7963,1))-[F:ASWK]REPLNK
     RES_OK = 0
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
   Endif
  Endif
  If [F:ASW]TYPMSKREP<>1 & [F:ASWK]TYPLNK=4
   L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&            func AFNC.MES1(mess(252,143,1), mess([F:ASW]TYPMSKREP,7963,1))-":"-mess(254,143,1)
   RES_OK = 0
   Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  If [F:ASWK]ENALNK=2
    If [F:ASWK]AFFLNK=1 & [F:ASWK]CMPLNK=9 & [F:ASWK]EDILNK=2
      #si prop clé de la classe principale, pas de lookup
      If func SUBASW_TOOL.IS_CLA_KEY([F:ASWK]ANCLNK,func SUBASW_TOOL.GET_TYP_FROM_PRO_PATH_DOSS([L]DOSSIER,[F:ASW]CODREP,[F:ASWK]ANCLNK),[F:ASW]CODCLA,[F:ASW]ABRCLA)
         L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([F:ASWK]CMPLNK,7971,1),mess(2,7964,1))+' : '+
&                   func AFNC.MES1(mess(218,143,1),[F:ASWK]ANCLNK)
          RES_OK = 0
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
      Endif
    Endif
    # Type de lien Représentation/"Dupliquer fiche" non autorisé
    If [F:ASWK]CMPLNK=6
      #Lien de type $1$ non autorisé. Ce lien doit être inactif ou supprimé
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES1(mess(216,143,1),mess([F:ASWK]TYPLNK,7974,1)+'/"'+mess(6,7971,1)+'"')
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
    # On autorise les opérations uniquement sur AFFLNK=5/4
    If [F:ASWK]TYPLNK=3 & !find([F:ASWK]AFFLNK,4,5)
      #Lien de type $1$ non autorisé sur ce type d'ancre. Ce lien doit être inactif ou supprimé
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES1(mess(267,143,1),mess(3,7974,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
    #101877/99183 #Method on property not allowed
    If [F:ASWK]TYPLNK=2 & [F:ASWK]AFFLNK=1
      #Lien de type $1$ non autorisé sur ce type d'ancre. Ce lien doit être inactif ou supprimé
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES1(mess(267,143,1),mess(2,7974,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
    #Sur Lookup, pas de méthode ni X3 Convergence
    If find([F:ASWK]TYPLNK,2,4) & [F:ASWK]LOKLNK=2
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES2(mess(215,143,1),mess([F:ASWK]TYPLNK,7974,1),mess(4,7964,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif [F:ASWK]LOKLNK=2 & [F:ASWK]TARLNK>1
      #Lien avec une cible "$1$" non autorisé sur facette $2$
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES2(mess(286,143,1),mess([F:ASWK]TARLNK,7975,1),mess(4,7964,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
    #Sur Summary, pas de méthode ni X3 Convergence
    If find([F:ASWK]TYPLNK,2,4) & [F:ASWK]SUMLNK=2
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&               func AFNC.MES2(mess(215,143,1),mess([F:ASWK]TYPLNK,7974,1),mess(5,7964,1))
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
    #Sur Edit, uniquement Rep(1)/9-10 ou methode(2)
    If [F:ASWK]FLGSTDLNK<>2 & [F:ASWK]EDILNK=2
      If [F:ASWK]TYPLNK=1
        If !find([F:ASWK]CMPLNK,9,10)
          L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([F:ASWK]CMPLNK,7971,1),mess(2,7964,1))
          RES_OK = 0
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
        Elsif [F:ASWK]TARLNK>1
          #Lien avec une cible "$1$" non autorisé sur facette $2$
          L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES2(mess(286,143,1),mess([F:ASWK]TARLNK,7975,1),mess(2,7964,1))
          RES_OK = 0
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
        Endif
      Elsif !find([F:ASWK]TYPLNK,2,5)
          L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([F:ASWK]TYPLNK,7974,1),mess(2,7964,1))
          RES_OK = 0
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
      Elsif [F:ASWK]TARLNK>1
          #Lien avec une cible "$1$" non autorisé sur facette $2$
          L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES2(mess(286,143,1),mess([F:ASWK]TARLNK,7975,1),mess(2,7964,1))
          RES_OK = 0
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
      Endif
    Endif
    #101876
    If [F:ASWK]TYPLNK=2
     If find([F:ASWK]AFFLNK,2,3) & [F:ASWK]CLAPTRLNK<>[F:ASWK]ANCLNK
      # Chemin de la classe incorrect
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   mess(57,140,1)-":"-[F:ASWK]CLAPTRLNK
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Elsif find([F:ASWK]AFFLNK,4,5) & ([F:ASWK]CLAPTRLNK<>"" & [F:ASWK]CLAPTRLNK<>[F:ASW]ABRCLA)
      # Chemin de la classe incorrect
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   mess(57,140,1)-":"-[F:ASWK]CLAPTRLNK
      RES_OK = 0
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Elsif [F:ASWK]AFFLNK=1
      If pat([F:ASWK]ANCLNK,[F:ASWK]CLAPTRLNK+".*")=0
       # Chemin de la classe incorrect
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   mess(57,140,1)-":"-[F:ASWK]CLAPTRLNK
       RES_OK = 0
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
      Elsif instr(0,right$([F:ASWK]ANCLNK,len([F:ASWK]CLAPTRLNK)+2),".")>0
       # Chemin de la classe incorrect
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   mess(57,140,1)-":"-[F:ASWK]CLAPTRLNK
       RES_OK = 0
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
      Endif
     Endif
    Endif
    #102203/5
    If [F:ASWK]TARLNK>1
     # to be able to set the target on a page link (a free link or a representation link on query, details, or summary facet).
     OK_TARGET=0
     If [F:ASWK]AFFLNK=4 & [F:ASWK]TYPLNK=5 : OK_TARGET=1 : Endif
     If [F:ASWK]AFFLNK=4 & [F:ASWK]TYPLNK=1 & find([F:ASWK]CMPLNK,2,5,10)>0 : OK_TARGET=1 : Endif
     If !OK_TARGET
       # Cible $1$ non autorisée sur ce type de lien
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES1(mess(284,143,1),mess([F:ASWK]TARLNK,7975,1))
       RES_OK = 0
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
     If [F:ASWK]TARLNK=3 & [F:ASWK]TYPLNK=1 & [F:ASWK]REPLNK=[ASWK]CODREP
       #un lien avec une cible "$1$" ne peut pas pointer sur la représentation courante
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+
&                   func AFNC.MES1(mess(289,143,1),mess([F:ASWK]TARLNK,7975,1))
       RES_OK = 0
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
    Endif
  Endif
  #Check parameters
  #cf AML 7971
  If [F:ASWK]REMSTDLNK=""
   # 4.1 check keys/parameters of link (TYPPAR = 3)
   Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR,WWVALPAR
   Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
   Raz WWPARFIL,WWPARENT

   Gosub DEF_PARLNK From SUBASW_TOOL
   Gosub LOAD_PARLNK From SUBASW_TOOL

   For I=0 To [L]WWNBRPARALL-1
    Raz L_ERR_MSG,WPARNOVERIF
    If [F:ASWK]CODLNK="AEDIT" & [F:ASWK]AFFLNK=4 & WWTYPKEY(I)=2
     #pas de clé pour les liens convergence en page ssi STD (AEDIT)
     WPARNOVERIF=1
    Endif
    If WWTYPKEY(I)=2
     L_ERR_MSG_TYP = mess(51,140,1)
    Else
     L_ERR_MSG_TYP = mess(50,140,1)
    Endif

    Read [ASWP]ASWP0 = [L]CODREP; 3; [L]WWTYPKEY(I);[F:ASWK]ANCLNK;[F:ASWK]CODLNK;[F:ASWK]AFFLNK;[L]WWCODPAR(I)
    If fstat
     # on ne bloque pas pour les paramètres de filtre ou d'entrée
     If WPARNOVERIF=0 & ([L]WWTYPKEY(I)=2 | ([L]WWPARFIL(I)<>2 & [L]WWPARENT(I)<>2))
       RES_OK = 0
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+L_ERR_MSG_TYP-'"'+[L]WWCODPAR(I)+'" : '+mess(141,143,1)
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
    Else
     If !func SUBASW_TOOL.L_CHECK_PARAMETER([F:ASWP]CODFLD,"",[F:ASWP]CODPAR,PARACT,[F:ASWP]VALEUR, [L]WWTYPINTPAR(I), [L]WWADRVAL(I), L_PARCOL,
&            [F:ASWP]CODREP, 2, 1, [F:ASWK]CMPLNK,
&            [F:ASWK]DETLNK,[F:ASWK]QRYLNK,[F:ASWK]EDILNK,[F:ASWK]LOKLNK,[F:ASWK]SUMLNK,
&            max([F:ASWP]TYPAFF,[F:ASWP]PARFIL,[F:ASWP]PARENT), L_ERR_MSG)
      RES_OK = 0
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+L_ERR_MSG_TYP-'"'+[F:ASWP]CODPAR+'" : '+L_ERR_MSG
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Endif
     If [F:ASWK]CMPLNK=9 & [F:ASWP]TYPKEY=2 & [F:ASWP]ADRVAL=1 & [F:ASWP]VALEUR=[F:ASWK]ANCLNK
      [L]AS_LOKREFANC=1
     Endif
    Endif
   Next
   If [F:ASWK]CMPLNK=9 & [L]AS_LOKREFANC=0
     L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)+' : '+func AFNC.MES1(mess(224,143,1), mess(1,34,1))
     RES_OK = 0
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif
 Next
Return

#----------------------------------
$VERIF_ASWR
Local Char WATY(GLONATY)
# 5 exposed properties
 # 5.1 check block valid
 For [ASWR]ASWR0 Where CODREP = [L]CODREP

  WATY=func SUBASW_TOOL.GET_TYP_FROM_PRO_PATH_DOSS(DOSSIER,[F:ASW]CODREP, [F:ASWR]CODPRO)
  #90233
  For [ASWR2]ASWR3 Where CODREP=[L]CODREP & CODPRO=[F:ASWR]CODPRO & [F:ASWR2]ALIAS<[F:ASWR]ALIAS
    # PROPRIÉTÉ EXPOSÉE XXX / YYY
    L_ERR_MSG = func AFNC.MES1( mess(239,143,1),[ASWR2]ALIAS) # Le code propriété est déjà utilisé sur l'alias "$1$"
    L_ERR_MSG = mess(35,140,1)-[ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-"/"-[ASWR]CODPRO-":"-L_ERR_MSG
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Next

  If [F:ASWR]INTPRO=0
    # Propriété exposée xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW4","AZINTPRO")+'"'
    Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
  If [F:ASWR]INTSHTPRO=0
    # Propriété exposée xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW4","AZINTSHTPRO")+'"'
    Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif

  #Check UOMPRO
  If [F:ASWR]UOMPRO<>""
   If find(func ATY_TOOL.GET_INTERNAL_TYP_LM30(WATY),2,3,4,5,6)=0
     # Propriété exposée xxx : La propriété unité doit être indiquée uniquement sur les propriétés numériques
     L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(242,143,1)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
   Read [ASWR2]ASWR3=[F:ASW]CODREP;[F:ASWR]UOMPRO
   If !fstat
    If func SUBASW.IS_ATY_UNIT(func SUBASW_TOOL.GET_TYP_FROM_PRO_PATH_DOSS(DOSSIER,[F:ASW]CODREP, [F:ASWR2]CODPRO))=0
     # Propriété exposée xxx : La propriété "$1$" ne correspond pas à une unité
     L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-func AFNC.MES1(mess(241,143,1), [F:ASWR]UOMPRO)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Elsif ([F:ASWR]QRYPRO=2 & [F:ASWR2]QRYPRO<>2)
&      | ([F:ASWR]DETPRO=2 & [F:ASWR2]DETPRO<>2)
&      | ([F:ASWR]EDIPRO=2 & [F:ASWR2]EDIPRO<>2)
&      | ([F:ASWR]LOKPRO=2 & [F:ASWR2]LOKPRO<>2)
&      | ([F:ASWR]SUMPRO=2 & [F:ASWR2]SUMPRO<>2)
     # Propriété exposée xxx : La propriété unité doit être présente sur les mêmes facettes
     L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(243,143,1)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
   Else
     # Propriété exposée xxx : YYY Veuillez indiquer une propriété exposée
     L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-[F:ASWR]UOMPRO-mess(170,143,1)
     Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif

 If [F:ASWR]TYPAFFPRO=2
  If WATY<>""
   Read [ATY]CODTYP=WATY
   If !fstat & [F:ATY]FMTPROSYR=6 & !(nomap="SUPERV" & [L]CODREP="ZZVPOTCRUD") : #VVVVV pour test SAM111036
    # Propriété exposée xxx : YYY Ce type de données ne peut pas être saisissable
    L_ERR_MSG=mess(35,140,1)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-WATY-mess(251,143,1)
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif
 Endif

  Read [ASWB]ASWB0=[L]CODREP;[F:ASWR]BLCPRO
  If fstat
   RES_OK = 0
   L_ERR_MSG = mess(35,140,1)-[ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-"/"-[ASWR]BLCPRO-":"-mess(141,123,1) :# PROPRIÉTÉ EXPOSÉE XXX / YYY # BLOC INEXISTANT
   Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
  If instr(1,[F:ASWR]CODPRO,".")
   L_COL_CUR=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH([F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[F:ASWR]CODPRO,1)
   If L_COL_CUR<>"" & [ASWR]QRYPRO=2
    FLG_OK=1
    Call CONTROLE_QRYPRO([L]CODREP,[ASWR]ALIAS,[ASWR]CODPRO,L_COL_CUR,[F:ASW]CODCLA,[F:ASW]ABRCLA,FLG_OK,L_ERR_MSG) From SUBASW2
    If !FLG_OK
      RES_OK = 0
      # PROPRIÉTÉ EXPOSÉE XXX / YYY
       # Collection de dimensionnement non autorisée en query
       # Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en query
      L_ERR_MSG = mess(35,140,1)-[ASWR]ALIAS-"/"-[ASWR]CODPRO-":"-L_ERR_MSG
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
   Endif
   #Check EDIPRO if classe based on a view
   If [ASWR]EDIPRO=2  & WTYPCLA=2 & [L]ISTABLE<>2
    L_ERR_MSG = mess(95,140,1) : # Facette Edit non compatible avec l'utilisation d'une vue.
    L_ERR_MSG = mess(35,140,1)-[ASWR]ALIAS-"("+mess(3,40,1)-num$(I+1)+")"-"/"-[ASWR]CODPRO-":"-L_ERR_MSG
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
   If L_COL_CUR<>"" & [ASWR]LOKPRO=2
    FLG_OK=1
    Call CONTROLE_LOKPRO([L]CODREP,[ASWR]ALIAS,[ASWR]CODPRO,L_COL_CUR,[F:ASW]CODCLA,[F:ASW]ABRCLA,FLG_OK,L_ERR_MSG) From SUBASW2
    If !FLG_OK
      RES_OK = 0
      # PROPRIÉTÉ EXPOSÉE XXX / YYY
       # Collection de dimensionnement non autorisée en lookup
       # Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en lookup
      L_ERR_MSG = mess(35,140,1)-[ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-"/"-[ASWR]CODPRO-":"-L_ERR_MSG
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Endif
   Endif
  Endif
 Next

 # 5.2 check that the properties of the same collection are in the same block
 #Exception for classes 1-1
 FLG_HAS_ERROR=0
 Filter [ASWR] Where CODREP = [L]CODREP
 For [ASWR]ASWR0
  If instr(1,[F:ASWR]CODPRO,".")
   L_COL_CUR=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH([F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[F:ASWR]CODPRO,0)
   L_BLC_STD = [F:ASWR]BLCPRO
   If L_COL_CUR<>""
     #ajout clause sur BLCPRO et ALIAS pour perf
     Filter [ASWR2] Where CODREP = [L]CODREP & [F:ASWR2]ALIAS>[F:ASWR]ALIAS & [F:ASWR2]BLCPRO <> L_BLC_STD
     For [ASWR2]ASWR0
      If instr(1,[F:ASWR2]CODPRO,".")
       [L]L_COL_CUR2=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH([F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[F:ASWR2]CODPRO,0)
       If [L]L_COL_CUR=[L]L_COL_CUR2
        If [F:ASWR2]BLCPRO <> L_BLC_STD
         RES_OK = 0
         # Les propriétés exposées appartenant à la même collection $1$ doivent être définies dans le même bloc
         L_ERR_MSG = func AFNC.MES1( mess(165,143,1),L_COL_CUR)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"+"/"+L_BLC_STD-[F:ASWR2]ALIAS+"/"+[F:ASWR2]BLCPRO
         Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
         FLG_HAS_ERROR = 1
         Break
        Endif
       Elsif pat([L]L_COL_CUR2,[L]L_COL_CUR+'.*')<>0
        If [F:ASWR2]BLCPRO <> L_BLC_STD
         RES_OK = 0
         # Les propriétés exposées appartenant à la même collection $1$ doivent être définies dans le même bloc
         L_ERR_MSG = func AFNC.MES1( mess(165,143,1),L_COL_CUR)-[F:ASWR]ALIAS-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"+"/"+L_BLC_STD-[F:ASWR2]ALIAS+"/"+[F:ASWR2]BLCPRO
         Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
         FLG_HAS_ERROR = 1
         Break
        Endif
       Endif
      Endif
     Next
     Filter [ASWR2]
   Endif
   If FLG_HAS_ERROR : Break : Endif
  Endif
  Gosub VERIF_ASWK_ASWR
 Next
 Filter [ASWR]

Return
#----------------------------------
#---------------------------------------------------------------------------------------------------#
# Charge representation : Menus
#---------------------------------------------------------------------------------------------------#
$CHARGE_ASWMN
Local Integer NBMEN
Local Instance ASWMEN(1..) Using C_ASWMEN
For [ASWMN]ASWMN1 Where CODREP=[L]CODREP
  NBMEN+=1
  If NBMEN=1
   ASWMEN(NBMEN) = NewInstance C_ASWMEN AllocGroup null
  Else
   ASWMEN(NBMEN) = NewInstance C_ASWMEN AllocGroup ASWMEN(1)
  Endif
  SetInstance ASWMEN(NBMEN) With  [F:ASWMN]
Next
Return

#----------------------------------------#
$VERIF_ASWMN
Local Integer NOMEN

Local Char WPARENT(GLONAVA),WMENU(GLONAVA)
Local Integer I

For NOMEN=1 To NBMEN
 WPARENT=ASWMEN(NOMEN).PARMENU
 WMENU=ASWMEN(NOMEN).CODMENU
 While WPARENT<>""
  If WPARENT=WMENU
    #Code parent "$1$" non autorisé pour le menu "$2$"
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
    RES_OK = 0
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    WPARENT=""
  Else
   I=find(WPARENT,ASWMEN(1..NBMEN).CODMENU)
   If I=0
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
    RES_OK = 0
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    WPARENT=""
   Elsif ASWMEN(I).PARMENU=ASWMEN(NOMEN).CODMENU
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), ASWMEN(NOMEN).PARMENU, ASWMEN(NOMEN).CODMENU)
    RES_OK = 0
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    WPARENT=""
   Else
    WPARENT=ASWMEN(I).PARMENU
    WMENU=ASWMEN(I).CODMENU
   Endif
  Endif
 Wend
Next
Return
#----------------------------------

#----------------------------------------#
$VERIF_FACETTE
Local Char L_ERR_MSG(250)
Local Integer L_OK,I,J,K,FAC_OK

For K = 0 To 4
 FAC_OK=0
 I=0 : OK_LNK=0
 If [F:ASW]LNKMENFAC(K) <> ""
  # Check if it's a Menu
  If [F:ASW]AFFLNKFAC(K)=0
   I = find([F:ASW]LNKMENFAC(K), ASWMEN(1..NBMEN).CODMENU)
   If I>0 & ASWMEN(I).PARMENU=""
    FAC_OK = 1
   Endif
  Endif
  If !FAC_OK & I=0
   # Check if it's a Page link
   If [F:ASW]AFFLNKFAC(K)<>0
     Read [ASWK]ASWK0=[L]CODREP;[F:ASW]AFFLNKFAC(K);"";[F:ASW]LNKMENFAC(K)
     If !fstat
      FAC_OK=func IS_LNKMENFAC_OK(K+1)
     Endif
   Endif
  Endif

  If !FAC_OK
   RES_OK = 0
   L_ERR_MSG = func AFNC.MES1(mess(230,143,1), mess(K+1,7964,1))-":"-mess(227,143,1) :# Il faut indiquer un code lien valide pour la facette ou un code menu
   Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
  Endif
 Endif
Next
Return


Funprog IS_LNKMENFAC_OK(NOFAC)
Value Integer NOFAC
Local Integer OK_LNK,J
  OK_LNK=0
  # verif facette du lien OK
  If NOFAC=1 & [F:ASWK]DETLNK=2 : OK_LNK=1 : Endif
  If NOFAC=2 & [F:ASWK]EDILNK=2 : OK_LNK=1 : Endif
  If NOFAC=3 & [F:ASWK]QRYLNK=2 : OK_LNK=1 : Endif
  If NOFAC=4 & [F:ASWK]LOKLNK=2 : OK_LNK=1 : Endif
  If NOFAC=5 & [F:ASWK]SUMLNK=2 : OK_LNK=1 : Endif

  If OK_LNK
   If [F:ASWK]ENALNK<>2 : OK_LNK=0
   # Page ou Fiche/Enregistrement sur Detail/Edit/Summary
   Elsif !([F:ASWK]AFFLNK=4 |([F:ASWK]AFFLNK = 5 & find(NOFAC,1,2,5))) : OK_LNK=0
   # sans menu
   Elsif [F:ASWK]MENLNK<>"" : OK_LNK=0
   Elsif [F:ASWK]TARLNK=3 : OK_LNK=0
   Elsif [F:ASWK]FLGSTDLNK<>2
    #pas lien de remplacement
    For [ASWK2] Where CODREP=[L]CODREP & AFFLNK=[F:ASWK]AFFLNK & REMSTDLNK=[F:ASWK]CODLNK
      OK_LNK=0
      Break
    Next
   Endif
  Endif
End OK_LNK

