#<AdxTL>@(#)7.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Call ATRCMAJ30
#Call ACPTMAJ30
#Call ATRSMAJ30
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################################################
# ... MAJ30 : Mises à jour à effectuer lors du passage à la version 6
#
# Subprog ADICMAJ30
# Subprog ACPTMAJ30
# Subprog CPTMAJ30
# Subprog ATRSMAJ30
# Subprog TRSMAJ30
##########################################################################################################
#
# Pré-requis : le dossier de référence contient :
#        - le menu 2644 figé pour les 3 premières lignes
#        - le modèle comptable lié à la législation dit de "Référence" renseigne les 3 premiers type des référentiels (<=> code plan)
#        - les code axes AX1 à AX9 qui représentent les 9 axes analytiques de la V5
#        - les codes sectotiels (V5 tables diverses 360 & 361) seront récupérés du référentiel dit "IAS"
#
#
##########################################################################################################
## Module compta : avant validation
##########################################################################################################
##  Dans les AXXMAJ, on a les anciens + les nouveaux champs dans les tables...
##-------------------------------------------------------------------------------------------------------#
Subprog ADICMAJ30
##-------------------------------------------------------------------------------------------------------#
# Récupération des textes des tableaux de bord.
Gosub TXS_ATEXTRA From CPTMAJ30A2
# Récupération de la table ADI 327 (obsolète en V6) à passer en ADI 313
Gosub ADI313  From TRSMAJ30A
End

##-------------------------------------------------------------------------------------------------------#
Subprog ADICMAJ30_ANA
##-------------------------------------------------------------------------------------------------------#
# Force le code activité ANA
Call ECR_TIME(mess(81,125,1)-": ADOSACT/ACTIV (ANA)") From DOSSUB : # maj table

Local File ADOSACT                  [ADA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]

Read [ADA]ADA0 = [F:ADS]DOSSIER;"ANA"
If fstat or [F:ADA]DIME>=20 : End : Endif
Trbegin [ADA] , [ACV]
 Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT="ANA"  With DIME=20
 Update [ACV] Where CODACT="ANA" With DIME=20, DIMFIL=20, DIMMAX=20
Commit
Close Local File
End

##########################################################################################################
## Partie TRONC COMMUN
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog ATRCMAJ30
##-------------------------------------------------------------------------------------------------------#
Gosub INIVAR
If !OK : End : Endif

##-------------------------------------------------------------------------------------------------------#
# Données récupérées du dossiers de copie
#   Modèle comptable
#   Référentiels
##-------------------------------------------------------------------------------------------------------#
Gosub GACM From CPTMAJ30A
Gosub GLED From CPTMAJ30A
##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCOUNT
#   Reprise des comptes V5 de cumuls pour la pyramide
#   Reprise des comptes V5 à attribuer au Référentiel Général principal du modèle comptable
#   Reprise des nature  V5 à attribuer au Référentiel Général analytique du modèle comptable
#   Reprise des compte V5  pour le référentiel sectoriel / IAS
##-------------------------------------------------------------------------------------------------------#
Gosub PYRAM_CUMUL From CPTMAJ30A2
Gosub GACCOUNT_GEN From CPTMAJ30A
If PLANA<>"" & PLGEN<>PLANA
 Gosub GACCOUNT_ANA From CPTMAJ30A
Endif
If PLIAS<>"" & PLGEN<>PLIAS
 Gosub GACCOUNT_IAS From CPTMAJ30A
Endif
# Fin de la mise à jour de la table GACCOUNT.
Gosub DELETE_GAC From CPTMAJ30A
# Mise à jour des interdictions Compte/Section
Gosub CAAUZ From CPTMAJ30A

##-------------------------------------------------------------------------------------------------------#
# Migrer les paramètres V5 sous le plan de compte V6 (Comptes divers)
##-------------------------------------------------------------------------------------------------------#
Gosub PARAMCOA  From CPTMAJ30A

##-------------------------------------------------------------------------------------------------------#
# Ajout du code plan associé au Référentiel Général principal du modèle comptable
#  Mise à jour TABACCLIK
##-------------------------------------------------------------------------------------------------------#
Gosub TABACCLIK  From CPTMAJ30A

##-------------------------------------------------------------------------------------------------------#
# Migration des tables de données de base & paramètrage
##-------------------------------------------------------------------------------------------------------#
Gosub FISCALYEAR From CPTMAJ30B
Gosub PERIOD     From CPTMAJ30B
Gosub GDIE       From CPTMAJ30B
Gosub GDIE_CPY   From CPTMAJ30A2
Gosub GDIE_FCY   From CPTMAJ30A2 : # Bug 52857
Gosub GDIE_AUS   From CPTMAJ30A2
Gosub CACCE      From CPTMAJ30B
Gosub CADSP      From CPTMAJ30B
Gosub GTYPACCENT From CPTMAJ30A
Gosub GACCCODLIG From CPTMAJ30A
Gosub GACCCODE   From CPTMAJ30A
Gosub CADIEDEF   From CPTMAJ30A
Gosub CACCEDEF   From CPTMAJ30A
Gosub SUP_GAU    From CPTMAJ30A2
Gosub TEX_GAU    From CPTMAJ30A2
Gosub GAUTACE    From CPTMAJ30B
Gosub GRPAUTACE  From CPTMAJ30B
Gosub VARAUTACE  From CPTMAJ30B
Gosub TABFOR     From CPTMAJ30B
Gosub RITENZIONE From CPTMAJ30B

##-------------------------------------------------------------------------------------------------------#
# Migration des mouvements de données commune - Obsolète, passage par les Migrations par Flux - 72334
##-------------------------------------------------------------------------------------------------------#
#Gosub ECHEANCES     From TRSMAJ30B

##-------------------------------------------------------------------------------------------------------#
# Mise à jour forcée de l'onglet sélection des objets.
##-------------------------------------------------------------------------------------------------------#
Call AOBJLST_TRC([F:ADS]DOSSIER,[F:ADS]DOSREF)

##-------------------------------------------------------------------------------------------------------#
# Mise à jour des textes
##-------------------------------------------------------------------------------------------------------#
Call ATEXTRA

##-------------------------------------------------------------------------------------------------------#
# Initialisation de la législation
##-------------------------------------------------------------------------------------------------------#
Call INILEG_TRC([F:ADS]DOSSIER,LEGREF) From CPTMAJ30A2

Gosub FINVAR
End

##########################################################################################################
## Partie COMPTABILITE
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
Subprog ACPTMAJ30
##-------------------------------------------------------------------------------------------------------#
Gosub INIVAR
If !OK : End : Endif

##-------------------------------------------------------------------------------------------------------#
# Ajout du code plan associé au Référentiel Général principal du modèle comptable
#  Mise à jour GAPARBSE, GAPARDUM, GTABACC2
##-------------------------------------------------------------------------------------------------------#
Gosub GAPARBSE   From CPTMAJ30A
Gosub GAPARDUM   From CPTMAJ30A
Gosub GTABACC2   From CPTMAJ30A

##-------------------------------------------------------------------------------------------------------#
# Migration des tables de données de base & paramètrage
##-------------------------------------------------------------------------------------------------------#
Call RAZFIC([F:ADS]DOSSIER,"GAJOUSTA")
Gosub GJOURNAL   From CPTMAJ30B
Gosub GRPSAC     From CPTMAJ30B
Gosub GDIAENTRY  From CPTMAJ30A
Gosub GDIAACC    From CPTMAJ30A
Gosub PYRAM_ACC  From CPTMAJ30A
Gosub PYRAM_CCE  From CPTMAJ30A
Gosub BUDPAR     From CPTMAJ30A
Gosub BUDVER     From CPTMAJ30A
Gosub BUDFOR     From CPTMAJ30A
Gosub GRPDSP     From CPTMAJ30A
Gosub CDIADSP    From CPTMAJ30A
Gosub GCLCACEPAR From CPTMAJ30A
Call RAZFIC([F:ADS]DOSSIER,"BATCH")
#Gosub BATCH_CPT  From CPTMAJ30B
Gosub BATCH_LET  From CPTMAJ30B
Gosub DCLVAT     From CPTMAJ30B
Gosub CSFRES     From CPTMAJ30B

##-------------------------------------------------------------------------------------------------------#
# Migration des tableaux de bord
##-------------------------------------------------------------------------------------------------------#
Gosub TXSA From CPTMAJ30A2
Gosub TXSD From CPTMAJ30A2
Gosub TXSP From CPTMAJ30A2
Gosub TXSV From CPTMAJ30A2


##-------------------------------------------------------------------------------------------------------#
# Migration des mouvements  - Obsolète, passage par les Migrations par Flux - 72334
##-------------------------------------------------------------------------------------------------------#
#Gosub GACCENTRY  From CPTMAJ30C
#Gosub GACCENTRYD From CPTMAJ30C
#Gosub GACCENTRYA From CPTMAJ30C
#If PLIAS<>""
# Gosub GACEIAS From CPTMAJ30C
#Endif
#Gosub DELETE_DAE From CPTMAJ30C
#Gosub DELETE_DAA From CPTMAJ30C
#Gosub GENTLOH  From CPTMAJ30C
#Gosub GENTLOTD From CPTMAJ30C    : Gosub DELETE_LOD From CPTMAJ30C
#Gosub GCOMMIT  From CPTMAJ30C
#Gosub GCOMMITD From CPTMAJ30C    : Gosub DELETE_CMD From CPTMAJ30C
#Gosub BUD      From CPTMAJ30C
#Gosub BUDOD    From CPTMAJ30C

##-------------------------------------------------------------------------------------------------------#
# Suppression des données
##-------------------------------------------------------------------------------------------------------#
Call RAZFIC([F:ADS]DOSSIER,"BALANCE")
Call RAZFIC([F:ADS]DOSSIER,"BALANA")

#Demande 56154
If filinfo(filpath("FIL","GLCONSO","fde",[F:ADS]DOSSIER),0)>0
 Call RAZFIC([F:ADS]DOSSIER,"GLCONSO")
Endif
If filinfo(filpath("FIL","BALCONSO","fde",[F:ADS]DOSSIER),0)>0
 Call RAZFIC([F:ADS]DOSSIER,"BALCONSO")
Endif

##-------------------------------------------------------------------------------------------------------#
# Suppression des consultations obsolètes
##-------------------------------------------------------------------------------------------------------#
Call DELCNS([F:ADS]DOSSIER)

##-------------------------------------------------------------------------------------------------------#
# Mise à jour forcée de l'onglet sélection des objets.
##-------------------------------------------------------------------------------------------------------#
Call AOBJLST_CPT([F:ADS]DOSSIER,[F:ADS]DOSREF)

##-------------------------------------------------------------------------------------------------------#
# Mise à jour des textes
##-------------------------------------------------------------------------------------------------------#
Gosub NEWATX From CPTMAJ30A2

##-------------------------------------------------------------------------------------------------------#
# Mise à jour PARAMATRAGE
##-------------------------------------------------------------------------------------------------------#
Call AOBJPARAM([F:ADS]DOSSIER,[F:ADS]DOSREF) From CPTMAJ30A2

##-------------------------------------------------------------------------------------------------------#
# Initialisation de la législation
##-------------------------------------------------------------------------------------------------------#
Call INILEG_CPT([F:ADS]DOSSIER,LEGREF) From CPTMAJ30A2

Gosub FINVAR
End

##########################################################################################################
## Module compta : apres validation
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
Subprog CPTMAJ30
Local File =[F:ADS]DOSSIER+".ADOVAL"   [MADW]   # Valeurs paramétres
Local Char ZONE(30)

Raz ZONE
Read [MADW]ADW0 = "";"";"SCHSAISIE"
If !fstat
 ZONE = [F:MADW]VALEUR
Endif

Trbegin [MADW]
If ZONE<>""
 Update [MADW] Where PARAM="SCHSTDC"  With VALEUR=ZONE
 If fstat
  Call ERREUR("ADOVAL-SCHSTDC",2) From DOSDIC
 Else
  Call ECR_TIME(mess(81,125,1)-": ADOVAL SCHSTDC") From DOSSUB
 Endif
Else
 Update [MADW] Where PARAM="SCHSTDC"  With VALEUR=""
 If fstat
  Call ERREUR("ADOVAL-SCHSTDC",2) From DOSDIC
 Else
  Call ECR_TIME(mess(81,125,1)-": ADOVAL SCHSTDC") From DOSSUB
 Endif
Endif
Update [MADW] Where PARAM="SCHSTDL"  With VALEUR=""
 If fstat
  Call ERREUR("ADOVAL-SCHSTDL",2) From DOSDIC
 Else
  Call ECR_TIME(mess(81,125,1)-": ADOVAL SCHSTDL") From DOSSUB
 Endif
Commit
Close Local File [MADW]
End

##########################################################################################################
## Module tiers : avant validation
##########################################################################################################
##  Dans les AXXMAJ, on a les anciens + les nouveaux champs dans les tables...

##-------------------------------------------------------------------------------------------------------#
Subprog ATRSMAJ30

Gosub INIVAR
If !OK : End : Endif

##-------------------------------------------------------------------------------------------------------#
# Migration des tables de données de base & paramètrage
##-------------------------------------------------------------------------------------------------------#
Gosub INVDACPAR  From TRSMAJ30A
Gosub BANK       From TRSMAJ30A
Gosub TABEXPENS  From TRSMAJ30A
Gosub GACCDENCOD From TRSMAJ30A
Gosub FACTOR     From TRSMAJ30A

##-------------------------------------------------------------------------------------------------------#
# Migration des mouvements - Obsolète, passage par les Migrations par Flux - 72334
##-------------------------------------------------------------------------------------------------------#
#Gosub FACTURE_TIERS From TRSMAJ30B
#Gosub PAYMENTH      From TRSMAJ30B
#Gosub EXPENSES      From TRSMAJ30B

##-------------------------------------------------------------------------------------------------------#
# Suppression des données
##-------------------------------------------------------------------------------------------------------#
If filinfo(filpath("FIL","FUP","fde",[F:ADS]DOSSIER),0)>0
 Call RAZFIC([F:ADS]DOSSIER,"FUP")
Endif
Call RAZFIC([F:ADS]DOSSIER,"TMPEXPENSE")

##-------------------------------------------------------------------------------------------------------#
# Législation sous TABFILBAN (1ère partie sous INILEG_CPT de CPTMAJ30A2)
##-------------------------------------------------------------------------------------------------------#
# 2ème partie, RAZ de LEG selon condition
Call INILEG_TFB([F:ADS]DOSSIER,[F:ADS]DOSCOP) From CPTMAJ30A2

Gosub FINVAR
End

##########################################################################################################
## Module tiers : après validation
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
Subprog TRSMAJ30

End


$INIVAR
# Ouverture des tables du dossier de copie
Local File =[F:ADS]DOSCOP+".GACM" [RGCM]  # Modèle comptable
Local File =[F:ADS]DOSCOP+".GLED" [RLED]  # Référentiel

# Ouverture des tables du dossier à migrer
Local File =[F:ADS]DOSSIER+".ADOVAL"   [MADW]   # Valeurs paramétres
Local File =[F:ADS]DOSSIER+".ACTIV"    [MACV]   # Codes activités

# Déclaration de variables Communes
Local Char LEGREF(30)      # Législation de référence
LEGREF = [F:ADS]DOSLEG(0)

Local Integer TYPGEN       # Type de référentiel dit 'Social'
Local Integer TYPANA       # Type de référentiel dit 'Analytique'
Local Integer TYPIAS       # Type de référentiel dit 'Sectoriel'

Local Char LEDANA(30)      # Code référentiel analytique
Local Char LEDIAS(30)      # Code référentiel sectoriel/IAS

Local Char PLGEN(30)       # Code plan du Référentiel Général pincipal
Local Char PLANA(30)       # Code plan du Référentiel Général analytique
Local Char PLIAS(30)       # Code plan du Référentiel dit IAS / Sectoriel

Local Char AXEIAS1(30)     # Axe du référentiel IAS (ancien 360)
Local Char AXEIAS2(30)     # Axe du référentiel IAS (ancien 361)

Local Integer MIGGOPTCANA  # Valeur du paramètre GOPTCANA du dossier à migrer
Local Char    MIGGSYSCUR   # Valeur du paramètre GSYSCUR du dossier à migrer

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3

# Déclaration des variables communes de travail
Local Integer I,J,OK
Local Integer NBLED, TYPREF
Local Char ZONE(30), AMZV5(30), AMZV6(30)

##-------------------------------------------------------------------------------------------------------#
OK=1

Local File ADOVAL [XADW]   # Valeurs paramétres
Local Char WGACM(30)
Raz WGACM
Read [XADW]ADW0 = "";"";"MIGGCM"
If !fstat
 WGACM= [F:XADW]VALEUR
Endif

If WGACM= ""
 # Paramètre non défini
 OK=0 : Call ERREUR("MIGGCM : "-mess(141,105,1),4) From DOSDIC : Return
Endif

# Lecture du modèle comptable du dossier de copie ayant la législation identique.
Read [RGCM]GCM0 = WGACM
If fstat
 # Erreur de lecture - Aucun modèle comptable défini pour cette législation
 OK=0 : Call ERREUR(mess(198,105,1),4) From DOSDIC : Return
Endif

# Initialisation des codes plans des référentiels principaux
Read [RLED]LED0 = [F:RGCM]LED(0)
If !fstat
 PLGEN  = [F:RLED]COA
 TYPGEN = 1
Else
 # Erreur de lecture - Pas de code référentiel saisi pour ce type de référentiel
 OK=0 : Call ERREUR(mess(97,104,1),4) From DOSDIC : Return
Endif

If [F:RGCM]LED(1)<>""
 Read [F:RLED]LED0 = [F:RGCM]LED(1)
 If !fstat
  LEDANA = [F:RGCM]LED(1)
  PLANA  = [F:RLED]COA
  TYPANA = 2
 Else
  PLANA = ""
 Endif
Else
 Read [F:RLED]LED0 = [F:RGCM]LED([F:RGCM]ANALEDTYP-1)
 If !fstat
  LEDANA = [F:RGCM]LED([F:RGCM]ANALEDTYP-1)
  PLANA  = [F:RLED]COA
  TYPANA = [F:RGCM]ANALEDTYP
 Else
  PLANA = ""
 Endif
Endif

# Initialisation du référentiel dit IAS / Sectoriel...
If [F:RGCM]LED(2)<>""
 Read [MACV]CODACT = "IAS"
 If !fstat & [F:MACV]FLACT=2
  Read [RLED]LED0 = [F:RGCM]LED(2)
  If !fstat
   LEDIAS = [F:RGCM]LED(2)
   PLIAS  = [F:RLED]COA
   TYPIAS = 3
  Else
   PLIAS =""
  Endif
 Else
  PLIAS = ""
 Endif
Else
 PLIAS = ""
Endif
#Contrôle supplémentaire - 68390
If filinfo(filpath("FIL","GACEIAS","fde",[F:ADS]DOSSIER),0)<=0 | filinfo(filpath("FIL","GACEIASD","fde",[F:ADS]DOSSIER),0)<=0
 PLIAS = ""
Endif


##-------------------------------------------------------------------------------------------------------#
Read [MADW]ADW0 = "";"";"SYSCUR"
If !fstat
 [L]MIGGSYSCUR = [F:MADW]VALEUR
Endif

# NOK... la table ACV est déjà mise à jour
#Read [MACV]CODACT = "ANA"
#If !fstat
# [L]MIGGOPTCANA = [F:MACV]DIME
#Endif
## <PP> mess() : s'applique sur l'application courante (=V6)
#[L]MIGGOPTCANA = len(mess(0,601,1))
Local File =[F:ADS]DOSSIER+".APLSTD"   [MSTD]   # Tables des messages
Filter [MSTD] Where LANCHP=601 & LANNUM=0 & LAN=[F:ADS]LANDEF
Read [MSTD] First
If !fstat
 [L]MIGGOPTCANA = len([F:MSTD]LANMES)
Else
 Filter [MSTD] Where LANCHP=601 & LANNUM=0
 Read [MSTD] First
 [L]MIGGOPTCANA = len([F:MSTD]LANMES)
Endif

Filter [MSTD]
Close File [MSTD]

##-------------------------------------------------------------------------------------------------------#
Global Char MIGGLANMAJ(10)
Global Char MIGDOSMAJ(10)
Global Char MIGDOSCOP(10)
If dim(MIGLEGANA)<=0 : Global Char MIGLEGANA(10) : Endif

MIGGLANMAJ = [F:ADS]LANDEF
MIGDOSMAJ  = [F:ADS]DOSSIER
MIGDOSCOP  = [F:ADS]DOSCOP

Return

$FINVAR
Kill MIGGLANMAJ
Kill MIGDOSMAJ
Kill MIGDOSCOP
#Kill MIGLEGANA #73681
Return

####################################################################
Subprog RAZFIC(DOSSIER,TABLE)
Value Char    DOSSIER
Value Char    TABLE

Local Integer OK
Call VIDE(DOSSIER,TABLE,OK) From DOSTAB
End

#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets.
#########################################################################################
Subprog AOBJLST_TRC(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(10)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

Call ECR_TIME(mess(81,125,1)-": AOBJLST") From DOSSUB : # maj table

Trbegin [AOL]

 For WOBJET = "GAC", "CCE", "CDE", "GTE", "DSP",
&             "CAC", "GRA", "GAU", "GAD", "GVG", "GVA", "DU6", "FIY", "DU5"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File [AOL] , [AOL2]
End

#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets.
#########################################################################################
Subprog AOBJLST_CPT(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(10)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

Call ECR_TIME(mess(81,125,1)-": AOBJLST") From DOSSUB : # maj table

Trbegin [AOL]

 For WOBJET = "JOU", "GDE", "GSP", "TXS", "TX2", "TXW",
&             "GAF", "PDM", "CSF", "BUP", "TBU", "DTP",
&             "GDA", "GSC", "DAD", "GCU", "BUC", "CDA", "TPY", "GDS", "GBS", "TES", "FGP"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File [AOL] , [AOL2]
End

#########################################################################################
# Suppression des consultations obsolètes
#########################################################################################
Subprog DELCNS(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".GTABACC" [GTC]

Local Char WCNS(GLONACN)
Local Char MASQUE(GLONAMK)

Call ECR_TIME(mess(81,125,1)-": GTABACC") From DOSSUB : # maj table

 For [GTC]GTC0 Where find(CNSCOD,"CIA", "PIA", "BAF", "BIA", "PYA")
  MASQUE = "WM"+[F:GTC]CNSCOD+[F:GTC]COD
  Call TR_DELMSK(MASQUE,DOSSIER) From MSKDIV
  Call TR_DELWIN(MASQUE,DOSSIER) From MSKDIV
 Next

 Trbegin [GTC]
 For [GTC]GTC0 Where find(CNSCOD,"CIA", "PIA", "BAF", "BIA", "PYA")
  Delete [GTC] Curr
  If fstat
   Call ERREUR("GTABACC"-[F:GTC]CNSCOD-[F:GTC]COD,3) From DOSDIC
  Endif
 Next
 Commit
Close Local File [GTC]
End


#########################################################################################
# Modification des textes
#########################################################################################
Subprog ATEXTRA

Local File =MIGDOSMAJ+".ATEXTRA" [MAXX] , =MIGDOSCOP+".ATEXTRA" [CAXX]

# Récupérer le texte du "Paramètrage de la table diverse"  321
#   V5 : "Interdiction nature"
#   V6 : Modifié en "Interdiction compte"

Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-321") From DOSSUB : # maj table
Trbegin [MAXX]
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="LNGDES" & IDENT1="321"
 Read [CAXX]AXX0 = "ATABTAB";"LNGDES";[F:MAXX]LANGUE;"321";""
 If !fstat
  [F:MAXX]TEXTE =   [F:CAXX]TEXTE
  Rewrite [MAXX]
  If fstat
   Call ERREUR("ATEXTRA"-"ADI-LNGDES-321",2) From DOSDIC
  Endif
 Endif
Next
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="SHODES" & IDENT1="321"
 Read [CAXX]AXX0 = "ATABTAB";"SHODES";[F:MAXX]LANGUE;"321";""
 If !fstat
  [F:MAXX]TEXTE =   [F:CAXX]TEXTE
  Rewrite [MAXX]
  If fstat
   Call ERREUR("ATEXTRA"-"ADI-SHODES-321",2) From DOSDIC
  Endif
 Endif
Next
Commit

# Suppression des textes des Tables diverses 360 & 361
Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-360") From DOSSUB : # maj table
Trbegin [MAXX]
Delete [MAXX]  Where CODFIC="ATABTAB" & IDENT1="360"
If fstat
 Call ERREUR("ATEXTRA-360",3) From DOSDIC
Endif
Commit
Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-361") From DOSSUB : # maj table
Trbegin [MAXX]
Delete [MAXX]  Where CODFIC="ATABTAB" & IDENT1="361"
If fstat
 Call ERREUR("ATEXTRA-361",3) From DOSDIC
Endif
Commit


# Transfert de données : Récupérer le texte du "Paramètrage de la table diverse"  F88878
#   V5 : SEPA est sous le ADI 327
#   V6 : SEPA est sous le ADI 313
Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-313") From DOSSUB : # maj table
Trbegin [MAXX]
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="LNGDES" & IDENT1="313"
 Read [CAXX]AXX0 = "ATABTAB";"LNGDES";[F:MAXX]LANGUE;"313";""
 If !fstat
  [F:MAXX]TEXTE =   [F:CAXX]TEXTE
  Rewrite [MAXX]
  If fstat
   Call ERREUR("ATEXTRA"-"ADI-LNGDES-313",2) From DOSDIC
  Endif
 Endif
Next
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="SHODES" & IDENT1="313"
 Read [CAXX]AXX0 = "ATABTAB";"SHODES";[F:MAXX]LANGUE;"313";""
 If !fstat
  [F:MAXX]TEXTE =   [F:CAXX]TEXTE
  Rewrite [MAXX]
  If fstat
   Call ERREUR("ATEXTRA"-"ADI-SHODES-313",2) From DOSDIC
  Endif
 Endif
Next
Commit

Close Local File [MAXX] , [CAXX]
End

#########################################################################################
# Mise à jour des textes => Récupération des textes en Textes Traduisibles.
#   MIGDOSMAJ => le dossier à migrer.
#
# MAJTEXTRA est appelé pour toutes les tables contenant des DES/DESSHO en V5 qui deviennent des DESTRA/SHOTRA en V6
#
#########################################################################################
Subprog MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Value    Char     VALEUR, TABLE, CHAMP, CLE1, CLE2

Local File =MIGDOSMAJ+".ATEXTRA" [MAXX]

Read [MAXX]AXX0 = TABLE;CHAMP;MIGGLANMAJ;CLE1;CLE2
If !fstat
 [F:MAXX]TEXTE = VALEUR
 If dim([F:MAXX]UPDDAT)>0 : [F:MAXX]UPDDAT = date$ : Endif
 If dim([F:MAXX]UPDUSR)>0 : [F:MAXX]UPDUSR = GUSER : Endif
 Rewrite [MAXX]
 If fstat
  Call ERREUR("ATEXTRA"-[L]TABLE-[L]CHAMP-[L]CLE1-[L]CLE2,2) From DOSDIC
 Endif
Else
 Raz [F:MAXX]
 [F:MAXX]CODFIC = TABLE
 [F:MAXX]ZONE   = CHAMP
 [F:MAXX]LANGUE = MIGGLANMAJ
 [F:MAXX]TEXTE  = VALEUR
 [F:MAXX]IDENT1 = CLE1
 [F:MAXX]IDENT2 = CLE2
 If dim([F:MAXX]CREDAT)>0 : [F:MAXX]CREDAT = date$ : Endif
 If dim([F:MAXX]CREUSR)>0 : [F:MAXX]CREUSR = GUSER : Endif
 Write [MAXX]
 If fstat
  Call ERREUR("ATEXTRA"-[L]TABLE-[L]CHAMP-[L]CLE1-[L]CLE2,2) From DOSDIC
 Endif
Endif

Close File [MAXX]
End


#########################################################################################
# Copie de textes traduisibles depuis le dossier de COPIE
#    MIGDOSCOP => le dossier de copie
#
# COPTEXTRA est appelé pour toutes les nouvelles tables V6
#
#########################################################################################
Subprog COPTEXTRA(TABLE,CLE1)
Value    Char    TABLE, CLE1

Local File =MIGDOSCOP+".ATEXTRA" [CAXX]
Local File =MIGDOSMAJ+".ATEXTRA" [MAXX]


For [F:CAXX]AXX0 Where [F:CAXX]CODFIC=[L]TABLE & [F:CAXX]IDENT1=[L]CLE1
 Read [MAXX]AXX0 = [F:CAXX]CODFIC;[F:CAXX]ZONE;[F:CAXX]LANGUE;[F:CAXX]IDENT1;[F:CAXX]IDENT2
 If fstat
  Raz [F:MAXX]
  [F:MAXX]CODFIC = [F:CAXX]CODFIC
  [F:MAXX]ZONE   = [F:CAXX]ZONE
  [F:MAXX]LANGUE = [F:CAXX]LANGUE
  [F:MAXX]TEXTE  = [F:CAXX]TEXTE
  [F:MAXX]IDENT1 = [F:CAXX]IDENT1
  [F:MAXX]IDENT2 = [F:CAXX]IDENT2
  If dim([F:MAXX]CREDAT)>0 : [F:MAXX]CREDAT = date$ : Endif
  If dim([F:MAXX]CREUSR)>0 : [F:MAXX]CREUSR = GUSER : Endif
  Write [MAXX]
  If fstat
   Call ERREUR("ATEXTRA"-[L]TABLE,2) From DOSDIC
  Endif
 Endif
Next

Close File [CAXX], [MAXX]
End



#########################################################################################
# Lecture des textes en Textes Traduisibles sur le dossier de COPIE
#########################################################################################
Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2

Local File =MIGDOSCOP+".ATEXTRA" [CAXX]

Read [CAXX]AXX0 = TABLE;CHAMP;MIGGLANMAJ;CLE1;CLE2
If fstat=0
 VALEUR = [F:CAXX]TEXTE
Else
 Read [CAXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
 If fstat=0
  VALEUR = [F:CAXX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
Close File [CAXX]
End

