#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################## 
# FUNVENFREI                                       JL - Novembre 2000  #
#    SIMULATION CALCUL PORT (Tarifs transporteurs)                     #
#                                                                      #
#    - Traitement        : FUNVENFREI                                  #
#    - Action e_commerce : SAISFREI  (Saisie fenêtre)                  #
#                                     Fenêtre : FSFREI                 #
#----------------------------------------------------------------------# 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             de l'écran BPTS [M:BPTS]                                 # 
#----------------------------------------------------------------------#
# Valeur de PARAM(1) = [M]CODTRT ( origine de l'appel )                # 
#    [M]CODTRT=BPT (appel depuis maintenance transporteur)             # 
#    [M]CODTRT=SOH (appel depuis les commandes)       dev. ultérieur   # 
#    [M]CODTRT=SDH (appel depuis les livraisons)      dev. ultérieur   # 
#    [M]CODTRT=SIH (appel depuis les factures)        dev. ultérieur   # 
######################################################################## 

######################################################################## 
# Etiquettes ACTION
######################################################################## 
$ACTION
#Local Integer JLOK : Call AVERTIR ("ACTION="+ACTION-GACTION-"COUZON="+COUZON,JLOK) From GESECRAN
 
#--- Actions liées à la saisie fenêtre des variables
Case ACTION
  When "OUVRE"        : Case GACTION
                          When "SAISFREI"    : Gosub OUVRE_SAISFREI
                        Endcase  
  When "DEBUT"        : Case GACTION
                          When "SAISFREI"    : Gosub DEBUT_SAISFREI
                        Endcase  
  When "BOUTON"       : Case GACTION
                          When "SAISFREI"    : Gosub BOUTON_SAISFREI
                        Endcase  
  When "APRES_MODIF"  : Case GACTION
                          When "SAISFREI"    : Gosub AM_SAISFREI
                        Endcase
  When Default
Endcase

Return 

########################################################################
# Détail des actions liées à la saisie fenêtre des variables
########################################################################
$OUVRE_SAISFREI
If clalev ([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev ([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev ([F:BPD])=0  : Local File BPDLVCUST  [BPD]  : Endif
If clalev ([F:BPA])=0  : Local File BPADDRESS  [BPA]  : Endif
If clalev ([F:BPT])=0  : Local File BPCARRIER  [BPT]  : Endif
If clalev ([F:CAA])=0  : Local File CARAREA    [CAA]  : Endif
If clalev ([F:CAP])=0  : Local File CARPRICE   [CAP]  : Endif
If clalev ([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev ([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
Return
########################################################################
$DEBUT_SAISFREI

#--- valeurs par defaut
Raz [M:BPTS]
[M:BPTS]CODTRT=PARAM(1)
[M:BPTS]VCRY=GPAYS 

Case [M:BPTS]CODTRT
  When "BPT"   Gosub CHARG_BPT  : # appel à partir maintenance transporteur 
  When "SOH"   Gosub CHARG_SOH  : # appel à partir des commandes 
  When "SDH"   Gosub CHARG_SDH  : # appel à partir des livraisons
  When "SIH"   Gosub CHARG_SIH  : # appel à partir des factures 
Endcase 
Affzo [M:BPTS]

Return

########################################################################
$BOUTON_SAISFREI
Case BOUT
  When "1"   : Gosub TRAITEMENT
Endcase
Return

########################################################################
$AM_SAISFREI
Case COUZON
  When "VBPTNUM" : Read [BPT]BPT0=CZ
                   If !fstat : [M:BPTS]VCUR1=[F:BPT]CUR : [M:BPTS]VWEU1=[F:BPT]WEU : [M:BPTS]VVOU1=[F:BPT]VOU : Endif
                   Affzo [M:BPTS]VCUR1, VWEU1, VVOU1 
  When "VBPCNUM" : Raz [M:BPTS]VBPAADD, VBPDNAM, VCRY, VPOSCTY, VPOSCOD
                   GBPCNUM=CZ 
                   Filter [BPD] Where BPCNUM=CZ & ENAFLG=2
                   Read [BPD]BPD0=CZ;[F:BPC]BPDADD
                   If fstat=0
                     [M:BPTS]VBPAADD=[F:BPD]BPAADD
                   Else
                     Read [BPD]BPD0 First
                     If fstat=0 : [M:BPTS]VBPAADD=[F:BPD]BPAADD : [M:BPTS]VBPDNAM=[F:BPD]BPDNAM(0) : Endif
                   Endif  
                   Filter [BPD]
                   Read [BPA]BPA0=1;CZ;[M:BPTS]VBPAADD   
                   If fstat=0 
                     [M:BPTS]VCRY=[F:BPA]CRY : [M:BPTS]VPOSCTY=[F:BPA]CTY : [M:BPTS]VPOSCOD=[F:BPA]POSCOD
                   Endif
                   Affzo [M:BPTS]VBPAADD, VBPDNAM, VCRY, VPOSCTY, VPOSCOD 

  When "VBPAADD" : Raz [M:BPTS]VBPDNAM, VCRY, VPOSCTY, VPOSCOD
                   [M:BPTS]VSTOFCY=[F:BPD]STOFCY
                   [M:BPTS]VBPAADD=[F:BPD]BPAADD
                   [M:BPTS]VBPDNAM=[F:BPD]BPDNAM(0)
                   Read [BPA]BPA0=1;[M:BPTS]VBPCNUM;CZ   
                   If fstat=0 
                     [M:BPTS]VCRY=[F:BPA]CRY : [M:BPTS]VPOSCTY=[F:BPA]CTY : [M:BPTS]VPOSCOD=[F:BPA]POSCOD
                   Endif
                   Affzo [M:BPTS]VBPAADD, VSTOFCY, VBPDNAM, VCRY, VPOSCTY, VPOSCOD 

  When "VCUR"      [M:BPTS]VCUR2=CZ
                   Affzo [M:BPTS]VCUR2 
Endcase 

Return

########################################################################
# Initialisation de l'ecran en fonction de l'origine
########################################################################

$CHARG_BPT
[M:BPTS]VBPTNUM = [M:BPT0]BPTNUM
[M:BPTS]VBPCNUM = ""   
[M:BPTS]VBPAADD = ""
[M:BPTS]VBPDNAM = ""
[M:BPTS]VCUR1   = [M:BPT1]X1CUR
[M:BPTS]VWEU1   = [M:BPT1]WEU
[M:BPTS]VVOU1   = [M:BPT1]VOU 
[M:BPTS]VSTOFCY = GFCYDEF(7)
[M:BPTS]VCRY    = GPAYS
[M:BPTS]VPOSCTY = ""
[M:BPTS]VPOSCOD = ""
[M:BPTS]VCUR    = GLOCALDEV
[M:BPTS]VCHGTYP = 1
[M:BPTS]VCHGDAT = date$   
[M:BPTS]VAMTNOT = 0
[M:BPTS]VWEU    = [M:BPTS]VWEU1 
[M:BPTS]VGROWEI = 0
[M:BPTS]VVOU    = [M:BPTS]VVOU1
[M:BPTS]VVOL    = 0
Raz [M:BPTS]VBPTARE, VAMTFRE
[M:BPTS]VCUR2   = [M:BPTS]VCUR
Return

#-----------------------------------------------------------------------
$CHARG_SOH
[M:BPTS]VBPTNUM = [M:SOH2]BPTNUM
Read [BPT]BPT0=[M:SOH2]BPTNUM
If !fstat
  [M:BPTS]VCUR1=[F:BPT]CUR
  [M:BPTS]VWEU1=[F:BPT]WEU
  [M:BPTS]VVOU1=[F:BPT]VOU
Endif
[M:BPTS]VBPCNUM = [M:SOH0]BPCORD  
[M:BPTS]VSTOFCY = [M:SOH2]STOFCY
[M:BPTS]VBPAADD = [M:ADB2]BPAADD
[M:BPTS]VBPDNAM = [M:ADB2]BPRNAM
Read [BPA]BPA0=1;[M:BPTS]VBPCNUM;[M:BPTS]VBPAADD
If fstat=0
  [M:BPTS]VCRY    = [F:BPA]CRY
  [M:BPTS]VPOSCTY = [F:BPA]CTY
  [M:BPTS]VPOSCOD = [F:BPA]POSCOD
Endif
[M:BPTS]VCUR    = [M:SOH0]CUR
[M:BPTS]VCHGTYP = [M:SOH0]CHGTYP
[M:BPTS]VCHGDAT = [M:SOH0]ORDDAT   
[M:BPTS]VAMTNOT = [M:SOH4]ORDNOT
[M:BPTS]VWEU    = "" 
[M:BPTS]VGROWEI = 0
[M:BPTS]VVOU    = ""
[M:BPTS]VVOL    = 0
Raz [M:BPTS]VBPTARE, VAMTFRE
[M:BPTS]VCUR2   = [M:BPTS]VCUR
Return

#-----------------------------------------------------------------------
$CHARG_SDH
[M:BPTS]VBPTNUM = [M:SDH2]BPTNUM
Read [BPT]BPT0=[M:SDH2]BPTNUM
If !fstat
  [M:BPTS]VCUR1=[F:BPT]CUR
  [M:BPTS]VWEU1=[F:BPT]WEU
  [M:BPTS]VVOU1=[F:BPT]VOU
Endif
[M:BPTS]VBPCNUM = [M:SDH0]BPCORD  
[M:BPTS]VSTOFCY = [M:SDH0]STOFCY
[M:BPTS]VBPAADD = [M:ADB2]BPAADD
[M:BPTS]VBPDNAM = [M:ADB2]BPRNAM
Read [BPA]BPA0=1;[M:BPTS]VBPCNUM;[M:BPTS]VBPAADD
If fstat=0
  [M:BPTS]VCRY    = [F:BPA]CRY
  [M:BPTS]VPOSCTY = [F:BPA]CTY
  [M:BPTS]VPOSCOD = [F:BPA]POSCOD
Endif
[M:BPTS]VCUR    = [M:SDH1]CUR
[M:BPTS]VCHGTYP = [M:SDH0]CHGTYP
[M:BPTS]VCHGDAT = [M:SDH1]DLVDAT   
[M:BPTS]VAMTNOT = [M:SDH1]DLVNOT  
[M:BPTS]VWEU    = [M:SDH2]WEU 
[M:BPTS]VGROWEI = [M:SDH2]GROWEI
[M:BPTS]VVOU    = [M:SDH2]VOU
[M:BPTS]VVOL    = [M:SDH2]VOL
Raz [M:BPTS]VBPTARE, VAMTFRE
[M:BPTS]VCUR2   = [M:BPTS]VCUR
Return

#-----------------------------------------------------------------------
$CHARG_SIH
[M:BPTS]VBPTNUM = ""
[M:BPTS]VCUR1   = ""
[M:BPTS]VWEU1   = ""
[M:BPTS]VVOU1   = ""
[M:BPTS]VBPCNUM = [M:SIH1]BPCORD  
[M:BPTS]VSTOFCY = [M:SIH1]STOFCY
[M:BPTS]VBPAADD = [M:ADB2]BPAADD
[M:BPTS]VBPDNAM = [M:ADB2]BPRNAM
Read [BPA]BPA0=1;[M:BPTS]VBPCNUM;[M:BPTS]VBPAADD
If fstat=0
  [M:BPTS]VCRY    = [F:BPA]CRY
  [M:BPTS]VPOSCTY = [F:BPA]CTY
  [M:BPTS]VPOSCOD = [F:BPA]POSCOD
Endif
[M:BPTS]VCUR    = [M:SIH0]CUR
[M:BPTS]VCHGTYP = [M:SIH0]CHGTYP
[M:BPTS]VCHGDAT = [M:SIH0]INVDAT   
[M:BPTS]VAMTNOT = [M:SIH4]INVNOT
[M:BPTS]VWEU    = [M:BPTS]VWEU1 
[M:BPTS]VGROWEI = 0
[M:BPTS]VVOU    = [M:BPTS]VVOU1
[M:BPTS]VVOL    = 0
Raz [M:BPTS]VBPTARE, VAMTFRE
[M:BPTS]VCUR2   = [M:BPTS]VCUR
Return

########################################################################
# Calcul des frais de port
########################################################################

$TRAITEMENT  
Local Char FRELIB (150) (0..19) : # pour recuperer le detail du calcul
Local Integer STAT
Raz [M:BPTS]VFRELIB : Raz [M:BPTS]NBLIB
#Local Integer JLOK : Call AVERTIR ("Je passe avant call TRANSPORT",JLOK) From GESECRAN

Call TRANSPORT([M:BPTS]VBPTNUM,[M:BPTS]VBPCNUM,[M:BPTS]VSTOFCY,[M:BPTS]VCRY,[M:BPTS]VPOSCTY,
&              [M:BPTS]VPOSCOD,[M:BPTS]VCUR,[M:BPTS]VCHGTYP,[M:BPTS]VCHGDAT,[M:BPTS]VAMTNOT,
&              [M:BPTS]VWEU,[M:BPTS]VGROWEI,[M:BPTS]VVOU,[M:BPTS]VVOL,[M:BPTS]VBPTARE,
&              [M:BPTS]VAMTFRE,FRELIB,STAT) From TRTPRICE
#---
For I=0 To dim(FRELIB)-1
  If FRELIB(I)<>"" : [M:BPTS]NBLIB +=1 : [M:BPTS]VFRELIB(I)=FRELIB(I) : Endif
Next I

Affzo [M:BPTS]

Return

########################################################################
#           Actions Champs ecran BPTS
######################################################################## 

Subprog AS_VBPTNUM(VALEUR)
Variable Char    VALEUR()
# pas de saisie du code transporteur si appel depuis la gestion des transporteurs 
If [M:BPTS]CODTRT="BPT" : mkstat=2 : Endif
End

########################################
Subprog AS_VBPAADD(VALEUR)
Variable Char    VALEUR()
If [M:BPTS]VBPCNUM="" : mkstat=2 : Endif
End

########################################################################

