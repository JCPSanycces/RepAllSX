#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# Sélection d'un script d'appel pour exécution                      Module CRM           3 janvier 2001  #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$PREMIER
  Call LOADSCP(1)
Return

##########################################################################################################
$PRECEDENT
  Call LOADSCP(2)
Return

##########################################################################################################
$SUIVANT
  Call LOADSCP(3)
Return

##########################################################################################################
$DERNIER
  Call LOADSCP(4)
Return

##########################################################################################################
$OUVRE
  Global Char GSZCLLC2
  If GABREV = "CLL" Then
    GSZCLLC2 = [M:CLL0]CLLNUM
  Else
    GSZCLLC2 = GCRMKEY
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Call LOADSCP(1)
  #Si il y a aucun script de défini. On arrête tout.
  If [M:SCP2]SCPNUMY(nolign-1) Then
    GMESSAGE = mess(371,196,1) #Aucun script n'est défini dans l'application. Fonction inaccessible.
    GERR = 2
    FIN = 1
    Return
  Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:SCP2]
  Kill GSZCLLC2
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
  Case BOUT
    When "A"
      FIN = 1
    When Default
  Endcase
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
Subprog LOADSCP(IWHATTODO)
Value Integer IWHATTODO

Local Integer IMAXREC
Local Integer IG
Local Integer ISCQ
Local Integer IQUALDETECT

  IG = 0
  ISCQ = 0
  IMAXREC = 0
  IQUALDETECT = 0
  #1 : Premier
  #2 : Précédent
  #3 : Suivant
  #4 : Dernier
  Case IWHATTODO
    When 1
      Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Asc
      For [SCP]
        If IG >= dim([M:SCP2]SCPNUMY) Then
          Break
        Endif
        #Détermine si des réponses ont été qualifiées pour ce script.
        IQUALDETECT = 0
        Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
        For [SCA]
          IQUALDETECT = 1
          Break
        Next
        Filter [SCA]  
        If IQUALDETECT Then
          [M:SCP2]QLF(IG) = 2
          [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
          [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
          #Calcul le nombre de questions du script.
          Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
          ISCQ = 0
          For [SCQ]
            ISCQ += 1        
          Next
          [M:SCP2]NBQQST(IG) = ISCQ
          Filter [SCQ]
          IG += 1
        Else
          If [F:SCP]SCPFLG <> 2 Then
            [M:SCP2]QLF(IG) = 1    
            [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
            [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
            #Calcul le nombre de questions du script.
            Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
            ISCQ = 0
            For [SCQ]
              ISCQ += 1        
            Next
            [M:SCP2]NBQQST(IG) = ISCQ
            Filter [SCQ]
            IG += 1
          Endif
        Endif
      Next
      Filter [SCP]
    When 2
      If [M:SCP2]NBSCP > 0 Then
        If [M:SCP2]SCPNUMY(0) <> "" Then
          Filter [SCP] Where [F:SCP]SCPNUM < [M:SCP2]SCPNUMY(0) Order By [F:SCP]SCPNUM Desc
          For [SCP]
            If IMAXREC >= dim([M:SCP2]SCPNUMY)-1 Then
              Break
            Endif
            #Détermine si des réponses ont été qualifiées pour ce script.
            IQUALDETECT = 0
            Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
            For [SCA]
              IQUALDETECT = 1
              Break
            Next
            Filter [SCA]  
            If IQUALDETECT Then
              IMAXREC += 1
            Else
               If [F:SCP]SCPFLG <> 2 Then
                 IMAXREC += 1
               Endif
            Endif
          Next
          Filter [SCP]
          If IMAXREC Then
            Filter [SCP] Where [F:SCP]SCPNUM < [M:SCP2]SCPNUMY(0) Order By [F:SCP]SCPNUM Desc
            For [SCP] 
              If IMAXREC < 0 Then
                Break
              Endif
              #Détermine si des réponses ont été qualifiées pour ce script.
              IQUALDETECT = 0
              Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
              For [SCA]
                IQUALDETECT = 1
                Break
              Next
              Filter [SCA]  
              If IQUALDETECT Then
                [M:SCP2]QLF(IMAXREC) = 2
                [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
                [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
                #Calcul le nombre de questions du script.
                Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                ISCQ = 0
                For [SCQ]
                  ISCQ += 1        
                Next
                [M:SCP2]NBQQST(IMAXREC) = ISCQ
                Filter [SCQ]
                IMAXREC -= 1
                IG += 1
              Else
                If [F:SCP]SCPFLG <> 2 Then
                  [M:SCP2]QLF(IMAXREC) = 1    
                  [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
                  [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
                  #Calcul le nombre de questions du script.
                  Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                  ISCQ = 0
                  For [SCQ]
                    ISCQ += 1        
                  Next
                  [M:SCP2]NBQQST(IMAXREC) = ISCQ
                  Filter [SCQ]
                  IMAXREC -= 1
                  IG += 1
                Endif
              Endif
            Next
            Filter [SCP]
          Endif
          If IG = 0 Then
            Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Asc
            For [SCP] 
              #Détermine si des réponses ont été qualifiées pour ce script.
              IQUALDETECT = 0
              Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
              For [SCA]
                IQUALDETECT = 1
                Break
              Next
              Filter [SCA]  
              If IQUALDETECT Then
                [M:SCP2]QLF(IG) = 2
                [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
                [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
                #Calcul le nombre de questions du script.
                Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                ISCQ = 0
                For [SCQ]
                  ISCQ += 1        
                Next
                [M:SCP2]NBQQST(IG) = ISCQ
                Filter [SCQ]
                IG += 1
              Else
                If [F:SCP]SCPFLG <> 2 Then
                  [M:SCP2]QLF(IG) = 1    
                  [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
                  [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
                  #Calcul le nombre de questions du script.
                  Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                  ISCQ = 0
                  For [SCQ]
                    ISCQ += 1        
                  Next
                  [M:SCP2]NBQQST(IG) = ISCQ
                  Filter [SCQ]
                  IG += 1
                Endif
              Endif
            Next
            Filter [SCP]
          Endif
        Endif
      Endif
    When 3
      If [M:SCP2]NBSCP > 0 Then
        If [M:SCP2]SCPNUMY([M:SCP2]NBSCP - 1) <> "" Then
          Filter [SCP] Where [F:SCP]SCPNUM > [M:SCP2]SCPNUMY([M:SCP2]NBSCP - 1) Order By [F:SCP]SCPNUM Asc
          For [SCP] 
            If IG >= dim([M:SCP2]SCPNUMY) Then
              Break
            Endif
            #Détermine si des réponses ont été qualifiées pour ce script.
            IQUALDETECT = 0
            Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
            For [SCA]
              IQUALDETECT = 1
              Break
            Next
            Filter [SCA]  
            If IQUALDETECT Then
              [M:SCP2]QLF(IG) = 2
              [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
              [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
              #Calcul le nombre de questions du script.
              Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
              ISCQ = 0
              For [SCQ]
                ISCQ += 1        
              Next
              [M:SCP2]NBQQST(IG) = ISCQ
              Filter [SCQ]
              IG += 1
            Else
              If [F:SCP]SCPFLG <> 2 Then
                [M:SCP2]QLF(IG) = 1    
                [M:SCP2]SCPNUMY(IG) = [F:SCP]SCPNUM
                [M:SCP2]SCPNAMY(IG) = [F:SCP]SCPNAM
                #Calcul le nombre de questions du script.
                Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                ISCQ = 0
                For [SCQ]
                  ISCQ += 1        
                Next
                [M:SCP2]NBQQST(IG) = ISCQ
                Filter [SCQ]
                IG += 1
              Endif
            Endif
          Next
          Filter [SCP]
          If IG = 0 Then
            Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Desc
            For [SCP]
              If IMAXREC >= dim([M:SCP2]SCPNUMY)-1 Then
                Break
              Endif
              #Détermine si des réponses ont été qualifiées pour ce script.
              IQUALDETECT = 0
              Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
              For [SCA]
                IQUALDETECT = 1
                Break
              Next
              Filter [SCA]  
              If IQUALDETECT Then
                IMAXREC += 1
              Else
                If [F:SCP]SCPFLG <> 2 Then
                  IMAXREC += 1
                Endif
              Endif
            Next
            Filter [SCP]
            If IMAXREC Then
              IMAXREC -= 1
              Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Desc
              For [SCP] 
                If IMAXREC < 0 Then
                  Break
                Endif
                #Détermine si des réponses ont été qualifiées pour ce script.
                IQUALDETECT = 0
                Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
                For [SCA]
                  IQUALDETECT = 1
                  Break
                Next
                Filter [SCA]  
                If IQUALDETECT Then
                  [M:SCP2]QLF(IMAXREC) = 2
                  [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
                  [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
                  #Calcul le nombre de questions du script.
                  Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                  ISCQ = 0
                  For [SCQ]
                    ISCQ += 1        
                  Next
                  [M:SCP2]NBQQST(IMAXREC) = ISCQ
                  Filter [SCQ]
                  IMAXREC -= 1
                  IG += 1
                Else
                  If [F:SCP]SCPFLG <> 2 Then
                    [M:SCP2]QLF(IMAXREC) = 1    
                    [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
                    [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
                    #Calcul le nombre de questions du script.
                    Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
                    ISCQ = 0
                    For [SCQ]
                      ISCQ += 1        
                    Next
                    [M:SCP2]NBQQST(IMAXREC) = ISCQ
                    Filter [SCQ]
                    IMAXREC -= 1
                    IG += 1
                  Endif
                Endif
              Next
              Filter [SCP]
            Endif
          Endif
        Endif
      Endif
    When 4
      Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Desc
      For [SCP]
        If IMAXREC >= dim([M:SCP2]SCPNUMY)-1 Then
          Break
        Endif
        #Détermine si des réponses ont été qualifiées pour ce script.
        IQUALDETECT = 0
        Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
        For [SCA]
          IQUALDETECT = 1
          Break
        Next
        Filter [SCA]  
        If IQUALDETECT Then
          IMAXREC += 1
        Else
          If [F:SCP]SCPFLG <> 2 Then
            IMAXREC += 1
          Endif
        Endif
      Next
      Filter [SCP]
      If IMAXREC Then
        IMAXREC -= 1
        Filter [SCP] Where [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Desc
        For [SCP] 
          If IMAXREC < 0 Then
            Break
          Endif
          #Détermine si des réponses ont été qualifiées pour ce script.
          IQUALDETECT = 0
          Filter [SCA] Where [F:SCA]CLL = GSZCLLC2 and [F:SCA]SCP = [F:SCP]SCPNUM
          For [SCA]
            IQUALDETECT = 1
            Break
          Next
          Filter [SCA]  
          If IQUALDETECT Then
            [M:SCP2]QLF(IMAXREC) = 2
            [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
            [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
            #Calcul le nombre de questions du script.
            Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
            ISCQ = 0
            For [SCQ]
              ISCQ += 1        
            Next
            [M:SCP2]NBQQST(IMAXREC) = ISCQ
            Filter [SCQ]
            IMAXREC -= 1
            IG += 1
          Else
            If [F:SCP]SCPFLG <> 2 Then
              [M:SCP2]QLF(IMAXREC) = 1    
              [M:SCP2]SCPNUMY(IMAXREC) = [F:SCP]SCPNUM
              [M:SCP2]SCPNAMY(IMAXREC) = [F:SCP]SCPNAM
              #Calcul le nombre de questions du script.
              Filter [SCQ] Where [F:SCQ]SCPNUM = [F:SCP]SCPNUM
              ISCQ = 0
              For [SCQ]
                ISCQ += 1        
              Next
              [M:SCP2]NBQQST(IMAXREC) = ISCQ
              Filter [SCQ]
              IMAXREC -= 1
              IG += 1
            Endif
          Endif
        Next
        Filter [SCP]
      Endif
  Endcase
  [M:SCP2]NBSCP = IG
  Affzo [M:SCP2]1-99
End
