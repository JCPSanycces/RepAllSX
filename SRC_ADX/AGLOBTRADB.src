# ! ACTUELLEMENT NE SERT PLUS QUE POUR LA REMONTEE DES TRADS DE DOC !
#   !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
End

$CHARG_TRANSLATE
Case GPRODUIT
 When -1 : GINDUS = ""                                      : # Superviseur
 When  0 : GINDUS = "AWS-X3-INDCLOUD:20100@X3INDCLOUD"      : # X3
 When  1 : GINDUS = ""                                      : # Géode
 When  2 : GINDUS = "" : # Paye
 When  3 : GINDUS = "" : # ABEL
 When  4 : GINDUS = "" : # Loan
Endcase

GFOLDER_V150 (0) = "AWS-X3-INDV5:15005@SUPERV150"   : # superviseur superv V5 (dossier SUPERV150)
GFOLDER_V150 (1) = "AWS-X3-INDV5:15150@X3IND150"    : # X3 V5
GFOLDER_V150 (2) = "AWS-X3-INDV5:6150@GEOIND150"    : # geode v5
GFOLDER_V150 (3) = "AWS-X3-INDV5:15160@PAYIND150"   : # paye v5
GFOLDER_V150 (4) = "AWS-X3-INDV5:4150@ABEIND150"    : # abel v5
GFOLDER_V150 (5) = ""

#GFOLDER_V200 (0) = "AWS-X3-INDAVENG:20200@SUPERVAVEN"   : # superviseur superv V10 (dossier SUPERV)
#GFOLDER_V200 (1) = "AWS-X3-INDAVENG:20100@X3INDAVENG"   : # X3 V10 AVENGER
#GFOLDER_V200 (2) = "AWS-X3-INDAVENG:20300@GEOINDAVEN"   : # geode v10
#GFOLDER_V200 (3) = ""                                   : # paye v10
#GFOLDER_V200 (4) = ""                                   : # ABEL en v10 n'existe plus
#GFOLDER_V200 (5) = ""
#
#GFOLDER_R080 (0) = "scmsup-v11-svr:1801@FOLDEV"         : # superviseur superv V11 (dossier SUPERV)
#GFOLDER_R080 (1) = "AWS-X3-INDCHALL:20100@X3INDCHALL"   : # X3 V11 CHALLENGER
#GFOLDER_R080 (2) = "AWS-X3-INDCHALL:20300@GEOINDCHAL"   : # geode v11
#GFOLDER_R080 (3) = ""                                   : # paye v11
#GFOLDER_R080 (4) = ""                                   : # ABEL en v11 n'existe plus
#GFOLDER_R080 (5) = ""

GFOLDER_R090 (0) = ""                                   : # superviseur superv V12 (dossier SUPERV)
GFOLDER_R090 (1) = "AWS-X3-INDCLOUD:20100@X3INDCLOUD"   : # X3 V12
GFOLDER_R090 (2) = ""                                   : # geode v12
GFOLDER_R090 (3) = ""                                   : # paye v12
GFOLDER_R090 (4) = ""                                   : # ABEL en v12 n'existe plus
GFOLDER_R090 (5) = ""

GNBLANSTD = 0

If GPRODUIT = -1
    # produit superviseur
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XFRA" : GREFFRA (GNBLANSTD) = "SUPTRANS"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XSPA" : GREFFRA (GNBLANSTD) = "SUPTRANS"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XBRI" : GREFFRA (GNBLANSTD) = "SUPTRANS"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XENG" : GREFFRA (GNBLANSTD) = "SUPTRANS"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XPOR" : GREFFRA (GNBLANSTD) = "SUPTRANS"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "SUPTRANS" : GDEMOF(GNBLANSTD) = "SUPTRANS" : GUSRLAN(GNBLANSTD) = "XITA" : GREFFRA (GNBLANSTD) = "SUPTRANS"
Elsif GPRODUIT = 3
    # produit abel
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "SEED"       : GUSRLAN(GNBLANSTD) = "XFRA" : GREFFRA (GNBLANSTD) = "X3REFV7"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XSPA" : GREFFRA (GNBLANSTD) = "X3REFV7"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XBRI" : GREFFRA (GNBLANSTD) = "X3REFV7"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XENG" : GREFFRA (GNBLANSTD) = "X3REFV7"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XPOR" : GREFFRA (GNBLANSTD) = "X3REFV7"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "X3REFV7"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XITA" : GREFFRA (GNBLANSTD) = "X3REFV7"
Elsif GPRODUIT = 1
    # produit geode
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEOREFFRA" : GUSRLAN(GNBLANSTD) = "XFRA" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEODEMOSPA" : GUSRLAN(GNBLANSTD) = "XSPA" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEOTST140" : GUSRLAN(GNBLANSTD) = "XBRI" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEOTST140" : GUSRLAN(GNBLANSTD) = "XENG" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEODEMOPOR" : GUSRLAN(GNBLANSTD) = "XPOR" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "GEOREFCHAL" : GDEMOF(GNBLANSTD) = "GEOTST140" : GUSRLAN(GNBLANSTD) = "XITA" : GREFFRA (GNBLANSTD) = "GEOREFCHAL"
Elsif GPRODUIT = 2
    # produit paye
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "PAYREFFRA" : GDEMOF(GNBLANSTD) = "PAYTESTV7" : GUSRLAN(GNBLANSTD) = "XFRA"  : GREFFRA (GNBLANSTD) = "PAYREFFRA"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "PAYREFPOR" : GDEMOF(GNBLANSTD) = "PAYTESTV7"  : GUSRLAN(GNBLANSTD) = "XPOR" : GREFFRA (GNBLANSTD) = "PAYREFFRA"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "PAYREFZAF" : GDEMOF(GNBLANSTD) = "PAYTESTV7"  : GUSRLAN(GNBLANSTD) = "XENG" : GREFFRA (GNBLANSTD) = "PAYREFFRA"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "PAYREFSPA" : GDEMOF(GNBLANSTD) = "PAYTESTV7"  : GUSRLAN(GNBLANSTD) = "XSPA" : GREFFRA (GNBLANSTD) = "PAYREFFRA"
Else
    # produit x3
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "SEED"       : GUSRLAN(GNBLANSTD) = "XFRA"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XSPA"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XBRI"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XENG"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XPOR"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XITA"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "CHI" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XCHI"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "GER" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "X3TST"      : GUSRLAN(GNBLANSTD) = "XGER"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "RUS" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "TESTCPPRM"  : GUSRLAN(GNBLANSTD) = "XRUS"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POL" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "TESTCPPRM"  : GUSRLAN(GNBLANSTD) = "XPOL"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ARB" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GDEMOF(GNBLANSTD) = "TESTCPPRM"  : GUSRLAN(GNBLANSTD) = "XARB"  : GREFFRA (GNBLANSTD) = "X3REFCLOUD"
Endif

Return

