#<AdxTL>@(#)216.0.0.0 $Revision$ Mise en portefeuille des règlements
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..1)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"PAYMEP"
 GFONCTION="PAYMEP" : Call AUTORIS From EXEFNC
Endif
GACTION="PAYMEP"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYMEP","DPAYMEP",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

#########
$INIT_DIA
#########
[M:DIA]ACCSTA=3

# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return

#########
$CONTROLE
#########
If GSERVEUR : [M:DIA]TRC=2 : Endif
TMP=1
If [M:DIA]PRO=2 : TIT="T" : # Opération en cours
Else            : TIT="R" : # Recherche
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,SAI) From CPTDIV2
If SAI : Return : Endif
Return

#####
$EXEC
#####
Local Char     NUM(GLONVCR), DEVLOC(GLONCUR), SEP(3)
Local Decimal  MT, MT2
Local Integer  I

Onerrgo ERREUR From CONTROLE
If [M:DIA]TRC=2 & !clalev([F:PYT])
 Local File TMPPAYTOT [PYT]
Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call TITAWI(BCRIT,GMESSAGE) From OBJDIV
 Call OUVRE_TRACE(GMESSAGE) From LECFIC
Endif

[M:DIA]NB=0
If GSERVEUR
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Elsif dim([M:DIA]LEG)>0
  GCURLEG = [M:DIA]LEG
 Endif
Endif
Call PAYCPT(NUM) From PAYCPTA

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return

$TR_RAZ_PYT
GOK=1
Trbegin [PYT]
 Delete [PYT] Where TRC=GTRACE
 If fstat=1 | fstat>5
  GOK=2 : Call RSTA("PYT",GTRACE) From GLOCK
 Endif
Commit
Return

########
$TERMINE
########
If GSERVEUR : Return : Endif
If ![M:DIA]NB : # Aucun règlement traité
 GERR=2 : GMESSAGE=mess(2,117,1)
Elsif [M:DIA]TRC<>2 : # NB règlement(s) traité(s)
 GERR=2 : GMESSAGE=num$([M:DIA]NB)-mess(28,117,1)
Endif
Return

##################################
## Etiquettes de l'écran PAYMEP ##
##################################
$SEL_TABLE
Case COUZON

 When "LOT" : # Lot de saisie
  OBJET="PYL"
  If [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
   CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTYP<>2
   CRITERE-="& PAYTYP='"+[M]TYP+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif

Endcase
Return

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR)From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR)From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY = 2 : mkstat = 1 : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 1 : Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat | [F:TPY]STA3<>2 : # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]ALLUSR = 2 : VALEUR="" : mkstat = 2
Elsif VALEUR="" : VALEUR = GUSER
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char VALEUR
If [M]ALLCUR=2 : mkstat=1 : Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char    VALEUR()
If [M]ALLCUR=2 | [M]CUR<>"" : mkstat=1 : Endif
End

Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]ALLCPY<>2 & [F:PYL]CPY<>[M]CPY
 # Lot de saisie de société
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY : mkstat=2 : End
Elsif [M]ALLTYP<>2 & [F:PYL]PAYTYP<>[M]TYP
 # Lot de saisie de transaction
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP  : mkstat=2 : End
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYL]PAYTYP) From CPTLEC
If fstat | [F:TPY]STA3<>2
 # Transaction de règlement non paramétrée pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2 : End
Endif
End

Subprog AS_PRO(VALEUR)
Variable Integer VALEUR
Local Integer I
If [M]FCY<>""
 I=find([M]FCY,GUSRFCY(1..GNBAUZ))
 If !I | !instr(1,GUSRAUZ(I),"G")
  VALEUR=1 : mkstat=2
 Endif
Endif
End

Subprog AS_VALDAT(VALEUR)
Variable Date    VALEUR
If [M]PRO<>2 : mkstat=1 : Endif
End

########################################


Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog C_ALLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
End

Subprog C_PRO(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Effzo VALDAT : Grizo VALDAT
Else
 Actzo VALDAT
Endif
End

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If [M]ALLLOT=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
If [M]ALLUSR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
If [M]ALLCUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
If [M]PRO<>2
 Effzo VALDAT : Grizo VALDAT
Else
 Actzo VALDAT
Endif
If GBIDC1<>""
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP
 If dim(ZTYP)>0 : Affzo ZTYP : Endif
 Grizo ALLTYP, TYP
Else
 Actzo ALLTYP
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
End

######################################################################################

