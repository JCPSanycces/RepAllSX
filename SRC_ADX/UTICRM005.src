#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Initialisation de HTOTTIMSPG avec TIMSPG quand ça n'a pas été fait #
########################################################################
# FGR 17/02/2009 : X3SUIVI52520
########################################################################

########################################################################
Local Char DOSSIER(30) 

  Call OUVRE_TRACE("UTICRM005: start") From LECFIC
  Call TEMPON("O") From GESECRAN
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [F:ADS]DOSSIER=DOSSIER
  If fstat Then
    Raz [F:ADS]
  Endif
  #
  If [F:ADS]MODULE(12) <> 2 and [F:ADS]MODULE(13) <> 2 Then
    End
  Endif
  #
  If DOSSIER<>"" Then
    Call MAJ_UTICRM005(DOSSIER)
  Endif
  Call FERME_TRACE From LECFIC
  Call TEMPOFF     From GESECRAN
  Call LEC_TRACE From LECFIC
End
########################################################################

########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
Local Char WOBJET(10)

  If APPLI = "X3" Then
    End 
  Endif
  # 12 = Support client
  # 13 = Action commerciale
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [F:ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  If [F:ADS]MODULE(12) <> 2 and [F:ADS]MODULE(13) <> 2 Then
    End
  Endif
  Call MAJ_UTICRM005(APPLI)
End

########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI
Local Char WOBJET(10)

  If APPLI = "X3" Then
    End 
  Endif
  # 12 = Support client
  # 13 = Action commerciale
  If [F:ADS]MODULE(12) <> 2 and [F:ADS]MODULE(13) <> 2 Then
    End
  Endif
  Call MAJ_UTICRM005(APPLI)
End

########################################################################
Subprog MAJ_UTICRM005(DOSSIER)
Value Char DOSSIER

Local Integer N_REWRITE
Local Integer IBINTERVEN

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  N_REWRITE = 0
  IBINTERVEN = 1
  If filinfo(filpath("FIL","INTERVEN","fde",DOSSIER),0) <= 0 Then
    IBINTERVEN = 0
  Endif
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    If !clalev ([F:ITN]) : Local File =DOSSIER+".INTERVEN" [ITN] : Endif
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Réaffectation du temps passé") From DOSSUB
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    Call ECR_TIME("DEBUT => Intervention (ITN)") From DOSSUB
    Trbegin [ITN]
    # Toutes les intervention qui ont une durée (en heure) dans l'ancienne rubrique (TIMSPG)
    # et qui n'en n'ont pas dans les nouvelles (HTOTTIMSPG et MTOTTIMSPG)
    Filter [ITN] Where TIMSPG <> 0 and HTOTTIMSPG = 0 and MTOTTIMSPG = 0
    For [ITN]ITN0
      [F:ITN]HTOTTIMSPG = [F:ITN]TIMSPG   #CHECK IGNORE_LINE
      Rewrite [ITN]
      If fstat <> 0 Then
        Call ECR_TRACE("ITN :" - [F:ITN]NUM - ":" - num$(fstat), 1) From GESECRAN
      Endif
      N_REWRITE += 1
    Next
    Filter [ITN]
    Commit
    Call ECR_TIME("FIN => Intervention (ITN) :" - num$(N_REWRITE) - "enregistrements mis à jour") From DOSSUB
  Endif
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    Close Local File [ITN]
  Endif
End
