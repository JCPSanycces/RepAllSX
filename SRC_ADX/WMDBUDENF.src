#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
## BI-DIMENSION ## Synchronization rule BUDENF

$OUVRE
Local Char FILTRE(250)
OUVTAB = GDOSSIER+".ENVFIY" : If clalev([F:ENF])=0 : Local File =OUVTAB [ENF] : Endif
OUVTAB = GDOSSIER+".ENVELOPPE" : If clalev([F:ENV])=0 : Local File =OUVTAB [ENV] : Endif
OUVTAB = "Link [ENF]"
Link [ENF] With
& [ENV]ENV0 = [F:ENF]ENV
& As [LNK_]
& Order By Key CLE = [ENF]ENV;[ENF]FIYNUM
FILTRE = ""
Return

$FERME
If clalev([F:ENF]) : Close local File [ENF] : Endif
If clalev([F:ENV]) : Close local File [ENV] : Endif
Return

$DCLE
Local Char    DCLE(GLONAVA)(1..2)
Local Integer DTYP(1..2)
Local Integer NBDCLE
NBDCLE = 2
DCLE(1) = "ENV"
DTYP(1) =  7
DCLE(2) = "FIY"
DTYP(2) =  7
Return

$CHARGE_CLE
If dim([F:AAA_]ENV)>0
 [F:AAA_]ENV = [F:ENF]ENV
Endif
If dim([F:AAA_]FIY)>0
 [F:AAA_]FIY = [F:ENF]FIYNUM
Endif
Return

########################################################################
# Return the filter necessary for incremental delete in synchroonization
Subprog GET_FLTDELINC(PFLT)
Variable Clbfile PFLT
PFLT = "1=1"
Append PFLT, " & [F:AAA_]ENV=[F:ENF]ENV"
Append PFLT, " & [F:AAA_]FIY=[F:ENF]FIYNUM"

End

$MAJFLD
### ENV
[L]FLD="ENV"
[L]FORMULE='[F:ENF]ENV'
If dim([F:AAA_]ENV)>0
 [F:AAA_]ENV = [F:ENF]ENV
Endif

### FIY
[L]FLD="FIY"
[L]FORMULE='[F:ENF]FIYNUM'
If dim([F:AAA_]FIY)>0
 [F:AAA_]FIY = [F:ENF]FIYNUM
Endif

### AMTBUDFIY
[L]FLD="AMTBUDFIY"
[L]FORMULE='[F:ENF]AMTBUDFIY'
If dim([F:AAA_]AMTBUDFIY)>0
 [F:AAA_]AMTBUDFIY = [F:ENF]AMTBUDFIY
Endif

### AMTAPPFIY
[L]FLD="AMTAPPFIY"
[L]FORMULE='[F:ENF]AMTAPPFIY'
If dim([F:AAA_]AMTAPPFIY)>0
 [F:AAA_]AMTAPPFIY = [F:ENF]AMTAPPFIY
Endif

### AMTRESFIY
[L]FLD="AMTRESFIY"
[L]FORMULE='[F:ENF]AMTRESFIY'
If dim([F:AAA_]AMTRESFIY)>0
 [F:AAA_]AMTRESFIY = [F:ENF]AMTRESFIY
Endif

### STA
[L]FLD="STA"
[L]FORMULE='[F:ENF]STAFIY'
If dim([F:AAA_]STA)>0
 [F:AAA_]STA = [F:ENF]STAFIY
Endif

### APPDATFIY
[L]FLD="APPDATFIY"
[L]FORMULE='[F:ENF]APPDATFIY'
If dim([F:AAA_]APPDATFIY)>0
 [F:AAA_]APPDATFIY = [F:ENF]APPDATFIY
Endif

### REVDATFIY
[L]FLD="REVDATFIY"
[L]FORMULE='[F:ENF]REVDATFIY'
If dim([F:AAA_]REVDATFIY)>0
 [F:AAA_]REVDATFIY = [F:ENF]REVDATFIY
Endif


Return

