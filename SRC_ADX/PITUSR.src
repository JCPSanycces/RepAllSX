#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : utilisateurs
#                             cf AML 2240 : 33
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables PJTWPIV devient WK
######################################################################
$OUVTAB_USR
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:AUS]) Local File AUTILIS [AUS] Endif
Return

######################################################################
Subprog TRT_USR(ID,CLETRT,PITUSR,P_CRITERE,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITUSR () 
Value Char P_CRITERE() 
Variable Integer OK

If PITUSR ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_USR
Gosub OUVREPIVOT From CONNECTFCT


Local Integer WNBUSR  : Raz WNBUSR 
Local Integer WPREUSR : Raz WPREUSR
Local Char    OPTUSR(GDIMFIC)
OPTUSR = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitusr")
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES 
Local Integer WKHEATYP       : Raz WKHEATYP 
Local Char    WKHEADMES (250): Raz WKHEADMES 

Call READPIT(PITUSR,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Call LOADPIVZON(PITUSR,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(PITUSR,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREUSR,OPTUSR) From CONNECTFCT

#######
For [AUS] Where evalue(P_CRITERE)
    Gosub WR_USR
Next
#######

Call WRPIVOT_END(PITUSR ,WNBUSR ,WKNORECMES ,WPREUSR ,OPTUSR) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_USR
    ################################
    # fichiers USR
    ################################
    #     Ouverture du fichier OPTUSR en écriture
    If WPREUSR = 0
      Openo OPTUSR,0 Using [FPIV]
      WPREUSR = 1
    Else
      Openo OPTUSR Using [FPIV]
    Endif
    
    WNBUSR += 1
    Call RAZVALPIVOT(PITUSR,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITUSR,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Return

######################################################################
#############################################################################
Funprog AUS_GETDES(USR)
Value Char USR

If pat(GVERSION,"1.5.*")
    If !clalev([F:AUS]) Local File AUTILIS [AUS] Endif
    If [F:AUS]USR <> USR
        Read [AUS]CODUSR=USR
        If fstat : End "" : Endif
    Endif
     End [F:AUS]NOMUSR
Else
    End func AFNC.TEXTRA("AUTILIS","INTUSR",USR,"")
Endif
End ""

#############################################################################

