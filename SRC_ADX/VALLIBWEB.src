#<AdxTL>@(#)1.0.0.0 $Revision$
# VALLIBWEB                                        CC   01/10/2004
#
#
#              Chargement et restitution des libellés serveur Web
#

#Gosub DELETF
Call EXPORTLIBS
End

$DELETF
Local File APLSTD  [AST]
Local File AMENLOC [AML]
Trbegin [AST],[AML]
Delete [AST] Where [F:AST]LANCHP>=9700 and [F:AST]LANCHP<9800  
Delete [AML] Where [F:AML]MENLOC>=9700 and [F:AML]MENLOC<9800
Commit
Return

Subprog IMPORTLIBS
Local Char NOMFIC(250),DIRSEP,NAMEREP(200),RESSOURCE(120)
Local Char TLAN(GLONLAN)(1..50)
Local Integer NBLAN,SAVMAX,FIN

Case toupper(GOS(1))
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Local Integer NBIMP,I,LASTNUM,MENDEP,MENFIN,NBF
Local Char IMP(120)(1..100)
If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REP = "X3_ROOT"+DIRSEP+"IMP"
NAMEREP=filpath(REP,"","","X3_PUB")
Local File (HLP(150)) From System 'lsadx -a'-toupper(nomap(0))-NAMEREP As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>4<>0
   FIN=instr(1,[F:HLP_]HLP,".x")
   If !find(left$([F:HLP_]HLP,FIN-1),IMP(1..NBIMP))
     NBIMP+=1
     IMP(NBIMP)=left$([F:HLP_]HLP,FIN-1)
   Endif
 Endif
Next HLP_
If NBIMP=0 : End : Endif
Local File APLSTD  [AST]
Local File AMENLOC [AML]
Gosub INILIBW
For NBF=1 To NBIMP
  NAMEREP=IMP(NBF)
  Gosub IMPFIC
  Gosub MAJMENLOC
Next NBF
Infbox("Nombre de fichiers importés : "+num$(NBIMP))

End

$INILIBW
# Phase 1 : Crée le répertoire EXP sous X3_ROOT si il n'existe pas

  Local Char MACHINE(GDIMFIC),ORDSYS(100),REPERT(GDIMFIC)
  Local Integer STAT,K
  Call NAMEFIC("","EXP","","",REPERT) From INTRUTILA
  If filinfo(REPERT,0)<0
   K = instr(1,REPERT,"@")
   If K
    ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
   Else
    ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
   Endif
   Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
  Endif


# Phase 2 : Recherche la liste des langues

  Filter [AST] Where LANCHP=9802 and LANNUM=1 and LAN<>"XXX" 
  For [AST]
    If [F:AST]LANMES<>""
      NBLAN+=1
      TLAN(NBLAN)=[F:AST]LAN
    Endif
  Next
  Filter [AST]
Return

$MAJMENLOC
  LASTNUM=0
  SAVMAX=NUMMAX
  If NUMMEN=0 : Gosub RECHREF : Endif
  RESSOURCE=NAMEREP
  Trbegin [AST],[AML]

#  Raz du menu dans les langues XXX et FRA
  Delete [AST] Where [F:AST]LANCHP=NUMMEN and [F:AST]LAN="XXX"  
  Delete [AST] Where [F:AST]LANCHP=NUMMEN and [F:AST]LAN="FRA"  
  Delete [AML] Where [F:AML]MENLOC=NUMMEN
  Read [AML]MENLOC=9802
  [F:AML]MENLOC=NUMMEN
  [F:AML]CREDAT=date$
  If dim([F:AML]CRETIM)>0 : [F:AML]CRETIM=time : Endif
  [F:AML]CREUSR=GUSER
  Raz [F:AML]UPDDAT,UPDUSR
  If dim([F:AML]UPDTIM)>0 : Raz [F:AML]UPDTIM : Endif
  Write [AML]
  If fstat<>0 : Goto ERRWRIT1 : Endif

  [F:AST]LANCHP=NUMMEN
  [F:AST]CREDAT=date$
  If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM=time : Endif
  [F:AST]CREUSR=GUSER
  Raz [F:AST]UPDDAT,UPDUSR
  If dim([F:AST]UPDTIM)>0 : Raz [F:AST]UPDTIM : Endif



# Langue XXX
  [F:AST]LAN="XXX"
  [F:AST]LANNUM=0
  [F:AST]LANMES="Serveur Web"-num$(NUMMEN)
  Write [AST]
  If fstat<>0 : Goto ERRWRIT : Endif
  [F:AST]LANNUM=1
  [F:AST]LANMES="Name"
  If NUMMAX=0 : NUMMAX=1 : Endif
  Write [AST]
  If fstat<>0 : Goto ERRWRIT : Endif  

Local Integer NBRS
  For I=1 To NBID
    Raz MENDEP,MENFIN,NBRS
    If LIBNUM(I)=""
      MENDEP=NUMMAX+1
      MENFIN=MENDEP+LIBREC(I)-1
      NUMMAX+=LIBREC(I)
    Else
      For indice=1 To len(LIBNUM(I))
        If mid$(LIBNUM(I),indice,1)="/"
          NBRS+=1
          If MENDEP=0 : MENDEP=val(left$(LIBNUM(I),indice-1)) : Endif
        Endif
      Next indice
      If MENDEP=0 : MENDEP=val(LIBNUM(I)) : Endif
      MENFIN=MENDEP+NBRS       
    Endif
    For indice=MENDEP To MENFIN
      [F:AST]LANNUM=indice
      [F:AST]LANMES=LIBID(I)
      Write [AST]
      If fstat<>0 : Goto ERRWRIT : Endif
    Next indice
  Next I


# Langue FRA

  [F:AST]LAN="FRA"
  [F:AST]LANNUM=0
  [F:AST]LANMES="Serveur Web"-num$(NUMMEN)
  Write [AST]
  If fstat<>0 : Goto ERRWRIT : Endif

  NUMMAX=SAVMAX
  [F:AST]LANNUM=1
  [F:AST]LANMES=RESSOURCE
  If NUMMAX=0 : NUMMAX=1 : Endif
  Write [AST]
  If fstat<>0 : Goto ERRWRIT : Endif  

  For I=1 To NBID
    Raz MENDEP,MENFIN,NBRS
    If LIBNUM(I)=""
      MENDEP=NUMMAX+1
      MENFIN=MENDEP+LIBREC(I)-1
      NUMMAX+=LIBREC(I)
    Else
      For indice=1 To len(LIBNUM(I))
        If mid$(LIBNUM(I),indice,1)="/"
          NBRS+=1
          If MENDEP=0 : MENDEP=val(left$(LIBNUM(I),indice-1)) : Endif
        Endif
      Next indice
      If MENDEP=0 : MENDEP=val(LIBNUM(I)) : Endif
      MENFIN=MENDEP+NBRS       
    Endif
    For indice=MENDEP To MENFIN
      [F:AST]LANNUM=indice
      [F:AST]LANMES=LIBFRA(indice-MENDEP+1,I)
      Write [AST]
      If fstat<>0 : Goto ERRWRIT : Endif
    Next indice
  Next I

  Commit

Return



$ERRIMP
  Call ECR_TRACE("Erreur import type"-num$(TERR)-RESSOURCE-VALL1,1) From GESECRAN
  If adxlog=1 : Rollback : Endif
Return


$ERRWRIT
  Call ECR_TRACE("Erreur ecriture table APLSTD "-num$(NUMMEN)-num$([F:AST]LANNUM)-num$(fstat),1) From GESECRAN
  Rollback
Return

$ERRWRIT1
  Call ECR_TRACE("Erreur ecriture table AMENLOC "-num$(NUMMEN)-num$(fstat),1) From GESECRAN
  Rollback
Return



$RECHREF
Filter [AML] Where MENLOC>=9700 & MENLOC<9800
For [AML]
  LASTNUM=[F:AML]MENLOC
Next
If LASTNUM<9700 : LASTNUM=9700 : Endif
NUMMEN=LASTNUM+1
Filter [AML]
Return


$IMPFIC
Local Char VALL1(100)(1..2000)
Local Integer NBLU
Call NAMEFIC("","IMP","",NAMEREP,NOMFIC) From INTRUTILA
NOMFIC+=".splited"
Openi NOMFIC,0 Using [IMP_]
Iomode adxifs ""  Using [IMP_]
Iomode adxirs chr$(10)  Using [IMP_]
Iomode adxium GUTF8  Using [IMP_]
fstat=0
While fstat=0
  NBLU+=1
  Rdseq VALL1(NBLU) Using [IMP_]
Wend

Local Char VALCOU(250),VLIB(250)(1..10)
Local Integer NUMMEN             : # Numéro du menu local à importer
Local Char LIBNUM(50)(1..500)
Local Char LIBID(110)(1..500)
Local Char LIBFRA(120)(1..10,1..500)
Local Integer LIBREC(1..500)     : # Nombre d'enregistrement LIBFRA pour l'entrée
Local Integer NUMMAX             : # Plus grand numéro d'entrée rencontrée
Local Integer INDT,IC,FINT,NBID,ILIB
Local Integer POSD,POSD1,POSD2
Local Integer POSF,POSF1,POSF2
VALCOU=VALL1(1)+VALL1(2)
INDT=2
Gosub RECHLIBS
While FINT=0
  Gosub RECHID
  Gosub RECHNUM
  Gosub RECHFRA
Wend

Return


$RECHLIBS
POSD=instr(1,VALCOU,"<libs")
If POSD<>0
  POSD1=instr(POSD+1,VALCOU,">")
  POSD2=instr(POSD+1,VALCOU,"num=")
  If POSD2<>0 and POSD2<POSD1
    POSF=instr(POSD2+5,VALCOU,'"')
    If POSF>POSD2+5
      NUMMEN=val(mid$(VALCOU,POSD2+5,POSF-POSD2-5))
    Endif
  Endif
  IC=POSD1+1
  Gosub CHVALCOU
Endif
Return

$RECHID
IC=instr(1,VALCOU,"<lib id=")
If IC<>0
  Gosub CHVALCOU
  POSF=instr(10,VALCOU,'"')
  NBID+=1
  LIBID(NBID)=mid$(VALCOU,10,POSF-10)
  IC=POSF+1
  Gosub CHVALCOU
Else
  IC=max(0,len(VALCOU)-7)
  Gosub CHVALCOU
  If FINT<>1 : Goto RECHID : Endif
Endif
Return

$RECHNUM
If FINT=1 : Return : Endif
POSD1=instr(1,VALCOU,"num=")
POSD2=instr(1,VALCOU,">")
If POSD1<>0 and POSD1<POSD2
  POSF=instr(POSD1+5,VALCOU,'"')
  LIBNUM(NBID)=mid$(VALCOU,POSD1+5,POSF-POSD1-5)
Endif
IC=POSD2+1
Gosub CHVALCOU
Gosub RECHMAXNUM
Return

$RECHMAXNUM
  Local Integer IT1
  For indice=len(LIBNUM(NBID)) To 1 Step -1
   If mid$(LIBNUM(NBID),indice,1)="/"
     If val(right$(LIBNUM(NBID),indice+1))>NUMMAX 
       NUMMAX=val(right$(LIBNUM(NBID),indice+1))
       IT1=1 
       Break 1
     Endif     
   Endif
  Next indice
  If IT1=0 & val(LIBNUM(NBID))>NUMMAX : NUMMAX=val(LIBNUM(NBID)) : Endif
Return

$RECHFRA
If FINT=1 : Return : Endif
Raz ILIB,VLIB
IC=instr(1,VALCOU,"<FRA")
If IC<>0
  Gosub CHVALCOU
  POSF=instr(1,VALCOU,'>')
  If mid$(VALCOU,POSF-1,1)="/" : Return : Endif
  IC=POSF+1
$RECHFRA1
  Gosub CHVALCOU
  POSF=instr(1,VALCOU,'</FRA')
  If POSF<>0
    ILIB+=1
    VLIB(ILIB)=mid$(VALCOU,1,POSF-1)
    IC=POSF+4
    Gosub CHLIBFRA
    Gosub CHVALCOU
  Else
    ILIB+=1
    VLIB(ILIB)=mid$(VALCOU,1,len(VALCOU)-10)
    IC=len(VALCOU)-10+1
    Goto RECHFRA1
  Endif
Else
  IC=max(0,len(VALCOU)-7)
  Gosub CHVALCOU
  If FINT<>1 : Goto RECHFRA : Endif
Endif
Return

$CHVALCOU
If IC<>0
  VALCOU=right$(VALCOU,IC)
Endif
If len(VALCOU)<100
  INDT+=1
  VALCOU+=VALL1(INDT)
Endif
If IC<=7 and INDT>NBLU : FINT=1 : Endif
Return

$CHLIBFRA
Local Integer J,POS1,IREC,IPOS,IPOS1,INDI,FINDEC,ILEN
Local Char DECOMP(250)
IREC=0 : IPOS=1 : INDI=0 : IPOS1=1
While FINDEC=0
  Gosub DECLIB
  If FINDEC=1 : Break 1 : Endif
  If len(DECOMP)<100
    INDI+=1
    LIBFRA(INDI,NBID)=DECOMP
    IPOS1=len(DECOMP)+1
  Else
    POS1=instr(110,DECOMP," ")
    If POS1=0 or POS1>120
      For POS1=100 To 1 Step -1
        If mid$(DECOMP,POS1,1)=" " : Break 1 : Endif
      Next POS1
    Endif
    INDI+=1
    LIBFRA(INDI,NBID)=left$(DECOMP,POS1)
    IPOS1=POS1+1
  Endif
Wend
LIBREC(NBID)=INDI
Return

$DECLIB
DECOMP=right$(DECOMP,IPOS1)
If len(DECOMP)<200
  If IREC>0 and IPOS<len(VLIB(IREC))
     DECOMP+=right$(VLIB(IREC),IPOS)
  Endif 
  If IREC<dim(VLIB)
$DECLIB1
    IREC+=1 : IPOS=1 : ILEN=min(len(VLIB(IREC)),220-len(DECOMP))
    If ILEN>0 
      DECOMP+=left$(VLIB(IREC),ILEN)
      IPOS=ILEN+1
    Endif
    If len(DECOMP)<100 and IREC<dim(VLIB) and IPOS>len(VLIB(IREC))
      Goto DECLIB1
    Endif
  Endif
Endif
If len(DECOMP)=0 : FINDEC=1 : Endif 
Return



# ------------------------------------------------------------------------------------

Subprog EXPORTLIBS

Local Char NOMFIC(250),DIRSEP,VALL1(200),RESSOURCE(120),TEXT(200)
Local Char TLAN(GLONLAN)(1..50)
Local Integer NBLAN,NOMEN,NOMES,I,J,K,L,H,NBEXP

Case toupper(GOS(1))
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Local File APLSTD  [AST]
Local File APLSTD  [AST1]
Local File AMENLOC [AML]

Gosub INILIBW
Filter [AML] Where MENLOC>=9700 and MENLOC<9800
For [AML]
  NOMEN=[F:AML]MENLOC
  Gosub EXPORTONELIB
  NBEXP+=1
Next
Filter [AML]
Infbox("Nombre de fichiers exportés : "+num$(NBEXP))

End


$EXPORTONELIB
 Local Char NAMLIB(120)(1..500)
 Local Integer NBLIB,NLIG,DEFTRAD,ADD

 Read [AST]CLE=NOMEN;1;"FRA"
 If fstat<>0 : Return : Endif
 RESSOURCE=[F:AST]LANMES
 J=instr(1,RESSOURCE,"toAplStd")
 If J<>0
   RESSOURCE=left$(RESSOURCE,J-1)+"from"+right$(RESSOURCE,J+2)
 Endif
 Call NAMEFIC("","EXP","",RESSOURCE,NOMFIC) From INTRUTILA
 Openo NOMFIC,0 Using [CST_]
 Iomode adxifs "" Using [CST_]
 Iomode adxirs chr$(10) Using [CST_]
 Iomode adxium GUTF8 Using [CST_]
 VALL1='<?xml version="1.0" encoding="utf-8" ?>'
 Wrseq VALL1 Using [CST_]
 Gosub RECHLANM 
 VALL1='<libs  num="'+num$(NOMEN)+'" name="'+RESSOURCE+'" langs="'
 For J=1 To NBLAN
   If J>1 : VALL1+="," : Endif
   VALL1+=TLAN(J)
 Next J
 VALL1+='">'
 Wrseq VALL1 Using [CST_]
 Filter [AST1] Where LANCHP=NOMEN and LANNUM>1 and LAN="XXX" 
 NBLIB=1
 For [AST1]
   NBLIB+=1
   NAMLIB(NBLIB)=[F:AST1]LANMES
 Next
 Filter [AST1]
 For J=2 To NBLIB
   If ADD>0 : ADD-=1 : Goto EXPORTSUI : Endif
   NOMES=J
   NLIG=0
   For L=J To J+10
     If NAMLIB(L)<>NAMLIB(J) : Break 1 : Endif
     NLIG+=1
   Next L
   VALL1='  <lib id="'+NAMLIB(J)+'" num="'
   For H=1 To NLIG
     If H>1 : ADD+=1 : VALL1+="/" : Endif
     VALL1+=num$(NOMES+H-1)
   Next H
   VALL1+='">'
   Wrseq VALL1 Using [CST_]
   Gosub SERW_ENR
   VALL1='  </lib>'
   Wrseq VALL1 Using [CST_]
$EXPORTSUI
 Next J

 VALL1="</libs>"
 Wrseq VALL1 Using [CST_]
 Openo Using [CST_]
Return


$SERW_ENR
For I=1 To NBLAN
  DEFTRAD=0
  VALL1='    <'+TLAN(I)+'>'
  For K=1 To NLIG
    Read [AST]CLE=NOMEN;NOMES+K-1;TLAN(I)
    If TLAN(I)<>"FRA" and (fstat<>0 or vireblc([F:AST]LANMES,2)="") and (DEFTRAD=1 or K=1)
      Read [AST]CLE=NOMEN;NOMES+K-1;"FRA"
      DEFTRAD=1
    Endif
    If fstat<>0 : [F:AST]LANMES="" : Endif
    TEXT=[F:AST]LANMES
    Call MODVAL(TEXT) From INTRUTILA
    VALL1+=TEXT
    If K<>NLIG : Wrseq VALL1 Using [CST_] : Raz VALL1 : Endif
  Next K
  VALL1+='</'+TLAN(I)+'>'
  Wrseq VALL1 Using [CST_]
Next I
Return

#  Recherche la liste des langues du menu NOMEN
$RECHLANM
  Filter [AST] Where LANCHP=NOMEN and LANNUM=2 and LAN<>"XXX" 
  Raz NBLAN,TLAN
  For [AST]
    If [F:AST]LANMES<>""
      NBLAN+=1
      TLAN(NBLAN)=[F:AST]LAN
    Endif
  Next
  Filter [AST]
Return
