Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZISM)")>indice
 [M]ISM(indice) = VALEUR
 Affzo ZISM(indice)
Endif
Gosub _AFF
End

Subprog S_ISM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "HSH"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ISM(VALEUR)
Variable Char    VALEUR()
Call OBJET("HSH",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_ISM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HSH"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ISM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HSH",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZISM
Onevent BEFORE_AREA Gosub AV_ZISM From W1ITF5
Return

$AV_ZISM
Call LECTEXTRA(zc,"HANDLING","DESAXX",num$([M]ISM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_REDMODFLG
Onevent INIT_AREA Call D_REDMODFLG(zc) From W1ITF5
Onevent BEFORE_INPUT Call AS_REDMODFLG(zc) From W1ITF5
Return

Subprog D_REDMODFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]REDMODFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_REDMODFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ITMTOLPOS
Onevent AFTER_CHANGE Gosub AMM_ITMTOLPOS From W1ITF5
Onevent CONTROL Call C_ITMTOLPOS(zc) From W1ITF5
Return

Subprog C_ITMTOLPOS(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_ITMTOLPOS
Call AM_ITMTOLPOS(zc)
If !mkstat & GOBJET
 zoncou = "ITMTOLPOS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ITMTOLPOS(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_ITMTOLPOS(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "ITMTOLPOS" : GZNUM = 42018 : Endif
Gosub _AFF
End

$ON_ITMTOLNEG
Onevent CONTROL Call C_ITMTOLNEG(zc) From W1ITF5
Onevent AFTER_CHANGE Gosub AMM_ITMTOLNEG From W1ITF5
Return

Subprog C_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_ITMTOLNEG(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "ITMTOLNEG" : GZNUM = 42020 : Endif
Gosub _AFF
End

$AMM_ITMTOLNEG
Call AM_ITMTOLNEG(zc)
If !mkstat & GOBJET
 zoncou = "ITMTOLNEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_ITMTOLNEG(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "ITMTOLNEG" : GZNUM = 42020 : Endif
Gosub _AFF
End

$ON_OLD_ISM
Return

$CHG_STY
Return


