Onevent AFTER_CHANGE Gosub AMM_WGRACS From W1ITF5
Return

Subprog AS_WGRACS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_WGRACS(zc) From W1ITF5
Onkey 144 Titled GBOUTP Call P_WGRACS(zc) From W1ITF5
Onkey 146 Titled GBOUTA Call SA_WGRACS(zc) From W1ITF5
Gosub _AFF
End

Subprog C_WGRACS(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ACS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "WGRACS" : GZNUM = 729 : Endif
If !mkstat
 ## Action CONTACC
 Call CONTACC(VALEUR) From SUBACS
 If mkstat : GERR = 1 : GZONE = "WGRACS" : GZNUM = 729 : Endif
Endif
Gosub _AFF
End

$AMM_WGRACS
Call AM_WGRACS(zc)
If !mkstat & GOBJET
 zoncou = "WGRACS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WGRACS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZWGRACS)")>indice
 [M]WGRACS(indice) = VALEUR
 Affzo ZWGRACS(indice)
Endif
Gosub _AFF
End

Subprog S_WGRACS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELACC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELACC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELACC","SUBACS","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_WGRACS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ACS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WGRACS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ACS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

