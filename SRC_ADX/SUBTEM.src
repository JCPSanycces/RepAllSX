#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## SFT Team maintenance
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "VERIF_CRE"    : Gosub VERIF_CRE
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "EXEACT"       : Gosub EXEACT
  When "LIENS"        : Gosub LIENS
  When Default
Endcase

Return

######################################################################################
$OUVRE

  If !clalev([F:TMA])       : Local File TABMAT     [TMA]       : Endif
  If !clalev([F:SFTX])      : Local File SFTTXN     [SFTX]      : Endif
  If !clalev([F:SFTTH2])    : Local File SFTTEMH    [SFTTH2]     : Endif

  Local Integer  DELETED_EMP(1..)

Return

######################################################################################
$SETBOUT

  #testing
  Affzo [M:SFTT]10

Return

######################################################################################
$VERIF_CRE

  Local Integer I

  If [M:SFTT]NBLIG = AVOID.AINT
    GERR = 1 : GMESSAGE = mess(17,170,1) : Return    # No line entered
  Else
    For I = 0 To [M:SFTT]NBLIG - 1
      Call EMPLOYEE_VAL([M:SFTT]EMPNUM(I), "C")
    Next
  Endif

Return

######################################################################################
$EXEACT

  Local Integer I
  Local Integer ERRNUM
  Local Char    ERRMSG(255)

  Case BOUT
    When "E" #Save
      If maxtab(DELETED_EMP) > 0
        For I = 1 To maxtab(DELETED_EMP)

          #If Employee remains in the grid then skip it
          If find(DELETED_EMP(I), [M:SFTT]EMPNUM)
            Goto NEXT_EMP
          Endif

          If func CHECK_OPEN_ACTIVITIES([M:SFTT]TEAMNUM,DELETED_EMP(I)) = [V]CST_AYES
            Call STOP_OPEN_ACTIVITIES([M:SFTT]TEAMNUM,DELETED_EMP(I),ERRNUM,ERRMSG) From SFTLIB
            If ERRNUM
              GERR=1 : GMESSAGE = ERRMSG
              mkstat = 2
              Return
            Endif
          Endif

          Call REMOVE_EMPLOYEE([M:SFTT]TEAMNUM,DELETED_EMP(I),ERRNUM,ERRMSG)
          If ERRNUM
            GERR=1 : GMESSAGE = ERRMSG
            mkstat = 2
            Return
          Endif
NEXT_EMP:
        Next
        Raz DELETED_EMP()

        If [M:SFTT]TEAMNUM <> 0 and [M:SFTT]EMPNUM = 0
          If func CHECK_OPEN_ACTIVITIES([M:SFTT]TEAMNUM,[M:SFTT]TEAMNUM) = [V]CST_AYES
            Call STOP_OPEN_ACTIVITIES([M:SFTT]TEAMNUM,[M:SFTT]TEAMNUM,ERRNUM,ERRMSG) From SFTLIB
            If ERRNUM
              GERR=1 : GMESSAGE = ERRMSG
              mkstat = 2
              Return
            Endif
          Endif
        Endif
      Endif
  Endcase

Return

######################################################################################
LIENS

  #Initialize variable
  Raz DELETED_EMP()

Return

######################################################################################
$APRES_MODIF

 Case zoncou
    When "NBLIG"
      # a new line was added
      If status=82 | status=73
        Actzo [M:SFTT]EMPNUM(nolign-1)
      Elsif status=65
        Gosub DEL
      Endif
  Endcase

Return

######################################################################################
Subprog C_TEAMNUM(VALEUR)
Variable Decimal VALEUR

  # Validate if the team exist and active
  Read [TMA]TMA0=VALEUR
  If !fstat
    # Team?
    If [F:TMA]EMPTYP <> 2     # Detail team
      GERR=1 : GMESSAGE =  func AFNC.MES1(mess(96,2422,1), num$(VALEUR))  # Employee type must be a Detail team
      mkstat = 2
    Endif

    # Team active?
    If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
      GERR=1 : GMESSAGE =  num$(VALEUR) - " : " + mess(2,126,1)
      mkstat = 2
      End
    Endif
  Else    # Team not found
    GERR=1 : GMESSAGE =  num$(VALEUR) - " : " + mess(23,100,1)
    mkstat = 2
    End
  Endif

End

######################################################################################
Subprog AM_TEAMNUM(VALEUR)
Variable Decimal VALEUR

    Filter [F:SFTTM] Where TEAMNUM = VALEUR
    Look [F:SFTTM] First
    Filter [F:SFTTM]
    If fstat    # Initialize grid
      [M:SFTT]TEAMNUM = VALEUR
      Raz [M:SFTT]NBLIG
      Effzo 10
    Endif

End

######################################################################################
Subprog AV_EMPNUM(VALEUR)
Variable Decimal VALEUR

  If VALEUR=0
    Actzo [M:SFTT]EMPNUM(nolign-1)
  Else
    Diszo [M:SFTT]EMPNUM(nolign-1)
  Endif

End

######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal  VALEUR

  # Validate employee id
  Call EMPLOYEE_VAL(VALEUR, "A")

End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  # set the create flag so that the save action knows to write a new record
  [M:SFTT]CREFLG(nolign-1) = [V]CST_AYES

  If VALEUR<>0
    Diszo [M:SFTT]EMPNUM(nolign-1)
  Endif

End

######################################################################################
Subprog EMPLOYEE_VAL(IEMPNUM, ATYPE)
Value Integer   IEMPNUM
Value Char      ATYPE

  Local Char      EMPSHIFT(6), EMPDEFFCY(5)
  Local Integer   ERRNUM
  Local Char      ERRMSG(125)
  Local Integer   RET

  # Validate if the employee exist and active
  Read [TMA]TMA0=IEMPNUM
  If !fstat
    # Can't be any team types
    If [F:TMA]EMPTYP <> 1     # Only employee allowed
      GERR=1 : GMESSAGE = func AFNC.MES1(mess(97,2422,1), num$(IEMPNUM))  # Employee type must be Employee to be added
      mkstat = 2
      End
    Endif

    # Employee active?
    If func SFTLIB.EMPLOYEEACTIVE(IEMPNUM) = [V]CST_ANO
      GERR=1 : GMESSAGE =  num$(IEMPNUM) - " : " + mess(2,126,1)   # Invalid record
      mkstat = 2
      End
    Endif
  Else    # Employee not found
    GERR=1 : GMESSAGE =  num$(IEMPNUM) - " : " + mess(23,100,1)    # Record does not exist
    mkstat = 2
    End
  Endif

  # verify member not already on the team
  # ...member already on the current grid
  If ATYPE = "A"      # Validate only when add a record not when create
    If find(IEMPNUM, [M:SFTT]EMPNUM)
      GERR=1 : GMESSAGE = func AFNC.MES1(mess(98,2422,1), num$(IEMPNUM)) # Employee already part of the team
      mkstat = 2
      End
    Endif
  Endif

  # ...or member already on a Team table
  Look [SFTTM]SFTTM1 = [M:SFTT]TEAMNUM;EMPNUM=IEMPNUM
  If !fstat
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(98,2422,1), num$(IEMPNUM)) # Employee already part of the team
    mkstat = 2
    End
  Endif

  # verify that the employee shift matches team shift
  # 1-EMPSHIFT = AVOID.ACHAR & TEMSHIFT <> AVOID.ACHAR
  # 2-EMPSHIFT <> AVOID.ACHAR & TEMSHIFT = AVOID.ACHAR
  # 3-EMPSHIFT <> AVOID.ACHAR & TEMSHIFT <> AVOID.ACHAR & EMPSHIFT <> TEMSHIFT
  EMPSHIFT = [F:TMA]SHIFT
  EMPDEFFCY = [F:TMA]DEFFCY
  Read [TMA]TMA0 = [M:SFTT]TEAMNUM
  If !fstat
    If EMPSHIFT<>[F:TMA]SHIFT
      GERR=1 : GMESSAGE = mess(99,2422,1)       # Shift code assigned to the employee does not match team shift code
      mkstat = 2
      End
    Endif

    If ATYPE = "A"
      If EMPDEFFCY<>[F:TMA]DEFFCY
        GERR=3 : GMESSAGE = mess(120,2422,1)    # Site assigned to the employee does not match team site
      Endif
    Endif
  Endif

 # verify member not on another team
  Filter [SFTTM] Where TEAMNUM <> [M:SFTT]TEAMNUM & EMPNUM=IEMPNUM
  Read [SFTTM] First
  Filter [SFTTM]
  If !fstat
    # prompt if the user should be removed from the current team and added to this one
    Call OUINON (func AFNC.MES2(mess(106,2422,1), num$([F:SFTTM]TEAMNUM),num$([F:SFTTM]TEAMNUM)) ,RET) From GESECRAN
    If RET = [V]CST_AYES
      If func CHECK_OPEN_ACTIVITIES(AVOID.AINT,IEMPNUM) = [V]CST_AYES        # if there are activities out there, prompt to stop them all
        Call OUINON (mess(104,2422,1), RET) From GESECRAN    # Employee has open activities.  Do you want to stop all of the employee’s activities?
        If RET <> [V]CST_AYES
          mkstat = 2
          End
        Endif

        Call STOP_OPEN_ACTIVITIES(AVOID.AINT,IEMPNUM,ERRNUM,ERRMSG) From SFTLIB
        If ERRNUM
          GERR=1 : GMESSAGE = ERRMSG
          mkstat = 2
          End
        Endif
      Endif

      Call REMOVE_EMPLOYEE([F:SFTTM]TEAMNUM,IEMPNUM,ERRNUM,ERRMSG)
      If ERRNUM
        GERR=1 : GMESSAGE = ERRMSG
        mkstat = 2
        End
      Endif

    Else
      mkstat = 2
      End
    Endif
  Else
    # verify member has no open individual transactions
    If func CHECK_OPEN_ACTIVITIES(AVOID.AINT,IEMPNUM) = [V]CST_AYES    # if there are activities out there, prompt to stop them all
      Call OUINON (mess(104,2422,1),RET) From GESECRAN    # Employee has open activities.  Do you want to stop all of the employee’s activities?
      If RET <> [V]CST_AYES    # No clock out
          mkstat = 2
          End
      Endif

      Call STOP_OPEN_ACTIVITIES(AVOID.AINT,IEMPNUM,ERRNUM,ERRMSG) From SFTLIB
      If ERRNUM
        GERR=1 : GMESSAGE = ERRMSG
        mkstat = 2
        End
      Endif

    Endif
  Endif

End

######################################################################################
# Check for employee open activities
######################################################################################
Funprog CHECK_OPEN_ACTIVITIES(ITEAMNUM, IEMPNUM)
Value    Integer ITEAMNUM
Value    Integer IEMPNUM

  Local Integer OPEN
  Local Char CRIT(255)

  # Default to No
  [L]OPEN = [V]CST_ANO

  Raz OPEN

  CRIT -= 'EMPNUM =' + num$(IEMPNUM)

  If ITEAMNUM<>AVOID.AINT
    CRIT -= '& TEAMNUM =' + num$(ITEAMNUM)
  Endif

  Filter [F:SFTX] Where SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM & evalue(CRIT)
  Look [F:SFTX] First
  Filter [F:SFTX]
  If !fstat
    [L]OPEN = [V]CST_AYES
  Endif

End OPEN

###################################################################
# Remove employee id from Team table and add to Team history table
###################################################################
Subprog REMOVE_EMPLOYEE(ITEAMNUM,IEMPNUM,ERRNUM,ERRMSG)
Value    Integer  ITEAMNUM
Value    Integer  IEMPNUM
Variable Integer  ERRNUM
Variable Char     ERRMSG

  Local Date      CURDATE

  [L]CURDATE  = date$

  Raz ERRNUM

  Trbegin [SFTTM],[SFTTH2]

  Read [SFTTM]SFTTM1 = ITEAMNUM;IEMPNUM
  If fstat
      ERRNUM = [V]CST_AERROR
      ERRMSG = mess(913,9137,1) - num$(ITEAMNUM) - num$(IEMPNUM)    # File reading failed
      Goto GETOUT
  Endif

  Raz [F:SFTTH2]

  [F:SFTTH2] = [F:SFTTM]
  [F:SFTTH2]ENDDAT = [L]CURDATE
  Call NEXT_TEAM_SEQ(ITEAMNUM,IEMPNUM,[F:SFTTH2]TEAMSEQ) From SFTLIB

  Write [SFTTH2]
  If fstat
      ERRNUM = [V]CST_AERROR
      ERRMSG = mess(912,9137,1) - num$(ITEAMNUM) - num$(IEMPNUM) - num$([F:SFTTH2]TEAMSEQ)  # File writing failed
      Goto GETOUT
  Endif

  Delete [F:SFTTM] Curr
  If fstat
      ERRNUM = [V]CST_AERROR
      ERRMSG= func AFNC.MES1(mess(129,2260,1), num$(ITEAMNUM) - num$(IEMPNUM)) # Unable to delete
      Goto GETOUT
  Endif

GETOUT:
  If ERRNUM
      Rollback
  Else
      Commit
  Endif

End

######################################################################################
$DEL

  Local Integer RET
  #OK = 1

  # verify member on the team
  Look [SFTTM]SFTTM1 = [M:SFTT]TEAMNUM;[M:SFTT]EMPNUM(nolign-1)
  If fstat
      Return
  Endif

  # make sure no open activities exist
  If func CHECK_OPEN_ACTIVITIES([M:SFTT]TEAMNUM,[M:SFTT]EMPNUM(nolign-1)) = [V]CST_AYES    # if there are activities out there, prompt to stop them all
    Call OUINON (mess(107,2422,1),RET) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
    If RET <> [V]CST_AYES
      mkstat = 2
      Return
    Endif
  Endif

  I = maxtab(DELETED_EMP)

  If I > 0
    If find([M:SFTT]EMPNUM(nolign-1), DELETED_EMP)
      Return
    Endif
  Endif

  DELETED_EMP(I+1) = [M:SFTT]EMPNUM(nolign-1)

Return
######################################################################################

