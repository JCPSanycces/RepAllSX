#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIPTCDUP                                                        #
# Manages Duplicate class for EDIPTC                                          #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "PTCCODNEW"
    Case [L]ARULE
      When "CONTROL"   : Gosub PTCCODNEW_CONTROL
      When "PROPAGATE" : Gosub PTCCODNEW_PROPAGATE
    Endcase
  Endcase
Return

####################################################################

$PTCCODNEW_CONTROL
  If this.PTCCODNEW <> ""
    this.PTCCODNEW = func EDILIBA.FORMATVAL("PTCCOD", this.PTCCODNEW)
  Endif
Return

$PTCCODNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("PTCCODNEW")

  If this.PTCCODNEW <> ""
    If func CTRL_EXIST_PTC(this.PTCCODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("PTCCODNEW",mess(45,7779,1)-":"-this.PTCCODNEW,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$AREAD_AFTER
  If this.PTCCOD <> ""
    Local File EDIPTC [EPT]
    Read [EPT]EPT0 = this.PTCCOD
    If !fstat
      this.PTCDES    = [EPT]PTCDES
      this.PTCDESNEW = [EPT]PTCDES-"(Copy)"
    Else
      this.PTCDES    = ""
      this.PTCDESNEW = ""
    Endif
    LogicClose File [EPT]
  Endif
Return

####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.PTCCODNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_PTC(this.PTCCODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("PTCRELNEW",mess(45,7779,1)-":"-this.PTCCODNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_PTC(this.PTCCOD, this.PTCCODNEW, this.PTCDES, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.PTCCODNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.PTCCODNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

####################################################################

Funprog CTRL_EXIST_PTC(WPTCCOD)
Value Char WPTCCOD

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WPTCCOD <> ""
    Local File EDIPTC [EPT]
    Read [EPT]EPT0 = WPTCCOD
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EPT]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################
Funprog COPY_PTC(WPTCCOD, WPTCCOD_NEW, WPTCDES_NEW, WERR)
Value Char WPTCCOD
Value Char WPTCCOD_NEW
Value Char WPTCDES_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WNBREG #X3-112620 EDI protocol duplication (JUCON 14/10/18)

  If WOK = [V]CST_AOK
    Local File EDIPTCD [EPTD]
    Filter [EPTD] Where PTCCOD = WPTCCOD
    WNBREG=rowcount([EPTD] )#X3-112620 EDI protocol duplication (JUCON 14/10/18)

    For [EPTD]
      If WOK = [V]CST_AOK
        Local File EDIPTCD [C_EPTD]
        Trbegin [C_EPTD]
        [C_EPTD]          = [EPTD]
        [C_EPTD]PTCCOD    = WPTCCOD_NEW
        Write [C_EPTD]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIPTCD ("+mess(3,40,1)-num$([C_EPTD]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EPTD]
      Else
      #
      Endif
    Next

    If WNBREG<10:  Gosub CREATE_REC :Endif   #X3-112620 EDI protocol duplication (JUCON 14/10/18)

    Filter [EPTD]
    LogicClose File [EPTD]

    #Ini X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
    Local File EDIPTCM [EPTM]
    Filter [EPTM] Where PTCCOD = WPTCCOD
    For [EPTM]
      If WOK = [V]CST_AOK
        Local File EDIPTCM [C_EPTM]
        Trbegin [C_EPTM]
        [C_EPTM]          = [EPTM]
        [C_EPTM]PTCCOD    = WPTCCOD_NEW
        Write [C_EPTM]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIPTCM ("+mess(3,40,1)-num$([C_EPTM]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EPTM]
      Else
      #
      Endif
    Next
    Filter [EPTM]
    LogicClose File [EPTM]
    #End X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
  Endif

  If WOK = [V]CST_AOK
    Local File EDIPTC [EPT]
    Read [EPT]EPT0 = WPTCCOD
    If !fstat
      Local File EDIPTC [C_EPT]
      Trbegin [C_EPT]
      [C_EPT]          = [EPT]
      [C_EPT]VALID     = [V]CST_ANO
      [C_EPT]FLGACT    = [V]CST_ANO
      [C_EPT]CACHEUUID = NullUuid()
      [C_EPT]PTCDES    = WPTCDES_NEW #[C_EPT]PTCDES-"(Copy)"
      [C_EPT]PTCCOD    = WPTCCOD_NEW
      Write [C_EPT]
      If !fstat
        Commit
      Else
#        WOK = 3#[V]CST_AERROR
        WOK = [V]CST_AERROR
        WERR = "EDIPTC ("+mess(1,7983,1)+")"
        Rollback
      Endif
      LogicClose File [C_EPT]
    Else
#      WOK = 4#[V]CST_AERROR
      WOK = [V]CST_AERROR
      WERR = "EDIPTC ("+mess(7,7983,1)+")"
    Endif
    Filter [EPT]
    LogicClose File [EPT]
  Endif

End WOK

#Ini X3-112620 EDI protocol duplication (JUCON 14/10/18)
$CREATE_REC
  Local Char WLINCOD(20)(3)
  WLINCOD(0)="DIRSIGNATURE"
  WLINCOD(1)="DIRATTACHMENT"
  WLINCOD(2)="DIRPRINTSERVER"

  Local File EDIPTCD [C_EPTD]
  [C_EPTD]          = [EPTD]
  [C_EPTD]PTCCOD    = WPTCCOD_NEW
  If WNBREG=7
    For I=0 To 2
      [C_EPTD]NUMLIN       = WNBREG+I+1
      [C_EPTD]PTCLINCOD    = WLINCOD(I)
      [C_EPTD]PTCLINVALTYP = "FIC"
      Gosub WRITE_REC
    Next
  Else
    For I=1 To 2
      [C_EPTD]NUMLIN       = WNBREG+I
      [C_EPTD]PTCLINCOD    = WLINCOD(I)
      [C_EPTD]PTCLINVALTYP = "FIC"
      Gosub WRITE_REC
    Next
  Endif
  LogicClose File [C_EPTD]
Return

$WRITE_REC
    Trbegin [C_EPTD]
    Write [C_EPTD]
    If !fstat
      Commit
    Else
      WOK = [V]CST_AERROR
      WERR = "EDIPTCD ("+mess(3,40,1)-num$([C_EPTD]NUMLIN)+")"
      Rollback
    Endif
Return
#End X3-112620 EDI protocol duplication (JUCON 14/10/18)

