#<AdxTL>@(#)0.0.0.0 $Revision$

Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

  Local Char CCMCHGMAN(30)

  If (clalev([AUS]) = 0) : Local File AUTILIS [AUS] : Endif

  Read [AUS]CODUSR = VALEUR

  If (fstat = 0)
    Call PARAMUTIL("CCMCHGMAN", CCMCHGMAN, [F:AUS]USR, "") From SUBAUS
    If (CCMCHGMAN <> "2")
      OK = 0
      MESSAGE = func ASYRFNC.MES1(mess(13,2038,1),VALEUR)
      GMESSAGE = MESSAGE
      GERR = 1
    Endif
  Elsif (VALEUR <> "")
    OK = 0
    MESSAGE = func ASYRFNC.MES1(mess(14,2038,1),VALEUR)
    GMESSAGE = MESSAGE
    GERR = 1
  Endif

  Close Local File [AUS]

End

