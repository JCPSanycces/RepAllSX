#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################
##########################################################################################
###                                                                                    ###
###             TRANSPORT DOCUMENT COMMUNICATION VIA WEB SERVICE                       ###
###                                                                                    ###
##########################################################################################
##########################################################################################
Subprog SENDDTTOAT(DTNUM, DOCTYP, STAT)
Value    Char    DTNUM
Value    Integer DOCTYP
Variable Integer STAT

STAT = 0

Gosub DECL_VARS

Gosub OPEN_TABLES

If GTRACE = ""
  Call OUVRE_TRACE(mess(102,7711,1)+':'-DTNUM) From LECFIC
  [L]PRIVTRACE = 1
Else
  Call ECR_TRACE(mess(102,7711,1)+':'-DTNUM,0) From GESECRAN
Endif

Gosub SET_VARS
If !OK : STAT = 1 : Gosub TRACE : End : Endif

Gosub CTR_VALS
If !OK : STAT = 1 : Gosub TRACE : End : Endif

Gosub SEND_DT
If !OK : STAT = 1 : Gosub TRACE : End : Endif

Gosub UPD_DT_STAT
If !OK : STAT = 1 : Gosub TRACE : End : Endif

MESSAGE = mess(103,7711,1)
Gosub TRACE

End
##########################################################################################
##########################################################################################
$DECL_VARS

Local Char      PWSURL(250)
Local Char      PUSERNAME(15)
Local Char      PPASSWORD(15)
Local Integer   PTAXREGNUMBE
Local Char      PCOMPANYNAM(60)
Local Char      PADDRESSDET(60)
Local Char      PCITY(60)
Local Char      PPOSTALCODE(60)
Local Char      PCOUNTRY(60)
Local Char      P3EECNUM(20)     #
Local Char      P3EECNUMC(20)    #customer
Local Char      P3EECNUMS(20)    #supplier
Local Char      P3NAM(60)
Local Char      P3ADDRESSDET(60)
Local Char      P3CITY(60)
Local Char      P3POSTALCODE(60)
Local Char      P3COUNTRY(60)
Local Char      PVEHICLEID(20)
Local Char      PMOVTYP(2) : PMOVTYP = "GT"

#Line arrays
Local Integer ARRAYDIM
Case [L]DOCTYP
  When 2
    ARRAYDIM = func AFNC.ACTIV("SDH")
  When 3,4,5
    ARRAYDIM = func AFNC.ACTIV("SRH")
  When 6,7,8
    ARRAYDIM = func AFNC.ACTIV("SLS")
  When 9
    ARRAYDIM = func AFNC.ACTIV("PNH")
  When 10
    ARRAYDIM = func AFNC.ACTIV("TNH")
Endcase

Local Char      PORIGON(255)(ARRAYDIM+20)    #+20 for invoicing elements
Local Char      PAPRDDES(30)(ARRAYDIM+20)    #+20 for invoicing elements
Local Decimal   PAQTY(ARRAYDIM+20)           #+20 for invoicing elements
Local Char      PAUNIT(5)(ARRAYDIM+20)       #+20 for invoicing elements
Local Decimal   PAUNITPRICE(ARRAYDIM+20)     #+20 for invoicing elements

#bundle
Local Integer   STATUSCODE
Local Char      MODULE(100)  : MODULE = 'bundle-sage-pt-at/atCommunication'
Local Char      FONCTION(30) : FONCTION = 'sendDT'
Local Char      MODE(10)     : MODE = 'wait'
Local Clbfile   ARGUMENTS(8)
Local Char      RETURNS(255)
Local Clbfile   RESHEAD(0)
Local Clbfile   RESBODY(0)

#bundle return values
Local Char      ATDCOD(200)
Local Integer   RETCOD
Local Char      RETCODSTR(30)
Local Char      RETMES(250)
Local Char      AESKEY(100)
Local Char      DATTIM(30)

#working variables
Local Char      ATAUS(GLONAUS)
Local Char      AUSPASS(20)
Local Integer   I, J, LINEC
Local Char      DOCTYPDKD(10)
Local Char      DATCTR(20)
Local Char      FCY(GLONFCY)
Local Char      TZPAR(10)

Local Integer   OK        : OK      = 1
Local Char      MESSAGE(255)
Local Shortint  PRIVTRACE
Local Char      DBGMOD(1)
Local Char      TESMOD(1)
Local Char      SAFTPEXPCTR(1)

#SAF-T code related
Local Integer  SAFTTYPE
Local Char     SOC(GLONCPY)
Local Char     SAFTVER(10)
Local Shortint VENEXEFLG     #Para indicar se a taxa é isenta nas v
Local Tinyint  ISSAFTVERCURRENT : ISSAFTVERCURRENT = 1
Local Char     SAFPRIRNC(30)
Local Decimal  SAFPRIRND
Local Char     SAFTPRDKITACTIVE(1)
#to discard
Local Char DISCARD1(1), DISCARD2(1)
#Footer elements
Local Integer DIMSVV, DIMSVF : DIMSVV = func AFNC.ACTIV("SVA")  : DIMSVF = func AFNC.ACTIV("SFIV")

Gosub DECLARE_VARS   From SAFTGENPORMG   #transport document variables (common to saf-t)

Return
##########################################################################################
##########################################################################################
$OPEN_TABLES

Local File AUTILIS     [PTAUS]
Local File COMPANY     [PTCPY]
Local File BPADDRESS   [PTADC]
Local File BPARTNER    [PTBPR]
Local File DKSDATA     [PTDKD]
Local File SALTRS      [PTSLT]
Local File FACILITY    [PTFCY]
Local File COMPANY     [CPY2]

Gosub DECLARE_TABLES From SAFTGENPORMG   #transport document tables (common to saf-t)

Return
##########################################################################################
##########################################################################################
$SET_VARS

#SAF-T code related
[L]SAFTTYPE = 8

#posicionar na company
Case [L]DOCTYP
  When 2
    Read [F:PTSDH]SDH0 = [L]DTNUM
    If fstat :  OK = 0 : MESSAGE = [L]DTNUM-mess(178,199,1) : Return : Endif
    Read [F:PTCPY]CPY0 = [F:PTSDH]CPY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(104,7711,1), [F:PTSDH]CPY) : Return : Endif
    Read [F:PTFCY]FCY0 = [F:PTSDH]STOFCY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(105,7711,1), [F:PTSDH]CPY) : Return : Endif
    Call LEC_TSD_LEG([F:PTFCY]LEG, [F:PTSDH]SDHTYP,STAT) From TRTLECLEG
    If find([F:TSD]RECTYP, 2, 3)
        OK = 0 : MESSAGE = func AFNC.MES1(mess(107,7711,1), [L]DTNUM) : Return
    Endif
    If [F:TSD]SAFTTRNTYP = 3
        OK = 0 : MESSAGE = func AFNC.MES1(mess(108,7711,1), [L]DTNUM) : Return
    Endif
    [L]DOCTYPDKD = [F:PTSDH]SDHTYP
  When 3,4,5
    Read [F:PTSRH]SRH0 = [L]DTNUM
    If fstat :  OK = 0 : MESSAGE = [L]DTNUM-mess(178,199,1) : Return : Endif
    Read [F:PTCPY]CPY0  = [F:PTSRH]CPY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(104,7711,1), [F:PTSRH]CPY) : Return : Endif
    Read [F:PTFCY]FCY0 = [F:PTSRH]STOFCY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(105,7711,1), [F:PTSRH]CPY) : Return : Endif
    Call LEC_TRE_LEG([F:PTFCY]LEG, [F:PTSRH]SRHTYP,STAT) From TRTLECLEG
    If find([F:TRE]RECTYP, 2, 3)
        OK = 0 : MESSAGE = func AFNC.MES1(mess(107,7711,1), [L]DTNUM) : Return
    Endif
    If [F:TRE]SAFTTRNTYP = 3
        OK = 0 : MESSAGE = func AFNC.MES1(mess(108,7711,1), [L]DTNUM) : Return
    Endif
    # BRBAN 07/04/2015 107403 - [F:TRE]COMAT must be 2
    If [F:TRE]COMAT<>2
      OK = 0 : MESSAGE = mess(29,107,1) : Return
    Endif
    #-
    [L]DOCTYPDKD = [F:PTSRH]SRHTYP
  When 6,7,8
    Read [F:PTSGH]SGH0 = [L]DTNUM
    If fstat :  OK = 0 : MESSAGE = [L]DTNUM-mess(178,199,1) : Return : Endif
    Read [F:PTFCY]FCY0  = [F:PTSGH]STOFCY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(105,7711,1), [F:PTSGH]STOFCY) : Return : Endif
    Read [F:PTCPY]CPY0  = [F:PTFCY]LEGCPY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(104,7711,1), [F:PTFCY]LEGCPY) : Return : Endif
    Call LEC_TSG_LEG([F:PTFCY]LEG, [F:PTSGH]SGHTYP,STAT) From TRTLECLEG
    If find([F:TSG]RECTYP, 2, 3)
        OK = 0 : MESSAGE = func AFNC.MES1(mess(107,7711,1), [L]DTNUM) : Return
    Endif
    If [F:TSG]SAFTTRNTYP = 3
        OK = 0 : MESSAGE = func AFNC.MES1(mess(108,7711,1), [L]DTNUM) : Return
    Endif
    [L]DOCTYPDKD = [F:PTSGH]SGHTYP
  When 9
    Read [F:PTPNH]PNH0 = [L]DTNUM
    If fstat :  OK = 0 : MESSAGE = [L]DTNUM-mess(178,199,1) : Return : Endif
    Read [F:PTCPY]CPY0  = [F:PTPNH]CPY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(104,7711,1), [F:PTPNH]CPY) : Return : Endif
    Read [F:PTFCY]FCY0 = [F:PTPNH]PNHFCY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(105,7711,1), [F:PTPNH]PNHFCY) : Return : Endif
    Call LEC_TPN_LEG([F:PTFCY]LEG, [F:PTPNH]PNHTYP,STAT) From TRTLECLEG
    If find([F:TPN]RECTYP, 2, 3)
        OK = 0 : MESSAGE = func AFNC.MES1(mess(107,7711,1), [L]DTNUM) : Return
    Endif
    If [F:TPN]SAFTTRNTYP = 3
        OK = 0 : MESSAGE = func AFNC.MES1(mess(108,7711,1), [L]DTNUM) : Return
    Endif
    [L]DOCTYPDKD = [F:PTPNH]PNHTYP
  When 10
    Read [F:PTTNH]TNH0 = [L]DTNUM
    If fstat :  OK = 0 : MESSAGE = [L]DTNUM-mess(178,199,1) : Return : Endif
    Read [F:PTCPY]CPY0  = [F:PTTNH]CPY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(104,7711,1), [F:PTTNH]CPY) : Return : Endif
    Read [F:PTFCY]FCY0 = [F:PTTNH]FCY
    If fstat :  OK = 0 : MESSAGE = func AFNC.MES1(mess(105,7711,1), [F:PTTNH]FCY) : Return : Endif
    Call LEC_TTN_LEG([F:PTFCY]LEG, [F:PTTNH]TNHTYP,STAT) From TRTLECLEG
    If find([F:TTN]RECTYP, 2, 3)
        OK = 0 : MESSAGE = func AFNC.MES1(mess(107,7711,1), [L]DTNUM) : Return
    Endif
    If [F:TTN]SAFTTRNTYP = 3
        OK = 0 : MESSAGE = func AFNC.MES1(mess(108,7711,1), [L]DTNUM) : Return
    Endif
    [L]DOCTYPDKD = [F:PTTNH]TNHTYP
Endcase

[L]SOC = [F:PTCPY]CPY

#check if the document was already communicated
Read [F:PTDKD]DKD0 = "SAFT-PT";[L]DOCTYPDKD;[L]DTNUM
If !fstat
  If [F:PTDKD]ATDTCOD <> ""
    OK = 0
    MESSAGE = func AFNC.MES1(mess(109,7711,1), [L]DTNUM)
    Return
  Endif
Else
  OK = 0
  MESSAGE = func AFNC.MES1(mess(110,7711,1), [L]DTNUM)
  Return
Endif

##test mode and debug mode parameters
Call PARAM([F:PTCPY]CPY, "DBGCOMAT", [L]DBGMOD) From ADOVAL
Call PARAM([F:PTCPY]CPY, "TSTCOMAT", [L]TESMOD) From ADOVAL

If [L]TESMOD = "2"
   PWSURL     = "https://servicos.portaldasfinancas.gov.pt:701/sgdtws/documentosTransporte"
Else
   PWSURL     = "https://servicos.portaldasfinancas.gov.pt:401/sgdtws/documentosTransporte"
Endif

#AT user
Call PARAM([F:PTCPY]CPY, "USRCOMAT", [L]ATAUS) From ADOVAL

If [L]ATAUS = ""
  OK = 0 : MESSAGE = mess(111,7711,1)
  Return
Endif

Read [F:PTAUS]CODUSR = [L]ATAUS
If fstat : Raz [F:PTAUS] : Endif

Call GETSEC([F:PTAUS]NEWPAS, [L]AUSPASS)

PUSERNAME    = ctrans([F:PTCPY]EECNUM,"PT","") + "/" + [L]ATAUS
PPASSWORD    = [L]AUSPASS
PTAXREGNUMBE = val(ctrans([F:PTCPY]EECNUM,"PT",""))

#remaining values for the company
Filter [F:PTADC] Where [F:PTADC]BPATYP = 2 & [F:PTADC]BPANUM = [F:PTCPY]CPY & [F:PTADC]BPAADDFLG = 2
Read [F:PTADC] First
If fstat
  Filter [F:PTADC] Where [F:PTADC]BPATYP = 2 & [F:PTADC]BPANUM = [F:PTCPY]CPY
  Read [F:PTADC] First
  If fstat
    Raz [F:PTADC]
  Endif
Endif
Filter [F:PTADC]

PCOMPANYNAM = [F:PTCPY]CPYNAM
PADDRESSDET = vireblc([F:PTADC]BPAADDLIG(0) + " " + [F:PTADC]BPAADDLIG(1) + " " + [F:PTADC]BPAADDLIG(2), 2)
PCITY       = vireblc([F:PTADC]CTY,2)
PPOSTALCODE = vireblc(format$("K:4#[-]3#[]", [F:PTADC]POSCOD),2)
PCOUNTRY    = vireblc([F:PTADC]CRY,2)

#document values
[L]SAFTWAY = 0
[L]LINEC   = 0
Gosub RAZVAR_MG From SAFTGENPORMG

Gosub SET_SAFPRIRND From SAFTGENPOR
Gosub SET_SAFTPRDKITACTIVE From SAFTGENPOR

Case [L]DOCTYP
  When 2
    Gosub FEED_VARS From SAFTGENMGSDH
    Read [F:PTBPR]BPR0 = [L]MGCUSTOID
    If [F:PTBPR]LEGETT = 2
        OK = 0 : MESSAGE = func AFNC.MES1(mess(106,7711,1), [L]MGCUSTOID) : Return
    Endif
    If !fstat : Gosub SET_BPVARS : Else : Gosub SET_BPDVARS : Endif
    [L]PVEHICLEID = [F:PTSDH]LICPLATE+[F:PTSDH]TRLLICPLATE
    [L]P3EECNUMC  = [L]P3EECNUM
  When 3,4,5
    Gosub FEED_VARS From SAFTGENMGSRH
    Read [F:PTBPR]BPR0 = [L]MGCUSTOID
    If [F:PTBPR]LEGETT = 2
        OK = 0 : MESSAGE = func AFNC.MES1(mess(106,7711,1), [L]MGCUSTOID) : Return
    Endif
    If !fstat : Gosub SET_BPVARS : Endif
    [L]PVEHICLEID = [F:PTSRH]LICPLATER+[F:PTSRH]TRLLICPLATER
    [L]P3EECNUMC  = [L]P3EECNUM
  When 6,7,8
    Gosub FEED_VARS From SAFTGENMGSGH
    If [F:PTSGH]BETFCYCOD = 2
      Read [F:CPY2]CPY0 = [L]MGCUSTOID
      If !fstat : Gosub SET_BCPYVARS : Endif
      [L]P3EECNUMC  = [L]P3EECNUM
    Else
      Read [F:PTBPR]BPR0 = [L]MGSUPPLID
      If !fstat : Gosub SET_BPVARS : Endif
      [L]P3EECNUMS  = [L]P3EECNUM
    Endif
    [L]PVEHICLEID = [F:PTSGH]LICPLATE+[F:PTSGH]TRLLICPLATE
  When 9
    Gosub FEED_VARS From SAFTGENMGPNH
    Read [F:PTBPR]BPR0 = [L]MGSUPPLID
    If !fstat : Gosub SET_BPVARS : Endif
    [L]PVEHICLEID = [F:PTPNH]LICPLATER+[F:PTPNH]TRLLICPLATER
    [L]P3EECNUMS  = [L]P3EECNUM
  When 10
    Gosub FEED_VARS From SAFTGENMGTNH
    If [F:PTTNH]BPCBPS=1
      Read [F:PTBPR]BPR0 = [L]MGCUSTOID
      If [F:PTBPR]LEGETT = 2
          OK = 0 : MESSAGE = func AFNC.MES1(mess(106,7711,1), [L]MGCUSTOID) : Return
      Endif
      If !fstat : Gosub SET_BPVARS : Endif
      [L]PVEHICLEID = [F:PTTNH]LICPLATE+[F:PTTNH]TRLLICPLATE
      [L]P3EECNUMC  = [L]P3EECNUM
    Elsif [F:PTTNH]BPCBPS=2
      Read [F:PTBPR]BPR0 = [L]MGSUPPLID
      If !fstat : Gosub SET_BPVARS : Endif
      [L]PVEHICLEID = [F:PTTNH]LICPLATE+[F:PTTNH]TRLLICPLATE
      [L]P3EECNUMS  = [L]P3EECNUM
    Endif
Endcase

If [L]P3COUNTRY <> "PT" |  [L]P3COUNTRY = ""
   P3ADDRESSDET = ""
   P3CITY       = ""
   P3POSTALCODE = ""
   P3COUNTRY    = ""
Endif

Return
##########################################################################################
##########################################################################################
$SET_BPDVARS
#------- Customer information for shipments
If [L]DOCTYP = 2

   [L]P3NAM        = vireblc([F:PTSDH]BPINAM(0) + " " + [F:PTSDH]BPINAM(1),2)
   [L]P3ADDRESSDET = vireblc([F:PTSDH]BPIADDLIG(0)-[F:PTSDH]BPIADDLIG(1)-[F:PTSDH]BPIADDLIG(2),2)
   [L]P3CITY       = vireblc([F:PTSDH]BPICTY,2)
   [L]P3POSTALCODE = vireblc([F:PTSDH]BPIPOSCOD,2)
   [L]P3COUNTRY    = vireblc([F:PTSDH]BPICRY,2)

   If len([L]P3POSTALCODE) = 7 & [L]P3COUNTRY = 'PT'
     [L]P3POSTALCODE= format$("K:4#[-]3#", [L]P3POSTALCODE)
   Endif

   #RM * 21-10-2013 * nas expedições onde se considerou cliente diverso, exportar o código de terceiro de acordo com o que foi exportado em customers
   If [F:PTSDH]BPIEECNUM <> [F:PTBPR]EECNUM & [F:PTSDH]BPIEECNUM <> ""
      [L]P3EECNUM = func SAFTGENPORTG.GETEECNUM([F:PTSDH]BPIEECNUM)
   Else
      [L]P3EECNUM = func SAFTGENPORTG.GETEECNUM([F:PTBPR]EECNUM)
   Endif
Endif

Return
##########################################################################################
##########################################################################################
$SET_BPVARS

If [L]DOCTYP = 2

   [L]P3NAM        = vireblc([F:PTSDH]BPINAM(0) + " " + [F:PTSDH]BPINAM(1),2)
   [L]P3ADDRESSDET = vireblc([F:PTSDH]BPIADDLIG(0)-[F:PTSDH]BPIADDLIG(1)-[F:PTSDH]BPIADDLIG(2),2)
   [L]P3CITY       = vireblc([F:PTSDH]BPICTY,2)
   [L]P3POSTALCODE = vireblc([F:PTSDH]BPIPOSCOD,2)
   [L]P3COUNTRY    = vireblc([F:PTSDH]BPICRY,2)

   If len([L]P3POSTALCODE) = 7 & [L]P3COUNTRY = 'PT'
     [L]P3POSTALCODE= format$("K:4#[-]3#", [L]P3POSTALCODE)
   Endif

   #RM * 21-10-2013 * nas expedições onde se considerou cliente diverso, exportar o código de terceiro de acordo com o que foi exportado em customers
   If [F:PTSDH]BPIEECNUM <> [F:PTBPR]EECNUM & [F:PTSDH]BPIEECNUM <> ""
      [L]P3EECNUM = func SAFTGENPORTG.GETEECNUM([F:PTSDH]BPIEECNUM)
   Else
      [L]P3EECNUM = func SAFTGENPORTG.GETEECNUM([F:PTBPR]EECNUM)
   Endif

   If [L]P3NAM = "" | [L]P3ADDRESSDET = ""
      Read [F:PTBPC]BPC0 = [F:PTBPR]BPRNUM

      Call ADDRESS(1, [F:PTBPR]BPRNUM,[F:PTBPC]BPAINV,DISCARD1,P3ADDRESSDET,P3CITY,P3POSTALCODE,P3COUNTRY,DISCARD2) From SAFTGENPORMG

      P3NAM        = vireblc([F:PTBPR]BPRNAM(0) + " " + [F:PTBPR]BPRNAM(1),2)
      P3EECNUM     = func SAFTGENPORTG.GETEECNUM([F:PTBPR]EECNUM)

      Kill DISCARD1, DISCARD2
   Endif
Else
   Filter [F:PTADC] Where [F:PTADC]BPATYP = 1 & [F:PTADC]BPANUM = [F:PTBPR]BPRNUM & [F:PTADC]BPAADDFLG = 2
   Read [F:PTADC] First
   If fstat
     Filter [F:PTADC]
     Filter [F:PTADC] Where [F:PTADC]BPATYP = 1 & [F:PTADC]BPANUM = [F:PTBPR]BPRNUM
     Read [F:PTADC] First
     If fstat
       Raz [F:PTADC]
     Endif
   Endif
   Filter [F:PTADC]

   Call ADDRESS(1, [F:PTBPR]BPRNUM,[F:PTADC]BPAADD,DISCARD1,P3ADDRESSDET,P3CITY,P3POSTALCODE,P3COUNTRY,DISCARD2) From SAFTGENPORMG

   P3NAM        = vireblc([F:PTBPR]BPRNAM(0)    + " " + [F:PTBPR]BPRNAM(1),2)
   P3EECNUM     = func SAFTGENPORTG.GETEECNUM([F:PTBPR]EECNUM)

Endif

Return
##########################################################################################
##########################################################################################
$SET_BCPYVARS
#------- Customer information for inter-company

Filter [F:PTADC] Where [F:PTADC]BPATYP = 2 & [F:PTADC]BPANUM = [F:CPY2]CPY & [F:PTADC]BPAADDFLG = 2
Read [F:PTADC] First
If fstat
  Filter [F:PTADC]
  Filter [F:PTADC] Where [F:PTADC]BPATYP = 2 & [F:PTADC]BPANUM = [F:CPY2]CPY
  Read [F:PTADC] First
  If fstat
    Raz [F:PTADC]
  Endif
Endif
Filter [F:PTADC]

Call ADDRESS(2, [F:CPY2]CPY,[F:PTADC]BPAADD,DISCARD1,P3ADDRESSDET,P3CITY,P3POSTALCODE,P3COUNTRY,DISCARD2) From SAFTGENPORMG

P3NAM        = vireblc([F:CPY2]CPYNAM,2)
P3EECNUM     = func SAFTGENPORTG.GETEECNUM([F:CPY2]EECNUM)

Return
##########################################################################################
##########################################################################################
$FEED_VAR_WS
#------- Line information

[L]LINEC += 1

PORIGON([L]LINEC-1)     = MGDORIGIN
PAPRDDES([L]LINEC-1)    = MGDPRODES
PAQTY([L]LINEC-1)       = MGDQUANTI
PAUNIT([L]LINEC-1)      = MGDUOM
PAUNITPRICE([L]LINEC-1) = MGDNETPRI

Return
##########################################################################################
##########################################################################################
$CTR_VALS

If MGCOUNTRY_ST <> "PT" | (find([L]DOCTYP, 3, 4, 5) & MGCOUNTRY_SF<>'PT')
  OK = 0 : MESSAGE = mess(112,7711,1)
  Return
Endif

If MGMOVSTRT = "" | (len(vireblc(MGMOVSTRT,2))<>19 & len(vireblc(MGMOVSTRT,2))<>29)
  OK = 0 : MESSAGE = mess(113,7711,1) : Return
Endif

# BRBAN * 23/03/2015 #106027
[L]FCY = [F:PTFCY]FCY
DATCTR = format$("D:YYYY[-]MM[-]DD", date$)+"T"+time$
Gosub SET_TZ_X3

If MGMOVSTRT < DATCTR
  OK =0 : MESSAGE = mess(114,7711,1) : Return
Endif

Return
##########################################################################################
##########################################################################################
$SEND_DT

Gosub SET_CTX_OBJ
Gosub SET_DATA_OBJ
Gosub SET_OPT_OBJ

If [L]DBGMOD = "2"
  Gosub LOG_PARAMETERS
  Local Char MULTIMESS(250)(10)
  Setlob MULTIMESS With DATA
  Call ECR_TRACE("---- DATA ----", 0) From GESECRAN
  Call ECR_TRACE([L]MULTIMESS, 0) From GESECRAN
  Call ECR_TRACE("--------------", 0) From GESECRAN
  Kill MULTIMESS
Endif

ARGUMENTS = CTX + ',' + DATA + ',' + OPT

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, RETURNS, '0', RESHEAD, RESBODY)

If STATUSCODE = 200
  [L]RETCODSTR = func AJSONLIB.GET_PROP(RESBODY,"ReturnCodeString")
  [L]RETMES    = func AJSONLIB.GET_PROP(RESBODY,"ReturnMessage")
  [L]AESKEY    = func AJSONLIB.GET_PROP(RESBODY,"NonceAESKey")
  [L]DATTIM    = func AJSONLIB.GET_PROP(RESBODY,"createdDateTimeUTC")
  [L]ATDCOD    = func AJSONLIB.GET_PROP(RESBODY,"ATDocCodeID")
Else
  [L]RETMES    = num$(STATUSCODE)+": " + func AJSONLIB.GET_PROP(RESHEAD,"message")
  [L]RETCODSTR = "-99"
Endif

If [L]RETCODSTR = "0"
   Call ECR_TRACE(func AFNC.MES1(mess(115,7711,1), MGDOCNUMB)-[L]ATDCOD , 0) From GESECRAN
Else
   Local Char MULTIMESS(250)(3)
   Setlob MULTIMESS With RESHEAD
   Call ECR_TRACE([L]MULTIMESS, 1) From GESECRAN
   Kill MULTIMESS
Endif

If [L]RETCODSTR = "-100"
   STAT = 0
Else
   STAT = val([L]RETCODSTR)
Endif

[L]RETCOD = val([L]RETCODSTR)

Return
##########################################################################################
##########################################################################################
$UPD_DT_STAT

If [F:PTDKD]KEYCODE <> "SAFT-PT" | [F:PTDKD]DOCTYP <> [L]DOCTYPDKD | [F:PTDKD]DOCNUM <> [L]DTNUM
  Read [F:PTDKD]DKD0 = "SAFT-PT";[L]DOCTYPDKD;[L]DTNUM
  If fstat
    MESSAGE = mess(13,7711,1)
    OK      = 0
    Return
  Endif
Endif

If [F:PTDKD]ATDTCOD = ""
   [F:PTDKD]ATDTCOMSTA = num$([L]RETCOD) + string$(([L]RETCOD<>0)," "+[L]RETMES)
   [F:PTDKD]ATDTCOMKEY = [L]AESKEY
   [F:PTDKD]ATDTDATTIM = [L]DATTIM
   If [L]RETCOD = -100
      [F:PTDKD]ATDTCOD    = "0"
   Elsif [L]ATDCOD = "" & [L]RETCOD = 0 #& [L]FARPURDOC = 1
      [F:PTDKD]ATDTCOD    = "0"
   Else
      [F:PTDKD]ATDTCOD    = [L]ATDCOD
   Endif
   [F:PTDKD]ATDTINPTYP = 3
   [F:PTDKD]ATDTREQDAT = date$
   [F:PTDKD]ATDTREQTIM = time$
   [F:PTDKD]ATDTRECDAT = date$
   [F:PTDKD]ATDTRECTIM = time$
   If dim([F:PTDKD]ATDTTESMOD) > 0
      If [L]TESMOD = "2"
         [F:PTDKD]ATDTTESMOD = 2
      Else
         [F:PTDKD]ATDTTESMOD = 1
      Endif
   Endif
   Rewrite [F:PTDKD]
Endif

Return
##########################################################################################
##########################################################################################
###                                                                                    ###
###                               User information                                     ###
###                                                                                    ###
##########################################################################################
##########################################################################################
Subprog GETSEC(GARB, GOLD)
Value    Char    GARB
Variable Char    GOLD

Local Integer I , I1, P0, P1, P2
Local Libelle CRI(1..24)
Local Libelle CRI2(1..12)

Raz CRI

For I=1 To min(len(GARB),24)
   CRI(I) = ascii(mid$(GARB,I,1))
Next I

For I=1 To 24
   If mod(I,2) <> 0
      Gosub P11
   Else
      Gosub P12
      CRI2(int((I/2))) = P1+P2
   Endif
Next I

Call CRI(CRI2) From VISULIC

GOLD = ""
For I=1 To 12
   GOLD += chr$(CRI2(I))
Next I

End

$P11
Gosub P0
P1 = P0*16
Return

$P12
Gosub P0
P2 = mod(P0,16)
Return

$P0
If CRI(I)>=65
   P0 = CRI(I)-65+10
Else
   P0 = CRI(I)-48
Endif

Return
##########################################################################################
##########################################################################################
###                                                                                    ###
###                               Trace and log                                        ###
###                                                                                    ###
##########################################################################################
##########################################################################################
$TRACE

If MESSAGE <> ""
   Call ECR_TRACE(MESSAGE, STAT) From GESECRAN
Endif

If [L]PRIVTRACE = 1
  Call LEC_TRACE   From LECFIC
  Call FERME_TRACE From LECFIC
Endif

Return
##########################################################################################
##########################################################################################
$LOG_PARAMETERS

Call ECR_TRACE("EndPoint:"-PWSURL,0) From GESECRAN

Call ECR_TRACE("TaxRegistrationNumber:"           - num$(PTAXREGNUMBE),0) From GESECRAN
Call ECR_TRACE("CompanyName:"                     - PCOMPANYNAM,       0) From GESECRAN
Call ECR_TRACE("CompanyAddress - AddressDetail:"  - PADDRESSDET,       0) From GESECRAN
Call ECR_TRACE("CompanyAddress - City:"           - PCITY,             0) From GESECRAN
Call ECR_TRACE("CompanyAddress - PostalCode:"     - PPOSTALCODE,       0) From GESECRAN
Call ECR_TRACE("CompanyAddress - Country:"        - PCOUNTRY,          0) From GESECRAN
Call ECR_TRACE("DocumentNumber:"                  - MGDOCNUMB,         0) From GESECRAN
Call ECR_TRACE("MovementStatus:"                  - MGMOVSTAT,         0) From GESECRAN
Call ECR_TRACE("MovementType:"                    - MGMOVTYPE,         0) From GESECRAN
Call ECR_TRACE("CustomerTaxID:"                   - P3EECNUMC,         0) From GESECRAN
Call ECR_TRACE("SupplierTaxID:"                   - P3EECNUMS,         0) From GESECRAN
Call ECR_TRACE("MovementType:"                    - MGMOVTYPE,         0) From GESECRAN
Call ECR_TRACE("CustomerAddress - AddressDetail:" - P3ADDRESSDET,      0) From GESECRAN
Call ECR_TRACE("CustomerAddress - City:"          - P3CITY,            0) From GESECRAN
Call ECR_TRACE("CustomerAddress - PostalCode:"    - P3POSTALCODE,      0) From GESECRAN
Call ECR_TRACE("CustomerAddress - Country:"       - P3COUNTRY,         0) From GESECRAN
Call ECR_TRACE("ShipTo - AddressDetail:"          - MGADDDETA_ST,      0) From GESECRAN
Call ECR_TRACE("ShipTo - City:"                   - MGCITY_ST,         0) From GESECRAN
Call ECR_TRACE("ShipTo - PostalCode:"             - MGPOSTCOD_ST,      0) From GESECRAN
Call ECR_TRACE("ShipTo - Country:"                - MGCOUNTRY_ST,      0) From GESECRAN
Call ECR_TRACE("ShipFrom - AddressDetail:"        - MGADDDETA_SF,      0) From GESECRAN
Call ECR_TRACE("ShipFrom - City:"                 - MGCITY_SF,         0) From GESECRAN
Call ECR_TRACE("ShipFrom - PostalCode:"           - MGPOSTCOD_SF,      0) From GESECRAN
Call ECR_TRACE("ShipFrom - Country:"              - MGCOUNTRY_SF,      0) From GESECRAN
Call ECR_TRACE("MovementStartTime:"               - MGMOVSTRT,         0) From GESECRAN
Call ECR_TRACE("MovementEndTime:"                 - MGMOVENDT,         0) From GESECRAN
Call ECR_TRACE("VehicleID:"                       - PVEHICLEID,        0) From GESECRAN

For J = 1 To [L]LINEC
   Call ECR_TRACE("OrderReferences("+num$([L]J-1)+"):"-PORIGON([L]J-1),0)     From GESECRAN
   Call ECR_TRACE("ProductDescription("+num$([L]J-1)+"):"-PAPRDDES([L]J-1),0) From GESECRAN
   Call ECR_TRACE("Quantity("+num$([L]J-1)+"):"-num$(PAQTY([L]J-1)),0)        From GESECRAN
   Call ECR_TRACE("UnitOfMeasure("+num$([L]J-1)+"):"-PAUNIT([L]J-1),0)        From GESECRAN
   Call ECR_TRACE("UnitPrice("+num$([L]J-1)+")"-num$(PAUNITPRICE([L]J-1)),0)  From GESECRAN
Next

Call ECR_TRACE("LineCount:"-num$([L]LINEC),0) From GESECRAN

Return
##########################################################################################
##########################################################################################
###                                                                                    ###
###                              Date and timezone                                     ###
###                                                                                    ###
##########################################################################################
##########################################################################################
# BRBAN 24-03-2015 #106027
# BRBAN 23/03/2015 #107396 Added FCY variable to set time zone
##########################################################################################
Funprog CTRL_COMDAT(TZFCY,STRDAT,STRTIM)
Value Date STRDAT
Value Char STRTIM
Value Char TZFCY

Local Integer RET          :  [L]RET    = 0
Local Char    DATCTR(20)   :  [L]DATCTR = format$("D:YYYY[-]MM[-]DD", date$)+"T"+time$
Local Char    FCY(GLONFCY) :  [L]FCY    = [L]TZFCY
Local Char    TZPAR(10)    :  [L]TZPAR  = ''
Local Char    PORSTRMOV(50):  [L]PORSTRMOV  = format$("D:YYYY[-]MM[-]DD",[L]STRDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([L]STRTIM,":","")+"00")

Gosub SET_TZ_X3

If [L]PORSTRMOV < [L]DATCTR
  [L]RET = 0
Else
  [L]RET = 1
Endif
End [L]RET
##########################################################################################
##########################################################################################
$SET_TZ
Return
##########################################################################################
##########################################################################################
$SET_TZ_X3
#------- BRBAN * 23/03/2015 #106027 Set time zone difference

Call PARAM([L]FCY, "TIMZONDIF", [L]TZPAR) From ADOVAL

If len([L]TZPAR) = 6
   Local Char    TZSENS(1) : [L]TZSENS = left$([L]TZPAR, 1)
   Local Integer TZYEAR    : [L]TZYEAR = 0
   Local Integer TZMONT    : [L]TZMONT = 0
   Local Integer TZDAY     : [L]TZDAY  = 0
   Local Integer TZHOUR    : [L]TZHOUR = val(mid$([L]TZPAR, 2,2))
   Local Integer TZMINU    : [L]TZMINU = val(mid$([L]TZPAR, 5,2))

   Local Integer TDYEAR
   Local Integer TDMONT
   Local Integer TDDAY
   Local Integer TDHOUR
   Local Integer TDMINU

   Local Integer TFYEAR
   Local Integer TFMONT
   Local Integer TFDAY
   Local Integer TFHOUR
   Local Integer TFMINU

   If len(DATCTR) = 19 #"YYYY-MM-DDTHH:mm:ss"
      [L]TDYEAR = val(mid$([L]DATCTR, 1,4))
      [L]TDMONT = val(mid$([L]DATCTR, 6,2))
      [L]TDDAY  = val(mid$([L]DATCTR, 9,2))
      [L]TDHOUR = val(mid$([L]DATCTR, 12,2))
      [L]TDMINU = val(mid$([L]DATCTR, 15,2))

      If    [L]TZSENS = "-"
         Gosub SUB_TZ
         DATCTR= format$("D:YYYY[-]MM[-]DD",gdat$(TFDAY, TFMONT, TFYEAR))+"T"+format$("hh[:]mm[:]ss", string$(TFHOUR<10,"0") + num$(TFHOUR) + string$(TFMINU<10,"0") + num$(TFMINU) + mid$([L]
& DATCTR, 18,2))
      Elsif TZSENS = "+"
         Gosub ADD_TZ
         DATCTR= format$("D:YYYY[-]MM[-]DD",gdat$(TFDAY, TFMONT, TFYEAR))+"T"+format$("hh[:]mm[:]ss", string$(TFHOUR<10,"0") + num$(TFHOUR) + string$(TFMINU<10,"0") + num$(TFMINU) + mid$([L]
& DATCTR, 18,2))
      Endif
   Endif

Endif

Return
##########################################################################################
##########################################################################################
$ADD_TZ

#minutos
[L]TFMINU  = mod([L]TZMINU + [L]TDMINU, 60)
[L]TZHOUR += int(([L]TZMINU + [L]TDMINU)/60)

#horas
[L]TFHOUR  = mod([L]TZHOUR + [L]TDHOUR, 24)
[L]TZDAY  += int(([L]TZHOUR + [L]TDHOUR)/24)

#dias
If [L]TDDAY + [L]TZDAY > day(eomonth(gdat$([L]TDDAY, [L]TDMONT, [L]TDYEAR)))
   [L]TFDAY = ([L]TDDAY + [L]TZDAY) - day(eomonth(gdat$([L]TDDAY, [L]TDMONT, [L]TDYEAR)))
   [L]TZMONT = 1
Else
   [L]TFDAY = ([L]TDDAY + [L]TZDAY)
Endif

#meses
If [L]TDMONT + [L]TZMONT > 12
   [L]TFMONT = ([L]TDMONT + [L]TZMONT) - 12
   [L]TZYEAR = 1
Else
   [L]TFMONT = [L]TDMONT + [L]TZMONT
Endif

#anos
[L]TFYEAR = [L]TDYEAR + [L]TZYEAR

Return
##########################################################################################
##########################################################################################
$SUB_TZ

#minutos
If [L]TDMINU > [L]TZMINU
  [L]TFMINU = [L]TDMINU - [L]TZMINU
Else
  [L]TFMINU = 60 + [L]TDMINU - [L]TZMINU
  [L]TZHOUR += 1
Endif

#horas
If [L]TDHOUR > [L]TZHOUR
  [L]TFHOUR = [L]TDHOUR - [L]TZHOUR
Else
  [L]TFHOUR = 24 + [L]TDHOUR - [L]TZHOUR
  [L]TZDAY += 1
Endif

#dias
If [L]TDDAY - [L]TZDAY > 1
  [L]TFDAY = [L]TDDAY - [L]TZDAY
Else
  [L]TFDAY = day(eomonth(addmonth(gdat$([L]TDDAY,[L]TDMONT,[L]TFMONT),-1)))+[L]TDDAY - [L]TZDAY
  [L]TZMONT += 1
Endif

#meses
If [L]TDMONT - [L]TZMONT < 1
   [L]TFMONT = 12 + [L]TDMONT - [L]TZMONT
   [L]TZYEAR = 1
Else
   [L]TFMONT = [L]TDMONT - [L]TZMONT
Endif

#anos
[L]TFYEAR = [L]TDYEAR - [L]TZYEAR

Return
##########################################################################################
##########################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK

#------- BRBAN 24-03-2015 #107396 Timezone parameter control

Case PARAM
   When "TIMZONDIF"
      Gosub CTR_TIMZONDIF
Endcase

End
##########################################################################################
##########################################################################################
$CTR_TIMZONDIF
If len(VALEUR) = 0 : Return : Endif

Local Char PORPAT(5) : PORPAT = "##:##"

If len(VALEUR) <> 6
   OK       = 0
   GMESSAGE = mess(149,100,1) - "([+|-]##[:]##)" #Incorrect Format
   Return
Endif

If left$(VALEUR, 1) <> "+" & left$(VALEUR, 1) <> "-"
   OK       = 0
   GMESSAGE = mess(149,100,1) - "([+|-]##[:]##)"
   Return
Endif

If !pat(right$(VALEUR,2), PORPAT)
   OK       = 0
   GMESSAGE = mess(149,100,1) - "([+|-]##[:]##)"
   Return
Endif

Return
##########################################################################################
##########################################################################################
###                                                                                    ###
###                                  Web service payload                               ###
###                                                                                    ###
##########################################################################################
##########################################################################################
$SET_CTX_OBJ

# Format CONTEXT to JSON object
Local Char PROP03(255) : PROP03 = "R0BMLRwdGhwdBhWVggEsMTstJwQTFzldIyQwQkRUKxEEHAc="
PROP03 = num$(len(PROP03))+"-"+PROP03
Local Char PROP03_DATA(255) : PROP03_DATA = MGDOCNUMB+MGMOVTYPE+MGMOVEDAT
PROP03 = func DKSLIB.BYTOP(PROP03,PROP03_DATA, 0)

Local Char PROP04(255) : PROP04 = PPASSWORD
PROP04 = num$(len(PROP04))+"-"+PROP04
PROP04 = func DKSLIB.BYTOP(PROP04,PROP03, 0)

Local Clbfile CTX(0) : CTX = '{'
Append CTX, '"username": "' + PUSERNAME + '",'
Append CTX, '"endpoint": "' + PWSURL + '",'
Append CTX, '"prop03": "' + PROP03 + '",'
Append CTX, '"prop04": "' + PROP04 + '",'
Append CTX, '"operation": "transporte"'
Append CTX, '}'

Return
##########################################################################################
##########################################################################################
$SET_DATA_OBJ

# Format DATA to JSON object
Local Clbfile DATA(8) : DATA = '{'
Append DATA, '"TaxRegistrationNumber" : "' + num$(PTAXREGNUMBE) + '",'
Append DATA, '"CompanyName" : "' + func PORLEGLIB1.REPQUOMARK(PCOMPANYNAM) + '",'
Append DATA, '"CompanyAddress" : {'
Append DATA, '  "Addressdetail" : "' + func PORLEGLIB1.REPQUOMARK(PADDRESSDET) + '",'
Append DATA, '  "City" : "' + PCITY + '",'
Append DATA, '  "PostalCode" : "' + PPOSTALCODE + '",'
Append DATA, '  "Country" : "' + PCOUNTRY + '"'
Append DATA, '},'
Append DATA, '"DocumentNumber" : "' + MGDOCNUMB + '",'
Append DATA, '"MovementStatus" : "' + MGMOVSTAT + '",'
Append DATA, '"MovementDate" : "' + MGMOVEDAT + '",'
Append DATA, '"MovementType" : "' + MGMOVTYPE + '",'
If P3EECNUMC <> ''
  Append DATA, '"CustomerTaxID": "' + P3EECNUMC + '",'
  Append DATA, '"CustomerAddress" : {'
  Append DATA, '  "Addressdetail" : "' + func PORLEGLIB1.REPQUOMARK(P3ADDRESSDET) + '",'
  Append DATA, '  "City" : "' + P3CITY + '",'
  Append DATA, '  "PostalCode" : "' + P3POSTALCODE + '",'
  Append DATA, '  "Country" : "' + P3COUNTRY + '"'
  Append DATA, '},'
  Append DATA, '"CustomerName" : "' + func PORLEGLIB1.REPQUOMARK(P3NAM) + '",'
Else
  Append DATA, '"SupplierTaxID": "' + P3EECNUMS + '",'
Endif
Append DATA, '"AddressTo" : {'
Append DATA, '  "Addressdetail" : "' + func PORLEGLIB1.REPQUOMARK(MGADDDETA_ST) + '",'
Append DATA, '  "City" : "' + MGCITY_ST + '",'
Append DATA, '  "PostalCode" : "' + MGPOSTCOD_ST + '",'
Append DATA, '  "Country" : "' + MGCOUNTRY_ST + '"'
Append DATA, '},'
Append DATA, '"AddressFrom" : {'
Append DATA, '  "Addressdetail" : "' + func PORLEGLIB1.REPQUOMARK(MGADDDETA_SF) + '",'
Append DATA, '  "City" : "' + MGCITY_SF + '",'
Append DATA, '  "PostalCode" : "' + MGPOSTCOD_SF + '",'
Append DATA, '  "Country" : "' + MGCOUNTRY_SF + '"'
Append DATA, '},'
If MGMOVENDT <> ''
  Append DATA, '"MovementEndTime" : "' + MGMOVENDT + '",'
Endif
Append DATA, '"MovementStartTime" : "' + MGMOVSTRT + '",'
If PVEHICLEID <> ''
  Append DATA, '"VehicleID" : "' + PVEHICLEID + '",'
Endif

# Format LINES to JSON array
Append DATA, '"Line": ['
SEP  = ''
For I=1 To LINEC
 Append DATA, SEP+'{'
 If PORIGON(I)<>''
  Append DATA, '"OrderReferences": "' + PORIGON(I-1) + '",'
 Endif
 Append DATA, '"ProductDescription": "' + func PORLEGLIB1.REPQUOMARK(PAPRDDES(I-1)) + '",'
 Append DATA, '"Quantity": ' + num$(PAQTY(I-1)) + ','
 Append DATA, '"UnitOfMeasure": "' + PAUNIT(I-1) + '",'
 Append DATA, '"UnitPrice": ' + num$(PAUNITPRICE(I-1))
 Append DATA, '}'
 SEP = ','
Next I

Append DATA, ']'
Append DATA, '}'

Return
##########################################################################################
##########################################################################################
$SET_OPT_OBJ

Local Char DEBUGMODE(10) : DEBUGMODE = 'false'
If DBGMOD = "2" : DEBUGMODE = 'true' : Endif

# Format OPTIONS to JSON object
Local Clbfile OPT(0) : OPT = '{'
Append OPT, '"ignoreProxy": "false",'
Append OPT, '"debugMode": "' + DEBUGMODE + '",'
Append OPT, '"debug": "false",'
Append OPT, '"forceSoapEncode": "windows-1252",'
Append OPT, '"forceDataEncode": "ascii"'
Append OPT, '}'

Return
##########################################################################################
## by MNO 09.03.2018 - replace " with \" so it does not cause issues in JSON
##########################################################################################
Funprog REPQUOMARK(MAINSTR)
Value Char MAINSTR
Value Integer  POSITION : POSITION = 0

While instr(POSITION, MAINSTR, '"')>0
  POSITION = instr(POSITION, MAINSTR, '"')+1
  MAINSTR = left$(MAINSTR ,POSITION-2) + '\"' + right$(MAINSTR ,POSITION)
  POSITION += 1
Wend

End MAINSTR
#######################################################################################
#######################################################################################

