#<AdxTL>@(#)6.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : ENV
#   Fonction : GESENV - Entité
#   Action   : GOBJET
#   Ecran concerné : ENV0, ENV1, ENV2
#   Description : Définition d'enveloppe budgétaire pour les budgets opérationnels
#
#--------------------------------------------------------------------------
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

Raz GPILOBJ
Call OBJET("ENV",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "STYLE"       : Gosub STYLE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "APRES_CRE"   : Gosub APRES_CRE
 When "CHANGE"      : Gosub CHANGE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "AVANT_MODFIC": Gosub AVANT_MODFIC
 When "MODIF"       : Gosub MODIF
 When "AV_VERF_ANU" : Gosub AV_VERF_ANU
 When "ANNULE"      : Gosub ANNULE
 When "ABANDON"     : Gosub ABANDON
 When "VERROU"      : Gosub VERROU
 When "DEVERROU"    : Gosub DEVERROU
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN"         : Kill GCHKBUD,GCHKAPP,GPURREQ
 When "APRES_MODIF" : If GCHKBUD=1 | GCHKAPP=1 : Gosub SETBOUT From GOBJSUB : OK = 0 : Endif
Endcase
Return

$OUVRE
# - Tables
If !clalev([F:CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([F:ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([F:ENT]) : Local File ENTITE     [ENT] : Endif
If !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If !clalev([F:BUD2]): Local File BUD      [BUD2] : Endif
If !clalev([F:BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([F:BUT]) : Local File BUDTYP     [BUT] : Endif
If !clalev([F:BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([F:BVD]) : Local File BUDREVDET  [BVD] : Endif
If !clalev([F:BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([F:BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([F:AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:GCM]) : Local File GACM       [GCM] : Endif
If !clalev([F:LED]) : Local File GLED       [LED] : Endif
If !clalev([F:DIE]) : Local File GDIE       [DIE] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP   [FGR] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY    [AGF] : Endif
If !clalev([F:AGC]) : Local File AGRPCPY    [AGC] : Endif
If !clalev([F:BUA]) : Local File BUDPURAUD  [BUA] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:POH]) : Local File PORDER     [POH] : Endif

# - Variables
Global Char GAPPNIV(3)
Global Integer GCHKAPP, GCHKBUD, GPURREQ
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Local Char AXE(GLONDIE)
Local Integer I
Local Integer FLGBUT(0..6)
Local Char ENTUSR(GLONENT)
If dim(GSLTOFFTYP)<=0 : Global Integer GSLTOFFTYP : Endif : # Type de document office autorisé
Local Char USRENV(GLONADW)
If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAMUTIL("USRAPPENV",USRENV,"","") From SUBAUS
Endif   # Issue X3-107197

Local Char    SYMBOL(30)
Local Integer LOCKCCE
Local Char    OLDENV(GLONENV)
Return

$LIENS
Raz FLGBUT
#Chargement des champs invisibles utiles
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
Case [F:BUP]LEV
 When 1 : #Niveau societe
  [M:ENV1]SOCIETE=[F:ENV]FCY
  Call LEC_CPY([F:ENV]FCY) From CPTLEC
  [M:ENV1]INTFCY=[F:CPY]CPYNAM
  [M:ENV1]SITE=[F:CPY]MAIFCY
 When 2 : #Niveau site
  [M:ENV1]SITE=[F:ENV]FCY
  Call LEC_FCY([F:ENV]FCY) From CPTLEC
  [M:ENV1]INTFCY=[F:FCY]FCYNAM
  [M:ENV1]SOCIETE=[F:FCY]LEGCPY
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Endcase
[M:ENV0]CURENV = [F:BUP]CUR

#Chargement des champs invisible mais utiles
[M:ENV0]BUDLEV = [F:BUP]LEV

Call SETMAINREF([M:ENV1]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
[M:ENV1]LEDTYP=LEDTYPANA

Call LECLED([M:ENV1]SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
Call LEC_LED(CODLED) From CPTLEC
For I=0 To dim([F:LED]DIE)-1
 Call LEC_DIE([F:LED]DIE(I)) From CPTLEC
 If [F:DIE]ENV=2
  [M:ENV1]INDDIE = I+1 : # DIE index in the ledger
  [M:ENV1]DIE=[F:DIE]DIE : Break
 Endif
Next

#-Chargement du tableau des financeurs
I=0
While  I<dim([F:ENV]BPRFIN) & [F:ENV]BPRFIN(I)<>""
 [M:ENV2]BPRFIN(I) = [F:ENV]BPRFIN(I)
 [M:ENV2]AMTFIN(I) = [F:ENV]AMTFIN(I)
 [M:ENV2]NBFIN+=1
 I+=1
Wend

#-Chargement des montants prévisonnels par période
I=0
While  I<dim([F:ENV]AMTPRV) & [F:ENV]AMTPRV(I)<>0
 [M:ENV2]PERSTR(I) = [F:ENV]PERSTR(I)
 [M:ENV2]PEREND(I) = [F:ENV]PEREND(I)
 [M:ENV2]AMTPRV(I) = [F:ENV]AMTPRV(I)
 [M:ENV2]NBPRV+=1
 I+=1
Wend

#-Chargement du tableau de ventilation/Exercice
I=0
For [ENF]ENF0 Where ENV=[F:ENV]ENV
 [M:ENV1]FIYSTR(I)    = [F:ENF]FIYSTR
 [M:ENV1]FIYEND(I)    = [F:ENF]FIYEND
 [M:ENV1]FIYNUM(I)    = [F:ENF]FIYNUM
## Colonne exercice à remplir avec N°exercice + intitulé exercice
 Read [FIY]FIY0 = [M:ENV1]SOCIETE;[M:ENV1]LEDTYP;[F:ENF]FIYNUM
 If !fstat
  If [F:FIY]DESSHO<>""
   [M:ENV1]FIYINT(I)  = num$([F:ENF]FIYNUM)-"-"-[F:FIY]DESSHO
  Else
   [M:ENV1]FIYINT(I)  = num$([F:ENF]FIYNUM)
  Endif
 Endif
 [M:ENV1]AMTBUDFIY(I) = [F:ENF]AMTBUDFIY
 [M:ENV1]AMTAPPFIY(I) = [F:ENF]AMTAPPFIY
 [M:ENV1]AMTRESFIY(I) = [F:ENF]AMTRESFIY
 [M:ENV1]STAFIY(I)    = [F:ENF]STAFIY
 [M:ENV1]APPDATFIY(I) = [F:ENF]APPDATFIY
 [M:ENV1]REVDATFIY(I) = [F:ENF]REVDATFIY
 [M:ENV1]NBFIY+=1
 I+=1
Next
Affzo [M:ENV1]30

#Chargement des textes traduisibles (intitulés)
Call LECTEXTRA([M:ENV0]DESTRA,"ENVELOPPE","DESTRA",[M:ENV0]ENV,"") From ATEXTRA
Call LECTEXTRA([M:ENV0]SHOTRA,"ENVELOPPE","SHOTRA",[M:ENV0]ENV,"") From ATEXTRA

#03/03/08 : Gestion des approbations
Call SETGLBAPP([F:ENV]FCY,GAPPNIV) From TRTGDD

##Grizage/degrizage en fonction du status
Actzo [M:ENV0]
Actzo [M:ENV1]
Actzo [M:ENV2]

If [F:ENV]STA<>1
 Diszo [M:ENV0]BUDTYP,BUD
 Diszo [M:ENV1]PRJ,FCY,ENTMNA,ACS,EXTBUD,AMTENV
Endif

Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
If [F:BUT]YEAFLG=2 :#Pluriannuel
 Diszo [M:ENV1]RECOND
Endif

# Info d'enveloppe d'origine si enveloppe créée par reconduction ou report
If [F:ENV]ENVORG<>""
 #Enveloppe d'origine
 If !clalev([F:ENV3]) : Local File ENVELOPPE [ENV3] :  Endif
 Local Char ORGENV
 ORGENV=[F:ENV]ENVORG
 Read [F:ENV3]ENV0 = [F:ENV]ENVORG
 If !fstat
  #[M:ENV0]INFOENVORG=mess(240,108,1)-[F:ENV]ENVORG
  Case [F:ENV3]TYPREC
   When 1 : [M:ENV0]INFOENVORG=mess(253,108,1) :#Enveloppe reconduite depuis $1$ le $2$
   When 2 : [M:ENV0]INFOENVORG=mess(259,108,1) :#Engagements reportés depuis $1$ le $2$
   When Default : [M:ENV0]INFOENVORG="Enveloppe d'origine :"-[F:ENV]ENVORG
  Endcase
  If [F:ENV3]TYPREC<>0
   Call DYNAMIC([M:ENV0]INFOENVORG,"$1$",[F:ENV]ENVORG) From TEXTE
   Call DYNAMIC([M:ENV0]INFOENVORG,"$2$",format$(GFMD,[F:ENV3]DRECOND)) From TEXTE
  Endif
 Endif
Endif

# Info d'enveloppe créée si enveloppe d'origine d'une enveloppe reconduite
If [F:ENV]DRECOND<>[0/0/0] & [F:ENV]ENVRCD<>""
 Grizo [M:ENV1]RECOND
 Case [F:ENV]TYPREC
  When 1 : [M:ENV1]INFORECOND=mess(240,108,1) :#Reconduite sur $$1 le $2$
  When 2 : [M:ENV1]INFORECOND=mess(258,108,1) :#Engagements reportés sur $1$ le $2$
  When Default : [M:ENV1]INFORECOND = "Enveloppe reconduite le"-format$(GFMD,[F:ENV]DRECOND)
 Endcase
 If [F:ENV]TYPREC<>0
  Call DYNAMIC([M:ENV1]INFORECOND,"$1$",[F:ENV]ENVRCD) From TEXTE
  Call DYNAMIC([M:ENV1]INFORECOND,"$2$",format$(GFMD,[F:ENV]DRECOND)) From TEXTE
 Endif
Endif

#Si hors budgets, montants non saisissable
If [M:ENV1]EXTBUD=2
 Grizo [M:ENV1]AMTENV,EXDPRC
 If [M:ENV1]REVDAT=[0/0/0] | [M:ENV1]AMTENV=0
  Grizo [M:ENV1]AMTRES
 Endif
Endif

#Si ligne budgétaire, site/société non saisissable
Gosub CHK_BUD

Gosub GRIZ_TAB_BUD

Gosub INFO_MONTANT

Local Integer LRET_VALUE
Call LEC_CPY([M:ENV1]SOCIETE) From CPTLEC
LRET_VALUE=func AOFFDOC.OFFICE_DOC("ENV", "ENVELOPPE", "ENVELOPPE", [M:ENV0]ENV, isomess, [M:ENV1]SOCIETE, [F:CPY]LEG, "GDD")

Gosub CHK_APP
Gosub CHK_REV
Return

$STYLE
#Lorsque que l'on a reconduit un budget sur un projet
#et que les dates ne correspondent plus
Call C_REAEND([M]REAEND)
Return

$GRIZ_TAB_BUD
#Grizage au niveau des budgets
For I=0 To [M:ENV1]NBFIY-1
 If [M:ENV1]STAFIY(I)<>1
  Grizo [M:ENV1]AMTBUDFIY(I)
  Affzo [M:ENV1]AMTBUDFIY(I)
 Endif
Next
Return

$INFO_MONTANT
#Montants informatifs
Local Char    CRITBUD(100)
Local Decimal VE_BUD, RES_BUD, VE_LIG, CONSO_LIG, ENG_LIG, PREENG_LIG, REA_LIG
VE_BUD=0
RES_BUD=0
VE_LIG=0
CONSO_LIG=0
ENG_LIG=0
PREENG_LIG=0
REA_LIG=0

For I=0 To [M]NBFIY-1
 #Budgets
 VE_BUD  += [M]AMTBUDFIY(I)
 RES_BUD += [M]AMTRESFIY(I)
 #Lignes
 CRITBUD = 'LEDTYP='+num$([M]LEDTYP)-'& BUD="'+[M]BUD+'" & FIY='+num$([M]FIYNUM(I))-'& VER="1" &'
 CRITBUD -= 'CCE'+num$([M:ENV1]INDDIE)+'="'+[M]ENV+'"'
 Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 Case [F:BUP]LEV
  When 1
   CRITBUD -='& CPY="'+[M]SOCIETE+'"'
  When 2
   CRITBUD -='& FCY="'+[M]SITE+'"'
  Endcase
 Filter [BUD] Where evalue(CRITBUD)
 For [BUD]BUD0
  VE_LIG += [F:BUD]AMT(0)
  ENG_LIG += [F:BUD]AMTCMM
  PREENG_LIG += [F:BUD]AMTCMMPRP
  REA_LIG += [F:BUD]AMTREA
 Next
 Filter [BUD]
Next

#Enveloppe
[M]SOLDE1 = [M]AMTENV-[M]AMTRES
[M]VE    = VE_BUD
[M]RAVE  = [M]SOLDE1-[M]VE

#Budgets
[M]VE1    = [M]VE
[M]RES1   = RES_BUD
[M]SOLDE2 = [M]VE-[M]RES1
[M]RAVE1  = [M]SOLDE2-VE_LIG

#Lignes
[M]VE2    = VE_LIG
[M]VE3    = VE_LIG
[M]VE_PREENG = PREENG_LIG
[M]VE_ENG = ENG_LIG
[M]VE_REA = REA_LIG
[M]RES2   =PREENG_LIG+ENG_LIG+REA_LIG
[M]RAVE2  = VE_LIG-[M]RES2

Affzo [M]
Return

$CHK_APP
#Acces à la consultation des révisions si existantes sur l'enveloppe
Filter [BOA] Where ENV=[M]ENV
Look [BOA]BOA0 First
If !fstat
 FLGBUT(2)=1
Endif
Filter [BOA]
#Approbation En-cours
Filter [BOA] Where STA=2 & ENV=[M]ENV
Read [BOA]BOA0 First
If !fstat
 If [F:BOA]TYP=4
  Filter [BAD] Where NUMAPP=[F:BOA]NUM
  Look [BAD]BAD0 First
  If !fstat :   FLGBUT(3)=1 : Endif
  Filter [BAD]
 Else
  FLGBUT(3)=1
 Endif
Endif
Filter [BOA]
#Historique Approbation
Filter [BOA] Where STA<>2 & ENV=[M]ENV
Read [BOA]BOA0 First
If !fstat
 If [F:BOA]TYP=4
  Filter [BAD] Where NUMAPP=[F:BOA]NUM
  Look [BAD]BAD0 First
  If !fstat :   FLGBUT(5)=1: Endif
  Filter [BAD]
 Else
  FLGBUT(5)=1
 Endif
Endif
Filter [BOA]
Return

$CHK_REV
#Acces à la consultation des révisions si existantes sur l'enveloppe
Filter [BRV] Where ENV=[M]ENV
Look [BRV]BRV0 First
If !fstat
 FLGBUT(1)=1
Endif
Filter [BRV]
#En-cours Révision
Filter [BRV] Where STA=2 & ENV=[M]ENV
Read [BRV]BRV0 First
If !fstat
 If [F:BRV]TYP=4
  Filter [BVD] Where NUMREV=[F:BRV]NUM
  Look [BVD]BVD0 First
  If !fstat : FLGBUT(4)=1 : Endif
  Filter [BVD]
 Else
  FLGBUT(4)=1
 Endif
Endif
Filter [BRV]
#Historique Révision
Filter [BRV] Where STA<>2 & ENV=[M]ENV
Read [BRV]BRV0 First
If !fstat
 If [F:BRV]TYP=4
  Filter [BVD] Where NUMREV=[F:BRV]NUM
  Look [BVD]BVD0 First
  If !fstat : FLGBUT(6)=1 : Endif
  Filter [BVD]
 Else
  FLGBUT(6)=1
 Endif
Endif
Filter [BRV]
Return

$CHK_BUD
#Si ligne budgétaire, site/société non saisissable
Filter [BUD] Where evalue('CCE'+num$([M:ENV1]INDDIE))=[M:ENV0]ENV
Look [BUD]BUD0 First
If !fstat
 Grizo [M:ENV1]FCY
 FLGBUT(0) = 1
Else
 FLGBUT(0) = 0
 Actzo [M:ENV1]FCY
Endif
Filter [BUD]
Return


$FILGAUCHE
Case currbox
 When "GAU_CHE"
 FILGAUCHE = "STA<>4"
 When "GAU_CHE1"
 FILGAUSUP(0) = "STA=4"
Endcase
Return

$SETBOUT
#--------------------------------------------------------------#
# Autorisation de Suppression et de soumission pour approbation
#--------------------------------------------------------------#
If GCHKBUD
 Gosub CHK_BUD
 Raz GCHKBUD
Endif
If GCHKAPP
 Gosub CHK_APP
 [M:ENV1]STA = [F:ENV]STA
 Affzo [M:ENV1]STA
 Raz GCHKAPP
Endif

# Impossibilité de supprimer une enveloppe 'à approuver', 'approuvée' ou 'fermée'
# ou si un budget exercice est en statut 'à approuver', 'approuvé' ou 'fermé'
# Interdiction de supprimer si ligne budgétaire

If [M:ENV1]STA<>1 | FLGBUT(0)=1
 Call VIREBOUT(CHAINE,"A") From GOBJET :# No Suppression Possible
Else
 For I=0 To [M:ENV1]NBFIY-1
  If [M:ENV1]STAFIY(I)<>1
   Call VIREBOUT(CHAINE,"A") From GOBJET :# No Suppression Possible
   Break
  Endif
 Next
Endif

Case GAPPNIV
 When "111","121","122","112" : #Nothing
 When Default : If USRENV="2" & GREP<>"C" & GREP<>"D" : CHMEN+="1" : Endif
Endcase

#Acces à la consultation des situations budgétaires si enveloppe existe
CHMEN+="3"

#------------------#
#  Consultations
#------------------#

#Acces à la consultation des révisions si existantes sur l'enveloppe
If FLGBUT(1)=1
 CHMEN +="2"
Endif

#Acces à la consultation des révisions si existantes sur l'enveloppe
If FLGBUT(2)=1
 CHMEN +="9"
Endif

#Acces aux signatures 11/02/09
#Approbation En-cours
If FLGBUT(3)=1
 CHMEN+="4"
Endif

 #En-cours Révision
If FLGBUT(4)=1
 CHMEN+="5"
Endif

 #Historique Approbation
If FLGBUT(5)=1
 CHMEN+="6"
Endif

 #Historique Révision
If FLGBUT(6)=1
 CHMEN+="7"
Endif

#Acces au détail des achats

# Performance : 95901
# The loop (For [BUA]) is only executed if the envelope changes. Once the enveloppe is approved, [M]BUD can not be changed.
# Entry commitments (Invoice, order, purchase request) is done from approved enveloppes, and existing budget lines.
# Once a budget line exists in the enveloppe, [M]FCY can not be changed

If [M]ENV<>OLDENV
 Local Char CRITBUA(250)
 Local Integer PURBNG
 If !clalev([PIH]) : Local File PINVOICE  [PIH] : Endif
 If !clalev([PSH]) : Local File PREQUIS   [PSH] : Endif
 If !clalev([POH]) : Local File PORDER    [POH] : Endif
 If !clalev([HAE]) : Local File GACCENTRY [HAE] : Endif

 CRITBUA ='BUD="'+[M]BUD+'"'
 If [M]BUD<>[F:BUP]BUD
  Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
 Endif
 If [F:BUP]LEV=1
  CRITBUA -='& CPY="'+[M]FCY+'"'
 Else
  If [M]FCY<>""
   CRITBUA -='& FCY="'+[M]FCY+'"'
  Endif
 Endif
 CRITBUA -='& find("'+[F:BUP]DIE(0)+'",[F:BUA]DIE(0..8))'
 CRITBUA -='& find("'+[F:BUP]DIE(1)+'",[F:BUA]DIE(0..8))'
 CRITBUA -='& find("'+[M]ENV+'",[F:BUA]CCE(0..8))'

 PURBNG=0

 Filter [BUA] Where evalue(CRITBUA)
 For [BUA]BUA0
  Case [F:BUA]TYP
   When 1 :#Demande d'achat
    Look [PSH]PSH0=[F:BUA]NUM
    If !fstat
     PURBNG+=1
    Endif
   When 2 :#Commande
    Look [POH]POH0=[F:BUA]NUM
    If !fstat
     PURBNG+=1
    Endif
   When 3 :#Facture
    Look [PIH]PIH0=[F:BUA]NUM
    If !fstat
     PURBNG+=1
    Endif
   When 4,5 :#Facture/avoir à recevoir
    Look [HAE]HAE0=[F:BUA]TYPPCE;[F:BUA]NUM
    If !fstat
     PURBNG+=1
    Endif
  Endcase
  If PURBNG>0 : Break : Endif
 Next
 Filter [BUA]

 If PURBNG
  CHMEN+="8"
  GPURREQ = 1
 Else
  GPURREQ = 0
 Endif
 OLDENV = [M]ENV
Else
 If GPURREQ=1 : CHMEN +="8" : Endif
Endif

#-------------------------------#
# Autorisations de modification
#-------------------------------#

#--- Si statut de l'enveloppe est 'fermée', plus de modification possibles

If [M:ENV1]STA=4
 Call VIREBOUT(CHAINE,"M") From GOBJET :# No Modification Possible
Endif

#---Ou si il existe une révision en cours sur l'enveloppe ou un budget
If 1=2
Local Integer BRV : BRV=1
For [BRV]BRV0 Where STA=2 & [F:BRV]ENV=[M]ENV
 If [F:BRV]TYP=1 | [F:BRV]TYP=2  : BRV=0 : Break : Endif
 If [F:BRV]TYP=4
  Filter [BVD] Where NUMREV=[F:BRV]NUM & (TYP=1 | TYP=2)
  Look [BVD]BVD0 First
  If !fstat : BRV=0 : Break : Endif
  Filter [BVD]
 Endif
Next
If !BRV
 #Objet de l'enveloppe en cours de révision. Modification impossible.
 #Call MESSAGE(mess(181,108,1)) From GESECRAN
 Call VIREBOUT(CHAINE,"M") From GOBJET :# No Modification Possible
Endif
Endif :#1=2

#-------------------#
# Changement de clé #
#-------------------#
#On interdit tout changement de clé, il y a trop de tables potentiellement impactées.
#**Key change is forbidden, there are too many tables involve.
Call VIREBOUT(CHAINE,"H") From GOBJET :# No Chgmnt de clé Possible
Return

$RAZCRE
# Alimentation de l'entité responsable automatisée en fonction de l'utilisateur
Read [AUS]CODUSR = GUSER
If fstat : Raz [F:AUS] : Endif
If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAMUTIL("GDDENTUSR",ENTUSR,"","") From SUBAUS
Endif   # Issue X3-107197
If ENTUSR<>""
 [M:ENV1]ENTMNA=ENTUSR
 Read [ENT]ENT0 = ENTUSR
 If !fstat
  If [F:ENT]ACS<>""    : [M:ENV1]ACS   =[F:ENT]ACS    : Endif
  If [F:ENT]ENTRAT<>"" : [M:ENV1]ENTRAT=[F:ENT]ENTRAT : Endif
  If [F:ENT]ENTAPP<>"" : [M:ENV1]ENTAPP=[F:ENT]ENTAPP : Endif
 Endif
 Affzo [M:ENV1]ENTMNA,ENTAPP,ENTRAT
Endif
Raz FLGBUT
Return

$RAZDUP
Global Char GENVDUP(GLONENV)
GENVDUP=[F:ENV]ENV
If [M:ENV1]EXTBUD=2
 Raz [M]AMTENV,AMTRES,AMTBUDFIY,AMTRESFIY
Endif
[M:ENV1]STA=1
For I=0 To [M:ENV1]NBFIY-1
 [M:ENV1]STAFIY(I)=1
Next
Actzo [M:ENV1]AMTENV,NBFIY,PRJ,FCY,ENTMNA,EXTBUD,ACS
Raz [M:ENV1]APPDAT,REVDAT,AMTAPP,AMTAPPFIY,APPDATFIY,REVDATFIY,INFORECOND,INFOENVORG
Gosub INFO_MONTANT
Affzo [M:ENV1]
Raz FLGBUT
Return

$VERIF_CRE
If [M:ENV1]FCY=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 zonsui="[M:ENV1]FCY"
 OK=0 : Return
Endif
If [M:ENV1]ENTMNA=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 zonsui="[M:ENV1]ENTMNA"
 OK=0 : Return
Endif
Call LECTURE("ENT",[M:ENV1]ENTMNA,"") From CONTOBJ
If [F:ENT]CPY<>""
 If [F:ENT]CPY<>[M:ENV1]SOCIETE
  #Incohérence entre la société de l'entité responsable et la société de l'enveloppe
  GMESSAGE = mess(154,108,1)
  zonsui="[M:ENV1]ENTMNA"
  OK=0 : Return
 Endif
Endif
If [M:ENV1]REASTR=[0/0/0]
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 zonsui="[M:ENV1]REASTR"
 OK=0 : Return
Endif
If [M:ENV1]REAEND=[0/0/0]
 Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
 If [F:BUT]YEAFLG = 1
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  zonsui="[M:ENV1]REAEND"
  OK=0 : Return
 Endif
Endif
If [M:ENV1]AMTENV=0 & [M:ENV1]EXTBUD=1
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 zonsui="[M:ENV1]AMTENV"
 OK=0 : Return
Endif

# Vérification montant budgetisé par rapport aux lignes dupliquées
If GREP="D" & dim(GENVDUP)>0 & GENVDUP<>"" & [M]EXTBUD<>2
 Local Decimal SOM_BUD_DUP
 For I=0 To [M:ENV1]NBFIY-1
  SOM_BUD_DUP=0
  Filter [BUD2] Where evalue('CCE'+num$([M:ENV1]INDDIE))=GENVDUP & FIY=[M:ENV1]FIYNUM(I)
  For [BUD2]BUD0
   SOM_BUD_DUP+=[F:BUD2]AMT(0)
  Next
  If [M:ENV1]AMTBUDFIY(I)<SOM_BUD_DUP
   #Le montant disponible du budget ne peut être inférieur au montant ventilé dans les lignes
   GMESSAGE=[M:ENV1]FIYINT(I)-":"-mess(172,108,1)
   OK=0 : Break
  Endif
 Next
 Filter [BUD2]
 If OK=0 : Return : Endif
Endif
# Le compte budgétaire et l'entité destinatrice stockés au niveau des lignes budgétaires
# doit être compatible avec la société/site de l'enveloppe dupliquée
If GREP="D" & dim(GENVDUP)>0 & GENVDUP<>""
 Filter [BUD2] Where evalue('CCE'+num$([M:ENV1]INDDIE))=GENVDUP
 For [BUD2]BUD0
  # Compte budgétaire
  Call LEC_GAC([F:BUD2]ACC,[F:BUD2]COA) From CPTLEC
  If [F:GAC]FCY<>""
   If [F:BUP]LEV=1 : #Niveau societe
    Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M:ENV1]FCY,[M:ENV1]FCY,[F:GAC]ACC) From CFYSUB
   Elsif [F:BUP]LEV=2 : #Niveau site
    Call LEC_FCY([M:ENV1]FCY) From CPTLEC
    Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M:ENV1]FCY,[F:FCY]LEGCPY,[F:GAC]ACC) From CFYSUB
   Endif
   If mkstat = 2
    OK = 0 : GMESSAGE=mess(279,108,1)+"\"+GMESSAGE : mkstat = 0 : Break
   Endif
  Endif
  # Entité
  Call LEC_LED([F:BUD2]LED) From CPTLEC
  For I=0 To [F:LED]DIENBR-1
   Call LEC_DIE([F:LED]DIE(I)) From CPTLEC
   If [F:DIE]ENT=2 : Break : Endif
  Next
  Call LEC_CCE(evalue('[F:BUD2]CCE'+num$(I)),evalue('[F:BUD2]DIE'+num$(I))) From CPTLEC
  If [F:CCE]FCY<>""
   If [F:BUP]LEV=1 : #Niveau societe
    Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:ENV1]FCY,[M:ENV1]FCY,[F:CCE]CCE) From CFYSUB
   Elsif [F:BUP]LEV=2 : #Niveau site
    Call LEC_FCY([M:ENV1]FCY) From CPTLEC
    Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:ENV1]FCY,[F:FCY]LEGCPY,[F:CCE]CCE) From CFYSUB
   Endif
   If mkstat = 2
    OK = 0 : GMESSAGE=mess(279,108,1)+"\"+GMESSAGE : mkstat = 0 : Break
   Endif
  Endif
 Next
 Filter [BUD2]
 If OK = 0 : Return : Endif
Endif
Return

$INICRE
Local Integer STAT
Local Char    NUMENV(15)
Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
#Read [F:BUT]BUT0 = [M:ENV0]BUDTYP
#If !fstat
 If [F:BUT]MANCOU=1 | ([F:BUT]COU<>"" & [M:ENV0]ENV="")
  Call NUMERO([F:BUT]COU,[M:ENV1]SITE,[M:ENV1]REASTR,"",[L]NUMENV,STAT) From SUBANM
  If STAT = 0
   [F:ENV]ENV = [L]NUMENV
   [M:ENV0]ENV = [L]NUMENV
   Affzo [M:ENV0]ENV
  Else
   #Problème lors de la récupération du compteur
   GERR=1 : GMESSAGE = mess(60,199,1) : GOK=0 : Return
  Endif
 Endif
#Endif
Return

$CREATION
Gosub SAVENVFIY
Gosub TEXTRA
# En création d'une enveloppe, il faut créer une section analytique enveloppe sur l'axe
Gosub CRECCE
Return

$SAVENVFIY
#Ecriture de la table de ventilation par exercice
For nolign=1 To [M:ENV1]NBFIY
 Raz [F:ENF]
 [F:ENF]ENV       = [M:ENV0]ENV
 [F:ENF]FIYSTR    = [M:ENV1]FIYSTR(nolign-1)
 [F:ENF]FIYEND    = [M:ENV1]FIYEND(nolign-1)
 [F:ENF]FIYNUM    = [M:ENV1]FIYNUM(nolign-1)
 [F:ENF]AMTBUDFIY = [M:ENV1]AMTBUDFIY(nolign-1)
 [F:ENF]AMTAPPFIY = [M:ENV1]AMTAPPFIY(nolign-1)
 [F:ENF]AMTRESFIY = [M:ENV1]AMTRESFIY(nolign-1)
 [F:ENF]STAFIY    = [M:ENV1]STAFIY(nolign-1)
 [F:ENF]APPDATFIY = [M:ENV1]APPDATFIY(nolign-1)
 Write [ENF]
 If fstat
  GOK=0 : Call FSTA("ENF") From GLOCK : Break
 Endif
Next nolign
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("ENVELOPPE","DESTRA",CLECUR1,"","ENVELOPPE","DESTRA",[M:ENV0]ENV,"")  From ATEXTRA
 Call DUPTEXTRA("ENVELOPPE","SHOTRA",CLECUR1,"","ENVELOPPE","SHOTRA",[M:ENV0]ENV,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:ENV0]DESTRA,"ENVELOPPE","DESTRA",[M:ENV0]ENV,"") From ATEXTRA
Call MAJTEXTRA([M:ENV0]SHOTRA,"ENVELOPPE","SHOTRA",[M:ENV0]ENV,"") From ATEXTRA
Return

$APRES_CRE
If GREP="D" &  dim(GENVDUP)>0 & GENVDUP<>""
 Local Decimal VE_LIG2
 For I=0 To [M]NBFIY-1
   Trbegin [BUD2]
   Filter [BUD] Where evalue('CCE'+num$([M:ENV1]INDDIE))=GENVDUP & FIY=[M:ENV1]FIYNUM(I)
   For [BUD]BUD0
     Raz [BUD2]
     [F:BUD2]=[F:BUD]
     Case [M:ENV0]BUDLEV
      When 1 : [F:BUD2]CPY = [M:ENV1]SOCIETE
      When 2 : [F:BUD2]FCY = [M:ENV1]SITE
               [F:BUD2]CPY = [M:ENV1]SOCIETE
     Endcase
     [F:BUD2]ACCNUM = uniqid([F:BUD2])
     Assign'[F:BUD2]CCE'+num$([M:ENV1]INDDIE) With [M:ENV0]ENV
     If [M]EXTBUD=2
      Raz [F:BUD2]AMT,[F:BUD2]AMTAPP,[F:BUD2]AMTATT
     Endif
     Raz [F:BUD2]AMTAPP,AMTCMM,AMTCMMPRP,QTYCMM,QTYCMMPRP,AMTREA,AMTCCA,AMTCAP,AMTFAS
     Raz [F:BUD2]APPDAT,REVDAT,UPDDAT,UPDUSR
     [F:BUD2]STA=1
     [F:BUD2]CREUSR=GUSER
     [F:BUD2]CREDAT=date$
     Write [BUD2]
     If fstat :  GOK=0 : Call FSTA("BUD2") From GLOCK : Break : Endif
     VE_LIG2 += [F:BUD2]AMT(0)
   Next
   Commit
   Filter [BUD]
 Next
 Kill GENVDUP
 #Lignes
 [M]VE2    = VE_LIG2
 [M]VE3    = VE_LIG2
 [M]RAVE2  = VE_LIG2
 Affzo [M:ENV1]VE2,VE3,RAVE2 :#,EXTBUD
Endif
Return

$CHANGE
#changement de clé, suppresion de la section et recréation de celle-ci avec le nouveau code
If [M:ENV1]DIE<>""
 #annulation section
 Delete [CCE] Where DIE=[M:ENV1]DIE & CCE=OCODE
 If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Return : Endif
 Call SUPTEXTRA("CACCE","DESTRA",[M:ENV1]DIE,OCODE) From ATEXTRA
 Call SUPTEXTRA("CACCE","SHOTRA",[M:ENV1]DIE,OCODE) From ATEXTRA
 #creation section
 GOK = 1
 Raz [F:CCE]
 [F:CCE]DIE    = [M:ENV1]DIE
 [F:CCE]CCE    = NCODE
 [F:CCE]ENAFLG = 2
 [F:CCE]ACS    = [M:ENV1]ACS
 [F:CCE]VLYSTR = [M:ENV1]REASTR
 [F:CCE]VLYEND = [M:ENV1]REAEND
 [F:CCE]FCY    = [M:ENV1]FCY
 [F:CCE]BUDTRK = 2
 [F:CCE]IPT    = 2
 Write [CCE]
 If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Endif
 Call DUPTEXTRA("ENVELOPPE","DESTRA",OCODE,"","CACCE","DESTRA",[M:ENV1]DIE,NCODE)  From ATEXTRA
 Call DUPTEXTRA("ENVELOPPE","SHOTRA",OCODE,"","CACCE","SHOTRA",[M:ENV1]DIE,NCODE)  From ATEXTRA
Endif
Return

$AP_CHANGE
Call CHGTEXTRA("ENVELOPPE","DESTRA",[M:ENV0]ENV,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("ENVELOPPE","SHOTRA",[M:ENV0]ENV,"",NCODE,"") From ATEXTRA
Return

$CRECCE
If [M:ENV1]DIE<>""
 GOK = 1
 Raz [F:CCE]
 [F:CCE]DIE    = [M:ENV1]DIE
 [F:CCE]CCE    = [M:ENV0]ENV
 [F:CCE]ENAFLG = 2
 [F:CCE]ACS    = [M:ENV1]ACS
 [F:CCE]VLYSTR = [M:ENV1]REASTR
 [F:CCE]VLYEND = [M:ENV1]REAEND
 [F:CCE]FCY    = [M:ENV1]FCY
 [F:CCE]BUDTRK = 2
 [F:CCE]IPT    = 2
 Write [CCE]
 If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Endif
 Call DUPTEXTRA("ENVELOPPE","DESTRA",[M:ENV0]ENV,"","CACCE","DESTRA",[M:ENV1]DIE,[M:ENV0]ENV)  From ATEXTRA
 Call DUPTEXTRA("ENVELOPPE","SHOTRA",[M:ENV0]ENV,"","CACCE","SHOTRA",[M:ENV1]DIE,[M:ENV0]ENV)  From ATEXTRA
Endif
Return

$AVANT_MOD
Local Integer BRV : BRV=1
For [BRV]BRV0 Where STA=2 & [F:BRV]ENV=[M]ENV
 If [F:BRV]TYP=1 | [F:BRV]TYP=2  : BRV=0 : Break : Endif
 If [F:BRV]TYP=4
  Filter [BVD] Where NUMREV=[F:BRV]NUM & (TYP=1 | TYP=2)
  Look [BVD]BVD0 First
  If !fstat : BRV=0 : Break : Endif
  Filter [BVD]
 Endif
Next
If !BRV
 #Objet de l'enveloppe en cours de révision. Modification impossible.
 Call MESSAGE(mess(181,108,1)) From GESECRAN
 OK=0
Endif
Return

$MODIF
#-Suppression de la table ENVFIY
Delete [ENF] Where ENV=[M:ENV0]ENV
If fstat=1
 GOK=-1 : GLOCK="$ENVFIY"-[M:ENV0]ENV : Return
Endif
# Mise à jour des ventilations enveloppe/exercice
Gosub SAVENVFIY
# Mise à jour des textes traduissibles
Gosub TEXTRA
# Mise à jour de la section analytique
Gosub MODCCE
Return

$MODCCE
If [M:ENV1]DIE<>""
 Readlock [CCE]CCE0 = [M:ENV1]DIE;[M:ENV0]ENV
 If fstat=1
  GOK=-1 : GLOCK="$CACCE"-[M:ENV1]DIE-[M:ENV0]ENV : Return
 Elsif !fstat
  GOK = 1
  [F:CCE]ACS    = [M:ENV1]ACS
  [F:CCE]VLYSTR = [M:ENV1]REASTR
  [F:CCE]VLYEND = [M:ENV1]REAEND
  [F:CCE]FCY    = [M:ENV1]FCY
  Rewrite [CCE]
  If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Endif
  Call MAJTEXTRA([M:ENV0]DESTRA,"CACCE","DESTRA",[M:ENV1]DIE,[M:ENV0]ENV) From ATEXTRA
  Call MAJTEXTRA([M:ENV0]SHOTRA,"CACCE","SHOTRA",[M:ENV1]DIE,[M:ENV0]ENV) From ATEXTRA
 Endif
Endif
Return

$AV_VERF_ANU
If GREP<>"M"
 # Envx reconduite ou reportée sur EnvY
 If !clalev([F:ENV3]) : Local File ENVELOPPE [ENV3] : Endif
 #** EnvX renewed or carry-forwarded on EnvY
 #**Cancellation of EnvY
 Filter [ENV3] Where ENVRCD=[F:ENV]ENV
 For [ENV3]ENV0
  [F:ENV3]ENVRCD=""
  [F:ENV3]DRECOND=[0/0/0]
  Rewrite [ENV3]
  If fstat
   GOK=0 : Call FSTA("ENV3") From GLOCK
  Endif
 Next
 Filter [ENV3]
 #**Cancellation of EnvX
 Filter [ENV3] Where ENVORG=[F:ENV]ENV
 For [ENV3]ENV0
  [F:ENV3]ENVORG=""
  Rewrite [ENV3]
  If fstat
   GOK=0 : Call FSTA("ENV3") From GLOCK
  Endif
 Next
 Filter [ENV3]
Endif
#-Suppression de la table ENVFIY
Delete [ENF] Where ENV=[M:ENV0]ENV
If fstat=1
 GOK=-1 : GLOCK="$ENVFIY"-[M:ENV0]ENV : Return
Endif
Return

$AVANT_MODFIC
# Gestion modification en hors budget
If [F:ENV]EXTBUD=1 & [M:ENV1]EXTBUD=2
 Filter [BUD2] Where evalue('CCE'+num$([M:ENV1]INDDIE))=[F:ENV]ENV
 For [BUD2]BUD0
  Raz [F:BUD2]AMT(0)
  Raz [F:BUD2]AMTAPP,[F:BUD2]AMTATT
  Rewrite [BUD2]
  If fstat
  GOK=0 : Call FSTA("BUD2") From GLOCK
  Endif
 Next
 Filter [BUD2]
Endif
Return

$ANNULE
Gosub ANNULATION
# Annulation des textes traduisibles pour toutes les langues
Call SUPTEXTRA("ENVELOPPE","DESTRA",[M:ENV0]ENV,"") From ATEXTRA
Call SUPTEXTRA("ENVELOPPE","SHOTRA",[M:ENV0]ENV,"") From ATEXTRA
Return

$ANNULATION
If [M:ENV1]DIE<>""
 #En suppression d'une entité, il faut également supprimé la section créée
 Delete [CCE] Where DIE=[M:ENV1]DIE & CCE=[M:ENV0]ENV
 If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Return : Endif
 Call SUPTEXTRA("CACCE","DESTRA",[M:ENV1]DIE,[M:ENV0]ENV) From ATEXTRA
 Call SUPTEXTRA("CACCE","SHOTRA",[M:ENV1]DIE,[M:ENV0]ENV) From ATEXTRA
Endif
Return

$ABANDON
Actzo [M:ENV0]ENV
Return

$VERROU
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
Case [F:BUP]LEV
 When 1 : #Niveau societe
  Call LEC_CPY([F:ENV]FCY) From CPTLEC
 When 2 : #Niveau site
  Call LEC_FCY([F:ENV]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Endcase
Call SETMAINREF([F:CPY]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
Call LECLED([F:CPY]CPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
Call LEC_LED(CODLED) From CPTLEC
For I=0 To dim([F:LED]DIE)-1
 Call LEC_DIE([F:LED]DIE(I)) From CPTLEC
 If [F:DIE]ENV=2 : Break : Endif
Next
[L]SYMBOL = "CCE"+[F:ENV]ENV+"\"+[F:DIE]DIE
Lock =SYMBOL With lockwait=0
If fstat
 Unlock =SYMBOLE
 LOCKCCE =  0 : OK=0
Endif
LOCKCCE = 1
Return

$DEVERROU
If LOCKCCE : Unlock =SYMBOL : Endif
Return

$SEL_TABLE
Case TABLE
 When "SELBUP"
  Default File [BUP]
  CRITERE = "GDDFLG=2"
  OBJET   = "BUP"
 When "SELENV"
  Default File [ENV]
  Local Char SOCIETE(GLONCPY), SITE(GLONFCY)
  Local Integer SOC,J
  Global Char GLISTFCY(GLONFCY)(1..GNBSITE)
  CRITERE = "1=1"
  #param 1=> PROJET
  If PARAM(1)<>""
   CRITERE-='& PRJ="'+PARAM(1)+'"'
  Endif
  #param 2=> SOCIETE & param 3=> SITE
  If PARAM(2)<>""
   SOCIETE=PARAM(2)
   SOC=find(SOCIETE,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     GLISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
  Endif
  If PARAM(3)<>""
   SITE=PARAM(3)
   Call LECTURE("FCY",SITE,"") From CONTOBJ
   SOCIETE=[F:FCY]LEGCPY
   #CRITERE -= '& (FCY="'+SOCIETE+'" | FCY="'+SITE+'")'
   CRITERE -= '& FCY="'+SITE+'"'
  Else
   If PARAM(2)<>""
    CRITERE -= '& (FCY="'+SOCIETE+'" | find(FCY,GLISTFCY(1..'+num$(J)+')))'
   Endif
  Endif

  #param 4=> STATUT
  If PARAM(4)<>""
   CRITERE -= '& STA='+PARAM(4)
  Endif
  OBJET   = "ENV"
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELFCY"  : Gosub S_FCYENV
 When "SELENVO" : Gosub S_ENVO
Endcase
Return

$S_FCYENV
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Local Integer MAXDIM
MAXDIM=max(1,nbrecord([CPY]),nbrecord([FCY]))
Local Char TEXTE(GLONDES)(1..MAXDIM,1..2)
Local Char TEX(GLONDES)(1..MAXDIM)
TIT = mess(87,106,1) :# Choix société / site
TIT(1)=mess(6,26,1) :# Sociétés / Sites
TIT(2)=mess(30,109,1) :# Intitulé
Case [M:ENV0]BUDLEV
 When 1 : # Société
  If [M]PRJ<>""
   Call LECTURE("PRJ",[M]PRJ,"") From CONTOBJ
   For [AGC]AGC0 Where GRP=[F:PRJ]GCF
    Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
    Call SETMAINREF([F:AGC]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    Call LECLED([F:AGC]CPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
    Call LECTURE("LED",CODLED,"") From CONTOBJ
    If [F:LED]GDD=2 :# Référentiel Flagué Budgets opérationnels
     NBTEX += 1
     TEX(NBTEX)   = [F:CPY]CPY
     TEXTE(NBTEX,1) = [F:CPY]CPY
     TEXTE(NBTEX,2) = [F:CPY]CPYNAM
    Endif
   Next
  Else
   For [CPY]CPY0 Where CPYLEGFLG=2
    Call SETMAINREF([F:CPY]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    Call LECLED([F:CPY]CPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
    Call LECTURE("LED",CODLED,"") From CONTOBJ
    If [F:LED]GDD=2 :# Référentiel Flagué Budgets opérationnels
     NBTEX += 1
     TEX(NBTEX)   = [F:CPY]CPY
     TEXTE(NBTEX,1) = [F:CPY]CPY
     TEXTE(NBTEX,2) = [F:CPY]CPYNAM
    Endif
   Next
  Endif
 When 2 : # Site
  If [M]PRJ<>""
   Call LECTURE("PRJ",[M]PRJ,"") From CONTOBJ
   NBTEX=0
   For [FGR]FGR0 Where CPY=[F:PRJ]GCF
    Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
    Call SETMAINREF([F:FCY]LEGCPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    Call LECLED([F:FCY]LEGCPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
    Call LECTURE("LED",CODLED,"") From CONTOBJ
    If [F:LED]GDD=2 :# Référentiel Flagué Budgets opérationnels
     NBTEX += 1
     TEX(NBTEX)   = [F:FCY]FCY
     TEXTE(NBTEX,1) = [F:FCY]FCY
     TEXTE(NBTEX,2) = [F:FCY]FCYNAM
    Endif
   Next
   If NBTEX=0 & find([F:PRJ]GCF,GSITE(1..GNBSITE))
    Call LECTURE("FCY",[F:PRJ]GCF,"") From CONTOBJ
    NBTEX += 1
    TEX(NBTEX)   = [F:FCY]FCY
    TEXTE(NBTEX,1) = [F:FCY]FCY
    TEXTE(NBTEX,2) = [F:FCY]FCYNAM
   Endif
  Else
   For [FCY]FCY0
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    Call SETMAINREF([F:FCY]LEGCPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    Call LECLED([F:FCY]LEGCPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
    Call LECTURE("LED",CODLED,"") From CONTOBJ
    If [F:LED]GDD=2 :# Référentiel Flagué Budgets opérationnels
     NBTEX += 1
     TEX(NBTEX)   = [F:FCY]FCY
     TEXTE(NBTEX,1) = [F:FCY]FCY
     TEXTE(NBTEX,2) = [F:FCY]FCYNAM
    Endif
   Next
  Endif
Endcase
Return

#-------------------------------#
# Selection avec options        #
#-------------------------------#

$S_ENVO
#Action de selection utilisée dans les fonction de report d'enveloppe pluri-annuelles
#et de recondution d'enveloppe annuelle. Selon le cas PARAM(9), on construit le filtre sur
#les enveloppes de la même façon que dans ces fonction pour l'affichage des tableaux de sélection

If !clalev([ENV2]) : Local File ENVELOPPE [ENV2] : Endif
If !clalev([ENF2]) : Local File ENVFIY    [ENF2] : Endif
If !clalev([BUD2]) : Local File BUD       [BUD2] : Endif
If !clalev([BUT2]) : Local File BUDTYP    [BUT2] : Endif

Local Char SOCIETE(GLONCPY), SITE(GLONFCY)
Local Char CRITERE1(250),CRITERE2(250),CRITLIG(50)

Local Char TEXTE(GLONDES)(1..500,1..2)
Local Char TEX(GLONDES)(1..500)
Local Char INTENV
Local Integer SOC,J,ACHAT
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
Local Date DATDEB,DATFIN
Local Integer INDENV, INDENT, INDCCE3

TIT = mess(40,100,1)-mess(178,108,1) :# Choix Enveloppe
TIT(1)= mess(178,108,1) :# Enveloppe
TIT(2)= mess(30,109,1) :# Intitulé

CRITERE1 = "1=1"
#param 1=> PROJET
If PARAM(1)<>""
 If len(PARAM(1))>GLONPRJ
  CRITERE1-='&'-PARAM(1)
 Else
  CRITERE1-='& PRJ="'+PARAM(1)+'"'
 Endif
Endif
#param 2=> SOCIETE
If PARAM(2)<>""
 SOCIETE=PARAM(2)
 SOC=find(SOCIETE,GSOC(1..GNBSOC))
 J=0
 If SOC
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   J+=1
   LISTFCY(J)=[F:FCY]FCY
  Next
 Endif
Endif
#& param 3=> SITE
If PARAM(3)<>""
 If len(PARAM(3))>GLONFCY
  If evalue(seg$(PARAM(3),2,5))
   If PARAM(2)<>""
    CRITERE1 -= '& (FCY="'+SOCIETE+'" | find(FCY,LISTFCY(1..'+num$(J)+')))'
   Endif
  Else
   CRITERE1-='&'-PARAM(3)
  Endif
 Else
  SITE=PARAM(3)
  Call LECTURE("FCY",SITE,"") From CONTOBJ
  SOCIETE=[F:FCY]LEGCPY
  CRITERE1 -= '& FCY="'+SITE+'"'
 Endif
Else
 If PARAM(2)<>""
  CRITERE1 -= '& (FCY="'+SOCIETE+'" | find(FCY,LISTFCY(1..'+num$(J)+')))'
 Endif
Endif

#param 4=> STATUT
If PARAM(4)<>""
 For I=1 To len(PARAM(4))
  If I>1
   CRITERE1 -= '| STA='+mid$(PARAM(4),I,1)
  Else
   CRITERE1 -= '& (STA='+mid$(PARAM(4),I,1)
  Endif
 Next
 CRITERE1 += ')'
Endif

#param 5 => Date début &param 6 => Date fin
If PARAM(5)<>"" & PARAM(5)<>"[0/0/0]" & PARAM(5)<>"000000"
&  & PARAM(6)<>"" & PARAM(6)<>"[0/0/0]" & PARAM(6)<>"000000"
 DATDEB=PARAM(5)
 DATFIN=PARAM(6)
 CRITERE1 -= '& (REASTR<=['+format$(GFMD,DATFIN)+'] & REAEND>=['+format$(GFMD,DATDEB)+'])'
Endif

#PARAM(7) => COMPTE
CRITLIG="1=1"
If PARAM(7)<>""
CRITLIG -= '& ACC="'+PARAM(7)+'"'
Endif

CRITERE2="1=1"
#PARAM(8) => OPTIONA
If PARAM(8)<>""
CRITERE2 -= '&'-PARAM(8)
Endif

#PARAM(10) => ENTMNA
If PARAM(10)<>""
 If len(PARAM(10))>GLONENT
  CRITERE2 -='&'-PARAM(10)
 Else
  CRITERE2 -= '& ENTMNA="'+PARAM(10)+'"'
 Endif
Endif

#PARAM(11) => ENTAPP
If PARAM(11)<>""
If len(PARAM(11))>GLONENT
  CRITERE2 -='&'-PARAM(11)
 Else
  CRITERE2 -= '& ENTAPP="'+PARAM(11)+'"'
 Endif
Endif

# Param 9=> OPTION
# 1 = annuelle
# 2 = pluri-annuelle
Local Integer ENVOK,TYPOK
Local Libelle LEDTYPGEN, LEDTYPANA
Local Decimal EXERCICE
Local Decimal SOM_DISPO_LIG, DISPO_LIG
#

For [ENV2]ENV0  Where evalue(CRITERE1) & evalue(CRITERE2)
 TYPOK=0
 ENVOK=0
 If PARAM(9)<>""
  Read [BUT2]BUT0=[F:ENV2]BUDTYP
  If !fstat
   If [F:BUT2]YEAFLG=val(PARAM(9))
    TYPOK=1
   Else
    TYPOK=0
   Endif
  Endif
 Else
  TYPOK=1
 Endif
 Call SETMAINREF([F:ENV2]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call GETEXE([F:ENV2]SOCIETE,LEDTYPANA,DATDEB,EXERCICE) From CPTSUB
 Local Integer NBBUL : NBBUL=0
 Call GETGDDINDDIE([F:ENV2]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

 Case val(PARAM(9))
  When 0,1 :#annuelle Reconduction
   ENVOK=1
  When 2 :#pluri-annuelle report
   Call LECTURE("BUT",[F:ENV2]BUDTYP,"") From CONTOBJ
   If [F:BUT]YEAFLG=2 :# Pluri-annuelle
    Read [ENF]ENF0=[F:ENV2]ENV;EXERCICE
     If !fstat & [F:ENF]STAFIY<>4
      SOM_DISPO_LIG=0
      For [BUD] Where evalue(CRITLIG) & evalue('CCE'+num$(INDENV))=[F:ENV2]ENV & FIY=[F:ENF]FIYNUM & STA<>4
       NBBUL+=1
       #Alimentation des montants utiles
       DISPO_LIG=[F:BUD]AMT-[F:BUD]AMTREA-[F:BUD]AMTCMM-[F:BUD]AMTCMMPRP
       SOM_DISPO_LIG += DISPO_LIG
      Next
      If SOM_DISPO_LIG>0 | NBBUL=0
       ENVOK=1
      Endif
     Endif
   Endif
 Endcase
 If GFONCTION="CCLCAP"
  Call VERFLIGACH([F:ENV2]ENV,0,INDENV,ACHAT) From TRTBUOCAP
  If ACHAT : ENVOK=0 : Endif
 Endif
 If GFONCTION="REQAPP"
  If [F:ENV2]STA=3
   ENVOK=0
   For [ENF2]ENF0 Where ENV=[F:ENV2]ENV
    If [F:ENF2]STAFIY=1 : ENVOK=1 : Break : Endif
    For [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV & FIY=[F:ENF2]FIYNUM
     If [F:BUD2]STA=1 : ENVOK=1 : Break 2 : Endif
    Next
   Next
  Endif
 Endif
 If GFONCTION="REQREV"
  If [F:ENV2]STA=1
   ENVOK=0
   For [ENF2]ENF0 Where ENV=[F:ENV2]ENV
    If [F:ENF2]STAFIY=3 : ENVOK=1 : Break : Endif
    For [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV & FIY=[F:ENF2]FIYNUM
     If [F:BUD2]STA=3 : ENVOK=1 : Break 2 : Endif
    Next
   Next
  Endif
 Endif
 If GFONCTION="CONSBOA"
  If [F:ENV2]STA<>3 | [F:ENV2]STA<>2
   ENVOK=0
   For [ENF2]ENF0 Where ENV=[F:ENV2]ENV
    If [F:ENF2]STAFIY=3 | [F:ENF2]STAFIY=2 : ENVOK=1 : Break : Endif
    For [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV & FIY=[F:ENF2]FIYNUM
     If [F:BUD2]STA=3 | [F:BUD2]STA=2 : ENVOK=1 : Break 2 : Endif
    Next
   Next
  Endif
 Endif
 If GFONCTION="CONSBRV"
  If [F:ENV2]REVDAT=[0/0/0]
   ENVOK=0
   For [ENF2]ENF0 Where ENV=[F:ENV2]ENV
    If [F:ENF2]REVDATFIY<>[0/0/0] : ENVOK=1 : Break : Endif
    For [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV & FIY=[F:ENF2]FIYNUM
     If [F:BUD2]REVDAT<>[0/0/0] : ENVOK=1 : Break 2 : Endif
    Next
   Next
  Endif
 Endif
 If TYPOK & ENVOK & NBTEX<=dim([L]TEX)-1
  NBTEX += 1
  TEX(NBTEX)     = [F:ENV2]ENV
  TEXTE(NBTEX,1) = [F:ENV2]ENV
  Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV2]ENV,"") From ATEXTRA
  TEXTE(NBTEX,2) = INTENV
 Endif
Next
If NBTEX=0
 GMESSAGE=mess(104,199,1): #Aucun enregistrement pour ces sélections
 GERR=1
Endif
Return



###########################################################################################
##----------------------- Etiquettes des écrans ENVx 19/02/2008  ------------------------##
###########################################################################################

#######################################################################################
# ENV0 #
#######################################################################################
Subprog C_ENV(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
If VALEUR=""
 If [F:BUT]MANCOU=2 & [F:BUT]COU=""
  #Zone Obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Else
  [M:ENV0]ENV=VALEUR
 Endif
Else
 Look [ENV]ENV0=VALEUR
 If fstat
  If [F:BUT]MANCOU=1
   #Compteur automatique
   Call MESSAGE(mess(193,108,1)) From GESECRAN
   Raz [M:ENV0]ENV
   Affzo [M:ENV0]ENV
  Endif
 Endif
Endif
End

#######################################################################################
Subprog C_BUDTYP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUT",VALEUR,"") From CONTOBJ
If [F:BUT]YEAFLG=2
 [M:ENV1]RECOND=1
 Diszo [M:ENV1]RECOND
Else
 Actzo [M:ENV1]RECOND
Endif
End

#######################################################################################
Subprog AM_BUDTYP(VALEUR)
Variable Char    VALEUR()
If [M:ENV0]BUDTYP<>VALEUR
 Read [BUT]BUT0 = VALEUR
 If fstat
  #Type de budget inexistant
  GMESSAGE=mess(112,108,1) : mkstat=2 : End
 Endif
Endif
End

#######################################################################################
Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Read [BUP]BUP0 = VALEUR
If !fstat
 If [F:BUP]GDDFLG<>2
  #Le code budget doit être flagué dépense
  GMESSAGE = mess(110,108,1)
  mkstat =2 : End
 Endif
 [M:ENV0]BUDLEV = [F:BUP]LEV
 [M:ENV0]CURENV = [F:BUP]CUR
 Affzo [M:ENV0]
Endif
End

#######################################################################################
Subprog AP_BUD(VALEUR)
Variable Char    VALEUR()
Read [BUP]BUP0 = VALEUR
If !fstat
 [M:ENV0]CURENV = [F:BUP]CUR
 Affzo [M:ENV0]
Endif
End

#######################################################################################
# ENV1 #
#######################################################################################
Subprog C_PRJ(VALEUR)
Variable Char    VALEUR()
If [M:ENV1]SOCIETE<>""
 Local Char PRJENV
 If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAM([M:ENV1]SOCIETE,"GDDPRJENV",PRJENV) From ADOVAL
 Endif   # Issue X3-107197
 If val(PRJENV)=2 & VALEUR=""
  #L'enveloppe doit être rattachée à un projet
  GMESSAGE = mess(111,108,1)
  mkstat = 2
 Endif
Endif
If VALEUR<>""
 Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
 If [F:PRJ]CUR<>[M:ENV0]CURENV
  #Imcompatibilité des devises
  GMESSAGE=mess(208,108,1)
  mkstat=2
 Endif
Endif
End

#######################################################################################
Subprog AP_PRJ(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
 Call LECTURE("AGF",[F:PRJ]GCF,"") From CONTOBJ
 If [F:AGF]FLGCPY=1 & [M:ENV0]BUDLEV=1
  #Le projet, défini comme groupe de sites, n'est pas compatible avec le code budget (niveau société)
  GMESSAGE=mess(156,108,1)
  mkstat=2 : End
 Endif
 If [F:PRJ]ACS<>""
  Call CONTEXE([F:PRJ]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
Endif
Affzo [M:ENV1]
End

#######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif

Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR)

Case [M:ENV0]BUDLEV
 When 1 : #Niveau societe
  #La société existe?
  If !find(VALEUR,GSOC(1..GNBSOC))
   GMESSAGE = mess(81,116,1) :# Société incorrecte
   mkstat=2 : End
  Endif
  #06/10/09:Autorisation site
  Call CONTCPY(VALEUR) From CPTSUB
  #Si projet, la société fait-elle partie des sociétés du projet?
  If [M:ENV1]PRJ<>""
   Call LECTURE("PRJ",[M:ENV1]PRJ,"") From CONTOBJ
   If VALEUR<>[F:PRJ]GCF
    Read [AGC]AGC0 = [F:PRJ]GCF;VALEUR
    If fstat=5
     #La société saisie est incompatible (niveau ou valeur) avec le groupe/site du projet
     GMESSAGE=mess(157,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
  #Référentiel ana flagué GDD
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  Call SETMAINREF(VALEUR,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Call LECLED(VALEUR,LEDTYPANA,CODLED,DEVLED) From CPTDIV
  If DEVLED<>[M]CURENV
   #Incompatibilité entre la devise du code budget et celle du référentiel analytique principal pour cette société/site
   GMESSAGE=mess(212,108,1)
   mkstat=2 : End
  Endif
  Call LECTURE("LED",CODLED,"") From CONTOBJ
  If [F:LED]GDD<>2
   #Seules sont autorisées les sociétés dont le référentiel analytique principal est flagué Gestion des dépenses
   GMESSAGE = mess(114,108,1)
   mkstat=2 : End
  Else
   Read [BUP]BUP0 = [M:ENV0]BUD
   If !fstat & [F:LED]COA<>[F:BUP]COA
    # Incompatibilité entre le plan de comptes du budget et celui du référentiel analytique principal pour cette société/site
    GMESSAGE = mess(256,108,1)
    mkstat=2 : End
   Endif
   For I=0 To dim([F:LED]DIE)-1
    Call LECTURE("DIE",[F:LED]DIE(I),"") From CONTOBJ
    If [F:DIE]ENV=2
     [M:ENV1]INDDIE = I+1 : # DIE index in the ledger
     [M:ENV1]DIE=[F:DIE]DIE : Break
    Endif
   Next
   [M:ENV1]LEDTYP  = LEDTYPANA
   [M:ENV1]SOCIETE = [F:CPY]CPY
   [M:ENV1]SITE    = [F:CPY]MAIFCY
   [M:ENV1]INTFCY  = [F:CPY]CPYNAM
  Endif

 When 2 : #Niveau site
  #Le site existe?
  If !find(VALEUR,GSITE(1..GNBSITE))
   GMESSAGE = mess(82,116,1) :# Site incorrect
   mkstat=2 : End
  Endif
  #06/10/09:Autorisation site
  Call CONTFCY(VALEUR) From CPTSUB
  #Si projet, le site appartient-il à l'une des sociétés ou l'un des sites du projet?
  If [M:ENV1]PRJ<>""
   Call LECTURE("PRJ",[M:ENV1]PRJ,"") From CONTOBJ
   If VALEUR<>[F:PRJ]GCF
    #Call LECTURE("AGF",[F:PRJ]GCF,"") From CONTOBJ
    Read [FGR]FGR0 = [F:PRJ]GCF;VALEUR
    If fstat=5
     #Le site ne fait pas partie des sites du groupe du projet
     GMESSAGE=mess(158,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
  #Référentiel ana flagué GDD
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  Call SETMAINREF([F:FCY]LEGCPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Call LECLED([F:FCY]LEGCPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
  If DEVLED<>[M]CURENV
   #Incompatibilité entre la devise du code budget et celle du référentiel analytique principal pour cette société/site
   GMESSAGE=mess(212,108,1)
   mkstat=2 : End
  Endif
  Call LECTURE("LED",CODLED,"") From CONTOBJ
  If [F:LED]GDD<>2
   #Seules sont autorisées les sociétés/sites dont le référentiel analytique principal est flagué Gestion des dépenses
   GMESSAGE = mess(114,108,1)
   mkstat=2 : End
  Else
   Read [BUP]BUP0 = [M:ENV0]BUD
   If !fstat & [F:LED]COA<>[F:BUP]COA
    # Incompatibilité entre le plan de comptes du budget et celui du référentiel analytique principal pour cette société/site
    GMESSAGE = mess(256,108,1)
    mkstat=2 : End
   Endif
   For I=0 To dim([F:LED]DIE)-1
    Call LECTURE("DIE",[F:LED]DIE(I),"") From CONTOBJ
    If [F:DIE]ENV=2
     [M:ENV1]INDDIE = I+1 : # DIE index in the ledger
     [M:ENV1]DIE=[F:DIE]DIE : Break
    Endif
   Next
   [M:ENV1]LEDTYP  = LEDTYPANA
   [M:ENV1]SOCIETE = [F:FCY]LEGCPY
   [M:ENV1]SITE    = [F:FCY]FCY
   [M:ENV1]INTFCY  = [F:FCY]FCYNAM
  Endif
Endcase

#Si obligation de rattachement à un projet pour la société encours
If [M:ENV1]PRJ=""
 Local Char PRJENV
 If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAM([M:ENV1]SOCIETE,"GDDPRJENV",PRJENV) From ADOVAL
 Endif # Issue X3-107197
 If val(PRJENV)=2
  #L'enveloppe doit être rattachée à un projet
  Call MESSAGE(mess(111,108,1)) From GESECRAN
  zonsui="PRJ": End
 Endif
Endif

#Cohérence avec société de l'entité
If [M:ENV1]ENTMNA<>""
 Call LECTURE("ENT",[M:ENV1]ENTMNA,"") From CONTOBJ
 If [F:ENT]CPY<>""
  If [F:ENT]CPY<>[M:ENV1]SOCIETE
   #Incohérence entre la société de l'entité responsable et la société de l'enveloppe
   Call MESSAGE(mess(154,108,1)) From GESECRAN
  Endif
 Endif
Endif

#Cohérence entre les axes du code budget et les axes du référentiel de la société
Call LECLED([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,CODLED,DEVLED) From CPTDIV
Call LECTURE("LED",CODLED,"") From CONTOBJ
Call LECTURE("BUP",[M:ENV0]BUD,"") From CONTOBJ
#
#Local Integer NOKENT, NOKENV  : NOKENT=0 : NOKENV=0
#For I=0 To [F:LED]DIENBR-1
# Call LECTURE("DIE",[F:LED]DIE(I),"") From CONTOBJ
# If [F:DIE]ENT=2 & [F:LED]DIE(I)<>[F:BUP]DIE(0) : NOKENT=1 : Endif
# If [F:DIE]ENV=2 & [F:LED]DIE(I)<>[F:BUP]DIE(1) : NOKENV=1 : Endif
#Next
#If NOKENT | NOKENV
# #Incohérence entre les axes entité et enveloppe du référentiel de la société et ceux du paramétrage budget
# Call MESSAGE(mess(155,108,1)) From GESECRAN
#Endif
Local Integer OKENT, OKENV , OKDIE3
OKENT  = find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1))
OKENV  = find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1))
If [F:BUP]DIE(2)<>""
 OKDIE3 = find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1))
Else
 OKDIE3=1
Endif
If !OKENT | !OKENV | !OKDIE3
 # Le référentiel analytique principal de la société ne comporte pas l'ensemble des axes du paramètrage budget (+Code Budget)
 Call MESSAGE(mess(155,108,1)-"("-[F:BUP]BUD-")") From GESECRAN
 mkstat=2 : End
Endif

#Cohérence entre la legislation du code budget et celle de la société
Call LEC_CPY([M:ENV1]SOCIETE) From CPTLEC
Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
If [F:CPY]LEG<>"" & [F:BUT]LEG<>""
 If [F:CPY]LEG<>[F:BUT]LEG
  #Incohérence entre le code législation de cette société/site et celui du type de budget renseigné
  GMESSAGE=mess(257,108,1)
  mkstat=2 : End
 Endif
Endif
End

#######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Decimal EXED, EXEF : EXED=0 : EXEF=0
Local Date DDEB,DFIN,DATFIN
Call SETGLBAPP([M:ENV1]SOCIETE,GAPPNIV) From TRTGDD
If [M]PRJ<>""
 Call LECTURE("PRJ",[M]PRJ,"") From CONTOBJ
 Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[F:PRJ]REASTR,EXED) From CPTSUB
 If EXED=0
  #Il n'existe pas d'exercice pour les dates du projet sur cette société
  GMESSAGE=mess(159,108,1)
  mkstat=2 : End
 Else
  Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
  If [F:BUT]YEAFLG=1
   [M:ENV1]REASTR=[F:PRJ]REASTR
   Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXED,DDEB,DFIN) From CPTSUB
   [M:ENV1]REAEND=DFIN
  Else
   [M:ENV1]REASTR=[F:PRJ]REASTR
   DATFIN=[F:PRJ]REAEND
   While EXEF=0
    Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,DATFIN,EXEF) From CPTSUB
    If EXEF=0
     DATFIN=gdat$(day(DATFIN),month(DATFIN),year(DATFIN)-1)
    Endif
   Wend
   Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXEF,DDEB,DFIN) From CPTSUB
   [M:ENV1]REAEND=DFIN
  Endif
  Gosub SETEXETAB
 Endif
Else
 Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[M:ENV1]REASTR,EXED) From CPTSUB
 If EXED<>0 : Gosub SETEXETAB : Endif
Endif
End

#######################################################################################
Subprog D_ENTMNA(VALEUR)
Variable Char    VALEUR()
# ARV: A voir comment alimenter ce champ, si cela depend de l'utilisateur
#      & si 'non', comment contrôler ses droits
If 1=2
Local Char ENTUSR(GLONENT)
If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAMUTIL("GDDENTUSR",ENTUSR,"","") From SUBAUS
Endif   # Issue X3-107197
If ENTUSR<>""
 VALEUR=ENTUSR
 Read [ENT]ENT0 = ENTUSR
 If !fstat
  If [F:ENT]ACS<>""    : [M:ENV1]ACS   =[F:ENT]ACS    : Endif
  If [F:ENT]ENTRAT<>"" : [M:ENV1]ENTRAT=[F:ENT]ENTRAT : Endif
  If [F:ENT]ENTAPP<>"" : [M:ENV1]ENTAPP=[F:ENT]ENTAPP : Endif
 Endif
Endif
Endif :#1=2
End

#######################################################################################
Subprog C_ENTMNA(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ENT",VALEUR,"") From CONTOBJ
If [F:ENT]ENTFLG=1
 #Entité non flaguée 'Entité budgétaire'
 GMESSAGE=mess(160,108,1)
 mkstat=2 : End
Endif
If [F:ENT]CPY<>""
 If [F:ENT]CPY<>[M:ENV1]SOCIETE
  #Incohérence entre la société de l'entité responsable et la société de l'enveloppe
  GMESSAGE = mess(154,108,1)
  mkstat=2 : End
 Endif
Endif

If [F:ENT]ACS<>""
 If [M:ENV1]ACS<>"" & [F:ENT]ACS<>[M:ENV1]ACS
  #Attention: Le code d'acces de l'enveloppe est lié à celui de l'entité responsable
  GMESSAGE=mess(213,108,1)
  mkstat=2 : End
 Else
  Call CONTEXE([F:ENT]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif

 [M:ENV1]ACS = [F:ENT]ACS
 Grizo [M:ENV1]ACS
 Affzo [M:ENV1]ACS
Else
 Actzo [M:ENV1]ACS
 Affzo [M:ENV1]ACS
Endif

#82965
[M:ENV1]ENTAPP=[F:ENT]ENTAPP
[M:ENV1]ENTRAT=[F:ENT]ENTRAT
If [M:ENV1]ENTAPP<>[F:ENV]ENTAPP |  [M:ENV1]ENTRAT<>[F:ENV]ENTRAT
 mkstat=4 :#pour passer en modif de l'enveloppe
Endif
End

#######################################################################################
## Gestion des périodes et budgets exercices

Subprog AS_REASTR(VALEUR)
Variable Date    VALEUR
If [M:ENV1]FCY=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
End

#######################################################################################
Subprog C_REASTR(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0]
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif

Local Decimal EXERCICE
Local Date DDEB,DFIN

#Ctrl que la date appartient bien à un exercice définit pour cette société
Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,VALEUR,EXERCICE) From CPTSUB
If EXERCICE=0
 VALEUR=[M:ENV1]REASTR
 #Il n'y a pas d'exercice défini avec cette société/site pour cette date
 GMESSAGE=mess(161,108,1)
 mkstat=2 : End
Endif

#Si enveloppe annuelle et que la date de fin est déjà renseignée, on ne doit pas pouvoir
#saisir un date de début inférieure au premier jour de l'exercice
Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
If [M:ENV1]REAEND<>[0/0/0] & VALEUR<>[0/0/0] & [F:BUT]YEAFLG=1
 Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[M:ENV1]REAEND,EXERCICE) From CPTSUB
 Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXERCICE,DDEB,DFIN) From CPTSUB
 If VALEUR<DDEB
  VALEUR=DDEB
  #La date de début maximum ne doit pas être inférieure au premier jour de l'exercice
  GMESSAGE=mess(162,108,1)
  mkstat=2 : End
 Endif
Endif

#Projet
If [M:ENV1]PRJ<>""
 Call LECTURE("PRJ",[M:ENV1]PRJ,"") From CONTOBJ
 If VALEUR>[F:PRJ]REAEND
  zonsui = "[M:ENV1]PRJ"
  #La période de réalisation de l'enveloppe ne peut pas dépasser celle du projet
  GMESSAGE = mess(113,108,15)
  mkstat = 1 : End
 Endif
Endif

# Contrôle dates de validité avec les entités
If func SUBENV.CTL_ENT([M:ENV1]ENTMNA,VALEUR)=2 | func SUBENV.CTL_ENT([M:ENV1]ENTAPP,VALEUR)=2
& | func SUBENV.CTL_ENT([M:ENV1]ENTRAT,VALEUR)=2
 End
Endif

# Contrôle dates de validité du budget
If [M:ENV0]BUD<>""
 Call LEC_BUD([M:ENV0]BUD) From CPTLEC
 If ([F:BUP]VLYSTR<>[0/0/0] & VALEUR<[F:BUP]VLYSTR) | ([F:BUP]VLYEND<>[0/0/0] & VALEUR>[F:BUP]VLYEND)
  # Date incompatible avec les dates de validité du budget
  GMESSAGE = mess(277,108,1)-[M:ENV0]BUD-"\"-num$([F:BUP]VLYSTR)-"-"-num$([F:BUP]VLYEND)
  mkstat = 2 : End
 Endif
Endif
End

#######################################################################################
Funprog CTL_ENT(ENT,DAT)
Value Char ENT
Value Date DAT
If ENT<>""
 Call LEC_ENT(ENT) From CPTLEC
 If ([F:ENT]VLYSTR<>[0/0/0] & DAT<[F:ENT]VLYSTR) | ([F:ENT]VLYEND<>[0/0/0] & DAT>[F:ENT]VLYEND)
  # Date incompatible avec les dates de validité de l'entité
  GMESSAGE = mess(276,108,1)-ENT-"\"-num$([F:ENT]VLYSTR)-"-"-num$([F:ENT]VLYEND)
  mkstat = 2
 Endif
Endif
End mkstat

#######################################################################################
Subprog AM_REASTR(VALEUR)
Variable Date    VALEUR
If [M:ENV1]NBFIY<>0

 If VALEUR<[M:ENV1]REASTR
  [M:ENV1]REAEND=VALEUR
  #Sauvegarde du tableau des budgets exercices
  Gosub SAVBUDEXE
  #Reconstruction du tableau des budgets exercices
  Gosub RECBUDEXE
 Elsif VALEUR>[M:ENV1]REASTR
  #Sauvegarde du tableau des budgets exercices
  Gosub SAVBUDEXE
  For N=1 To NBBUD
   If E_FIYEND(N)<VALEUR
    If E_STAFIY(N)=3
     VALEUR=[M:ENV1]REASTR
     #On ne peut pas supprimer un budget exercice approuvé
     GMESSAGE=mess(163,108,1)
     mkstat=2 : End
    Elsif E_STAFIY(N)=1
     Filter [BUD] Where LEDTYP=[M:ENV1]LEDTYP & BUD=[M:ENV0]BUD & FIY=E_FIYNUM(N) &
&                       evalue('CCE'+num$([M:ENV1]INDDIE))=[M:ENV0]ENV
     Read [BUD]BUD0 First
     If !fstat
      VALEUR=[M:ENV1]REASTR
      #On ne peut pas supprimer un budget exercice comportant des lignes budgétaires
      GMESSAGE=mess(164,108,1)
      mkstat=2 : End
     Endif
     Filter [BUD]
    Endif
   Endif
  Next
  [M:ENV1]REASTR=VALEUR
  #Reconstruction du tableau des budgets exercices
  Gosub RECBUDEXE
 Endif

Else
 [M:ENV1]REASTR=VALEUR
 #Si enveloppe annuelle, alim auto du champ fin de période
 Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
 If VALEUR<>[0/0/0] & [F:BUT]YEAFLG=1
  Local Decimal EXERCICE
  Local Date DDEB,DFIN
  Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[M:ENV1]REASTR,EXERCICE) From CPTSUB
  Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXERCICE,DDEB,DFIN) From CPTSUB
  If DFIN<>[0/0/0]
   [M:ENV1]REAEND=DFIN
   Gosub SETEXETAB
   Affzo [M:ENV1]
  Endif
 Endif
Endif
End

#######################################################################################
Subprog AS_REAEND(VALEUR)
Variable Date    VALEUR
If [M:ENV1]FCY=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 zonsui="[M:ENV1]FCY"
 mkstat=2 : End
Endif
End

#######################################################################################
Subprog C_REAEND(VALEUR)
Variable Date    VALEUR
Local Decimal EXERCICE
Local Date DDEB,DFIN

#Ctrl que la date appartient bien à un exercice définit pour cette société
Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,VALEUR,EXERCICE) From CPTSUB
If EXERCICE=0
 #Il n'y a pas d'exercice défini avec cette société/site pour cette date
 GMESSAGE=mess(161,108,1)
 mkstat=2 : End
Endif

#Ctrl si enveloppe annuelle, date de fin doit être renseignée
Call LECTURE("BUT",[M:ENV0]BUDTYP,"") From CONTOBJ
If VALEUR=[0/0/0] & [F:BUT]YEAFLG<>2
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif

#Ctrl <= Date de fin d'exercice qd enveloppe annuelle
Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[M:ENV1]REASTR,EXERCICE) From CPTSUB
Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXERCICE,DDEB,DFIN) From CPTSUB
If VALEUR>DFIN & [F:BUT]YEAFLG<>2
 [M:ENV1]REAEND=[M:ENV1]REAEND : Affzo [M:ENV1]REAEND
 #La date de fin maximum ne doit pas être supérieure au dernier jour de l'exercice
 GMESSAGE = mess(165,108,1)
 mkstat=2 : End
Endif

#Ctrl si un projet est défini, la date de fin ne peut dépasser celle du projet
If [M:ENV1]PRJ<>""
 Call LECTURE("PRJ",[M:ENV1]PRJ,"") From CONTOBJ
 If VALEUR>[F:PRJ]REAEND
  zonsui = "[M:ENV1]PRJ"
  #La période de réalisation de l'enveloppe ne peut pas dépasser celle du projet
  GMESSAGE = mess(113,108,15)
  mkstat = 2 : End
 Endif
Endif

# Contrôle dates de validité avec les entités
If func SUBENV.CTL_ENT([M:ENV1]ENTMNA,VALEUR)=2 | func SUBENV.CTL_ENT([M:ENV1]ENTAPP,VALEUR)=2
& | func SUBENV.CTL_ENT([M:ENV1]ENTRAT,VALEUR)=2
 End
Endif

# Contrôle dates de validité du budget
If [M:ENV0]BUD<>""
 Call LEC_BUD([M:ENV0]BUD) From CPTLEC
 If ([F:BUP]VLYSTR<>[0/0/0] & VALEUR<[F:BUP]VLYSTR) | ([F:BUP]VLYEND<>[0/0/0] & VALEUR>[F:BUP]VLYEND)
  # Date incompatible avec les dates de validité du budget
  GMESSAGE = mess(277,108,1)-[M:ENV0]BUD-"\"-num$([F:BUP]VLYSTR)-"-"-num$([F:BUP]VLYEND)
  mkstat = 2 : End
 Endif
Endif
End

#######################################################################################
Subprog AM_REAEND(VALEUR)
Variable Date    VALEUR
If [M:ENV1]NBFIY<>0
 If VALEUR>[M:ENV1]REAEND
  [M:ENV1]REAEND=VALEUR
  #Sauvegarde du tableau des budgets exercices
  Gosub SAVBUDEXE
  #Reconstruction du tableau des budgets exercices
  Gosub RECBUDEXE
 Elsif VALEUR<[M:ENV1]REAEND
  #Sauvegarde du tableau des budgets exercices
  Gosub SAVBUDEXE
  For N=1 To NBBUD
   If E_FIYSTR(N)>VALEUR
    If E_STAFIY(N)=3
     VALEUR=[M:ENV1]REAEND : Affzo [M]REAEND
     #On ne peut pas supprimer un budget exercice approuvé
     GMESSAGE=mess(163,108,1)
     mkstat=2 : End
    Elsif E_STAFIY(N)=1
     Filter [BUD] Where LEDTYP=[M:ENV1]LEDTYP & BUD=[M:ENV0]BUD & FIY=E_FIYNUM(N) &
&                       evalue('CCE'+num$([M:ENV1]INDDIE))=[M:ENV0]ENV
     Read [BUD]BUD0 First
     If !fstat
      [M:ENV1]REAEND=[M:ENV1]REAEND : Affzo [M:ENV1]REAEND
      #On ne peut pas supprimer un budget exercice comportant des lignes budgétaires
      GMESSAGE=mess(164,108,1)
      mkstat=2 : End
     Endif
     Filter [BUD]
    Endif
   Endif
  Next
  [M:ENV1]REAEND=VALEUR
  #Reconstruction du tableau des budgets exercices
  Gosub RECBUDEXE
 Endif
Else
 [M:ENV1]REAEND=VALEUR
 Gosub SETEXETAB
 Affzo [M:ENV1]
Endif
End

#--------------------------------------------------------------------------------#
# Initialisation du tableau de ventilation enveloppe/exercice de la société(site)
# renseigné en fonction des dates de réalisation
#--------------------------------------------------------------------------------#
$SETEXETAB
#Useful variables
Local Decimal EXERCICE
Local Date DDEB,DFIN
Raz [M:ENV1]NBFIY
J=0
Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,[M:ENV1]REASTR,EXERCICE) From CPTSUB
If EXERCICE<>0
 While  J<dim([M:ENV1]FIYSTR) & DFIN<=[M:ENV1]REAEND
  Call DATEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,EXERCICE,DDEB,DFIN) From CPTSUB
  [M:ENV1]FIYNUM(J)=EXERCICE
  Read [FIY]FIY0 = [M:ENV1]SOCIETE;[M:ENV1]LEDTYP;EXERCICE
  [M:ENV1]FIYINT(J)=num$(EXERCICE)-"-"-[F:FIY]DESSHO
  If DDEB<[M:ENV1]REASTR
   [M:ENV1]FIYSTR(J)=[M:ENV1]REASTR
  Else
   [M:ENV1]FIYSTR(J)=DDEB
  Endif
  If DFIN>=[M:ENV1]REAEND
   [M:ENV1]FIYEND(J)=[M:ENV1]REAEND : Break
  Else
   [M:ENV1]FIYEND(J)=DFIN
  Endif
  J+=1
  Call GETEXE([M:ENV1]SOCIETE,[M:ENV1]LEDTYP,DFIN+1,EXERCICE) From CPTSUB
 Wend
[M:ENV1]NBFIY = J+1
Endif
Affzo [M:ENV1]30
Return

$SAVBUDEXE
#Sauvegarde des budgets exercice
Local Integer NBBUD : NBBUD=[M:ENV1]NBFIY
Local Date    E_FIYSTR(1..NBBUD)
Local Date    E_FIYEND(1..NBBUD)
Local Integer E_FIYNUM(1..NBBUD)
Local Char    E_FIYINT(20)(1..NBBUD)
Local Decimal E_AMTBUDFIY(1..NBBUD)
Local Decimal E_AMTAPPFIY(1..NBBUD)
Local Decimal E_AMTRESFIY(1..NBBUD)
Local Integer E_STAFIY(1..NBBUD)
Local Date    E_APPDATFIY(1..NBBUD)
For I=1 To NBBUD
 Raz E_FIYSTR(I), E_FIYEND(I), E_FIYNUM(I), E_FIYINT(I), E_AMTBUDFIY(I), E_AMTAPPFIY(I), E_AMTRESFIY(I), E_STAFIY(I), E_APPDATFIY(I)
Next
For I=1 To NBBUD
 E_FIYSTR(I)    = [M:ENV1]FIYSTR(I-1)
 E_FIYEND(I)    = [M:ENV1]FIYEND(I-1)
 E_FIYNUM(I)    = [M:ENV1]FIYNUM(I-1)
 E_FIYINT(I)    = [M:ENV1]FIYINT(I-1)
 E_AMTBUDFIY(I) = [M:ENV1]AMTBUDFIY(I-1)
 E_AMTAPPFIY(I) = [M:ENV1]AMTAPPFIY(I-1)
 E_AMTRESFIY(I) = [M:ENV1]AMTRESFIY(I-1)
 E_STAFIY(I)    = [M:ENV1]STAFIY(I-1)
 E_APPDATFIY(I) = [M:ENV1]APPDATFIY(I-1)
Next
Return

$RECBUDEXE
#Reconstruction du tableau des budgets exercices
Gosub SETEXETAB
For I=0 To [M]NBFIY-1
 J=0 : J=find([M:ENV1]FIYNUM(I),E_FIYNUM(1..NBBUD))
 If J
  [M:ENV1]FIYINT(I)    = E_FIYINT(J)
  [M:ENV1]AMTBUDFIY(I) = E_AMTBUDFIY(J)
  [M:ENV1]AMTAPPFIY(I) = E_AMTAPPFIY(J)
  [M:ENV1]AMTRESFIY(I) = E_AMTRESFIY(J)
  [M:ENV1]STAFIY(I)    = E_STAFIY(J)
  [M:ENV1]APPDATFIY(I) = E_APPDATFIY(J)
 Else
  Case GAPPNIV
   When "211","212"
    [M:ENV1]STAFIY(I)=[M:ENV1]STA
    [M:ENV1]APPDATFIY(I) = date$
  Endcase
 Endif
Next
Gosub INFO_MONTANT
Return

## Fin gestion budgets exercice
############################################################################################

Subprog C_EXTBUD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz [M:ENV1]AMTENV,AMTAPP,AMTRES,EXDPRC,VE,VE1,VE2,VE3,VE_ENG,VE_PREENG,VE_REA
 Raz [M:ENV1]RES1,RES2,RAVE,RAVE1,RAVE2,SOLDE1,SOLDE2
 Raz [M:ENV1]AMTBUDFIY,AMTRESFIY
 Grizo [M:ENV1]AMTENV,AMTRES,EXDPRC,AMTBUDFIY,AMTRESFIY
 Affzo [M:ENV1]
Else
 Actzo [M:ENV1]AMTENV,AMTRES,AMTAPP,EXDPRC,AMTBUDFIY,AMTRESFIY
Endif
End

#######################################################################################
Subprog C_AMTENV(VALEUR)
Variable Decimal VALEUR
If (VALEUR-[M]AMTRES) < [M]VE1
 [M]AMTENV=[M]AMTENV : Affzo [M]AMTENV
 #Le montant disponible de l'enveloppe ne peut être inférieur au montant ventilé dans le ou les budget(s) exercice(s)
 GMESSAGE=mess(166,108,1)
 mkstat=2
Endif
End

#######################################################################################
Subprog AM_AMTENV(VALEUR)
Variable Decimal VALEUR
[M]AMTENV=VALEUR
Gosub INFO_MONTANT
End

#######################################################################################
Subprog C_AMTRES(VALEUR)
Variable Decimal VALEUR
If ([M:ENV1]AMTENV-VALEUR ) < [M:ENV1]VE1
 [M:ENV1]AMTRES=[M:ENV1]AMTRES : Affzo [M:ENV1]AMTRES
 #Le montant saisi de réserve dépasse le disponible de l'enveloppe
 GMESSAGE=mess(166,108,1)
 mkstat=2
Endif
End

#######################################################################################
Subprog AM_AMTRES(VALEUR)
Variable Decimal VALEUR
[M:ENV1]AMTRES=VALEUR
Gosub INFO_MONTANT
End

#######################################################################################
Subprog C_AMTBUDFIY(VALEUR)
Variable Decimal VALEUR
#---------------------------------------------------------------------
#Ctrl que pas supérieur au montant disponible de l'enveloppe
#---------------------------------------------------------------------
Local Decimal SOMAMT
[M:ENV1]AMTBUDFIY(nolign-1)=VALEUR
SOMAMT=0
For I=0 To [M:ENV1]NBFIY
 SOMAMT += [M:ENV1]AMTBUDFIY(I)
Next
If SOMAMT>([M:ENV1]AMTENV-[M:ENV1]AMTRES)
 VALEUR=([M:ENV1]AMTENV-[M:ENV1]AMTRES)-(SOMAMT-VALEUR)
 #La somme des montants des budgets par exercice ne doit pas dépasser le montant disponible de l'enveloppe
 GMESSAGE=mess(116,108,1)
 mkstat=2
Endif
If [M]ENV<>""
 #---------------------------------------------------------------------
 #Ctrl que pas inférieur au montant ventilé dans les lignes
 #---------------------------------------------------------------------
 Local Decimal VE_LIG :  VE_LIG =0
 Filter [BUD] Where evalue('CCE'+num$([M:ENV1]INDDIE))=[M]ENV & FIY=[M]FIYNUM(nolign-1)
 For [BUD]BUD0
  VE_LIG += [F:BUD]AMT(0)
 Next
 Filter [BUD]
 If VE_LIG<>0 & (VALEUR-[F:ENF]AMTRESFIY)<VE_LIG
  #Le montant disponible du budget ne peut être inférieur au montant ventilé dans les lignes
  GMESSAGE=mess(172,108,1)
  mkstat=2
 Endif
Endif
End

#######################################################################################
Subprog AM_AMTBUDFIY(VALEUR)
Variable Decimal VALEUR
[M]AMTBUDFIY(nolign-1)=VALEUR
Case GAPPNIV
 When "211","212"
  [M:ENV1]AMTAPPFIY(nolign-1)=VALEUR
Endcase
Gosub INFO_MONTANT
End

#######################################################################################
Subprog C_AMTRESFIY(VALEUR)
Variable Decimal VALEUR
If VALEUR>=[M]AMTBUDFIY(nolign-1) & VALEUR<>0
 #Le montant de la réserve ne peut être supérieur ou égal au montant du budget exercice
 GMESSAGE=mess(118,108,1)
 mkstat=2
Endif
If [M]ENV<>""
 Local Decimal VENBUDLIG
  Filter [BUD] Where evalue('CCE'+num$([M:ENV1]INDDIE))=[M:ENV0]ENV & FIY=[M:ENV1]FIYNUM(nolign-1)
 For [BUD]BUD0
  VENBUDLIG += [F:BUD]AMT(0)
 Next
 Filter [BUD]
 If VENBUDLIG<>0 & ([M:ENV1]AMTBUDFIY(nolign-1)-VALEUR ) < VENBUDLIG
  VALEUR=AMTRESFIY(nolign-1)
  #Le montant saisi de réserve dépasse le disponible du budget
  GMESSAGE=mess(167,108,1)
  mkstat=2
 Endif
Endif
End

#######################################################################################
Subprog AM_AMTRESFIY(VALEUR)
Variable Decimal VALEUR
[M]AMTRESFIY(nolign-1)=VALEUR
Gosub INFO_MONTANT
End

#######################################################################################
Subprog IB_NBFIY
#Bouton 2 : Saisie/Consultation des lignes
If GREP="C" | GREP="D"
 Raz GBOUT2
Endif
#Bouton 3 : soumission pour approbation (APPCALL)
If [M]STAFIY(nolign-1)<>1 | GREP="C" | GREP="D"
 Raz GBOUT3
Endif
#Bouton 4 : Consultation des révision
Local Integer BOK, DOK : BOK=0 : DOK=0
Filter [BRV] Where TYP=2 & ENV=[M]ENV & FIY=[M]FIYNUM(nolign-1)
Look [BRV] First
If !fstat : BOK=1 : Endif
Filter [BRV]
Filter [BRV] Where TYP=4 & ENV=[M]ENV
 For [BRV]BRV0
  Filter [BVD] Where NUMREV=[F:BRV]NUM & TYP=2 & FIY=[M]FIYNUM(nolign-1)
  Look [BVD] First
  If !fstat : DOK=1 : Endif
  Filter [BVD]
 Next
Filter [BRV]
If !BOK & !DOK :  Raz GBOUT4 : Endif

#Bouton 6 : Détail des achats
Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
Local Char CRITBUA(250)
CRITBUA ='BUD="'+[M]BUD+'"'
CRITBUA -='& FIY='+num$([M]FIYNUM(nolign-1))
Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
If [F:BUP]LEV=1
 CRITBUA -='& CPY="'+[M]FCY+'"'
Else
 If [M]FCY<>""
  CRITBUA -='& FCY="'+[M]FCY+'"'
 Endif
Endif
CRITBUA -='& find("'+[F:BUP]DIE(0)+'",[F:BUA]DIE(0..8))'
CRITBUA -='& find("'+[F:BUP]DIE(1)+'",[F:BUA]DIE(0..8))'
CRITBUA -='& find("'+[M]ENV+'",[F:BUA]CCE(0..8))'
Local Integer PURBNG
Filter [BUA] Where evalue(CRITBUA)
PURBNG=0
# Issue X3-71287
If !clalev([PIH]) : Local File PINVOICE  [PIH] : Endif
If !clalev([PSH]) : Local File PREQUIS   [PSH] : Endif
If !clalev([POH]) : Local File PORDER    [POH] : Endif
If !clalev([HAE]) : Local File GACCENTRY [HAE] : Endif
For [BUA]BUA0
 Case [F:BUA]TYP
  When 1 :#Demande d'achat
   Look [PSH]PSH0=[F:BUA]NUM
   If !fstat
    PURBNG+=1
   Endif
  When 2 :#Commande
   Look [POH]POH0=[F:BUA]NUM
   If !fstat
    PURBNG+=1
   Endif
  When 3 :#Facture
   Look [PIH]PIH0=[F:BUA]NUM
   If !fstat
    PURBNG+=1
   Endif
  When 4,5,8 :#Facture/avoir à recevoir
   Look [HAE]HAE0=[F:BUA]TYPPCE;[F:BUA]NUM
   If !fstat
    PURBNG+=1
   Endif
 Endcase
Next
If !PURBNG
 Raz GBOUT6
Endif
Filter [BUA]
End

