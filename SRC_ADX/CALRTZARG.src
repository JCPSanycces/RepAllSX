#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog CALRTZ(CAS,BPR,COA,ACC,SITLIN,FACCUR,DATDOC,AMTHTLIN,AMTVATLIN,NBLIGNE,DUDPAY)
Value Integer CAS                   : # Cas s'appel : 1:Gestion factures/échéances   2:Gestion ordres de paiements
Value Char    BPR()                 : # Tiers
Value Char    COA                   : # Plan du référentiel général principal
Value Char    ACC()(0..)            : # Comptes du référentiel général principal
Value Char    SITLIN()(0..)
Value Char    FACCUR()
Value Date    DATDOC                : # Date facture si CAS=1 ; Date ordre de paiement si CAS=2
Value Decimal AMTHTLIN(0..)
Value Decimal AMTVATLIN(0..)
Value Integer NBLIGNE
Value Integer DUDPAY                : # N° échéance règlée (Passé uniquement lorsque CAS=2)

Local Integer NBRTZ                 : # Nb de retenues associées au founisseurs et valides
Local Integer NUMRET                : # Compteur retenues fournisseurs
Local Integer NBRET
Local Integer VU, IND

Local Char    SITE(GLONFCY)
Local Char    FCYSAT(GLONADI)
Local Char    ADRSIT(5)

Local Integer NOL, APPLIC, OKRTZ    : # Variables diverses
Local Integer NBRIT                 : # Nb de retenues
Local Integer TYPCHARGE
Local Integer SENS                  : # Sens
Local Integer ECH                   : # Compteur n° échéancce
Local Integer NBECH                 : # Nb échéance


Local Decimal BASNONIMP             : # Montant base non imposable
Local Decimal BASMINIMP             : # Montant mininum de base imposable
Local Decimal ARRODEV

Local Integer IND
Local Decimal LTHERITAMT, LTHERITAMTR, LRITBAS, LRITBASR, LRITAMT, LRITAMTR

Local Char    TRITCOD(GLONRTZ)(0..30)

Local Decimal ARODEV
Call LECDEV(FACCUR) From TRTDIV
ARODEV = [F:TCU]CURRND

Local Decimal ARODEV2
Call LECDEV(GCURSHR) From TRTDIV
ARODEV2 = [F:TCU]CURRND

Local Char    RTZCUR(GLONCUR)       : # devise de ritenzione = devise zone commune. Les montants dans la table de retenues
RTZCUR = GCURSHR                    : # sont renseignés en devise GCURSHR

Read [F:BPS]BPS0=[L]BPR

If [F:BPS]RITNBR = 0 : End : Endif
Local Char    CODRTZ(GLONRTZ)(0..[F:BPS]RITNBR-1)   : # Tableau des codes retenues valides associées au fournisseurs
Local Decimal RITBASFAC(0..[F:BPS]RITNBR-1)  : # Bases retenues pour la facture en devise de facture
Local Decimal RITBASRTZ(0..[F:BPS]RITNBR-1)  : # Bases retenues pour la facture en devise de ritenzione
Local Decimal RITAMTFAC(0..[F:BPS]RITNBR-1)  : # Montants retenue pour la facture en devise de facture
Local Decimal RITAMTFACR(0..[F:BPS]RITNBR-1) : # Montants retenue pour la facture en devise de ritenzione

Local Integer NB_RTZ
Local Decimal TTHERITAMT(0..dim([F:BPS]RITCOD)-1), TTHERITAMTR(0..dim([F:BPS]RITCOD)-1)
Local Decimal TRITBAS(0..dim([F:BPS]RITCOD)-1), TRITBASR(0..dim([F:BPS]RITCOD)-1)
Local Decimal TRITAMT(0..dim([F:BPS]RITCOD)-1), TRITAMTR(0..dim([F:BPS]RITCOD)-1)

If clalev([F:RIU])  = 0 : Local File RITDUD [RIU]  : Endif
If clalev([F:RIU2]) = 0 : Local File RITDUD [RIU2] : Endif

## Les bases et les montants retenues sont stockés dans RITDUD en négatif pour les avoirs
SENS = 1 : NBECH = 0 : NBRET = 0

If CAS = 1
 For [DUD]DUD1 Where ACCNUM=[F:PIH]ACCNUM
  SENS = [F:DUD]SNS*-1
  NBECH += 1

  ## Recherche des retenues applicables pour le founisseur. Si CAS=1, c'est la date d'échéance (date prévision du règlement) qui
  ## compte : sur une facture multi-échéances, les taux de retenues à appliquer peuvent être différents entre deux échéances
  ## d'une même facture
  For NUMRET =0 To [F:BPS]RITNBR-1
   Read [F:RTZ]RTZ0 = [F:BPS]RITCOD(NUMRET)
   If [F:RTZ]LEG=GCURLEG : # On applique uniquement les retenues qui correspondent à la législation courante....
    APPLIC = ([F:RTZ]STRDAT<=[F:DUD]DUDDAT) and ([F:RTZ]ENDDAT=[0/0/0] | [F:DUD]DUDDAT<=[F:RTZ]ENDDAT) # applicable
    If [F:RTZ]TYP=1 & APPLIC # Retenue sur reglement 'Valide'
     If !find([F:BPS]RITCOD(NUMRET),CODRTZ(0..NBRET))
      CODRTZ(NBRET)=[F:BPS]RITCOD(NUMRET)
      NBRET += 1
     Endif
    Endif
   Endif
  Next
 Next
Elsif CAS = 2
 For [DUD]DUD1 Where ACCNUM=[F:PIH]ACCNUM
  SENS = [F:DUD]SNS*-1
  NBECH += 1

  ## Recherche des retenues applicables pour le founisseur. Si CAS=2, c'est la date de l'ordre de paiement (DATDOC) qui
  ## compte : sur une facture multi-échéances, les taux de retenues à appliquer peuvent être différents entre deux échéances
  ## d'une même facture
  For NUMRET =0 To [F:BPS]RITNBR-1
   Read [F:RTZ]RTZ0 = [F:BPS]RITCOD(NUMRET)
   If [F:RTZ]LEG=GCURLEG : # On applique uniquement les retenues qui correspondent à la législation courante....
    APPLIC = ([F:RTZ]STRDAT<=DATDOC) and ([F:RTZ]ENDDAT=[0/0/0] | DATDOC<=[F:RTZ]ENDDAT) # applicable
    If [F:RTZ]TYP=1 & APPLIC # Retenue sur reglement 'Valide'
     If !find([F:BPS]RITCOD(NUMRET),CODRTZ(0..NBRET))
      CODRTZ(NBRET)=[F:BPS]RITCOD(NUMRET)
      NBRET += 1
     Endif
    Endif
   Endif
  Next
 Next
Endif

## Sauvegarde dans les tableaux des montants de retenues réelles enregistrées (des échéances ou une partie de l'échéance
## a pu être déjà règlée...)
Local Char    TABRITCOD0(GLONRTZ)(0..dim([F:RIU]RITCOD)-1)
Local Char    TABRITCOD1(GLONRTZ)(0..NBECH-1,0..dim([F:RIU]RITCOD)-1)
Local Decimal TABRITAMT0(0..dim([F:RIU]RITCOD)-1)
Local Decimal TABRITAMTR0(0..dim([F:RIU]RITCOD)-1)
Local Decimal TABRITAMT1(0..NBECH-1,0..dim([F:RIU]RITCOD)-1)
Local Decimal TABRITAMTR1(0..NBECH-1,0..dim([F:RIU]RITCOD)-1)
Raz TABRITCOD0, TABRITCOD1, TABRITAMT0, TABRITAMT1, TABRITAMTR0, TABRITAMTR1
For [RIU]RIU0 Where NUM=[F:PIH]NUM & TYPREC = 0
 For NUMRET = 0 To [F:RIU]NBRRIT-1
  If [F:RIU]RITCOD(NUMRET)<>"" & [F:RIU]RITAMT(NUMRET)<>0
   TABRITCOD0(NUMRET)  = [F:RIU]RITCOD(NUMRET)
   TABRITAMT0(NUMRET)  = [F:RIU]RITAMT(NUMRET)
   TABRITAMTR0(NUMRET) = [F:RIU]RITAMTRPT(NUMRET)
  Endif
 Next
Next
For [RIU]RIU0 Where NUM=[F:PIH]NUM & TYPREC = 1
 For NUMRET = 0 To [F:RIU]NBRRIT-1
  If [F:RIU]RITCOD(NUMRET)<>"" & [F:RIU]RITAMT(NUMRET)<>0
   TABRITCOD1([F:RIU]DUDLIG-1,NUMRET)  = [F:RIU]RITCOD(NUMRET)
   TABRITAMT1([F:RIU]DUDLIG-1,NUMRET)  = [F:RIU]RITAMT(NUMRET)
   TABRITAMTR1([F:RIU]DUDLIG-1,NUMRET) = [F:RIU]RITAMTRPT(NUMRET)
  Endif
 Next
Next

## On efface RIU
If CAS = 1
 ## On va calculer les retenues 'Théoriques' de chaque échéance par rapport aux dates d'échéances (on ne sait pas à quelle
 ## date se fera le règlement)
 Delete [RIU] Where NUM=[F:PIH]NUM
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-[F:PIH]NUM : End
 Endif
 Delete [RIU2] Where NUM=[F:PIH]NUM
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-[F:PIH]NUM : End
 Endif

Elsif CAS = 2
 # On va calculer les retenues de l'échéance à règler par rapport à la date de l'ordre de paiement
 Delete [RIU] Where NUM=[F:PIH]NUM & DUDLIG=DUDPAY & TYPREC=1
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-[F:PIH]NUM : End
 Endif
 Delete [RIU2] Where NUM=[F:PIH]NUM & DUDLIG=DUDPAY & TYPREC=1
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-[F:PIH]NUM : End
 Endif
Endif

Local Decimal RITBASDUD(0..NBECH-1,0..[F:BPS]RITNBR-1)  : # Bases retenues par échéance en devise de échéance (=facture)
Local Decimal RITBASDUDR(0..NBECH-1,0..[F:BPS]RITNBR-1) : # Bases retenues par échéance en devise de ritenzione
Local Decimal RITAMTDUD(0..NBECH-1,0..[F:BPS]RITNBR-1)  : # Montants retenue par échéance en devise de échéance (=facture)
Local Decimal RITAMTDUDR(0..NBECH-1,0..[F:BPS]RITNBR-1) : # Montants retenue par échéance en devise de ritenzione


## Parmi les retenues applicables sur le fournisseur, recherche des retenues applicables
## par rapport au type de charge
#Recherche des retenues applicables par rapport au compte parmi les
For NOL=0 To NBLIGNE-1 # boucle sur les lignes de facture
 Read [F:GAC]GAC0 = GPLAN(1);ACC(NOL)
 TYPCHARGE = [F:GAC]RITTYP
 For NUMRET=0 To NBRET-1
  Read [F:RTZ]RTZ0 = CODRTZ(NUMRET)
  If [F:RTZ]LEG=GCURLEG : # On applique uniquement les retenues qui correspondent à la législation courante....
   OKRTZ = 0
   If [F:RTZ]CAT = 7 : # Ingresos Brutos
    ## On applique la retenue type 'Ingresos Brutos' si le site de réception SITLIN(NOL) est associé
    ## à la province d'application de la retenue
    SITE = SITLIN(NOL)
    Gosub LIRE_PROVINCE
    If [F:RTZ]SAT="" | (FCYSAT<>"" & [F:RTZ]SAT=FCYSAT)
     OKRTZ = 1
    Endif
   Else
    OKRTZ = 1
   Endif
   # type de charge inclus dans la base ?
   If OKRTZ & TYPCHARGE<>0 & [F:RTZ]BAS(TYPCHARGE-1)=2
    Case [F:RTZ]BASRTZ
     When 1 : # Montant HT
      RITBASFAC(NUMRET) += AMTHTLIN(NOL)*SENS
     When 2 : # Montant TVA
      RITBASFAC(NUMRET) += AMTVATLIN(NOL)*SENS
     When 3 : # Cumul mensuel (retenue GANANCIAS)
      RITBASFAC(NUMRET) += AMTHTLIN(NOL)*SENS
    Endcase
   Endif
  Endif
 Next NUMRET
Next NUMLIG # fin boucle lignes

## On a toutes les retenues, on peut les calculer
Raz RITAMTFAC, RITAMTFACR
If CAS = 1
 ECH = 0
 For [DUD]DUD1 Where ACCNUM=[F:PIH]ACCNUM
  For NUMRET=0 To NBRET-1
   CODRET = CODRTZ(NUMRET)
   Read [F:RTZ]RTZ0 = CODRET
   APPLIC = ([F:RTZ]STRDAT<=[F:DUD]DUDDAT) and ([F:RTZ]ENDDAT=[0/0/0] | [F:DUD]DUDDAT<=[F:RTZ]ENDDAT) # applicable
   If APPLIC<>0
    Gosub CALCUL_RETENUE
   Endif
  Next
  Gosub CHARGE_RITDUD
  If GOK<1 : Break : Endif
  ECH += 1
 Next
 Gosub CHARGE_RITDUD0
 If GOK<1 : End : Endif
Elsif CAS = 2
 Read [DUD]DUD1 = [F:PIH]ACCNUM ; DUDPAY
 If !fstat
  ECH = DUDPAY-1
  For NUMRET=0 To NBRET-1
   CODRET = CODRTZ(NUMRET)
   Read [F:RTZ]RTZ0 = CODRET
   APPLIC = ([F:RTZ]STRDAT<=DATDOC) and ([F:RTZ]ENDDAT=[0/0/0] | DATDOC<=[F:RTZ]ENDDAT) # applicable
   If APPLIC<>0
    Gosub CALCUL_RETENUE
   Endif
  Next
  Gosub CHARGE_RITDUD
  If GOK<1 : End : Endif
 Endif
 Gosub CHARGE_RITDUD0
 If GOK<1 : End : Endif
Endif
If GOK<1 : End : Endif
End


$LIRE_PROVINCE
Read [FCY]FCY0 = SITE
If !fstat
 ADRSIT = [F:FCY]BPAADD
Endif
If ADRSIT <> ""
 Read [BPA]BPA0 = 3 ; SITE ; ADRSIT
 If !fstat
  FCYSAT = [F:BPA]SAT
 Endif
Endif
Return


########################################################################
# Programme de calcul retenue sans tenir compte des SEUILS
########################################################################
$CALCUL_RETENUE
Local Integer BASNONIMP, BASMINIMP
Call LECTURE("RTZ",CODRET,"") From CONTOBJ

# Minimun base imposable : si la base imposable est inférieure au montant paramétré dans [F:RTZ]BASMIN, on ne calcule
# pas la retenue
If RTZCUR<>FACCUR
 Call CONVERT (RTZCUR,FACCUR,"",0,[0/0/0],[F:RTZ]BASMIN,BASMINIMP,OK) From TRTDEV
Else
 BASMINIMP  = [F:RTZ]BASMIN
Endif
If BASMINIMP <>0
 If RITBASFAC(NUMRET)<BASMINIMP
  RITBASFAC(NUMRET) = 0
 Endif
Endif

If RITBASFAC(NUMRET) = 0
 RITBASRTZ(NUMRET) = 0 : RITAMTDUD(ECH,NUMRET)=0 : RITAMTDUDR(ECH,NUMRET)=0 : # Base nulle => Montant nul
 Return
Endif

## Base non nulle, on continue...

# Taux d'abattement sur la base de retenues
If [F:RTZ]BASRAT > 0
 RITBASFAC(NUMRET)*=((100-[F:RTZ]BASRAT)/100) # base abattue en devise facture
 Call ARRDEV(RITBASFAC(NUMRET),FACCUR) From TRTDIV # arrondi de la base
Endif

# Minimum de base non imposable (même principe que le taux, mais c'est un montant fixe...)
# NB : pour les retenues Ganancias (Cumul mensuel/taux par tranche, le 'Montant non imposable' sera exploité
# lors du calcul réel de retenues (afin de stocker la base d'origine dans la table de cumul mensuel)
If [F:RTZ]BASEXE<>0 & [F:RTZ]MET<>2
 If RTZCUR<>FACCUR
  Call CONVERT (RTZCUR,FACCUR,"",0,[0/0/0],[F:RTZ]BASEXE,BASNONIMP,OK) From TRTDEV
 Else
  BASNONIMP = [F:RTZ]BASEXE
 Endif
 RITBASFAC(NUMRET) = RITBASFAC(NUMRET) - BASNONIMP
Endif

# Conversion de la base en devise de ritenzione (alimentation du RITBASRTZ(NUMRET))

If FACCUR<>RTZCUR
 Call CONVERT(FACCUR,RTZCUR,"",0,[0/0/0],RITBASFAC(NUMRET),RITBASRTZ(NUMRET),OK) From TRTDEV
Else
 [L]RITBASRTZ(NUMRET) = RITBASFAC(NUMRET)
Endif

## On a la base de retenues pour la facture, on veut la base de retenues pour l'échéance...
COEFF = [F:DUD]AMTCUR/[F:PIH]AMTATI
RITBASDUD(ECH,NUMRET) = arr(RITBASFAC(NUMRET)*COEFF,ARODEV)
RITBASDUDR(ECH,NUMRET) = arr(RITBASRTZ(NUMRET)*COEFF,ARODEV2)

Case [F:RTZ]MET
 When 1: #---------------------- Taux simple ----------------------#

   RITAMTDUD(ECH,NUMRET) = RITBASDUD(ECH,NUMRET)*([F:RTZ]RAT(0)/100) # mt retenue

 When 2: #------------------- Taux par tranches -------------------#

  NUMSEUIL=0
  While [F:RTZ]BKT(NUMSEUIL)<>0 and RITBASRTZ(NUMRET)>[F:RTZ]BKT(NUMSEUIL)
   [L]NUMSEUIL+=1 # on passe dans la tranche supérieure
  Wend
  RITAMTDUD(ECH,NUMRET) = RITBASDUD(ECH,NUMRET)*([F:RTZ]RAT(NUMSEUIL)/100) # mt retenue

 When 3: #---------------- Taux par seuil mini-maxi ---------------#
  ## On ne s'en sert pas dans le cas de l'Argentine...

Endcase

If [F:RTZ]MET<>3
 # ARRONDI DU MONTANT DE LA RETENUE EN DEVISE DE FACTURE
 # CONVERSION DU MONTANT CALCULE : DEV. FACT. -> DEV. RTZ.
 Call ARRDEV(RITAMTDUD(ECH,NUMRET),FACCUR) From TRTDIV
 If RITAMTDUD(ECH,NUMRET)=0
  RITBASDUD(ECH,NUMRET) = 0 : RITBASDUDR(ECH,NUMRET) = 0 : RITAMTDUDR(ECH,NUMRET) = 0
 Elsif FACCUR<>RTZCUR Then
  Call CONVERT (FACCUR,RTZCUR,[F:CPY]ACCCUR,1,DATDOC,[L]RITAMTDUD(ECH,NUMRET),RITAMTDUDR(ECH,NUMRET),OK) From TRTDEV
 Else
  RITAMTDUDR(ECH,NUMRET) = RITAMTDUD(ECH,NUMRET)
 Endif
Endif
Return


########################################################################
# Alimentation table RITDUD
########################################################################
$CHARGE_RITDUD
## Enregistrements de type 'Détail' (TYPREG = 1)
NBRIT = 0
Raz [F:RIU]
For NUMRET=0 To NBRET-1
 If RITAMTDUD(ECH,NUMRET)<>0
  NBRIT += 1
  [F:RIU]RITCOD(NBRIT-1) = CODRTZ(NUMRET)
  ## Base + Montant 'théorique' retenues en devise facture
  [F:RIU]CUR = FACCUR
  [F:RIU]RITBAS(NBRIT-1)    = RITBASDUD(ECH,NUMRET)
  [F:RIU]THERITAMT(NBRIT-1) = RITAMTDUD(ECH,NUMRET)
  ## Base + Montant 'théorique' retenues en devise RTZCUR = GCURSHR
  [F:RIU]RITBASRPT(NBRIT-1)  = RITBASDUDR(ECH,NUMRET)
  [F:RIU]THERITAMTR(NBRIT-1) = RITAMTDUDR(ECH,NUMRET)

  RITAMTFAC(NBRIT-1)  += RITAMTDUD(ECH,NUMRET)
  RITAMTFACR(NBRIT-1) += RITAMTDUDR(ECH,NUMRET)

  ## Alimentation 'Montant document' ([F:RIU]AMTVCR). Va servir lors du calcul réel de retenues lorsqu'on ne paie
  ## pas en totalité le montant d'une échéance
  ## Pour les enregistrements de type détail (TYPREC=1) :
  ## - Dans AMTVCR(0), on indique le montant TTC de l'échéance
  [F:RIU]AMTVCR(0) = [F:DUD]AMTCUR

  ## S'il y avait des montants de retenues réelles déjà enregistrés, on les récupère...
  [F:RIU]RITAMT(NBRIT-1) = 0
  For IND = 0 To NBRET-1
   If [F:RIU]RITCOD(NBRIT-1)  = TABRITCOD1([F:DUD]DUDLIG-1,IND)
    [F:RIU]RITAMT(NBRIT-1)    = TABRITAMT1([F:DUD]DUDLIG-1,IND)
    [F:RIU]RITAMTRPT(NBRIT-1) = TABRITAMTR1([F:DUD]DUDLIG-1,IND)
   Endif
  Next
 Endif
Next

If NBRIT>0
 [F:RIU]TYPREC    = 1
 [F:RIU]NUM       = [F:PIH]NUM
 [F:RIU]DUDNUM    = [F:PIH]ACCNUM
 [F:RIU]DUDLIG    = [F:DUD]DUDLIG
 [F:RIU]NBRRIT   = NBRIT
 Write [RIU]
 If fstat
  GOK=0 : Call FSTA("RIU") From GLOCK : Break 2
 Endif
Endif
Return


$CHARGE_RITDUD0
If CAS = 1
 Local Decimal AMTVAT
 For I=0 To [F:PIH]NBRTAX-1
  If [F:PIH]TAX(I)<>""
   Call LEC_TVT_LEG(GCURLEG,[F:PIH]TAX(I)) From CPTLEC
   If !fstat & [F:TVT]VATTYP=1 : # Taxe de type TVA
    AMTVAT += [F:PIH]AMTTAX(I)
   Endif
  Endif
 Next
 ## Enregistrement de type 'Totalisation' (TYPREG = 0) : un seul enregistrement
 NBRIT = 0
 Raz [F:RIU2]
 For NUMRET=0 To NBRET-1
  If RITAMTFAC(NUMRET)<>0
   NBRIT += 1
   [F:RIU2]RITCOD(NBRIT-1) = CODRTZ(NUMRET)
   ## Base + Montant 'théorique' retenues en devise facture
   [F:RIU2]CUR = [F:PIH]CUR
   [F:RIU2]RITBAS(NBRIT-1)    = RITBASFAC(NUMRET)
   [F:RIU2]THERITAMT(NBRIT-1) = RITAMTFAC(NUMRET)
   ## Base + Montant 'théorique' retenues en devise RTZCUR = GCURSHR
   [F:RIU2]RITBASRPT(NBRIT-1)  = RITBASRTZ(NUMRET)
   [F:RIU2]THERITAMTR(NBRIT-1) = RITAMTFACR(NUMRET)

   ## Alimentation 'Montant document' ([F:RIU2]AMTVCR). Va servir dans le calcul du montant réel
   ## de retenue lorsque la base seuil est 'Par document'.
   ## Pour les enregistrements de type totalisation (TYPREC=0) :
   ## - Dans AMTVCR(0), on indique le montant HT du document
   ## - Dans AMTVCR(1), on indique le montant TVA du document (certaines retenues sont calculées sur le montant TVA...)
   If FACCUR<>RTZCUR
    Call CONVERT (FACCUR,RTZCUR,[F:CPY]ACCCUR,1,DATDOC,[F:PIH]AMTNOT,[F:RIU2]AMTVCR,OK) From TRTDEV
   Else
    [F:RIU2]AMTVCR(0) = [F:PIH]AMTNOT
   Endif

   If FACCUR<>RTZCUR
    Call CONVERT (FACCUR,RTZCUR,[F:CPY]ACCCUR,1,DATDOC,AMTVAT,[F:RIU2]AMTVCR,OK) From TRTDEV
   Else
    [F:RIU2]AMTVCR(1) = AMTVAT
   Endif

   ## S'il y avait des montants de retenues réelles déjà enregistrés, on les récupère...
   [F:RIU2]RITAMT(NUMRET) = 0
   For IND = 0 To NBRET-1
    If [F:RIU2]RITCOD(NBRIT-1)  = TABRITCOD0(IND)
     [F:RIU2]RITAMT(NBRIT-1)    = TABRITAMT0(IND)
     [F:RIU2]RITAMTRPT(NBRIT-1) = TABRITAMTR0(IND)
    Endif
   Next
  Endif
 Next

 If NBRIT>0
  [F:RIU2]TYPREC    = 0
  [F:RIU2]NUM       = [F:PIH]NUM
  [F:RIU2]DUDNUM    = [F:PIH]ACCNUM  : # Pas important pour les enregistrements type 'Totalisation'
  [F:RIU2]DUDLIG    = 1 : # Pas important pour les enregistrements type 'Totalisation'
  [F:RIU2]NBRRIT    = NBRIT
  Write [RIU2]
  If fstat
   GOK=0 : Call FSTA("RIU2") From GLOCK
  Endif
 Endif
 If GOK<1 : Return : Endif
Endif

If CAS = 1 | CAS = 2
 Readlock [RIU2]RIU0 = 0 ; [F:PIH]NUM ; [F:PIH]ACCNUM ; 1
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD2"-num$(0)-[F:PIH]NUM-num$([F:PIH]ACCNUM)-num$(1) : Return
 Elsif !fstat
  [F:RIU2]NBRRIT = 0 : Raz [F:RIU2]RITCOD : Raz [F:RIU2]THERITAMT : Raz [F:RIU2]THERITAMTR : Raz [F:RIU2]RITBAS : Raz [F:RIU2]RITBASRPT

  ## Dans l'enregistrement type 'Totalisation', il y a peut-être des codes retenues qui ne devraient
  ## plus y être et des retenues qui se rajoutent (cas d'une échéance qui est réglée plus tard = les retenues
  ## appliquées sont différentes de celles calculées à l'origine)
  NB_RTZ = 0
  Raz TRITCOD, TTHERITAMT, TTHERITAMTR, TRITBAS, TRITBASR, TRITAMT, TRITAMTR
  For [RIU]RIU0 Where TYPREC=1 & NUM=[F:RIU2]NUM & DUDNUM=[F:RIU2]DUDNUM
   For NUMRET = 0 To [F:RIU]NBRRIT-1
    If [F:RIU]RITCOD(NUMRET)<>"" & [F:RIU]THERITAMT(NUMRET)<>0
     IND = find([F:RIU]RITCOD(NUMRET),TRITCOD(0..NB_RTZ-1))
     If !IND
      TRITCOD(NB_RTZ)     = [F:RIU]RITCOD(NUMRET)
      TTHERITAMT(NB_RTZ)  = [F:RIU]THERITAMT(NUMRET)
      TTHERITAMTR(NB_RTZ) = [F:RIU]THERITAMTR(NUMRET)
      TRITBAS(NB_RTZ)     = [F:RIU]RITBAS(NUMRET)
      TRITBASR(NB_RTZ)    = [F:RIU]RITBASRPT(NUMRET)
      TRITAMT(NB_RTZ)     = [F:RIU]RITAMT(NUMRET)
      TRITAMTR(NB_RTZ)    = [F:RIU]RITAMTRPT(NUMRET)
      NB_RTZ += 1
     Else
      TTHERITAMT(IND-1)  += [F:RIU]THERITAMT(NUMRET)
      TTHERITAMTR(IND-1) += [F:RIU]THERITAMTR(NUMRET)
      TRITBAS(IND-1)     += [F:RIU]RITBAS(NUMRET)
      TRITBASR(IND-1)    += [F:RIU]RITBASRPT(NUMRET)
      TRITAMT(IND-1)     += [F:RIU]RITAMT(NUMRET)
      TRITAMTR(IND-1)    += [F:RIU]RITAMTRPT(NUMRET)
     Endif
    Endif
   Next
  Next
  [F:RIU2]NBRRIT = NB_RTZ
  For NUMRET = 0 To NB_RTZ-1
   [F:RIU2]RITCOD(NUMRET)     = TRITCOD(NUMRET)
   [F:RIU2]THERITAMT(NUMRET)  = TTHERITAMT(NUMRET)
   [F:RIU2]THERITAMTR(NUMRET) = TTHERITAMTR(NUMRET)
   [F:RIU2]RITBAS(NUMRET)     = TRITBAS(NUMRET)
   [F:RIU2]RITBASRPT(NUMRET)  = TRITBASR(NUMRET)
   [F:RIU2]RITAMT(NUMRET)     = TRITAMT(NUMRET)
   [F:RIU2]RITAMTRPT(NUMRET)  = TRITAMTR(NUMRET)
  Next
  Rewrite [RIU2]
  If fstat
   GOK=0 : Call FSTA("RIU2") From GLOCK
  Endif
 Endif
Endif
Gosub PAYPRT
Return



$PAYPRT
## Sur chaque enregistrement de type 'Détail' (TYPREC=1), on renseigne les codes retenues paramétrées en tant que paiement
## partiel = "Sur premier règlement", ceci afin que toutes les retenues paramétrées comme tel soient prises en
## compte dans le calcul de retenues et soient donc règlées lors de la 1ère échéance règlée
## Exemple : facture avec deux échéances :
## 1ère échéance  règlée le 15/12/2005 : retenue RIVASERV  (validité 2005) 10% ; Base retenue = 98 EUR
## 2ième échéance règléé le 01/02/2006 : retenue RIVASERV2 (validité 2006) 15% ; Base retenue = 98 EUR
## Ces deux retenues sont des retenues IVA, paramétrées avec paiement partiel = "Sur premier règlement"
## => lors du règlement de la 1ère échéance, on veut règler le retenue RIVASERV et la retenue RIVASERV2 (9.8+14.7=24.7)
For [RIU2]RIU0 Where TYPREC=0 & NUM=[F:RIU]NUM & DUDNUM=[F:RIU]DUDNUM
 For NUMRET = 0 To [F:RIU2]NBRRIT-1
  Read [RTZ]RTZ0 = [F:RIU2]RITCOD(NUMRET)
  If [F:RTZ]PAYPRT = 2
   For [RIU]RIU0 Where TYPREC=1 & NUM=[F:RIU2]NUM & DUDNUM=[F:RIU2]DUDNUM
    IND = find([F:RIU2]RITCOD(NUMRET),[F:RIU]RITCOD(0..dim([F:RIU]NBRRIT)-1))
    If !IND
     [F:RIU]NBRRIT += 1
     [F:RIU]RITCOD([F:RIU]NBRRIT-1)     = [F:RIU2]RITCOD(NUMRET)
     Rewrite [RIU]
     If fstat
      GOK=0 : Call FSTA("RIU") From GLOCK : Break 3
     Endif
    Endif
   Next
  Endif
 Next
Next
If GOK<1 : Return : Endif
Return

