#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIFLODUP                                                        #
# Manages Duplicate class for EDIFLO                                          #
# Author : RBA  + JUCON                                                       #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "FLOCODNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub FLOCODNEW_CONTROL
        When "PROPAGATE" : Gosub FLOCODNEW_PROPAGATE
      Endcase
    When "FLORELNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub FLORELNEW_CONTROL
        When "PROPAGATE" : Gosub FLORELNEW_PROPAGATE
      Endcase
    When Default
  Endcase
Return

####################################################################

$FLOCODNEW_CONTROL
  If this.FLOCODNEW <> ""
    this.FLOCODNEW = func EDILIBA.FORMATVAL("FLOCOD", this.FLOCODNEW)
  Endif
Return

$FLOCODNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("FLOCODNEW")
  ASTATUS = fmet this.ADELETEERROR("FLORELNEW")

  If this.FLOCODNEW <> "" and this.FLORELNEW <> ""
    If func CTRL_EXIST_FLO(this.FLOCODNEW,this.FLORELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("FLOCODNEW",mess(45,7779,1)-":"-this.FLOCODNEW+"~"+this.FLORELNEW,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$FLORELNEW_CONTROL
  If this.FLORELNEW <> ""
    this.FLORELNEW = func EDILIBA.FORMATVAL("FLOREL", this.FLORELNEW)
  Endif
Return

$FLORELNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("FLOCODNEW")
  ASTATUS = fmet this.ADELETEERROR("FLORELNEW")

  If this.FLOCODNEW <> "" and this.FLORELNEW <> ""
    If func CTRL_EXIST_FLO(this.FLOCODNEW,this.FLORELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("FLORELNEW",mess(45,7779,1)-":"-this.FLOCODNEW+"~"+this.FLORELNEW,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$AREAD_AFTER
  If this.FLOCOD <> "" and this.FLOREL <> ""
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = this.FLOCOD; this.FLOREL
    If !fstat
      this.FLODES    = [EFL]FLODES
      this.FLODESNEW = [EFL]FLODES-"(Copy)"
    Else
      this.FLODES    = ""
      this.FLODESNEW = ""
    Endif
    LogicClose File [EFL]
  Endif
Return

####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.FLOCODNEW <> "" and this.FLORELNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_FLO(this.FLOCODNEW,this.FLORELNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("FLORELNEW",mess(45,7779,1)-":"-this.FLOCODNEW+"~"+this.FLORELNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_FLO(this.FLOCOD, this.FLOREL, this.FLOCODNEW, this.FLORELNEW, this.FLODESNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.FLOCODNEW+"~"+this.FLORELNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.FLOCODNEW+"~"+this.FLORELNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_FLO(WFLOCOD,WFLOREL)
Value Char WFLOCOD
Value Char WFLOREL

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WFLOCOD <> "" and WFLOREL <> ""
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = WFLOCOD;WFLOREL
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EFL]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_FLO(WFLOCOD, WFLOREL, WFLOCOD_NEW, WFLOREL_NEW, WFLODES_NEW, WERR)
Value Char WFLOCOD
Value Char WFLOREL
Value Char WFLOCOD_NEW
Value Char WFLOREL_NEW
Value Char WFLODES_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK

  If WOK = [V]CST_AOK
    Local File EDIFLOD [EFLD]
    Filter [EFLD] Where FLOCOD = WFLOCOD and FLOREL = WFLOREL
    For [EFLD]
      If WOK = [V]CST_AOK
        Local File EDIFLOD [C_EFLD]
        Trbegin [C_EFLD]
        [C_EFLD]          = [EFLD]
        [C_EFLD]FLOCOD    = WFLOCOD_NEW
        [C_EFLD]FLOREL    = WFLOREL_NEW
        Write [C_EFLD]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIFLOD ("+mess(3,40,1)-num$([C_EFLD]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EFLD]
      Else
      #
      Endif
    Next
    Filter [EFLD]
    LogicClose File [EFLD]
  Endif

  # INI Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  If WOK = [V]CST_AOK
    Local File EDIFLOA [EFLA]
    Filter [EFLA] Where FLOCOD = WFLOCOD and FLOREL = WFLOREL
    For [EFLA]
      If WOK = [V]CST_AOK
        Local File EDIFLOA [C_EFLA]
        Trbegin [C_EFLA]
        [C_EFLA]          = [EFLA]
        [C_EFLA]FLOCOD    = WFLOCOD_NEW
        [C_EFLA]FLOREL    = WFLOREL_NEW
        Write [C_EFLA]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIFLOA ("+mess(3,40,1)-num$([C_EFLA]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_EFLA]
      Else
      #
      Endif
    Next
    Filter [EFLA]
    LogicClose File [EFLA]
  Endif

  If WOK = [V]CST_AOK
    Local File EDIFLOAP [EFLP]
    Filter [EFLP] Where FLOCOD = WFLOCOD and FLOREL = WFLOREL
    For [EFLP]
      If WOK = [V]CST_AOK
        Local File EDIFLOAP [C_EFLP]
        Trbegin [C_EFLP]
        [C_EFLP]          = [EFLP]
        [C_EFLP]FLOCOD    = WFLOCOD_NEW
        [C_EFLP]FLOREL    = WFLOREL_NEW
        Write [C_EFLP]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDIFLOAP ("+mess(3,40,1)-num$([C_EFLP]NUMSEQ)+")"
          Rollback
        Endif
        LogicClose File [C_EFLP]
      Else
      #
      Endif
    Next
    Filter [EFLP]
    LogicClose File [EFLP]
  Endif
# END  Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)

  If WOK = [V]CST_AOK
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = WFLOCOD;WFLOREL
    If !fstat
      Local File EDIFLO [C_EFL]
      Trbegin [C_EFL]
      [C_EFL]          = [EFL]
      [C_EFL]VALID     = [V]CST_ANO
      [C_EFL]FLGACT    = [V]CST_ANO
      [C_EFL]CACHEUUID = NullUuid()
      [C_EFL]FLODES    = WFLODES_NEW #[C_EFL]FLODES-"(Copy)"
      [C_EFL]FLOCOD    = WFLOCOD_NEW
      [C_EFL]FLOREL    = WFLOREL_NEW
      Write [C_EFL]
      If !fstat
        Commit
      Else
#        WOK = 3#[V]CST_AERROR
        WOK = [V]CST_AERROR
        WERR = "EDIFLO ("+mess(1,7983,1)+")"
        Rollback
      Endif
      LogicClose File [C_EFL]
    Else
#      WOK = 4#[V]CST_AERROR
      WOK = [V]CST_AERROR
      WERR = "EDIFLO ("+mess(7,7983,1)+")"
    Endif
    Filter [EFL]
    LogicClose File [EFL]
  Endif

End WOK

