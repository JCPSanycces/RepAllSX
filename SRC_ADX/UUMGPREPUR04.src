#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPREPUR04   Pre-migration Historiques de commandes      Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPREPUR04") From LECFIC
  Endif

  Call MAJ_UUMGPREPUR04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPREPUR04(DOSSIER)
Value Char DOSSIER

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Call ECR_TIME("UUMGPREPUR04 Purchase Orders Process : Update UPORDER-C") From DOSSUB
Call ECR_TRACE("UUMGPREPUR04 : Process Start on : "+DOSSIER,0) From GESECRAN
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPREPUR04 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#Fin MAE 386
Local Integer ERR
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
# Passage en V6
If val(VERSION)<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V6

  #--------------- Suppression index ----------#
  #Call MIGINDDEL (DOSSIER,"PORDER",ERR) From TRTMIG
  #If ERR : Goto FIN : Endif
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"UPORDER",ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Endif

# Passage en V7
If val(VERSION)<GMIGX3VER70
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV7
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V7

  #--------------- Suppression index ----------#
  #Call MIGINDDEL (DOSSIER,"PORDER",ERR) From TRTMIG
  #If ERR : Goto FIN : Endif
Endif
#Fin MAE 386
$FIN
Call ECR_TIME("UUMGPREPUR04 : Purchase Orders Process END.")  From DOSSUB
End
############################################################
$ADDCOLV6

  #1- ajouter la colonne dans la table POH
  Call MIGADDCOL (DOSSIER,"UPORDER","EECICT","A",20,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","EECLOC","C",2,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","EECNUM","A",20,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOADD","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPONAM","A",40,2,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOADDLIG","A",40,3,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOPOSCOD","A",10,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOCTY","A",40,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOSAT","A",40,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOCRY","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPOCRYNAM","A",40,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPAPAY","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"UPORDER","BPAINV","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  #--------------- Field ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"UPORDERC","","EECNUM2","A",20,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  #2- ajouter un index unique
  #--------------- INDEX ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"UPORDER","BPSNUM+POHNUM+REVNUM","","",0,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Return
############################################################
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
$ADDCOLV7
Return
############################################################
$TRT_X3_V7
Return
############################################################
############################################################
$TRT_X3_V6
Local Integer COMPTEUR


#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:UOH]) : Close File [UOH] : Endif
Local File =DOSSIER+".UPORDER"    [UOH]
Local File =DOSSIER+".UPORDERC"    [UOC]
Local File =DOSSIER+".BPARTNER"    [BPR]
Local File =DOSSIER+".BPSUPPLIER"  [BPS]
Local File =DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]

Local Char WBPS(GLONBPS),WBPR(GLONBPR)

If dim(GACTDEB)<1  Global Libelle  GACTDEB : Endif
If dim(GACTSAD)<1  Global Libelle  GACTSAD : Endif
#----- Code activité "SAD" Stockage systématique des adresses -----#
Read [ACV] CODACT="SAD"
If !fstat
  GACTSAD=[F:ACV]FLACT
Else
  GACTSAD=1
Endif
#----- Code activité "DEB" Déclaration échange de biens CEE -----#
Read [ACV] CODACT="DEB"
If !fstat
  GACTDEB=[F:ACV]FLACT
Else
  GACTDEB=2
Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2
Local Integer ICLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Link [UOH] With [BPS]BPS0=[F:UOH]BPSNUM As [LNK] Order By Key CLE=[F:UOH]BPSNUM;[F:UOH]POHNUM;[F:UOH]REVNUM

$LOOP_PUR03
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:UOH]BPSNUM=ACLE1 & [F:UOH]POHNUM=ACLE2& [F:UOH]REVNUM>ICLE3"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:UOH]BPSNUM=ACLE1 & [F:UOH]POHNUM>ACLE2"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:UOH]BPSNUM>ACLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [UOH]
GOK = 1

For [LNK]CLE Where evalue(CRITERE)

  # --- alimentation des champs et écriture enreg
  Gosub MAJ30_UOH
  If GOK<1 : Break : Endif

  If [F:UOH]POHTYP=2
    For [UOC]POC0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
        Gosub MAJ30_UOC
        If GOK<1 : Break : Endif
        Rewrite [F:UOC]
        If fstat
          Call ECR_TRACE("File UPORDERC(POHNUM/LINREVNUM/POPLIN)"-[F:UOC]POHNUM-num$([F:UOC]LINREVNUM)-num$([F:UOC]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
          GOK=0 : Break
        Endif
    Next
  Endif
  If GOK<1 : Break : Endif

  Rewrite [F:UOH]
  If fstat
    Call ECR_TRACE("File UPORDER(POHNUM/REVNUM)"-[F:UOH]POHNUM-num$([F:UOH]REVNUM)+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:UOH]BPSNUM
    ACLE2 = [F:UOH]POHNUM
    ICLE3 = [F:UOH]REVNUM
    STOP=1
    Break
  Endif
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_PUR03
  Endif
Endif

$FIN_1
Gosub UNSET_FIRST From TRTFIRST
Close Local File [UOH],[UOC],[ACV],[BPS],[BPR],[BPA]
Call ECR_TIME("UUMGPREPUR04 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
Return
##############################################################################################
$MAJ30_UOH
    Gosub LECT_BPSPOH
    #----- Alimentation des informations douanières si commande classique -----#
    If [F:UOH]POHTYP<>2
      #----- Alimentation incoterm et lieu de transport CEE -----#
      If [F:UOH]EECICT=""
        [F:UOH]EECICT=[F:BPS]EECICT : # Incoterm
      Endif
      If GACTDEB=2 & [F:UOH]EECLOC=0
        [F:UOH]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
      Endif
      #----- Alimentation identification CEE du tiers facturant -----#
      If GACTDEB=2 & [F:UOH]EECNUM=""
        Gosub LECT_BPRI
        [F:UOH]EECNUM=[F:BPR]EECNUM : # Identification CEE
      Endif
    Endif

    If [F:UOH]BPOADD=""
      #----- Si fournisseur divers, adr.commande = adr.expédition -----#
      If [F:BPS]BPSTYP=3
        [F:UOH]BPOADD      =[F:UOH]BPAADD
        [F:UOH]BPONAM(0)   =[F:UOH]BPRNAM(0)
        [F:UOH]BPONAM(1)   =[F:UOH]BPRNAM(1)
        [F:UOH]BPOADDLIG(0)=[F:UOH]BPAADDLIG(0)
        [F:UOH]BPOADDLIG(1)=[F:UOH]BPAADDLIG(1)
        [F:UOH]BPOADDLIG(2)=[F:UOH]BPAADDLIG(2)
        [F:UOH]BPOPOSCOD   =[F:UOH]POSCOD
        [F:UOH]BPOCTY      =[F:UOH]CTY
        [F:UOH]BPOSAT      =[F:UOH]SAT
        [F:UOH]BPOCRY      =[F:UOH]CRY
        [F:UOH]BPOCRYNAM   =[F:UOH]CRYNAM
      #----- alimentation code adresse expédition -----#
      Else
        If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
          Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]BPOADD=[F:BPR]BPAADD
        If GACTSAD=2 : # Stockage systématique de l'adresse !
          #----- Lecture BPARTNER si nécessaire -----#
          Gosub LECT_BPRS
          #----- Lecture de l'adresse si nécessaire -----#
          Gosub LECT_BPAS
          #-----
          [F:UOH]BPONAM(0)    = [F:BPR]BPRNAM(0)
          [F:UOH]BPONAM(1)    = [F:BPR]BPRNAM(1)
          [F:UOH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:UOH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:UOH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:UOH]BPOCRY       = [F:BPA]CRY
          [F:UOH]BPOCRYNAM    = [F:BPA]CRYNAM
          [F:UOH]BPOSAT       = [F:BPA]SAT
          [F:UOH]BPOPOSCOD    = [F:BPA]POSCOD
          [F:UOH]BPOCTY       = [F:BPA]CTY
        Endif
      Endif
    Endif

    #----- Alimentation code adresse fournisseur payé -----#
    If [F:UOH]BPAPAY=""
      If [F:BPS]BPRPAY=[F:UOH]BPRPAY
        If [F:BPR]BPRNUM<>[F:BPS]BPRPAY
          Read [BPR] BPR0=[F:BPS]BPRPAY : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]BPAPAY=[F:BPR]BPAADD
      Else
        Gosub LECT_BPSP
        If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
          Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]BPAPAY=[F:BPR]BPAADD
      Endif
    Endif

    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:UOH]BPAINV=""
      If [F:BPS]BPSINV=[F:UOH]BPSINV
        If [F:BPR]BPRNUM<>[F:BPS]BPSINV
          Read [BPR] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]BPAINV=[F:BPR]BPAADD
      Else
        Gosub LECT_BPSI
        If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
          Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

##############################################################################################
##############################################################################################

###################################
$LECT_BPSPOH
If [F:BPS]BPSNUM<>[F:UOH]BPSNUM
  WBPS=[F:UOH]BPSNUM
  Gosub LECT_BPS
Endif
Return
$LECT_BPSP
If [F:BPS]BPSNUM<>[F:UOH]BPRPAY
  WBPS=[F:UOH]BPRPAY
  Gosub LECT_BPS
Endif
Return
$LECT_BPSI
If [F:BPS]BPSNUM<>[F:UOH]BPSINV
  WBPS=[F:UOH]BPSINV
  Gosub LECT_BPS
Endif
Return
$LECT_BPS
  Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return
#####################################
$LECT_BPRI
If [F:BPR]BPRNUM<>[F:UOH]BPSINV
  WBPR=[F:UOH]BPSINV
  Gosub LECT_BPR
Endif
Return
$LECT_BPRS
If [F:BPR]BPRNUM<>[F:UOH]BPSNUM
  WBPR=[F:UOH]BPSNUM
  Gosub LECT_BPR
Endif
Return
$LECT_BPR
  Read [BPR] BPR0=WBPR : If fstat Raz [F:BPR] : Endif
Return
#####################################
$LECT_BPAS
If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:UOH]BPSNUM | [F:BPA]BPAADD<>[F:UOH]BPOADD
  Read [BPA] BPA0=1;[F:UOH]BPSNUM;[F:UOH]BPOADD
  If fstat  Raz [F:BPA] : Endif
Endif
Return

##############################################################################################
##############################################################################################
$MAJ30_UOC
    If GACTDEB=2
      If [F:UOC]EECNUM2=""
        Gosub LECT_BPRI
        [F:UOC]EECNUM2=[F:BPR]EECNUM : # Identification CEE
      Endif
    Endif
Return

##############################################################################################
##############################################################################################

