##########################################################################
## Procedures and functions used to manage X3 Model
##########################################################################

#**
#* Return the list of models
#*!
Funprog GET_MODEL_LIST()
  Local Clbfile JSON(4)
  Local Integer BFIRST : BFIRST = 1
  Local Char    STARTSTMP(16)
  Local Char    ENDSTMP(16)

  STARTSTMP = timestamp$
  If clalev([F:AWM])=0 : Local File AWRKLNK [AWM] : Endif

  Raz [L]JSON
  Append [L]JSON, '{"$version":1'
  Append [L]JSON, ',"$timestamp":' + STARTSTMP
#  Append [L]JSON, ',"$keyname":"CODFIC"'
  Append [L]JSON, ',"items":['
  Columns [F:AWM](MODELE)
  For [F:AWM]AWM0
    If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
    Append [L]JSON, '"'
    Append [L]JSON, [F:AWM]MODELE
    Append [L]JSON, '"'
  Next [F:AWM]AWM0
  Close Local File [F:AWM]

  Append [L]JSON, "]"
  Append [L]JSON, ',"$elapsed":'
  ENDSTMP = timestamp$
  Append [L]JSON, num$(val(ENDSTMP) - val(STARTSTMP))
  Append [L]JSON, "}"
End JSON


#**
#* Return the list of tables
#*!
Funprog GET_TABLE_LIST()
  Local Clbfile JSON(4)
  Local Integer BFIRST : BFIRST = 1
  Local Char    STARTSTMP(16)
  Local Char    ENDSTMP(16)

  If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif

  STARTSTMP = timestamp$
  Raz [L]JSON
  Append [L]JSON, '{"$version":1'
  Append [L]JSON, ',"$timestamp":' + STARTSTMP
#  Append [L]JSON, ',"$keyname":"CODFIC"'
  Append [L]JSON, ',"items":['
  Columns [F:ATB](CODFIC)
  For [F:ATB]CODFIC
    If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
    Append [L]JSON, '"'
    Append [L]JSON, [F:ATB]CODFIC
    Append [L]JSON, '"'
  Next [F:ATB]CODFIC
  Close Local File [F:ATB]

  Append [L]JSON, "]"
  Append [L]JSON, ',"$elapsed":'
  ENDSTMP = timestamp$
  Append [L]JSON, num$(val(ENDSTMP) - val(STARTSTMP))
  Append [L]JSON, "}"
End JSON

#**
#* Return table info (code + name)
#* @param TABLE the code of the table
#*!
Funprog GET_TABLE_DESC(TABLE)
  Value Char    TABLE()

  Local Char    NAME(255)
  Local Char    COLNAME(255)
  Local Char    TABLECODE(255)
  Local Char    STARTSTMP(16)
  Local Char    ENDSTMP(16)

  Local Clbfile JSON(6)
  Local Integer BFIRST : BFIRST = 1

  STARTSTMP = timestamp$
  If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif

  TABLE = toupper(TABLE)
  TITLE = ""
  Raz [L]JSON
  Append [L]JSON, '{"$version":1'
  Append [L]JSON, ',"$timestamp":' + STARTSTMP
  Read [F:ATB]CODFIC=TABLE
  If fstat = 0
    # Names
#    BFIRST = 1
#    If clalev([F:ATXZ])=0 : Local File ATEXTE [ATXZ] : Endif
#    Append [L]JSON, '"titles":['
#    NUM = [F:ATB]INTITFIC
#    Filter [F:ATXZ] Where [F:ATXZ]NUMERO = NUM
#    For [F:ATXZ]
#      If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
#      Append [L]JSON, '["'
#      Append [L]JSON, [F:ATXZ]LAN
#      Append [L]JSON, '","'
#      Append [L]JSON, [F:ATXZ]TEXTE
#      Append [L]JSON, '"]'
#    Next
#    Append [L]JSON, "]"
#    Filter [F:ATXZ]
#    Close Local File [ATXZ]

    Call TEXTE([F:ATB]INTITFIC, TITLE) From OBJDIV
    Append [L]JSON, ',"title":"' + TITLE + '"'

    Append [L]JSON, ',"properties":'
    Call APPEND_PROPERTIES(JSON)

    # Columns
    BFIRST = 1
    If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
    Append [L]JSON, ',"columns":['
    Filter [F:ATZ] Where CODFIC = TABLE
    For [F:ATZ]
      If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
      # Column properties
      Call APPEND_PROPERTIES(JSON)
    Next
    Append [L]JSON, "]"
    Filter [F:ATZ]
    Close Local File [ATZ]

    # Indexes
    BFIRST = 1
    If clalev([F:AIX])=0 : Local File ATABIND [AIX] : Endif
    Append [L]JSON, ',"indexes":['
    Filter [F:AIX] Where [F:AIX]CODFIC = TABLE
    For [F:AIX]
      If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
      # Index properties
      Call APPEND_PROPERTIES(JSON)
    Next
    Append [L]JSON, "]"
    Filter [F:AIX]
    Close Local File [AIX]

    # Audits
    BFIRST = 1
    If clalev([F:ATA])=0 : Local File ATABAUD [ATA] : Endif
    Append [L]JSON, ',"audits":['
    Filter [F:ATA] Where [F:ATA]CODFIC = TABLE
    For [F:ATA]
      If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
      # Audit properties
      Call APPEND_PROPERTIES(JSON)
    Next
    Append [L]JSON, "]"
    Filter [F:ATA]
    Close Local File [ATA]

  Endif
  Close Local File [F:ATB]

  Append [L]JSON, ',"$elapsed":'
  ENDSTMP = timestamp$
  Append [L]JSON, num$(val(ENDSTMP) - val(STARTSTMP))
  Append [L]JSON, "}"
End JSON

#**
#* Append table properties of the current open table to a JSON clob
#*
#* @param JSON the target JSON
#*!
Subprog APPEND_PROPERTIES(JSON)
Variable Clbfile JSON

  NBZ = [G]nbzon

  Append [L]JSON, '{'
  # properties
  For I = 0 To NBZ - 1
    If I <> 0
      Append [L]JSON, ","
    Endif
    COLNAME = [G]adxfname(I)
    Append [L]JSON, '"'
    Append [L]JSON, COLNAME
    Append [L]JSON, '":'
    Append [L]JSON, func EVALUE_EXPR("[F]" + COLNAME)
  Next I
  Append [L]JSON, '}'

End

Funprog GET_MODEL(MODEL)
  Value Char MODEL()

  Local Char VALUE_SEP(4) : VALUE_SEP = ","
  Local Clbfile JSON(6)
  Local Integer BFIRST : BFIRST = 1

  STARTSTMP = timestamp$
  If clalev([F:AWM])=0 : Local File AWRKLNK [AWM] : Endif

  MODEL = toupper(MODEL)
  TITLE = ""
  Raz [L]JSON
  Append [L]JSON, '{"$version":1'
  Append [L]JSON, ',"$timestamp":' + STARTSTMP
  Read [F:AWM]AWM0=MODEL
  If fstat = 0
    Call TEXTE([F:AWM]INTITMOD, TITLE) From OBJDIV
    Append [L]JSON, ',"title":"' + TITLE + '"'

    Append [L]JSON, ',"properties":'
    Call APPEND_PROPERTIES(JSON)

    # Links
    BFIRST = 1
    If clalev([F:AWK])=0 : Local File AWRKTAB [AWK] : Endif
    Append [L]JSON, ',"links":['
    Filter [F:AWK] Where [F:AWK]MODELE = MODEL
    For [F:AWK]
      If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
      # Column properties
      Call APPEND_PROPERTIES(JSON)
    Next
    Append [L]JSON, "]"
    Filter [F:AWK]
    Close Local File [AWK]
  Endif
  Close Local File [F:AWM]

  Append [L]JSON, ',"$elapsed":'
  ENDSTMP = timestamp$
  Append [L]JSON, num$(val(ENDSTMP) - val(STARTSTMP))
  Append [L]JSON, "}"

End [L]JSON

#**
#* Query table
#* @param TABLE the code of the table to query
#* @param FILTER_EXPR the filter expression to restrict the set of records
#*!
Funprog QUERY(TABLE,FILTER_EXPR)
  Value Char    TABLE()
  Value Char    FILTER_EXPR()

  Local Char VALUE_SEP(4) : VALUE_SEP = ","
  Local Integer BFIRST : BFIRST = 1
  Local Char    NAME(255)
  Local Clbfile JSON(6)
  Local Integer NBF
  Local Char    STARTSTMP(16)
  Local Char    ENDSTMP(16)

  TABLE = toupper(TABLE)
  Local File =TABLE [TAB_]

  STARTSTMP = timestamp$

  Raz [L]JSON
  Append [L]JSON, '{"$version":1'
  Append [L]JSON, ',"$timestamp":' + STARTSTMP
  Append [L]JSON, ',"names":['
  NBF = [G:TAB_]nbzon
  For I = 0 To NBF - 1
    NAME = [G:TAB_]adxfname(I)
    Append [L]JSON, '"'
    Append [L]JSON, NAME
    Append [L]JSON, '"'
    If I <> NBF - 1
      Append [L]JSON, VALUE_SEP
    Endif
  Next I
  Append [L]JSON, '],"values":['

  Filter [F:TAB_] Where evalue(FILTER_EXPR)
  For [F:TAB_]
    If [L]BFIRST = 0 : Append [L]JSON, "," : Else : [L]BFIRST = 0 : Endif
    Append [L]JSON, "["
    For I = 0 To NBF - 1
      NAME = [G:TAB_]adxfname(I)
#      Append [L]JSON, NAME
#      Append [L]JSON, ":"
      Append [L]JSON, func EVALUE_EXPR("[F:TAB_]" + NAME)
      If I <> NBF - 1
        Append [L]JSON, VALUE_SEP
      Endif
    Next I
    Append [L]JSON, "]"
  Next
  Filter [F:TAB_]
  Close Local File [F:TAB_]

  Append [L]JSON, "]"
  ENDSTMP = timestamp$
  Append [L]JSON, ',"$elapsed":'
  Append [L]JSON, num$(val(ENDSTMP) - val(STARTSTMP))
  Append [L]JSON, "}"
End [L]JSON

#**
#* Return table info
#* @param CODE the code of the table
#*!
Funprog GET_TABLE_VALUES(CODE)
Value Char    CODE()

Local Char    TABLECODE(255)
Local Char    NAME(255)
Local Clbfile FIELDS(1)

Local Char LINE_SEP(4) : LINE_SEP = chr$(10)
Local Char VALUE_SEP(4) : VALUE_SEP = ","
Local Integer NBF

If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif

FIELDS = ""
TABLECODE = func GETTABLECODE(CODE)

Read [F:ATB]CODFIC=TABLECODE
If fstat=0
  Append FIELDS, "{"
  NBF = [G:ATB]nbzon
  For I = 0 To NBF - 1
    NAME = [G:ATB]adxfname(I)
    Append FIELDS, NAME
    Append FIELDS, ":"
    Append FIELDS, func EVALUE_EXPR("[F:ATB]" + NAME)
    If I <> NBF - 1
      Append FIELDS, VALUE_SEP
    Endif
  Next I
  Append FIELDS, "}"
Endif
Close Local File [F:ATB]
End FIELDS

#**
#* Evaluates an expression
#* @param EXPR the expression to evaluate
#* @return RETOUR error code (0=OK) + separator + evaluated result
#*!
Funprog EVALUE_EXPR(EXPR)
Value Char EXPR()

Local Integer ERRCODE
Local Clbfile RETOUR(6)
Local Clbfile EVAL(6)
Local Char C(1)
Local Integer A
ERRCODE = 0

Onerrgo EVALUE_EXPR_ERROR
EVAL = evalue(EXPR + "+''")
RETOUR = '"'
L = len(EVAL)
For I = 1 To L
  C = mid$(EVAL, I, 1)
  A = ascii(C)
  Case A
    When 8 :
      Append RETOUR, "\b"
    When 9 :
      Append RETOUR, "\t"
    When 10 :
      Append RETOUR, "\n"
    When 12 :
      Append RETOUR, "\f"
    When 13 :
      Append RETOUR, "\r"
    When Default :
      If C = '"' | C = "'" | C = "\" | C = "/"
        Append RETOUR, "\"
      Endif
      Append RETOUR, C
  Endcase
Next I
Append RETOUR, '"'

# If the error has been trapped ERRCODE is not 0 at this point
If ERRCODE <> 0
  ERRCODE = 0
  RETOUR = num$(evalue(EXPR))
Endif

If ERRCODE <> 0
  RETOUR = "#error#" + num$(ERRCODE) + "#"
#  RETOUR = "#error#" + num$(ERRCODE) + ":" + errmes$(ERRCODE) + "#"
Endif

End RETOUR


 $EVALUE_EXPR_ERROR
    ERRCODE = errn
 Resume

