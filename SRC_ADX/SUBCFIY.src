################################################################
# Etiquettes masque CREFIY : Création des exercices
################################################################
Subprog AS_CREAT(VALEUR)
Variable Integer VALEUR 
If nolign>1 
 If [M:DIA]CREAT(nolign-2)<>2 
  VALEUR = 1 : mkstat=2 : End 
 Endif 
Endif
End

Subprog C_CREAT(VALEUR)
Variable Integer VALEUR 
Local Integer IJ 
If VALEUR<>2 
 For IJ=nolign To [M:DIA]NBLIG-1 
  [M:DIA]CREAT(IJ) = 1 
 Next IJ 
Endif
End

Subprog B2_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 2
Next I
Affzo LEDFLG
End

Subprog B3_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 1
Next I
Affzo LEDFLG
End
