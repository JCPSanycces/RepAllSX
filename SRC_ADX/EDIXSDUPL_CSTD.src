###############################################################################
# Class EDIXSDUPL                                                             #
# Author : RBA                                                                #
###############################################################################



#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub AREAD_AFTER
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"  : Gosub ADELETE_CONTROL_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_FILE_UPLOAD"        : Gosub MET_FILE_UPLOAD
    When "MET_FILE_REMOVE"        : Gosub MET_FILE_REMOVE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CODE" :
      Case [L]ARULE
        When "CONTROL"    : Gosub CODE_CONTROL
      Endcase
    When "NAM" :
      Case [L]ARULE
         When "PROPAGATE" : Gosub NAM_PROPAGATE
      Endcase
    When "FILNAM" :
      Case [L]ARULE
         When "CONTROL"   : Gosub FILNAM_CONTROL
      Endcase
  Endcase
Return

####################################################################
$CODE_CONTROL
  If this.CODE <> ""
    this.CODE = func EDILIBA.FORMATVAL("CODE", this.CODE)
  Endif
Return

###################################################################
$NAM_PROPAGATE
  If this.NAM <> ""
    this.FILNAM = tolower(vireblc(this.NAM,4)+".xsd")
  Endif
Return

###################################################################
$FILNAM_CONTROL
  If this.FILNAM <> ""
  Endif
Return


####################################################################

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#
#********************************************************************
$AREAD_AFTER

Return

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AINSERT_CONTROL_AFTER
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Char WERR(250) : WERR = ""

  WOK = fmet this.MET_FILE_UPLOAD(WERR)
  If WOK <> [V]CST_AOK
    ASTATUS = fmet this.ASETERROR("",WERR, WOK)
  Endif
Return


#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AUPDATE_CONTROL_AFTER
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Char WERR(250) : WERR = ""

  WOK = fmet this.MET_FILE_UPLOAD(WERR)
  If WOK <> [V]CST_AOK
    ASTATUS = fmet this.ASETERROR("",WERR, WOK)
  Else
    If func FILTXT_HAS_CHANGED(this.CODE, this.FILTXT) = [V]CST_AYES
      #rendre invalide les XML Files correspondant
      Local File EDIXMLFIL [EXF]
      Local File EDIXMLFILXSD [EXSD]
      Link [EXSD] With [EXF]EXF0 = [EXSD]MSGCOD;[EXSD]MSGREL;[EXSD]MSGFILNOR As [LIEN] Where [EXSD]CODE = this.CODE and [EXF]VALID = [V]CST_AYES
      For [LIEN]
        WOK = func UNVALID_XML([EXF]MSGCOD,[EXF]MSGREL,[EXF]MSGFILNOR, WERR)
        If WOK = [V]CST_AOK
          ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)

          #rendre invalide et desactivé les Flows correspondant
          Local File EDIFLO [EFL]
          Local File EDIFLOD [EFLD]
          Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD;[EFLD]FLOREL As [LIEN2] Where [EFLD]MSGTYP = 1
&              and [EFLD]MSGCOD = [EXF]MSGCOD and [EFLD]MSGREL = [EXF]MSGREL and [EFLD]MSGFILNOR = [EXF]MSGFILNOR
          For [LIEN2]
            WOK = func UNVALID_FLOW([EFL]FLOCOD,[EFL]FLOREL, WERR)
            If WOK = [V]CST_AOK
              ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
            Endif
          Next
          LogicClose File [EFLD]
          LogicClose File [EFL]
        Endif
      Next
      LogicClose File [EXSD]
      LogicClose File [EXF]
    Else
      #nothing to do, nothing has changed
    Endif
  Endif
Return


####################################################################


#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Char WERR(250) : WERR = ""

  WOK = func XSD_IS_USED(this.CODE,WERR)
  If WOK = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Else
    WOK = fmet this.MET_FILE_REMOVE(WERR)
    If WOK <> [V]CST_AOK
      ASTATUS = fmet this.ASETERROR("",WERR, [V]CST_AERROR)
    Endif
  Endif
Return

#********************************************************************
# Method MET_FILE_UPLOAD
#********************************************************************
#* WERR
#
#*
#********************************************************************
#* @return ok/error
#*!
$MET_FILE_UPLOAD
  Local Integer WRET_VALUE  : WRET_VALUE = [V]CST_AERROR
  Local Integer WOK         : WOK = 0
  # Create a file containing text
  Local Blbfile WBLOB_DOC(0)
  Local Char WDESCRIPTION(50)      : DESCRIPTION   = left$(this.FILDES,50) #"xml template"
#  Local Char WFILE_NAME(50)        : WFILE_NAME    = "EDIXSD-"+ this.CODE #this.FILNAM #"file.xsd"    ## SAM 112148
  Local Char WFILE_NAME(50)        : WFILE_NAME    = this.FILNAM #"file.xsd"                           ## SAM 112148
  Local Char WCONTENT_TYPE(20)     : WCONTENT_TYPE = "application/xml"
  Local Char WPROPS_COD(20)(1..2)  : WPROPS_COD(1) = "documentDate"
  Local Char WPROPS_VAL(100)(1..2) : WPROPS_VAL(1) = '"'+format$("D:YYYY[-]MM[-]DD",date$)+'"' #'"2014-01-01"'
  Local Char WUUID(50)
  Local Char WVOLUME(10)           : WVOLUME = "STD"
  Local Integer WFUTURE            : WFUTURE = 0
  Local Clbfile WRESHEAD(0)
  Local Clbfile WDATA(0)
  Local Clbfile WTEXT(0)
#  Local Char WERR(250)
# The content must be stored in a blob
  WTEXT = this.FILTXT #"Example of text"+chr$(10)+" - on several lines"+chr$(10)+' - with accents such as I took a dish "à la carte"'
  WOK   = strEncode(WTEXT,WBLOB_DOC,0) : # 50: blob containing ascii  #### ENCODING 0 : utf8
# Let's create the document
  If this.UUIDXSD = NullUuid()
    WUUID = ""
  Else
    WUUID = num$(this.UUIDXSD)
    Local Char WERR(250)
    WERR = ""
    WOK = func XSD_IS_USED(this.CODE,WERR)
  Endif

  WOK = func ASYRSAREA.WRITEALL(WBLOB_DOC, WDESCRIPTION, WFILE_NAME, WCONTENT_TYPE, WPROPS_COD, WPROPS_VAL, WUUID, WVOLUME, WFUTURE, WRESHEAD, WDATA)

  If WOK = 200
    Local Integer I
    # If OK is equal to 200, ID contains the UUID of the newly created document
    this.UUIDXSD = toUuid(WUUID)
    WERR = ""
    WRET_VALUE = [V]CST_AOK
  Else
    this.UUIDXSD =  NullUuid()    # X3-60422 (JUCON 18/10/2017)
    WRET_VALUE = [V]CST_AERROR
#    WERR = mess(163,2006,1) #"Error while uploading XSD file" #Erreur lors du téléchargement du fichier XSD  # X3-60422 (JUCON 18/10/2017)
    WERR = mess(163,2006,1)+"."-mess(195,2006,1) #"Error while uploading XSD file" #Erreur lors du téléchargement du fichier XSD
  Endif
  ARET_VALUE = WRET_VALUE
Return

#********************************************************************
# Method MET_FILE_REMOVE
#********************************************************************
#*
#
#*
#********************************************************************
#* @return ok/error
#*!
$MET_FILE_REMOVE
  Local Integer WRET_VALUE  : WRET_VALUE = [V]CST_AERROR
  Local Integer WOK         : WOK = 0
  Local Char WERR(250)      : WERR = ""

  Local Char WUUID(50)
  Local Integer WFUTURE            : WFUTURE = 0
  Local Clbfile WRESHEAD(0)
  Local Integer WRES

 #X3-67156 - Delete EDI XMLfile and XSD
#  If this.UUIDXSD <> NullUuid()
#    WUUID = num$(this.UUIDXSD)
#    WOK = func ASYRSAREA.REMOVE(WUUID, WFUTURE, WRESHEAD, WRES)
#    If WOK = 200 and WRES = 1
#      # If OK is equal to 200, removed
#      this.UUIDXSD = NullUuid()
#      WRET_VALUE = [V]CST_AOK
#    Else
#      WRET_VALUE = [V]CST_AERROR
#    Endif
#  Else
#    WRET_VALUE = [V]CST_AERROR
#  Endif
#
#  If WRET_VALUE = [V]CST_AERROR
#    WERR = mess(164,2006,1) #"File deletion failed" #La suppression du fichier XSD a échoué
#  Endif
  If this.UUIDXSD <> NullUuid()
    WUUID = num$(this.UUIDXSD)
    WOK = func ASYRSAREA.REMOVE(WUUID, WFUTURE, WRESHEAD, WRES)
    If WOK = 200 and WRES = 1
      # If OK is equal to 200, removed
      this.UUIDXSD = NullUuid()
      WRET_VALUE = [V]CST_AOK
    Else
      WERR = mess(164,2006,1) #"File deletion failed" #La suppression du fichier XSD a échoué
      WRET_VALUE = [V]CST_AERROR
    Endif
  Else
    WRET_VALUE = [V]CST_AOK #no pb if file is not found, file has not be created
  Endif
 #/X3-67156 - Delete EDI XMLfile and XSD
  ARET_VALUE = WRET_VALUE

Return



#********************************************************************
# Funprog FILTXT_HAS_CHANGED
#********************************************************************
#
#********************************************************************
Funprog FILTXT_HAS_CHANGED(WCODE, WFILTXT)
Value Char WCODE
Value Clbfile WFILTXT

  Local Integer WUPDFILTXT : WUPDFILTXT = [V]CST_ANO
  If WCODE <> ""
    Local File EDIXSDUPLLOB [EXUL]
    Read [EXUL]EXUL0 = WCODE
    If !fstat
      If [EXUL]TXT <> WFILTXT
        WUPDFILTXT = [V]CST_AYES
      Endif
    Endif
    LogicClose File [EXUL]
  Endif
End WUPDFILTXT

#********************************************************************
# Funprog UNVALID_XML
#********************************************************************
#
#********************************************************************
Funprog UNVALID_XML(WMSGCOD, WMSGREL,WMSGFILNOR, WERR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR
Variable Char WERR

  WERR = ""
  Local Integer WOK
  Local File EDIXMLFIL[EXF]
  Read [EXF]EXF0 = WMSGCOD;WMSGREL;WMSGFILNOR
  If !fstat
    Trbegin [EXF]
    [EXF]VALID = [V]CST_ANO
    Rewrite [EXF]
    If !fstat
      Commit
      WOK  = [V]CST_AOK
      WERR = "("+[EXF]MSGCOD+"~"+[EXF]MSGREL+"~"+[EXF]MSGFILNOR+")"-mess(165,2006,1) #"Fichier XML invalidé"
    Else
      Rollback
      WOK = [V]CST_AERROR
    Endif
  Else
    WOK = [V]CST_AERROR
  Endif
  LogicClose File [EXF]
End WOK


#********************************************************************
# Funprog UNVALID_FLOW
#********************************************************************
#
#********************************************************************
Funprog UNVALID_FLOW(WFLOCOD,WFLOREL,WERR)
Value Char WFLOCOD
Value Char WFLOREL
Variable Char WERR

  WERR = ""
  Local Integer WOK : WOK = [V]CST_AOK

  Local File EDIFLO[EFL]
  Read [EFL]EFL0 = WFLOCOD;WFLOREL
  If !fstat
    Trbegin [EFL]
    [EFL]VALID  = [V]CST_ANO
    [EFL]FLGACT = [V]CST_ANO
    Rewrite [EFL]
    If !fstat
      Commit
      WOK = [V]CST_AOK
      WERR = "("+[EFL]FLOCOD+"~"+[EFL]FLOREL+")"-mess(28,2006,1)  #Flow has been invalidated and deactivated
    Else
      Rollback
      WOK = [V]CST_AERROR
    Endif
  Else
    WOK = [V]CST_AERROR
  Endif
  LogicClose File [EFL]
End WOK



#********************************************************************
# Funprog XSD_IS_USED
#********************************************************************
#
#********************************************************************
Funprog XSD_IS_USED(WCODE,WERR)
Value Char WCODE
Variable Char WERR

  WERR = ""
  Local Integer WOK : WOK = [V]CST_AFALSE

  Local File EDIXMLFILXSD [EXSD]
  Filter [EXSD] Where [EXSD]CODE = WCODE
  For [EXSD]
    WOK = [V]CST_ATRUE
    WERR = mess(1,115,1)+"."-mess(162,2006,1)+".("+[EXSD]MSGCOD+"~"+[EXSD]MSGREL+"~"+[EXSD]MSGFILNOR+")"
    Break
  Next
  LogicClose File [EXSD]
End WOK

