############################################################
############################################################
Funprog GET_TYP(ITYPE)
Value Integer ITYPE

Local Char SARENDRE(GLONAOB)

  If ITYPE > 2 Then
    SARENDRE = "PIV"
  Elsif ITYPE <= 2 Then
    SARENDRE = "PIH"
  Else
    SARENDRE = ""
  Endif
End SARENDRE
