#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
WCHAR = [M]REFNUM
If varmode([M]REFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]REFNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DROITEMP"
  Call DROIT([M]REFNUM,"","1","") From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARAM(1) = "EML"
   Local Char    VALEUR(250)
   VALEUR = [M]REFNUM
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
   [M]REFNUM = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]REFNUM or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_REFNUM([M]REFNUM) From SUBDLA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DAT
mkstat = 0
zoncou = "DAT"
indice = 0
WDATE = [M]DAT
If varmode([M]DAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DAT" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DAT=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 47432 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]DAT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DAT([M]DAT) From SUBDLA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 47432 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CTRNUM
mkstat = 0
zoncou = "CTRNUM"
indice = 0
WCHAR = [M]CTRNUM
If varmode([M]CTRNUM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CTRNUM([M]CTRNUM) From SUBDLA
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CTRNUM : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CTRNUM,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTVCR"
   Call CONTVCR([M]CTRNUM) From TRTDIV
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("CTR","",[M]CTRNUM,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CTRNUM or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CTRNUM([M]CTRNUM) From SUBDLA
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DLA0"
Return

