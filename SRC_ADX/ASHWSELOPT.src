#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char VALEUR(20) , PARAM(250)(1..3)
PARAM(1) = "F"
PARAM(2) = "14"
PARAM(3) = "ATY"
Call S_LIS_CHAR(VALEUR,PARAM,"ASHWSELOPT","ASHWSELOPT","") From GACTION
End

#------------------------------#
$ACTION
Case ACTION
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
Endcase
Return

$SEL_LISTE
Case LISTE
 When "ASHWSELOPT" : Gosub SEL_OPT
Endcase
Return

$VERF_LISTE
Case LISTE
 When "ASHWSELOPT" : Gosub VERF_OPT
Endcase
Return

$SEL_OPT
Case PARAM(1)
 When "T" : Gosub SEL_OPTTAB
 When "F" : Gosub SEL_OPTFLD
Endcase
Return

$VERF_OPT
Case PARAM(1)
 When "T" : Gosub VERF_OPTTAB
 When "F" : Gosub VERF_OPTFLD
Endcase
Return

#---------------------------------------------#
# Options de bas de tableau
#---------------------------------------------#

$SEL_OPTTAB
TIT(0) = mess(0,128,1)   : # Options du tableau
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
Gosub DEFOPT_TAB
Return

#------------------#
$DEFOPT_TAB
Local Char    TEX(GLONDES)(1..50) , TEXTE(GLONDES)(1..50,1..1)  
Local Integer NBTEX
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = "K" : TEXTE(NBTEX,1) = mess(8,128,1)   : # K Ligne Prv/Suv en saisie
NBTEX += 1 : TEX(NBTEX) = "A" : TEXTE(NBTEX,1) = mess(5,128,1)   : # A Annulation
NBTEX += 1 : TEX(NBTEX) = "R" : TEXTE(NBTEX,1) = mess(6,128,1)   : # R Reprise
NBTEX += 1 : TEX(NBTEX) = "I" : TEXTE(NBTEX,1) = mess(7,128,1)   : # I Insertion
NBTEX += 1 : TEX(NBTEX) = "D" : TEXTE(NBTEX,1) = mess(9,128,1)   : # D Annulation multiple
NBTEX += 1 : TEX(NBTEX) = "S" : TEXTE(NBTEX,1) = mess(2,128,1)   : # S Couper
NBTEX += 1 : TEX(NBTEX) = "B" : TEXTE(NBTEX,1) = mess(3,128,1)   : # B Copier
NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX,1) = mess(4,128,1)   : # C Coller
NBTEX += 1 : TEX(NBTEX) = "T" : TEXTE(NBTEX,1) = mess(14,128,1)  : # T Affichage complet
NBTEX += 1 : TEX(NBTEX) = "?" : TEXTE(NBTEX,1) = mess(11,128,1)  : # ? Recherche
NBTEX += 1 : TEX(NBTEX) = "+" : TEXTE(NBTEX,1) = mess(13,128,1)  : # + Justification colonnes
NBTEX += 1 : TEX(NBTEX) = "=" : TEXTE(NBTEX,1) = mess(15,128,1)  : # = Mode fiche automatique
NBTEX += 1 : TEX(NBTEX) = "1" : TEXTE(NBTEX,1) = mess(12,128,1)  : # 1-9 nb de colonnes fixes
Return

#----------------------#
$VERF_OPTTAB
Local Char OPT(20)
OPT = PARAM(2)
If VALEUR>="1" & VALEUR<="9"
 For I=1 To len(OPT)
  If mid$(OPT,I,1)>="1" & mid$(OPT,I,1)<="9"
   OPT = left$(OPT,I-1)+VALEUR+right$(OPT,I+1)
   Break
  Endif
 Next I
Elsif !instr(1,OPT,VALEUR)
 OPT += VALEUR
Endif
VALEUR = OPT
PARAM(2) = OPT
mkstat = 2
Return

#----------------------------------------------------------#
# Options de format des champs
#----------------------------------------------------------#

$SEL_OPTFLD
Local Integer TAB
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
TAB = 0 : # Champs dans un bloc liste
Call LECTURE("ATY",PARAM(3),"") From CONTOBJ
TIT(0) = mess(100,123,1) : # Choix options
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
Gosub DEF_OPTFMT
Return

#--------------------------------------------------#
$DEF_OPTFMT
Local Char    TEX(GLONDES)(1..50) , TEXTE(GLONDES)(1..50,1..2)  
Local Integer NBTEX
NBTEX  = 0
Case [F:ATY]TYPTYP

 When 1 : # Menu local

  If dim([L]TAB)<=0 or [L]TAB=1
   NBTEX += 1 : TEX(NBTEX) = "c" : TEXTE(NBTEX,2) = mess(155,123,1) : # Couleur
  Endif
  NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(94,126,1)   : # Affiché en fond d'écran

 When 7 : # Alpha

  If dim([L]TAB)<=0 or [L]TAB=1
   NBTEX += 1 : TEX(NBTEX) = "=" : TEXTE(NBTEX,2) = mess(32,123,1)  : # Centré
   NBTEX += 1 : TEX(NBTEX) = "<" : TEXTE(NBTEX,2) = mess(33,123,1)  : # Cadré à gauche
   NBTEX += 1 : TEX(NBTEX) = ">" : TEXTE(NBTEX,2) = mess(34,123,1)  : # Cadré à droite
  Endif
  NBTEX += 1 : TEX(NBTEX) = "A" : TEXTE(NBTEX,2) = mess(35,123,1)   : # Majuscules
  NBTEX += 1 : TEX(NBTEX) = "#" : TEXTE(NBTEX,2) = mess(36,123,1)   : # Chiffres
  NBTEX += 1 : TEX(NBTEX) = "T" : TEXTE(NBTEX,2) = mess(37,123,1)   : # Tokenisé
  NBTEX += 1 : TEX(NBTEX) = "D" : TEXTE(NBTEX,2) = mess(38,123,1)   : # Pas de token
  NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX,2) = mess(40,123,1)   : # Format de clé
  NBTEX += 1 : TEX(NBTEX) = "z" : TEXTE(NBTEX,2) = mess(41,123,1)   : # Commentaires non affichés
  NBTEX += 1 : TEX(NBTEX) = "X" : TEXTE(NBTEX,2) = mess(72,133,1)   : # Saisie masquée
  NBTEX += 1 : TEX(NBTEX) = "U" : TEXTE(NBTEX,2) = mess(73,133,1)   : # Fichier local
  If dim([L]TAB)<=0 or [L]TAB=1
   NBTEX += 1 : TEX(NBTEX) = "c" : TEXTE(NBTEX,2) = mess(155,123,1) : # Couleur
  Endif
  NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(94,126,1)   : # Affiché en fond d'écran
  NBTEX += 1 : TEX(NBTEX) = "M" : TEXTE(NBTEX,2) = mess(219,126,1)  : # Taille du champ non optimisée
  NBTEX += 1 : TEX(NBTEX) = "L" : TEXTE(NBTEX,2) = mess(230,126,1)  : # Longueur complète

 When 8 : # Date

  Local Integer IDAT
  NBTEX += 1 : TEX(NBTEX) = "Z" : TEXTE(NBTEX,2) = mess(43,123,1)  : # Date nulle autorisée
  NBTEX += 1 : TEX(NBTEX) = "z" : TEXTE(NBTEX,2) = mess(44,123,1)  : # Valeur nulle non affichée
  For IDAT=1 To len(mess(0,19,1))
   NBTEX += 1 : TEX(NBTEX) = num$(IDAT)
   TEXTE(NBTEX,2) = format$(mess(IDAT,19,1),date$)
  Next IDAT
  If dim([L]TAB)<=0 or [L]TAB=1
   NBTEX += 1 : TEX(NBTEX) = "c" : TEXTE(NBTEX,2) = mess(155,123,1) : # Couleur
  Endif
  NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(94,126,1)   : # Affiché en fond d'écran

 When 9,10 : # Blob , Clob

 When Default : # Numérique

  NBTEX += 1 : TEX(NBTEX) = "z" : TEXTE(NBTEX,2) = mess(44,123,1)   : # Valeur nulle non afffichée
  NBTEX += 1 : TEX(NBTEX) = "+" : TEXTE(NBTEX,2) = mess(45,123,1)   : # Nombres positifs
  NBTEX += 1 : TEX(NBTEX) = "3" : TEXTE(NBTEX,2) = mess(46,123,1)   : # Séparateur groupes de 3
  NBTEX += 1 : TEX(NBTEX) = "F" : TEXTE(NBTEX,2) = mess(47,123,1)   : # Nombres flottants
  NBTEX += 1 : TEX(NBTEX) = "0" : TEXTE(NBTEX,2) = mess(48,123,1)   : # Zéros devant
  NBTEX += 1 : TEX(NBTEX) = "-" : TEXTE(NBTEX,2) = mess(203,126,1)  : # Affichage signe +
  NBTEX += 1 : TEX(NBTEX) = "D" : TEXTE(NBTEX,2) = mess(209,126,1)  : # Signe derrière
  If dim([L]TAB)<=0 or [L]TAB=1
   NBTEX += 1 : TEX(NBTEX) = "c" : TEXTE(NBTEX,2) = mess(155,123,1) : # Couleur
  Endif
  NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(94,126,1)   : # Affiché en fond d'écran

Endcase

Return

#---------------------------------------------------------#
$VERF_OPTFLD
Local Char OPT(20)
OPT = PARAM(2)
If VALEUR>="1" & VALEUR<="9"
 J = 0
 For I=1 To len(OPT)
  If mid$(OPT,I,1)>="1" & mid$(OPT,I,1)<="9"
   OPT = left$(OPT,I-1)+VALEUR+right$(OPT,I+1)
   J = 1
   Break
  Endif
 Next I
Endif
If !instr(1,OPT,VALEUR)
 OPT += VALEUR
Endif
VALEUR = OPT
PARAM(2) = OPT
mkstat = 2
Return

