#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
# Tables
#   CSFPARH (clé CODANY)       : paramétrage
#   CSFPARL (clé CODANY+LIG)   : lignes/formules des comptes d'origines
#
# Ecran      Intitulé       Fenetre   Fonction    Traitement    Objet
# CSFPAR  |  Paramétrage    OCSF      GESCSF      SUBCSF        CSF
#
################################################################################
Raz GPILCOD, GBIDC1, GBIDC2
Call OBJET("CSF",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
################################################################################
$ACTION

Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "LIENS"       : Gosub LIENS
  When "STYLE"       : Gosub STYLE
  When "INICRE"      : Gosub INICRE
  When "INIMOD"      : Gosub INIMOD
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "AP_CHANGE"   : Gosub AP_CHANGE
  When "ANNULE"      : Gosub ANNULE
  When Default
Endcase

Return
################################################################################
################################################################################
$OUVRE

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:CWH])=0 : Local File CSFPARH [CWH] : Endif
If clalev([F:CWL])=0 : Local File CSFPARL [CWL] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
If clalev([F:COA])=0 : Local File GCOA    [COA] : Endif
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif

Local Mask CSFPAR [CSF0]

Return
################################################################################
################################################################################
$LIENS

Local Integer I : I=0

For [CWL] Where CODANY=[M:CSF0]CODANY
  [M:CSF0]ORIFRM(I) = [F:CWL]ORIFRM
  [M:CSF0]COD1(I)   = [F:CWL]COD1
  [M:CSF0]COD2(I)   = [F:CWL]COD2
  [M:CSF0]LIBEL(I)  = [F:CWL]LIBEL
  [M:CSF0]LIG += 1
  I +=1
Next

Call LECTEXTRA([M:CSF0]DESTRA,"CSFPARH","DESTRA",[M:CSF0]CODANY,"") From ATEXTRA
Call LECTEXTRA([M:CSF0]SHOTRA,"CSFPARH","SHOTRA",[M:CSF0]CODANY,"") From ATEXTRA

#If [M:CSF0]COA<>""
#  Call LECTURE("COA",[M:CSF0]COA,"") From CONTOBJ
#  If [F:COA]TAXMGT=1
#    Grizo [M:CSF0]EXTFLG
#  Else
#    Actzo [M:CSF0]EXTFLG
#  Endif
#Endif

#If [M]CPY<>"" & [M:CSF0]LEDTYP>0
#  Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
#  If [F:CPY]CPYLEGFLG=2
#    # Société Juridique
#    Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
#    If [F:GCM]LED([M:CSF0]LEDTYP-1) <> ""
#      Call LECTURE("LED",[F:GCM]LED([M:CSF0]LEDTYP-1),"") From CONTOBJ
#      Call LECTURE("COA",[F:LED]COA,"") From CONTOBJ
#      If [F:COA]TAXMGT=1
#        [M:CSF0]EXTFLG=1
#        Grizo [M:CSF0]EXTFLG
#      Else
#        Actzo [M:CSF0]EXTFLG
#      Endif
#    Endif
#  Endif
#Endif

Affzo [M:CSF0]

Return
################################################################################
################################################################################
$STYLE

Chgstl [M:CSF0]ORIFRM  With "SELECTION"

Return
################################################################################
################################################################################
$INICRE

Gosub INICREMOD

Return
################################################################################
################################################################################
$INIMOD

Gosub INICREMOD

Return
################################################################################
################################################################################
$INICREMOD

If dim([F:CSF]DES)>0
  [F:CSF]DES = [M:CSF0]DESTRA
Endif

Gosub SAVELIG

Return
################################################################################
################################################################################
$SAVELIG

Delete [CWL] Where CODANY=[M:CSF0]CODANY
If fstat=1
  GOK=-1 : GLOCK="$CWL"-[M:CSF0]CODANY : Return
Elsif fstat>5
  GOK=0 : Call RSTA("CWL",[M:CSF0]CODANY) From GLOCK : Return
Endif

For I=0 To [M:CSF0]LIG-1
  Raz [F:CWL]
  [F:CWL]CODANY = [M:CSF0]CODANY
  [F:CWL]LIG    = I+1
  [F:CWL]ORIFRM = [M:CSF0]ORIFRM(I)
  [F:CWL]COD1   = [M:CSF0]COD1(I)
  [F:CWL]COD2   = [M:CSF0]COD2(I)
  [F:CWL]LIBEL  = [M:CSF0]LIBEL(I)
  Write [CWL]
  If fstat
    GOK=0 : Call FSTA("CWL") From GLOCK : Break
  Endif
Next

Return
################################################################################
################################################################################
$CREATION

Gosub TEXTRA
If GOK<1 : Return : Endif

Return
################################################################################
################################################################################
$MODIF

Gosub TEXTRA
If GOK<1 : Return : Endif

Return
################################################################################
################################################################################
$TEXTRA

If GREP="D"
  ## En duplication, on veut récupérer tous les intitulés traduisibles...
  Call DUPTEXTRA("CSFPARH","DESTRA",CLECUR1,"","CSFPARH","DESTRA",[M:CSF0]CODANY,"")  From ATEXTRA
  Call DUPTEXTRA("CSFPARH","SHOTRA",CLECUR1,"","CSFPARH","SHOTRA",[M:CSF0]CODANY,"")  From ATEXTRA
Endif

Call MAJTEXTRA([M:CSF0]DESTRA,"CSFPARH","DESTRA",[M:CSF0]CODANY,"") From ATEXTRA
Call MAJTEXTRA([M:CSF0]SHOTRA,"CSFPARH","SHOTRA",[M:CSF0]CODANY,"") From ATEXTRA

Return
################################################################################
################################################################################
$AP_CHANGE

Call CHGTEXTRA("CSFPARH","DESTRA",[M:CSF0]CODANY,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("CSFPARH","SHOTRA",[M:CSF0]CODANY,"",NCODE,"") From ATEXTRA

Return
################################################################################
################################################################################
$ANNULE

Call SUPTEXTRA("CSFPARH","DESTRA",[M:CSF0]CODANY,"") From ATEXTRA
Call SUPTEXTRA("CSFPARH","SHOTRA",[M:CSF0]CODANY,"") From ATEXTRA

Return
################################################################################
################################################################################
#
################################################################################
## Etiquettes du mask CSFPAR
################################################################################
Subprog C_COD2(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif

If nolign<>1
  For I=0 To nolign-2
    If [M:CSF0]COD2(I)=VALEUR & [M:CSF0]COD1(I)=[M:CSF0]COD1(nolign-1)
      GMESSAGE = mess(122,102,1) :#Sous code déjà utilisé pour ce code
      mkstat=2
      Break
    Endif
  Next
Endif

End
