#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
#      TRAITEMENTS EPURATION Module support client     février 2007
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE_EPURE
    When "FILTRE"      : Gosub FILTRE
    When "HISTO"       : Gosub HISTO
    When "EPURE"       : Gosub EPURE
    When "FERME"       : Gosub FERME_EPURE
  Endcase
Return

##########################################################################################################
#    OUVRE_EPURE                                                                #
#################################################################################
$OUVRE_EPURE
  Case [F:AHI]COD
    When "CON"    :    Gosub OUVRE_CON
    When "SOL"    :    Gosub OUVRE_SOL
    When "SRE"    :    Gosub OUVRE_SRE
    When "CIX"    :    Gosub OUVRE_CIX
    When "MAC"    :    Gosub OUVRE_MAC
  Endcase
Return

##########################################################################################################
#    FILTRE
#################################################################################
$FILTRE
  Case [F:AHI]COD
    When "CON"    :    Gosub FILTRE_CON
    When "SOL"    :    Gosub FILTRE_SOL
    When "SRE"    :    Gosub FILTRE_SRE
    When "CIX"    :    Gosub FILTRE_CIX
    When "MAC"    :    Gosub FILTRE_MAC
  Endcase
Return

##########################################################################################################
#    HISTO                                                                      #
#################################################################################
$HISTO
  Case [F:AHI]COD
    When "CON"    :    Gosub HIS_EPU_CON
    When "SOL"    :    Gosub HIS_EPU_SOL
    When "SRE"    :    Gosub HIS_EPU_SRE
    When "CIX"    :    Gosub HIS_EPU_CIX
    When "MAC"    :    Gosub HIS_EPU_MAC
  Endcase
Return

##########################################################################################################
#    EPURE                                                                      #
#################################################################################
$EPURE
  Case [F:AHI]COD
    When "CON"    :    Gosub HIS_EPU_CON
    When "SOL"    :    Gosub HIS_EPU_SOL
    When "SRE"    :    Gosub HIS_EPU_SRE
    When "CIX"    :    Gosub HIS_EPU_CIX
    When "MAC"    :    Gosub HIS_EPU_MAC
  Endcase
Return

##########################################################################################################
#    FERME_EPURE                                                                #
#################################################################################
$FERME_EPURE
  Case [F:AHI]COD
    When "CON"    :    Gosub FERME_CON
    When "SOL"    :    Gosub FERME_SOL
    When "SRE"    :    Gosub FERME_SRE
    When "CIX"    :    Gosub FERME_CIX
    When "MAC"    :    Gosub FERME_MAC
  Endcase
Return

##########################################################################################################
# Création d'une table dans le dossier fille.
#################################################################################
$CRETAB_HISTO
  #--- Création des tables non liées
  OK = 0
  If filinfo(filpath("FIL",TABLE,"fde",HISAPL),0) < 0 Then
    OK = 1
  Else
    Call VUE_OK(TABLE, HISAPL, "FIL", OK) From DOSVUE
  Endif
  If OK Then
    NEWTAB = TABLE
    Call CRETABLE(APPLI, HISAPL, TYPDBA, NEWTAB, COEFF, 0) From CREHISTO
  Endif
  OK = 1
Return

#################################################################################
$DECLARE_VARIABLES
Local Integer IERRINF

  IERRINF = 0
Return

##########################################################################################################
#    Epuration des contrats de service                                          #
# ------------------------------------------------------------------------------#
#    CON : Actions liées à l'épuration des contrats de service                  #
#################################################################################
$OUVRE_CON
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:CQL]) = 0 : Local File =[L]APPLI + ".CONTQUAL"  [CQL]  : Endif
      If clalev([F:CCA]) = 0 : Local File =[L]APPLI + ".CONTCARE"  [CCA]  : Endif
      If clalev([F:CCV]) = 0 : Local File =[L]APPLI + ".CONTCOV"   [CCV]  : Endif
      TABLE = "CONTQUAL"
      Gosub CRETAB_HISTO
      If clalev([F:CQL1])= 0 : Local File =[L]HISAPL+ ".CONTQUAL"  [CQL1] : Endif
      TABLE = "CONTCARE"
      Gosub CRETAB_HISTO
      If clalev([F:CCA1])= 0 : Local File =[L]HISAPL+ ".CONTCARE"  [CCA1] : Endif
      TABLE = "CONTCOV"
      Gosub CRETAB_HISTO
      If clalev([F:CCV1])= 0 : Local File =[L]HISAPL+ ".CONTCOV"   [CCV1] : Endif
    Else
      If clalev([F:CQL]) = 0 : Local File =[L]HISAPL + ".CONTQUAL" [CQL]  : Endif
      If clalev([F:CCA]) = 0 : Local File =[L]HISAPL + ".CONTCARE" [CCA]  : Endif
      If clalev([F:CCV]) = 0 : Local File =[L]HISAPL + ".CONTCOV"  [CCV]  : Endif
    Endif
  Else
    If clalev([F:CQL]) = 0 : Local File =[L]APPLI + ".CONTQUAL"    [CQL]  : Endif
    If clalev([F:CCA]) = 0 : Local File =[L]APPLI + ".CONTCARE"    [CCA]  : Endif
    If clalev([F:CCV]) = 0 : Local File =[L]APPLI + ".CONTCOV"     [CCV]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_CON
Return

##########################################################################################################
$CONTROL_CON
  # Le contrat doit être résilié ou clôturé et il ne doit plus y avoir de facture à émettre
Return

##########################################################################################################
$HIS_EPU_CON
  #CHECK FILE_DECLARE CONTSERV [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]CONNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_CON
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  # Contraintes qualités
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [CQL] Where [F:CQL]TPL <> 2 and [F:CQL]CONNUM = [F:F1]CONNUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(770,182,1) - ":" - [F:CQL]GRALEV + mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:CQL1]
        [F:CQL1] = [F:CQL]
        If dim([F:CQL1]CREHISDAT)>0 : [F:CQL1]CREHISDAT = date$    : Endif
        If dim([F:CQL1]CREHISUSR)>0 : [F:CQL1]CREHISUSR = [V]GUSER : Endif
        Write [F:CQL1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CONTQUAL" - [F:CQL]GRALEV - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [CQL] Where [F:CQL]TPL <> 2 and [F:CQL]CONNUM = [F:F1]CONNUM
      Call ECR_TRACE(mess(771,182,1) - ":" - [F:CQL]GRALEV + mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [CQL] Where [F:CQL]TPL <> 2 and [F:CQL]CONNUM = [F:F1]CONNUM
    If fstat Then
      Call ECR_TRACE("$CONTQUAL" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #Plans d'entretien
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [CCA] Where [F:CCA]TPL <> 2 and [F:CCA]CONNUM = [F:F1]CONNUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(773,182,1) - ":" - [F:CCA]CCANUM + mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:CCA1]
        [F:CCA1] = [F:CCA]
        If dim([F:CCA1]CREHISDAT)>0 : [F:CCA1]CREHISDAT = date$    : Endif
        If dim([F:CCA1]CREHISUSR)>0 : [F:CCA1]CREHISUSR = [V]GUSER : Endif
        Write [F:CCA1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CONTCARE" - [F:CCA]CCANUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [CCA] Where [F:CCA]TPL <> 2 and [F:CCA]CONNUM = [F:F1]CONNUM
      Call ECR_TRACE(mess(774,182,1) - ":" - [F:CCA]CCANUM + mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [CCA] Where [F:CCA]TPL <> 2 and [F:CCA]CONNUM = [F:F1]CONNUM
    If fstat Then
      Call ECR_TRACE("$CONTCARE" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #Couvertures du contrat
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(775,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]CONNUM = [F:F1]CONNUM
      If ![L]SIMUL Then
        Raz [F:CCV1]
        [F:CCV1] = [F:CCV]
        If dim([F:CCV1]CREHISDAT)>0 : [F:CCV1]CREHISDAT = date$    : Endif
        If dim([F:CCV1]CREHISUSR)>0 : [F:CCV1]CREHISUSR = [V]GUSER : Endif
        Write [F:CCV1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CONTCOV" - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(776,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]CONNUM = [F:F1]CONNUM
    If fstat Then
      Call ECR_TRACE("$CONTCOV" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_CON
  If clalev([F:CQL])  : Close Local File [CQL]  : Endif
  If clalev([F:CQL1]) : Close Local File [CQL1] : Endif
  If clalev([F:CCA])  : Close Local File [CCA]  : Endif
  If clalev([F:CCA1]) : Close Local File [CCA1] : Endif
  If clalev([F:CCV])  : Close Local File [CCV]  : Endif
  If clalev([F:CCV1]) : Close Local File [CCV1] : Endif
Return

##########################################################################################################
#    Epuration des solutions                                                    #
# ------------------------------------------------------------------------------#
#    SOL : Actions liées à l'épuration des solutions                            #
#################################################################################
$OUVRE_SOL
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:HD3]) = 0  : Local File =[L]APPLI + ".HD3CLOB"    [HD3]  : Endif
      TABLE = "HD3CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD31])= 0  : Local File =[L]HISAPL + ".HD3CLOB"   [HD31] : Endif
    Else
      If clalev([F:HD3]) = 0  : Local File =[L]HISAPL + ".HD3CLOB"   [HD3]  : Endif
    Endif
  Else
    If clalev([F:HD3]) = 0    : Local File =[L]APPLI + ".HD3CLOB"    [HD3]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_SOL
Return

##########################################################################################################
$CONTROL_SOL
Return

##########################################################################################################
$HIS_EPU_SOL
Local Char SDH3TYP(type([F:HD3]TYP)-10)

  #CHECK FILE_DECLARE SOLUTION [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_SOL
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  #Demande
  If [L]OKHIS and [L]OKEPU = 0 Then
    For SDH3TYP="PBL", "SOL"
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]NUM - SDH3TYP - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      For [HD3] Where [F:HD3]NUM = [F:F1]NUM and [F:HD3]TYP = SDH3TYP
        If ![L]SIMUL Then
          Raz [F:HD31]
          [F:HD31] = [F:HD3]
          If dim([F:HD31]CREHISDAT)>0 : [F:HD31]CREHISDAT = date$    : Endif
          If dim([F:HD31]CREHISUSR)>0 : [F:HD31]CREHISUSR = [V]GUSER : Endif
          Write [F:HD31]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$HD3CLOB" - [F:HD31]NUM - [F:HD3]TYP - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  For SDH3TYP="PBL", "SOL"
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]NUM - SDH3TYP - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      Delete [HD3] Where [F:HD3]NUM = [F:F1]NUM and [F:HD3]TYP = SDH3TYP
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$HD3CLOB" - [F:F1]NUM - SDH3TYP - mess(10,100,1), 1) From GESECRAN
        Break
      Endif
    Endif
  Next
  If IERRINF Then
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
  # -------------------------------------
Return

##########################################################################################################
$FERME_SOL
  If clalev([F:HD3])  : Close Local File [HD3]   : Endif
  If clalev([F:HD31]) : Close Local File [HD31]  : Endif
Return

##########################################################################################################
#    Epuration des demandes de service                                          #
# ------------------------------------------------------------------------------#
#    SRE : Actions liées à l'épuration des demandes de service                  #
#################################################################################
$OUVRE_SRE
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:HDT]) = 0 : Local File =[L]APPLI + ".HDKTASK"     [HDT]  : Endif
      If clalev([F:ECE]) = 0 : Local File =[L]APPLI + ".ESCSRE"      [ECE]  : Endif
      If clalev([F:ITN]) = 0 : Local File =[L]APPLI + ".INTERVEN"    [ITN]  : Endif
      If clalev([F:RRS]) = 0 : Local File =[L]APPLI + ".RESRES"      [RRS]  : Endif
      If clalev([F:HD1]) = 0 : Local File =[L]APPLI + ".HD1CLOB"     [HD1]  : Endif
      If clalev([F:HD2]) = 0 : Local File =[L]APPLI + ".HD2CLOB"     [HD2]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"     [HD6]  : Endif
      If clalev([F:TXC]) = 0 : Local File =[L]APPLI + ".TEXCLOB"     [TXC]  : Endif
      If clalev([F:CAL]) = 0 : Local File =[L]APPLI + ".CPTANALIN"   [CAL]  : Endif
      TABLE = "HDKTASK"
      Gosub CRETAB_HISTO
      If clalev([F:HDT1])= 0 : Local File =[L]HISAPL+ ".HDKTASK"     [HDT1] : Endif
      TABLE = "ESCSRE"
      Gosub CRETAB_HISTO
      If clalev([F:ECE1])= 0 : Local File =[L]HISAPL+ ".ESCSRE"      [ECE1] : Endif
      TABLE = "INTERVEN"
      Gosub CRETAB_HISTO
      If clalev([F:ITN1])= 0 : Local File =[L]HISAPL+ ".INTERVEN"    [ITN1] : Endif
      TABLE = "RESRES"
      Gosub CRETAB_HISTO
      If clalev([F:RRS1])= 0 : Local File =[L]HISAPL+ ".RESRES"      [RRS1] : Endif
      TABLE = "HD1CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD11])= 0 : Local File =[L]HISAPL+ ".HD1CLOB"     [HD11] : Endif
      TABLE = "HD2CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD21])= 0 : Local File =[L]HISAPL+ ".HD2CLOB"     [HD21] : Endif
      TABLE = "HD6CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD61])= 0 : Local File =[L]HISAPL+ ".HD6CLOB"     [HD61] : Endif
      TABLE = "TEXCLOB"
      Gosub CRETAB_HISTO
      If clalev([F:TXC1])= 0 : Local File =[L]HISAPL+ ".TEXCLOB"     [TXC1] : Endif
      TABLE = "CPTANALIN"
      Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL + ".CPTANALIN"  [CAL1]  : Endif
    Else
      If clalev([F:HDT]) = 0 : Local File =[L]HISAPL + ".HDKTASK"    [HDT]  : Endif
      If clalev([F:ECE]) = 0 : Local File =[L]HISAPL + ".ESCSRE"     [ECE]  : Endif
      If clalev([F:ITN]) = 0 : Local File =[L]HISAPL + ".INTERVEN"   [ITN]  : Endif
      If clalev([F:RRS]) = 0 : Local File =[L]HISAPL + ".RESRES"     [RRS]  : Endif
      If clalev([F:HD1]) = 0 : Local File =[L]HISAPL + ".HD1CLOB"    [HD1]  : Endif
      If clalev([F:HD2]) = 0 : Local File =[L]HISAPL + ".HD2CLOB"    [HD2]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]HISAPL + ".HD6CLOB"    [HD6]  : Endif
      If clalev([F:TXC]) = 0 : Local File =[L]HISAPL + ".TEXCLOB"    [TXC]  : Endif
      If clalev([F:CAL]) = 0 : Local File =[L]HISAPL + ".CPTANALIN"  [CAL]  : Endif
    Endif
  Else
    If clalev([F:HDT]) = 0 : Local File =[L]APPLI + ".HDKTASK"       [HDT]  : Endif
    If clalev([F:ECE]) = 0 : Local File =[L]APPLI + ".ESCSRE"        [ECE]  : Endif
    If clalev([F:ITN]) = 0 : Local File =[L]APPLI + ".INTERVEN"      [ITN]  : Endif
    If clalev([F:RRS]) = 0 : Local File =[L]APPLI + ".RESRES"        [RRS]  : Endif
    If clalev([F:HD1]) = 0 : Local File =[L]APPLI + ".HD1CLOB"       [HD1]  : Endif
    If clalev([F:HD2]) = 0 : Local File =[L]APPLI + ".HD2CLOB"       [HD2]  : Endif
    If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"       [HD6]  : Endif
    If clalev([F:TXC]) = 0 : Local File =[L]APPLI + ".TEXCLOB"       [TXC]  : Endif
    If clalev([F:CAL]) = 0 : Local File =[L]APPLI + ".CPTANALIN"     [CAL]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_SRE
Return

##########################################################################################################
$CONTROL_SRE
  # Elle doit être clôturée. Et si elle est facturable, elle doit être facturée ou non facturable.
Return

##########################################################################################################
$HIS_EPU_SRE
  #CHECK FILE_DECLARE SERREQUEST [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]SRENUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_SRE
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  #Clob Description
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]SRENUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD1] Where [F:HD1]NUM = [F:F1]SRENUM and [F:HD1]TYP = "SRE"
      If ![L]SIMUL Then
        Raz [F:HD11]
        [F:HD11] = [F:HD1]
        If dim([F:HD11]CREHISDAT)>0 : [F:HD11]CREHISDAT = date$    : Endif
        If dim([F:HD11]CREHISUSR)>0 : [F:HD11]CREHISUSR = [V]GUSER : Endif
        Write [F:HD11]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD1CLOB" - [F:HD11]NUM - "SRE" - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]SRENUM - "SRE" - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD1] Where [F:HD1]NUM = [F:F1]SRENUM and [F:HD1]TYP = "SRE"
    If fstat Then
      Call ECR_TRACE("$HD1CLOB" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #---------------------------------------------------#
  # Textes Consommations
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM and [F:HDT]HDTSALTEX <> ""
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - [F:HDT]HDTSALTEX - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      Read [TXC]TXC0=[F:HDT]HDTSALTEX
      If !fstat Then
        If ![L]SIMUL Then
          Raz [F:TXC1]
          [F:TXC1] = [F:TXC]
          If dim([F:TXC1]CREHISDAT) > 0 : [F:TXC1]CREHISDAT = date$    : Endif
          If dim([F:TXC1]CREHISUSR) > 0 : [F:TXC1]CREHISUSR = [V]GUSER : Endif
          Write [F:TXC1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$TEXCLOB" - [F:HDT]HDTNUM - [F:HDT]HDTSALTEX - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM and [F:HDT]HDTSALTEX <> ""
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - [F:HDT]HDTSALTEX - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - [F:HDT]HDTSALTEX - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Endif
      Delete [TXC] Where [F:TXC]CODE = [F:HDT]HDTSALTEX
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$TEXCLOB" - mess(10,100,1), 1) From GESECRAN
        Break
      Endif
    Endif
  Next
  If IERRINF Then
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
  #---------------------------------------------------#
  # Lignes comptables analytiques CPTANALIN
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(782,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      Read [CAL] CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
      If !fstat Then
        If ![L]SIMUL Then
          [F:CAL1] = [F:CAL]
          If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
          If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
          Write [CAL1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$CPTANALIN" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM
    If ![L]SIMUL Then
      Delete [CAL] Where ABRFIC = "HDT" & VCRTYP = 0 & VCRNUM = [F:HDT]HDTNUM & VCRLIN = 0 & VCRSEQ = 0 & CPLCLE = "" & ANALIG = 1
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$CPTANALIN" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(10,100,1), 1) From GESECRAN
        Break
      Endif
    Endif
  Next
  If IERRINF Then
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
  #---------------------------------------------------#
  #Consommations
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(782,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:HDT1]
        [F:HDT1] = [F:HDT]
        If dim([F:HDT1]CREHISDAT) > 0 : [F:HDT1]CREHISDAT = date$    : Endif
        If dim([F:HDT1]CREHISUSR) > 0 : [F:HDT1]CREHISUSR = [V]GUSER : Endif
        Write [F:HDT1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HDKTASK" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [HDT]HDT1 Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM
      Call ECR_TRACE(mess(783,182,1) - ":" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [HDT] Where [F:HDT]TPL <> 2 and [F:HDT]SRENUM = [F:F1]SRENUM
    If fstat Then
      Call ECR_TRACE("$HDKTASK" - [F:F1]SRENUM - [F:HDT]HDTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #Escalades
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(948,182,1) - [F:F1]SRENUM - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [ECE]ECE1 Where [F:ECE]SRENUM = [F:F1]SRENUM
      If ![L]SIMUL Then
        Raz [F:ECE1]
        [F:ECE1] = [F:ECE]
        If dim([F:ECE1]CREHISDAT) > 0 : [F:ECE1]CREHISDAT = date$    : Endif
        If dim([F:ECE1]CREHISUSR) > 0 : [F:ECE1]CREHISUSR = [V]GUSER : Endif
        Write [F:ECE1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$ESCSRE" - [F:ECE]SRENUM - [F:ECE]ESCCOD - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [ECE]ECE1 Where [F:ECE]SRENUM = [F:F1]SRENUM
      Call ECR_TRACE(mess(949,182,1) - [F:F1]SRENUM - [F:ECE]ESCCOD + [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [ECE] Where [F:ECE]SRENUM = [F:F1]SRENUM
    If fstat Then
      Call ECR_TRACE("$ESCSRE" - [F:F1]SRENUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #Réservations de ressources
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
      For [RRS]RRS1 Where [F:RRS]RRSORI = 3 and [F:RRS]RRSORIVCR = [F:ITN]NUM
        If [L]TRACEDET Then
          Call ECR_TRACE(mess(751,182,1) - ":" - [F:RRS]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
        Endif
        If ![L]SIMUL Then
          Raz [F:RRS1]
          [F:RRS1] = [F:RRS]
          If dim([F:RRS1]CREHISDAT) > 0 : [F:RRS1]CREHISDAT = date$    : Endif
          If dim([F:RRS1]CREHISUSR) > 0 : [F:RRS1]CREHISUSR = [V]GUSER : Endif
          Write [F:RRS1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$RESRES" - [F:RRS]NUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  If [L]TRACEDET Then
    For [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
      For [RRS]RRS1 Where [F:RRS]RRSORI = 3 and [F:RRS]RRSORIVCR = [F:ITN]NUM
        Call ECR_TRACE(mess(754,182,1) - ":" - [F:RRS]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
    Next
  Endif
  If ![L]SIMUL Then
    For [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
      Delete [RRS] Where [F:RRS]RRSORI = 3 and [F:RRS]RRSORIVCR = [F:ITN]NUM
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$RESRES" - [F:F1]SRENUM - mess(10,100,1), 1) From GESECRAN
        Break
      Endif
    Next
  Endif
  If IERRINF Then
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
  #---------------------------------------------------#
  # Interventions
  For [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(788,182,1) - ":" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    # ---------------
    #Objet
    If [L]OKHIS Then
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(901,182,1) - ":" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      For [HD6] Where [F:HD6]NUM = [F:ITN]NUM and [F:HD6]TYP = "ITNOBJ"
        If ![L]SIMUL Then
          Raz [F:HD61]
          [F:HD61] = [F:HD6]
          If dim([F:HD61]CREHISDAT) > 0 : [F:HD61]CREHISDAT = date$    : Endif
          If dim([F:HD61]CREHISUSR) > 0 : [F:HD61]CREHISUSR = [V]GUSER : Endif
          Write [F:HD61]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$HD6CLOB" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - [F:HD61]NUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Endif
    # Suppression dans le dossier mère
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(902,182,1) - ":" - [F:ITN]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      Delete [HD6] Where [F:HD6]NUM = [F:ITN]NUM and [F:HD6]TYP = "ITNOBJ"
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$HD6CLOB" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(10,100,1),1) From GESECRAN
        Break
      Endif
    Endif
    # ---------------
    #Compte-rendu
    If [L]OKHIS Then
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(901,182,1) - ":" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      For [HD2] Where [F:HD2]NUM = [F:ITN]NUM and [F:HD2]TYP = "ITN"
        If ![L]SIMUL Then
          Raz [F:HD21]
          [F:HD21] = [F:HD2]
          If dim([F:HD21]CREHISDAT) > 0 : [F:HD21]CREHISDAT = date$    : Endif
          If dim([F:HD21]CREHISUSR) > 0 : [F:HD21]CREHISUSR = [V]GUSER : Endif
          Write [F:HD21]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$HD2CLOB" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - [F:HD21]NUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Endif
    # Suppression dans le dossier mère
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(902,182,1) - ":" - [F:ITN]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      Delete [HD2] Where [F:HD2]NUM = [F:ITN]NUM and [F:HD2]TYP = "ITN"
      If fstat Then
        IERRINF = 1
        Call ECR_TRACE("$HD2CLOB" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(10,100,1), 1) From GESECRAN
        Break
      Endif
    Endif
    # ---------------
    # Intervention elle-même
    If [L]OKHIS Then
      If ![L]SIMUL Then
        Raz [F:ITN1]
        [F:ITN1] = [F:ITN]
        If dim([F:ITN1]CREHISDAT) > 0 : [F:ITN1]CREHISDAT = date$    : Endif
        If dim([F:ITN1]CREHISUSR) > 0 : [F:ITN1]CREHISUSR = [V]GUSER : Endif
        Write [F:ITN1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$INTERVEN" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Endif
  Next
  If IERRINF Then
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
      Call ECR_TRACE(mess(789,182,1) - ":" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [ITN] Where [F:ITN]SRVDEMNUM = [F:F1]SRENUM
    If fstat Then
      Call ECR_TRACE("$INTERVEN" - [F:ITN]SRVDEMNUM - [F:ITN]NUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_SRE
  If clalev([F:HD1])  : Close Local File [HD1]  : Endif
  If clalev([F:HD11]) : Close Local File [HD11] : Endif
  If clalev([F:HD2])  : Close Local File [HD2]  : Endif
  If clalev([F:HD21]) : Close Local File [HD21] : Endif
  If clalev([F:HD6])  : Close Local File [HD6]  : Endif
  If clalev([F:HD61]) : Close Local File [HD61] : Endif
  If clalev([F:HDT])  : Close Local File [HDT]  : Endif
  If clalev([F:HDT1]) : Close Local File [HDT1] : Endif
  If clalev([F:ECE])  : Close Local File [ECE]  : Endif
  If clalev([F:ECE1]) : Close Local File [ECE1] : Endif
  If clalev([F:ITN])  : Close Local File [ITN]  : Endif
  If clalev([F:ITN1]) : Close Local File [ITN1] : Endif
  If clalev([F:RRS])  : Close Local File [RRS]  : Endif
  If clalev([F:RRS1]) : Close Local File [RRS1] : Endif
  If clalev([F:TXC])  : Close Local File [TXC]  : Endif
  If clalev([F:TXC1]) : Close Local File [TXC1] : Endif
  If clalev([F:CAL])  : Close Local File [CAL]  : Endif
  If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

##########################################################################################################
#    Epuration des valeurs des indices                                          #
# ------------------------------------------------------------------------------#
#    CIX : Actions liées à l'épuration des valeurs des indices                  #
#################################################################################
$OUVRE_CIX
  Gosub DECLARE_VARIABLES
  If clalev([F:CON]) = 0  : Local File =[L]APPLI + ".CONTSERV" [CON]  : Endif
Return

##########################################################################################################
$FILTRE_CIX
Return

##########################################################################################################
$CONTROL_CIX
Local Integer IROWCOUNT

  #CHECK FILE_DECLARE CONTIDX [F1]
  #---------------------------------------------------#
  Filter [CON] Where [F:CON]CONBASIDX = [F:F1]IND and ([F:CON]LASIDXDAT  = [F:F1]INDDAT or [F:CON]OLASIDXDAT = [F:F1]INDDAT)
  IROWCOUNT = rowcount([F:CON])
  Filter [CON]
  If IROWCOUNT > 0 Then
    # Indice encore utilisé à cette date : non purgeable
    Call ECR_TRACE(func AFNC.MES2(mess(1154,196,1), [F:F1]IND, format$(GFMDAT4,[F:F1]INDDAT)),1) From GESECRAN
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
Return

##########################################################################################################
$HIS_EPU_CIX
  #CHECK FILE_DECLARE CONTIDX [F1]
  If [L]TRACEDET Then
    Call ECR_TRACE("*" - mess(1,13,1) - [F:F1]IND - format$(GFMDAT4,[F:F1]INDDAT), 0) From GESECRAN
  Endif
  # Valeurs des indices
  Gosub CONTROL_CIX
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
Return

##########################################################################################################
$FERME_CIX
  If clalev([F:CON])  : Close Local File [CON]  : Endif
Return

##########################################################################################################
#    Epuration des Parcs clients                                                #
# ------------------------------------------------------------------------------#
#    MAC : Actions liées à l'épuration des Parcs clients                        #
#################################################################################
$OUVRE_MAC
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:CCV]) = 0 : Local File =[L]APPLI + ".CONTCOV"   [CCV]  : Endif
      Gosub CRETAB_HISTO
      If clalev([F:CCV1])= 0 : Local File =[L]HISAPL+ ".CONTCOV"   [CCV1] : Endif
    Else
      If clalev([F:CCV]) = 0 : Local File =[L]HISAPL + ".CONTCOV"  [CCV]  : Endif
    Endif
  Else
    If clalev([F:CCV]) = 0 : Local File =[L]APPLI + ".CONTCOV"     [CCV]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_MAC
Return

##########################################################################################################
$CONTROL_MAC
Return

##########################################################################################################
$HIS_EPU_MAC
  #CHECK FILE_DECLARE MACHINES [F1]
  #---------------------------------------------------#
  #Couvertures du contrat
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]MACNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT =  [F:F1]MACNUM and [F:CCV]PAEKEY(0) = ""
      If ![L]SIMUL Then
        Raz [F:CCV1]
        [F:CCV1] = [F:CCV]
        If dim([F:CCV1]CREHISDAT)>0 : [F:CCV1]CREHISDAT = date$    : Endif
        If dim([F:CCV1]CREHISUSR)>0 : [F:CCV1]CREHISUSR = [V]GUSER : Endif
        Write [F:CCV1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CONTCOV" - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(776,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT =  [F:F1]MACNUM and [F:CCV]PAEKEY(0) = ""
    If fstat Then
      Call ECR_TRACE("$CONTCOV" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_MAC
  If clalev([F:CCV])  : Close Local File [CCV]  : Endif
  If clalev([F:CCV1]) : Close Local File [CCV1] : Endif
Return

##########################################################################################################
#    Epuration des Demandes de garantie                                         #
# ------------------------------------------------------------------------------#
#    RQW : Actions liées à l'épuration des Demandes de garantie                 #
#################################################################################
$OUVRE_RQW
  Gosub DECLARE_VARIABLES
  If clalev([F:MAC]) = 0 : Local File =[L]APPLI + ".MACHINES"     [MAC]  : Endif
  If clalev([F:RCW]) = 0 : Local File =[L]APPLI + ".WARREQCPN"    [RCW]  : Endif
Return

##########################################################################################################
$FILTRE_RQW
Return

##########################################################################################################
$CONTROL_RQW
Local Integer MACFOUND

  # Elle doit être validée, et le parc associé ne doit plus exister
  MACFOUND = 0
  For [RCW] Where [F:RCW]RQWNUM = [F:F1]RQWNUM
    For [MAC] Where [F:MAC]MACPDTCOD = [F:RCW]ITMREF and MACORI = 5 and [F:MAC]MACORIVCR = [F:F1]RQWNUM and [F:MAC]MACORIVCRL = [F:RCW]RQWNUMLIN
      IMACFOUND = 1
      Break
    Next
    If IMACFOUND = 1 Then
      Break
    Endif
  Next
  If IMACFOUND = 1 Then
    # Au moins un parc existe encore : on ne purge pas
    Call ECR_TRACE(func AFNC.MES1(mess(1155,196,1), [F:F1]RQWNUM), 1) From GESECRAN
    OKHIS = 0
    OKEPU = 0
    Return
  Endif
Return

##########################################################################################################
$HIS_EPU_RQW
  #CHECK FILE_DECLARE WARREQUEST [F1]
Return

##########################################################################################################
$FERME_RQW
  If clalev([F:MAC])  : Close Local File [MAC]  : Endif
  If clalev([F:RCW])  : Close Local File [RCW]  : Endif
Return
