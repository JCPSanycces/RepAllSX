#**
#* GENER_EVE create an event
#*@deprecated
#*
#* @param POBJ        object's class
#* @param PEVENT      event's class
#*!
#Funprog GENER_EVE(POBJ, PEVENT)
#Variable Instance POBJ Using OBJECT
#Variable Instance PEVENT  Using C_EVENT

#  POBJ = cast(POBJ, =POBJ.ObjectType)
#End

#**
#* TAG_GENER_EVE Tag called by every object for creating an event
#*!
$TAG_GENER_EVE

Local Integer LRET, WRETURNCODE

  PEVENT.CPY = POBJ.CPY
  PEVENT.FCY = POBJ.FCY

  Gosub CONTEXT_INFOS
  Gosub OUVRE_TABLE From =PEVENT.TRTEVTINT
  Gosub SET_CRT_INFOS
  [F:EVT0]CNX = PEVENT.CONTEXT

#  GPOINT = "GENEVT"
#  Gosub ENTREE From EXEFNC
#  If [L]ARET_VALUE >=  [V]CST_AERROR
#    [L]BRETURN = [V]CST_AFALSE
#    Return
#  Endif

  # Appel de la fonction d'archivage ARCH_DPRPLN(PAASREF, PDPRPLN, PCODEVT, PTIMSTP, PNUMTRT, PFICTRA, PEVENT.RETU RNCODE)
  #> En attendant une extension du mécanisme à d'autres cas et l'éventualité de pouvoir paramétrer
  #  son déclenchement,

  If  (PEVENT.EVT = "FASMTC" or PEVENT.EVT = "FASREEVAL" or PEVENT.EVT = "FASCHGPPL") and
&      [F:CPY]LEG = "FRA"
    Call ARCH_DPRPLN(PEVENT.REF, PEVENT.PLAN, [0/0/0], [0/0/0], "", PEVENT.EVT,
&                    [F:EVT0]TIMSTP, 0, "", WRETURNCODE) From TRCPROCOMARC
    If WRETURNCODE
      [L]LRET = fmet this.ASETERROR("", "Err [EVENT_CSTD-ARCH_DPRPLN] " -
&                      "(CPY =" - [F:EVT0]CPY -
&                      "EVT =" - PEVENT.EVTINT -"PLAN =" -
&                      num$([F:EVT0]DPRPLN) - "REF =" - [F:EVT0]REF + ") (29)", [V]CST_AERROR)
      [L]BRETURN = [V]CST_AFALSE
      Return
    Endif
  Endif

  Write [EVT0]
  If fstat
    [L]LRET = fmet this.ASETERROR("", "Err [EVENT_CSTD] fstat =" - num$(fstat) -
&                    "(CPY =" - [F:EVT0]CPY - "EVT =" - PEVENT.EVTINT -
&                    "PLAN =" - num$([F:EVT0]DPRPLN) - "REF =" - [F:EVT0]REF + ") (30)", [V]CST_AERROR)
    [L]BRETURN = [V]CST_AFALSE
    Return
  Endif
  PEVENT.TIMSTP = [F:EVT0]TIMSTP  # used by QLF

Return

#**
#* _DEL_PHYELT_EVENT delete an event
#*
#* @param PEVENT      event's class
#*        PEVENT.EVTINT      internal code (mandatory)
#*        PEVENT.REF         reference (mandatory)
#*!
Funprog _DEL_PHYELT_EVENT(PEVENT)
Variable Instance PEVENT  Using C_EVENT

Local Char CRITERE(250)
Local Integer ASTATUS
  PEVENT.PLAN = [V]CST_PLNAUC
  PEVENT.NBDELEVENT = 0

  Gosub OUVRE_TABLE From =PEVENT.TRTEVTINT
#  GOK=1
#  GPOINT = "GENEVT" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
#  If GOK < 1
#    [L]ASTATUS = [V]CST_AERROR
#    [L]ARET_VALUE = [V]CST_AFALSE
#    End
#  Endif

  [L]CRITERE = AVOID.ACHAR
  If PEVENT.REF <> AVOID.ACHAR

    [L]CRITERE -= "REF = PEVENT.REF"

    Delete [EVT0] Where evalue([L]CRITERE)
    If fstat
      [L]ASTATUS = fmet this.ASETERROR("", func AFNC.MES1(mess(100, [V]CST_MSGMIS, 1), PEVENT.EVTINT) - "(33)", [V]CST_AERROR)
      End [V]CST_AFALSE
    Endif

    PEVENT.NBDELEVENT = adxdlrec
    If PEVENT.NBDELEVENT
      If dim(APPLI) < 0
        Local Char APPLI(30)
        APPLI = nomap
      Endif
      Local File =APPLI+".ATEXTRA" [AXX]
      Delete [AXX] Where CODFIC = PEVENT.TABNAME and ZONE = "DES" and IDENT1 = PEVENT.REF
    Endif
  Endif

End [V]CST_ATRUE

#**
#* CONTEXT_INFOS Give context informations
#*!
$CONTEXT_INFOS
#  Local Char    LCNDREQEVT(200)  # Condition de recherche d'événement

  If PEVENT.PLAN = [V]CST_PLNAUC
    PEVENT.CONTEXT = 0
  Else
    PEVENT.CONTEXT = func CNX_CSTD.GETCNXOFPLN(PEVENT.PLAN, fmet GACTX.ACACHE.CNX.AGETVALCHAR(PEVENT.CPY, 1, "CNXOFPLN"))
    If PEVENT.CONTEXT = -1
      PEVENT.CONTEXT = 0
    Endif
  Endif

  PEVENT.CURPERSTR = [0/0/0]
  If PEVENT.CONTEXT = 0 Then
    PEVENT.CURPERSTR = fmet GACTX.ACACHE.CNX.AGETVALDAT(PEVENT.CPY, [V]CST_CNXCPFI, "CURPERSTR")
  Else
    PEVENT.CURPERSTR = fmet GACTX.ACACHE.CNX.AGETVALDAT(PEVENT.CPY, PEVENT.CONTEXT, "CURPERSTR")
  Endif

Return

#**
#* SET_CRT_INFOS set (parameter and general) properties value when create an event
#*!
$SET_CRT_INFOS

  [F:EVT0]CREDAT    = date$
  [F:EVT0]CRETIM    = time
  # Issue number 110495
  [F:EVT0]CREDATTIM = datetime$
  [F:EVT0]AUUID     = getUuid
  # End issue number 110495
  [F:EVT0]TIMSTP = func BUILD_TIMSTP(date$, time)
  PEVENT.TIMSTP = [F:EVT0]TIMSTP
  Gosub EVTINT      From =PEVENT.TRTEVTINT

  [F:EVT0]CPY       = PEVENT.CPY
  [F:EVT0]FCY       = PEVENT.FCY
  [F:EVT0]REF       = PEVENT.REF
  [F:EVT0]CURPERSTR = PEVENT.CURPERSTR

  If PEVENT.JOB_OBJ = [V]CST_OMDEPEN
    [F:EVT0]LIN       = PEVENT.LIN
  Endif

  [F:EVT0]CREUSR    = GACTX.USER
  [F:EVT0]UPDUSR    = ""
  [F:EVT0]UPDDAT    = [0/0/0]
  [F:EVT0]DPRPLN    = PEVENT.PLAN
  [F:EVT0]EVTINT    = PEVENT.EVTINT
  [F:EVT0]EVTDAT    = PEVENT.EFFDAT
  [F:EVT0]CPTFLG    = 1
  [F:EVT0]SNSEVE    = [V]CST_TEACT
  [F:EVT0]CREUSRO   = ""
  [F:EVT0]TIMSTPO   = ""
  If PEVENT.ACCDAT <> [0/0/0]
    [F:EVT0]CPTDATINT = PEVENT.ACCDAT
  Else
    [F:EVT0]CPTDATINT = PEVENT.EFFDAT
  Endif

  [F:EVT0]CUR = func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY, [F:EVT0]DPRPLN)

Return

#**
#* reinit the event's table
#*!
$RAZ_F_EVT0_1

  Raz [F:EVT0], [F:EVT0]

Return

#**
#* BUILD_TIMSTP Build timstamp :
#*
#*   - N° de séquence en base 26 (12 car) contenant
#*          o Heure sur 5 chiffre
#*          o adxuid(1) sur 10 car
#*          o N° de séquence obtenu par incrément de la globale NUMEVT (4 car)
#*
#* @param PDATE   Date YYYYMMDD (8 car)
#* @param PTIME
#*!
Funprog BUILD_TIMSTP(PDATE, PTIME)
Value Date    PDATE
Value Integer PTIME

Local Char    RTIMSTP(30)
Local Decimal DECTIMSTP
Local Char    L36DAT(30)
Local Char    L36SUITE(30)
Local Char    RBAS36TIMSTP(20)

  If dim(GNUMEVT) < 0
    Global Integer GNUMEVT # sans doute à mettre ds CACHE
  Endif

  If GNUMEVT = 99999
    GNUMEVT = 0
  Endif
  GNUMEVT += 1

  Local Integer L_BASE       : L_BASE   = 36
  Local Char    L_YEAR(4)    : L_YEAR   = num$(year(PDATE))
  Local Char    L_MONTH(2)   : L_MONTH  = format$("N0:2",(month(PDATE)))
  Local Char    L_DAY(2)     : L_DAY    = format$("N0:2",(day(PDATE)))
  Local Char    L_TIME(5)    : L_TIME   = format$("N0:5",PTIME)
  Local Char    L_ADXUID(10) : L_ADXUID = format$("N0:10",adxuid(1))
  Local Char    L_SEQ(5)     : L_SEQ   = format$("N0:5",GNUMEVT)

  L36DAT   = func DEC_TO_BASE_N(val(L_YEAR + L_MONTH + L_DAY + L_TIME), L_BASE)
  L36SUITE = func DEC_TO_BASE_N(val(L_ADXUID + L_SEQ), L_BASE)

  RBAS36TIMSTP = L36DAT + "-" + L36SUITE

End RBAS36TIMSTP

#**
#*  Conversion d'un nombre entier en base n
#*
#*
#* @param PNBDEC
#* @param PBASE
#*!
Funprog DEC_TO_BASE_N(PNBDEC, PBASE)
Value Decimal PNBDEC
Value Integer PBASE

Local Integer LEXPBASEN : LEXPBASEN = 26
Local Char    RNBBASEN(30), LBUFFBASEN(30)
Local Integer LQUOTIENT, FINI, I

  LEXPBASEN=26
  Repeat
    If PNBDEC >= PBASE^LEXPBASEN
      Local Integer LDEB
      LQUOTIENT = int(PNBDEC / PBASE^LEXPBASEN)
      If LQUOTIENT<10
        RNBBASEN+=num$(LQUOTIENT)
      Else
        RNBBASEN+=chr$(65+LQUOTIENT-10)
      Endif
      PNBDEC -= LQUOTIENT*PBASE^LEXPBASEN
      LEXPBASEN-=1
    Else
      If dim(LDEB)>0
        RNBBASEN+="0"
      Endif
      LEXPBASEN-=1
    Endif
    I+=1
    If LEXPBASEN<0
      FINI=1
    Endif
    If I=500
      FINI=1
    Endif
  Until FINI

End RNBBASEN

#**
#* GET_DATE_PREVIOUS_EVENT get the most recent event (where EVTDAT < PEVENT.EFFDAT)
#*
#* @param   PEVENT
#*          PEVENT.REF       reference (mandatory)
#*          PEVENT.CPY       company (mandatory)
#*          PEVENT.EVTINT    internal code (mandatory)
#*          PEVENT.DPRPLN    plan (mandatory)
#*          PEVENT.EVTDAT    event date (mandatory)
#* @return  Date of last event without extourn : null date if not found
#*!
Funprog GET_DATE_PREVIOUS_EVENT(PEVENT)
Variable Instance PEVENT Using C_EVENT

Local Integer WRETURN
Local Date WRETURN_DATE, WEFFDAT

  [L]WRETURN_DATE = [0/0/0]
  [L]WEFFDAT = PEVENT.EFFDAT

  Gosub OUVRE_TABLE From =PEVENT.TRTEVTINT

  # read the last event (where EVTDAT < PEVENT.EFFDAT)

  [L]WRETURN = [V]CST_AFALSE

  While [L]WRETURN = [V]CST_AFALSE

    Filter [F:EVT0] Where (REF = PEVENT.REF and
&                          CPY = PEVENT.CPY and
&                          EVTINT = PEVENT.EVTINT and
&                          DPRPLN = PEVENT.PLAN and
&                          EVTDAT < WEFFDAT and
&                          SNSEVE <> [V]CST_TEAACT)
    Read [F:EVT0]EVE0 Last
    Filter [F:EVT0]
    If fstat
      Break
    Endif

# Does exists an EXTOURN event ?

    Filter [F:EVT1] Where ( +
&                REF = PEVENT.REF and
&                CPY = PEVENT.CPY and
&                EVTINT = PEVENT.EVTINT and
&                DPRPLN = PEVENT.PLAN and
&                CREUSRO = [F:EVT0]CREUSR and
&                TIMSTPO = [F:EVT0]TIMSTP and
&                SNSEVE = [V]CST_TEAACT)

    Read [F:EVT1]EVE1 Last
    Filter [F:EVT1]

    # It's an event without extourn : It's Ok
    If fstat > [V]CST_AOK
      [L]WRETURN = [V]CST_ATRUE
      [L]WRETURN_DATE = [F:EVT0]EVTDAT
      Break
    Else
      # changed date for searching an older event
      [L]WEFFDAT = [F:EVT0]EVTDAT
    Endif
  Wend

End [L]WRETURN_DATE

#**
#*  Donne le nom d'un axe pour une société et un type de référentiel donnés
#*
#*
#* @param PCPY      Company
#* @param PPLN      depreciation plan
#* @param PNUMAXE   axe's number(1 to 9)
#*!
Funprog GET_DIE_BY_PLN(PCPY, PPLN, PNUMAXE)
Value Char    PCPY()
Value Integer PPLN
Value Integer PNUMAXE

Local Integer LCOATYP

  If PPLN = [V]CST_PLNCPT
    LCOATYP = 2
  Elsif PPLN = [V]CST_PLNIAS
    LCOATYP = 3
  Else
    Local Integer RCNX
    Call GET_CNX_FROM_PLAN (PCPY, PPLN, RCNX)  From GLOBIENS
    If RCNX
      Local File CONTEXT [CNX]
      Read [F:CNX]CNX0 = PCPY; RCNX
      If !fstat
        Local Integer I_PLN
        I_PLN = find(PPLN, [F:CNX]PLNCAA)
        If I_PLN
          Case [F:CNX]ORIBASDPR(I_PLN-1)
          When 1 : LCOATYP=2
          When 2 : LCOATYP=3
          When Default : LCOATYP=2
          Endcase
        Endif
      Endif
    Endif
  Endif

End func GET_DIE_BY_COA_TYP(PCPY, LCOATYP, PNUMAXE)

#**
#*  Renvoie la section correspondant au code axe passé ene paramétre
#*
#*
#* @param PCLASSE
#* @param PDIENAM
#* @param PCCENAM
#* @param PDIE
#*!
# - CBO - 26.06.2015 - FQ107956 - La fct GET_CCE (ici au même niveau que dans GENEVE) est moins developpée que dans TRTFASTRF

Funprog GET_CCE(PCLASSE, PDIENAM, PCCENAM, PDIE)
Value Char    PCLASSE()
Value Char    PDIENAM()
Value Char    PCCENAM()
Value Char    PDIE()

Local Char    LDIENAM(30), LCCENAM(30)
Local Integer I_DIE

  # Issue  X3-64332
  If PDIENAM = ""
    LDIENAM = "DIE"
  Else
    LDIENAM = PDIENAM
  Endif
  If PCCENAM = ""
    LCCENAM = "CCE"
  Else
    LCCENAM = PCCENAM
  Endif

  I_DIE = evalue("find('" + PDIE + "'," + PCLASSE + LDIENAM + ")")
  If I_DIE
    End evalue(PCLASSE + LCCENAM + "(" + num$(I_DIE - 1) + ")")
  Endif

End ""

#**
#*  Donne le nom d'un axe
#*
#* @param PCPY
#* @param PCOATYP
#* @param PNUMAXE
#*!
Funprog GET_DIE_BY_COA_TYP(PCPY, PCOATYP, PNUMAXE)
Value Char    PCPY()
Value Integer PCOATYP
Value Integer PNUMAXE

 Local Char LGCM(30), LCOA(30)
 Local Integer I_LED

 Local File GACM [GCM]
 Local File GLED [LED]

#  Call SETGCM(PCPY, LGCM) From CPTDIV
  Local File COMPANY [CPY]
  Read[CPY]CPY0 = PCPY
  LGCM = [F:CPY]ACM

#  Call LECTURE("GCM", LGCM, "") From CONTOBJ
  Read[GCM]GCM0 = LGCM

  Case PCOATYP
  When 2
    I_LED = [F:GCM]ANALEDTYP - 1
    If I_LED >= 0
      LCOA  = [F:GCM]LED(I_LED)
    Endif
  When 3
    I_LED = [F:GCM]IASLEDTYP-1
    If I_LED >= 0
      LCOA  = [F:GCM]LED(I_LED)
    Endif
  Endcase

  If LCOA <> ""
#    Call LECTURE("LED", LCOA, "") From CONTOBJ
    Read[LED]LED0 = LCOA

    End [F:LED]DIE(PNUMAXE - 1)
  Endif
End ""

