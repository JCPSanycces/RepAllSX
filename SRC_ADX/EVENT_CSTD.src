$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

$METHODS
#Case [L]AMETHOD
#Endcase
Return

$OPERATIONS

  Case [L]CURPTH
    When ""
      Case [L]AOPERATION
        When "INIT_EVENT"           : Gosub INIT_EVENT
        When "CRT_EVENT_PHY"        : Gosub CRT_EVENT_PHY
        When "CRT_EVENT_LOF"        : Gosub CRT_EVENT_LOF
        When "CRT_EVENT_FAS"        : Gosub CRT_EVENT_FAS
        When "EXT_EVENT"            : Gosub EXT_EVENT
        When "DEL_PHYELT_EVENT"     : Gosub DEL_PHYELT_EVENT
        When "DEL_ALL_PHYELT_EVENT" : Gosub DEL_ALL_PHYELT_EVENT
        When "GET_TABLE_VALUE"      : Gosub GET_TABLE_VALUE
      Endcase
  Endcase

Return

$PROPERTIES

  Case [L]CURPRO
  Endcase

Return


