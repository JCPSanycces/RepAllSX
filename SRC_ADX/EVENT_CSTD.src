#**
#* INIT_EVENT Init the event's class for an named(EVTINT) event
#* @param    EVENT.EVTINT       internal code of event (mandatory)
#*
#* @return   EVENT.TRTEVTINT    generated script of event
#* @return   EVENT.PLAN         ([V]CST_PLNAUC if no plan)
#* @return   EVENT.EVT          event's code
#* @return   EVENT.TABNAME      event's tabname
#* @return   EVENT.JOB_OBJ      event's object
#*!
$INIT_EVENT

Local Integer EXISTE_ADX

  If this.EVTINT = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": EVTINT (1)", [V]CST_AERROR)
    Return
  Endif

  this.TRTEVTINT = "GVS" + this.EVTINT

  Call EXISTE_ADX("", "", this.TRTEVTINT, [L]EXISTE_ADX) From ORDSYS
  If [L]EXISTE_ADX = 0
    [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES5(mess(80, 144, 1), this.TRTEVTINT, "", "", "", "") - "(2)", [V]CST_AERROR)
    Return
  Endif

  Call _INFOS_EVT(this)

  [L]ARET_VALUE = [V]CST_AOK

Return

#**
#* private (and technical) function for acces to $INFO_EVTINT with the same parameter's name
#*
#* @param PEVENT
#*!
Subprog _INFOS_EVT(PEVENT)
Variable Instance PEVENT Using C_EVENT

  Gosub INFO_EVTINT From =PEVENT.TRTEVTINT

End

#**
#* Create an event (Physical element)
#*
#* After 'Local Instance EVT Using C_EVENT...' and before calling the method,
#* it must be done :
#* EVENT.EVTINT = "name"   internal code of event (mandatory, ex = "PHYAFFGEO")
#* fmet EVENT.INIT_EVENT() mandatory called
#*
#* @param POBJECT       PHYELT class (must be read (or affected))
#* @param EVENT.REF     mandatory
#* @param EVENT.EFFDAT  effective date (ex = date$)
#* @param EVENT.ACCDAT  accounting date (ex = [0/0/0])
#*!
$CRT_EVENT_PHY

  Gosub CTRL_PARAM_CRT
  If [L]ARET_VALUE >= [V]CST_AERROR
    Return
  Endif

  If func GENER_EVE_PHY(POBJECT, this) = [V]CST_ATRUE
    [L]ARET_VALUE = [V]CST_AOK
  Else
    [L]ARET_VALUE = [V]CST_AERROR
  Endif

Return

#**
#* CRT_EVENT_LOF Create an event (Expense)
#* @param POBJECT     LAYOUT class
#*        POBJECT must be read (or affected)
#*
#*  After 'Local Instance EVT Using C_EVENT...' and before calling the method,
#*  it must be done :
#*  EVENT.EVTINT = "name"   mandatory (ex = "PHYAFFGEO")
#*  fmet EVENT.INIT_EVENT() mandatory called
#*
#*  @param                EVENT.REF       mandatory
#*  @param                EVENT.LIN       mandatory
#*  @param                EVENT.EFFDAT    effective date (ex = date$)
#*  @param                EVENT.ACCDAT    accounting date (ex = [0/0/0])
#*
#*!
$CRT_EVENT_LOF

  Gosub CTRL_PARAM_CRT
  If [L]ARET_VALUE >= [V]CST_AERROR
    Return
  Endif

  If func GENER_EVE_LOF(POBJECT, this) = [V]CST_ATRUE
    [L]ARET_VALUE = [V]CST_AOK
  Else
    [L]ARET_VALUE = [V]CST_AERROR
  Endif

Return

#**
#* CRT_EVENT_FAS Create an event (Fixed asset)
#* @param POBJECT     FXDASSETS class
#*        POBJECT must be read (or affected)
#*
#*  After 'Local Instance EVT Using C_EVENT...' and before calling the method,
#*  it must be done :
#*  EVENT.EVTINT = "name"   mandatory (ex = "PHYAFFGEO")
#*  fmet EVENT.INIT_EVENT() mandatory called
#*
#*  @param                EVENT.REF       mandatory
#*  @param                EVENT.EFFDAT    effective date (ex = date$)
#*  @param                EVENT.ACCDAT    accounting date (ex = [0/0/0])
#*
#*!
$CRT_EVENT_FAS

  Gosub CTRL_PARAM_CRT
  If [L]ARET_VALUE >= [V]CST_AERROR
    Return
  Endif

  If func GENER_EVE_FAS(POBJECT, this) = [V]CST_ATRUE
    [L]ARET_VALUE = [V]CST_AOK
  Else
    [L]ARET_VALUE = [V]CST_AERROR
  Endif

Return

#**
#* EXT_EVENT Extourn's event
#* if he doesn't exist : it is created
#*
#*  After 'Local Instance EVT Using C_EVENT...' and before calling the method,
#*  it must be done :
#*  EVENT.EVTINT = "name"   mandatory (ex = "PHYAFFGEO")
#*  fmet EVENT.INIT_EVENT() mandatory called
#*
#*  EVENT.REF       mandatory
#*  EVENT.LIN       mandatory if LAYOUTFAS
#*  EVENT.CPY       mandatory
#*  EVENT.PLAN      mandatory
#*  EVENT.EFFDAT    mandatory
#* @return PEVENT.TIMSTP
#* @return : [V]CST_AOK       event found and extourn created
#* @return : [V]CST_AWARNING  event not found
#* @return : [V]CST_AERROR    error
#*
#*!
$EXT_EVENT

#Local Integer STA
Local Char WERRMSG(250)

  Gosub CTRL_PARAM_EXT
  If [L]ARET_VALUE >= [V]CST_AERROR
    Return
  Endif

  Call _CONTEXT_INFOS(this)
  Gosub OUVRE_TABLE From =this.TRTEVTINT

  # read the last event

  Filter [F:EVT0] Where (REF = this.REF and
&                        CPY = this.CPY and
&                        EVTINT = this.EVTINT and
&                        DPRPLN = this.PLAN and
&                        EVTDAT = this.EFFDAT and
&                        SNSEVE <> [V]CST_TEAACT)
  Read [F:EVT0]EVE0 Last
  If fstat
    # not a real error (RETURNCODE = CST_AWARNING)
    [L]ASTATUS = fmet this.ASETERROR("", func AFNC.MES1(mess(104, [V]CST_MSGMIS, 1), this.REF), [V]CST_AWARNING)
    Return
  Endif

  this.TIMSTP = [F:EVT0]TIMSTP

# Does exists an EXTOURN event ?

  Filter [F:EVT1] Where ( +
&              REF = this.REF and
&              CPY = this.CPY and
&              EVTINT = this.EVTINT and
&              DPRPLN = this.PLAN and
&              CREUSRO = [F:EVT0]CREUSR and
&              TIMSTPO = [F:EVT0]TIMSTP and
&              SNSEVE = [V]CST_TEAACT)

  Read [F:EVT1]EVE1 Last
  # It doesn'nt exist : It's not a problem : we keep it (and don't create an other one)
  If fstat = [V]CST_AOK
    [L]ARET_VALUE = [V]CST_AOK
    Return
  Endif

  # differents infos in extourn event
  [F:EVT0]SNSEVE = [V]CST_TEAACT
  [F:EVT0]CREUSRO = [F:EVT0]CREUSR
  [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
  [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
  [F:EVT0]CREUSR = GACTX.USER
  [F:EVT0]CREDAT = date$
  # Issue number 110495
  [F:EVT0]CREDATTIM = datetime$
  [F:EVT0]AUUID     = getUuid
  # End issue number 110495
  [F:EVT0]CRETIM = time
  [F:EVT0]CPTFLG = [V]CST_ANO
  [F:EVT0]EVTDAT = this.EFFDAT
  [F:EVT0]TIMSTP = func BUILD_TIMSTP(date$, time)

  GPOINT = "ANNEVT" : Gosub ENTREE From EXEFNC
  If [L]ARET_VALUE >= [V]CST_AERROR
    Return
  Endif

  Write [EVT0]
  If fstat
    If this.PLAN = [V]CST_PLNAUC
      [L]WERRMSG = "[EXT_EVENT] Err /fstat = " - num$(fstat) - "\" - [F:EVT0]CPY - "-" - [F:EVT0]EVTINT - "-" - [F:EVT0]REF - "(4)"
    Else
      [L]WERRMSG = "[EXT_EVENT] Err /fstat = " - num$(fstat) - "\" - [F:EVT0]CPY - "-" - [F:EVT0]EVTINT - "-" - num$([F:EVT0]PLN) - "-" - [F:EVT0]REF - "(5)"
    Endif
    [L]ARET_VALUE = fmet this.ASETERROR("", [L]WERRMSG, [V]CST_AERROR)
  Else
    [L]ARET_VALUE = [V]CST_AOK
  Endif
  this.TIMSTP = [F:EVT0]TIMSTP  # for QLF

Return

#**
#* _CONTEXT_INFOS private (and technical) function for acces to $CONTEXT_INFOS with the same parameter's name
#*
#* @param PEVENT
#*!
Subprog _CONTEXT_INFOS(PEVENT)
Variable Instance PEVENT  Using C_EVENT

  Gosub CONTEXT_INFOS

End

#**
#* DEL_PHYELT_EVENT delete physical assets events from one REF and one TYPE
#*
#*  EVENT.REF       mandatory
#*  EVENT.EVTINT    mandatory (ex := EPHYCRT")
#*
#*!ok
$DEL_PHYELT_EVENT

Local Char    CRITERE(255)
Local Integer STA

  [L]STA = fmet this.INIT_EVENT()

  Gosub CTRL_PARAM_DEL_PHY
  If [L]ARET_VALUE >=  [V]CST_AERROR
    Return
  Endif

  If func _DEL_PHYELT_EVENT(this) = [V]CST_ATRUE
    [L]ARET_VALUE = [V]CST_AOK
  Else
    [L]ARET_VALUE = [V]CST_AERROR
  Endif

Return

#**
#* DEL_ALL_PHYELT_EVENT delete physical events from one REF and all TYPEs
#*
#* @param this.REF      : mandatory
#*
#*!
$DEL_ALL_PHYELT_EVENT

Local Integer NBDELEVENT_TOT
Local File ATABDIV  [ADI]

  [L]NBDELEVENT_TOT = 0
  this.NBDELEVENT = 0

  For [ADI] Where NUMTAB = [V]CST_TD_EVENT and N2 = [V]CST_OMPHY

    If [F:ADI]CODE <> AVOID.ACHAR

      this.EVT = [F:ADI]CODE
      this.EVTINT = [F:ADI]CODE

      this.NBDELEVENT = 0
      Gosub DEL_PHYELT_EVENT
      If [L]ARET_VALUE <> [V]CST_AOK
        [L]NBDELEVENT_TOT = 0
        Break
      Endif
      [L]NBDELEVENT_TOT += this.NBDELEVENT
    Endif

    this.NBDELEVENT = [L]NBDELEVENT_TOT

  Next

Return

#**
#* GET_TABLE_VALUE Read an event and give the property's value
#*
#* @param   this.REF       mandatory
#*
#* @param   this.TIMSTP    mandatory
#* OR
#* @param   this.EVTINT    mandatory (grouped)
#* @param   this.DPRPLN    mandatory (grouped)
#*
#* @param   PPROPERTY     : property to evalue
#* @return  RVALUE        : property's value
#*!
$GET_TABLE_VALUE

  [L]ARET_VALUE =  [V]CST_AOK
  RVALUE = AVOID.ACHAR
  Gosub OUVRE_TABLE  From =this.TRTEVTINT

  # Issue 110604
  If this.EFFDAT <> AVOID.ADATE
  # read the event

    Filter [F:EVT0] Where (REF = this.REF and
&                        EVTDAT = this.EFFDAT and
&                        EVTINT = this.EVTINT and
&                        DPRPLN = this.PLAN and
&                        SNSEVE <> [V]CST_TEAACT)
    Read [F:EVT0]EVE3 First
    Filter [F:EVT0]

  # End Issue 110604
  Elsif this.TIMSTP = AVOID.ACHAR
  # read the last event

    Filter [F:EVT0] Where (REF = this.REF and
&                        EVTINT = this.EVTINT and
&                        DPRPLN = this.PLAN and
&                        SNSEVE <> [V]CST_TEAACT)
    Read [F:EVT0]EVE0 Last
    Filter [F:EVT0]

  Else

  # read the (exact) event
    Read [F:EVT0]EVE0 =this.REF; this.TIMSTP
    If fstat
      [L]ARET_VALUE = fmet this.ASETERROR("", "No event =" - this.REF - this.TIMSTP - "(6)", [V]CST_AERROR)
      Return
    Endif
  Endif

  Onerrgo ERROR_GET_TABLE_VALUE

  Case evalue("type( [F:EVT0]" + PPROPERTY + ")")
    When 1, 2, 4, 5, 6, 7, 9
      RVALUE = evalue("num$([F:EVT0]" + PPROPERTY + ")")
    When 3
      RVALUE = format$("D:DDMMYYYY", evalue("[F:EVT0]" + PPROPERTY))
    When Default
      RVALUE = evalue("[F:EVT0]" + PPROPERTY)
  Endcase
  Onerrgo

Return


# ==============================================================================
#
# End of methods
#
# Begin of used functions, subprogs, tags :
#
# ==============================================================================

#**
#* ERROR_GET_TABLE_VALUE Error in GET_TABLE_VALUE
#*!
$ERROR_GET_TABLE_VALUE

  [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES2(mess(222, 115, 1), PPROPERTY, this.TABNAME) - "(7)", [V]CST_AERROR)

Resume

#**
#* CTRL_PARAM_CRT control if all needed params are not null (create)
#*!
$CTRL_PARAM_CRT

  If this.EVTINT = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": EVTINT (10)", [V]CST_AERROR)
  Endif

  If this.REF = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": REF (11)", [V]CST_AERROR)
  Endif

  If this.JOB_OBJ = [V]CST_OMDEPEN
    If this.LIN = AVOID.AINT
      [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": LIN (12)", [V]CST_AERROR)
    Endif
  Else
    this.LIN = AVOID.AINT
  Endif

Return

#**
#* CTRL_PARAM_EXT control if all needed params are not null (extourn)
#*!
$CTRL_PARAM_EXT

  If this.EVTINT = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": EVTINT (19)", [V]CST_AERROR)
  Endif

  If this.CPY = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": CPY (20)", [V]CST_AERROR)
  Endif

  If this.REF = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": REF (21)", [V]CST_AERROR)
  Endif

  If this.PLAN = AVOID.AINT
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": PLAN (22)", [V]CST_AERROR)
  Endif

  #_________________________________________________________
  If this.JOB_OBJ = [V]CST_OMDEPEN
    If this.LIN = AVOID.AINT
      [L]ARET_VALUE = fmet this.ASETERROR("", WERRMSG, [V]CST_AERROR)
    Endif
  Else
    this.LIN = AVOID.AINT
  Endif

  If this.EFFDAT = AVOID.ADATE
  # Issue X3-32955
#    [L]ARET_VALUE = fmet this.ASETERROR("", WERRMSG, [V]CST_AERROR)
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": EFFDAT (23)", [V]CST_AERROR)
  # End Issue X3-32955
  Endif

Return

#**
#* CTRL_PARAM_DEL_PHY control if all needed params are not null (delete PHYELT event)
#*!
$CTRL_PARAM_DEL_PHY

  If this.EVTINT = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": EVTINT (26)", [V]CST_AERROR)
  Endif

  If this.REF = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(171, 133, 1) - ": REF (27)", [V]CST_AERROR)
  Endif

Return

#**
#* GENER_EVE_PHY Create an Physical asset's event
#*
#* @param POBJ        object's class
#* @param PEVENT      event's class
#*!
Funprog GENER_EVE_PHY(POBJ, PEVENT)
Variable Instance POBJ Using C_PHYELT
Variable Instance PEVENT Using C_EVENT

Local Integer BRETURN

  [L]BRETURN = [V]CST_ATRUE
  Gosub TAG_GENER_EVE

End [L]BRETURN

