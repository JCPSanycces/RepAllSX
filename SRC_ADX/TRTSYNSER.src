#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
# ACTION  : SAISYNSER  : Resynchronisation manuelle des numéros séries  #
#                        d'une ligne de stock                           #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "BOUTON"        : Gosub BOUTON
 When "MEN"           : Gosub MENU
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
 When "RAF"           : WAFFPICK=1
 When "TIR"           : WAFFPICK=1
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE
 When "HINT"          : Gosub HINT_KEY
 When "DEB_PIC"       : Gosub DEB_PIC
 When "CRE_PIC"       : Gosub CRE_PIC
 When "ANU_PIC"       : Gosub ANU_PIC
 When "FIN_PIC"       : Gosub FIN_PIC
 Endcase

Return

#########################################################################
#    Actions liés à la fenêtre                                          #
#########################################################################

$OUVRE
Local Integer WPICK           : # 1=depick / 2=pick
Local Integer WAFFPICK        : # 0=pas d'alimentation picking
Local Integer WGENR           : # 1 si on a enregistré , 0 sinon
Local Char    LFCY(GLONFCY)
Local Char    LITM(GLONITM)
Local Decimal LSTO, OLDSTO
Local Integer LNOL
Local Integer LRET
Local Integer OK
Local Integer I, J, K, NOL

Raz WGENR
# Récupération des paramètres
LFCY    = PARAM(1)
LITM    = PARAM(2)
LSTO    = val(PARAM(3))
LNOL    = val(PARAM(4))

If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:STO])=0  Local File STOCK      [STO]   Endif
If clalev([F:STS])=0  Local File STOSER     [STS]   Endif
If clalev([F:STS1])=0 Local File STOSER     [STS1]  Endif
Return

$OUVRE_BOITE
# Récupération des noms de currbox des tiroirs
Global Char  GBOXSTS1(10),GBOXSTS2(10)
GBOXSTS1 = "GAU_CHE1"
GBOXSTS2 = "GAU_CHE2"
Return

$DEBUT
[M:STS0]STOFCY = LFCY
[M:STS0]ITMREF = LITM
[M:STS0]STOCOU = LSTO
Read [ITM]ITM0=[M:STS0]ITMREF
If fstat
  Call RSTA ("ITM",[M:STS0]ITMREF) From GLOCK
  FIN=1 : Return
Endif
Read [ITF]ITF0=[M:STS0]ITMREF;[M:STS0]STOFCY
If fstat
  Call RSTA ("ITF",[M:STS0]STOFCY-[M:STS0]ITMREF) From GLOCK
  FIN=1 : Return
Endif

Read [STO]STO0=[M:STS0]STOFCY;[M:STS0]STOCOU
If fstat
  Call RSTA ("STO",[M:STS0]STOFCY-num$([M:STS0]STOCOU)) From GLOCK
  FIN=1 : Return
Endif
[M:STS0] = [F:STO]

[M:STS0]STOSTU1 = [F:ITM]STU
[M:STS0]STOSTU2 = [F:ITM]STU

[M:STS0]STOQTYINI = [F:STO]QTYSTU
[M:STS0]STOQTYNEW = [F:STO]QTYSTU

Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
[M:STS0]STOSERINI = rowcount([F:STS])
[M:STS0]STOSERNEW = [M:STS0]STOSERINI
Filter [STS]

Effzo [M:STS1]

Gosub TIROIR

Return

$SETBOUT
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

$APRES_MODIF

Return

$AVANT_ENR
If [M:STS1]NBLIG1=0 & [M:STS1]NBLIG2=0
  Call ERREUR(mess(300,139,1)) From GESECRAN
  FOK=0 : Return
Endif

If [M:STS0]STOSERNEW<>[M:STS0]STOQTYNEW
  OK=1 : Call AVERTIR(mess(499,184,1), OK) From GESECRAN
  If OK=1
    FOK=0 : Return
  Endif
Endif

If [M:STS1]NBLIG1>0
  For I=0 To [M:STS1]NBLIG1-1
    If [M:STS1]STOCOU1(I)=[M:STS0]STOCOU
      GMESSAGE=[M:STS1]SERNUM1(I)-mess(497,184,1)
      FOK=0 : GERR=1
      Break
    Endif
  Next I
  If FOK=0 : Return : Endif
Endif

Return

$ENR
If [M:STS1]NBLIG1>0 | [M:STS1]NBLIG2>0
  Call ECR_TRACE(mess(287,195,1)-[M:STS0]ITMREF,0) From GESECRAN
Endif

Trbegin [STS]
# Traitement des no séries dissociés du chrono stock traité
If [M:STS1]NBLIG1>0
  For I=0 To [M:STS1]NBLIG1-1
    Readlock [STS]STS0=[M:STS0]ITMREF;[M:STS1]SERNUM1(I)
    If fstat
      Call RSTA ("STS",[M:STS0]ITMREF,[M:STS1]SERNUM1(I)) From GLOCK
      FOK=0 : Break
    Else
      OLDSTO=[F:STS]STOCOU
      # Réécriture du no série avec le nouveau chrono stock
      # Attention s'il est nul, il sera supprimé lors de la resynchro automatique
      [F:STS]STOCOU = [M:STS1]STOCOU1(I)
      Call REWSTS From STKLIB
      If fstat
        Call FSTA ("STS") From GLOCK
        FOK=0 : Break
      Endif
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
      If LRET<>0 : FOK=0 : Break : Endif

      Call ECR_TRACE("-"-mess(47,197,1)-":"-[F:STS]SERNUM,0) From GESECRAN
      Call ECR_TRACE("---"-mess(70,151,1)-mess(50,196,1)-":"-num$([F:STS]STOCOU)-" "-mess(551,177,1)-mess(50,196,1)-":"-num$(OLDSTO),0) From GESECRAN
    Endif
  Next I
  If FOK=0
    Rollback : Return
  Endif
Endif

# Traitement des no séries associés au chrono stock traité
If [M:STS1]NBLIG2>0
  For I=0 To [M:STS1]NBLIG2-1
    Readlock [STS]STS0=[M:STS0]ITMREF;[M:STS1]SERNUM2(I)
    If fstat=5
      [F:STS]ITMREF = [M:STS0]ITMREF
      [F:STS]SERNUM = [M:STS1]SERNUM2(I)
      [F:STS]STOCOU = [M:STS0]STOCOU
      [F:STS]STOFCY = [M:STS0]STOFCY
      Call ECRSTS From STKLIB
      If fstat
        Call FSTA ("STS") From GLOCK
        FOK=0 : Break
      Endif
      OLDSTO=0
    Elsif fstat
      Call RSTA ("STS",[M:STS0]ITMREF,[M:STS1]SERNUM2(I)) From GLOCK
      FOK=0 : Break
    Else
      OLDSTO=[F:STS]STOCOU
      # Réécriture du no série avec le chrono stock traité
      [F:STS]STOCOU = [M:STS0]STOCOU
      Call REWSTS From STKLIB
      If fstat
        Call FSTA ("STS") From GLOCK
        FOK=0 : Break
      Endif
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
      If LRET<>0 : FOK=0 : Break : Endif
    Endif
    Call ECR_TRACE("-"-mess(47,197,1)-":"-[F:STS]SERNUM,0) From GESECRAN
    Call ECR_TRACE("---"-mess(70,151,1)-mess(50,196,1)-":"-num$([F:STS]STOCOU)-" "-mess(551,177,1)-mess(50,196,1)-":"-num$(OLDSTO),0) From GESECRAN
  Next I
  If FOK=0
    Rollback : Return
  Endif
Endif

Commit
# On a enregistré
WGENR = 1
FIN=1

Return

$ABA

Return

$BOUTON

Return

$MENU

Return

$FIN
# Si on a enregistré
If WGENR=1
  Gosub CHARGE_ITM From FUNSYNSER
# Si on a pas enregistré, libération des no séries
Else
  If [M:STS1]NBLIG1>0
    For I=0 To [M:STS1]NBLIG1-1
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[M:STS1]SERNUM1(I),1,LRET) From STKLIB
    Next I
  Endif
  If [M:STS1]NBLIG2>0
    For I=0 To [M:STS1]NBLIG2-1
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[M:STS1]SERNUM2(I),1,LRET) From STKLIB
    Next I
  Endif
Endif

Return

$FINSAI

Return

$FILGAUCHE
Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)
Case currbox
 When GBOXSTS1 : Gosub FILGAUSTS1
 When GBOXSTS2 : Gosub FILGAUSTS2
Endcase
Return

$FILGAUSTS1
FILGAUSUP(0)='[F:STS]ITMREF=[M:STS0]ITMREF & [F:STS]STOCOU=[M:STS0]STOCOU & ISSDAT=[0/0/0]'
Return

$FILGAUSTS2
FILGAUSUP(0)='[F:STS]ITMREF=[M:STS0]ITMREF & [F:STS]STOCOU<>[M:STS0]STOCOU & ISSDAT=[0/0/0]'
Return

$AP_FILGAUCHE
WPICK=2 : Gosub RAFFRAICHI
Return

$CLE_GAUCHE
Return

$HINT_KEY
Return

$DEB_PIC
Return

$CRE_PIC
Case currbox
 When GBOXSTS1 : Gosub CRE_PICSTS1
 When GBOXSTS2 : Gosub CRE_PICSTS2
Endcase
Return

# No séries à retirer
$CRE_PICSTS1

Read [STS]STS0=[F:STS]ITMREF;[F:STS]SERNUM
If fstat
   Call RSTA ("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK
   FOK=0 : Return
Elsif [F:STS]SDHNUM<>""
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(495,184,1)
   FOK=0  : Return
Endif
Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
If fstat
   Call RSTA ("STO",[F:STS]STOFCY-num$([F:STS]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
#--- No série en cours de traitement?
If func STKLIB.REC_STOSERW_UID([F:STS]ITMREF,[F:STS]SERNUM,adxuid(1))<>0
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(449,184,1)
   FOK=0  : Return
Endif

If [M:STS0]STOQTYNEW>=[M:STS0]STOSERNEW
  OK=1 : Call AVERTIR(num$([F:STS]STOCOU)+"\"+mess(501,184,1), OK) From GESECRAN
  If OK=1 : FOK=0 : Return : Endif
Endif

# Contrôle de l'insertion
If [M:STS1]NBLIG1+1 >= dim([M:STS1]SERNUM1)-1
  FOK=0 : GERR=1
  GMESSAGE=mess(122,199,1)
  Return
Endif

# Création no série en cours de traitement
Call CRE_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
If LRET<>0 : FOK=0 : Return : Endif

# Ouverture de la ligne
nolign = [M:STS1]NBLIG1
Insa nolign,1,[M:STS1]NBLIG1 [M:STS1]NBLIG1
[M:STS1]NBLIG1 += 1
nolign = [M:STS1]NBLIG1
NOL = nolign-1
status = 0

[M:STS1]SERNUM1(NOL) = [F:STS]SERNUM
[M:STS1]STOCOU1(NOL) = [F:STS]STOCOU
[M:STS1]STA1(NOL)    = [F:STO]STA
If dim([M:STS1]LOT1)>0 [M:STS1]LOT1(NOL) = [F:STO]LOT Endif
If dim([M:STS1]SLO1)>0 [M:STS1]SLO1(NOL) = [F:STO]SLO Endif
If dim([M:STS1]LOC1)>0 [M:STS1]LOC1(NOL) = [F:STO]LOC Endif
If dim([M:STS1]ECCVALMAJ1)>0 [M:STS1]ECCVALMAJ1(NOL) = [F:STO]ECCVALMAJ Endif
If dim([M:STS1]PALNUM1)>0    [M:STS1]PALNUM1(NOL)    = [F:STO]PALNUM    Endif
If dim([M:STS1]CTRNUM1)>0    [M:STS1]CTRNUM1(NOL)    = [F:STO]CTRNUM    Endif
If dim([M:STS1]STOFLD11)>0   [M:STS1]STOFLD11(NOL)   = [F:STO]STOFLD1   Endif
If dim([M:STS1]STOFLD12)>0   [M:STS1]STOFLD12(NOL)   = [F:STO]STOFLD2   Endif

#[M:SS1]SERNEW(LNOL)-= 1
[M:STS0]STOSERNEW  -= 1
Affzo [M:STS0]STOSERNEW

Return

# No séries à ajouter
$CRE_PICSTS2
# Il y a déjà trop de no séries pour ce chrono stock
If [M:STS0]STOSERNEW>=[M:STS0]STOQTYNEW
  OK=1 : Call AVERTIR(num$([M:STS0]STOCOU)+"\"+mess(500,184,1), OK) From GESECRAN
  If OK=1 : FOK=0 : Return : Endif
Endif

Read [STS]STS0=[F:STS]ITMREF;[F:STS]SERNUM
If fstat
   Call RSTA ("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK
   FOK=0 : Return
Elsif [F:STS]SDHNUM<>""
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(495,184,1)
   FOK=0  : Return
Endif
Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
If fstat
   # Ne pas mettre de message d'erreur, car il faut pouvoir prendre le no série
   Raz [F:STO]
   #Call RSTA ("STO",[F:STS]STOFCY-num$([F:STS]STOCOU)) From GLOCK
   #FOK=0 : Return
Endif
#--- No série en cours de traitement?
If func STKLIB.REC_STOSERW_UID([F:STS]ITMREF,[F:STS]SERNUM,adxuid(1))<>0
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(449,184,1)
   FOK=0  : Return
Endif

Filter [STS1] Where ITMREF=[M:STS0]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
If rowcount([F:STS1])=[F:STO]QTYSTUACT
  OK=1 : Call AVERTIR(num$([F:STO]STOCOU)+"\"+mess(496,184,1), OK) From GESECRAN
  If OK=1 : FOK=0 : Endif
Elsif rowcount([F:STS1])<[F:STO]QTYSTUACT
  OK=1 : Call AVERTIR(num$([F:STO]STOCOU)+"\"+mess(501,184,1), OK) From GESECRAN
  If OK=1 : FOK=0 : Endif
  Endif
Filter [STS1]
If FOK=0: Return: Endif

# Contrôle de l'insertion
If [M:STS1]NBLIG2+1 >= dim([M:STS1]SERNUM2)-1
  FOK=0 : GERR=1
  GMESSAGE=mess(122,199,1)
  Return
Endif

# Création no série en cours de traitement
Call CRE_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
If LRET<>0 : FOK=0 : Return : Endif

# Ouverture de la ligne
nolign = [M:STS1]NBLIG2
Insa nolign,1,[M:STS1]NBLIG2 [M:STS1]NBLIG2
[M:STS1]NBLIG2 += 1
nolign = [M:STS1]NBLIG2
NOL = nolign-1
status = 0

[M:STS1]SERNUM2(NOL) = [F:STS]SERNUM
[M:STS1]STOCOU2(NOL) = [F:STS]STOCOU
[M:STS1]STA2(NOL)    = [F:STO]STA
If dim([M:STS1]LOT2)>0 [M:STS1]LOT2(NOL) = [F:STO]LOT Endif
If dim([M:STS1]SLO2)>0 [M:STS1]SLO2(NOL) = [F:STO]SLO Endif
If dim([M:STS1]LOC2)>0 [M:STS1]LOC2(NOL) = [F:STO]LOC Endif
If dim([M:STS1]ECCVALMAJ21)>0 [M:STS1]ECCVALMAJ2(NOL) = [F:STO]ECCVALMAJ Endif
If dim([M:STS1]PALNUM2)>0    [M:STS1]PALNUM2(NOL)    = [F:STO]PALNUM    Endif
If dim([M:STS1]CTRNUM2)>0    [M:STS1]CTRNUM2(NOL)    = [F:STO]CTRNUM    Endif
If dim([M:STS1]STOFLD21)>0   [M:STS1]STOFLD21(NOL)   = [F:STO]STOFLD1   Endif
If dim([M:STS1]STOFLD22)>0   [M:STS1]STOFLD22(NOL)   = [F:STO]STOFLD2   Endif
#[M:STS1]PICK2(NOL)   = 1

#[M:SS1]SERNEW(LNOL)+= 1
[M:STS0]STOSERNEW  += 1
Affzo [M:STS0]STOSERNEW

Return

$ANU_PIC
Raz I,J
Case currbox
 When GBOXSTS1 : Gosub ANU_PICSTS1
 When GBOXSTS2 : Gosub ANU_PICSTS2
Endcase
Return

$ANU_PICSTS1
OK = 0
If [M:STS1]NBLIG1 <> 0
  While OK <> 1
    I = find([F:STS]SERNUM,[M:STS1]SERNUM1(J..[M:STS1]NBLIG1-1))
    If I<>0
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
      If LRET<>0 : FOK=0 : Break : Endif
      NOL = J+I-1
      J   = NOL
      #[M:SS1]SERNEW(LNOL) += 1
      [M:STS0]STOSERNEW   += 1
      Dela NOL,1,[M:STS1]NBLIG1-1 [M:STS1]NBLIG1
      [M:STS1]NBLIG1 -= 1
      If J>[M:STS1]NBLIG1-1 : OK=1 : Endif
    Else
      OK=1
    Endif
  Wend
Endif
Affzo [M:STS0]STOSERNEW
Return

$ANU_PICSTS2
OK = 0
If [M:STS1]NBLIG2 <> 0
  While OK <> 1
    I = find([F:STS]SERNUM,[M:STS1]SERNUM2(J..[M:STS1]NBLIG2-1))
    If I<>0
      # Suppression no série en cours de traitement
      Call DEL_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
      If LRET<>0 : FOK=0 : Break : Endif
      NOL = J+I-1
      J   = NOL
      #[M:SS1]SERNEW(LNOL) -= 1
      [M:STS0]STOSERNEW   -= 1
      Dela NOL,1,[M:STS1]NBLIG2-1 [M:STS1]NBLIG2
      [M:STS1]NBLIG2 -= 1
      If J>[M:STS1]NBLIG2-1 : OK=1 : Endif
    Else
      OK=1
    Endif
  Wend
Endif
Affzo [M:STS0]STOSERNEW
Return


$FIN_PIC
Affzo [M:STS1]1-99
Case currbox
 When GBOXSTS1 : If [M:STS1]NBLIG1<>0
                   zonsui = "[M:STS1]NBLIG1("+num$(NOL)+")"
                 Endif
 When GBOXSTS2 : If [M:STS1]NBLIG2<>0
                   zonsui = "[M:STS1]NBLIG2("+num$(NOL)+")"
                 Endif
Endcase

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$TIROIR
#-----------------------------------------------------------------------#
# Remplissage de la liste de picking                                    #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes déjà saisies    #
#-----------------------------------------------------------------------#
If currbox=GBOXSTS1
  If [M:STS1]NBLIG1<>0
    For I=0 To [M:STS1]NBLIG1-1
      If [M:STS1]SERNUM1(I)<>""
        Read [STS]STS0=[M:STS0]ITMREF;[M:STS1]SERNUM1(I)
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Endif
    Next I
  Endif
Elsif currbox=GBOXSTS2
  If [M:STS1]NBLIG2<>0
    For I=0 To [M:STS1]NBLIG2-1
      If [M:STS1]SERNUM2(I)<>""
        Read [STS]STS0=[M:STS0]ITMREF;[M:STS1]SERNUM2(I)
        Read [STO]STO0=[M:STS0]STOFCY;[F:STS]STOCOU
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Endif
    Next I
  Endif
Endif

Return

###############################################################################
## Ecran SYNSTS1
###############################################################################

Subprog C_STOCOU1(VALEUR)
Variable Decimal VALEUR

Local    Integer OK, NOL
NOL=nolign-1

If VALEUR=[M:STS0]STOCOU
  GMESSAGE=[F:STS]SERNUM-mess(497,184,1)
  mkstat=2 : End
Endif

If VALEUR<>0
  Read [STO]STO0=[M:STS0]STOFCY;VALEUR
  If fstat
    Call ERREUR(mess(46,141,1)) From GESECRAN
    mkstat=2 : End
  Elsif [F:STO]ITMREF<>[M:STS0]ITMREF
    Call ERREUR(mess(50,196,1)-":"-mess(7,135,1)) From GESECRAN
    mkstat=2 : End
  Else
    Filter [STS] Where ITMREF=[M:STS0]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
    If rowcount([F:STS])=[F:STO]QTYSTUACT
      OK=1 : Call AVERTIR(num$(VALEUR)+"\"+mess(496,184,1), OK) From GESECRAN
      If OK=1 : mkstat=2 : Endif
    Elsif rowcount([F:STS])>[F:STO]QTYSTUACT
      OK=1 : Call AVERTIR(num$(VALEUR)+"\"+mess(500,184,1), OK) From GESECRAN
      If OK=1 : mkstat=2 : Endif
      Endif
    Filter [STS]
    If mkstat=2 : End : Endif
  Endif
  If [F:ITM]LOTMGTCOD>1
    [M:STS1]LOT1(NOL) = [F:STO]LOT
    If [F:ITM]LOTMGTCOD=4
      [M:STS1]SLO1(NOL) = [F:STO]SLO
    Endif
    If dim([M:STS1]ECCVALMAJ1)>0
      [M:STS1]ECCVALMAJ1(NOL) = [F:STO]ECCVALMAJ
    Endif
  Endif
  [M:STS1]STA1(NOL) = [F:STO]STA
  If [F:ITF]LOCMGTCOD=2
    [M:STS1]LOC1(NOL) = [F:STO]LOC
  Endif
  If dim([M:STS1]PALNUM1)>0
    [M:STS1]PALNUM1(NOL) = [F:STO]PALNUM
  Endif
  If dim([M:STS1]CTRNUM1)>0
    [M:STS1]CTRNUM1(NOL) = [F:STO]CTRNUM
  Endif
  If dim([M:STS1]STOFLD11)>0
    [M:STS1]STOFLD11(NOL) = [F:STO]STOFLD1
  Endif
  If dim([M:STS1]STOFLD21)>0
    [M:STS1]STOFLD21(NOL) = [F:STO]STOFLD2
  Endif
Else
  OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(498,184,1), OK) From GESECRAN
  If OK=1
    mkstat=2 : End
  Endif
  Raz [M:STS1]STA1(NOL)
  If dim([M:STS1]LOC1)>0 : Raz [M:STS1]LOC1(NOL) : Endif
  If dim([M:STS1]LOT1)>0 : Raz [M:STS1]LOT1(NOL) : Endif
  If dim([M:STS1]SLO1)>0 : Raz [M:STS1]SLO1(NOL) : Endif
  If dim([M:STS1]PALNUM1)>0  : Raz [M:STS1]PALNUM1(NOL)  : Endif
  If dim([M:STS1]CTRNUM1)>0  : Raz [M:STS1]CTRNUM1(NOL)  : Endif
  If dim([M:STS1]STOFLD11)>0 : Raz [M:STS1]STOFLD11(NOL) : Endif
  If dim([M:STS1]STOFLD21)>0 : Raz [M:STS1]STOFLD21(NOL) : Endif
  If dim([M:STS1]ECCVALMAJ1)>0 : Raz [M:STS1]ECCVALMAJ1(NOL) : Endif
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SYNSTS1) 10/03/2017 15:18:39 (TS)
######################################################################################
Subprog AS_SERNUM2(VALEUR)
Variable Char    VALEUR()
# Si ligne pickée pas d'accés au no série
#If [M:STS1]PICK2(nolign-1)=1 mkstat=2 Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SYNSTS1) 16/03/2017 13:51:54 (TS)
######################################################################################
Subprog C_SERNUM2(VALEUR)
Variable Char    VALEUR()
# Lecture no série saisie
#If [M:STS1]PICK2(nolign-1)<>1
#  Read [STS]STS0=[M:STS0]ITMREF;VALEUR
#  If !fstat
#    Call ERREUR(mess(3,187,1)) From GESECRAN
#    mkstat=2 : End
#  Endif
#Endif

Local    Integer OK, LRET, NOL
NOL=nolign-1

If VALEUR=""
  mkstat=2 : End
Endif

# Il y a déjà trop de no séries pour ce chrono stock
If [M:STS0]STOSERNEW>=[M:STS0]STOQTYNEW
  OK=1 : Call AVERTIR(num$([M:STS0]STOCOU)+"\"+mess(500,184,1), OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
Endif

# No série déjà saisie
If [M:STS1]NBLIG2>0 & find(VALEUR,[M:STS1]SERNUM2(0..[M:STS1]NBLIG2-1))
   GERR=1 : GMESSAGE=mess(194,184,1)
   mkstat=2 : End
Endif

Read [STS]STS0=[M:STS0]ITMREF;VALEUR
If fstat=5
  # No série inexistant, confirmez-vous la saisie ?
  OK=1 : Call AVERTIR(mess(43,196,1)+","-mess(326,196,1), OK) From GESECRAN
  If OK=1 : Raz VALEUR : mkstat=2 : Endif
  End
Elsif fstat
  Call RSTA ("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK
  mkstat=2 : End
Elsif [F:STS]SDHNUM<>""
  GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(495,184,1)
  mkstat=2  : End
Endif
Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
If fstat
  # Ne pas mettre de message d'erreur, car il faut pouvoir prendre le no série
  Raz [F:STO]
Endif
#--- No série en cours de traitement?
If func STKLIB.REC_STOSERW_UID([F:STS]ITMREF,[F:STS]SERNUM,adxuid(1))<>0
  GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(449,184,1)
  mkstat=2  : End
Endif

Filter [STS1] Where ITMREF=[M:STS0]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
If rowcount([F:STS1])=[F:STO]QTYSTUACT
  OK=1 : Call AVERTIR(num$([F:STO]STOCOU)+"\"+mess(496,184,1), OK) From GESECRAN
  If OK=1 : mkstat=2 : Endif
Elsif rowcount([F:STS1])<[F:STO]QTYSTUACT
  OK=1 : Call AVERTIR(num$([F:STO]STOCOU)+"\"+mess(501,184,1), OK) From GESECRAN
  If OK=1 : mkstat=2 : Endif
  Endif
Filter [STS1]
If mkstat=2 : End : Endif

# Création no série en cours de traitement
Call CRE_STOSERW([M:STS0]ITMREF,[F:STS]SERNUM,1,LRET) From STKLIB
If LRET<>0 : mkstat=2 : End : Endif

[M:STS1]SERNUM2(NOL) = [F:STS]SERNUM
[M:STS1]STOCOU2(NOL) = [F:STS]STOCOU
[M:STS1]STA2(NOL)    = [F:STO]STA
If dim([M:STS1]LOT2)>0 [M:STS1]LOT2(NOL) = [F:STO]LOT Endif
If dim([M:STS1]SLO2)>0 [M:STS1]SLO2(NOL) = [F:STO]SLO Endif
If dim([M:STS1]LOC2)>0 [M:STS1]LOC2(NOL) = [F:STO]LOC Endif
If dim([M:STS1]ECCVALMAJ21)>0 [M:STS1]ECCVALMAJ2(NOL) = [F:STO]ECCVALMAJ Endif
If dim([M:STS1]PALNUM2)>0    [M:STS1]PALNUM2(NOL)    = [F:STO]PALNUM    Endif
If dim([M:STS1]CTRNUM2)>0    [M:STS1]CTRNUM2(NOL)    = [F:STO]CTRNUM    Endif
If dim([M:STS1]STOFLD21)>0   [M:STS1]STOFLD21(NOL)   = [F:STO]STOFLD1   Endif
If dim([M:STS1]STOFLD22)>0   [M:STS1]STOFLD22(NOL)   = [F:STO]STOFLD2   Endif
#[M:STS1]PICK2(NOL)   = 1

[M:STS0]STOSERNEW  += 1
Affzo [M:STS0]STOSERNEW

End

