#<AdxTL>@(#)135.0.0.0 $Revision$
Local Char    VALEUR(250), PARAM(250)(1..20)
PARAM(1) = ""
PARAM(2) = ""
PARAM(3) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"CRITSEL","GSTD2","CRITSEL") From GSAISIE
End

#---------------------------#
$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

#---------------------------#
$DEBUT
[M]CRITERE = PARAM(1)
[M]DOSSIER = PARAM(2)
[M]TABLE = PARAM(3)
If PARAM(3)<>""
 If PARAM(2)=nomap | PARAM(2)=""
  Local File =PARAM(3) [AAA_]
 Else
  Local File =PARAM(2)+"."+PARAM(3) [AAA_]
 Endif
Endif
Return

#---------------------------#
$OK
PARAM(1) = [M]CRITERE
FIN = 1
Return

#---------------------------#
Subprog C_CRITERE(VALEUR)
Variable Char VALEUR
Local Integer I , J , K , L , ER
# On vire les blancs
VALEUR = vireblc(VALEUR,2)
# On essaye de détecter les dates à l'ancien format (par gentillesse)
I = 1
$SELDAT
J = instr(I,VALEUR,"[")
If J
 K = instr(J+1,VALEUR,"]")
 If K
  L = instr(J+1,VALEUR,"/")
  If L & L<K
   J = instr(L+1,VALEUR,"/")
   If J = K-3
    VALEUR = left$(VALEUR,J)+"19"+right$(VALEUR,J+1)
    I = K+1 : Goto SELDAT
   Endif
  Endif
 Endif
Endif
I = parse(VALEUR)
If VALEUR<>""
 If I
  ER = abs(I)
  Gosub ERRCRIT :  mkstat = 2
 Elsif clalev([F:AAA_])>0
  ER = 0
  Onerrgo ER
  Filter [AAA_] Where evalue(VALEUR)
  Read [AAA_] Last
  Filter [AAA_]
  If ER
   Gosub ERRCRIT : mkstat = 2
  Endif 
 Endif
Endif
End

$ER
ER = errn
Resume

$ERRCRIT
Call ERREUR(mess(33,100,1)+"\"+errmes$(ER)+"\|"+errm+"|") From GESECRAN : # Erreur sur critère de sélection
Return
