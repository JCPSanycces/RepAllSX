#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMP_APRES_MOD" : Gosub IMP_APRES
 When "IMP_APRES_CRE" : Gosub IMP_APRES
Endcase
Return


$IMP_OUVRE
If clalev([F:JCO3]) = 0 : Local File GJOUCOA  [JCO3] : Endif

Local Integer NB,NEW
Return


$IMPORT

Case IMPFIC
 When "JCO"

  If [F:JCO]ACC<>""    # Compte de trésorerie.

   Raz nolign
   I = find([F:JCO]COA,[M]COA(0..[M]NBRACC-1))
   If I
    nolign = I
   Elsif [M]NBRACC<dim([M]COA)
    [M]NBRACC += 1
    nolign = [M]NBRACC
   Endif
   If nolign>0
    [M]COA(nolign-1) = [F:JCO]COA
    [M]ACC(nolign-1) = [F:JCO]ACC
   Endif
  Endif

Endcase
Return

$AP_IMPORT

Case IMPFIC
 When "JCO"

  If dim([M]JOU)<1 : Return : Endif

  If dim([M]LEG)<1
   GCURLEG = GDOSLEG(1)
  Else
   GCURLEG = [M]LEG
  Endif

  # Enreigstrement des comptes fréquents/interdits
  Trbegin [F:JCO3]
  Read [JCO3]JCO0=[F:JCO]COA;[M]JOU;GCURLEG
  If !fstat
   NEW = 1
  Else
   Raz [F:JCO3]
   NEW = 0
  Endif

  For NB = 1 To [F:JCO]FBDNBR
   I = find([F:JCO]FBDACC(NB-1),[F:JCO3]FBDACC(0..[F:JCO3]FBDNBR))
   If !I
    [F:JCO3]FBDACC([F:JCO3]FBDNBR)=[F:JCO]FBDACC(NB-1)
    [F:JCO3]FBDNBR+=1
   Else
    [F:JCO3]FBDACC(I-1)=[F:JCO]FBDACC(NB-1)
   Endif
  Next

  For NB = 1 To [F:JCO]FRQNBR
   I = find([F:JCO]FRQACC(NB-1),[F:JCO3]FRQACC(0..[F:JCO3]FRQNBR))
   If !I
    [F:JCO3]FRQACC([F:JCO3]FRQNBR)=[F:JCO]FRQACC(NB-1)
    [F:JCO3]FRQCOD([F:JCO3]FRQNBR)=[F:JCO]FRQCOD(NB-1)
    [F:JCO3]FRQNBR+=1
   Else
    [F:JCO3]FRQACC(I-1)=[F:JCO]FRQACC(NB-1)
    [F:JCO3]FRQCOD(I-1)=[F:JCO]FRQCOD(NB-1)
   Endif
  Next

  [F:JCO3]UPDUSR = GUSER
  [F:JCO3]UPDDAT = date$


  If NEW
   Rewrite [JCO3]
   If fstat
    OK = 0 : Call ERREUR("GJOUCOA"-[F:JCO3]COA-[F:JCO3]JOU-[F:JCO3]LEG,2) From DOSDIC
   Endif

  Else
   [F:JCO3]JOU = [M]JOU
   [F:JCO3]LEG = GCURLEG
   [F:JCO3]COA = [F:JCO]COA
   [F:JCO3]ACC = [F:JCO]ACC
   [F:JCO3]CREUSR = GUSER
   [F:JCO3]CREDAT = date$
   Write [JCO3]
   If fstat
    OK = 0 : Call ERREUR("GJOUCOA"-[F:JCO3]COA-[F:JCO3]JOU-[F:JCO3]LEG,2) From DOSDIC
   Endif
  Endif

  If !OK
   Rollback
  Else
   Commit
  Endif
Endcase
Return

$IMP_APRES
If clalev([F:COA]) = 0 : Local File GCOA     [COA] : Endif

If dim([M]LEG)<1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG = [M]LEG
Endif

For [F:COA]COA0
 Read [JCO]JCO0=[F:COA]COA;[M]JOU;GCURLEG
 If fstat
  Raz [JCO]
  [F:JCO]JOU    = [M]JOU
  [F:JCO]LEG    = GCURLEG
  [F:JCO]COA    = [F:COA]COA
  [F:JCO]CREUSR = GUSER
  [F:JCO]CREDAT = date$
  Write [JCO]
  If fstat
    OK = 0 : Call ERREUR("GJOUCOA"-[F:JCO3]COA-[F:JCO3]JOU-[F:JCO3]LEG,2) From DOSDIC
  Endif
 Endif
Next

For [JCO] Where JOU=[M]JOU & LEG=GCURLEG
 Read [F:COA]COA0 = [F:JCO]COA
 If fstat
  Delete [JCO] Curr
  If fstat
   OK = 0 : Call ERREUR("GJOUCOA"-[F:JCO]COA,3) From DOSDIC
  Else
   Call ECR_TRACE([F:JCO]COA-[F:JCO]JOU-[F:JCO]LEG,-1) From GESECRAN
  Endif
 Endif
Next
Return

