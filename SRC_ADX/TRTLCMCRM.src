  Filter [SREF] Order By [F:SRE6]CREDAT Desc
  For [SREF]
    DTDATE = [F:SRE6]CREDAT
    SZKEY = [F:SRE6]SRENUM
    SZCUR = [F:SRE6]SRECUR
    Break
  Next
  Filter [SREF]
  Close Local File [SREF]
  #
  IIMVTTYP = 7
  If DTDATE <> [00/00/00] Then
    Call LCM_MAJINFO (SZBPRNUM, 11, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZFCY, SZCUR, MTAMT, IERRINF, ICHAPTER, IBRETOUR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 11, SZCPY, SZFCY, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
