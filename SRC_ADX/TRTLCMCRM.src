#<AdxTL>@(#)1.0.0.0 $Revision$
# Gestion de la table LASTCUSMVT pour les informations de la CRM    module CRM juillet 2007
##########################################################################################################
Subprog LCM_MAJINFO (SZBPCNUM, IIFTYP, SZCPY, IMVTTYP, DTMVTDAT, SZVCRNUM, SZFCY, SZCUR, MTAMT, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPCNUM
Value Integer IIFTYP
Value Char SZCPY
Value Integer IMVTTYP
Value Date DTMVTDAT
Value Char SZVCRNUM
Value Char SZFCY
Value Char SZCUR
Value Decimal MTAMT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ITRAIT
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  ITRAIT = 0
  If SZBPCNUM = "" Then
    End
  Endif
  If SZCPY = "" Then
    End
  Endif
  #
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If !clalev([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
  # FGR 11/08/2009 : X3SUIVI57005 Ajout du site (SZFCY) dans la clé primaire
  #Read [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY;SZFCY
  Read [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY        # FLORENT ICI : SZFCY retiré de la clé pour le moment
  If fstat = 0 Then
    # L'enregistrement existe : On ne contrôle rien. C'est le travaille de l'appelant. Ici on enregistre ce qu'on nous dit
    If [F:LCM]MVTTYP = IMVTTYP and [F:LCM]MVTDAT = DTMVTDAT and [F:LCM]VCRNUM = SZVCRNUM and [F:LCM]CUR = SZCUR and [F:LCM]AMT = MTAMT Then
      # ... Sauf que là tout est pareil, on gagne du temps, on fait rien
      ITRAIT = 0
    Else
      ITRAIT = 1  # Il faut remplacer
    Endif
  Else
    ITRAIT = 2    # Il faut créer
  Endif
  If ITRAIT = 0 Then
    End
  Endif
  #
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  If ITRAIT = 1 Then
    # FGR 11/08/2009 : X3SUIVI57005 Ajout du site (SZFCY) dans la clé primaire
    #Readlock [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY;SZFCY
    Readlock [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY        # FLORENT ICI : SZFCY retiré de la clé pour le moment
    If fstat <> 0 Then
      #Erreur : Impossible de locker les derniers mouvements clients.
      IERRINF = 439
      ICHAPTER = 177
      IBRETOUR = 0
      GOK = 0
      End
    Endif
    [F:LCM]UPDDAT = date$
    [F:LCM]UPDUSR = GUSER
  Elsif ITRAIT = 2 Then
    Raz [F:LCM]
    [F:LCM]BPCNUM = SZBPCNUM
    [F:LCM]IFFTYP = IIFTYP
    [F:LCM]CPY = SZCPY
    [F:LCM]IFFFCY = SZFCY    # FGR 11/08/2009 : X3SUIVI57005 : Maintenant il est dans la clé
    [F:LCM]CREDAT = date$
    [F:LCM]CREUSR = GUSER
  Endif
  [F:LCM]IFFFCY = SZFCY      # FLORENT ICI : SZFCY retiré de la clé pour le moment
  [F:LCM]MVTTYP = IMVTTYP
  [F:LCM]MVTDAT = DTMVTDAT
  [F:LCM]VCRNUM = SZVCRNUM
  [F:LCM]CUR = SZCUR
  [F:LCM]AMT = MTAMT
  If ITRAIT = 2 Then
    Write [LCM]
    If fstat <> 0 Then
      #Erreur lors de l'écriture des derniers mouvements clients.
      IERRINF = 440
      ICHAPTER = 177
      IBRETOUR = 0
      GOK = 0
      Call FSTA("LCM") From GLOCK
    Endif
  Elsif ITRAIT = 1 Then
    Rewrite [LCM]
    If fstat <> 0 Then
      #Erreur lors de la modification des derniers mouvements clients.
      IERRINF = 441
      ICHAPTER = 177
      IBRETOUR = 0
      GOK = 0
      Call FSTA("LCM") From GLOCK
      Unlock [LCM]
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

###############################################################################################
#On a une donnée qui a été supprimé, on supprime de LCM
Subprog LCM_DELINFO (SZBPCNUM, IIFTYP, SZCPY, SZFCY, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPCNUM
Value Integer IIFTYP
Value Char SZCPY
Value Char SZFCY  # FGR 11/08/2009 : X3SUIVI57005 ajout du site
Variable Integer IBSUPR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IBSUPR = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  If SZBPCNUM = "" Then
    End
  Endif
  If SZCPY = "" Then
    End
  Endif
  #
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If !clalev([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  #
  #Delete [LCM] Where [F:LCM]BPCNUM = SZBPCNUM and [F:LCM]IFFTYP = IIFTYP and [F:LCM]CPY = SZCPY and [F:LCM]IFFFCY = SZFCY
  Delete [LCM] Where [F:LCM]BPCNUM = SZBPCNUM and [F:LCM]IFFTYP = IIFTYP and [F:LCM]CPY = SZCPY   # FLORENT ICI : SZFCY retiré de la clé pour le moment
  If fstat = 0 Then
    #la suppression a eu lieu
    If adxdlrec > 0 Then
      IBSUPR = 1
    Else
      IBSUPR = 0
    Endif
  Else
    #Erreur lors de la suppression de données sur les derniers mouvements clients.
    IERRINF = 443
    ICHAPTER = 177
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

###############################################################################################
#On a une donnée qui a été supprimé, on supprime de LCM
Subprog LCM_DELKEY(IMVTTYP, SZVCRNUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
Value Integer IMVTTYP
Value Char SZVCRNUM
Variable Integer IBSUPR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  # Note : Pas la peine de passer le site.
  # ====   On détruit un mouvement par l'identifiant de la pièce.
  #        Pas le tiers.
  #        Il pourrait donc y avoir deux lignes supprimées : une au niveau site, une au niveau société.
  IBSUPR = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  If !clalev([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  Delete [LCM] Where [F:LCM]MVTTYP = IMVTTYP  and [F:LCM]VCRNUM = SZVCRNUM
  If fstat = 0 Then
    #la suppression a eu lieu
    If adxdlrec > 0 Then
      IBSUPR = 1
    Else
      IBSUPR = 0
    Endif
  Else
    #Erreur lors de la suppression de données sur les derniers mouvements clients.
    IERRINF = 443
    ICHAPTER = 177
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
#traitement de information premier contact pour un client et une société donnée
Subprog LCM_BPRFIRSTCNT (SZBPRNUM, SZCPY, SZFCY, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY  # FGR 11/08/2009 : X3SUIVI57005 ajout du site
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBSUPR
Local Integer IIMVTTYP
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)  # FGR 11/08/2009 : X3SUIVI57005 ajout du site

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  IBSUPR = 0
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  If SZBPRNUM = "" Then
    End
  Endif
  If SZCPY = "" Then
    End
  Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TSK6]) : Local File TASK [TSK6] : Endif
  If !clalev([F:CLL6]) : Local File PHONECALL [CLL6] : Endif
  If !clalev([F:BAP6]) : Local File BAPPOINT [BAP6] : Endif
  #
  If SZFCY <> "" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    SZWHERE = "[F:TSK6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [TSK6] With [FCY]FCY0=[F:TSK6]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK6]TSKDON=2 and [F:TSK6]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK6]TSKSTR
  For [TSKF]
    DTTSK = [F:TSK6]TSKSTR
    SZKEYTSK = [F:TSK6]TSKNUM
    DTDATE = DTTSK
    Break
  Next
  Filter [TSKF]
  Close Local File [TSKF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:CLL6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [CLL6] With [FCY]FCY0=[F:CLL6]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL6]CLLDON=2 and [F:CLL6]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL6]CLLDATX Asc; [F:CLL6]CLLHOU Asc
  For [CLLF]
    DTCLL = [F:CLL6]CLLDATX
    SZKEYCLL = [F:CLL6]CLLNUM
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTCLL < DTDATE) Then
      DTDATE = DTCLL
    Endif
    Break
  Next
  Filter [CLLF]
  Close Local File [CLLF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:BAP6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [BAP6] With [FCY]FCY0=[F:BAP6]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP6]APTDON=2 and [F:BAP6]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP6]APTDATX Asc; [F:BAP6]APTHOU Asc
  For [BAPF]
    DTBAP = [F:BAP6]APTDATX
    SZKEYBAP = [F:BAP6]APTNUM
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTBAP < DTDATE) Then
      DTDATE = DTBAP
    Endif
    Break
  Next
  Filter [BAPF]
  Close Local File [BAPF]
  #
  # Note le min(DTTSK,DTCLL,DTBAP) ne fonctionne pas. Si une des date vaut [0/0/0] alors le min aussi et on va dans le Else !
  If DTDATE <> [00/00/00] Then
    If DTDATE = DTCLL Then
      SZKEY = SZKEYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO (SZBPRNUM, 1, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZFCY, "", 0, IERRINF, ICHAPTER, IBRETOUR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 1, SZCPY, SZFCY, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (début)
  If IBRETOUR = 1 and SZFCY <> "" and GNAVIG <> "FUNCRMLCM" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    # On ne le fait pas en synchro (FUNCRMLCM) pour ne le faire qu'une fois par société.
    Call LCM_BPRFIRSTCNT (SZBPRNUM, SZCPY, "", IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (fin)
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
End

##########################################################################################################
#traitement de information dernier contact pour un client et une société donnée
Subprog LCM_BPRLASTCNT (SZBPRNUM, SZCPY, SZFCY, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY  # FGR 11/08/2009 : X3SUIVI57005 ajout du site
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBSUPR
Local Integer IIMVTTYP
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)  # FGR 11/08/2009 : X3SUIVI57005 ajout du site

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  IBSUPR = 0
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  If SZBPRNUM = "" Then
    End
  Endif
  If SZCPY = "" Then
    End
  Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TSK6]) : Local File TASK [TSK6] : Endif
  If !clalev([F:CLL6]) : Local File PHONECALL [CLL6] : Endif
  If !clalev([F:BAP6]) : Local File BAPPOINT [BAP6] : Endif
  #
  If SZFCY <> "" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    SZWHERE = "[F:TSK6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [TSK6] With [FCY]FCY0=[F:TSK6]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK6]TSKDON=2 and [F:TSK6]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK6]TSKDAT Desc
  For [TSKF]
    DTTSK = [F:TSK6]TSKDAT
    SZKEYTSK = [F:TSK6]TSKNUM
    Break
  Next
  Filter [TSKF]
  Close Local File [TSKF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:CLL6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [CLL6] With [FCY]FCY0=[F:CLL6]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL6]CLLDON=2 and [F:CLL6]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL6]CLLDATX Desc;[F:CLL6]CLLHOU Desc
  For [CLLF]
    DTCLL = [F:CLL6]CLLDATX
    SZKEYCLL = [F:CLL6]CLLNUM
    Break
  Next
  Filter [CLLF]
  Close Local File [CLLF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:BAP6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [BAP6] With [FCY]FCY0=[F:BAP6]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP6]APTDON=2 and [F:BAP6]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP6]APTDATX Desc; [F:BAP6]APTHOU Desc
  For [BAPF]
    DTBAP = [F:BAP6]APTDATX
    SZKEYBAP = [F:BAP6]APTNUM
    Break
  Next
  Filter [BAPF]
  Close Local File [BAPF]
  #
  DTDATE = max(DTTSK,DTCLL,DTBAP)
  If DTDATE <> [00/00/00] Then
    If DTDATE=DTCLL Then
      SZKEY = SZKEYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO (SZBPRNUM, 2, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZFCY, "", 0, IERRINF, ICHAPTER, IBRETOUR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 2, SZCPY, SZFCY, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (début)
  If IBRETOUR = 1 and SZFCY <> "" and GNAVIG <> "FUNCRMLCM" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    # On ne le fait pas en synchro (FUNCRMLCM) pour ne le faire qu'une fois par société.
    Call LCM_BPRLASTCNT (SZBPRNUM, SZCPY, "", IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (fin)
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
End

##########################################################################################################
#traitement de information prochain contact pour un client et une société donnée
Subprog LCM_BPRNEXTCNT (SZBPRNUM, SZCPY, SZFCY, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY  # FGR 11/08/2009 : X3SUIVI57005 ajout du site
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBSUPR
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)  # FGR 11/08/2009 : X3SUIVI57005 ajout du site

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  IBSUPR = 0
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  If SZBPRNUM = "" Then
    End
  Endif
  If SZCPY = "" Then
    End
  Endif
  If !clalev([F:FCY]) : Local File  FACILITY [FCY] : Endif
  If !clalev([F:TSK6]) : Local File TASK [TSK6] : Endif
  If !clalev([F:CLL6]) : Local File PHONECALL [CLL6] : Endif
  If !clalev([F:BAP6]) : Local File BAPPOINT [BAP6] : Endif
  #
  If SZFCY <> "" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    SZWHERE = "[F:TSK6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [TSK6] With [FCY]FCY0=[F:TSK6]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK6]TSKDON=1 and [F:TSK6]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK6]TSKSTR Asc
  For [TSKF]
    DTTSK = [F:TSK6]TSKSTR
    SZKEYTSK = [F:TSK6]TSKNUM
    DTDATE = DTTSK
    Break
  Next
  Filter [TSKF]
  Close Local File [TSKF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:CLL6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [CLL6] With [FCY]FCY0=[F:CLL6]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL6]CLLDON=1 and [F:CLL6]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL6]CLLDATX Asc;[F:CLL6]CLLHOU Asc
  For [CLLF]
    DTCLL = [F:CLL6]CLLDATX
    SZKEYCLL = [F:CLL6]CLLNUM
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTCLL < DTDATE) Then
      DTDATE = DTCLL
    Endif
    Break
  Next
  Filter [CLLF]
  Close Local File [CLLF]
  #
  If SZFCY <> "" Then
    SZWHERE = "[F:BAP6]SALFCY=SZFCY"
  Else
    SZWHERE = "1=1"
  Endif
  Link [BAP6] With [FCY]FCY0=[F:BAP6]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP6]APTDON=1 and [F:BAP6]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP6]APTDATX Asc; [F:BAP6]APTHOU Asc
  For [BAPF]
    DTBAP = [F:BAP6]APTDATX
    SZKEYBAP = [F:BAP6]APTNUM
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTBAP < DTDATE) Then
      DTDATE = DTBAP
    Endif
    Break
  Next
  Filter [BAPF]
  Close Local File [BAPF]
  #
  # Note le min(DTTSK,DTCLL,DTBAP) ne fonctionne pas. Si une des date vaut [0/0/0] alors le min aussi et on va dans le Else !
  If DTDATE <> [00/00/00] Then
    If DTDATE = DTCLL Then
      SZKEY = SZKEYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO (SZBPRNUM, 3, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZFCY, "", 0, IERRINF, ICHAPTER, IBRETOUR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 3, SZCPY, SZFCY, IBSUPR, IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (début)
  If IBRETOUR = 1 and SZFCY <> "" and GNAVIG <> "FUNCRMLCM" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
    # On ne le fait pas en synchro (FUNCRMLCM) pour ne le faire qu'une fois par société.
    Call LCM_BPRNEXTCNT (SZBPRNUM, SZCPY, "", IERRINF, ICHAPTER, IBRETOUR)
  Endif
  # FGR 11/08/2009 : X3SUIVI57005 : On refait ça au niveau société (fin)
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
End

