#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP6 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRSAL
mkstat = 0
zoncou = "NBRSAL"
indice = 0
status = 1
zoncou = "NBRSAL"
If varmode([M]NBRSAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRSAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRSAL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRSAL = nolign
   status = 75
   Call SAI_NBRSAL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRSAL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRSAL
mkstat = 0
zoncou = "NBRSAL"

## Zone NBRSAL
mkstat = 0
zoncou = "NBRSAL"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP6"
Return

