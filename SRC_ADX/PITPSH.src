#<AdxTL>@(#)6.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : demande d'achat/avancement
#                             cf AML 2240 : 30
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables PSHWPIV devient WK, STAPSHWPIV devient STAWK
######################################################################
$OUVTAB_PSH
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:PSH]) Local File PREQUIS   [PSH] Endif
If !clalev([F:PSD]) Local File PREQUISD  [PSD] Endif
If !clalev([F:PSO]) Local File PREQUISO  [PSO] Endif
If !clalev([F:PTD]) Local File PRECEIPTD [PTD] Endif
Return

######################################################################
Subprog TRT_PSH(ID,CLETRT,PITPSH,P_CRITERE,PITSTAPSH,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITPSH () 
Value Char P_CRITERE() 
Value Char PITSTAPSH () 
Variable Integer OK


If PITPSH="" & PITSTAPSH="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_PSH
Gosub OUVREPIVOT From CONNECTFCT


If PITPSH<>""
    Local Integer WNBPSH : Raz WNBPSH 
    Local Integer WPREPSH : Raz WPREPSH
    Local Char    OPTPSH(GDIMFIC)
    OPTPSH = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitpsh")
    Local Integer WKNBZON : Raz WKNBZON
    Local Char WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP : Raz WKHEATYP 
    Local Char WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITPSH,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITPSH,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITPSH,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREPSH,OPTPSH) From CONNECTFCT
Endif
If PITSTAPSH<>""
    Local Integer WNBSTAPSH : Raz WNBSTAPSH
    Local Integer WPRESTAPSH : Raz WPRESTAPSH
    Local Char    OPTSTAPSH(GDIMFIC)
    OPTSTAPSH = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitstapsh")
    Local Integer STAWKNBZON : Raz STAWKNBZON
    Local Char STAWKNORECMES (50): Raz STAWKNORECMES 
    Local Integer STAWKHEATYP : Raz STAWKHEATYP 
    Local Char STAWKHEADMES (250): Raz STAWKHEADMES 
    
    Call READPIT(PITSTAPSH,STAWKNBZON,STAWKNORECMES,STAWKHEATYP ,STAWKHEADMES ) From CONNECTFCT
    Local Char STAWKTABZON(GLONATB+GLONAVA+2)(1..STAWKNBZON) : Raz STAWKTABZON
    Local Char STAWKTABABR(GLONABR)(1..STAWKNBZON) : Raz STAWKTABABR
    Local Char STAWKZON(GLONAVA)(1..STAWKNBZON) : Raz STAWKTABZON
    Local Char STAWKFRM(150)(1..STAWKNBZON) : Raz STAWKFRM
    Local Integer STAWKWRK(1..STAWKNBZON) : Raz STAWKWRK
    Local Char STAWKVAL(255)(1..STAWKNBZON) : Raz STAWKVAL
    Local Char STAWKVALFIC(GLONAVA)(1..STAWKNBZON) : Raz STAWKVALFIC
    Call LOADPIVZON(PITSTAPSH,STAWKNBZON,STAWKTABZON,STAWKTABABR,STAWKZON,STAWKFRM,STAWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITSTAPSH,STAWKNBZON,STAWKTABZON,STAWKTABABR,STAWKZON,STAWKWRK,STAWKHEATYP,STAWKHEADMES,WPRESTAPSH,OPTSTAPSH) From CONNECTFCT
Endif
#######
Link [PSD] With [PSH]PSH0~=[F:PSD]PSHNUM
& As [LNK]

For [LNK]PSD0 Where evalue(P_CRITERE)
    Raz [PSO]
    Gosub WR_PSH

    If PITSTAPSH<>""
        Link [PTD] With [PSO]PSO0~=[F:PSD]PSHNUM;[F:PSD]PSDLIN;[F:PTD]POHNUM As [LNK2]
        WQTYR=0
        For [LNK2]PTD0
            WQTYR+=[F:PTD]QTYSTU
        Next
        Gosub WR_STAPSH
    Endif

Next
#######
If PITPSH<>"" : Call WRPIVOT_END(PITPSH ,WNBPSH ,WKNORECMES ,WPREPSH ,OPTPSH) From CONNECTFCT : Endif
If PITSTAPSH<>"" : Call WRPIVOT_END(PITSTAPSH ,WNBSTAPSH ,STAWKNORECMES ,WPRESTAPSH ,OPTSTAPSH) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_PSH
If PITPSH<>""
    ################################
    # fichiers PSH
    ################################
    #     Ouverture du fichier OPTPSH en écriture
    If WPREPSH = 0
      Openo OPTPSH,0 Using [FPIV]
      WPREPSH = 1
    Else
      Openo OPTPSH Using [FPIV]
    Endif
    WNBPSH += 1
    Call RAZVALPIVOT(PITPSH,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITPSH,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_STAPSH
If PITSTAPSH<>""
    ################################
    # fichiers STAPSH
    ################################
    #     Ouverture du fichier OPTSTAPSH en écriture
    If WPRESTAPSH = 0
      Openo OPTSTAPSH,0 Using [FPIV]
      WPRESTAPSH = 1
    Else
      Openo OPTSTAPSH Using [FPIV]
    Endif
    WNBSTAPSH += 1
    Call RAZVALPIVOT(PITSTAPSH,STAWKNBZON,STAWKVAL,STAWKVALFIC) From CONNECTFCT
    Call SETVAL("PREQUIS","WQTYR",STAWKNBZON,STAWKTABZON,STAWKVAL,STAWKVALFIC,num$(WQTYR)) From CONNECTFCT

    Call EVALPIVOT(PITSTAPSH,STAWKNBZON,STAWKTABZON,STAWKTABABR,STAWKZON,STAWKFRM,STAWKWRK,STAWKVAL,STAWKVALFIC) From CONNECTFCT
    Call WRPIVOT(STAWKNBZON,STAWKTABZON,STAWKTABABR,STAWKZON,STAWKFRM,STAWKWRK,STAWKVAL,STAWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
#############################################################################
Funprog PSH_GETSTA
Local Char LSTA
Raz LSTA
LSTA="0" : # En attente
If [F:PSH]PSHNUM<>""
    If [F:PSH]CLEFLG=2 # soldée
        If [F:PSH]APPLINNBR=0 & [F:PSH]ORDLINNBR=0
            LSTA="1" : # refusee
        Else
            LSTA="2" : # soldée
        Endif
    Endif
    If [F:PSH]APPLINNBR > 0
            LSTA="3" : # signée
    Endif
    If [F:PSH]ORDLINNBR > 0
            LSTA="4" : # commandée
    Endif
Endif
End LSTA
#############################################################################
Funprog PSD_GETSTA
Local Char LSTA
Local Integer WCLEFLG
Raz LSTA
LSTA="0" : # En attente
If [F:PSH]PSHNUM<>""
    If [F:PSH]CLEFLG=2 # soldée
        If [F:PSH]APPLINNBR=0 & [F:PSH]ORDLINNBR=0
            LSTA="1" : # refusee
        Elsif [F:PSD]LINCLEFLG=2
            LSTA="2" : # soldée
        Else
            LSTA="1" : # refusee
        Endif
    Endif
    If [F:PSD]LINAPPFLG <> 1 & [F:PSD]LINAPPFLG <> 4
        LSTA="3" : # signée
    Endif
    If [F:PSD]LINORDFLG = 2
        If !clalev([F:PSO]) Local File PREQUISO  [PSO] Endif
        If !clalev([F:POQ]) Local File PORDERQ   [POQ] Endif
        # FQ 65322 GA 06/2010 renvoyer Soldée si toutes les lignes de cde sont soldées
        Filter [PSO] Where PSHNUM=[F:PSD]PSHNUM & PSDLIN=[F:PSD]PSDLIN
        For [F:PSO] 
           Read [F:POQ]POQ0(2)=[F:PSO]POHNUM;[F:PSO]POPLIN
           If !fstat
              If [F:POQ]LINCLEFLG=1 
                 WCLEFLG=1 : Break
              Else
                 WCLEFLG=2   
              Endif
           Endif
        Next
        Filter [PSO]
        If WCLEFLG=2
            LSTA="2" : # soldée
        Else
            LSTA="4" : # commandée
        Endif
    Endif
Endif
End LSTA

#############################################################################
# FQ 65034 Accès aux Sections de la tale PSD                                #
# P_DIE    
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog PSD_GETCCE(P_DIE)
Value    Char    P_DIE () 

Local Char WCCE(GLONCCE)

# FQ 65646 [F:PSD]PSDSEQ champ inexistant
WCCE = func PITCCE.CAL_GETCCE("PSD",P_DIE,2,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"")

End WCCE
#############################################################################

