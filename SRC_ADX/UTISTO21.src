#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UTISTO21   Module STO                                                    #
#            Update VALWC activity code value                              #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update the activity code VALWC") From LECFIC

  Call MAJ_UTISTO21(DOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO21(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Local Integer NBW, NBF

Call ECR_TRACE("UTISTO21 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open Tables -----#
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"   [ACV]  : Endif
If clalev([F:ACV2]) =0  Local File =DOSSIER+".ACTIV"   [ACV2] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ACV2]

Readlock [ACV2]CODACT="VALWC"
If !fstat
    NBW=func AFNC.ACTIV("ENW")
    NBW=max(NBW,func AFNC.ACTIV("INV"))
    NBF=func AFNC.ACTIV("MAT")
    NBF=max(NBF,func AFNC.ACTIV("MAC"))
    NBF=max(NBF,func AFNC.ACTIV("LAB"))
    If [F:ACV2]DIMMAX<NBW*NBF
        # Erreur
        Call ECR_TRACE("New VALWC activity code value is too high (>32567). Please, decrease ENW, INV, MAT, MAC or LAB.",1) From GESECRAN
    Endif
    [F:ACV2]DIME = min([F:ACV2]DIMMAX,NBW*NBF)
  Rewrite [ACV2]
  If !fstat : COMPTEUR +=1 : Endif
Endif

Commit

Close Local File [ACV], [ACV2]

Call ECR_TRACE("UTISTO21 : "+num$(COMPTEUR)+" record processed",0) From GESECRAN

End

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If [F:ADS]MODULE(6)<>2 : End : Endif    # Module Stock active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTISTO21(APPLI)

End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI="X3" End : Endif

If [F:ADS]MODULE(6)<>2 : End : Endif        # Module Stock active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTISTO21(APPLI)

End
