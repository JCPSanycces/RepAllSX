#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UTICPT51   Module CPT    1099/DAS processing                             #
#            Initialize FEE activity code                                  #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update the activity code FEE") From LECFIC

  Call MAJ_UTICPT51(DOSSIER) 

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT51(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT51 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open Tables -----#
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"   [ACV]  : Endif
If clalev([F:ACV2]) =0  Local File =DOSSIER+".ACTIV"   [ACV2] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ACV2]

 Readlock [ACV2]CODACT="FEE"    
 If !fstat
  If func AFNC.ACTIV("S1099") | func AFNC.ACTIV("DAS")
   [F:ACV2]FLACT=2
  Else
   [F:ACV2]FLACT=1
  Endif
  Rewrite [ACV2]
  If !fstat : COMPTEUR +=1 : Endif
 Endif

Commit

Close Local File [ACV], [ACV2]

Call ECR_TRACE("UTICPT51 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif    # Module CPT active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTICPT51(APPLI)  
      
End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI="X3" End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif        # Module CPT active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTICPT51(APPLI)

End
