#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque AVERIFSRC2 (Spécifique)
# CBO 2008.09.29 sélection des modules du dossier choisi

$ACTION

    Case ACTION
        When "OUVRE"    : Gosub OUVRE
        When "DEBUT"    : Gosub DEBUT
        When "OK"       : Gosub OK
        When "ABA"      : Gosub ABA
    
    
    Endcase
Return

$OUVRE
Return


$DEBUT
    If clalev ([F:AST])
        Close Local File [F:AST]
    Endif
    # CBO 2011.06.09
    If dim([M:DIA]MACHINE) >= 0
        GAWMACHINE = [M:DIA]MACHINE
        GAWPORT = [M:DIA]PORT
    Endif

    If GAWMACHINE = ""
        Local File = [M:DIA]DOSSIER + "." + "APLSTD" [AST]
    Else
        Local File = GAWMACHINE + ":" + num$(GAWPORT) + "@" + [M:DIA]DOSSIER + "." + "APLSTD" [AST]
    Endif
     
    nolign = 0
    [M:DI2]BASTAB = 0
    For [AST]LAN From GLANGUE ; 014 To GLANGUE ; 014 Where [F:AST]LANNUM > 0
    
        [M:DI2]MODULE(nolign) = [F:AST]LANMES 
        [M:DI2]MODULE2(nolign) = [F:AST]LANNUM
        nolign += 1
        [M:DI2]BASTAB += 1
        
        If nolign  >= 30
            Break
        Endif
    
    Next
    
    Affzo [M:DI2]
    Close Local File [F:AST]
    
Return



$ABA


Return

$OK

    [M:DIA]LIBMODULE = [M:DI2]MODULE(nolign - 1)
    [M:DIA]NUMMODULE = [M:DI2]MODULE2(nolign - 1)
    Affzo [M:DIA]

Return
