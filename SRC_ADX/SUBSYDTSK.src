#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# TSK_INIT      : Initialisation synchronisation des taches
#
# TSK_SET_DESC   : Description passage info Outlook/Adonix
# TSK_SET        : Mise à jour d'une tache depuis Outlook vers Adonix
# TSK_LOADSET    : Transformation des info de Outlook en Adonix
# TSK_SET_OK     : Confirmation mise à jour Outlook vers Adonix
#
# TSK_GET_DESC   : Description passage info Adonix/Outlook
# TSK_GET        : Mise à jour d'une tache depuis Adonix vers Outlook
# TSK_GET_OK     : Confirmation mise à jour Adonix vers Outlook
##########################################################################################################
# FGR 21/07/2009 : X3SUIVI56584 : Remplacement de USERID(login X3) par GUSER(AUS) partout "où il faut"
##########################################################################################################
# Debut synchronisation taches
# ------------------------------------------------------------
Subprog TSK_INIT(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TBKINT, TBVINT)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Char TBKINT()(1..)       # Paramètres caractères
Variable Integer TBVINT(1..)

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

#Variables globales indiquant les droits sur la synchro des taches
Global Integer GIBTSKADXCRE       #Droit création tâche dans Adonix
Global Integer GIBTSKADXUPD       #Droit modification tâche dans Adonix
Global Integer GIBTSKADXDLT       #Droit suppression tâche dans Adonix
Global Integer GIBTSKOTKCRE       #Droit création tâche dans Outlook
Global Integer GIBTSKOTKUPD       #Droit modifcation tâche dans Outlook
Global Integer GIBTSKOTKDLT       #Droit suppression tâche dans Outlook
Global Integer GIBCLLADXCRE       #Droit création appel dans Adonix
Global Integer GIBCLLADXUPD       #Droit modification appel dans Adonix
Global Integer GIBCLLADXDLT       #Droit suppression appel dans Adonix
Global Integer GIBCLLOTKCRE       #Droit création appel dans Outlook
Global Integer GIBCLLOTKUPD       #Droit modifcation appel dans Outlook
Global Integer GIBCLLOTKDLT       #Droit suppression appel dans Outlook
Global Integer GIBPOSSYNCTSK      #synchronisation tache possible
Global Integer GIBPOSSYNCCLL      #synchronisation appel possible
Global Integer GIBSYNCTSKGERECOR  #Gestion des correspondants pour synchronisation des taches
Global Integer GINUMETAPEGET      #Numéro de l'étape dans la partie GET
Global Integer GINUMTRTGET        #Numéro de traitement dans la partie GET

Local Integer IBPARAMCHRG
Local Integer INDICETAB
Local Char TEXTMESGLOB(250)
Local Char TEXTMESTMP(250)
Local Char TEXTMES(250)
Local Integer IBERROR
Local Integer INBMES

  GINUMETAPEGET = 1
  GINUMTRTGET = 1
  GIBTSKADXCRE = MC_FALSE
  GIBTSKADXUPD = MC_FALSE
  GIBTSKADXDLT = MC_FALSE
  GIBTSKOTKCRE = MC_FALSE
  GIBTSKOTKUPD = MC_FALSE
  GIBTSKOTKDLT = MC_FALSE
  IBERROR = MC_FALSE
  IBPARAMCHRG = MC_FALSE
  INDICETAB = 1
  Raz TEXTMESGLOB
  Raz TEXTMESTMP
  Raz TEXTMES
  INBMES = 1
  # Statut
  RET = MC_OK
  #Initialisation synchronisation des tâches
  Call ECR_TRACE(mess(225,177,1) - "(" + USERID + ")(" + GUSER + ")", 0) From GESECRAN
  If dim(MSGFLG) > 0 Then
    INBMES = 1
    While INBMES < dim(MSGFLG)+1
      If MSGTXT(INBMES) <> "" Then
        Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
      Endif
      INBMES += 1
    Wend
    INBMES = 1
  Endif
  Raz MSGFLG
  Raz MSGTXT
  If GCRMSYNC <> 2 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If GCRMSYNCTSK = 1 and GCRMSYNCCLL = 1 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If USERID = "" Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If IBPARAMCHRG = MC_FALSE Then
    IBPARAMCHRG = MC_TRUE
    #On a un utilisateur On regarde son paramétrage
    Local File SYNCPAR [SYP]
    Read [SYP]SYP0=GUSER
    If fstat = 0 Then
      If [F:SYP]TSKADXCRE = 2 Then
        GIBTSKADXCRE = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]TSKADXUPD = 2 Then
        GIBTSKADXUPD = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]TSKADXDLT = 2 Then
        GIBTSKADXDLT = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]TSKOTKCRE = 2 Then
        GIBTSKOTKCRE = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]TSKOTKUPD = 2 Then
        GIBTSKOTKUPD = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]TSKOTKDLT = 2 Then
        GIBTSKOTKDLT = MC_TRUE
        GIBPOSSYNCTSK = MC_TRUE
      Endif
      If [F:SYP]CLLADXCRE = 2 Then
        GIBCLLADXCRE = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
      If [F:SYP]CLLADXUPD = 2 Then
        GIBCLLADXUPD = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
      If [F:SYP]CLLADXDLT = 2 Then
        GIBCLLADXDLT = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
      If [F:SYP]CLLOTKCRE = 2 Then
        GIBCLLOTKCRE = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
      If [F:SYP]CLLOTKUPD = 2 Then
        GIBCLLOTKUPD = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
      If [F:SYP]CLLOTKDLT = 2 Then
        GIBCLLOTKDLT = MC_TRUE
        GIBPOSSYNCCLL = MC_TRUE
      Endif
    Endif
  Else
    GIBPOSSYNCTSK = MC_FALSE
    GIBPOSSYNCCLL = MC_FALSE
  Endif
  GIBSYNCTSKGERECOR = GIBPOSSYNCCOR
  #On alimente le tableau de paramètre pour Retour à Outlook
  # Synchronisation possible sur les taches
  TBKINT(INDICETAB) = MC_MD
  If GIBTSKADXCRE = MC_FALSE and GIBTSKADXUPD = MC_FALSE and GIBTSKADXDLT = MC_FALSE
&        and GIBTSKOTKCRE = MC_FALSE and GIBTSKOTKUPD = MC_FALSE and GIBTSKOTKDLT = MC_FALSE
&        and GIBCLLADXCRE = MC_FALSE and GIBCLLADXUPD = MC_FALSE and GIBCLLADXDLT = MC_FALSE
&        and GIBCLLOTKCRE = MC_FALSE and GIBCLLOTKUPD = MC_FALSE and GIBCLLOTKDLT = MC_FALSE
& Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_C
  If GIBTSKADXCRE = MC_FALSE and GIBCLLADXCRE = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_U
  If GIBTSKADXUPD = MC_FALSE and GIBCLLADXUPD = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_D
  If GIBTSKADXDLT = MC_FALSE and GIBCLLADXDLT = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_C
  If GIBTSKOTKCRE = MC_FALSE and  GIBCLLOTKCRE = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_U
  If GIBTSKOTKUPD  = MC_FALSE and GIBTSKOTKUPD = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_D
  If GIBTSKOTKDLT  = MC_FALSE and GIBCLLOTKDLT = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  #Initialisation synchronisation des tâches
  #Paramétrage synchronisation Outlook-Adonix
  Call ECR_TRACE(mess(226,177,1), 0) From GESECRAN
  #Création
  If GIBTSKADXCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBTSKADXUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBTSKADXDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB,0) From GESECRAN
  #Création
  If GIBCLLADXCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBCLLADXUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBCLLADXDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB, 0) From GESECRAN
  #Paramétrage synchronisation Adonix-Outlook
  Call ECR_TRACE(mess(227,177,1), 0) From GESECRAN
  #Création
  If GIBTSKOTKCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBTSKOTKUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBTSKOTKDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB,0) From GESECRAN
  #Création
  If GIBCLLOTKCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBCLLOTKUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBCLLOTKDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB, 0) From GESECRAN
  #Nettoyage du aux traitements précédents
  Local File SYNCDATA [SYD]
  #Suppression enregistrement généré par synchro
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  Delete [SYD] Where [F:SYD]SYDUSR = GUSER and ([F:SYD]SYDTYP = "TSK"  or [F:SYD]SYDTYP = "CLL") and [F:SYD]SYDGEN = 1
  If fstat = 0 Then
    Commit
  Else
    Rollback
    IBERROR= MC_TRUE
    MSGFLG(INBMES) = MC_ERROR
    #Erreur lors de l'initialisation des données de synchronisation (suppression données obsolètes)
    MSGTXT(INBMES) = mess(229,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES+ = 1
  Endif
  If IBERROR = MC_FALSE Then
    #Aucun enregistrement n'a encore été modifié par la synchro
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and ([F:SYD]SYDTYP = "TSK" or [F:SYD]SYDTYP = "CLL") and ([F:SYD]SYDUPD = 1 or [F:SYD]SYDOTKSTA = 0)
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDOTKSTA = 1
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
    Else
      Rollback
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de l'initialisation des données de synchronisation (Nettoyage données obsolètes)
      MSGTXT(INBMES) = mess(230,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES+ = 1
      RET = MC_KO
    Endif
  Endif
End

##########################################################################################################
# Description passage info Outlook/Adonix
Subprog TSK_SET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 100
Local Integer WI : WI= 0
Local Char WDSC(200)(1..SC_MAX)
Local Integer INBMES

  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  Gosub TSK_INISETDSC From SUBSYDTSKD
  Gosub TSK_LD_SETDESC From SUBSYDTSKD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog TSK_SET(MAJ dans Adonix)
##########################################################################################################
Subprog TSK_SET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, TASKID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char TASKID()            # ID permettant de retrouver la tache (OL ou X3)
Value Char UPDFLG()
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer TBVINT(1..)
Variable Char TBKDEC()(1..)       # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char TBKDATTIM()(1..)    # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char TBKCLOB()(1..)      # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZTSKUSR(GLONAUS)
Local Integer LERRCOD
Local Integer ITRACE
Local Integer IOPENTRACE
Local Integer INBRECORD
Local Char SZMODE(GLONDES)
Local Integer IBERROR
Local Integer INBMES
Local Char SZTSKNUM(GLONTSK)
Local Char SZOBJET(GLONAOB)

  LERRCOD = 0
  IBRETOUR = 1
  IBERROR = MC_FALSE
  INBMES = 1
  INBRECORD = 0
  RET = MC_OK
  SZTSKUSR = ""
  SZMODE= ""
  SZTSKNUM = ""
  SZOBJET = ""
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  If left$(TASKID,3) = "CLL" Then
    #On est sur une tache de type appel
    Call CLL_SET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, TASKID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB) From SUBSYDCLL
    End
  Endif
  #Traitement de l'identifiant tache
  Call DECOD_OTKID(TASKID, "TSK", SZTSKNUM, SZOBJET) From SUBSYDUTIL
  If GCRMSYNC <> 2 Then
    RET = MC_OK
    End
  Endif
  If GCRMSYNCTSK <> 2 Then
    RET = MC_OK
    End
  Endif
  If USERID = "" Then
    MSGFLG(INBMES) = MC_ERROR
    #Aucun utilisateur n'est défini pour la synchronisation.
    MSGTXT(INBMES) = mess(231,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
    End
  Endif
  ITRACE = 1
  #Reinitialisation type conflit
  GITYPECONFLIT = 0
  GDTDATEMODIFOTK = [00/00/00]
  GDTDATEMODIFADX = [00/00/00]
  Local File TASK [TSK]
  Local File SYNCDATA [SYD]
  #"Traitement données outlook+" TASKID = "  + SZTSKNUM + " " Type+" : " UPDFLG
  Call ECR_TRACE((mess(228,177,1) - "TASKID =" - TASKID + "  " + mess(115,123,1) - ":" - UPDFLG), 0) From GESECRAN
  If UPDFLG = MC_UPD_RES Then
    If SZTSKNUM = "" Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et la tâche a le mode restauration.
      MSGTXT(INBMES) = mess(256,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Else
      #Deux cas soit la tache existe encore et on passe en modif
      #         soit la tache n'existe plus et on passe en création avec le code passé
      Read [TSK]TSK0=SZTSKNUM
      If fstat <> 0 Then
        #If faut créer
        UPDFLG = MC_UPD_CRE
      Else
        UPDFLG = MC_UPD_MOD
      Endif
    Endif
  Else
    If UPDFLG = MC_UPD_CRE Then
      SZTSKNUM = ""
    Endif
  Endif
  If SZTSKNUM = "" Then
    If UPDFLG <> MC_UPD_CRE Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et la tâche n'est pas nouvelle.
      MSGTXT(INBMES) = mess(255,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Endif
  Endif
  If RET = MC_KO_NEXT or RET = MC_KO Then
    #On sort
    End
  Endif
  If UPDFLG = MC_UPD_CRE Then
    #Cas d'une nouvelle tache
    If GIBTSKADXCRE = MC_TRUE Then
      #On a le droit de creer une tache donc on la creer
      SZMODE = MC_UPD_CRE
      Gosub TSK_LOADSET
      #Rq: transaction géré dans la fonction avec commit ou rollback
      Call CRETSK("SUBSYDTSK", ITRACE, 0, SZTSKNUM, LERRCOD) From SUBTSKCC
      If LERRCOD = 0 Then
        TASKID = "TSK" + SZTSKNUM
        Call DEBTRANS From GLOCK
        Read [TSK]TSK0=SZTSKNUM
        If fstat = 0 Then
          Trbegin [SYD]
          #Si pas de problème lors de la création de la tache, on cree une info de synchro
          Call SYDWRITE(GUSER, [F:TSK]SALFCY, [F:TSK]TSKNUM, "TSK", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            IBERROR = MC_TRUE
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour la nouvelle tâche - ":" -  [F:TSK]TSKNUM
            MSGTXT(INBMES) = mess(233,177,1) - ":" - [F:TSK]TSKNUM
            Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            Rollback
          Else
            Commit
          Endif
          #Traitement des zones à transcoder
          If IBERROR = MC_FALSE Then
            Gosub TRTERRORCODIF
          Endif
        Else
          RET = MC_KO_NEXT
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la lecture de la tâche - ":" -  [F:TSK]TSKNUM
          MSGTXT(INBMES) = mess(234,177,1) - ":" - [F:TSK]TSKNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          IBERROR = MC_TRUE
        Endif
      Else
        MSGFLG(INBMES) = MC_ERROR
        MSGTXT(INBMES) = GMESSIMP
        INBMES += 1
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la création d"une nouvelle tâche.
        MSGTXT(INBMES) = mess(232,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
        IBERROR = MC_TRUE
      Endif
    Endif
  Else
    #On est en modification ou en suppression
    #On vérifie que la tache existe
    Read [TSK]TSK0=SZTSKNUM
    If fstat <> 0 Then
      #Tache non trouve, elle a du être supprimé
      If UPDFLG <> MC_UPD_SUP Then
        #La tache existe dans Outlook
        #On vérifie que l'on a une trace pour l'utilisateur dans la synchro
        INBRECORD = 0
        Call DEBTRANS From GLOCK
        Trbegin [SYD]
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
          INBRECORD += 1
          If [F:SYD]SYDATTTYP <> "A" Then
            Readlock [SYD]Curr
            If fstat = 0 Then
              [F:SYD]SYDATTTYP = "A"
              [F:SYD]SYDOTKSTA = 1
              [F:SYD]SYDUPD = 1
              [F:SYD]SYDDAT = date$
              [F:SYD]SYDHOU = time$
              [F:SYD]CREUSR = GUSER
              [F:SYD]CREDAT = date$
              Rewrite [SYD]
              If fstat <> 0 Then
                RET = MC_KO_NEXT
                IBERROR = MC_TRUE
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de la modification des données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
                MSGTXT(INBMES) = mess(235,177,1) - ":" - [F:TSK]TSKNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                Break
              Endif
            Else
              RET = MC_KO_NEXT
              IBERROR = MC_TRUE
              MSGFLG(INBMES) = MC_ERROR
              #Impossible de locké les données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
              MSGTXT(INBMES) = mess(236,177,1) - ":" - [F:TSK]TSKNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              Break
            Endif
          Endif
        Next
        If INBRECORD = 0 and IBERROR = MC_FALSE Then
          #On n'a pas de donné de synchronisation
          #On crée une donnée pour indiqué à OutLook de supprimé
          Call SYDWRITE(GUSER, [F:TSK]SALFCY, SZTSKNUM, "TSK", "A", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
            MSGTXT(INBMES) = mess(237,177,1) - ":" - [F:TSK]TSKNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            IBERROR = MC_TRUE
          Endif
        Endif
        #On vérifie que l'on a une transaction en cours
        If adxlog Then
          If IBERROR = MC_TRUE Then
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Else
      #La tache existe
      If UPDFLG = MC_UPD_SUP Then
        #Il faut supprimer la tache
        If GIBTSKADXDLT = MC_TRUE Then
          SZMODE = MC_UPD_SUP
          Gosub TSK_LOADSET
          #Rq: transaction géré dans la fonction avec commit ou rollback
          Call DELTSK("SUBSYDTSK", ITRACE, IOPENTRACE, SZTSKNUM, LERRCOD) From SUBTSKCA
          If LERRCOD > 0 Then
            RET = MC_KO_NEXT
            MSGFLG(INBMES) = MC_ERROR
            MSGTXT(INBMES) = GMESSIMP
            INBMES += 1
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la suppression de la tâche - ":" -  [F:TSK]TSKNUM
            MSGTXT(INBMES) = mess(238,177,1) - ":" - [F:TSK]TSKNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
          Endif
          If LERRCOD = 0 Then
            #On a pu supprimer la tache et l'ordre vient de Outlook
            #On supprime les liens
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
            If fstat<> 0 Then
              Rollback
              IBERROR = MC_TRUE
              #Problème car incohérence entre TASK ET SYNCDATA
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la suppression des données de synchronisation pour la tâche - ":" - SZTSKNUM
              MSGTXT(INBMES) = mess(249,177,1) - ":" - SZTSKNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
            Else
              Commit
            Endif
          Endif
        Endif
      Else
        #On est en modif sur une tache qui existe
        Call GETUTIFROMREP([F:TSK]TSKREP, SZTSKUSR, IERRINF, ICHAPTER, IBRETOUR) From CRMUTIL150
        If IBRETOUR <> 0 Then
          If SZTSKUSR <> GUSER Then
            #On a eu un changement de représentant
            #On vérifie dans les données de synchro pour l'ancien
            INBRECORD = 0
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            For [SYD]SYD1 Where [F:SYD]SYDUSR = SZTSKUSR and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
              INBRECORD += 1
              If [F:SYD]SYDATTTYP <> "P" Then
                Readlock [SYD]Curr
                If fstat = 0 Then
                  [F:SYD]SYDATTTYP = "P"
                  [F:SYD]SYDOTKSTA = 1
                  [F:SYD]SYDUPD = 1
                  [F:SYD]SYDDAT = date$
                  [F:SYD]SYDHOU = time$
                  [F:SYD]CREUSR = GUSER
                  [F:SYD]CREDAT = date$
                  Rewrite [SYD]
                  If fstat <> 0 Then
                    RET = MC_KO_NEXT
                    MSGFLG(INBMES) = MC_ERROR
                    #Erreur lors de la modification des données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
                    MSGTXT(INBMES) = mess(235,177,1) - ":" - [F:TSK]TSKNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    IBERROR = MC_TRUE
                    Break
                  Endif
                Else
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Impossible de locké les données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
                  MSGTXT(INBMES) = mess(236,177,1) - ":" - [F:TSK]TSKNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                  Break
                Endif
              Endif
            Next
            If INBRECORD = 0 and IBERROR = MC_FALSE Then
              #On crée une donnée pour indiqué à OutLook de supprimé pour l"utilisateur
              Call SYDWRITE(SZTSKUSR, [F:TSK]SALFCY, SZTSKNUM, "TSK", "P", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBRETOUR = 0 Then
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de l'écriture des données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
                MSGTXT(INBMES) = mess(237,177,1) - ":" - [F:TSK]TSKNUM
                Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
              Endif
            Endif
            #On vérifie que l'on a une transaction en cours
            If adxlog Then
              If IBERROR = MC_TRUE Then
                Rollback
              Else
                Commit
              Endif
            Endif
          Endif
          #On modifie la tache
          If GIBTSKADXUPD = MC_TRUE and IBERROR = MC_FALSE Then
            INBRECORD = 0
            For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
              INBRECORD += 1
              Break
            Next
            If INBRECORD > 0 Then
              #Tache aussi modifier dans X3 donc Conflit
              #On recherche le type de conflit
              Gosub GETTYPECONFLIT
            Endif
            SZMODE = MC_UPD_MOD
            Gosub TSK_LOADSET
            #Rq: transaction géré dans la fonction avec commit ou rollback
            Call UPDTSK("SUBSYDTSK", ITRACE, IOPENTRACE, SZTSKNUM, LERRCOD) From SUBTSKCM
            If LERRCOD = 0 Then
              #On vérifie que l'on a une donnée de synchro
              INBRECORD = 0
              Call DEBTRANS From GLOCK
              Trbegin [SYD]
              For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
                INBRECORD += 1
                If [F:SYD]SYDATTTYP <> "M" Then
                  Readlock [SYD]Curr
                  If fstat = 0 Then
                    [F:SYD]SYDATTTYP = "M"
                    [F:SYD]SYDOTKSTA = 1
                    [F:SYD]SYDUPD = 1
                    [F:SYD]SYDDAT = date$
                    [F:SYD]SYDHOU = time$
                    [F:SYD]CREUSR = GUSER
                    [F:SYD]CREDAT = date$
                    Rewrite [SYD]
                    If fstat <> 0 Then
                      RET = MC_KO_NEXT
                      IBERROR = MC_TRUE
                      MSGFLG(INBMES) = MC_ERROR
                      #Erreur lors de la modification des données de synchronisation pour la tâche - ":" -  [F:TSK]TSKNUM
                      MSGTXT(INBMES) = mess(235,177,1) - ":" - [F:TSK]TSKNUM
                      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                      INBMES += 1
                      Break
                    Endif
                  Else
                    RET = MC_KO_NEXT
                    IBERROR = MC_TRUE
                    MSGFLG(INBMES) = MC_ERROR
                    #Impossible de locké les données de synchronisation pour la tâche - ":" -  SZTSKNUM
                    MSGTXT(INBMES) = mess(236,177,1) - ":" - SZTSKNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    Break
                  Endif
                Endif
              Next
              If INBRECORD = 0 and IBERROR = MC_FALSE Then
                #On n'a pas de donné de synchronisation
                #On crée une donnée pour indiqué à OutLook d'en tenir compte
                Call SYDWRITE(GUSER, [F:TSK]SALFCY, SZTSKNUM, "TSK", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
                If IBRETOUR = 0 Then
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Erreur lors de l'écriture des données de synchronisation pour la tâche - ":" -  SZTSKNUM
                  MSGTXT(INBMES) = mess(237,177,1) - ":" - SZTSKNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                Endif
              Endif
              #On vérifie que l'on a une transaction en cours
              If adxlog Then
                If IBERROR = MC_TRUE Then
                  Rollback
                Else
                  Commit
                Endif
              Endif
              #Traitement des zones à transcoder
              If IBERROR = MC_FALSE Then
                Gosub TRTERRORCODIF
              Endif
            Else
              MSGFLG(INBMES) = MC_ERROR
              MSGTXT(INBMES) = GMESSIMP
              INBMES += 1
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la modification de la tâche - ":" -  SZTSKNUM
              MSGTXT(INBMES) = mess(239,177,1) - ":" - SZTSKNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              RET = MC_KO_NEXT
            Endif
          Else
            RET = MC_OK
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Recherche du type de conflit
##########################################################################################################
$GETTYPECONFLIT
Local Integer IFIND

  #date de modification dans Outlook
  #IOTK = 1
  #While IOTK < dim(TBKDATTIM)+1
  #    If TBKDATTIM(IOTK) = "LastModificationTime"
  #Date de modification
  IFIND = find("LastModificationTime", TBKDATTIM)
  If IFIND > 0 Then
    Call GETDATEFROMCHAR(TBVDATTIM(IFIND),GDTDATEMODIFOTK,IERRINF,ICHAPTER,IBRETOUR) From SUBSYDUTIL
  Endif
  #date de modification dans Adonix
  GDTDATEMODIFADX = [F:TSK]UPDDAT
  If GDTDATEMODIFADX >= GDTDATEMODIFOTK Then
    GITYPECONFLIT = MC_RECENTADX
  Else
    GITYPECONFLIT = MC_RECENTOTK
  Endif
Return

##########################################################################################################
# Transfert des infos de Outlook vers Adonix
##########################################################################################################
$TSK_LOADSET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Integer IOTK
Local Integer IVALEUR
Local Integer INBHOUR
Local Char SZREP(GLONREP)
Local Char SZSITE(GLONFCY)
Local Char SZBPRCOR(GLONCOR)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Date DTVALEUR
Local Char SZVALEUR(250)
Local Integer IBCONTINUE
Local Integer IFIND
Local Integer IINDICE
Local Char SZCHAINE(250)
Local Char SZCORID(250)
Local Char SZOBJET(GLONAOB)

  Raz SZBPRCOR
  Raz SZREP
  Raz SZSITE
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = MC_TRUE
  DTVALEUR = [00/00/00]
  Raz SZVALEUR
  #Tableau de char
  Raz GTBKCHR
  Raz GTBVCHR
  #Tableau entiers
  Raz GTBKINT
  Raz GTBVINT
  #Tableau decimal
  Raz GTBKDEC
  Raz GTBVDEC
  #tableau date
  Raz GTBKDATTIM
  Raz GTBVDATTIM
  #tableau clob
  Raz GTBKCLOB
  Raz GTBVCLOB
  Raz GTBTRTFIE
  Raz GTBTRTVAL
  GNBTRT = 0
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  #Recherche du nombre de contact
  If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
  IFIND = 0
  IBCONTINUE = 1
  Raz SZCHAINE
  IINDICE = 0
  While IBCONTINUE = 1
    If GIBSYNCTSKGERECOR = MC_FALSE Then
      Break
    Endif
    IINDICE += 1
    If IINDICE >= dim(TBKCHR) Then
      IBCONTINUE = 0
      Break
    Endif
    SZCHAINE = "Lk_" + num$(IINDICE) + "_CtAdxId"
    #On recherche CtAdxId
    IFIND = find(SZCHAINE, TBKCHR)
    If IFIND > 0 Then
      If TBVCHR(IFIND) <> "" Then
        #Traitement de l'identifiant correspondant
        Call DECOD_OTKID(TBVCHR(IFIND), "COR", SZCORID, SZOBJET) From SUBSYDUTIL
        IBCONTINUE = 0
        Read [COR]COR0=SZCORID
        If fstat = 0 Then
          GTBKCHR(ICHAR) = "TSKCOR"
          GTBVCHR(ICHAR) = SZCORID
          ICHAR += 1
          If [F:COR]CNTNUM <> "" Then
            GTBKCHR(ICHAR) = "TSKCCN"
            GTBVCHR(ICHAR) = [F:COR]CNTNUM
            ICHAR += 1
          Else
            GTBKCHR(ICHAR) = "TSKCCN"
            GTBVCHR(ICHAR) = ""
            ICHAR += 1
          Endif
          SZBPRCOR = [F:COR]BPRNUM
        Else
          SZBPRCOR = ""
        Endif
      Else
        GTBKCHR(ICHAR) = "TSKCOR"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        GTBKCHR(ICHAR) = "TSKCCN"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        SZBPRCOR = ""
      Endif
    Else
      # FGR 25/08/2014 : X3SUIVI102228 : en 2013 il n'y a plus le contact, donc ne pas l'effacer si on arrive ici
      If dim(GSYNOLVERSION) >= 0 and GSYNOLVERSION >= "15.0" Then
      Else
        # Jusqu'à OL2010
        GTBKCHR(ICHAR) = "TSKCOR"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        GTBKCHR(ICHAR) = "TSKCCN"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        SZBPRCOR = ""
        IBCONTINUE = 0
      Endif
      Break
    Endif
  Wend
  #Traitement du tableau de char d'outlook
  IOTK = 1
  While IOTK < dim(TBKCHR)+1
    Case TBKCHR(IOTK)
      When "Companies"
        #Société
        If TBVCHR(IOTK) <> "" Then
          Call SYN_GETBPR(TBVCHR(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
          If SZVALEUR <> "" Then
            GTBKCHR(ICHAR) = "TSKCMP"
            GTBVCHR(ICHAR) = SZVALEUR
            ICHAR += 1
          Else
            If SZBPRCOR <> "" Then
              GTBKCHR(ICHAR) = "TSKCMP"
              GTBVCHR(ICHAR) = SZBPRCOR
              ICHAR += 1
            Else
              GTBTRTFIE(GNBTRT) = "TSKCMP"
              GTBTRTVAL(GNBTRT) = TBVCHR(IOTK)
              GNBTRT+ = 1
            Endif
          Endif
        Else
          GTBKCHR(ICHAR) = "TSKCMP"
          GTBVCHR(ICHAR) = ""
          ICHAR += 1
        Endif
    Endcase
    IOTK + = 1
  Wend
  #Traitement du tableau entier d'outlook
  IOTK = 1
  While IOTK < dim(TBKINT)+1
    Case TBKINT(IOTK)
      When "ActualWork"
        #Travail réel
        IVALEUR = TBVINT(IOTK)
        GTBKINT(IINT) = "HOUTIMSPG"
        GTBVINT(IINT) = int(IVALEUR/60)
        IVALEUR = GTBVINT(IINT)
        IINT += 1
        GTBKINT(IINT) = "MNTTIMSPG"
        GTBVINT(IINT) = TBVINT(IOTK) - (IVALEUR*60)
        IINT += 1
      When "Complete"
        #Terminé Oui/non
        GTBKINT(IINT) = "TSKDON"
        If TBVINT(IOTK) = 1 Then
          GTBVINT(IINT) = 2
        Else
          GTBVINT(IINT) = 1
        Endif
        IINT += 1
    Endcase
    IOTK + = 1
  Wend
  #Traitement du tableau de décimal d'outlook
  #  IOTK = 1
  #  While IOTK < dim(TBKDEC)+1
  #    Case TBKDEC(IOTK)
  #      When "test"
  #    Endcase
  #    IOTK += 1
  #  Wend
  #Traitement du tableau de date d'outlook
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    Case TBKDATTIM(IOTK)
      When "StartDate"
        #Date début
        GTBKDATTIM(IDATE) = "TSKSTR"
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVDATTIM(IDATE) = DTVALEUR
        IDATE += 1
      When "DueDate"
        #Echéance
        GTBKDATTIM(IDATE) = "TSKDAT"
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVDATTIM(IDATE) = DTVALEUR
        IDATE += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de clob d'outlook
  IOTK = 1
  While IOTK < dim(TBKCLOB)+1
    Case TBKCLOB(IOTK)
      When "Subject"
        GTBKCLOB(ICLOB) = "FULOBJ"
        GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
        ICLOB += 1
      When "Body"
        GTBKCLOB(ICLOB) = "FULRPO"
        GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
        ICLOB += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement des zones spéciales
  #Représentant
  Call PARAMUTIL("AUSCRMF", SZREP, GUSER, SZSITE) From SUBAUS
  GTBKCHR(ICHAR) = "TSKREP"
  GTBVCHR(ICHAR) = SZREP
  ICHAR += 1
  #Site
  Raz SZSITE
  Call SITECRMREP("ACT", SZREP, SZSITE) From CRM_UTIL
  If SZSITE <> "" Then
    GTBKCHR(ICHAR) = "SALFCY"
    GTBVCHR(ICHAR) = SZSITE
    ICHAR += 1
  Endif
  #Numéro de tache (cas particulier de larestoration
  If SZTSKNUM  <> "" Then
    GTBKCHR(ICHAR) = "TSKNUM"
    GTBVCHR(ICHAR) = SZTSKNUM
    ICHAR += 1
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une tache. (exemple)
#############################################################################
$TSK_SET_HEA_INFO
Local Integer INDEXE
Local Char SZREP(GLONREP)
Local Integer IBAFFECTE

  SZREP = ""
  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INDEXE = 0
  IBAFFECTE = MC_FALSE
  Case IMPZON
    When "TSKNUM"
      #Numéro de tache
      If GREP = "C" Then
        INDEXE = find("TSKNUM", GTBKCHR)
        If INDEXE <> 0 Then
          [M:TSK0]TSKNUM = GTBVCHR(INDEXE)
        Endif
      Endif
    When "SALFCY"
      #Site
      If GREP = "C" Then
        INDEXE = find("SALFCY", GTBKCHR)
        If INDEXE <> 0 Then
          [M:TSK0]SALFCY = GTBVCHR(INDEXE)
        Endif
      Endif
    When "TSKCMP"
      #Tiers
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKCMP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK0]TSKCMP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKCCN"
      #Interlocuteur
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKCCN", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK0]TSKCCN = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKCOR"
      #Interlocuteur
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKCOR", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK0]TSKCOR = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKPJT"
      #Affaire
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKPJT", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK0]TSKPJT = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKDAT"
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKDAT", GTBKDATTIM)
          If INDEXE <> 0 Then
            [M:TSK1]TSKDAT = GTBVDATTIM(INDEXE)
          Endif
        Endif
      Endif
    When "TSKSTR"
      #Echéance
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
           IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKSTR", GTBKDATTIM)
          If INDEXE <> 0 Then
            [M:TSK1]TSKSTR = GTBVDATTIM(INDEXE)
          Endif
          INDEXE = find("TSKORIADI", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKORIADI = GTBVCHR(INDEXE)
            [M:TSK1]TSKORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:TSK1]TSKORIADI)
            Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150
          Endif
          INDEXE = find("TSKORIVCR", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKORIVCR = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("TSKORIVCRL", GTBKINT)
          If INDEXE <> 0 Then
            [M:TSK1]TSKORIVCRL = GTBVINT(INDEXE)
          Endif
          INDEXE = find("TSKCMGNUM", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKCMGNUM = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("TSKOPGNUM", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKOPGNUM = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("TSKOPGTYP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKOPGTYP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKTYP"
      #Catégorie
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKTYP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKTYP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKREP"
      #Représentant
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKREP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK1]TSKREP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "TSKDEL"
      #Retard
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKDEL", GTBKINT)
          If INDEXE <> 0 Then
            [M:TSK1]TSKDEL = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "TSKDON"
      #Effectué
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKDON", GTBKINT)
          If INDEXE <> 0 Then
            [M:TSK0]TSKDON = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "HOUTIMSPG"
      #Temps passé (heures)
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("HOUTIMSPG", GTBKINT)
          If INDEXE <> 0 Then
            [M:TSK2]HOUTIMSPG = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "MNTTIMSPG"
      #Temps passé (minute)
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("MNTTIMSPG", GTBKINT)
          If INDEXE <> 0 Then
            [M:TSK2]MNTTIMSPG = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "TSKSAO"
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("TSKSAO", GTBKCHR)
          If INDEXE <> 0 Then
            [M:TSK2]TSKSAO = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "FULOBJ"
      #Objet
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULOBJ", GTBKCLOB)
          If INDEXE <> 0 Then
            [M:TSK1]FULOBJ = GTBVCLOB(INDEXE)
          Endif
        Endif
      Endif
    When "FULRPO"
      #Compte-rendu
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULRPO", GTBKCLOB)
          If INDEXE <> 0 Then
            Local Clbfile LBCLOB(3)

            LBCLOB = GTBVCLOB(INDEXE)
            Call CLEANCLOBBAP(LBCLOB) From SUBSYDUTIL
            [M:TSK2]FULRPO = LBCLOB
          Endif
        Endif
      Endif
  Endcase
Return

##########################################################################################################
# Traitement de l'enregistrement des erreurs de transcodifications
$TRTERRORCODIF
Local Integer ITRT

  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  ITRT = 0
  If GNBTRT > 0 Then
    #On a des données a sauvegarder
    Call DEBTRANS From GLOCK
    Trbegin [SYL]
    While ITRT < GNBTRT
      Call SYLWRITE(GUSER, "TSK", SZTSKNUM, GTBTRTFIE(ITRT), GTBTRTVAL(ITRT), IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
      If IBRETOUR = MC_FALSE Then
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de l'écriture des traces de transcodifications. Tâche - ":" -  [F:TSK]TSKNUM + Champs +GTBTRTFIE(ITRT)
        MSGTXT(INBMES) = mess(248,177,1) - ":" - [F:TSK]TSKNUM - mess(149,123,1) - GTBTRTFIE(ITRT)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
      ITRT+ = 1
    Wend
    If IBRETOUR = MC_TRUE Then
      Commit
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
Return

##########################################################################################################
# Confirmation Set (Outlook vers Adonix)
# ------------------------------------------------------------
Subprog TSK_SET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TASKID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char TASKID()               # ID permettant de retrouver la tache

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IBERROR
Local Integer INBMES
Local Char SZTSKNUM(GLONTSK)
Local Char SZOBJET(GLONAOB)
Local Char SZRET(GLONDES)
Local Integer WI

  IBERROR = MC_FALSE
  Raz SZTSKNUM
  Raz SZOBJET
  # Analyse des messages si besoin
  WI = find(2,MSGFLG)
  #  If(WI!= 0) .....
  WI = find(1,MSGFLG)
  #  If(WI!= 0) .....
  INBMES = 1
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  If left$(TASKID,3) = "CLL" Then
    #On est sur une tache de type appel
    Call CLL_SET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TASKID) From SUBSYDCLL
    End
  Endif
  #"Confirmation données outlook" TASKID = "  + TASKID + " " Status +" : " + RET
  Call ECR_TRACE((mess(258,177,1) - "TASKID =" - TASKID + "  " + mess(259,123,1) - ":" - RET), 0) From GESECRAN
  #Traitement de l'identifiant tache
  Call DECOD_OTKID(TASKID, "TSK", SZTSKNUM, SZOBJET) From SUBSYDUTIL
  Local File SYNCDATA [SYD]
  IBERROR = MC_FALSE
  If SZRET <> MC_OK Then
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour la tâche - ":" -  SZTSKNUM
          MSGTXT(INBMES) = mess(235,177,1) - ":" - SZTSKNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locké les données de synchronisation pour la tâche - ":" -  SZTSKNUM
        MSGTXT(INBMES) = mess(236,177,1) - ":" - SZTSKNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
      RET = MC_OK
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
End

##########################################################################################################
# Description passage info Adonix/Outlook
# ------------------------------------------------------------
Subprog TSK_GET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

Local Integer INBMES

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 100
Local Integer WI : WI= 0
Local Char WDSC(200)(1..SC_MAX)

  Gosub TSK_INIGETDSC From SUBSYDTSKD
  Gosub TSK_LD_GETDESC From SUBSYDTSKD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog TSK_GET (MAJ OutLook depuis Adonix)
# ------------------------------------------------------------
Subprog TSK_GET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, TASKID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char TASKID()            # ID permettant de retrouver la tache (OL ou X3)
Variable Char UPDFLG()            # Type de mise à jour (C,M,S)
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer  TBVINT(1..)
Variable Char TBKDEC()(1..)       # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char TBKDATTIM()(1..)    # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char TBKCLOB()(1..)      # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  #Mise à vide des tableaux dynamiques
  Gosub RAZPARAMDYN From SUBSYDSYN

Local Char SZMESSAGE(250)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer INBRECORD
Local Char SZSYDATTTYP(250)
Local Integer ISYDGEN
Local Integer ISYDUPD
Local Integer INBMES
Local Char SZTSKNUM(GLONTSK)
Local Char SZOBJET(GLONAOB)
Local Integer IBERROR

  Raz SZMESSAGE
  IBERROR = 0
  IBRETOUR = 1
  INBRECORD = 0
  ISYDGEN= 0
  ISYDUPD = 0
  SZSYDATTTYP = ""
  INBMES = 1
  Raz SZTSKNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  RET = MC_OK
  Local File TASK [TSK]
  Local File SYNCDATA [SYD]
  Local File HD4CLOB [HD4]
  Local File HD6CLOB [HD6]
  Local File CORRESPOND [COR]
  If GINUMTRTGET = 1 Then
    #Traitement des taches
    If GIBTSKOTKCRE = MC_FALSE and GIBTSKOTKUPD = MC_FALSE and  GIBTSKOTKDLT = MC_FALSE Then
      #Aucun droit synchronisation  dans Outlook pour les taches on passe aux appels
      GINUMTRTGET = 2
      GINUMETAPEGET = 1
    Endif
  Endif
  If GINUMTRTGET = 2 Then
    #Traitement des taches
    If GIBCLLOTKCRE = MC_FALSE and GIBCLLOTKUPD = MC_FALSE and  GIBCLLOTKDLT = MC_FALSE Then
      #Aucun droit synchronisation  dans Outlook pour les appels on passe à la fin
      GINUMTRTGET = 3
      End
    Endif
  Endif
  #Ontraite les enregistrements par type
  #Rappel
  # "C" création,
  # "D" duplication,
  # "M" modification,
  # "A" annulation
  # "P" changement utilisateur (pour ancien)
  # "R" restauration ou forcage synchro
  If GINUMTRTGET = 1 Then
    INBRECORD = 0
    #Etape 1
    #Enregistrement à créer
    If GINUMETAPEGET = 1 Then
      If GIBTSKOTKCRE = MC_FALSE Then
        #Pas le droit de créer On passe à l'étape 2
        GINUMETAPEGET = 3
      Else
        INBRECORD = 0
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "C" or [F:SYD]SYDATTTYP = "D")
          INBRECORD += 1
          SZTSKNUM = [F:SYD]SYDKEY
          SZSYDATTTYP = [F:SYD]SYDATTTYP
          ISYDGEN = [F:SYD]SYDGEN
          ISYDUPD = [F:SYD]SYDUPD
          Break
        Next
        If INBRECORD = 0 Then
          #On n'a plus d'enregistrement On passe à l'étape 2
          GINUMETAPEGET = 2
        Endif
      Endif
    Endif
    #Etape 2
    #Enregistrement modifié
    If GINUMETAPEGET = 2 Then
      If GIBTSKOTKUPD = MC_FALSE Then
        #Pas le droit de créer On passe à l'étape 3
        GINUMETAPEGET = 3
      Else
        INBRECORD = 0
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "M"
          INBRECORD += 1
          SZTSKNUM = [F:SYD]SYDKEY
          SZSYDATTTYP = [F:SYD]SYDATTTYP
          ISYDGEN = [F:SYD]SYDGEN
          ISYDUPD = [F:SYD]SYDUPD
          Break
        Next
        If INBRECORD = 0 Then
          #On n'a plus d'enregistrement On passe à l'étape 3
          GINUMETAPEGET = 3
        Endif
      Endif
    Endif
    #Etape 3
    #Enregistrement restauration ou forcage synchro
    If GINUMETAPEGET = 3 Then
      If GIBTSKOTKCRE = MC_FALSE and GIBTSKOTKUPD = MC_FALSE Then
        #Pas le droit de créer et de modifer  On passe à l'étape 4
        GINUMETAPEGET = 4
      Else
        INBRECORD = 0
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "R"
          INBRECORD += 1
          SZTSKNUM = [F:SYD]SYDKEY
          SZSYDATTTYP = [F:SYD]SYDATTTYP
          ISYDGEN = [F:SYD]SYDGEN
          ISYDUPD = [F:SYD]SYDUPD
          Break
        Next
        If INBRECORD = 0 Then
          #On n'a plus d'enregistrement On passe à l'étape 4
          GINUMETAPEGET = 4
        Endif
      Endif
    Endif
    #Etape 4
    #suppression enregistrement non touché par synchro
    If GINUMETAPEGET = 4 Then
      If GIBTSKOTKDLT = MC_FALSE Then
        #Pas le droit de créer On passe à l'étape 5
        GINUMETAPEGET = 5
      Else
        INBRECORD = 0
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "A" or [F:SYD]SYDATTTYP = "P")
          INBRECORD += 1
          SZTSKNUM = [F:SYD]SYDKEY
          SZSYDATTTYP = [F:SYD]SYDATTTYP
          ISYDGEN = [F:SYD]SYDGEN
          ISYDUPD = [F:SYD]SYDUPD
          Break
        Next
        If INBRECORD = 0 Then
          #On n'a plus d'enregistrement On passe à l'étape 5
          GINUMETAPEGET = 5
        Endif
      Endif
    Endif
    If GINUMETAPEGET <> 5 Then
      #On a un enregistrement, il faut le traiter
      #Cas des enregistrements nouveaux ou modifiés (la tache existe dans Adonix)
      Call  CODE_OTKID(SZTSKNUM, "TSK", TASKID) From SUBSYDUTIL
      #"Traitement données Adonix "TASKID = "  + TASKID+ " " Type+" : " SZSYDATTTYP
      Call ECR_TRACE((mess(260,177,1) - "TASKID =" - TASKID + "  " + mess(115,123,1) - ":" - SZSYDATTTYP), 0) From GESECRAN
      If SZSYDATTTYP = "P" Then
        UPDFLG = "A"
      Else
        UPDFLG = SZSYDATTTYP
      Endif
      If UPDFLG <> "A" Then
        Read [TSK]TSK0=SZTSKNUM
        If fstat <> 0 Then
          #Problème car incohérence entre TASK ET SYNCDATA
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la lecture de la tâche - ":" -  SZTSKNUM
          MSGTXT(INBMES) = mess(234,177,1) - ":" - SZTSKNUM
          Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
          INBMES += 1
          RET = MC_KO_NEXT
        Endif
      Endif
      If RET = MC_OK Then
        #On charge les tableaux dynamiques
        Gosub TSK_LOADGET
      Endif
    Else
      #On n'a plus de tache on traite les appels
      GINUMTRTGET = 2
      GINUMETAPEGET = 1
    Endif
  Endif
  If GINUMTRTGET = 2 Then
    Call CLL_GET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, TASKID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB) From SUBSYDCLL
  Endif
  If GINUMTRTGET = 3 Then
    RET = MC_NOMORE
  Endif
End

##########################################################################################################
# Transfert des infos de Adonix vers Outlook
##########################################################################################################
$TSK_LOADGET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Char SZVALEUR(250)     # FGR 25/02/2014 : X3SUIVI97224
Local Integer IBEXIST
Local Char SZREPCONNECT(GLONREP)
Local Integer IBVIDE
#Local Clbfile LBCLOBENTETE   # FGR 15/01/2013 : X3SUIVI87223
Local Clbfile LBCLOBENTETE(3) # FGR 25/08/2013 : X3SUIVI102228
Local Char SZTEXTE(250)       # FGR 15/01/2013 : X3SUIVI87223
Local Char SZTEXTE1(250)      # FGR 25/02/2014 : X3SUIVI97224

  Raz SZREPCONNECT
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  Raz SZVALEUR
  IBEXIST = 0
  IBVIDE = MC_FALSE
  If UPDFLG = "A" Then
    IBVIDE = MC_TRUE
  Endif
  Call GETREPFROMUTI(GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT = "" Then
    #Erreur, aucun représentant n'est associé à cet utilisateur : GUSER
    MSGTXT(INBMES) = mess(301,177,1) - ":" - GUSER
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
  Endif
  #Tiers
  TBKCHR(ICHAR) = "Companies"
  Call SYN_SETBPR([F:TSK]TSKCMP, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
  If IBRETOUR = MC_TRUE and IBVIDE = MC_FALSE Then
    TBVCHR(ICHAR) = SZVALEUR
  Endif
  ICHAR += 1
  If GIBSYNCTSKGERECOR = MC_TRUE Then
    #Interlocuteur
    IBERROR = 0
    If [F:TSK]TSKCOR <> "" Then
      TBKCHR(ICHAR) = "Lk_1_CtAdxId"
      Call  CODE_OTKID([F:TSK]TSKCOR, "COR", TBVCHR(ICHAR)) From SUBSYDUTIL
      ICHAR += 1
      TBKCHR(ICHAR) = "Lk_1_Name"
      Read [COR]COR0=[F:TSK]TSKCOR
      If fstat = 0 Then
        TBVCHR(ICHAR) = [F:COR]LNA - [F:COR]FNA
      Else
        TBVCHR(ICHAR) = [F:TSK]TSKCOR
      Endif
      ICHAR += 1
    Endif
  Endif
  #Travail réel
  TBKINT(IINT) = "ActualWork"
  If IBVIDE = MC_FALSE Then
    TBVINT(IINT) = ([F:TSK]HOUTIMSPG*60) + [F:TSK]MNTTIMSPG
  Endif
  IINT += 1
  #Status
  TBKINT(IINT) = "Status"
  If IBVIDE = MC_FALSE Then
    If [F:TSK]TSKDON = 2 Then
      TBVINT(IINT) = 2
    Else
      If (([F:TSK]HOUTIMSPG*60) + [F:TSK]MNTTIMSPG) > 0 Then
        TBVINT(IINT) = 1
      Else
        TBVINT(IINT) = 0
      Endif
    Endif
  Endif
  IINT += 1
  #Date début
  TBKDATTIM(IDATE) = "StartDate"
  If IBVIDE = MC_FALSE Then
    Call SETDATETIMETOCHAR([F:TSK]TSKSTR, "000000", SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  IDATE += 1
  #Echéance
  TBKDATTIM(IDATE) = "DueDate"
  If IBVIDE = MC_FALSE Then
    Call SETDATETIMETOCHAR([F:TSK]TSKDAT, "000000", SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  IDATE += 1
  #AdxTaskDateTime
  TBKDATTIM(IDATE) = "AdxTaskDateTime"
  If IBVIDE = MC_FALSE Then
    Call SETDATETIMETOCHAR([F:TSK]TSKDAT, "000000", SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  IDATE += 1
  # FGR 16/01/2013 : X3SUIVI87223 (début)
  Raz LBCLOBENTETE
  # ------------------------
  # FGR 25/02/2014 : X3SUIVI97224 (début)
  # Entête
  LBCLOBENTETE += mess(680,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:TSK]TSKNUM, "GESTSK", [F:TSK]TSKNUM)
  LBCLOBENTETE += chr$(13) + chr$(10) + string$(50, '-')
  #
  If [F:TSK]TSKCMP <> "" Then
    Call GETBPRTYP([F:TSK]TSKCMP, SZTEXTE, SZTEXTE1) From CRM_UTIL
    Call SYN_SETBPR([F:TSK]TSKCMP, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    Read [BPR]BPR0=[F:TSK]TSKCMP
    If SZTEXTE1 = "" Then
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - SZVALEUR
    Else
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GES" + SZTEXTE1, [F:TSK]TSKCMP) - ":" - SZVALEUR
    Endif
  Endif
  If [F:TSK]TSKCCN <> "" Then
    If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
    Read [AIN]AIN0=[F:TSK]TSKCCN
    If !fstat Then
      SZTEXTE = mess([F:AIN]CNTTYP,3038,1)
      Call BUILDFULNAM("AIN", SZVALEUR) From CRMUTIL140
      If [F:AIN]CNTTYP = 1 Then
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESAIN", [F:TSK]TSKCCN)
      Else
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESLDS", [F:TSK]TSKCCN)
      Endif
    Endif
  Endif
  If [F:TSK]TSKCOR <> "" Then
    Call TEXTE(15307, SZTEXTE) From OBJDIV
    If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
    Read [COR]COR0=[F:TSK]TSKCOR
    If !fstat Then
      Call BUILDFULNAM("COR", SZVALEUR) From CRMUTIL140
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESCOR", [F:TSK]TSKCOR)
      Call GET_INFO_CORRESPONDANT([F:TSK]TSKCOR, LBCLOBENTETE) From SUBSYDUTIL
    Endif
  Endif
  If [F:TSK]TSKPJT <> "" Then
    Call TEXTE(18260, SZTEXTE) From OBJDIV
    If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
    Read [OPP]OPP0=[F:TSK]TSKPJT
    If !fstat Then
      If dim([F:OPP]OPPDES) >= 0 Then
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:OPP]OPPDES, "GESOPP", [F:TSK]TSKPJT)
      Else
        Call LECTEXTRA(SZTEXTE1, "PIMPL", "PIMDESAXX", [F:TSK]TSKPJT, "") From ATEXTRA
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZTEXTE1, "GESOPP", [F:TSK]TSKPJT) #- ":" - [F:OPP]OPPDES - "(" + [F:TSK]TSKPJT + ")"
      Endif
    Endif
  Endif
  # FGR 25/02/2014 : X3SUIVI97224 (fin)
  # ------------------------
  If [F:TSK]TSKTYP <> "" Then
    Call TEXTE(707, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - [F:TSK]TSKTYP - "(" + func CRM_UTIL.FGET_LIB(431, [F:TSK]TSKTYP, "LNGDES") + ")"
  Else
    Call TEXTE(707, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ": ***" + mess(962,182,1) + "***"
  Endif
  If [F:TSK]TSKPIOLEV <> "" Then
    Call TEXTE(14482, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - [F:TSK]TSKPIOLEV - "(" + func CRM_UTIL.FGET_LIB(405, [F:TSK]TSKPIOLEV, "LNGDES") + ")"
  Else
    Call TEXTE(14482, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE
    Call TEXTE(16710, SZTEXTE) From OBJDIV
    LBCLOBENTETE += " : ***" + SZTEXTE + "***"
  Endif
  If [F:TSK]TSKDEL > 0 Then
    Call TEXTE(22153, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - num$([F:TSK]TSKDEL) - mess(2,976,1)
  Endif
  # ------------------------
  If LBCLOBENTETE <> "" Then
    Call ADDBALISEBAP(LBCLOBENTETE) From SUBSYDUTIL
  Endif
  #Description
  TBKCLOB(ICLOB) = "Subject"
  If IBVIDE = MC_FALSE Then
    If [F:TSK]NUMFULOBJ <> "" and [F:TSK]TYPFULOBJ <> "" Then
      Read [HD6]HD60=[F:TSK]NUMFULOBJ;[F:TSK]TYPFULOBJ
      If fstat = 0 Then
        TBVCLOB(ICLOB) = [F:HD6]CLOB
      Endif
    Endif
  Endif
  ICLOB += 1
  #Compte rendu
  TBKCLOB(ICLOB) = "Body"
  # FGR 16/01/2013 : X3SUIVI87223 (début)
  If LBCLOBENTETE <> "" Then
    TBVCLOB(ICLOB) = LBCLOBENTETE
  Endif
  # FGR 16/01/2013 : X3SUIVI87223 (fin)
  If IBVIDE = MC_FALSE Then
    If [F:TSK]NUMFULRPO <> "" and [F:TSK]TYPFULRPO <> "" Then
      Read [HD4]HD40=[F:TSK]NUMFULRPO;[F:TSK]TYPFULRPO
      If fstat = 0 Then
        If LBCLOBENTETE <> "" Then
          TBVCLOB(ICLOB) += chr$(13) + chr$(10) + chr$(13) + chr$(10) + [F:HD4]CLOB
        Else
          TBVCLOB(ICLOB) = [F:HD4]CLOB
        Endif
      Endif
    Endif
  Endif
  ICLOB += 1
Return

##########################################################################################################
# Confirmation Get
# ------------------------------------------------------------
Subprog TSK_GET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TASKID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char TASKID()               # ID permettant de retrouver la tache

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Char SZTSKNUM(GLONTSK)
Local Char SZOBJET(GLONAOB)
Local Integer INBMES
Local Integer IBERROR
Local Char SZRET(GLONDES)

  Raz SZTSKNUM
  Raz SZOBJET
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  If left$(TASKID,3) = "CLL" Then
    #On est sur une tache de type appel
    Call CLL_GET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TASKID) From SUBSYDCLL
    End
  Endif
  #"Confirmation données Adonix" TASKID = "  + TASKID + " " Status +" : " + RET
  Call ECR_TRACE((mess(261,177,1) - "TASKID =" - TASKID + "  " + mess(259,123,1) - ":" - RET), 0) From GESECRAN
  IBERROR = MC_FALSE
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  Local File SYNCDATA [SYD]
  Call DECOD_OTKID(TASKID, "TSK", SZTSKNUM, SZOBJET) From SUBSYDUTIL
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If SZRET = MC_OK Then
    #Tout s'est bien passé, on supprime les enregistrements de SYNCDATA
    Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
    If fstat <> 0 Then
      IBERROR = MC_TRUE
      #Problème car incohérence entre TASK ET SYNCDATA
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de la suppression des données de synchronisation pour la tâche - ":" - SZTSKNUM
      MSGTXT(INBMES) = mess(249,177,1) - ":" - SZTSKNUM
      Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
      INBMES += 1
    Endif
  Else
    #Problème on met à jour le flag
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = SZTSKNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour la tâche - ":" - SZTSKNUM
          MSGTXT(INBMES) = mess(235,177,1) - ":" - SZTSKNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la modification des données de synchronisation pour la tâche - ":" - SZTSKNUM
        MSGTXT(INBMES) = mess(236,177,1) - ":" - SZTSKNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
  Endif
  If IBERROR = MC_FALSE Then
    Commit
    RET = MC_OK
  Else
    Rollback
    RET = MC_KO_NEXT
  Endif
End

