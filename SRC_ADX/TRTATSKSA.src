#############################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#############################################
$EXEC
# ouverture de la trace et écriture de l'en-tête
#"Extraction Attestation Pôle emploi"
TIT=mess(128,10703,1)
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#MIPEA - 2016-09-30 - X3PEOP-751 - START
SYMBOLE = "HRATS"+num$(date$)
#SYMBOLE = "ATS"+num$(date$)
#MIPEA - 2016-09-30 - X3PEOP-751 - END
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Local Char RUBUIFINC(GLONRUB)
Local Date USEXITDAT
#MIPEA - 2016-09-30 - X3PEOP-751 - END
#JASMI - 2016-10-03 - X3PEOP-751 - Needs to be done on EXEC action - START
#MIPEA - 2017-01-23- X3-12004- START
Call PARAM(GCURLEG,"SLDTTCPT",RUBSLDCPT)From ADOVAL
#Call PARAM("","SLDTTCPT",RUBSLDCPT)From ADOVAL
#MIPEA - 2017-01-23- X3-12004- END
If RUBSLDCPT=""
 Call ECR_TRACE(mess(68,10703,1),0) From GESECRAN : # Parameter "Balance of any account" POA
 GOK=0
Endif
Call PARAM(GCURLEG,"SLDHRSDIF",RUBHRSDIF)From ADOVAL
Call PARAM(GCURLEG,"SLDDIFAMT",RUBAMTDIF)From ADOVAL
#98617_US2621
Call PARAM(GCURLEG,"MAIGARMUT",RUBMUTMAIN)From ADOVAL
Call PARAM(GCURLEG,"MAIGARPRV",RUBPRVMAIN)From ADOVAL
#end 98617_US2621
Call PARAM(GCURLEG,"NBSTAREA",RUBNBSTA)From ADOVAL : : #US3751 108474 trainee
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - START
Call PARAM(GCURLEG,"MTDUIFINC",RUBUIFINC)From ADOVAL
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - NED
#JASMI - 2016-10-03 - X3PEOP-751 - Needs to be done on EXEC action - END

#89566
GPOINT = "ADDCRITSPE" : Gosub ENTREE From EXEFNC
If vireblc([L]CRITSPE,4)="" : [L]CRITSPE="1=1" : Endif
#CRITEMP="1=1"
[L]CRITEMP=[L]CRITSPE

CRITEMP2="1=1"
CRITFCY="1=1"

If dim([M:DIA]ALLCPY)>0 & [M:DIA]ALLCPY<>2  #société
 CRITFCY -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If dim([M:DIA]ALLFCY)>0 &  [M:DIA]ALLFCY<>2  #site
 CRITFCY -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif

If dim([M:DIA]MATDEB)>0
 If [M:DIA]MATDEB<>"" #borne début matricule
  CRITEMP -= '& REFNUM>="'+[M:DIA]MATDEB+'"'
 Endif
 If [M:DIA]MATFIN<>"" #borne fin du matricule
  CRITEMP -= '& REFNUM<="'+[M:DIA]MATFIN+'"'
 Endif
Endif
If dim([M:DIA]REFNUM)>0 & [M:DIA]REFNUM<>""
 CRITEMP -= '& REFNUM="'+[M:DIA]REFNUM+'"'
Endif

#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#CRITEMP2 -= '& [F:HRCTR]XITDAT<>[00/00/00] & [F:HRCTR]XITFNL=2'
#If dim([M:DIA]DATXITSTR)>0
# If [M:DIA]DATXITSTR<>[00/00/00]
#  CRITEMP2 -= '& [F:HRCTR]XITDAT>=[M:DIA]DATXITSTR'
# Endif
# If [M:DIA]DATXITEND<>[00/00/00]
#  CRITEMP2 -= '& [F:HRCTR]XITDAT<=[M:DIA]DATXITEND'
# Endif
#Endif
CRITEMP2 -= '& (([F:HRCTR]XITDAT<>[00/00/00] & [F:HRCTR]XITFNL=2'
If dim([M:DIA]DATXITSTR)>0
 If [M:DIA]DATXITSTR<>[00/00/00]
  CRITEMP2 -= '& [F:HRCTR]XITDAT>=[M:DIA]DATXITSTR'
 Endif
 If [M:DIA]DATXITEND<>[00/00/00]
  CRITEMP2 -= '& [F:HRCTR]XITDAT<=[M:DIA]DATXITEND'
 Endif
Endif
CRITEMP2 -= ')'
CRITEMP2_1=''
CRITEMP2_2=''
If [M:DIA]EXOCOD<>''
  CRITEMP2_1 -= '|(([M:DIA]EXOCOD=[F:HRCTR]EXOCOD1 & [F:HRCTR]EXOSTR1>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR1<=[M:DIA]DATXITEND)'
  CRITEMP2_1 -= ' |([M:DIA]EXOCOD=[F:HRCTR]EXOCOD2 & [F:HRCTR]EXOSTR2>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR2<=[M:DIA]DATXITEND)'
  CRITEMP2_2 -= ' |([M:DIA]EXOCOD=[F:HRCTR]EXOCOD3 & [F:HRCTR]EXOSTR3>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR3<=[M:DIA]DATXITEND)'
  CRITEMP2_2 -= ' |([M:DIA]EXOCOD=[F:HRCTR]EXOCOD4 & [F:HRCTR]EXOSTR4>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR4<=[M:DIA]DATXITEND))'
Endif
CRITEMP2_2+=')'
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END

#88314
CRITEMP3="1=1"
If dim([M:DIA]ALLSRV)>0 & [M:DIA]ALLSRV<>2
 CRITEMP3 -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If dim([M:DIA]ALLPRF)>0 & [M:DIA]ALLPRF<>2
 CRITEMP3 -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

If [M:DIA]POP<>""
#MIPEA - 2016-09-30 - X3PEOP-751 - START
  CRITEMP3 -= '& [F:HRPOA]REFNUM<>""'
 #CRITEMP3 -= '& [F:POA]REFNUM<>""'
#MIPEA - 2016-09-30 - X3PEOP-751 - END
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Link [HRCTR] With
&     [FCY]FCY0 = [F:HRCTR]ETRFCY,
&     [ID]ID0   = [F:HRCTR]REFNUM,
&     [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&     As [LNK] Where [F:ID]FLGPAY=2 & [F:FCY]LEG=GCURLEG : #MIPEA - 2016-08-11 - X3PEOP-975
Else
 Link [HRCTR] With
&     [FCY]FCY0 = [F:HRCTR]ETRFCY,
&     [ID]ID0 = [F:HRCTR]REFNUM
&     As [LNK] Where [F:ID]FLGPAY=2 & [F:FCY]LEG=GCURLEG : #MIPEA - 2016-08-11 - X3PEOP-975
Endif
# Link [HRCTR] With
#&   [ID]ID0   = [F:HRCTR]REFNUM,
#&   [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
#&   As [LNK] Where [F:ID]FLGPAY=2 :#106972
#Else
# Link [HRCTR] With
#&   [ID]ID0 = [F:HRCTR]REFNUM
#&   As [LNK] Where [F:ID]FLGPAY=2 :#106972
#Endif
#
#MIPEA - 2016-09-30 - X3PEOP-751 - END

### Enchainement de l'extraction AED
##[L]WFLGAED = 1
##If dim([M:DIA]FLGAED) > 0
##    [L]WFLGAED = [M:DIA]FLGAED
##    [L]WN4DVER = [M:DIA]N4DVER
##    [L]WDNAYEA = [M:DIA]DNAYEA
##    #88314
##    [L]WALLSRV = [M:DIA]ALLSRV
##    [L]WSRV    = [M:DIA]SRV
##    [L]WALLPRF = [M:DIA]ALLPRF
##    [L]WPRF    = [M:DIA]PRF
##    [L]WPOP    = [M:DIA]POP
##Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<>0
 If NBSAL=0
   Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
 Else
  #Opération réalisée
  Call ECR_TRACE(mess(3,10705,1),0) From GESECRAN
 Endif
Else
 #Opération interrompue : Erreur lors de la transaction.
 Call ECR_TRACE(mess(4,10705,1),0) From GESECRAN
Endif
Unlock =SYMBOLE

Call FERME_TRACE From LECFIC
Return

#############################################
$TR1
NBSAL=0
GOK=1
Trbegin [HRATS]
Gosub RECUP_RUBRIQUE
For [FCY]FCY0 Where evalue(CRITFCY)
 #JOJAC - 2016-09-30 - X3PEOP-751 - START
 #Read [SIT]HRSIT0=[F:FCY]FCY
 Read [FCY]FCY0=[F:FCY]FCY
 #JOJAC - 2016-09-30 - X3PEOP-751 - END
 If !fstat
  #88314
  #For [HRCTR]CTR1 Where  ETRFCY=[F:FCY]FCY  & evalue(CRITEMP) & evalue(CRITEMP2)
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#  For [LNK] Where ETRFCY=[F:FCY]FCY & evalue(CRITEMP) & evalue(CRITEMP2) & evalue(CRITEMP3)
  For [LNK] Where ETRFCY=[F:FCY]FCY & evalue(CRITEMP) & evalue(CRITEMP2+CRITEMP2_1+CRITEMP2_2) & evalue(CRITEMP3)
   If [F:HRCTR]XITDAT=[0/0/0]
    If [M:DIA]EXOCOD=[F:HRCTR]EXOCOD1 & [F:HRCTR]EXOSTR1>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR1<=[M:DIA]DATXITEND
      [L]USEXITDAT=nday$(nday([F:HRCTR]EXOSTR1)-1)
    Elsif [M:DIA]EXOCOD=[F:HRCTR]EXOCOD2 & [F:HRCTR]EXOSTR2>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR2<=[M:DIA]DATXITEND
      [L]USEXITDAT=nday$(nday([F:HRCTR]EXOSTR2)-1)
    Elsif [M:DIA]EXOCOD=[F:HRCTR]EXOCOD3 & [F:HRCTR]EXOSTR3>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR3<=[M:DIA]DATXITEND
      [L]USEXITDAT=nday$(nday([F:HRCTR]EXOSTR3)-1)
    Elsif [M:DIA]EXOCOD=[F:HRCTR]EXOCOD4 & [F:HRCTR]EXOSTR4>=[M:DIA]DATXITSTR & [F:HRCTR]EXOSTR4<=[M:DIA]DATXITEND
      [L]USEXITDAT=nday$(nday([F:HRCTR]EXOSTR4)-1)
    Endif
   Else
    [L]USEXITDAT=[F:HRCTR]XITDAT
   Endif
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
   Read[F:ID]ID0=[F:HRCTR]REFNUM
   If !fstat
    OK = 1
    If [F:ID]CODACS<>"" & GUSRACS<>2
     Read[F:ACC]CODACC= GUSER;[F:ID]CODACS
     If fstat or [F:ACC]EXEC<>2
      OK = 0
     Endif
    Endif
   Else
    OK=0
   Endif
   If OK
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#    Readlock [ATS]ATS0=[F:HRCTR]REFNUM;[F:HRCTR]XITDAT;[F:HRCTR]CTRNUM
    Readlock [HRATS]ATS0=[F:HRCTR]REFNUM;[L]USEXITDAT;[F:HRCTR]CTRNUM
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
    If fstat=0
     If [M:DIA]ENAFLG=2     #Oui: MAJ attestation existante
      FLAG=1
      Gosub RECUP_INFOS
     Endif
    Elsif fstat=5
     FLAG=0
     Gosub RECUP_INFOS
    Else
     #"Erreur de lecture sur le fichier :"
     Call ECR_TRACE(mess(4,10707,1)-"TASSEDIC",0) From GESECRAN
     GOK = 0 : Break 2
    Endif
   Endif
  Next
 Endif
Next
Commit
