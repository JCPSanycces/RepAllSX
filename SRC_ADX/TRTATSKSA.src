##&                      [M:DIA]ALLFCY, [M:DIA]FCY, [M:DIA]ALLSRV, [M:DIA]SRV, [M:DIA]ALLPRF, [M:DIA]PRF, 3, [M:DIA]MATDEB, [M:DIA]MATFIN,
##&                      [M:DIA]POP, 2, "", 0, "", "", [M:DIA]ERASE, 2, 1, 2, 1,0,0) From TRTDSNTR :#105476 - US3540
##Endif
Return

$RECUP_RUBRIQUE
NBRUBSAL=0
NBRUBHRT=0
NBRUBASS=0
NBRUBPRV=0
NBRUBCP=0
NBRUBALC=0
NBINDEM=0
NBM12SAL=0
NBM12HRT=0
NBM12ASS=0
#
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Filter [F:RUB] Where LEG=GCURLEG
#MIPEA - 2016-09-30 - X3PEOP-751 - END
####TYPRUB=5 then it is a Plate
For [F:RUB]RUB0 Where [F:RUB]ATTASS<>""
 #THRAM - 2018-02-01 - X3-73514 - START
 #Case [F:RUB]ATTASS
 Case mid$([F:RUB]ATTASS,3,len([F:RUB]ATTASS)-2)#THRAM - 2018-02-01 - X3-73514 - END
  When "SAL"   : NBRUBSAL+=1 : RUBSAL(NBRUBSAL)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPSAL(NBRUBSAL)=3 : Else : TYPSAL(NBRUBSAL)=1 : Endif
  When "HRT"   : NBRUBHRT+=1 : RUBHRT(NBRUBHRT)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPHRT(NBRUBHRT)=3 : Else : TYPHRT(NBRUBHRT)=1 : Endif
  When "ASS"   : NBRUBASS+=1 : RUBASS(NBRUBASS)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPASS(NBRUBASS)=3 : Else : TYPASS(NBRUBASS)=1 : Endif
  When "PRV"   : NBRUBPRV+=1 : RUBPRV(NBRUBPRV)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPPRV(NBRUBPRV)=3 : Else : TYPPRV(NBRUBPRV)=1 : Endif
  When "CP"    : NBRUBCP+=1 : RUBCP(NBRUBCP)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPCP(NBRUBCP)=3 : Else : TYPCP(NBRUBCP)=1 : Endif
  When Default : NBRUBALC+=1 : RUBALC(NBRUBALC)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPALC(NBRUBALC)=3 : Else : TYPALC(NBRUBALC)=1 : Endif
 Endcase
Next
For [F:RUB]RUB0 Where BNSALC<>""
 NBINDEM+=1 : INDEMN(NBINDEM)=[F:RUB]COD
Next
For [F:RUB]RUB0 Where [F:RUB]ATTASS<>""
 #THRAM - 2018-02-01 - X3-73514 - START
 #Case [F:RUB]ATTASS
 Case mid$([F:RUB]ATTASS,3,len([F:RUB]ATTASS)-2)#THRAM - 2018-02-01 - X3-73514 - END
  When "SAL"   : NBM12SAL+=1 : M12SAL(NBM12SAL)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12SAL(NBM12SAL)=3 : Else : TYPM12SAL(NBM12SAL)=1 : Endif
  When "HRT"   : NBM12HRT+=1 : M12HRT(NBM12HRT)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12HRT(NBM12HRT)=3 : Else : TYPM12HRT(NBM12HRT)=1 : Endif
  When "ASS"   : NBM12ASS+=1 : M12ASS(NBM12ASS)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12ASS(NBM12ASS)=3 : Else : TYPM12ASS(NBM12ASS)=1 : Endif
 Endcase
Next

#MIPEA - 2016-09-30 - X3PEOP-751 - START
Filter [F:RUB]
#MIPEA - 2016-09-30 - X3PEOP-751 - END

Return

#############################################
$RECUP_INFOS
Raz [F:HRATS]
Gosub INFOS_EMP
Gosub INFOS_FCY
If [F:HRATS]FCYHRSWEK<>[F:HRATS]EMPHRSWEK & [F:HRATS]FCYHRSWEK<>0 & [F:HRATS]EMPHRSWEK<>0 & [F:HRCTR]TYPJOB=2
 [F:HRATS]GRDHRSWEK=2
Endif
#Search the last number assigned for the head office
Filter [F:HRATS2] Where FCYSGE=[F:HRATS]FCYSGE & REFNUM<>[F:HRATS]REFNUM & XITDAT<>[F:HRATS]XITDAT & CTRNUM<>[F:HRATS]CTRNUM
Read [F:HRATS2]ATS0 Last
Filter [F:HRATS2]
If !fstat
 [F:HRATS]NUMORD= [F:HRATS2]NUMORD+1
Else
 [F:HRATS]NUMORD=1
Endif
Gosub AFFECTE_DIVERS
GOK=1
GPOINT = "MAJATS" : Gosub ENTREE From EXEFNC
If GOK
    If FLAG=0
        If dim([F:HRATS]CREDAT)>0 : [F:HRATS]CREDAT = date$ : Endif
        If dim([F:HRATS]CREUSR)>0 : [F:HRATS]CREUSR = GUSER : Endif
        If dim([F:HRATS]CRETIM)>0 : [F:HRATS]CRETIM = time  : Endif
        Write [F:HRATS]
        If fstat<>0
#MIPEA - 2017-01-19 - X3PEOP-751 - START
            GOK = 0 : Call FSTA("HRATS") From GLOCK : Return
#            GOK = 0 : Call FSTA("ATS") From GLOCK : Return
#MIPEA - 2017-01-19 - X3PEOP-751 - END
        Endif
    Else
        If dim([F:HRATS]UPDDAT)>0 : [F:HRATS]UPDDAT = date$ : Endif
        If dim([F:HRATS]UPDUSR)>0 : [F:HRATS]UPDUSR = GUSER : Endif
        If dim([F:HRATS]UPDTIM)>0 : [F:HRATS]UPDTIM = time  : Endif
        Rewrite [F:HRATS]
        If fstat<>0
#MIPEA - 2017-01-19 - X3PEOP-751 - START
            GOK = 0 : Call FSTA("HRATS") From GLOCK : Return
#            GOK = 0 : Call FSTA("ATS") From GLOCK : Return
#MIPEA - 2017-01-19 - X3PEOP-751 - END
        Endif
    Endif

##    # Enchainement de l'extraction AED
##    If [L]WFLGAED = 2
##        [L]ENDDAT_AED = eomonth([F:HRATS]XITDAT)
##        [L]STRDAT_AED = gdat$(1, month([L]ENDDAT_AED), year([L]ENDDAT_AED))
##        #88314
##        Call AED_SILENCIEUSE([L]WN4DVER, [L]WDNAYEA, [F:FCY]LEGCPY, "15", [L]STRDAT_AED, [L]ENDDAT_AED, 1,
##&                            [F:HRATS]FCY, [L]WALLSRV, [L]WSRV, [L]WALLPRF, [L]WPRF, 1, [F:HRATS]REFNUM, [L]WPOP, 1,
##&                            [F:HRATS]CTRNUM, "") From TRTDXTR
##    Endif
Endif
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - START
If GOK
  Write [F:HRATSSA]
  If fstat<>0
    GOK = 0 : Call FSTA("HRATSSA") From GLOCK : Return
  Endif
Endif
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - END
Return

#############################################
$INFOS_EMP
#Extracting information for the employee's departure :
Call ECR_TRACE(mess(129,10703,1)-[F:HRCTR]REFNUM,0) From GESECRAN
Gosub DEBPERIO
NBSAL=NBSAL+1
STATUT=1
[F:HRATS]REFNUM = [F:HRCTR]REFNUM
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#[F:HRATS]XITDAT = [F:HRCTR]XITDAT
[F:HRATS]XITDAT = [L]USEXITDAT
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
[F:HRATS]STRDAT = DEBPERIO
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#[F:HRATS]ENDDAT = [F:HRCTR]XITDAT
[F:HRATS]ENDDAT = [L]USEXITDAT
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
[F:HRATS]CTRNUM = [F:HRCTR]CTRNUM
If [F:HRCTR]DATANC<>[0/0/0]
 # Seniority date
 [F:HRATS]STRWRK = [F:HRCTR]DATANC
 # Date of entry into society
Elsif [F:HRCTR]DATCPY<>[0/0/0]
 [F:HRATS]STRWRK = [F:HRCTR]DATCPY
Else
 # Date du dernier job
 [F:HRATS]STRWRK = DEBPERIO
Endif
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#[F:HRATS]ENDWRK = [F:HRCTR]XITDAT
[F:HRATS]ENDWRK = [L]USEXITDAT
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
#JASMI - 2015-10-14 - Req. 108579 - US 3890 - START
#Read[F:ADI]=359;[F:HRCTR]XITGRD
## Nonexistent pattern in the certificate employment center so we met'AUT Other '
#If !fstat & [F:ADI]N1<>2
# [F:HRATS]GRDXIT="AUT"
# Call LECTEXTRA([F:HRATS]GRDXITSPE,"ATABDIV","LNGDES","359",[F:HRCTR]XITGRD) From ATEXTRA
#Else
# [F:HRATS]GRDXIT=[F:HRCTR]XITGRD
#Endif
[F:HRATS]GRDXIT=[F:HRCTR]XITGRD
#JASMI - 2015-10-14 - Req. 108579 - US 3890 - END
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - START
Delete [F:HRATSSA] Where REFNUM=[F:HRATS]REFNUM & XITDAT=[F:HRATS]XITDAT & CTRNUM=[F:HRATS]CTRNUM
If fstat=1
 GOK =-1 : GLOCK = "$HRTASSEDICSA" : Return
Endif
Raz [F:HRATSSA]
[F:HRATSSA]REFNUM=[F:HRCTR]REFNUM
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
#[F:HRATSSA]XITDAT=[F:HRCTR]XITDAT
[F:HRATSSA]XITDAT=[L]USEXITDAT
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
[F:HRATSSA]CTRNUM=[F:HRCTR]CTRNUM
[F:HRATSSA]DATANC=[F:HRCTR]DATANC
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATANC=[0/0/0]
  [F:HRATSSA]ANCPERSRV=0
Else
  [F:HRATSSA]ANCPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATANC))*12
  [F:HRATSSA]ANCPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATANC))+1
Endif
[F:HRATSSA]DATCPY=[F:HRCTR]DATCPY
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATCPY=[0/0/0]
  [F:HRATSSA]CPYPERSRV=0
Else
  [F:HRATSSA]CPYPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATCPY))*12
  [F:HRATSSA]CPYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATCPY))+1
Endif
[F:HRATSSA]DATFCY=[F:HRCTR]DATFCY
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATFCY=[0/0/0]
  [F:HRATSSA]FCYPERSRV=0
Else
  [F:HRATSSA]FCYPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATFCY))*12
  [F:HRATSSA]FCYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATFCY))+1
Endif
#JOJAC - 2016-08-11 - X3PEOP-1000 - START
#If func AFNC.ACTIV("KZA")>0
If func DIVPAYE.IS_KZA(GCURLEG)
#JOJAC - 2016-08-11 - X3PEOP-1000 - END
  If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA [CTRSA] : Endif
  Read [CTRSA]CTRSA0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
  If !fstat
    [F:HRATSSA]UEMCLMSUB=1
    [F:HRATSSA]TOTMONREM=0
    If [CTRSA]UIFSTA=1
      [F:HRATSSA]NONCTBRSN=10
    Else
      Case [CTRSA]UIFSTA
      When 5
        [F:HRATSSA]NONCTBRSN=1
      When 3
        [F:HRATSSA]NONCTBRSN=2
      When 2
        [F:HRATSSA]NONCTBRSN=3
      When 4
        [F:HRATSSA]NONCTBRSN=4
      When Default
        [F:HRATSSA]NONCTBRSN=0
      Endcase
    Endif
    [F:HRATSSA]TERRSN=[HRCTR]XITGRD
  Endif
Endif
#JASMI - 2015-08-11 - Req. 108579 - US 3890 - END

#JASMI - 2015-11-02 - Req. 105483 - START
#JOJAC - 2016-08-11 - X3PEOP-1000 - START
#If func AFNC.ACTIV("KMIEA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
#JOJAC - 2016-08-11 - X3PEOP-1000 - END
  [F:HRATSSA]DNARUPCON=[HRCTR]DNARUPCON
  Read [CTRMID]CTRMID0=[HRCTR]REFNUM;[HRCTR]CTRNUM;[HRCTR]CTRDAT
  If !fstat
    [F:HRATSSA]NTCPAY=[CTRMID]NTCPAY
  Endif
Endif
#JASMI - 2015-11-02 - Req. 105483 - END

[F:HRATS]DATNTF=[F:HRCTR]NTFDAT
[F:HRATS]LSTDAYWRK=[F:HRCTR]LSTDAY
If [F:HRCTR]FLGPRV=2      :#Notice made & paid
 [F:HRATS]FLGPRV=2
 [F:HRATS]STRDATPRV1=[F:HRCTR]STRTIMNTC
 [F:HRATS]ENDDATPRV1=[F:HRCTR]ENDTIMNTC
 [F:HRATS]STRDATPRV2=[F:HRCTR]STRTIMNTC
 [F:HRATS]ENDDATPRV2=[F:HRCTR]ENDTIMNTC
Endif
If [F:HRCTR]FLGPRV2=2      :#Notice not completed & paid
 [F:HRATS]FLGPRVOFF=2
 [F:HRATS]STRDATPRV4=[F:HRCTR]STRNTC2
 [F:HRATS]ENDDATPRV4=[F:HRCTR]ENDNTC2
 [F:HRATS]STRDATPRV2=[F:HRCTR]STRNTC2
 [F:HRATS]ENDDATPRV2=[F:HRCTR]ENDNTC2
Endif
If [F:HRCTR]FLGPRV3=2      :#Notice & not done without pay
 [F:HRATS]FLGPRVOFF=2
 [F:HRATS]STRDATPRV4=[F:HRCTR]STRNTC3
 [F:HRATS]ENDDATPRV4=[F:HRCTR]ENDNTC3
 [F:HRATS]STRDATPRV3=[F:HRCTR]STRNTC3
 [F:HRATS]ENDDATPRV3=[F:HRCTR]ENDNTC3
Endif
[F:HRATS]=[F:ID]
If [F:HRCTR]WRKCTY<>""
 [F:HRATS]LSTPLCWRK=[F:HRCTR]WRKCTY
 If [F:HRCTR]WRKCODPOS<>""
  [F:HRATS]DEPLSTPLC=num$(left$([F:HRCTR]WRKCODPOS,2))
 Endif
Else
 Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
 If !fstat
  [F:HRATS]LSTPLCWRK=[F:BPA]CTY
  [F:HRATS]DEPLSTPLC=num$(left$([F:BPA]POSCOD,2))
 Endif
Endif

#We leave the old code qualif if used by clients
[F:HRATS]QLF=[F:HRCTR]QLF
#Added new code
[F:HRATS]CATQLF=[F:HRCTR]CATQLF
# Recovering the relationship with the V6 fashion!
[F:HRATS]FLGLIKFAM=[F:HRCTR]LNK     :#flag
[F:HRATS]TYPLNK=[F:HRCTR]TYPLNK  :#libellé

If dim([F:HRATS]RGMSPESSC)>=0 & dim([F:HRCTR]SYSFLG)>=0
  [F:HRATS]RGMSPESSC=[F:HRCTR]SYSFLG
Endif

[F:HRATS]STA=[F:HRCTR]STACAT
[F:HRATS]EMPSYSSSC=[F:HRCTR]SYSSSC
[F:HRATS]LSTJOB=[F:HRCTR]JOB
[F:HRATS]EMPQLY=[F:HRCTR]TYPJOB
[F:HRATS]EMPCTR=[F:HRCTR]NATCON
[F:HRATS]EMPHRSWEK=[F:HRCTR]HRSWEK
#JASMI - 2015-10-19 - Requirement 108579 - US 3990 - START
#If [F:HRCTR]RATMIDWRK>0
# [F:HRATS]EMPHRSYEA=val(func AFNC.PARAM("HOUMAXYEA",[F:HRCTR]ETRFCY))*([F:HRCTR]RATMIDWRK/100)
#Else :#100%
# [F:HRATS]EMPHRSYEA=val(func AFNC.PARAM("HOUMAXYEA",[F:HRCTR]ETRFCY))
#Endif
[F:HRATS]EMPHRSYEA=[F:HRCTR]NBRHOUCTR
#JASMI - 2015-10-19 - Requirement 108579 - US 3990 - END
STATUT=[F:HRCTR]STAEMP

If [F:HRATS]LSTDAYWRK<>[0/0/0]
 LASTDAT=[F:HRATS]LSTDAYWRK
Else
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - START
# LASTDAT=[F:HRATS]XITDAT
 LASTDAT=[L]USEXITDAT
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END

 #Last day worked POA
 Call ECR_TRACE(mess(211,10703,1),-1) From GESECRAN
Endif

#US3751 108474 Stagiaire
WISTRAINEE=func DIVPAYE.ISTRAINEE([F:HRCTR]NATCON)
If WISTRAINEE
   [F:HRATS]NBRPERSTG=[F:HRCTR]NBRPER
   [F:HRATS]PERSTG=[F:HRCTR]PERCON
Endif
#END US3751 108474 Stagiaire

Gosub RECUP_IRC
Gosub RECUP_SALAIRES
Gosub RECUP_PRIMES_INDEMNITE
Gosub RECUP_SOLDE_TOUT_COMPTE
Return

#############################################
## Research the date of the employee that matches his departure.
## Indeed, it has been transferred and therefore the contract start date does not match the date of entry
$DEBPERIO
DEBPERIO = [0/0/0]
Filter [F:HRCTR2] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT & XITFNL=2
Read [F:HRCTR2]CTR0 Last
Filter [F:HRCTR2]
If !fstat
 Read [F:HRCTR2]CTR0 Next
 If !fstat
  DEBPERIO=[F:HRCTR2]CTRDAT
 Endif
Endif
If DEBPERIO=[0/0/0]
 Filter [F:HRCTR2] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 Read [F:HRCTR2]CTR0 First
 Filter [F:HRCTR2]
 If !fstat
  DEBPERIO=[F:HRCTR2]CTRDAT
 Else
  DEBPERIO=[F:HRCTR]CTRDAT
 Endif
Endif
Return

