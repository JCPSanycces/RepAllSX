$AFFECTE_DIVERS
[F:HRATS]FLGNSS=1       :#Auto assurance
[F:HRATS]FLGCVT=1       :#Convention de gestion
[F:HRATS]FLGAFR=1       :#Extension AFR
[F:HRATS]FLGVACSPE=1    :#Régime particulier pour les emplois "aidés"
[F:HRATS]FLGRVC=1       :#Titre révocable
[F:HRATS]EMPSTA=1       :#Statut particulier du salarié
[F:HRATS]JOBPUB=1       :#Emploi public
