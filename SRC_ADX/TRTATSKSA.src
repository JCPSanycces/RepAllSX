Local Char CRITEMP2_1 (250), CRITEMP2_2 (250)
#JASMI - 2015-10-08 - Requirement 108579 - US 3990 - END
Local Char CRITSPE (250)                :#89566
Local Integer FLAG
Local Integer INDIC, I, J, NBSAL, K
Local Char VARRCO (10), VAGIRC (10)
