#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque MODCPT
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"MODCPT","MODCPT","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$OUVRE
Local File ACODNUM [ANM] , AVALNUM [AVN] , AVALATT [AVA] , COMPANY [CPY] , FACILITY [FCY]
Local Mask MODCPT [MCP]
Local Char    SIT(20) , CPT(20) , CMP(20)
Local Integer PER
Raz [M:MCP]
Return

$SETBOUT
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 REP = ""
Endif
Return

$TR1
GOK = 1
Trbegin [AVN]
 Readlock [AVN]AVN0 = CPT;SIT;PER;[L]CMP
 If fstat=1
  GOK = -1 : GLOCK = "$AVALNUM"-CPT-SIT-num$(PER)-[L]CMP : Goto ROLL_TR1
 Elsif fstat
  If [M]VAL1>1
   Raz [F:AVN]
   [F:AVN]CODNUM  = CPT
   [F:AVN]SITE    = SIT
   [F:AVN]PERIODE = PER
   [F:AVN]COMP    = [L]CMP
   [F:AVN]VALEUR  = [M]VAL1
   Write [AVN]
   If fstat
    GOK = 0 : Call FSTA("AVN") From GLOCK : Goto AB_TR1
   Endif
  Endif
 Else
  If [M]VAL1=1
   Delete [AVN]
  Else
   [F:AVN]VALEUR = [M]VAL1
   Rewrite [AVN]
   If fstat
    GOK = 0 : Call FSTA("AVN") From GLOCK : Goto AB_TR1
   Endif
  Endif
 Endif
 Delete [AVA] Where CODNUM=CPT & SITE=SIT & PERIODE=PER & COMP=CMP
 If fstat=1
  GOK = -1 : GLOCK = "$AVALATT"-CPT-SIT-num$(PER)-CMP : Goto ROLL_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ABANDON
Gosub LECTURE
REP = ""
Return

$APRES_MODIF
Case COUZON
 When "VAL1"
  REP = "M"
 When Default
  Case evalue("type([M]"+COUZON+")")
   When 1,2,4,5,6,7,8,9 : Assign "[M]"+COUZON With val(CZ)
   When Default         : Assign "[M]"+COUZON With CZ
  Endcase
  Gosub LECTURE
Endcase
Return

$LECTURE
OK = 1
Case [F:ANM]NIVRAZ
 When 1
  PER = 0
 When 2
  If [M]YEA=0
   OK = 0
  Else
   PER = mod([M]YEA,100)
  Endif
 When 3
  If [M]YEA=0 or [M]MON=0
   OK = 0
  Else
   PER = 100*mod([M]YEA,100)+[M]MON
  Endif
 When 4
  If [M]EXE=0
   OK = 0
  Else
   PER = [M]EXE
  Endif
 When 5 :#115647
  If [M]EXE=0 | [M]MON=0
   OK = 0
  Else
   PER = 100*[M]EXE+[M]MON
  Endif
Endcase
Case [F:ANM]NIVDEF
 When 1
  SIT = ""
 When 2
  If [M]CPY=""
   OK = 0
  Else
   SIT = [M]CPY
  Endif
 When 3
  If [M]FCY=""
   OK = 0
  Else
   SIT = [M]FCY
  Endif
Endcase
CPT = [M]ANM
[L]CMP = [M]CMP
If !OK
 REP = ""
 Grizo VAL1
Else
 Actzo VAL1
 Read [AVN]AVN0 = CPT;SIT;PER;[L]CMP
 If fstat
  [M]VAL1 = 1
 Else
  [M]VAL1 = [F:AVN]VALEUR
 Endif
 Affzo VAL1
 REP = ""
Endif
Return



########################################
Subprog C_ANM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ANM",VALEUR,"") From CONTOBJ
If [F:ANM]SEQ=2 : # Type de séquence BDD
 # Pas de valeur de compteur pour une numérotation de type séquence BDD
 Call ERREUR(mess(171,139,1)) From GESECRAN
 mkstat = 1 : End
Endif
Case [F:ANM]NIVDEF
 When 1
  [M]CPY = "" : [M]FCY = ""
  Grizo CPY,ZCPY,FCY,ZFCY
 When 2
  [M]FCY = ""
  Grizo FCY,ZFCY : Actzo CPY,ZCPY
 When 3
  [M]CPY = ""
  Grizo CPY,ZCPY : Actzo FCY,ZFCY
Endcase
Affzo CPY, FCY
Case [F:ANM]NIVRAZ
 When 1
  [M]YEA = 0 : [M]MON = 0 : [M]EXE = 0
  Grizo YEA,MON,EXE
 When 2
  [M]MON = 0 : [M]EXE = 0
  Grizo MON,EXE : Actzo YEA
 When 3
  [M]EXE = 0
  Grizo EXE  : Actzo MON : Actzo YEA
 When 4
  [M]MON = 0 : [M]YEA = 0
  Actzo EXE : Grizo MON,YEA
Endcase
Affzo YEA, MON, EXE
If find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1)) or (GPRODUIT=1 & [F:ANM]SEQDEP=2)
 Actzo CMP
Else
 [M]CMP = ""
 Grizo CMP
Endif
Affzo CMP
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1900 or VALEUR>2999 : mkstat = 1 : End : Endif
End

Subprog C_MON(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>12 : mkstat = 1 : End : Endif
End

Subprog C_VAL1(VALEUR)
Variable Decimal VALEUR
Local Integer K
If VALEUR<1 : mkstat = 1 : End : Endif
Call LECTURE("ANM",[M]ANM,"") From CONTOBJ
K = find(8,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
If K
 VALEUR = mod(VALEUR,10^[F:ANM]POSLNG(K-1))
Endif
End

