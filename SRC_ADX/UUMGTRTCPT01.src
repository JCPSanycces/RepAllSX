#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT01                                      Module  Accounting   #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Journal Entry                                            #
#            GACCENTRY/GACCENTRYD/GACCENTRYA                             #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   GACCENTRY : CPY;TYP;NUM                                              #
#   GACCENTRYD : CPY;TYP;NUM;LIG                                         #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   GACCENTRY : TYP;NUM                                                  #
#   GACCENTRYD : TYP;NUM;LIG                                             #
#   GACCENTRYA : TYP;NUM;LIG;ANALIG                                      #
#                                                                        #
# Issue X3-52049 - 2017-08-21 by BEFOU : adding of ORIGIN Field          #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT01") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT01(DOSSIER)
  Call MAJ_UUMGTRTCPT01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTCPT01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMHAEM,WNAMDAEM,WNAMDAAM,WNAMHIAM
Call MIGTABNAME (DOSSIER,"GACCENTRY",WNAMHAEM,ERR) From TRTMIG  : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GACCENTRYD",WNAMDAEM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GACCENTRYA",WNAMDAAM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GACEIAS",WNAMHIAM,ERR) From TRTMIG    : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMHAEM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMDAEM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMDAAM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"GACCENTRY",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GACCENTRYD",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"GACCENTRYA",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT01",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT01(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMHAEM,WNAMDAEM,WNAMDAAM,WNAMHIAM
Call MIGTABNAME (DOSSIER,"GACCENTRY",WNAMHAEM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GACCENTRYD",WNAMDAEM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GACCENTRYA",WNAMDAAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GACEIAS",WNAMHIAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMHAEM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMDAEM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMDAAM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTCPT01 - Journal Entry Process : Update GACCENTRY/GACCENTRYD/GACCENTRYA") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT01 : Process Start on : "+DOSSIER,0) From GESECRAN

#-----  Control of ACCNUM Sequence  -----#
Call ACCNUM_SEQ(DOSSIER)

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCENTRY",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCENTRYD",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCENTRYA",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:HAE]) = 0 :  Local File =DOSSIER+".GACCENTRY"    [HAE]   : Endif    # Acccounting Journal Entry
If clalev([F:DAE]) = 0 :  Local File =DOSSIER+".GACCENTRYD"   [DAE]   : Endif    # General Acccounting Line
If clalev([F:DAA]) = 0 :  Local File =DOSSIER+".GACCENTRYA"   [DAA]   : Endif    # Analytical Acccounting Line

# X3 Renamed File
If clalev([F:HAEM]) = 0 :  Local File =DOSSIER+"."+WNAMHAEM   [HAEM]  : Endif    # Acccounting Journal Entry
If clalev([F:DAEM]) = 0 :  Local File =DOSSIER+"."+WNAMDAEM   [DAEM]  : Endif    # General Acccounting Line
If clalev([F:DAAM]) = 0 :  Local File =DOSSIER+"."+WNAMDAAM   [DAAM]  : Endif    # Analytical Acccounting Line

# Fichier X3 - IAS
If filinfo(filpath("FIL",WNAMHIAM,"fde",DOSSIER),0)>=0
 If clalev([F:HIAM]) = 0 :  Local File =DOSSIER+"."+WNAMHIAM   [HIAM]  : Endif    # IAS Accounting Journal Line
Endif

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_HAE (100) (adxwrb)
Local Char WTAB_DAE (100) (adxwrb)
Local Char WTAB_DAA (100) (adxwrb)
Local Shortint WCPT_HAE,WCPT_DAE,WCPT_DAA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Variables linked to the migration process
Local Integer ACCNUM_GEN, ACCNUM_ANA, ACCNUM_IAS  # Saving of Uniqid
Local Integer ACCNUM_DAA, ACCNUM_DAA_AUT
Local Integer FLGPOR, CPYPOR : [L]FLGPOR=0

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(4))

#-----  Link of Head Table & Line Table (except Analytic, including in For)
#-----  We don't have the line number in the key !
Link [DAEM] With [HAEM]HAE0~=[F:DAEM]TYP;[F:DAEM]NUM
&    As [LNK]
&    Order By Key CLE = [F:HAEM]CPY;[F:HAEM]TYP;[F:HAEM]NUM

# EP to add a criteria in the "where"
FLUX="UUMGTRTCPT01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT01
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:HAEM]CPY='"+TABMIGKEY(1)+"' & [F:HAEM]TYP='"+TABMIGKEY(2)+"' & [F:HAEM]NUM>'"+TABMIGKEY(3)+"'"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:HAEM]CPY='"+TABMIGKEY(1)+"' & [F:HAEM]TYP>'"+TABMIGKEY(2)+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:HAEM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [HAE],[DAE],[DAA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:HAEM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 If [F:CPY]CRY="PT"
  [L]CPYPOR=1
  If ![L]FLGPOR : Gosub INI_ADI389 : Endif
 Else
  [L]CPYPOR=0
 Endif

 For [LNK]CLE(3)

  If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP | [F:HAEM]ANA<>2 #Single-Ledger
   NBLUS+=1

   # EP to delete line
   If FILTRELIN
    FLUX="UUMGTRTCPT01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
   Endif

   # To Update GACCENTRY table - Header of Journal Entry
   Gosub MAJ30_HAE
   If GOK<1 : Break 2 : Endif

   For [LNK]CLE

    # To Update GACCENTRYD table - Generals Lines of Journal Entry
    Gosub MAJ30_DAE
    If !GOK : Break 3 : Endif

    # To Update GACCENTRYA tables - Analyticals Lines of Journal Entry
    Gosub MAJ30_DAA
    If !GOK : Break 3 : Endif

   Next

   NB+=1
   If NB>GMAXUPDTRS
    TABMIGKEY(1)= [F:HAEM]CPY
    TABMIGKEY(2)= [F:HAEM]TYP
    TABMIGKEY(3)= [F:HAEM]NUM
    STOP=1
    Break 2
   Endif
  Endif
  $SUITE_BOUCLE
  Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT01",7,ERR) From TRTMIG
Else
 Flush [F:HAE]
 If fstat
  Call ECR_TRACE("File GACCENTRY, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub HAE_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:DAE]
 If fstat
  Call ECR_TRACE("File GACCENTRYD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub DAE_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:DAA]
 If fstat
  Call ECR_TRACE("File GACCENTRYA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub DAA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(4)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT01",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT01
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [DAE], [DAA]
Close Local File [HAEM], [DAEM], [DAAM]
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"GACCENTRY",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GACCENTRYD",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GACCENTRYA",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT01") From TRTMIG
Call ECR_TIME("UUMGTRTCPT01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


$MAJ30_HAE
#--- Transclass
#Raz [HAE]  # expensive... must RAZ new V6 fields
[HAE] = [HAEM]

#--- New fields's assignation
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:HAE]LED(IREF-1)    = [F:GCM]LED(IREF-1)
  [F:HAE]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
  [F:HAE]RATDIV(IREF-1) = 1
  If IREF<3
   [F:HAE]RATMLT(IREF-1) = [F:HAEM]RATCUR
  Else
   [F:HAE]RATMLT(IREF-1) = [F:HAEM]RATRPT
  Endif
 Else # useful to delete intruction RAZ
  [F:HAE]LED(IREF-1)    = ""
  [F:HAE]CURLED(IREF-1) = ""
  [F:HAE]RATDIV(IREF-1) = 0
  [F:HAE]RATMLT(IREF-1) = 0
 Endif
Next
# Issue X3-52049 - 2017-08-21 by BEFOU : adding of ORIGIN Field
# [F:HAE]ORIGIN = [F:HAEM]FLGGEN
Gosub WRI_HAE
Return


$MAJ30_DAE
#--- Transclass
#Raz [HAE]  # expensive... must RAZ new V6 fields
[F:DAE] = [F:DAEM]

#--- New fields's assignation
# Renamed field
[F:DAE]LIN    = [F:DAEM]LIG

# News fields
[F:DAE]IDTLIN = num$([F:DAE]LIN)  # Journal Entry transaction are "Colum" entry type
[F:DAE]FIY    = [F:HAE]FIY
[F:DAE]PER    = [F:HAE]PER

If [L]CPYPOR & [L]FLGPOR=1 & [F:DAE]STT1<>""
 If find([F:DAE]STT1,[L]VAL389(1..[L]NBRVAL389))
  [F:DAE]CAPFLOTYP = [F:DAE]STT1
  [F:DAE]STT1 = ""
 Endif
Endif

# Writing on chart of Account of Legal Ledger  (V5 if not analytic GL record)
If [F:HAEM]ANA<>2
 [F:DAE]LEDTYP    = [L]TYPGEN
 [F:DAE]LED       = [L]LEDGEN
 [F:DAE]COA       = [L]COAGEN
 [F:DAE]CURLED    = [F:HAE]CURLED([F:DAE]LEDTYP-1)
 [F:DAE]AMTLED    = [F:DAEM]AMTLOC
 [F:DAE]AMTFLG    = [F:DAEM]AMTLOCFLG
 [F:DAE]AMTLED1   = [F:DAEM]AMTLOC1
 [F:DAE]ACCNUMORI = 0
 [L]ACCNUM_GEN    = [F:DAE]ACCNUM
 [L]ACCNUM_DAA    = [F:DAE]ACCNUM
 Gosub WRI_DAE
 If GOK<1 : Return : Endif

  # Management of Automatic ledgers at the same time (recovering of ACCNUM + the forced amount...)
 If [L]TYPAUTGEN
  [F:DAE]LEDTYP  = [L]TYPAUTGEN
  [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
  [F:DAE]AMTLED  = [F:DAEM]AMTRPT
  [F:DAE]AMTFLG  = [F:DAEM]AMTRPTFLG
  [F:DAE]AMTLED1 = [F:DAEM]AMTRPT1
  Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)  # It must initialize a new ACCNUM
  [F:DAE]ACCNUMORI  = [L]ACCNUM_GEN
  [L]ACCNUM_DAA_AUT = [F:DAE]ACCNUM
  Gosub WRI_DAE
  If GOK<1 : Return : Endif
 Endif
Endif

# Writing on chart of Account of Analytical Ledger
If LEDANA<>"" & [F:DAEM]CNA<>"" & [L]TYPGEN<>[L]TYPANA
 [F:DAE]LEDTYP  = [L]TYPANA
 [F:DAE]LED     = [L]LEDANA
 [F:DAE]COA     = [L]COAANA
 [F:DAE]ACC     = [F:DAEM]CNA
 [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
 [F:DAE]AMTLED  = [F:DAEM]AMTLOC
 [F:DAE]AMTFLG  = [F:DAEM]AMTLOCFLG
 [F:DAE]AMTLED1 = [F:DAEM]AMTLOC1
 Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)   # It must initialize a new ACCNUM
 [F:DAE]ACCNUMORI = 0
 [L]ACCNUM_ANA  = [F:DAE]ACCNUM
 [L]ACCNUM_DAA  = [F:DAE]ACCNUM
 Gosub WRI_DAE
 If GOK<1 : Return : Endif

 # Management of Automatic ledgers at the same time (recovering of ACCNUM + the forced amount...)
 If [L]TYPAUTANA
  [F:DAE]LEDTYP  = [L]TYPAUTANA
  [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
  [F:DAE]AMTLED  = [F:DAEM]AMTRPT
  [F:DAE]AMTFLG  = [F:DAEM]AMTRPTFLG
  [F:DAE]AMTLED1 = [F:DAEM]AMTRPT1
  Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)    # It must initialize a new ACCNUM
  [F:DAE]ACCNUMORI  = [L]ACCNUM_ANA
  [L]ACCNUM_DAA_AUT = [F:DAE]ACCNUM
  Gosub WRI_DAE
  If GOK<1 : Return : Endif
 Endif
Endif

#------------
# Second party  - IAS
#------------
# Writing on chart of Account of IAS Ledger
If LEDIAS<>"" & clalev([F:HIAM])
 Read [HIAM]HIA0 = [F:DAEM]TYP;[F:DAEM]NUM
 If !fstat & [F:HIAM]FLG = 2
  [F:DAE]LEDTYP  = [L]TYPIAS
  [F:DAE]LED     = [L]LEDIAS
  [F:DAE]COA     = [L]COAIAS
  [F:DAE]ACC     = [F:DAEM]ACC
  [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
  [F:DAE]AMTLED  = [F:DAEM]AMTLOC
  [F:DAE]AMTFLG  = [F:DAEM]AMTLOCFLG
  [F:DAE]AMTLED1 = [F:DAEM]AMTLOC1
  Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)   # It must initialize a new ACCNUM
  [F:DAE]ACCNUMORI = 0
  [L]ACCNUM_IAS = [F:DAE]ACCNUM
  Gosub WRI_DAE
  If GOK<1 : Return : Endif

  If [F:DAEM]SCT1<>"" or [F:DAEM]SCT2<>""
   # To Save on DAE
   Raz [DAA]   # We keep RAZ (Analytic & IAS : 24 fiels on DAA)
   # Transclass... Initialization relative to DAE
   [DAA] = [DAE]
   [F:DAA]ANALIN+=1
   [F:DAA]DIE(0) = [L]AXEI(1)
   [F:DAA]CCE(0) = [F:DAEM]SCT1
   [F:DAA]DIE(1) = [L]AXEI(2)
   [F:DAA]CCE(1) = [F:DAEM]SCT2
   [F:DAA]AMTLED = [F:DAEM]AMTLOC
   Gosub WRI_DAA
   If GOK<1 : Return : Endif

   # Management of Automatic ledgers at the same time (recovering of the forced amount...)
   If [L]TYPAUTIAS
    [F:DAA]LEDTYP = [L]TYPAUTIAS
    [F:DAA]CURLED = [F:HAE]CURLED([F:DAA]LEDTYP-1)
    [F:DAA]AMTLED = [F:DAEM]AMTRPT
    Gosub WRI_DAA
    If GOK<1 : Return : Endif

    # Management of Automatic ledgers at the same time (recovering of ACCNUM + the forced amount...)
    [F:DAE]LEDTYP = [L]TYPAUTIAS
    [F:DAE]CURLED = [F:HAE]CURLED([F:DAE]LEDTYP-1)
    [F:DAE]AMTLED = [F:DAEM]AMTRPT
    [F:DAE]AMTFLG = [F:DAEM]AMTRPTFLG
    [F:DAE]AMTLED1= [F:DAEM]AMTRPT1
    Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM) # It must initialize a new ACCNUM
    [F:DAE]ACCNUMORI = [L]ACCNUM_IAS
    Gosub WRI_DAE
    If GOK<1 : Return : Endif

   Endif
  Endif
 Endif
Endif
Return

Subprog ACCNUM_DAE(DOS,NUM)
Value Char DOS()
Variable Integer NUM
Local File =[L]DOS+".GACCENTRYD" [DAE]
NUM = uniqid([F:DAE])
End

Subprog ACCNUM_SEQ(DOS)
Value Char DOS()
Local Integer ERR, MAX1, MAX2, MAX3

Call ECR_TIME("UUMGTRTCPT01 - ACCNUM sequence - Process Start on :"+DOS) From DOSSUB

Call MIGGETTOTNBR (DOS,"GACCENTRYD_ACCNUM",MAX2,ERR) From TRTMIG
If clalev([F:DAE]) : Close File [DAE] : Endif
Local File =[L]DOS+".GACCENTRYD" [DAE]
MAX1 = uniqid([DAE])
Read [DAE]DAE2 Last
MAX3 = [F:DAE]ACCNUM
While  MAX1 < MAX2 | MAX1 < MAX3
 MAX1=uniqid([DAE])
Wend

Call ECR_TIME("UUMGTRTCPT01 - ACCNUM sequence - Process End on :"+DOS) From DOSSUB
End


$MAJ30_DAA
#--- Reading of the Analytics Lines
For [DAAM]DAA0 Where TYP=[F:DAEM]TYP & NUM=[F:DAEM]NUM & LIG=[F:DAEM]LIG

 #--- Transclass
 #Raz [F:DAA]   # expensive... must RAZ new V6 fields
 # Transclass... Initialization relative to DAA
 [F:DAA] = [F:DAAM]

 #--- New fields's assignation
 # Renamed field

 [F:DAA]LIN    = [F:DAAM]LIG
 [F:DAA]ANALIN = [F:DAAM]ANALIG

 # Field linked to DAE Fields
 [F:DAA]SNS = [F:DAE]SNS
 [F:DAA]CUR = [F:DAE]CUR

 # News Fields
 [F:DAA]LEDTYP = [L]TYPANA
 [F:DAA]IDTLIN = num$([F:DAAM]LIG)  # Journal Entry transaction are "Colum" entry type
 [F:DAA]LED    = [F:GCM]LED([L]TYPANA-1)
 [F:DAA]CURLED = [F:GCM]CUR([L]TYPANA-1)
 [F:DAA]COA    = [L]COAANA
 [F:DAA]ACC    = [F:DAAM]CNA
 If [L]COAANA=[L]COAGEN
  [F:DAA]ACC    = [F:DAE]ACC
  [F:DAA]BPR    = [F:DAE]BPR
 Endif
 [F:DAA]AMTLED = [F:DAAM]AMTLOC
 For AXE=1 To dim([F:DAA]DIE)
  If AXE<=[L]NBRAXE
   [F:DAA]DIE(AXE-1) = [L]AXEA(AXE)
   [F:DAA]CCE(AXE-1) = [F:DAAM]CCE(AXE-1)
  Else # useful to delete intruction RAZ
   [F:DAA]DIE(AXE-1) = ""
   [F:DAA]CCE(AXE-1) = ""
  Endif
 Next
 [F:DAA]ACCNUM = [L]ACCNUM_DAA
 Gosub WRI_DAA
 If GOK<1 : Break : Endif

 # Management of Automatic ledgers at the same time (recovering of the forced amount...)
 If [L]TYPAUTANA
  [F:DAA]LEDTYP = [L]TYPAUTANA
  [F:DAA]CURLED = [F:GCM]CUR([L]TYPAUTANA-1)
  [F:DAA]AMTLED = [F:DAAM]AMTRPT
  [F:DAA]ACCNUM = [L]ACCNUM_DAA_AUT
  Gosub WRI_DAA
  If GOK<1 : Break : Endif
 Endif
Next
Return


# Write Instruction
$WRI_HAE
# To Save reference
Gosub HAE_STK
WriteB [F:HAE]
If fstat
 Call ECR_TRACE("File GACCENTRY, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub HAE_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_DAE
# To Save reference
Gosub DAE_STK
WriteB [F:DAE]
If fstat
 Call ECR_TRACE("File GACCENTRYD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub DAE_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_DAA
# To Save reference
Gosub DAA_STK
WriteB [F:DAA]
If fstat
 Call ECR_TRACE("File GACCENTRYA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub DAA_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$HAE_STK
Call STK (WTAB_HAE,WCPT_HAE,[F:HAE]TYP-'/'-[F:HAE]NUM) From TRTMIG
Return
$DAE_STK
Call STK (WTAB_DAE,WCPT_DAE,[F:DAE]TYP-'/'-[F:DAE]NUM-'/'-num$([F:DAE]LIN)-'/'-num$([F:DAE]LEDTYP)) From TRTMIG
Return
$DAA_STK
Call STK (WTAB_DAA,WCPT_DAA,[F:DAA]TYP-'/'-[F:DAA]NUM-'/'-num$([F:DAA]LIN)-'/'-num$([F:DAA]LEDTYP)-'/'-num$([F:DAA]ANALIN)) From TRTMIG
Return

##############################################################################################
$HAE_ERRTRA
Call ERRTRA (WTAB_HAE,WCPT_HAE,"File GACCENTRY(TYP/NUM)=") From TRTMIG
Return
$DAE_ERRTRA
Call ERRTRA (WTAB_DAE,WCPT_DAE,"File GACCENTRYD(TYP/NUM/LIN/LEDTYP)=") From TRTMIG
Return
$DAA_ERRTRA
Call ERRTRA (WTAB_DAA,WCPT_DAA,"File GACCENTRYA(TYP/NUM/LIN/LEDTYP/ANALIN)=") From TRTMIG
Return

##############################################################################################
$INI_ADI389
If clalev([F:ADI]) = 0 :  Local File =DOSSIER+".ATABDIV"  [ADI]  : Endif     # Miscellaneous tables
Local Integer NBRVAL389

Filter [ADI] Where NUMTAB=389
NBRVAL389 = rowcount([F:ADI])
If NBRVAL389
 Local Char VAL389(GLONADI)(1..NBRVAL389)
 FLGPOR=1
Else
 FLGPOR=-1 : Return
Endif

NBRVAL389 = 0
For [ADI]
 If !find([F:ADI]CODE,[L]VAL389)
  [L]NBRVAL389 += 1
  [L]VAL389(NBRVAL389) = [F:ADI]CODE
 Endif
Next
Filter [ADI]
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT01(APPLI)
End

