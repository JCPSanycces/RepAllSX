#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque OBI1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone LVL
mkstat = 0
zoncou = "LVL"
indice = 0
IMPENT = [M]LVL
WNUM = IMPENT
If varinit([M]LVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]LVL,indice)=0
 [M]LVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LVL(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LVL" : GZNUM = 5230 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_LVL(IMPENT) From SUBOBI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LVL" : GZNUM = 5230 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]LVL = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone CPY
mkstat = 0
zoncou = "CPY"
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY(indice)) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","",[M]CPY(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FCY(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]FCY(indice)) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","",[M]FCY(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SRV
mkstat = 0
zoncou = "SRV"
If varmode([M]SRV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRV" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SRV(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("SRV","",[M]SRV(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LIEN
mkstat = 0
zoncou = "LIEN"
SAVACT = GACTION : GACTION = "STD"
Call AV_LIEN([M]LIEN(indice)) From SUBOBI
GACTION = SAVACT
If mkstat=1 : Raz [M]LIEN(indice) : Endif

## Zone CRI
mkstat = 0
zoncou = "CRI"
If varinit([M]CRI,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CRI(indice),"10582","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CRI,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CRI" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]CRI(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]CRI(indice),"10582","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]CRI(indice),"10582",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_CRI([M]CRI(indice)) From SUBOBI
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone OBJ
mkstat = 0
zoncou = "OBJ"
If varmode([M]OBJ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OBJ" : Gosub ACTION From =IMPTRT
 Endif
 If [M]OBJ(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OBJ" : GZNUM = 14435 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SNS
mkstat = 0
zoncou = "SNS"
IMPENT = [M]SNS(indice)
If varinit([M]SNS,indice)=0
 IMPENT = 1
Endif
If varmode([M]SNS,indice)=0
 [M]SNS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SNS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SNS(indice)
 Endif
Endif
[M]SNS(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "OBI1"
Return

