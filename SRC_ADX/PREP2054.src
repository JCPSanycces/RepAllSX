#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################################
# Programme : PREP2054
#
# Fonction  :
#      1- Maj de la table TMP2054  pour l'état FAS2054
# Création     :  15/04/2013    (FQ-89160)
# Modification :
# Issue X3-68907 - 2018-01-12 by MDJ : mess=60,7784 replaced by mess=106,7784 (NEW)
# MDJ   02.02.2015 FQ105523   : Prise en compte des immobilisations financières (classe 4)
# MDJ   27.11.2013 FQ92637    : 	Etat sur périodes cumulées
#########################################################################################
$ACTION

    Case ACTION
       When "OUVRE" :   Gosub OUVRE
       When "FIN"   :   Gosub FIN
    Endcase

Return
######################################################################################
$OUVRE

If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif
If clalev([F:T54])=0    :    Local File TMP2054         [T54]   : Endif
If clalev([F:T54M])=0   :    Local File TMP2054         [T54M]  : Endif
If clalev([F:T54C])=0   :    Local File TMP2054         [T54C]  : Endif #*FQ92637
If clalev([F:CNX])=0    :    Local File CONTEXT         [CNX]   : Endif
If clalev([F:FIS])=0    :    Local File FISCYEAR        [FIS]   : Endif

SYMBOLE = "PREP2054"
Lock SYMBOLE With lockwait = 3
If fstat
   Return
Endif


 If dim(G_CRITERE)<0  : Global Char    G_CRITERE  (250)  : Endif  # Critère de sélection : Endif
 If dim(G_CRITERE2)<0 : Global Char    G_CRITERE2 (250)  : Endif  # Critère de sélection : Endif
 #*FQ92637

Return
######################################################################################
$FIN

Unlock=SYMBOLE

Return
#=============================================================================
# traitement PREP2054 : alimentation de la table TMP2054
#=============================================================================
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALEUR(30)

Gosub OUVRE
Gosub MAJ_TMP2054

End
###################################################
$MAJ_TMP2054
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMP2054 pour l'état FAS2054 (Liasse fiscale 2054)  ---#
#------------------------------------------------------------------------------------#
    Local Integer I                # Compteur de paramètres
    Local Char    LCPY (5)         # Société
    Local Integer LPLAN            # Plan
    Local Char    LTYPFLUX (15)    # Type de flux
    Local Char    LCODFLUX (5)     # Code flux
    Local Char    LTYPLIASSE       # Exercice ou Périodique
    Local Integer LSITUAT          # Situation
    Local Date    LDATDEB          # Date deb
    Local Date    LDATFIN          #      fin
    Local Char    LREFDEB          # réf deb
    Local Char    LREFFIN          #     fin
    Local Date    LDATNULL         : LDATNULL = [01/01/1900]
    Local Integer LEDTNUM          # Identifiant session
    Local Char    LCRITERE  (250)   # Critère de sélection
    Local Char    LCRITERE2 (250)   # Critère de sélection
    Local Char    SCPY
    Local Char    WCOA (3)          # plan de compte  général de la société
    Local Integer RCNX              # contexte du plan passé en paramètre
    Local Date    RCNXDAT(1..5)     # date d'un contexte
    Local  Char   SAASREF          #*FQ92637
    Global Date   G_FLUSTRDAT      #*FQ92637
    Global Date   G_FLUENDDAT      #*FQ92637

    If clalev([T54])=0 : Local File TMP2054 [T54] : Endif
    Trbegin [T54]
    Delete [T54] Where CREUSR = GUSER
    If fstat = 1
      Rollback
      #  "Problème à l'effacement du fichier temporaire"
         Call MESSAGE (mess(155,197,1)) From GESECRAN
    Else
       Commit
    Endif

   Call GETPARAM("societe",NBPAR,PARAMETRE,LCPY)
   Call GETPARAM("plan",NBPAR,PARAMETRE,PARAM)       : LPLAN    = val(PARAM)
   Call GETPARAM("typflux",NBPAR,PARAMETRE,LTYPFLUX)
   Call GETPARAM("codflux",NBPAR,PARAMETRE,LCODFLUX)
   Call GETPARAM("typliasse",NBPAR,PARAMETRE,PARAM)  : LSITUAT  = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)     : LDATDEB  = PARAM :  G_FLUSTRDAT = LDATDEB #*FQ92637
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)     : LDATFIN  = PARAM :  G_FLUENDDAT = LDATFIN #*FQ92637
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)        :  LEDTNUM   = val(PARAM)


   LCRITERE  = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "societe"     :     LCRITERE   =  "CPY='"+LCPY+"'"
            When "codflux"     :     LCRITERE  += "& CODTXS='"+LCODFLUX+"'"
            When "plan"        :     LCRITERE  += "& DPRPLN="+num$(LPLAN)
            When "typflux"     :     LCRITERE  += "& TYP="+num$(LTYPFLUX)
            When "refdeb"      :     LCRITERE  += "& AASREF>='"+LREFDEB+"'"
            When "reffin"      :     LCRITERE  += "& AASREF<='"+LREFFIN+"'"
         Endcase
      Endif
   Next
   G_CRITERE = LCRITERE
   # LCRITERE +=  "& OWNTYP="+num$(1) or OWNTYP="+num$(5)

#*FQ92637   If LSITUAT = 1
#*FQ92637     LCRITERE2 =     "FIYSTRDAT=["+format$(GFMD,LDATDEB)+"]"
#*FQ92637     LCRITERE2 +=  "& FIYENDDAT=["+format$(GFMD,LDATFIN)+"]"
#*FQ92637     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATNULL)+"]"
#*FQ92637     LCRITERE2 +=  "& PERENDDAT<=["+format$(GFMD,LDATNULL)+"]"
#*FQ92637   Else
#*FQ92637     LCRITERE2 =     "PERSTRDAT=["+format$(GFMD,LDATDEB)+"]"
#*FQ92637    LCRITERE2 +=  "& PERENDDAT=["+format$(GFMD,LDATFIN)+"]"
#*FQ92637   Endif

   Case LSITUAT
   When 1
     LCRITERE2 =     "FIYSTRDAT=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& FIYENDDAT=["+format$(GFMD,LDATFIN)+"]"
     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATNULL)+"]"
     LCRITERE2 +=  "& PERENDDAT<=["+format$(GFMD,LDATNULL)+"]"
   When 2
     LCRITERE2 =     "PERSTRDAT=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& PERENDDAT=["+format$(GFMD,LDATFIN)+"]"
   When 3
     LCRITERE2 =     "PERSTRDAT>=["+format$(GFMD,LDATDEB)+"]"
     LCRITERE2 +=  "& PERSTRDAT<=["+format$(GFMD,LDATFIN)+"]"
     G_CRITERE2 = LCRITERE2
   Endcase

   If clalev([F:T54])=0    :    Local File TMP2054         [T54]    : Endif
   #--------------------------------
   Call DEBTRANS From GLOCK
   Trbegin [T54]
   Delete [T54] Where  (CREUSR =  GUSER)
   If fstat=1 | fstat>5
      GOK = 0
      Call RSTA("T54","") From GLOCK
      Rollback
   Endif
   Commit

   If !GOK : Return : Endif

   If clalev([F:PFL])=0    :    Local File PARFLUX          [PFL]    : Endif
   If clalev([F:PFD])=0    :    Local File PARFLUXDET       [PFD]    : Endif
   If clalev([F:FLU])=0    :    Local File FXDLIFL          [FLU]    : Endif
   If clalev([F:FLUD])=0   :    Local File FXDLIFL          [FLUD]   : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:WFLU])=0   :    Local File FXDLIFL          [WFLU]   : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:E28])=0    :    Local File EFASREEVAL       [E28]    : Endif   #*FQ92637 Enreg. de travail flux pour périodes cumulées
   If clalev([F:CPY])=0    :    Local File COMPANY          [CPY]    : Endif
   If clalev([F:CNX])=0    :    Local File CONTEXT          [CNX]    : Endif
   If clalev([F:FIY])=0    :    Local File FISCYEAR         [FIY]    : Endif
   If clalev([F:DEPF])= 0  :    Local File DEPREC           [DEPF]   : Endif : #*FQ92637 Plans d'amortissements pour les flux

   # Lecture contexte du plan d'amortissement pour récupérer le plan de compte lié
   Call GET_CNX_FROM_PLAN (LCPY, LPLAN, RCNX) From GLOBIENS
   If RCNX <=0
      GOK=0 : Return
   Endif
   Read[CNX]CNX0= LCPY;RCNX
   Local Integer I_COA
   If fstat=0
      I_COA = find(LPLAN,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
      If I_COA > 0
         WCOA= [F:CNX]COA(I_COA-1)
      Endif
   Endif

  # #*FQ92637  Récupération des dates d'un contexte dans la variable dimensionnée RCNXDAT
  Local Integer RCRET
  Call GET_CNX_DAT(LCPY,RCNX,RCNXDAT,RCRET) From GLOBIENS

   #*FQ92637 Si Liasse sur périodes cumulées, date début et date fin appartiennent au même exercice
   Local Date RFIYENDDATD, RFIYENDDATF
   Local Date RPERENDDATD, RPERENDDATF
   Local Integer RCOD
   If LSITUAT = 3
      Call GET_FIY_PER(LDATDEB,LCPY,RCNX,RFIYENDDATD,RPERENDDATD,RCOD)  From GLOBIENS
      Call GET_FIY_PER(LDATFIN,LCPY,RCNX,RFIYENDDATF,RPERENDDATF,RCOD)  From GLOBIENS
      If  LDATDEB <> RCNXDAT(1)
         GOK=0
         #  "La date de début doit être égale à la date de début de l'exercice."
         Call MESSAGE (mess(62,GML_MSGMIS,1)) From GESECRAN
         Return
      Endif
      If  RFIYENDDATD <> RFIYENDDATF
         GOK=0
         #  "Les dates de début et de fin doivent appartenir au même exercice."
         Call MESSAGE (mess(59,GML_MSGMIS,1)) From GESECRAN
         Return
      Endif
   Endif #*FQ92637 END

   Call DEBTRANS From GLOCK
   Trbegin [T54], [T54M], [T54C], [PFL], [PFD], [FLU]
   #FQ105523 For [PFL] Where ( OUTFUNDS < 2 )  and ( CLATXS < 4 ) and ( CODTXS = LCODFLUX ) and ( COA=WCOA )
   For [PFL] Where ( OUTFUNDS < 2 )  and ( CLATXS < 5 ) and ( CODTXS = LCODFLUX ) and ( COA=WCOA )
      Raz[T54]
      Raz[T54M]
      Raz[T54C] #*FQ92637
      For [PFD]  Where ( CODTXS = [F:PFL]CODTXS ) and ( POSTXS = [F:PFL]POSTXS ) and ( COA=WCOA)
         If LSITUAT <> 3
            #*FQ92637  ----- Situations Exercice ou période -----
            Filter [FLU] Where ( evalue(LCRITERE) & evalue (LCRITERE2)) and
&                              ( TXSCAT=num$([F:PFD]POSTXS) and GAC=[F:PFD]GAC and COA=WCOA) Order By TXSCAT Asc; GAC Asc
            For [FLU]
               GOK=1
               #1------------
               [F:T54M]TXSCAT     = [F:FLU]TXSCAT
               [F:T54M]FCY        = [F:FLU]FCY
               [F:T54M]TYP        = [F:FLU]TYP
               [F:T54M]FLGSTATXS  = [F:FLU]FLGSTATXS
               [F:T54M]CNX        = [F:FLU]CNX
               [F:T54M]GAC        = [F:FLU]GAC
               [F:T54M]CODTXS     = [F:FLU]CODTXS
               [F:T54M]PERSTRDAT  = [F:FLU]PERSTRDAT
               [F:T54M]PERENDDAT  = [F:FLU]PERENDDAT
               Gosub CHARGE_T54M
               #========================================================
            Next # [FLU]
            Filter[FLU]
         Else
            #*FQ92637  ----- Situation périodes cumulées -----
            SAASREF = ""
            Filter [FLU] Where ( evalue(LCRITERE) & evalue (LCRITERE2)) &( TXSCAT=num$([F:PFD]POSTXS) )&
&                             ( GAC=[F:PFD]GAC and COA=WCOA )
&                              Order By TXSCAT Asc; GAC Asc; AASREF Asc; PERSTRDAT Asc
              For [FLU]
                 GOK=1
                 If [F:FLU]AASREF <> SAASREF
                    SAASREF = [F:FLU]AASREF
                 Else
                    Goto NEXTFLU
                 Endif
                 [F:FLUD] = [F:FLU]
                 Gosub GENERE_FLUX_CUMULES_T54
                 If !GOK  : Break 3 : Endif
                 Gosub CHARGE_T54CUM
                 $NEXTFLU
              Next   # [FLU]
              Filter[FLU]
              [F:T54M]=[F:T54C]
         Endif
      Next # [PFD]
      Filter[PFD]
      [F:T54]=[F:T54M]
      [F:T54]EDTNUM = LEDTNUM
      [F:T54]CREUSR = GUSER
      [F:T54]CLATXS     =  [F:PFL]CLATXS
      [F:T54]POSTXS     =  [F:PFL]POSTXS
      [F:T54]POSTXSDES  =  [F:PFL]DES
      [F:T54]CPY        =  LCPY
      [F:T54]DPRPLN     =  LPLAN
      If LEDTNUM <> 0
         Write [F:T54]
         If fstat : GOK=0 : Call FSTA("T54") From GLOCK : Endif
         If !GOK : Break :  Goto ROLL_TR1 : Endif
      Endif
   Next  # [PFL]
   If GOK : Commit : Else Gosub ROLL_TR1 : Endif

 If dim(G_FLUSTRDAT)  >0   : Kill G_FLUSTRDAT  : Endif #*FQ92637
 If dim(G_FLUENDDAT)  >0   : Kill G_FLUENDDAT  : Endif #*FQ92637
 If dim(G_CRITERE)    >0   : Kill G_CRITERE    : Endif #*FQ92637
 If dim(G_CRITERE2)   >0   : Kill G_CRITERE2   : Endif #*FQ92637

Return
##*FQ92637 #####################################################################################
$CHARGE_T54M

    # lecture du bien pour voir s'il est composant et récupérer la base d'amort. des composants
    Read[FAS]FAS0 = [F:FLU]AASREF
    If fstat=0
      If [F:FAS]CMPSTA = 3
        [F:T54M]AC    +=  [F:FLU]DPRBASSTR
      Endif
    Endif
    [F:T54M]A1    +=  [F:FLU]DPRBASSTR
    [F:T54M]A2    +=  [F:FLU]RVAAMT
    [F:T54M]A3    +=  [F:FLU]INCBUY + [F:FLU]INCTRF
    [F:T54M]B1    +=  [F:FLU]DCRTRF
    [F:T54M]B2    +=  [F:FLU]DCRSAL
    [F:T54M]B3    +=  [F:FLU]DPRBASEND
    [F:T54M]B4    +=  [F:FLU]BSEVALEND

Return
###*FQ92637 ####################################################################################
 $GENERE_FLUX_CUMULES_T54
Local Integer PSTA : PSTA=2      # Flux provisoires
Local Integer PRPT : PRPT=1      # Pour dire au TRTFLUX que l'on vient des traitements préparatoirs aux éditions
Local Integer PPLN : PPLN=LPLAN  # Passage du plan au TRTFLUX
Local Integer RERROR

  # On appelle le sous-pro qui génère un flux exercice à partir des périodes de l'exercice
  # On s'en sert ici pour générer un flux de périodes cumulées qui sera chargé dans la table TMP2054 (T54C]
  # Les classes [F:FAS] et [F:DEPF] doivent être ouvertes sur le bien et le plan courant
  # Les classes [F:CNX] et [F:FIS] doivent être ouvertes sur le contexte courant
      Read[FIS]FIY1=LCPY;RCNX;GVML_TECOURA
      Call GENERE_FLUX_EXERCICE (GML_TFPLIASS, PSTA, PRPT, PPLN, RERROR) From TRTFLUX
      If RERROR <> 0
         # Pas de flux période, c'est anormal :  "Veuillez vérifier les bornes de dates".
         #*X3-68907 Call ECR_TRACE(mess(60,GML_MSGMIS,1)-""-"RERROR = "-num$(RERROR),1) From GESECRAN
         Call ECR_TRACE(mess(106,GML_MSGMIS,1)-""-"RERROR = "-num$(RERROR),1) From GESECRAN
         GOK=0
         Return
      Endif
      [F:T54C]TXSCAT     = [F:WFLU]TXSCAT
      [F:T54C]FCY        = [F:WFLU]FCY
      [F:T54C]TYP        = [F:WFLU]TYP
      [F:T54C]FLGSTATXS  = [F:WFLU]FLGSTATXS
      [F:T54C]CNX        = [F:WFLU]CNX
      [F:T54C]GAC        = [F:WFLU]GAC
      [F:T54C]CODTXS     = [F:WFLU]CODTXS
      [F:T54C]PERSTRDAT  = LDATDEB
      [F:T54C]PERENDDAT  = LDATFIN

Return
###*FQ92637  ####################################################################################
$CHARGE_T54CUM

    # lecture du bien pour voir s'il est composant et récupérer la base d'amort. des composants
    Read[FAS]FAS0 = [F:WFLU]AASREF
    If fstat=0
      If [F:FAS]CMPSTA = 3
        [F:T54C]AC    +=  [F:WFLU]DPRBASSTR
      Endif
    Endif
    [F:T54C]A1    +=  [F:WFLU]DPRBASSTR
    If [F:DEPF]PERSTRDAT >= LDATDEB
       [F:T54C]A2    +=  [F:WFLU]RVAAMT
    Endif
    [F:T54C]A3    +=  ([F:WFLU]INCBUY + [F:WFLU]INCTRF)
    [F:T54C]B1    +=  [F:WFLU]DCRTRF
    [F:T54C]B2    +=  [F:WFLU]DCRSAL
    [F:T54C]B3    +=  [F:WFLU]DPRBASEND
    [F:T54C]B4    +=  [F:WFLU]BSEVALEND

Return
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
######################################################################################
$ROLL_TR1

 If dim(G_FLUSTRDAT)  >0   : Kill G_FLUSTRDAT  : Endif #*FQ92637
 If dim(G_FLUENDDAT)  >0   : Kill G_FLUENDDAT  : Endif #*FQ92637
 If dim(G_CRITERE)    >0   : Kill G_CRITERE    : Endif #*FQ92637
 If dim(G_CRITERE2)   >0   : Kill G_CRITERE2   : Endif #*FQ92637
Rollback : Call ROLL From GLOCK
If GROLL : Return  : Endif
Return

