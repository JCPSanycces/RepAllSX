#<AdxTL>@(#)9.0.0.0 $Revision$


Raz GPILOBJ,GNBMASKOUV
Call OBJET("ATV",GBIDC1,GBIDC2) From GOBJET
End

# Gestion du masque Atv2
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "SORTIE"     : Gosub SORTIE
 When "OK"         : Gosub OK_CHX
 When "FIN"        : Gosub FIN_CHX
Endcase
Return

$INIT
If !clalev([F:ABO])  : Local File  ABIREPORT  [ABO] : Endif
If !clalev([F:ABOID])  : Local File  ABIREPORTID  [ABOID] : Endif
If !clalev([F:ABM])  : Local File  ABIDATMRT  [ABM] : Endif
If !clalev([F:ABW])  : Local File  ABIDATWRH  [ABW] : Endif
If !clalev([F:ATX])  : Local File  ATEXTE     [ATX] : Endif
If !clalev([F:ATX2]) : Local File  ATEXTE    [ATX2] : Endif
If !clalev([F:ATV2]) : Local File  ABITRAUNV [ATV2] : Endif
Return

$SORTIE
Gosub EFF_FICHIER
$SORTIE2
If dim([M:ATV1]RAPORT) > 0
 GBIDC1 = [M:ATV2]LANGDES
Endif
If dim([M:ATV2]MACHINE) > 0
 Raz [M:ATV2]
Endif
If GINFO
 Call FERME_VLC From GESECRAN
Endif
Return

$FIN_CHX
Raz [M:ABW2]
#Raz [M:ATV2]
Return

$EFF_FICHIER
# efface tout les fichiers en sortie
If dim([M:ATV2]MACHINE) > 0 & [M:ATV2]MACHINE<>""
 GBIDC1 = 'AE_RM "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\*'+num$(adxuid(1))+'*"'
 Call SYSTEME2([M:ATV2]MACHINE+':'+[M:ATV2]SERV,GBIDC1,"",GBIDI1,GBIDC2) From ORDSYS
 GBIDC1 = 'AE_RM "'+[M:ATV2]REPADXDIR+'\tmp\*'+num$(adxuid(1))+'*"'
 Call SYSTEME2([M:ATV2]MACHINE+':'+[M:ATV2]SERV,GBIDC1,"",GBIDI1,GBIDC2) From ORDSYS
Endif
Return

$COP_FICHIER
If dim([M:ATV2]MACHINE) > 0 & [M:ATV2]MACHINE<>""
 # copie tout les fichiers dans un repertoire ERR_lOG si on a une erreur
 GBIDC1 = 'AE_CP "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\*'+num$(adxuid(1))+'*" '+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ERR_LOG'
 Call SYSTEME2([M:ATV2]MACHINE+':'+[M:ATV2]SERV,GBIDC1,"",GBIDI1,GBIDC2) From ORDSYS
Endif
Return

$OK_CHX
[M:ATV2]DATAW    = [M:ABW2]CHXABW
[M:ATV2]DATAMORI = [M:ABW2]CHXABM
Return

$INIT_DIA
Local Clbfile  ORDRE(2)
Local Integer STATS,OUT
Local Char    RESULT(GDIMFIC)(1..30)
Local Char    DOCPRO(GDIMFIC)
Local Char    IMPPRO(GDIMFIC)
Local Char    UNIPRO(GDIMFIC)
Local Char    DOCFILTPRO(GDIMFIC)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,STAT,OK
Local Char    RETOUR(250)
Local Integer I,K,L,M,N,BALISE,ERR
Local Char    WEBILIST(6),WEBIUNV(6),SOLCREA(6),UNIVLIST(6)
Local Char    REPBIS(80),REPBIS21(80),REPBIS22(80)
Local Char    FIC1(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    SSDOS(5),IMPORT(250)

If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif

If [M:ATV2]DATAW  = ""
 For [F:ABW]ABW0
  I+=1
 Next ABW
 If I=1
  [M:ATV2]DATAW = [F:ABW]COD
 Endif
 Local Char XVALEUR(1),XPARAM(1)(1..2)
 Call SAISIE_CHAR(XVALEUR,XPARAM,"ABICHXABW","SUBATV2","") From GSAISIE
 If GINFO
  Call OUVRE_VLC(mess(133,148,1),"","") From GESECRAN : # "Génération fichier de description du référentiel BO"
 Endif
Endif

If [M:ATV2]DATAW = "" : Gosub SORTIE2 : Return : Endif

Read [ABW]ABW0 = [M:ATV2]DATAW
If !fstat & [M:ATV2]LANGORI=""
 [M:ATV2]LANGORI = [F:ABW]LAN
Endif

If [M:ATV2]LANGDES = "" : [M:ATV2]LANGDES   = GLANGUE : Endif
#If [M:ATV2]LANGORI = "" : [M:ATV2]LANGORI   = GLANGUE : Endif
[M:ATV2]SREP     = '\TOOLS\BO\'

### init user et mdp BO
Call RECHPROP("busobj.login.adminusr",[M:ATV2]USRBI,GBIDI1) From INTRUTILA
Call INCRYPT([M:ATV2]USRBI,RETOUR) From INTRUTILA
[M:ATV2]USRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[M:ATV2]PWDBI,GBIDI1) From INTRUTILA

OK=1
Gosub INIT_SOLUTION
If !OK : Goto ERREUR2 : Endif
WEBILIST = "TRUE"      : # Creation de la liste des etats BI
WEBIUNV  = "TRUE"      : # Ajout des univers a la liste des etats BI
SOLCREA  = "TRUE"      : # Création du repertoire solution dans l'arborecence BO
UNIVLIST = "TRUE"      : # Création de la liste des univers et connexions existantes sur le serveur BO
REPBIS   = GREPBI      : # Critere repertoire de recherche niveau 1
REPBIS21 = GREPSOLIND  : # Critere repertoire de recherche niveau 2
REPBIS22 = GINSTID     : # Critere repertoire de recherche niveau 2
IMPORT   = ""
Gosub CRE_PARAM
If !OK : Goto ERREUR2 : Endif
OK = 1
If GADONIX =2 & find(GUSER,"CCL","TCA")>0
 CHEMIN = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE
  Gosub CRE_DOCLISTFILT
  Call OUINON("Voulez-vous regenerer le fichier tool.xml ? ",GBIDI1) From GESECRAN
  If GBIDI1=2
   Gosub CRE_DOCLISTFILT
   Gosub GENE_TOOL
  Endif
 Else
  Gosub CRE_DOCLISTFILT
  Gosub GENE_TOOL
 Endif
Else
 Gosub CRE_DOCLISTFILT
 Gosub GENE_TOOL
Endif
If !OK
 Goto ERREUR2
Endif
BALISE = 1
Gosub CRE_LIST_ETA   : # parcours et mets dans des varaibles dimensionner les etat et univers du fichier tool
Gosub RECH_REPDESID  : # recherche l'ID du repertoire BO de destination qui correspond au nom de la solution
If !OK
 Goto ERREUR2
Endif
Gosub CHARGE_TAB : # Chargement du mask
Return

$RECH_REPDESID
N=find(GREPBI,DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif

For J=0 To NBDOSSIER
 If DOSSIER(J) = GINSTID & DOS_P_ID(J) = DOS_ID(N-1)
  Break
 Endif
Next I

For I=0 To NBDOSSIER-1
 If DOSSIER(I) = [M:ATV2]DATAW & DOS_P_ID(I) = DOS_ID(J)
  Break
 Endif
Next I
For K=0 To NBDOSSIER-1
 If DOSSIER(K) = [M:ATV2]LANGDES & DOS_P_ID(K) = DOS_ID(I)
  [M:ATV2]REPDESID = DOS_ID(K)
  Break
 Endif
Next K
Return

$ERREUR2
Gosub COP_FICHIER
If GINFO
 Call FERME_VLC From GESECRAN
Endif
If GTRACE <> ""
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
Return

$CONTROLE
Call OUVRE_TRACE(mess(6,14,1)-":"-mess(42,127,1)) From LECFIC : # Traduction Etats Business Objects
### Il doit y avoir au moins 1 langue
If [M:ATV2]LANGORI = ""
 Call ECR_TRACE(mess(8,125,1) ,1) From GESECRAN
 OK = 0
 Goto CONTROLE1
Endif
### On verifie qu'il y est au moins un etat selectionné
OK =0
For I=0 To [M:ATV2]NBETA-1
 If [M:ATV2]TRADUC(I) = 2
  OK =1 : Break
 Endif
Next I
If !OK
 Call ECR_TRACE(mess(6,135,1),1) From GESECRAN : # Etat inexistant
 OK =0
Endif
$CONTROLE1
If !OK
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
 FIN = 1
 Return
Endif
Return

$EXEC
If [M:ATV2]CHOIX = 1 : # Aucune action sur le serveur BO
 Gosub DECLARATION
 Gosub GENE_MAP : # Generation du fichier xml(map.xml)
 If !OK
  Goto ERREUR
 Endif
 Gosub SYNCHRO : # On parcours le fichier map.xml pour recupere tous les intitulés
 If !OK
  Goto ERREUR
 Endif
Elsif [M:ATV2]CHOIX = 2 : # Action sur le serveur BO mapping et/ou traduction
 Gosub MAPPING
Endif
If GINFO
 Call FERME_VLC From GESECRAN
Endif
TRA = 1
Return

$MAPPING
OK = 1
Gosub DECLARATION
If [M:ATV2]UNIVDESID = "" | [M:ATV2]REPDESID  = "" : # On recrée un fichier tool pour avoir L'iD du nouveau univers
 WEBILIST = "FALSE"
 If [M:ATV2]REPDESID = "" : WEBILIST = "TRUE" : Endif
 WEBIUNV  = "FALSE"
 SOLCREA  = "FALSE"
 UNIVLIST = "TRUE"
 REPBIS   = GREPBI
 REPBIS21 = GREPSOLIND
 REPBIS22 = GINSTID
 IMPORT   = ""
 Gosub CRE_PARAM
 If !OK :  Goto ERREUR : Endif
 Gosub GENE_TOOL
 If !OK :  Goto ERREUR : Endif
 BALISE = 0
 If [M:ATV2]REPDESID = ""
  Gosub CRE_LIST_ETA
  Gosub RECH_REPDESID
 Endif
 Call FIND_UNV([ABM]ABR,FICHIER,GBIDC1,GBIDC2,OK) From SUBATV2
 [M:ATV2]UNIVDESID = right$(GBIDC1,instr(1,GBIDC1,"&&&")+3)
 If !OK
  Goto ERREUR
 Endif
Endif
#### Mapping des etats vers le nouveau univers dans le repertoire de destination
Gosub GENE_UNIV
If !OK
 Goto ERREUR
Endif
WEBILIST = "TRUE"
WEBIUNV  = "FALSE" : If GBOVERSION>="R3" : WEBIUNV  = "TRUE" : Endif : # Bug 72719
SOLCREA  = "FALSE"
UNIVLIST = "FALSE"
REPBIS   = GREPBI
REPBIS21 = GREPSOLIND
REPBIS22 = GINSTID
IMPORT   = ""
Gosub CRE_PARAM
If !OK :  Goto ERREUR : Endif
Gosub GENE_TOOL
If !OK :  Goto ERREUR : Endif
BALISE = 0
Gosub CRE_LIST_ETA
# Enregistrrement des nouveau CUI des etats.
Gosub TR_CUID_ETAT
If !GOK :  Goto ERREUR : Endif
If [M:ATV2]LANGDES <> [M:ATV2]LANGORI : # Traduction des etats, on doit refaire un tool pour avoir les id des nouveaux etats mappés
 Gosub GENE_MAP : # On regenere un fichier map.xml
 If !OK
  Goto ERREUR
 Endif
 Gosub TRADUCTION : # Algo pour recreer le fichier map.xml a y rajoutant la traduction des libelles precedemnt crées.
 If !OK
  Goto ERREUR
 Endif
 Gosub GENE_TRANS : # On fait la traduction en modifiant les etats, on remplace les intitules FRA par la langue choisi.
 If !OK
  Goto ERREUR
 Endif
Endif
Return

$TR_CUID_ETAT

If !clalev([F:ABOID])  : Local File  ABIREPORTID  [ABOID] : Endif

Trbegin [ABOID]
GOK = 1
For I=0 To [M:ATV2]NBETA-1
 If [M:ATV2]TRADUC(I) =2
  For J=0 To [L]NBETAT-1
   If [M:ATV2]ETAT(I) = [L]ETAT(J)
    K = find([L]ETAT_F_CUID(J),[L]DOSREFID(0..NBDOSREF) )
    If K >0 O
     L = find([L]DOSREFID_P(K-1),[L]DOSREFID(0..NBDOSREF) )
     If L
      M=  find([L]DOSREFID_P(L-1),[L]DOSREFID(0..NBDOSREF) )
     Endif
    Endif
    If L & K & M & [L]DOSREF(K-1) = [M:ATV2]LANGDES & [L]DOSREF(L-1) = [M:ATV2]DATAW & [L]DOSREF(M-1) = GINSTID
     [M:ATV2]ETAIDNEW(I) = [L]ETAT_ID(J)
     Filter [ABO] Where REPCOD = [L]ETAT(J)
     Read [ABO]ABO1 First
     Filter [ABO]
     If !fstat & [F:ABO]DATAM <> "" & [F:ABO]ENAFLG =2
      Read [F:ABOID]ABOID0=[ABO]COD;[M:ATV2]DATAW;[M:ATV2]LANGDES
      If !fstat
       [F:ABOID]DOCID=[L]ETAT_CUID(J)
       Rewrite [F:ABOID]
       If fstat
        GOK=0 : Call FSTA("F:ABOID") From GLOCK
       Endif
      Else
       [F:ABOID]COD     = [ABO]COD
       [F:ABOID]DATAW = [M:ATV2]DATAW
       [F:ABOID]LAN     = [M:ATV2]LANGDES
       [F:ABOID]DOCID  = [L]ETAT_CUID(J)
       Write [F:ABOID]
       If fstat
        GOK=0 : Call FSTA("F:ABOID") From GLOCK
       Endif
      Endif
     Endif
    Endif
   Endif
  Next J
 Endif
Next I
If !GOK : Rollback : Return : Endif
Commit
Return

$ERREUR
Gosub COP_FICHIER
If dim([L]ABIVALTOT)>0 & [L]ABIVALTOT>0 : Return : Endif
Call TEMPOFF From GESECRAN
If GINFO
 Call FERME_VLC From GESECRAN
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
FIN = 1
Return

$INIT_SOLUTION
Local Char    NOMFIC(GDIMFIC)
Local Integer I1,I2
# Initialisations

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0
 Call ECR_TRACE(NOMFIC-mess(101,100,1),1) From GESECRAN  : # : Fichier inexistant
 OK =0
 Return
Endif

## Lecture fichier
Openi NOMFIC,0 Using [R1]
Iomode adxifs ""  Using [R1]
Iomode adxirs chr$(10)  Using [R1]
Iomode adxium GUTF8  Using [R1]

fstat=0
While fstat=0
 Rdseq GBIDC1 Using [R1]
 If instr(1,GBIDC1,"busobj.adxadmin.port")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]SERV=vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
 If instr(1,GBIDC1 ,"busobj.tools.path")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]BOTOOL=vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
 If instr(1,GBIDC1 ,"component.busobj.servername")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]MACHINE=vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
 If instr(1,GBIDC1,"busobj.rest.port")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]PORTREST=vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
 If instr(1,GBIDC1 ,"component.busobj.name")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]COMPBONAM =vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
 If instr(1,GBIDC1 ,"busobj.files.path")<>0
  I1=instr(1,GBIDC1,">")
  I2=instr(I1+1,GBIDC1,'<')
  If I2-I1-1>0
   [M:ATV2]BOFILE =vireblc(mid$(GBIDC1,I1+1,I2-I1-1),2)
  Endif
 Endif
Wend
Openi NOMFIC

If [M:ATV2]PORTREST="" : [M:ATV2]PORTREST="6405" : Endif
Call VAR_BOWORLD("dblink","","",[M:ATV2]SERV_ODBC,GBIDI1) From ABICREBAS
If GBIDI1
 Call ERREUR("boworld.xml"-mess(101,100,1)) From GESECRAN
 OK =0
 Return
Endif

Raz [M:ATV2]REPADXDIR
Call VARADX("ADXDIR",[M:ATV2]MACHINE+":"+[M:ATV2]SERV,[M:ATV2]REPADXDIR) From ADXD
If [M:ATV2]REPADXDIR=""
 OK = 0 : Call ECR_TRACE("("+[M:ATV2]MACHINE+":"+[M:ATV2]SERV+") busobj.adxadmin not available" ,1) From GESECRAN
 Return
 End
Endif

### Verif dossier
Local Char    CHEMIN(250)
Local Integer EXISTE
CHEMIN = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME(MACHINE+":"+[M:ATV2]SERV,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM,"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
CHEMIN = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ERR_LOG'
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME(MACHINE+":"+[M:ATV2]SERV,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ERR_LOG',"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
[M:ATV2]FICLIST    = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'List_'+num$(adxuid(1))+'.xml'
[M:ATV2]FICMAP     = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Map_'+num$(adxuid(1))+'.xml'
[M:ATV2]FICTOOL    = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Tool_'+num$(adxuid(1))+'.xml'
[M:ATV2]FICTOOL2   = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Tool2_'+num$(adxuid(1))+'.xml'
[M:ATV2]FICPARAM   = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Param_'+num$(adxuid(1))+'.xml'
If dim(GFUSION)>0 & GFUSION>0
 [M:ATV2]FICTOKEN   = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Token_'+num$(adxuid(1))+'.txt'
Else
 Raz [M:ATV2]FICTOKEN
Endif

If dim(GFUSION)>0 & GFUSION>0 & [M:ATV2]FICTOKEN <>""
 Local Clbfile TOKEN(1)
 Local Char RETOUR(250)(1..)
 Getui RETOUR="" With "GetBoToken"
 Local Integer IDX : IDX = 1
 For IDX=1 To maxtab(RETOUR)
   Append TOKEN, right$(RETOUR(IDX), 13)
 Next IDX
 If TOKEN="unsupported" or TOKEN=""
  OK=0
  Call ECR_TRACE(mess(167,148,1),1) From GESECRAN
 Return
Endif

 # Ecriture tOKEN
 Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOKEN , 0 Using [W1]
 Iomode adxifs  ""  Using [W1]
 Iomode adxirs  ""  Using [W1]   : # chr$(13)+chr$(10)
 Iomode adxium  GUTF8  Using [W1]
 Wrseq TOKEN Using [W1]
 Openo Using [W1]
Endif

If GADONIX =2
 [M:ATV2]FICTOOL    = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'Tool_'+GUSER+'.xml'
Endif

Local Integer MAC64
Local Char CMD64(100),CMDTXT(250)
Call VERIF_MAC64(MAC64) From PATCHABI
If MAC64
 CMD64 = "%Windir%\SysWOW64\CMD.exe /c "
Else
 Raz CMD64
Endif

$VERSION
Local Char TOOLCMD(50),UNIVCMD(50),MAPCMD(50),TRANSCMD(50),IMPCMD(50)
If GBOVERSION="R3"
 TOOLCMD = "BI_Tools_V31.cmd"
 UNIVCMD = "BI_ChangeUniv_V31.cmd"
 MAPCMD  = "BI_MakeMap_V31.cmd"
 TRANSCMD = "BI_Translate_V31.cmd"
 IMPCMD   = "BI_ImpBiar_V31.cmd"
Elsif GBOVERSION="R4"
 TOOLCMD = "BI_Tools_V41.cmd"
 UNIVCMD = "BI_ChangeUniv_V41.cmd"
 MAPCMD  = "BI_MakeMap_V41.cmd"
 TRANSCMD = "BI_Translate_V41.cmd"
 IMPCMD   = "BI_ImpBiar_V41.cmd"
Else
 TOOLCMD  = "BI_Tools_V2.cmd"
 UNIVCMD  = "BI_ChangeUniv.cmd"
 MAPCMD   = "BI_MakeMap.cmd"
 TRANSCMD = "BI_Translate.cmd"
 IMPCMD   = "BI_ImpBiar.cmd"
Endif
Return

######################################################################################
Subprog B1_NBETA
Local Integer I
For I=nolign-1 To [M:ATV2]NBETA-1
 If [M:ATV2]DATAM(I) = [M:ATV2]DATAMORI
  [M:ATV2]TRADUC(I) = 2
 Endif
Next I
Affzo 25
End

Subprog B2_NBETA
Local Integer I
For I=nolign-1 To [M:ATV2]NBETA-1
 If [M:ATV2]DATAM(I) = [M:ATV2]DATAMORI
  [M:ATV2]TRADUC(I) = 1
 Endif
Next I
Affzo 25
End

Subprog C_TRADUC(VALEUR)
Variable Integer VALEUR
If [M:ATV2]ETAT(nolign-1)="" : mkstat=1 : Endif
End

Subprog S_DATAMORI(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(0..50) , INTIT(30) , TEXTE(50)(0..50)
NBTEX = 0
Read [F:ABW]ABW0 = [M:ATV2]DATAW
If !fstat
 For I=0 To [F:ABW]NBRABM-1
  Read [F:ABM]ABM0 = [F:ABW]CODABM(I)
  If !fstat
   NBTEX += 1
   Call TEXTE([F:ABM]INTIT,INTIT) From OBJDIV
   TEX(NBTEX) =[F:ABM]COD
   TEXTE(NBTEX) =  format$("K:11X",[F:ABM]COD)-"("-INTIT-")"
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Next I
Endif
If NBTEX
 If NBTEX =1 : VALEUR = TEX(1) : End : Endif
 Call SAITEX(NBTEX,TEXTE,NUM,"Datamart") From GESECRAN
 If NUM<>0 & status<>7
  VALEUR = TEX(NUM)
 Endif
Endif
End

Subprog C_CHXABM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer OK
Read [F:ABW]ABW0 = [M:ABW2]CHXABW
If !fstat
 For I=0 To [F:ABW]NBRABM-1
  Read [F:ABM]ABM0 = [F:ABW]CODABM(I)
  If !fstat
   OK=1
   Break
  Endif
 Next I
Endif
If !OK
 GMESSAGE =mess(40,148,1) : # Datamart non présent dans le datawarehouse
 mkstat = 2 : End
Endif
OK = 0
For [F:ABO] Where [F:ABO]DATAM=VALEUR
 OK=1 : Break
Next
If !OK
  GMESSAGE =mess(140,148,1) : #AUCUN ÉTAT À MAPPER
 mkstat = 2 : End
Endif
End

Subprog S_CHXABM(VALEUR)
Variable Char    VALEUR()
[M:ATV2]DATAW = [M:ABW2]CHXABW
Call S_DATAMORI(VALEUR)
[M:ATV2]DATAW = ""
End

Subprog D_UNIVDES(VALEUR)
Variable Char    VALEUR()
If [M]DATAMORI<> "" & VALEUR = ""
 Call C_DATAMORI([M]DATAMORI)
Endif
End

Subprog D_CHXABW(VALEUR)
Variable Char    VALEUR()
VALEUR = [M:ATV2]DATAW
End


Subprog AM_LANGORI(VALEUR)
Variable Char    VALEUR()
If [M:ATV2]DATAMORI = "" : End : Endif
Local Integer BALISE,OK
BALISE = 1
OK=1
Gosub CRE_LIST_ETA
If !OK
 GMESSAGE = mess(147,100,1) : #  ------------------- ERREUR -------------------
 mkstat = 2 : End
Endif
[M:ATV2]LANGORI = VALEUR
Gosub CHARGE_TAB
Local Integer I
I = 1
While I<=[M:ATV2]NBETA
 If [M:ATV2]DATAM(I-1)<>[M:ATV2]DATAMORI
  Dela I-1,1 [M:ATV2]NBETA
  [M:ATV2]NBETA -= 1
 Else
  Actzo TRADUC(I-1)
  I += 1
 Endif
Wend
Sorta [M:ATV2]NBETA [M:ATV2]NBETA Order By [M:ATV2]DATAM([S]indice)
Affzo [M:ATV2]
End

Subprog AM_DATAMORI(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
While I<=[M:ATV2]NBETA
 If [M:ATV2]DATAM(I-1)<>VALEUR
  Dela I-1,1 [M:ATV2]NBETA
  [M:ATV2]NBETA -= 1
 Else
  Actzo TRADUC(I-1)
  I += 1
 Endif
Wend
Sorta [M:ATV2]NBETA [M:ATV2]NBETA Order By [M:ATV2]DATAM([S]indice)
Affzo [M:ATV2]
End

Subprog C_DATAMORI(VALEUR)
Variable Char    VALEUR()
Local    Char FICHIER(GDIMFIC)
Local    Integer OK
OK = 0
If !clalev([F:ABO])  : Local File  ABIREPORT  [ABO] : Endif
For [F:ABO] Where [F:ABO]DATAM=VALEUR
 OK=1 : Break
Next
If !OK
  GMESSAGE =mess(140,148,1) : #AUCUN ÉTAT À MAPPER
 mkstat = 2 : End
Endif
FICHIER = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL
If filinfo(FICHIER,7)<0
 GMESSAGE = "|"+[M:ATV2]FICTOOL+"|"-":"-mess(101,100,1)
 mkstat = 2 : End
Endif
Read [ABM]ABM0 = VALEUR
If !fstat
 Raz GBIDC1
 Call FIND_UNV([F:ABM]ABR,[L]FICHIER,GBIDC1,GBIDC2,OK)
 If (!OK  & [M:ATV2]CHOIX <> 1) or GBIDC1=""
  GMESSAGE = mess(87,148,1)-":"-VALEUR
  mkstat = 2 : End
 Endif
 [M:ATV2]UNIVDES   = left$(GBIDC1,instr(1,GBIDC1,"&&&")-1)
 [M:ATV2]UNIVDESID = right$(GBIDC1,instr(1,GBIDC1,"&&&")+3)
Endif
End

Subprog FIND_UNV(ABR,FICHIER,UNIVERS,UNIVERS2,OKK)
Value    Char ABR
Value    Char FICHIER
Variable Char UNIVERS
Variable Char UNIVERS2
Variable Integer OKK
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,OK,I1,I2
Local Char    TAB(20)(0..500),TAB_ID(20)(0..500),TAB_UNV(20)(0..500)
Local Clbfile CLOB(9)
Local Integer DEB,FIN,NBUNV,TAB_NIV(0..500),REPSOL
Local Char    UNIVID(80),PARENTID(80)
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Openi FICHIER,0 Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]

Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  End
 Endif
Endif

Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Gosub FIND_FOLD_UNIV From ABICREUNV

Openi FICHIER,0 Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  End
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Gosub RECH_FOLD

If NBUNV = 0
 REPSOL =1
 N=find(GREPBI,U_DOSSIER(0..U_NBDOS))
 If N = 0 : End : Endif

 For J=0 To U_NBDOS-1
  If U_DOSSIER(J) = GREPSOLIND & U_DOS_P_ID(J) = U_DOS_ID(N-1)
   Break
  Endif
 Next J

 For I=0 To U_NBDOS-1
  If U_DOSSIER(I) = GREPBOPROD & U_DOS_P_ID(I) = U_DOS_ID(J)
   Break
  Endif
 Next I
 For K=0 To U_NBDOS-1
  If U_DOSSIER(K) = "ALL" & U_DOS_P_ID(K) = U_DOS_ID(I)
   FOLDDES   = U_DOS_CUID(K)
   FOLDDESID = U_DOS_ID(K)
   Break
  Endif
 Next K
 Gosub RECH_FOLD
Endif

If NBUNV > 0
 OKK = 1
 I= find(max(TAB_NIV),TAB_NIV(0..NBUNV))
 UNIVERS  = TAB_UNV(I-1)
 If val(right$(UNIVERS,len(UNIVERS)-3)) = 9999
  UNIVERS2 = [L]ABR+"0001"
 Elsif REPSOL =1
  UNIVERS2 = [L]ABR+"0001"
 Else
  UNIVERS2 = [L]ABR+string$(4-len(num$(val(right$(UNIVERS,len(UNIVERS)-3))+1)),"0")+num$(val(right$(UNIVERS,len(UNIVERS)-3))+1)
 Endif
Else
 OKK =0
 UNIVERS  = [L]ABR+"0001"
 UNIVERS2 = [L]ABR+"0001"
Endif
UNIVERS += "&&&"+TAB_ID(I-1)
UNIVERS2 += "&&&"+TAB_ID(I-1)
End

$RECH_FOLD
DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(1,CLOB,'Universe Id="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 UNIVID = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(DEB,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 PARENTID = seg$(CLOB,DEB+10,FIN-1)

 If PARENTID = FOLDDESID
  DEB = instr(DEB,CLOB,'Universe="')
  FIN = instr(DEB+10,CLOB,'"')
  CHAINE = seg$(CLOB,DEB+10,FIN-1)
  If CHAINE <> "" & len(CHAINE)>4
   If left$(CHAINE,len(CHAINE)-4) = [L]ABR & val(right$(CHAINE,len(CHAINE)-3)) > 0
    TAB_UNV(NBUNV) = CHAINE
    TAB_NIV(NBUNV) = val(right$(CHAINE,len(CHAINE)-3))
    TAB_ID(NBUNV)  = UNIVID
    NBUNV +=1
   Endif
  Endif
 Endif

 DEB = instr(FIN,CLOB,'Universe Id="')
Wend
Return

######################################################################################
$CRE_LIST_ETA

Local Clbfile CLOB(12),CLB(12)

Local Integer DEB,FINS
Local Integer DEBDOC,FINDOC,FINFOLD
Local Integer I,J,K,L
Local Char    CHAINE(250)

### tableau etat Bo --- CUID folder
Local Char    ETAT_F_CUID(20)(0..500)
Local Char    ETAT_CUID(80)(0..500)
Local Char    ETAT(80)(0..500)
Local Char    ETAT_UNV(10)(0..500)
Local Char    ETAT_ID(20)(0..500)
Local Char    ETAT_UNVID(20)(0..500)
Local Integer NBETAT

Local Char    DOSSIER(80)(0..200)
Local Char    DOS_ID(20)(0..200)
Local Char    DOS_CUID(50)(0..200)
Local Char    DOS_P_ID(20)(0..200)
Local Integer NBDOSSIER

# Initialisations

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+[M:ATV2]FICTOOL+"|"-mess(101,100,1),1) From GESECRAN
 Else
  Call ERREUR("|"+[M:ATV2]FICTOOL+"|"-mess(101,100,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

## Lecture fichier map.xml et afectation du clob
Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL Using [R1] #
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]

DEB = instr(1,CLOB,"<Folders_And_Webis")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(1,CLOB,"<Folders_And_Webis")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  Return
 Endif
Endif

Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

FINS = instr(1,CLOB,"</Folders_And_Webis")
If !FINS
 Call ECR_TRACE(mess(92,148,1),1) From GESECRAN : # "Aucun états trouvés dans l'Infoview"
 Return
Endif

CLOB = seg$(CLOB,DEB,FINS-1)
DEB = instr(1,CLOB,"<Folders_And_Webis")

Local Integer OKCREETA
DEB = instr(DEB,CLOB,"<")
While DEB>0
 FINS = instr(DEB,CLOB,">")
 CLB = seg$(CLOB,DEB,FINS)
 If instr(0,CLB,"Folder CUID=")
  Gosub CRE_DOSSIER
 Elsif  instr(0,CLB,"WebiDoc CUID=")
  OKCREETA = 1
  If BALISE & instr(DEB,CLOB,"</WebiDoc>") >0
   FINS = instr(DEB,CLOB,"</WebiDoc>")+9
   CLB = seg$(CLOB,DEB,FINS)
   If instr(3,CLB,"WebiDoc CUID=")
    FINS = instr(DEB,CLOB,"/>")+2
   Endif
  Endif
  If OKCREETA & instr(DEB,CLOB,"</WebiDoc>") >0
   Gosub CRE_ETAT
  Endif
 Endif
 DEB = instr(FINS,CLOB,"<")
Wend
Return

$CRE_DOSSIER
I = instr(0,CLB,'Folder CUID="')+13
J = instr(I,CLB,'"')-1
If I> 0 & J >0
 DOS_CUID(NBDOSSIER) = seg$(CLB,I,J)
 I = instr(0,CLB,'Id="')+4
 J = instr(I,CLB,'"')-1
 DOS_ID(NBDOSSIER) = seg$(CLB,I,J)
 I = instr(0,CLB,'Name="')+6
 J = instr(I,CLB,'"')-1
 DOSSIER(NBDOSSIER) = seg$(CLB,I,J)
 I = instr(0,CLB,'ParentID="')+10
 J = instr(I,CLB,'"')-1
 DOS_P_ID(NBDOSSIER) = seg$(CLB,I,J)
 NBDOSSIER +=1
Endif
Return

$CRE_ETAT
I = instr(0,CLB,'ParentID="')+10
J = instr(I,CLB,'"')-1
If I> 0 & J >0
 ETAT_F_CUID(NBETAT) = seg$(CLB,I,J)
 I = instr(0,CLB,'Title="')+7
 J = instr(I,CLB,'"')-1
 ETAT(NBETAT) = seg$(CLB,I,J)
 I = instr(0,CLB,'CUID="')+6
 J = instr(I,CLB,'"')-1
 ETAT_CUID(NBETAT) = seg$(CLB,I,J)
 I = instr(0,CLB,'Id="')+4
 J = instr(I,CLB,'"')-1
 ETAT_ID(NBETAT) = seg$(CLB,I,J)
 I = instr(0,CLB,'Universe="')+10
 J = instr(I,CLB,'"')-1
 ETAT_UNV(NBETAT) = seg$(CLB,I,J)
 I = instr(0,CLB,'Universe Id="')+13
 J = instr(I,CLB,'"')-1
 ETAT_UNVID(NBETAT) = seg$(CLB,I,J)
 NBETAT +=1
Endif
Return


######################################################################################
$CHARGE_TAB
Local Char    DOSREF(80)(0..100),DOSREFID_P(20)(0..100),DOSREFID(20)(0..100)
Local Integer NBDOSREF,H

H=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If !H : Return : Endif
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = [L]DOS_ID(H-1)
  [L]DOSREF(NBDOSREF)     = [L]DOSSIER(I)
  [L]DOSREFID(NBDOSREF)   = [L]DOS_ID(I)
  [L]DOSREFID_P(NBDOSREF) = [L]DOS_P_ID(I)
  NBDOSREF +=1
 Elsif find([L]DOS_P_ID(I),DOSREFID(0..NBDOSREF))
  [L]DOSREF(NBDOSREF)     = [L]DOSSIER(I)
  [L]DOSREFID(NBDOSREF)   = [L]DOS_ID(I)
  [L]DOSREFID_P(NBDOSREF) = [L]DOS_P_ID(I)
  NBDOSREF +=1
 Endif
Next I
J=0
[M:ATV2]NBETA = 0
Raz [M:ATV2]ETAT
For SSDOS="ALL","VER","SPE"
 For I=0 To NBETAT-1
  K = find([L]ETAT_F_CUID(I),[L]DOSREFID(0..NBDOSREF) )
  If K >0
  L = find([L]DOSREFID_P(K-1),[L]DOSREFID(0..NBDOSREF) )
   If L
    M=  find([L]DOSREFID_P(L-1),[L]DOSREFID(0..NBDOSREF) )
   Endif
  Endif
  If L & K & M :   Gosub ETAT_ALL_SPE_VER  : Endif
 Next I
Next
Affzo [M:ATV2]
H=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))

For I=0 To NBDOSSIER-1
 If !find([L]DOS_ID(I),[L]DOSREFID(0..NBDOSREF))
  If [L]DOSSIER(I) = GINSTID  & [L]DOS_P_ID(I) = [L]DOS_ID(H-1)
   [L]DOSREF(NBDOSREF)     = [L]DOSSIER(I)
   [L]DOSREFID(NBDOSREF)   = [L]DOS_ID(I)
   [L]DOSREFID_P(NBDOSREF) = [L]DOS_P_ID(I)
   NBDOSREF +=1
  Elsif find([L]DOS_P_ID(I),DOSREFID(0..NBDOSREF))
   [L]DOSREF(NBDOSREF)     = [L]DOSSIER(I)
   [L]DOSREFID(NBDOSREF)   = [L]DOS_ID(I)
   [L]DOSREFID_P(NBDOSREF) = [L]DOS_P_ID(I)
   NBDOSREF +=1
  Endif
 Endif
Next I

H=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
[L]DOSREF(NBDOSREF)     = [L]DOSSIER(H-1)
[L]DOSREFID(NBDOSREF)   = [L]DOS_ID(H-1)
[L]DOSREFID_P(NBDOSREF) = [L]DOS_P_ID(H-1)
NBDOSREF +=1

For I=0 To NBDOSREF-1
 [M:ATV2]DOS(I)      = [L]DOSREF(I)
 [M:ATV2]DOSID(I)    = [L]DOSREFID(I)
 [M:ATV2]DOSIDFAT(I) = [L]DOSREFID_P(I)
Next I
[M:ATV2]NBDOS = NBDOSREF
Return

$ETAT_ALL_SPE_VER
If L & K & M & find([L]DOSREF(K-1),[L]SSDOS) & [L]DOSREF(L-1) = GREPBOPROD & [L]DOSREF(M-1) = GREPSOLIND & !find([L]ETAT(I),[M:ATV2]ETAT(0..[M:ATV2]NBETA ))
 Filter [ABO] Where REPCOD = [L]ETAT(I) & ENAFLG=2
 Read [ABO]ABO1 First
 Filter [ABO]
 If !fstat & [F:ABO]DATAM <> "" & [F:ABO]ENAFLG =2
  If ([F:ABO]LANREF = "" & [M:ATV2]LANGORI = "FRA" ) |( [F:ABO]LANREF = [M:ATV2]LANGORI) | [M:ATV2]LANGORI = ""
   [M:ATV2]ETAT([M:ATV2]NBETA)     = [L]ETAT(I)
   [M:ATV2]ETATID([M:ATV2]NBETA)   = [L]ETAT_ID(I)
   [M:ATV2]ETAIDFAT([M:ATV2]NBETA) = [L]ETAT_F_CUID(I)
   [M:ATV2]REPERT([M:ATV2]NBETA)   = [L]DOSREF(find([L]DOSREFID_P(K-1),[L]DOSREFID(0..NBDOSREF))-1)+" / "+SSDOS
   [M:ATV2]DATAM([M:ATV2]NBETA)    = [F:ABO]DATAM
   [M:ATV2]UNIVERS([M:ATV2]NBETA)  = [L]ETAT_UNV(I)
   [M:ATV2]ETAUNVID([M:ATV2]NBETA) = [L]ETAT_UNVID(I)
   [M:ATV2]TRADUC([M:ATV2]NBETA)   = 1
   If [F:ABO]LANREF = ""
    [M:ATV2]LAN([M:ATV2]NBETA) = "FRA"
   Else
    [M:ATV2]LAN([M:ATV2]NBETA) = [F:ABO]LANREF
   Endif
   [M:ATV2]NBETA += 1
  Endif
 Endif
Endif
Return


######################################################################################
$DECLARATION
# Déclarations
Local Clbfile CLOB(12),CLB(9)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,STAT
Local Char    NEWFIC(250)
Local Integer DEB,FIN
Local Integer DEBNAME,FINNAM
Local Integer DEBLIB,FINLIB
Local Char    TITLE(80),LIBEL(80)
Local Char    CHAINE(250),WETATID(20)
Local Char    TRADUCTION(80),DESC1(80),DESC2(80),DESC3(80)
Local Char    FIC(GDIMFIC),PREFIX(20)
FIC= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICMAP
Return

######################################################################################
$SYNCHRO
If filinfo(FIC,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+FIC+"|"-mess(101,100,1),1) From GESECRAN
 Else
  Call ERREUR("|"+FIC+"|"-mess(101,100,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

# Initialisations

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
## Lecture fichier map.xml et afectation du clob
Openi FIC   Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]

DEB = instr(0,CLOB,"<WebiDoc")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
  DEB = instr(0,CLOB,"<WebiDoc")
  If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  Return
 Endif
Endif

Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Call ECR_TRACE(mess(72,148,1)-":"-[M:ATV2]LANGORI,0) From GESECRAN : # Langue de référence
Call ECR_TRACE(mess(73,148,1)-":"-[M:ATV2]LANGDES,0) From GESECRAN : # Langue de traduction
Call ECR_TRACE("",0) From GESECRAN

Trbegin [ATV]
While DEB>0
 FIN = instr(DEB,CLOB,"</WebiDoc")+9
 CLB = seg$(CLOB,DEB,FIN)
 DEBNAM = instr(0,CLB,"name=")+6
 FINNAM = instr(DEBNAM,CLB,'"')-1
 I= instr(0,CLB,'docrepoid="')+11
 J= instr(I,CLB,'"')-1
 WETATID = seg$(CLB,I,J)
 Call VERIF_CHOIX2(WETATID,STAT)
 If STAT
  I=find(WETATID,[M:ATV2]ETATID(0..[M:ATV2]NBETA))
  Call ECR_TRACE([M:ATV2]ETAT(I-1)+" : ",0) From GESECRAN
  TITLE  = seg$(CLB,DEBNAM,FINNAM)
  Gosub DELETE_ENREG
  If GOK < 1 : Break : Endif
  LIBEL  =""
  Call TRAD([M:ATV2]DATAMORI,[M:ATV2]LANGORI,[M:ATV2]LANGDES,TITLE,LIBEL,1,GBIDC1)
  DEBLIB  = instr(DEBNAM,CLB,'<WebiLib')
  While DEBLIB > 0
   FINLIB  = instr(DEBLIB,CLB,'/>')-1
   CHAINE  = seg$(CLB,DEBLIB,FINLIB)
   LIBEL   = seg$(CHAINE,instr(0,CHAINE,'Key="')+5,len(CHAINE)-1)
   If !instr(1,LIBEL,"§FOR_") & pat(LIBEL,"*?*") > 0
    If pat(LIBEL,"§???_*")
     LIBEL = right$(LIBEL,6)
    Endif
    If pat(LIBEL,"*?*") > 0
     Call TRAD([M:ATV2]DATAMORI,[M:ATV2]LANGORI,[M:ATV2]LANGDES,TITLE,LIBEL,1,GBIDC1)
    Endif
   Endif
   DEBLIB  = instr(FINLIB,CLB,'<WebiLib')
  Wend
 Endif
 DEB = instr(FIN,CLOB,"<WebiDoc")
Wend
If GOK<1 : Goto TR_ROLL : Endif
Commit
Return

$TR_ROLL
Rollback
Return

$DELETE_ENREG
Delete [ATV2] Where STA = 0 & ABM = [M:ATV2]DATAMORI & LANTRA = [M:ATV2]LANGDES & RAPORT = [M:ATV2]ETAT(I-1)
If fstat=1 : GOK=-1 : GLOCK="$ABITRAUNV" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ATV2") From GLOCK : Return
Endif
Return

Subprog VERIF_CHOIX2(CUID,STAT)
Value Char       CUID
Variable Integer STAT
Local Integer I,J
STAT =1
I=find(CUID,[M:ATV2]ETATID(0..[M:ATV2]NBETA))
If I
 If [M:ATV2]TRADUC(I-1) <> 2
  STAT = 0
  End
 Endif
Else
 STAT =0
 End
Endif
End

#############################
Funprog ISSP5
Local Char FILEVERSBO(250),MACHINE(250),SERV(10)
Local Integer EXISTE,ISSP5
Local Clbfile CLOB(9)

 Call RECHPROP("busobj.files.path",[L]FILEVERSBO,GBIDI1) From INTRUTILA
Call RECHPROP("component.busobj.servername",[L]MACHINE,GBIDI1) From INTRUTILA
 Call RECHPROP("busobj.adxadmin.port",[L]SERV,GBIDI1) From INTRUTILA
[L]FILEVERSBO = [L]MACHINE+':'+[L]SERV+'@'+[L]FILEVERSBO+"\patch-versions.xml"
Call EXISTE([L]FILEVERSBO,[L]EXISTE) From ORDSYS
If EXISTE

 ## Lecture fichier patch-versions.xml
 Openi [L]FILEVERSBO Using [R1]
 Iomode adxifs  ""  Using [R1]
 Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
 Iomode adxium  GUTF8  Using [R1]

 ## Afectation du clob
 Rdseq CLOB  Using [R1]
 If instr(1,CLOB,"SP5")>0
  [L]ISSP5 = 1
 Endif

Endif
Openi Using [R1]

End ISSP5

#########################################################################################################
$TRADUCTION
# Initialisations
Local Char    LIBTRAD(250)(0..500)
Local Integer NBTRAD , ORD_TRAD(0..500) , ORD , NONTRAD , ONGLET , ER , ISSP5 , ISONGLET

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
NEWFIC = FIC+"new.xml"

If filinfo(FIC,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+NEWFIC+"|"-mess(101,100,1),1) From GESECRAN
 Else
  Call ERREUR("|"+NEWFIC+"|"-mess(101,100,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

[L]ISSP5 = func ISSP5

## Ecriture fichier
Onerrgo ERREURS
Openo NEWFIC , 0 Using [W1]
Iomode adxifs  ""  Using [W1]
Iomode adxirs  chr$(13)+chr$(10)  Using [W1]
Iomode adxium  GUTF8  Using [W1]

## Lecture fichier map.xml
Openi FIC   Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]

## Afectation du clob
Rdseq CLOB  Using [R1]
If !fstat : Rdseq CLOB  Using [R1] : Endif
Openi Using [R1]

DEB = instr(0,CLOB,"<WebiDoc")

### Ecriture debut fichier
If DEB
 Wrseq left$(CLOB,DEB-1) Using [W1]
Else
 Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
 Openo Using [W1]
 adxifs = SAVIFS
 adxirs = SAVIRS
 adxium = SAVIUM
 OK = 0
 Return
Endif

Call ECR_TRACE(mess(72,148,1)-":"-[M:ATV2]LANGORI,0) From GESECRAN : # Langue de référence
Call ECR_TRACE(mess(73,148,1)-":"-[M:ATV2]LANGDES,0) From GESECRAN : # Langue de traduction
Call ECR_TRACE("",0) From GESECRAN

While DEB>0
 FIN = instr(DEB,CLOB,"</WebiDoc")+9
 CLB = seg$(CLOB,DEB,FIN)
 DEBNAM = instr(0,CLB,"name=")+6
 FINNAM = instr(DEBNAM,CLB,'">')-1
 I= instr(0,CLB,'docrepoid="')+11
 J= instr(I,CLB,'"')-1
 WETATID = seg$(CLB,I,J)
 Call VERIF_CHOIX(WETATID,STAT)
 If STAT
  Raz NBTRAD,LIBTRAD,ORD_TRAD
  Call ECR_TRACE(mess(25,42,1)-":"-seg$(CLB,DEBNAM,FINNAM),0) From GESECRAN
  Wrseq left$(CLB,instr(0,CLB,'">'))-'LangDest="'+[M:ATV2]LANGDES+'" FolderDestId="'+[M:ATV2]REPDESID+'">' Using [W1]
  TITLE  = seg$(CLB,DEBNAM,FINNAM)
  Wrseq '<WebiTitle Name="'+TITLE+'">' Using [W1]
  Wrseq '<Title Lang="FRA" TitleValue="'+TITLE+'"/>' Using [W1]
  LIBEL = "" : Call TRAD([M:ATV2]DATAMORI,[M:ATV2]LANGORI,[M:ATV2]LANGDES,TITLE,LIBEL,0,TRADUCTION)
  If [M:ATV2]LANGDES <> "FRA" : Wrseq '<Title Lang="'+[M:ATV2]LANGDES+'" TitleValue="'+TRADUCTION+'"/>' Using [W1] : GBIDC1 = "" : Endif
  Wrseq '</WebiTitle>' Using [W1]
  For [ABO]ABO0
   If [F:ABO]REPCOD = TITLE & [F:ABO]ETAREF = 2
    DESC1 = func ABICREDES.TEXTEBI([F:ABO]DES1,"",[M:ATV2]LANGDES) : # func AFNC.TEXTE([F:ABO]DES1)
    DESC2 = func ABICREDES.TEXTEBI([F:ABO]DES2,"",[M:ATV2]LANGDES) : # func AFNC.TEXTE([F:ABO]DES2)
    DESC3 = func ABICREDES.TEXTEBI([F:ABO]DES3,"",[M:ATV2]LANGDES) : # func AFNC.TEXTE([F:ABO]DES3)
   Endif
  Next
  If DESC1 <> "" | DESC2 <> "" |DESC3 <> ""
   Wrseq '<WebiDescription Name="Description">' Using [W1]
   Wrseq '<Description Lang="'+[M:ATV2]LANGDES+'" DescriptionValue="'+DESC1-DESC2-DESC3+'"/>' Using [W1]
   Wrseq '</WebiDescription>' Using [W1]
  Endif
  DEBLIB  = instr(DEBNAM,CLB,'<WebiLib')
  While DEBLIB > 0
   ONGLET = 0
   ISONGLET = 0
   FINLIB  = instr(DEBLIB,CLB,'/>')-1
   CHAINE  = seg$(CLB,DEBLIB,FINLIB)
   LIBEL   = seg$(CHAINE,instr(0,CHAINE,'Key="')+5,len(CHAINE)-1)
   If instr(0,CHAINE,"OMReport") : ONGLET = 1 : ISONGLET= 1 : Endif
   If instr(0,CHAINE,"OMConstantFormula") : ONGLET = 1 : Endif
   If !ISONGLET or !ISSP5
    Wrseq CHAINE+'>' Using [W1]
    Wrseq '<Lib Lang="FRA" LibValue="'+LIBEL+'"/>'  Using [W1]
    If !instr(1,LIBEL,"§FOR_") & pat(LIBEL,"*?*")
     If pat(LIBEL,"§???_*")
      PREFIX = left$(LIBEL,5)
      LIBEL = right$(LIBEL,6)
     Endif
     If pat(LIBEL,"*?*") > 0
      Call TRAD([M:ATV2]DATAMORI,[M:ATV2]LANGORI,[M:ATV2]LANGDES,TITLE,LIBEL,0,TRADUCTION)
     Else
      PREFIX = ""
     Endif
    Else
     TRADUCTION = LIBEL
    Endif
    Call VERIF_TRADUC([M:ATV2]DATAMORI,TITLE,[M:ATV2]LANGORI,LIBEL,NONTRAD)
    If !NONTRAD & len(LIBEL) > 1 & ONGLET=0
     ORD = find(PREFIX+TRADUCTION,LIBTRAD(0..NBTRAD))
    If !ORD
     LIBTRAD(NBTRAD) = PREFIX+TRADUCTION
    Else
     ORD_TRAD(ORD) +=1
     LIBTRAD(NBTRAD) += PREFIX+TRADUCTION+"_"+num$(ORD_TRAD(ORD))
     Call ECR_TRACE(mess(69,104,1)-":"-LIBTRAD(NBTRAD),-1) From GESECRAN #  : Doublon
    Endif
    TEXTETRAD = LIBTRAD(NBTRAD)
    Else
     TEXTETRAD = TRADUCTION
    Endif
    Wrseq '<Lib Lang="'+[M:ATV2]LANGDES+'" LibValue="'+TEXTETRAD+'"/>' Using [W1]  : GBIDC1 = "" : # bug trd vers fra
    NBTRAD +=1
    Wrseq '</WebiLib>' Using [W1]
   Endif
   PREFIX = ""
   DEBLIB  = instr(FINLIB,CLB,'<WebiLib')
  Wend
  Wrseq '</WebiDoc>' Using [W1]
 Endif
 DEB = instr(FIN,CLOB,"<WebiDoc")
Wend
Wrseq '</X3WebiDocMap>' Using [W1]

Openo Using [W1]

Call MOVE(FIC,FIC+".old",STAT) From ORDSYS
Call MOVE(NEWFIC,FIC,STAT) From ORDSYS
Call EFFACE(NEWFIC,STAT) From ORDSYS

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

Subprog VERIF_CHOIX(CUID,STAT)
Value Char       CUID
Variable Integer STAT
Local Integer I,J
STAT =1
I=find(CUID,[M:ATV2]ETAIDNEW(0..[M:ATV2]NBETA))
If I
 If [M:ATV2]TRADUC(I-1) <> 2
  STAT = 0
  End
 Endif
Else
 STAT =0
 End
Endif
End


Subprog VERIF_TRADUC(ABM,TITLE,LANGORI,LIB,NONTRAD)
Value Char       ABM
Value Char       TITLE
Value Char       LANGORI
Value Char       LIB
Variable Integer NONTRAD
NONTRAD =0
Read [ATV]ATV0 = ABM;TITLE;LANGORI;LIB
If !fstat
 If [F:ATV]TYPERR = 1
  NONTRAD = 1
 Endif
Endif
End

######################################################################################
Subprog TRAD(ABM,LANGORI,LANG,TITLE,LIB,CREA,TRADUC)
Value Char ABM
Value Char LANGORI
Value Char LANG
Value Char TITLE
Value Char LIB
Value Integer CREA
Variable Char TRADUC

If LIB = ""
 TRADUC = TITLE
Else
 TRADUC = LIB
Endif

If TRADUC="" | TRADUC=" " : End : Endif

Read [ATV]ATV0 = ABM;TITLE;LANG;TRADUC
If !fstat
 If CREA : End : Endif
 Case [ATV]TYPERR
  When 1 : # texte inexistant dans lal langue d'origine
   Call ECR_TRACE(TRADUC -":"-mess(71,148,1),-1) From GESECRAN
  When 2 : # texte sans trad
   Call ECR_TRACE(TRADUC -":"-mess(74,148,1),-1) From GESECRAN
  When 3 : # doublon
   If [ATV]STA = 2
    Read [ATX]TEXTE =LANG;[F:ATV]TXTREF
    If !fstat
     TRADUC = [ATX]TEXTE
    Else
     TRADUC = [F:ATV]TXTTRA
    Endif
   Else
    Call ECR_TRACE(TRADUC -":"-mess(75,148,1),-1) From GESECRAN : # Doublon dans la langue de traduction
   Endif
  When 4 : # traduit
   Read [ATX]NUMERO =LANG;[F:ATV]TXTREF
   If !fstat
    TRADUC = [ATX]TEXTE
   Else
    TRADUC = [F:ATV]TXTTRA
   Endif
 Endcase
 End
Endif

Local Integer NBTEX,VALEUR
Local Char    TEX(80)(0..60)
Local Char    RESULT(80)(0..60)
Local Integer OK,STAT

For [ATX]TEXTE Where LAN=[M:ATV2]LANGORI & TEXTE=TRADUC
 OK =1
 For [ATX2] Where NUMERO = [ATX]NUMERO & LAN = LANG
  NBTEX += 1
  TEX(NBTEX) = format$("N:7#",[F:ATX2]NUMERO)
  TEX(NBTEX) -= [ATX2]TEXTE : RESULT(NBTEX) = [ATX2]TEXTE
  If dim([F:ATX2]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX2]COMMENT+")" : Endif
 Next
Next
If CREA
 Gosub SYNCH
Else
 Gosub FICH
Endif
End

$FICH
If NBTEX = 1 & OK =1
 TRADUC = [F:ATX2]TEXTE
Endif
If NBTEX = 0 & OK =0 : # pas de texte du tout
 Call ECR_TRACE(TRADUC -":"-mess(71,148,1),-1) From GESECRAN
Elsif NBTEX = 0 & OK = 1
 Call ECR_TRACE(TRADUC -":"-mess(74,148,1),-1) From GESECRAN : # "Texte non traduit dans la langue de traduction"
Elsif NBTEX > 1
 Read [ATV]ATV0 = ABM;TITLE;LANGORI;TRADUC
 If !fstat
  If [ATV]TYPERR = 4 & [ATV]STA =2
   Read [ATX]NUMERO = LANG;[F:ATV]TXTREF
   If !fstat
    TRADUC = [ATX]TEXTE
   Else
    TRADUC = [F:ATV]TXTTRA
   Endif
  Else
   Call ECR_TRACE(TRADUC -":"-mess(75,148,1),-1) From GESECRAN : # Doublon dans la langue de traduction
   Return
  Endif
 Else
  Call ECR_TRACE(TRADUC -":"-mess(75,148,1),-1) From GESECRAN : # Doublon dans la langue de traduction
 Endif
Endif
Return

$SYNCH
Raz [F:ATV2]
[F:ATV2]RAPORT = TITLE
[F:ATV2]TEXTE  = TRADUC
[F:ATV2]LANREF = [M:ATV2]LANGORI
[F:ATV2]LANTRA = LANG
[F:ATV2]ABM    = [M:ATV2]DATAMORI
If NBTEX = 1 & OK =1
 Call ECR_TRACE(mess(6,14,1)-LANG-"->"-TRADUC -":"-[F:ATX2]TEXTE,0) From GESECRAN  : # mess(6,14,1) : Traductions
 [F:ATV2]TXTREF = [ATX]NUMERO
 [F:ATV2]TXTTRA = [ATX2]TEXTE
 [F:ATV2]TYPERR = 4
Elsif NBTEX = 0 & OK =0 : # pas de texte du tout
 Call ECR_TRACE(TRADUC -":"-mess(71,148,1),-1) From GESECRAN
 [F:ATV2]TYPERR = 1
Elsif NBTEX = 0 & OK = 1
 Call ECR_TRACE(TRADUC -":"-mess(74,148,1),-1) From GESECRAN
 [F:ATV2]TYPERR = 2
Elsif NBTEX > 1
 Read [ATV]ATV0 = ABM;TITLE; LANG;TRADUC
 If !fstat
  Return
 Else
  Call ECR_TRACE(TRADUC -":"-mess(75.,148,1),-1) From GESECRAN : # Doublon dans la langue de traduction
  [F:ATV2]TYPERR = 3
 Endif
Endif
Write [ATV2]
If fstat
 GOK=0 : Call FSTA("ATV2") From GLOCK
Endif
Return

##################################################################################################
$GENE_MAP
Gosub CRE_TOOL2

ORDRE = ''
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+MAPCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM+'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'Map_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Map_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Map_'+num$(adxuid(1))+'.err" '

If GINFO
 Call AFF_VLC(mess(130,148,1)-":",[M:ATV2]COMPBONAM+'\'+'Map_'+num$(adxuid(1))+'.xml') From GESECRAN
Endif

ORDSYS(1)= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3map_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3map_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Endif
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Map_'+num$(adxuid(1))+'.out',OUT)
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'Map_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Map_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

Call CHECK_ERR([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Map_'+num$(adxuid(1))+'.err',OUT)
If OUT
 If GTRACE <> ""
  Call ECR_TRACE('Map_'+num$(adxuid(1))-":"-mess(505,153,1),1) From GESECRAN
 Else
  Call ERREUR('Map_'+num$(adxuid(1))-":"-mess(505,153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

Return

##################################################################################################

$GENE_UNIV
Local Char CHAINE(100)(0..100)
Local Integer NB , ER
Call ECR_TRACE(mess(034,9021,1)-":",0) From GESECRAN : # Liste des états
DOCPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocList_'+num$(adxuid(1))+'.properties'
UNIPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'UnivList_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier liste univers
Onerrgo ERREURS
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+UNIPRO ,0  Using [U1]
Iomode adxifs  ""  Using [U1]
Iomode adxirs  chr$(13)+chr$(10)  Using [U1]
Iomode adxium  GUTF8  Using [U1]

For I=0 To [M:ATV2]NBETA-1
 If [M:ATV2]TRADUC(I) = 2
  If ! find([M:ATV2]UNIVERS(I)+";"+[M:ATV2]UNIVDES+";"+[M:ATV2]ETAUNVID(I)+';'+[M:ATV2]UNIVDESID,CHAINE(0..NB))
   Wrseq [M:ATV2]UNIVERS(I)+";"+[M:ATV2]UNIVDES+";"+[M:ATV2]ETAUNVID(I)+';'+[M:ATV2]UNIVDESID Using [U1]
   CHAINE(NB) = [M:ATV2]UNIVERS(I)+";"+[M:ATV2]UNIVDES+";"+[M:ATV2]ETAUNVID(I)+';'+[M:ATV2]UNIVDESID
   NB += 1
  Endif
 Endif
Next I
Openo Using [U1]

## Ecriture fichier liste documents
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+DOCPRO , 0  Using [D1]
Iomode adxifs  ""  Using [D1]
Iomode adxirs  chr$(13)+chr$(10)  Using [D1]
Iomode adxium  GUTF8  Using [D1]
For I=0 To [M:ATV2]NBETA-1
 If [M:ATV2]TRADUC(I) = 2
  Wrseq [M:ATV2]ETAT(I)+';'+[M:ATV2]ETAT(I)+';'+[M:ATV2]ETATID(I)+';'+[M:ATV2]REPDESID Using [D1]
 Endif
Next I
Openo Using [D1]

For I=0 To [M:ATV2]NBETA-1
 If[M:ATV2]TRADUC(I) = 2
  Call ECR_TRACE("  -"-[M:ATV2]ETAT(I),0) From GESECRAN
 Endif
Next I

$GENE_UNIV2

ORDRE = ''
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+UNIVCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'Univ_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Univ_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Univ_'+num$(adxuid(1))+'.err"'

If GINFO
 Call AFF_VLC(mess(131,148,1)-":","") From GESECRAN
Endif

ORDSYS(1) = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3univ_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3univ_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Endif
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Univ_'+num$(adxuid(1))+'.out',OUT)
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'Univ_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Univ_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

Call CHECK_ERR([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Univ_'+num$(adxuid(1))+'.err',OUT)
If OUT
 If GTRACE <> ""
  Call ECR_TRACE('Univ_'+num$(adxuid(1))-":"-mess(505,153,1),1) From GESECRAN
 Else
  Call ERREUR('Univ_'+num$(adxuid(1))-":"-mess(505,153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

Return

##################################################################################################
$GENE_TRANS
ORDRE = ''
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+TRANSCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'Trans_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Trans_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Trans_'+num$(adxuid(1))+'.err"'

If GINFO
 Call AFF_VLC(mess(132,148,1)-":","") From GESECRAN
Endif

Call ECR_TRACE(mess(6,14,1)-":",0) From GESECRAN : #  Traductions
For I=0 To [M:ATV2]NBETA-1
 If[M:ATV2]TRADUC(I) = 2
  Call ECR_TRACE("  -"-[M:ATV2]ETAT(I),0) From GESECRAN
 Endif
Next I

ORDSYS(1) =[M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3trans_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3trans_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Endif
Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Trans_'+num$(adxuid(1))+'.out',OUT)
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'Trans_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Trans_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

Call CHECK_ERR([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Trans_'+num$(adxuid(1))+'.err',OUT)
If OUT
 If GTRACE <> ""
  Call ECR_TRACE('Trans_'+num$(adxuid(1))-":"-mess(505,153,1),1) From GESECRAN
 Else
  Call ERREUR('Trans_'+num$(adxuid(1))-":"-mess(505,153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

Return

##################################################################################################
$GENE_TOOL

ORDRE = ''
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+TOOLCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'Tool_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Tool_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\Tmp\'+[M:ATV2]COMPBONAM+'\'+'Tool_'+num$(adxuid(1))+'.err" '

If GINFO
 Call AFF_VLC(mess(133,148,1)-":",[M:ATV2]COMPBONAM+'\'+'Tool_'+num$(adxuid(1))+'.xml') From GESECRAN
Endif

ORDSYS(1) =  [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3tool_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3tool_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)
Endif

Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Tool_'+num$(adxuid(1))+'.out',OUT)
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'Tool_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Tool_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

If OUT=99
 If GTRACE <> ""
  Call ECR_TRACE(mess(142,148,1),1) From GESECRAN : # "Serveur BO pas à jour, veuillez contacter votre administrateur"
 Else
  Call ERREUR(mess(142,148,1)) From GESECRAN : # "Serveur BO pas à jour, veuillez contacter votre administrateur"
 Endif
 OK =0
 Return
Endif

Call CHECK_ERR([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\Tool_'+num$(adxuid(1))+'.err',OUT)
If OUT
 If GTRACE <> ""
  Call ECR_TRACE('Tool_'+num$(adxuid(1))-":"-mess(505,153,1),1) From GESECRAN
 Else
  Call ERREUR('Tool_'+num$(adxuid(1))-":"-mess(505,153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

##################################################################################################
$CRE_PARAM
## Ecriture fichier
Onerrgo ERREURS

DOCPRO     = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocList_'+num$(adxuid(1))+'.properties'
UNIPRO     = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'UnivList_'+num$(adxuid(1))+'.properties'
DOCFILTPRO = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocListFilter_'+num$(adxuid(1))+'.properties'
IMPPRO     = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
# Ecriture Param
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICPARAM , 0 Using [W1]
Iomode adxifs  ""  Using [W1]
Iomode adxirs  chr$(13)+chr$(10)  Using [W1]
Iomode adxium  GUTF8  Using [W1]

Wrseq '<?xml version="1.0" encoding="utf-8"?>' Using [W1]
Wrseq '<parameters>' Using [W1]
Wrseq '<bo.connect.server>'+[M:ATV2]MACHINE+'</bo.connect.server>' Using [W1]
Wrseq '<bo.connect.port>'+[M:ATV2]PORTREST+'</bo.connect.port>' Using [W1]
If dim(GFUSION)>0 & GFUSION>0
 Wrseq '<bo.connect.token>'+[M:ATV2]FICTOKEN+'</bo.connect.token>' Using [W1]
Else
 Wrseq '<bo.connect.user>'+[M:ATV2]USRBI+'</bo.connect.user>' Using [W1]
 Wrseq '<bo.connect.passwd>'+[M:ATV2]PWDBI+'</bo.connect.passwd>' Using [W1]
Endif
Wrseq '<bo.connect.type>secEnterprise</bo.connect.type>' Using [W1]
Wrseq '<utils.out.list>'+[M:ATV2]FICLIST+'</utils.out.list>' Using [W1]
Wrseq '<utils.out.map>'+[M:ATV2]FICMAP+'</utils.out.map>' Using [W1]
Wrseq '<utils.out.tools>'+[M:ATV2]FICTOOL+'</utils.out.tools>' Using [W1]
Wrseq '<utils.solution.install>'+GREPSOLIND+'</utils.solution.install>' Using [W1]
Wrseq '<utils.solution.work>'+GINSTID+'</utils.solution.work>' Using [W1]
Wrseq '<utils.x3.folder>'+[M:ATV2]DATAW+'</utils.x3.folder>' Using [W1]
Wrseq '<utils.x3.folderlang>'+[M:ATV2]LANGDES+'</utils.x3.folderlang>' Using [W1]
Wrseq '<utils.input.list>'+[M:ATV2]FICTOOL2+'</utils.input.list>' Using [W1]
Wrseq '<utils.input.map>'+[M:ATV2]FICMAP+'</utils.input.map>' Using [W1]
Wrseq '<utils.univsrc.path>universes</utils.univsrc.path>' Using [W1]
Wrseq '<utils.univdest.path>universes</utils.univdest.path>' Using [W1]
Wrseq '<utils.doclist.path>'+DOCPRO+'</utils.doclist.path>' Using [W1]
Wrseq '<utils.doclistfilter.path>'+DOCFILTPRO+'</utils.doclistfilter.path>' Using [W1]
Wrseq '<utils.univlist.path>'+UNIPRO+'</utils.univlist.path>' Using [W1]
Wrseq '<utils.folder.filter>'+REPBIS+'</utils.folder.filter>' Using [W1]
Wrseq '<utils.folder.filter.level2.1>'+REPBIS21+'</utils.folder.filter.level2.1>' Using [W1]
Wrseq '<utils.folder.filter.level2.2>'+REPBIS22+'</utils.folder.filter.level2.2>' Using [W1]
Wrseq '<utils.universe.list>'+UNIVLIST+'</utils.universe.list>' Using [W1]
Wrseq '<utils.webi.list>'+WEBILIST+'</utils.webi.list>' Using [W1]
Wrseq '<utils.webi.listuniverses>'+WEBIUNV+'</utils.webi.listuniverses>' Using [W1]
Wrseq '<utils.solution.create>'+SOLCREA+'</utils.solution.create>' Using [W1]
Wrseq '<utils.impbiar.path>'+IMPPRO+'</utils.impbiar.path> ' Using [W1]
Wrseq '<utils.install.sage>'+GREPBI+'</utils.install.sage> ' Using [W1]
If dim(IMPORT)>0
 Wrseq '<utils.import.sage>'+IMPORT+'</utils.import.sage> ' Using [W1]
Endif
If dim([M:DIA]MODVAR)>0
 Wrseq '<utils.fix.variables>'+string$([M:DIA]MODVAR<>2,"FALSE")+string$([M:DIA]MODVAR=2,"TRUE")+'</utils.fix.variables>' Using [W1]
Else
 Wrseq '<utils.fix.variables>TRUE</utils.fix.variables>' Using [W1]
Endif
Wrseq '</parameters>' Using [W1]
Openo Using [W1]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return



Subprog ECRITURE_COMMANDE(FICHIER,ORDRE)
Value    Char    FICHIER
Variable Clbfile ORDRE
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,ER
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
## Ecriture fichier Ordre
Onerrgo ERREURS
Openo FICHIER, 0 Using [O1]
Iomode adxifs  ""  Using [O1]
Iomode adxirs  chr$(13)+chr$(10)  Using [O1]
Iomode adxium  GUTF8  Using [O1]
Wrseq ORDRE Using [O1]
Openo Using [O1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

$ERREURS
ER = errn
GMESSAGE = errp+"("+num$(errl)+")"-errm
If ER>0 : GMESSAGE += errmes$(ER) : Endif
If GTRACE<>""
 Call ECR_TRACE(GMESSAGE,ER) From GESECRAN
Endif
GMESSAGE = ""
Resume

$CRE_TOOL2
Local Integer DEB_WEBI , ER

# Initialisations

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+[M:ATV2]FICTOOL+"|"-mess(101,100,1),1) From GESECRAN
 Else
  Call ERREUR("|"+[M:ATV2]FICTOOL+"|"-mess(101,100,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

## Ecriture fichier

Onerrgo ERREURS

Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL2 ,0 Using [W1]
Iomode adxifs  ""  Using [W1]
Iomode adxirs  chr$(13)+chr$(10)  Using [W1]
Iomode adxium  GUTF8  Using [W1]

## Lecture fichier tool.xml et afectation du clob
Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL Using [R1] : # CCL
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]

DEB = instr(1,CLOB,"<Folders_And_Webis")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(1,CLOB,"<Folders_And_Webis")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  Return
 Endif
Endif

FINS = instr(1,CLOB,"</Folders_And_Webis")
If !FINS
 Call ECR_TRACE(mess(92,148,1),1) From GESECRAN : # "Aucun états trouvés dans l'Infoview"
 Return
Endif

Local Integer BALISEFIN

BALISEFIN = instr(1,CLOB,"<Document_Folder_Navigation")

Openi Using [R1]

DEB_WEBI = instr(DEB,CLOB,'"Folders_And_Webis">')+20
Wrseq seg$(CLOB,1,DEB_WEBI-1) ; Using [W1]
Gosub PARCOURS_FOLDERS
Wrseq '</Folders_And_Webis>' ;   Using [W1]
Wrseq '</BO_Navigation>' ; Using [W1]
If BALISEFIN>0
 Wrseq '</Document_Folder_Navigation>' ; Using [W1]
Else
 Wrseq '</X3WebiDocMap>' ; Using [W1]
Endif
Openo Using [W1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$PARCOURS_FOLDERS
STAT = 0
H=find(GREPBI,[M:ATV2]DOS(0..[M:ATV2]NBDOS))
Wrseq '<Folder CUID="" Id="'+[M:ATV2]DOSID(H-1)+'" Name="'+[M:ATV2]DOS(H-1)+'" ParentID="'+[M:ATV2]DOSIDFAT(H-1)+'">' ; Using [W1]

For I=0 To [M:ATV2]NBDOS-1
 If [M:ATV2]DOSIDFAT(I) = [M:ATV2]DOSID(H-1)
  Wrseq '<Folder CUID="" Id="'+[M:ATV2]DOSID(I)+'" Name="'+[M:ATV2]DOS(I)+'" ParentID="'+[M:ATV2]DOSIDFAT(I)+'">' ; Using [W1]
   For J = 0 To [M:ATV2]NBDOS-1
    If [M:ATV2]DOSIDFAT(J) = [M:ATV2]DOSID(I)
     Wrseq '<Folder CUID="" Id="'+[M:ATV2]DOSID(J)+'" Name="'+[M:ATV2]DOS(J)+'" ParentID="'+[M:ATV2]DOSIDFAT(J)+'">' ; Using [W1]
      For K = 0 To [M:ATV2]NBDOS-1
       If [M:ATV2]DOSIDFAT(K) = [M:ATV2]DOSID(J)
        Wrseq '<Folder CUID="" Id="'+[M:ATV2]DOSID(K)+'" Name="'+[M:ATV2]DOS(K)+'" ParentID="'+[M:ATV2]DOSIDFAT(K)+'">' ; Using [W1]
         For L=0 To [M:ATV2]NBETA-1
           If [M:ATV2]CHOIX = 1
            If [M:ATV2]ETAIDFAT(L) = [M:ATV2]DOSID(K)
             Call VERIF_CHOIX2([M:ATV2]ETATID(L),STAT)
             If STAT
              Wrseq '<WebiDoc Id="'+[M:ATV2]ETATID(L)+'" ParentID="'+[M:ATV2]ETAIDFAT(L)+'" Title="'+[M:ATV2]ETAT(L)+'"/>' ;  Using [W1]
             Endif
            Endif
           Else
            If [M:ATV2]REPDESID = [M:ATV2]DOSID(K)
             Call VERIF_CHOIX([M:ATV2]ETAIDNEW(L),STAT)
             If STAT
              Wrseq '<WebiDoc Id="'+[M:ATV2]ETAIDNEW(L)+'" ParentID="'+[M:ATV2]REPDESID +'" Title="'+[M:ATV2]ETAT(L)+'"/>' ;  Using [W1]
             Endif
            Endif
           Endif
           STAT = 0
         Next L
        Wrseq '</Folder>'  ; Using [W1]
       Endif
      Next K
     Wrseq '</Folder>'  ; Using [W1]
    Endif
   Next J
  Wrseq '</Folder>'  ; Using [W1]
 Endif
Next I
Wrseq '</Folder>'  ; Using [W1]
Return


$CRE_DOCLISTFILT
DOCFILTPRO = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocListFilter_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier
Onerrgo ERREURS
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+DOCFILTPRO , 0 Using [W1]
Iomode adxifs  ""  Using [W1]
Iomode adxirs  chr$(13)+chr$(10)  Using [W1]
Iomode adxium  GUTF8  Using [W1]

Filter [F:ABO] Where DATAM = [M:ATV2]DATAMORI & ENAFLG=2
For [F:ABO]
 Wrseq [F:ABO]REPCOD Using [W1]
Next
Filter [F:ABO]
Openo Using [W1]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return


Subprog FICHIER_OUT(FICHIER,OK)
Value      Char FICHIER
Variable   Integer OK
Local Clbfile CLOB(9)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,ER
OK = 0

If filinfo(FICHIER,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+FICHIER+"|"-mess(101,100,1),1) From GESECRAN  : # : Fichier inexistant
 Else
  Call ERREUR("|"+FICHIER+"|"-mess(101,100,1)) From GESECRAN  : # : Fichier inexistant
 Endif
 OK =1
 End
Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Openi FICHIER,0 Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  ""  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

If instr(0,CLOB,"#@~-SAGE-~@#OK")
 OK = 0
Elsif instr(0,CLOB,"#@~-SAGE-~@#KO")
 OK =1
Else
 OK =99
Endif

End

Subprog CHECK_ERR(FICHIER,OK)
Value      Char FICHIER
Variable   Integer OK
Local Clbfile CLOB(9)
Local Char    SAVIFS(5),SAVIRS(5),LIGNE(250)
Local Integer SAVIUM,ER
OK = 0

If filinfo(FICHIER,7)<0
 If GTRACE <> ""
  Call ECR_TRACE("|"+FICHIER+"|"-mess(101,100,1),1) From GESECRAN  : # : Fichier inexistant
 Else
  Call ERREUR("|"+FICHIER+"|"-mess(101,100,1)) From GESECRAN  : # : Fichier inexistant
 Endif
 OK =1
 End
Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Openi FICHIER,0 Using [R1]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  ""  Using [R1]
Iomode adxium  GUTF8  Using [R1]
OK = 0
Rdseq LIGNE Using [R1]
While !fstat
 If LIGNE<>""
   If GTRACE <> ""
    Call ECR_TRACE(LIGNE,0) From GESECRAN
   Endif
   If !instr(1,toupper(LIGNE),"WARNING")
    OK = 1 : Break
   Endif
  Endif
 Rdseq LIGNE Using [IMP]
Wend
If !OK and LIGNE<>""
 If GTRACE <> ""
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif
 If !instr(1,toupper(LIGNE),"WARNING")
  OK = 1
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

