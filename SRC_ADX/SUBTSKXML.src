#<AdxTL>@(#)5.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'une Tâche                                                              Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################

Subprog TSKINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(1195, SZHTMLTITLE) From OBJDIV      #Tâche
SZSUBPROG = "TSKINXML"
SZAOBABREV = "TSK"

Gosub XMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREXML

Gosub XMLPART3 From CRMXML140

End

#########################################################################################################################
Subprog TSKLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZFILTER = ""
    SZFILTER = "1=1"
Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14664, SZHTMLTITLE) From OBJDIV      #Tâches
SZSUBPROG = "TSKLISTXML"
SZAOBABREV = "TSK"

Gosub XMLPART2B From CRMXML140
If IERRINF : End : Endif

Gosub DOLISTXML

Gosub XMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML

Gosub SETTSKEXCEPT From CRMEXCEPT

#On extrait
Filter [TSK] Where evalue(SZFILTER)

For [TSK]
    SZCTAOB = "TSK"
    SZCTAOBNUM = [F:TSK]TSKNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLTSK From CRMEXCEPT
Next

Filter [TSK]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML

Gosub SETTSKEXCEPT From CRMEXCEPT

#On extrait
Filter [TSK] Where [F:TSK]TSKNUM = SZRECNUM

For [TSK]
    SZCTAOB = "TSK"
    SZCTAOBNUM = [F:TSK]TSKNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLTSK From CRMEXCEPT
Next

Filter [TSK]

Return




