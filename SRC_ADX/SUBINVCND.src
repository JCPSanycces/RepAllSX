#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet INVCND) 28/10/2015 13:35:17 (CPO)
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
######################################################################################
End
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "FERME"       : Gosub FERME
  When "LIENS"       : Gosub LIENS
  When "AFFMASK"     : Gosub AFFMASK
  #--Update
  When "MODIF"       : Gosub MODIF
  When "APRES_MOD"   : Gosub APRES_MOD
  #--Create
  When "RAZCRE"      : Gosub RAZCRE
  When "RAZDUP"      : Gosub RAZDUP
  When "CREATION"    : Gosub CREATION
  When "APRES_CRE"   : Gosub APRES_CRE
  #--Delete
  When "AV_ANNULE"   : Gosub AV_ANNULE
  When "ANNULE"      : Gosub ANNULE
  #--Copy
  #
  #--Code changing
 #--Code changing
  When "CHGCOD"      : Gosub CHGCOD        # X3-4924 Manage change key fonction on invoice term (JUCON 18/11/16)
  When "AP_CHANGE"   : Gosub AP_CHANGE     # X3-4924 Manage change key fonction on invoice term (JUCON 18/11/16)
  #--Other
  When "SETBOUT"     : Gosub SETBOUT
  When "SEL_TABLE"   : Case TABLE :      When "SELINVCND"    : Gosub SELINVCND :    Endcase
  When Default
Endcase
Return
######################################################################################
$OUVRE
Local Integer WRET # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification

  #--Hybride mode ON
  ANOWRITE = 1
  Global Instance GCLSINVCND Using C_TABINVCND
  #--

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  GCLSINVCND = NewInstance C_TABINVCND AllocGroup null
  #--Mandatory to call in order to have the context ACTX set before the first snapshot
  WRET = fmet GCLSINVCND.AINIT()
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR=1
      WRET = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Else
      GERR=2
      WRET = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif
  If GERR=1 : OK=0 : Return : Endif
  # End issue X3-38457

  #-----------------------------------#
  # Sauvegarde des variables globales #
  #-----------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #--Lors d'un tunnel depuis un document (exemple : livraison)
  Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes

Return
#-------------------------------------------------------------------------------------
$MODIF
Local Integer MY_STATUS, I, WILINE, WRET

  #----FOR HYBRID MODE----
  If dim(GCLSINVCND)>0 and GCLSINVCND<>null
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN")
  Endif

  #-----------------------------
  Gosub SET_CLS_WITH_M
  If (GERR = 1) : Return : Endif
  #-----------------------------

  [L]MY_STATUS = fmet GCLSINVCND.AUPDATE()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If GMESSAGE<>"" # Ini SAM 120866 JUCON 12/01/2017
      Local Char WTXT(250), WERR(250)
      Call TEXTE(56729,WTXT) From OBJDIV
      If left$(GMESSAGE,7)="FREQINV": WERR=seg$(GMESSAGE,9,len(GMESSAGE)): WERR=WTXT-":"+WERR: GMESSAGE=WERR: Endif
    Endif           # End SAM 120866 JUCON 12/01/2017
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif

  Gosub LIENS
  #----END FOR HYBRID MODE----

Return
#-------------------------------------------------------------------------------------
$LIENS
Local Integer MY_STATUS, WILINE,SAV_NOLIGN,WRET

  #----FOR HYBRID MODE----
  #--Loading screen throught the class AREAD Method
  If (GCLSINVCND <> null) : FreeGroup GCLSINVCND : GCLSINVCND=null : Endif
  GCLSINVCND = NewInstance C_TABINVCND AllocGroup null

  [L]MY_STATUS = fmet GCLSINVCND.AREAD([M:INVCND1]INVCND,[M:INVCND1]LEG)
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif
  #--Loading header properties into the screen, from the class
  Gosub SET_M_INVCND1_WITH_CLS
  If GERR = 1 Then
    Return
  Endif
  #--
  #--Once the class is loaded, we have to load the collection lines into the screen
  #--We could do it directly from looping on the F file, but we prefer loading from collection lines of the class
  #--For "Periodicity" invoice mode, there is only the header
  If [M:INVCND1]INVCNDTYP<>3
    Actzo  [M:INVCND1]NBLIG
    #--ActiINVCNDing the lines
    Chgfmt [M:INVCND1]NBLIG      With "+N:3"
    Grizo  [M:INVCND1]15
    nolign=0
    For WILINE=1 To maxtab(GCLSINVCND.INVCNDLIN)
      If GCLSINVCND.INVCNDLIN(WILINE)<>null and find(GCLSINVCND.INVCNDLIN(WILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        nolign += 1
        Gosub SET_M_INVCND1_WITH_CLS_LINE
        If GERR = 1 Then
          Break #Return
        Endif
      Endif
    Next
    [M:INVCND1]NBLIG=nolign
  Else
    #--"Periodicity" type
    #--No lines to handle
    nolign=0 : [M:INVCND1]NBLIG=0
    Grizo  [M:INVCND1]NBLIG
    Chgfmt [M:INVCND1]NBLIG      With "-N:3"
    Actzo  [M:INVCND1]15
  Endif
  If GERR = 1 Then
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Return
  Endif
  #----END FOR HYBRID MODE----
Return
#-------------------------------------------------------------------------------------
$RAZCRE
Local Integer MY_STATUS,WILINE,WRET

  #----FOR HYBRID MODE----
  #--Initializing screen throught the class AINIT Method
  If (GCLSINVCND <> null) : FreeGroup GCLSINVCND : GCLSINVCND=null : Endif
  GCLSINVCND = NewInstance C_TABINVCND AllocGroup null

  [L]MY_STATUS = fmet GCLSINVCND.AINIT()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif
  #--
  #--Now, we have to load the properties into the screen INVCND1
  Gosub SET_M_INVCND1_WITH_CLS
  If GERR = 1 Then
    Return
  Endif
  Affzo [M:INVCND1]1-99
  #--
  #----END FOR HYBRID MODE----
  [M:INVCND1]INVCNDTYP=2                    ## 107888 Scheduled invoiced (JUCON 24/01/16)
  Affzo  [M:INVCND1]INVCNDTYP               ## 107888 Scheduled invoiced (JUCON 24/01/16)
  Call AM_INVCNDTYP([M:INVCND1]INVCNDTYP)   ## 107888 Scheduled invoiced (JUCON 24/01/16)

  Gosub GRILEG
Return
#-------------------------------------------------------------------------------------
$RAZDUP
Local Integer MY_STATUS,WILINE,WRET

  #----FOR HYBRID MODE----
  If (GCLSINVCND <> null) : FreeGroup GCLSINVCND : GCLSINVCND=null : Endif
  GCLSINVCND = NewInstance C_TABINVCND AllocGroup null

  [L]MY_STATUS = fmet GCLSINVCND.AINIT()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif
  #----END FOR HYBRID MODE----
  #--
  #Affzo [M:INVCND1]1-99
  #--

Return
#-------------------------------------------------------------------------------------
$SET_CLS_WITH_M
Local Integer OLD_MAXTAB,WILINE,WIJSAVE_NOLIGN,WRET

  WIJSAVE_NOLIGN = nolign

  #--Header properties
  SetInstance GCLSINVCND With [F:INVCND]
  Gosub SET_CLS_WITH_M_INVCND1
  If GERR = 1 Then
    GOK=0
    Return
  Endif

  OLD_MAXTAB = maxtab(GCLSINVCND.INVCNDLIN)
  #--Lines properties
  For I = 0 To [M:INVCND1]NBLIG-1
    # Retrieve the element using the screen's AUUID
    WILINE=0
    If [M:INVCND1]AUUID(I)<>""
      #--We have to consider the ASTALIN
      #ILINE = find(toUuid([M:INVCND1]AUUID(I)), GCLSINVCND.INVCNDLIN(1..maxtab(GCLSINVCND.INVCNDLIN)).AUUID)
      WILINE = sigma(1,OLD_MAXTAB,
&      (indcum)*(find(GCLSINVCND.INVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                toUuid([M:INVCND1]AUUID(I))=GCLSINVCND.INVCNDLIN(indcum).AUUID))
    Endif
    If (WILINE = 0)
      # We did not find the element matching with the array line.
      # We add a line.
      WILINE = fmet GCLSINVCND.ADDLINE("INVCNDLIN", [V]CST_ALASTPOS)
      If (WILINE = [V]CST_ANOTDEFINED)
        # Error management
#        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GCLSINVCND)
#        MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN")
        MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        GOK = 0 : GERR = 1
        MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
        Break
      Endif
    Endif

    nolign = I + 1
    # Need to use [F] because it's not possible to set a class from [M]
    #--First, there are some inportant properties set in ADDLINE_AFTER method
    #--As they are not set in classic X3 after addind a line, it's important to copy them to [M]
    [M:INVCND1]INVCNDLIN(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVCNDLIN

    #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
    If 1=1
      Raz [F:INVCNDD]
      [F:INVCNDD] = [M:INVCND1]
      # Use the SetInstance
      SetInstance GCLSINVCND.INVCNDLIN(WILINE) With [F:INVCNDD]
    Else
      #SetInstance GCLSINVCND.INVCNDLIN(WILINE) With [M:INVCND1]30
    Endif
    # Complete for non matching fields and translatable fields
    Gosub SET_CLS_LINE_WITH_M_INVCND1
    If GERR = 1 Then
      GOK=0
      Break
    Endif

  Next

  nolign = WIJSAVE_NOLIGN
  If (GERR = 1) : Return : Endif

  # Now, all elements that don't have the status Updated or Created must be deleted, because it means they don't match with lines in the array
  # Or those already marked as deleted
  For I = 1 To maxtab(GCLSINVCND.INVCNDLIN)
    If (find(GCLSINVCND.INVCNDLIN(I).ASTALIN, [V]CST_ANEW, [V]CST_ADEL,[V]CST_ANEWDEL))=0
&   and      num$(GCLSINVCND.INVCNDLIN(I).AUUID)<>""
&   and find(num$(GCLSINVCND.INVCNDLIN(I).AUUID),[M:INVCND1]AUUID(0..[M:INVCND1]NBLIG-1))=0
      If (fmet GCLSINVCND.ADELLINE("INVCNDLIN", GCLSINVCND.INVCNDLIN(I).AORDER) <> [V]CST_AOK)
        # Error management
#        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GCLSINVCND)
#        MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN")
        MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        GOK = 0 : GERR = 1
        MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
        Break
      Endif
    Endif
  Next

Return
#-------------------------------------------------------------------------------------
#--Header properties CLS => M:
$SET_M_INVCND1_WITH_CLS
  If GCLSINVCND=null : GERR=1 : Return : Endif

  #--Copying properties from class into the screen
  #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
  If 1=1
    SetInstance [F:INVCND] With GCLSINVCND
    [M:INVCND1] = [F:INVCND]

    [M:INVCND1]FBDDAYFLGMON = GCLSINVCND.FBDDAYFLGMON
    [M:INVCND1]FBDDAYFLGTUE = GCLSINVCND.FBDDAYFLGTUE
    [M:INVCND1]FBDDAYFLGWED = GCLSINVCND.FBDDAYFLGWED
    [M:INVCND1]FBDDAYFLGTHU = GCLSINVCND.FBDDAYFLGTHU
    [M:INVCND1]FBDDAYFLGFRI = GCLSINVCND.FBDDAYFLGFRI
    [M:INVCND1]FBDDAYFLGSAT = GCLSINVCND.FBDDAYFLGSAT
    [M:INVCND1]FBDDAYFLGSUN = GCLSINVCND.FBDDAYFLGSUN

    [M:INVCND1]DESAXX = GCLSINVCND.DESAXX
    [M:INVCND1]SHOAXX = GCLSINVCND.SHOAXX
  Else
    #SetInstance [M:INVCND1]30 With GCLSINVCND
  Endif

Return
#-------------------------------------------------------------------------------------
#--Header properties M: => CLS
$SET_CLS_WITH_M_INVCND1
Local Integer MY_STATUS
  If GCLSINVCND=null : GERR= 1 : Return : Endif

  #--Copying properties from class into the screen
  GCLSINVCND.FBDDAYFLGMON = [M:INVCND1]FBDDAYFLGMON
  GCLSINVCND.FBDDAYFLGTUE = [M:INVCND1]FBDDAYFLGTUE
  GCLSINVCND.FBDDAYFLGWED = [M:INVCND1]FBDDAYFLGWED
  GCLSINVCND.FBDDAYFLGTHU = [M:INVCND1]FBDDAYFLGTHU
  GCLSINVCND.FBDDAYFLGFRI = [M:INVCND1]FBDDAYFLGFRI
  GCLSINVCND.FBDDAYFLGSAT = [M:INVCND1]FBDDAYFLGSAT
  GCLSINVCND.FBDDAYFLGSUN = [M:INVCND1]FBDDAYFLGSUN

  GCLSINVCND.DESAXX       = [M:INVCND1]DESAXX
  GCLSINVCND.SHOAXX       = [M:INVCND1]SHOAXX

  MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
  If GMESSAGE<>""
    GERR = 1
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  Endif
Return
#-------------------------------------------------------------------------------------
#--Line properties CLS => M:
$SET_M_INVCND1_WITH_CLS_LINE

  If WILINE<1 or GCLSINVCND.INVCNDLIN(WILINE)=null : GERR=1 : Return : Endif
  #--Copying properties from class into the screen
  #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
  If 1=1
    Raz [F:INVCNDD]
    SetInstance [F:INVCNDD] With GCLSINVCND.INVCNDLIN(WILINE)
    [M:INVCND1] = [F:INVCNDD]

    [M:INVCND1]INVDAYMON1(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON1
    [M:INVCND1]INVDAYMON2(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON2
    [M:INVCND1]INVDAYMON3(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON3
    [M:INVCND1]INVDAYMON4(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON4
    [M:INVCND1]INVDAYMON5(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON5
    [M:INVCND1]INVDAYMON6(nolign-1) = GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON6
  Else
    #SetInstance [M:INVCND1]30 With GCLSINVCND.INVCNDLIN(WILINE)
  Endif
  [M:INVCND1]AUUID(nolign-1)      = num$(GCLSINVCND.INVCNDLIN(WILINE).AUUID)

Return

#-------------------------------------------------------------------------------------
#--Header properties M: => CLS
$SET_CLS_LINE_WITH_M_INVCND1
Local Integer MY_STATUS
  If WILINE<1 or GCLSINVCND.INVCNDLIN(WILINE)=null : GERR=1 : Return : Endif
  #--Copying properties from class into the screen
  #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
  If 1=1
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON1 = [M:INVCND1]INVDAYMON1(nolign-1)
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON2 = [M:INVCND1]INVDAYMON2(nolign-1)
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON3 = [M:INVCND1]INVDAYMON3(nolign-1)
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON4 = [M:INVCND1]INVDAYMON4(nolign-1)
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON5 = [M:INVCND1]INVDAYMON5(nolign-1)
    GCLSINVCND.INVCNDLIN(WILINE).INVDAYMON6 = [M:INVCND1]INVDAYMON6(nolign-1)
  Else
    #SetInstance GCLSINVCND.INVCNDLIN(WILINE) With [M:INVCND1]30
  Endif
  MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
  If GMESSAGE<>""
    GERR = 1
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  Endif

Return
#-------------------------------------------------------------------------------------
$CREATION
Local Integer MY_STATUS,I,WILINE,WRET
  #----FOR HYBRID MODE----

  #--If there was a previous error on while "Creation", lines keep adding to the class !
#  If maxtab(GCLSINVCND.INVCNDLIN)>0
#    FreeGroup GCLSINVCND
#    GCLSINVCND = NewInstance C_TABINVCND AllocGroup null
#    [L]MY_STATUS = fmet GCLSINVCND.AINIT()
#    If ([L]MY_STATUS >= [V]CST_AERROR)
#      # Error management
#      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GCLSINVCND)
#      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN")
#      GOK = 0 : GERR = 1
#      Return
#    Endif
#  Endif

  If dim(GCLSINVCND)>0 and GCLSINVCND<>null
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN")
  Endif

  Gosub SET_CLS_WITH_M
  If (GERR = 1) : Return : Endif

  [L]MY_STATUS = fmet GCLSINVCND.AINSERT()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If GMESSAGE<>""     # Ini SAM 120866 JUCON 12/01/2017
      Local Char WTXT(250), WERR(250)
      Call TEXTE(56729,WTXT) From OBJDIV
      If left$(GMESSAGE,7)="FREQINV": WERR=seg$(GMESSAGE,9,len(GMESSAGE)): WERR=WTXT-":"+WERR: GMESSAGE=WERR: Endif
    Endif               # End SAM 120866 JUCON 12/01/2017
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif

  Gosub LIENS
  #----END FOR HYBRID MODE----

Return
#-------------------------------------------------------------------------------------
$APRES_CRE

  Gosub RELIT From GOBJSUB

Return
#-------------------------------------------------------------------------------------
$APRES_MOD

  Gosub RELIT From GOBJSUB

Return
#-------------------------------------------------------------------------------------
$AFFMASK

  If [M:INVCND1]INVCNDTYP=3
    Chgfmt [M:INVCND1]NBLIG      With "-N:3"
    Actzo  [M:INVCND1]15
  Else
    Chgfmt [M:INVCND1]NBLIG      With "+N:3"
    Grizo  [M:INVCND1]15
  Endif
  #--Gestion multi-législation
  Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
  Gosub GRILEG

  #--No update allowed if tunneling
  If GFONC1<>""
    Diszo [INVCND1]1-99 : GCONSULT=1
  Endif

Return
#-------------------------------------------------------------------------------------
$GRILEG
  If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
    Diszo [INVCND1]LEG
    [INVCND1]LEG=GDOSLEG(1)
    Affzo [INVCND1]LEG : If dim([INVCND1]ZLEG)>0  Affzo [INVCND1]ZLEG : Endif
  Endif
Return
#-------------------------------------------------------------------------------------
$AV_ANNULE
  #----FOR HYBRID MODE----
  #--It's called from a subprog so the ANOWRITE opened in $OUVRE is not known
  Local Integer ANOWRITE
  ANOWRITE = 1
  #----END FOR HYBRID MODE----
Return
#-------------------------------------------------------------------------------------
$ANNULE
Local Integer MY_STATUS,WRET

  #----FOR HYBRID MODE----
  [L]MY_STATUS = fmet GCLSINVCND.ADELETE()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      Return
    Else
      GERR = 2
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCND,"INVCNDLIN") # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
  Endif
  #----END FOR HYBRID MODE----
Return
#-------------------------------------------------------------------------------------
$SETBOUT
  #------------------------------#
  # Désactivation bouton "Copie" #
  #------------------------------#
  If CLECUR = 0 | GREP <> ""
    # Call VIREBOUT(CHAINE,"2") From GOBJET  #SAM 121442
    Call VIREBOUT(CHAINE,"12") From GOBJET   #SAM 121442
  Endif

  If GREP = "" Then
    # Note FGR : obligé de l'ajouter à la main. comme il y a plus de deux
    #            éléments dans la clé, le superviseur ne le mets pas tout seul
    CHAINE += "A"
#    # FGR 23/04/2013 : X3SUIVI71937 : obligé de le réactivé à la main parce que 3 éléments de PK
#    CHAINE += "H"
  Endif

Return
#-------------------------------------------------------------------------------------
$FERME
  #----FOR HYBRID MODE----
  #--Freeing/Killing the global instance used by hybride mode
  If (GCLSINVCND <> null) : FreeGroup GCLSINVCND : Endif
  Kill GCLSINVCND
  #----END FOR HYBRID MODE----

  #------------------------------------#
  # Restitution des variables globales #
  #------------------------------------#
  Gosub REST_GLOB From TRTX3GLOB

  # To manage the button "Tunnel"
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONINVCND) : Endif

  VCOD = CLE2
Return
#-------------------------------------------------------------------------------------
######################################################################
$AP_CHANGE  # X3-4924 Manage change key fonction on invoice term (JUCON 18/11/16)
  Call CHGTEXTRA("TABINVCND","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
  Call CHGTEXTRA("TABINVCND","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return
#-------------------------------------------------------------------------------------
$MAJ_ATEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABINVCND","DESAXX",CLECUR1,"","TABINVCND","DESAXX",[F:INVCND]INVCND,[F:INVCND]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABINVCND","SHOAXX",CLECUR1,"","TABINVCND","DESAXX",[F:INVCND]INVCND,[F:INVCND]LEG)  From ATEXTRA
Endif
#----- Création/Modification des textes traduisibles (ATEXTRA) -----#
Call MAJTEXTRA ([M:INVCND1]DESAXX,"TABINVCND","DESAXX",[M:INVCND1]INVCND,[M:INVCND1]LEG) From ATEXTRA  #MAE, multiLEG
Call MAJTEXTRA ([M:INVCND1]SHOAXX,"TABINVCND","SHOAXX",[M:INVCND1]INVCND,[M:INVCND1]LEG) From ATEXTRA  #MAE, multiLEG
#----- SOS libellés -----#
If dim([F:INVCND]LANDESSHO)>0
  [F:INVCND]LANDESSHO=GLANGUE+"~"+[M:INVCND1]DESAXX+"~"+[M:INVCND1]SHOAXX
Endif
#-----
Return
#-------------------------------------------------------------------------------------
######################################################################################
#--Données par législation pour le Condition de paiement
######################################################################################
Subprog CONTINVCND (COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY )
Value    Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer WNBTOT, WI, WNO_ERR,  WENROK
Local Char    WLEG  (GLONADI), WMESS1 (120), WMESS2 (120), WMESS3 (120)
Local Integer CAS
Local Char    OPTIONS(30)

If GFONCTION = "GESINVCND" | COD="" : End : Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If clalev([F:CPY])=0     : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0     : Local File FACILITY   [FCY]  : Endif
If clalev([F:INVCND])=0  : Local File TABINVCND [INVCND]  : Endif
If clalev([F:AMZZ])= 0   : Local File AMSKZON   [AMZZ] : Endif :#--for the selection options of the object

If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
  LEG = GCURLEG
Endif

CAS = 1 : # Legislation is empty

#-------------------------------------------------------------------#
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
#-------------------------------------------------------------------#
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    If [F:FCY]FCY<>[L]FCY
      Read [F:FCY]FCY0=[L]FCY
      If fstat : Raz [F:FCY] Endif
    Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif

  If [L]CPY<>""
    If [F:CPY]CPY<>[L]CPY
      Read [F:CPY]CPY0=[L]CPY
      If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG=[F:CPY]LEG
  Endif
Endif
#--/CPO

If LEG<>""
  Read [INVCND]INVCND0=COD;LEG
  If fstat
    Read [INVCND]INVCND0=COD;""
  Else
    CAS = 2 : # Legislation isn't empty
  Endif
Else
  Read [INVCND]INVCND0(1)=COD
  If !fstat
    LEG = [F:INVCND]LEG
    CAS = 2
  Endif
Endif
If fstat
  Filter [INVCND] Where INVCND=[L]COD
  Look [INVCND]INVCND0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    GMESSAGE = [L]COD-":"-mess(23,100,1)
  Endif
  Filter [INVCND]
  mkstat = 2 : End
Endif

#----------------------------------------------------------------------------------------------------------------------#
#--Filtrage par groupe de société3

#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABINVCND, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#----------------------------------------------------------------------------------------------------------------------#
If [L]CPY<>"" and [L]FCY=""
  If [F:INVCND]GRP<>""
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
  Read [AGF]AGF0=[F:INVCND]GRP
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Société
      If [F:INVCND]GRP<>[L]CPY
        GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:INVCND]GRP : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Elsif [F:AGF]FLGCPY=2
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:INVCND]GRP;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:INVCND]GRP : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe  et la législation
If [F:INVCND]GRP<>"" and LEG<>""
  Call CTLGFYLEG([F:INVCND]GRP,LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:INVCND]LEG<>""
  Call CTLGFYLEG(GROUPE,[F:INVCND]LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe  et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
  If CPY="" & FCY="" & [F:INVCND]GRP<>"" & [F:INVCND]GRP<>GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP
    If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
  Call CONTROLE("INVCND",OPTIONS,LEG,COD,mkstat) From CONTOBJ
 Else
  Call CONTROLE("INVCND",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End

###############################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:INVCND]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGICNDZGRP"
    Local File =SZVIEW [INVCNDZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:INVCNDZ]ICNDZ0 = [L]GROUPE;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG
  If fstat
    GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:INVCND]GRP-":"-mess(178,187,1)
    mkstat=1
    Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGICNDYGRP"
    Local File =SZVIEW [INVCNDY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    #-- Si problème, pas de contrôle
    Return
  Endif

  Read [F:INVCNDY]ICNDY0 = [L]GROUPE;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG #--Clé INVCNDY0 et non pas INVCNDZ0
  If fstat
   GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:INVCND]GRP-":"-mess(178,187,1)
   mkstat=1
   Return
  Endif
Endif
Return

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le Condition de paiement
######################################################################################
## Tunnel Condition de paiement
######################################################################################
Subprog TUNINVCND(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Global Char VCOD(GLONINVCND)
Local Char  VLEG(GLONADI)
# To update the INVCND code after the tunnel order
VCOD = COD
VLEG = LEG
If clalev([F:INVCND])=0 : Local File TABINVCND [INVCND] : Endif
If func AFNC.ACTIV("LEG")=0 : VLEG = GDOSLEG : Endif

Read [INVCND]INVCND0 = VCOD;VLEG
If fstat : VLEG = "" : Endif
Call OBJET("INVCND",VLEG,VCOD) From GOBJET
COD = VCOD
Kill VCOD
End
####################################################################################################
## $SELINVCND : Données par législation pour l'Echéancier                                            ##
##       --> Si [L]LEG<>""                           --> Utilisation de la vue LEGICNDSEL  (INVCNDS)  ##
##       --> Si [L]LEG=""                            --> Utilisation de la vue LEGICNDPAR  (INVCNDP)  ##
##       --> Si [L]LEG=<>"" OU (LEG="" & GROUPE<>'') --> Utilisation de la vue LEGICNDGRP  (INVCNDG)  ##
##   FACGROUP --> Table de lien Groupe et site                                                    ##
##   AGRPCPY  --> Table de lien Groupe et société                                                 ##
####################################################################################################
$SELINVCND

If clalev([F:INVCND])=0 : Local File TABINVCND [INVCND] : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:CPY])=0    : Local File COMPANY   [CPY]    : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]    : Endif
If clalev([F:AXX])=0    : Local File ATEXTRA   [AXX]    : Endif

If clalev([F:AGF])=0  : Local File AGRPFCY   [AGF] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#--Pour déterminer les options de sélection

Local Char    FCY(GLONFCY), CPY(GLONCPY), LEG(GLONADI),   GRP(GLONAGC)
Local Integer WNOL, ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif #--Pour déterminer les options de sélection
Local Char CODMSK   (GLONAMK)                    #--Pour déterminer les options de sélection
Local Char CHAMPCOD (GLONAVA)                    #--Pour déterminer les options de sélection

AUTRE_CRIT = '1=1'

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
LEG      = PARAM(1)
FCY      = PARAM(2)
GRP      = PARAM(3)
CPY      = PARAM(4)
CODMSK   = PARAM(5)
CHAMPCOD = PARAM(6)

Local Char GFY

GFY = GRP
#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
# Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = INVCND2
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif
Endif

#-- Initialisation de législation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG="" & GFONCTION <> "GESINVCND" :  [L]LEG = GCURLEG : Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOINVCND
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("INVCND","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:INVCND]INVCND"
ORDRE   = "[F:INVCND]INVCND;[F:INVCND]LEG"
OBJET   = ""
#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------
ICRITERE = 0
ICRITERE += 1
CRITERE(ICRITERE) = '1=1'
#--Groupe de soc/sites
If FCY="" & CPY="" & GFY<>""
 Read [F:AGF]AGF0=[L]GFY
 If !fstat
   If [F:AGF]FLGLEG=2 : [L]CPY=[L]GFY : Endif
 Endif
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(ICRITERE) -= '& ([F:INVCND]GRP="" | ([F:INVCND]GRP<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
Elsif [L]CPY<>""
  CRITERE(ICRITERE) -= '& ([F:INVCND]GRP="" | ([F:INVCND]GRP<>"" & [F:INVCNDC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
ICRITERE += 1
If LEG<>""
  CRITERE(ICRITERE) -= '& ([F:INVCND]LEG="'+[L]LEG+'" | [F:INVCND]LEG="")'
Endif
#--First selection character
If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(ICRITERE) -= '& left$([F:INVCND]INVCND,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

CRITERE(ICRITERE) -= '&'-[L]AUTRE_CRIT

ICRITERE += 1
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGICNDYGRP"
      Local File =SZVIEW [INVCNDY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "INVCND"
      Return
    Endif
Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGICNDZGRP"
      Local File =SZVIEW [INVCNDZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "INVCND"
      Return
    Endif
Endif
Endif
If 1=1
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGICNDCPY"
    Local File =SZVIEW [INVCNDC]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "INVCND"
    Return
  Endif
  If [L]LEG<>""
    #--View throughout GCURLEG
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGICNDSEL"
      Local File =SZVIEW [INVCNDS]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "INVCND"
      Return
    Endif
    If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
      Link [INVCND] With [F:AXX]AXX0     = "TABINVCND";"DESAXX";GLANGUE;[F:INVCND]INVCND;[F:INVCND]LEG,
&                     [F:INVCNDY]ICNDY0 ~= [L]GRP;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG,
&                     [F:INVCNDS]ICND0  ~= [F:INVCND]INVCND;[F:INVCND]LEG;[L]LEG
&                  As [LINVCND]
    Else
      Link [INVCND] With [F:AXX]AXX0    = "TABINVCND";"DESAXX";GLANGUE;[F:INVCND]INVCND;[F:INVCND]LEG,
&                     [F:FGR]FGR1       = [L]FCY;[F:INVCND]GRP,
&                     [F:INVCNDC]ICND0  = [F:INVCND]INVCND;[F:INVCND]LEG;[F:INVCND]GRP;[L]CPY,
&                     [F:INVCNDS]ICND0 ~= [F:INVCND]INVCND;[F:INVCND]LEG;[L]LEG
&                  As [LINVCND]
    Endif
  Else
    #--View without legislation
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGICNDPAR"
      Local File =SZVIEW [INVCNDP]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "INVCND"
      Return
    Endif
    If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
      Link [INVCND] With [F:AXX]AXX0     = "TABINVCND";"DESAXX";GLANGUE;[F:INVCND]INVCND;[F:INVCND]LEG,
&                     [F:INVCNDZ]ICNDZ0 ~= [L]GRP;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG
&                  As [LINVCND]
    Else
      Link [INVCND] With [F:AXX]AXX0    = "TABINVCND";"DESAXX";GLANGUE;[F:INVCND]INVCND;[F:INVCND]LEG,
&                     [F:FGR]FGR1       = [L]FCY;[F:INVCND]GRP,
&                     [F:INVCNDC]ICND0  = [F:INVCND]INVCND;[F:INVCND]LEG;[F:INVCND]GRP;[L]CPY,
&                     [F:INVCNDP]ICND0 ~= [F:INVCND]INVCND;[F:INVCND]LEG
&                  As [LINVCND]
    Endif
  Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOINVCND
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LINVCND]
DEFPAG = 1

Return
################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
#######################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'un taux de taxe                  #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File TABINVCND                  [INVCND1]
  Local File TABINVCNDLIN               [INVCNDD1]
  Local File ATEXTRA                    [AXX1]
Else
  Local File =[M]DOSORG+".TABINVCND"    [INVCND1]
  Local File =[M]DOSORG+".TABINVCNDLIN" [INVCNDD1]
  Local File =[M]DOSORG+".ATEXTRA"      [AXX1]
Endif
If [M]DOSDES=nomap
  Local File TABINVCND                  [INVCND2]
  Local File TABINVCNDLIN               [INVCNDD2]
  Local File ATEXTRA                    [AXX2]
  Local File ACTIV                      [ACV2]
Else
  Local File =[M]DOSDES+".TABINVCND"    [INVCND2]
  Local File =[M]DOSDES+".TABINVCNDLIN" [INVCNDD2]
  Local File =[M]DOSDES+".ATEXTRA"      [AXX2]
  Local File =[M]DOSDES+".ATABDIV"      [ADI2]
  Local File =[M]DOSDES+".ACTIV"        [ACV2]
  Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS  From ATEXTRA

Call DEBTRANS From GLOCK
Gosub TRT_COPIE

Close Local File [INVCND1], [INVCNDD1], [AXX1], [INVCND2], [INVCNDD2], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'un taux de taxe           #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [INVCND2]INVCND0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Local Integer ILIG
#--/vérifications
Trbegin [INVCND2], [INVCNDD2]
  Delete [INVCND2] Where INVCND=(TABLE) & LEG=LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABINVCND"-TABLE-LEGDES   : Goto ROLL_COPIE :#--CPO 71937
  Elsif fstat GOK=0 : Call RSTA("INVCND2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  Delete [INVCNDD2] Where INVCND=(TABLE)& LEG=LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABINVCNDLIN"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("INVCNDD2",TABLE) From GLOCK     : Goto AB_COPIE
  Endif
  If !fstat
     For [INVCND1]INVCND0 Where INVCND=TABLE & LEG = TABLE2
         Raz [F:INVCND2]
         [F:INVCND2]=[F:INVCND1]
         [F:INVCND2]LEG = LEGDES
         If TABLE2=LEGDES
             Call COPTEXTRA("TABINVCND","DESAXX",TABLE,TABLE2) From ATEXTRA
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA("TABINVCND","SHOAXX",TABLE,TABLE2) From ATEXTRA
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
         Else
             Call COPTEXTRA1("TABINVCND","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA1("TABINVCND","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
         Endif
         If dim([F:INVCND2]UPDUSR)>0 : [F:INVCND2]UPDUSR = GUSER : Endif
         If dim([F:INVCND2]UPDDAT)>0 : [F:INVCND2]UPDDAT = date$ : Endif
         Write [INVCND2]
         If fstat GOK=0 : Call FSTA("INVCND2") From GLOCK : Goto AB_COPIE : Endif
     Next
     For [INVCNDD1]INVCNDD0 Where INVCND=(TABLE) & LEG = TABLE2
       Raz [F:INVCNDD2]
       [F:INVCNDD2]=[F:INVCNDD1]
       [F:INVCNDD2]LEG = LEGDES
       Write [INVCNDD2]
       If fstat GOK=0 : Call FSTA("INVCNDD2") From GLOCK : Goto AB_COPIE : Endif
     Next
  Endif

Commit
Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback : Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif : Return
#################################################################################
