$CONTROL_INVDAYMON
  If VALEUR=0 or VALEUR=99 : Return : Endif
  If VALEUR>30  or VALEUR<0
    GMESSAGE = func AFNC.MES2(mess(459,192,1),"30","99") #-- 'Seulement des valeurs positives, inférieures ou égales à $1$ ou égales à $2$'
    GERR=1 : mkstat=2
  Endif
Return
