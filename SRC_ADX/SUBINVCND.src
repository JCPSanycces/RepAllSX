######################################################################################
Subprog AM_INVCNDTYP(VALEUR)
Variable Integer VALEUR
Local Integer MY_STATUS,WRET
  #----FOR HYBRID MODE----
  #--Triggering Control/Propagate
  GCLSINVCND.INVCNDTYP = VALEUR
  MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
  If GMESSAGE<>""
    Local Char WTXT(250), WERR(250)     # Ini SAM 120866 JUCON 12/01/2017
    Call TEXTE(56729,WTXT) From OBJDIV
    If left$(GMESSAGE,7)="FREQINV": WERR=seg$(GMESSAGE,9,len(GMESSAGE)): WERR=WTXT-":"+WERR: GMESSAGE=WERR: Endif
    GERR=1 : mkstat=2 : End             # End SAM 120866 JUCON 12/01/2017
  Endif  #--
  If VALEUR=3
    [M:INVCND1]NBLIG = 0
    Grizo  [M:INVCND1]NBLIG
    Chgfmt [M:INVCND1]NBLIG      With "-N:3"
    Actzo  [M:INVCND1]15
  Else
    #--Raz screen fields
    [M:INVCND1]FREQINV = GCLSINVCND.FREQINV
    [M:INVCND1]PERINV  = GCLSINVCND.PERINV
    [M:INVCND1]INVMETH = GCLSINVCND.INVMETH
    [M:INVCND1]INVDAY  = GCLSINVCND.INVDAY
    Affzo [M:INVCND1]15
    #--/
    Actzo  [M:INVCND1]NBLIG
    Chgfmt [M:INVCND1]NBLIG      With "+N:3"
    Grizo  [M:INVCND1]15
  Endif
  #----END FOR HYBRID MODE----
End
#-------------------------------------------------------------------------------------
Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
Local Integer MY_STATUS,WRET
  #----FOR HYBRID MODE----
  #--Triggering Control/Propagate
  GCLSINVCND.GRP = VALEUR
  MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
  If GMESSAGE<>""
    GERR=1 : mkstat=2 : End
  Endif
  #----END FOR HYBRID MODE----
  #--
End
######################################################################################
#--------------------------------------------------------
#----FOR HYBRID MODE----
Funprog RAZMAXMSG(POBJ,PCOLLNAME)
Variable Instance POBJ   Using OBJECT
Value    Char     PCOLLNAME

  Local Integer LIN, MAXERR , LIN2, WRET
  Local Char WMSG(250)

  If PCOLLNAME<>""
    Local Instance POBJCH Using OBJECT
  Endif

  #--Head object => deleting errors
  [L]MAXERR = 0
  For [L]LIN = 1 To maxtab(POBJ.AERROR)
    If (POBJ.AERROR([L]LIN) <> null and POBJ.AERROR([L]LIN).DEL <> [V]CST_AYES) #CCL
      If POBJ.AERROR([L]LIN).STA > [L]MAXERR
            [L]MAXERR = POBJ.AERROR([L]LIN).STA
            If POBJ.AERROR([L]LIN).PRO = AVOID.ACHAR
              #WMSG = POBJ.AERROR([L]LIN).MES
              WRET = fmet POBJ.ADELETEERROR("")
            Else
              #WMSG = POBJ.AERROR([L]LIN).PRO - POBJ.AERROR([L]LIN).MES
              WRET = fmet POBJ.ADELETEERROR(POBJ.AERROR([L]LIN).PRO)
            Endif
       Endif
    Endif
  Next
  #--Head object collection => deleting errors
  [L]MAXERR = 0
  If WRET<=[V]CST_AERROR
    If PCOLLNAME<>""
      For [L]LIN2 = 1 To evalue("maxtab(POBJ."+PCOLLNAME+")")
        If evalue("POBJ."+PCOLLNAME+"("+num$(LIN2)+")") <> null
          POBJCH =  evalue("POBJ."+PCOLLNAME+"("+num$(LIN2)+")")
          If find(POBJCH.ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL)=0
            For [L]LIN = 1 To maxtab(POBJCH.AERROR)
              If (POBJCH.AERROR([L]LIN) <> null and POBJCH.AERROR([L]LIN).DEL <> [V]CST_AYES)
                If POBJCH.AERROR([L]LIN).STA > [L]MAXERR
                    [L]MAXERR = POBJCH.AERROR([L]LIN).STA
                    If POBJCH.AERROR([L]LIN).PRO = AVOID.ACHAR
                      #WMSG = POBJCH.AERROR([L]LIN).MES
                      WRET = fmet POBJCH.ADELETEERROR("")
                    Else
                      #WMSG = POBJCH.AERROR([L]LIN).PRO - POBJCH.AERROR([L]LIN).MES
                      WRET = fmet POBJCH.ADELETEERROR(POBJCH.AERROR([L]LIN).PRO)
                    Endif
                 Endif
              Endif
            Next
          Endif
        Endif
      Next
    Endif
  Else
    End WRET
  Endif

End WRET
#----END FOR HYBRID MODE----
