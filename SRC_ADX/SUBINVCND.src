######################################################################################
Subprog AVANT_NBLIG

Local Integer ILINE,MY_STATUS,SAVE_NOLIGN,LAST_LIG,WRET,WOK,WILINE

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  #--Let's do a snapshot before modifications
  If  find(status,73, 75, 82)>0
    Gosub HYBRID_SET_SNAPSHOT : If GERR=1 : End : Endif
  Endif
  # End issue X3-38457

  #--It's important to have the right info into the header class !
  #--Header properties
  Raz [F:INVCND]
  [F:INVCND] = [M:INVCND1]
  SetInstance GCLSINVCND With [F:INVCND]
  Gosub SET_CLS_WITH_M_INVCND1
  If GERR = 1 Then
    End
  Endif
  #--
  If    status=73 | status = 82

    #--Si insertion ligne : init du pourcentage restant
    [M:INVCND1]INVPERCENT(nolign-1)=max(0,100-sum([M:INVCND1]INVPERCENT(0..[M:INVCND1]NBLIG-1)))
    #----------------------------------------------------------------------------
    # Retrieve the element using the screen's AUUID
    ILINE=0
    If [M:INVCND1]AUUID(nolign-1)<>""
      #--We have to consider the ASTALIN
      #ILINE = find(toUuid([M:INVCND1]AUUID(I)), GCLSINVCND.INVCNDLIN(1..maxtab(GCLSINVCND.INVCNDLIN)).AUUID)
      ILINE = sigma(1,maxtab(GCLSINVCND.INVCNDLIN),
&      (indcum)*(GCLSINVCND.INVCNDLIN(indcum)<>null and find(GCLSINVCND.INVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                toUuid([M:INVCND1]AUUID(nolign-1))=GCLSINVCND.INVCNDLIN(indcum).AUUID))
      Endif
      If (ILINE = 0)
        # We did not find the element matching with the array line.
        # We add a line.
        ILINE = fmet GCLSINVCND.ADDLINE("INVCNDLIN", [V]CST_ALASTPOS)
        If (ILINE = [V]CST_ANOTDEFINED)
          # Error management
          MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
          GERR = 1
          End
        Endif
    Endif
    GCLSINVCND.INVCNDLIN(ILINE).INVPERCENT = [M:INVCND1]INVPERCENT(nolign-1)

    #--The upper line code triggers the propagate, hence the following code :
    WILINE = ILINE
    Gosub SET_M_INVCND1_WITH_CLS_LINE
    If GERR = 1 : End : Endif
    Affzo [M:INVCND1]1-99

    #----------------------------------------------------------------------------
  Elsif status=65
    #--pas besoin de faire un snapshot car on ne peut pas abandonner la suppression de ligne par Esc

    #--Si suppression ligne : répartition du delta sur la dernière ligne saisie
    If [M]NBLIG>1
      If [M:INVCND1]NBLIG=nolign
        LAST_LIG = max(0,[M:INVCND1]NBLIG-2)
      Else
        LAST_LIG = max(0,[M:INVCND1]NBLIG-1,nolign-1)
      Endif
      WOK=1
      Call OUINON(mess(480,192,1),WOK) From GESECRAN
      If WOK=2
        [M:INVCND1]INVPERCENT(LAST_LIG)+=[M:INVCND1]INVPERCENT(nolign-1)
        Affzo [M:INVCND1]INVPERCENT(LAST_LIG)
      Endif
    Endif
    #----------------------------------------------------------------------------
    # Retrieve the element using the screen's AUUID
    # 1st) Eventually deleting the old line from the collection
    ILINE=0
    If [M:INVCND1]AUUID(nolign-1)<>""
      #--We have to consider the ASTALIN
      #ILINE = find(toUuid([M:INVCND1]AUUID(I)), GCLSINVCND.INVCNDLIN(1..maxtab(GCLSINVCND.INVCNDLIN)).AUUID)
        ILINE = sigma(1,maxtab(GCLSINVCND.INVCNDLIN),
&      (indcum)*(GCLSINVCND.INVCNDLIN(indcum)<>null and find(GCLSINVCND.INVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                toUuid([M:INVCND1]AUUID(nolign-1))=GCLSINVCND.INVCNDLIN(indcum).AUUID))
      Endif
      If (ILINE <> 0)
        If (fmet GCLSINVCND.ADELLINE("INVCNDLIN", GCLSINVCND.INVCNDLIN(ILINE).AORDER) <> [V]CST_AOK)
        # Error management
        MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        GERR = 1
        End
      Endif
    Endif
    # 2nd) Updating properties for the NBLIG-1 line
    #--Does this Mask line exist into the collection ?
    # Retrieve the element using the screen's AUUID
    If LAST_LIG>0 and WOK=2
      ILINE=0
      If [M:INVCND1]AUUID(LAST_LIG)<>""
        #--We have to consider the ASTALIN
        ILINE = sigma(1,maxtab(GCLSINVCND.INVCNDLIN),
&           (indcum)*(GCLSINVCND.INVCNDLIN(indcum)<>null and find(GCLSINVCND.INVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                   toUuid([M:INVCND1]AUUID(LAST_LIG))=GCLSINVCND.INVCNDLIN(indcum).AUUID))
        Endif
        If (ILINE = 0)
          # We did not find the element matching with the array line.
        # We add a line.
        ILINE = fmet GCLSINVCND.ADDLINE("INVCNDLIN", [V]CST_ALASTPOS)
        If (ILINE = [V]CST_ANOTDEFINED)
          # Error management
          MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
          GERR = 1
          End
        Endif
      Endif
      #--Updating properties...
      GCLSINVCND.INVCNDLIN(ILINE).INVPERCENT = [M:INVCND1]INVPERCENT(LAST_LIG)

      #--The upper line code triggers the propagate, hence the following code :
      SAVE_NOLIGN=nolign : nolign = LAST_LIG+1
      WILINE = ILINE
      Gosub SET_M_INVCND1_WITH_CLS_LINE

      nolign=SAVE_NOLIGN
    Endif
    If GERR = 1 : End : Endif
    Affzo [M:INVCND1]1-99
  Endif
  #--------------------------------------------------

End
######################################################################################
Subprog AM_INVPERCENT(VALEUR)
Variable Decimal VALEUR

  Local Integer ILINE,MY_STATUS,SAVE_NOLIGN,LAST_LIG,WILINE,WRET

  [M:INVCND1]INVPERCENT(nolign-1) = VALEUR
  # Retrieve the element using the screen's AUUID
  ILINE=0
  If [M:INVCND1]AUUID(nolign-1)<>""
    #--We have to consider the ASTALIN
    #ILINE = find(toUuid([M:INVCND1]AUUID(I)), GCLSINVCND.INVCNDLIN(1..maxtab(GCLSINVCND.INVCNDLIN)).AUUID)
      ILINE = sigma(1,maxtab(GCLSINVCND.INVCNDLIN),
&   (indcum)*(GCLSINVCND.INVCNDLIN(indcum)<>null and find(GCLSINVCND.INVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&           toUuid([M:INVCND1]AUUID(nolign-1))=GCLSINVCND.INVCNDLIN(indcum).AUUID))
    Endif
    If (ILINE = 0)
      # We did not find the element matching with the array line.
      # We add a line.
      ILINE = fmet GCLSINVCND.ADDLINE("INVCNDLIN", [V]CST_ALASTPOS)
      If (ILINE = [V]CST_ANOTDEFINED)
        # Error management
        MY_STATUS= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        GERR = 1
        End
      Endif
    Endif

  #--In order not to loose modified properties not yet loaded into the line instance...
  SAVE_NOLIGN = nolign
  Raz [F:INVCND] : [F:INVCND] = [M:INVCND1]
  Gosub SET_CLS_WITH_M
  nolign = SAVE_NOLIGN
  If GERR = 1 : End : Endif

  #--For a newly inserted line, the NBLIG is not increased yet
  #--We need to manually set the ILINE instance with mask's values...
  If nolign>[M:INVCND1]NBLIG
    # Need to use [F] because it's not possible to set a class from [M]
    #--First, there are some inportant properties set in ADDLINE_AFTER method
    #--As they are not set in classic X3 after addind a line, it's important to copy them to [M]
    [M:INVCND1]INVCNDLIN(nolign-1) = GCLSINVCND.INVCNDLIN(ILINE).INVCNDLIN

    Raz [F:INVCNDD] : [F:INVCNDD] = [M:INVCND1]
    # Use the SetInstance
    SetInstance GCLSINVCND.INVCNDLIN(ILINE) With [F:INVCNDD]

    # Complete for non matching fields and translatable fields
    Gosub SET_CLS_LINE_WITH_M_INVCND1
    If GERR = 1 Then
      End
    Endif
  Endif

  GCLSINVCND.INVCNDLIN(ILINE).INVPERCENT = [M:INVCND1]INVPERCENT(nolign-1)

  #--The upper line code triggers the propagate, hence the following code :
  WILINE = ILINE
  Gosub SET_M_INVCND1_WITH_CLS_LINE
  If GERR = 1 : End : Endif

  Affzo [M:INVCND1]1-99

End
