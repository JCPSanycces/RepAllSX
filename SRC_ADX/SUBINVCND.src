######################################################################################
##  S/P                                                                              #
######################################################################################
# Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
Subprog VERF_PARAM(PPARAM, PVALEUR, POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

  If PVALEUR = "" Then
    End
  Endif

Local Char FCY(GLONFCY)
Local Char SAVE_GCURFCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char SAVE_GSOCIETE(GLONCPY)
Local Char LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

  Local File TABINVCND [INVCND]
  #-------------------------
  [L]SAVE_GCURFCY = GCURFCY
  [L]SAVE_GSOCIETE = GSOCIETE
  If GFONCTION = "ADPVAL" Then
    # Saisie valeurs paramètres. Type de données = PGT
    FCY = [M:ADWP]FCY
    GCURFCY = FCY
    CPY = [M:ADWP]CMP
    GSOCIETE = CPY

    If dim([M:ADWP]LEG) > 0 Then
      LEG = [M:ADWP]LEG
    Else
      LEG = GDOSLEG
    Endif

    #--Initialisation de législation
    #-- Initialisation de législation
    If func AFNC.ACTIV("LEG")=0
     [L]LEG = GDOSLEG
    Else
      If [L]LEG = "" Then
        If [L]FCY <> "" Then
          Call LEC_FCY([L]FCY) From CPTLEC
          Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
          GSOCIETE = [F:FCY]LEGCPY
          [L]LEG = [F:CPY]LEG
        Elsif [L]CPY <> "" Then
          Call LEC_CPY([L]CPY) From CPTLEC
          [L]LEG = [F:CPY]LEG
        Endif
      Endif
    Endif
    If [L]LEG = "" Then
      [L]LEG = GCURLEG
    Endif
    Call CONTINVCND(PVALEUR, LEG, "MULTILEGADP", PPARAM, FCY, "", CPY)
    If mkstat Then
      POK = 0
    Endif
  Endif
  GCURFCY  = [L]SAVE_GCURFCY
  GSOCIETE = [L]SAVE_GSOCIETE
End
######################################################################################
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
Subprog APRES_NBLIG()
Local Integer  NOL : NOL=nolign-1

  #--in case of abandonned modification (esc, select of another browser list while still beeing on the line etc.)
  If adxgtb=1 | find(status,6,7)
     Gosub HYBRID_REVERT_TO_SNAPSHOT
     End
  Elsif find(status,71, 75)
     Gosub HYBRID_SET_SNAPSHOT
     If GERR=1 : End : Endif
  Endif

End
#------------------------------------------------------------------------------------------------------
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$HYBRID_REVERT_TO_SNAPSHOT
Local Integer  WRET

  #--In order to handle abandonned modifications (on GESINVCND, when a line is abandoned - exp : using Escape)
  If GCLSINVCND<>null and GCLSINVCND.snapshot<>null
    WRET = GCLSINVCND.revertToSnapshot
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GERR=1 :Return : Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$HYBRID_SET_SNAPSHOT
Local Integer WRET

  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  If GCLSINVCND<>null
    If GCLSINVCND.snapshot<>null
      WRET = GCLSINVCND.freeSnapshot
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GCLSINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : Return : Endif
    Endif
    If GCLSINVCND.snapshotEnabled = 0
      GCLSINVCND.snapshotEnabled = 1 #--snapshot enabeling if not done yet
    Endif
  Endif

Return
# End issue X3-38457

