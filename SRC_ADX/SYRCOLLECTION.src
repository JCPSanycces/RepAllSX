##############################################################################################
# Common data : subroutine for collections
# FGR 04/2016
##############################################################################################
##############################################################################################
#**
#* Manage the value of sort property on insert collection line
#*
#* @param AINSTANCE current class
#* @param APRONAME  property name
#* @param AVALUE    property value
#* @param AINS      collection name in parent class
#* @param ISTEP     increment
#* @return  [V]CST_AERROR or [V]CST_AOK
#*!
Funprog SORTADD(AINSTANCE, APRONAME, AVALUE, AINS, ISTEP)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Integer AVALUE
Value Char AINS
Value Integer ISTEP

Local Integer ICURAORDER
Local Integer ARET_VALUE
Local Integer APOS
Local Integer ADIMMIN
Local Integer ADIMMAX
Local Integer NI
Local Integer NCURLINE
Local Integer NCURLINE1
Local Integer NPRELINE
Local Integer NPRELINE1


  # -----------------------------------------------
  If [L]AINS = "" or [L]APRONAME = "" Then
    End [V]CST_AERROR
  Endif
  If evalue("dim(AINSTANCE.APARENT." + [L]AINS + ")") < 0 Then
    End [V]CST_AERROR
  Endif
  # exitence du pointeur
  If [L]ISTEP = 0 Then
    [L]ISTEP = 1
  Endif
  [L]ICURAORDER = AINSTANCE.AORDER
  [L]ARET_VALUE = [V]CST_AOK
  If evalue("type(AINSTANCE.APARENT." + [L]AINS + ")") = 524 Then
    # c'est  un pointeur
    [L]ADIMMAX = fmet AINSTANCE.APARENT.AGETDIM(AINS)
    [L]ADIMMIN = fmet AINSTANCE.APARENT.AGETMIN(AINS)
    If [L]ADIMMAX=1 & [L]ADIMMIN=2
      Raz [L]APOS
    Else
      [L]APOS = evalue("maxtab(AINSTANCE.APARENT." + [L]AINS + ")")
    Endif
    # -----------------------------------------------
    # 1°) find the new line index in the collection
    NCURLINE = evalue("find([L]ICURAORDER," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(1)+".."+num$([L]APOS)+").AORDER)")
    Repeat
      If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")")<>null and find(evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+").ASTALIN"),[V]CST_ANEW) <> 0 Then
        Break
      Else
        NCURLINE1 = NCURLINE
        NCURLINE = evalue("find([L]ICURAORDER," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE1+1)+".."+num$([L]APOS)+").AORDER)")
        If NCURLINE > 0 Then
          NCURLINE += NCURLINE1
        Endif
      Endif
    Until 1=1
    # -----------------------------------------------
    # 2°) find the previous line index in the collection
    NPRELINE = evalue("find([L]ICURAORDER-1," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(1)+".."+num$([L]APOS)+").AORDER)")
    If NPRELINE > 0 Then
      Repeat
        If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NPRELINE)+")")<>null and find(evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NPRELINE)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          Break
        Else
          NPRELINE1 = NPRELINE
          NPRELINE = evalue("find([L]ICURAORDER-1," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(NPRELINE1+1)+".."+num$([L]APOS)+").AORDER)")
          If NPRELINE > 0 Then
            NPRELINE += NPRELINE1
          Endif
        Endif
      Until 1=1
    Endif
    # -----------------------------------------------
    # 3°) the TRKSORT for the new line is the previous one plus 1
    If NPRELINE = 0 Then
      Assign("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")."+ [L]APRONAME) With ISTEP
    Else
      Assign("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")."+ [L]APRONAME) With evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NPRELINE)+")."+ [L]APRONAME) + ISTEP
    Endif
    # -----------------------------------------------
    # 4°) We have to add 1 on all others line in the collection which have TRKSORT >= the the current line TRKSORT (execpt the current line)
    For NI = 1 To [L]APOS
      If NI <> NCURLINE Then
        If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")")<>null and find(evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) >= evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")."+ [L]APRONAME) Then
            Assign("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) With evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) + ISTEP
          Endif
        Endif
      Endif
    Next NI
    # -----------------------------------------------
  Endif
End [L]ARET_VALUE

##############################################################################################
#**
#* Manage the value of sort property on delete collection line
#*
#* @param AINSTANCE current class
#* @param APRONAME  property name
#* @param AVALUE    property value
#* @param AINS      collection name in parent class
#* @param ISTEP     increment
#* @return  [V]CST_AERROR or [V]CST_AOK
#*!
Funprog SORTDEL(AINSTANCE, APRONAME, AVALUE, AINS, ISTEP)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Integer AVALUE
Value Char AINS
Value Integer ISTEP

Local Integer ICURAORDER
Local Integer ARET_VALUE
Local Integer NCURLINE
Local Integer NCURLINE1
Local Integer NI
Local Integer APOS
Local Integer ADIMMIN
Local Integer ADIMMAX

  If [L]AINS = "" or [L]APRONAME = "" or ISTEP < 0 Then
    End [V]CST_AERROR
  Endif
  If evalue("dim(AINSTANCE.APARENT." + [L]AINS + ")") < 0 Then
    End [V]CST_AERROR
  Endif
  # exitence du pointeur
  If [L]ISTEP = 0 Then
    [L]ISTEP = 1
  Endif
  [L]ICURAORDER = AINSTANCE.AORDER
  ARET_VALUE = [V]CST_AOK
  If evalue("type(AINSTANCE.APARENT." + [L]AINS + ")") = 524 Then
    # c'est  un pointeur
    [L]ADIMMAX = fmet AINSTANCE.APARENT.AGETDIM(AINS)
    [L]ADIMMIN = fmet AINSTANCE.APARENT.AGETMIN(AINS)
    If [L]ADIMMAX=1 & [L]ADIMMIN=2
      Raz [L]APOS
    Else
      [L]APOS = evalue("maxtab(AINSTANCE.APARENT." + [L]AINS + ")")
    Endif
    # -----------------------------------------------
    # 1°) find the new line index in the collection
    NCURLINE = evalue("find([L]ICURAORDER," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(1)+".."+num$([L]APOS)+").AORDER)")
    Repeat
      If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")")<>null and find(evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) <> 0 Then
        Break
      Else
        NCURLINE1 = NCURLINE
        NCURLINE = evalue("find([L]ICURAORDER," + "AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE1+1)+".."+num$([L]APOS)+").AORDER)")
        If NCURLINE > 0 Then
          NCURLINE += NCURLINE1
        Endif
      Endif
    Until 1=1
    # -----------------------------------------------
    For NI = 1 To [L]APOS
      If NI <> NCURLINE Then
        If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")")<>null and find(evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) >= evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NCURLINE)+")."+ [L]APRONAME) Then
            Assign("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) With evalue("AINSTANCE.APARENT."+[L]AINS+"("+num$(NI)+")."+ [L]APRONAME) - ISTEP
          Endif
        Endif
      Endif
    Next NI
    # -----------------------------------------------
  Endif
End [L]ARET_VALUE

##############################################################################################
#**
#* Compute a new unic sequence number in a collection
#*
#* @param AINSTANCE current class
#* @param APRONAME  property name
#* @param AVALUE    property value
#* @param AINS      collection name in parent class
#* @param ISTEP     increment
#* @return  [V]CST_AERROR or [V]CST_AOK
#*!
Funprog SEQADD(AINSTANCE, APRONAME, AVALUE, AINS, ISTEP)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Integer AVALUE
Value Char AINS
Value Integer ISTEP

Local Integer ARET_VALUE
Local Integer ADIMMIN
Local Integer ADIMMAX
Local Integer APOS

  # -----------------------------------------------
  If [L]AINS = "" or [L]APRONAME = "" Then
    End [V]CST_AERROR
  Endif
  If evalue("dim(AINSTANCE.APARENT." + [L]AINS + ")") < 0 Then
    End [V]CST_AERROR
  Endif
  # exitence du pointeur
  If [L]ISTEP = 0 Then
    [L]ISTEP = 1
  Endif
  [L]ARET_VALUE = [V]CST_AOK
  If evalue("type(AINSTANCE.APARENT." + [L]AINS + ")") = 524 Then
    # c'est  un pointeur
    [L]ADIMMAX = fmet AINSTANCE.APARENT.AGETDIM(AINS)
    [L]ADIMMIN = fmet AINSTANCE.APARENT.AGETMIN(AINS)
    If [L]ADIMMAX=1 & [L]ADIMMIN=2
      Assign("AINSTANCE." + [L]APRONAME) With 0
    Else
      [L]APOS = evalue("maxtab(AINSTANCE.APARENT." + [L]AINS + ")")
      Assign("AINSTANCE." + [L]APRONAME) With evalue("max(AINSTANCE.APARENT." + [L]AINS + "(" + num$(1) + ".." + num$([L]APOS) + ")." + [L]APRONAME + ")") + ISTEP
    Endif
    # -----------------------------------------------
  Endif
End [L]ARET_VALUE

