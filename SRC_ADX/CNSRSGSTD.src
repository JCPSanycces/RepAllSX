#<AdxTL>@(#)4.0.0.0 $Revision$
#################################################################################################################
#
#   Recapitulative Statement Germany
#
#   PURPOSE :    Gathers data for monthly, quarterly or yearly recapitulative statements
#                according to German VAT legislation and creates printable reports,
#                XML-, CSV- and ELMA5-file-exports.
#   AUTHORS :    DNE
#   DATE    :    2012-05-16
#   UPDATES :    2012-08-14 DNE - Company groups
#                2012-08-15 DNE - Consistency checks before file export: Exports are not allowed if there
#                                 are errors or even warnings.
#                2012-08-27 DNE - Common code moved to CNSRSGSTDLIB.src to be used by the Austrian recap.
#                                 statement function, too.
#   UPDATES :    2013-01-11 MAMAY/DNE - Mass data complient update
#                2013-12-12 ANGRE/DNE - Reduced export impediments (SAM #95245)
#                2017-03-13 DNE - Field GERPTP (participant code) removed including all warnings on
#                                 non-existence (X3-7773)
#
#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "RSG", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################



#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "OUVRE"       : Gosub OUVRE
        When "EXEBOUT"     : Gosub EXEBOUT
        When "FERME"       : Gosub FERME
        When "LECTURE"     : Grizo [M:RSG0]FLGVALIDONLY # SAM #95245 (DNE)
        When "APRES_MODIF" : FLGSELMODIFIED = 1
        When "SEL_LISTE"   : If LISTE = "SELRSGCRN" : Gosub SEL_LISTE_SELRSGCRN : Endif
        When "SETBOUT"     : Gosub SETBOUT
    Endcase
Return



#** #############################################################################################
#* SETBOUT disables inquiry export menu entries.
#*! #############################################################################################

$SETBOUT
    Disable GSTAXLS
    Disable GSTAXLS2
Return



#** #############################################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Open/Initialize objects and variables.
#*
#*! #############################################################################################################

$OUVRE
    # Processing local variables (to make sure they exist everywhere).
    Local Integer  I
    Local Char FILERSG(255)
    Local Integer FLGSELMODIFIED : FLGSELMODIFIED = 0 # Modification flag.
    Local Integer NOERR          : NOERR = 0          # Number of errors (red bullets)
    Local Integer NOWARN         : NOWARN = 0         # Number of warnings (yellow bullets)
    Local Char WFILDATDEB(255)                        # Start date filter
    Local Char WFILDATFIN(255)                        # End date filter
    Local Char WFILCRY(255)                           # Country filter
    Local Char WFILVAT(255)                           # VAT code filter

    # Open needed tables.
    If clalev([F:GCM])=0   : Local File GACM        [GCM]   : Endif
    If clalev([F:LED])=0   : Local File GLED        [LED]   : Endif
    If clalev([F:COA])=0   : Local File GCOA        [COA]   : Endif
    If clalev([F:GTE])=0   : Local File GTYPACCENT  [GTE]   : Endif
    If clalev([F:HAE])=0   : Local File GACCENTRY   [HAE]   : Endif
    If clalev([F:DAE])=0   : Local File GACCENTRYD  [DAE]   : Endif
    If clalev([F:CPY])=0   : Local File COMPANY     [CPY]   : Endif
    If clalev([F:FCY])=0   : Local File FACILITY    [FCY]   : Endif
    If clalev([F:BPR])=0   : Local File BPARTNER    [BPR]   : Endif
    If clalev([F:BPD])=0   : Local File BPDLVCUST   [BPD]   : Endif
    If clalev([F:BPC])=0   : Local File BPCUSTOMER  [BPC]   : Endif
    If clalev([F:GAC])=0   : Local File GACCOUNT    [GAC]   : Endif
    If clalev([F:AGC])=0   : Local File AGRPCPY     [AGC]   : Endif
    If clalev([F:FGR])=0   : Local File FACGROUP    [FGR]   : Endif
    If clalev([F:BPA])=0   : Local File BPADDRESS   [BPA]   : Endif
    If func ASYRFNC.ACTIV("MUL") >0 : # Issue 56229 - 2017-11-15 by MWA
      If clalev([F:BPE])=0   : Local File BPEXCEPT    [BPE]   : Endif
    Endif
    If clalev([F:SIH])=0   : Local File SINVOICE    [SIH]   : Endif
    If clalev([F:SIV])=0   : Local File SINVOICEV   [SIV]   : Endif
    If clalev([F:RSLG1])=0 : Local File RSLINESGER1 [RSLG1] : Endif
    If clalev([F:RSLG2])=0 : Local File RSLINESGER2 [RSLG2] : Endif

    # Open recap. statement configuration table.
    If clalev([F:RSP])=0   : Local File VDGERRSP    [RSP]   : Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  EXEBOUT
#*
#* Purpose:    Button dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button.
#*
#*! #############################################################################################################

$EXEBOUT
    Case BOUT
        When "A" # OK button
            # Calculate recap. statement.
            Call TEMPON( "C" ) From GESECRAN
            Gosub CALC_RECAP_STATEMENT From CNSRSGSTDLIB
            Call TEMPOFF From GESECRAN

        When "B", "1" # "Print" or "Export" button

            If [M:RSG1]NBLIG <> 0 & sum( [M:RSG1]AMTTRN(0..( [M:RSG1]NBLIG ) ) ) = 0
              Call ERREURT( mess(324,107,1), 1 ) From GESECRAN # "Export is not possible, as the total is 0,00. German Recapitulative Statements with a total of 0,00 are not to be transmitted!"
              Return
            Endif

            # Alert if the site is set for a real reporting is only allowed for companies not sites.
            If [M:RSG0]FCYLIN <> ""
                Call ERREURT( mess(280,107,1), 1 ) From GESECRAN # "Only companies/company groups can print/export recap. stat. Please empty site field."
                Return
            Endif

            # Warn if the curreny is not EUR.
            If [M:RSG0]CUR <> "EUR"
                Call ERREURT( mess(320,107,1), 0 ) From GESECRAN # "Ledger currency is not EUR."
            Endif

            # Recalculate recapitulative statement (if necessary which is indicated
            # by the flag FLGSELMODIFIED).
            If FLGSELMODIFIED
                Call TEMPON( "C" ) From GESECRAN
                Gosub CALC_RECAP_STATEMENT From CNSRSGSTDLIB
                Call TEMPOFF From GESECRAN
            Endif

            # Alert if the result set is empty (that is there is nothing to report.)
            If [M:RSG1]POSTOT = 0
                Call ERREURT( mess(279,107,1), 1 ) From GESECRAN # "An empty result set cannot be printed/exported."
                Return
            Endif

            # Branch to print or export functionality.
            Case BOUT
                When "B" # Button "Report"
                    # If there was an error/warning created in CALC_RECAP_STATEMENT display a warning
                    # message and ask if we should proceed.
                    If NOERR or NOWARN
                        Local Integer YESNO : YESNO = 1 # NO.
                        Call OUINONT( mess(276,107,1) + "\" + mess(286,107,1) + "\" + mess(287,107,1), YESNO ) From GESECRAN
                                      # "There are errors/warnings.\By default they will be absent from the recapitulation statement and displayed in the control report.\Proceed anyway?"
                        Case YESNO
                            When 1 : Return
                        Endcase
                    Endif
                    Call OPEN_REPORT( GFONCTION ) From CNSRSGSTDLIB

                When "1" # Button "Export"
                    # Yearly exporting is not allowed.
                    If month( [M:RSG0]DATDEB ) = 1 and month([M:RSG0]DATFIN ) = 12
                        Call ERREURT( mess(310,107,1) - mess(288,107,1), 1 ) From GESECRAN
                                      # "Results for a calendar year date range are available in preview mode only. Recapitulative statement cannot be exported"
                        Return
                    Endif

                    # If there was an error/warning created in CALC_RECAP_STATEMENT display an error
                    # message and abort.
                    #
                    # SAM #95245 (ANGRE/DNE)
                    Local Char GRPCPY(GLONCPY)

                    If [M:RSG0]CPY <> "" Then
                        GRPCPY = [M:RSG0]CPY
                    Elsif  [M:RSG0]GRP <> ""
                        GRPCPY = [M:RSG0]GRP
                    Endif
                    If ( NOERR and ( [M:RSG0]FLGVALIDONLY <> 2 ) )
&                      or ( NOWARN and ( func AFNC.PARAM( "GERRSEXTMP", GRPCPY ) <> "2" ) )
                        Call ERREURT( mess(276,107,1) - mess(288,107,1), 1 ) From GESECRAN
                                      # "There are errors/warnings. Recapitulative statement cannot be exported."
                        Return
                    Endif

                    # Open the RSG export screen.
                    Call OPEN_RS_EXPORT_DIALOG From CNSRSGSTDLIB
            Endcase

       When "5" # Button "Recall"
            If [M:RSG0]GRP = ""
                Call SET_FLGVALIDONLY( [M:RSG0]CPY )
            Else
                Call SET_FLGVALIDONLY( [M:RSG0]GRP )
            Endif
            FLGSELMODIFIED = 1
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  FERME
#*
#* Purpose:    Handler after closing the window. Does some cleaning up:
#*             - Deletes temporary report data from AREPORTM table.
#*
#*! #############################################################################################################

$FERME
    # Delete temporary report data from AREPORTM table.
    If !clalev([ARM]): Local File AREPORTM[ARM] : Endif

    # Delete temporary table data
    Call DELETEDBLINES From CNSRSGSTDLIB

    GOK = 1
    Call DEBTRANS From GLOCK
    Trbegin [ARM]
    Delete [ARM] Where
&       ( ( RPTCOD = [M:RSG0]LEG + "RS" ) or ( RPTCOD = [M:RSG0]LEG + "RSVAL" ) )
&       & USR = GUSER
    If fstat
        Rollback
    Else
        Commit
    Endif
    File [ARM]

    # Reenable inquiry exports.
    Enable GSTAXLS
    Enable GSTAXLS2
Return



#** #############################################################################################################
#*
#* Sub chunk:  SEL_LISTE_SELRSGCRN
#*
#* Purpose:    Handler to the SEL_LISTE event for SELRSGCRN action.
#*             Creates a list of the company's tax identifiers to choose from.
#*
#*! #############################################################################################################

$SEL_LISTE_SELRSGCRN
    Local Integer DIMTAXNUM : DIMTAXNUM = dim([CPY]GERTAXIDT)     # Number of possible tax identifiers
    Local Char TEXTE(30)(1..DIMTAXNUM, 1..3)                      # Array for selection rows
    Local Char TEX(30)(1..DIMTAXNUM)                              # Array for selection values
    Local Char COMP(GLONCPY)                                      # Company or company group
    Local Integer I                                               # FOR loop counter

    # Initialize row and column counter.
    NBCOL = 0                                                     # Column counter
    NBTEX = 0                                                     # Row counter

    # Set selection title.
    TIT(NBCOL) = mess(252,107,1)                                  # "Tax identifier"

    # Set column titles.
    NBCOL += 1
    TIT(NBCOL) = mess(252,107,1)                                  # "Tax identifier"
    NBCOL += 1
    TIT(NBCOL) = mess(253,107,1)                                  # "Tax office"
    NBCOL += 1
    TIT(NBCOL) = ""

    # Fill selection with tax identifier and tax office
    If [M:RSG0]GRP <> ""
      COMP = [M:RSG0]GRP
    Else
      COMP = [M:RSG0]CPY
    Endif
    Read [F:CPY]CPY0 = COMP
    If !fstat
        For I = 0 To DIMTAXNUM - 1

            # Check if the last tax identifier was reached and break off.
            If [CPY]GERTAXIDT( I ) = ""
                Break
            Endif

            # Add row to selection list.
            NBTEX += 1
            TEX( NBTEX ) = [CPY]GERTAXIDT( I )
            TEXTE( NBTEX, 1 ) = [CPY]GERTAXIDT( I )
            TEXTE( NBTEX, 2 ) = [CPY]GERTAXCEN( I )
            Read [F:BPR]BPR0 = [CPY]GERTAXCEN( I )
            If !fstat
                TEXTE( NBTEX, 3 ) = [F:BPR]BPRNAM
            Endif
        Next
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  SINGLE_DOCUMENT
#*
#* Purpose:    Cleans up the detail tab (mask CONSRSG2) and reinitializes the detail information for the
#*             selected line in the result tab (mask CONSRSG1).
#*
#*! #############################################################################################################

$SINGLE_DOCUMENT
    Local Integer K : K = 0 # Line counter

    # Clean up detail mask.
    Raz [M:RSG2]

    # Reinitialize the selected data.
    Filter [RSLG2] Where GEREECNUM = [M:RSG1]GEREECNUM( nolign - 1 )
&                  and USERID = func CNSRSGSTDLIB.GETUSERID()
&                  and TRNTYP = [M:RSG1]TRNTYP( nolign - 1 )
    For [F:RSLG2]
        [M:RSG2]OFFACC(K)    = [F:RSLG2]OFFACC
        [M:RSG2]GEREECNUM(K) = [F:RSLG2]GEREECNUM
        [M:RSG2]NUM(K)       = [F:RSLG2]NUM
        [M:RSG2]TYP(K)       = [F:RSLG2]TYP
        [M:RSG2]AMTTRN(K)    = [F:RSLG2]AMTTRN
        [M:RSG2]DESVCR(K)    = [F:RSLG2]DESVCR
        [M:RSG2]TAX(K)       = [F:RSLG2]TAX
        [M:RSG2]VACBPR(K)    = [F:RSLG2]VACBPR
        [M:RSG2]VACBPRRSP(K) = [F:RSLG2]VACBPRRSP
        [M:RSG2]TRNTYP(K)    = [F:RSLG2]TRNTYP
        [M:RSG2]CRY(K)       = [F:RSLG2]CRY
        [M:RSG2]COMMENT(K)   = [F:RSLG2]COMMENT
        [M:RSG2]FLG(K)       = [F:RSLG2]FLG
        K += 1
    Next
    Filter [RSLG2]

    # Set number of lines.
    [M:RSG2]NBLIG = K

    # Update the detail screen view.
    Affzo [M:RSG2]
Return



# ###############################################################################################################
# ##########
# ########## Utility functions/procedures
# ##########
# ##########
# ##########
# ###############################################################################################################

#** #############################################################################################################
#*
#*Procedure:   GET_CPYDATA
#*
#* Purpose:    Loads some fields from company/company group configuration.
#*
#*
#* Parameters:
#*
#* @param PCPY           Value Char       Company
#* @param PGRP           Value Char       Company group
#* @param RLEG           Variable Char    Returns the legislation
#* @param RGEREECNUM     Variable Char    Returns the EU VAT ID
#* @param RCRN           Variable Char    Returns the tax identifier
#* @param RGERCODELMA5   Variable Char    Returns the participant code
#*
#*! #############################################################################################################

Subprog GET_CPYDATA( PCPY, PGRP, RLEG, RGEREECNUM, RCRN, RGERCODELMA5 )
Value Char PCPY
Value Char PGRP
Variable Char RLEG()
Variable Char RCRN()
Variable Char RGEREECNUM()
Variable Char RGERCODELMA5()

    Local Char CPY(GLONCPY) # Holds the company/company group

    # If there is no company and no company group given do nothing.
    If PCPY = "" & PGRP = "" Then
        End
    Endif

    # If a company is provided in PCPY CPY is set to the given company.
    If PCPY <> "" Then
        CPY = PCPY
    # Else if a company group is provided in PGRP CPY is set to the given company groupy.
    Elsif  PGRP <> ""
        CPY = PGRP
    Endif

    # Look up in the company table for the company's legislation, the participant code etc.
    Read [F:CPY]CPY0 = CPY
    If !fstat
        RLEG = [F:CPY]LEG
        Call GET_TAXNUM_EECNUM( CPY, "", RGEREECNUM, RCRN, RGERCODELMA5 )
    Endif
End



#** #############################################################################################################
#*
#* Procedure:  GET_TAXNUM_EECNUM
#*
#* Purpose:    Searches for the participant number for RS in the company legal data information and returns it.
#*             An error occurs if no participant number is found and mkstat set to 2 to block the user.
#*
#*
#* Parameters:
#*
#* @param PCPY           Value Char       Company
#* @param PCRN           Value Char       Tax ID
#* @param RGEREECNUM     Variable Char    Returns the EU VAT ID
#* @param RCRN           Variable Char    Returns the tax identifier
#* @param RGERCODELMA5   Variable Char    Returns the participant code
#*
#*! #############################################################################################################

Subprog GET_TAXNUM_EECNUM( PCPY, PCRN, RGEREECNUM, RCRN, RGERCODELMA5 )
Value Char PCPY
Value Char PCRN
Variable Char RCRN()
Variable Char RGEREECNUM()
Variable Char RGERCODELMA5()

    Local Integer I

    RCRN = ""
    Read [F:CPY]CPY0 = PCPY
    If !fstat
        If PCRN <> ""
            For I = 0 To dim([CPY]GERTAXIDT) - 1
                If PCRN = [CPY]GERTAXIDT(I)
                    RCRN = PCRN
                    RGEREECNUM = [CPY]GEREECNUM(I)
                    RGERCODELMA5 = [CPY]GERCODELMA5(I)
                    Break
                Endif
            Next
        Else
            For I = 0 To dim([CPY]GERTAXIDT) - 1
                If [CPY]GERDEFVAL(I) - 1
                    RCRN = [CPY]GERTAXIDT(I)
                    RGEREECNUM = [CPY]GEREECNUM(I)
                    RGERCODELMA5 = [CPY]GERCODELMA5(I)
                    Break
                Endif
            Next
        Endif
    Endif
End



# SAM #95245 (DNE)
#** #############################################################################################################
#*
#* Procedure:  SET_FLGVALIDONLY
#*
#* Purpose:    Enables or disables FLGVALIDONLY according to setting of paramter GERRSEXTMP.
#*
#*
#* Parameters:
#*
#* @param PCPY           Value Char       Company
#*
#*! #############################################################################################################

Subprog SET_FLGVALIDONLY( PCPY )
Value Char PCPY

    # Enable or disable FLGVALIDONLY according to setting of paramter GERRSEXTMP.
    If func AFNC.PARAM( "GERRSEXTMP", PCPY ) = "2"
        Actzo [M:RSG0]FLGVALIDONLY
    Else
        [M:RSG0]FLGVALIDONLY = 1
        Grizo [M:RSG0]FLGVALIDONLY
    Endif
End



# ###############################################################################################################
# ##########
# ########## Screen/Window handling
# ##########
# ##########
# ##########
# ###############################################################################################################

#################################################################################################################
#
#    Event: Validate the company group entry.
#    Does:  Consistency checks for the company group (see code comments).
#
#################################################################################################################

Subprog C_GRP(VALEUR)
Variable Char VALEUR()
    Local Char CRN(20), GEREECNUM(20), LEG(10), GERCODELMA5(11)
    Local Char CUR(GLONCUR) : CUR = ""
    Local Integer COUNTER : COUNTER = 0

    If VALEUR <> ""
        # Check consistency of parameter DCLVATDAT and currency between the company group and
        # its member companies.
        Local Integer IS_DOCDATE : IS_DOCDATE = func CNSRSGSTDLIB.IS_DCLVATDAT_OF_CPY_DOCDATE( VALEUR )

        For [F:AGC] Where GRP = VALEUR
            # Check parameter consistency for group members.
            If IS_DOCDATE <> func CNSRSGSTDLIB.IS_DCLVATDAT_OF_CPY_DOCDATE( [F:AGC]CPY )
                GMESSAGE = mess(284,107,1) - [F:AGC]CPY + "." # "Inconsistent parameter DCLVATDAT for company"
                mkstat = 2
                End
            Endif

            # Check currency consistency for group members.
            Read [F:CPY]CPY0 = [F:AGC]CPY
            If !fstat
                If COUNTER = 0
                    CUR = [F:CPY]ACCCUR
                Elsif CUR <> [F:CPY]ACCCUR
                    GMESSAGE = mess(319,107,1) # "Inconsistent currencies upon group."
                    mkstat = 2
                    End
                Endif
            Endif

            COUNTER += 1
        Next

        # Check if the given value is a group of companies.
        If COUNTER < 1
            GMESSAGE = mess(283,107,1) # "This is not a group of companies."
            mkstat = 2
            End
        Endif

        # Check if the company group has a tax identifier.
        Call GET_CPYDATA( [M:RSG0]CPY, VALEUR, LEG, GEREECNUM, CRN, GERCODELMA5 )
        If CRN = ""
            GMESSAGE = mess(299,107,1) + "\" + mess(300,107,1) # "Tax identifier missing. Please check the company's legal data settings."
            mkstat = 2
            End
        Endif
    Endif
End



#################################################################################################################
#
#    Event: After company group field has changed.
#    Does:  Greys out company and site fields and loads some data from the company group's legal data
#           parameterization.
#
#################################################################################################################

Subprog AM_GRP(VALEUR)
Variable Char VALEUR()

    # If company group is given gray out company and side.
    If VALEUR <> "" Then
        [M:RSG0]CPY = ""
        [M:RSG0]FCYLIN = ""
        Affzo [M:RSG0]
        Grizo [M:RSG0]CPY
        Grizo [M:RSG0]FCYLIN
    Else
        Actzo [M:RSG0]
    Endif

    # Set EU VAT ID,  participant code and tax identifier
    Call GET_CPYDATA( [M:RSG0]CPY, VALEUR, [M:RSG0]LEG, [M:RSG0]GEREECNUM, [M:RSG0]CRN, [M:RSG0]GERCODELMA5 )

    # Set currency.
    Read [F:AGC]AGC0(1) = VALEUR
    If !fstat
        Read [F:CPY]CPY0 = [F:AGC]CPY
        If !fstat
            [M:RSG0]CUR = [F:CPY]ACCCUR
        Endif
    Endif

    # SAM #95245 (DNE)
    # Enable or disable FLGVALIDONLY according to setting of paramter XEGERRSEXT.
    Call SET_FLGVALIDONLY( VALEUR )

    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: Validate the company entry.
#    Does:  Consistency checks for the company (see code comments).
#
#################################################################################################################

Subprog C_CPY(VALEUR)
Variable Char VALEUR()

    Local Char CRN(20), GEREECNUM(20), LEG(10), GERCODELMA5(11)

    If VALEUR = ""
        If [M:RSG0]GRP = ""
            GMESSAGE = mess(256,107,1) # "Please enter company or company group."
            mkstat = 2
        Endif
    Else
        Call GET_CPYDATA( VALEUR, [M:RSG0]GRP, LEG, GEREECNUM, CRN, GERCODELMA5 )
        If CRN = ""
            GMESSAGE = mess(299,107,1) + "\" + mess(300,107,1) # "Tax identifier missing. Please check the company's legal data settings."
            mkstat = 2
        Endif
    Endif
End



#################################################################################################################
#
#    Event: After company field has changed.
#    Does:  Greys out company group field and loads some data from the company's legal data parameterization.
#
#################################################################################################################

Subprog AM_CPY(VALEUR)
Variable Char VALEUR()

    # Set legislation, EU VAT ID,  participant code and tax identifier
    Call GET_CPYDATA( VALEUR, [M:RSG0]GRP, [M:RSG0]LEG, [M:RSG0]GEREECNUM, [M:RSG0]CRN, [M:RSG0]GERCODELMA5 )

    # Set currency.
    Read [F:CPY]CPY0 = VALEUR
    If !fstat
        [M:RSG0]CUR = [F:CPY]ACCCUR
    Endif

    # SAM #95245 (DNE)
    # Enable or disable FLGVALIDONLY according to setting of paramter XEGERRSEXT.
    Call SET_FLGVALIDONLY( VALEUR )

    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: While changing the end date.
#    Does:  Checks it we use a correct date range (monthly, quarterly etc.)
#
#################################################################################################################

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR

    If VALEUR < [M:RSG0]DATDEB
&      or year([M:RSG0]DATDEB) <> year(VALEUR)
        GMESSAGE = mess(264,107,1)      # "Invalid date range"
        mkstat = 2
        End
    Endif
    If gdat$( 0, month( VALEUR ) + 1, year( VALEUR ) ) <> VALEUR
&      or gdat$( 1, month( [M:RSG0]DATDEB ), year( [M:RSG0]DATDEB ) ) <> [M:RSG0]DATDEB
        GMESSAGE = mess(264,107,1)      # "Invalid date range"
        mkstat = 2
        End
    Endif
    If !( (month([M:RSG0]DATDEB) = month(VALEUR))
&      or (month([M:RSG0]DATDEB)=1 and month(VALEUR)=3)
&      or (month([M:RSG0]DATDEB)=4 and month(VALEUR)=6)
&      or (month([M:RSG0]DATDEB)=7 and month(VALEUR)=9)
&      or (month([M:RSG0]DATDEB)=10 and month(VALEUR)=12)
&      or (month([M:RSG0]DATDEB)=1 and month(VALEUR)=12) )
        GMESSAGE = mess(264,107,1)      # "Invalid date range"
        mkstat = 2
        End
    Endif
End



#################################################################################################################
#
#    Event: While changing the legislation.
#    Does:  Checks if the given legislation is part of the RS parameterization in table VDGERRSP.
#
#################################################################################################################

Subprog C_LEG(VALEUR)
Variable Char VALEUR()

    If VALEUR <> ""
        Read [F:RSP]RSP0(1) = VALEUR
        If fstat
            GMESSAGE = mess(261,107,1) - VALEUR # "This legislation does not have a recapitulative statement parameterization."
            mkstat = 2
            End
        Endif
    Endif
End



#################################################################################################################
#
#    Event: While entering/changing the site field
#    Does:  Checks if the given site corresponds to the company/company group field.
#
#################################################################################################################

Subprog C_FCYLIN(VALEUR)
Variable Char VALEUR()

    If VALEUR <> ""
        Read [F:FCY]FCY1 = [M:RSG0]CPY; VALEUR
        If fstat
          GMESSAGE = mess(412,199,1) # "This is not a company site"
            mkstat = 2
        Endif
    Endif
End



#################################################################################################################
#
#    Event: While changing the tax identifier (to another tax identifier of the company).
#    Does:  Checks that the tax identifier corresponds to the company/company group parameterization
#           and that an RS particpant number exists ind the company legal data settings.
#
#################################################################################################################

Subprog C_CRN(VALEUR)
Variable Char VALEUR()
    Local Char CPY(GLONCPY) : Raz CPY

    # If company and group are empty we cannot do anything. So we just leave.
    If [M:RSG0]CPY = "" & [M:RSG0]GRP = "" Then
        End
    Endif

    # Otherwise we get the needed company code either from company or company group field
    # for further use (see below).
    If [M:RSG0]CPY <> "" Then
        CPY = [M:RSG0]CPY
    Elsif  [M:RSG0]GRP <> ""
        CPY = [M:RSG0]GRP
    Endif

    # Get the EU VAT ID, participant code and tax identifier by company and tax identifier.
    Local Char CRN(20), GEREECNUM(20), GERCODELMA5(11)

    Call GET_TAXNUM_EECNUM( CPY, VALEUR, GEREECNUM, CRN, GERCODELMA5 )
    If VALEUR <> CRN
        GMESSAGE = mess(285,107,1) # "Incorrect tax identifier."
        mkstat = 2
        End
    Endif
End



#################################################################################################################
#
#    Event: After tax identifier field has changed.
#    Does:  Fill the member number field.
#
#################################################################################################################

Subprog AM_CRN(VALEUR)
Variable Char VALEUR()
    Local Char CPY(GLONCPY) : Raz CPY

    # If company and group are empty we cannot do anything. So we just leave.
    If [M:RSG0]CPY = "" & [M:RSG0]GRP = "" Then
        End
    Endif

    # Otherwise we get the needed company code either from company or company group field
    # for further use (see below).
    If [M:RSG0]CPY <> "" Then
        CPY = [M:RSG0]CPY
    Elsif  [M:RSG0]GRP <> ""
        CPY = [M:RSG0]GRP
    Endif

    # Set EU VAT ID,  participant code and tax identifier.
    Call GET_TAXNUM_EECNUM( CPY, VALEUR, [M:RSG0]GEREECNUM, VALEUR, [M:RSG0]GERCODELMA5 )
    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: While entering a line in mask RSP0.
#    Does:  Selects all documents accourding to EU TAX ID and line code in the selected line in mask RSP2.
#
#################################################################################################################

Subprog IB_NBLIG
    Gosub SINGLE_DOCUMENT
End

