##########################################################################################################
##########################################################################################################

#-- Accounting code lines V8
$GACCCODLIG
Local Integer NBRLIG
Local File =[F:ADS]DOSSIER+".GACCCODLIG"  [CCL]

Call ECR_TIME(mess(81,125,1)-": GACCCODLIG") From DOSSUB : # maj table

Trbegin [CCL]

Read [CCL]CCL0 = 1;72
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
 [F:CCL]NUMLIG = 72
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 183
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-72",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 1;73
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
 [F:CCL]NUMLIG = 73
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 186
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-73",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 8;16
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 8
 [F:CCL]NUMLIG = 16
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 184
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/8-16",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 8;17
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 8
 [F:CCL]NUMLIG = 17
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 185
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/8-17",1) From DOSDIC
 Endif
Endif

Commit
Close Local File [CCL]
Return

