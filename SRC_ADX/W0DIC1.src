#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DIC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLD
mkstat = 0
zoncou = "FLD"
indice = 0
If varmode([M]FLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FLD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "DIC"
  Local Char    VALEUR(250)
  VALEUR = [M]FLD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]FLD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WDES
mkstat = 0
zoncou = "WDES"
indice = 0
If varmode([M]WDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WDES" : Gosub ACTION From =IMPTRT
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TBL
mkstat = 0
zoncou = "TBL"
indice = 0
If varmode([M]TBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TBL" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TBL,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TBL" : GZNUM = 1176 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("ATB","",[M]TBL,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TBL" : GZNUM = 1176 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ROW
mkstat = 0
zoncou = "ROW"
indice = 0
If varmode([M]ROW,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ROW" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ENAFLG(IMPENT) From SUBDIC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENAFLG" : GZNUM = 188 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ENAFLG = IMPENT

## Zone ENASEL
mkstat = 0
zoncou = "ENASEL"
indice = 0
IMPENT = [M]ENASEL
If varinit([M]ENASEL,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENASEL,indice)=0
 [M]ENASEL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENASEL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENASEL(indice)
 Endif
Endif
[M]ENASEL = IMPENT

## Zone MSFLG
mkstat = 0
zoncou = "MSFLG"
indice = 0
IMPENT = [M]MSFLG
If varinit([M]MSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MSFLG,indice)=0
 [M]MSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MSFLG(indice)
 Endif
Endif
[M]MSFLG = IMPENT

## Zone POTFLG
mkstat = 0
zoncou = "POTFLG"
indice = 0
IMPENT = [M]POTFLG
If varinit([M]POTFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]POTFLG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POTFLG(IMPENT) From SUBDIC
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]POTFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "POTFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]POTFLG(indice)
 Endif
Endif
[M]POTFLG = IMPENT

## Zone FLGRET
mkstat = 0
zoncou = "FLGRET"
indice = 0
IMPENT = [M]FLGRET
If varinit([M]FLGRET,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGRET,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FLGRET(IMPENT) From SUBDIC
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]FLGRET(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGRET" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGRET(indice)
 Endif
Endif
[M]FLGRET = IMPENT

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"
indice = 0
status = 1
zoncou = "NBRPAR"
If varmode([M]NBRPAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPAR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPAR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPAR = nolign
   status = 75
   Call SAI_NBRPAR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRPAR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"

## Zone PARCOD
mkstat = 0
zoncou = "PARCOD"
If varmode([M]PARCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PARCOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 36 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PARVAL
mkstat = 0
zoncou = "PARVAL"
If varmode([M]PARVAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARVAL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DIC1"
Return

