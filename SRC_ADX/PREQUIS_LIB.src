#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub LOADPARAMFROMDOC
End
####################################################################################
# Bibliothèque des fonctions et méthodes associées aux classes PREQUIS et PREQUISD #
####################################################################################
#######################################################################################
#---------------------------------------------------------------------------- #
# Alimentation des paramètres pour la recherche des codes taxes               #
#                                                                             #
# Method that loads properties of FINDVAT (MYPARAM) with PREQUISD (this)      #
#                                                                             #
#------------------------------------------------------------------------------
$LOADVATPARAMFROMDOC

Local Date    WDAT
Local Char    WCUR(GLONCUR)
Local Integer WCHGTYP
Local Decimal WCOEFDEVISE
Local Integer WSTAT
Local Integer WRET, WLINE, WI
Local Integer CTX_PTX
#-----
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File TAXLINK    [TLK] : # Table Calcul base calcul taxe (link)
Local File AGRPCPY    [AGC] : # Table Groupes de sociétés

Local File BPARTNER   [BPR]
Local File BPSUPPLIER [BPS]
Local File ITMMASTER  [ITM]
Local File TABVACITM  [TVI]

WCOEFDEVISE=1

If this.APARENT=null Return Endif

#If this.ACTX.USER="MAE" Dbgaff : Endif

# -----
# Alimentation des propriétés de la classe de données paramètres FINDVAT : MYPARAM
# -----
# A voir comment tester d'autres cas : TRAIT=11,12,13,2,3 (+taxesLiées au code activité PTX)
#CTX_PTX = func AFNC.ACTIV("PTX")
If MYPARAM.TRAIT= 0
 # If CTX_PTX >0
 #   MYPARAM.TRAIT   = 3  : # Code traitement 1=Taxes classiques+taxes provinciales
 # Else
    MYPARAM.TRAIT   = 1  : # Code traitement 1=Taxes classiques (TVA+parafiscales+spéciales)
 # Endif
Endif
MYPARAM.BPCBPS    = 2  : # Type de tiers   2=Fournisseur
MYPARAM.TIERS     = this.BPSNUM
MYPARAM.ITMREF    = this.ITMREF

MYPARAM.GSOCIETE  = this.CPY

#Read [CPY] CPY0=this.CPY        : If fstat  Raz [F:CPY] : Endif
#MYPARAM.GLOCALDEV = [F:CPY]ACCCUR
MYPARAM.GLOCALDEV = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"ACCCUR")

#Read [FCY] FCY0=this.PSHFCY     : If fstat  Raz [F:FCY] : Endif
#MYPARAM.GFINRSP   = [F:FCY]FINRSPFCY
MYPARAM.GFINRSP   = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PSHFCY,"FINRSPFCY")

MYPARAM.GSYSCUR   = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")

Read [BPR] BPR0=MYPARAM.TIERS   : If fstat  Raz [F:BPR] : Endif
Read [BPS] BPS0=MYPARAM.TIERS   : If fstat  Raz [F:BPS] : Endif
Read [ITM] ITM0=MYPARAM.ITMREF  : If fstat  Raz [F:ITM] : Endif
Read [CPY] CPY0=MYPARAM.GSOCIETE  : If fstat  Raz [F:CPY] : Endif

# -----
# Alimentation des propriétés de la classe de données paramètre TAXLINK
# C'est une propriété de la classe de données paramètre FINDVAT faisant partie de la collection C_TLK
# -----
If MYPARAM.C_TLK(1) = null
  WRET = fmet MYPARAM.ADDLINE("C_TLK",1)
  If WRET = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class PREQUISD : Method call LOADVATPARAMFROMDOC result error for MYPARAM.ADDLINE 'C_TLK':", [V]CST_AERROR)
    Return
  Endif
Endif

SetInstance MYPARAM.C_TLK(1) With [F:CPY]
SetInstance MYPARAM.C_TLK(1) With [F:BPR]

MYPARAM.C_TLK(1).MODULE=6

SetInstance MYPARAM.C_TLK(1) With [F:BPS]

If dim([F:BPS]AGTPCP)>0
  MYPARAM.C_TLK(1).AGTPCPBPR=[F:BPS]AGTPCP
Else
  MYPARAM.C_TLK(1).AGTPCPBPR=2
Endif

# Alimentations à partir de l'article
If MYPARAM.ITMREF<>AVOID.ACHAR

  SetInstance MYPARAM.C_TLK(1) With [F:ITM]   : # Equivalent du transclasse

  # Alimentation de TSICOD depuis l'article car non présent dans PREQUISD
  For WLINE = 1 To dim([F:ITM]TSICOD)
     If MYPARAM.C_TLK(1).C_TSICOD(WLINE) = null
       WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_TSICOD",WLINE)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM.C_TLK(1) 'C_TSICOD':", [V]CST_AERROR)
         Break
       Endif
      Endif
      MYPARAM.C_TLK(1).C_TSICOD(WLINE).TSICOD =  [F:ITM]TSICOD(WLINE-1)
  Next WLINE

Endif


MYPARAM.C_TLK(1).FCY      = MYPARAM.GFINRSP
MYPARAM.C_TLK(1).AGTPCPCPY= [F:CPY]AGTPCP
#-----
MYPARAM.C_TLK(1).NBGRP=0

WI=1
For [AGC] AGC1 Where CPY=MYPARAM.GSOCIETE

  If MYPARAM.C_TLK(1).C_GRP(WI) = null
    WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_GRP",WI)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM.C_TLK(1) 'C_GRP':", [V]CST_AERROR)
      Return
    Endif
  Endif

  MYPARAM.C_TLK(1).C_GRP(WI).GRP =[F:AGC]GRP
  WI+=1
  If WI>99  Break : Endif
Next
MYPARAM.C_TLK(1).NBGRP=WI-1

# -----
# Alimentation à partir du contexte : içi alimentation à partir de la classe Détail Demandes d'achat
# -----
# Se situe dans ALITLK pour ce qui concerne les commandes
MYPARAM.C_TLK(1).PURFCY     = this.PSHFCY

MYPARAM.C_TLK(1).CUR        = this.CUR
MYPARAM.C_TLK(1).VACBPR     = this.VACBPR
MYPARAM.C_TLK(1).VACBPR_LEG = this.VACBPR_LEG

For WLINE = 1 To maxtab(this.C_VACITM)
  If this.C_VACITM(WLINE)<>null
    If MYPARAM.C_VAT(WLINE) = null
      WRET = fmet MYPARAM.ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM 'C_VAT':", [V]CST_AERROR)
        Return
      Endif
    Endif
    MYPARAM.C_VAT(WLINE).VACITM     = this.C_VACITM(WLINE).VACITM
    MYPARAM.C_VAT(WLINE).VACITM_LEG = this.C_VACITM(WLINE).VACITM_LEG
    MYPARAM.C_VAT(WLINE).VAT        = "" : #AVOID.ACHAR
    MYPARAM.C_VAT(WLINE).VAT_LEG    = "" : #AVOID.ACHAR
  Endif
Next WLINE

# Dans TAXLINK VACITM n'est pas dimensionné, on initialise avec le 1er niveau
If MYPARAM.C_VAT(1) <> null
  MYPARAM.C_TLK(1).VACITM     = MYPARAM.C_VAT(1).VACITM
  MYPARAM.C_TLK(1).VACITM_LEG = MYPARAM.C_VAT(1).VACITM_LEG
Endif

MYPARAM.C_TLK(1).QTY    = this.QTYPUU

If this.APARENT.ObjectType="C_PREQUIS"
  WDAT = this.APARENT.PRQDAT
Else
  WDAT = date$
Endif
WCUR = this.CUR : WCHGTYP = this.CHGTYP
Gosub CHARG_RATRPT
Return

$CHARG_RATRPT
If WCUR <> MYPARAM.GSYSCUR
    Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR,WCUR,MYPARAM.GLOCALDEV,WCHGTYP,WDAT,1000000.00,WCOEFDEVISE,WSTAT) From TRTDEV_SYRA
    If WSTAT=0 & WCOEFDEVISE<>0 WCOEFDEVISE=WCOEFDEVISE/1000000.00 Else WCOEFDEVISE=1 Endif
Endif
MYPARAM.C_TLK(1).RATRPT = WCOEFDEVISE
Return

############################################################################
#------------------------------------------------------------------------- #
# Récupération des codes taxes après la recherche                          #
#                                                                          #
# Method that loads results from FINDVAT (MYPARAM) to PREQUISD (this)      #
#                                                                          #
# ------------------------------------------------------------------------ #
$LOADVATRESULTFROMFINDVAT
Local Integer WLINE, WRET

If this.APARENT=null Return Endif

For WLINE=1 To maxtab(MYPARAM.C_VAT)

  If MYPARAM.C_VAT(WLINE)<>null
    If this.C_VACITM(WLINE)=null
      WRET = fmet this.ADDLINE("C_VACITM",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", "Data Class PREQUIS : Method call LOADVATRESULTFROMFINDVAT result error for this.ADDLINE 'C_VACITM':", [V]CST_AERROR)
        Return
      Endif
    Endif

    this.C_VACITM(WLINE).VAT     = MYPARAM.C_VAT(WLINE).VAT
    this.C_VACITM(WLINE).VAT_LEG = MYPARAM.C_VAT(WLINE).VAT_LEG
  Endif

Next WLINE

Return

#------------------------------------------------#
# _MET_INIBPSNUM : Intialisation du fournisseur  #
#------------------------------------------------#
$_MET_INIBPSNUM
Local Integer CTX_PSHINIBPS(1)
#
CTX_PSHINIBPS = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PSHINIBPS")
If  CTX_PSHINIBPS = 2
  Local File ITMBPS [ITP]
  For [ITP] ITP1 Where ITMREF=this.ITMREF & DOUFLG<>3
    If this.PSHFCY <> [F:ITP]BPSNUM
      # l'affectation va lancer automatiquement le CONTROL et le PROPAGATE de BPSNUM
      this.BPSNUM=[F:ITP]BPSNUM : Break
    Endif
  Next
  LogicClose File [ITP]
Endif
Return

#------------------------------------------------#
#_MET_LOADVAT : chargement des codes taxes       #
#------------------------------------------------#
$_MET_LOADVAT
#------------------- Récupération des taxes
Local Instance MYVATPARAM Using C_FINDVAT
MYVATPARAM = NewInstance C_FINDVAT AllocGroup null

MYVATPARAM.setAccessorEnabled = 0
#--Initializing taxes using the RECHVATCOD subroutine
MYVATPARAM.TRAIT = 1
WRET = fmet MYVATPARAM.FINDVAT(this)
If fmet MYVATPARAM.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
  [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"FINDVAT", [V]CST_AERROR)
  WRET = [L]ASTATUS
  FreeGroup MYVATPARAM
  Return
Endif

FreeGroup MYVATPARAM
Return

#------------------------------------------------#
#_MET_MAJPSH : mise à jour de l'entête de DA     #
#------------------------------------------------#
$_MET_MAJPSH
# Issue 92916 - 2013-10-07 by SR : ajout de WSUPLIG
Local Integer WSTAT, I, WSUPLIG, WAPPLIN, WBIDI1
Local Char WCUR(GLONCUR)
Local Decimal WMTT
#-------------------------------------------------------------------#
# calcul du total de la DA en devise comptable Gcur                 #
# si la ligne a une devise <> il faut convertir le mt               #
#                                                                   #
# mise à jour des indicateurs entete                                #
#-------------------------------------------------------------------#
WAPPLIN = 0
this.TOTPRQ = 0
this.ORDFLG = 1
this.CLEFLG = 1
this.PRNFLG = 1
WBIDI1 = 1
#récupération des valeurs des paramétres
WCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"ACCCUR")
WAPPPSH = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,this.ACTX.AFOLDER,"APPPSH")
WPSHAPPHEA = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,this.ACTX.AFOLDER,"PSHAPPHEA")
# Issue 92916 - 2013-10-07 by SR : initialisation de WSUPLIG
WSUPLIG = 1
#
#----- Màj nbre de lignes Soldées, commandées et en dépassement de budget -----#
#Raz [F:PSH]APPLINNBR, [F:PSH]CLELINNBR, [F:PSH]ORDLINNBR, [F:PSH]FBULINNBR
 For I = 1 To maxtab(this.PSD)
  If this.PSD(I).CUR<>WCUR & find(this.ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
    Call CONVERT(this.ACTX,this.PSD(I).CUR,WCUR,WCUR,this.PSD(I).CHGTYP,datesyst,this.PSD(I).LINAMT,
&                WMTT,WSTAT) From TRTDEV_SYRA
    If WSTAT <> 0
        Break
      Return
    Endif
  Else
    WMTT=this.PSD(I).LINAMT
  Endif
  this.TOTPRQ+=WMTT
  #----- Indicateurs solde - signée - commandée -----#
  If this.PSD(I).LINAPPFLG=3 | this.PSD(I).LINAPPFLG=4 | this.PSD(I).LINAPPFLG=5
    this.APPLINNBR+=1
    If this.PSD(I).LINAPPFLG=5
      WAPPLIN+=1
    Endif
  Elsif this.PSD(I).LINAPPFLG=2
    WBIDI1=2
  Endif
  If this.PSD(I).LINCLEFLG=2  this.CLELINNBR+=1 : Endif
  If this.PSD(I).LINORDFLG=2  this.ORDLINNBR+=1 : Endif
  If this.PSD(I).FBUFLG=2     this.FBULINNBR+=1 : Endif
  this.LINNBR+=1
Next I
#------
If this.ORDLINNBR >= this.LINNBR
  this.ORDFLG = 2
Endif
If this.CLELINNBR >= this.LINNBR
  this.CLEFLG = 2
Endif
If this.APPLINNBR >= this.LINNBR
  If WAPPPSH <= "1"
    this.APPFLG = 4
  Elsif WAPPLIN = this.LINNBR
    this.APPFLG = 5
  Else
    this.APPFLG = 3
  Endif
Elsif this.APPLINNBR <> 0
  If WAPPPSH <= "1"
    this.APPFLG = 4
  Elsif WAPPLIN = this.LINNBR
    this.APPFLG = 5
  Else
    this.APPFLG = 2
  Endif
Else
  this.APPFLG = WBIDI1
Endif
#-----

If WAPPPSH>"1"
  #----- Solde/désolde ligne (UPDFLG=2) et totalement signé, ne rien faire ! -----#
  # Issue 92916 - 2013-10-07 by SR : Tester si DA complétement signée à l'entête mais manque des lignes
  # Issue 93463 - 2014-01-27 by SR : Tester si DA complétement signée à l'entête et modif de zones entêtes impactantes
  If this.CLEFLG<>2 & (find(1,[M:PSH1]UPDFLG(0..[M:PSH1]NBLIG-1)) | (this.APPFLG<3 & WPSHAPPHEA="2")
&    | (this.APPFLG=3 & WPSHAPPHEA = "2"  & WSUPLIG = 2 ))
    this.APPFLG=0
  Endif
Else
  this.APPFLG=4
Endif
If this.CLEFLG=2 & this.APPFLG=0
  this.APPFLG=1
Endif
Return

#################################################################################################################################
#------------------------------------------------------------------------------
$LOADPARAMFROMDOC
#--MYPARAM => pointer to the class parameters
#Variable Instance MYPARAM Using C_PFINDPRICE
#Value    Integer  INDEXLINE

  Local Integer WRET
  Local Integer WLINE : Raz WLINE

  Local Char WBID(30), WMESSAGE(250)
  Local Char WBIDC1(GLONFCY), WBIDC2(GLONBPR), WBIDC3(GLONBPA)

  Local File BPSUPPLIER [BPS]
  Local File ITMMASTER  [ITM]

  Read [F:BPS]BPS0=this.BPSNUM
  If fstat : Raz [F:BPS] : Endif
#
  MYPARAM.setAccessorEnabled = 0
#
  If MYPARAM.C_LINE(INDEXLINE) = null
    WRET = fmet MYPARAM.ADDLINE("C_LINE",INDEXLINE)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif
#
  For WLINE=1 To 3
    If MYPARAM.C_LINE(INDEXLINE).C_VAT(WLINE) = null
      WRET = fmet MYPARAM.C_LINE(INDEXLINE).ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","PFINDPRICE.C_LINE(INDEXLINE)"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif
  Next WLINE
#
  If MYPARAM.C_LINE(INDEXLINE).C_PPKD(1) = null
    WRET = fmet MYPARAM.C_LINE(INDEXLINE).ADDLINE("C_PPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKD","PFINDPRICE.C_LINE(INDEXLINE)"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif
#
#
  MYPARAM.FMTCOLREM(1).PLISTC = [F:BPS]PLISTC
  MYPARAM.CHGTYP    = [F:BPS]CHGTYP

  MYPARAM.C_PPKH(1).EECICT     = [F:BPS]EECICT
  MYPARAM.C_PPKH(1).PTE        = [F:BPS]PTE #MAE : probléme potentiel, peut être utilisé INIPTE from TRTX3.
  MYPARAM.C_PPKH(1).PTE_LEG    = AVOID.ACHAR
  Call LEC_TPT_LEG(this.ACTX, this.LEG, MYPARAM.C_PPKH(1).PTE, 1, WRET) From TRTLECLEG_SYRA
  If WRET=0
     MYPARAM.C_PPKH(1).PTE_LEG  = [F:TPT]LEG
   Endif
  MYPARAM.C_PPKH(1).MDL      = [F:BPS]MDL
  MYPARAM.C_PPKH(1).PLIBPRCNR  = AVOID.AINT #=> même dans vintage il n'est pas initialsé
#Lines PSD
  MYPARAM.CUR      = this.CUR #--MAE! à ne pas déplacer en en-tête chargement cls param
  MYPARAM.BPSNUM   = this.BPSNUM #--MAE! à ne pas déplacer en en-tête chargement cls param
  MYPARAM.VACBPR   = this.VACBPR
  MYPARAM.VACBPR_LEG = this.VACBPR_LEG
  MYPARAM.FCY       = this.PRHFCY #site de réception
#    Call LEC_TVB_LEG(this.ACTX, this.LEG, MYPARAM.VACBPR, WRET) From TRTLECLEG_SYRA
#    If WRET=0
#      MYPARAM.VACBPR_LEG = [F:TVB]LEG
#    Endif
   WRET = func TRTPRICE_SYRA.ALICOLREM (MYPARAM.FMTCOLREM(1).BPCBPS, this.CUR, 2, this, MYPARAM.PLI(1), MYPARAM.FMTCOLREM(1), MYPARAM.FMTCOLREM(1).PLISTC, WMESSAGE) #From TRTPRICE_SYRA
    #--Test if errors
    If WRET=[V]CST_AOK : WRET = fmet MYPARAM.AGETMAXERROR("") : Endif
    If WRET >=[V]CST_AERROR
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALICOLREM"
      Endif
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif
#
  MYPARAM.GPLINBR = maxtab(MYPARAM.PLI)
  MYPARAM.C_PPKH(1).BPSNUM     = [F:BPS]BPSNUM
  MYPARAM.C_PPKH(1).BPSINV     = [F:BPS]BPSINV
  MYPARAM.C_PPKH(1).PJT        = this.PJT
  If filinfo(filpath("FIL","PIMPL","fde",nomap),0)>0
     MYPARAM.C_PPKH(1).PJTNUM     = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT)
  Endif

  MYPARAM.C_PPKH(1).VACBPR     = MYPARAM.VACBPR
  MYPARAM.C_PPKH(1).VACBPR_LEG = MYPARAM.VACBPR_LEG



#
#  #--3) Loading the "line" properties => those that normaly comes from a document line

  MYPARAM.NBLIG           = maxtab(MYPARAM.C_LINE)
  MYPARAM.C_LINE(INDEXLINE).ITMREF=this.ITMREF
  MYPARAM.C_LINE(INDEXLINE).QTY   =this.QTYPUU
  MYPARAM.C_LINE(INDEXLINE).FCY   =this.PRHFCY
  MYPARAM.C_LINE(INDEXLINE).PUU   =this.PUU
  MYPARAM.C_LINE(INDEXLINE).CUR    = this.CUR
  MYPARAM.C_LINE(INDEXLINE).PUUSTUCOE = 1  #AVOID.ADEC
  MYPARAM.C_LINE(INDEXLINE).GROPRI    = AVOID.ADEC
  MYPARAM.C_LINE(INDEXLINE).NETPRI    = AVOID.ADEC
  MYPARAM.C_LINE(INDEXLINE).CLCAMT1  = AVOID.ADEC
  MYPARAM.C_LINE(INDEXLINE).CLCAMT2  = AVOID.ADEC
  MYPARAM.C_LINE(INDEXLINE).CLCAMT3  = AVOID.ADEC
   For WLINE = 1 To maxtab(MYPARAM.C_LINE(INDEXLINE).C_DISCRG)
      If MYPARAM.C_LINE(INDEXLINE).C_DISCRG(WLINE)<>null
         MYPARAM.C_LINE(INDEXLINE).C_DISCRG(WLINE).DISCRGVAL  = AVOID.ADEC
         MYPARAM.C_LINE(INDEXLINE).C_DISCRG(WLINE).DISCRGREN  = AVOID.AINT
      Endif
    Next WLINE
#
    MYPARAM.C_LINE(INDEXLINE).PRIREN = AVOID.AINT
    MYPARAM.C_LINE(INDEXLINE).GRPFLG = AVOID.AINT
    MYPARAM.C_LINE(INDEXLINE).CUR = this.CUR
 #--2) Loading the "line" part of the working table pPRICLINK
    MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).FCY     = MYPARAM.C_PPKH(1).POHFCY #this.FCY
    MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).PRHFCY  = this.PRHFCY
#    MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).PJT     = this.PJT
#    If filinfo(filpath("FIL","PIMPL","fde",nomap),0)>0
#      MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).PJTNUM  = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT)
#    Endif
#
   Read [F:ITM]ITM0=this.ITMREF
   If fstat : Raz [F:ITM] : Endif

   For I = 1 To dim([F:ITM]TSICOD)

     If MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).C_TSICOD(I) = null
       WRET = fmet MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).ADDLINE("C_TSICOD",I)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSICOD","PFINDPRICE.C_LINE(INDEXLINE).C_PPKD(1)"), [V]CST_AERROR)
         Break
       Endif
     Endif
     MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).C_TSICOD(I).TSICOD = [F:ITM]TSICOD(I-1)
   Next I

  Read [F:BPS]BPS0=this.BPSNUM
   If fstat : Raz [F:BPS] : Endif

   For I = 1 To dim([F:BPS]TSSCOD)

     If MYPARAM.C_PPKH(1).C_TSCCOD(I) = null
       WRET = fmet MYPARAM.C_PPKH(1).ADDLINE("C_TSCCOD",I)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSCCOD","PFINDPRICE.C_PPKH(1)"), [V]CST_AERROR)
         Break
       Endif
     Endif
     MYPARAM.C_PPKH(1).C_TSCCOD(I).TSSCOD = [F:BPS]TSSCOD(I-1)
   Next I

#

## C_LINE collection from PFNDPRICED class

 MYPARAM.C_LINE(INDEXLINE).PUUSTUCOE = AVOID.AINT
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).FCY=this.PRHFCY
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).ITMREFORI  = AVOID.ACHAR
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).CLCAMT1    = MYPARAM.C_LINE(INDEXLINE).CLCAMT1 #0  #AVOID.ADEC
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).CLCAMT2    = MYPARAM.C_LINE(INDEXLINE).CLCAMT2 #0  #AVOID.ADEC
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).CLCAMT3    = MYPARAM.C_LINE(INDEXLINE).CLCAMT3 #0  #AVOID.ADEC
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).CSTTYP     = 1  #Prix standard par defaut
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).CUR        = MYPARAM.C_LINE(INDEXLINE).CUR #this.CURREF
 MYPARAM.C_LINE(INDEXLINE).C_PPKD(1).PJT        = AVOID.ACHAR


this.setAccessorEnabled = 1
[L]ARET_VALUE = [L]ASTATUS

Return
#------------------------------------------------------------------------------
$LOADDOCFROMRESULT
#--MYRESULT => pointer to the Result instance
#--MYPARAM  => pointer to the Parameters instance

Local Char WMESSAGE(250)
  If MYRESULT = null
    [L]ASTATUS = fmet this.ASETERROR ("", "MYRESULT :"-mess(18,9137,1), [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
  Endif
#

  Local File TABCUR      [TCU]
  Local File PFOOTINV    [PFI]
  Local File PRICSTRUCT  [PRS]
#
  Local Integer WDIMPRD
  WDIMPRS = min( dim([F:PRS]NPRNOTFLG), dim([F:PRS]INCDCR), dim([F:PRS]INVDTA), dim([F:PRS]CLCRUL))
#
  Read [TCU]TCU0=this.CUR
  If fstat : Raz [F:TCU] : Endif

#
  If MYRESULT.C_PRICE(1) <> null
    this.GROPRI = arr(MYRESULT.C_PRICE(1).MONTANT,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
    #--Pour l'appel à CALCNETPRI
    For WLINE=1 To maxtab(MYRESULT.C_DISCRG)

      If WLINE<= WDIMPRS-1 and MYRESULT.C_DISCRG(WLINE)<>null
        this.C_DISCRG(WLINE).DISCRGVAL = MYRESULT.C_DISCRG(WLINE).MONTANT
        this.C_DISCRG(WLINE).DISCRGREN = MYRESULT.C_DISCRG(WLINE).MOTIF

        #Assign "this.DISCRGVAL"+num$(WLINE) With MYRESULT.C_DISCRG(WLINE).MONTANT
        #Assign "this.DISCRGREN"+num$(WLINE) With MYRESULT.C_DISCRG(WLINE).MOTIF

      Endif

    Next WLINE

  Endif

Return

#------------------------------------------------#
# SEARCHPRICE : Recherche tarif                  #
#------------------------------------------------#
$SEARCHPRICE
#lancement de la recherche tarif et initialisation du PRINET
 #Appel à la recherche tarifs
 #--Nouvelle instance de la classe métier de recherche tarifs
 Local Instance MYPARAM Using C_PFINDPRICE

 MYPARAM = NewInstance C_PFINDPRICE AllocGroup null


 #--Chargement partie en-tête commune de MYPARAM
 Gosub CHARG_MYPARAM_FROM_PSH From PREQUIS_CMET

 [L]ASTATUS = fmet MYPARAM.FINDPRICE(this,1)
     If [L]ASTATUS>= [V]CST_AERROR
       [L]ASTATUS = fmet this.ASETERROR ("", "Erreur recherche tarif : Article "-this.PSD(I).ITMREF-"ligne "-num$(IJ), [V]CST_AERROR)
     Endif
#    #--Appel au sous-pro de calcul du prix net
    Local Decimal WAMTDISCRG(1..) #  2/18/2014
    Local Char WMESSAGE(250)
    WRET = func TRTACHPRI_SYRA.CALCNETPRI_DETAILS(this.QTYPUU,this.CUR,this,this,WAMTDISCRG,WMESSAGE)
    If WRET >=[V]CST_AERROR
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"CALCNETPRI_DETAILS"
      Endif
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif

    this.NETPRI      = arr(this.NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())

 FreeGroup MYPARAM

Return

#################################################################################################################################
#------------------------------------------------------------------------------
$LOADWIPPARAM
#--MYPARAM => pointer to the class parameters
#Variable Instance MYPARAM Using C_ORDK
Local File ITMFACILIT[ITF]
Local File ITMMASTER[ITM]
Local File ORDERS[ORD]
Local Integer STAT
Local Char TRTLIG(3)
#Récupération du statut de la ligne
If this.WIPNUM<>AVOID.ACHAR
  MYORDERS.WIPNUM=this.WIPNUM
Endif
STAT = this.ASTALIN
If STAT =[V]CST_AUPD
  TRTLIG="M"
Elsif STAT =[V]CST_ANEW
  TRTLIG="C"
Elsif (STAT =[V]CST_ADEL or STAT=[V]ANEWDEL)
  TRTLIG = "A"
Endif

If this.LINCLEFLG=2
  If [F:PSD]WIPNUM<>"" & STAT=[V]CST_AUPD
    MYORDERS.MAJCOD = TRTLIG
    MYORDERS.WIPTYP = 2
    MYORDERS.WIPNUM = [F:PSD]WIPNUM
    MYORDERS.ITMREF = [F:PSD]ITMREF
  Endif
  Return
Endif
#----- Mise à jour des encours uniquement si article géré en stock -----#
Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PRHFCY
If fstat
  Raz [F:ITF]
  Read [ITM] ITM0=[F:PSD]ITMREF
  If !fstat  [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif

If [F:ITF]STOMGTCOD>1
  If STAT=[V]CST_AUPD
    Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
    If fstat
    Raz [F:ORD] : Endif
    SetInstance MYORDERS With [F:ORD]
  Endif
  MYORDERS.MAJCOD    = TRTLIG
  MYORDERS.WIPTYP    = 2
  MYORDERS.WIPSTA    = 2
  If [F:PSD]WIPNUM <> AVOID.ACHAR
    MYORDERS.WIPNUM    = [F:PSD]WIPNUM
  Endif
  MYORDERS.ITMREF    = [F:PSD]ITMREF
  MYORDERS.STOFCY    = [F:PSD]PRHFCY
  MYORDERS.PJT       = [F:PSD]PJT
  MYORDERS.BPRNUM    = [F:PSD]BPSNUM
  MYORDERS.STRDAT    = [F:PSD]EXTORDDAT
  MYORDERS.ENDDAT    = [F:PSD]EXTRCPDAT
  MYORDERS.VCRTYP    = 14
  MYORDERS.VCRNUM    = [F:PSD]PSHNUM
  MYORDERS.VCRLIN    = [F:PSD]PSDLIN
  MYORDERS.VCRSEQ    = 0
  MYORDERS.EXTQTY    = [F:PSD]QTYSTU
  MYORDERS.CPLQTY    = [F:PSD]ORDQTYSTU
  MYORDERS.ALLQTY    = 0
  MYORDERS.SHTQTY    = 0
  MYORDERS.FMI       = 1
  MYORDERS.MRPMES    = 1
  #----- Chargement pièce origine si création autrement conservation valeurs -----#
  If MYORDERS.MAJCOD="C" | [F:ORD]WIPNUM=""
    MYORDERS.ORIFCY    = [F:PSD]PSHFCY
    MYORDERS.VCRTYPORI = 0
    MYORDERS.VCRNUMORI = ""
    MYORDERS.VCRLINORI = 0
    MYORDERS.VCRSEQORI = 0
  Endif
  #-----
  MYORDERS.BOMALT    = 0
  MYORDERS.ORI       = 1
  MYORDERS.ABBFIL    = "PSD"
Endif


Return

$WIP #US 71069/260 by RBA 07/29/2016
#Variable Instance TECORDERS Using C_TECORDERS : #
#Local Integer ARET_VALUE

  Local Instance ORDERS Using C_ORDERS

  # -------------------------------------
  ORDERS = NewInstance C_ORDERS AllocGroup null
  [L]ARET_VALUE = fmet ORDERS.ORDERS_FROM_PREQUISD(2, this.WIPNUM, this.ITMREF, this, TECORDERS)
  FreeGroup ORDERS
  # ---------------
Return

