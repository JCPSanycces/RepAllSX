Local Char VALEUR(250), PARAM(250)(1..20)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMPTXT","AIMPTXT",4,"XYAIMPTXT") From GTRAITE
End

#----------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "SORTIE"       : Gosub SORTIE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
Endcase
Return

#-----------------#
$INIT
Local Integer LIG , NBPAR , SAVCONSDIA , STA
Local Char    DOCCLI(GDIMFIC)
SAVCONSDIA = GCONSDIA
GCONSDIA = 0
LIG = nolign-1
Local Mask AOBJTXT3 [RPT]
Gosub SET_TYPX3 From GOBJTXT : # Types documents clob et blob gérés par le client (en dur)
Raz [M]
[M]TYP = [M:AOX]TYPDOC(LIG)
[M]NAM = [M:AOX]NAM(LIG)
If find([M:AOX]TYPDOC(LIG),BLOBX3,CLOBX3,CLOBXT)
 If [M:AOX]IDENT1="" : [M:AOX]IDENT1 = " " : Endif
 If [M:AOX]IDENT2="" : [M:AOX]IDENT2 = " " : Endif
 NBPAR = -1
 NBPAR += 1 : [M]TBPAR(NBPAR) = "objet"    : [M]TBVAL(NBPAR) = [M:AOX]CBLOB
 NBPAR += 1 : [M]TBPAR(NBPAR) = "ident1"   : [M]TBVAL(NBPAR) = [M:AOX]IDENT1
 NBPAR += 1 : [M]TBPAR(NBPAR) = "ident2"   : [M]TBVAL(NBPAR) = [M:AOX]IDENT2
 NBPAR += 1 : [M]TBPAR(NBPAR) = "ident3"   : [M]TBVAL(NBPAR) = format$("N0:3#",LIG+1)
 If find([M:AOX]TYPDOC(LIG),BLOBX3)
  [M]ETAT = "ABLOB"
 Elsif find([M:AOX]TYPDOC(LIG),CLOBX3,CLOBXT)
  [M]ETAT = "ACLOB"
 Endif
Else
 Local Char    REP1(30) , REP2(30) , DOC(250) , REP(250) , OS(10)
 DOC = [M:AOX]NAM(LIG)
 If left$(DOC,1)="%"
  Call PARAM("","DIRPCE",REP) From ADOVAL
  If REP=""
   Call PARAM("","DIRPCE1",REP1) From ADOVAL
   Call PARAM("","DIRPCE2",REP2) From ADOVAL
   REP = REP1+REP2
  Endif
  If left$(REP,1)="%"
   REP = filpath(right$(REP,2),"","",0)
  Endif
  If REP=""
   Call GET_OS("",OS) From ORDSYS
   If OS="unix"
    REP = "/"
   Else
    REP = "\"
   Endif
  Elsif !find(right$(REP,len(REP)),"/","\") & !find(mid$(DOC,2,1),"\","/")
   If instr(1,REP,"\")
    REP += "\"
   Else
    REP += "/"
   Endif
  Endif
  DOC = REP+right$(DOC,2)
 Endif
 #102428 If instr(1,DOC,"/") : # Il faut transférer le document sur le client pour pouvoir l'imprimer
 If len(DOC) & pat(DOC,"[*]/*")
  DOCCLI = DOC
  DOC = func ASYRSYS._GETFULLPATH(DOCCLI)
  Raz DOCCLI
 Endif
 # 106857 CCL
 #If instr(1,DOC,"/") | filinfo(DOC,0)>0 : # Il faut transférer le document sur le client pour pouvoir l'imprimer
 # DOCCLI = DOC
 # Call COPCLI(DOC,DOCCLI,STA) From ORDSYS
  #If !STA : DOC = DOCCLI : Endif
 #Endif
 NBPAR = -1
 NBPAR += 1 : [M]TBPAR(NBPAR) = "docjoin" : [M]TBVAL(NBPAR) = DOC
 [M]ETAT = "ADOC"
Endif
Return

#-----------------#
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Endif
Return

#-----------------#
$EXEC
Local Mask AOBJTXT3 [DIA]
[M:DIA] = [M:RPT]
Close Local Mask [RPT]
If dim([L]DOC)>0 and pat([M]NAM,"[*]/*") : # 117153
 # 106857 CCL
 If instr(1,DOC,"/") | filinfo(DOC,0)>0 : # Il faut transférer le document sur le client pour pouvoir l'imprimer
  DOCCLI = DOC
  Call COPCLI(DOC,DOCCLI,STA) From ORDSYS
  If !STA : DOC = DOCCLI : Endif
 Endif
 Return : # pas d'impression
Else
 If [M]IMPDIF=2
  Call ETATDIFF([M]ETAT,[M]PRT,GLANGUE,0,"",[M]TBPAR,[M]TBVAL,[M]DIFDAT,[M]DIFTIM) From AIMP3
 Else
  Call ETAT([M]ETAT,[M]PRT,GLANGUE,0,"",[M]TBPAR,[M]TBVAL) From AIMP3
 Endif
Endif
Return

#-----------------#
$SORTIE
GCONSDIA = SAVCONSDIA
Return

#-----------------#
$DEBUT
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
Call LECTURE("ARP",[M]ETAT,"") From CONTOBJ
Affzo
Call AIMDEF([M]PRT,[M]ETAT,[M]TBPAR,[M]TBVAL) From IMPRIME
GCONSDIA = 0
Return

#-----------------#
$SETBOUT
Raz CHMEN
Call VERF_DIFF(GUSER,K) From AIMP1
If K
 CHMEN += "4"
Endif
Return

#-----------------#
$AVANT_BOUTON
Case BOUT
 When "4"
  If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
  Call LECTURE("AIM",[M]PRT,"") From CONTOBJ
  If find([F:AIM]PRT,1)
   GERR = 1 : GMESSAGE = mess(12,135,1) : # Pas de prévisualisation en batch
  Endif
  If [F:AIM]PRTSRV=""
   GERR = 1 : GMESSAGE = mess(13,135,1) : # Serveur non défini
  Endif
Endcase
Return
