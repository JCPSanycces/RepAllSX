#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("FGP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When Default
Endcase
Return

$INICRE
$INIMOD
If dim([F:FGP]DES)>0
 [F:FGP]DES = [M:FGP1]DESTRA
Endif
Return


$LIENS
Call LECTEXTRA([M]DESTRA,"FUPGRP","DESTRA",[M]GRP,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"FUPGRP","SHOTRA",[M]GRP,"") From ATEXTRA
#angre additional parameter for ENABLE_DISABLE 130916
Call ENABLE_DISABLE([M:FGP1]FUPMAX,[M:FGP1]FUPFRY)
Return

$OUVRE
If clalev([F:BPC])  = 0 : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:BPC2]) = 0 : Local File BPCUSTOMER [BPC2] : Endif

Local Integer N
Local Char TMP(250)
Return

$CREATION
#angre test
#angre test
Gosub CHECK_FREQUENCY_TYPE
If GOK<1 : Return : Endif

Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
#angre test
Gosub CHECK_FREQUENCY_TYPE
If GOK<1 : Return : Endif

Gosub TEXTRA
If GOK<1 : Return : Endif
Return


$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("FUPGRP","DESTRA",CLECUR1,"","FUPGRP","DESTRA",[M]GRP,"")  From ATEXTRA
 Call DUPTEXTRA("FUPGRP","SHOTRA",CLECUR1,"","FUPGRP","SHOTRA",[M]GRP,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"FUPGRP","DESTRA",[M]GRP,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"FUPGRP","SHOTRA",[M]GRP,"") From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("FUPGRP","DESTRA",[M]GRP,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("FUPGRP","SHOTRA",[M]GRP,"",NCODE,"") From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("FUPGRP","DESTRA",[M]GRP,"") From ATEXTRA
Call SUPTEXTRA("FUPGRP","SHOTRA",[M]GRP,"") From ATEXTRA
Return


$CHECK_FREQUENCY_TYPE
  If [M:FGP1]FUPTYP = 5 and [M:FGP1]FUPFRY = 2
    Call ERREUR(mess(352,117,1)) From GESECRAN
    GOK = 0
  Endif
Return

Subprog ENABLE_DISABLE(VALEUR, FREQUENCY)
Value Decimal VALEUR
Value Tinyint FREQUENCY
Local Integer N

#angre 130916
    For N=0 To dim([M:FGP1]SEUILS)-1
      If FREQUENCY = 1
        Raz [M:FGP1]FUPINTERVAL(N)
        Affzo [M:FGP1]FUPINTERVAL(N)
        Grizo [M:FGP1]FUPINTERVAL(N)
        Raz [M:FGP1]FUPCRG(N)
        Affzo [M:FGP1]FUPCRG(N)
        Grizo [M:FGP1]FUPCRG(N)
      Else
        Raz [M:FGP1]SEUILS(N)
        Affzo [M:FGP1]SEUILS(N)
        Grizo [M:FGP1]SEUILS(N)
      Endif
    Next

# activer les seuils inférieurs à FUPMAX
For N=0 To VALEUR-1
 If FREQUENCY = 1
  Actzo [M:FGP1]SEUILS(N)
 Else
  Actzo [M:FGP1]FUPINTERVAL(N)
  Actzo [M:FGP1]FUPCRG(N)
 Endif
Next

# désactiver les seuils supérieurs à FUPMAX

For N=VALEUR To dim([M:FGP1]SEUILS)-1
 If FREQUENCY = 1
   Raz [M:FGP1]SEUILS(N)
   Effzo [M:FGP1]SEUILS(N)
   Grizo [M:FGP1]SEUILS(N)
   #angre 130916
   Grizo [M:FGP1]FUPINTERVAL(N)
   Grizo [M:FGP1]FUPCRG(N)
 Else
  Raz [M:FGP1]FUPINTERVAL(N)
  Effzo [M:FGP1]FUPINTERVAL(N)
  Grizo [M:FGP1]FUPINTERVAL(N)
  Raz [M:FGP1]FUPCRG(N)
  Effzo [M:FGP1]FUPCRG(N)
  Grizo [M:FGP1]FUPCRG(N)
  #angre 130916
  Grizo [M:FGP1]SEUILS(N)
 Endif
Next

# 2016-10-25 DNE INSERT BEGIN
    Call AM_FUPCUR( [M]FUPCUR )
# 2016-10-25 DNE INSERT END
End

#######################################################################################
Subprog AS_FUPTYP(VALEUR)
Variable Integer VALEUR
# masquer le 1er choix du menu ("Pas de relance")
GMENLOC(1) = 1
End

######################################################################################

Subprog C_FUPMAX(VALEUR)
Variable Decimal VALEUR

If VALEUR<0 : mkstat=2 : End : Endif

If VALEUR>5
 # Le niveau de relance doit être inférieur ou égal à 5
 GMESSAGE = mess(257,117,1)
 mkstat=2
 End
Endif
Call ENABLE_DISABLE(VALEUR,[M:FGP1]FUPFRY)
End

######################################################################################

# si type = globale par délai
# le nombre de seuils alimentés doit être égal à la valeur du niveau maxi de relance
# les autres seuils doivent être forcés à zéro
Subprog C_SEUILS(VALEUR)
Variable Decimal VALEUR
Local Integer N, ERR


# si le niveau maxi=1, aucun contrôle sur les seuils
If FUPMAX=1 : End : Endif

# pour tous les types sauf "globale par délai", si tous les seuils sont = zéro, ça roule
If [M:FGP1]FUPTYP<>5 and sum([M:FGP1]SEUILS(0..indice-1))+VALEUR=0 : End : Endif

# si type de relance = "globale par délai" le seuil correspondant au niveau maxi relance doit être obligatoirement différent zéro
If [M:FGP1]FUPTYP=5 and indice=[M:FGP1]FUPMAX-1 and VALEUR=0
 # Ce seuil est obligatoire
 GMESSAGE = mess(258,117,1)
 mkstat=2
 End
Endif

# si somme des seuils différente de zéro on vérifie que les seuils sont renseignés par ordre strictement croissant
If sum([M:FGP1]SEUILS(0..indice-1))+VALEUR<>0
 For N=1 To indice-1
  If [M:FGP1]SEUILS(N)<=[M:FGP1]SEUILS(N-1)
   # Les seuils doivent être par ordre strictement croissant
   Call ERREUR(mess(259,117,1)) From GESECRAN
   ERR = 1
   zonsui = "SEUILS("+num$(N)+")"
   Break
  Endif
 Next
 If ERR : End : Endif
 # cas particulier pour le champ sur lequel on est positionné
 If indice>0 and VALEUR<=[M:FGP1]SEUILS(indice-1)
  # Les seuils doivent être par ordre strictement croissant
  Call ERREUR(mess(259,117,1)) From GESECRAN
  ERR = 1
  zonsui = "SEUILS("+num$(indice)+")"
  End
 Endif
Endif
End

######################################################################################

Subprog AM_FUPMAX(VALEUR)
Variable Decimal VALEUR
# Si on a modifié le niveau maxi (donc le nombre de seuils)
# on force l'exécution des contrôles sur les champs Seuils
Setmok [M:FGP1] With 0
End

######################################################################################
## Section automatically added (screen FGP1) 09/13/2016 06:42:49 (ANGRE)
######################################################################################
Subprog AM_FUPFRY(VALEUR)
Variable Integer VALEUR
  Call ENABLE_DISABLE([M:FGP1]FUPMAX,VALEUR)
End


# 2016-10-25 DNE INSERT BEGIN
######################################################################################
## Section automatically added (screen FGP1) 10/25/2016 13:33:09 (DNE)
######################################################################################
Subprog AM_FUPCUR(VALEUR)
Variable Integer VALEUR

    If VALEUR = 2
        Actzo [M]FUPBALTRS
    Else
        [M]FUPBALTRS = 1
        Affzo [M]FUPBALTRS
        Grizo [M]FUPBALTRS
    Endif
End
# 2016-10-25 DNE INSERT END

