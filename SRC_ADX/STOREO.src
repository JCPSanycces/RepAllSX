#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()
#--- ouverture des tables
Gosub OUVRE 
#--- declaration des variables
Gosub DECLARE 

[L]CRITERE = "1=1"
[L]CRITER1 = "1=1"
[L]CRITER2 = "1=1"
#--- analyse des paramètres
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   #--- alimentation des paramètres utilisateur 
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "gwrhact"         : [L]PARAMETRE(I) = "gwrhact="+num$([L]VALEUR)
                             GWRHCOD = val([L]VALEUR)
   When "locreoflg"          : [L]PARAMETRE(I) = "locreoflg="+num$([L]VALEUR)
                            [L]LOCREO  = val([L]VALEUR)
   When "csmreoflg"          : [L]PARAMETRE(I) = "csmreoflg="+num$([L]VALEUR)
                            [L]CSMREO = val([L]VALEUR)
   When "shtreoflg"          : [L]PARAMETRE(I) = "shtreoflg="+num$([L]VALEUR)
                            [L]SHTREO = val([L]VALEUR)
   #--- préparation du filtre à appliquer sur les tables 
   When "stofcydeb"       : [L]CRITERE -= "& STOFCY>='"+[L]VALEUR+"'"
   When "stofcyfin"       : [L]CRITERE -= "& STOFCY<='"+[L]VALEUR+"'"
   When "lisnumdeb"       : [L]CRITERE -= "& SRGNUM>='"+[L]VALEUR+"'" 
                            [L]CRITER1 -= "& VCRNUM>='"+[L]VALEUR+"'" 
                            [L]CRITER2 -= "& SRGNUM>='"+[L]VALEUR+"'"
   When "lisnumfin"       : [L]CRITERE -= "& SRGNUM<='"+[L]VALEUR+"'"
                            [L]CRITER1 -= "& VCRNUM<='"+[L]VALEUR+"'" 
                            [L]CRITER2 -= "& SRGNUM<='"+[L]VALEUR+"'"
 Endcase
 Endif
Next

[M:SRO1]LOCREO    = LOCREO+1
[M:SRO1]CSMREO    = CSMREO+1
[M:SRO1]SHTREO    = SHTREO+1
Gosub ANA_ORIGINE From SUBSRO
Gosub PUR_WFICHIER
Raz GSEQREO
If GLOCREO <> 2 & GCSMREO <> 2 & GSHTREO <> 2
   End
Else
   Gosub TRT_WREO
Endif
End

###################################################################
$TRT_WREO
If GLOCREO = 2
   CRITER1 += "& [F:REO]STAFLG<>2 &[F:REO]VCRTYP=34"   
   Filter [REO]  Where evalue(CRITER1)
&                Order By Key REO1
   Gosub LECTURE_STOREO
Endif
If GCSMREO = 2
   CRITERE += "& [F:STA]ALLTYP=2 & find([F:STA]VCRTYP,2,10,36)>0 & ([F:STA]DEFLOCTYP<>'' | [F:STA]DEFLOC<>'')"   
   Filter [STA]  Where evalue(CRITERE)
&                Order By Key STA0
      Gosub LECTURE_STOALL_2
Endif
If GSHTREO = 2
   CRITER2 += "&[F:STA]ALLTYP=4&[F:STA]LOC<>''"
   Filter [STA]  Where evalue(CRITER2)
&         Order By Key STA0
   Gosub LECTURE_STOALL_4
Endif

Return

###################################################################
########################################################################
# LECTURE_STOREO                                          lecture STOREO
########################################################################
$LECTURE_STOREO

For [REO]
    If [F:ITM]ITMREF<>[F:REO]ITMREF
        Read [F:ITM]ITM0=[F:REO]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
    Raz [F:WREO]
    [F:WREO]                         = [F:REO]
    [F:WREO]ORIREO                   = 1
    [F:WREO]DEFTYPLOC                = ""
    [F:WREO]DEFLOC                   = ""
    If [F:REO]VCRNUM <> ""
       For [STA]STA0 Where STOFCY=[F:REO]STOFCY & ITMREF=[F:REO]ITMREF & VCRTYP = 34 &
&                         SRGNUM=[F:REO]VCRNUM & SRGLIN=[F:REO]VCRLIN &
&                         ALLTYP = 2
           Raz [F:WSTA]
           [F:WSTA]                         = [F:STA]
           Gosub CRE_WSTA
           If GOK = 0 
              Break 2
           Endif
       Next
    Endif
    Gosub CRE_WREO
    If GOK = 0 
       Break
    Endif
Next
Filter [F:REO]
Return


########################################################################
# LECTURE_STOALL_2                  lecture STOALL zones de consommation
########################################################################
$LECTURE_STOALL_2

For [STA]
    If [F:ITM]ITMREF<>[F:STA]ITMREF
        Read [F:ITM]ITM0=[F:STA]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
    Raz [F:WREO]
    [F:WREO]                         = [F:STA]
    [F:WREO]ORIREO                   = 2
    [F:WREO]VCRNUM                   = [F:STA]SRGNUM
    [F:WREO]VCRLIN                   = [F:STA]SRGLIN
    [F:WREO]LOC                      = [F:STA]DEFLOC
    [F:WREO]STU                      = [F:ITM]STU
    [F:WREO]QTYSTU                   = [F:STA]QTYSTUACT
    [F:WREO]QTYPCU                   = [F:STA]QTYSTUACT
    [F:WREO]QTYSTUORIA               = [F:STA]QTYSTUACT

    Gosub CRE_WREO
    If GOK = 0 
       Break
    Endif
    Raz [F:WSTA]
    [F:WSTA]                         = [F:STA]
    Gosub CRE_WSTA
    If GOK = 0 
       Break
    Endif
Next
Filter [F:STA]
Return

########################################################################
# LECTURE_STOALL_4                 lecture STOALL rupture emplacement
########################################################################
$LECTURE_STOALL_4

For [STA]
    If [F:ITM]ITMREF<>[F:STA]ITMREF
        Read [F:ITM]ITM0=[F:STA]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
    Raz [F:WREO]
    [F:WREO]                         = [F:STA]
    [F:WREO]ORIREO                   = 3
    [F:WREO]DEFTYPLOC                = ""
    [F:WREO]DEFLOC                   = ""
    [F:WREO]VCRNUM                   = [F:STA]SRGNUM
    [F:WREO]STU                      = [F:ITM]STU
    [F:WREO]PCU                      = [F:ITM]STU

    [F:WREO]QTYSTU                   = [F:STA]QTYSTUACT
    [F:WREO]QTYPCU                   = [F:STA]QTYSTUACT
    [F:WREO]QTYSTUORIA               = [F:STA]QTYSTUACT
    [F:WREO]VCRLIN                   = [F:STA]SRGLIN
    [F:WREO]PCUSTUCOE                = 1

    For [STA1]STA0 Where STOFCY=[F:STA]STOFCY & ITMREF=[F:STA]ITMREF & VCRTYP = 34 &
&                         SRGNUM=[F:STA]SRGNUM & SRGLIN=[F:STA]SRGLIN &
&                         ALLTYP = 2

        Raz [F:WSTA]
        [F:WSTA]                         = [F:STA1]
        Gosub CRE_WSTA
        If GOK = 0 
           Break 2
        Endif
    Next
    Gosub CRE_WREO
    If GOK = 0 
       Break
    Endif
Next
Filter [F:STA]
Return
##########################################################################
$CRE_WREO
# creation de l'enregistrement WREO
Trbegin [WREO]
GSEQREO +=1
[F:WREO]SEQ    = GSEQREO
[F:WREO]USR    = GUSER
[F:WREO]NUMREQ = [L]NUMREQ
Write [F:WREO]   
If fstat : GOK = 0 : Call FSTA("WREO") From GLOCK : Goto AB_CRE : Endif
Commit
Return 

$CRE_WSTA
# creation de l'enregistrement WSTA
Trbegin [WSTA]
[F:WSTA]USR    = GUSER
[F:WSTA]NUMREQ = [L]NUMREQ
Write [F:WSTA]   
If fstat : GOK = 0 : Call FSTA("WSTA") From GLOCK : Goto AB_CRE : Endif
Commit
Return 

$AB_CRE 
Rollback 
Return 

 

###########################################################
$PUR_WFICHIER
Trbegin [WREO]
Delete [WREO] Where USR = GUSER
Delete [WSTA] Where USR = GUSER 
fstat = 0
Delete [WREO] Where NUMREQ = [L]NUMREQ
Delete [WSTA] Where NUMREQ = [L]NUMREQ
fstat = 0
Commit
Return

###########################################################################  
$OUVRE 
Local File STOREO [REO], STOALL [STA], STOALL [STA1],ITMMASTER [ITM], WSTOREO [WREO], WSTOALL [WSTA]
Local Mask TCUN [WCU]
Return 
 
$DECLARE 
If clalev([M:SRO1])=0 Local Mask SRO1       [SRO1] Endif  # ecran parametrage pour calcul de l origine
Local Char    CRITERE(255),CRITER1(255),CRITER2(255),PARAM(30) , VALEUR(30) , ETAT(15)
Local Integer I, J, NUMREQ, LOCREO, CSMREO, SHTREO
Global Integer GWRHCOD
Global Integer GSEQREO
Raz [F:WREO]
Raz [F:WSTA]
Raz [M:SRO1]
Return 



