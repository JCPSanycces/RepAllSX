#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GTUNCPT
Call CONSCPT("","PEX","",1,"","","F1",[0/0/0],[0/0/0],"","")
End

####################################################################
##  Nouvelle consultation de compte gérée par GCONSULT            ##
####################################################################
Subprog CONSCPT(CECRAN,CSOC,CSITE,CLEDTYP,CCPT,CTIERS,CCOL,CDEB,CFIN,CDEV,COPT) 

Value Char    CECRAN
Value Char    CSOC
Value Char    CSITE
Value Integer CLEDTYP
Value Char    CCPT
Value Char    CTIERS
Value Char    CCOL
Value Date    CDEB
Value Date    CFIN
Value Char    CDEV
Value Char    COPT
Local Char    PARAM(10)(1..10)

PARAM(1) = CSOC
PARAM(2) = CSITE
PARAM(3) = num$(CLEDTYP)
PARAM(4) = CCPT
PARAM(5) = CTIERS
PARAM(6) = CCOL
PARAM(7) = CDEB
PARAM(8) = CFIN
PARAM(9) = CDEV
PARAM(10) = COPT
Call GCONSULT("CPT",CECRAN,PARAM) From GCONSULT
End
