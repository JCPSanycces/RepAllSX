#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## CRUD-CLASSE ## ESSWRKSA
# 2018-10-23 06:53:25 882


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File ESSWRKSA [EWSA_]

If !SILENCE : Call TRACE("2 --> Local Instance C_ESSWRKSA") From ASYRCOM : Endif
Local Instance ESSWRKSA Using C_ESSWRKSA

If !SILENCE : Call TRACE("3 --> New Instance C_ESSWRKSA") From ASYRCOM : Endif
ESSWRKSA = NewInstance C_ESSWRKSA AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EWSA_]EWSA0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of ESSWRKSA") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.AREAD([EWSA_]UID))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("ESSWRKSA.UID ="-num$(ESSWRKSA.UID)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(ESSWRKSA.AKEYS)
  Call TRACE("-"-num$(I)-":"-ESSWRKSA.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EWSA_]
FreeGroup ESSWRKSA
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(ESSWRKSA,ACLE,ASTATUS,_ETAG)
Variable Instance ESSWRKSA Using C_ESSWRKSA
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File ESSWRKSA [EWSA]
Default File [F:EWSA]
Read [F:EWSA]EWSA0 = [L]_UID
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EWSA]UPDTICK)>0
 [L]_ETAG = num$([F:EWSA]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(ESSWRKSA,ACLE,ASTATUS)
Variable Instance ESSWRKSA Using C_ESSWRKSA
Value Char ACLE
Variable Integer ASTATUS
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.AREAD([L]_UID))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(ESSWRKSA,_UID,ASTATUS)
Variable Instance ESSWRKSA Using C_ESSWRKSA
Value Integer _UID
Variable Integer ASTATUS

If ESSWRKSA = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKSA
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If ESSWRKSA.APARENT=null
 [L]A_I = ESSWRKSA.freeSnapshot
 ESSWRKSA.snapshotEnabled = 0
 ESSWRKSA.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & ESSWRKSA.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If ESSWRKSA.APARENT=null
 ESSWRKSA.snapshotEnabled = 1
 ESSWRKSA.setAccessorEnabled = 1
Endif
LogicClose File [EWSA]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA._ACTION_PARAM("AREAD_BEFORE",[L]_UID))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EWSA]
Read [F:EWSA]EWSA0 = [L]_UID
If fstat
[L]A_ERROR = num$([L]_UID)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(ESSWRKSA,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EWSA]AUUID)>0 & [F:EWSA]AUUID=NullUuid
 [F:EWSA]AUUID = getUuid
Endif
SetInstance ESSWRKSA With [F:EWSA]
ESSWRKSA.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



