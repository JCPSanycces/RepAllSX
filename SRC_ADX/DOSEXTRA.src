#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DOSEXTRA","DOSEXTRA",3,"XYDOSEXTRA") From GTRAITE
End

#------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

#------------------#
$INIT
Local Char    RETOUR(30) , MESSAGE(250)
Local Char    REPDOS(GDIMFIC) , REPHIS(GDIMFIC) , FICTRA(GDIMFIC)
Local Char    DOSSIER(GLONADS) , HISDOS(GLONADS) , MESSA(250)
TMP = 1
TRA = 1
Return

#------------------#
$INIT_DIA
If filinfo(filpath("","histo","",nomap),0)>0
 [M:DIA]DOSSIER = adxmother(0)
 [M:DIA]HISTO = 2
Else
 [M:DIA]DOSSIER = nomap(0)
 [M:DIA]HISTO = 1
Endif
[M:DIA]STOVOL = "SVG"
[M:DIA]CFG    = 2
[M:DIA]SIZ    = 1 : # Taille d'origine
Return

#------------------#
$EXEC
If [M:DIA]HISTO=2
 Local File =[M:DIA]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 HISDOS  = [F:ADW]VALEUR
 DOSSIER = [M:DIA]DOSSIER
Else
 HISDOS  = ""
 DOSSIER = [M:DIA]DOSSIER
Endif
If !func MAJVOL([M:DIA]DOSSIER,[M:DIA]STOVOL,[M:DIA]REPERT,MESSAGE)
 Call ERREUR(MESSAGE) From GESECRAN
 SAI = 1
 Return
Endif
REPHIS = [M:DIA]REPERT
REPDOS = [M:DIA]REPERT
Call EXTRA(DOSSIER,REPDOS,HISDOS,REPHIS,[M:DIA]FICHIER,num$([M:DIA]CFG),num$([M:DIA]SIZ),"0",0,FICTRA,RETOUR)
Return

#--------------------------------------------------#
Funprog MAJVOL(DOSSIER,VOLUME,REPERT,MESSAGE)
Value Char DOSSIER , VOLUME
Variable Char REPERT,MESSAGE
Local Integer ASTAT : ASTAT=1
Local File =DOSSIER+".AVOLUME" [AVL] , =DOSSIER+".ATEXTRA" [AXX]
Read [AVL]CODE=[L]VOLUME
If !fstat
# [L]REPERT = [F:AVL]VOLUME
 [L]REPERT = [F:AVL]ROOT  #X3-50400 - 8/6/2018
Else
 Trbegin [AVL]
 [F:AVL]VOLUME = [L]VOLUME
 [F:AVL]ROOT   = [L]VOLUME
 Write [AVL]
 If fstat
  [L]REPERT = ""
  MESSAGE = mess(355,139,1) : # Erreur en création du volume
  ASTAT = 0
  Rollback
 Else
  [L]REPERT = [L]VOLUME
  # Sauvegarde du dossier
  Call MAJTEXTRA(mess(116,100,1),"AVOLUME","DES",[M:DIA]STOVOL,"") From ATEXTRA
  Commit
 Endif
Endif
End ASTAT

#---------------------------------------------------------------------------------------------#
Subprog EXTRA(DOSSIER,REPDOS,HISDOS,REPHIS,FICHIER,FLGCFG,FLGSIZ,FLGSIL,TOUS,FICTRA,RETOUR)
Value    Char    DOSSIER , REPDOS , HISDOS , REPHIS , FICHIER
Value    Char    FLGCFG , FLGSIL , FLGSIZ
Value    Integer TOUS
Variable Char    FICTRA
Variable Char    RETOUR

Local Integer I , K , OK , NBFIC , STAT , INTERRUPT
Local Char    LISTEFIC(GLONATB+2)(1..5000)
Local Char    REPDAT(250)
Local Char    APPLI(GLONADS) , REPSVG(GDIMFIC)
Local Integer V130
Local Integer CFG , SIZ , SILENCE , NBERR , SEC
Local Char    REPBIS(GDIMFIC) , APPBIS(GLONADS)

CFG = val(FLGCFG)
SIZ = val(FLGSIZ)
SILENCE = val(FLGSIL)
NBERR = 0

If !GSERVEUR
 Call OUVRE_TRACE(mess(67,125,1)) From LECFIC : # Extraction données
Endif

Gosub SET_GTRACE : ## Pour l'indus

FICTRA = filpath("TRA",GTRACE,"tra")

If DOSSIER=""
 Call ECR_TRACE(mess(171,133,1),1) From GESECRAN : # Paramètre non renseigné
 NBERR += 1 : Goto FIN
Endif

For APPLI=DOSSIER,HISDOS

 OK = 1
 If HISDOS<>"" & !TOUS & APPLI<>HISDOS
  OK = 0
 Elsif APPLI<>""
  If APPLI=DOSSIER
   REPSVG = REPDOS
  Else
   REPSVG = REPHIS
  Endif
  If REPSVG=""
   Call ECR_TRACE(APPLI-":"-mess(9,141,1),1) From GESECRAN : # Répertoire inexistant
   NBERR += 1
   OK = 0
  Endif
 Else
  OK = 0
 Endif

 If OK

  Call ECR_TRACE(mess(67,125,1)-APPLI+"\"+string$(80,"-")+"\",0) From GESECRAN : # Extraction données

  K = instr(1,REPSVG,".")
  If K
   APPBIS = left$(REPSVG,K-1)
   REPBIS = right$(REPSVG,K+1)
   REPDAT = filpath(REPBIS,"","",APPBIS)
  Else
   REPDAT = filpath(REPSVG,"","",APPLI)
  Endif
  If filinfo(REPDAT,0)<0
   Call ECR_TRACE(mess(11,125,1)-"|"+REPDAT,0) From GESECRAN : # Création du répertoire
   Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+REPDAT+'"',"",STAT) From ORDSYS
  Endif

# Liste des fichiers à convertir

  If !instr(1,FICHIER,"*") & !instr(1,FICHIER,"?")
   If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)<0
    NBFIC = 0
   Else
    NBFIC = 1 : LISTEFIC(1) = FICHIER
   Endif
  Else
   Call SYSTEME2(adxmac(0),"lsadx -a"-APPLI-"FIL fde","",NBFIC,LISTEFIC) From ORDSYS
   I = 1
   While I<=NBFIC
    If !pat(LISTEFIC(I),FICHIER)
     Dela I,1 LISTEFIC(I)
     NBFIC -= 1
    Else
     I += 1
    Endif
   Wend
  Endif
  If NBFIC=0
   Call ECR_TRACE(APPLI-":"-mess(68,125,1),-1) From GESECRAN : # Pas de données à extraire
   OK = 0
  Endif
 Endif

 If OK

  If !GSERVEUR & !SILENCE
   Call OUVRE_BOITE(mess(67,125,1)-APPLI,NBFIC) From GESECRAN : # Extraction données
   Call SET_BOITE(mess(67,125,1),NBFIC) From GESECRAN
  Endif

  INTERRUPT = 0
  For I=1 To NBFIC
   If !GSERVEUR & !SILENCE
    Call AFF_BOITE(mess(56,123,1)-LISTEFIC(I),I,INTERRUPT) From GESECRAN : # Table
   Endif
   If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE" [ATB] : Endif
   Raz V130 , SEC
   Read [ATB]CODFIC = LISTEFIC(I)
   If !fstat
    If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
     V130 = 1
    Endif
    If dim([F:ATB]SECURE)>0 & [F:ATB]SECURE=2
     SEC = 1
    Endif
   Endif
   Close Local File [ATB]
   Call SAUVE(LISTEFIC(I),APPLI,REPSVG,max(SEC*2,CFG),SIZ,V130,NBERR)
  Next I

  If !GSERVEUR & !SILENCE
   Call FERME_BOITE From GESECRAN
  Endif

 Endif

Next APPLI

$FIN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

RETOUR = num$(NBERR)

End

#---------------------------------#
$SET_GTRACE
If GTRACE=""
 GTRACE = "Extrac_"+nomap
 Openo filpath("TRA",GTRACE,"tra",0) , 0
 Openo
Endif
Return

#------------------------------------------------------------------------#
Subprog SAUVE(FICHIER,APPLI,REPSVG,CFG,SIZ,V130,NBERR)
Value    Char    FICHIER
Value    Char    APPLI
Value    Char    REPSVG
Value    Integer CFG
Value    Integer SIZ
Value    Integer V130
Variable Integer NBERR

Local Integer I , K , STAT , ERR , VUE , OK
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    ORDSYS(250)(1..2) , FICSRC(250) , FICNEW(250)
Local Char    EXTFIC(3) , LIGNE(250) , CHAINE(250) , VERSION(20)
Local Char    FINITIAL(20)
Local Char    NINITIAL(20) , NBASE(5)
Local Char    OINITIAL(20) , ONEXT(20) , OPCTINC(20) , OBASE(5)
Local Decimal TAILLE
Local Char    FICTRA(GDIMFIC)
Local Char    NAMZ(30) , TYPZ(5) , LNGZ(10) , DIMZ(10) , TITZ(80) , NBZ(10)
Local Integer BLOB , TYPDAT
Local Char    REPBIS(GDIMFIC) , APPBIS(GLONADS)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

K = instr(1,REPSVG,".")
If K
 APPBIS = left$(REPSVG,K-1)
 REPBIS = right$(REPSVG,K+1)
Else
 APPBIS = APPLI
 REPBIS = REPSVG
Endif

ERR = 0

## Trace des valfil systèmes

FICTRA  = filpath("tmp",FICHIER,"tra",APPLI)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

## Pour l'indus

Gosub SET_GTRACE

## Existence du répertoire

FICSRC = filpath(REPBIS,"","",APPBIS)
If filinfo(FICSRC,0)<0
 Call ECR_TRACE(mess(11,125,1)-"|"+FICSRC,0) From GESECRAN : # Création du répertoire
 Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+FICSRC+'"',"",STAT) From ORDSYS
Endif

## Suppression de l'ancien SVG

If filinfo(filpath(REPBIS,FICHIER,"dat",APPBIS),0)>0 & filinfo(filpath(REPBIS,FICHIER,"fde",APPBIS),0)>0 & 1=0
# Il semblerait que la console importe des fichier srf au format base ...
# Donc pour corriger les éventuelles erreurs de la console, ces lignes sont maintenant supprimées à partir de la V6
 Call ECR_TRACE(mess(53,123,1)-APPBIS+"."+REPBIS+"/"+FICHIER,0) From GESECRAN : # Suppression
 ORDSYS(1) = 'valfil -s -d'-APPBIS-APPBIS+"."+REPBIS+"/"+FICHIER
 ORDSYS(2) = FICTRA
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Call TRACE(FICTRA,mess(28,125,1)-FICHIER,NBERR) From DOSINTEG : # Erreur d'effacement
Endif
If filinfo(filpath(REPBIS,FICHIER,"dat",APPBIS),0)>0 or filinfo(filpath(REPBIS,FICHIER,"fde",APPBIS),0)>0
 For EXTFIC = "dat" , "seq" , "fde" , "srf"
  FICSRC = filpath(REPBIS,FICHIER,EXTFIC,APPBIS)
  If filinfo(FICSRC,0)>0
   Call EFFACE(FICSRC,STAT) From ORDSYS
   If filinfo(FICSRC,0)>0
    Call ECR_TRACE("|"+FICSRC-":"-mess(54,123,1),1) From GESECRAN : # Suppression impossible
   Endif
  Endif
 Next EXTFIC
Endif

## Vue ?

Call VUE_OK(FICHIER,APPLI,"FIL",OK) From DOSVUE
If OK
 Call ECR_TRACE(mess(91,123,1)-APPBIS+"."+REPBIS+"/"+FICHIER-"("+mess(77,139,1)+")",0) From GESECRAN
 # Copie srf de la vue en format neutre pour la console
 FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
 If filinfo(FICSRC,0)>0
  Call EFFACE(FICSRC,STAT) From ORDSYS
 Endif
 FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
 If filinfo(FICSRC,0)>0
  FICNEW = filpath(REPBIS,FICHIER,"new",APPBIS)
  Openi FICSRC
  Openo FICNEW , 0
  Rdseq LIGNE   : Wrseq LIGNE  : # En-tête
  Rdseq LIGNE   : Wrseq LIGNE  : # Abréviation
  Rdseq LIGNE   : Wrseq LIGNE  : # ?
  Rdseq LIGNE : # Infos base
  Call PARBAS(LIGNE,OBASE,OINITIAL,ONEXT,OPCTINC) From DOSTAB
  adxifs = chr$(9)
  Wrseq "1",OINITIAL,ONEXT,OPCTINC : # Pour la console
  adxifs = ""
  Rdseq NBZ
  Wrseq NBZ
  adxifs = chr$(9)
  For I=1 To val(NBZ)
   Rdseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
   Wrseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
  Next I
  adxifs = ""
  Rdseq LIGNE
  NBZ = LIGNE
  Wrseq LIGNE
  For I=1 To val(NBZ)
   Rdseq LIGNE
   Wrseq LIGNE
  Next I
  Openi
  Openo
  FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
 Endif
 # Copie (vue)
 For EXTFIC="fde","viw"
  FICSRC = filpath(REPBIS,FICHIER,EXTFIC,APPBIS)
  If filinfo(FICSRC,0)>0
   Call EFFACE(FICSRC,STAT) From ORDSYS
  Endif
  FICSRC = filpath("FIL",FICHIER,EXTFIC,APPLI)
  If filinfo(FICSRC,0)>0
   Call COPIE(FICSRC,filpath(REPBIS,FICHIER,EXTFIC,APPBIS),STAT) From ORDSYS
  Endif
 Next EXTFIC
 If CFG=2
  FICSRC = filpath("FIL",FICHIER,"cfg",APPLI)
  If filinfo(FICSRC,0)>=0
   Call COPIE(FICSRC,filpath(REPBIS,FICHIER,"cfg",APPBIS),STAT) From ORDSYS
  Endif
 Else
  FICSRC = filpath(REPBIS,FICHIER,"cfg",APPBIS)
  If filinfo(FICSRC,0)>=0
   Call EFFACE(FICSRC,STAT) From ORDSYS
  Endif
 Endif
 End
Endif

## Verrou de la table

Onerrgo ERR_TRA
Local File =APPLI+"."+FICHIER [F1]
Lock [F1]
Onerrgo
If ERR
 Call ECR_TRACE(FICHIER-"|"+errmes$(ERR),1) From GESECRAN
 NBERR += 1 : End
Elsif fstat
 Call ECR_TRACE(FICHIER-mess(123,133,1),1) From GESECRAN : # Table en cours d'utilisation
Endif

## Déverrou

Unlock [F1]
Close Local File [F1]

## La table contient-elle un blob/clob

BLOB = 0
FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [I]
 For I=1 To 4
  Rdseq LIGNE Using [I]
 Next I
 Rdseq NBZ Using [I]
 adxifs = chr$(9)
 For I=1 To val(NBZ)
  Rdseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ Using [I]
  If find(TYPZ,"81","82") : # Clob, Blob
   BLOB = 1 : Break
  Endif
 Next I
 adxifs = ""
 Openi Using [I]
Endif
VERSION = func AFNC.PARTSEP(ver$(0),2," ")
OK = (left$(VERSION,3)<>"6.4")
OK *= (VERSION>="14r.316")
If BLOB & OK
 TYPDAT = 2 : # Fichier plat avec compression des champs blob/clob
Else
 TYPDAT = 1
Endif

## Transfert de FIL => SVG

Call ECR_TRACE(mess(59,123,1)-APPBIS+"."+REPBIS+"/"+FICHIER,0) From GESECRAN

## Création

ORDSYS(1)   = "valfil -s"
If V130
 ORDSYS(1) -= "-a"
Endif
ORDSYS(1)  -= "-c -t"+num$(TYPDAT)-APPLI-APPLI+"."+FICHIER-APPBIS+"."+REPBIS+"/"+FICHIER
ORDSYS(2)   = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Call TRACE(FICTRA,mess(51,123,1)-FICHIER,NBERR) From DOSINTEG : # Erreur en validation de la table

## Copie du fichier cfg

If CFG=2
 FICSRC = filpath("FIL",FICHIER,"cfg",APPLI)
 If filinfo(FICSRC,0)>=0
  Call COPIE(FICSRC,filpath(REPBIS,FICHIER,"cfg",APPBIS),STAT) From ORDSYS
 Endif
Else
 FICSRC = filpath(REPBIS,FICHIER,"cfg",APPBIS)
 If filinfo(FICSRC,0)>=0
  Call EFFACE(FICSRC,STAT) From ORDSYS
 Endif
Endif

## Taille du fichier dat

TAILLE = max(1,filinfo(filpath(REPBIS,FICHIER,"dat",APPBIS),7)) : # Si le .dat n'existe plus
If TAILLE>10*1024*1024
 FINITIAL = num$(-int(-TAILLE/(1024*1024)))+"M" : # Astuce pour arrondir à l'entier supérieur
Else
 FINITIAL = num$(-int(-TAILLE/(1024)))+"K"
Endif

## Mise à jour du fichier srf

FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
If filinfo(FICSRC,0)>=0
 FICNEW = filpath(REPBIS,FICHIER,"new",APPBIS)
 Openi FICSRC
 Openo FICNEW , 0
 Rdseq LIGNE : Wrseq LIGNE  : # En-tête
 Rdseq LIGNE : Wrseq LIGNE  : # Abréviation
 Rdseq LIGNE : Wrseq LIGNE  : # ???
 Rdseq LIGNE : # Infos base
 Call PARBAS(LIGNE,OBASE,OINITIAL,ONEXT,OPCTINC) From DOSTAB
 NBASE = num$(TYPDAT)
 If SIZ=2 & !BLOB
  NINITIAL = FINITIAL
 Else
  NINITIAL = OINITIAL
 Endif
 adxifs = chr$(9)
 Wrseq NBASE,NINITIAL,"",""
 adxifs = ""
 Rdseq LIGNE
 While fstat=0
  Wrseq LIGNE : Rdseq LIGNE
 Wend
 Openi
 Openo
 FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
 Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
Endif

## Création d'un fichier .seq pour le uniqid

Local File =APPLI+"."+FICHIER [SVG]
Onerrgo ERR_TRA
Openo filpath(REPBIS,FICHIER,"seq",APPBIS) , 0
Wrseq num$(uniqid([SVG]))
Onerrgo
If ERR
 Call ECR_TRACE(FICHIER-errmes$(ERR),1) From GESECRAN
 NBERR += 1 :  End
Endif
Openo
Close Local File [SVG]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

# Génération du .fde dans le cas d'une table contenant un contenant un clob et suivant la version du moteur

If TYPDAT=2
 ORDSYS(1) = 'valfil -s -n'-APPBIS-APPBIS+"."+REPBIS+"/"+FICHIER
 ORDSYS(2) = FICTRA
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Call TRACE(FICTRA,mess(7,21,1)-FICHIER+".fde",NBERR) From DOSINTEG : # Erreur
 End
Endif

## Bug 12853 On vérifie au moins que les fichiers dat, seq, fde, srf ont bien été créés

For EXTFIC = "dat" , "seq" , "fde" , "srf"
 FICSRC = filpath(REPBIS,FICHIER,EXTFIC,APPBIS)
 If filinfo(FICSRC,0)<0
  Call ECR_TRACE(mess(101,100,1)-APPBIS+"."+REPBIS+"/"+FICHIER+"."+EXTFIC,1) From GESECRAN
  # Fichier inexistant
 Endif
Next EXTFIC

End

#------------------#
$ERR_TRA
ERR = errn
Call ECR_TRACE("|"+FICHIER+"|\|"+errp+"("+num$(errl)+")|\|"-num$(ERR)+":"+errmes$(ERR)+"|\|"+errm,1) From GESECRAN
Resume

#------------------------------------------------------------------------#
Subprog C_FICHIER(FICHIER)
Variable Char FICHIER()
If FICHIER="" : FICHIER = "*" : Endif
If !instr(1,FICHIER,"*") & !instr(1,FICHIER,"?")
 If filinfo(filpath("FIL",FICHIER,"fde",[M:DIA]DOSSIER),0)<0
  Call ERREUR(mess(101,100,1)) From GESECRAN : # Fichier inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
Local Integer STAT , I , K
Local Char    REPERT(250)
Local Char    APPBIS(GLONADS) , REPBIS(GDIMFIC) , DOSSVG(GLONADS)
If [M]HISTO=2
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 DOSSVG  = [F:ADW]VALEUR
 Close Local File [ADW]
Else
 DOSSVG = [M]DOSSIER
Endif
K = instr(1,VALEUR,".")
If K
 APPBIS = left$(VALEUR,K-1)
 REPBIS = right$(VALEUR,K+1)
Else
 APPBIS = DOSSVG
 REPBIS = VALEUR
Endif
If find(REPBIS,"TRT","FIL","ETM","TRA","tmp","BQR","BQE","BQT","LIA","TXT","REPORT","GRAPH"
&             ,"GEN","PIC","LNK","ECR","PCD","DEC")
& or pat(REPBIS,"M???")
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Elsif instr(1,VALEUR,":") or left$(VALEUR,1)="\" or left$(VALEUR,1)="/"
 GMESSAGE = mess(115,139,1) : # Le répertoire de sauvegarde ne peut pas être en absolu
 mkstat = 2 : End
Elsif VALEUR<>vireblc(VALEUR,4)
 GMESSAGE = mess(71,133,1) : # Caractère <ESPACE> interdit
 mkstat = 2 : End
Endif
REPERT = filpath(REPBIS,"","",APPBIS)
Call EXISTE(REPERT,STAT) From ORDSYS
If STAT=1
 GMESSAGE = "|"+REPERT+"|\"+mess(132,133,1) : # Ce fichier existe déjà
 mkstat = 2 : End
Elsif STAT=0
 If APPBIS<>DOSSVG
  REPERT = filpath("","","",APPBIS)
  Call EXISTE(REPERT,STAT) From ORDSYS
  If STAT<>2
   GMESSAGE = REPERT-":"-mess(86,133,1) : # Répertoire inexistant
   mkstat = 2 : End
  Endif
 Else
  K = 0
  For I=len(VALEUR) To 1 Step -1
   If mid$(VALEUR,I,1)="\" or mid$(VALEUR,I,1)="/"
    K = I : Break
   Endif
  Next I
  If K
   REPERT = filpath(left$(VALEUR,K-1),"","",0)
   Call EXISTE(REPERT,STAT) From ORDSYS
   If STAT<>2
    GMESSAGE = REPERT-":"-mess(86,133,1) : # Répertoire inexistant
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
End

Subprog C_HISTO(VALEUR)
Variable Integer VALEUR
Local Integer OK
If VALEUR<>2 : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",[M]DOSSIER),0)>0
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADW]VALEUR<>"" & filinfo(filpath("FIL","","",[F:ADW]VALEUR),0)>0
  OK = 1
 Endif
Endif
If !OK
 Call ERREUR(mess(208,133,1)) From GESECRAN : # Dossier historisé inexistant
 mkstat = 1 : End
Endif
End

Subprog AP_DOSSIER(VALEUR)
Variable Char VALEUR
Local Integer OK
If VALEUR="" : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",[L]VALEUR),0)>0
 Local File =[L]VALEUR+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADW]VALEUR<>"" & filinfo(filpath("FIL","","",[L]VALEUR),0)>0
  OK = 1
 Endif
 Close Local File [ADW]
Endif
If !OK
 [M]HISTO = 1
 Affzo HISTO
Endif
End

Subprog AV_HISTO(VALEUR)
Variable Integer HISTO
Local Integer OK
If [M]DOSSIER="" : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",[M]DOSSIER),0)>0
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADW]VALEUR<>"" & filinfo(filpath("FIL","","",[M]DOSSIER),0)>0
  OK = 1
 Endif
 Close Local File [ADW]
Endif
If !OK
 Grizo HISTO
Else
 Actzo HISTO
Endif
End

Subprog C_STOVOL(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSSIER+".AVOLUME" [AVL]
Read [AVL]CODE=VALEUR
If fstat
 [M]REPERT = VALEUR
Else
 [M]REPERT = [F:AVL]ROOT
Endif
Call C_REPERT([M]REPERT)
End

