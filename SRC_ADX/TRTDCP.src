######################################################################################
Subprog C_SSTTAXACT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Actzo [M:DCP]SSTCPY,SFINUM
Else
  Raz [M:DCP]SSTCPY,SFINUM
  Grizo [M:DCP]SSTCPY,SFINUM
Endif
End

######################################################################################
Subprog C_SSTCPY(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
End

######################################################################################
Subprog AS_SFINUM(VALEUR)
Variable Decimal VALEUR
[M]FILTRE_SFI="VATRUL=4 & CLCBAS=1 & CLCVACITM='"+""+"' & SSTCOD<>'"+""+"'"  # filtre for action SELSFI
End

Subprog C_SFINUM(VALEUR)
Variable Decimal VALEUR
mkstat = 0

If VALEUR <> 0 & [M:DCP]SFINUM(nolign-1) <> VALEUR
  Read [F:SFI]SFI0 = VALEUR
  If !fstat
    Call CHECK_VALID_SFI ([F:SFI]VATRUL,[F:SFI]CLCBAS,[F:SFI]CLCVACITM,[F:SFI]SSTCOD) From TRTDCP
  Else
    GMESSAGE = mess(23,100,1)
    GERR = 1
    mkstat = 2
  Endif
Endif

End

######################################################################################
# Called from SUBSFI; VERIF_MOD also
Subprog CHECK_VALID_SFI (RUL, CLCBAS, CLCVAC, SST)
Value Integer RUL, CLCBAS
Value Char CLCVAC, SST
GERR = 0

# Tax rule must be Fixed rate
If RUL<>4
  GMESSAGE = func AFNC.MES1(mess(424,192,1), mess(4,283,1))
  GERR = 1
  mkstat = 2
# Calculation base must be Before tax
Elsif CLCBAS<>1
  GMESSAGE = func AFNC.MES1(mess(424,192,1), mess(1,2219,1))
  GERR = 1
  mkstat = 2
# Tax level selection must be blank
Elsif CLCVAC<>""
  GMESSAGE = mess(425,192,1)
  GERR = 1
  mkstat = 2
# SST tax code must NOT be blank
Elsif SST=""
  GMESSAGE = mess(254,191,1)+" "+mess(37,119,1)
  GERR = 1
  mkstat = 2
Endif

End
# 106867.en
