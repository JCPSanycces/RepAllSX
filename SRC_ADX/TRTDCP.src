########################################
Subprog IB_DADCPYNAM
GBOUT2 = mess(7,122,1) : # Initialisation
End

########################################
Subprog B2_DADCPYNAM(VALEUR)
Variable Char    VALEUR()
Raz DADCPYNAM,DADCRN,DADNAF,DADPOSCOD,POSCTY,CTYNAM,POSCTYCOD,ADDCPL,STREETNUM,ABC,
&    STREET
Read [F:CPY]CPY0=[M]CPY
If !fstat
 VALEUR        = [F:CPY]CPYNAM
 [M:DCP]DADCRN = [F:CPY]CRN
 [M:DCP]DADNAF = [F:CPY]NAF
 Affzo DADCRN,DADNAF
 Read [F:BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
 If !fstat
  [M:DCP]DADPOSCOD = [F:BPA]POSCOD
  [M:DCP]POSCTY    = [F:BPA]CTY
  [M:DCP]CTYNAM    = [F:BPA]CTY
  Read [POS]POS1=GPAYS;[M:DCP]POSCTY;[M:DCP]DADPOSCOD
  If !fstat
   [M:DCP]POSCTYCOD = [F:POS]POSCTYCOD
  Endif
  Call SET_ADR([M:DCP]ADDCPL,[M:DCP]STREETNUM,[M:DCP]ABC,[M:DCP]STREET) From SUBPRV
  Affzo ADDCPL,STREETNUM,ABC,STREET,DADPOSCOD,POSCTY,CTYNAM,POSCTYCOD
  GMEDIASAI = 1
  #Fonctions inexistantes ds SUBPOS
  #Call CONTCP([M]DADPOSCOD,GPAYS,[M]POSCTY) From SUBPOS
  #Call CONTVILLE([M]POSCTY,GPAYS,[M]DADPOSCOD) From SUBPOS
  GMEDIASAI = 0
 Endif
Else
 VALEUR = [M]CPYNAM
 Call SET_ADR2 From TRTDFC
Endif
End

########################################
Subprog C_DADFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz DADCRN2, ADDCPL2, STREETNUM2,ABC2,STREET2,DADPOSCOD2,POSCTY2,CTYNAM2
 Read [FCY]FCY0=VALEUR
 If !fstat
  [M:DCP]DADCRN2 = [F:FCY]CRN
  Read [F:BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
  If !fstat
   [M:DCP]DADPOSCOD2 = [F:BPA]POSCOD
   [M:DCP]POSCTY2    = [F:BPA]CTY
   [M:DCP]CTYNAM2    = [F:BPA]CTY
   Call SET_ADR([M:DCP]ADDCPL2,[M:DCP]STREETNUM2,[M:DCP]ABC2,[M:DCP]STREET2) From SUBPRV
   Affzo ADDCPL2,STREETNUM2,ABC2,STREET2,DADPOSCOD2,POSCTY2,CTYNAM2
   GMEDIASAI = 1
   #Fonctions inexistantes ds SUBPOS
   #Call CONTCP([M:DCP]DADPOSCOD2,GPAYS,[M:DCP]POSCTY2) From SUBPOS
   #Call CONTVILLE([M:DCP]POSCTY2,GPAYS,[M:DCP]DADPOSCOD2) From SUBPOS
   GMEDIASAI = 0
  Endif
 Endif
Endif
End

