Subprog AS_DADPOSCOD(VALEUR)
Variable Char    VALEUR()

  Gosub AFFECTE_ZONCOUP
End

Subprog AS_DADPOSCOD2(VALEUR)
Variable Char    VALEUR()

  Gosub AFFECTE_ZONCOUP
End

# MHB 05/11/08 : pour pouvoir récupérer la ville associée au CP lors de la sélection
# par tunnel, via SUBPOS (TUNPOS)
$AFFECTE_ZONCOUP

  If dim(GZONCOUP)<0 Then Global Char GZONCOUP Endif
  GZONCOUP=zoncou
Return
