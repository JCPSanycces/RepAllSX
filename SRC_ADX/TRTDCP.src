######################################################################################
#  Spécificités module vente pour le champs PLISTC                                   #
######################################################################################
## Etiquette ajoutée par le superviseur (écran CPY2) 15/12/2005 10:59:11 (LD)
######################################################################################
Subprog AM_PLISTC(VALEUR)
Variable Char    VALEUR()

If GREP="C" End : Endif
Local Shortint WMVT : WMVT=0
# S'il n'y a aucun mouvement pour cette société, ttes les modifications sont possibles
If clalev([F:SQH]) =0 Local File SQUOTE [SQH]  : Endif   : # Devis
Filter [SQH] Where CPY=[M:CPY0]CPY
If rowcount ([F:SQH])>0 WMVT=1 Endif
Filter [SQH]
If WMVT=1 Gosub VERIF_COL_PLISTC : End : Endif
If clalev([F:SOH]) =0 Local File SORDER [SOH]  : Endif   : # Commandes
Filter [SOH] Where CPY=[M:CPY0]CPY
If rowcount ([F:SOH])>0 WMVT=1 Endif
Filter [SOH]
If WMVT=1 Gosub VERIF_COL_PLISTC : End : Endif
If clalev([F:SDH]) =0 Local File SDELIVERY [SDH] : Endif : # Livraison
Filter [SDH] Where CPY=[M:CPY0]CPY
If rowcount ([F:SDH])>0 WMVT=1 Endif
Filter [SDH]
If WMVT=1 Gosub VERIF_COL_PLISTC : End : Endif
If clalev([F:SIV]) =0 Local File SINVOICEV [SIV] : Endif : # Facture
Filter [SIV] Where CPY=[M:CPY0]CPY
If rowcount ([F:SIV])>0 WMVT=1 Endif
Filter [SIV]
If WMVT=1 Gosub VERIF_COL_PLISTC : End : Endif
If clalev([F:SPC]) =0 Local File SPRICCONF [SPC] : Endif : # Paramétrage tarif
Filter [SPC] Where PLICPY=[M:CPY0]CPY
If rowcount ([F:SPC])>0 WMVT=1 Endif
Filter [SPC]
If WMVT=1 Gosub VERIF_COL_PLISTC : End : Endif
End
# ------------------------------------------------------------------------------------------------------------ #
# S'il y a des mvts pour la société, les colonnes de l'ancienne et la nvelle structure doivent être identiques #
# ------------------------------------------------------------------------------------------------------------ #
$VERIF_COL_PLISTC
Local Shortint I

If clalev([F:PRS]) =0 Local File PRICSTRUCT [PRS]  : Endif
If clalev([F:PRS2])=0 Local File PRICSTRUCT [PRS2] : Endif
If [F:PRS]BPCBPS<>1 | [F:PRS]PLISTC<>VALEUR
  Read [PRS] PRS0=1;VALEUR : If fstat Raz [F:PRS] : Endif
Endif
Read [PRS2] PRS0=1;[M]PLISTC : If fstat Raz [F:PRS2] : Endif
For I=0 To 8
  If [F:PRS2]INCDCR(I)=0 Break : Endif
  If [F:PRS2]INCDCR(I)   <>[F:PRS]INCDCR(I)    |
&    [F:PRS2]VALTYP(I)   <>[F:PRS]VALTYP(I)    |
&    [F:PRS2]CLCRUL(I)   <>[F:PRS]CLCRUL(I)    |
&    [F:PRS2]NPRNOTFLG(I)<>[F:PRS]NPRNOTFLG(I) |
&    [F:PRS2]INVDTA(I)   <>[F:PRS]INVDTA(I)    mkstat=2
                                               GMESSAGE=mess(290,199,1)
                                               Break : Endif
Next I

End

