#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
  Case ACTION
    When Default
  Endcase
Return

Subprog CHARG_DCP(SOC)
Value Char SOC()
Raz [M:DCP]
Read [F:DCP]DCP0=SOC
If !fstat
 [M:DCP] = [F:DCP]
Endif
If !GIMPORT
 If [M:CPY1]CPYLEGFLG=2
  Actzo [M:DCP]
 Else
  Grizo [M:DCP]
 Endif
Endif
End

Subprog CREDCP(SOC)
Value Char    SOC()
Delete [DCP] Where CPY=SOC
If fstat=1
 GOK = -1
 GLOCK = "$DADCPY"-SOC
 End
Elsif fstat>5
 GOK = 0
 Call RSTA("DCP",SOC) From GLOCK
 End
Endif
If [M:CPY1]CPYLEGFLG=2
 [F:DCP]CPY = SOC
 [F:DCP]    = [M:DCP]
 Write [DCP]
 If fstat
  GOK=0 : Call FSTA("DCP") From GLOCK
 Endif
Endif
End

Subprog CTLDAD()
If [M:CPY1]CPYLEGFLG<>2
 Read[DCP]DCP0=[M:CPY0]CPY
 If !fstat
  Delete [DCP] Where CPY=[M:CPY0]CPY
  If fstat=1
   GOK = -1
   GLOCK = "$DADCPY"-[M:CPY0]CPY
   End
  Elsif fstat>5
   GOK = 0
   Call RSTA("DCP",[M:CPY0]CPY) From GLOCK
   End
  Endif
 Endif
Endif
End

