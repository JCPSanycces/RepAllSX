#<AdxTL>@(#)12.0.0.0 $Revision$
# This program is called by the configuration console

# SOLUTION_FAMILY is the XXXX identifier in upper case (10 char max)
# PATH is a path on application server where the file get_[xxxx]world has been transferred
# RETURN_STATUS must be set to 0 if OK, to 1 if an error occurs
# ERROR_MESSAGE may contain an error message if OK is equal to 1
Local Integer RETURN_STATUS
Local Char    ERROR_MESSAGE(250)
Call CONFIGURATION("AAAA", "/u/dom/chemin", RETURN_STATUS, ERROR_MESSAGE)
End

Subprog CONFIGURATION(SOLUTION_FAMILY, PATH, RETURN_STATUS, ERROR_MESSAGE)
Value Char SOLUTION_FAMILY(), PATH()
Variable Integer RETURN_STATUS
Variable Char ERROR_MESSAGE()
Onerrgo NOPROG
Call CONFIGURATION(PATH, RETURN_STATUS, ERROR_MESSAGE) From ="A_"+toupper(SOLUTION_FAMILY)
Onerrgo
End

$NOPROG
Resume
