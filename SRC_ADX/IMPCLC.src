$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
Endcase
Return

$IMPORT
[M]TYP       = [F:CLC]REFTYP
[M]LASTYPDEF = [F:CLC]LASTYP(0)
[M]LASNUMDEF = [F:CLC]LASNUM(0)
[M]LASDATDEF = [F:CLC]LASDAT(0)
[M]LASTYPSIM = [F:CLC]LASTYP(1)
[M]LASNUMSIM = [F:CLC]LASNUM(1)
[M]LASDATSIM = [F:CLC]LASDAT(1)
Return
