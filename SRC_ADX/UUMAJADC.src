#<AdxTL>@(#)12.0.0.0 $Revision$
##############################################################################
## Init champ SRCINT de la table ADICTRT
##############################################################################
Call OUVRE_TRACE("") From LECFIC
Call PATCH_X3(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Local Integer MAJ
Local Char CHAINE(250)

If DOSSIER<>GDOSX3 : End : Endif
Local File "ADICTRT" [ADC] 

# Mise à jour de la table ADICTRT
Call ECR_TRACE(mess(81,125,1)-"ADICTRT:"-time$,0) From GESECRAN
Trbegin [ADC]
 For [ADC]
  MAJ = 0
  CHAINE = num$([F:ADC]SRC)+"/"+num$([F:ADC]SRCINT)
  If [F:ADC]SRC<>2
   If GPRODUIT=-1 & find([F:ADC]MODULE,1,2,5,6,7,9,11,12,13)<>0
    If [F:ADC]SRCINT<>2
     [F:ADC]SRCINT = 2 : MAJ = 1
    Endif
   Elsif [F:ADC]MODULE=1 & [F:ADC]SRC<>2
    If [F:ADC]SRCINT<>2
     [F:ADC]SRCINT = 2 : MAJ = 1
    Endif
   Endif
  Endif
  If [F:ADC]SRCINT=0
   [F:ADC]SRCINT = 2 : MAJ = 1
  Endif
  If [F:ADC]SRC=2
   If [F:ADC]SRCINT<>1
    [F:ADC]SRCINT = 1 : MAJ = 1
   Endif
  Endif
  If MAJ
   Rewrite [ADC]
   If fstat
    Call ERREUR("ADICTRT"-[F:ADC]CODTRT,2) From DOSDIC
   Endif
   Call ECR_TRACE([F:ADC]CODTRT-CHAINE-"=>"-num$([F:ADC]SRC)+"/"+num$([F:ADC]SRCINT),0) From GESECRAN
  Endif
 Next
Commit

Close Local File [ADC]
End

