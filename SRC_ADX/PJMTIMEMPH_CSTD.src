#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMPH
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From PJMTIMEMPH_CSTD_EVENTS   # Issue X3-94962 - 2018-06-20 by FGR
        When "ACONTROL"                : Gosub ACONTROL                        From PJMTIMEMPH_CSTD_EVENTS
      Endcase
    When "TIMENT"
      Case [L]AEVENT
        When "ADELLINE_BEFORE"         : Gosub TIMENT_ADELLINE_BEFORE          From PJMTIMEMPH_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub TIMENT_ADDLINE_AFTER            From PJMTIMEMPH_CSTD_EVENTS
        When "AINSERT_AFTER"           : Gosub TIMENT_AINSERT_AFTER            From PJMTIMEMPH_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR
        When "AUPDATE_AFTER"           : Gosub TIMENT_AUPDATE_AFTER            From PJMTIMEMPH_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR
        When "ADELETE_AFTER"           : Gosub TIMENT_ADELETE_AFTER            From PJMTIMEMPH_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR
      Endcase
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"          : Gosub SETERROR                                  From PJMTIMEMPH_CSTD_METHODS
    When "PTE_RESET_ERRORS"  : Gosub PTE_RESET_ERRORS                          From PJMTIMEMPH_CSTD_METHODS
    #
    When "TIMENT_GET_INDEX"  : Gosub TIMENT_GET_INDEX                          From PJMTIMEMPH_CSTD_METHODS
    When "_TIMENT_VALIDATION": Gosub _TIMENT_VALIDATION                        From PJMTIMEMPH_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "FROM_PJMOPEAFF"    : Gosub FROM_PJMOPEAFF                            From PJMTIMEMPH_CSTD_OPERATIONS
    When "TIMENT_VALIDATION" : Gosub TIMENT_VALIDATION                         From PJMTIMEMPH_CSTD_OPERATIONS # Issue X3-66487 - 2018-04-08 by SINGC
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CLB"               : Gosub CLB
    When "TCHPTESEQ"         : Gosub TCHPTESEQ             # Issue X3-94962 - 2018-06-20 by FGR
  Endcase
Return


####################################################################################################
$CLB
  Case [L]ARULE
    When "INIT"       :     Gosub CLB_INIT
    When "CONTROL"    :     Gosub CLB_CONTROL
  Endcase
Return

$CLB_INIT
  Local File PJMAUS [PAUS]
  # ----------------------
  Read [PAUS]PAUS=this.ACTX.USER
  If !fstat Then
    If [F:PAUS]PAUSTT = [V]CST_AYES or [F:PAUS]PAUSPA = [V]CST_AYES Then
      this.CLB = this.ACTX.USER
    Endif
  Endif
Return

$CLB_CONTROL
  # 1) To be able to change the this.CLB value the user have to be an administrator
  If this.CLB <> this.ACTX.USER Then
    Local File PJMAUS [PAUS]
    # ----------------------
    Read [PAUS]PAUS=this.ACTX.USER
    If [F:PAUS]PAUSPA <> [V]CST_AYES Then
      [L]ASTATUS = fmet this.SETERROR("CLB", func AFNC.MES1(mess(222,2260,1), this.CLB),[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################################################
$TCHPTESEQ
  # Issue X3-94962 - 2018-06-20 by FGR
  Case [L]ARULE
    When "INIT"       :     Gosub TCHPTESEQ_INIT
  Endcase
Return

$TCHPTESEQ_INIT
  # Issue X3-94962 - 2018-06-20 by FGR
  this.TCHPTESEQ = 0
Return

