#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CHGITG0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:07"
A_USER  = "DOC"
A_STAMP = "20181109230307"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CHGITG0 [DIA0]
Gosub HORODAT
Local Inpbox "CHGITG0" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA0] As [SIM_]
Grizo [DIA0]5
Grizo [DIA0]10
Grizo [DIA0]15
Grizo [DIA0]20
Grizo [DIA0]25
Grizo [DIA0]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=40 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=40 : Y1(1)=3 : Y2(1)=6
X1(2)=1 : X2(2)=40 : Y1(2)=7 : Y2(2)=24
X1(3)=41 : X2(3)=80 : Y1(3)=1 : Y2(3)=2
X1(4)=41 : X2(4)=80 : Y1(4)=3 : Y2(4)=6
X1(5)=41 : X2(5)=80 : Y1(5)=7 : Y2(5)=24
Return

$ON_TCLCODOLD
Onevent CONTROL Call C_TCLCODOLD(zc) From W1CHGITG0
Onevent AFTER_CHANGE Gosub AMM_TCLCODOLD From W1CHGITG0
Onevent BEFORE_INPUT Call AS_TCLCODOLD(zc) From W1CHGITG0
Return

Subprog AS_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TCLCODOLD(zc) From W1CHGITG0
Onkey 144 Titled GBOUTP Call P_TCLCODOLD(zc) From W1CHGITG0
Onkey 146 Titled GBOUTA Call SA_TCLCODOLD(zc) From W1CHGITG0
Gosub _AFF
End

Subprog C_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ITG","$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
 If !mkstat
  ## Action STD
  Call C_TCLCODOLD(VALEUR) From SUBCHGITG
  If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TCLCODOLD
Call AM_TCLCODOLD(zc)
If !mkstat & GOBJET
 zoncou = "TCLCODOLD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TCLCODOLD(VALEUR) From SUBCHGITG
If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZTCLCODOLD)")>indice
 [M]TCLCODOLD(indice) = VALEUR
 Affzo ZTCLCODOLD(indice)
Endif
Gosub _AFF
End

Subprog S_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ITG"
PARMSK(2) = "$"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ITG"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ITG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTCLCODOLD
Onevent BEFORE_AREA Gosub AV_ZTCLCODOLD From W1CHGITG0
Return

$AV_ZTCLCODOLD
Call LECTEXTRA(zc,"ITMCATEG","TCLAXX",num$([M]TCLCODOLD(indice)),"") From ATEXTRA
Gosub _AFF
Return

