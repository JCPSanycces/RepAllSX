#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMAFF Properties
###################################################################################################
$PAFCLB
  Case [L]ARULE
    When "CONTROL"   : Gosub PAFCLB_CONTROL
    When "PROPAGATE" : Gosub PAFCLB_PROPAGATE
  Endcase
Return

$PAFCLB_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PAFCLB <> this.snapshot.PAFCLB Then
      [L]ASTATUS = fmet this.SETERROR("PAFCLB", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
  # ----------------------
  Local File PJMAUS [PAS]
  Read [PAS]PAUS=this.PAFCLB
  If fstat Then
    [L]ASTATUS = fmet this.SETERROR("PAFCLB", func AFNC.MES1(mess(185,2260,1), this.PAFCLB), [V]CST_AERROR)
  Endif
Return

$PAFCLB_PROPAGATE
  Local File PJMAUS [PAS]
  Read [PAS]PAUS = this.PAFCLB
  this.PAFROL = [PAS]PAUSROL
Return

