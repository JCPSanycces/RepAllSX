#<AdxTL>@(#)11.0.0.0 $Revision$

####################################################
## Etats UNALLOCCASH1 / UNALLOCCASH2
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    PARAM(30) , RPT(GLONARP)
Local Char    BPCTYP,BPSTYP
#
Local Char SOCIETE(GLONCPY)
Local Integer NBSOC
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer K, I, J
#
If !clalev([F:ARM])  : Local File AREPORTM   [ARM] : Endif
If !clalev([F:CDA])  : Local File GACCDENCOD [CDA]  : Endif
If !clalev([F:CDA2]) : Local File GACCDENCOD [CDA2] : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif

# Récupération des commandes
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
Call GETPARAM("societe",NBPAR,PARAMETRE,PARAM) From ETAT
Call PARAM(PARAM,"BPCORDTYP",[L]BPCTYP) From ADOVAL : # CCL
Call PARAM(PARAM,"BPSORDTYP",[L]BPSTYP) From ADOVAL : # CCF

Call SETPARAM("ccl",NBPAR,PARAMETRE,[L]BPCTYP) From ETAT
Call SETPARAM("ccf",NBPAR,PARAMETRE,[L]BPSTYP) From ETAT

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM) From ETAT
K = instr(1,PARAM,".")
If K : PARAM = left$(PARAM,K-1) : Endif
RPT = PARAM


If ETAT="UNALLOCCASH2"

 Local Char BPR(GLONBPR)

 Call GETPARAM("tiers",NBPAR,PARAMETRE,[L]BPR) From ETAT

 If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
 Read [BPR]BPR0 = [L]BPR
 If fstat
  #Tiers incorrect
  Call ECR_TRACE([L]BPR+":"-mess(50,102,1),1) From GESECRAN
  GOK = 0 : End
 Endif

Else

 Local Char    BPRSTR(GLONBPR), BPREND(GLONBPR)

 Call GETPARAM("tiersdeb",NBPAR,PARAMETRE,[L]BPRSTR) From ETAT
 Call GETPARAM("tiersfin",NBPAR,PARAMETRE,[L]BPREND) From ETAT

# If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
# Read [BPR]BPR0 = [L]BPRSTR
# If fstat
#  #Tiers incorrect
#  Call ECR_TRACE([L]BPRSTR+":"-mess(50,102,1),1) From GESECRAN
#  GOK = 0 : End
# Endif
# Read [BPR]BPR0 = [L]BPREND
# If fstat
#  #Tiers incorrect
#  Call ECR_TRACE([L]BPREND+":"-mess(50,102,1),1) From GESECRAN
#  GOK = 0 : End
# Endif
Endif

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT : NUMREQ = val(PARAM)
PARAM = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
If SOCIETE<>"?????"
 Read [CPY]CPY0 = SOCIETE
 If fstat
  # Société incorrecte
  Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
  GOK = 0 : End
 Endif
 If [F:CPY]CPYLEGFLG<>2
  NBSOC = 0
  For [FGR]FGR0 Where CPY=SOCIETE
   Read [FCY]FCY0 = [F:FGR]FCY
   If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
    NBSOC += 1
    TBSOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Next
 Else
  NBSOC = 1
  TBSOC(1) = SOCIETE
 Endif 
Endif
Call DEBTRANS From GLOCK
Gosub TR0 From CPTRPT
Gosub TR1

End

$TR1
GOK=1
Trbegin [ARM]
 Raz [F:ARM]
 For I=1 To NBSOC
  Call LEC_CPY(TBSOC(I)) From CPTLEC
  For [CDA2]CDA0(1)
   Call LEC_CDA_LEG([F:CPY]LEG,[F:CDA2]COD) From CPTLEC
   If !fstat
    #Dans le LEC_CDA_LEG on lit CDA avec le leg si il existe ou leg vide si il n'existe pas
    #donc on a bien dan [F:CDA] le LEG qu'il faut pour notre CPY
    J += 1
    [F:ARM]RPTCOD = ETAT
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = NUMREQ
    [F:ARM]NUMLIG = J
    [F:ARM]CLEA1 = [F:CDA]COD
    [F:ARM]CLEA2 = [F:CDA]LEG
    [F:ARM]CLEA3 = [F:CPY]CPY
    [F:ARM]CLEA4 = "GACCDENCOD"
    Write [F:ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
   Endif 
  Next
 Next
 If GOK=0 : Rollback : Return : Endif
Commit
Return
