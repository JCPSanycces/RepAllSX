#<AdxTL>@(#)10.0.0.0 $Revision$  Gestion du masque CONSSED1
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSED]: Transmask [M:SED1] To [M:CSED]# Issue 25606 [M:CSED] = [M:SED1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STF]) = 0 : Local File STOLOCAFF  [STF] : Endif
If clalev([F:STC]) = 0 : Local File STOLOC     [STC] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
#
Local Char    WFIL(250)
Local Char    WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSED"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SED1]FLG = 0
[M:SED1]    = [M:CSED]
Return
############################################################
$AP_MAGNETO
[M:SED1]FLG = 0
Return
############################################################
$SETBOUT
If [M:SED1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(7)  = [M:SED2]LOC(nolign-1)
      REPONSE = GSTAFIN
    Endif
Endcase
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SED1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SED1]ITMREFSTR = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SED1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:SED1]SELFLG = val(PARAM(I))
      Endif
    When 6 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = PARAM(I)
      Endif
  Endcase
Next I
If clalev([M:CSED]) <> 0 & [M:CSED]MEMO = "STD"
  [M:SED1] = [M:CSED]
Endif
[M:SED1]FLG = 2
Return
############################################################
$LECTURE
If [M:SED1]FLG = 2
  [M:SED1]FLG = 0
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK] #[STF]  prise en compte du dépôt via un link (PLI le 29/01/2010)
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK] #[STF]  prise en compte du dépôt via un link (PLI le 29/01/2010)
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SED2]
    WLIG = 0
    For [LNK] #[STF]  prise en compte du dépôt via un link (PLI le 29/01/2010)
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK] #[STF]  prise en compte du dépôt via un link (PLI le 29/01/2010)
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK] #[STF]  prise en compte du dépôt via un link (PLI le 29/01/2010)
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SED1]FLG = 0
  [M:SED1]FLG = 1
  Raz [M:SED2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
# --- Prise en compte du filtre sur le dépôt (par PLI, le 29/01/2010)
# --- on passe par un Link pour filtrer le dépôt sur [STC]
#  Filter [STF] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
#&              Order By Key STF0
  Link [STF] With [STC]STC0=[F:STF]STOFCY;[F:STF]LOC As [LNK]
&            Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&            Order By Key STF0
  Raz [F:STF]
Endif
Return
############################################################
$LOAD_FILTER
# Filtre site
WFIL = '[F:STF]STOFCY=[M:SED1]FCY&[F:STF]ITMREF<>""'
# Filtre dépôt  (Par PLI, le 29/01/2010)
If dim([M:SED1]WRH) > 0 & [M:SED1]WRH <> ""
  WFIL += "&([F:STC]WRH=[M:SED1]WRH)"
Endif
# Filtre article
If [M:SED1]ITMREFSTR <> "" | [M:SED1]ITMREFEND <> ""
  If [M:SED1]ITMREFSTR = [M:SED1]ITMREFEND
    WFIL += "&[F:STF]ITMREF=[M:SED1]ITMREFSTR"
  Else
    WFIL += "&[F:STF]ITMREF>=[M:SED1]ITMREFSTR"
    WFIL += "&[F:STF]ITMREF<=[M:SED1]ITMREFEND"
  Endif
Endif
Return
############################################################
$LOA_LIGNE
[M:SED2] = [F:STF]
# --- Prise en compte du filtre sur le dépôt (par PLI, le 29/01/2010)
# --- on passe par un Link pour filtrer le dépôt sur [STC]
#Read [STC]STC0=[F:STF]STOFCY;[F:STF]LOC
#If fstat = 0
#  [M:SED2] = [F:STC]
#Endif
[M:SED2] = [F:STC]


#
If [F:ITM]ITMREF <> [F:STF]ITMREF
  Read [ITM]ITM0=[F:STF]ITMREF
  If fstat
    Raz [F:ITM]
  Endif
Endif
#[M:SED2]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SED2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SED2]STU    (nolign-1) = [F:ITM]STU
$LOA_LIGNE_FIN
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SED1]FLG = 0
If dim([M:SED1]WRH) > 0
   Raz   [M:SED1]WRH
   Affzo [M:SED1]WRH
Endif
End
############################################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End
######################################################################################
Subprog AM_WRH(VALEUR)     # prise en compte du dépôt via un link (PLI le 29/01/2010)
Variable Char    VALEUR()
[M:SED1]FLG = 0
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SED1]FLG  = 0
[M]ITMREFEND = VALEUR
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SED1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SED") From SUBGTC

End

