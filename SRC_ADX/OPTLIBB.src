#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################
# Routines diverses pour dialogue Ordo - X3 07.05 31503
###########################################################################
# OPERATION_MOVED_PE    appelé au déplacement d'une opération
#---------------------
# Lorsque qu'une opération est déplacée sur un nouveau poste dans
# l'ordonnancement, ce point d'entrée applicatif est appelé pour valider
# ce déplacement.
# Paramètres en entrée:
# --------------------
#                             WMFGNUM     : numéro d'OF
#                             WOPENUM     : numéro d'opération
#                             WOPESPLNUM  : numéro de fraction d'opération
#                             WWST        : poste de charge destinataire
#                             WSBB        : sous-poste éventuel
#                             WDATE       : nouvelle date
#
# Paramètres en sortie:
# --------------------
# La réponse est formulée par un appel au sous-programme WRITE_FEEDBACK
# du traitement OPTLIBB:
# Call WRITE_FEEDBACK(LFCY, LCOD, LOK, LMESS, LFOCUS, LFOCUSMESS) From OPTLIBB
# avec:
#         Char     LFCY  : site de production
#         Char     LCOD  : code réponse
#                          "050" = contrôle utilisateur en changement de poste opération
#         Integer  LOK   : Indicateur de validation
#                          0 = déplacement interdit
#                          1 = déplacement autorisé, sans modification de données
#                          2 = déplacement autorisé, avec modification de données
#         Char     LMESS : Message à afficher dans l'ordonnancement
#                          (le message sera affiché quelque soit le type de validation)
#         Integer  LFOCUS    : Indicateur de focus
#                              0 = pas de focus
#                              1 = focus actif
#         Char     LFOCUSMESS : Message focus (annule et remplace l'infobulle sur l'opération)
#
# La modification de données est communiquée via le masque OPTW1 [OPW1].
# Les champs disponibles sont les suivants:
#                           EXTLAB        : poste M.O secondaire
#                           OPELABCOE     : coefficient MO opératoire
#                           PRPTIM        : temps de préparation
#                           EXTSETTIM     : temps de réglage
#                           EXTOPETIM     : temps opératoire
#                           PSPTIM        : temps post-opératoire
#                           EXTWSTNBR     : nombre de poste utilisé
#                           EXTLABNBR     : nombre de MO utilisé
###########################################################################
$OPERATION_MOVED_PE
Raz [M:OPW1]
#------------------------------------------------------------------------------------------------------------------
# point d'entrée GANTT_OPE_MOVED
If GSCHENTRYB : GPOINT = "OPE_MOVED" : Gosub ENTREE From EXEFNC : Endif
If GPE : Return : Endif
#------------------------------------------------------------------------------------------------------------------
Return

###########################################################################
# Test 02.07
$OPERATION_INVENTORY_PE
Raz [M:MODK]
GINVOPEN = 0
#------------------------------------------------------------------------------------------------------------------
# point d'entrée GANTT_OPE_INVENTORY
If GSCHENTRYB : GPOINT = "OPE_INVENT" : Gosub ENTREE From EXEFNC : Endif
If GPE : Return : Endif
#------------------------------------------------------------------------------------------------------------------
Return



###########################################################################
# Ecriture feedback
# Format:
#       - Code échange (exemple 050 = contrôle changement poste opération
#       - Flag validation (0 = Non, 1 = Oui)
#       - Message utilisateur
###########################################################################
Subprog WRITE_FEEDBACK(LFCY, LCOD, LOK, LMESS, LFOCUS, LFOCUSMESS)
Value Char     LFCY
Value Char     LCOD
Value Integer  LOK
Value Char     LMESS
Value Integer  LFOCUS
Value Char     LFOCUSMESS

Local Char    OPTFEED(200)
Local Integer SAVIUM : SAVIUM = adxium

# génération ficher
OPTFEED = func OPTLIB.FILNAM(LFCY,"ilfeed",0)

adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)
adxium = GUTF8

Openo OPTFEED,0

# déplacement opération
Wrseq LCOD;LOK;LMESS;LFOCUS;LFOCUSMESS;[M:OPW1]EXTLAB;[M:OPW1]OPELABCOE;[M:OPW1]PRPTIM;[M:OPW1]EXTSETTIM;
&     [M:OPW1]EXTOPETIM;[M:OPW1]PSPTIM;[M:OPW1]EXTWSTNBR;[M:OPW1]EXTLABNBR

# fermeture
Openo

adxium = SAVIUM

# paramètres
Call ILFIL2CSV(LFCY,"ilfeed","v6_x3_feedback") From OPTLIB

End

###########################################################################
# Ecriture focus 09.06
# Format:
#       - Code échange (000 = focus sur opération au lancement
#       - Flag problème (0 = Non, 1 = Oui)
#       - Message utilisateur
###########################################################################
Subprog WRITE_FOCUS(LFCY, LCOD, LOK, LMESS)
Value Char     LFCY
Value Char     LCOD
Value Integer  LOK
Value Char     LMESS

Local Integer SAVIUM : SAVIUM = adxium

adxifs = ";"
adxirs = chr$(10)
adxium = GUTF8

If GSCHFOCUS = ""
   GSCHFOCUS = func OPTLIB.FILNAM(LFCY,"ilfocus",0)
Endif

If GFOCUSOPEN = 0
  Openo GSCHFOCUS,0
  GFOCUSOPEN = 1
Else
  Openo GSCHFOCUS
Endif

# focus initial
Wrseq LCOD;LOK;LMESS;[M:OPW1]MFGNUM;[M:OPW1]OPENUM;[M:OPW1]OPESPLNUM

Openo

adxium = SAVIUM

End

###########################################################################
# Ecriture Custom features 02.07
# Format:
#       - Code (001 = action click droit opération)
#       - Titre action
###########################################################################
Subprog WRITE_CUSTOM(LFCY, LCOD, LMESS)
Value Char     LFCY
Value Char     LCOD
Value Char     LMESS

Local Integer SAVIUM : SAVIUM = adxium

adxifs = ";"
adxirs = chr$(10)
adxium = GUTF8


If GCUSTOMOPEN = 0
  Openo GSCHCUSTOM,0
  GCUSTOMOPEN = 1
Else
  Openo GSCHCUSTOM
Endif

# custom action
Wrseq LCOD;LMESS

Openo

adxium = SAVIUM

End

###########################################################################
# Ecriture dispo
# Format:
#       - Code échange (exemple 051 = dispo stock)
###########################################################################
# Test 02.07
Subprog WRITE_INVENTORY(LFCY, LCOD, LOK)
Value Char     LFCY
Value Char     LCOD
Value Integer  LOK

Local Integer SAVIUM : SAVIUM = adxium

# génération ficher
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)
adxium = GUTF8

If GSCHINV = ""
   GSCHINV = func OPTLIB.FILNAM(LFCY,"ilinv",0)
Endif

If GINVOPEN = 0
  Openo GSCHINV,0
  GINVOPEN = 1
Else
  Openo GSCHINV
Endif

# déplacement opération
Wrseq LCOD;LOK;
&     [M:MODK]LIB(0);[M:MODK]DATA(0);[M:MODK]LIB(1);[M:MODK]DATA(1);[M:MODK]LIB(2);[M:MODK]DATA(2);[M:MODK]LIB(3);
&     [M:MODK]DATA(3);[M:MODK]LIB(4);[M:MODK]DATA(4);[M:MODK]LIB(5);[M:MODK]DATA(5);[M:MODK]LIB(6);[M:MODK]DATA(6);
&     [M:MODK]LIB(7);[M:MODK]DATA(7);[M:MODK]LIB(8);[M:MODK]DATA(8);[M:MODK]LIB(9);[M:MODK]DATA(9);
&     [M:MODK]LIB(10);[M:MODK]DATA(10);[M:MODK]LIB(11);[M:MODK]DATA(11);[M:MODK]LIB(12);[M:MODK]DATA(12);
&     [M:MODK]LIB(13);[M:MODK]DATA(13);[M:MODK]LIB(14);[M:MODK]DATA(14);[M:MODK]LIB(15);[M:MODK]DATA(15);
&     [M:MODK]LIB(16);[M:MODK]DATA(16);[M:MODK]LIB(17);[M:MODK]DATA(17);[M:MODK]LIB(18);[M:MODK]DATA(18);
&     [M:MODK]LIB(19);[M:MODK]DATA(19);[M:MODK]LIB(20);[M:MODK]DATA(20)

# fermeture
Openo

adxium = SAVIUM

End

###########################################################################
# reset feedback
###########################################################################
Subprog RESET_FEEDBACK
Call WRITE_FEEDBACK("XXX", "000", 1, "", 0, "") From OPTLIBB
End

###########################################################################
# reset focus
###########################################################################
Subprog RESET_FOCUS
Call WRITE_FOCUS("XXX", "000", 1, "") From OPTLIBB
GFOCUSOPEN = 0
End

###########################################################################
# reset custom
###########################################################################
Subprog RESET_CUSTOM
Call WRITE_CUSTOM("XXX", "000", "") From OPTLIBB
GCUSTOMOPEN = 0
End

###########################################################################
# reset dispo
###########################################################################
# Test 02.07
Subprog RESET_INVENTORY
Call WRITE_INVENTORY("XXX", "000", 1) From OPTLIBB
GINVOPEN = 0
End

###########################################################################
# transfert dispo
###########################################################################
# test 07.02
Subprog COPY_INVENTORY(LFCY)
Value Char LFCY

Call ILFIL2CSV(LFCY,"ilinv","v6_x3_inventory") From OPTLIB

End
