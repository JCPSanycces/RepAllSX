#<AdxTL>@(#)0.0.0.0 $Revision$
# This script is used by the following classes :
# ***
# TCWPSH_CSTD
# ***
# TCWPOH_CSTD
# ***
# TCWPOC_CSTD
# ***
# TCWPXX_CSTD
# ***


###############################################################################

$AREAD_AFTER
  Local File AWRKHISSUI [AWS]
  Read [AWS]AWS2 = this.DEST;this.CHRONO
  If !fstat
    Gosub READ_DATA_AWS #get workflow info
    Case WCODOBJ
      When "PSH" : Gosub READ_DATA_PSH  #get Purchase req. info
      When "POH" : Gosub READ_DATA_POH  #get Order info
      When "POC" : Gosub READ_DATA_POC  #get Open order info
      When "PXX" : #nothing to do
    Endcase
  Endif
  LogicClose File [AWS]
Return

###############################################################################

$READ_DATA_AWS
  Local Integer I
  I = instr(1,[AWS]CLEDEC,"~")
  If I > 0
    this.KEYNUM = left$([AWS]CLEDEC, I-1)
    this.KEYLIN = val(right$([AWS]CLEDEC, I+1))
  Else
    this.KEYNUM = [AWS]CLEDEC
    this.KEYLIN = 0
  Endif

  SetInstance this With [F:AWS]
  this.MAIENV   = func GET_EMAIL([AWS]EMETTEUR, [AWS]MAIENV)
  this.EMAIL    = func GET_EMAIL([AWS]DEST, [AWS]EMAIL)
Return

###############################################################################

$READ_DATA_PSH
  #get PREQUIS (header)
  Local File PREQUIS [PSH]
  Read [PSH]PSH0 = this.KEYNUM
  If !fstat
    SetInstance this.PSH With [F:PSH]
    #Attention : here we get currency from workflow's info
    this.CUR = func GET_CPYCUR([F:PSH]CPY)
  Endif
  LogicClose File [PSH]

  #get PREQUISD (lines)
  Local Integer WPOS, WPOS1
  Local File PREQUISD [PSD]

  If this.KEYLIN = 0
    Filter [PSD] Where PSHNUM = this.KEYNUM Order By PSDLIN Asc
  Else
    Filter [PSD] Where PSHNUM = this.KEYNUM and PSDLIN = this.KEYLIN
  Endif
  For [PSD]
    WPOS = fmet this.PSH.ADDLINE("PSD",[V]CST_ALASTPOS)
    If WPOS >= 0
      SetInstance this.PSH.PSD(WPOS) With [F:PSD]

      #get Analytique
      Local File CPTANALIN [CAL]
      Read [CAL]CAL0 = "PSD";0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;"";1
      If !fstat
        WPOS1 = fmet this.PSH.PSD(WPOS).ADDLINE("PSDCAL",[V]CST_ALASTPOS)
        If WPOS1 >= 0
          SetInstance this.PSH.PSD(WPOS).PSDCAL(WPOS1) With [F:CAL]
          For J = 1 To func GET_OPTCANA() #GOPTCANA
            this.PSH.PSD(WPOS).PSDCAL(WPOS1).C_DIE(J).DIE = [F:CAL]DIE(J-1)
            this.PSH.PSD(WPOS).PSDCAL(WPOS1).C_DIE(J).CCE = [F:CAL]CCE(J-1)
          Next J
        Endif
      Endif
      LogicClose File [CAL]
    Endif
  Next
  Filter [PSD]
  LogicClose File [PSD]
Return

###############################################################################

$READ_DATA_POH
  #get PORDER (header)
  Local File PORDER [POH]
  Read [POH]POH0 = this.KEYNUM
  If !fstat
    SetInstance this.POH With [F:POH]
  Endif
  LogicClose File [POH]

  #get PORDERP (lines)
  Local Integer WPOS, WPOS1, WPOS2
  Local File PORDERP [POP]

  If this.KEYLIN = 0
    Filter [POP] Where POHNUM = this.KEYNUM Order By POPLIN Asc
  Else
    Filter [POP] Where POHNUM = this.KEYNUM and POPLIN = this.KEYLIN
  Endif
  For [POP]
    WPOS = fmet this.POH.ADDLINE("POP",[V]CST_ALASTPOS)
    If WPOS >= 0
      SetInstance this.POH.POP(WPOS) With [F:POP]

      #get PORDERQ (lines)
      Local File PORDERQ [POQ]
      Read [POQ]POQ0 = [F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ
      If !fstat
        WPOS1 = fmet this.POH.POP(WPOS).ADDLINE("POQ",[V]CST_ALASTPOS)
        If WPOS1 >= 0
          SetInstance this.POH.POP(WPOS).POQ(WPOS1) With [F:POQ]
        Endif
      Endif
      LogicClose File [POQ]

      #get Analytique
      Local File CPTANALIN [CAL]
      Read [CAL]CAL0 = "POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
      If !fstat
        WPOS2 = fmet this.POH.POP(WPOS).ADDLINE("POPCAL",[V]CST_ALASTPOS)
        If WPOS2 >= 0
          SetInstance this.POH.POP(WPOS).POPCAL(WPOS2) With [F:CAL]
          For J = 1 To func GET_OPTCANA() #GOPTCANA
            this.POH.POP(WPOS).POPCAL(WPOS2).C_DIE(J).DIE = [F:CAL]DIE(J-1)
            this.POH.POP(WPOS).POPCAL(WPOS2).C_DIE(J).CCE = [F:CAL]CCE(J-1)
          Next J
        Endif
      Endif
      LogicClose File [CAL]
    Endif
  Next
  Filter [POP]
  LogicClose File [POP]
Return

###############################################################################

$READ_DATA_POC
  #get PORDER (header)
  Local File PORDER [POH]
  Read [POH]POH0 = this.KEYNUM
  If !fstat
    SetInstance this.POH With [F:POH]
  Endif
  LogicClose File [POH]

  #get PORDERC (line)
  Local Integer WPOS, WPOS1, WPOS2
  Local File PORDERC [POC]

  If this.KEYLIN = 0
    Filter [POC] Where POHNUM = this.KEYNUM Order By POPLIN Asc
  Else
    Filter [POC] Where POHNUM = this.KEYNUM and POPLIN = this.KEYLIN
  Endif
  For [POC]
    WPOS = fmet this.POH.ADDLINE("POC",[V]CST_ALASTPOS)
    If WPOS >= 0
      SetInstance this.POH.POC(WPOS) With [F:POC] #only one unique line to read
    Endif
  Next
  Filter [POC]
  LogicClose File [POC]
Return

###############################################################################

Funprog GET_EMAIL(USER, EMAIL)
Value Char USER
Value Char EMAIL
  Local Char WEMAIL(250) : WEMAIL = ""
  If EMAIL = ""
    Local File AUTILIS [AUS]
    Read [AUS]CODUSR = USER
    If !fstat
      WEMAIL = [AUS]ADDEML
    Endif
    LogicClose File [AUS]
  Else
    WEMAIL = EMAIL
  Endif
End WEMAIL

###############################################################################

Funprog GET_OPTCANA()
  #get WOPTCANA
  Local Integer WOPTCANA
  Local File ACTIV [ACV]
  Read [ACV]CODACT = "ANA"
  If !fstat and [ACV]FLACT = [V]CST_AYES
    WOPTCANA = [ACV]DIMMAX  #GOPTCANA
  Else
    WOPTCANA  = 0
  Endif
  LogicClose File [ACV]
End WOPTCANA

###############################################################################

Funprog GET_CPYCUR(WCPY)
Value Char WCPY
  Local File COMPANY [CPY]
  Read [CPY]CPY0 = WCPY
  If !fstat
    WCUR = [CPY]ACCCUR
  Else
  Endif
  LogicClose File [CPY]
End WCUR

