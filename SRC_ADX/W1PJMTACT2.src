$ON_STRDAT
Onevent AFTER_CHANGE Gosub AMM_STRDAT From W1PJMTACT2
Onevent BEFORE_AREA Gosub AV_STRDAT From W1PJMTACT2
Return

$AV_STRDAT
Chgfmt [M]STRDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$AMM_STRDAT
Call AM_STRDAT(zc)
If !mkstat & GOBJET
 zoncou = "STRDAT" : Gosub APRES_MODIF From =GPROGRAMME
