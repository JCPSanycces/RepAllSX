#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:56"
A_USER  = "DOC"
A_STAMP = "20181109230556"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBPJTAC2"
  If [M]NBPJTAC2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTACT2 [PJTAC2]
Gosub HORODAT
Local Inpbox "PJMTACT2" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC2] As [SIM_]
Grizo [PJTAC2]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTAC2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=25
Return

$ON_NBPJTAC2
Onevent CONTROL Call C_NBPJTAC2 From W1PJMTACT2
Return

Subprog C_NBPJTAC2
Local Decimal BASPAG
## Action STD
Call C_NBPJTAC2 From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "NBPJTAC2" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_OPENUMLNK
Onevent AFTER_CHANGE Gosub AMM_OPENUMLNK From W1PJMTACT2
Onevent BEFORE_INPUT Call AS_OPENUMLNK(zc) From W1PJMTACT2
Onevent CONTROL Call C_OPENUMLNK(zc) From W1PJMTACT2
Return

Subprog AS_OPENUMLNK(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_OPENUMLNK(zc) From W1PJMTACT2
Gosub _AFF
End

Subprog C_OPENUMLNK(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPENUMLNK" : GZNUM = 1002420 : Endif
Gosub _AFF
End

$AMM_OPENUMLNK
Call AM_OPENUMLNK(zc)
If !mkstat & GOBJET
 zoncou = "OPENUMLNK" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPENUMLNK(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_OPENUMLNK(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPENUMLNK" : GZNUM = 1002420 : Endif
Gosub _AFF
End

Subprog S_OPENUMLNK(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELPJMOPEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMOPEL"
 PARMSK(1) = [M:PJTA0]OPPNUM
 PARMSK(2) = [M:PJTA0A]TASCOD
 PARMSK(3) = num$([M:PJTAC0]OPENUM)
 PARMSK(4) = num$([M:PJTAC0]OPESPLNUM)
 Call S_LIS_NUM(VALEUR,PARMSK,"SELPJMOPEL","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_OPELNKTYP
Onevent AFTER_CHANGE Gosub AMM_OPELNKTYP From W1PJMTACT2
Onevent INIT_AREA Call D_OPELNKTYP(zc) From W1PJMTACT2
Onevent BEFORE_INPUT Call AS_OPELNKTYP(zc) From W1PJMTACT2
Onevent CONTROL Call C_OPELNKTYP(zc) From W1PJMTACT2
Return

Subprog D_OPELNKTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]OPELNKTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPELNKTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_OPELNKTYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPELNKTYP" : GZNUM = 10108 : Endif
Gosub _AFF
End

$AMM_OPELNKTYP
Call AM_OPELNKTYP(zc)
If !mkstat & GOBJET
 zoncou = "OPELNKTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPELNKTYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_OPELNKTYP(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPELNKTYP" : GZNUM = 10108 : Endif
Gosub _AFF
End

