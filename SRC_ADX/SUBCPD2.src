#########################################################################
# Traitement lié à la fenêtre de complément demandes de livraison       #
#########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"      : Gosub DEBUT
Endcase

Return

#########################################################################
# Actions sur la fenêtre de saisie                                      #
#########################################################################
$DEBUT
Local Integer NOL

# Action VISUDLIV / Fenêtre ICOMPDLI2
If GACTION = "VISUDLIV"
   NOL = nolign-1
   [M] = [F:SOC]
   [M]YSTOFCY = [M:SOV1]STOFCY(NOL)
   [M]YUSEPLC = [M:SOV1]USEPLC(NOL)
   [M]YBPTNUM = [M:SOV1]BPTNUM(NOL)
   [M]YMDL    = [M:SOV1]MDL(NOL) 
   [M]YDAYLTI = [M:SOV1]DAYLTI(NOL)
   [M]YDLVPIO = [M:SOV1]DLVPIO(NOL)
   [M]YPCK    = [M:SOV1]PCK(NOL)
   [M]YPCKCAP = [M:SOV1]PCKCAP(NOL)
Endif
Affzo [M:CPD2]1-99
Return

