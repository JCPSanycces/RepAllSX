#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MIGXTD2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:26"
A_USER  = "DOC"
A_STAMP = "20181109230526"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "TDFNBR"
  If [M]TDFNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MIGXTD2 [MIGXTD2]
Gosub HORODAT
Local Inpbox "MIGXTD2" From GFONCTION At A_STAMP With A_WINDPREV Mask [MIGXTD2] As [SIM_]
Grizo [MIGXTD2]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MIGXTD2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_TDFNBR
Onevent BEFORE_INPUT Call AS_TDFNBR From W1MIGXTD2
Return

Subprog AS_TDFNBR
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
mkstat = 2 : GMESSAGE = ""
If !mkstat
Endif
Gosub _AFF
End

$CHG_STY
Return


