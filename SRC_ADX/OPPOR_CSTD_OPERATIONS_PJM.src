#######################################################################################
$PJM_TASK_RITT_SOQQTY
#Value Char OPPNUM ()
#Variable Instance TECSOQITM Using C_TECSOQITM : #
#Local Integer ARET_VALUE

Local Instance LOGFILE Using C_ALOG
Local Instance ZINSPJM Using C_OPPOR
Local Instance ZTECSOQITM Using C_TECSOQITM
Local Integer IRET
Local Integer IRETLOG

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If TECSOQITM <> null Then # Issue X3-20398/121073 - 2017-01-20 by FGR
    Repeat
      If ZTECSOQITM <> null Then
        FreeGroup ZTECSOQITM
        Raz ZTECSOQITM
      Endif
      ZTECSOQITM = NewInstance C_TECSOQITM AllocGroup null
      IRET = fmet ZTECSOQITM._LOAD_ONE_OPPNUM(TECSOQITM)
      If IRET < [V]CST_AERROR Then
        If maxtab(ZTECSOQITM.SOQ) > 0 Then
          # ------------------------------------
          ZINSPJM = NewInstance C_OPPOR AllocGroup null
          ZINSPJM.TCHTOREAD = "PJM"
          IRET = fmet ZINSPJM.AREAD(ZTECSOQITM.SOQ(1).OPPNUM)
          If IRET < [V]CST_AERROR Then
            If fmet ZINSPJM.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
              If ZINSPJM.PIMPL.OPPSTATE <> 4 and ZINSPJM.PIMPL.OPPSTATE <> 9 Then
                ZINSPJM.PJM(1).TCHACTION = "SOQQTY"
                [L]ARET_VALUE = fmet ZINSPJM.PJM(1)._TASK_RITT_SOQQTY(ZTECSOQITM)
                If IRET < [V]CST_AERROR Then
                  [L]ARET_VALUE = fmet ZINSPJM.AUPDATE()
                  If [L]ARET_VALUE >= [V]CST_AERROR Then
                    IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(ZINSPJM, this)
                  Endif
                Else
                  IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(ZINSPJM, this)
                Endif
              Else
                [L]ARET_VALUE = fmet this.SETERROR("", ZTECSOQITM.SOQ(1).OPPNUM - ":" - mess(251,2260,1), [V]CST_AERROR)
              Endif
            Else
              [L]ARET_VALUE = fmet this.SETERROR("", ZTECSOQITM.SOQ(1).OPPNUM - ":" - mess(197,2260,1), [V]CST_AERROR)
            Endif
          Else
            [L]ARET_VALUE = fmet this.SETERROR("", ZTECSOQITM.SOQ(1).OPPNUM - ":" - mess(49,125,1), [V]CST_AERROR)
          Endif
          # ------------------------------------
          FreeGroup ZINSPJM
          Raz ZINSPJM
          # ------------------------------------
          If [L]ARET_VALUE >= [V]CST_AERROR Then
            Break
          Endif
        Endif
      Endif
    Until maxtab(ZTECSOQITM.SOQ) = 0
    # ------------------------------------
    If ZTECSOQITM <> null Then
      FreeGroup ZTECSOQITM
      Raz ZTECSOQITM
    Endif
    # ------------------------------------
    If [L]ARET_VALUE <> [V]CST_AOK Then
      If LOGFILE = null Then
        LOGFILE = NewInstance C_ALOG AllocGroup null
        IRETLOG = fmet LOGFILE.ABEGINLOG(mess(1003,2260,1))     ### TODO FLORENT CREER MESSAGE
      Endif
      # ------------------------------------
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
      # ------------------------------------
    Endif
    # ------------------------------------
    If LOGFILE <> null Then
      TECSOQITM.LOGFILNAM = fmet LOGFILE.AGETNAME()          # Set in the parameter technical class the name of the log file
      IRETLOG = fmet LOGFILE.AFLUSHLOG()
      IRETLOG = fmet LOGFILE.AENDLOG()
      FreeGroup LOGFILE
    Endif
  Endif
  # ------------------------------------
Return

#######################################################################################
$PJM_TASK_RITT_ALLOCATION
#Value Char OPPNUM ()
#Variable Instance TECALLITM Using C_TECALLITM : #
#Local Integer ARET_VALUE

Local Instance LOGFILE Using C_ALOG
Local Instance ZINSPJM Using C_OPPOR
Local Instance ZTECALLITM Using C_TECALLITM
Local Integer IRET
Local Integer IRETLOG

  # Issue X3-31898 - 2017-11-17 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If TECALLITM <> null Then
    Repeat
      If ZTECALLITM <> null Then
        FreeGroup ZTECALLITM
        Raz ZTECALLITM
      Endif
      ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
      IRET = fmet ZTECALLITM._LOAD_ONE_OPPNUM(TECALLITM)
      If IRET < [V]CST_AERROR Then
        If maxtab(ZTECALLITM.RITT) > 0 Then
          # ------------------------------------
          ZINSPJM = NewInstance C_OPPOR AllocGroup null
          ZINSPJM.TCHTOREAD = "PJM"
          IRET = fmet ZINSPJM.AREAD(ZTECALLITM.RITT(1).OPPNUM)
          If IRET < [V]CST_AERROR Then
            If fmet ZINSPJM.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
              If ZINSPJM.PIMPL.OPPSTATE <> 4 and ZINSPJM.PIMPL.OPPSTATE <> 9 Then
                ZINSPJM.PJM(1).TCHACTION = "ALLOC"
                [L]ARET_VALUE = fmet ZINSPJM.PJM(1)._TASK_RITT_ALLOCATION(ZTECALLITM)
                If [L]ARET_VALUE < [V]CST_AERROR Then
                  [L]ARET_VALUE = fmet ZINSPJM.AUPDATE()
                  If [L]ARET_VALUE >= [V]CST_AERROR Then
                    IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(ZINSPJM, this)
                  Endif
                Else
                  IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(ZINSPJM, this)
                Endif
              Else
                [L]ARET_VALUE = fmet this.SETERROR("", ZTECALLITM.RITT(1).OPPNUM - ":" - mess(251,2260,1), [V]CST_AERROR)
              Endif
            Else
              [L]ARET_VALUE = fmet this.SETERROR("", ZTECALLITM.RITT(1).OPPNUM - ":" - mess(197,2260,1), [V]CST_AERROR)
            Endif
          Else
            [L]ARET_VALUE = fmet this.SETERROR("", ZTECALLITM.RITT(1).OPPNUM - ":" - mess(49,125,1), [V]CST_AERROR)
          Endif
          # ------------------------------------
          FreeGroup ZINSPJM
          Raz ZINSPJM
          # ------------------------------------
          If [L]ARET_VALUE >= [V]CST_AERROR Then
            Break
          Endif
        Endif
      Endif
    Until maxtab(ZTECALLITM.RITT) = 0
    # ------------------------------------
    If ZTECALLITM <> null Then
      FreeGroup ZTECALLITM
      Raz ZTECALLITM
    Endif
    # ------------------------------------
    If [L]ARET_VALUE <> [V]CST_AOK Then
      If LOGFILE = null Then
        LOGFILE = NewInstance C_ALOG AllocGroup null
        IRETLOG = fmet LOGFILE.ABEGINLOG(mess(1002,2260,1))
      Endif
      # ------------------------------------
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
      # ------------------------------------
    Endif
    # ------------------------------------
    If LOGFILE <> null Then
      TECALLITM.LOGFILNAM = fmet LOGFILE.AGETNAME()          # Set in the parameter technical class the name of the log file
      IRETLOG = fmet LOGFILE.AFLUSHLOG()
      IRETLOG = fmet LOGFILE.AENDLOG()
      FreeGroup LOGFILE
    Endif
  Endif
  # ------------------------------------
Return

#######################################################################################
$PJM_SPLD_SOLD
#Value Char OPPNUM ()
#Value Char PSONUM : #
#Value Integer IACTION : #
#Variable Instance TECSPLDSOLD Using C_TECSPLDSOLD : #
