#######################################################################################
# Issue X3-69372 - 2018-03-30 by FGR/SINGC : BEGIN
$PJM_TASK_TIMEENTRY
#Value Char OPPNUM ()
#Variable Instance PJMTIMEMP Using C_PJMTIMEMP : #
#Variable Instance TECPTETAS Using C_TECPTETAS : #
#Local Integer ARET_VALUE

Local Instance LOGFILE Using C_ALOG
Local Instance ZINSPJM Using C_OPPOR
Local Integer IRET
Local Char SMESSAGE(250)
Local Char SSNPPROJECT(GLONPIM)
Local Char SSNPBUDGET(GLONPBU)
Local Char SSNPTASK(GLONTAC)
Local Char SPROJECT(GLONPIM)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)
Local Integer IADXLOG

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If this.OPPNUM <> AVOID.ACHAR and this.OPPNUM <> [L]OPPNUM Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(120,7711,1), [V]CST_AERROR))
  Endif
  # ------------------------------------
  If fmet PJMTIMEMP._PJM_TASK_TIMEENTRY_TOUPDATE() = [V]CST_AYES Then
    If [L]ARET_VALUE < [V]CST_AERROR Then
      If this.OPPNUM = "" Then
        this.TCHTOREAD = "PJM"
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.AREAD([L]OPPNUM))
      Endif
    Endif
    # ------------------------------------
    If [L]ARET_VALUE < [V]CST_AERROR Then
      If fmet this.COM_IS_PJM_OPPOR() = [V]CST_AFALSE Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(197,2260,1), [V]CST_AERROR))
      Endif
      If this.PJM(1).OPPSTATE = 1 or this.PJM(1).OPPSTATE = 4 or this.PJM(1).OPPSTATE = 9 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.PJM(1).OPPSTATE,2249,1)), [V]CST_AERROR))
      Endif
    Endif
    # ------------------------------------
    If [L]ARET_VALUE < [V]CST_AERROR Then
      # ------------------------------------
      IADXLOG = (adxlog = 1)
      If IADXLOG = [V]CST_AFALSE Then
        Local File OPPOR [OPP]
        Trbegin [F:OPP]
      Endif
      # ------------------------------------
      If PJMTIMEMP.ASTALIN = [V]CST_ANEW Then
        # ------------------------------------
        If PJMTIMEMP.PIMTASCOD <> AVOID.ACHAR Then
          # If now it is a budget, nothing to do
          TECPTETAS.IACTION = [V]CST_ANEW
          this.PJM(1).TCHACTION = "TIMEENTRY"
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS_TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE))
          If [L]ARET_VALUE > [V]CST_AOK Then
            IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(this, PJMTIMEMP)
          Endif
        Endif
        # ------------------------------------
      Elsif PJMTIMEMP.ASTALIN = [V]CST_ADEL Then
        # ------------------------------------
        If PJMTIMEMP.snapshot.PIMTASCOD <> AVOID.ACHAR Then
          # If previously it was a budget, nothing to do
          TECPTETAS.IACTION = [V]CST_ADEL
          this.PJM(1).TCHACTION = "TIMEENTRY"
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS_TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE))
          If [L]ARET_VALUE > [V]CST_AOK Then
            IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(this, PJMTIMEMP)
          Endif
        Endif
        # ------------------------------------
      Elsif PJMTIMEMP.ASTALIN = [V]CST_AUPD and fmet PJMTIMEMP._PJM_TASK_TIMEENTRY_TOUPDATE() = [V]CST_AYES Then
        # ------------------------------------
        Raz SSNPPROJECT
        Raz SSNPBUDGET
        Raz SSNPTASK
        If PJMTIMEMP.snapshot.PIMTASCOD <> AVOID.ACHAR Then
          IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, PJMTIMEMP.snapshot.PIMTASCOD, SSNPPROJECT, SSNPBUDGET, SSNPTASK)
        Endif
        SPROJECT = [L]OPPNUM # Issue X3-85806 - 2018-06-06 by FGR : not Raz SPROJECT
        Raz SBUDGET
        Raz STASK
        If PJMTIMEMP.PIMTASCOD <> AVOID.ACHAR Then
          IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, PJMTIMEMP.PIMTASCOD, SPROJECT, SBUDGET, STASK)
        Endif
        If PJMTIMEMP.snapshot.PIMTASCOD <> AVOID.ACHAR Then
          # If previously it was a budget, nothing to do
          If SSNPPROJECT = SPROJECT or SPROJECT = AVOID.ACHAR Then
            # First we have to check if PJMTIMEMP.snapshot. and PJMTIMEMP are on the same project : "ZINSPJM = this"
            ZINSPJM = this
          Else
            ZINSPJM = NewInstance C_OPPOR AllocGroup null
            ZINSPJM.TCHTOREAD = "PJM"
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet ZINSPJM.AREAD(SSNPPROJECT))
            # Issue X3-85806 - 2018-06-06 by FGR : BEGIN
            If [L]ARET_VALUE <> [V]CST_AOK Then
              IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZINSPJM, PJMTIMEMP)
            Endif
            # Issue X3-85806 - 2018-06-06 by FGR : END
          Endif
          If [L]ARET_VALUE < [V]CST_AERROR Then
            TECPTETAS.IACTION = [V]CST_ADEL
            ZINSPJM.PJM(1).TCHACTION = "TIMEENTRY"
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet ZINSPJM.PJM(1).TAS_TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE))
            # Issue X3-85806 - 2018-06-06 by FGR : BEGIN
            If [L]ARET_VALUE <> [V]CST_AOK Then
              IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZINSPJM, PJMTIMEMP)
            Endif
            # Issue X3-85806 - 2018-06-06 by FGR : END
          Endif
          If [L]ARET_VALUE < [V]CST_AERROR Then
            If ZINSPJM <> this Then
              # If we are working on 2 different projects, we have to update the decreased one
              [L]ARET_VALUE = max([L]ARET_VALUE, fmet ZINSPJM.AUPDATE())
              If [L]ARET_VALUE <> [V]CST_AOK Then
                IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZINSPJM, PJMTIMEMP)
                If LOGFILE = null Then
                  LOGFILE = NewInstance C_ALOG AllocGroup null
                  IRETLOG = fmet LOGFILE.ABEGINLOG(mess(304,2260,1))
                Endif
                Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(ZINSPJM, LOGFILE) From SYRSTACKTOOLS
              Endif
              FreeGroup ZINSPJM
              Raz ZINSPJM
            Endif
          Endif
        Endif
        If [L]ARET_VALUE < [V]CST_AERROR Then
          If PJMTIMEMP.PIMTASCOD <> AVOID.ACHAR Then
            # If now it is a budget, nothing to do
            TECPTETAS.IACTION = [V]CST_ANEW
            this.PJM(1).TCHACTION = "TIMEENTRY"
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS_TIMEENTRY(PJMTIMEMP, TECPTETAS, LOGFILE))
            If [L]ARET_VALUE > [V]CST_AOK Then
              IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(this, PJMTIMEMP)
            Endif
          Endif
        Endif
        # ------------------------------------
      Endif
      # ------------------------------------
      If [L]ARET_VALUE < [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE,fmet this.AUPDATE())
        If [L]ARET_VALUE > [V]CST_AOK Then
          IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(this, PJMTIMEMP)
        Endif
      Endif
      # ------------------------------------
      If IADXLOG = [V]CST_AFALSE Then
        If [L]ARET_VALUE > [V]CST_AWARNING Then
          Rollback
        Else
          Commit
        Endif
      Endif
    Endif
    # ------------------------------------
    If [L]ARET_VALUE <> [V]CST_AOK Then
      If LOGFILE = null Then
        LOGFILE = NewInstance C_ALOG AllocGroup null
        IRETLOG = fmet LOGFILE.ABEGINLOG(mess(304,2260,1))
      Endif
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
    Endif
    # ------------------------------------
    If LOGFILE <> null Then
      TECPTETAS.LOGFILNAM = fmet LOGFILE.AGETNAME()          # Set in the parameter technical class the name of the log file
      IRETLOG = fmet LOGFILE.AFLUSHLOG()
      IRETLOG = fmet LOGFILE.AENDLOG()
      FreeGroup LOGFILE
    Endif
    # ------------------------------------
    If [L]ARET_VALUE < [V]CST_AERROR Then # Issue X3-18324/120705 - 2017-01-04 by FGR
      Raz this.PJM(1).TCHACTION
    Endif
  Endif
Return

#$PJM_TASK_TIMEENTRY
