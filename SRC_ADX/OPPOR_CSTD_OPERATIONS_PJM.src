#######################################################################################
$PJM_TASK_RTKO_CLOSING
#Value Char OPPNUM ()
#Value Char TASCOD ()
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Instance LOGFILE Using C_ALOG

  # ------------------------------------
  If this.OPPNUM <> AVOID.ACHAR and OPPNUM <> this.OPPNUM Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(120,7711,1), [V]CST_AERROR)
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    If this.OPPNUM = "" Then
      this.TCHTOREAD = "PJM"
      [L]ARET_VALUE = fmet this.AREAD(OPPNUM)
    Endif
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    If fmet this.COM_IS_PJM_OPPOR() = [V]CST_AFALSE Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(197,2260,1), [V]CST_AERROR)
    Endif
    If this.PIMPL.PIMSTA <> [V]CST_AYES Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(251,2260,1), [V]CST_AERROR)
    Endif
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    # ------------------------------------
    If this.PJM(1).OPPSTATE = 1 or this.PJM(1).OPPSTATE = 4 Then
      [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.PJM(1).OPPSTATE,2249,1)), [V]CST_AERROR)
    Endif
    # ------------------------------------
    ILINE = fmet this.PJM(1).TAS_GET_INDEX(TASCOD)
    If ILINE < 1 Then
      [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(255,2260,1), TASCOD), [V]CST_AERROR)
    Else
      this.PJM(1).TAS(ILINE).TCHACTION = "RTKO_CLOSING"
      If [L]ARET_VALUE <> [V]CST_AERROR Then
        [L]ARET_VALUE = fmet this.PJM(1).TAS(ILINE).RTKO_CLOSING(OPENUM, OPESPLNUM, LOGFILE, TECOPPACT)
      Endif
      If [L]ARET_VALUE <> [V]CST_AERROR Then
        [L]ARET_VALUE = fmet this.AUPDATE()
      Endif
    Endif
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AOK Then
    If LOGFILE = null Then
      LOGFILE = NewInstance C_ALOG AllocGroup null
      IRETLOG = fmet LOGFILE.ABEGINLOG(mess(304,2260,1))
    Endif
    # ------------------------------------
    Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
    # ------------------------------------
  Endif
  # ------------------------------------
  If LOGFILE <> null Then
    TECOPPACT.LOGFILNAM = fmet LOGFILE.AGETNAME()          # Set in the parameter technical class the name of the log file
    IRETLOG = fmet LOGFILE.AFLUSHLOG()
    IRETLOG = fmet LOGFILE.AENDLOG()
    FreeGroup LOGFILE
  Endif
  # ------------------------------------
  Raz this.PJM(1).TCHACTION
Return

