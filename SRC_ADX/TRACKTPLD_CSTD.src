#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TRACKTPLD


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
#Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
    When"TRKDEPCOD"
      Case [L]ARULE
        When "CONTROL"      : Gosub TRKDEPCOD_CONTROL
        When "PROPAGATE"    : Gosub TRKDEPCOD_PROPAGATE
   Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#  When "_SORT_TRACKTPLD"      : Gosub _SORT_TRACKTPLD      From TRACKTPLD_CMET
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
$TRKDEPCOD_PROPAGATE
Local Integer WIND
# Issue 53814 - 2017-09-05 by MAE : suppression de la dépendance si changement
If this.TRKDEPCOD <> this.snapshot.TRKDEPCOD
  WIND = find(this.snapshot.TRKDEPCOD, this.APARENT.TKTD(1..maxtab(this.APARENT.TKTD)).TRKCOD)
  If WIND <> AVOID.ADEC
    If this.snapshot.TRKDEPCOD <> AVOID.ACHAR
      this.TRKDEPLIN = AVOID.ADEC
    Endif
  Endif
Endif
# End issue 53814
WIND = find(this.TRKDEPCOD, this.APARENT.TKTD(1..maxtab(this.APARENT.TKTD)).TRKCOD)
If WIND <> AVOID.ADEC
  If this.TRKDEPCOD <> AVOID.ACHAR
    this.TRKDEPLIN = this.APARENT.TKTD(WIND).TRKLIN
  Endif
Endif
Return

$TRKDEPCOD_CONTROL
If this.TRKDEPCOD<>AVOID.ACHAR
WINDEX = find(this.TRKDEPCOD,this.APARENT.TKTD(1..maxtab(this.APARENT.TKTD)).TRKCOD)
  If WINDEX = AVOID.ADEC
    ASTATUS = fmet this.ASETERROR(CURPRO, mess(562,194,1), [V]CST_AERROR)
    Return
  Else
    If this.APARENT.TKTD(WINDEX).TRKMDY <> CST_AYES
     ASTATUS = fmet this.ASETERROR(CURPRO, mess(558,194,1), [V]CST_AERROR)
     Return
    Endif
    If this.APARENT.TKTD(WINDEX).TRKSORT >= this.TRKSORT
     ASTATUS = fmet this.ASETERROR(CURPRO, mess(563,194,1), [V]CST_AERROR)
     Return
    Endif
  Endif
Endif
Return

