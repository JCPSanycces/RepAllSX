#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC16          Moulinette de Migration              Module TRC  #
#                                                                        #
#          Update of new field BOMALTTYP                                 #
#                                                                        #
##########################################################################
# From TRCMAJ30  : UPDBMR   : Update of BOMRET    new field BOMALTTYP    #
#                              +  new flags instead of old CLSTYP        #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC16") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC16(WDOSSIER)
  Call MAJ_UUMGTRTTRC16(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC16(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC16(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC16(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

GOK=1
Gosub LOA_BOM From UUMGTRTTRC00

Gosub UPDBMR
If GOK<=0
    Call ECR_TRACE("UUMGTRTTRC16 table BOMRET Incorrectly Processed : Update BMR"-WDOSSIER,1) From GESECRAN
Endif
End
##########################################################################
Subprog RAZ_UUMGTRTTRC16(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1

#1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"BOMRET",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","BOMRET","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_UUMGTRTTRC16 Raz table BOMRET"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"BOMRET",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC16",ERR) From TRTMIG
Endif

End

####################################################################################
# FQ 49980 GA 10/2008
$UPDBMR
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # Module 9=Tronc commun
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If filinfo(filpath("FIL","BOMRET","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMBMRM
Call MIGTABNAME (WDOSSIER,"BOMRET",WNAMBMRM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMBMRM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC16 tables BMR Process : Update BMR") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC16:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"BOMRET",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:BMR])  = 0 : Local File =WDOSSIER+".BOMRET"      [BMR]  : Endif   # Fichier X3 "Vide"
If clalev([F:BMRM]) = 0 : Local File =WDOSSIER+"."+WNAMBMRM   [BMRM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:ITM])  = 0 : Local File =WDOSSIER+".ITMMASTER"   [ITM]  : Endif   # Articles migrés pour recup des *FLG

#-----  Déclaration des variables -----#
Local Char WTAB_BMR (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_BMR

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC16",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
# Issue 80145 Key=ITMREF+STOFCY
#&    Order By Key CLE = [F:BMRM]STOFCY;[F:BMRM]ITMREF
# Issue 80205 Unique ID = BMRUID+ITMREF+NIV
Link [BMRM] With [ITM]ITM0~=[F:BMRM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:BMRM]BMRUID;[F:BMRM]ITMREF;[F:BMRM]NIV

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC16" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BMR00
Raz NB
# Clé BMR0: BMRUID+ITMREF+NIV
If STOP = 1
 STOP = 2
 CRITERE = "[F:BMRM]BMRUID=val(TABMIGKEY(1)) & [F:BMRM]ITMREF=TABMIGKEY(2) & [F:BMRM]NIV>val(TABMIGKEY(3))"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:BMRM]BMRUID=val(TABMIGKEY(1)) & [F:BMRM]ITMREF>TABMIGKEY(2)"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:BMRM]BMRUID>val(TABMIGKEY(1))"
Else
 CRITERE = "1=1"
Endif

Trbegin [BMR]
GOK = 1

For [LNK] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_BMR : Endif
  Endif

  #Raz [F:BMR]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BMR
  Endif

  [F:BMR] = [F:BMRM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_BMR
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub BMR_STK : # pour stocker ref
      WriteB [F:BMR]
  Else
      Write [F:BMR]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File BOMRET, Error ="-num$(fstat),1) From GESECRAN
      Gosub BMR_ERRTRA : # pour afficher les ref
    Else
      # Issue 80205 Unique ID BMR0: BMRUID+ITMREF+NIV
      Call ECR_TRACE("File BOMRET(BMRUID/ITMREF/NIV)"-num$([F:BMR]BMRUID)-"/"-[F:BMR]ITMREF-"/"-num$([F:BMR]NIV)+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
   # Issue 80205 Unique ID BMR0: BMRUID+ITMREF+NIV
    TABMIGKEY(1) = num$([F:BMRM]BMRUID)
    TABMIGKEY(2) = [F:BMRM]ITMREF
    TABMIGKEY(3) = num$([F:BMRM]NIV)
    STOP=1
    Break
  Endif
$NEXT_BMR
Next

$END_BMR
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC16",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:BMR]
    If fstat
        Call ECR_TRACE("File BOMRET, Error ="-num$(fstat),1) From GESECRAN
        Gosub BMR_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_BMR : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_BMR
  Endif
  Commit
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC16",STOP,ERR) From TRTMIG
  NBCOMMIT+=NB
  If STOP
    Goto LOOP_BMR00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BMR]
Close Local File [BMRM]
Close Local File [ITM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"BOMRET",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC16") From TRTMIG
Call ECR_TIME("UUMGTRTTRC16:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$BMR_STK
Call STK (WTAB_BMR,WCPT_BMR,num$([F:BMR]BMRUID)-"/"-[F:BMR]ITMREF-"/"-num$([F:BMR]NIV)) From TRTMIG
Return

#######################################################################
$BMR_ERRTRA
Call ERRTRA (WTAB_BMR,WCPT_BMR,"File BOMRET(BMRUID/ITMREF/NIV)=") From TRTMIG
Return

##########################################################################
$RAZV6_BMR
Raz [F:BMR]BOMALTTYP  # V6 new field
Return

#######################################################################
# Code extrait de TRCMAJ30 - table BOMRET
########################################################################
$MAJV6_BMR
If [F:BMR]BOMALT > 0 & [F:BMR]BOMALTTYP=0
   [F:BMR]BOMALTTYP = WBOMALTTYP([F:BMR]BOMALT)
Endif
[F:BMR]MFGFLG = [F:ITM]MFGFLG
[F:BMR]SCPFLG = [F:ITM]SCPFLG
[F:BMR]SCSFLG = [F:ITM]SCSFLG
[F:BMR]PHAFLG = [F:ITM]PHAFLG
[F:BMR]GENFLG = [F:ITM]GENFLG
[F:BMR]TOOFLG = [F:ITM]TOOFLG
[F:BMR]DLVFLG = [F:ITM]DLVFLG
[F:BMR]PURFLG = [F:ITM]PURFLG
[F:BMR]SALFLG = [F:ITM]SALFLG
[F:BMR]INTFLG = [F:ITM]INTFLG
#[F:BMR]UPDUSR=GUSER
#[F:BMR]UPDDAT=date$
Return
