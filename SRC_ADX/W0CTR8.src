# Superviseur
# Gestion du masque CTR8 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone XITDAT
mkstat = 0
zoncou = "XITDAT"
indice = 0
WDATE = [M]XITDAT
If varmode([M]XITDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "XITDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_XITDAT([M]XITDAT) From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "XITDAT" : GZNUM = 1177 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]XITDAT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_XITDAT([M]XITDAT) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "XITDAT" : GZNUM = 1177 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone XITFNL
mkstat = 0
zoncou = "XITFNL"
indice = 0
IMPENT = [M]XITFNL
WNUM = IMPENT
If varinit([M]XITFNL,indice)=0
 IMPENT = 1
Endif
If varmode([M]XITFNL,indice)=0
 [M]XITFNL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "XITFNL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]XITFNL(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_XITFNL(IMPENT) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XITFNL" : GZNUM = 46631 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]XITFNL = IMPENT

## Zone XITGRD
mkstat = 0
zoncou = "XITGRD"
indice = 0
WCHAR = [M]XITGRD
If varmode([M]XITGRD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRXGD"
 Call DEFHRXGD([M]XITGRD,GCURLEG,GSOCIETE) From SUBHRXGD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]XITGRD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "XITGRD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]XITGRD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRXGD"
   Call CONTHRXGD([M]XITGRD,GCURLEG,GSOCIETE) From SUBHRXGD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]XITGRD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]XITGRD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_XITGRD([M]XITGRD) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]XITGRD or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_XITGRD([M]XITGRD) From SUBCTR
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

