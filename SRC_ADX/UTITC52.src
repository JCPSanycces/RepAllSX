#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################
# UTITC52                                                  Module Tronc commun                        #
# Suppression des enregistrement OMMRPT.TYPTPL=2                                                       #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
# Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-08-07 by MAE :
 #Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif
 If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC52: deletion records OMMRPT.TYPTPL=2") From LECFIC

 Call MAJ_UTITC52(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################################
Subprog MAJ_UTITC52(APPLI)
Value Char APPLI

Local Integer IFOUND

  If filinfo(filpath("FIL", "OMMRPT", "fde", APPLI), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  #
  Call ECR_TRACE("UUTITC52: Process Start on: "+APPLI,0) From GESECRAN
  Local File =APPLI+".OMMRPT" [OMR]
  #
  If type([F:OMR]TYPTPL) >= 0 Then
    Trbegin [OMR]
    IFOUND = 0
    For [OMR] Where TYPTPL <> 1
      IFOUND = 1
      Break
    Next
    If IFOUND = 1 Then
      Delete [OMR] Where TYPTPL <> 1
      If fstat Then
        GOK = 0 : Call ECR_TRACE(mess(28,125,1),-1) From GESECRAN : Goto AB_UUTITC52
      Else
        Call ECR_TRACE(mess(499,196,1) - "[" + num$(adxdlrec)  - mess(20,133,1) + "]",0) From GESECRAN
      Endif
    Endif
    Commit
  Endif
  Call ECR_TRACE("UUTITC52: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITC52
  Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"OMMRPT") : End : Endif
  # End MAE 108760

  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC52(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
If APPLI=GDOSX3
     End
Endif

  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"OMMRPT") : End : Endif
  Call MAJ_UTITC52(APPLI)
End

