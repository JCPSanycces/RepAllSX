#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FDEPOINT","DEPOINTAGE","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"           : Gosub DEBUT
 When "END"             : Gosub FIN
 When "SETBOUT"         : Gosub SETBOUT
 When "ENR"             : Gosub ENREGISTRE
 When "ABA"             : Gosub ABANDON
 When "BOUTON"          : Gosub BOUTON
 When "AB2_NBLIG"       : Gosub AV_B2_NBLIG
 When "BB2_NBLIG"       : Gosub AP_B2_NBLIG
 When "FINSAI"          : Gosub FINSAI
Endcase
Return

$DEBUT
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:RBK])=0 : Local File RELBANK    [RBK] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:AMK])=0 : Local File AMSK       [AMK] : Endif
If clalev([F:BED])=0 : Local File BANRECD    [BED] : Endif #107251.n

If clalev([F:DAE2])=0
 Local File GACCENTRYD [DAE2] Order By Key CLE = CHK ; CHKDAT ; ACCNUM
Endif
If clalev([F:RBK2])=0
 Local File RELBANK [RBK2] Order By Key CLE = CHK ; DATCHK ; BAN ; RBKNUM ; RECTYP ; RBKLIN
Endif

# GRNA 18/07/2011
Gosub OUVRE_CHN From CHKLIB

Local Char    LIGTRACE(100), OLDCHK(5), CRITERE(250) , MASQUE(10)
Local Integer I, J, K, COK, NOL, OCCUP, KIAOK, MAXLIG, STAT
Local Char    SYMBCHK(20), PBKOCC(2)
Local Char    VERTYP(GLONGTE), VERNUM(GLONVCR), PIECE(max(GLONREF,30))
Local Integer PBLOCK

MASQUE = "DEPOINT0"
Local Mask DEPOINT1 [DP1]
Default Mask [SAI1]

Raz [M:SAI1]
KIAOK = (dim([M]BANDAT)>0)
MAXLIG = dim([M]CHK)
Return

$FIN
Unlock =SYMBCHK
Gosub DELOCK
Return

$FINSAI
Return

$DELOCK
For I=0 To [M]NBLIG-1
 If [M]ACCNUM(I)<>0
  K = instr(1,[M]REFB(I)," ")
  PIECE = "HAE"+vireblc(mid$([M]REFB(I),K+1,GLONVCR),2)+"\"+left$([M]REFB(I),K-1)
  Unlock =PIECE
 Endif
Next I
Return

$ABANDON
For I=0 To [M]NBLIG-1
 If [M]CHX(I)="*" and [M]CHK(I)<>""
  [M]CHX(I)=""
  If ! GIMPORT : Affzo [M]CHX(I) : Endif
 Endif
Next I
Return

$SETBOUT
Raz ETABOU, CHMEN
ETABOU(GBFIN) = 1
If find("*",[M:SAI1]CHX(0..[M:SAI1]NBLIG-1))
 REP = "M"
 ETABOU(GENRE) = 1    : # Degrise Enregistrer si sélection
 ETABOU(GABAN) = 1    : # Degrise Abandon si sélection
Else
 REP = ""
Endif
If REP=""
 CHMEN += "OS"
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

$ENREGISTRE
NOL = nolign
Call TEMPON("V") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
If !GIMPORT
 Affzo
 SUIZON = "[M]CHX("+num$(NOL-1)+")"
Endif
Return

$TR1
GOK=1
Trbegin [DAE], [RBK]
For J=0 To [M]NBLIG-1
 If [M]CHX(J)<>"" & [M]CHK(J)<>"" : # Ligne sélectionnée
  Call DEPOINT(J)
  If GOK<=0 : Break : Endif
  Gosub DEPOINT_GRP
  If GOK<=0 : Break : Endif
  [M]CHK(J)=""
  [M]CHX(J)=""
 Endif
Next J
If GOK<0   : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

$DEPOINT_GRP
If [M]CHK(J)<"a" & !instr(1,"0123456789",left$([M]CHK(J),1)) & [M]CHK(J)<>"*"  : # Cas d'un pointage par rapprochement bancaire
 If [M]CRIAMT = 0
  For J_GRP=0 To [M]NBLIG-1
   If [M]CHX(J_GRP)="" & [M]CHK(J_GRP)=[M]CHK(J) & J<>J_GRP : # Ligne sélectionnée
    Call DEPOINT(J_GRP)
    If GOK<=0 : Break : Endif
    [M]CHK(J_GRP)=""
   Endif
  Next J_GRP
 Else
  Gosub DEPOINT2
 Endif
Endif
Return

$DEPOINT2
For [RBK2]CLE Where CHK = [M]CHK(J) & DATCHK = [M]CHKDAT(J) & BAN = [M]BAN With Lock
 If fstat=1
  GOK=-1 : GLOCK="$RELBANK"-[F:RBK]BAN-[F:RBK]RBKNUM : Break
 Endif
 [F:RBK2]CHK = ""
 [F:RBK2]DATCHK = [0/0/0]
 Rewrite [RBK2]
 If fstat
  GOK = 0 : Call FSTA("RBK2") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
For [DAE2]CLE Where CHK = [M]CHK(J) & CHKDAT = [M]CHKDAT(J) & ACC = [M]BANACC With Lock
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRYD"-[F:DAE2]TYP-[F:DAE2]NUM-num$([F:DAE2]LIN) : Break
 Endif
 [F:DAE2]CHK = ""
 [F:DAE2]CHKDAT = [0/0/0]
 Rewrite [DAE2]
 If fstat
  GOK = 0 : Call FSTA("DAE2") From GLOCK : Break
 Endif

 # GRNA 18/07/2011
 Gosub REVERSE_CHN From CHKLIB
 If GOK<1 : Break : Endif
Next
Return

$BOUTON
Case BOUT
 When "S"
  Gosub RECHERCHE
  If PBLOCK = 2
   If !GSERVEUR : Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC :  Endif
   FIN = 1
   Gosub FIN
  Endif
 When "O"
  Unlock =SYMBCHK
Endcase
Return

##################################
# BOUTON RECHERCHE
##################################
$RECHERCHE
If [M]NBLIG>0 : Gosub DELOCK : Endif
If !GIMPORT : Effzo [SAI1]10-15 : Endif
#Recherche du compte banque
Read [BAN]BAN0 = [M]BAN
If !fstat
 [M]BANACC = [F:BAN]BANACC
 [M]BANBPR = [F:BAN]BANBPR
Endif
Gosub CHARGEMENT
Gosub SYMBOLE
If [M]NBLIG<>0
 SUIZON = "[M]CHX(0)"
Endif
Return

$SYMBOLE
Unlock =SYMBCHK
SYMBCHK ="AUTCHK"+"\"+[M]BAN
Lock =SYMBCHK
If fstat
 GERR = 1 : GMESSAGE = mess(23,120,1) : # Compte en cours de pointage
 Unlock =SYMBCHK
 Return
Endif
Return

$CHARGEMENT
Call TEMPON("R") From GESECRAN
Gosub CALC_SOLDE
Call PARAM([M]CPY,"PRCRBKOCC",PBKOCC) From ADOVAL
Read [AMK]CODMSK=MASQUE
I=find(1,[F:AMK]TYPBLOC)
If I<>0
 OCCUP = ((100-val(PBKOCC))/100)*[F:AMK]NBLIGT(I-1)
Endif
nolign = 0
Gosub CHARGE_ECR
If FIN = 1 : Call TEMPOFF From GESECRAN : Return : Endif
If GOK : Gosub CHARGE_RBK : Endif
[M]NBLIG = nolign
Sorta NBLIG NBLIG Order By CHK([S]indice),AMTBNQ([S]indice),ACCDAT([S]indice)
Call TEMPOFF From GESECRAN
If !GIMPORT : Affzo : Endif
If [M]NBLIG = 0
 GERR = 2 : GMESSAGE = mess(20,124,1) : # Tableau vide
Endif
Return

$CALC_SOLDE
Read [BAN]BAN0 = [M]BAN
If !fstat
 [M]CUR    = [F:BAN]CUR
 [M]CPY    = [F:BAN]CPY
 [M]FCY    = [F:BAN]FCY
 [M]BANBPR = [F:BAN]BANBPR
Endif
Call SETCUR(1,[F:BAN]CPY,[M]CURLED) From CPTDIV
Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,datesyst,[M]BLC) From SUBCHK
Call PARAM([M]CPY,"SNSBNQ",[M]SNSBNQ) From ADOVAL
Call SOLDEBANK([M]BAN,[M]SNSBNQ,[M]BLB,[M]SNSBLB) From SUBRAB
Return

$CHARGE_ECR
 PBLOCK = 0
 CRITERE = "LEDTYP= GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK<>''"
 If [M]CRIAMT <> 0  : CRITERE -= '& AMTCUR=[M]CRIAMT' : Endif
 If [M]CRIDAT <> [0/0/0] : CRITERE -= '& CHKDAT>=['+format$(GFMD,[M]CRIDAT)+']' : Endif
 If [M]CRICHK <> "" : CRITERE -= '& CHK="'+[M]CRICHK+'"' : Endif
 Filter [DAE] Where evalue(CRITERE)
 For [DAE]DAE1
  If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
   COK = 1
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   If fstat
    COK = 0
   Else
    If [F:HAE]CAT <> 1 : COK = 0 : Endif : #(LA618) Réel
    Gosub VERROU
   Endif
  Else
   COK = 0
  Endif

  #107251.sn
  #Check if it originated from BANREC function, If so set COK = 0 and not load the transaction
  If COK
    Read [BED]BED1 = [F:DAE]ACCNUM
      If !fstat : COK = 0 : Endif
  Endif
  #107251.en

  If COK
   Raz [M]RBKLIN(nolign),[M]RBKNUM(nolign)
   [M]ACCNUM(nolign) = [F:DAE]ACCNUM
   [M]ACCDAT(nolign) = [F:HAE]ACCDAT
   [M]BANCIB(nolign) = [F:HAE]BANCIB
   [M]DES(nolign)    = [F:DAE]DES
   If [F:DAE]SNS=1
    [M]SNS(nolign)   = 1
    [M]SNS2(nolign)  = left$(mess(1,610,1),1) : # D
   Endif
   If [F:DAE]SNS=-1
    [M]SNS(nolign)    = 2
    [M]SNS2(nolign)   = left$(mess(2,610,1),1) : # C
   Endif

   # Si la devise de la piece est différente de la devise banque, mettre 0
   # sauf dans le cas où le compte de banque est passé à l'Euro
   Case [F:DAE]CUR
     When [M]CUR         :
       [M]AMTBNQ(nolign) = [F:DAE]AMTCUR
     When [F:BAN]OLDCUR  :
       [M]BANCUR(nolign) = [F:DAE]CUR
       [M]AMTCUR(nolign) = [F:DAE]AMTCUR
       Call CONVERT([M]BANCUR(nolign),[M]CUR,[M]CURLED,1,[M]ACCDAT(nolign),[M]AMTCUR(nolign),
&                   [M]AMTBNQ(nolign),STAT) From TRTDEV
     When Default        :
       [M]AMTBNQ(nolign) = 0
   Endcase

   [M]CHK(nolign)    = [F:DAE]CHK
   [M]CHKDAT(nolign) = [F:DAE]CHKDAT
   [M]REFC(nolign)   = [F:HAE]REF
   [M]REFB(nolign) = [F:HAE]TYP+" "+[F:DAE]NUM
   If [F:DAE]AMTFLG <> 0
    [M]AMTLED(nolign) = [F:DAE]AMTLED1
   Else
    [M]AMTLED(nolign) = [F:DAE]AMTLED
   Endif
   [M]VALDAT(nolign) = [F:HAE]VALDAT
   If KIAOK
    [M]BANDAT(nolign) = [F:HAE]BANDAT
   Endif
   [M]INDCOM(nolign) = 0
   [M]RENREJ(nolign) = ""
   nolign +=1
   If nolign >= MAXLIG
    GERR = 2 : GMESSAGE = mess(26,100,1) : # Tableau plein
    GOK=0
    Break
   Endif
   If nolign >= OCCUP : Break : Endif : # Taux de remplissage maximum
  Endif
 Next
Filter [DAE]
Return

$CHARGE_RBK
CRITERE = 'BAN=[M]BAN & CHK<>"" & RECTYP=2'
If [M]CRIAMT <> 0  : CRITERE -= '& AMTCUR=[M]CRIAMT' : Endif
If [M]CRIDAT <> [0/0/0] : CRITERE -= '& DATCHK>=['+format$(GFMD,[M]CRIDAT)+']' : Endif
If [M]CRICHK <> "" : CRITERE -= '& CHK="'+[M]CRICHK+'"' : Endif
Filter [RBK] Where evalue(CRITERE)
For [RBK]RBK1
 Gosub REMPLIT
 nolign +=1
 If nolign >= MAXLIG
  GERR = 2 : GMESSAGE = mess(26,100,1) : # Tableau plein
  Break
 Endif
Next
Filter [RBK]
Return

$REMPLIT
Raz [M]ACCNUM(nolign),[M]AMTLED(nolign),[M]CHKDAT(nolign)
[M]RBKNUM(nolign) = [F:RBK]RBKNUM
[M]RBKLIN(nolign) = [F:RBK]RBKLIN
[M]ACCDAT(nolign) = [F:RBK]OPEDAT
[M]BANCIB(nolign) = [F:RBK]BANCIB
[M]DES(nolign)    = [F:RBK]DES
If ([F:RBK]SNS=1 & val([M]SNSBNQ)=1) |
&  ([F:RBK]SNS=-1 & val([M]SNSBNQ)=2)
 [M]SNS(nolign)   = 1
 [M]SNS2(nolign)  = left$(mess(1,610,1),1) : # D
Endif
If ([F:RBK]SNS=-1 & val([M]SNSBNQ)=1) |
&  ([F:RBK]SNS=1 & val([M]SNSBNQ)=2)
 [M]SNS(nolign)   = 2
 [M]SNS2(nolign)  = left$(mess(2,610,1),1) : # C
Endif

If [F:RBK]CUR=[M]CUR
 [M]AMTBNQ(nolign) = [F:RBK]AMTCUR
 Raz [M]AMTCUR(nolign), BANCUR(nolign)
Else
 [M]BANCUR(nolign) = [F:RBK]CUR
 [M]AMTCUR(nolign) = [F:RBK]AMTCUR
 Call CONVERT([M]BANCUR(nolign),[M]CUR,[M]CURLED,1,[M]ACCDAT(nolign),[M]AMTCUR(nolign),
&             [M]AMTBNQ(nolign),STAT) From TRTDEV
Endif

[M]CHK(nolign)    = [F:RBK]CHK
[M]CHKDAT(nolign) = [F:RBK]DATCHK
[M]REFC(nolign)   = [F:RBK]ENTNUM
If [M]REFC(nolign) = "0" : [M]REFC(nolign) = "" : Endif
[M]REFB(nolign)   = [F:RBK]REF
[M]VALDAT(nolign) = [F:RBK]VALDAT
[M]INDCOM(nolign) = [F:RBK]INDCOM
[M]RENREJ(nolign) = [F:RBK]RENREJ
Return

$VERROU
# Pièce en cours de modif sur autre poste
If [F:DAE]TYP=VERTYP & [F:DAE]NUM=VERNUM
 COK = 0
 Return
Endif
Lock = "HAE"+[F:DAE]NUM+"\"+[F:DAE]TYP
If fstat
 # Pas de message dans une boucle en web
 # Call ERREUR(mess(11,105,1)-" "-[F:DAE]NUM-[F:DAE]TYP-" : "-mess(60,100,1))
 # &  From GESECRAN
 #Numéro de pièce xxxxxxxx : Enregistrement verrouillé
 If PBLOCK=0
  COK=2
  Call AVERTIR(mess(139,121,1),COK) From GESECRAN
  # Des échéances sont en cours de visualisation et n'ont pu être chargées
  If COK=2 : # OK poursuivre
   PBLOCK = 1
  Else # Annuler
   PBLOCK = 2
   FIN = 1
   Call OUVRE_TRACE(mess(15,120,1)) From LECFIC
   Call ECR_TRACE(mess(11,105,1)-[F:DAE]NUM-[F:DAE]TYP-":"-mess(60,100,1),1) From GESECRAN
  Endif
 Elsif PBLOCK = 2
  Call ECR_TRACE(mess(11,105,1)-[F:DAE]NUM-[F:DAE]TYP-":"-mess(60,100,1),1) From GESECRAN
 Endif
 COK = 0
 VERTYP = [F:DAE]TYP
 VERNUM = [F:DAE]NUM
Endif
Return

#########################################
# BOUTON AUTO
#########################################
$TR2
Local Char    LIGTRACE(100), OLDCHK(5)
Local Date DATMIN, DATMAX
Local Char CLOSEDPER(2)
GOK=1

Call PARAM ([F:BAN]CPY,"CLOSEDPER",CLOSEDPER) From ADOVAL
Call PREMEX([F:BAN]CPY,GTYPGEN,DATMIN) From CPTSUB
Call DEREX ([F:BAN]CPY,GTYPGEN,DATMAX) From CPTSUB
Local Integer OK_REVERSE

Read [BAN]BAN0=[M:DP1]BANK
Trbegin [DAE], [RBK]
 CRITERE = 'LEDTYP=GTYPGEN & CPY=[F:BAN]CPY & ACC=[F:BAN]BANACC & BPR=[F:BAN]BANBPR & CHK<>"" & ([F:BAN]FCY="" | [F:BAN]FCY=FCYLIN)'
 If [M:DP1]DATDEB <> [0/0/0] : CRITERE -= '& CHKDAT>=['+format$(GFMD,[M:DP1]DATDEB)+']' : Endif
 If [M:DP1]DATFIN <> [0/0/0] : CRITERE -= '& CHKDAT<=['+format$(GFMD,[M:DP1]DATFIN)+']' : Endif
 If [M:DP1]CHKDEB <> "" : CRITERE -= '& CHK>="'+[M:DP1]CHKDEB+'"' : Endif
 If [M:DP1]CHKFIN <> "" : CRITERE -= '& CHK<="'+[M:DP1]CHKFIN+'"' : Endif
 Filter [DAE] Where evalue(CRITERE) Order By Key CLE=CHK
 For [DAE] With Nohint
  Readlock [DAE] Curr
  GCLE = num$([F:DAE]ACCNUM)
  If fstat=1
   GOK = -1 : GLOCK="$GACCENTRYD"-GCLE : Break
  Elsif fstat
   GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK : Break
  Elsif [F:DAE]BPR="" | [F:DAE]BPR=[F:BAN]BANBPR

   OK_REVERSE = 1
   If val(CLOSEDPER)=1 & (DATMIN=[0/0/0] | DATMAX=[0/0/0] | [F:DAE]ACCDAT<DATMIN | [F:DAE]ACCDAT>DATMAX)
    OK_REVERSE = 0
   Endif

   If OK_REVERSE
    If OLDCHK <> [F:DAE]CHK
     OLDCHK = [F:DAE]CHK
     If [F:DAE]CHK<>"*"
      Filter [RBK] Where BAN=[M:DP1]BANK & RECTYP=2 & CHK=[F:DAE]CHK
     Else
      Filter [RBK] Where BAN=[M:DP1]BANK & RECTYP=2 & CHK=[F:DAE]CHK & DATCHK=[F:DAE]CHKDAT
     Endif
     For [RBK]RBK1
      Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
      Readlock [RBK]
      GCLE = [F:RBK]BAN-num$([F:RBK]RBKNUM)-num$([F:RBK]RECTYP)-num$([F:RBK]RBKLIN)
      If fstat=1
       GOK = -1 : GLOCK="$RELBANK"-GCLE : Break 2
      Elsif fstat
       GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : Break 2
      Else
       # Relevé
       LIGTRACE = mess(42,117,1)+space$(5)+format$("D:"+GFMDAT,[F:RBK]OPEDAT)+
&                 space$(3)+format$("K:5X",[F:RBK]CHK)
       If ([F:RBK]SNS=1 & val([M:SAI1]SNSBNQ)=1) |
&         ([F:RBK]SNS=-1 & val([M:SAI1]SNSBNQ)=2)
        LIGTRACE += space$(3)+left$(mess(1,610,1),1)+
&              num$(format$("N3:"+[F:TCU]CURFMT1,[F:RBK]AMTCUR))+space$(3)+[F:RBK]DES
       Elsif ([F:RBK]SNS=1 & val([M:SAI1]SNSBNQ)=2)|
&            ([F:RBK]SNS=-1 & val([M:SAI1]SNSBNQ)=1)
        LIGTRACE += space$(3)+left$(mess(2,610,1),1)+
&              num$(format$("N3:"+[F:TCU]CURFMT1,[F:RBK]AMTCUR))+space$(3)+[F:RBK]DES
       Endif
       [F:RBK]CHK = ""
       Rewrite [RBK]
       If fstat
        GOK = 0 : Call FSTA("RBK") From GLOCK : Break 2
       Else  Call ECR_TRACE(LIGTRACE,0) From GESECRAN
       Endif
      Endif
     Next
    Endif

    # Ecriture
    Call LECTURE("TCU",[F:DAE]CUR,"") From CONTOBJ
    LIGTRACE = mess(47,120,1)+space$(3)+format$("D:"+GFMDAT,[F:DAE]ACCDAT)+
&              space$(3)+format$("K:5X",[F:DAE]CHK)
    If [F:DAE]SNS=1
     LIGTRACE += space$(3)+left$(mess(1,610,1),1)+
&           num$(format$("N3:"+[F:TCU]CURFMT1,[F:DAE]AMTCUR))+space$(3)+[F:DAE]DES
    Else
     LIGTRACE += space$(3)+left$(mess(2,610,1),1)+
&           num$(format$("N3:"+[F:TCU]CURFMT1,[F:DAE]AMTCUR))+space$(3)+[F:DAE]DES
    Endif
    [F:DAE]CHK    = ""
    [F:DAE]CHKDAT = [0/0/0]
    Rewrite [DAE]
    If fstat
     GOK = 0 : Call FSTA("DAE") From GLOCK : Break
    Else  Call ECR_TRACE(LIGTRACE,0) From GESECRAN
    Endif
    # GRNA 18/07/2011
    Gosub REVERSE_CHN From CHKLIB
    If GOK<1 : Break : Endif
   Endif
  Endif
 Next

 Filter [DAE]
 Filter [RBK]
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

##################################
# ETIQUETTES DEPOINT0
##################################
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call BANDEF(VALEUR) From SUBCHK
 If VALEUR<>"" :  Raz CRIDAT : Endif #DdM31717
Endif
End

Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
# Contrôle accés à la fonction
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 GMESSAGE = mess(25,120,1)-" "-VALEUR : #Vous n'avez pas accés à la banque
 mkstat = 2
 End
Endif
If VALEUR<>[M]BAN : Raz CRIDAT : Endif #DdM31717
End

Subprog D_CRIDAT(VALEUR)
Variable Date    VALEUR()
If [M]BAN="" : End : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
Local Char CRITDAT(250)
Read [BAN]BAN0 = [M]BAN
If !fstat
 If [F:BAN]FCY<>""
  CRITDAT = "LEDTYP="+num$(GTYPGEN)+" & CPY='"+[F:BAN]CPY+"' & FCYLIN='"+[F:BAN]FCY+"' & ACC='"+[F:BAN]BANACC+"'"
 Else
  CRITDAT = "LEDTYP="+num$(GTYPGEN)+" & CPY='"+[F:BAN]CPY+"' & ACC='"+[F:BAN]BANACC+"'"
 Endif
 If [F:BAN]BANBPR<>""
  CRITDAT += " & BPR='"+[F:BAN]BANBPR+"'"
 Endif
 If [F:BAN]CHKCOD<>""
  CRITDAT += " & CHK='"+[F:BAN]CHKCOD+"'"
 Else
  CRITDAT += " & CHK<>''"
 Endif
 Filter [DAE] Where evalue(CRITDAT) Order By CHKDAT
 Read [DAE] Last
 If !fstat
  [M]CRIDAT = [F:DAE]CHKDAT
  If !GIMPORT : Affzo [M]CRIDAT : Endif
 Endif
 Filter [DAE]
Endif
End

Subprog D_SNSBLC2(VALEUR)
Variable Char    VALEUR()
If [M]SNSBLC=1
 VALEUR = left$(mess(1,610,1),1) : # D
Else
 VALEUR = left$(mess(2,610,1),1) : # C
Endif
End

Subprog D_SNSBLB2(VALEUR)
Variable Char    VALEUR()
If [M]SNSBLB=1
 VALEUR = left$(mess(1,610,1),1) : # D
Else
 VALEUR = left$(mess(2,610,1),1) : # C
Endif
End

Subprog AV_CHX(VALEUR)
Variable Char    VALEUR()
Gosub COULEUR
End

$COULEUR
If [M]RBKNUM(nolign-1)<>"" & [M]CHK(nolign-1) <> ""  # Rouge écriture banque
 Chgstl [M]NBLIG(nolign-1) With "BACKRED"
Endif
If [M]CHK(nolign-1)=""   :                           # Bleu ligne dépointée
 Chgstl [M]NBLIG(nolign-1) With "MTC3"
Endif
Return

Subprog IB_NBLIG
Local Char CLOSEDPER(2)
Local Date DATMIN , DATMAX
Call PARAM ([M]CPY,"CLOSEDPER",CLOSEDPER) From ADOVAL
Call PREMEX([M]CPY,GTYPGEN,DATMIN) From CPTSUB
Call DEREX ([M]CPY,GTYPGEN,DATMAX) From CPTSUB

If nolign>0 & [M]RBKNUM(nolign-1)<>""
 GBOUT2=""
Else
 GBOUT2 = mess(25,110,1)  : # Pièce
Endif
# KC Vinci : Si ACCDAT de la ligne est en période fermée alors ne pas permettre "Sélection"
# Donc Dépointage non autorisée.
If (nolign>0 & [M]CHK(nolign-1)="")|(val(CLOSEDPER)=1 & (DATMIN=[0/0/0] | DATMAX=[0/0/0] |
&[M]ACCDAT(nolign-1)<DATMIN | [M]ACCDAT(nolign-1)>DATMAX))
 GBOUT1=""
Else
 GBOUT1 = mess(18,100,1)  : # Sélection
Endif
End

$AV_B2_NBLIG
GCONSULT = 1
K = instr(1,[M]REFB(nolign-1)," ")
GFLAG   = ""
GSCHEMA = ""
GBIDC1  = left$([M]REFB(nolign-1),K-1)
GBIDC2  = vireblc(mid$([M]REFB(nolign-1),K+1,GLONVCR),2)
Return

$AP_B2_NBLIG
GCONSULT = 0
Return

Subprog B1_NBLIG
If [M]CHK(nolign-1)<>""  : # On ne sélectionne ou désélectionne que les lignes non dépointées
  If [M]CHX(nolign-1) <> ""
    [M]CHX(nolign-1) = ""
  Else
    [M]CHX(nolign-1) = "*"
  Endif
  Affzo [M]CHX(nolign-1)
Endif
mkstat = 4   :# on déclenche l'apres modif
End

Subprog DEPOINT(J)
Value Integer J
Case [M]ACCNUM(J)
 When 0
  Readlock [RBK]RBK0=[M]BAN;[M]RBKNUM(J);2;[M]RBKLIN(J)
  GCLE = [M]BAN-num$([M]RBKNUM(J))-num$(2)-num$([M]RBKLIN(J))
  If fstat=1
   GOK = -1 : GLOCK="$RELBANK"-GCLE : End
  Elsif fstat
   GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : End
  Else
   # Dépointer
   [F:RBK]CHK = ""
   [F:RBK]DATCHK = [0/0/0]
   Rewrite [RBK]
   If fstat
    GOK = 0 : Call FSTA("RBK") From GLOCK : End
   Endif
  Endif
 When Default
  Readlock [DAE]DAE2=[M]ACCNUM(J)
  GCLE = num$([M]ACCNUM(J))
  If fstat=1
   GOK = -1 : GLOCK="$GACCENTRYD"-GCLE : End
  Elsif fstat
   GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK : End
  Else
   # Dépointer
   [F:DAE]CHK    = ""
   [F:DAE]CHKDAT = [0/0/0]
   Rewrite [DAE]
   If fstat
    GOK = 0 : Call FSTA("DAE") From GLOCK : End
   Endif
   # GRNA 18/07/2011
   Gosub REVERSE_CHN From CHKLIB
   If GOK<1 : End : Endif
  Endif
 Endcase
End
