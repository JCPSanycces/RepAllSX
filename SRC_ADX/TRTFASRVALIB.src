#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
# Action métier : "REEVALUER"  Réévaluation Libre d'un bien comptable   #
#                                                                       #
#########################################################################
#
#      FASRVA0  :  Entête  Réévaluation - unitaire         (OAC0)
#      FASRVA   :  Paramètres de réévaluation - unitaire   (FASR)
#      FASRVAM  :  Paramètres de réévaluation - massif     (FASR)
#
#************************************************************************
#    Création : 18.02.2011
#
#************************************************************************
#    Dernières modifications
#    CBO : 23.12.2014   FQ104164  : Erreur evt fiscal valeurs origine
#    MDJ : 26.04.2013   FQ-89419  : Seule la rééval du plan comptable doit avoir une effet sur les plans Fiscal/Minimum
#    MDJ : 24.12.2012   FQ-84817  : Alimentation incorrecte du DPM dans l'evt de rééval du plan fiscal
#    MDJ : 21.12.2012   FQ-84817  : le DPRCUMFLG ne doit jamais être déforcé
#    MWA : 16.04.2012   FQ-81475  : Valeur marché ne doit pas être remise à 0.
#    MDJ : 20.02.2011   FQ-80075  : Evénements générés à tort quand RVAAMT=0
#    MDJ : 08.11.2011   FQ-77221  : Massif direct : suppression contrôle NBV > RSDVAL
#    MDJ : 29.07.2011   FQ-75459 : Massif :  pb en maj des  plans FISCAL et MINIMUM + ctrl G_RVALIB
#    MDJ : 06.01.2011   FQ-67995b : Réévaluation libre comptable pour sociétés françaises (suite)
#    MDJ : 18.02.2011   FQ-67995  : Réévaluation libre comptable pour sociétés françaises
#************************************************************************
#====================================================
#
$ANNU_REEVAL_DIRT_LIB

#Infbox "TRTFASRVA - ANNU_REEVAL_DIRT_LIB"
#CHECK FILE_DECLARE EFASREEVAL [EFS]
  LCDINT= "FASRVA"+num$([M:FASR]DPRPLN)

  Filter [DEPO] Where (AASREF=[F:MAS1]AASREF & DPRPLN = [M:FASR]DPRPLN)
  Read [DEPO]DEP0 =[F:MAS1]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  #-1 ---------------------------
  If !(fstat)
    LRVADAT = [F:DEPO]RVADAT
    [F:DEPW]BSEVAL = [F:DEPO]BSEVAL
    # Ajout lecture événement de réévaluation pour récupérer
    # les anciennes valeurs du  bien (avant réévaluation)
    Filter [EFS] Where ( REF=[F:MAS1]AASREF and DPRPLN=[M:FASR]DPRPLN )
    Read [EFS]Last
    If !(fstat)
      [F:DEPW]DPM         = [F:EFS]DPM
      [F:DEPW]DPMT        = [F:EFS]DPM
      [F:DEPW]DPRBAS      = [F:EFS]DPRBASO
      [F:DEPW]DPRCUM      = [F:EFS]DPRCUMO
      [F:DEPW]DPRCUMFLG   = [F:EFS]DPRCUMFLGO
      [F:DEPW]PERCLOCUM   = [F:EFS]PERCLOCUMO
      [F:DEPW]PERCLOEXC   = [F:EFS]PERCLOEXCO
      [F:DEPW]EXECLOCUMT  = [F:EFS]EXECLOCUMO
      [F:DEPW]PERCLOCUMT  = [F:EFS]PERCLOCUMT
      [F:DEPW]PERCLOEXCT  = [F:EFS]PERCLOEXCT
      GNBVO_C             = [F:EFS]NBVO
      GNBVO               = [F:EFS]NBVO
      [F:DEPW]NBV         = [F:EFS]NBVO
      [F:DEPW]NBVT        = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
      GNBVTO              = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
      [F:DEPW]EXETRFCUM   = [F:EFS]EXETRFCUMO
      [F:DEPW]EXEIMLCUM   = [F:EFS]EXEIMLCUMO
      [F:DEPW]PERIMLCUM   = [F:EFS]PERIMLCUMO
      [F:DEPW]EXERVECUM   = [F:EFS]EXERVECUMO
      [F:DEPW]PERRVECUM   = [F:EFS]PERRVECUMO
      [F:DEPW]IMLBLC      = [F:EFS]EXEIMLCUMO + [F:EFS]PERIMLCUMO
&                         - [F:EFS]EXERVECUMO - [F:EFS]PERRVECUMO - [F:EFS]EXETRFCUMO
      [F:DEPW]IMLRVELIM   = [F:EFS]IMLRVELIM
      [F:DEPW]RVACRB      = 0
      [F:DEPW]LEGCUM     += [F:EFS]RVADERRVE #Fq-67995b
    Endif
    Filter [EFS]
    [F:DEPW]RVADAT     = [0/0/0]
    [F:DEPW]RVAAMT     = 0
    [F:DEPW]RVATIADAT  = 0
    [F:DEPW]RVATYP     = 0
    [F:DEPW]RVACOE     = 0
    [F:DEPW]RVACOEREF  = ""
  Endif
  #-1 ---------------------------
  Filter [DEPO]

  Read [DEPF]DEP0 =[F:MAS1]AASREF; G301FIS;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  #-1 ---------------------------
  If !(fstat)
    LRVADAT = [F:DEPO]RVADAT
    Filter [EFS] Where ( REF=[F:MAS1]AASREF and DPRPLN=G301FIS)
    Read [EFS]Last
    Filter [DEPF]
    If !(fstat)
      [F:DEPF]DPM         = [F:EFS]DPM
      [F:DEPF]DPMT        = [F:EFS]DPM
      [F:DEPF]DPRBAS      = [F:EFS]DPRBASO
      [F:DEPF]DPRCUM      = [F:EFS]DPRCUMO
      [F:DEPF]DPRCUMFLG   = [F:EFS]DPRCUMFLGO
      [F:DEPF]PERCLOCUM   = [F:EFS]PERCLOCUMO
      [F:DEPF]PERCLOEXC   = [F:EFS]PERCLOEXCO
      [F:DEPF]EXECLOCUMT  = [F:EFS]EXECLOCUMO
      [F:DEPF]PERCLOCUMT  = [F:EFS]PERCLOCUMT
      [F:DEPF]PERCLOEXCT  = [F:EFS]PERCLOEXCT
      GNBVO_C             = [F:EFS]NBVO
      GNBVO               = [F:EFS]NBVO
      [F:DEPF]NBV         = [F:EFS]NBVO
      [F:DEPF]NBVT        = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
      GNBVTO              = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
      [F:DEPF]EXETRFCUM   = [F:EFS]EXETRFCUMO
      [F:DEPF]EXEIMLCUM   = [F:EFS]EXEIMLCUMO
      [F:DEPF]PERIMLCUM   = [F:EFS]PERIMLCUMO
      [F:DEPF]EXERVECUM   = [F:EFS]EXERVECUMO
      [F:DEPF]PERRVECUM   = [F:EFS]PERRVECUMO
      [F:DEPF]IMLBLC      = [F:EFS]EXEIMLCUMO + [F:EFS]PERIMLCUMO
&                         - [F:EFS]EXERVECUMO - [F:EFS]PERRVECUMO - [F:EFS]EXETRFCUMO
      [F:DEPF]IMLRVELIM   = [F:EFS]IMLRVELIM
      [F:DEPF]RVACRB      = 0
    Endif
    Filter [EFS]
    [F:DEPF]RVADAT     = [0/0/0]
    [F:DEPF]RVATIADAT  = 0
    [F:DEPF]RVAAMT     = 0
    [F:DEPF]RVATYP     = 0
    [F:DEPF]RVACOE     = 0
    [F:DEPF]RVACOEREF  = ""
  #-- Maj plan Fiscal ----------------
  [F:DEPF]DEPSTA = GVML_SCNOCAL
  Rewrite[DEPF]
  If (fstat)
    RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
    GOK=0 : Return
  Endif
 Endif

  Read [DEPM]DEP0 =[F:MAS1]AASREF; G301MIN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  #-1 ---------------------------
  If !(fstat)
    LRVADAT = [F:DEPO]RVADAT
    [F:DEPM]BSEVAL = [F:DEPO]BSEVAL
    Filter [EFS] Where ( REF=[F:MAS1]AASREF and DPRPLN=G301MIN)
      Read [EFS]Last
      If !(fstat)
        [F:DEPM]DPM         = [F:EFS]DPM
        [F:DEPM]DPMT        = [F:EFS]DPM
        [F:DEPM]DPRBAS      = [F:EFS]DPRBASO
        [F:DEPM]DPRCUM      = [F:EFS]DPRCUMO
        [F:DEPM]DPRCUMFLG   = [F:EFS]DPRCUMFLGO
        [F:DEPM]PERCLOCUM   = [F:EFS]PERCLOCUMO
        [F:DEPM]PERCLOEXC   = [F:EFS]PERCLOEXCO
        [F:DEPM]EXECLOCUMT  = [F:EFS]EXECLOCUMO
        [F:DEPM]PERCLOCUMT  = [F:EFS]PERCLOCUMT
        [F:DEPM]PERCLOEXCT  = [F:EFS]PERCLOEXCT
        GNBVO_C             = [F:EFS]NBVO
        GNBVO               = [F:EFS]NBVO
        [F:DEPM]NBV         = [F:EFS]NBVO
        [F:DEPM]NBVT        = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        GNBVTO              = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        [F:DEPM]EXETRFCUM   = [F:EFS]EXETRFCUMO
        [F:DEPM]EXEIMLCUM   = [F:EFS]EXEIMLCUMO
        [F:DEPM]PERIMLCUM   = [F:EFS]PERIMLCUMO
        [F:DEPM]EXERVECUM   = [F:EFS]EXERVECUMO
        [F:DEPM]PERRVECUM   = [F:EFS]PERRVECUMO
        [F:DEPM]IMLBLC      = [F:EFS]EXEIMLCUMO + [F:EFS]PERIMLCUMO
&                           - [F:EFS]EXERVECUMO - [F:EFS]PERRVECUMO - [F:EFS]EXETRFCUMO
        [F:DEPM]IMLRVELIM   = [F:EFS]IMLRVELIM
        [F:DEPM]RVACRB      = 0
      Endif
    Filter [EFS]
    [F:DEPM]RVADAT     = [0/0/0]
    [F:DEPM]RVATIADAT  = 0
    [F:DEPM]RVAAMT     = 0
    [F:DEPM]RVATYP     = 0
    [F:DEPM]RVACOE     = 0
    [F:DEPM]RVACOEREF  = ""
  #--- Maj Plan Minimum ---------------
  [F:DEPM]DEPSTA = GVML_SCNOCAL
  Rewrite[DEPM]
  If (fstat)
    RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
    GOK=0 : Return
  Endif
  Endif
  If GOK : LOK = G_OUI : Endif

  If ( FLGDET = G_OUI )
    Call SEP_COMPTE_RENDU([F:MAS1]CPY)  From TRTFASRVA
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,[F:MAS1]AASREF+"/"+[F:MAS1]AASDES1,0,1) From TRACEABX3
    Gosub ECR_DETAIL_OLD From TRTFASRVA
  Endif

Return
#=================================================================
$REEVAL_DIRT_LIB
Local Decimal COEFF, LCOEFF
Local Decimal WNBV, WNBVO

  RMES = ""
  LOK = G_OUI
  #- 1 -----------------------------------
  If  ([M:FASR]RVATYP = GVML_MODCOE or [M:FASR]RVATYP = GVML_MODIND)
    #=====
    # Réévaluation par COEFFICIENT ou par INDICE
    # On réévalue la valeur nette et la base
    #=====
    If ( [M:FASR]RVACOEREF = "" )
      If ( [M:FASR]RVACOE <= 0 )
        #  Vous devez saisir le coefficient à appliquer pour chaque bien traité
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(136,GML_MSGFAS,1)) From TRCPROCOM
        LOK = G_NON :  GOK=0  : Return
      Else
        LCOEFF = [M:FASR]RVACOE
      Endif
    Else
      Call RECH_RVACOE([M:FASR]RVACOEREF, COEFF) From TRTFASRVA
      LCOEFF = COEFF
    Endif
    Call CAL_VALEUR_NETTE ( "RDE", [F:DEP]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
    # si le coefficient est > 1 on calcule les nouvelles valeurs
    # après réévaluation, sinon, on ne fait rien
    #- 2 -----------------------------------
    If ( LCOEFF > 0 )
      [F:DEPW]RVATIADAT  =  [M:FASR]RVATIADAT
      [F:DEPW]RVATYP     =  [M:FASR]RVATYP
      [F:DEPW]RVADAT     =  [M:FASR]RVADAT
      [F:DEPW]RVACOEREF  =  [M:FASR]RVACOEREF
      [F:DEPW]RVACOE     =  LCOEFF
      [F:DEPW]PERREFCLC  =  [F:DEP]FIYSTRDAT
      [F:DEPW]PERREFCLCT =  [F:DEP]FIYSTRDAT
      [F:DEPW]NBV        =  GNBVO_C   *  LCOEFF
      Call GET_MNT_ARRONDI ( [F:DEPW]NBV,     [M:FASR]CUR,  [F:DEPW]NBV )      From GLOBIENS
      [F:DEPW]RVAAMT   = ( [F:DEPW]NBV  - GNBVO_C )
      [F:DEPW]DPRBAS   = ( [F:DEP]DPRBAS   +   [F:DEPW]RVAAMT )
      GRVADERRVE       =  [F:DEP]LEGCUM   -  [F:DEP]LEGRVECUM
      [F:DEPW]LEGCUM  -=  GRVADERRVE  #Fq-67995b

      #------------- Mise à jour des plans Fiscal et Minimum
      #Fq-89419----- si c'est le plan comptable qui est réévalué
      If [M:FASR]DPRPLN = G301CPT #Fq-89419
      Read [DEPF]DEP0 =[F:DEP]AASREF;G301FIS;[F:DEP]FIYENDDAT;[F:DEP]PERENDDAT
      If fstat=0
         # FQ104164
        [F:DEPFO] = [F:DEPF]

         Call CAL_VALEUR_NETTE ( "RDE", [F:DEPF]DPRBAS, 2, 0, GNBVO_F  ) From GLOBB4
        #*Fq-84817
        GDPMO_F= [F:DEPF]DPM
        If ( [F:DEPF]LSTCLODAT <> [0/0/0] or ([F:DEPF]LSTCLODAT  = [0/0/0] and [F:DEPF]STRDPRDAT < [F:DEPF]FIYSTRDAT) )
          Local Integer LPRATYP
          Call GET_DPM_RSD([F:MAS1]CPY, [F:DEPF]DPM, [F:DEPF]DPM, LPRATYP) From TRTFAS
          [F:DEPF]DPMT    = [F:DEPF]DPM
          If LPRATYP > 0
             [F:DEPF]PRATYP  = LPRATYP
           Endif
           [F:DEPF]DPRCUMFLG    =   G_OUI
        Endif #*Fq-84817
         [F:DEPF]RVATIADAT    =  [M:FASR]RVATIADAT
         [F:DEPF]RVATYP       =  [M:FASR]RVATYP
         [F:DEPF]RVADAT       =  [M:FASR]RVADAT
         [F:DEPF]PERREFCLC    =  [F:DEP]FIYSTRDAT
         [F:DEPF]PERREFCLCT   =  [F:DEP]FIYSTRDAT
         #Fq-67995b [F:DEPF]RVADERRVE    =  [F:DEP]LEGCUM   -  [F:DEP]LEGRVECUM
         GDPRCUMO = [F:DEPF]DPRCUM
         [F:DEPF]DPRCUM      -=   GRVADERRVE    #Fq-67995b
         #*Fq-84817 [F:DEPF]DPRCUMFLG    =   G_OUI         #Fq-67995b
         [F:DEPF]EXECLOCUMT  -=   GRVADERRVE    #Fq-67995b
         [F:DEPF]DPRBAS       =  [F:DEPF]DPRBAS  +  [F:DEPW]RVAAMT
         [F:DEPF]RVAAMT       =  [F:DEPW]RVAAMT
      #--FQ-75459 Maj plan Fiscal ----------------
       [F:DEPF]DEPSTA = GVML_SCNOCAL
      Rewrite[DEPF]
      If (fstat)
         RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
         GOK=0 : Return
       Endif
      Endif
      Read [DEPM]DEP0 =[F:DEP]AASREF;G301MIN;[F:DEP]FIYENDDAT;[F:DEP]PERENDDAT
      If fstat=0
         # FQ104164
         [F:DEPMO] = [F:DEPM]

        Call CAL_VALEUR_NETTE ( "RDE", [F:DEPM]DPRBAS, 2, 0, GNBVO_M  ) From GLOBB4
        GDPMO_M = [F:DEPM]DPM
        If ( [F:DEPM]LSTCLODAT <> [0/0/0] or ([F:DEPM]LSTCLODAT  = [0/0/0] and [F:DEPM]STRDPRDAT < [F:DEPM]FIYSTRDAT) )
          Local Integer LPRATYP
          Call GET_DPM_RSD([F:MAS1]CPY, [F:DEPM]DPM, [F:DEPM]DPM, LPRATYP) From TRTFAS
          [F:DEPM]DPMT    = [F:DEPM]DPM
          If LPRATYP > 0
             [F:DEPM]PRATYP  = LPRATYP
           Endif
        Endif
        [F:DEPM]RVATIADAT    =  [M:FASR]RVATIADAT
        [F:DEPM]RVATYP       =  [M:FASR]RVATYP
        [F:DEPM]RVADAT       =  [M:FASR]RVADAT
        [F:DEPM]PERREFCLC    =  [F:DEP]FIYSTRDAT
        [F:DEPM]PERREFCLCT   =  [F:DEP]FIYSTRDAT
        [F:DEPM]DPRBAS       =  [F:DEPM]DPRBAS  +  [F:DEPW]RVAAMT
        [F:DEPM]RVAAMT       =  [F:DEPW]RVAAMT
        #--FQ-75459--- Maj Plan Minimum ---------------
        [F:DEPM]DEPSTA = GVML_SCNOCAL
        Rewrite[DEPM]
        If (fstat)
           RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
           GOK=0 : Return
         Endif
      Endif
      Endif  #FQ-89419
      #Fq-77221 If ( [F:DEPW]RVAAMT = 0 or [F:DEPW]NBV < [F:DEP]RSDVAL )
      If ( [F:DEPW]RVAAMT = 0 )
         # "Montant réévaluation invalide"
         Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(400,GML_MSGFAS,1)) From TRCPROCOM
         LOK=G_NON
         #Fq-80075 Return
      Endif
    #- 2 -----------------------------------
    Else
      # "Coefficient invalide"
       Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(173,GML_MSGFAS,-1)) From TRCPROCOM
      LOK=G_NON
       #Fq-80075 Return
    Endif
    #- 2 -----------------------------------
  Endif
  #- 1 -----------------------------------
  If (LOK = G_OUI and FLGDET = G_OUI)
    Call SEP_COMPTE_RENDU([F:MAS1]CPY)  From TRTFASRVA
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,[F:MAS1]AASREF+"/"+[F:MAS1]AASDES1,0,1) From TRACEABX3
    Gosub ECR_DETAIL_OLD From TRTFASRVA
  Endif

Return
#=================================================================
$CALC_RVACOE_LIB
Local Decimal LRVACOE
Local Char    CHAMP, LRVACOEREF
Local Char    LMESSAGE
Local Integer LCDRET
# infbox "TRTFASRVA -CALC_RVACOE_LIB"

 #-1 -----------------------------
 If ( ACTTYPGES = GTAMUNI )
   LRVACOE    = [M:FASR]RVACOE
   LRVACOEREF = [M:FASR]RVACOEREF
 #-1 -----------------------------
 Else
   #-2 -----------------------------
   If PINDICE
     LRVACOE = PVALEUR
   #-2 -----------------------------
   Else
      If ( [M:FASR]RVACOE > 1 )
        LRVACOE = [M:FASR]RVACOE
      Else
        LRVACOE = evalue(PCLASSE+"RVACOE")
      Endif
      LRVACOEREF = [M:FASR]RVACOEREF
    Endif
    #-2 -----------------------------
  Endif
  #-1 -----------------------------

  If ( PINDICE )
    # si on calcule les nouvelles valeurs à partir d'une ligne de l'écran de contrôle
       Gosub CALC_RVACOE_MFS0_LIB
  Else
    # si l'on calcule les nouvelles valeurs au chargement de l'Ã©cran de contrÃ´le
       Gosub CALC_RVACOE_TMP1_LIB
  Endif

Return
#=================================================================
$CALC_RVACOE_MFS0_LIB
# infbox "TRTFASRVA -CALC_RVACOE_MFS0_LIB"

  [M:MFS0]FLGERR(PINDICE-1)      =  G_NON
  [M:MFS0]FLGMOD(PINDICE-1)      =  G_OUI
  [M:MFS0]MSGERR(PINDICE-1)      =  ""

  [M:MFS0]RVATIADAT(PINDICE-1)   = [M:FASR]RVATIADAT
  [M:MFS0]RVATYP(PINDICE-1)      = [M:FASR]RVATYP
  [M:MFS0]RVADAT(PINDICE-1)      = [M:FASR]RVADAT
  [M:MFS0]RVACOEREF(PINDICE-1)   = LRVACOEREF
  [M:MFS0]RVACOE(PINDICE-1)      = LRVACOE

  #-1 ---------------
  If ([M:MFS0]RVACOE(PINDICE-1) <> 0)
    # << Coefficient > 1 >>
    [M:MFS0]NBV(PINDICE-1)        =  [M:MFS0]NBVO(PINDICE-1)   *  LRVACOE
    [M:MFS0]PERREFCLC(PINDICE-1)  =  [M:FASR]FIYSTRDAT
    [M:MFS0]PERREFCLCT(PINDICE-1) =  [M:FASR]FIYSTRDAT
    #FQ-81475 -------------------
    #[M:MFS0]NSPVAL(PINDICE-1)      =  0
    #FQ-66648 ----------------
    Call GET_MNT_ARRONDI ([M:MFS0]DPRBAS(PINDICE-1),     [M:FASR]CUR, [M:MFS0]DPRBAS(PINDICE-1))     From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]NBV(PINDICE-1),        [M:FASR]CUR,[M:MFS0]NBV(PINDICE-1))         From GLOBIENS
    [M:MFS0]RVAAMT(PINDICE-1)      =  [M:MFS0]NBV(PINDICE-1)-[M:MFS0]NBVO(PINDICE-1)
    Call GET_MNT_ARRONDI ([M:MFS0]RVAAMT(PINDICE-1),       [M:FASR]CUR,[M:MFS0]RVAAMT(PINDICE-1))         From GLOBIENS
    [M:MFS0]DPRBAS(PINDICE-1)      =  [M:MFS0]DPRBASO(PINDICE-1)+[M:MFS0]RVAAMT(PINDICE-1)
    GRVADERRVE       =  [M:MFS0]LEGCUM(PINDICE-1)  -  [M:MFS0]LEGRVECUM(PINDICE-1)
    [M:MFS0]LEGCUM(PINDICE-1) -= GRVADERRVE  #Fq-67995b
    # <<< Réévaluation >>>>
    If ([M:MFS0]RVAAMT(PINDICE-1) = 0)
      # "Montant réévaluation invalide"
      [M:MFS0]MSGERR (PINDICE-1) =  mess(400,GML_MSGFAS,1)
      [M:MFS0]FLGERR (PINDICE-1) =  G_OUI
      [M:MFS0]FLGMOD (PINDICE-1) =  G_NON
    Endif

  #-1 ---------------
  Else
    # << Coefficient = 0 >>
    # "Coefficient invalide"
    [M:MFS0]MSGERR (PINDICE-1)  =  mess(173,GML_MSGFAS,1)
    [M:MFS0]FLGERR (PINDICE-1)  =  G_OUI
    [M:MFS0]FLGMOD (PINDICE-1)  =  G_OUI
  Endif
  #-1 ---------------

  If  ([M:MFS0]FLGERR(PINDICE-1) = G_OUI and [M:MFS0]FLGMOD(PINDICE-1) <> G_OUI)
    [M:MFS0]RVACOEREF(PINDICE-1) =  ""
    [M:MFS0]RVACOE(PINDICE-1)    =  1
    [M:MFS0]RVATIADAT(PINDICE-1) =  0
    [M:MFS0]RVADAT(PINDICE-1)    =  [0/0/0]
    [M:MFS0]RVATYP(PINDICE-1)    =  0
    [M:MFS0]RVAAMT(PINDICE-1)    =  0
  Endif

Return
#=================================================================
$CALC_RVACOE_TMP1_LIB
# infbox "TRTFASRVA -CALC_RVACOE_TMP1_LIB"

  CHAMP=PCLASSE+"FLGERR"          : Assign CHAMP With G_NON
  CHAMP=PCLASSE+"FLGMOD"          : Assign CHAMP With G_OUI
  CHAMP=PCLASSE+"MSGERR"          : Assign CHAMP With ""

  CHAMP=PCLASSE+"RVATIADAT"       : Assign CHAMP With [M:FASR]RVATIADAT
  CHAMP=PCLASSE+"RVATYP"          : Assign CHAMP With [M:FASR]RVATYP
  CHAMP=PCLASSE+"RVADAT"          : Assign CHAMP With [M:FASR]RVADAT
  CHAMP=PCLASSE+"RVACOEREF"       : Assign CHAMP With LRVACOEREF
  CHAMP=PCLASSE+"RVACOE"          : Assign CHAMP With LRVACOE

  #-1 ------------------------------------
  If (evalue (PCLASSE+"RVACOE") > 0)
    # << Coefficent <> 0 >>
    CHAMP=PCLASSE+"NBV"             : Assign CHAMP With evalue (PCLASSE+"NBVO*LRVACOE")
    CHAMP=PCLASSE+"NBVT"            : Assign CHAMP With evalue (PCLASSE+"NBVTO*LRVACOE")
    CHAMP=PCLASSE+"PERREFCLC"       : Assign CHAMP With [M:FASR]FIYSTRDAT
    CHAMP=PCLASSE+"PERREFCLCT"      : Assign CHAMP With [M:FASR]FIYSTRDAT
    Case PCLASSE
    When "[F:TMP1]"
       Call GET_MNT_ARRONDI ([F:TMP1]NBV,   [M:FASR]CUR, [F:TMP1]NBV )      From GLOBIENS
       Call GET_MNT_ARRONDI ([F:TMP1]NBVT,  [M:FASR]CUR, [F:TMP1]NBVT )      From GLOBIENS
    When "[M:MFS0]"
        Call GET_MNT_ARRONDI ([M:MFS0]NBV,   [M:FASR]CUR, [M:MFS0]NBV )      From GLOBIENS
        Call GET_MNT_ARRONDI ([M:MFS0]NBVT,  [M:FASR]CUR, [M:MFS0]NBVT )      From GLOBIENS
    Endcase
    # FQ-81475 -------------
    # CHAMP=PCLASSE+"NSPVAL"          : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVAAMT"          : Assign CHAMP With evalue (PCLASSE+"NBV - "+PCLASSE+"NBVO")
    CHAMP=PCLASSE+"DPRBAS"          : Assign CHAMP With evalue (PCLASSE+"DPRBASO + "+PCLASSE+"RVAAMT")
    # << Réévaluation >>
    If (evalue (PCLASSE+"RVAAMT") = 0)
        # Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_NON
    Endif
  #-1 ------------------------------------
  Else
    # <<< Coefficent = 0 >>>
    # Coefficient invalide
    CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(173,GML_MSGFAS,1)
    CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_OUI
  Endif
  #-1 ------------------------------------
  If  ( evalue (PCLASSE+"FLGERR") = G_OUI and evalue (PCLASSE+"FLGMOD") <> G_OUI )
    CHAMP=PCLASSE+"RVACOEREF"     : Assign CHAMP With ""
    CHAMP=PCLASSE+"RVACOE"        : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVADAT"        : Assign CHAMP With [0/0/0]
    CHAMP=PCLASSE+"RVATYP"        : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVATIADAT"     : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVAAMT"        : Assign CHAMP With 0
  Endif

Return
#=================================================================
$CALC_RVAVMA_LIB
Local Decimal LNSPVAL
Local Integer LRVATYP
Local Char    LMESSAGE
Local Integer LCDRET

  #-1 --------------------------
  If ( ACTTYPGES = GTAMUNI )
    LNSPVAL = [M:FASR]NSPVAL
  Elsif (PINDICE)
    LNSPVAL = PVALEUR
  Else
    LNSPVAL = evalue(PCLASSE+"NSPVAL")
  Endif

  #-1 --------------------------
  # si on calcule les nouvelles valeurs à partir d'une ligne de l'écran de contrôle
  #-1 --------------------------
  If ( PINDICE )
    CHAMP=PCLASSE+"FLGERR(PINDICE-1)"       : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD(PINDICE-1)"       : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR (PINDICE-1)"      : Assign CHAMP With ""
    #-2 ----------------------
    #Fq-64311  If  ( LNSPVAL <= evalue(PCLASSE+"NBVO(PINDICE-1)") )
    If  ( LNSPVAL = evalue(PCLASSE+"NBVO(PINDICE-1)") )
      # "Valeur marché invalide"
      CHAMP=PCLASSE+"MSGERR (PINDICE-1)"    : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR (PINDICE-1)"    : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"    : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      #==================================
      # Réévaluation libre valeur MARCHE
      #==================================
      CHAMP=PCLASSE+"RVATIADAT(PINDICE-1)"    : Assign CHAMP With  GVML_ERDBPE
      CHAMP=PCLASSE+"RVATYP(PINDICE-1)"       : Assign CHAMP With  GVML_MODVMA
      CHAMP=PCLASSE+"RVADAT(PINDICE-1)"       : Assign CHAMP With  evalue (PCLASSE+"RVADAT(PINDICE-1)")
      CHAMP=PCLASSE+"RVACOE(PINDICE-1)"       : Assign CHAMP With 1
      CHAMP=PCLASSE+"RVACOEREF(PINDICE-1)"    : Assign CHAMP With ""

      CHAMP=PCLASSE+"PERREFCLC(PINDICE-1)"    : Assign CHAMP With [M:FASR]FIYSTRDAT
      CHAMP=PCLASSE+"PERREFCLCT(PINDICE-1)"   : Assign CHAMP With [M:FASR]FIYSTRDAT

      CHAMP=PCLASSE+"NBV(PINDICE-1)"         : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"NBVT(PINDICE-1)"        : Assign CHAMP With LNSPVAL
      #Fq-67995b CHAMP=PCLASSE+"PERCLOCUM(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXC(PINDICE-1)"   : Assign CHAMP With 0
      #Fq-67995b CHAMP=PCLASSE+"PERCLOCUMT(PINDICE-1)"  : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXCT(PINDICE-1)"  : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERIMLCUM(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERRVECUM(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"NSPVAL(PINDICE-1)"      : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"RVAAMT(PINDICE-1)"      : Assign CHAMP With LNSPVAL - evalue(PCLASSE+"NBVO(PINDICE-1)" )
      CHAMP=PCLASSE+"DPRBAS(PINDICE-1)"      : Assign CHAMP With evalue (PCLASSE+"DPRBASO(PINDICE-1)+"+PCLASSE+"RVAAMT(PINDICE-1)")
      If (evalue(PCLASSE+"RVAAMT(PINDICE-1)") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR (PINDICE-1)"   : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR (PINDICE-1)"   : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"   : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------
  #-1 --------------------------
  Else
    CHAMP=PCLASSE+"FLGERR"                  : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD"                  : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR"                  : Assign CHAMP With ""
    CHAMP=PCLASSE+"RVATIADAT"               : Assign CHAMP With  [M:FASR]RVATIADAT
    CHAMP=PCLASSE+"RVATYP"                  : Assign CHAMP With  GVML_MODVMA
    CHAMP=PCLASSE+"RVADAT"                  : Assign CHAMP With  [M:FASR]RVADAT
    CHAMP=PCLASSE+"RVACOE"                  : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVACOEREF"               : Assign CHAMP With ""
    If ( evalue (PCLASSE+"RVATIADAT") = GVML_ERDBEX )
      CHAMP=PCLASSE+"PERREFCLC"               : Assign CHAMP With [M:FASR]FIYSTRDAT
      CHAMP=PCLASSE+"PERREFCLCT"              : Assign CHAMP With [M:FASR]FIYSTRDAT
    Else
      CHAMP=PCLASSE+"PERREFCLC"               : Assign CHAMP With [M:FASR]PERSTRDAT
      CHAMP=PCLASSE+"PERREFCLCT"              : Assign CHAMP With [M:FASR]PERSTRDAT
    Endif
    #-2 ----------------------
    #Fq-64311  If ( LNSPVAL <= evalue(PCLASSE+"NBVO") )
    If  (LNSPVAL = evalue(PCLASSE+"NBVO"))
      # Valeur marché invalide
      CHAMP=PCLASSE+"MSGERR"            : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR"            : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD"            : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      CHAMP=PCLASSE+"NBV"                     : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"NBVT"                    : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"PERRVECUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"NSPVAL"                  : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"RVAAMT"                  : Assign CHAMP With LNSPVAL - evalue(PCLASSE+"NBVO")
      CHAMP=PCLASSE+"DPRBAS"                  : Assign CHAMP With evalue (PCLASSE+"DPRBASO + "+PCLASSE+"RVAAMT")
      If (evalue(PCLASSE+"RVAAMT") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"    : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"    : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"    : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------
  Endif
  #-1 ---------------------

Return
#====================================================
# Chargement table temporaire TMPMASFAS [F:TMP1]
# avec infos du bien comptable [F:MAS1]
#====================================================
$ALIM_TMP1_LIB
#Infbox "TRTFASRVA -ALIM_TMP1_LIB"

  If [M:FASR]CCLRVAFLG <> G_OUI
      GRVADERRVE = [F:DEP]LEGCUM - [F:DEP]LEGRVECUM
  Endif

  If  [F:TMP1]DPRPLN=G301CPT
     # Lecture DEPREC Fiscal pour l'exercice et la période courante
     Filter [DEPF] Where(AASREF=[F:MAS1]AASREF & DPRPLN=G301FIS & FIYENDDAT=[M:FASR]FIYENDDAT
&            & PERENDDAT=[M:FASR]PERENDDAT )
     Read[DEPF] First
     Filter [DEPF]
     If fstat = 0
         # FQ104164
         [F:DEPFO] = [F:DEPF]

         Gosub ALIM_TMP1_FIS
     Endif
     # Lecture DEPREC Minimum pour l'exercice et la période courante
     Filter [DEPM] Where(AASREF=[F:MAS1]AASREF & DPRPLN=G301MIN & FIYENDDAT=[M:FASR]FIYENDDAT
&            & PERENDDAT=[M:FASR]PERENDDAT )
     Read[DEPM] First
     Filter [DEPM]
     If fstat = 0
        # FQ104164
        [F:DEPMO] = [F:DEPM]

        Gosub ALIM_TMP1_MIN
     Endif
  Endif

Return
#=================================================================
$ALIM_TMP1_FIS
#====================================================
# Chargement table temporaire TMPMASFAS [F:TMP1]
# avec infos du bien comptable [F:MAS1]
# et du plan d'amortissement Fiscal [F:DEPF]
#====================================================
Global Char    GDPMO_F
Global Decimal GNSPVALO_F
Global Decimal GDPRBASO_F
Global Decimal GNBVO, GNBVO_F
Global Decimal GNBVTO, GNBVTO_F
#Infbox "TRTFASRVA -ALIM_TMP1_FIS"

  Call CAL_VALEUR_NETTE ( "RDE", [F:DEPF]DPRBAS, 2, 0, GNBVO  ) From GLOBB4
  Call CAL_VALEUR_NETTE ( "TDE", [F:DEPF]DPRBAS, 2, 0, GNBVTO ) From GLOBB4

  GDPMO_F      = [F:DEPF]DPM
  GNSPVALO_F   = [F:DEPF]NSPVAL
  GDPRBASO_F   = [F:DEPF]DPRBAS
  GCUMFLGO_F   = [F:DEPF]DPRCUMFLG
  GNBVO_F      = GNBVO
  GNBVTO_F     = GNBVTO

Return
#=================================================================
$ALIM_TMP1_MIN
#====================================================
# Chargement table temporaire TMPMASFAS [F:TMP1]
# avec infos du bien comptable [F:MAS1]
# et du plan d'amortissement Fiscal [F:DEPM]
#====================================================
#Infbox "TRTFASRVA -ALIM_TMP1_MIN"
Global Decimal GNSPVALO_M
Global Decimal GDPRBASO_M
Global Decimal GNBVO, GNBVO_M
Global Decimal GNBVTO, GNBVTO_M

 Call CAL_VALEUR_NETTE ( "RDE", [F:DEPM]DPRBAS, 2, 0, GNBVO  ) From GLOBB4
 Call CAL_VALEUR_NETTE ( "TDE", [F:DEPM]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
  GDPMO_M = [F:DEPM]DPM
  GNSPVALO_M   = [F:DEPM]NSPVAL
  GDPRBASO_M   = [F:DEPM]DPRBAS
  GNBVO_M      = GNBVO
  GNBVTO_M     = GNBVTO

Return
#=================================================================
$ALIM_MASK_LIB

  # Affectation des champs du plan  du bien courant
  I_FIS =   find(G301FIS,[M:FAS3]DPRPLN)
  I_MIN =   find(G301MIN,[M:FAS3]DPRPLN)
  If ( [M:FASR]CCLRVAFLG <> G_OUI )
     #*Fq-89419 If I_FIS > 0
     If ( G_RVALIB = G_OUI ) and ( [M:FASR]DPRPLN=G301CPT ) and ( I_FIS > 0 )
        [M:FAS3]NSPVAL(I_FIS-1)       = [F:TMP1]NSPVAL
        [M:FAS3]DPRBAS(I_FIS-1)       = [M:FAS3]DPRBAS(I_FIS-1) + [F:TMP1]RVAAMT #- GRVADERRVE
        [M:FAS3]RVATIADAT(I_FIS-1)    = 0
        [M:FAS3]PERREFCLC(I_FIS-1)    = [F:TMP1]PERREFCLC
        [M:FAS3]PERREFCLCT(I_FIS-1)   = [F:TMP1]PERREFCLCT
        [M:FAS3]RVADAT(I_FIS-1)       = [F:TMP1]RVADAT
        [M:FAS3]RVATYP(I_FIS-1)       = [F:TMP1]RVATYP
        [M:FAS3]DPRCUM(I_FIS-1)      -= GRVADERRVE   #Fq-67995b
        [M:FAS3]EXECLOCUMT(I_FIS-1)  -= GRVADERRVE   #Fq-67995b
        #*Fq-84817 déplacé en dessous car mis à jour uniquement en fonction de la date de début d'amortissement
        #*Fq-84817   [M:FAS3]DPRCUMFLG(I_FIS-1)    = G_OUI        #Fq-67995b
        #*Fq-84817
        If ( [M:FAS3]LSTCLODAT(I_FIS-1)  <> [0/0/0] or ([M:FAS3]LSTCLODAT(I_FIS-1)  = [0/0/0] and [M:FAS3]STRDPRDAT(I_FIS-1) < [M:FAS3]FIYSTRDAT(I_FIS-1)) )
        Local Integer LPRATYP
        Call GET_DPM_RSD([M:FAS0]CPY, [M:FAS3]DPM (I_FIS-1),
&                        [M:FAS3]DPM (I_FIS-1), LPRATYP) From TRTFAS
        [M:FAS3]DPMT(I_FIS-1)   = [M:FAS3]DPM (I_FIS-1)
        If LPRATYP > 0
          [M:FAS3]PRATYP(I_FIS-1) = LPRATYP
        Else
          [M:FAS3]PRATYP(I_FIS-1) = [F:DEP]PRATYP
        Endif
           [M:FAS3]DPRCUMFLG(I_FIS-1)    = G_OUI
        Endif #*Fq-84817
        [M:FAS3]DEPSTA(I_FIS-1)       = GVML_SCNOCAL
     Endif
     #*Fq-89419  If I_MIN > 0
     If ( G_RVALIB = G_OUI ) and ( [M:FASR]DPRPLN=G301CPT ) and ( I_MIN > 0 )
       [M:FAS3]NSPVAL(I_MIN-1)        = [F:TMP1]NSPVAL
       [M:FAS3]DPRBAS(I_MIN-1)        = [M:FAS3]DPRBAS(I_MIN-1) + [F:TMP1]RVAAMT
       [M:FAS3]RVATIADAT(I_MIN-1)     = [F:TMP1]RVATIADAT
       [M:FAS3]PERREFCLC(I_MIN-1)     = [F:TMP1]PERREFCLC
       [M:FAS3]PERREFCLCT(I_MIN-1)    = [F:TMP1]PERREFCLCT
       [M:FAS3]RVADAT(I_MIN-1)        = [F:TMP1]RVADAT
       [M:FAS3]RVATYP(I_MIN-1)        = 0
       #*Fq-84817
       If ( [M:FAS3]LSTCLODAT(I_MIN-1)  <> [0/0/0] or ([M:FAS3]LSTCLODAT(I_MIN-1)  = [0/0/0] and [M:FAS3]STRDPRDAT(I_MIN-1) < [M:FAS3]FIYSTRDAT(I_MIN-1)) )
       Local Integer LPRATYP
       Call GET_DPM_RSD([M:FAS0]CPY, [M:FAS3]DPM (I_MIN-1),
&                       [M:FAS3]DPM (I_MIN-1), LPRATYP) From TRTFAS
        [M:FAS3]DPMT(I_MIN-1)   = [M:FAS3]DPM (I_MIN-1)
        If LPRATYP > 0
          [M:FAS3]PRATYP(I_MIN-1) = LPRATYP
        Else
          [M:FAS3]PRATYP(I_MIN-1) = [F:DEP]PRATYP
        Endif
        Endif #Fq-84817
       [M:FAS3]DEPSTA(I_MIN-1)       = GVML_SCNOCAL
     Endif
  Else
     #*Fq-89419 If I_FIS > 0
     If ( G_RVALIB = G_OUI ) and ( I_FIS > 0 )
      # Annulation de révaluation plan fiscal
      Filter [EFS] Where ( REF= [M:FAS0]AASREF & DPRPLN= G301FIS )
      Read [EFS]Last
      If !(fstat)
        # lecture événement de réévaluation pour récupérer le mode avant réévaluation
        [M:FAS3]DPM    (I_FIS-1)    = [F:EFS]DPM
        [M:FAS3]PRATYP (I_FIS-1)    = [F:EFS]PRATYP
        [M:FAS3]DPMT   (I_FIS-1)    = [F:EFS]DPM
        [M:FAS3]DPRBAS (I_FIS-1)    = [F:EFS]DPRBASO
        [M:FAS3]DPRCUM (I_FIS-1)    = [F:EFS]DPRCUMO
        [M:FAS3]DPRCUMFLG(I_FIS-1)  = [F:EFS]DPRCUMFLGO
        [M:FAS3]EXECLOCUMT(I_FIS-1) = [F:EFS]EXECLOCUMO
        [M:FAS3]RVAAMT (I_FIS-1)   = 0
        [M:FAS3]RVACOE (I_FIS-1)   = 0
        [M:FAS3]RVACOEREF(I_FIS-1) = ""
        [M:FAS3]RVATIADAT(I_FIS-1) = 0
        [M:FAS3]RVATYP(I_FIS-1)    = 0
        [M:FAS3]RVADAT(I_FIS-1)    = [0/0/0]
        [M:FAS3]DEPSTA (I_FIS-1) = GVML_SCNOCAL
      Endif
    Endif
     #*Fq-89419  If I_MIN > 0
     If ( G_RVALIB = G_OUI )  and ( I_MIN > 0 )
       # Annulation de révaluation plan minimum
       Filter [EFS] Where ( REF= [M:FAS0]AASREF & DPRPLN= G301MIN)
       Read [EFS]Last
       If !(fstat)
          # lecture événement de réévaluation pour récupérer le mode avant réévaluation
          [M:FAS3]DPM    (I_MIN-1)   = [F:EFS]DPM
          [M:FAS3]PRATYP (I_MIN-1)   = [F:EFS]PRATYP
          [M:FAS3]DPMT   (I_MIN-1)   = [F:EFS]DPM
          [M:FAS3]DPRBAS (I_MIN-1)   = [F:EFS]DPRBASO
          [M:FAS3]RVAAMT (I_MIN-1)   = 0
          [M:FAS3]RVACOE (I_MIN-1)   = 0
          [M:FAS3]RVACOEREF(I_MIN-1) = ""
          [M:FAS3]RVATIADAT(I_MIN-1) = 0
          [M:FAS3]RVATYP(I_MIN-1)    = 0
          [M:FAS3]RVADAT(I_MIN-1)    = [0/0/0]
          [M:FAS3]DEPSTA (I_MIN-1)   = GVML_SCNOCAL
       Endif
    Endif
 Endif

Return
#=================================================================
$GENER_RVA_EVE_LIB
  Local Integer  LCDRET, LREVTCREE

  If [F:DEPW]BSEVAL > 0 # Facture
     If ( [F:DEPW]RVAAMT < 0 )
        If ( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) >= 0
           GRVADEVCHG = [F:DEPW]EXERVADEV+ [F:DEPW]PERRVADEV +[F:DEPW]RVAAMT
        Else
           GRVADEVCHG =  [F:DEPW]RVAAMT
        Endif
     Else #----- [F:DEPW]RVAAMT > 0
        If ( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) < 0
           If abs(( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) ) <= abs([F:DEPW]RVAAMT)
             GRVADEVCHG = -([F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV )  # solde de la rÃ©serve
           Else
            GRVADEVCHG =  [F:DEPW]RVAAMT
           Endif
        Else
           GRVADEVCHG =  0
        Endif
     Endif
  Endif    #Fq-64311
  GRVADERRVE =  [F:DEP]LEGCUM - [F:DEP]LEGRVECUM

  If ( GCCLFLG <> G_OUI )
    #Fq-80075
    If [F:DEPW]RVAAMT <> 0
     # Réévaluation---------------
     Local Date LDATEVT, LDATCPT
     LCDINT  = "FASRVA"+num$([F:DEP]DPRPLN)
     LDATEVT = max([F:DEPW]RVADAT,    [F:DEPW]STRDPRDAT)
     LDATCPT = max([F:DEPW]PERSTRDAT, [F:DEPW]STRDPRDAT)
     If [F:DEP]DPRCUMFLG > 0
       [F:DEPW]DPRCUMFLG = [F:DEP]DPRCUMFLG
      #*FQ-84817   Else
      #*FQ-84817     [F:DEPW]DPRCUMFLG = G_NON
     Endif
     Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,LDATEVT,LDATCPT,LCDRET) From GENEVE
     # Génération EVt Plan Fiscal ( DEPF est déjà l'état après réévaluation )
     # Les nouvelles valeurs sont déjà portées par l'enreg. [DEPF]
      #Fq-89419 uniquement si le plan réévalué est le plan comptable
     #----------------------------------------------------------------------
       If [M:FASR]DPRPLN = G301CPT  #Fq-89419
     Read [DEPF]DEP0 =[F:MAS1]AASREF;G301FIS;[F:DEPW]FIYENDDAT;[F:DEPW]PERENDDAT
     If fstat=0
        [F:DEPW]DPRBAS=  [F:DEPF]DPRBAS #+ [F:DEPW]RVAAMT
        LCDINT  = "FASRVA"+num$(G301FIS)
        [F:DEPW]NBV =  [F:DEPF]NBV # FQ104164
        #*Fq-84817 [F:DEP]DPM        = [F:DEPF]DPM
        [F:DEP]DPM        = GDPMO_F
        [F:DEP]NBV        = GNBVO_F

          # FQ104164 : traitement des champs *O avant la nouvelle valeur
          # valeurs origine alimentées depuis le plan fiscal avant modif
          [F:DEP]DPRCUM    = [F:DEPFO]DPRCUM                  # alimente DPRCUMO
          [F:DEPW]DPRCUM   = [F:DEPF]DPRCUM                   # alimente DPRCUM

          [F:DEP]DPRCUMFLG = [F:DEPFO]DPRCUMFLG               # alimente DPRCUMFLGO
          If [F:DEPF]DPRCUMFLG > 0
            [F:DEPW]DPRCUMFLG  =  [F:DEPF]DPRCUMFLG          # alimente DPRCUMFLG
          Endif

          [F:DEP]DPRBAS     = [F:DEPFO]DPRBAS
          [F:DEP]PERCLOCUM  = [F:DEPFO]PERCLOCUM
          [F:DEP]PERCLOEXC  = [F:DEPFO]PERCLOEXC
          [F:DEP]EXETRFCUM  = [F:DEPFO]EXETRFCUM
          [F:DEP]EXEIMLCUM  = [F:DEPFO]EXEIMLCUM

          [F:DEP]PERIMLCUM  = [F:DEPFO]PERIMLCUM
          [F:DEP]EXERVECUM  = [F:DEPFO]EXERVECUM
          [F:DEP]PERRVECUM  = [F:DEPFO]PERRVECUM
          [F:DEP]EXECLOCUMT = [F:DEPFO]EXECLOCUMT
          # end FQ104164

        LDATEVT  = max([F:DEPW]RVADAT,    [F:DEPW]STRDPRDAT)
        LDATCPT  = max([F:DEPW]PERSTRDAT, [F:DEPW]STRDPRDAT)
        Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,LDATEVT,LDATCPT,LCDRET) From GENEVE
     Endif
     # Génération EVt Plan Minimum ( DEPM est déjà l'état après réévaluation )
     # Les nouvelles valeurs sont déjà portées par l'enreg. [DEPM]
     #----------------------------------------------------------------------
      Read [DEPM]DEP0 =[F:MAS1]AASREF;G301MIN;[F:DEPW]FIYENDDAT;[F:DEPW]PERENDDAT
      If fstat=0
        If GDPMO_M <> ""
         [F:DEP]DPM = GDPMO_M
        Else
          [F:DEP]DPM     =  [F:DEPM]DPM
         Endif
        [F:DEPW]DPRBAS =  [F:DEPM]DPRBAS
        [F:DEP]NBV        = GNBVO_M
        GRVADERRVE = 0

          # FQ104164 : traitement des champs *O avant la nouvelle valeur
          # valeurs origine alimentées depuis le plan fiscal avant modif

          [F:DEP]DPRCUM     = [F:DEPMO]DPRCUM
          [F:DEPW]DPRCUM    = [F:DEPM]DPRCUM

          [F:DEP]DPRCUMFLG     = [F:DEPMO]DPRCUMFLG
          If [F:DEPM]DPRCUMFLG > 0
            [F:DEPW]DPRCUMFLG  =  [F:DEPM]DPRCUMFLG                 # alimente DPRCUMFLG
          Endif

          [F:DEP]DPRBAS     = [F:DEPMO]DPRBAS
          [F:DEP]PERCLOCUM  = [F:DEPMO]PERCLOCUM
          [F:DEP]PERCLOEXC  = [F:DEPMO]PERCLOEXC
          [F:DEP]EXETRFCUM  = [F:DEPMO]EXETRFCUM
          [F:DEP]EXEIMLCUM  = [F:DEPMO]EXEIMLCUM

          [F:DEP]PERIMLCUM  = [F:DEPMO]PERIMLCUM
          [F:DEP]EXERVECUM  = [F:DEPMO]EXERVECUM
          [F:DEP]PERRVECUM  = [F:DEPMO]PERRVECUM
          [F:DEP]EXECLOCUMT = [F:DEPMO]EXECLOCUMT
          # end FQ104164

        LCDINT  = "FASRVA"+num$(G301MIN)
        LDATEVT  = max([F:DEPW]RVADAT,    [F:DEPW]STRDPRDAT)
        LDATCPT  = max([F:DEPW]PERSTRDAT, [F:DEPW]STRDPRDAT)
        Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,LDATEVT,LDATCPT,LCDRET) From GENEVE
      Endif
       Endif #Fq-89419
     Endif #Fq-80075
  Else
#     # Annulation réévaluation --------------
   GRVADERRVE = 0
   LCDINT= "FASRVA"+num$([F:DEP]DPRPLN)
   Call ANNULE_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]RVADAT,LREVTCREE,LCDRET) From GENEVE
   Read [DEPF]DEP0 =[F:MAS1]AASREF;G301FIS;[F:DEPW]FIYENDDAT;[F:DEPW]PERENDDAT
   If fstat=0
      LCDINT= "FASRVA"+num$([F:DEPF]DPRPLN)
      Call ANNULE_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]RVADAT,LREVTCREE,LCDRET) From GENEVE
   Endif
   Read [DEPM]DEP0 =[F:MAS1]AASREF;G301MIN;[F:DEPW]FIYENDDAT;[F:DEPW]PERENDDAT
   If fstat=0
      LCDINT= "FASRVA"+num$([F:DEPM]DPRPLN)
      Call ANNULE_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]RVADAT,LREVTCREE,LCDRET) From GENEVE
   Endif
  Endif

  If (LCDRET)
    RMES = mess(107,GML_MSGFAS,1)-num$(LCDRET)
    GOK=0
  Endif

Return
