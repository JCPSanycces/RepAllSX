#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################################
#                                                           # 
# Traitement lié à l'action de copie de gamme               #
#                                                           #
#     Action : TRTROUCOP                                    #
#                                               07/01   MM  #
#                                                           #
#############################################################                                                           #
# adapté pour la génération des macro gammes. 04/02         #
#                                                           #
#############################################################

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE 
Endcase
Return

#############################################################
$INIT 
Local Integer NBOPMX   : NBOPMX=100       # dimension tables op
Local Integer WOPENUM (NBOPMX)            # n° opération
Local Integer WNEXOPENUM(NBOPMX)          # n° opération suivante
Local Integer WMFGMST(NBOPMX)             # étape production

Local  Integer I, J , OSILENCE
Local  Char    WFIL(250)
Local  Integer OK,  WINT, WETAPPROD
Local  Char    FORMULE1(255)

If clalev([F:ROH]) = 0  : Local File ROUTING    [ROH]  : Endif
If clalev([F:ROO]) = 0  : Local File ROUOPE     [ROO]  : Endif
If clalev([F:ROS]) = 0  : Local File ROUSCD     [ROS]  : Endif
If clalev([F:TRO]) = 0  : Local File TABROUALT  [TRO]  : Endif
If clalev([F:ACC]) = 0  : Local File ACCES      [ACC]  : Endif
If clalev([F:MWS]) = 0  : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TFO]) = 0  : Local File TABFOR     [TFO]  : Endif
If clalev([F:AXX]) = 0  : Local File ATEXTRA    [AXX]  : Endif

# Tables de travail
If clalev([F:ROHW])= 0  : Local File ROUTING    [ROHW] : Endif
If clalev([F:ROOW])= 0  : Local File ROUOPE     [ROOW] : Endif
If clalev([F:ROSW])= 0  : Local File ROUSCD     [ROSW] : Endif
If clalev([F:MWSW])= 0  : Local File WORKSTATIO [MWSW] : Endif

Local Mask ROUCOP0 [DIA]

Return

#############################################################
$CONTROLE 

# Pour gérer la fin sans validation
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN
If OK<> 2  : SAI = 1 :  Return : Endif

Return

#############################################################
$EXEC

Call OUVRE_TRACE(mess(141,190,1)) From LECFIC
# pour copier l'écran dans la trace
Call PRTSCR("ROUCOP0","DIA","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

# préparation du filtre de sélection 
WFIL  = "ROUALT = [M:DIA]ALTORG "
WFIL += "& FCY = [M:DIA]FCYORG "    # 30204 MM 06.05
If [M:DIA]ITMREFDEB <>"" & [M:DIA]ITMREFDEB=[M:DIA]ITMREFFIN
   WFIL+= " & ITMREF = [M:DIA]ITMREFDEB"
Else : ## GH 11/04/2012 bug 80594
   If [M:DIA]ITMREFDEB<>"" :  WFIL+= " & ITMREF >= [M:DIA]ITMREFDEB" : Endif
   If [M:DIA]ITMREFFIN<>"" :  WFIL+= " & ITMREF <= [M:DIA]ITMREFFIN" : Endif
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

OSILENCE = GSILENCE
GOK=1 : GERR=0 : GMESSAGE="" : GSILENCE=1

Trbegin [ROH]

For [ROH] Where evalue(WFIL) & evalue(FORMULE1)

  ## GH 11/04/2012 cas de [M:DIA]ITMREFFIN="" & [M:DIA]ITMREFDEB<>"" non géré
  # Test si gamme courante appartient à la sélection de gammes à copier 
  #If ([M:DIA]ITMREFFIN<>"") 
  #    If (([F:ROH]ITMREF< [M:DIA]ITMREFDEB) | ([F:ROH]ITMREF > [M:DIA]ITMREFFIN))
  #        Goto NEXT_ROH
  #    Endif
  #Endif

  # contrôle d'existence de l'enregistrement  
  Look [ROHW]ROH1 = [M:DIA]FCYDST;[F:ROH]ITMREF;[M:DIA]ALTDST    # 30204 MM 06.05
  If !fstat :  Goto NEXT_ROH : Endif

  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(mess(63,198,1)-[F:ROH]ITMREF,0) From GESECRAN  : # Gamme
  I=0 : WINT=0
  For [ROO]ROO0 Where  FCY=[F:ROH]FCY & ITMREF=[F:ROH]ITMREF & ROUALT=[F:ROH]ROUALT  
    # Cas macro gammes
    If [M:DIA]FRCCP = 2 
        Read [MWSW]WST0 = [F:ROO]WST;[M:DIA]FCYDST    # 30204 MM 06.05
        If fstat
            GMESSAGE = [F:ROO]WST-":"-mess(196,193,1)- [M:DIA]FCYDST : # 30204 MM 06.05
            GERR=1 : Break 2
        Endif
        If [F:MWSW]RCCP <> 2
            Call ECR_TRACE(mess(25,9150,1)-num$([F:ROO]OPENUM)+"."+num$([F:ROO]RPLIND)-":"-mess(165,190,1),0) From GESECRAN
            Goto NEXT_OPE 
        Endif
    Endif

    # si le site de destination est different du site origine, controler si site dest. possède 
    # les postes de charge nécessaire à la réalisation des gammes qu'on s'apprête à copier
    If [M:DIA]FCYDST <> [F:ROH]FCY : # 30204 MM 06.05
        Read [MWS]WST0 = [F:ROO]WST;[F:ROH]FCY          
        If  fstat
            GMESSAGE = [F:ROO]WST-":"-mess(196,193,1)- [M:DIA]FCYDST : # 30204 MM 06.05
            GERR=1 : Break 2
        Endif
        # poste inexistant sur ce site
        Read [MWSW]WST0 = [F:ROO]WST;[M:DIA]FCYDST    # 30204 MM 06.05
        If fstat | [F:MWS]WSTTYP <> [F:MWSW]WSTTYP 
            GMESSAGE = mess(182,193,1)    
            GERR = 1 : Break 2  
        Endif     
        If [F:ROO]LABWST<>""
            Read [MWS]WST0  = [F:ROO]LABWST;[F:ROH]FCY
            Read [MWSW]WST0 = [F:ROO]LABWST;[M:DIA]FCYDST    # 30204 MM 06.05
            If fstat | [F:MWS]WSTTYP <> [F:MWSW]WSTTYP 
                GMESSAGE = mess(182,193,1)    
                GERR = 1 : Break 2
            Endif  
        Endif
        If [F:ROO]SCOWST<>""
            Read [MWS]WST0  = [F:ROO]SCOWST;[F:ROH]FCY
            Read [MWSW]WST0 = [F:ROO]SCOWST;[M:DIA]FCYDST    # 30204 MM 06.05
            If fstat | [F:MWS]WSTTYP <> [F:MWSW]WSTTYP 
               GMESSAGE = mess(182,193,1)    
               GERR=1 : Break 2
            Endif  
        Endif
   Endif

   #rupture
   If WINT <>  [F:ROO]OPENUM 
      WINT = [F:ROO]OPENUM  # on stocke le numero d'opération courante
      # MAJ de la table Gamme Jalonnement opérations = ROUSCD
      Read [ROS]ROS0 = [F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM     # 30204 MM 06.05
      If fstat
         GOK=0 : Call RSTA("ROS",[F:ROO]FCY-[F:ROO]ITMREF-num$([F:ROO]ROUALT)-num$([F:ROO]OPENUM)) From GLOCK : Break 2
      Endif
      [F:ROSW] = [F:ROS]
      [F:ROSW]ROUALT = [M:DIA]ALTDST
      [F:ROSW]FCY    = [M:DIA]FCYDST    # 30204 MM 06.05
      [F:ROSW]CREDAT = date$
      [F:ROSW]CREUSR = GUSER
      [F:ROSW]UPDDAT = [0/0/0]
      [F:ROSW]UPDUSR = ""
      Write [ROSW]
      If fstat
         GOK=0 : Call FSTA("ROSW") From GLOCK : Break 2
      Endif
      If [M:DIA]FRCCP= 2
          WOPENUM(I)=[F:ROS]OPENUM
          WNEXOPENUM(I)=[F:ROS]NEXOPENUM
          WMFGMST(I)=[F:ROS]MFGMST
          I+=1
      Endif
   Endif 

   # MAJ de la table Gamme opération = ROUOPE
   [F:ROOW] = [F:ROO]
   [F:ROOW]ROUALT       = [M:DIA]ALTDST     
   [F:ROOW]FCY          = [M:DIA]FCYDST       # 30204 MM 06.05
  If [F:ROOW]FCY<>[F:ROO]FCY & [F:ROO]STDOPENUM <>0  # GH 10/07/13 bug 90719
   # If [F:ROO]STDOPENUM <>0  # 30204 MM 06.05
      Raz [F:ROOW]STDOPENUM,[F:ROOW]ROODES
   Endif
   # copie de texte ?
   If [F:ROO]ROOTEX <> ""
      If !find(left$([F:ROO]ROOTEX,3),"ROT")
          Call DUP_CLOB("ROO",[F:ROOW]ROOTEX,J) From TRTX3TEX
          If !J : GERR=1 : Break 2 : Endif # FQ 69909 Ctrl des sources avant Return
      Endif
   Endif
   [F:ROOW]CREDAT = date$
   [F:ROOW]CREUSR = GUSER
   [F:ROOW]UPDDAT = [0/0/0]
   [F:ROOW]UPDUSR = ""    
   Write [ROOW]
   If fstat
      GOK=0 : Call FSTA("ROOW") From GLOCK : Break 2
   Endif

   #---------
   # GH 12/04/2012 FQ 80755 permet de traiter des tables spécifiques complémentaires 
   GPOINT = "AFTCREROO"
   Gosub  ENTREE From EXEFNC
   If GOK<0 | GERR : Break 2 : Endif
   #---------

$NEXT_OPE
  Next : # [ROO]
     
  # MAJ de la table Gamme entête = ROUTING
  [F:ROHW] = [F:ROH]
  [F:ROHW]ROUALT = [M:DIA]ALTDST
  [F:ROHW]FCY    = [M:DIA]FCYDST    # 30204 MM 06.05 
  # copie de texte ?
  If [F:ROH]TEXNUM <> ""
        If !find(left$([F:ROH]TEXNUM,3),"ITM")
            Call DUP_CLOB("ROO",[F:ROHW]TEXNUM,J) From TRTX3TEX
            If !J : GERR=1 : Break : Endif # FQ 69909 Ctrl des sources avant Return
        Endif
  Endif
  # 26998 12.04 MM
  [F:ROHW]LASWORQTY = 0
  [F:ROHW]LASWORDAT = [0/0/0]
  #
  [F:ROHW]CREDAT = date$
  [F:ROHW]CREUSR = GUSER
  [F:ROHW]UPDDAT = [0/0/0]
  [F:ROHW]UPDUSR = ""
  Write [ROHW]
  If fstat
     GOK=0 : Call FSTA("ROHW") From GLOCK : Break
  Endif
  Call DUPTEXTRA("ROUTING","ROUDESAXX",[F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY
&               ,"ROUTING","ROUDESAXX",[F:ROHW]ITMREF+"~"+num$([F:ROHW]ROUALT),[F:ROHW]FCY) From ATEXTRA : # GH 11/04/2012 bug 80594
  If GOK<1 : Break : Endif

  #---------
  # GH 12/04/2012 FQ 80755 permet de traiter des tables spécifiques complémentaires
  GPOINT = "AFTCREROH"
  Gosub  ENTREE From EXEFNC
  If GOK<0 | GERR : Break : Endif
  #---------

  Call ECR_TRACE(mess(142,190,1),0) From GESECRAN : # Gamme copiée

  If [M:DIA]FRCCP=2   
    # On interdit les gammes vides
    If I=0
       GMESSAGE = mess(9,193,1) : # Cette gamme n'a aucune opération
       GERR=1 : Break
    Endif 
  
    # WETAPPROD=1 , pas d'OP productive dans macro gamme
    # WETAPPROD= 2, une OP productive existe dans macro gamme

    # Test si OP 0 productive
    If WMFGMST(0)=2 : WETAPPROD=2 : Else WETPPROD=1 : Endif

    # Recadrage du N° d'OP suivante de l'OP (n-1) par rapport au N° de l'OP (n)
    For J=1 To I-1
        If WOPENUM(J-1)<>WOPENUM(J)
            WNEXOPENUM(J-1)= WOPENUM(J)
            Readlock [ROSW]ROS0=[M:DIA]FCYDST;[F:ROO]ITMREF;[M:DIA]ALTDST;WOPENUM(J-1)    # 30204 MM 06.05
            If fstat
               GOK=0 : Call RSTA("ROSW",[M:DIA]FCYDST-[F:ROO]ITMREF-num$([M:DIA]ALTDST)-num$(WOPENUM(J-1))) From GLOCK : Break 2
            Endif
            [F:ROSW]NEXOPENUM =  WNEXOPENUM(J-1)
            Rewrite [ROSW]
            If fstat
               GOK=0 : Call FSTA("ROSW") From GLOCK : Break 2
            Endif
        Endif 
        If WMFGMST(J)=2 : WETAPPROD=2 : Endif
    Next J

    # Si aucune opération productive , c'est la dernière OP de la gamme qui le devient
    If WETAPROD=1
        WMFGMST(I-1)= 2 
        Readlock [ROSW]ROS0 = [M:DIA]FCYDST;[F:ROO]ITMREF;[M:DIA]ALTDST;WOPENUM(I-1)    # 30204 MM 06.05
        If fstat
            GOK=0 : Call RSTA("ROSW",[M:DIA]FCYDST-[F:ROO]ITMREF-num$([M:DIA]ALTDST)-num$(WOPENUM(I-1))) From GLOCK : Break
        Endif
        [F:ROSW]MFGMST = WMFGMST(I-1) 
        Rewrite [ROSW]
        If fstat
           GOK=0 : Call FSTA("ROSW") From GLOCK : Break
        Endif
    Endif
    
 Endif
    
$NEXT_ROH
Next : # [ROH]

If GERR
   Rollback
   If GMESSAGE<>""
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      GMESSAGE=""
   Endif
Elsif GOK<1
   Rollback
Else
   Commit
Endif
If GOK<1 | GERR
   Call ECR_TRACE("\\"+mess(17,107,1),0) From GESECRAN : # Abandon suite à une erreur dans la transaction
Endif

GSILENCE=OSILENCE
Return

##################################################
$ANALYSE_FORMULE

# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [TFO]TFO0=9;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return

#############################################################
$SORTIE

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Raz [M:DIA]
Close Local Mask [DIA]

Return

################################################################################
#                                                                              #
# Etiquettes écrans                                                            #
#                                                                              #
################################################################################

Subprog C_ALTORG(VALEUR)
Variable Decimal VALEUR

If [F:TRO]FCY="" :  Actzo [DIA]FCYORG
Else [M:DIA]FCYORG = [F:TRO]FCY : Affzo [DIA]FCYORG : Grizo [DIA]FCYORG
Endif

End

#########################################
# 30204 MM 06.05
Subprog AM_ALTORG(VALEUR)
Variable Decimal VALEUR

If varmode([M:DIA]FCYORG)=0
   Raz [M:DIA]FCYORG
Endif

End

########################################
Subprog C_ALTDST(VALEUR)
Variable Decimal VALEUR

# vérification des droits de l'utilisateur
Read [ACC]CODACC = GUSER;[F:TRO]ACSCOD
If !fstat & [F:ACC]MODIF = 1
   GMESSAGE = mess(144, 199,1) : mkstat=2 : End # pas d'autorisation de modif sur cette alternative
Endif

If [F:TRO]FCY="" :  Actzo [DIA]FCYDST
Else [M:DIA]FCYDST = [F:TRO]FCY : Affzo [DIA]FCYDST : Grizo [DIA]FCYDST
Endif

If VALEUR = [M:DIA]ALTORG & [F:TRO]FCY = [M:DIA]FCYORG
   # Les couples alternative/site origine et alternative/site destination sont identiques
   GMESSAGE = mess(245,193,1) : mkstat = 2 : End 
Endif

# contrôle de cohérence
# l'alternative doit être de type RCCP pour autoriser la génération de macro gamme
If [F:TRO]RCCUSE <> 2
   [M:DIA]FRCCP=1 : Grizo [DIA]FRCCP
Else
   Actzo [DIA]FRCCP
Endif

End

########################################
# 30204 MM 06.05
Subprog AM_ALTDST(VALEUR)
Variable Decimal VALEUR

If varmode([M:DIA]FCYDST)=0
   Raz [M:DIA]FCYDST
Endif

End

########################################
# 30204 MM 06.05
Subprog C_FCYDST(VALEUR)
Variable Char    VALEUR()

If VALEUR = [M:DIA]FCYORG & [M:DIA]ALTORG =  [M:DIA]ALTDST
    # Les couples alternative/site origine et alternative/site destination sont identiques
    GMESSAGE = mess(245,193,1) : mkstat = 2 : End
Endif
End

########################################
Subprog C_ITMREFDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <>""
    Look [ROH]ROH1 = [M:DIA]FCYORG;VALEUR;[M:DIA]ALTORG    # 30204 MM 06.05
    If fstat : mkstat = 2 :GMESSAGE= mess(23,100,1) : End : Endif      # fiche inexistante
Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <>""
   [M:DIA]ITMREFFIN = VALEUR
Endif

End

########################################
Subprog C_ITMREFFIN(VALEUR)
Variable Char    VALEUR()

If VALEUR < [M:DIA]ITMREFDEB
    GMESSAGE= mess(44,199,1) : mkstat = 2 : End
Endif

If VALEUR <>""
    Look [ROH]ROH1 = [M:DIA]FCYORG;VALEUR;[M:DIA]ALTORG    # 30204 MM 06.05
    If fstat : mkstat = 2 :GMESSAGE= mess(23,100,1) : End : Endif      # fiche inexistante

    If VALEUR = [M:DIA]ITMREFDEB      
        Look [ROH]ROH1 = [M:DIA]FCYDST;VALEUR;[M:DIA]ALTDST     # 30204 MM 06.05
        If !fstat : mkstat = 2 : GMESSAGE= mess(178,193,1) : End : Endif   # gamme de destination déjà existante
    End : Endif
Endif 

End
