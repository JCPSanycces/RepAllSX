#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("JOU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "AFFMASK"      : Gosub AFFMASK
 When "RAZCRE"       : Gosub RAZCRE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "ANNULE"       : Gosub ANNULE
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "FERME"        : Gosub FERME
 When "CHGCOD"       : Gosub CHGCOD
 When "AS_JOU"       : Raz GCURLEG
Endcase
Return

$OUVRE
If clalev([F:CPY]) = 0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:JST]) = 0  : Local File GAJOUSTA [JST]  : Endif
If clalev([F:COA]) = 0  : Local File GCOA     [COA]  : Endif
If clalev([F:JCO]) = 0  : Local File GJOUCOA  [JCO]  : Endif
If clalev([F:JC2]) = 0  : Local File GJOUCOA  [JC2]  : Endif
If clalev([F:JOU2]) = 0 : Local File GJOURNAL [JOU2] : Endif
Local Integer I, K
Local Char OLDJOU(GLONJOU), OLDLEG(GLONADI)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$AFFMASK
If dim([M:JOU0]LEG)>0
 If func AFNC.ACTIV("LEG")=0
  Chgfmt [M:JOU0]LEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:JOU0]ZLEG)>0
   Chgfmt [M:JOU0]ZLEG With "-K:"+num$(type([M:JOU0]ZLEG)-10)+"X"
  Endif
 Endif
Endif
Gosub GRILEG
Return

$RAZCRE
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0
 Diszo [M:JOU0]LEG
 [M:JOU0]LEG=GDOSLEG(1)
 Affzo [M:JOU0]LEG
Endif
Return

$SETBOUT
If !CLECUR or REP<>""
 Call VIREBOUT(CHAINE,"1") From GOBJET
 Call VIREBOUT(CHAINE,"2") From GOBJET
Else
 If !instr(1,GUSRAUZ(1),"M") : Call VIREBOUT(CHAINE,"1") From GOBJET :  Endif
 If !instr(1,GUSRAUZ(1),"M") : Call VIREBOUT(CHAINE,"3") From GOBJET :  Endif
 Local Integer OKACC
 Call LECACC([F:JOU]ACS,OKACC) From CPTSUB
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Endif
Endif
Return

$LIENS
## Display in the array the chart of accounts and the treasury accounts
nolign=0
# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
#If GNBLEG=1
If GNBLEG=1 and GLEGACT = 1       # only one legislation and LEG activity code inactive?
# X3-91211 end
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG = [M:JOU0]LEG
Endif
For [JCO]JCO0 Where [F:JCO]JOU=[M]JOU & [F:JCO]LEG=GCURLEG
 If [F:JCO]ACC<>'' & nolign<dim([M]COA)
  nolign+=1
  [M]OCOA(nolign-1) = [F:JCO]COA
  [M]COA(nolign-1)  = [F:JCO]COA
  [M]ACC(nolign-1)  = [F:JCO]ACC
 Endif
Next
[M]ONBLIG=nolign
[M]NBRACC=nolign

Call LECTEXTRA([M:JOU0]DESTRA,"GJOURNAL","DESTRA",[M:JOU0]JOU,GCURLEG) From ATEXTRA
Call LECTEXTRA([M:JOU0]SHOTRA,"GJOURNAL","SHOTRA",[M:JOU0]JOU,GCURLEG) From ATEXTRA
If [F:JOU]FCY<>""
 Call LIENFCYCPY([F:JOU]FCY,"[M:JOU0]FCYDES") From CFYSUB
Endif
Return

$INICRE
$INIMOD
# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
#If GNBLEG=1 : [F:JOU]LEG = GDOSLEG(1) : Endif
If GNBLEG=1 and GLEGACT = 1 : [F:JOU]LEG = GDOSLEG(1) : Endif       # only one legislation and LEG activity code inactive?
# X3-91211 end
If dim([F:JOU]DES)>0
 [F:JOU]DES = [M:JOU0]DESTRA
Endif
Return

$VERIF
If [M:JOU1]TYP=3
 If [M]NBRACC = 0
  # Définir au moins un plan de compte avec un compte de trésorerie
  GMESSAGE = mess(82,104,1)
  OK = 0 : Return
 Else
  K=0
  For I=0 To [M:JOU1]NBRACC-1
   Read [COA]COA0 = [M:JOU1]COA(I)
   If !fstat
    If [F:COA]GENTRK = 2
     K+=1
    Endif
   Endif
  Next
  If K=0
   # Le compte trésorerie doit être saisie sur au moins un plan de compte flagué Général
   GMESSAGE = mess(84,104,1)
   OK = 0 : Return
  Endif
 Endif
Endif
OLDJOU = [F:JOU]JOU
OLDLEG = [F:JOU]LEG
Return

# En création d'un journal, on va créer :
# * les enregistrements pour chaque société dans GAJOUSTA (Journaux-états)
# * les enregistrements pour chaque plan de compte dans GJOUCOA (Journaux-Plan de compte)
$CREATION
If [M:JOU1]TYP=3 & [M:JOU1]NBRACC=0
 # Définir au moins un plan de compte avec un compte de trésorerie
 GMESSAGE = mess(82,104,1)
 OK = 0 : Return
Else
 ## Ecriture dans GAJOUSTA
 For [CPY]CPY0  Where [F:CPY]CPYLEGFLG=2
  Look [F:JST]JST0=[F:CPY]CPY;[M:JOU0]JOU
  If fstat
   [F:JST]CPY       = [F:CPY]CPY
   [F:JST]JOU       = [M:JOU0]JOU
   [F:JST]OPGSTRDAT = [F:CPY]STRPER
   [F:JST]OPGENDDAT = [0/0/0]
   [F:JST]LEG       = [F:CPY]LEG
   [F:JST]CREUSR    = GUSER
   [F:JST]CREDAT    = date$
   Write [JST]
   If fstat
    GOK = 0 : Call FSTA("JST") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif

 ## Ecriture dans GJOUCOA
 If !GIMPORT
  For [COA]COA0
   Look [F:JCO]JCO0=[F:COA]COA;[M:JOU0]JOU;GCURLEG
   If fstat
    Raz [JCO]
    [F:JCO]JOU    = [M:JOU0]JOU
    [F:JCO]COA    = [F:COA]COA
    [F:JCO]LEG    = GCURLEG
    For I=0 To [M]NBRACC-1
     If [M]COA(I)=[F:COA]COA
      [F:JCO]ACC = [M]ACC(I)
      Break
     Endif
    Next
    If GREP="D"
     Read [F:JC2]JCO0= [F:COA]COA;OLDJOU;OLDLEG
     If !fstat
      [F:JCO]FBDNBR = [F:JC2]FBDNBR
      For I=0 To [F:JC2]FBDNBR-1
       [F:JCO]FBDACC(I) = [F:JC2]FBDACC(I)
      Next
      [F:JCO]FRQNBR = [F:JC2]FRQNBR
      For I=0 To [F:JC2]FRQNBR -1
       [F:JCO]FRQACC(I) = [F:JC2]FRQACC(I)
       [F:JCO]FRQCOD(I) = [F:JC2]FRQCOD(I)
      Next
     Endif
    Endif
    [F:JCO]CREUSR = GUSER
    [F:JCO]CREDAT = date$
    Write [JCO]
    If fstat
     GOK = 0 : Call FSTA("JCO") From GLOCK : Break
    Endif
   Endif
  Next
  If GOK<1 : Return : Endif
 Endif
Endif
Gosub TEXTRA
Return


$MODIF
## RAZ du compte de trésorerie dans GJOUCOA qd le compte de trésorerie,
## pour un plan de compte et un journal donnés, a été modifié
For I=0 To [M]ONBLIG-1
 If !find([M]OCOA(I),[M]COA(0..[M]NBRACC-1))
  Readlock [JCO]JCO0 = [M]OCOA(I);[M]JOU;GCURLEG
  If fstat=1
   GOK = -1 : GLOCK = "$GJOUCOA"-[M]OCOA(I)-[M]JOU-GCURLEG : Break
  Endif
  [F:JCO]ACC    = ''
  [F:JCO]UPDUSR = GUSER
  [F:JCO]UPDDAT = date$
  Rewrite [JCO]
  If fstat
   GOK = 0 : Call FSTA("JCO") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
#Enregistrer l'ajout ou la modification d'une ligne du tableau Plan de compte/Compte de trésorerie dans GJOUCOA
For I=0 To [M]NBRACC-1
 Read [JCO]JCO0=[M:JOU1]COA(I);[M:JOU0]JOU;GCURLEG
 If !fstat
  If [F:JCO]ACC <> [M:JOU1]ACC(I)
   [F:JCO]ACC = [M:JOU1]ACC(I)
   [F:JCO]UPDUSR = GUSER
   [F:JCO]UPDDAT = date$
   Rewrite [JCO]
   If fstat
    GOK = 0 : Call FSTA("JCO") From GLOCK : Break
   Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Gosub TEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GJOURNAL","DESTRA",CLECUR2,CLECUR1,"GJOURNAL","DESTRA",[M:JOU0]JOU,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("GJOURNAL","SHOTRA",CLECUR2,CLECUR1,"GJOURNAL","SHOTRA",[M:JOU0]JOU,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M:JOU0]DESTRA,"GJOURNAL","DESTRA",[M:JOU0]JOU,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M:JOU0]SHOTRA,"GJOURNAL","SHOTRA",[M:JOU0]JOU,GCURLEG) From ATEXTRA
Return

$APRES_CRE
$APRES_MOD
Gosub RELIT From GOBJSUB
Return

$ANNULE
# 71216 : We delete the records in the table GAJOUSTA if there is no record left in GJOURNAL with
# the same journal code and an another legislation
If GNBLEG=1
 Gosub ANNULE2
Else
 Filter [JOU2] Where JOU=[M:JOU0]JOU and LEG<>GCURLEG
 Look [JOU2]JOU0 First
 Filter [JOU2]
 If fstat
  Gosub ANNULE2
 Endif
Endif
Call SUPTEXTRA("GJOURNAL","DESTRA",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("GJOURNAL","SHOTRA",SUPP,[L]CODE) From ATEXTRA
Return

$ANNULE2
Delete [JST] Where JOU=[M:JOU0]JOU
If fstat=1
 GOK = -1 : Call RSTA("JST",[M:JOU0]JOU) From GLOCK : Return
Endif
Return

$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

$AP_CHANGE
# OCODE contains the former journal code
# NCODE contains the new journal code
# SUPP contains the legislation
Call CHGTEXTRA("GJOURNAL","DESTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("GJOURNAL","SHOTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
# The file GAJOUSTA has the link expression : [M]JOU;""
# => No change key on this table in the program CHGCLELEG
If ![L]TRANS : Trbegin [JST] : Endif
 For [CPY]CPY0  Where [F:CPY]CPYLEGFLG=2
  Look [F:JST]JST0=[F:CPY]CPY;NCODE
  If fstat
   [F:JST]CPY       = [F:CPY]CPY
   [F:JST]JOU       = NCODE
   [F:JST]OPGSTRDAT = [F:CPY]STRPER
   [F:JST]OPGENDDAT = [0/0/0]
   [F:JST]LEG       = [F:CPY]LEG
   [F:JST]CREUSR    = GUSER
   [F:JST]CREDAT    = date$
   Write [JST]
   If fstat
    GOK = 0 : Call FSTA("JST") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK>=1 & GNBROTHLEG=0
  Delete [JST] Where JOU=OCODE
  If fstat=1
   GOK = -1 : Call RSTA("JST",OCODE) From GLOCK
  Endif
 Endif
 If ![L]TRANS & GOK<1 : Rollback : Return : Endif
If ![L]TRANS : Commit : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
#If TUNNEL<>1 | dim(VCOD)<1 : Return : Endif
# JFL : US50 scrum sprint 3
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONJOU) : Endif

VCOD = CLE2
Return

#########################################################################
## Etiquettes des masques [JOU0]
#########################################################################
Subprog IB_JOU
If GFONCTION = "GESJOU" : GBOUT1="" : End : Endif
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG= VALEUR
End

#########################################################################
## Etiquettes des masques [JOU1]
#########################################################################
Subprog C_FCY(VALEUR)
Variable Char VALEUR
Local Integer I
For I=0 To [M]NBRACC-1
 If [M]ACC(I)<>""
  Call LECTURE("GAC",[M]ACC(I),[M]COA(I)) From CONTOBJ
  Call COMPAT(VALEUR,[F:GAC]FCY,[M]ACC(I)) From CFYSUB
 Endif
Next
#cohérence législation
Local Shortint STAT
Local Char MESSA(250)
Call CNTCOHGRPLEG(VALEUR,GCURLEG,STAT,MESSA) From CPTCNT
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End

