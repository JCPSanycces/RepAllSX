Subprog AS_TYP(VALEUR)
Variable Integer  VALEUR
# Change the abbreviation name from [HAE] to [HAE9] in order to avoid the problem when coming from (tunnel) a function
# where [HAE] is opened for GACCTMP[HAE] as from CPTDUM
If clalev([F:HAE9])=0
 If ! find(GREP,"C","D")
  Local File GACCENTRY [HAE9]
  Read [HAE9]HAE1(1) = [M]JOU
  If fstat = 0
   mkstat = 2 : End
  Endif
 Endif
Else
 mkstat = 2 : End
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>3
 Grizo [M:JOU1]NBRACC, COA ,ACC
Else
 Actzo [M:JOU1]NBRACC, COA ,ACC
Endif
End

Subprog AS_NBRACC
If [M]TYP<>3 : mkstat = 2 : End : Endif
End

Subprog C_COA(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 # Champ plan de compte obligatoire
 GMESSAGE = mess(76,104,1)
 mkstat=2 : End
Else
 Call UNICITE(VALEUR,[M]COA) From OBJDIV
Endif
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Integer I
If clalev([F:GAC])=0 : Local File GACCOUNT : Endif
If clalev([F:JCO])=0 : Local File GJOUCOA : Endif
If [M]COA(NOL)<>"" & VALEUR=""
 # Champ compte de trésorerie obligatoire
 GMESSAGE = mess(77,104,1)
 mkstat = 2 : End
Endif
If VALEUR<>""
 Read [JCO]JCO0 = [M]COA(NOL);[M]JOU;GCURLEG
 If !fstat
  For I=0 To [F:JCO]FBDNBR-1
   If [F:JCO]FBDACC(I)<>"" & pat(VALEUR,[F:JCO]FBDACC(I))
    ## Compte de trésorerie interdit
    GMESSAGE = mess(117,106,1)
    mkstat = 2 : Break
   Endif
  Next
  If mkstat : End : Endif
 Endif
 Call LECTURE("GAC",VALEUR,[M]COA(NOL)) From CONTOBJ
 Call COMPAT([M:JOU0]FCY,[F:GAC]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif
End

Subprog AM_ACC(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Call LECTURE("GAC",VALEUR,[M]COA(NOL)) From CONTOBJ
If [F:GAC]SAC = 2
 Local Integer OK
 # Compte de type collectif
 OK = 2 : Call AVERTIR(mess(19,104,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : Endif
Endif
End

Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>3
 Raz [M]NBRACC, [M]COA, [M]ACC
 Effzo NBRACC, COA, ACC
Elsif VALEUR = 3
 Actzo NBRACC, COA, ACC
Endif
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

##################################################
## Actions of the data type JOU
##################################################

# Control
Subprog CONTJOU(COD,LEG,GFY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    GFY()

Local    Integer CAS
If GFONCTION = "GESJOU" | COD="" : End : Endif
If clalev([F:JOU])=0 : Local File GJOURNAL [JOU] : Endif
# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
#If GNBLEG = 1
If GNBLEG = 1 and GLEGACT = 1       # only one legislation and LEG activity code inactive?
# X3-91211 end
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [JOU]JOU0=COD;LEG
 If fstat
  Read [JOU]JOU0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Filter [JOU] Where ENAFLG=2
 Read [JOU]JOU0(1)=COD
 Filter [JOU]
 If !fstat
  LEG = [F:JOU]LEG
  CAS = 2
 Else
  # To display the right message : either the recording is disable either it doesn't exist
  Read [JOU]JOU0(1)=COD
 Endif
Endif

If !fstat & [F:JOU]ENAFLG<>2
 # Jounaux comptables : xxx Fiche inactive
 Gosub TIT From WOJOU
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(2,126,1)
 mkstat = 2 : End
Elsif fstat
 If LEG<>""
  # LEG=FRA and the recording exists for the ITA legislation.
  # The right message isn't "Fiche inexistante" but "Fiche inexistante pour la législation courante"
  Filter [JOU] Where JOU=[L]COD
  Look [JOU]JOU0 First
  Filter [JOU]
  If !fstat
   # Fiche inexistante pour la législation courante
   # Issue 109042 - 2015-07-01 by CPO : Having the same error message formatting
   #GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
   Gosub TIT From WOJOU
   GMESSAGE = TIT-":"-[L]COD
   GMESSAGE += "\"+mess(232,107,1)-"["+[L]LEG+"]"
   # End issue 109042
   mkstat = 2 : End
  Endif
 Endif
 # Fiche inexistante
 # Issue 109042 - 2015-07-01 by CPO : Having the same error message formatting
 #GMESSAGE = [L]COD-":"-mess(23,100,1)
 Gosub TIT From WOJOU
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(23,100,1)
 # End issue 109042
 mkstat = 2 : End
Endif
If [L]GFY<>"" & [F:JOU]FCY<>"" & [L]GFY<>[F:JOU]FCY
 Call COMPAT([L]GFY,[F:JOU]FCY,"") From CFYSUB
 If mkstat=2
  Gosub TIT From WOJOU
  GMESSAGE = TIT-":"-[L]COD-[F:JOU]LEG
  GMESSAGE += "\"+mess(23,127,1)-":"-[F:JOU]FCY
  End
 Endif
Endif

If CAS=2
 Call CONTROLE("JOU","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("JOU","","",COD,mkstat) From CONTOBJ
Endif
End

##################################################

## Tunnel Journal codes
Subprog TUNJOU(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONJOU)
 TOKILL = 1
Endif

If clalev([F:JOU])=0 : Local File GJOURNAL [JOU] : Endif

# To update the journal code after the tunnel order
VCOD = COD

# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
#If GNBLEG = 1
If GNBLEG = 1 and GLEGACT = 1       # only one legislation and LEG activity code inactive?
# X3-91211 end
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG="" : # If LEG="" then firstly we search a JOU record with LEG="" secondly a JOU record with LEG<>""
 Read [JOU]JOU0 = VCOD;LEG
 If fstat
  Read [JOU]JOU0(1)=VCOD
  If !fstat
   LEG = [F:JOU]LEG
  Endif
 Endif
Endif

Read [JOU]JOU0 = VCOD;LEG
If fstat : LEG = "" : Endif

Call LEC_JOU_LEG(LEG,VCOD) From CPTLEC
If !fstat
 LEG = [F:JOU]LEG
Else
 Raz VCOD,LEG
Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("JOU",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE
If VCOD<>"" : COD = VCOD : Endif
If TOKILL : Kill VCOD : Endif
End

##################################################
Subprog VERF_PARAM(PARAM,VALPAR,OK)
Value    Char     PARAM()
Value    Char     VALPAR()
Variable Integer  OK

Local Char    LEG(GLONADI)
Local Integer I

If !clalev([F:JOU]) : Local File GJOURNAL  [JOU]  : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY]  : Endif

Raz LEG
If dim([M:ADWP]FCY)>0
 If [M:ADWP]FCY<>""
  Call GETSOC([M:ADWP]FCY) From DEVSUB
 Elsif [M:ADWP]CMP<>""
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
  Call LEC_CPY([M:ADWP]CMP) From CPTLEC
  Call GETSOC([F:CPY]MAIFCY) From DEVSUB
  Raz GCURFCY : # To not trigger control on the group in the CONTOBJ process
 Else
# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
# If GNBLEG=1
  If GNBLEG=1 and GLEGACT = 1       # only one legislation and LEG activity code inactive?
# X3-91211 end
   GCURLEG = GDOSLEG(1)
  Else
   GCURLEG = [M:ADWP]LEG
  Endif
 Endif

 If [M:ADWP]FCY<>""
  Call CONTJOU(VALPAR,LEG,[M:ADWP]FCY)
 Else
  Call CONTJOU(VALPAR,LEG,[M:ADWP]CMP)
 Endif
 If mkstat : OK = 0 : End : Endif
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat : OK = 0 : End : Endif
Endif
End


##################################################
## JOU selection
####################################################
Subprog SELJOU(COD,LEG)
Variable Char    COD()
Value    Char    LEG
Local Char PARMSK(30)(1..10)
If clalev([F:JOU])=0 : Local File GJOURNAL [JOU] : Endif
PARMSK(1) = LEG
# X3-91211 begin Bader 2018-06-27 if LEG activity code active and only one legislation > don't set GDOSLEG (keep LEG field empty)
#If GNBLEG=1 : PARMSK(1) = GDOSLEG : Endif
If GNBLEG=1 and GLEGACT = 1 : PARMSK(1) = GDOSLEG : Endif       # only one legislation and LEG activity code inactive?
# X3-91211 end
Call S_TAB_CHAR(COD,PARMSK,"SELJOU","SELJOU","") From GACTION
End

