#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRAXE
mkstat = 0
zoncou = "NBRAXE"
indice = 0
status = 1
zoncou = "NBRAXE"
If varmode([M]NBRAXE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRAXE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRAXE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRAXE = nolign
   status = 75
   Call SAI_NBRAXE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CCEINI
mkstat = 0
zoncou = "CCEINI"
indice = 0
WCHAR = [M]CCEINI
If varmode([M]CCEINI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCEINI" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCDE"
 Call CONTCDE([M]CCEINI,"") From SUBCDE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCEINI" : GZNUM = 4054 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]CCEINI
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]CCEINI = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CCEINI" : GZNUM = 4054 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CCEINI or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_CCEINI([M]CCEINI) From SUBHRTIM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCEINI" : GZNUM = 4054 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CCEINIDES
mkstat = 0
zoncou = "CCEINIDES"
indice = 0
If varinit([M]CCEINIDES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]CCEINIDES,"CACCEDEF","DESTRA",[M:HRTIM2]CCEINI,"") From ATEXTRA
 GACTION = SAVACT
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRAXE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRAXE
mkstat = 0
zoncou = "NBRAXE"

## Zone CCEDAC
mkstat = 0
zoncou = "CCEDAC"
IMPENT = [M]CCEDAC(indice)
If varinit([M]CCEDAC,indice)=0
 IMPENT = 1
Endif
If varmode([M]CCEDAC,indice)=0
 [M]CCEDAC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCEDAC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CCEDAC(indice)
 Endif
Endif
[M]CCEDAC(indice) = IMPENT

## Zone CCE
mkstat = 0
zoncou = "CCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("CCE","!",[M]CCE(indice),num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CNTCCE"
   Call SECTION([M]CCE(indice),1,"",[0/0/0],[M]DIE(nolign-1)) From SUPCPT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRAXE
mkstat = 0
zoncou = "NBRAXE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRTIM2"
Return

