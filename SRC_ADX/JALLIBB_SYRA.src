#<AdxTL>@(#)0.0.0.0 $Revision$
# Syracuse compliant version of JALLIBB Subprogs
#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités
# Cette séquence n'est plus utilisée
# Chargement capacité
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
Subprog LOACAP(LDATD,LDATF,LCAP,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
#Local    Char WMESS(250)
Local    Integer INBR  : INBR = 1                # llc 09.03 19553

#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
Gosub LOAD_CPV From JALLIBB
If LRET : End : Endif

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS From JALLIBB
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))
    WNBR = [F:MWS]WSTNBR

    # lecture schéma horaire
    Gosub LOAD_TWD_FROM_CPV From JALLIBB
    If LRET : Break : Endif

$S_CAP
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J) * WNBR
        Endif
    Else
        LCAP(I) = 0
    Endif

    # Can't allow entry point if called from Syracuse
    # point d'entrée génération pondération capacité    19553
    #Gosub PE_CAPACITY

$L_CAP
    WDATD += 1
    I     += 1
    IPER   = 0
Wend


End

#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités
# Chargement capacité + nb exemp.
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LNBR  : Tableau des nombres d'exemplaires en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
Subprog LOACAPN(LDATD,LDATF,LCAP,LNBR,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LNBR()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Integer INBR  : INBR = 1                # llc 09.03 19553
#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IDISP, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 optimisation
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV From JALLIBB
  If LRET : End : Endif
Endif

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS From JALLIBB
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))

    WNBR = [F:MWS]WSTNBR

    # lecture schéma horaire
    Gosub LOAD_TWD_FROM_CPV From JALLIBB
    If LRET : Break : Endif
    LNBR(I) = WNBR

$S_CAPN
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J) * LNBR(I)
        Endif
    Else
        LCAP(I) = 0
    Endif

    # Can't allow entry point if called from Syracuse
    # point d'entrée génération pondération capacité    19553
    #Gosub PE_CAPACITY

$L_CAPN
    WDATD += 1
    I     += 1
    IPER   = 0
Wend

End

#########################################################################
# remplace NEWCALDFR 09.2009
# prise en compte des schémas journaliers v6
Subprog CALDFR(LFCY,LDATE,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST,LDEFDIH)
Value    Char     LFCY
Value    Date     LDATE
Variable Decimal  LHOUD
Variable Char     LHOUC
Variable Decimal  LDAYCAP
Variable Decimal  LDAYFR
Value    Char     LWST
Value    Char     LDEFDIH()

Local Integer WCODCAP : WCODCAP=1
Call CALDFRCAP(LFCY,LDATE,WCODCAP,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST,2,LDEFDIH)

End


#########################################################################
# Issue 108897 by GA 07/2015 sometimes CALDFR need to avoid using weekly structure
Subprog CALDFRCAP(LFCY,LDATE,LCODCAP,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST,LTYP,LDEFDIH)
Value    Char     LFCY
Value    Date     LDATE
Value    Integer  LCODCAP   # Issue 108897: New parameter
Variable Decimal  LHOUD
Variable Char     LHOUC
Variable Decimal  LDAYCAP
Variable Decimal  LDAYFR
Value    Char     LWST
Value    Integer  LTYP      # Issue 108897: New parameter 1=pre-op time, 2=Op time, 3=post-op time
Value    Char     LDEFDIH()

Local    Decimal  WDAYFR, WTIME, WDURATION, WSTARTD, WDIFF
#Local    Char     WSTARTC
Local    Integer  J, K, LRET

Local File WORKSTATIO [MWS]
Local File TABWEEDIA  [TWD]
Local File DIAHOU     [DIH]
Local File CAPVAR     [CPV] # Issue 108515 GA 06/2015


# lecture poste
Gosub LOAD_MWS From JALLIBB
If LRET : End : Endif

# Issue 108515 GA 06/2015 - start - Is there any Capacity variation ?
# lecture schéma de référence
#Gosub LOAD_TWD_FROM_MWS
#If LRET : End : Endif
# lecture variations de capacité
Local Integer IVAR, WNBR, IPER : Raz IVAR, IPER
Local Date    WDATD : WDATD = LDATE
Local Date    WDATF : WDATF = LDATE
WNBR=[F:MWS]WSTNBR
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV From JALLIBB
  If LRET : End : Endif
Endif
# lecture schéma horaire
Gosub LOAD_TWD_FROM_CPV From JALLIBB
If LRET : End : Endif
# Issue 108515 GA 06/2015 - end

J = dayn(LDATE) - 1

# lecture schéma horaire
If [F:DIH]NUM <> [F:TWD]DIAHOU(J)
    Read [DIH]DIH0=[F:TWD]DIAHOU(J)
    If fstat : Raz [F:DIH] : Endif
Endif

If [F:DIH]NUM = ""
    Read [DIH]DIH0=LDEFDIH
    If fstat : Raz [F:DIH] : Endif
Endif

# plafonne journée à 24h
If LDAYCAP > 24 : LDAYCAP = 24 : Endif
# prise en compte découpage horaire
If LDAYCAP <= 0 : LDAYCAP = 24 : Endif

# Issue 108897 by GA 07/2015 sometimes CALDFR need to avoid using weekly structure
#   LCODCAP = 0 : universal calendar 24h/day
#             1 : regarding LCAP
#             2 : universal calendar 24h/day
#                 - backward scheduling keep post-op time after  day work
#                 - forward scheduling  keep pre-op  time before day work
If LCODCAP <> 1
    LDAYCAP = 24 : WSTARD=0
    WDIFF = LHOUD - WSTARTD
    If WDIFF > LDAYCAP   : WDIFF = LDAYCAP : Endif

    If WDIFF > 0
        WDAYFR = WDIFF / LDAYCAP
        LDAYFR = WDAYFR
    Else
        LDAYFR = 0
    Endif

    Goto CALDFR_END
Endif

# Issue 108515 GA 06/2015 old method is obsolete, even if LDAYCAP=24
# si capa = 24 ou pas de schéma horaire, méthode v5
#If LDAYCAP = 24 | (dim([F:DIH]STRHOU) <= 0)
If (dim([F:DIH]STRHOU) <= 0)
    Local File PARJAL [PJA]
    Read [PJA]PJA0 = LFCY
    If fstat
        Raz [F:PJA]
    Endif
    If (LDAYCAP > 0  & LDAYCAP <= 10)
        Call CONVHOU([F:PJA]STRTEAM1,WSTARTD) From JALLIBB
    Endif
    If (LDAYCAP > 10 & LDAYCAP <= 20)
        Call CONVHOU([F:PJA]STRTEAM2,WSTARTD) From JALLIBB
    Endif

    WDIFF = LHOUD - WSTARTD
    If WDIFF > LDAYCAP   : WDIFF = LDAYCAP : Endif

    If WDIFF > 0
        WDAYFR = WDIFF / LDAYCAP
        LDAYFR = WDAYFR
    Else
        LDAYFR = 0
    Endif
    Goto CALDFR_END
Endif
# parcours des horaires
For K = 0 To dim([F:DIH]STRHOU) - 1

    If K = 0 & LHOUC <= [F:DIH]STRHOU(K)
        LDAYFR = 0
        Break
    Endif

    If LHOUC <= [F:DIH]ENDHOU(K)
        # incohérence, si heure pendant un break, on réaligne sur début tranche
        If LHOUC < [F:DIH]STRHOU(K) : LHOUC = [F:DIH]STRHOU(K) : Endif
        Call DURATIONFROMDIH([F:DIH]STRHOU(K), LHOUC, WDURATION) From JALLIBB
        WTIME += WDURATION
        Break
    Endif

    # calcul durée ligne horaire
    Call DURATIONFROMDIH([F:DIH]STRHOU(K), [F:DIH]ENDHOU(K), WDURATION) From JALLIBB
    WTIME += WDURATION
Next K

If WTIME > LDAYCAP
    WDAYFR = 1
Else
    WDAYFR = WTIME / LDAYCAP
Endif
LDAYFR = WDAYFR

$CALDFR_END
End

#########################################################################
# Conversion fraction de jour en heure HH:MM suivant schéma horaire
# Si traitement de masse, penser à ouvrir les tables suivantes:
#    WORKSTATIO - TABWEEDIA - DIAHOU - CAPVAR
Subprog OPETIME(LDEFDIH, LFCY, LWST, LDAT, LFRACTION, LHOUR)
Value     Char    LDEFDIH
Value     Char    LFCY
Value     Char    LWST
Value     Date    LDAT
Value     Decimal LFRACTION
Variable  Char    LHOUR

Local Integer IEND : IEND = 0
Local Integer J,K
Local Integer LRET, WNBR
Local Decimal WTIME, WDURATION, WDURTOT
Local Char    WDEFAULT(5) : WDEFAULT = "08:00"        # si pas moyen de calculer une heure on prend 08h00 comme référence
Local Char    WHOURC(5)                               # Issue 108515 GA 06/2015
Raz WTIME, WDURATION, WDURTOT                         # Issue 108515 GA 06/2015

Local    Date WDATD : WDATD = LDAT
Local    Date WDATF : WDATF = LDAT                   # Issue 95695 & 96955 GA 02/2014 mandatory for LOAD_CPV
Local Integer J, K, IVAR, WNBR, IPER, LRET
Raz LRET, IVAR, IPER

Raz LHOUR
If LDAT = [0/0/0] : End : Endif
Local File WORKSTATIO [MWS]
Local File TABWEEDIA  [TWD]
Local File DIAHOU     [DIH]
Local File CAPVAR     [CPV]


# lecture poste
Gosub LOAD_MWS From JALLIBB
If LRET : End : Endif
WNBR = [F:MWS]WSTNBR

# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 optimisation
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV From JALLIBB
  If LRET : End : Endif
Endif

# lecture schéma horaire
WDATD=LDAT
Gosub LOAD_TWD_FROM_CPV From JALLIBB
If LRET : End : Endif

J = dayn(LDAT) - 1
# calcul temps
WTIME = LFRACTION * [F:TWD]DAYCAP(J)

# lecture schéma horaire
If [F:DIH]NUM <> [F:TWD]DIAHOU(J)
    Read [DIH]DIH0=[F:TWD]DIAHOU(J)
    If fstat : Raz [F:DIH] : Endif
Endif
If [F:DIH]NUM = ""
    Read [DIH]DIH0=LDEFDIH
    If fstat : Goto END_TIME : Endif
Endif

# parcours des horaires
For K = 0 To dim([F:DIH]STRHOU) - 1
    If WTIME = 0 : LHOUR = [F:DIH]STRHOU(K) : IEND = 1 : Break : Endif
    If [F:DIH]STRHOU(K) ="" : Break : Endif   # Issue 108515 GA 06/2015
    # calcul durée ligne horaire
    Call DURATIONFROMDIH([F:DIH]STRHOU(K), [F:DIH]ENDHOU(K), WDURATION) From JALLIBB
    WDURTOT+=WDURATION                        # Issue 108515 GA 06/2015
    WHOURC=[F:DIH]STRHOU(K)                   # Issue 108515 GA 06/2015
    # Issue 108515 GA 06/2015 Add WDURATION to check [F:TWD]DAYCAP(J)
    If WDURATION >= WTIME : Break : Endif
    WTIME -= WDURATION
Next K

If IEND : End : Endif
If K > dim([F:DIH]STRHOU) - 1 : Goto END_TIME : Endif
If WHOURC=""                  : Goto END_TIME : Endif : # Issue 112302 - 2015-11-10 by GH - not calculate LHOUR from WHOURC blank

Call ADDDURATIONTOHOUR(WHOURC, WTIME, LHOUR) From JALLIBB

# Issue 108515 GA 06/2015 [F:TWD]DAYCAP(J) is not ok
# Time table schema duration is less than daily capacity: Warning !
If WTIME>0
   # Issue 112302 - 2015-11-10 by GH - calculation of WDURTOT for all time periods whatever the valeur of WTIME is
   For I = K+1 To dim([F:DIH]STRHOU) - 1
       If [F:DIH]STRHOU(I) ="" : Break : Endif
       # calcul durée ligne horaire
       Call DURATIONFROMDIH([F:DIH]STRHOU(I), [F:DIH]ENDHOU(I), WDURATION) From JALLIBB
       WDURTOT+=WDURATION
   Next I
   #If [F:TWD]DAYCAP(J)<>WDURTOT : # Issue 116202 18/05/2016 by GH - rounding management
   If abs(WDURTOT-[F:TWD]DAYCAP(J))>=0.01
      If K>0 & LFRACTION=1 : LHOUR=[F:DIH]ENDHOU(K-1) : Endif
      If GTRACE<>""
         #Call ECR_TRACE("Inconsistent Time table schema duration/Capacity for"-LWST-[F:TWD]TWD-[F:TWD]DIAHOU(K)-num$([F:TWD]DAYCAP(J))-num$(WDURTOT+WDURATION),-1) From GESECRAN
         Call ECR_TRACE(mess(332,193,1)-LWST-day$(J+1)-format$("D:"+GFMDAT4,LDAT)-":"
&                      -[F:TWD]TWD+"="+num$([F:TWD]DAYCAP(J))-mess(30,197,1)-"<>"-[F:DIH]NUM+"="+num$(arr(WDURTOT,0.001))-mess(30,197,1),-1) From GESECRAN
      Endif
   Endif
Endif

$END_TIME
# si rien de calculé, par défaut on prend début = 08h00
If LHOUR = "" : Call ADDDURATIONTOHOUR(WDEFAULT, WTIME, LHOUR) From JALLIBB : Endif
If LHOUR = "2400"  : LHOUR = "2359" : Endif
End

#########################################################################
# Calcul date début / fin et durée
#   LSIG    = "+" ou "-"
#   LDAT    = Date de référence
#   LDAYFR  = Fraction de jour correspondante
#   LTIME   = Temps(en H/100)
#   LDATD   = Date de début calendrier
#   LDATF   = Date de fin calendrier
#   LCODCAP = 0 : calendrier universel
#             1 : fonction de LCAP
#   LCAP    = Table capacités
#   LDUR    = Durée calculée (en J/100)
#   LDATR   = Date résultat
#   LDFRR   = Fraction de jour résultat
#   LNBRD   = Table nombre de postes
#   LNBR    = nombre de poste utilisé par l'opération
#   LTYP    = type de temps (1 = prp, 2 = réglage/opératoire, 3 = post/attente)
#   LFCY    = site - required for STRTEAM1 and STRTEAM2 values from scheduling parameters
# réécriture 06.05 (prise en compte heures début de travail)
Subprog CALDUR(LSIG,LDAT,LDAYFR,LTIME,LDATD,LDATF,
&              LCODCAP,LCAP,LDUR,LDATR,LDFRR,LNBRD,LNBR,LTYP,LFCY)
Value    Char     LSIG()
Variable Date     LDAT
Variable Decimal  LDAYFR
Variable Decimal  LTIME
Variable Date     LDATD
Variable Date     LDATF
Variable Integer  LCODCAP
Variable Decimal  LCAP()
Variable Decimal  LDUR
Variable Date     LDATR
Variable Decimal  LDFRR
Variable Integer  LNBRD()
Variable Integer  LNBR
Value    Integer  LTYP           : # GA 08/2008 paramètre manquant  (non utilisé ???)
Value    Char     LFCY() # Need to pass site for STRTEAM1
#
Local    Integer  I
Local    Decimal  WCAP, WCAPS
Local    Decimal  WTIME
Local    Decimal  WDISP, WDISPA, WDISPR # Issue 82755 GA 10/2014 WDISP rounded
Local    Decimal  WDFR
Local    Date     WDAT
Local    Integer  OFFSET : OFFSET = 0

#
# 06.05 31012
Local    Decimal  WSTARTD

# 83321
If LDAT = [0/0/0] : End : Endif

LDUR = 0
LDATR = LDAT
LDFRR = LDAYFR
If LTIME > 0
    WDAT = LDAT
    WTIME = LTIME
    WDFR = LDAYFR
    # 05.05 30281
    If WDFR > 0.9999 & LSIG = "+" & WDAT <> [0/0/0]
        WDAT += 1
        LDATR = WDAT
        WDFR = 0
    Endif
    # 05.05 30281
    If WDFR < 0.0001 & LSIG = "-" & WDAT <> [0/0/0]
        WDAT -= 1
        LDATR = WDAT
        WDFR = 1
    Endif
    I = WDAT - LDATD
    If I < 0 : I = 0 : Endif
    If I > (dim(LCAP) - 1) : I = dim(LCAP) - 1 : Endif
    If I > LDATF-LDATD : WDAT = LDATF : I = LDATF-LDATD : LDATR = WDAT : Endif

    # Sens du parcours
    If LSIG = "+"

        # parcours aval
        While ((I < (LDATF-LDATD)) & (I <= dim(LCAP) -1))
            Gosub INIT_STARTD
            If LCODCAP = 0
                WCAP   = 24
                If LCAP(I) <> 0
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) : Else : WCAP = LCAP (I) : Endif
                    WDISPA = (24 - (WDFR * WCAP) - WSTARTD)
                Else
                    WDISPA = 24
                Endif
                WDISP   = WDISPA
            Else
                # si nb poste utilisé >= nb poste dispo, capacité max
                # sinon capacité "utile" = capacité unitaire * nb poste utilisé
                If LNBRD(I) <= LNBR
                    WCAP = LCAP(I)
                Else
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR : Else : WCAP = LCAP (I) : Endif
                Endif
                WDISP = WCAP * (1-WDFR)
            Endif
            WDISPR=arr(WDISP,10^-6) # Issue 82755 GA 10/2014 WDISP rounded
            If WTIME <= WDISPR
                Break 1
            Else
                LDUR += 1 - WDFR
                LDATR += 1
                WTIME -= WDISP
                If (I + 1) < dim(LCAP) - 1
                    If (LCODCAP = 0 & LCAP(I+1) > 0)
                        OFFSET = 1
                        Gosub INIT_STARTD
                        WTIME -= WSTARTD
                    Endif
                Endif
                WDFR = 0
                I += 1
            Endif
        Wend
        LDFRR = WDFR
        If WCAP > 0
            If LCODCAP <> 1
                # 03.06 35265
                If WTIME >= (WCAP * (1-WDFR))
                    LDFRR = 1
                    LDUR += 1 - WDFR
                Else
                    LDUR += WTIME / WCAP
                    If LDUR < 0.0001
                        LDUR = 0.0001
                    Endif
                    # 03.06 35265
                    If WCAP <> 0 : LDFRR = WDFR + WTIME / WCAP : Else : LDFRR = WDFR : Endif        # 09.04 24927
                Endif
                # sur temps hors charge on peut dépasser 1
                If LDFRR > 1 : LDATR += 1 : LDFRR = 0 : Endif
            Else
                LDUR += WTIME / WCAP
                If LDUR < 0.0001
                   LDUR = 0.0001
                Endif
                LDFRR = WDFR + WTIME / WCAP
            Endif
        Endif
        If LDFRR < 0.0001
          If LCODCAP <> 1 | (I>0 & LCAP(I-1) > 0) # Issue 82755 GA 10/2014
            LDATR -= 1
            LDFRR = 1
          Else
          # Issue 82755 GA 10/2014 check capacity
          # Except when previous day is a day off
            LDFRR = 0
          Endif
        Endif
    Else
    # parcours amont
        While I > 0
            Gosub INIT_STARTD
            If LCODCAP <> 1
                WCAP = 24
                If LCAP(I) <> 0
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) : Else : WCAP = LCAP (I) : Endif
                    WDISPA = (WDFR * WCAP) + WSTARTD
                Else
                    WDISPA = 24
                Endif
                # Issue 112545 - 2015-12-03 by LLC/BEEBE : waiting time longer than 24h will be clacouated badly
                #                                          bug in the enhancement made under requirement 108897
                #WDISP   = 24 # Issue 108897 by GA 07/2015 before WDISPA
                WDISP = WDISPA
            Else
                # si nb poste utilisé >= nb poste dispo, capacité max
                # sinon capacité "utile" = capacité unitaire * nb poste utilisé
                If LNBRD(I) <= LNBR
                    WCAP = LCAP(I)
                Else
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR : Else : WCAP = LCAP (I) : Endif
                Endif
                WDISP = WCAP * WDFR
            Endif
            WDISPR=arr(WDISP,10^-6) # Issue 82755 GA 10/2014 WDISP rounded
            If WTIME <= WDISPR
                Break 1
            Else
                LDUR += WDFR
                LDATR -= 1
                WTIME -= WDISP
                If (I - 1) > 0
                    If (LCODCAP <> 1 & LCAP(I-1) > 0)
                        OFFSET = -1
                        Gosub INIT_STARTD
                    If LNBRD(I-1) > 0 : WCAP = (LCAP(I-1) / LNBRD(I-1)) : Else : WCAP = LCAP (I-1) : Endif
                        WTIME -= (24 - WCAP - WSTARTD)
                    Endif
                Endif
                WDFR = 1
                I -= 1
            Endif
        Wend
        LDFRR = WDFR
        If WCAP > 0
            If LCODCAP <> 1
                 # 03.06 35265
                 If WTIME >= (WCAP * WDFR)
                    LDFRR = 0
                    LDUR += WDFR
                Else
                    LDUR += WTIME / WCAP
                    If LDUR < 0.0001
                        LDUR = 0.0001
                    Endif
                    # 03.06 35265
                    If WCAP <> 0 : LDFRR = WDFR - WTIME / WCAP : Else : LDFRR = WDFR : Endif
                    # sur temps hors charge on peut dépasser 1
                    If LDFRR < 0 : LDATR -= 1 : LDFRR = 1 : Endif
                    # Issue 108897 by GA 07/2015 LTYP=3 post-operation/waiting time
                    # hors charge sur periode non travaillée - time not worked out load period
                    If WDISPR-WTIME>WDISPA & LTYP=3 & LCODCAP=2 : LDFRR = 1 : Endif
                Endif
            Else
                LDUR += WTIME / WCAP
                If LDUR < 0.0001
                    LDUR = 0.0001
                Endif
                LDFRR = WDFR - WTIME / WCAP
            Endif
        Endif
        If LDFRR > 0.9999
          If LCODCAP <> 1 | (I <= dim(LCAP)-2 & LCAP(I+1) > 0) # Issue 82755 GA 10/2014
            LDATR += 1
            LDFRR = 0
          Else
          # Issue 82755 GA 10/2014 check capacity
          # Except when next day is a day off
            LDFRR = 1
          Endif
        Endif
    Endif
    If LCODCAP <> 1 : LDUR = LTIME / 24 : Endif
Endif

End

#########################################################################
# 06.06 31012
$INIT_STARTD
WSTARTD = 0
If LNBRD(I+OFFSET) > 1 : WCAPS = LCAP(I+OFFSET) / LNBRD(I+OFFSET) : Else : WCAPS = LCAP(I+OFFSET) : Endif
If WCAPS > 24 : WCAPS = 24 : Endif
If dim(LCODCAP)>0 & LCODCAP <> 1
    WCAPS = 24          # Issue 108897 by GA 07/2015
Else
  Local File PARJAL [PJA]
  Read [PJA]PJA0 = LFCY
  If fstat
    Raz [F:PJA]
  Endif
  If WCAPS > 0  & WCAPS <= 10 : Call CONVHOU([F:PJA]STRTEAM1,WSTARTD) From JALLIBB : Endif
  If WCAPS > 10 & WCAPS <= 20 : Call CONVHOU([F:PJA]STRTEAM2,WSTARTD) From JALLIBB : Endif
  Close File [PJA]
Endif
OFFSET = 0
Return

#########################################################################
# Chargement WORKLOAD du poste par l'opération
#   LMFGFCY  = Site
#   LWCR     = centre de charge
#   LWST     = code du poste
#   LMFGSTA  = statut OF
#   LCODORI  = Origine demande (2 = CBN, 3 = PDP)
#   LCAL     = numéro du calendrier
#   LCAP     = table des capacités journalières
#   LINFSTRD = date début
#   LINFSTRF = Fraction de jour début
#   LINFENDD = date fin
#   LINFENDF = Fraction de jour fin
#   LNBRD    = table des exemplaires journaliers
#   LNBR     = Nombre exemplaires demandé
#   LCOELAB  = Coefficient correctif main d'oeuvre
#   LSEC     = Mode MA ou MO principal: 0, Mode poste secondaire: 1            # 03.06 35162
#   LNBRP    = nombre d'exemplaire demandé poste principal                     # 03.06 35162
#   LUSER    = Current user
#   LRET  : code retour
#
# 03.06 35162
Subprog WSTLOAD(LMFGFCY,LWCR,LWST,LMFGSTA,LCODORI,LCAL,LCAP,LINFSTRD,LINFSTRF,
&               LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LSEC,LNBRP,LUSER,LRET)
Variable Char     LMFGFCY
Variable Char     LWCR
Variable Char     LWST
Variable Integer  LMFGSTA
Value    Integer  LCODORI
Variable Char     LCAL
Variable Decimal  LCAP()
Variable Date     LINFSTRD
Variable Decimal  LINFSTRF
Variable Date     LINFENDD
Variable Decimal  LINFENDF
Variable Integer  LNBRD()
Variable Integer  LNBR
Variable Decimal  LCOELAB
Value    Integer  LSEC           # 03.06 35162
Variable Integer  LNBRP          # 03.06 35162
Value    Char     LUSER()
Variable Integer  LRET

Local    Integer  I
Local    Integer  WRET
Local    Decimal  WCALC
Local    Decimal  WCAP
Local    Decimal  WDFR
Local    Date     WDATD
Local    Decimal  WENDDFR
Local    Date     WSTRDAT
Local    Date     WENDDAT

Raz WRET
I = 0
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif

Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST
&            Order By Key WKL0
Read [WKL]WKL0 First
If fstat = 4
    fstat = 0
    Call INIWKL(LMFGFCY,LWCR,LWST,LUSER,WRET) From JALLIBC_SYRA
Endif
Filter [WKL]

WSTRDAT = LINFSTRD
WDFR = LINFSTRF
If WDFR = 1
    WSTRDAT += 1
    I += 1
    WDFR = 0
Endif
WENDDAT = LINFENDD
WENDDFR = LINFENDF
If WENDDFR = 1
    WENDDAT += 1
    WENDDFR = 0
Endif

# ----- PE FILTERWKL
# entry point not available in syracuse mode
#If dim(GCAPACITY) > 0
#    GPE = 0
#    GPOINT = "FILTERWKL" : Gosub ENTREE From EXEFNC
#Endif
# -----
# If !GPE
Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST & PEREND >= WSTRDAT
&                Order By Key WKL0
# Endif

Read [WKL]WKL0 First
If fstat = 4 : Goto END_WSTLOAD : Endif
If fstat = 1 : LRET = 1 : Goto END_WSTLOAD : Endif

WDATD = WSTRDAT

While (WDATD <= WENDDAT) & (I <= dim(LCAP) -1)            # 08.06 37503

    If WDATD > [F:WKL]PEREND
        Readlock [WKL]WKL0 Next
        If fstat : Break : Endif
    Endif

    If WDATD = WENDDAT : WDFR += (1-WENDDFR) : Endif

    # 03.06 35162
    If LSEC
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBRP : Else  : WCAP = 0 : Endif
         Endif
    Else
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR  : Else  : WCAP = 0 : Endif
         Endif
    Endif

    WCALC = WCAP * LCOELAB * (1-WDFR)
    WCALC = arr(WCALC,0.0001)

    [F:WKL]PERLOD += WCALC
    Case LMFGSTA
        When 1 : [F:WKL]OWFLOD += WCALC
        When 2 : [F:WKL]OWPLOD += WCALC
        When 3 : If LCODORI = 3
                     [F:WKL]ORSLOD += WCALC
                 Else
                     [F:WKL]OWSLOD += WCALC
                 Endif
    Endcase
    [F:WKL]UPDDAT = date$
    [F:WKL]UPDUSR = LUSER

    # ----- PE WORKLOAD
    # entry point not available in syracuse mode
#    If dim(GCAPACITY) > 0
#        If GWKLACT <> "" : GPOINT = "WORKLOAD" : Gosub ENTREE From EXEFNC : Endif
#    Endif
    # -----

    Rewrite [WKL]
    WDATD += 1
    I += 1
    WDFR = 0
Wend

$END_WSTLOAD
Filter [WKL]
fstat = 0
End


#########################################################################
# Déchargement WORKLOAD du poste par l'opération
#   LMFGFCY  = Site
#   LWST     = code du poste
#   LMFGSTA  = statut OF
#   LCODORI  = origine demande (2 = CBN, 3 = PDP)
#   LCAL     = numéro du calendrier
#   LCAP     = table des capacités journalières
#   LINFSTRD = date début
#   LINFSTRF = Fraction de jour début
#   LINFENDD = date fin
#   LINFENDF = Fraction de jour fin
#   LNBRD    = table exemplaires journalier
#   LNBR     = Nombre exemplaires demandé
#   LCOELAB  = Coefficient correctif main d'oeuvre
#   LSEC     = Mode MA ou MO principal: 0, Mode poste secondaire: 1            # 03.06 35162
#   LNBRP    = nombre d'exemplaire demandé poste principal                     # 03.06 35162
#   LUSER    = Current user
#   LRET     = code retour
#
# 03.06 35162
Subprog WSTUNLD(LMFGFCY,LWST,LMFGSTA,LCODORI,LCAL,LCAP,LINFSTRD,LINFSTRF,
&               LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LSEC,LNBRP,LUSER,LRET)
Variable Char     LMFGFCY
Variable Char     LWST
Variable Integer  LMFGSTA
Value    Integer  LCODORI
Variable Char     LCAL
Variable Decimal  LCAP()
Variable Date     LINFSTRD
Variable Decimal  LINFSTRF
Variable Date     LINFENDD
Variable Decimal  LINFENDF
Variable Integer  LNBRD()
Variable Integer  LNBR
Variable Decimal  LCOELAB
Value    Integer  LSEC           # 03.06 35162
Variable Integer  LNBRP          # 03.06 35162
Value    Char     LUSER
Variable Integer  LRET
#
Local    Integer  I
Local    Integer  WRET
Local    Decimal  WCALC
Local    Decimal  WCAP
Local    Decimal  WDFR
Local    Date     WDATD
Local    Decimal  WENDDFR
Local    Date     WSTRDAT
Local    Date     WENDDAT
#
Raz WRET
I = 0

#
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
#
WSTRDAT = LINFSTRD
WDFR = LINFSTRF
If WDFR = 1
    WSTRDAT += 1
    I += 1
    WDFR = 0
Endif
WENDDAT = LINFENDD
WENDDFR = LINFENDF
If WENDDFR = 1
    WENDDAT += 1
    WENDDFR = 0
Endif
#
# ----- PE FILTERWKL
# entry point not available in syracuse mode
#If dim(GCAPACITY) > 0
#    GPE = 0
#    GPOINT = "FILTERWKL" : Gosub ENTREE From EXEFNC
#Endif
# -----
#If !GPE
    Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST & PEREND >= WSTRDAT
&                Order By Key WKL0
#Endif

Read [WKL]WKL0 First
If fstat = 4 : Goto END_WSTUNLD : Endif
If fstat = 1 : LRET = 1 : Goto END_WSTUNLD : Endif

WDATD = WSTRDAT

While (WDATD <= WENDDAT) & (I <= dim(LCAP) -1)            # 08.06 37503

    If WDATD > [F:WKL]PEREND
        Readlock [WKL]WKL0 Next
        If fstat : Break : Endif
    Endif

    If WDATD = WENDDAT : WDFR += (1-WENDDFR) : Endif

    # 03.06 35162
    If LSEC
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBRP : Else  : WCAP = 0 : Endif
         Endif
    Else
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR  : Else  : WCAP = 0 : Endif
         Endif
    Endif

    WCALC = WCAP * LCOELAB * (1-WDFR)
    WCALC = arr(WCALC,0.0001)

    [F:WKL]PERLOD -= WCALC
    Case LMFGSTA
        When 1 : [F:WKL]OWFLOD -= WCALC
        When 2 : [F:WKL]OWPLOD -= WCALC
        When 3 : If LCODORI = 3
                     [F:WKL]ORSLOD -= WCALC
                 Else
                     [F:WKL]OWSLOD -= WCALC
                 Endif
    Endcase

    If [F:WKL]PERLOD < 0 : [F:WKL]PERLOD = 0 : Endif
    If [F:WKL]OWFLOD < 0 : [F:WKL]OWFLOD = 0 : Endif
    If [F:WKL]OWPLOD < 0 : [F:WKL]OWPLOD = 0 : Endif
    If [F:WKL]OWSLOD < 0 : [F:WKL]OWSLOD = 0 : Endif
    If [F:WKL]ORSLOD < 0 : [F:WKL]ORSLOD = 0 : Endif
    [F:WKL]UPDDAT = date$
    [F:WKL]UPDUSR = LUSER

    # ----- PE WORKLOAD
    # entry point not available in syracuse mode
#    If dim(GCAPACITY) > 0
#        If GWKLACT <> "" : GPOINT = "WORKLOAD" : Gosub ENTREE From EXEFNC : Endif
#    Endif
    # -----

    Rewrite [WKL]
    WDATD += 1
    I += 1
    WDFR = 0
Wend

$END_WSTUNLD
Filter [WKL]
fstat = 0
End

