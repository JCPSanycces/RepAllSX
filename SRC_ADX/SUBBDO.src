#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("BDO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "RAZDUP"      : Gosub RAZDUP
 When "ABANDON"     : Gosub ABANDON
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "STATUT"      : Gosub STATUT
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$OUVRE
Gosub OUVFIC
Gosub DEFVAR
Return

$OUVFIC
If clalev([F:BDE])=0  : Local File BUDOD      [BDE]  : Endif
If clalev([F:BDO])=0  : Local File BUDODS     [BDO]  : Endif
If clalev([F:BDE2])=0 : Local File BUDOD      [BDE2] : Endif
If clalev([F:BDO2])=0 : Local File BUDODS     [BDO2] : Endif
If clalev([F:TBU])=0  : Local File TABBUDTYP  [TBU]  : Endif
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUD2])=0 : Local File BUD        [BUD2] : Endif
If clalev([F:BUD3])=0 : Local File BUD        [BUD3] : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:DTP])=0  : Local File CADISTMP   [DTP]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
#150
If clalev([F:GYM])=0  : Local File GACCPYM    [GYM]  : Endif : # Pyramides comptes
If clalev([F:GYK])=0  : Local File GACCPYMLIK [GYK]  : Endif : # Link Groupe Pyramides comptes
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif : # Groupe Pyramides comptes
If clalev([F:CYM])=0  : Local File GCCEPYM    [CYM]  : Endif : # Pyramides Section
If clalev([F:CYK])=0  : Local File GCCEPYMLIK [CYK]  : Endif : # Groupe Pyramides comptes
If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY]  : Endif : # Groupe Pyramides comptes
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Account
If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif : # Account
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif : # Plan de comptes
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif : # Modèle comptable
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif : # Referentiel
If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif : # Axes  analitiques
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif : # Textes trad
Return

$DEFVAR
Local Char ENTITE (GLONFCY)
Local Decimal DIV, MTT
Local Integer I, J, STA, INDAXE
Local Char TABAXI (GLONCCE)(1..9)
Local Char    VALPAR(10)
Local Integer TYPCUR
#Répartition temporelle
Local Decimal COEF(1..99,1..99), TOTCOEF
Local Decimal SUMAMT, SUMQTY, MTREP, QTREP
Local Integer M, N, EXO, NBPER
Local Integer PDEB, PFIN
Local Date    DATDEB,DATFIN
#Extourne
Local Date DATEXT
Local Char LIBEXT (GLONDES)
Local Integer FLGEXT
#Habilitation
Local Integer OKBUD
Local Integer MONOCPY
# Update BUD table
Local Char    BUDDIE(GLONDIE)(9), BUDCCE(GLONCCE)(9) : # To relate dimension of the budget to dimension of the ledger
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)       : # Ledger code, currency of the ledger
Return


$SETBOUT
# Deletion is forbidden. We have to do a reverse entry
# On ne doit pas pouvoir supprimer, il faut passer par une saisie inverse (négative)
Call VIREBOUT(CHAINE,"A") From GOBJET
If [M]ENAEXT<>2 & ! [M:BDO1]OKBUD: CHMEN += "1" : Endif
# Deletion of the buttons : Delete, save, create, duplicate
# suppression des boutons : supprimer, enregistrer, créer + interdiction de duplication
If MONOCPY : Call VIREBOUT(CHAINE,"AMCD") From GOBJET : Endif
Return

$RAZDUP
Raz   [M:BDO1]NUM,BUDTYP
Actzo [M:BDO1]NUM,VER,BUD
Affzo [M:BDO1]NUM,BUDTYP,VER,BUD
For nolign=1 To [M:BDO1]NBLIG
 [M:BDO1]FLGMOD(nolign-1)=0
Next
Raz [M:BDO1]OKBUD
Return

$ABANDON
Actzo [M:BDO1]NUM
Return

$APRES_MODIF
Case COUZON
 When "DES"
  If [M:BDO1]BUD<>"" & GREP<>"D" : SUIZON = "NBLIG([M:BDO1]NBLIG+1)" : Endif
Endcase
Return

$INICRE
# 103234 : mettre en ligne FCY pour le compteur ANM.
If [F:BUP]LEV = 1 : # Budget défini au niveau société
 Call LEC_CPY([M:BDO1]CPY([M:BDO1]NBLIG-1)) From CPTLEC
 Call LEC_FCY([F:CPY]MAIFCY) From CPTLEC
Else
 Call LEC_FCY([M:BDO1]FCY([M:BDO1]NBLIG-1)) From CPTLEC
Endif

Local Char NUMCPT (GLONVCR)
Local Integer VOK
VOK=1
Call COMPTEUR (NUMCPT,VOK)
If ! VOK
 [M:BDO1]NUM=NUMCPT
 Affzo[M:BDO1]NUM
 Gosub SAUVE_LIGNES
Endif
Return

$INIMOD
Gosub SAUVE_LIGNES
Grizo [M:BDO1]NUM,VER,BUD
Return

$LIENS
Call AP_BUD([F:BDE]BUD)
Gosub CHARGE_LIGNES
If [M:BDO1]OKBUD
 If ![M:BDO1]NBLIG
  GMESSAGE = mess(8,123,1) : GOK = 0 : Return   # Accès impossible à cette fiche
 Endif
 Call MESSAGE(mess(55,109,1)) From GESECRAN     # Vos résultats sont restreints à vos droits utilisateurs
Endif
Return

$INI_FMT
[M:BDO1]COA=[F:BUP]COA
Call LECTEXTRA([M:BDO1]LIBCPT,"GCOA","COLHEA",[BUP]COA,"") From ATEXTRA
If [F:BUP]PYMACC<>""
 [M:BDO1]LIBCPT += "/"+[F:BUP]PYMACC
Endif
If [F:BUP]DIE(0) <> ""
 [M:BDO1]FMTCCE1 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(0),"GDIE","COLHEA",[BUP]DIE(0),"") From ATEXTRA
 If [F:BUP]PYMCCE(0)<>""
  [M:BDO1]LIB(0) += "/"+[F:BUP]PYMCCE(0)
 Endif
Else
 [M:BDO1]FMTCCE1 = "-K:15X"
Endif
If [F:BUP]DIE(1) <> ""
 [M:BDO1]FMTCCE2 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(1),"GDIE","COLHEA",[BUP]DIE(1),"") From ATEXTRA
 If [F:BUP]PYMCCE(1)<>""
  [M:BDO1]LIB(1) += "/"+[F:BUP]PYMCCE(1)
 Endif
Else
 [M:BDO1]FMTCCE2 = "-K:15X"
Endif
If [F:BUP]DIE(2) <> ""
 [M:BDO1]FMTCCE3 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(2),"GDIE","COLHEA",[BUP]DIE(2),"") From ATEXTRA
 If [F:BUP]PYMCCE(2)<>""
  [M:BDO1]LIB(2) += "/"+[F:BUP]PYMCCE(2)
 Endif
Else
 [M:BDO1]FMTCCE3 = "-K:15X"
Endif

If [F:BUP]DIE(3)<>""
 [M:BDO1]FMTCCE4 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(3),"GDIE","COLHEA",[BUP]DIE(3),"") From ATEXTRA
 If [F:BUP]PYMCCE(3)<>""
  [M:BDO1]LIB(3) += "/"+[F:BUP]PYMCCE(3)
 Endif
Else
 [M:BDO1]FMTCCE4 = "-K:15X"
Endif
If [F:BUP]DIE(4)<>""
 [M:BDO1]FMTCCE5 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(4),"GDIE","COLHEA",[BUP]DIE(4),"") From ATEXTRA
 If [F:BUP]PYMCCE(4)<>""
  [M:BDO1]LIB(4) += "/"+[F:BUP]PYMCCE(4)
 Endif
Else
 [M:BDO1]FMTCCE5 = "-K:15X"
Endif
If [F:BUP]DIE(5)<>""
 [M:BDO1]FMTCCE6 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(5),"GDIE","COLHEA",[BUP]DIE(5),"") From ATEXTRA
 If [F:BUP]PYMCCE(5)<>""
  [M:BDO1]LIB(5) += "/"+[F:BUP]PYMCCE(5)
 Endif
Else
 [M:BDO1]FMTCCE6 = "-K:15X"
Endif
If [F:BUP]DIE(6)<>""
 [M:BDO1]FMTCCE7 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(6),"GDIE","COLHEA",[BUP]DIE(6),"") From ATEXTRA
 If [F:BUP]PYMCCE(6)<>""
  [M:BDO1]LIB(6) += "/"+[F:BUP]PYMCCE(6)
 Endif
Else
 [M:BDO1]FMTCCE7 = "-K:15X"
Endif
If [F:BUP]DIE(7)<>""
 [M:BDO1]FMTCCE8 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(7),"GDIE","COLHEA",[BUP]DIE(7),"") From ATEXTRA
 If [F:BUP]PYMCCE(7)<>""
  [M:BDO1]LIB(7) += "/"+[F:BUP]PYMCCE(7)
 Endif
Else
 [M:BDO1]FMTCCE8 = "-K:15X"
Endif
If [F:BUP]DIE(8)<>""
 [M:BDO1]FMTCCE9 = "K:15X"
 Call LECTEXTRA([M:BDO1]LIB(8),"GDIE","COLHEA",[BUP]DIE(8),"") From ATEXTRA
 If [F:BUP]PYMCCE(8)<>""
  [M:BDO1]LIB(8) += "/"+[F:BUP]PYMCCE(8)
 Endif
Else
 [M:BDO1]FMTCCE9 = "-K:15X"
Endif

Affzo [M:BDO1]
Return

$CHARGE_LIGNES
Effzo [M:BDO1]15
nolign=0
Raz [M:BDO1]OKBUD
For [F:BDO]BDO0 Where NUM=[M:BDO1]NUM
 # Demande 25826
 Raz mkstat
 [L]OKBUD=1
 If [F:BUP]LEV = 1 : # Budget défini au niveau société
  Call CONTALLFCY([F:BDO]FCY) From CPTSUB
  If mkstat
   Raz OKBUD, mkstat, GMESSAGE
   [M:BDO1]OKBUD = 1
  Endif
 Else
  Call CONTFCY([F:BDO]FCY) From SUPCPT
  If mkstat
   Raz OKBUD, mkstat, GMESSAGE
   [M:BDO1]OKBUD = 1
  Endif
 Endif
 If [L]OKBUD
  nolign += 1
  [M:BDO1]=[F:BDO]
  If [F:BUP]LEV = 1 : # Budget défini au niveau société
   [M:BDO1]CPY(nolign-1) = [F:BDO]CPY
   [M:BDO1]FCY(nolign-1) = ""
  Else
   [M:BDO1]FCY(nolign-1) = [F:BDO]FCY
   Call LECTURE("FCY",[F:BDO]FCY,"") From CONTOBJ
   [M:BDO1]CPY(nolign-1) = [F:FCY]LEGCPY
  Endif
  [M:BDO1]FLGMOD(nolign-1)=1
 Endif
Next
[M:BDO1]NBLIG=nolign
Gosub INI_FMT
Actzo [M:BDO1]NUM
Return

$SAUVE_LIGNES
For nolign=1 To [M:BDO1]NBLIG
 If  [M:BDO1]FLGMOD(nolign-1)<>1 :#on ne sauve que les nouvelles lignes...
  Raz [F:BDO]
  [F:BDO]=[M:BDO1]
  If [F:BUP]LEV = 1 : # Budget défini au niveau société
   [F:BDO]CPY=[M:BDO1]CPY(nolign-1)
  Else
   [F:BDO]FCY=[M:BDO1]FCY(nolign-1)
  Endif
  [F:BDO]NUM=[M:BDO1]NUM
  [F:BDO]LIN=nolign
  [F:BDO]COA = [F:BUP]COA
  [F:BDO]FIY = [M:BDO1]FIYSTR(nolign-1)
  Write [BDO]
  If fstat<>0
   GOK = 0 : Call FSTA("BDO") From GLOCK : Break
  Endif
  Gosub UPD_BUD
  If GOK<1 : Break  : Endif #Dmd32624
 Endif
Next
If GOK<1 : Return  : Endif #Dmd32624
Gosub CHARGE_LIGNES
Return

$UPD_BUD
If [F:BUP]DIVAMT<>0
 DIV = [F:BUP]DIVAMT
Else
 DIV = 1
Endif
Call LEC_CPY([M:BDO1]CPY(nolign-1)) From CPTLEC
Call CTL_DATE([M:BDO1]CPY(nolign-1),[M:BDO1]STRDAT(nolign-1),1)
Call CTL_DATE([M:BDO1]CPY(nolign-1),[M:BDO1]ENDDAT(nolign-1),2)
Gosub CAL_REPTPS

Gosub INIVAR_BUDCCE
For I=[M:BDO1]FIYSTR(nolign-1) To [M:BDO1]FIYEND(nolign-1)
 Readlock [BUD2]BUD0=[M:BDO1]LEDTYP(nolign-1); [M:BDO1]BUD; [F:BDO]CPY;
&         [F:BDO]FCY; I; [M:BDO1]VER; [M:BDO1]ACC(nolign-1);
&         BUDCCE(0); BUDCCE(1); BUDCCE(2); BUDCCE(3); BUDCCE(4);
&         BUDCCE(5); BUDCCE(6); BUDCCE(7); BUDCCE(8)
If fstat=1
  GOK=-1 : GLOCK="$BUD"-[M:BDO1]BUD : Break
 Elsif fstat
  #Création du budget
  Raz [F:BUD2]
  [F:BUD2]ACCNUM = uniqid([F:BUD])
  [F:BUD2]LEDTYP = [M:BDO1]LEDTYP(nolign-1)
  [F:BUD2]BUD    = [M:BDO1]BUD
  [F:BUD2]CPY    = [F:BDO]CPY
  [F:BUD2]FCY    = [F:BDO]FCY
  [F:BUD2]FIY    = I
  [F:BUD2]VER    = [M:BDO1]VER
  [F:BUD2]COA    = [M:BDO1]COA
  [F:BUD2]ACC    = [M:BDO1]ACC(nolign-1)
  [F:BUD2]UOM    = [M:BDO1]UOM(nolign-1)
  [F:BUD2]CCE1   = BUDCCE(0)
  [F:BUD2]CCE2   = BUDCCE(1)
  [F:BUD2]CCE3   = BUDCCE(2)
  [F:BUD2]CCE4   = BUDCCE(3)
  [F:BUD2]CCE5   = BUDCCE(4)
  [F:BUD2]CCE6   = BUDCCE(5)
  [F:BUD2]CCE7   = BUDCCE(6)
  [F:BUD2]CCE8   = BUDCCE(7)
  [F:BUD2]CCE9   = BUDCCE(8)
  [F:BUD2]DIE1   = BUDDIE(0)
  [F:BUD2]DIE2   = BUDDIE(1)
  [F:BUD2]DIE3   = BUDDIE(2)
  [F:BUD2]DIE4   = BUDDIE(3)
  [F:BUD2]DIE5   = BUDDIE(4)
  [F:BUD2]DIE6   = BUDDIE(5)
  [F:BUD2]DIE7   = BUDDIE(6)
  [F:BUD2]DIE8   = BUDDIE(7)
  [F:BUD2]DIE9   = BUDDIE(8)
  [F:BUD2]CREDAT = date$
  [F:BUD2]CREUSR = GUSER
  # Issue X3-51799
  # Columns LED & CUR were not being filled
  [F:BUD2]LED = CODLED
  [F:BUD2]CUR = [F:BUP]CUR
  # End Issue X3-51799
  Gosub MTTQTE
  If GOK>0
   Write [BUD2]
   If fstat
    GOK=0 : Call FSTA("BUD2") From GLOCK : Break
   Endif
  Endif
 Else
  # Mise à jour du budget
  [F:BUD2]UPDDAT = date$
  [F:BUD2]UPDUSR = GUSER
  Gosub MTTQTE
  If GOK>0
    # Issue X3-51799
    # Columns LED & CUR were not being filled
    If [F:BUD2]LED = "" : [F:BUD2]LED = CODLED : Endif
    If [F:BUD2]CUR = "" : [F:BUD2]CUR = [F:BUP]CUR : Endif
    # End Issue X3-51799
   Rewrite [BUD2]
   If fstat
    GOK=0 : Call FSTA("BUD2") From GLOCK : Break
   Endif
  Endif
 Endif
 If GOK<1 : Return  : Endif #Dmd32624
Next
Return

$INIVAR_BUDCCE
Call GET_LEDCUR(GACTX,[F:BDO]CPY,[M:BDO1]LEDTYP(nolign-1),CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
Call LEC_LED(CODLED) From CPTLEC
Raz BUDCCE, BUDDIE
For I=0 To [F:LED]DIENBR-1
 If [F:LED]DIE(I)=[F:BUP]DIE(0)    : BUDCCE(I) = [M:BDO1]CCE1(nolign-1) : BUDDIE(I) = [M:BDO1]DIE1(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(1) : BUDCCE(I) = [M:BDO1]CCE2(nolign-1) : BUDDIE(I) = [M:BDO1]DIE2(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(2) : BUDCCE(I) = [M:BDO1]CCE3(nolign-1) : BUDDIE(I) = [M:BDO1]DIE3(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(3) : BUDCCE(I) = [M:BDO1]CCE4(nolign-1) : BUDDIE(I) = [M:BDO1]DIE4(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(4) : BUDCCE(I) = [M:BDO1]CCE5(nolign-1) : BUDDIE(I) = [M:BDO1]DIE5(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(5) : BUDCCE(I) = [M:BDO1]CCE6(nolign-1) : BUDDIE(I) = [M:BDO1]DIE6(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(6) : BUDCCE(I) = [M:BDO1]CCE7(nolign-1) : BUDDIE(I) = [M:BDO1]DIE7(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(7) : BUDCCE(I) = [M:BDO1]CCE8(nolign-1) : BUDDIE(I) = [M:BDO1]DIE8(nolign-1)
 Elsif [F:LED]DIE(I)=[F:BUP]DIE(8) : BUDCCE(I) = [M:BDO1]CCE9(nolign-1) : BUDDIE(I) = [M:BDO1]DIE9(nolign-1)
 Endif
Next
Return


$MTTQTE
# Recherche de la période début et de la période fin de l'exercice I
Raz PDEB,PFIN
If I=[M:BDO1]FIYSTR(nolign-1) : PDEB = [M:BDO1]PERSTR(nolign-1) : Endif
If I=[M:BDO1]FIYEND(nolign-1) : PFIN = [M:BDO1]PEREND(nolign-1) : Endif
If PDEB=0 : PDEB=1 : Endif
If PFIN=0 : Call NBPER([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),I,PFIN) From CPTSUB : Endif
If PFIN=0 : Return : Endif
# Mise à jour des budgets
If [F:BUP]LEV=2
  ENTITE=[F:BDO]FCY
 Else
  ENTITE=[F:BDO]CPY
 Endif
For J=PDEB To PFIN
If [M:BDO1]CUR(nolign-1)<>[F:BUP]CUR & [M:BDO1]AMT(nolign-1)<>0
  Call PARAM(ENTITE,"BUDTYPCUR",VALPAR) From ADOVAL
  TYPCUR = val(VALPAR)
  If TYPCUR=0  : TYPCUR=1  : Endif
  Call CONVERT([M:BDO1]CUR(nolign-1),[F:BUP]CUR,[F:CPY]ACCCUR,TYPCUR,datesyst,[M:BDO1]AMT(nolign-1),MTT,STA) From TRTDEV
  If STA
   GOK=0
   #Budget XXX - Ligne no xxx : Erreur en conversion devise
   GMESSAGE = mess(47,103,1)-[M:BDO1]BUD-"-"-mess(61,100,1)-num$(nolign)-":"-mess(34,110,1)
   Break : Return
  Endif
 Else
  MTT   =[M:BDO1]AMT(nolign-1)
 Endif
 If TOTCOEF<>0
  MTREP=(MTT)*DIV*COEF(I,J)/TOTCOEF
 Else
  MTREP=(MTT)*DIV
 Endif
 Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
 [F:BUD2]AMT(J-1) += arr(SUMAMT+MTREP,[F:TCU]CURRND)-arr(SUMAMT,[F:TCU]CURRND)
 SUMAMT += MTREP

 If TOTCOEF<>0
  QTREP=[M:BDO1]QTY(nolign-1)*COEF(I,J)/TOTCOEF
 Else
  QTREP=[M:BDO1]QTY(nolign-1)
 Endif

 Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
 [F:BUD2]QTY(J-1) += arr(SUMQTY+QTREP,[F:TCU]CURRND)-arr(SUMQTY,[F:TCU]CURRND)
 SUMQTY += QTREP
Next
Return

# Récupération temporelles
$CAL_REPTPS
Raz COEF, TOTCOEF
If [F:BUP]PYMACC=""
  Call CONTROLE("GAC","",[M:BDO1]ACC(nolign-1),[F:BUP]COA,mkstat) From CONTOBJ
  If !fstat
     Read [DTP]DTP0 = [F:GAC]TIMDSP
  Endif
Else
  Call CONTROLE("GRY","",[M:BDO1]ACC(nolign-1),[F:BUP]PYMACC,mkstat) From CONTOBJ
  If !fstat
     Read [DTP]DTP0 = [F:GRY]TIMDSP
  Endif
Endif
If fstat
 For I=0 To dim([F:DTP]COE)-1
  [F:DTP]COE(I) = 1
 Next
Endif
For EXO=[M:BDO1]FIYSTR(nolign-1) To [M:BDO1]FIYEND(nolign-1)
 # Recherche de la période début et de la période fin de chaque exercice
 Raz PDEB,PFIN
 If EXO=[M:BDO1]FIYSTR(nolign-1) : PDEB = [M:BDO1]PERSTR(nolign-1) : Endif
 If EXO=[M:BDO1]FIYEND(nolign-1) : PFIN = [M:BDO1]PEREND(nolign-1) : Endif
 If PDEB=0 : PDEB=1 : Endif
 If PFIN=0 : Call NBPER([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),EXO,PFIN) From CPTSUB : Endif
 If PFIN=0 : Break : Endif
 # Recherche du coefficient
 NBPER=0
 For I=PDEB To PFIN
  Call DATPER([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),EXO,I,DATDEB,DATFIN) From CPTSUB
  # Renvoie la date début et la date fin de la période I de l'exo EXO pour la sté SIT
  While DATDEB<>[0/0/0]
   M = month(DATDEB)        : # M contient le no du mois de DATDEB
   N = day(eomonth(DATDEB)) : # N contient le dernier jour de DATDEB
   If M=month(DATFIN)       : # J contient le nb de jours de la période
    J = DATFIN-DATDEB+1
    DATDEB = [0/0/0]
   Else
    J = eomonth(DATDEB)-DATDEB+1
    DATDEB = eomonth(DATDEB)+1
   Endif
   COEF(EXO,I) += [F:DTP]COE(M-1)*J/N
  Wend
  TOTCOEF += COEF(EXO,I)
  NBPER+=1
 Next
Next

#Si pas de repartition temporelle, on divisera par le nb de periode.
If TOTCOEF=0 & NBPER>1 : TOTCOEF=NBPER : Endif
Return

Subprog COMPTEUR (NUMBER, POK)
Variable Char NUMBER ()
Variable Integer POK
Local Char    CPT(GLONANM)
Local Integer STA
If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif
If GNBLEG=1
 Call LECTURE("TCA",GDOSLEG(1),"2") From CONTOBJ
 If fstat
  Call LECTURE("TCA","","2") From CONTOBJ
 Endif
Else
 Call LECTURE("TCA","","2") From CONTOBJ
Endif
CPT = [F:TCA]CODNUM(6)
Call NUMERO(CPT,"",datesyst,"",[F:BDE]NUM,STA) From SUBANM
POK=STA
NUMBER=[F:BDE]NUM
If STA
 Case STA
  When 1
   GOK = 0 : GMESSAGE = CPT-":"-mess(2,114,1) : # Compteur inexistant
  When 2
   GOK = 0 : GMESSAGE = CPT-":"-mess(13,114,1) : # Dépassement de compteur
  When 99
   GOK = 0 : GMESSAGE = CPT-":"-mess(18,114,1) : # Transaction abandonnée
 Endcase
 End
Endif
End

# initialisation des paramètres de l'action SAIEXTOUR
$AVANTBOUT
DATEXT=date$
LIBEXT=mess(55,105,1)-":"-[M:BDO1]NUM-GUSER    :#Extourne
FLGEXT=2
Case BOUT
 When "1"
  GBIDC1 = DATEXT
  GBIDC2 = LIBEXT
  GBIDI1 = FLGEXT
Endcase
Return

$STATUT
Case BOUT
 When "1"
  Call DEBTRANS From GLOCK
  Gosub TR_REVERSAL
Endcase
Return

$TR_REVERSAL
GOK = 1
Trbegin [BDE2]
 Local Char    EXTNUM (GLONVCR)
 Local Integer VEXT, SAVE_GNBDERNIER
 VEXT = 1
 DATEXT = GBIDC1
 LIBEXT = GBIDC2
 FLGEXT = GBIDI1
 If FLGEXT=2
  Call COMPTEUR(EXTNUM,VEXT)
  If ! VEXT
   Gosub CRE_BDE
   If GOK=1
    Gosub CRE_BDO
   Endif
   If GOK=1
    CLECUR1 = EXTNUM
    AFFICHE = 1
    # To avoid the call to SET_DERLU in $RELIT because SET_DERLU defines a transaction
    SAVE_GNBDERNIER = GNBDERNIER
    GNBDERNIER = 0
    Gosub RELIT From GOBJSUB
    GNBDERNIER = SAVE_GNBDERNIER
    For nolign=1 To [M:BDO1]NBLIG
     # YYFIN_104036_US9 Hors US
     Raz [F:BDO]
     [F:BDO]CPY = [M:BDO1]CPY(nolign-1)
     [F:BDO]FCY = [M:BDO1]FCY(nolign-1)
     # End YYFIN_104036_US9
     Gosub UPD_BUD
     If GOK<1 : Break : Endif #Dmd32624
    Next
   Endif
  Endif
 Endif
 If GOK<0   : Goto ROLL_TR_REVERSAL
 Elsif !GOK : Goto AB_TR_REVERSAL
 Endif
Commit
Return

$AB_TR_REVERSAL
Rollback

$ROLL_TR_REVERSAL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_REVERSAL : Endif
Return

$CRE_BDE
Raz[F:BDE2]
[F:BDE2]=[M:BDO1]
[F:BDE2]NUM=EXTNUM
[F:BDE2]DES=LIBEXT
[F:BDE2]BUDTYP=""
[F:BDE2]ENAEXT=2
[F:BDE2]DATEXT=DATEXT
[F:BDE2]CREUSR=GUSER
[F:BDE2]CREDAT=date$
Write [BDE2]
If fstat
 GOK=0 : Call FSTA("BDE2") From GLOCK
Endif
Return

$CRE_BDO
For nolign=1 To [M:BDO1]NBLIG
 Raz [F:BDO2]
 [F:BDO2]=[M:BDO1]
 [F:BDO2]AMT=[M:BDO1]AMT(nolign-1)*-1
 [F:BDO2]QTY=[M:BDO1]QTY(nolign-1)*-1
  If [F:BUP]LEV = 1 : # Budget défini au niveau société
     [F:BDO2]CPY=[M:BDO1]CPY(nolign-1)
  Else
     [F:BDO2]FCY=[M:BDO1]FCY(nolign-1)
  Endif

 [F:BDO2]NUM=[F:BDE2]NUM
 [F:BDO2]LIN=nolign
 [F:BDO2]FIY=[M:BDO1]FIYSTR(nolign-1)
 Write [BDO2]
 If fstat<>0
  GOK = 0 : Call FSTA("BDO2") From GLOCK : Break
 Endif
Next
Return

################################################################################
#  Screen BDO1
################################################################################

## Header
Subprog C_NUM(VALEUR)
Variable Char     VALEUR
If (GREP="" or GREP="C" or GREP="D") & VALEUR<>""
 Look [BDO]BDO0 = VALEUR
 If fstat : VALEUR = "" : Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
If GREP="" & VALEUR=""
 mkstat = 4
Endif
End

Subprog AS_BUD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & GREP<>"C" & GREP<>"D"
 mkstat=2 : End
Endif
End

Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Local Char BUDGET(GLONBUP)
Call C_BUD(VALEUR) From BUDSUB : #YYFIN_104036_US9 virer le INDDIE dans BUDSUB
If mkstat : End : Endif
If [F:BUP]BUPODS=1    :#Aucune gestion
 # Code budget non géré par les OD
 GMESSAGE = VALEUR-":"-mess(58,108,1)
 mkstat = 2 : End
Endif
If GREP="D"
 Call AP_BUD(VALEUR)
Endif
End

Subprog AP_BUD(VALEUR)
Variable Char     VALEUR()
Call LECTURE("BUP",VALEUR,"") From CONTOBJ
Gosub INI_FMT
zoncou="NBLIG"
Gosub CHG_FMT From W1BDO1
End

Subprog C_VER(VALEUR)
Variable Char    VALEUR()
If [F:BUV]STA=2
 GMESSAGE = mess(58,109,1) : # Version fermée
 mkstat = 2
Endif
End


## Table

Subprog AS_NBLIG
If [M:BDO1]OKBUD
 GMESSAGE = mess(9,123,1)   # Modification impossible
 mkstat = 2 : Endif
End

Subprog C_NBLIG
If [M:BDO1]FLGMOD(nolign-1)=1
 mkstat = 2 : End
Endif
If [M:BDO1]BUDTYP<>"" & (status=65 or status=68 or status=73 or status=75 or status=82 or status=83)
 GMESSAGE = mess(67,108,1) :#"Modification impossible : OD budgétaire générée"
 mkstat = 2 : End
Endif
End


# Company
Subprog AS_CPY(VALEUR)
Variable Char     VALEUR()
If [F:BUP]LEV=2 : # Site
 mkstat=2 : End
Endif
If nolign-1>0 & VALEUR=""
 VALEUR=[M:BDO1]CPY(nolign-2)
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Raz mkstat
Call CONTALLFCY(VALEUR) From CPTSUB
If mkstat : End : Endif
Call CONTAUZ(VALEUR,"","C") From CPTSUB
If mkstat
    GMESSAGE = mess(25,135,1)-VALEUR    # Vous n'avez pas les droits sur la société
    mkstat=2 : End
Endif
Gosub NBREF
If NB<1
 GMESSAGE = mess(97,108,1) : # Aucun référentiel ne correspond
 mkstat   = 2 : End
Endif
End

$NBREF
Local Integer I , NB , TYPREF, LEDTYP
Local Char    REFER(GLONLED)
Local Char    TCODLED(GLONLED)(1..len(mess(0,2644,1))), CODLED(GLONLED), DEVLED(GLONCUR)

Call LEC_BUP([M]BUD) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC

# on doit initialiser avec la valeur du type de référentiel analytique principal
Call SETREF([F:CPY]CPY,NB,TCODLED) From CPTDIV
# vérifier que le référentiel analytique principal est flaggé budget
Read [LED]LED0=TCODLED(2)
If [F:LED]BUD=2
 ## Recherche du code référentiel et devise référentiel associé au type de référentiel
 ## et à la société passés en paramètres
 Call GET_LEDCUR(GACTX,[F:CPY]CPY,2,CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
 [M:BDO1]LEDTYP(nolign-1)=[F:GCM]ANALEDTYP
 [M:BDO1]LED(nolign-1)=[L]CODLED
Endif

NB = 0
For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2 : # le référentiel ne doit pas être automatique
  Read [LED]LED0 = [F:GCM]LED(I-1)
  OK  = 1
  OK *= ([F:LED]BUD=2)
  OK *= ([F:LED]COA=[F:BUP]COA)
  OK *= (find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(0)="")
  OK *= (find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(1)="")
  OK *= (find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(2)="")
  OK *= (find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(3)="")
  OK *= (find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(4)="")
  OK *= (find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(5)="")
  OK *= (find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(6)="")
  OK *= (find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(7)="")
  OK *= (find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(8)="")
  If OK
   NB += 1
   If NB=1
    TYPREF = I
    REFER  = [F:LED]LED
   Endif
   GMENLOC(I) = 0
  Endif
 Endif
Next I
Return

Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
[M:BDO1]DIE1(nolign-1)=[F:BUP]DIE(0)
[M:BDO1]DIE2(nolign-1)=[F:BUP]DIE(1)
[M:BDO1]DIE3(nolign-1)=[F:BUP]DIE(2)
[M:BDO1]DIE4(nolign-1)=[F:BUP]DIE(3)
[M:BDO1]DIE5(nolign-1)=[F:BUP]DIE(4)
[M:BDO1]DIE6(nolign-1)=[F:BUP]DIE(5)
[M:BDO1]DIE7(nolign-1)=[F:BUP]DIE(6)
[M:BDO1]DIE8(nolign-1)=[F:BUP]DIE(7)
[M:BDO1]DIE9(nolign-1)=[F:BUP]DIE(8)
End


# Site
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR()
If [F:BUP]LEV=1
 mkstat=1 : End
Endif
If nolign-1>0 & VALEUR=""
 VALEUR=[M:BDO1]FCY(nolign-2)
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Gosub NBREF
If NB<1
 GMESSAGE = mess(97,108,1) : # Aucun référentiel ne correspond
 mkstat   = 2 : End
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char     VALEUR()
[M:BDO1]DIE1(nolign-1)=[F:BUP]DIE(0)
[M:BDO1]DIE2(nolign-1)=[F:BUP]DIE(1)
[M:BDO1]DIE3(nolign-1)=[F:BUP]DIE(2)
[M:BDO1]DIE4(nolign-1) = [F:BUP]DIE(3)
[M:BDO1]DIE5(nolign-1) = [F:BUP]DIE(4)
[M:BDO1]DIE6(nolign-1) = [F:BUP]DIE(5)
[M:BDO1]DIE7(nolign-1) = [F:BUP]DIE(6)
[M:BDO1]DIE8(nolign-1) = [F:BUP]DIE(7)
[M:BDO1]DIE9(nolign-1) = [F:BUP]DIE(8)
If [F:BUP]LEV=2
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 [M:BDO1]CPY (nolign-1)=[F:FCY]LEGCPY
 Affzo CPY
Endif
Call CONTAUZ("",VALEUR,"C") From CPTSUB
If mkstat
   GMESSAGE = VALEUR-":"-mess(2,104,1)  : # Vous n'avez pas les droits pour ce site
   mkstat = 2 : End
Endif
End


# Ledger
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("CPY",[M]CPY(nolign-1),"") From CONTOBJ
Gosub NBREF
If NB>=1
 VALEUR = TYPREF
 [M]LED(nolign-1) = REFER
 If NB=1
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
Call LECTURE("CPY",[M]CPY(nolign-1),"") From CONTOBJ
Read [GCM]GCM0 = [F:CPY]ACM
If [F:GCM]LED(VALEUR-1)=""
 GMESSAGE = mess(105,104,1)-[M]CPY(nolign-1) : # Référentiel non défini pour la société
 mkstat = 2 : End
Else
 Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
 If [F:GCM]CFMAUT(VALEUR-1)=2 or [F:LED]BUD<>2
  GMESSAGE = mess(201,111,1) : # Référentiel incorrect
  mkstat = 2 : End
 Else
  If  ([F:LED]COA<>[F:BUP]COA)
&   | ([F:BUP]DIE(0)<>"" & !find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(1)<>"" & !find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(2)<>"" & !find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(3)<>"" & !find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(4)<>"" & !find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(5)<>"" & !find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(6)<>"" & !find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(7)<>"" & !find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)))
&   | ([F:BUP]DIE(8)<>"" & !find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)))
   ## End YYFIN_104036_US9
   GMESSAGE = mess(37,108,1) : # Axes incompatibles
   mkstat = 2 : End
  Endif
 Endif
 [M]LED(nolign-1) = [F:LED]LED
Endif
End

Subprog IB_ACC
If [F:BUP]PYMACC=""
 GBOUT1 = mess(35,103,1) : # Comptes analytiques
 GBIDC3 = "GAC"
 GBIDC1 = [F:BUP]COA
Else
 GBOUT1 = mess(24,103,1) : # Groupe compte
 GBIDC3 = "GRY"
 GBIDC1 = [F:BUP]PYMACC
Endif
End

Subprog C_ACC(VALEUR)
Variable Char VALEUR()
Local Char    CCEACC(max(GLONGAC,GLONCCE)) : # Valeur de la nature ou section
Local Integer OK , IND
If VALEUR<>""
 VALEUR = toupper(VALEUR)
Endif

If [F:BUP]PYMACC=""
 Call CONTROLE("GAC","",VALEUR,[F:BUP]COA,mkstat) From CONTOBJ
 If mkstat : End : Endif
 ## Vérif code d'accès
 Call CONTEXE([F:GAC]ACS) From CPTSUB : # Vérif code d'accès
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 ## Vérif budgétisable
 If [F:GAC]BUDTRK<> 2 : GMESSAGE = mess(4,103,1) : mkstat = 2 : End : Endif : # Compte non budgétisable
 ## Vérif site/société et Dates de validité pour ACC
 ## La nature doit être valide et autorisée sur les sites et pèriodes budgets saisis en critère
 Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M:BDO1]FCY(nolign-1),[M:BDO1]CPY(nolign-1),VALEUR) From CFYSUB
 If mkstat=2  : Endif
 If [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND<[M]STRDAT(nolign-1)
& | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[M]ENDDAT(nolign-1)
  # Nature inactive (Il faut au moins qu'un jour d'activité de la nature
  # se chevauche sur l'exercice pour que la nature soit active)
  GMESSAGE = mess(6,103,1)
  mkstat = 2
 Elsif  [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND>[M]STRDAT(nolign-1)
&     | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[M]ENDDAT(nolign-1)
  OK = 2 : Call AVERTIR(mess(18,103,1)-VALEUR-mess(23,108,1),OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
 ## Autorisations avec les sections
 IND = 0
 CCEACC = VALEUR
 Gosub AUTCCEACC
 If !OK : mkstat = 2 : End : Endif
Else
 If clalev([F:GRY])=0  : Local File  GACCGRUPYM [GRY]  : Endif : # Groupe Pyramides comptes
 Filter [GRY] Where PYM = [F:BUP]PYMACC
 Call CONTROLE("GRY","",VALEUR,[F:BUP]PYMACC,mkstat) From CONTOBJ
 If mkstat : End : Endif
 Filter [GRY]
 ## Vérif budgétisable
 If [F:GRY]BUDTRK<> 2 : GMESSAGE = mess(26,103,1) : mkstat = 2 : End : Endif : # Groupe de compte non budgétisable
 If [F:GRY]LEV<>[F:BUP]PYMACCLEV
  ## Groupe de compte incorrecte
  GMESSAGE = mess(31,103,1)
  mkstat=2 : End
 Endif
Endif
End

$AUTCCEACC
# Check the account/dimension authorizations
If !clalev([F:GAC])  : Local File GACCOUNT [GAC]  : Endif
If !clalev([F:CCE2]) : Local File CACCE    [CCE2] : Endif
If !clalev([F:AUZ])  : Local File CAAUZ    [AUZ]  : Endif
OK =1
If IND<>0 & [F:CCE]AUZ<>""
 # Dimension
 Call LEC_GAC([M]ACC(nolign-1),[M]COA) From CPTLEC
 If [F:GAC]AUZ<>""
  Look [AUZ]CAZ0 = 2;[F:GAC]AUZ;[F:CCE]AUZ
  If !fstat
   GMESSAGE = CCEACC-mess(27,106,1)-[F:GAC]COA-[F:GAC]ACC : # Interdit avec le compte
   OK = 0 : Return
  Endif
 Endif
Elsif IND=0 & [F:GAC]AUZ<>""
 # Account
 Local Integer SECTYP
 Local Char    DIE(GLONDIE)
 Local Char    SECTION(GLONCCE)
 For SECTYP=1 To [F:BUP]DIENBR
  Raz SECTION
  Case SECTYP
   When 1 : SECTION = [M]CCE1(nolign-1) : DIE = [M]DIE1(nolign-1)
   When 2 : SECTION = [M]CCE2(nolign-1) : DIE = [M]DIE2(nolign-1)
   When 3 : SECTION = [M]CCE3(nolign-1) : DIE = [M]DIE3(nolign-1)
   When 4 : SECTION = [M]CCE4(nolign-1) : DIE = [M]DIE4(nolign-1)
   When 5 : SECTION = [M]CCE5(nolign-1) : DIE = [M]DIE5(nolign-1)
   When 6 : SECTION = [M]CCE6(nolign-1) : DIE = [M]DIE6(nolign-1)
   When 7 : SECTION = [M]CCE7(nolign-1) : DIE = [M]DIE7(nolign-1)
   When 8 : SECTION = [M]CCE8(nolign-1) : DIE = [M]DIE8(nolign-1)
   When 9 : SECTION = [M]CCE9(nolign-1) : DIE = [M]DIE9(nolign-1)
  Endcase
  If SECTION<>""
   Read [CCE2]CCE0 = DIE;SECTION
   If [F:CCE2]AUZ<>""
    Look [AUZ]CAZ0 = 2;[F:GAC]AUZ;[F:CCE2]AUZ
    If !fstat
     GMESSAGE = CCEACC-mess(26,106,1)-[F:CCE2]DIE-[F:CCE2]CCE : # Interdit avec la section
     OK = 0 : Break
    Endif
   Endif
  Endif
 Next
Endif
Return


# Dimensions
Subprog IB_CCE1
Local Integer IND
IND = 1 : Gosub IB_CCE
End


Subprog AS_CCE1(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 1 : Gosub AS_CCE
End

Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
Local Integer IND
IND = 1 : Gosub C_CCE
End

#############################
Subprog IB_CCE2
Local Integer IND
IND = 2 : Gosub IB_CCE
End

Subprog AS_CCE2(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 2 : Gosub AS_CCE
End

Subprog C_CCE2(VALEUR)
Variable Char    VALEUR()
Local Integer IND
IND = 2 : Gosub C_CCE
End

#############################
Subprog IB_CCE3
Local Integer IND
IND = 3 : Gosub IB_CCE
End
Subprog AS_CCE3(VALEUR)
