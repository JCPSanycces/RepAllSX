End

Subprog C_CCE9(VALEUR)
Variable Char    VALEUR()
Local Integer IND
IND = 9 : Gosub C_CCE
End

#############################

$IB_CCE
If [F:BUP]PYMCCE(IND-1)=""
 GBOUT1 = mess(36,103,1) : # Sections analytiques
 GBIDC3 = "CCE"
 Case IND
  When 1 : GBIDC1 = [M]DIE1(nolign-1)
  When 2 : GBIDC1 = [M]DIE2(nolign-1)
  When 3 : GBIDC1 = [M]DIE3(nolign-1)
  When 4 : GBIDC1 = [M]DIE4(nolign-1)
  When 5 : GBIDC1 = [M]DIE5(nolign-1)
  When 6 : GBIDC1 = [M]DIE6(nolign-1)
  When 7 : GBIDC1 = [M]DIE7(nolign-1)
  When 8 : GBIDC1 = [M]DIE8(nolign-1)
  When 9 : GBIDC1 = [M]DIE9(nolign-1)
 Endcase
Else
 GBOUT1 = mess(25,103,1) : # Groupe section
 GBIDC3 = "CRY"
 GBIDC1 = [F:BUP]PYMCCE(IND-1)
Endif
Return

$AS_CCE
Gosub INDDIE From BUDGET3
If INDDIE<IND : mkstat=1 : End : Endif
Return

$AXI
Local Char  AXI(GLONDIE)
Case IND
 When 1 : AXI = [M:BDO1]DIE1(nolign-1)
 When 2 : AXI = [M:BDO1]DIE2(nolign-1)
 When 3 : AXI = [M:BDO1]DIE3(nolign-1)
 When 4 : AXI = [M:BDO1]DIE4(nolign-1)
 When 5 : AXI = [M:BDO1]DIE5(nolign-1)
 When 6 : AXI = [M:BDO1]DIE6(nolign-1)
 When 7 : AXI = [M:BDO1]DIE7(nolign-1)
 When 8 : AXI = [M:BDO1]DIE8(nolign-1)
 When 9 : AXI = [M:BDO1]DIE9(nolign-1)
Endcase
Return

$C_CCE
Local Char    CCEACC(max(GLONGAC,GLONCCE)) : # Valeur de la section (ou nature)
Local Integer OK, I, J
Gosub AXI
If VALEUR<>""
 VALEUR = toupper(VALEUR)
Endif

If [F:BUP]PYMCCE(IND-1)=""
 ## Existence
 Call CONTROLE("CCE","",VALEUR,AXI,mkstat) From CONTOBJ
 If mkstat : End : Endif
 ## Code d'accès
 Call CONTEXE([F:CCE]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 ## Section non budgétisable
 If [F:CCE]BUDTRK = 1 : GMESSAGE = mess(5,103,1) : mkstat=2 : End : Endif
 ## Vérif site/société et Dates de validités
 ## La section doit être valide et autorisée sur toutes les lignes critères
 Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:BDO1]FCY(nolign-1),[M:BDO1]CPY(nolign-1),VALEUR) From CFYSUB
 If mkstat : End : Endif
 If [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[M:BDO1]STRDAT(nolign-1)
& | [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[M:BDO1]ENDDAT(nolign-1)
  # Section inactive
  GMESSAGE = mess(7,103,1)
  mkstat=2 : End
 Elsif [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[M:BDO1]STRDAT(nolign-1)
&    | [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[M:BDO1]ENDDAT(nolign-1)
  # Si la section n'est pas active sur la totalité de l'année, on met un message
  # d'avertissement
  # Section non active sur la totalité de l'année
  OK = 2 : Call AVERTIR(mess(17,103,1)-VALEUR-mess(24,108,1),OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
 If mkstat : End : Endif
 ## Autorisations nature
 CCEACC = VALEUR
 Gosub AUTCCEACC
 If !OK : mkstat = 2 : End : Endif
 ## Autorisations sections
 CCEACC = VALEUR
 Gosub AUTSECSEC
 If !OK : mkstat = 2 : End : Endif
Else
 Filter [CRY]
 Call CONTROLE("CRY","",VALEUR,[F:BUP]PYMCCE(IND-1),mkstat) From CONTOBJ
 If mkstat : End : Endif
 If [F:CRY]LEV<>[F:BUP]PYMCCELEV(IND-1)
  # Groupe de section incorrect
  GMESSAGE = mess(32,103,1)
  mkstat=2 : End
 Endif
 If [F:CRY]BUDTRK<>2
  GMESSAGE = mess(27,103,1)
  mkstat = 2 :End
 Endif
Endif
# Zoom depuis la gestion des sections analytiques qui alimente automatiquement la section.
# Pour passer dans l'aprés modif (qui charge les natures), on positionne mkstat à 4.
## INDDIE nombre d'axes gerès
If GFONCTION="GESCCE" and INDDIE=1
 mkstat = 4
Endif
Return

$AUTSECSEC
# On contrôle les interdictions avec les autres sections
OK = 1
If [F:CCE]AUZ<>""
 If clalev([F:CCE2])=0 : Local File CACCE [CCE2] : Endif
 If clalev([F:AUZ])=0   : Local File CAAUZ [AUZ] : Endif
 Local Integer SECTYP
 Local Char    DIE(GLONDIE)
 Local Char    SECTION(GLONCCE)
 For SECTYP=1 To [F:BUP]DIENBR
  If SECTYP<>IND
   Raz SECTION
   Case SECTYP
    When 1 : SECTION = [M]CCE1(nolign-1) : DIE = [M]DIE1(nolign-1)
    When 2 : SECTION = [M]CCE2(nolign-1) : DIE = [M]DIE2(nolign-1)
    When 3 : SECTION = [M]CCE3(nolign-1) : DIE = [M]DIE3(nolign-1)
    When 4 : SECTION = [M]CCE4(nolign-1) : DIE = [M]DIE4(nolign-1)
    When 5 : SECTION = [M]CCE5(nolign-1) : DIE = [M]DIE5(nolign-1)
    When 6 : SECTION = [M]CCE6(nolign-1) : DIE = [M]DIE6(nolign-1)
    When 7 : SECTION = [M]CCE7(nolign-1) : DIE = [M]DIE7(nolign-1)
    When 8 : SECTION = [M]CCE8(nolign-1) : DIE = [M]DIE8(nolign-1)
    When 9 : SECTION = [M]CCE9(nolign-1) : DIE = [M]DIE9(nolign-1)
   Endcase
   If SECTION<>""
    Read [CCE2]CCE0 = DIE;SECTION
    If [F:CCE2]AUZ<>""
     Look [AUZ]CAZ0 = 1;[F:CCE]AUZ;[F:CCE2]AUZ
     If !fstat
      GMESSAGE = CCEACC-mess(26,106,1)-[F:CCE2]DIE-[F:CCE2]CCE
      OK = 0 : Break
     Endif
    Endif
   Endif
  Endif
 Next
Endif
Return

## Currency
Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR=[BUP]CUR
Endif
End

## Amount Quantity
Subprog AS_AMT(VALEUR)
Variable Decimal VALEUR
If nolign-1>0 & VALEUR=0
 VALEUR=[M:BDO1]AMT(nolign-2)
Endif
End

Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
If [F:BUP]QTY<>2
 mkstat=1 : End
Endif
If [F:BUP]PYMACC=""    :#Compte
 Filter [GAC] Where COA=[F:BUP]COA & ACC=[M:BDO1]ACC(nolign-1)
 Read [GAC]GAC0 First
 Filter [GAC]
 If !fstat
  If [F:GAC]UOM=""
   mkstat=1 : End
  Endif
  If [M:BDO1]AMT(nolign-1)<>0 & [F:GAC]VALUOM<>0
   VALEUR=[M:BDO1]AMT(nolign-1)/[F:GAC]VALUOM
  Endif
 Endif
Else
 Filter [GRY] Where PYM=[F:BUP]PYMACC & GRU=[M:BDO1]ACC(nolign-1)
 Read [GRY]GRY0 First
 Filter [GRY]
 If !fstat
  If [F:GRY]UOMDAC<>2
   mkstat=1 : End
  Endif
  If [M:BDO1]AMT(nolign-1)<>0 & [F:GRY]DEFVAL<>0
   VALEUR=[M:BDO1]AMT(nolign-1)/[F:GRY]DEFVAL
  Endif
 Endif
Endif
End


# UOM
Subprog D_UOM(VALEUR)
Variable Char    VALEUR()

If [F:BUP]QTY=2
If [F:BUP]PYMACC=""    :#Compte
  Filter [GAC] Where COA=[F:BUP]COA & ACC=[M:BDO1]ACC(nolign-1)
  Read [GAC]GAC0 First
  Filter [GAC]
  If [F:GAC]UOM<>""
   VALEUR = [F:GAC]UOM
  Endif
Else                   :#Groupe de compte
  Filter [GRY] Where PYM=[F:BUP]PYMACC & GRU=[M:BDO1]ACC(nolign-1)
  Read [GRY]GRY0 First
  Filter [GRY]
  If [F:GRY]UOMDAC = 2
   VALEUR = [F:GRY]UOM
  Endif
Endif
Endif
End


# Start Date / End Date
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXE, PER
If nolign-1>0 & VALEUR=[0/0/0]
 VALEUR=[M:BDO1]STRDAT(nolign-2)
Else

 If VALEUR=[0/0/0]
 Call GETEXE([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),date$,EXE) From CPTSUB
  Case [BUP]BUDCTL
   When 2
    Filter [FIY] Where CPY=[M:BDO1]CPY(nolign-1) & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & FIYNUM=EXE
    Read [FIY]FIY0 First
    Filter [FIY]
    VALEUR=[FIY]FIYSTR      :#Début de l'exercice courant
   When 3
    Call GETPERSOC([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),date$,EXE,PER) From CPTSUB
    Filter [PER] Where CPY=[M:BDO1]CPY(nolign-1) & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & FIYNUM=EXE & PERNUM=PER
    Read [PER]PER0 First
    Filter [PER]
    VALEUR=[PER]PERSTR      :#Début de la période courante
   When 4,5
    VALEUR=[F:BUP]VLYSTR    :#Début de validité du budget
  Endcase
 Endif
Endif
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXE, PER
If nolign-1>0 & VALEUR=[0/0/0]
 VALEUR=[M:BDO1]ENDDAT(nolign-2)
Elsif VALEUR=[0/0/0]
 Call GETEXE([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),date$,EXE) From CPTSUB
  Case [BUP]BUDCTL
   When 2
    Filter [FIY] Where CPY=[M:BDO1]CPY(nolign-1) & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & FIYNUM=EXE
    Read [FIY]FIY0 First
    Filter [FIY]
   VALEUR=[FIY]FIYEND      :#Fin de l'exercice courant
   When 3
    ##150 vedere
   Call GETPERSOC([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),[M:BDO1]STRDAT(nolign-1),EXE,PER) From CPTSUB
    Filter [PER] Where CPY=[M:BDO1]CPY(nolign-1) & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & FIYNUM=EXE & PERNUM=PER
    Read [PER]PER0 First
    Filter [PER]
   VALEUR=[PER]PEREND      :#Fin de la période courante
  When 4
   VALEUR=[BUP]VLYEND      :#Fin de validité du budget
  When 5
   Call GETPERSOC([M:BDO1]CPY(nolign-1),[M:BDO1]LEDTYP(nolign-1),date$,EXE,PER) From CPTSUB
    Filter [PER] Where CPY=[M:BDO1]CPY(nolign-1) & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & FIYNUM=EXE & PERNUM=PER
    Read [PER]PER0 First
    Filter [PER]
   VALEUR=[PER]PEREND      :#Fin de la période courante
 Endcase
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Call CTL_DATE([M:BDO1]CPY(nolign-1),VALEUR,1)
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Call CTL_DATE([M:BDO1]CPY(nolign-1),VALEUR,2)
End

Subprog CTL_DATE(STE,DTE,FLG)
Value Char     STE
Value Date     DTE
Value Shortint FLG : # 1= Date début / 2 = Date fin
Local Decimal  EXO
If STE<>""
 Call GETEXE(STE,[M:BDO1]LEDTYP(nolign-1),DTE,EXO) From CPTSUB
Endif
Read [FIY]FIY0 = STE;[M:BDO1]LEDTYP(nolign-1);EXO
If fstat
 GMESSAGE = mess(52,116,1) : # Exercice incorrect
 mkstat = 2 : End
Endif

# La date de début doit être une date de début de période
Case FLG
 When 1 : Filter [PER] Where CPY=STE & FIYNUM=EXO & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & PERSTR=DTE
          Read [PER]PER0 First
          If fstat
           mkstat = 2 : GMESSAGE = mess(49,108,1) : Filter [PER] : End
          Endif
 When 2 : Filter [PER] Where CPY=STE & FIYNUM=EXO & LEDTYP=[M:BDO1]LEDTYP(nolign-1) & PEREND=DTE
          Read [PER]PER0 First
          If fstat
           mkstat = 2 : GMESSAGE = mess(50,108,1) : Filter [PER] : End
          Endif
Endcase
Filter [PER]

# Il faut que le code budget soit actif sur la période
Case FLG
 When 1
  If [F:BUP]VLYSTR>DTE
   GMESSAGE = mess(31,108,1) : # Code budget inactif
   mkstat = 2 : End
  Endif
 When 2
  If [F:BUP]VLYEND<>[0/0/0] & [F:BUP]VLYEND<DTE
   GMESSAGE = mess(31,108,1) : # Code budget inactif
   mkstat = 2 : End
  Endif
Endcase
Case FLG
 When 1 : [M:BDO1]FIYSTR(nolign-1) = EXO
          [M:BDO1]PERSTR(nolign-1) = [F:PER]PERNUM
 When 2 : [M:BDO1]FIYEND(nolign-1) = EXO
          [M:BDO1]PEREND(nolign-1) = [F:PER]PERNUM
Endcase
End

