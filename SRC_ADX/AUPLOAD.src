#<AdxTL>@(#)8.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AUPLOAD","AUPLOAD","") From GSAISIE
End


$ACTION
Case ACTION
  When "SEL_LISTE" : Goto SELLIST
  When "DEBUT" : Gosub DEBUT
  When "BOUTON"    : Gosub BOUTON
Endcase
Return

$BOUTON
If BOUT<>"A" : Return : Endif
If [M]TYPDEST=1
#Call UPLFILEFIC(LOC,DOSS,REP,FIC,ERR) From GESECRAN
 Infbox("Transfert vers Fichier")
Elsif [M]TYPDEST=2
#Call UPLCLBFIC(LOC,KEY1,KEY2,KEY3,KEY4,ERR) From GESECRAN
 Infbox("Transfert vers Clob")
Elsif [M]TYPDEST=3
#Call UPLBLBFIC(LOC,KEY1,KEY2,KEY3,KEY4,ERR) From GESECRAN
 Infbox("Transfert vers Blob")
Endif

Return


$SELLIST
Local Char    ORDSYS(80)(1..2) , FIC(80)(1..1000) 
Local Integer NBFIC,I
ORDSYS = "lsadx -a"-nomap-PARAM(1)
Call SYSTEME2(adxmac(0),ORDSYS,"",NBFIC,FIC) From ORDSYS
NBTEX = 0
For I=1 To NBFIC
 If FIC(I)<>"." and FIC(I)<>".." and NBTEX<dim(TEX)-1
   NBTEX += 1 : TEX(NBTEX) = FIC(I)
 Endif
 If NBTEX=dim(TEX) : Break 1 : Endif
Next I
Return

$DEBUT
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran AUPLOAD) 12/10/2005 15:30:34 (CCORA)
######################################################################################

Subprog AP_TYPDEST(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Effzo 20 : Diszo 20 : Actzo 15
Elsif VALEUR=2 | VALEUR=3
  Effzo 15 : Diszo 15 : Actzo 20
Endif
End


Subprog AS_REPERT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=filpath("tmp","","",nomap)
Endif
End

Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
If filinfo(VALEUR,0)<0
  GMESSAGE="Répertoire inexistant"
  mkstat=2
Endif
End

Subprog C_NOMFIC(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If filinfo([M]REPERT+"\"+VALEUR,7)>0
  Call AVERTIR("Le fichier existe, désirez vous le remplacer ?",OK) From GESECRAN 
  If OK<>2 : mkstat=2 : Endif
Endif
End


Subprog AP_IDENT3(VALEUR)
Variable Char    VALEUR()
End
