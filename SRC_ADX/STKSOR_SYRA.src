#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Traitement STKSOR - Librairie des composants de sortie
#######################################################################################
# CTLECCVAL      Contrôle de la version majeure saisie par rapport
#                à la règle de gestion
#######################################################################################
#######################################################################################
# CTLECCVAL     Contrôle de la version majeure saisie par rapport
#               à la règle de gestion
#               A utiliser en saisie écran
#######################################################################################
# Prérequis   : La table ECCSTA doit être ouverte
#######################################################################################
# Paramètre E : LECCVAL  = Version majeure
#               LFCY     = Site
#               LITM     = Article
#               LTRSTYP  = Type de mouvement (ML 704)
#                          Si devis, commande ou préparation,
#                          mettre comme pour une livraison
#               LTRSCOD  = Code mouvement
#               LDAT     = Date du besoin
# Paramètre S : LRET     = 0 : OK
#                          1 : Version ne respectant pas la règle de gestion
#                              GMESSAGE positionné et à exploiter en sortie
#                          2 : Erreur lecture article
#                          3 : Erreur lecture règle de gestion
#                          4 : Erreur version inexistante
#######################################################################################
Funprog CTLECCVAL(CTX, LECCVAL, LFCY, LITM, LTRSTYP, LTRSCOD, LDAT, LRET, SMESSAGE)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    LECCVAL
Value    Char    LFCY
Value    Char    LITM
Value    Integer LTRSTYP
Value    Char    LTRSCOD
Value    Date    LDAT
Variable Integer LRET
Variable Char    SMESSAGE

Local Integer IARENDRE

  # -------------------------------
  Raz LRET
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # -------------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_AFALSE Then
    End IARENDRE
  Endif
  # -------------------------------
  Local File ITMMASTER [ITM]
  Local File ECCSTA [ECS]
  Local File TABSTORUL [SRU]
  # -------------------------------
  If LECCVAL <> AVOID.ACHAR Then
    # Si pas de version, ne rien faire
    Read [ITM]ITM0=LITM
    If !fstat Then
      # Lecture de la règle de gestion à utiliser
      IARENDRE = func STKLIB_SYRA.LECSRU(CTX, LFCY, [F:ITM]TCLCOD, LTRSTYP, LTRSCOD, "", SMESSAGE)
      If IARENDRE = [V]CST_AOK Then
        Read [ECS]ECS0=LITM;LECCVAL
        If !fstat Then
          Case [F:ECS]ECCSTA
            When 1
              If [F:SRU]AUZPRO = 1 Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(422,184,1)
              Elsif [F:SRU]AUZPRO = 2 and [F:ECS]SPSFLG = [V]CST_AYES Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(424,184,1)
              Endif
            When 2
              If [F:SRU]AUZACT = 1 Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(423,184,1)
              Elsif [F:SRU]AUZACT = 2 and [F:ECS]SPSFLG = [V]CST_AYES Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(424,184,1)
              Endif
            When 3
              If [F:SRU]AUZSTP = 1 or ([F:SRU]AUZSTP = 2 and [F:ECS]EXNFLG <> [V]CST_AYES) Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(425,184,1)
              Elsif [F:SRU]AUZSTP = 2 and [F:ECS]EXNFLG = [V]CST_AYES and [F:ECS]EXNDAT <> [0/0/0] and LDAT > [F:ECS]EXNDAT Then
                LRET = 1
                IARENDRE = [V]CST_AWARNING
                SMESSAGE = mess(425,184,1)
              Endif
            When 4
              LRET = 1
              IARENDRE = [V]CST_AWARNING
              SMESSAGE = mess(433,184,1)
          Endcase
        Else
          LRET = 4
          IARENDRE = [V]CST_AERROR
          SMESSAGE = LECCVAL - ":" - mess(308,193,1)
        Endif
      Else
        LRET = 3
      Endif
    Else
      LRET = 2
      IARENDRE = [V]CST_AERROR
      SMESSAGE = LITM - ":" - mess(212,199,1)
    Endif
  Endif
End IARENDRE

########################################################################
# STKCTRECC : Contrôle versions
########################################################################
# Paramètres E : PITM       = Article
#                PMAJ       = version majeure
#                PMIN       = version mineure
#                PLOT       = lot
#                PORI       = origine du controle :
#                 1 = rubrique ECCVALMAJ : Zone obligatoire
#                 2 = rubrique ECCVALMIN : Zone obligatoire
#                 3 = rubrique ECCVALMAJ : Zone non obligatoire
#                 4 = rubrique ECCVALMIN : Zone non obligatoire
#                 5 = rubrique ECCVALMAJ : Zone obligatoire sans controle lot
#                 6 = rubrique ECCVALMIN : Zone obligatoire sans controle lot
#                 7 = rubrique ECCVALMAJ : doit exister si renseignée sans controle lot
#                 8 = rubrique ECCVALMIN : doit exister si renseignée sans controle lot
########################################################################
Funprog STKCTRECC(CTX, PITM, PMAJ, PMIN, PLOT, PORI, SMESSAGE)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char    PITM
Value Char    PMAJ
Value Char    PMIN
Value Char    PLOT
Value Integer PORI
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer WCTRLOT

  # -------------------------------
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # -------------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_AFALSE Then
    End IARENDRE
  Endif
  # -------------------------------
  Local File ITMMASTER [ITM]
  Local File STOLOT [STL]
  Local File ECCSTA [ECS]
  Local File ECCVAL [EVL]
  # -------------------------------
  Read [ITM]ITM0=PITM
  If !fstat Then
    WCTRLOT = 2
    If find(PORI,5,6,7,8) Then
      Raz WCTRLOT
    Endif
    # -------------------------------
    If PORI = 3 & PMAJ = AVOID.ACHAR Then
      End IARENDRE
    Endif
    If PORI = 4 & PMIN = AVOID.ACHAR Then
      End IARENDRE
    Endif
    # -------------------------------
    If [F:ITM]ECCSTO = 2 and PMIN <> AVOID.ACHAR Then
      IARENDRE = [V]CST_AERROR
      SMESSAGE = mess(420,184,1)   # Version majeure ou mineure incorrecte !
      End IARENDRE
    Endif
    # si le lot renseigné controle de la cohérence des versions
    If PLOT <> AVOID.ACHAR and WCTRLOT = 2 Then
      Filter [F:STL] Where ITMREF = PITM and LOT = PLOT Order By Key STL0
      Read [STL]First
      Filter [F:STL]
      If !fstat Then
        If PMAJ <> [F:STL]ECCVALMAJ Then
          IARENDRE = [V]CST_AERROR
          SMESSAGE = mess(395,184,1) # La version saisie est differentre de celle du lot
          End IARENDRE
        Endif
        If PMIN <> AVOID.ACHAR and PMIN <> [F:STL]ECCVALMIN Then
          IARENDRE = [V]CST_AERROR
          SMESSAGE = mess(395,184,1) # La version saisie est differentre de celle du lot
          End IARENDRE
        Endif
        End IARENDRE
      Endif
    Endif
    # -------------------------------
    # controle existence version majeure
    If PMAJ = AVOID.ACHAR and PORI = 7 Then
      End IARENDRE
    Endif
    Read [ECS]ECS0=PITM;PMAJ
    If fstat Then
      IARENDRE = [V]CST_AERROR
      GMESSAGE = mess(406,184,1) # Version inexistante  !
      End IARENDRE
    Endif
    # si version active
    If [F:ECS]ECCSTA = 4 Then
      IARENDRE = [V]CST_AERROR
      SMESSAGE = mess(397,184,1) # la version n est pas active  !
      End IARENDRE
    Endif
    # si l article ne gere pas la version mineure : end
    If [F:ITM]ECCSTO < 3 Then
      End IARENDRE
    Endif
    # si l origine du controle est la rubrique ECCVALMAJ : end
    If find(PORI,1,3,5,7) Then
      End IARENDRE
    Endif
    # controle existence version mineure
    If PMIN = AVOID.ACHAR and PORI = 8 Then
      End IARENDRE
    Endif
    Read [EVL]EVL1=PITM;PMAJ;PMIN;4
    If fstat Then
      IARENDRE = [V]CST_AERROR
      SMESSAGE = mess(434,184,1) # Version mineure inexistante !
    Endif
  Else
    IARENDRE = [V]CST_AERROR
    SMESSAGE = LITM - ":" - mess(212,199,1)
  Endif
End IARENDRE

