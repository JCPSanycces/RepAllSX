#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################################################################
# Contrôle de cohérence des informations stockées dans DEPREC après éclatement d'un bien
# Traitement appelé à partir du TRTFASSPL
# MDJ : 14-05-2008
# MDJ : FQ 83610(83610)23-07-2012 : Perte du solde de dépréciation (remplacement de CALPLN par CALDEP)
#               (ACCES SUPPRIME DEPUIS LE TRTFASSPL)
# MDJ : FQ 49389/49418 25-09-2008 : suppression call oui_non et DEF_CONSTANTES_CALCUL From GCALUTIL1
############################################################################################
#-------------------------------------
$ACTION
 Case ACTION
  When Default
 Endcase
Return

#-------------------------------------
$CONTROLE
Return
#--------------------------------------------------------------#
# S/P appelé par TRTFASSPL                                     #
#--------------------------------------------------------------#
Subprog CORR_PERCLO(PCPY,PAASREF,RERROR)
 Value    Char       PCPY    # Société
 Value    Char       PAASREF # Bien comptable
 Variable Integer    RERROR  # erreur

  #!!!!!!!   Fq-83610 suppression définitive du contrôle !!!!!!!!
  RERROR = 0 : End


Local Char LCPY    : LCPY    =   PCPY
Local Char LAASREF : LAASREF =   PAASREF
#-------------------------------------
 Local Integer PSIMU          : PSIMU = G_NON
 Local Integer PTEST          : PTEST = G_NON
 Local Integer PDET           : PDET  = 0
 Local Integer OK
 Local Char    LIGNE(130)

 If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif
 If !clalev([F:CNX])  : Local File CONTEXT   [CNX]  : Endif
 If !clalev([F:FIY])  : Local File FISCYEAR  [FIY]  : Endif
 If !clalev([F:FAS])  : Local File FXDASSETS [FAS]  : Endif
 If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif
 #Fq-83610 If !clalev([M:XPLN]) : Local Mask CALPLN    [XPLN] : Endif
 If !clalev([M:XPLN]) : Local Mask CALDEP    [XPLN] : Endif
 If !clalev([M:CAL0]) : Local Mask CAL0      [CAL0] : Endif
 #Fq-83610 If !clalev([M:WPLN]) : Local Mask CALPLN    [WPLN] : Endif
 If !clalev([M:WPLN]) : Local Mask CALDEP    [WPLN] : Endif

 Call OUVRE_TRACE("TRTSPLCOR"-GUSER-date$) From LECFIC

 Call ECR_TRACE("Trace détaillée :"-mess(PDET,1,1),0) From GESECRAN
 Call ECR_TRACE("Mode diagnostic :"-mess(PSIMU,1,1),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN

 Local Integer NBBCOTOT
 Local Integer NBBCOTRT
 Local Integer OK
 Call ECR_TRACE("Société"-LCPY,0) From GESECRAN
 Gosub DEF_VAR_CPY
 Filter [F:CNX] Where CPY=LCPY
 For [F:CNX]
    Read [F:FIY]FIY1=LCPY;[F:CNX]CNX;GVML_TECOURA
    If !fstat
       Gosub LOAD_INFO_CNX
       For I_PLN=1 To G301MAX-1
          If GPLNCAL(I_PLN)=G_OUI
             Call ECR_TRACE("  Plan"-mess(I_PLN,3101,1),0) From GESECRAN
             Read [F:FAS]FAS0=LAASREF
             Raz NBBCOTRT : NBBCOTOT = rowcount([F:FAS])
             If !GSERVEUR : Call OUVRE_BOITE("Ctrl DEPREC"-[F:CPY]CPY-"/"-mess(I_PLN,3101,1),NBBCOTOT) From GESECRAN : Endif
             If fstat=0
                NBBCOTRT+=1
                Gosub TRT_UN_BIEN
             Endif
             If PDET : Call ECR_TRACE("    Nombre de biens traités pour ce plan"-num$(NBBCOTRT),0) From GESECRAN : Endif
          Endif
       Next I_PLN
       If !GSERVEUR : Call FERME_BOITE From GESECRAN : Endif
    Endif
 Next
 Filter [F:CNX]
 If PDET :  Call LEC_TRACE() From LECFIC : Endif

 GSERVEUR = 0

End
#-------------------------------------
$DEF_VAR_CPY
Return

#-------------------------------------
$LOAD_INFO_CNX

 #> Définition / alimentation des variables contexte / exercice
 Local Integer LNBRPER
 Local Integer LINDCURPER
 Local Integer GPLNCAL(1..G301MAX-1)

 LNBRPER    = [F:FIY]NBRPER
 LINDCURPER = [F:FIY]INDCURPER

 Local Date    LDEBEXE
 Local Date    LFINEXE
 Local Date    LDEBPER(1..LNBRPER)
 Local Date    LFINPER(1..LNBRPER)
 Local Integer I

 LDEBEXE = [F:FIY]DATSTRFIY
 LFINEXE = [F:FIY]DATENDFIY

 For I=1 To LNBRPER
  LDEBPER(I)=[F:FIY]DATSTRPER(I-1)
  LFINPER(I)=[F:FIY]DATENDPER(I-1)
 Next I

 #> Définition / alimentation des variables plan d'amortissement
 For I=1 To [F:CNX]NBPLC
   If [F:CNX]PLNCAA(I-1)> 0
      GPLNCAL([F:CNX]PLNCAA(I-1))=G_OUI
   Endif
 Next I

Return
#-------------------------------------
$TRT_UN_BIEN

 #> Chargement des masques de travail plan pour les biens comptables
 #  ================================================================

Raz [M:WPLN], [M:XPLN]

#Filter [F:DEP] Where (CPY=LCPY & DPRPLN=I_PLN & AASREF=LAASREF &
#&                     PERENDDAT <= [F:FIY]DATENDPER([F:FIY]INDCURPER-1)  & FIYENDDAT<=LFINEXE)
Filter [F:DEP] Where  (CPY=LCPY & DPRPLN=I_PLN & AASREF=LAASREF  & PERENDDAT<=LFINEXE & FIYENDDAT<=LFINEXE)

 For [F:DEP]
   [M:WPLN]NB_DEP += 1
   nolign         = [M:WPLN]NB_DEP
   [M:WPLN]        = [F:DEP]
 Next
 Filter [F:DEP]

 [M:XPLN]=[M:WPLN]
 [M:WPLN]NB_DEP=nolign-1
 [M:XPLN]NB_DEP=nolign-1
 Affzo [M:WPLN]

 #> Recalcul des cumuls dans les masques de travail
 #  ===============================================

 For I_PER=1 To [M:WPLN]NB_DEP
  If I_PER>1

   If [M:WPLN]PERSTRDAT(I_PER-1) <>  [M:WPLN]FIYSTRDAT(I_PER-1)
       # PERCLOCUM -------------------------------------------------------
      [M:WPLN]PERCLOCUM(I_PER-1)  = [M:WPLN]PERCLOCUM(I_PER-2) + [M:WPLN]PERENDDPE(I_PER-2)
      [M:WPLN]PERCLOCUMI(I_PER-1) = [M:WPLN]PERCLOCUMI(I_PER-2)+ [M:WPLN]DPEI(I_PER-2)
      [M:WPLN]PERCLOCUMT(I_PER-1) = [M:WPLN]PERCLOCUMT(I_PER-2)+ [M:WPLN]DPET(I_PER-2)
   Endif
   # EXECLOCUM --------------------------------------------------------
#*Fq-83610   [M:WPLN]EXECLOCUMI(I_PER-1) = [M:WPLN]EXECLOCUMI(I_PER-2) + [M:WPLN]PERCLOCUMI(I_PER-2)
#*Fq-83610   [M:WPLN]EXECLOCUMT(I_PER-1) = [M:WPLN]EXECLOCUMT(I_PER-2) + [M:WPLN]PERCLOCUMT(I_PER-2)

   # IMLBLC --------------------------------------------------------
   #Fq-83610 [M:WPLN]IMLBLC(I_PER-1)     = [M:WPLN]IMLCUM(I_PER-1) + [M:WPLN]IMLRVECUM(I_PER-1)
   #Fq-83610  CFF 17/7/2012: Voici le bonne formule d'entretien du solde de dépréciation
   [M:WPLN]IMLBLC(I_PER-1)     = [M:WPLN]IMLBLC(I_PER-2) + [M:WPLN]IML(I_PER-2) - ([M:WPLN]IMLRVE(I_PER-2) + [M:WPLN]IMLRVETRF(I_PER-2))


   # CRBCUM --------------------------------------------------------
   [M:WPLN]CRBCUM(I_PER-1)     = [M:WPLN]CRBCUM(I_PER-2) + [M:WPLN]CRBAMT(I_PER-2)

   # ALWCUM --------------------------------------------------------
   [M:WPLN]ALWCUM(I_PER-1)     = [M:WPLN]ALWCUM(I_PER-2) + [M:WPLN]ALWCUM(I_PER-2)

   # EXERVADEV --------------------------------------------------------
   [M:WPLN]EXERVADEV(I_PER-1)  = [M:WPLN]EXERVADEV(I_PER-2)+ [M:WPLN]PERRVADEV(I_PER-2) + [M:WPLN]RVAAMT(I_PER-2)+ [M:WPLN]RVACRB(I_PER-2)

   # PERRVADEV --------------------------------------------------------
   [M:WPLN]PERRVADEV(I_PER-1)  = [M:WPLN]PERRVADEV(I_PER-2) + [M:WPLN]RVAAMT(I_PER-2)- [M:WPLN]RVACRB(I_PER-2)
  Endif

 Next

 #> Comparaison informations stockées, informations corrigées
 #  =========================================================

 For I_PER=1 To [M:WPLN]NB_DEP
 If [M:WPLN]PERSTRDAT(I_PER-1) <>  [M:WPLN]FIYSTRDAT(I_PER-1)
  #> --------------------------------------------------------------------
  #> Contrôle PERCLOCUM/PERCLOCUMI/PERCLOCUMT
  #> --------------------------------------------------------------------
  If [M:WPLN]PERCLOCUM(I_PER-1)<>[M:XPLN]PERCLOCUM(I_PER-1)
   Call ECR_TRACE(space$(10)+LAASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"PERCLOCUM incorrect stocké"-
&                 num$([M:XPLN]PERCLOCUM(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]PERCLOCUM(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610 [M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
Endif
  If [M:WPLN]PERCLOCUMI(I_PER-1)<>[M:XPLN]PERCLOCUMI(I_PER-1)
   Call ECR_TRACE(space$(10)+LAASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"PERCLOCUMI incorrect stocké"-
&                 num$([M:XPLN]PERCLOCUMI(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]PERCLOCUMI(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif

  If [M:WPLN]PERCLOCUMT(I_PER-1)<>[M:XPLN]PERCLOCUMT(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"PERCLOCUMT incorrect stocké"-
&                 num$([M:XPLN]PERCLOCUMT(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]PERCLOCUMT(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  #> --------------------------------------------------------------------
  #> Contrôle EXECLOCUMI/EXECLOCUMT
  #> --------------------------------------------------------------------
  If [M:WPLN]EXECLOCUMI(I_PER-1)<>[M:XPLN]EXECLOCUMI(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"EXECLOCUMI incorrect stocké"-
&                 num$([M:XPLN]EXECLOCUMI(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]EXECLOCUMI(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  If [M:WPLN]EXECLOCUMT(I_PER-1)<>[M:XPLN]EXECLOCUMT(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"EXECLOCUMT incorrect stocké"-
&                 num$([M:XPLN]EXECLOCUMI(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]EXECLOCUMI(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  #> --------------------------------------------------------------------
  #> Contrôle IMLBLC
  #> --------------------------------------------------------------------
  If [M:WPLN]IMLBLC (I_PER-1)<>[M:XPLN]IMLBLC (I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"IMLBLC incorrect stocké"-
&                 num$([M:XPLN]IMLBLC (I_PER-1))-"corrigé"-
&                 num$([M:WPLN]IMLBLC (I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif

  #> --------------------------------------------------------------------
  #> Contrôle CRBCUM/ALWCUM/RVACRB
  #> --------------------------------------------------------------------
  If [M:WPLN]CRBCUM(I_PER-1)<>[M:XPLN]CRBCUM(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"CRBCUM incorrect stocké"-
&                 num$([M:XPLN]CRBCUM(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]CRBCUM(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  If [M:WPLN]ALWCUM(I_PER-1)<>[M:XPLN]ALWCUM(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"ALWCUM incorrect stocké"-
&                 num$([M:XPLN]ALWCUM(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]ALWCUM(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  If [M:WPLN]RVACRB(I_PER-1)<>[M:XPLN]RVACRB(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"RVACRB incorrect stocké"-
&                 num$([M:XPLN]RVACRB(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]RVACRB(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  #> --------------------------------------------------------------------
  #> Contrôle EXERVADEV/PERRVADEV
  #> --------------------------------------------------------------------
  If [M:WPLN]EXERVADEV(I_PER-1)<>[M:XPLN]EXERVADEV(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"EXERVADEV incorrect stocké"-
&                 num$([M:XPLN]EXERVADEV(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]EXERVADEV(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  If [M:WPLN]PERRVADEV(I_PER-1)<>[M:XPLN]PERRVADEV(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"PERRVADEV incorrect stocké"-
&                 num$([M:XPLN]PERRVADEV(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]PERRVADEV(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif
  #> --------------------------------------------------------------------
  #> Contrôle DPRCUM
  #> --------------------------------------------------------------------
  If [M:WPLN]DPRCUM(I_PER-1)<>[M:XPLN]DPRCUM(I_PER-1)
   Call ECR_TRACE(space$(10)+[F:FAS]AASREF-num$(I_PER)-[M:WPLN]PERENDDAT(I_PER-1)-"DPRCUM incorrect stocké"-
&                 num$([M:XPLN]DPRCUM(I_PER-1))-"corrigé"-
&                 num$([M:WPLN]DPRCUM(I_PER-1))
&                 ,1) From GESECRAN
   #*Fq-83610[M:WPLN]FLGCRE(I_PER-1)=8
   [M:WPLN]ETRPNT(I_PER-1)=8
  Endif

 Next I_PER

 #> Correction des écarts constatés par le traitement
 #  =================================================

If PSIMU<>G_OUI
   For I_PER=1 To [M:WPLN]NB_DEP
      #*Fq-83610 If [M:WPLN]FLGCRE(I_PER-1)=8
      If [M:WPLN]ETRPNT(I_PER-1)=8
         Read [F:DEP]DEP0=LAASREF;I_PLN;[M:WPLN]FIYENDDAT(I_PER-1);[M:WPLN]PERENDDAT(I_PER-1)
         nolign=I_PER
         [F:DEP]=[M:WPLN]
         Rewrite [F:DEP]
         Call ECR_TRACE(space$(15)+"Correction DEPREC"-[M:WPLN]PERENDDAT(I_PER-1),0) From GESECRAN
         If fstat
            Call ECR_TRACE("Err mise à jour DEPREC => "+"/fstat="+num$(fstat)-[F:DEP]AASREF+":"+num$([F:DEP]DPRPLN)+";"+[F:DEP]FIYENDDAT+";"+[F:DEP]PERENDDAT
&                     ,1)From GESECRAN
            RERROR = 99
         Else
         Endif
      Endif
   Next I_PER
Endif

Return
