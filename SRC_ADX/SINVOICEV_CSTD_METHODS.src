#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SINVOICEV
#######################################################################################
End

#######################################################################################
$AREAD_AFTER
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation

  # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - added LEG propert to SINVOICEV class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SIVTYP_LEG(this, this.SIVTYP, this.CPY, this.SALFCY, this.LEG, this.SIVTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEP, this.CPY, this.SALFCY, this.LEG, this.DEP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  If func ASYRFNC.ACTIV("DEB")>0 #AFNC.ACTIV("DEB") = 1 # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECNAT_LEG(this, this.EECNAT, this.CPY, this.SALFCY, this.LEG, this.EECNAT_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECNAT_LEG(this, this.EECNATR, this.CPY, this.SALFCY, this.LEG, this.EECNATR_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECSCH_LEG(this, this.EECSCH, this.CPY, this.SALFCY, this.LEG, this.EECSCH_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECSCH_LEG(this, this.EECSCHR, this.CPY, this.SALFCY, this.LEG, this.EECSCHR_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  # End issue X3-38343

  [L]ASTATUS = fmet this.INIT_TSCCODADI()

Return
#######################################################################################
$AREAD_AFTER_C_PAM

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - added LEG property to SINVOICEV class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PAM_LEG(this.APARENT, this.PAM, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.PAM_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
$AINIT

  [L]ASTATUS = fmet this.INIT_TSCCODADI()

Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

#######################################################################################
# Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - AREAD_AFTER replaced by AEAD_BEFORE
$AREAD_BEFORE_SIH

  # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
  #--everything that concern SIH must be done at SIH level for CURPTH="SIH"
  # SOBJET.SIH
  # From SIV
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - added LEG property to SINVOICEV class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.FCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  this.LEG = this.APARENT.LEG

Return
#######################################################################################
# Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
$AREAD_AFTER_SIH_C_TAX

