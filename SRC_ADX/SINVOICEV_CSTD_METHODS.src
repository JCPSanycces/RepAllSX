  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACITM_LEG(this.APARENT, this.VACITM, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.APARENT.LEG, this.VACITM_LEG)
