  If this.APARENT.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.FCY, this.APARENT.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  #TAX

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.TAX, this.APARENT.CPY, this.APARENT.FCY, this.APARENT.APARENT.LEG, this.TAX_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
