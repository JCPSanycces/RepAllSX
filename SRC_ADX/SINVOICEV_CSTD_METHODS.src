    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
