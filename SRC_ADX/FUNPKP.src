Subprog AS_GROWEI(VALEUR)
Variable Decimal VALEUR
Local Integer I
Raz I
# si deja colisé modif interdite
If [M:PKP1]PACQTYSTU (nolign-1) <> 0
   mkstat = 2
   End
Endif

# la modif du poids est autorisée sur la premiere ligne du pacseq
If nolign-1 > 0
   I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <> nolign-1 & [M:PKP1]PACSEQH(nolign-1) <>1))
      If I <> 0
         mkstat = 2
         End
      Endif
Endif
End

Subprog AS_LBLFMT(VALEUR)
Variable Char    VALEUR()
# si deja colisé modif interdite
If [M:PKP1]PACQTYSTU (nolign-1) <> 0
   mkstat = 2
   End
Endif
# la modif de l etiquette est autorisée sur la premiere ligne du pacseq

If nolign-1 > 0
   I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <>  nolign-1 & [M:PKP1]PACSEQH(nolign-1) <>1))
      If I <> 0
         mkstat = 2
         End
      Endif
Endif

End
