Variable Decimal VALEUR
End

Subprog C_GROWEI(VALEUR)
Variable Decimal VALEUR

End


Subprog AS_PCK(VALEUR)
Variable Char    VALEUR()
# si deja colisé modif interdite
If [M:PKP1]PACQTYSTU (nolign-1) <> 0
   mkstat = 2
   End
Endif
Local Integer I
I = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <> nolign-1) & [M:PKP1]PACSEQ(nolign-1) <> 0)
If I <> 0
   mkstat = 2
Endif
End
Subprog AS_PACSEQ(VALEUR)
Variable Decimal VALEUR

# si deja colisé modif interdite
If [M:PKP1]PACQTYSTU (nolign-1) <> 0
   mkstat = 2
   End
Endif

If [M:PKP1]QTY (nolign-1) =  0                # 56102
   mkstat = 2
   End
Endif


Local Integer I
I = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <> nolign-1) & [M:PKP1]PACSEQ(nolign-1) <> 0)
If I <> 0
   mkstat = 2
   End
Endif

If [M:PKP1]QTYSTU(nolign-1) <> 0
   If VALEUR = 0
      VALEUR = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
      [M:PKP1]PACSEQH  (nolign-1)  =  1
   Endif
Endif

End
Subprog AS_NETWEI(VALEUR)
Variable Decimal VALEUR

# si pas UP pas de saisie
If [M:PKP1]LIGWEU (nolign-1) = ""
   mkstat = 2
   End
Endif

# si gere en stock et gestion detail stock à oui  la modif du poids doit se faire dans la fenetre detail
If [M:PKP1]STOMGTCOD(nolign-1)  > 1 &  [M:PKP1]PCKSTKFLG(nolign-1) = 2
   mkstat = 2
   End
Endif
# si deja colisé modif interdite
If [M:PKP1]PACQTYSTU (nolign-1) <> 0
   mkstat = 2
   End
Endif
Local Integer I
I = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <> nolign-1) & [M:PKP1]PACSEQ(nolign-1) <> 0)
If I <> 0
   mkstat = 2
   End
Endif

End
