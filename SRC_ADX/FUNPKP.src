#<AdxTL>@(#)0.0.0.0 $Revision$ Post-Colisage
##################################################################################
#    GESTION DU COLISAGE                                                         #
#--------------------------------------------------------------------------------#
#  - Traitement        : FUNPKP                                                  #
#  - Action            : TRTPPKP    (Trt standard)                               #
#                        SAIPKP     (Saisie fenêtre)                             #
#  Dans le cas d appel depuis un document (Livraison  / préparation ..)          #
#       il faut la présence dans l écran entete du document de la rubrique PKGTYP#
#       et alimenter la global GPKGTYP dans le traitement du document            #
#       afin de gérer la sélection des transactions colisage                     #
#       filtrée sur le type le cas échéant                                       #
#################################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
If GUSER  = "HCB"
# Infbox ACTION
Endif
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"        : Case GACTION
                       When "TRTPKP" : Gosub INIT_TRTPKP
                      Endcase
 When "INIT_DIA"    : Case GACTION
                       When "TRTPKP" : Gosub INIT_DIA_TRTPKP
                      Endcase
 When "TERMINE"     : Case GACTION
                       When "TRTPKP" : Gosub TERMINE_TRTPKP
                      Endcase
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie
Case ACTION

 When "OUVRE"       : Case GACTION
                       When "TRTPKP", "SAIPKP" : Gosub OUVRE_TRTPKP
                      Endcase
 When "TITRE"       : Case GACTION
                       When "TRTPKP", "SAIPKP" : Gosub TIT_TRT
                      Endcase
 When "OUVRE_BOITE"  : Case GACTION
                       When "TRTPKP", "SAIPKP" : Gosub OUVRE_BOITE_TRTPKP
                      Endcase

 When "SETBOUT"     : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub SETBOUT_TRTPKP
                      Endcase
 When "DEBUT"       : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub DEBUT_TRTPKP
                      Endcase
 When "AP_CHOIX"    : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AP_CHOIX_TRTPKP
                      Endcase
 When "APRES_MODIF" : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub APRES_MODIF
                      Endcase
 When "AVANT_ENR"   : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AVANT_ENR_TRTPKP
                      Endcase
 When "ENR"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub ENR_TRTPKP
                      Endcase
 When "SUP"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub SUP_TRTPKP
                      Endcase
 When "AVANT_FIR"   : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AVANT_PREMIER_TRTPKP
                      Endcase
 When "FIR"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub PREMIER_TRTPKP
                      Endcase
 When "AVANT_LAS"   : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AVANT_DERNIER_TRTPKP
                      Endcase
 When "LAS"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub DERNIER_TRTPKP
                      Endcase

 When "AVANT_SUI"   : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AVANT_SUI_TRTPKP
                      Endcase
 When "SUI"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub SUI_TRTPKP
                      Endcase
 When "AVANT_PRE"   : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub AVANT_PRE_TRTPKP
                      Endcase
 When "PRE"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub PRE_TRTPKP
                      Endcase

 When "FIN"         : Case GACTION
                           When "TRTPKP", "SAIPKP" : Gosub FIN_TRTPKP
                      Endcase
 When "ABA"          : Case GACTION
                            When "TRTPKP", "SAIPKP" : Gosub ABA_TRTPKP
                      Endcase

 When "FINSAI"      : Case GACTION
                      Endcase

 When "AAPRES_NBLIG" : Case GACTION
                       When "TRTPKP", "SAIPKP", "SAIPKP2" : Gosub AAPRES_NBLIG     # hcb 55930
                       Endcase

 When "AB1_NBLIG"    : Case GACTION
                            When "TRTPKP", "SAIPKP", "ACLOB" : Gosub AB1_NBLIG
                       Endcase

 When "BB1_NBLIG"    : Case GACTION
                            When "TRTPKP", "SAIPKP", "ACLOB" : Gosub BB1_NBLIG
                       Endcase
# hcb 79994 deb
 When "BB2_NBLIG"    : Case GACTION
                            When "ACLOB" : Gosub BB2_NBLIG
                       Endcase
# hcb 79994 fin


Endcase

#--- Actions liées au traitement divers
Case ACTION
 When "TRT_DIV"     : Case TRAIT
                       When "PKPCOLOR"   : Gosub PKPCOLOR
                      Endcase
 When Default
Endcase

Return


#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

$AB1_NBLIG

Return

$BB1_NBLIG
# restitution environnement apres ACLOB

# repercution du numero de texte sur les autres lignes du colis
Local Integer WPACSEQ
Local Char    WSPHTEX(20)
WPACSEQ = [M:PKP1]PACSEQ(nolign-1)
WSPHTEX = [M:PKP1]SPHTEX(nolign-1)
For I = 0 To [M:PKP1]NBLIG-1
    If [M:PKP1]PACSEQ(I) =  WPACSEQ
       [M:PKP1]SPHTEX(I) =  WSPHTEX
       [M:PKP1]MODFLG(I) = 2
    Endif
Next

[M:PKP1]MODFLG(nolign-1) = 2
Return

# hcb 79994 deb
$BB2_NBLIG
[M:PKP1]MODFLG(nolign-1) = 2
Return
# hcb 79994 fin


#########################################################################
$INIT_TRTPKP
TIT = mess(320,198,1)
# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

If clalev([F:SDH]) = 0 Local File SDELIVERY  [SDH] Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD [SDD] Endif
If clalev([F:PRH]) = 0 Local File STOPREH    [PRH] Endif
If clalev([F:PRH1]) = 0 Local File STOPREH   [PRH1] Endif                 # hcb 110327-pck bug
If clalev([F:PRE]) = 0 Local File STOPRED    [PRE] Endif
If clalev([F:SRT]) = 0 Local File STKTRS     [SRT] Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD]  Endif
If clalev([F:SPH]) = 0 Local File SPACK      [SPH] Endif
If clalev([F:SPD]) = 0 Local File SPACKD     [SPD] Endif
If clalev([F:TPA]) = 0 Local File TABPACKAGE [TPA] Endif
If clalev([F:STJ]) = 0 Local File STOJOU     [STJ] Endif
If clalev([F:BPT]) = 0 Local File BPCARRIER  [BPT] Endif
If clalev([F:STA]) = 0 Local File STOALL     [STA] Endif
If clalev([F:STO]) = 0 Local File STOCK      [STO] Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER  [ITM] Endif
# hcb 76101
If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif
# hcb 76101

Call GLOBVAR(GFCYDEF(7)) From WWGLOBSTO

Return

#########################################################################
$INIT_DIA_TRTPKP
Raz [M:PKS1]

[M:PKS1]SSTOFCY = GFCYDEF(7)
[M:PKS1]SSHIDAT = date$
[M:PKS1]SVCRTYP = 4
[M:PKS1]SCOL    = 1
[M:PKS1]SNONVAL = 2
[M:PKS1]SVAL    = 1
[M:PKS1]SINV    = 1
[M:PKS1]PKGTYP  = 2
[M:PKS1]OBJET   = "SDH"
[M:PKS1]PREUSR  = GUSER
GFLAG           = ""

# lecture de la premiere transaction Colisage declaratif
#               de la validation des listes ...
Filter [SRT] Where SRTTYP=11 & ENAFLG=2 & PKGTYP = [M:PKS1]PKGTYP
   Read [SRT] First
Filter [SRT]
If fstat
   Raz [F:SRT]
Endif
[M:PKS1]SRTNUM  = [F:SRT]SRTNUM
[M:PKS1]SRTTYP  = [F:SRT]SRTTYP
GFLAG           = [F:SRT]SRTNUM
GSRTNUM         = GFLAG
GPKPNUM         = GFLAG
Diszo [M:PKS1]SINV
Return

#########################################################################
$TERMINE_TRTPKP

Return



#########################################################################
# Détail des actions liées à la saisie fenêtre                          #
#########################################################################


$OUVRE_BOITE_TRTPKP
Global Char     GWCLECUR
Global Char     GORI_PKP  : GORI_PKP  =  "PKP1"      #  sert à charger l ecran PKP2

Global Integer  GVCRTYP
Global Integer  GDOCFLG
Global Char     GDOCNAM
Global Char     GSAVGFLAG
If dim(GPKD_BOITE)<1
   Global Char GPKD_BOITE(10)
Endif
If GACTION   = "TRTPKP"
   GVCRTYP   = [M:PKS1]SVCRTYP
Else
   GSAVGFLAG = GFLAG
   GVCRTYP   = val(PARAM(1))
   GFLAG     = PARAM(2)
   If GFLAG  = ""
      Local Char PARMSK(250)(1..16)
      PARMSK(1) = "SPK"
      PARMSK(2) = "B"
      If dim([M]PKGTYP) > 0
         [M]PKGTYP = GPKGTYP
      Endif
      Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
      GFLAG = VALEUR
     # lecture de la premiere transaction Colisage si pas de selection
     #               de la validation des listes ...
      If GFLAG = ""
         Filter [SRT] Where SRTTYP=11 & ENAFLG=2 & PKGTYP =  GPKGTYP
             Read [SRT] First
         Filter [SRT]
         If fstat
            Raz [F:SRT]
         Endif
         GFLAG           = [F:SRT]SRTNUM
      Endif
   Endif
   Read [SRT] SRT0=11;GFLAG
   If fstat | [F:SRT]ENAFLG=1
      Raz GFLAG
   Endif
   GSRTNUM = GFLAG
   GPKPNUM = GFLAG
Endif
GPKD_BOITE = "WOPKP"+GPKPNUM

GGRPFCY = [F:SRT]GFY
GDOCFLG = [F:SRT]DOCFLG
GDOCNAM = [F:SRT]DOCNAM

Case GVCRTYP
     When 3   : GBIDC1  = mess( 3,701,1)       # Preparation
                Raz GBIDC2
     When 4   : GBIDC1  = mess( 4,701,1)       # livraison
                GBIDC2  = mess( 2,407,1)       # Date livraison
Endcase
Global Integer GMODPAC  # pour gerer bouton enregistrement / abandon
Raz GMODPAC
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
If dim(GPKD_BOITE)>0
   If GPKD_BOITE <> ""
      BOITE = GPKD_BOITE
   Endif
   Kill GPKD_BOITE
Endif

Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="FPKP"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif

Gosub CHANGE_AWI From FUNPKP


Global Decimal GNBRLIG  # rubrique pour activer le bouton Suppression
                        # alimentée dans CHARGE_COLIS si nombre de detail > 1  GNBRLIG = 1

Global Decimal GWUNTWEI # poids de l Us par rapport à l emballage
Global Decimal GWUNT    # poids de l us article
Global Char    GWWEU    # unite de poids SDD si livraison , ITM si préparation



# Définition des critères de sélection des livraisons
#--- depuis le menu colisage
If GACTION = "TRTPKP"
   CRIT= "1=1"
   If [M:PKS1]SVCRTYP = 4
#                             criteres Livraison  (SDH)
      If [M:PKS1]SNUMDEB<>""
         CRIT -= '& SDHNUM>="'+[M:PKS1]SNUMDEB+'"'
      Endif
      If [M:PKS1]SNUMFIN<>""
         CRIT -= '& SDHNUM<="'+[M:PKS1]SNUMFIN+'"'
      Endif
      If [M:PKS1]SSTOFCY<>""
         CRIT -= '& STOFCY="'+[M:PKS1]SSTOFCY+'"'
      Endif
      If [M:PKS1]SSHIDAT<>[0/0/0]
         CRIT -= "& SHIDAT<=["+format$(GFMD,[M:PKS1]SSHIDAT)+"]"
      Endif
      If [M:PKS1]SBPCORDDEB<>""
         CRIT -= '& BPCORD>="'+[M:PKS1]SBPCORDDEB+'"'
      Endif
      If [M:PKS1]SBPCORDFIN<>""
         CRIT -= '& BPCORD<="'+[M:PKS1]SBPCORDFIN+'"'
      Endif
      If [M:PKS1]SBPAADDDEB<>""
         CRIT -= '& BPAADD>="'+[M:PKS1]SBPAADDDEB+'"'
      Endif
      If [M:PKS1]SBPAADDFIN<>""
         CRIT -= '& BPAADD<="'+[M:PKS1]SBPAADDFIN+'"'
      Endif
      If [M:PKS1]SCOL<>2
         CRIT -= "& PACFLG<>2"
      Endif
      If [M:PKS1]SNONVAL<>2
         CRIT -= "& CFMFLG=2"
      Endif
      If [M:PKS1]SVAL<>2
         CRIT -= "& CFMFLG<>2"
      Endif
      If [M:PKS1]SINV<>2
         CRIT -= "& INVFLG<>2"
      Endif

# recherche premeire livraisons à traiter pour chargement filgauche
      Filter [SDH] Where evalue (CRIT)
      Read [SDH]SDH0 First
      If fstat
         Raz [F:SDH]
      Endif
      Filter [SDH]
   Else
#                             criteres Préparation  (PRH)
      If [M:PKS1]SNUMDEB<>""
         CRIT -= '& PRHNUM>="'+[M:PKS1]SNUMDEB+'"'
      Endif
      If [M:PKS1]SNUMFIN<>""
         CRIT -= '& PRHNUM<="'+[M:PKS1]SNUMFIN+'"'
      Endif
      If [M:PKS1]SSTOFCY<>""
         CRIT -= '& STOFCY="'+[M:PKS1]SSTOFCY+'"'
      Endif
      If [M:PKS1]SSHIDAT<>[0/0/0]
         CRIT -= "& SHIDAT<=["+format$(GFMD,[M:PKS1]SSHIDAT)+"]"
      Endif
      If [M:PKS1]SBPCORDDEB<>""
         CRIT -= '& BPCORD>="'+[M:PKS1]SBPCORDDEB+'"'
      Endif
      If [M:PKS1]SBPCORDFIN<>""
         CRIT -= '& BPCORD<="'+[M:PKS1]SBPCORDFIN+'"'
      Endif
      If [M:PKS1]SBPAADDDEB<>""
         CRIT -= '& BPAADD>="'+[M:PKS1]SBPAADDDEB+'"'
      Endif
      If [M:PKS1]SBPAADDFIN<>""
         CRIT -= '& BPAADD<="'+[M:PKS1]SBPAADDFIN+'"'
      Endif
      If [M:PKS1]SCOL<>2
         CRIT -= "& PACFLG<>2"
      Endif
      CRIT -= "& DLVFLG = 2"

# recherche premeire livraisons à traiter pour chargement filgauche
      Filter [PRH] Where evalue (CRIT)
      Read [PRH]PRH0 First
      If fstat
         Raz [F:PRH]
      Endif
      Filter [PRH]
   Endif
Endif

#--- depuis la gestion des livraisons : preparation
If GACTION = "SAIPKP"
   If GCONSULT = 2 & dim(GVCRNUMCOL) > 0 & GVCRNUMCOL <> ""
      If GVCRTYP = 4
         CRIT = "SDHNUM=GVCRNUMCOL"
      Else
         CRIT = "PRHNUM=GVCRNUMCOL & DLVFLG = 2 "
      Endif
   Else
      If GVCRTYP = 4
         CRIT = "SDHNUM=[M:SDH0]SDHNUM"
      Else
         CRIT = "PRHNUM=[M:PRH0]PRHNUM & DLVFLG = 2 "
      Endif
   Endif
Endif

Return

#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","11",GPKPNUM) From ATEXTRA
    TIT = GPKPNUM-":"-TIT
Return

########################################################################
# CHANGE_AWI                               chargement traitement fenetre
########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

$OUVRE_TRTPKP

Local  Integer  FINCOL, NBLIV, VOK : VOK = 1

Local  Char     W

Local  Char     SYMBOLE
Local  Integer  I, J, K, NOL
#---------------------------------------------------------------------#
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# WCODTRT     : Traitement effectué "C" (Création), "A" (Annulation)  #
#---------------------------------------------------------------------#
Local Char WPOINT_CODTRT
Local  Char  CRIT(250)
TIT = mess(156,195,1)
If clalev([F:ITF])  = 0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])  = 0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:STJ])  = 0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO])  = 0 Local File STOCK      [STO]  Endif
If clalev([F:STA])  = 0 Local File STOALL     [STA]  Endif
If clalev([F:SPD])  = 0 Local File SPACKD     [SPD]  Endif
If clalev([F:SPH])  = 0 Local File SPACK      [SPH]  Endif
If clalev([F:TPA])  = 0 Local File TABPACKAGE [TPA]  Endif
If clalev([F:ARP])  = 0 Local File AREPORT    [ARP]  Endif
If clalev([F:SDH1]) = 0 Local File SDELIVERY  [SDH1] Endif
If clalev([F:PRH1]) = 0 Local File STOPREH    [PRH1] Endif
# hcb 76101
If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif
# hcb 76101

# Issue X3-69499 - 2018-06-12 by TS
If clalev([F:ACV]) = 0 Local File ACTIV      [ACV] Endif
Global Integer GVALIDLIN  : # Niveau de validation de la livraison
                            #   1 = Ligne de livraison
                            #   0 = Livraison complète
GVALIDLIN=0
# Complète Delivery Validation "CDV"
Read [ACV] CODACT = "CDV"
If !fstat & [F:ACV]FLACT<>2
  GVALIDLIN=1
Endif
# End issue X3-69499

# Compteur colisage
Local Integer LRET
# Récupération des codes compteur
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(24) = [F:TCA]MANCOU(24) # Compteur colisage
GSTKCPT   (24) = [F:TCA]CODNUM(24)

Return

#########################################################################
$SETBOUT_TRTPKP
# si nombre de colis  > 0 bouton suppression
If [M:PKP1]PACNBR > 0 & GCONSULT <> 2
   CHBOU+="S"
Else
   Call VIREBOUT(CHBOU,"S") From GOBJET
Endif


Call VIREBOUT(CHBOU,"EA") From GOBJET

# si des modif ont ete faites boutons enregistrer et abandon
If GMODPAC = 1
   CHBOU+="E"
   CHBOU+="A"
Endif

# # pas de menu suivant precedent premier dernier si  action <> de la fonction de colisage
If GACTION <>  "TRTPKP"
   Call VIREBOUT(CHBOU,"<>09") From GOBJET
Else
# pas de menu suivant precedent premier dernier si un seul document est selectionné
   If [M:PKS1]SNUMDEB<> "" & [M:PKS1]SNUMDEB = [M:PKS1]SNUMFIN
      Call VIREBOUT(CHBOU,"<>09") From GOBJET
   Endif
Endif

#Bouton Etiquette  absent si nombre de colis = 0
If [M:PKP1]PACNBR  = 0
   Call VIREBOUT(CHMEN,"a") From GOBJET
Endif
If GCONSULT = 2
   Call VIREBOUT(CHBOU,"AES") From GOBJET
Endif


Return


#########################################################################

$APRES_MODIF
WI = find(2,[M:PKP1]MODFLG(0..[M:PKP1]NBLIG-1))
If WI > 0
   GMODPAC = 1
Endif
Actzo [M:PKP1]BPTNUM
Actzo [M:PKP1]PREUSR

Return


#########################################################################
$DEBUT_TRTPKP
Raz NBLIV
If GVCRTYP = 4
# Filtre sur les livraisons à traiter
   Filter [SDH] Where evalue (CRIT)
   Read [SDH]SDH0 First
   If !fstat
      # Issue X3-69499 - 2018-06-12 by TS
      If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
        Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
        If rowcount([SDD])>0
          Filter [SDD]
          Goto NEXT_SDH
        Endif
        Filter [SDD]
      Endif
      # End issue X3-69499
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_SDH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
   Goto SUITE_SDH
$NEXT_SDH
   Read [SDH]SDH0 Next
   If !fstat
      # Issue X3-69499 - 2018-06-12 by TS
      If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
        Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
        If rowcount([SDD])>0
          Filter [SDD]
          Goto NEXT_SDH
        Endif
        Filter [SDD]
      Endif
      # End issue X3-69499
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_SDH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
$SUITE_SDH
   Gosub CHARGE_PKP1
Else
# Filtre sur les preparations à traiter
   Filter [PRH] Where evalue (CRIT)
   Read [PRH]PRH0 First
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_PRH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
   Goto SUITE_PRH
$NEXT_PRH
   Read [PRH]PRH0 Next
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto NEXT_PRH
      Elsif VOK=0
         FIN=1
         Return
      Endif
   Else
      FIN=1
      Return
   Endif
$SUITE_PRH
   Gosub CHARGE_PKP1
Endif

Return

###################################################################
# Chargement de l'écran de colisage de la livraison / preparation #
###################################################################
$CHARGE_PKP1
Local Char WPACNUM
Raz WPACNUM
Raz [M:PKP1]
Local Integer LLIG
Local Integer I
Local Decimal WQTYSAUSTU
Local Decimal WPACQTYSTU   # sert à  mémoriser  [xxx]PACQTYSTU
Raz GMODPAC                # hcb 55930
If GVCRTYP = 4
   [M:PKP1]       = [F:SDH]
   [M:PKP1]VCRTYP = 4
   [M:PKP1]VCRNUM = [F:SDH]SDHNUM
   [M:PKP1]PACNBR = [F:SDH]PACNBR
   [M:PKP1]BPCORD = [F:SDH]BPCORD
   [M:PKP1]BPAADD = [F:SDH]BPAADD
   [M:PKP1]BPTNUM = [F:SDH]BPTNUM
   If [F:SDH]BPTNUM <> [F:BPT]BPTNUM
      Read [BPT]BPT0 = [F:SDH]BPTNUM
         If fstat
            Raz [F:BPT]
         Endif
   Endif

   If [F:SDH]BPDNAM(0) <> ""

      [M:PKP1]BPDNAM = [F:SDH]BPDNAM(0)
   Else
      If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD
         Read [BPD]BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
         If fstat
            Raz [F:BPD]
         Endif
      Endif
      [M:PKP1]BPDNAM = [F:BPD]BPDNAM
   Endif

   Filter [SDD] Where SDHNUM=[M:PKP1]VCRNUM & [F:SDD]PCKFLG = 2
   For [SDD]
       Raz WQTYSAUSTU
       Raz WPACNUM
       Raz GWUNTWEI
       Raz GWUNT
       Raz GWWEU
       LLIG = [M:PKP1]NBLIG
       Raz [M:PKP1]NETWEI    (LLIG)
       Raz [M:PKP1]GROWEI    (LLIG)
       Raz [M:PKP1]NETWEIPCK (LLIG)
       Raz [M:PKP1]VOL       (LLIG)
       If [F:ITM]ITMREF <> [F:SDD]ITMREF                                                           # hcb 110327-pck
          Read [F:ITM]ITM0=[F:SDD]ITMREF                                                           # hcb 110327-pck
          If fstat                                                                                 # hcb 110327-pck
             Raz [F:ITM]                                                                           # hcb 110327-pck
          Endif                                                                                    # hcb 110327-pck
       Endif                                                                                       # hcb 110327-pck
      # [M:PKP1]STOMGTCOD (LLIG) = [F:ITM]STOMGTCOD
#lecture ITMFACILIT  pour recuperer STOMGTCOD et PCKSTKFLG
       If [F:ITF]STOFCY <> [M:PKP1]STOFCY | [F:ITF]ITMREF <> [F:SDD]ITMREF
          Read [ITF]ITF0 = [F:SDD]ITMREF ;[M:PKP1]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif

       GWUNTWEI = 1                                # poids de l US / colis
       GWUNT    = [F:SDD]UNTWEI/[F:SDD]SAUSTUCOE   # poids de l US
       GWWEU    = [F:SDD]WEU
       [M:PKP1]STOMGTCOD   (LLIG)          = [F:ITF]STOMGTCOD    #gestion stock
       [M:PKP1]PCKSTKFLG   (LLIG)          = [F:ITF]PCKSTKFLG    #detail stock colisage
       [M:PKP1]PCKSERFLG   (LLIG)          = [F:ITF]PCKSERFLG                                      # hcb 110327-pck
       [M:PKP1]SERMGTCOD   (LLIG)          = [F:ITM]SERMGTCOD                                      # hcb 110327-pck
       [M:PKP1]QTYINI      (LLIG)          = [F:SDD]QTY                                            # hcb 110327-pck
       [M:PKP1]WLLIG       (LLIG)          = LLIG * 10000
       [M:PKP1]VCRLIN      (LLIG)          = [F:SDD]SDDLIN
       [M:PKP1]ITMREF      (LLIG)          = [F:SDD]ITMREF
       [M:PKP1]ITMDES1     (LLIG)          = [F:SDD]ITMDES1
       [M:PKP1]SAU         (LLIG)          = [F:SDD]SAU
       [M:PKP1]SAUSTUCOE   (LLIG)          = [F:SDD]SAUSTUCOE
       [M:PKP1]UNTWEI      (LLIG)          = GWUNT
       [M:PKP1]LIGWEU      (LLIG)          = GWWEU
       [M:PKP1]LIGUNTWEI   (LLIG)          = GWUNTWEI
       [M:PKP1]WEUSDD      (LLIG)          = [F:SDD]WEU
       [M:PKP1]STU         (LLIG)          = [F:SDD]STU
       [M:PKP1]LBLFMT      (LLIG)          = GDOCNAM


#                                                                       # hcb 105708 deb
       Local Integer WOK
       Raz WOK
       If [F:SDD]PACQTYSTU = 0
          Filter [SPD] Where  VCRTYP   = GVCRTYP          &
&                             VCRNUM   = [F:SDD]SDHNUM    &
&                             VCRLIN   = [F:SDD]SDDLIN
&         Order By Key SPD0
          For [SPD]
              WOK = 1
              Break
          Next
          Filter [SPD]

       Endif
#                                                                       # hcb 105708 end

      If [F:SDD]PACQTYSTU <> 0  | WOK = 1                               # hcb 105708
#lecture des détails colis existant pour cette ligne de livraison
          Filter [SPD] Where  VCRTYP   = GVCRTYP          &
&                             VCRNUM   = [F:SDD]SDHNUM    &
&                             VCRLIN   = [F:SDD]SDDLIN
&         Order By Key SPD0

          Raz WQTYSAUSTU
          For [SPD]
              If WPACNUM = [F:SPD]PACNUM

                 [M:PKP1]NETWEI    (LLIG)   += [F:SPD]NETWEI
#                [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE         # hcb X3-70246
                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU                            # hcb X3-70246

                 Call QTEARR([M:PKP1]QTYSTU (LLIG),[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]NETWEIPCK (LLIG)   += [M:PKP1]NETWEI  (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
                 [M:PKP1]PACQTYSTU (LLIG)    = [M:PKP1]QTYSTU  (LLIG)
#                [M:PKP1]QTY       (LLIG)    = [M:PKP1]QTYSTU  (LLIG) /  [F:SDD]SAUSTUCOE  # hcb 97419
#                 [M:PKP1]QTY       (LLIG)    += [F:SPD]QTY                # hcb X3-108941
                 [M:PKP1]QTY       (LLIG)    += [F:SPD]QTYPCU/[M:PKP1]SAUSTUCOE   (LLIG) #  hcb X3-108941
                 Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV         # hcb 76850
                [M:PKP1]QTYSAU    (LLIG)    = [M:PKP1]QTY     (LLIG)
                 [M:PKP1]QTYSAUSTU (LLIG)    = [M:PKP1]QTYSTU  (LLIG)
#                WQTYSAUSTU                 += ([F:SPD]QTYPCU * [F:SPD]PCUSTUCOE)    # hcb 97419
#                 WQTYSAUSTU                 += [F:SPD]QTY                            # hcb X3-108941
                  WQTYSAUSTU                 += [F:SPD]QTYPCU/[F:SDD]SAUSTUCOE        # hcb X3-108941
                 Call QTEARR(WQTYSAUSTU,[M:PKP1]SAU  (LLIG)) From TRTDIV             # hcb 97419
              Else
# Lecture entete COLIS
                 Read [SPH]SPH0 = GVCRTYP;[F:SDD]SDHNUM ;[F:SPD]PACNUM;[F:SPD]PACSEQ
                 If fstat
                    Raz [F:SPH]
                 Endif
                 LLIG = [M:PKP1]NBLIG
                 If [F:TPA]PCK <> [F:SPH]PCK
                    Read [TPA]TPA0=[F:SPH]PCK
                    If fstat
                       Raz [F:TPA]
                    Endif
                 Endif
                If GWWEU <> "" & [F:SPH]WEU <> ""
                    If GWWEU <> [F:SPH]WEU
        # Conversion poids unitaire de unité poids liv en unité poids colis
                       Call SCONV_TCO(GWWEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
                    Endif
                 Endif
                 [M:PKP1]LIGUNTWEI (LLIG)       = GWUNTWEI
                 [M:PKP1]NETWEI    (LLIG)       = [F:SPD]NETWEI
                 [M:PKP1]GROWEI    (LLIG)       = [F:SPH]NETWEI + [F:SPH]PCKWEI

   # Calcul poids de la ligne  en unite de l emballage
                 [M:PKP1]NETWEIPCK (LLIG)   += [M:PKP1]NETWEI(LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
                 [M:PKP1]PACFLG    (LLIG)       = 2
                 [M:PKP1]MODFLG    (LLIG)       = 0
                 [M:PKP1]PCK       (LLIG)       = [F:SPH]PCK
                 [M:PKP1]PCKWEI    (LLIG)       = [F:SPH]PCKWEI
                 [M:PKP1]SCCCOD    (LLIG)       = [F:SPH]SCCCOD
                 [M:PKP1]LIGWEU    (LLIG)       = GWWEU
                 [M:PKP1]VOL       (LLIG)       = [F:SPH]VOL
                 [M:PKP1]WEU       (LLIG)       = [F:SPH]WEU
                 [M:PKP1]VOU       (LLIG)       = [F:SPH]VOU
                 [M:PKP1]LBLFMT    (LLIG)       = [F:SPH]LBLFMT
                 [M:PKP1]SPHTEX    (LLIG)       = [F:SPH]SPHTEX
                 [M:PKP1]PACNUM    (LLIG)       = [F:SPD]PACNUM
                 [M:PKP1]PACNUM_AV (LLIG)       = [F:SPD]PACNUM
                 [M:PKP1]STOMGTCOD (LLIG)       = [F:ITF]STOMGTCOD    #gestion stock
                 [M:PKP1]PCKSTKFLG (LLIG)       = [F:ITF]PCKSTKFLG    #detail stock colisage
                 [M:PKP1]PCKSERFLG (LLIG)       = [F:ITF]PCKSERFLG                                 # hcb 110327-pck
                 [M:PKP1]SERMGTCOD (LLIG)       = [F:ITM]SERMGTCOD                                 # hcb 110327-pck
                 [M:PKP1]QTYINI    (LLIG)       = [F:SDD]QTY                                       # hcb 110327-pck
                 [M:PKP1]WLLIG     (LLIG)       = LLIG * 10000
                 [M:PKP1]VCRLIN    (LLIG)       = [F:SDD]SDDLIN
                 [M:PKP1]ITMREF    (LLIG)       = [F:SDD]ITMREF
                 [M:PKP1]ITMDES1   (LLIG)       = [F:SDD]ITMDES1
                 [M:PKP1]SAU       (LLIG)       = [F:SDD]SAU
                 [M:PKP1]SAUSTUCOE (LLIG)       = [F:SDD]SAUSTUCOE
                 [M:PKP1]UNTWEI    (LLIG)       = GWUNT
                 [M:PKP1]WEUSDD    (LLIG)       = [F:SDD]WEU
                 [M:PKP1]STU       (LLIG)       = [F:SDD]STU

                  # recherche no pacseq
                 If LLIG = 0
                    [M:PKP1]PACSEQ    (LLIG)    = 1
                    [M:PKP1]PACSEQH   (LLIG)    = 1
                 Else
                    Raz I
                    I =sigma(0,[M:PKP1]NBLIG-1,(indcum+1)*([M:PKP1]PACNUM(indcum) = [M:PKP1]PACNUM (LLIG) &
&                                               I=0 & sigma(I=1,1,1)))
                    If I <> 0
                       I -= 1
                       [M:PKP1]PACSEQ (LLIG) = [M:PKP1]PACSEQ (I)
                       Raz [M:PKP1]GROWEI    (LLIG)
                       Raz [M:PKP1]LBLFMT    (LLIG)
                       Raz [M:PKP1]PACSEQH   (LLIG)
                    Else
                       [M:PKP1]PACSEQ    (LLIG)    = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
                       [M:PKP1]PACSEQH   (LLIG)    = 1
                    Endif
                 Endif
#                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE         # hcb X3-70246
                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU                             # hcb X3-70246
                 Call QTEARR([M:PKP1]QTYSTU (LLIG),[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]PACQTYSTU (LLIG)       = [M:PKP1]QTYSTU (LLIG)
#                 [M:PKP1]QTY       (LLIG)       = [M:PKP1]QTYSTU (LLIG) /  [F:SDD]SAUSTUCOE   # hcb 97419
#                 [M:PKP1]QTY       (LLIG)    += [F:SPD]QTY                # hcb X3-108941
                 [M:PKP1]QTY       (LLIG)    += [F:SPD]QTYPCU/[M:PKP1]SAUSTUCOE   (LLIG) #  hcb X3-108941
                 Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]QTYSAU    (LLIG)       = [M:PKP1]QTY    (LLIG)
                 [M:PKP1]QTYSAUSTU (LLIG)       = [M:PKP1]QTYSTU (LLIG)
#                 WQTYSAUSTU                 += [F:SPD]QTY                            # hcb X3-108941
                  WQTYSAUSTU                 += [F:SPD]QTYPCU/[F:SDD]SAUSTUCOE        # hcb X3-108941
                 Call QTEARR(WQTYSAUSTU,[M:PKP1]SAU  (LLIG)) From TRTDIV             # hcb 120142
                 If [F:TPA]PCK     <> [F:SPH]PCK
                    Read [TPA]TPA0 =  [F:SPH]PCK
                    If fstat
                       Raz [F:TPA]
                    Endif
                 Endif
                 [M:PKP1]PCKLEN    (LLIG)       = [F:TPA]PCKLEN
                 [M:PKP1]PCKWID    (LLIG)       = [F:TPA]PCKWID
                 [M:PKP1]PCKHEI    (LLIG)       = [F:TPA]PCKHEI
                 [M:PKP1]DIU       (LLIG)       = [F:TPA]DIU
                 [M:PKP1]NBLIG += 1
                 WPACNUM = [F:SPD]PACNUM
                 WSCCCOD = [F:SPH]SCCCOD
              Endif
          Next
          Filter [SPD]
 #         If WQTYSAUSTU < [M:PKP1]QTYSAU(LLIG)                             # hcb 122453
           If WQTYSAUSTU < [F:SDD]QTY                                       # hcb 122453
             LLIG = [M:PKP1]NBLIG
             [M:PKP1]MODFLG        (LLIG)          = 0
             Raz [M:PKP1]NETWEI    (LLIG)
             Raz [M:PKP1]GROWEI    (LLIG)
             Raz [M:PKP1]NETWEIPCK (LLIG)
             Raz [M:PKP1]VOL       (LLIG)
             [M:PKP1]WLLIG         (LLIG)          = LLIG * 10000
             [M:PKP1]STOMGTCOD     (LLIG)          = [F:ITF]STOMGTCOD    #gestion stock
             [M:PKP1]PCKSTKFLG     (LLIG)          = [F:ITF]PCKSTKFLG    #detail stock colisage
             [M:PKP1]PCKSERFLG     (LLIG)          = [F:ITF]PCKSERFLG                              # hcb 110327-pck
             [M:PKP1]SERMGTCOD     (LLIG)          = [F:ITM]SERMGTCOD                              # hcb 110327-pck
             [M:PKP1]QTYINI        (LLIG)          = [F:SDD]QTY                                    # hcb 110327-pck
             If [M:PKP1]PCKSERFLG  (LLIG) = 2 & [M:PKP1]SERMGTCOD (LLIG) = 4 & [F:SDD]PACQTYSTU = 0  # hcb 110327-pck
                [M:PKP1]IDETAIL    (LLIG) = 4                                                      # hcb 110327-pck
             Endif                                                                                 # hcb 110327-pck

             [M:PKP1]VCRLIN        (LLIG)          = [F:SDD]SDDLIN
             [M:PKP1]ITMREF        (LLIG)          = [F:SDD]ITMREF
             [M:PKP1]ITMDES1       (LLIG)          = [F:SDD]ITMDES1
             [M:PKP1]SAU           (LLIG)          = [F:SDD]SAU
             [M:PKP1]SAUSTUCOE     (LLIG)          = [F:SDD]SAUSTUCOE
             [M:PKP1]LIGUNTWEI     (LLIG)          = 1                    # hcb 57663
             [M:PKP1]UNTWEI        (LLIG)          = GWUNT
             [M:PKP1]WEUSDD        (LLIG)          = [F:SDD]WEU
             [M:PKP1]STU           (LLIG)          = [F:SDD]STU
             [M:PKP1]PCK           (LLIG)          = [F:SDD]PCK
             [M:PKP1]PCKCAP        (LLIG)          = [F:SDD]PCKCAP    # hcb 55930
             [M:PKP1]QTYSAU        (LLIG)          = [F:SDD]QTY - WQTYSAUSTU                            # hcb 116765
             [M:PKP1]QTYSAUSTU     (LLIG)          = [M:PKP1]QTYSAU   (LLIG) * [F:SDD]SAUSTUCOE         # hcb 116765
             Call QTEARR([M:PKP1]QTYSAUSTU (LLIG),[M:PKP1]STU  (LLIG)) From TRTDIV                      # hcb 116765
             [M:PKP1]QTYSTU        (LLIG)          = [M:PKP1]QTYSAUSTU   (LLIG)
             [M:PKP1]QTY           (LLIG)          = [M:PKP1]QTYSAU      (LLIG)
             [M:PKP1]NETWEI        (LLIG)          = [M:PKP1]QTYSTU      (LLIG) * [M:PKP1]UNTWEI   (LLIG)   # hcb 54897
             [M:PKP1]NETWEIPCK     (LLIG)          = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
             [M:PKP1]GROWEI        (LLIG)          = 0
             [M:PKP1]LIGWEU        (LLIG)          = GWWEU
             [M:PKP1]PACNUM        (LLIG)          = ""
             [M:PKP1]SCCCOD        (LLIG)          = ""
             [M:PKP1]WEU           (LLIG)          = [F:SDD]WEU
             #If [M:PKP1]WEU      (LLIG)          = ""
             #   [M:PKP1]WEU      (LLIG)          = [F:ITM]WEU
             #   [M:PKP1]WEUSDD   (LLIG)          = [F:ITM]WEU
             #Endif
             If [F:SDD]PCK <> ""
                If [F:TPA]PCK     <> [F:SDD]PCK
                   Read [TPA]TPA0 =  [F:SDD]PCK
                   If fstat
                      Raz [F:TPA]
                   Endif
                Endif
                [M:PKP1]PCKWEI   (LLIG)          = [F:TPA]PCKWEI
                [M:PKP1]VOL      (LLIG)          = [F:TPA]VOL
                [M:PKP1]WEU      (LLIG)          = [F:TPA]WEU
                [M:PKP1]VOU      (LLIG)          = [F:TPA]VOU
                [M:PKP1]PCKLEN   (LLIG)          = [F:TPA]PCKLEN
                [M:PKP1]PCKWID   (LLIG)          = [F:TPA]PCKWID
                [M:PKP1]PCKHEI   (LLIG)          = [F:TPA]PCKHEI
                [M:PKP1]DIU      (LLIG)          = [F:TPA]DIU
                If [F:TPA]LBLFMT <> ""
                   [M:PKP1]LBLFMT (LLIG)         = [F:TPA]LBLFMT
                Endif
             Endif
             # calcul nombre de detail
             Gosub CAL_NBDETAIL
             [M:PKP1]NBLIG += 1
          Endif
       Else

          [M:PKP1]LIGUNTWEI     (LLIG)       = GWUNTWEI
          [M:PKP1]PCK           (LLIG)       = [F:SDD]PCK
          [M:PKP1]PCKCAP        (LLIG)       = [F:SDD]PCKCAP    # hcb 55930
          [M:PKP1]QTYSAU        (LLIG)       = [F:SDD]QTY
          [M:PKP1]QTYSAUSTU     (LLIG)       = [F:SDD]QTYSTU
          [M:PKP1]QTYSTU        (LLIG)       = [M:PKP1]QTYSAUSTU   (LLIG)
          [M:PKP1]QTY           (LLIG)       = [M:PKP1]QTYSAU      (LLIG)
          [M:PKP1]NETWEI        (LLIG)       = [M:PKP1]QTYSTU      (LLIG) * [M:PKP1]UNTWEI   (LLIG)   # hcb 54897
          [M:PKP1]NETWEIPCK     (LLIG)       = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
          [M:PKP1]GROWEI        (LLIG)       = 0
          [M:PKP1]LIGWEU        (LLIG)       = GWWEU
          [M:PKP1]WEU           (LLIG)       = GWWEU
          [M:PKP1]PACNUM        (LLIG)       = ""
          [M:PKP1]SCCCOD        (LLIG)       = ""
          If [F:SDD]PCK <> ""
             If [F:TPA]PCK     <> [F:SDD]PCK
                Read [TPA]TPA0 =  [F:SDD]PCK
                If fstat
                   Raz [F:TPA]
                Endif
             Endif
# hcb 54897
             If GWWEU <> "" & [F:TPA]WEU <> ""
                If GWWEU <> [F:TPA]WEU
        # Conversion poids unitaire de unité poids liv en unité poids colis
                       Call SCONV_TCO(GWWEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
                    Endif
                 [M:PKP1]LIGUNTWEI (LLIG)       = GWUNTWEI
                 [M:PKP1]NETWEI        (LLIG)   = [M:PKP1]QTYSTU      (LLIG) * GWUNT
                 [M:PKP1]NETWEIPCK     (LLIG)   = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
             Endif
# hcb 54897
             [M:PKP1]PCKWEI     (LLIG)       = [F:TPA]PCKWEI
             [M:PKP1]VOL        (LLIG)       = [F:TPA]VOL
             [M:PKP1]WEU        (LLIG)       = [F:TPA]WEU
             [M:PKP1]VOU        (LLIG)       = [F:TPA]VOU
             [M:PKP1]PCKLEN     (LLIG)       = [F:TPA]PCKLEN
             [M:PKP1]PCKWID     (LLIG)       = [F:TPA]PCKWID
             [M:PKP1]PCKHEI     (LLIG)       = [F:TPA]PCKHEI
             [M:PKP1]DIU        (LLIG)       = [F:TPA]DIU
             If [F:TPA]LBLFMT <> ""
                [M:PKP1]LBLFMT     (LLIG)       = [F:TPA]LBLFMT
             Endif
          Endif
          # calcul nombre de detail
          Gosub CAL_NBDETAIL
          # Colisage automatique si :                                                                # hcb 55930
          #      Emballage  et capacité sont renseignés                                              # hcb 55930
          #      Nombre de détail = 1                                                                # hcb 55930
          [M:PKP1]QTYINI(LLIG)    =    [M:PKP1]QTY   (LLIG)                                        # hcb 110327-pck
           WPACQTYSTU             =    [F:SDD]PACQTYSTU                                            # hcb 110327-pck
          If [M:PKP1]PCK(LLIG) <> "" & [M:PKP1]PCKCAP(LLIG) <> 0                                     # hcb 55930 2
             Gosub COLIS_AUTO                                                                        # hcb 55930
          Else                                                                                       # hcb 55930
             If [M:PKP1]PCKSERFLG (LLIG) = 2 & [M:PKP1]SERMGTCOD (LLIG) = 4 & [F:SDD]PACQTYSTU = 0 # hcb 110327-pck
                [M:PKP1]IDETAIL   (LLIG) = 4                                                       # hcb 110327-pck
             Endif                                                                                 # hcb 110327-pck
             [M:PKP1]NBLIG += 1
          Endif                                                                                      # hcb 55930
       Endif
   Next
   Filter [SDD]
Else
   [M:PKP1]       = [F:PRH]
   [M:PKP1]VCRTYP = 3
   [M:PKP1]VCRNUM = [F:PRH]PRHNUM
   [M:PKP1]PACNBR = [F:PRH]PACNBR
   [M:PKP1]BPCORD = [F:PRH]BPCORD
   [M:PKP1]BPAADD = [F:PRH]BPAADD
   If [F:BPD]BPCNUM <> [F:PRH]BPCORD | [F:BPD]BPAADD <> [F:PRH]BPAADD
      Read [BPD]BPD0 = [F:PRH]BPCORD;[F:PRH]BPAADD
      If fstat
         Raz [F:BPD]
      Endif
   Endif
   [M:PKP1]BPDNAM = [F:BPD]BPDNAM

   If dim([F:PRH]PREUSR) > 0
      [M:PKP1]PREUSR = [F:PRH]PREUSR
   Endif

   Filter [PRE] Where PRHNUM=[M:PKP1]VCRNUM & [F:PRE]PCKFLG = 2
   For [PRE]
       Raz WQTYSAUSTU
       Raz WPACNUM
       LLIG = [M:PKP1]NBLIG
       If [F:ITM]ITMREF <> [F:PRE]ITMREF
          Read [F:ITM]ITM0=[F:PRE]ITMREF
          If fstat
             Raz [F:ITM]
          Endif
       Endif
       [M:PKP1]STOMGTCOD (LLIG) = [F:ITM]STOMGTCOD
#lecture ITMFACILIT  pour recuperer STOMGTCOD et PCKSTKFLG
       If [F:ITF]STOFCY <> [M:PKP1]STOFCY | [F:ITF]ITMREF <> [F:PRE]ITMREF
          Read [ITF]ITF0 = [F:PRE]ITMREF ;[M:PKP1]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif
       GWUNTWEI = 1                                # poids de l US / colis
       GWUNT    = [F:ITM]ITMWEI                    # poids de l US
       GWWEU    = [F:ITM]WEU

       [M:PKP1]STOMGTCOD     (LLIG)          = [F:ITF]STOMGTCOD    #gestion stock
       [M:PKP1]PCKSTKFLG     (LLIG)          = [F:ITF]PCKSTKFLG    #detail stock colisage
       [M:PKP1]PCKSERFLG     (LLIG)          = [F:ITF]PCKSERFLG                                    # hcb 110327-pck
       [M:PKP1]SERMGTCOD     (LLIG)          = [F:ITM]SERMGTCOD                                    # hcb 110327-pck
       [M:PKP1]QTYINI        (LLIG)          = [F:PRE]QTYSTU                                       # hcb 110327-pck
       [M:PKP1]WLLIG         (LLIG)          = LLIG * 10000
       Raz [M:PKP1]NETWEI    (LLIG)
       Raz [M:PKP1]GROWEI    (LLIG)
       Raz [M:PKP1]NETWEIPCK (LLIG)
       Raz [M:PKP1]VOL       (LLIG)
       [M:PKP1]VCRLIN        (LLIG)          = [F:PRE]PRELIN
       [M:PKP1]ITMREF        (LLIG)          = [F:PRE]ITMREF
       [M:PKP1]MODFLG        (LLIG)          = 0
       #[M:PKP1]ITMDES1       (LLIG)          = [F:ITM]ITMDES1
       Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKP1]ITMDES1(LLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
       [M:PKP1]SAU           (LLIG)          = [F:PRE]PCU              # 55839
       [M:PKP1]SAUSTUCOE     (LLIG)          = [F:PRE]PCUSTUCOE        # 55839
       [M:PKP1]LIGUNTWEI     (LLIG)          = GWUNTWEI
       [M:PKP1]UNTWEI        (LLIG)          = GWUNT
       [M:PKP1]WEUSDD        (LLIG)          = [F:ITM]WEU
       [M:PKP1]WEU           (LLIG)          = [F:ITM]WEU
       [M:PKP1]STU           (LLIG)          = [F:PRE]STU
       [M:PKP1]LIGWEU        (LLIG)          = GWWEU

       If [F:PRE]PACQTYSTU <> 0
#lecture des détails colis existant pour cette ligne de livraison
          Filter [SPD] Where  VCRTYP   = GVCRTYP          &
&                             VCRNUM   = [F:PRE]PRHNUM    &
&                             VCRLIN   = [F:PRE]PRELIN
&         Order By Key SPD0
          For [SPD]
              If WPACNUM = [F:SPD]PACNUM
                 [M:PKP1]NETWEI    (LLIG)   += [F:SPD]NETWEI
#                [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE         # hcb X3-70246
                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU                            # hcb X3-70246

                 Call QTEARR([M:PKP1]QTYSTU (LLIG),[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]NETWEIPCK (LLIG)   += [M:PKP1]NETWEI  (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
                 [M:PKP1]PACQTYSTU (LLIG)    = [M:PKP1]QTYSTU  (LLIG)
                 [M:PKP1]QTY       (LLIG)    = [M:PKP1]QTYSTU  (LLIG) / [M:PKP1]SAUSTUCOE (LLIG)  # hcb 55839
                 Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]QTYSAU    (LLIG)    = [M:PKP1]QTY     (LLIG)
                 [M:PKP1]QTYSAUSTU (LLIG)    = [M:PKP1]QTYSTU  (LLIG)
#                 WQTYSAUSTU                 += [F:SPD]QTYPCU         * [F:SPD]PCUSTUCOE    # hcb X3-70246
                 WQTYSAUSTU                 += [F:SPD]QTYPCU                                # hcb X3-70246
                 Call QTEARR(WQTYSAUSTU,[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76686

              Else
# Lecture entete COLIS
                 Read [SPH]SPH0 = GVCRTYP;[F:PRE]PRHNUM;[F:SPD]PACNUM;[F:SPD]PACSEQ
                 If fstat
                    Raz [F:SPH]
                 Endif
                 LLIG = [M:PKP1]NBLIG
                 [M:PKP1]PACFLG    (LLIG)       = 2
                 [M:PKP1]MODFLG    (LLIG)       = 0
                 [M:PKP1]STOMGTCOD (LLIG)       = [F:ITF]STOMGTCOD    #gestion stock
                 [M:PKP1]PCKSTKFLG (LLIG)       = [F:ITF]PCKSTKFLG    #detail stock colisage
                 [M:PKP1]PCKSERFLG (LLIG)       = [F:ITF]PCKSERFLG                                 # hcb 110327-pck
                 [M:PKP1]SERMGTCOD (LLIG)       = [F:ITM]SERMGTCOD                                 # hcb 110327-pck
                 [M:PKP1]QTYINI    (LLIG)       = [F:PRE]QTYSTU                                    # hcb 110327-pck
                 [M:PKP1]PCK       (LLIG)       = [F:SPH]PCK
                 [M:PKP1]PCKWEI    (LLIG)       = [F:SPH]PCKWEI
                 [M:PKP1]SCCCOD    (LLIG)       = [F:SPH]SCCCOD
                 [M:PKP1]NETWEI    (LLIG)       = [F:SPD]NETWEI
                 [M:PKP1]GROWEI    (LLIG)       = [F:SPH]NETWEI + [F:SPH]PCKWEI
                 [M:PKP1]VOL       (LLIG)       = [F:SPH]VOL
                 [M:PKP1]WEU       (LLIG)       = [F:SPH]WEU
                 [M:PKP1]VOU       (LLIG)       = [F:SPH]VOU
                 [M:PKP1]LBLFMT    (LLIG)       = [F:SPH]LBLFMT
                 [M:PKP1]SPHTEX    (LLIG)       = [F:SPH]SPHTEX
                 [M:PKP1]PACNUM    (LLIG)       = [F:SPD]PACNUM
                 [M:PKP1]PACNUM_AV (LLIG)       = [F:SPD]PACNUM
                 [M:PKP1]WLLIG     (LLIG)       = LLIG * 10000
                 [M:PKP1]VCRLIN    (LLIG)       = [F:PRE]PRELIN
                 [M:PKP1]ITMREF    (LLIG)       = [F:PRE]ITMREF
                 #[M:PKP1]ITMDES1   (LLIG)       = [F:ITM]ITMDES1
                 Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKP1]ITMDES1(LLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
                 [M:PKP1]SAU       (LLIG)       = [F:PRE]PCU              # 55839
                 [M:PKP1]SAUSTUCOE (LLIG)       = [F:PRE]PCUSTUCOE        # 55839
                 [M:PKP1]UNTWEI    (LLIG)       = GWUNT
                 [M:PKP1]LIGUNTWEI (LLIG)       = GWUNTWEI
                 [M:PKP1]WEUSDD    (LLIG)       = [F:ITM]WEU
                 [M:PKP1]STU       (LLIG)       = [F:PRE]STU
                 [M:PKP1]WEUSDD    (LLIG)       = [F:ITM]WEU
                 [M:PKP1]LIGWEU    (LLIG)       = GWWEU
                 [M:PKP1]NETWEIPCK (LLIG)       = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)

                  # recherche no pacseq
                 If LLIG = 0
                    [M:PKP1]PACSEQ    (LLIG)    = 1
                    [M:PKP1]PACSEQH   (LLIG)    = 1
                 Else
# hcb 86233
                    I =sigma(0,[M:PKP1]NBLIG-1,(indcum+1)*([M:PKP1]PACNUM(indcum) = [M:PKP1]PACNUM (LLIG) &
&                                               I=0 & sigma(I=1,1,1)))

                    If I <> 0
                       I -= 1
                       [M:PKP1]PACSEQ (LLIG) = [M:PKP1]PACSEQ (I)
                       Raz [M:PKP1]GROWEI    (LLIG)
                       Raz [M:PKP1]LBLFMT    (LLIG)
                       Raz [M:PKP1]PACSEQH   (LLIG)
                    Else
                       [M:PKP1]PACSEQ    (LLIG)    = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
                       [M:PKP1]PACSEQH   (LLIG)    =  1
                    Endif
                 Endif
#                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE         # hcb X3-70246
                 [M:PKP1]QTYSTU    (LLIG)      += [F:SPD]QTYPCU                             # hcb X3-70246
                 Call QTEARR([M:PKP1]QTYSTU (LLIG),[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]PACQTYSTU (LLIG)       = [M:PKP1]QTYSTU (LLIG)

                 [M:PKP1]QTY       (LLIG)       = [M:PKP1]QTYSTU (LLIG) / [M:PKP1]SAUSTUCOE(LLIG)  # hcb 55839
                 Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV         # hcb 76850
                 [M:PKP1]QTYSAU    (LLIG)       = [M:PKP1]QTY    (LLIG)
                 [M:PKP1]QTYSAUSTU (LLIG)       = [M:PKP1]QTYSTU (LLIG)

#                 WQTYSAUSTU                    += [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE         # hcb X3-70246
                 WQTYSAUSTU                    += [F:SPD]QTYPCU                             # hcb X3-70246

                 Call QTEARR(WQTYSAUSTU,[M:PKP1]STU  (LLIG)) From TRTDIV         # hcb 76686
                 If [F:TPA]PCK     <> [F:SPH]PCK
                    Read [TPA]TPA0 =  [F:SPH]PCK
                    If fstat
                       Raz [F:TPA]
                    Endif
                 Endif
                 [M:PKP1]PCKLEN    (LLIG)       = [F:TPA]PCKLEN
                 [M:PKP1]PCKWID    (LLIG)       = [F:TPA]PCKWID
                 [M:PKP1]PCKHEI    (LLIG)       = [F:TPA]PCKHEI
                 [M:PKP1]DIU       (LLIG)       = [F:TPA]DIU
                 [M:PKP1]NBLIG += 1
                 WPACNUM = [F:SPD]PACNUM
                 WSCCCOD = [F:SPH]SCCCOD
              Endif
          Next
          Filter [SPD]
          If WQTYSAUSTU < [F:PRE]QTYSTU
             LLIG = [M:PKP1]NBLIG
             [M:PKP1]STOMGTCOD     (LLIG)          = [F:ITF]STOMGTCOD    #gestion stock
             [M:PKP1]PCKSTKFLG     (LLIG)          = [F:ITF]PCKSTKFLG    #detail stock colisage
             [M:PKP1]PCKSERFLG     (LLIG)          = [F:ITF]PCKSERFLG                              # hcb 110327-pck
             [M:PKP1]SERMGTCOD     (LLIG)          = [F:ITM]SERMGTCOD                              # hcb 110327-pck
             [M:PKP1]QTYINI        (LLIG)          = [F:PRE]QTYSTU                                 # hcb 110327-pck
             If [M:PKP1]PCKSERFLG  (LLIG) = 2 & [M:PKP1]SERMGTCOD  (LLIG) = 4 & [F:PRE]PACQTYSTU = 0 # hcb 110327-pck
                [M:PKP1]IDETAIL    (LLIG) = 4                                                      # hcb 110327-pck
             Endif                                                                                 # hcb 110327-pck
             [M:PKP1]WLLIG         (LLIG)          = LLIG * 10000
             Raz [M:PKP1]NETWEI    (LLIG)
             Raz [M:PKP1]GROWEI    (LLIG)
             Raz [M:PKP1]NETWEIPCK (LLIG)
             Raz [M:PKP1]VOL       (LLIG)
             [M:PKP1]VCRLIN        (LLIG)          = [F:PRE]PRELIN
             [M:PKP1]ITMREF        (LLIG)          = [F:PRE]ITMREF
             [M:PKP1]MODFLG        (LLIG)          = 0
             #[M:PKP1]ITMDES1       (LLIG)          = [F:ITM]ITMDES1
             Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PKP1]ITMDES1(LLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
             [M:PKP1]SAU           (LLIG)          = [F:PRE]PCU              # 55839
             [M:PKP1]SAUSTUCOE     (LLIG)          = [F:PRE]PCUSTUCOE        # 55839
             [M:PKP1]UNTWEI        (LLIG)          = GWUNT
             [M:PKP1]LIGUNTWEI     (LLIG)          = GWUNTWEI
             [M:PKP1]WEUSDD        (LLIG)          = [F:ITM]WEU
             [M:PKP1]WEU           (LLIG)          = [F:ITM]WEU
             [M:PKP1]STU           (LLIG)          = [F:PRE]STU
             [M:PKP1]PCK           (LLIG)          = [F:PRE]PCK
             [M:PKP1]PCKCAP        (LLIG)          = [F:PRE]PCKCAP    # hcb 55930
             [M:PKP1]QTYSAUSTU     (LLIG)          = [F:PRE]QTYSTU - WQTYSAUSTU
             [M:PKP1]QTYSAU        (LLIG)          = [M:PKP1]QTYSAUSTU   (LLIG)
             [M:PKP1]LIGWEU        (LLIG)          = GWWEU
             [M:PKP1]QTYSTU        (LLIG)          = [M:PKP1]QTYSAUSTU   (LLIG)
             [M:PKP1]QTY           (LLIG)          = [M:PKP1]QTYSAU      (LLIG) / [M:PKP1]SAUSTUCOE (LLIG)  # hcb 55839
             Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV         # hcb 76850

             [M:PKP1]NETWEI        (LLIG)          = [M:PKP1]QTYSTU      (LLIG) * [M:PKP1]UNTWEI   (LLIG)   # hcb 54897
             [M:PKP1]NETWEIPCK     (LLIG)          = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
             [M:PKP1]PACNUM        (LLIG)          = ""
             [M:PKP1]SCCCOD        (LLIG)          = ""

             If [F:PRE]PCK <> ""
                If [F:TPA]PCK     <> [F:PRE]PCK
                   Read [TPA]TPA0 =  [F:PRE]PCK
                   If fstat
                      Raz [F:TPA]
                   Endif
                Endif
# hcb 54897
             If GWWEU <> "" & [F:TPA]WEU <> ""
                If GWWEU <> [F:TPA]WEU
        # Conversion poids unitaire de unité poids liv en unité poids colis
                       Call SCONV_TCO(GWWEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
                    Endif
                 [M:PKP1]LIGUNTWEI (LLIG)       = GWUNTWEI
                 [M:PKP1]NETWEI        (LLIG)   = [M:PKP1]QTYSTU      (LLIG) * GWUNT
                 [M:PKP1]NETWEIPCK     (LLIG)   = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
             Endif
# hcb 54897

                [M:PKP1]PCKWEI   (LLIG)          = [F:TPA]PCKWEI
                [M:PKP1]VOL      (LLIG)          = [F:TPA]VOL
                [M:PKP1]WEU      (LLIG)          = [F:TPA]WEU
                [M:PKP1]VOU      (LLIG)          = [F:TPA]VOU
                [M:PKP1]PCKLEN   (LLIG)          = [F:TPA]PCKLEN
                [M:PKP1]PCKWID   (LLIG)          = [F:TPA]PCKWID
                [M:PKP1]PCKHEI   (LLIG)          = [F:TPA]PCKHEI
                [M:PKP1]DIU      (LLIG)          = [F:TPA]DIU
                [M:PKP1]LBLFMT   (LLIG)          = [F:TPA]LBLFMT
             Endif
             # calcul nombre de detail
             Gosub CAL_NBDETAIL
             [M:PKP1]NBLIG += 1
          Endif
       Else
          [M:PKP1]PCK           (LLIG)       = [F:PRE]PCK
          [M:PKP1]PCKCAP        (LLIG)       = [F:PRE]PCKCAP    # hcb 55930
#         [M:PKP1]QTYSAU        (LLIG)       = [F:PRE]QTYSTU                                           # hcb 122860
          [M:PKP1]QTYSAUSTU     (LLIG)       = [F:PRE]QTYSTU
          [M:PKP1]QTYSTU        (LLIG)       = [M:PKP1]QTYSAUSTU   (LLIG)
          [M:PKP1]QTYSAU        (LLIG)       = [M:PKP1]QTYSAUSTU   (LLIG)/ [M:PKP1]SAUSTUCOE (LLIG)    # hcb 122860
          Call QTEARR([M:PKP1]QTYSAU (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV                           # hcb 122860
          [M:PKP1]QTY           (LLIG)       = [M:PKP1]QTYSAU      (LLIG)                              # hcb 122860
#          [M:PKP1]QTY           (LLIG)       = [M:PKP1]QTYSAU      (LLIG) / [M:PKP1]SAUSTUCOE (LLIG)  # hcb 122860
#          Call QTEARR([M:PKP1]QTY (LLIG),[M:PKP1]SAU  (LLIG)) From TRTDIV                             # hcb 122860

          [M:PKP1]NETWEI        (LLIG)       = [M:PKP1]QTYSTU      (LLIG) * [M:PKP1]UNTWEI   (LLIG)   # hcb 54987
          [M:PKP1]NETWEIPCK     (LLIG)       = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
          [M:PKP1]LIGWEU        (LLIG)       = GWWEU
          [M:PKP1]GROWEI        (LLIG)       = 0
          [M:PKP1]PACNUM        (LLIG)       = ""
          [M:PKP1]SCCCOD        (LLIG)       = ""

          If [F:PRE]PCK <> ""
             If [F:TPA]PCK     <> [F:PRE]PCK
                Read [TPA]TPA0 =  [F:PRE]PCK
                If fstat
                   Raz [F:TPA]
                Endif
             Endif
# hcb 64897
             If GWWEU <> "" & [F:TPA]WEU <> ""
                If GWWEU <> [F:TPA]WEU
        # Conversion poids unitaire de unité poids liv en unité poids colis
                       Call SCONV_TCO(GWWEU,[F:TPA]WEU,GWUNTWEI) From TRTVENQTE
                    Endif
                 [M:PKP1]LIGUNTWEI (LLIG)       = GWUNTWEI
                 [M:PKP1]NETWEI        (LLIG)   = [M:PKP1]QTYSTU      (LLIG) * GWUNT
                 [M:PKP1]NETWEIPCK     (LLIG)   = [M:PKP1]NETWEI      (LLIG) * [M:PKP1]LIGUNTWEI(LLIG)
             Endif
# hcb 64897

             [M:PKP1]PCKWEI     (LLIG)       = [F:TPA]PCKWEI
             [M:PKP1]VOL        (LLIG)       = [F:TPA]VOL
             [M:PKP1]WEU        (LLIG)       = [F:TPA]WEU
             [M:PKP1]VOU        (LLIG)       = [F:TPA]VOU
             [M:PKP1]PCKLEN     (LLIG)       = [F:TPA]PCKLEN
             [M:PKP1]PCKWID     (LLIG)       = [F:TPA]PCKWID
             [M:PKP1]PCKHEI     (LLIG)       = [F:TPA]PCKHEI
             [M:PKP1]DIU        (LLIG)       = [F:TPA]DIU
             If [F:TPA]LBLFMT <> ""                                         # hcb 55930
                [M:PKP1]LBLFMT     (LLIG)       = [F:TPA]LBLFMT             # hcb 55930
             Endif                                                          # hcb 55930
          Endif
          # calcul nombre de detail
          Gosub CAL_NBDETAIL
          # Colisage automatique si :                                                                # hcb 55930
          #      Emballage  et capacité sont renseignés                                              # hcb 55930
          #      Nombre de détail = 1                                                                # hcb 55930
          [M:PKP1]QTYINI(LLIG)    =    [M:PKP1]QTY   (LLIG)                               # hcb 110327-pck
           WPACQTYSTU             =    [F:PRE]PACQTYSTU                                   # hcb 110327-pck

          If [M:PKP1]PCK(LLIG) <> "" & [M:PKP1]PCKCAP(LLIG) <> 0                                     # hcb 55930 2
             Gosub COLIS_AUTO                                               # hcb 55930
          Else                                                              # hcb 55930
             If [M:PKP1]PCKSERFLG (LLIG) = 2 & [M:PKP1]SERMGTCOD (LLIG) = 4 & [F:PRE]PACQTYSTU = 0 # hcb 110327-pck
                [M:PKP1]IDETAIL   (LLIG) = 4                                                       # hcb 110327-pck
             Endif                                                                                 # hcb 110327-pck
             [M:PKP1]NBLIG += 1
          Endif                                                             # hcb 55930
       Endif
   Next
   Filter [PRE]
Endif

If [M:PKP1]PREUSR = ""
   If dim([M:PKS1]PREUSR) > 0
      [M:PKP1]PREUSR = [M:PKS1]PREUSR
   Endif
Endif

Call GLOBVAR([M:PKP1]STOFCY) From WWGLOBSTO

If GSSCCROOT <> ""
   If GSSCCCOU = ""
      [M:PKP1]SSCCGES = mess(271,184,1)     # Code SSCC partielle
   Else
      [M:PKP1]SSCCGES = mess(274,184,1)     # Code SSCC automatique
   Endif
Endif
If GORI_PKP  =  "PKP1"
   Raz GPE                                       # hcb 76725
   GPOINT="AFF_PKP1" : Gosub ENTREE From EXEFNC  # hcb 76725
   If GPE = 0                                    # hcb 76725
      Affzo [M:PKP1]
      Actzo [M:PKP1]
# la saisie du transporteur et preparateur ne sont effectif que si une ligne est modifiée
      Diszo [M:PKP1]BPTNUM
      Diszo [M:PKP1]PREUSR
#     Raz GMODPAC                # hcb 55930
   Endif                                         # hcb 76725

Endif
If GCONSULT = 2
   Grizo [M:PKP1]
Endif
Diszo [M:PKP1]VCRNUM # diszo pour conserver les menus contextuels

Return

#                                                                # hcb 55930 deb
###################################################################
# Colisage automatique si emballage et capacité sont renseignés
###################################################################
$COLIS_AUTO
Local Integer WNBCOL        # nombre de colis
Local Decimal WQTYCOL       # quantité à coliser
Local Integer LIG_PKP1      # ligne à traiter
Local Integer I
Local Integer J
Local Integer WPACSEQDEB    # dernier pacseq
# si plusieurs detail et nombre de colis = 0 on sort

If [M:PKP1]NBDETAIL     (LLIG) > 1 & [M:PKP1]NBCOL     (LLIG) = 0     # hcb 55930 2
   If [M:PKP1]PCKSERFLG (LLIG) = 2 & [M:PKP1]SERMGTCOD (LLIG) = 4  &  WPACQTYSTU = 0               # hcb 110327-pck
      [M:PKP1]IDETAIL   (LLIG) = 4                                                                 # hcb 110327-pck
   Endif                                                                                           # hcb 110327-pck
   [M:PKP1]NBLIG += 1
   Return
Endif

LIG_PKP1 =   LLIG
WQTYCOL  =   [M:PKP1]QTY(LLIG)

If [M:PKP1]NBDETAIL     (LLIG) > 1                                   # hcb 55930 2
    WNBCOL = [M:PKP1]NBCOL     (LLIG)
Else
   WNBCOL   = int([M:PKP1]QTY(LLIG)/[M:PKP1]PCKCAP(LLIG))
   If mod([M:PKP1]QTY(LLIG),[M:PKP1]PCKCAP(LLIG)) <> 0
      WNBCOL += 1
   Endif
Endif

If WNBCOL=0
   [M:PKP1]NBLIG += 1
   Return
Endif

If [M:PKP1]NBLIG <> 0
   WPACSEQDEB = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
Else
   WPACSEQDEB = 1
Endif

# Contrôle que l'on peut insérer les lignes dans le tableau
If [M:PKP1]NBLIG + WNBCOL > dim([M:PKP1]ITMREF)-1
   GMESSAGE=mess(278,184,1)    # Tableau plein ! (code activite SPK)
   [M:PKP1]NBLIG += 1
   Return
Endif
GMODPAC = 1 # pour bouton enregistrer
[M:PKP1]NBLIG += WNBCOL
# Alimentation des nouvelles lignes
Raz J
For I = LIG_PKP1 To LIG_PKP1+WNBCOL
    [M:PKP1]ITMREF     (I)  = [M:PKP1]ITMREF      (LIG_PKP1)
    [M:PKP1]ITMDES1    (I)  = [M:PKP1]ITMDES1     (LIG_PKP1)
    [M:PKP1]PCKCAP     (I)  = [M:PKP1]PCKCAP      (LIG_PKP1)
    [M:PKP1]QTYSAU     (I)  = [M:PKP1]PCKCAP      (I)
    [M:PKP1]SAU        (I)  = [M:PKP1]SAU         (LIG_PKP1)
    [M:PKP1]SAUSTUCOE  (I)  = [M:PKP1]SAUSTUCOE   (LIG_PKP1)
    [M:PKP1]QTYSAUSTU  (I)  = [M:PKP1]QTYSAU(I)*[M:PKP1]SAUSTUCOE (I)
    Call QTEARR([M:PKP1]QTYSAUSTU(I),[M:PKP1]STU  (LIG_PKP1)) From TRTDIV
    [M:PKP1]STU        (I)  = [M:PKP1]STU         (LIG_PKP1)
    [M:PKP1]QTY        (I)  = [M:PKP1]QTYSAU      (I)
    [M:PKP1]QTYSTU     (I)  = [M:PKP1]QTYSAUSTU   (I)
    [M:PKP1]PCK        (I)  = [M:PKP1]PCK         (LIG_PKP1)
    [M:PKP1]PACSEQ     (I)  = WPACSEQDEB + J
    [M:PKP1]PACSEQH    (I)  = 1
    [M:PKP1]PCKWEI     (I)  = [M:PKP1]PCKWEI      (LIG_PKP1)
    [M:PKP1]LIGUNTWEI  (I)  = [M:PKP1]LIGUNTWEI   (LIG_PKP1)
    [M:PKP1]STOMGTCOD  (I)  = [M:PKP1]STOMGTCOD   (LIG_PKP1)
    [M:PKP1]PCKSTKFLG  (I)  = [M:PKP1]PCKSTKFLG   (LIG_PKP1)
    [M:PKP1]PCKSERFLG  (I)  = [M:PKP1]PCKSERFLG   (LIG_PKP1)                                       # hcb 110327-pck
    [M:PKP1]SERMGTCOD  (I)  = [M:PKP1]SERMGTCOD   (LIG_PKP1)                                       # hcb 110327-pck
    [M:PKP1]QTYINI     (I)  = [M:PKP1]QTYINI      (LIG_PKP1)                                       # hcb 110327-pck
    [M:PKP1]NBDETAIL   (I)  = [M:PKP1]NBDETAIL    (LIG_PKP1)
    [M:PKP1]NBCOL      (I)  = [M:PKP1]NBCOL       (LIG_PKP1)         # hcb 55930 2
    [M:PKP1]NETWEI     (I)  = [M:PKP1]QTYSTU      (I) * GWUNT
    [M:PKP1]NETWEIPCK  (I)  = [M:PKP1]NETWEI      (I) * [M:PKP1]LIGUNTWEI(I)
    [M:PKP1]LIGWEU     (I)  = [M:PKP1]LIGWEU      (LIG_PKP1)
    [M:PKP1]WEU        (I)  = [M:PKP1]WEU         (LIG_PKP1)
    [M:PKP1]PCKLEN     (I)  = [M:PKP1]PCKLEN      (LIG_PKP1)
    [M:PKP1]PCKWID     (I)  = [M:PKP1]PCKWID      (LIG_PKP1)
    [M:PKP1]PCKHEI     (I)  = [M:PKP1]PCKHEI      (LIG_PKP1)
    [M:PKP1]DIU        (I)  = [M:PKP1]DIU         (LIG_PKP1)
    [M:PKP1]VOL        (I)  = [M:PKP1]VOL         (LIG_PKP1)
    [M:PKP1]VOU        (I)  = [M:PKP1]VOU         (LIG_PKP1)
    [M:PKP1]LBLFMT     (I)  = [M:PKP1]LBLFMT      (LIG_PKP1)
    [M:PKP1]VCRLIN     (I)  = [M:PKP1]VCRLIN      (LIG_PKP1)
    [M:PKP1]SPHTEX     (I)  = [M:PKP1]SPHTEX      (LIG_PKP1)
    [M:PKP1]MODFLG     (I)  = 2
    [M:PKP1]PACFLG     (I)  = [M:PKP1]PACFLG      (LIG_PKP1)
    [M:PKP1]VCRLIN     (I)  = [M:PKP1]VCRLIN      (LIG_PKP1)
    [M:PKP1]PACQTYSTU  (I)  = [M:PKP1]PACQTYSTU   (LIG_PKP1)
    [M:PKP1]UNTWEI     (I)  = [M:PKP1]UNTWEI      (LIG_PKP1)
    [M:PKP1]WEUSDD     (I)  = [M:PKP1]WEUSDD      (LIG_PKP1)
    [M:PKP1]WLLIG      (I)  = [M:PKP1]WLLIG       (LIG_PKP1) + 1
    [M:PKP1]PACNUM_AV  (I)  = [M:PKP1]PACNUM_AV   (LIG_PKP1)
    [M:PKP1]GROWEI     (I)  = [M:PKP1]NETWEIPCK   (I) + [M:PKP1]PCKWEI(I)
# hcb test
    If [M:PKP1]STOMGTCOD  (I)  <  2 |
&      [M:PKP1]PCKSTKFLG  (I)  <> 2 |
&      [M:PKP1]IDETAIL    (I)  = 1
    Else
       If [M:PKP1]PCKSERFLG (I) = 2 & [M:PKP1]SERMGTCOD  (I) = 4  &  WPACQTYSTU = 0                # hcb 110327-pck
          [M:PKP1]IDETAIL   (I) = 3                                                                # hcb 110327-pck
       Else                                                                                        # hcb 110327-pck
          [M:PKP1]IDETAIL   (I) = 2
       Endif                                                                                       # hcb 110327-pck
    Endif
    J += 1
   # Quantité du dernier colis
    If J = WNBCOL
       [M:PKP1]QTYSAU     (I) = WQTYCOL - [M:PKP1]PCKCAP(LIG_PKP1)*(WNBCOL-1)
       Call QTEARR([M:PKP1]QTYSAU(I),[M:PKP1]SAU         (LIG_PKP1) ) From TRTDIV    # hcb 99460
       [M:PKP1]QTY        (I) = [M:PKP1]QTYSAU      (I)
       [M:PKP1]QTYSAUSTU  (I) = [M:PKP1]QTYSAU(I)*[M:PKP1]SAUSTUCOE (I)
       Call QTEARR([M:PKP1]QTYSAUSTU(I),[M:PKP1]STU (LIG_PKP1)) From TRTDIV
       [M:PKP1]QTYSTU     (I)  = [M:PKP1]QTYSAUSTU  (I)
       [M:PKP1]NETWEI     (I)  = [M:PKP1]QTYSTU     (I) * GWUNT
       [M:PKP1]NETWEIPCK  (I)  = [M:PKP1]NETWEI     (I) * [M:PKP1]LIGUNTWEI(I)
       [M:PKP1]GROWEI     (I)  = [M:PKP1]NETWEIPCK  (I) + [M:PKP1]PCKWEI   (I)
       Break
     Endif
Next I


Return
#                                                               # hcb 55930 fin

# Verrouillage de la livraison / preparation
$VERROU

# on ne verrouille pas si action <> de la fonction de colisage , cela se fait par la fonction appelant
If GACTION <>  "TRTPKP"
   Return
Endif

If GVCRTYP = 4
   SYMBOLE = "SDH"+[F:SDH]SDHNUM

   Lock = SYMBOLE With lockwait = 0
   If fstat = 1

      Call ECR_TRACE([F:SDH]SDHNUM-mess(10,100,1),1) From GESECRAN
      VOK = 1
   Elsif fstat
      Call ECR_TRACE(mess(150,199,1)-"$SDELIVERY",1) From GESECRAN
      VOK = 0
   Endif
Else
   SYMBOLE = "PRH"+[F:PRH]PRHNUM
   Lock = SYMBOLE With lockwait = 0
   If fstat = 1
      Call ECR_TRACE([F:PRH]PRHNUM-mess(10,100,1),1) From GESECRAN
      VOK = 1
   Elsif fstat
      Call ECR_TRACE(mess(150,199,1)-"$STOPREH",1) From GESECRAN
      VOK = 0
   Endif
Endif

Return

# Déverrouillage de la livraison / preparation
$DEVERROU
# on ne verrouille pas si action <> de la fonction de colisage , cela se fait par la fonction appelant
If GACTION <>  "TRTPKP"
   Return
Endif


Unlock = SYMBOLE
Return

#########################################################################
$AP_CHOIX_TRTPKP

Raz FINCOL

Return

#########################################################################
$AVANT_ENR_TRTPKP


Return

#########################################################################

#########################################################################
$ENR_TRTPKP
Local Integer WI
#                               #  hcb  55930 2 deb
Raz WI
Local Integer WY
# 101090 - Verify changes if BOL attached to shipment
Local Integer OK : OK = 2
Call VERIF_BOLMOD(OK) From SUBSDHB
If OK<>2 : GOK=0 : Return : Endif

For WY = 0 To [M:PKP1]NBLIG-1
#   If [M:PKP1]IDETAIL(WY) =  2                                                                    # hcb 110327-pck
    If find([M:PKP1]IDETAIL(WY),2,3)                                                               # hcb 110327-pck

       If  [M:PKP1]PCK(WY) <> "" & [M:PKP1]PCKCAP(WY) <> 0
           If  [M:PKP1]NBDETAIL  (WY) = 1
               Goto NEXTWI
           Else
               If  [M:PKP1]NBCOL  (WY) =  0
                   WI = 1
                   Break
               Else
                  Goto NEXTWI
               Endif
           Endif
       Endif
    Endif
$NEXTWI
Next
#WI = find(2,[M:PKP1]IDETAIL(0..[M:PKP1]NBLIG-1))
#                               # hcb 55930 2 fin
If WI > 0
# des détails stock ne sont pas renseignés !
   Call MESSAGE (mess(289,184,1)) From GESECRAN
   Return
Endif
Gosub ENR_COLISAGE
Gosub DEVERROU
Raz GMODPAC
If GOK = 1                                   # hcb 110889
   If LPACFLG = 2
   # si entierement colise on imprime
   #--- Impression des étiquettes ----#
      If GDOCFLG = 2  & !GIMPORT & !GWEBSERV
         Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
         WPARAM(1) = num$([M:PKP1]VCRTYP)
         WPARAM(2) = [M:PKP1]VCRNUM
         GSVG_GACTION = GACTION
         GACTION = "SAIPKE"
         Call TRAITE_CHAR(WVALEUR,WPARAM,"FPKE","FUNPKE","",4,"SPEPKE") From GTRAITE
         GACTION = GSVG_GACTION
      Endif
   Endif
Endif                                        # hcb 110889
Gosub CHARGE_PKP1

Return
#########################################################################
$ABA_TRTPKP
#########################################################################

Gosub CHARGE_PKP1

Return

#####################################################
# Enregistrement du colisage                        #
#####################################################
$ENR_COLISAGE
If clalev([M:PKP2])=0  Local Mask PKP2 [PKP2]  Endif  #  ecran stockage mvt détail colisage
Global Integer   GLIG_PKP1
Global Char      GORI_PKP  : GORI_PKP  =  "PKP1"      #  sert à charger l ecran PKP2
Local Integer    LIG_PKP1, LRET, WSTAT, WPACSEQ
Local Char       WPACNUM
Local Char       WSCCCOD
Local Char       WLBLFMT
Local Char       WSPHTEX(20)
Raz WLBLFMT
Raz WSPHTEX
Raz LIG_PKP1
Raz WPACSEQ
Raz [M:PKP2]

Raz GPE                                           # hcb 76725
GPOINT="ENR_COLISAGE" : Gosub ENTREE From EXEFNC  # hcb 76725
If GPE = 0                                        # hcb 76725

   Sorta [M:PKP1]NBLIG [M:PKP1]NBLIG Order By [M:PKP1]PACSEQ(indice) , [M:PKP1]VCRLIN(indice)
   Call DEBTRANS From GLOCK
   GOK = 1
   Trbegin [SPH]
   For LIG_PKP1 = 0 To [M:PKP1]NBLIG-1
       If [M:PKP1]MODFLG (LIG_PKP1) =  2 & [M:PKP1]PACSEQ(LIG_PKP1) <> 0
          GLIG_PKP1 = LIG_PKP1
          Gosub CHARGE_PKP2 From TRTPKP2
          If GOK <> 1
             Break
          Endif
          Gosub ECRCOL_PKP2 From FUNPKP
          If GOK <> 1
             Break
          Endif
          Raz [M:PKP1]MODFLG (LIG_PKP1)
       Endif
   Next
   If WPACSEQ <> 0 & GOK = 1                          # hcb 110327-pck  bug
      Call ENTETE_COLIS([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,[F:SPD]PACNUM,WPACSEQ,WLBLFMT,WSPHTEX,WSCCCOD,LRET)From FUNPKP
      If GOK = 0 | LRET <> 0
         GOK = 0
      Endif
   Endif

   If GOK = 1
      Gosub MAJDOC_ORIGINE From FUNPKP
   Endif

   If GOK <> 1
      Gosub ABORT
   Else
      Commit
   Endif

# tri par ordre de remplissage
   Sorta [M:PKP1]NBLIG [M:PKP1]NBLIG Order By [M:PKP1]WLLIG(indice)
   Affzo[M:PKP1]20
Endif                                             # hcb 76725

Return

########################################################
# Ecriture des details d une ligne de PKP1 depuis PKP2 #
########################################################
$ECRCOL_PKP2
Local Integer WLIN
Local Integer WVCRLIN
Local Date    LDAT      # date
LDAT = date$
Raz WVCRLIN
Raz WLIN

Local Integer CALLNUMPAC    # 76101

#----------------------------------------------------------------------------#
#   Point d'entree à la mise à jour d'un détail colis         Pe  PACKDETMAJ #
#----------------------------------------------------------------------------#
WPOINT_CODTRT="A"
GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
If GOK <> 1
   Return
Endif

# dans le cas d une modification d un colisage existant on vire le colis
#         le SPH sera reecri en lisant tous les SPD correspondant
If [M:PKP1]PACNUM_AV(GLIG_PKP1) <> ""
   Delete [SPH] Where VCRTYP = GVCRTYP & VCRNUM = [M:PKP1]VCRNUM & PACNUM = [M:PKP1]PACNUM_AV(GLIG_PKP1)

   Delete [SPD] Where VCRTYP = GVCRTYP & VCRNUM = [M:PKP1]VCRNUM & VCRLIN = [M:PKP1]VCRLIN(GLIG_PKP1) &
&                     PACNUM = [M:PKP1]PACNUM_AV(GLIG_PKP1)
Endif

If WPACSEQ <> [M:PKP1]PACSEQ(GLIG_PKP1)
   If WPACSEQ <> 0
      Call ENTETE_COLIS([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,WPACNUM,WPACSEQ,WLBLFMT,WSPHTEX,WSCCCOD,LRET)  From FUNPKP
      If GOK = 0 | LRET <> 0
         GOK = 0
         Return
      Endif
   Endif

   WPACNUM =  [M:PKP2]PACNUM
   WSCCCOD =  [M:PKP2]SCCCOD
   WPACSEQ =  [M:PKP2]PACSEQ
   WLBLFMT =  [M:PKP2]LBLFMT
   WSPHTEX =  [M:PKP2]SPHTEX
   Raz CALLNUMPAC    # 76101
   If [M:PKP1]PACNUM(GLIG_PKP1) = ""
       CALLNUMPAC = 1 # 76101

      Call NUM_PAC([M:PKP1]STOFCY,LDAT,WPACNUM) From FUNPKD
      If WPACNUM = ""
         Call ERREUR(mess(272,184,1)) From GESECRAN
         GOK = 0
         Return
      Endif
      Call NUMERO_SSCC([M:PKP1]STOFCY,[M:PKP1]ITMREF(GLIG_PKP1),WSCCCOD,LRET) From FUNPKD
      If LRET <> 0
         GOK = 0
         Return
      Endif
   Endif
Else
   If [M:PKP1]PACNUM(GLIG_PKP1) = ""
      WPACNUM =  [M:PKP1]PACNUM(GLIG_PKP1 -1)
      WSCCCOD =  [M:PKP1]SCCCOD(GLIG_PKP1 -1)
   Endif
Endif

#----------------------------------------------------------------------------#
# Ecriture du detail du colis                               ecriture SPACKD  #
#----------------------------------------------------------------------------#
Raz GNBRLIG
For nolign=1 To [M:PKP2]NBLIG
   # La ligne n'est pas colisée
    If [M:PKP2]QTY(nolign-1) = 0
       Goto NEXT_NOLIGN
    Endif
    GNBRLIG += 1
    If WVCRLIN <> [M:PKP1]VCRLIN(GLIG_PKP1)               # hcb 63350 2
       WVCRLIN =  [M:PKP1]VCRLIN(GLIG_PKP1)               # hcb 63350 2
       If CALLNUMPAC = 0  # 76101
          Raz WLIN
#recherche dernier rang
          Filter [SPD] Where  VCRTYP     = [M:PKP1]VCRTYP            &
&                             VCRNUM     = [M:PKP1]VCRNUM            &
&                             VCRLIN     = [M:PKP1]VCRLIN(GLIG_PKP1) &
&                             PACNUM     = WPACNUM
&                             Order By Key SPD0 Desc
          Read [SPD] First
          If fstat
             Raz [F:SPD]
          Endif
          WLIN = [F:SPD]PACIND
          Filter [SPD]
       Endif                                # 76101
    Endif
    WLIN += 1
   # Ecriture du détail colis
    [F:SPD]           = [M:PKP2]
#                                                                                                  # hcb 110327-pck deb
    If [M:PKP2]SERMGTCOD = 4
       [F:SPD]SERDEB    = [M:PKP2]SERNUM   (nolign-1)          # Serie du colis
       [F:SPD]SERFIN    = [M:PKP2]SERFIN   (nolign-1)          # Serie du colis
       [F:SPD]SERORIDEB = [M:PKP2]SERORIDEB(nolign-1)          # Serie origine du document
       [F:SPD]SERORIFIN = [M:PKP2]SERORIFIN(nolign-1)          # Serie origine du document
       Raz [F:SPD]SERNUM
    Endif
#                                                                                                  # hcb 110327-pck fin

#    [F:SPD]PCU        = [M:PKP2]STU       (nolign-1)   # hcb 99460
    [F:SPD]PCU        = [M:PKP2]PCU        (nolign-1)   # hcb X3-108941
    [F:SPD]QTYPCU     = [M:PKP2]QTYSTU       (nolign-1)   # hcb x3-70246
    Call QTEARR([F:SPD]QTYPCU,[F:SPD]PCU ) From TRTDIV # hcb 99460
    [F:SPD]SAU        = [M:PKP1]SAU       (GLIG_PKP1)  # hcb 55839
    [F:SPD]QTY        = [M:PKP2]QTY       (nolign-1)   # hcb 99460
    Call QTEARR([F:SPD]QTY ,[F:SPD]SAU) From TRTDIV    # hcb 99460
    [F:SPD]WEU        = [M:PKP1]LIGWEU    (GLIG_PKP1)
    [F:SPD]VCRTYP     = [M:PKP1]VCRTYP
    [F:SPD]VCRNUM     = [M:PKP1]VCRNUM
    [F:SPD]VCRLIN     = [M:PKP1]VCRLIN    (GLIG_PKP1)
    [F:SPD]PCKSTKFLG  = [M:PKP1]PCKSTKFLG (GLIG_PKP1)
    [F:SPD]ITMWEI     = [M:PKP1]UNTWEI    (GLIG_PKP1)
#   [F:SPD]PCUSTUCOE  = [M:PKP1]SAUSTUCOE (GLIG_PKP1) # hcb 122860
    [F:SPD]PACNUM     = WPACNUM
    [F:SPD]PACIND     = WLIN
    [F:SPD]CPY        = GSOCIETE
    [F:SPD]STOFCY     = [M:PKP1]STOFCY
    [F:SPD]CREDAT     = date$
    [F:SPD]CREUSR     = GUSER
    [F:SPD]EXPNUM     = [C]EXPORT
    [F:SPD]PACSEQ     = 1
    If [F:SPD]WSTOCOU = 0
       [F:SPD]WSTOCOU = 1
    Endif

#----------------------------------------------------------------------------#
#   Point d'entree à la mise à jour d'un détail colis         Pe  PACKDETMAJ #
#----------------------------------------------------------------------------#
    WPOINT_CODTRT="C"
    GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
    If GOK <> 1
       Break
    Endif

    Write [SPD]
    If fstat
       Call FSTA("SPD") From GLOCK
       GOK=0
       Break
    Endif

$NEXT_NOLIGN
Next nolign

If GOK  <> 1
   Return
Endif


If WPACSEQ = 0
   Return
Endif

# afficher le numero de colis
If GORI_PKP  =  "PKP1"
   [M:PKP1]PACNUM(GLIG_PKP1) = WPACNUM
   [M:PKP1]SCCCOD(GLIG_PKP1) = WSCCCOD
Endif

Return

#######################################################
# calcul cumuls et maj entête livraison  / preparation#
#######################################################
#  calcul cumuls et  maj entête livraison               reecriture SDELIVERY #
$MAJDOC_ORIGINE
Local Integer  LPACFLG   # flag colisage  2 = complet
Local Integer  LPACNBR   # nombre de colis
Local Decimal  LNETWEI   # Poids net du document
Local Decimal  LGROWEI   # Poids brut du document
Local Char     LWEU      # Unité de poids du document
Local Decimal  LVOL      # Volume du document
Local Char     LVOU      # Unité de volume du document
Local Integer  WOK
Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
Call COLISAGE_ORIGINE([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
If GOK = 0 | LRET <> 0
   Return
Endif
If GVCRTYP = 4
# Réécriture de la livraison
   Readlock [SDH]SDH0=GWCLECUR
   If fstat
      GOK = 0
      Call RSTA("SDH",GWCLECUR) From GLOCK
      Return
   Endif

   Local Integer IJL
   IJL=sum(([F:SDH]GROWEI <> LGROWEI),
&          ([F:SDH]VOL    <> LVOL),
&          ([F:SDH]BPTNUM <> [M:PKP1]BPTNUM))

   [F:SDH]PACFLG = LPACFLG
   [F:SDH]PACNBR = LPACNBR
   [F:SDH]BPTNUM = [M:PKP1]BPTNUM

   [F:SDH]NETWEI = LNETWEI
   [F:SDH]GROWEI = LGROWEI
   [F:SDH]VOL    = LVOL
   If [F:SDH]VOU = ""
      [F:SDH]VOU = LVOU
   Endif
# si livraison non validée on calcul le tarif transporteur
   If [F:SDH]CFMFLG <> 2 & IJL
       Gosub RECH_TARIF_TRSP From TRTVENLIV
   Endif
# si livraison validée on calcul le tarif transporteur à la demande
   If [F:SDH]CFMFLG = 2 & IJL
      Call OUINON(mess(279,184,1),WOK) From GESECRAN
      If WOK = 2
         Gosub RECH_TARIF_TRSP From TRTVENLIV
      Endif
   Endif

   Rewrite [SDH]

#  calcul cumuls et  maj entête preparation             reecriture STOPREH  #

Else
# Réécriture de la preparation
   Readlock [PRH1]PRH0=GWCLECUR                               # hcb 110327-pck bug
   If fstat
      GOK = 0
      Call RSTA("PRH",GWCLECUR) From GLOCK
      Return
   Endif
   [F:PRH1]PACFLG = LPACFLG                                   # hcb 110327-pck bug
   [F:PRH1]PACNBR = LPACNBR                                   # hcb 110327-pck bug
   [F:PRH1]BPTNUM = [M:PKP1]BPTNUM                            # hcb 110327-pck bug

   [F:PRH1]NETWEI = LNETWEI                                   # hcb 110327-pck bug
   [F:PRH1]GROWEI = LGROWEI                                   # hcb 110327-pck bug
   [F:PRH1]WEU    = LWEU                                      # hcb 110327-pck bug

   Rewrite [PRH1]

Endif

Return

# Rollback suite à erreur
$ABORT
Rollback

Return

#########################################################################
$SUP_TRTPKP

Local Integer WOK
# confirmation de la suppression du colisage dans le cas ou l utilisateur n est pas parametre en confimation suppression
If GCONF (1) <> 2
   Call OUINON(mess(275,184,1),WOK) From GESECRAN
   If WOK <> 2
      Return
   Endif
Endif

# 101090 - Verify changes if BOL attached to shipment
Local Integer OK : OK = 2
Call VERIF_BOLMOD(OK) From SUBSDHB
If OK<>2 : GOK=0 : Return : Endif

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]
Local Integer LLIG
Local Integer LANU_SDD
LLIG     = 0
LANU_SDD = 0
Gosub ANU_COLISAGE
If GOK <> 1
   Gosub ABORT
Else
   Commit
Endif
Gosub DEVERROU
Gosub CHARGE_PKP1
Return


#####################################################
# Annulation du colisage                            #
#####################################################
$ANU_COLISAGE
Local Integer  LRET
Local Integer  LPACFLG        # flag colisage  2 = complet
Local Integer  LPACNBR        # nombre de colis
Local Decimal  LNETWEI        # Poids net du document
Local Decimal  LGROWEI        # Poids brut du document
Local Char     LWEU           # Unité de poids du document
Local Decimal  LVOL           # Volume du document
Local Char     LVOU           # Unité de volume du document
Local Char     WFILSPH(150)   # filtre dans le cas de suppression d un colis ou de tout les colis
Local Char     WFILSPD(150)   # filtre dans le cas de suppression d un colis ou de tout les colis
WFILSPH = "1=1"
WFILSPD = "1=1"
Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
Raz LRET
# LANU_SDD = 0  annulation colisage du document
# LANU_SDD = 2  annulation colisage d une ligne de document
# LANU_SDD = 3  annulation d un colis
If LANU_SDD = 2
# Suppression du colisage du regroupement
   Raz LRET
   Delete [SPD] Where VCRTYP = GVCRTYP & VCRNUM = [M:PKP1]VCRNUM & VCRLIN = [M:PKP1]VCRLIN(LLIG) &
&                     PACNUM = [M:PKP1]PACNUM(LLIG) & PACSEQ = 1

   Call ENTETE_COLIS([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,[M:PKP1]PACNUM(LLIG),[M:PKP1]PACSEQ(LLIG),[M:PKP1]LBLFMT(LLIG),[M:PKP1]SPHTEX(LLIG),[M:PKP1]SCCCOD(LLIG),LRET)  From FUNPKP
   If GOK = 0 | LRET <> 0
      GOK = 0
      Return
   Endif

Else
   If LANU_SDD = 3
      WFILSPH = "[F:SPH]VCRTYP = GVCRTYP  & [F:SPH]VCRNUM = [M:PKP1]VCRNUM  & [F:SPH]PACNUM = [M:PKP1]PACNUM(nolign-1)"
      WFILSPD = "[F:SPD]VCRTYP = GVCRTYP  & [F:SPD]VCRNUM = [M:PKP1]VCRNUM  & [F:SPD]PACNUM = [M:PKP1]PACNUM(nolign-1)"
   Else
      WFILSPH = "[F:SPH]VCRTYP = GVCRTYP  & [F:SPH]VCRNUM = [M:PKP1]VCRNUM"
      WFILSPD = "[F:SPD]VCRTYP = GVCRTYP  & [F:SPD]VCRNUM = [M:PKP1]VCRNUM"
   Endif
   Filter [SPH] Where evalue(WFILSPH)
&               Order By Key SPH0
   For [SPH]
       If [F:SPH]SPHTEX <> ""
          If left$([F:SPH]SPHTEX,3)="SPH"
             Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
          Endif
       Endif
   Next
   Filter [SPH]
   Raz LRET
# Suppression de tous les colis d un document
   Delete [SPH] Where evalue(WFILSPH)
   Delete [SPD] Where evalue(WFILSPD)
Endif
Call COLISAGE_ORIGINE([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,0,LRET) From FUNPKD
If GOK = 0 | LRET <> 0
   GOK = 0
   Return
Endif

If GVCRTYP = 4
# Réécriture de la livraison
   Readlock [SDH1]SDH0=[M:PKP1]VCRNUM
   If fstat
      GOK = 0
      Call RSTA("SDH1",[M:PKP1]VCRNUM) From GLOCK
      Return
   Endif
   Local Integer IJL
   IJL=sum(([F:SDH1]GROWEI <> LGROWEI),
&          ([F:SDH1]VOL    <> LVOL),
&          ([F:SDH1]BPTNUM <> [M:PKP1]BPTNUM))

   [F:SDH1]PACFLG = LPACFLG
   [F:SDH1]PACNBR = LPACNBR
   [F:SDH1]BPTNUM = [M:PKP1]BPTNUM

   [F:SDH1]NETWEI = LNETWEI
   [F:SDH1]GROWEI = LGROWEI
   [F:SDH1]VOL    = LVOL
   If [F:SDH1]VOU = ""
      [F:SDH1]VOU = LVOU
   Endif
# si livraison non validée on calcul le tarif transporteur
   If [F:SDH1]CFMFLG <> 2 & IJL
       Gosub RECH_TARIF_TRSP From TRTVENLIV
   Endif
   Rewrite [SDH1]
   [F:SDH] = [F:SDH1]    # hcb 65587
Else
# Réécriture de la livraison
   Readlock [PRH1]PRH0=[M:PKP1]VCRNUM
   If fstat
      GOK = 0
      Call RSTA("PRH1",[M:PKP1]VCRNUM) From GLOCK
      Return
   Endif
   [F:PRH1]PACNBR = LPACNBR
   [F:PRH1]PACFLG = LPACFLG

   [F:PRH1]NETWEI = LNETWEI
   [F:PRH1]GROWEI = LGROWEI
   If LGROWEI = 0
      Raz LWEU
   Endif
   [F:PRH1]WEU    = LWEU
   Rewrite [PRH1]
   [F:PRH] = [F:PRH1]    # hcb 65587

Endif
Return


#########################################################################
$AVANT_PREMIER_TRTPKP

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif
Return

$PREMIER_TRTPKP
If GVCRTYP = 4
   Read [SDH]SDH0 First
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
Else
   Read [PRH]PRH0 First
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
Endif

Gosub CHARGE_PKP1

Return

#########################################################################
$AVANT_DERNIER_TRTPKP

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return


$DERNIER_TRTPKP
If GVCRTYP = 4
   Read [SDH]SDH0 Last
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
Else
   Read [PRH]PRH0 Last
   If fstat>2
      Call MESSAGE(mess(11,100,1)) From GESECRAN
      Return
   Endif
Endif

Gosub CHARGE_PKP1

Return


#########################################################################
$AVANT_SUI_TRTPKP

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return

#########################################################################
$SUI_TRTPKP
Gosub DEVERROU
If GVCRTYP = 4
   Gosub NEXT_SDH
Else
   Gosub NEXT_PRH
Endif
If FIN = 1
   Call MESSAGE(mess(11,100,1)) From GESECRAN
   FIN = 0
Endif

Return


#########################################################################
$AVANT_PRE_TRTPKP

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return

#########################################################################
$PRE_TRTPKP
GMODPAC = 0
GNBRLIG = 0
Gosub DEVERROU

If GVCRTYP = 4
   Read [SDH]SDH0 Prev
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:SDH]SDHNUM
      Gosub VERROU
      If VOK=1
         Goto PREV_SDH
      Elsif VOK=0
         Gosub FIN_PRE_TRTPKP
         Return
      Endif
   Else
      Gosub FIN_PRE_TRTPKP
      Return
   Endif
$PREV_SDH
   Gosub CHARGE_PKP1
Else
   Read [PRH]PRH0 Prev
   If !fstat
      NBLIV += 1
      VOK = 2
      GWCLECUR = [F:PRH]PRHNUM
      Gosub VERROU
      If VOK=1
         Goto PREV_PRH
      Elsif VOK=0
         Gosub FIN_PRE_TRTPKP
         Return
      Endif
   Else
      Gosub FIN_PRE_TRTPKP
      Return
   Endif
$PREV_PRH
   Gosub CHARGE_PKP1
Endif

Return

$FIN_PRE_TRTPKP
Call MESSAGE(mess(11,100,1)) From GESECRAN
Return

#########################################################################
$FIN_TRTPKP
If NBLIV = 0
   Call MESSAGE(mess(104,199,1)) From GESECRAN
Endif

Gosub DEVERROU

If GVCRTYP = 4
   Filter [SDH]
Else
   Filter [PRH]
Endif
If GACTION = "SAIPKP"
   GFLAG   = GSAVGFLAG
Endif
Return

########################################################################
# Mise à jour entete colis suite à enregistrement ou suppression d un colisage
#-----------------------------------------------------------------------
#            E : LFCY    = Nom du site
#                LTYP    = Type document
#                LNUM    = Numéro document
#              : LPAC    = Numéro colis
#              : LSEQ    = Sequence
#              : LSEQ    = Libellé
#              : LTEX    = Texte
#              : LSSC    = Code SSCC
#            S : LRET    = Code Erreur
########################################################################
Subprog ENTETE_COLIS(LFCY,LTYP,LNUM,LPAC,LSEQ,LLBL,LTEX,LSSC,LRET)
Value    Char     LFCY
Value    Integer  LTYP
Value    Char     LNUM
Value    Char     LPAC
Value    Integer  LSEQ
Value    Char     LLBL
Value    Char     LTEX
Value    Char     LSSC

Variable Integer  LRET
Local    Char     WITMREF
Local    Integer  WONE
Local    Decimal  WNETWEI
Local    Integer  WSPD
Local    Integer  WSTAT
Local    Integer  I
Local    Decimal  WNETWEI1                                                 # hcb X3-85746
Raz WNETWEI
Raz WITMREF
Raz WSPD
WONE = 2
Readlock  [SPH]SPH0=LTYP;LNUM;LPAC;1
Case fstat
  When 0
 # calcul WNETWEI WONE
       Filter [SPD] Where STOFCY = LFCY & VCRTYP = LTYP & VCRNUM = LNUM & PACNUM = LPAC
&             Order By Key CLE = STOFCY;VCRTYP;VCRNUM;PACNUM
       Columns [SPD] (ITMREF, NETWEI,WEU)                                  # hcb X3-85746
       For [SPD]
           WSPD = 1
           If WITMREF  = ""
              WITMREF  =  [F:SPD]ITMREF
           Endif
           If WITMREF <> [F:SPD]ITMREF
              WONE = 1
           Endif
#                                                                          # hcb X3-85746 deb
           If [F:SPH]WEU  <> [F:SPD]WEU
              WNETWEI1 = [F:SPD]NETWEI
        # Conversion poids unitaire de unité poids liv en unité poids colis
              Call SCONV_TCO([F:SPD]WEU,[F:SPH]WEU,WNETWEI1) From TRTVENQTE
              WNETWEI += WNETWEI1
           Else
#                                                                          # hcb X3-85746 deb
              WNETWEI += [F:SPD]NETWEI
           Endif                                                           # hcb X3-85746
       Next
       Filter  [SPD]
       Columns [SPD]

       If WSPD = 0
          If [F:SPH]SPHTEX <> ""
             If left$([F:SPH]SPHTEX,3)="SPH"
                Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
             Endif
          Endif
          Delete [SPH]
       Else
          [F:SPH]NETWEI    = WNETWEI
          [F:SPH]ONEITMFLG = WONE
          [F:SPH]UPDDAT    = date$
          [F:SPH]UPDUSR    = GUSER
          Rewrite [SPH]
       Endif

  When 1
       GLOCK="$SPACK"-LNUM-LPAC
       GOK = 0
  When 4,5

        If LPAC <> [F:SPD]PACNUM | LTYP <> [F:SPD]VCRTYP | LNUM <> [F:SPD]VCRNUM

           Filter [SPD] Where VCRTYP     = LTYP            &
&                             VCRNUM     = LNUM            &
&                             PACNUM     = LPAC
&                       Order By Key SPD0 Desc
           Read [SPD] First
           If fstat
              GOK = 0
              Call FSTA("SPD") From GLOCK
              End
           Endif
        Endif
        [F:SPH]          = [F:SPD]
        If [F:TPA]PCK <> [F:SPH]PCK
           Read [TPA]TPA0=[F:SPH]PCK
           If fstat
              Raz [F:TPA]
           Endif
        Endif
       [F:SPH]       = [F:TPA]
       If GVCRTYP = 4
# Conversion prix emballage
          If [F:SDH]CUR <> GSYSCUR
             Call CONVERT(GSYSCUR,[F:SDH]CUR,GSYSCUR,[F:SDH]CHGTYP,date$,
&                         [F:TPA]PCKPRI,[F:SPH]PCKPRI,WSTAT) From TRTDEV
          Endif
          [F:SPH]CUR       = [F:SDH]CUR
          [F:SPH]CHGTYP    = [F:SDH]CHGTYP
       Else
          [F:SPH]CUR       = GSYSCUR
          [F:SPH]CHGTYP    = 1
       Endif
       [F:SPH]PKGTYP    = 2                 # post colisage
       [F:SPH]CPY       = GSOCIETE
       Raz [F:SPH]NETWEI
# recherche no colis
       Raz I
       I  = sigma(0,[M:PKP1]NBLIG-1,(indcum+1)*([M:PKP1]PACSEQ(indcum) = LSEQ & [M:PKP1]PACSEQH(indcum) = 1 & I=0 & sigma(I=1,1,1)))
       If I <> 0
          I -=1
         [F:SPH]NETWEI = [M:PKP1]GROWEI(I) - [F:SPH]PCKWEI
       Endif
       WONE             = sigma(0,[M:PKP1]NBLIG-1,[M:PKP1]NETWEIPCK(indcum)*([M:PKP1]PACSEQ(indcum) = LSEQ &
&                                 [M:PKP1]ITMREF(indcum) <>  [M:PKP1]ITMREF(I)))
# hcb 92276 modification ligne ci-dessus
       If WONE   <> 0
          WONE = 1
       Else
          WONE = 2
       Endif
       [F:SPH]ONEITMFLG = WONE
       [F:SPH]LBLFMT    = LLBL              # Etiquette
       [F:SPH]SPHTEX    = LTEX              # texte
       [F:SPH]SCCCOD    = LSSC              # code SSCC
       [F:SPH]PACSEQ    = 1
       [F:SPH]PREUSR    = [M:PKP1]PREUSR    # préparateur
       [F:SPH]BPCORD    = [M:PKP1]BPCORD    # client livré
       [F:SPH]CREDAT    = date$             # hcb 60067
       [F:SPH]CREUSR    = GUSER
       #MAE, bg 83369
       [F:SPH]UPDUSR   = [F:SPD]UPDUSR
       [F:SPH]UPDDAT   = [F:SPD]UPDDAT
       [F:SPH]EXPNUM    = [C]EXPORT
       GPOINT = "BEFWRISPH"                 # hcb 73603
       Gosub ENTREE From EXEFNC             # hcb 73603
       Write [SPH]
       If fstat
          GOK = 0
          Call FSTA("SPH") From GLOCK
       Endif
       If [F:SPH]SPHTEX <>""
          Call CRE_CLOB([F:SPH]SPHTEX ,GOK) From TRTX3TEX
          If GOK<1
             End
          Endif
       Endif
Endcase
End

###########################################################
# Raz colisage d une ligne
###########################################################

$RAZ_COLISAGE
For I = 0 To [M:PKP1]NBLIG-1
    If [M:PKP1]PACSEQ(I) =  WPACSEQ
       Raz [M:PKP1]PACNUM       (I)
       Raz [M:PKP1]SCCCOD       (I)
       Raz [M:PKP1]PACSEQ       (I)
       Raz [M:PKP1]PACSEQH      (I)
#      Raz [M:PKP1]IDETAIL      (I)                                                                # hcb 110327-pck
       Raz [M:PKP1]GROWEI       (I)
       Raz [M:PKP1]NETWEIPCK    (I)
       Raz [M:PKP1]PCK          (I)
       Raz [M:PKP1]LBLFMT       (I)
       If GVCRTYP = 4
          [M:PKP1]PCK           (I) = [F:SDD]PCK
          [M:PKP1]PCKCAP        (I) = [F:SDD]PCKCAP    # hcb 55930
          [M:PKP1]LBLFMT        (I) = GDOCNAM
       Else
          [M:PKP1]PCK           (I)  = [F:PRE]PCK
          [M:PKP1]PCKCAP        (I)  = [F:PRE]PCKCAP    # hcb 55930
       Endif
       If [M:PKP1]PCK           (I) <> ""
          Read [TPA]TPA0 =  [M:PKP1]PCK (I)
          If fstat
             Raz [F:TPA]
          Endif
          If [F:TPA]LBLFMT <> ""
             [M:PKP1]LBLFMT     (I) = [F:TPA]LBLFMT
          Endif
       Endif
#                                                                                                  # hcb 110327-pck deb
       If [M:PKP1]IDETAIL (I) = 3 & [M:PKP1]PCKSERFLG (I) = 2
          [M:PKP1]IDETAIL (I) = 4
       Endif
#                                                                                                  # hcb 110327-pck fin

       Affzo [M:PKP1]PACNUM     (I)
       Affzo [M:PKP1]ITMREF     (I)
       Affzo [M:PKP1]ITMDES1    (I)
       Affzo [M:PKP1]QTYSAU     (I)
       Affzo [M:PKP1]SAU        (I)
       Affzo [M:PKP1]SAUSTUCOE  (I)
       Affzo [M:PKP1]QTYSAUSTU  (I)
       Affzo [M:PKP1]STU        (I)
       Affzo [M:PKP1]QTY        (I)
       Affzo [M:PKP1]QTYSTU     (I)
       Affzo [M:PKP1]PCK        (I)
       Affzo [M:PKP1]PACSEQ     (I)
       Affzo [M:PKP1]SCCCOD     (I)
       Affzo [M:PKP1]LBLFMT     (I)
       Affzo [M:PKP1]PCKWEI     (I)
       Affzo [M:PKP1]LIGWEU     (I)
       Affzo [M:PKP1]NETWEI     (I)
       Affzo [M:PKP1]GROWEI     (I)
       Affzo [M:PKP1]WEU        (I)
       Affzo [M:PKP1]PCKLEN     (I)
       Affzo [M:PKP1]PCKWID     (I)
       Affzo [M:PKP1]PCKHEI     (I)
       Affzo [M:PKP1]DIU        (I)
       Affzo [M:PKP1]VOL        (I)
       Affzo [M:PKP1]VOU        (I)
       Affzo [M:PKP1]VCRLIN     (I)
    Endif
Next
Return


Subprog APRES_NBLIG
Local Integer WPACSEQ
Local    Integer NOL
NOL = nolign-1

If [M:PKP1]PACSEQ(NOL) <> 0 & [M:PKP1]QTYSAUSTU (NOL) = [M:PKP1]QTYSTU(NOL)
#                                      hcb 90656 deb
   Affzo [M:PKP1]PACNUM     (NOL)
   Affzo [M:PKP1]ITMREF     (NOL)
   Affzo [M:PKP1]ITMDES1    (NOL)
   Affzo [M:PKP1]QTYSAU     (NOL)
   Affzo [M:PKP1]SAU        (NOL)
   Affzo [M:PKP1]SAUSTUCOE  (NOL)
   Affzo [M:PKP1]QTYSAUSTU  (NOL)
   Affzo [M:PKP1]STU        (NOL)
   Affzo [M:PKP1]QTY        (NOL)
   Affzo [M:PKP1]QTYSTU     (NOL)
   Affzo [M:PKP1]PCK        (NOL)
   Affzo [M:PKP1]PACSEQ     (NOL)
   Affzo [M:PKP1]PACNUM     (NOL)
   Affzo [M:PKP1]SCCCOD     (NOL)
   Affzo [M:PKP1]LBLFMT     (NOL)
   Affzo [M:PKP1]PCKWEI     (NOL)
   Affzo [M:PKP1]LIGWEU     (NOL)
   Affzo [M:PKP1]NETWEI     (NOL)
   Affzo [M:PKP1]GROWEI     (NOL)
   Affzo [M:PKP1]WEU        (NOL)
   Affzo [M:PKP1]PCKLEN     (NOL)
   Affzo [M:PKP1]PCKWID     (NOL)
   Affzo [M:PKP1]PCKHEI     (NOL)
   Affzo [M:PKP1]PCKCAP     (NOL)
   Affzo [M:PKP1]DIU        (NOL)
   Affzo [M:PKP1]VOL        (NOL)
   Affzo [M:PKP1]VOU        (NOL)
   Affzo [M:PKP1]VCRLIN     (NOL)
#                                      hcb 90656 fin
Endif
WPACSEQ = [M:PKP1]PACSEQ(NOL)

End




Subprog C_PCK(VALEUR)
Variable Char    VALEUR()
Local    Integer I

# Si le no séquence n'a pas été saisi, pas de contrôle
If [M:PKP1]PACSEQ(nolign-1) = 0 End Endif
# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
If nolign <> 1
   I = find([M:PKP1]PACSEQ(nolign-1),[M:PKP1]PACSEQ(0..nolign-2))
Endif
If I <> 0
   If VALEUR <> [M:PKP1]PCK(I-1)
      GMESSAGE=mess(135,192,1) : mkstat = 2 : End
   Endif
Else
   If nolign <> [M:PKP1]NBLIG
      I = find([M:PKP1]PACSEQ(nolign-1),[M:PKP1]PACSEQ(nolign..[M:PKP1]NBLIG-1))
   Endif
   If I <> 0
      I += nolign
      If VALEUR <> [M:PKP1]PCK(I-1)
         GMESSAGE=mess(135,192,1) : mkstat = 2 : End
      Endif
   Endif
Endif

End

Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()
[M:PKP1]MODFLG(nolign-1) = 2
If VALEUR = ""
   Local Integer WPACSEQ
   WPACSEQ = [M:PKP1]PACSEQ    (nolign-1)
   Gosub RAZ_COLISAGE
   Raz [M:PKP1]PACSEQ    (nolign-1)
   Raz [M:PKP1]PACNUM    (nolign-1)
   Raz [M:PKP1]SCCCOD    (nolign-1)
   Raz [M:PKP1]PCKWEI    (nolign-1)
   Raz [M:PKP1]VOL       (nolign-1)
   Raz [M:PKP1]WEU       (nolign-1)
   Raz [M:PKP1]VOU       (nolign-1)
   Raz [M:PKP1]PCKLEN    (nolign-1)
   Raz [M:PKP1]PCKWID    (nolign-1)
   Raz [M:PKP1]PCKHEI    (nolign-1)
   Raz [M:PKP1]DIU       (nolign-1)
   Raz [M:PKP1]LBLFMT    (nolign-1)
   If GVCRTYP = 4
      [M:PKP1]LBLFMT    (nolign-1) = GDOCNAM
   Endif
   Affzo [M:PKP1]QTY    (nolign-1)
   Affzo [M:PKP1]QTYSTU (nolign-1)
   Affzo [M:PKP1]PACSEQ (nolign-1)
   Affzo [M:PKP1]PACNUM (nolign-1)
   Affzo [M:PKP1]SCCCOD (nolign-1)
   Affzo [M:PKP1]NETWEI (nolign-1)
   Affzo [M:PKP1]GROWEI (nolign-1)
   Affzo [M:PKP1]PCKWEI (nolign-1)
   Affzo [M:PKP1]VOL    (nolign-1)
   Affzo [M:PKP1]WEU    (nolign-1)
   Affzo [M:PKP1]VOU    (nolign-1)
   Affzo [M:PKP1]PCKLEN (nolign-1)
   Affzo [M:PKP1]PCKWID (nolign-1)
   Affzo [M:PKP1]PCKHEI (nolign-1)
   Affzo [M:PKP1]DIU    (nolign-1)
   Affzo [M:PKP1]LBLFMT (nolign-1)

   End
Endif

If VALEUR <> ""  &  [F:TPA]PCK <> VALEUR
   Read [TPA]TPA0=VALEUR
   If fstat
      Raz [F:TPA]
   Endif
Endif

[M:PKP1]LIGUNTWEI (nolign-1)  = 1
If [M:PKP1]WEUSDD(nolign-1) <> [F:TPA]WEU
# Conversion poids unitaire de unité poids liv en unité poids colis
       Call SCONV_TCO([M:PKP1]WEUSDD(nolign-1),[F:TPA]WEU,[M:PKP1]LIGUNTWEI (nolign-1)) From TRTVENQTE
Endif

[M:PKP1]PCKWEI (nolign-1)       = [F:TPA]PCKWEI
[M:PKP1]VOL    (nolign-1)       = [F:TPA]VOL
[M:PKP1]WEU    (nolign-1)       = [F:TPA]WEU
[M:PKP1]VOU    (nolign-1)       = [F:TPA]VOU
[M:PKP1]PCKLEN (nolign-1)       = [F:TPA]PCKLEN
[M:PKP1]PCKWID (nolign-1)       = [F:TPA]PCKWID
[M:PKP1]PCKHEI (nolign-1)       = [F:TPA]PCKHEI
[M:PKP1]DIU    (nolign-1)       = [F:TPA]DIU
If [F:TPA]LBLFMT <> ""
   [M:PKP1]LBLFMT (nolign-1)       = [F:TPA]LBLFMT
Endif
[M:PKP1]NETWEIPCK (nolign-1)    = [M:PKP1]NETWEI  (nolign-1) * [M:PKP1]LIGUNTWEI(nolign-1)

If [M:PKP1]PACSEQH      (nolign-1)  =  1
   [M:PKP1]GROWEI       (nolign-1)  = [M:PKP1]NETWEIPCK (nolign-1) + [M:PKP1]PCKWEI (nolign-1)
   Affzo [M:PKP1]GROWEI (nolign-1)
Endif

Affzo [M:PKP1]NETWEI (nolign-1)
Affzo [M:PKP1]GROWEI (nolign-1)
Affzo [M:PKP1]PCKWEI (nolign-1)
Affzo [M:PKP1]VOL    (nolign-1)
Affzo [M:PKP1]WEU    (nolign-1)
Affzo [M:PKP1]VOU    (nolign-1)
Affzo [M:PKP1]PCKLEN (nolign-1)
Affzo [M:PKP1]PCKWID (nolign-1)
Affzo [M:PKP1]PCKHEI (nolign-1)
Affzo [M:PKP1]DIU    (nolign-1)
Affzo [M:PKP1]LBLFMT (nolign-1)

End

Subprog AM_PACNUM(VALEUR)
Variable Char    VALEUR()
[M:PKP1]MODFLG(nolign-1) = 2

If [M:PKP1]PACFLG(nolign-1) = 1
   If !find(VALEUR,[M:PKP1]PACNUM(0..[M:PKP1]NBLIG-1))
          GMESSAGE =mess(270,184,1)  # Numéro de colis inexistant!
          mkstat = 2
          End
   Endif
Endif

# controle que si le numero existe il doit avoir le meme pacseq
I = find(VALEUR,[M:PKP1]PACNUM(0..[M:PKP1]NBLIG-1))
If I <> 0
   If [M:PKP1]PACSEQ(nolign-1) <> [M:PKP1]PACSEQ(I-1)
      GMESSAGE=mess(272,184,1) # erreur codification colis !!!
      mkstat = 2
   Endif
Endif

# recherche si numero colis existe deja
Local Integer WOK
Raz WOK
Filter [SPH] Where PACNUM   = VALEUR
&            Order By Key SPH0
For [SPH]
    If [F:SPH]VCRNUM  <> [M:PKP1]VCRNUM | [F:SPH]VCRTYP <> [M:PKP1]VCRTYP
       WOK = 9
       Break
    Endif
Next
Filter [SPH]
If WOK = 9
   GMESSAGE =mess(290,184,1)  # Numéro de colis existant!
   mkstat = 2
   End
Endif

End

Subprog IB_NBLIG
Local Integer WI
# Détail colisage
GBOUT1 = mess(277,184,1)
# Texte colis
GBOUT2 = mess(276,184,1)
# Suppression ligne colis
GBOUT3 = mess(478,198,1)
# Suppression colis :
GBOUT4 = mess(483,198,1) + [M:PKP1]PACNUM(nolign-1)
# Colisage automatique
GBOUT5 = mess(484,198,1)
# Raz Colisage
GBOUT6 = mess(485,198,1) + num$([M:PKP1]PACSEQ(nolign-1))

Raz GBOUT3    # on supprime un colis entierement (accord jerome)


If GCONSULT = 2
   Raz GBOUT3
   Raz GBOUT4
   Raz GBOUT5
   Raz GBOUT6
Endif
# pas de detail colisage si des modifs sont en cours
Raz WI
WI = find(2,[M:PKP1]MODFLG(0..[M:PKP1]NBLIG-1))
If WI > 0
   GBOUT1 = ""
Endif

If [M:PKP1]PACFLG(nolign-1) <> 2
   GBOUT3 = ""
   GBOUT4 = ""
Endif

If [M:PKP1]PACSEQ(nolign-1) <> 0
   GBOUT5 = ""
Endif
# Pas de colisage colisage automatique si
#      l article site gére le colisage detail stock
#      le nombre de détail est > 1
If [M:PKP1]PCKSTKFLG (nolign-1) = 2 &
&  [M:PKP1]NBDETAIL  (nolign-1) > 1
   GBOUT5 = ""
Endif
If [M:PKP1]PACFLG(nolign-1) = 2
   GBOUT6 = ""
Endif
If [M:PKP1]PACSEQ(nolign-1) = 0
   GBOUT6 = ""
Endif


End


Subprog B1_NBLIG
# globales pour retour du detail sans modif
Global Integer GPACSEQ_PKP1
Global Char    GPACNUM_PKP1(30)
Global Char    GSCCCOD_PKP1(20)
GPACSEQ_PKP1 = [M:PKP1]PACSEQ(nolign-1)
GPACNUM_PKP1 = [M:PKP1]PACNUM(nolign-1)
GSCCCOD_PKP1 = [M:PKP1]SCCCOD(nolign-1)
If [M:PKP1]PACSEQ   (nolign-1) = 0
   [M:PKP1]PACSEQ   (nolign-1) = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
   [M:PKP1]PACSEQH  (nolign-1) =  1

Endif

GOUVPAC = 2
End

Subprog B3_NBLIG
If [M:PKP1]PACFLG(nolign-1) <> 2
   End
Endif
Local Integer LLIG
Local Integer LANU_SDD
LANU_SDD = 2
LLIG     = nolign-1
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]
Gosub ANU_COLISAGE
If GOK <> 1
   Gosub ABORT
Else
   Commit
Endif

Gosub CHARGE_PKP1

End

Subprog B4_NBLIG
If [M:PKP1]PACFLG(nolign-1) <> 2
   End
Endif

# suppression du colis
Local Integer WOK
Call OUINON(mess(287,184,1)+" "+[M:PKP1]PACNUM(nolign-1)+"  "+mess(288,184,1) ,WOK) From GESECRAN
If WOK <> 2
   End
Endif

Local Integer LLIG
Local Integer LANU_SDD
LANU_SDD = 3
LLIG     = nolign-1
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]
Gosub ANU_COLISAGE
If GOK <> 1
   Gosub ABORT
Else
   Commit
Endif

Gosub CHARGE_PKP1
mkstat = 99  # hcb 65587
End


Subprog B6_NBLIG
# Raz colisage
Local Integer WPACSEQ
WPACSEQ = [M:PKP1]PACSEQ(nolign-1)
Gosub RAZ_COLISAGE
mkstat = 99  # hcb 65587
End


Subprog C_PACSEQ(VALEUR)
Variable Decimal VALEUR
Local    Integer I, NOL
Local    Integer WPACSEQ
# Traitement particulier s'il ni a qu'une ligne
If [M:PKP1]NBLIG = 1
   If VALEUR = 1
      End
   Else
      GMESSAGE=mess(136,192,1)
      mkstat = 2
      End
   Endif
Endif
# si qte traitée <> 0 alors pacseq doit etre renseigné
If VALEUR = 0 & [M:PKP1]PACSEQ (nolign-1) <> 0
   WPACSEQ = [M:PKP1]PACSEQ(nolign-1)
   Gosub RAZ_COLISAGE
   End
Endif
# Le no séquence doit exister ou être consécutif
If VALEUR > max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
   GMESSAGE=mess(136,192,1) : mkstat = 2
Endif
# Si le code emballage n'a pas été saisi, pas de contrôle
If [M:PKP1]PCK(nolign-1) = ""
   End
Endif

# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
I = find(VALEUR,[M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1))
If I <> 0
   If [M:PKP1]PCK(nolign-1) <> ""
      If [M:PKP1]PCK(nolign-1) <> [M:PKP1]PCK(I-1)
         GMESSAGE=mess(135,192,1) : mkstat = 2
      Endif
   Endif
Endif

End

Subprog AM_PACSEQ(VALEUR)
Variable Decimal VALEUR
[M:PKP1]MODFLG(nolign-1) = 2
Local Integer I
If VALEUR <>  0
# recherche no colis
   Raz I
   I  = sigma(0,[M:PKP1]NBLIG-1,(indcum+1)*([M:PKP1]PACSEQ(indcum) = VALEUR & indcum <> nolign-1 & [M:PKP1]PACSEQH(indcum) = 1 & I=0 & sigma(I=1,1,1)))
   If I <> 0
      I -= 1
      [M:PKP1]PACNUM       (nolign-1) = [M:PKP1]PACNUM (I)
      [M:PKP1]SCCCOD       (nolign-1) = [M:PKP1]SCCCOD (I)
      Affzo [M:PKP1]PACNUM (nolign-1)
      Affzo [M:PKP1]SCCCOD (nolign-1)
      If [M:PKP1]NETWEI    (nolign-1) = 0
         [M:PKP1]NETWEI    (nolign-1)  = [M:PKP1]QTYSTU    (nolign-1) * [M:PKP1]UNTWEI   (nolign-1)   # hcb 54897
      Endif
      [M:PKP1]NETWEIPCK    (nolign-1)  = [M:PKP1]NETWEI    (nolign-1) * [M:PKP1]LIGUNTWEI(nolign-1)

      [M:PKP1]GROWEI       (I)        += [M:PKP1]NETWEIPCK (nolign-1)
#     Raz [M:PKP1]LBLFMT   (nolign-1)   # hcb  103101
      Raz [M:PKP1]GROWEI   (nolign-1)
      Raz [M:PKP1]PACSEQH  (nolign-1)

      If    [M:PKP1]PCK          (nolign-1) = ""
            [M:PKP1]PCK          (nolign-1) = [M:PKP1]PCK    (I)
            [M:PKP1]PCKWEI       (nolign-1) = [M:PKP1]PCKWEI (I)
            [M:PKP1]VOL          (nolign-1) = [M:PKP1]VOL    (I)
            [M:PKP1]WEU          (nolign-1) = [M:PKP1]WEU    (I)
            [M:PKP1]VOU          (nolign-1) = [M:PKP1]VOU    (I)
            [M:PKP1]PCKLEN       (nolign-1) = [M:PKP1]PCKLEN (I)
            [M:PKP1]PCKWID       (nolign-1) = [M:PKP1]PCKWID (I)
            [M:PKP1]PCKHEI       (nolign-1) = [M:PKP1]PCKHEI (I)
            [M:PKP1]DIU          (nolign-1) = [M:PKP1]DIU    (I)
            [M:PKP1]LBLFMT       (nolign-1) = [M:PKP1]LBLFMT (I)   # hcb  103101
            Affzo [M:PKP1]PCK    (nolign-1)
            Affzo [M:PKP1]PCKWEI (nolign-1)
            Affzo [M:PKP1]VOL    (nolign-1)
            Affzo [M:PKP1]WEU    (nolign-1)
            Affzo [M:PKP1]VOU    (nolign-1)
            Affzo [M:PKP1]PCKLEN (nolign-1)
            Affzo [M:PKP1]PCKWID (nolign-1)
            Affzo [M:PKP1]PCKHEI (nolign-1)
            Affzo [M:PKP1]DIU    (nolign-1)
      Endif
      Affzo [M:PKP1]NETWEI (nolign-1)
      Affzo [M:PKP1]GROWEI (nolign-1)
      Affzo [M:PKP1]LBLFMT (nolign-1)
      Affzo [M:PKP1]GROWEI (I)
   Else
      If [M:PKP1]PCK(nolign-1) = ""
         GMESSAGE=mess(286,184,1)   # code emballage non renseigné !
         mkstat = 2
      Else
         [M:PKP1]NETWEI       (nolign-1)  = [M:PKP1]QTYSTU    (nolign-1) * [M:PKP1]UNTWEI   (nolign-1)   # hcb 54897
         [M:PKP1]NETWEIPCK    (nolign-1)  = [M:PKP1]NETWEI    (nolign-1) * [M:PKP1]LIGUNTWEI(nolign-1)   # hcb 54897
         [M:PKP1]GROWEI       (nolign-1)  = [M:PKP1]NETWEIPCK (nolign-1) + [M:PKP1]PCKWEI (nolign-1)
         [M:PKP1]PACSEQH      (nolign-1)  =  1
         Affzo [M:PKP1]GROWEI (nolign-1)
      Endif
   Endif
Endif

End

# Appelé avant l'action SAIPKP2
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Local Shortint WRET
GOUVPAC = 0
# si pas de modif sur la ligne pas d ouverture détail
If [M:PKP1]MODFLG(nolign-1) <> 2
   Return
Endif
# on ouvre la fenetre de detail dans le cas suivant
#      l article site est géré en stock
#      l article site gére le colisage detail stock
#      le nombre de détail est > 1
#      la  qte traitée est <> de la qte à coliser
#
If [M:PKP1]STOMGTCOD (nolign-1) > 1 &
&  [M:PKP1]PCKSTKFLG (nolign-1) = 2 &
&  [M:PKP1]NBDETAIL  (nolign-1) > 1 &
&  [M:PKP1]QTYSTU(nolign-1) <> [M:PKP1]QTYSAUSTU(nolign-1)
   Global Integer GPACSEQ_PKP1
   Global Char    GPACNUM_PKP1(30)
   Global Char    GSCCCOD_PKP1(20)
   GPACSEQ_PKP1 = [M:PKP1]PACSEQ(nolign-1)
   GPACNUM_PKP1 = [M:PKP1]PACNUM(nolign-1)
   GSCCCOD_PKP1 = [M:PKP1]SCCCOD(nolign-1)
   GOUVPAC = 1
   Return
Endif
Return


Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
#If VALEUR  *  [M:PKP1]SAUSTUCOE(nolign-1) > [M:PKP1]QTYSAUSTU(nolign-1)    # hcb x3-102665
If VALEUR > [M:PKP1]QTYSAU(nolign-1)                                        # hcb x3-102665
   mkstat = 2
   End
Endif


End

Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

[M:PKP1]MODFLG(nolign-1) = 2
If VALEUR = 0
   Local Integer WPACSEQ
   WPACSEQ = [M:PKP1]PACSEQ(nolign-1)
   Gosub RAZ_COLISAGE
   Raz   [M:PKP1]QTY       (nolign-1)           # 56102
   Raz   [M:PKP1]QTYSTU    (nolign-1)
   Raz   [M:PKP1]NETWEI    (nolign-1)
   Affzo [M:PKP1]QTYSTU    (nolign-1)
   Affzo [M:PKP1]NETWEI    (nolign-1)
   Affzo [M:PKP1]QTY       (nolign-1)           # 56102
   End
Endif

[M:PKP1]QTYSTU(nolign-1) = VALEUR * [M:PKP1]SAUSTUCOE(nolign-1)
Call QTEARR([M:PKP1]QTYSTU(nolign-1), [M:PKP1]STU(nolign-1)) From TRTDIV
[M:PKP1]NETWEI    (nolign-1) = [M:PKP1]QTYSTU   (nolign-1) * [M:PKP1]UNTWEI   (nolign-1)   # hcb 54897
Call QTEARR([M:PKP1]NETWEI(nolign-1), [M:PKP1]LIGWEU(nolign-1)) From TRTDIV                               # hcb 119241

[M:PKP1]NETWEIPCK (nolign-1) = [M:PKP1]NETWEI   (nolign-1) * [M:PKP1]LIGUNTWEI(nolign-1)

If [M:PKP1]PACSEQH      (nolign-1)  =  1
   [M:PKP1]GROWEI       (nolign-1)  = [M:PKP1]NETWEIPCK (nolign-1) + [M:PKP1]PCKWEI (nolign-1)
Endif
Affzo [M:PKP1]QTYSTU(nolign-1)
Affzo [M:PKP1]NETWEI(nolign-1)
Affzo [M:PKP1]GROWEI(nolign-1)


End

Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
If VALEUR   > [M:PKP1]QTYSAUSTU(nolign-1)
   mkstat = 2
   End
Endif

End

Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR

End

Subprog IB_PACNUM
If [M:PKP1]PACNBR = 0
   Raz GBOUT1
Endif

End


Subprog AM_NETWEI(VALEUR)
Variable Decimal VALEUR
[M:PKP1]MODFLG(nolign-1) = 2

[M:PKP1]NETWEIPCK(nolign-1) = VALEUR  *  [M:PKP1]LIGUNTWEI(nolign-1)

If [M:PKP1]PACSEQH      (nolign-1)  =  1
   [M:PKP1]GROWEI       (nolign-1)  = [M:PKP1]NETWEIPCK (nolign-1) + [M:PKP1]PCKWEI (nolign-1)
   Affzo [M:PKP1]GROWEI (nolign-1)
Endif

End

Subprog AM_LBLFMT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Integer WOK
# si modif etiquette recherche coherence pacseq
I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(nolign-1) & indcum <>  nolign-1))
If I <> 0
   If VALEUR <> [M:PKP1]LBLFMT(I-1)
# Incohérence entre l étiquette et le no séquence:\Désirez vous répercuter la modification  ?
      Call OUINON(mess(281,184,1),WOK) From GESECRAN
      If WOK <> 2
         End
      Endif
   Endif
   Raz I
   Local Integer WPACSEQ
   Local Char    WLBLFMT
   WPACSEQ = [M:PKP1]PACSEQ(nolign-1)
   WLBLFMT = VALEUR
     For I = 0 To [M:PKP1]NBLIG-1
         If [M:PKP1]PACSEQ(I) =  WPACSEQ
            [M:PKP1]LBLFMT(I) =  WLBLFMT
         Endif
     Next
   Affzo [M:PKP1]20
Endif

[M:PKP1]MODFLG(nolign-1) = 2

End

#---------------------------------------------------
# Avant zone : Colorisation des lignes non colisées  => rouge
#---------------------------------------------------
$PKPCOLOR
pcolor = GCOUL(0)                # noir
#      Gosub PKPCOLOR            # colorisation ligne en  rouge                                    # hcb 110327-pck aml deb
If [M:PKP1]PACSEQ(nolign-1) =  0
#    pcolor = GCOUL(1)
#Endif
   If [M:PKP1]NBDETAIL(nolign-1) = 1
      pcolor = GCOUL(3)               # bleu
   Else
      pcolor = GCOUL(1)               # rouge
   Endif
Endif
#                                                                                                  # hcb 110327-pck aml fin

Return


#########################################################################
# CAL_NBDETAIL calcul du nombre de detail pour une ligne de document
#              resultat dans [m:pkp1]nbdetail(llig) avec pour valeur
#                  0 : sans detail
#                  1 : un seul detail
#                  2 : plus de un detail
#              si colisage non fait et emballage + capacités de renseignés determination
#                 nombre de colis et colisage automatique si PKP1
#
#########################################################################
$CAL_NBDETAIL

Raz [M:PKP1]NBDETAIL  (LLIG)
# si article non gere en stock pas de calcul
If  [M:PKP1]STOMGTCOD (LLIG) <  2
    Return
Endif
# si article site ne gere pas le colisage detail stock  pas de calcul
If  [M:PKP1]PCKSTKFLG (LLIG) <> 2
    Return
Endif

Local Char    WFILSTA(20)
# si origine : livraison validée on lit stojou

# Issue X3-69499 - 2018-06-13 by TS
#If GVCRTYP = 4 & [F:SDH]CFMFLG = 2
# Ajout test sur LINCFMFLG par sécurité car normalement inutile,
# les livraisons partiellement validées étant filtrées (non chargées)
If GVCRTYP=4 & ([F:SDH]CFMFLG=2 | [F:SDD]LINCFMFLG=2)
# End issue X3-69499
   Columns [STJ] (STOFCY, VCRTYP, VCRNUM, VCRLIN, UPDCOD, REGFLG)
   Filter  [STJ] Where STOFCY=[M:PKP1]STOFCY & VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM
&                   &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                   &  UPDCOD=2 & REGFLG<>2
&  Order By Key STJ1
   For [STJ]
       [M:PKP1]NBDETAIL     (LLIG) += 1
       If [M:PKP1]NBDETAIL  (LLIG) > 1
          Break
       Endif
   Next
   Filter  [STJ]
   Columns [STJ]
Else
# Si origine  : livraison non validée / preparation on recupere les allocation detailées et manquant 2 / 4
   WFILSTA = 'find(ALLTYP,2,4)<>0'
   Columns [STA] (VCRTYP, VCRNUM, VCRLIN, ITMREF, ALLTYP)
   Filter  [STA] Where VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                   &  ITMREF=[M:PKP1]ITMREF(LLIG) & evalue(WFILSTA)
   For [STA]
       [M:PKP1]NBDETAIL     (LLIG) += 1
       If [M:PKP1]NBDETAIL  (LLIG) > 1
          Break
       Endif
   Next
   Filter  [STA]
   Columns [STA]
Endif
#                                                        #  hcb 55930 2 deb
# si colisage non fait
# si code emballage et capacité renseignés
# si nombre de detail > 1
#    alors verification que la qte de chacune des lignes de detail corresponde à la capacite de l emballage
#    si ok alors comptage du nombre de colis  : [pkp1]nbcol
# si l"article gere les series globales cet automatisme est trop compliqué à mettre en oeuvre il faudrait    # hcb 110327-pck
# lors de l enregistrement mémoriser le dernier numero de serie lors de la lecture de stojou ou stoall       # hcb 110327-pck
If [M:PKP1]SERMGTCOD = 4                                                                                     # hcb 110327-pck
   Return                                                                                                    # hcb 110327-pck
Endif                                                                                                        # hcb 110327-pck
Raz [M:PKP1]NBCOL (LLIG)
If ((GVCRTYP = 4 & [F:SDD]PACQTYSTU = 0) | (GVCRTYP = 3 & [F:PRE]PACQTYSTU = 0))
&             & [M:PKP1]PCK(LLIG) <> "" & [M:PKP1]PCKCAP(LLIG) <> 0 & [M:PKP1]NBDETAIL(LLIG) > 1
   Local Integer WCALNBCOL
   Raz WCALNBCOL
   Raz GPE                         # hcb 70359
   GPOINT = "CALWCALNBCOL"         # hcb 70359
   Gosub  ENTREE From EXEFNC       # hcb 70359
   If GPE =  0                     # hcb 70359
# alors verification que la qte de chacune des lignes de detail corresponde à la capacite de l emballage
# si origine : livraison validée on lit stojou

      # Issue X3-69499 - 2018-06-13 by TS
      #If GVCRTYP = 4 & [F:SDH]CFMFLG = 2
      # Ajout test sur LINCFMFLG par sécurité car normalement inutile,
      # les livraisons partiellement validées étant filtrées (non chargées)
      If GVCRTYP=4 & ([F:SDH]CFMFLG=2 | [F:SDD]LINCFMFLG=2)
      # End issue X3-69499
         Columns [STJ] (STOFCY, VCRTYP, VCRNUM, VCRLIN, UPDCOD, REGFLG, QTYSTU)
         Filter  [STJ] Where STOFCY=[M:PKP1]STOFCY & VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM
&                         &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                         &  UPDCOD=2 & REGFLG<>2 &  QTYSTU <> [M:PKP1]PCKCAP(LLIG)
&        Order By Key STJ1
         For [STJ]
             WCALNBCOL = 1
             Break
         Next
         Filter  [STJ]
         Columns [STJ]
      Else
# Si origine  : livraison non validée / preparation on recupere les allocation detailées et manquant 2 / 4
         WFILSTA = 'find(ALLTYP,2,4)<>0'
         Columns [STA] (VCRTYP, VCRNUM, VCRLIN, ITMREF, ALLTYP, QTYSTU)
         Filter  [STA] Where VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                         &  ITMREF=[M:PKP1]ITMREF(LLIG) & evalue(WFILSTA) & QTYSTU <> [M:PKP1]PCKCAP(LLIG)
         For [STA]
             WCALNBCOL = 1
             Break
         Next
         Filter  [STA]
         Columns [STA]
      Endif
   Endif                           # hcb 70359
   If WCALNBCOL = 0
# comptage du nombre de colis  : [pkp1]nbcol
# si origine : livraison validée on lit stojou

      # Issue X3-69499 - 2018-06-13 by TS
      #If GVCRTYP = 4 & [F:SDH]CFMFLG = 2
      # Ajout test sur LINCFMFLG par sécurité car normalement inutile,
      # les livraisons partiellement validées étant filtrées (non chargées)
      If GVCRTYP=4 & ([F:SDH]CFMFLG=2 | [F:SDD]LINCFMFLG=2)
      # End issue X3-69499
         Columns [STJ] (STOFCY, VCRTYP, VCRNUM, VCRLIN, UPDCOD, REGFLG)
         Filter  [STJ] Where STOFCY=[M:PKP1]STOFCY & VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM
&                         &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                         &  UPDCOD=2 & REGFLG<>2
&        Order By Key STJ1
         For [STJ]
             [M:PKP1]NBCOL (LLIG) += 1
         Next
         Filter  [STJ]
         Columns [STJ]
      Else
# Si origine  : livraison non validée / preparation on recupere les allocation detailées et manquant 2 / 4
         WFILSTA = 'find(ALLTYP,2,4)<>0'
         Columns [STA] (VCRTYP, VCRNUM, VCRLIN, ITMREF, ALLTYP)
         Filter  [STA] Where VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM &  VCRLIN=[M:PKP1]VCRLIN(LLIG)
&                         &  ITMREF=[M:PKP1]ITMREF(LLIG) & evalue(WFILSTA)
         For [STA]
             [M:PKP1]NBCOL (LLIG) += 1
         Next
         Filter  [STA]
         Columns [STA]
      Endif
   Endif
Endif
#                                                        #  hcb 55930 2 fin


Return

Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
#                                                        #  hcb 55930 2 deb
# rouge (GCOUL = 1) = colisage à faire
# vert  (GCOUL = 2) = colisage auto ok à enregistrer
# noire (GCOUL = 0) = colisage      ok
pcolor = GCOUL(0)
If [M:PKP1]PACNUM(nolign-1) = ""                                                                   # hcb 110327-pck aml

   If [M:PKP1]PACSEQ(nolign-1) =  0
      Gosub PKPCOLOR
   Else
# detail à renseigner
#   If [M:PKP1]IDETAIL(nolign-1) =  2                                                              # hcb 110327-pck
       If [M:PKP1]IDETAIL(nolign-1) >  1                                                           # hcb 110327-pck
           If  [M:PKP1]PCK(nolign-1) <> "" & [M:PKP1]PCKCAP(nolign-1) <> 0  & [M:PKP1]NBDETAIL  (nolign-1) < 2
&            & [M:PKP1]MODFLG(nolign-1) = 2                                                           # hcb 110327-pck
               pcolor = GCOUL(2)
           Else
               If [M:PKP1]NBCOL (nolign-1) = 0
                  pcolor = GCOUL(1)
               Else
                  pcolor = GCOUL(2)
               Endif
          Endif
       Else
          If  [M:PKP1]MODFLG(nolign-1) = 2                                                 # hcb 110327-pck aml
#                    # hcb 110327-pck aml
              pcolor = GCOUL(2)
          Else                                                                             # hcb 110327-pck aml
              pcolor = GCOUL(1)                                                            # hcb 110327-pck aml
          Endif                                                                            # hcb 110327-pck aml
       Endif
   Endif
Endif                                                                                              # hcb 110327-pck aml

#                                                        #  hcb 55930 2 fin

End


Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Char NUM
GCONSULT = 2
Case [M:PKP1]VCRTYP
When 3       # preparation
      NUM = num$([M:PKP1]VCRTYP)
      Call OBJET("PRH",[M:PKP1]VCRNUM,NUM) From GOBJET
When 4       # livraison
      Call OBJET("SDH",[M:PKP1]VCRNUM,NUM) From GOBJET
Endcase
GCONSULT = 0

End

