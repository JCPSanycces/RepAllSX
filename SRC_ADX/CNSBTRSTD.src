#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry BTR
$ACTION
Case ACTION
  When "AUTORIS"      : Gosub AUTORIS
  When "OUVRE"        : Gosub OUVRE
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "LECTURE"      : Gosub LECTURE
  When "APRES_CHOI"   : Gosub AP_CHOIX
  When "AP_CHOIX2"    : Gosub AP_CHOIX2
  When "FERME"        : Gosub FERME
  When "SETBOUT"      : Gosub SETBOUT #SAM 100592
Endcase
Return

$AUTORIS
  Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(14)
  If GTUNCPT(14)
    Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
    # The same function cannot be called twice!
  Else
    GTUNCPT(14) = 1
  Endif
  MEMO="btr"
Return

$SEL_TABLE
  Case COUZON
    When "BANK"    :  Gosub S_BAN    : # Bank
  Endcase
Return
############################################
$AP_CHOIX2
Local Char    SAVACT(GLONACT), XMEM(3)
Local Integer FLGEXE

XMEN="btr"

I=find(REPONSE,LBOUT)
If I<1 : Return : Endif
SAVACT = GACTION

Case CBOUT(I-1)
 When "M"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBTR]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "1"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
 When "R"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBTR]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "2"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
 When "E"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBTR]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "3"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
Endcase
GACTION = SAVACT

Return

############################################
$SETBOUT     #SAM 100592
CHAINE="CRD=LF"
Return

############################################
$FERME
If dim(OTUNCPT)>0 : GTUNCPT(14) = OTUNCPT : Endif
Kill GCOLDES, GCOLAMT

# Delete of the working table before leave the inquiry
$TRT_ANNUL
Trbegin [BPL]
Delete [BPL] Where CNSUSR=GUSER
If fstat=1
 GLOCK = "BANKPOSD"-"" : Goto ROLL_TR_ANNUL
Elsif fstat>5
 Call RSTA("BPL","") From GLOCK : Goto AB_TR_ANNUL
Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRT_ANNUL : Endif
Return


############################################
$OUVRE

If !clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If !clalev([M:CBTR])=0 : Local Mask CRITBTR    [CBTR] : Endif

Global Char GCOLDES(20)(0..15), GCOLAMT(20)
Local Char SOC(GLONCPY), SITE(GLONFCY), BANKGR((GLONBGR)),BANK(GLONBAN), CFOTYP(13), DEV(GLONCUR), DEVCUR(GLONCUR), TSITE(GLONFCY)(1..)
Local Char CRITERE(250), WFIL(250)(15), CRITADD(250), AUXLNK(50)
Local Integer GRP, ICRIT, NBSITE ,TYPRAT, FILSTA, IMP, LEVC, LEVD, OK

Return

#############################################
$LECTURE
  OK=0
  IMP=0
  If [M]CPY<>"" : OK=1 : Endif
  If !OK or [M]CPY="" : NBLU=0 : Return : Endif

  If IMP=0
    Actzo [M:BTR0]
    Effzo [M:BTR1]
    Effzo [M:BTR2]
    Raz CFOTYP
  Endif

  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG<0 : NOL = MAXLIG : Endif

  Gosub INIT

  If GERR=1  : NBLU=0 : Return : Endif
  Gosub LOAD_FILTER
  Raz [M:BTR1]
  Raz [M:BTR2]

  Effzo [M:BTR1]
  Effzo [M:BTR2]

  If CHGPAG > 0
      SUITE=1
      If CHGPAG = 1
          RETOUR = 1
      Elsif CHGPAG = 2
          RETOUR = 2
      Endif

      Filter [BPL] Where evalue(CRITERE)  Order By Key BPL1 Asc
  Else
      RETOUR=1
      If CHGPAG = -1
          SUITE = 1
      Else
          SUITE = 2
      Endif

      Filter [F:BPL] Where evalue(CRITERE) Order By Key BPL1 Asc
  Endif
  If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:BTR1]NBLIG : Endif

  For [F:BPL] With Nohint
    If GUSRFCY(1) = "\" | find([F:BPL]FCY, GUSRFCY(1..GNBAUZ))
      Gosub DET_LEVEL
      If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
          Break
      Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
          Break
      Endif
    Endif
  Next

Return

######################################################################################
$LOAD_FILTER
    Raz CRITERE, ICRIT
    Call LECTURE("CPY",[M:BTR0]CPY,"") From CONTOBJ
    GRP=([F:CPY]CPYLEGFLG=1)

    Call ADDCRIT(CRITERE,ICRIT,"CNSUSR",'[F:BPL]CNSUSR="'+GUSER+'"'," & ") From GOBJSUB
    # Company/Site
    If !GRP
        If [M:BTR0]CPY<>""
            Call ADDCRIT(CRITERE,ICRIT,"CPY",'[F:BPL]CPY="'+[M:BTR0]CPY+'"'," & ") From GOBJSUB
        Endif
        If [M:BTR0]FCY<>""
            Call ADDCRIT(CRITERE,ICRIT,"FCY",'[F:BPL]FCY="'+[M:BTR0]FCY+'"'," & ") From GOBJSUB
        Endif
    Else
      For [FGR]FGR0 Where CPY = [M:BTR0]CPY
        Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
        NBSITE+=1
        TSITE(NBSITE) = [F:FGR]FCY
      Next
        # Site group
      Call ADDCRIT(CRITERE,ICRIT,"FCY",'find([F:BPL]FCY,TSITE(1..NBSITE))'," & ") From GOBJSUB
    Endif

    # Site autorization
    If GUSRFCY(1)<>"\" & ([M:BTR0]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
        Call ADDCRIT(CRITERE,ICRIT,"FCY",'find([F:BPL]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
    Endif

    # Bank range
    If [M:BTR0]GRPBAN<>""
        Call ADDCRIT(CRITERE, ICRIT,"GRPBAN",'[F:BPL]GRPBAN>="'+[M:BTR0]GRPBAN+'"'," & ") From GOBJSUB
    Endif
    If [M:BTR0]BANK<>""
        Call ADDCRIT(CRITERE, ICRIT,"BANK",'[F:BPL]BAN<="'+[M:BTR0]BANK+'"'," & ") From GOBJSUB
    Endif

    # Date range
    If [M:BTR0]INIDAT<>[0/0/0]
        Call ADDCRIT(CRITERE, ICRIT,"INIDAT",'[F:BPL]DUDDAT>=['+format$(GFMD,[M:BTR0]INIDAT-1)+']'," & ") From GOBJSUB
    Endif
    If [M:BTR0]ENDDAT<>[0/0/0]
        Call ADDCRIT(CRITERE, ICRIT,"ENDDAT",'[F:BPL]DUDDAT<=['+format$(GFMD,[M:BTR0]ENDDAT)+']'," & ") From GOBJSUB
    Endif

    Case CHGPAG
      When 3 : # Update page
        Case [M]LEVELA # SAM 118321
          When 1: AUXLNK =INICPY+INIFRT+INIGRP+INIBAN+INIFCY
          When 2: AUXLNK =INIGRP+INIFRT+INICPY+INIFCY+INIBAN
          When 3: AUXLNK =INIBAN+INIFRT+INICPY+INIFCY+INIGRP
          When 4: AUXLNK =INIFCY+INIFRT+INICPY+INIGRP+INIBAN
        Endcase
        Call ADDCRIT(CRITERE,ICRIT,"INDLNK",'[F:BPL]INDLNK>="'+AUXLNK+'"'," & ") From GOBJSUB
      When 2 : # Next
        Case [M]LEVELA # SAM 118321
          When 1: AUXLNK=FINCPY+FINFRT+FINGRP+FINBAN+FINFCY
          When 2: AUXLNK=FINGRP+FINFRT+FINCPY+FINFCY+FINBAN
          When 3: AUXLNK=FINBAN+FINFRT+FINCPY+FINFCY+FINGRP
          When 4: AUXLNK=FINFCY+FINFRT+FINCPY+FINGRP+FINBAN
        Endcase
        Call ADDCRIT(CRITERE,ICRIT,"INDLNK",'[F:BPL]INDLNK>"'+AUXLNK+'"'," & ") From GOBJSUB
      When -2 : # Previous
        Case [M]LEVELA # SAM 118321
          When 1: AUXLNK =INICPY+INIFRT+INIGRP+INIBAN+INIFCY
          When 2: AUXLNK =INIGRP+INIFRT+INICPY+INIFCY+INIBAN
          When 3: AUXLNK =INIBAN+INIFRT+INICPY+INIFCY+INIGRP
          When 4: AUXLNK =INIFCY+INIFRT+INICPY+INIGRP+INIBAN
        Endcase
        Call ADDCRIT(CRITERE,ICRIT,"INDLNK",'[F:BPL]INDLNK<"'+AUXLNK+'"'," & ") From GOBJSUB
    Endcase

Return
########################################################
$AP_CHOIX
 Raz CFOTYP
 Actzo [M:BTR0]
Return

$INIT
  If [M:BTR0]CPY<>""
    If [M:BTR0]TYPGAC=2:   CFOTYP ="1" :  Else:  CFOTYP ="0" : Endif #accounting
    If [M:BTR0]TYPDUD=2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #due date
    If [M:BTR0]CFOPQ =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #RFQs
    If [M:BTR0]CFOPC =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #purchasing contract
    If [M:BTR0]CFOPO =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #purchase orders
    If [M:BTR0]CFORN =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #receipts
    If [M:BTR0]CFOSQ =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #quotes
    If [M:BTR0]CFOSO =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #sales orders
    If [M:BTR0]CFOSC =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #sales contract
    If [M:BTR0]CFOCM =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #CRM contract
    If [M:BTR0]CFODN =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #deliveries
    If [M:BTR0]CFOLEA=2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #leasing
    If [M:BTR0]CFOME =2:   CFOTYP+="1" :  Else:  CFOTYP+="0" : Endif #manual forecast

    If [M:BTR0]GRPBAN="" and [M:BTR0]BANK="": Call AVERTIR(mess(45,120,1)+mess(00010,00123,1),OK) From GESECRAN: GERR=1: Return: Endif # bank is mandatory
    If CFOTYP=string$(13,"0"): Call AVERTIR(mess(365,192,1),OK) From GESECRAN :GERR=1: Return: Endif #CFO selection null

    If [M:BTR0]CUR="": DEV=[M:BTR0]CURCPY : Endif
    TYPRAT=[M:BTR0]TYPRAT
    # Other filters
    ##############################
    If [M:CBTR]CUR<>[M:BTR0]CUR
      DEVCUR=[M:CBTR]CUR
      TYPRAT=[M:CBTR]TYPRAT
    Endif
    ################################
    SOC=[M:BTR0]CPY
    SITE=[M:BTR0]FCY
    BANKGR=[M:BTR0]GRPBAN
    BANK=[M:BTR0]BANK
    LEVC=[M:BTR0]LEVELA
    LEVD=[M:BTR0]LEVELD
    DEV= [M:BTR0]CURCPY
    DEVCUR=[M:BTR0]CUR

    Call WRITE_TMP (SOC,SITE,BANKGR,BANK,[M:BTR0]INIDAT,[M:BTR0]ENDDAT,LEVC,LEVD,[M:BTR0]PERCOD,DEV,DEVCUR,TYPRAT,CFOTYP,IMP) From BTRRPT

    Raz GCOLDES
    Gosub INIT_PERIOD

    Raz [M:BTR1]
    Raz [M:BTR2]
    Actzo [M:BTR1]
    Actzo [M:BTR2]
  Endif
Return

$DET_LEVEL
    If NBLU = 1
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:BTR1] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0
      If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
      NOL    += 1
      If NOL=0
        INICPY     = [F:BPL]CPY
        INIFCY     = [F:BPL]FCY
        INIGRP     = [F:BPL]GRPBAN
        INIBAN     = [F:BPL]BAN
        INIFRT     = [F:BPL]TYPFRT
        INIDUDDAT  = [F:BPL]DUDDAT
      Endif
      FINCPY     = [F:BPL]CPY
      FINFCY     = [F:BPL]FCY
      FINGRP     = [F:BPL]GRPBAN
      FINBAN     = [F:BPL]BAN
      FINFRT     = [F:BPL]TYPFRT
      FINDUDDAT  = [F:BPL]DUDDAT
    Else
      If NOL <= 0 : RETOUR=2 : Return : Endif
        NOL    -= 1
        If NOL=MAXLIG-1
          FINCPY     = [F:BPL]CPY
          FINFCY     = [F:BPL]FCY
          FINGRP     = [F:BPL]GRPBAN
          FINBAN     = [F:BPL]BAN
          FINFRT     = [F:BPL]TYPFRT
          FINDUDDAT  = [F:BPL]DUDDAT
        Endif
        INICPY     = [F:BPL]CPY
        INIFCY     = [F:BPL]FCY
        INIGRP     = [F:BPL]GRPBAN
        INIBAN     = [F:BPL]BAN
        INIFRT     = [F:BPL]TYPFRT
        INIDUDDAT  = [F:BPL]DUDDAT
      Endif

  # Operations by group
      Local Integer K, NL, L, LEV

      Case [M]LEVELD
        When 1: Gosub LEV_TOT
        When 2: Gosub LEV_CFO
        When 3: Gosub LEV_DOC
      Endcase
  Return

$LEV_TOT
  Local Integer OK
  Raz OK

  If [F:BPL]TYPFRT="*BA": OK=1 :[F:BPL]TYPFRT=mess(200,121,1): Endif
  If [F:BPL]TYPFRT="*BB": OK=1 :[F:BPL]TYPFRT=mess(195,121,1): Endif
  If [F:BPL]TYPFRT="*DA": OK=1 :[F:BPL]TYPFRT=mess(065,116,1): Endif

  Gosub ADD_TYPLINE

Return

$LEV_CFO
  Local Integer OK
  Raz OK

  If [F:BPL]TYPFRT="*BA": OK=1 :[F:BPL]TYPFRT=mess(200,121,1): Endif
  If [F:BPL]TYPFRT="*BB": OK=1 :[F:BPL]TYPFRT=mess(195,121,1): Endif
  If [F:BPL]TYPFRT="*DA": OK=1 :[F:BPL]TYPFRT=mess(065,116,1): Endif

  If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA" & OK=0
    If [F:BPL]TYPFRT="*CM0"  : [F:BPL]TYPFRT=mess(199,121,1): Endif
    If [F:BPL]TYPFRT<"*CM20" : [F:BPL]TYPFRT=mess(val(right$([F:BPL]TYPFRT,4)),3636,1): Endif
    If [F:BPL]TYPFRT>="*CM20" and [F:BPL]TYPFRT<"*CM99": [F:BPL]TYPFRT=mess(201,121,1)   :  Endif
    Raz [F:BPL]DUDDAT
  Endif

  Gosub ADD_TYPLINE

Return

$LEV_DOC
  Local Integer OK
  Raz OK
  If [F:BPL]TYPFRT="*BA" : OK=1: [F:BPL]TYPFRT=mess(200,121,1): Endif
  If [F:BPL]TYPFRT="*BB" : OK=1: [F:BPL]TYPFRT=mess(195,121,1): Endif
  If [F:BPL]TYPFRT="*DA" : OK=1: [F:BPL]TYPFRT=mess(065,116,1): Endif
  If [F:BPL]TYPFRT="*CM0": [F:BPL]TYPFRT=mess(199,121,1): Endif
  If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA": [F:BPL]TYPFRT=mid$([F:BPL]TYPFRT,4,25): Endif

  Gosub ADD_TYPLINE

Return

$ADD_TYPLINE

 Case [M]LEVELA
    When 1:
      If [M]LEVELD=1
        If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA" & OK=0: [F:BPL]TYPFRT=mess(91,105,1) : Raz [F:BPL]DUDDAT   : Endif
      Endif
      K=find([F:BPL]CPY,[M:BTR1]CPY())
      If K=0: NL=[M:BTR1]NBLIG :  Endif
      If K>0
        If [F:BPL]TYPFRT=[M:BTR1]TYPFRT(K-1): NL=K-1
        Else
            WOKK=0
            For I=K To [M:BTR1]NBLIG
              If [F:BPL]CPY=[M:BTR1]CPY(I-1) and [F:BPL]TYPFRT=[M:BTR1]TYPFRT(I-1): NL=I-1 : WOKK=1 : Break :Endif
            Next
            If !WOKK: NL=[M:BTR1]NBLIG: Endif
        Endif
      Endif
      Raz WOKK
      Gosub LEVEL1
    When 2:
      If [M]LEVELD=1
        If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA" & OK=0: [F:BPL]TYPFRT=mess(91,105,1) : Raz [F:BPL]DUDDAT   : Endif
      Endif
      K=find([F:BPL]GRPBAN,[M:BTR1]GRPBAN())
      If K=0: NL=[M:BTR1]NBLIG :  Endif
      If K>0
        If [F:BPL]TYPFRT=[M:BTR1]TYPFRT(K-1): NL=K-1
        Else
            WOKK=0
            For I=K To [M:BTR1]NBLIG
              If [F:BPL]GRPBAN=[M:BTR1]GRPBAN(I-1) and [F:BPL]TYPFRT=[M:BTR1]TYPFRT(I-1): NL=I-1 : WOKK=1 : Break :Endif
            Next
            If !WOKK: NL=[M:BTR1]NBLIG: Endif
        Endif
      Endif
      Raz WOKK
      Gosub LEVEL2
    When 3:
      If [M]LEVELD=1
        If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA" & OK=0: [F:BPL]TYPFRT=mess(91,105,1) : Raz [F:BPL]DUDDAT   : Endif
      Endif
      K=find([F:BPL]BAN,[M:BTR1]BAN())
      If K=0: NL=[M:BTR1]NBLIG :  Endif
      If K>0

        If [F:BPL]TYPFRT=[M:BTR1]TYPFRT(K-1): NL=K-1
        Else
            WOKK=0
            For I=K To [M:BTR1]NBLIG
              If [M]LEVELD=1
                If [F:BPL]CPY=[M:BTR1]CPY(I-1) and [F:BPL]TYPFRT=[M:BTR1]TYPFRT(I-1): NL=I-1 : WOKK=1 : Break :Endif
              Else
                If [F:BPL]BAN=[M:BTR1]BAN(I-1) and [F:BPL]TYPFRT=[M:BTR1]TYPFRT(I-1): NL=I-1 : WOKK=1 : Break :Endif
              Endif
            Next
            If !WOKK: NL=[M:BTR1]NBLIG: Endif
        Endif
      Endif
      Raz WOKK
      Gosub LEVEL3
    When 4:
      If [M]LEVELD=1
        If [F:BPL]TYPFRT>"*BB" & [F:BPL]TYPFRT<"*DA" & OK=0: [F:BPL]TYPFRT=mess(91,105,1) : Raz [F:BPL]DUDDAT   : Endif
      Endif
      K=find([F:BPL]FCY,[M:BTR1]FCY())
      If K=0: NL=[M:BTR1]NBLIG: Endif
       If K>0
        If [F:BPL]TYPFRT=[M:BTR1]TYPFRT(K-1): NL=K-1
        Else
            WOKK=0
            For I=K To [M:BTR1]NBLIG
              If [F:BPL]FCY=[M:BTR1]FCY(I-1) and [F:BPL]TYPFRT=[M:BTR1]TYPFRT(I-1): NL=I-1 : WOKK=1 : Break :Endif
            Next
            If !WOKK: NL=[M:BTR1]NBLIG: Endif
        Endif
      Endif
      Raz WOKK
      Gosub LEVEL4
  Endcase

 If NL>= [M:BTR1]NBLIG: [M:BTR1]NBLIG+=1: Endif
 NOL= [M:BTR1]NBLIG-1
 Actzo [M:BTR1]

Return

$LEVEL1
    [M:BTR1]CPY(NL)      = [F:BPL]CPY
    [M:BTR1]GRPBAN(NL)   = [F:BPL]GRPBAN
    [M:BTR1]BAN(NL)     = [F:BPL]BAN
    [M:BTR1]TYPFRT(NL)   = [F:BPL]TYPFRT
    If OK<>1
      [M:BTR1]DUDDAT(NL)   = [F:BPL]DUDDAT
    Else: Raz [M:BTR1]DUDDAT(NL)
    Endif
    Gosub AMTCUR_SUM
    LEV=1
Return

$LEVEL2
    [M:BTR1]GRPBAN(NL)   = [F:BPL]GRPBAN
    [M:BTR1]BAN(NL)     = [F:BPL]BAN
    [M:BTR1]TYPFRT(NL)   = [F:BPL]TYPFRT
    If OK<>1
      [M:BTR1]DUDDAT(NL)   = [F:BPL]DUDDAT
    Else: Raz [M:BTR1]DUDDAT(NL)
    Endif
    Gosub AMTCUR_SUM
    LEV=2

Return

$LEVEL3
    [M:BTR1]BAN(NL)      = [F:BPL]BAN
    [M:BTR1]GRPBAN(NL)   = [F:BPL]GRPBAN
    [M:BTR1]TYPFRT(NL)   = [F:BPL]TYPFRT
    If OK<>1
      [M:BTR1]DUDDAT(NL)   = [F:BPL]DUDDAT
    Else: Raz [M:BTR1]DUDDAT(NL)
    Endif
    Gosub AMTCUR_SUM
    LEV=3

Return

$LEVEL4
    [M:BTR1]GRPBAN(NL)   = [F:BPL]GRPBAN
    [M:BTR1]FCY(NL)      = [F:BPL]FCY
    [M:BTR1]TYPFRT(NL)   = [F:BPL]TYPFRT
    [M:BTR1]BAN(NL)      = [F:BPL]BAN
    If OK<>1
      [M:BTR1]DUDDAT(NL)   = [F:BPL]DUDDAT
    Else: Raz [M:BTR1]DUDDAT(NL)
    Endif
    Gosub AMTCUR_SUM
    LEV=4
Return

$AMTCUR_SUM
    [M:BTR1]AMTCUR1(NL) += [F:BPL]AMTCUR(0)
    [M:BTR1]AMTCUR2(NL) += [F:BPL]AMTCUR(1)
    [M:BTR1]AMTCUR3(NL) += [F:BPL]AMTCUR(2)
    [M:BTR1]AMTCUR4(NL) += [F:BPL]AMTCUR(3)
    [M:BTR1]AMTCUR5(NL) += [F:BPL]AMTCUR(4)
    [M:BTR1]AMTCUR6(NL) += [F:BPL]AMTCUR(5)
    [M:BTR1]AMTCUR7(NL) += [F:BPL]AMTCUR(6)
    [M:BTR1]AMTCUR8(NL) += [F:BPL]AMTCUR(7)
    [M:BTR1]AMTCUR9(NL) += [F:BPL]AMTCUR(8)
    [M:BTR1]AMTCUR10(NL)+= [F:BPL]AMTCUR(9)
    [M:BTR1]AMTCUR11(NL)+= [F:BPL]AMTCUR(10)
    [M:BTR1]AMTCUR12(NL)+= [F:BPL]AMTCUR(11)
    [M:BTR1]AMTCUR13(NL)+= [F:BPL]AMTCUR(12)
    [M:BTR1]AMTCUR14(NL)+= [F:BPL]AMTCUR(13)
    [M:BTR1]AMTCUR15(NL)+= [F:BPL]AMTCUR(14)
Return

$INIT_PERIOD
  Local Integer I, J, WOKK
  Local Date DATWEEK
  Raz GCOLDES, DATWEEK,WOKK
  DATWEEK=[M:BTR0]INIDAT
  GCOLDES(0)=mess(7,2,1)  #Previous
  Case [M:BTR0]PERCOD
    When 2:
      [M]ENDDAT=([M]INIDAT+(14*7))-1
        For I=0 To 13
          If week([M:BTR0]INIDAT)+I>week(gdat$(31,12,year([M:BTR0]INIDAT))):
            If WOKK=1
              J+=1
            Else
              WOKK=1: DATWEEK=gdat$(01,01,year([M:BTR0]INIDAT)+1): J=0
            Endif
          Else J=I
          Endif
          GCOLDES(I+1)  =mess(4,47,1)-num$(week(DATWEEK)+J)+"-"+num$(year(DATWEEK))   # Week
        Next
    When 3:
        [M]ENDDAT= eomonth(addmonth([M]INIDAT,11))
        For I=0 To 11
          GCOLDES(I+1)=  month$(val(mid$(([M:BTR0]INIDAT),5,2))+I)+"-"+num$(year(addmonth([M]INIDAT,I)))
        Next
    When Default:
      [M]ENDDAT=[M]INIDAT+13
        For I=0 To 13
          GCOLDES(I+1)=  day$([M:BTR0]INIDAT+I) - num$(day([M:BTR0]INIDAT+I))
        Next
  Endcase
Return


$AMT_DETAIL
Local Char SOC(GLONCPY)
Local Char    PARMSK(250)(1..20), SAVACT(20)
Global Shortint GNBL

GNBL=nolign-1

If [M:BTR1]CPY(GNBL)<>"": SOC=[M:BTR1]CPY(GNBL) Else SOC=[M:BTR0]CPY: Endif

SAVACT = GACTION : GACTION = "BTRBP"

Call TRAITE_CHAR(SOC,PARMSK,"","SUBBTRBP","BTRBP",4,"BTRBP") From GTRAITE

GACTION = SAVACT

Kill GNBL

Return

##########################################################################
Subprog OTHERCRIT(CFOCR,FILSTA,N)
Value Char CFOCR
Value Integer N
Variable Integer FILSTA
Local Char EXPRESSION (250), CRIT(250)

Onerrgo ERR_EXPRESSION

 Case N
   When 1:
       # ini X3-99809 Banking position filter JUCON 10/07/2018
#     If [M:CBTR]FILBAN <> "" and [M:CBTR]FILBAN <> CFOCR : FILSTA=1                   # Bank
     If [M:CBTR]FILBAN <> "" : FILSTA=1                    # Bank
       EXPRESSION= [M:CBTR]FILBAN
       If (instr(1,EXPRESSION,"=")+instr(1,EXPRESSION,">")+instr(1,EXPRESSION,"<"))=0
         CRIT="BAN='"+EXPRESSION+"'"
       Else
         CRIT=evalue('EXPRESSION')-"& BAN='"+CFOCR+"'"
       Endif
       If !clalev([BAN]): Local File BANK       [BAN]:  Endif
       Filter [BAN] Where evalue(CRIT)
#       Read [BAN]BAN0=CFOCR
       Read [BAN] First
      # End X3-99809 Banking position filter JUCON 10/07/2018
       If !fstat: FILSTA=0: Endif
       Filter [BAN]
     Endif
  When 2:
    If [M:CBTR]FTYPGAC<>"" : FILSTA=1                   # GAC
      EXPRESSION= [M:CBTR]FTYPGAC
      If !clalev([HAE]): Local File GACCENTRY   [HAE]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [HAE] Where evalue(CRIT)
      Read First
      If !fstat: FILSTA=0: Endif
      Filter [HAE]
    Endif
  When 3:
    If [M:CBTR]FTYPDUD<>"" : FILSTA=1                   # DUD
      EXPRESSION= [M:CBTR]FTYPDUD
      If !clalev([DUD]): Local File GACCDUDATE  [DUD]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [DUD] Where evalue(CRIT)
      Read First
      If !fstat: FILSTA=0: Endif
      Filter [DUD]
    Endif
    If [M:CBTR]FILBPR<>"" : FILSTA=1                    # BPR
      If !clalev([BPR])   : Local File BPARTNER    [BPR]  :  Endif
      EXPRESSION= [M:CBTR]FILBPR
      # ini X3-99809 Banking position filter JUCON 10/07/2018
      If (instr(1,EXPRESSION,"=")+instr(1,EXPRESSION,">")+instr(1,EXPRESSION,"<"))=0
        CRIT="BPRNUM='"+EXPRESSION+"'"
      Else
        CRIT=evalue('EXPRESSION')
      Endif
      Filter [BPR] Where evalue(CRIT)
     # Read [BPR]BPR0=CFOCR
      For [BPR]
        If !fstat
          If [CFODD]BPR=[BPR]BPRNUM:  FILSTA=0: Break: Endif
        Endif
      Next
      # End X3-99809 Banking position filter JUCON 10/07/2018
      Filter [BPR]
    Endif
    If [M:CBTR]FCFOPQ<>"" : FILSTA=1                    # PQ
      EXPRESSION= [M:CBTR]FCFOPQ
      If !clalev([PSH]): Local File PREQUIS     [PSH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [PSH] Where evalue(CRIT)
      Read [PSH]PSH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [PSH]
    Endif
    If [M:CBTR]FCFOPO<>"" : FILSTA=1                    # PO
      EXPRESSION= [M:CBTR]FCFOPO
      If !clalev([POH]): Local File PORDER      [POH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [POH] Where evalue(CRIT)
      Read [POH]POH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [POH]
    Endif
    If [M:CBTR]FCFOPC<>"" : FILSTA=1                    # PC
      EXPRESSION= [M:CBTR]FCFOPC
      If !clalev([POH]): Local File PORDER      [POH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [POH] Where evalue(CRIT)
      Read [POH]POH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [POH]
    Endif
     If [M:CBTR]FCFORN<>"" : FILSTA=1                    # Receipts
      EXPRESSION= [M:CBTR]FCFORN
      If !clalev([PTH]): Local File PRECEIPT    [PTH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [PTH] Where evalue(CRIT)
      Read [PTH]PTH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [PTH]
    Endif
    If [M:CBTR]FCFOSQ<>"" : FILSTA=1                    # Quotes
      EXPRESSION= [M:CBTR]FCFOSQ
      If !clalev([SQH]): Local File SQUOTE      [SQH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [SQH] Where evalue(CRIT)
      Read [SQH]SQH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [SQH]
    Endif
    If [M:CBTR]FCFOSO<>"" : FILSTA=1                    # SO
      EXPRESSION= [M:CBTR]FCFOSO
      If !clalev([SOH]): Local File SORDER      [SOH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [SOH] Where evalue(CRIT)
      Read [SOH]SOH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [SOH]
    Endif
    If [M:CBTR]FCFOSC<>"" : FILSTA=1                    # SC
      EXPRESSION= [M:CBTR]FCFOSC
      If !clalev([SOH]): Local File SORDER      [SOH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [SOH] Where evalue(CRIT)
      Read [SOH]SOH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [SOH]
    Endif
    If [M:CBTR]FCFODN<>"" : FILSTA=1                    # Deliveries
      EXPRESSION= [M:CBTR]FCFODN
      If !clalev([SDH]): Local File SDELIVERY   [SDH]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [SDH] Where evalue(CRIT)
      Read [SDH]SDH0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [SDH]
    Endif
    If [M:CBTR]FCFOCM<>"" : FILSTA=1                    # CRM
      EXPRESSION= [M:CBTR]FCFOCM
      If !clalev([CON]): Local File CONTSERV     [CON]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [CON] Where evalue(CRIT)
      Read [CON]CON0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [CON]
    Endif
    If [M:CBTR]FCFOLEA<>"": FILSTA=1                    # Leasing
      EXPRESSION= [M:CBTR]FCFOLEA
      If !clalev([LEA]): Local File LEASE       [LEA]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [LEA] Where evalue(CRIT)
      Read [LEA]LEA0=CFOCR
      If !fstat: FILSTA=0: Endif
      Filter [LEA]
    Endif
    If [M:CBTR]FCFOME<>"" : FILSTA=1                    # Manual
      EXPRESSION= [M:CBTR]FCFOME
      If !clalev([CFOMM]): Local File CFOMANMVT [CFOMM]:  Endif
      CRIT=evalue('EXPRESSION')
      Filter [CFOMM] Where evalue(CRIT)
      Read First
      If !fstat: FILSTA=0: Endif
      Filter [CFOMM]
    Endif
 Endcase
End


$ERR_EXPRESSION
GMESSAGE=mess(33,100,1)
mkstat=2
Resume


Subprog CRIT_CONTROL(MSKFLD,ABR,LNG,STAT)
Value Char MSKFLD,ABR
Value Shortint LNG
Variable Shortint STAT
Local Char CAR(1)
Raz STAT

For I=4 To LNG
  CAR=mid$(MSKFLD,I,I+1)
  If CAR="]" and mid$(MSKFLD,I-3,3)<>ABR: STAT=1: Break: Endif
Next
End

######################################################################################
## Section automatically added (screen CONSBTR) 09/18/2013 12:25:06 (JUCON)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>""
    [M]CPY=VALEUR
    Raz [M]GRPBAN, BANK
    Actzo [M]GRPBAN, BANK
    Read [CPY]CPY0=[M]CPY
    If !fstat
      If [F:CPY]ACCCUR<>""
        [M]CURCPY =[F:CPY]ACCCUR
        [M]CUR    =[F:CPY]ACCCUR
      Else
        Call PARAM(VALEUR,"CURSHRFLD",[M]CURCPY) From ADOVAL
        If [M]CURCPY<>"": [M]CUR=[M]CURCPY
        Else [M]CURCPY=GSYSCUR: [M]CUR=[M]CURCPY
        Endif
      Endif
      If [M]INIDAT=[00/00/00]
        [M]INIDAT=date$
      Endif
      Case [M:BTR0]PERCOD
        When 1: [M]ENDDAT=[M]INIDAT+14
        When 2: [M]ENDDAT=[M]INIDAT+(14*7)
        When 3: [M]ENDDAT=addmonth([M]INIDAT,12)
      Endcase
      Affzo [M]INIDAT, ENDDAT
    Else
      Raz [M]FCY
    Endif
    Affzo [M]FCY, GRPBAN, BANK, CUR, ENDDAT
  Endif

End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>""
    Read [FCY]FCY0=VALEUR
    If !fstat
      If [F:FCY]FINFLG=2
        [M]CPY=[F:FCY]LEGCPY
        Read [CPY]CPY0=[M]CPY
        If !fstat
          [M]CURCPY =[F:CPY]ACCCUR
          [M]CUR    =[F:CPY]ACCCUR
        Endif
      Else
        GMESSAGE=mess(13,122,1)   : mkstat=2
      Endif
    Endif
    Affzo [M]CPY, CUR
  Endif
End

Subprog C_INIDAT(VALEUR)
Variable Date    VALEUR
 # Call C_DATDEB(VALEUR) From CONSSUB
End

Subprog AM_INIDAT(VALEUR)
Variable Date    VALEUR
  [M]INIDAT=VALEUR
  Gosub INIT_PERIOD
  Affzo [M]INIDAT, ENDDAT
End

Subprog AM_GRPBAN(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>""
    Raz [M:BTR0]BANK: Grizo [M:BTR0]BANK
  Else
    Actzo [M:BTR0]BANK
  Endif

End

Subprog C_GRPBAN(VALEUR)
Variable Char    VALEUR()
Local Integer I, WOKK

  If VALEUR<>""
    Read [BGR]BGR0=VALEUR
    If !fstat:
      Raz WOKK
      For I=0 To dim([F:BGR]BAN)-1
        If [F:BGR]BAN(I)<>""
          Read [BAN]BAN0=[F:BGR]BAN(I)
          If !fstat
             Read [CPY]CPY0= [M]CPY
             If !fstat and [F:CPY]CPYLEGFLG=2
               If [F:BAN]CPY=[M]CPY:  WOKK=1: Break: Endif
             Else
               Read [AGC]AGC0=[M]CPY;[F:BAN]CPY
               If !fstat: WOKK=1: Break: Endif
             Endif
          Endif
        Endif
      Next
    Endif

    If WOKK=0
      GMESSAGE= mess(203,121,1) - [M]CPY
      mkstat=2
    Endif
  Endif

End

Subprog AV_BANK(VALEUR)
Variable Char    VALEUR()

  If [M:BTR0]GRPBAN<>"" : Grizo [M:BTR0]BANK
  Else :Actzo [M:BTR0]BANK
  Endif

End

$S_BAN
  OBJET="BAN"
  Read [CPY]CPY0=[M]CPY
  If !fstat and [F:CPY]CPYLEGFLG=2
    CRITERE = "CPY='"+[M]CPY+"' & CFOEXD<2"
  Endif
Return

Subprog C_BANK(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    Read [BAN]BAN0=VALEUR
    If fstat
      GMESSAGE= mess(13,602,1)-mess(40,9016,1)
      mkstat=2
    Else
      If [F:BAN]CFOEXD=2
       GMESSAGE= mess(192,187,1): mkstat=2
      Else
        Read [CPY]CPY0=[M]CPY
        If !fstat & [F:CPY]CPYLEGFLG=2
          If [F:BAN]CPY<>[M]CPY
            GMESSAGE= mess(1,653,1)-mess(5,117,1)-[F:BAN]CPY
            mkstat=2
          Endif
        Endif
      Endif
    Endif
  Endif
End

Subprog AM_BANK(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    If [M:BTR0]LEVELA=2
      GMESSAGE=mess(37,103,1) +":" -mess(2,3634,1): mkstat=2
    Else
      Raz [M:BTR0]GRPBAN: Grizo [M:BTR0]GRPBAN
      Read [BAN]BAN0=VALEUR
      If !fstat
        Read [CPY]CPY0=[M]CPY
        If !fstat & [F:CPY]CPYLEGFLG=1
          [M]CPY=[F:BAN]CPY
          Affzo [M]CPY
        Endif
      Endif
    Endif
  Else
    Actzo [M:BTR0]GRPBAN
  Endif
End

Subprog AM_LEVELA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2 and [M]GRPBAN=""
    GMESSAGE= mess(2,3634,1)-mess(1101,196,1)
    mkstat=2
  Endif
End

Subprog AM_LEVELD(VALEUR)
Variable Integer VALEUR
  If VALEUR<>[M:BTR0]LEVELD
    [M:BTR0]LEVELD=VALEUR
  Endif
  Affzo [M:BTR0]LEVELD
End

Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
  If VALEUR<>[M]PERCOD
    [M]PERCOD=VALEUR
    Gosub INIT_PERIOD
    Affzo [M:BTR0]INIDAT, ENDDAT
    If [M:BTR1]NBLIG=0: Affzo [M:BTR1]: Endif
  Endif
End
######################################################################################
## Section automatically added (screen CONSBTR1) 10/24/2013 17:17:25 (JUCON)
######################################################################################
Subprog AM_LEVELG(VALEUR)
Variable Integer VALEUR
Local Shortint K, NPER

  GCOLAMT=[M:BTR1]TYPFRT(nolign-1)
  Effzo [M:BTR2]

  If VALEUR<>[M:BTR1]LEVELG(nolign-1)
    K=find(2,[M:BTR1]LEVELG())
    If K<>0: [M:BTR1]LEVELG(K-1)=1 : Affzo [M:BTR1]LEVELG(K-1): Endif
    If VALEUR=2
      If [M:BTR0]PERCOD=1: NPER=14: Else: NPER=12: Endif

      For I=0 To NPER
        [M:BTR2]LIBTOT(I)= GCOLDES(I)
        Case I
          When 0:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR1(nolign-1)
          When 1:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR2(nolign-1)
          When 2:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR3(nolign-1)
          When 3:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR4(nolign-1)
          When 4:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR5(nolign-1)
          When 5:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR6(nolign-1)
          When 6:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR7(nolign-1)
          When 7:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR8(nolign-1)
          When 8:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR9(nolign-1)
          When 9:  [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR10(nolign-1)
          When 10: [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR11(nolign-1)
          When 11: [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR12(nolign-1)
          When 12: [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR13(nolign-1)
          When 13: [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR14(nolign-1)
          When 14: [M:BTR2]AMTTOT(I)=[M:BTR1]AMTCUR15(nolign-1)
        Endcase
        [M:BTR2]NBTOT+=1
      Next
    Else
      Raz [M:BTR2]
    Endif
  Endif

  Affzo [M:BTR2]

End

Subprog AV_TYPFRT(VALEUR)
Variable Char    VALEUR()
Local Shortint OK

  If VALEUR=mess(200,121,1) : Chgstl [M]TYPFRT(nolign-1) With "CFO1" : OK=1: Endif
  If VALEUR=mess(195,121,1) : Chgstl [M]TYPFRT(nolign-1) With "CFO2" : OK=1: Endif
  If VALEUR=mess(65,116,1)  : Chgstl [M]TYPFRT(nolign-1) With "CFO3" : OK=1: Endif

#  If VALEUR=mess(200,121,1) : pcolor=GCOUL(3): OK=1: Endif
#  If VALEUR=mess(195,121,1) : pcolor=GCOUL(2): OK=1: Endif
#  If VALEUR=mess(65,116,1)  : pcolor=GCOUL(1): OK=1: Endif
#  If OK=0: pcolor=GCOUL(0): Endif

End

