Subprog C_FILBPR(VALEUR)
Variable Char    VALEUR()
Local Char ABR(5),MSKFLD(250)
Local Shortint LNG,STAT
ABR="BPR"
MSKFLD=toupper(VALEUR)
LNG=len(VALEUR)
Call CRIT_CONTROL(MSKFLD,ABR,LNG,STAT)
If STAT=1
  GMESSAGE=mess(33,100,1)
  mkstat=2
Endif
End

