#<AdxTL>@(#)6.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Fonction : REQAPP - Soumission pour approbation
#   Action   : REQAPP
#   Fenêtre  : REQAPP
#   Ecran concerné : BOAR
#   Description : Fonction de demande de soumission. Selection des objets
#                 concernés par société/site.
#
#--------------------------------------------------------------------------

Local Char PARAM(10)(1..5) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"REQAPP","SUBBOAR","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_OK"     : Gosub AVANT_OK
 When "OK"           : Gosub OK
 When Default
Endcase
Return

$OUVRE
#Recup du parametrage du niveau d'approbation
Global Char GAPPNIV(3)

#Entité de l'utilisateur courant (GUSER)
Global Char GENTUSR

#Paramétrage des niveaux d'approbation autorisés de l'utilisateur
Global Integer GAPPUSRENV,GAPPUSRBUD,GAPPUSRLIG
Local Char PARAPPENV,PARAPPBUD,PARAPPLIG

#Paramètre de bébrayage du circuit d'appro (ligne) en fonction de l'utilisateur
Global Integer GDEBAPP
Local Char PARDEBAPP
Call PARAMUTIL("GDDENTUSR",GENTUSR,"","") From SUBAUS
Call PARAMUTIL("USRAPPENV",PARAPPENV,"","") From SUBAUS
Call PARAMUTIL("USRAPPBUD",PARAPPBUD,"","") From SUBAUS
Call PARAMUTIL("USRAPPLIG",PARAPPLIG,"","") From SUBAUS
Call PARAMUTIL("GDDDEBAPP",PARDEBAPP,"","") From SUBAUS
GAPPUSRENV=val(PARAPPENV)
GAPPUSRBUD=val(PARAPPBUD)
GAPPUSRLIG=val(PARAPPLIG)
GDEBAPP=val(PARDEBAPP)

#Tables utiles
If !clalev([AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([LED]) : Local File GLED       [LED] : Endif
If !clalev([GCM]) : Local File GACM       [GCM] : Endif
If !clalev([CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([ACC]) : Local File ACCES      [ACC] : Endif
If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([TCA]) : Local File TABCOUAFF  [TCA] : Endif
#Masque
Local Mask BOAR
#Variables locales
Local Integer STAT
Local Char NUMAPP
Local Char APPCPT(GLONANM)
Return

$SETBOUT
Return

$DEBUT
Raz [M:BOAR]
Return

$AVANT_OK
Local Integer OK,COCHE : COCHE=0
For I=0 To [M]NBLIG-1
 If [M]SOU(I)=2
  COCHE=1 : Break
 Endif
Next
If !COCHE
 #Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Endif
Return

$OK
If [M]NBLIG<=0 : End : Endif
Local Char LISTENVAPP(GLONENV)(1..[M]NBLIG)
Local Char LISTAPPMUL(GLONENV)(1..[M]NBLIG)
Local Char ENVCUR(GLONENV)
Local Integer INDENV, INDENT, INDCCE3

#Etablissement de la liste des enveloppes dont au moins un objet et soumis à approbation
K=1 : P=1

For J=0 To [M]NBLIG-1
 If [M]SOU(J)=2
  If !find([M]ENV(J),LISTENVAPP(1..[M]NBLIG))
   LISTENVAPP(K)=[M]ENV(J)
   ENVCUR=[M]ENV(J)
   K+=1
  Endif
 Endif
Next

If [M]NBLIG>1
 Local Integer X, NB
 X=1
 While X<=dim(LISTENVAPP) & LISTENVAPP(X)<>""
  NB=0
  For I=0 To [M]NBLIG-1
   If [M]SOU(I)=2 & [M]ENV(I)=LISTENVAPP(X) : NB+=1 : Endif
  Next
  If NB>1
   LISTAPPMUL(P)=LISTENVAPP(X)
   P+=1
  Endif
  X+=1
 Wend
Endif

Local Char ALREADY_DONE(GLONENV)(1..[M]NBLIG)
Local Integer Q : Q=1
Local Integer NIVEAU

Call DEBTRANS From GLOCK
Gosub TR_OK
Return

$TR_OK
GOK=1
Trbegin [BOA],[BAD]

 #Gestion du statut des objets / Passage au statut 'A approuver'
 For I=0 To [M]NBLIG-1
  If [M]SOU(I)=2
   Call LECTURE("ENV",[M]ENV(I),"") From CONTOBJ
   Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
   Case [M]NIV(I)
    When 1 :#Enveloppe
     Gosub $CHG_STA_ENV_AND_CO
     If GOK<1 : Break : Endif
    When 2
     Gosub $CHG_STA_BUD_AND_CO
     If GOK<1 : Break : Endif
    When 3
     Gosub $CHG_STA_LIG
     If GOK<1 : Break : Endif
   Endcase
  Endif
 Next

 If GOK<0 : Goto ROLL_TR_OK
 Elsif !GOK : Goto AB_TR_OK
 Endif

 For I=0 To [M]NBLIG-1
  If [M]SOU(I)=2
   If !find([M]ENV(I),LISTAPPMUL(1..[M]NBLIG))
    NIVEAU=[M]NIV(I)
    Gosub CRE_APPRO
   Elsif !find([M]ENV(I),ALREADY_DONE(1..[M]NBLIG))
    ALREADY_DONE(Q)=[M]ENV(I)
    Q+=1
    NIVEAU=4
    Gosub CRE_APPRO
   Endif
  Endif
  If GOK<1 : Break : Endif
 Next I

 If GOK<1 : Goto AB_TR_OK : Endif

Commit
Return

$AB_TR_OK
Rollback
Return

$ROLL_TR_OK
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_OK : Endif

$CRE_APPRO
#Lecture affectation compteur
Read [TCA]TCA0 = 2;[M]CPY
If !fstat
 APPCPT = [F:TCA]CODNUM(9)
Endif
If APPCPT=""
 Read [TCA]TCA0 = 2;""
 If !fstat
  APPCPT = [F:TCA]CODNUM(9)
 Endif
Endif
Call NUMERO(APPCPT,[M:BOAR]FCY,date$,"",[L]NUMAPP,STAT) From SUBANM
If [L]NUMAPP=""
 #Anomalie au niveau du compteur, vérifiez l'affectation.
 GMESSAGE=mess(236,108,1)
 mkstat=2
 GOK=0
 Return
Endif

[F:BOA]NUM    = [L]NUMAPP
[F:BOA]TYP    = NIVEAU
[F:BOA]ENV    = [M]ENV(I)
[F:BOA]PRJ    = [M]PRJ(I)
[F:BOA]FIY    = [M]FIY(I)
[F:BOA]CUR    = [M]CUR(I)
If NIVEAU=4
 #Création des éléments dans BUDAPPDET
 L=0
 For J=0 To [M]NBLIG
  If [M]ENV(J)=[M]ENV(I) & [M]SOU(J)=2
   L+=1
   [F:BAD]NUMERO = L
   [F:BAD]NUMAPP = [L]NUMAPP
   [F:BAD]TYP    = [M]NIV(J)
   [F:BAD]ENV    = [M]ENV(J)
   [F:BAD]FIY    = [M]FIY(J)
   [F:BAD]ACCNUM = [M]ACCNUM(J)
   [F:BAD]ACC    = [M]ACC(J)
   [F:BAD]COA    = [M]COA(J)
   [F:BAD]AMT    = [M]AMT(J)
   [F:BAD]CUR    = [M]CUR(J)
   Write [BAD]
   If fstat
    GOK=0 : Call FSTA("BAD") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Else
 [F:BOA]AMT    = [M]AMT(I)
Endif

[F:BOA]ACCNUM = [M]ACCNUM(I)
[F:BOA]ACC    = [M]ACC(I)
[F:BOA]COA    = [M]COA(I)
[F:BOA]STA    = 2
[F:BOA]DMDDAT = date$
[F:BOA]CREDAT = date$
[F:BOA]CREUSR = GUSER
Write [BOA]
If fstat
 GOK=0 : Call FSTA("BOA") From GLOCK  : Return
Endif
Call WORKFLOW(1,"APP","","") From AWRK
Return


$CHG_STA_ENV_AND_CO
Readlock [ENV]ENV0 = [M]ENV(I)
If fstat=1
 GOK=-1 : GLOCK="$ENVELOPPE"-[M]ENV(I) : Return
Elsif fstat
 GOK=0 : Call FSTA("ENV") From GLOCK : Return
Elsif !fstat & [F:ENV]STA=1
 [F:ENV]STA=2
 Call FLDUPD("ENV") From OBJDIV
 Rewrite [ENV]
 If fstat
  GOK=0 : Call FSTA("ENV") From GLOCK : Return
 Endif
Endif

#Passage du status des budgets et des lignes budgétaires à "à approuver" selon le paramètrage
If [M]APPNIV="212" | [M]APPNIV="211"
 For [ENF]ENF0 Where ENV=[M]ENV(I) & STAFIY=1
  Readlock [ENF]ENF0=[F:ENF]ENV;[F:ENF]FIYNUM
  If fstat=1
   GOK=-1 : GLOCK="$ENVFIY"-[F:ENF]ENV-num$([F:ENF]FIYNUM) : Break
  Elsif fstat
   GOK=0 : Call FSTA("ENF") From GLOCK : Break
  Else
   [F:ENF]STAFIY=2
   Call FLDUPD("ENF") From OBJDIV
   Rewrite [ENF]
   If fstat
    GOK=0 : Call FSTA("ENF") From GLOCK : Break
   Endif
  Endif

  If [M]APPNIV="211"
   For [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(I) & FIY=[F:ENF]FIYNUM & STA=1
    Readlock [BUD]BUD1=[F:BUD]ACCNUM
    If fstat=1
     GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM : Break 2
    Elsif fstat
     GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
    Else
     [F:BUD]STA=2
     Call FLDUPD("BUD") From OBJDIV
     Rewrite [BUD]
     If fstat
      GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
     Endif
    Endif
   Next
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return

$CHG_STA_BUD_AND_CO
#Passage du status du budget exercice à "à approuver"
Readlock [ENF]ENF0 = [M]ENV(I);[M]FIY(I)
If fstat=1
 GOK=-1 : GLOCK="$ENVFIY"-[M]ENV(I)-num$([M]FIY(I)) : Return
Elsif fstat
 GOK=0 : Call FSTA("ENF") From GLOCK : Return
Elsif !fstat & [F:ENF]STAFIY=1
 [F:ENF]STAFIY=2
 Call FLDUPD("ENF") From OBJDIV
 Rewrite [ENF]
 If fstat
  GOK=0 : Call FSTA("ENF") From GLOCK : Return
 Endif
Endif

#Passage du status de la ligne budgétaire à "à approuver" selon le paramètrage
If [M]APPNIV="121" | [M]APPNIV="221"
 For [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(I) & FIY=[M]FIY(I) & STA=1
  Readlock [BUD]BUD1=[F:BUD]ACCNUM
  If fstat=1
   GOK=-1 : GLOCK="$BUD"-num$([F:BUD]ACCNUM) : Break
  Elsif fstat
   GOK=0 : Call FSTA("BUD") From GLOCK : Break
  Else
   [F:BUD]STA=2
   Call FLDUPD("BUD") From OBJDIV
   Rewrite [BUD]
   If fstat
    GOK=0 : Call FSTA("BUD") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return

$CHG_STA_LIG
#Passage du status de la ligne budgétaire à "à approuver"
Readlock [BUD]BUD1=[M]ACCNUM(I)
If fstat=1
 GOK=-1 : GLOCK="$BUD"-num$([M]ACCNUM(I)) : Return
Elsif fstat
 GOK=0 : Call FSTA("BUD") From GLOCK : Return
Elsif !fstat & [F:BUD]STA=1
 [F:BUD]STA=2
 Call FLDUPD("BUD") From OBJDIV
 Rewrite [BUD]
 If fstat
  GOK=0 : Call FSTA("BUD") From GLOCK : Return
 Endif
Endif
Return

######################################################################################

Subprog C_CFY(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC, ISITE
Raz [M]FCY
ISOC   = find(VALEUR,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 [M]FCY=VALEUR
 Call CONTFCY(VALEUR) From CPTSUB
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Else
 Call CONTCPY(VALEUR) From CPTSUB
Endif
[M]CPY=GSOC(ISOC)
Call SETGLBAPP(GSOC(ISOC),GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
Affzo [M]
End

Subprog AM_CFY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CFY=VALEUR
 Raz [M]CRIPRJ
 Raz [M]ENTMSTR,ENTMEND
 Raz [M]ENTASTR,ENTAEND
 Raz [M]ENVSTR,ENVEND
 Raz [M]NBLIG
 Affzo [M]
Endif
End

Subprog AS_CRIDATSTR(VALEUR)
Variable Date    VALEUR
If [M]CFY<>""
 Call DATDEFSOC([M]CPY,VALEUR,[M]CRIDATEND) From CONSSUB
Endif
End

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CFY<>""
 Gosub CHARGEMENT
Endif
End

Subprog C_CRIPRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call LECACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End


Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
Endif
End

Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif
Endif
End


#--------------------------------------------------------------------------------------------#

$CHARGEMENT
Local Integer OKBOA, I : I=0
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char INTENV(30)
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3

CTLACS = 1

Raz [M]NBLIG

Local Integer SOC,J
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
SOC=find([M]CFY,GSOC(1..GNBSOC))
J=1
If SOC
 For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
  LISTFCY(J)=[F:FCY]FCY
  J+=1
 Next
Endif

Local Char CRITENV(250)
CRITENV="1=1"
CRITENV-= '& (FCY="'+[M]CFY+'" | find(FCY,LISTFCY(1..J)))'

If [M]CRIPRJ<>""
 CRITENV -='& PRJ="'+[M]CRIPRJ+'"'
Endif
If [M]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M]ENTMSTR+'" & ENTMNA<="'+[M]ENTMEND+'"'
Endif
If [M]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M]ENTASTR+'" & ENTAPP<="'+[M]ENTAEND+'"'
Endif
If [M]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif
If [M]CRIDATSTR<>[0/0/0] & [M]CRIDATEND<>[0/0/0]
 CRITENV -='& REASTR<=['+format$(GFMD,[M]CRIDATEND)+'] & REAEND>=['+format$(GFMD,[M]CRIDATSTR)+']'
Endif

For [ENV]ENV0 Where evalue(CRITENV)
 #Si une approbation est en cours sur l'enveloppe, on n'affiche pas celle-ci
 OKBOA=1

 Filter [BOA] Where ENV=[F:ENV]ENV & STA=2
 Look [BOA]BOA0 First
 If !fstat : OKBOA=0 : Endif
 Filter [BOA]

 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif

 If OKACS & OKBOA
  #Pour intitulé exercice
  Call SETMAINREF([F:ENV]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  If (GAPPNIV="211" | GAPPNIV="212" | GAPPNIV="221" | GAPPNIV="222") & [F:ENV]STA=1 & ([F:ENV]AMTENV<>0 | [F:ENV]EXTBUD=2) & GAPPUSRENV=2
   [M]NIV(I)    = 1
   [M]ENV(I)    = [F:ENV]ENV
   [M]CUR(I)    = [F:ENV]CURENV
   [M]AMT(I)    = [F:ENV]AMTENV
   [M]ENVINT(I) = INTENV
   [M]PRJ(I)    = [F:ENV]PRJ
   [M]ENTMNA(I) = [F:ENV]ENTMNA
   [M]SOU(I)    = 1
   Raz [M]FIY(I),[M]INTFIY(I),[M]ENTDEN(I),[M]LOT(I),[M]ACC(I),[M]ACCNUM(I),[M]COA(I)
   I+=1
   #----TB protection----
   If I>dim([M:BOAR]NIV)-1
    #Tableau Plein
    Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
   Endif
   #--------------------
  Endif

  #Les budgets exercices
  For [ENF]ENF0 Where ENV=[F:ENV]ENV
   If (GAPPNIV="121" | GAPPNIV="122" | GAPPNIV="221" | GAPPNIV="222") & [F:ENF]STAFIY=1  & ([F:ENF]AMTBUDFIY<>0 | [F:ENV]EXTBUD=2) & GAPPUSRBUD=2
    If (GAPPNIV="221" | GAPPNIV="222") & [F:ENV]STA<>2
     [M]NIV(I)    = 2
     [M]ENV(I)    = [F:ENF]ENV
     [M]FIY(I)    = [F:ENF]FIYNUM
     [M]INTFIY(I) = num$([F:ENF]FIYNUM)
     Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
     If !fstat
      [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
     Endif
     [M]AMT(I)    = [F:ENF]AMTBUDFIY
     [M]ENVINT(I) = INTENV
     [M]CUR(I)    = [F:ENV]CURENV
     [M]PRJ(I)    = [F:ENV]PRJ
     [M]ENTMNA(I) = [F:ENV]ENTMNA
     [M]SOU(I)    = 1
     Raz [M]ENTDEN(I),[M]LOT(I),[M]ACC(I),[M]ACCNUM(I),[M]COA(I)
     I+=1
     #----TB protection----
     If I>dim([M:BOAR]NIV)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
     Endif
     #--------------------
    Else
     [M]NIV(I)    = 2
     [M]ENV(I)    = [F:ENF]ENV
     [M]FIY(I)    = [F:ENF]FIYNUM
     [M]INTFIY(I) = num$([F:ENF]FIYNUM)
     Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
     If !fstat
      [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
     Endif
     [M]AMT(I)    = [F:ENF]AMTBUDFIY
     [M]ENVINT(I) = INTENV
     [M]CUR(I)    = [F:ENV]CURENV
     [M]PRJ(I)    = [F:ENV]PRJ
     [M]ENTMNA(I) = [F:ENV]ENTMNA
     [M]SOU(I)    = 1
     Raz [M]ENTDEN(I),[M]LOT(I),[M]ACC(I),[M]ACCNUM(I),[M]COA(I)
     I+=1
     #----TB protection----
     If I>dim([M:BOAR]NIV)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
     Endif
     #--------------------
    Endif
   Endif

   #Les Lignes Budgétaires
    For [BUD] Where STA=1 & evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM
    If (GAPPNIV="112" | GAPPNIV="122" | GAPPNIV="212" | GAPPNIV="222") & ([F:BUD]AMT(0)<>0 | [F:ENV]EXTBUD=2) & GAPPUSRLIG=2 | GDEBAPP=2
     If (GAPPNIV="121" | GAPPNIV="222") & ([F:ENF]STAFIY<>2)
      [M]NIV(I)    = 3
      [M]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
      [M]FIY(I)    = [F:BUD]FIY
      [M]INTFIY(I) = num$([F:BUD]FIY)
      Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BUD]FIY
      If !fstat
       [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
      Endif
      [M]ACCNUM(I) = [F:BUD]ACCNUM
      [M]AMT(I)    = [F:BUD]AMT(0)
      [M]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
      [M]ACC(I)    = [F:BUD]ACC
      [M]COA(I)    = [F:BUD]COA
      [M]LOT(I)    = [F:BUD]LOT
      [M]ENVINT(I) = INTENV
      [M]CUR(I)    = [F:ENV]CURENV
      [M]PRJ(I)    = [F:ENV]PRJ
      [M]ENTMNA(I) = [F:ENV]ENTMNA
      [M]SOU(I)    =1
      I+=1
      #----TB protection----
      If I>dim([M:BOAR]NIV)-1
       #Tableau Plein
       Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 3
      Endif
      #--------------------
     Else
      [M]NIV(I)    = 3
      [M]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
      [M]FIY(I)    = [F:BUD]FIY
      [M]INTFIY(I) = num$([F:BUD]FIY)
      Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BUD]FIY
      If !fstat
       [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
      Endif
      [M]ACCNUM(I) = [F:BUD]ACCNUM
      [M]AMT(I)    = [F:BUD]AMT(0)
      [M]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
      [M]ACC(I)    = [F:BUD]ACC
      [M]COA(I)    = [F:BUD]COA
      [M]LOT(I)    = [F:BUD]LOT
      [M]ENVINT(I) = INTENV
      [M]CUR(I)    = [F:ENV]CURENV
      [M]PRJ(I)    = [F:ENV]PRJ
      [M]ENTMNA(I) = [F:ENV]ENTMNA
      [M]SOU(I)    = 1
      I+=1
      #----TB protection----
      If I>dim([M:BOAR]NIV)-1
       #Tableau Plein
       Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 3
      Endif
      #--------------------
     Endif
    Endif
   Next
  Next
 Endif :#OKACS
Next

If I=0
 #Aucun objet ne satisfait ces critères de sélection
 Call MESSAGE(mess(218,108,1)) From GESECRAN
 Return
Endif

[M]NBLIG=I
Affzo [M]
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Gosub COLORIZE
Return

$COLORIZE
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For I=0 To [M]NBLIG-1
 If [M]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(I) With "GDD"+num$(K)
 Else
  Chgstl [M]NBLIG(I) With "GDD"+num$(K)
 Endif
 ENVCUR=[M]ENV(I)
Next
Affzo [M]
Return

#--------------------------------------------------------------------------------------------#

Subprog IB_NBLIG
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
End

Subprog C_SOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 #Selection automatique des objets supérieurs
 Case NIV(nolign-1)
  When 2 : #Budget exercice
   For J=0 To [M]NBLIG-1
    If [M]NIV(J)=1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]SOU(J)<>2
     [M]SOU(J)=2
     Affzo [M] : Break
    Endif
   Next
  When 3 : #Ligne budgétaire
   If GDEBAPP=1
    For J=0 To [M]NBLIG-1
     If [M]NIV(J)<>3 & [M]ENV(J)=[M]ENV(nolign-1) & ([M]FIY(J)=[M]FIY(nolign-1) | [M]FIY(J)=0) & J<>(nolign-1) & [M]SOU(J)<>2
      [M]SOU(J)=2
      Affzo [M]
     Endif
    Next
  Endif
 Endcase
Else
 #Vérif que niveau d'en dessous non sousmis
 Case NIV(nolign-1)
  When 1 : #Enveloppe
   For J=0 To [M]NBLIG-1
    If [M]NIV(J)<>1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]SOU(J)=2
     [M]SOU(J)=1
     Affzo [M]
    Endif
   Next
  When 2 : #Budget exercice
   If GDEBAPP=1
    For J=0 To [M]NBLIG-1
     If [M]NIV(J)=3 & [M]ENV(J)=[M]ENV(nolign-1) & [M]FIY(J)=[M]FIY(nolign-1) & J<>(nolign-1) & [M]SOU(J)=2
      [M]SOU(J)=1
      Affzo [M]
     Endif
    Next
   Endif
 Endcase
Endif
[M]SOU(nolign-1)=VALEUR
Affzo [M]
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]SOU(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
  [M]SOU(I)=COCHE
 Next
 Affzo [M]
Endif
End

