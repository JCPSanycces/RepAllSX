#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char VALEUR(20)
Local Char    PARMSK(250)(1..20) , SAVACT(20)
PARMSK(1) = "ZZFDBT1"
 SAVACT = GACTION : GACTION = "AYUSEL"
 PARMSK(1) = "ZZFDBT1"
 Call S_TAB_CHAR(VALEUR,PARMSK,"ADVSEL","SUBAYUACT","") From GACTION
 GACTION = SAVACT
Infbox VALEUR
End
######################################################################################
## Xtend:  Gestion Paramétrage avancé
## Actions

#  Version 0001
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "SEL_TABLE"        : Gosub SEL_TABLE
 When "FIN_TABLE"        : Gosub FIN_TABLE
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYUSEL        ADVSEL        Sélection d'un paramétre avancé
######################################################################################
$SEL_TABLE
Case TABLE
When "ADVSEL"
      Gosub ADV_SEL
Endcase
Return

$FIN_TABLE
Case TABLE
When "ADVSEL"
      Gosub ADV_FIN
Endcase
Return

#    AYUSEL        ADVSEL        Sélection d'un paramétre avancé
######################################################################################
# VALEUR        Adresse       Clé composite :  [FCyCod]~[ObjTyp]~[ObjCod]
# PARAM    1    Valeur        Site Xtend
#               
$ADV_SEL
#---------------------------------------------------------------#
Local Char FCYWRK(GLONAYG)
[L]FCYWRK= PARAM(1)  # Site 
OBJET ="AYU"
SUPP  = [L]FCYWRK
Return

$ADV_FIN
#---------------------------------------------------------------#
If ([F]OBJTYP<>0 and [F]OBJCOD<>"")
    VALEUR= FCYWRK +"~"+ num$([F]OBJTYP) +"~"+ [F]OBJCOD
Endif
Return
