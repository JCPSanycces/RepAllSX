#<AdxTL>@(#)7.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Local File GACCDUDATE [DUD], PAYMENTH [PYH], PAYMENTD [PYD], TABPAYTYP [TPY]
Local Integer TEST
Local Decimal MTCUR, MTLOC, MTRPT
Local Char MESSA(150)

Call OUVRE_TRACE("Mise à jour des échéances réglées") From LECFIC
Call ECR_TRACE("",0) From GESECRAN

# Variable TEST : prise en compte des mouvements, elle prend 2 valeurs possibles :
# si <>0 : mode test, on fait un Rollback en fin de traitement
# si =0  : mode réel, les mises à jour sont prises en compte
TEST = 1 
Gosub TR

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Close Local File [DUD], [PYH], [PYD]
End

$TR
Trbegin [DUD]
GOK=1
Filter [PYD] Where VCRTYP<>"" & VCRNUM<>""  Order By Key PYD1
For [PYD]PYD1(2)
 Raz MTCUR, MTLOC, MTRPT, [F:DUD]
## DBA le 23/12/02 : Optimisation recherche des échéances non soldées...
## Si l'échéance est soldée FLGCLE=2 sinon FLGCLE=1.
# Readlock [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
 Readlock [DUD]DUD6 = 1;[F:PYD]DUDNUM;[F:PYD]DUDLIG
 If fstat=1
  GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG) : Break 
 Elsif fstat
  GOK=0 : Call RSTA("DUD",num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG)) From GLOCK : Break 
# Elsif [F:DUD]AMTCUR<>[F:DUD]PAYCUR
 Else
  For [PYD]PYD1
   Read [PYH]PYH0 = [F:PYD]NUM 
   If fstat
    GOK=0 : Call RSTA("PYH",[F:PYD]NUM) From GLOCK : Break 2
   Else
    Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
    Read [TPY]TPY0 = [F:PYH]PAYTYP;[F:CPY]LEG
    If fstat
     GOK=0 : Call RSTA("TPY",[F:PYH]PAYTYP) From GLOCK : Break 2
    Else
     # Le règlement est-il validé ?
     If [F:PYH]STA=9 | ([F:PYH]STA>=3 & [F:TPY]STA3=2) | ([F:PYH]STA>=8 & [F:TPY]STA8=2)
      MTCUR += [F:PYD]PAYCURLIN
      MTLOC += [F:PYD]PAYLOCLIN
      MTRPT += [F:PYD]PAYRPTLIN
     Endif
    Endif
   Endif
  Next 
  If MTCUR<>0 & [F:DUD]PAYCUR<>MTCUR 
   MESSA = mess(3,629,1)-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG)-":"
   MESSA -= num$([F:DUD]PAYCUR)-"-->"-num$(MTCUR)-[F:DUD]CUR
   [F:DUD]PAYCUR = MTCUR
   [F:DUD]PAYLOC = MTLOC
   [F:DUD]PAYRPT = MTRPT
   Call SLDECH("DUD")From MODECHE
   Rewrite [DUD]
   If fstat
    GOK=0 : Call FSTA("DUD") From GLOCK : Break 
   Else
    Call ECR_TRACE(MESSA,0) From GESECRAN
   Endif
   Call HISTOECH("DUD",1,[F:PYH]ACCDAT)From MODECHE
  Endif
 Endif
Next
Filter [PYD]
If GOK<0 : Goto ROLL_TR
Elsif GOK=0 : Goto AB_TR
Endif
If TEST 
 Rollback 
Else 
 Commit 
Endif
Return

$ROLL_TR
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR : Endif
Return

$AB_TR
Rollback 
Return


