#<AdxTL>@(#)5.0.0.0 $Revision$
Local Integer OUT_STAT
Call RBKVALPAY("BE000_HRG10000017",7, OUT_STAT)
End
######################################################################################
# Traitement : SUBRBB4
# -----------------------------------------------------------------------------------
# Description: Releves belges - Validation releve règlement
# -----------------------------------------------------------------------------------
# Issue X3-57781 - 2017-10-13 by BEFOU : Update of the SNS when creating PYH
######################################################################################
#**
#* Génération de règlements à partir d'une ligne de relevé Belge
#*
#* @param IN_RBKNUM : statement
#* @param IN_RBKLIN : statement line
#* @param OUT_STAT  : status 1=Ok, <>1:Ko
#*!
Subprog  RBKVALPAY(IN_RBKNUM,IN_RBKLIN, OUT_STAT)
Value Char      IN_RBKNUM
Value Integer   IN_RBKLIN
Variable Integer OUT_STAT

Local Char    SAV_GFONCTION(GLONFCT), SYMBOLE(30)

OUT_STAT = 1
# Le contrôle des infos requises pour la génération du règlement
# a déjà été effectué en amont dans la gestion des relevés belges

Gosub DECLARE

Read [F:RBH]RBH0=IN_RBKNUM
If fstat Then OUT_STAT=0 : End : Endif

Trbegin [PYH] , [PYD] , [PYA] , [BAN], [PYL], [RBD]

Readlock [F:RBD]RBD0=IN_RBKNUM;IN_RBKLIN
If !fstat
 Gosub CREPAY
Else
 OUT_STAT=0
Endif

If OUT_STAT Then
 Commit
 Gosub VALPAY
Else
 Rollback
Endif

End

#**
#* Déclaration des tables et variables
#*!
$DECLARE
If !clalev([F:RBH]) : Local File RBKBELHEA  [RBH] : Endif
If !clalev([F:RBD]) : Local File RBKBELDET  [RBD] : Endif
If !clalev([F:RBU]) : Local File RBKBELDUD  [RBU] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:PYD]) : Local File PAYMENTD   [PYD] : Endif
If !clalev([F:PYA]) : Local File PAYMENTA   [PYA] : Endif
If !clalev([F:PYL]) : Local File PAYLOT     [PYL] : Endif
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
If !clalev([F:BID]) : Local File BID        [BID] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:CAC]) : Local File GACCCODE   [CAC] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif

Local Integer OK, STAT, OKTCA, SIGN, I, ADDGAC
Local Char    CODCPT(GLONCAC)
Local Char    DEVISE(GLONCUR)
Local Char    DEVLED(GLONCUR) : # Devise du référentiel principal général (celui qui gère les échéances)
Local Char    OLDCCE(GLONCCE)(dim([F:PYA]CCE)-1)
Local Char    COMPTE(GLONGAC)
Local Char    PLAN(GLONCOA)
Local Char    BAN(GLONBAN)
Local Decimal PYHAMTLOC, PYHAMTCUR, ARD
Local Char    IDT_LIN(5)
I=max(1,nbrecord([F:TPY]))
Local Char    LOTID(5)(I), LOTCOD(20)(I)
Local Integer LOTX(I), NBLOT
Local Decimal EXERCICE, PERIODE

Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels

Return

#**
#* Création du règlement
#*!
$CREPAY
Call GETSOC([F:RBD]FCYLIN) From DEVSUB
Call LEC_TPY_LEG(GCURLEG,[F:RBD]PAYTYP) From CPTLEC
Call SETPLAN([F:RBH]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
Call SETCUR(1,[F:RBH]CPY,DEVLED) From CPTDIV

Gosub SET_PYH

If OUT_STAT=0 : Return : Endif
If dim([F:PYA]CCE)>0
 Raz OLDCCE
Endif

# Recherche d'un numéro
COMPTREG = ""
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 If [F:PYH]SNS=1 : COMPTREG = [F:TCA]CODNUM(0)
 Else            : COMPTREG = [F:TCA]CODNUM(1)
 Endif
 COMPTLOT = [F:TCA]CODNUM(6)
Endif
If COMPTREG="" : COMPTREG = "PY1" : Endif
Call NUMERO(COMPTREG,[F:PYH]FCY,[F:PYH]ACCDAT,[F:TPY]PAYTYP,[F:PYH]NUM,[L]STAT) From SUBANM
If [L]STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN
 Return  :# GOK est positionné dans SUBANM
Endif

# Montant banque
Call LEC_BAN([F:RBH]BAN) From CPTLEC
[F:PYH]BAN = [F:RBH]BAN
[L]BAN     = [F:RBH]BAN

# Lecture devise
Call LEC_TCU([F:RBH]CUR) From CPTLEC
ARD=[F:TCU]CURRND

NUMLIN = 1
For [F:RBU]RBU0 Where RBKNUM=IN_RBKNUM and RBKLIN=IN_RBKLIN

 Read [DUD]DUD1 = [F:RBU]DUDNUM;[F:RBU]DUDLIG
 If fstat
  Raz [F:DUD]
 Endif

 ###################  PAYMENTH
 If [F:PYH]BPRSAC="" & [F:DUD]SAC<>""
  [F:PYH]BPRSAC = [F:DUD]SAC
  [F:PYH]COA = GPLAN(1)
  Gosub RECH_ACC
 Endif

 ###################  PAYMENTD
 Raz [F:PYD]
 [F:PYD]NUM      = [F:PYH]NUM
 [F:PYD]LIN      = [L]NUMLIN

 For I=1 To GNBPLAN
  Call LECLED([F:PYH]CPY,GTYPLED(I),[F:PYD]LED(I-1),DEVISE) From CPTDIV
  [F:PYD]COA(I-1) = GPLAN(I)
 Next

 [F:PYD]VCRTYP = [F:DUD]TYP

 # Destination comptable
 [F:PYD]DENCOD = [F:RBU]DENCOD
 Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
 [F:PYD]ACCSNS = [F:CDA]ACCSNS
 [F:PYD]ACCTYP = [F:CDA]ACCTYP
 If [F:CDA]IPTDAC=2 Then
  [F:PYD]IPTTYP=3
 Else
  [F:PYD]IPTTYP=0
 Endif

 # Type achat
 If [F:PYH]PURTYP=0 & [F:PYD]IPTTYP=3
  If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
  Read [PIH]PIH2 = [F:DUD]TYP;[F:DUD]NUM
  If fstat=0 & [F:PIH]ORIMOD=3
   If !clalev([F:PIL]) : Local File BPSINVLIG [PIL] : Endif
   Read [PIL]PIL0(1) = [F:PIH]NUM
   If fstat<=2 : [F:PYH]PURTYP = [F:PIL]PURTYP : Endif
  Elsif fstat=0 & [F:PIH]ORIMOD=6
   If !clalev([F:PID]) : Local File PINVOICED [PID] : Endif
   Read [PID]PID0(1) = [F:PIH]NUM
   If fstat<=2 : [F:PYH]PURTYP = [F:PID]LINPURTYP : Endif
  Endif
 Endif

 If [F:DUD]FCY<>"" Then
  [F:PYD]FCYLIN   = [F:DUD]FCY
 Else
  [F:PYD]FCYLIN   = [F:RBD]FCYLIN
 Endif

 [F:PYD]CURLIN   = [F:DUD]CUR
 If [F:PYD]CURLIN = ""
  [F:PYD]CURLIN   = [F:RBH]CUR
 Endif

 [F:PYD]VCRNUM   = [F:RBU]VCRNUM
 [F:PYD]DUDNUM   = [F:RBU]DUDNUM
 [F:PYD]DUDLIG   = [F:RBU]DUDLIG

 [F:PYD]BPRINV    = [F:RBD]BPRNUM
 [F:PYD]BPRSACINV = [F:DUD]SAC

 [F:PYD]AMTLIN = [F:RBU]AMTLINCUR

 [L]SIGN = 0
 If [F:DUD]ACCNUM<>0 | [F:PYD]ACCSNS=1
  Call SNSPAYECH([F:PYD]ACCSNS,[F:PYH]SNS,[F:DUD]SNS,[L]SIGN) From SUBPAY2
 Else
  SIGN = 1
 Endif
 [F:PYD]AMTLIN *= [L]SIGN

 [F:PYD]PAYCURLIN = [L]SIGN*[F:PYD]AMTLIN
# Sens du mouvement et sens de la destination comptable différent
 SIGN = 1
 If ([F:CDA]ACCSNS=2 & [F:PYH]SNS=2) or ([F:CDA]ACCSNS=3 & [F:PYH]SNS=1)
  SIGN = -1
 Else
  SIGN = 1
 Endif
 If [F:DUD]ACCNUM<>0
  # Les montants sont toujours affichés en positif
  Case [F:DUD]BPRTYP
    When 1 : SIGN = [F:DUD]SNS*SIGN : # Client
    When 2 : SIGN = [F:DUD]SNS*(-1)*SIGN : # Fournisseur
  Endcase
 Endif
 If [F:PYD]ACCTYP=1
  [F:PYD]AMTLIN2 = [F:RBU]AMTLIN * [L]SIGN
 Endif

 Gosub SET_PYD : If OUT_STAT=0 : Break : Endif

 # En devise société
 [F:PYD]PAYLOCLIN=[F:RBU]AMTLINLOC*sgn([F:PYD]PAYCURLIN)

 Write [PYD]
 If fstat
  OUT_STAT=0 : Call FSTA("PYD") From GLOCK : Break
 Endif

 Gosub SET_PYA : If OUT_STAT=0 : Break : Endif

 ###################  GACCDUDATE
 # pas de maj de l'échéance ! les TMPxxx ont déjà été maj lors de l'import/saisie du relevé
 #[F:DUD]TMPCUR += [F:PYD]PAYCURLIN
 #[F:DUD]TMPLOC += [F:PYD]PAYLOCLIN
 #Call SLDECH("DUD")From MODECHE
 #Rewrite [F:DUD]
 #If fstat
 # OUT_STAT=0 : Call FSTA("DUD") From GLOCK : Break
 #Endif

 [F:PYH]AMTCUR += [F:PYD]AMTLIN2

 If sgn([F:PYD]AMTLIN2)>0 or sgn([F:PYD]AMTLIN)<0
  [L]PYHAMTLOC+=[F:PYD]PAYLOCLIN
 Else
  [L]PYHAMTLOC-=[F:PYD]PAYLOCLIN
 Endif


 # Montant banque
 If [F:PYD]ACCTYP=1 | [F:PYD]ACCTYP=2
  # Sens du mouvement et sens de la destination comptable différent
  SIGN = 1
  If ([F:CDA]ACCSNS=2 & [F:PYH]SNS=2) or ([F:CDA]ACCSNS=3 & [F:PYH]SNS=1)
   SIGN = -1
  Else
   SIGN = 1
  Endif
  If [F:DUD]ACCNUM<>0
   # Les montants sont toujours affichés en positif
   Case [F:DUD]BPRTYP
     When 1 : SIGN = [F:DUD]SNS*SIGN : # Client
     When 2 : SIGN = [F:DUD]SNS*(-1)*SIGN : # Fournisseur
   Endcase
  Endif
  If [F:PYH]CUR=[M:RBK0]CUR & [F:PYD]ACCTYP=1
   [F:PYH]BANPAYTPY +=SIGN*abs([F:PYD]AMTLIN2-[F:PYD]RITAMT2)
  Elsif [F:PYD]CURLIN=[M:RBK0]CUR : # Devise banque
   [F:PYH]BANPAYTPY +=SIGN*abs([F:PYD]AMTLIN-[F:PYD]RITAMT2)
  Elsif [F:PYD]DUDNUM<>0 & [F:CPY]ACCCUR=[M:RBK0]CUR
   [F:PYH]BANPAYTPY +=SIGN*abs([F:PYD]PAYLOCLIN)
  Endif
 Endif

 [L]NUMLIN += 1

Next

# Initialisation de l'adresse pour le réglement
Call LEC_BPR([F:PYH]BPR) From CPTLEC
If fstat : Raz [F:BPR] : Endif
ADDGAC=0
If [F:PYH]BPAINV =""
 If [F:DUD]BPAPAY<>"" Then
  [F:PYH]BPAINV = [F:DUD]BPAPAY
 Elsif [F:BPR]BPAADD<> ""
  [F:PYH]BPAINV = [F:BPR]BPAADD
 Else
  Call LEC_GAC([F:PYH]ACC,GPLAN(1)) From CPTLEC
  [F:PYH]BPAINV = [F:GAC]BPAADD
  ADDGAC=1
 Endif
 If ADDGAC Then
  Local Char BPA(GLONBPA)
  Call BPA(GPLAN(1),[F:PYH]ACC,BPA) From SUBGAC
  Read [BPA]BPA0 = 5;[L]BPA;[F:PYH]BPAINV
 Else
  Read [BPA]BPA0 = 1;[F:PYH]BPR;[F:PYH]BPAINV
 Endif
 If !fstat
  For I=0 To min(dim([F:PYH]BPANAM),dim([F:BPR]BPRNAM))-1
   [F:PYH]BPANAM(I) = [F:BPR]BPRNAM(I)
  Next I

  For I=0 To min(dim([F:PYH]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
   [F:PYH]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
  Next I

  [F:PYH]POSCOD = [F:BPA]POSCOD
  [F:PYH]CTY    = [F:BPA]CTY
  [F:PYH]CRY    = [F:BPA]CRY
  [F:PYH]SAT    = [F:BPA]SAT
  If [F:BPA]CRYNAM<>"" : [F:PYH]CRYNAM = [F:BPA]CRYNAM
  Else [F:PYH]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[F:PYH]CRYNAM) From TRTDIV
  Endif
 Endif
Endif

If [F:PYH]BPAINV="" Then
 Call ECR_TRACE([F:PYH]ACC-"("+GPLAN(1)+") : "-mess(16,199,1),1) From GESECRAN
 OUT_STAT=0
Endif

If OUT_STAT=0 : Return : Endif

###################  PAYMENTH
# Gestion du code motif économique (CFONB)
Local Integer STAT_BDFE
Local Char    ECOCOD, CUR_D
CUR_D=[F:PYH]CUR
Call CALC_BDFECOCOD([F:PYH]PAYTYP,[F:PYH]BPR,[F:PYH]BID,[F:PYH]BPAINV,[F:PYH]AMTCUR,CUR_D,[F:PYH]ACCDAT,[F:PYH]CPY,ECOCOD,STAT_BDFE) From SUBPAY
If STAT_BDFE>0 Then
 [F:PYH]BDFECOCOD = ECOCOD
Endif
# Si le code motif économique n'est pas renseigné, alors que saisie obligatoire
If [F:PYH]BDFECOCOD="" and STAT_BDFE=1 Then
 Call ECR_TRACE(mess(47,114,1),1) From GESECRAN : # Code motif économique manquant
 OUT_STAT=0 : Return
Endif

Call SIGN2(1,[F:PYH]SNS,0,0,0,I) From PAYDIV
If [F:PYH]SNS=1 : I*=-1 : Endif
[F:PYH]BANPAYTPY *= I
If [F:BAN]CUR=[F:PYH]CUR : [F:PYH]AMTBAN=[F:PYH]AMTCUR : Endif

# Pour ne pas générer des règlts < 0
If [F:PYH]AMTCUR<=0 | [F:PYH]AMTBAN<0
 OUT_STAT=0 : Return
Endif

[L]PYHAMTCUR=[F:PYH]AMTCUR

If COMPTLOT<>""
 # Attribution d'un lot
 I = find([F:PYH]PAYTYP,LOTID(0..NBLOT-1))-1
 If I<0 | LOTX(I)>=X1 : # Nouveau code lot
  Call NUMERO(COMPTLOT,[F:PYH]FCY,datesyst,GUSER,[F:PYH]PAYLOT,[L]STAT) From SUBANM
  If [L]STAT
   # Problème lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   Call ECR_TRACE(mess(60,199,1)-"("+COMPTLOT+") : "+MESSA,1) From GESECRAN
   OUT_STAT=0 : Return
  Endif
  [F:PYH]PAYLOTLIG=1
  Raz [F:PYL]
  [F:PYL]COD   =[F:PYH]PAYLOT
  [F:PYL]DES   = "" #TITTRA
  [F:PYL]CPY   =[F:PYH]CPY
  [F:PYL]FCY   =[F:PYH]FCY
  [F:PYL]PAYTYP=[F:PYH]PAYTYP
  If dim([F:PYL]CREDAT)>0 : [F:PYL]CREDAT=date$ : Endif
  If dim([F:PYL]CREUSR)>0 : [F:PYL]CREUSR=GUSER   : Endif
  I=0
 Else
  [F:PYH]PAYLOT=LOTCOD(I) : [F:PYH]PAYLOTLIG=LOTX(I)+1
  Readlock [PYL]PYL0 = [F:PYH]PAYLOT
  If fstat=1
   OUT_STAT=0 : GLOCK="$PAYLOT"-[F:PYH]PAYLOT : Return
  Elsif fstat
   OUT_STAT=0 : Call RSTA("PYL",[F:PYH]PAYLOT) From GLOCK : Return
  Endif
  I=1
 Endif
 [F:PYL]NBRPAY+=1

 # Montant du lot en devise locale
 If [F:TPY]SNS<3 & [F:PYH]SNS=[F:TPY]SNS : K=1
 Elsif [F:TPY]SNS<3 & [F:PYH]SNS<>[F:TPY]SNS : K=-1
 Elsif [F:PYH]SNS=2 : K=1
 Else K=-1
 Endif
 [F:PYL]TOTLOC+=K*[L]PYHAMTLOC

 If I : Rewrite [PYL]
 Else : Write [PYL]
 Endif
 If fstat
  OUT_STAT=0 : Call FSTA("PYL") From GLOCK : Return
 Endif
Else Raz [F:PYH]PAYLOT, [F:PYH]PAYLOTLIG
Endif

Write [PYH]
If fstat
 OUT_STAT=0 : Call FSTA("PYH") From GLOCK : Return
Endif

###################  BANK

If [F:PYH]BAN<>"" & [F:PYH]BANPAYTPY<>0
 Readlock [BAN]BAN0 = [F:PYH]BAN
 If fstat=1
  OUT_STAT=0 : GLOCK="$BANK"-[F:PYH]BAN : Return
 Elsif fstat
  OUT_STAT=0 : Call RSTA("BAN",[F:PYH]BAN) From GLOCK : Return
 Endif
 [F:BAN]PAYTPY += [F:PYH]BANPAYTPY
 Rewrite [F:BAN]
 If fstat
  OUT_STAT=0 : Call FSTA("BAN") From GLOCK : Return
 Endif
Endif

###################  RBD : Ligne de relevé

[F:RBD]PYHNUM = [F:PYH]NUM
[F:RBD]STATUT = 3 # Validée
[F:RBD]VALFLG = 1 # A valider = NON
Rewrite [F:RBD]
If fstat
 OUT_STAT=0 : Call FSTA("RBD") From GLOCK : Return
Endif

################## Lot

If [F:PYH]PAYLOT<>""
 I = find([F:PYH]PAYTYP,[L]LOTID(0..NBLOT-1))-1
 If I<0
  I=NBLOT : NBLOT+=1
  [L]LOTID(I)=[F:PYH]PAYTYP
 Endif
 [L]LOTCOD(I)=[F:PYH]PAYLOT
 [L]LOTX(I)=[F:PYH]PAYLOTLIG
Endif

################## Trace
SEP=", "
Gosub TRACE_PYH

Local Char ORDSORT(50)
ORDSORT = "NUM;LIN"
Filter [PYD] Where NUM=[F:PYH]NUM Order With ORDSORT
For [PYD]
# If [F:PYD]ACCTYP=1
  Read [DUD]DUD1=[F:PYD]DUDNUM;[F:PYD]DUDLIG
  If fstat : Raz [F:DUD] : Endif
  [L]STAT=0 : Gosub TRACE_PYD
# Endif
Next : # [PYD]
Filter [PYD]
GMESSAGE=""
Return

#**
#* Préparation de l'entête de règlement
#*!
$SET_PYH
Raz [F:PYH]
[F:PYH]BPR    = [F:RBD]BPRNUM
[F:PYH]PAYTYP = [F:RBD]PAYTYP

[F:PYH]FCY = [F:RBD]FCYLIN

# Collectif
[F:PYH]BPRSAC = ""

I=([F:PYH]BPRSAC<>"")
If [F:TPY]DUDFLG<>2
 For [F:RBU]RBU0 Where RBKNUM=IN_RBKNUM and RBKLIN=IN_RBKLIN

  Read [DUD]DUD1=[F:RBU]DUDNUM;[F:RBU]DUDLIG
  If fstat=0
   If [F:DUD]SAC<>""
    If !I  : [F:PYH]BPRSAC=[F:DUD]SAC : I=2
    Elsif I=2 & [F:PYH]BPRSAC<>[F:DUD]SAC : [F:PYH]BPRSAC="" : I=1
    Endif
   Endif
   If I=1 : Break : Endif
  Endif
 Next : # [RBU]
 If [F:PYH]DUDDAT=[0/0/0] Then [F:PYH]DUDDAT=[F:RBD]VALDAT : Endif
Endif


If !find([F:DUD]PAM,[F:TPY]PAM(0..[F:TPY]NBRPAM-1))
[F:PYH]PAM = [F:DUD]PAM
Else
[F:PYH]PAM = [F:TPY]PAM
Endif

[F:PYH]CPY=[F:RBH]CPY
[F:PYH]CUR=[F:RBH]CUR

Call LEC_CPY([F:PYH]CPY) From CPTLEC
If [F:TPY]DACBID<>3 & [F:PYH]BPR<>""
 Call LEC_BPR([F:PYH]BPR) From CPTLEC
 Local Char CRITBID (250)
 Local Integer TROUVE
 TROUVE=0
 #Recherche du rib par défaut en fonction du tiers et de son code adresse
 If [F:TPY]SNS>0 & [F:TPY]SNS<3
  CRITBID = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[F:BPR]BPRNUM+"'"
  CRITBID -=" & [F:BID]BPAADD ='"+[F:DUD]BPAPAY+"'"
  CRITBID -=" & [F:BID]BIDNUMFLG = 2 "
  Filter [BID] Where evalue (CRITBID)
  Read [BID]BID0 First
  Filter [BID]
  If !fstat : TROUVE=1 : Endif
 Endif
 If !TROUVE
  # Rib par défaut
  Read [BID]BID0(3) = 1;[F:BPR]BPRNUM;[F:BPR]BIDNUM
  If fstat
   # sinon le premier par défaut du premier code adresse
   For [BID]BID0 Where BPATYP=1 & BPANUM=[F:BPR]BPRNUM
    If [F:BID]BIDNUMFLG = 2 : TROUVE=0 : Break : Endif
   Next
   If !TROUVE
    # Sinon le premier
    Read [BID]BID0(2) = 1;[F:BPR]BPRNUM
   Endif
  Endif
 Endif

 If fstat<=2
  [F:PYH]BID    = [F:BID]BIDNUM
  [F:PYH]BIDCRY = [F:BID]CRY
  [F:PYH]PAB1 = [F:BID]PAB1
  [F:PYH]PAB2 = [F:BID]PAB2
  Local Integer OKVII
  Call ACTIV("VII",OKVII) From SUBACV
  If OKVII
   [F:PYH]PAB3    = [F:BID]PAB3
   [F:PYH]PAB4    = [F:BID]PAB4
   [F:PYH]BICCOD  = [F:BID]BICCOD
   [F:PYH]MIDPAB1 = [F:BID]MIDPAB1
   [F:PYH]MIDPAB2 = [F:BID]MIDPAB2
   [F:PYH]MIDPAB3 = [F:BID]MIDPAB3
   [F:PYH]MIDPAB4 = [F:BID]MIDPAB4
   [F:PYH]MIDBICCOD = [F:BID]MIDBICCOD
   [F:PYH]MIDCRY   = [F:BID]MIDCRY
  Endif
 Endif
Endif

[F:PYH]SNS       = [F:TPY]SNS
[F:PYH]PST       = 1
[F:PYH]STA       = 1
[F:PYH]STAFLG(0) = 1

If [F:TPY]DUDFLG=2 & [F:TPY]STA3<>2 & [F:TPY]STA8<>2
# Règlt par date échéance et 1ère comptabilisation = Remise en banque
 Call VERF_DAT([F:PYH]CPY,[F:PYH]DUDDAT,[L]STAT) From SUBPAYP
 If ![L]STAT
  Call ECR_TRACE([F:PYH]CPY-format$(GFMDAT,[F:PYH]DUDDAT)-":"-GMESSAGE,1) From GESECRAN
  GMESSAGE=""
 Else
  [F:PYH]ACCDAT=[F:PYH]DUDDAT
 Endif
Else
 [F:PYH]ACCDAT = [F:RBD]ACCDAT
Endif
If [F:PYH]ACCDAT=[0/0/0] : OUT_STAT=0 : Return : Endif
#-> Dates par Module
#Module en dur en attendant
MODULE = 3
Call CTLDATMOD(MODULE,[F:PYH]ACCDAT,[F:RBH]CPY) From CPTSUB
If mkstat
 Call ECR_TRACE(format$(GFMDAT,[F:PYH]ACCDAT)-GMESSAGE,1) From GESECRAN
 GMESSAGE="" : OUT_STAT=0 : Return
Endif
Call GETPERSOC([F:PYH]CPY,GTYPGEN,[F:PYH]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:PYH]FIY = EXERCICE
[F:PYH]PER = PERIODE

Call CONTDEV([F:PYH]CUR,[F:PYH]ACCDAT) From TRTDEV
If mkstat
 Call ECR_TRACE([F:PYH]NUM-GMESSAGE,1) From GESECRAN
 OUT_STAT=0 : Return
Endif

[F:PYH]BILDAT    = [F:RBD]ACCDAT  : # date de création de la traite
[F:PYH]ORIDAT    = [F:PYH]BILDAT  : # date d'origine
[F:PYH]VALDAT    = [F:PYH]DUDDAT
If dim([F:PYH]CREDAT)>0 : [F:PYH]CREDAT=date$ : Endif
If dim([F:PYH]CREUSR)>0 : [F:PYH]CREUSR=GUSER : Endif
[F:PYH]EXPNUM    = [C]EXPORT

[F:PYH]FRMREF = ""

# Type de chèque
If find([F:TPY]DACCHQTYP,1,2)
 [F:PYH]CHQTYP = 1
Endif

# Type de remise
If find([F:TPY]DACFRMTYP,1,2)
 [F:PYH]FRMTYP = 1
Elsif [F:PYH]FRMTYP=0
 [F:PYH]FRMTYP = 1
Endif

# Collectif
If [F:PYH]BPRSAC<>""
 [F:PYH]COA = GPLAN(1)
 Gosub RECH_ACC
Else
 [L]OK = 0
 If [F:PYH]BPR<>""
  Call LEC_BPR([F:PYH]BPR) From CPTLEC
  If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=1    : [L]OK = 1 :# Client
  Elsif [F:BPR]BPCFLG=1 & [F:BPR]BPSFLG=2 : [L]OK = 2 :# Fournisseur
  Elsif [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=2 : Case [F:RBD]SNS
                                             When 1 : [L]OK = 2 :# Dépense -> Fournisseur
                                             When 2 : [L]OK = 1 :# Recette -> Client
                                            Endcase
  Endif
 Endif
 If find([L]OK,1,2)
  Case [L]OK
   When 1 :# Client
    Call LEC_BPC([F:PYH]BPR) From CPTLEC
    Call INIT_COMPTE([F:PYH]BPR,[F:PYH]CPY,"C",CODCPT) From CPTSUB
    Call LEC_CAC(2,[L]CODCPT,GPLAN(1)) From CPTLEC
   When 2 :# Fournisseur
    Call LEC_BPS([F:PYH]BPR) From CPTLEC
    Call INIT_COMPTE([F:PYH]BPR,[F:PYH]CPY,"F",CODCPT) From CPTSUB
    Call LEC_CAC(3,[L]CODCPT,GPLAN(1)) From CPTLEC
  Endcase
  Call LEC_GAC([F:CAC]ACC(0),GPLAN(1)) From CPTLEC
  If !fstat
   [F:PYH]ACC    = [F:CAC]ACC(0)
   [F:PYH]BPRSAC = [F:GAC]ACCSHO
   [F:PYH]BPRTYP = [L]OK
   [F:PYH]COA    = GPLAN(1)
  Endif
 Else
  #angre X3-98841
  If [F:RBD]ACCTMP = ""
    Call LEC_CAC(17,[F:BPR]ACCCOD,GPLAN(1)) From CPTLEC
    [F:RBD]ACCTMP = [F:CAC]ACC(0)
  Endif
  Call LEC_GAC([F:RBD]ACCTMP,GPLAN(1)) From CPTLEC
  [F:PYH]ACC    = [F:RBD]ACCTMP
  [F:PYH]BPRSAC = [F:GAC]ACCSHO
  Case [F:RBD]SNS
   When 1 : [F:PYH]BPRTYP = 2 :# Dépense -> Fournisseur
   When 2 : [F:PYH]BPRTYP = 1 :# Recette -> Client
  Endcase
  [F:PYH]COA    = GPLAN(1)
 Endif
Endif

If [F:PYH]ACC=""
 # Compte inexistant
 Call ECR_TRACE(mess(22,116,1),1) From GESECRAN
 OUT_STAT = 0 : Return
Endif

## Le sens est initialisé plus haut par rapport à la transaction de règlement. Par contre, si le sens de
## la transaction est 'Indéterminé', il faut initialiser le sens du règlement par rapport au tiers
## ou bien le cas échéant au compte auquel est associé le règlement
#
# Issue X3-57781
  #If [F:PYH]SNS=3 : # Indéterminé
  # If [F:PYH]BPR<>""
  #  Call LEC_BPR([F:PYH]BPR) From CPTLEC
  #  If fstat=0
  #   If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2    : [F:PYH]SNS = 2 : # Recette
  #   Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2 : [F:PYH]SNS = 1 : # Depense
  #   Endif
  #  Endif
  # Endif
  #Endif
  #If [F:PYH]SNS=3 & [F:PYH]ACC<>""
  # Call LEC_GAC([F:PYH]ACC,GPLAN(1)) From CPTLEC
  # If fstat=0
  #  If [F:GAC]UPDBLC=2                             : [F:PYH]SNS=2
  #  Elsif [F:GAC]UPDBLC=3                          : [F:PYH]SNS=1
  #  Elsif [F:GAC]AUZBPR(0)=2 & [F:GAC]AUZBPR(1)<>2 : [F:PYH]SNS=2
  #  Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2 : [F:PYH]SNS=1
  #  Endif
  # Endif
  #Endif
# End issue X3-57781
If [F:PYH]SNS=3 Then [F:PYH]SNS=[F:RBD]SNS : Endif

# Initialisation de BPRTYP
Call CLIFOU([F:PYH]BPR,[F:PYH]COA,[F:PYH]ACC,[F:PYH]SNS,[F:PYH]BPRTYP) From PAYDIV
Return

#**
#* Ligne de règlement
#*!
$SET_PYD
#If [F:PYD]ACCTYP=1
 If [F:RBU]ACC<>""
  PLAN = GPLAN(1) : COMPTE = [F:RBU]ACC
 Elsif [F:CDA]ACCBPR<>""
  PLAN = GPLAN(1)
  Call LEC_CAC(14,[F:CDA]ACCBPR,PLAN) From CPTLEC
  If !fstat
   Case [F:PYH]BPRTYP
    When 1 : COMPTE = [F:CAC]ACC(2)
    When 2 : COMPTE = [F:CAC]ACC(3)
   Endcase
  Endif
 Else
  PLAN = GPLAN(1) : COMPTE = [F:PYH]ACC
 Endif
 If COMPTE<>"" : [F:PYD]ACC(0) = COMPTE : Endif
#Else
# PLAN = GPLAN(1) : COMPTE = [F:PYD]ACC(0)
#Endif
[F:PYD]BPRLIN = [F:PYH]BPR

If !instr(1,COMPTE,"x")
 Call LEC_GAC(COMPTE,PLAN) From CPTLEC
 If fstat
  # Destination comptable DENCOD : COMPTE Compte inexistant
  Call ECR_TRACE(mess(40,121,1)-[F:PYD]DENCOD-":"-COMPTE-"("+PLAN+")"+mess(22,116,1),1) From GESECRAN
  OUT_STAT = 0 : Return
 Elsif [F:GAC]SAC=2 & (([F:PYH]BPR="" & [F:PYD]ACCTYP=1) | (COMPTE<>"" & [F:PYD]BPRLIN=""))
  # Destination comptable DENCOD : COMPTE Type de compte incorrect
  Call ECR_TRACE(mess(40,121,1)-[F:PYD]DENCOD-":"-COMPTE-mess(59,106,1),1) From GESECRAN
  OUT_STAT = 0 : Return
 Else
  Call CONTACC(GTYPLED(I),PLAN,COMPTE,[F:PYH]FCY,"",[F:PYH]ACCDAT) From CPTCNT
  If mkstat
   Call ECR_TRACE([F:PYH]NUM-GMESSAGE,1) From GESECRAN
   OUT_STAT=0 : Return
  Endif
 Endif
Endif

If [F:PYD]ACCTYP=1
 Read [DAE]DAE0 = [F:RBU]VCRTYP;[F:RBU]VCRNUM;[F:RBU]DUDLIG;GTYPGEN
 If !fstat
  [F:PYD]ACC(0) = [F:DAE]ACC
  IDT_LIN = [F:DAE]IDTLIN
 Endif
 For I=1 To GNBPLAN
  If GTYPLED(I)<>GTYPGEN
   Read [DAE]DAE7(4) = [F:RBU]VCRTYP;[F:RBU]VCRNUM;IDT_LIN;GTYPLED(I)
   If !fstat
    [F:PYD]ACC(I-1) = [F:DAE]ACC
   Endif
  Endif
 Next
 Gosub INI_OTHACC
 Gosub RECH_ACCANA
Else
 Gosub INI_OTHACC
 Gosub RECH_ACCANA
Endif

If CPTANA<>""
 If [F:PYD]ACCTYP=1
  If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
  Read [DAE]DAE2 = [F:RBU]DUDNUM
  If fstat=0 & [F:DAE]DSP<>"" : [F:PYD]DSP=[F:DAE]DSP : Endif
 Endif
 If !instr(1,CPTANA,"x")
  Call LEC_GAC(CPTANA,PLANA) From CPTLEC
  If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
   MT = 0
   Call CONVERT([F:PYD]CURLIN,GCURSHR,DEVLED,GTYPCURSHR,[F:PYH]ACCDAT,[F:PYD]AMTLIN,MT,STAT) From TRTDEV
   If !STAT
    [F:PYD]QTYLIN = MT/[F:GAC]VALUOM
    Call AROQTE([F:PYD]QTYLIN,[F:GAC]UOM) From CPTINI
   Endif
  Endif
 Endif
Endif

COMPTE = evalue("[F:PYD]ACC("+num$(0)+")")
If [F:CDA]RPCVAT<2
 Raz [F:PYD]VATLIN
Else
 [F:PYD]VATLIN = [F:RBU]VATLIN
 If evalue("[F:PYD]ACC("+num$(0)+")")<>"" & !instr(1,COMPTE,"x")
  Call LEC_GAC(COMPTE,GPLAN(1)) From CPTLEC
  If [F:GAC]FLGVAT<2 : Raz [F:PYD]VATLIN
  Elsif [F:PYD]VATLIN="" : [F:PYD]VATLIN=[F:GAC]VAT(0)
  Endif
 Endif
Endif
Return

#**
#* Analytique
#*!
$SET_PYA
If CPTANA="" : Return : Endif
Local Integer K, NLED, INDLED, INDAXI, IND, AXI, INDAXE, SUIVI, VU : # <85830>
Local Decimal MT, QTE, SMT, SQTE  : # <85830>
If [F:GAC]FLGUOM=2
 If clalev([F:TUN])=0 : Local File TABUNIT [TUN] : Endif
 Call LEC_TUN([F:GAC]UOM) From CPTLEC
 ARQ = 10^(-[F:TUN]UOMDEC)
Endif

Case [F:PYD]DSP
 When ""
  K = 0
  If [F:PYD]ACCTYP=1
   SMT = 0 : SQTE = 0
   If clalev([F:DAA])=0 : Local File GACCENTRYA [DAA]: Endif
   Read [DAE]DAE2 = [F:PYD]DUDNUM
   ## Parcours des imputations analytiques (ANALIN) associées au compte auxiliarisés (tiers facturé/facturant)
   If fstat=0
   For [DAA]DAA2(4) Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & IDTLIN=[F:DAE]IDTLIN
    If K=0
     Raz [F:PYA]
     [F:PYA] = [F:PYH]
     [F:PYA] = [F:PYD]
    Endif
    K += 1
    [F:PYA]LINANA = K
    MT=0 : QTE=0
    If [F:DAE]AMTCUR=[F:PYD]AMTLIN
     MT=[F:DAA]AMTCUR
    Elsif [F:DAE]AMTCUR<>0
     MT = arr(([F:DAA]AMTCUR+SMT)*[F:PYD]AMTLIN/[F:DAE]AMTCUR,ARD)
&        -arr(SMT*[F:PYD]AMTLIN/[F:DAE]AMTCUR,[F:TCU]CURRND)
     SMT += [F:DAA]AMTCUR
    Endif
    If [F:GAC]FLGUOM=2
     If [F:DAE]UOM=[F:GAC]UOM & [F:DAE]QTY=[F:PYD]QTYLIN
      QTE=[F:DAA]QTY
     Elsif [F:PYD]AMTLIN<>0
      QTE = arr((MT+SQTE)*[F:PYD]QTYLIN/[F:PYD]AMTLIN,ARQ)
&          -arr(SQTE*[F:PYD]QTYLIN/[F:PYD]AMTLIN,ARQ)
      SQTE += [F:DAA]QTY
     Endif
    Endif
    [F:PYA]AMTANA = MT
    [F:PYA]QTYANA = QTE
    ## On est sur une imputation analytque, parcours des types référentiels
    For [DAA]DAA2
     If find([F:DAA]LEDTYP,GTYPLED(1..GNBPLAN))
      For AXE=1 To GNBAXE
       VU = find(GAXE(AXE),[F:DAA]DIE(0..dim([F:DAA]DIE)-1))
       If VU
        Assign "[F:PYA]DIE("+num$(AXE-1)+")" With [F:DAA]DIE(VU-1)
        Assign "[F:PYA]CCE("+num$(AXE-1)+")" With [F:DAA]CCE(VU-1)
       Endif
      Next
     Endif
    Next
    If K>0
     Write [PYA]
     If fstat
      OUT_STAT=0 : Call FSTA("PYA") From GLOCK : Break
     Endif
    Endif
   Next
   Endif
   If OUT_STAT=0 : Return : Endif
  Endif
  If K=0
   Raz [F:PYA]
   [F:PYA]=[F:PYH]
   [F:PYA]=[F:PYD]
   [F:PYA]LINANA = 1
   [F:PYA]AMTANA = [F:PYD]AMTLIN
   [F:PYA]QTYANA = [F:PYD]QTYLIN
   OK = 0

   For AXE=1 To GNBAXE
    [F:PYA]DIE(AXE-1) = GAXE(AXE)

    For NLED=1 To GNBPLAN
     Call INDLED([F:PYD]LED(NLED-1),GAXE(AXE),INDLED,INDAXI) From CPTDIV
     If INDAXI
      # Init selon le code PAYMENTD
      Call INISEC([F:PYA]CCE(AXE-1),"PAYMENTD",GAXE(AXE),[F:PYH]BPRTYP) From PAYDIV

      # Init selon entête de facture/commande
      If [F:PYA]CCE(AXE-1)=""

       If [F:PYH]SNS=1 : OPT="2143"
       Else            : OPT="1234"
       Endif

       For I=1 To 4
        Case mid$(OPT,I,1)
         When "1" : # Facture client
          If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
          If [F:SIH]NUM<>[F:PYD]VCRNUM
           Read [SIH]SIH0 = [F:PYD]VCRNUM
           If fstat : Raz [SIH] : Endif
          Endif
          If [F:SIH]GTE=[F:RBU]VCRTYP
           INDAXE = find(GAXE(AXE),[F:SIH]DIE(0..dim([F:SIH]DIE)-1))
           If INDAXE
            [F:PYA]DIE(AXE-1) = GAXE(AXE)
            [F:PYA]CCE(AXE-1) = [F:SIH]CCE(INDAXE-1)
            Break
           Endif
          Endif
         When "2" : # Facture fournisseur
          If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
          If [F:PIH]NUM<>[F:PYD]VCRNUM
           Read [PIH]PIH0 = [F:PYD]VCRNUM
           If fstat : Raz [PIH] : Endif
          Endif
          If [F:PIH]GTE=[F:RBU]VCRTYP
           INDAXE = find(GAXE(AXE),[F:PIH]DIE(0..dim([F:PIH]DIE)-1))
           If INDAXE
            [F:PYA]DIE(AXE-1) = GAXE(AXE)
            [F:PYA]CCE(AXE-1) = [F:PIH]CCE(INDAXE-1)
            Break
           Endif
          Endif
        Endcase
       Next I
      Endif

      ## Si section de l'axe AXE-1 toujours pas initialisé, on essaye d'initialiser la section
      ## selon le compte du référentiel qui gère l'axe
      If [F:PYA]CCE(AXE-1)=""
       Call INDLED([F:PYD]LED(NLED-1),GAXE(AXE),IND,AXI) From CPTDIV
       If IND & AXI
        If !instr(1,evalue("[F:PYD]ACC("+num$(NLED-1)+")"),"X")
         Call LEC_GAC(evalue("[F:PYD]ACC("+num$(NLED-1)+")"),GPLAN(NLED)) From CPTLEC
         SUIVI = find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
         If SUIVI
          [F:PYA]CCE(AXE-1) = [F:GAC]CCEDEF(SUIVI-1)
          If [F:PYA]CCE(AXE-1)<>"" : Break : Endif
         Endif
        Endif
       Endif
      Endif
     Endif
    Next

   Next AXE
   Write [PYA]
   If fstat
    OUT_STAT=0 : Call FSTA("PYA") From GLOCK
   Endif
  Endif

 When Default
  K = 0 : SUMPOI = 0
  If clalev([F:DSP])=0 : Local File CADSP [DSP] : Endif
  For [DSP]DSP0 Where DSP=[F:PYD]DSP
   SUMPOI += [F:DSP]COE
  Next
  SUMP = 0
  For [DSP]DSP0 Where DSP=[F:PYD]DSP
   K += 1
   Raz [F:PYA]
   [F:PYA]=[F:PYH]
   [F:PYA]=[F:PYD]
   [F:PYA]LINANA = K
   For AXE=1 To GNBAXE
    For NLED=1 To GNBPLAN
     Call INDLED([F:PYD]LED(NLED-1),GAXE(AXE),INDLED,INDAXI) From CPTDIV
     If INDAXI
      VU = find(GAXE(AXE),[F:DSP]DIE(0..dim([F:DSP]DIE)-1))
      If VU
       [F:PYA]DIE(AXE-1) = GAXE(AXE)
       [F:PYA]CCE(AXE-1) = evalue("[F:DSP]CCE"+num$(VU))
       If [F:PYA]CCE(AXE-1)<>"" : Break : Endif
      Endif
     Endif
    Next
   Next
   If SUMPOI<>0
    [F:PYA]AMTANA = arr([F:PYD]AMTLIN*(SUMP+[F:DSP]COE)/SUMPOI,ARD)
&                  -arr([F:PYD]AMTLIN*SUMP/SUMPOI,ARD)
    If [F:GAC]FLGUOM=2
     [F:PYA]QTYANA = arr([F:PYD]QTYLIN*(SUMP+[F:DSP]COE)/SUMPOI,AROQTE)
&                   -arr([F:PYD]QTYLIN*SUMP/SUMPOI,ARQ)
    Endif
    SUMP += [F:DSP]COE
   Endif
   Write [PYA]
   If fstat
    OUT_STAT=0 : Call FSTA("PYA") From GLOCK : Break
   Endif
  Next
Endcase
Return

#**
#* Lecture du compte dans GACCOUNT
#*!
$RECH_ACC
Read [GAC]GAC1 = [F:PYH]COA;[F:PYH]BPRSAC
If fstat=0 : [F:PYH]ACC = [F:GAC]ACC : Endif
Call CLIFOU([F:PYH]BPR,[F:PYH]COA,[F:PYH]ACC,[F:PYH]SNS,[F:PYH]BPRTYP) From PAYDIV
Return

#**
#* $RECH_ACCANA
#*!
$RECH_ACCANA
Local Char PLANA(GLONCOA), CPTANA(GLONGAC)
Local Char TPLAN(GLONCOA)(1..GNBPLAN), TCOMPTEX(GLONGAC)(1..GNBPLAN)
Local Integer II
For II=1 To GNBPLAN
 TPLAN(II)   = GPLAN(II)
 TCOMPTEX(II) = evalue("[F:PYD]ACC("+num$(II-1)+")")
Next
Call RECH_ACC(2,[F:PYH]CPY,GTYPLED,GNBPLAN,TPLAN,TCOMPTEX,PLANA,CPTANA) From CPTDIV
Return

#**
#* INI_OTHACC comme sous SUBPAY (Saisie des règlements) & TRTPCE (Propagation lors de la validation des règlements)
#* Cas d'un blocage sur l'analytique suite à un compte devenu suivi analytique.
#*!
$INI_OTHACC
Local Char    CRIBLE(20)
Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
Local Integer IREF
For I=2 To GNBPLAN
 If [F:PYD]ACC(I-1)=""
  For IREF=1 To GNBPLAN
   [L]ACCORG = evalue("[F:PYD]ACC("+num$(IREF-1)+")")
   If [L]ACCORG<>""
    Call LECTURE("GAC",ACCORG,GPLAN(IREF)) From CONTOBJ
    If find(GPLAN(I),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
     Call INIACC(GPLAN(IREF),[L]ACCORG,GPLAN(I),ACCDES,[L]CRIBLE) From CPTINI
     If [L]ACCDES<>""
      ## Le compte du type référentiel I a été initialisé par le type référentiel IREF -> On sort
      Break
     Endif
    Elsif GPLAN(IREF)=GPLAN(I) : # Demande 55712. Plans de comptes identiques
     [L]ACCDES = [L]ACCORG
     Break
    Else
     [L]ACCDES = "" : Break
    Endif
   Endif
  Next
  [F:PYD]ACC(I-1) = [L]ACCDES
 Endif
Next
Return


#**
#* Trace de l'entête de règlement
#*!
$TRACE_PYH
# Règlement NUM PAYLOT : PAYTYP, FCY, ACCDAT, BAN, (PAM,) (DUDDAT,) BPRSAC, BPR BPRNAM, AMTCUR CUR
GMESSAGE=[F:PYH]PAYTYP+SEP+[F:PYH]FCY+SEP+format$("D:"+GFMDAT,[F:PYH]ACCDAT)+SEP+[F:PYH]BAN
If [F:TPY]DACPAM<>3
 GMESSAGE+=SEP+[F:PYH]PAM
Endif
If [F:TPY]DACDUDDAT<>3
 GMESSAGE+=SEP+format$("D:"+GFMDAT,[F:PYH]DUDDAT)
Endif
Call LEC_BPR([F:PYH]BPR) From CPTLEC
If fstat : Raz [F:BPR] : Endif
GMESSAGE+=SEP+[F:PYH]BPRSAC-[F:PYH]BPR+SEP+[F:BPR]BPRNAM
GMESSAGE+=SEP+[F:DUD]BPAPAY
GMESSAGE+=SEP+num$([F:PYH]AMTCUR)-[F:PYH]CUR
Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-[F:PYH]PAYLOT-":"-GMESSAGE,0) From GESECRAN
#If [F:TPY]DACBID<>3 & [F:PYH]BID=""
# Call ECR_TRACE([F:PYH]BPR-":"-mess(27,199,1),1) From GESECRAN : # Rib inexistant
#Endif
Return

#**
#* Trace de la ligne de règlement
#*!
$TRACE_PYD
If [F:DUD]NUM<>"" Then
 # VCRTYP, VCRNUM, DUDDAT, FCY, SAC BPR, BPRNAM, (BPRVCR BPRDATVCR,) AMTLIN CUR
 GMESSAGE =[F:PYD]VCRTYP
 GMESSAGE-=[F:PYD]VCRNUM+SEP+format$("D:"+GFMDAT,[F:DUD]DUDDAT)+SEP+[F:DUD]FCY
 Call LEC_BPR([F:DUD]BPR) From CPTLEC
 GMESSAGE+=SEP+[F:DUD]SAC-[F:DUD]BPR+SEP+[F:BPR]BPRNAM
 If [F:HAE]TYP<>[F:PYD]VCRTYP | [F:HAE]NUM<>[F:PYD]VCRNUM
  Read [HAE]HAE0 = [F:PYD]VCRTYP;[F:PYD]VCRNUM
  If fstat : Raz [HAE] : Endif
 Endif
 If [F:HAE]NUM<>"" & ([F:HAE]BPRVCR<>"" | [F:HAE]BPRDATVCR<>[0/0/0])
  GMESSAGE+=SEP+[F:HAE]BPRVCR-format$("D:"+GFMDAT,[F:HAE]BPRDATVCR)
 Endif
 GMESSAGE+=SEP+num$([F:PYD]AMTLIN)-[F:DUD]CUR
 If [L]STAT<0 : # Escompte
  GMESSAGE-="("+GDIV(2)+")"
 Elsif [L]STAT>0 : # Agio
  GMESSAGE-="("+GDIV(5)+")"
 Elsif [F:DUD]CUR<>[F:PYH]CUR
  GMESSAGE-="->"-num$([F:PYD]AMTLIN2)-[F:PYH]CUR
 Endif
Else
 GMESSAGE=num$([F:PYD]AMTLIN)-[F:PYH]CUR
Endif
Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Return

#**
#* Validation du règlement
#*!
$VALPAY
#-- Are we allowed to process ?
[L]SAV_GFONCTION=GFONCTION
GFONCTION="REMBAN"
Call AUTORIS From EXEFNC
If GNBAUZ=0
  Call ECR_TRACE(GFONCTION-mess(74,100,1),1) From GESECRAN
  OUT_STAT = 0
  Goto END_PROCESS
Endif


Onerrgo ERREUR From CONTROLE
If clalev([M:DIA]) : Close Local Mask [DIA] : Endif
Local Mask PAYREMBAN [DIA]
Onerrgo
If GERREUR : GERREUR=0 : OUT_STAT=0 : Return : Endif

Raz [M:DIA]
[M:DIA]ALLCPY=2    : [M:DIA]ALLFCY=2    : [M:DIA]ALLTYP=2
[M:DIA]PRO=2       : [M:DIA]TRC=2       : [M:DIA]ALLUSR=2
[M:DIA]ACCSTA=9    : [M:DIA]ALLLOT=2    : [M:DIA]ALLBAN=2
[M:DIA]ALLFRMTYP=2 : [M:DIA]PAY5=1      : [M:DIA]PAY7=1
[M:DIA]PAY9=2                :# Case à cocher "Règlement"
[M:DIA]VALDAT=[F:PYH]VALDAT  :# Date de valeur
[M:DIA]ACCDAT=[F:PYH]ACCDAT  :# Date comptable

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(mess(4,2673,1)-":"-[F:PYH]NUM,0) From GESECRAN

Call PAYCPT([F:PYH]NUM) From PAYCPTA

#-- end process statement line
$END_PROCESS
If clalev([M:DIA]) : Close Local Mask [DIA] : Endif
GFONCTION=[L]SAV_GFONCTION
If [L]SAV_GFONCTION <> "" : Call AUTORIS From EXEFNC : Endif
If [L]SYMBOLE<>"" : Unlock =[L]SYMBOLE : Endif

Return

