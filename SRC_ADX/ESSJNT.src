#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
Local Char GLOBEML(GLONEML)

If clalev([F:HRCTR1])     = 0 : Local File EMPLOCTR      [HRCTR1]     : Endif
If clalev([F:CTRSA1])     = 0 : Local File EMPLOCTRSA    [CTRSA1]     : Endif
If clalev([F:CTRUKI1])    = 0 : Local File EMPLOCTRUKI   [CTRUKI1]    : Endif
If clalev([F:ID])         = 0 : Local File EMPLOID       [ID]         : Endif
If clalev([F:FCY])        = 0 : Local File FACILITY      [FCY]         : Endif

GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#Manage Localisations
Call MANAGE_LOCALISATION("ESSJNT") From DIVPAYE

Return

$DEBUT
Local Char EMPCODE (GLONEML)
EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

#ALL Legislations
Gosub FILTER_CTR
Gosub CHARGE_ALL

#UKI
If func DIVPAYE.IS_KUK_LEG(GCURLEG)>0
  Gosub CHARGE_UKI
Endif



#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSJNTHIDE
Call SHOW_LEGACTCALLS From WESSJNTSHOW
Gosub DISPLAY_HIDE

Filter [F:HRCTR1]
Filter [F:ID]
Affzo [M:ESJNT]1-99

Return

$FILTER_CTR
Filter [F:HRCTR1] Where REFNUM = EMPCODE and XITDAT=[0/0/0] and [F:HRCTR1]FLGRET <> 2 and [F:HRCTR1]FLGVAR <> 2 Order By CTRDAT Desc
Filter [F:ID] Where REFNUM = EMPCODE
Return

$CHARGE_ALL
Local Integer I
Local Char    LEGI,LEGC
Local Integer PNOLIB,OKPAR
Local Char CTRLEG(GLONADI)

nolign = 0

For [F:HRCTR1]
  #CTRLEG = func DIVPAYE_SOA.GET_LEG_FCY([F:HRCTR1]ETRFCY, 1)
  #If CTRLEG = GCURLEG
    nolign+= 1
    [M:ESJNT] = [F:HRCTR1]
    #Set marital status
    Call VERIF_AML_EML([F:HRCTR1]ETRFCY,[F:HRCTR1]SITFAM,1,"SITFAM",PNOLIB,LEGI,LEGC,OKPAR) From SUBCTR2
    [M:ESJNT]NOLIBM(nolign-1)=PNOLIB
    If([F:HRCTR1]SITFAM<>0)
      [M:ESJNT]SITFAMA(nolign-1) = mess([F:HRCTR1]SITFAM,[M:ESJNT]NOLIBM,1)
    Else
      [M:ESJNT]SITFAMA(nolign-1)=""
    Endif
  #Endif
Next
[M:ESJNT]NBRMSA = nolign
Return

$CHARGE_UKI
Local Integer I
nolign = 0

For [F:HRCTR1]
  Read [CTRUKI1]CTRUKI0 = [F:HRCTR1]REFNUM;[F:HRCTR1]CTRNUM;[F:HRCTR1]CTRDAT
  If !fstat
    #If [F:CTRUKI1]PARINI <>"" or [F:CTRUKI1]PARNIN <>"" or [F:CTRUKI1]PARSECNAM <>"" or [F:CTRUKI1]PARTTL <>""
      nolign+= 1
      [M:ESJNT] = [F:CTRUKI1]
      [M:ESJNT]CTRPAR(nolign-1) = [F:CTRUKI1]CTRNUM
    Endif
  #Endif
Next
[M:ESJNT]NBRMSK = nolign
Return

$DISPLAY_HIDE
Local Char WSIGN(1)
WSIGN="-"

#Hide
If func DIVPAYE.IS_KUK_LEG(GCURLEG)=1
  Gosub SPECIFIC_UK
Endif
Return

$SPECIFIC_UK
If func DIVPAYE.IS_KUK_LEG(GCURLEG)=0 : Return :Endif

If dim([M:ESJNT]MRGDAT)>0       : Chgfmt [M:ESJNT]MRGDAT        With "-D"+GFMDAT4         : Raz [M:ESJNT]MRGDAT       : Endif
If dim([M:ESJNT]JNTREFNUM)>0    : Chgfmt [M:ESJNT]JNTREFNUM     With WSIGN+"K:30X"        : Raz [M:ESJNT]JNTREFNUM    : Endif
If dim([M:ESJNT]JNTDATBRN)>0    : Chgfmt [M:ESJNT]JNTDATBRN     With WSIGN+"D:"+GFMDAT4   : Raz [M:ESJNT]JNTDATBRN    : Endif
If dim([M:ESJNT]JNTCRY)>0       : Chgfmt [M:ESJNT]JNTCRY        With WSIGN+"K:3X"         : Raz [M:ESJNT]JNTCRY       : Endif
If dim([M:ESJNT]JNTCRYNAM)>0    : Chgfmt [M:ESJNT]JNTCRYNAM     With WSIGN+"K:40X"        : Raz [M:ESJNT]JNTCRYNAM    : Endif
If dim([M:ESJNT]JNTTEL)>0       : Chgfmt [M:ESJNT]JNTTEL        With WSIGN+"K:20X"        : Raz [M:ESJNT]JNTTEL       : Endif
If dim([M:ESJNT]SPOMDNNAM)>0    : Chgfmt [M:ESJNT]SPOMDNNAM     With WSIGN+"K:20X"        : Raz [M:ESJNT]SPOMDNNAM    : Endif
Return

