#<AdxTL>@(#)9.0.0.0 $Revision$
#Call LECFIC(filpath("tmp","",""),"espion","tra")
#End

Local Char PARAM(250)(1..5) , VALEUR(250) , SAVACT(20)
GNBMASKOUV = 0
GTRACE = ""
SAVACT = GACTION
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","LECTRA",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

#---------------------------------------------------------------------------------------------#
#                           POUR BIEN GERER UNE TRACE
#---------------------------------------------------------------------------------------------#
#
# 1) Ouvrir une trace   Call OUVRE_TRACE("Commentaire") From LECFIC
#
# 2) Ecrire ds la trace Call ECR_TRACE("Message",err) From GESECRAN
#                                              err :  0 Information
#                                                  : >0 Erreur      couleur 1 (rouge)
#                                                  : -2 Information couleur 3 (vert ou bleu)
#                                                  : <0 Information couleur 2 (bleu ou vert)
#
# 3) Fermer la trace    Call FERME_TRACE From LECFIC
#
# 4) Lire la trace      Call LEC_TRACE   From LECFIC
#                    ou Call SUPP_TRACE  From LECFIC : supprime la trace après l'avoir lue
#                    ou Call CONS_TRACE  From LECFIC : lire la trace sans pouvoir la supprimer
#                    ou positionner TRA = 1 dans l'action CONTROLE du modèle GTRAITE
#                                         8 pour lire la trace sans pouvoir la supprimer
#                                         9 pour lire la trace et la supprimer automatiquement
#
#---------------------------------------------------------------------------------------------#

#---------------------------------------------------------------------------------------------#
Subprog LEC_TRACE
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
If dim(GVTMOD)>0 & GVTMOD
 Call LECTRA_VT : End
Endif
SAVACT = GACTION
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

#---------------------------------------------------------------------------------------------#
Subprog SUPP_TRACE
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
SAVACT = GACTION
PARAM(5) = "S"
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

#---------------------------------------------------------------------------------------------#
Subprog CONS_TRACE
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
SAVACT = GACTION
PARAM(5) = "C"
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

#---------------------------------------------------------------------------------------------#
$ACTION
Case GACTION
 When "LECTRA"
  Case BOITE
   When "LECFIC"
    Case ACTION
     When "AVANT_PAR"   : Gosub AVANT_PAR
     When "CONTROLE"    : Gosub CONTROLE
     When "OUVRE"       : Gosub OUVRE
     When "TITRE"       : Gosub TIT
     When "DEBUT"       : Gosub DEBUT
     When "SETBOUT"     : Gosub SETBOUT
     When "BOUTON"      : Gosub BOUTON
     When "MEN"         : Gosub MENU
     When "SUP"         : Gosub ANNUL
     When "RAF"         : Gosub RAF
     When "SUI"         : Gosub SUIVANT
     When "PRE"         : Gosub PRECEDENT
     When "FIR"         : Gosub PREMIER
     When "LAS"         : Gosub DERNIER
     When "EDI"         : Gosub EDIT
     When "FIN"         : Gosub FIN
    Endcase
  Endcase
 When "LECTRACE"
  Case ACTION
   When "EXEC"       : TRA = 1 : # action LECTRACE GH 8/10/01
  Endcase
 When "SELTRA"
  Case ACTION
   When "SEL_TABLE"  : Gosub SEL_TRA
   When "FIN_TABLE"  : Gosub FIN_TRA
   When "BOUT_TABLE"
    Case GSTATUT
     When GSTASVG    : Gosub SVG_TRA
     When GSTAPRG    : Gosub PRG_TRA
     When GSTASRA    : Gosub SRA_TRA
    Endcase
    OK = 0
  Endcase
 When "LECPAG"
  Case ACTION
   When "OK"         : PARAM(1) = num$([M]PAGE)
   When "END"        : PARAM(1) = "0"
  Endcase
Endcase
Return


#---------------------------------------------------------------------------------------------#
$AVANT_PAR
If BCRIT<>""
 If clalev([LECT])=0 : Local Mask LECTRA [LECT] : Endif
Endif
Return

#---------------------------------------------------------------------------------------------#
$CONTROLE
If BCRIT<>""
 If GSTATUT<>GSTAOK
  FIN = 1 : Return
 Endif
 Local Char    CHEMIN(GDIMFIC) , FICHIER(GDIMFIC) , MACHINE(GDIMFIC)
 Local Integer ER
 FICHIER = [M:LECT]FICHIER
 Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
 If (GBROWS & !GADXLOC) & MACHINE="#"
  Call ERREUR(mess(85,150,1)) From GESECRAN : # Fonction non disponible en mode web
  SAI = 1
 Elsif max(instr(1,FICHIER,"/"),instr(1,FICHIER,"\"),instr(1,FICHIER,"@"))
  Onerrgo ERFIL
  CHEMIN = filpath("",FICHIER,"",0)
  Onerrgo
  If ER
   Call ERREUR(errmes$(abs(ER))) From GESECRAN
   SAI = 1
  Else
   Call EXISTE(CHEMIN,OK)
   If !OK
    SAI = 1
   Else
    PARAM(2) = CHEMIN
    PARAM(5) = "C" : # Consultation uniquement
   Endif
  Endif
 Else
  CHEMIN = filpath("TRA",FICHIER,"tra",0)
  If filinfo(CHEMIN,0)<=0
   SAI = 1
  Else
   GTRACE = FICHIER
  Endif
 Endif
Elsif PARAM(2)<>""
 If filinfo(filpath(PARAM(1),PARAM(2),PARAM(3),"","",PARAM(4)),0)<0
  FIN = 1
 Endif
Elsif GTRACE<>""
 If filinfo(filpath("TRA",GTRACE,"tra",0),0)<0
  If TRA
   GTRACE = ""
   GERRTRACE = 0
  Endif
  FIN = 1
 Endif
 If dim(GTRALIG)>1 and GTRANBR>0
  Call FLUSH_TRACE From GESECRAN
 Endif
Else
 FIN = 1
Endif
Return

$ERFIL
ER = errn
Resume

#---------------------------------------------------------------------------------------------#
$OUVRE
Local Char    FICH(GDIMFIC) , NOMFIC(GDIMFIC) , EXT(10) , FICCLI(GDIMFIC)
Local Char    REPERT(GDIMFIC) , APPLI(GLONADS) , MACHINE(GDIMFIC)
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
Local Integer STA , SUP , CONS , MAIL , TRA , NODEL
Local Integer K , R , TYL , OPTERR , MAXLIG , SAVCONF
Local Char    RESOL(10) , MESSA(250) , SAVTRACE(GLONTRA) , MOTSAI(250) , MOTREC(250)
Local Integer MAXERR ,ERL
Local Integer ERR       : # Nb of errors(error+warning)
Local Integer WAR       : # Nb of warnings
Local Integer S_MAXPAG  : # static variable which stores the max total number of pages
S_MAXPAG = 1000         : # Nombre de pages consultables
Local Integer PAGE      : # page number to go to
Local Decimal CPT , STOP , OUT
Local Integer DIME
Local Integer OPTREC , NBREC , MAXREC
Local Integer LERRPAGE(1..)   : # list of all page numbers where there're errors, will be filled in LECTOUT
Local Integer NERRPAGE        : # dimention of LERRPAGE, will be calculated in LECTOUT
Local Integer LWARPAGE(1..)   : # list of all page numbers where there're warnings, will be filled in LECTOUT
Local Integer NWARPAGE        : # dimention of LWARPAGE, will be calculated in LECTOUT
Local Integer CURPAGE         : # current page number

DIME = 250                   : # Taille du buffer de lecture
Local Char    TMP(DIME)      : # Buffer de lecture du Rdseq
Local Integer PGSEEK         : # Indice du no page pour retrouver le Seek du début de chaque page
Local Integer NBPAGE         : # Nb de pages lues
Local Integer NBERR          : # Nb erreurs (réelles + warning)
Local Integer NBWAR          : # Nb de warning

Local Integer PORTRAIT       : # Nombre de caractères maxi dans une ligne d'édition portrait
PORTRAIT = 90
Local Integer PAYSAGE        : # Si une ligne dépasse PORTRAIT on édite en paysage

Local Decimal NOSEEK(S_MAXPAG) : # Seek début de chaque pages
MAXERR = 10000               : # nb d'erreurs référençables qd on choisit de ne visualiser que les erreurs
Local Decimal LIG(1..MAXERR) : # No ligne de la trace complète (ne sert qu'à la visu des erreurs)
MAXREC = 1000                : # Nb de lignes contenant le texte recherché
Local Decimal REC(1..MAXREC) : # No de lignes correspondant

Local Mask    LECFIC [LFI]
MAXLIG = dim([M:LFI]LIGNE)   : # Nombre maxi de lignes dans une page

TRA   = (PARAM(2)="")  : # Donc GTRACE est renseigné
SUP   = (PARAM(5)="S")
CONS  = (PARAM(5)="C")
NODEL = (func AFNC.PARAMUTIL("ACLRLOG","","")="1" & GADONIX<>2)

If TRA
 REPERT  = "TRA"
 FICH    = GTRACE
 EXT     = "tra"
 If !GSERVEUR & GERRTRACE
  Call ERREUR(mess(159,115,1)-num$(GERRTRACE)) From GESECRAN : # Nombre d'erreurs :
 Endif
 MACHINE = adxmac(0)
 APPLI   = nomap
Else
 REPERT = PARAM(1)
 FICH   = PARAM(2)
 EXT    = PARAM(3)
 If PARAM(4)="#"
  MACHINE = "#"
 Else
  Call MACHINE(PARAM(4),MACHINE,APPLI) From ORDSYS
 Endif
Endif

NOMFIC = filpath(REPERT,FICH,EXT,APPLI,"",MACHINE)

SAVCONF = GCONF(1)
GCONF(1) = 1 : # Pour virer le message standard "Confirmation d'annulation"

Local File AWRKPAR [AWA]
Filter [AWA] Where TYPEVT=1 & CODEVT="TRA" & ENAFLG=2 & ENAMES=2
Read [AWA]AWA1 First
If !fstat
 MAIL = 1
Endif
Filter [AWA]
Close Local File [AWA]

Disable GSTATM2 : # On empilerait 2 masques de même abréviation
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR : # Format de la trace (normalement en Utf8)
Return

#--------------------#
$TIT
Local Char TIT(200)
TIT = mess(82,115,1)-FICH : # Lecture fichier de trace
Return

#--------------------#
$DEBUT
Raz [M]
Onerrgo RIEN
[M]COMMENT = format$("K:120X",filcom(REPERT,FICH,EXT,APPLI,"",MACHINE))
Onerrgo
[M]NOMFIC = NOMFIC
Call PARAM("","ECRRESOL",RESOL) From ADOVAL
Case RESOL
 When "1"     : TYL = 100 : # Basse résolution
 When Default : TYL = 115 : # Nombre de caractères dans une ligne en haute résolution
Endcase
[M]FORMAT = "K:"+num$(TYL)+"X"
Openi NOMFIC, 0
Raz NBERR , NBWAR , OUT , zonsui
Gosub LECTOUT
If STOP
 MESSA = mess(71,139,1) : # La trace dépasse # pages, voulez-vous consulter uniquement les erreurs ?
 I = instr(1,MESSA,"#")
 If I<>0
  MESSA = left$(MESSA,I-1)+num$(S_MAXPAG)-right$(MESSA,I+1)
 Endif
 Call AVERTIR(MESSA,OK) From GESECRAN
 If OK=2
  OPTERR = 1
  Gosub LECTOUT
  If STOP
   Call ERREUR(mess(106,139,1)) From GESECRAN : # La trace contient trop de lignes
  Endif
 Endif
Endif
Gosub PREMIER
Return

#--------------------#
$SETBOUT
If !instr(1,CHBOU,"=")
 CHBOU += "=" : # Raffraîchissement
Endif
If !instr(1,CHBOU,"I")
 CHBOU += "I" : # Impression
Endif
If !instr(1,CHBOU,"S")
 CHBOU += "S" : # Suppression
Endif
pcolor = GCOUL(0)
Call ERRBOUT(0, PGSEEK, LERRPAGE, K) : # Y'a-t'il une erreur ?
If !K
 Call VIREBOUT(CHMEN,"E") From GOBJET : # Erreur suivante
Endif
Call WARBOUT(0, PGSEEK, LWARPAGE, K) : # Is there a "next warning" ?
If !K
 Call VIREBOUT(CHMEN,"G") From GOBJET : # Warning suivante
Endif
If CONS or NODEL or OPTERR or OPTREC
 Call VIREBOUT(CHBOU,"S") From GOBJET : # Suppression
Elsif SUP
 ETABOU(GBFIN) = 0 : # On grise le bouton 'Fin' pour montrer que la trace sera supprimée
Endif
If !MAIL
 Call VIREBOUT(CHMEN,"W") From GOBJET : # Workflow
Endif
If STA or PGSEEK+1>=NBPAGE : # On est à la fin de la trace ou sur la dernière page
 Call VIREBOUT(CHBOU,">9") From GOBJET
Endif
If PGSEEK<1 : # On est au début
 Call VIREBOUT(CHBOU,"<0") From GOBJET
Endif
If (STA or PGSEEK+1>=NBPAGE) & PGSEEK<1 : # Y'a qu'une page
 Call VIREBOUT(CHMEN,"P") From GOBJET
Endif
If OPTERR or OPTREC
 Call VIREBOUT(CHMEN,"O") From GOBJET : # Que les erreurs
 Call VIREBOUT(CHMEN,"EG") From GOBJET : # Erreur suivante et Warning suivant
Else
 Call VIREBOUT(CHMEN,"D") From GOBJET : # Détail
Endif
If OPTREC
 Call VIREBOUT(CHMEN,"R") From GOBJET : # Recherche
Endif
GPOINT = "SETBOUT" : Gosub ENTREE From EXEFNC
Return

#--------------------#
$BOUTON
Case BOUT
 When "E"
  CURPAGE = PGSEEK+1
  Call ERRSUI(nolign-1,CURPAGE,LERRPAGE) : # Erreur suivante
  # If the next error is on a following page, move to this page
  If CURPAGE > PGSEEK+1
   PAGE = CURPAGE
   Gosub PAGE_E
  Endif
 When "G"
  CURPAGE = PGSEEK+1
  Call WARSUI(nolign-1,CURPAGE,LWARPAGE) : # Warning suivant
  # If the next warning is on a following page, move to this page
  If CURPAGE > PGSEEK+1
   PAGE = CURPAGE
   Gosub PAGE_W
  Endif
Endcase
Return

#--------------------#
$MENU
Case BOUT
 When "P" : Gosub PAGE_E    : # Page : with cursor pointed to the first error found
 When "R" : Gosub RECHERCHE : # Recherche d'un texte
 When "O" : Gosub ERREURS   : # Erreurs
 When "D" : Gosub ERREURS   : # Détail
 When "W" : Gosub MESSAGE   : # Envoi trace
 When "C" : Gosub COPIE     : # Copie trace
Endcase
Return

#--------------------#
$ANNUL
OK = 2
If !SUP
 Call OUINON(mess(148,100,1),OK) From GESECRAN : # Voulez-vous effacer le fichier de trace ?
 If OK<>2 : Return : Endif
Endif
Openi
Gosub VIREFIC
FIN = 1
Return

#--------------------#
$VIREFIC
SAVTRACE = GTRACE
GTRACE = "" : # JML 24/06/98 pour que ORDSYS ne le recrée pas ...
Call EFFACE(NOMFIC,STA) From ORDSYS
GTRACE = SAVTRACE
Return

#--------------------#
$RAF
Raz NBERR , NBWAR
Gosub LECTOUT
Gosub PAGE_E

#If !GBROWS
 zonsui = "[M]NBLIG("+num$([M]NBLIG)+")"
#Endif
Return

#--------------------#
$RECHERCHE
Call SAICAR(MOTSAI,mess(92,115,1),mess(28,123,1),"A",0,30,"",OK) From GESECRAN : # Recherche texte/Texte
If OK=1 or MOTSAI="" : Return : Endif
OPTREC = 1
MOTREC = MOTSAI
If !instr(1,MOTREC,"*") & !instr(1,MOTREC,"?")
 MOTREC = "*"+MOTREC+"*"
Endif
MOTREC = toupper(ctrans(MOTREC))
Raz NBREC
Gosub LECTOUT
If NBREC=0
 MESSA = MOTSAI-":"-mess(96,115,1) : # Texte non trouvé
Else
 MESSA = num$(NBREC)-mess(95,115,1) : # textes trouvés
Endif
Call MESSAGE(MESSA) From GESECRAN
If NBREC=0
 OPTREC = 0
 Gosub LECTOUT
Endif
Raz NBREC
Gosub PREMIER
Return

#--------------------#
$ERREURS
If OPTERR or OPTREC
 OPTERR = 0
 OPTREC = 0
Else
 # La dernière ligne de la trace est un warning s'il y des erreurs
 WAR = max(0,NBWAR)
 ERR = max(0,NBERR)
 If ERR>0
  MESSA = mess(159,115,1)-num$(ERR) : # Nombre d'erreurs
 Else
  MESSA = mess(55,139,1) : # Aucune erreur
 Endif
 If WAR>0
  MESSA -= "("+num$(WAR)-mess(157,133,1)+")" : # (avertissements)
 Endif
 Call MESSAGE(MESSA) From GESECRAN
 If ERR=0 : Return : Endif
 OPTERR = 1
Endif
Gosub LECTOUT
Gosub PREMIER
Return

#--------------------#
$MESSAGE
SAVTRACE = GTRACE
If !TRA
 GTRACE = NOMFIC
Endif
Call WORKFLOW(1,"TRA","","") From AWRK
GTRACE = SAVTRACE
Return

#--------------------#
$EDIT
SAVTRACE = GTRACE
If EXT="tra" & adxmac(0)=""
    # jira 68128 case of log in arequete and print , the full path is used ..so extension is needed for atrace.rpt
    If instr(1,GTRACE,"/") or instr(1,GTRACE,"\")
       GTRACE = NOMFIC
    Else
       GTRACE = FICH
    Endif
Else
    GTRACE = NOMFIC
Endif
Openi
[M:LFI]OPTERR = OPTERR+1
If PAYSAGE
 Call IMPRIME("ATRACEPAYS",GFONCTION) From ETAT
Else
 Call IMPRIME("ATRACE",GFONCTION) From ETAT
Endif
GTRACE = SAVTRACE
Openi NOMFIC
fstat = 0
REPORT1 = ""
REPORT2 = ""
Return

#--------------------#
$FIN
If SUP
 Call TEMPON("S") From GESECRAN
 Gosub VIREFIC
 Call TEMPOFF From GESECRAN
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
If GTRTIME<>""
 Enable GSTATM2
Endif
GCONF(1) = SAVCONF
If TRA
 GTRACE = ""
 GERRTRACE = 0
Endif
Return


#--------------------#
$LECLIG
ERL = 0
Onerrgo ERL
Rdseq TMP
Onerrgo
If !ERL & !fstat
 If right$(TMP,len(TMP))=chr$(13)
  TMP = left$(TMP,len(TMP)-1)
 Endif
 If len(TMP)>=DIME
  OUT = DIME
 Endif
 If left$(TMP,5)<>"#<Adx" & !PAYSAGE
  If find(left$(TMP,1),"=","<",">")
   If len(TMP)-7>PORTRAIT
    PAYSAGE = 1
   Endif
  Elsif len(TMP)>PORTRAIT
   PAYSAGE = 1
  Endif
 Endif
#  CC 04/06/2004    On enleve les eventuels caracteres binaires qui font planter le browser
 If GBROWS<>0
  TMP = ctrans(TMP,sigma(1,31,chr$(indcum))," ")
 Endif
Endif

Return

$ERL
ERL = errn
TMP = "Read error"
Resume

#--------------------#
$PRECEDENT
PAGE = PGSEEK
Gosub PAGE_E
Return

#--------------------#
$SUIVANT
PAGE = PGSEEK+2
Gosub PAGE_E
Return

#--------------------#
$PREMIER
PAGE = 1
Gosub PAGE_E
Return

#--------------------#
$DERNIER
PAGE = NBPAGE
Gosub PAGE_E
Return

#----------read one page and point the cursor to the first error----------#
$PAGE_E
Gosub PAGE
Call ERRSUI(-1, CURPAGE, LERRPAGE)
Return


#----------read one page and point the cursor to the first warning----------#
$PAGE_W
Gosub PAGE
Call WARSUI(-1, CURPAGE, LWARPAGE)
Return

#-------- read one page with page number stored in variable PAGE------------#
$PAGE
If PAGE>0
 If PAGE>=NBPAGE
  # set to the last page number
  PGSEEK = NBPAGE-1
 Elsif PAGE<=1
  # set to the first page number
  PGSEEK = 0
 Else
  # any other page number
  PGSEEK = PAGE-1
 Endif
 Seek First+NOSEEK(PGSEEK)
 If(PGSEEK = 0)
  Gosub TETE
 Else
  Gosub LECLIG
 Endif
 # read the page
 Gosub LECPAGE
Endif
Return


#--------------------#
$LECTOUT
Raz PGSEEK , NOSEEK , NBPAGE
Raz CPT , ERR , WAR , STOP , PAYSAGE
# no need to count LERRPAGE/LWARPAGE if already done
If NBERR = 0
 Raz LERRPAGE, NERRPAGE
 Raz LWARPAGE, NWARPAGE
Endif
Gosub TETE

While fstat=0
 K = find(left$(TMP,1),"<",">") : # Erreurs et Warning
 If K
  For I=2 To 5
   If mid$(TMP,I,1)<"0" or mid$(TMP,I,1)>"9"
    K = 0
    Break
   Endif
  Next I
 Endif
 If K & (instr(1,TMP,mess(45,126,1)) or instr(1,TMP,mess(60,134,1)))
  # Fin sur erreur de trace
  # Requête terminée avec avertissements
  TMP = right$(TMP,7)
  K = 0
 Endif
 # no need to count the number of errors if already done
 If NBERR=0 & K
  ERR += 1
  If ERR<=MAXERR
   LIG(ERR) = CPT+1
  Endif
  # in case it's a warning...
  If left$(TMP,1)=">"
   WAR += 1
   # add the page number into LWARPAGE if not added yet
   If !find(PGSEEK+1,LWARPAGE)
     NWARPAGE += 1
     LWARPAGE(NWARPAGE) = PGSEEK+1
   Endif
  # in case it's an error...
  Else
   # add the page number into LERRPAGE if not added yet
   If !find(PGSEEK+1,LERRPAGE)
     NERRPAGE += 1
     LERRPAGE(NERRPAGE) = PGSEEK+1
   Endif
  Endif
 Endif
 If OPTREC
  R = (pat(toupper(ctrans(TMP)),MOTREC)=1)
  If R
   NBREC += 1
   If NBREC<=MAXREC
    REC(NBREC) = CPT+1
   Endif
  Endif
 Endif

 If !OPTERR or K
  Gosub INC
  If STOP : Break : Endif
  If K
   TMP = right$(TMP,7)
  Endif
  While len(TMP)>TYL
   Gosub INC
   If STOP : Break 2 : Endif
   TMP = right$(TMP,TYL+1)
  Wend
 Endif
 Gosub LECLIG
Wend
NBPAGE = PGSEEK+1
If NBERR=0
 NBERR = ERR
 NBWAR = WAR
Endif
Return

$INC
CPT += 1
If mod(CPT,MAXLIG)=0
 If PGSEEK>=S_MAXPAG-1 : # Pour ne pas dépasser maxpag
  STOP = 1
 Else
  PGSEEK += 1
  NOSEEK(PGSEEK) = adxseek(0)
 Endif
Endif
Return

#--------------------#
$TETE
Seek First
adxium = GUTF8 : # Quelque soit le format utilisé, l'entête doit être en Uft8 à cause de 'filcom'
Gosub LECLIG
If left$(TMP,5)<>"#<Adx"
 Seek First
Endif
adxium = GTRAFOR
Gosub LECLIG
Return

#--------------------#
$LECPAGE
GMODIF = 0 : # Pour décoloriser
Affzo
Raz [M]NBLIG
Raz nolign
ERR = PGSEEK*MAXLIG
# fill the page line by line
While !fstat & nolign<MAXLIG
 K = find(left$(TMP,1),"<",">","=") : # Erreur , Warning et Message (serveur batch)
 If K
  For I=2 To 5
   If mid$(TMP,I,1)<"0" or mid$(TMP,I,1)>"9"
    K = 0
    Break
   Endif
  Next I
 Endif
 If OPTREC
  R = (pat(toupper(ctrans(TMP)),MOTREC)=1)
 Endif
 If (!OPTERR & !OPTREC) or (OPTERR & K & left$(TMP,1)<>"=") or (OPTREC  & R)
  nolign += 1
  # in case of error/warning: remove the prefix < or >
  If K
   If left$(TMP,1)=">"
    [M]TYPTEX(nolign-1) = -val(seg$(TMP,2,5))
   Elsif left$(TMP,1)="<"
    [M]TYPTEX(nolign-1) = val(seg$(TMP,2,5))
   Else
    [M]TYPTEX(nolign-1) = 0
   Endif
   TMP = right$(TMP,7)
  Else
   [M]TYPTEX(nolign-1) = 0
  Endif
  # fill a line
  [M]LIGNE(nolign-1) = left$(TMP,TYL)
  TMP = right$(TMP,TYL+1)
  While TMP<>"" & nolign<MAXLIG
   nolign += 1
   [M]LIGNE(nolign-1) = left$(TMP,TYL)
   TMP = right$(TMP,TYL+1)
   [M]TYPTEX(nolign-1) = [M]TYPTEX(nolign-2)
  Wend
  If OPTREC & NBREC<MAXREC
   NBREC += 1
   [M]LIGNE(nolign-1) -= "("+num$(REC(NBREC))+")"
  Endif
  # in case extract only the errors/warnings, display also the initial line number
  If OPTERR
   ERR += 1
   If ERR<=MAXERR
    [M]LIGNE(nolign-1) -= "("+num$(LIG(ERR))+")"
   Endif
  Endif

  If nolign>=MAXLIG : Break : Endif
 Endif
 Gosub LECLIG
Wend
[M]NBLIG = nolign
STA = fstat
[M]COMMENT = format$("K:120X",[M]COMMENT)
If [M]NBLIG=MAXLIG or PGSEEK>0
 [M]COMMENT += mess(16,100,1)-num$(PGSEEK+1) : # Page
 [M]COMMENT += "/"+num$(NBPAGE)
Endif
Titcol [M]NBLIG [M]COMMENT
GMODIF = 1 : # Pour coloriser
Affzo
nolign = [M]NBLIG

Return

#-------------------------------find the next error---------------------------------------#
Subprog ERRSUI(NOL,CURPAGE,LERRPAGE)
Value Integer NOL
Variable Integer CURPAGE
Variable Integer LERRPAGE(1..) # shouldn't make any change although defined as Variable
Local Integer I, ERR
Local Integer FOUNDC : # indicator : if next error block is found in the current page
Local Integer FOUNDF : # indicator : if next error block is found in a following page
FOUNDC = 0
FOUNDF = 0

If NOL=-1
 ERR = 0 : NOL = 0
Else
 ERR = ([M]TYPTEX(NOL)>0)
Endif

# find the next error whose previous line is a comment/warning:
For I=NOL To [M]NBLIG-1
 If [M]TYPTEX(I)<=0 and ERR<>0
  ERR = 0
 Elsif [M]TYPTEX(I)>0 and ERR=0
  NOL = I : nolign = I+1
  FOUNDC = 1 : Break
 Endif
Next I

# in case no more error found in the current page, move to the next page in LERRPAGE
If !FOUNDC
 For I=1 To dim(LERRPAGE)
  If LERRPAGE(I)>CURPAGE
   CURPAGE = LERRPAGE(I)
   FOUNDF = 1
   Break
  Endif
 Next I
Endif

If (!FOUNDF)
 zonsui = "NBLIG("+num$(NOL)+")"
Endif

End

#-------------------------------find the next warning---------------------------------------#
Subprog WARSUI(NOL,CURPAGE,LWARPAGE)
Value Integer NOL
Variable Integer CURPAGE
Variable Integer LWARPAGE(1..) # shouldn't make any change although defined as Variable
Local Integer I, WAR
Local Integer FOUNDC : # indicator : if next warning block is found in the current page
Local Integer FOUNDF : # indicator : if next warning block is found in a following page
FOUNDC = 0
FOUNDF = 0

If NOL=-1
 WAR = 0 : NOL = 0
Else
 WAR = ([M]TYPTEX(NOL)<0)
Endif

# find the next warning whose previous line is a comment/error:
For I=NOL To [M]NBLIG-1
 If [M]TYPTEX(I)>=0 and WAR<>0
  WAR = 0
 Elsif [M]TYPTEX(I)<0 and WAR=0
  NOL = I : nolign = I+1
  FOUNDC = 1 : Break
 Endif
Next I

# in case no more warning found in the current page, move to the next page in LWARPAGE
If !FOUNDC
 For I=1 To dim(LWARPAGE)
  If LWARPAGE(I)>CURPAGE
   CURPAGE = LWARPAGE(I)
   FOUNDF = 1
   Break
  Endif
 Next I
Endif

If (!FOUNDF)
 zonsui = "NBLIG("+num$(NOL)+")"
Endif

End

#---------------------------------check if there's still a "next error"---------------------------------#
Subprog ERRBOUT(NOL,CURPAGE,LERRPAGE,OK)
Value    Integer NOL
Value Integer CURPAGE
Variable Integer LERRPAGE(1..) # shouldn't make any change although defined as Variable
Variable Integer OK
Local Integer I, ERR

# boutton "Erreur suivante" is deactivated by default
OK  = 0

If NOL=-1
 ERR = 0 : NOL = 0
Else
 ERR = ([M]TYPTEX(NOL)<0)
Endif

For I=NOL To [M]NBLIG-1
 If [M]TYPTEX(I)<=0 and ERR<>0
  ERR = 0
 Elsif [M]TYPTEX(I)>0 and ERR=0
  # another error block is found in the same page, so activate the boutton
  OK = 1 : Break
 Endif
Next I

If !OK
 For I=1 To dim(LERRPAGE)
  If LERRPAGE(I)>CURPAGE
   # another error block is found in a following page, so activate the boutton
   OK = 1
   Break
  Endif
 Next I
Endif

End

#---------------------------------check if there's still a "next warning"---------------------------------#
Subprog WARBOUT(NOL,CURPAGE,LWARPAGE,OK)
Value    Integer NOL
Value Integer CURPAGE
Variable Integer LWARPAGE(1..) # shouldn't make any change although defined as Variable
Variable Integer OK
Local Integer I, WAR

# boutton "Warning suivant" is deactivated by default
OK  = 0

If NOL=-1
 WAR = 0 : NOL = 0
Else
 WAR = ([M]TYPTEX(NOL)<0)
Endif

For I=NOL To [M]NBLIG-1
 If [M]TYPTEX(I)>=0 and WAR<>0
  WAR = 0
 Elsif [M]TYPTEX(I)<0 and WAR=0
  # another warning block is found in the same page, so activate the boutton
  OK = 1 : Break
 Endif
Next I

If !OK
 For I=1 To dim(LWARPAGE)
  If LWARPAGE(I)>CURPAGE
   # another warning block is found in a following page, so activate the boutton
   OK = 1
   Break
  Endif
 Next I
Endif

End

#---------------------------------------------------------------------------------------------#
Subprog OUVRE_TRACE(COMMENT)
Value Char    COMMENT
Local Integer NUMIMP, ER, ROL, MAXROL
Local Char    FICTRA(250) , TEXTE(200) , SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
GTRACE = ""

# Point d'entrée pour donner un nom
GPE = 0
GPOINT = "OUVRE" : Gosub ENTREE From EXEFNC

If GPE=0 or GTRACE=""
 Onerrgo ERFIL
 Gosub INC_NUMIMP
 Onerrgo
 If ER
  Case ER
   When 1 : Call ERREUR("NUMIMP :"-mess(135,133,1)) From GESECRAN : # Compteur verrouillé
   When 2 : Call ERREUR(mess(13,100,1)-"APLCOM") From GESECRAN    : # Erreur d'écriture sur le fichier
  Endcase
  NUMIMP = 9999
 Endif
 GTRACE = "F"+num$(NUMIMP)
Endif
FICTRA = filpath("TRA",GTRACE,"tra",0)
Openo FICTRA , 0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$("D:"+GFMDAT,date$)-time$-"("+GUSER
If GPRODUIT=1 & dim(GFCY)>0 & dim(GDEP)>0 : ## GEODE
 TEXTE-=GFCY+"/"+GDEP
Endif
TEXTE += ")"-COMMENT
Wrseq TEXTE
Openo
GLTRACE   = filinfo(FICTRA,7)
GERRTRACE = 0
GTRABLK   = 1
If dim(GTRALIG)>1
 Raz GTRANBR , GTRALIG
Endif
adxifs    = SAVIFS
adxirs    = SAVIRS
adxium    = SAVIUM
End

#---------------------------------------------------------------------------#
# Lock Whith lockwait=3 fait une première tentative (écriture) sur APLLCK
# attend 1 seconde, refait une autre tentative (3 au total) sur APLLCK, etc.
# Nombre maximum de tentatives = [s]lockwait * GROLLBACK
#---------------------------------------------------------------------------#

$INC_NUMIMP
Lock NUMIMP With lockwait=[S]lockwait
If fstat
 ROL += 1
 If ROL>GROLLBACK
  ER = 1 : Return
 Else
  Goto INC_NUMIMP
 Endif
Elsif !adxlog
 Gosub TR_NUMIMP
Else
 Gosub MAJ_NUMIMP
Endif
Unlock NUMIMP
Return

#-----------------#
$TR_NUMIMP
Trbegin ADOVAL
 Gosub MAJ_NUMIMP
Commit
Return

#-----------------#
$MAJ_NUMIMP
NUMIMP = [C]NUMIMP
[C]NUMIMP += 1
If fstat : ER = 2 : Endif
Return

#---------------------------------------------------------------------------------------------#
Subprog FERME_TRACE
Local Char    FICTRA(GDIMFIC) , TEXTE(200) , SAVIFS(10) , SAVIRS(10)
Local Integer STA , SAVIUM , SAUT
Openo
FICTRA = filpath("TRA",GTRACE,"tra",0)
If GLTRACE=0 or (filinfo(FICTRA,7)<=GLTRACE & (dim(GTRALIG)<=1 or GTRANBR=0))
 If 1=1
  GTRACE = "" : # Pour que ordsys ne le recréé pas
  Call EFFACE(FICTRA,STA) From ORDSYS
 Else
  TEXTE = mess(207,139,1) : # Traitement terminé sans erreur
  SAUT  = 0
  Gosub FIN_TRACE
 Endif
Else
 If GERRTRACE<>0
  TEXTE = ">0001 "+mess(45,126,1) : # Fin sur erreur de trace
 Else
  TEXTE = mess(44,126,1) : # Fin normale de trace
 Endif
 SAUT = 1
 Gosub FIN_TRACE
Endif
GLTRACE = 0
End

#------------------------------------------#
$FIN_TRACE
Call FLUSH_TRACE From GESECRAN
TEXTE -= format$("D:"+GFMDAT,date$)-time$
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Openo FICTRA
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR
If SAUT & (dim([V]GTRABLK)<0 or !GTRABLK) : Wrseq : Endif
Wrseq TEXTE
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
If clalev([F:ARC])=0 & dim(GFONCTION)>0 : # mb 10.2.14 bug 96473
 Call EVENEMENT(4,GFONCTION,FICTRA,"") From ARCHIVE : # Archive
Endif
Return

#---------------------------------------------------------------------------------------------#
Subprog SAUT_TRACE
# Saute une ligne dans la trace courante, si la dernière ligne de celle-ci n'est pas déjà vide
If GTRACE<>"" & dim([V]GTRABLK)>0 & !GTRABLK
 Call ECR_TRACE("",0) From GESECRAN
Endif
End

#---------------------------------------------------------------------------------------------#
$COPIE
If clalev([M:LECF])=0 or dim([M:LECF]NOMFIC)<=0 or [M:LECF]NOMFIC=""
 Return
Endif
FICCLI = [M:LECF]NOMFIC
Call SET_NAMCLI(FICCLI) From ORDSYS
Call COPCLI([M:LECF]NOMFIC,FICCLI,STA) From ORDSYS
Return

#---------------------------------------------------------------------------------------------#
Subprog EXISTE(CHEMIN,OK)
Variable Char    CHEMIN : # Nom complet du fichier (machine.domaine@répertoire/fichier)
Variable Integer OK

Local Integer ABSOLU , ER , I , K
Local Char    REPERT(GDIMFIC) , NOMFIC(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    NAMCLI(GDIMFIC) , EXTCLI(30) , NOMCLI(GDIMFIC) , REPCLI(GDIMFIC)
Local Char    MACHINE(80) , OS(GDIMFIC)(1..3)

FICHIER = CHEMIN

$CHERCHE
Call MACHINE(FICHIER,MACHINE,NOMFIC) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
Raz ER
If OS=""
 Call ERREUR("|"+MACHINE-"|\"-mess(90,141,1)) From GESECRAN : # Machine inexistante
 OK = 0 : End
Endif
If MACHINE="#"
 Call SETNAM(NOMFIC,NAMCLI,EXTCLI) From GOBJTXT
 If EXTCLI<>""
  NAMCLI += "."+EXTCLI
 Endif
 K = instr(1,NOMFIC,NAMCLI)
 If K
  I = 0
  For CODREP="X3UserDir","X3UserTempDir","X3TempDir"
   Call PARCLI(CODREP+";",REPCLI) From GLOBVAR
   If toupper(left$(NOMFIC,K-2))=toupper(REPCLI)
    I = 1 : Break
   Endif
  Next CODREP
  If I
   Call EXIST_FILECLI(NAMCLI,REPCLI,"","",NOMCLI,ER) From ORDSYS
   If ER : FICHIER = "#@"+NOMCLI : Endif
  Elsif GBROWS
   ER = 0
  Else
   Call EXISTE(FICHIER,ER) From ORDSYS
  Endif
 Else
  For REPCLI="Temp","User","UserTemp"
   Call EXIST_FILECLI(NAMCLI,REPCLI,"","",NOMCLI,ER) From ORDSYS
   If ER : FICHIER = "#@"+NOMCLI : Break : Endif
  Next REPCLI
 Endif
Else
 Call EXISTE(FICHIER,ER) From ORDSYS
Endif
Case ER
 When 2 : # C'est un répertoire
  Call ERREUR("|"+FICHIER-"|\"-mess(55,141,1)) From GESECRAN : # Ce fichier est un répertoire
  OK = 0 : End
 When 1 : # Fichier trouvé
  CHEMIN = FICHIER
  OK = 1 : End
 When Default : # Pas trouvé
  If MACHINE="" & !GBROWS
   FICHIER = "#@"+FICHIER : # On tente un accès sur le poste client , sauf en WEB
   Goto CHERCHE
  Endif
  Call ERREUR(mess(101,100,1)) From GESECRAN : # Fichier inexistant
  OK = 0 : End
Endcase
End

#-----------------------------------------#
Subprog REPERT(FICHIER,REPERT,ABSOLU)
Value    Char    FICHIER
Variable Char    REPERT
Variable Integer ABSOLU
Local Integer I, J
I = len(FICHIER)
J = 0
While I
 If instr(1,"/\",mid$(FICHIER,I,1))
  J = I : Break
 Endif
 I -= 1
Wend
If !J
 ABSOLU = 0
Else
 ABSOLU = 1
 REPERT = left$(FICHIER,J-1)
Endif
End

#-------------------------------------------------------------------------------------------------------#
$SEL_TRA
Local Integer T , S , H , M , ER , SUITE , SEC
Local Date    DAT
Local Char    TIM(20) , ORDSYS(250) , CAR(1) , TIT(100)(5) , COMMENT(100) , CHAINE(30)
Local Char    FICTRA(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , REPERT(GDIMFIC) , APPLI(GLONADS) , EXTENS(10)
Local Char    REVERSE(10) , FILTRE(250) , LIMITE(10) , FILRAP(250)
Local Char    WFIC(GLONTRA)(1..GNBSEL), WCOM(100)(1..GNBSEL), WTAI(20)(1..GNBSEL)
Local Char    WHEU(20)(1..GNBSEL), WORD(10)(1..GNBSEL)
Local File   (Char FIC(GLONTRA), Char COM(100), Char TAI(20), Char HEU(20), Char ORD(10))
&             From Variable WFIC, WCOM ,WTAI, WHEU, WORD As [FT2]
If max(instr(1,VALEUR,"."),instr(1,VALEUR,"/"),instr(1,VALEUR,"\"),instr(1,VALEUR,"@"))
 Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
 Case MACHINE
  When "#" : # Il faut un répertoire
   If (GBROWS & !GADXLOC)
    Call ERREUR(mess(85,150,1)) From GESECRAN : # Fonction non disponible en mode web
    OK = 0 : Return
   Endif
   Call EXISTE(VALEUR,ER) From ORDSYS
   If ER=1 : # Fichier
    Call REPERT(REPERT,REPERT,K)
   Elsif ER=0 : # Non trouvé
    OK = 0 : Return
   Endif
  When Default : # Il faut une appli
   I = len(REPERT)+1
   For CAR=".","/","\"
    K = instr(1,REPERT,CAR)
    If K & K<I
     I = K
    Endif
   Next CAR
   APPLI = toupper(left$(REPERT,I-1))
   If MACHINE="" : MACHINE = adxmac(0) : Endif
   Onerrgo ERFIL
   K = filinfo(filpath("TRA","","",APPLI,"",MACHINE),0)
   Onerrgo
   If ER
    Call ERREUR(errmes$(abs(ER))) From GESECRAN
    OK = 0 : Return
   Elsif K<0
    Call ERREUR(APPLI-"\"+mess(7,125,1)) From GESECRAN : # Dossier inexistant
    OK = 0 : Return
   Endif
   REPERT = "TRA"
   EXTENS = "tra"
 Endcase
 FILTRE = '1=1'
Else
 MACHINE = adxmac(0)
 APPLI   = nomap
 REPERT  = "TRA"
 EXTENS  = "tra"
 If instr(1,VALEUR,"*") or instr(1,VALEUR,"?")
  FILTRE = 'pat(FICHE,"'+VALEUR+'")'
 Elsif VALEUR<>""
  FILTRE = 'FICHE<="'+VALEUR+'"'
 Else
  LIMITE = '-n'+num$(GNBSEL+50) : # Pour aller + vite la première fois
  FILTRE = '1=1'
 Endif
Endif
FILRAP   = '1=1'
FILSUITE = '1=1'
REVERSE  = '-r'
SIZCOL = 380
SIZLIG = 120
Gosub CHARGE_TRA
Default File [FT2]
START = "FIC"
ORDRE = "ORD"
Raz NBCOL , COL , COLTYP , TIT
For CHAINE="FIC","COM","TAI","HEU"
 NBCOL += 1
 COL(NBCOL)    = "[F:FT2]"+CHAINE
 COLTYP(NBCOL) = evalue("type([F:FT2]"+CHAINE+")")
 Case NBCOL
  When 1 : TIT(NBCOL) = mess(55,100,1)  : # Fichier
  When 2 : TIT(NBCOL) = mess(123,124,1) : # Commentaire
  When 3 : TIT(NBCOL) = mess(52,125,1)  : # Taille
  When 4 : TIT(NBCOL) = "Time GMT"
 Endcase
Next CHAINE
TIT  = mess(116,124,1)-"-" : # Choix fichier de trace
If MACHINE<>""
 TIT -= MACHINE+"@"+APPLI
Elsif APPLI<>nomap
 TIT -= APPLI
Endif
Return

#-----------------#
$CHARGE_TRA
If clalev([F:FTR])>0 : Close Local File [FTR] : Endif
Case MACHINE
 When "#"
  ORDSYS = '#@cmd /c dir /a:-d /b'-REPERT
 When Default
  ORDSYS = MACHINE+'@lsadx -t'-REVERSE-LIMITE
  If APPLI<>""
   ORDSYS -= "-a"-APPLI
  Endif
  ORDSYS -= REPERT-EXTENS
Endcase
Local File (FICHE(GLONTRA)) From System ORDSYS As [FTR]
Raz I , J , SUITE
For [FTR] Where FICHE<>"" & evalue(FILTRE)
 J += 1
 FICTRA = filpath(REPERT,FICHE,EXTENS,APPLI,"",MACHINE)
 Gosub SET_TIM
 Gosub SET_COM
 If evalue(FILSUITE) & evalue(FILRAP)
  Gosub SET_TAILLE
  If T>0
   If I>=dim(WORD) or (LIMITE<>"" & J>=dim(WORD))
    SUITE = 1 : Break
   Endif
   I += 1
   WCOM(I) = COMMENT
   WTAI(I) = format$("N3:8",T)-"Ko"
   WORD(I) = format$("N0:#####",I)
   WHEU(I) = TIM
   WFIC(I) = [F:FTR]FICHE
  Endif
 Endif
Next FTR
For J=I+1 To dim(WORD)
 WORD(J) = chr$(255)
Next J
adxmxl = I
Return

#---------------------------------#
$SET_TAILLE
Onerrgo RIEN
T = filinfo(FICTRA,7) : # Taille
If T<>0 : T = max(1,arr(T/1024,1)) : Endif
Onerrgo
Return

$SET_COM
Onerrgo RIEN
COMMENT = filcom(REPERT,FICHE,EXTENS,APPLI,"",MACHINE)
Onerrgo
Return

$RIEN
Resume

$SET_TIM
S = filinfo(FICTRA,9) : # Secondes
H = int(mod(S,3600*24)/3600) : # Heures GMT
M = int(mod(mod(S,3600*24),3600)/60) : # Minutes
SEC = int(mod(S,3600*24))-((H*3600)+(M*60)) : # Secondes
DAT = [01/01/1970]+int(S/(3600*24)) : # Date
TIM = right$(num$(100+H),2)+":"+right$(num$(100+M),2)+":"+right$(num$(100+SEC),2)
TIM = num$(year(DAT))+"-"+right$(num$(100+month(DAT)),2)+"-"+right$(num$(100+day(DAT)),2)-TIM
Return

#-----------------#
$FIN_TRA
Case GSTATUT
 When GSTALFT, GSTALF2
  Case MACHINE
   When adxmac(0)
   When "#"       : VALEUR = "#@"+REPERT+"\"+VALEUR
   When Default   : VALEUR = filpath(REPERT,VALEUR,EXTENS,APPLI,"",MACHINE)
  Endcase
Endcase
Return

#-----------------#
$SVG_TRA
If !SUITE
 Return
Endif
LIMITE = ""
If adxmxl
 FILSUITE = 'TIM<"'+WHEU(adxmxl)+'"'
Else
 FILSUITE = '1=1'
Endif
REVERSE = '-r'
Gosub CHARGE_TRA
Default File [FT2]
Return

#-----------------#
$PRG_TRA
LIMITE = ""
FILSUITE = 'TIM>"'+WHEU(1)+'"'
REVERSE = ''
Gosub CHARGE_TRA
If adxmxl
 FILSUITE = 'TIM<="'+WHEU(adxmxl)+'"'
Else
 FILSUITE = '1=1'
Endif
REVERSE = '-r'
Gosub CHARGE_TRA
Default File [FT2]
Return

#-----------------#
$SRA_TRA
If CRIRAP<>""
 FILRAP = CRIRAP
 For I=1 To NBCOL
  Case I
   When 1 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[F]FICHE")
   When 2 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]COMMENT")
   When 3 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]TIM")
  Endcase
 Next I
 CRIRAP = ''
Else
 FILRAP = '1=1'
Endif
FILSUITE = '1=1'
REVERSE  = ''
LIMITE   = ''
Gosub CHARGE_TRA
Default File [FT2]
Return

#---------------------------------------------------------------------------------------------#
Subprog LECTRACE
Case GBIDC1
 When "L" : Call LIRE_TRACE
Endcase
End

# Lecture trace avec boîte de dialogue pour choisir le nom de la trace
Subprog LIRE_TRACE
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
SAVACT = GACTION
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","LECTRA",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

## JML 04/10/99 Lecture fichier sur client
Subprog LECFIC_CLI(REPERT,FICH,EXT)
Value Char    REPERT(), FICH(), EXT()
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
SAVACT = GACTION
PARAM(1) = REPERT
PARAM(2) = FICH
PARAM(3) = EXT
PARAM(4) = "#"
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

# Lecture fichier pas forcément trace
Subprog LECFIC(REPERT,FICH,EXT)
Value Char    REPERT(), FICH(), EXT()
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
Local Integer K
SAVACT = GACTION
K = instr(1,REPERT,"@")
If K
 PARAM(1) = right$(REPERT,K+1)
 PARAM(4) = left$(REPERT,K-1)
Else
 PARAM(1) = REPERT
 PARAM(4) = ""
Endif
PARAM(2) = FICH
PARAM(3) = EXT
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

# Lecture fichier avec suppression
Subprog SUPPFIC(REPERT,FICH,EXT)
Value Char    REPERT(), FICH(), EXT()
Local Char PARAM(250)(1..5) , VALEUR(10) , SAVACT(20)
Local Integer K
SAVACT = GACTION
K = instr(1,REPERT,"@")
If K
 PARAM(1) = right$(REPERT,K+1)
 PARAM(4) = left$(REPERT,K-1)
Else
 PARAM(1) = REPERT
 PARAM(4) = ""
Endif
PARAM(2) = FICH
PARAM(3) = EXT
PARAM(5) = "S"
GACTION = "LECTRA"
Call TRAITE_CHAR(VALEUR,PARAM,"LECFIC","LECFIC","",4,"XYLECFIC") From GTRAITE
GACTION = SAVACT
End

# Contrôle existence fichier trace
Subprog C_FICHIER(FICH)
Variable Char FICH()
Local    Char FICTRA(GDIMFIC)
FICTRA = filpath("TRA",FICH,"tra",0)
If filinfo(FICTRA,0)<0
 GMESSAGE = mess(101,100,1) : # Fichier inexistant
 mkstat = 2 : End
Endif
End

#---------------------------------------------------------------------------------------------#
Subprog IMPRIME(NBPAR,PARAMETRES)
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Call IMPRIME(NBPAR,PARAMETRES) From ATRACE
End

#---------------------------------------------------------------------------------------------#
Subprog LECTRA_VT
Local Char    NOMFIC(GDIMFIC)
Local Char    TMP(250), MSG(250)
Local Integer I , K , ER , ERL

If GTRACE="" & (dim(GTRAVT)<=0 or GTRAVT="") : End : Endif

If GERRTRACE>0
 NOMFIC = filpath("TRA",GTRACE,"tra",nomap,"",adxmac(0))
 Onerrgo ERFIL
 K = filinfo(NOMFIC,0)
 Onerrgo
 If !ER & K>0
  Openi NOMFIC Using [TRA_]
  Iomode adxifs "" Using [TRA_]
  Iomode adxirs chr$(10) Using [TRA_]
  Iomode adxium GUTF8 Using [TRA_]
  Rdseq TMP Using [TRA_]
  Iomode adxium GTRAFOR Using [TRA_]
  While fstat=0
   If left$(TMP,1)="<"
    TMP = right$(TMP,6)
    If TMP<>"" : ER=1 : Break : Endif
   Endif
   Onerrgo ERL
   Rdseq TMP Using [TRA_]
   Onerrgo
  Wend
  Openi Using [TRA_]
  If !ER : TMP = "" : Endif
 Endif
Endif

MSG = ""
If GTRACE<>""
 MSG = mess(21,134,1)-GTRACE : # Trace
Endif
If GERRTRACE>0
 If MSG<>"" : MSG += "\" : Endif
 MSG += mess(159,115,1)-num$(GERRTRACE) : # Nombre d'erreurs :
 If TMP<>"" : MSG += "\ \|"+TMP+"|" : Endif
Endif
If dim(GTRAVT)>0 & GTRAVT<>""
 If MSG<>"" : MSG += "\" : Endif
 MSG += "|"+GTRAVT+"|"
Endif
Call MESSAGE(MSG) From GESECRAN
End

#---------------------------------------------------------------------------------------------#
# Etiquettes écran LECFIC , LECTRA
#---------------------------------------------------------------------------------------------#

Subprog AV_LIGNE(VALEUR)
Variable Char     VALEUR
Local Integer K
K = instr(1,[M]FORMAT,"c")
If K
 [M]FORMAT = left$([M]FORMAT,K-1)+right$([M]FORMAT,K+1)
Endif
K = instr(1,[M]FORMAT,":")
If [M]TYPTEX(nolign-1)<>0
 [M]FORMAT = left$([M]FORMAT,K-1)+"c"+right$([M]FORMAT,K)
 If [M]TYPTEX(nolign-1)>0
  # Erreur
  pcolor = GCOUL(1*GMODIF) : # Rouge
 Else
  # Warning
  Case [M]TYPTEX(nolign-1)
   When -2      : pcolor = GCOUL(3*GMODIF) : # Vert
   When Default : pcolor = GCOUL(2*GMODIF) : # Bleu
  Endcase
 Endif
Endif
End

Subprog AS_FICHIER(VALEUR)
Variable Char     VALEUR
End

Subprog AM_LIGNE(VALEUR)
Variable Char     VALEUR
mkstat = 2
End

