$ACTION
Case ACTION
Endcase
Return
############################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return
############################################################
# 27544 MM 01.05
Subprog IB_BASPAG
Gosub SET_NOL

GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
If NOL>=0 & [M:ORDS]YEA(NOL) <> 0
  GBOUT1 = mess(319,198,1)     # Calendrier du mois
  GBOUT2 = mess(238,198,1)     # Encours
  GBOUT3 = mess(283,198,1)     # Regrouper
Endif
End
#############################################################
Subprog AS_BASPAG
If nolign > 0    
#test sylvie 070300
  [M]FILTAB = "[F:ORD]WIPTYP=1&[F:ORD]WIPSTA="+num$([M]TYP(nolign-1))
#  [M]FILTAB = "[F:ORD]WIPTYP=1&[F:ORD]WIPSTA="+num$([M]TYP(nolign-1))+
#&             "&[F:ORD]ENDDAT>=GBIDA1&[F:ORD]ENDDAT<=GBIDA2"
  GBIDA1 = [M]DAYSTR(nolign-1)
  GBIDA2 = [M]DAYEND(nolign-1)
Endif
End
############################################################
Subprog APRES_BASPAG

Gosub SET_NOL

[M:ORDS]TOTQTY(NOL) = [M:ORDS]WEEQTY1(NOL)+[M:ORDS]WEEQTY2(NOL)+
&                     [M:ORDS]WEEQTY3(NOL)+[M:ORDS]WEEQTY4(NOL)+
&                     [M:ORDS]WEEQTY5(NOL)
Gosub CAL_TOTAL From SUBORZ    # MM WEB 06.03
Affzo [M:ORDS]TOTQTY(NOL),TOTPRC(NOL) :# TOTPRC rajouté le 31/01/00 (TB)
Affzo [M:ORDS]PERQTY

# MM WEB 10.03 + MM 21214 Derniers lus 03.04
If (currbox="GAU_CHE"|currbox="GAU_CHE9")   
 If [M:ORDS]CREFLG(NOL)=0 
    If [M:ORDS]DAYSTR(NOL)< [M:ORDS]STRDAT &  [M:ORDS]DAYSTR(NOL)<>[0/0/0]
        [M:ORDS]STRDAT= [M:ORDS]DAYSTR(NOL)
    Endif
    If [M:ORDS]DAYEND(NOL)> [M:ORDS]ENDDAT 
        [M:ORDS]ENDDAT= [M:ORDS]DAYEND(NOL)
     Endif
    Affzo [M:ORDS]STRDAT,ENDDAT
 Endif
Endif
#

End

###############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    mkstat=2
    GMESSAGE = mess(215,193,1) : GERR=1
Endif

End

##############################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
#If currbox="GAU_CHE1" : Grizo [M:ORDS]ITMREF : mkstat=2 : Endif

End

##############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

Read [ITM]ITM0= VALEUR
  If fstat 
    mkstat = 2 
    GMESSAGE = mess(134,100,1) : GERR=1 : End
  Endif
Read [ITF]ITF0=VALEUR;[M:ORDS]STOFCY
  If fstat 
    mkstat = 2 
    GMESSAGE = mess(2,196,1)+" : "+[M:ORDS]STOFCY : GERR=1 : End
  Endif
Read [TUN]TUN0=[F:ITM]STU
  If fstat 
    fstat = 0
    Raz [F:TUN]
  Endif

End

############################################################
Subprog AS_WEEQTY1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If [M:ORDS]TYP(NOL) = 3 & (currbox="GAU_CHE" |currbox="GAU_CHE9")    # 21214 03.04 MM Derniers lus
  End
Else 
  mkstat = 2
Endif
End
