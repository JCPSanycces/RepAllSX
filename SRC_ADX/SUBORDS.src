############################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:ORDS]STRDAT & VALEUR <>[0/0/0]
    mkstat = 2
    GMESSAGE = mess(44,199,1)
    GERR=1    # MM WEB 06.03
Endif
End
############################################################
Subprog AV_YEAMONTXT(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
If [M:ORDS]MON(NOL)<> 0 & [M:ORDS]YEA(NOL) <> 0
  VALEUR = month$([M:ORDS]MON(NOL))
Endif
End
############################################################
Subprog C_BASPAG
#Case status 
#  When 65, 73, 82 : Grizo [M:ORDS]10
#Endcase
Case status 
  When 65, 68, 83 : If find([M:ORDS]TYP(nolign-1),1,2) : mkstat=2 : Endif
Endcase

End

############################################################
Subprog AV_YEA(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If nolign > 0
  Case [M:ORDS]TYP(nolign-1) 
    When 1 : 
      pcolor = GCOUL(1)
    When 2 :
      pcolor = GCOUL(3)
    When Default :
      pcolor = GCOUL(0)
  Endcase
Endif
Inftxt "" At 2
If VALEUR = 0
  If NOL = 0
    VALEUR = year(date$)
  Else
    If [M:ORDS]MON(NOL-1) = 12
      VALEUR = [M:ORDS]YEA(NOL-1)+1
    Else
      VALEUR = [M:ORDS]YEA(NOL-1)
    Endif
  Endif
Endif
End
############################################################
Subprog AS_YEA(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If [M:ORDS]YEAMONTXT(NOL) <> ""
  mkstat = 2
Endif
End
############################################################
Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR < year(date$)
  mkstat = 2
Endif
End
############################################################
Subprog AV_MON(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If VALEUR = 0
  If NOL = 0
    VALEUR = month(date$)
  Else
    If [M:ORDS]MON(NOL-1) = 12
      VALEUR = 1
    Else
      VALEUR = [M:ORDS]MON(NOL-1)+1
    Endif
  Endif
Endif

End
############################################################
Subprog AS_MON(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If [M:ORDS]YEAMONTXT(NOL) <> ""
  mkstat = 2
Endif
End
############################################################
Subprog C_MON(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If VALEUR < 1 | VALEUR > 12
  mkstat = 2
  End
Endif
#
Local Date    WDAT,  WDATD, WDATF
Local Integer WSEMD, WSEMF, WYEA, WMON, WWEE
Local Integer WIND, I
#
For I = 0 To [M:ORDS]BASPAG
# <MG> 25/04/00
  If [M:ORDS]YEA(I) = [M:ORDS]YEA(NOL) &
&    [M:ORDS]MON(I) = VALEUR           & 
&    [M:ORDS]TYP(I) = 3                &
&    I <> NOL
    mkstat = 2
    GMESSAGE = mess(24,123,1)-num$(I) 
    GERR=1    # MM WEB 06.03
    End
  Endif 
Next I


[M:ORDS]MON(NOL)       = VALEUR
[M:ORDS]TYP(NOL)       = 3
[M:ORDS]YEAMONTYP(NOL) = ([M:ORDS]YEA(NOL)*1000)+([M:ORDS]MON(NOL)*10)
WDAT = gdat$(15,[M:ORDS]MON(NOL),[M:ORDS]YEA(NOL))
Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WWEE) From CBNLIB
WIND = NOL
Gosub CAL_DAT From SUBORZ    #  MM WEB 06.03
#

Affzo [M:ORDS]YEAMONTXT(NOL)
Affzo [M:ORDS]TYPDES(NOL)
Affzo [M:ORDS]DAYSTR(NOL)
Affzo [M:ORDS]DAYEND(NOL)
End
############################################################
Subprog AV_TYPDES(VALEUR)
Variable Char     VALEUR
Gosub SET_NOL
Case [M:ORDS]TYP(NOL)
  When 1 : VALEUR = mess(1,317,1) 
  When 2 : VALEUR = mess(2,317,1)  
  When 3 : VALEUR = mess(56,190,1)
Endcase
End
############################################################
Subprog AV_WEEQTY1(VALEUR)
Variable Decimal VALEUR
If [M:ORDS]DISFLG <> 0
  Gosub SET_NOL
  Inftxt format$("D:"+GFMDAT4,[M:ORDS]WEESTR1(NOL))-" - "-
&        format$("D:"+GFMDAT4,[M:ORDS]WEEEND1(NOL)) At 2
Endif
End
