#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
Endcase
Return


$IMPORT
Case IMPFIC
 When "BDO" : 

  If GREP="M" & [F:BDO]LIN>=1 & [F:BDO]LIN<=[M]NBLIG : # Modif ligne existante
   nolign = [F:BDO]LIN
  Else                                               : # Ajout d'une ligne
   If [M]NBLIG>=dim([M]CPY)
    If GREP<>""
     Call ECR_TRACE([F:BDO]NUM-mess(33,106,1),1) From GESECRAN
     # Tableau de saisie des lignes plein
    Endif
    OK = 0 : Return
   Endif
   [M]NBLIG += 1
   nolign = [M]NBLIG
  Endif
 
 Endcase
Return


