#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLPUR03   Contrôle Pre-migration Commandes ouvertes   Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
      Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLPUR03") From LECFIC
  Endif

  Call MAJ_UUMGCTLPUR03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLPUR03(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(5)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLPUR03 Purchase Orders Process : PORDER-C-P-Q") From DOSSUB
Call ECR_TRACE("UUMGCTLPUR03 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1 :#PORDER without PORDERC
Gosub CTL2 :#PORDERC without PORDER
Gosub CTL3 :#PORDERP without PORDER
Gosub CTL4 :#PORDERQ without PORDER

$FIN
Call ECR_TIME("UUMGCTLPUR03 : Purchase Orders Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PORDER")   : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PORDERC")  : Return : Endif


REQSQL(0)="SELECT POH.POHNUM_0 FROM "-DOSSIER+".PORDER POH "
REQSQL(1)="WHERE POHTYP_0=2 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDERC POC WHERE POH.POHNUM_0=POC.POHNUM_0) "
REQSQL(2)="ORDER BY POH.POHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PORDER without PORDERC",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPOHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"POHNUM="-[BXX]VPOHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PORDER")   : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PORDERC")  : Return : Endif

REQSQL(0)="SELECT POC.POHNUM_0 FROM "-DOSSIER+".PORDERC POC "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER POH WHERE POH.POHNUM_0=POC.POHNUM_0) "
REQSQL(2)="ORDER BY POC.POHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PORDERC without PORDER",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPOHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"POHNUM="-[BXX]VPOHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

###################################################################################
$CTL3
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PORDER")   : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PORDERP")  : Return : Endif

REQSQL(0)="SELECT DISTINCT POP.POHNUM_0,POP.POPLIN_0 FROM "-DOSSIER+".PORDERP POP "
REQSQL(1)="WHERE POHTYP_0=2 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER POH WHERE POH.POHNUM_0=POP.POHNUM_0) "
REQSQL(2)="ORDER BY POP.POHNUM_0,POP.POPLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PORDERP without PORDER",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPOHNUM(50),Integer VPOPLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"POHNUM/POPLIN="-[BXX]VPOHNUM+'/'+num$([BXX]VPOPLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

###################################################################################
$CTL4
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PORDER")   : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PORDERQ")  : Return : Endif


REQSQL(0)="SELECT DISTINCT POQ.POHNUM_0,POQ.POPLIN_0 FROM "-DOSSIER+".PORDERQ POQ "
REQSQL(1)="WHERE POHTYP_0=2 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER POH WHERE POH.POHNUM_0=POQ.POHNUM_0) "
REQSQL(2)="ORDER BY POQ.POHNUM_0,POQ.POPLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PORDERQ without PORDER",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPOHNUM(50),Integer VPOPLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"POHNUM/POPLIN="-[BXX]VPOHNUM+'/'+num$([BXX]VPOPLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

