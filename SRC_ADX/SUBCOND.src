#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
# Sous-programmes utilisés pour calculer les valeurs                       Module CRM  8 Septembre 2000  #
#                                des champs des contrats de services.
##########################################################################################################
#
# SETSTRDAT  : Calcul la date de début du contrat de sevrice.
# SETENDDAT  : Calcul la date de fin du contrat de service.
# SLASINVDAT : Calcul la date de dernière facture.                                           (Pas utilisé)
# SNEXINVDAT : Calcul la date de prochaine facture.
# NEX2INVDAT : Calcul la date de prochaine facture.
# SNEXSHIINV : Calcul la date du prochain envoi de facture.
# SNEXINVAMT : Calcul le montant de la prochaine facture.
# SLASVALIDX : Calcul la valeur de l'indice utilisé.
# SLASIDXDAT : Calcul la date de la valeur de l'indice utilisé.
# SITTDATEND : Calcul la date de fin d'intervention sur site pour problèmes non bloquants.
# SITDATENDX : Calcul la date de fin d'intervention sur site pour problèmes bloquants.
# SETAMTPLY  : Calcul les pénalités de retard pour problèmes non bloquants dans la devise de la commande.
# SETAMTPLYX : Calcul les pénalités de retard pour problèmes bloquants dans la devise de la commande.
# SETCOVAMT  : Calcul les franchises de prestations couvertes par article dans la devise du contrat.
# CPTAMT11   : Calcul les informations pour un contrat en terme à échoir et post réévaluation (Modif manuelle)
# FCPTAMT11  : Calcul les informations pour un contrat en terme à échoir et post réévaluation (Facturation)
# CPTAMT21   : Calcul les informations pour un contrat en terme échu et post réévaluation (Modif manuelle)
# FCPTAMT21  : Calcul les informations pour un contrat en terme échu et post réévaluation (Facturation)
# CPTAMT12   : Calcul les informations pour un contrat en terme à échoir et pré-réévaluation (Modif manuelle)
# FCPTAMT12  : Calcul les informations pour un contrat en terme à échoir et pré-réévaluation (Facturation)
# CPTAMT22   : Calcul les informations pour un contrat en terme échu et pré-réévaluation (Modif manuelle)
# FCPTAMT22  : Calcul les informations pour un contrat en terme échu et pré-réévaluation (Facturation)
#
# CTRLDATCON : Verifie si les informations de date et durée sont cohérentes
##########################################################################################################
##########################################################################################################
# Calcul la date de début du contrat de sevrice.
##########################################################################################################
Subprog SETSTRDAT(DSIUDAT, DSTRDAT)
Value Date DSIUDAT
Variable Date DSTRDAT

  If DSTRDAT = [00/00/00] Then
    DSTRDAT = DSIUDAT
  Endif
End

##########################################################################################################
# Calcul la date de fin du contrat de service.
##########################################################################################################
Subprog SETENDDAT(DSTRDAT, IREWFRY, IBASREWFRY, DENDDAT)
Value Date DSTRDAT
Value Integer IREWFRY
Value Integer IBASREWFRY
Variable Date DENDDAT

Local Date DBUFDAT

  #Définit la date de fin de contrat par défaut en fonction de la fréquence de renouvellement
  #Met à jour la date de début et de fin du contrat
  If IBASREWFRY = 1 Then
    # heure
    DENDDAT = DSTRDAT
  Elsif IBASREWFRY = 2 Then
    # jour
    If IREWFRY > 1
      DENDDAT = DSTRDAT + (IREWFRY - 1)
    Else
      DENDDAT = DSTRDAT
    Endif
  Elsif IBASREWFRY = 3 Then
    # semaine
    DENDDAT = DSTRDAT + ((IREWFRY * 7) - 1)
  Elsif IBASREWFRY = 4 Then
    # mois
    DBUFDAT = addmonth(DSTRDAT, IREWFRY)
    DENDDAT = DBUFDAT - 1
  Elsif IBASREWFRY = 5 Then
    # ans
    DBUFDAT = gdat$(day(DSTRDAT), month(DSTRDAT), year(DSTRDAT) + IREWFRY)
    DENDDAT = DBUFDAT - 1
  Elsif IBASREWFRY = 6 Then
    # vide
    DSTRDAT = [00/00/00]
    DENDDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul la date de dernière facture
##########################################################################################################
Subprog SLASINVDAT(DLASINVDAT)
Variable Date DLASINVDAT

  DLASINVDAT = date$
End

##########################################################################################################
# Calcul la date de prochaine facture
##########################################################################################################
Subprog SNEXINVDAT(DLASINVDAT, IINVFRY, IBASINVFRY, DSIUDAT, DCONSTRDAT, DNEXINVDAT)
Value Date DLASINVDAT
Value Integer IINVFRY
Value Integer IBASINVFRY
Value Date DSIUDAT
Value Date DCONSTRDAT
Variable Date DNEXINVDAT

Local Date SWDATORI # FGR 29/08/2008 : X3SUIVI48882

  If DLASINVDAT = [00/00/00] Then
    If DCONSTRDAT = [00/00/00] Then
      DNEXINVDAT = DSIUDAT
    Else
      DNEXINVDAT = DCONSTRDAT
    Endif
    End
  Endif
  If IINVFRY = 0 Then
    DNEXINVDAT = DLASINVDAT
    End
  Endif
  #
  If IBASINVFRY = 1 Then
    # heure
    If IINVFRY < 24 Then
      DNEXINVDAT = DLASINVDAT
    Else
      DNEXINVDAT = DLASINVDAT + (IINVFRY / 24)
    Endif
  Elsif IBASINVFRY = 2 Then
    # jour
    DNEXINVDAT = DLASINVDAT + IINVFRY
  Elsif IBASINVFRY = 3 Then
    # semaine
    DNEXINVDAT = DLASINVDAT + (IINVFRY * 7)
  Elsif IBASINVFRY = 4 Then
    # mois
    #DNEXINVDAT = addmonth(DLASINVDAT, IINVFRY)
    #
    # FGR 29/08/2008 : X3SUIVI48882 : correction problème de date prochaine facture lorsque ça tombait en fin de mois
    If DCONSTRDAT = [00/00/00] Then
      SWDATORI = DSIUDAT
    Else
      SWDATORI = DCONSTRDAT
    Endif
    If SWDATORI = eomonth(SWDATORI) Then
      # Si la date d'origine est le dernier jour du mois
      # => Les factures suivantes doivent toujours être sur le DERNIER jour du mois
      DNEXINVDAT = eomonth(gdat$(1, month(DLASINVDAT)+IINVFRY, year(DLASINVDAT)))
    Else
      # Si la date d'origine n'est pas sur le dernier jour du mois
      # => les factures suivantes doivent toujours être sur le MEME jour du mois, mais IINVFRY mois plus loin
      #    (Donc pas de changement par rapport à ce qui se faisait jusque là).
      DNEXINVDAT = addmonth(DLASINVDAT, IINVFRY)
    Endif
  Elsif IBASINVFRY = 5 Then
    # ans
    DNEXINVDAT = gdat$(day(DLASINVDAT), month(DLASINVDAT), year(DLASINVDAT) + IINVFRY)
  Elsif IBASINVFRY = 6 Then
    # vide
    DNEXINVDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul la date de prochaine facture
##########################################################################################################
Subprog NEX2INVDAT(DLASINVDAT, IINVFRY, IBASINVFRY, DSIUDAT, DCONSTRDAT, DNEXINVDAT)
Value Date DLASINVDAT
Value Integer IINVFRY
Value Integer IBASINVFRY
Value Date DSIUDAT
Value Date DCONSTRDAT
Variable Date DNEXINVDAT

Local Date SWDATORI # FGR 29/08/2008 : X3SUIVI48882

  If DLASINVDAT = [00/00/00] Then
    If DCONSTRDAT = [00/00/00] Then
      DLASINVDAT = DSIUDAT
    Else
      DLASINVDAT = DCONSTRDAT
    Endif
  Endif
  If IINVFRY = 0 Then
    DNEXINVDAT = DLASINVDAT
    End
  Endif
  #
  If IBASINVFRY = 1 Then
    # heure
    If IINVFRY < 24 Then
      DNEXINVDAT = DLASINVDAT
    Else
      DNEXINVDAT = DLASINVDAT + (IINVFRY / 24)
    Endif
  ElsIf IBASINVFRY = 2 Then
    # jour
    DNEXINVDAT = DLASINVDAT + IINVFRY
  Elsif IBASINVFRY = 3 Then
    # semaine
    DNEXINVDAT = DLASINVDAT + (IINVFRY * 7)
  Elsif IBASINVFRY = 4 Then
    # mois
    #DNEXINVDAT = addmonth(DLASINVDAT, IINVFRY)
    #
    # FGR 29/08/2008 : X3SUIVI48882 : correction problème de date prochaine facture lorsque ça tombait en fin de mois
    If DCONSTRDAT = [00/00/00] Then
      SWDATORI = DSIUDAT
    Else
      SWDATORI = DCONSTRDAT
    Endif
    If SWDATORI = eomonth(SWDATORI) Then
      # Si la date d'origine est le dernier jour du mois
      # => Les factures suivantes doivent toujours être sur le DERNIER jour du mois
      DNEXINVDAT = eomonth(gdat$(1, month(DLASINVDAT)+IINVFRY, year(DLASINVDAT)))
    Else
      # Si la date d'origine n'est pas sur le dernier jour du mois
      # => les factures suivantes doivent toujours être sur le MEME jour du mois, mais IINVFRY mois plus loin
      #    (Donc pas de changement par rapport à ce qui se faisait jusque là).
      DNEXINVDAT = addmonth(DLASINVDAT, IINVFRY)
    Endif
  Elsif IBASINVFRY = 5 Then
    # ans
    DNEXINVDAT = gdat$(day(DLASINVDAT), month(DLASINVDAT), year(DLASINVDAT) + IINVFRY)
  ElsIf IBASINVFRY = 6 Then
    # vide
    DNEXINVDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul la date du prochain envoi de facture
##########################################################################################################
Subprog SNEXSHIINV(DNEXINVDAT, IINVLTI, IBASINVLTI, DNEXSHIINV)
Value Date DNEXINVDAT
Value Integer IINVLTI
Value Integer IBASINVLTI
Variable Date DNEXSHIINV

  If DNEXINVDAT = [00/00/00] Then
    # FGR 27/08/2008 : X3SUIVI48780 : On ne fait rien dans ce cas, ça fait planter dans les cas 4 et 5
    DNEXSHIINV = DNEXINVDAT
    End
  Endif
  If IINVLTI = 0
    DNEXSHIINV = DNEXINVDAT
    End
  Endif
  If IBASINVLTI = 1 Then
    #heure
    If IINVFRY < 24 Then
      DNEXSHIINV = DNEXINVDAT
    Else
      DNEXSHIINV = DNEXINVDAT - (IINVLTI / 24)
    Endif
  Elsif IBASINVLTI = 2 Then
    #jour
    DNEXSHIINV = DNEXINVDAT - IINVLTI
  Elsif IBASINVLTI = 3 Then
    #semaine
    DNEXSHIINV = DNEXINVDAT - (IINVLTI * 7)
  Elsif IBASINVLTI = 4 Then
    #mois
    DNEXSHIINV = gdat$(day(DNEXINVDAT), month(DNEXINVDAT) - IINVLTI, year(DNEXINVDAT))
  Elsif IBASINVLTI = 5 Then
    #ans
    DNEXSHIINV = gdat$(day(DNEXINVDAT), month(DNEXINVDAT), year(DNEXINVDAT) - IINVLTI)
  Elsif IBASINVLTI = 6 Then
    #vide
    DNEXSHIINV = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul le montant de la prochaine facture
##########################################################################################################
Subprog SNEXINVAMT(YEABAS, IINVFRY, IBASINVFRY, COEF, AMOUNT)
Value Decimal YEABAS
Value Integer IINVFRY
Value Integer IBASINVFRY
Value Decimal COEF
Variable Decimal AMOUNT

Local Integer INBDAY
Local Integer INBYEAR
Local Integer ILEFTDAYS
Local Decimal AM
Local Decimal AM2
Local Decimal AM3
Local Decimal IDECAMOUNT

  INBDAY = 0
  INBYEAR = 0
  ILEFTDAYS = 0
  AM = 0
  AM2 = 0
  AM3 = 0
  IDECAMOUNT = 0
  #Calcul le nombre de jours à facturer
  If IBASINVFRY = 1 Then
    #heure
    If IINVFRY <= 24 Then
      AM = YEABAS * COEF
      IDECAMOUNT = AM / 365.25
    Else
      INBDAY = IINVFRY / 24
      AM = YEABAS * COEF
      IDECAMOUNT = AM * (INBDAY / 365.25)
    Endif
  Elsif IBASINVFRY = 2 Then
    #jours
    AM = YEABAS * COEF
    IDECAMOUNT = AM * (IINVFRY / 365.25)
  Elsif IBASINVFRY = 3 Then
    #semaine
    AM = YEABAS * COEF
    IDECAMOUNT = AM * ((IINVFRY * 7) / 365.25)
  Elsif IBASINVFRY = 4 Then
    #mois
    AM = YEABAS * COEF
    IDECAMOUNT = AM * (IINVFRY / 12)
  Elsif IBASINVFRY = 5 Then
    #année
    AM = YEABAS * COEF
    IDECAMOUNT = AM * IINVFRY
  Elsif IBASINVFRY = 6 Then
    #vide
    AMOUNT = 0
    End
  Endif
  AMOUNT = arr(IDECAMOUNT,10^-GDECPRI)
End

##########################################################################################################
# Calcul la valeur de l'indice utilisé
##########################################################################################################
Subprog SLASVALIDX(SZINDTYP, DDAT, ILASVALIDX)
Value Char SZINDTYP
Value Date DDAT
Variable Decimal ILASVALIDX

Local Integer IC
Local Decimal IIDXVAL

  IC = 0
  IIDXVAL = 0
  If !clalev([F:CIX]) : Local File CONTIDX [CIX] : Endif
  #Définit la nouvelle base de redevance annuelle
  Filter [CIX] Where [F:CIX]IND = SZINDTYP and [F:CIX]INDDAT <= DDAT Order By [F:CIX]INDDAT Desc
  For [CIX] Hint Key CIX1
    IIDXVAL = [F:CIX]INDVAL
    IC += 1
    Break
  Next
  Filter [CIX]
  If IC > 0 Then
    If IIDXVAL > 0 Then
      ILASVALIDX = IIDXVAL
    Endif
  Endif
End

##########################################################################################################
# Calcul la date de la valeur de l'indice utilisé.
##########################################################################################################
Subprog SLASIDXDAT(SZINDTYP, DDAT, DLASIDXDAT)
Value Char SZINDTYP
Value Date DDAT
Variable Date DLASIDXDAT

Local Integer IC
Local Decimal IIDXVAL
Local Date DIDXDAT

  IC = 0
  DIDXDAT = [00/00/00]
  IIDXVAL = 0
  If !clalev([F:CIX]) : Local File CONTIDX [CIX] : Endif
  #Définit la nouvelle base de redevance annuelle
  Filter [CIX] Where [F:CIX]IND = SZINDTYP and [F:CIX]INDDAT <= DDAT Order By [F:CIX]INDDAT Desc
  For [CIX] Hint Key CIX1
    IIDXVAL = [F:CIX]INDVAL
    DIDXDAT = [F:CIX]INDDAT
    IC += 1
    Break
  Next
  Filter [CIX]
  If IC > 0 Then
    If IIDXVAL > 0 Then
      DLASIDXDAT = DIDXDAT
    Endif
  Endif
End

##########################################################################################################
# Calcul la date de fin d'intervention sur site pour problèmes non bloquants.
##########################################################################################################
Subprog SITTDATEND(DSTRDAT, IDUR, IDURBAS, DITTDATEND)
Value Date DSTRDAT
Value Integer IDUR
Value Integer IDURBAS
Variable Date DITTDATEND

  If DSTRDAT = [00/00/00] Then
    DITTDATEND = [00/00/00]
    End
  Endif
  If IDUR = 0 Then
    DITTDATEND = DSTRDAT
    End
  Endif
  If IDURBAS = 1 Then
    #heure
    DITTDATEND = DSTRDAT
  Elsif IDURBAS = 2 Then
    #jour
    DITTDATEND = DSTRDAT + IDUR
  Elsif IDURBAS = 3 Then
    #semaine
    DITTDATEND = DSTRDAT + (IDUR * 7)
  Elsif IDURBAS = 4 Then
    #mois
    DITTDATEND = addmonth(DSTRDAT, IDUR)
  Elsif IDURBAS = 5 Then
    #ans
    DITTDATEND = gdat$(day(DSTRDAT), month(DSTRDAT), year(DSTRDAT) + IDUR)
  Elsif IDURBAS = 6 Then
    #vide
    DSTRDAT = [00/00/00]
    DITTDATEND = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul les pénalités de retard pour problèmes non bloquants dans la devise de la commande.
##########################################################################################################
Subprog SETAMTPLY(ISOHFCY, ISOHCUR, ICOTCUR, ICOTPLY, IAMTPLY)
Value Char ISOHFCY
Value Char ISOHCUR
Value Char ICOTCUR
Value Decimal ICOTPLY
Variable Decimal IAMTPLY

Local Char DEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  DEVSOC = ""
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  Call GETDEVCPY("", ISOHFCY, DEVSOC, IT_IS_OK) From CRM_UTIL
  # Devise d'origine
  # Devise destination
  # Devise de la société
  # Type de cours
  # Date du cours
  # Montant origine
  # Montant destination
  # Status de retour (0 = OK)
  Call CONVERT(ICOTCUR,ISOHCUR,DEVSOC,2,date$,ICOTPLY,IAMTPLY,IT_IS_NOT_OK) From TRTDEV
  If IT_IS_NOT_OK Then
    #Certains montants n'ont pas pus être calculés correctement en raison d'une mauvaise qualification de la table des devises.
    GMESSAGE = mess(278,196,1)
    GERR = 2
  Endif
End

##########################################################################################################
# Calcul les franchises de prestations couvertes par article dans la devise du contrat.
##########################################################################################################
Subprog SETCOVAMT(SZFCY, SZCOTCUR, SZDESCUR, ICOVAMT, IDESAMT)
Value Char SZFCY
Value Char SZCOTCUR
Value Char SZDESCUR
Value Decimal ICOVAMT
Variable Decimal IDESAMT

Local Char DEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  DEVSOC = ""
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  Call GETDEVCPY("", SZFCY, DEVSOC, IT_IS_OK) From CRM_UTIL
  # Devise d'origine
  # Devise destination
  # Devise de la société
  # Type de cours
  # Date du cours
  # Montant origine
  # Montant destination
  # Status de retour (0 = OK)
  Call CONVERT(SZCOTCUR,SZDESCUR,DEVSOC,2,date$,ICOVAMT,IDESAMT,IT_IS_NOT_OK) From TRTDEV
  If IT_IS_NOT_OK
  #Certains montants n'ont pas pus être calculés correctement en raison d'une mauvaise qualification de la table des devises.
    GMESSAGE = mess(278,196,1)
    GERR = 2
  Endif
End

##########################################################################################################
# Calcul les informations pour un contrat en terme à échoir et post réévaluation (Modif manuelle)
##########################################################################################################
Subprog CPTAMT11
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [M:CON4]CONREW = 2 Then
    Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
    #Calcul la date de prochaine facture.
    Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
  Else
    Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DDAT1)
    If [M:CON4]CONENDDAT < DDAT1 Then
      [M:CON2]NEXINVAMT = 0
      [M:CON2]NEXINVDAT = [00/00/00]
      [M:CON2]NEXSHIINV = [00/00/00]
    Else
      Call SNEXINVDAT(DDAT1, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DNEXINVDAT)
      DDAT2 = DNEXINVDAT - 1
      If [M:CON4]CONENDDAT < DDAT2 Then
        INBDAY = nday([M:CON4]CONENDDAT) - nday(DDAT1)
        INBDAY += 1
        If INBDAY > 0 Then
          AM = [M:CON4]CONAMT * [M:CON8]INVFRYCOE
          IDECAMOUNT = AM * (INBDAY / 365.25)
          [M:CON2]NEXINVAMT = arr(IDECAMOUNT,10^-GDECPRI)
        Endif
      Else
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
      Endif
      #Calcul la date de prochaine facture.
      Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
    Endif
  Endif
  #REEVALUATION
  #Calcul de la dernière valeur d'index utilisée et de sa date
  If [M:CON4]RVASSP = 1 Then
    If [M:CON4]RVAFRY <> 0 Then
      If [M:CON4]RVAFRYBAS > 0 Then
        If [M:CON4]RVAFRYBAS <> 6 Then
          If [M:CON4]CONBASIDX <> "" Then
            If [M:CON4]RVADAT = [00/00/00] Then
              [M:CON4]RVADAT = [M:CON4]SIUDAT
              Call SETINDVAL([M:CON4]SIUDAT, [M:CON4]CONBASIDX) From SUBCONB1
            Else
              If GICURCHANGED Then
                [M:CON4]RVADAT = [M:CON2]LASINVDAT
                Call SETINDVAL([M:CON2]LASINVDAT, [M:CON4]CONBASIDX) From SUBCONB1
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    If [M:CON4]RVADAT = [00/00/00] Then
      [M:CON4]RVADAT = [M:CON4]SIUDAT
    Else
      If GICURCHANGED Then
        [M:CON4]RVADAT = [M:CON2]LASINVDAT
      Endif
    Endif
    [M:CON4]LASVALIDX = 0
    [M:CON4]LASIDXDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul les informations pour un contrat en terme à échoir et post réévaluation (Facturation)
##########################################################################################################
$FCPTAMT11
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #REEVALUATION
  IRVAFLG = 0
  If [F:CON]RVAFRY <> 0 Then
    If [F:CON]RVAFRYBAS > 0 Then
      If [F:CON]RVAFRYBAS <> 6 Then
        If [F:CON]RVASSP = 1 Then
          If [F:CON]CONBASIDX <> "" Then
            IRVAFLG = 1
          Endif
        Else
          If [F:CON]CONBASFOR <> "" Then
            IRVAFLG = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  If IRVAFLG Then
    If [F:CON]RVADAT = [00/00/00] Then
      [F:CON]RVADAT = [F:CON]LASINVDAT
      If [F:CON]RVASSP = 1 Then
        Call FSETINDVAL([F:CON]LASINVDAT, [F:CON]CONBASIDX) From SUBCONB1
      Else
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
      Endif
    Else
      Call GETNEWDAT([F:CON]RVADAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNDAT) From SUBCONB1
      #If DNDAT <= [F:CON]NEXINVDAT Then                    # FGR 26/07/2013 : X3SUIVI91169
      If DNDAT<> [0/0/0] and DNDAT <= [F:CON]NEXINVDAT Then # FGR 26/07/2013 : X3SUIVI91169
        #Le contrat doit être réévalué.
        Call SETOLDINF([M:SIH0]NUM, 0, 1) From SUBCONB2
        Call RVACONB([F:CON]CONNUM, ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [F:CON]CONREW = 2 Then
    If [F:CON]RSIFLG <> 2 Then
      If [F:CON]FDDFLG <> 2 Then
        If [F:CON]CONENDDAT <= [M:SIH0]INVDAT Then
          #Il faut renouveler
          Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
          Call REWCONB(ISOK) From SUBCONB1
          If !ISOK Then
            If INTRANS Then
              ISOK = 0
              GOK = 0
              Call FSTA("CON") From GLOCK
              Return
            Else
              Rollback
              ISOK = 0
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
    Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
    #Calcul la date de prochaine facture.
    Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
  Else
    Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DDAT1)
    If [F:CON]CONENDDAT < DDAT1 Then
      #On vérifie si le contrat ne comporte pas de demande de renouvellement.
      If [F:CON]MANREWFLG = 2 Then
        #Le contrat doit être renouvelé.
        Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
        Call REWCONB(ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
        Gosub RENOUVELLE_CONTRAT   # FGR 27/06/2011 : X3SUIVI74226
        #[F:CON]MANREWFLG = 1
        #If [F:CON]MANREWAMT > 0 Then
        #  [F:CON]CONAMT = [F:CON]MANREWAMT
        #  [F:CON]MANREWAMT = 0
        #Endif
        [F:CON]RVADAT = [F:CON]CONSTRDAT
        If [F:CON]RVASSP = 1 Then
          Call FSETINDVAL([F:CON]CONSTRDAT, [F:CON]CONBASIDX) From SUBCONB1
        Else
          [F:CON]LASVALIDX = 0
          [F:CON]LASIDXDAT = [00/00/00]
        Endif
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
        #Calcul la date de prochaine facture.
        Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
        #Calcul la date du prochain envoi de facture.
        Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      Else
        [F:CON]NEXINVAMT = 0
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Else
      Call SNEXINVDAT(DDAT1, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DNEXINVDAT)
      DDAT2 = DNEXINVDAT - 1
      If [F:CON]CONENDDAT < DDAT2 Then
        INBDAY = nday([F:CON]CONENDDAT) - nday(DDAT1)
        INBDAY += 1
        If INBDAY > 0 Then
          AM = [F:CON]CONAMT * [F:CON]INVFRYCOE
          IDECAMOUNT = AM * (INBDAY / 365.25)
          [F:CON]NEXINVAMT = arr(IDECAMOUNT,10^-GDECPRI)
        Endif
      Else
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
      Endif
      #Calcul la date de prochaine facture.
      Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
      #Calcul la date du prochain envoi de facture.
     Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
    Endif
  Endif
Return

##########################################################################################################
# Calcul le montant de la prochaine facture pour un contrat en terme échu et post réévaluation (Modif manuelle)
##########################################################################################################
Subprog CPTAMT21
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [M:CON4]CONREW = 2 Then
    Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
    #Calcul la date de prochaine facture.
    Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
  Else
    If [M:CON2]LASINVDAT >= [M:CON4]CONENDDAT Then
      [M:CON2]NEXINVAMT = 0
      [M:CON2]NEXINVDAT = [00/00/00]
      [M:CON2]NEXSHIINV = [00/00/00]
    Else
      Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DDAT1)
      DDAT2 = DDAT1 - 1
      If [M:CON4]CONENDDAT < DDAT2 Then
        INBDAY = nday([M:CON4]CONENDDAT) - nday([M:CON2]LASINVDAT)
        INBDAY += 1
        If INBDAY > 0 Then
          AM = [M:CON4]CONAMT * [M:CON8]INVFRYCOE
          IDECAMOUNT = AM * (INBDAY / 365.25)
          [M:CON2]NEXINVAMT = arr(IDECAMOUNT,10^-GDECPRI)
        Endif
        [M:CON2]NEXINVDAT = [M:CON4]CONENDDAT + 1
      Else
        Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
      Endif
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
    Endif
  Endif
  #REEVALUATION
  If GICURCHANGED Then
    [M:CON4]RVADAT = [00/00/00]
  Endif
  [M:CON4]LASVALIDX = 0
  [M:CON4]LASIDXDAT = [00/00/00]
End

##########################################################################################################
# Calcul le montant de la prochaine facture pour un contrat en terme échu et post réévaluation (Facturation)
##########################################################################################################
$FCPTAMT21
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #REEVALUATION
  IRVAFLG = 0
  If [F:CON]RVAFRY <> 0 Then
    If [F:CON]RVAFRYBAS > 0 Then
      If [F:CON]RVAFRYBAS <> 6 Then
        If [F:CON]RVASSP = 1 Then
          If [F:CON]CONBASIDX <> "" Then
            IRVAFLG = 1
          Endif
        Else
          If [F:CON]CONBASFOR <> "" Then
            IRVAFLG = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  If IRVAFLG Then
    If [F:CON]RVADAT = [00/00/00] Then
      [F:CON]RVADAT = [F:CON]LASINVDAT
      If [F:CON]RVASSP = 1 Then
        Call FSETINDVAL([F:CON]LASINVDAT, [F:CON]CONBASIDX) From SUBCONB1
      Else
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
      Endif
    Else
      Call GETNEWDAT([F:CON]RVADAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNDAT) From SUBCONB1
      #If DNDAT <= [M:SIH0]INVDAT
      #If DNDAT <= [F:CON]NEXINVDAT Then                      # FGR 26/07/2013 : X3SUIVI91169
      If DNDAT <> [0/0/0] and DNDAT <= [F:CON]NEXINVDAT Then  # FGR 26/07/2013 : X3SUIVI91169
        #Le contrat doit être réévalué.
        Call SETOLDINF([M:SIH0]NUM, 0, 1) From SUBCONB2
        Call RVACONB([F:CON]CONNUM, ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  # FACTURATION
  # Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [F:CON]CONREW = 2 Then
    If [F:CON]RSIFLG <> 2 Then
      If [F:CON]FDDFLG <> 2 Then
        If [F:CON]CONENDDAT <= [M:SIH0]INVDAT Then
          #Il faut renouveler
          Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
          Call REWCONB(ISOK) From SUBCONB1
          If !ISOK Then
            If INTRANS Then
              ISOK = 0
              GOK = 0
              Call FSTA("CON") From GLOCK
              Return
            Else
              Rollback
              ISOK = 0
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
    #Calcul le montant de la prochaine facture.
    Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
    #
    #Calcul la date de prochaine facture.
    Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
    #
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
  Else
    #If [F:CON]CONENDDAT <= [M:SIH0]INVDAT
    If [F:CON]CONENDDAT < [M:SIH0]INVDAT Then
      #On vérifie si le contrat ne comporte pas de demande de renouvellement.
      If [F:CON]MANREWFLG = 2 Then
        #Le contrat doit être renouvelé.
        Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
        Call REWCONB(ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
        Gosub RENOUVELLE_CONTRAT   # FGR 27/06/2011 : X3SUIVI74226
        #[F:CON]MANREWFLG = 1
        #If [F:CON]MANREWAMT > 0 Then
        #  [F:CON]CONAMT = [F:CON]MANREWAMT
        #  [F:CON]MANREWAMT = 0
        #Endif
        [F:CON]RVADAT = [00/00/00]
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
        #
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([F:CON]CONSTRDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
        #
        #Calcul la date du prochain envoi de facture.
        Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      Else
        [F:CON]NEXINVAMT = 0
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Else
      Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DDAT1)
      DDAT2 = DDAT1 - 1
      If [F:CON]CONENDDAT < DDAT2 Then
        INBDAY = nday([F:CON]CONENDDAT) - nday([F:CON]ONEXINVDAT)
        INBDAY += 1
        If INBDAY > 0 Then
          AM = [F:CON]CONAMT * [F:CON]INVFRYCOE
          IDECAMOUNT = AM * (INBDAY / 365.25)
          [F:CON]NEXINVAMT = arr(IDECAMOUNT,10^-GDECPRI)
        Endif
       [F:CON]NEXINVDAT = [F:CON]CONENDDAT + 1
      Else
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, [F:CON]NEXINVAMT)
        #
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
      Endif
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      # FGR 17/11/2008 : X3SUIVI50379
      If [F:CON]LASINVDAT > [F:CON]CONENDDAT Then
        [F:CON]NEXINVAMT = 0
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Calcul les informations pour un contrat en terme à échoir et pré-réévaluation (Modif manuelle)
##########################################################################################################
Subprog CPTAMT12
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  If [M:CON2]LASINVDAT = [00/00/00] Then
    Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
  Else
    [M:CON2]NEXINVAMT = 0
  Endif
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [M:CON4]CONREW = 2 Then
    #Calcul la date de prochaine facture.
    Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
  Else
    Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DDAT1)
    If [M:CON4]CONENDDAT < DDAT1 Then
      [M:CON2]NEXINVDAT = [00/00/00]
      [M:CON2]NEXSHIINV = [00/00/00]
    Else
      Call SNEXINVDAT(DDAT1, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DNEXINVDAT)
      DDAT2 = DNEXINVDAT - 1
      If [M:CON4]CONENDDAT < DDAT2 Then
        INBDAY = nday([M:CON4]CONENDDAT) - nday(DDAT1)
        INBDAY += 1
        If INBDAY > 0 Then
          AM = [M:CON4]CONAMT * [M:CON8]INVFRYCOE
          IDECAMOUNT = AM * (INBDAY / 365.25)
          [M:CON2]NEXINVAMT = arr(IDECAMOUNT,10^-GDECPRI)
        Else
          #Calcul le montant de la prochaine facture.
          Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
        Endif
      Else
        #Calcul le montant de la prochaine facture.
        Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
      Endif
      #Calcul la date de prochaine facture.
      Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
    Endif
  Endif
  #REEVALUATION
  If [M:CON4]RVASSP = 1 Then
    If [M:CON4]RVAFRY <> 0 Then
      If [M:CON4]RVAFRYBAS > 0 Then
        If [M:CON4]RVAFRYBAS <> 6 Then
          If [M:CON4]CONBASIDX <> "" Then
            If [M:CON4]RVADAT = [00/00/00] Then
              [M:CON4]RVADAT = [M:CON4]SIUDAT
              Call SETINDVAL([M:CON4]SIUDAT, [M:CON4]CONBASIDX) From SUBCONB1
            Else
              If GICURCHANGED Then
                [M:CON4]RVADAT = [M:CON2]LASINVDAT
                Call SETINDVAL([M:CON2]LASINVDAT, [M:CON4]CONBASIDX) From SUBCONB1
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    If [M:CON4]RVADAT = [00/00/00] Then
      [M:CON4]RVADAT = [M:CON4]SIUDAT
    Else
      If GICURCHANGED Then
        [M:CON4]RVADAT = [M:CON2]LASINVDAT
      Endif
    Endif
    [M:CON4]LASVALIDX = 0
    [M:CON4]LASIDXDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul les informations pour un contrat en terme à échoir et pré-réévaluation (Facturation)
##########################################################################################################
$FCPTAMT12
Local Date DDAT1
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #REEVALUATION
  IRVAFLG = 0
  If [F:CON]RVAFRY <> 0 Then
    If [F:CON]RVAFRYBAS > 0 Then
      If [F:CON]RVAFRYBAS <> 6 Then
        If [F:CON]RVASSP = 1 Then
          If [F:CON]CONBASIDX <> "" Then
            IRVAFLG = 1
          Endif
        Else
          If [F:CON]CONBASFOR <> "" Then
            IRVAFLG = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  If IRVAFLG Then
    If [F:CON]RVADAT = [00/00/00] Then
      [F:CON]RVADAT = [F:CON]LASINVDAT
      If [F:CON]RVASSP = 1 Then
        Call FSETINDVAL([F:CON]LASINVDAT, [F:CON]CONBASIDX) From SUBCONB1
      Else
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
      Endif
    Else
      Call GETNEWDAT([F:CON]RVADAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNDAT) From SUBCONB1
      #If DNDAT <= [F:CON]NEXINVDAT Then                      # FGR 26/07/2013 : X3SUIVI91169
      If DNDAT <> [0/0/0] and DNDAT <= [F:CON]NEXINVDAT Then  # FGR 26/07/2013 : X3SUIVI91169
        #Le contrat doit être réévalué.
        Call SETOLDINF([M:SIH0]NUM, 0, 1) From SUBCONB2
        Call RVACONB([F:CON]CONNUM, ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [F:CON]CONREW = 2 Then
    If [F:CON]RSIFLG <> 2 Then
      If [F:CON]FDDFLG <> 2 Then
        If [F:CON]CONENDDAT <= [M:SIH0]INVDAT Then
          #Il faut renouveler
          Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
          Call REWCONB(ISOK) From SUBCONB1
          If !ISOK Then
            If INTRANS Then
              ISOK = 0
              GOK = 0
              Call FSTA("CON") From GLOCK
              Return
            Else
              Rollback
              ISOK = 0
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
    #Calcul la date de prochaine facture.
    Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
  Else
    Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DDAT1)
    If [F:CON]CONENDDAT < DDAT1 Then
      #On vérifie si le contrat ne comporte pas de demande de renouvellement.
      If [F:CON]MANREWFLG = 2 Then
        #Le contrat doit être renouvelé.
        Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
        Call REWCONB(ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
        Gosub RENOUVELLE_CONTRAT   # FGR 27/06/2011 : X3SUIVI74226
        #[F:CON]MANREWFLG = 1
        #If [F:CON]MANREWAMT > 0 Then
        #  [F:CON]CONAMT = [F:CON]MANREWAMT
        #  [F:CON]MANREWAMT = 0
        #Endif
        [F:CON]RVADAT = [F:CON]CONSTRDAT
        If [F:CON]RVASSP = 1 Then
          Call FSETINDVAL([F:CON]CONSTRDAT, [F:CON]CONBASIDX) From SUBCONB1
        Else
          [F:CON]LASVALIDX = 0
          [F:CON]LASIDXDAT = [00/00/00]
        Endif
        #Calcul la date de prochaine facture.
        Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
        #Calcul la date du prochain envoi de facture.
        Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      Else
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Else
      #Calcul la date de prochaine facture.
      Call SNEXINVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
    Endif
  Endif
  [F:CON]NEXINVAMT = 0
Return

##########################################################################################################
# Calcul les informations pour un contrat en terme échu et pré-réévaluation (Modif manuelle)
##########################################################################################################
Subprog CPTAMT22
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  If [M:CON2]LASINVDAT = [00/00/00] Then
    Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT)
  Else
    [M:CON2]NEXINVAMT = 0
  Endif
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [M:CON4]CONREW = 2 Then
    #Calcul la date de prochaine facture.
    Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
  Else
    If [M:CON2]LASINVDAT >= [M:CON4]CONENDDAT Then
      [M:CON2]NEXINVDAT = [00/00/00]
      [M:CON2]NEXSHIINV = [00/00/00]
    Else
      Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, DDAT1)
      DDAT2 = DDAT1 - 1
      If [M:CON4]CONENDDAT < DDAT2 Then
        [M:CON2]NEXINVDAT = [M:CON4]CONENDDAT + 1
      Else
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT)
      Endif
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV)
    Endif
  Endif
  #REEVALUATION
  If [M:CON4]RVASSP = 1 Then
    If [M:CON4]RVAFRY <> 0 Then
      If [M:CON4]RVAFRYBAS > 0 Then
        If [M:CON4]RVAFRYBAS <> 6 Then
          If [M:CON4]CONBASIDX <> "" Then
            If [M:CON2]LASINVDAT <> [00/00/00] Then
              If GICURCHANGED Then
                [M:CON4]RVADAT = [M:CON2]LASINVDAT
                Call SETINDVAL([M:CON2]LASINVDAT, [M:CON4]CONBASIDX) From SUBCONB1
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    If [M:CON2]LASINVDAT <> [00/00/00] Then
      If GICURCHANGED Then
        [M:CON4]RVADAT = [M:CON2]LASINVDAT
      Endif
    Endif
    [M:CON4]LASVALIDX = 0
    [M:CON4]LASIDXDAT = [00/00/00]
  Endif
End

##########################################################################################################
# Calcul le montant de la prochaine facture pour un contrat en terme échu et pré-réévaluation (Facturation)
##########################################################################################################
$FCPTAMT22
Local Date DDAT1
Local Date DDAT2
Local Date DNEXINVDAT
Local Integer INBDAY
Local Decimal AM
Local Decimal IDECAMOUNT

  INBDAY = 0
  AM = 0
  IDECAMOUNT = 0
  #REEVALUATION
  IRVAFLG = 0
  If [F:CON]RVAFRY <> 0 Then
    If [F:CON]RVAFRYBAS > 0 Then
      If [F:CON]RVAFRYBAS <> 6 Then
        If [F:CON]RVASSP = 1 Then
          If [F:CON]CONBASIDX <> "" Then
            IRVAFLG = 1
          Endif
        Else
          If [F:CON]CONBASFOR <> "" Then
            IRVAFLG = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  If IRVAFLG Then
    If [F:CON]RVADAT = [00/00/00] Then
      [F:CON]RVADAT = [F:CON]LASINVDAT
      If [F:CON]RVASSP = 1 Then
        Call FSETINDVAL([F:CON]LASINVDAT, [F:CON]CONBASIDX) From SUBCONB1
      Else
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
      Endif
    Else
      Call GETNEWDAT([F:CON]RVADAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNDAT) From SUBCONB1
      #If DNDAT <= [F:CON]NEXINVDAT Then                       # FGR 26/03/2013 : X3SUIVI91169
      If DNDAT <> [0/0/0] and DNDAT <= [F:CON]NEXINVDAT Then   # FGR 26/03/2013 : X3SUIVI91169
        #Le contrat doit être réévalué.
        Call SETOLDINF([M:SIH0]NUM, 0, 1) From SUBCONB2
        Call RVACONB([F:CON]CONNUM, ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #FACTURATION
  #Vérifie si la fin du contrat intervient d'ici deux fréquences de facturation
  If [F:CON]CONREW = 2 Then
    If [F:CON]RSIFLG <> 2 Then
      If [F:CON]FDDFLG <> 2 Then
        If [F:CON]CONENDDAT <= [M:SIH0]INVDAT Then
          #Il faut renouveler
          Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
          Call REWCONB(ISOK) From SUBCONB1
          If !ISOK Then
            If INTRANS Then
              ISOK = 0
              GOK = 0
              Call FSTA("CON") From GLOCK
              Return
            Else
              Rollback
              ISOK = 0
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
    #Calcul la date de prochaine facture.
    Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
    #Calcul la date du prochain envoi de facture.
    Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
  Else
    If [F:CON]CONENDDAT < [M:SIH0]INVDAT Then
      #On vérifie si le contrat ne comporte pas de demande de renouvellement.
      If [F:CON]MANREWFLG = 2 Then
        #Le contrat doit être renouvelé.
        Call SETOLDINF([M:SIH0]NUM, 1, 0) From SUBCONB2
        Call REWCONB(ISOK) From SUBCONB1
        If !ISOK Then
          If INTRANS Then
            ISOK = 0
            GOK = 0
            Call FSTA("CON") From GLOCK
            Return
          Else
            Rollback
            ISOK = 0
            Return
          Endif
        Endif
        Gosub RENOUVELLE_CONTRAT   # FGR 27/06/2011 : X3SUIVI74226
        #[F:CON]MANREWFLG = 1
        #If [F:CON]MANREWAMT > 0 Then
        #  [F:CON]CONAMT = [F:CON]MANREWAMT
        #  [F:CON]MANREWAMT = 0
        #Endif
        [F:CON]RVADAT = [00/00/00]
        [F:CON]LASVALIDX = 0
        [F:CON]LASIDXDAT = [00/00/00]
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([F:CON]CONSTRDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
        #Calcul la date du prochain envoi de facture.
        Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      Else
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Else
      Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DDAT1)
      DDAT2 = DDAT1 - 1
      If [F:CON]CONENDDAT < DDAT2 Then
        [F:CON]NEXINVDAT = [F:CON]CONENDDAT + 1
      Else
        #Calcul la date de prochaine facture.
        Call NEX2INVDAT([F:CON]LASINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [F:CON]NEXINVDAT)
      Endif
      #Calcul la date du prochain envoi de facture.
      Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV)
      # FGR 17/11/2008 : X3SUIVI50379
      If [F:CON]LASINVDAT > [F:CON]CONENDDAT Then
        [F:CON]NEXINVAMT = 0
        [F:CON]NEXINVDAT = [00/00/00]
        [F:CON]NEXSHIINV = [00/00/00]
      Endif
    Endif
  Endif
  [F:CON]NEXINVAMT = 0
Return

##########################################################################################################
$RENOUVELLE_CONTRAT
  # FGR 27/06/2011 : X3SUIVI74226
  [F:CON]MANREWFLG = G_NON
  If [F:CON]MANREWAMT > 0 Then
    [F:CON]CONAMT = [F:CON]MANREWAMT
    If [F:CON]MANREWFRY <> 0 Then
      # On teste parce que les rubriques sont nouvelles. Si elles n'étaient pas alimentées ça rendrait le contrat incorrect
      [F:CON]REWFRY = [F:CON]MANREWFRY
      [F:CON]REWFRYBAS = [F:CON]MANREWFRYBAS
      [F:CON]CONREW = [F:CON]MANCONREW
      [F:CON]CONSTRDAT = [F:CON]MANCONSTRDAT
      [F:CON]CONENDDAT = [F:CON]MANCONENDDAT
    Endif
    Raz [F:CON]MANREWFRY
    Raz [F:CON]MANREWFRYBAS
    Raz [F:CON]MANCONREW
    Raz [F:CON]MANCONSTRDAT
    Raz [F:CON]MANCONENDDAT
    Raz [F:CON]MANREWAMT
  Endif
Return

##########################################################################################################
# Verifie si les informations de date et durée sont cohérentes.
##########################################################################################################
Subprog CTRLDATCON(DSTRDAT, IREWFRY, IBASREWFRY, DENDDAT,IBRETOUR)
Value Date DSTRDAT
Value Integer IREWFRY
Value Integer IBASREWFRY
Value Date DENDDAT
Variable Integer IBRETOUR

Local Date DBUFDAT

  IBRETOUR = 1
  Call SETENDDAT(DSTRDAT, IREWFRY, IBASREWFRY, DBUFDAT)
  If DBUFDAT <> DENDDAT Then
    IBRETOUR = 0
  Else
    IBRETOUR = 1
  Endif
End
