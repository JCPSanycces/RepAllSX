#<AdxTL>@(#)3.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "BY"
Call TRAITE_CHAR(VALEUR,PARAM,"","PYRVERFACC","",1,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return


$INIT
TMP = 1
Return

$EXEC
TRA = 1
Local Integer I , ER1 , ER2 , ER3 , NBREF , NIV
Local Char    REF(GLONGRY)(1..100)
Local Char    DESIG(GLONAX3)
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GYM])=0  : Local File GACCPYM    [GYM]  : Endif
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:GRY2])=0 : Local File GACCGRUPYM [GRY2] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif

Read [GYM]GYM0 = PARAM(1)
If fstat : End : Endif

Call OUVRE_TRACE(mess(59,103,1)-PARAM(1)) From LECFIC : # Vérification pyramide

ER1 = 0
For [GAC]GAC0 Where COA=[F:GYM]COA
 NBREF = 0
 For [GRY]GRY5 Where PYM=PARAM(1) & ACC>"" & pat([F:GAC]ACC,[F:GRY]ACC)<>0
  NBREF = 1 : Break
 Next
 If NBREF=0
  If ER1=0 
   Call ECR_TRACE(mess(75,103,1),0) From GESECRAN : # Comptes non référéncés
   Call ECR_TRACE("",0) From GESECRAN
   ER1 += 1
  Endif
  Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Call ECR_TRACE([F:GAC]ACC-DESIG,0) From GESECRAN
 Endif
Next

ER2 = 0
For [GAC]GAC0 Where COA=[F:GYM]COA
 NBREF = 0
 For [GRY]GRY5 Where PYM=PARAM(1) & ACC>"" & pat([F:GAC]ACC,[F:GRY]ACC)<>0
  NBREF += 1 : REF(NBREF) = [F:GRY]GRU
  If NBREF>=dim(REF) : Break : Endif
 Next
 If NBREF>1
  If ER2=0
   If ER1
    Call ECR_TRACE("",0) From GESECRAN
   Endif
   Call ECR_TRACE(mess(76,103,1),0) From GESECRAN : # Comptes multi-référéncés
   Call ECR_TRACE("",0) From GESECRAN
   ER2 += 1
  Endif
  Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  For I=1 To NBREF
   Call ECR_TRACE([F:GAC]ACC-DESIG-":"-mess(24,103,1)-REF(I),0) From GESECRAN : # Groupe de comptes
  Next I
 Endif
Next

ER3 = 0
NIV = 0
For [GRY]GRY1(2) Where PYM=PARAM(1)
 NIV += 1
 If NIV>1
  For [GRY]GRY1
   NBREF = 0
   For [GRY2]GRY2 Where PYM=PARAM(1) & SBBGRU=[F:GRY]GRU
    NBREF = 1 : Break
   Next
   If NBREF=0
    If ER3=0
     If ER1 or ER2
      Call ECR_TRACE("",0) From GESECRAN
     Endif
     Call ECR_TRACE(mess(79,103,1),0) From GESECRAN : # Groupes sans père
     Call ECR_TRACE("",0) From GESECRAN
     ER3 += 1
    Endif
    Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
    Call ECR_TRACE([F:GRY]GRU-DESIG,0) From GESECRAN
   Endif
  Next
 Endif
Next

If ER1=0 & ER2=0 & ER3=0
 Call ECR_TRACE(mess(164,115,1),0) From GESECRAN : # Aucune anomalie
Endif
Call FERME_TRACE From LECFIC
Return

