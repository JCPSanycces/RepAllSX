#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################################
# UTIVEN11                                                                  Module VENTE      #
#                                                                             24/03/2011      #
# Concerne le bug 72056 :                                                                     #
# Lors du passage V6.0 à V6.1, les chps STRDAT ENDDAT sur SINVOICED n'ont pas été initialisés #
#                                                                                             #
# But de l'utilitaire :                                                                       #
#     Initialiser STRDAT ENDDAT de SINVOICED à partir de STRDATSVC ENDDATSVC de SINVOICE      #
#                                                                                             #
###############################################################################################


Call MAJ_UTIVEN11
End


Subprog MAJ_UTIVEN11
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVEN11 - Sales invoice Process : Update SINVOICED") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN11 - Sales invoice Process : Update SINVOICED") From LECFIC
  Call EXE_UTIVEN11(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVEN11(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIVEN11 : Start folder's process"-DOSSIER) From DOSSUB

#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#
Gosub TRT_SIH    : # Traitement des factures
#----- Fin du traitement -----#

$FIN_UTIVEN11
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIVEN11 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Initialisation champs dans les factures                      #
# -------------------------------------------------------------- #
# Table SINVOICED   - Lignes factures                            #
#   STRDAT         Date début prestation                         #
#   ENDDAT         Date fin   prestation                         #
#----------------------------------------------------------------#
$TRT_SIH
If filinfo(filpath("FIL","SINVOICE","fde", DOSSIER),0) < 0 : Return : Endif
If filinfo(filpath("FIL","SINVOICED","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UTIVEN11 : Sales Invoice Process : Update SINVOICED") From DOSSUB
Local File =DOSSIER+".SINVOICE"    [SIH]
Local File =DOSSIER+".SINVOICED"   [SID]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(GLONSIH), CRITERE(100), CRITERE1(100), CRITERE2(100)

CRITERE1 = '([F:SIH]STRDATSVC<>[0/0/0] | [F:SIH]ENDDATSVC<>[0/0/0])'
CRITERE2 = '([F:SID]STRDAT=[0/0/0] | [F:SID]ENDDAT=[0/0/0])'

Link [SID] With [SIH]SIH0~=[SID]NUM As [KSID] 

$B_TRT_SIH
If  STOP=1
    CRITERE = '[F:SIH]NUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
# Pour test
#CRITERE = 'find(NUM,"FCAPN1303000000004","FCAPN1303000000003","FCAPN1211000000002")'

Raz COMPTEUR

Trbegin [KSID]
  For [KSID] SID0 Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2)

    If [F:SID]ENDDAT=[0/0/0] [F:SID]ENDDAT=[F:SIH]ENDDATSVC Endif   
    If [F:SID]STRDAT=[0/0/0] [F:SID]STRDAT=[F:SIH]STRDATSVC Endif   
    Rewrite [SID]
    If fstat
        Call ECR_TRACE("File SINVOICED"-[F:SID]NUM-num$([F:SID]SIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    NBENR+=1 : COMPTEUR+=1

    If COMPTEUR>GMAXUPDTRS CLE1=[F:SIH]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto B_TRT_SIH : Endif

Close Local File [SIH]
Close Local File [SID]

Call ECR_TIME("UTIVEN11 : Sales Invoice Process : Ended :"+"("-num$(NBENR)-")") From DOSSUB
Return 


Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("UTIVEN11 - Sales invoice Process : Update SINVOICED",0) From GESECRAN
  Call EXE_UTIVEN11(DOSSIER)
Endif
#-----
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(4)=2
Call EXE_UTIVEN11(APPLI)
Endif
End

