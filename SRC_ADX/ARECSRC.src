#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(10)
Raz GNBMASKOUV
Call TRAITE_CHAR(VALEUR,PARAM,"","ARECSRC","ARECSRC",4,"") From GTRAITE
End

#-------------------------------------------------------------#
$ACTION
Case ACTION
  When "OK"              : Gosub EXECOK
  When "DEBUT"           : Gosub DEBUT
Endcase
Return

$DEBUT
Effzo [M:ARC]
Return

$EXECOK
Local Char MACHINE(100),OS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS<>"unix"
  If GLANGUE="FRA"
    Call ERREUR("Fonction disponible uniquement en environnements Linux et Aix") From GESECRAN
  Else
    Call ERREUR("Function only available on Linux and Aix configurations") From GESECRAN
  Endif
  Return
Endif

Local Char DOSS,TOFIND(200)
DOSS=[M:ARC]DOSSIER
TOFIND=[M:ARC]ACHERCH
TYPREC=[M:ARC]CASSE
Gosub RECHTXT
Return


$RECHTXT
Local Char RESULT(200),ORDERC(200),CHEMIN(200),FILNAM(30),TRAC(200),MESSA(200)
Local Integer TIMDEB

CHEMIN=filpath("TRT","","",DOSS)
FILNAM="REC-"+GUSER+"-"+num$(time)

TRAC=filpath("tmp",FILNAM,"txt")
If TYPREC=2
   # Recherche en tenant compte de la casse 
   ORDERC="find "-CHEMIN-"-name *.src | sort |xargs grep"-'"'+TOFIND+'" > '+TRAC
Else   
   # Recherche sans tenir compte de la casse
   ORDERC="find "-CHEMIN-"-name *.src | sort |xargs grep -i"-'"'+TOFIND+'" > '+TRAC
Endif
TIMDEB=time
System RESULT = adxmac(0)+"@"+ORDERC
Gosub POSTTRAIT
CHAINE = TOFIND+"~"+DOSS+"~"+num$(time-TIMDEB)+"~"+num$(NBLIG)+"~"+num$(NBCOM)+"~"+num$(NBSRC)
If GLANGUE="FRA"
  MESSA =  'Recherche de la chaine "$1$" dans le dossier $2$\effectuée en $3$ secondes\'
  MESSA += 'Nombre d'+"'"+'occurences: $4$ dont $5$ en commentaires\'
  MESSA += 'Nombre de programmes source: $6$\'
Else
  MESSA =  'Search for string "$1$" in folder $2$\Done in $3$ seconds\'
  MESSA += 'String found: $4$ times including $5$ comment lines\'
  MESSA += 'Number of source code programs: $6$\'
Endif
Call MESSAGE(func AFNC.MESN(MESSA,CHAINE)) From GESECRAN

Call LECFIC(filpath("tmp","",""),FILNAM,"txt") From LECFIC
Call SUPPFIC(filpath("tmp","",""),FILNAM,"txt") From LECFIC
Return



$POSTTRAIT
Local Char VALL1(250),NOMSRC,OLDSRC
Local Integer NBLIG, NBSRC, NBCOM
Local Integer D1,D2,D3,D4
Openi filpath("tmp",FILNAM,"txt") Using [TTR]
Iomode adxifs "" Using [TTR]
Iomode adxirs chr$(10) Using [TTR]
Iomode adxium GUTF8 Using [TTR]
While fstat=0
  Rdseq VALL1 Using [TTR]
  If fstat<>0 : Break 1 : Endif
  NBLIG+=1
  D1=instr(1,VALL1,".src")
  D3=0
  For D2=D1 To 1 Step -1
   If mid$(VALL1,D2,1)="/"
     D3=D2
     Break 1
   Endif
  Next D2
  If D3<>0 : NOMSRC=mid$(VALL1,D3+1,D1-D3-1) : Endif

# Is-it a comment line ?

  D1=instr(D1,VALL1,":")
  For D4=D1+1 To len(VALL1)
    If mid$(VALL1,D4,1)="#"
      NBCOM+=1
      Break 1
    Elsif mid$(VALL1,D4,1)<>" "
      Break 1
    Endif
  Next D4
  If NOMSRC<>OLDSRC
    NBSRC+=1
    OLDSRC=NOMSRC
  Endif

Wend
Openi Using [TTR]


Return


