#<AdxTL>@(#)0.0.0.0 $Revision$

######################################################
## Intégration d'une aide sur champ
######################################################

$AIDE_CHAMP
If [L]ISFULLMOD<>2
 If !(([L]TYPPTC=2 & GDOSX3=[L]APPLI) | ([L]TYPPTC<>2 & GDOSX3<>[L]APPLI))
  Gosub FIN_OBJ From PATCH
  Return
 Endif
Endif
Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ-INTITOBJ,0) From GESECRAN
Local File =APPLI+".ADOCFLD"   [ADZ]
If TYPENR=2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub TR_ADZ
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ADZ
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ADZ]
Return

$DEL_ADZ
Trbegin [ADZ]
 Delete [ADZ] Where MOTCLE=[L]NOMOBJ
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCFLD"-[L]NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADZ",[L]NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$TR_ADZ
Trbegin [ADZ]
 Gosub SUPP_ADZ
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ADZ"   : Gosub ADZ1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADZ",[F:ADZ]MOTCLE,[F:ADZ]LAN,"C") From GOBJET : Endif
Return

$ABORT
Rollback
Return

## Lecture d'une aide sur champ
$ADZ1
FICHIER = "ADOCFLD" : ABR = "ADZ"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ADZ]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
If find([F:ADZ]LAN,[F:ADS]LAN) : # test si la langue est bien dans le dossier
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADZ]CREDAT = date$
  [F:ADZ]CREUSR = GUSER
  If dim([F:ADZ]CRETIM)>0 : [F:ADZ]CRETIM = time  : Endif
  [F:ADZ]UPDDAT = date$
  [F:ADZ]UPDUSR = GUSER
  If dim([F:ADZ]UPDTIM)>0 : [F:ADZ]UPDTIM = time  : Endif
 Endif
 Write [ADZ]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCFLD"-[F:ADZ]LAN-"/"-[F:ADZ]MOTCLE : Return
 Endif
Endif
Return

$SUPP_ADZ
I = 0
While I<dim([L]LANPATCH)
 I += 1
 If find([L]LANPATCH(I),[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  Delete [ADZ] Where LAN=[L]LANPATCH(I) & MOTCLE=NOMOBJ
  If fstat : GOK = 0 : ER = 99 : ERFIC = "ADOCFLD"-[L]LANPATCH(I)+"~"+NOMOBJ : Return : Endif
 Endif
Wend
Return

######################################################
## Intégration d'une documention
######################################################

$ADOC
K = instr(1,NOMOBJ,"~")
If K
 [L]TYPS = left$(NOMOBJ,K-1)
 [L]CODS = right$(NOMOBJ,K+1)
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
If ([L]TYPPTC<>2 & GDOSX3<>[L]APPLI) | ([L]TYPPTC=2) |  [L]ISFULLMOD=2
 Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ-INTITOBJ,0) From GESECRAN
Endif
Local File =DOSSIER(D)+".ADOCUMENT" [ADO]
Local File =DOSSIER(D)+".ADOCBLB"   [ADB]
Local File =DOSSIER(D)+".ADOCCLB"   [ADH]
If TYPENR=2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub TR_ADO
Elsif TYPENR=-2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub DEL_ADO
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ADO],[ADB],[ADH]
Return

$TR_ADO
Trbegin [ADO] , [ADB] ,[ADH]
 # suppresion des enreg non protégés par un code activité
 Gosub SUPP_ADO
 If ER : Goto ABORT : Endif
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # La transaction
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ADO"
      If ([L]TYPPTC<>2 & GDOSX3 <> [L]APPLI) | [L]TYPPTC=2 |  [L]ISFULLMOD=2
       Gosub ADO1
      Else
       FICHIER = "ADOCUMENT" : ABR = "ADO"
       Gosub LIS
      Endif
     When "ADB"
      If ([L]TYPPTC=2 & GDOSX3 = [L]APPLI) | ([L]TYPPTC<>2 & GDOSX3 <> [L]APPLI) |  [L]ISFULLMOD=2
       Gosub ADB2
      Else
       FICHIER = "ADOCBLB" : ABR = "ADB"
       Gosub LIS
      Endif
     When "ADH"
      If ([L]TYPPTC=2  & GDOSX3 = [L]APPLI) | ([L]TYPPTC<>2 & GDOSX3 <> [L]APPLI) |  [L]ISFULLMOD=2
       Gosub ADH3
      Else
       FICHIER = "ADOCCLB" : ABR = "ADH"
       Gosub LIS
      Endif
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2
 Local Char DOC_CLE1(250), DOC_CLE2(50)(0..1)
 [L]DOC_CLE1=[F:ADO]TYP  :  [L]DOC_CLE2(0)=[F:ADO]LAN  :  [L]DOC_CLE2(1)=[F:ADO]COD
 Call TRACE_COR_PATCH("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "C") From GOBJET
Endif
Return

$DEL_ADO
Trbegin [ADO] , [ADB] ,[ADH]
 For [ADO]ADO0 Where TYP=[L]TYPS & COD=[L]CODS
   Local Char DOC_CLE1(250), DOC_CLE2(50)(0..1)
   [L]DOC_CLE1=[F:ADO]TYP  :  [L]DOC_CLE2(0)=[F:ADO]LAN  :  [L]DOC_CLE2(1)=[F:ADO]COD
   Delete [ADB] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD
   Delete [ADH] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD
   Delete [ADO]ADO0 Curr
   If fstat
    GOK = 0 : ER = 99 : ERFIC = "ADOCUMENT"-[F:ADO]LAN+"~"+-[F:ADO]TYP+"~"+[F:ADO]COD : Return
   Endif
  Call TRACE_COR_PATCH("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "A") From GOBJET
 Next
Commit
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

## Lecture documentation
$ADO1
FICHIER = "ADOCUMENT" : ABR = "ADO"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# si on trouve un enreg c'est qu'il protégé par un code activité alors on arrete
Look [ADO]ADO0 = [F:ADO]LAN ;[F:ADO]TYP ;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
If !fstat
 Return
Endif
MODOBJ = max(1,[F:ADO]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ADO]CODACT
If find([F:ADO]LAN,[F:ADS]LAN) : # test si la langue est bien dans le dossier
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADO]CREDAT = date$
  [F:ADO]CREUSR = GUSER
  If dim([F:ADO]CRETIM)>0 : [F:ADO]CRETIM = time  : Endif
  [F:ADO]UPDDAT = date$
  [F:ADO]UPDUSR = GUSER
  If dim([F:ADO]UPDTIM)>0 : [F:ADO]UPDTIM = time  : Endif
 Endif
 Write [ADO]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCUMENT"-[F:ADO]LAN+"~"+[F:ADO]TYP+"~"+[F:ADO]COD : Return
 Endif
Endif
Return

## Documentation fichiers joints
$ADB2
FICHIER = "ADOCBLB" : ABR = "ADB"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# si on trouve un enreg c'est qu'il protégé par un code activité alors on arrete
Look [ADB]ADB0 = #[F:ADB]LAN ;[F:ADB]TYP ;[F:ADB]COD;[F:ADB]LEV;[F:ADB]SUBLEV;[F:ADB]LIG
If !fstat
 Return
Endif
If find([F:ADB]LAN,[F:ADS]LAN) : # test si la langue est bien dans le dossier
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADB]CREDAT = date$
  [F:ADB]CREUSR = GUSER
  If dim([F:ADB]CRETIM)>0 : [F:ADB]CRETIM = time  : Endif
  [F:ADB]UPDDAT = date$
  [F:ADB]UPDUSR = GUSER
  If dim([F:ADB]UPDTIM)>0 : [F:ADB]UPDTIM = time  : Endif
 Endif
 Write [ADB]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCBLB"-[F:ADB]LAN+"~"+[F:ADB]TYP+"~"+[F:ADB]COD : Return
 Endif
Endif
Return

## Documentation fichier texte
$ADH3
FICHIER = "ADOCCLB" : ABR = "ADH"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# si on trouve un enreg c'est qu'il protégé par un code activité alors on arrete
Look [ADH]ADH0 =  #[F:ADH]LAN ;[F:ADH]TYP ;[F:ADH]COD;[F:ADH]LEV;[F:ADH]SUBLEV
If !fstat
 Return
Endif
If find([F:ADH]LAN,[F:ADS]LAN) : # test si la langue est bien dans le dossier
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ADH]CREDAT = date$
  [F:ADH]CREUSR = GUSER
  If dim([F:ADH]CRETIM)>0 : [F:ADH]CRETIM = time  : Endif
  [F:ADH]UPDDAT = date$
  [F:ADH]UPDUSR = GUSER
  If dim([F:ADH]UPDTIM)>0 : [F:ADH]UPDTIM = time  : Endif
 Endif
 Write [ADH]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCCLB"-[F:ADH]LAN+"~"+[F:ADH]TYP+"~"+[F:ADH]COD : Return
 Endif
Endif
Return

$SUPP_ADO
I=1
While [L]LANPATCH(I) <> ""
 If find([L]LANPATCH(I),[F:ADS]LAN)
  For [ADO]ADO0 Where LAN=[L]LANPATCH(I) & TYP=[L]TYPS & COD=[L]CODS
   OK = 1
   If [F:ADO]CODACT>="X" & !find([F:ADO]CODACT,ACTIV(1..NBACT))
    OK = 0
   Endif
   If OK
    If ([L]TYPPTC=2  & GDOSX3=[L]APPLI) | ([L]TYPPTC<>2 & GDOSX3<>[L]APPLI)  | ([L]ISFULLMOD=2)
     Delete [ADB] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD
&                     & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
     If fstat
      GOK = 0 : ER = 99 : ERFIC = "ADOCBLB"-[F:ADO]LAN+"~"+-[F:ADO]TYP+"~"+[F:ADO]COD : Break
     Endif
     Delete [ADH] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD
&                     & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
     If fstat
      GOK = 0 : ER = 99 : ERFIC = "ADOCCLB"-[F:ADO]LAN+"~"+-[F:ADO]TYP+"~"+[F:ADO]COD : Break
     Endif
    Endif
    If ([L]TYPPTC<>2 & GDOSX3<>[L]APPLI) | [L]TYPPTC=2  | ([L]ISFULLMOD=2)
     Delete [ADO]ADO0 Curr
     If fstat
      GOK = 0 : ER = 99 : ERFIC = "ADOCUMENT"-[F:ADO]LAN+"~"+-[F:ADO]TYP+"~"+[F:ADO]COD : Break
     Endif
    Endif
   Endif
  Next
 Endif
 I+=1
Wend
If ER : Return : Endif
Return

######################################################
## Intégration de  liens de doc
######################################################

$LIENS
K = instr(1,NOMOBJ,"~")
If K
 [L]TYPS = left$(NOMOBJ,K-1)
 [L]CODS = right$(NOMOBJ,K+1)
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =DOSSIER(D)+".ADOCFNC"   [ADF]
Read [ADF]ADF0 = [L]TYPS;[L]CODS
If TYPENR=2 :#SCM deletion
 If !fstat & [F:ADF]CODACT>="X" & !find([F:ADF]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
 Elsif !([L]TYPPTC=2 | ([L]TYPPTC<>2 & GDOSX3<>[L]APPLI) | [L]ISFULLMOD=2)
  Gosub FIN_OBJ From PATCH
 Else
  Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ-INTITOBJ,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_ADF
 Endif
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ADF
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ADF]
Return

$TR_ADF
Trbegin [ADF]
 Gosub SUPP_ADF
 If ER : Goto ABORT : Endif
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # La transaction
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ADF"   : Gosub ADF1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
Return

$DEL_ADF
Trbegin [ADF]
 Delete [ADF] Where TYP=[L]TYPS and COD=[L]CODS
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ADOCFNC"-[L]TYPS+"~"+[L]CODS : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADF",[L]TYPS,[L]CODS,"A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

## Lecture documentation
$ADF1
FICHIER = "ADOCFNC" : ABR = "ADF"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ADF]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ADF]CODACT
If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 [F:ADF]CREDAT = date$
 [F:ADF]CREUSR = GUSER
 If dim([F:ADF]CRETIM)>0 : [F:ADF]CRETIM = time  : Endif
 [F:ADF]UPDDAT = date$
 [F:ADF]UPDUSR = GUSER
 If dim([F:ADF]UPDTIM)>0 : [F:ADF]UPDTIM = time  : Endif
Endif
Write [ADF]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ADOCFNC"-[L]TYPS-"/"-[L]CODS : Return
Endif
Return

$SUPP_ADF
Delete [ADF] Where TYP = [L]TYPS & COD = [L]CODS
If fstat : GOK = 0 : ER = 99 : ERFIC = "ADOCFNC"-[L]TYPS+"~"+[L]CODS : Return : Endif
Return

$LIS
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
Return

