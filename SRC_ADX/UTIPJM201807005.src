#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201807005
# Issue X3-99928 - 2018-08-23 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201807005(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201807005(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char SCHAINE(250)

  Call ECR_TRACE("UTIPJM201807005: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ACTION" [ACT]
  Local File =DOSSIER + ".ACTCODPAR" [AAR]
  Local File =DOSSIER + ".ACTPAR" [ATR]
  Local File =DOSSIER + ".ADOCUMENT" [ADO]
  Local File =DOSSIER + ".ADOCCLB" [ADH]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [ACT]
  # -----------------
  # ACTION DELETION
  SCHAINE = 'PJMSNP'
  Delete [ACT] Where [F:ACT]ACTION = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTION, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Delete [AAR] Where [F:AAR]CODPAR = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTCODPAR, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Delete [ATR] Where [F:ATR]ACTION = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTCODPAR, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Call EFFACE_DOC("ACT", SCHAINE) From SUBADO
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201807005 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201807005 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  #  If APPLI = GDOSX3 and GADONIX <> 2 Then
  #    End
  #  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTION") : End : Endif
  If filinfo(filpath("FIL","ACTCODPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTCODPAR") : End : Endif
  If filinfo(filpath("FIL","ADOCUMENT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCUMENT") : End : Endif
  If filinfo(filpath("FIL","ADOCCLB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCCLB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807005(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  #  If APPLI = GDOSX3 and GADONIX <> 2 Then
  #    End
  #  Endif
  # -------------------------
  If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTION") : End : Endif
  If filinfo(filpath("FIL","ACTCODPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTCODPAR") : End : Endif
  If filinfo(filpath("FIL","ADOCUMENT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCUMENT") : End : Endif
  If filinfo(filpath("FIL","ADOCCLB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCCLB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807005(APPLI)
End

