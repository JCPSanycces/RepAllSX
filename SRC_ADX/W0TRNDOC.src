#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRNDOC 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone DPEDAT
mkstat = 0
zoncou = "DPEDAT"
indice = 0
If varmode([M]DPEDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DPEDAT([M]DPEDAT) From TRNDOC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DPEDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DPEDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETD
mkstat = 0
zoncou = "ETD"
indice = 0
If varmode([M]ETD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ARVDAT
mkstat = 0
zoncou = "ARVDAT"
indice = 0
If varmode([M]ARVDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ARVDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ARVDAT([M]ARVDAT) From TRNDOC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ARVDAT" : GZNUM = 52762 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ETA
mkstat = 0
zoncou = "ETA"
indice = 0
If varmode([M]ETA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETA" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ETA([M]ETA) From TRNDOC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LICPLATE
mkstat = 0
zoncou = "LICPLATE"
indice = 0
If varmode([M]LICPLATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LICPLATE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TRLLICPLATE
mkstat = 0
zoncou = "TRLLICPLATE"
indice = 0
If varmode([M]TRLLICPLATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRLLICPLATE" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone MANDOC
mkstat = 0
zoncou = "MANDOC"
indice = 0
If varmode([M]MANDOC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MANDOC" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_MANDOC([M]MANDOC) From TRNDOC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MANDOC" : GZNUM = 52733 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone ATDTCOD
mkstat = 0
zoncou = "ATDTCOD"
indice = 0
If varmode([M]ATDTCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ATDTCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ATCOMICO
mkstat = 0
zoncou = "ATCOMICO"
indice = 0
If varinit([M]ATCOMICO,indice)=0
 [M]ATCOMICO = 174
Endif
If varmode([M]ATCOMICO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ATCOMICO" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRNDOC"
Return

