#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM004
# Issue X3-5293/119288 - 2016-10-20 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM004(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM004(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR

  IERR = 0
  Call ECR_TRACE("UTIPJM004: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMTSK", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSK" [PJTA]
  Local File =SZAPPLI + ".PJMTSKITM" [JTT]
  Local File =SZAPPLI + ".ORDERS" [ORD]
  # -------------------------
  If dim([F:PJTA]TASDATP) > 0 Then
    Trbegin [PJTA]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM004: Updating PJMCOSTCTR", 0) From GESECRAN
    Filter [PJTA] Where [F:PJTA]TASSTATE = 1
    For [PJTA]
      # -----------------------------
      Filter [JTT] Where [F:JTT]OPPNUM = [F:PJTA]OPPNUM and [F:JTT]TASCOD = [F:PJTA]TASCOD and [F:JTT]WIPNUM <> ""
      For [JTT]
        NCOUNT += 1
        Delete [ORD] Where [F:ORD]WIPTYP = 14 and [F:ORD]WIPNUM = [F:JTT]WIPNUM and  [F:ORD]ITMREF = [F:JTT]ITMREF
        If fstat Then
          Call ECR_TRACE("File ORDERS" - num$([F:ORD]WIPTYP) - [F:ORD]WIPNUM - [F:ORD]ITMREF + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Else
          [F:JTT]WIPNUM = ""
          Rewrite [JTT]
          If fstat Then
            Call ECR_TRACE("File PJMTSKITM" - [F:JTT]OPPNUM - [F:JTT]TASCOD - num$([F:JTT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Endif
      Next
      Filter [JTT]
      # -----------------------------
    Next
    Filter [PJTA]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM004: PJMCOSTCTR" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM004: PJMCOSTCTR" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM004 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM004 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM004(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM004(APPLI)
End

