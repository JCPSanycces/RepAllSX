 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYCEN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CPYLEGFRM
mkstat = 0
zoncou = "CPYLEGFRM"
indice = 0
If varinit([M]CPYLEGFRM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CPYLEGFRM,"11706","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CPYLEGFRM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CPYLEGFRM" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]CPYLEGFRM,"11706","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPYLEGFRM" : GZNUM = 29319 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]CPYLEGFRM,"11706",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPYLEGFRM" : GZNUM = 29319 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone RETFDSNUM
