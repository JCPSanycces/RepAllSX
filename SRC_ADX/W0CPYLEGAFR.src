## Zone TAXCLC
mkstat = 0
zoncou = "TAXCLC"
indice = 0
IMPENT = [M]TAXCLC
If varinit([M]TAXCLC,indice)=0
 IMPENT = 1
Endif
If varmode([M]TAXCLC,indice)=0
 Call INICOMBO(11719) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TAXCLC(IMPENT) From TRTCPYLEGAFR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,11719,1))))
 Endif
 [M]TAXCLC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TAXCLC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TAXCLC(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TAXCLC" : GZNUM = 8118 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "TAXCLC" : GZNUM = 8118 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TAXCLC = IMPENT

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone ADDNBR
mkstat = 0
zoncou = "ADDNBR"
indice = 0
status = 1
zoncou = "ADDNBR"
If varmode([M]ADDNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]ADDNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]ADDNBR = nolign
   status = 75
   Call SAI_ADDNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_ADDNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone ADDNBR
mkstat = 0
zoncou = "ADDNBR"

## Zone ADDTYP
mkstat = 0
zoncou = "ADDTYP"
IMPENT = [M]ADDTYP(indice)
If varinit([M]ADDTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ADDTYP,indice)=0
 [M]ADDTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ADDTYP(indice)
 Endif
Endif
[M]ADDTYP(indice) = IMPENT

## Zone ADDPOSNUM
