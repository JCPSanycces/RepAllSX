  IMPMOD = 0 : IMPZON = "ADDTWN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ADDDTCNBR
mkstat = 0
zoncou = "ADDDTCNBR"
If varmode([M]ADDDTCNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDDTCNBR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ADDDTC
mkstat = 0
zoncou = "ADDDTC"
If varmode([M]ADDDTC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDDTC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ADDCRY
mkstat = 0
zoncou = "ADDCRY"
If varinit([M]ADDCRY,indice)=0
 [M]ADDCRY(indice) = GPAYS
Endif
If varmode([M]ADDCRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDCRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]ADDCRY(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ADDCRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ADDRGN
mkstat = 0
zoncou = "ADDRGN"
If varmode([M]ADDRGN,indice)=0
 SAVACT = GACTION : GACTION = "SAISAT"
 Call SAISAT(ADDCRY,"") From TRTDIV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ADDRGN(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDRGN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLSAT"
  PARAM(1) = ADDCRY
  PARAM(2) = ""
  Local Char    VALEUR(250)
  VALEUR = [M]ADDRGN(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CTLSAT","TRTDIV","") From GACTION
  [M]ADDRGN(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ADDRGN" : GZNUM = 55949 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ADDNBR
mkstat = 0
zoncou = "ADDNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGAFR"
Return

