  IMPMOD = 0 : IMPZON = "ADDSCT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ADDTWN
mkstat = 0
zoncou = "ADDTWN"
If varmode([M]ADDTWN,indice)=0
