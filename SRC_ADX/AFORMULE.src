#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char FORMULE(250)
#FORMULE = "âŽ"
FORMULE = ""
Call B1_FORMULE(FORMULE,"[A]901","[F:ATB]ATABLE","","","")
End

#-------------------------------------#
$ACTION
Case ACTION
 When "TRT_DIV" : Gosub TRT_DIV
Endcase
Return

#-------------------------------------------------------------------------------------------------------#
# Instruction "field"
#--------------------------#
# 0   <= NumÃĐro d'image <256  : enregistrement Ã  destination de l'arbre des champs
# 256 <= NumÃĐro d'image <512  : enregistrement Ã  destination de l'arbre des fonctions
# 512 <= NumÃĐro d'image <1024 : enregistrement Ã  destination de l'arbre des opÃĐrateurs
#-----------------------------------#
# ParamÃĻtres TABLE1 TABLE2 TABLEn
#-----------------------------------#
# Le paramÃĻtre doit contient une expression (une expression est encadrÃĐe par des guillemets
# ou c'est une variable)
# Si cette expression commence par:
# [F] elle doit ÃŠtre suivie du code d'une table ou d'une vue (tables ATABLE et AVIEW)
# [F: elle doit ÃŠtre suivie de l'abrÃĐviation et du code d'une table ou d'une vue (tables ATABLE et AVIEW)
# [M] elle doit ÃŠtre suivie du code d'un ÃĐcran  (table AMSK)
# [M: elle doit ÃŠtre suivie de l'abrÃĐviation et du code d'un ÃĐcran  (table AMSK)
# [V] elle doit ÃŠtre suivie du code d'une variable globale (table AGLOBVAR)
# [L] elle doit ÃŠtre suivie du code d'une variable locale (table AVARLOC)
# [A] elle doit ÃŠtre suivie du numÃĐro d'une table diverse (table ATABDIV)
# [A: elle doit ÃŠtre suivie du numÃĐro d'une table diverse (table ATABDIV)
# POur [A: et [A] si on ajoute ~Prefix alors on ramene Prefix+[F:ADI]CODE
# un caractÃĻre alpha , c'est une table
# =   elle doit ÃŠtre suivie d'une expression dÃĐfinissant une variable dimensionnÃĐe (globale ou masque)
#     qui contient d'autres paramÃĻtres. UtilisÃĐ quand on veut gÃĐrer plus de 5 paramÃĻtres.
#-------------------------------------------------------------------------------------------------------#

Subprog B1_FORMULE(EXPRES,TABLE1,TABLE2,TABLE3,TABLE4,TABLE5)
Variable Char    EXPRES()
Value    Char    TABLE1
Value    Char    TABLE2
Value    Char    TABLE3
Value    Char    TABLE4
Value    Char    TABLE5

If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AVW])=0 : Local File AVIEW     [AVW] : Endif
If clalev([F:AVD])=0 : Local File AVIEWD    [AVD] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK      [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON   [AMZ] : Endif
If clalev([F:AVR])=0 : Local File AVARLOC   [AVR] : Endif
If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif
If clalev([F:ADV])=0 : Local File ATABTAB   [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif


Local Char    TT(30) , PTT(30) , UTT(30) , TABLE(30)(1..100) , COD(20)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , FORMULE(250)
Local Integer E , I , J , K , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL , NBCOD
Local Integer NBVAR , NUM , NBVARLOC , NBVARGLO
Local Char    OPE(50)(1..50) , TEX(50)(1..50) , ABR(GLONABR)
Local Char    CODVAR(80)(1..50) , TEXVAR(50)(1..50)
Local Char    CODVARLOC(80)(1..50) , TEXVARLOC(50)(1..50)
Local Char    CODVARGLO(80)(1..50) , TEXVARGLO(50)(1..50)
Local Char    PARAM(250)(1..3) , CHAINE(250) , PREFIX (20)

NBTABLE=0
For TT = TABLE1,TABLE2,TABLE3,TABLE4,TABLE5
 If TT<>""
  If left$(TT,1)="="
   PTT = right$(TT,2)
   Gosub PLUS_TAB
  Else
   UTT = TT
   Gosub UNE_TAB
  Endif
 Endif
Next TT
FORMULE = vireblc(format$("KT:250X",EXPRES),2)
Gosub SAI_FORMULE
End

#-------------------------------------------------------#
$PLUS_TAB
J = evalue("dim("+PTT+")")
For I=0 To J-1
 UTT = evalue(PTT+"("+num$(I)+")")
 Gosub UNE_TAB
Next I
Return

#--------------------#
$UNE_TAB
Case left$(UTT,3)
 When "[F]"
  Read [ATB]CODFIC = right$(UTT,4)
  If !fstat
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Else
   Read [AVW]AVW0 = right$(UTT,4)
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = UTT
   Endif
  Endif
 When "[F:"
  Read [ATB]CODFIC = right$(UTT,instr(1,UTT,"]")+1)
  If !fstat
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Else
   Read [AVW]AVW0 = right$(UTT,instr(1,UTT,"]")+1)
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = UTT
   Endif
  Endif
 When "[M]"
  Read [AMK]CODMSK = right$(UTT,4)
  If !fstat
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Endif
 When "[M:"
  Read [AMK]CODMSK = right$(UTT,instr(1,UTT,"]")+1)
  If !fstat
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Endif
 When "[V]"
  K = instr(1,UTT," ")
  If K
   CHAINE = seg$(UTT,4,K-1)
  Else
   CHAINE = right$(UTT,4)
  Endif
  If evalue("dim("+CHAINE+")")
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Endif
 When "[L]"
  K = instr(1,UTT," ")
  If K
   CHAINE = seg$(UTT,4,K-1)
  Else
   CHAINE = right$(UTT,4)
  Endif
  If evalue("dim("+CHAINE+")")
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Endif
 When "[A:"
  If val(seg$(UTT,instr(1,UTT,"[A:")+3,instr(1,UTT,"]")-1))>0
   Read [F:ADV]CODE = val(seg$(UTT,instr(1,UTT,"[A:")+3,instr(1,UTT,"]")-1))
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = UTT
   Endif
  Endif
 When "[A]"
  If val(right$(UTT,4))>0
   Read [F:ADV]CODE = val(right$(UTT,4))
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = UTT
   Endif
  Endif
 When Default
  Read [ATB]CODFIC = UTT
  If !fstat
   NBTABLE += 1
   TABLE(NBTABLE) = UTT
  Else
   Read [AVW]AVW0 = UTT
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = UTT
   Endif
  Endif
Endcase
Return

#-------------------------------------------------------#
$SAI_FORMULE
Formula FORMULE As [AAA_]

# Nouvelle table/vue-Aide de la table/vue
Field [AAA_]  5 , "" , "ZZ1" , mess(131,126,1) , mess(161,133,1) , "ZZ1"
# Nouvel ÃĐcran/Aide de l'ÃĐcran
Field [AAA_]  5 , "" , "ZZ2" , mess(132,126,1) , mess(163,133,1) , "ZZ2"

NBCHAMP = 0
NBVAR = 0
NBCOD = 0

# Aides suivant les valeurs des paramÃĻtres de l'action AFORMULE
For I=1 To NBTABLE
 TT = TABLE(I)
 Case left$(TT,3)
  When "[M]","[M:" : Gosub MASQUE
  When "[F]","[F:" : Gosub TABLE
  When "[V]"       : Gosub VARIAGLO
  When "[L]"       : Gosub VARIALOC
  When "[A]","[A:" : Gosub DIVERSE
  When Default     : Gosub TABLE
 Endcase
Next I

# Variables globales/Aide de la table/Variable
I = 0
For [AVR]AVR0 Where TYP=1 & (FCT=GFONCTION or FCT = "")
 I += 1
 If I=1
  Field [AAA_]  1 , "" , "VARIABLE" , mess(86,123,1) , mess(161,133,1) , mess(142,105,1)
 Endif
 # Aide du champ
 Call TEXTE([F:AVR]INTIT,TEX(1)) From OBJDIV
 OPE(1) = format$("KTv2:15X",[F:AVR]COD)
 Field [AAA_]  2 , "VARIABLE" , "VARIABLE."+OPE(1) , OPE(1)-TEX(1) , mess(162,133,1) , OPE(1)
Next AVR
If NBVARGLO>0
 If I=0
  # Variables locales/Aide de la table/Variable
  Field [AAA_]  1 , "" , "VARIABLE" , mess(86,123,1) , mess(161,133,1) , mess(142,105,1)
 Endif
 For I=1 To NBVARGLO
  # Aide du champ
  Field [AAA_]  2 , "VARIABLE" , "VARIABLE."+CODVARGLO(I) , CODVARGLO(I)-TEXVARGLO(I) , mess(162,133,1) , CODVARGLO(I)
 Next I
Endif

# Variables suivant environnement
I = 0
For [AVR]AVR0 Where TYP=2 & FCT=GFONCTION
 I += 1
 If I=1
  # Variables locales/Aide de la table/Variable
  Field [AAA_]  1 , "" , "VARENV" , mess(212,100,1) , mess(161,133,1) , mess(142,105,1)
 Endif
 # Aide du champ
 Call TEXTE([F:AVR]INTIT,TEX(1)) From OBJDIV
 OPE(1) = format$("KTv2:15X",[F:AVR]COD)
 Field [AAA_]  2 , "VARENV" , "VARENV."+OPE(1) , OPE(1)-TEX(1) , mess(162,133,1) , OPE(1)
Next AVR
If NBVARLOC>0
 If I=0
  # Variables locales/Aide de la table/Variable
  Field [AAA_]  1 , "" , "VARENV" , mess(212,100,1) , mess(161,133,1) , mess(142,105,1)
 Endif
 For I=1 To NBVARLOC
  # Aide du champ
  Field [AAA_]  2 , "VARENV" , "VARENV."+CODVARLOC(I) , CODVARLOC(I)-TEXVARLOC(I) , mess(162,133,1) , CODVARLOC(I)
 Next I
Endif

# Fonctions suivant environnement
I = 0
For [AVR]AVR0 Where TYP=3 & (FCT=GFONCTION or FCT="")
 I += 1
 If I=1
  # Fonctions/Aide sur fonction/Fonction
  Field [AAA_]  275 , "" , "FONCTION" , mess(3,2945,1) , mess(190,151,1) , mess(75,123,1)
 Endif
 K = instr(1,[F:AVR]COD,"/")
 If K
  OPE(2) = left$([F:AVR]COD,K-1)
  OPE(3) = right$([F:AVR]COD,K+1)
  Read [ASU]ASU0=OPE(2);OPE(3)
  If !fstat
   # Aide sur fonction
   Call TEXTE([F:AVR]INTIT,TEX(1)) From OBJDIV
   OPE(1) = format$("KTv2:50X",[F:AVR]COD)
   CHAINE = "func "+OPE(2)+"."+OPE(3)
   J = 0
   For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    J += 1
    If J=1
     CHAINE += "("
    Else
     CHAINE += ","
    Endif
    CHAINE += [F:ASP]PARAM
   Next ASP
   If J
    CHAINE += ")"
   Endif
   Field [AAA_]  275 , "FONCTION" , "FONCTION."+OPE(1) , TEX(1) , OPE(2)+"_"+OPE(3) , CHAINE
  Endif
 Endif
Next AVR

# Michel Giet (Variables locales)
If dim(WVAS)>0
 Gosub DEFVARLOC
 # Variables locales/Aide de la table/Variable
 Field [AAA_]  1 , "" , "VARLOC" , mess(212,100,1) , mess(161,133,1) , mess(142,105,1)
 For I=1 To NBTEX
  # Aide du champ
  Field [AAA_]  2 , "VARLOC" , "VARLOC."+OPE(I) , TEX(I) , mess(162,133,1) , OPE(I)
 Next I
 For I=1 To NBVAR
  # Aide du champ
  Field [AAA_]  2 , "VARLOC" , "VARLOC."+CODVAR(I) , CODVAR(I)-TEXVAR(I) , mess(162,133,1) , CODVAR(I)
 Next I
Endif

If dim([V]GFRMNB)>0 & GFRMNB>0
 # Variables locales/Aide de la table/Variable
 Field [AAA_]  1 , "" , "VARSUP" , mess(212,100,1) , mess(161,133,1) , mess(142,105,1)
 For I=1 To GFRMNB
  # Aide du champ
  Field [AAA_]  2 , "VARSUP" , "VARSUP."+GFRMVAR(I) , GFRMVAR(I)-GFRMLIB(I) , mess(162,133,1) , GFRMVAR(I)
 Next I
Endif

Boxact [AAA_]

#----------------------------#
$SAI
Boxinp [AAA_] Using REPONSE, FORMULE
Case REPONSE
 When 7       : Goto FIN
 When 46      : Gosub VERIF : If E=0 : Infbox mess(157,100,1) : Endif : # OK
 When 1       : Gosub VERIF : If E=0 : EXPRES = FORMULE : Goto FIN : Else : Goto SAI_FORMULE : Endif
 When 47      : Gosub ADD_OBJET
 When Default : Infbox "REPONSE"-num$(REPONSE)
Endcase
Goto SAI

#----------------------------#
$FIN
GSTATUT = REPONSE
Close Inpbox [AAA_]
Return

#-----------------------------#
$ADD_OBJET
Case FORMULE
 When "ZZ1" : Gosub ADD_TABLE
 When "ZZ2" : Gosub ADD_ECRAN
Endcase
Return

#-----------------------------#
$ADD_TABLE
Raz PARAM , TT
Call S_TAB_CHAR(TT,PARAM,"ASELVTAB","SUBAVW","") From GACTION
If TT<>"" and !find(TT,TABLE(1..NBTABLE))
 NBTABLE += 1
 TABLE(NBTABLE) = TT
 Gosub TABLE
Endif
Return

#-----------------------------#
$ADD_ECRAN
TT = ""
PARAM(1) = "AMK"
PARAM(2) = "$"
PARAM(3) = ""
Call S_TAB_CHAR(TT,PARAM,"SELOBJ","SELOBJ","") From GACTION
If TT<>""
 Gosub MASQUE
Endif
Return

#----------------------------#
$TABLE
If left$(TT,3)="[F]"
 CHAINE = right$(TT,4)
 Read [ATB]CODFIC = CHAINE
 If fstat
  Raz [F:ATB]
  Read [AVW]AVW0 = CHAINE
 Endif
 ABR = ""
Elsif left$(TT,3)="[F:"
 CHAINE = right$(TT,instr(1,TT,"]")+1)
 Read [ATB]CODFIC = CHAINE
 If fstat
  Raz [F:ATB]
  Read [AVW]AVW0 = CHAINE
 Endif
 ABR = seg$(TT,4,instr(1,TT,"]")-1)
Else
 CHAINE = TT
 Read [ATB]CODFIC = CHAINE
 If !fstat
  ABR = [F:ATB]ABRFIC
 Else
  Raz [F:ATB]
  Read [AVW]AVW0 = CHAINE
  ABR = [F:AVW]ABRVUE
 Endif
Endif
If !find(ABR-[F:ATB]CODFIC,COD(1..NBCOD))
 NBCOD += 1
 COD(NBCOD) = ABR-[F:ATB]CODFIC
 If [F:ATB]CODFIC<>""
  Gosub CHAMP_TABLE
 Else
  Gosub CHAMP_VUE
 Endif
Endif
Return

#----------------------------#
$CHAMP_TABLE
Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
If [F:ATB]ABRFIC<>ABR
 TEXTE -= "("+ABR+")"
Endif
# Table/Aide de la table
Field [AAA_] 1 , "" , COD(NBCOD) , mess(56,123,1)-[F:ATB]CODFIC-TEXTE , mess(161,133,1) , ABR
For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC
 Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
 If [F:ATZ]CODACT<>""
  Read [ACV]CODACT = [F:ATZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:ATZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:ATZ]DIME
 Endif
 For J=1 To DIME
  If DIME=1
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-TEXTE
   If ABR=""
    CHAMP = "[F]"+[F:ATZ]CODZONE
   Else
    CHAMP = "[F:"+ABR+"]"+[F:ATZ]CODZONE
   Endif
  Else
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE+"("+num$(J-1)+")"
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-"("+num$(J-1)+")"-TEXTE
   If ABR=""
    CHAMP = "[F]"+[F:ATZ]CODZONE+"("+num$(J-1)+")"
   Else
    CHAMP = "[F:"+ABR+"]"+[F:ATZ]CODZONE+"("+num$(J-1)+")"
   Endif
  Endif
  # Aide du champ
  Field [AAA_] 2 , COD(NBCOD) , COD(NBCOD)+"."+[F:ATZ]CODZONE+"_"+num$(J) , DESIG , mess(162,133,1) , CHAMP
  NBCHAMP += 1
 Next J
Next
Return

# Michel Giet : possibilitÃĐ de convertir le libellÃĐ du champs (tarifs)
#
$CONVTEX
For L = 0 To dim(WCVF)-1
  If WCVF(L) = CHAINE & WCVZ(L)= WCVW
    TEXTE = WCVT(L)
    Break
  Endif
Next L
Return

#----------------------------#
$CHAMP_VUE
Call TEXTE([F:AVW]INTIT,TEXTE) From OBJDIV
If [F:AVW]ABRVUE<>ABR
 TEXTE -= "("+ABR+")"
Endif
# Table/Aide de la table
Field [AAA_]  1 , "" , COD(NBCOD) , mess(77,139,1)-[F:AVW]CODVUE-TEXTE , mess(161,133,1) , ABR
For [AVD]AVD1 Where CODVUE=[F:AVW]CODVUE
 Call TEXTE([F:AVD]FLDINT,TEXTE) From OBJDIV
 If [F:AVD]FLDACT<>""
  Read [ACV]CODACT = [F:AVD]FLDACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:AVD]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:AVD]DIME
 Endif
 For J=1 To DIME
  If DIME=1
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:AVD]FLDVUE
     Gosub CONVTEX
   Endif
   DESIG = [F:AVD]FLDVUE-TEXTE
   If ABR=""
    CHAMP = "[F]"+[F:AVD]FLDVUE
   Else
    CHAMP = "[F:"+ABR+"]"+[F:AVD]FLDVUE
   Endif
  Else
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:AVD]FLDVUE+"("+num$(J-1)+")"
     Gosub CONVTEX
   Endif
   DESIG = [F:AVD]FLDVUE-"("+num$(J-1)+")"-TEXTE
   If ABR=""
    CHAMP = "[F]"+[F:AVD]FLDVUE+"("+num$(J-1)+")"
   Else
    CHAMP = "[F:"+ABR+"]"+[F:AVD]FLDVUE+"("+num$(J-1)+")"
   Endif
  Endif
  # Aide du champ
  Field [AAA_]  2 , COD(NBCOD) , COD(NBCOD)+"."+[F:AVD]FLDVUE+"_"+num$(J) , DESIG , mess(162,133,1) , CHAMP
  NBCHAMP += 1
 Next J
Next
Return

$DIVERSE
If left$(TT,3)="[A]"
 CHAINE = right$(TT,4)
Elsif left$(TT,3)="[A:"
 CHAINE = right$(TT,instr(1,TT,"]")+1)
Else
 CHAINE = TT
Endif
If instr(1,TT,"~")
 I=instr(1,TT,"~")
 PREFIX=right$(TT,I+1)
Endif
Read [ADV]CODE = val(CHAINE)
NUM = [F:ADV]NUMTAB
Call LECTEXTRA(TEXTE,"ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"") From ATEXTRA
If !find("ADI"-num$(NUM),COD(1..NBCOD))
 NBCOD += 1
 COD(NBCOD) = "ADI"-num$(NUM)
 Field [AAA_]  1 , "" , COD(NBCOD), mess(63,139,1)-num$(NUM)-":"-TEXTE ,"" , num$(NUM)
 For [F:ADI] Where NUMTAB = NUM
  DESIG = ""
  Call LECTEXTRA(DESIG,"ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From ATEXTRA
  Field [AAA_]  2 , COD(NBCOD) , [F:ADI]CODE , DESIG-"("+[F:ADI]CODE+")", "" , PREFIX+[F:ADI]CODE
  NBCHAMP += 1
 Next
Endif
Return

#----------------------------#
$MASQUE
If left$(TT,3)="[M]"
 CHAINE = right$(TT,4)
 Read [AMK]CODMSK = CHAINE
 ABR = ""
Elsif left$(TT,3)="[M:"
 CHAINE = right$(TT,instr(1,TT,"]")+1)
 Read [AMK]CODMSK = CHAINE
 ABR = seg$(TT,4,instr(1,TT,"]")-1)
Else
 CHAINE = TT
 Read [AMK]CODMSK = CHAINE
 ABR = [F:AMK]ABRMSK
Endif
Call TEXTE([F:AMK]INTMSK,TEXTE) From OBJDIV
If [F:AMK]ABRMSK<>ABR
 TEXTE -= "("+ABR+")"
Endif
If !find(ABR-[F:AMK]CODMSK,COD(1..NBCOD))
 NBCOD += 1
 COD(NBCOD) = ABR-[F:AMK]CODMSK
 # Ecran/Aide de l'ÃĐcran
 Field [AAA_]  1 , "" , COD(NBCOD) , mess(2,42,1)-[F:AMK]CODMSK-TEXTE , mess(163,133,1) , ABR
 Gosub ZONE
Endif
Return

#----------------------------#
$ZONE
For [AMZ]CODZON Where CODMSK=[F:AMK]CODMSK
 Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:AMZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:AMZ]DIME
 Endif
 If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1
  If [F:AMZ]CODTYP="ABS"
   DESIG = [F:AMZ]CODZON-TEXTE
   If ABR<>""
    CHAMP = "[M:"+ABR+"]"+[F:AMZ]CODZON
   Else
    CHAMP = "[M]"+[F:AMZ]CODZON
   Endif
   # Aide du champ
   Field [AAA_]  2 , COD(NBCOD) , COD(NBCOD)+"."+[F:AMZ]CODZON , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Else
   DESIG = [F:AMZ]CODZON-"()"-TEXTE
   CHAMP = "[M:"+ABR+"]"+[F:AMZ]CODZON+"(indice)"
   # Aide du champ
   Field [AAA_]  2 , COD(NBCOD) , COD(NBCOD)+"."+[F:AMZ]CODZON , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Endif
 Else
  For J=1 To DIME
   If DIME=1
    DESIG = [F:AMZ]CODZON-TEXTE
    If ABR<>""
     CHAMP = "[M:"+ABR+"]"+[F:AMZ]CODZON
    Else
     CHAMP = "[M]"+[F:AMZ]CODZON
    Endif
   Else
    DESIG = [F:AMZ]CODZON-"("+num$(J-1)+")"-TEXTE
    If ABR<>""
     CHAMP = "[M:"+ABR+"]"+[F:AMZ]CODZON+"("+num$(J-1)+")"
    Else
     CHAMP = "[M]"+[F:AMZ]CODZON+"("+num$(J-1)+")"
    Endif
   Endif
   # Aide du champ
   Field [AAA_]  2 , COD(NBCOD) , COD(NBCOD)+"."+[F:AMZ]CODZON+"_"+num$(J) , DESIG , mess(162,133,1) , CHAMP
   NBCHAMP += 1
  Next J
 Endif
Next
Return

#----------------------------#
$VERIF
If FORMULE=""
 E = 0
Else
 E = abs(parse(FORMULE))
 If E
  Errbox errmes$(E)+chr$(13)+errm
 Endif
Endif
Return

#----------------------------#
$DEFVARLOC
NBTEX = 0
If dim(WVAT) > 0
  For  I = 0 To dim(WVAT)-1
    If I < dim(OPE)-1 & I < dim(TEX)-1
      NBTEX += 1
      OPE(NBTEX) = WVAS(I)
      TEX(NBTEX) = WVAT(I)
    Endif
  Next
Endif
Return

#----------------------------#
$VARIA
CHAINE = right$(TT,4)
K = instr(1,CHAINE," ")
NBVAR += 1
If K
 CODVAR(NBVAR) = left$(CHAINE,K-1)
 CHAINE = right$(CHAINE,K+1)
Else
 CODVAR(NBVAR) = CHAINE
 CHAINE = ""
Endif
TEXVAR(NBVAR) = CHAINE
Return

#----------------------------#
$VARIALOC
CHAINE = right$(TT,4)
K = instr(1,CHAINE," ")
NBVARLOC += 1
If K
 CODVARLOC(NBVARLOC) = left$(CHAINE,K-1)
 CHAINE = right$(CHAINE,K+1)
Else
 CODVARLOC(NBVARLOC) = CHAINE
 CHAINE = ""
Endif
TEXVARLOC(NBVARLOC) = CHAINE
Return

#----------------------------#
$VARIAGLO
CHAINE = right$(TT,4)
K = instr(1,CHAINE," ")
NBVARGLO += 1
If K
 CODVARGLO(NBVARGLO) = left$(CHAINE,K-1)
 CHAINE = right$(CHAINE,K+1)
Else
 CODVARGLO(NBVARGLO) = CHAINE
 CHAINE = ""
Endif
TEXVARGLO(NBVARGLO) = CHAINE
Return

#------------------------------------------------------------------------#
Subprog B1_FORMUL(EXPRES,FILTAB,TEXCON,VARSUP)
Variable Char    EXPRES()
Variable Char    FILTAB()
Variable Char    TEXCON()
Variable Char    VARSUP()
#
Local    Char    WFIL(250)
Local    Integer WCVD, WVAR, I, J, K, L
#
# CrÃĐation des tables de conversion
WCVD = 0
For I = 0 To dim(TEXCON)-1
  If TEXCON(I) <> ""
    WCVD += 1
  Endif
Next
#
If WCVD > 0
  Local Char WCVF(20)(WCVD)
  Local Char WCVZ(20)(WCVD)
  Local Char WCVT(50)(WCVD)
  Local Char WCVW(80)
  For I = 0 To WCVD - 1
    WCVW = TEXCON(I)
    J = instr(1,WCVW,",")
    K = instr(J+1,WCVW,",")
    WCVF(I) = seg$(WCVW,1,J-1)
    WCVZ(I) = seg$(WCVW,J+1,K-1)
    WCVT(I) = seg$(WCVW,K+1,len(WCVW))
  Next I
Endif
# CrÃĐation table variables suplÃĐmentaires
WVAR = 0
For I = 0 To dim(VARSUP)-1
  If VARSUP(I) <> ""
    WVAR += 1
  Endif
Next
#
If WVAR > 0
  Local Char WVAS(50)(WVAR)
  Local Char WVAT(50)(WVAR)
  Local Char WVAW(100)
  For I = 0 To WVAR - 1
    WVAW = VARSUP(I)
    J = instr(1,WVAW,",")
    WVAS(I) = seg$(WVAW,1,J-1)
    WVAT(I) = seg$(WVAW,J+1,len(WVAW))
  Next I
Endif
#
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AVW])=0 : Local File AVIEW     [AVW] : Endif
If clalev([F:AVD])=0 : Local File AVIEWD    [AVD] : Endif
If clalev([F:AVT])=0 : Local File AVIEWTAB  [AVT] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK      [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON   [AMZ] : Endif
If clalev([F:AVR])=0 : Local File AVARLOC   [AVR] : Endif
If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif

Local Char    TT(30) , PTT(30) , UTT(30) , TABLE(30)(1..100) , COD(20)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , FORMULE(250)
Local Integer E , I , J , K , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL , NBCOD
Local Integer NBVAR , NUM , NBVARLOC , NBVARGLO
Local Char    OPE(50)(1..50+WVAR) , TEX(50)(1..50+WVAR) , ABR(GLONABR)
Local Char    CODVAR(80)(1..50+WVAR) , TEXVAR(50)(1..50+WVAR)
Local Char    CODVARLOC(80)(1..50+WVAR) , TEXVARLOC(50)(1..50+WVAR)
Local Char    CODVARGLO(80)(1..50+WVAR) , TEXVARGLO(50)(1..50+WVAR)
Local Char    PARAM(250)(1..3) , CHAINE(250) , PREFIX (20)

# SÃĐlection des tables (Filtre si dimension = 1 / Liste si dimension <> 1)
NBTABLE=0
If dim(FILTAB) = 1 & FILTAB <> ""
  Filter [ATB] Where evalue(FILTAB)
&              Order By Key CODFIC
  For [ATB]
    If NBTABLE < dim(TABLE)
      NBTABLE += 1
      TABLE(NBTABLE) = [F:ATB]CODFIC
    Else
      Break
    Endif
  Next
  Filter [ATB]
  Filter [AVT] Where evalue(FILTAB)
  For [AVT]
    If NBTABLE < dim(TABLE)
      NBTABLE += 1
      TABLE(NBTABLE) = [F:AVT]CODFIC
    Else
      Break
    Endif
  Next
  Filter [AVT]
Else
  For I = 0 To dim(FILTAB)-1
    If FILTAB(I) <> ""
      Read [ATB]CODFIC=FILTAB(I)
      If fstat=0
        NBTABLE += 1
        TABLE(NBTABLE) = [F:ATB]CODFIC
      Else
        Read [AVW]AVW0=FILTAB(I)
        If fstat=0
          NBTABLE += 1
          TABLE(NBTABLE) = [F:AVW]CODVUE
        Endif
      Endif
    Endif
  Next I
Endif
FORMULE = vireblc(format$("KT:250X",EXPRES),2)
Gosub SAI_FORMULE
End

#------------------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "AFRCONT" : Gosub AFRCONT
Endcase
Return

#-----------------------------#
$AFRCONT
Local Integer E , ER
Local Char    CHAINE(250)
If VALEUR="" : Return : Endif
CHAINE = PARAM(1) : # Expression pour ne pas faire le contrÃīle
If CHAINE<>""
 Onerrgo ER
 E = evalue(CHAINE)
 Onerrgo
 If !ER & !E
  Return
 Endif
Endif
VALEUR = format$("KTv2:255X",VALEUR)
E = parse(VALEUR)
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E) : # Expression incorrecte
 mkstat = 2 : Return
Endif
Return

$ER
ER = errn
Resume

#-----------------------------# A virer #-----------------------------#
Subprog C_FORMULE(VALEUR)
Variable Char VALEUR()
Local Integer E
If VALEUR="" : End : Endif
VALEUR = format$("KTv2:255X",VALEUR)
E = parse(VALEUR)
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E) : # Expression incorrecte
 mkstat = 2 : End
Endif
End

Subprog IB_FORMULE
GBOUT1 = mess(190,139,1) : # Assistant de formule
GFRMNB = 0
End

#------------------------------------------------------------------------#
Subprog AFFMESS
Local Integer I , J , K , L , M , N , C , OK
Local Clbfile CLOB(GLONACB)
If zoncou=""
 End
Elsif evalue("dim([M]"+zoncou+")")<=0
 End
Endif
CLOB = zc
I = 0
While pat(vireblc(right$(CLOB,I+1),4),"*mess(#*,#*,#*)*")
 I = instr(I+1,CLOB,"mess(")
 If I
  J = instr(I+1,CLOB,")")
  If J
   K = instr(I,CLOB,",")
   If K
    N = val(seg$(CLOB,I+5,K-1))
    L = instr(K+1,CLOB,",")
    If L
     C = val(seg$(CLOB,K+1,L-1))
     M = val(seg$(CLOB,L+1,J-1))
     CLOB = left$(CLOB,I-1)+mess(N,C,M)+right$(CLOB,J+1)
    Endif
   Endif
  Endif
 Endif
Wend
Local Mask AFFCLOB [AFF]
[M:AFF]AFFCLB = CLOB
Call DIALWIN(OK,mess(201,124,1),"AFFCLOB") From GESECRAN : # Message
Close Local Mask [AFF]
End
