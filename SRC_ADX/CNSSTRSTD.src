#<AdxTL>@(#)6.0.0.0 $Revision$ Consultation SAD
Local Char PARAM(20)(1..4)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "AB"
PARAM(4) = ""
Call GCONSULT("STR","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FERME"      : Gosub FERME
  When "LECTURE"    : Gosub LECTURE
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return

############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:SDH])=0 : Local File SDELIVERY  [SDH] : Endif
If clalev([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif
If clalev([F:PNH])=0 : Local File PRETURN    [PNH] : Endif
If clalev([F:PND])=0 : Local File PRETURND   [PND] : Endif
If clalev([F:STJ])=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:WCN])=0 : Local File WRKSTOCNS  [WCN] : Endif
If clalev([F:SRD])=0 : Local File SRETURND   [SRD] : Endif   : # Issue X3-81029
#
Local Char    WFIL(250), WFILS(250), WFILSTJ(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I,J
Local Decimal WRTNQTY   : # Issue X3-81029
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSTR"
SUITE  = 1
RETOUR = 1
J=0
Return
############################################################
$FIN_CRIT
[M:STR1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:STR1]FLG = 0
Return
############################################################
$FERME
Filter [STJ]
Filter [WCN]
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STR1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STR1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
Return
############################################################
$LECTURE
If [M:STR1]ITMREF = "" | [M:STR1]FCY = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TAB_WRKSTOCNS
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [WCN]
      If nolign <= MAXLIG
         Gosub LOA_LIGNE
         NBLU    = 2
         nolign += 1
         NOL    += 1
      Else
         Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [WCN]
       If WLIG >= WSKIP
         If nolign <= MAXLIG
           Gosub LOA_LIGNE
           NBLU    = 2
           nolign += 1
           NOL    += 1
         Else
           Break
         Endif
       Else
         WLIG += 1
       Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:STR2]
    WLIG = 0
    For [WCN]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [WCN]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [WCN]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return

############################################################
$TAB_WRKSTOCNS
If [M:STR1]FLG = 1
   Return
Else [M:STR1]FLG = 1
Endif
Raz [M:STR2]
#--- purge table WRKSTOCNS
Gosub TRT_PURGE_WCN

#--- livraison en transfert
Gosub TRT_FILTER_LIV
For [LNK]
  Gosub TRT_FILTER_JOU_L
  Gosub TRT_LECT_JOU_L
Next

#--- retour en transfert
Gosub TRT_FILTER_RET
For [LN2]
  Gosub TRT_FILTER_JOU_R
  Gosub TRT_LECT_JOU_R
Next

#--- filtre table WRKSTOCNS
Gosub TRT_FILTER_WCN
Return

############################################################
$TRT_PURGE_WCN
Delete [WCN] Where USR    = GUSER &
&                  NUMREQ = adxuid(1)
Return

############################################################
$TRT_FILTER_WCN
Filter [WCN] Where USR    = GUSER &
&                  NUMREQ = adxuid(1)
&            Order By Key WCN0
Return

############################################################
$TRT_FILTER_LIV
Gosub LOAD_FILTER_LIV
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Link [SDD] With [SDH]SDH0=[F:SDD]SDHNUM
&            As [LNK]
&            Where evalue(WFIL)  &
&                  evalue(WFILS) &
&                  evalue(WFILSPE)
&            Order By Key SDD2
Return

############################################################
$LOAD_FILTER_LIV
# Filtre livraison inter-sites
WFIL = "[F:SDH]BETFCY=2"
# Filtre site
If [M:STR1]FCY <> ""
  WFIL += "&[F:SDH]STOFCY=[M:STR1]FCY"
Endif
# Filtre article
If [M:STR1]ITMREF <> ""
    WFIL += "&[F:SDD]ITMREF=[M:STR1]ITMREF"
Endif
# Filtre livraison non receptionnée entierement
WFIL += "&[F:SDD]QTYSTU>[F:SDD]RCPQTYSTU"
Return

############################################################
$TRT_FILTER_JOU_L
#--- Issue X3-81029
Raz WRTNQTY
For [SRD]SRD1 Where SDHNUM=[F:SDD]SDHNUM & SDDLIN=[F:SDD]SDDLIN & PNHNUM=""
  WRTNQTY += [F:SRD]QTYSTU
Next
#---
# filtre sur la table STOJOU
Gosub LOAD_FILTER_JOU_L
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Filter [STJ] Where evalue(WFILSTJ) & evalue(WFILSPE)
&            Order By Key STJ1
Return

############################################################
$LOAD_FILTER_JOU_L
WFILSTJ  = " [F:STJ]STOFCY=[F:SDD]STOFCY"
WFILSTJ += "&[F:STJ]ITMREF=[F:SDD]ITMREF"
WFILSTJ += "&[F:STJ]UPDCOD=2"
WFILSTJ += "&[F:STJ]REGFLG<>2"
WFILSTJ += "&[F:STJ]VCRTYP=4"
WFILSTJ += "&[F:STJ]VCRNUM=[F:SDD]SDHNUM"
WFILSTJ += "&[F:STJ]VCRLIN=[F:SDD]SDDLIN"
WFILSTJ += "&[F:STJ]QTYSTU<0"
Return

############################################################
$TRT_LECT_JOU_L
#--- Issue X3-81029
#If [F:SDD]RCPQTYSTU=0 | rowcount([STJ])=1
If ([F:SDD]RCPQTYSTU=0 & WRTNQTY=0) | rowcount([STJ])=1
#---
   For [STJ]
      Gosub CRE_WCN_LIV
   Next
Else
   Raz [F:STJ]
   Gosub CRE_WCN_LIV
Endif
Return

############################################################
$CRE_WCN_LIV
# creation de l'enregistrement WCN
Trbegin [WCN]
Raz [F:WCN]
[F:WCN]NUMREQ = adxuid(1)
[F:WCN]USR    = GUSER
J +=1
[F:WCN]NUMLIG = J
[F:WCN]STOFCY = [F:SDH]STOFCY
[F:WCN]PRHFCY = [F:SDH]PRHFCY
[F:WCN]VCRTYP = 4
[F:WCN]VCRNUM = [F:SDH]SDHNUM
[F:WCN]VCRLIN = [F:SDD]SDDLIN
[F:WCN]ITMREF = [F:SDD]ITMREF
[F:WCN]STU    = [F:SDD]STU

#--- Issue X3-81029
#If [F:SDD]RCPQTYSTU=0
#    [F:WCN]QTYSTU(nolign-1) = abs([F:STJ]QTYSTU)
#Else [F:WCN]QTYSTU(nolign-1) = abs([F:SDD]QTYSTU-[F:SDD]RCPQTYSTU)
#Endif
If [F:SDD]RCPQTYSTU=0 & WRTNQTY=0
  [F:WCN]QTYSTU(nolign-1) = abs([F:STJ]QTYSTU)
Else
  [F:WCN]QTYSTU(nolign-1) = abs([F:SDD]QTYSTU-[F:SDD]RCPQTYSTU-WRTNQTY)
Endif
#---

#--- Issue X3-81029
#If [F:SDD]RCPQTYSTU <>0 & rowcount([STJ])>1
#   [F:WCN]LOT    = "***"
#   [F:WCN]SLO    = "***"
#   [F:WCN]SERNUM = "***"
#   [F:WCN]LOC    = "***"
#   [F:WCN]STA    = "***"
#   [F:WCN]BPSLOT = "***"
#Else
#   [F:WCN]LOT    = [F:STJ]LOT
#   [F:WCN]SLO    = [F:STJ]SLO
#   [F:WCN]SERNUM = [F:STJ]SERNUM
#   [F:WCN]LOC    = [F:STJ]LOC
#   [F:WCN]STA    = [F:STJ]STA
#   [F:WCN]BPSLOT = [F:STJ]BPSLOT
#Endif
If ([F:SDD]RCPQTYSTU=0 & WRTNQTY=0) | rowcount([STJ])=1
   [F:WCN]LOT    = [F:STJ]LOT
   [F:WCN]SLO    = [F:STJ]SLO
   [F:WCN]SERNUM = [F:STJ]SERNUM
   [F:WCN]LOC    = [F:STJ]LOC
   [F:WCN]STA    = [F:STJ]STA
   [F:WCN]BPSLOT = [F:STJ]BPSLOT
Else
   [F:WCN]LOT    = "***"
   [F:WCN]SLO    = "***"
   [F:WCN]SERNUM = "***"
   [F:WCN]LOC    = "***"
   [F:WCN]STA    = "***"
   [F:WCN]BPSLOT = "***"
Endif

If [F:WCN]QTYSTU(nolign-1)=0
   Rollback : Return
Endif
#---

Write [F:WCN]
If fstat : Goto ROLL_CRE_L : Endif
Commit
Return

$ROLL_CRE_L
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto CRE_WCN_LIV : Endif
Return

############################################################
$TRT_FILTER_RET
Gosub LOAD_FILTER_RET
Link [PND] With [PNH]PNH0=[F:PND]PNHNUM
&            As [LN2]
&            Where evalue(WFIL)  &
&                  evalue(WFILS)
&            Order By Key PND0
Return

############################################################
$LOAD_FILTER_RET
# Filtre retour inter-sites
WFIL = "[F:PNH]BETFCY=2"
# Filtre site
If [M:STR1]FCY <> ""
  WFIL += "&[F:PNH]PNHFCY=[M:STR1]FCY"
Endif
# Filtre article
If [M:STR1]ITMREF <> ""
    WFIL += "&[F:PND]ITMREF=[M:STR1]ITMREF"
Endif
# Filtre retour non receptionné entierement
WFIL += "&[F:PND]QTYSTU>[F:PND]SRDQTYSTU"
Return

############################################################
$TRT_FILTER_JOU_R
# filtre sur la table STOJOU
Gosub LOAD_FILTER_JOU_R
Filter [STJ] Where evalue(WFILSTJ)
&            Order By Key STJ1
Return

############################################################
$LOAD_FILTER_JOU_R
WFILSTJ  = " [F:STJ]STOFCY=[F:PND]PNHFCY"
WFILSTJ += "&[F:STJ]ITMREF=[F:PND]ITMREF"
WFILSTJ += "&[F:STJ]UPDCOD=2"
WFILSTJ += "&[F:STJ]REGFLG<>2"
WFILSTJ += "&[F:STJ]VCRTYP=8"
WFILSTJ += "&[F:STJ]VCRNUM=[F:PND]PNHNUM"
WFILSTJ += "&[F:STJ]VCRLIN=[F:PND]PNDLIN"
WFILSTJ += "&[F:STJ]QTYSTU<0"
Return

############################################################
$TRT_LECT_JOU_R
If [F:PND]SRDQTYSTU=0 | rowcount([STJ])=1
   For [STJ]
      Gosub CRE_WCN_RET
   Next
Else
   Raz [F:STJ]
   Gosub CRE_WCN_RET
Endif
Return

############################################################
$CRE_WCN_RET
# creation de l'enregistrement WCN
Trbegin [WCN]
Raz [F:WCN]
[F:WCN]NUMREQ = adxuid(1)
[F:WCN]USR    = GUSER
J +=1
[F:WCN]NUMLIG = J
[F:WCN]STOFCY = [F:PNH]PNHFCY
[F:WCN]PRHFCY = [F:PND]LINSTOFCY
[F:WCN]VCRTYP = 8
[F:WCN]VCRNUM = [F:PNH]PNHNUM
[F:WCN]VCRLIN = [F:PND]PNDLIN
[F:WCN]ITMREF = [F:PND]ITMREF
[F:WCN]STU    = [F:PND]STU

If [F:PND]SRDQTYSTU=0
     [F:WCN]QTYSTU(nolign-1) = abs([F:STJ]QTYSTU)
Else [F:WCN]QTYSTU(nolign-1) = abs([F:PND]QTYSTU-[F:PND]SRDQTYSTU)
Endif
If [F:PND]SRDQTYSTU <>0 & rowcount([STJ])>1
   [F:WCN]LOT    = "***"
   [F:WCN]SLO    = "***"
   [F:WCN]SERNUM = "***"
   [F:WCN]LOC    = "***"
   [F:WCN]STA    = "***"
   [F:WCN]BPSLOT = "***"
Else
   [F:WCN]LOT    = [F:STJ]LOT
   [F:WCN]SLO    = [F:STJ]SLO
   [F:WCN]SERNUM = [F:STJ]SERNUM
   [F:WCN]LOC    = [F:STJ]LOC
   [F:WCN]STA    = [F:STJ]STA
   [F:WCN]BPSLOT = [F:STJ]BPSLOT
Endif

Write [F:WCN]
If fstat : Goto ROLL_CRE : Endif
Commit
Return

$ROLL_CRE
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto CRE_WCN_RET : Endif
Return

############################################################
$LOA_LIGNE
[M:STR2]=[F:WCN]
Return

############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:STR1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:STR1] = [F:ITM]
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:STR1]FLG = 0
End
###########################################################

Subprog IB_NBLIG
  If [M]VCRTYP(nolign-1) <> 4     : Raz GBOUT1 : Endif
  If [M]VCRTYP(nolign-1) <> 8     : Raz GBOUT2 : Endif
End

# FQ 57754 Module Stocks GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

Call VALGTC(APPLI,"STR") From SUBGTC

End

