##################################################
Subprog SUGTLOENT(TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,LOCTYP,OPTPAR)
Value    Integer TRSTYP
Value    Char    CODTRS
Value    Char    STOFCY
Value    Char    ITMREF
Value    Char    UOM
Value    Decimal QTY
Value    Char    STA
Variable Char    LOCTYP()
Value    Char    OPTPAR

Local Integer LSEQ
Local Integer LSTOSEQ
Local Integer LNBDET
Local Integer I
#--- Bug 72649
Local Char    LLOC(GLONLOC)

    If dim([M]WSTOSEQ)>1
        LSTOSEQ = [M]WSTOSEQ(nolign-1)
    Else
        LSTOSEQ = [M]WSTOSEQ
    Endif

    If UOM<>"$" & UOM<>"" & STA<>"$" & STA<>"" & LOCTYP=""
        If LSTOSEQ>0
            I = find(LSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
        Endif
        If I>0
            I -= 1
            LNBDET = func SUBSCSB.CALCNBDET(LSTOSEQ)
            #------ On ne fait pas de suggestion à partir du moment où il y a plusieurs lignes de détail
            #------ car la suggestion crée les réservations
            If LNBDET>1
                End
            Endif
#------ Pour le changement d'emplacement, cela n'a pas d'utilité
#------ mais cela est nécessaire dans le cas des entrées => idée à copier
#-            If LNBDET=1
#-                UOM = [M:SGW]WPCUDES(I)
#-            Endif
            LSEQ = [M:SGW]WLOCSEQ(I)
        Else
            LSEQ = 100000+LSTOSEQ
        Endif
        #--- Bug 72649 ajout paramètre emplacement
        Call STKSUGTLO(LSEQ,TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,LOCTYP,OPTPAR,"","",LLOC) From STKLOC
    Endif

End


##################################################
Subprog CTRTLOENT(TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,OBL,LOCTYP,PRET,OPTPAR)
Value    Integer TRSTYP
Value    Char    CODTRS
Value    Char    STOFCY
Value    Char    ITMREF
Value    Char    UOM
Value    Decimal QTY
Value    Char    STA
Value    Integer OBL
Variable Char    LOCTYP()
Variable Shortint PRET
Value    Char    OPTPAR

Local Integer I
Local Integer LSEQ
Local Integer LSTOSEQ
Local Integer LRET
Local Char    LLOC(GLONLOC)

Local Integer LNBDET
Local Char    LUOM(GLONUOM)
Local Decimal LQTY
Local Char    LSTA(GLONSTA)

    If dim([M]WSTOSEQ)>1
        LSTOSEQ = [M]WSTOSEQ(nolign-1)
    Else
        LSTOSEQ = [M]WSTOSEQ
    Endif

    If LSTOSEQ>0
        I = find(LSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1)) -1
        If I>=0
            LNBDET = func SUBSCSB.CALCNBDET(LSTOSEQ)
        Endif
    Endif
    If LNBDET>1
        OBL = 1
        # Si la quantité a été modifiée, on considère jusqu'à la fin de ligne le contrôle OK
        # De toute façon, la fenêtre de détail s'ouvrira
        If UOM<>"$" & QTY<>sigma(I, [M:SGW]NBLIG-1, (([M:SGW]WSTOSEQ(indcum) = LSTOSEQ) | sigma([M:SGW]NBLIG,[M:SGW]NBLIG,0))
&                                                  *([M:SGW]WQTYPCUDES(indcum)) )
            End
        Endif
    Endif

    LNBDET = sigma(I,[M:SGW]NBLIG-1, [M:SGW]WSTOSEQ(indcum) = LSTOSEQ)
    For J=0 To max(LNBDET-1,0)
        If UOM="$"
            LUOM = [M:SGW]WPCUDES(I+J)
            LQTY = [M:SGW]WQTYPCUDES(I+J)
        Else
            LUOM = UOM
            LQTY = QTY
        Endif
        If STA="$"
            LSTA = [M:SGW]WSTADES(I+J)
        Else
            LSTA = STA
        Endif
        If LNBDET=0
            LSEQ = 100000+LSTOSEQ
            LLOC = [M]LOCDES(nolign-1)
        Else
            LSEQ = [M:SGW]WLOCSEQ(I+J)
            LLOC = [M:SGW]WLOCDES(I+J)
        Endif
        Call STKCTRTLO(LSEQ,TRSTYP,CODTRS,STOFCY,ITMREF,LUOM,LQTY,LSTA,OBL,LOCTYP,PRET,OPTPAR,"","") From STKLOC
    Next

    If LOCTYP<>[M]LOCTYPDES(nolign-1)
        For J=0 To max(LNBDET-1,0)
            If LNBDET=0
                LSEQ = 100000+LSTOSEQ
                LLOC = [M]LOCDES(nolign-1)
            Else
                LSEQ = [M:SGW]WLOCSEQ(I+J)
                LLOC = [M:SGW]WLOCDES(I+J)
            Endif
            Call STKDELRES(LSEQ,STOFCY,LLOC,LRET) From STKLOC
        Next
        Effzo [M]LOCDES(nolign-1)
    Endif
End



##################################################
Subprog SUGEMPENT(TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,LOCTYP,LOC,BPRNUM,OPTPAR,WRH)
Value    Integer TRSTYP
Value    Char    CODTRS
Value    Char    STOFCY
Value    Char    ITMREF
Value    Char    UOM
Value    Decimal QTY
Value    Char    STA
Variable Char    LOCTYP()
Variable Char    LOC()
Value    Char    BPRNUM
Value    Char    OPTPAR
Value    Char    WRH

Local Integer LSEQ
Local Integer LSTOSEQ
Local Integer LNBDET
Local Integer I

    If dim([M]WSTOSEQ)>1
        LSTOSEQ = [M]WSTOSEQ(nolign-1)
        If LSTOSEQ>0
            I = find(LSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1)) -1
            If I<0 : End : Endif
            LNBDET = func SUBSCSB.CALCNBDET(LSTOSEQ)
        Endif
        #------ On ne fait pas de suggestion à partir du moment où il y a plusieurs lignes de détail
        #------ car la suggestion crée les réservations
        If LNBDET>1
            End
        Endif
    
        If LNBDET=0
            LSEQ = 100000+LSTOSEQ
        Else # LNBDET=1
            LSEQ = [M:SGW]WLOCSEQ(I)
        Endif
    Else
        LSTOSEQ = [M]WSTOSEQ
        LSEQ = [M]WLOCSEQ(nolign-1)
    Endif

    If UOM<>"$" & UOM<>"" & STA<>"$" & STA<>"" & LOC="" & LOCTYP<>""

        Call STKSUGEMP(LSEQ,TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,LOCTYP,LOC,BPRNUM,OPTPAR,"",WRH) From STKLOC
    Else
        If LOCTYP=""
            mkstat = 2
        Endif
    Endif

End

##################################################
Subprog CTREMPENT(TRSTYP,CODTRS,STOFCY,ITMREF,UOM,QTY,STA,LOCORI,LOCTYP,LOC,BPRNUM,OBL,PRET,OVFQTY,OPTPAR)
Value    Integer TRSTYP
Value    Char    CODTRS
Value    Char    STOFCY
Value    Char    ITMREF
Value    Char    UOM
Value    Decimal QTY
Value    Char    STA
Value    Char    LOCORI
Variable Char    LOCTYP()
Variable Char    LOC()
Value    Char    BPRNUM
Value    Integer OBL
Variable Shortint PRET
Variable Decimal OVFQTY
Value    Char    OPTPAR

Local Decimal LSEQ
Local Integer LSTOSEQ
Local Integer LNBDET
Local Integer I
Local Char    LUOM(GLONUOM)
Local Decimal LQTY
Local Char    LSTA(GLONSTA)

If LOC<>""
   If dim([M]WSTOSEQ)>1
      LSTOSEQ = [M]WSTOSEQ(nolign-1)
      If LSTOSEQ>0
         I = find(LSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1)) -1
         If I>=0
            LNBDET = sigma(I,[M:SGW]NBLIG-1, [M:SGW]WSTOSEQ(indcum) = LSTOSEQ)
         Endif
      Endif
   Else
      LSTOSEQ = [M]WSTOSEQ
      If LSTOSEQ>0
         I = find(LSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1)) -1
         LNBDET = 1
      Endif
   Endif

   For J=0 To max(LNBDET-1,0)
      LQTY = QTY
      LSTA = STA
      LUOM = UOM
      If LNBDET=0
         LSEQ = 100000+LSTOSEQ
      Else
         LSEQ = [M:SGW]WLOCSEQ(I+J)
         If QTY=0
            LQTY = [M:SGW]WQTYPCUDES(I+J)
         Endif
         If STA="$"
            LSTA = [M:SGW]WSTADES(I+J)
         Endif
         If UOM="$"
            LUOM = [M:SGW]WPCUDES(I+J)
         Endif
      Endif
      If LOC = LOCORI
         Call STKVALEMP(LSEQ,TRSTYP,CODTRS,STOFCY,ITMREF,LUOM,
&                      [M:SCS1]STUDIS(nolign-1)/[M:SCS1]PCUSTUCOE(nolign-1),
&                      LQTY,LSTA,LOCTYP,LOC,BPRNUM,PRET,OVFQTY,OPTPAR,"") From STKLOC
      Else
         Call STKCTREMP(LSEQ,TRSTYP,CODTRS,STOFCY,ITMREF,LUOM,LQTY,LSTA,LOCTYP,
&                       LOC,BPRNUM,OBL,PRET,OVFQTY,OPTPAR,"","") From STKLOC
      Endif
   Next
Endif

End


