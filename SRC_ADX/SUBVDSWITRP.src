#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
#  Infbox ACTION
Case ACTION
  When "SETBOUT" : If CLECUR and SUPPR : CHAINE += "A" : Endif
  When "APRES_CHOI" : If REPONSE = GSTAANU : Gosub ANNULER : REPONSE = 0 : Endif

 When Default
Endcase
Return

$ANNULER
  # Check for an existing lock.
    If !VERROU
        Gosub VERROU From GOBJET
        If !VERROU
            # A lock exists: Display an error message and leave.
            Call ERREUR( mess(10,100,1) ) From GESECRAN # "Change In Progress on another workstation"
            Return
        Else
            AFFICHE = 1

            # Restore the grid.
            Gosub RELIT From GOBJSUB
        Endif
    Endif

    # Let's ask if the user really wishes to delete all rows.
    OK = 2 # Default is NO.
    If dim([V]GCONF) <= 0 or [V]GCONF(1) = 2
# 2017-11-22 DNE MODIF BEGIN
        Call OUINON( mess(123,105,1) - "(" + [M]VAT + ")", OK ) From GESECRAN # "Confirm delete?"
# 2017-11-22 DNE MODIF ORIG
#        Call OUINON( mess(123,105,1) - "(" + [M]LEG + "~" + [M]VAT + ")", OK ) From GESECRAN # "Confirm delete?"
# 2017-11-22 DNE MODIF END
    Endif

    # If NO cancel the deletion.
    If OK <> 2
        Return
    Endif

    # Otherwise delete.
    Call DEBTRANS From GLOCK
    Trbegin [TRSP]
# 2017-11-22 DNE MODIF BEGIN
    Delete [TRSP] Where VAT=[M]VAT
    If fstat = 1
      Call RSTA("TRSP",[M]VAT) From GLOCK
      Rollback
    Else
        Commit
    Endif
# 2017-11-22 DNE MODIF ORIG
#    Delete [TRSP] Where LEG=[M]LEG & VAT=[M]VAT
#    If fstat = 1
#      Call RSTA("TRSP",[M]LEG-[M]VAT) From GLOCK
#      Rollback
#    Else
#        Commit
#    Endif
# 2017-11-22 DNE MODIF END
    CLECUR = 0

    # Restore the grid.
    Gosub RELIT From GOBJSUB
Return

######################################################################################

######################################################################################
## Section automatically added (screen TRSP0) 10.02.2014 10:10:16 (ANGRE)
######################################################################################
Subprog AM_REPLIN(VALEUR)
Variable Integer VALEUR

 [M:TRSP0]DIGIT(nolign-1) =  val(mess(VALEUR,3640,1))

End

