#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la création d'une solution  Module CRM                  26 septembre 2000   #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer HDK4ISDIRTY
Global Integer GIHBDISP
Global Char GXSOLCPT(GLONANM)  # Code compteur pour solution
Global Char GXSOLNUM(GLONVCR)  # N° de solution
Global Char HDK4CONTEXT
Global Char HDK4SRENUM(GLONSRE)
Global Char HDK4ITNNUM(GLONITN)

  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  If !clalev([F:PBQ]) : Local File FAMPBQUE [PBQ] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:HD1]) : Local File HD1CLOB [HD1] : Endif
  If !clalev([F:HD2]) : Local File HD2CLOB [HD2] : Endif
  If !clalev([F:HD3]) : Local File HD3CLOB [HD3] : Endif
  If !clalev([F:SOL]) : Local File SOLUTION [SOL] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  #PARAM(1) = Code demande de service
  #PARAM(2) = Code intervention
  #PARAM(3) = Contexte appelant
  HDK4ISDIRTY = 0
  GIHBDISP = 0
  If PARAM(3) = "" Then
    #Aucun contexte n'a pu être obtenue. Action abandonnée.
    GMESSAGE = mess(304,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  HDK4SRENUM = PARAM(1)
  HDK4ITNNUM = PARAM(2)
  HDK4CONTEXT = PARAM(3)
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(3)
  #  GXSOLCPT = [F:TCA]CODNUM(3)
  Call READ_COUNTER("", 12, 3, GSOCIETE, GCURLEG, GXSOLCPT, GMANCOU) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #Traitement de la clôture
  Case HDK4CONTEXT
    When "SRE"
      Gosub OPENFSRE
    When "ITN"
      Gosub OPENFITN
    When "HDK"
      Gosub OPENFHDK
    When "RPO"
      Gosub OPENFRPO
    When Default
  Endcase
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If HDK4ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Char SZFULSOLDES(250)

  [M:SOL2]SOLDESUPDF = 0
  Raz SZFULSOLDES
  #Initialise la catégorie de la solution
  [M:SOL1]CAT = ""
  Case HDK4CONTEXT
    When "SRE"
      Gosub LOADFSRE
    When "ITN"
      Gosub LOADFITN
    When "HDK"
      Gosub LOADFHDK
    When "RPO"
      Gosub LOADFRPO
    When Default
  Endcase
  Affzo [M:SOL0]1-99
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
  Setlob SZFULSOLDES With [M:SOL2]SOLFULDES
  If SZFULSOLDES <> "" Then
    HDK4ISDIRTY = 1
  Endif
  GIHBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  If GIHBDISP Then
    Raz [M:SOL0]
    Raz [M:SOL1]
    Raz [M:SOL2]
    Raz [M:SOL3]
    Raz [M:SOL4]
  Endif
  #Réinitialise les variable de comptage du OUVRE
  Case HDK4CONTEXT
    When "SRE"
      GISRECOUNT = 0
    When "ITN"
      GIITNCOUNT = 0
    When "HDK"
      GIHDKCOUNT = 0
      #Dévérouillage de la demande
      Call UNLOCKSRE(HDK4SRENUM) From SUBITNB1
    When "RPO"
      GIRPOCOUNT = 0
    When Default
  Endcase
  #Rafraichit le plan de travail Help-Desk
  If HDK4CONTEXT = "HDKAGD" Then
    If GIHBDISP Then
      Gosub ONLOAD From TRTHDKAGD
    Endif
  Endif
  Kill HDK4ISDIRTY
  Kill HDK4CONTEXT
  Kill HDK4SRENUM
  Kill HDK4ITNNUM
  Kill GIHBDISP
  Kill GXSOLCPT
  Kill GXSOLNUM
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  HDK4ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSAVE
Local Integer IAREWECREATING
Local Integer ZI
Local Integer IH
Local Char SZTMPKWD
Local Char SZFULSOLDES(250)
Local Char SZMESSAGE(250)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IWRITE

  Raz SZFULSOLDES
  IAREWECREATING = 0
  Raz SZMESSAGE
  IBRETOUR = 1
  IWRITE = 0
  #Contrôle de la présence d'un texte dans la solution
  Setlob SZFULSOLDES With [M:SOL2]SOLFULDES
  If SZFULSOLDES = "" Then
    #Aucune description de solution n'a été renseigné. Création refusée.
    GMESSAGE = mess(837,182,1)
    GERR = 2
    Return
  Endif
  #Extraction des mots-clés.
  If [M:SOL2]SOLDESUPDF = 0 Then
    # FGR 12/03/2008 X3SUIVI46197 : Manquait le paramètre !
    #Call AM_SOLFULDES From SUBSOL
    Call AM_SOLFULDES([M]SOLFULDES) From SUBSOL
  Endif
  #Enregistrement de la solution saisie
  Call DEBTRANS From GLOCK
  Trbegin [SOL], [HD3]
  # Récupération du compteur de solution
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", "", GXSOLCPT, date$, "", [M:SOL0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      IAREWECREATING = 1
      Affzo [M:SOL0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      Rollback
      Return
    Endif
  Endif
  Readlock [SOL]SOL0=[M:SOL0]NUM
  If fstat = 5 Then
    #Enregistrement non trouvé, il faut le créer
    IWRITE = fstat
  Elsif fstat = 0 Then
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    IWRITE = fstat
  Else
    IWRITE = -1
  Endif
  If IWRITE <> -1 Then
    #Enregistrement non trouvé, il faut le créer
    [F:SOL]NUM = [M:SOL0]NUM
    [F:SOL]SRENUM = HDK4SRENUM
    [F:SOL]CAT = [M:SOL1]CAT
    [F:SOL]PBLGRP = [M:SOL1]PBLGRP
    [F:SOL]TTR = [M:SOL1]TTR
    [F:SOL]PBLDES = [M:SOL1]PBLDES
    [F:SOL]TYPPBLDES = "PBL"
    [F:SOL]NUMPBLDES = [M:SOL0]NUM
    [F:SOL]PBLDESFLG = [M:SOL1]PBLDESFLG
    [F:SOL]SOLDES = [M:SOL2]SOLDES
    [F:SOL]TYPSOLDES = "SOL"
    [F:SOL]NUMSOLDES = [M:SOL0]NUM
    [F:SOL]SOLDESFLG = [M:SOL2]SOLDESFLG
    For ZI = 0 To dim([M:SOL3]KEYWRD)-1
      [F:SOL]KEYWRD(ZI) = [M:SOL3]KEYWRD(ZI)
    Next
    For ZI = 0 To dim([M:SOL4]CODSOL)-1
      [F:SOL]CODSOL(ZI) = [M:SOL4]CODSOL(ZI)
    Next
    #
    If IWRITE = 5 Then
      #Enregistrement non trouvé, il faut le créer
      [F:SOL]CREUSR = GUSER
      [F:SOL]CREDAT = date$
      [F:SOL]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
      Write [SOL]
      If fstat Then
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
        Return
      Endif
    Elsif fstat = 0 Then
      #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
      [F:SOL]UPDUSR = GUSER
      [F:SOL]UPDDAT = date$
      [F:SOL]UPDHOU = left$(time$, 2) + mid$(time$, 4, 2)
      Rewrite [SOL]
      If fstat Then
        GMESSAGE = mess(101,141,1) #Erreur modification
        GERR = 1
        Rollback
        Return
      Endif
    Endif
    Gosub ADDFULPBLDES
    If GERR Then
      Return
    Else
      Gosub ADDFULSOLDES
      If GERR Then
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  #Renseigne la demande de service avec le code de la solution.
  Case HDK4CONTEXT
    When "SRE"
      Gosub USREFSRE
    When "ITN"
      Gosub UPD_SRE_SOL
    When "HDK"
      Gosub UPD_SRE_SOL
    When "RPO"
      Gosub UPD_SRE_SOL
    When Default
  Endcase
  If IAREWECREATING = 1 Then
    [M:SOL1]CREHOU = [F:SOL]CREHOU
    Affzo [M:SOL1]CREHOU
    IAREWECREATING = 0
  Endif
  HDK4ISDIRTY = 0
  ETABOU(GSPE1) = 0
  FIN = 1
Return

##########################################################################################################
$ADDFULPBLDES
  Delete [HD3] Where [F:HD3]NUM = [M:SOL0]NUM and [F:HD3]TYP = "PBL"
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète de la demande d'origine. Transaction abandonnée.
    GMESSAGE = mess(842,182,1)
    GERR = 1
    Rollback
    Return
  Endif
  Raz [F:HD3]
  [F:HD3]NUM = [M:SOL0]NUM
  [F:HD3]TYP = "PBL"
  [F:HD3]CLOB = [M:SOL1]PBLFULDES
  Write [HD3]
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète de la demande d'origine. Transaction abandonnée.
    GMESSAGE = mess(842,182,1)
    GERR = 1
    Rollback
    Return
  Endif
Return

##########################################################################################################
$ADDFULSOLDES
  Delete [HD3] Where [F:HD3]NUM = [M:SOL0]NUM and [F:HD3]TYP = "SOL"
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète de la solution. Transaction abandonnée.
    GMESSAGE = mess(844,182,1)
    GERR = 1
    Rollback
    Return
  Endif
  Raz [F:HD3]
  [F:HD3]NUM = [M:SOL0]NUM
  [F:HD3]TYP = "SOL"
  [F:HD3]CLOB = [M:SOL2]SOLFULDES
  Write [HD3]
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète de la solution. Transaction abandonnée.
    GMESSAGE = mess(844,182,1)
    GERR = 1
    Rollback
    Return
  Endif
Return

##########################################################################################################
# Exécute les tests d'ouverture lors d'un appel depuis une demande de service.
###################################################################################
$OPENFSRE
  If GISRECOUNT Then
    GISRECOUNT = 0
  Else
    GISRECOUNT += 1

    Local Integer ITERHDT
    Local Integer IDONEFLG
    Local Integer IREP
    Local Integer ILESS
    Local Integer IFIRSTSTEP
    Local Char SZSKILLEDREP
    Local Char SZQUEUE
    Local Char SZHDKREP
    Local Integer IHDKREP
    Local Char SZSREPBL

    SZHDKREP = ""
    IHDKREP = 0
    SZSKILLEDREP = ""
    SZQUEUE = ""
    ILESS = 0
    IFIRSTSTEP = 0
    IREP = 0
    ITERHDT = 0
    IDONEFLG = 0
    SZSREPBL = ""
    #Traitements liés à la nouvelle valeur du champs
    If VALEUR = 1 Then
      #Dispatching
      Actzo SREDET
      If [M:SRE0]SALFCY <> "" Then
        [M:SRE2]SREDET = [M:SRE0]SALFCY
        Read [FCY]FCY0=[M:SRE0]SALFCY
        If fstat Then
          [M:SRE2]SREDETCLA = [M:SRE0]SALFCY
        Else
          [M:SRE2]SREDETCLA = [F:FCY]FCYNAM
        Endif
      Endif
      FIN = 1
    Elsif VALEUR = 2 Then
      #Collaborateur
      Actzo [M:SRE2]SREDET
      SZSREPBL = ""
      If [M:SRE7]SREPBLGRP = "" Then
        If [M:SRE0]SREMACPBL <> "" Then
          SZSREPBL = [M:SRE0]SREMACPBL
        Endif
      Else
        SZSREPBL = [M:SRE7]SREPBLGRP
      Endif
      Call GETDEFREP(SZSREPBL, SZSKILLEDREP)
      If SZSKILLEDREP = "" Then
        Call PARAMUTIL("AUSHDKA", SZHDKREP, GUSER, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP = 2 Then
          SZSKILLEDREP = GUSER
        Endif
      Endif
      #Affectation du nouveau collaborateur par défaut
      If SZSKILLEDREP = "" Then
        [M:SRE2]SREDET = ""
        [M:SRE2]SREDETCLA = ""
      Else
        [M:SRE2]SREDET = SZSKILLEDREP
        Read [AUS]CODUSR=SZSKILLEDREP
        If fstat Then
          [M:SRE2]SREDETCLA = SZSKILLEDREP
        Else
          [M:SRE2]SREDETCLA = [F:AUS]NOMUSR
        Endif
      Endif
      FIN = 1
    Elsif VALEUR = 3 Then
      #Queue
      Actzo SREDET
      Filter [PBQ] Where [F:PBQ]GRPPBLNUM = [M:SRE7]SREPBLGRP and [F:PBQ]STTFLG = 0
      For [PBQ]
        If !IFIRSTSTEP Then
          ILESS = [F:PBQ]SRECOU
          SZQUEUE = [F:PBQ]QUENUM
        Else
          If [F:PBQ]SRECOU < ILESS Then
            ILESS = [F:PBQ]SRECOU
            SZQUEUE = [F:PBQ]QUENUM
          Endif
        Endif
        IFIRSTSTEP += 1
      Next
      Filter [PBQ]
      #Affectation de la nouvelle queue par défaut
      If IFIRSTSTEP = 0 Then
        [M:SRE2]SREDET = ""
        [M:SRE2]SREDETCLA = ""
      Else
        [M:SRE2]SREDET = SZQUEUE
        Read [QUE]QUE0=SZQUEUE
        If fstat Then
          [M:SRE2]SREDETCLA = SZQUEUE
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #[M:SRE2]SREDETCLA = [F:QUE]TTR
          Call LECTEXTRA([M:SRE2]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        Endif
      Endif
      FIN = 1
    Elsif VALEUR = 4 Then
      #Service commercial
      Grizo [M:SRE2]SREDET
      [M:SRE2]SREDET = ""
      [M:SRE2]SREDETCLA = ""
      FIN = 1
    Elsif VALEUR = 5 Then
      #Clôture
      IREP = 0
      Call OUINON(mess(285,196,1), IREP) From GESECRAN #Etes-vous sur de vouloir clôturer la demande ?
      If IREP = 2 Then
        #Mémorise le nom du technicien qui a traité la demande.
        If [M:SRE2]SREASS = 2 Then
          [M:SRE2]REP = [M:SRE2]SREDET
          [M:SRE2]SREDET = ""
          Read [AUS] CODUSR = [M:SRE2]REP
          If !fstat Then
            [M:SRE2]SREDETCLA = mess(351,196,1) - [F:AUS]NOMUSR
          Endif
        Else
          If [M:SRE2]REP <> "" Then
            [M:SRE2]REP = ""
          Endif
          [M:SRE2]SREDET = ""
          [M:SRE2]SREDETCLA = ""
        Endif
        Grizo [M:SRE2]SREDET
        #Défini le nouvel état de la demande
        If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
        Filter [ADI] Where [F:ADI]NUMTAB = 422
        For [ADI]
          If [F:ADI]N1 = 2 Then
            [M:SRE2]SRESAT = [F:ADI]CODE
            Break
          Endif
        Next
        Filter [ADI]
        #Détecte s'il y a des consommations non effectuées.
        IDONEFLG = 0
        Call SETDONDATFLG(HDK4SRENUM, IDONEFLG) From SUBSREB2
        [M:SRE9]DONDATFLG = IDONEFLG
        #Neutralise la saisie dans le tableau des consommations
        Grizo [M:SRE9]5
      Else
        VALEUR = [M:SRE2]SREASS
        FIN = 1
      Endif
    Endif
    #Met à jour la date de dernière affectation
    [M:SRE2]SREDATASS = date$
    [M:SRE2]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
    [M:SRE2]SREASS = VALEUR
    Affzo [M:SRE2]1-99
    Affzo [M:SRE9]1-99
  Endif
Return

##########################################################################################################
# Exécute les tests d'ouverture lors d'un appel depuis une intervention.
###################################################################################
$OPENFITN
  If GIITNCOUNT Then
    GIITNCOUNT = 0
  Else
    GIITNCOUNT += 1

    Local Integer IDONEFLG
    Local Integer IREP
    Local Integer IERRINF   # FGR 19/08/2009 : X3SUIVI57247
    Local Integer ICHAPTER  # FGR 19/08/2009 : X3SUIVI57247
    Local Integer IBRETOUR  # FGR 19/08/2009 : X3SUIVI57247

    IDONEFLG = 0
    IREP = 0
    #Si le problème est résolu, l'intervention est forcément effectuée.
    If VALEUR = 2 Then
      If [M:ITN0]DON <> 2 Then
        [M:ITN0]DON = 2
        Affzo [M:ITN0]DON
      Endif
    Else
      #Si le problème n'est pas résolu on ne fait rien
      FIN = 1
      Return
    Endif
    #Si aucune demande de service n'est associée à l'intervention. On ne fait rien.
    If HDK4SRENUM = "" Then
      FIN = 1
      Return
    Endif
    #Si la demande de service associée est déjà clôturée. On ne fait rien.
    If HDK4SRENUM <> "" Then
      Read [SRE]SRE0=HDK4SRENUM
      If fstat Then
        GMESSAGE = mess(309,196,1) #Erreur lors de la clôture de la demande de service. Transaction abandonnée.
        GERR = 1
        FIN = 1
        Return
      Endif
      If [F:SRE]SREASS = 5 Then
        FIN = 1
        Return
      Endif
    Endif
    [M:ITN4]WISCLOFLG = 0
    [M:ITN4]WISSATFLG = 0
    If GAUSHDKG = 2 Then
      IREP = 0
      Call OUINON(mess(308,196,1), IREP) From GESECRAN #Voulez-vous clôturer la demande de service associée.
      If IREP = 2 Then
        [M:ITN4]WISCLOFLG = 1
      Else
        [M:ITN4]WISCLOFLG = 1
        [M:ITN4]WISSATFLG = 1
        FIN = 1
        Return
      Endif
    Else
      [M:ITN4]WISCLOFLG = 1
      [M:ITN4]WISSATFLG = 1
      FIN = 1
      Return
    Endif
    #Détecte s'il y a des consommations non effectuées pour la demande de service
    IDONEFLG = 0
    Call SETDONALLFLG(HDK4SRENUM, HDK4ITNNUM, "M", IDONEFLG) From SUBITNB2
    [M:ITN8]DONDATFLG = IDONEFLG
    If ![M:ITN8]DONDATFLG Then
      #Détecte s'il y a des consommations non effectuées pour l'intervention
      Call SETDONITNFLG (IERRINF, ICHAPTER, IBRETOUR) From SUBITNB2
      If IBRETOUR = 0 Then
        # FGR 19/08/2009 : X3SUIVI57247 : cas très improbable puisque les paramètre jamais utilisés dans le S/P...
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
        FIN = 1
        Return
      Endif
    Endif
    #Création d'une fiche solution
    IREP = 0
    Call OUINON(mess(310,196,1), IREP) From GESECRAN #Voulez-vous créer une fiche solution ?
    If IREP <> 2 Then
      FIN = 1
    Endif
    Affzo [M:ITN8]1-99
    Affzo [M:ITN4]1-99
  Endif
Return

##########################################################################################################
# Exécute les tests d'ouverture lors d'un appel depuis le plan de travail Help-Desk.
###################################################################################
$OPENFHDK
  If GIHDKCOUNT Then
    GIHDKCOUNT = 0
  Else
    GIHDKCOUNT += 1

    Local Integer IREP
    Local Integer IERR
    Local Integer IDONEFLG
    Local Integer IINVFLG
    Local Integer ILESS
    Local Integer IFIRSTSTEP
    Local Char SZSKILLEDREP
    Local Char SZQUEUE
    Local Char SZCLO
    Local Integer ISTOOK
    Local Char SZPBLSRE
    Local Integer ISSRELOCKED
    Local Integer IERRINF
    Local Integer ICHAPTER
    Local Integer IBRETOUR

    SZPBLSRE = ""
    SZCLO = ""
    SZSKILLEDREP = ""
    SZQUEUE = ""
    ILESS = 0
    IFIRSTSTEP = 0
    IREP = 0
    IERR = 0
    IINVFLG = 0
    ISTOOK = 1
    ISSRELOCKED = 0
    IERRINF = 0
    ICHAPTER = 0
    IBRETOUR = 1
    #Vérification du lock superviseur posé sur la demande de service
    Call ISAOB2LOCKED(HDK4SRENUM, "SRE", ISSRELOCKED) From CRMUTIL140
    If ISSRELOCKED Then
      #Modification en cours sur un autre poste.
      GMESSAGE = mess(10,100,1)
      GERR = 2
      FIN = 1
      Return
    Endif
    #Vérification du lock croisé avec les interventions
    Call LOCKSRE(HDK4SRENUM, ISSRELOCKED) From SUBITNB1
    If !ISSRELOCKED Then
      #Modification impossible. Intervention en cours de saisie sur un autre poste.
      GMESSAGE = mess(592,182,1)
      GERR = 2
      FIN = 1
      Return
    Endif
    #Contrôle que toutes les sorties de stock prévuées ont été réalisées.
    Filter [HDT] Where [F:HDT]SRENUM = HDK4SRENUM and [F:HDT]TPL <> 2
    For [HDT] HDT1
      If [F:HDT]HDTTYP = 2 Then
        If [F:HDT]HDTSTOISS = 2 Then
          If [F:HDT]HDTDONDAT = [00/00/00] Then
            ISTOOK = 0
            Break
          Else
            If [F:HDT]HDTISSISS < [F:HDT]HDTISSQTY Then
              ISTOOK = 0
              Break
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [HDT]
    If !ISTOOK Then
      #Des sorties de stock n'ont pas été enregistrées sur cette demande. La clôture n'est pas autorisée.
      GMESSAGE = mess(529,182,1)
      GERR = 2
      FIN = 1
      Return
    Endif
    Call OUINON(mess(285,196,1), IREP) From GESECRAN #Etes-vous sur de vouloir clôturer la demande.
    If IREP <> 2 Then
      FIN = 1
      Return
    Endif
    #Détecte s'il y a des consommations non effectuées.
    IDONEFLG = 0
    Call SETDONDATFLG(HDK4SRENUM, IDONEFLG) From SUBSREB2
    Read [SRE]SRE0=HDK4SRENUM
    If fstat Then
      GMESSAGE = mess(309,196,1) #Erreur lors de la clôture de la demande de service. Transaction abandonnée.
      GERR = 1
      FIN = 1
      Return
    Endif
    #Désaffectation du collaborateur ou de la queue précédente.
    If [F:SRE]SREPBLGRP = "" Then
      If [F:SRE]SREMACPBL <> "" Then
        SZPBLSRE = [F:SRE]SREMACPBL
      Endif
    Else
      SZPBLSRE = [F:SRE]SREPBLGRP
    Endif
    Call MNGPBLSTAT([F:SRE]SRENUM, SZPBLSRE, SZPBLSRE, [F:SRE]SREASS, 5, [F:SRE]SREDET, "", IERRINF,ICHAPTER,IBRETOUR)
    If IBRETOUR=0 Then
      #Erreur lors de la mise à jour des statistiques sur compétences.
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      FIN = 1
      Return
    Endif
    #Détermine le status de facturation de la demande.
    Call GETINVFLG(HDK4SRENUM, IINVFLG) From SUBSREB2
    #Clôture relative à la facturation
    Call CLOSRE(HDK4SRENUM, "", [F:SRE]SREBPC, 5, [F:SRE]SREASS, IINVFLG, IDONEFLG,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB2
    If IBRETOUR = 0 Then
      GOK = 0
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
    Endif
    #Clôture de la demande de service.
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    #Mémorise le nom du technicien qui a traité la demande.
    If [F:SRE]SREASS = 2 Then
      [F:SRE]REP = [F:SRE]SREDET
    Else
      If [F:SRE]REP <> "" Then
        [F:SRE]REP = ""
      Endif
    Endif
    If GCLOINV = 2 Then
      [F:SRE]SREINVFLG = IINVFLG
    Else
      [F:SRE]SREINVFLG = 1
    Endif
    [F:SRE]SREASS = 5
    [F:SRE]SREDATASS = date$
    [F:SRE]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
    [F:SRE]SREDET = ""
    If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [F:ADI]NUMTAB = 422
    For [ADI]
      If [F:ADI]N1 = 2 Then
        [F:SRE]SRESAT = [F:ADI]CODE
        Break
      Endif
    Next
    Filter [ADI]
    Rewrite [SRE]
    If fstat Then
      #Erreur lors de l'enregistrement de la clôture de la demande de service.
      GMESSAGE = mess(319,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Commit
    Endif
    #Ajoute un historique d'état de la demande
    Call CREHISTO([F:SRE]SRENUM, [F:SRE]SRESAT, [F:SRE]REP, 5,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
    Endif
  Endif
Return

##########################################################################################################
# Exécute les tests d'ouverture lors d'un appel depuis un compte-rendu d'intervention.
###################################################################################
$OPENFRPO
  If GIRPOCOUNT Then
    GIRPOCOUNT = 0
  Else
    GIRPOCOUNT += 1

    Local Integer ISPGTIMHOU
    Local Integer ISPGTIMMNT
    Local Integer IDONEFLG
    Local Integer IREP

    IDONEFLG = 0
    IREP = 0
    ISPGTIMHOU = 0
    ISPGTIMMNT = 0
    #Si le problème n'est pas résolu on ne fait rien
    If VALEUR <> 2 Then
      FIN = 1
      Return
    Endif
    #Si aucune demande de service n'est associée à l'intervention. On ne fait rien.
    If HDK4SRENUM = "" Then
      FIN = 1
      Return
    Endif
    #Si la demande de service associée est déjà clôturée. On ne fait rien.
    Read [SRE]SRE0=HDK4SRENUM
    If fstat Then
      FIN = 1
      Return
    Endif
    If [F:SRE]SREASS = 5 Then
      FIN = 1
      Return
    Endif
    [M:HDK4]WISCLOFLG = 0
    [M:HDK4]WISSATFLG = 0
    If GAUSHDKG = 2 Then
      IREP = 0
      Call OUINON(mess(308,196,1), IREP) From GESECRAN #Voulez-vous clôturer la demande de service associée.
      If IREP = 2 Then
        [M:HDK4]WISCLOFLG = 1
      Else
        [M:HDK4]WISCLOFLG = 1
        [M:HDK4]WISSATFLG = 1
        FIN = 1
        Return
      Endif
    Else
      [M:HDK4]WISCLOFLG = 1
      [M:HDK4]WISSATFLG = 1
      FIN = 1
      Return
    Endif
    #Détecte s'il y a des consommations non effectuées pour la demande de service
    IDONEFLG = 0
    Call SETDONALLFLG(HDK4SRENUM, HDK4ITNNUM, "F", IDONEFLG) From SUBITNB2
    [M:HDK4]DONDATFLG = IDONEFLG
    #Affichage du nouveau temps réellement passé.
    If IDONEFLG Then
      #Il faut d'abord calculer pour du beurre la nouvelle durée réellement consacrée automatiquement.
      Call GETHDK4SPG(HDK4ITNNUM, [F:SRE]SREBPC, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
      [M:HDK4]HTOTTIMSPG = ISPGTIMHOU
      [M:HDK4]MTOTTIMSPG = ISPGTIMMNT
      [M:HDK4]MANTIMFLG = 0
    Endif
    #Création d'une fiche solution
    IREP = 0
    Call OUINON(mess(310,196,1), IREP) From GESECRAN #Voulez-vous créer une fiche solution ?
    If IREP <> 2 Then
      FIN = 1
    Endif
    Affzo [M:HDK4]1-99
  Endif
Return

##########################################################################################################
# Ouvre la fenêtre lors d'un appel depuis une demande de service
###################################################################################
$LOADFSRE
  #Initialise les infos déduites de la demande de service.
  [M:SOL1]PBLGRP = [M:SRE7]SREPBLGRP
  [M:SOL1]TTR = [M:SRE1]SRETTR
  [M:SOL1]PBLDES = [M:SRE1]SREDES
  [M:SOL1]PBLDESFLG = [M:SRE1]SREDESFLG
  [M:SOL1]PBLFULDES = [M:SRE1]SREFULDES
  [M:SOL2]SOLDES = ""
  [M:SOL2]SOLDESFLG = 0
  Raz [M:SOL2]SOLFULDES
  HDK4SRENUM = [M:SRE0]SRENUM
  Gosub LOADF_COMMUN
Return

##########################################################################################################
# Ouvre la fenêtre lors d'un appel depuis une intervention
###################################################################################
$LOADFITN
  [M:SOL1]PBLGRP = [F:SRE]SREPBLGRP
  [M:SOL1]TTR = [F:SRE]SRETTR
  [M:SOL1]PBLDES = [F:SRE]SREDES
  [M:SOL1]PBLDESFLG = [F:SRE]SREDESFLG
  Read [HD1]HD10=HDK4SRENUM;"SRE"
  If fstat Then
    Raz [M:SOL1]PBLFULDES
  Else
    [M:SOL1]PBLFULDES = [F:HD1]CLOB
  Endif
  [M:SOL2]SOLDES = [M:ITN4]RPO
  [M:SOL2]SOLDESFLG = [M:ITN4]RPOFLG
  [M:SOL2]SOLFULDES = [M:ITN4]FULRPO
  HDK4SRENUM = [M:ITN0]SRVDEMNUM
  Gosub LOADF_COMMUN
Return

##########################################################################################################
# Ouvre la fenêtre lors d'un appel depuis le plan de travail Help-Desk.
###################################################################################
$LOADFHDK
  [M:SOL1]PBLGRP = [F:SRE]SREPBLGRP
  [M:SOL1]TTR = [F:SRE]SRETTR
  [M:SOL1]PBLDES = [F:SRE]SREDES
  [M:SOL1]PBLDESFLG = [F:SRE]SREDESFLG
  Read [HD1]HD10=HDK4SRENUM;"SRE"
  If fstat Then
    Raz [M:SOL1]PBLFULDES
  Else
    [M:SOL1]PBLFULDES = [F:HD1]CLOB
  Endif
  [M:SOL2]SOLDES = ""
  [M:SOL2]SOLDESFLG = 0
  Raz [M:SOL2]SOLFULDES
  HDK4SRENUM = [F:SRE]SRENUM
  Gosub LOADF_COMMUN
Return

##########################################################################################################
# Ouvre la fenêtre lors d'un appel depuis un compte-rendu d'intervention
###################################################################################
$LOADFRPO
  [M:SOL1]PBLGRP = [F:SRE]SREPBLGRP
  [M:SOL1]TTR = [F:SRE]SRETTR
  [M:SOL1]PBLDES = [F:SRE]SREDES
  [M:SOL1]PBLDESFLG = [F:SRE]SREDESFLG
  Read [HD1]HD10=HDK4SRENUM;"SRE"
  If fstat Then
    Raz [M:SOL1]PBLFULDES
  Else
    [M:SOL1]PBLFULDES = [F:HD1]CLOB
  Endif
  [M:SOL2]SOLDES = [M:HDK4]RPO
  [M:SOL2]SOLDESFLG = [M:HDK4]RPOFLG
  [M:SOL2]SOLFULDES = [M:HDK4]FULRPO
  HDK4SRENUM = [F:SRE]SRENUM
  Gosub LOADF_COMMUN
Return

##########################################################################################################
# partie commune à LOADFSRE, LOADFITN, LOADFHDK, LOADFRPO
###################################################################################
$LOADF_COMMUN
  [M:SOL1]CREDAT = date$
  [M:SOL1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:SOL1]FULNAMUSR = GUSER
  Else
    [M:SOL1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  [M:SOL0]SRENUM = HDK4SRENUM
  [M:SOL0]CXTSYNSRE = "FSOLSRE"
  [M:SOL0]CXTSYNSOL = "FSOL"
  Gosub DISPICON From SUBSOLB
Return

##########################################################################################################
# Renseigne la demande de service avec le code de la solution lors d'un appel depuis une demande de service
###################################################################################
$USREFSRE
  [M:SRE0]SOLNUM = [M:SOL0]NUM
Return

##########################################################################################################
# Renseigne la demande de service avec le code de la solution lors d'un appel depuis une intervention
# Renseigne la demande de service avec le code de la solution lors d'un appel depuis le plan de travail Help-Desk.
# Renseigne la demande de service avec le code de la solution lors d'un appel depuis un compte-rendu d'intervention
###################################################################################
$UPD_SRE_SOL
  If HDK4SRENUM <> "" Then
    Read [SRE]SRE0=HDK4SRENUM
    If fstat Then
      FIN = 1
      Return
    Endif
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    [F:SRE]SOLNUM = [M:SOL0]NUM
    Rewrite [SRE]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
      Return
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Alimente la table HDI des lignes de consommations facturables avec contrôle de l'agrégation.
################################################################################################
Subprog FEEDHDI(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG
Local Decimal IARRHDTQTY
Local Decimal IARRAMTINV
Local Decimal ISUMSTUQTY
Local Decimal ISUMAMTINV
Local Decimal ICONVCOEF
Local Decimal ISUMQTY
Local Decimal IHDTQTY
Local Char SZPREITM(250)
Local Char SZCURITM(250)
Local Char SZPREUOM
Local Char SZPRECTL(250)
Local Char SZCURCTL(250)
Local Integer IORD
Local Integer INOTEXFLG
Local Char SZITMSAU
Local Char SVHDTNUM(GLONVCR)  # FGR 03/11/2010 : X3SUIVI68364
Local Char SSIVNULL(GLONDES)  # FGR 22/11/2013 : X3SUIVI92040
Local Integer ISIVNULL        # FGR 22/11/2013 : X3SUIVI92040

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Si la facturation des demandes n'est pas activée. On ne fait rien.
  If GCLOINV <> 2 Then
    End
  Endif
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:HDI]) : Local File HDKTASKINV [HDI] : Endif
  If !clalev([F:HDT]) : Local File HDKTASK [HDT] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
  If !clalev([F:CALT]) : Local File CPTANALIN [CALT] : Endif
  If !clalev([F:CALK]) : Local File CPTANALIN [CALK] : Endif  : # pour le LINK
  If SZSRENUM = "" Then
    #Erreur lors de la génération d'une ligne de facture.
    IERRINF = 313
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #Erreur lors de la génération d'une ligne de facture.
    IERRINF = 313
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (début) Ligne à 0 interdites ou autorisées
  Call PARAML([F:SRE]SALFCY, "SIVNULL", SSIVNULL) From ADOVAL
  ISIVNULL = val(SSIVNULL)
  If ISIVNULL <> G_YES and ISIVNULL <> G_NO Then
    ISIVNULL = G_NO
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (fin)
  IORD = 0
  SZPREITM = ""
  SZCURITM = ""
  SZPREUOM = ""
  SZPRECTL = ""
  SZCURCTL = ""
  ISUMQTY = 0
  ICONVCOEF = 0
  INOTEXFLG = 0
  SZITMSAU = ""
  IHDTQTY = 0
  ISUMSTUQTY = 0
  ISUMAMTINV = 0
  IARRAMTINV = 0
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDI]
  Endif
  Call DELHDI(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  If GINVSREMOD = 2 Then
    #Facturation sans agrégation
    If GINVSREUOM = 2 Then
      # Facturation en unité de vente
      Gosub FNOHDIVENUOM
    Else
      # Facturation en unité de consommation
      Gosub FNOHDIHDTUOM
    Endif
  Else
    #Facturation avec agrégation
    If GINVSREUOM = 2 Then
      # Facturation en unité de vente
      Gosub FHDIVENUOM
    Else
      # Facturation en unité de consommation
      Gosub FHDIHDTUOM
    Endif
  Endif
  #Point d'entrée pour ajouter ou retoucher les lignes de facture.
  Gosub PE_FEEDHDI From TRTCRMPE
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Corps facturation (partie sans agrégation)
###################################################
$CORP_FACT_SS_AGREG
  Read [CALT]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
  If fstat Then
    #Erreur lors de la lecture des axes analytiques associés aux consommations.
    IERRINF = 433
    ICHAPTER = 177
    IBRETOUR = 0
    GOK = 0
    Return
  Endif
  Raz [F:HDI]
  [F:HDI] = [F:HDT]
  [F:HDI]HDTORD = IORD
  If GINVSREUOM = 2 Then
    # Facturation en unité de vente
    Read [ITM]ITM0=[F:HDT]HDTITM
    If fstat Then
      #Erreur lors de la génération d'une ligne de facture.
      IERRINF = 313
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Return
    Endif
    If [F:ITM]SAU <> [F:HDT]HDTUOM Then
      Call SREC_COE([F:HDT]HDTITM, [F:SRE]SREBPC, [F:ITM]SAU, [F:HDT]HDTUOM, ICONVCOEF) From TRTVENQTE
      [F:HDI]HDTUOM = [F:ITM]SAU
      [F:HDI]HDTQTY = [F:HDT]HDTQTY * ICONVCOEF
    Endif
  Endif
  #On arrondi la quantité facturable
  IARRHDTQTY = [F:HDI]HDTQTY
  Call QTEARR(IARRHDTQTY, [F:HDI]HDTUOM) From TRTDIV
  [F:HDI]HDTQTY = IARRHDTQTY
  If GINVSREUOM = 2 Then
    [F:HDI]HDTAMTINV = [F:HDT]HDTAMTINV / [F:HDI]HDTQTY
  Else
    [F:HDI]HDTAMTINV = [F:HDT]HDTAMTINV / [F:HDT]HDTQTY
  Endif
  #On arrondi le montant facturable
  IARRAMTINV = [F:HDI]HDTAMTINV
  [F:HDI]HDTAMTINV = arr(IARRAMTINV,10^-GDECPRI)
  Write [HDI]
  If fstat Then
    #Erreur lors de la génération d'une ligne de facture.
    IERRINF = 313
    ICHAPTER = 182
    IBRETOUR = 0
    Call FSTA("HDI") From GLOCK
    GOK = 0
    Return
  Endif
  [F:CAL] = [F:CALT]
  [F:CAL]ABRFIC = "HDI"
  [F:CAL]VCRNUM = [F:HDI]SRENUM
  [F:CAL]VCRLIN = [F:HDI]HDTORD
  [F:CAL]VCRSEQ = 0
  [F:CAL]CPLCLE = ""
  [F:CAL]ANALIG = 1
  Write [CAL]
  If fstat Then
    #Erreur lors de la génération des axes analytiques d'une ligne de facture.
    IERRINF = 432
    ICHAPTER = 177
    IBRETOUR = 0
    Call FSTA("CAL") From GLOCK
    GOK = 0
    Return
  Endif
  IORD += 1
Return

##########################################################################################################
# Facturation en unité de vente sans agrégation
###################################################
$FNOHDIVENUOM
  #Première boucle sans agrégation
  # FGR 22/11/2013 : X3SUIVI92040 (début)
  #Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0
  If ISIVNULL = G_YES Then
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0
  Else
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00]
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (fin)
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
Return

##########################################################################################################
# Facturation en unité de consommation sans agrégation
###################################################
$FNOHDIHDTUOM
  #Première boucle sans agrégation
  # FGR 22/11/2013 : X3SUIVI92040 (début)
  #Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0
  If ISIVNULL = G_YES Then
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0
  Else
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00]
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (fin)
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
Return

##########################################################################################################
# Facturation en unité de vente avec agrégation
###################################################
#CHECK IGNORE_BEGIN
$OLDFHDIVENUOM
  #Première boucle sans agrégation
  # FGR 22/11/2013 : X3SUIVI92040 (début)
  #Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  If ISIVNULL = G_YES Then
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  Else
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTTEX <> ""
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (fin)
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  #Deuxième boucle avec agrégation
  Gosub SETVENUOMFLT
  For [HDTK]
    Read [CALT]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
    If fstat Then
      #Erreur lors de la lecture des axes analytiques associés aux consommations.
      IERRINF = 433
      ICHAPTER = 177
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
    If SZPREITM <> "" Then
      Gosub SETCURITM
      If SZPREITM <> SZCURITM Then
        Gosub CORP_FACT_AV_AGREG
        If IBRETOUR = 0 Then
          Break
        Endif
      Endif
    Endif
    Read [ITM]ITM0=[F:HDT]HDTITM
    If fstat Then
      #Erreur lors de la génération d'une ligne de facture.
      IERRINF = 313
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
    If [F:ITM]SAU = [F:HDT]HDTUOM Then
      SZITMSAU = [F:HDT]HDTUOM
      ISUMQTY += [F:HDT]HDTQTY
    Else
      Call SREC_COE([F:HDT]HDTITM, [F:SRE]SREBPC, [F:ITM]SAU, [F:HDT]HDTUOM, ICONVCOEF) From TRTVENQTE
      SZITMSAU = [F:ITM]SAU
      IHDTQTY = [F:HDT]HDTQTY * ICONVCOEF
      ISUMQTY += IHDTQTY
    Endif
    ISUMSTUQTY += [F:HDT]HDTSTUQTY
    ISUMAMTINV += [F:HDT]HDTAMTINV
    Gosub SETPREITM
    Raz [F:HDI]
    [F:HDI] = [F:HDT]
    INOTEXFLG += 1
  Next
  Filter [HDTK]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  If SVHDTNUM <> "" Then        # FGR 16/04/2012 : X3SUIVI81565
    Gosub PIED_FACT_AV_AGREG
    If IBRETOUR = 0 Then
      Return
    Endif
  Endif
Return
#CHECK IGNORE_END

$FHDIVENUOM
  #Première boucle sans agrégation
  Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  #Deuxième boucle avec agrégation
  Gosub SETVENUOMFLT
  For [HDTK]
    If SZPREITM <> "" Then
      Gosub SETCURITM
      If SZPREITM <> SZCURITM Then
        Gosub CORP_FACT_AV_AGREG
        If IBRETOUR = 0 Then
          Break
        Endif
      Endif
    Endif
    SVHDTNUM = [F:HDT]HDTNUM         # FGR 03/11/2010 : X3SUIVI68364
    Read [ITM]ITM0=[F:HDT]HDTITM
    If fstat Then
      #Erreur lors de la génération d'une ligne de facture.
      IERRINF = 313
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
    If [F:ITM]SAU = [F:HDT]HDTUOM Then
      SZITMSAU = [F:HDT]HDTUOM
      ISUMQTY += [F:HDT]HDTQTY
    Else
      Call SREC_COE([F:HDT]HDTITM, [F:SRE]SREBPC, [F:ITM]SAU, [F:HDT]HDTUOM, ICONVCOEF) From TRTVENQTE
      SZITMSAU = [F:ITM]SAU
      IHDTQTY = [F:HDT]HDTQTY * ICONVCOEF
      ISUMQTY += IHDTQTY
    Endif
    ISUMSTUQTY += [F:HDT]HDTSTUQTY
    ISUMAMTINV += [F:HDT]HDTAMTINV
    Gosub SETPREITM
    Raz [F:HDI]
    [F:HDI] = [F:HDT]
    INOTEXFLG += 1
  Next
  Filter [HDTK]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  If SVHDTNUM <> "" Then        # FGR 16/04/2012 : X3SUIVI81565
    Gosub CORP_FACT_AV_AGREG
    If IBRETOUR = 0 Then
      Return
    Endif
  Endif
Return

##########################################################################################################
# Facturation en unité de consommation avec agrégation
###################################################
########## FGR si c'est bon, CPO sinon
#CHECK IGNORE_BEGIN
$OLDFHDIHDTUOM
  #Première boucle sans agrégation
  Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  #Deuxième boucle avec agrégation
  Gosub SETVENUOMFLT
  For [HDTK]
    Read [CALT]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
    If fstat Then
      #Erreur lors de la lecture des axes analytiques associés aux consommations.
      IERRINF = 433
      ICHAPTER = 177
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
    Gosub SETCURCTL
    If SZPREITM <> "" Then
      If SZPREUOM <> "" Then
        If SZPRECTL <> SZCURCTL Then
          Gosub CORP_FACT_AV_AGREG
          If IBRETOUR = 0 Then
            Break
          Endif
        Endif
      Endif
    Endif
    SZPREITM = [F:HDT]HDTITM
    SZPREUOM = [F:HDT]HDTUOM
    Gosub SETPRECTL
    ISUMQTY += [F:HDT]HDTQTY
    ISUMSTUQTY += [F:HDT]HDTSTUQTY
    ISUMAMTINV += [F:HDT]HDTAMTINV
    Raz [F:HDI]
    [F:HDI] = [F:HDT]
    INOTEXFLG += 1
  Next
  Filter [HDTK]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  If SVHDTNUM <> "" Then        # FGR 16/04/2012 : X3SUIVI81565
    Gosub PIED_FACT_AV_AGREG
    If IBRETOUR = 0 Then
      Return
    Endif
  Endif
Return
#CHECK IGNORE_END

##########################################################################################################
$FHDIHDTUOM
  # Première boucle sans agrégation
  # FGR 22/11/2013 : X3SUIVI92040 (début)
  #Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  If ISIVNULL = G_YES Then
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX <> ""
  Else
    Filter [HDT] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTTEX <> ""
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (fin)
  For [HDT]HDT0 Hint Key HDT1
    Gosub CORP_FACT_SS_AGREG
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [HDT]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  #Deuxième boucle avec agrégation
  Gosub SETVENUOMFLT
  For [HDTK]
    Gosub SETCURCTL
    If SZPREITM <> "" Then
      If SZPREUOM <> "" Then
        If SZPRECTL <> SZCURCTL Then
          Gosub CORP_FACT_AV_AGREG
          If IBRETOUR = 0 Then
            Break
          Endif
        Endif
      Endif
    Endif
    SVHDTNUM = [F:HDT]HDTNUM         # FGR 03/11/2010 : X3SUIVI68364
    SZPREITM = [F:HDT]HDTITM
    SZPREUOM = [F:HDT]HDTUOM
    Gosub SETPRECTL
    ISUMQTY += [F:HDT]HDTQTY
    ISUMSTUQTY += [F:HDT]HDTSTUQTY
    ISUMAMTINV += [F:HDT]HDTAMTINV
    Raz [F:HDI]
    [F:HDI] = [F:HDT]
    INOTEXFLG += 1
  Next
  Filter [HDTK]
  If GOK < 1 Then
    Return
  Endif
  #-------------------------------
  If SVHDTNUM <> "" Then        # FGR 16/04/2012 : X3SUIVI81565
    Gosub CORP_FACT_AV_AGREG
    If IBRETOUR = 0 Then
      Return
    Endif
  Endif
Return

##########################################################################################################
# Corps facturation (partie avec agrégation)
#############################################################
$CORP_FACT_AV_AGREG
  # FGR 03/11/2010 : X3SUIVI68364 (début)
  Read [CALT]CAL0="HDT";0;SVHDTNUM;0;0;"";1
  If fstat Then
    #Erreur lors de la lecture des axes analytiques associés aux consommations.
    IERRINF = 433
    ICHAPTER = 177
    IBRETOUR = 0
    GOK = 0
    Return
  Endif
  # FGR 03/11/2010 : X3SUIVI68364 (fin)
  #
  [F:HDI]HDTORD = IORD
  [F:HDI]HDTQTY = ISUMQTY
  If GINVSREUOM = 2 Then
    # Facturation en unité de vente
    [F:HDI]HDTUOM = SZITMSAU
  Endif
  [F:HDI]HDTSTUQTY = ISUMSTUQTY
  [F:HDI]HDTAMTINV = ISUMAMTINV / ISUMQTY
  # On arrondi la quantité facturable
  IARRHDTQTY = [F:HDI]HDTQTY
  Call QTEARR(IARRHDTQTY, [F:HDI]HDTUOM) From TRTDIV
  [F:HDI]HDTQTY = IARRHDTQTY
  # On arrondi le montant facturable
  IARRAMTINV = [F:HDI]HDTAMTINV
  [F:HDI]HDTAMTINV = arr(IARRAMTINV,10^-GDECPRI)
  Write [HDI]
  If fstat Then
    # Erreur lors de la génération d'une ligne de facture.
    IERRINF = 313
    ICHAPTER = 182
    IBRETOUR = 0
    Call FSTA("HDI") From GLOCK
    GOK = 0
    Return
  Endif
  [F:CAL] = [F:CALT]
  [F:CAL]ABRFIC = "HDI"
  [F:CAL]VCRNUM = [F:HDI]SRENUM
  [F:CAL]VCRLIN = [F:HDI]HDTORD
  [F:CAL]VCRSEQ = 0
  [F:CAL]CPLCLE = ""
  [F:CAL]ANALIG = 1
  Write [CAL]
  If fstat Then
    # Erreur lors de la génération des axes analytiques d'une ligne de facture.
    IERRINF = 432
    ICHAPTER = 177
    IBRETOUR = 0
    Call FSTA("CAL") From GLOCK
    GOK = 0
    Return
  Endif
  IORD += 1
  ISUMQTY = 0
  ISUMSTUQTY = 0
  ISUMAMTINV = 0
Return

##########################################################################################################
# Dernière partie cas facture avec agrégation
#############################################################
#CHECK IGNORE_BEGIN
$PIED_FACT_AV_AGREG
  If INOTEXFLG Then
    [F:HDI]HDTORD = IORD
    [F:HDI]HDTQTY = ISUMQTY
    If GINVSREUOM = 2 Then
      # Facturation en unité de vente
      [F:HDI]HDTUOM = SZITMSAU
    Endif
    [F:HDI]HDTSTUQTY = ISUMSTUQTY
    [F:HDI]HDTAMTINV = ISUMAMTINV / ISUMQTY
    #On arrondi la quantité facturable
    IARRHDTQTY = [F:HDI]HDTQTY
    Call QTEARR(IARRHDTQTY, [F:HDI]HDTUOM) From TRTDIV
    [F:HDI]HDTQTY = IARRHDTQTY
    #On arrondi le montant facturable
    IARRAMTINV = [F:HDI]HDTAMTINV
    [F:HDI]HDTAMTINV = arr(IARRAMTINV,10^-GDECPRI)
    Write [HDI]
    If fstat Then
      #Erreur lors de la génération d'une ligne de facture.
      IERRINF = 313
      ICHAPTER = 182
      IBRETOUR = 0
      Call FSTA("HDI") From GLOCK
      GOK = 0
      Return
    Endif
    Read [CAL]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
    [F:CAL]ABRFIC = "HDI"
    [F:CAL]VCRNUM = [F:HDI]SRENUM
    [F:CAL]VCRLIN = [F:HDI]HDTORD
    [F:CAL]VCRSEQ = 0
    [F:CAL]CPLCLE = ""
    [F:CAL]ANALIG = 1
    Write [CAL]
    If fstat Then
      #Erreur lors de la génération des axes analytiques d'une ligne de facture.
      IERRINF = 432
      ICHAPTER = 177
      IBRETOUR = 0
      Call FSTA("CAL") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return
#CHECK IGNORE_END

##########################################################################################################
# Enregistrement des statistiques sur compétence
#############################################################
Subprog MNGPBLSTAT(SZSRENUM, SZSREPREPBL, SZPBL, ISREPREASS, ISREASS, SZSREPREDET, SZSREDET, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZSREPREPBL
Value Char SZPBL
Value Integer ISREPREASS
Value Integer ISREASS
Value Char SZSREPREDET
Value Char SZSREDET
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  If !clalev([F:PBQ]) : Local File FAMPBQUE [PBQ] : Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [PBR], [PBQ]
  Endif
  #Gestion de la décrémentation
  If ISREPREASS = 2 and SZSREPREDET <> "" Then
    If SZSREPREPBL <> "" Then
      Read [PBR]PBR2=SZSREPREPBL;SZSREPREDET
      If !fstat Then
        Readlock [PBR]PBR2=SZSREPREPBL;SZSREPREDET
        If !fstat Then
          [F:PBR]SRECOU -= 1
          Rewrite [PBR]
          If fstat Then
            #Erreur lors de la décrementation des statistiques sur compétences.
            IERRINF = 720
            ICHAPTER = 182
            IBRETOUR = 0
            Call FSTA("PBR") From GLOCK
            GOK = 0
          Endif
        Endif
      Endif
    Endif
  Endif
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If ISREPREASS = 3 and SZSREPREDET <> "" Then
      If SZSREPREPBL <> "" Then
        Read [PBQ]PBQ2=SZSREPREPBL;SZSREPREDET
        If !fstat Then
          Readlock [PBQ]PBQ2=SZSREPREPBL;SZSREPREDET
          If !fstat Then
            [F:PBQ]SRECOU -= 1
            Rewrite [PBQ]
            If fstat Then
              #Erreur lors de la décrementation des statistiques sur compétences.
              IERRINF = 720
              ICHAPTER = 182
              IBRETOUR = 0
              Call FSTA("PBQ") From GLOCK
              GOK = 0
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Incrémentation de la statistique avec la nouvelle affectation.
  #Collaborateur
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If ISREASS = 2 and SZSREDET <> "" Then
      If SZPBL <> "" Then
        Read [PBR]PBR2=SZPBL;SZSREDET
        If fstat Then
          #Il faut créer la nouvelle statistique
          Raz [F:PBR]
          [F:PBR]GRPPBLNUM = SZPBL
          [F:PBR]REPNUM = SZSREDET
          Read [AUS]CODUSR=SZSREDET
          If fstat Then
            [F:PBR]REPNAM = ""
          Else
            [F:PBR]REPNAM = [F:AUS]NOMUSR
          Endif
          [F:PBR]SRECOU = 1
          [F:PBR]STTFLG = 1
          Write [PBR]
          If fstat Then
            #Erreur lors de la création d'une nouvelle statistique sur compétence.
            IERRINF = 721
            ICHAPTER = 182
            IBRETOUR = 0
            Call FSTA("PBR") From GLOCK
            GOK = 0
          Endif
        Else
          Readlock [PBR]PBR2=SZPBL;SZSREDET
          If !fstat Then
            [F:PBR]SRECOU += 1
            Rewrite [PBR]
            If fstat Then
              #Erreur lors de la mise à jour des statistiques sur compétences.
              IERRINF = 722
              ICHAPTER = 182
              IBRETOUR = 0
              Call FSTA("PBR") From GLOCK
              GOK = 0
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Queue
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If ISREASS = 3 and SZSREDET <> "" Then
      If SZPBL <> "" Then
        Read [PBQ]PBQ2=SZPBL;SZSREDET
        If fstat Then
          #Il faut créer la nouvelle statistique
          Raz [F:PBQ]
          [F:PBQ]GRPPBLNUM = SZPBL
          [F:PBQ]QUENUM = SZSREDET
          Read [QUE]QUE0=SZSREDET
          If fstat Then
            [F:PBQ]QUENAM = ""
          Else
            # FGR 23/09/2009 : X3SUIVI58037
            #[F:PBQ]QUENAM = [F:QUE]TTR
            Call LECTEXTRA([F:PBQ]QUENAM,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
          Endif
          [F:PBQ]SRECOU = 1
          [F:PBQ]STTFLG = 1
          Write [PBQ]
          If fstat Then
            #Erreur lors de la création d'une nouvelle statistique sur compétence.
            IERRINF = 721
            ICHAPTER = 182
            IBRETOUR = 0
            Call FSTA("PBQ") From GLOCK
            GOK = 0
          Endif
        Else
          Readlock [PBQ]PBQ2=SZPBL;SZSREDET
          If !fstat Then
            [F:PBQ]SRECOU += 1
            Rewrite [PBQ]
            If fstat Then
              #Erreur lors de la mise à jour des statistiques sur compétences.
              IERRINF = 722
              ICHAPTER = 182
              IBRETOUR = 0
              Call FSTA("PBQ") From GLOCK
              GOK = 0
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Renvoie le collaborateur le moins occupé pour une famille de compétence donnée
###################################################
Subprog GETDEFREP(SZPBL, SZDEFREP)
Value Char SZPBL
Variable Char SZDEFREP

Local Integer IMINCOUNT
Local Integer IFIRSTSTEP
Local Char SZSKILLEDREP
Local Char SZHDKREP
Local Integer IHDKREP
Local Integer ISREFLG
Local Integer ISRECOUNT
Local Integer ISREPBRCOUNT

  SZDEFREP = ""
  SZHDKREP = ""
  IHDKREP = 0
  IMINCOUNT = 0
  IFIRSTSTEP = 0
  SZSKILLEDREP = ""
  ISREFLG = 0
  ISRECOUNT = 0
  ISREPBRCOUNT = 0
  If SZPBL = "" Then
    End
  Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  Filter [PBR] Where [F:PBR]GRPPBLNUM = SZPBL and [F:PBR]STTFLG = 0
  For [PBR]
    Read [AUS] CODUSR = [F:PBR]REPNUM
    If !fstat Then
      Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:PBR]REPNUM, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP = 2 Then
        If !IFIRSTSTEP Then
          IMINCOUNT = [F:PBR]SRECOU
          SZSKILLEDREP = [F:PBR]REPNUM
        Else
          If [F:PBR]SRECOU < IMINCOUNT Then
            IMINCOUNT = [F:PBR]SRECOU
            SZSKILLEDREP = [F:PBR]REPNUM
          Endif
        Endif
        IFIRSTSTEP += 1
      Endif
    Endif
  Next
  Filter [PBR]
  If IFIRSTSTEP > 0 Then
    #Un représentant a été trouvé.
    #Recherche le collaborateur vraiment le moins occupé
    Filter [PBR] Where [F:PBR]GRPPBLNUM = SZPBL and [F:PBR]STTFLG = 0 and [F:PBR]REPNUM <> SZSKILLEDREP and [F:PBR]SRECOU = IMINCOUNT
    For [PBR]
      If ISREFLG = 0 Then
        Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = SZSKILLEDREP and [F:SRE]SREMACPBL = "" and [F:SRE]SREPBLGRP = ""
        For [SRE]
          ISRECOUNT += 1
        Next
        Filter [SRE]
        ISREFLG = 1
      Endif
      Read [AUS]CODUSR=[F:PBR]REPNUM
      If !fstat Then
        Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:PBR]REPNUM, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP = 2 Then
          ISREPBRCOUNT = 0
          Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = [F:PBR]REPNUM and [F:SRE]SREMACPBL = "" and [F:SRE]SREPBLGRP = ""
          For [SRE]
            ISREPBRCOUNT += 1
          Next
          Filter [SRE]
          If ISREPBRCOUNT < ISRECOUNT Then
            ISRECOUNT = ISREPBRCOUNT
            SZSKILLEDREP = [F:PBR]REPNUM
          Endif
        Endif
      Endif
    Next
    Filter [PBR]
    SZDEFREP = SZSKILLEDREP
  Endif
End

##########################################################################################################
#Définition du filtre
####################################################
$SETVENUOMFLT
Local Char SZORDER(30)(250)
Local Integer NI
Local Integer NE

  Raz SZORDER
  NE = 0
  SZORDER(NE) = "[F:HDT]HDTITM Asc;"
  NE += 1
  # FGR 19/08/2009 : X3SUIVI57249 obligé de limité à 18 le nombre d'itération.
  #                  On ne peut mettre que 20 élément dans le Order au maximum
  #For NI = 1 To GOPTCANA-1
  #For NI = 1 To min(GOPTCANA-1, 18)
  For NI = 1 To min(GOPTCANA-1, 14)  # FGR 11/10/2010 : X3SUIVI67496
    SZORDER(NE) = "[F:CALK]CCE(" + num$(NI-1) + ") Asc;"  # FGR 03/11/20110 : X3SUIVI68364 c'est (NI-1)
    NE += 1
  Next NI
  SZORDER(NE) = "[F:HDT]HDTUOM Asc"
  Link [HDT] With [CALK]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1 As [HDTK]
  # FGR 22/11/2013 : X3SUIVI92040 (début)
  #  Filter [HDTK] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX = "" and HDTSALTEX = ""
  #&          Order With SZORDER
  If ISIVNULL = G_YES Then
    Filter [HDTK] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTAMTINV > 0 and HDTTEX = "" and HDTSALTEX = ""
&                 Order With SZORDER
  Else
    Filter [HDTK] Where SRENUM = SZSRENUM and TPL <> 2 and HDTINV = 2 and HDTDONDAT <> [00/00/00] and HDTTEX = "" and HDTSALTEX = ""
&                 Order With SZORDER
  Endif
  # FGR 22/11/2013 : X3SUIVI92040 (début)
Return

##########################################################################################################
#Définition de SZPREITM
####################################################
$SETPREITM
  SZPREITM = [F:HDT]HDTITM
  SZPREITM = SZPREITM + func GET_CCE_RUPT
Return

##########################################################################################################
#Définition de SZCURITM
####################################################
$SETCURITM
  SZCURITM = [F:HDT]HDTITM
  SZCURITM = SZCURITM + func GET_CCE_RUPT
Return

##########################################################################################################
#Définition de SZPRECTL
####################################################
$SETPRECTL
  SZPRECTL = SZPREITM
  SZPRECTL = SZPRECTL + func GET_CCE_RUPT
  SZPRECTL = SZPRECTL + "\" + SZPREUOM
Return

##########################################################################################################
#Définition de SZCURCTL
####################################################
$SETCURCTL
  SZCURCTL = [F:HDT]HDTITM
  SZCURCTL = SZCURCTL + func GET_CCE_RUPT
  SZCURCTL = SZCURCTL + "\" + [F:HDT]HDTUOM
Return

##########################################################################################################
# Rend partie clé de rupture sur CCE
####################################################
Funprog GET_CCE_RUPT
Local Char SARENDRE(250)
Local Integer IINDICE

  SARENDRE = ""
  For IINDICE = 0 To min(GOPTCANA-1, 14)              # FGR 03/11/20110 : X3SUIVI68364
    SARENDRE = SARENDRE + "\" + [F:CALK]CCE(IINDICE)  # FGR 03/11/20110 : X3SUIVI68364 pas [F:CALT]
  Next IINDICE
End SARENDRE
