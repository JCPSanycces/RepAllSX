#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLPUR08   Contrôle Pre-migration Factures             Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLPUR08") From LECFIC
  Endif

  Call MAJ_UUMGCTLPUR08(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLPUR08(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(5)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLPUR08 Purchase Invoices Process : PINVOICE-V-D") From DOSSUB
Call ECR_TRACE("UUMGCTLPUR08 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1
Gosub CTL2
Gosub CTL3
Gosub CTL4

$FIN
Call ECR_TIME("UUMGCTLPUR08 : Purchase Invoices Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICED") : Return : Endif


REQSQL(0)="SELECT PIH.NUM_0 FROM "-DOSSIER+".PINVOICE PIH "
REQSQL(1)="WHERE ORIMOD_0<>3 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PINVOICED PID WHERE PIH.NUM_0=PID.NUM_0) "
REQSQL(2)="ORDER BY PIH.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PINVOICE without PINVOICED",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICED") : Return : Endif

REQSQL(0)="SELECT PID.NUM_0,PID.PIDLIN_0 FROM "-DOSSIER+".PINVOICED PID "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PINVOICE PIH WHERE PIH.NUM_0=PID.NUM_0) "
REQSQL(2)="ORDER BY PID.NUM_0,PID.PIDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PINVOICED without PINVOICE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VNUM(50),Integer VPIDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM/PIDLIN="-[BXX]VNUM+'/'+num$([BXX]VPIDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################
###################################################################################
$CTL3
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICEV") : Return : Endif

REQSQL(0)="SELECT PIH.NUM_0 FROM "-DOSSIER+".PINVOICE PIH "
REQSQL(1)="WHERE ORIMOD_0<>3 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PINVOICEV PIV WHERE PIH.NUM_0=PIV.NUM_0) "
REQSQL(2)="ORDER BY PIH.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PINVOICE without PINVOICEV",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL4
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PINVOICEV") : Return : Endif

REQSQL(0)="SELECT PIV.NUM_0 FROM "-DOSSIER+".PINVOICEV PIV "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PINVOICE PIH WHERE PIH.NUM_0=PIV.NUM_0) "
REQSQL(2)="ORDER BY PIV.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PINVOICEV without PINVOICE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
