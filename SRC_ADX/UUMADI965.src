##################################################################################
# UUMADI965                                                                   #
# MDJ - Init du flag "genre TVS" dans la table ADI 965                          #
# 29/06/2010 Fq-60551                                                           #
##################################################################################
 Call PATCH(nomap)  
End 
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

 #If PAPPLI=adxmother
 # End
 #Endif

 If filinfo(filpath("FIL","ATABDIV","fde",PAPPLI),0)<=0
  End
 Else
  Call EXE_MAJADI965(PAPPLI)
 Endif

End

#######################################################################
# Pour exécution depuis intégration de patch
########################################################################
Subprog PATCH(PAPPLI)
Value Char APPLI

 #If PAPPLI=adxmother
 # End
 #Endif
 
 Local Char FICHIER(250)
 FICHIER=filpath("FIL","ATABDIV","fde",PAPPLI)
 If filinfo(FICHIER,0) < 0
  End
 Else
  Call EXE_MAJADI965(PAPPLI) 
 Endif 

End

#--------------------------------------------
# Initialisation du champ CNX dans les
# événements 
#--------------------------------------------
Subprog EXE_MAJADI965(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)
Local Integer OK
Local Integer OK

 GOK = 1

#-----
Call ECR_TRACE("UUMADI965 : Update new flag on ADI 965 table "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ADI]) =0  Local File =LDOSSIER+".ATABDIV"     [ADI] : Endif
#-------------------------------#
#   mise a jour table ATABDIV   #
#-------------------------------#
Trbegin [ADI]
For [ADI] Where NUMTAB=965 
   If CODE = "VP" 
      [F:ADI]N1     = G_OUI
      [F:ADI]N2     = 0
   Else
      [F:ADI]N1     = G_NON
      [F:ADI]N2     = 0
   Endif
   Rewrite [F:ADI]
Next

$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif
#----- Fin du traitement -----#
WMSG ="UUMADI965 : end of process"
Call ECR_TRACE(WMSG,0) From GESECRAN

End





