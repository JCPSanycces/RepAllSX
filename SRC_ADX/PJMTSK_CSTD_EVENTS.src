#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSK
###################################################################################################
# EVENTS
###################################################################################################
$AINSERT_CONTROL_BEFORE
Local Integer IRET
Local Integer IERROR
Local Integer IMANUAL
Local Char SMESSAGE(250)
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(type(this.TASNUM)-10)
Local Char SCPY(GLONCPY)

  # -------------------------
  #this.PIMPL.PIMTYP Field managed at TASK_ADD_AS_xxx because value is depending of xxx.
  this.PIMPL.OPPNUM = this.OPPNUM
  this.PIMPL.PBUCOD = this.PBUCOD
  this.PIMPL.TASCOD = this.TASCOD
  # -------------------------
  # ML2389 (line 13)
  SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.TASFCY,"LEGCPY")
  Call READ_COUNTER(this.ACTX, 9, 12, SCPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR))
    Return
  Endif
  If SCOMPTEUR = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(365,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------------
  # Appel du compteur de numérotation
  IRET = func ANM_TOOL.NUMERO(this.ACTX, SCOMPTEUR, this.TASFCY, date$, "", SNUMERO, SMESSAGE)
  If IRET = [V]CST_AERROR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(22,7770,1) - "(" + SCOMPTEUR + ") :" - SMESSAGE, [V]CST_AERROR))
    Return
  Endif
  this.TASNUM = SNUMERO
  # -------------------------
  Gosub INSERT_UPDATE_CONTROL_BEFORE
  # -------------------------
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  If this.TASSTATE = 4 and this.TCHACTION <> "CLOSING" and this.TCHACTION <> "STATUS" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
    Return
  Endif
  # -------------------------
  Gosub INSERT_UPDATE_CONTROL_BEFORE
  # -------------------------
  If this.TASTLA = [V]CST_ANO Then
    If this.TASENDDT <> this.snapshot.TASENDDT Then
      this.TASTLA = [V]CST_AYES
    Endif
  Endif
  [L]ASTATUS = max([L]ASTATUS, fmet this.RITT_REPEAT_TASENDDT())
Return

###################################################################################################
# To write it one time
$INSERT_UPDATE_CONTROL_BEFORE
Local Integer NI
Local Integer ITODO

  ITODO = [V]CST_AYES
  Local File ATABDIV[ADI]
  If this.PRCCPLADI <> AVOID.ACHAR Then
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PRCCPLADI <> this.snapshot.PRCCPLADI) Then
      If this.PRCCPL = this.snapshot.PRCCPL Then
        Read [ADI]CODE=387;this.PRCCPLADI
        If not (this.PRCCPL >= [F:ADI]N1 and (([F:ADI]N2 < 100 and this.PRCCPL < [F:ADI]N2) or ([F:ADI]N2 = 100 and this.PRCCPL <= [F:ADI]N2))) Then
          this.PRCCPL = [F:ADI]N3
          ITODO = [V]CST_ANO
        Endif
      Endif
    Endif
  Endif
  # -------------------------
  If ITODO = [V]CST_AYES Then
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PRCCPL <> this.snapshot.PRCCPL) Then
      If this.PRCCPLADI = this.snapshot.PRCCPLADI Then
        Filter [ADI] Where [F:ADI]NUMTAB = 387
        For [ADI]CODE
          If this.PRCCPL >= [F:ADI]N1 and (([F:ADI]N2 < 100 and this.PRCCPL < [F:ADI]N2) or ([F:ADI]N2 = 100 and this.PRCCPL <= [F:ADI]N2)) Then
            this.PRCCPLADI = [F:ADI]CODE
            Break
          Endif
        Next
        Filter [ADI]
      Endif
    Endif
  Endif
  # -------------------------
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RITT(NI).OPPNUM = "" or this.RITT(NI).TASCOD = "" Then
        this.RITT(NI).OPPNUM = this.OPPNUM
        this.RITT(NI).TASCOD = this.TASCOD
      Endif
    Endif
  Next NI
  # -------------------------
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RTKO(NI).OPPNUM = "" or this.RTKO(NI).TASCOD = "" Then
        this.RTKO(NI).OPPNUM = this.OPPNUM
        this.RTKO(NI).TASCOD = this.TASCOD
      Endif
    Endif
  Next NI
Return

###################################################################################################
$ACONTROL
Local Integer NI
Local Integer IFOUND
Local Integer IWRHFLG

  # -------------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  # -------------------------
  If this.ASTALIN = [V]CST_AUPD and this.TASFCY <> this.snapshot.TASFCY Then
    If this.TASSTATE <> 1 or fmet this.RTKO_COUNT() > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------
  If this.PIMPL.PIMTYP = 6 or this.PIMPL.PIMTYP = 7 Then
    # the site must be, at least "stock" site
    IWRHFLG = fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.TASFCY, "WRHFLG")
    If IWRHFLG <> [V]CST_AYES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", this.TASFCY - ":" - mess(358,184,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------
  If this.ASTALIN = [V]CST_AUPD and this.TASNUM <> this.snapshot.TASNUM Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASNUM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # -------------------------
  If this.TASSTARTDT <> AVOID.ADATE and this.TASENDDT <> AVOID.ADATE Then
    If this.TASENDDT < this.TASSTARTDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", mess(289,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------
  If this.TASTLA = [V]CST_AYES and this.TASTLA <> this.snapshot.TASTLA Then
    IFOUND = [V]CST_ANO
    If this.ASTALIN = [V]CST_AUPD Then
      If this.TASENDDT <> this.snapshot.TASENDDT Then
        IFOUND = [V]CST_AYES
      Endif
    Endif
    If IFOUND = [V]CST_ANO Then
      For NI = 1 To maxtab(this.RITT)
        If this.RITT(NI) <> null Then
          If this.RITT(NI).ASTALIN = [V]CST_ADEL or this.RITT(NI).ASTALIN = [V]CST_ANEWDEL Then
            IFOUND = [V]CST_AYES
            Break
          Elsif this.RITT(NI).ASTALIN = [V]CST_ANEW Then
            IFOUND = [V]CST_AYES
            Break
          Elsif this.RITT(NI).ASTALIN = [V]CST_AUPD Then
            If this.RITT(NI).ITMREF <> this.RITT(NI).snapshot.ITMREF or this.RITT(NI).ITTQTY <> this.RITT(NI).snapshot.ITTQTY or this.RITT(NI).BOMALT <> this.RITT(NI).snapshot.BOMALT
&            or (dim(this.RITT(NI).ECCVALMAJ) > 0 and this.RITT(NI).ECCVALMAJ <> this.RITT(NI).snapshot.ECCVALMAJ)
&            or (dim(this.RITT(NI).ECCVALMIN) > 0 and this.RITT(NI).ECCVALMIN <> this.RITT(NI).snapshot.ECCVALMIN)
&          Then
              IFOUND = [V]CST_AYES
              Break
            Endif
          Endif
        Endif
      Next NI
    Endif
  Elsif this.TASTLA = [V]CST_ANO and this.TASTLA <> this.snapshot.TASTLA Then
    IFOUND = [V]CST_AYES
    If this.ASTALIN = [V]CST_AUPD Then
      If this.TCHACTION <> "LAUNCH" Then
        IFOUND = [V]CST_ANO
      Endif
    Endif
  Endif
  If IFOUND = [V]CST_ANO Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASTLA", mess(18,9804,1) - "(" + this.TASCOD - mess(this.TASTLA,1,1) + ")", [V]CST_AERROR))
  Endif
  If this.PRCCPLADI <> AVOID.ACHAR Then
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PRCCPLADI <> this.snapshot.PRCCPLADI) Then
      Local File ATABDIV[ADI]
      Read [ADI]CODE=387;this.PRCCPLADI
      If this.PRCCPLADI <> [ADI]CODE Then
        If not ([F:ADI]N1 >= this.PRCCPL and (([F:ADI]N2 < 100 and this.PRCCPL < [F:ADI]N2) or ([F:ADI]N2 = 100 and this.PRCCPL <= [F:ADI]N2))) Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRCCPL", func AFNC.MES1(mess(996,2260,1), this.TASCOD), [V]CST_AERROR))
        Endif
      Endif
      IFOUND = [V]CST_ANO
      Filter [ADI] Where [F:ADI]NUMTAB = 387
      For [ADI]CODE
        If this.PRCCPL >= [F:ADI]N1 and (([F:ADI]N2 < 100 and this.PRCCPL < [F:ADI]N2) or ([F:ADI]N2 = 100 and this.PRCCPL <= [F:ADI]N2)) Then
          If this.PRCCPLADI = [F:ADI]CODE Then
            IFOUND = [V]CST_AYES
            Break
          Endif
        Endif
      Next
      Filter [ADI]
      If IFOUND = [V]CST_ANO Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRCCPLADI", func AFNC.MES1(mess(996,2260,1), this.TASCOD), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.TCHANSREQDAT.INIT()
Return

###################################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

###################################################################################################
# RITT
###################################################################################################
$RITT_ACONTROL
  If this.TASFCY <> this.APARENT.TASFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  #If this.APARENT.TASSTATE <> 1 and this.REQDAT = AVOID.ADATE Then  # Issue X3-107689 - 2018-10-08 by FGR
  If this.APARENT.TASSTATE <> 1 and this.APARENT.TASSTATE <> 4 and this.APARENT.TASSTATE <> 9 and
&    this.REQDAT = AVOID.ADATE Then                                  # Issue X3-107689 - 2018-10-08 by FGR
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("REQDAT", func AFNC.MES2(mess(542,2260,1), this.ITMREF, mess(this.APARENT.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.APARENT.TASSTARTDT <> AVOID.ADATE and this.REQDAT <> AVOID.ADATE and this.REQDAT < this.APARENT.TASSTARTDT Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("REQDAT", func AFNC.MES3(mess(558,2260,1), this.ITMREF, format$(GFMDAT,this.REQDAT), format$(GFMDAT,this.APARENT.TASSTARTDT)), [V]CST_AERROR))
  Endif
  If this.APARENT.TASENDDT <> AVOID.ADATE and this.REQDAT <> AVOID.ADATE and this.REQDAT > this.APARENT.TASENDDT Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("REQDAT", func AFNC.MES3(mess(559,2260,1), this.ITMREF, format$(GFMDAT,this.REQDAT), format$(GFMDAT,this.APARENT.TASENDDT)), [V]CST_AERROR))
  Endif
  # Issue X3-105748 - 2018-08-30 by FGR : BEGIN
  # Issue X3-101833 - 2018-08-06 by FGR : BEGIN
  #If (this.APARENT.TASSTATE = 2 or this.APARENT.TASSTATE = 3) and this.APARENT.TCHACTION <> "REACTIVATE" Then
  #  If this.FRCDLTALLFLG = [V]CST_AYES and this.FRCDLTALLFLG = this.snapshot.FRCDLTALLFLG and this.ASTALIN = [V]CST_AUPD Then
  #    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1124,2260,1) - this.APARENT.TCHACTION, [V]CST_AERROR))
  #  Endif
  #Endif
  # Issue X3-101833 - 2018-08-06 by FGR : END
  If (this.APARENT.TASSTATE = 2 or this.APARENT.TASSTATE = 3) Then
    If fmet this.FRCDLTALLFLG_UPDATABLE() = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1124,2260,1) - this.APARENT.TCHACTION, [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-105748 - 2018-08-30 by FGR : END
Return

###################################################################################################
$RITT_ADDLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.PIMPL.PIMTYP <> 6 and this.PIMPL.PIMTYP <> 7 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(156,2260,1), mess(this.PIMPL.PIMTYP,2254,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$RITT_ADDLINE_AFTER
Local Integer NI
Local Integer NE

  NE = 0
  For NI = 1 To maxtab(this.APARENT.RITT)
    # FGR : explaination : We don't have to test ASTALIN in this case because lines could be deleted and undeleted
    #If this.APARENT.RITT(NI) <> null and find(this.APARENT.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
    If this.APARENT.RITT(NI) <> null Then
      If this.APARENT.RITT(NI).ITTSEQ > NE Then
        NE = this.APARENT.RITT(NI).ITTSEQ
      Endif
    Endif
  Next NI
  this.ITTSEQ = NE + 10
  # -------------------------
  this.TASFCY = this.APARENT.TASFCY
  this.STOFCY = this.APARENT.TASFCY              # Issue X3-65941 - 2018-01-12 by FGR
  this.OPPCMP = this.APARENT.OPPCMP
  this.TCHTASSTATE = this.APARENT.TASSTATE
  this.CUR = this.APARENT.CUR
  # -------------------------
  this.APARENT.TASTLA = [V]CST_AYES
  # -------------------------
  this.REQDAT = this.APARENT.TASENDDT
Return

###################################################################################################
$RITT_ADELLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.RITT([L]ALINE).ALLQTY > 0 or this.RITT([L]ALINE).DLVQTY <> 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(999,2260,1), this.RITT([L]ALINE).ITMREF), [V]CST_AERROR))
  Endif
  # Issue X3-101833 - 2018-08-06 by FGR : BEGIN
  If this.RITT([L]ALINE).WIPNUM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1126,2260,1), [V]CST_AERROR))
  Endif
  If this.RITT([L]ALINE).ODLQTY > 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1125,2260,1), [V]CST_AERROR))
  Endif
  # Issue X3-101833 - 2018-08-06 by FGR : END
Return

###################################################################################################
$RITT_ADELLINE_AFTER
  this.APARENT.TASTLA = [V]CST_AYES
Return

###################################################################################################
$RITT_AUPDATE_CONTROL_BEFORE
  If this.APARENT.TASSTATE = 4 and this.APARENT.TCHACTION <> "CLOSING" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.APARENT.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$RITT_AUPDATE_CONTROL_AFTER
  If this.ITMREF <> this.snapshot.ITMREF or this.ITTQTY <> this.snapshot.ITTQTY or this.BOMALT <> this.snapshot.BOMALT
&    or (dim(this.ECCVALMAJ) > 0 and this.ECCVALMAJ <> this.snapshot.ECCVALMAJ)
&    or (dim(this.ECCVALMIN) > 0 and this.ECCVALMIN <> this.snapshot.ECCVALMIN)
& Then
    this.APARENT.TASTLA = [V]CST_AYES
  Endif
Return

###################################################################################################
$RITT_AINSERT_BEFORE
Local Instance TECORDERS Using C_TECORDERS

  # Orders records management => Creation
  TECORDERS = NewInstance C_TECORDERS AllocGroup null
  # -------------------------
  TECORDERS.TASANSDEL = this.APARENT.TCHANSORDER
  TECORDERS.TASSTATE = this.APARENT.TASSTATE
  TECORDERS.TASSTATESNAP = this.APARENT.snapshot.TASSTATE
  TECORDERS.STRDAT = this.APARENT.TASSTARTDT
  TECORDERS.ENDDAT = this.REQDAT
  TECORDERS.VCRNUM = this.APARENT.TASNUM
  # -------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.WIP(TECORDERS))
  # -------------------------
  FreeGroup TECORDERS
Return

###################################################################################################
$RITT_AUPDATE_BEFORE
Local Instance TECORDERS Using C_TECORDERS

  # Orders records management => Creation
  TECORDERS = NewInstance C_TECORDERS AllocGroup null
  # -------------------------
  TECORDERS.TASANSDEL = this.APARENT.TCHANSORDER
  TECORDERS.TASSTATE = this.APARENT.TASSTATE
  TECORDERS.TASSTATESNAP = this.APARENT.snapshot.TASSTATE
  TECORDERS.STRDAT = this.APARENT.TASSTARTDT
  TECORDERS.ENDDAT = this.REQDAT
  TECORDERS.VCRNUM = this.APARENT.TASNUM
  # -------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.WIP(TECORDERS))
  # -------------------------
  FreeGroup TECORDERS
Return

###################################################################################################
$RITT_ADELETE_AFTER
Local Instance TECORDERS Using C_TECORDERS

  # Orders records management => Modification
  TECORDERS = NewInstance C_TECORDERS AllocGroup null
  # -------------------------
  TECORDERS.TASANSDEL = this.APARENT.TCHANSORDER
  TECORDERS.TASSTATE = this.APARENT.TASSTATE
  TECORDERS.TASSTATESNAP = this.APARENT.snapshot.TASSTATE
  TECORDERS.STRDAT = this.APARENT.TASSTARTDT
  TECORDERS.ENDDAT = this.REQDAT
  TECORDERS.VCRNUM = this.APARENT.TASNUM
  # -------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.WIP(TECORDERS))
  # -------------------------
  FreeGroup TECORDERS
Return

###################################################################################################
# RTKO
###################################################################################################
$RTKO_ACONTROL
  If this.TCHTCACOD <> this.APARENT.TCACOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHTCACOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHTASSTATE <> this.APARENT.TASSTATE and this.TCHTASSTATE <> this.APARENT.snapshot.TASSTATE Then
    # In case of status change, the first condition could be false. but the second one have to be true.
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHTASSTATE", mess(18,9804,1) - num$(this.TCHTASSTATE) - num$(this.APARENT.TASSTATE), [V]CST_AERROR))
  Endif
  If this.TCHCHGTYP <> this.APARENT.TCHCHGTYP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHCHGTYP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASFCY <> this.APARENT.TASFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.APARENT.TASSTARTDT <> AVOID.ADATE and this.OPESTR <> AVOID.ADATE Then
    If this.OPESTR < this.APARENT.TASSTARTDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(601,2260,1), this.APARENT.TASCOD) - func AFNC.MES5(mess(602,2260, 1), num$(this.OPENUM), format$(GFMDAT,this.OPESTR),
&                                         format$(GFMDAT,this.OPEEND),
&                                         format$(GFMDAT,this.APARENT.TASSTARTDT), format$(GFMDAT,this.APARENT.TASENDDT)), [V]CST_AERROR))
    Endif
  Endif
  If this.APARENT.TASENDDT <> AVOID.ADATE and this.OPEEND <> AVOID.ADATE Then
    If this.OPEEND > this.APARENT.TASENDDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(601,2260,1), this.APARENT.TASCOD) - func AFNC.MES5(mess(602,2260,1), num$(this.OPENUM),
&                                         format$(GFMDAT,this.OPESTR), format$(GFMDAT,this.OPEEND),
&                                         format$(GFMDAT,this.APARENT.TASSTARTDT), format$(GFMDAT,this.APARENT.TASENDDT)), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-101322 - 2018-08-09 by FGR : BEGIN
  If this.APARENT.TASSTATE <> 1 and this.APARENT.TASSTATE <> 4 and this.APARENT.TASSTATE <> 5 Then
    If this.OPESTR = [0/0/0] Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTR", mess(449,2260,1), [V]CST_AERROR))
    Endif
    If this.OPEEND = [0/0/0] Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEEND", mess(449,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-101322 - 2018-08-09 by FGR : END
Return

###################################################################################################
$RTKO_ADDLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.PIMPL.PIMTYP <> 5 and this.PIMPL.PIMTYP <> 7 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(157,2260,1), mess(this.PIMPL.PIMTYP,2254,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$RTKO_ADDLINE_AFTER
Local Integer NI
Local Integer NE

  NE = 0
  For NI = 1 To maxtab(this.APARENT.RTKO)
    # FGR : explaination : We don't have to test ASTATIN in this case because lines could be deleted and undeleted
    #If this.APARENT.RTKO(NI) <> null and find(this.APARENT.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
    If this.APARENT.RTKO(NI) <> null Then
      If this.APARENT.RTKO(NI).OPENUM > NE Then
        NE = this.APARENT.RTKO(NI).OPENUM
      Endif
    Endif
  Next NI
  this.OPENUM = NE + 10
  this.OPESPLNUM = 1
  # -------------------------
  this.TASFCY = this.APARENT.TASFCY
  this.CUR = this.APARENT.CUR
  this.TCHTCACOD = this.APARENT.TCACOD        # Technical property. update also RTKO_INIT_TECH_PROP
  this.TCHTASSTATE = this.APARENT.TASSTATE    # Technical property. update also RTKO_INIT_TECH_PROP
  this.TCHCHGTYP = this.APARENT.TCHCHGTYP     # Technical property. update also RTKO_INIT_TECH_PROP
  # -------------------------
  # Init operation default status (depending of the TASSTATE value)
  Case this.APARENT.TASSTATE
    When 1                   # New
      this.OPESTA = 1        # =>Pending
    When 2, 3                # Launch or Started
      this.OPESTA = 4        # =>In progress
    When 9                   # Suspended
      this.OPESTA = 1        # =>Pending
  Endcase
  # -------------------------
  Local File PJMTSKCAT [PTC]
  # -------------------------
  Read [PTC]CTA0=this.APARENT.TCACOD
  If [F:PTC]TCAMOD = 1 Then
    If this.APARENT.TASSTARTDT <> [0/0/0] Then
      this.OPESTR = this.APARENT.TASSTARTDT
    Endif
    If this.APARENT.TASENDDT <> AVOID.ADATE Then
      this.OPEEND = this.APARENT.TASENDDT
    Endif
  Endif
Return

###################################################################################################
$RTKO_ADELLINE_BEFORE
Local Integer NI
Local Integer NE

  [L]ASTATUS = [V]CST_AOK
  # -------------------------
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------------
  If fmet this.RTKO([L]ALINE).RAFFT_COUNT() > 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(426,2260,1), [V]CST_AERROR))
  Endif
  # -------------------------
  Local File PJMTIMEMP [PTE]
  # -------------------------
  Filter [PTE] Where [F:PTE]PIMTASCOD = this.PIMPL.PIMNUM and [F:PTE]OPENUM = this.RTKO([L]ALINE).OPENUM and [F:PTE]OPESPLNUM = this.RTKO([L]ALINE).OPESPLNUM
  For [PTE]
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(300,2260,1), [V]CST_AERROR))
    Break
  Next
  Filter [PTE]
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RTKO(NI) <> this.RTKO([L]ALINE) Then
        For NE = 1 To maxtab(this.RTKO(NI).OPLNK)
          If this.RTKO(NI).OPLNK(NE) <> null and find(this.RTKO(NI).OPLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.RTKO(NI).OPLNK(NE).OPENUMLNK = this.RTKO([L]ALINE).OPENUM and this.RTKO(NI).OPLNK(NE).OPESPNUMLNK = this.RTKO([L]ALINE).OPESPLNUM Then
              [L]ASTATUS = max([L]ASTATUS, fmet this.RTKO([L]ALINE).SETERROR("OPENUM", mess(954,2260,1), [V]CST_AERROR))
              Break
            Endif
          Endif
        Next NE
      Endif
    Endif
  Next NI
Return

###################################################################################################
$RTKO_AINSERT_CONTROL_BEFORE
  Gosub RTKO_AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$RTKO_AUPDATE_CONTROL_BEFORE
Local Integer ILINE
Local Integer ICURLINE
Local Integer IEXIT
Local Integer IUPDATE

  If this.APARENT.TASSTATE = 4 and this.APARENT.TCHACTION <> "CLOSING" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.APARENT.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  # -------------------------
  Gosub RTKO_AINSERT_AUPDATE_CONTROL_BEFORE
  # -------------------------
Return

###################################################################################################
$RTKO_AINSERT_AUPDATE_CONTROL_BEFORE
  If this.ROODESAXX = AVOID.ACHAR Then
    this.ROODESAXX = this.APARENT.PIMPL.PIMDESAXX
  Endif
Return

###################################################################################################
# RTKO.OPLNK
###################################################################################################
$RTKO_OPLNK_ACONTROL
Local Integer ILINELNK
Local Integer NI
Local Integer ITYP
Local Char STYP(GLONDES)(1..)
Local Char SVAL(GLONAUS+GLONWST)(1..)
Local Integer IOFFSET
Local Integer ITODO

  [L]ASTATUS = [V]CST_AOK
  If this.APARENT.OPESTR <> AVOID.ADATE and this.APARENT.OPEEND <> AVOID.ADATE Then
    ILINELNK = fmet this.APARENT.APARENT.RTKO_GET_INDEX(this.OPENUMLNK, this.OPESPNUMLNK)
    If ILINELNK = 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUMLNK", mess(268,2260,1), [V]CST_AERROR))
      Return
    Endif
    # ---------------------------------
    If this.APARENT.APARENT.RTKO(ILINELNK).OPESTR <> AVOID.ADATE and this.APARENT.APARENT.RTKO(ILINELNK).OPEEND <> AVOID.ADATE Then
      ITYP = 0
      ITYP += 1
      STYP(ITYP) = "WST"
      SVAL(ITYP) = this.APARENT.APARENT.RTKO(ILINELNK).EXTWST
      If this.APARENT.APARENT.RTKO(ILINELNK).EXTLAB <> AVOID.ACHAR Then
        ITYP += 1
        STYP(ITYP) = "WST"
        SVAL(ITYP) = this.APARENT.APARENT.RTKO(ILINELNK).EXTLAB
      Endif
      Case this.OPELNKTYP
        When 1
          # End to start
          ITODO = 1
          IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.APARENT.TASFCY, STYP, SVAL,
&                                                              this.APARENT.APARENT.RTKO(ILINELNK).OPEEND, AVOID.ACHAR, this.OPELNKLAG, ITODO,
&                                                              IOFFSET)
          [L]ASTATUS = max([L]ASTATUS, IRET)
        When 2
          # Start to start
          If this.OPELNKLAG > 0 Then
            ITODO = 1
          Else
            ITODO = 2
          Endif
          IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.APARENT.TASFCY, STYP, SVAL,
&                                                              this.APARENT.APARENT.RTKO(ILINELNK).OPESTR, AVOID.ACHAR, this.OPELNKLAG, ITODO,
&                                                              IOFFSET)
          [L]ASTATUS = max([L]ASTATUS, IRET)
        When 3
          # End to end
          If this.OPELNKLAG > 0 Then
            ITODO = 1
          Else
            ITODO = 2
          Endif
          IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.APARENT.TASFCY, STYP, SVAL,
&                                                              this.APARENT.APARENT.RTKO(ILINELNK).OPEEND, AVOID.ACHAR, this.OPELNKLAG, ITODO,
&                                                              IOFFSET)
          [L]ASTATUS = max([L]ASTATUS, IRET)
        When 4
          # Start to end
          If this.OPELNKLAG > 0 Then
            ITODO = 1
          Else
            ITODO = 2
          Endif
          IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.APARENT.TASFCY, STYP, SVAL,
&                                                              this.APARENT.APARENT.RTKO(ILINELNK).OPESTR, AVOID.ACHAR, this.OPELNKLAG, ITODO,
&                                                              IOFFSET)
          [L]ASTATUS = max([L]ASTATUS, IRET)
      Endcase
      # -------------------------
      If IRET < [V]CST_AERROR Then
        Case this.OPELNKTYP
          When 1
            # End to start
            If this.APARENT.OPESTR <= this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET Then
              Case this.OPELNKCSTR
                When 1
                  # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.OPESTR <> this.APARENT.snapshot.OPESTR
&                      or this.OPELNKLAG <> this.snapshot.OPELNKLAG
&                      or this.APARENT.APARENT.RTKO(ILINELNK).OPEEND <> this.APARENT.APARENT.RTKO(ILINELNK).snapshot.OPEEND
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(929,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                         func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                  Endif
                When 2
                  # Strict
                  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(928,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                     func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET)),
&                                                                 [V]CST_AERROR))
              Endcase
            Endif
          When 2
            # Start to start
            If this.APARENT.OPESTR < this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET Then
              Case this.OPELNKCSTR
                When 1
                  # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.OPESTR <> this.APARENT.snapshot.OPESTR
&                      or this.OPELNKLAG <> this.snapshot.OPELNKLAG
&                      or this.APARENT.APARENT.RTKO(ILINELNK).OPESTR <> this.APARENT.APARENT.RTKO(ILINELNK).snapshot.OPESTR
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(931,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                         func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                  Endif
                When 2
                  # Strict
                  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(930,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                     func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET)),
&                                                                 [V]CST_AERROR))
              Endcase
            Endif
          When 3
            # End to end
            If this.APARENT.OPEEND < this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET Then
              Case this.OPELNKCSTR
                When 1
                  # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.OPEEND <> this.APARENT.snapshot.OPEEND
&                      or this.OPELNKLAG <> this.snapshot.OPELNKLAG
&                      or this.APARENT.APARENT.RTKO(ILINELNK).OPEEND <> this.APARENT.APARENT.RTKO(ILINELNK).snapshot.OPEEND
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(927,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                  Endif
                When 2
                  # Strict
                  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(926,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                     func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPEEND + IOFFSET)),
&                                                                 [V]CST_AERROR))
              Endcase
            Endif
          When 4
            # Start to end
            If this.APARENT.OPEEND < this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET Then
              Case this.OPELNKCSTR
                When 1
                  # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.OPEEND <> this.APARENT.snapshot.OPEEND
&                      or this.OPELNKLAG <> this.snapshot.OPELNKLAG
&                      or this.APARENT.APARENT.RTKO(ILINELNK).OPESTR <> this.APARENT.APARENT.RTKO(ILINELNK).snapshot.OPESTR
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(933,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                  Endif
                When 2
                  # Strict
                  [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(932,2260,1), num$(this.APARENT.OPENUM), num$(this.APARENT.APARENT.RTKO(ILINELNK).OPENUM)) + "\" +
&                                                                     func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.RTKO(ILINELNK).OPESTR + IOFFSET)),
&                                                                 [V]CST_AERROR))
              Endcase
            Endif
        Endcase
      Endif
    Endif
  Endif
Return

###################################################################################################
# PIMPL
###################################################################################################
$PIMPL_ACONTROL
Local Integer IPYMTYP

  IPIMTYP = fmet this.APARENT.GET_PIMTYP_FROM_TCACOD(this.APARENT.TCACOD)
  If this.PIMTYP <> IPIMTYP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTYP", mess(205,2260,1) - "(" + mess(this.PIMTYP,2254,1) + ")", [V]CST_AERROR))
  Endif
  If this.TASSTATE <> this.APARENT.TASSTATE Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTATE", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.PBUCOD <> this.APARENT.PBUCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.FCY <> this.APARENT.TASFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
# SPLD
###################################################################################################
$SPLD_ACONTROL
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.OPPCMP <> this.APARENT.OPPCMP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.PBUCOD <> this.APARENT.PBUCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASCOD <> this.APARENT.TASCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.STOFCY <> this.APARENT.TASFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$SPLD_ADDLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$SPLD_ADDLINE_AFTER
  this.PBUCOD = this.APARENT.PBUCOD
  this.CUR = this.APARENT.CUR
  this.OPPCMP = this.APARENT.OPPCMP
  this.STOFCY = this.APARENT.TASFCY
Return

###################################################################################################
$SPLD_ADELLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.SPLD([L]ALINE).PSONUM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(196,143,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
# PTLNK
###################################################################################################
$PTLNK_ACONTROL
Local Integer NI
Local Char SOPPNUM(GLONOPP)
Local Char STASCOD(GLONTAC)
Local Char SPBUCOD(GLONPBU)

  If this.OPPNUM <> this.APARENT.OPPNUM Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASCOD <> this.APARENT.TASCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  For NI = 1 To maxtab(this.APARENT.PTLNK)
    If this.APARENT.PTLNK(NI) <> null and find(this.APARENT.PTLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.PTLNK(NI) <> this Then
        If this.APARENT.PTLNK(NI).PIMOPPTASLNK = this.PIMOPPTASLNK Then
          If this.APARENT.PTLNK(NI).TASLNKTYP = this.TASLNKTYP Then
            IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.PIMOPPTASLNK, SOPPNUM, SPBUCOD, STASCOD)
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASLNKTYP", func AFNC.MES3(mess(979,2260,1), SOPPNUM, STASCOD, mess(this.TASLNKTYP,7723,1)), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$PTLNK_ADDLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PTLNK_ADELLINE_BEFORE
  If this.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PTLNK_AUPDATE_CONTROL_BEFORE
  If this.APARENT.TASSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.APARENT.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
Return

