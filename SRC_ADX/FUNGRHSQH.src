#<AdxTL>@(#)9.0.0.0 $Revision$
#####################################################################################
#                                       Module Ventes - Decembre 2006               #
#                                                                                   #
#                 CONSULTATIONS GRAPHIQUES DEVIS                                    #
#                                                                                   #
#####################################################################################
#                                                                                   #
#                                                                                   #
#            Devis par période                                                      #
#            -----------------                                                      #
# GACTION  : TRTGRHSQH1 : Sélections                                                #
#            (Fenêtre : DGRHSQH1)                                                   #     
#            (Ecran   : SGRHSQH1 DIA)                                               #
#            VISUGRHSQ1 : HT Devis                                                  #
#            (Fenêtre : IGRHSQH1)                                                   #     
#            (Ecran   : SGQ1    SGQ1)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par période=1)                       #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Devis par représentant                                                 #
#            ----------------------                                                 #
# GACTION  : TRTGRHSQH3 : Sélections                                                #
#            (Fenêtre : DGRHSQH3)                                                   #     
#            (Ecran   : SGRHSQH3 DIA)                                               #
#            VISUGRHSQ3 : Devis par représentant                                    #
#            (Fenêtre : IGRHSQH3)                                                   #     
#            (Ecran   : SGQ3    SGQ3)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par représentant=2)                  #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Palmarès Devis                                                         #
#            --------------                                                         #
# GACTION  : TRTGRHSQH2 : Sélections                                                #
#            (Fenêtre : DGRHSQH2)                                                   #     
#            (Ecran   : SGRHSQH2 DIA)                                               #
#            VISUGRHSQ2 : Palmarès                                                  #
#            (Fenêtre : IGRHSQH2)                                                   #     
#            (Ecran   : SGQ2    SGQ2)                                               #
#            (Param ABREV   : Abrév du masque contenant les critères)               #
#            (Param TYPTIERS: Type de graphique (palmarès clt=1 ou représentant=2)  #
#            (Param DATDEB  : Date début)                                           #
#            (Param DATFIN  : Date fin)                                             #
#                                                                                   #
#                                                                                   #
#####################################################################################
# Prérequis VISUGRHSQ1 et 2 : Le masque contenant les critères doit être ouvert     #
#####################################################################################
#####################################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION  
            When "TRTGRHSQH1"  :  Gosub OUVRE_TRTGRHSQH
            When "VISUGRHSQ1"  :  Gosub OUVRE_VISUGRHSQ1
            When "TRTGRHSQH3"  :  Gosub OUVRE_TRTGRHSQH
            When "VISUGRHSQ3"  :  Gosub OUVRE_VISUGRHSQ1
            When "TRTGRHSQH2"  :  Gosub OUVRE_TRTGRHSQH
            When "VISUGRHSQ2"  :  Gosub OUVRE_VISUGRHSQ2
        Endcase
    When "DEBUT"          : 
        Case GACTION 
            When "TRTGRHSQH1"  :  Gosub DEBUT_TRTGRHSQH1
            When "TRTGRHSQH3"  :  Gosub DEBUT_TRTGRHSQH1
            When "VISUGRHSQ1"  :  Gosub DEBUT_VISUGRHSQ1
            When "VISUGRHSQ3"  :  Gosub DEBUT_VISUGRHSQ1
            When "TRTGRHSQH2"  :  Gosub DEBUT_TRTGRHSQH2
            When "VISUGRHSQ2"  :  Gosub DEBUT_VISUGRHSQ2
        Endcase
    When "TITRE"
        Case GACTION
            When "VISUGRHSQ1"  :  Gosub TIT_VISUGRHSQ1
            When "VISUGRHSQ3"  :  Gosub TIT_VISUGRHSQ1
            When "VISUGRHSQ2"  :  Gosub TIT_VISUGRHSQ2
        Endcase
    When "SETBOUT"          : 
        Case GACTION 
            When "TRTGRHSQH2"  :  Gosub SETB_TRTGRHSQH2
        Endcase
    When "BOUTON" 
        Case GACTION 
            When "TRTGRHSQH2"  :  Gosub BOUT_TRTGRHSQH2
            When "VISUGRHSQ1"  :  Gosub BOUT_VISUGRHSQ1
            When "VISUGRHSQ3"  :  Gosub BOUT_VISUGRHSQ1
            When "VISUGRHSQ2"  :  Gosub BOUT_VISUGRHSQ2
        Endcase
    When "FIN" 
        Case GACTION 
            When "VISUGRHSQ1"  :  Gosub FIN_VISUGRHSQ1
            When "VISUGRHSQ2"  :  Gosub FIN_VISUGRHSQ2
        Endcase
    When "OK" 
        Case GACTION 
            When "TRTGRHSQH1"  :  Gosub OK_TRTGRHSQH
            When "TRTGRHSQH3"  :  Gosub OK_TRTGRHSQH
        Endcase
    When Default
Endcase
Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSQH1,TRTGRHSQH3            #
#                                TRTGRHSQH2                       #                    
#                                                                 #
###################################################################
###################################################################
$OUVRE_TRTGRHSQH

Gosub OUVRE

Return
###################################################################
###################################################################
$OUVRE

If clalev([F:SQH])=0 Local File SQUOTE     [SQH]  : Endif
If clalev([F:SQD])=0 Local File SQUOTED    [SQD]  : Endif
If clalev([F:BPC])=0 Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:CPY])=0 Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU]  : Endif
If clalev([F:PER])=0 Local File PERIOD     [PER]  : Endif
If clalev([F:ACN])=0 Local File ACONSULT   [ACN]  : Endif

Return
###################################################################
$DEBUT

[M]SALFCY=GFCYDEF(5)
If [M]SALFCY <> "" : # Parametre Site
    If [F:FCY]FCY <> [M]SALFCY  Read [F:FCY]FCY0 = [M]SALFCY
                                If fstat Raz [F:FCY], [M]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M]SALFCY <> ""
             Call GETDEV([M]SALFCY) From DEVSUB
             [M]CPY  = GSOCIETE
        Endif
    Endif
Endif

Return
###################################################################
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSQH1 TRTGRHSQH3            #
#                                                                 #
#                    HT par période et par représentant           #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSQH1

Raz [M:DIA]

If dim([M]PERCOD)>0
    [M]PERCOD=4         : # Init. de la périodicité au mois
    [M]PERNBR=3         : # Init. du nombre de période à 3
Endif
[M]QUODATFIN=eomonth(date$)
[M]QUODATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

If !find([M:DIA]VLYSTAN,1,2) : [M:DIA]VLYSTAN= 2 : ENDIF
If !find([M:DIA]VLYSTAO,1,2) : [M:DIA]VLYSTAO= 2 : ENDIF
If !find([M:DIA]QUOSTAN,1,2) : [M:DIA]QUOSTAN= 2 : Endif
If !find([M:DIA]QUOSTAO,1,2) : [M:DIA]QUOSTAO= 2 : Endif
If !find([M:DIA]APPFLGN,1,2) : [M:DIA]APPFLGN= 2 : Endif
If !find([M:DIA]APPFLGO,1,2) : [M:DIA]APPFLGO= 2 : Endif

Gosub DEBUT

If GACTION="TRTGRHSQH1"
    Call LECMEMO ("STD","[M:DIA]","vg1") From GMEMO
Else
    Call LECMEMO ("STD","[M:DIA]","vg9") From GMEMO
Endif

Affzo [DIA]1-99

Return
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$OK_TRTGRHSQH
Affzo [M:DIA]1-99 
FIN=0
Return

###################################################################
#                                                                 #
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSQH2                       #
#                                                                 #
#                    Palmarès HT commandé client et représentant  #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSQH2

Raz [M:DIA]

[M]QUODATFIN=eomonth(date$)
[M]QUODATDEB=gdat$(01,month(addmonth(date$,-5)),year(addmonth(date$,-5)))

If !find([M:DIA]VLYSTAN,1,2) : [M:DIA]VLYSTAN=2 : Endif  : # On prend les devis valides
If !find([M:DIA]VLYSTAO,1,2) : [M:DIA]VLYSTAO=2 : Endif  : # On prend les devis non valides
If !find([M:DIA]QUOSTAN,1,2) : [M:DIA]QUOSTAN=1 : Endif  : # On ne prend pas les devis non commandés
If !find([M:DIA]QUOSTAO,1,2) : [M:DIA]QUOSTAO=2 : Endif  : # On prend les devis commandés
If !find([M:DIA]APPFLGN,1,2) : [M:DIA]APPFLGN=2 : Endif  : # On prend les devis signés 
If !find([M:DIA]APPFLGO,1,2) : [M:DIA]APPFLGO=2 : Endif  : # On prend les devis non signés 

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg2") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
$SETB_TRTGRHSQH2

# Pas de palmarès client si la consultation n'est pas multi-client
If [M:DIA]BPCORD<>"" ETABOU(GSPE4) = 0 : Endif

# Pas de palmarès représentant si la consultation n'est pas multi-client ou si les représentants ne sont pas gérés
If [M:DIA]BPCORD<>"" 
    ETABOU(GSPE5) = 0 
Else
    If func AFNC.ACTIV("REP")<1 
        ETABOU(GSPE5) = 0
    Endif
Endif

Return
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$BOUT_TRTGRHSQH2

Case BOUT
    When "1", "2" : 
        Affzo [M:DIA]1-99 
Endcase

Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSQ1                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSQ1

Local Integer  WSAVPERCOD, WPERCOD : # Périodicité 1=jour,2=Semaine,3=Quinz.,4=Mois,5=Trimestre,6=Semestre,7=Année,8=Décade
Local Date     WSAVDATDEB, WDATDEB : # Date début
Local Date     WSAVDATFIN, WDATFIN : # Date fin
Local Integer  WSAVPERNBR, WPERNBR : # Nombre de période

Local Char     WCURS(GLONCUR)    : # Devise société
Local Char     WCURD(GLONCUR)    : # Devise dossier

Local Char     WPROGSPE(GLONADC) : # Nom du programme spécifique
Local Integer  WOK

# Variables communes avec la consultation devis
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSQ")
# -- > "DIA"  : On vient de la fonction graphique montant HT devis
# -- > "CCSQ" : On vient de la consultation devis
Local Char    WABREV : WABREV=PARAM(1)
# Type de graphique
# -- > 1 : Montant HT par période 
# -- > 2 : Montant HT par représentant
Local Integer WTYP : WTYP=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations devis
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSQ"
   If !clalev([M:CSQ1])  Local Mask CONSCSQ1 [CSQ1] : Endif
   If !clalev([M:CCSQ])  Local Mask CRITCSQ  [CCSQ] : Endif
Endif

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #
If evalue("dim([M:"+WABREV+"]PERCOD)")>0
    WPERCOD=evalue("[M:"+WABREV+"]PERCOD")
    WSAVPERCOD=WPERCOD
Else
    WPERCOD=4
Endif
If evalue("dim([M:"+WABREV+"]QUODATDEB)")>0
    WDATDEB=evalue("[M:"+WABREV+"]QUODATDEB")
    WSAVDATDEB=WDATDEB
    WDATDEB=gdat$(01,month(WDATDEB),year(WDATDEB))
Else
    WDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
If evalue("dim([M:"+WABREV+"]QUODATFIN)")>0
    WDATFIN=evalue("[M:"+WABREV+"]QUODATFIN")
    WSAVDATFIN=WDATFIN
    WDATFIN=eomonth(WDATFIN)
Else
    WDATFIN=eomonth(date$)
Endif

If evalue("dim([M:"+WABREV+"]PERNBR)")>0
    WPERNBR=evalue("[M:"+WABREV+"]PERNBR")
    WSAVPERNBR=WPERNBR
Else
#    WPERNBR=3
    If year(WDATFIN)=year(WDATDEB)
        WPERNBR=month(WDATFIN)-month(WDATDEB)+1
    Else
        WPERNBR=13-month(WDATDEB)+month(WDATFIN)
    Endif
    WPERNBR=max(1,WPERNBR)
Endif

Gosub CHARGE_CCSQ

Return
###################################################################
$TIT_VISUGRHSQ1
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYP=1 
    TIT=mess(274,195,1) 
    If [M:CCSQ]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSQ]BPCORD Endif
Else 
    TIT=mess(275,195,1) 
    If [M:CCSQ]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSQ]BPCORD Endif
Endif

Return

###################################################################
$DEBUT_VISUGRHSQ1

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #

Raz [M]
[M]CPY=[M:CCSQ]CPY
If WTYP=1 
    [M]PERCOD=WPERCOD
    [M]PERNBR=WPERNBR
Endif
[M]QUODATDEB=WDATDEB
[M]QUODATFIN=WDATFIN
[M]CURS=WCURS
[M]WTYP=WTYP

# Si la société est renseignée, le cdé HT est dans la devise société sinon il est en devise dossier
If [M:CCSQ]CPY<>"" [M]CUR=[M]CURS Else [M]CUR=GSYSCUR Endif

# -- Chargement des périodes
Effzo [M]10
If WTYP=1 Gosub CHARGE_PERIODE_SGQ1 Endif

[M:CCSQ]QUODATDEB=[M]QUODATDEB
[M:CCSQ]QUODATFIN=[M]QUODATFIN
Gosub ENTCRIT From WWCNSCSQ    : # Charge [M:CSQ1] à partir de [M:CCSQ]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSQSTD
# -- HT / Représentant 
# --> Il faut que le représentant 1 soit renseigné
If WTYP=2 WFIL += "&[F:SQH]REP(0)<>''" Endif
If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGQ1]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M]WFIL =WFIL    
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGQ1

Affzo [M]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSQ1

Case BOUT
    When "R" : 
        # -- Rechargement du tableau
        # -- Chargement des périodes
        Effzo [M]10
        If [M]WTYP=1 Gosub CHARGE_PERIODE_SGQ1 Endif
        [M:CCSQ]QUODATDEB=[M]QUODATDEB
        [M:CCSQ]QUODATFIN=[M]QUODATFIN
        Gosub ENTCRIT From WWCNSCSQ    : # Charge [M:CSQ1] à partir de [M:CCSQ]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGQ1
        Affzo [M]10
Endcase

Return
###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSQ1
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
PARAM(5)=num$(WSAVPERCOD)
PARAM(6)=num$(WSAVPERNBR)
Return

###################################################################
# -------------------------------------- #
# Chargement des périodes                #
# -------------------------------------- #
$CHARGE_PERIODE_SGQ1
Local Date    WDTE
Local Integer WPER, WMOIS
Local Char    WLIB
Local Integer I,WCOUNT

Effzo [M:SGQ1]10

WDTE=[M]QUODATDEB
WPER=[M]PERCOD
For I = 0 To [M:SGQ1]PERNBR-1                           
    If I > dim([M]WABS) - 1 : Break Endif 
    WCOUNT+=1
   [M:SGQ1]WSTRDAT(I) = WDTE
    Gosub DET_PER_LIB From TRTVENGRH : [M]WABS(I)=WLIB
    Case [M:SGQ1]PERCOD
        When 1 :  [M:SGQ1]WENDDAT(I) = WDTE                                 : # jour
        When 2 :  [M:SGQ1]WENDDAT(I) = WDTE + (7-dayn(WDTE))                : # Semaine
        When 3 :                                                            : # Quinzaine
        When 4 : [M:SGQ1]WENDDAT(I) = eomonth([M:SGQ1]WSTRDAT(I))           : # Mois
        When 5 : WMOIS=month([M:SGQ1]WSTRDAT(I))                            : # Trimestre      
                 Case WMOIS
                    When 1,2,3    : [M:SGQ1]WENDDAT(I)=gdat$(31,03,year([M:SGQ1]WSTRDAT(I)))
                    When 4,5,6    : [M:SGQ1]WENDDAT(I)=gdat$(30,06,year([M:SGQ1]WSTRDAT(I)))
                    When 7,8,9    : [M:SGQ1]WENDDAT(I)=gdat$(30,09,year([M:SGQ1]WSTRDAT(I)))
                    When 10,11,12 : [M:SGQ1]WENDDAT(I)=gdat$(31,12,year([M:SGQ1]WSTRDAT(I)))                                 
                 Endcase
        When 6 : WMOIS=month([M:SGQ1]WSTRDAT(I))                            : # Semestre
                 Case WMOIS
                    When 1,2,3,4,5,6    : [M:SGQ1]WENDDAT(I)=gdat$(30,06,year([M:SGQ1]WSTRDAT(I)))
                    When 7,8,9,10,11,12 : [M:SGQ1]WENDDAT(I)=gdat$(31,12,year([M:SGQ1]WSTRDAT(I)))                                
                 Endcase
        When 7 : [M:SGQ1]WENDDAT(I) = gdat$(31,12,year([M:SGQ1]WSTRDAT(I))) : # Année
        When 8 :                                                            : # Décade
    Endcase
    WDTE = [M:SGQ1]WENDDAT(I) + 1
Next I
##[M:SGQ1]NBLIGG=[M:SGQ1]PERNBR
[M:SGQ1]NBLIGG=WCOUNT
Return


# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGQ1

Local Decimal WORDAMT,WNORDAMT,WEXYAMT
Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

#-- Application des Filtres
Case [M]WTYP
    When 1 :  # Par période
        Filter [SQH] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2) 
    When 2 :  # Par représentant
        Filter [SQH] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2) 
&                    Order By Key CLE=[F:SQH]REP(0)
Endcase
#-- lecture 
$BOUCLE_SQH1
For [SQH] With Nohint

    # Filtre sur la société
    If [M]CPY <> "" 
        If [F:FCY]FCY <> [F:SQH]SALFCY  Read [F:FCY]FCY0 = [F:SQH]SALFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSQ]CPY Goto SUIV_SQH1 : Endif
    Endif
    If [M]CPY="" & [M:CCSQ]SALFCY="" 
        Call GETDEV([F:SQH]SALFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M]CURS
    Endif
    Raz WEXYAMT, WNORDAMT, WORDAMT
    # Devis expiré : Devis non cdé dt la date de validité est expirée
    If [F:SQH]QUOSTA=1 & [F:SQH]VLYDAT<>[0/0/0] & [F:SQH]VLYDAT<date$
      WEXYAMT  = [F:SQH]QUOINVNOT
    # Devis non cdé
    Elsif [F:SQH]QUOSTA=1
      WNORDAMT = [F:SQH]QUOINVNOT
    # Devis cdé
    Elsif [F:SQH]QUOSTA=3
      WORDAMT  = [F:SQH]QUOINVNOT
    Else
    # Devis partiellement cdé
      Local Decimal WMNTCALC
      For [F:SQD]SQD0 Where SQHNUM=[F:SQH]SQHNUM & ORDQTY<>0
          WMNTCALC+= [F:SQD]ORDQTY * [F:SQD]NETPRINOT
      Next
      Call ARRDEV (WMNTCALC, [F:SQH]CUR) From TRTDIV
      # On ne prend en compte la partie cdée que si on a demandé les devis cdés
      If [M:CCSQ]QUOSTAO = 2 WORDAMT  = WMNTCALC Endif
      # On ne prend en compte la partie non cdée que si on a demandé les devis non cdés
      If [M:CCSQ]QUOSTAN = 2 WNORDAMT = [F:SQH]QUONOT-WMNTCALC Endif
    Endif

    Case [M]WTYP
        When 1 :
            # Recherche de la période à laquelle appartient le devis
            For WJ=0 To [M]NBLIGG-1
                If [F:SQH]QUODAT>=[M]WSTRDAT(WJ) & [F:SQH]QUODAT<=[M]WENDDAT(WJ) Break Endif
            Next
        When 2 :
            # Recherche du représentant dans la liste des représentants déjà chargés dans le graphe
            WJ=find ([F:SQH]REP(0), [M]WABS(0..[M]NBLIGG-1))
            If WJ=0 & [M]NBLIGG<dim([M]WABS) 
                # Le réprésentant n'est pas encore dans le graphe : On le charge
                [M]NBLIGG+=1 
                WJ=[M]NBLIGG : [M]WABS(WJ-1)=[F:SQH]REP(0)                
            Elsif WJ=0 
                # Le tableau est plein : On ne peut plus charger de nvx réprésentants 
                Break 
            Endif
            WJ-=1
    Endcase
    If WJ<[M]NBLIGG & WJ>=0
        # Conversion des montants calculés dans la devise d'affichage
        If [F:SQH]CUR <> [M]CUR
            WMNTORG (0) = WORDAMT
            WMNTORG (1) = WNORDAMT
            WMNTORG (2) = WEXYAMT
            Call CONVERT2([F:SQH]CUR, [M]CUR, WCUR, [F:SQH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
            Call CONVERT2([F:SQH]CUR, [M]CUR, WCUR, [F:SQH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
            Call CONVERT2([F:SQH]CUR, [M]CUR, WCUR, [F:SQH]CHGTYP, datesyst, WMNTORG(2), WMNTDES(2),SPSTAT) From TRTDEV
            If [F:TCU]CUR <> [M]CUR
                Read [F:TCU]TCU0 = [M]CUR
                If fstat Raz [F:TCU] : Endif
            Endif
            [M]WORDAMT(WJ)  += arr(WMNTDES(0),[F:TCU]CURRND)
            [M]WNORDAMT(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
            [M]WEXYAMT(WJ)  += arr(WMNTDES(2),[F:TCU]CURRND)
        Else
            [M]WORDAMT(WJ)  += WORDAMT
            [M]WNORDAMT(WJ) += WNORDAMT
            [M]WEXYAMT(WJ)  += WEXYAMT
        Endif
    Endif

  $SUIV_SQH1
Next
Filter [SQH]

Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSQ2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSQ2

Local Date    WSAVDATDEB            :    # Date début
Local Date    WSAVDATFIN            :    # Date fin

Local Char    WCURS(GLONCUR)        :    # Devise société
Local Char    WCURD(GLONCUR)        :    # Devise dossier

Local Char    WPROGSPE(GLONADC)     :    # Nom du programme spécifique
Local Integer WOK

# Variables communes avec la consultation devis
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSQ")
# -- > "DIA"  : On vient de la fonction graphique montant HT devis
# -- > "CCSQ" : On vient de la consultation devis
Local Char WABREV : WABREV=PARAM(1)
# -- > 1 : Palmarès client 
# -- > 2 : Palmarès représentant
Local Integer WTYPTIERS : WTYPTIERS=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations devis
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSQ"
   If !clalev([M:CSQ1])  Local Mask CONSCSQ1 [CSQ1] : Endif
   If !clalev([M:CCSQ])  Local Mask CRITCSQ  [CCSQ] : Endif
Endif

WSAVDATDEB=evalue("[M:"+WABREV+"]QUODATDEB")
WSAVDATFIN=evalue("[M:"+WABREV+"]QUODATFIN")

Return
###################################################################
$TIT_VISUGRHSQ2
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYPTIERS=1 TIT=mess(270,195,1) Else TIT=mess(271,195,1) Endif

Return

###################################################################
$DEBUT_VISUGRHSQ2

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #
Gosub CHARGE_CCSQ

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M:SGQ2]
[M:SGQ2]CPY=[M:CCSQ]CPY
[M:SGQ2]QUODATDEB=[M:CCSQ]QUODATDEB
[M:SGQ2]QUODATFIN=[M:CCSQ]QUODATFIN
[M:SGQ2]CURS=WCURS
[M:SGQ2]WTYPTIERS=WTYPTIERS

[M:SGQ2]NBRTOP=10

# Si la société est renseignée, le cdé HT est dans la devise société sinon il est en devise dossier
If [M:CCSQ]CPY<>"" [M:SGQ2]CUR=[M:SGQ2]CURS Else [M:SGQ2]CUR=GSYSCUR Endif

Gosub ENTCRIT From WWCNSCSQ    : # Charge [M:CSQ1] à partir de [M:CCSQ]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSQSTD
# -- Palmarès représentant
# --> Il faut que le représentant 1 soit renseigné
If WTYPTIERS=2 WFIL += "&[F:SQH]REP(0)<>''" Endif

If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGQ2]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M:SGQ2]WFIL =WFIL    
[M:SGQ2]WFIL1=WFIL1
[M:SGQ2]WFIL2=WFIL2

# -- Chargement des données
Gosub CHARGE_DONNEES_SGQ2

Affzo [M:SGQ2]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSQ2

Case BOUT
    When "R" : 
        # -- Chargement des données
        [M:CCSQ]QUODATDEB=[M:SGQ2]QUODATDEB
        [M:CCSQ]QUODATFIN=[M:SGQ2]QUODATFIN
        Gosub ENTCRIT From WWCNSCSQ    : # Charge [M:CSQ1] à partir de [M:CCSQ]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGQ2

        Affzo [M:SGQ2]10
Endcase

Return

###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSQ2
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
Return

###################################################################
###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGQ2

Local Decimal WORDAMT,WNORDAMT,WEXYAMT
Local Decimal WMNT
Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

Local Char    WBPR
Local Integer WTOP : WTOP=[M:SGQ2]NBRTOP

#Dbgaff 
Effzo [M:SGQ2]10
#-- Application des Filtres
Case [M:SGQ2]WTYPTIERS
    When 1 :
        Filter [SQH] Where evalue([M:SGQ2]WFIL) & evalue([M:SGQ2]WFIL1) & evalue([M:SGQ2]WFIL2) 
&                    Order By Key SQH1
    When 2 :
        Filter [SQH] Where evalue([M:SGQ2]WFIL) & evalue([M:SGQ2]WFIL1) & evalue([M:SGQ2]WFIL2) 
&                    Order By Key CLE=[F:SQH]REP(0)

Endcase
#-- lecture 
$BOUCLE_SQH2
For [SQH] With Nohint

    # Filtre sur la société
    If [M:SGQ2]CPY <> "" 
        If [F:FCY]FCY <> [F:SQH]SALFCY  Read [F:FCY]FCY0 = [F:SQH]SALFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSQ]CPY Goto SUIV_SQH2 : Endif
    Endif
    If [M:SGQ2]CPY="" & [M:CCSQ]SALFCY="" 
        Call GETDEV([F:SQH]SALFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M:SGQ2]CURS
    Endif

    If WBPR="" 
        If [M:SGQ2]WTYPTIERS=1 WBPR=[F:SQH]BPCORD Else WBPR=[F:SQH]REP(0) Endif
        Raz WORDAMT 
    Endif

    # Changement de tiers : chargement du tiers qui vient d'être traité dans le graphique
    If (WBPR<>[F:SQH]BPCORD & [M:SGQ2]WTYPTIERS=1) | (WBPR<>[F:SQH]REP(0) & [M:SGQ2]WTYPTIERS=2)
        If WORDAMT<>0 Gosub CHARGE_BPR Endif
        If [M:SGQ2]WTYPTIERS=1 WBPR=[F:SQH]BPCORD Else WBPR=[F:SQH]REP(0) Endif
        Raz WORDAMT
    Endif
    If (WBPR=[F:SQH]BPCORD & [M:SGQ2]WTYPTIERS=1) | (WBPR=[F:SQH]REP(0) & [M:SGQ2]WTYPTIERS=2)
        # Même tiers traité : On cumule le montant HT cdé
        If [F:SQH]QUOSTA=3
            # Devis totalement cdé
            WMNT=[F:SQH]QUOINVNOT 
        Elsif [M:CCSQ]QUOSTAO = 2 
            # Devis partiellement cdé
            # On ne prend en compte la partie cdée que si on a demandé les devis cdés
            Raz WMNT    
            For [F:SQD]SQD0 Where SQHNUM=[F:SQH]SQHNUM & ORDQTY<>0
                WMNT+= [F:SQD]ORDQTY * [F:SQD]NETPRINOT
            Next
            Call ARRDEV (WMNT, [F:SQH]CUR) From TRTDIV
        Endif
        # Conversion des montants calculés dans la devise d'affichage
        If [F:SQH]CUR <> [M:SGQ2]CUR
            WMNTORG (0) = WMNT
            Call CONVERT2([F:SQH]CUR, [M:SGQ2]CUR, WCUR, [F:SQH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
            If [F:TCU]CUR <> [M:SGQ2]CUR
                Read [F:TCU]TCU0 = [M:SGQ2]CUR
                If fstat Raz [F:TCU] : Endif
            Endif
            WORDAMT  += arr(WMNTDES(0),[F:TCU]CURRND)
        Else
            WORDAMT  += WMNT
        Endif
    Endif

    $SUIV_SQH2  
Next
Filter [SQH]

If WORDAMT<>0 Gosub CHARGE_BPR Endif
If [M:SGQ2]NBLIGG>0
    If [M:SGQ2]NBLIGG<WTOP 
        Sorta [M:SGQ2]NBLIGG [M:SGQ2]NBLIGG Order By [M:SGQ2]WORDAMT(indice)*-1
    Else
        [M:SGQ2]WABSBPR(WTOP)=[M:SGQ2]WABSBPR(WTOP+1)
        [M:SGQ2]WORDAMT(WTOP)=[M:SGQ2]WORDAMT(WTOP+1)      
        Raz [M:SGQ2]WABSBPR(WTOP+1), [M:SGQ2]WORDAMT(WTOP+1)
    Endif
Endif

# Une fois le chargement terminé, il faut mettre à 0 les valeurs négatives du graph 
If [M:SGQ2]NBLIGG>0
    WI=[M:SGQ2]NBLIGG
    While [M:SGQ2]WORDAMT(WI-1)<0
        Raz [M:SGQ2]WORDAMT(WI-1)
        WI-=1 : If WI=0 Break Endif
    Wend
Endif
Return

# -------------------------------------------------------------------------- #
# Chargement des valeurs du tiers (client ou représentant) dans le tableau   #
# -------------------------------------------------------------------------- #
$CHARGE_BPR
If [M:SGQ2]NBLIGG<WTOP
    # On charge les 10 premiers tiers
    [M:SGQ2]WABSBPR([M:SGQ2]NBLIGG)=WBPR
    [M:SGQ2]WORDAMT([M:SGQ2]NBLIGG)=WORDAMT      
    [M:SGQ2]NBLIGG+=1            
    If [M:SGQ2]NBLIGG=WTOP 
        Sorta [M:SGQ2]NBLIGG [M:SGQ2]NBLIGG Order By [M:SGQ2]WORDAMT(indice)*-1
    Endif
Else
#Dbgaff
    # On met le tiers qui vient d'être traité en dernière position (11ème) et on trie les 11 lignes du tableau 
    [M:SGQ2]WABSBPR(WTOP)=WBPR
    [M:SGQ2]WORDAMT(WTOP)=WORDAMT      
    Sorta WTOP+1 [M:SGQ2]NBLIGG Order By [M:SGQ2]WORDAMT(indice)*-1
    # On bascule le dernier tiers (11ème) dans la position Autres (12ème position) 
    [M:SGQ2]WABSBPR(WTOP+1)=mess(20,127,1)
    [M:SGQ2]WORDAMT(WTOP+1)+=[M:SGQ2]WORDAMT(WTOP)      
    Raz [M:SGQ2]WABSBPR(WTOP), [M:SGQ2]WORDAMT(WTOP)
    [M:SGQ2]NBLIGG=WTOP+1            
Endif        

Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSQ1                       #
#                                VISUGRHSQ2                       #                    
#                                                                 #
###################################################################
###################################################################
# -------------------------------------------------------------------------- #
# Chargement systématique des écrans consultations devis                     #
# --> Pour pouvoir exploiter l'action FILTRE spécifique                      #
# --> Pour pouvoir évaluer   les filtres depuis les actions champs           #
# -------------------------------------------------------------------------- #
$CHARGE_CCSQ

If WABREV<>"CCSQ"
   [M:CCSQ]CPY      =evalue("[M:"+WABREV+"]CPY")
   [M:CCSQ]SALFCY   =evalue("[M:"+WABREV+"]SALFCY")
   [M:CCSQ]BPCORD   =evalue("[M:"+WABREV+"]BPCORD")
   [M:CCSQ]SQHNUMDEB=evalue("[M:"+WABREV+"]SQHNUMDEB")
   [M:CCSQ]SQHNUMFIN=evalue("[M:"+WABREV+"]SQHNUMFIN")
   [M:CCSQ]QUODATDEB=evalue("[M:"+WABREV+"]QUODATDEB")
   [M:CCSQ]QUODATFIN=evalue("[M:"+WABREV+"]QUODATFIN")
   [M:CCSQ]QUOSTAO  =evalue("[M:"+WABREV+"]QUOSTAO")
   [M:CCSQ]QUOSTAN  =evalue("[M:"+WABREV+"]QUOSTAN")
   [M:CCSQ]VLYSTAO  =evalue("[M:"+WABREV+"]VLYSTAO")
   [M:CCSQ]VLYSTAN  =evalue("[M:"+WABREV+"]VLYSTAN")
   [M:CCSQ]APPFLGO  =evalue("[M:"+WABREV+"]APPFLGO")
   [M:CCSQ]APPFLGN  =evalue("[M:"+WABREV+"]APPFLGN")
Endif

If !find([M:CCSQ]VLYSTAN,1,2) : [M:CCSQ]VLYSTAN= 2 : Endif
If !find([M:CCSQ]VLYSTAO,1,2) : [M:CCSQ]VLYSTAO= 2 : Endif
If !find([M:CCSQ]QUOSTAN,1,2) : [M:CCSQ]QUOSTAN= 2 : Endif
If !find([M:CCSQ]QUOSTAO,1,2) : [M:CCSQ]QUOSTAO= 2 : Endif
If !find([M:CCSQ]APPFLGN,1,2) : [M:CCSQ]APPFLGN= 2 : Endif
If !find([M:CCSQ]APPFLGO,1,2) : [M:CCSQ]APPFLGO= 2 : Endif

# -- Récupération du nom du traitement spécifique pour pouvoir utiliser l'action FILTRE
Read [ACN] ACN0="CSQ" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

# -------------------------------------------------------------------------- #
# Analyse paramères, initialisations                                         #
# -------------------------------------------------------------------------- #
If [M:CCSQ]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CCSQ]SALFCY,GUSRFCY(1..GNBAUZ)) [M:CCSQ]SALFCY="" Endif

If [M:CCSQ]BPCORD <> "" : # Parametre Client 
    If [F:BPC]BPCNUM<>[M:CCSQ]BPCORD Read [F:BPC]BPC0 = [M:CCSQ]BPCORD
                                     If fstat Raz [F:BPC], [M:CCSQ]BPCORD Endif
    Endif
Endif

If [M:CCSQ]SALFCY <> "" : # Paramètre Site
    If [F:FCY]FCY <> [M:CCSQ]SALFCY  Read [F:FCY]FCY0 = [M:CCSQ]SALFCY
                                     If fstat Raz [F:FCY], [M:CCSQ]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M:CCSQ]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M:CCSQ]SALFCY <> ""
             Call GETDEV([M:CCSQ]SALFCY) From DEVSUB
             [M:CCSQ]CPY  = GSOCIETE
             WCURS = GLOCALDEV
        Endif
    Endif
Elsif [M:CCSQ]CPY<>""
    If [F:CPY]CPY <> [M:CCSQ]CPY  Read [F:CPY]CPY0 = [M:CCSQ]CPY
                           If fstat Raz [F:CPY], [M:CCSQ]CPY Endif
    Endif
    WCURS = [F:CPY]ACCCUR 
Endif

Return

######################################################################### 
#############################################################################
#                                                                           #
##     Etiquettes masques SGRHSQH1, SGRHSQH2                               ##
#                                                                           #
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
  GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]SALFCY = ""
  # Mail CH : 03/03/04
  #  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  #  Raz [M]CURS
#  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
  GSOCIETE="" : GLOCALDEV=""
Endif
End
###########################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Affzo ZCPY
Raz [M]SALFCY, ZSALFCY
Affzo SALFCY,ZSALFCY
If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE 
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
#    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End
########################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Affzo CPY, ZCPY
Endif
End
########################################
Subprog AM_SQHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SQHNUMFIN= VALEUR : Endif
End

######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSQH1, SGQ1                                            ##
#                                                                                    #
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSQH1) 12/12/2006 14:43:00 (LD)
######################################################################################
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Quinzaine
GMENLOC(8)=1 : # Décade
End
########################################
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR

# -- Recalcul du nbre de périodes
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo [M]PERNBR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes 
Local Date WDATE
Call CALDATPER(VALEUR,[M]PERNBR,"-",[0/0/0],[M]QUODATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]QUODATDEB=WDATE : Affzo [M]QUODATDEB
Endif
End
########################################
Subprog C_PERNBR(VALEUR)
Variable Decimal VALEUR
#If VALEUR<1 | VALEUR>24 mkstat=2 Endif
End
########################################
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR

# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"-",[0/0/0],[M]QUODATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]QUODATDEB=WDATE : Affzo [M]QUODATDEB
Endif

End
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSQH1, SGRHSQH2, SGQ2, SGQ1                            ##
#                                                                                    #
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSQH2) 19/12/2006 17:19:00 (LD)
######################################################################################
Subprog AM_QUODATDEB(VALEUR)
Variable Date    VALEUR

If dim([M]PERCOD)>0
  # -- Recalcul date fin en fonction de la périodicité et du nbre de périodes 
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]QUODATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]QUODATFIN=WDATE : Affzo [M]QUODATFIN
  Endif
  #-----
#Elsif VALEUR>[M]DATFIN
#  [M]DATFIN=VALEUR
Elsif VALEUR <> [0/0/0] 
  [M]QUODATFIN= VALEUR 
Endif

End
########################################
Subprog AM_QUODATFIN(VALEUR)
Variable Date    VALEUR

If dim([M]PERCOD)>0
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]QUODATFIN,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]QUODATDEB=WDATE : Affzo [M]QUODATDEB
  Endif
  #-----
Endif

End
###############################################################################################################
######################################################################################
#                                                                                    #
##     Etiquettes masques SGQ2                                                      ##
#                                                                                    #
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGQ2) 05/04/2007 10:56:29 (LD)
######################################################################################
Subprog C_NBRTOP(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>60
  GMESSAGE=mess(6,199,1) : mkstat=1 : End : # Valeur incorrecte !
Endif
End
######################################################################################

