#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque PHO5
##########################################################################################################
Subprog AM_REP(VALEUR)
Variable Char    VALEUR()

Local Char SZFNC
Local Integer IFNC
Local Char SZSTA
Local Integer ISTA

  SZFNC = ""
  IFNC = 0
  SZSTA = ""
  ISTA = 0
  Read [REP]REP0=VALEUR
  If !fstat Then
    Read [AUS]CODUSR=[F:REP]AUSNUM
    If !fstat Then
      Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
      If SZFNC = "" Then
        IFNC = 1
      Else
        IFNC = val(SZFNC)
      Endif
      Call PARAMUTIL("AUSCRMB", SZSTA, [F:REP]AUSNUM, "") From SUBAUS
      If SZSTA = "" Then
        ISTA = 1
      Else
        ISTA = val(SZSTA)
      Endif
      [M:PHO5]STA(nolign-1) = ISTA
      [M:PHO5]FNC(nolign-1) = IFNC
    Endif
  Endif
  [M:PHO5]REP(nolign-1) = VALEUR
  Affzo [M:PHO5]
End

##########################################################################################################
Subprog C_REP(VALEUR)
Variable Char    VALEUR()
Local Integer I

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif

Local Char SZMSNEND
Local Date DMSNEND
Local Char SZFNC
Local Integer IFNC
Local Char SZSTA
Local Integer ISTA

  SZFNC = ""
  IFNC = 0
  SZSTA = ""
  ISTA = 0
  SZMSNEND = ""
  DMSNEND = [00/00/00]
  #Vérifie si ce collaborateur n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:PHO5]REP)-1
    If I <> nolign-1 Then
      If [M:PHO5]REP(I) = VALEUR and [M:PHO5]REP(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(432,196,1) #Ce collaborateur a déjà été saisi.
        GERR = 2
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Endif
    Endif
  Next
  If GERR Then
    # FGR 02/02/2010 : X3SUIVI60986
    End
  Endif
  If VALEUR = "" Then
    mkstat = 2
  Else
    Read [REP]REP0=VALEUR
    If fstat Then
      mkstat = 2
    Else
      If [F:REP]AUSNUM = "" Then
        GMESSAGE = mess(364,196,1) #Ce représentant n'est pas associé à une fiche utilisateur. Saisie refusée.
        GERR = 2
        mkstat = 2
      Else
        Read [AUS]CODUSR=[F:REP]AUSNUM
        If fstat Then
          #Les informations de status de ce représentant n'ont pu être lues. Saisie refusée.
          GMESSAGE = mess(427,196,1) 
          GERR = 2
          mkstat = 2
        Else
          Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
          If SZFNC = "" Then
            IFNC = 1
          Else
            IFNC = val(SZFNC)
          Endif
          Call PARAMUTIL("AUSCRMB", SZSTA, [F:REP]AUSNUM, "") From SUBAUS
          If SZSTA = "" Then
            ISTA = 1
          Else
            ISTA = val(SZSTA)
          Endif
          Call PARAMUTIL("AUSCRMD", SZMSNEND, [F:REP]AUSNUM, "") From SUBAUS
          If SZMSNEND = "" Then
            DMSNEND = [00/00/00]
          Else
            DMSNEND = gdat$(val(right$(SZMSNEND,7)), val(seg$(SZMSNEND,5,6)),val(left$(SZMSNEND,4)))
          Endif
          If IFNC = 2 or IFNC = 3 or IFNC = 4 Then
            If ISTA <> 1 Then
              If DMSNEND < GDMAXOPGEND Then
                #La mission du représentant expire avant la fin de la campagne d'appels. Saisie refusée.
                GMESSAGE = mess(429,196,1)
                GERR = 2
                mkstat = 2
              Endif
            Endif
          Else
            #Ce représentant n'est pas associé à une fonction commerciale. Saisie refusée.
            GMESSAGE = mess(428,196,1)
            GERR = 2
            mkstat = 2
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog IB_NBREP

  Raz GBOUT1
  If [M:PHO5]REP(nolign-1) <> "" Then
    GBOUT1 = mess(65,198,1) #Détail
  Endif
End
