#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
VALEUR = ""
PARAM(1) = nomap(0)
PARAM(2) = "1"
Call TRAITE_CHAR(VALEUR,PARAM,"EDITRTWEB","EDITRTWEB","",6,"") From GTRAITE
End

#-----------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "RAF"         : Gosub RAF
 When "NEW"         : Gosub NEW
 When "ENR"         : Gosub ENR
 When "SUP"         : Gosub SUP
 When "FIN"         : Gosub DEVERROU
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"
  Case TABLE
   When "SELTRT" : Gosub SEL_TRT
  Endcase
 When "BOUT_TABLE"
  Case TABLE
   When "SELTRT"
    Case GSTATUT
     When GSTASVG   : Gosub SVG_TRT
     When GSTAPRG   : Gosub PRG_TRT
     When GSTASRA   : Gosub SRA_TRT
    Endcase
  Endcase
  OK = 0
Endcase
Return

#------------------------------------------#
$INIT
# Issue X3-66727 - 2017-11-30 by CCC : Allow script editor only for Admin profile
If GPROFIL<>GSUPER & GADONIX<>2
 Call ERREUR(mess(145,124,1)) From GESECRAN : # Fonction réservée à l'administrateur
 FIN = 1 : Return
Endif
If clalev([M:ADC2])>0
 FIN = 1 : Return
Endif
If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif
Raz GBIDC1
Return

#------------------------------------------#
$DEBUT
Local Char    FICLCK(GDIMFIC) , CHAINE(250)
Local Integer STAT , EXECUTE
Local Char    UTIL(GLONDES) , NOM(GLONDES) , HREMOD(GLONHS)
Local Decimal TAILLE
Local Date    DATMOD
[M]CODTRT = VALEUR
[M]APPLI = PARAM(1)
EXECUTE = val(PARAM(2))
If [M]APPLI<>""
 Affzo APPLI
 If [M]CODTRT<>""
  [M]TYP="SRC" : Affzo [M]TYP
  [M]INTTYP=mess(43,115,1) : Affzo [M]INTTYP
  [M]REPERT="TRT" : Affzo [M]REPERT
  Affzo CODTRT
  Gosub LECTURE
  zonsui = "FICSRC"
 Else
  zonsui = "CODTRT"
 Endif
Endif
Return

#------------------------------------------#
$AP_CHOIX
Case REPONSE
 When GSTACLK+3
  REPONSE = 0
  Gosub VERROU
  If VERROU
   Gosub LECTURE
  Else
   Gosub QUILOCKE
  Endif
 When GSTAESC,GSTAEND
  Gosub ABORT
  If !OK : REPONSE = 0 : Endif
Endcase
Return

#------------------------#
$QUILOCKE
Local Char LCKERR(250)(1..3)
Openi FICLCK Using [LOK]
Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]
Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
# Le fichier est verrouillé par
Call ERREUR(mess(200,124,1)+"\|"+LCKERR(1)+"|\|"+LCKERR(2)+"|\|"+LCKERR(3)) From GESECRAN
Return

#------------------------------------------#
$ABORT
If [M]FICSRC<>[M]SAVSRC : REP = "M" : Endif
OK = 1
If REP="M" & GCONF(3)=1
 Call OUINON(mess(7,126,1)+"\"+mess(9,126,1),OK) From GESECRAN
 # La fiche courante a été modifiée, voulez-vous abandonner la modification
 If OK<>2 : OK = 0 : Endif
Endif
Return

#------------------------------------------#
$VERROU
#FICLCK = filpath("TRT",[M]CODTRT,"LCKsrc",[M]APPLI)
FICLCK = filpath([M]REPERT,[M]CODTRT,"LCK"+tolower([M]TYP),[M]APPLI)
If filinfo(FICLCK,0)>0
 VERROU = 0
Else
 Openo FICLCK Using [LOK]
 Iomode adxifs ""       Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GASCII   Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq format$(GFMD,date$)-"-"-time$ Using [LOK]
 Openo Using [LOK]
 VERROU = 1
Endif
Return

#------------------------------------------#
$DEVERROU
If VERROU & FICLCK<>"" & filinfo(FICLCK,0)>0
 Call EFFACE(FICLCK,STAT) From ORDSYS
 VERROU = 0
Endif
Return

#------------------------------------------#
$SETBOUT
If !VERROU | [M]CODTRT=""
 Call VIREBOUT(CHBOU,"ESN") From GOBJET : # Enregistrer/Supprimer/Nouveau
 Call VIREBOUT(CHMEN,"3") From GOBJET : # Compiler
 If [M]CODTRT=""
  Call VIREBOUT(CHMEN,"4") From GOBJET : # Exécuter
 Endif
Elsif func AVAL_TOOL.ISSCRIPTALLOWED([M]REPERT,[M]CODTRT)=[V]CST_AFALSE
 Call VIREBOUT(CHBOU,"ESN") From GOBJET : # Enregistrer/Supprimer/Nouveau
 Call VIREBOUT(CHMEN,"3") From GOBJET : # Compiler
 Call VIREBOUT(CHMEN,"4") From GOBJET : # Exécuter
Elsif REP="M"
 Call VIREBOUT(CHBOU,"S") From GOBJET
Endif
If !EXECUTE
 Call VIREBOUT(CHMEN,"4") From GOBJET
Endif
If [M]REPERT<>"TRT"
 Call VIREBOUT(CHMEN,"4") From GOBJET : # Exécuter
Endif
If !instr(1,CHBOU,"=")
 CHBOU += "="
Endif
If (!VERROU & [M]CODTRT<>"")
& | ([M]REPERT<>"" & [M]CODTRT<>"" & func AVAL_TOOL.ISSCRIPTALLOWED([M]REPERT,[M]CODTRT)=[V]CST_AFALSE)
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

#------------------------------------------#
$RAF
Gosub ABORT
If !OK : Return : Endif
Gosub LECTURE
Affzo
zonsui = "FICSRC"
Return

#------------------------------------------#
$NEW
Gosub ABORT
If !OK : Return : Endif
Gosub DEVERROU
REP = ""
Actzo CODTRT , APPLI, TYP
Effzo CODTRT , FICSRC , SAVSRC
Gosub RAZINFO
Return

#------------------------------------------#
$ENR
Call ECRIRE_TRT(OK)
If OK
 REP = ""
 Actzo CODTRT , APPLI,TYP
Endif
zonsui = "FICSRC"
Return

#------------------------------------------#
$SUP
Call EFFACE_TRT(OK)
If OK
 Gosub DEVERROU
 REP = ""
 Actzo CODTRT , APPLI,TYP
 Effzo CODTRT , FICSRC , SAVSRC
 Gosub RAZINFO
 Return
Endif
zonsui = "FICSRC"
Return

#------------------------------------------#
$BOUTON
Case BOUT
 When "3" : # Compiler
  Call ECRIRE_TRT(OK)
  If OK
   #Call VALID("TRT",[M]CODTRT,[M]APPLI,OK) From VALMSKSUB
   Local Integer STAT,TYPAGE
   Local Char MES(250)
   Call VALID_TECH([M]REPERT,[M]CODTRT,0,[M]APPLI,0,TYPAGE,STAT,MES) From AVAL_TOOL
   If MES<>""
    Call ECR_TRACE(MES,1) From GESECRAN : # Erreur
    OK=0
   Endif
  Endif
 When "4" : # Exécuter
  If !VERROU
   OK = 1
  Else
   Call ECRIRE_TRT(OK)
   If OK
    #Call VALID("TRT",[M]CODTRT,[M]APPLI,OK) From VALMSKSUB
    Local Integer STAT,TYPAGE
    Local Char MES(250)
    Call VALID_TECH([M]REPERT,[M]CODTRT,0,[M]APPLI,0,TYPAGE,STAT,MES) From AVAL_TOOL
    If MES<>""
     Call ECR_TRACE(MES,1) From GESECRAN : # Erreur
     OK=0
    Endif
   Endif
  Endif
  If OK
   GBIDC1 = [M]CODTRT
   If dim(GFUSION)>0 & GFUSION
    fstat=0
    Run =GBIDC1
    Raz GBIDC1
   Else
    FIN = 1
   Endif
   Return
  Endif
Endcase
REP = ""
Actzo CODTRT , APPLI,TYP
zonsui = "FICSRC"
Return

#------------------------------------------#
$EXEC
If GBIDC1<>"" & (dim(GFUSION)<=0 | !GFUSION)
 fstat=0
 Run =GBIDC1
Endif
Return

#------------------------------------------#
$APRES_MODIF
Case zoncou
 When "CODTRT"
  [M]CODTRT = zc
  Gosub LECTURE
  zonsui = "FICSRC"
 When "APPLI"
  [M]APPLI = zc
  If [M]CODTRT<>""
   Gosub LECTURE
   zonsui = "FICSRC"
  Else
   zonsui = "TYP"
  Endif
 When "TYP"
  [M]TYP = zc
  If [M]CODTRT<>""
    Actzo CODTRT
    Effzo CODTRT , FICSRC , SAVSRC
    Gosub RAZINFO
  Endif
  zonsui = "CODTRT"
 When "FICSRC"
  If !VERROU
   Gosub QUILOCKE
   Call LIRE_TRT(OK)
   mkstat = 2
  Else
   REP = "M"
   Grizo CODTRT , APPLI, TYP
  Endif
Endcase
Return

#------------------------------------------#
$LECTURE
Gosub DEVERROU
Gosub RAZINFO
Gosub VERROU
Call LIRE_TRT(OK)
If VERROU
 Actzo [M]FICSRC
Else
 Grizo [M]FICSRC
Endif
#If OK & [M]REPERT="TRT"
# Call INFOADX([M]CODTRT,[M]APPLI,"",UTIL,NOM,TAILLE,DATMOD,HREMOD,OK)
# If OK>=0
#  [M]PROPRIETE = mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-mess(161,124,1)-UTIL : # Modifié le par
# Endif
#Endif
If [M]REPERT="TRT"
 Read [ADC]ADC0 = [M]CODTRT
 If !fstat
  [M]DES = [F:ADC]DES
  If dim([F:ADC]TEXTE)>0 & [F:ADC]TEXTE<>""
   CHAINE = "("+[F:ADC]TEXTE+")"
  Else
   CHAINE = ""
  Endif
  Inftxt [M]DES-CHAINE At 1
  Inftxt mess([F:ADC]MODULE,14,1) At 2
 Endif
Elsif OK & [M]REPERT="STC"
  Local Char DESIG(80)
  Local Integer ER,K
  ER = 0
  Onerrgo RIEN
  DESIG = filcom("STC",CODTRT,"stc",APPLI)
  Onerrgo
  If ER
  DESIG = ""
  Endif
  K=instr(1,DESIG,"$Revision$")
  If K
   DESIG=right$(DESIG,K+len("$Revision$"))
  Endif
  [M]DES = DESIG
Endif
REP = ""
Return

#------------------------------------------#
$RAZINFO
Effzo PROPRIETE , DES
Inftxt "" At 2
Inftxt "" At 1
Return

#-----------------------------------------------------------------------------------#
$SEL_TRT
Local Char    REVERSE(10) , FILTRE(250) , REPERT(GDIMFIC) , CHAINE(250) , FILRAP(250)
Local Char    MACHINE(250) , APPLI(GLONADS) , DOSSIER(GLONADD) , ORDSYS(250)
Local Char    CODTRT(GLONADC) , DESIG(80) , CODUSR(GLONDES) , TIMMOD(10)
Local Date    DATMOD
Local Libelle MODULE
Local Char    WTRT(GLONADC)(1..GNBSEL) , WDES(GLONDES)(1..GNBSEL)
Local Char    WUSR(GLONDES)(1..GNBSEL) , WTIM(10)(1..GNBSEL)
Local Libelle WMDL(1..GNBSEL)
Local Date    WDAT(1..GNBSEL)
Local Char    TYP(3)
Local Integer NB_TRT,NB_TRT2
DOSSIER = PARAM(1)
TYP     = PARAM(2)
Local File   (Char TRT(GLONADC) , Char DES(GLONDES) , Char USR(GLONDES) , Date DAT
&           , Char TIM(10) , Libelle MDL)
&     From    Variable WTRT , WDES , WUSR , WDAT , WTIM , WMDL
&     As     [TR2]

If DOSSIER="" : DOSSIER = nomap : Endif
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
If TYP="stc"
 [L]REPERT = filpath("STC","","",APPLI,"",MACHINE)
Else
 [L]REPERT = filpath("TRT","","",APPLI,"",MACHINE)
Endif
FILTRE = 'TRT>="'+VALEUR+'"'
If DOSSIER=nomap
 Local File ADICTRT [ADC]
Else
 Local File =DOSSIER+".ADICTRT" [ADC]
Endif
FILRAP = '1=1'
SIZLIG = 100
Call  TRANSCOL("TRT",NBCOL,COL,TIT,FMTCOL) From OBJDIV
Gosub CHARGE
Default File [TR2]
START = "TRT"
Case TYP
 When "src"   : TIT = mess(43,115,1)   : # Traitement (src)
 When "stc"   : TIT = mess(8,140,1)   : # Classe (stc)
 When Default : TIT = mess(2727,200,1) : # Archive des traitements
Endcase
Return

#-----------------#
$CHARGE
Local Integer WADC,K
If TYP="stc"
 WADC=0
Else
 WADC=1
Endif

If FILTRE<>"" : FILTRE += "&" : Endif
FILTRE += 'left$(TRT,1)<>"W" & TRT<>""'
If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
Case TYP
 When "src"
  #{SAM 112322 ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REVERSE-REPERT
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REVERSE-REPERT-TYP
  #}SAM 112322 FILTRE += '& pat(TRT,"*.src")'
 When "stc"
  #{SAM 112322 ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REVERSE-REPERT
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REVERSE-REPERT-TYP
  #}SAM 112322 FILTRE += '& pat(TRT,"*.stc")'
 When Default
  # 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
  ORDSYS = MACHINE+"@"+'archive -d '+DOSSIER-REVERSE-' -t -l "*"'
Endcase
Local File (TRT(30)) From System ORDSYS As [TRT_]

If FILRAP <> "1=1"
 NB_TRT =0
 For [TRT_] Where evalue(FILTRE)
  NB_TRT +=1
 Next
 Call OUVRE_BOITE("Recherche en cours",NB_TRT) From GESECRAN : # Recherche action
 If TYP = "src"
  Call SET_BOITE(mess(43,115,1),NB_TRT) From GESECRAN : # Traitement (src)
 Elsif TYP = "stc"
  Call SET_BOITE(mess(8,140,1),NB_TRT) From GESECRAN : # classe (stc)
 Else
  Call SET_BOITE(mess(44,115,1),NB_TRT) From GESECRAN : # Traitement (adx)
 Endif
Endif
I = 0
NB_TRT =0
NB_TRT2 = 0
For [TRT_] Where evalue(FILTRE)
 NB_TRT +=1 : Call AFF_BOITE("",NB_TRT,NB_TRT2) From GESECRAN
 If TYP="stc"
 K = instr(1,[F:TRT_]TRT,".stc")
 Else
 K = instr(1,[F:TRT_]TRT,".src")
 Endif
 If K
  CODTRT = left$([F:TRT_]TRT,K-1)
 Else
  CODTRT = [F:TRT_]TRT
 Endif
 Raz CODUSR , DATMOD , TIMMOD
 If find("[F:TR2]USR",COL) or find("[F:TR2]DAT",COL) or find("[F:TR2]TIM",COL)
  Call INFOADX(CODTRT,APPLI,MACHINE,CODUSR,GBIDC1,GBIDD1,DATMOD,TIMMOD,K)
 Endif
 If WADC
  Read [ADC]ADC0 = CODTRT
  If !fstat
   DESIG = [F:ADC]DES
   MODULE = [F:ADC]MODULE
  Else
   WADC=0
  Endif
 Endif
 If !WADC
  Case TYP
   When "stc"
    ER = 0
    Onerrgo RIEN
    DESIG = filcom("STC",CODTRT,"stc",APPLI)
    Onerrgo
    If ER
    DESIG = ""
    Endif
    K=instr(1,DESIG,"$Revision$")
    If K
     DESIG=right$(DESIG,K+len("$Revision$"))
    Endif
   When "src"
    ER = 0
    Onerrgo RIEN
    DESIG = filcom("TRT",CODTRT,"src",APPLI)
    Onerrgo
    If ER
    DESIG = ""
    Endif
   When "adx"
    Call INFO_ADX("","",CODTRT,20,DESIG) From ORDSYS
  Endcase
  MODULE = 99
 Endif
 If evalue(FILRAP)
  If I>=GNBSEL
   If FILRAP <> "1=1" : Call MESSAGE(mess(26,100,1)) From GESECRAN : Endif : # Tableau plein
   Break
  Endif
  I += 1
  WTRT(I) = CODTRT
  WDES(I) = DESIG
  WUSR(I) = CODUSR
  WDAT(I) = DATMOD
  WTIM(I) = TIMMOD
  WMDL(I) = MODULE
 Endif
Next TRT_
If FILRAP <> "1=1"
 Call FERME_BOITE From GESECRAN
Endif
For J=I+1 To GNBSEL
 WTRT(J) = chr$(255)
Next J
adxmxl = I
Return

#-----------------#
$SVG_TRT
If adxmxl
 FILTRE = 'TRT>"'+WTRT(adxmxl)+'"'
Else
 FILTRE = ''
Endif
Gosub CHARGE
Default File [TR2]
Return

#-----------------#
$PRG_TRT
FILTRE = 'TRT<"'+WTRT(1)+'"'
REVERSE = '-r'
Gosub CHARGE
REVERSE = ''
If adxmxl
 FILTRE = 'TRT>="'+WTRT(adxmxl)+'"'
Else
 FILTRE = ''
Endif
Gosub CHARGE
Default File [TR2]
Return

#-----------------#
$SRA_TRT
If CRIRAP<>""
 FILRAP = CRIRAP
 For I=1 To NBCOL
  Case I
   When 1 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]CODTRT")
   When 2 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]DESIG")
   When 3 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]CODUSR")
   When 4 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]DATMOD")
   When 5 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]TIMMOD")
   When 6 : FILRAP = func AFNC.TRANSF(FILRAP,COL(I),"[L]MODULE")
  Endcase
 Next I
 CRIRAP = ''
Else
 FILRAP = '1=1'
Endif
FILTRE = ''
REVERSE = ''
Gosub CHARGE
Default File [TR2]
Return

#---------------------#
$SET_DIME
DIME = 10000
Return

#-----------------------------------------------------------------------------------#
Subprog LIRE_TRT(OK)
Variable Integer OK
Local Integer OK , I , J , K , NB , R , TRONC
Local Char    CHAINE(250)
Gosub SET_DIME
Local Char    LIGNE(250)(1..DIME)
Gosub INITRT
Raz [M]FICSRC , SAVSRC
If filinfo(NOMSRC,0)<0 : OK = 0 : End : Endif
OK = 1
Openi NOMSRC Using [TRT]
Iomode adxifs "" Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]
Raz LIGNE , NB
Rdseq CHAINE Using [TRT]
If !fstat & left$(CHAINE,5)<>left$(TETADO,5)
 NB += 1
 LIGNE(NB) = CHAINE
Endif
Iomode adxirs "" Using [TRT]
Rdseq CHAINE Using [TRT]
While CHAINE<>""
 While CHAINE<>""
  If NB>=DIME
   Call ERREUR("|"+NOMSRC-"|\"-mess(175,115,1)) From GESECRAN : # Taille du fichier trop grande
   Break 2
  Else
   K = instr(1,CHAINE,chr$(10))
   If K
    NB += 1
    LIGNE(NB) = left$(CHAINE,K)
    CHAINE = right$(CHAINE,K+1)
   Else
    NB += 1
    LIGNE(NB) = CHAINE
    CHAINE = ""
   Endif
  Endif
 Wend
 Rdseq CHAINE Using [TRT]
Wend
Openi Using [TRT]
fstat=0
Setlob [M]FICSRC With LIGNE
[M]SAVSRC = [M]FICSRC
End


#------------------------------------------#
Subprog ECRIRE_TRT(OK)
Variable Integer OK
Local Integer I , K , NB , STAT
Local Char    MES(250)
Gosub SET_DIME
Local Char    LIGNE(255)(1..DIME)
[M]SAVSRC = [M]FICSRC
Gosub INITRT
Raz LIGNE
Setlob LIGNE With [M]FICSRC
If LIGNE=""
 Call ERREUR(mess(90,123,1)) From GESECRAN : # Traitement inexistant
 OK = 0
 End
Endif
OK = 1
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# On vire les CR du clob avant l'écriture dans le fichier .src, car les trt.src n'aiment pas les CR
For I=1 To NB
 LIGNE(I) = ctrans(LIGNE(I),chr$(13),"")
Next I
Openo NOMSRC,0 Using [TRT]
Iomode adxifs ""       Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8    Using [TRT]
If [M]REPERT="STC"
 Wrseq TETADO+[M]DES Using [TRT]
Else
 Wrseq TETADO-[M]DES Using [TRT]
Endif
Iomode adxirs ""       Using [TRT]
For I=1 To NB
 Wrseq LIGNE(I) Using [TRT]
Next I
Wrseq chr$(10) Using [TRT]
Wrseq chr$(10) Using [TRT]
Wrseq chr$(10) Using [TRT]
Openo Using [TRT]
#STAT = func SUBADC.DICTRT([M]CODTRT,"src",[M]APPLI,"","",1,MES)
STAT = func SUBADC.DICTRT([M]CODTRT,tolower([M]TYP),[M]APPLI,"","",1,MES)
End

#------------------------------------------#
Subprog EFFACE_TRT(OK)
Variable Integer OK
Local Integer STAT
Local Char    MES(250)
Gosub INITRT
If filinfo(NOMSRC,0)<0
 Call ERREUR(mess(101,100,1)) From GESECRAN : # Fichier inexistant
 OK = 0 : End
Endif
If GCONF(1)=1
 OK = 1
 # Voulez-vous supprimer ce fichier ?
 Call AVERTIR([M]APPLI+"."+[M]CODTRT+".src :"-mess(140,141,1),OK) From GESECRAN
 If OK<>2
  OK = 0 : End
 Endif
Endif
Call EFFACE(NOMSRC,STAT) From ORDSYS
If [M]REPERT="TRT"
 Call EFFACE_ADX("",[M]APPLI,[M]CODTRT,STAT) From ORDSYS
Elsif [M]REPERT="STC"
 Call EFFACE_STC("",[M]APPLI,[M]CODTRT,STAT) From ORDSYS
Endif
OK = 1
#STAT = func SUBADC.DICTRT([M]CODTRT,"src",[M]APPLI,"","",2,MES)
STAT = func SUBADC.DICTRT([M]CODTRT,tolower([M]TYP),[M]APPLI,"","",2,MES)
End

#------------------------------------------#
$INITRT
Local Char NOMSRC(GDIMFIC) , TETADO(80)
#NOMSRC = filpath("TRT",[M]CODTRT,"src",[M]APPLI)
NOMSRC = filpath([M]REPERT,[M]CODTRT,tolower([M]TYP),[M]APPLI)
TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Return

#-----------------------------------------------------------------------------------#
Subprog INFOFIC(FICHIER,UTIL,NOM,TAILLE,DATMOD,HREMOD,OK)
Value    Char    FICHIER
Variable Char    UTIL
Variable Char    NOM
Variable Decimal TAILLE
Variable Date    DATMOD
Variable Char    HREMOD
Variable Integer OK
Local Integer A , T , J , H , M , S , ER
Local Integer IDUSER
Local Char    LIGNE(50)(1..50)
If filinfo(FICHIER,0)<0 : OK = 0 : End : Endif
OK = 1
T = filinfo(FICHIER,9)
J = int(T/(3600*24))
H = int(mod(T,3600*24)/3600)
M = int(mod(T,3600)/60)
S = mod(T,60)
DATMOD  = [01/01/1970]+J
HREMOD  = format$("N0:2#",H)+":"+format$("N0:2#",M)+":"+format$("N0:2#",S)
IDUSER  = filinfo(FICHIER,5)
TAILLE  = filinfo(FICHIER,7)
Raz NOM, UTIL
If GOS(1)="unix"
 ER = 0
 Onerrgo RIEN
 Openi "/etc/passwd" Using [ID]
 Onerrgo
 If !ER
  Iomode adxifs ":"      Using [ID]
  Iomode adxirs chr$(10) Using [ID]
  Iomode adxium GASCII   Using [ID]
  Rdseq LIGNE Using [ID]
  While fstat=0
   If val(LIGNE(3))=IDUSER
    UTIL = LIGNE(1)
    NOM  = LIGNE(5)
    Break
   Endif
   Rdseq LIGNE Using [ID]
  Wend
  Openi Using [ID]
 Endif
Endif
End

$RIEN
ER = errn
Resume

#-----------------------------------------------------------------------------------#
Subprog INFOADX(FICHIER,APPLI,MACHINE,UTIL,NOM,TAILLE,DATMOD,HREMOD,OK)
Value    Char    FICHIER
Value    Char    APPLI
Value    Char    MACHINE
Variable Char    UTIL
Variable Char    NOM
Variable Decimal TAILLE
Variable Date    DATMOD
Variable Char    HREMOD
Variable Integer OK
Local Decimal PROPRIO
Local Integer ER
Local Char    LIGNE(50)(1..50)
Raz NOM, UTIL
Call INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK) From SUBADC
If TAILLE<0 or PROPRIO<=0 : End : Endif
If GOS(1)="unix"
 ER = 0
 Onerrgo RIEN
 Openi "/etc/passwd" Using [ID]
 Onerrgo
 If !ER
  Iomode adxifs ":"      Using [ID]
  Iomode adxirs chr$(10) Using [ID]
  Iomode adxium GASCII   Using [ID]
  Rdseq LIGNE Using [ID]
  While fstat=0
   If val(LIGNE(3))=PROPRIO
    UTIL = LIGNE(1)
    NOM  = LIGNE(5)
    Break
   Endif
   Rdseq LIGNE Using [ID]
  Wend
  Openi Using [ID]
 Endif
Endif
End

######################################################################################
# Selection of type
######################################################################################
Subprog SEL_TYP(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..3) , TIT(GLONDES)(0..3) , CRITERE(250)

NBTEX+= 1
TEX(NBTEX,1) = "SRC"
TEX(NBTEX,2) = mess(43,115,1)
TEX(NBTEX,3) = "TRT"
NBTEX+= 1
TEX(NBTEX,1) = "STC"
TEX(NBTEX,2) = mess(8,140,1)
TEX(NBTEX,3) = "STC"

CHOI = 0
TIT(0) = mess(22,123,1) : # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ADC2", "TYP") : # "Type"
TIT(2) = ""
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ADC2", "REPERT") : # "Répertoire"
Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
End

#-----------------------------------------------------------------------------------#
Subprog C_FICSRC
Local Char    CHAINE(50)
Local Integer OK
Raz CHAINE
Setlob CHAINE With [M]FICSRC
If CHAINE="" & filinfo(filpath([M]REPERT,[M]CODTRT,tolower([M]TYP),[M]APPLI),0)>0
 Call ERREUR(mess(10,123,1)) From GESECRAN : # Zone obligatoire
 Call LIRE_TRT(OK)
 mkstat = 2
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR="SRC"
 [M]INTTYP=mess(43,115,1) : Affzo [M]INTTYP
 [M]REPERT="TRT" : Affzo [M]REPERT
Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR=""
 GMESSAGE = mess(10,123,1) : #ZONE OBLIGATOIRE
 mkstat=2 : End
Elsif !find([L]VALEUR,"SRC","STC")
 GMESSAGE = VALEUR-mess(83,123,1) : # VALEUR INCORRECTE
 mkstat=2 : End
Endif
End

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR()
If VALEUR="SRC"
 [M]INTTYP=mess(43,115,1) : Affzo [M]INTTYP
 [M]REPERT="TRT" : Affzo [M]REPERT
Elsif VALEUR="STC"
 [M]INTTYP=mess(8,140,1) : Affzo [M]INTTYP
 [M]REPERT="STC" : Affzo [M]REPERT
Endif
End

Subprog S_TYP(VALEUR)
Variable Char    VALEUR()
Call SEL_TYP(VALEUR)
End

Subprog IB_CODTRT
If [M]REPERT<>"TRT"
 GBOUT1=""
Endif
End

Subprog AM_CODTRT(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
End

