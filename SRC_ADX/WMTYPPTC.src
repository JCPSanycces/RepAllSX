#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## ATY-ATYPE ## PTC
# 2018-11-09 07:14:57 457

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,PTCCOD,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char PTCCOD
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIPTC [EPT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIPTC" [EPT]
Endif

Default File [F:EPT]
Read [F:EPT]EPT0 = [L]PTCCOD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PTCCOD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "VALID"
  [L]ATSTFILTER = ([F:EPT]VALID = [V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(50676)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PTCCOD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


