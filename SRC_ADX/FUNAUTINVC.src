#####################################################################
$ADDCOX
Local Integer IERRCON5
IERRCON5 = 0

Trbegin [COX]
Filter  [CON5] Where (evalue(CRITERE) & evalue (FILSUP) & evalue(SZFILTCON5BPC))

For [CON5]
    Raz [F:COX]
    [F:COX] = [F:CON5]
    [F:COX]PRONUM = adxuid(1)
    Write [COX]
    If fstat
        IERRCON5 = 1
        Break
    Endif
Next

Filter [CON5]

If IERRCON5
    Rollback
Else
    Commit
Endif

Return

