Local Integer WADXUID(1..1000)
Local Integer WDIM
Local Integer WTRBEGIN : Raz WTRBEGIN
Local Integer IERRINFCAX
IERRINFCAX = 0

Call UIDADX(WADXUID,WDIM) From TRTX3

Raz I, J

# Si pas de transaction en cours
If adxlog<>1
    Trbegin [CAX]
    WTRBEGIN=1
Endif

Filter [CAX] Where [F:CAX]PRONUM <> 0

For [CAX]
    If !find([F:CAX]PRONUM,WADXUID(1..WDIM))
        Delete [CAX] Curr
        If fstat
            IERRINFCOX = 1
            Break
        Endif
    Endif
Next

Filter [CAX]

# Si on a ouvert une transaction
If WTRBEGIN=1
    If IERRINFCAX
        Rollback
        Return
    Endif
Endif

# Si on a ouvert une transaction
Delete [CAX] Where [F:CAX]PRONUM = adxuid(1)
If fstat
    If WTRBEGIN=1
        Rollback
    Endif
Else
    If WTRBEGIN=1
        Commit
    Endif
Endif
Raz WTRBEGIN

Return


####################################################################
$DELCAX
