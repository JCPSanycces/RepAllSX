IERRINFCAX = 0

If adxuid(1) = 0 : Return : Endif

# Si pas de transaction en cours
If adxlog<>1
    Trbegin [CAX]
    WTRBEGIN=1
Endif

Delete [CAX] Where [F:CAX]PRONUM = adxuid(1)
If fstat
    If WTRBEGIN=1
        Rollback
    Endif
Else
    If WTRBEGIN=1
        Commit
    Endif
Endif
Raz WTRBEGIN

Return

