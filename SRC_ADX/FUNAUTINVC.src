#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#                                                  LD - Juillet   2002  #
#     FACTURES AUTO. DES CONTRATS DE SERVICE                            #
#                                                                       #
#     - Traitement        : FUNAUTINVC                                  #
#     - Action e_commerce : TRTAUTINVC  (Traitement standard)           #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
  #--- Actions liées au traitement standard
  Case ACTION
    When "OUVRE_BATCH" : Gosub INIT_TRTAUTINVC
    When "INIT"        : Gosub INIT_TRTAUTINVC
    When "DEBUT"       : Affzo [DIA]1-99
    When "OK"          : GOK=1
    When "END"         : GOK=0 : FIN=1
    When "CONTROLE"    : Gosub CONTROLE_TRTAUTINVC
    When "EXEC"        : Gosub EXEC_TRTAUTINVC
    When "TERMINE"     : Gosub TERMINE_TRTAUTINVC
    When Default
  Endcase
Return

#########################################################################
$CHECK_INVCNO_MSK
Local Integer OKTRT
# Local Char SNOMTRT(GLONADC) #X3-23080

  # FGR 22/12/2014 : X3SUIVI104963 : # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
  If filinfo(filpath("ECR","WSIH4INV","msk",0),0) < 0 Then
    Call ECR_TRACE(mess(262,191,1) - ":" - mess(263,191,1) - mess(264,191,1), 1) From GESECRAN
    OK = 0
    FIN = 1
  Else
    # For SNOMTRT = "W0WSIH4INV"    #X3-23080
      #Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS       #X3-23080
      Call EXISTE_ADX("", "", "W0WSIH4INV", OKTRT) From ORDSYS   #X3-23080
      If OKTRT > 0 Then
        # Il existe, c'est bon
      Else
        # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
        If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
        If [F:ADS]DOSSIER <> nomap Then
          Read [F:ADS]DOSSIER=nomap
        Endif
        Call VALID("WSIH4INV", nomap, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OKTRT) From VALMSK
        #Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS       #X3-23080
        Call EXISTE_ADX("", "", "W0WSIH4INV", OKTRT) From ORDSYS   #X3-23080
        If OKTRT > 0 Then
          # Il existe, c'est bon
        Else
          Call ECR_TRACE(mess(262,191,1) - ":" - mess(263,191,1) - mess(265,191,1), 1) From GESECRAN
          OK = 0
          FIN = 1
         # Break #X3-23080
        Endif
      Endif
    # Next       #X3-23080
  Endif
Return

