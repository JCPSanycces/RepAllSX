#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################
#########################################################################
$INIT_TRTAUTINVC
  # FGR 04/08/2014 : X3SUIVI98833 (début)
  Gosub CHECK_INVCNO_MSK
  If FIN = 1 Then
    Return
  Endif
  # FGR 04/08/2014 : X3SUIVI98833 (fin)
  If GMODU(12) = 2
    Global Shortint GINVTYP  : GINVTYP = 1  : # Type document        = Facture
    #----- Ouverture des tables et déclaration des variables pour les états -----#
    Gosub INIT_ETAT From TRTX3ETA
    #-----
    # En batch , il vaut mieux mettre onerrgo
    If GSERVEUR
      Onerrgo ERRBATCH
    Endif
    Gosub OUVRE
  Else
    #Le module Support client n'est pas activé. Fonction inaccessible.
    GMESSAGE = mess(194,177,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  Local Mask SAUTINVC [DIA]
  Raz [M:DIA]

  [M]SALFCY=GFCYDEF(5)
  [M]NEXSHIINV=date$
  [M]SIVTYP=GSIVTYP
  [M]INVDATFLG=1
  [M]INVDATINV=date$
  [M]TYPITMDES = 1
  [M]IME=1
  [M]DSYFLG = 1

  Call LECMEMO ("STD","[M:DIA]", "vf5") From GMEMO

  # Positionner le flag si saisie des paramêtres depuis la gestion des abonnements
  [M]ABT = 1
  If GFONCTION1 = "GESABA" Then
    [M]ABT = 2
  Endif
Return

#########################################################################
$CONTROLE_TRTAUTINVC
  If GOK < 1 Then
    FIN = 1
  Else
    TMP = 1
  Endif
Return

#########################################################################
$EXEC_TRTAUTINVC
Local Char    WPARAM(10)
Local Decimal WAMTNOTLIN

#-- pour appel GENSIH
Local Integer LCOD            : LCOD=1
Local Char    LMAJ(1)         : LMAJ="C"
Local Integer LECH            : LECH=2
Local Integer LTEST           : LTEST=1
Local Char    LTRT(GLONADC)   : LTRT="FUNAUTINVC"
Local Char    LORINUM(GLONVCR)
Local Char    LSIVNUM(GLONSIH)
Local Integer LERR   : LERR=0
Local Integer ICONTOINV
Local Integer ICONCOUNT
Local Integer ICONOK
Local Integer IDOIMETEST
Local Char SZMESS1(250)
Local Char SZMESS2(250)
Local Char FILSUP(250)
Local Char SZFILTCON5BPC(250)
Local Integer ITERRVA
Local Integer IRECNUMX
  SZFILTCON5BPC = ""
  IRECNUMX = 0
  ITERRVA = 0
  SZMESS1 = ""
  SZMESS2 = ""
  ICONTOINV = 0
  ICONCOUNT = 0
  ICONOK = 0
  IDOIMETEST = 0
  FILSUP="1=1"
  # -----------------------------------------
  # Issue SAM120356 - 2017-01-09 by FGR : BEGIN
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  Read [DVA]DVA0="REW";"WARRANTY"
  If !fstat Then
    If [F:DVA]DATX(0) = date$ Then
      # Pour forcer le recalcul des garanties
      Trbegin [DVA]
      [F:DVA]DATX(0) -= 1
      Rewrite [DVA]
      If fstat Then
        #La gestion des renouvellements des garanties à tacite reconduction n'a pas pu être configurée.
        GMESSAGE = mess(352,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  Call REWWARRANTY() From SUBCONB2
  # Issue SAM120356 - 2017-01-09 by FGR : END
  # -----------------------------------------

Global Char GDIAINVTYP(type([M]SIVTYP)-10)
Global Char GDIASALFCY(type([M]SALFCY)-10)
Global Date GDIANEXSHIINV
Global Date GDIAINVDAT
Global Integer  GDIAINVDATFLG
Global Integer  GIDIAIMEFLG
Global Char     GSZBPCBREAK(GLONBPR)
Global Integer  GSZSFIBREAK                                             :#--CPO 79550
Global Char     GWORDERWITH(50),GWORDERWITHSFI(255),GWORDERWITHLAST(15) :#--CPO 79550
Global Char     GSZOPPBREAK(GLONPJT)  # FGR 28/11/2011 : X3SUIVI71065
  Raz GSZOPPBREAK

Global Char GSZPYRBREAK(GLONBPR)  # FGR 08/04/2010 : X3SUIVI38132 : Tiers payeur
Global Char GSZGRUBREAK(GLONBPR)  # FGR 08/04/2010 : X3SUIVI38132 : Client groupe
  Raz GSZPYRBREAK                 # FGR 08/04/2010 : X3SUIVI38132 : Tiers payeur
  Raz GSZGRUBREAK                 # FGR 08/04/2010 : X3SUIVI38132 : Client groupe
Global Decimal GPRITPBREAK        # FGR 08/04/2010 : X3SUIVI38132 : Type de prix
Global Char GSZVACBREAK(GLONTVB)  # FGR 08/04/2010 : X3SUIVI38132 : Régime de taxe
  Raz GPRITPBREAK                 # FGR 08/04/2010 : X3SUIVI38132 : Type de prix
  Raz GSZVACBREAK                 # FGR 08/04/2010 : X3SUIVI38132 : Régime de taxe

# -------------------------------------
# FGR 29/11/2012 : X3SUIVI84296 (début)
#                  CRITERE et FILSUP sont des variables dimensionnées
#                  GDIACRITERE et GDIAFILSUP doivent l'être de la même façon
  #Global Char GDIACRITERE(250)
  #Global Char GDIAFILSUP(250)
  If dim(CRITERE) > 0 Then
    Global Char GDIACRITERE(250)(0..dim(CRITERE)-1)
  Else
    Global Char GDIACRITERE(250)
  Endif
  If dim(FILSUP) > 0 Then
    Global Char GDIAFILSUP(250)(0..dim(FILSUP)-1)
  Else
    Global Char GDIAFILSUP(250)
  Endif
# FGR 29/11/2012 : X3SUIVI84296 (fin)
# -------------------------------------

Global Char GSZFILTINVBPC(250)
Global Char GSZCONBREAK(GLONCON)
Global Integer GIDIASIH4STOP
Global Decimal GIDIANEXINVAMT
Global Char GSZDIAITMREF(GLONITM)
Global Char GSZDIACONNUM(GLONCON)
Global Integer GITER2CONTRACT
Global Integer GIAUTINVCFLG
Global Char GSZDIACRVACAH(10)(999)
Global Char GSZDIACREWCAH(10)(999)
Global Char GSZDIAITMDATDES(GLONDES)
Global Integer GIDIATYPITMDES
Global Date GDTDIADATSTR          # FGR 08/04/2010 : X3SUIVI38132
Global Date GDTDIADATEND          # FGR 08/04/2010 : X3SUIVI38132

  Raz GDTDIADATSTR                # FGR 08/04/2010 : X3SUIVI38132
  Raz GDTDIADATEND                # FGR 08/04/2010 : X3SUIVI38132
  GDIASALFCY = [M]SALFCY
  GDIAINVTYP = [M]SIVTYP
  GSZCONBREAK = ""
  GSZBPCBREAK = ""
  GDIAINVDATFLG = [M]INVDATFLG
  GIDIAIMEFLG = [M]IME
  GDIAINVDAT = [M]INVDATINV
  GIDIASIH4STOP = 0
  GIDIANEXINVAMT = 0
  GSZDIAITMREF = ""
  GSZDIACONNUM = ""
  GITER2CONTRACT = 0
  GIAUTINVCFLG = 0
  Raz GSZDIACRVACAH
  Raz GSZDIACREWCAH
  GSZDIAITMDATDES = ""
  GIDIATYPITMDES = [M]TYPITMDES
  GSZSFIBREAK = 0      :#--CPO 79550
  GWORDERWITH     = "" :#--CPO 79550
  GWORDERWITHSFI  = "" :#--CPO 79550
  GWORDERWITHLAST = "" :#--CPO 79550

  If [M]NEXSHIINV = [00/00/00] Then
    GDIANEXSHIINV = date$
  Else
    GDIANEXSHIINV = [M]NEXSHIINV
  Endif
  Read [ACV]CODACT="SIH"
  If fstat Then
    Global Char GITERCONTRACT(GLONCON)(999)
    Global Decimal GIONEXINVAMT(999)
    Global Date GDOLASINVDAT(999)
    Global Date GDONEXINVDAT(999)
    Global Date GDONEXSHIINV(999)
    Global Date GDOCONSTRDAT(999)
    Global Date GDOCONENDDAT(999)
    Global Decimal GIOLASVALIDX(999)
    Global Date GDOLASIDXDAT(999)
    Global Date GDORVADAT(999)
    Global Decimal GIOCONAMT(999)
    Global Integer GIODSYWND(999)
  Else
    Global Char GITERCONTRACT(GLONCON)([F:ACV]DIME)
    Global Decimal GIONEXINVAMT([F:ACV]DIME)
    Global Date GDOLASINVDAT([F:ACV]DIME)
    Global Date GDONEXINVDAT([F:ACV]DIME)
    Global Date GDONEXSHIINV([F:ACV]DIME)
    Global Date GDOCONSTRDAT([F:ACV]DIME)
    Global Date GDOCONENDDAT([F:ACV]DIME)
    Global Decimal GIOLASVALIDX([F:ACV]DIME)
    Global Date GDOLASIDXDAT([F:ACV]DIME)
    Global Date GDORVADAT([F:ACV]DIME)
    Global Decimal GIOCONAMT([F:ACV]DIME)
    Global Integer GIODSYWND([F:ACV]DIME)
  Endif
  Raz GITERCONTRACT
  Raz GIONEXINVAMT
  Raz GDOLASINVDAT
  Raz GDONEXINVDAT
  Raz GDONEXSHIINV
  Raz GDOCONSTRDAT
  Raz GDOCONENDDAT
  Raz GIOLASVALIDX
  Raz GDOLASIDXDAT
  Raz GDORVADAT
  Raz GIOCONAMT
  Raz GIODSYWND

  Gosub CLEANCOX
  Gosub CLEANCAX
  Gosub CLEANCRX
  ## --> Réalimentation GSOCIETE,GFINRSP,GLOCALDEV
  #Call GETDEV([M]SALFCY) From DEVSUB
  # --> Chargement globales référenciels, comptes et sections de la société
#  If GFCY <> [M]SALFCY Then             : # Bug 69105
#    GFCY = [M]SALFCY                    : # Bug 69105
#    Gosub CHARG_PARAM                   : # Bug 69105
#  Endif                                 : # Bug 69105
  GFCY = [M]SALFCY : Gosub CHARG_PARAM   : # Bug 69105
  # --> Récupération des paramêtres de vente
  Call GLOBVAR([M]SALFCY,"VEN") From TRTX3
  # --> Vérification Type de facture utilisateur
  Gosub VERF_SIVTYP

  If !GSERVEUR
    # Ouverture de la trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SAUTINVC","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
  If func AFNC.ACTIV("KPO") & GCURLEG = "POR"

    If [F:TSV]SAFTINVTYP = 2
      GMESSAGE = mess(78,7711,1)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Return
    Endif

    If [F:TSV]AUTINV = 2
      GMESSAGE = mess(146,7711,1)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Return
    Endif

  Endif
  #85803 RICAR 2014/05/20 - Portuguese legal requirements - END

  If [M]INVDATFLG=1
    WINVDAT=[M]INVDATINV
    If [M]INVDATINV = [0/0/0]
      [M]INVDATINV = date$

      Local Date WINVDAT

      WINVDAT=[M]INVDATINV
      Gosub CTL_INVDAT
      If mkstat <> 0
        Call ECR_TRACE(mess(468,197,1)-format$(GFMDAT,[M]INVDATINV)-GMESSAGE,1) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
      Endif
    Endif
  Endif

  # Bornage de la date de prise en compte des demandes si la requête est abonnée
  # Si date de prise en compte non renseignée, on force la date du jour
  If [M]NEXSHIINV = [0/0/0] and [M]ABT = 2 Then
    [M]NEXSHIINV = date$
  Endif
  Gosub SEL_CON
  Case [M]IME
    When 1
      # Echéance unique
      Gosub DOIME1
    When 2
      # 1 fac/échéance
      Gosub DOIME2
    When 3
      # 1 fac/contrat
      Gosub DOIME3
    When 4
      # 1 fac/client
      Gosub DOIME4
  Endcase
  Kill GDIASALFCY
  Kill GDIAINVTYP
  Kill GDIAINVDAT
  Kill GIDIAIMEFLG
  Kill GDIAINVDATFLG
  Kill GDIANEXSHIINV
  Kill GSZBPCBREAK
  #--CPO 79550
  Kill GSZSFIBREAK
  Kill GWORDERWITH
  Kill GWORDERWITHSFI
  Kill GWORDERWITHLAST
  #--/
  #LSE 30/10/2006 FQ38245
  Kill GSZOPPBREAK
  # FGR 12/03/2009 : X3SUIVI28408
  #Kill GSDSTRBREAK  # FGR 08/04/2010 : X3SUIVI38132
  #Kill GSDENDBREAK  # FGR 08/04/2010 : X3SUIVI38132
  Kill GDTDIADATSTR  # FGR 08/04/2010 : X3SUIVI38132
  Kill GDTDIADATEND  # FGR 08/04/2010 : X3SUIVI38132
  Kill GSZPYRBREAK   # FGR 08/04/2010 : X3SUIVI38132 : Tiers payeur
  Kill GSZGRUBREAK   # FGR 08/04/2010 : X3SUIVI38132 : Client groupe
  Kill GPRITPBREAK   # FGR 08/04/2010 : X3SUIVI38132 : Type de prix
  Kill GSZVACBREAK   # FGR 08/04/2010 : X3SUIVI38132 : Régime de taxe

  Kill GDIACRITERE
  Kill GDIAFILSUP
  Kill GSZFILTINVBPC
  Kill GSZCONBREAK
  Kill GIDIASIH4STOP
  Kill GIDIANEXINVAMT
  Kill GSZDIAITMREF
  Kill GSZDIACONNUM
  Kill GIAUTINVCFLG
  Kill GSZDIACRVACAH
  Kill GSZDIACREWCAH
  Kill GSZDIAITMDATDES
  Kill GIDIATYPITMDES

  Kill GITERCONTRACT
  Kill GITER2CONTRACT
  Kill GIONEXINVAMT
  Kill GDOLASINVDAT
  Kill GDONEXINVDAT
  Kill GDONEXSHIINV
  Kill GDOCONSTRDAT
  Kill GDOCONENDDAT
  Kill GIOLASVALIDX
  Kill GDOLASIDXDAT
  Kill GDORVADAT
  Kill GIOCONAMT
  Kill GIODSYWND
Return

###############################################################
$DOIME1
  # Echéance unique
  # 71065 : PJT
  # Note FGR : Rien à prévoir pour le PJT. La facture est mono-contrat et mono-échéance. Donc mono-PJT.
  # 71065 : PJT
  Gosub OUVBOITE
  Filter [CON] Where (evalue(CRITERE) & evalue (FILSUP))
  For [CON]
    #Cliché du contrat pour restauration en cas d'erreur.
    Raz GSZDIACRVACAH
    Raz GSZDIACREWCAH
    Raz [F:CON4]
    [F:CON4] = [F:CON]
    [F:WCON] = [F:CON]  # FGR 25/03/2013 : X3SUIVI87947
    #Appel du composant de création facture.
    Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
    If LERR Then
      Gosub IMEERR
    Else
      NBINV += 1
      #--CPO 87923 Gestion des prélèvements SDD
      Gosub INIT_CTL_UMRNUM
      #--/
      If [M:DIA]PRNFLG = 2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
        If LSIVNUM <> "" Then
          Read [SIV]SIV0=LSIVNUM
          If !fstat Then
            #----- Recherche du nouveau code état à partir du modèle -----#
            If [F:BPC]BPCNUM <> [F:SIH]BPR Then
              Read [BPC]BPC0=[F:SIH]BPR
              If fstat Then
                Raz [F:BPC]
              Endif
            Endif
            If [F:BPC]TPMCOD <> "" Then
              If [F:TPM]TPMCOD<>[F:BPC]TPMCOD Then
                Read [TPM]TPM0=[F:BPC]TPMCOD
                If fstat Then
                  Raz [F:TPM]
                Endif
              Endif
              If [F:TPM]SALINV<>"" Then
                WARP_RPTCOD(0)=[F:TPM]SALINV
              Else
                WARP_RPTCOD(0)=[M:DIA]PRNNAM
              Endif
            Else
              WARP_RPTCOD(0)=[M:DIA]PRNNAM
            Endif
            #----- Nombre de copies -----#
            WARP_NBRCPY=[F:SIV]COPNBR
            #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
            Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
            #-----
          Endif
        Endif
      Endif
    Endif
      If !GSERVEUR Then
        ICONCOUNT += 1
        Call AFF_BOITE ([F:CON]CONNUM, ICONCOUNT, ICONOK) From GESECRAN
      Endif
  Next
Filter [CON]

If !GSERVEUR
    Call FERME_BOITE From GESECRAN
Endif

Return

###############################################################
$DOIME2
  # 1 facture par échéance
  # 71065 : PJT
  # Note FGR : Rien à prévoir pour le PJT. La facture est mono-contrat et mono-échéance. Donc mono-PJT.
  # 71065 : PJT
  Gosub OUVBOITE
  Filter [CON] Where (evalue(CRITERE) & evalue (FILSUP))
  For [CON]
    #Cliché du contrat pour restauration en cas d'erreur.
    While 1
      # FGR 13/10/2008 : X3SUIVI49551 ajout de "or ([F:CON]INVMET <> 2 and [F:CON]NEXINVDAT > [F:CON]CONENDDAT)" si "Pré-facturation"
      If [F:CON]NEXINVDAT = [00/00/00] or ([F:CON]INVMET <> 2 and [F:CON]NEXINVDAT > [F:CON]CONENDDAT) Then
        Break
      Else
        If [F:CON]NEXSHIINV > GDIANEXSHIINV Then
          Break
        Endif
      Endif
      Raz GSZDIACRVACAH
      Raz GSZDIACREWCAH
      Raz [F:CON4]
      [F:CON4] = [F:CON]
      [F:WCON] = [F:CON]  # FGR 25/03/2013 : X3SUIVI87947
      #Appel du composant de création facture.
      Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
      If LERR Then
        Gosub IMEERR
        Break
      Else
        NBINV += 1
        #--CPO 87923 Gestion des prélèvements SDD
        Gosub INIT_CTL_UMRNUM
        #--/
        If [M:DIA]PRNFLG = 2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
          If LSIVNUM <> "" Then
            Read [SIV]SIV0=LSIVNUM
            If !fstat Then
              #----- Recherche du nouveau code état à partir du modèle -----#
              If [F:BPC]BPCNUM <> [F:SIH]BPR Then
                Read [BPC]BPC0=[F:SIH]BPR
                If fstat Then
                  Raz [F:BPC]
                Endif
              Endif
              If [F:BPC]TPMCOD <> "" Then
                If [F:TPM]TPMCOD <> [F:BPC]TPMCOD Then
                  Read [TPM]TPM0=[F:BPC]TPMCOD
                  If fstat Then
                    Raz [F:TPM]
                  Endif
                Endif
                If [F:TPM]SALINV <> "" Then
                  WARP_RPTCOD(0) = [F:TPM]SALINV
                Else
                  WARP_RPTCOD(0) = [M:DIA]PRNNAM
                Endif
              Else
                WARP_RPTCOD(0) = [M:DIA]PRNNAM
              Endif
              #----- Nombre de copies -----#
              WARP_NBRCPY = [F:SIV]COPNBR
              #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
              Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
              #-----
            Endif
          Endif
        Endif
      Endif
    Wend
    If !GSERVEUR Then
      ICONCOUNT += 1
      Call AFF_BOITE ([F:CON]CONNUM, ICONCOUNT, ICONOK) From GESECRAN
    Endif
  Next
  Filter [CON]
  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif
Return

###############################################################
$DOIME3
  # 1 facture par contrat
  # 71065 : PJT
  # Note FGR : Rien à prévoir pour le PJT. La facture est mono-contrat. Donc mono-PJT.
  # 71065 : PJT
  Gosub OUVBOITE
  Filter  [CON2] Where (evalue(CRITERE) & evalue (FILSUP))
  For [CON2]
    #LSE19/01/2006 34411
    #Read [CON] CON0 = [F:CON]CONNUM
    Read [CON] CON0 = [F:CON2]CONNUM
    If !fstat Then
      #Cliché du contrat pour restauration en cas d'erreur.
      Raz GSZDIACRVACAH
      Raz GSZDIACREWCAH
      Raz [F:CON4]
      [F:CON4] = [F:CON]
      [F:WCON] = [F:CON]  # FGR 25/03/2013 : X3SUIVI87947
      Raz GIONEXINVAMT
      Raz GDOLASINVDAT
      Raz GDONEXINVDAT
      Raz GDONEXSHIINV
      Raz GDOCONSTRDAT
      Raz GDOCONENDDAT
      Raz GIOLASVALIDX
      Raz GDOLASIDXDAT
      Raz GDORVADAT
      Raz GIOCONAMT
      Raz GIODSYWND
      GIONEXINVAMT(0) = [F:CON]NEXINVAMT
      GDOLASINVDAT(0) = [F:CON]LASINVDAT
      GDONEXINVDAT(0) = [F:CON]NEXINVDAT
      GDONEXSHIINV(0) = [F:CON]NEXSHIINV
      GDOCONSTRDAT(0) = [F:CON]CONSTRDAT
      GDOCONENDDAT(0) = [F:CON]CONENDDAT
      GIOLASVALIDX(0) = [F:CON]LASVALIDX
      GDOLASIDXDAT(0) = [F:CON]LASIDXDAT
      GDORVADAT(0) = [F:CON]RVADAT
      GIOCONAMT(0) = [F:CON]CONAMT
      GIODSYWND(0) = [F:CON]DSYWND
      #Appel du composant de création facture.
      Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
      If LERR Then
        Gosub IMEERR
      Else
        NBINV += 1
        #--CPO 87923 Gestion des prélèvements SDD
        Gosub INIT_CTL_UMRNUM
        #--/
        If [M:DIA]PRNFLG=2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
          If LSIVNUM <> "" Then
            Read [SIV]SIV0=LSIVNUM
            If !fstat Then
              #----- Recherche du nouveau code état à partir du modèle -----#
              If [F:BPC]BPCNUM<>[F:SIH]BPR Then
                Read [BPC]BPC0=[F:SIH]BPR
                If fstat Then
                  Raz [F:BPC]
                Endif
              Endif
              If [F:BPC]TPMCOD <> "" Then
                If [F:TPM]TPMCOD<>[F:BPC]TPMCOD Then
                  Read [TPM]TPM0=[F:BPC]TPMCOD
                  If fstat Then
                    Raz [F:TPM]
                  Endif
                Endif
                If [F:TPM]SALINV<>"" Then
                  WARP_RPTCOD(0)=[F:TPM]SALINV
                Else
                  WARP_RPTCOD(0)=[M:DIA]PRNNAM
                Endif
              Else
                WARP_RPTCOD(0)=[M:DIA]PRNNAM
              Endif
              #----- Nombre de copies -----#
              WARP_NBRCPY=[F:SIV]COPNBR
              #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
              Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
              #-----
            Endif
          Endif
        Endif
      Endif
      If !GSERVEUR Then
        ICONCOUNT += 1
        Call AFF_BOITE ([F:CON]CONNUM, ICONCOUNT, ICONOK) From GESECRAN
      Endif
    Endif
  Next
  Filter [CON2]
  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif
Return

###############################################################
$DOIME4
  # 1 facture par client
  Gosub OUVBOITE
  # -------------------------------------
  # FGR 29/11/2012 : X3SUIVI84296 (début)
  #GDIACRITERE = CRITERE
  #GDIAFILSUP = FILSUP
  Local Integer INIME4

  Raz GDIACRITERE
  For INIME4 = 0 To dim(CRITERE)-1
    GDIACRITERE(INIME4) = CRITERE(INIME4)
  Next NI
  Raz GDIAFILSUP
  For INIME4 = 0 To dim(FILSUP)-1
    GDIAFILSUP(INIME4) = FILSUP(INIME4)
  Next NI
  # FGR 29/11/2012 : X3SUIVI84296 (fin)
  # -------------------------------------
  GSZCONBREAK = ""
  GSZBPCBREAK = ""
  GSZSFIBREAK = 0         :#--CPO 79550
  GWORDERWITH     = ""    :#--CPO 79550
  GWORDERWITHSFI  = ""    :#--CPO 79550
  GWORDERWITHLAST = ""    :#--CPO 79550
  Local Integer WCONTINUE :#--CPO 79550
  WCONTINUE = 1           :#--CPO 79550

  Raz GSZPYRBREAK         # FGR 08/04/2010 : X3SUIVI38132 : Tiers payeur
  Raz GSZGRUBREAK         # FGR 08/04/2010 : X3SUIVI38132 : Client groupe
  Raz GPRITPBREAK         # FGR 08/04/2010 : X3SUIVI38132 : Type de prix
  Raz GSZVACBREAK         # FGR 08/04/2010 : X3SUIVI38132 : Régime de taxe
  #
  Raz GSZOPPBREAK
  # 71065 : PJT
  #GSZFILTINVBPC = "CONBPCINV=GSZBPCBREAK and CONPJT=GSZOPPBREAK and CONBPCPYR=GSZPYRBREAK and CONBPCGRU=GSZGRUBREAK and CONPRITYP=GPRITPBREAK and CONVACBPR=GSZVACBREAK"
  GSZFILTINVBPC = "CONBPCINV=GSZBPCBREAK and CONBPCPYR=GSZPYRBREAK and CONBPCGRU=GSZGRUBREAK and CONPRITYP=GPRITPBREAK and CONVACBPR=GSZVACBREAK"
  If GPJTSNGDOC = G_OUI Then
    GSZFILTINVBPC -= " and CONPJT=GSZOPPBREAK"
  Endif
  # 71065 : PJT
  # ------------------------------------
  #
  #--CPO 79550
  #--Il faut revoir le Filter, éventuellement ...
  #---1) chercher sur les SFI s'il y a des elts paramétrés avec GRUFLG à "Non si différence"
  #----- On ajoute dans le tableau [L]GRUNOM les numeros des élements
  #----- dont la regle de regroupement est à "Non si différent", pour ce document
  #----- En se basant sur un contrat faisant l'objet de la facturation
  #----- , et comme la structure est la même, on ajoute au Ordeer by les INVDTAAMT concernés par le GRUFLG
  Gosub OPEN_SFI From TRTX3CPY

  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #GWORDERWITH     = "CONBPCINV Asc; CONBPC Asc; CONPJT Asc;"
  GWORDERWITH     = "[F:VIME4]SORT Asc;"
  # Issue X3-74080 - 2018-02-14 by FGR : END
  GWORDERWITHLAST = "CONNUM Asc"

  Local Integer RCNTDFI : RCNTDFI= nbrecord([F:SFI])
  If RCNTDFI<=5 : RCNTDFI = 10 : Endif

  Local Integer GRUNON([L]RCNTDFI), I1, I2,I,J, PDESVCR,PORIVCR

  PDESVCR=4  :#--factures
  PORIVCR=23 :#--contrats de service
  I2=0
  Read [SFI]First
  While fstat=0
      I1=find([L]PORIVCR,[F:SFI]ORIVCR(0..dim([F:SFI]ORIVCR)-1))
      If I1>0 & [F:SFI]DESVCR(I1-1)=PDESVCR & [F:SFI]GRUFLG(I1-1)=2
          [L]GRUNON(I2)=[F:SFI]SFINUM
          I2+=1
      Endif
      Read [F:SFI] Next
  Wend
  #--Il nous faut un contrat, afin d'alimenter le Order by en fonction des INVDTA retenus sur les contrats
  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #Filter [CON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order By CONBPCINV Asc; CONBPC Asc; CONPJT Asc; CONNUM Asc
  Filter [LCON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order By [F:VIME4]SORT Asc; CONNUM Asc
  # Issue X3-74080 - 2018-02-14 by FGR : END
  Read [F:LCON2]First        # Issue X3-74080 - 2018-02-14 by FGR
  If !fstat
    While [L]GRUNON(I)>0 and I<RCNTDFI-1
        J=find([L]GRUNON(I), [F:CON]INVDTA)
        #--Normalement, on peut ajouter jusqu'à 14 INVDTAAMT(x) Asc avant de remplir les 255 char...
        #--Je ne pense pas avoir besoin d'une seconde var tableau
        #--Il faut avoir plus de 14 éléments paramétrés en taux et avec le "Non si différents"
        If J>0 and 255-len(GWORDERWITHSFI)-len("INVDTAAMT("+num$(J-1)+") Asc;")>0
            GWORDERWITHSFI += "INVDTAAMT("+num$(J-1)+") Asc;"
        Endif
        I+=1
    Wend
  Endif
  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #Filter [CON2]
  Filter [LCON2]
  # Issue X3-74080 - 2018-02-14 by FGR : END

  If GWORDERWITHSFI<>""
    # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
    #Filter [CON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order With GWORDERWITH+GWORDERWITHSFI+GWORDERWITHLAST
    Filter [LCON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order With GWORDERWITH+GWORDERWITHSFI+GWORDERWITHLAST
    # Issue X3-74080 - 2018-02-14 by FGR : END
  Else
  #--/
    # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
    #Filter [CON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order By CONBPCINV Asc; CONBPC Asc; CONPJT Asc; CONNUM Asc
    Filter [LCON2] Where (evalue(CRITERE) & evalue (FILSUP)) Order By [F:VIME4]SORT Asc; CONNUM Asc
    # Issue X3-74080 - 2018-02-14 by FGR : END
  Endif

  For [LCON2]      # Issue X3-74080 - 2018-02-14 by FGR
    If GSZBPCBREAK <> [F:CON2]CONBPCINV or GSZOPPBREAK<>[F:CON2]CONPJT or GSZPYRBREAK<>[F:CON2]CONBPCPYR or GSZGRUBREAK<>[F:CON2]CONBPCGRU or GPRITPBREAK<>[F:CON2]CONPRITYP
&   or GSZVACBREAK<>[F:CON2]CONVACBPR
&   or GSZSFIBREAK = 1 Then :#--CPO 79550 Then

      GSZBPCBREAK = [F:CON2]CONBPCINV
      GSZCONBREAK = [F:CON2]CONNUM
      GSZOPPBREAK = [F:CON2]CONPJT
      GSZPYRBREAK = [F:CON2]CONBPCPYR   # FGR 08/04/2010 : X3SUIVI38132 : Tiers payeur
      GSZGRUBREAK = [F:CON2]CONBPCGRU   # FGR 08/04/2010 : X3SUIVI38132 : Client groupe
      GPRITPBREAK = [F:CON2]CONPRITYP   # FGR 08/04/2010 : X3SUIVI38132 : Type de prix
      GSZVACBREAK = [F:CON2]CONVACBPR   # FGR 08/04/2010 : X3SUIVI38132 : Régime de taxe
      #GSZSFIBREAK = 0 :#--CPO 79550
      #
      Raz GITERCONTRACT
      Raz GIONEXINVAMT
      Raz GDOLASINVDAT
      Raz GDONEXINVDAT
      Raz GDONEXSHIINV
      Raz GDOCONSTRDAT
      Raz GDOCONENDDAT
      Raz GIOLASVALIDX
      Raz GDOLASIDXDAT
      Raz GDORVADAT
      Raz GIOCONAMT
      Raz GIODSYWND
      GITER2CONTRACT = 0
      #
      #--CPO 79550
      WCONTINUE = 1
      If [V]GSZSFIBREAK = 1
        Read [F:CON]=[F:CON2]CONNUM
        If !fstat and ([F:CON]NEXSHIINV=[0/0/0] or [F:CON]NEXSHIINV>[V]GDIANEXSHIINV) Then
          WCONTINUE = 0
        Endif
      Endif
      If WCONTINUE = 1 Then
      #--/
          SZFILTCON5BPC = "CONBPCINV=GSZBPCBREAK and CONPJT=GSZOPPBREAK and CONBPCPYR=GSZPYRBREAK and CONBPCGRU=GSZGRUBREAK and CONPRITYP=GPRITPBREAK and CONVACBPR=GSZVACBREAK"
          #
          Read [CON]CON0=[F:CON2]CONNUM
          If !fstat Then
            GITERCONTRACT(GITER2CONTRACT) = [F:CON]CONNUM
            GIONEXINVAMT(GITER2CONTRACT) = [F:CON]NEXINVAMT
            GDOLASINVDAT(GITER2CONTRACT) = [F:CON]LASINVDAT
            GDONEXINVDAT(GITER2CONTRACT) = [F:CON]NEXINVDAT
            GDONEXSHIINV(GITER2CONTRACT) = [F:CON]NEXSHIINV
            GDOCONSTRDAT(GITER2CONTRACT) = [F:CON]CONSTRDAT
            GDOCONENDDAT(GITER2CONTRACT) = [F:CON]CONENDDAT
            GIOLASVALIDX(GITER2CONTRACT) = [F:CON]LASVALIDX
            GDOLASIDXDAT(GITER2CONTRACT) = [F:CON]LASIDXDAT
            GDORVADAT(GITER2CONTRACT) = [F:CON]RVADAT
            GIOCONAMT(GITER2CONTRACT) = [F:CON]CONAMT
            GIODSYWND(GITER2CONTRACT) = [F:CON]DSYWND
            #
            GITER2CONTRACT += 1
            Gosub DELCOX
            Gosub DELCAX
            Gosub DELCRX
            Gosub ADDCOX
            #
            [F:WCON] = [F:CON]  # FGR 25/03/2013 : X3SUIVI87947
            #Appel du composant de création facture.
            Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
            # FGR 09/11/2012 : X3SUIVI84296 (début) : on relit le contrat, il a été perdu dans GESSIH
            #                                         du coup, ça fausse le contenu des messages dans la trace.
            Read [CON]CON0=[F:CON2]CONNUM
            # FGR 09/11/2012 : X3SUIVI84296 (fin)
            If LERR Then
              Gosub IME4ERR
            Else
              NBINV += 1
              #--CPO 87923 Gestion des prélèvements SDD
              Gosub INIT_CTL_UMRNUM
              #--/
              If [M:DIA]PRNFLG=2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
                If LSIVNUM <> "" Then
                  Read [SIV] SIV0=LSIVNUM
                  If !fstat Then
                    #----- Recherche du nouveau code état à partir du modèle -----#
                    If [F:BPC]BPCNUM<>[F:SIH]BPR Then
                      Read [BPC] BPC0=[F:SIH]BPR : If fstat  Raz [F:BPC] : Endif
                    Endif
                    If [F:BPC]TPMCOD <> "" Then
                      If [F:TPM]TPMCOD <> [F:BPC]TPMCOD Then
                        Read [TPM] TPM0=[F:BPC]TPMCOD : If fstat  Raz [F:TPM] : Endif
                      Endif
                      If [F:TPM]SALINV <> "" Then
                        WARP_RPTCOD(0) = [F:TPM]SALINV
                      Else
                        WARP_RPTCOD(0) = [M:DIA]PRNNAM
                      Endif
                    Else
                      WARP_RPTCOD(0) = [M:DIA]PRNNAM
                    Endif
                    #----- Nombre de copies -----#
                    WARP_NBRCPY = [F:SIV]COPNBR
                    #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
                    Call ALIM_ETAT(1, WARP_NBRCPY, WARP_RPTCOD, WARP_NUMREQ, WARP_NUMLIG, WARP_SEQREQ) From TRTX3ETA
                    #-----
                  Endif
                Endif
              Endif
            Endif
          Endif
      Endif :#--CPO 79550
    Endif
    #
    If WCONTINUE = 1 :#--CPO 79550
      If !GSERVEUR Then
        ICONCOUNT += 1
        Call AFF_BOITE ([F:CON2]CONNUM, ICONCOUNT, ICONOK) From GESECRAN
      Endif
    Endif
  Next
  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #Filter [CON2]
  Filter [LCON2]
  # Issue X3-74080 - 2018-02-14 by FGR : END
  #
  If !GSERVEUR
    Call FERME_BOITE From GESECRAN
  Endif
Return

#-----------------------------------------------------------------------#
$OUVBOITE
  If !GSERVEUR Then
    ICONTOINV = 0
    Filter  [CON] Where (evalue(CRITERE) & evalue (FILSUP))
    For [CON]
      ICONTOINV += 1
    Next
    Filter [CON]
    #Call OUVRE_BOITE(mess(656,182,1), ICONTOINV) From GESECRAN        # FGR 17/08/2016 : X3SUIVI118071
    Call OUVRE_BOITE(mess(656,182,1), max(1,ICONTOINV)) From GESECRAN  # FGR 17/08/2016 : X3SUIVI118071
  Endif
Return

#-----------------------------------------------------------------------#
$IME4ERR
  IRESTOREOK = 1
  #La facturation du contrat n° XXXX a échoué. L'état initial du contrat n'a pas pu être restauré.
  SZMESS1 = mess(657,182,1) + " " + [F:CON]CONNUM + " " + mess(658,182,1) + " " + mess(659,182,1)
  #La facturation du contrat n° XXXX a échoué.
  SZMESS2 = mess(657,182,1) + " " + [F:CON]CONNUM + " " + mess(658,182,1)
  #Une erreur s'est produite
  #On remet le contrat en état
  Call DEBTRANS From GLOCK
  Trbegin [CON]
  Filter [COX] Where [F:COX]PRONUM = adxuid(1)
  For [COX]
    Read [CON] CON0 = [F:COX]CONNUM
    If fstat Then
      IRESTOREOK = 0
      Break
    Else
      [F:CON] = [F:COX]
      Rewrite [CON]
      If fstat Then
        IRESTOREOK = 0
        Break
      Endif
    Endif
  Next
  If IRESTOREOK Then
    Commit
  Else
    Rollback
  Endif
  #Remise en état des réévaluations
  If IRESTOREOK Then
    Call DEBTRANS From GLOCK
    Trbegin [CAM]
    Filter [CAX] Where [F:CAX]PRONUM = adxuid(1)
    For [CAX]
      Delete [CAM] Where [F:CAM]CONNUM = [F:CAX]CONNUM and [F:CAM]AMTRECNUMX = [F:CAX]AMTRECNUMX
      If fstat Then
        IRESTOREOK = 0
        Break
      Endif
    Next
    If IRESTOREOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #Remise en état des renouvellements
  If IRESTOREOK Then
    Call DEBTRANS From GLOCK
    Trbegin [CRE]
    Filter [CRX] Where [F:CRX]PRONUM = adxuid(1)
    For [CRX]
      Delete [CRE] Where [F:CRE]CONNUM = [F:CRX]CONNUM and [F:CRE]REWRECNUMX = [F:CRX]REWRECNUMX
      If fstat Then
        IRESTOREOK = 0
        Break
      Endif
    Next
    If IRESTOREOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If IRESTOREOK Then
    Call ECR_TRACE(SZMESS2,1) From GESECRAN
  Else
    Call ECR_TRACE(SZMESS1,1) From GESECRAN
  Endif
Return

#-----------------------------------------------------------------------#
$IMEERR
  IRESTOREOK = 1
  #La facturation du contrat n° XXXX a échoué. L'état initial du contrat n'a pas pu être restauré.
  SZMESS1 = mess(657,182,1) + " " + [F:CON]CONNUM + " " + mess(658,182,1) + " " + mess(659,182,1)
  #La facturation du contrat n° XXXX a échoué.
  SZMESS2 = mess(657,182,1) + " " + [F:CON]CONNUM + " " + mess(658,182,1)
  #Une erreur s'est produite
  #On remet le contrat en état
  Call DEBTRANS From GLOCK
  Trbegin [CON]
  [F:CON] = [F:CON4]
  Rewrite [CON]
  If fstat Then
    Rollback
    IRESTOREOK = 0
  Else
    Commit
  Endif
  #Remise en état des réévaluations
  If IRESTOREOK Then
    ITERRVA = 0
    For ITERRVA = 0 To dim(GSZDIACRVACAH) - 1
      If GSZDIACRVACAH(ITERRVA) = "" Then
        Break
      Else
        IRECNUMX = val(GSZDIACRVACAH(ITERRVA))
        Call DEBTRANS From GLOCK
        Trbegin [CAM]
        Delete [CAM] Where [F:CAM]CONNUM = [F:CON]CONNUM and [F:CAM]AMTRECNUMX = IRECNUMX
        If fstat Then
          Rollback
          IRESTOREOK = 0
        Else
          Commit
        Endif
      Endif
    Next
  Endif
  #Remise en état des renouvellements
  If IRESTOREOK Then
    ITERREW = 0
    For ITERREW = 0 To dim(GSZDIACREWCAH) - 1
      If GSZDIACREWCAH(ITERREW) = "" Then
        Break
      Else
        IRECNUMX = val(GSZDIACREWCAH(ITERREW))
        Call DEBTRANS From GLOCK
        Trbegin [CRE]
        Delete [CRE] Where [F:CRE]CONNUM = [F:CON]CONNUM and [F:CRE]REWRECNUMX = IRECNUMX
        If fstat Then
          Rollback
          IRESTOREOK = 0
        Else
          Commit
        Endif
      Endif
    Next
  Endif
  If IRESTOREOK Then
    Call ECR_TRACE(SZMESS2,1) From GESECRAN
  Else
    Call ECR_TRACE(SZMESS1,1) From GESECRAN
  Endif
Return

#-----------------------------------------------------------------------#
#     contrôle de la date de facture                                    #
#-----------------------------------------------------------------------#
$CTL_INVDAT
Local Decimal EXERCICE, PERIODE

  If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif
  For [PER]PER0 Where CPY=GSOCIETE & PERSTR<=WINVDAT & PEREND>=WINVDAT & LEDTYP=GTYPGEN
    EXERCICE = [F:PER]FIYNUM
    PERIODE  = [F:PER]PERNUM
  Next
  If EXERCICE=0 or PERIODE=0 Then
    GMESSAGE = mess(1,104,1) : # MSG=Date incorrecte
    mkstat = 2
    Return
  Endif
  If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
  Read [FIY]FIY0 = GSOCIETE;GTYPGEN;EXERCICE
  If fstat or [F:FIY]FIYSTA<>2 Then
    GMESSAGE = mess(20,101,1) : # MSG=Exercice non ouvert
    mkstat = 2
    Return
  Endif
  If [F:PER]PERSTA < 2 Then
    GMESSAGE = mess(35,101,1) : # MSG=Periode non ouverte
    mkstat = 2
    Return
  Endif
  If [F:PER]PERSTA > 2 Then
    GMESSAGE = mess(36,101,1) : # MSG=Période fermee
    mkstat = 2
    Return
  Endif
  #Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
  #If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : Return : Endif

# V6.2 : Certification
#----- Contrôle date pour certification NF -----#
Call CTLDAT_CNF(5,[M:DIA]SALFCY,[0/0/0],WINVDAT,"","") From CONTX3
If mkstat  Return : Endif

Return

#-----------------------------------------------------------------------#
#    Sélection des contrats à traiter                                   #
#    Gbn-Fq78211 : agrandissement du critère                            #
#-----------------------------------------------------------------------#
$SEL_CON
Local Date DEMPTYDAT

  DEMPTYDAT = [00/00/00]
  #--> critères de saisie
  CRITERE(0) = 'SALFCY ="'+[M]SALFCY+'"'
  #-- CPO 67136 : Error if the date field is not filled ("If.." added)
  If [M]NEXSHIINV<>[0/0/0]
    CRITERE(0) -= "& NEXSHIINV <= [" +format$(GFMD,[M]NEXSHIINV)+"]"
  Endif
  CRITERE(0) -= "& NEXINVDAT <> [00/00/00]"
  # FGR 12/11/2012 : X3SUIVI85217 (début)
  #  * N'est pas résilié
  #  * Est résilé mais la date de prochaine facture est supérieure à la date de résiliation
  #CRITERE(0) -= ' & RSIFLG<>2'
  #CRITERE(0) -= ' & ((RSIFLG<>2) | (RSIFLG=2 & NEXINVDAT>RSIDAT))'
  #CRITERE(0) -= ' & ((RSIFLG<>2) | (RSIFLG=2 & NEXINVDAT<=RSIDAT))'  # FGR 04/02/2013 : X3SUIVI87756
  CRITERE(0) -= ' & ((RSIFLG<>2) | (RSIFLG=2 & NEXINVDAT<RSIDAT))'    # FGR 21/11/2013 : X3SUIVI94039 : strictement inférieur
  # FGR 12/11/2012 : X3SUIVI85217 (fin)
  CRITERE(0) -= ' & FDDFLG<>2'
  CRITERE(0) -= ' & CONCAT<>1'
  CRITERE(0) -= ' & CONAMT>0'
  CRITERE(0) -= ' & ITMREF<>""'

  #--CPO 80926 Erreur sur filtre :
  If CRITERE(0)<>"" : CRITERE(1)+="& 1=1" : Endif
  If [M]CONNUMDEB <> ""  Then
    CRITERE(1) = '& CONNUM>="'+[M]CONNUMDEB+'"'
  Endif
  If [M]CONNUMFIN <> "" Then
    If CRITERE(1)<>"" : CRITERE(1)+="&" : Endif
    CRITERE(1) -= ' CONNUM<="'+[M]CONNUMFIN+'"'
  Endif
  If [M]BPCINVDEB <> "" Then
    If CRITERE(1)<>"" : CRITERE(1)+="&" : Endif
    CRITERE(1) -= ' CONBPCINV>="'+[M]BPCINVDEB+'"'
  Endif
  If [M]BPCINVFIN <> "" Then
    If CRITERE(1)<>"" : CRITERE(1)+="&" : Endif
    CRITERE(1) -= ' CONBPCINV<="'+[M]BPCINVFIN+'"'
  Endif

  # V6.2 : Certification
  # Si ctrl date documents : Le contrat doit avoir une date <= à la date de la facture
  If GCTLDATORI=2 & [M:DIA]INVDATFLG=1
    If CRITERE(1)<>"" : CRITERE(1)+="&" : Endif
    #CRITERE(1) -='[F:CON]CONSTRDAT<=[M:DIA]INVDATINV'  # Issue 119001 - 2016-10-26 by FGR : Remove the abrev.
    CRITERE(1) -='CONSTRDAT<=[M:DIA]INVDATINV'          # Issue 119001 - 2016-10-26 by FGR : Remove the abrev.
  Endif

  #---------------------------------------------------------------------#
  # Point d'entree ajout filtres supplémentaires                        #
  #---------------------------------------------------------------------#
  Gosub PE_AUTINVCFIL From TRTCRMPE

Return

#########################################################################
$TERMINE_TRTAUTINVC
  #On nettoie CONTSERVX, CONTAMTX et CONTREWX
  Gosub DELCOX
  Gosub DELCAX
  Gosub DELCRX
  If NBINV Then
    If [M:DIA]PRNFLG=2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
      If [M:DIA]DSYFLG = 2 Then
        Call PRINT_ETAT (1,WARP_NUMREQ,"PREVISU") From TRTX3ETA
      Else
        Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]PRNDEN) From TRTX3ETA
      Endif
    Endif
  Endif
  If !GSERVEUR  Then
    # --> fermeture trace
    If !NBINV Then
      Call ECR_TRACE(mess(463,197,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
    # --> aucune commande à traiter ou lecture trace
    If !NBINV Then
       GERR = 2
       GMESSAGE = mess(463,197,1)
    Endif
    TRA = 1
  Endif
Return

#-----------------------------------------------------------------------#
#    Ouvre                                                              #
#-----------------------------------------------------------------------#
$OUVRE
Local Char    LNUM(GLONVCR)
Local Integer OK, STAT, NBINV, NBPOSTE
Local Char    TIT(50), CRITERE(250)(2), CRITDET(150)
Local Char    WMESS(80), WMESS1(80), WMESS2(80)

Local Integer WRET, LIN, WSOHLIN, WSIHLIN, WSIHACV, LINFLG

Local Char    WKEY(20), WKEY1(66), WNUM(GLONVCR), WDATA(250)
Local Char    WIME(1)
Local Decimal MNTCALC
Local Char    WTRANSAC(GLONGAU), WIDENT(GLONGTE), WJOURNAL(GLONJOU)
Local Date    WINVDAT
Local Char    WBPINAM(GLONNAM)

  TIT = mess(440,182,1)
  #---------------------------------------#
  # Ouverture des fichiers utilisés       #
  #---------------------------------------#
  If clalev([F:TCA]) = 0 Local File TABCOUAFF   [TCA] : Endif
  If clalev([F:TSV]) = 0 Local File TABSIVTYP   [TSV] : Endif
  If clalev([F:SWI]) = 0 Local File SWRKINV     [SWI] : Endif
  If clalev([F:SIH]) = 0 Local File SINVOICE    [SIH] : Endif
  If clalev([F:SIV]) = 0 Local File SINVOICEV   [SIV] : Endif
  If clalev([F:SID]) = 0 Local File SINVOICED   [SID] : Endif
  If clalev([F:WSID]) = 0 Local File SINVOICED [WSID] : Endif  # FGR 25/03/2013 : X3SUIVI87947
  If clalev([F:SVF]) = 0 Local File SVCRFOOT    [SVF] : Endif
  If clalev([F:SVV]) = 0 Local File SVCRVAT     [SVV] : Endif

  If clalev([F:CAX]) = 0 Local File CONTAMTX    [CAX] : Endif
  If clalev([F:CAM]) = 0 Local File CONTAMT     [CAM] : Endif
  If clalev([F:CRX]) = 0 Local File CONTREWX    [CRX] : Endif
  If clalev([F:CRE]) = 0 Local File CONTREW     [CRE] : Endif
  If clalev([F:COX]) = 0 Local File CONTSERVX   [COX] : Endif
  If clalev([F:CON]) = 0 Local File CONTSERV    [CON] : Endif
  If clalev([F:WCON]) = 0 Local File CONTSERV   [WCON] : Endif  # FGR 25/03/2013 : X3SUIVI87947
  If clalev([F:CON2]) = 0 Local File CONTSERV    [CON2] : Endif
  If clalev([F:CON3]) = 0 Local File CONTSERV    [CON3] : Endif
  If clalev([F:CON4]) = 0 Local File CONTSERV    [CON4] : Endif
  If clalev([F:CON5]) = 0 Local File CONTSERV    [CON5] : Endif
  If clalev([F:SOH]) = 0 Local File SORDER      [SOH] : Endif
  If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ] : Endif
  If clalev([F:SOP]) = 0 Local File SORDERP     [SOP] : Endif
  If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [BPC] : Endif
  If clalev([F:BPD]) = 0 Local File BPDLVCUST   [BPD] : Endif
  If clalev([F:BPR]) = 0 Local File BPARTNER    [BPR] : Endif
  If clalev([F:MVC]) = 0 Local File BPCUSTMVT   [MVC] : Endif
  If clalev([F:LCM]) = 0 Local File LASTCUSMVT  [LCM] : Endif
  If clalev([F:CAL]) = 0 Local File CPTANALIN   [CAL] : Endif

  If clalev([F:GTE]) = 0 Local File GTYPACCENT  [GTE] : Endif
  If clalev([F:CAC]) = 0 Local File GACCCODE    [CAC] : Endif
  If clalev([F:GAC]) = 0 Local File GACCOUNT    [GAC] : Endif
  If clalev([F:GAU]) = 0 Local File GAUTACE     [GAU] : Endif
  If clalev([F:GAG]) = 0 Local File GAUTACEF    [GAG] : Endif
  If clalev([F:ANM]) = 0 Local File ACODNUM     [ANM] : Endif
  If GMODU(2)=2                :  # 105566 : Ajout test présence module compta
      If clalev([F:JOU])= 0 Local File GJOURNAL [JOU] : Endif
  Endif                        :  # 105566

  If clalev([F:GCM]) = 0 Local File GACM        [GCM] : Endif

  If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM] : Endif
  If clalev([F:ITS]) = 0 Local File ITMSALES    [ITS] : Endif
  If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF] : Endif
  If clalev([F:TMD]) = 0 Local File TABMODELIV  [TMD] : Endif
  If clalev([F:PER]) = 0 Local File PERIOD      [PER] : Endif

  If clalev([F:ARP]) = 0 Local File AREPORT     [ARP] : Endif
  If clalev([F:ARM]) = 0 Local File AREPORTM    [ARM] : Endif
  If clalev([F:ACV]) = 0 Local File ACTIV       [ACV] : Endif

  If clalev([F:CPY]) = 0 : Local File COMPANY   [CPY] : Endif   # 106867.n

  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  If clalev([F:VIME4]) = 0 Local File VCONTIME4 [VIME4] : Endif
  Link [CON2] With [VIME4]VIME40=[F:CON2]CONNUM As [LCON2]
  Link [CON3] With [VIME4]VIME40=[F:CON3]CONNUM As [LCON3]
  Link [CON4] With [VIME4]VIME40=[F:CON4]CONNUM As [LCON4]
  Link [CON5] With [VIME4]VIME40=[F:CON5]CONNUM As [LCON5]
  # Issue X3-74080 - 2018-02-14 by FGR : END

  #Call GETDEV(GFCYDEF(5)) From DEVSUB
  # --> Chargement globales référenciels, comptes et sections de la société
  Raz GSOC_ACTIVE
  GFCY=GFCYDEF(5)
  Gosub CHARG_PARAM
  # ------------------------------------------- #
  # Récupération des paramêtres de vente        #
  # ------------------------------------------- #
  Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3
  # --> Vérification Type de facture utilisateur
  Gosub VERF_SIVTYP
  # Raz [M:DIA]
Return

#######################################################################
Funprog GET_CRIT_SEL_CON

Local Char SARENDRE(250)

  # FGR 18/06/2012 : X3SUIVI82627
  Raz SARENDRE
  #SARENDRE = "GCTLDATORI<>2 | (GCTLDATORI=2 & (([M]INVDATFLG = 1 & [F:CON]CONSTRDAT<=[M]INVDATINV)))"

  SARENDRE  = "GCTLDATORI<>2 |"
  SARENDRE += "("
  SARENDRE +=    "GCTLDATORI=2 &"
  SARENDRE +=    "("
  SARENDRE +=    "([M]INVDATFLG = 1 & [F:CON]CONSTRDAT<=[M]INVDATINV) |"
  SARENDRE +=    "([M]INVDATFLG <> 1)"
  SARENDRE +=    ")"
  SARENDRE += ")"
End SARENDRE

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
########################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
## --> Alimentation GSOCIETE,GFINRSP,GLOCALDEV
#Call GETDEV(VALEUR) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
If GFCY<>VALEUR : GFCY=VALEUR : Gosub CHARG_PARAM Endif
# --> Récupération des paramêtres de vente
Call GLOBVAR(VALEUR,"VEN") From TRTX3
# --> Vérif.Type de facture utilisateur : Législation identique à la législation du site
Gosub VERF_SIVTYP
[M]SIVTYP=GSIVTYP : Affzo [M]SIVTYP
End
########################################
Subprog AP_INVDATFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    If [M]INVDATINV = [0/0/0]
        [M]INVDATINV = date$
    Endif
    Affzo [M]INVDATINV
    Actzo [M]INVDATINV
Else
    Raz [M]INVDATINV
    Affzo [M]INVDATINV
    Grizo [M]INVDATINV
Endif
End
########################################
Subprog C_INVDATINV(VALEUR)
Variable Date    VALEUR
Local    Date    WINVDAT

#--CPO 75310 Before doing the control...
If GSOCIETE<>[M]CPY or GFCY<>[M]SALFCY
  # --> Chargement globales référenciels, comptes et sections de la société
  GFCY=[M]SALFCY : Gosub CHARG_PARAM
  # --> Récupération des paramêtres de vente
  Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif
#--CPO

If [M]INVDATFLG = 2  End Endif
WINVDAT=VALEUR
If VALEUR <> [0/0/0] Gosub CTL_INVDAT Endif
End
########################################
# ----------------------------------- CONNUMDEB ---------------------------------
Subprog AM_CONNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]CONNUMFIN = VALEUR : Endif
End
########################################
# ----------------------------------- BPCINVDEB ---------------------------------
Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]BPCINVFIN = VALEUR : Endif
End
########################################
Subprog AP_PRNFLG(VALEUR)
Variable Integer VALEUR
Local Integer IOBLIG

If VALEUR = 1
   Raz [M]PRNNAM, [M]PRNDEN, [M]PRNIMP, [M]PRNSRV
   [M]DSYFLG = 1
   Diszo [M]PRNNAM, PRNDEN
Else
   If vireblc([M]PRNNAM,2)=""
        Call INIT_ARP("SIH", [M:DIA]PRNNAM) From TRTVENIMP
        Actzo [M]PRNNAM, PRNDEN
   Endif
Endif
Affzo [M]PRNNAM, PRNDEN, PRNIMP, PRNSRV, DSYFLG
End
########################################
Subprog C_PRNNAM(VALEUR)
Variable Char    VALEUR()

# Document obligatoire si impression facture
If [M:DIA]PRNFLG = 2 & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
   End
Endif
End
########################################
Subprog C_PRNSRV(VALEUR)
Variable Char    VALEUR()
Gosub CTL_SRV From TRTVENIMP
End
########################################
Subprog C_PRNIMP(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
#If [M:DIA]PRNNAM <> "" & VALEUR = ""
#   GMESSAGE=mess(10,123,1) : mkstat = 2
#Endif
End
##########################################################################
Subprog AM_PRNIMP(VALEUR)
Variable Char    VALEUR()

If VALEUR = "PREVISU"
    [M]DSYFLG = 2
Else
    [M]DSYFLG = 1
Endif

[M]PRNIMP = VALEUR
Affzo [M]PRNIMP, DSYFLG
End
##########################################################################
Subprog AM_DSYFLG(VALEUR)
Variable Integer VALEUR
Local Integer IOBLIG
IOBLIG = 0

If VALEUR = 2
    [M]PRNIMP = "PREVISU"
Else
    If [M]PRNNAM <> ""
        Call DEFIMP([M]PRNNAM,GUSER,"",[M]PRNDEN,IOBLIG) From IMPRIME
    Endif
Endif

[M]DSYFLG = VALEUR
Affzo [M]DSYFLG, PRNIMP
End

###########################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

########################################################################
#    pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIH4
#    Actions appelées dans le TRTVENFACG
########################################################################
$ACTION_GS
  Case GWACTION_GS
    When "READ_DETAIL"
      Gosub READ_DETAIL
    When "AP_READ_DETAIL"
      Gosub AP_READ_DETAIL
    When "MSK_ENTETE"
      Gosub MSK_ENTETE
    When "MSK_DETAIL"
      Gosub MSK_DETAIL
    When "ERREUR"
      Gosub ERREUR
    When "AP_VERIF_CRE"
      Gosub AP_VERIF_CRE
    When "CREATION"
      Gosub CREATION
  Endcase
Return

#-----------------------------------------------------------------------
# Chargement des ecrans entete de facture
#-----------------------------------------------------------------------
$MSK_ENTETE
  Case IMPZON
    When "SIVTYP"
      IMPMOD=1
      [M]SIVTYP = GDIAINVTYP
    When "SALFCY"
      Gosub SETSALFCY
    When "INVDAT"
      Gosub SETINVDAT
    When "INVREF"
      # FGR 26/02/2009 : CONORITXT est inutile
      #If [F:CON]CONORIVCR<>"" & [F:CON]CONORITXT=mess(2,2977,1) Then
      If [F:CON]CONORIVCR <> "" and [F:CON]CONORI = 2 Then
        Gosub LEC_SOH
        If [F:SOH]CUSORDREF<>"" Then
          [M]INVREF=[F:SOH]CUSORDREF
          IMPMOD=1
        Endif
      Endif
    When "BPAADD"
      # FGR 26/02/2009 : CONORITXT est inutile
      #If [F:CON]CONORIVCR<>"" and [F:CON]CONORITXT=mess(2,2977,1) Then
      If [F:CON]CONORIVCR <> "" and [F:CON]CONORI = 2 Then
        Gosub LEC_SOH
        If [F:SOH]BPAADD <> "" Then
          [M]BPAADD = [F:SOH]BPAADD
          IMPMOD = 1
        Endif
      Endif
    When "BPCINV"
      Gosub SETBPCINF From TRTSIHCON
    When "PJT"
      IMPMOD=1
      [M]PJT=[F:CON]CONPJT
    When "CUR"
      IMPMOD=1
      [M]CUR=[F:CON]CUR
      [M]CURTYP = [F:CON]CONCHGTYP     # FGR 26/10/2015 : X3SUIVI112020
    When "PTE"
      IMPMOD=1
      [M]PTE=[F:CON]PTE
    When "REP"
      Case indice
        When 0
          [M]REP(0)=[F:CON]SALREP(0)
        When 1
          [M]REP(1)=[F:CON]SALREP(1)
      Endcase
    When "INVDTAAMT"
      #Gosub SETINVDTA From TRTSIHCON #--CPO 79550 Nouvelle règle de transfert : Contrats de services -> Factures
    When "VACBPR"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]VACBPR = [F:CON]CONVACBPR
    When "BPCORD"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCORD = [F:CON]CONBPC
    When "BPCGRU"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCGRU = [F:CON]CONBPCGRU
    When "BPRPAY"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPRPAY = [F:CON]CONBPCPYR
    When "PRITYP"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]PRITYP = [F:CON]CONPRITYP
    When "CURTYP"  # FGR 26/10/2015 : X3SUIVI112020 et pas "CHGTYP"
      # FGR 06/11/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]CURTYP = [F:CON]CONCHGTYP  # FGR 26/10/2015 : X3SUIVI112020 et pas "CHGTYP"
    When "STRDATSVC"
      # FGR 12/03/2009 : X3SUIVI28408 : chargement dates début/fin période prestation  pour CCA/FCA
      IMPMOD = 1
      [M]STRDATSVC = [F:CON]CONSTRDAT
    When "ENDDATSVC"
      # FGR 12/03/2009 : X3SUIVI28408 : chargement dates début/fin période prestation  pour CCA/FCA
      IMPMOD = 1
      [M]ENDDATSVC = [F:CON]CONENDDAT
    When "CCE"
      #FQ68364 Axes lignes Contrat de service vers facture
      #Chargement des sections analytiques entête facture à partir du contrat
      Call CHARG_CCEH("SIH2","NBAXE","CON") From TRTX3CPT
      #Initialisation sections analytiques vides
      If dim([M:SIH2]NBAXE)>0
          Local Char SECTION(GLONCCE)

          For I=1 To GNBDIE
              #If [F:SIH]CCE(I-1)=""
              If [M:SIH2]CCE(I-1)=""
                  [F:SIH]DIE(I-1)=GDIE(I)
                  [M:SIH2]DIE(I-1)=GDIE(I)
                  Call INISEC(SECTION, "SIH", GDIE(I)) From SUBCDE
                  [F:SIH]CCE(I-1) = SECTION
                  [M:SIH2]CCE(I-1) = SECTION
              Endif
          Next I
      Endif
      #fin FQ68364
    When "UMRNUM"
      #--CPO 87923 Gestion des prélèvements SDD
      #--Le champ est paramétré comme obligatoire, il faut pouvoir créer la facture avec un avertissement

      #--/
  Endcase
Return

#--------------------------------------------------------------------------------
# Lecture entête commande vente pour alimentation des zones venant de la commande
#--------------------------------------------------------------------------------
$LEC_SOH
  If [F:SOH]SOHNUM <> [F:CON]CONORIVCR
    Read [SOH]SOH0 = [F:CON]CONORIVCR
    If fstat Then
      Raz [F:SOH]
    Endif
  Endif
Return

#-----------------------------------------------------------------------
$SETSALFCY
  IMPMOD=1
  #LSE 03/10/2006 FQ37877
  #If [M]SALFCY = ""
    [M]SALFCY = GDIASALFCY
  #Endif
Return

#-----------------------------------------------------------------------
$SETINVDAT
  IMPMOD=1
  If GDIAINVDATFLG = 1
    [M]INVDAT=GDIAINVDAT
  Else
    [M]INVDAT=[F:CON]NEXINVDAT
  Endif
Return

#-----------------------------------------------------------------------
$READ_DETAIL
  # FGR 29/06/2012 : X3SUIVI81775
  nolign = 0
  LIG_DETAIL = "C"
  Case GIDIAIMEFLG
    When 1
      # ------------------------------------------------------------------------------------------------
      # Echéance unique
      If LEC_DETAIL = 0
        Local Integer OKREP

        OKREP = 1
        #Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
        Call SETSIHPRICE(GIDIANEXINVAMT) From SUBCONB2
        GSZDIAITMREF = [F:CON]ITMREF
        GSZDIACONNUM = [F:CON]CONNUM
        # ------------------------------------------------------------------------------------------------
        #Gosub CALCUL_FIN_PERIODE      # FGR 27/08/2015 : X3SUIVI110592
        If [F:CON]INVMET <> 2 Then     # FGR 26/08/2015 : X3SUIVI110592
          Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
        Endif                          # FGR 26/08/2015 : X3SUIVI110592
        # ------------------------------------------------------------------------------------------------
        Call INVCPTCON([F:CON]CONNUM, 0, OKREP) From SUBCONB1
        If OKREP
          LEC_DETAIL = 1
        Else
          LEC_DETAIL = 3
        Endif
        # ------------------------------------------------------------------------------------------------
        If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
          Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
        Endif                          # FGR 26/08/2015 : X3SUIVI110592
        If [F:CON]INVMET = 2 Then
          Gosub CALCUL_DEBUT_PERIODE
        Endif
        # ------------------------------------------------------------------------------------------------
        Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
      Else
        LEC_DETAIL = 2
      Endif
      # ------------------------------------------------------------------------------------------------
    When 2
      # ------------------------------------------------------------------------------------------------
      # 1 fac/échéance
      If LEC_DETAIL = 0
        Local Integer OKREP

        OKREP = 1
        #Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
        Call SETSIHPRICE(GIDIANEXINVAMT) From SUBCONB2
        GSZDIAITMREF = [F:CON]ITMREF
        GSZDIACONNUM = [F:CON]CONNUM
        # ------------------------------------------------------------------------------------------------
        #Gosub CALCUL_FIN_PERIODE      # FGR 27/08/2015 : X3SUIVI110592
        If [F:CON]INVMET <> 2 Then     # FGR 26/08/2015 : X3SUIVI110592
          Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
        Endif                          # FGR 26/08/2015 : X3SUIVI110592
        # ------------------------------------------------------------------------------------------------
        Call INVCPTCON([F:CON]CONNUM, 0, OKREP) From SUBCONB1
        If OKREP
          LEC_DETAIL = 1
        Else
          LEC_DETAIL = 3
        Endif
        # ------------------------------------------------------------------------------------------------
        If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
          Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
        Endif                          # FGR 26/08/2015 : X3SUIVI110592
        If [F:CON]INVMET = 2 Then
          Gosub CALCUL_DEBUT_PERIODE
        Endif
        # ------------------------------------------------------------------------------------------------
        Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
      Else
        LEC_DETAIL = 2
      Endif
      # ------------------------------------------------------------------------------------------------
    When 3
      # ------------------------------------------------------------------------------------------------
      # 1 fac/contrat
      Local Integer OKREP

      OKREP = 1
      #Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
      Call SETSIHPRICE(GIDIANEXINVAMT) From SUBCONB2
      GSZDIAITMREF = [F:CON]ITMREF
      GSZDIACONNUM = [F:CON]CONNUM
      # ------------------------------------------------------------------------------------------------
      #Gosub CALCUL_FIN_PERIODE      # FGR 27/08/2015 : X3SUIVI110592
      If [F:CON]INVMET <> 2 Then     # FGR 26/08/2015 : X3SUIVI110592
        Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
      Endif                          # FGR 26/08/2015 : X3SUIVI110592
      # ------------------------------------------------------------------------------------------------
      Call INVCPTCON([F:CON]CONNUM, 0, OKREP) From SUBCONB1
      If OKREP
        If [F:CON]NEXINVDAT = [00/00/00]
          LEC_DETAIL = 2
        Else
          If [F:CON]NEXSHIINV <= GDIANEXSHIINV
            LEC_DETAIL = 1
          Else
            LEC_DETAIL = 2
          Endif
        Endif
        GIDIASIH4STOP = LEC_DETAIL
        LEC_DETAIL = 1
      Else
        LEC_DETAIL = 3
      Endif
      # ------------------------------------------------------------------------------------------------
      If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
        Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
      Endif                          # FGR 26/08/2015 : X3SUIVI110592
      If [F:CON]INVMET = 2 Then
        Gosub CALCUL_DEBUT_PERIODE
      Endif
      # ------------------------------------------------------------------------------------------------
      Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
    When 4
      # ------------------------------------------------------------------------------------------------
      # 1 fac/client
      Local Integer OKREP

      OKREP = 1
      #Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
      Call SETSIHPRICE(GIDIANEXINVAMT) From SUBCONB2
      GSZDIAITMREF = [F:CON]ITMREF
      GSZDIACONNUM = [F:CON]CONNUM
      # ------------------------------------------------------------------------------------------------
      #Gosub CALCUL_FIN_PERIODE      # FGR 27/08/2015 : X3SUIVI110592
      If [F:CON]INVMET <> 2 Then     # FGR 26/08/2015 : X3SUIVI110592
        Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
      Endif                          # FGR 26/08/2015 : X3SUIVI110592
      # ------------------------------------------------------------------------------------------------
      Call INVCPTCON([F:CON]CONNUM, 0, OKREP) From SUBCONB1
      If OKREP
        #--CPO 79550
        #--Il faut le faire dans le READ_DETAIL avant appel à BPCCONTROL car positionne
        #--le F:CON sur le contrat suivant
        #--Dans le cas où GIDIAIMEFLG=4
        Gosub CON_SIH_PLUS From TRTSIHCON
        #--/
        If [F:CON]NEXINVDAT = [00/00/00]
          Gosub BPCCONTROL
        Else
          If [F:CON]NEXSHIINV <= GDIANEXSHIINV
            GIDIASIH4STOP = LEC_DETAIL
            LEC_DETAIL = 1
            If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
              Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
            Endif                          # FGR 26/08/2015 : X3SUIVI110592
            # FGR 17/03/2013 : X3SUIVI90341 (début)
            If [F:CON]INVMET = 2 Then
              Gosub CALCUL_DEBUT_PERIODE
            Endif
            # FGR 17/03/2013 : X3SUIVI90341 (fin)
          Else
            If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
              Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
            Endif                          # FGR 26/08/2015 : X3SUIVI110592
            # FGR 17/03/2013 : X3SUIVI90341 (début)
            If [F:CON]INVMET = 2 Then
              Gosub CALCUL_DEBUT_PERIODE
            Endif
            # FGR 17/03/2013 : X3SUIVI90341 (fin)
            Gosub BPCCONTROL
          Endif
        Endif
      Else
        LEC_DETAIL = 3
        If [F:CON]INVMET = 2 Then      # FGR 26/08/2015 : X3SUIVI110592
          Gosub CALCUL_FIN_PERIODE     # FGR 26/08/2015 : X3SUIVI110592
        Endif                          # FGR 26/08/2015 : X3SUIVI110592
        # FGR 17/03/2013 : X3SUIVI90341 (début)
        If [F:CON]INVMET = 2 Then
          Gosub CALCUL_DEBUT_PERIODE
        Endif
        # FGR 17/03/2013 : X3SUIVI90341 (fin)
      Endif
      # ------------------------------------------------------------------------------------------------
      # FGR 17/03/2013 : X3SUIVI90341 (début)
      #If [F:CON]INVMET = 2 Then
      #  Gosub CALCUL_DEBUT_PERIODE
      #Endif
      # FGR 17/03/2013 : X3SUIVI90341 (fin)
      # ------------------------------------------------------------------------------------------------
      Gosub SETITMDATDES   # FGR 15/04/2013 : X3SUIVI89258 à faire en dernier
  Endcase
  # ------------------------------------------------------------------------------------------------
  # FGR 25/07/2013 : X3SUIVI90904 (début)
  If [F:CON]RSIFLG = 2 Then
    # Si le contrat a été résilié, on contrôle les dates
    If GDTDIADATEND > [F:CON]RSIDAT Then
      # Si la date de fin de période est > à la date de résiliation : on ne facture par l'échéance
      If [F:CON]RSIDAT >= GDTDIADATSTR Then
        # Si la date de résiliation est dans la période, on prend l'échéance
      Else
        # Sinon, on ne la prend plus
        LEC_DETAIL = 2
      Endif
    Endif
  Endif
  # FGR 25/07/2013 : X3SUIVI90904 (fin)
  # ------------------------------------------------------------------------------------------------
Return

#########################################################################
$CALCUL_DEBUT_PERIODE
  # FGR 29/06/2012 : X3SUIVI81775
  If [F:CON]INVMET = 1 Then
    # Pré-facturation (terme à échoir)
    # On facture au début donc de la période :
    #     * La (date de prochaine facture) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de PROCHAINE prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    If [F:CON]NEXINVDAT <> [0/0/0] Then
      # Si le contrat a déjà été facturé, le début de la période commence au lendemain
      GDTDIADATSTR = [F:CON]NEXINVDAT
    Else
      # ... Sinon, elle commence au début du contrat
      GDTDIADATSTR = [F:CON]CONSTRDAT
    Endif
  Else
    # Post-facturation (terme échu)
    # On facture à la fin de la période :
    #     * La (date de dernière facture +1) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    # FGR 25/03/2013 : X3SUIVI87947 (début)
    # FGR 17/03/2013 : X3SUIVI90341 (début)
    #If [F:CON]OLASINVDAT <> [0/0/0] Then
    #  If clalev([F:WSID]) = 0 Local File SINVOICED [WSID] : Endif
    #  Filter [F:WSID] Where [F:WSID]CONNUM=[F:CON]CONNUM Order By [F:WSID]INVDAT Desc; [F:WSID]NUM Asc
    #  If rowcount([F:WSID]) = 0 Then
    #    [F:CON]OLASINVDAT = [0/0/0]
    #  Endif
    #  Filter [F:WSID]
    #Endif
    Read [F:CON]CON0=[F:CON]CONNUM
    # D'abord on regarde si des échéances du contrat existent dans la facture en cours...
    NE = -1
    For NI = [M:SIH4]NBLIG-1 To 0 Step -1
      If [M:SIH4]CONNUM(NI) = [F:CON]CONNUM Then
        NE = NI
        [F:CON]OLASINVDAT = [M:SIH4]ENDDAT(NI) + 1
        Break
      Endif
    Next NI
    If NE = -1 Then
      # ... et si non, on cherche dans les factures déjà émises.
      If [F:CON]OLASINVDAT <> [0/0/0] Then
        If clalev([F:WSID]) = 0 Local File SINVOICED [WSID] : Endif
        #Filter [F:WSID] Where [F:WSID]CONNUM=[F:CON]CONNUM Order By [F:WSID]INVDAT Desc; [F:WSID]NUM Asc
        Filter [F:WSID] Where [F:WSID]CONNUM=[F:CON]CONNUM Order By [F:WSID]ENDDAT Desc; [F:WSID]NUM Asc
        For [F:WSID]
          #[F:CON]OLASINVDAT = [F:WSID]INVDAT
          [F:CON]OLASINVDAT = [F:WSID]ENDDAT + 1
          Break
        Next
        Filter [F:WSID]
      Endif
    Endif
    # FGR 17/03/2013 : X3SUIVI90341 (fin)
    # FGR 25/03/2013 : X3SUIVI87947 (fin)
    # ---------------------------------------------------------------------------------
    If [F:CON]OLASINVDAT <> [0/0/0] Then
      # Si le contrat a déjà été facturé, le début de la période commence au lendemain
      GDTDIADATSTR = [F:CON]OLASINVDAT
    Else
      # ... Sinon, elle commence au début du contrat
      #GDTDIADATSTR = [F:CON]CONSTRDAT
      GDTDIADATSTR = [F:WCON]CONSTRDAT   # FGR 25/03/2013 : X3SUIVI87947
    Endif
  Endif
Return

#########################################################################
$CALCUL_FIN_PERIODE
  # FGR 29/06/2012 : X3SUIVI81775
  If [F:CON]INVMET = 1 Then
    # Pré-facturation (terme à échoir)
    # On facture au début donc de la période :
    #     * La (date de prochaine facture) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de PROCHAINE prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    Gosub CALCUL_DEBUT_PERIODE
    Call SNEXINVDAT([F:CON]NEXINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, GDTDIADATEND) From SUBCOND
    #If GDTDIADATEND <> [0/0/0] Then                                                               # FGR 07/10/2015 : X3SUIVI111228
    #If GDTDIADATEND <> [0/0/0] and GDTDIADATEND <= [F:CON]CONENDDAT Then                          # FGR 07/10/2015 : X3SUIVI111228
    # Note X3SUIVI113219 : Les contrats à points arrivent soit à leur terme, soit sont refacturés lorsque
    # le crédit de points est épuisé. La date de fin les concernant est donc obligatoirement la date de fin de contrat.
    If GDTDIADATEND <> [0/0/0] and GDTDIADATEND <= [F:CON]CONENDDAT and [F:CON]CONCAT <> 4 Then    # FGR 17/12/2015 : X3SUIVI113219
      # C'est la veille de la PROCHAINE prochaine facture
      GDTDIADATEND =  GDTDIADATEND - 1
    Else
      # S'il n'en n'a pas, c'est qu'il se termine, et la fin est la fin du contrat
      GDTDIADATEND = [F:CON]CONENDDAT
    Endif
  Else
    # Post-facturation (terme échu)
    # On facture à la fin de la période :
    #     * La (date de dernière facture +1) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    #If [F:CON]NEXINVDAT <> [0/0/0] Then                                                 # FGR 07/10/2015 : X3SUIVI111228
    #If [F:CON]NEXINVDAT <> [0/0/0] and [F:CON]NEXINVDAT <= [F:CON]CONENDDAT Then        # FGR 07/10/2015 : X3SUIVI111228
    If [F:CON]ONEXINVDAT <> [0/0/0] and [F:CON]ONEXINVDAT <= [F:CON]CONENDDAT Then       # FGR 25/08/2016 : X3SUIVI114499
      # S'il n'en n'a pas, c'est qu'il se termine, et la fin est la fin du contrat
      #GDTDIADATEND = [F:CON]NEXINVDAT - 1                                               # FGR 25/08/2016 : X3SUIVI114499
      GDTDIADATEND = [F:CON]ONEXINVDAT - 1                                               # FGR 25/08/2016 : X3SUIVI114499
    Else
      # Sinon, c'est la veille de la prochaine facture la fin de la période
      GDTDIADATEND =  [F:CON]CONENDDAT
    Endif
  Endif
Return

#########################################################################
$BPCCONTROL
Local Integer IBPCFOUND
#--CPO 79550 Nouvelle règle de transfert : Contrats de services -> Factures
Local Integer IOK_SFI_GRUFLG
Local Integer ISFI,ISFI2
Local Decimal DTAAMTCMP,DTAAMTCMP2
Local Char    TSTRUL
Local Integer WEXIST_PREV_INV,WEXIST_PREV_INV2
Local Char SAV_GSZCONBREAK(GLONVCR)
Local Tinyint WT_BRDRUL
#--/
  IBPCFOUND = 0
  IOK_SFI_GRUFLG = 1            :#--CPO 79550
  SAV_GSZCONBREAK = GSZCONBREAK :#--CPO 79550

  #Recherche du contrat suivant
  #--CPO 79550
  If dim(GWORDERWITHSFI)>0 and GWORDERWITHSFI<>""
    # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
    #Filter [CON3] Where (evalue(GDIACRITERE) & evalue (GDIAFILSUP) & evalue(GSZFILTINVBPC)) Order With GWORDERWITH+GWORDERWITHSFI+GWORDERWITHLAST
    Filter [LCON3] Where (evalue(GDIACRITERE) & evalue (GDIAFILSUP) & evalue(GSZFILTINVBPC)) Order With GWORDERWITH+GWORDERWITHSFI+GWORDERWITHLAST
    # Issue X3-74080 - 2018-02-14 by FGR : END
  Else
  #--/
    # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
    #Filter [CON3] Where (evalue(GDIACRITERE) & evalue (GDIAFILSUP) & evalue(GSZFILTINVBPC)) Order By CONBPC Asc;CONPJT Asc;CONNUM Asc
    Filter [LCON3] Where (evalue(GDIACRITERE) & evalue (GDIAFILSUP) & evalue(GSZFILTINVBPC)) Order By [F:VIME4]SORT Asc;CONNUM Asc
    # Issue X3-74080 - 2018-02-14 by FGR : END
  Endif

  GSZSFICTL = 0
  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #For [CON3]
  For [LCON3]
  # Issue X3-74080 - 2018-02-14 by FGR : END
    #--CPO 107376 F:CON3
    #If [F:CON]CONBPCINV = GSZBPCBREAK and [F:CON]CONPJT = GSZOPPBREAK Then
    If [F:CON3]CONBPCINV = GSZBPCBREAK and [F:CON3]CONPJT = GSZOPPBREAK Then
    #--/
      GSZCONBREAK = [F:CON3]CONNUM
      IBPCFOUND = 1
    Endif
    #--CPO 79550
    #--------------------------------------------------------------
    If IBPCFOUND = 1 and clalev([M:SFIT])>0 and [F:CON]CONNUM<>[F:CON3]CONNUM
      #--Il faut avant tout vérifier si le contrat n'a pas une échéance déjà facturée
      WEXIST_PREV_INV = func SUBSIHC.CON_CHECK_EXIST_PREV_INV([F:CON]CONNUM,"")
      WEXIST_PREV_INV2= func SUBSIHC.CON_CHECK_EXIST_PREV_INV([F:CON3]CONNUM,"")
      For ISFI=0 To dim([M:SIH2]INVDTA) - 1
          If [M:SIH2]INVDTA(ISFI) = 0 : Break : Endif
          If [M:SIH2]INVDTATYP(ISFI) = 3 : # %
              # Recherche Param concernant Doc Ori et Dest
              TSTRUL = num$([M:SIH2]INVDTA(ISFI)) + "~23~4"
              ISFI2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

              If ISFI2>=0 and [M:SFIT]T_GRUFLG(ISFI2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
                  WT_BRDRUL = [M:SFIT]T_BRDRUL(ISFI2)
                  #--CPO Détermination du montant à comparer venant du contrat à venir
                  If WT_BRDRUL=3 and WEXIST_PREV_INV=[V]CST_ATRUE : # eclaté sur 1ere facture
                      DTAAMTCMP=0
                  Else
                      #DTAAMTCMP=[M:SIH2]INVDTAAMT(ISFI)
                      ISFI2 = find ( [M:SIH2]INVDTA(ISFI) , [F:CON]INVDTA )
                      If ISFI2>0
                        DTAAMTCMP = [F:CON]INVDTAAMT(ISFI2-1)
                      Else
                        DTAAMTCMP = 0
                      Endif
                  Endif

                  #--CPO Détermination du montant à comparer venant du contrat courant
                  If WT_BRDRUL=3 and WEXIST_PREV_INV2=[V]CST_ATRUE : # eclaté sur 1ere facture
                      DTAAMTCMP2=0
                  Else
                      #DTAAMTCMP=[M:SIH2]INVDTAAMT(ISFI)
                      ISFI2 = find ( [M:SIH2]INVDTA(ISFI) , [F:CON3]INVDTA )
                      If ISFI2>0
                        DTAAMTCMP2 = [F:CON3]INVDTAAMT(ISFI2-1)
                      Else
                        DTAAMTCMP2 = 0
                      Endif
                  Endif

#                  ISFI2 = find ( [M:SIH2]INVDTA(ISFI) , [F:CON3]INVDTA )
#                  If ISFI2>0 and [F:CON3]INVDTAAMT(ISFI2-1) <> DTAAMTCMP
                   If DTAAMTCMP<>DTAAMTCMP2
                      IOK_SFI_GRUFLG = 0
                      #--On ne doit pas regrouper,
                      #--On continue à chercher l'échéance suivante compatible
                      GSZCONBREAK = SAV_GSZCONBREAK
                      GSZSFIBREAK = 1
                      Raz IBPCFOUND
                      Break
                  Endif
              Endif
          Endif
      Next I
    Endif
    #--------------------------------------------------------------
    #--/
    #--CPO 79550
    #Break
    If IOK_SFI_GRUFLG = 1
      Break
    Endif
    #--/
  Next
  # Issue X3-74080 - 2018-02-14 by FGR : BEGIN
  #Filter [CON3]
  Filter [LCON3]
  # Issue X3-74080 - 2018-02-14 by FGR : END
  If IBPCFOUND Then
    Read [CON]CON0=GSZCONBREAK
    If fstat Then
      LEC_DETAIL = 3
      Return
    Else
      [F:WCON] = [F:CON]  # FGR 17/06/2013 : X3SUIVI90341

      GITERCONTRACT(GITER2CONTRACT) = [F:CON]CONNUM

      GIONEXINVAMT(GITER2CONTRACT) = [F:CON]NEXINVAMT
      GDOLASINVDAT(GITER2CONTRACT) = [F:CON]LASINVDAT
      GDONEXINVDAT(GITER2CONTRACT) = [F:CON]NEXINVDAT
      GDONEXSHIINV(GITER2CONTRACT) = [F:CON]NEXSHIINV
      GDOCONSTRDAT(GITER2CONTRACT) = [F:CON]CONSTRDAT
      GDOCONENDDAT(GITER2CONTRACT) = [F:CON]CONENDDAT
      GIOLASVALIDX(GITER2CONTRACT) = [F:CON]LASVALIDX
      GDOLASIDXDAT(GITER2CONTRACT) = [F:CON]LASIDXDAT
      GDORVADAT(GITER2CONTRACT) = [F:CON]RVADAT
      GIOCONAMT(GITER2CONTRACT) = [F:CON]CONAMT
      GIODSYWND(GITER2CONTRACT) = [F:CON]DSYWND

      GITER2CONTRACT += 1
      GIAUTINVCFLG = 1
      LEC_DETAIL=1
    Endif
  Else
    LEC_DETAIL=2
  Endif
  GIDIASIH4STOP = LEC_DETAIL
  LEC_DETAIL = 1
Return

#-----------------------------------------------------------------------
$AP_READ_DETAIL

  If GIDIAIMEFLG > 2 Then
    LEC_DETAIL = GIDIASIH4STOP
  Endif

Return

#-----------------------------------------------------------------------
$MSK_DETAIL
  Case IMPZON
     When "ITMREF"
       Gosub SETITMCON
       #--CPO 79550
       #--Il faut le faire dans le READ_DETAIL avant appel à BPCCONTROL car positionne
       #--le F:CON sur le contrat suivant
       #--Dans le cas où GIDIAIMEFLG=4
       #--De toute façon, il n'utilise pas les infos du détail, mais de l'en-tête à l'origine du détail
       If GIDIAIMEFLG<>4
         Gosub CON_SIH_PLUS From TRTSIHCON
       Endif
       #--/
     When "SAU"
       Gosub SETSAUCON
     When "QTY"
       Gosub SETQTYCON
     When "GROPRI"
       Gosub SETPRICON
     When "STRDAT"
       # FGR 08/04/2010 : X3SUIVI38132 : chargement dates début/fin période prestation  pour CCA/FCA
       IMPMOD = 1
       [M]STRDAT(nolign-1) = GDTDIADATSTR
     When "ENDDAT"
       # FGR 08/04/2010 : X3SUIVI38132 : chargement dates début/fin période prestation  pour CCA/FCA
       IMPMOD = 1
       [M]ENDDAT(nolign-1) = GDTDIADATEND
     When "DPJT"
       # FGR 28/11/2011 : X3SUIVI71065
       IMPMOD = 1
       [M]DPJT(nolign-1) = [F:CON]CONPJT
  Endcase
  # pour avoir le no. de la ligne et la reference article dans l'erreur
  GCLE = mess(3,40,1)-num$(nolign)-mess(18,7,1)-[M]ITMREF(nolign-1)
Return

#FGR 15/04/2013 : X3SUIVI89258 (début)
###########################################################################################
$SETITMDATDES
  If GIDIATYPITMDES = 2 Then
    If [F:CON]CONCAT = 4 Then
      GSZDIAITMDATDES = ""
    Else
      Local Char SZITMDATDEB(50)
      Local Char SZITMDATFIN(50)
      Local Date DITMDATDEB
      Local Date DITMDATFIN

      Case [F:CON]INVMET
        When 1, 2
          SZITMDATDEB = format$(GFMDAT4, GDTDIADATSTR)
          SZITMDATFIN = format$(GFMDAT4, GDTDIADATEND)
          GSZDIAITMDATDES = SZITMDATDEB + " -> " + SZITMDATFIN
        When Default
          GSZDIAITMDATDES = ""
      Endcase
    Endif
  Else
    GSZDIAITMDATDES = ""
  Endif
Return

###########################################################################################
$SETITMCON
  IMPMOD = 1
  [M]ITMREF(nolign-1) = GSZDIAITMREF
  [M]CONNUM(nolign-1) = GSZDIACONNUM
  Gosub SETPRICON
Return

###########################################################################################
$SETQTYCON
  IMPMOD = 1
  [M]QTY(nolign-1)=1
  Gosub SETPRICON
  If GSZDIAITMDATDES <> "" Then
    [M]ITMDES(nolign-1) = GSZDIAITMDATDES
  Endif
Return

###########################################################################################
$SETSAUCON
  IMPMOD = 1
  Read [ITM]ITM0=GSZDIAITMREF
  If !fstat Then
    [M]SAU(nolign-1) = [F:ITM]SAU
  Endif
  Gosub SETPRICON
Return

###########################################################################################
$SETPRICON
  IMPMOD = 1
  [M]GROPRI(nolign-1) = GIDIANEXINVAMT
Return

#-----------------------------------------------------------------------
$AP_VERIF_CRE
  If GIDIAIMEFLG = 4 Then
    If GIAUTINVCFLG Then
      [M]SIHORINUM = ""
    Endif
  Endif
Return

#-----------------------------------------------------------------------
# Tables mises a jour lors de la creation de facture
# (on est dans une transaction : en cas d'erreur positionner GOK)
#-----------------------------------------------------------------------
$CREATION
Local Integer OKREP
Local Integer ITERCONTRACT

  OKREP = 1
  ITERCONTRACT = 0
  Case GIDIAIMEFLG
    When 1
      # Echéance unique
      # FGR 11/10/2013 : X3SUIVI92393 (début)
      For ITERCONTRACT = 0 To [M:SIH4]NBLIG-1
        If [F:CON]CONNUM <> [M:SIH4]CONNUM(ITERCONTRACT) Then
          Read [CON]CON0=[M:SIH4]CONNUM(ITERCONTRACT)
          If fstat Then
            Call RSTA ("CON", [M:SIH4]CONNUM(ITERCONTRACT)) From GLOCK
            GOK = 0
          Endif
        Endif
        [F:CON]OINV = [M:SIH0]NUM
        Rewrite [CON]
        If fstat Then
          GOK = 0
          Call FSTA("CON") From GLOCK
        Endif
      Next ITERCONTRACT
      # FGR 11/10/2013 : X3SUIVI92393 (fin)
    When 2
      # 1 fac/échéance
      # FGR 11/10/2013 : X3SUIVI92393 (début)
      For ITERCONTRACT = 0 To [M:SIH4]NBLIG-1
        If [F:CON]CONNUM <> [M:SIH4]CONNUM(ITERCONTRACT) Then
          Read [CON]CON0=[M:SIH4]CONNUM(ITERCONTRACT)
          If fstat Then
            Call RSTA ("CON", [M:SIH4]CONNUM(ITERCONTRACT)) From GLOCK
            GOK = 0
          Endif
        Endif
        [F:CON]OINV = [M:SIH0]NUM
        Rewrite [CON]
        If fstat Then
          GOK = 0
          Call FSTA("CON") From GLOCK
        Endif
      Next ITERCONTRACT
      # FGR 11/10/2013 : X3SUIVI92393 (fin)
    When 3
      # 1 fac/contrat
      Call MAJOLDOINV([F:CON]CONNUM, 0, 0, 1, OKREP) From SUBCONB1
      If !OKREP Then
        Call RSTA ("CON",[F:CON]CONNUM) From GLOCK
        GOK = 0
      Endif
    When 4
      # 1 fac/client
      For ITERCONTRACT = 0 To dim(GITERCONTRACT)-1
        If GITERCONTRACT(ITERCONTRACT) = "" Then
          Break
        Else
          Call MAJOLDOINV(GITERCONTRACT(ITERCONTRACT), 1, ITERCONTRACT, 1, OKREP) From SUBCONB1
          If !OKREP Then
            Call RSTA ("CON",[F:CON]CONNUM) From GLOCK
            GOK = 0
            Break
          Endif
        Endif
      Next
  Endcase
Return

#-----------------------------------------------------------------------
$ERREUR
Return

####################################################################
$CLEANCOX
Local Integer I, J
Local Integer WADXUID(1..1000)
Local Integer WDIM
Local Integer WTRBEGIN : Raz WTRBEGIN
Local Integer IERRINFCOX

  IERRINFCOX = 0
  Call UIDADX(WADXUID,WDIM) From TRTX3
  Raz I, J
  # Si pas de transaction en cours
  If adxlog <> 1 Then
    Trbegin [COX]
    WTRBEGIN=1
  Endif
  Filter [COX] Where [F:COX]PRONUM <> 0
  For [COX]
    If !find([F:COX]PRONUM,WADXUID(1..WDIM)) Then
      Delete [COX] Curr
      If fstat Then
        IERRINFCOX = 1
        Break
      Endif
    Endif
  Next
  Filter [COX]
  # Si on a ouvert une transaction
  If WTRBEGIN = 1 Then
    If IERRINFCOX Then
      Rollback
      Return
    Endif
  Endif
  # Si on a ouvert une transaction
  Delete [COX] Where [F:COX]PRONUM = adxuid(1)
  If fstat Then
    If WTRBEGIN = 1 Then
      Rollback
    Endif
  Else
    If WTRBEGIN = 1 Then
      Commit
    Endif
  Endif
  Raz WTRBEGIN
Return

####################################################################
$DELCOX
Local Integer WTRBEGIN
Local Integer IERRINFCOX

  WTRBEGIN = 0
  IERRINFCOX = 0
  If adxuid(1) = 0 Then
    Return
  Endif
  # Si pas de transaction en cours
  If adxlog <> 1 Then
    Trbegin [COX]
    WTRBEGIN=1
  Endif
  Delete [COX] Where [F:COX]PRONUM = adxuid(1)
  If fstat Then
    If WTRBEGIN = 1 Then
      Rollback
    Endif
  Else
    If WTRBEGIN = 1 Then
      Commit
    Endif
  Endif
  Raz WTRBEGIN
Return

####################################################################
$CLEANCAX
