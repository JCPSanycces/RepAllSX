#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM005 - Reset UIF status         #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Update created period(DATCRE) and final exit(DATXITFNL) on contract.") From LECFIC
    Call MAJ_UTIHRM010(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIHRM010(DOSSIER)
Value Char DOSSIER
Local Char CODE (GLONACV)
Local Integer WRITECOUNT, WRITEERROR

  Call ECR_TRACE("UTIHRM010 : Start update on : "+DOSSIER,0) From GESECRAN
  # ------------------------------------
  Local File =DOSSIER+".ACTIV" [ACVHR]
  # ------------------------------------
  WRITEERROR = 0

  Read [ACVHR]CODACT = "KGZA"
  If fstat
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code KGZA does not exist on : "+DOSSIER,1) From GESECRAN
    Return
  Elsif  [F:ACVHR]FLACT <> 2
      Call ECR_TRACE("UTIHRM005: Process aborted as activity code KGZA is inactive on : "+DOSSIER,1) From GESECRAN
     Return
  Endif

  Read [ACVHR]CODACT = "FHRPA"

  If fstat
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code FHRPA does not exist on : "+DOSSIER,1) From GESECRAN
    Return
  Elsif  [F:ACVHR]FLACT <> 2
      Call ECR_TRACE("UTIHRM005: Process aborted as activity code FHRPA is inactive on : "+DOSSIER,1) From GESECRAN
     Return
  Endif


Local File =DOSSIER+".EMPLOCTR" [HRCTR]


Trbegin [HRCTR]

 For [HRCTR]

    If [HRCTR]DATANC <> [00/00/00] Then
        [HRCTR]DATCRE = [HRCTR]DATANC
    Endif

    If [HRCTR]XITDAT <> [00/00/00]  and [HRCTR]DATXITFNL=2 Then
        [HRCTR]DATXITFNL = [HRCTR]XITDAT
    Endif

    Rewrite [F:HRCTR]

    If fstat Then
       WRITECOUNT = 0
       WRITEERROR = 1
    Else
        WRITECOUNT +=1
    Endif

    If WRITEERROR = 1 Then
        Break
    Endif

  Next


    If WRITEERROR Then
      Rollback
      Call ECR_TRACE("UTIHRM010: Process aborted due to write failure to EMPLOCTR on : "+DOSSIER,0) From GESECRAN
    Else
      Commit
      Call ECR_TRACE("UTIHRM010: Process completed on : "+DOSSIER+" - Records affected "+num$(WRITECOUNT),0) From GESECRAN
    Endif

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------

  If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTR") : End : Endif

  # -------------------------
  Call MAJ_UTIHRM010(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTR") : End : Endif

  Call MAJ_UTIHRM010(APPLI)
End

