#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:25"
A_USER  = "DOC"
A_STAMP = "20181109230425"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "PARNBR"
  If [M]PARNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENHREXT2 [HREXE2]
Gosub HORODAT
Local Inpbox "GENHREXT2" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE2] As [SIM_]
Grizo [HREXE2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXE2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_PARDTALVL
Onevent INIT_AREA Call D_PARDTALVL(zc) From W1GENHREXT2
Return

Subprog D_PARDTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]PARDTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PARDTACLC
Return

$ON_PARTYP
Return

$ON_PARMDT
Onevent INIT_AREA Call D_PARMDT(zc) From W1GENHREXT2
Return

Subprog D_PARMDT(VALEUR)
Variable Integer VALEUR
If varinit([M]PARMDT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PARVALTYP
Onevent INIT_AREA Call D_PARVALTYP(zc) From W1GENHREXT2
Return

Subprog D_PARVALTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]PARVALTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PARDEFDEB
Return

$ON_PARDEFFIN
Return

$ON_PARVALDEB
Onevent BEFORE_INPUT Call AS_PARVALDEB(zc) From W1GENHREXT2
Onevent CONTROL Call C_PARVALDEB(zc) From W1GENHREXT2
Return

Subprog IB_PARVALDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,[M:HREXE2]PARTYP(nolign-1),[M:HREXE2]PARNBRLIB(nolign-1),"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_PARVALDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_PARVALDEB(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,[M:HREXE2]PARTYP(nolign-1)) From FMTVAR
If mkstat=2
 [M]PARVALDEB(INDIC) = VALEUR
 Affzo PARVALDEB(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PARVALDEB(zc) From W1GENHREXT2
Onkey   2 Titled GBOUTS Call S_PARVALDEB(zc) From W1GENHREXT2
Gosub _AFF
End

Subprog C_PARVALDEB(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,[M:HREXE2]PARTYP(nolign-1),[M:HREXE2]PARNBRLIB(nolign-1),[M:HREXE2]PARLNG(nolign-1),[M:HREXE2]VALINT1(nolign-1)) From FMTVAR
If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M:HREXE2]VALINT1(nolign-1),[M:HREXE2]PARTYP(nolign-1),"","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
 If !mkstat
  ## Action STD
  Call C_PARVALDEB(VALEUR) From TRTGENHREX
  If mkstat : GERR = 1 : GZONE = "PARVALDEB" : GZNUM = 7928 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_PARVALDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M:HREXE2]PARTYP(nolign-1)
 PARMSK(2) = num$([M:HREXE2]PARNBRLIB(nolign-1))
 PARMSK(3) = num$([M:HREXE2]PARLNG(nolign-1))
 PARMSK(4) = [M:HREXE2]VALINT1(nolign-1)
 PARMSK(5) = [M:HREXE2]PARVAL(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:HREXE2]VALINT1(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M:HREXE2]PARTYP(nolign-1)
 PARMSK(2) = num$([M:HREXE2]PARNBRLIB(nolign-1))
 PARMSK(3) = num$([M:HREXE2]PARLNG(nolign-1))
 PARMSK(4) = [M:HREXE2]VALINT1(nolign-1)
 PARMSK(5) = [M:HREXE2]PARVAL(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:HREXE2]VALINT1(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PARVALDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = [M:HREXE2]PARTYP(nolign-1)
 PARMSK(2) = [M:HREXE2]PARVAL(nolign-1)
 PARMSK(3) = num$([M:HREXE2]PARNBRLIB(nolign-1))
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PARVALFIN
Onevent BEFORE_INPUT Call AS_PARVALFIN(zc) From W1GENHREXT2
Onevent CONTROL Call C_PARVALFIN(zc) From W1GENHREXT2
Return

