Onkey 129 Titled GBOUT1 Call B1_PARVALFIN(zc) From W1GENHREXT2
Onkey   2 Titled GBOUTS Call S_PARVALFIN(zc) From W1GENHREXT2
Gosub _AFF
End

Subprog C_PARVALFIN(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,[M:HREXE2]PARTYP(nolign-1),[M:HREXE2]PARNBRLIB(nolign-1),[M:HREXE2]PARLNG(nolign-1),[M:HREXE2]VALINT2(nolign-1)) From FMTVAR
If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M:HREXE2]VALINT2(nolign-1),[M:HREXE2]PARTYP(nolign-1),"","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
 If !mkstat
  ## Action STD
  Call C_PARVALFIN(VALEUR) From TRTGENHREX
  If mkstat : GERR = 1 : GZONE = "PARVALFIN" : GZNUM = 7929 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_PARVALFIN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M:HREXE2]PARTYP(nolign-1)
 PARMSK(2) = num$([M:HREXE2]PARNBRLIB(nolign-1))
 PARMSK(3) = num$([M:HREXE2]PARLNG(nolign-1))
 PARMSK(4) = [M:HREXE2]VALINT2(nolign-1)
 PARMSK(5) = [M:HREXE2]PARVAL(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:HREXE2]VALINT2(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M:HREXE2]PARTYP(nolign-1)
 PARMSK(2) = num$([M:HREXE2]PARNBRLIB(nolign-1))
 PARMSK(3) = num$([M:HREXE2]PARLNG(nolign-1))
 PARMSK(4) = [M:HREXE2]VALINT2(nolign-1)
 PARMSK(5) = [M:HREXE2]PARVAL(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:HREXE2]VALINT2(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

