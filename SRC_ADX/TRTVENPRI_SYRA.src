#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------#
# Sous-prog CALCNETPRI : Calcul du prix net         FQ 47040    #
#                                                               #
#    Idem CLCNETPRI (+ ajout du code MSK)                       #
#---------------------------------------------------------------#
# Entrée  MSK      : Masque écran à mettre à jour [M] par défaut#
#         QTY      : Quantite                                   #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Funprog CALCNETPRI(QTY, CUR, MYDOC, MYDOCLIN)
Value    Decimal QTY
Value    Char    CUR
Value    Instance MYDOC    Using OBJECT
Variable Instance MYDOCLIN Using OBJECT

Local Integer  WRET
Local Decimal  AMTDISCRG(1..9)
Local Char     WMESSAGE(250)

Raz AMTDISCRG
Raz WMESSAGE

WRET = func CALCNETPRI_DETAILS(QTY, CUR, MYDOC, MYDOCLIN, AMTDISCRG, WMESSAGE)

End [L]WRET
#---------------------------------------------------------------#
# Sous-prog CALCNETPRI : Calcul du prix net         FQ 47040    #
#                                                               #
#    Idem CLCNETPRI (+ ajout du code MSK)                       #
#---------------------------------------------------------------#
# Entrée  MSK      : Masque écran à mettre à jour [M] par défaut#
#         QTY      : Quantite                                   #
#         CUR      : Devise                                     #
#         NLIG     : Numéro de la ligne (nolign-1)              #
#---------------------------------------------------------------#
Funprog CALCNETPRI_DETAILS(QTY, CUR, MYDOC, MYDOCLIN, AMTDISCRG,WMESS)
Value    Decimal QTY
Value    Char    CUR
Value    Instance MYDOC    Using OBJECT
Variable Instance MYDOCLIN Using OBJECT
Variable Decimal  AMTDISCRG(1..)
Variable Char     WMESS

Local Decimal  GROPRI,NETPRI#,MAJREM(1..9)
Local Shortint I
#Local Char WMESS(250)
Local Char WFCY(GLONFCY)

Local Integer WRET

If MYDOC=null or MYDOCLIN=null : End [V]CST_AERROR : Endif

# Si l'on est sur une ligne d'avoir en valeur, pas de calcul du prix net
If dim(MYDOC.INVTYP)>0 & MYDOC.INVTYP=2 & MYDOCLIN.QTY=0 End Endif

GROPRI=MYDOCLIN.GROPRI
If dim(MYDOCLIN.C_DISCRG)>0
  If maxtab(MYDOCLIN.C_DISCRG)>0
    Local Decimal MAJREM(1..maxtab(MYDOCLIN.C_DISCRG))
  Else
    Local Decimal MAJREM(1..9)
  Endif
  For I=1 To maxtab(MYDOCLIN.C_DISCRG)
      If MYDOCLIN.C_DISCRG(I)<>null and dim(MYDOCLIN.C_DISCRG(I).DISCRGVAL)>0
         MAJREM(I)=MYDOCLIN.C_DISCRG(I).DISCRGVAL
      Else
         MAJREM(I)=0
      Endif
  Next I
Elsif dim(MYDOC.C_DISCRG)>0
  If maxtab(MYDOC.C_DISCRG)>0
    Local Decimal MAJREM(1..maxtab(MYDOC.C_DISCRG))
  Else
    Local Decimal MAJREM(1..9)
  Endif
  For I=1 To maxtab(MYDOC.C_DISCRG)
      If MYDOC.C_DISCRG(I)<>null and dim(MYDOC.C_DISCRG(I).DISCRGVAL)>0
         MAJREM(I)=MYDOC.C_DISCRG(I).DISCRGVAL
      Else
         MAJREM(I)=0
      Endif
  Next I
Elsif dim(MYDOCLIN.DISCRGVAL1)>0
  Local Decimal MAJREM(1..9)
  MAJREM(1)=MYDOCLIN.DISCRGVAL1
  If dim(MYDOCLIN.DISCRGVAL2)>0 : MAJREM(2)=MYDOCLIN.DISCRGVAL2 : Endif
  If dim(MYDOCLIN.DISCRGVAL3)>0 : MAJREM(3)=MYDOCLIN.DISCRGVAL3 : Endif
  If dim(MYDOCLIN.DISCRGVAL4)>0 : MAJREM(4)=MYDOCLIN.DISCRGVAL4 : Endif
  If dim(MYDOCLIN.DISCRGVAL5)>0 : MAJREM(5)=MYDOCLIN.DISCRGVAL5 : Endif
  If dim(MYDOCLIN.DISCRGVAL6)>0 : MAJREM(6)=MYDOCLIN.DISCRGVAL6 : Endif
  If dim(MYDOCLIN.DISCRGVAL7)>0 : MAJREM(7)=MYDOCLIN.DISCRGVAL7 : Endif
  If dim(MYDOCLIN.DISCRGVAL8)>0 : MAJREM(8)=MYDOCLIN.DISCRGVAL8 : Endif
  If dim(MYDOCLIN.DISCRGVAL9)>0 : MAJREM(9)=MYDOCLIN.DISCRGVAL9 : Endif
Else
  End [V]CST_AERROR
Endif

If dim(MYDOCLIN.FOCFLG)>0
  If MYDOCLIN.FOCFLG = 3 : End WRET : Endif
Endif

# --> Calcul du prix net
#If dim(GCALNETLIN)>0 : GCALNETLIN=NLIG+1   : Endif
#If dim(GCALNETABR)>0 : GCALNETABR=WMSK     : Endif

If dim(MYDOCLIN.STOFCY)>0
  WFCY = MYDOCLIN.STOFCY
Elsif dim(MYDOC.FCY)>0
  WFCY = MYDOC.FCY
Elsif dim(MYDOC.PURSALFCY)>0
  WFCY = MYDOC.PURSALFCY
Endif

If dim(MYDOC.PLISTC)>0  : # ne pas utiliser WMSK ici
  Call CALNET_DETAILS(MYDOC.ACTX, WFCY,1,MYDOC.PLISTC, GROPRI,MAJREM,QTY,NETPRI,CUR,AMTDISCRG,WRET,WMESS) From TRTPRICE_SYRA
  #Call CALNET(MYDOC.ACTX, WFCY,1,MYDOC.PLISTC, GROPRI,MAJREM,QTY,NETPRI,CUR,WRET,WMESS) From TRTPRICE_SYRA
Else
  Call CALNET_DETAILS(MYDOC.ACTX, WFCY,1,""          , GROPRI,MAJREM,QTY,NETPRI,CUR,AMTDISCRG,WRET,WMESS) From TRTPRICE_SYRA
  #Call CALNET_DETAILS(MYDOC.ACTX, WFCY,1,"", GROPRI,MAJREM,QTY,NETPRI,CUR,WRET,WMESS) From TRTPRICE_SYRA
Endif

#[M]NETPRI(NLIG) = NETPRI
If dim(MYDOCLIN.NETPRI)>0
  MYDOCLIN.NETPRI = [L]NETPRI
Endif
# --> Si netpri = 0 : Pas de passage dans le calcul de la marge
#                     Les prix ne seront pas recalculés : Il faut les raz
If NETPRI = 0
   #[M]NETPRINOT(NLIG) = 0
   #[M]NETPRIATI(NLIG) = 0
   If dim(MYDOCLIN.NETPRINOT)>0
     #Raz MYDOCLIN.NETPRINOT
     MYDOCLIN.NETPRINOT = 0  #AVOID.ADEC
   Endif
   If dim(MYDOCLIN.NETPRIATI)>0
     #Raz MYDOCLIN.NETPRIATI
     MYDOCLIN.NETPRIATI = 0  #AVOID.ADEC
   Endif
Endif
End [L]WRET
