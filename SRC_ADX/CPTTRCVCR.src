##################################################################################
# DECLARE
#   Common Variables Declaration
# TRC_VCR  
#
# AP_TRCVCR
#
# DEL_GTT
#
# KEY_FIELD
#
##################################################################################

$DECLARE

Local Integer TRC_LIGAUT      : ## number of lines' Automatic Journals / numéro de ligne de la pièce automatique
Local Integer TRC_EVE         : ## number of events' Automatic Journals / numéro d'événement pour une ligne de pièce automatique


Local Integer TRCCAS          : ## 1 : Table Elements Déclencheurs ([TB9])  =   Table déclenchante ([TB0]) 
                              : ## 2 : Table Elements Déclencheurs ([TB9])  <>  Table déclenchante ([TB0]) 

Local Decimal NBRKEYTB0       : # Nombre de clé index 1 de [TB0]
Local Decimal NBRKEYTB9       : # Nombre de clé [TB9] + index paramètré sous GESGAU associé à [TB9]
Local Decimal NBRKEY          : # Nombre de clé [TB9]

Local Char PKEYTB0(GLONAVA)(1..20)  # Champs de l'index de la table [TB0]
Local Char PKEYTB9(GLONAVA)(1..20)  # Champs de l'index de la table [TB9]

Local Char    TRCABRFIC(30)
Local Char    VKEY(50)

Local Char TBL(GLONATB), LIK(120), IDX(GLONANX)

If clalev([F:TB9]) : Close File [TB9] : Endif

Read [ATI]NUMLIG(2) = [F:GAU]TRCTBL;1
If fstat : Return : Endif

If [F:GAU]TRCTBL=[F:GAU]TBL & ([F:GAU]TRCKEY=[F:GAU]KEYTBL or [F:GAU]TRCKEY=[F:ATI]CODIND)

 TRCCAS = 1 
 # Elements déclencheurs identique
 Read [ATI]CODIND = [F:GAU]TRCTBL;[F:GAU]TRCKEY
 If fstat : Return : Endif
 Call KEY_FIELD([F:ATI]DESCRIPT,PKEYTB0,NBRKEYTB0)
 [L]TRCABRFIC ="TB0"
 [L]TBL = [F:GAU]TBL
 [L]LIK = [F:ATI]DESCRIPT
 [L]IDX = [F:GAU]TRCKEY

Else

 TRCCAS = 2
 # Table des élements déclencheurs <> Table déclenchante
# Read [ATI]NUMLIG(2) = [F:GAU]TBL;[F:GAU]KEYTBL
# If fstat : Return : Endif
 Call KEY_FIELD([F:ATI]DESCRIPT,PKEYTB0,NBRKEYTB0)

 Read [ATI]CODIND = [F:GAU]TRCTBL;[F:GAU]TRCKEY
 If fstat : Return : Endif
 Call KEY_FIELD([F:ATI]DESCRIPT,PKEYTB9,NBRKEYTB9)
 If clalev([F:TB9])  = 0 : Local File =[F:GAU]TRCTBL [TB9] : Endif
 [L]TRCABRFIC ="TB9"
 [L]TBL = [F:GAU]TRCTBL
 [L]LIK = [F:ATI]DESCRIPT
 [L]IDX = [F:GAU]TRCKEY

Endif

Return

##################################################################################
$TRCVCR
If clalev([F:DAT8])=0 : Return : Endif

If [L]TRCCAS = 1 
 [L]NBRKEY = [L]NBRKEYTB0
Else
 Gosub READ_TB9
 If fstat : Return : Endif 

 [L]NBRKEY = [L]NBRKEYTB9
Endif

If [L]NBRKEY = 0 : Return : Endif


#---  Gestion du numéro de séquence pour un événement
#If TRC_LIGAUT <> [F:GAD]LINNUM
#  TRC_EVE = 1
#Else
# If NBRKEY=1
#  If [F:GTT]KEY1 = num$(evalue("[F:"+[L]TRCABRFIC+"]"+evalue("PKEY"+[L]TRCABRFIC+"(1)")))
#   TRC_EVE = TRC_EVE+1
#  Else
#   TRC_EVE = 1
#  Endif
# Else
#  I=1
#  While I<=NBRKEY
#   If evalue("[F:GTT]KEY"+num$(I)) = num$(evalue("[F:"+[L]TRCABRFIC+"]"+evalue("PKEY"+[L]TRCABRFIC+"(I)")))
#    I+=1
#   Else
#    Break
#   Endif
#  Wend
#  If I=NBRKEY
#   TRC_EVE = TRC_EVE+1
#  Else
#   TRC_EVE = 1
#  Endif
# Endif
#Endif
TRC_EVE+=1

#--- Enregistrement
Raz [F:GTT]
[F:GTT]CODACE    = [F:GAU]COD
[F:GTT]LINCODACE = [F:GAD]LINNUM

If NBRKEY=1
 
 [F:GTT]KEY1       = num$(evalue("[F:"+[L]TRCABRFIC+"]"+evalue("PKEY"+[L]TRCABRFIC+"(1)")))
 [F:GTT]SUMKEY = [F:GTT]KEY1
Else

 I=1
 While I<=NBRKEY
  Assign "[F:GTT]KEY"+num$(I) With num$(evalue("[F:"+[L]TRCABRFIC+"]"+evalue("PKEY"+[L]TRCABRFIC+"(I)")))
  [F:GTT]SUMKEY += num$(evalue("[F:"+[L]TRCABRFIC+"]"+evalue("PKEY"+[L]TRCABRFIC+"(I)")))
  I+=1
 Wend

Endif
 
TRC_LIGAUT       = [F:GTT]LINCODACE
[F:GTT]NUMORD    = TRC_EVE
[F:GTT]VCRNUM    = NBVAL
[M]TRCLIG(NOL)   = NOL+1
[F:GTT]LIN       = NOL+1
[F:GTT]SNS       = [L]SENS
[F:GTT]CUR       = [M:HAE1]CUR
[F:GTT]AMTCUR    = [L]MONTLIG
[F:GTT]UIDUSR    = adxuid(2)
Write [GTT]
If fstat
 GOK=0 : Call FSTA("GTT") From GLOCK
Endif
If GOK<1 : STAT = 20 : Return : Endif
#If GTRACE<>""
#Call ECR_TRACE([F:GTT]COD-[F:GTT]KEY1-[F:GTT]KEY2-[F:GTT]KEY3-[F:GTT]KEY4-[F:GTT]KEY5-[F:GTT]KEY6-[F:GTT]KEY7-[F:GTT]KEY8-[F:GTT]KEY9-[F:GTT]KEY10-
#&            num$([F:GTT]LINCODACE)-num$([F:GTT]VCRNUM)-num$([F:GTT]LIN)-num$([F:GTT]NUMORD)-num$(MONTLIG)-[L]SENS,-1)  From GESECRAN
#Endif
Return

##################################################################################
$AP_TRCVCR
If clalev([F:DAT8])=0 : Return : Endif

TRC_EVE = 1
For [GTT]GTT1(4) Where CODACE = [F:GAU]COD & VCRNUM = NBVAL & UIDUSR  = adxuid(2)
 Filter [DAT8] Where TYP = [M:HAE0]TYP & NUM = [M:HAE0]NUM & LEDTYP = GTYPGEN & TRCLIG = [F:GTT]LIN 
 Read [DAT8]DAT0 First
 Filter [DAT8]
 If !fstat
  ## Conserver un historique des lignes d'écritures qui sont regroupées
  For [GTT]GTT1(5)
   Raz [F:GAT]
   [F:GAT] = [F:GTT]
   [F:GAT]VCRTYP = [M:HAE0]TYP
   [F:GAT]VCRNUM = [M:HAE0]NUM 
   [F:GAT]ACCNUM = [F:DAT8]ACCNUM
   [F:GAT]NUMORD = TRC_EVE
   Raz [F:GAT]AMTCUR
   For [GTT]GTT1
    [F:GAT]AMTCUR += [F:GTT]AMTCUR*[F:GTT]SNS
   Next
   If [F:GAT]AMTCUR<0 : [F:GAT]SNS = -1 : Else : [F:GAT]SNS = +1 : Endif
   [F:GAT]AMTCUR = abs([F:GAT]AMTCUR)
   [F:GAT]GAU       = [F:GTT]CODACE
   [F:GAT]TBL       = [L]TBL
   [F:GAT]LIK       = [L]LIK
   [F:GAT]IDX       = [L]IDX

   Write [GAT]
   If fstat
    GOK=0 : Call FSTA("GAT") From GLOCK : Break
   Endif
   TRC_EVE += 1
  Next
 Endif
Next
If GOK<1 : STAT = 20 : Return : Endif
Return

##################################################################################
$DEL_GTT
## Effacement de la table temporaire
Delete [GTT] Where UIDUSR=adxuid(2)  
If fstat=1  
 GOK=-1 : GLOCK = "GAUTRCTMP"-num$(adxuid(2)) : Return
Endif 
Return

##################################################################################
Subprog KEY_FIELD(PKEY,TABKEY,NB)
Value    Char    PKEY()
Variable Char    TABKEY()(1..)
Variable Decimal NB

Local Char    WKEY1(120), WKEY2(120)
Local Integer I1,I2

NB = 0
WKEY1 = PKEY
While WKEY1<>""
 I1 = instr(1,WKEY1,"+")
 I2 = instr(1,WKEY1,"-")
 If I2
  If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
 Endif
 If I1 
  WKEY2 = left$(WKEY1,I1-1)
  WKEY1 = right$(WKEY1,I1+1)
 Else
  WKEY2 = WKEY1
  WKEY1 = ""
 Endif
 NB += 1
 TABKEY(NB) = WKEY2
Wend
End

##################################################################################
$READ_TB9
If [L]NBRKEYTB9=0 : Return : Endif
For I=1 To NBRKEYTB9
 If TRCCAS= 2 
  VKEY = num$(evalue("[F:TB0]"+PKEYTB9(I)))
 Else
  VKEY = num$(evalue("[F:GAT]KEY"+num$(I)))
 Endif
 Case evalue("type([F:"+[L]TRCABRFIC+"]"+PKEYTB9(I)+")")
  When 1,2,4,5,6,7,8,9
   Assign "[F:"+[L]TRCABRFIC+"]"+PKEYTB9(I) With val(VKEY)
  When 3
   If VKEY="" : VKEY = "00000000" : Endif
   I1 = instr(1,VKEY,"/")
   If I1
    Assign "[F:"+[L]TRCABRFIC+"]"+PKEYTB9(I) With evalue("["+VKEY+"]")
   Elsif len(VKEY)=8
    Assign "[F:"+[L]TRCABRFIC+"]"+PKEYTB9(I) With VKEY
   Else
    Assign "[F:"+[L]TRCABRFIC+"]"+PKEYTB9(I) With [0/0/0]
   Endif
  When Default
   Assign "[F:"+[L]TRCABRFIC+"]"+PKEYTB9(I) With VKEY
 Endcase
Next I
[G:TB9]currind = 1
For I=0 To [G:TB9]nbind-1
 If [L]IDX = evalue("[G:TB9]keyname("+num$(I)+")")
  [G:TB9]currind = I+1 : Break
 Endif
Next I
[G:TB9]currlen = 0
Read [F:TB9] =
Return

##################################################################################
$IB_NBLIG
# La tracabilité d'une ligne de pièce comptable va essentiellement zoomer sur un objet (clé = element déclenchant)
# Si l'élément déclenchant pointe sur un objet alors
#    - GBOUT7 => Tableau qui liste la justification du montant de la ligne (Ecran GASACCNUM)
#    - GBOUT8 => Zoom directement sur l'objet (précédé par une fenêtre de sélection si plusieurs éléments déclenchant <>)
# La restitution de l'information n'étant pas un objet classique
#    - GBOUT9 => Zoom vers l'action défini sous GESGAU

If !clalev([F:GAT]) : Local File GAUTRCVCR  [GAT] : Endif
If !clalev([F:GAU]) : Local File GAUTACE    [GAU] : Endif
If !clalev([F:AOB]) : Local File AOBJET     [AOB] : Endif
If !clalev([F:ACT]) : Local File ACTION     [ACT] : Endif

Read [GAT]GAT0(1) = [M]ACCNUM(nolign-1)
If !fstat
 
 #---- Init GBOUT7 & GBOUT8
 Filter [AOB] Where NOMFIC=[F:GAT]TBL & TYPGES=1
 Read [AOB]NOMFIC First
 If !fstat
  GBOUT7=mess(61,117,1)  : # Suivi
  Call TEXTE([F:AOB]LIBEL,GBOUT8) From OBJDIV  
  #--- cas particulier PIH/BIS et SIH/BIC
  If find([F:GAT]TBL,"SINVOICE","PINVOICE")
   GBOUT8 = mess(87,121,1) : # Factures
  Endif
 Endif
 Filter [AOB]

 #---- Init GBOUT9
 Read [GAU]GAU0 = [F:GAT]GAU
 If !fstat 
  If [F:GAU]TRCACT<>"" 
   If [F:GAU]TRCACT="GASACCNUM1" 
    GBOUT9=mess(61,117,1)  : # Suivi
   Else
    Read [ACT]ACTION = [F:GAU]TRCACT
    If !fstat
     Call TEXTE([F:ACT]INTITA,GBOUT9) From OBJDIV  
    Endif
   Endif
  Endif
 Endif

If GBOUT7=""
# GBOUT7="Test CP"
Endif
Endif
Return
