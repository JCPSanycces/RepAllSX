#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SALADDRESS_C_ADDLIG
#######################################################################################
End
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return
#######################################################################################
$METHODS
  Case CURPTH
    When ""
      Case [L]AMETHOD
        When "INIT_SALADDRESS"         : Gosub INIT_SALADDRESS
        When "GET_SALADDRESS"          : Gosub GET_SALADDRESS
        When "READ_BPA"                : Gosub READ_BPA
        When "GET_BPA"                 : Gosub GET_BPA
        When Default
      Endcase
    When Default
  Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPTH
    When ""
      Case CURPRO
        When "BPRNAM1"                     :  Gosub BPRNAM1
        When "BPRNAM2"                     :  Gosub BPRNAM2
        When "ADDLIG1"                     :  Gosub ADDLIG1
        When "ADDLIG2"                     :  Gosub ADDLIG2
        When "ADDLIG3"                     :  Gosub ADDLIG3
        When Default
      Endcase
    When Default
  Endcase
Return
#######################################################################################
#######################################################################################
#######################################################################################
# METHODS                                                                             #
#######################################################################################
#######################################################################################
#######################################################################################
$INIT_SALADDRESS
#Value Char STYPVCR ()
#Value Char SBPRNUM ()
#Value Char SBPAADD ()
#Value Char SCNTNAM ()

  # Charge la classe SALADDRESS soit à partir de l'appelant, soit à partir de la classe BPADDRESS[BPA]
  # ----------------------------------------------------------------------------
  Gosub DECLARE_VAR_LOC
  ISENS = 1
  # ----------------------------------------------------------------------------
  [L]ARET_VALUE = 0
  # ----------------------------------------------------------------------------
  this.TYPVCR = STYPVCR
  this.BPRNUM = SBPRNUM
  this.BPAADD = SBPAADD
  this.BPADES = SBPADES
  this.CNTNAM = SCNTNAM
  # ----------------------------------------------------------------------------
  Gosub PUT_VALUES
  If [L]ARET_VALUE <> 0 Then
    Return
  Endif
  # ----------------------------------------------------------------------------
  If SZPOSCOD = "" and SZCTY = "" and SZSAT = "" and SZCRY = "" and SZADDLIG(1) = "" and SZADDLIG(2) = "" and SZADDLIG(3) = "" and SBPRNUM <> "" Then
    # Si on n'a rien on déclenche la lecture de BPADDRESS
    # ---------------------------------------------------
    [L]ARET_VALUE = fmet this.GET_BPA()
    If [L]ARET_VALUE <> 0 Then
      Return
    Endif
  Else
    # Sinon, on prend les valeurs qu'on a
    # -----------------------------------
    this.CRY = SZCRY

    If 1=1 Then
      For NI = 1 To dim(SZADDLIG)
        NLINE = fmet this.ADDLINE("C_ADDLIG", NI)
        this.C_ADDLIG(NI).ADDLIG = SZADDLIG(NI)
      Next NI
    Else
      NLINE = fmet this.ADDLINE("C_ADDLIG", 1)
      this.C_ADDLIG(1).ADDLIG = "SZADDLIG(1)"
    Endif

    this.POSCOD = SZPOSCOD
    this.CTY = SZCTY
    this.SAT = SZSAT
    this.CRYNAM = SZCRYNAM
    If 1=1 Then
    For NI = 1 To dim(ZSBPRNAM)
      NLINE = fmet this.ADDLINE("C_BPRNAM", NI)
      this.C_BPRNAM(NI).BPRNAM = ZSBPRNAM(NI)
    Next NI
    Endif
  Endif
  # ----------------------------------------------------------------------------
Return

#######################################################################################
$GET_SALADDRESS
  # Rend dans la classe appelantes les information addresse qui sont dans SALADDRESS
  # ----------------------------------------------------------------------------
  Gosub DECLARE_VAR_LOC
  ISENS = 2
  # ----------------------------------------------------------------------------
  [L]ARET_VALUE = 0
  # ----------------------------------------------------------------------------
  SZBPRADD = this.BPAADD
  SZCRY = this.CRY
  # ----------------------------------------
  Raz SZADDLIG
  NE = 1
  For NI = 1 To maxtab(this.C_ADDLIG)
    If this.C_ADDLIG(NI) <> null Then
      SZADDLIG(NE) = this.C_ADDLIG(NI).ADDLIG
      NE += 1
    Endif
  Next NI
  # ----------------------------------------
  SZPOSCOD = this.POSCOD
  SZCTY = this.CTY
  SZSAT = this.SAT
  SZCRYNAM = this.CRYNAM
  # ----------------------------------------
  Raz ZSBPRNAM
  NE = 1
  For NI = 1 To maxtab(this.C_BPRNAM)
    If this.C_BPRNAM(NI) <> null Then
      ZSBPRNAM(NE) = this.C_BPRNAM(NI).BPRNAM
      NE += 1
    Endif
  Next NI
  # ----------------------------------------------------------------------------
  Gosub PUT_VALUES
  If [L]ARET_VALUE <> 0 Then
    Return
  Endif
  # ----------------------------------------------------------------------------
Return

#######################################################################################
$DECLARE_VAR_LOC
Local Integer NI
Local Integer NE
Local Integer NLINE
Local Char SZPOSCOD(type(this.POSCOD)-10)
Local Char SZCTY(type(this.CTY)-10)
Local Char SZSAT(type(this.SAT)-10)
Local Char SZCRY(type(this.CRY)-10)

#NI = fmet this.AGETDIM("C_ADDLIG")               # Permet de récupérer le max de la collection
#Local Char SZADDLIG(50)(1..NI)                   # Voir pour faire mieux que ça
Local Char SZADDLIG(50)(1..3)                   # Voir pour faire mieux que ça

Local Char SZBPRADD(type(this.BPAADD)-10)
Local Char SZCRYNAM(type(this.CRYNAM)-10)

#NI = fmet this.AGETDIM("C_BPRNAM")               # Permet de récupérer le max de la collection
#Local Char ZSBPRNAM(35)(1..NI)                   # Voir pour faire mieux que ça
Local Char ZSBPRNAM(35)(1..2)                   # Voir pour faire mieux que ça

Local Char SBPADES(type(this.BPADES)-10)

Local Integer ISENS

  ISENS = 0                                      # ISENS=1 : INIT
                                                 # ISENS=2 : GET
  NI = 0
  NE = 0
Return

#######################################################################################
$READ_BPA
#Value Char SBPANUM ()
#Value Char SBPAADD ()
Local Integer IRET

  [L]ARET_VALUE = 0
  # ----------------------------------------------------------------------------
  If this.BPA(1) = null Then
    NLINE = fmet this.ADDLINE("BPA", [V]CST_AFIRSTPOS)
  Else
    NLINE = 1
  Endif
  # ----------------------------------------------------------------------------
  #  this.BPA.BPATYP = 1
  #  this.BPA.BPANUM = SBPANUM
  #  this.BPA.BPAADD = SBPAADD
  If fmet this.BPA(NLINE).AREAD(1,SBPANUM,SBPAADD) Then
    [L]ARET_VALUE = 1
    Return
  Endif
  # ----------------------------------------------------------------------------
Return

#######################################################################################
$GET_BPA
Local Integer NI
Local Integer NLINE

  [L]ARET_VALUE = 0
  # ----------------------------------------------------------------------------
  If this.BPAADD = "" Then
    # Si en entrée on n'a pas reçu de code adresse, on prend l'adresse par défaut du client
    Local File BPCUSTOMER [BPC]
    Read [F:BPC]BPC0=this.BPRNUM
    If fstat Then
      Raz [F:BPC]
    Endif
    this.BPAADD = [F:BPC]BPAADD
    Close Local File [BPC]
  Endif
  # ----------------------------------------------------------------------------
  If this.BPA(1) = null Then
    [L]ARET_VALUE = fmet this.READ_BPA(this.BPRNUM, this.BPAADD)
    If [L]ARET_VALUE <> 0 Then
      Return
    Endif
  Endif
  # ----------------------------------------------------------------------------
  this.BPAADD = this.BPA(1).BPAADD
  this.BPADES = this.BPA(1).BPADES
  this.CRY = this.BPA(1).CRY
  ####
  For NI = 1 To 3 :#maxtab(this.BPA(1).BPADDLI)
    NLINE = fmet this.ADDLINE("C_ADDLIG", NI)
    this.C_ADDLIG(NI).ADDLIG = evalue("this.BPA(1).BPAADDLIG"+num$(NI))
  Next NI
  ####
  this.POSCOD = this.BPA(1).POSCOD
  this.CTY = this.BPA(1).CTY
  this.SAT = this.BPA(1).SAT
  # ----------------------------------------------------------------------------
  # this.ACTX.LAN (pour la langue courante)
  Local File ATEXTRA [AXX]
  Read [F:AXX]AXX0="TABCOUNTRY";"CRYDES";this.ACTX.LAN;this.CRY;""
  If fstat Then
    Raz [F:AXX]
  Endif
  this.CRYNAM = [F:AXX]TEXTE
  Close Local File [AXX]
  # ----------------------------------------------------------------------------
  Local File BPARTNER [BPR]
  Read [F:BPR]BPR0=this.BPRNUM
  If fstat Then
    Raz [F:BPR]
  Endif
  NLINE = fmet this.ADDLINE("C_BPRNAM", 1)
  this.C_BPRNAM(1).BPRNAM = [F:BPR]BPRNAM(0)

  NLINE = fmet this.ADDLINE("C_BPRNAM", 2)
  this.C_BPRNAM(2).BPRNAM = [F:BPR]BPRNAM(1)
  Close Local File [BPR]
  # ----------------------------------------------------------------------------
Return

#######################################################################################
$PUT_VALUES
  # ----------------------------------------------------------------------------
  # ISENS = 1 (INIT)
  #       Depuis la classe parent vers les variables locales
  # ISENS = 2 (GET)
  #       Depuis les variables locales vers la classe parent
  # ----------------------------------------------------------------------------
  # Cette partie aurait pu être mise dans tous les différents objets.
  # J'ai choisi de la mettre ici, et de cette façon, afin de globaliser le maintenance, et de ne
  # pas avoir une multiplicité de traitements à modifier.
  # ----------------------------------------------------------------------------
  Case this.TYPVCR
    When "SQHBPC", "SOHBPC"
      # Adresse commande
      If ISENS = 1 Then
        SZCRY = this.APARENT.BPCCRY
        Raz SZADDLIG
        For NI = 1 To maxtab(this.APARENT.C_BPCADDLIG)
          If this.APARENT.C_BPCADDLIG(NI) <> null Then
            SZADDLIG(NI) = this.APARENT.C_BPCADDLIG(NI).BPCADDLIG
          Endif
        Next NI
        SZPOSCOD = this.APARENT.BPCPOSCOD
        SZCTY = this.APARENT.BPCCTY
        SZSAT = this.APARENT.BPCSAT
        SZCRYNAM = this.APARENT.BPCCRYNAM
        #
        Raz ZSBPRNAM
        For NI = 1 To maxtab(this.APARENT.C_BPCNAM)
          If this.APARENT.C_BPCNAM(NI) <> null Then
            ZSBPRNAM(NI) = this.APARENT.C_BPCNAM(NI).BPCNAM
          Endif
        Next NI
      Elsif ISENS = 2 Then
        this.APARENT.BPAORD = SZBPRADD
        this.APARENT.BPCCRY = SZCRY
        For NI = 1 To 3#dim(SZADDLIG)
          If this.APARENT.C_BPCADDLIG(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPCADDLIG", NI)
          Endif
          this.APARENT.C_BPCADDLIG(NI).BPCADDLIG = SZADDLIG(NI)
        Next NI
        this.APARENT.BPCPOSCOD = SZPOSCOD
        this.APARENT.BPCCTY = SZCTY
        this.APARENT.BPCSAT = SZSAT
        this.APARENT.BPCCRYNAM = SZCRYNAM
        #
        For NI = 1 To 2#dim(ZSBPRNAM)
          If this.APARENT.C_BPCNAM(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPCNAM", NI)
          Endif
          this.APARENT.C_BPCNAM(NI).BPCNAM = ZSBPRNAM(NI)
        Next NI
      Endif
    When "SQHBPD", "SOHBPD"
      # Adresse Livraison
      If ISENS = 1 Then
        SZCRY = this.APARENT.BPDCRY
        Raz SZADDLIG
        For NI = 1 To maxtab(this.APARENT.C_BPDADDLIG)
          If this.APARENT.C_BPDADDLIG(NI) <> null Then
            SZADDLIG(NI) = this.APARENT.C_BPDADDLIG(NI).BPDADDLIG
          Endif
        Next NI
        SZPOSCOD = this.APARENT.BPDPOSCOD
        SZCTY = this.APARENT.BPDCTY
        SZSAT = this.APARENT.BPDSAT
        SZCRYNAM = this.APARENT.BPDCRYNAM
        #
        Raz ZSBPRNAM
        For NI = 1 To maxtab(this.APARENT.C_BPDNAM)
          If this.APARENT.C_BPDNAM(NI) <> null Then
            ZSBPRNAM(NI) = this.APARENT.C_BPDNAM(NI).BPDNAM
          Endif
        Next NI
      Elsif ISENS = 2 Then
        this.APARENT.BPAORD = SZBPRADD
        this.APARENT.BPDCRY = SZCRY
        For NI = 1 To dim(SZADDLIG)
          If this.APARENT.C_BPDADDLIG(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPDADDLIG", NI)
          Endif
          this.APARENT.C_BPDADDLIG(NI).BPDADDLIG = SZADDLIG(NI)
        Next NI
        this.APARENT.BPDPOSCOD = SZPOSCOD
        this.APARENT.BPDCTY = SZCTY
        this.APARENT.BPDSAT = SZSAT
        this.APARENT.BPDCRYNAM = SZCRYNAM
        #
        For NI = 1 To dim(ZSBPRNAM)
          If this.APARENT.C_BPDNAM(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPDNAM", NI)
          Endif
          this.APARENT.C_BPDNAM(NI).BPDNAM = ZSBPRNAM(NI)
        Next NI
      Endif
    When "SOHBPI"
      # Adresse Facture
      If ISENS = 1 Then
        SZCRY = this.APARENT.BPICRY
        Raz SZADDLIG
        For NI = 1 To maxtab(this.APARENT.C_BPIADDLIG)
          If this.APARENT.C_BPIADDLIG(NI) <> null Then
            SZADDLIG(NI) = this.APARENT.C_BPIADDLIG(NI).BPIADDLIG
          Endif
        Next NI
        SZPOSCOD = this.APARENT.BPIPOSCOD
        SZCTY = this.APARENT.BPICTY
        SZSAT = this.APARENT.BPISAT
        SZCRYNAM = this.APARENT.BPICRYNAM
        #
        Raz ZSBPRNAM
        For NI = 1 To maxtab(this.APARENT.C_BPINAM)
          If this.APARENT.C_BPINAM(NI) <> null Then
            ZSBPRNAM(NI) = this.APARENT.C_BPINAM(NI).BPINAM
          Endif
        Next NI
      Elsif ISENS = 2 Then
        this.APARENT.BPAINV = SZBPRADD
        this.APARENT.BPICRY = SZCRY
        For NI = 1 To dim(SZADDLIG)
          If this.APARENT.C_BPIADDLIG(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPIADDLIG", NI)
          Endif
          this.APARENT.C_BPIADDLIG(NI).BPIADDLIG = SZADDLIG(NI)
        Next NI
        this.APARENT.BPIPOSCOD = SZPOSCOD
        this.APARENT.BPICTY = SZCTY
        this.APARENT.BPISAT = SZSAT
        this.APARENT.BPICRYNAM = SZCRYNAM
        #
        For NI = 1 To dim(ZSBPRNAM)
          If this.APARENT.C_BPINAM(NI) = null Then
            NLINE = fmet this.APARENT.ADDLINE("C_BPINAM", NI)
          Endif
          this.APARENT.C_BPINAM(NI).BPINAM = ZSBPRNAM(NI)
        Next NI
      Endif
    When Default
      [L]ARET_VALUE = 1
      Return
  Endcase
Return

#######################################################################################
#######################################################################################
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
#######################################################################################
# ----------------------- BPRNAM1 --------------------------------------
$BPRNAM1
  Case [L]ARULE
    When "GET"
      If this.C_BPRNAM(1) <> null Then
        this.BPRNAM1 = this.C_BPRNAM(1).BPRNAM
      Endif
    When Default     : Return
  Endcase
Return

# ----------------------- BPRNAM2 --------------------------------------
$BPRNAM2
  Case [L]ARULE
    When "GET"
      If this.C_BPRNAM(2) <> null Then
        this.BPRNAM2 = this.C_BPRNAM(2).BPRNAM
      Endif
    When Default     : Return
  Endcase
Return

# ----------------------- ADDLIG1 --------------------------------------
$ADDLIG1
  Case [L]ARULE
    When "GET"
      If this.C_ADDLIG(1) <> null Then
        this.ADDLIG1 = this.C_ADDLIG(1).ADDLIG
      Endif
    When Default     : Return
  Endcase
Return

# ----------------------- ADDLIG2 --------------------------------------
$ADDLIG2
  Case [L]ARULE
    When "GET"
      If this.C_ADDLIG(2) <> null Then
        this.ADDLIG2 = this.C_ADDLIG(2).ADDLIG
      Endif
    When Default     : Return
  Endcase
Return

# ----------------------- ADDLIG3 --------------------------------------
$ADDLIG3
  Case [L]ARULE
    When "GET"
      If this.C_ADDLIG(3) <> null Then
        this.ADDLIG3 = this.C_ADDLIG(3).ADDLIG
      Endif
    When Default     : Return
  Endcase
Return

