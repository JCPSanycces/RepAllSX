#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201804001
# Issue X3-69372 - 2018-04-20 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201804001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201804001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char SOLDIDENT1(GLONID1)
Local Char SNEWIDENT1(GLONID1)

  Call ECR_TRACE("UTIPJM201804001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".PJMTIMEMP" [PTE]
  Local File =DOSSIER + ".PJMTIMEMP" [PTEB]
  Local File =DOSSIER + ".PJMTIMEMP" [PTEC]
  Local File =DOSSIER + ".ATEXTRA" [AXX]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [AXX]
  For [PTE]
    SOLDIDENT1 = [F:PTE]CLB + "~" + [F:PTE]OPPNUM + "~" + format$("YYYYMMDD",[F:PTE]PTEDAT) + "~" + num$([F:PTE]PTESEQ)
    # ------------
    Filter [PTEB] Where [F:PTEB]AUUID <> [F:PTE]AUUID and [F:PTEB]CLB = [F:PTE]CLB and [F:PTEB]PTESEQ = [F:PTE]PTESEQ
    For [PTEB]
      Filter  [PTEC] Where [F:PTEC]CLB = [F:PTEB]CLB Order By Key KEYSEQ=[F:PTEC]CLB;[F:PTEC]PTESEQ Desc
      For [PTEC]KEYSEQ
        [F:PTE]PTESEQ = [F:PTEC]PTESEQ + 10
        Rewrite [F:PTE]
        If fstat Then
          Call ECR_TRACE("File PJMTIMEMP" - SOLDIDENT1 + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
        Break
      Next
      Filter [PTEC]
      Break
    Next
    Filter [PTEB]
    # ------------
    If IERR = 0 Then
      SNEWIDENT1 = [F:PTE]CLB + "~" + num$([F:PTE]PTESEQ)
      Filter [AXX] Where [F:AXX]CODFIC = "PJMTIMEMP" and [F:AXX]ZONE = "PTEDESAXX" and [F:AXX]IDENT1 = SOLDIDENT1 and [F:AXX]IDENT2 = ""
      For [AXX]
        [F:AXX]IDENT1 = SNEWIDENT1
        Rewrite [AXX]
        COMPTEUR += 1
        If fstat Then
          Call ECR_TRACE("File ATEXTRA" - [F:AXX]CODFIC - [F:AXX]ZONE - SOLDIDENT1 - [F:AXX]IDENT2 + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Next
      Filter [AXX]
    Endif
  Next
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201804001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201804001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201804001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201804001(APPLI)
End

