##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
     When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
     When "AINSERT_AFTER"                : Gosub AINSERT_AFTER

     When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE

     When "ADELETE_CONTROL_BEFORE"       : Gosub ADELETE_CONTROL_BEFORE
     When "ADELETE_AFTER"                : Gosub ADELETE_AFTER

     When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
  When "BPA"
    Case [L]AEVENT
      When "ADELLINE_BEFORE"             : Gosub BPA_ADELLINE_BEFORE
    Endcase
  When "BID"
    Case [L]AEVENT
      When "ADELLINE_BEFORE"             : Gosub BID_ADELLINE_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "FINFLG"           : Gosub FINFLG
  When "BPA.BPAADD"       : Gosub BPA_BPAADD
  When "BPA.BPAADDFLG"    : Gosub BPA_BPAADDFLG
  When "BID.BPANUM"       : Gosub BID_BPANUM
  When "BID.BPAADD"       : Gosub BID_BPAADD
  When "BID.BIDNUM"       : Gosub BID_BIDNUM
  When "BID.BIDNUMFLG"    : Gosub BID_BIDNUMFLG
  When "ORICERFLG"        : Gosub ORICERFLG     :#X3-60505
  When "CRY"              : Gosub CRY           :#X3-60505
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




###############################################################################################
$BPA_ADELLINE_BEFORE
Local Integer I
If this.BPAADD = this.BPA(ALINE).BPAADD
  this.BPAADD=AVOID.ACHAR
Endif

If this.BID<>null
  For I=1 To maxtab(this.BID)
    If this.BPA(ALINE).BPAADD = this.BID(I).BPAADD & find(this.BID(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=[V]CST_AFALSE
      [L]ASTATUS=fmet this.ASETERROR("BPAADD", this.BPA(ALINE).BPAADD-mess(169,133,1)-this.BID(I).BIDNUM,[V]CST_AERROR)
    Endif
  Next
Endif

Return

###############################################################################################
$BID_ADELLINE_BEFORE
Local Integer I
If this.BIDNUM = this.BID(ALINE).BIDNUM
  this.BIDNUM=AVOID.ACHAR
Endif

If this.BPA<>null
  For I=1 To maxtab(this.BPA)
    If this.BID(ALINE).BIDNUM = this.BPA(I).BPABID & find(this.BPA(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=[V]CST_AFALSE
      this.BPA(I).BPABID=AVOID.ACHAR
    Endif
  Next
Endif
Return

###############################################################################################
$ADELETE_CONTROL_BEFORE
  Gosub FINRSPFCY_ADELETE_CONTROL
Return

###############################################################################################
$FINRSPFCY_ADELETE_CONTROL
Local Integer MY_STATUS : [L]MY_STATUS=[V]CST_AOK
Local File FACILITY [FCY]

Filter [FCY] Where [FCY]FINRSPFCY = this.FCY & [FCY]FCY<>this.FCY
For [FCY]
  [L]MY_STATUS =  fmet this.ASETERROR("FINRSPFCY",mess(101,126,1)-[F:FCY]FCY-[F:FCY]FCYNAM,[V]CST_AERROR)
Next
Filter [FCY]

[L]ASTATUS = max([L]MY_STATUS,[L]ASTATUS)

Return

###############################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub FACILITY_CONTROL
  Gosub BPA_DEFAULT_CONTROL
  Gosub BID_DEFAULT_CONTROL
Return

###############################################################################################
$AINSERT_AFTER
  Gosub INSERT_CLASS_COLUMN
Return

###############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub FACILITY_CONTROL
Gosub BPA_DEFAULT_CONTROL
Gosub BID_DEFAULT_CONTROL
Return


###############################################################################################
$TRANS_COLUMN_CLASS
Local Integer I
For I=1 To maxtab(this.BPA)
  If this.BPA(I).BPATYP<>3
    this.BPA(I).BPATYP=3
  Endif
  If this.BPA(I).BPANUM<>this.FCY
    this.BPA(I).BPANUM=this.FCY
  Endif
Next

For I=1 To maxtab(this.BID)
  If this.BID(I).BPATYP<>3
    this.BID(I).BPATYP=3
  Endif
  If this.BID(I).BPANUM<>this.FCY
    this.BID(I).BPANUM=this.FCY
  Endif
Next
Return
###############################################################################################
$BPA_DEFAULT_CONTROL
Local Integer I,FOUND,FIRST_IDX
FIRST_IDX=0
If this.BPA<>null
  FOUND=[V]CST_AFALSE
  For I=1 To maxtab(this.BPA)
      If find(this.BPA(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
        If this.BPA(I).BPAADDFLG=[V]CST_AYES
          FOUND=[V]CST_ATRUE
          Break
        Endif
      Endif
   Next
   If FOUND=[V]CST_AFALSE
    [L]ASTATUS = fmet this.ASETERROR("BPADDRESS",mess(41,133,1),[V]CST_AERROR)
   Endif
Endif

Return

###############################################################################################
$BID_DEFAULT_CONTROL
Local Integer I,FOUND,FIRST_IDX
FIRST_IDX=0
If this.BID<>null
  FOUND=[V]CST_AFALSE
  For I=1 To maxtab(this.BID)
      If find(this.BID(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
        If this.BID(I).BIDNUMFLG=[V]CST_AYES
          FOUND=[V]CST_ATRUE
          Break
        Else
          If FIRST_IDX=0
            FIRST_IDX=I
          Endif
        Endif
      Endif
   Next
   If FOUND=[V]CST_AFALSE and FIRST_IDX<>0
    this.BID(FIRST_IDX).BIDNUMFLG=[V]CST_AYES
   Endif
Endif

Return

###############################################################################################
$ADELETE_AFTER
# Delete FACGROUP
Local File FACGROUP [FGR]
Local Instance FACGROUP Using C_FACGROUP

For [F:FGR] Where FCY=this.FCY
  FACGROUP = NewInstance C_FACGROUP AllocGroup null
  [L]ASTATUS = fmet FACGROUP.AREAD([F:FGR]CPY,[F:FGR]FCY)
  If [L]ASTATUS = [V]CST_AOK
    [L]ASTATUS = fmet FACGROUP.ADELETE()
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = FACILITY.ASETERROR("FACGROUP","Delete error",[V]CST_AERROR)
    Endif
  Endif
  FreeGroup FACGROUP
  If [L]ASTATUS<>[V]CST_AOK : Break : Endif
Next

Return

###############################################################################################
$AREAD_AFTER
  Gosub FACILITY_CONTROL
Return

###############################################################################################
$FACILITY_CONTROL
Local Integer I,FOUND
BPA_FOUND=[V]CST_ANO
# Default Address Control
If find([V]CST_AYES,this.BPA(1..maxtab(this.BPA)).BPAADDFLG)>0
  BPA_FOUND=[V]CST_AYES
Else
  BPA_FOUND=[V]CST_ANO
  # One address must be set as a default
  [L]ASTATUS = fmet this.ASETERROR("FACILITY",mess(41,133,1),[V]CST_AERROR)
Endif

# Check facility is not a company
#If this.FCY<>""
#  If fmet this.ACTX.ACACHE.ACPY.AREAD(this.FCY) = [V]CST_AOK
#    # This code already exists as a company
#    [L]ASTATUS = fmet this.ASETERROR(this.FCY,mess(141,133,1),[V]CST_AERROR)
#  Else
#    [L]ASTATUS = [V]CST_AOK
#  Endif
#Endif

Return

###############################################################################################
# TODO: can we eliminate the option to determine the length of the facility. It is whatever is defined  parameters. ???? The entire routine can be dropped.
# Who do we ask?


Subprog MAJLENCOD(DOSSIER)
Value Char DOSSIER
Local Char    MAXCOD(GLONCPY) , MINCOD(GLONCPY) , TEXMES(250)(1..5)
Local Clbfile ENTMES(1)
Local Integer I,K,OK
If DOSSIER="" or DOSSIER=nomap
 Local File FACILITY [FCY]
Else
 Local File =DOSSIER+".FACILITY" [FCY]
Endif
Raz MAXCOD , MINCOD
For [FCY]
 If len(MINCOD)=0 or len([F:FCY]FCY)<len(MINCOD)
  MINCOD = [F:FCY]FCY
 Endif
 If len([F:FCY]FCY)>len(MAXCOD)
  MAXCOD = [F:FCY]FCY
 Endif
Next FCY
If len(MAXCOD)<>len(MINCOD)
 # Attention, la longueur des codes $1$ n'est pas uniforme (il varie de $2$ [$3$] à $4$ [$5$]).
 # Si vous utilisez des compteurs, incluant des codes $6$ et que ceux-ci sont définis avec un contrôle strict
 # de chronologie, les codes $7$ seront complétés par un ou plusieurs caractères $8$ pour atteindre la longueur requise
 ENTMES  = mess(220,125,1)+mess(221,125,1)+mess(222,125,1)
 TEXMES = mess(29,109,1)+"~"+num$(len(MINCOD))+"~"+MINCOD+"~"+num$(len(MAXCOD))+"~"+MAXCOD
 TEXMES += "~"+mess(29,109,1)+"~"+mess(29,109,1)+"~"+"_"
 ENTMES = func AFNC.MESNC(ENTMES,TEXMES)


Raz TEXMES , I
While ENTMES<>""
 I += 1
 K = instr(100,ENTMES," ")
 If K
  TEXMES(I) = left$(ENTMES,K-1)
  ENTMES = right$(ENTMES,K+1)
 Else
  TEXMES(I) = ENTMES
  ENTMES = ""
   Endif
  Wend
Endif


#TODO: #Call MAJPAR(DOSSIER,"FCYMAXLEN",num$(len(MAXCOD))) From SUBADS
#TODO:#Call MAJPAR(DOSSIER,"FCYMINLEN",num$(len(MINCOD))) From SUBADS

End

###############################################################################################
$INSERT_CLASS_COLUMN
Gosub INSERT_FACGROUP
Return

#########################################################################################################
# Update FACGROUP
$INSERT_FACGROUP

# TODO: review message text values
# Loop on AGRPCPY adding Facility Grouping
Local File AGRPCPY [AGC]
Local Instance FACGROUP Using C_FACGROUP

For [F:AGC]AGC0 Where CPY=this.LEGCPY
  FACGROUP = NewInstance C_FACGROUP AllocGroup null
  FACGROUP.CPY  = [F:AGC]GRP
  FACGROUP.FCY  = this.FCY
  [L]ASTATUS = fmet FACGROUP.AINSERT()
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("FACGROUP","insert error message text",fstat )
  Endif
  FreeGroup FACGROUP
  If [L]ASTATUS<> [V]CST_AOK : Break : Endif
Next

Return

###############################################################################################
# PROPERTIES
###############################################################################################

################################################################################################
$FINFLG
Case [L]ARULE
  When "PROPAGATE"        : Gosub FINFLG_PROPAGATE
Endcase
Return

$FINFLG_PROPAGATE
Gosub FINFLG_DEPENDENCY
Return

################################################################################################
$BID_BPANUM
Case [L]ARULE
  When "INIT"                     : this.BPANUM = this.APARENT.FCY
Endcase
Return

###############################################################################################
$BPA_BPAADD

Case [L]ARULE
  When "CONTROL"                  : Gosub BPA_BPAADD_CONTROL
Endcase

Return

##################################################
$BPA_BPAADD_CONTROL
Local Integer I,CNT

If this.APARENT.BPA<>null
  For I=1 To maxtab(this.APARENT.BPA)
      If find(this.APARENT.BPA(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
        If this.APARENT.BPA(I).BPAADD=this.BPAADD
          CNT+=1
        Endif
      Endif
  Next
  If CNT>1
    [L]ASTATUS = fmet this.APARENT.ASETERROR("BPADDRESS",this.BPAADD-mess(29,100,1),[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$BPA_BPAADDFLG
Case [L]ARULE
  When "PROPAGATE"        : Gosub BPA_BPAADDFLG_PROPAGATE
Endcase
Return

########################
$BPA_BPAADDFLG_PROPAGATE
Local Integer I

If this.BPAADDFLG= [V]CST_AYES
  For I=1 To maxtab(this.APARENT.BPA)
    If this.APARENT.BPA(I)<> null
     If this.APARENT.BPA(I).BPAADDFLG = [V]CST_AYES
        this.APARENT.BPA(I).BPAADDFLG = [V]CST_ANO
      Endif
    Endif
  Next
  this.BPAADDFLG= [V]CST_AYES
  this.APARENT.BPAADD = this.BPAADD
 Endif

Return

###############################################################################################
$BID_BIDNUMFLG
Case [L]ARULE
  When "PROPAGATE"        : Gosub BID_BIDNUMFLG_PROPAGATE
Endcase
Return

########################
$BID_BIDNUMFLG_PROPAGATE
Local Integer I

If this.BIDNUMFLG= [V]CST_AYES
  For I=1 To maxtab(this.APARENT.BID)
    If this.APARENT.BID(I)<> null
     If this.APARENT.BID(I).BIDNUMFLG = [V]CST_AYES
        this.APARENT.BID(I).BIDNUMFLG = [V]CST_ANO
      Endif
    Endif
  Next
  this.BIDNUMFLG= [V]CST_AYES
  this.APARENT.BIDNUM = this.BIDNUM
 Endif

Return

###############################################################################################
$BID_BPAADD
Case [L]ARULE
  When "CONTROL"          : Gosub BID_CONTROL
Endcase
Return

###############################################################################################
$BID_BIDNUM
Case [L]ARULE
  When "CONTROL"          : Gosub BID_CONTROL
Endcase
Return

###############################################################################################
$BID_CONTROL
Local Integer I,CNT
If this.APARENT.BID<>null
  For I=1 To maxtab(this.APARENT.BID)
    If find(this.APARENT.BID(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      If this.BIDNUM<>"" & this.APARENT.BID(I).BIDNUM=this.BIDNUM
        If this.BPAADD<>"" & this.APARENT.BID(I).BPAADD=this.BPAADD
          CNT+=1
        Endif
      Endif
    Endif
  Next
  If CNT>1
    [L]ASTATUS = fmet this.APARENT.ASETERROR("BPADDRESS",this.BIDNUM - this.BPAADD-mess(29,100,1),[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$FINFLG_DEPENDENCY
If this.FINFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FINRSPFCY", "$isMandatory", "false")
  this.FINRSPFCY = AVOID.ACHAR
Else
  If dim(this.ORICERFLG)>=0   :#X3-69093
    this.ORICERFLG=[V]CST_ANO :#X3-60505
  Endif
Endif

Return

###############################################################################################
#X3-60505
$CRY
# Country
Case [L]ARULE
  When "PROPAGATE"        : Gosub CRY_PROPAGATE
Endcase
Return

#X3-60505
$CRY_PROPAGATE
  #X3-69093
  If dim(this.ORICERFLG)>=0 & this.ORICERFLG = [V]CST_AYES &
&  (fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES
&    & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES)
    this.ORICERFLG=[V]CST_ANO
  Endif
Return
###############################################################################################
#X3-60505
$ORICERFLG
# Origin's auto-certification
  Case [L]ARULE
    When "INIT"             : Gosub ORICERFLG_INIT
    When "PROPAGATE"        : Gosub ORICERFLG_PROPAGATE
  Endcase
Return

#X3-60505
$ORICERFLG_INIT
  If this.ORICERFLG<[V]CST_ANO
    this.ORICERFLG = [V]CST_ANO
  Elsif this.FINFLG <> [V]CST_AYES |
&  (this.CRY<>AVOID.ACHAR & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES)
    this.ORICERFLG=[V]CST_ANO
  Endif
Return

#X3-60505
$ORICERFLG_PROPAGATE
  If this.ORICERFLG<>[V]CST_AYES
    this.REXNUM = AVOID.ACHAR
  Endif
Return

