#<AdxTL>@(#)10.0.0.0 $Revision$

Call OBJET("QCR", GBIDC1, GBIDC2) From GOBJET
End


$SET_NOL
Local Integer NOL
NOL = nolign-1
Return


######################################################################
$OUVRE_BOITE
# Récupération des noms de currbox des tiroirs
Global Char     GBOXSTO(10)
GBOXSTO = "GAU_CHE"+num$(find("ST2",OBJLIS(1..8))+find("STO",OBJLIS(1..8))
&         +find("ST1",OBJLIS(1..8)))
Return

######################################################################
$OUVRE
Global Char    GTRUCOD(GLONTRU)
Raz GSOC_ACTIVE

Local Char     WCRIT(200)
Local Char     WCRITPIC(250)   : # Critère pour contrôle ligne stock pickée
Local Char     WCRITSTO3(70)   : # Critère péremption
Local Char     WCRITSTO4(90)   : # Critère statuts
Local Char     WPICKSTO(2)
Local Integer  LRET, I
Local Integer  WA, WQ, WR

# Si on vient par tunnel il faut sauvegarder les variables globales
If GFONC1<>GFONCTION Gosub SAUV_GLOB From TRTX3GLOB : Endif

If dim(GRAFFRAICHIQCR)<0
   Global Libelle GRAFFRAICHIQCR
Endif
Raz GRAFFRAICHIQCR

If dim(GQCRAUZSST)<=0
   Global Char    GQCRAUZSST(15)
Endif
GSCSAUZSST = "Q*"
Global Char GFILLOCENT(250)
GFILLOCENT = "1=1"

If !clalev([F:QLD])  : Local File STOQLYD    [QLD]  : Endif
If !clalev([F:SGW])  : Local File STOSRGW    [SGW]  : Endif
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD] : Endif
If GWRHACT = 2
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif


#----- Ouverture des tables -----#
Gosub OPEN_FILES From STKLIB


[M:QCR1]TRSTYP = 34          # demande analyse
If !clalev([F:STO])  : Local File STOCK [STO]  : Endif
If !clalev([F:STO1]) : Local File STOCK [STO1] : Endif


$OUVRE_SUIT
GFCY=GFCYDEF(7)
Gosub CHARG_PARAM
# Initialisation des tables nécessaires à la gestion d'emplacements
#Gosub STK_INILOC From STKLOC

#  ecran de travail enreg mvt du document
If clalev([M:STW])=0
   Local Mask STOWORK   [STW]
Endif
Raz [M:STW]

If !GVTMOD=1 Gosub DECLARE From TABLEAUX Endif
Return

######################################################################
$FILTRE
Default File [SGH]
FILTSUP = "TRSTYP = 34"    # demande analyse
Return

######################################################################
$LIENS

# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATQCR) > 0
   Kill GCTRDATQCR
Endif

If GFCY<>[F:SGH]STOFCY GFCY=[F:SGH]STOFCY : Gosub CHARG_PARAM : Endif

Local Integer I
Local Integer LRET

[M:QCR1]VCRTYP = 29        # changement stock
Diszo [M:QCR1]5
Actzo [M:QCR1]VCRNUM    # Car il y a un diszo en RAZCRE (et RAZDUP)

Gosub LIENS From TABLEAUX
Affzo [M:QCR1]

Call STKCTRIPT( [M:QCR1]IPTDAT, [M:QCR1]STOFCY, "1") From STKLIB
If GERR=1
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz GERR
   Raz GMESSAGE
   Grizo [M:QCR1]5
Elsif GERR=2
   Call MESSAGE(GMESSAGE) From GESECRAN
   Raz GERR
   Raz GMESSAGE
   Grizo [M:QCR1]5
Else
   Call STKDISCOL("QCR1",[M]NBLIG) From STKECR
   Diszo [QCR1]ITMREF,ITMDES1
   Actzo [QCR1]ITMREF([M]NBLIG),ITMDES1([M]NBLIG)
   If dim([M:QCR1]QTYPCU)>0
      Diszo [QCR1]QTYPCU
      Actzo [QCR1]QTYPCU([M]NBLIG)
   Endif
   If dim([M:QCR1]STADES)>0
      Diszo [QCR1]STADES
      Actzo [QCR1]STADES([M:QCR1]NBLIG)
   Endif
#   If dim([M:QCR1]LOCTYPES)>0
#      Diszo [QCR1]LOCTYPDES
#      Actzo [QCR1]LOCTYPDES([M:QCR1]NBLIG)
#   Endif
#   If dim([M:QCR1]LOCES)>0
#      Diszo [QCR1]LOCDES
#      Actzo [QCR1]LOCDES([M:QCR1]NBLIG)
#   Endif
Endif
Return


######################################################################
$DEFLIG
Default Mask [QCR1]
Default File [SGD]
CRIT   = 'VCRNUM="'+[M:QCR1]VCRNUM+'"'
FICLIG = "SCHGD"
ABLIG  = "SGD"
ZONLIG = "VCRLIN"
Return

######################################################################
$LIENS_LIG

Gosub SET_NOL

Call RECSTOSOR (1,"QCR1",NOL,[M:QCR1]STOFCY,[M:QCR1]ITMREF(NOL),
&               [M:QCR1]VCRTYP,[M:QCR1]VCRNUM,[M:QCR1]VCRLIN(NOL),
&               "",LRET) From STKECR

Return

######################################################################
$RAZCRE
Actzo [M:QCR1]5
If GSTKCPTMAN(9)<>2
   Effzo [M:QCR1]VCRNUM
   Diszo [M:QCR1]VCRNUM
Endif
[M:QCR1]VCRTYP=29      # changement stock
[M:QCR1]TRSTYP=34      # demande analyse

Return

######################################################################
$RAZDUP
Return

######################################################################
$STATUT
If BOUT="a" & mkstat=4 & REP=""
   REP ="M" : GREP="M"
Endif
Return

######################################################################
$SETBOUT
If  GREP<>""
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If [M:QCR1]VCRNUM="" & GREP<>"C"
   Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Call VIREBOUT(CHAINE,"A") From GOBJET
Call VIREBOUT(CHAINE,"D") From GOBJET
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

######################################################################
$VERIF_CRE
Gosub VERIF_ENR
Return

######################################################################
$VERIF_MOD
Gosub VERIF_ENR
Return

######################################################################
$VERIF_ENR
If GREP<>"M" & sigma( 0,[M:QCR1]NBLIG-1, [M:QCR1]CREFLG(indcum)=0)=0   # hcb 63711
   Raz GOK, OK
   Return
Endif
#                                                                      # hcb 110327 deb
Local Integer I
For I=0 To [M:QCR1]NBLIG-1
    If [M:QCR1]ITMREF(I) <> [F:ITM]ITMREF
       Read [ITM]ITM0=[M:QCR1]ITMREF(I)
       If fstat
          Call ECR_TRACE(mess(134,100,1)-"("+[M:QCR1]ITMREF(I)+")",1) From GESECRAN
          Raz GOK,OK
          Break
       Endif
   Endif
   If [F:ITM]SERMGTCOD = 4 & [M:QCR1]SERNUM(I) = ""
      # Le nb de no série ne correspond pas à la qté à traiter
      Call ECR_TRACE(mess(246,199,1)+"  "+ mess(93,100,1)+" : "+num$(I+1),1) From GESECRAN
      Raz GOK,OK
      Break
   Endif
Next I

#                                                                      # hcb 110327 end

Return
######################################################################
$INICRE

Local Integer LSTAT, I
Local Char    LNUM
# Création du numéro de document si nécessaire
If GSTKCPTMAN(14)<>2 | [M:QCR1]VCRNUM = ""
   Call NUMERO(GSTKCPT(14), [M:QCR1]STOFCY, [M:QCR1]IPTDAT,
&              "", LNUM, LSTAT) From SUBANM
   If GOK <0
      Return
   Endif
   If LSTAT=0
      [M:QCR1]VCRNUM = LNUM
      [F:SGH]VCRNUM  = LNUM
   Else
      GERR=1:GMESSAGE = mess(60,199,1)
      GOK=0
   Endif
Endif

Return

######################################################################
$INIMOD
Return

######################################################################
$CREATION
Gosub CREATION From TABLEAUX
Return

######################################################################
$MODIF
Gosub MODIF From TABLEAUX
Return

######################################################################
$INICRE_LIG
[F:SGD]VCRNUM = [F:SGH]VCRNUM
Return

######################################################################
$VALLIG
If SIGN=1
   Call ALISTW (nolign-1) From SUBQCRB
Endif
Return

######################################################################
$APRES_CRE

If !GIMPORT & !GWEBSERV & GTRACE<>""
   If dim(GTRAVT)>0 GTRAVT=mess(39,7750,1)-[F:SGH]VCRNUM Endif
   Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
   If dim(GTRAVT)>0 Raz GTRAVT Endif
Endif

If GFONCTION = GFONC1
   If !GIMPORT & !GVTMOD
      Gosub RELIT  From GOBJSUB
      Gosub TIROIR From SUBQCRP
   Endif
Endif
Return

######################################################################
$APRES_MOD
Gosub APRES_CRE
Return

######################################################################
$AB_CREATION
If GTRACE<>""  & !GIMPORT
   Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif

Return

######################################################################
$AB_MODIF
If GTRACE<>""  & !GIMPORT
   Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif
Return


######################################################################
$APRES_MODIF

If GRAFFRAICHIQCR
   Gosub TIROIR From SUBQCRP
   Raz GRAFFRAICHIQCR
Endif
Case COUZON
     When "ITMREFSEL" :
           Raz WCRIT, WCRITPIC, WCRITSTO3, WCRITSTO4
           Raz WA, WQ, WR
           Raz WCRIT
           If WA=1
              WCRIT+='pat([F:STO]STA,"A*")<>0'
           Endif
           If WQ=1
              If WCRIT<>"" WCRIT+='|' Endif
              WCRIT+='pat([F:STO]STA,"Q*")<>0'
           Endif
           If WR=1
              If WCRIT<>"" WCRIT+='|' Endif
              WCRIT+='pat([F:STO]STA,"R*")<>0'
           Endif

           If WCRITSTO4<>""
              If WCRITPIC<>""
                 WCRITPIC+='&('+WCRITSTO4+')'
              Else
                 WCRITPIC+=WCRITSTO4
              Endif
           Elsif WCRITPIC<>""
              If WCRIT<>"" WCRITPIC+='&('+WCRIT+')' Endif
           Else
              If WCRIT<>""
                 WCRITPIC+=WCRIT
              Else
                 WCRITPIC='1=1'
              Endif
           Endif
           Gosub TIROIR From SUBQCRP
      When "WRHSEL" :
           Gosub TIROIR From SUBQCRP
      When "NBLIG" :
           If find(status,65,83)
              Gosub TIROIR From SUBQCRP
           Endif
    Endcase
Return

######################################################################
$ABANDON
Local Integer LRET
Local Integer I
Actzo [M:QCR1]VCRNUM
WPICK = 1
Raz [M:QCR1]ITMREFSEL
If dim([M:QCR1]WRHSEL) > 0
   Raz [M:QCR1]WRHSEL
Endif
Gosub TIROIR From SUBQCRP
For I = 0 To [M:QCR1]NBLIG-1
    If  [M:QCR1]CREFLG(I) = 0 & [M:QCR1]WSTOCOU(I) <> 0
        #--- On fait le ménage dans le document
        Call DELSTO([M:QCR1]STOFCY,I,I, LRET) From SUBQCRB
    Endif
Next

Return

######################################################################
$FERME

# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATQCR) > 0
   Kill GCTRDATQCR
Endif


Kill GQCRAUZSST

If GFONC1<>GFONCTION Gosub REST_GLOB From TRTX3GLOB Endif
Return

###############################
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",3,"") From TRTX3CPT
# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
Local Integer LRET
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
#                                                                  # hcb 53503 deb
GSTKCPTMAN(0) = [F:TCA]MANCOU(0) # Cpt du chrno stock
GSTKCPT   (0) = [F:TCA]CODNUM(0)

GSTKCPTMAN(1) = [F:TCA]MANCOU(1)
GSTKCPT   (1) = [F:TCA]CODNUM(1)

#                                                                  # hcb 53503 fin
GSTKCPTMAN(14) = [F:TCA]MANCOU(14)
GSTKCPT   (14) = [F:TCA]CODNUM(14)
#Controle compteur
Call CTRCPT(GSTKCPT(14),type([M:QCR1]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif

GSTKCPTMAN(0) = [F:TCA]MANCOU(0) # Cpt du chrno stock
GSTKCPT   (0) = [F:TCA]CODNUM(0)

GSTKCPTMAN(1) = [F:TCA]MANCOU(1)
GSTKCPT   (1) = [F:TCA]CODNUM(1)



Return

