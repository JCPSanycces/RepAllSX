#<AdxTL>@(#)9.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation de la table ATATTAB
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Init ATATTAB file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#-------------------#
$MAJTAB

Local Integer I 
Local Integer L_NBALP, L_NBNUM
Local Char    DESIG(80)

If DOSSIER=nomap
 Local File ATABTAB [ADV] , ATEXTRA [AXX]
Else
 Local File =DOSSIER+".ATABTAB" [ADV] , =DOSSIER+".ATEXTRA" [AXX]
Endif

If dim([F:ADV]COLALPTYP)<0 or dim([F:ADV]COLNUMTYP)<0  
 Return 
Endif

Trbegin [ADV]
 For [ADV]
  Raz L_NBALP, L_NBNUM
  
  # ALPDES1
  Call LECTEXTRA(DESIG,"ATABTAB","ALPDES1",num$([F]NUMTAB),"") From ATEXTRA
  If DESIG<>""
   [F:ADV]COLALPTYP(L_NBALP)    = [F:ADV]CODTYP1
   [F:ADV]COLALPSUP(L_NBALP)    = [F:ADV]SUP1
   Call DUPTEXTRA("ATABTAB","ALPDES1",num$([F:ADV]NUMTAB),"","ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(L_NBALP)) From ATEXTRA
   # clean data from the old columns
   Call SUPTEXTRA("ATABTAB","ALPDES1",num$([F]NUMTAB),"") From ATEXTRA
   Raz [F:ADV]CODTYP1,[F:ADV]SUP1
   L_NBALP +=1
  Endif
  
  # ALPDES2
  Call LECTEXTRA(DESIG,"ATABTAB","ALPDES2",num$([F]NUMTAB),"") From ATEXTRA
  If DESIG<>""
   [F:ADV]COLALPTYP(L_NBALP)    = [F:ADV]CODTYP2
   [F:ADV]COLALPSUP(L_NBALP)    = [F:ADV]SUP2
   Call DUPTEXTRA("ATABTAB","ALPDES2",num$([F:ADV]NUMTAB),"","ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(L_NBALP)) From ATEXTRA
   # clean data from the old columns
   Call SUPTEXTRA("ATABTAB","ALPDES2",num$([F]NUMTAB),"") From ATEXTRA
   Raz [F:ADV]CODTYP2,[F:ADV]SUP2   
   L_NBALP +=1
  Endif
  
  # NUMDES1
  Call LECTEXTRA(DESIG,"ATABTAB","NUMDES1",num$([F]NUMTAB),"") From ATEXTRA
  If DESIG<>""
   [F:ADV]COLNUMTYP(L_NBNUM)    = [F:ADV]CODTYP3
   [F:ADV]COLNUMSUP(L_NBNUM)    = [F:ADV]SUP3
   Call DUPTEXTRA("ATABTAB","NUMDES1",num$([F:ADV]NUMTAB),"","ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(L_NBNUM)) From ATEXTRA
   # clean data from the old columns
   Call SUPTEXTRA("ATABTAB","NUMDES1",num$([F]NUMTAB),"") From ATEXTRA
   Raz [F:ADV]CODTYP3,[F:ADV]SUP3  
   L_NBNUM +=1
  Endif
  
  # NUMDES2
  Call LECTEXTRA(DESIG,"ATABTAB","NUMDES2",num$([F]NUMTAB),"") From ATEXTRA
  If DESIG<>""
   [F:ADV]COLNUMTYP(L_NBNUM)    = [F:ADV]CODTYP4
   [F:ADV]COLNUMSUP(L_NBNUM)    = [F:ADV]SUP4
   Call DUPTEXTRA("ATABTAB","NUMDES2",num$([F:ADV]NUMTAB),"","ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(L_NBNUM)) From ATEXTRA
   # clean data from the old columns
   Call SUPTEXTRA("ATABTAB","NUMDES2",num$([F]NUMTAB),"") From ATEXTRA
   Raz [F:ADV]CODTYP4,[F:ADV]SUP4  
   L_NBNUM +=1
  Endif
  
  If L_NBALP<>0 or L_NBNUM<>0
   Rewrite [ADV]
   If fstat
    Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),3) From DOSDIC
   Endif
  Endif
  
 Next ADV
Commit


Close Local File [ADV], [AXX]

Return




