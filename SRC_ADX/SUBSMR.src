######################################################################################
## Etiquette ajoutée par le superviseur (écran SMR1) 22/06/2015 15:42:00 (HCB)
######################################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M]LOT (nolign-1)
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ(nolign-1)
      Raz [M]ECCVALMIN(nolign-1)
      Raz [M]ECCSAIFLG(nolign-1)
   Endif
Endif
End
#                                                                          # hcb 71276 fin


######################################################################################

#                                                                            # hcb 110327 deb
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:SMR1]LOCTYP) > 0
   If  [M:SMR1]LOCTYP(nolign-1) <> [F:TLO]LOCTYP
       Read [TLO]TLO0=[M:SMR0]STOFCY;[M:SMR1]LOCTYP(nolign-1)
       If fstat
          Raz [F:TLO]
       Endif
   Endif
   If [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
      mkstat = 2
   Endif
Endif
#                                                                            # hcb 110327 deb
End
#                                                                        # hcb 51677 deb

Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
Local Char    LSEC
Local Integer I
If [M:SMR1]NBLIG=0
   [M:SMR0]PJT=VALEUR
   For I=1 To GNBDIE
       If dim([M:SMR0]CCE)>0
          Raz [M:SMR0]CCE(I-1)
          Call INISEC (LSEC, "STKENDH", I) From TRTX3CPT
          [M:SMR0]CCE(I-1) = LSEC
          [M:SMR0]DIE(I-1) = GDIE(I)
       Else
          Break
       Endif
    Next
Endif
End
#                                                                        # hcb 51677 fin

