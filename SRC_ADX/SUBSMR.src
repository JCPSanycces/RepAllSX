########################################
# Sous pro action ZCENTW, pour rafraichir l'affichage de STOENTW
Subprog APDETAIL
    If clalev([M:ENTW])
        Affzo [M:ENTW]
    Endif
    If clalev([M:SOW])
        Affzo [M:SOW]
    Endif
    If clalev([M:SMO1])
        Affzo [M:SMO1]
    Endif
    If clalev([M:SMR1])
        Affzo [M:SMR1]
    Endif
    If clalev([M:STW])
        Affzo [M:STW]
    Endif
    If clalev([M:SGW])
        Affzo [M:SGW]
    Endif
End


