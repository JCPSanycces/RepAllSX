#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################
#                 GESTION de l'OBJET SMR                 #
#                                                        #
# $XXX SMR gère les mouvements de stock suivants:        #
#    - Entrées diverses                                  #
#    - Mouvements combinés (Reste à faire)               #
#                                                        #
##################################################string$(GWRHACT-1,num$(sigma(1,min(1,dim([M]WRH)),[M]WRH(nolign-1))))#######

Call OBJET("SMR", GBIDC1, GBIDC2) From GOBJET
End

$ACTION
#--- Dem 78142
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBSMRA
 When "VARIANTE"     : Gosub VARIANTE     From SUBSMRA
 When "SETTRANS"     : Gosub SETTRANS     From SUBSMRA
 When "OUVRE"        : Gosub OUVRE        From SUBSMRA
 When "FILTRE"       : Gosub FILTRE       From SUBSMRA
 When "LIENS"        : Gosub LIENS        From SUBSMRA
 When "DEFLIG"       : Gosub DEFLIG       From SUBSMRA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBSMRA

 When "SETBOUT"      : Gosub SETBOUT      From SUBSMRA
 When "STATUT"       : Gosub STATUT       From SUBSMRA

 When "RAZCRE"       : Gosub RAZCRE       From SUBSMRA
 When "RAZDUP"       : Gosub RAZDUP       From SUBSMRA

 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBSMRA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBSMRA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBSMRA
 When "INICRE"       : Gosub INICRE       From SUBSMRA
 When "INIMOD"       : Gosub INIMOD       From SUBSMRA
 When "CREATION"     : Gosub CREATION     From SUBSMRA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBSMRA
 When "VALLIG"       : Gosub VALLIG       From SUBSMRA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBSMRA
 When "MODIF"        : Gosub MODIF        From SUBSMRA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBSMRA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBSMRA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBSMRA


 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBSMR

 When "AB5_NBLIG"    : Gosub AB5_NBLIG    From SUBSMR
 When "BB5_NBLIG"    : Gosub BB5_NBLIG    From SUBSMR

 When "AB1_LOC"      : Gosub AB1_LOC      From SUBSMR
 When "BB1_LOC"      : Gosub BB1_LOC      From SUBSMR

 When "ANNULE"       : Gosub ANNULE       From SUBSMRA
 When "ABANDON"      : Gosub ABANDON      From SUBSMRA
 When "FIN"          : Gosub ABANDON      From SUBSMRA
 When "FERME"        : Gosub FERME        From SUBSMRA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBSMRA
 When "GRISE"        : Gosub GRISE        From SUBSMRA

Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return


########################################
########################################
#
#    ACTIONS CHAMPS EN-TETE
#
########################################
########################################

########################################
# SMRNUM
########################################
# Initialise le type de document
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()

    [M:SMR0]VCRTYP=19
End

########################################
# Vérifie que le numéro est renseigné si le document n'a pas de compteur affecté.
#
Subprog C_VCRNUM(VALEUR)
Variable Char VALEUR
    #-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
    If (VALEUR="" &  GSTKCPT(9)="")
        mkstat = 2
        End
    Endif
    #-- Si on est en création , n° saisi vide et un compteur est présent on sort
    If (GREP="C" & VALEUR="" &  GSTKCPT(9)<>"")
        End
    Endif

    #-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
    If [M:SMR0]VCRNUM="" & GREP<>"C"
        Look [F:SMH]SMH0=[M:SMR0]VCRTYP;VALEUR
        If fstat
            GMESSAGE=mess(178,199,1)
            mkstat=2
            End
        Endif
    Endif

    If VALEUR<>"" & GSTKCPTMAN(9)<>2
        Look [F:SMH]SMH0=[M:SMR0]VCRTYP;VALEUR
        If fstat
            Raz VALEUR
            End
        Endif
    Endif
End

Subprog AM_STOFCY(VALEUR)
Variable Char VALEUR

Local Char    LSEC
Local Integer I

GFCY=VALEUR : Gosub CHARG_PARAM From SUBSMRA       # ana

    #------- Initialisation des sections ana --------#
    # doit être fait en am_stofcy car des sections peuvent être fonction du site #
    [M:SMR0]STOFCY=VALEUR
    For I=1 To GNBDIE
        If dim([M:SMR0]CCE)>0
            Call INISEC (LSEC, "STKENDH", I) From TRTX3CPT
            [M:SMR0]CCE(I-1) = LSEC
            [M:SMR0]DIE(I-1) = GDIE(I)   # hcb 69574
        Else
            Break
        Endif
    Next
Gosub AFF_TITCOL  From SUBSMRA          # hcb 103041

#--- Bug 65478
# Réinitialisation du dépôt
If dim([M:SMR0]WRHE)>0
   Call WRHINIT([M:SMR0]WRHE,VALEUR,5) From STKWRH
Endif
#---

# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT From SUBSMRA

End

########################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End


########################################
########################################
#
#    ACTIONS CHAMPS LIGNES
#
########################################
########################################

########################################
# NBLIG
########################################
# Gère la suppression et l'insertion des lignes
########################################
Subprog AVANT_NBLIG
Local Integer LLIG


    # Insertion de ligne.
    # Le status est en insertion uniquement sur "Avant_nblig" pas sur "Avant_saisie"
    If status=73 | status=82
        Local Integer LRET
        If dim([M:SMR1]ITMREF)=nolign
            GMESSAGE=mess(7,184,1) #"Tableau des entrées plein."
            GERR = 1
        Else
            Call STKACTLIG(nolign-1) From STKECR
            Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)
            If dim([M]PCU)>0
                Actzo [M]PCU(nolign-1),QTYPCU(nolign-1)
            Endif
            If dim([M]PCUSTUCOE)>0
                Actzo [M]PCUSTUCOE(nolign-1)
            Endif
            If dim([M]PRIORD)>0
                Actzo [M]PRIORD(nolign-1)
            Endif
            If dim([M]MVTDES)>0
                Actzo [M]MVTDES(nolign-1)
            Endif


            If GREP = "M"
               If dim(GCTRDAT) <= 0
                  If [M:SMR0]IPTDAT < date$
                     Global Integer GCTRDAT
                     # Attention ! la date d imputation est antérieure à la date du jour
                     Call MESSAGE(mess(162,184,1)) From GESECRAN
                  Endif
               Endif
            Endif


        Endif
    Endif
End

########################################
# Ajoute le menu contextuel "Détail", permettant de décomposer la ligne
# ou le menu contextuel "Modification", permettant de modifier la ligne et son détail
Subprog IB_NBLIG

    Gosub SET_NOL
    If (dim([M:SMR1]ITMREF)<nolign) | ([M:SMR1]ITMREF(NOL) = "")   # hcb 170505 29514
        GBOUT2 = ""
        GBOUT3 = ""
        GBOUT4 = ""
        GBOUT5 = ""
    Else
        Call STKINIBTN( 2, 5, 3, 4, "SMR1", "SRT", [M:SMR1]ITMREF(NOL) , [M:SMR0]STOFCY ) From STKENT
    Endif
    If [M:SMR1]WSTOSEQ(NOL)=0 | !find([M:SMR0]MVTPRICOD,1,2) | !GACTDECCST              # hcb 50197
        Raz GBOUT6
    Endif
End
########################################
Subprog B2_NBLIG
#Ouverture fenêtre de détail par clic droit
GOUVENT = 16384 # =2^14
End

########################################
Subprog B3_NBLIG
    Call INFOLOT("SMR1", nolign-1) From STKENT
End
########################################
Subprog B4_NBLIG
    GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
    GOUVENT = 1     # permet de passer le test de l'ouverture de la fenetre complément lot
End

########################################
$AB5_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:SMR0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif


If [M:SMR0]VCRNUM<>""
  SYMBOLE2="SMR"+[M:SMR0]VCRNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:SMR0]VCRNUM-mess(10,100,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return

########################################
$BB5_NBLIG
If [M:SMR0]VCRNUM<>""
  SYMBOLE2="SMR"+[M:SMR0]VCRNUM
  Unlock=SYMBOLE2
Endif
If GRELITSMR=1
    mkstat=4
Endif

Return

########################################
Subprog C_NBLIG

    If [M:SMR1]NBLIG>0
        Diszo [M:SMR0]STOFCY
    Else
        Actzo [M:SMR0]STOFCY
    Endif
    Call STKCTRNBLIG("SMR1",[M:SMR0]STOFCY) From STKENT

End

########################################
# Appelé avant l'action SAISTOENT
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Local Shortint WRET
If adxgtb<>1 & !find(status,65,68,83)
    Diszo [M]ITMREF(nolign-1)
Endif

Call OUVENT([M:SMR0]STOFCY,"SMR1",1,[M:SMR0]TRSCOD,"",19,[M:SMR0]IPTDAT,nolign-1,[M:SMR1]NBLIG,"SRT","",WRET) From STKENT
#---- Dans le cas d'une ligne incorrecte, et où dans le détail on ferait "FIN"
Affzo [M:SMR1]ITMREF(nolign-1)

Return


########################################
Subprog APRES_NBLIG
#-------------#
# Après ligne #
#-------------#
If GIMPORT | GWEBSERV
  Gosub AAPRES_NBLIG : # Si import il faut appeler le début de l'action SAISTOENT !
Endif
Local Char    LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Local Integer LRET
Raz LECCMAJ, LECCMIN
If dim([M:SMR1]ECCVALMAJ)>0
    [L]LECCMAJ  =string$([M:SMR1]ECCVALMAJ(nolign-1)<>"$",[M:SMR1]ECCVALMAJ(nolign-1))
    [L]LECCMIN  =string$([M:SMR1]ECCVALMIN(nolign-1)<>"$",[M:SMR1]ECCVALMIN(nolign-1))
Endif
If [M:SMR1]PRISAI(nolign-1)=GPRISAIAUT
    Call SETNEWPRIOVE([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(nolign-1),[M:SMR1]PRI(nolign-1),1,[M:SMR1]QTYSTU(
& nolign-1),"", LRET) From STKVAL
Else
    Call SETNEWPRI([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(nolign-1),[M:SMR1]PRI(nolign-1),"") From STKVAL
    [M:SMR1]PRIORD(nolign-1) = [M:SMR1]PRI(nolign-1)
Endif
Affzo [M:SMR1]PRI(nolign-1)
Affzo [M:SMR1]PRIORD(nolign-1)

End


########################################
# ITMREF
########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
    Gosub SET_NOL
    If [M:SMR1]WSTOFLG(NOL)=0 & [M:SMR1]CREFLG(NOL)=0
        pcolor=GCOUL(1)
    Else
        pcolor=GCOUL(0)
    Endif
End

########################################
# Quand la saisie d'une réf article s'est bien passée
# on remplit le champ désignation
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Char    LSEC
Local Integer I
#[M:SMR1]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SMR1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189

#--- Bug 62980
#--- Contrôle date entrée par rapport aux dates mouvements en attente
Local Date    LDATRUP
Local Decimal LQTYRUP
#--- Bug 69674
#Call CTLRUP([M]STOFCY,VALEUR,[M]IPTDAT,1,LDATRUP,LQTYRUP) From STKLIB
Call CTLRUP([M:SMR0]STOFCY,VALEUR,[M:SMR0]IPTDAT,1,LDATRUP,LQTYRUP) From STKLIB
#---
End

########################################
# UNITE de conditionnement
########################################
# Recherche le coefficient UC/US pour initialiser le champ PCUSTUCOE
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOE      # hcb 90680
    Gosub SET_NOL

    Call CTLUOM ([M:SMR1]ITMREF(NOL),3,"", VALEUR,LCOE, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif
    [M:SMR1]PCUSTUCOE(NOL) = LCOE   # hcb 90680
    If LMODIF=2
        Actzo [M:SMR1]PCUSTUCOE(NOL)
    Endif

    [M:SMR1]QTYSTU(NOL) = [M:SMR1]QTYPCU(NOL) * [M:SMR1]PCUSTUCOE(NOL)
    Call QTEARR([M:SMR1]QTYSTU(NOL), [F:ITM]STU) From TRTDIV
    Affzo [M:SMR1]PCUSTUCOE(NOL),QTYSTU(NOL)

End

########################################
# QUANTITE
########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
    If VALEUR<=0
        mkstat=2
    Endif
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    #--- Contrôle si la quantité UC génère une qté US arrondie
    Local Integer LRET
    If [M:SMR1]PCU(NOL)<>[M:SMR1]STU(NOL)
       Call STKCTRCOE(VALEUR,[M:SMR1]PCUSTUCOE(NOL),[M:SMR1]STU(NOL),LRET) From STKACT
       If LRET=0 : mkstat=2 : End : Endif
    Endif

    [M:SMR1]QTYSTU(NOL) = VALEUR * [M:SMR1]PCUSTUCOE(NOL)
    Call QTEARR([M:SMR1]QTYSTU(NOL), [F:ITM]STU) From TRTDIV
    Affzo [M:SMR1]QTYSTU(NOL)
End

########################################
# PCUSTUCOE Coef UC/US
########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    #--- Contrôle si le coef UC/US génère une qté US arrondie
    Local Integer LRET
    If [M:SMR1]PCU(NOL)<>[M:SMR1]STU(NOL)
       Call STKCTRCOE([M:SMR1]QTYPCU(NOL),VALEUR,[M:SMR1]STU(NOL),LRET) From STKACT
       If LRET=0 : mkstat=2 : End : Endif
    Endif

    [M:SMR1]QTYSTU(NOL) = [M:SMR1]QTYPCU(NOL) * VALEUR
    Call QTEARR([M:SMR1]QTYSTU(NOL), [F:ITM]STU) From TRTDIV
    Affzo QTYSTU(NOL)
End

########################################
# NBSLO
########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR
Call STKCTRNBSLO(VALEUR, [M:SMR1]PCU(nolign-1), [M:SMR1]QTYPCU(nolign-1)) From STKACT
End

########################################
# SLO
########################################
Subprog B2_SLO(VALEUR)
Variable Char VALEUR
    Call RECLASTSLO([M:SMR1]ITMREF(nolign-1),[M:SMR1]LOT(nolign-1),"","",VALEUR) From STKLIB
End

#---- Calcul le n° de sous lot fin en vérifiant, si nécessaire, l'existence des sous lots. ---#
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

Gosub SET_NOL

#If VALEUR = ""           # hcb 45909  test
#   Call RECLASTSLO([M:SMR1]ITMREF(nolign-1),[M:SMR1]LOT(nolign-1),"","",VALEUR) From STKLIB # hcb 45909  test
#Endif                    # hcb 45909  test


If VALEUR<>""         # hcb 45909
    Call STKCTRSLO(VALEUR, [M:SMR1]NBSLO(NOL), [M:SMR1]LOT(NOL),
&                  [M:SMR1]ITMREF(NOL), [M:SMR1]BPSLOT(NOL), [M:SMR1]GESLOT(NOL), "", 0, 0, 0,
&                  [M:SMR0]STOFCY, [M:SMR1]SLOF(NOL)) From STKACT
    If !mkstat
        Affzo [M:SMR1]SLOF(NOL)
    Endif
Endif                 # hcb 45909
End

########################################
# Dépôt
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:SMR0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:SMR0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:SMR1]WRH(nolign-1)<>""
   Raz [M:SMR1]LOC(nolign-1)
Endif
End

########################################
# TYPE D'EMPLACEMENT
########################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
#                                                                    # hcb X3-94829 deb
If dim([M:SMR1]LPNNUM)>0 & [M:SMR1]LPNNUM(nolign-1)<>""
   If [F:TLO]LOCCAT>2
      GMESSAGE=mess(399,199,1)-":"-mess([F:TLO]LOCCAT,2710,1)
      mkstat=2
      End
   Endif
Endif
#                                                                    # hcb X3-94829 fin

#--- Bug 72649
If [M:SMR1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:SMR1]LOC(nolign-1),[M:SMR1]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                            # hcb 110327 deb
If dim([M:SMR1]SERNUM) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
   Raz   [M:SMR1]SERNUM (nolign-1)
   Raz   [M:SMR1]SERNUMF(nolign-1)
   Affzo [M:SMR1]SERNUM (nolign-1)
   Affzo [M:SMR1]SERNUMF(nolign-1)
Endif
#                                                                            # hcb 110327 deb
End

########################################
# EMPLACEMENT
########################################
$AB1_LOC
    GLOCSEL = "LOCTYP='"+[M:SMR1]LOCTYP(nolign-1)+"'"
Return

$BB1_LOC
    Raz GLOCSEL
Return

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [STC]STC0=[M:SMR0]STOFCY;VALEUR
    Read [TLO]TLO0=[M:SMR0]STOFCY;[F:STC]LOCTYP
    # test si type quai autorisé
#                                                                    # hcb X3-94829 deb
#    If !fstat & [M:SMR0]SRGWAIFLG <> 2 & [F:TLO]LOCCAT = 2      # hcb 50197
#         GMESSAGE = mess(854,196,1)
#         mkstat = 2
#         End
#    Endif
   If fstat
      mkstat=2
      End
   Elsif [F:TLO]LOCCAT = 2 & [M:SMR0]SRGWAIFLG <> 2
         GMESSAGE=mess(854,196,1)
         mkstat=2
         End
   Elsif dim([M:SMR1]LPNNUM)>0 & [M:SMR1]LPNNUM(nolign-1)<>""
      If [F:TLO]LOCCAT>2
         GMESSAGE=mess(399,199,1)-":"-mess([F:TLO]LOCCAT,2710,1)
         mkstat=2
         End
      Endif
   Endif
Endif
#                                                                    # hcb X3-94829 fin

Affzo [M:SMR1]LOCTYP(nolign-1)    # Il a pu etre modifié par le controle STKCTREMP
End


