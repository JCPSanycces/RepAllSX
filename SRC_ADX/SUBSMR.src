######################################################################################
## Etiquette ajoutée par le superviseur (écran SMR1) 29/08/2006 10:04:06 (CCC)
######################################################################################
Subprog CL_PRISAI(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Raz LECCMAJ, LECCMIN
If dim([M:SMR1]ECCVALMAJ)>0
    [L]LECCMAJ = string$([M:SMR1]ECCVALMAJ(nolign-1)<>"$",[M:SMR1]ECCVALMAJ(nolign-1))
    [L]LECCMIN = string$([M:SMR1]ECCVALMIN(nolign-1)<>"$",[M:SMR1]ECCVALMIN(nolign-1))
Endif

If VALEUR=GPRISAIMAN
    VALEUR=GPRISAIAUT
    Call SETNEWPRIOVE([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(nolign-1),[M:SMR1]PRI(nolign-1),1,[M:SMR1]QTYSTU(nolign-1),"", LRET) From STKVAL
    Affzo [M:SMR1]PRI(nolign-1)
    Affzo [M:SMR1]PRIORD(nolign-1)
Else
    VALEUR=GPRISAIMAN
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SMR0) 02/03/2010 11:46:30 (TS)
######################################################################################
#--- Bug 62980
Subprog AM_IPTDAT(VALEUR)
Variable Date    VALEUR
#--- Contrôle date entrée par rapport aux dates mouvements en attente
If GREP="C" & [M]NBLIG>0
  Local Integer I
  Local Date    LDATRUP, LDAT
  Local Decimal LQTYRUP
  For I=0 To [M]NBLIG-1
    #--- Bug 69674
    #Call CTLRUP([M]STOFCY,[M]ITMREF(I),VALEUR,0,LDATRUP,LQTYRUP) From STKLIB
    Call CTLRUP([M:SMR0]STOFCY,[M:SMR1]ITMREF(I),VALEUR,0,LDATRUP,LQTYRUP) From STKLIB
    #---
    If LDAT<LDATRUP LDAT=LDATRUP Endif
  Next I
  If LDAT<>[0/0/0]
    Call MESSAGE(mess(354,184,1)-":\"+mess(355,184,1)-format$("DD2",LDAT)+
&                "\"+mess(357,184,1)-format$("DD2",LDAT)) From GESECRAN
  Endif
Endif
End
#---

