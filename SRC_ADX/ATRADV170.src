$MAJSUPER_170
#
# si on est deja dans l'appli superviseur on ne fait rien.
# superv170 n'est pas accessible pour les filiales.
#------------------
If GPRODUIT = -1
    Return
Endif


#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en V6
# on essaye de mettre a jour la v6 si même aml et même description
# ----------------------------------------
#---------------#
# cas produit X3#
# mise a jour v6 et v5#
#---------------#
WLANTRAD = [M]LAN
If GPRODUIT = 0
    If GFOLDER_V160(1) <> "" 
        Gosub X3IND160_APLSTD From ATRADAML
    Endif
    If GFOLDER_V150(1) <> "" 
        Gosub X3IND150_APLSTD From ATRADAML
    Endif
Endif

WLANTRAD = [M]LAN
# cas produit geode 
# a faire plsu tard.......
If GPRODUIT = 1

Endif



WLANTRAD = [M]LAN
# cas produit paye quand on aura les refs
# a faire plsu tard.......
If GPRODUIT = 2
    If GFOLDER_V160(3) <> "" 
        Gosub PAYIND160_APLSTD From ATRADAML
    Endif
Endif



#---------------------------------
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
# sauf les menus locaux modifiables
#---------------------------------




# lecture table amenloc pour connaitre le module
# Cas du Titre d'un menu local : WCHAPITRE=0 ou 200 
# amenloc du dossier en cours
#-------------------
WCHAPITRES=WCHAPITRE
If WCHAPITRE= 0   : WCHAPITRES=WNUMERO     : Endif
If WCHAPITRE= 200 : WCHAPITRES=200+WNUMERO : Endif
Read [XYM]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XYM]MODULE <> 1
            Return
      Endif
      If [F:XYM]AUZMOD = 2
            Return
      Endif
Else
      Return
Endif

# lecture table amenloc du superviseur pour connaitre si menu local perso par produit
# il n'y a que dans SUPERV qu'on a l'info
# amenloc superv7
# ------------------------------------------------
Read [XYA]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XYA]FLGPRO = 2
            Return
      Endif
Else
      Return
Endif



# ok on est sur un chapitre superviseur
# lecture aplstd superv et verification si c'est le même
#------------------------
WLANTRAD = [M]LAN
Gosub SUPERV170_APLSTD From ATRADAML

#---------------------------
# ok on est sur un chapitre superviseur
#---------------------------
WLANTRAD = [M]LAN
#--------------#
# - geode
#--------------#
If GFOLDER_V170(2) <> "" 
    If GPRODUIT <> 1
        Gosub GEOIND170_APLSTD From ATRADAML
    Endif
Endif
#--------------#
# -- x3 
#--------------#
If GFOLDER_V170(1) <> "" 
    If GPRODUIT <> 0
        Gosub X3IND170_APLSTD From ATRADAML
    Endif
Endif

#--------------#
# -- paye 
#--------------#
If GFOLDER_V170(3) <> "" 
    If GPRODUIT <> 2
         Gosub PAYIND170_APLSTD From ATRADAML
    Endif
Endif
#--------------#
# -- abel 
#--------------#
If GFOLDER_V170(4) <> "" 
        # --- on ne fait plus rien sur abel V7 
Endif

Return









