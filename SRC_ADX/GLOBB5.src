Subprog  CAL_AJUST_PERIODE ( PTYPPRO, PDTDBPER, PDTFNPER, RDTDBPER, RDTFNPER)
Value     Integer  PTYPPRO
Value     Date     PDTDBPER
Value     Date     PDTFNPER
Variable  Date     RDTDBPER
Variable  Date     RDTFNPER
 RDTDBPER = PDTDBPER
 RDTFNPER = PDTFNPER
 Case PTYPPRO
   When GVML_TPMOIS, GVML_TPHLFY
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "M")
     If !( func GLOBB9.CAL_DAT_ISENDOFMONTH (PDTFNPER) ) Then
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -1, "M")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "M")
     Else
       RDTFNPER = PDTFNPER
     Endif
   When GVML_TPSEMA
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "W")
     If !( func GLOBB9.CAL_DAT_ISENDOFWEEK (PDTFNPER) ) Then
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -7, "D")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "W")
     Else
       RDTFNPER = PDTFNPER
     Endif
   When GVML_TPHLFM
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "Q")
     If !( func GLOBB9.CAL_DAT_ISENDOFHLFM (PDTFNPER) ) Then
       RDTFNPER = func GLOBB9.CAL_DAT_PREM( PDTFNPER, "Q")
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( RDTFNPER, -1, "D")
     Else
       RDTFNPER = PDTFNPER
     Endif
   When GVML_TPHLFQ
     RDTDBPER = func GLOBB9.CAL_DAT_PREM( PDTDBPER, "M")
     If !( func GLOBB9.CAL_DAT_ISENDOFMONTH (PDTFNPER) ) Then
       RDTFNPER = func GLOBB9.CAL_DAT_PLUS( PDTFNPER, -1, "M")
       RDTFNPER = func GLOBB9.CAL_DAT_DERN( RDTFNPER, "M")
     Else
       RDTFNPER = PDTFNPER
     Endif
 Endcase
End
Subprog  CAL_PDS_DET_PER ( PDTDBPER, PDTDBAMT, PDTFNAMT, PDATSOR, PDATCLS, PTYPPRODAT, RPDSDETPER)
Value    Date      PDTDBPER
Value    Date      PDTDBAMT
Value    Date      PDTFNAMT
Value    Date      PDATSOR
Value    Date      PDATCLS
Value    Char      PTYPPRODAT
Variable Decimal   RPDSDETPER
Local Integer IP
Local Decimal WDURDETPER, WDURPER
Local Decimal WPDSPER, WPDSDETPER
Local Date    WDTDBAMT
  RPDSDETPER = 0
  IP = find(PDTDBPER, [M:FIY]DATSTRPER)
  If (IP = 0) Then : End : Endif
  Call CAL_DAT_DIFF( [M:FIY]DATSTRPER(IP-1), [M:FIY]DATENDPER(IP-1), PTYPPRODAT, WDURPER  ) From   GLOBB9
  [M:DIV]PD(0)= [M:FIY]DATSTRPER(IP-1): [M:DIV]PD(1)= [M:FIY]DATENDPER(IP-1)
  [M:DIV]PD(2)= [M:DIV]DATNUL : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= PDTDBAMT
  [M:DIV]PD(5)= PDTFNAMT : [M:DIV]PD(6)= PDATSOR: [M:DIV]PD(7)= PDATCLS : [M:DIV]PC(0)= PTYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDETPER = [M:DIV]RV(1)
  Case PTYPPRODAT
    When "M"     : WPDSPER = [M:FIY]NBRMONPER(IP-1)
    When "W"     : WPDSPER = [M:FIY]NBRWEKPER(IP-1)
    When "D"     : WPDSPER = [M:FIY]NBRDAYPER(IP-1)
    When "Y"     : WPDSPER = WDURPER  # neutralisation
    When "Q"     : WPDSPER = arr((([M:FIY]NBRMONPER(IP-1)*2)), 1.)
    When "T"     : WPDSPER = arr((([M:FIY]NBRMONPER(IP-1)*2)/3), 1.)
    When Default : WPDSPER = 0
  Endcase
  If ( WDURPER <> 0 ) Then
    WPDSDETPER  = WPDSPER * (WDURDETPER / WDURPER)
  Else
    WPDSDETPER = 0
  Endif
  RPDSDETPER = WPDSDETPER
End
Subprog  CAL_DOT_PER ( PMNTREF, PDOTEXE, PCUMP_1, PAMTEXC, PEXCP_1, RDOTPER, REXCPER)
Value    Decimal   PMNTREF       : # Montant de référence
Value    Decimal   PDOTEXE       : # Dotation exercice
Value    Decimal   PCUMP_1       : # Cumul dotation des périodes 1 à n-1
Value    Decimal   PAMTEXC       : # Amortissement exceptionnel
Value    Decimal   PEXCP_1       : # Cumul d'amortissement exceptionnel
Variable Decimal   RDOTPER       : # Dotation période
Variable Decimal   REXCPER       : # Amortissement exceptionnel période
RDOTPER    = 0.
REXCPER    = 0.
Local Decimal WPDSDETEXE         : WPDSDETEXE = 0
Local Decimal WPDSDET            : WPDSDET    = 0
Local Decimal WDOTPER            : WDOTPER    = 0.
Local Decimal WEXCPER            : WEXCPER    = 0.
Local Decimal WDOTPERCUM         : WDOTPERCUM = 0.
Local Decimal WDOTEXCCUM         : WDOTEXCCUM = 0.
Local Decimal WDUREXE            : WDUREXE    = 0.
Local Decimal WDURDET            : WDURDET    = 0.
Local Decimal WDETEXE            : WDETEXE    = 0.
Local Date    WDTDBPER,  WDTFNPER
Local Char    WMODAMT
Local Date    WDTDBAMT
  WDTDBAMT = [F:DEPC]STRDPRDAT
  If ( [M:DIV]MODTYP = GVML_TMSTAND ) Then
    WMODAMT = [M:DIV]MODAMT
  Else
    WMODAMT = "@@"
  Endif
  If ( [M:DIV]FLGSLDPER ) Then
    Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
    When "T"
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
    When "I"     # When "T" FQ102893
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
    Endcase
    RDOTPER  = [M:DIV]RV(1)
    If ( [M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then
      Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From   GLOBB5
    Endif
    If ( [M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) and
& (       ([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1)) <> 0
&     and  abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
&     and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1) )
& )
&  or
& (        not func GLOBB9.CAL_DAT_INSIDE(max([F:DEPC]ENDDPRDAT,[M:PCPT]ENDDPRDAT([M:DIV]DL-1)),[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I")
&     and abs(RDOTPER) > abs([M:PCPT]PERENDDPE([M:DIV]DL-1))
& )     ) Then
    Else : # FQ116979 Else
      REXCPER = 0
      End
    Endif : # FQ116979 Endif
  Endif
  Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From   GLOBB5
  If ( G_ETP_GLOBI5 ) Then
    G_SKPSTD = 0
    GPOINT = "PERDPC" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9120 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  If ( not G_SKPSTD ) Then
    Case WMODAMT
      When G_DPMSA
        WDOTPER = 0.
        WEXCPER = 0.
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      When G_DPM1P
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]DTDBAMTREG <= [M:DIV]DTFNPER ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      When G_DPMLP, G_DPMLV, G_DPMDF, G_DPMIT, G_DPMDP, G_DPMDV, G_DPMLB, G_DPMDB, G_DPMDX, G_DPMDA,
&          G_DPMLE, G_DPMDI, G_DPMDE, G_DPMFM, G_DPMLG, G_DPMRE, G_DPMDM, G_DPMSL, G_DPMAL, G_DPMAD,
&          G_DPMHL, G_DPMHD, G_DPMTL, "@@"
        If (WMODAMT = G_DPMAD) Then
          Local Date S_DTFNAMT : S_DTFNAMT = [M:DIV]DTFNAMT : [M:DIV]DTFNAMT = [0/0/0]
        Endif
        If ( WMODAMT = G_DPMRE ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
        Endif
        If ( WMODAMT = G_DPMIT ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
          If ( [M:DIV]PROEXEINV = G_OUI ) Then
            If ( [M:DIV]DTDBAMTREG >= [M:FIY]DATSTRPER(0) ) Then
              Local Date WDEB, WFIN
              Local Integer WIND
              If ( func GLOBB9.CAL_DAT_INSIDE(WDTDBAMT,[M:FIY]DATSTRFIY([M:DIV]FEC-1),[M:FIY]DATENDFIY([M:DIV]FEC-1),"I") ) Then
                Call CAL_PERIODE_SELON_DATE ( [M:DIV]DTDBAMTREG, WDEB, WFIN, WIND ) From   GLOBB8
                WDTDBAMT = WDEB
              Else
                Call CAL_LOCALISE_PERIODE_SELON_DATE ( [M:DIV]DTDBAMTREG, WDEB, WFIN, WIND ) From   GLOBB8
                WDTDBAMT = WDEB
              Endif
            Endif
          Endif
        Endif
        If ( [M:DIV]BCALPDS ) Then
          [M:DIV] BCALPDS = 0
          Local Integer NBEXE
          Local Integer NBMAX
          Local Integer IEXE
          Local Integer IPER
          Local Integer IP
          Local Decimal WPDSDETPER
          Local Integer FIRSTPER  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Depreciation
          If ([M:DIV]TRTDEM = "CALSIM") Then
            NBMAX = [M:FIY]NB_EXE
          Else
            NBMAX = [M:CNX]HRZPER(find([M:DIV]CNT, [M:CNX]CNX)-1)
          Endif
          Raz [M:FIY]PERPDSDET
          For NBEXE = 0 To NBMAX
            IEXE = ([M:DIV]FEC+NBEXE)
            [L]FIRSTPER = 1 : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Depreciation
            For IPER = 1 To [M:FIY]NBRPER(IEXE-1)
              IP = [M:FIY]INDDEBPER(IEXE-1) + (IPER-1)
              If ( func GLOBB9.CAL_DAT_INSIDE(WDTDBAMT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG ,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DETVTEDAT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") or
&                  func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:FIY]DATSTRPER(IP-1),[M:FIY]DATENDPER(IP-1),"I") ) Then
                Call CAL_PDS_DET_PER (  [M:FIY]DATSTRPER(IP-1), WDTDBAMT, [M:DIV]DTFNAMT,
&                    [M:DIV]DATSORREG, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WPDSDETPER ) From   GLOBB5
                [M:FIY]PERPDSDET (IP-1) = WPDSDETPER
              Else
                If ( WDTDBAMT > [M:FIY]DATENDPER(IP-1) or
&                    ( [M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG < [M:FIY]DATSTRPER(IP-1) ) or
&                    ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [M:FIY]DATSTRPER(IP-1) )) Then
                Else
                  If ( [M:DIV]DTFNAMT < [M:FIY]DATSTRPER(IP-1) and [M:DIV]DTFNAMT <> [0/0/0] ) Then
                    Break
                  Else
                    Case [M:DIV]TYPPRODAT
                      When "D"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRDAYPER (IP-1)
                      When "M"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRMONPER (IP-1)
                      When "W"
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRWEKPER (IP-1)
                      When "Y"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)/6)), 1.)
                      When "Q"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)*2)), 1.)
                      When "T"
                        [M:FIY]PERPDSDET (IP-1) = arr((([M:FIY]NBRMONPER(IP-1)*2)/3), 1.)
                      When Default
                        [M:FIY]PERPDSDET (IP-1) = [M:FIY]NBRDAYPER (IP-1)
                    Endcase
                  Endif
                Endif
              Endif
              : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
              If ( [M:DIV2]RGRPPER_R = GVML_REPFIRAV or
&                  [M:DIV2]RGRPPER_T = GVML_REPFIRAV or
&                  [M:DIV2]RGRPPER_I = GVML_REPFIRAV  ) Then
                If ( [M:FIY]PERPDSDET (IP-1) <> 0 ) Then
                  If ( [L]FIRSTPER ) Then
                    [L]FIRSTPER = 0
                    [M:FIY]PERPDSDET (IP-1) = 1
                  Else
                    [M:FIY]PERPDSDET (IP-1) = 0
                  Endif
                Endif
              Endif
            Next IPER
          Next NBEXE
        Endif
        WPDSDETEXE = sum( [M:FIY]PERPDSDET (find([M:DIV]PERDATREF,  [M:FIY]DATSTRPER)-1..
&                                           find([F:DEPC]FIYENDDAT, [M:FIY]DATENDPER)-1) )
        WPDSDET    = sum( [M:FIY]PERPDSDET (find([M:DIV]PERDATREF, [M:FIY]DATSTRPER)-1..
&                                           find([F:DEPC]PERENDDAT,    [M:FIY]DATENDPER)-1) )
        If (WPDSDETEXE = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          If ( [M:DIV]BSRA ) Then
             If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then : WDOTPER    = PDOTEXE - PCUMP_1  : Endif
          Else
             WDOTPER = PMNTREF- PCUMP_1
          Endif
        Elsif ([M:DIV2]BSOLDPER = G_OUI) Then
          WDOTPER = 0
        Else
          Local Decimal YDOTEXE
          If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
            Case [M:DIV]TYPCAL
            When "R"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1R)
            When "T"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1T)
            When "I"
              YDOTEXE = (PDOTEXE - [M:DIV]ECACUME_1I)
            Endcase
          Else
            YDOTEXE = PDOTEXE
          Endif
          If ( abs(PCUMP_1) > abs(YDOTEXE) and
&              ( ([M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG <= [F:DEPC]PERENDDAT) or
&                ([M:DIV]DTFNAMT   <> [0/0/0] and [M:DIV]DTFNAMT   <= [F:DEPC]PERENDDAT) )
&            ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
            If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
              [M:DIV2]BSOLDPER = G_OUI
              Case [M:DIV]TYPCAL
              When "R"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1R) - PCUMP_1
              When "T"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1T) - PCUMP_1
              When "I"
                WDOTPER = (PDOTEXE - [M:DIV]ECACUME_1I) - PCUMP_1
              Endcase
            Endif
          Else
            If ([M:DIV]RGLECAE_1 = GVML_REXCPER and PCUMP_1 = PDOTEXE) Then
              WDOTPER = 0
            Else
              WDOTPERCUM = ( PMNTREF * (WPDSDET / WPDSDETEXE) )
              [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
              WDOTPER    = WDOTPERCUM - PCUMP_1
            Endif
          Endif
          If (PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
              WDOTEXCCUM = ( PAMTEXC * (WPDSDET / WPDSDETEXE) )
              [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXCCUM = [M:DIV]RV(1)
              WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
        Endif
        If (WMODAMT = G_DPMAD) Then
          [M:DIV]DTFNAMT = S_DTFNAMT
        Endif
      When G_DPMUO
       If ( [M:DIV]DTFNPPL <> [0/0/0] and
&           ( [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG or [F:DEPC]PERSTRDAT > [M:DIV]DTFNPPL ) ) Then
          [F:DEPC]PERQTY = 0
          [F:DEPC]RSDQTY = 0
          RDOTPER = 0.
          REXCPER = 0.
          End
        Endif
        Local Integer WIPC
        Local Integer WIPN
        Local Integer WIFNE
        Local Decimal WUOAREP
        Local Decimal WUOPCUM
        WIPC   = find([M:DIV]PERDATREF, [M:PPL]PERSTRDAT)
        WIPN   = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
        WIFNE  = find([F:DEPC]FIYENDDAT, [M:PPL]PERENDDAT)
        If (WIFNE = 0 and func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNPPL, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT,"I") ) Then
          WIFNE  = [M:PPL]NB_PPL : # FQ109277
        Endif
        If ([M:PPL]IPSO) Then
          WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min([M:PPL]IPSO, WIFNE,[M:PPL]IFNA)-1))
        Else
          WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min(WIFNE,[M:PPL]IFNA)-1))
        Endif
        If ([M:PPL]IPSO) Then
        WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..min([M:PPL]IPSO-1, WIPN-1)))
        Else
        WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..WIPN-1))
        Endif
        [F:DEPC]PERQTY = [M:PPL]PERQTY(WIPN-1)                      : # UO périodes
        [F:DEPC]RSDQTY = sum([M:PPL]PERQTY(WIPN-1..[M:PPL]IFNA-1))  : # UO résiduelle periode n
        If ( WUOAREP = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          If ( [M:DIV]BSRA ) Then
             If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then : WDOTPER    = PDOTEXE - PCUMP_1  : Endif
          Else
          Endif
        Else
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( PMNTREF * (WUOPCUM / WUOAREP) )
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WUOPCUM / WUOAREP) )
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXCCUM = [M:DIV]RV(1)
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
        Endif
      When G_DPMUD, G_DPMUL, G_DPMCA, G_DPMRA, G_DPMTD
        If (  WMODAMT = G_DPMRL or ([M:DIV]TYPPRODAT = "Q" and (find(WMODAMT, G_DPMUD,G_DPMUL,G_DPMTD)>0)) ) Then
          WDTDBAMT = [M:DIV]DTDBAMTREG
        Endif
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDURDET = [M:DIV]RV(1)
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDETEXE = [M:DIV]RV(1)
        If (WDETEXE = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Endif
        Else
          If ( abs(PCUMP_1) >= abs(PDOTEXE) and [M:DIV]RGLECAE_1 <> GVML_RDOTPER  and
&              ( ([M:DIV]DATSORREG <> [0/0/0] and [M:DIV]DATSORREG <= [F:DEPC]PERENDDAT) or
&                ([M:DIV]DTFNAMT   <> [0/0/0] and [M:DIV]DTFNAMT   <= [F:DEPC]PERENDDAT) )
&            ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( PMNTREF * (WDURDET / WDETEXE) )
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WDURDET / WDETEXE) )
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXCCUM = [M:DIV]RV(1)
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
        Endif
      When G_DPMPC, G_DPMPD
        If ( PDOTEXE = 0 and PAMTEXC = 0 and [M:DIV]DATSORREG = [0/0/0] ) Then
          RDOTPER = 0.
          REXCPER = 0.
          End
        Endif
        WDTDBAMT = [M:DIV]DTDBAMTREG
        Local Integer IPER,      INDPER
        Local Decimal WRECCUMP_1
        If ( WMODAMT = G_DPMPD and [F:DEPC]ALWCOD = GVML_RPEXERC and
&            func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBPER , [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, "I") ) Then
          [M:DIV]PD(0)= WDTDBAMT : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From   GLOBB8
          WDUREXE = [M:DIV]RV(1)
        Else
          WDUREXE = 12
        Endif
        WRECUMP_1 = 0.
        If (  WDTDBAMT < [M:FIY]DATENDFIY ([M:DIV]FEC-1)  and
&         func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBPER , [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, "I") and
&         [M:DIV]DTFNPER <> [M:DIV]DTFNEXE and PCUMP_1 = 0 ) Then
          Call CAL_PERIODE_SELON_DATE ( WDTDBAMT, WDTDBPER, WDTFNPER, INDPER ) From   GLOBB8
          If (INDPER <> 0 and WDTDBPER < [M:DIV]DTDBPER ) Then
            Repeat
              Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO,
&             [M:FIY]DATSTRPER(INDPER-1), [M:FIY]DATENDPER(INDPER-1), WDTDBPER, WDTFNPER) From   GLOBB5
              [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= WDTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
              [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
              [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
              Gosub GSB_CAL_DUR_DET From   GLOBB8
              WDURDET = [M:DIV]RV(1)
              If (WDURDET <> 0 ) Then
                WRECCUMP_1 += ( PMNTREF * (WDURDET / WDUREXE) )
              Else
                WRECCUMP_1 = 0.
              Endif
              INDPER += 1
            Until INDPER >= [M:DIV]FPC
            [M:DIV]PV(0)= WRECCUMP_1 : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WRECCUMP_1 = [M:DIV]RV(1)
          Endif
        Endif
        If (  ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I") ) or
&             ( [M:DIV]DATSORREG <> [0/0/0] and
&               func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG  , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I")) or
&             ( [M:DIV]DETVTEDAT <> [0/0/0] and
&               func GLOBB9.CAL_DAT_INSIDE([M:DIV]DETVTEDAT  , [M:DIV]DTDBPER, [M:DIV]DTFNPER, "I")) ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        Else
          [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From   GLOBB8
          WDURDET = [M:DIV]RV(1)
          If (WDURDET <> 0 ) Then
            WDOTPER = ( PMNTREF * (WDURDET / WDUREXE) ) - PCUMP_1
            If ( abs(PCUMP_1) + abs(WDOTPER) > abs(PDOTEXE) and [M:DIV]DATSORREG = [0/0/0] ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
            If ( abs(PDOTEXE) < abs(PMNTREF) and [M:DIV]DATSORREG = [0/0/0] and
&                abs(PDOTEXE) - ( abs(PCUMP_1) - abs(WDOTPER) ) < 0 ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
            If ( abs(PDOTEXE) > abs(PMNTREF) and [M:DIV]DATSORREG = [0/0/0] and
&                abs(PMNTREF) = ( abs(PCUMP_1) + abs(WDOTPER) )  ) Then
              WDOTPER = PDOTEXE - PCUMP_1
            Endif
          Else
            WDOTPER = 0.
          Endif
        Endif
        If ( WRECCUMP_1 <> 0 ) Then
          [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPER = [M:DIV]RV(1)
          WDOTPER += WRECCUMP_1
        Endif
      When G_DPMSY, G_DPMPR
        Local Date     WDTDB2
        Local Decimal  WDOTPER1, WDOTPER2, WDURDET, WDUREXE
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DTFN1 : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDURDET = [M:DIV]RV(1)
        Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDUREXE) From   GLOBB8
        WDOTPER1 = ( [M:DIV]VALAMT * [M:DIV]TXAMT1 * (WDURDET / WDUREXE) )
        [M:DIV]PV(0)= WDOTPER1 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPER1 = [M:DIV]RV(1)
        WDTDB2 = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFN1,  1, "D" )
        [M:DIV]PD(0)= WDTDB2 : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL: [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDURDET = [M:DIV]RV(1)
        WDOTPER2 = ( [M:DIV]VALAMT * [M:DIV]TXAMT2 *(WDURDET / WDUREXE) )
        [M:DIV]PV(0)= WDOTPER2 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPER2 = [M:DIV]RV(1)
        WDOTPER    = WDOTPER1 + WDOTPER2 - PCUMP_1
        If ( abs(WDOTPER1 + WDOTPER2) > abs(PDOTEXE) ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        Else
          WDOTPER = ( WDOTPER1 + WDOTPER2 ) - PCUMP_1
        Endif
        If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I") ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        Endif
      When G_DPMCR
        Gosub CAL_DOT_PER_CR From   GLOBB5RU
      When G_DPMDR
        Gosub CAL_DOT_PER_DR From   GLOBB5RU
      When G_DPMLR
        Gosub CAL_DOT_PER_LR From   GLOBB5RU
      When G_DPMSR
        Gosub CAL_DOT_PER_SR From   GLOBB5RU
      When G_DPMUR
        Gosub CAL_DOT_PER_UR From   GLOBB5RU
      When G_DPMML
        Gosub CAL_DOT_PER_ML From   GLOBB5PL
      When G_DPMMD
        Gosub CAL_DOT_PER_MD From   GLOBB5PL
      When G_DPMRL
        Gosub CAL_DOT_PER_RL From   GLOBB5PL
      When G_DPMRX
        Gosub CAL_DOT_PER_RX From   GLOBB5PL
      When G_DPMRD
        Gosub CAL_DOT_PER_RD From   GLOBB5PL
      When Default
        WDOTPER = 0.
        WEXCPER = 0.
    Endcase
  Endif
  If ([M:DIV]DIFRGL = GVML_RGNODER and [F:DEPC]DPRPLN = G301FIS and [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1)) Then
    If ( abs([F:DEPC]ENDDPE + [F:DEPC]EXCDPR) = abs([M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1))
&        and  abs([F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC) = abs([M:PCPT]PERCLOCUM([M:DIV]DL-1) + [M:PCPT]PERCLOEXC([M:DIV]DL-1))
&      )
&    or
&      (  not func GLOBB9.CAL_DAT_INSIDE(max([F:DEPC]ENDDPRDAT,[M:PCPT]ENDDPRDAT([M:DIV]DL-1)),[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I")
&      )  Then
      Case [M:DIV]TYPCAL
      When "R"
        [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      When "T"
        [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      When "I"     # When "T" FQ102893
        [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
        Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      Endcase
      If ([M:DIV]RV(1) <> 0 ) Then
        WDOTPER = [M:PCPT]PERENDDPE([M:DIV]DL-1)
        WEXCPER = [M:PCPT]PEREXCDPR([M:DIV]DL-1)
      Endif
    Endif
  Endif
  [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : RDOTPER = [M:DIV]RV(1)
  [M:DIV]PV(0)= WEXCPER : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : REXCPER = [M:DIV]RV(1)
  If ( REXCPER <> 0 ) Then
  Endif
End
Subprog  CCN_PROV_PER ( PEXEACGRPR, PEXEFISRPR, PEXERVERPR, PEXESUPCAD,
&                       PP_1ACGRPR, PP_1FISRPR, PP_1RVERPR, PP_1SUPCAD,
&                       RPERACGRPR, RPERFISRPR, RPERRVERPR, RPERSUPCAD )
Value    Decimal   PEXEACGRPR    : # Provision comptable exercice
Value    Decimal   PEXEFISRPR    : # Provision fiscale exercice
Value    Decimal   PEXERVERPR    : # Reprise provision fiscale exercice
Value    Decimal   PEXESUPCAD    : # Supplément de caducité exercice
Value    Decimal   PP_1ACGRPR    : # Cumul provision comptable des périodes 1 à n-1
Value    Decimal   PP_1FISRPR    : # Cumul provision fiscale des périodes 1 à n-1
Value    Decimal   PP_1RVERPR    : # Cumul reprise provision fiscale des périodes 1 à n-1
Value    Decimal   PP_1SUPCAD    : # Cumul supplément de caducité des périodes 1 à n-1
Variable Decimal   RPERACGRPR    : # Provision comptable période
Variable Decimal   RPERFISRPR    : # Provision fiscale période
Variable Decimal   RPERRVERPR    : # Reprise provision fiscale période
Variable Decimal   RPERSUPCAD    : # Supplément de caducité période
RPERACGRPR    = 0.
RPERFISRPR    = 0.
RPERRVERPR    = 0.
RPERSUPCAD    = 0.
Local Decimal WPDSDETEXE         : WPDSDETEXE = 0
Local Decimal WPDSDET            : WPDSDET    = 0
Local Decimal WDOTPER            : WDOTPER    = 0.
Local Decimal WEXCPER            : WEXCPER    = 0.
Local Decimal WDOTPERCUM         : WDOTPERCUM = 0.
Local Decimal WDUREXE            : WDUREXE    = 0.
Local Decimal WDURDET            : WDURDET    = 0.
Local Decimal WDETEXE            : WDETEXE    = 0.
Local Decimal WDURDETCPT         : WDURDETCPT = 0.
Local Decimal WDETEXECPT         : WDETEXECPT = 0.
Local Date    WDTDBPER,  WDTFNPER
Local Char    WMODAMT
Local Date    WDTDBAMT
  WDTDBAMT = [F:DEPC]STRDPRDAT
  Call CAL_AJUST_PERIODE
&      ( [M:DIV]TYPPRO, [M:DIV]EXEDATREF, [F:RPRC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From GLOBB5
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNEXE
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDETCPT = [M:DIV]RV(1)
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNEXE
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDETEXECPT = [M:DIV]RV(1)
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDET = [M:DIV]RV(1)
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSORCCN : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDETEXE = [M:DIV]RV(1)
  If ( WDETEXECPT = 0 ) Then
    RPERACGRPR = 0.
  Else
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1ACGRPR) >= abs(PEXEACGRPR) ) Then
      WDOTPER    = PEXEACGRPR - PP_1ACGRPR
    Else
      WDOTPERCUM = ( PEXEACGRPR * (WDURDETCPT / WDETEXECPT) )
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      WDOTPER    = WDOTPERCUM - PP_1ACGRPR
    Endif
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERACGRPR = [M:DIV]RV(1)
  Endif
  If ( WDETEXE = 0 ) Then
    RPERFISRPR = 0.
    RPERRVERPR = 0.
    RPERSUPCAD = 0.
  Else
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1FISRPR) >= abs(PEXEFISRPR) ) Then
      WDOTPER    = PEXEFISRPR - PP_1FISRPR
    Else
      WDOTPERCUM = ( PEXEFISRPR * (WDURDET / WDETEXE) )
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      WDOTPER    = WDOTPERCUM - PP_1FISRPR
    Endif
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERFISRPR = [M:DIV]RV(1)
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1RVERPR) >= abs(PEXERVERPR) ) Then
      WDOTPER    = PEXERVERPR - PP_1RVERPR
    Else
      WDOTPERCUM = ( PEXERVERPR * (WDURDET / WDETEXE) )
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      WDOTPER    = WDOTPERCUM - PP_1RVERPR
    Endif
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERRVERPR = [M:DIV]RV(1)
    WDOTPER = 0.
    WDOTPERCUM = 0.
    If ( abs(PP_1SUPCAD) >= abs(PEXESUPCAD) ) Then
      WDOTPER    = PEXESUPCAD - PP_1SUPCAD
    Else
      WDOTPERCUM = ( PEXESUPCAD * (WDURDET / WDETEXE) )
      [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
      WDOTPER    = WDOTPERCUM - PP_1SUPCAD
    Endif
    [M:DIV]PV(0)= WDOTPER : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPERSUPCAD = [M:DIV]RV(1)
  Endif
  If ( [F:WFAS]GACACN = GVML_NIENCOU ) Then
    RPERACGRPR = 0
    RPERFISRPR = 0
    RPERRVERPR = 0
    RPERSUPCAD = 0
  Endif
  If ( [F:WFAS]RNWDAT <> [0/0/0] and [F:RPRC]PERSTRDAT > [F:WFAS]RNWDAT ) Then
    If ( [F:WFAS]RNWFLG = G_OUI ) Then
      RPERFISRPR = 0
    Endif
    RPERRVERPR = 0
    RPERSUPCAD = 0
  Endif
 If ( [F:WFAS]ISSDAT <> [0/0/0] and[F:RPRC]PERSTRDAT > [F:WFAS]ISSDAT ) Then
    RPERACGRPR = 0
    RPERFISRPR = 0
    RPERRVERPR = 0
    RPERSUPCAD = 0
 Endif
End
