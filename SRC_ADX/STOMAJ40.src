#CHECK IGNORE_SOURCE
Call OUVRE_TRACE ("ccc") From LECFIC
Local File ADOSSIER
Read [F:ADS]DOSSIER="GX3APP"
#Call LOTFCY([F:ADS]DOSSIER)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
#################################################################################
# Avant mise à jour dictionnaire    AMAJDIC40                                   #
# ----------------------------------------------------------------------------- #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                 ASTOMAJ40                                   #
# ----------------------------------------------------------------------------- #
# ----------------------------------------------------------------------------- #
# Après mise à jour                 STOMAJ40                                    #
# ----------------------------------------------------------------------------- #
#                                                                               #
#################################################################################

Subprog AMAJDIC40

Local File ADOSACT                  [ADA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]

End

Subprog ASTOMAJ40
Local Integer NUMPROC
Raz NUMPROC

End

#################################################################################
Subprog STOMAJ40
Local Integer NUMPROC
Raz NUMPROC

#---- Init des nouvelles zones inventaires ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ40 Stocks Transactions Process "+num$(NUMPROC)+": Update CUNLISTE") From DOSSUB
Call STKCUL([F:ADS]DOSSIER)



End

###############################################################################
# STKCUL : MAJ des inventaires
#             - Init date dernier inventaire
###############################################################################
# Paramètres E : LDOS   = Dossier
#################################################################################
Subprog STKCUL(LDOS)
Value Char LDOS
#
#----- Ouverture des fichiers -----#
If clalev([F:CUL]) = 0 : Local File =LDOS+".CUNLISTE"  [CUL]  : Endif
If clalev([F:STJ1])= 0 : Local File =LDOS+".STOJOU"    [STJ1] : Endif
If clalev([F:STJ]) = 0 : Local File =LDOS+".STOJOU"    [STJ]  : Endif
If clalev([F:ITG]) = 0 : Local File =LDOS+".ITMCATEG"  [ITG]  : Endif
If clalev([F:ITM]) = 0 : Local File =LDOS+".ITMMASTER" [ITM]  : Endif
If clalev([F:CUD]) = 0 : Local File =LDOS+".CUNLISDET" [CUD]  : Endif
If clalev([F:STJ5])= 0 : Local File =LDOS+".STOJOU"    [STJ5] : Endif            # hcb 105294
If clalev([F:SMA]) = 0 : Local File =LDOS+".STKMVTADJ" [SMA]  : Endif            # hcb 105294


#----                                                                CUNLISTE ----#
Call ECR_TRACE("Start trace : CUNLISTE" ,0) From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [CUL]
For [CUL]CUL1
    [F:CUL]LASIPTDAT = [F:CUL]IPTDAT
    If [F:CUL]CUNLISSTA < 4                   # uniquement si liste est a compter
       [F:CUL]IPTDAT    = [F:CUL]CREDAT
    Endif
    Rewrite  [CUL]  
Next
Commit

#-------------------- Vérification presence enregistrement bidon STOJOU ----------#
Local Integer WRET  
Local Char    WITMREF(GLONITM)    # hcb 121825
Local Char    WLIS              
Raz WITMREF  
Raz WLIS    
Raz WRET
#----                                                                CUNLISTE ----#
Call ECR_TRACE("Start trace : STOJOU" ,0) From GESECRAN
Call DEBTRANS From GLOCK

Trbegin [STJ]

Filter [CUD] Where CUNLISSTA < 3                     
&            Order By Key CUD3
For [CUD]
  If WITMREF <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM  
     WITMREF =  [F:CUD]ITMREF 
     WLIS    =  [F:CUD]CUNLISNUM                           
     Read [CUL]CUL0=[F:CUD]CUNSSSNUM;[F:CUD]CUNLISNUM 
     If !fstat 
        Columns [STJ] (MVTSEQ)
        Filter  [STJ] Where STOFCY   = [F:CUD]STOFCY
&                         & UPDCOD   = 2
&                         & ITMREF   = [F:CUD]ITMREF
&                         & IPTDAT   = [F:CUL]IPTDAT
&                         & MVTIND   = 0
&                         & VCRTYP   = 9
&                         & VCRNUM   = [F:CUD]CUNLISNUM
&                         & VCRNUMORI= [F:CUD]CUNSSSNUM
&                         & REGFLG   = 2

        Read [STJ] STJ0 First
        Filter  [STJ]                   
        Columns [STJ]                   
        If fstat
           Raz [F:STJ]
           [F:STJ]STOFCY    = [F:CUD]STOFCY 
           [F:STJ]OWNER     = [F:CUD]OWNER
           [F:STJ]UPDCOD    = 2
           [F:STJ]REGFLG    = 2
           [F:STJ]ITMREF    = [F:CUD]ITMREF
           [F:STJ]VCRTYP    = 9
           [F:STJ]VCRNUM    = [F:CUD]CUNLISNUM
           [F:STJ]VCRNUMORI = [F:CUD]CUNSSSNUM
           [F:STJ]IPTDAT    = [F:CUL]IPTDAT   
           If [F:ITM]ITMREF<>[F:CUD]ITMREF
              Read [ITM]ITM0=[F:CUD]ITMREF
              If fstat
                 Raz [F:ITM] 
              Endif 
           Endif
#----- Création du mouvement de stock -----#
           Call ECRSTJ(0,WRET) From STKLIB
           If WRET <> 0 
              GOK = 0 
           Else
              Call ECR_TRACE(mess(59,123,1)-" "-[F:CUD]STOFCY-" : "-[F:CUD]CUNSSSNUM-" : "-[F:CUD]CUNLISNUM-" : "-[F:CUD]ITMREF,1) From GESECRAN 
           Endif
        Endif
     Endif
  Endif
  If GOK < 1
     Break
  Endif
Next
Filter [CUD]
Commit

#-----
End







