#################################################################################

Subprog AMAJDIC40

Local File ADOSACT                  [ADA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]

End

#################################################################################
# Moulinette Avant mise à jour concernant le module GPAO                        #
#################################################################################
Subprog AGPAMAJ40
Local Integer NUMPROC
Raz NUMPROC

# 102918 mm 09.2014
# modification de la structure de la table SENTENCES + index afin que les libellés
# soit stockés dans ATEXTRA
NUMPROC += 1
Call ECR_TIME("GPAMAJ40 Manufacturing Transactions Process "+num$(NUMPROC)+": Update SENTENCES") From DOSSUB
Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA45

End

#################################################################################
Subprog GPAMAJ40
Local Integer NUMPROC
Raz NUMPROC

#---- Init FLD(5)  des sections par défaut STKEOF et STKSOF ------#
NUMPROC += 1
Call ECR_TIME("GPAMAJ40 Manufacturing Transactions Process "+num$(NUMPROC)+": Update CACCEDEF") From DOSSUB
Call UTI_MOUL(APPLI) From UTIGPA41

End
