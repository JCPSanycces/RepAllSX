#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GLE
# LE          : 09 Décembre  2010 16:03:58
# Moulinette pour suppression des enregistrements de VATHIS pour lesquels il n'y a pas
# de changement de secteur
# FQ69571
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM023: Suppression dans VATHIS") From LECFIC
  Call EXE_UTIIMM023(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM023(APPLI)
 Value Char APPLI
  If clalev([F:VAT])  : Close Local File [VAT] : Endif
  Local File =APPLI+".VATHIS" [VAT]
  Call ECR_TRACE("UTIIMM023: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM023
  Call ECR_TRACE("UTIIMM023: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM023
  Local Integer NB_DEL : NB_DEL = 0

  Call ECR_TRACE("Number of VATHIS rows : "-num$(rowcount([F:VAT])), 0) From GESECRAN

  Trbegin [F:VAT]
  
  For [VAT]
    If [F:VAT]AASBUS = [F:VAT]AASBUSO
      Delete [F:VAT] Curr
      NB_DEL += 1
    Endif
  Next
  
  Call ECR_TRACE("Number of VATHIS rows deleted : "-num$(NB_DEL), 0) From GESECRAN

  If !GOK Then
    Goto AB_UTIIMM023
  Else
    Commit
  Endif
Return

$AB_UTIIMM023
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If filinfo(filpath("FIL","VATHIS","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM023(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If filinfo(filpath("FIL","VATHIS","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM023(APPLI)
End
