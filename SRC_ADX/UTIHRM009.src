#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2018-05-03 - X3-89706 - START

#----- Update formula activity code changes made in daughter folders -----#
#----- FAFPH  FKGPH FKSEQ FKSPA FKSQS FKSSD FPAPO FUKGZ KAFR  KGZA  KMIEA KPOAO-----#
#----- Changes should not affect activation/de-activation of the activity code-----#

Local Char DOSSIER(30) : DOSSIER = nomap
  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

    Call TEMPON("O") From GESECRAN
    If !GSERVEUR
      Call OUVRE_TRACE("Process UTIHRM009") From LECFIC
    Endif

    If nomap<>GDOSX3 Then
      Call MAJ_UTIHRM009(nomap)
    Else
      Local Integer OK
      Call OUINON("Run UTI on all folders in the application except for reference folder",OK) From GESECRAN
      If OK<>2 : End : Endif
      If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
      For [ADS]
        If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
          If filinfo(filpath("FIL","ACTIV","fde",[F:ADS]DOSSIER),0)>0
            Call MAJ_UTIHRM009([F:ADS]DOSSIER)
          Endif
        Endif
      Next
    Endif

    Call TEMPOFF From GESECRAN
    If !GSERVEUR
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
    Endif
  Endif
End

Subprog MAJ_UTIHRM009(APPLIW)
Value Char APPLIW()
Local Integer COMPTEUR

COMPTEUR = 0
Call ECR_TRACE("UTIHRM009: Process Start on : "+APPLIW,0) From GESECRAN
Call ECR_TRACE("------------------------------"+APPLIW,0) From GESECRAN
Call ECR_TRACE("Updating activity codes - FAFPH,FKGPH,FKSEQ,FKSPA,FKSQS,FKSSD,FPAPO,FUKGZ,KAFR,KGZA,KMIEA,KPOAO on : "+APPLIW,0) From GESECRAN
#----- Open tables -----#
If clalev([F:ACVW])  =0  Local File =APPLIW+".ACTIV"   [ACVW] : Endif

Call DEBTRANS From GLOCK
#----- Update formula activity code changes made in daughter folders -----#
#----- FAFPH  FKGPH FKSEQ FKSPA FKSQS FKSSD FPAPO FUKGZ KAFR  KGZA  KMIEA KPOAO-----#
#----- Changes should not affect activation/de-activation of the activity code-----#

Trbegin [ACVW]
Update [ACVW] Where CODACT="FAFPH" With RANG=15 , ACTFOR="KAFR & (HRPAY|HRHRM)"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FKGPH" With RANG=20
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FKSEQ" With RANG=20
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FKSPA" With RANG=20 , ACTFOR="HRPAY & KGZA"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FKSQS" With RANG=20
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FKSSD" With RANG=20
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FPAPO" With RANG=15
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="FUKGZ" With RANG=20
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KAFR"  With RANG=10 , ACTFOR="KAFRS|KYAFR"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KGZA"  With RANG=15 , ACTFOR="KZA|KAFR|KMIEA"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KMIEA" With RANG=10 , ACTFOR="KAE|KQA|KSA"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KPOAO" With RANG=5
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KAFRS" With RANG=5 , ACTFOR="KZM|KNG|KGH|KNA|KKE|KLS|KMA"
COMPTEUR += adxuprec
Update [ACVW] Where CODACT="KYAFR" With RANG=5 , ACTFOR="" , DEP=1
COMPTEUR += adxuprec
Commit


Call ECR_TRACE("UTIHRM009 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN


Call ECR_TRACE("UTIHRM009 : Process End on : "+APPLIW,0) From GESECRAN

Close Local File [ACVW]

End

Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI = GDOSX3 and GADONIX <> 2 Then
  End
Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

If func DOSVUE.ISVIEW(APPLI,"ACTIV") : End : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIHRM009(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI = GDOSX3 and GADONIX <> 2 Then
  End
Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

If func DOSVUE.ISVIEW(APPLI,"ACTIV") : End : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIHRM009(APPLI)
End

#MIPEA - 2018-05-03 - X3-89706 - END

