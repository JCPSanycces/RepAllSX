#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSP1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone IMPLEMENT
mkstat = 0
zoncou = "IMPLEMENT"
indice = 0
IMPENT = [M]IMPLEMENT
If varinit([M]IMPLEMENT,indice)=0
 IMPENT = 1
Endif
[M]IMPLEMENT = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG From SUBNCSP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call AP_NBLIG From SUBNCSP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG From SUBNCSP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TEXT
mkstat = 0
zoncou = "TEXT"
IMPENT = [M]TEXT(indice)
If varinit([M]TEXT,indice)=0
 IMPENT = 1
Endif
[M]TEXT(indice) = IMPENT

## Zone TRANTYPE
mkstat = 0
zoncou = "TRANTYPE"
WCHAR = [M]TRANTYPE(indice)
If varinit([M]TRANTYPE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TRANTYPE(indice),"807","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TRANTYPE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TRANTYPE" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]TRANTYPE(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]TRANTYPE(indice),"807","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]TRANTYPE(indice),"807",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]TRANTYPE(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_TRANTYPE([M]TRANTYPE(indice)) From SUBNCSP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ACTIONID
mkstat = 0
zoncou = "ACTIONID"
WCHAR = [M]ACTIONID(indice)
If varmode([M]ACTIONID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACTIONID" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ACTIONID(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ACTIONID" : GZNUM = 89 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ACTIONID([M]ACTIONID(indice)) From SUBNCSP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ACTIONID" : GZNUM = 89 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]ACTIONID(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ACTIONID([M]ACTIONID(indice)) From SUBNCSP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ACTIONID" : GZNUM = 89 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ACTTYP
mkstat = 0
zoncou = "ACTTYP"
WCHAR = [M]ACTTYP(indice)
If varinit([M]ACTTYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]ACTTYP(indice),"805","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ACTTYP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACTTYP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]ACTTYP(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ACTTYP" : GZNUM = 730 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]ACTTYP(indice),"805","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ACTTYP" : GZNUM = 730 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]ACTTYP(indice),"805",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "ACTTYP" : GZNUM = 730 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]ACTTYP(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_ACTTYP([M]ACTTYP(indice)) From SUBNCSP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "ACTTYP" : GZNUM = 730 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone COMPLETEDATE
mkstat = 0
zoncou = "COMPLETEDATE"
WDATE = [M]COMPLETEDATE(indice)
If varmode([M]COMPLETEDATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMPLETEDATE" : Gosub ACTION From =IMPTRT
 Endif
 If [M]COMPLETEDATE(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COMPLETEDATE" : GZNUM = 24640 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]COMPLETEDATE(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_COMPLETEDATE([M]COMPLETEDATE(indice)) From SUBNCSP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COMPLETEDATE" : GZNUM = 24640 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ACTIONER
mkstat = 0
zoncou = "ACTIONER"
WCHAR = [M]ACTIONER(indice)
If varmode([M]ACTIONER,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACTIONER" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ACTIONER(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("AUS","",[M]ACTIONER(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]ACTIONER(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ACTIONER([M]ACTIONER(indice)) From SUBNCSP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone LINESTATUS
mkstat = 0
zoncou = "LINESTATUS"
IMPENT = [M]LINESTATUS(indice)
WNUM = IMPENT
If varinit([M]LINESTATUS,indice)=0
 IMPENT = 1
Endif
If varmode([M]LINESTATUS,indice)=0
 [M]LINESTATUS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LINESTATUS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LINESTATUS(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_LINESTATUS(IMPENT) From SUBNCSP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LINESTATUS" : GZNUM = 1179 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]LINESTATUS(indice) = IMPENT

## Zone COMMENT
mkstat = 0
zoncou = "COMMENT"
WCHAR = [M]COMMENT(indice)
If varmode([M]COMMENT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_COMMENT([M]COMMENT(indice)) From SUBNCSP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]COMMENT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMMENT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]COMMENT(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_COMMENT([M]COMMENT(indice)) From SUBNCSP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COMMENT" : GZNUM = 821 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSP1"
Return

