#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet ABM
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ABM",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"          : Gosub OUVRE
 When "LIENS"          : Gosub LIENS
 When "EXEBOUT"        : Gosub EXEBOUT
 When "SETBOUT"        : Gosub SETBOUT
 When "APRES_MODIF"    : Gosub APRES_MODIF
Endcase
Return
######################################################################################
$LIENS
Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE([M]COD,nomap,STA) From ABICREUNV
If !STA 
 Call ERREUR(func AFNC.MES1(mess(101,148,1),[M]COD)) From GESECRAN
Endif
Call TEXTE([M:ABM1]INTIT,[M:ABM1]ZINTIT) From OBJDIV
Call C_AUZFCY([F:ABM]AUZFCY)
Return

$OUVRE
If clalev([F:AHH])=0  : Local File ABIHIERA   [AHH]  : Endif
If clalev([F:ABF])=0  : Local File ABITABDAT  [ABF]  : Endif
Return

$SETBOUT
CHBOU = ""
If CLECUR
 CHMEN += "2" : # Copie globale
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V1") From GOBJET
 Call VIREBOUT(CHMEN,"2") From GOBJET
Endif
Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE([M:ABM1]COD,nomap,STA) From ABICREUNV
If !STA 
 Call VIREBOUT(CHAINE,"M2") From GOBJET
 CHAINE += "V"
Endif
Return

$EXEBOUT
Case BOUT
 When "V" : Call VERIF([M]COD)
Endcase
Return

$APRES_MODIF
If status = 65 & zoncou = "NBRABF"
 OK =1
 For [AHH]AHH0
  For I=0 To [AHH]NBAHH-1
    If [AHH]CODABF(I) = [M:ABM1]CODABF(nolign-1)
     GMESSAGE =func AFNC.MES2(mess(70,148,1),[M:ABM1]CODABF(nolign-1),[F:AHH]COD-"("+func AFNC.TEXTE([F:AHH]DES)+")")
     OK = 0 : Break
    Endif
  Next I
 Next AHH
Endif
Return

Subprog VERIF(DATAM)
Value Char DATAM
Local Mask ABICREUNV [DIA]
If clalev([F:ABW])=0 : Local File ABIDATWRH [ABW] : Endif
Local Integer OK,I
Raz [M:DIA]
GINFO = 0
[M:DIA]EXPORT  = 1
[M:DIA]AUTSIT  = 1
[M:DIA]LANGORI = "FRA"
[M:DIA]LANGDES = GLANGUE
[M:DIA]DATAM   = DATAM
[M:DIA]UNIVERS = "TEST"
[M:DIA]TEST    = 2
[M:DIA]TRAD    = 1
For [ABW]ABW0
 For  I=0 To [F:ABW]NBRABM-1
  If [F:ABW]CODABM(I) =  DATAM 
   [M:DIA]DATAW = [F:ABW]COD
   If [F:ABW]LAN = GLANGUE : Break : Endif
  Endif 
 Next I
Next ABW
Call TEMPON("F") From GESECRAN
Gosub EXEC From ABICREUNV
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC
End

Subprog VERIF2(DATAM)
Value Char DATAM
If clalev([F:ABM])=0 : Local File ABIDATMRT [ABM] : Endif
If clalev([F:ABF])=0 : Local File ABITABDAT [ABF] : Endif
If clalev([F:ABZ])=0 : Local File ABITABFLD [ABZ] : Endif
If clalev([F:ABK])=0 : Local File ABITABLNK [ABK] : Endif
If clalev([F:ABI])=0 : Local File ABIDIM    [ABI] : Endif

Local Integer I , NBTEX , NBCLA
Local Integer ANO , NBANO
Local Integer MAXTEX : MAXTEX = 2500
Local Integer MAXCLA : MAXCLA = 1000
Local Char    WTEX(80)(1..MAXTEX) , WTABLE(GLONAVA)(1..MAXTEX) , WCHAMP(GLONAVA)(1..MAXTEX)
Local Char    WCLA(80)(1..MAXCLA) , WCLTAB(GLONAVA)(1..MAXCLA) , WCLCHP(GLONAVA)(1..MAXCLA)
Local Char    WCLASS(80)(1..MAXTEX)
Local Integer WDOUB(1..MAXTEX)
Local Char    TEXTE(80) , TABLE(GLONAVA) , RACINE(80)

Read [ABM]ABM0 = DATAM
Call OUVRE_TRACE(mess(118,148,1)-":"-DATAM) From LECFIC
I=1
Call VERIF_INTITULE_VARIABLE(DATAM,nomap,I) From ABICREUNV
If I=1
 For I=1 To [F:ABM]NBRABF
  TABLE = [F:ABM]CODABF(I-1)
  Gosub FAIT
 Next I
 Gosub TRACE
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$FAIT
Read [ABF]ABF0 = TABLE
Call TEXTE([F:ABF]INTIT,RACINE) From OBJDIV
NBCLA += 1
WCLA(NBCLA)   = RACINE
WCLCHP(NBCLA) = ""
WCLTAB(NBCLA) = TABLE

For [ABZ] Where CODABF=TABLE & (TYPFLD=1 or TYPFLD=2)
 Call TEXTE([F:ABZ]INTFLD,TEXTE) From OBJDIV
 NBTEX += 1
 WTEX(NBTEX)   = TEXTE
 WCHAMP(NBTEX) = [F:ABZ]CODFLD
 WTABLE(NBTEX) = TABLE
 WCLASS(NBTEX) = RACINE
Next

For [ABK] Where CODABF=TABLE
 CHAINE = [F:ABK]EXPLNK
 Repeat
  K = instr(1,CHAINE,";")
  If K
   CHAINE = right$(CHAINE,K+1)
  Endif
 Until K=0
 Read [ABZ]ABZ1 = TABLE;CHAINE
 Call TEXTE([F:ABZ]INTFLD,TEXTE) From OBJDIV
 NBCLA += 1
 WCLA(NBCLA)   = RACINE+"/"+TEXTE
 WCLCHP(NBCLA) = [F:ABZ]CODFLD
 WCLTAB(NBCLA) = TABLE
 Call DIMENSION([F:ABK]CODLNK,NBTEX,WTEX,WCHAMP,WTABLE,WCLASS,RACINE+"/"+TEXTE)
Next
Return

$TRACE
Call ECR_TRACE(mess(119,148,1),0) From GESECRAN : # Liste des classes
Call ECR_TRACE("",0) From GESECRAN
Raz WDOUB
For I=1 To NBTEX-1
 For J=I+1 To NBTEX
  If WTEX(I)=WTEX(J) & WCLASS(I)=WCLASS(J)
   WDOUB(I) = -1
   WDOUB(J) = -1
  Endif
 Next J
Next I
For I=1 To NBCLA
 Call ECR_TRACE(WCLA(I),0) From GESECRAN
 For J=1 To NBTEX
  If WCLASS(J)=WCLA(I)
   Call ECR_TRACE(space$(10)+WTEX(J)-"("+WTABLE(J)-WCHAMP(J)+")",WDOUB(J)) From GESECRAN
  Endif
 Next J
 Call ECR_TRACE("",0) From GESECRAN
Next I
Return

Subprog DIMENSION(DIMENSION,NBTEX,WTEX,WCHAMP,WTABLE,WCLASS,CLASSE)
Value    Char    DIMENSION
Variable Integer NBTEX
Variable Char    WTEX()(1..)
Variable Char    WCHAMP()(1..)
Variable Char    WTABLE()(1..)
Variable Char    WCLASS()(1..)
Value    Char    CLASSE

Local Char    TEXTE(80)
Local Integer I , NBCLE
Local Char    CLE(GLONAVA)(1..16)
Local Integer NBDIM
Local Char    TBDIM(GLONABI)(1..100)

Read [ABI]ABI0 = DIMENSION
TEXTE = [F:ABI]CLE
NBCLE = 0
While TEXTE<>""
 NBCLE += 1
 I = instr(1,TEXTE,"+")
 If I
  CLE(NBCLE) = left$(TEXTE,I-1)
  TEXTE      = right$(TEXTE,I+1)
 Else
  CLE(NBCLE) = TEXTE
  TEXTE      = ""
 Endif
Wend

Local File ABIDIMFLD [ABJ]
NBDIM = 0
For [ABJ] Where CODDIM=DIMENSION
 If !find([F:ABJ]FLDDIM,CLE(1..NBCLE-1)) & (TYPFLD=1 or TYPFLD=2)
  Call TEXTE([F:ABJ]INTDIM,TEXTE) From OBJDIV
  NBTEX += 1
  WTEX(NBTEX)   = TEXTE
  WCHAMP(NBTEX) = [F:ABJ]FLDDIM
  WTABLE(NBTEX) = DIMENSION
  WCLASS(NBTEX) = CLASSE
 Endif
 If [F:ABJ]DIMFAT<>"" & !find([F:ABJ]DIMFAT,TBDIM(1..NBDIM))
  NBDIM += 1
  TBDIM(NBDIM) = [F:ABJ]DIMFAT
  Call DIMENSION([F:ABJ]DIMFAT,NBTEX,WTEX,WCHAMP,WTABLE,WCLASS,CLASSE)
 Endif
Next
End


#-------------------------------------------------------------------------#
$TRTCOP
Local Char    TABDIM(30)(0..250)
Local Integer NBDIM
If [M]DOSORG=nomap 
 Local File ABIDATMRT [ABM1]
 Local File ATEXTE    [ATX1] 
Else 
 Local File =[M]DOSORG+".ABIDATMRT" [ABM1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif 
If [M]DOSDES=nomap 
 Local File ABIDATMRT [ABM2] 
 Local File ATEXTE    [ATX2] 
Else 
 Local File =[M]DOSDES+".ABIDATMRT" [ABM2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABM1] , [ATX1] , [ABM2] , [ATX2] 

Return

$TR_COP
GOK = 1
Trbegin [ABM2],  [ATX2]
 Delete [ABM2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIDATMRT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABM2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABM1] Where COD=TABLE
  [F:ABM2] = [F:ABM1]
  Call COPTEXTE([F:ABM1]INTIT,[F:ABM2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif  
  Write [ABM2]
  If fstat
   GOK = 0 : Call FSTA("ABM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################
## Le même "récursivé" (pb d'indice ??)
##########################################################
$DIMENSIONS_R
TABDIM(NBDIM) = [F:ABK2]CODLNK
NBDIM +=1
Call DIMREC([M:DIA]DOSORG,NBDIM,TABDIM)
End

Subprog DIMREC(DOSORG,NBDIM,TABDIM)
Value    Char    DOSORG
Variable Integer NBDIM
Variable Char    TABDIM()(1..)
If DOSORG=nomap
 Local File ABIDIMFLD [ABJ]
Else
 Local File =DOSORG+".ABIDIMFLD" [ABJ]
Endif
For [ABJ] Where CODDIM=TABDIM(NBDIM-1)
 If [F:ABJ]DIMFAT <> "" & !find([F:ABJ]DIMFAT,TABDIM(0..NBDIM))
  TABDIM(NBDIM) = [F:ABJ]DIMFAT
  NBDIM +=1
  Call DIMREC(DOSORG,NBDIM,TABDIM)
 Endif
Next
End

######################################################################################
Subprog C_CODABF(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Integer    ERN,I
Local Char       INTITULE(80)
# Verif intitule table de fait
Read [F:ABF]ABF0 =  VALEUR
If !fstat : OK = 1 : Endif
If [F:ABF]INTEVAL <> ""
 Onerrgo ERREUR
 INTITULE = evalue([F:ABF]INTEVAL)
 Onerrgo
 If ERN
  OK = 0 
 Endif
 If instr(1,INTITULE,",")
  OK = 0
 Endif
Endif
If OK =0 
 GMESSAGE = func AFNC.MES1(mess(102,148,1),VALEUR)
 mkstat =2 : End
Endif
End 

Subprog C_ABR(VALEUR)
Variable Char    VALEUR()
Read [ABM]ABM1 = VALEUR
If !fstat & [M]COD<>[F:ABM]COD
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(56,123,1)-":"-[F:ABM]COD : # Table
 mkstat=2 : End
Endif
End

Subprog C_AUZFCY(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo FNC
Else
 Effzo FNC
 Grizo FNC
Endif
End

Subprog AS_FNC(VALEUR)
Variable Char    VALEUR()
If [M]AUZFCY<>2
 mkstat = 2 : End
Endif
End

$ERREUR
ERN = errn
Resume

Subprog AV_INTABF(VALEUR)
Variable Char    VALEUR()
Read [F:ABF]ABF0 = [M:ABM1]CODABF(nolign-1)
If !fstat
 If [F:ABF]INTEVAL <> ""
  Onerrgo $ERREUR
  VALEUR = evalue([F:ABF]INTEVAL)
  Onerrgo
 Else
  VALEUR = func AFNC.TEXTE([F:ABF]INTIT)
 Endif
Endif
End
