#<AdxTL>@(#)0.0.0.0 $Revision$
End
#######################################################################################
# Classe OPPORCRM
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
$OPPNBQ
  Case [L]ARULE
    When "INIT"      : Gosub OPPNBQ_INIT
    When Default     : Return
  Endcase
Return

$OPPNBQ_INIT
  this.OPPNBQ = 0
Return

#######################################################################################
$DAMAVE
  Case [L]ARULE
    When "INIT"      : Gosub DAMAVE_INIT
    When Default     : Return
  Endcase
Return

$DAMAVE_INIT
  this.DAMAVE = [V]CST_ANO
Return

#######################################################################################
$DAMCUM
  Case [L]ARULE
    When "INIT"      : Gosub DAMCUM_INIT
    When Default     : Return
  Endcase
Return

$DAMCUM_INIT
  this.DAMCUM = [V]CST_AYES
Return

#######################################################################################
$PBYPRJ
  Case [L]ARULE
    When "CONTROL"   : Gosub PBYPRJ_CONTROL
    When Default     : Return
  Endcase
Return

$PBYPRJ_CONTROL
  If this.PBYPRJ > 100 Then
    [L]ASTATUS = fmet this.SETERROR("PBYPRJ", mess(83,123,1) - ":" - num$(this.PBYPRJ) - "> 100", [V]CST_AFATAL)
  Endif
Return

#######################################################################################
$OPPSUC
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPSUC_CONTROL
    When Default     : Return
  Endcase
Return

$OPPSUC_CONTROL
  If this.OPPSUC > 100 Then
    [L]ASTATUS = fmet this.SETERROR("OPPSUC", mess(83,123,1) - ":" - num$(this.OPPSUC) - "> 100", [V]CST_AFATAL)
  Endif
Return

