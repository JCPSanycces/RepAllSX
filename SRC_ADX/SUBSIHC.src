## 98833 : Vérification de l'existance de l'écran WSIH4INV utilisé par GENSIH
##########################################################################
#$CHECK_INVCNO_MSK
#Local Integer OKTRT
#Local Char SNOMTRT(GLONADC)
#
#If filinfo(filpath("ECR","WSIH4INV","msk",0),0) < 0 Then
#  GMESSAGE=mess(246,191,1)
#  OK = 0
#Else
#  Call EXISTE_ADX("", "", "W0WSIH4INV", OKTRT) From ORDSYS
#  If OKTRT > 0 Then
#    # Il existe, c'est bon
#  Else
#    GMESSAGE = mess(246,191,1)
#    OK = 0
#  Endif
#Endif
#
#Return
## 98833

#########################################################################

#########################################################################
$SEL4
#-----------------------------------------------------------------------#
# Sélection d'un contrat                                                #
#-----------------------------------------------------------------------#

# 98833 : Vérification de l'existance de l'écran WSIH4INV utilisé par GENSIH
#Gosub CHECK_INVCNO_MSK            X3-23080
#If OK = 0 GERR=1 : Return Endif   X3-23080
# 98833

# Dde 38132 : Pouvoir mettre plusieurs échéances sur une même facture
#----- On ne peut "picker" qu'une seule échéance par facture
#If [M:SIH4]NBLIG>0
#  GMESSAGE=mess(277,192,1) : OK=0 : Return
#Endif
# Dde 38132

#--- Lecture de la table [CON]
Read [CON]CON0=[F:CON]CONNUM
If fstat
   Call RSTA ("CON",[F:CON]CONNUM) From GLOCK : OK=0 : Return
Endif

If [F:CON]ITMREF = ""
    #Aucun article de facturation n'est précisé sur le contrat de service sélectionné.
    GMESSAGE = mess(636, 182, 1)
    OK = 0
    Return
Endif

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:CON]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:CON]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:CON]CONNUM, [F:CON]SSTENTCOD)
  Return
Endif
# LTA.en 79065

Gosub SEL4CONMAN
If OK=0 Return Endif

Diszo [M:SIH1]STOMVTFLG
Diszo [M:SIH1]STOFCY

Call RECH_ORINUM From SUBSIHB : # Dde 38132

Return

#########################################################################
#Picking d'un contrat associé créé manuellement
$SEL4CONMAN
Local  Char SWPJTMSG(250)  # FGR 15/12/2011 X3SUIVI71065

[F:WCON] = [F:CON]  # FGR 25/03/2013 : X3SUIVI87947
If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SRE]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SRE]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
Endif

# Dde 38132 : Pouvoir mettre plusieurs échéances sur une même facture
If [M:SIH4]NBLIG<>0
   # Contrôle des conditions des regroupement
   Gosub CTL_CDE
   If OK=0 Return Endif
Else
  # FGR 28/11/2011 : X3SUIVI71065 (début)
  If func TRTPJT.IS_PJT_AVAILABLE([F:CON]CONPJT, "[M:SIH1]PJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG([F:CON]CONPJT, SWPJTMSG) From TRTPJT
    OK = 0
    GERR = 1
    Return
  Endif
  # FGR 28/11/2011 : X3SUIVI71065 (fin)
Endif
# Dde 38132

#----- Blocage logique de la demande
SYMBOLE2="CON"+[F:CON]CONNUM : Lock=SYMBOLE2
If fstat
  GMESSAGE="$CONTSERV"-[F:CON]CONNUM-mess(10,100,1)
  OK=0 : Return
Endif
#-- pour appel GENSIH
Local Integer LCOD   : LCOD=2
Local Char    LMAJ   : LMAJ="C"
Local Integer LECH   : LECH=2
Local Integer LTEST  : LTEST=1           : # pas de trace
Local Char    LTRT   : LTRT="TRTSIHCON"
Local Char    LORINUM
Local Char    LSIVNUM
Local Integer LERR   : LERR=0

# Dde 38132
If [M]NBLIG>=1 LCOD=3 Endif

# FGR 11/02/2013 : X3SUIVI87630 (début)
Global Char GSPCKCON(GLONDES)

  GSPCKCON = "PICKE"
# FGR 11/02/2013 : X3SUIVI87630 (fin)

#Appel du composant de création facture.
Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG

# Dde 38132
#If LERR>0 : OK=0 : Raz [M:SIH4] : Affzo [M:SIH4] : Return : Endif
If LERR>0 & [M:SIH4]NBLIG>=1
    Dela [M:SIH4]NBLIG-1,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
    [M:SIH4]NBLIG -= 1
    OK=0 : Return
Endif
# Dde 38132

# LTA.sn 79065
 # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
 If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
   [M:SIH1]SSTENTCOD = [F:CON]SSTENTCOD
 Endif
 # LTA.en 79065

Return

#########################################################################
#Picking d'un contrat associé à une ligne de commande de vente (Non utilisé en V140)
$SEL4CONSOH
# Vérif. si le contrat n'a pas été facturé depuis le dernier raffraichissement de la liste de picking
If [F:CON]NEXSHIINV > [M]INVDAT
    GMESSAGE = [F:CON]CONNUM-":"-mess(249,192,1) : OK=0 : Return
Endif
#--- Lecture des tables [SOH],[SOQ],[SOP]
Read [SOH]SOH0=[F:CON]CONORIVCR
If fstat
   Call RSTA ("SOH",[F:CON]ORDNUM) From GLOCK : OK=0 : Return
Endif
Read [SOQ]SOQ0=[F:CON]CONORIVCR;[F:CON]CONORIVCRL;[F:CON]CONORIVCRL
If fstat
   Call RSTA ("SOQ",[F:CON]CONORIVCR-num$([F:CON]CONORIVCRL)) From GLOCK : OK=0 : Return
Endif
Read [SOP]SOP0=[F:CON]CONORIVCR;[F:CON]CONORIVCRL;[F:CON]CONORIVCRL
If fstat
   Call RSTA ("SOP",[F:CON]CONORIVCR-num$([F:CON]CONORIVCRL)) From GLOCK : OK=0 : Return
Endif

If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SOH]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SOH]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

#WSAU = [F:SOP]SAU
#WSTU = [F:SOP]STU

# C'est la première ligne de la facture
If [M]NBLIG = 0
   # Lecture client facture
   Read [BPC]BPC0 = [F:CON]CONBPCINV
   If fstat
      Call RSTA("BPC",[F:CON]CONBPCINV) From GLOCK : OK=0 : Return
   Endif
   # Lecture client livré
   Read [BPD]BPD0 = [F:SOQ]BPCORD;[F:SOQ]BPAADD
   If fstat : Raz [F:BPD] : Endif
   # Lecture mode de livraison
   If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif
   Raz [F:TMD]
   If [F:SOQ]MDL <> ""
      Read [TMD]TMD0 = [F:SOQ]MDL
      If  fstat : Raz [F:TMD] : Endif
   Endif
   # Alimentation des masques (entête)
   Call ALISOHSIH() From TRTVENFAC
   Close Local File [TMD]
   Call PJT_INFO_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065
Else
   # Contrôle des conditions des regroupement
   Gosub CTL_CDE
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "CON"+[F:CON]CONNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:CON]CONNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:SIH4]NBLIG
Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
[M:SIH4]NBLIG += 1
nolign = [M:SIH4]NBLIG
NOL = nolign-1
status = 0

WQTY = 1

# Alimentation de la classe [M:SDH1] de la ligne
Call ALISOQSIH(NOL,WQTY,WQTYSTU) From TRTVENFAC

Call LINNUM("SIDLIN") From TABLEAUX

Call APRES_LIGNE(NOL,1) From SUBSIHB

nolign  = NOL+1

[M:SIH1]SIHORI=7
[M:SIH1]STOMVTFLG=2

[M:SIH0]INVDAT = [F:CON]NEXINVDAT
[M:SIH2]STRDUDDAT = [F:CON]NEXINVDAT

Diszo [M:SIH1]STOMVTFLG
Diszo [M:SIH1]STOFCY

Call RECH_ORINUM From SUBSIHB

 # LTA.sn 79065
 # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
 If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
   [M:SIH1]SSTENTCOD = [F:SOH]SSTENTCOD
 Endif
 # LTA.en 7906
#Gosub CAL_FACTURE

#Raz GMESSAGE

Return

#--------------------------------------------------------------------------------#
# Contrôle de la ligne commande sélectionnée                                     #
# Elle doit être facturable                                                      #
#--------------------------------------------------------------------------------#
$CTL_CDE_LIG
Local Char SWPJTMSG(250)      : # 71065 : PJT
# Ligne gérée en contremarque et commande d'achat non générée
If find([F:SOQ]FMI,2,3) & [F:SOQ]FMINUM=""
   If [F:SOQ]ALLQTY=0
       OK=0 : GERR=1
       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(111,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
       Return
   Else
       WOK=1
       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(160,197,1)+"\"+mess(147,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
       If WOK=1 OK=0 : Return Endif
   Endif
Endif
# Ligne gérée en contremarque réceptionnée et pas de quantité allouée
If [F:SOQ]FMI=3 & [F:SOQ]ALLQTY=0 & [F:SOQ]STOMGTCOD>1
   WOK=1
   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&              +"\"+mess(65,192,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
   If WOK=1 OK=0 : Return Endif
Endif
# Ligne gérée avec un ordre de production et OF non généré
If [F:SOQ]FMI=5 & [F:SOQ]FMINUM=""
   If [F:SOQ]ALLQTY=0
       OK=0 : GERR=1
       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(138,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
       Return
   Else
       WOK=1
       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(201,197,1)+"\"+mess(147,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
       If WOK=1 OK=0 : Return Endif
   Endif
Endif
# Ligne gérée avec un ordre de production et pas de quantité allouée
If [F:SOQ]FMI=5 & [F:SOQ]ALLQTY=0
   WOK=1
   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&              +"\"+mess(124,192,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
   If WOK=1 OK=0 : Return Endif
Endif
# Issue X3-38392
# Has to be moved in TRT_LIGCDE when WQTY is calculated
## Si livraison ligne cde complète et ligne cde non allouée totalement
#If [F:SOH]DME=2 & (WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY < [F:SOQ]QTY)
#   WOK=1
#   If [F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>0
#       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
#&                  format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
#   Else
#       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
#&                  format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
#   Endif
#   If WOK=1 OK=0 : Return Endif
#Endif
# End issue X3-38392

  # --------------------------------------
  # FGR 21/04/2015 : X3SUIVI105605 (début) : seulement pour les factures
Local Integer LRET

  If [M:SIH0]INVTYP = 1 Then
    If dim([M:SIH4]ECCVALMAJ) >= 0 Then
      Call CTLECCVAL([F:SOQ]ECCVALMAJ, [F:SOQ]STOFCY, [F:SOQ]ITMREF, 4, "", [M:SIH0]INVDAT, LRET) From STKSOR
      If LRET >= 1 Then
        Raz OK
        Return
      Endif
    Endif
    #
    If dim([M:SIH4]ECCVALMIN) >= 0 Then
      Call STKCTRECC([F:SOQ]ITMREF, [F:SOQ]ECCVALMAJ, [F:SOQ]ECCVALMIN, "", 4) From STKACT
      If mkstat Then
        Raz OK
        Return
      Endif
    Endif
  Endif
  # FGR 21/04/2015 : X3SUIVI105605 (fin)
  # --------------------------------------
Return


#########################################################################
$CTL_CDE
Local Char    WMES(150), WBPCINV(GLONBPC), WSALFCY(GLONFCY)            # hcb V6
Local Char    WBPCGRU(GLONBPC), WBPCPYR(GLONBPC), WVACBPR(GLONTVB), WPJT(GLONPJT) : # Dde 38132
Local Integer WPRITYP                                                             : # Dde 38132
Local Char SWPJTMSG(250)                                                          : # Dde 71065

# FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
Gosub INIT_WONFAITQUOI
#Case currbox
Case WONFAITQUOI
    When GBOXSO3 : WMES = [F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT) :#--CPO 83985 GFMDAT au lieu de GFMD
                   WBPCINV = [F:SOH]BPCINV
                   WSALFCY = [F:SOH]SALFCY
                   WBPCGRU = [F:SOH]BPCGRU    : # Dde 38132
                   WBPCPYR = [F:SOH]BPCPYR    : # Dde 38132
                   WPRITYP = [F:SOH]PRITYP    : # Dde 38132
                   WVACBPR = [F:SOH]VACBPR    : # Dde 38132
                   WPJT    = [F:SOH]PJT       : # Dde 38132
    When GBOXCO1 : WMES = [F:CON]CONNUM-format$(GFMDAT,[F:CON]NEXINVDAT) :#--CPO 83985 GFMDAT au lieu de GFMD
                   WBPCINV = [F:CON]CONBPCINV
                   WSALFCY = [F:CON]SALFCY
                   WBPCGRU = [F:CON]CONBPCGRU : # Dde 38132
                   WBPCPYR = [F:CON]CONBPCPYR : # Dde 38132
                   WPRITYP = [F:CON]CONPRITYP : # Dde 38132
                   WVACBPR = [F:CON]CONVACBPR : # Dde 38132
                   WPJT    = [F:CON]CONPJT    : # Dde 38132
    When Default
Endcase

# FGR 28/11/2011 : X3SUIVI71065 (début)
# Uniquement pour les contrats de services
If WONFAITQUOI = GBOXCO1
  If func TRTPJT.IS_PJT_AVAILABLE(WPJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG(WPJT, SWPJTMSG) From TRTPJT
    OK = 0
    Return
  Endif
Endif
# FGR 28/11/2011 : X3SUIVI71065 (fin)
#--------------------------------------------------------------------------------#
# La ligne commande ou le contrat sélectionné ne doit pas être déjà sélectionné  #
#--------------------------------------------------------------------------------#

For I=0 To [M:SIH4]NBLIG-1
  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #Case currbox
  Case WONFAITQUOI
    When GBOXSO3 : If [F:SOQ]SOHNUM=[M:SIH4]SOHNUM(I) & [F:SOQ]SOPLIN=[M:SIH4]SOPLIN(I) & [M]CREFLG(I)=0
                      OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(145,192,1)
                      Break
                   Endif
    When GBOXCO1 : If [F:CON]CONNUM=[M:SIH4]CONNUM(I) & [M]CREFLG(I)=0
                      OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(145,192,1)
                      Break
                   Endif
    When Default
   Endcase
Next I
If OK=0 Return Endif

#-----------------------------------------#
#  Contrôle des critéres de regroupement  #
#-----------------------------------------#
#If WBPCINV<>[M:SIH0]BPCINV | ([M:SIH1]BPRPAY<>"" & [F:SOH]BPCPYR<>[M:SIH1]BPRPAY) | : # Dde 38132
#&  ([M:SIH1]BPCGRU<>"" & [F:SOH]BPCGRU<>[M:SIH1]BPCGRU)                             : # Dde 38132
If WBPCINV<>[M:SIH0]BPCINV | ([M:SIH1]BPRPAY<>"" & WBPCPYR<>[M:SIH1]BPRPAY) |
&  ([M:SIH1]BPCGRU<>"" & WBPCGRU<>[M:SIH1]BPCGRU)                                    : # Dde 38132
   OK=0 : GERR=1
   GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(102,192,1)
   Return
Endif
If WSALFCY<>[M:SIH0]SALFCY
   OK=0 : GERR=1
   GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(103,192,1)
   Return
Endif

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #Case currbox
  Case WONFAITQUOI
    When GBOXSO3 :
                # Dde 38132
                If [F:SOH]PLISTC<>[M:SIH0]PLISTC
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(305,192,1)
                   Return
                Endif
                #--CPO 80112 Champ BPIEECNUM soumis à code activité
                If (dim([M]BPIEECNUM)>0 & [F:SOH]BPIEECNUM<>[M]BPIEECNUM) | [F:SOH]EECICT<>[M]EECICT
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(303,192,1)
                   Return
                Endif
                If dim([M]EECLOC)>0 & [F:SOH]EECLOC<>[M]EECLOC
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(304,192,1)
                   Return
                Endif
                # Dde 38132

                If [F:SOH]CUR<>[M:SIH2]CUR | [F:SOH]PTE<>[M:SIH2]PTE |
&                     ([M:SIH2]DEP<>"" & [F:SOH]DEP<>[M:SIH2]DEP)
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(104,192,1)
                   Return
                Endif
                If [F:SOH]BETFCY<>[M:SIH1]BETFCY | [F:SOH]BETCPY<>[M:SIH1]BETCPY
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(102,192,1)
                   Return
                Endif
                # Factures inter-sociétés
                If [M]BETFCY=2
                    # Pas de cdes créés manuellement avec des cdes créés automatiquement
                    If [F:SOH]ORIFCY=[F:SOH]SALFCY & [M]ORIFCY<>[M]SALFCY
                       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(180,191,1)+":\"+mess(172,191,1)-mess(182,191,1)
                       Return
                    Endif
                    # Pas de cdes créés automatiquement avec des cdes créés manuellement
                    If [F:SOH]ORIFCY<>[F:SOH]SALFCY & [M]ORIFCY=[M]SALFCY
                       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(181,191,1)+":\"+mess(178,191,1)
                       Return
                    Endif
                Endif
    When GBOXCO1 : If [F:CON]CUR<>[M:SIH2]CUR | [F:CON]PTE<>[M:SIH2]PTE
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(104,192,1)
                   Return
                Endif
    When Default
Endcase

# Dde 38132
If WPRITYP<>[M:SIH1]PRITYP | WVACBPR<>[M:SIH1]VACBPR
    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(105,192,1)
    Return
Endif
#Gbn-Fq77304-New entry point to avoid the control on the project field
GPE=0 : Local Char GPECNX : GPECNX="CTL_ORD" : GPOINT="SIHCTLPJT" : Gosub ENTREE From EXEFNC
If !GPE
 If WPJT<>[M:SIH1]PJT
     OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(107,192,1)
     Return
 Endif
Endif
# Dde 38132

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SIH1]SSTENTCOD & WONFAITQUOI=GBOXSO3   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SIH1]SSTENTCOD & WONFAITQUOI=GBOXSO3   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SOH]SOHNUM, [F:SOH]SSTENTCOD)
  Return
Endif
# LTA.en 79065
#-----------------------------------------------------------
#--CPO 79550 Nouvelle règle de transfert : Contrats de services -> Facture
If WONFAITQUOI = GBOXCO1
  # Controle du champ GRUFLG :
  # Si Oui (1), pas de restriction
  #  Sinon (2), vérifier que les éléments en % ont la meme valeur
  Local Integer I2
  Local Decimal DTAAMTCMP
  Local Char    TSTRUL
  #--Il faut avant tout voir si le contrat à l'origine de la facture
  #--n'a pas fait l'objet d'autres factures
  Local Integer WEXIST_PREV_INV
  WEXIST_PREV_INV = func CON_CHECK_EXIST_PREV_INV([F:CON]CONNUM,[M:SIH0]NUM)

  For I=0 To dim([F:CON]INVDTA) - 1
      If [F:CON]INVDTA(I) = 0 : Break : Endif
      If [F:CON]INVDTATYP(I) = 3 : # %
          # Recherche Param concernant Doc Ori et Dest
          TSTRUL = num$([F:CON]INVDTA(I)) + "~23~4"
          I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

          If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
              If [M:SFIT]T_BRDRUL(I2)=3 and WEXIST_PREV_INV=[V]CST_ATRUE : # eclaté sur 1ere facture
                  DTAAMTCMP=0
              Else
                  DTAAMTCMP=[F:CON]INVDTAAMT(I)
              Endif

              I2 = find ( [F:CON]INVDTA(I) , [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
              If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                  OK=0 : GERR=1
                  # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                  Local Char SHOAXX
                  Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:CON]INVDTA(I)),"") From ATEXTRA
                  GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                  Break
              Endif
          Endif
      Endif
  Next I
Endif
#-----------------------------------------------------------
#--/
# Si picking de contrat de service, on arrête les contrôles
  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #If currbox = GBOXCO1 Return Endif
  If WONFAITQUOI = GBOXCO1 Return Endif

#----------------------------------#
# Contrôle des liens cde/liv/fac   #
#----------------------------------#
# 1 facture/commande(soldée) ou 1 commande/BL
If [M:SIH0]IME<=3 & YSOHNUM<>"" & [F:SOH]SOHNUM<>YSOHNUM
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(55,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
# Si une facture par client livré
If [M:SIH0]IME=4 & ([F:SOQ]BPCORD<>[M:SIH1]BPCORD | [F:SOQ]BPAADD<>[M:SIH1]BPAADD)
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&           +"\"+mess(101,192,1)+"\"+mess(192,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif


# Controle du champ GRUFLG :
# Si Oui (1), pas de restriction
#  Sinon (2), vérifier que les éléments en % ont la meme valeur
Local Integer I2
Local Decimal DTAAMTCMP
Local Char    TSTRUL
#--CPO 107663
For I=0 To dim([F:SOH]INVDTA) - 1
    If [F:SOH]INVDTA(I) = 0 : Break : Endif
    If [F:SOH]INVDTATYP(I) = 3 : # %
        # Recherche Param concernant Doc Ori et Dest
        TSTRUL = num$([F:SOH]INVDTA(I)) + "~12~18"
        I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

        If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
            If [M:SFIT]T_BRDRUL(I2)=3 and [F:SOH]INVSTA<>1 : # eclaté sur 1ere facture et deja partiellement ou totalement facturée
                DTAAMTCMP=0
            Else
                DTAAMTCMP=[F:SOH]INVDTAAMT(I)
            Endif

            I2 = find ([F:SOH]INVDTA(I), [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
            If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                OK=0 : GERR=1
                # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                Local Char SHOAXX
                Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SOH]INVDTA(I)),"") From ATEXTRA
                GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                Break
            Endif
        Endif
    Endif
Next I
#--/
# ACA - Controle des codes adresses client commande et facture
If ([F:SOH]BPAINV<>[M:ADB3]BPAADD)
    OK=0 : GERR=1
    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&       format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(329,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    Return
Endif


Return

#########################################################################
$SEL5
#-----------------------------------------------------------------------#
# Sélection d'une facture                                               #
#-----------------------------------------------------------------------#
# Issue X3-38212
#Localisation Belge --str
If func AFNC.ACTIV("KBE")
  If find([M:SIH0]INVTYP,2,4)
    If func AFNC.PARAM("BELVCS",GSOCIETE)="2"
      #--For credit note : only one invoice can be attached
      # !! if direct suppression of lines, the fields [M:SIH1]SIHORIxxx are not refreshed
      Local Integer W_I
      For W_I=0 To [M:SIH4]NBLIG-1
        If [M:SIH4]XSIHORINUM(W_I)<>''
          If [M:SIH4]XSIHORINUM(W_I)<>[F:SID]NUM | [M:SIH4]CREFLG(W_I)<>0
            OK=0 : FIN=1
            GMESSAGE=mess(165,187,1) :#--One Invoice per Credit Note
          Endif
          Break
        Endif
      Next
    Endif
  Endif
Endif
If OK=0 : Return : Endif
#Localisation Belge --end
# End issue X3-38212

Local  Integer WLIG, WOK, CDTSTA
Global Libelle GSIVSUP
#--- Lecture des tables [SIH],[SIV],[SID]
Read [SIV]SIV0=[F:SID]NUM
If fstat
   Call RSTA ("SIV",[F:SIV]NUM) From GLOCK : OK=0 : Return
Endif
Read [SIH]SIH0=[F:SID]NUM
If fstat
   Call RSTA ("SIH",[F:SIV]NUM) From GLOCK : OK=0 : Return
Endif
Read [SID]SID0=[F:SID]NUM;[F:SID]SIDLIN
If fstat
   Call RSTA ("SID",[F:SID]NUM-num$([F:SID]SIDLIN)) From GLOCK : OK=0 : Return
Endif

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")
  If [F:SLT]INVCAN=2
    Local Integer W_I

    For W_I=0 To [M:SIH4]NBLIG-1
      If [M:SIH4]XSIHORINUM(W_I)<>''
        If [M:SIH4]XSIHORINUM(W_I)<>[F:SIV]NUM
          OK=0 : FIN=1
          GMESSAGE=mess(3,7712,1) :#--One invoice per invoice cancellation credit note.
        Endif
        Break
      Endif
    Next
    If OK=0 : Return : Endif

    # Issue 37086 - 2017-07-12 by RMA : It should not be possible to cancel a paided invoice.
    If clalev([F:DAE]) = 0 : Local File GACCENTRYD [DAE] : Endif
    Read [F:DAE]DAE2 = [F:SIH]ACCNUM
    If !fstat & [F:DAE]MTC <> ""
      OK=0 : FIN=1
      GMESSAGE=mess(8,7712,1) :#--It's not possible to cancel a matched invoice.
    Endif
    If OK=0 : Return : Endif

  Endif
Endif
# -
OK=1

#--- Contrôle si règlement en attente sur cette facture
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM & TMPCUR<>0
    GERR=1 : Call ERREUR(mess(74,119,1)) From GESECRAN
    OK=0 : Break
Next
If OK=0 : Return : Endif

#--- Contrôle de la devise
Local Char WNEWCUR : WNEWCUR=[F:SIH]CUR

If [F:SIH]CUR <> GEURO & ([M:SIH0]CUR = GEURO | [M]NBLIG = 0)
    If !find([F:SIH]NUM, [M]XSIHORINUM(0..[M]NBLIG-1))
        Local Char WDEVISE : Local Date WDAT : Local Integer WOK
        WDEVISE=[F:SIH]CUR:WDAT=[M:SIH0]INVDAT
        Gosub CTLDEVISEIN From CONTX3
#       Devise "in" interdite ou disparue
        If WOK=2 | WOK=3 WNEWCUR=GEURO  Endif
        Default File [SIV]
    Else
#        On a déjà pické des lignes sur cette facture
        WNEWCUR=[M:SIH0]CUR
    Endif
Endif

If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SIV]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SIV]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
   #--- Ligne à 0 interdites
   Call PARAML(GFCY,"SIVNULL",PARAM) From ADOVAL
   GSIVNULL = val(PARAM)
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

# BRBAN 105200#US2
Gosub SEL5 From SUBSIHC1
If OK=0 : Return : Endif
# -

# --- Contrôle si la facture a déjà fait l'objet d'un avoir
# WCTL=0 : Ctrl non encore effectué car 1ère ligne de la facture traitée
# WCTL=1 : Ctrl déjà effectué sur les lignes précédentes de la facture avec abandon
# WCTL=2 : Ctrl déjà effectué sur les lignes précédentes de la facture avec poursuite
If WCTL=0
    WCTL=2
    If [F:SIV]INVCNOSTA = 2
        WOK=1
        Call AVERTIR(mess(45,191,1),WOK) From GESECRAN
        If WOK=1 WCTL=1 : OK=0 : GERR=1 : Return Endif
    Endif
Elsif WCTL=1
    OK=0 : Return
Endif

# C'est la 1ère ligne de l'avoir
If [M:SIH4]NBLIG = 0
   # Lecture client facture
   Read [BPC]BPC0 = [F:SIV]BPCINV
   If fstat
      Call RSTA("BPC",[F:SIV]BPCINV) From GLOCK : OK=0 : Return
   Endif

   # Issue X3-63491
   If [F:SIH]CUR <> WNEWCUR
     Local Integer SPSTAT
     Local Char    WOLDCUR(GLONTCU), WNEWCUR(GLONTCU)
     Local Integer WCURTYP
     Local Date    WINVDAT

     WOLDCUR = [F:SIH]CUR
     #WNEWCUR = [M:SIH0]CUR
     WCURTYP = [F:SIH]CURTYP
     WINVDAT = [M:SIH0]INVDAT
     Gosub CTL_EXIST_RAT_CUR From SUBSIHB
     If SPSTAT <> 0 OK=0 : Return Endif
   Endif
   # End issue X3-63491

   [M:SIH0]CUR = WNEWCUR
   [M:SIH2]CUR = WNEWCUR

   # FGR 22/11/2013 : X3SUIVI94311 (début)
   #If dim([M:SIH2]VATDAT)>0 : [M:SIH2]VATDAT=[F:SIV]INVDAT : Endif    # bug 15093
   If dim([M:SIH2]VATDAT) > 0 Then
     If [F:SIH]VATDAT <> [0/0/0] Then
       [M:SIH2]VATDAT = [F:SIH]VATDAT
     Else
       [M:SIH2]VATDAT = [F:SIV]INVDAT
     Endif
   Endif
   # FGR 22/11/2013 : X3SUIVI94311 (fin)

   # Alimentation des masques entête facture
   Call ALISIHSIH(4) From TRTVENFAC

   # Calcul en-cours
   #--- Alimentation cours pour conversion en-cours de dev.soc vers dev.facture (Utilisé si ctrl en-cours au niveau soc)
   Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT2<>0 WCOURS=arr([M:SIH2]RAT1/[M:SIH2]RAT2, 10^-GDECRCU) : Endif
   Call SDCDTSTA("",[M:SIH1]BPCORD,[M:SIH0]CHGTYP,WCOURS,[M:SIH0]CUR,[M:SIH0]INVDAT,0,0,CDTSTA,
&                [M:SIH0]OST,[M:SIH0]OSTAUZ) From TRTVENCDT
   # Contrôle seulement pour les avoirs
   If [M:SIH0]INVTYP=2 & (CDTSTA=2 | CDTSTA=3)
       If CDTSTA = 2 GMESSAGE = mess(151,199,1) Endif
       If CDTSTA = 3 GMESSAGE = mess(29,192,1) Endif
       WOK=1: Call AVERTIR(GMESSAGE,WOK) From GESECRAN
       Raz GMESSAGE
       If WOK=1 OK=0 : Return : Endif
   Endif
Else
   # Contrôle des conditions de regroupement
   Gosub CTL_FAC
   If OK=0 Return Endif

   # Contrôle des taux de taxe                                        : # bug 15093
   Gosub CTL_TAUTAX                                                   : # bug 15093
   If OK=0 Return Endif                                               : # bug 15093

Endif

# Contrôle de l'insertion
If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SIV"+[F:SIV]NUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SIV]NUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

 # LTA.sn 79065
 # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
 If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
   [M:SIH1]SSTENTCOD = [F:SIH]SSTENTCOD
 Endif
 # LTA.en 79065

#--- La sélection est correcte
# Ouverture de la ligne
nolign = [M:SIH4]NBLIG
Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
[M:SIH4]NBLIG += 1
nolign = [M:SIH4]NBLIG
NOL = nolign-1
status = 0

If [M:SIH1]STOMVTFLG=2 & [F:SID]STOMGTCOD<>1 & find([F:SIV]SIHORI,1,2)
    #   Pour les factures directes et les factures de commandes uniquement
    #   Initialisation et grisage champs stock sur ligne document d'entrée
    #   si "U" Pas d'initialisation des unités et coefficients
    Default Mask [SIH4]
    Call INIZONENT([F:SID]ITMREF,"SIH4",[F:SID]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]NUM,3,0) From STKECR
    If mkstat Unlock = SYMBOLE2 : OK=0 : GERR=1 : Return : Endif
#Else                                                     : # Bug 67637
#    # Pas de gestion des stocks                          : # Bug 67637
#    Default Mask [SIH4]                                  : # Bug 67637
#    Call STKRAZGRILIG("SIH4", NOL) From TRTVENSTK        : # Bug 67637
Endif                                                     : # Bug 67637

# Alimentation de la classe [M:SIH4] de la ligne
Call ALISIDSIH(4,NOL) From TRTVENFAC

Call LINNUM("SIDLIN") From TABLEAUX

# Conversion des montants si nécessaire
If [F:SIH]CUR <> [M:SIH0]CUR
    Local Char    WANCCUR : WANCCUR=[F:SIH]CUR
    Local Decimal MNTORI, MNTDES
    Local Integer I, SPSTAT
    Call CONVERT2(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, [M]GROPRI(NOL), MNTDES, SPSTAT) From TRTDEV
    [M]GROPRI(NOL) = arr(MNTDES, 10^-GDECPRI)

    For I = 1 To 9
        If evalue ("dim([m:sih4]discrgval"+num$(I)+"(nol))")>0
            If GFMTREM(I-1)="M"
                MNTORI = evalue("[m:sih4]discrgval"+num$(I)+"(NOL)")
                Call CONVERT(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, MNTORI, MNTDES, SPSTAT) From TRTDEV
                Assign "[m:sih4]discrgval"+num$(I)+"(NOL)" With MNTDES
            Endif
        Endif
    Next
    Call CONVERT2(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, [M]CPRPRI(NOL), MNTDES, SPSTAT) From TRTDEV
    [M]CPRPRI(NOL) = arr(MNTDES, 10^-GDECPRI)
Endif

GNETMAR=0

# Si avoir sur facture avec mouvement de stock
If [M:SIH1]STOMVTFLG=2
    Local Integer WRET
    If [M:SIH4]STOMGTCOD(NOL)>1 & [M:SIH4]WSTOFLG(NOL)=0 & [M:SIH4]RTNSTOUPD(NOL)=2
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=5;GFLAG
                                If fstat Raz [F:SLT] Endif
                                Endif
        # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
        Call STJSTOENTW("SIH4",12,18,[M:SIH0]INVDAT,NOL,[M:SIH4]NBLIG,"SLT",0,WRET) From STKENT
        # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
        # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer
        # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
        # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
        If WRET=4
            Call MESSAGE([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
        Elsif WRET<>0
            If WRET=2
                Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-"\"-mess(285,192,1)) From GESECRAN
            Elsif WRET=6
                Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
            Endif
            Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG : [M:SIH4]NBLIG-=1
            If left$([M:SIH4]SIDTEX(NOL),3)="SID"
                Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
            Endif
            # Unlock entête facture
            SYMBOLE2 = "SIV"+[F:SID]NUM
            Unlock = SYMBOLE2
            GERR=1 : OK=0 : Return
        Endif
#        Call RECPRISTJ([M:SIH1]STOFCY,5,[M:SIH4]XSIHORINUM(NOL),[M:SIH4]SIDORILIN(NOL),[M:SIH4]PRIORD(NOL)) From STKENT
        Call RECPRISTJ([M:SIH4]DSTOFCY(NOL),5,[M:SIH4]XSIHORINUM(NOL),[M:SIH4]SIDORILIN(NOL),[M:SIH4]PRIORD(NOL)) From STKENT
    Endif
Endif

Gosub SIH_SIH_PLUS From SUBSFIT
#If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  OK = 0
  Return
Endif

# Bug 24952 : Avoir sur facture : il faut conserver le prix de revient de la facture pour avoir la même marge
# Calculs prix net, marge et maj montants livrés et poids
#Call ALICLCAMT([M:SIH4]ITMREF(NOL), [M:SIH4]QTY(NOL), NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
#Call CLCNETPRI([M:SIH4]QTY(NOL),[M:SIH0]CUR, NOL)From TRTVENPRI
#Call CLCPFM([M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,[M:SIH0]CUR,NOL,1) From TRTVENPRI
Call APRES_LIGNE(NOL,1) From SUBSIHB
GNETMAR=1

nolign  = NOL+1
[M:SIH1]SIHORI=4

#--CPO 79343
If GREP<>"C" and GSIHSUPPLIGDSP<>999999
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    GSIHSUPPLIGDSP +=1
  Endif
Endif
#--/CPO

Diszo [M:SIH1]STOFCY

Call RECH_ORINUM From SUBSIHB

#Gosub CAL_FACTURE

#Raz GMESSAGE

Return

#########################################################################
$CTL_FAC
Local Char WMES(150)
Local Char SWPJTMSG(250)    : # 71065 : PJT
WMES = [F:SIV]NUM-mess(27,159,1)-[F:SID]ITMREF
#------------------------------------------------------------------#
# La ligne facture sélectionnée ne doit pas être déjà sélectionné  #
#------------------------------------------------------------------#
For I=0 To [M:SIH4]NBLIG-1
    If [F:SID]NUM=[M:SIH4]XSIHORINUM(I) & [F:SID]SIDLIN=[M:SIH4]SIDORILIN(I) & [M]CREFLG(I)=0
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(199,192,1)
        Break
    Endif
Next I
If OK=0 Return Endif

#-----------------------------------------#
#  Contrôle des critéres de regroupement  #
#-----------------------------------------#
If [F:SIV]BPCINV<>[M:SIH0]BPCINV
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(101,191,1) : Return
Endif
If [M:SIH1]BPCGRU<>"" & [F:SIV]BPCGRU<>[M:SIH1]BPCGRU
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(98,191,1) : Return
Endif
If [M:SIH1]BPRPAY<>"" & [F:SIV]BPRPAY<>[M:SIH1]BPRPAY
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(97,191,1) : Return
Endif
If dim([M:SIH2]BPRFCT) > 0
    If [M:SIH2]BPRFCT<>"" & [F:SIV]BPRFCT<>[M:SIH2]BPRFCT
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(100,191,1) : Return
    Endif
Endif
If [M:SIH2]BPRSAC<>"" & [F:SIH]BPRSAC<>[M:SIH2]BPRSAC
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(99,191,1) : Return
Endif
If [F:SIV]SALFCY<>[M:SIH0]SALFCY
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(103,192,1) : Return
Endif
If [F:SIV]PLISTC<>[M:SIH0]PLISTC
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(305,192,1) : Return
Endif
#--CPO 80112 Champ BPIEECNUM soumis à code activité
If (dim([M]BPIEECNUM)>0 & [F:SIV]BPIEECNUM<>[M]BPIEECNUM) | [F:SIV]EECICT<>[M]EECICT
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(303,192,1) : Return
Endif
If dim([M]EECLOC)>0 & [F:SIV]EECLOC<>[M]EECLOC
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(304,192,1) : Return
Endif
If [F:SIV]BETFCY<>[M:SIH1]BETFCY
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(102,192,1) : Return
Endif
# Avoir inter-sociétés
If [M]BETFCY=2
    # Pas de fac. issues de flux manuels avec des fac. directes ou des fac. issues de flux automatiques
    If [F:SIV]ORIFCY=[F:SIV]SALFCY & [M]ORIFCY<>[M]SALFCY
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(192,191,1)+"\"+mess(193,191,1) : Return
    Endif
    # Pas de fac. directes ou de fac. issues de flux automatiques avec des fac. issues de flux manuels
    If [F:SIV]ORIFCY<>[F:SIV]SALFCY & [M]ORIFCY=[M]SALFCY
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(191,191,1)+"\"+mess(194,191,1) : Return
    Endif
Endif

# Pas de ctrl de la condition de paiement (non renseignée dans les avoirs)
If [M:SIH2]DEP<>"" & [F:SIV]DEP<>[M:SIH2]DEP
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(104,192,1) : Return
Endif
If [F:SIV]CUR<>[M:SIH2]CUR & ([F:TCU]EURFLG<>2 | [M:SIH2]CUR <> WNEWCUR)
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(104,192,1) : Return
Endif
If [F:SIV]PRITYP<>[M:SIH1]PRITYP | [F:SIH]VAC<>[M:SIH1]VACBPR
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(105,192,1) : Return
Endif

# 71065 : PJT
##Gbn-Fq77304-New entry point to avoid the control on the project field
#GPE=0 : Local Char GPECNX : GPECNX="CTL_INV" : GPOINT="SIHCTLPJT" : Gosub ENTREE From EXEFNC
#If !GPE
# If [F:SIV]PJT<>[M:SIH1]PJT
#    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(107,192,1) : Return
# Endif
# 71065 : PJT

#--CPO 71065 Code affaire
If func TRTPJT.IS_PJT_AVAILABLE([F:SID]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SID]PJT, SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
#--/CPO

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:SIH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SIH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SIH]NUM, [F:SIH]SSTENTCOD)
  Return
Endif
# LTA.en 79065

If [F:SIV]STOMVTFLG<>[M:SIH1]STOMVTFLG
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(197,192,1)+"\"+mess(198,192,1) : Return
Endif
#--------------------#
# Contrôle des liens #
#--------------------#
# Si une facture par client livré
If [M:SIH0]IME=4 & ([F:SIV]BPCORD<>[M:SIH1]BPCORD | [F:SIV]BPAADD<>[M:SIH1]BPAADD)
   OK=0 : GERR=1
   GMESSAGE=[F:SIV]NUM-mess(27,159,1)-[F:SID]ITMREF
&           +"\"+mess(197,192,1)+"\"+mess(192,192,1)
   Return
Endif

# Controle du champ GRUFLG :
# Si Oui (1), pas de restriction
#  Sinon (2), vérifier que les éléments en % ont la meme valeur

#If [F:SOH]SOHNUM <> YSOHNUM : # Bug 82556 : Ctrl si regroupement possible non effectué
    Local Integer I2
    Local Decimal DTAAMTCMP
    Local Char    TSTRUL
    #--CPO 107663
    For I=0 To dim([F:SIV]INVDTA) - 1
        If [F:SIV]INVDTA(I) = 0 : Break : Endif
        If [F:SIV]INVDTATYP(I) = 3 : # %
            # Recherche Param concernant Doc Ori et Dest
            TSTRUL = num$([F:SIV]INVDTA(I)) + "~4~5"
            I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

            If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
                #--CPO 106951 l'entrée du ML de BRDRUL est 4 "1er Avoir" ici et non pas 1 "1ère Commande"
               #If [M:SFIT]T_BRDRUL(I2)=1 and [F:SIV]INVCNOSTA<>1 : # eclaté sur 1ere facture et deja partiellement ou totalement "avoirée"
                If [M:SFIT]T_BRDRUL(I2)=4 and [F:SIV]INVCNOSTA<>1 : # eclaté sur 1ere facture et deja partiellement ou totalement "avoirée"
                    DTAAMTCMP=0
                Else
                    DTAAMTCMP=[F:SIV]INVDTAAMT(I)
                Endif

                I2 = find ( [F:SIV]INVDTA(I) , [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
                If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                    OK=0 : GERR=1
                    # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                    Local Char SHOAXX
                    Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SIV]INVDTA(I)),"") From ATEXTRA
                    GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                    Break
                Endif
            Endif
        Endif
    Next I
#--/
#Endif                       : # Bug 82556
Return

#########################################################################
# Avoir / Facture : changement de taux d'une taxe entre avoir et facture
#                   l'avoir doit avoir le taux de taxe de la facture
#------------------------------------------------------------------------
$CTL_TAUTAX                                                           : # bug 15093
Local Char    WVAT (GLONVAT)                                          : # bug 15093
Local Decimal WRATCNO, WRATINV                                        : # bug 15093
Local Integer WJL                                                     : # bug 15093
WOK=0                                                                 : # bug 15093
If [F:SID]VAT(0)<>""                                                  : # bug 15093
   WJL=find ([F:SID]VAT(0),[M:SIHV]XVTAX)                             : # bug 15093
   If WJL & [F:SID]RATTAXLIN<>[M:SIHV]XVRAT(WJL-1)                    : # bug 15093
      WOK=1 : WVAT=[F:SID]VAT(0)                                      : # bug 15093
      WRATCNO=[M:SIHV]XVRAT(WJL-1) : WRATINV=[F:SID]RATTAXLIN         : # bug 15093
   Endif                                                              : # bug 15093
Endif                                                                 : # bug 15093
If [F:SID]VAT(1)<>"" & WOK=0                                          : # bug 15093
   # voir si besoin controler taxes secondaires                           bug 15093
Endif                                                                 : # bug 15093
If [F:SID]VAT(2)<>"" & WOK=0                                          : # bug 15093
   # voir si besoin controler taxes secondaires                           bug 15093
Endif                                                                 : # bug 15093
If WOK=1                                                              : # bug 15093
  GMESSAGE  =mess(364,199,1)                                          : # bug 15093
  GMESSAGE +="\"+mess(39,105,1)+" "+WVAT                              : # bug 15093
  GMESSAGE +="  "+mess(2,267,1)+"="+num$(WRATCNO)                     : # bug 15093
  GMESSAGE +="  "+mess(55,198,1)+"="+num$(WRATINV)                    : # bug 15093
  Call AVERTIR(GMESSAGE,WOK) From GESECRAN                            : # bug 15093
  Raz GMESSAGE                                                        : # bug 15093
  If WOK=1 OK=0 : Return : Endif                                      : # bug 15093
Endif                                                                 : # bug 15093
Return                                                                : # bug 15093

#########################################################################
$SEL6
#-----------------------------------------------------------------------#
# Sélection d'une ligne de retour                                       #
#-----------------------------------------------------------------------#
Local  Integer  WOK, CDTSTA

#--- Lecture des tables [SRH],[SRD]
Read [SRH]SRH0=[F:SRD]SRHNUM
If fstat
   Call RSTA ("SRH",[F:SRH]SRHNUM) From GLOCK : OK=0 : Return
Endif
Read [SRD]SRD0=[F:SRH]SRHNUM;[F:SRD]SRDLIN
If fstat
   Call RSTA ("SRD",[F:SRD]SRHNUM-num$([F:SRD]SRDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été facturée depuis le dernier raffraichissement de la liste de picking
If [F:SRD]SIHNUM <> ""
    GMESSAGE = [F:SRD]SRHNUM-":"-mess(27,159,1)-[F:SRD]ITMREF-":"-mess(250,192,1) : OK=0 : Return
Endif
# Retour lié à une livraison
If [F:SRD]SDHNUM <> ""
#--- Lecture des tables [SDH],[SDD] correspondant
    Read [SDH]SDH0=[F:SRD]SDHNUM
    If fstat
       Call RSTA ("SDH",[F:SRD]SDHNUM) From GLOCK : OK=0 : Return
    Endif
    Read [SDD]SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN
    If fstat
       Call RSTA ("SDD",[F:SRD]SRHNUM-num$([F:SRD]SDDLIN)) From GLOCK : OK=0 : Return
    Endif
#--- Lecture des tables [SIH],[SIV] [SID] correspondant
    # On vérifie que la livraison a bien été facturée car l'avoir sur retour est initialisé à partir de la facture
    If GDLVRTNCNO=2 & [F:SDH]SIHNUM="" & WCTL=0
        GMESSAGE=[F:SRD]SRHNUM-":"-mess(324,192,1) : OK=0 : Return
    Endif
    Read [SIH]SIH0=[F:SDH]SIHNUM
    If fstat
       Call RSTA ("SIH",[F:SDH]SIHNUM) From GLOCK : OK=0 : Return
    Endif
    Read [SIV]SIV0=[F:SDH]SIHNUM
    If fstat
       Call RSTA ("SIV",[F:SDH]SIHNUM) From GLOCK : OK=0 : Return
    Endif
    # FGR 07/11/2014 : X3SUIVI103869 (début) # La facture doit être validée
    If [F:SIV]INVSTA <> 3 Then
      GMESSAGE = [F:SDH]SIHNUM - ":" -mess(36,119,1)
      OK = 0
      Return
    Endif
    # FGR 07/11/2014 : X3SUIVI103869 (fin)
    Filter [SID] Where NUM=[F:SIH]NUM & SDHNUM=[F:SDD]SDHNUM & SDDLIN=[F:SDD]SDDLIN
&                Order By Key SID0
    Read [SID]SID0 First
    If fstat : Filter [SID] : OK=0 : Return : Endif
#--- Contrôle de la devise
    Filter [SID]
    OK=1
    Local Char WNEWCUR(GLONCUR) : WNEWCUR=[F:SDH]CUR
    If [F:SDH]CUR <> GEURO & ([M:SIH0]CUR = GEURO | [M]NBLIG = 0)
        If !find([F:SDH]SDHNUM, [M]SDHNUM(0..[M]NBLIG-1))
            Local Char WDEVISE(GLONCUR) : Local Date WDAT : Local Integer WOK
            WDEVISE=[F:SDH]CUR:WDAT=[M:SIH0]INVDAT
            Gosub CTLDEVISEIN From CONTX3
#           Devise "in" interdite ou disparue
            If WOK=2 | WOK=3 WNEWCUR=GEURO  Endif
            Default File [SIV]
        Else
#            On a déjà pické des lignes sur cette facture
            WNEWCUR=[M:SIH0]CUR
        Endif
    Endif
Endif

If [M:SIH0]SALFCY="" & [F:SRH]SALFCY=""
   # Bug 55737 : Pas de site de vente par défaut et pas de site de vente sur le retour
   GMESSAGE = mess(341,192,1) : OK=0 : Return
Elsif [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SRH]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SRH]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY) From WWGLOBVEN
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
   #--- Ligne à 0 interdites
   Call PARAML(GFCY,"SIVNULL",PARAM) From ADOVAL
   GSIVNULL = val(PARAM)
Endif

#--- Lecture des tables articles
Gosub LEC_TABART
# C'est la première ligne de la facture
If [M]NBLIG = 0
   # Alimentation des masques (entête)
   If [F:SRD]SDHNUM <> ""
#      Retour de livraison : Alimentation à partir de la facture de la livraison
       WBPCINV=[F:SRH]BPCINV
       Read [BPC]BPC0 = [F:SRH]BPCINV
       If fstat
           Call RSTA("BPC",[F:SRH]BPCINV) From GLOCK : OK=0 : Return
       Endif
       [M:SIH0]CUR = WNEWCUR
       [M:SIH2]CUR = WNEWCUR
       # -------------------------------------
       # FGR 10/01/2014 : X3SUIVI84442 (début)
       ##--CPO 84442 Gestion Taux TVA en avoir client sur retour de livraison facturée
       ##--reprise correction dans $SEL5
       #If dim([M:SIH2]VATDAT)>0 : [M:SIH2]VATDAT=[F:SIV]INVDAT : Endif
       ##--/
       If dim([M:SIH2]VATDAT)>0 Then
          If [F:SIH]VATDAT <> [0/0/0] Then
           [M:SIH2]VATDAT = [F:SIH]VATDAT
         Else
           [M:SIH2]VATDAT = [F:SIV]INVDAT
         Endif
       Endif
       # FGR 10/01/2014 : X3SUIVI84442 (fin)
       # -------------------------------------
       Call ALISIHSIH(6) From TRTVENFAC
       # Calcul en-cours
       #--- Alimentation cours pour conversion en-cours de dev.soc vers dev.facture (Utilisé si ctrl en-cours au niveau soc)
       Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT2<>0 WCOURS=arr([M:SIH2]RAT1/[M:SIH2]RAT2, 10^-GDECRCU) : Endif
       Call SDCDTSTA("",[M:SIH1]BPCORD,[M:SIH0]CHGTYP,WCOURS,[M:SIH0]CUR,[M:SIH0]INVDAT,0,0,CDTSTA,
&                     [M:SIH0]OST,[M:SIH0]OSTAUZ) From TRTVENCDT
       # Contrôle seulement pour les avoirs
       If [M:SIH0]INVTYP=2 & (CDTSTA=2 | CDTSTA=3)
           If CDTSTA = 2 GMESSAGE = mess(151,199,1) Endif
           If CDTSTA = 3 GMESSAGE = mess(29,192,1) Endif
           WOK=1: Call AVERTIR(GMESSAGE,WOK) From GESECRAN
           Raz GMESSAGE
           If WOK=1 OK=0 : Return : Endif
       Endif
   Else
#      Retour direct: Alimentation à partir du client
       Local  Char WBPCINV
       If [F:SRH]BPCINV<>""
#          Il y a un clt facture sur le retour : Lecture du client facture lié au retour
           Read [BPC]BPC0 = [F:SRH]BPCINV
           If fstat
               Call RSTA("BPC",[F:SRH]BPCINV) From GLOCK : OK=0 : Return
           Endif
       Elsif [M:SIH0]BPCINV <> ""
#          Pas de clt facture sur le retour et un clt facture a été saisi : Lecture du client facture saisi
           Read [BPC]BPC0 = [M:SIH0]BPCINV
           If fstat
               Call RSTA("BPC",[M:SIH0]BPCINV) From GLOCK : OK=0 : Return
           Endif
       Else
#          Pas de clt facture sur le retour et aucun clt facture n'a été saisi :
#          Lecture du client lié au retour pour récupérer le client facture
           Read [BPC]BPC0 = [F:SRH]BPCORD
           If fstat
               Call RSTA("BPC",[F:SRH]BPCORD) From GLOCK : OK=0 : Return
           Endif
           If [F:BPC]BPCNUM <> [F:BPC]BPCINV
               Read [BPC]BPC0 = [F:BPC]BPCINV
               If fstat
                   Call RSTA("BPC",[F:BPC]BPCINV) From GLOCK : OK=0 : Return
               Endif
           Endif
       Endif
       # Lecture client livré
       Read [BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD
       If fstat
          Call RSTA("BPD",[F:SRH]BPCORD+[F:SRH]BPAADD) From GLOCK : OK=0 : Return
       Endif
       Call ALISRHSIH([F:BPC]BPCNUM) From TRTVENFAC
       #-- X3Suivi 85532
       Read [BPC]BPC0 = [M:SIH1]BPCORD
       [M:SIH1]BPCNAM=[F:BPC]BPCNAM(0)
       [M:SIH1]VACBPR=[F:BPC]VACBPR
       # Calcul en-cours
       #--- Alimentation cours pour conversion en-cours de dev.soc vers dev.facture (Utilisé si ctrl en-cours au niveau soc)
       Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT2<>0 WCOURS=arr([M:SIH2]RAT1/[M:SIH2]RAT2, 10^-GDECRCU) : Endif
       Call SDCDTSTA("",[M:SIH1]BPCORD,[M:SIH0]CHGTYP,WCOURS,[M:SIH0]CUR,[M:SIH0]INVDAT,0,0,CDTSTA,
&                     [M:SIH0]OST,[M:SIH0]OSTAUZ) From TRTVENCDT
       # Contrôle seulement pour les avoirs
       If [M:SIH0]INVTYP=2 & (CDTSTA=2 | CDTSTA=3)
           If CDTSTA = 2 GMESSAGE = mess(151,199,1) Endif
           If CDTSTA = 3 GMESSAGE = mess(29,192,1) Endif
           WOK=1: Call AVERTIR(GMESSAGE,WOK) From GESECRAN
           Raz GMESSAGE
           If WOK=1 OK=0 : Return : Endif
       Endif
   Endif
Else
   # Contrôle des conditions des regroupement, et des liens cde/fac
   Gosub CTL_RET
   If OK=0 Return Endif
Endif
# Contrôle de l'insertion
If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SRH"+[F:SRH]SRHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SRH]SRHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

#--CPO 79550 Transferts : Retours -> Avoirs sur retours
Gosub SRH_SIH_PLUS From SUBSFIT
#If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  Raz OK
  Call ERREUR(GMESSAGE) From GESECRAN
  Return
Endif
#--/
#--- La sélection est correcte
# Ouverture de la ligne
nolign = [M:SIH4]NBLIG
Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
[M:SIH4]NBLIG += 1
nolign = [M:SIH4]NBLIG
NOL = nolign-1
status = 0

GNETMAR=0
# Alimentation de la classe [M:SIH4] de la ligne
If [F:SRD]SDHNUM <> ""
    Call ALISIDSIH(6,NOL) From TRTVENFAC
    Call LINNUM("SIDLIN") From TABLEAUX
    # Conversion des montants si nécessaire
    If [F:SDH]CUR <> [M:SIH0]CUR
        Local Char    WANCCUR : WANCCUR=[F:SDH]CUR
        Local Decimal MNTORI, MNTDES
        Local Integer I, SPSTAT
        Call CONVERT2(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, [M]GROPRI(NOL), MNTDES, SPSTAT) From TRTDEV
        [M]GROPRI(NOL) = arr(MNTDES, 10^-GDECPRI)
        For I = 1 To 9
            If evalue ("dim([m:sih4]discrgval"+num$(I)+"(nol))")>0
                If GFMTREM(I-1)="M"
                    MNTORI = evalue("[m:sih4]discrgval"+num$(I)+"(NOL)")
                    Call CONVERT(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, MNTORI, MNTDES, SPSTAT) From TRTDEV
                    Assign "[m:sih4]discrgval"+num$(I)+"(NOL)" With MNTDES
                Endif
            Endif
        Next
        Call CONVERT2(WANCCUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, date$, [M]CPRPRI(NOL), MNTDES, SPSTAT) From TRTDEV
        [M]CPRPRI(NOL) = arr(MNTDES, 10^-GDECPRI)
        # Calculs prix net, marge et maj montants livrés et poids
        Call ALICLCAMT([M:SIH4]ITMREF(NOL), [M:SIH4]QTY(NOL), NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
        Call CLCNETPRI([M:SIH4]QTY(NOL),[M:SIH0]CUR, NOL)From TRTVENPRI
        Call CLCPFM([M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,[M:SIH0]CUR,NOL,1) From TRTVENPRI
        # LTA.sn 79065
        # If func AFNC.ACTIV("LTA") & GLOCUSATAX & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
        If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
          [M:SIH1]SSTENTCOD = [F:SDH]SSTENTCOD
        Endif
        # LTA.en 79065

    Endif
Else
    Call ALISRDSIH(NOL) From TRTVENFAC
    Call LINNUM("SIDLIN") From TABLEAUX
Endif
Call APRES_LIGNE(NOL,1) From SUBSIHB
nolign  = NOL+1
GNETMAR=1

[M:SIH1]SIHORI=6
Diszo [M:SIH1]STOFCY

# Pas de gestion des stocks
Default Mask [SIH4]
Call STKRAZGRILIG("SIH4", NOL) From TRTVENSTK

Call RECH_ORINUM From SUBSIHB

#Gosub CAL_FACTURE

#Raz GMESSAGE

Return
#########################################################################
$CTL_RET
Local Char WMES(150), WBPCINV(GLONBPC), WSALFCY(GLONFCY)        # hcb V6
Local Char SWPJTMSG(250)    : # 71065 : PJT
WMES = [F:SRH]SRHNUM-mess(27,159,1)-[F:SRD]ITMREF
#--------------------------------------------------------------------------------#
# La ligne retour sélectionné ne doit pas être déjà sélectionné                  #
#--------------------------------------------------------------------------------#
For I=0 To [M:SIH4]NBLIG-1
    If [F:SRD]SRHNUM=[M:SIH4]SRHNUM(I) & [F:SRD]SRDLIN=[M:SIH4]SRDLIN(I) & [M]CREFLG(I)=0
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(201,192,1)
        Break
    Endif
Next I
If OK=0 Return Endif

#-----------------------------------------#
#  Contrôle des critéres de regroupement  #
#-----------------------------------------#
If [F:SRH]BPCINV <> "" & [F:SRH]BPCINV<>[M:SIH0]BPCINV
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(101,191,1) : Return
Endif
If [F:SRH]SALFCY <> "" & [F:SRH]SALFCY<>[M:SIH0]SALFCY
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(103,192,1) : Return
Endif
If [F:SRH]PLISTC<>[M:SIH0]PLISTC
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(305,192,1) : Return
Endif
#--CPO 80112 Champ BPIEECNUM soumis à code activité
If (dim([M]BPIEECNUM)>0 & [F:SRH]BPIEECNUM<>[M]BPIEECNUM) | [F:SRH]EECICT<>[M]EECICT
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(303,192,1) : Return
Endif
If dim([M]EECLOC)>0 & [F:SRH]EECLOC<>[M]EECLOC
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(304,192,1) : Return
Endif
If [F:SRH]BETFCY<>[M:SIH1]BETFCY | [F:SRH]BETCPY<>[M:SIH1]BETCPY
   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(102,192,1) : Return
Endif
# Facture inter-sociétés
If [M]BETFCY=2
    # Pas de retours issus de flux manuels avec retours direct ou retours issus de flux automatiques
    If [F:SRH]ORIFCY=[F:SRH]SALFCY & [F:SRH]SALFCY<>"" & [M]ORIFCY<>[M]SALFCY
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(188,191,1)+"\"+mess(189,191,1) : Return
    Endif
    # Pas de retours directs ou de retour issus de flux automatique avec des retours issus de flux manuels
    If ([F:SRH]SALFCY="" | [F:SRH]ORIFCY<>[F:SRH]SALFCY) & [M]SALFCY<>"" & [M]ORIFCY=[M]SALFCY
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(187,191,1)+"\"+mess(190,191,1) : Return
    Endif
Endif

If [F:SRD]SDHNUM <> ""
# Si retour de livraison
    If [M:SIH1]BPRPAY<>"" & [F:SIH]BPRPAY<>[M:SIH1]BPRPAY
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(97,191,1) : Return
    Endif
    If [M:SIH1]BPCGRU<>"" & [F:SIV]BPCGRU<>[M:SIH1]BPCGRU
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(98,191,1) : Return
    Endif
    If dim ([M:SIH2]BPRFCT) > 0
        If [M:SIH2]BPRFCT<>"" & [F:SIV]BPRFCT<>[M:SIH2]BPRFCT
           OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(100,191,1) : Return
        Endif
    Endif
    If [M:SIH2]BPRSAC<>"" & [F:SIH]BPRSAC<>[M:SIH2]BPRSAC
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(99,191,1) : Return
    Endif
#   Pas de ctrl de la condition de paiement (non renseignée dans les avoirs)
    If [M:SIH2]DEP<>"" & [F:SIV]DEP<>[M:SIH2]DEP
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(104,192,1) : Return
    Endif
    If [F:SDH]CUR<>[M:SIH2]CUR & ([F:TCU]EURFLG<>2 | [M:SIH2]CUR <> WNEWCUR)
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(104,192,1) : Return
    Endif
    If [F:SIV]PRITYP<>[M:SIH1]PRITYP | [F:SIH]VAC<>[M:SIH1]VACBPR
       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(105,192,1) : Return
    Endif
    #Gbn-Fq77304-New entry point to avoid the control on the project field
    GPE=0 : Local Char GPECNX : GPECNX="CTL_RET" : GPOINT="SIHCTLPJT" : Gosub ENTREE From EXEFNC
    If !GPE
     If [F:SIV]PJT<>[M:SIH1]PJT
        OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(202,192,1)+"\"+mess(107,192,1) : Return
     Endif
    Endif
    # LTA.sn 79065
#   If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
      OK=0 : GERR=1 :GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SDH]SDHNUM, [F:SDH]SSTENTCOD) : Return
    Endif
    # LTA.en 79065

    #-----------------------------------------------------------
    #--CPO 79550 Nouveau transfert elts fact : Retour -> Avoir
    # Controle du champ GRUFLG :
    # Si Oui (1), pas de restriction
    #  Sinon (2), vérifier que les éléments en % ont la meme valeur
    Local Integer I2
    Local Decimal DTAAMTCMP
    Local Char    TSTRUL
    #--Il faut avant tout voir si la livraison à l'origine de la ligne de retour
    #--n'a pas fait l'objet d'autres retours objets d'autres avoirs que le courant
    Local Integer WEXIST_PREV_CRENOT
    WEXIST_PREV_CRENOT = func RET_CHECK_EXIST_PREV_CRENOT([F:SRD]SDHNUM,[M:SIH0]NUM)

    For I=0 To dim([F:SDH]INVDTA) - 1
        If [F:SDH]INVDTA(I) = 0 : Break : Endif
        If [F:SDH]INVDTATYP(I) = 3 : # %
            # Recherche Param concernant Doc Ori et Dest
            TSTRUL = num$([F:SDH]INVDTA(I)) + "~3~5"
            I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

            If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
                If [M:SFIT]T_BRDRUL(I2)=4 and WEXIST_PREV_CRENOT=[V]CST_ATRUE : # eclaté sur 1ere liv et deja partiellement ou totalement facturée
                    DTAAMTCMP=0
                Else
                    DTAAMTCMP=[F:SDH]INVDTAAMT(I)
                Endif

                I2 = find ( [F:SDH]INVDTA(I) , [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
                If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                    OK=0 : GERR=1
                    # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                    Local Char SHOAXX
                    Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SDH]INVDTA(I)),"") From ATEXTRA
                    GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                    Break
                Endif
            Endif
        Endif
    Next I
    #-----------------------------------------------------------
Endif

#--CPO 71065 Code affaire avoirs sur retours
If func TRTPJT.IS_PJT_AVAILABLE([F:SRD]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SRD]PJT, SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
#--/CPO

#----------------------------------#
# Contrôle des liens cde/liv/fac   #
#----------------------------------#
# Si une facture par client livré
If [M:SIH0]IME=4 & ([F:SRH]BPCORD<>[M:SIH1]BPCORD | [F:SRH]BPAADD<>[M:SIH1]BPAADD)
   OK=0 : GERR=1
   GMESSAGE=[F:SRH]SRHNUM-mess(27,159,1)-[F:SRD]ITMREF
&           +"\"+mess(202,192,1)+"\"+mess(192,192,1)
   Return
Endif

Return
#########################################################################
$DESEL1
#-----------------------------------------------------------------------#
# Désélection d'une livraison                                           #
#-----------------------------------------------------------------------#
Raz I,J,NOL
If [M:SIH4]NBLIG <> 0
   WORINUM=[F:SDH]SDHNUM
   While NOL < [M:SIH4]NBLIG
      I = find(WORINUM,[M:SIH4]SDHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         #--CPO 79343
         If GREP<>"C" and GSIHSUPPLIGDSP>0 and GSIHSUPPLIGDSP<>999999
           Local Integer WTEMPDSP : Raz WTEMPDSP
           Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
           If WTEMPDSP=1
             GSIHSUPPLIGDSP -=1
           Endif
        Endif
        #--/CPO
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         Raz GMESSAGE
       Else
         NOL=J+I
       Endif
       J=NOL
   Wend

#  suppression des montants du document dans les elements de facturation
   Local Integer NBPOSTE : NBPOSTE = 10
   Read [SDH]SDH0=WORINUM : #  Lecture : On est pas tjs positionné sur le bon enregistrement
   If fstat Call RSTA ("SDH",WORINUM) From GLOCK : OK=0 : Return : Endif
   # Call SAISFOOT2(6,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SDH]CUR,[M:SIH2]CUR,"SUP") From TRTVENELT
Endif

# Unlock entête livraison
SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
Unlock = SYMBOLE2

Gosub DESEL1_6

Return

#########################################################################
$DESEL2
#-----------------------------------------------------------------------#
# Désélection d'une ligne de commande                                   #
#-----------------------------------------------------------------------#

Local Integer WRET
# Alimentation de la clé de SOQ et forçage de la valeur de SOPSEQ
[F:SOQ]SOHNUM = [F:SOP]SOHNUM
[F:SOQ]SOPLIN = [F:SOP]SOPLIN
[F:SOQ]SOQSEQ = [F:SOP]SOPLIN
[F:SOP]SOPSEQ = [F:SOP]SOPLIN
Raz I,J
OK = 0
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SOQ]SOHNUM,[M:SIH4]SOHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0 & [F:SOQ]SOPLIN=[M:SIH4]SOPLIN(J+I-1)
&                                & [F:SOQ]SOQSEQ=[M:SIH4]SOQSEQ(J+I-1)
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         #--CPO 79343
         If GREP<>"C" and GSIHSUPPLIGDSP>0 and GSIHSUPPLIGDSP<>999999
           Local Integer WTEMPDSP : Raz WTEMPDSP
           Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
           If WTEMPDSP=1
             GSIHSUPPLIGDSP -=1
           Endif
         Endif
         #--/CPO
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         If find([M]LINTYP(NOL),2,10) GMODIF=3 : Endif
         If [M:SIH4]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         # Si annulation composé kit alors suppression des composants
         If GMODIF = 3
            NL = NOL
            Gosub SUPNOM From TRTVENBOM
         Endif
         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
   I = find([F:SOQ]SOHNUM,[M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1))
   If !I
       Local Integer NBPOSTE : NBPOSTE = 10
       If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
           Read [SOH]SOH0=[F:SOQ]SOHNUM
           If fstat Call RSTA ("SOH",[F:SOH]SOHNUM) From GLOCK : OK=0 : Return : Endif
       Endif
#      Plus aucune ligne pour cette cde : Suppression des montants cde dans les élts facturation
       # Call SAISFOOT2(7,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SOH]CUR,[M:SIH2]CUR,"SUP")
# &                     From TRTVENELT
   Endif

Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette commande, il faut la débloquer
Raz I,J
OK = 2
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SOQ]SOHNUM,[M:SIH4]SOHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête commande
   SYMBOLE2 = "SOH"+[F:SOQ]SOHNUM
   Unlock = SYMBOLE2
Endif

Gosub DESEL1_6

Return


#########################################################################
$DESEL3
#-----------------------------------------------------------------------#
# Désélection d'une demande de service                                  #
#-----------------------------------------------------------------------#
Raz I,J
Local Integer NOL
If [M:SIH4]NBLIG <> 0
   While NOL < [M:SIH4]NBLIG
      I = find([F:SRE]SRENUM,[M:SIH4]SRENUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         Raz GMESSAGE
       Else
         NOL=J+I
       Endif
       J=NOL
   Wend
Endif

SYMBOLE2="SRE"+[F:SRE]SRENUM
Unlock=SYMBOLE2

Gosub DESEL1_6

Return

#########################################################################
$DESEL4
#-----------------------------------------------------------------------#
# Désélection d'un contrat                                              #
#-----------------------------------------------------------------------#
Raz I,J,NOL
If [M:SIH4]NBLIG <> 0
   While NOL < [M:SIH4]NBLIG
      I = find([F:CON]CONNUM,[M:SIH4]CONNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         Raz GMESSAGE
       Else
         NOL=J+I
       Endif
       J=NOL
   Wend
Endif

# Unlock contrat service
SYMBOLE2 = "CON"+[F:CON]CONNUM
Unlock = SYMBOLE2

Gosub DESEL1_6

Return
#########################################################################
$DESEL5
#-----------------------------------------------------------------------#
# Désélection d'une facture                                             #
#-----------------------------------------------------------------------#

Raz I,J
OK = 0
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SID]NUM,[M:SIH4]XSIHORINUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0 & [F:SID]SIDLIN=[M:SIH4]SIDORILIN(J+I-1)
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         #--CPO 79343
         If GREP<>"C" and GSIHSUPPLIGDSP>0 and GSIHSUPPLIGDSP<>999999
           Local Integer WTEMPDSP : Raz WTEMPDSP
           Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
           If WTEMPDSP=1
             GSIHSUPPLIGDSP -=1
           Endif
         Endif
         #--/CPO
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette facture, il faut la débloquer
Raz I,J
OK = 2
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SID]NUM,[M:SIH4]XSIHORINUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête facture
   SYMBOLE2 = "SIV"+[F:SID]NUM
   Unlock = SYMBOLE2
Endif

Gosub DESEL1_6
Return
#########################################################################
$DESEL6
#-----------------------------------------------------------------------#
# Désélection d'une ligne de retour                                     #
#-----------------------------------------------------------------------#

Raz I,J
OK = 0
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SRD]SRHNUM,[M:SIH4]SRHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0 & [F:SRD]SRDLIN=[M:SIH4]SRDLIN(J+I-1)
         # Maj montant marge et suppression des textes
         GMODIF=1
         NOL=J+I-1
         WRET = 0
         If left$([M:SIH4]SIDTEX(NOL),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         Endif
         Call SUB_TOT(NOL) From SUBSIHB
         If find([M]LINTYP(NOL),2,10) GMODIF=3 : Endif
         Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
         [M:SIH4]NBLIG -= 1
         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur ce retour, il faut le débloquer
Raz I,J
OK = 2
If [M:SIH4]NBLIG <> 0
   While OK <> 1
      I = find([F:SRD]SRHNUM,[M:SIH4]SRHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête retour
   SYMBOLE2 = "SRH"+[F:SRD]SRHNUM
   Unlock = SYMBOLE2
Endif

Gosub DESEL1_6

Return
#########################################################################
$DESEL1_6

Raz GMODIF

# S'il n'y a plus de ligne, raz de l'origine
If [M:SIH4]NBLIG=0
   [M:SIH1]SIHORI=1
   Raz [M:SIH1]SIHORINUM
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz [M:SIH1]SIHORITYP
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz [M:SIH1]SIHORIDAT
   Raz [M:SIH1]STOMVTFLG
   Actzo [M:SIH1]STOMVTFLG
   Actzo [M:SIH1]STOFCY
   If [M:SIH1]STOMVTFLG<>2
      Grizo [M:SIH1]STOFCY
   Endif
Else
   Call RECH_ORINUM From SUBSIHB
Endif

#Gosub CAL_FACTURE

Return

#########################################################################
$CAL_FACTURE
#-----------------------------------------------------------------------#
# Lecture des tables articles                                           #
#-----------------------------------------------------------------------#
# Spécificité USA
Local Char     WKU_MAJ : WKU_MAJ="2"

# 101874 : V9 : Taxe code control
# Il faut faire le calcul systématiquement pour l'onglet valorisation soit à jour
# (Quand on clique sur l'onglet, on ne passe pas ds l'action AP_NBLIG qui fait le calcul)
## Valuation depends on SIHVALLIG parameter
#If GSIHVALLIG=2
    [M:SIH0]INVCLCFLG=2
    Gosub CHARG_TABLEAUX From TRTVENFACC
    Gosub CAL_FACTURE From TRTVENFACC
    [M:SIH0]INVCLCFLG=1
    [M:SIH4]INVNOT = [M:SIHV]INVNOT
    [M:SIH4]INVATI = [M:SIHV]INVATI
    #Affzo [M:SIHV]1-99
    #Affzo [M:SIH4]1-99
    #Affzo [M:SIH2]1-99
    #Affzo [M:SIH1]1-99
    #Affzo [M:SIH0]1-99
#Endif

Return

#########################################################################
$LEC_TABART
Local Char  WITMREF(GLONITM),WBPCORD(GLONBPC)

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  Gosub INIT_WONFAITQUOI
#Case currbox
Case WONFAITQUOI
 When GBOXSD1 : WITMREF=[F:SDD]ITMREF : WBPCORD=[F:SDH]BPCORD
 When GBOXSO3 : WITMREF=[F:SOQ]ITMREF : WBPCORD=[F:SOH]BPCORD
 When GBOXSI1 : WITMREF=[F:SID]ITMREF : WBPCORD=[F:SIV]BPCINV
 When GBOXSR1 : WITMREF=[F:SRD]ITMREF : WBPCORD=[F:SRH]BPCORD
 When GBOXSVIC1 : WITMREF=[F:SVIC]ITMREF : WBPCORD=[F:SVIC]BPCORD # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
 When Default :
Endcase

# BRBAN 105200#US2
Gosub LEC_TABART From SUBSIHC1
# -

#-----------------------------------------------------------------------#
# Lecture des tables articles                                           #
#-----------------------------------------------------------------------#
If [F:ITM]ITMREF <> WITMREF
   Read [ITM]ITM0=WITMREF
   If fstat Raz [F:ITM] Endif
Endif
If [F:ITS]ITMREF <> WITMREF
   Read [ITS]ITS0 = WITMREF
   If fstat Raz [F:ITS] Endif
Endif
If ([F:ITU]ITMREF <> WITMREF) | ([F:ITU]BPCNUM <> WBPCORD)
   Read [F:ITU]ITU0 = WITMREF;WBPCORD
   If fstat Raz [F:ITU] Endif
Endif
Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  Gosub INIT_WONFAITQUOI
#Case currbox
Case WONFAITQUOI
 When GBOXSD1 : If sum([M:SIH4]SDDLIN)<>0 & [M:SIH0]INVTYP=1
                   For I=0 To [M:SIH4]NBLIG-1
                      # Ligne issue d'un picking livraison réalisé au cours de cette transaction
                      If [M:SIH4]SDHNUM(I)<>"" & [M:SIH4]CREFLG(I)=0
                         Read [SDH]SDH0=[M:SIH4]SDHNUM(I)
                         If    WPICK=1 Gosub DEPICK From GOBJSUB
                         Elsif WPICK=2 Gosub REPICK From GOBJSUB
                         Endif
                      Endif
                   Next I
                Endif
 When GBOXSO3 : If sum([M:SIH4]SOQSEQ)<>0 & [M:SIH0]INVTYP=1
                   For I=0 To [M:SIH4]NBLIG-1
                      # Ligne issue d'un picking commande réalisé au cours de cette transaction
                      If [M:SIH4]SOHNUM(I)<>"" & [M:SIH4]SDHNUM(I)="" & [M:SIH4]CREFLG(I)=0
&                      & !find([M:SIH4]LINTYP(I),3,4,5,11,12,13)
#                         Read [SOQ]SOQ0=[M:SIH4]SOHNUM(I);[M:SIH4]SOPLIN(I);[M:SIH4]SOQSEQ(I)
                         Read [SOP]SOP0=[M:SIH4]SOHNUM(I);[M:SIH4]SOPLIN(I);[M:SIH4]SOQSEQ(I)
                         If    WPICK=1 Gosub DEPICK From GOBJSUB
                         Elsif WPICK=2 Gosub REPICK From GOBJSUB
                         Endif
                      Endif
                   Next I
                Endif
When GBOXSR3 : If [M:SIH4]NBLIG<>0
                   If sigma(I=0,[M:SIH4]NBLIG-1,[M:SIH4]SRENUM(I))<>"" & [M:SIH0]INVTYP=1
                      For I=0 To [M:SIH4]NBLIG-1
                         # Ligne issue d'un picking demande service réalisé dans cette transaction
                         If [M:SIH4]SRENUM(I)<>"" & [M:SIH4]CREFLG(I)=0
#                            Read [SRE]SRE0=[M:SIH4]CONNUM(I)
                            Read [SRE]SRE0=[M:SIH4]SRENUM(I)
                            If    WPICK=1 Gosub DEPICK From GOBJSUB
                            Elsif WPICK=2 Gosub REPICK From GOBJSUB
                            Endif
                         Endif
                      Next I
                   Endif
                Endif
When GBOXCO1 : If [M:SIH4]NBLIG<>0
                   If sigma(I=0,[M:SIH4]NBLIG-1,[M:SIH4]CONNUM(I))<>"" & [M:SIH0]INVTYP=1
                      For I=0 To [M:SIH4]NBLIG-1
                         # Ligne issue d'un picking contrat réalisé au cours de cette transaction
                         If [M:SIH4]CONNUM(I)<>"" & [M:SIH4]CREFLG(I)=0
                            Read [CON]CON0=[M:SIH4]CONNUM(I)
                            If    WPICK=1 Gosub DEPICK From GOBJSUB
                            Elsif WPICK=2 Gosub REPICK From GOBJSUB
                            Endif
                         Endif
                      Next I
                   Endif
                Endif
 When GBOXSI1 :
                If [M:SIH4]NBLIG<>0
                   If sigma(I=0,[M:SIH4]NBLIG-1,[M:SIH4]XSIHORINUM(I))<>"" & [M:SIH0]INVTYP=2
                      For I=0 To [M:SIH4]NBLIG-1
                         # Ligne issue d'un picking facture réalisé au cours de cette transaction
                         If [M:SIH4]XSIHORINUM(I)<>"" & [M:SIH4]CREFLG(I)=0
                            Read [SID]SID0=[M:SIH4]XSIHORINUM(I);[M:SIH4]SIDORILIN(I)
                            If    WPICK=1 Gosub DEPICK From GOBJSUB
                            Elsif WPICK=2 Gosub REPICK From GOBJSUB
                            Endif
                         Endif
                      Next I
                   Endif
                Endif
 When GBOXSR1 : If [M:SIH4]NBLIG<>0
                   If sigma(I=0,[M:SIH4]NBLIG-1,[M:SIH4]SRHNUM(I))<>"" & [M:SIH0]INVTYP=2
                      For I=0 To [M:SIH4]NBLIG-1
                         # Ligne issue d'un picking retour réalisé au cours de cette transaction
                         If [M:SIH4]SRHNUM(I)<>"" & [M:SIH4]CREFLG(I)=0
                            Read [SRD]SRD0=[M:SIH4]SRHNUM(I);[M:SIH4]SRDLIN(I)
                            If    WPICK=1 Gosub DEPICK From GOBJSUB
                            Elsif WPICK=2 Gosub REPICK From GOBJSUB
                            Endif
                         Endif
                      Next I
                   Endif
                Endif
 When GBOXSVIC1 : Gosub RAFFRAICHI From LIBSAL_INVCND_SIH_PICK # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices

 When Default
Endcase
Return

###########################################################################
# TRT_LIGDEV    Traitement de la ligne devis à facturer                   #
#-------------------------------------------------------------------------#
# Utilisation : bouton  facture depuis la gestion des devis               #
###########################################################################
$TRT_LIGDEV
#  # FGR 30/11/2011 : X3SUIVI71065 (début)
  Local Char SWPJTMSG(250)

  If func TRTPJT.IS_PJT_AVAILABLE([F:SQD]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG([F:SQD]PJT, SWPJTMSG) From TRTPJT
    Return
  Endif
#  # FGR 30/11/2011 : X3SUIVI71065 (fin)

   Gosub SQH_SIH_PLUS From SUBSFIT
   #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
   If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
     OK = 0
     Return
   Endif

   # Ouverture de la ligne
   nolign = [M:SIH4]NBLIG
   Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
   [M:SIH4]NBLIG += 1
   nolign = [M:SIH4]NBLIG
   NOL = nolign-1
   status = 0

   # Lecture des tables articles
   Local Char  WITMREF(GLONITM), WBPCORD(GLONBPC)
   WITMREF=[F:SQD]ITMREF : WBPCORD=[F:SQH]BPCORD
   If [F:ITM]ITMREF <> WITMREF
       Read [ITM]ITM0=WITMREF
       If fstat Raz [F:ITM] Endif
   Endif
   If [F:ITS]ITMREF <> WITMREF
       Read [ITS]ITS0 = WITMREF
       If fstat Raz [F:ITS] Endif
   Endif
   If ([F:ITU]ITMREF <> WITMREF) | ([F:ITU]BPCNUM <> WBPCORD)
       Read [F:ITU]ITU0 = WITMREF;WBPCORD
       If fstat Raz [F:ITU] Endif
   Endif

   # Alimentation de la classe [M:SIH4] de la ligne
   Call ALISQDSIH(NOL) From TRTVENFAC

   Call LINNUM("SIDLIN") From TABLEAUX

   Call APRES_LIGNE(NOL,1) From SUBSIHB

Return

########################################################################
$REAJUSTE_QTY
#---------------------------------------------
# TS : réajustement qté en unité vente entière
#---------------------------------------------

GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 :  Return : Endif

If WSAU<>[F:ITM]STU

   # Bug 29257
   WQTYARR = WQTY
   Call QTEARR(WQTYARR,WSAU) From TRTDIV
   If WQTYARR=WQTY Return Endif

   Call CTRQTYPCU(WSAU,WSAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
   If WQTYARR<>WQTYSTU
      WQTYSTU = WQTYARR
      WQTY    = WQTYSTU/WSAUSTUCOE
   Endif
Endif
Return
#---------------------------------------------
