#85785

If dim([M:SIH0]ISEXTDOC)>0
  Local Integer SAV_ISEXTDOC
  [L]SAV_ISEXTDOC = [M:SIH0]ISEXTDOC
Endif

If clalev([M:SIH1])
  If dim([M:SIH1]FLD40REN)>0
    Local Char SAV_FLD40REN(GLONADI)
    [L]SAV_FLD40REN = [M:SIH1]FLD40REN
  Endif
Endif

If clalev([M:SIH1])
  If dim([M:SIH1]FLD41REN)>0
    Local Char SAV_FLD41REN(GLONADI)
    [L]SAV_FLD41REN = [M:SIH1]FLD41REN
  Endif
Endif

Return
########################################################################
$GET_SAV_VALUES
#85785

If dim([M:SIH0]ISEXTDOC)>0
  [M:SIH0]ISEXTDOC = [L]SAV_ISEXTDOC
  Kill [L]SAV_ISEXTDOC
Endif

If clalev([M:SIH1])
  If dim([M:SIH1]FLD40REN)>0
    [M:SIH1]FLD40REN = [L]SAV_FLD40REN
    Kill [L]SAV_FLD40REN
  Endif
Endif

If clalev([M:SIH1])
  If dim([M:SIH1]FLD41REN)>0
    [M:SIH1]FLD41REN = [L]SAV_FLD41REN
    Kill [L]SAV_FLD41REN
  Endif
Endif

Return
########################################################################
########################################################################
#--CPO 79550 Nouveau transfert elts fact : Retour -> Avoir
#--Return : [V]CST_ATRUE if it exists other credit notes for the PSDHNUM delivery
#                        (throught returns lines with PSDHNUM origin)
#           [V]CST_AFALSE if PSDHNUM="" or no other credit notes
#-----------------------------------------------------------------------
Funprog RET_CHECK_EXIST_PREV_CRENOT(PSDHNUM,PSIHNUM)
Value Char PSDHNUM
Value Char PSIHNUM

If PSDHNUM="" : End [V]CST_AFALSE : Endif

Local Tinyint WRET

Local File SRETURND [SRD99]

  Filter [SRD99] Where RTNCNOFLG=2 and SDHNUM=PSDHNUM and SIHNUM<>PSIHNUM and SIHNUM<>""
  Read [SRD99] First
  If fstat>0
    WRET = [V]CST_AFALSE
  Else
    WRET = [V]CST_ATRUE
  Endif
  Filter [SRD99]

End WRET
#########################################################################
#--CPO 79550 Nouveau transfert elts fact : Contrats de services -> Facture
#--Return : [V]CST_ATRUE if it exists other invoices for the PCONNUM contract
#           [V]CST_AFALSE if PCONNUM="" or no other invoices
#-----------------------------------------------------------------------
Funprog CON_CHECK_EXIST_PREV_INV(PCONNUM,PSIHNUM)
Value Char PCONNUM
Value Char PSIHNUM

If PCONNUM="" : End [V]CST_AFALSE : Endif

Local Tinyint WRET

Local File SINVOICED [SID99]

  Filter [SID99] Where CONNUM=PCONNUM and NUM<>PSIHNUM
  Read [SID99] First
  If fstat>0
    WRET = [V]CST_AFALSE
  Else
    WRET = [V]CST_ATRUE
  Endif
  Filter [SID99]

End WRET
#########################################################################

