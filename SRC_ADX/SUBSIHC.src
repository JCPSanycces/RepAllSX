#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# SUBSIHC : GESTION DES FACTURES                                        #
#-----------------------------------------------------------------------#
# Novembre 2000                                                      TS #
#########################################################################
# Issue 121079 - 20170412 by LD : Direct invoice and back to back order
# Issue X3-38392 - 20170821 by LD : Pick Commande a facturation directe : message a tort
# Issue X3-38212 - 20171127 by LD : Numero VCS - Avoir sur plusieurs factures
# Issue X3-63491 - 20171214 by LD : Wrong amount in sales invoice elements in amounts with a different currency

#########################################################################
# TRAITEMENTS LIES AUX PICKINGS                                         #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$HINT_KEY
Case currbox
 When GBOXSD1 : HINTLIS(val(right$(GBOXSD1,8)))="SDH3"
 When GBOXSO3 : HINTLIS(val(right$(GBOXSO3,8)))="SOP4"
 When GBOXSR3 : HINTLIS(val(right$(GBOXSR3,8)))="SRE1"
 When GBOXCO1 : HINTLIS(val(right$(GBOXCO1,8)))="CON1"
 When GBOXSI1 : HINTLIS(val(right$(GBOXSI1,8)))="SID1"
 When GBOXSR1 : HINTLIS(val(right$(GBOXSR1,8)))="SRD2"
 When Default : Return
Endcase

Return

#########################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB

WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$REMP_DERLU
#MAE, pour raz liste gauche si navigation autre que depuis client
# FGR 11/05/2011 : X3SUIVI73730 :  and GNAVIG(GPILNAV-1) <> "GESSRE"
If GFONC1<>"GESSIH"
   If GPILNAV>1
      If !find(GNAVIG(GPILNAV-1),"GESBPC","FUNCMG3", "GESSRE")
         adxmxl=0
      Endif
   Else
      adxmxl=0
   Endif
Endif
Return

#########################################################################
$FILGAUCHE
#MAE, pour raz liste gauche si navigation autre que depuis client
# FGR 11/05/2011 : X3SUIVI73730 :  and GNAVIG(GPILNAV-1) <> "GESSRE"
If GFONC1<>"GESSIH"
   If GPILNAV>1
      If !find(GNAVIG(GPILNAV-1),"GESBPC","FUNCMG3", "GESSRE")
         If ILIS=0 adxmxl=0 Endif
      Endif
   Elsif ILIS=0
      adxmxl=0
   Endif
Endif

# BRBAN 105200#US2
Gosub FILGAUCHE From SUBSIHC1
# -

Case currbox
 When GBOXSD1 : Gosub FILGAUCHE1
 When GBOXSO3 : Gosub FILGAUCHE2
 When GBOXSR3 : Gosub FILGAUCHE3
 When GBOXCO1 : Gosub FILGAUCHE4
 When GBOXSI1 : Gosub FILGAUCHE5
 When GBOXSR1 : Gosub FILGAUCHE6
 When GBOXSVIC1 : Gosub FILGAUCHE7 From LIBSAL_INVCND_SIH_PICK # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
 When Default : Return
Endcase
Return

#########################################################################
$FILGAUCHE1
#-------------------------------
# Filtre picking des livraisons
#-------------------------------
# Si pas de clé courante(sauf si création) ou pas facture ou validée ou
# origine facture = commande ou contrat ou dde, rien dans la liste de picking

If (GREP="" & !CLECUR) | [M]INVTYP<>1 | [M]INVSTA=3 | find([M]SIHORI, 2, 7, 8, 10) # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - SIHORI=10 Scheduled invoices picking left
   FILGAUSUP(0)='[F:SDH]INVFLG=99'
   Return
Endif

# Les livraisons doivent être non facturées, mais validées
FILGAUSUP(0) ='[F:SDH]INVFLG=1&[F:SDH]CFMFLG=2'

# X3-1152 : Non invoiceable deliveries
FILGAUSUP(0)+='&[F:SDH]SDHCAT<>4'
# X3-1152 : Non invoiceable deliveries

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISDHNUM<>"" FILGAUSUP(0)+='&[F:SDH]SDHNUM=[M:SIH0]CRISDHNUM' Endif

If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SDH]SALFCY=[M]SALFCY'  Endif

# FGR 27/01/2015 : X3SUIVI105705 (début)
#If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
#   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
#   ##If COUZON="BPCINV"
#   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SDH]BPCINV=CZ'        Endif
#   ##Else
#   ##   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SDH]BPCINV=[M]BPCINV' Endif
#   ##Endif
#   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SDH]BPCINV=[M]BPCINV' Endif
#Else
#   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
#   ##If COUZON="BPCINV"
#   ##   FILGAUSUP(0)+='&[F:SDH]BPCINV=CZ'
#   ##Else
#   ##   FILGAUSUP(0)+='&[F:SDH]BPCINV=[M]BPCINV'
#   ##Endif
#   FILGAUSUP(0)+='&[F:SDH]BPCINV=[M]BPCINV'
#Endif
If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SDH]BPCINV=[M]BPCINV' Endif
# FGR 27/01/2015 : X3SUIVI105705 (fin)


If [M]NBLIG <> 0
   If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SDH]BPCPYR=[M]BPRPAY' Endif

   If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SDH]BPCGRU=[M]BPCGRU' Endif
Endif

# Les livraisons ne doivent pas être inter-sites intra-société
FILGAUSUP(0)+='&([F:SDH]BETFCY=1|([F:SDH]BETFCY=2&[F:SDH]BETCPY=2))'

# Les livraisons ne doivent ni des prêts, ni sous-traitance
#FILGAUSUP(1)+='&[F:SDH]LND<>2&[F:SDH]SDHCAT<>2'
# Les livraisons ne doivent pas être de sous-traitance
FILGAUSUP(1)+='&[F:SDH]SCO<>2'
# Les livraisons doivent être normales
# ou de prêts pas totalement retournées avec date retour prévue < date facture
FILGAUSUP(1)+='&([F:SDH]LND<>2|([F:SDH]LND=2&[F:SDH]RTNSTA<>3&[F:SDH]LNDRTNDAT<[M]INVDAT))'

# V6.2 : Certification
# Si ctrl date documents : La livraison doit avoir une date <= à la date de la facture
#If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SDH]DLVDAT<=[M:SIH0]INVDAT' : Endif : # Dde 73382
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SDH]SHIDAT<=[M:SIH0]INVDAT' : Endif  : # Dde 73382

If [M]NBLIG <> 0
   If [M]CUR<>"" FILGAUSUP(1)+='&[F:SDH]CUR=[M]CUR'       Endif

   If [M]PTE<>"" FILGAUSUP(1)+='&[F:SDH]PTE=[M]PTE'       Endif

   If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SDH]PRITYP=[M]PRITYP' Endif

   If [M]VACBPR<>"" FILGAUSUP(1)+='&[F:SDH]VACBPR=[M]VACBPR' Endif

#  If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(2)+='&[F:SDH]SSTENTCOD=[M]SSTENTCOD' : Endif # LTA.n  79065 #89534 - Use FILGAUSUP(2) and not index 1 # 106867.o
   If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(2)+='&[F:SDH]SSTENTCOD=[M]SSTENTCOD' : Endif # LTA.n  79065 #89534 - Use FILGAUSUP(2) and not index 1  # 106867.n

Endif

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(2)+='&[F:SDH]PJT=[M]PJT'
   Endif
Endif
#--/CPO

#--CPO 79560 Pas de picking livr. si fact. directe sans mvt de stock et des lignes saisies
If ([M:SIH4]NBLIG>0 or [M:SIH4]ITMREF(0)<>"" ) and [M:SIH1]STOMVTFLG<>2 and [M:SIH1]SIHORI=1
  FILGAUSUP(2)+='&[F:SDH]INVFLG=99'
Endif
#--/CPO

# 40127 : Return status management
# Livraisons de prêt : On ne facture que celles qui ne sont pas entièrement retournées
# Livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que celles qui ne sont pas entièrement retournées
# Livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture toutes les livraisons
# 105759
#FILGAUSUP(0)+='&(([F:SDH]RTNSTA<3&([F:SDH]LND=2|GDLVRTNCNO=1)) | ([F:SDH]LND=1&GDLVRTNCNO=2))'
FILGAUSUP(2)+='&(([F:SDH]RTNSTA<3&([F:SDH]LND=2|GDLVRTNCNO=1)) | ([F:SDH]LND=1&GDLVRTNCNO=2))'
# 105759
# 40127

# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SDH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SDH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission

Return

#########################################################################
$FILGAUCHE2
#------------------------------
# Filtre picking des commandes
#------------------------------

# Si pas de clé courante(sauf si création) ou pas facture ou validée ou
# origine facture = livraison ou contrat ou dde , rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>1 | [M]INVSTA=3 | find([M]SIHORI, 3, 7, 8, 10) # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - SIHORI=10 Scheduled invoices picking left
   FILGAUSUP(0)='[F:SOP]SOQSTA=99'
   Return
Endif

# Les lignes de commandes ne doivent pas être soldées
FILGAUSUP(0) ='[F:SOP]SOQSTA=1'

# Les commandes doivent être à facturation directe
FILGAUSUP(0)+='&[F:SOP]SOHCAT=3'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISOHNUM<>"" FILGAUSUP(0)+=' & [F:SOP]SOHNUM=[M:SIH0]CRISOHNUM' Endif
If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+=' & [F:SOP]ITMREF=[M:SIH0]CRIITMREF' Endif

If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SOP]SALFCY=[M]SALFCY'    Endif

If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SOP]BPCINV=[M]BPCINV' Endif
Else
   FILGAUSUP(0)+='&[F:SOP]BPCINV=[M]BPCINV'
Endif

If [M]NBLIG <> 0
   If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SOH]BPCPYR=[M]BPRPAY'    Endif

   If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SOH]BPCGRU=[M]BPCGRU'    Endif
Endif

# Les commandes doivent être non facturées
FILGAUSUP(0)+='&[F:SOH]INVSTA<>3'

# Les commandes doivent être signées
FILGAUSUP(1)='& [F:SOH]APPFLG>2'

# Les Lignes ne doivent pas être des lignes de contrats de service
FILGAUSUP(1)+='&[F:SOP]CONNUM=""'

#  Les Lignes ne doivent pas être des composants de kit/sous-traité
FILGAUSUP(1)+='&(!find([F:SOP]LINTYP,3,4,5,11,12,13))'

# V6.2 : Certification
# Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SOH]ORDDAT<=[M:SIH0]INVDAT' : Endif

# La date d'expédition des cdes doit être < à la date de facture + Nb jours pour picking cde/DL
If [M]INVDAT <> [0/0/0]
   FILGAUSUP(1)+='&[F:SOQ]SHIDAT<=[M]INVDAT+GSHINBRDAY'
Endif

If [M]NBLIG <> 0
   If [M]CUR<>"" FILGAUSUP(1)+='&[F:SOH]CUR=[M]CUR'       Endif

   If [M]PTE<>"" FILGAUSUP(1)+='&[F:SOH]PTE=[M]PTE'       Endif

   If [M]PRITYP<>0 FILGAUSUP(1)+='&[F:SOH]PRITYP=[M]PRITYP' Endif

   If [M]VACBPR<>"" FILGAUSUP(1)+='&[F:SOH]VACBPR=[M]VACBPR' Endif

#  If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(2)+='&[F:SOH]SSTENTCOD=[M]SSTENTCOD' : Endif # LTA.n  79065   #89534 - Use FILGAUSUP(2) in place of index 1  # 106867.o
   If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(2)+='&[F:SOH]SSTENTCOD=[M]SSTENTCOD' : Endif # LTA.n  79065   #89534 - Use FILGAUSUP(2) in place of index 1  # 106867.n

Endif

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(2)+='&[F:SOH]PJT=[M]PJT'
   Endif
Endif
#--/CPO
# order holds
FILGAUSUP(2) += '& [F:SOH]HLDSTA < 2'

#--CPO 79560 Pas de picking cdes. si fact. directe sans mvt de stock et des lignes saisies
If ([M:SIH4]NBLIG>0 or [M:SIH4]ITMREF(0)<>"") and [M:SIH1]STOMVTFLG<>2 and [M:SIH1]SIHORI=1
  FILGAUSUP(2)+='&[F:SOP]SOQSTA=99'
Endif
#--/CPO

# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SOH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SOH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission

Return

#########################################################################
$FILGAUCHE3
#-----------------------------------------
# Filtre picking des demandes de service
#-----------------------------------------
# Si pas de clé courante(sauf si création) ou pas facture ou validée ou
# origine facture = commande ou livraison ou contrat, rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>1 | [M]INVSTA=3 | find([M]SIHORI, 2, 3, 7, 10) # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - SIHORI=10 Scheduled invoices picking left
FILGAUSUP(0)='[F:SRE]SRENUM=""'
   Return
Endif

FILGAUSUP(0) ='[F:SRE]SREASS=5'                     : # demande cloturee
FILGAUSUP(0)+='&[F:SRE]SREINVFLG=2'                 : # demande facturable

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISRENUM<>"" FILGAUSUP(0)+=' & [F:SRE]SRENUM=[M:SIH0]CRISRENUM' Endif

If [M:SIH0]SALFCY<>""
   FILGAUSUP(0)+='&[F:SRE]SALFCY=[M:SIH0]SALFCY'    : # si site vente saisi
Endif
If [M:SIH0]BPCINV<>""
   FILGAUSUP(0)+='&[F:SRE]SREBPCINV=[M:SIH0]BPCINV' : # si client facture saisi
Endif

#LTA.sn 79065
If [M]NBLIG <> 0
# If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(0)+='&[F:SRE]SSTENTCOD=[M:SIH1]SSTENTCOD' : Endif   # 106867.o
  If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(0)+='&[F:SRE]SSTENTCOD=[M:SIH1]SSTENTCOD' : Endif   # 106867.n
Endif
#LTA.en # LTA.n  79065

# V6.2 : Certification
# Si ctrl date documents : La demande de service doit avoir une date <= à la date de la facture
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SRE]SREDATASS<=[M:SIH0]INVDAT' : Endif


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SRE",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SRE") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission

Return

#########################################################################
$FILGAUCHE4
#------------------------------
# Filtre picking des contrats
#------------------------------
# Si pas de clé courante(sauf si création) ou pas facture ou validée ou
# origine facture = commande ou livraison ou dde, rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>1 | [M]INVSTA=3 | find([M]SIHORI, 2, 3, 8, 10) # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - SIHORI=10 Scheduled invoices picking left
# list on sales invoices)
   FILGAUSUP(0)='[F:CON]CONENDDAT=[00/00/00]&[F:CON]CONSTRDAT=[00/00/00]'
   Return
Endif

FILGAUSUP(0) ='[F:CON]NEXSHIINV<=[M]INVDAT'
FILGAUSUP(0)+='&[F:CON]NEXINVDAT<>[00/00/00]'
FILGAUSUP(0)+='&[F:CON]NEXINVDAT <= [F:CON]CONENDDAT'  # Issue SAM120356 - 2017-01-09 by FGR add : 'and [F:CON]NEXINVDAT >= [F:CON]CONENDDAT'

# FGR 25/07/2013 : X3SUIVI90904 (début)
#FILGAUSUP(0)+='&[F:CON]RSIFLG<>2'
#FILGAUSUP(0)+= '& (([F:CON]RSIFLG<>2) | ([F:CON]RSIFLG=2 & [F:CON]NEXINVDAT<=[F:CON]RSIDAT))'
FILGAUSUP(0)+= '& (([F:CON]RSIFLG<>2) | ([F:CON]RSIFLG=2 & [F:CON]NEXINVDAT<[F:CON]RSIDAT))'    # FGR 21/11/2013 : X3SUIVI94039 : strictement inférieur
# FGR 25/07/2013 : X3SUIVI90904 (fin)

FILGAUSUP(0)+='&[F:CON]FDDFLG<>2'
FILGAUSUP(0)+='&[F:CON]CONCAT<>1'
FILGAUSUP(0)+='&[F:CON]CONAMT>0'
FILGAUSUP(0)+='&[F:CON]ITMREF<>""'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
#If [M:SIH0]CRICONNUM<>"" FILGAUSUP(0)+=' & [F:CON]CONNUM=[M:SIH0]CRICONNUM' Endif       # FGR 19/06/2015 : X3SUIVI108981
#If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+=' & [F:CON]ITMREF=[M:SIH0]CRIITMREF' Endif       # FGR 19/06/2015 : X3SUIVI108981
If [M:SIH0]CRICONNUM<>"" FILGAUSUP(1)+=' &[F:CON]CONNUM=[M:SIH0]CRICONNUM' Endif         # FGR 19/06/2015 : X3SUIVI108981
If [M:SIH0]CRIITMREF<>"" FILGAUSUP(1)+=' &[F:CON]ITMREF=[M:SIH0]CRIITMREF' Endif         # FGR 19/06/2015 : X3SUIVI108981

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="SALFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:CON]SALFCY=CZ'           Endif
##Else
##   If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:CON]SALFCY=[M]SALFCY'    Endif
##Endif
#If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:CON]SALFCY=[M]SALFCY'    Endif                      # FGR 19/06/2015 : X3SUIVI108981
If [M]SALFCY<>"" FILGAUSUP(1)+='&[F:CON]SALFCY=[M]SALFCY'    Endif                       # FGR 19/06/2015 : X3SUIVI108981

#LSE 06/02/2007 FQ39540
If [M:SIH0]BPCINV<>""
   # FGR 30/09/2013 : X3SUIVI92757 : problème de longueur de chaîne
   #FILGAUSUP(0)+='&[F:CON]CONBPCINV=[M:SIH0]BPCINV' : # si client facture saisi
   FILGAUSUP(1)+='&[F:CON]CONBPCINV=[M:SIH0]BPCINV' : # si client facture saisi
Endif

# V6.2 : Certification
# Si ctrl date documents : La demande de service doit avoir une date <= à la date de la facture
#If GCTLDATORI=2  FILGAUSUP(1) +='& [F:CON]CONSTRDAT<=[M:SIH0]INVDAT' : Endif  # FGR 04/04/2016 : X3SUIVI115535
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:CON]NEXSHIINV<=[M:SIH0]INVDAT' : Endif   # FGR 04/04/2016 : X3SUIVI115535 (conservé filtre deux fois pour ne pas oublier la certification)

#LTA.sn 79065
If [M]NBLIG <> 0
# If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(1)+='&[F:CON]SSTENTCOD=[M:SIH1]SSTENTCOD' : Endif   # 106867.o
  If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(1)+='&[F:CON]SSTENTCOD=[M:SIH1]SSTENTCOD' : Endif   # 106867.n
Endif
#LTA.en 79065

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(1)+='&[F:CON]CONPJT=[M]PJT'
   Endif
Endif
#--/CPO


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("CON",GBIDC3) From SUBARL
## FGR 21/01/2014 : X3SUIVI96009 : ça écrase les (1) précédents
##If GBIDC3<>"" FILGAUSUP(1)= "& " + GBIDC3 : Endif
#If GBIDC3<>"" FILGAUSUP(2) += "& " + GBIDC3 : Endif
#Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"CON") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission

Return

#########################################################################
$FILGAUCHE5
#------------------------------
# Filtre picking des factures
#------------------------------
# Si pas de clé courante (sauf si création) ou pas avoir ou validée:rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>2 | ([M]SIHORI <> 4 & [M]SIHORI <> 1) | [M]INVSTA=3
   FILGAUSUP(0)='[F:SID]BPCINV=""'
   Return
Endif

# Pour optimiser, on filtre sur le client facture même si celui-ci n'est pas renseigné
# --> on ne pourra picker une facture que lorsque le client aura été saisi
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPCINV"
##   FILGAUSUP(0) ='[F:SID]BPCINV=CZ'
##Else
##   FILGAUSUP(0) ='[F:SID]BPCINV=[M]BPCINV'
##Endif
FILGAUSUP(0) ='[F:SID]BPCINV=[M]BPCINV'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="SALFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:SID]SALFCY=CZ'          Endif
##Else
##   If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SID]SALFCY=[M]SALFCY'   Endif
##Endif
If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SID]SALFCY=[M]SALFCY'   Endif

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISIHNUM<>"" FILGAUSUP(0)+=' & [F:SIV]NUM=[M:SIH0]CRISIHNUM' Endif
If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+=' & [F:SID]ITMREF=[M:SIH0]CRIITMREF' Endif
#--CPO 87923 Gestion des prélèvements SDD
If dim([M:SIH0]CRIUMRNUM)>0 and find([M:SIH0]CRIUMRNUM,"","~~~~") < 1
FILGAUSUP(2) += '& [F:SIH]UMRNUM="'+ [M:SIH0]CRIUMRNUM + '"'
Endif

# Ce doit être des factures validées
FILGAUSUP(0) +='&[F:SIV]INVTYP=1&[F:SIV]INVSTA=3'

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPRPAY"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SIV]BPRPAY=CZ'           Endif
   ##Else
   ##   If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SIV]BPRPAY=[M]BPRPAY'    Endif
   ##Endif
   If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SIV]BPRPAY=[M]BPRPAY'    Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCGRU"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SIV]BPCGRU=CZ'           Endif
   ##Else
   ##   If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SIV]BPCGRU=[M]BPCGRU'    Endif
   ##Endif
   If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SIV]BPCGRU=[M]BPCGRU'    Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPRFCT"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SIV]BPRFCT=CZ'           Endif
   ##Else
   ##   If dim ([M]BPRFCT) > 0
   ##      If [M]BPRFCT<>"" FILGAUSUP(0)+='&[F:SIV]BPRFCT=[M]BPRFCT' Endif
   ##   Endif
   ##Endif
   If dim ([M]BPRFCT) > 0
     If [M]BPRFCT<>"" FILGAUSUP(0)+='&[F:SIV]BPRFCT=[M]BPRFCT' Endif
   Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPRSAC"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SIH]BPRSAC=CZ'           Endif
   ##Else
   ##   If [M]BPRSAC<>"" FILGAUSUP(0)+='&[F:SIH]BPRSAC=[M]BPRSAC'    Endif
   ##Endif
   If [M]BPRSAC<>"" FILGAUSUP(0)+='&[F:SIH]BPRSAC=[M]BPRSAC'    Endif
Endif

If [M]NBLIG <> 0
#   Ne pas filtrer sur la devise pour le passage à l'euro

    ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
    ##If COUZON="VACBPR"
    ##    If CZ<>""         FILGAUSUP(1)+='&[F:SIH]VAC=CZ'           Endif
    ##Else
    ##    If [M]VACBPR<>""  FILGAUSUP(1)+='&[F:SIH]VAC=[M]VACBPR'    Endif
    ##Endif
    If [M]VACBPR<>""  FILGAUSUP(1)+='&[F:SIH]VAC=[M]VACBPR'    Endif

#   If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(1)+='&[F:SIH]SSTENTCOD=[M]SSTENTCOD' : Endif #LTA.n 79065   # 106867.o
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(1)+='&[F:SIH]SSTENTCOD=[M]SSTENTCOD' : Endif #LTA.n 79065   # 106867.n

    If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SIV]PRITYP=[M]PRITYP'  Endif

    ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
    ##If COUZON="STOMVTFLG"
#      If CZ<>""          FILGAUSUP(1)+='&[F:SIV]STOMVTFLG>=val(CZ)'        Endif
    ##   If val(CZ)<>0      FILGAUSUP(1)+='&[F:SIV]STOMVTFLG>=val(CZ)'        Endif
    ##Else
    ##   If [M]STOMVTFLG<>0 FILGAUSUP(1)+='&[F:SIV]STOMVTFLG>=[M]STOMVTFLG'   Endif
    ##Endif
    If [M]STOMVTFLG<>0 FILGAUSUP(1)+='&[F:SIV]STOMVTFLG>=[M]STOMVTFLG'   Endif
Endif

# V6.2 : Certification
# Si ctrl date documents : La facture doit avoir une date <= à la date de l'avoir
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SIV]INVDAT<=[M:SIH0]INVDAT' : Endif

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(1)+='&[F:SIV]PJT=[M]PJT'
   Endif
Endif
#--/CPO

#--CPO 87923 Gestion des prélèvements SDD
If dim([M:SIH0]CRIUMRNUM)>0 and [M:SIH0]CRIUMRNUM = "~~~~"
  #--Dans ce cas l'utilisateur est passé par "Options/Critères picking" et a remis à "" le n° mandat !!!
  Raz [M:SIH0]CRIUMRNUM
Else
  If dim([M:SIH2]UMRNUM)>0 and GSDDMGT=2 and [M:SIH2]SDDFLG=2
    If [M:SIH2]PTE<>"" and [M:SIH2]UMRNUM<>"" and find([M:SIH0]CRIUMRNUM,"","~~~~") > 0
      FILGAUSUP(2)+='&[F:SIH]UMRNUM="'+[M]UMRNUM+'"'
    Endif
  Endif
Endif
#--/

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  Local Char INVCLT(10) : [L]INVCLT = "0"

  Call PARAML(GFCY,"INVCAN", [L]INVCLT) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  If val([L]INVCLT)=2
    FILGAUSUP(2)+="& [F:SIH]REVCANSTA=0"
  Endif
Endif
# -


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SIH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
#Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list in credit note function doesn't work
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SIH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


Return
#########################################################################
$FILGAUCHE6
#------------------------------
# Filtre picking des retours
#------------------------------

# Si pas de clé courante (sauf si création) ou pas avoir ou validée:rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>2 | ([M]SIHORI <> 6 & [M]SIHORI <> 1)| [M]INVSTA=3
   FILGAUSUP(0)='[F:SRD]SIHNUM="ZZZZZZZZZZZZZZZ"'
   Return
Endif

# Le retour ne doit pas avoir déjà été facturé
FILGAUSUP(0) ='[F:SRD]SIHNUM=""'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISRHNUM<>"" FILGAUSUP(0)+=' & [F:SRH]SRHNUM=[M:SIH0]CRISRHNUM' Endif
If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+=' & [F:SRD]ITMREF=[M:SIH0]CRIITMREF' Endif

# Ce doit être des lignes de retour devant faire l'objet d'un avoir
FILGAUSUP(0)+='&[F:SRD]RTNCNOFLG=2'

# Ce ne doit pas être des retours de prêts
FILGAUSUP(0)+='&[F:SRH]LNDRTN=1'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="SALFCY"
##   If CZ<>""        FILGAUSUP(0)+='& (([F:SRH]SALFCY="" & [F:SRH]CPY=GSOCIETE) | [F:SRH]SALFCY=CZ)' Endif
##Else
##   If [M]SALFCY<>"" FILGAUSUP(0)+='& (([F:SRH]SALFCY="" & [F:SRH]CPY=GSOCIETE) | [F:SRH]SALFCY=[M]SALFCY)' Endif
##Endif
If [M]SALFCY<>"" FILGAUSUP(0)+='& (([F:SRH]SALFCY="" & [F:SRH]CPY=GSOCIETE) | [F:SRH]SALFCY=[M]SALFCY)' Endif

If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCINV"
   ##   If CZ<>""        FILGAUSUP(0)+='& [F:SRH]BPCINV=CZ' Endif
   ##Else
   ##   If [M]BPCINV<>"" FILGAUSUP(0)+='& [F:SRH]BPCINV=[M]BPCINV' Endif
   ##Endif
   If [M]BPCINV<>"" FILGAUSUP(0)+='& [F:SRH]BPCINV=[M]BPCINV' Endif
Else
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCINV"
   ##   FILGAUSUP(0)+='& [F:SRH]BPCINV=CZ'
   ##Else
   ##   FILGAUSUP(0)+='& [F:SRH]BPCINV=[M]BPCINV'
   ##Endif
   FILGAUSUP(0)+='& [F:SRH]BPCINV=[M]BPCINV'
Endif

# V6.2 : Certification
# Si ctrl date documents : Le retour doit avoir une date <= à la date de l'avoir
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SRH]RTNDAT<=[M:SIH0]INVDAT' : Endif

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(1)+='&[F:SRH]PJT=[M]PJT'
   Endif
Endif
#--/CPO

#RMA * 85785
If func PORLEGLIB.DIGSIGN([M:SIH0]SALFCY,"")
  FILGAUSUP(1)+='&[F:SRH]SRHCFMFLG=2'
Endif


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SRH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SRH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission

Return
#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSD1,GBOXSO3,GBOXSR3, GBOXCO1,GBOXSI1,GBOXSR1 : WPICK=2 : Gosub RAFFRAICHI
 When GBOXSVIC1 : WPICK=2 : Gosub RAFFRAICHI # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
 When Default
Endcase
Return

#########################################################################
$INIT_WONFAITQUOI
  # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
  If dim(WONFAITQUOI) < 0 Then
    Local Char WONFAITQUOI(20)

    WONFAITQUOI = currbox
  Endif
  # FGR 11/07/2008 : X3SUIVI48011 (FIN)
Return

#########################################################################
$DEB_PICK
Local Integer I, J, WOK, SVGSTODIS, FUNCTION, WRET, NOL
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYPCE, WALLQTYPCE
#Local Char    WNUMTEX(12), SYMBOLE2(20)
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
#Local Char    WNUMTEX(12), SYMBOLE2(GLONVCR+GLONABR)  # FGR 11/07/2008 : X3SUIVI48011
Local Char    WNUMTEX(12), SYMBOLE2(50) #--Locking SVIC record needs more then GLONVCR+GLONABR !
# End issue 107888
Local Integer WCTL : WCTL=0

  FUNCTION = 4  : # Identifiant facture pour TRTVENBOM

  # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
  Gosub INIT_WONFAITQUOI
  WONFAITQUOI = currbox
  # FGR 11/07/2008 : X3SUIVI48011 (FIN)

#--CPO 87923 Gestion des prélèvements SDD
#--On ne fait rien quand on vient des Demandes de services et Contrats de service
#--Création de facture idem picking depuis ces derniers
If find(GFONC1,"GESSRE","GESCON")<1
  If [M:SIH4]NBLIG=0
    If dim(WSDD_SAVEPTE)<0
      Local Char WSDD_SAVEPTE(GLONPTE)
    Endif
    If dim(WSDD_SAVEBPRPAY)<0
      Local Char WSDD_SAVEBPRPAY(GLONBPR)
    Endif
    If dim([M:SIH2]UMRNUM)>0
      If dim(WSDD_SAVEUMRNUM)<0
        Local Char WSDD_SAVEUMRNUM(GLONMDT)
      Endif
      WSDD_SAVEUMRNUM=[M:SIH2]UMRNUM
    Endif
    WSDD_SAVEPTE   =[M:SIH2]PTE
    WSDD_SAVEBPRPAY=[M:SIH1]BPRPAY
  Endif
Endif
#--/

  # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component)
  If WONFAITQUOI= GBOXSVIC1 and [M:SIH1]SIHORI=10 : Gosub DEB_PICK From LIBSAL_INVCND_SIH_PICK : Endif
  # End issue 107888

Return

#########################################################################
$PICKE
  If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
    Return
   Endif
  Endif

  #85785
  Gosub SET_SAV_VALUES

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #Case currbox
   Case WONFAITQUOI
    When GBOXSD1
      Gosub SEL1
      #                Gosub ATT_ECRAN
    When GBOXSO3
      Gosub SEL2
      #                Gosub ATT_ECRAN
    When GBOXSR3
      Gosub SEL3
      #                Gosub ATT_ECRAN
    When GBOXCO1
      Gosub SEL4
      #                Gosub ATT_ECRAN
    When GBOXSI1
      Gosub SEL5
      #                Gosub ATT_ECRAN
    When GBOXSR1
      Gosub SEL6
      #                Gosub ATT_ECRAN
  When GBOXSVIC1
    Gosub SEL7 From LIBSAL_INVCND_SIH_PICK # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
    When Default
  Endcase

  # BRBAN 105200#US2
  Gosub PICKE From SUBSIHC1
  # -


  #85785
  Gosub GET_SAV_VALUES

Return

#########################################################################
$DEPICK
Local Char WORINUM (GLONVCR)

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #Case currbox
  Case WONFAITQUOI
    When GBOXSD1 : Gosub DESEL1
      # ACA - Fait lors de AVANT_LIGNE - Gosub SDH_MOINS From SUBSFIT
      #                Gosub ATT_ECRAN
    When GBOXSO3 : Gosub DESEL2
      # ACA - Fait lors de AVANT_LIGNE - Gosub SOH_MOINS From SUBSFIT
      #                Gosub ATT_ECRAN
    When GBOXSR3 : Gosub DESEL3
      #                Gosub ATT_ECRAN
    When GBOXCO1 : Gosub DESEL4
      #                Gosub ATT_ECRAN
    When GBOXSI1 : Gosub DESEL5
      # ACA - Fait lors de AVANT_LIGNE - Gosub SIH_MOINS From SUBSFIT
      #                Gosub ATT_ECRAN
    When GBOXSR1 : Gosub DESEL6
      #                Gosub ATT_ECRAN
    When GBOXSVIC1 : Gosub DESEL7 From LIBSAL_INVCND_SIH_PICK # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
    When Default
  Endcase

  # BRBAN 105200#US2
  Gosub DEPICK From SUBSIHC1
  #-
Return

#########################################################################
$FIN_PICK
Call PJT_INFO_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065
Raz WCTL
#MGG SAL_X3-38365_2_credit_memo_for_1_product_KO
GINVSEL=""
GADDPREV=2
#END MGG SAL_X3-38365_2_credit_memo_for_1_product_KO

  #--CPO 87923 Gestion des prélèvements SDD.
  #--On ne fait rien quand on vient des Demandes de services et Contrats de service
  #--Création de facture idem picking depuis ces derniers
  If find(GFONC1,"GESSRE","GESCON")<1
    #--Si première ligne il faut relancer un AM_PTE
    If dim([L]WSDD_SAVEPTE)>0 and dim([L]WSDD_SAVEBPRPAY)>0
      If [L]WSDD_SAVEPTE<>[M:SIH2]PTE or [L]WSDD_SAVEBPRPAY<>[M:SIH1]BPRPAY
        If dim([M:SIH2]UMRNUM)>0 : Raz [M:SIH2]UMRNUM : Endif
        Call AM_PTE([M:SIH2]PTE) From SUBSIH
      Endif
      Kill [L]WSDD_SAVEPTE, [L]WSDD_SAVEBPRPAY
    Endif
  Endif
  #--/

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  Gosub INIT_WONFAITQUOI
  #Case currbox
   Case WONFAITQUOI
    When GBOXSD1 :
      Call SDH_SIH_CALCUL From SUBSFIT
    When GBOXSO3 :
      Call SOH_SIH_CALCUL From SUBSFIT
    When GBOXSI1 :
      Call SIH_SIH_CALCUL From SUBSFIT
    When GBOXSR1 :
       Call SRH_SIH_CALCUL From SUBSFIT #--CPO 79550 Transferts : Retours -> Avoirs sur retours
    When GBOXCO1 :
       Call CON_SIH_CALCUL From SUBSFIT #--CPO 79550 Transferts : Contrats de service -> Factures
    When GBOXSVIC1
       #-- Normal order -> Invoices (by using a scheduling invoice)
       Call SVIC_ORISOH_SIH_CALCUL From SUBSFIT # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Pre analysis
    When Default
  Endcase

  # BRBAN 105200#US2
  If func AFNC.ACTIV("INVCA")>0
    If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
      Call SIH_SIH_CALCUL From SUBSFIT
    Endif
  Endif
  # -

  Gosub CAL_FACTURE

  If REP = ""
   If !VERROU
     GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
     GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
  Endif

  # ACA (2009-09-22) Lot S03 : chargement des sections des elts de fac des documents origine
  Local Integer IVCRTYP
   Case WONFAITQUOI
    When GBOXSD1 :
      [L]IVCRTYP=2
    When GBOXSO3 :
      [L]IVCRTYP=20
    When GBOXSI1 :
      [L]IVCRTYP=4
    When GBOXSR1 :
      [L]IVCRTYP=2  #--CPO 79550 Transferts : Retours -> Avoirs sur retours
    When GBOXCO1 :
      #--Pour l'instant il n'y a pas de gestion des axes/sections sur les éléments de fact des contrats de serv
      #[L]IVCRTYP=23 #--CPO 79550 Transferts : Contrats de services -> Factures
    When GBOXSVIC1
       [L]IVCRTYP=20 # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Pre analysis
    When Default
  Endcase

  # BRBAN 105200#US2
  If func AFNC.ACTIV("INVCA")>0
    If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
      [L]IVCRTYP=4
    Endif
  Endif
  # -

  # 81878 : Ajout borne pour ne pas trier le tableau complet
  #Sorta [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
  Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
  # 81878
  Call CHARG_CCE_MULTI([L]IVCRTYP,"[M:SFIT]VCRENT","[M:SFIT]DTA","[M:SIHV]XFNUM","[M:SIHV]SFICCE","[M:SIHV]DSP") From TRTX3CPT

  # Si avoir sur facture avec mouvement de stock
  #If [M:SIH1]STOMVTFLG=2 & currbox=GBOXSI1
  #    If dim(I)<0 Local Shortint I : Endif
  #    Local Integer WRET
  #    For I=0 To [M:SIH4]NBLIG-1
  #        If [M:SIH4]STOMGTCOD(I)>1 & [M:SIH4]WSTOFLG(I)=0
  #            If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=5;GFLAG
  #                                    If fstat Raz [F:SLT] Endif
  #                                    Endif
  #            # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
  #            Call STJSTOENTW("SIH4",12,18,[M:SIH0]INVDAT,I,[M:SIH4]NBLIG,"SLT",0,WRET) From STKENT
  #            If WRET=1 GERR=1 : OK=0 : Return : Endif
  #            If GMESSAGE <> "" Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : Endif
  #        Endif
  #    Next I
  #Endif

  # FGR 11/07/2008 : X3SUIVI48011 : c'est WONFAITQUOI qui contient ce qu'il faut
  #Case currbox
   Case WONFAITQUOI
    When GBOXSD1, GBOXSO3, GBOXSR3, GBOXCO1, GBOXSI1, GBOXSR1
&       ,GBOXSVIC1  # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component)
      Affzo [M:SIHV]1-99
      Affzo [M:SIH4]1-99
      Affzo [M:SIH2]1-99
      Affzo [M:SIH1]1-99
      Affzo [M:SIH0]1-99
      Gosub ATT_ECRAN
      zonsui = "[M:SIH4]NBLIG("+num$(NOL)+")"
    When Default
  Endcase

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
    Affzo [M:SIHV]1-99
    Affzo [M:SIH4]1-99
    Affzo [M:SIH2]1-99
    Affzo [M:SIH1]1-99
    Affzo [M:SIH0]1-99
    Gosub ATT_ECRAN
    zonsui = "[M:SIH4]NBLIG("+num$(NOL)+")"
  Endif
Endif
# -
  # Bug : 116322 : X3 allowes creation of sales invoice in forbidden period
  #-- LCC 29/11/16
   Call CTLDAT_CNF(5,[M]SALFCY,[0/0/0],[M:SIH0]INVDAT,"","") From CONTX3
   If mkstat : zonsui="[M:SIH0]INVDAT": Return: Endif
  #--/LCC1
Return

#########################################################################
# FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
#########################################################################
# Enchaîne création facture idem sélection depuis liste de picking
#       * Demandes de service
#########################################################################
$CREFAC_IDEM_PICKE
  Call TEMPON("V") From GESECRAN

  GREP = "C"
  REP = "C"
  GOK = 1
  OK = 1
  Gosub RAZCRE From SUBSIHA
  Gosub DEB_PICK
  #
  # Note FGR : Prévu, à décommenter et déplacer dans "Case GFONC1" quand nécessaire
    #When GBOXSD1
    #  Gosub SEL1
    #When GBOXSO3
    #  Gosub SEL2
    #When GBOXSI1
    #  Gosub SEL5
    #When GBOXSR1
    #  Gosub SEL6
  Case GFONC1
    When "GESSRE"
      # Demande de service
      WONFAITQUOI = GBOXSR3
    When "GESCON"
      # Contrat de service
      WONFAITQUOI = GBOXCO1
    When Default
  Endcase
  #
  Gosub PICKE
  Gosub FIN_PICK From SUBSIHC
  #
  If [M:SIH4]NBLIG = 0 Then
    GERR = 1
    GMESSAGE = mess(68,192,1)
    Raz GOK
  Endif
  If GERR <> 1 Then
    # --> Lignes à zéro interdites (1=non 2=oui)
    If GSIVNULL = 2 & sum([M:SIH4]AMTNOTLIN) = 0 Then
     GERR = 1
     GMESSAGE = mess(91,106,1)
     Raz GOK
    Endif
    #
    If GERR <> 1 Then
      #--CPO 87923 Gestion des prélèvements SDD
      #--Hors proformas
      If find([M:SIH0]INVTYP, 1,2)
        Gosub INIT_CTL_UMRNUM From SUBSIHB
      Endif
      #--/
      # Création de la facture
      Gosub CREATION From GOBJET1
      #--CPO 79550 Pour affichage des nouvelle valeurs dans le [M:SIH2]NBFAC
      If GFONC1="GESCON"
        GREP=""
      Endif
      #--/
    Endif
  Endif
  #
  Call TEMPOFF From GESECRAN
Return
#########################################################################
# FGR 11/07/2008 : X3SUIVI48011 (FIN)
#########################################################################

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$ATT_ECRAN
#-----------------------------------------------------------------------#
# Activation, désactivation champs écran facture en picking             #
#-----------------------------------------------------------------------#
If [M]NBLIG=0
   Actzo [M:SIH0]SIVTYP, SALFCY, BPCINV
   Actzo [M:SIH1]BPRPAY, BPCGRU, VACBPR
   If GUPDCUR=2 Actzo [M:SIH2]CUR Endif
   If [M:SIH2]CUR <> GLOCALDEV Actzo [M:SIH2]CURTYP Endif
   If GNOTATI=2 Actzo [M:SIH1]PRITYP Endif
   If [M]INVTYP=2 & [M]SIHORI=4 Actzo [M:SIH1]STOMVTFLG Endif
Else
   Diszo [M:SIH0]SIVTYP, SALFCY, BPCINV
   Diszo [M:SIH1]BPRPAY, BPCGRU, VACBPR, PRITYP
   Diszo [M:SIH2]CUR, CURTYP
Endif
Return
#########################################################################
$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))
Local Char SACTION : SACTION=ACTION
Gosub REMP_LISGAU From GOBJSUB
ACTION=SACTION
Return

#########################################################################
$SEL1
#-----------------------------------------------------------------------#
# Sélection d'une livraison                                             #
#-----------------------------------------------------------------------#
Local  Integer WLIG, WOK
Local  Char    WCRITSDD (150)
Global Libelle GSIVSUP
Local  Char SWPJTMSG(250)  # FGR 15/12/2011 X3SUIVI71065

Read [SDH]SDH0=[F:SDH]SDHNUM
If fstat
   Call RSTA ("SDH",[F:SDH]SDHNUM) From GLOCK : OK=0 : Return
Endif
# Vérif. si la livraison n'a pas été facturée depuis le dernier raffraichissement de la liste de picking
If [F:SDH]INVFLG=2
    GMESSAGE = [F:SDH]SDHNUM-":"-mess(95,192,1) : OK=0 : Return
Endif
If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SDH]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SDH]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
Endif

# 40127 : Return status management
# With RTNSTA Returned deliveries are now filtered in FILGAUCHE1
#Raz WLIG
#For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
#   #If (GDLVRTNCNO=1 & [F:SDD]QTYSTU > [F:SDD]RTNQTYSTU) | GDLVRTNCNO=2
#   # Bug 46937
#   # Si livraisons de prêt, on facture ce qui n'est pas retourné
#   # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
#   # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
#   If ([F:SDD]QTYSTU>[F:SDD]RTNQTYSTU & ([F:SDH]LND=2 | GDLVRTNCNO=1)) |
#&     ([F:SDH]LND=1 & GDLVRTNCNO=2)
#       WLIG += 1
#   Endif
#Next
#If WLIG = 0
#   GMESSAGE = mess(444,197,1)-":"-mess(276,192,1)      : # Il n'y a rien à facturer
#   OK=0 : GERR=1 : Return
#Else
#   If [F:SDH]LND = 2
#      WOK=1
#      Call OUINON(mess(39,191,1),WOK) From GESECRAN
#      If WOK=1 OK=0 : GERR=1 : Return Endif
#   Endif
#Endif

# 71065 : PJT

# If [F:SDH]LND = 2
#    WOK=1
#    Call OUINON(mess(39,191,1),WOK) From GESECRAN
#    If WOK=1 OK=0 : GERR=1 : Return Endif
# Endif
## 40127

#--CPO 71065 Si première livraison, il faut initialiser le code affaire en-tête afin de faire les tests suivants
If [M:SIH4]NBLIG = 0 and [F:SDH]PJT <> ""
  If func TRTPJT.IS_PJT_AVAILABLE([F:SDH]PJT, "[M:SIH1]PJT", SWPJTMSG) = G_OUI Then
    [M:SIH1]PJT = [F:SDH]PJT
  Endif
Endif
#--/CPO
Raz WLIG
For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
   # FGR 06/12/2011 : X3SUIVI71065 (début)
   If func TRTPJT.IS_PJT_AVAILABLE([F:SDD]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
     Call PJT_ADD_MSG([F:SDD]PJT, SWPJTMSG) From TRTPJT
     WLIG = -1
     OK = 0
   Endif
   # FGR 06/12/2011 : X3SUIVI71065 (fin)
Next

If WLIG = -1 Then
  # FGR 06/12/2011 : X3SUIVI71065
  Return
Else
 If [F:SDH]LND = 2
    WOK=1
    Call OUINON(mess(39,191,1),WOK) From GESECRAN
    If WOK=1 OK=0 : GERR=1 : Return Endif
 Endif
Endif
# 71065 : PJT

# Si 1 facture / commande soldée
If [F:SDH]IME=2 & [F:SDH]SOHNUM<>"" & [M:SIH4]NBLIG=0
#  Vérification que la commande est soldée
   Read [SOH]SOH0 = [F:SDH]SOHNUM
   If fstat
      Call RSTA("SOH",[F:SDH]SOHNUM) From GLOCK : OK=0 : Return
   Elsif [F:SOH]ORDSTA=1
      GERR=1:GMESSAGE=mess(129,197,1)-":"-[F:SDH]SDHNUM-":"-mess(98,197,1)-":"-[F:SDH]SOHNUM-"\"+mess(186,192,1)+"\"+mess(188,192,1)
      OK=0 : Return
   Else
#  Vérification que les livraisons de cette commande sont validées
      Gosub VERIF_SDH
      If OK=0 Return Endif
   Endif
#  On prévient que ttes les livraisons doivent être sur la même facture
   # FGR 22/06/2015 : X3SUIVI109023 (début)
   #GERR=2:GMESSAGE=mess(129,197,1)-":"-[F:SDH]SDHNUM-":"-mess(98,197,1)-":"-[F:SDH]SOHNUM-"\"+mess(105,191,1)-"\"+mess(104,191,1)
   Call MESSAGE(mess(129,197,1)-":"-[F:SDH]SDHNUM-":"-mess(98,197,1)-":"-[F:SDH]SOHNUM-"\"+mess(105,191,1)-"\"+mess(104,191,1)) From GESECRAN
   # FGR 22/06/2015 : X3SUIVI109023 (fin)
Endif

# C'est la 1ère ligne de la facture
If [M:SIH4]NBLIG = 0
   # Lecture client facture
   Read [BPC]BPC0 = [F:SDH]BPCINV
   If fstat
      Call RSTA("BPC",[F:SDH]BPCINV) From GLOCK : OK=0 : Return
   Endif
   # Alimentation des masques entête facture
   Call ALISDHSIH() From TRTVENFAC
Else
   # Contrôle des conditions de regroupement
   Gosub CTL_LIV
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M:SIH4]NBLIG+[F:SDH]LINNBR >= dim([M:SIH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

# Traitement d'une nouvelle livraison sur la facture
# If [M:SIH4]NBLIG > 0
#   alimentation des elements de facturation
#     Local Integer NBPOSTE : NBPOSTE = 10
#    # Call SAISFOOT2(6,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SDH]CUR,[M:SIH2]CUR,"NON") From TRTVENELT
# Endif

# Bug 46937
# Si livraisons de prêt, on facture ce qui n'est pas retourné
# Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
# Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
WCRITSDD='([F:SDD]QTYSTU>[F:SDD]RTNQTYSTU & ([F:SDH]LND=2 | GDLVRTNCNO=1)) | ([F:SDH]LND=1 & GDLVRTNCNO=2)'
# Ne prendre en compte que les lignes non complètement retournées
#For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & ((GDLVRTNCNO=1 & [F:SDD]QTYSTU>[F:SDD]RTNQTYSTU) | GDLVRTNCNO=2)
For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & evalue(WCRITSDD)
   # Traitement de la ligne de livraison
   Gosub TRT_LIGLIV
   #If GERR <> 0 Then         # FGR 19/08/2014 : X3SUIVI100811
   If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
     OK = 0
     Break
   Endif
Next
#If GERR <> 0 Then            # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  Return
Endif

[M:SIH1]SIHORI=3
[M:SIH1]STOMVTFLG=2
Diszo [M:SIH1]STOMVTFLG
Diszo [M:SIH1]STOFCY

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
  [M:SIH1]SSTENTCOD = [F:SDH]SSTENTCOD
Endif
# LTA.en 79065

#--CPO 79343
If GREP<>"C" and GSIHSUPPLIGDSP<>999999 and [M:SIH4]NBLIG > 0
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",[M:SIH4]NBLIG-1,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    GSIHSUPPLIGDSP +=1
  Endif
Endif
#--/CPO

Call RECH_ORINUM From SUBSIHB

# Si plus d'une livraison sur la facture, réinitialiser la date écheance avec la date facture
# (au cas où origine date échéance = date livraison)
If [M:SIH1]SIHORINUM = ""
    [M:SIH2]STRDUDDAT = [M:SIH0]INVDAT
Endif

#Gosub CAL_FACTURE

#Raz GMESSAGE

Return

#########################################################################
$CTL_LIV
Local Char SWPJTMSG(250)  # FGR 15/12/2011 : X3SUIVI71065

#--------------------------------------------------------------------------------#
# Contrôle de la livraison sélectionnée                                          #
# Elle doit être facturable et cohérente par rapport aux autres liv. sélection.  #
#--------------------------------------------------------------------------------#

If [F:SDH]BPCINV<>[M:SIH0]BPCINV | ([M:SIH1]BPRPAY<>"" & [F:SDH]BPCPYR<>[M:SIH1]BPRPAY) |
&  ([M:SIH1]BPCGRU<>"" & [F:SDH]BPCGRU<>[M:SIH1]BPCGRU) | [F:SDH]BETFCY<>[M:SIH1]BETFCY |
&  [F:SDH]BETCPY<>[M:SIH1]BETCPY
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(102,192,1)
   Return
Endif
# Facture inter-sociétés
If [M]BETFCY=2
    # Pas de liv. directes avec des liv. issues de cdes
    If [F:SDH]ORIFCY="" & [M]ORIFCY<>""
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-":"-mess(179,191,1)-":\"+mess(183,191,1)
        Return
    Endif
    # Pas de liv. issues de cdes auto. avec des liv. directes ou des liv. issues de cdes manuelles
    If ([F:SDH]ORIFCY<>"" & [F:SDH]ORIFCY<>[F:SDH]SALFCY) & ([M]ORIFCY="" | [M]ORIFCY=[M]SALFCY)
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-":"-mess(173,191,1)-":\"+mess(174,191,1)
        Return
    Endif
    # Pas de liv. issues de cdes manuelles avec liv. directes ou de liv. issues de cdes automatiques
    If [F:SDH]ORIFCY=[F:SDH]SALFCY & [M]ORIFCY<>[M]SALFCY
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-":"-mess(175,191,1)-":\"+mess(176,191,1)
        Return
    Endif
Endif
If [F:SDH]SALFCY<>[M:SIH0]SALFCY
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(103,192,1)
   Return
Endif
If [F:SDH]PLISTC<>[M:SIH0]PLISTC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(305,192,1)
   Return
Endif
If [F:SDH]CUR<>[M:SIH2]CUR | [F:SDH]PTE<>[M:SIH2]PTE | ([M:SIH2]DEP<>"" & [F:SDH]DEP<>[M:SIH2]DEP)
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(104,192,1)
   Return
Endif
If [F:SDH]PRITYP<>[M:SIH1]PRITYP | [F:SDH]VACBPR<>[M:SIH1]VACBPR
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(105,192,1)
   Return
Endif

# 71065 : PJT
##Gbn-Fq77304-New entry point to avoid the control on the project field
#GPE=0 : Local Char GPECNX : GPECNX="CTL_DLV" : GPOINT="SIHCTLPJT" : Gosub ENTREE From EXEFNC
#If !GPE
# If [F:SDH]PJT<>[M:SIH1]PJT
#    OK=0 : GERR=1
#    GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(107,192,1)
#    Return
# Endif
#Endif
# 71065 : PJT

# FGR 28/11/2011 : X3SUIVI71065 (début)
If func TRTPJT.IS_PJT_AVAILABLE([F:SDH]PJT, "[M:SIH1]PJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SDH]PJT, SWPJTMSG) From TRPPJT
  OK = 0
  Return
Endif
# FGR 28/11/2011 : X3SUIVI71065 (fin)

#--- CPO 72237 Le champ BPIEECNUM est soumis à code activité, par contre le EECICT non
#If [F:SDH]BPIEECNUM<>[M]BPIEECNUM | [F:SDH]EECICT<>[M]EECICT
If (dim([M]BPIEECNUM)>0 & [F:SDH]BPIEECNUM<>[M]BPIEECNUM) | [F:SDH]EECICT<>[M]EECICT
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-"\"+mess(187,192,1)+"\"+mess(303,192,1)
   Return
Endif
If dim([M]EECLOC)>0 & [F:SDH]EECLOC<>[M]EECLOC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-"\"+mess(187,192,1)+"\"+mess(304,192,1)
   Return
Endif
#-------------------------------------------------#
# Contrôle des liens dus au mode de facturation   #
#-------------------------------------------------#
# Si une facture par BL
If [M:SIH0]IME=1
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(190,192,1)
   Return
Endif
# Si une facture par commande(soldée) ou par client livré
If find([M:SIH0]IME,2,3,4) & [F:SDH]IME<>[M:SIH0]IME
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(189,192,1)
   Return
Endif
# Si une facture par période ou manuelle
If find([M:SIH0]IME,5,6) & !find([F:SDH]IME,5,6)
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(189,192,1)
   Return
Endif
# Si une facture par commande(soldée)
If find([M:SIH0]IME,2,3) & [F:SDH]SOHNUM<>""
   For I=0 To [M:SIH4]NBLIG-1
      If [M:SIH4]SOHNUM(I)<>"" & [M:SIH4]SOHNUM(I)<>[F:SDH]SOHNUM
         OK=0 : GERR=1
         GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(191,192,1)
         Break
      Endif
   Next I
   If OK=0 Return Endif
Endif
# Si une facture par client livré
If [M:SIH0]IME=4 & ([F:SDH]BPCORD<>[M:SIH1]BPCORD | [F:SDH]BPAADD<>[M:SIH1]BPAADD)
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM+"\"+mess(187,192,1)+"\"+mess(192,192,1)
   Return
Endif

# Controle du champ GRUFLG :
# Si Oui (1), pas de restriction
#  Sinon (2), vérifier que les éléments en % ont la meme valeur
Local Integer I2
Local Decimal DTAAMTCMP
Local Char    TSTRUL
#--CPO 107663
For I=0 To dim([F:SDH]INVDTA) - 1
    If [F:SDH]INVDTA(I) = 0 : Break : Endif
    If [F:SDH]INVDTATYP(I) = 3 : # %
        # Recherche Param concernant Doc Ori et Dest
        TSTRUL = num$([F:SDH]INVDTA(I)) + "~2~19"
        I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

        If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
            #--CPO Il faut tester la valeur "1ère Facture" (valeur 3)
            #If [M:SFIT]T_BRDRUL(I2)=1 and [F:SDH]SIHNUM<>"" : # eclaté sur 1ere liv et deja partiellement ou totalement facturée
            If [M:SFIT]T_BRDRUL(I2)=3 and [F:SDH]SIHNUM<>"" : # eclaté sur 1ere liv et deja partiellement ou totalement facturée
                DTAAMTCMP=0
            Else
                DTAAMTCMP=[F:SDH]INVDTAAMT(I)
            Endif

            I2 = find ( [F:SDH]INVDTA(I) , [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
            If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                OK=0 : GERR=1
                # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                Local Char SHOAXX
                Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SDH]INVDTA(I)),"") From ATEXTRA
                GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                Break
            Endif
        Endif
    Endif
Next I
#--/

# ACA - Controle des codes adresses client commande et facture
If ([F:SDH]BPAINV<>[M:ADB3]BPAADD)
    OK=0 : GERR=1
    GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-
&       format$(GFMDAT,[F:SDD]SHIDAT)+"\"+mess(187,192,1)+"\"+mess(329,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    Return
Endif

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SDH]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SDH]SDHNUM, [F:SDH]SSTENTCOD)
  Return
Endif
# LTA.en 79065

Return


#---------------------------------------------------------------------------------#
# Si 1 facture/commande soldée                                                    #
# --> Ttes les livraisons de la commande doivent être validées                    #
#---------------------------------------------------------------------------------#
$VERIF_SDH

If !clalev([F:SDH1]) Local File SDELIVERY [SDH1] Endif
#p Filter [SDH1] Where SOHNUM = [F:SOH]SOHNUM & CFMFLG=1
#p Look [SDH1]SDH0 First
Filter [SDH1] Where BPCORD=[F:SOH]BPCORD & SOHNUM = [F:SOH]SOHNUM & CFMFLG=1
Look [SDH1]SDH1 First
If fstat=0
    OK=0
    GERR=1:GMESSAGE=mess(129,197,1)-":"-[F:SDH]SDHNUM-":"-mess(98,197,1)-":"-[F:SDH]SOHNUM-"\"+mess(105,191,1)+"\"+mess(225,192,1)
Endif
Filter [SDH1]
Close Local File [SDH1]
Default File [SIV]

Return

###########################################################################
# TRT_LIGLIV    Traitement de la ligne livraison à facturer               #
#-------------------------------------------------------------------------#
# Utilisation : picking livraison depuis la gestion des factures          #
#               bouton  facture   depuis la gestion des livraisons        #
###########################################################################
$TRT_LIGLIV

   # Ouverture de la ligne
   nolign = [M:SIH4]NBLIG
   Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
   [M:SIH4]NBLIG += 1
   nolign = [M:SIH4]NBLIG
   NOL = nolign-1
   status = 0

   # Lecture des tables articles
   Gosub LEC_TABART

   # Alimentation de la classe [M:SIH4] de la ligne
   Call ALISDDSIH(NOL) From TRTVENFAC

   Gosub SDH_SIH_PLUS From SUBSFIT
   #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
   If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
     OK = 0
     Return
   Endif

   Call LINNUM("SIDLIN") From TABLEAUX

   #If find([M:SIH4]LINTYP(NOL),3,4,5,11,12,13) GNETMAR=0 Endif : # 89124
   GNETMAR=0                                                    : # 89124
   Call APRES_LIGNE(NOL,1) From SUBSIHB
   GNETMAR=1

Return

#########################################################################
$SEL2
#-----------------------------------------------------------------------#
# Sélection d'une ligne de commande                                     #
#-----------------------------------------------------------------------#

# Alimentation de la clé de SOQ et forçage de la valeur de SOPSEQ
[F:SOQ]SOHNUM = [F:SOP]SOHNUM
[F:SOQ]SOPLIN = [F:SOP]SOPLIN
[F:SOQ]SOQSEQ = [F:SOP]SOPLIN
[F:SOP]SOPSEQ = [F:SOP]SOPLIN
#--- Lecture des tables [SOQ],[SOH],[SOP]
Read [SOQ]SOQ0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
If fstat
   Call RSTA ("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
   OK=0 : Return
Endif
# Vérification si la ligne n'a pas été soldée
# depuis le dernier raffraichissement de la liste de picking
If [F:SOQ]INVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
   GMESSAGE = [F:SOQ]SOHNUM-":"-mess(27,159,1)-[F:SOQ]ITMREF-":"-mess(248,192,1)
   OK=0 : Return
Endif
Read [SOH]SOH0=[F:SOQ]SOHNUM
If fstat
   Call RSTA ("SOH",[F:SOQ]SOHNUM) From GLOCK
   OK=0 : Return
Endif
Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
If fstat
   Call RSTA ("SOP",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
   OK=0 : Return
Endif

If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SOH]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SOH]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

# --- Contrôle état crédit de la commande
# WCTL=0 : Ctrl non encore effectué car 1ère ligne de la cde traitée
# WCTL=1 : Ctrl déjà effectué sur les lignes précédentes de la cde avec abandon
# WCTL=2 : Ctrl déjà effectué sur les lignes précédentes de la cde avec poursuite
If WCTL=0
    WCTL=2
    #--- Contrôle état crédit de la commande
    Call SDCDTSTA ([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,[F:SOH]UNL,1,
&                  CDTSTA,[M]OST,[M]OSTAUZ) From TRTVENCDT
    Case CDTSTA
     When 2 : OK=0 : GERR=1          : # Client bloqué
              GMESSAGE=[F:SOH]SOHNUM-mess(52,192,1)
              WCTL=1 : Return
     When 3 :                        : # Dépassement d'en cours
              # Si déblocage crédit non autorisé on bloque
              If GCDTUNL=1
                  OK=0:GERR=1
                  GMESSAGE=[F:SOH]SOHNUM-mess(29,192,1)
                  WCTL=1 : Return
              Endif
              WOK=2
              Call AVERTIR([F:SOH]SOHNUM-mess(29,192,1),WOK) From GESECRAN
              If WOK=1 OK=0 : WCTL=1 : Return Endif
     When 4 : If GLOKORD=2
                 OK=0 : GERR=1       : # Acomptes non versés
                 GMESSAGE=[F:SOH]SOHNUM-mess(53,192,1)
                 WCTL=1 : Return
              Endif
     When 5 : OK=0 : GERR=1          : # Sage Exchange
              Local Char VCRNUM
              Local Integer VCRTYP
              Call SEPP_CUR_DOC([F:SOH]SOHNUM,[L]VCRTYP,[L]VCRNUM) From SEPPCDT
              If [L]VCRNUM<>[F:SOH]SOHNUM
                If [L]VCRTYP=4
                  GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(54,198,1)-[L]VCRNUM)
                Else
                  GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(55,198,1)-[L]VCRNUM)
                Endif
              Else
                GMESSAGE = mess(9,2092,1)
              Endif
              GMESSAGE=[F:SOH]SOHNUM-GMESSAGE
              WCTL=1 : Return
     When Default
    Endcase
Elsif WCTL=1
    OK=0 : Return
Endif

#--- Appel au traitement de contrôle de la sélection

# C'est la 1ére commande de la facture
If [M:SIH4]NBLIG <> 0
   If sum([M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1)) = ""
      YSOHNUM = [F:SOH]SOHNUM
   Endif
Endif

# Contrôle que la ligne de commande est facturable
Gosub CTL_CDE_LIG
If OK=0 Return Endif

# C'est la première ligne de la facture
If [M]NBLIG = 0
   # Lecture client facture
   Read [BPC]BPC0 = [F:SOH]BPCINV
   If fstat
      Call RSTA("BPC",[F:SOH]BPCINV) From GLOCK : OK=0 : Return
   Endif
   # Lecture client livré
   Read [BPD]BPD0 = [F:SOQ]BPCORD;[F:SOQ]BPAADD
   If fstat
      Call RSTA("BPD",[F:SOQ]BPCORD+[F:SOQ]BPAADD) From GLOCK : OK=0 : Return
   Endif
   # Lecture mode de livraison
   If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif
   Raz [F:TMD]
   If [F:SOQ]MDL <> ""
      Read [TMD]TMD0 = [F:SOQ]MDL
      If  fstat : Raz [F:TMD] : Endif
   Endif
   # Alimentation des masques (entête)
   Call ALISOHSIH() From TRTVENFAC
   YSOHNUM = [F:SOH]SOHNUM
   Close Local File [TMD]

   # LTA.sn 79065
   # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
   If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
     [M:SIH1]SSTENTCOD = [F:SOH]SSTENTCOD
   Endif
   # LTA.en 79065
Else
   # Contrôle des conditions des regroupement, et des liens cde/fac
   Gosub CTL_CDE
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SOH"+[F:SOH]SOHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

#-----------------------------------------------
# Traitement de la ligne de commande à facturer
#-----------------------------------------------
Gosub TRT_LIGCDE
If OK=0 Unlock = SYMBOLE2 : Endif

Default File [SIV]

[M:SIH1]SIHORI=2
[M:SIH1]STOMVTFLG=2
Diszo [M:SIH1]STOMVTFLG
Diszo [M:SIH1]STOFCY

Call RECH_ORINUM From SUBSIHB

#--CPO 79343
If GREP<>"C" and GSIHSUPPLIGDSP<>999999 and [M:SIH4]NBLIG > 0
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",[M:SIH4]NBLIG-1,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    GSIHSUPPLIGDSP +=1
  Endif
Endif
#--/CPO

#Gosub CAL_FACTURE

#Raz GMESSAGE

Return

###########################################################################
# TRT_LIGCDE    Traitement de la ligne commande à facturer                #
#-------------------------------------------------------------------------#
# Utilisation : picking commande depuis la gestion des factures           #
#               bouton  facture  depuis la gestion des commandes          #
###########################################################################

$TRT_LIGCDE
Local Integer WRUP   : # Génération des ruptures (0=non / 1=oui)
Local Integer WRET
Local Integer WSTA, WA, WQ, WR
Local Integer WSTOSEQ
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYARR, WQTA
Local Decimal WQTYCPE, WQTYSTUCPE, WCOECPE
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
Local Decimal WSVGQTYSTU
Local Integer WNEGSTO

# FGR 30/11/2011 : X3SUIVI71065 (début)
Local Char SWPJTMSG(250)

If func TRTPJT.IS_PJT_AVAILABLE([F:SOQ]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SOQ]PJT, SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
# FGR 30/11/2011 : X3SUIVI71065 (fin)

WNEGSTO = [F:ITM]NEGSTO

GPOINT = "TRT_LIGCDE" : Gosub ENTREE From EXEFNC

WSAUSTUCOE = [F:SOP]SAUSTUCOE
WSAU       = [F:SOP]SAU
If WSAUSTUCOE=0 WSAUSTUCOE=1 Endif

#----------------------------------------
# Détermination de la quantité à facturer
#----------------------------------------

Raz WRUP
# Qté facturée = qté restant à facturer sauf
# si article géré en stock ou article non géré en stock et quantité allouée <> 0
WQTY    = [F:SOQ]QTY - ([F:SOQ]ODLQTY + [F:SOQ]INVQTY)
WQTYSTU = [F:SOQ]QTYSTU - ([F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU)

# Si proforma
If [M:SIH0]INVTYP=5
   Goto TRT_LIGCDE_SUI
Endif
# Si article non géré en stock et non composé d'un kit/sous-traité
If [F:SOQ]STOMGTCOD=1 & !find([F:SOP]LINTYP,2,10)
   If [F:SOQ]TDLQTY<>0
      WQTY    = [F:SOQ]TDLQTY
      WQTYSTU = [F:SOQ]TDLQTYSTU
   Endif
   # Issue X3-38392
   # Moved from CTL_CDE_LIG
   # Si livraison (ligne) cde complète et ligne cde non facturée totalement
   If [F:SOH]DME>1 & (WQTY+[F:SOQ]ODLQTY+[F:SOQ]INVQTY < [F:SOQ]QTY)
      WOK=1
      If [F:SOQ]ODLQTY+[F:SOQ]INVQTY<>0
          Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                      format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Else
           Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                      format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Endif
      If WOK=1 OK=0 : Return Endif
   Endif
   # End issue X3-38392
Endif

# Article géré en stock ou composé de kit/sous-traité
# Détermination de la quantité théorique à livrer
If [F:SOQ]STOMGTCOD<>1 | find([F:SOP]LINTYP,2,10)
   # Si qté allouée
   If [F:SOQ]ALLQTY<>0
      WQTY    = [F:SOQ]ALLQTY
      WQTYSTU = [F:SOQ]ALLQTYSTU
      # Si qté rupture, stock négatif autorisé et livraison des ruptures
      If [F:SOQ]SHTQTY<>0
         #If WNEGSTO=2 & GSHTDLV=2
         If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
            WQTY    += [F:SOQ]SHTQTY
            WQTYSTU += [F:SOQ]SHTQTYSTU
            WRUP  = 1
         Endif
      # Sinon si stock négatif autorisé et livraison des ruptures,
      # on génèrera une rupture si nécessaire
      #Elsif WNEGSTO=2 & GSHTDLV=2
      Elsif (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
        WRUP  = 1
      Endif
   # Sinon si qté rupture
   Elsif [F:SOQ]SHTQTY<>0
      # Si stock négatif autorisé et livraison des ruptures
      #If WNEGSTO=2 & GSHTDLV=2
      If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
         WQTY    = [F:SOQ]SHTQTY
         WQTYSTU = [F:SOQ]SHTQTYSTU
         WRUP = 1
      Endif
   # Sinon si stock négatif autorisé et livraison des ruptures,
   # on génèrera une rupture si nécessaire
   #Elsif WNEGSTO=2 & GSHTDLV=2
   Elsif (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
      WRUP=1
   Endif

   # Si livraison (ligne) cde complète et ligne cde non allouée totalement
   If [F:SOH]DME>1 & (WQTY+[F:SOQ]ODLQTY+[F:SOQ]INVQTY < [F:SOQ]QTY)
      WOK=1
      If [F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>0
          Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                     format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Else
          Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                     format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Endif
      If WOK=1
         OK=0 : Return
      Endif
   Endif

   #---------------------------------------------
   # TS : réajustement qté en unité vente entière
   #---------------------------------------------
   Gosub REAJUSTE_QTY

   # Bug 29257
   WSVGQTYSTU = WQTYSTU

   # Si article géré en stock (composé de kit ou non)
   # Détermination de la quantité réellement facturable
   If [F:SOQ]STOMGTCOD<>1
      # Si allocation détaillée et qté allouée<>0 ou qté rupture livrable
      If [F:SOQ]ALLTYP=2 &
&       ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)))
#&       ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2))
         # Chargement STOSORW à partir des allocations
         [M:ALP]TRSTYP    = 4
         [M:ALP]TRSCOD    = [M:SIH0]TRSCOD
         [M:ALP]VCRTYP    = 2
         [M:ALP]VCRNUM    = [F:SOQ]SOHNUM
         [M:ALP]VCRLIN    = [F:SOQ]SOPLIN
         [M:ALP]VCRSEQ    = [F:SOQ]SOQSEQ
#         [M:ALP]STOFCY    = [M:SIH1]STOFCY
         [M:ALP]STOFCY    = [F:SOQ]STOFCY
         [M:ALP]ITMREF    = [F:SOQ]ITMREF
         # --------------------------------------
         # FGR 21/04/2015 : X3SUIVI105605 (début)
         If dim([M:ALP]ECCVALMAJ) >= 0 Then
          [M:ALP]ECCVALMAJ = [F:SOQ]ECCVALMAJ
         Endif
         # FGR 21/04/2015 : X3SUIVI105605 (fin)
         # --------------------------------------
         [M:ALP]QTY       = WQTYSTU
         [M:ALP]TYPQTY    = 2
         [M:ALP]STA       = [F:SOQ]STA
         [M:ALP]PECSCOLOC = 1
         [M:ALP]BESDAT    = [M:SIH0]INVDAT
         [M:ALP]DLVDAT    = [M:SIH0]INVDAT
         If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SIH1]WRHE)>0
            [M:ALP]WRH = [M:SIH1]WRHE
         Else
            Raz [M:ALP]WRH
         Endif
         #DLUBPC
         [M:ALP]BPRNUM   = [M:SIH1]BPCORD
         Raz WRET
         Call ALLSTOSORW("SIH4",[M:SIH4]NBLIG,[M:SIH4]NBLIG,WRUP,1,1,WRET)
&                        From STKSOR
         If WRET<>0
            Raz WQTYSTU,WQTY
            OK=0 : Return
         Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            Raz WQTYSTU,WQTY
            # Issue 121079
            #OK=0 : GERR=1
            OK=0
            # End issue 121079
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(156,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            Call ERREUR(GMESSAGE) From GESECRAN
            Return
         Else
            WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            If [F:SOP]SAUSTUCOE=0 [F:SOP]SAUSTUCOE=1 Endif
            WQTY    = WQTYSTU/[F:SOP]SAUSTUCOE
            Call QTEARR(WQTY,[F:SOP]SAU) From TRTDIV
         Endif

      # Sinon si détermination automatique du stock
      # allocation globale ou (allocation détaillée et qté allouée+rupture=0)
      Elsif GSLTSTKFLG=2
         # Chargement STOSORW par éxécution de l'algorithme
         [M:ALP]TRSTYP    = 4
         [M:ALP]TRSCOD    = [M:SIH0]TRSCOD
         [M:ALP]VCRTYP    = 5
#         [M:ALP]STOFCY    = [M:SIH1]STOFCY
         [M:ALP]STOFCY    = [F:SOQ]STOFCY
         [M:ALP]ITMREF    = [F:SOQ]ITMREF
         # --------------------------------------
         # FGR 21/04/2015 : X3SUIVI105605 (début)
         If dim([M:ALP]ECCVALMAJ) >= 0 Then
          [M:ALP]ECCVALMAJ = [F:SOQ]ECCVALMAJ
         Endif
         # FGR 21/04/2015 : X3SUIVI105605 (fin)
         # --------------------------------------
         [M:ALP]QTY       = WQTYSTU
         [M:ALP]TYPQTY    = 2
         [M:ALP]PCU       = [F:SOP]SAU
         [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
         [M:ALP]BESDAT    = [M:SIH0]INVDAT
         [M:ALP]DLVDAT    = [M:SIH0]INVDAT
         [M:ALP]ALLDAT    = [0/0/0]
         [M:ALP]STOLOC    = ""
         [M:ALP]PECINTLOC  = 2
         [M:ALP]PECSCOLOC = 1
         [M:ALP]PECPLFLOC = 2
         [M:ALP]PECCUNLOK = 1
         [M:ALP]FILSTO    = ""
         [M:ALP]LOT       = [F:SOQ]LOT
         [M:ALP]LOC       = [F:SOQ]LOC
         [M:ALP]STA       = [F:SOQ]STA
         If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SIH1]WRHE)>0
            [M:ALP]WRH = [M:SIH1]WRHE
         Else
            Raz [M:ALP]WRH
         Endif
         Raz [M:ALP]ALLQTY
         # Si allocation globale, on passe la qté déjà alloée en global
         If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ]ALLQTYSTU Endif
         Raz WRET
         Call GENSTOSORW("SIH4",[M:SIH4]NBLIG,[M:SIH4]NBLIG,WRUP,"C",WRET)
&             From STKSOR
         If WRET<>0
            Raz WQTYSTU,WQTY
            OK=0 : Return
         Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            Raz WQTYSTU,WQTY
            # Issue 121079
            #OK=0 : GERR=1
            OK=0
            # End issue 121079
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            Call ERREUR(GMESSAGE) From GESECRAN
            Return
         Else
            WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            If [F:SOP]SAUSTUCOE=0 [F:SOP]SAUSTUCOE=1 Endif
            WQTY    = WQTYSTU/[F:SOP]SAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,[F:SOP]SAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
               # Si la qté a été réajustée, il faut diminuer STOSORW en conséquence
               If WQTYSTU < [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
                  WQTA = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT-WQTYSTU
                  Call DIM_STOSORW([M:SIH4]NBLIG,"SIH4",[F:SOQ]STOFCY,WQTA,WRET) From STKSOR
               Endif
            Endif

         Endif
      # Sinon pas de détermination automatique du stock et
      # stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
      # allocation globale ou
      # allocation détaillée et qté allouée=0 ou qté rupture non livrable
      # --> calcul du stock disponible
      #Elsif WNEGSTO<>2 | (WNEGSTO=2 & GSHTDLV<>2)
      Elsif (WNEGSTO<>2 & GSHTDLV<>3) | (WNEGSTO=2 & GSHTDLV<2)
         # Lecture cumuls article
#         Read [ITV]ITV0=[F:ITM]ITMREF;[M:SIH1]STOFCY
         Read [ITV]ITV0=[F:ITM]ITMREF;[F:SOQ]STOFCY
         If fstat Raz [F:ITV] Endif
         # Lecture de la règle de gestion à utiliser
         Call LECSRU([F:SOQ]STOFCY,[F:ITM]TCLCOD,4,[M:SIH0]TRSCOD,"",WRET)
&             From STKLIB
         If WRET<>0 OK=0 : Return Endif
         # Statuts autorisés par la règle de gestion
         If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
         If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
         If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
         WSTA = WA+2*WQ+4*WR
         # Calcul stock disponible
         Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
         # On rajoute l'allouée global
         If [F:SOQ]ALLTYP=1 WSTUDIS+=[F:SOQ]ALLQTYSTU Endif

         # Pas de disponible --> rien à livrer
         If WSTUDIS = 0 | (find([F:SOH]DME,2,3) & WSTUDIS < WQTYSTU)
            # Issue 121079
            #OK=0 : GERR=1
            OK=0
            # End issue 121079
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
            Call ERREUR(GMESSAGE) From GESECRAN
            Raz WQTYSTU,WQTY
            Return
            # Disponible < qte à livrer ---> qte à livrer = disponible
         Elsif WSTUDIS < WQTYSTU
            WQTYSTU = WSTUDIS
            WQTY    = WQTYSTU/WSAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,WSAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
            Endif

         Endif
      Endif
   Endif
Endif

# Si composé d'un kit/sous-traité
If find([F:SOP]LINTYP,2,10)
   WQTYCPE    = WQTY
   WQTYSTUCPE = WQTYSTU

   # Détermination de la quantité livrable du composant
   OK=1
   Gosub STODETKIT
   If OK=0
      Raz WQTY,WQTYSTU,WQTYCPE,WQTYSTUCPE : Return
   Endif

   WQTY    = WQTYCPE
   WQTYSTU = WQTYSTUCPE

   #---------------------------------------------
   # TS : réajustement qté en unité vente entière
   #---------------------------------------------
   Gosub REAJUSTE_QTY

   # Repositionnement sur l'article composé
   If [F:ITM]ITMREF <> [F:SOQ]ITMREF
      Read [ITM]ITM0=[F:SOQ]ITMREF
      If fstat
         Raz [F:ITM] : OK=0 : Return
      Endif
   Endif

Endif

$TRT_LIGCDE_SUI
#--- La sélection est correcte
#If [M:SIH4]NBLIG > 0
#   Local Integer NBPOSTE, WNEWCDE : NBPOSTE=
#   WNEWCDE = find([F:SOH]SOHNUM,[M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1))
#   # Nouvelle commande pour cette facture
#   # Alimentation des elements de facturation
#   If !WNEWCDE
#      # Call SAISFOOT2(7,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SOH]CUR,[M:SIH2]CUR,
## &                   "NON") From TRTVENELT
#    Endif
# Endif

Gosub SOH_SIH_PLUS From SUBSFIT
#If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  Raz OK
  Call ERREUR(GMESSAGE) From GESECRAN
  Return
Endif

# Sauvegarde du lien entre ligne document et écran travail
[L]WSTOSEQ = [M:SIH4]WSTOSEQ([M:SIH4]NBLIG)
# Ouverture de la ligne
nolign = [M:SIH4]NBLIG
Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
[M:SIH4]NBLIG += 1
nolign = [M:SIH4]NBLIG
NOL = nolign-1
status = 0

# Alimentation de la classe [M:SIH4] de la ligne
Call ALISOQSIH(NOL,WQTY,WQTYSTU) From TRTVENFAC

# Récupération du lien entre ligne document et écran travail
[M:SIH4]WSTOSEQ(NOL) = [L]WSTOSEQ

Call LINNUM("SIDLIN") From TABLEAUX

# Calculs prix net, marge et maj montants livrés et poids
GNETMAR=0
Call ALICLCAMT([M:SIH4]ITMREF(NOL),[M:SIH4]QTY(NOL),NOL,"SIH4",
&              [M:SIH4]CLCAMT1(NOL),[M:SIH4]CLCAMT2(NOL)) From TRTX3
# Bug 59754: Pas de calcul prix net : Il faut garder le prix net de la cde
# (Si frais/remise dépendant de la qté (par ligne) et plusieurs fac.,le prix net doit être le même sur chaque fac.)
#Call CLCNETPRI([M:SIH4]QTY(NOL),[M:SIH2]CUR,NOL) From TRTVENPRI
Call CLCPFM   ([M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,
&              [M:SIH0]INVDAT,[M:SIH2]CUR,NOL,1) From TRTVENPRI
Call APRES_LIGNE(NOL,0) From SUBSIHB
GNETMAR=1

Raz GOUVSOR
# La ligne de facture est-elle complète du point de vue stock
If [M]STOMGTCOD(NOL)<>1 & [M:SIH0]INVTYP=1
   # Si stock à sortir non encore déterminé, init emplacement par défaut
   If dim([M:SIH4]LOC) & [M:SIH4]WSTOSEQ(NOL)=0
      Call STKINIEMPS([M:SIH4]LOC(NOL)) From STKLOC
   Endif
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBSIH
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("SIH4",NOL,[M:SIH4]NBLIG,[M:SIH4]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&       From STKSOR
   If WRET=1 Endif
Endif

nolign  = NOL+1
# Sauvegarde qté cde et qté à livrer du composé
WQTYCPE    = [F:SOQ]QTY
WALLQTYCPE = WQTY

# Si composé de kit/sous-traité
If find([M:SIH4]LINTYP(NOL),2,10) & [M:SIH0]INVTYP=1
   If !clalev([F:SOP1]) Local File SORDERP [SOP1] Endif
   Filter [SOP1] Where SOHNUM=[F:SOP]SOHNUM & SOPSEQ>[F:SOP]SOPSEQ
   For [SOP1]
      If find([F:SOP1]LINTYP,3,4,5,11,12,13)
         Read [SOQ]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
         If fstat
            Call RSTA ("SOQ",[F:SOP1]SOHNUM+num$([F:SOP1]SOPLIN)) From GLOCK
            Goto SEL_SUI
         Endif
         [F:SOP] = [F:SOP1]
         # Lecture des tables articles
         Gosub LEC_TABART
         # Contrôle de l'insertion
         If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
            Raz OK : GERR=1 : GMESSAGE=mess(122,199,1)
            Call ERREUR(GMESSAGE) From GESECRAN
            Break
         Endif
         # Sauvegarde du lien entre ligne document et écran travail
         [L]WSTOSEQ = [M:SIH4]WSTOSEQ([M:SIH4]NBLIG)
         # Ouverture de la ligne
         Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
         [M:SIH4]NBLIG += 1
         nolign = [M:SIH4]NBLIG
         NOL = nolign-1
         status = 0
         # Calcul de la quantité livrée du composant
         WQTY    = (WALLQTYCPE * [F:SOQ]QTY) / WQTYCPE
         WQTYSTU = WQTY*[F:SOQ]QTYSTU/[F:SOQ]QTY
         # Alimentation de la classe [M:SIH4] de la ligne
         Call ALISOQSIH(NOL,WQTY,WQTYSTU) From TRTVENFAC
         # Récupération du lien entre ligne document et écran travail
         [M:SIH4]WSTOSEQ(NOL) = [L]WSTOSEQ

         Call LINNUM("SIDLIN") From TABLEAUX
         # Calculs prix net, marge et maj montants livrés et poids
         GNETMAR=0
         Call ALICLCAMT([M:SIH4]ITMREF(NOL),[M:SIH4]QTY(NOL),NOL,"SIH4",
&                       [M:SIH4]CLCAMT1(NOL),[M:SIH4]CLCAMT2(NOL)) From TRTX3
         # Bug 59754: Pas de calcul prix net : Il faut garder le prix net de la cde
         # (Si frais/remise dépendant de la qté (par ligne) et plusieurs fac.,le prix net doit être le même sur chaque fac.)
         #Call CLCNETPRI([M:SIH4]QTY(NOL),[M:SIH2]CUR,NOL) From TRTVENPRI
         Call CLCPFM   ([M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,
&                       [M:SIH0]INVDAT,[M:SIH2]CUR,NOL,1) From TRTVENPRI
         Call APRES_LIGNE(NOL,0) From SUBSIHB
         GNETMAR=1

         Raz GOUVSOR
         #--- Bug 23899 : TS le 23.08.04
         # La ligne de facture est-elle complète du point de vue stock
         If [M]STOMGTCOD(NOL)<>1
            # Alimentation de [M:ALP]
            Gosub ALI_ALP From SUBSIH
            # Détermination du stock à sortir (automatisme, saisie)
            Call OUVSOR("SIH4",NOL,[M:SIH4]NBLIG,[M:SIH4]WSTOSEQ(NOL),GSLTSTKFLG,WRET) From STKSOR
            If WRET=1 Endif
         Endif
         Raz GOUVSOR
         #---

         nolign = NOL+1
      Else
         Break
      Endif
   $SEL_SUI
   Next
   Filter [SOP1]
   Close Local File [SOP1]
Endif

Return
###########################################################################
# STODETKIT : Détermination de la quantité à livrer d'un kit              #
#             à partir des quantités livrables des composants             #
###########################################################################
$STODETKIT

# 71065 : PJT
# This code was moved to SUBSIHC1 due to this program's size limitations

Gosub STODETKIT From SUBSIHC1
# 71065 : PJT

Return

###########################################################################
# Recherche de la quantité livrable du composant                          #
###########################################################################
$RECH_QTEDIS

Raz WDISCPS,WDISSTUCPS
Raz WQTY, WQTYSTU

Raz WRUP

# Détermination de la qté à livrer du composant

# Si qté allouée
If [F:SOQ1]ALLQTY<>0
   WQTY    = [F:SOQ1]ALLQTY
   WQTYSTU = [F:SOQ1]ALLQTYSTU
   # Si qté rupture, stock négatif autorisé et livraison des ruptures
   #If [F:SOQ1]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2
   If [F:SOQ1]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)
      WQTY    += [F:SOQ1]SHTQTY
      WQTYSTU += [F:SOQ1]SHTQTYSTU
      WRUP  = 1
   Endif
# Sinon si qté rupture
Elsif [F:SOQ1]SHTQTY<>0
   # Si stock négatif autorisé et livraison des ruptures
   #If WNEGSTO=2 & GSHTDLV=2
   If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
      WQTY    = [F:SOQ1]SHTQTY
      WQTYSTU = [F:SOQ1]SHTQTYSTU
      WRUP = 1
   # Sinon question 'voulez-vous livrer la rupture?'
   Else
      WOK=2
      Call AVERTIR([F:SOQ1]ITMREF-":"-mess(230,192,1),WOK) From GESECRAN
      If WOK=1
         OK=0 : Return
      Else
         WQTY    = [F:SOQ1]SHTQTY
         WQTYSTU = [F:SOQ1]SHTQTYSTU
         WRUP = 1
      Endif
   Endif
Endif

# Si pas de qte allouée/rupture ou si qte allouée/rupture > qté à livrer
# on conserve la quantité à livrer
# sinon la quantité à livrer devient la qte allouée/rupture
If WQTYSTU=0 | WQTYSTU>WQTYSTUCPS
   WQTY    = WQTYCPS
   WQTYSTU = WQTYSTUCPS
Endif

# Si allocation détaillée et qté allouée+rupture<>0
If [F:SOQ1]ALLTYP=2 & ([F:SOQ1]ALLQTY<>0 | [F:SOQ1]SHTQTY<>0)
   # Chargement STOSORW à partir des allocations
   [M:ALP]TRSTYP    = 4
   [M:ALP]TRSCOD    = [M:SIH0]TRSCOD
   [M:ALP]VCRTYP    = 2
   [M:ALP]VCRNUM    = [F:SOQ1]SOHNUM
   [M:ALP]VCRLIN    = [F:SOQ1]SOPLIN
   [M:ALP]VCRSEQ    = [F:SOQ1]SOQSEQ
#   [M:ALP]STOFCY    = [M:SIH1]STOFCY
   [M:ALP]STOFCY    = [F:SOQ1]STOFCY
   [M:ALP]ITMREF    = [F:SOQ1]ITMREF
   # --------------------------------------
   # FGR 21/04/2015 : X3SUIVI105605 (début)
   If func AFNC.ACTIV("ECC") Then
     [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
   Endif
   # FGR 21/04/2015 : X3SUIVI105605 (fin)
   # --------------------------------------
   [M:ALP]QTY       = WQTYSTU
   [M:ALP]TYPQTY    = 2
   [M:ALP]STA       = [F:SOQ1]STA
   [M:ALP]PECSCOLOC = 1
   [M:ALP]BESDAT    = [M:SIH0]INVDAT
   [M:ALP]DLVDAT    = [M:SIH0]INVDAT
   If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SIH1]WRHE)>0
      [M:ALP]WRH = [M:SIH1]WRHE
   Else
      Raz [M:ALP]WRH
   Endif
   #DLUBPC
   [M:ALP]BPRNUM    = [M:SIH1]BPCORD
   Raz WRET
   Call ALLSTOSORW("SIH4",WINDICE,[M:SIH4]NBLIG,WRUP,0,1,WRET) From STKSOR
   If WRET<>0
      OK=0 : Return
   Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
      # Issue 121079
      #OK=0 : GERR=1
      OK=0
      # End issue 121079
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ1]SHIDAT)+"\"+mess(156,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   Else
      WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
      If [F:SOP1]SAUSTUCOE=0 [F:SOP1]SAUSTUCOE=1 Endif
      WQTY    = WQTYSTU/[F:SOP1]SAUSTUCOE
      Call QTEARR(WQTY,[F:SOP1]SAU) From TRTDIV
   Endif

# Sinon si détermination automatique du stock
# allocation globale ou (allocation détaillée et qté allouée+rupture=0)
Elsif GSLTSTKFLG=2
   # Chargement STOSORW par éxécution de l'algorithme
   [M:ALP]TRSTYP    = 4
   [M:ALP]TRSCOD    = [M:SIH0]TRSCOD
   [M:ALP]VCRTYP    = 4
#   [M:ALP]STOFCY    = [M:SIH1]STOFCY
   [M:ALP]STOFCY    = [F:SOQ]STOFCY
   [M:ALP]ITMREF    = [F:SOQ1]ITMREF
   # --------------------------------------
   # FGR 21/04/2015 : X3SUIVI105605 (début)
   If func AFNC.ACTIV("ECC") Then
     [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
   Endif
   # FGR 21/04/2015 : X3SUIVI105605 (fin)
   # --------------------------------------
   [M:ALP]QTY       = WQTYSTU
   [M:ALP]TYPQTY    = 2
   [M:ALP]PCU       = [F:SOP1]SAU
   [M:ALP]PCUSTUCOE = [F:SOP1]SAUSTUCOE
   [M:ALP]BESDAT    = [M:SIH0]INVDAT
   [M:ALP]DLVDAT    = [M:SIH0]INVDAT
   [M:ALP]ALLDAT    = [0/0/0]
   [M:ALP]STOLOC    = ""
   [M:ALP]PECINTLOC = 2
   [M:ALP]PECSCOLOC = 1
   [M:ALP]PECPLFLOC = 2
   [M:ALP]PECCUNLOK = 1
   [M:ALP]FILSTO    = ""
   [M:ALP]LOT       = [F:SOQ1]LOT
   [M:ALP]LOC       = [F:SOQ1]LOC
   [M:ALP]STA       = [F:SOQ1]STA
   Raz [M:ALP]ALLQTY
   If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SIH1]WRHE)>0
      [M:ALP]WRH = [M:SIH1]WRHE
   Else
      Raz [M:ALP]WRH
   Endif
   # Si allocation globale, on passe la qté déjà alloée en global
   If [F:SOQ1]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ1]ALLQTYSTU Endif
   Raz WRET
   Call GENSTOSORW("SIH4",WINDICE,[M:SIH4]NBLIG,WRUP,"C",WRET) From STKSOR
   If WRET<>0
      OK=0 : Return
   Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
      # Issue 121079
      #OK=0 : GERR=1
      OK=0
      # End issue 121079
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   Else
      WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
      If [F:SOP1]SAUSTUCOE=0 [F:SOP1]SAUSTUCOE=1 Endif
      WQTY    = WQTYSTU/[F:SOP1]SAUSTUCOE
      Call QTEARR(WQTY,[F:SOP1]SAU) From TRTDIV
   Endif

# Sinon pas de détermination automatique du stock et qté allouée+rupture=0
# --> calcul du stock disponible
Elsif [F:SOQ1]ALLQTY+[F:SOQ1]SHTQTY=0
   # Lecture cumuls article
#   Read [ITV]ITV0=[F:ITM]ITMREF;[M:SIH1]STOFCY
   Read [ITV]ITV0=[F:ITM]ITMREF;[F:SOQ1]STOFCY
   If fstat Raz [F:ITV] Endif
   # Lecture de la règle de gestion à utiliser
   Call LECSRU([F:SOQ1]STOFCY,[F:ITM]TCLCOD,4,[M:SIH0]TRSCOD,"",WRET) From STKLIB
   If WRET<>0
      OK=0 : Return
   Endif
   # Statuts autorisés par la règle de gestion
   If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
   If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
   If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
   WSTA = WA+2*WQ+4*WR
   # Calcul stock disponible
   Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
   # On rajoute l'allouée global
   If [F:SOQ1]ALLTYP=1 WSTUDIS+=[F:SOQ1]ALLQTYSTU Endif

   # Pas de disponible --> rien à livrer
   If WSTUDIS = 0 | (find([F:SOH]DME,2,3) & WSTUDIS < WQTYSTU)
      # Issue 121079
      #OK=0 : GERR=1
      OK=0
      # End issue 121079
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ1]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   # Disponible < qte à livrer ---> qte à livrer = disponible
   Elsif WSTUDIS < WQTYSTU
      WQTY    = (WQTY*WSTUDIS)/WQTYSTU
      WQTYSTU = WSTUDIS
   Endif
Endif

WDISSTUCPS = WQTYSTU
WDISCPS    = WQTY

Return

########################################################################
$AB_TRT
Rollback
Return

#########################################################################
$SEL3
#-----------------------------------------------------------------------#
# Sélection d'une demande se service à facturer                         #
#-----------------------------------------------------------------------#
Local Char SWPJTMSG(250)  # FGR 20/12/2011 : X3SUIVI71065

# 98833 : Vérification de l'existance de l'écran WSIH4INV utilisé par GENSIH
#Gosub CHECK_INVCNO_MSK            X3-23080
#If OK = 0 GERR=1 : Return Endif   X3-23080
# 98833

#----- On ne peut "picker" qu'une seule demande par facture
If [M:SIH4]NBLIG>0
  GMESSAGE=mess(269,192,1) : OK=0 : Return
Endif
#--- Lecture de la table [SRE]
Read [SRE]SRE0=[F:SRE]SRENUM
If fstat
   Call RSTA ("SRE",[F:SRE]SRENUM) From GLOCK : OK=0 : Return
Endif

If [M:SIH0]SALFCY=""
   #Call GETDEV(GFCY) From DEVSUB
   If GFCY<>[F:SRE]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SRE]SALFCY : Gosub CHARG_PARAM From SUBSIHA
       If GERR=1 OK=0 : Return Endif
   Endif
   # Alimentation des champs liés au type de facture
   # --> Alimentation catégorie facture, type pièce, code journal
   # --> Alimentation infos compteur
   # --> Si type pièce renseigné : Contrôle et récup infos compteur
   Local Char WSIVTYP(GLONTSV)
   Gosub INIT_SIVTYP From SUBSIHB
   If GERR=1 OK=0 : Return Endif
   [M:SIH0]SIVTYP=WSIVTYP
   # Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
   # Récupération du paramètre TC
   Local Char PARAM(GLONADP)
   Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
   GSIVSUP = val(PARAM)
Endif

# FGR 28/11/2011 : X3SUIVI71065 (début)
If [M:SIH4]NBLIG > 0 Then
  If func TRTPJT.IS_PJT_AVAILABLE([F:SRE]SREPJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG([F:SRE]SREPJT, SWPJTMSG) From TRTPJT
    OK = 0
    GERR = 1
    Return
  Endif
Else
  If func TRTPJT.IS_PJT_AVAILABLE([F:SRE]SREPJT, "[M:SIH1]PJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG([F:SRE]SREPJT, SWPJTMSG) From TRTPJT
    OK = 0
    GERR = 1
    Return
  Endif
Endif
# FGR 28/11/2011 : X3SUIVI71065 (fin)

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SIH4]NBLIG>0 & [F:SRE]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SRE]SSTENTCOD<>[M:SIH1]SSTENTCOD   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SRE]SRENUM, [F:SRE]SSTENTCOD)
  Return
Endif
# LTA.en 79065

#----- Blocage logique de la demande
SYMBOLE2="SRE"+[F:SRE]SRENUM : Lock=SYMBOLE2
If fstat
  GMESSAGE="$SERREQUEST"-[F:SRE]SRENUM-mess(10,100,1)
  OK=0 : Return
Endif

#-- pour appel GENSIH
Local Integer LCOD   : LCOD=2
Local Char    LMAJ   : LMAJ="C"
Local Integer LECH   : LECH=2
Local Integer LTEST  : LTEST=1           : # pas de trace
Local Char    LTRT   : LTRT="TRTSIHSRE"
Local Char    LORINUM
Local Char    LSIVNUM
Local Integer LERR   : LERR=0

#Appel du composant de création facture.
Filter [HDI] Where [F:HDI]SRENUM = [F:SRE]SRENUM

Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG

Filter [HDI]

If LERR>0 : OK=0 : Raz [M:SIH4] : Affzo [M:SIH4] : Return : Endif

 # LTA.sn 79065
 # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
 If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
   [M:SIH1]SSTENTCOD = [F:SRE]SSTENTCOD
 Endif
 # LTA.en 7906

Diszo [M:SIH1]STOMVTFLG
Diszo [M:SIH1]STOFCY

Return

# FGR 22/12/2014 : X3SUIVI104963 : Vérification de l'existance de l'écran WSIH4INV utilisé par GENSIH
#                                  Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
