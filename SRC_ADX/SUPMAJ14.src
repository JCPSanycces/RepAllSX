## Mise à jour zone PFINUMCAR dans PFOOTINV
#########################################################################################

Subprog PFOOTINV

If filinfo(filpath("FIL","PFOOTINV","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PFOOTINV"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]

Trbegin [PFI]
 For [PFI]
  [F:PFI]PFINUMCAR = num$([F:PFI]PFINUM)
  Rewrite [PFI]
  If fstat
   Call ERREUR("PFOOTINV"-[F:PFI]PFINUMCAR,1) From DOSDIC
  Endif
 Next
Commit

End

#########################################################################################
## Mise à jour zone BPCBPSCAR dans PRICSTRUCT
#########################################################################################

Subprog PRICSTRUCT

If filinfo(filpath("FIL","PRICSTRUCT","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PRICSTRUCT"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PRICSTRUCT"   [PRS]

Trbegin [PRS]
 For [PRS]
  [F:PRS]BPCBPSCAR = num$([F:PRS]BPCBPS)
  Rewrite [PRS]
  If fstat
   Call ERREUR("PRICSTRUCT"-[F:PRS]BPCBPSCAR,1) From DOSDIC
  Endif
 Next
Commit

End

#########################################################################################
# Mise à jour zones FLDTYP FLDTYPCPL dans SPRICCONF (Codes statistiques)
#########################################################################################

Subprog SPRICCONF

If filinfo(filpath("FIL","SPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": SPRICCONF"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".SPRICCONF"   [SPC]

Local Integer IJL, IMOD
Trbegin [SPC]
 For [SPC]
   Raz IMOD
   For IJL=0 To dim([F:SPC]ABB)-1 
     If find([F:SPC]FLDTYP(IJL),"STI","STC","STS")
       [F:SPC]FLDTYP(IJL)="ADI" : IMOD=1
       Case [F:SPC]FLD(IJL) 
         When "TSICOD"  : [F:SPC]FLDTYPCPL(IJL)=num$([F:SPC]CRIIND(IJL)+20)
         When "TSICOD1" : [F:SPC]FLDTYPCPL(IJL)="20"           
         When "TSICOD2" : [F:SPC]FLDTYPCPL(IJL)="21"
         When "TSICOD3" : [F:SPC]FLDTYPCPL(IJL)="22"
         When "TSICOD4" : [F:SPC]FLDTYPCPL(IJL)="23"
         When "TSICOD5" : [F:SPC]FLDTYPCPL(IJL)="24"
         When "TSCCOD"  : [F:SPC]FLDTYPCPL(IJL)=num$([F:SPC]CRIIND(IJL)+30)
         When "TSCCOD1" : [F:SPC]FLDTYPCPL(IJL)="30"           
         When "TSCCOD2" : [F:SPC]FLDTYPCPL(IJL)="31"
         When "TSCCOD3" : [F:SPC]FLDTYPCPL(IJL)="32"
         When "TSCCOD4" : [F:SPC]FLDTYPCPL(IJL)="33"
         When "TSCCOD5" : [F:SPC]FLDTYPCPL(IJL)="34"
         When "TSSCOD"  : [F:SPC]FLDTYPCPL(IJL)=num$([F:SPC]CRIIND(IJL)+40)
         When "TSSCOD1" : [F:SPC]FLDTYPCPL(IJL)="40"           
         When "TSSCOD2" : [F:SPC]FLDTYPCPL(IJL)="41"
         When "TSSCOD3" : [F:SPC]FLDTYPCPL(IJL)="42"
         When "TSSCOD4" : [F:SPC]FLDTYPCPL(IJL)="43"
         When "TSSCOD5" : [F:SPC]FLDTYPCPL(IJL)="44"
       Endcase
     Endif
   Next IJL
   If IMOD
     Rewrite [SPC]
     If fstat
       Call ERREUR("SPRICCONF"-[F:SPC]PLI,1) From DOSDIC
     Endif
   Endif
 Next
Commit
End

#########################################################################################
# Mise à jour zones FLDTYP FLDTYPCPL dans PPRICCONF (Codes statistiques)
#########################################################################################

Subprog PPRICCONF

If filinfo(filpath("FIL","PPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PPRICCONF"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PPRICCONF"   [PPC]

Local Integer IJL, IMOD
Trbegin [PPC]
 For [PPC]
   Raz IMOD
   For IJL=0 To dim([F:PPC]ABB)-1 
     If find([F:PPC]FLDTYP(IJL),"STI","STC","STS")
       [F:PPC]FLDTYP(IJL)="ADI" : IMOD=1
       Case [F:PPC]FLD(IJL) 
         When "TSICOD"  : [F:PPC]FLDTYPCPL(IJL)=num$([F:PPC]CRIIND(IJL)+20)
         When "TSICOD1" : [F:PPC]FLDTYPCPL(IJL)="20"           
         When "TSICOD2" : [F:PPC]FLDTYPCPL(IJL)="21"
         When "TSICOD3" : [F:PPC]FLDTYPCPL(IJL)="22"
         When "TSICOD4" : [F:PPC]FLDTYPCPL(IJL)="23"
         When "TSICOD5" : [F:PPC]FLDTYPCPL(IJL)="24"
         When "TSCCOD"  : [F:PPC]FLDTYPCPL(IJL)=num$([F:PPC]CRIIND(IJL)+30)
         When "TSCCOD1" : [F:PPC]FLDTYPCPL(IJL)="30"           
         When "TSCCOD2" : [F:PPC]FLDTYPCPL(IJL)="31"
         When "TSCCOD3" : [F:PPC]FLDTYPCPL(IJL)="32"
         When "TSCCOD4" : [F:PPC]FLDTYPCPL(IJL)="33"
         When "TSCCOD5" : [F:PPC]FLDTYPCPL(IJL)="34"
         When "TSSCOD"  : [F:PPC]FLDTYPCPL(IJL)=num$([F:PPC]CRIIND(IJL)+40)
         When "TSSCOD1" : [F:PPC]FLDTYPCPL(IJL)="40"           
         When "TSSCOD2" : [F:PPC]FLDTYPCPL(IJL)="41"
         When "TSSCOD3" : [F:PPC]FLDTYPCPL(IJL)="42"
         When "TSSCOD4" : [F:PPC]FLDTYPCPL(IJL)="43"
         When "TSSCOD5" : [F:PPC]FLDTYPCPL(IJL)="44"
       Endcase
     Endif
   Next IJL
   If IMOD
     Rewrite [PPC]
     If fstat
       Call ERREUR("PPRICCONF"-[F:PPC]PLI,1) From DOSDIC
     Endif
   Endif
 Next
Commit
End

#########################################################################################
## Transfert TABSTTITM dans ATABDIV   
## Creation des ATABTAB (Definition des tables diverses) 20, 21, 22, 23, 24 
#########################################################################################

Subprog TABSTTITM

If filinfo(filpath("FIL","TABSTTITM","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(4,505,1)-": TABSTTITM --> ATABDIV"-time$,0) From GESECRAN : # transfert

Local File =[F:ADS]DOSSIER+".TABSTTITM" [TSI], =[F:ADS]DOSSIER+".ATABDIV" [ADI]
Local File =[F:ADS]DOSSIER+".ATABTAB"   [ADV]

Trbegin [TSI]

Delete [ADI] Where find(NUMTAB,20,21,22,23,24) 
For [TSI]
    Raz [F:ADI]  
    Case [F:TSI]TSIGRP
         When 1       [F:ADI]NUMTAB =20  
         When 2       [F:ADI]NUMTAB =21  
         When 3       [F:ADI]NUMTAB =22  
         When 4       [F:ADI]NUMTAB =23  
         When 5       [F:ADI]NUMTAB =24  
         When Default [F:ADI]NUMBAB =20         
    Endcase
    [F:ADI]CODE   =[F:TSI]TSICOD 
    [F:ADI]DES    =[F:TSI]DESNUM : [F:ADI]DESSHO =[F:TSI]SHONUM
    [F:ADI]INTIT  =[F:TSI]TSIDES : [F:ADI]INTSHO =[F:TSI]TSISHO   
    [F:ADI]DEFVAL =1 
    [F:ADI]CREUSR =[F:TSI]CREUSR : [F:ADI]CREDAT =[F:TSI]CREDAT : [F:ADI]CRETIM =time
    [F:ADI]UPDUSR =[F:TSI]UPDUSR : [F:ADI]UPDDAT =[F:TSI]UPDDAT : [F:ADI]UPDTIM =time
    Write [ADI]
    If fstat
       Call ERREUR("ATABDIV"-num$([F:ADI]NUMTAB)-"/"-[F:ADI]CODE,1) From DOSDIC
    Endif
Next

For IJN=20 To 24
    Delete [ADV] Where NUMTAB=IJN
    Raz [ADV]
    [F:ADV]NUMTAB=IJN   : [F:ADV]NUMCAR=num$(IJN) : [F:ADV]MODULE=9
    [F:ADV]UPDFLG=2     : [F:ADV]LNGFLG=1         : [F:ADV]LNG=3
    [F:ADV]CREUSR=GUSER : [F:ADV]CREDAT=date$     : [F:ADV]CRETIM=time

    If IJN=21 : [F:ADV]DEPNUM=20 : Endif
    If IJN=22 : [F:ADV]DEPNUM=21 : Endif
    If IJN=23 : [F:ADV]DEPNUM=22 : Endif
    If IJN=24 : [F:ADV]DEPNUM=23 : Endif

    Write [ADV]
    If fstat
       Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),1) From DOSDIC
    Endif
Next IJN

Commit

End



#########################################################################################
## Transfert TABSTTBPC dans ATABDIV  
## Creation des ATABTAB (Definition des tables diverses) 30, 31, 32, 33, 34 
#########################################################################################

Subprog TABSTTBPC

If filinfo(filpath("FIL","TABSTTBPC","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(4,505,1)-": TABSTTBPC --> ATABDIV"-time$,0) From GESECRAN : # transfert

Local File =[F:ADS]DOSSIER+".TABSTTBPC" [TSC], =[F:ADS]DOSSIER+".ATABDIV" [ADI]  
