    Case [F:TSC]TSCGRP
         When 1       [F:ADI]NUMTAB =30  
         When 2       [F:ADI]NUMTAB =31  
         When 3       [F:ADI]NUMTAB =32  
         When 4       [F:ADI]NUMTAB =33  
         When 5       [F:ADI]NUMTAB =34  
         When Default [F:ADI]NUMBAB =30         
    Endcase
    [F:ADI]CODE   =[F:TSC]TSCCOD 
    [F:ADI]DES    =[F:TSC]DESNUM : [F:ADI]DESSHO =[F:TSC]SHONUM
    [F:ADI]INTIT  =[F:TSC]TSCDES : [F:ADI]INTSHO =[F:TSC]TSCSHO   
    [F:ADI]DEFVAL =1 
    [F:ADI]CREUSR =[F:TSC]CREUSR : [F:ADI]CREDAT =[F:TSC]CREDAT : [F:ADI]CRETIM =time
    [F:ADI]UPDUSR =[F:TSC]UPDUSR : [F:ADI]UPDDAT =[F:TSC]UPDDAT : [F:ADI]UPDTIM =time
    Write [ADI]
    If fstat
       Call ERREUR("ATABDIV"-num$([F:ADI]NUMTAB)-"/"-[F:ADI]CODE,1) From DOSDIC
    Endif
Next

For IJN=30 To 34
    Delete [ADV] Where NUMTAB=IJN
    Raz [ADV]
    [F:ADV]NUMTAB=IJN   : [F:ADV]NUMCAR=num$(IJN) : [F:ADV]MODULE=9
    [F:ADV]UPDFLG=2     : [F:ADV]LNGFLG=1         : [F:ADV]LNG=3
    [F:ADV]CREUSR=GUSER : [F:ADV]CREDAT=date$     : [F:ADV]CRETIM=time

    If IJN=31 : [F:ADV]DEPNUM=30 : Endif
    If IJN=32 : [F:ADV]DEPNUM=31 : Endif
    If IJN=33 : [F:ADV]DEPNUM=32 : Endif
    If IJN=34 : [F:ADV]DEPNUM=33 : Endif

    Write [ADV]
    If fstat
       Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),1) From DOSDIC
    Endif
Next IJN

Commit

End

#########################################################################################
## Transfert TABSTTBPS dans ATABDIV 
## Creation des ATABTAB (Definition des tables diverses) 40, 41, 42, 43, 44 
#########################################################################################

Subprog TABSTTBPS

If filinfo(filpath("FIL","TABSTTBPS","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(4,505,1)-": TABSTTBPS --> ATABDIV"-time$,0) From GESECRAN : # transfert

Local File =[F:ADS]DOSSIER+".TABSTTBPS" [TSS], =[F:ADS]DOSSIER+".ATABDIV" [ADI]
Local File =[F:ADS]DOSSIER+".ATABTAB"   [ADV]

Trbegin [TSS]

Delete [ADI] Where find(NUMTAB,40,41,42,43,44) 
For [TSS]
    Raz [F:ADI]  
    Case [F:TSS]TSSGRP
         When 1       [F:ADI]NUMTAB =40  
         When 2       [F:ADI]NUMTAB =41  
         When 3       [F:ADI]NUMTAB =42  
         When 4       [F:ADI]NUMTAB =43  
         When 5       [F:ADI]NUMTAB =44  
         When Default [F:ADI]NUMBAB =40         
    Endcase
    [F:ADI]CODE   =[F:TSS]TSSCOD 
    [F:ADI]DES    =[F:TSS]DESNUM : [F:ADI]DESSHO =[F:TSS]SHONUM
    [F:ADI]INTIT  =[F:TSS]TSSDES : [F:ADI]INTSHO =[F:TSS]TSSSHO   
    [F:ADI]DEFVAL =1 
    [F:ADI]CREUSR =[F:TSS]CREUSR : [F:ADI]CREDAT =[F:TSS]CREDAT : [F:ADI]CRETIM =time
    [F:ADI]UPDUSR =[F:TSS]UPDUSR : [F:ADI]UPDDAT =[F:TSS]UPDDAT : [F:ADI]UPDTIM =time
    Write [ADI]
    If fstat
       Call ERREUR("ATABDIV"-num$([F:ADI]NUMTAB)-"/"-[F:ADI]CODE,1) From DOSDIC
    Endif
Next

For IJN=40 To 44
    Delete [ADV] Where NUMTAB=IJN
    Raz [ADV]
    [F:ADV]NUMTAB=IJN   : [F:ADV]NUMCAR=num$(IJN) : [F:ADV]MODULE=9
    [F:ADV]UPDFLG=2     : [F:ADV]LNGFLG=1         : [F:ADV]LNG=3
    [F:ADV]CREUSR=GUSER : [F:ADV]CREDAT=date$     : [F:ADV]CRETIM=time

    If IJN=41 : [F:ADV]DEPNUM=40 : Endif
    If IJN=42 : [F:ADV]DEPNUM=41 : Endif
    If IJN=43 : [F:ADV]DEPNUM=42 : Endif
    If IJN=44 : [F:ADV]DEPNUM=43 : Endif

    Write [ADV]
    If fstat
       Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),1) From DOSDIC
    Endif
Next IJN

Commit

End

#----------------------------------------------------------------------------------------
#  Création ATEXTRA de ATABTAB pour les tables diverses 20-->24  30-->34  40-->44 
#  Appelé par sous/prog ATEXTRA 
#----------------------------------------------------------------------------------------
$ATABTAB_STT

Local Integer IJN                    : # pour boucle des no table  
Local Integer IJL                    : # pour boucle des langues
Local Char T_CLE1   (2)  (0..15)
Local Char L_TEXTE  (80)
Local Char SAVGLANGUE  (5)           : # sauvegarde de GLANGUE 
Local Integer JNUM, JCHAPITRE

T_CLE1(0) ="20" : T_CLE1(1) ="21" : T_CLE1(2) ="22" : T_CLE1(3) ="23" : T_CLE1(4) ="24" 
T_CLE1(5) ="30" : T_CLE1(6) ="31" : T_CLE1(7) ="32" : T_CLE1(8) ="33" : T_CLE1(9) ="34" 
T_CLE1(10)="40" : T_CLE1(11)="41" : T_CLE1(12)="42" : T_CLE1(13)="43" : T_CLE1(14)="44" 

Local File =[F:ADS]DOSSIER+".APLSTD" [AST]

Trbegin [AXX]
For IJN=0 To dim(T_CLE1)-1
    If T_CLE1(IJN)<>"" 
       JNUM=val(mid$(T_CLE1(IJN),2,1))+1 
       If find(T_CLE1(IJN),"20","21","22","23","24") : JCHAPITRE=206 : Endif              
       If find(T_CLE1(IJN),"30","31","32","33","34") : JCHAPITRE=207 : Endif              
       If find(T_CLE1(IJN),"40","41","42","43","44") : JCHAPITRE=208 : Endif              
       For IJL=0 To dim([F:ADS]LAN)-1
           If [F:ADS]LAN(IJL)<>""
              SAVGLANGUE=GLANGUE
              GLANGUE=[F:ADS]LAN(IJL)
              Read [AST] CLE=JCHAPITRE;JNUM;GLANGUE 
              If !fstat : L_TEXTE = [F:AST]LANMES : Endif
              If L_TEXTE=""
                 Read [AST] CLE=200;4+val(mid$(T_CLE1(IJL),1,1));GLANGUE
                 If !fstat : L_TEXTE = [F:AST]LANMES : Endif
                 If L_TEXTE<>""
                    L_TEXTE +=" "+num$(val(mid$(T_CLE1(IJL),2,1))+1)
                 Endif 
              Endif

#              Call MAJTEXTRA(L_TEXTE,"ATABTAB","LNGDES",T_CLE1(IJN),"") From ATEXTRA

              Delete [AXX] Where CODFIC="ATABTAB" & ZONE="LNGDES" & LANGUE=GLANGUE & IDENT1=T_CLE1(IJN)
              Raz [F:AXX]
              [F:AXX]CODFIC = "ATABTAB"
              [F:AXX]ZONE   = "LNGDES"
              [F:AXX]LANGUE = GLANGUE
              [F:AXX]TEXTE  = L_TEXTE
              [F:AXX]IDENT1 = T_CLE1(IJN)
              [F:AXX]IDENT2 = ""
              If dim([F:AXX]CREDAT)>0 : [F:AXX]CREDAT = date$ : Endif
              If dim([F:AXX]CREUSR)>0 : [F:AXX]CREUSR = GUSER : Endif
              Write [AXX]
              If fstat
                 Call ERREUR("ATEXTRA"-[F:AXX]CODFIC-[F:AXX]ZONE-GLANGUE-[F:AXX]IDENT1,1) From DOSDIC
              Endif
              GLANGUE=SAVGLANGUE
           Endif
       Next IJL 
    Endif
Next IJN
Commit

Return

#########################################################################################
## Récupération de la table ATEXTRA pour les tables ATABDIV ATABTAB TABUNIT...
#########################################################################################

Subprog ATEXTRA

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".ATABDIV" [ADI], =[F:ADS]DOSSIER+".ATABTAB" [ADV]
&        , =[F:ADS]DOSSIER+".TABUNIT" [TUN]

Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX], =[F:ADS]DOSSIER+".TABLAN"  [TLA]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AX2] Order By Key CLE = LANGUE;NUMERO

# Tables diverses
Call ECR_TRACE("   -- ATABDIV step "-time$,0) From GESECRAN : # maj table

Trbegin [AXX]
 Delete [AXX] Where CODFIC="ATABDIV"
 For [ADI]
  If [F:ADI]DES<>0
   Call CRETEX("ATABDIV","LNGDES",[F:ADI]DES,num$([F:ADI]NUMTAB),[F:ADI]CODE)
  Endif 
  If [F:ADI]DESSHO<>0
   Call CRETEX("ATABDIV","SHODES",[F:ADI]DESSHO,num$([F:ADI]NUMTAB),[F:ADI]CODE)
  Endif
 Next
Commit

# Paramètrage tables diverses
Call ECR_TRACE("   -- ATABTAB step"-time$,0) From GESECRAN : # maj table


Trbegin [AXX]
 Delete [AXX] Where CODFIC="ATABTAB"
 For [ADV]
  If [F:ADV]DES<>0
   Call CRETEX("ATABTAB","LNGDES",[F:ADV]DES,num$([F:ADV]NUMTAB),"")
  Endif 
  If [F:ADV]DESSHO<>0
   Call CRETEX("ATABTAB","SHODES",[F:ADV]DESSHO,num$([F:ADV]NUMTAB),"")
  Endif
  If [F:ADV]DESALP1<>0
   Call CRETEX("ATABTAB","ALPDES1",[F:ADV]DESALP1,num$([F:ADV]NUMTAB),"")
  Endif 
  If [F:ADV]DESALP2<>0
   Call CRETEX("ATABTAB","ALPDES2",[F:ADV]DESALP2,num$([F:ADV]NUMTAB),"")
  Endif
  If [F:ADV]DESNUM1<>0
   Call CRETEX("ATABTAB","NUMDES1",[F:ADV]DESNUM1,num$([F:ADV]NUMTAB),"")
  Endif 
  If [F:ADV]DESNUM2<>0
   Call CRETEX("ATABTAB","NUMDES2",[F:ADV]DESNUM2,num$([F:ADV]NUMTAB),"")
  Endif
 Next
Commit

Gosub ATABTAB_STT

# Unités de mesure
Call ECR_TRACE("   -- TABUNIT step"-time$,0) From GESECRAN : # maj table

Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABUNIT"
 For [TUN]
  If [F:TUN]DESNUM<>0
   Call CRETEX("TABUNIT","DES",[F:TUN]DESNUM,[F:TUN]UOM,"")
  Endif 
  If [F:TUN]SHONUM<>0
   Call CRETEX("TABUNIT","DESSHO",[F:TUN]SHONUM,[F:TUN]UOM,"")
  Endif
 Next
Commit

# Elements facturation ventes
Call ECR_TRACE("   -- SFOOTINV step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","SFOOTINV","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]
 Trbegin [AXX]
  Delete [AXX] Where CODFIC="SFOOTINV"
  For [SFI]
   If [F:SFI]DES<>0
    Call CRETEX("SFOOTINV","DESAXX",[F:SFI]DES,num$([F:SFI]SFINUM),"")
   Endif 
   If [F:SFI]SHO<>0
    Call CRETEX("SFOOTINV","SHOAXX",[F:SFI]SHO,num$([F:SFI]SFINUM),"")
   Endif
  Next
 Commit
Endif

# Elements facturation achats
Call ECR_TRACE("   -- PFOOTINV step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","PFOOTINV","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
 Trbegin [AXX]
  Delete [AXX] Where CODFIC="PFOOTINV"
  For [PFI]
   If [F:PFI]DES<>0
    Call CRETEX("PFOOTINV","DESAXX",[F:PFI]DES,num$([F:PFI]PFINUM),"")
   Endif 
   If [F:PFI]SHO<>0
    Call CRETEX("PFOOTINV","SHOAXX",[F:PFI]SHO,num$([F:PFI]PFINUM),"")
   Endif
  Next
 Commit
Endif

# Structures tarifs achats/ventes
Call ECR_TRACE("   -- PRICSTRUCT step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","PRICSTRUCT","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".PRICSTRUCT"   [PRS]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="PRICSTRUCT" 
 For [PRS]
     For IJL=0 To dim([F:PRS]INCDCR)-1
         If [F:PRS]DES(IJL)<>0
            Call CRETEX("PRICSTRUCT","DESAXX("+num$(IJL)+")",
&                       [F:PRS]DES(IJL),num$([F:PRS]BPCBPS),[F:PRS]PLISTC)
         Endif 
         If [F:PRS]SHO(IJL)<>0
            Call CRETEX("PRICSTRUCT","SHOAXX("+num$(IJL)+")",
&                       [F:PRS]SHO(IJL),num$([F:PRS]BPCBPS),[F:PRS]PLISTC)
         Endif 
     Next IJL 
 Next
 Commit
Endif
# Table Emballages
Call ECR_TRACE("   -- TABPACKAGE step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABPACKAGE","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABPACKAGE"   [TPA]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABPACKAGE"
 For [TPA]
  If [F:TPA]DESNUM<>0
   Call CRETEX("TABPACKAGE","DESAXX",[F:TPA]DESNUM,[F:TPA]PCK,"")
  Endif 
  If [F:TPA]SHONUM<>0
   Call CRETEX("TABPACKAGE","SHOAXX",[F:TPA]SHONUM,[F:TPA]PCK,"")
  Endif
 Next
 Commit
Endif

# Table Modes de livraison
Call ECR_TRACE("   -- TABMODELIV step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABMODELIV","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABMODELIV"   [TMD]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABMODELIV"
 For [TMD]
  If [F:TMD]DESNUM<>0
   Call CRETEX("TABMODELIV","DESAXX",[F:TMD]DESNUM,[F:TMD]MDL,"")
  Endif 
  If [F:TMD]SHONUM<>0
   Call CRETEX("TABMODELIV","SHOAXX",[F:TMD]SHONUM,[F:TMD]MDL,"")
  Endif
 Next
 Commit
Endif

# Table Conditions de paiement
Call ECR_TRACE("   -- TABPAYTERM step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABPAYTERM","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABPAYTERM"   [TPT]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABPAYTERM"
 For [TPT]
  If [F:TPT]DESNUM<>0 & [F:TPT]PTELIN=1
   Call CRETEX("TABPAYTERM","DESAXX",[F:TPT]DESNUM,[F:TPT]PTE,"")
  Endif 
  If [F:TPT]SHONUM<>0 & [F:TPT]PTELIN=1 
   Call CRETEX("TABPAYTERM","SHOAXX",[F:TPT]SHONUM,[F:TPT]PTE,"")
  Endif
 Next
 Commit
Endif

# Table Statistiques clients
Call ECR_TRACE("   -- TABSTTBPC step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABSTTBPC","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABSTTBPC"   [TSC]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABSTTBPC"
 For [TSC]
  If [F:TSC]DESNUM<>0
   Call CRETEX("TABSTTBPC","DESAXX",[F:TSC]DESNUM,num$([F:TSC]TSCGRP),[F:TSC]TSCCOD)
  Endif 
  If [F:TSC]SHONUM<>0
   Call CRETEX("TABSTTBPC","SHOAXX",[F:TSC]SHONUM,num$([F:TSC]TSCGRP),[F:TSC]TSCCOD)
  Endif
 Next
 Commit
Endif

# Table Statistiques fournisseurs
Call ECR_TRACE("   -- TABSTTBPS step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABSTTBPS","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABSTTBPS"   [TSS]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABSTTBPS"
 For [TSS]
  If [F:TSS]DESNUM<>0
   Call CRETEX("TABSTTBPS","DESAXX",[F:TSS]DESNUM,num$([F:TSS]TSSGRP),[F:TSS]TSSCOD)
  Endif 
  If [F:TSS]SHONUM<>0
   Call CRETEX("TABSTTBPS","SHOAXX",[F:TSS]SHONUM,num$([F:TSS]TSSGRP),[F:TSS]TSSCOD)
  Endif
 Next
 Commit
Endif

# Table Statistiques articles
#
Call ECR_TRACE("   -- TABSTTITM step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","TABSTTITM","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TABSTTITM"   [TSI]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="TABSTTITM"
 For [TSI]
  If [F:TSI]DESNUM<>0
   Call CRETEX("TABSTTITM","DESAXX",[F:TSI]DESNUM,num$([F:TSI]TSIGRP),[F:TSI]TSICOD)
  Endif 
  If [F:TSI]SHONUM<>0
   Call CRETEX("TABSTTITM","SHOAXX",[F:TSI]SHONUM,num$([F:TSI]TSIGRP),[F:TSI]TSICOD)
  Endif
 Next
 Commit
Endif

# Table Articles (3 désignations traduisibles) elles sont aussi physiquement dans l'enregistrement
Call ECR_TRACE("   -- ITMMASTER step"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","ITMMASTER","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
 Trbegin [AXX]
 Delete [AXX] Where CODFIC="ITMMASTER"
 For [ITM]
  If [F:ITM]ITMNUM1<>0
   Call CRETEX("ITMMASTER","DES1AXX",[F:ITM]ITMNUM1,[F:ITM]ITMREF,"")
  Endif 
  If [F:ITM]ITMNUM2<>0
   Call CRETEX("ITMMASTER","DES2AXX",[F:ITM]ITMNUM2,[F:ITM]ITMREF,"")
  Endif 
  If [F:ITM]ITMNUM3<>0
   Call CRETEX("ITMMASTER","DES3AXX",[F:ITM]ITMNUM3,[F:ITM]ITMREF,"")
  Endif 
 Next
 Commit
Endif

Trbegin [AXX]
 Delete [AXX] Where CODFIC="" : # Une fois que TOUS les textes traduisibles sont récupérés
Commit

# Coup de sécurité : on vire les homonymes

Local Char COD(20) , ZON(20) , LAN(10) , ID1(80) , ID2(80) , TEX(200)
Raz COD , ZON , LAN , ID1 , ID2 , TEX
Trbegin [AXX]
 For [AXX]
  If COD=[F:AXX]CODFIC & ZON=[F:AXX]ZONE & LAN=[F:AXX]LANGUE & ID1=[F:AXX]IDENT1 & ID2=[F:AXX]IDENT2
   Delete [AXX] Curr
   Call ECR_TRACE(COD-ZON-LAN-ID1-ID2-TEX-[F:AXX]TEXTE,0) From GESECRAN
  Endif 
  COD = [F:AXX]CODFIC
  ZON = [F:AXX]ZONE
  LAN = [F:AXX]LANGUE
  ID1 = [F:AXX]IDENT1
  ID2 = [F:AXX]IDENT2
  TEX = [F:AXX]TEXTE
 Next AXX
Commit

End

Subprog CRETEX(TAB,ZON,NUM,CLE1,CLE2)
Value Char    TAB,ZON
Value Integer NUM
Value Char    CLE1,CLE2
Local Integer I
For I=1 To dim([F:ADS]LAN)
 If [F:ADS]LAN(I-1)<>""
  Read [AX2]CLE = [F:ADS]LAN(I-1);NUM
  If !fstat
   [F:AXX] = [F:AX2]
   [F:AXX]CODFIC = TAB
   [F:AXX]ZONE   = ZON
   [F:AXX]LANGUE = [F:ADS]LAN(I-1)
   [F:AXX]IDENT1 = CLE1
   [F:AXX]IDENT2 = CLE2
   [F:AXX]NUMERO = 0
   [F:AXX]CHAP   = ""
   [F:AXX]LNG    = 0
   Gosub TRT_TEXTE
   Write [AXX]
   If fstat
    Call ERREUR("ATEXTRA"-TAB-ZON-[F:ADS]LAN(I-1)-CLE1-CLE2,1) From DOSDIC
   Endif
  Endif
 Endif
Next I
For [TLA]
 If !find([F:TLA]LAN,[F:ADS]LAN(0..dim([F:ADS]LAN)-1))
  Read [AX2]CLE = [F:TLA]LAN;NUM
  If !fstat
   [F:AXX] = [F:AX2]
   [F:AXX]CODFIC = TAB
   [F:AXX]ZONE   = ZON
   [F:AXX]LANGUE = [F:TLA]LAN
   [F:AXX]IDENT1 = CLE1
   [F:AXX]IDENT2 = CLE2
   [F:AXX]NUMERO = 0
   [F:AXX]CHAP   = ""
   [F:AXX]LNG    = 0
   Gosub TRT_TEXTE
   Write [AXX]
   If fstat
    Call ERREUR("ATEXTRA"-TAB-ZON-[F:TLA]LAN-CLE1-CLE2,1) From DOSDIC
   Endif
  Endif
 Endif
Next TLA
End

#--- Traitements a effectuer sur le texte 
$TRT_TEXTE
Local Integer IJ0
#    Remplacement du code interne Euro (128) --> (8364)
If [F:AXX]CODFIC="ATABDIV" 
   While instr(1,[F:AXX]TEXTE,chr$(128))
         IJ0=instr(1,[F:AXX]TEXTE,chr$(128))         
         [F:AXX]TEXTE=left$([F:AXX]TEXTE,IJ0-1)+chr$(8364)+right$([F:AXX]TEXTE,IJ0+1)
   Wend
Endif
Return

#########################################################################################
## Nouvelle structure AOBJTAB
#########################################################################################

Subprog AOBJTAB

Local Integer I

Local File =[F:ADS]DOSSIER+".AOBJTAB" [AOT], =[F:ADS]DOSSIER+".AOBJTAB" [AOT2]

Call ECR_TRACE(mess(81,125,1)-": AOBJTAB"-time$,0) From GESECRAN : # maj table

For [AOT2] Where NUMLIG=0
 Trbegin [AOT]
  For I=0 To [F:AOT2]NBFIC-1
   [F:AOT]ABREV   = [F:AOT2]ABREV
   [F:AOT]TABFIC  = [F:AOT2]FICHIER(I)
   [F:AOT]TABLIEN = [F:AOT2]EXPLIEN(I)
   [F:AOT]TABABR  = ""
   [F:AOT]TABACT  = [F:AOT2]FICACT(I)
   [F:AOT]NUMLIG  = I+1
   Write [AOT]
   If fstat
    Call ERREUR("AOBJTAB"-[F:AOT]ABREV-num$([F:AOT]NUMLIG),1) From DOSDIC
   Endif
  Next I
 Commit
Next
Trbegin [AOT]
 Delete [AOT] Where NUMLIG=0
Commit
End

#########################################################################################
## Création des windows sur les objets qui n'en ont pas
#########################################################################################

Subprog AWINDOW_CRE

Local Integer I

Local File =[F:ADS]DOSSIER+".AOBJET" [AOB], =[F:ADS]DOSSIER+".AWINDOW" [AWI]

Call ECR_TRACE(mess(81,125,1)-": AWINDOW"-time$,0) From GESECRAN : # maj table

Trbegin [AWI]
 For [AOB]
  Read [AWI]AWI0 = "O"+[F:AOB]ABREV
  If fstat & [F:AOB]TYPGES<4 & [F:AOB]NOMFIC<>""
   Raz [F:AWI]
   [F:AWI] = [F:AOB]
   If dim([F:AOB]NBMSK)<0
    [F:AWI] = [F:AOB]
   Endif 
   [F:AWI]LIBEL  = ""
   [F:AWI]WIN    = "O"+[F:AOB]ABREV
   [F:AWI]DES    = [F:AOB]LIBEL
   [F:AWI]OBJ    = [F:AOB]ABREV
   [F:AWI]ENAFLG = 2
   [F:AWI]TYP    = 1
   For I=0 To [F:AWI]NBMSK-1
    [F:AWI]FLGMSK(I) = 2
   Next I
   [F:AWI]WINTYP = 2
   [F:AWI]CREDAT = date$
   [F:AWI]CREUSR = GUSER   
   If dim([F:AWI]CRETIM)>0 : [F:AWI]CRETIM = time  : Endif
   Write [AWI]
   If fstat
    Call ERREUR("AWINDOW"-"O"+[F:AOB]ABREV,1) From DOSDIC
   Endif
  Endif
 Next AOB
Commit
End

#########################################################################################
## Mise à jour zone ROWMSK et BSTD dans AWINDOW
#########################################################################################

Subprog AWINDOW

Local Integer I, K, INC

Call ECR_TRACE(mess(81,125,1)-": AWINDOW"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AWINDOW"   [AWI]

Trbegin [AWI]
 For [AWI]
  K = 0
  INC = 5
  For I=0 To [F:AWI]NBMSK-1
   K += INC
   [F:AWI]ROWMSK(I) = K
  Next I
  Case [F:AWI]WINTYP
   When 2 : For I=0 To dim([F:AWI]BSTD)-1
             If I<>4
              [F:AWI]BSTD(I) = 2
             Endif
            Next I
            [F:AWI]BSTD(17) = 2
   When 3 : [F:AWI]BSTD(6) = 2
   When 4 : [F:AWI]BSTD(1) = 2
   When Default : [F:AWI]BSTD(17) = 2
  Endcase
  Rewrite [AWI]
  If fstat
   Call ERREUR("AWINDOW"-[F:AWI]WIN,1) From DOSDIC
  Endif
 Next AWI
Commit

End

#########################################################################################
## Mise à jour de la table AWINBRO à partir des  browser définis dans AOBJET
#########################################################################################

Subprog AWINBRO

Local Integer I, K, OK

Call ECR_TRACE(mess(81,125,1)-": AWINBRO"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AWINBRO"   [AWB], =[F:ADS]DOSSIER+".AWINDOW"   [AWI]
&        , =[F:ADS]DOSSIER+".AOBJET"    [AOB]


Trbegin [AWB]
 Delete [AWB] Where 1=1
 For [AWI]AWI0
  Read [AWB]AWB0 = [F:AWI]WIN
  If !fstat 
   OK = 0
   For I=0 To [F:AWB]NBLIS-1
    If [F:AWB]OBJLIS(I)="ALI"
     [F:AWB]TRELIS(I) = 4
     OK = 1
    Endif
   Next I
   If OK
    Rewrite [AWB]
    If fstat
     Call ERREUR("AWINBRO"-[F:AWI]WIN,1) From DOSDIC
    Endif
   Endif
  Else
   OK = 0
   If [F:AWI]OBJ<>"" 
    Read [AOB]ABREV = [F:AWI]OBJ
    If !fstat : OK = 1 : Else : Raz [F:AOB] : Endif
   Elsif left$([F:AWI]WIN,1)="O" & len([F:AWI]WIN)=4
    Read [AOB]ABREV = right$([F:AWI]WIN,2)
    If !fstat : OK = 1 : Else : Raz [F:AOB] : Endif
   Endif   
   Raz [F:AWB]
   If OK
    [F:AWB] = [F:AOB]
   Endif
   [F:AWB]WIN = [F:AWI]WIN
   K = 5
   For I=0 To [F:AWB]NBLIS-1
    If [F:AWB]ROWLIS(I)=0
     [F:AWB]ROWLIS(I) = K
     K += 5
    Endif
    If [F:AWB]OBJLIS(I)="ALI"
     [F:AWB]TRELIS(I) = 4
    Endif
    If dim([F:AWB]FLELIS)>0
     [F:AWB]FLELIS(I) = 2
     If [F:AWB]OBJLIS(I)="ALI"
      [F:AWB]FLELIS(I) = 1
     Elsif dim([F:AOB]SUILIS)>0 & [F:AOB]SUILIS<>"" & mid$([F:AOB]SUILIS,I+1,1)<>"2"
      [F:AWB]FLELIS(I) = 1
     Endif
    Endif
   Next I
   Write [AWB]
   If fstat
    Call ERREUR("AWINBRO"-[F:AWI]WIN,1) From DOSDIC
   Endif
  Endif
 Next AWI
Commit
End

#########################################################################################
## Mise à jour de la table AWINBOUT à partir des boutons définis dans AWINDOW
#########################################################################################

Subprog AWINBOUT

Local Integer OK , I

Call ECR_TRACE(mess(81,125,1)-": AWINBOUT"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AWINBOUT"   [AWT],  =[F:ADS]DOSSIER+".AWINDOW" [AWI]

Trbegin [AWT]
 Delete [AWT] Where 1=1
 For [AWI]
  For I=0 To [F:AWI]NBBOUT-1
   [F:AWT]WIN = [F:AWI]WIN
   [F:AWT]NUM = I+1
   [F:AWT]CODBOUT = [F:AWI]CODBOUT(I)
   [F:AWT]TXTBOUT = [F:AWI]TXTBOUT(I)
   [F:AWT]TYPBOUT = [F:AWI]TYPBOUT(I)
   Case [F:AWT]TYPBOUT
    When 1
     If [F:AWT]CODBOUT>="a" & [F:AWT]CODBOUT<="z"
      [F:AWT]VALBOUT = 1
     Else
      [F:AWT]VALBOUT = 2
     Endif
    When 2
     If len([F:AWT]CODBOUT)>1
      [F:AWT]TYPBOUT=3
      If right$([F:AWT]CODBOUT,2)>="a" & right$([F:AWT]CODBOUT,2)<="z"
       [F:AWT]VALBOUT = 1
      Else
       [F:AWT]VALBOUT = 2
      Endif
     Endif
   Endcase
   [F:AWT]ACTBOUT = [F:AWI]ACTBOUT(I)
   [F:AWT]CODACTBOUT = [F:AWI]CODACTBOUT(I)
   Write [AWT]
   If fstat
    Call ERREUR("AWINBOUT"-[F:AWI]WIN-[F:AWI]CODBOUT(I),1) From DOSDIC
   Endif
  Next I
 Next
Commit
End

#########################################################################################
## Récupération des pièces jointes et mot-clé
#########################################################################################

Subprog AOBJTXT

Local Integer I , J , K , NBTYP
Local Char    CHAINE(250), TBTYP(3)(1..100)

Call ECR_TRACE(mess(81,125,1)-": AOBJTXT & AOBJTXTA"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AOBJTXT" [AOX], =[F:ADS]DOSSIER+".AOBJTXTA" [AOM]
Local File =[F:ADS]DOSSIER+".ATABTAB" [ADV], =[F:ADS]DOSSIER+".ATABDIV"  [ADI]

# Mise à jour des pièces jointes
    
Raz TBTYP, NBTYP

Trbegin [AOX]
 For [AOX]
  If [F:AOX]IDENT1="" & [F:AOX]IDENT2=""
   [F:AOX]CAT    = [F:AOX]ROLE
   [F:AOX]IDENT3 = num$([F:AOX]NUM)
   CHAINE = [F:AOX]CLE
   I = instr(1,CHAINE,"_")
   If I
    [F:AOX]IDENT1 = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    [F:AOX]IDENT1 = CHAINE
    CHAINE = ""
   Endif
   J = 0
   While CHAINE<>""
    J += 1
    If [F:AOX]IDENT2<>""
     [F:AOX]IDENT2 += "~"
    Endif
    I = instr(1,CHAINE,"_")
    If I
     [F:AOX]IDENT2 += left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Else
     [F:AOX]IDENT2 += CHAINE
     CHAINE = ""
    Endif
   Wend
   If J
    [F:AOX]IDENT2 += string$(16-J,"~")
   Endif
   CHAINE = [F:AOX]NAM
   I = instr(1,CHAINE,".")
   If I=0
    [F:AOX]TYPDOC = "RTF"
   Else
    While I<>0
     K = I
     I = instr(K+1,CHAINE,".")
    Wend
    [F:AOX]TYPDOC = vireblc(toupper(mid$(CHAINE,K+1,3)),2)
   Endif
   If !find([F:AOX]TYPDOC,TBTYP(1..NBTYP))
    NBTYP += 1
    TBTYP(NBTYP) = [F:AOX]TYPDOC
   Endif
   Rewrite [AOX]
   If fstat
    Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]CLE-num$([F:AOX]NUM),1) From DOSDIC
   Endif
  Endif
 Next
Commit

# Mise à jour table diverse 902 d'après les extensions trouvées

Trbegin [ADV], [ADI]
 Read [ADV]CODE = 902
 If fstat
  Raz [F:ADV]
  [F:ADV]NUMTAB = 902
  [F:ADV]NUMCAR = "902" 
  Write [ADV]
  If fstat
   Call ERREUR("ATABTAB 902",1) From DOSDIC
  Endif
 Endif
 For I=1 To NBTYP
  Read [ADI]CODE = 902;TBTYP(I)
  If fstat
   Raz [F:ADI]
   [F:ADI]NUMTAB = 902
   [F:ADI]CODE   = TBTYP(I)
   [F:ADI]A1     = tolower(TBTYP(I))
   [F:ADI]N1     = 1 : # Pas de blob pour le moment
   Write [ADI]
   If fstat
    Call ERREUR("ATABDIV 902"-TBTYP(I),1) From DOSDIC
   Endif
  Endif
 Next I
Commit

# Mise à jour des commentaires

Trbegin [AOM]
 For [AOM]
  If [F:AOM]IDENT1="" & [F:AOM]IDENT2=""
   [F:AOM]IDENT3 = num$([F:AOM]NUM)
   CHAINE = [F:AOM]CLE
   I = instr(1,CHAINE,"_")
   If I
    [F:AOM]IDENT1 = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    [F:AOM]IDENT1 = CHAINE
    CHAINE = ""
   Endif
   While CHAINE<>""
    If [F:AOM]IDENT2<>""
     [F:AOM]IDENT2 += "~"
    Endif
    I = instr(1,CHAINE,"_")
    If I
     [F:AOM]IDENT2 += left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Else
     [F:AOM]IDENT2 += CHAINE
     CHAINE = ""
    Endif
   Wend
   Rewrite [AOM]
   If fstat
    Call ERREUR("AOBJTXTA"-[F:AOM]ABREV-[F:AOM]CLE-num$([F:AOM]NUM),1) From DOSDIC
   Endif
  Endif
 Next
Commit

End

#########################################################################################
# Remplacement des _ dans les liaisons par des ~
#########################################################################################

Subprog MAJLNK

Local File =[F:ADS]DOSSIER+".ALINK"  [ALI], =[F:ADS]DOSSIER+".ALINK"   [AL2]
&        , =[F:ADS]DOSSIER+".AOBJET" [AOB], =[F:ADS]DOSSIER+".ATABIND" [ATI]

Local Integer OK, K
Local Char    NEWSRCKEY(50), NEWDSTKEY(50)

Call ECR_TRACE(mess(81,125,1)-": ALINK"-time$,0) From GESECRAN : # maj table

For [ALI]
 OK = 0
 NEWSRCKEY = [F:ALI]SRCKEY
 If instr(1,NEWSRCKEY,"_")
  Read [AOB]ABREV = [F:ALI]SRCOBJ
  Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
  If instr(1,[F:ATI]DESCRIPT,"+") | instr(1,[F:ATI]DESCRIPT,"-")
   K = instr(1,NEWSRCKEY,"_")
   While K
    NEWSRCKEY = left$(NEWSRCKEY,K-1)+"~"+right$(NEWSRCKEY,K+1)
    K = instr(1,NEWSRCKEY,"_")
    OK = 1
   Wend
  Endif
 Endif
 NEWDSTKEY = [F:ALI]DSTKEY
 If instr(1,NEWDSTKEY,"_")
  Read [AOB]ABREV = [F:ALI]DSTOBJ
  Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
  If instr(1,[F:ATI]DESCRIPT,"+") | instr(1,[F:ATI]DESCRIPT,"-")
   K = instr(1,NEWDSTKEY,"_")
   While K
    NEWDSTKEY = left$(NEWDSTKEY,K-1)+"~"+right$(NEWDSTKEY,K+1)
    K = instr(1,NEWDSTKEY,"_")
    OK = 1
   Wend
  Endif
 Endif
 If OK
  Trbegin [AL2]
   Update [AL2] Where USRCOD=[F:ALI]USRCOD & SRCOBJ=[F:ALI]SRCOBJ & SRCKEY=[F:ALI]SRCKEY
&                   & DSTOBJ=[F:ALI]DSTOBJ & DSTKEY=[F:ALI]DSTKEY
&               With  SRCKEY=NEWSRCKEY, DSTKEY=NEWDSTKEY, DSTXXX=[F:ALI]DSTOBJ+"|"+NEWDSTKEY
  Commit  
 Endif
Next

End

#########################################################################################
## Init des nouvelles zones écran
#########################################################################################

Subprog AMSK

Call ECR_TRACE(mess(81,125,1)-": AMSKZON & AMSK"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AMSKZON" [AMZ]

# L'option "longueur affichée" est maintenant saisissable dans les colonnes

Trbegin [AMZ]
 For [AMZ] Where OPTSAI="$" & [F:AMZ]OPTFOR=""
  [F:AMZ]OPTSAI = ""
  Rewrite [AMZ]
  If fstat
   Call ERREUR("AMSKZON"-[F:AMZ]CODMSK-[F:AMZ]CODZON,1) From DOSDIC
  Endif
 Next
Commit

# Il faut agrandir le champ LONG à la taille de l'intitulé des champs menus locaux 1 case à cocher

Local File =[F:ADS]DOSSIER+".AMSK" [AMK] , =[F:ADS]DOSSIER+".ATEXTE" [ATX]

Local Char    INTZON(80)
Local Integer I , J , K

Trbegin [AMZ]
 For [AMK]CODMSK Where MODULE>1
  For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK & TYPGRAPH=2 & INTEVAL="" & SAIAFF<=2
   If [F:AMZ]NUMBLOC>0 & [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=2
    Call TEXTE([F:AMZ]INTIT,INTZON) From OBJDIV
    I = [F:AMK]LNGLIB([F:AMZ]NUMBLOC-1)
    J = len(INTZON)
    K = int(J*3/4)
    If K>[F:AMZ]LONG
     [F:AMZ]LONG = K
     Rewrite [AMZ]
     If fstat
      Call ERREUR("AMSKZON"-[F:AMZ]CODMSK-[F:AMZ]CODZON,2) From DOSDIC
     Endif  
    Endif
   Endif
  Next AMZ
 Next AMK
Commit

Local File =[F:ADS]DOSSIER+".AMSKACT" [AMA]

# Le champ EXEACT remplace client,import,websai,webfin

For [AMK]
 Trbegin [AMA]
  For [AMA] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
   If [F:AMA]CLIENT=1 & [F:AMA]WEBSAI=1 & ([F:AMA]WEBFIN>=2 | [F:AMA]IMPORT=2)
    [F:AMA]EXEACT = 2
   Elsif ([F:AMA]CLIENT=2 | [F:AMA]WEBSAI=2) & ([F:AMA]IMPORT=2 | [F:AMA]WEBFIN>=2)
    [F:AMA]EXEACT = 3
   Else
    [F:AMA]EXEACT = 1
   Endif
   Rewrite [AMA]
   If fstat
    Call ERREUR("AMSKACT"-[F:AMA]CODAFF-[F:AMA]CODZON-[F:AMA]ACTION,1) From DOSDIC
   Endif
  Next
 Commit
Next 

Close Local File [AMZ], [AMK], [AMA], [ATX]

# Init des poids blocs et champs

Call RECUPSCR([F:ADS]DOSSIER,[F:ADS]DOSSIER,"","ZZZZZZZZZZ",0,0,0,1,2,0) From INTRRECUP

End

#########################################################################################
## Màj de la table AMENLOC à partir des menus locaux créés dans APLSTD
#########################################################################################

Subprog AMENLOC

Call ECR_TRACE(mess(81,125,1)-": AMENLOC"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".AMENLOC" [AML], =[F:ADS]DOSSIER+".APLSTD" [AST], =[F:ADS]DOSSIER+".APLSTD" [AST2]

Local Integer OK, K , T1, T2
Local Date    D1, D2
Local Char    U1(20), U2(20), MODULES(30)

MODULES = "SCTIVAKG0BXLO" : # X3

# S Superviseur
# C Comptabilité
# T Tiers
# I Immo
# V Ventes
# A Achats
# K 
# G GPAO
# 0 Tronc commun
# B Développement
# X Interne X3
# L Support client
# O Action commerciale

Trbegin [AML]
 For [AST] Where LANNUM=1 & LAN=GLANGUE & LANCHP>0 & LANCHP<>200
  Filter [AST2] Where LAN=GLANGUE & LANCHP=[F:AST]LANCHP & LANNUM>0
  Read [AST2]CLE First
  D1 = [F:AST2]CREDAT
  T1 = [F:AST2]CRETIM
  U1 = [F:AST2]CREUSR
  Read [AST2]CLE Last
  If [F:AST]UPDDAT<>[0/0/0]
   D2 = [F:AST]UPDDAT
   T2 = [F:AST]UPDTIM
   U2 = [F:AST]UPDUSR
  Else
   D2 = [F:AST]CREDAT
   T2 = [F:AST]CRETIM
   U2 = [F:AST]CREUSR
  Endif
  Filter [AST2]
  Read [AML]MENLOC=[F:AST]LANCHP
  If fstat
   Raz [F:AML]
   [F:AML]MENLOC = [F:AST]LANCHP
   Gosub INIZON
   If [F:AML]AUZMOD=0
    [F:AML]LONG = 0
   Else
    [F:AML]LONG = 15
   Endif
   Write [AML]
   If fstat
    Call ERREUR("AMENLOC"-num$([F:AST]LANCHP),1) From DOSDIC
   Endif
  Else
   Gosub INIZON
   Rewrite [AML]
   If fstat
    Call ERREUR("AMENLOC"-num$([F:AST]LANCHP),1) From DOSDIC
   Endif
  Endif
 Next
Commit

End

####################
$INIZON
K = 0
If [F:AML]MODIF<>""
 K = instr(1,MODULES,left$([F:AML]MODIF,1))
Endif
If K                                          : [F:AML]MODULE = K : [F:AML]AUZMOD = 2
Elsif [F:AML]MENLOC>0 & [F:AML]MENLOC<=99     : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 1
Elsif [F:AML]MENLOC>=201 & [F:AML]MENLOC<=300 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 9
Elsif [F:AML]MENLOC>=301 & [F:AML]MENLOC<=400 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 8
Elsif [F:AML]MENLOC>=401 & [F:AML]MENLOC<=500 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 5
Elsif [F:AML]MENLOC>=501 & [F:AML]MENLOC<=600 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 6
Elsif [F:AML]MENLOC>=601 & [F:AML]MENLOC<=700 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 2
Elsif [F:AML]MENLOC>=701 & [F:AML]MENLOC<=800 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 7
Elsif [F:AML]MENLOC>=801 & [F:AML]MENLOC<=900 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 4
Elsif [F:AML]MENLOC>=901 & [F:AML]MENLOC<=949 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 1
Elsif [F:AML]MENLOC>=950 & [F:AML]MENLOC<=999 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 13
Elsif [F:AML]MENLOC>=2201 & [F:AML]MENLOC<=2300 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 9
Elsif [F:AML]MENLOC>=2301 & [F:AML]MENLOC<=2400 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 8
Elsif [F:AML]MENLOC>=2401 & [F:AML]MENLOC<=2500 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 5
Elsif [F:AML]MENLOC>=2501 & [F:AML]MENLOC<=2600 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 6
Elsif [F:AML]MENLOC>=2601 & [F:AML]MENLOC<=2700 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 2
Elsif [F:AML]MENLOC>=2701 & [F:AML]MENLOC<=2800 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 7
Elsif [F:AML]MENLOC>=2801 & [F:AML]MENLOC<=2899 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 14
Elsif [F:AML]MENLOC>=2900 & [F:AML]MENLOC<=2949 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 1
Elsif [F:AML]MENLOC>=2950 & [F:AML]MENLOC<=2999 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 13
Elsif [F:AML]MENLOC>=3000 & [F:AML]MENLOC<=3099 : [F:AML]AUZMOD = 1 : [F:AML]MODULE = 15
Else
 [F:AML]MODULE = 1
 [F:AML]AUZMOD = 1
Endif
If ([F:AST]LANCHP>=100 & [F:AST]LANCHP<200) | [F:AST]LANCHP>=8900
 [F:AML]MENLOCAL = 1
 [F:AML]AUZMOD   = 0
Else
 [F:AML]MENLOCAL = 2
Endif
[F:AML]CREDAT = D1
[F:AML]CRETIM = T1
[F:AML]CREUSR = U1
[F:AML]UPDDAT = D2
[F:AML]UPDTIM = T2
[F:AML]UPDUSR = U2
Return

###########################################################################################
# Rajout dans les écrans du paramètre TABDIV (dépendance) sur le type de donnée ADI
###########################################################################################

Subprog AMSKADI

Local File =[F:ADS]DOSSIER+".AMSKZON" [AMZ], =[F:ADS]DOSSIER+".AMSKPAR" [AMP]

Call ECR_TRACE(mess(81,125,1)-": AMSKPAR"-time$,0) From GESECRAN : # maj table

For [AMZ] Where CODTYP="ADI"

 Trbegin [AMP]
  Read [AMP]CODPAR = 1;[F:AMZ]CODMSK;[F:AMZ]CODZON;"TABDIV"
  If fstat
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMZ]CODMSK
   [F:AMP]CODZON = [F:AMZ]CODZON
   [F:AMP]CODPAR = "TABDIV"
   [F:AMP]VALPAR = '""'
   Write [AMP]
   If fstat
    Call ERREUR("AMSKPAR"-[F:AMZ]CODMSK-[F:AMZ]CODZON,1) From DOSDIC
   Endif
  Endif
 Commit

Next

End

#########################################################################################
## Màj de la table ACTION, champ SPETRT
#########################################################################################

Subprog ACTION

Call ECR_TRACE(mess(81,125,1)-": ACTION"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".ACTION" [ACT]

Trbegin [ACT]
 For [ACT] Where find(TYP,3,4)
  If [F:ACT]SPETRT=""
   Case [F:ACT]TYP
    When 3 : # Gtraite
     If left$([F:ACT]CODTRT,3)="SUB"
      [F:ACT]SPETRT = "SPE"+mid$([F:ACT]CODTRT,4,3)
     Elsif [F:ACT]CODTRT<>""
      [F:ACT]SPETRT = "XY"+[F:ACT]CODTRT
     Endif
    When 4 : # Gsaisie
     If left$([F:ACT]CODTRT,3)="SUB"
      [F:ACT]SPETRT = "SPE"+mid$([F:ACT]CODTRT,4,3)
     Elsif [F:ACT]PARAM2<>""
      Call NOMSPEWIN([F:ACT]PARAM2,[F:ACT]SPETRT) From MSKDIV
     Endif
   Endcase
   Rewrite [ACT]
   If fstat
    Call ERREUR("ACTION"-[F:ACT]ACTION,2) From DOSDIC
   Endif
  Endif
 Next 
Commit

End

#########################################################################################
## Rajout boutons mémo dans les fenêtres critères de consultation
#########################################################################################

Subprog MAJBOUT

Local File =[F:ADS]DOSSIER+".AWINDOW" [AWI], =[F:ADS]DOSSIER+".AWINPAR"  [AWP]
&        , =[F:ADS]DOSSIER+".AWINBOUT"  [AWT]
&        , =[F:ADS]DOSSIER+".AMSK"    [AMK], =[F:ADS]DOSSIER+".ACONSULT" [ACN]
&        , =[F:ADS]DOSSIER+".ATEXTE"  [ATX], =[F:ADS]DOSREF+".ATEXTE" [ATX2]

Local Integer I, J, K, L, OK, LIBPAR(0..2)
Local Char    BOUT(3), PAR(10)

For [AWT] Where WIN="ASELOBJ"
 Read [ATX2]NUMERO = GLANGUE;[F:AWT]TXTBOUT
 Read [ATX]TEXTE = GLANGUE;[F:ATX2]TEXTE
 Case [F:AWT]CODBOUT
  When "M" : LIBPAR(0) = [F:ATX]NUMERO : # Mémo
  When "R" : LIBPAR(1) = [F:ATX]NUMERO : # Rappel
  When "E" : LIBPAR(2) = [F:ATX]NUMERO : # Efface mémo
 Endcase
Next

Call ECR_TRACE(mess(81,125,1)-": AWINPAR"-time$,0) From GESECRAN : # maj table

Trbegin [AWI]
 For [AWI] Where find(WINTYP,3,4)
  For I=0 To dim([F:AWI]BSTD)-1
   OK = 0
   If [F:AWI]WINTYP=3
    If !find(I,1,5)
     OK = 1
    Else
     Read [ACN]ACN0=[F:AWI]CNS
     If !fstat
      If I=1 & [F:ACN]WND0<>""
       OK = 1
      Elsif I=5 & dim([F:ACN]GRAPHCOD)>0 & [F:ACN]GRAPHCOD<>""
       OK = 1
      Endif
     Endif
    Endif
   Elsif I=0
    OK = 1
   Endif
   If OK
    [F:AWI]BSTD(I) = 2
   Else
    [F:AWI]BSTD(I) = 1
   Endif
   [F:AWI]ACTSTD(I) = ""
  Next I
  Rewrite [AWI]
  If fstat
   Call ERREUR("AWINDOW"-[F:AWI]WIN,2) From DOSDIC
  Endif
  If [F:AWI]WINTYP=4
   Filter [AWT] Where WIN=[F:AWI]WIN & ACTBOUT="MEMO"
   Read [AWT]AWT0 First
   Filter [AWT]
   If fstat
    Filter [AWT] Where WIN=[F:AWI]WIN
    Read [AWT]AWT0 Last
    Filter [AWT]
    If !fstat
     K = [F:AWT]NUM
    Else
     K = 0
    Endif
    For BOUT="M","R","E"
     K += 1
     Raz [F:AWT]
     [F:AWT]WIN = [F:AWI]WIN
     [F:AWT]NUM = K
     [F:AWT]CODBOUT = BOUT
     Case BOUT
      When "M" : [F:AWT]TXTBOUT = LIBPAR(0) : [F:AWT]VALBOUT = 2
      When "R" : [F:AWT]TXTBOUT = LIBPAR(1) : [F:AWT]VALBOUT = 1
      When "E" : [F:AWT]TXTBOUT = LIBPAR(2) : [F:AWT]VALBOUT = 1    
     Endcase
     [F:AWT]TYPBOUT = 1
     [F:AWT]ACTBOUT = "MEMO"
     Write [AWT]
     If fstat
      Call ERREUR("AWINBOUT"-[F:AWT]WIN-BOUT,1) From DOSDIC
     Endif
     L = 0
     For PAR="CLASSE","EXT","TYPMEM"
      L += 1
      Raz [F:AWP]
      [F:AWP]WIN = [F:AWI]WIN
      [F:AWP]NUM = K
      [F:AWP]NOPAR = L
      [F:AWP]PARAM = PAR
      Case PAR
       When "CLASSE"
        Read [AMK]CODMSK = [F:AWI]NOMMSK(0)
        [F:AWP]VALEUR = '"[M:'+[F:AMK]ABRMSK+']"'
       When "EXT"
        [F:AWP]VALEUR = '"'+tolower([F:AWI]CNS)+'"'
       When "TYPMEM"
        Case BOUT
         When "M" : [F:AWP]VALEUR = '"1"'
         When "R" : [F:AWP]VALEUR = '"2"'
         When "E" : [F:AWP]VALEUR = '"3"'
        Endcase        
      Endcase
      Write [AWP]
      If fstat
       Call ERREUR("AWINPAR"-[F:AWP]WIN-[F:AWP]PARAM,1) From DOSDIC
      Endif
     Next PAR
    Next BOUT
   Endif
  Endif
 Next AWI
Commit
End

#########################################################################################
## Màj nouveaux champs dans table AMESSAGE
#########################################################################################

Subprog AMESSAGE

Local File =[F:ADS]DOSSIER+".AMESSAGE" [AMS]

Call ECR_TRACE(mess(81,125,1)-": AMESSAGE"-time$,0) From GESECRAN : # maj table

Trbegin [AMS]
 For [AMS]
  If left$([F:AMS]EVENEMENT,3)="OBJ"
   [F:AMS]TYPEVT = 2
   [F:AMS]CODEVT = right$([F:AMS]EVENEMENT,4)
  Elsif left$([F:AMS]EVENEMENT,2)="F_"
   [F:AMS]TYPEVT = 3
   [F:AMS]CODEVT = right$([F:AMS]EVENEMENT,3)
  Elsif left$([F:AMS]EVENEMENT,2)="R_"
   [F:AMS]TYPEVT = 4
   [F:AMS]CODEVT = right$([F:AMS]EVENEMENT,3)
  Elsif left$([F:AMS]EVENEMENT,2)="T_"
   [F:AMS]TYPEVT = 7
   [F:AMS]CODEVT = right$([F:AMS]EVENEMENT,3)
  Elsif [F:AMS]EVENEMENT="BATCH"
   [F:AMS]TYPEVT = 5
   [F:AMS]CODEVT = ""
   [F:AMS]EVENEMENT = "B_" 
  Elsif [F:AMS]EVENEMENT="ABORT"
   [F:AMS]TYPEVT = 6
   [F:AMS]CODEVT = ""
   [F:AMS]EVENEMENT = "A_" 
  Else
   [F:AMS]TYPEVT = 1
   [F:AMS]CODEVT = [F:AMS]EVENEMENT
  Endif
  Rewrite [AMS]
  If fstat
   Call ERREUR("AMESSAGE"-[F:AMS]CODE,1) From DOSDIC
  Endif
 Next
Commit
End

#########################################################################################
## Rajout des paramètres utilisateurs et mise à jour Profils fonction
#########################################################################################

Subprog AUTILIS

Call ECR_TRACE(mess(81,125,1)-": AUTILIS"-time$,0) From GESECRAN : # maj table

Local Integer I , ERR
Local Integer NUMCASE
Local Integer COMPTEUR
Local Char    CODEPROFIL(6), LPARAM(10)(1..26), LVALDOS(10)(1..26), ERRMES(250)

Local File =[F:ADS]DOSREF+".ADOPAR" [ADP], =[F:ADS]DOSREF+".ATEXTE" [ATX1]

Local File =[F:ADS]DOSSIER+".ADOPAR"    [ADP2], =[F:ADS]DOSSIER+".ATEXTE"  [ATX2]
&        , =[F:ADS]DOSSIER+".ADOVAL"    [ADW2]
&        , =[F:ADS]DOSSIER+".ADOVALAUS" [ADU2], =[F:ADS]DOSSIER+".ACCES"   [ACC2]
&        , =[F:ADS]DOSSIER+".ACCES"     [ACC3]
&        , =[F:ADS]DOSSIER+".AFCTFCT"   [AFT2], =[F:ADS]DOSSIER+".AUTILIS" [AUS2]

LPARAM(1)="LFTBOX"
LPARAM(2)="NBDERLUS"
LPARAM(3)="HISTCALC"
LPARAM(4)="CHDERLUS"
LPARAM(5)="DEMSRV"
LPARAM(6)="SELGLO"
LPARAM(7)="CONFSUP"
LPARAM(8)="CONFDUP"
LPARAM(9)="CONFABD"
LPARAM(10)="DATEDEBDFT"
LPARAM(11)="DATEFINDFT"
LPARAM(12)="POLICES"
LPARAM(13)="GRPLIAISON"
LPARAM(14)="LIAISAUTO"
LPARAM(15)="NIVBATCH"
LPARAM(16)="SCHSAISIE"
LPARAM(17)="SCHSAIANA"
LPARAM(18)="SCHSAILOT"
LPARAM(19)="CNTBUD"
LPARAM(20)="SAIDEVISE"
LPARAM(21)="DATDEBCTR"
LPARAM(22)="BANKDEF"
LPARAM(23)="CAISDEF"
LPARAM(24)="TRANSREG"
LPARAM(25)="NIVBONPAYE"
LPARAM(26)="AUZFCT"

LVALDOS(1)  = "100"
LVALDOS(2)  = "20"
LVALDOS(3)  = "10"
LVALDOS(4)  = "2"
LVALDOS(5)  = "1"
LVALDOS(6)  = "1"
LVALDOS(7)  = "1"
LVALDOS(8)  = "1"
LVALDOS(9)  = "1"
LVALDOS(10) = "00000000"
LVALDOS(11) = "00000000"
LVALDOS(12) = "1"
LVALDOS(15) = "10"
LVALDOS(19) = "1"
LVALDOS(20) = "1"
LVALDOS(21) = "00000000"
LVALDOS(25) = "1"
LVALDOS(26) = "*"

#########################################
#                                       #
# Insertion des parametres utilisateur  #
#                                       #
#########################################

Trbegin [ADP2]
 For I=1 To dim(LPARAM)
  If LPARAM(I)<>""
   Read [ADP]ADP1 = LPARAM(I)
   If !fstat
    Read [ADP2]ADP1 = [F:ADP]PARAM
    If fstat
     [F:ADP2] = [F:ADP]
     Call COPTEXTE([F:ADP]NAM,[F:ADP2]NAM) From OBJDIV
     Write [ADP2]
     If fstat : Call ERREUR("ADOPAR",2) From DOSDIC : Endif
    Endif
   Endif
  Endif 
 Next I
Commit

#################################################################
#                                                               #
#     Insertion des valeurs des parametres pour le dossier      #
#                                                               #
#################################################################

Trbegin [ADW2]
 For I=1 To dim(LPARAM)
  If (LVALDOS(I)<>"")
   Read [F:ADW2]ADW0="";"";LPARAM(I)
   If fstat
    [F:ADW2]FCY=""
    [F:ADW2]CMP=""   
    [F:ADW2]PARAM = LPARAM(I)
    If I=10 or I=11 or I=21
     [F:ADW2]VALEUR = "00000000"
    Else
     [F:ADW2]VALEUR = num$(LVALDOS(I))
    Endif
    Write [F:ADW2]
    If fstat : Call ERREUR("ADOVAL",2) From DOSDIC : Endif 
   Endif
  Endif
 Next
Commit

#################################################################
#                                                               #
# Insertion des valeurs des parametres pour chaque utilisateur  #
#                                                               #
#################################################################

Trbegin [ADU2]
 For [AUS2]CODUSR With Lock
  For I=1 To dim(LPARAM)
   Raz [F:ADU2]
   CODEPROFIL=""
   Case I
     When 1  :  If LVALDOS(I) <> num$([F:AUS2]LFTBOX)    
                    If [F:AUS2]LFTBOX <> 0
                         [F:ADU2]VALEUR = num$([F:AUS2]LFTBOX)    
                    Endif
                Endif
     When 2  :  If LVALDOS(I) <> num$([F:AUS2]LSTBOX)    
                    If [F:AUS2]LSTBOX <> 0        
                        [F:ADU2]VALEUR = num$([F:aus2]LSTBOX)    
                    Endif
                Endif
     When 3  :  If LVALDOS(I) <> num$([F:AUS2]CLCNB)     
                    If [F:AUS2]CLCNB <> 0
                        [F:ADU2]VALEUR = num$([F:AUS2]CLCNB)     
                    Endif
                Endif
     When 4  :  If LVALDOS(I) <> num$([F:AUS2]LSTRD)     
                    If [F:AUS2]LSTRD <> 0
                         [F:ADU2]VALEUR = num$([F:aus2]LSTRD)     
                    Endif
                Endif
     When 5  :  If LVALDOS(I) <> num$([F:AUS2]AUTBAT)    
                    If [F:AUS2]AUTBAT <> 0 
                         [F:ADU2]VALEUR = num$([F:AUS2]AUTBAT)        
                    Endif
                Endif
     When 6  :  If LVALDOS(I) <> num$([F:AUS2]SELOVR)    
                    If [F:AUS2]SELOVR <> 0
                        [F:ADU2]VALEUR = num$([F:AUS2]SELOVR)    
                    Endif
                Endif
     When 7  :  If LVALDOS(I) <> num$([F:AUS2]CONF(0)) 
                    If [F:AUS2]CONF(0) <> 0 
                        [F:ADU2]VALEUR = num$([F:AUS2]CONF(0))   
                    Endif
                Endif
     When 8  :  If LVALDOS(I) <> num$([F:AUS2]CONF(1))   
                    If [F:AUS2]CONF(1) <> 0 
                        [F:ADU2]VALEUR = num$([F:AUS2]CONF(1))   
                    Endif
                Endif
     When 9  :  If LVALDOS(I) <> num$([F:AUS2]CONF(2))
                    If [F:AUS2]CONF(2) <> 0 
                        [F:ADU2]VALEUR = num$([F:AUS2]CONF(2))   
                    Endif
                Endif
     When 10 :  If LVALDOS(I) <> num$([F:AUS2]STRDAT)    
                    If (val([F:AUS2]STRDAT) <> 0) and (len(num$(val([F:AUS2]STRDAT))) = 8)
                        [F:ADU2]VALEUR = format$("D:YYYYMMDD",[F:AUS2]STRDAT)
                    Endif
                Endif
     When 11 :  If LVALDOS(I) <> num$([F:AUS2]ENDDAT)    
                    If val([F:AUS2]ENDDAT) <> 0
                        [F:ADU2]VALEUR = format$("D:YYYYMMDD",[F:AUS2]ENDDAT)
                    Endif
                Endif
     When 12 :  If LVALDOS(I) <> num$([F:AUS2]POLICE)    : [F:ADU2]VALEUR = num$([F:aus2]POLICE)    : Endif
     When 13 :  If [F:AUS2]LNKGRP(0) <> ""
                   [F:ADU2]VALEUR = num$([F:aus2]LNKGRP(0)) 
                Endif
     When 14 :  If [F:AUS2]LNKGRP(1) <> ""
                    [F:ADU2]VALEUR = [F:AUS2]LNKGRP(1)
                Endif
     When 15 :  If dim([F:AUS2]NIVBATCH)>0 & LVALDOS(I) <> num$([F:AUS2]NIVBATCH)
                    [F:ADU2]VALEUR = num$([F:AUS2]NIVBATCH)
                Endif
     When 16 :  If dim([F:AUS2]SCHDEF)>0 & [F:AUS2]SCHDEF <> ""
                    [F:ADU2]VALEUR = [F:AUS2]SCHDEF
                Endif
     When 17 :  If dim([F:AUS2]SCHDEFA)>0 & [F:AUS2]SCHDEFA <> ""
                    [F:ADU2]VALEUR = [F:AUS2]SCHDEFA
                Endif
     When 18 :  If dim([F:AUS2]SCHDEFA)>0 & [F:AUS2]SCHDEFL <> ""
                    [F:ADU2]VALEUR = [F:AUS2]SCHDEFL
                Endif
     When 19 :  If dim([F:AUS2]CNTBUD)>0 & LVALDOS(I) <> num$([F:AUS2]CNTBUD)
                 [F:ADU2]VALEUR = num$([F:aus2]CNTBUD)
                Endif
     When 20 :  If dim([F:AUS2]EURDAC)>0 & LVALDOS(I) <> num$([F:AUS2]EURDAC)
                  [F:ADU2]VALEUR = num$([F:aus2]EURDAC)
                Endif
     When 21 :  If dim([F:AUS2]EURDAT)>0 & LVALDOS(I) <> num$([F:AUS2]EURDAT)    
                    If val([F:AUS2]EURDAT) <> 0
                        [F:ADU2]VALEUR = format$("D:YYYYMMDD",[F:AUS2]EURDAT)
                    Endif
                Endif
     When 22 :  If dim([F:AUS2]BANDEF)>0 & [F:AUS2]BANDEF <> ""
                    [F:ADU2]VALEUR = [F:AUS2]BANDEF
                Endif
     When 23 :  If dim([F:AUS2]CSHDEF)>0 & [F:AUS2]CSHDEF <> ""
                    [F:ADU2]VALEUR = [F:AUS2]CSHDEF
                Endif
     When 24 :  If dim([F:AUS2]PAYTYP)>0 & num$([F:AUS2]PAYTYP) <> ""
                 [F:ADU2]VALEUR = num$([F:aus2]PAYTYP)
                Endif
     When 25 :  If dim([F:AUS2]LEVPAZ)>0 & LVALDOS(I) <> num$([F:AUS2]LEVPAZ)
                  [F:ADU2]VALEUR = num$([F:aus2]LEVPAZ)
                Endif
   Endcase
   If [F:ADU2]VALEUR <> "" 
    If [F:ADU2]VALEUR <> "0"
     Read [F:ADU2]ADU0 = [F:AUS2]USR;LPARAM(I)
     If fstat=5
      [F:ADU2]CODUSR = [F:AUS2]USR
      [F:ADU2]PARAM  = LPARAM(I)
      Write [F:ADU2]
      If fstat : Call ERREUR("ADOVALAUS",1) From DOSDIC : Endif 
     Endif
    Endif
   Endif
# alimentaton d'un code profil par les éléments du premier utilisateur rattaché à ce code profil
   If I=1
    CODEPROFIL=[F:AUS2]PRFFCT 
    Read [F:AFT2]AFT0 = CODEPROFIL
    If fstat=0
     If [F:AFT2]ALLFCT = 0
      [F:AFT2]DIFIMP = [F:AUS2]DIFIMP
      [F:AFT2]FILTRE = [F:AUS2]FILTRE
      For COMPTEUR = 0 To dim([F:AUS2]AUTETA)-1
       If [F:AUS2]AUTETA(COMPTEUR) <> 0
        [F:AFT2]AUTETA(COMPTEUR) = [F:AUS2]AUTETA(COMPTEUR)
       Else
        [F:AFT2]AUTETA(COMPTEUR) = 1
       Endif
      Next COMPTEUR
      For COMPTEUR = 0 To dim([F:AFT2]FCYDEF)-1
       [F:AFT2]FCYDEF(COMPTEUR) = [F:AUS2]FCYDEF(COMPTEUR)
      Next COMPTEUR
      [F:AFT2]ALLFCT = [F:AFT2]ALLACS 
      [F:AFT2]ALLACS = [F:AUS2]ALLACS 
      Rewrite [F:AFT2]
      If fstat : Call ERREUR("AFCTFCT",2) From DOSDIC : Endif 
     Endif
    Endif
# mise à jour des codes acces
    If [F:AUS2]ALLACS <> 2
      For[ACC2] Where USR=[F:AUS2]USR
       Raz[F:ACC3]
       [F:ACC3]=[F:ACC2]
       [F:ACC3]USR=""
       [F:ACC3]PRFCOD=[F:AUS2]USR
       Write [ACC3]
       If fstat : Call ERREUR("ACCES",1) From DOSDIC : Endif
      Next
    Endif
   Endif
  Next I
 Next AUS2
Commit

Trbegin [AUS2]
 For [AUS2]
  [F:AUS2]USRCONNECT = 2
  Rewrite [AUS2]
  If fstat : Call ERREUR("AUTILIS",2) From DOSDIC : Endif 
 Next AUS2
Commit

End

#########################################################################################
## # Mise à jour des formats par pays
#########################################################################################

Subprog TABCOUNTRY
Local File =[F:ADS]DOSSIER+".TABCOUNTRY" [TCY] , =[F:ADS]DOSREF+".TABCOUNTRY" [TCY2]
Call ECR_TRACE(mess(81,125,1)-": TABCOUNTRY"-time$,0) From GESECRAN : # maj table
Trbegin [TCY]
 For [TCY]
  Read [TCY2]TCY0 = [F:TCY]CRY
  If !fstat   
   If dim([F:TCY]CTYCODFMT)>0 : [F:TCY]CTYCODFMT = [F:TCY2]CTYCODFMT : Endif
   If dim([F:TCY]PABFMT)>0    : [F:TCY]PABFMT    = [F:TCY2]PABFMT    : Endif
   If dim([F:TCY]ADRCODFMT)>0 : [F:TCY]ADRCODFMT = [F:TCY2]ADRCODFMT : Endif
   If dim([F:TCY]SOCNUMFMT)>0 : [F:TCY]SOCNUMFMT = [F:TCY2]SOCNUMFMT : Endif
   If dim([F:TCY]EMPNUMFMT)>0 : [F:TCY]EMPNUMFMT = [F:TCY2]EMPNUMFMT : Endif
   If dim([F:TCY]ETATFMT)>0   & [F:TCY]ETATFMT=""   : [F:TCY]ETATFMT   = [F:TCY2]ETATFMT   : Endif
   If dim([F:TCY]SUBDIVFMT)>0 & [F:TCY]SUBDIVFMT="" : [F:TCY]SUBDIVFMT = [F:TCY2]SUBDIVFMT : Endif
   If dim([F:TCY]CRNFMT)>0    & [F:TCY]CRNFMT=""    : [F:TCY]CRNFMT    = [F:TCY2]CRNFMT    : Endif
   If dim([F:TCY]BIDFMT)>0    & [F:TCY]BIDFMT=""    : [F:TCY]BIDFMT    = [F:TCY2]BIDFMT    : Endif
   If dim([F:TCY]BIDCRY)>0    & [F:TCY]BIDCRY=""    : [F:TCY]BIDCRY    = [F:TCY2]BIDCRY    : Endif
   If dim([F:TCY]CTYNUMFMT)>0 & [F:TCY]CTYNUMFMT="" : [F:TCY]CTYNUMFMT = [F:TCY2]CTYNUMFMT : Endif
   If dim([F:TCY]POSCODFMT)>0 & [F:TCY]POSCODFMT="" : [F:TCY]POSCODFMT = [F:TCY2]POSCODFMT : Endif
   If dim([F:TCY]POSCODCRY)>0 & [F:TCY]POSCODCRY="" : [F:TCY]POSCODCRY = [F:TCY2]POSCODCRY : Endif
   If dim([F:TCY]NAFFMT)>0    & [F:TCY]NAFFMT=""    : [F:TCY]NAFFMT    = [F:TCY2]NAFFMT    : Endif
   If dim([F:TCY]TELFMT)>0    & [F:TCY]TELFMT=""    : [F:TCY]TELFMT    = [F:TCY2]TELFMT    : Endif
  Else
   If dim([F:TCY]CTYCODFMT)>0 : [F:TCY]CTYCODFMT = "27X" : Endif
   If dim([F:TCY]PABFMT)>0    : [F:TCY]PABFMT    = "26X" : Endif
   If dim([F:TCY]ADRCODFMT)>0 : [F:TCY]ADRCODFMT = "32X" : Endif
   If dim([F:TCY]SOCNUMFMT)>0 : [F:TCY]SOCNUMFMT = "25X" : Endif
   If dim([F:TCY]EMPNUMFMT)>0 : [F:TCY]EMPNUMFMT = "10X" : Endif
   If dim([F:TCY]ETATFMT)>0   & [F:TCY]ETATFMT=""   : [F:TCY]ETATFMT   = "10X" : Endif
   If dim([F:TCY]SUBDIVFMT)>0 & [F:TCY]SUBDIVFMT="" : [F:TCY]SUBDIVFMT = "10X" : Endif
   If dim([F:TCY]BIDCRY)>0    & [F:TCY]BIDCRY=""    : [F:TCY]BIDCRY    = "10X" : Endif
   If dim([F:TCY]BIDFMT)>0    & [F:TCY]BIDFMT=""    : [F:TCY]BIDFMT    = "10X" : Endif
   If dim([F:TCY]CRNFMT)>0    & [F:TCY]CRNFMT=""    : [F:TCY]CRNFMT    = "10X" : Endif
   If dim([F:TCY]CTYNUMFMT)>0 & [F:TCY]CTYNUMFMT="" : [F:TCY]CTYNUMFMT = "10X" : Endif
   If dim([F:TCY]POSCODFMT)>0 & [F:TCY]POSCODFMT="" : [F:TCY]POSCODFMT = "10X" : Endif
   If dim([F:TCY]POSCODCRY)>0 & [F:TCY]POSCODCRY="" : [F:TCY]POSCODCRY = "10X" : Endif
   If dim([F:TCY]NAFFMT)>0    & [F:TCY]NAFFMT=""    : [F:TCY]NAFFMT    = "10X" : Endif
   If dim([F:TCY]TELFMT)>0    & [F:TCY]TELFMT=""    : [F:TCY]TELFMT    = "10X" : Endif
  Endif
  Rewrite [TCY]
  If fstat
   Call ERREUR("TABCOUNTRY"-[F:TCY]CRY,2) From DOSDIC
  Endif
 Next TCY
Commit
Close Local File [TCY] , [TCY2]
End

#########################################################################################
## Initialisation à 1 du type de requête dans ALISTE
#########################################################################################

Subprog ALISTE
Local File =[F:ADS]DOSSIER+".ALISTEH" [ALH]
Call ECR_TRACE(mess(81,125,1)-": ALISTEH"-time$,0) From GESECRAN : # maj table
Trbegin [ALH]
 Update [ALH] Where 1=1 With TYP=1
 If fstat
  Call ERREUR("ALISTEH",2) From DOSDIC
 Endif 
Commit
Close Local File [ALH]
End

#########################################################################################
## Pour virer les homonymes
#########################################################################################

Subprog CONTACT
Local File =[F:ADS]DOSSIER+".CONTACT" [CNT]
Filter [CNT] Order By Key CLE=BPATYP;BPANUM;CCNCRM
Call ECR_TRACE(mess(81,125,1)-": CONTACT"-time$,0) From GESECRAN : # maj table
Local Integer TYP
Local Char NUM(20) , CRM(20)
Raz TYP , NUM , CRM
Trbegin [CNT]
 For [CNT]CLE
  If TYP=[F:CNT]BPATYP & NUM=[F:CNT]BPANUM & CRM=[F:CNT]CCNCRM
   Delete [CNT] Curr
   Call ECR_TRACE(num$(TYP)-NUM-CRM,0) From GESECRAN
  Endif 
  TYP = [F:CNT]BPATYP
  NUM = [F:CNT]BPANUM
  CRM = [F:CNT]CCNCRM
 Next CNT
Commit
Filter [CNT]
Close Local File [CNT]
End

#########################################################################################
## Initialisation du code paramètre action dans AFONCTION
#########################################################################################

Subprog AFONCTION
Local File =[F:ADS]DOSSIER+".AFONCTION" [AFC]
&        , =[F:ADS]DOSSIER+".ACTPAR"    [ATR]
&        , =[F:ADS]DOSSIER+".ACTION"    [ACT]
Local Integer I
Local Char    ACT(20) 
If dim([F:AFC]CODPAR)<=0 : End : Endif
Call ECR_TRACE(mess(81,125,1)-": AFONCTION"-time$,0) From GESECRAN : # maj table
Trbegin [AFC]
 For [AFC]
  If [F:AFC]ACTION<>""
   ACT = [F:AFC]ACTION
   Gosub CHARGE_PAR
   Rewrite [AFC]
   If fstat
    Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
   Endif
  Endif
 Next AFC
Commit
End

$CHARGE_PAR
Raz [F:AFC]CODPAR
I = 0
$CHARGE_SUI
If ACT<>""
 Read [ACT]ACTION = ACT
 If !fstat
  For [ATR]NOPAR Where ACTION=ACT
   If [F:ATR]NOPAR>1 or [F:ACT]TYPACT<>2
    If !find([F:ATR]CODPAR,[F:AFC]CODPAR(0..I-1))
     [F:AFC]CODPAR(I) = [F:ATR]CODPAR
     I += 1
    Endif
   Endif
  Next ATR
  If [F:ACT]ACTSUI<>""
   ACT = [F:ACT]ACTSUI
   Goto CHARGE_SUI
  Endif
 Endif
Endif
Return

##############################################################################
# Epuration des traitements AUT GES et W et CNSxxx et validation des autres
##############################################################################

Subprog EPURTRT
Local Char    MACHINE(50), APPLI(50)
Local Char    TRAIT(15)(30000)
Local Integer I , NBTRAIT , OKSUP , STAT
Call MACHINE([F:ADS]DOSSIER,MACHINE,APPLI) From ORDSYS
Call ECR_TRACE("Purge Processes"-time$,0) From GESECRAN
Call SYSTEME2(MACHINE,"lsadx -a "+APPLI+" TRT src","",NBTRAIT,TRAIT) From ORDSYS
For I=0 To NBTRAIT
 If TRAIT(I)<>""
  OKSUP = find(left$(TRAIT(I),3),"AUT","GES","imp","exp")
  OKSUP += left$(TRAIT(I),1)="W"
  OKSUP += left$(TRAIT(I),2)="IA"
  OKSUP += (left$(TRAIT(I),3)="CNS" & len(TRAIT(I))=6)
  OKSUP += left$(TRAIT(I),5)="AGLOB"
  If OKSUP
   Call ECR_TRACE("Purge process"-TRAIT(I),0) From GESECRAN
   System MACHINE+'@ae_rm'-filpath("TRT",TRAIT(I),"*",[F:ADS]DOSSIER,"","")
  Else
   Call ECR_TRACE("Process validation"-TRAIT(I),0) From GESECRAN
   Call UTF8("TRT",TRAIT(I),"src",APPLI,1) From MAJUTF8
   Call SYSTEME(MACHINE,"valtrt"-APPLI-TRAIT(I),"",STAT) From ORDSYS
  Endif
 Endif
Next I
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
End

################################################################
# Epuration des écrans générés
################################################################

Subprog EPURMSK
Local Char    MACHINE(50), APPLI(50)
Local Char    MASQUE(15)(30000)
Local Integer I , J , NBMASQ , OKSUP , STAT
Local Char    COD(20), CRITERE1(250), CRITERE2(250)
Call MACHINE([F:ADS]DOSSIER,MACHINE,APPLI) From ORDSYS
Call ECR_TRACE("Purge Screens"-time$,0) From GESECRAN
Local File =[F:ADS]DOSSIER+".AMSK"    [AMK], =[F:ADS]DOSSIER+".AMSKZON" [AMZ]
&        , =[F:ADS]DOSSIER+".AMSKPAR" [AMP], =[F:ADS]DOSSIER+".AMSKACT" [AMA]
For COD = "W" , "IA" , "GIA"
 CRITERE1 = 'CODMSK>="'+COD+'" & CODMSK<="'+COD+'ZZZZZ"'
 CRITERE2 = 'CODAFF>="'+COD+'" & CODAFF<="'+COD+'ZZZZZ"'
 Trbegin [AMK]
  Delete [AMK] Where evalue(CRITERE1)
 Commit
 Trbegin [AMZ]
  Delete [AMZ] Where evalue(CRITERE1)
 Commit
 Trbegin [AMA]
  Delete [AMA] Where TYPAFF=1 & evalue(CRITERE2)
 Commit
 Trbegin [AMP]
  Delete [AMP] Where TYPAFF=1 & evalue(CRITERE2)
 Commit
Next COD
For J=0 To [F:ADS]NBRLAN-1
 If [F:ADS]LAN(J)<>"" & filinfo(filpath("E"+[F:ADS]LAN(J),"","",APPLI,"",MACHINE),0)>0
  Call SYSTEME2(MACHINE,"lsadx -a "+APPLI+" E"+[F:ADS]LAN(J)+" srm","",NBMASQ,MASQUE) From ORDSYS
  For I=0 To NBMASQ
   If MASQUE(I)<>""
    System MACHINE+'@ae_rm'-filpath("E"+[F:ADS]LAN(J),MASQUE(I),"*",APPLI,"",MACHINE)
   Endif
  Next I
 Endif
Next J
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
End

################################################################
# Epuration des fenêtres générées
################################################################

Subprog EPURFEN
Local Char CRITERE(250)
Call ECR_TRACE("Purge Windows"-time$,0) From GESECRAN
Local File =[F:ADS]DOSSIER+".AWINDOW" [AWI], =[F:ADS]DOSSIER+".AWINPAR" [AWP]
For CRITERE = 'WIN>="W"   & WIN<="WZZZZZZZZZ"'
&           , 'WIN>="GIA" & WIN<="GIAZZZZZZZ"' 
 Trbegin [AWI]
  Delete [AWI] Where evalue(CRITERE)
 Commit
 Trbegin [AWP]
  Delete [AWP] Where evalue(CRITERE)
 Commit
Next CRITERE
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
End

################################################################
Subprog MEMOS
Local Char    MACHINE(50), APPLI(50)
Local Char    TRAIT(50)(1..5000)
Local Integer I , K , NBTRAIT , OKSUP , STAT
Local Char    MEM(50) , EXT(5)
Call MACHINE([F:ADS]DOSSIER,MACHINE,APPLI) From ORDSYS
Call ECR_TRACE("Translate memos"-time$,0) From GESECRAN
Call SYSTEME2(MACHINE,"lsadx -a "+APPLI+" ETM","",NBTRAIT,TRAIT) From ORDSYS
For I=1 To NBTRAIT
 K = instr(1,TRAIT(I),".")
 If K
  EXT = right$(TRAIT(I),K+1)
  MEM = left$(TRAIT(I),K-1)
 Else
  EXT = ""
  MEM = TRAIT(I)
 Endif
 If vireblc(MEM,2)<>""
  Call ECR_TRACE("Translate mémo"-MEM-EXT,0) From GESECRAN
  Call UTF8("ETM",MEM,EXT,APPLI,1) From MAJUTF8
 Endif
Next I
End
