#<AdxTL>@(#)2.0.0.0 $Revision$
End

######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..200)
Local Integer NBSPE , NBACTS

DETAIL = 0
APPLI = [F:ADS]DOSSIER

MESSA = "Update Data Types"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJATY From DOSMAJATY

MESSA = "Update Activity Codes"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJACV From DOSMAJACV

# Le code activité STT ne doit pas être <4 dans un passage 130 en 140.
MESSA = "Update Activity Code STT"
Call ECR_TRACE(MESSA,0) From GESECRAN
Call ACTIV

MESSA = "Update tables"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJATB From DOSMAJATB

MESSA = "Detoken data"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call DETOKEN(MESSA,APPLI,0,0) From UUDETOKEN

End

######################################################################
Subprog AMAJ
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call TEXTE_ETAT  : # Initialisation des textes des états spécifiques
Call CREPAR      : # Création des paramètres BLOB140 et TEXCLOB140
Call ANAVIG      : # Raz de la table ANAVIG
Call AOBJLST     : # Mise à jour forcée de l'onglet sélection des objets TUN, TPA, etc...
Call COMPTEUR    : # Init type de séquence sur ACODNUM
Call PROFIL      : # Init type de profil fonction
Call PARSTA      : # Récupération des paramètres stats (ancienne table PARSTA2 = PARSTA2 + PARSTALIG
Call SFOOTINV    : # Mise à jour zone SFINUMCAR dans SFOOTINV
Call PFOOTINV    : # Mise à jour zone PFINUMCAR dans PFOOTINV
Call PRICSTRUCT  : # Mise à jour zone BPCBPSCAR dans PRICSTRUCT
Call SPRICCONF   : # Mise à jour zones FLDTYP FLDTYPCPL dans SPRICCONF
Call PPRICCONF   : # Mise à jour zones FLDTYP FLDTYPCPL dans PPRICCONF
Call TABSTTITM   : # Transfert contenu de TABSTTITM dans ATABDIV + creation ATABTAB 20 --> 24 
Call TABSTTBPC   : # Transfert contenu de TABSTTBPC dans ATABDIV + creation ATABTAB 30 --> 34 
Call TABSTTBPS   : # Transfert contenu de TABSTTBPS dans ATABDIV + creation ATABTAB 40 --> 44 
Call ATABTAB     : # Mise à jour zone NUMCAR et LNG dans ATABTAB
Call ATEXTRA     : # Récupération de la table ATEXTRA pour les tables ATABDIV ATABTAB TABUNIT...
Call EPURTRT     : # Epuration des traitements AUT GES et W et CNSxxx et validation des autres
Call EPURMSK     : # Epuration des écrans générés
Call EPURFEN     : # Epuration des fenêtres générées
Call TABCOUNTRY  : # Mise à jour des formats par pays
Call AOBJTAB     : # Nouvelle structure AOBJTAB
Call AWINDOW_CRE : # Création des windows sur les objets qui n'en ont pas
Call AWINDOW     : # Mise à jour zone ROWMSK et BSTD dans AWINDOW
Call AWINBRO     : # Mise à jour de la table AWINBRO à partir des  browser définis dans AOBJET
Call AWINBOUT    : # Mise à jour de la table AWINBOUT à partir des boutons définis dans AWINDOW
Call AOBJTXT     : # Récupération des pièces jointes et mot-clé
Call MAJLNK      : # Remplacement des _ dans les liaisons par des ~
Call AMSK        : # Init nouvelles zones des écrans
Call AMENLOC     : # Màj de la table AMENLOC à partir des menus locaux créés dans APLSTD
Call AMSKADI     : # Rajout dans les écrans du paramètre TABDIV (dépendance) sur le type de donnée ADI
Call ACTION      : # Màj de la table ACTION, champ SPETRT
Call MAJBOUT     : # Rajout boutons mémo dans les fenêtres critères de consultation
Call AMESSAGE    : # Màj nouveaux champs dans table AMESSAGE
Call AUTILIS     : # Rajout des paramètres utilisateurs et mise à jour Profils fonction
Call ALISTE      : # Init du type de requête ALISTEH
Call AFONCTION   : # Rajout du code paramètre (pour gérer les actions suite)
Call CONTACT     : # Pour virer les homonymes
Call MEMOS       : # Conversion des mémos en utf8
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
End

#########################################################################################
## Création des paramètres BLOB140 et TEXCLOB140
#########################################################################################

Subprog CREPAR
Local Char OBJET(15)
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
Call ECR_TRACE("Create parameter BLOB140 & TEXCLOB140",0) From GESECRAN
Trbegin [ADW]
 For OBJET="BLOB140","TEXCLOB140"
  Raz [F:ADW]
  [F:ADW]PARAM = OBJET
  [F:ADW]VALEUR = "Not done"
  [F:ADW]CREUSR = GUSER
  [F:ADW]CREDAT = date$
  Write [ADW]
  If fstat
   Call ERREUR("ADOVAL"-OBJET,1) From DOSDIC
  Endif
 Next OBJET
Commit
Close Local File [ADW]
End

####################################################
Subprog MAJTAB(TABLE)
Value Char TABLE  # FGR 01/02/2010 : X3SUIVI60986

Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]
Local File =[F:ADS]DOSSIER+".ATEXTE"  [ATX]
Local File =[F:ADS]DOSSIER+".ATYPE"   [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV"   [ACV]
Local File =[F:ADS]DOSSIER+".AINDEX"  [ANX]
Local File =[F:ADS]DOSREF+".ATABIND"  [AT2]
If dim(GCOEFTAB)<0
 Global Decimal GCOEFTAB
 GCOEFTAB = 0.5
Endif
Trbegin [ATI]
 Delete [ATI] Where CODFIC=TABLE & CODACT<="X" : # mb 21.10.8 bug 49632
 If fstat
  Call ERREUR("ATABIND",3) From DOSDIC
 Endif
 For [AT2] Where CODFIC=TABLE
  Look [ATI]CODIND=TABLE;[F:AT2]CODIND
  If fstat
   [F:ATI] = [F:AT2]
   Write [ATI]
   If fstat
    Call ERREUR("ATABIND"-TABLE,1) From DOSDIC
   Endif
  Endif
 Next AT2
Commit
Call MAJTAB(TABLE,0) From DOSTAB
End

######################################################################
Subprog ACTIV

Local Char WCOD(20)
WCOD = "STT"

Local File =[F:ADS]DOSREF+".ADOSACT" [ADA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]  

Read [ADA]ADA0 = [F:ADS]DOSSIER;WCOD
If fstat | [F:ADA]DIME>=4 : End : Endif
Trbegin [ADA] , [ACV]
 Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT=WCOD With DIME=4, FLACT=2
 Update [ACV] Where CODACT=WCOD With DIME=4, FLACT=2
 For WCOD="ST1","ST2","ST3","ST4"
  Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT=WCOD With FLACT=2
  Update [ACV] Where CODACT=WCOD With FLACT=2
 Next WCOD
 For WCOD="ST5","ST6","ST7","ST8"
  Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT=WCOD With FLACT=1
  Update [ACV] Where CODACT=WCOD With FLACT=1
 Next WCOD
Commit
End

######################################################################
Subprog MAJ
Call DEPLACE_ETAT
End

## Déplacement des états depuis REPORT vers REPORT/LAN

Subprog DEPLACE_ETAT
Local Integer I , J , K , STAT , NBRPT
Local Char    REPLAN(250) , ORDSYS(250)
Local Char    LISRPT(20)(1..1000)
Local Char    FICORG(250) , FICDES(250)
## Création des répertoires LAN
For I=0 To [F:ADS]NBRLAN-1
 REPLAN = filpath("REPORT",[F:ADS]LAN(I),"",[F:ADS]DOSSIER)
 If filinfo(REPLAN,0)<0
  K = instr(1,REPLAN,"@")
  If K
   ORDSYS = 'ae_mkdir'-'"'+right$(REPLAN,K+1)+'"'
  Else
   ORDSYS = 'ae_mkdir'-'"'+REPLAN+'"'
  Endif
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Endif
Next I
## Déplacement des états
Call SYSTEME2(adxmac(0),"lsadx -a"-[F:ADS]DOSSIER-"REPORT rpt","",NBRPT,LISRPT) From ORDSYS
For I=1 To NBRPT
 FICORG = filpath("REPORT",LISRPT(I),"rpt",[F:ADS]DOSSIER)
 FICDES = filpath(filpath("REPORT",[F:ADS]LAN(0),"",[F:ADS]DOSSIER),LISRPT(I),"rpt",[F:ADS]DOSSIER) 
 Call MOVE(FICORG,FICDES,STAT) From ORDSYS
Next I
End

#########################################################################################
## Initialisation des textes des états spécifiques
## + init nouvelles zones AREPORT
#########################################################################################
Subprog TEXTE_ETAT

Local File =[F:ADS]DOSSIER+".AREPORT" [ARP] , =[F:ADS]DOSSIER+".AREPORTD" [ARD]
&        , =[F:ADS]DOSSIER+".ATEXTE" [ATX]

Local Integer NUM , NUMNXT , RW , DETAIL
Local Char    LIBEL(GLONDES) , CHAMP(10) , OBJET(GLONARP)
Local Char    XX(1)

Call ECR_TRACE(mess(81,125,1)-": AREPORT"-time$,0) From GESECRAN : # maj table

DETAIL = 0
NUMNXT = 0

If GADONIX=2
 XX = ""
Else
 XX = "X"
Endif

Gosub TR1

End

$TR1
GOK = 1
Trbegin [ARP] , [ARD]
 For [ARP]ARP0 Where RPTCOD>=XX
  If DETAIL
   Call ECR_TRACE("entête rptcod="+[F:ARP]RPTCOD,0) From GESECRAN
  Endif
  RW = 0
  If dim([F:ARP]RPTDES)>0 & dim([F:ARP]DES)>0
   NUM   = [F:ARP]RPTDES
   LIBEL = [F:ARP]DES
   CHAMP = "RPTDES"
   OBJET = [F:ARP]RPTCOD
   Gosub NUMERO
   [F:ARP]RPTDES = NUM
  Endif
  If dim([F:ARP]RPTSHO)>0 & dim([F:ARP]DESSHO)>0
   NUM   = [F:ARP]RPTSHO
   LIBEL = [F:ARP]DESSHO
   CHAMP = "RPTSHO"
   OBJET = [F:ARP]RPTCOD
   Gosub NUMERO
   [F:ARP]RPTSHO = NUM
  Endif
  If dim([F:ARP]ENAFLG)>0 & ([F:ARP]ENAFLG<1 or [F:ARP]ENAFLG>2)
   [F:ARP]ENAFLG = 2 : RW = 1
  Endif
  If dim([F:ARP]MULLAN)>0 & ([F:ARP]MULLAN<1 or [F:ARP]MULLAN>2)
   [F:ARP]MULLAN = 2 : RW = 1
  Endif
  If dim([F:ARP]PRTNAT)>0 & [F:ARP]PRTNAT<1
   [F:ARP]PRTNAT = 1 : RW = 1
  Endif
  If dim([F:ARP]EXEBAT)>0 & ([F:ARP]EXEBAT<1 or [F:ARP]EXEBAT>2)
   [F:ARP]EXEBAT = 1 : RW = 1
  Endif
  If RW
   Rewrite [ARP]
   If fstat
    Call ERREUR("AREPORT"-OBJET,2) From DOSDIC
   Endif
  Endif
  If DETAIL
   Call ECR_TRACE("entête rptcod="+[F:ARP]RPTCOD-num$(fstat),0) From GESECRAN
  Endif
 Next
 
 For [ARD]ARD0 Where RPTCOD>=XX
  If DETAIL
   Call ECR_TRACE("ligne rptcod="+[F:ARD]RPTCOD,0) From GESECRAN
  Endif
  RW = 0
  If dim([F:ARD]PARNAM)>0 & dim([F:ARD]PARDES)>0
   NUM   = [F:ARD]PARNAM
   LIBEL = [F:ARD]PARDES
   CHAMP = "PARNAM"
   OBJET = [F:ARD]RPTCOD
   Gosub NUMERO
   [F:ARD]PARNAM = NUM
  Endif
  If RW
   Rewrite [ARD]
   If fstat
    Call ERREUR("AREPORTD"-OBJET,2) From DOSDIC
   Endif
  Endif
  If DETAIL
   Call ECR_TRACE("ligne rptcod="+[F:ARD]RPTCOD-num$(fstat),0) From GESECRAN
  Endif
 Next
Commit
Return

$NUMERO
If NUM=0 & LIBEL<>""
 Read [ATX]TEXTE = GLANGUE;LIBEL
 If !fstat
  NUM = [F:ATX]NUMERO
  RW = 1
 Else
  If NUMNXT=0
   If GADONIX=2 
    Filter [ATX] Where NUMERO<50000 Order By Key CLE=NUMERO;LAN
   Else
    Filter [ATX] Where NUMERO>=50000 Order By Key CLE=NUMERO;LAN
   Endif
   Read [ATX] Last
   Filter [ATX]
   NUMNXT = [F:ATX]NUMERO+1
  Else
   NUMNXT += 1
  Endif
  NUM = NUMNXT
  Raz [F:ATX]
  [F:ATX]LAN    = GLANGUE
  [F:ATX]TEXTE  = LIBEL
  [F:ATX]NUMERO = NUM
  [F:ATX]LONG   = 30
  [F:ATX]NOMOBJ = OBJET
  [F:ATX]NOMZON = CHAMP
  [F:ATX]TYPOBJ = 21
  [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
  Write [ATX]
  If fstat
   Call ERREUR("ATEXTE"-GLANGUE-num$(NUM),1) From DOSDIC
  Endif
  RW = 1
 Endif
 If DETAIL
  Call ECR_TRACE("numéro="+num$(NUM)-num$(fstat),0) From GESECRAN
 Endif
Endif
Return

#########################################################################################
## Effacement du contenu de la table ANAVIG
#########################################################################################
Subprog ANAVIG

Local File =[F:ADS]DOSSIER+".ANAVIG" [ANG]

Call ECR_TRACE(mess(81,125,1)-": ANAVIG"-time$,0) From GESECRAN : # maj table

Trbegin [ANG]
 Delete [ANG] Where 1=1
 If fstat
  Call ERREUR("ANAVIG",3) From DOSDIC
 Endif
Commit

End

#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets TUN, TPA, etc...
#########################################################################################
Subprog AOBJLST

Local Char WOBJET(10)
Local Integer I
Local File =[F:ADS]DOSSIER+".AOBJLST" [AOL] , =[F:ADS]DOSREF+".AOBJLST" [AOL2]
&        , =[F:ADS]DOSSIER+".AOBJET" [AOB]

Call ECR_TRACE(mess(81,125,1)-": AOBJLST"-time$,0) From GESECRAN : # maj table

Trbegin [AOL]

 For WOBJET = "TUN" , "TPA" , "PFI" , "SFI" , "TMD" , "TPT" , "STQ"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

## AST appartient au module développement en V130
 For [AOB] Where ([AOB]MODULE=1 & [AOB]ABREV>="A" & [AOB]ABREV<="AZZ") | [AOB]ABREV="AST"
  Read [AOL]AOL0 = [F:AOB]ABREV
  If !fstat
   Read [AOL2]AOL0 = [F:AOB]ABREV
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-[F:AOB]ABREV,2) From DOSDIC
    Endif
   Endif
  Endif
 Next AOB

 # cas particulier pour remplacer le champ désignation par le texte traduisible
 # sans toucher les autres personnalisations
 Read [AOL]AOL0 = "ITM"
 If !fstat
   Read [AOL2]AOL0 = "ITM"
   If !fstat
    I = find("ITMDES1",SELZON)
    If I & [F:AOL]SELFIC(I-1) = "ITMMASTER"
      [F:AOL]SELFIC(I-1) = "ATEXTRA"
      [F:AOL]SELZON(I-1) = "TEXTE"
      Rewrite [AOL]
      If fstat
       Call ERREUR("AOBJLST"-"ITM",2) From DOSDIC
      Endif
    Endif
   Endif
 Endif
 
Commit

End

#########################################################################################
## Nouveaux champs de ACODNUM
#########################################################################################
Subprog COMPTEUR

Local File =[F:ADS]DOSSIER+".ACODNUM" [ANM]

If dim([F:ANM]SEQ)>0
 Call ECR_TRACE(mess(81,125,1)-": ACODNUM"-time$,0) From GESECRAN : # maj table
 Trbegin [ANM]
  Update [ANM] Where SEQ<1 With SEQ=1
  If fstat
   Call ERREUR("ACODNUM",1) From DOSDIC
  Endif
 Commit
Endif

End

#########################################################################################
## Nouveaux champs de APROFIL
#########################################################################################
Subprog PROFIL

Local File =[F:ADS]DOSSIER+".APROFIL" [APF]

If dim([F:APF]TYPPRF)>0
 Call ECR_TRACE(mess(81,125,1)-": APROFIL"-time$,0) From GESECRAN : # maj table
 Trbegin [APF]
  Update [APF] Where TYPPRF<1 With TYPPRF=1
  If fstat
   Call ERREUR("APROFIL",1) From DOSDIC
  Endif
 Commit
Endif

End

#########################################################################################
## Récupération des paramètres stats (ancienne table PARSTA2 = PARSTA2 + PARSTALIG
#########################################################################################

Subprog PARSTA

Local File =[F:ADS]DOSSIER+".PARSTA2" [PS2], =[F:ADS]DOSSIER+".PARSTALIG" [PSL]

Local Integer I

Call ECR_TRACE(mess(81,125,1)-": PARSTALIG"-time$,0) From GESECRAN : # maj table

Trbegin [PSL]
 For [PS2]
  For I=0 To dim([F:PS2]VARNAM)-1
   If [F:PS2]VARNAM(I)<>"" | [F:PS2]AMTFOR(I)<>"" | [F:PS2]AMTDES(I)<>""
    [F:PSL]COD = [F:PS2]COD
    [F:PSL]NUMLIG = I+1
    [F:PSL]VARNAM = [F:PS2]VARNAM(I)
    [F:PSL]AMTDES = [F:PS2]AMTDES(I)
    [F:PSL]AMTFOR = [F:PS2]AMTFOR(I)
    [F:PSL]CNV = [F:PS2]CNV(I)
    [F:PSL]DEVORG = [F:PS2]DEVORG(I)
    [F:PSL]DEVDES = [F:PS2]DEVDES(I)
    [F:PSL]FRTFLG = [F:PS2]FRTFLG(I) 
    Write [PSL]
    If fstat
     Call ERREUR("PARSTALIG"-[F:PS2]COD-num$([F:PSL]NUMLIG),1) From DOSDIC
    Endif
   Endif
  Next I
 Next
Commit
End

#########################################################################################
## Mise à jour zone NUMCAR dans ATABTAB
#########################################################################################

Subprog ATABTAB

Call ECR_TRACE(mess(81,125,1)-": ATABTAB"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".ATABTAB"   [ADV]

Trbegin [ADV]
 For [ADV]
  [F:ADV]NUMCAR = num$([F:ADV]NUMTAB)
  If [F:ADV]LNG=0    : [F:ADV]LNG    = 3 : Endif
  If [F:ADV]UPDFLG=0 : [F:ADV]UPDFLG = 1 : Endif
  If [F:ADV]LNGFLG=0 : [F:ADV]LNGFLG = 1 : Endif
  Rewrite [ADV]
  If fstat
   Call ERREUR("ATABTAB"-[F:ADV]NUMCAR,1) From DOSDIC
  Endif
 Next
Commit

End

#########################################################################################
## Mise à jour zone SFINUMCAR dans SFOOTINV
#########################################################################################

Subprog SFOOTINV

If filinfo(filpath("FIL","SFOOTINV","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": SFOOTINV"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]

Trbegin [SFI]
 For [SFI]
  [F:SFI]SFINUMCAR = num$([F:SFI]SFINUM)
  Rewrite [SFI]
  If fstat
   Call ERREUR("SFOOTINV"-[F:SFI]SFINUMCAR,2) From DOSDIC
  Endif
 Next
Commit

End

