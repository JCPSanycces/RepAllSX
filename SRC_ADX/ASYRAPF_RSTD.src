#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ASYRAPF


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_JOIN_AFTER"            : Gosub AQUERY_JOIN_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





$AQUERY_DECODE_CRITERIA_AFTER
  Raz NBPRO
  NBPRO += 1
  TBPRO(NBPRO) = "CODPRF"       : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APF.CODPRF "       : TBFIL(NBPRO) = "[F:APF]CODPRF"
  NBPRO += 1
  TBPRO(NBPRO) = "INTPRF"       : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APF.INTPRF"        : TBFIL(NBPRO) = "[LNK_]INTPRF"
 Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[F:APF]CODPRF"
Return

$AQUERY_OPEN_AFTER
Return

$AQUERY_JOIN_AFTER
  Local File    APROFIL [QRY_APF]
  Local Integer I : I=0
  Local Char    TCODPRF(GLONAPM)(1..)
  Local Char    TINTPRF(GLONDES)(1..)

  Close Local File [LNK_]

  For [QRY_APF]APF1

    If I<1 | TCODPRF(I)<>[F:QRY_APF]CODPRF
      I += 1
      TCODPRF(I)    = [F:QRY_APF]CODPRF
      TINTPRF(I)    = func ASYRFNC.TEXTRA("APROFIL","INTPRF","0",TCODPRF(I))
    Endif
  Next

  Local File (Char T1CODPRF(GLONAPM),Char T1INTPRF(GLONDES)) From Variable TCODPRF,TINTPRF As [LNK_]
Return

$AQUERY_TRANS_AFTER
#  this.APF.CODPRF = [LNK_]T1CODPRF
#  this.APF.INTPRF = [LNK_]T1INTPRF
Return

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

