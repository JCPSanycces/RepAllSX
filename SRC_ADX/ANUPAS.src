#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Local Char PARAM(30)(1..2) , VALEUR(10) , PROGSPE(GLONADC)
Call SAISIE_CHAR(VALEUR,PARAM,"ANUPAS","ANUPAS",PROGSPE) From GSAISIE
End

#------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "BOUTON"   : Gosub BOUTON
Endcase
Return

#--------------------------------------------------------------#
$OUVRE
Local Char MESSAGE(250)
Local File AUTILIS [AUS]
If GPROFIL<>GSUPER & GADONIX<>2
 GMESSAGE = mess(145,124,1) : # Fonction réservée à l'administrateur
 GERR = 1 : FIN = 1 : Return
Endif
Return

#--------------------------------------------------------------#
$BOUTON
Case BOUT
 When "1"
  # Annulation du mot de passe de
  OK = 1 : Call OUINON(mess(54,100,1)-[M]USER,OK) From GESECRAN
  If OK=2
   OK = func RAZ_PASSE([M]USER,MESSAGE)
   If OK
    Affzo PASSE
   Endif
   Call MESSAGE(MESSAGE) From GESECRAN
   FIN = 0
  Endif
Endcase
Return

#----------------------------------------------------------------------#
Funprog RAZ_PASSE(USER,MESSAGE)
Value Char    USER
Variable Char MESSAGE
Local Char    PASSE(24)
Local Integer PASOBLI, MAIL , OK
Local File AWRKPAR [AWA] , ADOVAL  [ADW] , AUTILIS [AUS]
Read [ADW]ADW0 = "";"";"PASSWD"
If !fstat : PASOBLI = val([F:ADW]VALEUR) : Endif
If PASOBLI=2
 For [AWA]AWA1 Where TYPEVT=1 & CODEVT="PWD" & ENAFLG=2 & ENAMES=2
  MAIL = 1 : Break
 Next AWA
Endif
Read [AUS]CODUSR = USER
If fstat
 MESSAGE = USER-mess(141,100,1) : # Code utilisateur inexistant
 OK = 0
Else
 Lock ="AUS"+USER With lockwait=0
 If fstat=1
  MESSAGE = mess(30,100,1) : # Opération en cours sur un autre poste
  OK = 0
 Else
  Call DEBTRANS From GLOCK
  Gosub TR_PASSE
  If GOK=1
   OK = 1
   If PASOBLI<>2
    MESSAGE = mess(95,130,1) : # Mot de passe annulé
   Else
    If MAIL & [F:AUS]ADDEML<>""
     GMESSAGE = [L]PASSE
     Call WORKFLOW(1,"PWD","","") From AWRK
     GMESSAGE = ""
    Endif
    MESSAGE = mess(103,124,1)-":"-[F:AUS]USR : # Utilisateur
    MESSAGE += "\"+mess(87,139,1)-":"-PASSE : # Mot de passe provisoire 
   Endif
  Else
   OK = 0
   MESSAGE = mess(18,114,1) : # Transaction abandonnée
  Endif
  Unlock ="AUS"+USER
 Endif
Endif
End OK

#---------------#
$TR_PASSE
GOK=1
Trbegin [AUS]
 Readlock [AUS]CODUSR = [L]USER
 If fstat=1
  GOK=-1 : GLOCK="$AUTILIS"-[L]USER : Goto ROLL_PASSE
 Endif
 If PASOBLI=2
  # Génération d'un mot de passe provisoire
  Call GEN_PASSE([L]USER,[L]PASSE) From PASSE
  If GUSER<>[L]USER
   [F:AUS]PASSDAT = [01/01/1970]
  Else
   [F:AUS]PASSDAT = date$ 
  Endif
  If dim([F:AUS]FLGPASPRV)>0 
   [F:AUS]FLGPASPRV = 2
  Endif
 Else
  [L]PASSE = ""
  [F:AUS]PASSDAT = date$ 
  If dim([F:AUS]FLGPASPRV)>0
   [F:AUS]FLGPASPRV = 1
  Endif
 Endif
 If dim([F:AUS]UPDUSR)>0 : [F:AUS]UPDUSR = GUSER : Endif
 If dim([F:AUS]UPDDAT)>0 : [F:AUS]UPDDAT = date$ : Endif
 [F:AUS]PASSE  = [L]PASSE : Call CRYPT([F:AUS]PASSE) From GESUSER : # on le garde encore pour le web
 [F:AUS]NEWPAS = [L]PASSE : Call CRYPTNEW([F:AUS]NEWPAS) From GESUSER
 [F:AUS]NBRCON = 0
 Rewrite [AUS]
 If fstat
  GOK=0 : Call FSTA("AUS") From GLOCK : Goto AB_PASSE
 Endif
 If PASOBLI=2
  Call ESPION("",7,[F:AUS]NEWPAS,"") From ESPION
  If GOK<1 : Goto AB_PASSE : Endif
 Endif
Commit
Return

$ROLL_PASSE
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_PASSE : Endif
Return

$AB_PASSE
Rollback
Return

#--------------------------------------------------------------------------------#
Funprog DAT_PASSWD(FOLD,USER,PASSWD,MESSAGE)
Value    Char FOLD , USER , PASSWD
Variable Char MESSAGE
Local Char    PASSVIDE(24) , DOSSIER(30) , UTIL(30)
Local Integer VIDE

If dim(GFUSION)<=0 or GFUSION
 End 0
Endif

DOSSIER = [L]FOLD : If DOSSIER = "" : DOSSIER = nomap : Endif
UTIL    = [L]USER : If UTIL    = "" : UTIL    = GUSER : Endif

Local File =DOSSIER+".ADOVAL" [ADW_] , =DOSSIER+".AUTILIS" [AUS_]

Read [AUS_]CODUSR=UTIL
If fstat
 MESSAGE = UTIL-":"-mess(141,100,1) : # Code utilisateur inexistant
 End 1
Endif

# Mot de passe provisoire

If dim([F:AUS]FLGPASPRV)>0 and [F:AUS]FLGPASPRV=2
 MESSAGE = mess(106,130,1) : # Vous devez modifier votre mot de passe provisoire
 End 1
Endif

# Mot de passe obligatoire ?

If PASSWD=""
 PASSVIDE = ""
 VIDE = 0
 Call CTLPAS(PASSVIDE,VIDE) From GESUSER
 If VIDE
  Read [ADW_]ADW0 = "";"";"PASSWD"
  If !fstat & val([F:ADW_]VALEUR)=2
   MESSAGE = mess(100,100,1) : # Vous devez saisir un mot de passe
   End 1
  Endif
 Endif
Endif

# Mot de passe périmé ?

If dim([F:AUS_]PASSDAT)>0
 Read [ADW_]ADW0 = "";"";"CHGPASS"
 If !fstat & val([F:ADW_]VALEUR)>0
  If [F:AUS]PASSDAT+val([F:ADW_]VALEUR)<date$
   Call CTLPAS(PASSVIDE,VIDE) From GESUSER
   If !VIDE
    MESSAGE = mess(214,100,1) : # Mot de passe périmé
    End 1
   Endif
  Endif
 Endif
Endif

End 0

#---------------------------------#
Subprog AV_PASSE(VALEUR)
Variable Char    VALEUR()
Local Char PASSE(24)
Read [F:AUS]CODUSR=[M]USER
If !fstat
 [L]PASSE = [F:AUS]NEWPAS
 If [L]PASSE<>""
  Call VARPSE([L]PASSE) From GESUSER
 Endif
 VALEUR = [L]PASSE
Endif
End
