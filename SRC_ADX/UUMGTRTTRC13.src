#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC13          Moulinette de Migration              Module TRC  #
#                                                                        #
#          Update of new field BOMALTTYP                                 #
#                                                                        #
##########################################################################
# From TRCMAJ30  : UPDPDH   : Update of PDPHEA    new field BOMALTTYP    #
#                              +  new flags instead of old CLSTYP        #
##########################################################################
#### ATTENTION: table PDPHEA appartient au module GPAO                ####
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC13") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC13(WDOSSIER)
  Call MAJ_UUMGTRTTRC13(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC13(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC13(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC13(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

GOK=1
Gosub LOA_BOM From UUMGTRTTRC00

Gosub UPDPDH
If GOK<=0
    Call ECR_TRACE("UUMGTRTTRC13 table PDPHEA Incorrectly Processed : Update PDH"-WDOSSIER,1) From GESECRAN
Endif
End
##########################################################################
Subprog RAZ_UUMGTRTTRC13(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(7)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"PDPHEA",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","PDPHEA","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_ Raz table PDPHEA"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"PDPHEA",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC13",ERR) From TRTMIG
Endif

End


###############################################################################
# UPDPDH : - MAJ des infos de la catégorie CLSTYP
#          - INIT du type d'alternative BOMALTTYP
###############################################################################
# Paramètres E : WDOSSIER   = Dossier
###############################################################################
$UPDPDH
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(7)<>2 : # Modules 9=Tronc commun et 8=GPAO
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If filinfo(filpath("FIL","PDPHEA","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMPDHM
Call MIGTABNAME (WDOSSIER,"PDPHEA",WNAMPDHM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMPDHM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC13 tables PDH Process : Update PDH") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC13:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"PDPHEA",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:PDH])  = 0 : Local File =WDOSSIER+".PDPHEA"      [PDH]  : Endif   # Fichier X3 "Vide"
If clalev([F:PDHM]) = 0 : Local File =WDOSSIER+"."+WNAMPDHM   [PDHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:ITM])  = 0 : Local File =WDOSSIER+".ITMMASTER"   [ITM]  : Endif   # Articles migrés pour recup des *FLG

#-----  Déclaration des variables -----#
Local Char WTAB_PDH (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_PDH

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC13",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [PDHM] With [ITM]ITM0~=[F:PDHM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:PDHM]STOFCY;[F:PDHM]ITMREF

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC13" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PDH00
Raz NB
# Issue 80145 Key=STOFCY+ITMREF instead of ITMREF+STOFCY
If STOP=1
 STOP = 2
 CRITERE = "[F:PDHM]STOFCY=TABMIGKEY(1) & [F:PDHM]ITMREF>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PDHM]STOFCY>TABMIGKEY(1) "
Else
 CRITERE = "1=1"
Endif

Trbegin [PDH]
GOK = 1

For [LNK]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_PDH : Endif
  Endif

  #Raz [F:PDH]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_PDH
  Endif

  [F:PDH] = [F:PDHM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_PDH
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub PDH_STK : # pour stocker ref
      WriteB [F:PDH]
  Else
      Write [F:PDH]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File PDPHEA, Error ="-num$(fstat),1) From GESECRAN
      Gosub PDH_ERRTRA : # pour afficher les ref
    Else
      Call ECR_TRACE("File PDPHEA(ITMREF/STOFCY)"-[F:PDH]ITMREF-"/"-[F:PDH]STOFCY+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
   # Issue 80145 Key=STOFCY+ITMREF instead of ITMREF+STOFCY
    TABMIGKEY(1) = [F:PDHM]STOFCY
    TABMIGKEY(2) = [F:PDHM]ITMREF
    STOP=1
    Break
  Endif
$NEXT_PDH
Next

$END_PDH
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC13",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:PDH]
    If fstat
        Call ECR_TRACE("File PDPHEA, Error ="-num$(fstat),1) From GESECRAN
        Gosub PDH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_PDH : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/ACLE4/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_PDH
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC13",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PDH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PDH]
Close Local File [PDHM]
Close Local File [ITM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"PDPHEA",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC13") From TRTMIG
Call ECR_TIME("UUMGTRTTRC13:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$PDH_STK
Call STK (WTAB_PDH,WCPT_PDH,[F:PDH]STOFCY-"/"-[F:PDH]ITMREF) From TRTMIG
Return

#######################################################################
$PDH_ERRTRA
Call ERRTRA (WTAB_PDH,WCPT_PDH,"File PDPHEA(STOFCY/ITMREF)=") From TRTMIG
Return

##########################################################################
$RAZV6_PDH
Raz [F:PDH]BOMALTTYP
Return

#######################################################################
# Code extrait de TRCMAJ30 - table PDPHEA
#######################################################################
$MAJV6_PDH
[F:PDH]MFGFLG = [F:ITM]MFGFLG
[F:PDH]SCPFLG = [F:ITM]SCPFLG
[F:PDH]SCSFLG = [F:ITM]SCSFLG
[F:PDH]PHAFLG = [F:ITM]PHAFLG
[F:PDH]GENFLG = [F:ITM]GENFLG
[F:PDH]TOOFLG = [F:ITM]TOOFLG
[F:PDH]DLVFLG = [F:ITM]DLVFLG
[F:PDH]PURFLG = [F:ITM]PURFLG
[F:PDH]SALFLG = [F:ITM]SALFLG
[F:PDH]INTFLG = [F:ITM]INTFLG
If [F:PDH]BOMALT > 0 & [F:PDH]BOMALTTYP=0
   [F:PDH]BOMALTTYP=WBOMALTTYP([F:PDH]BOMALT)
Endif
#[F:PDH]UPDUSR=GUSER
#[F:PDH]UPDDAT=date$
Return
