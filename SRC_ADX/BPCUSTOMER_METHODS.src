#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
  #
  Gosub AREAD_AFTER_BPAPRI
  #--Chargement du tableau des éléments de facturation
  Gosub LOAD_INVDTA

  #--Chargement de la partie "Commande"
  # C'est à faire dans les classes de représentation
  #IRET = func BPCUSTOMER_PROG.LOAD_OST(this.BPCNUM, this.ACTX, "", "", AVOID.ACHAR, OSTCTL, OSTAUZ, OST, CDTISR, CDTISRDAT, ORDMINAMT)
  #------------------------------------------
  #--Chargement des propriétés _LEG liée aux propriétés déclinées par législation
  Gosub LOAD_VACBPR_LEG From BPCUSTOMER_PROPERTIES
  Gosub LOAD_DEP_LEG    From BPCUSTOMER_PROPERTIES
  Gosub LOAD_PTE_LEG    From BPCUSTOMER_PROPERTIES
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
Return

#######################################################################################
$AREAD_AFTER_BPAPRI
Local Integer NI
Local Integer ILINE
Local Integer NE
Local Integer NFOUND

  NFOUND = [V]CST_ANO
  NE = 0
  For NI = 1 To maxtab(this.BPR.BPA)
    If this.BPR.BPA(NI).BPAADDFLG = [V]CST_AYES Then
      NE = NI
    Endif
    If this.BPR.BPA(NI).BPAADD = this.BPAADD Then
      If this.BPAPRI(1) = null Then
        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      Else
        ILINE = 1
      Endif
      this.BPAPRI(ILINE) = this.BPR.BPA(NI)
      NFOUND = [V]CST_AYES
      Break
    Endif
  Next NI
  If NFOUND = [V]CST_ANO Then
    If NE = 0 Then
      If maxtab(this.BPR.BPA) > 0 Then
        NE = 1
      Endif
    Endif
    If NE > 0 Then
      If this.BPAPRI(1) = null Then
        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      Else
        ILINE = 1
      Endif
      this.BPAPRI(ILINE) = this.BPR.BPA(NE)
    Endif
  Endif
Return

#######################################################################################
$AREAD_AFTER_C_INVDTAAMT
Local Integer IRET

  #--Chargement du tableau des éléments de facturation

  #--Chargement des propriétés _LEG liée aux propriétés déclinées par législation
Return

#######################################################################################
$AREAD_AFTER_BPD
Local Integer IRET

  #--Initialisation du flag "Client livré par défaut"
  If this.APARENT = null
    Return
  Endif
  If dim(this.APARENT.BPDADD) > 0
    If this.APARENT.BPDADD = this.BPAADD
      this.BPDADDFLG = [V]CST_AYES
    Endif
  Endif
  #--Initialisation de VACBPR_LEG de BPDLVCUST
  Gosub LOAD_VACBPR_LEG From BPDLVCUST_CSTD
Return

#######################################################################################
$LOAD_INVDTA
Local Integer IRET
Local Integer I
Local Integer NBPOSTE

  NBPOSTE = maxtab(this.C_INVDTAAMT)
  Call  SAISFOOT (1,this,"C_BPCUSTOMER",NBPOSTE,this.CHGTYP,"",this.CUR,"NON") From SUBSFIT_SYRA
  # chargement devise client sur ligne montant
  For I = 1 To maxtab(this.C_INVDTAAMT)
    If this.C_INVDTAAMT(I)<>null and find(this.C_INVDTAAMT(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
      If this.C_INVDTAAMT(I).INVDTATYP = 3 :#--en %
        this.C_INVDTAAMT(I).INVDTACUR =  AVOID.ACHAR
      Else
        this.C_INVDTAAMT(I).INVDTACUR = this.CUR
      Endif
    Endif
  Next
Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

#######################################################################################
$LOCK_UNLOCK
    #Fmethod LOCK_UNLOCK(BPCNUM,PACTION)
    #Value Char BPCNUM ()
    #Value TINYINT PACTION
    #Local Integer ARET_VALUE
    #Gosub LOCK_UNLOCK From WMC0BPCUSTOMER
    #End [L]ARET_VALUE
  # -----------------------------------------------------------------------------------
  # PACTION=1 => Lock
  # PACTION=2 => Unlock
  # -----------------------------------------------------------------------------------
Local Integer  WLOG         : WLOG=[V]CST_ANO
Local Char     WERR(255)
Local Integer  WRET
Local Char SBPCTOREAD(type(this.BPCNUM)-10)
Local Integer IADXLOG

  # ----------------------------------------------------------------
  #> Diagnosis log opening
  #  ---------------------
  If WLOG = [V]CST_AYES Then
    Local Integer ALOG_RET
    Local Instance ALOG Using C_ALOG

    ALOG = NewInstance With C_ALOG
    ALOG_RET = fmet ALOG.ASETNAME("OREAD" + "_" + this.ACTX.USER + "_" + num$(adxuid(2)))
    ALOG_RET = fmet ALOG.ABEGINLOG("Customer log - OREAD Operation")
  Endif
  # ----------------------------------------------------------------
  # En premier, au moins l'action doit être gérée
  If PACTION <> 1 and PACTION <> 2 Then
    # Action inconnue (cas de bug programme)
    ERM = mess(1013,196,1)
    Goto LOCK_UNLOCK_ERROR
  Endif
  If BPCNUM = "" Then
    # Référence client obligatoire
    ERM = mess(185,187,1)
    Goto LOCK_UNLOCK_ERROR
  Endif
  # ----------------------------------------------------------------
  # Traitement du tiers risque (qui peut être différent)
  Local File BPCUSTOMER [BPC]
  Read [BPC]BPC0=[L]BPCNUM
  If fstat Then
    ERM = mess(297,196,1) - "(" + [L]BPCNUM + ")"
    Goto LOCK_UNLOCK_ERROR
  Endif
  # ----------------------------------------------------------------
  If [F:BPC]BPCRSK <> [F:BPC]BPCNUM Then
    SBPCTOREAD = [F:BPC]BPCRSK
  Else
    SBPCTOREAD = [F:BPC]BPCNUM
  Endif
  # ----------------------------------------------------------------
  # FGR 14/02/2014 : X3SUIVI96889 : (début) pour le moment on schunte AUPDATE
  Read [BPC]BPC0=SBPCTOREAD
  If fstat Then
    # Erreur de lecture
    WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AREAD: Key" - SBPCTOREAD
    WERR = mess(49,125,1) - SBPCTOREAD
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    ARET_VALUE = [V]CST_AERROR
    WRET = [V]CST_ANO
  Else
    Case PACTION
      When 1
        # Lock
        If [F:BPC]OSTCTL = 3 Then
          # Client déjà bloqué
          WERR = mess(78,117,1) - ":" - [F:BPC]BPCNUM - ":" - mess(183,187,1)
          Goto LOCK_UNLOCK_ERROR
        Endif
      When 2
        # Unlock
        If [F:BPC]OSTCTL <> 3 Then
          WERR = mess(78,117,1) - ":" - [F:BPC]BPCNUM - ":" - mess(184,187,1)
          Goto LOCK_UNLOCK_ERROR
        Endif
    Endcase
    # --------------------------
    # Action
    Case PACTION
      When 1
        # Lock
        [F:BPC]OSTCTL = 3 # Bloqué/Hold
      When 2
        # Unlock
        [F:BPC]OSTCTL = 1 # Contrôlé/Check
    Endcase
    # --------------------------
    # Florent : regarder s'il n'y a pas déjà une transaction en cours
    If adxlog = 1 Then
      IADXLOG = 1
    Else
      IADXLOG = 0
    Endif
    If IADXLOG = 0 Then
      Trbegin [F:BPC]
    Endif
    #
    Rewrite [F:BPC]
    If fstat Then
      WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AUPDATE: Key" - [F:BPC]BPCNUM
      WERR = mess(50,176,1) - [F:BPC]BPCNUM
      ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
      ARET_VALUE = [V]CST_AERROR
      WRET = [V]CST_ANO
      If IADXLOG = 0 Then
        Rollback
      Endif
    Else
      WRET = [V]CST_AOK
      If IADXLOG = 0 Then
        Commit
      Endif
    Endif
  Endif
#  # -------
#  WRET = fmet this.AREAD(SBPCTOREAD)
#  If WRET <> [V]CST_AOK Then
#    WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AREAD: Key" - SBPCTOREAD
#    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
#    ARET_VALUE = [V]CST_AERROR
#  Else
#    # C'est là que ça se passe
#    # --------------------------
#    # Contôles
#    If WRET = [V]CST_AOK Then
#      Case PACTION
#        When 1
#          # Lock
#          If this.OSTCTL = 3 Then
#            # Client déjà bloqué
#            WERR = mess(78,117,1) - ":" - this.BPCNUM - ":" - mess(183,187,1)
#            Goto LOCK_UNLOCK_ERROR
#          Endif
#        When 2
#          # Unlock
#          If this.OSTCTL <> 3 Then
#            WERR = mess(78,117,1) - ":" - this.BPCNUM - ":" - mess(184,187,1)
#            Goto LOCK_UNLOCK_ERROR
#          Endif
#      Endcase
#      # --------------------------
#      # Action
#      Case PACTION
#        When 1
#          # Lock
#          this.OSTCTL = 3 # Bloqué/Hold
#        When 2
#          # Unlock
#          this.OSTCTL = 1 # Contrôlé/Check
#      Endcase
#      # --------------------------
#      WRET = fmet this.AUPDATE
#      If WRET <> [V]CST_AOK Then
#        WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AUPDATE: Key" - this.BPCNUM
#        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
#        ARET_VALUE = [V]CST_AERROR
#      Endif
#    Endif
#  Endif
  # FGR 14/02/2014 : X3SUIVI96889 : (fin)
  # ----------------------------------------------------------------
  If WRET = [V]CST_AOK Then
    Case PACTION
      When 1
        WERR = mess(78,117,1) - this.BPCNUM - ":" - mess(181,187,1)
      When 2
        WERR = mess(78,117,1) - this.BPCNUM - ":" - mess(182,187,1)
    Endcase
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AINFO)
    ARET_VALUE = [V]CST_AOK
  Endif
  # ----------------------------------------------------------------
  #> log closing
  #  -----------
  If WLOG = [V]CST_AYES Then
    ALOG_RET = fmet ALOG.APUTINSTERRS(this)
    ALOG_RET = fmet ALOG.AENDLOG()
    FreeInstance ALOG
  Endif
  # ----------------------------------------------------------------
Return

#######################################################################################
$OLD_LOCK_UNLOCK
    #Fmethod LOCK_UNLOCK(BPCNUM,PACTION)
    #Value Char BPCNUM ()
    #Value TINYINT PACTION
    #Local Integer ARET_VALUE
    #Gosub LOCK_UNLOCK From WMC0BPCUSTOMER
    #End [L]ARET_VALUE
  # -----------------------------------------------------------------------------------
  # PACTION=1 => Lock
  # PACTION=2 => Unlock
  # -----------------------------------------------------------------------------------
Local Integer  WLOG         : WLOG=[V]CST_ANO
Local Char     WERR(255)
Local Integer  WRET
Local Instance BPC Using C_BPCUSTOMER

  # ----------------------------------------------------------------
  #> Diagnosis log opening
  #  ---------------------
  If WLOG = [V]CST_AYES Then
    Local Integer ALOG_RET
    Local Instance ALOG Using C_ALOG

    ALOG = NewInstance With C_ALOG
    ALOG_RET = fmet ALOG.ASETNAME("OREAD" + "_" + this.ACTX.USER + "_" + num$(adxuid(2)))
    ALOG_RET = fmet ALOG.ABEGINLOG("Customer log - OREAD Operation")
  Endif
  # ----------------------------------------------------------------
  # En premier, au moins l'action doit être gérée
  If PACTION <> 1 and PACTION <> 2 Then
    # Action inconnue (cas de bug programme)
    ERM = mess(1013,196,1)
    Goto LOCK_UNLOCK_ERROR
  Endif
  If BPCNUM = "" Then
    # Référence client obligatoire
    ERM = mess(185,187,1)
    Goto LOCK_UNLOCK_ERROR
  Endif
  # ----------------------------------------------------------------
  BPC = NewInstance With C_BPCUSTOMER
  WRET = fmet BPC.AREAD(BPCNUM)
  If WRET <> [V]CST_AOK Then
    WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AREAD: Key" - BPCNUM
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    ARET_VALUE = [V]CST_AERROR
  Else
    # C'est là que ça se passe
    # --------------------------
    # Traitement du tiers risque (qui peut être différent)
    Local Char SBPCRSK(type(BPC.BPCRSK)-10)

    If BPC.BPCRSK <> BPC.BPCNUM Then
      SBPCRSK = BPC.BPCRSK
      FreeInstance BPC
      BPC = NewInstance With C_BPCUSTOMER
      WRET = fmet BPC.AREAD(SBPCRSK)
      If WRET <> [V]CST_AOK Then
        WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AREAD: Key" - SBPCRSK
        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
        ARET_VALUE = [V]CST_AERROR
      Endif
    Endif
    # --------------------------
    # Contôles
    If WRET = [V]CST_AOK Then
      Case PACTION
        When 1
          # Lock
          If BPC.OSTCTL = 3 Then
            # Client déjà bloqué
            WERR = mess(78,117,1) - ":" - BPC.BPCNUM - ":" - mess(183,187,1)
            FreeInstance BPC
            Goto LOCK_UNLOCK_ERROR
          Endif
        When 2
          # Unlock
          If BPC.OSTCTL <> 3 Then
            WERR = mess(78,117,1) - ":" - BPC.BPCNUM - ":" - mess(184,187,1)
            FreeInstance BPC
            Goto LOCK_UNLOCK_ERROR
          Endif
      Endcase
      # --------------------------
      # Action
      Case PACTION
        When 1
          # Lock
          BPC.OSTCTL = 3 # Bloqué/Hold
        When 2
          # Unlock
          BPC.OSTCTL = 1 # Contrôlé/Check
      Endcase
      # --------
      WRET = fmet BPC.AUPDATE
      If WRET <> [V]CST_AOK Then
        WERR = "[BPCUSTOMER-LOCK_UNLOCK] Error BPC.AUPDATE: Key" - BPC.BPCNUM
        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
        ARET_VALUE = [V]CST_AERROR
      Endif
    Endif
  Endif
  # ----------------------------------------------------------------
  If WRET = [V]CST_AOK Then
    Case PACTION
      When 1
        WERR = mess(78,117,1) - BPC.BPCNUM - ":" - mess(181,187,1)
      When 2
        WERR = mess(78,117,1) - BPC.BPCNUM - ":" - mess(182,187,1)
    Endcase
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AINFO)
    ARET_VALUE = [V]CST_AOK
  Endif
  FreeInstance BPC
  # ----------------------------------------------------------------
  #> log closing
  #  -----------
  If WLOG = [V]CST_AYES Then
    ALOG_RET = fmet ALOG.APUTINSTERRS(this)
    ALOG_RET = fmet ALOG.AENDLOG()
    FreeInstance ALOG
  Endif
  # ----------------------------------------------------------------
Return

#**************************************************************************************
#* Error management : Information
#**************************************************************************************!
$LOCK_UNLOCK_INFO
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AINFO)
  ARET_VALUE = [V]CST_AINFO
Return

#**************************************************************************************
#* Error management : Warning
#**************************************************************************************!
$LOCK_UNLOCK_WARNING
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
  ARET_VALUE = [V]CST_AWARNING
Return

#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
$LOCK_UNLOCK_ERROR
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  ARET_VALUE = [V]CST_AERROR
Return

