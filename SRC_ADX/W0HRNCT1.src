#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRNCT1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRNCT"
 Call DEFHRNCT([M]COD,GCURLEG,GSOCIETE) From SUBHRNCT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]COD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]COD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 15886 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRNCT"
   Call CONTHRNCT([M]COD,GCURLEG,GSOCIETE) From SUBHRNCT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 15886 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]COD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]COD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 15886 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJW"
     PARAM(1) = "HRNCT"
     Local Char    VALEUR(250)
     VALEUR = [M]COD
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
     [M]COD = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 15886 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBHRNCT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"HRNATCON","DESAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"HRNATCON","SHOAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone GRP
mkstat = 0
zoncou = "GRP"
indice = 0
If varmode([M]GRP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!C",[M]GRP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CGRPCPYLEG"
  Call C_GRPCPYLEG([M]GRP,GCURLEG) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CODACS
mkstat = 0
zoncou = "CODACS"
indice = 0
If varmode([M]CODACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DEFVAL
mkstat = 0
zoncou = "DEFVAL"
indice = 0
IMPENT = [M]DEFVAL
If varinit([M]DEFVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]DEFVAL,indice)=0
 [M]DEFVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFVAL(indice)
 Endif
Endif
[M]DEFVAL = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone CODN4H
mkstat = 0
zoncou = "CODN4H"
indice = 0
If varmode([M]CODN4H,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODN4H" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CODDUE
mkstat = 0
zoncou = "CODDUE"
indice = 0
If varmode([M]CODDUE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODDUE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TYPCON
mkstat = 0
zoncou = "TYPCON"
indice = 0
IMPENT = [M]TYPCON
If varinit([M]TYPCON,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPCON,indice)=0
 [M]TYPCON(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPCON" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPCON(indice)
 Endif
Endif
[M]TYPCON = IMPENT

## Zone TYPCDD
mkstat = 0
zoncou = "TYPCDD"
indice = 0
IMPENT = [M]TYPCDD
If varinit([M]TYPCDD,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPCDD,indice)=0
 [M]TYPCDD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPCDD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPCDD(indice)
 Endif
Endif
[M]TYPCDD = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRNCT1"
Return

