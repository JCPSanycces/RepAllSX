#<AdxTL>@(#)0.0.0.0 $Revision$ 
##################################################################
# UTIACH112754 : Service products : ITMKND field Init            #
#           Module =  Purchase                                   #
##################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Product type Initialization") From LECFIC
 Call MAJ_UTIACH112754(DOSSIER)

 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


#####################################################################################
Subprog MAJ_UTIACH112754(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIACH112754 : Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:ITM])=0  : Local File =DOSSIER+".ITMMASTER"  [ITM]  : Endif
If clalev([F:PSD])=0  : Local File =DOSSIER+".PREQUISD"   [PSD]  : Endif
If clalev([F:POQ])=0  : Local File =DOSSIER+".PORDERQ"    [POQ]  : Endif
If clalev([F:POC])=0  : Local File =DOSSIER+".PORDERC"    [POC]  : Endif
If clalev([F:UOQ])=0  : Local File =DOSSIER+".UPORDERQ"   [UOQ]  : Endif
If clalev([F:UOC])=0  : Local File =DOSSIER+".UPORDERC"   [UOC]  : Endif
If clalev([F:PTD])=0  : Local File =DOSSIER+".PRECEIPTD"  [PTD]  : Endif
If clalev([F:PND])=0  : Local File =DOSSIER+".PRETURND"   [PND]  : Endif
If clalev([F:PID])=0  : Local File =DOSSIER+".PINVOICED"  [PID]  : Endif
If clalev([F:PID2])=0 : Local File =DOSSIER+".PINVOICED"  [PID2] : Endif

Local Integer NPSD, NPOQ, NPOC, NUOQ, NUOC, NPTD, NPND, NPID
Local Char     CLE1(GLONPOH), CRITERE(90)
Local Integer  CLE2, COMPTEUR, STOP
Local Integer  TESTMOD,I
# Pour tester sans mise à jour de la base
#TESTMOD = 2
TESTMOD = 1

Call DEBTRANS From GLOCK

Trbegin [PSD],[POQ],[UOQ],[POC],[UOC],[PTD]
Raz NPSD, NPOQ, NPOC, NUOQ, NUOC, NPTD

# Update PREQUISD
If TESTMOD = 2
  I = rowcount([F:PSD])
  Infbox "Nombre de lignes de DA = " - num$(I)
Endif
Update [F:PSD] Where ITMKND = 0 With ITMKND = 1
NPSD = adxuprec

# Update PORDERQ
If TESTMOD = 2
  I = rowcount([F:POQ])
  Infbox "Nombre de lignes de cde = " - num$(I)
Endif
Update [F:POQ] Where POHTYP = 1 & LINTYP <> 3  & VCRTYPORI <> 10 & ITMKND = 0 With ITMKND = 1
NPOQ = adxuprec
Update [F:POQ] Where POHTYP = 1 & LINTYP = 1   & VCRTYPORI =  10 & ITMKND = 0 With ITMKND = 2
NPOQ += adxuprec
Update [F:POQ] Where POHTYP = 1 & LINTYP = 3   & ITMKND = 0 With ITMKND = 2
NPOQ += adxuprec
Update [F:POQ] Where POHTYP = 2 & ITMKND = 0   With ITMKND = 1
NPOQ += adxuprec

# Update UPORDERQ
If TESTMOD = 2
  I = rowcount([F:UOQ])
  Infbox "Nombre de lignes historique de cde = " - num$(I)
Endif
Update [F:UOQ] Where POHTYP = 1 & LINTYP <> 3  & VCRTYPORI <> 10 & ITMKND = 0 With ITMKND = 1
WUOQ = adxuprec
Update [F:UOQ] Where POHTYP = 1 & LINTYP = 1   & VCRTYPORI =  10 & ITMKND = 0 With ITMKND = 2
NUOQ = +adxuprec
Update [F:UOQ] Where POHTYP = 1 & LINTYP = 3   & ITMKND = 0 With ITMKND = 2
NUOQ += adxuprec
Update [F:UOQ] Where POHTYP = 2 & ITMKND = 0   With ITMKND = 1
NUOQ += adxuprec

# Update PORDERC
If TESTMOD = 2
  I = rowcount([F:POC])
  Infbox "Nombre de lignes de contrat = " - num$(I)
Endif
Update [F:POC] Where ITMKND = 0 With ITMKND = 1
NPOC = adxuprec

# Update UPORDERC
If TESTMOD = 2
  I = rowcount([F:UOC])
  Infbox "Nombre de lignes historique de contrat = " - num$(I)
Endif
Update [F:UOC] Where ITMKND = 0 With ITMKND = 1
NUOC = adxuprec

# Update PRECEIPTD
If TESTMOD = 2
  I = rowcount([F:PTD])
  Infbox "Nombre de lignes réceptions = " - num$(I)
Endif
Update [F:PTD] Where LINTYP <> 3 & VCRTYPORI <> 10 & ITMKND = 0 With ITMKND = 1
NPTD = adxuprec
Update [F:PTD] Where LINTYP = 1  & VCRTYPORI  = 10 & ITMKND = 0 With ITMKND = 1
NPTD += adxuprec
Update [F:PTD] Where LINTYP = 3  & ITMKND = 0 With ITMKND = 2
NPTD += adxuprec

If TESTMOD = 2 : Rollback : Else : Commit : Endif

# Update PRETURND
Gosub UPDPND

# Update PINVOICED
Gosub UPDPID

Close Local File [ITM]
Close Local File [PSD]
Close Local File [POQ]
Close Local File [UOQ]
Close Local File [POC]
Close Local File [UOC]
Close Local File [PTD]
Close Local File [PND]
Close Local File [PID]
Close Local File [PID2]

Call ECR_TRACE("UTIACH112754: "+num$(NPSD)+" PREQUISD  records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NPOQ)+" PORDERQ   records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NUOQ)+" UPORDERQ  records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NPOC)+" PORDERC   records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NUOC)+" UPORDERC  records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NPTD)+" PRECEIPTD records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NPND)+" PRETURND  records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754: "+num$(NPID)+" PINVOICED records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH112754 : Process End on : "+DOSSIER,0) From GESECRAN

End


##########################################################################################
$UPDPND
Raz NPND
Raz CLE1, CLE2, STOP

#-----
$BOUCLE_PND
If STOP=1
  CRITERE='PNHNUM="'+CLE1+'" & PNDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE += " & ITMKND = 0"
Raz COMPTEUR
Call DEBTRANS From GLOCK
Trbegin [PND]
#
If TESTMOD = 2
  I = rowcount([F:PND])
  Infbox "Nombre de lignes retours = " - num$(I)
Endif
Link [F:PND] With [ITM]ITM0 = [F:PND]ITMREF As [LNK]
&    Where evalue(CRITERE)
Columns [LNK]([PND]PNHNUM,[PND]PNDLIN,[PND]ITMKND,[ITM]SCSFLG) Extended
For [LNK]
  Readlock [F:PND]PND0 Curr
  [F:PND]ITMKND = 1
  If [F:PND]PTHNUM <> ""
    Gosub LECT_PTDPND
    If [F:PTD]ITMKND > 1 : [F:PND]ITMKND = [F:PTD]ITMKND : Endif
  Else
    If [F:ITM]SCSFLG > 1 : [F:PND]ITMKND = 3 : Endif
  Endif
  Rewrite [F:PND]
  If fstat
    Call FSTA("PND") From GLOCK
  Else
    NPND+=1
    COMPTEUR += 1
    If COMPTEUR>GMAXUPDTRS : CLE1=[F:PND]PNHNUM : CLE2=[F:PND]PNDLIN : STOP=1 : Break : Endif
  Endif
Next
If TESTMOD = 2 : Rollback : Else : Commit : Endif
If STOP Goto BOUCLE_PND : Endif
Return

##################################
$LECT_PTDPND
  If [F:PTD]PTHNUM<>[F:PND]PTHNUM | [F:PTD]PTDLIN <> [F:PND]PTDLIN
    Read [PTD] PTD0= [F:PND]PTHNUM;[F:PND]PTDLIN : If fstat  Raz [F:PTD] : Endif
  Endif
Return

##########################################################################################
$UPDPID
Raz NPID
Raz CLE1, CLE2, STOP

#-----
$BOUCLE_PID
If STOP=1
  CRITERE='NUM="'+CLE1+'" & PIDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE += " & [F:PID]ITMKND = 0"
Raz COMPTEUR
Call DEBTRANS From GLOCK
Trbegin [PID]
#
If TESTMOD = 2
  I = rowcount([F:PID])
  Infbox "Nombre de lignes factures = " - num$(I)
Endif
Link [F:PID] With [ITM]ITM0 = [F:PID]ITMREF
&    As [LNK]
&   Where evalue(CRITERE)
Columns [LNK]([PID]NUM,[PID]PIDLIN,[PID]ITMKND,[PID]ITMREF,[ITM]SCSFLG) Extended
For [LNK]
  Readlock [F:PID]PID0 Curr
  [F:PID]ITMKND = 1
  If [F:PID]TYPORI <> 5
    Case [F:PID]TYPORI :
      When 1,6 :
       Gosub LECT_POQPID
        If [F:POQ]ITMREF = [F:PID]ITMREF & [F:POQ]ITMKND > 1
           [F:PID]ITMKND = [F:POQ]ITMKND
        Else
            If [F:ITM]SCSFLG > 1 : [F:PID]ITMKND = 3 : Endif
        Endif
     When 2   :
         Gosub LECT_PTDPID
         If [F:PTD]ITMREF = [F:PID]ITMREF & [F:PTD]ITMKND > 1
           [F:PID]ITMKND = [F:PTD]ITMKND
        Else
            If [F:ITM]SCSFLG > 1 : [F:PID]ITMKND = 3 : Endif
        Endif
     When 3   :
        Gosub LECT_PNDPID
        If [F:PND]ITMKND > 1 : [F:PID]ITMKND = [F:PND]ITMKND : Endif
     When 4   :
         Gosub LECT_PID2
         If [F:PID2]ITMREF = [F:PID]ITMREF & [F:PID2]ITMKND > 1
            [F:PID]ITMKND = [F:PID2]ITMKND
        Else
            If [F:ITM]SCSFLG > 1 : [F:PID]ITMKND = 3 : Endif
         Endif
    Endcase
  Else
    If [F:ITM]SCSFLG > 1 : [F:PID]ITMKND = 3 : Endif
  Endif
  Rewrite [F:PID]
  If fstat
    Call FSTA("PID") From GLOCK
  Else
    NPID+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS : CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN : STOP=1 : Break : Endif
  Endif
Next
If TESTMOD = 2 : Rollback : Else : Commit : Endif
If STOP  Goto BOUCLE_PID : Endif
#
Return

########################################################################
$LECT_POQPID
If [F:POQ]POHNUM <> [F:PID]NUMORI | [F:POQ]POPLIN <> [F:PID]LINORI | [F:POQ]POQSEQ <> [F:PID]SEQORI
  Read [F:POQ]POQ0 = [F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
  If fstat : Raz [F:POQ] : Endif
Endif
Return

########################################################################
$LECT_PTDPID
If [F:PTD]PTHNUM <> [F:PID]NUMORI | [F:PTD]PTDLIN <> [F:PID]LINORI
  Read [F:PTD]PTD0 = [F:PID]NUMORI;[F:PID]LINORI
  If fstat : Raz [F:PTD] : Endif
Endif
Return

########################################################################
$LECT_PNDPID
If [F:PND]PNHNUM <> [F:PID]NUMORI | [F:PND]PNDLIN <> [F:PID]LINORI
  Read [F:PND]PND0 = [F:PID]NUMORI;[F:PID]LINORI
  If fstat : Raz [F:PND] : Endif
Endif
Return

########################################################################
$LECT_PID2
  Read [PID2] PID0=[F:PID]NUMORI;[F:PID]LINORI
Return

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Call MAJ_UTIACH112754(APPLI)

End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Call MAJ_UTIACH112754(APPLI)
End

