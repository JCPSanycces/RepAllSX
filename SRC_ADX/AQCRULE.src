Funprog RULE_INIT(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
AVALUE="RULE_INIT"
End 0

Funprog RULE_CONTROL(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
AVALUE+="_CONTROL"
End 0

Funprog RULE_PROPAGATE(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
AVALUE+="_PROPAGATE"
End 0

Funprog RULE_FORMAT(AINSTANCE,APRONAME,AVALUE, AFORMAT, CLE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable    Clbfile     AVALUE
Variable Char AFORMAT
Value Char CLE
AFORMAT ="20B"
End 0


Funprog RULE_READ_MEDIA(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Clbfile     AVALUE
Value Char CLE

AVALUE=""
Local Char FILNAM(250)
FILNAM = filpath("tmp",CLE,"rul",0)

If filinfo(FILNAM,0)<0 : End 0: Endif

Openi FILNAM Using [FIC]
Rdseq AVALUE Using [FIC]
Openi Using [FIC]
End 0

Funprog RULE_READ_MEDIA_CNT(AINSTANCE,APRONAME,AVALCNT,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Char AVALCNT
Value Char CLE
[L]AVALCNT="text/plain"
End 0

Funprog RULE_EXIST_MEDIA(AINSTANCE,APRONAME,AEXIST,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Tinyint AEXIST
Value Char CLE
End 0

Funprog RULE_INSERT_MEDIA(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char CLE

Openo filpath("tmp",CLE,"rul",0),0 Using [FIC]
Wrseq AVALUE Using [FIC]
Openo Using [FIC]
End 0

Funprog RULE_UPDATE_MEDIA(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
Openo filpath("tmp",CLE,"rul",0),0 Using [FIC]
Wrseq AVALUE Using [FIC]
Openo Using [FIC]

End 0

Funprog RULE_DELETE_MEDIA(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
End 0




