#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# Programme : PREPSITU                                                                  #
#                                                                                        #
# Fonction  :                                                                           #
#      1- Maj de la table TMPSITU                                                       #
#########################################################################################
#    Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
#
# MDJ   16.02.2017 120518    raitement préparatoire à l'état DEPSITUCUR
#########################################################################################
$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# traitement PRESITU : alimentation de la table TMPSITU
#=============================================================================
If clalev([F:TSI])=0    :    Local File TMPSITU         [TSI]   : Endif
If clalev([F:TSIM])=0   :    Local File TMPSITU         [TSIM]  : Endif

If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif
If clalev([F:CCE])=0    :    Local File CACCE           [CCE]   : Endif
If clalev([F:DSP])=0    :    Local File CADSP           [DSP]   : Endif

If clalev([F:CPY])=0    :    Local File COMPANY         [CPY]   : Endif
If clalev([F:CNX])=0    :    Local File CONTEXT         [CNX]   : Endif
If clalev([F:FIY])=0    :    Local File FISCYEAR        [FIY]   : Endif

If clalev([F:DEP])=0    :    Local File DEPREC          [DEP]   : Endif    # DEPREC
If clalev([F:DEPE])=0   :    Local File DEPREC          [DEPE]  : Endif    # DEPREC exercice
If clalev([F:DEPP])=0   :    Local File DEPREC          [DEPP]  : Endif    # DEPREC période
If clalev([F:FCY])=0    :    Local File FACILITY        [FCY]   : Endif    # Sites financiers

If clalev([F:CAC])=0    :    Local File GACCCODE        [CAC]   : Endif    # Codes comptables

If clalev([F:GACC])=0   :    Local File GACCOUNT        [GACC]  : Endif    # Comptes généraux PCG
If clalev([F:GACI])=0   :    Local File GACCOUNT        [GACI]  : Endif    # Comptes généraux IAS

If clalev([F:ADI])=0   :    Local File ATABDIV        [ADI]  : Endif       # Tables diverses
If clalev([F:AFF])=0   :    Local File AFCTFCY        [AFF]  : Endif       # Profil fonction site

If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

Return
######################################################################################
$FIN
Return
######################################################################################
$EXEC


Gosub MAJ_TMPSITU

Return
###################################################
$MAJ_TMPSITU
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPSITU pour les états DEPSITU*                    ---#
#------------------------------------------------------------------------------------#

   Gosub OUVRE

    Local Integer I, I_COA      # Compteur paramètres / Indices
    Local Integer RCNX, WCNX
    Local Char LCPYDEB          # Société deb
    Local Char LCPYFIN
    Local Char LFCYDEB          # Site deb
    Local Char LFCYFIN
    Local Char LCCPTDEB         # Code comptable deb
    Local Char LCCPTFIN         # Code comptable fin
    Local Char LACCDEB          # Compte PCG deb
    Local Char LACCFIN          # Compte PCG fin
    Local Char LIASACDEB        # Compte IAS deb
    Local Char LIASACFIN        # Compte IAS fin
    Local Integer LTYPDETDEB    # Type dét deb
    Local Integer LTYPDETFIN    # Type dét  fin
    Local Date LDATDEB          # Date début
    Local Date LDATFIN          # Date fin
    Local Char LREFDEB          # réf deb
    Local Char LREFFIN          # réf fin
    Local Integer LSITUAT       # Situation
    Local Integer LPLAN         # Plan
    Local Integer LENCOURS      # Encours ?
    Local Integer LACTIF        # Actif ?
    Local Integer LSELENT       # Sélection entrées
    Local Integer LSELSOR       # Sélection sorties
    Local Date    LDATNULL      : LDATNULL = [01/01/1900]
    Local Integer LBAS0         # base à 0 si sortis ?
    Local Integer LTRI2         # Critère de tri 2
    Local Integer LTRI3         # Critère de tri 3
    Local Integer LDET          # Détail ?
    Local Integer LEDTNUM       # Identifiant session
    Local Char    LCRITERE  (250) # Critère de sélection
    Local Char    LCRITERE2 (250) # Critère de sélection
    Local Decimal WENDDPET
    Local Char    SCPY         # Société traitée
    Local Char    SFCY         # Site financier traité
    Local Char    X3PRF        # Code profil user
    Local Char    X3FCT        # Fonction
    Global Char   GWCOA        # Plan de compte

    If clalev([TSI])=0 : Local File TMPSITU [TSI] : Endif
    Trbegin [TSI]
    Delete [TSI] Where CREUSR = GUSER
    If fstat = 1
      #  "Problème à l'effacement du fichier temporaire"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Rollback
      Return
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)

   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)
   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)
   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)
   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)
   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)       : LDATDEB    =  PARAM
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)       : LDATFIN    =  PARAM
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("situation",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
   Call GETPARAM("situation",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
   Call GETPARAM("plan",NBPAR,PARAMETRE,PARAM)         : LPLAN      = val(PARAM)
   Call GETPARAM("encours",NBPAR,PARAMETRE,PARAM)      : LENCOURS   = val(PARAM)
   Call GETPARAM("actif",NBPAR,PARAMETRE,PARAM)        : LACTIF     = val(PARAM)
   Call GETPARAM("selentree",NBPAR,PARAMETRE,PARAM)    : LSELENT    = val(PARAM)
   Call GETPARAM("selbiensor",NBPAR,PARAMETRE,PARAM)   : LSELSOR    = val(PARAM)
   Call GETPARAM("biensor",NBPAR,PARAMETRE,PARAM)      : LBAS0      = val(PARAM)
   Call GETPARAM("tri2",NBPAR,PARAMETRE,PARAM)         : LTRI2      = val(PARAM)
   Call GETPARAM("tri3",NBPAR,PARAMETRE,PARAM)         : LTRI3      = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)       : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)       : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LCRITERE = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpydeb" :
                  If LCPYDEB <> ""
                     LCRITERE =    "CPY>='"+LCPYDEB+"'"
                  Else
                     LCRITERE =    "CPY<='"+LCPYFIN+"'"
                  Endif
            When "cpyfin" :
                  If LCPYDEB <> ""
                     LCRITERE += "& CPY<='"+LCPYFIN+"'"
                  Endif
            When "fcydeb"     :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY<='"+LFCYFIN+"'"
            When "ccptdeb"    :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"
            When "accdeb"     :     LCRITERE += "& GAC>='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC<='"+LACCFIN+"'"
            When "accifrsdeb" :     LCRITERE += "& IASACC>='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC<='"+LIASACFIN+"'"
            When "refdeb"     :     LCRITERE += "& AASREF>='"+LREFDEB+"'"
            When "reffin"     :     LCRITERE += "& AASREF<='"+LREFFIN+"'"
            When "encours"
                  If LENCOURS=1
                     LCRITERE2 =    "GACACN <3"
                  Else
                     LCRITERE2 =    "GACACN<>1"
                  Endif
            When "actif"
                  If LACTIF=1
                     LCRITERE2 +=    "& ENAFAS<>1"
                  Else
                     LCRITERE2 +=    "& ENAFAS=1"
                  Endif
            When "selentree"
                  Case LSELENT
                     When 1 :  LCRITERE2 +=  "& (AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
                               LCRITERE2 +=  "| ITSDAT   <= ["+format$(GFMD,LDATFIN)+"])"
                     When 2 :  LCRITERE2 +=  "& AASIPTDAT>= ["+format$(GFMD,LDATDEB)+"]"
                               LCRITERE2 +=  "& AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
                     When 3 :  LCRITERE2 +=  "& AASIPTDAT<  ["+format$(GFMD,LDATDEB)+"]"
                  Endcase
            When "selbiensor"
                  Case LSELSOR
                     When 1 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATNULL)+"])"
                     When 2 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATFIN)+"])"
                     When 3 :
                        If LSITUAT = 1
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "& ISSDAT   <= ["+format$(GFMD,LDATFIN)+"]"
                        Else
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                        Endif
                  Endcase
         Endcase
      Endif
   Next
#--------------------------------
   If clalev([TSI])=0 : Local File TMPSITU [TSI] : Endif
   Trbegin [TSI]
   Delete [TSI] Where CREUSR = GUSER
   If fstat=1 | fstat>5
     Rollback
    Else
        Commit
   Endif


   #
   Trbegin [TSI]
   SCPY= ""
   SFCY= ""
   GWCOA= ""
   Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) )  and (OWNTYP >= LTYPDETDEB ) and (OWNTYP <= LTYPDETFIN ) Order By CPY
   For [FAS] With Stability
      If  LSELENT = 1 and
&         ([F:FAS]AASIPTDAT <= [F:FAS]ITSDAT)   and  ([F:FAS]AASIPTDAT > LDATFIN) or
&         ([F:FAS]AASIPTDAT > [F:FAS]ITSDAT)    and  ([F:FAS]ITSDAT    > LDATFIN)
          Goto NEXTFAS
      Endif
      If [F:FAS]CPY <> SCPY
         # Lecture contexte du plan
         Call GET_CNX_FROM_PLAN ([F:FAS]CPY, LPLAN, RCNX) From GLOBIENS
         WCNX=RCNX
         # Lecture exercice courant du plan
         Filter [FIY] Where CPY=[F:FAS]CPY and CNX=WCNX and DATSTRFIY=LDATDEB & DATENDFIY=LDATFIN
         Read [FIY]First
         Filter [FIY]
         SCPY= [F:FAS]CPY
         Read[CNX]CNX0= SCPY;WCNX
         If fstat=0
            I_COA = find(LPLAN,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
            If I_COA > 0
               GWCOA= [F:CNX]COA(I_COA-1)
      Endif
         Endif
      Endif
      If [F:FAS]FCY <> SFCY
         Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
         If fstat <> 0
            Goto NEXTFAS
         Endif
         SFCY= [F:FAS]FCY
      Endif
      #1------------
      Raz[TSIM]
      [F:TSIM] = [F:FAS]
      [F:TSIM]COA = GWCOA
      #=========================================================
      # Récupération des intitulés des champs
      #=========================================================
      Read [CPY]CPY0    = [F:FAS]CPY
      If fstat=0 :     [F:TSIM]CPYNAM    = [F:CPY]CPYNAM  : Endif
      Read [FCY]FCY0    = [F:FAS]FCY
      If fstat=0 :     [F:TSIM]FCYNAM    = [F:FCY]FCYNAM : Endif
      [F:TSIM]AASDES1   = [F:FAS]AASDES1
      # Issue 114161  Read[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
      If fstat=0
         Call LECTEXTRA([F:TSIM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
         # Issue 114161   [F:TSIM]ACCDES=[F:CAC]DESTRA
          Endif
      Read[GACC]GAC0=GWCOA;[F:FAS]GAC
      If fstat=0
         Call LECTEXTRA([F:TSIM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]GAC) From ATEXTRA
      Endif
      Read[GACI]GAC0=GWCOA;[F:FAS]IASACC
      If fstat=0
         Call LECTEXTRA([F:TSIM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]IASACC) From ATEXTRA
      Endif

      Read[DSP]DSP0=[F:FAS]DSP;1
      If fstat=0
       [F:TSIM]DSPDES = [F:DSP]DESTRA
      Endif
      #*Récupération des intitulés des Axes/Sections
      [F:TSIM]DIE(0)=[F:FAS]DIE(0)
      Read[CCE]CCE0=[F:FAS]DIE(0);[F:FAS]CCE(0)
      If fstat=0
        [F:TSIM]CCE1=[F:FAS]CCE(0)
        Call LECTEXTRA ([F:TSIM]CCE1DES , "CACCE", "DESTRA", num$([F:FAS]DIE(0)), [F:FAS]CCE(0)) From ATEXTRA
      Endif

      [F:TSIM]DIE(1)=[F:FAS]DIE(1)
      Read[CCE]CCE0=[F:FAS]DIE(1);[F:FAS]CCE(1)
      If fstat=0
        [F:TSIM]CCE2=[F:FAS]CCE(1)
        Call LECTEXTRA ([F:TSIM]CCE2DES , "CACCE", "DESTRA", num$([F:FAS]DIE(1)), [F:FAS]CCE(1)) From ATEXTRA
      Endif

      [F:TSIM]DIE(2)=[F:FAS]DIE(2)
      Read[CCE]CCE0=[F:FAS]DIE(2);[F:FAS]CCE(2)
      If fstat=0
        [F:TSIM]CCE3=[F:FAS]CCE(2)
        Call LECTEXTRA ([F:TSIM]CCE3DES , "CACCE", "DESTRA", num$([F:FAS]DIE(2)), [F:FAS]CCE(2)) From ATEXTRA
      Endif

      [F:TSIM]DIE(3)=[F:FAS]DIE(3)
      Read[CCE]CCE0=[F:FAS]DIE(3);[F:FAS]CCE(3)
      If fstat=0
        [F:TSIM]CCE4=[F:FAS]CCE(3)
        Call LECTEXTRA ([F:TSIM]CCE4DES , "CACCE", "DESTRA", num$([F:FAS]DIE(3)), [F:FAS]CCE(3)) From ATEXTRA
      Endif

      [F:TSIM]DIE(4)=[F:FAS]DIE(4)
      Read[CCE]CCE0=[F:FAS]DIE(4);[F:FAS]CCE(4)
      If fstat=0
        [F:TSIM]CCE5=[F:FAS]CCE(4)
        Call LECTEXTRA ([F:TSIM]CCE5DES , "CACCE", "DESTRA", num$([F:FAS]DIE(4)), [F:FAS]CCE(4)) From ATEXTRA
      Endif

      [F:TSIM]DIE(5)=[F:FAS]DIE(5)
      Read[CCE]CCE0=[F:FAS]DIE(5);[F:FAS]CCE(5)
      If fstat=0
        [F:TSIM]CCE6=[F:FAS]CCE(5)
        Call LECTEXTRA ([F:TSIM]CCE6DES , "CACCE", "DESTRA", num$([F:FAS]DIE(5)), [F:FAS]CCE(5)) From ATEXTRA
      Endif

      [F:TSIM]DIE(6)=[F:FAS]DIE(6)
      Read[CCE]CCE0=[F:FAS]DIE(6);[F:FAS]CCE(6)
      If fstat=0
        [F:TSIM]CCE7=[F:FAS]CCE(6)
        Call LECTEXTRA ([F:TSIM]CCE7DES , "CACCE", "DESTRA", num$([F:FAS]DIE(6)), [F:FAS]CCE(6)) From ATEXTRA
      Endif

      [F:TSIM]DIE(7)=[F:FAS]DIE(7)
      Read[CCE]CCE0=[F:FAS]DIE(7);[F:FAS]CCE(7)
      If fstat=0
        [F:TSIM]CCE8=[F:FAS]CCE(7)
        Call LECTEXTRA ([F:TSIM]CCE8DES , "CACCE", "DESTRA", num$([F:FAS]DIE(7)), [F:FAS]CCE(7)) From ATEXTRA
      Endif

      [F:TSIM]DIE(8)=[F:FAS]DIE(8)
      Read[CCE]CCE0=[F:FAS]DIE(8);[F:FAS]CCE(8)
      If fstat=0
        [F:TSIM]CCE9=[F:FAS]CCE(8)
        Call LECTEXTRA ([F:TSIM]CCE9DES , "CACCE", "DESTRA", num$([F:FAS]DIE(8)), [F:FAS]CCE(8)) From ATEXTRA
      Endif


#      Read [ADI]CODE = GTD_FAMCPT;[F:FAS]ACGGRP
      Read [F:FAM]FAM0 = [F:FAS]ACGGRP
      If fstat=0
         Call LECTEXTRA ([F:TSIM]ACGGRPDES, "FASFAM", "FAMDES", [F:FAS]ACGGRP, "") From ATEXTRA
#         Call LECTEXTRA ([F:TSIM]ACGGRPDES, "ATABDIV", "LNGDES", num$(GTD_FAMCPT), [F:ADI]CODE) From ATEXTRA
      Endif
      Read [ADI]CODE = 613;[F:FAS]IASCGU
      If fstat=0
         Call LECTEXTRA ([F:TSIM]IASCGUDES, "ATABDIV", "LNGDES", "613", [F:ADI]CODE) From ATEXTRA
      Endif
      #=========================================================
      GSITU=G_NON
      #========================================================
      # Récupération des infos en provenance du plan comptable
      #========================================================
      If LSITUAT = 1
         #----- Exercice -----
         Filter [DEPE] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=LPLAN        &
&                              FIYSTRDAT=LDATDEB & FIYENDDAT=LDATFIN )
         Read[DEPE]DEP0 Last
         Filter [DEPE]
         If fstat = 0
            GSITU=G_OUI
            Gosub CHARGE_TSIM_EXE
         Else
            GSITU=G_NON
         Endif
      Else
         #----- Période -----
         Filter[DEPP] Where (CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=LPLAN &
&                            PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN )
         Read[DEPP]DEP0 Last
         Filter[DEPP]
         If fstat <> 0
               Goto NEXTFAS
         Endif
         If fstat = 0
            #
            # si "Biens sortis et non-sortis" : si sortie antérieure à l'exercice traité on n'édite pas le bien
            # si "Biens non sortis" :  si sortie <  début période traitée on n'édite pas le bien
            # si "Biens sortis" :  si non sortis ou sortie postérieure à la période traitée on n'édite pas le bien
            Case  LSELSOR
               When 1  :  GSITU=G_OUI
               When 2
                   If ( [F:FAS]ISSDAT >  [0/0/0] and [F:FAS]ISSDAT < LDATDEB  and [F:FAS]ISSDAT >= [F:DEPP]FIYSTRDAT ) or
&                     ( [F:FAS]ISSDAT > LDATFIN)  or
&                     ( [F:FAS]ISSDAT =  [0/0/0] )
                      GSITU=G_OUI
                   Else
                      GSITU=G_NON
                   Endif
               When 3
                   If  [F:FAS]ISSDAT < [F:DEPP]FIYSTRDAT or [F:FAS]ISSDAT > LDATFIN
                     GSITU=G_NON
                   Else
                     GSITU=G_OUI
                   Endif
               When Default : GSITU=G_OUI
            Endcase
            If GSITU=G_OUI
               Gosub CHARGE_TSIM_PER
            Endif
         Endif
      Endif
      If GSITU=G_OUI
         [F:TSI]=[F:TSIM]
         [F:TSI]EDTNUM = LEDTNUM
         [F:TSI]CREUSR = GUSER
         [F:TSI]CREDAT = date$
         Write [F:TSI]
         If fstat <> 0
            GOK=0
            Rollback
            Unlock[TSI]
         Else
            Commit
            Unlock[TSI]
         Endif
         #1------------
      Endif
      $NEXTFAS
   Next
   Filter[FAS]


Commit

Return
######################################################################################
$CHARGE_TSIM_EXE

     [F:TSIM]   = [F:DEPE]
     [F:TSIM]TCUMSTREXE   = [F:DEPE]DPRCUM
     [F:TSIM]TCUMENDEXE   = [F:DEPE]DPRCUM + [F:DEPE]ENDDPE + [F:DEPE]EXCDPR
     [F:TSIM]TDPEEXE      = [F:DEPE]ENDDPE
     [F:TSIM]TDPEEXCEXE   = [F:DEPE]EXCDPR
     [F:TSIM]TIMLEXE      = [F:DEPE]PERIMLCUM + [F:DEPE]IML
     [F:TSIM]TIMLRVEEXE   = [F:DEPE]PERRVECUM + [F:DEPE]PERTRFCUM + [F:DEPE]IMLRVE + [F:DEPE]IMLRVETRF
     [F:TSIM]TIMLBLCEXE   = [F:DEPE]EXEIMLCUM - [F:DEPE]EXERVECUM - [F:DEPE]EXETRFCUM

     If [FAS]ISSDAT >= LDATDEB and [FAS]ISSDAT <= LDATFIN
        [F:TSIM]TIMLRVEISS    = [F:FAS]IMLRVEISS(LPLAN-1)
     Endif
      #*Base, cumul et VN = 0 si sortis
      If ([FAS]ISSDAT <> [0/0/0] and [FAS]ISSDAT <= LDATFIN ) and LBAS0=1
         [F:TSIM]DPRBAS     = 0
         [F:TSIM]TCUMENDEXE = 0
         [F:TSIM]RSDVAL     = 0
         [F:TSIM]NBV        = 0
      Endif


Return
######################################################################################
$CHARGE_TSIM_PER
Local Date    RCNXDAT(1..5)
Local Integer RRET

   [F:TSIM]   = [F:DEPP]
   [F:TSIM]TCUMSTRPER  = [F:DEPP]DPRCUM + [F:DEPP]PERCLOCUM + [F:DEPP]PERCLOEXC
   [F:TSIM]TCUMENDPER  = [F:DEPP]DPRCUM + [F:DEPP]PERCLOCUM + [F:DEPP]PERCLOEXC + [F:DEPP]PERENDDPE + [F:DEPP]PEREXCDPR
   [F:TSIM]TDPEPER     = [F:DEPP]PERENDDPE
   [F:TSIM]TDPEEXCPER  = [F:DEPP]PEREXCDPR
   [F:TSIM]TIMLPER     = [F:DEPP]IML
   [F:TSIM]TIMLRVEPER  = [F:DEPP]IMLRVE + [F:DEPP]IMLRVETRF
   [F:TSIM]TIMLBLCPER  = [F:DEPP]IMLBLC

   #Récupération des dates de la période courante
   Call GET_CNX_DAT([F:FAS]CPY,[F:DEPP]CNX,RCNXDAT,RRET) From GLOBIENS

   [F:TSIM]TIMLRVEISS  = 0
   If [FAS]ISSDAT > [0/0/0]
      # Si date de sortie <= date de fin de période courante
      If ( [FAS]ISSDAT <= RCNXDAT(4) )
         # et si l'on édite la période courante
         If  ([F:DEPP]PERENDDAT= RCNXDAT(4))
            [F:TSIM]TIMLRVEISS    = [F:FAS]IMLRVEISS(LPLAN-1)
         Else
             [F:TSIM]TIMLRVEISS    = 0
         Endif
      Else
         # Si date de sortie postérieure à la date de fin de période courante et que l'on édite cette période
         If ( [FAS]ISSDAT >=LDATDEB and [FAS]ISSDAT <=LDATFIN )
              [F:TSIM]TIMLRVEISS    = [F:FAS]IMLRVEISS(LPLAN-1)
         Else
             [F:TSIM]TIMLRVEISS    = 0
         Endif
      Endif
      #* Base, cumul et VN = 0 si sortis
      If [FAS]ISSDAT <=LDATFIN and LBAS0=1
         [F:TSIM]DPRBAS     = 0
         [F:TSIM]TCUMENDEXE = 0
         [F:TSIM]RSDVAL     = 0
         [F:TSIM]NBV        = 0
      Endif
   Endif

Return
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

