$ON_NBRDAY1
Onevent BEFORE_INPUT Call AS_NBRDAY1(zc) From W1STY1
Onevent CONTROL Call C_NBRDAY1(zc) From W1STY1
Return

Subprog AS_NBRDAY1(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRDAY1(VALEUR) From SUBSTY
If mkstat=2
 [M]NBRDAY1(INDIC) = VALEUR
 Affzo NBRDAY1(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_NBRDAY1(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NBRDAY1" : GZNUM = 3599 : Endif
If !mkstat
 ## Action STD
 Call C_NBRDAY1(VALEUR) From SUBSTY
 If mkstat : GERR = 1 : GZONE = "NBRDAY1" : GZNUM = 3599 : Endif
Endif
Gosub _AFF
End

$ON_UPDHRS
Onevent INIT_AREA Call D_UPDHRS(zc) From W1STY1
Return

Subprog D_UPDHRS(VALEUR)
Variable Decimal VALEUR
If varinit([M]UPDHRS,indice)=0
 VALEUR = 0
Endif
Gosub _AFF
End

$CHG_STY
Return


