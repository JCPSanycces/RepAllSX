Subprog C_NATCOD0(VALEUR)
Variable Char    VALEUR()
## Action CONTNAT
Call CONTNAT(VALEUR) From SUBNAT
If mkstat : GERR = 1 : GZONE = "NATCOD0" : GZNUM = 47180 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NATCOD0" : GZNUM = 47180 : Endif
 If !mkstat
  ## Action CONTEXE
  Call CONTEXE([F:NAT]ACS) From CPTSUB
  If mkstat : GERR = 1 : GZONE = "NATCOD0" : GZNUM = 47180 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_NATCOD0
