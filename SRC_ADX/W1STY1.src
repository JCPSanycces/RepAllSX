#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque STY1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:40"
A_USER  = "DOC"
A_STAMP = "20181109230640"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDAY"
  If [M]NBRDAY=0
   If [M:STY1]FRMTIM(0)<>""
    Chgfmt STRTIM0 With [M:STY1]FRMTIM(0)
   Else
    Chgfmt STRTIM0 With "-K:1X"
   Endif
   If [M:STY1]FRMTIM(0)<>""
    Chgfmt ENDTIM0 With [M:STY1]FRMTIM(0)
   Else
    Chgfmt ENDTIM0 With "-K:1X"
   Endif
   If [M:STY1]FRMBRK(0)<>""
    Chgfmt BRKTIM0 With [M:STY1]FRMBRK(0)
   Else
    Chgfmt BRKTIM0 With "-K:1X"
   Endif
   If [M:STY1]FRMTIM(1)<>""
    Chgfmt STRTIM1 With [M:STY1]FRMTIM(1)
   Else
    Chgfmt STRTIM1 With "-K:1X"
   Endif
   If [M:STY1]FRMTIM(1)<>""
    Chgfmt ENDTIM1 With [M:STY1]FRMTIM(1)
   Else
    Chgfmt ENDTIM1 With "-K:1X"
   Endif
   If [M:STY1]FRMBRK(1)<>""
    Chgfmt BRKTIM1 With [M:STY1]FRMBRK(1)
   Else
    Chgfmt BRKTIM1 With "-K:1X"
   Endif
   If [M:STY1]FRMNAT(0)<>""
    Chgfmt NATCOD1 With [M:STY1]FRMNAT(0)
   Else
    Chgfmt NATCOD1 With "-K:1X"
   Endif
   If [M:STY1]FRMTIM(2)<>""
    Chgfmt STRTIM2 With [M:STY1]FRMTIM(2)
   Else
    Chgfmt STRTIM2 With "-K:1X"
   Endif
   If [M:STY1]FRMTIM(2)<>""
    Chgfmt ENDTIM2 With [M:STY1]FRMTIM(2)
   Else
    Chgfmt ENDTIM2 With "-K:1X"
   Endif
   If [M:STY1]FRMBRK(2)<>""
    Chgfmt BRKTIM2 With [M:STY1]FRMBRK(2)
   Else
    Chgfmt BRKTIM2 With "-K:1X"
   Endif
   If [M:STY1]FRMNAT(1)<>""
    Chgfmt NATCOD2 With [M:STY1]FRMNAT(1)
   Else
    Chgfmt NATCOD2 With "-K:1X"
   Endif
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask STY1 [STY1]
Gosub HORODAT
Local Inpbox "STY1" From GFONCTION At A_STAMP With A_WINDPREV Mask [STY1] As [SIM_]
Grizo [STY1]10
Grizo [STY1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [STY1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=117 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=117 : Y1(1)=3 : Y2(1)=28
Return

$ON_FIRDAY
Onevent CONTROL Call C_FIRDAY(zc) From W1STY1
Onevent INIT_AREA Call D_FIRDAY(zc) From W1STY1
Onevent BEFORE_INPUT Call AS_FIRDAY(zc) From W1STY1
Return

Subprog D_FIRDAY(VALEUR)
Variable Integer VALEUR
If varinit([M]FIRDAY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FIRDAY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FIRDAY(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_FIRDAY(VALEUR) From SUBSTY
If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
Gosub _AFF
End

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1STY1
Onevent AFTER_CHANGE Gosub AMM_COD From W1STY1
Onevent BEFORE_INPUT Call AS_COD(zc) From W1STY1
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(55957,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_COD(zc) From W1STY1
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1STY1
Onkey 144 Titled GBOUTP Call P_COD(zc) From W1STY1
Onkey 146 Titled GBOUTA Call SA_COD(zc) From W1STY1
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTSTY
  Call CONTSTY(VALEUR) From SUBSTY
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_COD
Call AM_COD(zc)
If !mkstat & GOBJET
 zoncou = "COD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_COD(VALEUR) From SUBSTY
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSTY
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSTY"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSTY","SUBSTY","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSTY
 Call TUNSTY(VALEUR) From SUBSTY
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "STY"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_COD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("STY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1STY1
Onevent CONTROL Call C_LEG(zc) From W1STY1
Onevent AFTER_CHANGE Gosub AMM_LEG From W1STY1
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1STY1
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1STY1
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1STY1
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1STY1
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1STY1
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBSTY
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1STY1
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

