#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# UTIACH19   Création des valeurs par défaut des nouveaux paramètres      #
#           NULMVTIFA et NULAMTIFA                                       #
##########################################################################
# CCC (2010-05-20) DM 64931
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  #--- Issue 108760 by TS
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  #---
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    #--- Issue 108760 By TS
    #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    #---
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIACH19(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIACH19(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIACH19: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Local File =DOSSIER + ".ADOVAL"  [ADW2]

  # Copie des valeurs du paramètre OPEIFA sur le paramètre SCOIFA
  Trbegin [ADW]
  For [F:ADW2] Where PARAM="OPEIFA"
      Look [ADW]ADW0=[F:ADW2]CMP;[F:ADW2]FCY;"SCOIFA"
      If fstat
          [F:ADW] = [F:ADW2]
          [F:ADW]PARAM = "SCOIFA"
          [F:ADW]CREDAT = date$
          [F:ADW]CREUSR = GUSER
          # Issue 110142 - 2015-08-07 by MUARN : soumis à dim
          If dim([F:ADW]CRETIM)>0 : [F:ADW]CRETIM = time : Endif
          Raz [F:ADW]UPDUSR, [F:ADW]UPDDAT
          # Issue 110142 - 2015-08-07 by MUARN : soumis à dim
          If dim([F:ADW]UPDTIM)>0 : Raz [F:ADW]UPDTIM : Endif
          Write [F:ADW]
          If fstat
              Call ECR_TRACE("SCOIFA: can't create parameter",1) From GESECRAN
          Endif
      Endif
  Next
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTIACH19 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 by TS
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  #---
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(APPLI,"ADOVAL") : End : Endif                  : # For Archive folder
  #---
  Call MAJ_UTIACH19(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(APPLI,"ADOVAL") : End : Endif                  : # For Archive folder
  #---
  Call MAJ_UTIACH19(APPLI)
End

