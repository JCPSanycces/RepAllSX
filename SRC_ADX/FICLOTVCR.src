#<AdxTL>@(#)8.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()
#--- ouverture des tables
Gosub OUVRE 
#--- declaration des variables
Gosub DECLARE 

[L]CRITERE    = "1=1" 
[L]CRITERESGH = "1=1& [F:SGH]TRSTYP = 34" 
[L]CRITERESGD = "1=1" 
#--- analyse des paramètres
For I=1 To NBPAR 
    J=instr(1,[L]PARAMETRE(I),"=")
    If J
       [L]PARAM  = left$([L]PARAMETRE(I),J-1)
       [L]VALEUR = right$([L]PARAMETRE(I),J+1)
       Case [L]PARAM
            When "X3ETA"           : [L]ETAT   =     [L]VALEUR
            When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
            When "vcrtyp"          : [L]VCRTYP = val([L]VALEUR)
            #--- alimentation des paramètres utilisateur 
            When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
            When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
            When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
            #--- préparation du filtre à appliquer sur les tables 

            When "stofcy"          : [L]CRITERE    -= "& STOFCY='"+[L]VALEUR+"'"
                                     [L]CRITERESGH -= "& [F:SGH]STOFCY='"+[L]VALEUR+"'"
            When "vcrnum"          : [L]CRITERE    -= "& VCRNUM='"+[L]VALEUR+"'" 
                                     [L]CRITERESGH -= "& [F:SGH]VCRNUM='"+[L]VALEUR+"'"
                                     [L]VCRNUM      = [L]VALEUR
            When "vcrlindeb"       : [L]CRITERE    -= "& VCRLIN>="+num$([L]VALEUR) 
                                     [L]CRITERESGD -= "& [F:SGD]VCRLIN>="+num$([L]VALEUR)
            When "vcrlinfin"       : [L]CRITERE    -= "& VCRLIN<="+num$([L]VALEUR) 
                                     [L]CRITERESGD -= "& [F:SGD]VCRLIN<="+num$([L]VALEUR)
            When "itmrefdeb"       : [L]CRITERE    -= "& ITMREF>='"+[L]VALEUR+"'" 
                                     [L]CRITERESGD -= "& [F:SGD]ITMREF>='"+[L]VALEUR+"'"
            When "itmreffin"       : [L]CRITERE    -= "& ITMREF<='"+[L]VALEUR+"'" 
                                     [L]CRITERESGD -= "& [F:SGD]ITMREF<='"+[L]VALEUR+"'"
            When "lotdeb"          : [L]CRITERE    -= "& LOT>='"+[L]VALEUR+"'" 
                                     [L]CRITERESGD -= "& [F:SGD]LOT>='"+[L]VALEUR+"'"
            When "lotfin"          : [L]CRITERE    -= "& LOT<='"+[L]VALEUR+"'" 
                                     [L]CRITERESGD -= "& [F:SGD]LOT<='"+[L]VALEUR+"'"

       Endcase
    Endif
Next
Gosub PUR_WSL
Local Integer WTYP
GOK=1
Case VCRTYP
     When 1 : WTYP = 4
              Gosub TRT_STOJOU_LIV
     When 2 : Gosub TRT_SCHGH  
Endcase
End

###################################################################
# origine  : livraison
###################################################################
$TRT_STOJOU_LIV
Read [F:SDH]SDH0 =  [L]VCRNUM
If fstat 
   Return  
Endif
# la livraison doit etre validée ........
If [F:SDH]CFMFLG <> 2
   Return
Endif
  
Trbegin [WSL]
Filter [STJ] Where evalue(CRITERE) 
&                  &      VCRTYP=WTYP 
&                  &      REGFLG<>2
&                  &      QTYSTU<0 
   For [STJ] Hint Key STJ1
       If [F:ITM]ITMREF    <> [F:STJ]ITMREF
          Read [F:ITM]ITM0 =  [F:STJ]ITMREF
          If fstat 
             Raz [F:ITM] 
          Endif
       Endif
       If [F:ITM]STOMGTCOD > 1 & [F:ITM]LOTMGTCOD > 1
          If [F:ITF]ITMREF    <> [F:STJ]ITMREF | [F:ITF]STOFCY <> [F:STJ]STOFCY
             Read [F:ITF]ITF0 =  [F:STJ]ITMREF;[F:STJ]STOFCY
             If fstat 
                Raz [F:ITF] 
             Endif
          Endif
          If [F:ITF]STOMGTCOD > 1 
             Look [WSL]WSL0=[L]NUMREQ;GUSER;[F:STJ]ITMREF;[F:STJ]LOT;[F:STJ]SLO;[F:STJ]STOFCY
             If fstat 
                Raz [F:WSL]
                [F:WSL]VCRTYP    = 1      
                [F:WSL]VCRNUM    = [F:STJ]VCRNUM  
                [F:WSL]ITMREF    = [F:STJ]ITMREF   
                [F:WSL]LOT       = [F:STJ]LOT      
                [F:WSL]SLO       = [F:STJ]SLO      
                [F:WSL]STOFCY    = [F:STJ]STOFCY
                [F:WSL]USR       = GUSER
                [F:WSL]NUMREQ    = [L]NUMREQ
                [F:WSL]CREUSR    = GUSER 
                [F:WSL]CREDAT    = date$ 
                [F:WSL]UPDUSR    = GUSER 
                [F:WSL]UPDDAT    = date$ 
                Write [F:WSL]   
                If fstat 
                   GOK=0 : Break 
                Endif
             Endif
          Endif   
       Endif
   Next
Filter [STJ]
If GOK=0
   Call FSTA("WSL") From GLOCK 
   Rollback
Else
   Commit
Endif
Return
###################################################################
# origine  : Demande analyse
###################################################################

TRT_SCHGH
Trbegin [WSL]
Link [SGD] With [SGH]SGH0=[F:SGD]VCRNUM 
&          As [INV] 
&          Where evalue(CRITERESGD)  &   
&                evalue(CRITERESGH)   
&          Order By Key SGD0  
For [INV]
    If [F:ITM]ITMREF    <> [F:SGD]ITMREF
       Read [F:ITM]ITM0 =  [F:SGD]ITMREF
       If fstat 
          Raz [F:ITM] 
       Endif
    Endif
    If [F:ITM]STOMGTCOD > 1 & [F:ITM]LOTMGTCOD > 1
       If [F:ITF]ITMREF    <> [F:SGD]ITMREF | [F:ITF]STOFCY <> [F:SGH]STOFCY
          Read [F:ITF]ITF0 =  [F:SGD]ITMREF;[F:SGH]STOFCY
          If fstat 
             Raz [F:ITF] 
          Endif
       Endif
       If [F:ITF]STOMGTCOD > 1 
          Look [WSL]WSL0=[L]NUMREQ;GUSER;[F:SGD]ITMREF;[F:SGD]LOT;[F:SGD]SLO;[F:SGH]STOFCY
          If fstat 
             Raz [F:WSL]
             [F:WSL]VCRTYP    = 2      
             [F:WSL]VCRNUM    = [F:SGD]VCRNUM  
             [F:WSL]ITMREF    = [F:SGD]ITMREF   
             [F:WSL]LOT       = [F:SGD]LOT      
             [F:WSL]SLO       = [F:SGD]SLO      
             [F:WSL]STOFCY    = [F:SGH]STOFCY
             [F:WSL]USR       = GUSER
             [F:WSL]NUMREQ    = [L]NUMREQ
             [F:WSL]CREUSR    = GUSER 
             [F:WSL]CREDAT    = date$ 
             [F:WSL]UPDUSR    = GUSER 
             [F:WSL]UPDDAT    = date$ 
             Write [F:WSL]   
             If fstat 
                GOK=0 : Break 
             Endif
          Endif
       Endif   
    Endif
Next
If GOK=0
   Call FSTA("WSL") From GLOCK 
   Rollback
Else
   Commit
Endif
Return


########################################################################### 


###########################################################
$PUR_WSL
Trbegin [WSL]
Delete [WSL] Where CREUSR = GUSER 
fstat = 0
Delete [WSL] Where NUMREQ = [L]NUMREQ
fstat = 0
Commit
Return

###########################################################################  
$OUVRE 
Local File STOJOU [STJ], WSTOLOTFCY [WSL] , ITMMASTER [ITM] , ITMFACILIT [ITF]
Local File SCHGH  [SGH], SCHGD      [SGD] , SDELIVERY [SDH]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15) ,VCRNUM
Local Char    CRITERESGH(255), CRITERESGD(255) 
Local Integer I, J, NUMREQ,VCRTYP 

Return 


