$IB_BOUTON
# On enlève le bouton Texte de bulletin de paye, si une paye plus récente a été générée ou si
# la paye sur laquelle on veut saisir un texte est comptabilisée ou en cours de comptabilisation.
Filter [VEP] Where EMP=[M:SVV]MAT(nolign-1)
Read [VEP]VEP0 Last
If !fstat
 # Verrouillé US 2022 65062 pas de test c'est du prévisionnel
 If [F:VEP]PYRDAT>[M:SVV]DAT(nolign-1) | ([F:VEP]PYRDAT=[M:SVV]DAT(nolign-1) & [F:VEP]PST>1)
  Raz GBOUT3
 Endif
Endif
Filter [VEP]
# On enlève le bouton Texte de bulletin de paye, si la variable n'est pas associée à une rubrique
# via la zone "texte associé"
Filter [RUB] Where LEG=GCURLEG and (TEXVRI(0)=VRIZON or TEXVRI(1)=VRIZON)
Read[RUB]RUB0 First
Filter [RUB]
If fstat
 Raz GBOUT3
Endif
Return

Subprog C_SVR(VALEUR)
Variable Char    VALEUR()
Call C_SVR (VALEUR)From TRTSAIVAR
End

Subprog C_TBL
Local Integer I,J
If status=65
 I=find("",[M]MAT2)
 If I=0
  # Suppression supplémentaire impossible. Veuillez enregistrer votre bordereau pour continuer...
  GMESSAGE = mess(15,10704,1)
  mkstat=2 : End
 Endif
 [M]MAT2(I-1) = [M]MAT(nolign-1)
 [M]CTR2(I-1) = [M]CTR(nolign-1)
 [M]CTRDAT2(I-1) = [M]CTRDAT(nolign-1)
 [M]DAT2(I-1) = [M]DAT(nolign-1)
 [M]TBL2 +=1

Elsif status=83 | status=68
 I=find("",[M]MAT2)
 If I=0
  # Suppression supplémentaire impossible. Veuillez enregistrer votre bordereau pour continuer...
  GMESSAGE = mess(15,10704,1)
  mkstat=2 : End
 Endif
 For J=nolign-1 To nolign1-1
  [M]MAT2(I-1) = [M]MAT(J)
  [M]CTR2(I-1) = [M]CTR(J)
  [M]CTRDAT2(I-1) = [M]CTRDAT(J)
  [M]DAT2(I-1) = [M]DAT(J)
  [M]TBL2 +=1
  I+=1
  If I>=dim([M]MAT2)
   # Suppression supplémentaire impossible. Veuillez enregistrer votre bordereau pour continuer...
   GMESSAGE = mess(15,10704,1)
   mkstat=2 : Break
  Endif
 Next
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End

