#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "TRTSAIVAR"
Call TRAITE_CHAR(VALEUR,PARAM,"TRTSAIPRV","TRTSAIPRV","DCRITPRV",4,"") From GTRAITE
End

###################################################################################################
## Saisie des valeurs prévisionnelles
###################################################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "CONTROLE"    : Gosub CONTROLE
 When "OK"          : Gosub OK
 When "END"         : Gosub FIN
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "BOUTON"      : Gosub BOUTON
Endcase
Return

$INIT
Local Char    VALPAR(30), VALVAR(GLONVRA)
Local Char    CRITERE(250), CRITERE2(250)
Local Date    DATM, DTRM
Local Char    MATM(GLONEML), SYMBOLE (80), CTRM(GLONHRCTR)
Local Integer INC
Gosub OUVREFIC
Gosub OUVRE From WPDEFTABLE
Local Mask CRITPRV [DIA]
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
Raz [M:DIA]
Call PARAM("","VPRDEB",VALPAR) From ADOVAL
If VALPAR<>"" : [M:DIA]DATDEB = gdat$(VALPAR) : Endif
Call PARAM("","VPRFIN",VALPAR) From ADOVAL
If VALPAR<>"" : [M:DIA]DATFIN = gdat$(VALPAR) : Endif

Call LECMEMO("STD","[M:DIA]","prv") From GMEMO
Call AFF_MEMO From DIVPAYE

Effzo [M:DIA]INI
Return

# A faire peu importe GACTION ??? A vérifier...
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$OUVREFIC
If clalev([F:SVR])=0 : Local File SCRVRA   [SVR] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:SRV])=0 : Local File SERVICE  [SRV] : Endif
If clalev([F:PRF])=0 : Local File PROFIL   [PRF] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
If clalev([F:VRA])=0 : Local File VARIA    [VRA] : Endif
If clalev([F:VPR])=0 : Local File VALPRV   [VPR] : Endif
If clalev([F:VPH])=0 : Local File VALPRVH  [VPH] : Endif
If clalev([F:VEP])=0 : Local File VALEMP   [VEP] : Endif
If clalev([F:HRPCB])=0 : Local File PRVCLOB  [HRPCB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:CTRW])=0 : Local File EMPLOCTR [CTRW] : Endif
Return

$APRES_MODIF
If GBOITE="TRTSAIPRV"
 If (COUZON="MAT" & [M]DAT(nolign-1)<>[0/0/0] & [M]CTR(nolign-1)<>"") |
&   (COUZON="DAT" & [M]MAT(nolign-1)<>"" & [M]CTR(nolign-1)<>"") |
&   (COUZON="CTR" & [M]MAT(nolign-1)<>"" & [M]DAT(nolign-1)<>[0/0/0])

  MATM = [M]MAT(nolign-1)
  CTRM = [M]CTR(nolign-1)
  DATM = [M]DAT(nolign-1)
  DTRM = [M]CTRDAT(nolign-1)
  Case COUZON
   When "MAT"
    MATM = CZ
   When "DAT"
    DATM = gdat$(CZ)
   When "CTR"
    CTRM = CZ
  Endcase
  For VARIAB=[M]VAR1,[M]VAR2,[M]VAR3,[M]VAR4,[M]VAR5,[M]VAR6,[M]VAR7,[M]VAR8,[M]VAR9,[M]VAR10,[M]VAR11,[M]VAR12,[M]VAR13,[M]VAR14,[M]VAR15
   Read [VPR]VPR0=MATM;CTRM;DTRM;DATM;VARIAB
   If !fstat
    Case VARIAB
     When [M]VAR1 : [M]VRI1(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI1(nolign-1)
     When [M]VAR2 : [M]VRI2(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI2(nolign-1)
     When [M]VAR3 : [M]VRI3(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI3(nolign-1)
     When [M]VAR4 : [M]VRI4(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI4(nolign-1)
     When [M]VAR5 : [M]VRI5(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI5(nolign-1)
     When [M]VAR6 : [M]VRI6(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI6(nolign-1)
     When [M]VAR7 : [M]VRI7(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI7(nolign-1)
     When [M]VAR8 : [M]VRI8(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI8(nolign-1)
     When [M]VAR9 : [M]VRI9(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI9(nolign-1)
     When [M]VAR10: [M]VRI10(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI10(nolign-1)
     When [M]VAR11: [M]VRI11(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI11(nolign-1)
     When [M]VAR12: [M]VRI12(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI12(nolign-1)
     When [M]VAR13: [M]VRI13(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI13(nolign-1)
     When [M]VAR14: [M]VRI14(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI14(nolign-1)
     When [M]VAR15: [M]VRI15(nolign-1) = [F:VPR]VARVAL : Affzo [M]VRI15(nolign-1)
    Endcase
   Endif
  Next
 Endif
Endif
Return

$DEBUT
Local Char DES (GLONAX3)
Case BOITE
 When "SAICMT"
  Raz [M:CMT]
  [M:CMT]CMT = PARAM(1)
 When "DCRITPRV"
  Affzo [DIA]
  Setmok [DIA] With 0
  If PARAM(1)<>"" & PARAM(2)<>""
   GCURLEG=PARAM(2)
   If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
   Read [SVR]SVR0 = PARAM(1);PARAM(2)
   Call LECTEXTRA([L]DES,"SCRVRA","DES",[F:SVR]COD,GCURLEG) From ATEXTRA
   Titled [DIA] [L]DES
   [M:DIA]SVR = PARAM(1)
   [M:DIA]ZSVR = [L]DES
   If dim ([M:DIA]LEG)>=0
    [M:DIA]LEG = PARAM(2)
    Call LECTEXTRA([M:DIA]ZLEG,"ATABDIV","LNGDES","909",PARAM(2)) From ATEXTRA
    Affzo [DIA]LEG,ZLEG
    Grizo [DIA]LEG
   Endif
   Affzo [DIA]SVR,ZSVR
   Grizo [DIA]SVR
  Else
   Call AFF_MEMO From DIVPAYE
  Endif
 When "TRTSAIPRV"
  Raz [M:SVV]
  #FRLAA - 2016-05-11 - REQUIREMENT 114309 US 116 - START
  Read [F:SVR]SVR0=GCURLEG;[M:DIA]SVR
  #Read [F:SVR]SVR0=[M:DIA]SVR;GCURLEG
  #FRLAA - 2016-05-11 - REQUIREMENT 114309 US 116 - END
  For I=1 To [F:SVR]NBRVAR

   Read [VRA]VRA0 = GCURLEG;[F:SVR]VARCOD(I-1)
   Read [ADI]CODE = 10337;[F:VRA]PAGEMP
   FORMA = "N3:9."+num$([F:ADI]N1)+"#"
   Case I
    When 1 : [M:SVV]VAR1 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI1 With FORMA
    When 2 : [M:SVV]VAR2 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI2 With FORMA
    When 3 : [M:SVV]VAR3 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI3 With FORMA
    When 4 : [M:SVV]VAR4 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI4 With FORMA
    When 5 : [M:SVV]VAR5 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI5 With FORMA
    When 6 : [M:SVV]VAR6 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI6 With FORMA
    When 7 : [M:SVV]VAR7 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI7 With FORMA
    When 8 : [M:SVV]VAR8 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI8 With FORMA
    When 9 : [M:SVV]VAR9 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI9 With FORMA
    When 10 : [M:SVV]VAR10 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI10 With FORMA
    When 11 : [M:SVV]VAR11 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI11 With FORMA
    When 12 : [M:SVV]VAR12 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI12 With FORMA
    When 13 : [M:SVV]VAR13 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI13 With FORMA
    When 14 : [M:SVV]VAR14 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI14 With FORMA
    When 15 : [M:SVV]VAR15 = [F:SVR]VARCOD(I-1) : Chgfmt [M:SVV]VRI15 With FORMA
   Endcase
   [M:SVV]LIBVAR(I-1)=[F:SVR]VARDES(I-1)
  Next I
  For I=[F:SVR]NBRVAR+1 To 15
   Case I
    When 1 : Chgfmt [M:SVV]VRI1 With "-N:9.2#"
    When 2 : Chgfmt [M:SVV]VRI2 With "-N:9.2#"
    When 3 : Chgfmt [M:SVV]VRI3 With "-N:9.2#"
    When 4 : Chgfmt [M:SVV]VRI4 With "-N:9.2#"
    When 5 : Chgfmt [M:SVV]VRI5 With "-N:9.2#"
    When 6 : Chgfmt [M:SVV]VRI6 With "-N:9.2#"
    When 7 : Chgfmt [M:SVV]VRI7 With "-N:9.2#"
    When 8 : Chgfmt [M:SVV]VRI8 With "-N:9.2#"
    When 9 : Chgfmt [M:SVV]VRI9 With "-N:9.2#"
    When 10 : Chgfmt [M:SVV]VRI10 With "-N:9.2#"
    When 11 : Chgfmt [M:SVV]VRI11 With "-N:9.2#"
    When 12 : Chgfmt [M:SVV]VRI12 With "-N:9.2#"
    When 13 : Chgfmt [M:SVV]VRI13 With "-N:9.2#"
    When 14 : Chgfmt [M:SVV]VRI14 With "-N:9.2#"
    When 15 : Chgfmt [M:SVV]VRI15 With "-N:9.2#"
   Endcase
  Next I
  Gosub FILTRE
  Gosub CHARGE
  #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
  Sorta [M]TBL [M]TBL Order By [M]DAT(indice),[M]MAT(indice),[M]CTR(indice),[M]CTRDAT(indice)
  #Sorta [M]TBL [M]TBL Order By [M]MAT(indice)
  #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
  [M:SVV]TRI = 0
  Affzo [SVV]
 When "VARTEXT"
  If len(evalue(PARAM(1)))>0
   [M]VARTXT    = evalue(PARAM(1))
   [M]SAVVARTXT = evalue(PARAM(1))
  Else
   Raz[M]
  Endif
  Affzo [VTX]
Endcase
Return

$FILTRE
# Mise en place du filtre sur la table des salariés et sur les valeurs prévisionnelles
CRITERE  = "[F:ID]ENAFLG=2 & [F:ID]FLGPAY=2 & [F:CPY]LEG='"+GCURLEG+"'"

CRITERE2 = "1=1"
If [M:DIA]ALLCPY<>2  #société
 CRITERE  -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
 CRITERE2 -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
 CRITERE  -= '& [F:CTRW]ETRFCY = "'+[M:DIA]FCY+'"'
 #CRITERE  -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
 CRITERE2 -= '& [F:VPH]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE  -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
 CRITERE2 -= '& [F:VPH]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE  -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
 CRITERE2 -= '& [F:VPH]EMP<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
 CRITERE -= '& [F:CTRW]ETRSRV = "'+[M:DIA]SRV+'"'
 #CRITERE -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
 CRITERE2 -= '& [F:VPH]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
 CRITERE -= '& [F:CTRW]PROPRF = "'+[M:DIA]PRF+'"'
 #CRITERE -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
Endif
If [M:DIA]POP<>""
 Link [CTRW] With
&    [ID]ID0=[F:CTRW]REFNUM,
&    [FCY]FCY0=[F:CTRW]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY,
&    [HRPOA]POA0 = [M:DIA]POP;[F:CTRW]REFNUM;[F:CTRW]CTRNUM;[F:CTRW]CTRDAT
& As [LECT]
& Where evalue(CRITERE)  & [F:HRPOA]REFNUM<>"" & [F:CTRW]CTRDAT<=[M:DIA]DATFIN & ([CTRW]XITDAT=[0/0/0] | [CTRW]XITDAT>=[M:DIA]DATDEB)
Else
 Link [CTRW] With
&    [ID]ID0=[F:CTRW]REFNUM,
&    [FCY]FCY0=[F:CTRW]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY
& As [LECT]
& Where evalue(CRITERE) & [F:CTRW]CTRDAT<=[M:DIA]DATFIN & ([CTRW]XITDAT=[0/0/0] | [CTRW]XITDAT>=[M:DIA]DATDEB)
Endif

Link [VPH] With
&   [FCY]FCY0 = [F:VPH]FCY
&   As [LLK]
&   Where evalue(CRITERE2)
Return


$CHARGE
Effzo [SVV]10
nolign = 0
PLEIN = 0

## On charge les valeurs prévisionnelles existantes
For [LLK]
 OK = 1
 Read [ID]ID0=[F:VPH]EMP
 If !fstat
  Call CONTROLE_VPH([F:VPH]EMP,[F:VPH]CTRDAT,[F:VPH]CTRNUM,[M:DIA]CRI,OK,1)
  If OK
   Filter [VPR] Where EMP=[F:VPH]EMP & CTRNUM=[F:VPH]CTRNUM & DAT>=[M:DIA]DATDEB & (DAT<=[M:DIA]DATFIN | [M:DIA]DATFIN=[0/0/0])
&                    & find(VARCOD,[F:SVR]VARCOD(0..[F:SVR]NBRVAR-1))
&                    & CTRDAT=[F:VPH]CTRDAT
   For [VPR]VPR0(4)
    If nolign>=dim([M:SVV]MAT)-1
     PLEIN = 1 : Break 2
    Endif
    [M:SVV]MAT(nolign) = [F:ID]REFNUM
    [M:SVV]DES(nolign) = [F:ID]NAM-[F:ID]SRN
    [M:SVV]CTR(nolign) = [F:VPR]CTRNUM
    [M:SVV]CTRDAT(nolign) = [F:VPR]CTRDAT
    Read [F:CTRW]CTR0=[F:ID]REFNUM;[F:VPR]CTRNUM;[F:VPR]CTRDAT
    [M:SVV]XITDAT(nolign) = [F:CTRW]XITDAT

    [M:SVV]DAT(nolign) = [F:VPR]DAT
    [M:SVV]FLG(nolign) = 1
    For [VPR]VPR0
     Read [HRPCB]PCB0=[F:VPR]VARCOD;[M:SVV]MAT(nolign);format$("D:4Y2M2D",[M:SVV]DAT(nolign));[M:SVV]CTR(nolign);[M:SVV]CTRDAT(nolign)
     If fstat : Raz [HRPCB] : Endif
     Case [F:VPR]VARCOD
      When [M:SVV]VAR1
       [M:SVV]VRI1(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT1(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB1(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR2
       [M:SVV]VRI2(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT2(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB2(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR3
       [M:SVV]VRI3(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT3(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB3(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR4
       [M:SVV]VRI4(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT4(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB4(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR5
       [M:SVV]VRI5(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT5(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB5(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR6
       [M:SVV]VRI6(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT6(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB6(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR7
       [M:SVV]VRI7(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT7(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB7(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR8
       [M:SVV]VRI8(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT8(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB8(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR9
       [M:SVV]VRI9(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT9(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB9(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR10
       [M:SVV]VRI10(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT10(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB10(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR11
       [M:SVV]VRI11(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT11(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB11(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR12
       [M:SVV]VRI12(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT12(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB12(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR13
       [M:SVV]VRI13(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT13(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB13(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR14
       [M:SVV]VRI14(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT14(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB14(nolign) = [F:HRPCB]CLOB
      When [M:SVV]VAR15
       [M:SVV]VRI15(nolign)  = [F:VPR]VARVAL
       [M:SVV]CMT15(nolign)  = [F:VPR]CMT
       [M:SVV]CLOB15(nolign) = [F:HRPCB]CLOB
     Endcase
    Next
    nolign +=1
   Next
  Endif
 Endif
Next
Filter [VPR]
[M:SVV]TBL = nolign
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
 Return
Endif

## On charge les salariés qui répondent aux critères de sélection et qui n'ont pas de valeurs prévisionnelles
For [LECT]
 OK = 1
 For I=0 To nolign
  If [F:ID]REFNUM=[M:SVV]MAT(I) & [F:CTRW]CTRNUM=[M:SVV]CTR(I) & [F:CTRW]CTRDAT=[M:SVV]CTRDAT(I)
   OK = 0 : Break
  Endif
 Next
 If OK
  Call CONTROLE([F:ID]REFNUM,[F:CTRW]CTRDAT,[F:CTRW]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
 Endif
 If OK
  If nolign>=dim([M:SVV]MAT)-1
   PLEIN = 1 : Break
  Endif
  [M:SVV]MAT(nolign) = [F:ID]REFNUM
  [M:SVV]DES(nolign) = [F:ID]NAM-[F:ID]SRN
  #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
  [M:SVV]CTR(nolign) = [F:CTRW]CTRNUM
  #[M:SVV]CTR(nolign) = [F:HRCTR]CTRNUM
  #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
  [M:SVV]CTRDAT(nolign) = [F:CTRW]CTRDAT
  [M:SVV]XITDAT(nolign) = [F:CTRW]XITDAT
  [M:SVV]FLG(nolign) = 1
  nolign +=1
 Endif
Next
[M:SVV]TBL = nolign
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
 Return
Endif
Return

$CONTROLE
#Affectations indispensables pour avoir GCURLEG renseigné dans la 2ième fenêtre
#Sinon on le perd...
If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
If GSTATUT=GSTAOK
 SYMBOLE = "SAIPRV"+[M:DIA]SVR+GCURLEG
 Lock =SYMBOLE
 If fstat
  GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
  GERR=1 : Gosub DEVERROU : Return
 Endif
 TMP = 1
Else
 FIN = 1
Endif
Return

$DEVERROU
#Unlock SYMBOLE
SYMBOLE = "SAIPRV"+[M:DIA]SVR+GCURLEG
Unlock =SYMBOLE
FIN=1
Return


$OK
Case GBOITE
 When "TRTSAIPRV"
  Local Decimal TOTVAL
  For I=0 To [M]TBL-1
   TOTVAL=0
   For J=1 To 15
    TOTVAL+=evalue("[M:SVV]VRI"+num$(J)+"("+num$(I)+")")
   Next
   If [M]DAT(I)=[0/0/0] & TOTVAL        :#Date obligatoire que si au moins une valeur saisie
    # Date obligatoire
    GERR=1 : GMESSAGE=mess(69,10702,1)
    SUIZON ="[M]DAT("+num$(I)+")"
    FIN = 0
    Break
   Endif
  Next
  If FIN=0 : Return : Endif
  Call DEBTRANS From GLOCK
  Gosub ENREGISTRER
  Gosub DEVERROU
 When "SAICMT"
  PARAM(1) = [M:CMT]CMT
 When "VARTEXT"
  If len([M]VARTXT)>0
   Assign PARAM(1) With [M]VARTXT
  Endif
Endcase
Return

$BOUTON
Case GBOITE
When "DCRITPRV"
 Case BOUT
  When "R" :
    Call AFF_MEMO From DIVPAYE
  Endcase
Endcase
Return

$ENREGISTRER
Local Char VARIA (GLONVRA)
Local Decimal VARVAL
GOK=1
Trbegin [VPH], [VPR]

 ##On efface les lignes supprimées et stockées dans TBL2
 For I=0 To [M]TBL2-1
  For J=1 To 15
   VARIA = evalue("[M:SVV]VAR"+num$(J))
   If VARIA<>""
     Delete [VPR] Where EMP=[M:SVV]MAT2(I) & CTRNUM=[M:SVV]CTR2(I) & DAT=[M:SVV]DAT2(I) & VARCOD=VARIA & CTRDAT=[M:SVV]CTRDAT2(I)
     If fstat=1
      GOK = -1 : GLOCK = "$VALPRV"-[M:SVV]MAT2(I)-[M:SVV]CTR2(I)-num$([M:SVV]CTRDAT2(I))-num$([M:SVV]DAT2(I))-VARIA
      Break
     Endif
     Delete [HRPCB] Where CODBLB=VARIA & IDENT1=[M:SVV]MAT2(I) & IDENT2=format$("D:4Y2M2D",[M:SVV]DAT2(I)) & IDENT3=[M:SVV]CTR2(I)
&                   & IDENT4=[M:SVV]CTRDAT2(I)
     If fstat=1
      GOK = -1 : GLOCK = "$PRVCLOB"-[M:SVV]MAT2(I)-num$([F:SVV]DAT2(I))-VARIA-[M:SVV]CTR2(I)-num$([M:SVV]CTRDAT2(I))
      Break
     Endif
   Endif
  Next
  Filter [VPR] Where EMP=[M:SVV]MAT2(I) & CTRNUM=[M:SVV]CTR2(I) & CTRDAT=[M:SVV]CTRDAT2(I)
  Read [VPR]VPR0 First
  Filter [VPR]
  If fstat
   Delete [VPH]VPH0=[M:SVV]MAT2(I);[M:SVV]CTR2(I);[M:SVV]CTRDAT2(I)
   If fstat=1
    GOK = -1 : GLOCK = "$VALPRVH"-[M:SVV]MAT2(I)-[M:SVV]CTR2(I)-num$([M:SVV]CTRDAT2(I))
    Break
   Endif
  Endif
 Next
# On efface tous les enregs des lignés chargées de VALPRV, VALPRH, PRVCLOB
For I=0 To [M]TBL-1
 For J=1 To 15
  VARIA = evalue("[M:SVV]VAR"+num$(J))
  If VARIA<>""
   Delete [VPR] Where EMP=[M:SVV]MAT(I) & CTRNUM=[M:SVV]CTR(I) & DAT=[M:SVV]DAT(I) & VARCOD=VARIA & CTRDAT=[M:SVV]CTRDAT(I)
   If fstat=1
    GOK = -1 : GLOCK = "$VALPRV"-[M:SVV]MAT(I)-[M:SVV]CTR(I)-num$([M:SVV]CTRDAT(I))-num$([M:SVV]DAT(I))-VARIA
    Break
   Endif
   Delete [HRPCB] Where CODBLB=VARIA & IDENT1=[M:SVV]MAT(I) & IDENT2=format$("D:4Y2M2D",[M:SVV]DAT(I)) & IDENT3=[M:SVV]CTR(I)
&                   & IDENT4=[M:SVV]CTRDAT(I)
   If fstat=1
    GOK = -1 : GLOCK = "$PRVCLOB"-[M:SVV]MAT(I)-num$([F:SVV]DAT(I))-VARIA-[M:SVV]CTR(I)-num$([M:SVV]CTRDAT(I))
    Break
   Endif
  Endif
 Next
 Filter [VPR] Where EMP=[M:SVV]MAT(I) & CTRNUM=[M:SVV]CTR(I) & CTRDAT=[M:SVV]CTRDAT(I)
 Read [VPR]VPR0 First
 Filter [VPR]
 If fstat
  Delete [VPH]VPH0=[M:SVV]MAT(I);[M:SVV]CTR(I);[M:SVV]CTRDAT(I)
  If fstat=1
   GOK = -1 : GLOCK = "$VALPRVH"-[M:SVV]MAT(I)-[M:SVV]CTR(I)-num$([M:SVV]CTRDAT(I))
   Break
  Endif
 Endif
Next

# On met à jour les valeurs prévisionnelles
# VALPRVH
For I=0 To [M]TBL-1
 #On n'enregistre pas les lignes pour une date de paie nulle...
 If [M:SVV]DAT(I)<>[0/0/0]
  Read [ID]ID0=[M:SVV]MAT(I)
  Read [F:CTRW]CTR0=[M:SVV]MAT(I);[M:SVV]CTR(I);[M:SVV]CTRDAT(I)
  Readlock [VPH]VPH0=[M:SVV]MAT(I);[M:SVV]CTR(I);[M:SVV]CTRDAT(I)
  If !fstat
   #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
   [F:VPH]FCY    = [F:CTRW]ETRFCY
   [F:VPH]SRV    = [F:CTRW]ETRSRV
   #[F:VPH]FCY    = [F:HRCTR]ETRFCY
   #[F:VPH]SRV    = [F:HRCTR]ETRSRV
   #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
   [F:VPH]CODACS = [F:ID]CODACS
   If dim([F:VPH]UPDDAT)>0 : [F:VPH]UPDDAT = date$ : Endif
   If dim([F:VPH]UPDUSR)>0 : [F:VPH]UPDUSR = GUSER : Endif
   If dim([F:VPH]UPDTIM)>0 : [F:VPH]UPDTIM = time  : Endif
   Rewrite [VPH]
  Elsif fstat>1
   Raz [F:VPH]
   [F:VPH]EMP    = [F:ID]REFNUM
   #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
   [F:VPH]CTRNUM = [F:CTRW]CTRNUM
   [F:VPH]CTRDAT = [F:CTRW]CTRDAT
   [F:VPH]FCY    = [F:CTRW]ETRFCY
   [F:VPH]SRV    = [F:CTRW]ETRSRV
   #[F:VPH]CTRNUM = [F:HRCTR]CTRNUM
   #[F:VPH]CTRDAT = [F:CTRW]CTRDAT
   #[F:VPH]FCY    = [F:HRCTR]ETRFCY
   #[F:VPH]SRV    = [F:HRCTR]ETRSRV
   #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
   [F:VPH]CODACS = [F:ID]CODACS
   If dim([F:VPH]CREDAT)>0 : [F:VPH]CREDAT = date$ : Endif
   If dim([F:VPH]CREUSR)>0 : [F:VPH]CREUSR = GUSER : Endif
   If dim([F:VPH]CRETIM)>0 : [F:VPH]CRETIM = time  : Endif
   Write [VPH]
  Endif
  If fstat
   GOK = 0 : Call FSTA("VPH") From GLOCK : Break
  Endif

  For J=1 To 15
   VARIA = evalue("[M:SVV]VAR"+num$(J))
   VARVAL= evalue("[M:SVV]VRI"+num$(J)+"("+num$(I)+")")
   If VARIA<>"" & VARVAL
    Readlock [VPR]VPR0=[M:SVV]MAT(I);[M:SVV]CTR(I);[M:SVV]CTRDAT(I);[M:SVV]DAT(I);VARIA
    If !fstat
     [F:VPR]VARVAL = VARVAL
     [F:VPR]CMT    = evalue("[M:SVV]CMT"+num$(J)+"("+num$(I)+")")
     If dim([F:VPR]UPDDAT)>0 : [F:VPR]UPDDAT = date$ : Endif
     If dim([F:VPR]UPDUSR)>0 : [F:VPR]UPDUSR = GUSER : Endif
     If dim([F:VPR]UPDTIM)>0 : [F:VPR]UPDTIM = time  : Endif
     Rewrite [VPR]
    Elsif fstat>1
     Raz [F:VPR]
     [F:VPR]EMP    = [M:SVV]MAT(I)
     [F:VPR]CTRNUM = [M:SVV]CTR(I)
     [F:VPR]CTRDAT = [M:SVV]CTRDAT(I)
     [F:VPR]DAT    = [M:SVV]DAT(I)
     [F:VPR]VARCOD = VARIA
     [F:VPR]VARVAL = VARVAL
     [F:VPR]CMT    = evalue("[M:SVV]CMT"+num$(J)+"("+num$(I)+")")
     If dim([F:VPR]CREDAT)>0 : [F:VPR]CREDAT = date$ : Endif
     If dim([F:VPR]CREUSR)>0 : [F:VPR]CREUSR = GUSER : Endif
     If dim([F:VPR]CRETIM)>0 : [F:VPR]CRETIM = time  : Endif
     Write [VPR]
    Endif
    If fstat
     GOK = 0 : Call FSTA("VPR") From GLOCK : Break 2
    Endif
    If len(evalue("[M:SVV]CLOB"+num$(J)+"("+num$(I)+")"))>0
     #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
     Readlock [HRPCB]PCB0=VARIA;[M:SVV]MAT(I);format$("D:4Y2M2D",[M:SVV]DAT(I));[M:SVV]CTR(I);[M:SVV]CTRDAT(I)
     #Readlock [HRPCB]PCB0=VARIA;[M:SVV]MAT(I);format$("D:4Y2M2D",[M:SVV]DAT(I));[M:SVV]CTR(I)
     #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
     If !fstat
      [F:HRPCB]CLOB   = evalue("[M:SVV]CLOB"+num$(J)+"("+num$(I)+")")
      If dim([F:HRPCB]UPDUSR)>0 : [F:HRPCB]UPDUSR = GUSER : Endif
      If dim([F:HRPCB]UPDDAT)>0 : [F:HRPCB]UPDDAT = date$ : Endif
      If dim([F:HRPCB]UPDTIM)>0 : [F:HRPCB]UPDTIM = time  : Endif
      Rewrite [HRPCB]
     Elsif fstat>1
      # Création des commentaires
      Raz [F:HRPCB]
      [F:HRPCB]CODBLB = VARIA
      [F:HRPCB]IDENT1 = [M:SVV]MAT(I)
      [F:HRPCB]IDENT2 = format$("D:4Y2M2D",[M:SVV]DAT(I))
      [F:HRPCB]IDENT3 = [M:SVV]CTR(I)
      [F:HRPCB]IDENT4 = [M:SVV]CTRDAT(I)
      [F:HRPCB]CLOB   = evalue("[M:SVV]CLOB"+num$(J)+"("+num$(I)+")")
      If dim([F:HRPCB]CREUSR)>0 : [F:HRPCB]CREUSR = GUSER : Endif
      If dim([F:HRPCB]CREDAT)>0 : [F:HRPCB]CREDAT = date$ : Endif
      If dim([F:HRPCB]CRETIM)>0 : [F:HRPCB]CRETIM = time  : Endif
      Write [HRPCB]
     Endif
     #FRLAA - 2016-04-18 - REQUIREMENT 114309 US 116 - START
     # Only 2 loops not 3
     If fstat : GOK = 0 : Call FSTA("HRPCB") From GLOCK : Break 2 : Endif
     #If fstat : GOK = 0 : Call FSTA("HRPCB") From GLOCK : Break 3 : Endif
     #FRLAA - 2016-04-18 - REQUIREMENT 114309 US 116 - END
    Endif
   Endif
  Next
 Endif
Next
If GOK<1 : Rollback : Return : Endif
Commit
Return

$FIN
Gosub DEVERROU
Return

######################################################################################

Subprog CONTROLE_VPH(MATRI,DATMAT,CTR,CRI,OK,FLG)
Value    Char    MATRI()
Value    Date    DATMAT
Value    Char    CTR ()
Value    Char    CRI()
Value    Integer FLG
Variable Integer OK

OK = 1
If clalev([F:ACC])=0  : Local File ACCES [ACC]     : Endif
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif

## Flag actif
If [F:ID]ENAFLG<>2 & FLG=1
 OK = 0 : End
Endif

# Critère libre
If CRI<>""
 Gosub LECEMP From WPDEFTABLE
 If !evalue(CRI)
  OK = 0 : End
 Endif
Endif

## Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  OK = 0 : End
 Endif
Endif

# Code d'accès
If [F:VPH]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:VPH]CODACS
 If fstat or [F:ACC]EXEC<>2
  OK = 0 : End
 Endif
Endif

# Droits par site
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:VPH]FCY,GUSRFCY(1..GNBAUZ))
  OK = 0 : End
 Endif
Endif

# Droits par service
If GUSRACS<>2 & !find([F:VPH]SRV,GAUTSRV(1..GNBSERV))
 OK = 0 : End
Endif

# Profil
If [M:DIA]ALLPRF<>2
 Filter [CTR1] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
 Read [CTR1]CTR0 Last
 Filter [CTR1]
 If fstat | [F:CTR1]PROPRF<>[M:DIA]PRF
  OK = 0 : End
 Endif
Endif

# Population
If [M:DIA]POP<>""
 #86255
 #Read[HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
 Filter [CTR1] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
 Read [CTR1]CTR0 Last
 Filter [CTR1]
 If fstat :  OK = 0 : End : Endif
 Read[HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM;[F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
 If fstat :  OK = 0 : End : Endif
Endif
End


######################################################################################
# Gestion du masque TRTSAIPRV
######################################################################################
#########################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

#########################
Subprog B1_TBL
Call B1_TBL From TRTSAIVAR
End

#########################
Subprog AVANT_TBL
Call AVANT_TBL From TRTSAIVAR
End

#########################
Subprog AS_DAT(VALEUR)
Variable Date    VALEUR
Local Integer    I
## On initialise la date avec la date de la ligne précédente
If VALEUR<>[0/0/0] : End : Endif

#FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
## On initialise la date avec la date de fin de contrat si elle existe
If [M]XITDAT(nolign-1)<>[0/0/0]
  VALEUR=[M]XITDAT(nolign-1) : End
Endif
## On initialise la date avec la date de la ligne précédente
#FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END

If nolign>1
 For I=nolign-2 To 0 Step -1
  If [M]DAT(I)<>[0/0/0]
   VALEUR = [M]DAT(I)
   Break
  Endif
 Next I
Endif
End

#########################
Subprog C_DAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]DATDEB | (VALEUR>[M:DIA]DATFIN & [M:DIA]DATFIN<>[0/0/0])
 # Date en dehors de la période définie
 GMESSAGE = mess(38,10703,1)-"("+format$(GFMD,[M:DIA]DATDEB)-"->"-format$(GFMD,[M:DIA]DATFIN)+")"
 mkstat = 2 : End
Endif
End

#########################
Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If [M]MAT(NOL)<>""
 [M]DAT(NOL)=VALEUR
 Gosub FIND_CTR
 If mkstat : mkstat=2 : End : Endif
 If VALEUR>[M]XITDAT(NOL) & [M]XITDAT(NOL)<>[0/0/0]
  # Période incompatible avec les entrées-sorties
  GMESSAGE = mess(26,10702,1)
  mkstat = 2 : End
 Endif
Endif
End

#########################
Subprog B1_DAT(VALEUR)
Variable Date    VALEUR
Local Integer I , NOL
If VALEUR<[M:DIA]DATDEB | (VALEUR>[M:DIA]DATFIN & [M:DIA]DATFIN<>[0/0/0])
 # Date en dehors de la période définie
 GMESSAGE = mess(38,10703,1)-"("+format$(GFMD,[M:DIA]DATDEB)-"->"-format$(GFMD,[M:DIA]DATFIN)+")"
 mkstat = 2 : End
Endif
NOL = nolign-1
For I=NOL+1 To [M]TBL-1
 If VALEUR>[M]XITDAT(I) & [M]XITDAT(I)<>[0/0/0]
  [M:SVV]DAT(I)   = [M]XITDAT(I)
 Else
 [M:SVV]DAT(I)   = VALEUR
 Endif
 [M:SVV]MODIF(I) = 1
Next I
Affzo [SVV]DAT
End

#########################
Subprog AS_MAT(VALEUR)
Variable Char    VALEUR()
If [M]FLG(nolign-1)=1 : mkstat = 2 : End : Endif
End

#########################
Subprog C_MAT(VALEUR)
Variable Char    VALEUR()
[M]DES(nolign-1) = [F:ID]NAM-[F:ID]SRN
End

#########################
Subprog AM_MAT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Raz [M]CTR(NOL)
Raz [M]CTRDAT(NOL)
Raz [M]XITDAT(NOL)
If [F:ID]FLGMULCTR<>2
 [M]MAT(NOL)=VALEUR
 Gosub FIND_CTR
 If mkstat : mkstat=2 : End : Endif
Endif
End

#########################
$FIND_CTR
Filter [CTRW] Where REFNUM=[M]MAT(NOL) & ([M]CTR(NOL)="" | CTRNUM=[M]CTR(NOL)) & ((FLGRET<>2 & CTRDAT<=[M]DAT(NOL)) | (FLGRET=2 & RETDATEFF<=[M]DAT(NOL)))
Read [CTRW]CTR1 Last
Filter [CTRW]
If !fstat
 [M]CTR(NOL) = [F:CTRW]CTRNUM
 [M]CTRDAT(NOL) = [F:CTRW]CTRDAT
 [M]XITDAT(NOL) = [F:CTRW]XITDAT
Endif
Gosub CTRL_CRITERIA
If mkstat : Return : Endif
Affzo [M]CTR(NOL)
Affzo [M]CTRDAT(NOL)
Affzo [M]XITDAT(NOL)
Return

#########################
$CTRL_CRITERIA
Local Integer I
For I=0 To [M]TBL-1
 If I<>NOL
  If [M]MAT(NOL)=[M]MAT(I) & [M]DAT(NOL)=[M]DAT(I) & [M]CTR(NOL)=[M]CTR(I) & [M]CTRDAT(NOL)=[M]CTRDAT(I)
   GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
   mkstat=2 : Break
  Endif
 Endif
Next
If mkstat : Return : Endif

Local Integer OK, MOK
Local Char MESSA (100)
MESSA = ""
If [M:DIA]CPY<>""
 Call LECTURE("FCY",[F:CTRW]ETRFCY,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M:DIA]CPY
  MESSA += mess(42,10702,1)-":"-[F:FCY]LEGCPY : # Société
 Endif
 If [M:DIA]FCY<>"" & [F:CTRW]ETRFCY<>[M:DIA]FCY
  If MESSA<>"" : MESSA += "\" : Endif
  MESSA += mess(43,10702,1)-":"-[F:CTRW]ETRFCY : # Site
 Endif
Endif
If [M:DIA]SRV<>"" & [M:DIA]SRV<>[F:CTRW]ETRSRV
 If MESSA<>"" : MESSA += "\" : Endif
 MESSA += mess(44,10702,1)-[F:CTRW]ETRSRV : # Service
Endif
#FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
If [M:DIA]PRF<>"" & [M:DIA]PRF<>[F:CTRW]PROPRF
#If [M:DIA]PRF<>"" & [M:DIA]PRF<>[F:CTRW]PRF
#FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - END
 If MESSA<>"" : MESSA += "\" : Endif
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
 MESSA += mess(45,702,1)-[F:CTRW]PROPRF : # Profil
 #MESSA += mess(45,10702,1)-[F:CTRW]PRF : # Profil
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 116 - START
Endif
If [M:DIA]POP<>""
 Read [POA]POA0=[M:DIA]POP;VALEUR
 If fstat
  If MESSA<>"" : MESSA += "\" : Endif
  MESSA += mess(129,10702,1)-[M:DIA]POP : # Ce salarié n'appartient pas à la population XXX
 Endif
Endif
Call CONTROLE_VPH(VALEUR,[M]CTRDAT(NOL),[M]CTR(NOL),[M:DIA]CRI,MOK,1)
If !MOK
 If MESSA<>"" : MESSA += "\" : Endif
 MESSA += mess(143,10702,1) : # Salarié non autorisé
Endif
If MESSA<>""
 Call LECTURE("EML",[M]MAT(NOL),"") From CONTOBJ
 OK = 2 : Call AVERTIR([F:CTRW]REFNUM-[F:ID]NAM-[F:ID]SRN+"\"+MESSA,OK) From GESECRAN
 If OK<>2 : mkstat = 2 : Return : Endif
Endif
Return

#########################
Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Call LECTURE("EML",[M]MAT(NOL),"") From CONTOBJ
If [F:ID]FLGMULCTR<>2 : mkstat=2 : End : Endif
End

#########################
Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Raz [M]CTRDAT(NOL)
Raz [M]XITDAT(NOL)
[M]CTR(NOL)=VALEUR
Gosub FIND_CTR
If mkstat : mkstat=2 : End : Endif
End

#########################
$CTL_DAT
If VALEUR<>0 & [M]DAT(nolign-1)=[0/0/0]
 Call AS_DAT([M]DAT(nolign-1))
 If [M]DAT(nolign-1)=[0/0/0]
  # Date obligatoire
  Call ERREUR(mess(69,10702,1)) From GESECRAN
  zonsui="[M]DAT("+num$(nolign-1)+")"
 Else
  Affzo [M]DAT(nolign-1)
 Endif
Endif
Return


Subprog IB_VRI1
Local Char VRIZON(30)
VRIZON = [M]VAR1
Gosub IB_BOUTON
End

Subprog AS_VRI1(VALEUR)
Variable Decimal VALEUR
Call AS_VRI1(VALEUR) From TRTSAIVAR
End

Subprog C_VRI1(VALEUR)
Variable Decimal VALEUR
Gosub CTL_DAT
End

Subprog B1_VRI1(VALEUR)
Variable Decimal VALEUR
Call B1_VRI1(VALEUR) From TRTSAIVAR
End

Subprog IB_VRI2
Local Char VRIZON(30)
VRIZON = [M]VAR2
Gosub IB_BOUTON
End

Subprog AS_VRI2(VALEUR)
Variable Decimal VALEUR
