$UPDATE_2230
  If clalev([F:HRCDI]) = 0 : Local File =LDOSSIER+"."+"CADIEDEF" [F:HRCDI]  : Endif

  Filter [F:HRCDI]
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 1  With [F:HRCDI]OBJ = 18 #Employee
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 2  With [F:HRCDI]OBJ = 19 #Department
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 3  With [F:HRCDI]OBJ = 20 #Profile
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 6  With [F:HRCDI]OBJ = 21 #Event
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 7  With [F:HRCDI]OBJ = 22 #Nature of activity
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 8  With [F:HRCDI]OBJ = 23 #Expenses for expense notes
  Update [F:HRCDI] Where [F:HRCDI]OBJ = 4  With [F:HRCDI]OBJ = 8  #Currency
Return
########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_LMNUMBERS(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_LMNUMBERS(APPLI)
End

