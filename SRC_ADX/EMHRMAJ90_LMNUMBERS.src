  Update [F:HRCCL] Where [F:HRCCL]TXT = 1  With [F:HRCCL]TXT = 190 #Payroll MO
  Update [F:HRCCL] Where [F:HRCCL]TXT = 2  With [F:HRCCL]TXT = 191 #Payment Net Payable
