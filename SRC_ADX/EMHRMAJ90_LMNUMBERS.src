  Update [F:HRCAC] Where [F:HRCAC]TYP = 11 With [F:HRCAC]TYP = 34 #Expense note
  Update [F:HRCAC] Where [F:HRCAC]TYP = 12 With [F:HRCAC]TYP = 10 #Tax
