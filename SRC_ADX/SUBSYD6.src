# Gestion du masque SYD6
$ACTION
  Case ACTION
    When Default
  Endcase
Return

##########################################################################################################
Subprog AM_CORFCTTXT(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SYD6]CORCNTFCT = 0
  Endif
End
