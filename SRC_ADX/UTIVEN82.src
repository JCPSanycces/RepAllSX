#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIVEN82                                                                           #
#                                                                                    #
# SALES module migration update tool for V11.0.2 (V11 Patch 2)                       #
# This script is launched when the patch 2 is applied on a V11 version               #
# For a migration to a highest version than V11, if the source folder level is lower #
# than 11.0.2, the post migration script UUMGPOSSAL02                                #
#                                                                                    #
# - 107888 / X3-15185 => Schedule invoice : initialization of INRNOT/INRATI on Sales #
#                        orders.                                                     #
#                                                                                    #
######################################################################################
  Call MAJ_UTIVEN82
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN82
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN82 - Upgrade process to V11 patch 2 for sales module") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN82 - Upgrade process to V11 patch 2 for sales module") From LECFIC
    Call EXE_UTIVEN82(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN82(DOSSIER)
Value Char    DOSSIER
  Call ECR_TIME("UTIVEN82 : Start folder's process"-DOSSIER) From DOSSUB
  #----- Start INRNOT/INRATI field init -----#
  Gosub TRT_INRXXX
  #----- End INRNOT/INRATI field init -----#
$FIN_UTIVEN82
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVEN82 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialization of the new field INRNOT and INRATI for scheduled invoices    #
#-------------------------------------------------------------------------------#
$TRT_INRXXX
 # Tables SORDER / VSORDER
 # Criterias :
 #   - SOHCAT = 1 or 3
 #   - BETFCY <> 2
 #   - INVSTA <3

  If GTRACE=""
   Call OUVRE_TRACE("UTIVEN82 - Upgrade process to V11 patch 2 for sales module") From LECFIC
   Local Integer LTRACE
  Endif

  If filinfo(filpath("FIL","SORDER","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","VSORDER","fde",DOSSIER),0) <= 0 Then
    Return
  Endif

  Local File =DOSSIER+".SORDER"    [SOH]
  Local File =DOSSIER+".VSORDER"   [VOH]

  GOK=1
  Trbegin [SOH]

  Update [SOH] Where (BETFCY<2 | (BETFCY=2 & BETCPY=2)) & INVSTA<3 & (SOHCAT=1 | SOHCAT=3)
&              With  INRNOT=[F:SOH]DLRNOT, INRATI=[F:SOH]DLRATI
  If fstat
   GOK=0
   Call ECR_TRACE("UTIVEN82/TRT_INRXXX => Error update SORDER="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("UTIVEN82/TRT_INRXXX => Nb updated sales orders (SORDER)="+num$(adxuprec),0) From GESECRAN
  Endif

  If GOK
    Update [VOH] Where (BETFCY<2 | (BETFCY=2 & BETCPY=2)) & INVSTA<3 & (SOHCAT=1 | SOHCAT=3)
&                With  INRNOT=DLRNOT, INRATI=DLRATI
    If fstat
     GOK=0
     Call ECR_TRACE("UTIVEN82/TRT_INRXXX => Error update VSORDER="+num$(fstat),1) From GESECRAN
    Else
     Call ECR_TRACE("UTIVEN82/TRT_INRXXX => Nb updated sales orders history (VSORDER)="+num$(adxuprec),0) From GESECRAN
    Endif
  Endif

  If GOK<1
   Rollback
  Else
   Commit
  Endif

  If dim(LTRACE)>0
   Call LEC_TRACE From LECFIC
  Endif

Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN82(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN82(APPLI)
End

