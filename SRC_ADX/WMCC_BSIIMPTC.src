#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 263


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub _AVARIABLES From WMC00BSIIMPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_BSIIMPTC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMC00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_BSIIMPTC
Else
 Gosub AINSERT_BSIIMPTC
Endif

Gosub _AINSERT_AFTER
[L]A_I = BSIIMPTC.freeSnapshot
BSIIMPTC.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If BSIIMPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
BSIIMPTC.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and !find(BSIIMPTC.LINES(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and !find(BSIIMPTC.LINES(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_BSIIMPTC
Trbegin [F:BSITC]
 Gosub AINSERT_BSIIMPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_BSIIMPTC
Raz [F:BSITC]
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00BSIIMPTC._MAJSQL_BSIIMPTC(BSIIMPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]A_TYPMAJ=[V]CST_ANEW

#-----------------------------------------------------#
For A_N2=1 To maxtab(BSIIMPTC.LINES)
 If BSIIMPTC.LINES(A_N2) <> null and
& (BSIIMPTC.LINES(A_N2).ASTALIN=[L]A_TYPMAJ or
& BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ALL)
  If BSIIMPTC.LINES(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:BSITCD]
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00BSIIMPTC._MAJSQL_BSIITCD(BSIIMPTC.LINES(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If BSIIMPTC.snapshotEnabled=1
 [L]A_RETIK = BSIIMPTC.revertUpdTick
Endif
[L]ASTATUS = max(fmet BSIIMPTC.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(BSIIMPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 BSIIMPTC.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(BSIIMPTC.LINES)
 If BSIIMPTC.LINES(A_N2) <> null
  If BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ADEL or BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance BSIIMPTC.LINES(A_N2)
   BSIIMPTC.LINES(A_N2) = null
  Elsif BSIIMPTC.LINES(A_N2).ASTALIN <> [V]CST_ALL
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



