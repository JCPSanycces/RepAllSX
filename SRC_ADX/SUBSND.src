#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier SINCDET
#######################################################################
# SUBSND : Paramétrage augmentation tarifs (lignes)
#######################################################################

$ACTION
Case ACTION
 When "OUVRE"              : Gosub OUVRE
 When "LIENS"              : Gosub LIENS
 When "FILTRE"             : Gosub FILTRE
 When "SETBOUT"            : Gosub SETBOUT
 When "FILGAUCHE"          : Gosub FILTRE
 When "RAZCRE"             : Gosub RAZCRE
 When "INICRE"             : Gosub INICRE
 When "INIMOD"             : Gosub INICRE
 When "ANNULE"             : Gosub ANNULE
 When Default    
Endcase 
Return

#######################################################################
$OUVRE
Local  Char    APPLI    : # nom du dossier (pour generer ecrans et traitements) 
Local  Integer I

APPLI=nomap

If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif
If clalev([F:AXX])=0 : Local File =APPLI+".ATEXTRA"     [AXX] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:SPI])=0 : Local File =APPLI+".SPRICINCR"   [SPI] : Endif

# --- Traitements generes pour les tables liees
#     les tables sont ouvertes pour permettre l'evaluation des formules selection et calcul

For I=0 To dim([F:SNE]TBL)-1
  If [F:SNE]TBL(I)<>""
    Read [F:ATB]CODFIC=[F:SNE]TBL(I)    
    If !fstat
      If evalue("clalev (["+[F:ATB]ABRFIC+"])") =0 : Local File =APPLI+"."+[F:ATB]CODFIC : Endif  
    Endif
  Endif
Next I

[M:SPID]COD=[F:SNE]COD

Return

#######################################################################
$LIENS
Local Integer I, IJL 
[M:SPID]PLISTC=[F:SNE]PLISTC
Gosub LES_COLONNES
[M:SPID]COD=[F:SNE]COD
Gosub LIB_DCGVAL
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30 
Return

#######################################################################
$FILTRE
If !GPILSEL : FILTSUP = 'COD="'+[F:SNE]COD+'"' : Endif
Return

#######################################################################
$SETBOUT
#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET
 
Return

#######################################################################
$RAZCRE
[M:SPID]COD=[F:SNE]COD
[M:SPID]PLISTC=[F:SNE]PLISTC
Diszo [SPID]COD
Gosub LES_COLONNES
Gosub LIB_DCGVAL
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30 
Return

#######################################################################
$INICRE
[F:SND]COD=[F:SNE]COD
[F:SND]CODLINCAR=num$([F:SND]CODLIN)
If [M]DELFLG=2  Grizo 30  Else Actzo 30  Endif  
Affzo 30

# ACA
Call MAJTEXTRA([M:SPID]DESAXX, "SINCDET","DESAXX",[M:SPID]COD,num$([M:SPID]CODLIN)) From ATEXTRA
# SOS Libellés
If dim([F:SND]LANDESSHO)>0
    [F:SND]LANDESSHO=GLANGUE+"~"+[M:SPID]DESAXX
Endif

Return

$ANNULE
# ACA - Suppression du texte traduisible
Delete [AXX] Where CODFIC="SINCDET" and IDENT1=[F:SND]COD and IDENT2=num$([F:SND]CODLIN)
Return

#######################################################################
# --- Garnir table des colonnes modifiables suivant structure et tarif
$LES_COLONNES
Local Integer IJL
If [M:SPID]ZONMAJ(0)=""
  [M:SPID]ZONMAJ(0)="PRI" : [M:SPID]ZONMAJLIB(0)=mess(70,200,1)
#  Read [F:PRS]PRS0=1;""
  Read [F:PRS]PRS0=1;[M]PLISTC
  For I=1 To dim([F:PRS]INCDCR)
    If [F:PRS]INCDCR(I-1)=0 : Break : Endif
    [M:SPID]ZONMAJ(I)="XFRAREM"+num$(I)
    Call LECTEXTRA ([M:SPID]ZONMAJLIB(I),"PRICSTRUCT","DESAXX("+num$(I-1)+")","1",[F:PRS]PLISTC)
&                   From ATEXTRA
  Next I 
Endif
Read [F:SPC]SPC0=[F:SNE]PLI
If [F:SPC]PRIPRO>1 & [F:SPC]PRIPRO<6
  [M:SPID]INCFLD(IJL)=[M:SPID]ZONMAJ(0)
  [M:SPID]INCDES(IJL)=[M:SPID]ZONMAJLIB(0)
  IJL +=1
Endif
For I=1 To dim([M:SPID]ZONMAJ)-1
  If [M:SPID]ZONMAJ(I)="" : Break : Endif
  If [F:SPC]DISCRGPRO(I-1)=1
    [M:SPID]INCFLD(IJL)=[M:SPID]ZONMAJ(I)
    [M:SPID]INCDES(IJL)=[M:SPID]ZONMAJLIB(I)
    IJL +=1
  Endif 
Next I
[M:SPID]NBINC=IJL
Affzo [M]
Return

#---------------------------------------------------------------------
$LIB_DCGVAL
#Read [F:PRS]PRS0=1;""
Read [F:PRS]PRS0=1;[M]PLISTC
Read [SPC]SPC0=[F:SNE]PLI
If fstat : Raz [F:SPC] : Endif
Raz [M:SPID]XXPRS
For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)<>0 & [F:SPC]DISCRGPRO(I)=1
     Call LECTEXTRA ([M:SPID]XXPRS(I),"PRICSTRUCT","DESAXX("+num$(I)+")","1",[F:PRS]PLISTC)
&                    From ATEXTRA
  Endif
Next I
Return

#---------------------------------------------------------------------
$CRIT_TARIF
Local Char    TEX (250)
Local Integer NBTEX, I, OK
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    NBTEX += 1
    If NBTEX > 1 : TEX += "\" : Endif
    TEX +="CRIT"+num$(I+1)+"  "+format$("K:20X",[F:SPC]CRIDES(I))+"  "+[F:SPC]FLDTYP(I)
  Endif
Next I
Call AVERTIR (TEX,OK) From GESECRAN

Return

#######################################################################

######################################## Ligne
Subprog AS_CODLIN(VALEUR)
Variable Decimal VALEUR
[M:SPID]COD=[F:SNE]COD
Diszo [SPID]COD
End

######################################## Expression de sélection
Subprog AS_SELFRM(VALEUR)
Variable Char    VALEUR()
Local    Integer I,IJ
Raz [M:SPID]FLTTAB, XXCONV, XXVAR
#[M:SPID]FLTTAB="find(ABRFIC,'SPI')"

[M:SPID]FLTTAB  ="find(ABRFIC,'SPI'"
For I=0 To dim([M:SPIE]TBL)-1
  If [M:SPIE]TBL(I)="" : Break : Endif
  Read [ATB]CODFIC=[M:SPIE]TBL(I) 
  If !fstat : [M:SPID]FLTTAB +=",'"+[F:ATB]ABRFIC+"'" : Endif 
Next I
[M:SPID]FLTTAB +=")"

#   critères variables du tarif
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    [M:SPID]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","+[F:SPC]CRIDES(I)
    IJ += 1 
    [M:SPID]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","+[F:SPC]CRIDES(I)  : # 07/08/03
    IJ += 1                                                               : # 07/08/03  
  Else
    [M:SPID]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
    [M:SPID]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","                   : # 07/08/03
    IJ += 1                                                               : # 07/08/03
  Endif
Next I
For I=0 To dim([F:PRS]INVDTA)-1
  If [M:SPID]XXPRS(I)<>""
    [M:SPID]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"+[M:SPID]XXPRS(I)
    IJ += 1   
  Else
    [M:SPID]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
#   variables du traitement
For I=0 To dim([F:SNE]VARCOD)-1
  If [F:SNE]VARCOD(I)<>"" 
    [M:SPID]XXVAR(I)=[F:SNE]VARCOD(I)+","+[F:SNE]VARDES(I)
  Endif
Next I
End

#---------------------------------------
Subprog C_SELFRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Local Integer ER
  Local Char    CHAINE (80) 
  Default File [SPI]         : # SPRICINCR doit etre le fichier par default
  Gosub VAR_DEF From ="WBI"+[F:SNE]COD
  Onerrgo ERRSELFRM
  ER = 0
  CHAINE = num$(evalue(VALEUR))
  Onerrgo
  If ER
    mkstat = 2 : End
  Endif
Endif
End

$ERRSELFRM
# --- c'est une variable traitement ???
Local Char VARI : VARI=errm
If find(VARI ,[F:SNE]VARCOD(0..dim([F:SNE]VARCOD)-1)) : Resume : Endif
ER = errn
GERR=1 : GMESSAGE=mess(37,124,1)+"\"+errmes$(ER)+"\"+errm : # Expression incorrecte
Resume

######################################## 
Subprog AM_DELFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]INCFLDUPD, INCFRM, INCRNDTYP, INCRND
  Grizo 30 
Else
  Actzo 30
Endif
Affzo 30
End

########################################
Subprog B1_NBINC
Gosub CRIT_TARIF
End

######################################## Expression augmentation
Subprog AS_INCFRM(VALEUR)
Variable Char    VALEUR()
Local    Integer IJ
If [M]INCFLDUPD(nolign-1)<2 : mkstat=2 : End : Endif
Raz [M:SPID]FLTTAB, XXCONV, XXVAR
#[M:SPID]FLTTAB="find(ABRFIC,'SPI')"

[M:SPID]FLTTAB  ="find(ABRFIC,'SPI'"
For I=0 To dim([M:SPIE]TBL)-1
  If [M:SPIE]TBL(I)="" : Break : Endif
  Read [ATB]CODFIC=[M:SPIE]TBL(I) 
  If !fstat : [M:SPID]FLTTAB +=",'"+[F:ATB]ABRFIC+"'" : Endif 
Next I
[M:SPID]FLTTAB +=")"

#   critères variables du tarif
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    [M:SPID]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","+[F:SPC]CRIDES(I)
    IJ += 1 
  Else
    [M:SPID]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1 
  Endif
Next I
For I=0 To dim([F:PRS]INVDTA)-1
  If [M:SPID]XXPRS(I)<>""
    [M:SPID]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"+[M:SPID]XXPRS(I)
    IJ += 1   
  Else
    [M:SPID]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif  
Next I
#   variables du traitement
For I=0 To dim([F:SNE]VARCOD)-1
  If [F:SNE]VARCOD(I)<>"" 
    [M:SPID]XXVAR(I)=[F:SNE]VARCOD(I)+","+[F:SNE]VARDES(I)
  Endif
Next I
End

#---------------------------------------
Subprog C_INCFRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Local Integer ER
  Local Char    CHAINE (80)
  Default File [SPI]         : # SPRICINCR doit etre le fichier par default
  Gosub VAR_DEF From ="WBI"+[F:SNE]COD
  Onerrgo ERRINCFRM
  ER = 0
  CHAINE = num$(evalue(VALEUR))
  Onerrgo
  If ER
    mkstat = 2 : End
  Endif
Endif
End

$ERRINCFRM
# --- c'est une variable traitement ???
Local Char VARI : VARI=errm
If find(VARI ,[F:SNE]VARCOD(0..dim([F:SNE]VARCOD)-1)) : Resume : Endif
ER = errn
GERR=1 : GMESSAGE=mess(37,124,1)+"\"+errmes$(ER)+"\"+errm : # Expression incorrecte
Resume


########################################
Subprog AM_INCFLDUPD(VALEUR)
Variable Integer VALEUR
If VALEUR<2
  Raz [M]INCFRM(nolign-1), [M]INCRNDTYP(nolign-1), [M]INCRND(nolign-1)
  Grizo INCFRM(nolign-1), INCRNDTYP(nolign-1), INCRND(nolign-1) 
  Affzo [M]INCFRM(nolign-1), INCRNDTYP(nolign-1), INCRND(nolign-1)
Endif

End

######################################## Type arrondi
Subprog AS_INCRNDTYP(VALEUR)
Variable Integer VALEUR
If [M]INCFLDUPD(nolign-1)<2 : mkstat=2 : End : Endif
End

#---------------------------------------
Subprog AM_INCRNDTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<2
  Raz [M]INCRND(nolign-1)
  Grizo INCRND(nolign-1) 
  Affzo INCRND(nolign-1)
Endif
End

######################################## Valeur arrondi
Subprog AS_INCRND(VALEUR)
Variable Decimal VALEUR
If [M]INCFLDUPD(nolign-1)<2 | [M]INCRNDTYP(nolign-1)<2 : mkstat=2 : End : Endif
End

#######################################################################


