#<AdxTL>@(#)5.0.0.0 $Revision$
#################################################################################################
# SUBBPCB    Gestion des prospects/clients.     Fonctionnalités CRM           10 juillet 2000   #
#                                                                                               #
# TRSF_BPP_BPC  : Transforme un prospect en client.                                             #
# LOADPIT       : Charge le nombre de points à débiter                                          #
# SAVEPIT       : Enregistre le nombre de points à débiter                                      #
#                                                                                               #
#################################################################################################
# Issue X3-61637 - 20171206 by LD : Converting Prospect into customer when activity code FUP inactive

###############################################################################################
# Transforme un prospect en client
# Conservé pour des évolutions ultérieures éventuelles.
$MAKEBPC
Local Integer BPRCLOSINGFLG

  BPRCLOSINGFLG = 0
  Raz [M:BPP0]
  Raz [M:BPRP]
  Raz [M:BPAP]
  Raz [M:BPP1]
  Raz [M:CNTP]
  Affzo [M:BPP0]1-99
  Affzo [M:BPRP]1-99
  Affzo [M:BPAP]1-99
  Affzo [M:BPP1]1-99
  Affzo [M:CNTP]1-99
  If !clalev([F:BPR]) Then
    Local File BPARTNER [BPR]
    BPRCLOSINGFLG = 1
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [BPC], [BPR]
  #Première partie de la transaction
  Read [BPC]BPC0=GSZPROSPCOD
  If fstat Then
    GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
    GERR = 1
  Else
    [F:BPC]PPTFLG = 1
    [F:BPC]BPCTYP = 1
    Rewrite [BPC]
    If fstat Then
      GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
      GERR = 1
      Rollback
    Endif
  Endif
  #Deuxième partie de la transaction
  Read [BPR]BPR0=GSZPROSPCOD
  If fstat Then
    GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
    GERR = 1
    Rollback
  Else
    [F:BPR]PPTFLG = 1
    [F:BPR]BPCFLG = 2
    Rewrite [BPR]
    If fstat Then
      GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
      GERR = 1
      Rollback
    Else
      Commit
    Endif
  Endif
  If BPRCLOSINGFLG Then
    Close Local File [BPR]
  Endif
Return

###############################################################################################
# Affiche un ancien prospect devenu client dans l'objet client
# Conservé pour des évolutions ultérieures éventuelles.
$CHGBPP
  Call DEBTRANS From GLOCK
  Trbegin [BPC], [BPR]
  #Première partie de la transaction
  #Passe le prospect en client
  Read [BPC]BPC0=VALEUR
  If fstat Then
    GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
    GERR = 1
  Else
    [F:BPC]PPTFLG = 1
    [F:BPC]BPCTYP = 1
    Rewrite [BPC]
    If fstat Then
      GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
      GERR = 1
      Rollback
    Endif
  Endif
  #Deuxième partie de la transaction
  #Passe le tiers en client
  Read [BPR]BPR0=VALEUR
  If fstat Then
    GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
    GERR = 1
    Rollback
  Else
    [F:BPR]PPTFLG = 1
    [F:BPR]BPCFLG = 2
    Rewrite [BPR]
    If fstat Then
      GMESSAGE = mess(224,196,1) #La transformation du prospect n'a pas pu être effectuée. Transaction abandonnée.
      GERR = 1
      Rollback
    Else
      Commit
    Endif
  Endif
Return

#########################################################################
#     Transformation d'un prospect en client                            #
#########################################################################
Subprog TRSF_BPP_BPC(WCLE, WSOC)
Value Char WCLE
Value Char WSOC

Local Integer NBPOSTE
Local Char WFCY
Local Char WBPAADD

  # ---> lecture tiers
  If [F:BPR]BPRNUM <> WCLE Then
    Read [BPR]BPR0=WCLE
    If fstat Then
      Raz [F:BPR]
    Endif
  Endif
  # ---> Init de la catégorie du tiers
  Call INI_BCGCATEG([F:BPR]BRGCOD) From SUBBPC

  # ---> lecture client
  If [F:BPC]BPCNUM <> WCLE Then
    Read [BPC]BPC0=WCLE
    If fstat Then
      Raz [F:BPC]
    Endif
  Endif
  # ---> Le tiers passe de prospect à client
  [M:BPRC]PPTFLG = 1
  [M:BPC2]PPTFLG = 1    # CCC (30/01/06) Bug 34453
  [M:BPRC]BPCFLG = 2
  # -------------------------------------------------------------------
  If GACTFTC = 2 Then
    # On alimente l'adresse du 1er client livré avec l'adresse par défaut du tiers
    If [M:BPC4]NBDLV = 0 Then           # FGR 05/03/2011 : X3SUIVI80041
      [M:BPC4]BPAADD(0) = [F:BPC]BPAADD
      [M:BPC4]FLMOD(0) = 1              # FGR 28/07/2014 : X3SUIVI100229
      WBPAADD = [M:BPC4]BPAADD(0)
      [M:BPC4]NBDLV = 1
      nolign = 1
      Gosub CHARGE_BPAADD From SUBBPC
    Endif
    If [M:BPC1]ABCCLS < 1 Then          # FGR 05/03/2011 : X3SUIVI80041
      [M:BPC1]ABCCLS = 4                # Catégorie ABC = Classe "D" par défaut
    Endif
  Endif
  # -------------------------------------------------------------------
  # Alimentation des zones par défaut
  If [M:BPC3]BPCGRU = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPCGRU = [M:BPC0]BPCNUM
  Endif
  If [M:BPC2]BPCTYP < 1 or [M:BPC2]BPCTYP = 4 Then            # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC2]BPCTYP = 1                  # Type de client normal
  Endif
  If [M:BPC3]BPCINV = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPCINV = [M:BPC0]BPCNUM
  Endif
  If [M:BPC3]BPAINV = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPAINV = [F:BPC]BPAADD
  Endif
  If [M:BPC3]BPCPYR = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPCPYR = [M:BPC0]BPCNUM
  Endif
  If [M:BPC3]BPAPYR = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPAPYR = [F:BPC]BPAADD
  Endif
  If [M:BPC3]BPCRSK = "" Then           # FGR 05/03/2011 : X3SUIVI80041
    [M:BPC3]BPCRSK = [M:BPC0]BPCNUM
  Endif
  # Issue X3-61637
  If dim([M:BPC3]FUPTYP) > 0
  # End issue X3-61637
      If [M:BPC3]FUPTYP < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
        [M:BPC3]FUPTYP = 3                  # Type de relance "Globale"
      Endif
  # Issue X3-61637
  Endif
  # End issue X3-61637
  # -------------------------------------------------------------------
  #LSE 22/11/2006 FQ 38466
  #Initialisation des zones non renseigné sur prospect pour déclenchement des valeurs par défauts
  #Ecran BPC1
  If [M:BPC1]FREINV < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC1]FREINV
  Endif
  If [M:BPC1]IME < 1 Then               # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC1]IME
  Endif
  If [M:BPC1]INVPER < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC1]INVPER
  Endif
  If [M:BPC1]DUDCLC < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC1]DUDCLC
  Endif
  # -------------------------------------------------------------------
  #Ecran BPC2
  If [M:BPC2]CHGTYP < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC2]CHGTYP
  Endif
  If [M:BPC2]OSTCTL < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC2]OSTCTL
  Endif
  # -------------------------------------------------------------------
  #Ecran BPC3
  If [M:BPC3]PTE = "" Then              # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC3]PTE
  Endif
  If [M:BPC3]DEP = "" Then              # FGR 05/03/2011 : X3SUIVI80041
    Raz [M:BPC3]DEP
  Endif
  # Issue X3-61637
  If dim([M:BPC3]FUPTYP) > 0
  # End issue X3-61637
      If [M:BPC3]FUPTYP < 1 Then            # FGR 05/03/2011 : X3SUIVI80041
        Raz [M:BPC3]FUPTYP
      Endif
  # Issue X3-61637
  Endif
  # End issue X3-61637
  # -------------------------------------------------------------------
  If GACTFTC = 2 Then
    #---- chargt tableau des elements de facturation pour CLIENT seulement #
    If [M:BPC1]NBFAC = 0  Then
      #NBPOSTE = dim ([M:BPC1]NOLIG)
      NBPOSTE = dim ([M:BPC1]NBFAC)   # FGR 22/12/2009 : X3SUIVI60986
      Call  SAISFOOT (1,"BPC1",NBPOSTE,[M:BPC2]CHGTYP,GSYSCUR,[M:BPRC]CUR,"OUI") From SUBSFIT
      [M:BPC1]NBFAC = NBPOSTE
    Endif
    #---- chargement devise client sur ligne montant
    For nolign = 0 To dim([M:BPC1]AMTCOD)-1
      If [M:BPC1]AMTCOD(nolign) = 2  Then
        [M:BPC1]WWCUR(nolign) = [M:BPRC]CUR
      Endif
    Next
  Endif
  # ---> On vient d'une transformation devis en commande
  If GORITRFBPP <> "" and GORITRFBPP <> "GESSOH" Then
    If [F:SQH]SQHNUM <> GORITRFBPP Then
      Read [SQH]SQH0=GORITRFBPP
      If fstat Then
        Raz [F:SQH]
      Endif
    Endif
    If [F:SQH]BPCORD = WCLE Then
      Gosub ALISQHBPC
    Endif
  Endif
  If dim([M:BPC2]BPCSNCDAT) >= 0 Then  # FGR 19/02/2015 : X3SUIVI106383 : Soumis à CA
    # FGR 03/06/2010 X3SUIVI64450 (début)
    If GORITRFBPP = "GESSOH" Then
      If dim([M:SOH0]ORDDAT) >= 0 Then
        [M:BPC2]BPCSNCDAT = [M:SOH0]ORDDAT
      Endif
      If [M:BPC2]BPCSNCDAT = [0/0/0] Then
        [M:BPC2]BPCSNCDAT = date$
      Endif
    Endif
    # FGR 03/06/2010 X3SUIVI64450 (fin)
  Endif
End

# ------------------------------------------------------------------------------ #
# Alimentation des zones du client à partir du devis (à transformer en commande) #
# ------------------------------------------------------------------------------ #
$ALISQHBPC
  [M:BPC3]VACBPR = [F:SQH]VACBPR
  If GACTFTC = 2 Then
    [M:BPC1]PRITYP = [F:SQH]PRITYP
    If dim([M:BPC1]REP) > 0 Then
      # --> Alimentation du 1er représentant
      [M:BPC1]REP(0) = [F:SQH]REP(0)
    Endif
    If dim([M:BPC1]REP) > 1 Then
      # --> Alimentation du 2eme représentant
      [M:BPC1]REP(1) = [F:SQH]REP(1)
    Endif
  Endif
  [M:BPC3]PTE = [F:SQH]PTE
  [M:BPC3]DEP = [F:SQH]DEP
  If GACTFTC = 2 and [F:SQH]BPAADD <> "" Then
    If [F:SQH]BPAADD <> [M:BPC4]BPAADD(0) Then
      [M:BPC4]BPAADD(1) = [F:SQH]BPAADD
      [M:BPC4]FLMOD(1) = 1                       # FGR 28/07/2014 : X3SUIVI100229
      [M:BPC4]NBDLV += 1
      nolign = 2
      Gosub SETNOL From SUBBPC
      Gosub CHARGE_ZONE_BPAADD From SUBBPC
    Endif
    If [F:SQH]BPDNAM <> "" Then
      [M:BPC4]BPDNAM0(NOL) = [F:SQH]BPDNAM(0)
      [M:BPC4]BPDNAM1(NOL) = [F:SQH]BPDNAM(1)
    Else
      [M:BPC4]BPDNAM0(NOL) = [M:BPRC]BPRNAM(0)
      [M:BPC4]BPDNAM1(NOL) = [M:BPRC]BPRNAM(1)
    Endif
    # --> Alimentation du 1er représentant
    If func AFNC.ACTIV("RED") > 0 Then
      [M:BPC4]REP0(NOL) = [F:SQH]REP(0)
    Endif
    # --> Alimentation du 2eme représentant
    If func AFNC.ACTIV("RED") > 1 Then
      [M:BPC4]REP1(NOL) = [F:SQH]REP(1)
    Endif
    [M:BPC4]STOFCY(NOL) = [F:SQH]STOFCY
    Call LECTURE("FCY",[F:SQH]STOFCY,"") From CONTOBJ
    [M:BPC4]BPTNUM(NOL) = [F:FCY]BPTNUM
    [M:BPC4]DAYLTI(NOL) = [F:SQH]DAYLTI
    [M:BPC4]FLMOD(NOL) = 1                       # FGR 28/07/2014 : X3SUIVI100229
  Endif
  If GACTFTC = 2 Then
    Columns [SQD] (SQHNUM, BPAADD, STOFCY, REP1, REP2, DAYLTI)
    For [SQD] Where SQHNUM = [F:SQH]SQHNUM and BPAADD <> "" and !find(BPAADD,[M:BPC4]BPAADD(0..[M:BPC4]NBDLV-1))
      [M:BPC4]BPAADD([M:BPC4]NBDLV) = [F:SQD]BPAADD
      [M:BPC4]FLMOD([M:BPC4]NBDLV) = 1           # FGR 28/07/2014 : X3SUIVI100229
      [M:BPC4]NBDLV += 1
      nolign = [M:BPC4]NBDLV
      Gosub SETNOL From SUBBPC
      Gosub CHARGE_ZONE_BPAADD From SUBBPC
      If [F:SQH]BPDNAM <> "" Then
        [M:BPC4]BPDNAM0(NOL) = [F:SQH]BPDNAM(0)
        [M:BPC4]BPDNAM1(NOL) = [F:SQH]BPDNAM(1)
      Else
        [M:BPC4]BPDNAM0(NOL) = [M:BPRC]BPRNAM(0)
        [M:BPC4]BPDNAM1(NOL) = [M:BPRC]BPRNAM(1)
      Endif
      # --> Alimentation du 1er représentant
      If func AFNC.ACTIV("RED") > 0 Then
        [M:BPC4]REP0(NOL) = [F:SQD]REP1
      Endif
      # --> Alimentation du 2eme représentant
      If func AFNC.ACTIV("RED") > 1 Then
        [M:BPC4]REP1(NOL) = [F:SQD]REP2
      Endif
      [M:BPC4]STOFCY(NOL) = [F:SQD]STOFCY
      Call LECTURE("FCY", [F:SQD]STOFCY, "") From CONTOBJ
      [M:BPC4]BPTNUM(NOL) = [F:FCY]BPTNUM
      [M:BPC4]DAYLTI(NOL) = [F:SQD]DAYLTI
      [M:BPC4]FLMOD(NOL) = 1                     # FGR 28/07/2014 : X3SUIVI100229
      If NBDLV >= dim ([M:BPC4]BPAADD) Then
        Break
      Endif
    Next
    Columns [SQD]
    Gosub CHARGE_BPD From SUBBPC
  Endif
Return

########################################################
# Charge le nombre de points à débiter
########################################################
Subprog LOADPIT(SZBPCNUM)
Value Char SZBPCNUM

  #MAE, bg 49547 If GMODU(12) <> 2 : End : Endif
  If GMODU(12) <> 2 or GACTFTC <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : Ca ne concerne pas la gestion des jetons, mais des points
    # C'est un type de contrat donc ça dépend de la présence du module gestion clients (code activité PIT)
    [M:BPC2]BPCPITDEB = 0
    [M:BPC2]NULPIO = 1
    Filter [PDB] Where [F:PDB]BPR = SZBPCNUM and [F:PDB]ITMREF = "" and [F:PDB]PBL = ""
    For [PDB]
      [M:BPC2]BPCPITDEB = [F:PDB]SGLNBRPIT
      [M:BPC2]NULPIO = [F:PDB]NULPIO
      Break
    Next
    Filter [PDB]
  Endif
End

########################################################
# Enregistre le nombre de points à débiter
########################################################
Subprog SAVEPIT(SZBPCNUM, IERRINF)
Value Char SZBPCNUM
Variable Integer IERRINF

  #MAE, bg 49547 If GMODU(12) <> 2 : End : Endif
  If GMODU(12) <> 2 or GACTFTC <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : Ca ne concerne pas la gestion des jetons, mais des points
    # C'est un type de contrat donc ça dépend de la présence du module gestion clients (code activité PIT)
    Read [PDB]PDB0=SZBPCNUM;"";""
    If fstat Then
      Call DEBTRANS From GLOCK
      Trbegin [PDB]
      [F:PDB]BPR = SZBPCNUM
      [F:PDB]ITMREF = ""
      [F:PDB]PBL = ""
      [F:PDB]SGLNBRPIT = [M:BPC2]BPCPITDEB
      If [M:BPC2]NULPIO = 0 Then
        [F:PDB]NULPIO = 1
      Else
        [F:PDB]NULPIO = [M:BPC2]NULPIO
      Endif
      [F:PDB]CREDAT = date$
      [F:PDB]CREUSR = GUSER
      Write [PDB]
      If fstat Then
        #Erreur lors de l'enregistrement des points à débiter.
        IERRINF = 467
        Rollback
      Else
        Commit
      Endif
    Else
      Call DEBTRANS From GLOCK
      Trbegin [PDB]
      Readlock [PDB]PDB0=SZBPCNUM;"";""
      If fstat Then
        #Erreur lors de l'enregistrement des points à débiter.
        IERRINF = 467
        Rollback
      Else
        [F:PDB]SGLNBRPIT = [M:BPC2]BPCPITDEB
        If [M:BPC2]NULPIO = 0 Then
          [F:PDB]NULPIO = 1
        Else
          [F:PDB]NULPIO = [M:BPC2]NULPIO
        Endif
        [F:PDB]UPDDAT = date$
        [F:PDB]UPDUSR = GUSER
        Rewrite [PDB]
        If fstat Then
          #Erreur lors de l'enregistrement des points à débiter.
          IERRINF = 467
          Rollback
          Unlock [PDB]
        Else
          Commit
          Unlock [PDB]
        Endif
      Endif
    Endif
  Endif
End

