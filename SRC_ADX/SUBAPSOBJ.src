#Local Char CL
#Call SELECT("AP1","A",CL,"") From SELOBJA
#End
# ------------------------------------------------------------
# SUBAPSOBJ - PORTAIL
# Version: 0008
#    Ouverture d'un objet par le portail
#        PARCODE(.)    Code du paramètre
#        PARVALUE(.)   Valeur du paramètre
#
#    Rechercher U_TRACEON=1  pour avoir une trace
#
#  Exemples de liens
#  X3Link="12074,OBJET=AUS&#38;CLES=ZZCP2"                        pour un appel objet
#  X3Link="12074,ACT=CNS&#38;INF=AWW~B1~3~0900006382~MB~~"        pour une action
#
#  0008:
#   E63860 - Clé en plusieurs parties
# ------------------------------------------------------------

#Subprog MONITEUR(PARCODE,PARVALUE,RET)        # le mode Web ne passe pas par ce canal
#    Const Char PARCODE ()()                   # mais par la methode classique type C/S
#    Const Char PARVALUE ()()
#    Variable Integer RET
#    Gosub E_EXECUTE
#    Call LEC_TRACE From LECFIC
#End


# --------------------------
#  Appel par fonction de type affichage divers  - Utiliser par le mode C/S
$ACTION
Local Char O_QS(250)
O_QS=adxpam     # Pour en avoir + de 10...

If ACTION="TRT_DIV"
    Case TRAIT
    When "OBJCALL"
        Gosub O_EXECUTE 
        If U_ERR : Gosub U_MESTOUSER From SUBAPSUTI : Endif
        Call LEC_TRACE From LECFIC
    Endcase
Endif
Return

# ------------------------------------------------------------
$O_EXECUTE                         # Init + type de dialogue
    Gosub O_VAR                    # init var et trace
    Gosub U_VAR From SUBAPSUTI     # init var des utilitaires

    # gestion QS
    U_QS_ENCODED=O_QS    # init QS

    # U_TRACEON=1 # pour avoir une trace
    U_TRAMES="Gestion debranchement sur un objet X3"
    Gosub U_TRAOPEN From SUBAPSUTI
    U_TRAMES="--> Debut: " + "Gestion debranchement sur un objet X3" : Gosub U_TRAPUT From SUBAPSUTI 

    # Analyse QS de l'URL
    Gosub U_QSINIT From SUBAPSUTI  : If U_ERR=UC_ERRG : Return : Endif

    # Objet std demandé ?
    U_QSCODE=MC_QSOBJET : Gosub U_QSREAD_UC From SUBAPSUTI
    O_FINDOBJ= U_QSEXIST  
    If (O_FINDOBJ)
        O_OBJET=U_QSVAL
        U_TRAMES="--> Appel objet X3: " + O_OBJET : Gosub U_TRAPUT From SUBAPSUTI 
        Gosub $O_EXECUTEOBJ 
        Return
    Endif

    # Objet Geode demandé ?  E45527
    U_QSCODE=MC_QSOBJGX : Gosub U_QSREAD_UC From SUBAPSUTI
    O_FINDOBJ= U_QSEXIST  
    If (O_FINDOBJ)
        O_OBJET=U_QSVAL
        U_TRAMES="--> Appel objet type Geode: " + O_OBJET : Gosub U_TRAPUT From SUBAPSUTI 
        Gosub $O_EXEOBJGX 
        Return
    Endif

    # Action demandée ?
    U_QSCODE=MC_QSACT : Gosub U_QSREAD_UC From SUBAPSUTI
    O_FINDACT= U_QSEXIST  
    If (O_FINDACT)
        O_ACT=U_QSVAL
        U_TRAMES="--> Appel action: " + O_ACT : Gosub U_TRAPUT From SUBAPSUTI 
        Gosub $O_EXECUTEACT 
        Return
    Endif


    # erreur 
    U_TRAMES="--> Erreur: Code objet ou action non trouvé"  : Gosub U_TRAPUT From SUBAPSUTI 
Return


# Cas appel objet X3 issu d'un lien portail  
# ------------------------------------------------------------
# Cas standard
# - - - - - - - - - - - - - - - - - - - - -
$O_EXECUTEOBJ         
    # Clés (option de type cle1~cle2~cle3)
    U_QSCODE=MC_QSCLES : Gosub U_QSREAD_UC From SUBAPSUTI
    U_TXTTOHEX=U_QSVAL : Gosub U_HEXTOTXT From SUBAPSUTI
    O_CLES=U_HEXTOTXT

    If (U_QSEXIST)       
        U_TRAMES="--> Cles: " + O_CLES  : Gosub U_TRAPUT From SUBAPSUTI 
        MW_I=instr(0,O_CLES,"~")
        If (MW_I <> 0)     
            O_CLE1=left$(O_CLES,MW_I-1)
            O_CLE2=right$(O_CLES,MW_I+1)
        Else
            O_CLE1=O_CLES : O_CLE2=""
        Endif
    Endif

    # Appel objet
    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    # Call OBJET(O_OBJET, O_CLE1, O_CLE2) From GOBJET    E63860
    Call OBJET_CHAR(O_CLE1, O_OBJET, O_CLE2) From GOBJET 

    # Trace
    U_TRAMES="--> Fin  : Gestion debranchement sur un objet X3"
    Gosub U_TRAPUT From SUBAPSUTI 
    Gosub U_TRACLOSE From SUBAPSUTI     # fermeture de la trace
Return

# Cas GEODE
# - - - - - - - - - - - - - - - - - - - - -
$O_EXEOBJGX         
    # Clés ( type cleprim~FCY~DEP~cle2~cle3)
    U_QSCODE=MC_QSCLES : Gosub U_QSREAD_UC From SUBAPSUTI
    U_TXTTOHEX=U_QSVAL : Gosub U_HEXTOTXT From SUBAPSUTI
    O_CLES=U_HEXTOTXT

    If (U_QSEXIST)       
        U_TRAMES="--> Cles: " + O_CLES  : Gosub U_TRAPUT From SUBAPSUTI 
        MW_I=instr(0,O_CLES,"~")
        O_CLE1=left$(O_CLES,MW_I-1)
        O_CLE2=right$(O_CLES,MW_I+1)
        MW_I=instr(0,O_CLE2,"~")
        O_FCY=left$(O_CLE2,MW_I-1)
        O_CLE2=right$(O_CLE2,MW_I+1)
        MW_I=instr(0,O_CLE2,"~")
        If (MW_I <> 0)     
            O_DEP=left$(O_CLE2,MW_I-1)
            O_CLE2=right$(O_CLE2,MW_I+1)
        Else
            O_DEP=O_CLE2 : O_CLE2=""
        Endif
    Endif

    # Appel objet
    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    O_FCYSAV=GFCY : O_DEPSAV=GDEP
    GFCY=O_FCY : GDEP=O_DEP

    # Call OBJET(O_OBJET, O_CLE1, O_CLE2) From GOBJET    E63860
    Call OBJET_CHAR(O_CLE1, O_OBJET, O_CLE2) From GOBJET

    GFCY=O_FCYSAV : GDEP=O_DEPSAV

    # Trace
    U_TRAMES="--> Fin  : Gestion debranchement sur un objet X3"
    Gosub U_TRAPUT From SUBAPSUTI 
    Gosub U_TRACLOSE From SUBAPSUTI     # fermeture de la trace
Return


# Cas appel action quelconque  
# ------------------------------------------------------------
$O_EXECUTEACT
    # Informations action
    U_QSCODE=MC_QSINFO : Gosub U_QSREAD_UC From SUBAPSUTI
    U_TXTTOHEX=U_QSVAL : Gosub U_HEXTOTXT From SUBAPSUTI
    O_ACTINF=U_HEXTOTXT

    #Infbox ("Action demandée"-O_ACT-chr$(13)-"Infos sup:"-O_ACTINF)
    Case O_ACT
        When "CNS" : Call ACTRUN(O_ACTINF) From SUBAPSCNS1
    Endcase
Return

# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# Variables
# - - - - - - - - - - - - - - - - - -
$O_VAR

# Paramêtres du query
Char PARCODE (30)(1..20)
Char PARVALUE (200)(1..20)
Local Char O_OBJET, O_CLES(250), O_CLE1, O_CLE2          # Données pour l'objet    E63860
Local Char MC_QSOBJET, MC_QSCLES : MC_QSOBJET="OBJ" : MC_QSCLES ="CLES"
Local Integer MW_I, MW_POS
#Local Char OC_URLCSF(40)       # URL de lien mode CSF (code fonction associé à cet objet)
#OC_URLCSF="x3://8207_"
#Local Char OC_URLWEB(50),OC_URLWEBEND(10)       # URL de lien mode CSF(code fonction associé à cet objet)
#OC_URLWEB='javascript:top.Ac_openX3(8207,"'
#OC_URLWEB='javascript:debugger;top.Ac_openX3(8207,"'
#OC_URLWEBEND='");'
#Local Char OC_MODECSF : OC_MODECSF='CSFILEINPUT'    # mode C/S par fichier
Local Char OC_X3FNC(5)       # Code fonction associé à cet objet: APTLOBJ 
#OC_X3FNC="8207"               # = NUMLFNC/AFONCTION + 3072 = 5135 + 3072         # JPJ E26673
OC_X3FNC="12074"               # = GSTAPTL2 + 3072 = 9002 + 3072         # JPJ E26673

# E45527
Local Char MC_QSOBJGX : MC_QSOBJGX="OBJGX" 
If GPRODUIT=1
    Local Char O_FCY(GLONFCY), O_FCYSAV(GLONFCY) 
    Local Char O_DEP(GLONDEP), O_DEPSAV(GLONDEP) 
Endif

# Action quelconque
Local Char MC_QSACT : MC_QSACT="ACT"
Local Char MC_QSINFO : MC_QSINFO="INF"
Local Integer MC_ACTMAX    : MC_ACTMAX=12        # Lg maxi de la chaine decrivant l'action
Local Integer MC_ACTINFMAX : MC_ACTINFMAX=150    # Lg maxi de la chaine decrivant l'information de l'action
                                                 # L'augmenter à 200 comporte des riques de troncature et de non fonctionnement (test ZJJCNST)
Local Char O_ACT(MC_ACTMAX)
Local Char O_ACTINF (250)                        

#
Local Integer O_FINDOBJ, O_FINDACT
Return

# Renvoi l'URL d'appel formatée 
# - - - - - - - - - - - - - - - - - -
Subprog GETURL(ABREV, CLEPRIM, CLESEC, MODE, URL)      
    Value Char ABREV()
    Value Char CLEPRIM()
    Value Char CLESEC()()
    Value Char MODE()    # Mode client ou web
    Variable Char URL
    
    If ABREV<>"" & CLEPRIM<>""
        Gosub O_VAR
        O_CLE1= num$(evalue("[F]"+ CLEPRIM))  # E52916
    
        Gosub BASEURLBEG
    
        Local Integer W_I
        For W_I=0 To dim(CLESEC)-1
            If CLESEC(W_I)<>""
                O_CLE2= num$(evalue("[F]"+ CLESEC(W_I)))   # E52916
                URL+="~" + O_CLE2 
            Endif
        Next W_I
    
        Gosub BASEURLEND    
    Else
        URL=""
    Endif
End


# Renvoi l'URL d'appel formatée d'un objet à une seul clé primaire
# - - - - - - - - - - - - - - - - - -
Subprog GETURLCLEPRIM(ABREV,CLEVAL, MODE, URL)      
    Value Char ABREV()
    Value Char CLEVAL()
    Value Char MODE()    # Mode client ou web
    Variable Char URL
    
    If ABREV<>"" & CLEVAL<>""
        Gosub O_VAR
        O_CLE1= CLEVAL
        Gosub BASEURLBEG
        Gosub BASEURLEND    
    Else
        URL=""
    Endif
 
End

# Renvoi l'URL d'appel formatée d'un objet avec clé composite 
# - - - - - - - - - - - - - - - - - -
Subprog GETURLCLECMP(ABREV, CLEPRIMVAL, CLESECVAL, MODE, URL)      
    Value Char ABREV()
    Value Char CLEPRIMVAL()
    Value Char CLESECVAL()()
    Value Char MODE()    # Mode client ou web
    Variable Char URL
    
    If ABREV<>"" & CLEPRIMVAL<>""
        Gosub O_VAR
        O_CLE1= CLEPRIMVAL
    
        Gosub BASEURLBEG
    
        Local Integer W_I
        For W_I=0 To dim(CLESECVAL)-1
            If CLESECVAL(W_I)<>""
                O_CLE2= CLESECVAL(W_I)
                URL+="~" + O_CLE2 
            Else 
                Break
            Endif
        Next W_I
    
        Gosub BASEURLEND    
    Else
        URL=""
    Endif
End





$BASEURLBEG
    URL=OC_X3FNC + "," + MC_QSOBJET + "=" + ABREV + "&" + MC_QSCLES + "=" + O_CLE1
Return

$BASEURLEND
Return


# E45527
# Renvoi l'URL d'appel formatée d'un objet GX à une seul clé primaire
# Passage par [Cle primaire]~[Site]~[Deposant]
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog GETURLCLEPGX(ABREV,CLEFCY, CLEDEP, CLEVAL, MODE, URL)      
    Value Char ABREV()
    Value Char CLEFCY()
    Value Char CLEDEP()
    Value Char CLEVAL()    # Partie primaire
    Value Char MODE()      # Mode client ou web
    Variable Char URL
    
    If ABREV<>"" & CLEVAL<>""
        Gosub O_VAR
        O_CLE1= CLEVAL + "~" + CLEFCY + "~" + CLEDEP 
        Gosub BASEURLBEGGX
    Else
        URL=""
    Endif
End

$BASEURLBEGGX
    URL=OC_X3FNC + "," + MC_QSOBJGX + "=" + ABREV + "&" + MC_QSCLES + "=" + O_CLE1
Return

# Renvoi l'URL d'appel formatée d'un objet GX avec clé composite 
# Passage par [Cle primaire]~[Site]~[Deposant]~CleSup1~CleSup2
# - - - - - - - - - - - - - - - - - -
Subprog GETURLCLECGX(ABREV, CLEFCY, CLEDEP, CLEPRIMVAL, CLESECVAL, MODE, URL)      
    Value Char ABREV()
    Value Char CLEFCY()
    Value Char CLEDEP()
    Value Char CLEPRIMVAL()
    Value Char CLESECVAL()()
    Value Char MODE()    # Mode client ou web
    Variable Char URL
    
    If ABREV<>"" & CLEPRIMVAL<>""
        Gosub O_VAR
        O_CLE1= CLEPRIMVAL + "~" + CLEFCY + "~" + CLEDEP
    
        Gosub BASEURLBEGGX
    
        Local Integer W_I
        For W_I=0 To dim(CLESECVAL)-1
            If CLESECVAL(W_I)<>""
                O_CLE2= CLESECVAL(W_I)
                URL+="~" + O_CLE2 
            Else 
                Break
            Endif
        Next W_I
    
        Gosub BASEURLEND    
    Else
        URL=""
    Endif
End



# Renvoi l'URL d'appel formatée d'une action  
# - - - - - - - - - - - - - - - - - - - - - - 
Subprog GETURLACT(ACTION, INFO, URL)   
    Value Char ACTION()
    Value Char INFO()
    Variable Char URL
    Gosub O_VAR
    If len(INFO) <= MC_ACTINFMAX   # Protection
        # Encapsulation données non connues par [[  ]] 
        #   Voir U_QSINIT SubApsUti - Décodage Query string - Pb info peut contenir des &
        O_ACTINF=MC_QSACT + "=" + ACTION + "&" + MC_QSINFO + "=[[" + INFO +"]]"
        URL=OC_X3FNC + "," + O_ACTINF
    Else
        Raz URL
    Endif
End


