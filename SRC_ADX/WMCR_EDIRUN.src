#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## CRUD-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 888


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EDIRUN [EDR_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EDIRUN") From ASYRCOM : Endif
Local Instance EDIRUN Using C_EDIRUN

If !SILENCE : Call TRACE("3 --> New Instance C_EDIRUN") From ASYRCOM : Endif
EDIRUN = NewInstance C_EDIRUN AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EDR_]EDR0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EDIRUN") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.AREAD([EDR_]NUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EDIRUN.NUM ="-num$(EDIRUN.NUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EDIRUN.AKEYS)
  Call TRACE("-"-num$(I)-":"-EDIRUN.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EDR_]
FreeGroup EDIRUN
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EDIRUN,ACLE,ASTATUS,_ETAG)
Variable Instance EDIRUN Using C_EDIRUN
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Shortint _NUM
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_NUM = val([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EDIRUN [EDR]
Default File [F:EDR]
Read [F:EDR]EDR0 = [L]_NUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EDR]UPDTICK)>0
 [L]_ETAG = num$([F:EDR]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EDIRUN,ACLE,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Value Char ACLE
Variable Integer ASTATUS
Local Shortint _NUM
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_NUM = val([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.AREAD([L]_NUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EDIRUN,_NUM,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Value Shortint _NUM
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub AVARIABLES From WMC00EDIRUN
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EDIRUN.APARENT=null
 [L]A_I = EDIRUN.freeSnapshot
 EDIRUN.snapshotEnabled = 0
 EDIRUN.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EDIRUN.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EDIRUN.APARENT=null
 EDIRUN.snapshotEnabled = 1
 EDIRUN.setAccessorEnabled = 1
Endif
LogicClose File [EDR] ,[EDRD]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN._ACTION_PARAM("AREAD_BEFORE",[L]_NUM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EDR]
Read [F:EDR]EDR0 = [L]_NUM
If fstat
[L]A_ERROR = num$([L]_NUM)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EDIRUN,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EDR]AUUID)>0 & [F:EDR]AUUID=NullUuid
 [F:EDR]AUUID = getUuid
Endif
SetInstance EDIRUN With [F:EDR]
EDIRUN.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EDRD]
 [L]A_N2=0
 For [F:EDRD]EDRD1 Where NUM=[F:EDR]NUM
  [L]A_N2 +=1
  EDIRUN.EDRD(A_N2) = NewInstance  C_EDIRUND(EDIRUN.ACTX,NullUuid,[L]A_N2,EDIRUN,"EDRD") AllocGroup EDIRUN
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EDRD]AUUID)>0 & [F:EDRD]AUUID=NullUuid
   [F:EDRD]AUUID = getUuid
  Endif
  SetInstance EDIRUN.EDRD(A_N2) With [F:EDRD]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ASETATTRIBUTE("NUM","$namProParent","NUM"))
 Next EDRD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



