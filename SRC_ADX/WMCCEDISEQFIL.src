If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_OPTCHA From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_OPTCHA From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_OPTDAT From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_OPTDAT From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_OPTMNL From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_OPTMNL From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_VALID From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_VALID From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLGMUX From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLGMUX From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To maxtab(this.ESFD)
 If this.ESFD(AINDCLA)<>null& find(this.ESFD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFD(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESFF)
 If this.ESFF(AINDCLA)<>null& find(this.ESFF(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFF(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.ESFN(AINDCLA)<>null& find(this.ESFN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFN(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYALIAS From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYALIAS From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYDES From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYDES From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYPROPERTY From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYPROPERTY From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
