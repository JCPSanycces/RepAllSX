####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EDISEQFIL
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGREL From WMC1EDISEQFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGREL From WMC1EDISEQFIL : Gosub TESTALLSTAT :  Endif
