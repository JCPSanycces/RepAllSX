#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion de de la synchronisation Outlook CRM 7/11/2005
##########################################################################################################
##########################################################################################################
# SYDINITCPT    : initialisation du compteur synchronisation
# SYDUSRFROMREP : renvoi l'utilisateur pour la synchronisation par rapport à un représentant
#                    et indique si synchronisation possible
# SYDUSRSYNCTYP : renvoi si la synchronisation est possible pour un type (COR, TSK, CLL, BAP)
# SYDWRITE      : Ecriture d'un nouvement de synchonisation
# SYDTSKCRE : gestion données synchronisation pour une nouvelle tache
# SYDTSKUPD : gestion données synchronisation pour une  tache existante
# SYDTSKDEL : gestion données synchronisation pour une  suppression de tache
# SYDCLLCRE : gestion données synchronisation pour un nouvel appel
# SYDCLLUPD : gestion données synchronisation pour un appel existant
# SYDCLLDEL : gestion données synchronisation pour une  suppression d'appel
# SYDCORCRE : gestion données synchronisation pour un nouveau correspondant
# SYDCORUPD : gestion données synchronisation pour un correspondant existant
# SYDCORDEL : gestion données synchronisation pour une suppression de correspondant
# SYDBAPCRE : gestion données synchronisation pour un nouveau rendez vous
# SYDBAPUPD : gestion données synchronisation pour un rendez vous existant
# SYDBAPDEL : gestion données synchronisation pour une suppression de rendez vous
##########################################################################################################
# "C" création,
# "D" duplication,
# "M" modification,
# "A" annulation
# "P" changement utilisateur (pour ancien)
##########################################################################################################
##########################################################################################################
Subprog SYDINITCPT(SZSYDCPT, IERRINF, ICHAPTER, IBRETOUR)
Variable Char SZSYDCPT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  #------------------------------------------------------------#
  # --> Récupération du code compteur synchronisation données  #
  #------------------------------------------------------------#
  IBRETOUR = 1
  Local File TABCOUAFF [TCA]
  Read [TCA]TCA0=13
  If fstat Then
    IERRINF = 64
    ICHAPTER = 199
    IBRETOUR = 0
    End
  Endif
  SZSYDCPT = [F:TCA]CODNUM(8)
End

##########################################################################################################
Subprog SYDUSRFROMREP(SZREP, SZUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZREP
Variable Char SZUSR
Variable Integer IBUSRSYNC_OK
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IBRETOUR = 1
  SZUSR = ""
  IBUSRSYNC_OK = 0
  Call GETUTIFROMREP(SZREP, SZUSR, IERRINF,ICHAPTER,IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    IBRETOUR = 1
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  If SZUSR = "" Then
    #si pas utilisateur on sort
    End
  Endif
  #On regarde si l'utilisateur est  défini pour la synchronisation
  Local File SYNCPAR [SYPW]
  Read [SYPW]SYP0=SZUSR
  If fstat Then
    #l'utilisateur n'est pas défini on ne continue pas
    End
  Endif
  #On a un utilisateur pour la synchronisation
  IBUSRSYNC_OK = 1
End

##########################################################################################################
#renvoi si la synchronisation est possible pour un type (COR, TSK, CLL, BAP)
Subprog SYDUSRSYNCTYP(SZUSR, SZTYPE, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZUSR
Value Char SZTYPE
Variable Integer IBUSRSYNC_OK
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBOK

  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  IBOK = 0
  If SZUSR = "" Then
    #si pas utilisateur on sort
    End
  Endif
  If GCRMSYNC <> 2 Then
    End
  Endif
  #On regarde si l'utilisateur est  défini pour la synchronisation
  Local File SYNCPAR [SYPW]
  Read [SYPW]SYP0=SZUSR
  If fstat <> 0 Then
    #l'utilisateur n'est pas défini on ne continue pas
    End
  Endif
  Case SZTYPE
    When "TSK"
      If GCRMSYNCTSK = 2 Then
        If [F:SYPW]TSKOTKCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]TSKOTKUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]TSKOTKDLT = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]TSKADXCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]TSKADXUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]TSKADXDLT = 2 Then
          IBOK = 1
        Endif
      Endif
    When "CLL"
      If GCRMSYNCCLL = 2 Then
        If [F:SYPW]CLLOTKCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CLLOTKUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CLLOTKDLT = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CLLADXCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CLLADXUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CLLADXDLT = 2 Then
          IBOK = 1
        Endif
      Endif
    When "BAP"
      If GCRMSYNCBAP = 2 Then
        If [F:SYPW]BAPOTKCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]BAPOTKUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]BAPOTKDLT = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]BAPADXCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]BAPADXUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]BAPADXDLT = 2 Then
          IBOK = 1
        Endif
      Endif
    When "COR"
      If GCRMSYNCCOR = 2 Then
        If [F:SYPW]COROTKCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]COROTKUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]COROTKDLT = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CORADXCRE = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CORADXUPD = 2 Then
          IBOK = 1
        Endif
        If [F:SYPW]CORADXDLT = 2 Then
          IBOK = 1
        Endif
      Endif
  Endcase
  If IBOK = 1 Then
    IBUSRSYNC_OK = 1
  Endif
End

##########################################################################################################
#Ecriture d'un nouvement de synchonisation
Subprog SYDWRITE(SZSYDUSR, SZSITE, SZSYDKEY, SZSYDTYP, SZSYDATTTYP, IBSYDOTKSTA, IBSYDGEN, IBSYDUPD, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSYDUSR
Value Char SZSITE
Value Char SZSYDKEY
Value Char SZSYDTYP
Value Char SZSYDATTTYP
Value Integer IBSYDOTKSTA
Value Integer IBSYDGEN
Value Integer IBSYDUPD
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSYDCPT(GLONDES)
Local Char SZSYDNUM(GLONVCR)
Local Integer STAT

  IBRETOUR = 1
  SZSYDCPT = ""
  SZSYDNUM = ""
  STAT = 0
  Local File SYNCDATA [SYD]
  #
  Call SYDINITCPT(SZSYDCPT, IERRINF, ICHAPTER, IBRETOUR)
  If IBRETOUR = 0 Then
    # problème lors de la récupération du compteur
    IERRINF = 60
    ICHAPTER = 199
    IBRETOUR = 0
    End
  Endif
  Call NUMERO(SZSYDCPT, SZSITE, date$, "", SZSYDNUM, STAT) From SUBANM
  If STAT <> 0 Then
    # problème lors de la récupération du compteur
    IERRINF = 60
    ICHAPTER = 199
    IBRETOUR = 0
    End
  Endif
  [F:SYD]SYDNUM = SZSYDNUM
  [F:SYD]SYDUSR = SZSYDUSR
  [F:SYD]SYDKEY = SZSYDKEY
  [F:SYD]SYDTYP = SZSYDTYP
  [F:SYD]SYDATTTYP = SZSYDATTTYP
  [F:SYD]SYDGEN = IBSYDGEN
  [F:SYD]SYDUPD = IBSYDUPD
  [F:SYD]SYDOTKSTA = IBSYDOTKSTA
  [F:SYD]SYDDAT = date$
  [F:SYD]SYDHOU = time$
  [F:SYD]CREUSR= GUSER
  [F:SYD]CREDAT = date$
  Write [SYD]
  If fstat Then
    #Erreur lors de la création des données pour la synchronisation
    IERRINF = 210
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Endif
End

##########################################################################################################
Subprog SYDTSKCRE(IERRINF, ICHAPTER, IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM(GLONVCR)
Local Char SZSYDUSR(GLONAUS)
Local Integer IBUSRSYNC_OK

  SZSITE = ""
  SZSYDUSR = ""
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  #On est en cours de synchronisation, on ne fait rien
  If GSYNCOUTLOOK = 1 Then
    End
  Endif
  ITSKUSRSYNC = 0
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCTSK <> 2 Then
    End
  Endif
  #---------------------------------------------------#
  # Récupération de l'utilisateur
  #---------------------------------------------------#
  If [M:TSK1]TSKREP = "" Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  Call SYDUSRFROMREP([M:TSK1]TSKREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
  If IBUSRSYNC_OK = 0 Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  Local File SYNCDATA [SYD]
  SZSITE = func CRM_UTIL.GET_SITE_DEFAUT("ACT", "")
  Call SYDWRITE(SZSYDUSR, SZSITE, [M:TSK0]TSKNUM, "TSK", "C", 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
End

##########################################################################################################
Subprog SYDTSKUPD(IERRINF, ICHAPTER, IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM(GLONVCR)
Local Char SZSYDUSR(GLONAUS)
Local Char SZCODESYD(250)
Local Integer IBMODIFREP
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer IBNEWOTK

  SZSITE = ""
  SZSYDUSR = ""
  SZCODESYD = ""
  IBMODIFREP = 0
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  IBNEWOTK = 0
  #On est en cours de synchronisation, on ne fait rien
  If GSYNCOUTLOOK = 1 Then
    End
  Endif
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCTSK <> 2 Then
    End
  Endif
  Local File SYNCDATA [SYD]
  SZSITE = func CRM_UTIL.GET_SITE_DEFAUT("ACT", "")
  IBMODIFREP = 0
  If [M:TSK1]TSKREP <> [M:TSK1]TSKREPINI Then
    IBNEWOTK = 1
    If [M:TSK1]TSKREPINI <> "" Then
      #On a une modification du représentant
      IBMODIFREP = 1
    Endif
  Endif
  If IBMODIFREP = 1 Then
    #On a un changement utilisateur, enregistrement donné pour ancien
    Call SYDUSRFROMREP([M:TSK1]TSKREPINI, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
    If IBUSRSYNC_OK = 0 Then
      #On arrete car pas d'utilisateur pour la syncro
      IBMODIFREP = 0
    Else
      #On recherche si il existe des données pour cet utilisateur
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [M:TSK0]TSKNUM
      For [SYD]SYD1
        INBRECORD += 1
        [F:SYD]SYDUSR = SZSYDUSR
        [F:SYD]SYDATTTYP = "P"
        [F:SYD]SYDDAT = date$
        [F:SYD]SYDHOU = time$
        [F:SYD]UPDUSR= GUSER
        [F:SYD]UPDDAT = date$
        Rewrite [SYD]
      Next
      Filter [SYD]
      If INBRECORD = 0 Then
        #Il faut creer un nouvel enregistrement
        Call SYDWRITE(SZSYDUSR, SZSITE, [M:TSK0]TSKNUM, "TSK", "P" , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 0 Then
          End
        Endif
      Endif
     Endif
  Endif
  #traitement des données pour utilisateur courant
  SZSYDUSR = ""
  Call SYDUSRFROMREP([M:TSK1]TSKREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
  If IBUSRSYNC_OK = 0 Then
    #On arrete car pas d'utilisateur pour la synchro
    End
  Endif
  #On recherche si il existe des données pour cet utilisateur
  INBRECORD = 0
  Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [M:TSK0]TSKNUM
  For [SYD]SYD1
    INBRECORD += 1
    [F:SYD]SYDATTTYP = "R"
    [F:SYD]SYDDAT = date$
    [F:SYD]SYDHOU = time$
    [F:SYD]CREUSR= GUSER
    [F:SYD]CREDAT = date$
    Rewrite [SYD]
  Next
  Filter [SYD]
  If INBRECORD = 0 Then
    #Il faut creer un nouvel enregistrement
    If IBNEWOTK = 0 Then
      SZCODESYD = "M"
    Else
      SZCODESYD = "C"
    Endif
    Call SYDWRITE(SZSYDUSR, SZSITE, [M:TSK0]TSKNUM, "TSK", SZCODESYD , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
  Endif
End

##########################################################################################################
Subprog SYDTSKDEL(IERRINF, ICHAPTER, IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM(GLONVCR)
Local Char SZSYDUSR(GLONAUS)
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD

  SZSITE = ""
  SZSYDUSR = ""
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  #On est en cours de synchronisation, on ne fait rien
  If GSYNCOUTLOOK = 1 Then
    End
  Endif
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCTSK <> 2 Then
    End
  Endif
  Local File SYNCDATA [SYD]
  SZSITE = func CRM_UTIL.GET_SITE_DEFAUT("ACT", "")
  #On supprime les données de synchronisation de type nouveau
  Delete [SYD] Where [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [M:TSK0]TSKNUM and [F:SYD]SYDATTTYP = "C"
  If fstat Then
    #Erreur lors de la suppression des données de synchronisation
    IERRINF = 211
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Endif
  #traitement des données pour utilisateur courant
  SZSYDUSR = ""
  Call SYDUSRFROMREP([M:TSK1]TSKREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
  If IBUSRSYNC_OK = 0 Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  #On recherche si il existe des données pour cet utilisateur
  INBRECORD = 0
  Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "TSK"  and [F:SYD]SYDKEY = [M:TSK0]TSKNUM
  For [SYD]SYD1
    INBRECORD += 1
    [F:SYD]SYDATTTYP = "A"
    [F:SYD]SYDDAT = date$
    [F:SYD]SYDHOU = time$
    [F:SYD]CREUSR= GUSER
    [F:SYD]CREDAT = date$
    Rewrite [SYD]
  Next
  Filter [SYD]
  If INBRECORD = 0 Then
    #Il faut creer un nouvel enregistrement
    Call SYDWRITE(SZSYDUSR, SZSITE, [M:TSK0]TSKNUM, "TSK", "A" , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
  Endif
End

