##########################################################################################################
Subprog SYDCLLUPD(IERRINF, ICHAPTER, IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM(GLONVCR)
Local Char SZSYDUSR(GLONAUS)
Local Char SZCODESYD(250)
Local Integer IBMODIFREP
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer IBNEWOTK

  SZSITE = ""
  SZSYDUSR = ""
  SZCODESYD = ""
  IBMODIFREP = 0
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  IBNEWOTK = 0
  #On est en cours de synchronisation, on ne fait rien
  If GSYNCOUTLOOK = 1 Then
    End
  Endif
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCCLL <> 2 Then
    End
  Endif
  Local File SYNCDATA [SYD]
  SZSITE = func CRM_UTIL.GET_SITE_DEFAUT("ACT", "")
  IBMODIFREP = 0
  If [M:CLL1]CLLREP <> [M:CLL1]CLLREPINI Then
    IBNEWOTK = 1
    If [M:CLL1]CLLREPINI <> "" Then
      #On a une modification du représentant
      IBMODIFREP = 1
    Endif
  Endif
  If IBMODIFREP = 1 Then
    #On a un changement utilisateur, enregistrement donné pour ancien
    Call SYDUSRFROMREP([M:CLL1]CLLREPINI, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
    If IBUSRSYNC_OK = 0 Then
      #On arrete car pas d'utilisateur pour la syncro
      IBMODIFREP = 0
    Else
      #On recherche si il existe des données pour cet utilisateur
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = [M:CLL0]CLLNUM
      For [SYD]SYD1
        INBRECORD += 1
        [F:SYD]SYDUSR = SZSYDUSR
        [F:SYD]SYDATTTYP = "P"
        [F:SYD]SYDDAT = date$
        [F:SYD]SYDHOU = time$
        [F:SYD]UPDUSR= GUSER
        [F:SYD]UPDDAT = date$
        Rewrite [SYD]
      Next
      Filter [SYD]
      If INBRECORD = 0 Then
        #Il faut creer un nouvel enregistrement
        Call SYDWRITE(SZSYDUSR, SZSITE, [M:CLL0]CLLNUM, "CLL", "P", 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 0 Then
          End
        Endif
      Endif
     Endif
  Endif
  #traitement des données pour utilisateur courant
  SZSYDUSR = ""
  Call SYDUSRFROMREP([M:CLL1]CLLREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR)
  If IBUSRSYNC_OK = 0 Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  #On recherche si il existe des données pour cet utilisateur
  INBRECORD = 0
  Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = [M:CLL0]CLLNUM
  For [SYD]SYD1
    INBRECORD += 1
    [F:SYD]SYDATTTYP = "R"
    [F:SYD]SYDDAT = date$
    [F:SYD]SYDHOU = time$
    [F:SYD]CREUSR= GUSER
    [F:SYD]CREDAT = date$
    Rewrite [SYD]
  Next
  Filter [SYD]
  If INBRECORD = 0 Then
    #Il faut creer un nouvel enregistrement
    If IBNEWOTK = 0 Then
      SZCODESYD = "M"
    Else
      SZCODESYD = "C"
    Endif
    Call SYDWRITE(SZSYDUSR, SZSITE, [M:CLL0]CLLNUM, "CLL", SZCODESYD, 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR)
  Endif
End

##########################################################################################################
