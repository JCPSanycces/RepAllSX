######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ASHW8) 16/01/2013 10:56:29 (KUYAN)
######################################################################################
Subprog C_CODMENU(VALEUR)
Variable Char    VALEUR()
 # unique check
 Call UNICITE(VALEUR,[M:ASW8]CODMENU(0..[M:ASW8]NBMENU-1)) From OBJDIV
End

Subprog C_FACCETTE(VALEUR)
Variable Integer VALEUR
 # unique check
 Call UNICITE(VALEUR,[M:ASW8]FACCETTE(0..[M:ASW8]NBCONFIG-1)) From OBJDIV
End


