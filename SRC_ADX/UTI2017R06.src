#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTI2017R06 UTI process for 2017R6 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017R6 - passage de R5 vers R6
#
#      correction utility to be done at the end of the patch - move from R5 to R6
#
##########################################################################
# Issue X3-53858 - 2017-09-25 by JUSYN : trace for WO validations and others
# Infbox "only update folder by patch"
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2017R06 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
# End issue X3-53858
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R06 (APPLI)

End

###################################################
Subprog EXE_UTI2017R06(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R06-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

# Issue X3-53685 - 2017-07-20 by CCC : run validation of requests in order to take into account last corrections in R5
Call PATCH(LDOSSIER) From SUBALH1     # Requests validation
Call PATCH(LDOSSIER) From SUBALT1     # Graphical requests validation

# Issue X3-37908 - 2017-10-06 by CCC : run validation of workflow rules linked to data models UPDFLD & AFCTFCT
Call PATCH(LDOSSIER) From UTIVALWRK

# Issue 50224 - 2017-09-25 by MAE : Validation of object CTRH1 and window OSHIP.
If [F:ADS]MODULE(5) = 2 Then
  Call PATCH(LDOSSIER) From UTIACH50224
  # Issue X3-57683 - 2017-09-28 by SR : Receipts entry transaction validation
  Call PATCH(LDOSSIER) From SUBPTR
Endif

# Issue X3-53858 - 2017-09-25 by JUSYN : WO validations
# Issue X3-38661 - 2017-10-10 by GH    : WO validations
If [F:ADS]MODULE(7)=2
  Call PATCH(LDOSSIER) From SUBMFL
Endif
#                                            # hcb x3-50357 deb
If [F:ADS]MODULE(6)=2
# Consultations
  Call PATCH(LDOSSIER) From CNSSFCSTD
  Call PATCH(LDOSSIER) From CNSSARSTD
  Call PATCH(LDOSSIER) From CNSSLOSTD
  Call PATCH(LDOSSIER) From CNSSSESTD
  Call PATCH(LDOSSIER) From CNSSPRSTD
  Call PATCH(LDOSSIER) From CNSSDASTD
  Call PATCH(LDOSSIER) From CNSSPESTD
  Call PATCH(LDOSSIER) From CNSSDOSTD
  Call PATCH(LDOSSIER) From CNSSADSTD
  Call PATCH(LDOSSIER) From CNSSAGSTD
  Call PATCH(LDOSSIER) From CNSSMVSTD
  Call PATCH(LDOSSIER) From CNSSMJSTD
  Call PATCH(LDOSSIER) From CNSSATSTD
  Call PATCH(LDOSSIER) From CNSSMASTD
  Call PATCH(LDOSSIER) From CNSSBISTD
  Call PATCH(LDOSSIER) From CNSSHSSTD
  Call PATCH(LDOSSIER) From CNSSRFSTD
  Call PATCH(LDOSSIER) From CNSSEDSTD
  Call PATCH(LDOSSIER) From CNSSIISTD
#                                            # hcb x3-50357 end
#                                            # hcb x3-51677 deb
# Transactions saisie
  Call PATCH(LDOSSIER) From SUBSRT
  Call PATCH(LDOSSIER) From SUBSOT
  Call PATCH(LDOSSIER) From SUBPBY
  Call PATCH(LDOSSIER) From SUBSCT
#                                            # hcb x3-51677 end
Endif                                        # hcb x3-50357

# Update ADMCA profil (october 2017)
Call PATCH(LDOSSIER) From UTIADMCA

Call PATCH(LDOSSIER) From UTIVEN59635        #X3-59635 initializing the metcorcod field in sales invoice transactions
Call PATCH(LDOSSIER) From SUBSLI             # Issue X3-59635 - 2017-10-26 by ADMIN : Need to revalidate the transactions X3.TRT/SUBSIHA1$adx (1844) Error 6 : Variable Non-existent METCOR
Call PATCH(LDOSSIER) From SUBSLA             # Issue X3-59635 - 2017-10-26 by ADMIN : Need to revalidate the transactions X3.TRT/SUBSIHA1$adx (1844) Error 6 : Variable Non-existent METCOR

Call PATCH(LDOSSIER) From UTICPT93           #X3-58523 Removal of obsolete north american reports

Call ECR_TRACE("END : UTI2017R06-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R06
End

