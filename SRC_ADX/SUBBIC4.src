##################################################################################################################

##################################################################################################################
#$INI_SALPRITYP - Initializing of the amount type SALPRITYP. Called from SUBBIC/C_BPR, SUBBIC/AM_BPR
#amount type is initialized with customer or customer category or parameter SALPRITYP
#if parameter NOTATI='No', the radio buttons are disabled, otherwise enabled.
##################################################################################################################

# IRMUE 14.05.12 AP/AR management/setting amount type
#The parameter COMAMTENT allows the use of amount+tax entry in AP / AR management.
$INI_SALPRITYP
## In case of 'Rebate on VAT' Option, the invoice has to be entered in 'Ex Tax' <85830>
## In case of 'Rebate on exempt VAT' Option, the invoice has to be entered in 'Ex Tax' <100922>
If GDEPMGTMOD=1 or (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIC1]DEP))
 [M:BIC1]SALPRITYP = 1 : Grizo [M:BIC1]SALPRITYP
Else
   If [F:BPC]PRITYP <> 0
      [M:BIC1]SALPRITYP = [F:BPC]PRITYP
   Else
      If !clalev([F:BCG])  : Local File BPCCATEG  [BCG]  : Endif
      Read [BCG]BCG0 = [F:BPC]BCGCOD
      If !fstat
         [M:BIC1]SALPRITYP = [BCG]PRITYP
      Endif
      If [M:BIC1]SALPRITYP = 0
         If dim(GPRITYP)>0
            [M:BIC1]SALPRITYP = GPRITYP
         Else
            [M:BIC1]SALPRITYP = 1
         Endif
      Endif
   Endif
   If dim(GNOTATI)>0 & GNOTATI= 1
      Grizo [M:BIC1]SALPRITYP
   Endif
Endif

[M:BIC3]SALPRITYP = [M:BIC1]SALPRITYP
Affzo [M:BIC1]SALPRITYP : Affzo [M:BIC3]SALPRITYP

Return

##################################################################################################################
# Subprog SETCOLOR - Called from SUBBIC/$LIENS, SUBBIC2/C_NBLIG
# Parameter PSALPRITYP is the amount type [M:BIC3]SALPRITYP. If SALPRITYP="Ex tax", the amount+tax gets gray color
# If SALPRITYP="Tax inc", the amount-tax gets gray color
##################################################################################################################
Subprog SETCOLOR(PSALPRITYP)
Value Integer PSALPRITYP

#2015-07-24 DNE INSERT BEGIN (SAM #109775)
    # NOTE: The colorization is not necessary for imports. In fact it is a performance issue.
    #       So in case of imports we avoid the following calls.
    If GIMPORT <> 0 End Endif
#2015-07-24 DNE INSERT END
    If PSALPRITYP<>2
       Chgstl [M:BIC3]AMTNOTLIN With ""
       Chgstl [M:BIC3]AMTATILIN With "INACTIV"
    Else
       Chgstl [M:BIC3]AMTATILIN With ""
       Chgstl [M:BIC3]AMTNOTLIN With "INACTIV"
    Endif
End

##################################################################################################################
# $AS_AMTNOTLIN - the field action. Called from SUBBIC2/AS_AMTNOTLIN
# when amount type ="Ex tax", then skips cursor this field
##################################################################################################################
$AS_AMTNOTLIN
If [M]SALPRITYP=2 & !GIMPORT
   mkstat=2
Endif
Return

##################################################################################################################
# $RECALTOTAMT - called from SUBBIC2/AM_VAT,SUBBIC2/AM_AMTATILIN
# recalculated total amount
##################################################################################################################

$RECALTOTAMT
Local Integer MAXLIG
MAXLIG = max(nolign,[M:BIC3]NBLIG)-1
[M]TOTNOT = sum([M]AMTNOTLIN(0..MAXLIG))
[M]TOTATI = sum([M]AMTATILIN(0..MAXLIG))
If status<>7
 If !GIMPORT : Affzo TOTNOT , TOTATI : Endif
Endif

Return

##################################################################################################################
#$AM_AMTATILIN - called from SUBBIC2/AM_AMTATILIN
#The tax amount will be recalculated, if gross amount is changed, or tax amountis is not imported
#recalculated total amount
##################################################################################################################

$AM_AMTATILIN

[M]AMTATILIN(nolign-1) = VALEUR
If !GIMPORT
   If dim([M:BIC1]SALPRITYP)>0 & [M:BIC1]SALPRITYP=2
       If [M]TAX1(nolign-1) = "" & [M]TAX2(nolign-1) = ""
           Gosub CALTVA From SUBBIC2
       Endif
   Else
      If ([M]TAX1(nolign-1)<>"" | [M]TAX2(nolign-1)<>"" | [M]VAT(nolign-1)<>"")
         Gosub CALTVA From SUBBIC2
      Endif
   Endif

   If dim([M:BIC1]SALPRITYP)>0 & [M:BIC1]SALPRITYP=2
      [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1) - [M]AMTVAT(nolign-1)-[M]AMTTAX1(nolign-1)-[M]AMTTAX2(nolign-1)
   Endif

   Affzo [M]AMTNOTLIN(nolign-1)
   Affzo [M]AMTVAT(nolign-1)
   Affzo [M]AMTATILIN(nolign-1)
   Gosub RECALTOTAMT
Endif
Return

##################################################################################################################
#$AM_SALPRITYP - called from SUBBIC2/AM_SALPRITYP
#update of [M:BIC3]SALPRITYP
#changed setting of color
##################################################################################################################

$AM_SALPRITYP
[M:BIC3]SALPRITYP = VALEUR
Affzo [M:BIC3]SALPRITYP

Call SETCOLOR(VALEUR)
Return


##################################################################################################################
#Subprog B2_AMTATILIN - called from SUBBIC2/B2_AMTATILIN
#The right click option “Close”
##################################################################################################################

Subprog B2_AMTATILIN(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL From SUBBIC2
VALEUR = [M]AMTATI-sum([M]AMTATILIN(0..NOL-1))-sum([M]AMTATILIN(NOL+1..[M]NBLIG-1))
End


