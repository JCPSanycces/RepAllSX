#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("LISTCPCEMP","") From ETAT
End

####################################################
## Compétences par salarié
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250), CRITERE1(250)
Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    PRFDEB(GLONPRF), PRFFIN(GLONPRF), SRVDEB(GLONSRV), SRVFIN(GLONSRV)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML),POPULATION(GLONPOP)
Local Decimal NUMREQ

If clalev([F:ARM])=0    : Local File AREPORTM  [ARM]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]  : Endif
If clalev([F:CPE])=0    : Local File CPCEMP    [CPE]  : Endif
If clalev([F:CPE1])=0   : Local File CPCEMP    [CPE1] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]: Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB)
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("prfdeb",NBPAR,PARAMETRE,PRFDEB)
Call GETPARAM("prffin",NBPAR,PARAMETRE,PRFFIN)
Call GETPARAM("srvdeb",NBPAR,PARAMETRE,SRVDEB)
Call GETPARAM("srvfin",NBPAR,PARAMETRE,SRVFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = "[F:ID]ENAFLG=2"
CRITERE2 = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"

If CPYDEB<>"" : CRITERE1 -= "& [F:FGR]CPY>='"+CPYDEB+"'"    : Endif
If CPYFIN<>"" : CRITERE1 -= "& [F:FGR]CPY<='"+CPYFIN+"'"    : Endif
If FCYDEB<>"" : CRITERE1 -= "& [F:ECT]FCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE1 -= "& [F:ECT]FCY<='"+FCYFIN+"'"    : Endif
If PRFDEB<>"" : CRITERE1 -= "& [F:ECT]PRF>='"+PRFDEB+"'"    : Endif
If PRFFIN<>"" : CRITERE1 -= "& [F:ECT]PRF<='"+PRFFIN+"'"    : Endif
If SRVDEB<>"" : CRITERE2 -= "& [F:ECT]SRV>='"+SRVDEB+"'"    : Endif
If SRVFIN<>"" : CRITERE2 -= "& [F:ECT]SRV<='"+SRVFIN+"'"    : Endif
If MATDEB<>"" : CRITERE2 -= "& [F:ECT]REFNUM>='"+MATDEB+"'" : Endif
If MATFIN<>"" : CRITERE2 -= "& [F:ECT]REFNUM<='"+MATFIN+"'" : Endif

If [L]POPULATION<>""
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
& , [FGR]FGR1(1)=[F:ECT]FCY
& , [HRPOA]POA0=[L]POPULATION;[F:ECT]REFNUM
& As [LID]
& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
& , [FGR]FGR1(1)=[F:ECT]FCY
& As [LID]
& Where evalue(CRITERE1) & evalue(CRITERE2)
Endif


Call DEBTRANS From GLOCK
Gosub TR1
Call DEBTRANS From GLOCK
Gosub TR2
Call TEMPOFF From GESECRAN
End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]
 I=1
 For [LID]ECT0
  Filter [CPE] Where REFNUM=[F:ECT]REFNUM
  For [CPE]CPE1(2)
   # SYMEU - 05/11/10 - EXI 66105 LOT 8 - V6.1 : on ne prend que les compétences validées
   # Filter [CPE1] Where REFNUM=[F:ECT]REFNUM & CPC=[F:CPE]CPC
   Filter [CPE1] Where REFNUM=[F:ECT]REFNUM & CPC=[F:CPE]CPC & CPCDAT <> [00/00/00] 
   Read [CPE1]CPE1 Last
   If !fstat
    Raz [F:ARM]
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ 
    [F:ARM]NUMLIG = I
    [F:ARM]CLEA1  = [F:ECT]REFNUM
    [F:ARM]CLEA2  = [F:CPE1]CPC
    [F:ARM]CLEA3  = [F:CPE1]LEVCPC
    [F:ARM]CLEA4  = [F:ECT]CTRNUM
    [F:ARM]CLEN1  = [F:CPE1]ORICPC
    [F:ARM]CLED1  = [F:CPE1]CPCDAT
    Write [ARM]
    If fstat 
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif 
   Endif
   I+=1
   Filter [CPE1]
  Next
 Next
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
