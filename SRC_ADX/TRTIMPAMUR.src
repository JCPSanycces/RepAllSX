#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT"        : Gosub OUVRE
    When "OUVRE_BATCH" : Gosub OUVRE
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
  Endcase
Return

######################################################################################
$OUVRE
  If GSERVEUR : Onerrgo ERRBATCH : Endif
  If GSERVEUR=1
    Local Mask IPMMURANO [DIA]
  Endif

  If func AFNC.ACTIV("KSP")=0
    Infbox (mess(200,104,1))  # Function only available when KSP activity code is active
    Return
  Endif

  If clalev([F:IPM])=0  : Local File IMURANO    [IPM]  : Endif
  If clalev([F:IPMD])=0 : Local File IMURANOD   [IPMD] : Endif
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
  If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
  If clalev([F:KPH])=0  : Local File KPYIMPHDR  [KPH]  : Endif
  If clalev([F:KPD])=0  : Local File KPYIMPDTL  [KPD]  : Endif
  If clalev([F:KPA])=0  : Local File KPYIMPDTLA [KPA]  : Endif
  If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif
  If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
  If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
  If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
  If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
  If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
  If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif

  Local Char  FICORG(GDIMFIC) , FICREL(GDIMFIC) , URL(10)
  Local Integer STAT , TYPFIC
  Local Char TXT(70), TIT(70)
  Local Integer WTRAIT(1..)
  Local Char WRSITE(GLONFCY)(1..), NFIC(250)

Return

######################################################################################
$INIT_DIA
  Raz [M:DIA]
  If GUSRFCY(1)="\" or GNBAUZ=GNBSITE
    [M:DIA]ALLCPY=2
    [M:DIA]ALLFCY=2
    Diszo [M:DIA]ALLFCY,CPY,FCY
  Else
    Diszo [M:DIA]ALLCPY
    Call INICPY([M:DIA]CPY) From SUPCPT
    Call INIFCY([M:DIA]FCY,[M:DIA]CPY) From SUPCPT
  Endif

  If [M]FICHIER="" & GFICPATH<>""
    [M]FICHIER = GFICPATH
  Endif

  [M]TYPEXP=2
  Affzo [M:DIA]ALLCPY,ALLFCY,CPY,FCY, TYPEXP

  Call AM_TYPEXP([M]TYPEXP)
Return

######################################################################################
$CONTROLE
  If [M:DIA]CPY=""
    SYMBOLE="IPMMURANO\All"
    Lock =SYMBOLE With lockwait=0
    If fstat
      GMESSAGE= mess(30,100,1)   # The record is used by an other user
      GERR=2 : FIN=1 : Return
    Endif
  Else
    SYMBOLE="IPMMURANO\All"
    Lock =SYMBOLE With lockwait=0
    If fstat
      GMESSAGE= mess(30,100,1)   # The record is used by an other user
      GERR=2 : FIN=1 : Return
    Else
      Unlock =SYMBOLE
      SYMBOLE="IPMMURANO\"+[M:DIA]CPY
      Lock =SYMBOLE With lockwait=0
      If fstat
        GMESSAGE= mess(30,100,1)   # The record is used by an other user
        GERR=2 : FIN=1 : Return
      Endif
    Endif
  Endif

  Call TEXTE(54622,TXT) From OBJDIV
  TIT= TXT
  TMP=1
Return

######################################################################################
$EXEC
  If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call PRTSCR("IPMMURANO","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  FICORG = [M]FICHIER
  TYPFIC = [M]TYPEXP

  If [M]TYPEXP=1
    Call SET_FICNAM(FICORG,FICREL,URL) From ORDSYS
    Call COPSRV(FICORG,FICREL,STAT) From ORDSYS
    If STAT : Return : Endif
  Else
    Call EXISTE(FICORG,STAT) From ORDSYS
    If STAT<>1 : Return : Endif
    FICREL = FICORG
  Endif
  Default Mask [DIA]
  [M]FICHIER = FICREL
  Affzo [M]FICHIER

  Gosub SELECT_SITES

  If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

  Openi NFIC Using [IMP]

Return

######################################################################################
$TERMINE
  Unlock =SYMBOLE
  If !GSERVEUR
    TRA=1
  Else
    TRA=0
  Endif
Return

######################################################################################
$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

######################################################################################
$SELECT_SITES
  Local Char CRITLEG(3)(1..), SELFCY(GLONFCY)(1..), SELCPY(GLONCPY)(1..), SELLEG(3)(1..), SELFCYNAM(35)(1..), RECOK(25)(1..)
  Local Char CRITERE(250), WMSG(250), NUMLOT(20)
  Local Integer I, NBLEG, NBFCY, WOKSET, WNBSITE, NBLIN, NBREC, NBRECOK, NBRECKO, NBRECSOK, NBRECDET
  NBFCY=1

  If [M:DIA]ALLCPY=2      #All companies
    Local Integer NBOK
    For [IPM]IPM0
      If [F:IPM]FCY<>""
        NBOK=find([F:IPM]FCY,SELFCY)
        If NBOK=0
          Read[FCY]FCY0=[F:IPM]FCY
          If fstat=[V]CST_AOK
            SELFCY(NBFCY)= [F:IPM]FCY
            SELCPY(NBFCY)   = [F:FCY]LEGCPY
            SELLEG(NBFCY)   = [F:FCY]LEG
            SELFCYNAM(NBFCY)= [F:FCY]FCYNAM
            NBFCY+=1
          Endif
        Endif
      Elsif [F:IPM]CPY<>""
        For [FCY] Where LEGCPY=[M:DIA]CPY and FINFLG=2
          NBOK=find([F:FCY]FCY,SELFCY)
          If NBOK=0
            SELFCY(NBFCY)   = [F:FCY]FCY
            SELCPY(NBFCY)   = [F:FCY]LEGCPY
            SELLEG(NBFCY)   = [F:FCY]LEG
            SELFCYNAM(NBFCY)= [F:FCY]FCYNAM
            NBFCY+=1
          Endif
        Next
      Elsif [F:IPM]LEG<>""
        If GLEGFIL<>"": CRITERE="FINFLG=2 & LEG="+GLEGFIL
        Else          : CRITERE="FINFLG=2 & LEG='"+[F:IPM]LEG+"'"
        Endif
        For [FCY] Where evalue(CRITERE)
          NBOK=find([F:FCY]FCY,SELFCY)
          If NBOK=0
            SELFCY(NBFCY)   = [F:FCY]FCY
            SELCPY(NBFCY)   = [F:FCY]LEGCPY
            SELLEG(NBFCY)   = [F:FCY]LEG
            SELFCYNAM(NBFCY)= [F:FCY]FCYNAM
            NBFCY+=1
          Endif
        Next
      Endif
    Next
  Else
    If [M:DIA]ALLFCY=2  #All sites of the company
      For [FCY]FCY0 Where LEGCPY=[M:DIA]CPY
        SELFCY(NBFCY)   = [F:FCY]FCY
        SELCPY(NBFCY)   = [F:FCY]LEGCPY
        SELLEG(NBFCY)   = [F:FCY]LEG
        SELFCYNAM(NBFCY)= [F:FCY]FCYNAM
        NBFCY+=1
      Next
    Else    #One site
      Read [FCY]FCY0=[M:DIA]FCY
      If fstat=[V]CST_AOK
        SELFCY(NBFCY)   = [F:FCY]FCY
        SELCPY(NBFCY)   = [F:FCY]LEGCPY
        SELLEG(NBFCY)   = [F:FCY]LEG
        SELFCYNAM(NBFCY)= [F:FCY]FCYNAM
      Endif
    Endif
  Endif

  If NBFCY>1: NBFCY=NBFCY-1: Endif
  # Sites to process

  WMSG=  mess(242,190,1)-tolower(mess(34,117,1))+":"-num$(NBFCY)+"."
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  # Process by site
  For I=1 To NBFCY
    Raz WOKSET
    Local Char MSGCPY(GLONCPY), MSGFCY(GLONFCY), MSGLEG(3)
    MSGCPY=format$("K:5X","")
    MSGFCY=format$("K:5X","")

    Gosub RECOVER_SETUP_LEVSITE
    If WOKSET=0
      Gosub RECOVER_SETUP_LEVCPY
    Endif
    If WOKSET=0
      Gosub RECOVER_SETUP_LEVLEG
    Endif

    If GLANGUE<>"ENG"
      WMSG=mess(3,45,1)+space$(19)+mess(68,142,1)+": "+mess(2,45,1)+space$(3)+mess(3,45,1)+space$(2)+mess(218,107,1)
    Else
      WMSG=mess(3,45,1)+space$(29)+mess(68,142,1)+": "+mess(2,45,1)+space$(3)+mess(3,45,1)+space$(2)+mess(218,107,1)
    Endif
    Call ECR_TRACE(WMSG,0) From GESECRAN

    If WOKSET<>0
      MSGLEG=format$("K:5X",[F:IPM]LEG)
    Else
      MSGLEG=SELLEG(I)
    Endif
    WMSG=format$("K:5X",SELFCY(I))+":"-format$("K:35X",SELFCYNAM(I))+MSGCPY+space$(5)+MSGFCY+space$(4)+MSGLEG
    Call ECR_TRACE(WMSG,0) From GESECRAN

    If WOKSET<>0   # Reading the import file

      Gosub IMPORT_FILE

      WMSG= mess(223,123,1)+":"-num$(NBREC) #Records read
      Call ECR_TRACE(WMSG,0) From GESECRAN

      If NBREC>0
        For J=1 To NBRECSOK
          WMSG=mess(65,154,1)+":" -RECOK(J)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Next

        WMSG=mess(176,116,1)+":"-num$(NBRECSOK)+space$(5)+ mess(140,116,1)+":"-num$(NBRECDET) : #Records created: X . Lines processed: Y
        Call ECR_TRACE(WMSG,0) From GESECRAN
        NBRECOK+=NBRECSOK
      Endif

    Else
      Call ECR_TRACE(mess(230,115,1),0) From GESECRAN   #Non-existing setup
    Endif
    Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Next

 #Totals
  Call ECR_TRACE(mess(70,195,1),0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(156,188,1)+":"-num$(NBLIN),0) From GESECRAN   #Records found
  Call ECR_TRACE(mess(176,116,1)+":"-num$(NBRECOK),0) From GESECRAN #Records created
  WMSG=mess(960,182,1)-mess(414,177,1)                              #Records not processed
  Call ECR_TRACE(WMSG+":"-num$(NBLIN-NBRECOK),0) From GESECRAN

Return

######################################################################################
$RECOVER_SETUP_LEVSITE
  # finding at level of the site
    Read [IPM]IPM0=SELCPY(I);SELFCY(I);SELLEG(I)
    If fstat=[V]CST_AOK
      WOKSET=1
      MSGCPY=format$("K:5X",[F:IPM]CPY)
      MSGFCY=format$("K:5X",[F:IPM]FCY)
    Else
      If SELFCY(I)=[F:CPY]MAIFCY
        Read [IPM]IPM0=SELCPY(I);[F:CPY]MAIFCY;SELLEG(I)
        If fstat=[V]CST_AOK
          WOKSET=1
          MSGCPY=format$("K:5X",[F:IPM]CPY)
          MSGFCY=format$("K:5X",[F:IPM]FCY)
        Endif
      Endif
    Endif
Return

$RECOVER_SETUP_LEVCPY
  # finding at level of the company
  Read [IPM]IPM0=SELCPY(I);"";SELLEG(I)
  If fstat=[V]CST_AOK
    WOKSET=2
    MSGCPY=format$("K:5X",[F:IPM]CPY)
    MSGFCY=space$(GLONFCY)
  Endif
Return

$RECOVER_SETUP_LEVLEG
    Read [IPM]IPM0="";"";SELLEG(I)
    If fstat=[V]CST_AOK
      WOKSET=3
      MSGCPY=space$(GLONCPY)
      MSGFCY=space$(GLONFCY)
    Endif
Return

######################################################################################
$IMPORT_FILE
  Local Integer K, CPYPOS, FCYPOS, WCPYPOS, WFCYPOS, SAVIUM, LONHEA(1..), NBLON, LONREG(1..), TOTLON
  Local Integer NBVAR, NBLINES, POSCON, NBDEF, TYPVAL(1..), INIVAL(1..), WACT(1..), WSNS(1..)
  Local Char FNAME(250), VNAME(250), NFIC(250), REALFCY(GLONFCY), REALCPY(GLONCPY), CONTAB(20)(1..), WDSP(10)
  Local Char USEVAL(20)(1..), USEVAL2(20)(1..), WDES(30)(1..), WFMT(5)(1..), WACCODE(GLONCAC)(1..), WCCE(GLONCCE)(1..)

  SAVIRS = adxirs
  SAVIUM = adxium
  Local Char SEPENR(8)

  If [F:IPM]SEPREC<>""
    SEPENR= [F:IPM]SEPREC
  Else
    SEPENR = "\013\010"  # Default value for Windows
  Endif

  T = 1
  $SEP1
  T = instr(1,SEPENR,"\")
  If T
    SEPENR = left$(SEPENR,T-1)+chr$(val(mid$(SEPENR,T+1,3)))+right$(SEPENR,T+4)
    T+=1
    Goto SEP1
  Endif

  FNAME=[M:DIA]FICHIER
  VNAME=FNAME

  NFIC=func NAMFICVOL(FNAME,VNAME)

  Openi NFIC Using [IMP]

  Iomode adxifs "" Using [IMP]
  Iomode adxirs SEPENR Using [IMP]
  Iomode adxium GUTF8 Using [IMP]

  Gosub PREP_VALUES

  Raz NBLIN

  # Reading the head data
  Rdseq WREGH Using [IMP]

  If dim(WREGHV)>0
    For K=1 To dim(WREGHV)  #X3-74048
      Rdseq WREGHV(K) Using [IMP]
    Next
  Endif
  If dim(WREGHF)>0
    Rdseq WREGHF Using [IMP]
  Endif

  Raz NBREC, NBRECSOK, NBRECKO ,NUMLOT

  While !fstat
    Local Integer OKK, NBLOT
    Local Char WERR(250), WLOT(20), FMTLOT(5), WDIE(GLONDIE), WLED(GLONLED)(10), WCOA(GLONCOA)(10), DIME(3)(5), DIMCCE(GLONCCE)(5)
    If WREGH<>"":  NBLIN+=1: Endif
    Raz REALCPY, REALFCY

    Trbegin [KPH]
    GOK=0
    Gosub CONTROL_SITE        #Control over the site

    If OKK=0

      ##################
      # FILLING HEADER #
      ##################
      NBREC+=1
      Raz [F:KPH]
      #Filling FCY
      [F:KPH]FCY=vireblc(REALFCY,4)

      #Filling CPY
      If REALCPY<>""
        [F:KPH]CPY=vireblc(REALCPY,4)
      Else
        Read [FCY]FCY0=[F:KPH]FCY
        If fstat=[V]CST_AOK
          [F:KPH]CPY=[F:FCY]LEGCPY
        Endif
      Endif

      #Filling CPYNAME
      If [F:KPH]CPY<>""
        Read[CPY]CPY0=[F:KPH]CPY
        If fstat=[V]CST_AOK
         [F:KPH]CPYNAM=[F:CPY]CPYNAM
        Endif
      Endif

      #Filling RPODAT and ACCDAT
      J=find(3,TYPVAL(1..NBVAR))
      If J<>0

        Local Char WDAT(LONREG(J))
        Local Date REALDAT
        For H=1 To NBLON
          If INIVAL(J)<LONHEA(H)
            Case H
              When 1            : WDAT=mid$(WREGH,INIVAL(J),LONREG(J))
              When NBLON        : WDAT=mid$(WREGF,INIVAL(J),LONREG(J))
              When Default      : WDAT=mid$(WREGHV(H),INIVAL(J),LONREG(J))
            Endcase
          Endif
        Next

        WDAT=vireblc(WDAT,4)

        If WDAT<>""
          Case USEVAL(J)
            When "YYYYMMDD"   : REALDAT=func TRANSDATE(WDAT,1)
            When "YYMMDD"     : REALDAT=func TRANSDATE(WDAT,2)
            When "DDMMYYYY"   : REALDAT=func TRANSDATE(WDAT,3)
            When "DDMMYY"     : REALDAT=func TRANSDATE(WDAT,4)
            When "YYYY-MM-DD" : REALDAT=func TRANSDATE(WDAT,5)
            When "YY-MM-DD"   : REALDAT=func TRANSDATE(WDAT,6)
            When "DD-MM-YYYY" : REALDAT=func TRANSDATE(WDAT,7)
            When "DD-MM-YY"   : REALDAT=func TRANSDATE(WDAT,8)
            When "MMDDYYYY"   : REALDAT=func TRANSDATE(WDAT,9)
            When "MMDDYY"     : REALDAT=func TRANSDATE(WDAT,10)
            When "MM-DD-YYYY" : REALDAT=func TRANSDATE(WDAT,11)
            When "MM-DD-YY"   : REALDAT=func TRANSDATE(WDAT,12)
          Endcase
        Endif
        If REALDAT<>[00/00/00]: [F:KPH]RPODAT=REALDAT
        Elsif [F:IPM]REPDAT=2 and REALDAT=[00/00/00]   # Date not found or wrong and setup has report date to yes
          Call ECR_TRACE(mess(198,104,1)+"."-mess(198,124,1) -num$(NBLIN),1) From GESECRAN: GOK=0: Goto ERR_NEXT
        Elsif [F:IPM]REPDAT=1 and REALDAT=[00/00/00]   # Date not found or wrong and setup has report date to yes
          Call ECR_TRACE(mess(196,104,1)+"."-mess(198,124,1) -num$(NBLIN),-1) From GESECRAN
        Endif
      Else
        If [F:IPM]REPDAT=2        # Date not found or wrong. The current date will be used
          Call ECR_TRACE(mess(198,104,1)+"."-mess(198,124,1) -num$(NBLIN),1) From GESECRAN:  GOK=0: Goto ERR_NEXT
        Endif
      Endif

      If [F:KPH]RPODAT=[00/00/00] : [F:KPH]RPODAT=date$: Endif

      If [F:IPM]REPDAT=2
        [F:KPH]ACCDAT=[F:KPH]RPODAT
      Else
        [F:KPH]ACCDAT=date$
      Endif

      Call CONTPER([F:KPH]ACCDAT,1,[F:KPH]FCY) From CPTSUB
      If mkstat=2
        Call ECR_TRACE(GMESSAGE+"."-mess(198,124,1) -num$(NBLIN),1) From GESECRAN:  GOK=0: Goto ERR_NEXT
      Endif

      #Filling BPRMURANO (employee)
      J=find(4,TYPVAL(1..NBVAR))
      If J<>0
        Local Char WEMP(LONREG(J))
        For H=1 To NBLON
          If INIVAL(J)<LONHEA(H)
            Case H
              When 1            : WEMP=mid$(WREGH,INIVAL(J),LONREG(J))
              When NBLON        : WEMP=mid$(WREGF,INIVAL(J),LONREG(J))
              When Default      : WEMP=mid$(WREGHV(H),INIVAL(J),LONREG(J))
            Endcase
          Endif
        Next

        WEMP=vireblc(WEMP,1)

        If WEMP<>""
          If USEVAL(J)="": [F:KPH]BPRMURANO= WEMP
          Else
            If clalev([F:BPS])=0: Local File BPSUPPLIER [BPS]: Endif
            Local Char CRIEMP(100)
            Local Integer WTYP
            CRIEMP=(USEVAL(J))+"='"+vireblc(toupper(WEMP),4)+"'"
            If instr(1,USEVAL(J),"BPR]")<>0
              If clalev([F:BPR])=0: Local File BPARTNER [BPR]: Endif
              Filter [BPR] Where evalue(CRIEMP)
              WTYP=1
            Elsif instr(1,USEVAL(J),"BPS]")<>0
              Filter [BPS] Where evalue(CRIEMP)
              WTYP=2
            Endif
            If WTYP<>0
              Read First
              If fstat=[V]CST_AOK
                If WTYP=1: [F:KPH]BPRMURANO=[F:BPR]BPRNUM
                  Read [BPS]BPS0=[F:BPR]BPRNUM
                  If fstat=[V]CST_AOK and [F:BPS]BPRDSP<>"": WDSP=[F:BPS]BPRDSP: Endif
                Endif
                If WTYP=2: [F:KPH]BPRMURANO=[F:BPS]BPSNUM
                  If [F:BPS]BPRDSP<>"": WDSP=[F:BPS]BPRDSP: Endif
                Endif
              Elsif [F:IPM]FLGDET=1: [F:KPH]BPRMURANO= WEMP
              Elsif [F:IPM]FLGDET=2: Call ECR_TRACE(mess(1128,196,1)+"."-mess(198,124,1) -num$(NBLIN),1) From GESECRAN:
                NBRECKO+=1:  Filter [BPR]: Raz [F:IPM]: GOK=0: Goto ERR_NEXT #Invalid BP
              Endif
              Close File [BPR], [BPS]
            Endif
          Endif
        Else
          # BP not specified
          If [F:IPM]FLGDET=1
            Call ECR_TRACE(mess(197,107,1)+"."-mess(198,124,1) -num$(NBLIN),-1) From GESECRAN
          Else
            Call ECR_TRACE(mess(197,107,1)+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
            NBRECKO+=1
            GOK=0: Goto ERR_NEXT
          Endif
        Endif
      Endif

      #Filling LOT, NUMURANO
      Local File KPYIMPHDR [KPHX]
      WLOT=[F:KPH]CPY+[F:KPH]FCY+format$("D:DDMMYY",[F:KPH]ACCDAT)
      FMTLOT="N0:"+num$(20-len(WLOT))
      NBLOT=1
      Filter [KPHX] Where left$(LOT,len(WLOT))=WLOT Order By LOT
      Read First
      If fstat<>[V]CST_AOK
        NUMLOT=WLOT+format$(FMTLOT,NBLOT)
       [F:KPH]NUMMURANO=1
      Else
        If NBRECSOK=0
          Read Last
          NBLOT=val(seg$([F:KPHX]LOT,len(WLOT)+1,len([F:KPHX]LOT)))
          NBLOT+=1
          NUMLOT=WLOT+format$(FMTLOT,NBLOT)
        Endif
      Endif
      Filter [KPHX]
      Close File [KPHX]

      [F:KPH]LOT=NUMLOT
      [F:KPH]NUMMURANO=NBRECSOK+1
      [F:KPH]RECID=num$(val(date$))+num$(ctrans(time$,":",""))+num$(NBRECSOK)


      #Filling REF
      J=find(5,TYPVAL(1..NBVAR))
      If J<>0
        Local Char WREF(LONREG(J))
        For H=1 To NBLON
          If INIVAL(J)<LONHEA(H)
            Case H
              When 1:             WREF=mid$(WREGH,INIVAL(J),LONREG(J))
              When NBLON        : WREF=mid$(WREGF,INIVAL(J),LONREG(J))
              When Default      : WREF=mid$(WREGHV(H),INIVAL(J),LONREG(J))
            Endcase
          Endif
        Next

        WREF=vireblc(WREF,4)
        If WREF<>""
          [F:KPH]REF=WREF
        Endif
      Endif

      If [F:KPH]REF=""
        Local Char TEXTE(50)
        Call LECTEXTRA (TEXTE,"IMURANO","DES",[F:IPM]IDENT1,[F:IPM]LEG) From ATEXTRA
        [F:KPH]REF=TEXTE
      Endif

      #Filling CUR
      J=find(6,TYPVAL(1..NBVAR))
      If J<>0
        Local Char WCUR(LONREG(J)), WCURDEF(GLONCUR), WCURSOC(GLONCUR)
        Local Integer WTRANCUR
        For H=1 To NBLON
          If INIVAL(J)<LONHEA(H)
            Case H
              When 1:             WCUR=mid$(WREGH,INIVAL(J),LONREG(J))
              When NBLON        : WCUR=mid$(WREGF,INIVAL(J),LONREG(J))
              When Default      : WCUR=mid$(WREGHV(H),INIVAL(J),LONREG(J))
            Endcase
          Endif
        Next

       WCUR=vireblc(WCUR,4)
        If WCUR<>""
          If CONTAB(J)<>"0": WTRANCUR=1: WCURDEF=func TRANSCODE(WCUR,val(CONTAB(J))): Endif
          If WCURDEF="": WCURDEF=WCUR: Endif
          If WCURDEF<>""
            Read [TCU]TCU0=WCURDEF
            If fstat=[V]CST_AOK
              [F:KPH]CUR=WCURDEF
            Else    # Nonexistent currency
              Call ECR_TRACE(WCURDEF+":"-mess(151,105,1)+"."-mess(198,124,1)-num$(NBLIN)+".",1) From GESECRAN: GOK=0: Goto ERR_NEXT
            Endif
          Endif
        Endif

        Call GET_CUR(GACTX,1,[F:KPH]CPY,WCURSOC,WERR) From FINCUR_SYRA

        If [F:KPH]CUR=""
          [F:KPH]CUR=WCURSOC
        Endif

        If [F:KPH]CUR<>WCURSOC
          Local File TABCHANGE [TCH]
          Filter [TCH] Where CHGTYP=[F:IPM]NOLIB1(6) & CURDEN=WCURSOC & CUR=[F:KPH]CUR
          Read Last
          If fstat=[V]CST_AOK
            [F:KPH]CHGRAT=[F:TCH]CHGRAT
          Endif
          Filter [TCH]
          If [F:KPH]CHGRAT=0
            Filter [TCH] Where CHGTYP=1 & CURDEN=WCURSOC & CUR=[F:KPH]CUR
            Read Last
            If fstat=[V]CST_AOK
              [F:KPH]CHGRAT=[F:TCH]CHGRAT
            Endif
            Filter [TCH]
          Endif
          LogicClose File [TCH]
        Else
          [F:KPH]CHGRAT=1
        Endif
      Endif

     #filling DIE
      If WDSP=""
        J=find(7,TYPVAL(1..NBVAR))   #Dimension 1
        If J<>0
          Local Char WDIE(GLONCCE), WDIEREF(GLONCCE)
          Local Integer NBDIE
          DIME(0)=USEVAL2(J)
          For H=1 To NBLON
            If INIVAL(J)<LONHEA(H)
              Case H
                When 1            : WDIE=mid$(WREGH,INIVAL(J),LONREG(J))
                When NBLON        : WDIE=mid$(WREGF,INIVAL(J),LONREG(J))
                When Default      : WDIE=mid$(WREGHV(H),INIVAL(J),LONREG(J))
              Endcase
            Endif
          Next

          WDIE=vireblc(WDIE,4)

          If WDIE<>""
            If CONTAB(J)<>"0": WDIEREF=func TRANSCODE(WDIE,val(CONTAB(J))): Endif
            If WDIEREF="": WDIEREF=WDIE : Endif
            DIMCCE(0)=WDIEREF
          Endif

          If DIMCCE(0)<>""
            NBDIE=find(DIME(0),[F:CPY]DIE)
            If NBDIE<>0
              GDIE(NBDIE)=[F:CPY]DIE(NBDIE-1)
              Raz mkstat, GMESSAGE
              Call CTRL_CCE(DIMCCE(0),NBDIE,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
              If mkstat
                Call ECR_TRACE(mess(2,103,1)-DIME(0)+":"-GMESSAGE+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
                GOK=0: Goto ERR_NEXT
              Endif
            Endif
          Endif

        Endif

        J=find(8,TYPVAL(1..NBVAR))  #Dimension 2
        If J<>0
          Local Char WDIE(GLONCCE), WDIEREF(GLONCCE)
          DIME(1)=USEVAL2(J)
          For H=1 To NBLON
            If INIVAL(J)<LONHEA(H)
              Case H
                When 1            : WDIE=mid$(WREGH,INIVAL(J),LONREG(J))
                When NBLON        : WDIE=mid$(WREGF,INIVAL(J),LONREG(J))
                When Default      : WDIE=mid$(WREGHV(H),INIVAL(J),LONREG(J))
              Endcase
            Endif
          Next

          WDIE=vireblc(WDIE,4)

          If WDIE<>""
            If CONTAB(J)<>"0": WDIEREF=func TRANSCODE(WDIE,val(CONTAB(J))): Endif
            If WDIEREF="": WDIEREF=WDIE: Endif
            DIMCCE(1)=WDIEREF
          Endif

          If DIMCCE(1)<>""
            NBDIE=find(DIME(1),[F:CPY]DIE)
            If NBDIE<>0
              GDIE(NBDIE)=[F:CPY]DIE(NBDIE-1)
              Raz mkstat, GMESSAGE
              Call CTRL_CCE(DIMCCE(1),NBDIE,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
              If mkstat
                Call ECR_TRACE(mess(2,103,1)-DIME(1)+":"-GMESSAGE+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
                GOK=0: Goto ERR_NEXT
              Endif
            Endif
          Endif

        Endif

        J=find(9,TYPVAL(1..NBVAR))  #Dimension 3
        If J<>0
          Local Char WDIE(GLONCCE), WDIEREF(GLONCCE)
          DIME(2)=USEVAL2(J)
          For H=1 To NBLON
            If INIVAL(J)<LONHEA(H)
              Case H
                When 1            : WDIE=mid$(WREGH,INIVAL(J),LONREG(J))
                When NBLON        : WDIE=mid$(WREGF,INIVAL(J),LONREG(J))
                When Default      : WDIE=mid$(WREGHV(H),INIVAL(J),LONREG(J))
              Endcase
            Endif
          Next
          WDIE=vireblc(WDIE,4)

          If WDIE<>""
            If CONTAB(J)<>"0": WDIEREF=func TRANSCODE(WDIE,val(CONTAB(J))): Endif
            If WDIEREF="": WDIEREF=WDIE: Endif
            DIMCCE(2)=WDIEREF
          Endif

          If DIMCCE(2)<>""
            NBDIE=find(DIME(2),[F:CPY]DIE)
            If NBDIE<>0
              GDIE(NBDIE)=[F:CPY]DIE(NBDIE-1)
              Raz mkstat, GMESSAGE
              Call CTRL_CCE(DIMCCE(2),NBDIE,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
              If mkstat
                Call ECR_TRACE(mess(2,103,1)-DIME(2)+":"-GMESSAGE+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
                GOK=0: Goto ERR_NEXT
              Endif
            Endif
          Endif


        Endif

        J=find(10,TYPVAL(1..NBVAR))  #Dimension 4
        If J<>0
          Local Char WDIE(GLONCCE), WDIEREF(GLONCCE)
          DIME(3)=USEVAL2(J)
          For H=1 To NBLON
            If INIVAL(J)<LONHEA(H)
              Case H
                When 1            : WDIE=mid$(WREGH,INIVAL(J),LONREG(J))
                When NBLON        : WDIE=mid$(WREGF,INIVAL(J),LONREG(J))
                When Default      : WDIE=mid$(WREGHV(H),INIVAL(J),LONREG(J))
              Endcase
            Endif
          Next

          WDIE=vireblc(WDIE,4)

          If WDIE<>""
            If CONTAB(J)<>"0": WDIEREF=func TRANSCODE(WDIE,val(CONTAB(J))): Endif
            If WDIEREF="": WDIEREF=WDIE: Endif
            DIMCCE(3)=WDIEREF
          Endif

          If DIMCCE(3)<>""
            NBDIE=find(DIME(3),[F:CPY]DIE)
            If NBDIE<>0
              GDIE(NBDIE)=[F:CPY]DIE(NBDIE-1)
              Raz mkstat, GMESSAGE
              Call CTRL_CCE(DIMCCE(3),NBDIE,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
              If mkstat
                Call ECR_TRACE(mess(2,103,1)-DIME(3)+":"-GMESSAGE+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
                GOK=0: Goto ERR_NEXT
              Endif
            Endif
          Endif

        Endif

        J=find(11,TYPVAL(1..NBVAR))  #Dimension 5
        If J<>0
          Local Char WDIE(GLONCCE), WDIEREF(GLONCCE)
          DIME(4)=USEVAL2(J)
          For H=1 To NBLON
            If INIVAL(J)<LONHEA(H)
              Case H
                When 1            : WDIE=mid$(WREGH,INIVAL(J),LONREG(J))
                When NBLON        : WDIE=mid$(WREGF,INIVAL(J),LONREG(J))
                When Default      : WDIE=mid$(WREGHV(H),INIVAL(J),LONREG(J))
              Endcase
            Endif
          Next

          WDIE=vireblc(WDIE,4)

          If WDIE<>""
            If CONTAB(J)<>"0": WDIEREF=func TRANSCODE(WDIE,val(CONTAB(J))): Endif
            If WDIEREF="": WDIEREF=WDIE : Endif
            DIMCCE(4)=WDIEREF
          Endif

          If DIMCCE(4)<>""
            NBDIE=find(DIME(4),[F:CPY]DIE)
            If NBDIE<>0
              GDIE(NBDIE)=[F:CPY]DIE(NBDIE-1)
              Raz mkstat, GMESSAGE
              Call CTRL_CCE(DIMCCE(4),NBDIE,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
              If mkstat
                Call ECR_TRACE(mess(2,103,1)-DIME(4)+":"-GMESSAGE+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN
                GOK=0: Goto ERR_NEXT
              Endif
            Endif
          Endif
        Endif
      Endif

      [F:KPH]GTE=[F:IPM]TYP       #Filling Entry type (GTE)
      [F:KPH]COD=[F:IPM]COD       #Filling automatic journal (COD)
      [F:KPH]IMPFIL=FICORG        # File import name
      [F:KPH]ORIPAY=2             # Origin is MURANO
      [F:KPH]FLGDET=[F:IPM]FLGDET # Detail or global
      [F:KPH]CDE=[F:IPM]CCEDEF    # Default dimensions
      [F:KPH]FLGVAL=1             # Not validated
      [F:KPH]STA=1                # Not posted
      [F:KPH]STALOT=1             # Status

      #Filling COA
      Read [CPY]CPY0 = [F:KPH]CPY
      Read [GCM]GCM0 = [F:CPY]ACM
      For NBLED=0 To 9
        Read [LED]LED0 = [F:GCM]LED(NBLED)
        Read [COA]COA0 = [F:LED]COA
        If fstat=[V]CST_AOK and [F:GCM]CFMAUT(NBLED)=1
          WLED(NBLED)=[F:GCM]LED(NBLED)
          WCOA(NBLED)=[F:COA]COA
       Endif
      Next

      ##################
      # FILLING DETAIL #
      ##################
      Local Integer N, INIVAR, DKO, POS
      Local Decimal TOTDEB, TOTCRE, TOTAL

      For N=POSCON To NBVAR
        POS+=1
        If WACT(N)=2 and DKO<>2
          Raz [F:KPD], DKO
          Local Char WCAMT(80),DESCON(30), WACCCOD(GLONCAC),WDIE(GLONDIE)(20), WSEC(GLONCCE)

          For H=1 To NBLON
            #Filling AMTCUR
            If INIVAL(N)<LONHEA(H)
              Case H
                When 1:             WCAMT=mid$(WREGH,INIVAL(N),LONREG(N))
                When NBLON        : WCAMT=mid$(WREHF,INIVAL(N),LONREG(N))
                When Default      : WCAMT=mid$(WREGHV(H),INIVAL(N),LONREG(N))
              Endcase
            Endif
          Next

          If vireblc(WCAMT,1)<>""
            WCAMT=ctrans(WCAMT,",",".")
            If len(WFMT(N))>1 and val(WCAMT)<>0
              If instr(1,WCAMT,".")<> len(WCAMT)-(val(right$(WFMT(N),3)))
                Call ECR_TRACE( mess(190,104,1)+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN # Misplaced position of decimal separator
                DKO=2: Break
              Endif
            Endif
          Endif

          # If amount is zero the line is not created
          If  val(WCAMT)=0 : DKO=1: Endif

          If DKO=0
            [F:KPD]AMTCUR=val(WCAMT)
            [F:KPD]SNS=WSNS(N)
            If WSNS(N)=1: TOTDEB+=[F:KPD]AMTCUR: Else: TOTCRE+=[F:KPD]AMTCUR: Endif


            #Filling description
            [F:KPD]NARRATIVE=WDES(N)

            #Filling ACCs
            Local Integer NBACC, WOKANA, WTRKANA(10)
            For NBLED=0 To 9
              Read [CAC]CAC0=26;WACCODE(N);WCOA(NBLED)
              If fstat=[V]CST_AOK
                [F:KPD]COA(NBLED)=WCOA(NBLED)
                Local File GACCOUNT [GACX]
                Read [GACX]GAC0=[F:CAC]ACC
                If fstat=[V]CST_AOK
                  If [F:KPH]FLGDET=1 and [F:GAC]ACCSHO <>""
                    Call ECR_TRACE( mess(123,106,1)+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN # Control account not authorized
                    DKO=2: Break
                  Endif
                Endif
                Close File [GACX]
                [F:KPD]ACC(NBLED)=[F:CAC]ACC(0)
                [F:KPD]LED(NBLED)= WLED(NBLED)
                If [F:CAC]ACC(0)<>""
                  NBACC=1
                  Read [COA]COA0=[F:KPD]COA(NBLED)
                  If fstat=[V]CST_AOK and [F:COA]ANATRK=2
                    WOKANA=1
                    WTRKANA(NBLED)=1
                  Endif
                Endif
              Endif
            Next

            If NBACC=0: Call ECR_TRACE(mess(1108,196,1)-WACCODE(N)-mess(132,107,1)+"."-mess(198,124,1)-num$(NBLIN),-1) From GESECRAN : Endif  # Account not entered

            #Filling employee
            [F:KPD]EMPLOYEE=[F:KPH]BPRMURANO

            If WOKANA=1
              If WDSP<>""    # Analitycal allocation in BPS
                [F:KPD]DSP=WDSP
              Else
                Local Integer NBDIE, WOK
                #Filling CCEs

                For NBDIE=0 To dim([F:CPY]DIE)-1
                  Raz WSEC,  mkstat
                  If [F:CPY]DIE(NBDIE)="": Break: Endif
                  [F:KPD]DIE(NBDIE)= [F:CPY]DIE(NBDIE)
                  GDIE(NBDIE+1)=[F:CPY]DIE(NBDIE)
                  K=find([F:CPY]DIE(NBDIE),DIME)

                  If K<>0
                    If DIMCCE(K-1)<>""
                      Raz mkstat, GMESSAGE
                      Call CTRL_CCE(DIMCCE(K-1),NBDIE+1,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
                      If mkstat
                        Call ECR_TRACE(GMESSAGE+"."-mess(198,124,1)-num$(NBLIN)+" / "+num$(POS)+" - "+WDES(N),1) From GESECRAN: Raz DIMCCE(K-1)
                        DKO=2: Break 2
                      Else
                        [F:KPD]CCE(NBDIE)=DIMCCE(K-1)
                      Endif
                    Endif

                    #Searching in the default dimension of the line
                    If [F:KPD]CCE(NBDIE)=""
                      Local Integer NBCOA
                      For NBCOA=0 To dim(WCOA)-1
                        If WCOA(NBCOA)="" or WTRKANA(NBCOA)<>1: Break: Endif

                        Call INISEC(WSEC,WCCE(N),[F:KPD]DIE(NBDIE)) From SUBCDE

                        #Searching in the default dimension of the header
                        If WSEC=""
                          Call INISEC(WSEC,[F:KPH]CDE,[F:KPD]DIE(NBDIE)) From SUBCDE
                        Endif

                          #Searching the default analytical dimension of the account
                        If WSEC=""
                          Read [GAC]GAC0=WCOA(NBCOA);[F:KPD]ACC(NBCOA)
                          If fstat=[V]CST_AOK
                            J=find([F:KPD]DIE(NBDIE),[F:GAC]DIE)
                            If J<>0: WSEC=[F:GAC]CCEDEF(J-1) : Endif
                          Endif
                        Endif

                        # Control of the dimensions charged from default dimensions
                        If WSEC<>""
                          Raz mkstat, GMESSAGE
                          Call CTRL_CCE(WSEC,NBDIE+1,"",[F:KPH]FCY,[F:KPH]ACCDAT) From TRTX3CPT
                          If mkstat
                            Call ECR_TRACE(GMESSAGE+"."-mess(198,124,1)-num$(NBLIN)+" / "+num$(POS)+" - "+WDES(N),1) From GESECRAN
                            Raz [F:KPD]CCE(NBDIE)
                            DKO=2: Break 2
                          Endif
                        Endif

                        If WSEC<>"": Break: Endif

                      Next

                      If WSEC<>"": [F:KPD]CCE(NBDIE)=WSEC: Endif
                    Endif

                    If [F:KPD]CCE(NBDIE)<>""
                      Read [CCE]CCE0=[F:KPD]DIE(NBDIE);[F:KPD]CCE(NBDIE)
                      If fstat=[V]CST_AOK
                        If [F:CCE]ENAFLG<>2
                          WERR=[F:KPD]CCE(NBDIE)+":"-mess(1,8,1)-tolower(mess(36,103,1))+"."
                        Endif
                      Else
                        WERR=[F:KPD]CCE(NBDIE)+":"-mess(278,199,1)+"."
                      Endif
                      If WERR<>""
                        Call ECR_TRACE(WERR+"."-mess(198,124,1)-num$(NBLIN)+" / "+num$(POS)+" - "+WDES(N),1) From GESECRAN
                        Raz [F:KPD]CCE(NBDIE)
                        DKO=2: Break 2
                      Endif
                      Local Integer NBCOA, NBACT
                      For NBCOA=0 To dim(WCOA)-1
                        If WCOA(NBCOA)="" : Break: Endif
                        If WTRKANA(NBCOA)=1 and NBACT=0
                          Read [GAC]GAC0=[F:KPD]COA(NBCOA);[F:KPD]ACC(NBCOA)
                          If fstat=[V]CST_AOK
                            J=find([F:KPD]DIE(NBDIE),[F:GAC]DIE)
                            If J=0: Raz [F:KPD]CCE(NBDIE) : Else : NBACT=1: Endif
                          Endif
                        Endif
                      Next
                    Else
                      If [F:CPY]OBYDIE(NBDIE)=2
                        WERR= mess(2,103,1)- [F:KPD]DIE(NBDIE)+":"-mess(46,106,1)+"."-mess(36,103,1)-mess(42,9003,1)+"."-mess(198,124,1)-num$(NBLIN)+" / "+num$(POS)+" - "+WDES(N)
                        Call ECR_TRACE(WERR,1) From GESECRAN:  DKO=2: Break 2
                      Endif
                    Endif
                  Endif
                Next
              Endif
             Endif

            If [F:IPM]FLGDET=2
              [F:KPH]GRPGAS=[F:KPH]CUR+[F:KPH]LOT+num$(NBRECSOK)
            Else
              [F:KPH]GRPGAS=[F:KPH]CUR+[F:KPH]LOT
            Endif

            NBRECDET+=1
            [F:KPD]RECID    =[F:KPH]RECID
            [F:KPD]LINENO   =(NBRECDET)*1000
            [F:KPD]GRPGAS   =[F:KPH]GRPGAS
            [F:KPD]NUMMURANO=[F:KPH]NUMMURANO

            If DKO=0
              Write [KPD]
              If fstat : GOK=0 : Call FSTA("KPD") From GLOCK : Rollback: Break : Endif
              [F:KPA]=[F:KPD]
              [F:KPA]ANALIG=1
              Write [KPA]
            Else
              If NBRECDET>0: NBRECDET-=1: Endif
            Endif
          Endif
        Endif
      Next

      If DKO<>0: GOK=0
      Else
        GOK=1
        TOTAL=TOTDEB-TOTCRE
        If TOTAL<>0: Call ECR_TRACE(mess(32,109,1)-"<>"-mess(33,109,1)+"."-mess(16,170,1)+"."-mess(198,124,1)-num$(NBLIN),1) From GESECRAN : GOK=0: Endif # Unbalanced entry
        [F:KPH]TOT=TOTCRE
      Endif
    Endif

$ERR_NEXT

    If GOK=1
      Write [KPH]
      If fstat : GOK=0 : Call FSTA("KPH") From GLOCK : Rollback:  Endif
      NBRECSOK+=1
      RECOK(NBRECSOK)=[F:KPH]RECID
      Commit
    Else
      Rollback
    Endif

    #Reading the next record
    Rdseq WREGH Using [IMP]
    If dim(WREGHV)>0
      For K=0 To dim(WREGHV)
        Rdseq WREGHV(K) Using [IMP]
      Next
    Endif
    If dim(WREGHF)>0
      Rdseq WREGHF Using [IMP]
    Endif
  Wend

  adxium=SAVIUM
  adxirs=SAVIRS
  #Sending the results to the trace

Return

######################################################################################
## Section automatically added (screen IPMMURANO) 01/22/2016 12:06:47 (JUCON)
######################################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    Grizo ALLCPY
    Actzo CPY
    mkstat = 1 : End
  Endif
End

######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    Effzo [M]CPY,FCY : Diszo [M]CPY,FCY
    [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
  Else
    Actzo CPY,ALLFCY
  Endif
End

######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
  If [M]ALLCPY=2 : mkstat = 1 : Endif
End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
  If [M]ALLCPY<>2 and VALEUR="" : mkstat=1 : Endif
  If VALEUR<>""
    Filter [IPM] Where CPY=VALEUR or LEG=[F:CPY]LEG
    If rowcount([IPM])=0:  GMESSAGE=mess(195,104,1): mkstat=2 : Endif  # : Non-existing payroll setup for this company
    Filter [IPM]
  Endif
End

######################################################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
  If [M]ALLCPY=2 : VALEUR = 2 : Endif
  If VALEUR=2
    Effzo FCY : Grizo FCY
  Else
    Actzo FCY
  Endif
End

######################################################################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : Endif
End

######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
 If [M]ALLFCY=2 : mkstat = 1 : Endif
End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer WKO
  If [M]ALLFCY<>2 and VALEUR="" : mkstat=1 : Endif
  If VALEUR<>""
    WKO=1
    Filter [IPM] Where FCY=VALEUR
    If rowcount([IPM])>0:  WKO=0 : Endif
    Filter [IPM]
    Read [FCY]FCY0=VALEUR
    If fstat=[V]CST_AOK
      Filter [IPM] Where CPY=[F:FCY]LEGCPY and FCY=""
      If rowcount([IPM])>0:  WKO=0 : Endif
      Filter [IPM]
      If WKO=1
        Filter [IPM] Where LEG=[F:FCY]LEG and CPY="" and FCY=""
        If rowcount([IPM])>0:  WKO=0 : Endif
        Filter [IPM]
      Endif
    Endif
  Endif

  If WKO=1: GMESSAGE=mess(195,104,1): mkstat=2 : Endif #  Non-existing payroll setup for this site

End

######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
  If GBATCH & VALEUR=1
    GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
    mkstat = 2 : End
  Endif
End

######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

  Local Integer ASTATUS

  If VALEUR=1
    Raz [DIA]VOLFIL, [DIA]FICHIER
    Grizo [DIA]VOLFIL
  Else
    Actzo [DIA]VOLFIL
  Endif
  Affzo [DIA]VOLFIL

End

######################################################################################
Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
  GFICPATH = VALEUR
End

######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
  Local Integer ASTATUS

  #Control that the file exists :
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  If [M]TYPEXP=2
    ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FOLDER,GMESSAGE)
    If ASTATUS<>CST_AOK
      ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FILEREAD,GMESSAGE)
      If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
    Endif
  Else
    ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FILEREAD,GMESSAGE)
    If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
  Endif

  GFICPATH = [M]FICHIER

End

######################################################################################
Funprog NAMFICVOL(FICFUL,VOLFIC)
Value Char    FICFUL , VOLFIC

  Local Char    NAMFIC(250) , VOL(250), FIL(250)
  Local Integer I , J
  I = instr(1,VOLFIC,"[")
  J = instr(I,VOLFIC,"]")
  If I & J
    VOL = seg$(VOLFIC,I+1,J-1)
    FIL= seg$(VOLFIC,J+2,len(VOLFIC))
    Local File AVOLUME [AVL]
    Read [AVL]CODE=VOL
    If !fstat
      NAMFIC = filpath([F:AVL]ROOT,"","","")
      If find(right$(NAMFIC,len(NAMFIC)),"/","\")
        NAMFIC = NAMFIC+FIL
      Else
        If instr(1,NAMFIC,"\")>0: NAMFIC = NAMFIC+"\"+FIL: Endif
        If instr(1,NAMFIC,"/")>0: NAMFIC = NAMFIC+"/"+FIL: Endif
      Endif
    Endif
    Close Local File [AVL]
  Else
    NAMFIC = FICFUL
  Endif

End NAMFIC

######################################################################################
$PREP_VALUES
  Local Integer K, J, TOTHEA, TOTDET
  Raz NBVAR
  NBHEA=1: NBDET=1

  For K=0 To 10
    If [F:IPM]HEAVALNAM(K)=0: Break: Endif
    NBVAR+=1
    TYPVAL(K+1) =[F:IPM]HEAVALNAM(K)
    LONREG(K+1) =([F:IPM]HEAVALEND(K)-[F:IPM]HEAVALINI(K))+1
    INIVAL(K+1) =[F:IPM]HEAVALINI(K)
    If TYPVAL(K+1)>2 and TYPVAL(K+1)<6
      CONTAB(K+1)="0"
    Else
      CONTAB(K+1) =[F:IPM]HEAUSEVAL(K)
    Endif
    USEVAL(K+1) =[F:IPM]HEAUSEVAL(K)
    USEVAL2(K+1)=[F:IPM]HEAUSEVAL2(K)
    If TYPVAL(K+1)=1: CPYPOS=K+1 : WCPYPOS=[F:IPM]HEAVALINI(K): Endif
    If TYPVAL(K+1)=2: FCYPOS=K+1 : WFCYPOS=[F:IPM]HEAVALINI(K): Endif
    WACT(K+1)=2
    If TOTLON<[F:IPM]HEAVALEND(K): TOTLON=[F:IPM]HEAVALEND(K): Endif
  Next


  Filter [IPMD] Where CPY=[F:IPM]CPY & FCY=[F:IPM]FCY & LEG=[F:IPM]LEG
  For [IPMD]
    NBLINES+=1: NBVAR+=1
    If POSCON=0: POSCON=NBVAR: Endif
    TYPVAL(NBVAR) =12      #Type for the concept line
    LONREG(NBVAR) =([F:IPMD]ENDPOS-[F:IPMD]INIPOS)+1
    INIVAL(NBVAR) =[F:IPMD]INIPOS
    WACT(NBVAR)   =[F:IPMD]FLGACT
    WDES(NBVAR)   =[F:IPMD]CODDES
    WFMT(NBVAR)   =[F:IPMD]LENGHT
    WFMT=ctrans(WFMT,",",".")
    WACCODE(NBVAR)=[F:IPMD]ACCCOD
    WCCE(NBVAR)   =[F:IPMD]CCEDEFL
    If [F:IPMD]SENSE=1
      WSNS(NBVAR)=[F:IPMD]SENSE
    Else
      WSNS(NBVAR)=-1
    Endif
    If TOTLON<[F:IPMD]ENDPOS: TOTLON=[F:IPMD]ENDPOS: Endif
  Next

  Filter [IPMD]

  If TOTLON>250
    Local Integer NBINI. LIN: NBINI=1:
    NBLON=int(TOTLON/250)
    For J=0 To NBLON-1
      LIN=J+1
      For K=NBINI To NBVAR
        If INIVAL(K)> LIN*250 #and INIVAL(K)+LONREG(K)>J*250:  X3-74048
         LONHEA(LIN)=INIVAL(K)-1: NBINI=K :Goto NEXT_J
        Endif #X3-74048
      Next
      $NEXT_J
      If LIN=1: Local Char WREGH(LONHEA(LIN))
      Elsif NBLON>1 and J=NBLON
        Local Char WREGHV(LONHEA(LIN)-LONHEA(LIN-1))(1..NBLON)
      Endif
      J+=1
    Next
#    Local Char WREGHF(TOTLON-sum(LONHEA(1..J))+2)  X3-74048
    Local Char WREGHF(TOTLON-sum(LONHEA(1..LIN)))
    NBLON+=1
  Else
    NBLON=1
    LONHEA=250
    Local Char WREGH(LONHEA)
  Endif

Return

######################################################################################
$CONTROL_SITE
  Raz REALFCY, REALCPY
  If CPYPOS<>0
    Local Char WSOC(LONREG(CPYPOS))
    For J=1 To NBLON
      If WCPYPOS<LONHEA(J)
        Case J
          When 1            : WSOC=mid$(WREGH,INIVAL(CPYPOS),LONREG(CPYPOS))
          When NBLON        : WSOC=mid$(WREGF,INIVAL(CPYPOS),LONREG(CPYPOS))
          When Default      : WSOC=mid$(WREGHV(J),INIVAL(CPYPOS),LONREG(CPYPOS))
        Endcase
      Endif
    Next

    WSOC=vireblc(WSOC,1)
    If WSOC<>""
      If CONTAB(CPYPOS)<>"0": REALCPY=func TRANSCODE(WSOC,val(CONTAB(CPYPOS))): Endif
    Endif
    If REALCPY="": REALCPY=WSOC: Endif
    Raz WSOC
  Endif

  If FCYPOS<>0
    Local Char WSITE(LONREG(FCYPOS))
    For J=1 To NBLON
      If WFCYPOS<LONHEA(J)
        Case J
          When 1          : WSITE=mid$(WREGH,INIVAL(FCYPOS),LONREG(FCYPOS))
          When NBLON      : WSITE=mid$(WREGF,INIVAL(FCYPOS),LONREG(FCYPOS))
          When Default    : WSITE=mid$(WREGHV(J),INIVAL(FCYPOS),LONREG(FCYPOS))
        Endcase
      Endif
    Next
  Endif

  WSITE=vireblc(WSITE,1)
  If WSITE<>""
    If CONTAB(FCYPOS)<>"0": REALFCY=func TRANSCODE(WSITE,val(CONTAB(FCYPOS))):  Endif
    If REALFCY="":  REALFCY=WSITE: Endif
    Raz WSITE
  Endif

  If REALCPY<>"" and REALFCY=""
    Read [CPY]CPY0=REALCPY
    If fstat=[V]CST_AOK
      REALFCY=[F:CPY]MAIFCY
    Endif
  Endif

  If REALFCY<>"" and REALCPY=""
    Read [FCY]FCY0=REALFCY
    If fstat=[V]CST_AOK
      REALCPY=[F:FCY]LEGCPY
    Endif
  Endif

  If REALFCY<>SELFCY(I) or REALCPY<>SELCPY(I): OKK=1:  Endif

  If FCYPOS=0 and CPYPOS=0: OKK=1 : Endif
  If OKK=1: NBRECKO+=1: Endif

Return

#############################################################
Funprog TRANSCODE(WFLD,WTAB)
Value Char WFLD
Value Integer WTAB
  Local Char WVAL(20)
  Local File AOBJEXTR [AOR]

  Filter [AOR] Where NUMTAB=WTAB and CODEXT=WFLD
  Read First
  If fstat=[V]CST_AOK
    WVAL=[F:AOR]CODLOC
  Endif
  LogicClose File [AOR]

End WVAL

######################################################################################
Funprog TRANSDATE(WDAT,WTYP)
Value Char WDAT
Value Integer WTYP
  Local Integer OPTDAT, WER
  Local Date WDATE

  Case WTYP
    When 1 : OPTDAT=4
    When 2 : OPTDAT=3
    When 3 : OPTDAT=2
    When 4 : OPTDAT=1
    When 5 : OPTDAT=4: WDAT=vireblc(ctrans(WDAT,"-",""),4)
    When 6 : OPTDAT=3: WDAT=vireblc(ctrans(WDAT,"-",""),4)
    When 7 : OPTDAT=2: WDAT=vireblc(ctrans(WDAT,"-",""),4)
    When 8 : OPTDAT=1: WDAT=vireblc(ctrans(WDAT,"-",""),4)
    When 9 : OPTDAT=2: WDAT=seg$(WDAT,3,4)+seg$(WDAT,1,2)+seg$(WDAT,5,8)
    When 10: OPTDAT=1: WDAT=seg$(WDAT,3,4)+seg$(WDAT,1,2)+seg$(WDAT,5,6)
    When 11: OPTDAT=2: WDAT=vireblc(ctrans(WDAT,"-",""),4): WDAT=seg$(WDAT,3,4)+seg$(WDAT,1,2)+seg$(WDAT,5,8)
    When 12: OPTDAT=1: WDAT=vireblc(ctrans(WDAT,"-",""),4): WDAT=seg$(WDAT,3,4)+seg$(WDAT,1,2)+seg$(WDAT,5,6)
  Endcase

  Call SETDATE(WDATE,WDAT,OPTDAT,WER) From SUBIMPOBJ

End WDATE

######################################################################################

