#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque ITGSTA
# Saisie des statuts autorisés en tableau    SUBISTA  JUIN 2002

$ACTION
Return

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:ISTA]STA(0..[M:ISTA]NBSTA-1)) From OBJDIV
If mkstat End Endif

If left$(VALEUR,1)="*" |left$(VALEUR,1)="?" | left$(VALEUR,1)="!" | left$(VALEUR,1)="#"
  mkstat = 2
  GMESSAGE = mess(357,199,1) #"Valeur non autorisée" car ctrl A,Q,R impossible!
  End
Endif

If !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?") & !instr(1,VALEUR,"!") & !instr(1,VALEUR,"#")
  Look [TST]TST0=VALEUR
  If fstat
    GMESSAGE=mess(23,100,1)
    mkstat=2
  Endif
Endif
End

############################################################
# Elimination sous statuts non autorisés et
# tri de la table des statuts
$TRI_STATUTS
Local Integer I : I = 0
Local Integer A : A = 0
Local Integer Q : Q = 0
Local Integer R : R = 0
Local Integer J, SUP

Local Integer AUZ_STA
If GFONCTION = "GESITG"
  # FGR 15/01/2010 : X3SUIVI60986
  #AUZ_STA = [M:ITG4]AUZSTA(GLIG)
  AUZ_STA = [M:ITG4]AUZSTAS(GLIG)
Elsif GFONCTION = "FUNSTORUL"
  AUZ_STA = [M:SRU1]AUZSTA(GLIG)
# >> utilisable aussi pour les types emplacements 140
Else
  AUZ_STA = [M]AUZSTA(GLIG)
Endif

If find(AUZ_STA,1,3,5,7)
   A = 1
Endif
If find(AUZ_STA,2,3,6,7)
   Q = 1
Endif
If find(AUZ_STA,4,5,6,7)
   R = 1
Endif
While I <> [M:ISTA]NBSTA
  If (left$([M:ISTA]STA(I),1) = "A" & A = 0)|
&    (left$([M:ISTA]STA(I),1) = "Q" & Q = 0)|
&    (left$([M:ISTA]STA(I),1) = "R" & R = 0)
      For J = I To [M:ISTA]NBSTA-1
        [M:ISTA]STA(J) = [M:ISTA]STA(J+1)
      Next J
      [M:ISTA]NBSTA -= 1
      [M:ISTA]STA([M:ISTA]NBSTA) = ""
      SUP = 1 # un au moins a été supprimé
  Else
      I += 1
  Endif
Wend
Sorta [M:ISTA]NBSTA [M:ISTA]STA Order By [M:ISTA]STA(indice)
If SUP
  GERR = 2
  GMESSAGE = mess(358,199,1) #Les valeurs non autorisées ont été supprimées !
Endif
#If !GIMPORT
#  Affzo [M:ISTA]20
#Endif
Return

########################################
Subprog AV_STAAXX(VALEUR)
Variable Char    VALEUR()
Read [TST]TST0=[M]STA(nolign-1)
If fstat = 0
  # FGR 15/01/2010 : X3SUIVI60986
  #Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,VALEUR) From TXTX3TEX
  Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,VALEUR) From TRTX3TEX
Else
  VALEUR = ""
Endif
End

