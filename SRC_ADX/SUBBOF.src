############################################################
# Fusion de nomenclature : gestion ecran BOMFUS0
############################################################

$ACTION
Return

Subprog C_ITMSEL(VALEUR)
Variable Char     VALEUR
If VALEUR = [M:BOH0]ITMREF & [M:DIA]ALTFUS = [M:BOH0]BOMALT
   mkstat = 2
Endif
End

Subprog C_ALTFUS(VALEUR)
Variable Decimal  VALEUR
Local Char WSUPP
Local Char ALTALP
If clalev ([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif
Read [F:TBO]TBO0 = [M:BOH0]BOMALTTYP;VALEUR
If fstat : GMESSAGE = mess(23,100,1)
           mkstat = 2
           End
Endif  
If [M:DIA]ITMSEL = [M:BOH0]ITMREF & VALEUR = [M:BOH0]BOMALT
   mkstat = 2 : End
Endif
ALTALP = num$(VALEUR)
WSUPP = [M:DIA]ITMSEL + "~" + num$([F:TBO]BOMALTTYP)
Call CONTROLE("BOD","",ALTALP,WSUPP,mkstat) From CONTOBJ
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BOMFUS0) 31/03/2006 15:46:25 (SR)
######################################################################################
Subprog S_ITMSEL(VALEUR)
Variable Char    VALEUR()
If status = 7 : End : Endif
Read [F:BOH]BOH0 Curr
If !fstat [M:DIA]ALTFUS = [F:BOH]BOMALT : Affzo [M:DIA]ALTFUS  : Endif
End

End


######################################################################################

