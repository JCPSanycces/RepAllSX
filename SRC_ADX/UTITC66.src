#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# Created by : RMA
# Date       : 12/11/2014
# Tool for feeding the RECTYP and SAFTTRNTYP in table TABSDHTYP
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC66: QAV7.1 P7 : Default values for RECTYP and SAFTTRNTYP on TABSDHTYP") From LECFIC
  Call EXE_UTITC66(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog EXE_UTITC66(APPLI)
Value Char APPLI

If clalev([F:TSD]) : Close Local File [TSD] : Endif
Local File =APPLI+".TABSDHTYP" [TSD]

Call ECR_TRACE("UTITC66: Process Start on : "+APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC66
Call ECR_TRACE("UTITC66: Process End on : "+APPLI,0) From GESECRAN

End
########################################
#### Tool - Begin                   ####
########################################
$TR_UTITC66

Local Shortint DO_SAFTTRNTYP : DO_SAFTTRNTYP = 0
Local Shortint DO_RECTYP     : DO_RECTYP     = 0
Local Shortint DO_DATUPDFLG  : DO_DATUPDFLG  = 0
Local Shortint RUPD          : RUPD          = 0

If dim([F:TSD]RECTYP) > 0
  DO_RECTYP = 1
Endif

If dim([F:TSD]SAFTTRNTYP) > 0
  DO_SAFTTRNTYP = 1
Endif

If dim([F:TSD]DATUPDFLG) > 0
  DO_DATUPDFLG = 1
Endif

For [F:TSD]
  RUPD = 0
  If DO_RECTYP = 1
    If [F:TSD]RECTYP = 0
      [F:TSD]RECTYP = 1
      RUPD          = 1
      Call ECR_TRACE([F:TSD]SDHTYP + ":RECTYP updated with"-mess([F:TSD]RECTYP,2029,1), 0) From GESECRAN
    Endif
  Endif
  If DO_SAFTTRNTYP > 0
    If [F:TSD]SAFTTRNTYP = 0
      [F:TSD]SAFTTRNTYP = 1
      RUPD = 1
      Call ECR_TRACE([F:TSD]SDHTYP + ":SAFTTRNTYP updated with"-mess([F:TSD]SAFTTRNTYP,2046,1), 0) From GESECRAN
    Endif
  Endif
  If DO_DATUPDFLG = 1
    If [F:TSD]DATUPDFLG = 0
      [F:TSD]DATUPDFLG = 1
      RUPD          = 1
      Call ECR_TRACE([F:TSD]SDHTYP + ":DATUPDFLG updated with"-mess([F:TSD]DATUPDFLG,1,1), 0) From GESECRAN
    Endif
  Endif
  If RUPD = 1
    Trbegin [F:TSD]
    Rewrite [F:TSD]
    If fstat
      Rollback
      Break
    Endif
    Commit
  Endif
Next

Return
########################################
#### Tool - End                   ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSDHTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC66(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier to update
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSDHTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC66(APPLI)
End
