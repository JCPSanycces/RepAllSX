#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("SXH",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Masse salariale: Transaction hypothèses sortie (Objet SXH)18/03/2009 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "INIMOD"    : Gosub INIMOD
 When "INICRE"    : Gosub INICRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "ANNULE"    : Gosub ANNULE
 When "FERME"     : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:MH])=0  : Local File MSXITEML [MH]  : Endif
Local Integer LDICO , LVRA
Local Integer LMS , MSJ , MOK
Local Char NOMWIN(10) , APPLI(GLONADS)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$SETBOUT
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
# Transaction transaction inactive
If [M]ENAFLG<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
 When "V" : APPLI=nomap(0) : Gosub GENERAWI
 When Default
Endcase
Return

$RAZCRE
[M]ENAFLG=2
Return

$LIENS
LDICO = 1
LVRA  = 1
Raz GFLDMS
Raz GVRAMS
#On charge les champs/variables de la transaction
For [F:SXD]SXD0 Where COD=[F:SXH]COD
 Case [F:SXD]ORIFLD
  When 1 #champ salarié
   If LDICO > dim(GFLDMS)
    GMESSAGE=mess(26,100,1)- num$(LDICO) : #Tableau plein
    Break
   Endif
   nolign=LDICO
   [M:SXH1]FLD(nolign-1)=[F:SXD]FLD
   [M:SXH1]TIT(nolign-1)=[F:SXD]TIT
   [M:SXH1]ORIFLD(nolign-1)=[F:SXD]ORIFLD
   GFLDMS(LDICO,0) = [F:SXD]FLD
   LDICO+=1
  When 2 #variable salarié
   If LVRA > dim(GVRAMS)
    GMESSAGE=mess(26,100,1)- num$(LVRA) : #Tableau plein
    Break
   Endif
   nolign=LVRA
   [M:SXH2]VRA(nolign-1)=[F:SXD]FLD
   [M:SXH2]TIT(nolign-1)=[F:SXD]TIT
   [M:SXH2]ORIFLD(nolign-1)=[F:SXD]ORIFLD
   GVRAMS(LVRA,0) = [F:SXD]FLD
   LVRA+=1
  When Default
 Endcase
Next
[M]NBDICO=LDICO-1
[M]NBVRA =LVRA-1
Return

$VERIF_MOD
MSJ=1
#On vérifie si il y a eu des suppressions de champs ou de variables
For LMS=1 To dim(GFLDMS)
 #57165
 #MSJ = find(GFLDMS(LMS,0),[M:SXH1]FLD(0..[M:SXH1]NBDICO))
 MSJ = find(GFLDMS(LMS,0),[M:SXH1]FLD(0..[M:SXH1]NBDICO-1))
 If !MSJ : Break : Endif
Next
If MSJ
 For LMS=1 To dim(GVRAMS)
  #57165
  #MSJ = find(GVRAMS(LMS,0),[M:SXH2]VRA(0..[M:SXH2]NBVRA))
  MSJ = find(GVRAMS(LMS,0),[M:SXH2]VRA(0..[M:SXH2]NBVRA-1))
  If !MSJ : Break : Endif
 Next
Endif
If !MSJ
#c'est le cas, on vérifie s'il existe une hypothèse pour cette transaction
 Read [F:MH]MHX1=[M:SXH0]COD
 If !fstat #on averti
  MOK=2
  #Les colonnes supprimées vont être supprimées dans les hypothèses de cette transaction
  Call AVERTIR(mess(8,10722,1),MOK) From GESECRAN
  If MOK = 1
   OK=0
  Endif
 Endif
Endif
If [F:SXH]ENAFLG = 2 & [M:SXH0]ENAFLG = 1
[F:SXH]ENAFLG = 1
 APPLI=nomap(0)
 Gosub GENERAWI
Endif
Return

$INIMOD
$INICRE
Delete [F:SXD] Where COD=[F:SXH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHXD" : Return
Endif
Raz GFLDMS
Raz GVRAMS
#champs salarié
For LMS=1 To [M:SXH1]NBDICO
 nolign=LMS
 Raz [F:SXD]
 [F:SXD]=[M:SXH0]
 [M:SXH1]TIT(nolign-1)=[M:SXH1]ZFLD(nolign-1) #On récupère l'intitulé long
 [F:SXD]=[M:SXH1]
 [F:SXD]LIG=LMS
 Write [F:SXD]
 If fstat<>0
  GOK = 0 : Call FSTA("SXD") From GLOCK : Break
 Endif
 GFLDMS(LMS,0) = [F:SXD]FLD
Next
#Variables salarié
If !GOK : Goto FININI : Endif
For LMS=1 To [M]NBVRA
 nolign=LMS
 Raz [F:SXD]
 [F:SXD]=[M:SXH0]
 [M:SXH2]TIT(nolign-1)=[M:SXH2]ZVRA(nolign-1) #On récupère l'intitulé long
 [F:SXD]FLD=[M:SXH2]VRA(nolign-1)
 [F:SXD]TIT=[M:SXH2]TIT(nolign-1)
 [F:SXD]ORIFLD=[M:SXH2]ORIFLD(nolign-1)
 [F:SXD]LIG=LMS+[M:SXH1]NBDICO
 Write [F:SXD]
 If fstat<>0
  GOK = 0 : Call FSTA("SXD") From GLOCK : Break
 Endif
 GVRAMS(LMS,0) = [F:SXD]FLD
Next
If !GOK : Goto FININI : Endif
#Maj des hypothèses...
Gosub MAJHYP From SUBSEH2
FININI
Return

$ANNULE
# Annulation de la fenêtre et des traitements associés
NOMWIN = "WFMHX"+[M:SXH0]COD
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Delete [F:SXD] Where COD=[F:SXH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHXD" : Return
Endif
Return

$GENERAWI
Call GENECR(APPLI,"MHX",[F:SXH]COD,[F:SXH]ENAFLG,[F:SXH]CODACS,[F:SXH]CODACT,[F:SXH]DES) From SUBSEH2
Return

########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCRMHXH [SXH1]
 Local File SCRMHXD [SXD1]
Else
 Local File =[M]DOSORG+".SCRMHXH" [SXH1]
 Local File =[M]DOSORG+".SCRMHXD" [SXD1]
Endif
If [M]DOSDES=nomap
 Local File SCRMHXH [SXH2]
 Local File SCRMHXD [SXD2]
Else
 Local File =[M]DOSDES+".SCRMHXH" [SXH2]
 Local File =[M]DOSDES+".SCRMHXD" [SXD2]
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [SXH1], [SXH2],[SXD1],[SXD2]
Return

$TR_COP
GOK = 1
Trbegin [SXH2],[SXD2]
 Delete [SXH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHXH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SXH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [SXD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHXD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SXHD","") From GLOCK : Goto AB_TR_COP
 Endif
 #Entete
 Read[SXH1]SXH0=TABLE
 If !fstat
  [F:SXH2] = [F:SXH1]
  If dim([F:SXH2]CREUSR)>0 : [F:SXH2]CREUSR = GUSER : Endif
  If dim([F:SXH2]CREDAT)>0 : [F:SXH2]CREDAT = date$ : Endif
  If dim([F:SXH2]CRETIM)>0 : [F:SXH2]CRETIM = time : Endif
  If dim([F:SXH2]UPDUSR)>0 : Raz [F:SXH2]UPDUSR  : Endif
  If dim([F:SXH2]UPDDAT)>0 : Raz [F:SXH2]UPDDAT  : Endif
  If dim([F:SXH2]UPDTIM)>0 : Raz [F:SXH2]UPDTIM  : Endif
  Write [SXH2]
  If fstat
   GOK = 0 : Call FSTA("SXH2") From GLOCK : Return
  Endif
  #Lignes
  For [SXD1]SXD0 Where COD=[F:SXH1]COD
   [SXD2]=[SXD1]
   Write [SXD2]
   If fstat
    GOK = 0 : Call FSTA("SXD2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

Subprog GENDOS(APPLI)
#Génération en masse
Value Char APPLI()
If clalev([F:SXH])=0  : Local File =APPLI+".SCRMHXH"    [SXH]  : Endif
If clalev([F:SXD])=0  : Local File =APPLI+".SCRMHXD"    [SXD]  : Endif
For [SXH]SXH0 Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:SXH]COD,0) From GESECRAN : Endif
  Gosub GENERAWI
 If GOK=0 : Break : Endif
Next
End
######################################################################################
######################################################################################

Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_FLD(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

Subprog AM_VRA(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_VRA(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

######################################################################################
