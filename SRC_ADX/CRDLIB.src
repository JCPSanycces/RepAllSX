Variable Decimal ASW()
Value    Char    QSTNUM
Value    Char    FLD
#
Assign "[M]FLD"+right$(FLD,4) With ASW
#
If ASW <> 0
  Assign "[M]OBS"+right$(FLD,4) With ""
Elsif evalue("[M]STD"+right$(FLD,4)) <> "."    : # Bug 28399 - TS
  Assign "[M]OBS"+right$(FLD,4) With ""        : # Bug 28399 - TS
Else
  Assign "[M]OBS"+right$(FLD,4) With "->"
Endif
Affzo ="OBS"+right$(FLD,4)
End
