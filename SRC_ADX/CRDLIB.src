If ASW = 0 & evalue("[M]STD"+right$(FLD,4))="."
#  Read [QLQ]QLQ0=QSTNUM  # hcb V6CQ
  If fstat = 0
    ASW = [F:QLQ]NUMDEFASW
  Endif
Endif
GERR = 4    # hcb V6CQ
GMESSAGE = UOM_ATABZON-":"-[F:QLQ]UOM-UOMDEC_ATABZON-":"-num$([F:QLQ]UOMDEC)-NUMNMN_ATABZON-":"-num$([F:QLQ]NUMNMNVAL)
End
