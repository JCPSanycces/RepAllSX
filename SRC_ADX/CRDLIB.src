############################################################
# Effacement masques et fenetres d'un fiche qualite
Subprog DELCRD(LAPP,LREF,LWRE,LFIC)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LWRE
Value    Char    LFIC
#
If clalev([F:ADS1])= 0 : Local File ADOSSIER           [ADS1]  : Endif
If clalev([F:QLC]) = 0 : Local File =LAPP+".QLYCRD"    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File =LAPP+".QLYCRDQST" [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File =LAPP+".TABCTL"    [TCT]   : Endif
If clalev([F:AMK1])= 0 : Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 : Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 : Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 : Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 : Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 : Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 : Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 : Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 : Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 : Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 : Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 : Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 : Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 : Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 : Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 : Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
If clalev([F:AWI1])= 0 : Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
#
Local    Char    W_MSK
Local    Char    W_ONG
Local    Char    W_SEQ(05)
Local    Integer W_I
Local    Char    W_ABR(15) : W_ABR = "ABCDEFGHIJKLMNO"
#
GOK=1  # FQ 68372 GA 10/2010

# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call RSTA("ADS1",LAPP) From GLOCK
  Goto DELCRD_FIN
Endif
#
#                                     # hcb 105126 deb
#Read [QLC]QLC0=LFIC;1
#If fstat
#  GOK = 0
#  Call FSTA("QLC") From GLOCK
#  Goto DELCRD_FIN
#Endif
Filter [QLC] Where QLYCRD = LFIC
   Look [QLC]QLC0 First
   If fstat
      GOK = 0
      Call FSTA("QLC") From GLOCK
      Goto DELCRD_FIN
   Else
      Read [QLC] Curr
   Endif
Filter [QLC]
#                                     # hcb 105126 deb
#
# FQ 68372 GA 10/2010 pb de volume
Gosub CHARG_MSK
If !GOK End Endif
#
# Effacement ancien masque
#
For W_I = 1 To dim([F:AMK1]TYPBLOC)
  W_ONG = W_MSK+mid$(W_ABR,W_I,1)
  Read [AMK2]CODMSK = W_ONG
  If fstat = 0
    Call DELMSK(W_ONG,LAPP) From MSKDIV
  Endif
Next W_I
# Effacement fenetre
Read [AWI1]AWI0=W_MSK
If fstat = 0
  Call DELWIN(W_MSK,LAPP) From MSKDIV
Endif
$DELCRD_FIN
End
############################################################
# Fenetre de selection contenu des tables de controle
############################################################
$SELTCTCRD
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]  : Endif
#
Local Char    WTCT(GLONTCT)  : WTCT = PARAM(1)
Local Char    WFIL(250) : WFIL = ""
Local Char    WALPCOD
Local Decimal WNUMCOD
Local Char    WCOL(30) : WCOL = "DESCOD"   # FQ 70242 GA 05/2011 lire la désignation dans la bonne langue
#
Read [TCT]TCT0=WTCT
If fstat
  Raz [F:TCT]
Endif
#TIT(0) = [F:TCT]TCTDES  # FQ 53410 V6 GA 03/2009 Texte traduit CRPOP # FQ 54568 [F:CQU]TCT devient WTCT
Call LECTEXTRA(TIT(0),"TABCTL","TCTDESAXX",WTCT,"") From ATEXTRA
#
Case [F:TCT]TCTTYP
  When 2 :
    WNUMCOD  = VALEUR
    EXPSTART = "[F:TCT]NUMCOD >= WNUMCOD"
    NBCOL += 1 : COL(NBCOL) = "NUMCOD"
    Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  When Default :
    WALPCOD  = VALEUR
    EXPSTART = "[F:TCT]ALPCOD >= WALPCOD"
    NBCOL += 1 : COL(NBCOL) = "ALPCOD"
    Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endcase
# FQ 70242 GA 05/2011 lire la désignation dans la bonne langue
If dim([F:TCT]LANNBR) > 0
  For W_I = 0 To dim([F:TCT]LAN)-1
    If GLANGUE = [F:TCT]LAN(W_I)
      If W_I
         WCOL = "DESCOD"+num$(W_I)
      Else
         WCOL = "DESCOD"
      Endif
      Break
    Endif
  Next W_I
Endif
NBCOL += 1 : COL(NBCOL) = WCOL
Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#
Raz [F:TCT]
ORDRE   = ""
#MAE, bg 47058
#CRITERE = "[F:TCT]TCT=WTCT"
CRITERE = "[F:TCT]TCT ='"+WTCT+"'"
# Si filtre sur valeurs
#
SIZLIG = 100
SIZCOL = 120
Default File [TCT]
#MAE, bg 47058, ajout de la pagination
DEFPAG=1
Return
############################################################
# Sous programme de chargement des reponses deja saisies
# LFIC  = Numero fiche qualite
# LDEM  = Demande d'analyse
# LSEQ  = Numero de sequence de la fiche lue et chargee
#
Subprog LECFIC(LFIC,LDEM,LLIN,LSEQ, LLECFIC)
Value    Char    LFIC
Value    Char    LDEM
Value    Integer LLIN
Variable Decimal LSEQ
Variable Integer LLECFIC
Local    Integer WNBQST
#
Local Integer W_I
Local Integer LNBQST : LNBQST = func LASTQST
If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
#-- Question
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
#-- Réponses
If clalev([F:QLA]) = 0 : Local File QLYCRDASW [QLA]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
If clalev([F:AMZ]) = 0 : Local File AMSKZON   [AMZ]   : Endif
#

For [QLC]QLC0 Where QLYCRD=LFIC
  If [F:QLC]QSTNUM<>""
    WNBQST+=1
    If evalue("dim([M]RPF"+format$("N0:3#",WNBQST)+")>0")              # hcb V6CQ
       Assign "[M]RPF"+format$("N0:3#",WNBQST) With [F:QLC]RPLQLYCRD   # hcb V6CQ
    Endif                                                              # hcb V6CQ
  Endif
Next

Read [QLC]QLC0=LFIC
If fstat=0
  For W_I=1 To LNBQST
    If evalue("dim([M]STD"+format$("N0:3#",W_I)+")>0")
       Assign "[M]STD"+format$("N0:3#",W_I) With "."
    Endif
  Next
  Filter [QLA] Where QLYCTLDEM = LDEM
&                  & VCRLIN    = LLIN
&                  & CRDSEQ    = LSEQ
&              Order By Key QLA0
  For [QLA]
    #LLECFIC=1
    For W_I=1 To LNBQST
      If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"=[F:QLA]QSTNUM")
        If evalue("dim([M]FLD"+format$("N0:3#",W_I)+")>0")
          Case evalue("[M]TYP"+format$("N0:3#",W_I))
            When 1,7 :  # Issue 122257 - 2017-05-04 by MAE : Ajout du type clob
              Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA]ALPASW
              WNBQST-=1
            When 2 :
              Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA]NUMASW
              WNBQST-=1
            When 3 :
              Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA]DATASW
              WNBQST-=1
            When 4 :
              Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA]NUMASW+1
              WNBQST-=1
          Endcase
          If [F:QLA]OSDASW = 2
            Assign "[M]STD"+format$("N0:3#",W_I) With mess(508,197,1)   # hors standard
            If [F:QLA]RPLQLYCRD <> "" & evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0") # hcb V6CQ
               Assign "[M]RPL"+format$("N0:3#",W_I) With [F:QLA]RPLQLYCRD               # hcb V6CQ
            Endif
          Else
            Assign "[M]STD"+format$("N0:3#",W_I) With ""
          Endif
          Break
        Endif
      Endif
#     hcb V6CQ le diszo évalué ne marche pas ..........donc je passe par une rubrique FLGxxx
#              que est testée en avant saisie de RLPxxx pour desactivée cette dernière
      If evalue("dim([M]FLG"+format$("N0:3#",W_I)+")>0")  # hcb V6CQ
         Assign "[M]FLG"+format$("N0:3#",W_I) With 0      # hcb V6CQ
      Endif
      GPOINT = "LECFIC"                # hcb 108856
      Gosub ENTREE From EXEFNC
    Next
  Next
  Filter [QLA]
  If WNBQST=0 : LLECFIC=1 : Endif
  Gosub AFF_LIB
Endif
End

############################################################
# Sous programme de chargement des reponses deja saisies GPAO
# LFIC  = Numero fiche qualite
# LSEQ  = Numero de sequence de la fiche lue et chargee
#
Subprog LECFIC2(LFIC,LLIN,LVCR,LLECFIC)
Value    Char    LFIC
Value    Integer LLIN
Value    Char    LVCR
Variable Integer LLECFIC
Local    Integer WNBQST
#
Local  Integer W_I
Local Integer LNBQST : LNBQST = func LASTQST

If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
If clalev([F:AMZ]) = 0 : Local File AMSKZON   [AMZ]   : Endif
If GREP = "C" | GFONC1 = "FUNBENCHO"
    If clalev([F:QLA1])<= 0 : Local File QLYWRK [QLA1] : Endif
Else
    If clalev([F:QLA1])<= 0 : Local File MTKCRDASW [QLA1] : Endif
Endif
#
For [QLC]QLC0 Where QLYCRD=LFIC
  If [F:QLC]QSTNUM<>""
    WNBQST+=1
    If evalue("dim([M]RPF"+format$("N0:3#",WNBQST)+")>0")              # hcb V6CQ
       Assign "[M]RPF"+format$("N0:3#",WNBQST) With [F:QLC]RPLQLYCRD   # hcb V6CQ
    Endif                                                              # hcb V6CQ
  Endif
Next
Read [QLC]QLC0=LFIC
If fstat = 0
    For W_I=1 To LNBQST
      If evalue("dim([M]STD"+format$("N0:3#",W_I)+")>0")
          Assign "[M]STD"+format$("N0:3#",W_I) With "."
      Endif
    Next
    If GREP = "C" | GFONC1 = "FUNBENCHO"
      Filter [QLA1] Where PRONUM = adxuid(1)
&                      & LINNUM  = LLIN
&                  Order By Key QLW0
    Else
      Filter [QLA1] Where MFGTRKNUM  = LVCR
&                      &  OPETRKLIN  = LLIN
&                  Order By Key MTA0
    Endif
    For [QLA1]
       #LLECFIC=1
        For W_I = 1 To LNBQST
          If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"=[F:QLA1]QSTNUM")
            If evalue("dim([M]FLD"+format$("N0:3#",W_I)+")>0")
              Case evalue("[M]TYP"+format$("N0:3#",W_I))
                When 1 :
                  Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA1]ALPASW
                  WNBQST-=1
                When 2 :
                  Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA1]NUMASW
                  WNBQST-=1
                When 3 :
                  Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA1]DATASW
                  WNBQST-=1
                When 4 :
                  Assign "[M]FLD"+format$("N0:3#",W_I) With [F:QLA1]NUMASW+1
                  WNBQST-=1
              Endcase
              If [F:QLA1]OSDASW = 2
                Assign "[M]STD"+format$("N0:3#",W_I) With mess(508,197,1)
                If [F:QLA1]RPLQLYCRD <> "" & evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0") # hcb V6CQ
                    Assign "[M]RPL"+format$("N0:3#",W_I) With [F:QLA1]RPLQLYCRD              # hcb V6CQ
                Endif
              Else
                Assign "[M]STD"+format$("N0:3#",W_I) With ""
              Endif
              Break
            Endif
          Endif
#     hcb V6CQ le diszo évalué ne marche pas ..........donc je passe par une rubrique FLGxxx
#              que est testée en avant saisie de RLPxxx pour desactivée cette dernière
          If evalue("dim([M]FLG"+format$("N0:3#",W_I)+")>0")  # hcb V6CQ
             Assign "[M]FLG"+format$("N0:3#",W_I) With 0      # hcb V6CQ
          Endif                                               # hcb V6CQ
        Next
    Next
    Filter [QLA1]
    If WNBQST=0 : LLECFIC=1 : Endif
    Gosub AFF_LIB
Endif
End

############################################################
# Sous programme de chargement des reponses deja saisies
# LDEM  = Numero demande d'analyse
# LSEQ  = Numero de sequence
# LITM  = Numero d'article
# LFIC  = Numero fiche qualite
# LTYP  = Type de saisie (1 = contrôle qualite / 2 = GPAO / 3 pesée)
# LIPT  = Date imputation
# LMSK  = Classe ecran pour transfer de chapms supplementaires de [QLA] (facultatif)
# LFLD  = Tableau des champs à transferer (si LMSK) ex LOT, BPSLOT,VCRTYP
#
Subprog ECRFIC(LDEM,LLIN,LSEQ,LITM,LFIC,LTYP,LIPT,LMSK,LFLD)
Value    Char    LDEM
Value    Integer LLIN
Variable Decimal LSEQ
Value    Char    LITM
Value    Char    LFIC
Value    Integer LTYP
Value    Date    LIPT
Value    Char    LMSK
Value    Char    LFLD()
#
Local  Integer W_I, W_J, W_K,W_L
Local Integer LNBQST : LNBQST = func LASTQST
#
If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:QLA]) = 0 : Local File QLYCRDASW [QLA]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
#
#Call DEBTRANS From GLOCK                  # hcb V6CQ
#Trbegin [QLA]                             # hcb V6CQ
If LSEQ <> 0
  Delete [QLA] Where QLYCTLDEM = LDEM
&                  & VCRLIN    = LLIN
&                  & CRDSEQ    = LSEQ
Else
    Filter [QLA] Where QLYCTLDEM = LDEM
&                    & VCRLIN    = LLIN
&                Order By Key QLA0
    Read [QLA]First
    If fstat = 0
      LSEQ = [F:QLA]CRDSEQ-1
    Else
      LSEQ = 9999
    Endif
Endif
#
For W_I=1 To LNBQST
  If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"<>''")
    Raz [F:QLA]
    [F:QLA]QLYCTLDEM = LDEM
    [F:QLA]VCRLIN    = LLIN
    [F:QLA]CRDSEQ    = LSEQ
    [F:QLA]TRKTYP    = LTYP
    [F:QLA]QSTNUM    = evalue("[M]QST"+format$("N0:3#",W_I))
    [F:QLA]ITMREF    = LITM
    [F:QLA]QLYCRD    = LFIC
    [F:QLA]IPTDAT    = LIPT
    If LMSK <> ""
      For W_J = 0 To dim(LFLD)-1
        If evalue("dim("+LMSK+LFLD(W_J)+")>0") & evalue("dim([F:QLA]"+LFLD(W_J)+")>0")
          Assign "[F:QLA]"+LFLD(W_J) With evalue(LMSK+LFLD(W_J))
        Endif
      Next W_J
    Endif
    W_K = 0
    Case evalue("[M]TYP"+format$("N0:3#",W_I))
      When 1,7 : # Issue 122257 - 2017-05-04 by MAE : Ajout du type Clob (7)
        [F:QLA]ALPASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLA]ASW    = [F:QLA]ALPASW
        If [F:QLA]ALPASW = ""
          W_K = 1
        Endif
      When 2 :
        [F:QLA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLA]ASW    = num$([F:QLA]NUMASW)
        #If [F:QLA]NUMASW = 0    : # Bug 28399 - TS
        #  W_K = 1               : # Bug 28399 - TS
        #Endif                   : # Bug 28399 - TS
      When 3 :
        [F:QLA]DATASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLA]ASW    = num$([F:QLA]DATASW)
        If [F:QLA]DATASW = [0/0/0]
          W_K = 1
        Endif
      When 4 :
        [F:QLA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLA]NUMASW -= 1
        [F:QLA]ASW    = num$([F:QLA]NUMASW)
    Endcase
    If evalue("[M]STD"+format$("N0:3#",W_I)+"=mid$(mess(508,197,1),1,15)")
      [F:QLA]OSDASW = 2
    Else
      [F:QLA]OSDASW = 1
    Endif
#                                             hcb V6CQ deb
    If evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0")
       [F:QLA]RPLQLYCRD  = evalue("[M]RPL"+format$("N0:3#",W_I))
    Endif
    If [F:QLA]QSTNUM <> ""
       If [F:QLA]QSTNUM <> [F:QLQ]QSTNUM
          Read [QLQ]QLQ0=[F:QLA]QSTNUM
          If fstat
             Raz [F:QLQ]
          Endif
       Endif
    [F:QLA]GPG       = [F:QLQ]GPG
    [F:QLA]PRNCOD    = [F:QLQ]PRNCOD
    Endif
#                                             hcb V6CQ fin
    [F:QLA]CREDAT = date$
    [F:QLA]CREUSR = GUSER
    [F:QLA]EXPNUM = [C]EXPORT
    # hcb 36926
    GPOINT = "PEWRIQLA"
    Gosub ENTREE From EXEFNC
    # hcb 36926
    If W_K = 0
      Write [QLA]
      If fstat
        Call FSTA("QLA") From GLOCK
        GOK = 0
        Break
      Endif
    Endif
  Endif
Next

#If GOK                         # hcb V6CQ
#    Commit                     # hcb V6CQ
#Else                           # hcb V6CQ
#    Rollback                   # hcb V6CQ
#Endif                          # hcb V6CQ

End

###########################################################
#Sous programme d'écriture fichier de travail
Subprog ECRFIC2(LVCRNUM, L, LMFGNUM, LOPE)
Value   Char    LVCRNUM
Value   Integer L
Value   Char    LMFGNUM
Value   Integer LOPE

Local  Integer W_I
Local Integer LNBQST : LNBQST = func LASTQST
If LVCRNUM <> "" : Goto ECR_MTA : Endif

#Call DEBTRANS From GLOCK
#If clalev([F:QLW]) = 0 : Local File QLYWRK    [QLW]   : Endif
#Trbegin [QLW]
If L >  0
  Delete [QLW] Where PRONUM = adxuid(1) & LINNUM = L
Endif
#
For W_I = 1 To LNBQST
  If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"<>''")
    Raz [F:QLW]
    Case evalue("[M]TYP"+format$("N0:3#",W_I))
      When 1,7 : # Issue 122257 - 2017-05-04 by MAE : Ajout du type Clob (7)
        [F:QLW]ALPASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLW]ASW    = [F:QLW]ALPASW
        If [F:QLW]ALPASW = ""
          W_K = 1
        Endif
      When 2 :
        [F:QLW]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLW]ASW    = num$([F:QLW]NUMASW)
      When 3 :
        [F:QLW]DATASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLW]ASW    = num$([F:QLW]DATASW)
        If [F:QLW]DATASW = [0/0/0]
          W_K = 1
        Endif
      When 4 :
        [F:QLW]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:QLW]NUMASW -= 1
        [F:QLW]ASW    = num$([F:QLW]NUMASW)
     Endcase

     If evalue("[M]STD"+format$("N0:3#",W_I)+"=mid$(mess(508,197,1),1,15)")
          [F:QLW]OSDASW = 2
      Else
          [F:QLW]OSDASW = 1
      Endif

     [F:QLW]PRONUM = adxuid(1)
     [F:QLW]LINNUM = L
     [F:QLW]QSTNUM = evalue("[M]QST"+format$("N0:3#",W_I))
     [F:QLW]VCRTYP = 12
     [F:QLW]TRKTYP = 2
     [F:QLW]CREDAT = date$
     [F:QLW]CREUSR = GUSER
#                                             hcb V6CQ deb
      If evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0")
         [F:QLW]RPLQLYCRD  = evalue("[M]RPL"+format$("N0:3#",W_I))
      Endif
      If [F:QLW]QSTNUM <> ""
         If [F:QLW]QSTNUM <> [F:QLQ]QSTNUM
            Read [QLQ]QLQ0=[F:QLW]QSTNUM
            If fstat
               Raz [F:QLQ]
            Endif
         Endif
        [F:QLW]GPG       = [F:QLQ]GPG
        [F:QLW]PRNCOD    = [F:QLQ]PRNCOD
      Endif
#                                             hcb V6CQ fin
     Write [QLW]
       If fstat : Call FSTA("QLW") From GLOCK : GOK = 0 : Break : Endif
   Endif
Next
#                           hcb V6CQ deb
#if GOK
#    Commit
#Else
#    Rollback
#Endif
#                           hcb V6CQ fin

End

$ECR_MTA
#Call DEBTRANS From GLOCK                                              # hcb V6CQ
#If clalev([F:MTA]) = 0 : Local File MTKCRDASW    [MTA]   : Endif      # hcb V6CQ
#Trbegin [MTA]                                                         # hcb V6CQ
For W_I = 1 To LNBQST
    If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"<>''")
        Readlock [MTA]MTA0=LVCRNUM;L;evalue("[M]QST"+format$("N0:3#",W_I))

        Case evalue("[M]TYP"+format$("N0:3#",W_I))
            When 1 :    [F:MTA]ALPASW = evalue("[M]FLD"+format$("N0:3#",W_I))
                        [F:MTA]ASW    = [F:MTA]ALPASW
                        If [F:MTA]ALPASW = "" : W_K = 1 : Endif
            When 2 :    [F:MTA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
                        [F:MTA]ASW    = num$([F:MTA]NUMASW)
                        #If [F:MTA]NUMASW = 0 : W_K = 1 : Endif    : # Bug 28399 - TS
            When 3 :    [F:MTA]DATASW = evalue("[M]FLD"+format$("N0:3#",W_I))
                        [F:MTA]ASW    = num$([F:MTA]DATASW)
                        If [F:MTA]DATASW = [0/0/0] : W_K = 1 : Endif
            When 4 :    [F:MTA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
                        [F:MTA]NUMASW -= 1
                        [F:MTA]ASW    = num$([F:MTA]NUMASW)
        Endcase

        If evalue("[M]STD"+format$("N0:3#",W_I)+"=mid$(mess(508,197,1),1,15)")
            [F:MTA]OSDASW = 2
        Else
            [F:MTA]OSDASW = 1
        Endif
#                                             hcb V6CQ deb
        [F:MTA]QSTNUM    = evalue("[M]QST"+format$("N0:3#",W_I))
        If evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0")
           [F:MTA]RPLQLYCRD  = evalue("[M]RPL"+format$("N0:3#",W_I))
        Endif
#                                             hcb V6CQ fin

        If fstat
#                                             hcb V6CQ deb
            If [F:MTA]QSTNUM <> ""
               If [F:MTA]QSTNUM <> [F:QLQ]QSTNUM
                  Read [QLQ]QLQ0=[F:MTA]QSTNUM
                  If fstat
                     Raz [F:QLQ]
                  Endif
                Endif
                [F:MTA]GPG       = [F:QLQ]GPG
                [F:MTA]PRNCOD    = [F:QLQ]PRNCOD
            Endif
#                                             hcb V6CQ fin
            [F:MTA]MFGTRKNUM = LVCRNUM
            [F:MTA]OPETRKLIN = L
            [F:MTA]OPENUM    = LOPE
            [F:MTA]MFGNUM    = LMFGNUM
            [F:MTA]IPTDAT    = [M:QLY0]IPTDAT
            [F:MTA]QLYCRD    = [M:QLY0]QLYCRD
            [F:MTA]QSTNUM    = evalue("[M]QST"+format$("N0:3#",W_I))
            [F:MTA]EXPNUM    = [C]EXPORT
            [F:MTA]CREDAT = date$
            [F:MTA]CREUSR = GUSER

            Write [MTA]
            If fstat : Call FSTA("MTA") From GLOCK : GOK = 0 : Break : Endif
        Else
            [F:MTA]UPDDAT = date$
            [F:MTA]UPDUSR = GUSER
            Rewrite [MTA]
            If fstat : Call FSTA("MTA") From GLOCK : GOK = 0 : Break : Endif
        Endif
    Endif
Next
#                    hcb V6CQ deb
#if GOK
#    Commit
#Else
#    Rollback
#Endif
#                    hcb V6CQ fin
End

###########################################################
#Sous programme d'écriture fichier de réponses vide de box centale de pesée
Subprog ECRFIC3(L,LMFGNUM,LOPENUM,LITMREF,LSEQ)
Value    Integer L
Value    Char    LMFGNUM
Value    Integer LOPENUM
Value    Char    LITMREF
Value    Integer LSEQ
Local  Integer W_I, LSEQ
Local Integer LNBQST : LNBQST = func LASTQST

If clalev([F:MWA]) = 0 : Local File MWMCRDASW    [MWA]   : Endif
#
Call DEBTRANS From GLOCK
Trbegin [MWA]
If LSEQ <> 0
  Delete [MWA] Where MFGNUM    = LMFGNUM
&                  & BOMOPE    = LOPENUM
&                  & ITMREF    = LITMREF
&                  & IPTDAT    = [M:QLY0]IPTDAT
&                  & MVTSEQ    = LSEQ
Else
    Filter [MWA] Where MFGNUM  = LMFGNUM
&                    & BOMOPE  = LOPENUM
&                    & ITMREF  = LITMREF
&                    & IPTDAT  = [M:QLY0]IPTDAT
&                Order By Key MWA0
    Read [MWA]First
    If fstat = 0
      LSEQ = [F:MWA]MVTSEQ-1
    Else
      LSEQ = 9999
    Endif
Endif

#
For W_I = 1 To LNBQST
  If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"<>''")
    Raz [F:MWA]
    Case evalue("[M]TYP"+format$("N0:3#",W_I))
      When 1 :
        [F:MWA]ALPASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:MWA]ASW    = [F:MWA]ALPASW
        If [F:MWA]ALPASW = ""
          W_K = 1
        Endif
      When 2 :
        [F:MWA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:MWA]ASW    = num$([F:MWA]NUMASW)
      When 3 :
        [F:MWA]DATASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:MWA]ASW    = num$([F:MWA]DATASW)
        If [F:MWA]DATASW = [0/0/0]
          W_K = 1
        Endif
      When 4 :
        [F:MWA]NUMASW = evalue("[M]FLD"+format$("N0:3#",W_I))
        [F:MWA]NUMASW -= 1
        [F:MWA]ASW    = num$([F:MWA]NUMASW)
     Endcase
     [F:MWA]MFGNUM = LMFGNUM
     [F:MWA]BOMOPE = LOPENUM
     [F:MWA]ITMREF = LITMREF
     [F:MWA]IPTDAT = [M:QLY0]IPTDAT
     [F:MWA]QLYCRD = [M:QLY0]QLYCRD
     [F:MWA]MVTSEQ = LSEQ
     [F:MWA]FCY    = GSCA1MFGFCY
     [F:MWA]STI    = GSCA1STI
     [F:MWA]BOX    = GSCA1BOX

     # mm 03.11 - gestion du type 4 : vide box fin matière
     If LMFGNUM = "" & LOPENUM = 0 & LITMREF = ""
               [F:MWA]PCRTYP = 1
     Elsif LMFGNUM <> "" &  LOPENUM = 0 & LITMREF = ""
               [F:MWA]PCRTYP = 2
     Elsif LMFGNUM <> "" &  LOPENUM <> 0  & LITMREF = ""
               [F:MWA]PCRTYP = 3
     Elsif  LMFGNUM = "" & LOPENUM = 0 & LITMREF <> ""
                 [F:MWA]PCRTYP = 4
     Endif
     [F:MWA]QSTNUM = evalue("[M]QST"+format$("N0:3#",W_I))
     [F:MWA]CREDAT = date$
     [F:MWA]CREUSR = GUSER
#                                             hcb V6CQ deb
     [F:MWA]QSTNUM    = evalue("[M]QST"+format$("N0:3#",W_I))
#    If evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0")
#       [F:MWA]RPLQLYCRD  = evalue("[M]RPL"+format$("N0:3#",W_I))
#    Endif
     If [F:MWA]QSTNUM <> ""
        If [F:MWA]QSTNUM <> [F:QLQ]QSTNUM
           Read [QLQ]QLQ0=[F:MWA]QSTNUM
           If fstat
              Raz [F:QLQ]
           Endif
        Endif
       [F:MWA]GPG       = [F:QLQ]GPG
       [F:MWA]PRNCOD    = [F:QLQ]PRNCOD
     Endif
#                                             hcb V6CQ fin
     Write [MWA]
       If fstat : Call FSTA("MWA") From GLOCK : GOK = 0 : Break : Endif
   Endif
Next
If GOK
    Commit
Else
    Rollback
Endif

End

###########################################################
# Controle reponses fiche
Subprog VERFIC(LCRD,LQUE,LREP,LRMA,LBLO,LBLS,LNEW,LMSG,LRET)    # hcb V6CQ
Value    Char    LCRD                                           # hcb V6CQ
Variable Decimal LQUE
Variable Decimal LREP
Variable Decimal LRMA
Variable Decimal LBLO
Variable Decimal LBLS
Variable Decimal LNEW
Variable Char    LMSG
Variable Integer LRET
#
Local    Integer W_I, W_J
Local    Char    W_QST
Local    Char    W_ALP
Local    Decimal W_NUM
Local    Date    W_DAT
Local    Integer W_OSD
Local Integer LNBQST : LNBQST = func LASTQST
#
Raz LQUE, LREP, LRMA, LBLO, LBLS, LNEW, LMSG, LRET
#

For W_I = 1 To LNBQST
  If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0")
      W_QST = evalue("[M]QST"+format$("N0:3#",W_I))
      If W_QST <> ""
        LQUE += 1
        Read [QLQ]QLQ0=W_QST
        If fstat
          LRET = fstat
          Break
        Endif
        Raz W_ALP, W_NUM, W_DAT, W_OSD
        If evalue("[M]STD"+format$("N0:3#",W_I)+"=''")
          W_OSD = 1
        Else
          W_OSD = 2
        Endif
        Case [F:QLQ]DEMASWTYP
          When 1 :
            W_ALP = evalue("[M]FLD"+format$("N0:3#",W_I))
            If W_ALP = ""
              Case [F:QLQ]DEMCTLTYP
                When 1 :
                  Read [TCT]TCT1=[F:QLQ]TCT;W_ALP;0
                  If fstat
                    LMSG += W_QST+", "
                    LRMA += 1
                    W_J   = 2
                  Endif
                When 2 :
                  If W_ALP < [F:QLQ]ALPSTRVAL | W_ALP > [F:QLQ]ALPENDVAL
                    LMSG += W_QST+", "
                    LRMA += 1
                    W_J   = 2
                  Endif
               Endcase
             Else
               LREP += 1
             Endif
             If W_J = 2
               Case [F:QLQ]LOKTYP
                 When 2 : LBLO = W_I
                 When 3 : LBLS = W_I
                 When 4 : LNEW = W_I
               Endcase
             Endif
          When 2 :
            W_NUM = evalue("[M]FLD"+format$("N0:3#",W_I))
            If W_NUM = 0
              Case [F:QLQ]DEMCTLTYP
                When 1 :
                  Read [TCT]TCT1=[F:QLQ]TCT;"";W_NUM
                  If fstat
                    LMSG += W_QST+", "
                    LRMA += 1
                    W_J   = 2
                  Endif
                When 2 :
                  If W_NUM < [F:QLQ]NUMSTRVAL | W_NUM > [F:QLQ]NUMENDVAL
                    LMSG += W_QST+", "
                    LRMA += 1
                    W_J   = 2
                  Endif
               Endcase
             Else
               LREP += 1
             Endif
             If W_J = 2
               Case [F:QLQ]LOKTYP
                 When 2 : LBLO = W_I
                 When 3 : LBLS = W_I
                 When 4 : LNEW = W_I
               Endcase
             Endif
          When 3 :
            W_DAT = evalue("[M]FLD"+format$("N0:3#",W_I))
            If W_DAT = [0/0/0]
              LMSG += W_QST+", "
              LRMA += 1
              W_J = 2
            Else
              LREP += 1
            Endif
            If W_J = 2
              Case [F:QLQ]LOKTYP
                When 2 : LBLO = W_I
                When 3 : LBLS = W_I
                When 4 : LNEW = W_I
              Endcase
            Endif
          When 4 :
            LREP += 1
        Endcase
      Endif
  Endif

#                                                      hcb V6CQ deb
# récuperation Nouvelle fiche par défaut
  If evalue("dim([M]RPF"+format$("N0:3#",W_I)+")>0")
     Read [QLC]QLC0=LCRD;W_I
     If fstat
        Raz [F:QLC]
     Endif
     Assign "[M]RPF"+format$("N0:3#",W_I) With [F:QLC]RPLQLYCRD
  Endif
#                                                      hcb V6CQ fin

Next
End

