#<AdxTL>@(#)5.0.0.0 $Revision$

Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "MGG"
PARBOUT(2) = "GIET"
PARBOUT(3) = "QLY66666"
PARBOUT(4) = date$
PARBOUT(5) = "1"
PARBOUT(6) = "0"
FLGEXE = 1
GACTION = "SAIQLYCRD"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"IQLYCRD","CRDLIB","",4,"") From GTRAITE
End
############################################################
# Bibliotheque de gestion des fiches qualite
############################################################
# Actions
# SAIQLYCRD  = Saisie fiche qualite
# SAITECCRD  = Saisie fiche technique
# SAIPROCRD  = Saisie des procédures de vide de box - centrale de pesée
# SELTCTCRD  = Selection reponse en liste de valeur
# CRDASALP   = Avant saisie reponse alphanumerique
# RPLASALP   = Avant saisie nouvelle fiche alphanumerique          V6CQ
# CRDASNUM   = Avant saisie reponse numerique
# CRDASDAT   = Avant saisie reponse date
# CRDAMALP   = Apres modification reponse alphanumerique
# RPLAMALP   = Apres modification nouvelle fiche alphanumerique    V6CQ
# CRDAMNUM   = Apres modification reponse numerique
# CRDAMDAT   = Apres modification reponse date
# CRDCTRALP  = Controle reponse alphanumerique
# CRDCTRRPL  = Controle nouvelle fiche alphanumerique              V6CQ
# CRDCTRNUM  = Controle reponse numerique
# CRDCTRDAT  = Controle reponse date
# CRDAVOBS   = Avant zone observation
############################################################
# Sous programmes
# GENCRD     = Generation de la fenetre de saisie des reponses
#              D'une fiche qualite
#              Ecran de reference   : QLYCRD1
#              Fenetre de reference : IQLYCRD
#              La fenetre generee est de nom WUQnnnnn (nnnnn = [F:QLC]SEQ)
#                 Contient le masque entete QLYCRD0
#                 Contient les onglets WUQnnnnnA, WUQnnnnnB, WUQnnnnnC ...
#
# LECFIC     = Lecture et chargement reponses saisies
# LECFIC2    = Lecture et chargement reponses saisies  GPAO
#
# ECRFIC     = Ecriture reponses
# ECRFIC2    = Ecriture reponses GPAO
# ECRFIC3    = Ecriture reponses Centrale
#
# VERFIC     = Contrôle saisie reponses
# CALSMPCOD  = Calcul de l'échantillon et/ou du code                # hcb V6CQ
# CALACPPRM  = Calcul du parammetre d'acceptation                   # hcb V6CQ

#
#########
###################################################
$ACTION
Case ACTION
  When "SEL_TABLE"  :
    Case GACTION
      When "SELTCTCRD"  : Gosub SELTCTCRD
    Endcase
  When "INIT"       :
    Case GACTION
      When "SAIQLYCRD" : Gosub INIT_SAIQLYCRD
      When "SAITECCRD" : Gosub INIT_SAITECCRD
      When "SAIPROCRD" : Gosub INIT_SAIPROCRD
    Endcase
  When "OUVRE"      :
    Case GACTION
      When "SAIQLYCRD" : Gosub OUVRE_SAIQLYCRD
      When "SAITECCRD" : Gosub OUVRE_SAIQLYCRD
      When "SAIPROCRD" : Gosub OUVRE_SAIQLYCRD
    Endcase
  When "DEBUT"      :
    Case GACTION
      When "SAIQLYCRD" : Gosub DEBUT_SAIQLYCRD
      When "SAITECCRD" : Gosub DEBUT_SAITECCRD
      When "SAIPROCRD" : Gosub DEBUT_SAIPROCRD
    Endcase
  When "SETBOUT"    :
    Case GACTION
      When "SAIQLYCRD" : Gosub SETBOUT_SAIQLYCRD
      When "SAITECCRD" : Gosub SETBOUT_SAIQLYCRD
      When "SAIPROCRD" : Gosub SETBOUT_SAIQLYCRD
    Endcase
  When "AP_CHOIX"    :  # 117343 mm 09.2016
    Case GACTION
       When "SAIPROCRD": Gosub APCHOIX_SAIPROCRD
    Endcase
  When "APRES_MODIF"
    #------------------------#
    # Apres modif d'un champ #
    #------------------------#
    Case GACTION
      When "SAIQLYCRD" : REP = "M" : Raz WLECFIC
      When "SAITECCRD" : REP = "M" : Raz WLECFIC
      When "SAIPROCRD" : REP = "M" : Raz WLECFIC
    Endcase
  When "ENR"
    Case GACTION
      When "SAIQLYCRD" : Gosub ENR_SAIQLYCRD
      When "SAITECCRD" : Gosub ENR_SAITECCRD
      When "SAIPROCRD" : Gosub ENR_SAIPROCRD
    Endcase
  When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When  "SAIQLYCRD"   : Gosub ABA_SAIQLYCRD
                         REP=""
   When "SAITECCRD"    : Gosub ABA_SAITECCRD
                         REP=""
   When "SAIPROCRD"    : Gosub ABA_SAIPROCRD
                         REP=""
  Endcase
  When "FINSAI"        GCONSULT=SVGCONSULT
Endcase
Return
############################################################
# Action de saisie d'une fiche qualite
# PARAM(01)  = Fiche qualite
# PARAM(02)  = Numero article
# PARAM(03)  = Numero d'analyse
# PARAM(04)  = Date de reference
# PARAM(05)  = Type de suivi (1= CQ / 2 GPAO / 3 Pesée)
# PARAM(06)  = N° ligne contrôle
# PARAM(07)  = Numero de sequence Entree = numero de sequence saisie (pour une meme danalyse)
#                                 Zéro   = nouvelle saisie de fiche
#                                 Sortie = numero de sequence utilise (si zero en entree)
# PARAM(08)  = Obligatoire (1=non / 2=oui) C'est à dire est-ce que toutes les réponses doivent
#              être saisies pour pouvoir enregistrer

$INIT_SAIQLYCRD
If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM]   : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO]   : Endif            # hcb V6CQ

Local Integer WLECFIC
#
Read [QLC]QLC0=PARAM(01)
If fstat
  FIN = 1
Else
  # FQ 68372 GA 10/2010 #BOITE = "WUQ"+format$("N0:5#",[F:QLC]SEQ)
  Local Char    W_MSK(GLONAMK) : W_MSK = ""
  Gosub CHARG_MSK
  BOITE = W_MSK
  Read [ITM]ITM0=PARAM(02)
  If fstat
     FIN = 1
  Endif
Endif
Return

############################################################
# Action de saisie d'une fiche qualite
# PARAM(01)  = Fiche qualite
# PARAM(02)  = Numero operation
# PARAM(03)  = Date de reference
# PARAM(04)  = numéro de ligne
# PARAM(05)  = Obligatoire
# PARAM(06)  = N° Suivi
# PARAM(07)  = N° OF
# PARAM(08)  = Modifiable
# PARAM(09)  = nolign

$INIT_SAITECCRD
If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:QLW]) = 0 : Local File QLYWRK    [QLW]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO]   : Endif            # hcb V6CQ

Local Integer WLECFIC

Read [QLC]QLC0=PARAM(01)
If fstat
  FIN = 1
Else
  # FQ 68372 GA 10/2010 #BOITE = "WUQ"+format$("N0:5#",[F:QLC]SEQ)
  Local Char    W_MSK(GLONAMK) : W_MSK = ""
  Gosub CHARG_MSK
  BOITE = W_MSK
Endif
Return


############################################################
# Action de saisie d'une fiche qualite
# PARAM(01)  = Fiche qualite
# PARAM(02)  = Numero OF
# PARAM(03)  = Numero operation
# PARAM(04)  = Date de reference
# PARAM(05)  = numéro de ligne
# PARAM(06)  = Obligatoire

$INIT_SAIPROCRD
If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:MWA]) = 0 : Local File MWMCRDASW [MWA]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO]   : Endif            # hcb V6CQ

Local Integer WLECFIC
#

Read [QLC]QLC0=PARAM(01)
If fstat
  FIN = 1
Else
  # FQ 68372 GA 10/2010 #BOITE = "WUQ"+format$("N0:5#",[F:QLC]SEQ)
  Local Char    W_MSK(GLONAMK) : W_MSK = ""
  Gosub CHARG_MSK
  BOITE = W_MSK
Endif
Return


############################################################
$OUVRE_SAIQLYCRD
Local Integer W_I, WLECFIC
Local Char    W_ABR(15) : W_ABR = "ABCDEFGHIJKLMNO"
Local Char    W_MSK(GLONAMK) : W_MSK = ""   # FQ 68372 GA 10/2010 avant (10)
Local Char    W_FLD(10) : W_FLD = ""
Local Char    W_MSG(100)
Local Decimal W_QNB
Local Decimal W_REP
Local Decimal W_RMA
Local Decimal W_BLO
Local Decimal W_BLS
Local Decimal W_NEW
Local Integer W_RET
Local Integer SVGCONSULT : SVGCONSULT=GCONSULT
#                          hcb V6CQ deb
Global Char GWSSMPLOT(20)
Global Char GWSSMPSLO(20)
# affichage du LOT et SLO  uniquement pour la fiche qualite
If GACTION = "SAIQLYCRD"
   GWSSMPLOT   = GSINVLOT
   GWSSMPSLO   = GSINVSLO
   If [F:ITM]LOTMGTCOD = 1
      GWSSMPLOT   = "-"+GSINVLOT
      GWSSMPSLO   = "-"+GSINVSLO
   Endif
   If [F:ITF]SMPMOD = 1
      GWSSMPLOT   = "-"+GSINVLOT
      GWSSMPSLO   = "-"+GSINVSLO
   Endif
   If [F:ITM]LOTMGTCOD < 4
      GWSSMPSLO   = "-"+GSINVSLO
   Endif
Else
      GWSSMPLOT   = "-"+GSINVLOT
      GWSSMPSLO   = "-"+GSINVSLO
Endif
Global Char NUMNMN_ATABZON(20)
Global Char UOM_ATABZON(10)
Global Char UOMDEC_ATABZON(20)
# mémorisation libellé : Valeur nominale
Call TEXTFIC("QLYCRDQST","NUMNMNVAL",2,NUMNMN_ATABZON) From OBJDIV
# mémorisation libellé : Unité
Call TEXTFIC("QLYCRDQST","UOM",2,UOM_ATABZON) From OBJDIV
# mémorisation libellé : Nombre de décimale
Call TEXTFIC("QLYCRDQST","UOMDEC",2,UOMDEC_ATABZON) From OBJDIV
#                                hcb V6CQ fin


Return
############################################################
$DEBUT_SAIQLYCRD
If find([M:STQ1]WSTOSEQ(val(PARAM(9))),[M:SGW]WSTOSEQ) | [M:STQ1]MVTFLG(val(PARAM(9)))=2
    GCONSULT=2
Endif
Effzo [M:QLY0]
For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub EFFECR
 Endif
Next W_I
#
[M:QLY0]ITMREF    = [F:ITM]ITMREF
#[M:QLY0]ITMDES1   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:QLY0]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:QLY0]QLYCRD    = [F:QLC]QLYCRD
# FGR 24/09/2009 : X3SUIVI58062
#[M:QLY0]QLYCRDDES = [F:QLC]QLYCRDDES
Call LECTEXTRA([M:QLY0]QLYCRDDES,"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA
[M:QLY0]QLYCTLDEM = PARAM(03)
[M:QLY0]QLYCTLLIG = val(PARAM(9))+1
[M:QLY0]IPTDAT    = PARAM(04)
[M:QLY0]TRKTYP    = val(PARAM(05))
[M:QLY0]VCRLIN    = val(PARAM(06))
[M:QLY0]CRDSEQ    = val(PARAM(07))
[M:QLY0]OBL       = val(PARAM(08))
[M:QLY0]QLYCTLQTY = val(PARAM(10))
[M:QLY0]QLYCTLUOM = PARAM(11)
If dim([M:QLY0]LOT) > 0  & dim([M:STQ1]LOT) > 0                          # hcb V6CQ
   [M:QLY0]LOT       = [M:STQ1]LOT(val(PARAM(09)))                       # hcb V6CQ
Endif                                                                    # hcb V6CQ
If dim([M:QLY0]SLO) > 0  & dim([M:STQ1]SLO) > 0                          # hcb V6CQ
   [M:QLY0]SLO       = [M:STQ1]SLO(val(PARAM(09)))                       # hcb V6CQ
Endif                                                                    # hcb V6CQ
[M:QLY0]VCRTYP       = [M:STQ1]VCRTYP                                    # hcb V6CQ
[M:QLY0]VCRNUM       = [M:STQ1]VCRNUM                                    # hcb V6CQ
Raz [M:QLY0]WSMPTYP                                                      # hcb V6CQ
If [F:ITF]SMPTYP > 1                                                     # hcb V6CQ
   [M:QLY0]WSMPTYP = mess(84,187,1) + " : " + mess([F:ITF]SMPMOD,2756,1) # hcb V6CQ
Endif                                                                    # hcb V6CQ

Affzo [M:QLY0]1-99

For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub AFFECR
 Endif
Next W_I
#
W_J = 1
Raz WLECFIC
If [M:QLY0]CRDSEQ <> 0 & [M:QLY0]TRKTYP = 1
  Call LECFIC([M:QLY0]QLYCRD,[M:QLY0]QLYCTLDEM,[M:QLY0]VCRLIN,[M:QLY0]CRDSEQ,WLECFIC)
Else
  Gosub AFF_LIB
Endif
For W_I = 1 To len(W_ABR)
  If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
    Gosub AFFECR
    If GCONSULT
      Default Mask "[M:QLY"+mid$(W_ABR,W_I,1)+"]"
      Diszo [M]1-99
    Endif
  Endif
Next W_I

If dim([M:QLY0]LOT) > 0                                                  # hcb V6CQ
   Diszo [M:QLY0]LOT            # hcb V6CQ
Endif
If dim([M:QLY0]SLO) > 0                                                  # hcb V6CQ
   Diszo [M:QLY0]SLO            # hcb V6CQ
Endif

Return
############################################################
$DEBUT_SAITECCRD
Effzo [M:QLY0]
For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub EFFECR
 Endif
Next W_I
#

[M:QLY0]QLYCRD    = [F:QLC]QLYCRD
# FGR 24/09/2009 : X3SUIVI58062
#[M:QLY0]QLYCRDDES = [F:QLC]QLYCRDDES
Call LECTEXTRA([M:QLY0]QLYCRDDES,"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA

[M:QLY0]IPTDAT    = PARAM(03)
[M:QLY0]VCRLIN    = val(PARAM(04))
Grizo [M:QLY0]QLYCTLDEM
Grizo [M:QLY0]ITMREF
Grizo [M:QLY0]ITMDES1
Affzo [M:QLY0]1-99
For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub AFFECR
 Endif
Next W_I
#
W_J = 1
Raz WLECFIC
Call LECFIC2([M:QLY0]QLYCRD,[M:QLY0]VCRLIN,PARAM(6),WLECFIC)
W_J = 1
For W_I = 1 To len(W_ABR)
  If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
    Gosub AFFECR
    If GCONSULT | val(PARAM(08)) = 1
        Default Mask "[M:QLY"+mid$(W_ABR,W_I,1)+"]"
        Diszo [M]1-99
    Endif
  Endif
Next W_I
Return

############################################################
$DEBUT_SAIPROCRD

Effzo [M:QLY0]
For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub EFFECR
 Endif
Next W_I
#
[M:QLY0]QLYCRD    = [F:QLC]QLYCRD
# FGR 24/09/2009 : X3SUIVI58062
#[M:QLY0]QLYCRDDES = [F:QLC]QLYCRDDES
Call LECTEXTRA([M:QLY0]QLYCRDDES,"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA
[M:QLY0]IPTDAT    = PARAM(05)   # mm 03.11
Grizo [M:QLY0]QLYCTLDEM
Grizo [M:QLY0]ITMREF
Grizo [M:QLY0]ITMDES1
Affzo [M:QLY0]1-99
For W_I = 1 To len(W_ABR)
 If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
   Gosub AFFECR
 Endif
Next W_I
#
W_J = 1
For W_I = 1 To len(W_ABR)
  If evalue("clalev([M:QLY"+mid$(W_ABR,W_I,1)+"])<>0")
    Gosub AFFECR
    If GCONSULT
        Default Mask "[M:QLY"+mid$(W_ABR,W_I,1)+"]"
        Diszo [M]1-99
    Endif
  Endif
Next W_I
Return

############################################################
$EFFECR
Case W_I
  When  1 : Effzo [M:QLYA]
  When  2 : Effzo [M:QLYB]
  When  3 : Effzo [M:QLYC]
  When  4 : Effzo [M:QLYD]
  When  5 : Effzo [M:QLYE]
  When  6 : Effzo [M:QLYF]
  When  7 : Effzo [M:QLYG]
  When  8 : Effzo [M:QLYH]
  When  9 : Effzo [M:QLYI]
  When 10 : Effzo [M:QLYJ]
  When 11 : Effzo [M:QLYK]
  When 12 : Effzo [M:QLYL]
  When 13 : Effzo [M:QLYM]
  When 14 : Effzo [M:QLYN]
  When 15 : Effzo [M:QLYO]
Endcase
Return

############################################################
$AFFECR
Case W_I
  When  1 : Affzo [M:QLYA]1-99
  When  2 : Affzo [M:QLYB]1-99
  When  3 : Affzo [M:QLYC]1-99
  When  4 : Affzo [M:QLYD]1-99
  When  5 : Affzo [M:QLYE]1-99
  When  6 : Affzo [M:QLYF]1-99
  When  7 : Affzo [M:QLYG]1-99
  When  8 : Affzo [M:QLYH]1-99
  When  9 : Affzo [M:QLYI]1-99
  When 10 : Affzo [M:QLYJ]1-99
  When 11 : Affzo [M:QLYK]1-99
  When 12 : Affzo [M:QLYL]1-99
  When 13 : Affzo [M:QLYM]1-99
  When 14 : Affzo [M:QLYN]1-99
  When 15 : Affzo [M:QLYO]1-99
Endcase
Return

############################################################
$SETBOUT_SAIQLYCRD
Call VERFIC([M:QLY0]QLYCRD,W_QNB,W_REP,W_RMA,W_BLO,W_BLS,W_NEW,W_MSG,W_RET)  # hcb V6CQ
If W_RMA =0 & !GCONSULT
  If WLECFIC=0
      ETABOU(GENRE) = 1
  Endif
Endif
Return

$ENR_SAIQLYCRD

Local Integer  WOK
Local Char WMESSAGE(250)
Call VERFIC([M:QLY0]QLYCRD,W_QNB,W_REP,W_RMA,W_BLO,W_BLS,W_NEW,W_MSG,W_RET)  # hcb V6CQ
If W_RMA > 0
  WMESSAGE = mess(62,196,1)+" : "+num$(W_RMA)+"\"+mid$(W_MSG,1,len(W_MSG)-2)
  #-- S'il y a déjà des qtés controlées, la fiche doit être complète
  If mod([M:QLY0]OBL,4)>=2
    Call ERREUR(WMESSAGE) From GESECRAN
    FIN=0
    Return
  Else
    WMESSAGE-="\"+mess(890,196,1)
    WOK=2 : Call OUINON(WMESSAGE,WOK) From GESECRAN
  Endif
Endif
#                                                 hcb V6CQ deb
If [F:ITF]SMPTYP > 1
   If [F:ITF]SMPMOD = 2
      Filter [QLD] Where VCRTYP    = [M:QLY0]VCRTYP
&                      & VCRNUM    = [M:QLY0]VCRNUM
&                      & LOT       = [M:QLY0]LOT
&                  Order By Key QLD2
   Else
      Filter [QLD] Where VCRTYP    = [M:QLY0]VCRTYP
&                      & VCRNUM    = [M:QLY0]VCRNUM
&                  Order By Key QLD0
   Endif
   Local Integer WI
   Raz WI

   Call DEBTRANS From GLOCK
   Trbegin [QLA]
   For [QLD]
       Call ECRFIC([M:QLY0]QLYCTLDEM,[F:QLD]VCRLIN,[M:QLY0]CRDSEQ,[M:QLY0]ITMREF,[M:QLY0]QLYCRD,[M:QLY0]VCRTYP,[M:QLY0]IPTDAT,
&                   W_MSK,W_FLD)
#---- Enregistrement de la nouvelle fiche  ----#
      If [M:QLY0]RPLQLYCRD <> "" & [F:QLD]QLYCRD <> [M:QLY0]RPLQLYCRD
         Readlock [QLD] Curr
         If fstat
            Call FSTA("QLD") From GLOCK
            GOK = 0
            Break
         Endif
         [F:QLD]QLYCRD = [M:QLY0]RPLQLYCRD
         Rewrite [QLD]
         If fstat
            Call FSTA("QLD") From GLOCK
            GOK = 0
            Break
         Endif
         [M:STQ1]QLYCRD(val(PARAM(09))) = [M:QLY0]RPLQLYCRD
         Affzo [M:STQ1]QLYCRD(val(PARAM(09)))
      Endif
   Next
   Filter [QLD]
   If GOK
      Commit
   Else
      Rollback
   Endif
Else
#
#                           HCB V6CQ fin
   Call DEBTRANS From GLOCK
   Trbegin [QLA]
   Call ECRFIC([M:QLY0]QLYCTLDEM,[M:QLY0]VCRLIN,[M:QLY0]CRDSEQ,[M:QLY0]ITMREF,[M:QLY0]QLYCRD,[M:QLY0]VCRTYP,[M:QLY0]IPTDAT,
&               W_MSK,W_FLD)
#---- Enregistrement de la nouvelle fiche  ----#
   If [M:QLY0]RPLQLYCRD <> ""
       Readlock [QLD]QLD0= [M:QLY0]VCRTYP;[M:QLY0]VCRNUM;[M:QLY0]VCRLIN
       If fstat
          Call FSTA("QLD") From GLOCK
          GOK = 0
       Endif
       If [F:QLD]QLYCRD <> [M:QLY0]RPLQLYCRD
          [F:QLD]QLYCRD =  [M:QLY0]RPLQLYCRD
          Rewrite [QLD]
          If fstat
             Call FSTA("QLD") From GLOCK
             GOK = 0
          Endif
          [M:STQ1]QLYCRD(val(PARAM(09))) = [M:QLY0]RPLQLYCRD
          Affzo [M:STQ1]QLYCRD(val(PARAM(09)))
       Endif
   Endif
   If GOK
      Commit
   Else
      Rollback
   Endif
Endif                                           # hcb V6CQ

PARAM(07) = num$([M:QLY0]CRDSEQ)
FIN = 1
If WOK=1 : Raz FIN : Endif
Return


############################################################
$ENR_SAITECCRD
Call VERFIC([M:QLY0]QLYCRD,W_QNB,W_REP,W_RMA,W_BLO,W_BLS,W_NEW,W_MSG,W_RET)  # hcb V6CQ
If W_RMA > 0
  GERR     = 2
  GMESSAGE = mess(62,196,1)+" : "+num$(W_RMA)+"\"+mid$(W_MSG,1,len(W_MSG)-2)
  If mod([M:QLY0]OBL,4)>=2
    GERR=1
    FIN=0
    Return
  Endif
Endif
#                                         hcb V6CQ deb
Call DEBTRANS From GLOCK
If PARAM(6) <> ""
   If clalev([F:MTA]) = 0 : Local File MTKCRDASW [MTA] : Endif
   Trbegin [MTA]
Else
   If clalev([F:QLW]) = 0 : Local File QLYWRK    [QLW] : Endif
   Trbegin [QLW]
Endif
#                                         hcb V6CQ fin


Call ECRFIC2(PARAM(6), val(PARAM(04)), PARAM(7), val(PARAM(2)))

#                                         hcb V6CQ deb
#---- Enregistrement de la nouvelle fiche  ----#
If [M:QLY0]RPLQLYCRD <> ""
   If clalev([F:MFO]) = 0 : Local File MFGOPE [MFO] : Endif
   Local Char LMABR(10)
   LMABR  = "[M:"+PARAM(9)+"]"
   Default Mask LMABR
   Readlock [MFO]MFO0= PARAM(7);val(PARAM(2));val(PARAM(7))
   If fstat
      Call FSTA("MFO") From GLOCK
      GOK = 0
   Endif
   If [F:MFO]TECCRD <> [M:QLY0]RPLQLYCRD
      [F:MFO]TECCRD =  [M:QLY0]RPLQLYCRD
      Rewrite [MFO]
      If fstat
         Call FSTA("MFO") From GLOCK
         GOK = 0
      Endif
      Assign LMABR+"TECCRD(val(PARAM(11)))" With [M:QLY0]RPLQLYCRD
      If PARAM(9) <> "MTK1"
          Affzo = LMABR+"TECCRD(val(PARAM(11)))"
      Endif
   Endif
Endif

If GOK
   Commit
Else
   Rollback
Endif
#                                         hcb V6CQ fin

FIN = 1
Return

############################################################
$ENR_SAIPROCRD
Call VERFIC([M:QLY0]QLYCRD,W_QNB,W_REP,W_RMA,W_BLO,W_BLS,W_NEW,W_MSG,W_RET)  # hcb V6CQ
If W_RMA > 0
  GERR     = 2
  GMESSAGE = mess(62,196,1)+" : "+num$(W_RMA)+"\"+mid$(W_MSG,1,len(W_MSG)-2)
  If mod([M:QLY0]OBL,4)>=2
    GERR=1
    FIN=0
    Return
  Endif
Endif
Call ECRFIC3(val(PARAM(05)),PARAM(02), val(PARAM(03)),PARAM(04),0)  # mm 03.11
FIN = 1
Return

############################################################
# Bouton abandon
$ABA_SAIQLYCRD
Gosub DEBUT_SAIQLYCRD
Return

############################################################
# Bouton abandon
$ABA_SAITECCRD
Gosub DEBUT_SAITECCRD
Return

############################################################
# Bouton abandon
$ABA_SAIPROCRD
Gosub DEBUT_SAIPROCRD
Return

############################################################
# 117343 mm 09.2016
$APCHOIX_SAIPROCRD
If REPONSE = GSTAEND  # end button
  If PARAM(07) = "2"   # mandatory process
     Call VERFIC([M:QLY0]QLYCRD,W_QNB,W_REP,W_RMA,W_BLO,W_BLS,W_NEW,W_MSG,W_RET)
     If W_RMA <>0
        GMESSAGE = mess(889,197,1) : GERR = 1
        Raz REPONSE
     Endif
  Endif
Endif

Return

############################################################
# Nom du masque écran pour la fiche technique
$CHARG_MSK
If dim(W_MSK)<0 : GOK=0 : Return Endif

Local    Char    W_SEQ(8)   # FQ 68372 GA 10/2010 avant (05)  pb si + 99999 fiches techniques (traçabilité)
If    [F:QLC]SEQ<100000
   W_SEQ = format$("N0:5#",[F:QLC]SEQ)
Elsif [F:QLC]SEQ<1000000
   W_SEQ = format$("N0:6#",[F:QLC]SEQ)
Else
   Call ECR_TRACE(LAPP-LFIC-num$([F:QLC]SEQ),-1) From GESECRAN
   GOK=0
Endif
W_MSK = "WUQ"+W_SEQ
Return

############################################################
# Sous programme de generation de la fenetre de saisie des reponses
# LAPP = Dossier
############################################################
Subprog GENCRD(LAPP,LREF,LWRE,LFIC)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LWRE
Value    Char    LFIC
#
If clalev([F:ADS1])= 0 : Local File ADOSSIER           [ADS1]  : Endif
If clalev([F:QLC]) = 0 : Local File =LAPP+".QLYCRD"    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File =LAPP+".QLYCRDQST" [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File =LAPP+".TABCTL"    [TCT]   : Endif
If clalev([F:AMK1])= 0 : Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 : Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 : Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 : Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 : Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 : Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 : Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 : Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 : Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 : Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 : Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 : Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 : Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 : Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 : Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 : Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
If clalev([F:AWI1])= 0 : Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
#
#  Ouverture des tables pour delmsk et delwin  cc et hcb 74033 22/05/2011

If clalev([F:AMK]) = 0 : Local File =LAPP+".AMSK"      [AMK]   : Endif
If clalev([F:AMZ]) = 0 : Local File =LAPP+".AMSKZON"   [AMZ]   : Endif
If clalev([F:AMA]) = 0 : Local File =LAPP+".AMSKACT"   [AMA]   : Endif
If clalev([F:AMP]) = 0 : Local File =LAPP+".AMSKPAR"   [AMP]   : Endif
If clalev([F:AWI]) = 0 : Local File =LAPP+".AWINDOW"   [AWI]   : Endif
If clalev([F:AWP]) = 0 : Local File =LAPP+".AWINPAR"   [AWP]   : Endif
If clalev([F:AWB]) = 0 : Local File =LAPP+".AWINBRO"   [AWB]   : Endif
If clalev([F:AWT]) = 0 : Local File =LAPP+".AWINBOUT"  [AWT]   : Endif
If clalev([F:ADS]) = 0 : Local File ADOSSIER           [ADS]   : Endif

Local    Char    W_MSK
Local    Char    W_ONG
Local    Char    W_FLD
Local    Char    W_SEQ(8)   # FQ 68372 GA 10/2010 avant W_SEQ(05)
Local    Integer W_MAX
Local    Integer W_NUM
Local    Integer W_I, W_J, W_K, W_L
Local    Char    W_ABR(15) : W_ABR = "ABCDEFGHIJKLMNO"
#
GOK=1  # FQ 68372 GA 10/2010

# Lecture parametres dossier
If  [F:ADS1]DOSSIER<>LAPP                    # hcb CC 74033
    Read [ADS1]DOSSIER=LAPP
    If fstat
       Call RSTA("ADS1",LAPP) From GLOCK
       Goto GEN_FIC_FIN
    Endif
Endif                                      # hcb CC 74033
#
#                                     # hcb 105126 deb
# Lecture de la fiche technique 1ère ligne
#Read [QLC]QLC0=LFIC;1
#If fstat
#  GOK = 0
#  Call FSTA("QLC") From GLOCK
#  Goto GEN_FIC_FIN
#Endif

Filter [QLC] Where QLYCRD = LFIC
   Look [QLC]QLC0 First
   If fstat
      GOK = 0
      Call FSTA("QLC") From GLOCK
      Goto GEN_FIC_FIN
   Else
      Read [QLC] Curr
   Endif
Filter [QLC]
#                                     # hcb 105126 deb



#
# FQ 68372 GA 10/2010 pb de volume
Gosub CHARG_MSK
If !GOK End Endif

# Lecture onglet de reference
Read [AMK1]CODMSK=LREF
If fstat
  GOK = 0
  Call FSTA("AMK1") From GLOCK
  Goto GEN_FIC_FIN
Endif
#
W_MAX = [F:AMK1]NBRLIG-1
#
Local Char    W_TEX(100)(W_MAX)               # FGR 24/09/2009 : X3SUIVI58062 passé à 100 au lieu de 50
Local Char    W_QST(GLONQST)(W_MAX)
Local Integer W_TYP    (W_MAX)
Local Integer W_STD    (W_MAX)
Local Integer W_CTL    (W_MAX)
Local Char    W_TCT(05)(W_MAX)
Local Char    W_INT(100)(W_MAX)               # FGR 24/09/2009 : X3SUIVI58062 passé à 100 au lieu de 20
Local Char    W_DEF(22)(W_MAX)
Local Integer W_LOK    (W_MAX)                # Hcb V6QC

# Lecture fenêtre
Read [AWI1]AWI0=W_MSK        # hcb CC 74033
If fstat<>0                  # hcb CC 74033
   Goto GENCREAT             # hcb CC 74033
Endif                        # hcb CC 74033


#
# Effacement ancien masque
#
Global Integer GOPTIMMIG                    # hcb CC 74033
#For W_I = 1 To dim([F:AMK1]TYPBLOC)        # hcb CC 74033
For W_I = 1 To [F:AWI1]NBMSK                # hcb CC 74033
#  W_ONG = W_MSK+mid$(W_ABR,W_I,1)          # hcb CC 74033
  W_ONG=[F:AWI1]NOMMSK(W_I-1)               # hcb CC 74033
  Read [AMK2]CODMSK = W_ONG
  If fstat <> 5                             # hcb CC 74033
#  If fstat = 0   hcb 38951
     Call DELMSK(W_ONG,LAPP) From MSKDIV
  Endif                                     # hcb CC 74033
Next W_I
# Effacement fenetre
#Read [AWI1]AWI0=W_MSK                      # hcb CC 74033
#  If fstat = 0   hcb 38951
Call DELWIN(W_MSK,LAPP) From MSKDIV
#  Endif          hcb 38951
Kill GOPTIMMIG                              # hcb CC 74033
$GENCREAT                                   # hcb CC 74033
# Generation des onglets
W_I = 0
W_J = 1
#-- Lecture et remplissage si existe
Filter [QLC] Where QLYCRD=LFIC
For [QLC]
  #===========================================================================================
  # FGR 24/09/2009 : X3SUIVI58062
  #W_TEX (W_I) = [F:QLC]TEX
  #Call SUPQUO(W_TEX(W_I))
  #Call LECTEXTRA(W_TEX(W_I),"QLYCRD","QSTTEXAXX",[F:QLC]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA
  W_TEX (W_I) = "func CRDLIB.GETQSTTEXAXX('" + [F:QLC]QLYCRD + "'," + num$([F:QLC]NUMLIN) + ")"
  #===========================================================================================
  #-- S'il s'agit d'une question
  If [F:QLC]QSTNUM <> ""
    Read [QLQ]QLQ0=[F:QLC]QSTNUM
    If fstat = 0
      W_QST   (W_I) = [F:QLC]QSTNUM
      W_TYP   (W_I) = [F:QLQ]DEMASWTYP
      W_CTL   (W_I) = [F:QLQ]DEMCTLTYP
      W_STD   (W_I) = [F:QLQ]OSDASW
      W_TCT   (W_I) = [F:QLQ]TCT
      W_LOK   (W_I) = [F:QLQ]LOKTYP                      # hcb V6cq
      #===========================================================================================
      # FGR 24/09/2009 : X3SUIVI58062
      # S'il n'y a pas d'intitulé de questions
      # FQ 53410 champ supprimé If [F:QLQ]QSTDES = ""
      #Call LECTEXTRA(W_INT   (W_I),"QLYCRDQST","QSTSHOAXX",[F:QLQ]QSTNUM,"") From ATEXTRA
      # Else
      #If W_INT="" # si rien trouvé dans QSTSHOAXX, on prend QSTDESAXX
      #  Call LECTEXTRA(W_INT   (W_I),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA
      #Endif
      #Call SUPQUO(W_INT(W_I))
      W_INT (W_I) = "func CRDLIB.GETQSTSHOAXX('" + [F:QLQ]QSTNUM + "')"
      #===========================================================================================
      Case [F:QLQ]DEMASWTYP
        When 1       : W_DEF   (W_I) = '"'+[F:QLQ]ALPDEFASW+'"'
        When 2       : W_DEF   (W_I) = num$([F:QLQ]NUMDEFASW)
        When 4       : W_DEF   (W_I) = num$([F:QLQ]NUMDEFASW+1)
        When Default : W_DEF   (W_I) = ""
      Endcase
      W_I += 1
    Endif
  #-- Ce n'est pas une question
  Else
    W_QST   (W_I) = ""
    W_TYP   (W_I) = 0
    W_CTL   (W_I) = 0
    W_STD   (W_I) = 0
    W_TCT   (W_I) = ""
    W_INT   (W_I) = ""
    W_DEF   (W_I) = ""
    W_LOK   (W_I) = 0                                  # hcb V6cq

    W_I += 1
  Endif
  GPOINT = "QLQGENCRD"                # hcb 65940
  Gosub ENTREE From EXEFNC
  If W_I = W_MAX
    Gosub GEN_ONGLET
    W_J += 1
  Endif
Next
Filter [QLC]
If W_I > 0
  Gosub GEN_ONGLET
  W_J += 1
Endif
# Creation de la fenetre
Read [AWI1]AWI0=LWRE
If fstat = 0
  [F:AWI2]          = [F:AWI1]
  [F:AWI2]WIN       = W_MSK
  For W_L = 0 To W_J-2
    [F:AWI2]NOMMSK (W_L) = W_MSK+mid$(W_ABR,W_L+1,1)
    [F:AWI2]INTMSK (W_L) = W_L+21810
    If GFONCTION1="GESQLC"
      [F:AWI2]INTMSK (W_L) = 2360
    Endif
    [F:AWI2]ROWMSK (W_L) = (W_L+1)*5
    [F:AWI2]FLGMSK (W_L) = 2
  Next W_L
  [F:AWI2]NBMSK = W_J-1
  Write [AWI2]
  If fstat
    Call FSTA("AWI2") From GLOCK
    Goto GEN_FIC_FIN
  Endif
  Filter [AWP1] Where WIN = LWRE
  For [AWP1]
    [F:AWP2]    = [F:AWP1]
    [F:AWP2]WIN = W_MSK
    Write [AWP2]
    If fstat
      Call FSTA("AWP2") From GLOCK
      Break
    Endif
  Next
  Filter [AWP1]
  Filter [AWT1] Where WIN = LWRE
  For [AWT1]
    [F:AWT2]    = [F:AWT1]
    [F:AWT2]WIN = W_MSK
    Write [AWT2]
    If fstat
      Call FSTA("AWT2") From GLOCK
      Break
    Endif
  Next
  Filter [AWT1]
  Filter [AWB1] Where WIN = LWRE
  For [AWB1]
    [F:AWB2]    = [F:AWB1]
    [F:AWB2]WIN = W_MSK
    Write [AWB2]
    If fstat
      Call FSTA("AWB2") From GLOCK
      Break
    Endif
  Next
  Filter [AWB1]
  Call VALID(W_MSK,LAPP,0,W_K) From VALWIN
Else
  Call FSTA("AWI1") From GLOCK
  GOK = 0
Endif
$GEN_FIC_FIN
End

############################################################
# FGR 24/09/2009 : X3SUIVI58062
Funprog GETQSTTEXAXX(SQLYCRD, INUMLIN)
Value Char SQLYCRD
Value Integer INUMLIN

Local Char SARENDRE(50)

  Call LECTEXTRA(SARENDRE,"QLYCRD","QSTTEXAXX",SQLYCRD,num$(INUMLIN)) From ATEXTRA
End SARENDRE

############################################################
# FGR 24/09/2009 : X3SUIVI58062
Funprog GETQSTSHOAXX(SQSTNUM)
Value Char SQSTNUM

Local Char SARENDRE(50)

  # Le long prime sur le court
  # FQ 53410 champ supprimé If [F:QLQ]QSTDES = ""
  #Call LECTEXTRA(SARENDRE,"QLYCRDQST","QSTSHOAXX",SQSTNUM,"") From ATEXTRA
  Call LECTEXTRA(SARENDRE,"QLYCRDQST","QSTDESAXX",SQSTNUM,"") From ATEXTRA
  # Else
  If SARENDRE="" # si rien trouvé dans QSTSHOAXX, on prend QSTDESAXX
    #Call LECTEXTRA(SARENDRE,"QLYCRDQST","QSTDESAXX",SQSTNUM,"") From ATEXTRA
    Call LECTEXTRA(SARENDRE,"QLYCRDQST","QSTSHOAXX",SQSTNUM,"") From ATEXTRA
  Endif
End SARENDRE

############################################################
# Suppression des carcateres quote et remplacement par simple quote
Subprog SUPQUO(LSTR)
Variable Char LSTR
#
Local Integer W_I
W_I = instr(1,LSTR,'"')
While W_I > 0
  LSTR = left$(LSTR,W_I-1)+"'"+right$(LSTR,W_I+1)
  W_I = instr(1,LSTR,'"')
Wend
End
############################################################
$GEN_ONGLET

# Ecriture AMSK
[F:AMK2]       = [F:AMK1]
[F:AMK2]CODMSK = W_MSK+mid$(W_ABR,W_J,1)
[F:AMK2]ABRMSK = "QLY"+mid$(W_ABR,W_J,1)
[F:AMK2]NBRLIG = W_I+1
[F:AMK2]MDL    = 1
W_ONG          = [F:AMK2]CODMSK
Write [AMK2]
If fstat
  Call FSTA("AMK2") From GLOCK
  GOK =0
  Goto GEN_ONGLET_FIN
Endif
# Mise à jour AMSKZON
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
For [AMZ1]
  [F:AMZ2]       = [F:AMZ1]
  [F:AMZ2]CODMSK = [F:AMK2]CODMSK
  Case [F:AMZ1]CODZON
    When "TEX" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_TEX(W_I) <> ""
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "TEX"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          #-- Valeur par défaut

          # FGR 24/09/2009 : X3SUIVI58062
          If left$(W_TEX(W_I), len("func ")) = "func " Then
            [F:AMZ2]VALDEF  = W_TEX(W_I)
          Else
            [F:AMZ2]VALDEF  = '"'+W_TEX(W_I)+'"'
          Endif

          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK1
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
    When "OBS" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_QST(W_I) <> ""
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "OBS"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK3
          If GOK <> 1
            Break 2
          Endif
        Else
         #Gbn-117358
          Local Char S_OPTSAI
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "OBS"+format$("N0:3#",W_NUM)
          #S_OPTSAI        = [F:AMZ2]OPTSAI
          [F:AMZ2]CODZON  = W_FLD
          # Issue 99277 - 2018-08-29 by MAE : passage de type A en type W pour responsive UI
          #[F:AMZ2]OPTSAI  = "W"
          [F:AMZ2]CODTYP = "W"
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          #[F:AMZ2]OPTSAI = S_OPTSAI
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
    When "FLD" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      #-- Question
      For W_I = 0 To W_MAX-1
        If W_QST(W_I) <> ""
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "FLD"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD

          # FGR 24/09/2009 : X3SUIVI58062
          If left$(W_INT(W_I), len("func ")) = "func " Then
            [F:AMZ2]INTEVAL = W_INT(W_I)
          Else
            [F:AMZ2]INTEVAL = '"'+W_INT(W_I)+'"'
          Endif

          [F:AMZ2]VALDEF  = W_DEF(W_I)
          # Issue 95415 - 2014-02-24 by SR : Gérer les propriétés du type Clob = 7
          Case W_TYP(W_I)
            When 1,7 :
              [F:AMZ2]CODTYP   = "A"
              [F:AMZ2]LONG     = 50                   # hcb V6CQ
              [F:AMZ2]OPTSAI   = ""
              [F:AMZ2]TYPGRAPH = 1
              [F:AMZ2]NOLIB    = 0
            When 2 :
              [F:AMZ2]CODTYP = "DCB"
              [F:AMZ2]LONG   = 20
              [F:AMZ2]OPTSAI = "F"
              [F:AMZ2]TYPGRAPH = 1
              [F:AMZ2]NOLIB    = 0
            When 3 :
              [F:AMZ2]CODTYP = "D"
              [F:AMZ2]LONG   = 0
              [F:AMZ2]OPTSAI = "Zz2"
              [F:AMZ2]TYPGRAPH = 1
              [F:AMZ2]NOLIB    = 0
            When 4 :
              [F:AMZ2]CODTYP = "M"
              [F:AMZ2]LONG   = 20
              [F:AMZ2]OPTSAI = ""
              [F:AMZ2]TYPGRAPH = 2
              [F:AMZ2]NOLIB    = 1
          Endcase
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK2
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
    When "STD" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        #Gbn-117358
        If W_QST(W_I) <> ""
            W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
            W_FLD           = "STD"+format$("N0:3#",W_NUM)
            [F:AMZ2]CODZON  = W_FLD
            [F:AMZ2]VALDEF = '""'
            Write [AMZ2]
            If fstat
              Call FSTA("AMZ2") From GLOCK
              GOK = 0
            Endif
            Gosub COP_PARMSK1
            If GOK <> 1
              Break 2
            Endif
         Else
          # Issue 99277 - 2018-08-29 by MAE : en type W si rien de saisie
          Local Char S_OPTSAI
          Local Integer S_INTIT
          Local Integer S_SAIAFF
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "STD"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          #S_OPTSAI = [F:AMZ2]OPTSAI
          #S_INTIT  = [F:AMZ2]INTIT
          #S_SAIAFF = [F:AMZ2]SAIAFF
          # Issue 99277 - 2018-08-29 by MAE : passage de type A en type W pour responsive UI
          #[F:AMZ2]OPTSAI  = "W"
          [F:AMZ2]CODTYP = "W"
          [F:AMZ2]INTIT  = 0
          [F:AMZ2]SAIAFF = 2
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          #[F:AMZ2]OPTSAI = S_OPTSAI
          #[F:AMZ2]INTIT  = S_INTIT
          #[F:AMZ2]SAIAFF = S_SAIAFF
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
    When "QST" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_QST(W_I) <> ""
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "QST"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          [F:AMZ2]VALDEF = '"'+W_QST(W_I)+'"'
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK1
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
    When "TYP" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_QST(W_I) <> ""
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "TYP"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          [F:AMZ2]VALDEF  = num$(W_TYP(W_I))
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK1
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
#                                                   hcb V6CQ  deb
#            Rubrique Nouvelle fiche  (uniquement si type blocage de la reponse = nouvelle fiche)
    When "RPL" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_LOK(W_I) = 4 & W_QST(W_I) <> ""   # hcb 74031
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "RPL"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
#
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK4
          If GOK <> 1
            Break 2
          Endif
        Else
          #Gbn-117358
          Local Char S_OPTSAI
          Local Integer S_INTIT
          Local Integer S_SAIAFF
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "RPL"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
          #S_OPTSAI = [F:AMZ2]OPTSAI
          #S_INTIT  = [F:AMZ2]INTIT
          #S_SAIAFF = [F:AMZ2]SAIAFF
          # Issue 99277 - 2018-08-29 by MAE : passage de type A en type W pour responsive UI
          #[F:AMZ2]OPTSAI  = "W"
          [F:AMZ2]CODTYP = "W"
          [F:AMZ2]INTIT  = 0
          [F:AMZ2]SAIAFF = 2
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          #[F:AMZ2]OPTSAI = S_OPTSAI
          #[F:AMZ2]INTIT  = S_INTIT
          #[F:AMZ2]SAIAFF = S_SAIAFF
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I
#            Rubrique Saisie  (uniquement si type blocage de la reponse = nouvelle fiche)
#            sert à desactiver rubrique RPL (nouvelle fiche) en avant saisie

    When "FLG" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_LOK(W_I) = 4 & W_QST(W_I) <> ""   # hcb 74031
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "FLG"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
#
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK1
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I

#            Rubrique RPF  (uniquement si type blocage de la reponse = nouvelle fiche)
#            sert à stocker la nouvelle fiche par défaut

    When "RPF" :
      [F:AMZ2]NOZONE = [F:AMZ1]NOZONE
      For W_I = 0 To W_MAX-1
        If W_LOK(W_I) = 4 & W_QST(W_I) <> ""   # hcb 74031
          W_NUM           = ((W_J-1)*W_MAX)+(W_I+1)
          W_FLD           = "RPF"+format$("N0:3#",W_NUM)
          [F:AMZ2]CODZON  = W_FLD
#
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK = 0
          Endif
          Gosub COP_PARMSK1
          If GOK <> 1
            Break 2
          Endif
        Endif
        [F:AMZ2]NOZONE += 1
      Next W_I

#                                                   hcb V6CQ  fin


    When Default :
#                                 # hcb  107257 deb
     Raz GPE
     GPOINT = "GEN_ONGLET"
     Gosub ENTREE From EXEFNC
     If GPE = 0
#                                 # hcb  107257 fin
        W_FLD = [F:AMZ2]CODZON
        Gosub COP_PARMSK1
        If GOK <> 1
           Break
        Endif
     Endif                           # hcb  107257
  Endcase
Next
Filter [AMZ1]
# Validation onglet
Call VALID(W_ONG,LAPP,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_K) From VALMSK
Raz W_I, W_TEX, W_QST, W_TYP, W_STD, W_CTL, W_TCT, W_INT
Return
############################################################
$GEN_ONGLET_FIN
Return
############################################################
$COP_PARMSK1
Filter [AMA1] Where TYPAFF = 1              &
&                   CODAFF = LREF           &
&                   CODZON = [F:AMZ1]CODZON
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2]       = [F:AMA1]
  [F:AMA2]CODAFF = [F:AMK2]CODMSK
  [F:AMA2]CODZON = W_FLD
  Write [AMA2]
  If fstat
    Call FSTA("AMA2") From GLOCK
    GOK =0
    Break
  Endif
Next
Filter [AMA1]
#
Filter [AMP1] Where TYPAFF = 1              &
&                   CODAFF = LREF           &
&                   CODZON = [F:AMZ1]CODZON
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2]       = [F:AMP1]
  [F:AMP2]CODAFF = [F:AMK2]CODMSK
  [F:AMP2]CODZON = W_FLD
  Write [AMP2]
  If fstat
    Call FSTA("AMP2") From GLOCK
    GOK = 0
    Break
  Endif
Next
Filter [AMP1]
Return
############################################################
$COP_PARMSK2
#                                 traitement rubrique FLDxxx  (réponses)
Filter [AMA1] Where TYPAFF = 1     &
&                   CODAFF = LREF  &
&                   CODZON = "FLD"
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2]       = [F:AMA1]
  [F:AMA2]CODAFF = [F:AMK2]CODMSK
  [F:AMA2]CODZON = W_FLD
  Case [F:AMA1]TYPACT
    When 4 :
      Case [F:AMA1]ACTION
        When "CRDASALP" :
          Case W_TYP(W_I)
            When  1 : [F:AMA2]ACTION = "CRDASALP"
            When  2 : [F:AMA2]ACTION = "CRDASNUM"
            When  3 : [F:AMA2]ACTION = "CRDASDAT"
            When  4 : [F:AMA2]ACTION = "CRDASBOO"
          Endcase
          Write [AMA2]
          If fstat
            Call FSTA("AMA2") From GLOCK
            GOK = 0
            Break
          Endif
      Endcase
    When 5 :
      Case W_TYP(W_I)
        When  1 : [F:AMA2]ACTION = "CRDCTRALP"
        When  2 : [F:AMA2]ACTION = "CRDCTRNUM"
        When  3 : [F:AMA2]ACTION = "CRDCTRDAT"
        When  4 : [F:AMA2]ACTION = "CRDCTRBOO"
      Endcase
      Write [AMA2]
      If fstat
        Call FSTA("AMA2") From GLOCK
        GOK = 0
        Break
      Endif
    When 7 :
      Case [F:AMA1]ACTION
        When "CRDAMALP"
          Case W_TYP(W_I)
            When  1 : [F:AMA2]ACTION = "CRDAMALP"
            When  2 : [F:AMA2]ACTION = "CRDAMNUM"
            When  3 : [F:AMA2]ACTION = "CRDAMDAT"
            When  4 : [F:AMA2]ACTION = "CRDAMBOO"
          Endcase
          Write [AMA2]
          If fstat
            Call FSTA("AMA2") From GLOCK
            GOK = 0
            Break
          Endif
      Endcase
    When 8 :
      Case [F:AMA1]ACTION
        When "SELTCTCRD" :
          If W_TCT(W_I) <> ""
            Write [AMA2]
            If fstat
              Call FSTA("AMA2") From GLOCK
              GOK = 0
              Break
            Endif
          Endif
      Endcase
    When 10 :
      Case [F:AMA1]ACTION
        When "VISUQST" :
          Write [AMA2]
          If fstat
            Call FSTA("AMA2") From GLOCK
            GOK = 0
            Break
          Endif
      Endcase
# hcb 36819
    When Default :
      GPOINT = "PEQLYA"
      Gosub ENTREE From EXEFNC
      If GOK <> 1           #hcb 37201
         Break              #hcb 37201
      Endif                 #hcb 37201
# hcb 36819
  Endcase
Next
Filter [AMA1]
#
Filter [AMP1] Where TYPAFF = 1     &
&                   CODAFF = LREF  &
&                   CODZON = "FLD"
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2]       = [F:AMP1]
  [F:AMP2]CODAFF = [F:AMK2]CODMSK
  [F:AMP2]CODZON = W_FLD
  Case [F:AMP1]CODPAR
    When "QSTNUM" :
      [F:AMP2]VALPAR = '"'+W_QST(W_I)+'"'
      Write [AMP2]
      If fstat
        Call FSTA("AMP2") From GLOCK
        GOK =0
        Break
      Endif
    When "TCT"    :
      If W_TCT(W_I) <> ""
        [F:AMP2] VALPAR = '"'+W_TCT(W_I)+'"'
        Write [AMP2]
        If fstat
          Call FSTA("AMP2") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    When "FLD" :
      [F:AMP2]VALPAR = '"'+W_FLD+'"'
      Write [AMP2]
      If fstat
        Call FSTA("AMP2") From GLOCK
        GOK = 0
        Break
      Endif
  Endcase
Next
Filter [AMP1]
Return

#                                                           hcb V6CQ deb
############################################################
$COP_PARMSK4
#                                 traitement rubrique RPLxxx  (nouvelle fiche)

Filter [AMA1] Where TYPAFF = 1     &
&                   CODAFF = LREF  &
&                   CODZON = "RPL"
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2]       = [F:AMA1]
  [F:AMA2]CODAFF = [F:AMK2]CODMSK
  [F:AMA2]CODZON = W_FLD
  Case [F:AMA1]TYPACT
    When 4 :
       Case [F:AMA1]ACTION
            When "RPLASALP" :
                 [F:AMA2]ACTION = "RPLASALP"
       Endcase
       Write [AMA2]
       If fstat
          Call FSTA("AMA2") From GLOCK
          GOK = 0
          Break
       Endif
    When 5 :
       Case [F:AMA1]ACTION
            When "RPLCTRALP" :
                 [F:AMA2]ACTION = "RPLCTRALP"
       Endcase
       Write [AMA2]
       If fstat
          Call FSTA("AMA2") From GLOCK
          GOK = 0
          Break
       Endif
    When 7 :
       Case [F:AMA1]ACTION
            When "RPLAMALP"
                 [F:AMA2]ACTION = "RPLAMALP"
       Endcase
       Write [AMA2]
       If fstat
          Call FSTA("AMA2") From GLOCK
          GOK = 0
          Break
       Endif
    When 8 :
       Case [F:AMA1]ACTION
            When "SELOBJW" :
                 [F:AMA2]ACTION = "SELOBJW"
       Endcase
       Write [AMA2]
       If fstat
          Call FSTA("AMA2") From GLOCK
          GOK = 0
          Break
       Endif
    When Default :
       GPOINT = "PEQLYARPL"
       Gosub ENTREE From EXEFNC
       If GOK <> 1
          Break
       Endif
    Endcase
Next
Filter [AMA1]
#
Filter [AMP1] Where TYPAFF = 1     &
&                   CODAFF = LREF  &
&                   CODZON = "RPL"
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2]       = [F:AMP1]
  [F:AMP2]CODAFF = [F:AMK2]CODMSK
  [F:AMP2]CODZON = W_FLD
  Case [F:AMP1]CODPAR
    When "QSTNUM" :
         [F:AMP2]VALPAR = '"'+W_QST(W_I)+'"'
         Write [AMP2]
         If fstat
            Call FSTA("AMP2") From GLOCK
            GOK =0
            Break
         Endif
    When "FLD" :
         [F:AMP2]VALPAR = '"'+W_FLD+'"'
         Write [AMP2]
         If fstat
            Call FSTA("AMP2") From GLOCK
            GOK = 0
            Break
         Endif
    When "OBJET"    :
         [F:AMP2] VALPAR = '"QLC"'
         Write [AMP2]
         If fstat
            Call FSTA("AMP2") From GLOCK
            GOK = 0
            Break
         Endif
    When "OBTIONA"  :
         [F:AMP2] VALPAR = '""'
         Write [AMP2]
         If fstat
            Call FSTA("AMP2") From GLOCK
            GOK = 0
            Break
         Endif
    When "SUPP"     :
         [F:AMP2] VALPAR = '""'
         Write [AMP2]
         If fstat
            Call FSTA("AMP2") From GLOCK
            GOK = 0
            Break
         Endif

  Endcase
Next
Filter [AMP1]

#                                                           hcb V6CQ fin

Return
############################################################
$COP_PARMSK3
Filter [AMA1] Where TYPAFF = 1     &
