############################################################
Subprog CRDAVOBS(OBS,QSTNUM,FLD)
Variable Char    OBS()
Value    Char    QSTNUM
Value    Char    FLD
OBS = ""
Case evalue("[M]TYP"+right$(FLD,4))
  When 1 :
    If evalue("[M]FLD"+right$(FLD,4)+"=''")
      OBS = "->"
    Endif
  When 2 :
    If evalue("[M]FLD"+right$(FLD,4)+"=0")
&    & evalue("[M]STD"+right$(FLD,4))="."
      OBS = "->"
    Endif
  When 3 :
    If evalue("[M]FLD"+right$(FLD,4)+"=[0/0/0]")
      OBS = "->"
    Endif
Endcase
End

#                                                            hcb V6CQ deb
Subprog RPLASALP(ASW,QSTNUM,FLD)
Variable Char    ASW()
Value    Char    QSTNUM
Value    Char    FLD
If evalue("[M]FLG"+right$(FLD,4))= 0
   mkstat = 2
Endif
End

Subprog RPLCTRALP(ASW,QSTNUM,FLD)
Variable Char    ASW()
Value    Char    QSTNUM
Value    Char    FLD
Local    Integer LNBQST : LNBQST = func LASTQST
Local    Integer W_I
Local    Integer I
Local    Char    FXX
Local    Char    W_FLD(10) : W_FLD = ""

If evalue("[M]FLG"+right$(FLD,4)) <> 0 & ASW = ""
   GMESSAGE=mess(10,123,1)   # Zone obligatoire
   mkstat=2
   End
Endif
If ASW <> ""
   If clalev([F:QLC3]) = 0 : Local File QLYCRD [QLC3] : Endif
   Read [QLC3]QLC0= ASW
   If fstat
      GMESSAGE=mess(23,100,1)   # Fiche inexistante
      mkstat=2
   Endif
   If [M:QLY0]RPLQLYCRD <> "" & [M:QLY0]RPLQLYCRD <> ASW
      I= 1
      # une nouvelle fiche à deja ete saisie !
      Call OUINON(mess(298,184,1)+" "+[M:QLY0]RPLQLYCRD+"  "+mess(301,184,1),I) From GESECRAN
      If I = 1
         mkstat = 2
         End
      Else
        [M:QLY0]RPLQLYCRD = ASW
        For W_I = 1 To LNBQST
            If evalue("dim([M]RPL"+format$("N0:3#",W_I)+")>0")
               If  evalue("[M]RPL"+format$("N0:3#",W_I)) <> ""
                   Assign "[M]RPL"+format$("N0:3#",W_I) With ASW
                   FXX      = format$("N0:3#",W_I)
                   Affzo ="RPL"+ FXX
               Endif
            Endif
        Next W_I
      Endif
   Else
      [M:QLY0]RPLQLYCRD = ASW
   Endif
Endif

End

Subprog RPLAMALP(ASW,QSTNUM,FLD)
Variable Char    ASW()
Value    Char    QSTNUM
Value    Char    FLD
If [M:QLY0]RPLQLYCRD = ""
   [M:QLY0]RPLQLYCRD = ASW
Else

Endif



End
#                                                            hcb V6CQ fin

##################################################
# Renvoie le n° de la dernière question
# ex: si 1 ligne de commentaires+2 questions+1ligne de commentaires+1 ligne de question
# => génération de 3 champs question QST002,QST003 et QST005
# => la fonction renvoie 5
Funprog LASTQST
Local Integer LNB,I
LNB = sigma(-999,0,abs(indcum-1)*
&                  (  evalue("dim([M]QST"+format$("N0:3#",abs(indcum))+")")>0
&                   & I=0
&                   & sigma(I=1,1,1) ))-1
End LNB



# Sous programme de chargement des reponses deja saisies
# LFIC  = Numero fiche qualite
# LDEM  = Demande d'analyse
# LSEQ  = Numero de sequence de la fiche lue et chargee
#
$AFF_LIB
Local    Char    ASWA(50)
Local    Integer ASWD
Local    Integer W_I
Local    Integer LNBQST : LNBQST = func LASTQST

Local Char  W_DESTCT(GLONDCT)  # hcb 103874
Local Char  W_FLDTCT(GLONAVA)  # hcb 103874


If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]   : Endif

#
For W_I=1 To LNBQST
    If evalue("dim([M]QST"+format$("N0:3#",W_I)+")>0") & evalue("[M]QST"+format$("N0:3#",W_I)+"<>''")
        QST=evalue("[M]QST"+format$("N0:3#",W_I))
        If evalue("[M]TYP"+format$("N0:3#",W_I)+"=1")
          ASWA=evalue("[M]FLD"+format$("N0:3#",W_I))
        Elsif evalue("[M]TYP"+format$("N0:3#",W_I)+"=2")
          ASWD=evalue("[M]FLD"+format$("N0:3#",W_I))
          ASWA=num$(ASWD)
        Endif
        Read [QLQ]QLQ0=QST
        If fstat = 0
            If [F:QLQ]DEMCTLTYP=1
                Read [TCT]TCT1=[F:QLQ]TCT;ASWA;0
                If !fstat
                    Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB             # hcb 103874
                    Assign "[M]STD"+format$("N0:3#",W_I) With W_DESTCT        # hcb 103874
#                   Assign "[M]STD"+format$("N0:3#",W_I) With [F:TCT]DESCOD   # hcb 103874
                Endif
            Endif
        Endif
    Endif
Next W_I
Return

#########################################################################
# LECSMPCOD  = Lecture et stockage taille echantillon                   #
#              stockés dans la table diverse 103                        #
#########################################################################
Subprog LECSMPCOD

Global Decimal GNBR103
# calcul nombre de code
Raz GNBR103

Filter [ADI] Where [F:ADI]NUMTAB = 103
&               Order By Key CODE
   For [ADI]
       GNBR103 += 1
   Next
Filter [ADI]

Global Decimal GQTY103   (1..GNBR103+1)
Global Integer GSMP103   (1..GNBR103+1)
Global Char    GCOD103(1)(1..GNBR103+1)
Local Integer I
I = 1

Filter [ADI] Where [F:ADI]NUMTAB = 103
&               Order By Key CODE
   For [ADI]
       GQTY103(I) = [F:ADI]N1
       GCOD103(I) = [F:ADI]A1
       GSMP103(I) = [F:ADI]N2
       I += 1
   Next
Filter [ADI]
End


# hcb V6CQ deb
#########################################################################
# CALSMPCOD  = Calcul de l'échantillon et du code                       #
#            Si LTRT = 1  (Détermination automatique)                   #
#               En entrée : Quantité initial du lot                     #
#               En sortie : Le Code de l'échantillon et la taille en UC #
#            Si LTRT = 2  (Modif de l'échantillon par l'utilisateur     #
#               En entrée : Quantité et échantillon en UC               #
#               En sortie : Le Code de l'échantillon                    #
#########################################################################
Subprog CALSMPCOD(LTRT,LQTY,LCODE,LSMP)
Value    Integer LTRT
Value    Decimal LQTY
Variable Char    LCODE
Variable Decimal LSMP

Case LTRT
    When 1 :
        For I = 1 To GNBR103
            If GQTY103(I) >= LQTY : Break : Endif
        Next
        LCODE =  GCOD103(I)
        LSMP  =  GSMP103(I)
    When 2 :
        For I = 1 To GNBR103
            If WSMP103(I) >= LSMP : Break : Endif
        Next
        LCODE =  GCOD103(I)
Endcase

GPOINT = "CALSMPCOD"
Gosub ENTREE From EXEFNC

End


########################################################################
# CALACPPRM = lecture QLYCRDNQA : Echantillonnage critère acceptation  #
#            En entrée : Code NQA de l'article                         #
#                        Code de l'echantillon                         #
#            En sortie : Critère d'acceptation                         #
#            Pre-requis: le fichier QLYCRDNQA doit etre ouvert         #
########################################################################
Subprog CALACPPRM(LNQA,LCODE,LACP)
Value    Integer    LNQA
Value    Char       LCODE
Variable Decimal    LACP
LACP = 0

# Lecture du fichier QLYCRDNQA
Read [NQA]NQA0=1;LNQA;LCODE
If fstat
   Raz [F:NQA]
Endif
LACP = [F:NQA]QTYACP

GPOINT = "CALACPPRM"
Gosub ENTREE From EXEFNC

End
# hcb V6CQ deb

