###########################################################
Subprog CRDCTRALP(ASW,QSTNUM,FLD)
Variable Char    ASW()
Value    Char    QSTNUM
Value    Char    FLD
Local    Integer W_I

Local    Char    WSTRVAL(250)            # hcb V6CQ
Local    Char    WENDVAL(250)            # hcb V6CQ

Local Char  W_DESTCT(GLONDCT)  # hcb 103874
Local Char  W_FLDTCT(GLONAVA)  # hcb 103874

#
Assign "[M]STD"+mid$(FLD,4,3) With ""
#
If ASW <> ""
  Read [QLQ]QLQ0=QSTNUM
  If fstat = 0
     If [F:QLQ]LOKTYP = 4                                        # hcb V6CQ
        Assign ("[M]FLG"+right$(FLD,4)) With 0                   # hcb V6CQ
        Assign ("[M]RPL"+right$(FLD,4)) With ""                  # hcb V6CQ
     Endif                                                       # hcb V6CQ
    Case [F:QLQ]DEMCTLTYP
      When 1 :
        Read [TCT]TCT1=[F:QLQ]TCT;ASW;0
        If fstat
          If [F:QLQ]OSDASW = 2
            If mod([M:QLY0]OBL,8)>=4
                GMESSAGE = mess(78,187,1)  # des changements de status ont deja eu lieu .....
                mkstat=2
            Else
                W_I = 1
                Call AVERTIR([F:QLQ]QSTNUM-[F:QLQ]QSTSHO-":"-mess(60,196,1),W_I) From GESECRAN
                If W_I = 2
                  Assign "[M]STD"+mid$(FLD,4,3) With mess(508,197,1)   # hors standard
                  If [F:QLQ]LOKTYP = 4  & GACTION <> "SAIPROCRD"                         # hcb V6CQ
                     Assign ("[M]FLG"+right$(FLD,4)) With 1                              # hcb V6CQ
                     Assign ("[M]RPL"+right$(FLD,4)) With evalue("[M]RPF"+right$(FLD,4)) # hcb V6CQ
                  Endif                                                                  # hcb V6CQ
                Else
                  mkstat = 2
                Endif
            Endif
          Else
            GMESSAGE = mess(78,184,1)
            mkstat = 2
          Endif
        Else
          Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB             # hcb 103874
          Assign "[M]STD"+mid$(FLD,4,3) With W_DESTCT               # hcb 103874
#         Assign "[M]STD"+mid$(FLD,4,3) With [F:TCT]DESCOD          # hcb 103874
        Endif
      When 2 :
#                                                         bornes
#                                       hcb V6CQ deb
        Raz WSTRVAL
        Raz WENDVAL
        If  [F:QLQ]STRVALFOR <> ""
            Call VALTFO_CHAR(32,[F:QLQ]STRVALFOR,WSTRVAL) From SUBTFO
        Endif
        If  [F:QLQ]ENDVALFOR <> ""
            Call VALTFO_CHAR(32,[F:QLQ]ENDVALFOR,WENDVAL) From SUBTFO
        Endif
        If  [F:QLQ]ALPSTRVAL <> ""
            WSTRVAL = [F:QLQ]ALPSTRVAL
        Endif
        If  [F:QLQ]ALPENDVAL <> ""
            WENDVAL = [F:QLQ]ALPENDVAL
        Endif

 #                                       hcb V6CQ fin

#       If ASW < [F:QLQ]ALPSTRVAL | ASW > [F:QLQ]ALPENDVAL               # hcb V6CQ
        If ASW < WSTRVAL | ASW > WENDVAL                                 # hcb V6CQ
          If [F:QLQ]OSDASW = 2
            If mod([M:QLY0]OBL,8)>=4
                GMESSAGE = mess(78,187,1)
                mkstat=2
            Else
                W_I = 1
                Call AVERTIR([F:QLQ]QSTNUM-[F:QLQ]QSTSHO-":"-mess(60,196,1),W_I) From GESECRAN
                If W_I = 2
                  Assign "[M]STD"+mid$(FLD,4,3) With mess(508,197,1)
                  If [F:QLQ]LOKTYP = 4 & GACTION <> "SAIPROCRD"                          # hcb V6CQ
                     Assign ("[M]FLG"+right$(FLD,4)) With 1                              # hcb V6CQ
                     Assign ("[M]RPL"+right$(FLD,4)) With evalue("[M]RPF"+right$(FLD,4)) # hcb V6CQ
                  Endif                                                                  # hcb V6CQ
                Else
                  mkstat = 2
                Endif
            Endif
          Else
            GMESSAGE = [F:QLQ]QSTNUM-[F:QLQ]QSTSHO
            GMESSAGE+= mess(78,184,1)
            GMESSAGE+= "\>= "-WSTRVAL+"\<="-WENDVAL                       # hcb V6CQ
            mkstat = 2
          Endif
        Endif
      When 3 :
    Endcase
  Endif
# hcb 34626
GPOINT = "PECRDCTR"
Gosub ENTREE From EXEFNC
# hcb 34626


Endif
End
############################################################
Subprog CRDCTRNUM(ASW,QSTNUM,FLD)
Variable Decimal ASW()
Value    Char    QSTNUM
Value    Char    FLD
Local    Integer W_I

Local    Decimal WSTRNUM                 # hcb V6CQ
Local    Decimal WENDNUM                 # hcb V6CQ
Local    Integer WDEC                    # hcb V6CQ
Local    Decimal WQTE                    # hcb V6CQ

Local Char  W_DESTCT(GLONDCT)  # hcb 103874
Local Char  W_FLDTCT(GLONAVA)  # hcb 103874

#
Assign "[M]STD"+mid$(FLD,4,3) With ""
#
#If ASW <> 0    : # Bug 28399 - TS
  Read [QLQ]QLQ0=QSTNUM
  If fstat = 0
# hcb V6CQ deb
     If [F:QLQ]LOKTYP = 4
         Assign ("[M]FLG"+right$(FLD,4)) With 0
         Assign ("[M]RPL"+right$(FLD,4)) With ""
     Endif
# Controle nombre de décimale
     WQTE = ASW
     WQTE = WQTE - int(WQTE)
     WDEC = 0
     While WQTE <> int(WQTE)
           WQTE *= 10
           WDEC += 1
     Wend
     If WDEC > [F:QLQ]UOMDEC
        GMESSAGE = mess(303,184,1)  # Nombre de décimales incorrecte  !
        mkstat = 2
        End
     Endif
# hcb V6CQ fin
     Case [F:QLQ]DEMCTLTYP
      When 1 :
        Read [TCT]TCT1=[F:QLQ]TCT;"";ASW
        If fstat
          If [F:QLQ]OSDASW = 2
            If mod([M:QLY0]OBL,8)>=4
                GMESSAGE = mess(78,187,1)
                mkstat=2
            Else
                W_I = 1
                Call AVERTIR([F:QLQ]QSTNUM-[F:QLQ]QSTSHO-":"-mess(60,196,1),W_I) From GESECRAN
                If W_I = 2
                  Assign "[M]STD"+mid$(FLD,4,3) With mess(508,197,1)
                  If [F:QLQ]LOKTYP = 4 & GACTION <> "SAIPROCRD"                          # hcb V6CQ
                     Assign ("[M]FLG"+right$(FLD,4)) With 1                              # hcb V6CQ
                     Assign ("[M]RPL"+right$(FLD,4)) With evalue("[M]RPF"+right$(FLD,4)) # hcb V6CQ
                  Endif                                                                  # hcb V6CQ
                Else
                  mkstat = 2
                Endif
            Endif
          Else
            GMESSAGE = mess(78,184,1)
            mkstat = 2
          Endif
        Else
          Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB             # hcb 103874
          Assign "[M]STD"+mid$(FLD,4,3) With W_DESTCT               # hcb 103874
#         Assign "[M]STD"+mid$(FLD,4,3) With [F:TCT]DESCOD          # hcb 103874
        Endif
      When 2 :
#                                                         bornes
#                                       hcb V6CQ deb
        Raz WSTRNUM
        Raz WENDNUM
        If  [F:QLQ]STRVALFOR <> ""
            Call VALTFO_NUM(32,[F:QLQ]STRVALFOR,WSTRNUM) From SUBTFO
        Endif
        If  [F:QLQ]ENDVALFOR <> ""
            Call VALTFO_NUM(32,[F:QLQ]ENDVALFOR,WENDNUM) From SUBTFO
        Endif
        If  [F:QLQ]NUMSTRVAL <> 0
            WSTRNUM = [F:QLQ]NUMSTRVAL
        Endif
        If  [F:QLQ]NUMENDVAL <> 0
            WENDNUM = [F:QLQ]NUMENDVAL
        Endif
#                                       hcb V6CQ fin
#       If ASW < [F:QLQ]NUMSTRVAL | ASW > [F:QLQ]NUMENDVAL               # hcb V6CQ
        If ASW < WSTRNUM | ASW > WENDNUM                                 # hcb V6CQ

          If [F:QLQ]OSDASW = 2
            If mod([M:QLY0]OBL,8)>=4
                GMESSAGE = mess(78,187,1)
                mkstat=2
            Else
                W_I = 1
                Call AVERTIR([F:QLQ]QSTNUM-[F:QLQ]QSTSHO-":"-mess(60,196,1),W_I) From GESECRAN
                If W_I = 2
                  Assign "[M]STD"+mid$(FLD,4,3) With mess(508,197,1)
                  If [F:QLQ]LOKTYP = 4 & GACTION <> "SAIPROCRD"                          # hcb V6CQ
                     Assign ("[M]FLG"+right$(FLD,4)) With 1                              # hcb V6CQ
                     Assign ("[M]RPL"+right$(FLD,4)) With evalue("[M]RPF"+right$(FLD,4)) # hcb V6CQ
                  Endif                                                                  # hcb V6CQ
                Else
                  mkstat = 2
                Endif
            Endif
          Else
            GMESSAGE = [F:QLQ]QSTNUM-[F:QLQ]QSTSHO
            GMESSAGE+="\"+mess(78,184,1)
            GMESSAGE+="\>= "-num$(WSTRNUM)+"\<="-num$(WENDNUM)         # hcb V6CQ
            mkstat = 2
          Endif
        Endif
      When 3 :
    Endcase
  Endif
#Endif    : # Bug 28399 - TS
# hcb 34626
GPOINT = "PECRDCTR"
Gosub ENTREE From EXEFNC
# hcb 34626

End
