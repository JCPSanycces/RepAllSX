If ASW = ""
#  Read [QLQ]QLQ0=QSTNUM  # hcb V6CQ
  If fstat = 0
    ASW = [F:QLQ]ALPDEFASW
  Endif
Endif
GERR = 4    # hcb V6CQ
GMESSAGE = NUMNMN_ATABZON-":"-[F:QLQ]ALPNMNVAL  # hcb V6CQ

End
