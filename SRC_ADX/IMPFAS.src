#<AdxTL>@(#)2.0.0.0 $Revision$
#*********************************************************************
#
#                IMPORT STANDARD DE BIENS COMPTABLES
#
#*********************************************************************
#    Création
#    GLE - 24.02.2009
#
#*********************************************************************
#    Modification
#
#    Issue X3-89781 - 2017-06-12 by MWA   : Issue when importing LOC field
#    Issue X3-63497 - 2017-11-23 by BEFOU : Commenting GREP for Error file
#    CBO - 14.03.2016  FQ115274 Suppression de LOCALIZAT
#    MWA - 29.07.2015  FQ109841 Suppression du traitement lié à PHYFMTCOU
#    MWA - 29.07.2015  FQ109840 Suppression du traitement lié à PHYNUMBCO
#    GLE - 16.06.2015  FR108913 Le paramètre REPDPRCUM n'existait plus depuis la V7, réintroduction en V9
#                               Remarque : aucun source n'est modifié, ce commentaire sert juste de rappel
#    MDJ - 09.02.2015  FQ100398 Suppression site géographique
#    CBO - 29.04.2014  FQ69690  Objet FAM
#    GLE - 24.02.2014  FQ97181  PERREFCLCI et PERREFCLCT ne doivent pas être nuls. Autocorrection avec la valeur de PERREFCLC
#    GLE - 19.02.2014  FQ96987  Correction suite à la fiche FQ96134
#    GLE - 14.02.2014  FQ96106  Ajout d'un message lorsque DPRCUM > DPRVAL
#    GLE - 27.01.2014  FQ95955  Chargement de FASPARCPY pour la création automatique des sections analytiques
#    GLE - 24.01.2014  FQ96134  La société est déduite du site financier
#    MDJ - 20.12.2013  FQ95213  Mauvais nb de paramètres dans GET_NUMERO (manquait la société)
#    MWA - 31.10.2013  FQ75616  Reprise avancée - part 2
#    GLE - 07.10.2013  FQ93198  Les localisations n'étaient pas correctement importées
#    GLE - 24.06.2013  FQ90644  Avertissement si REPDPRCUM est à Non
#    GLE - 13.12.2012  FQ86475  Si le flag de forçage des montants de TVA récupérés PCG et IAS n'est pas explicitement à Oui, il faut considérer que le montant
#                               n'est pas forcé (cas où le flag vaut 0)
#    GLE - 10.09.2012  FQ82293  Import des cumuls dérogatoire début de période PERLEGCUM et PERLEGRVE
#    GLE - 06.07.2012  FQ83143  Import du cumul d'amortissement début de période PERCLOCUM
#    GLE - 20.06.2012  FQ82227  Les actions champs des fenêtres complémentaires n'étaient pas jouées (erreur rubrique ISRCLCBAS obligatoire)
#    GLE - 17.01.2012  FQ79283  Les associations sont écrasées par des valeurs nulles si les champs sont dans le modèle d'import
#    GLE - 17.01.2012  FQ79242  Les actions champs du tableau des amortissements n'étaient pas jouées
#    GLE - 16.05.2011  FQ73850  L'acheteur n'est pas alimenté dans le cas d'une sortie dans l'exercice courant
#    GLE - 31.03.2011  FQ72796 : Forçage de la dotation exercice pour régulariser la saisie d'un cumul de dot. > valeur amortissable
#    GLE - 19.05.2010  FQ64491  Modification pour import Abel Entreprise
#    GLE - 30.06.2010  FQ65744  Erreur sur les éléments physique si le code activité PHY est à Non pour le dossier
#    GLE - 07.04.2010  FQ46184  Correction erreur sur [M:FAS3] lors de l'utilisation du bouton "TEST"
#    GLE - 26.02.2010  FQ62941  Suppression de l'alimentation manuelle des axes ; cette modification va avec la mise à jour de FAS2
#                               (action Init de NBRCCE passe de "Interactive" à "Toujours")
#    GLE - 26.02.2010  FQ62916  Forçage de la dotation exercice : fait à la suite de DPM au lieu de DPRCUM car DPRCUM n'est pas toujours saisissable
#    GLE - 23.02.2010  FQ62830  Biens sortis dans un exercice antérieur : initialisation des dates des exercices courants plus tôt
#    GLE - 01.02.2010  FQ61951  Si une répartition et des axes sont renseignés, seule la répartition est importée
#    GLE - 27.01.2010  FQ61340  Si le montant de TVA facturée n'est pas alimenté dans le fichier d'import, on le force à zéro -> KO
#    GLE - 19.11.2009  FQ61340  Correction dans la trace
#    GLE - 10.11.2009  FQ59686  Lors de l'import de la base et du cumul d'amortissement, il pouvait y avoir l'erreur
#                               "Le cumul d'amortissement ne peut pas être supérieur à la base amortissable (valeur bilan - valeur résiduelle)."
#    GLE - 09.11.2009  FQ59783  Lorsqu'on importe un mode d'amortissement déjà alimenté par une association mais que celle-ci ne
#                               détermine pas la règle particulière, celle-ci est à 0. Initialisation à 1 dans ce cas.
#    GLE - 30.10.2009  FQ59450  Les biens non sortis suivants un bien sortis étaient sortis également + amélioration de la trace d'erreur lors des sorties
#    GLE - 29.10.2009  FQ59447  Possibilité de préciser la règle de sortie (par défaut à "Sortie au jour précisé")
#    GLE - 22.10.2009  FQ59159  L'import de ENDDPE ne fonctionnait pas
#    GLE - 13.07.2009  FQ56478  Appel de l'action de sortie en mode silencieux
#  SYMEU - 04.05.2009  FQ49517  Numérotation des éléments physiques à partir du bien
#
#*********************************************************************

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub IMP_AVANT_OUVRE : # FQ90644
    When "IMP_OUVRE"        : Gosub IMP_OUVRE
    When "IMP_FERME"        : Gosub IMP_FERME
    When "IMPORT"           : Gosub IMPORT

    When "IMP_ZONE"         : Gosub IMP_ZONE
    When "IMP_TAB"          : Gosub IMP_TAB

    When "SET_IMPMOD"       : IMPMOD = 1

    When "IMP_VERIF_CRE"    : Gosub IMP_VERIF_CRE
    When "IMP_INICRE"       : Gosub IMP_INICRE
    When "IMP_CREATION"     : Gosub IMP_CREATION
    When "IMP_APRES_CRE"    : Gosub IMP_APRES_CRE : # FQ56478

    When "AP_IMPORT"        : Gosub AP_IMPORT
    When Default
  Endcase
Return

#################################################################### FQ90644
# Toute première action de l'import
#
$IMP_AVANT_OUVRE
  # Contrôle du paramètre REPDPRCUM qui devrait, sauf cas très particulier, être à Oui
  # Comme ce paramètre est société, on regarde s'il est positionné à Non au moins une fois
  If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif

  Local Integer RETOUR

  Filter [F:ADW] Where PARAM="REPDPRCUM" and VALEUR<>"2"
  If rowcount([F:ADW])>0
    If GSERVEUR
      # Exécution via le serveur batch
      Call ECR_TRACE(mess(909,GML_MSGFAS,1),-1) From GESECRAN
    Else
      GIMPORT = 0
      Call OUINON(mess(909,GML_MSGFAS,1)-mess(205,100,1), RETOUR) From GESECRAN
      GIMPORT = 1
      If (RETOUR = 1) Then
        Call ECR_TRACE(mess(77,GML_MSGCAL,1),-1) From GESECRAN
        OK = 0
      Else
        Call ECR_TRACE(mess(909,GML_MSGFAS,1),-1) From GESECRAN
      Endif
    Endif
  Endif
  Filter [F:ADW]
Return

####################################################################
# Au début de l'import
#
$IMP_OUVRE

  # Contrôle que la mise à jour est bien interdite
  If [M:AOE1]OPTUPD = G_OUI
    OK       = 0
    GERR     = 1
    GMESSAGE = mess(26,141,1)-[M:AOE0]EXT-":"-mess(686,GML_MSGFAS,1)
    Return
  Endif

  # Chargement des masques des quatres fenetres complementaires de la fenetre de gestion
  # des biens comptables

  Local Mask FASISR [FASI]        : # Assurance
  Local Mask FASVEH [FASV]        : # Véhicule
  Local Mask FASNSP [FASN]        : # Valeur marché
  Local Mask FASADV [FASA]        : # Reprise avancée FQ75616
  # Local Mask FASIVY [FASY]        : # Inventaire
  If GPHY = G_OUI : # FQ65744
    # FQ115274
    # Local Mask PHYIVY [PHYY]      : # Inventaire
  Endif
  Local Mask FASPARCPY [FPC]      : # Environnement comptable
  Local Integer RERROR            : # Code retour FQ95955

  Global Char TRTSTD_ISR (12)     : # Traitement standard de l'action du menu Assurance
  Global Char TRTSPE_ISR (12)     : # Traitement spécifique de l'action du menu Assurance
  Global Char TRTSTD_VEH (12)     : # Traitement standard de l'action du menu Véhicule
  Global Char TRTSPE_VEH (12)     : # Traitement spécifique de l'action du menu Véhicule
  Global Char TRTSTD_NSP (12)     : # Traitement standard de l'action du menu Valeur marché
  Global Char TRTSPE_NSP (12)     : # Traitement spécifique de l'action du menu Valeur marché
  Global Char TRTSTD_IVY (12)     : # Traitement standard de l'action du menu Inventaire
  Global Char TRTSPE_IVY (12)     : # Traitement spécifique de l'action du menu Inventaire
  Global Char TRTSTD_ADV (12)     : # Traitement standard de l'action du menu Reprise FQ75616
  Global Char TRTSPE_ADV (12)     : # Traitement spécifique de l'action du menu Reprise FQ75616

  Global Char GSEPDEC             : # Séparateur décimal du modèle d'import FQ64491
  Global Char FORMAT_DATE (8)     : # Format des dates pour l'import FQ75616

  Global Integer CRELOC           : # Indicateur de création auto de la localisation
  Global Integer CREBPR           : # Indicateur de création auto du fournisseur FQ64491
  Global Integer CREACGGRP        : # Indicateur de création auto de la famille
  Global Integer CRECCE(GOPTCANA) : # Indicateur de création auto des sections analytiques
  Global Integer CREUSRFL(10)     : # Indicateur de création auto des zones libres alpha
  Global Integer REPDPRCUM        : # Indicateur de reprise du cumul d'amortissement pour les biens
                                    # antérieur à l'exercice courant
  Global Integer REPENDDPE        : # Indicateur de reprise de la dotation exercice
  Global Integer G_DERRVEISS      : # Reprise de dérogatoire sur sortie

  Global Date    L_STRFIYCOU(1..G300MAX)
  Global Date    L_ENDFIYCOU(1..G300MAX)
  Global Date    L_STRPERCOU(1..G300MAX)
  Global Date    L_ENDPERCOU(1..G300MAX)
  Global Integer L_FLGPER   (1..G300MAX)

  Global Char GCPY_CURR           : # Contient la société du dernier bien importé
  GCPY_CURR = ""

  Local Integer RAZMSK            : # Indicateur de remise à blanc des masques gérés manuellement
  Local Integer L_I
  # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
  If GPHY = G_OUI Then
    Global Char G_ELEMENTS(GLONPHY)(1..999) # Va servir à stocker les éléments rattachés à un bien
  Endif
  Global Integer G_NOUVEAU_BIEN     # Mis à G_OUI quand on change de bien
  G_NOUVEAU_BIEN = G_NON
  # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

  GSEPDEC = [M:AOE1]SEPDEC : If GSEPDEC="" : GSEPDEC="." : Endif : # FQ64491

  # Chargement des actions des menus OI, ON, OM et OP
  Local File AWINBOUT [AWT]

  For [F:AWT] Where WIN = "OFAS"
    Case [F:AWT]CODBOUT
      When "OI" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_ISR, TRTSPE_ISR)
      When "ON" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_VEH, TRTSPE_VEH)
      When "OM" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_NSP, TRTSPE_NSP)
      # When "OP" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_IVY, TRTSPE_IVY)
    Endcase
  Next
  # Il n'y a plus d'action inventaire liée au bien
  TRTSTD_IVY="SUBPHYY"
  TRTSPE_IVY="SPEPHYY"

  # FQ75616
  TRTSTD_ADV = "TRTIMMOFEN"
  TRTSPE_ADV = "XWFASADV"

  Close Local File [AWT]

  # FQ75616 : Format des dates pour l'import
  Case [M:AOE1]OPTDAT
    When 1 : FORMAT_DATE = "DDMMYY"
    When 2 : FORMAT_DATE = "DDMMYYYY"
    When 3 : FORMAT_DATE = "YYMMDD"
    When 4 : FORMAT_DATE = "YYYYMMDD"
  Endcase

  # Ouverture de FASS pour la gestion de la sortie par action silencieuse
  If !clalev([F:FASS]) : Local File FXDASSETS  [FASS] : Endif : # FQ56478

  # Ouverture de la table COMPANY pour les associations
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

  # Ouverture de la table FACILITY pour déterminer la société FQ96134
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

  # Ouverture des tables pour l'alimentation des plans
  If !clalev([F:CNX]) : Local File CONTEXT   [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR  [FIS] : Endif

  # Ouverture des tables pour la création du réferentiel
  # FQ115274
  # If !clalev([F:LOC]) : Local File LOCALIZAT [LOC] : Endif : # Localisation
  If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif : # Tables diverses
  If !clalev([F:CCE]) : Local File CACCE     [CCE] : Endif : # Table des sections analytiques
  If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif : # Fournisseur FQ64491

  # Chargement des paramètres d'autorisation de création du réferentiel
  Local Char LPARM
  Call PARAM("","CRELOC",LPARM) From ADOVAL                   : # Localisation
  CRELOC = val(LPARM)
  Call PARAM("","CREBPR",LPARM) From ADOVAL                   : # Fournisseur FQ64491
  CREBPR = val(LPARM)
  Call PARAM("","CREACGGRP",LPARM) From ADOVAL                : # Famille
  CREACGGRP = val(LPARM)
  For L_I=0 To GOPTCANA-1
    Call PARAM("","CRECCE"+num$(L_I+1),LPARM) From ADOVAL     : # Sections analytiques
    CRECCE(L_I) = val(LPARM)
  Next L_I

  For L_I=0 To 9
    Call PARAM("","CREUSRFL"+num$(L_I+1),LPARM) From ADOVAL     : # Zones libres
    CREUSRFL(L_I) = val(LPARM)
  Next L_I

  # Mise à jour du paramètre d'import des biens en inactif
  Call PARAM("","DISAFAS",LPARM) From ADOVAL     : # Sections analytiques
  GDISAFAS = val(LPARM)

  GCOUSIT = "" : # Pour forcer le rechargement FQ96134
Return

####################################################################
# A la fin de l'import
#
$IMP_FERME
  # Fermeture des masques
  If clalev([M:FASI]) : Close Local Mask [M:FASI] : Endif
  If clalev([M:FASV]) : Close Local Mask [M:FASV] : Endif
  # If clalev([M:FASY]) : Close Local Mask [M:FASY] : Endif
  If clalev([M:PHYY]) : Close Local Mask [M:PHYY] : Endif
  If clalev([M:FASN]) : Close Local Mask [M:FASN] : Endif
  If clalev([M:FPC])  : Close Local Mask [M:FPC]  : Endif
  If clalev([M:FASA]) : Close Local Mask [M:FASA] : Endif  : # FQ75616

  # Suppression des variables
  If dim(RAZMSK)>0     : Kill RAZMSK     : Endif
  If dim(TRTSTD_ISR)>0 : Kill TRTSTD_ISR : Endif
  If dim(TRTSPE_ISR)>0 : Kill TRTSPE_ISR : Endif
  If dim(TRTSTD_VEH)>0 : Kill TRTSTD_VEH : Endif
  If dim(TRTSPE_VEH)>0 : Kill TRTSPE_VEH : Endif
  If dim(TRTSTD_NSP)>0 : Kill TRTSTD_NSP : Endif
  If dim(TRTSPE_NSP)>0 : Kill TRTSPE_NSP : Endif
  If dim(TRTSTD_IVY)>0 : Kill TRTSTD_IVY : Endif
  If dim(TRTSPE_IVY)>0 : Kill TRTSPE_IVY : Endif
  If dim(TRTSTD_ADV)>0 : Kill TRTSTD_ADV : Endif : # FQ75616
  If dim(TRTSPE_ADV)>0 : Kill TRTSPE_ADV : Endif : # FQ75616

  If dim(FORMAT_DATE)>0 : Kill FORMAT_DATE : Endif : # FQ75616
  If dim(CRELOC)>0      : Kill CRELOC      : Endif
  If dim(CREBPR)>0      : Kill CREBPR      : Endif : # FQ64491
  If dim(CREACGGRP)>0   : Kill CREACGGRP   : Endif
  If dim(CRECCE)>0      : Kill CRECCE      : Endif
  If dim(CREUSRFL)>0    : Kill CREUSRFL    : Endif
  If dim(REPDPRCUM)>0   : Kill REPDPRCUM   : Endif
  If dim(REPENDDPE)>0   : Kill REPENDDPE   : Endif
  If dim(L_STRFIYCOU)>0 : Kill L_STRFIYCOU : Endif
  If dim(L_ENDFIYCOU)>0 : Kill L_ENDFIYCOU : Endif
  If dim(L_STRPERCOU)>0 : Kill L_STRPERCOU : Endif
  If dim(L_ENDPERCOU)>0 : Kill L_ENDPERCOU : Endif
  If dim(L_FLGPER)>0    : Kill L_FLGPER    : Endif
  If dim(GCPY_CURR)>0   : Kill GCPY_CURR   : Endif

  # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
  If dim(G_ELEMENTS)>0     : Kill G_ELEMENTS     : Endif
  If dim(G_NOUVEAU_BIEN)>0 : Kill G_NOUVEAU_BIEN : Endif
  # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

  # Fermeture des tables pour l'alimentation des plans
  If clalev([F:CNX]) : Close Local File [CNX]    : Endif
  If clalev([F:FIS]) : Close Local File [FIS]    : Endif

  # Fermeture des tables pour l'alimentation du réferentiel
  # FQ115274
  # If clalev([F:LOC]) : Close Local File [LOC]    : Endif
  If clalev([F:ADI]) : Close Local File [ADI]    : Endif
  If clalev([F:CCE]) : Close Local File [CCE]    : Endif
  If clalev([F:BPR]) : Close Local File [BPR]    : Endif : # FQ64491
Return

####################################################################
# Verification avant l'enregistrement.
#
$IMP_VERIF_CRE
Return

####################################################################
# Alimentation de certaines zones de la classe [F] avant enregistrement.
#
$IMP_INICRE
  Local Integer N_I, N_CNX
  #Local Integer CDRET : # FQ62830 : déplacé dans AP_IMPORT

  # Initialisation des flags de calcul
  [F:FAS]FLGCLC = G_NON
  For N_CNX = 1 To G300MAX
    [F:FAS]FLGCNXCLC(N_CNX-1) = G_NON
  Next N_CNX

  # DEBUT FQ62830 : déplacé dans AP_IMPORT
  # Lecture des dates des différents contextes de la société (cache pour ne faire la lecture que si nécéssaire)
  #If [F:FAS]CPY <> GCPY_CURR
  #  Call GET_CPY_DAT([F:FAS]CPY,L_STRFIYCOU,L_ENDFIYCOU,L_STRPERCOU,L_ENDPERCOU,CDRET) From GLOBIENS
  #  GCPY_CURR = [F:FAS]CPY
  #Endif
  # FIN FQ62830

  # Alimentation de DEPSTA et de FLGCNXCLC en fonction de la date de sortie :
  #  - date de sortie antérieure au début de l'exercice courant -> DEPREC considéré comme clôturé
  #  - date de sortie supérieure ou égale au début de l'exercice courant -> DEPREC à calculer
  For N_I = 1 To [M:FAS3]NBLIG1
    N_CNX = [M:FAS3]CNX(N_I-1)
    If ([F:FAS]ISSDAT = [0/0/0]) or ([F:FAS]ISSDAT >= L_STRFIYCOU(N_CNX))
      [F:FAS]FLGCLC             = G_OUI
      [F:FAS]FLGCNXCLC(N_CNX-1) = G_OUI
      [M:FAS3]DEPSTA(N_I-1)     = GVML_SCNOCAL
    Else
      [M:FAS3]DEPSTA(N_I-1)     = GVML_SCCLOS
    Endif
  Next N_I

  # Alimentation du flag ISSFIYPRE permettant d'identifier les biens sortis dans un
  # exercice antérieur pour tous les contextes
  [F:FAS]ISSFIYPRE = G_NON
  If !find(GVML_SCNOCAL, [M:FAS3]DEPSTA)
    [F:FAS]ISSFIYPRE = G_OUI
  Endif
Return

####################################################################
# Après la création du bien.
#
$IMP_CREATION
  # Pour les biens sortis dans un exercice antérieur, déplacement
  # du DEPREC
  Local Integer ANNEE

  If [F:FAS]ISSDAT <> [0/0/0]
    For N_I = 1 To [M:FAS3]NBLIG1
      N_CNX = [M:FAS3]CNX(N_I-1)
      If ([F:FAS]ISSDAT <> [0/0/0]) and ([F:FAS]ISSDAT < L_STRFIYCOU(N_CNX))
        # Détermination de l'exercice contenant la date de sortie à partir de la date de début
        # de l'exercice courant
        If nday([F:FAS]ISSDAT) < nday(gdat$(day([M:FAS3]FIYSTRDAT(N_I-1)), month([M:FAS3]FIYSTRDAT(N_I-1)), year([F:FAS]ISSDAT)))
          ANNEE = year([M:FAS3]FIYSTRDAT(N_I-1)) - year([F:FAS]ISSDAT) + 1
        Else
          ANNEE = year([M:FAS3]FIYSTRDAT(N_I-1)) - year([F:FAS]ISSDAT)
        Endif

        # Déplacement du DEPREC
        Read [F:DEP]DEP0=[F:FAS]AASREF;[M:FAS3]DPRPLN(N_I-1);[M:FAS3]FIYENDDAT(N_I-1);[M:FAS3]PERENDDAT(N_I-1)
        If !fstat
          [F:DEP]FIYSTRDAT = gdat$(day([F:DEP]FIYSTRDAT), month([F:DEP]FIYSTRDAT), year([F:DEP]FIYSTRDAT)-ANNEE)
          [F:DEP]FIYENDDAT = gdat$(day([F:DEP]FIYENDDAT), month([F:DEP]FIYENDDAT), year([F:DEP]FIYENDDAT)-ANNEE)
          [F:DEP]PERSTRDAT = [F:DEP]FIYSTRDAT
          [F:DEP]PERENDDAT = [F:DEP]FIYENDDAT
          Rewrite [F:DEP] Curr
        Endif
      Endif
    Next N_I
  Endif
Return

#################################################################### FQ56478
# Après la création du bien, après le commit
#
$IMP_APRES_CRE
  # Si la classe [F:FASS] est renseignée, c'est qu'il y a pour le bien une sortie dans
  # l'exercice courant ou suivant
  If [F:FASS]ISSDAT <> [0/0/0]
    # Appel de l'action de sortie
    Call ECR_TRACE(mess(671,GML_MSGFAS,1)-":"-[F:FAS]AASREF-[F:FAS]AASDES1,0) From GESECRAN
    Local Integer RETOUR
    Call LAUNCH_SILTRT("FASISS","IMPFAS",RETOUR) From TRCPROCOM
    If G_MAJOK = G_OUI
      Call ECR_TRACE(mess(673,GML_MSGFAS,1),0) From GESECRAN
    Else
      If dim(GT_LIS_ERR) < 0 Then : # FQ59450
        Call ECR_TRACE(mess(672,GML_MSGFAS,1),1) From GESECRAN
      Else
        Call ECR_TRACE(mess(672,GML_MSGFAS,1)-"-"-GT_LIS_ERR(0),1) From GESECRAN
      Endif
    Endif
  Endif
Return

#################################################################### FQ56478
# Alimentation des masques de soumission des actions
# silencieuses
#
$ALIM_MASK
  If ACTMETNAM = "FASISS"

    [M:MHC]FLGCPY(find([F:FASS]CPY,[M:MHC]CPY)-1) = G_OUI
    [M:MHC]FLGFCY(find([F:FASS]FCY,[M:MHC]FCY)-1) = G_OUI

    [M:ASL]TBL1      = "FXDASSETS"
    [M:ASL]FLD1      = "AASREF"
    [M:ASL]OPE1      = 2
    [M:ASL]VAL1      = [F:FAS]AASREF : # On prend [F:FAS]AASREF et non [F:FASS]AASREF en cas de numérotation automatique
    [M:ASL]VALI1     = [F:FAS]AASREF : # On prend [F:FAS]AASREF et non [F:FASS]AASREF en cas de numérotation automatique

    [M:MHC]FLGSIM    = G_NON

    [M:FASS]CCLISSFLG = G_NON
    #[M:FASS]EXTISSFLG = G_NON : # FQ64491
    If [F:FASS]EXTISSFLG <> 0
      [M:FASS]EXTISSFLG = [F:FASS]EXTISSFLG
    Else
      [M:FASS]EXTISSFLG = G_NON
    Endif
    [M:FASS]ISSCMPFLG = G_NON
    [M:FASS]IMLFLG    = G_NON

    If GPHY = G_OUI : [M:FASS]ECRPHYATT = G_OUI : Endif

    [M:FASS]ISSDAT    = [F:FASS]ISSDAT
    Call AS_ISSTYP([M:FASS]ISSTYP) From TRTFASISS
    [M:FASS]ISSTYP    = [F:FASS]ISSTYP
    [M:FASS]ISSDATRUL = [F:FASS]ISSDATRUL : # FQ59447
    If [M:FASS]ISSDATRUL = 0              : # FQ59447
      [M:FASS]ISSDATRUL = 1
    Endif
    [M:FASS]ISSAMT    = [F:FASS]ISSAMT(0)
    If [M:FASS]ISSAMT <> 0
      [M:FASS]ISSAMTTYP = 2
    Else
      [M:FASS]ISSAMTTYP = 1
    Endif
    [M:FASS]BRDTYP = 1
    [M:FASS]BRDPLN = 1
    [M:FASS]BUY    = [F:FASS]BUY : # FQ73850
  Endif
Return

####################################################################
# Après l'import d'une ligne du fichier en entrée
#
$AP_IMPORT
  If [M:IMP2]TEST=2 : Return : Endif : # FQ46184

  Case SEPNUM
    When 2 :
      If dim([L]RAZMSK)>0
       If [L]RAZMSK
         Gosub ALI_TVA
         Raz [M:FASN], [L]RAZMSK
       Endif
      Endif
    When 3 :
      If dim([M:FAS8]NBPHY)>0
        Gosub ALI_FASY
      Endif
      OK = 0
      If dim([L]RAZMSK)>0
       If [L]RAZMSK : Raz [M:FASN], [L]RAZMSK : Endif
      Endif
    When Default
  Endcase
Return

####################################################################
# A chaque chargement de la classe F à partir du fichier d'import
#
$IMPORT
  Case SEPNUM
    When 1
      # Ligne de type "F" - Biens comptables [F:FAS]

      # Initialisation de la société à partir du site financier FQ96134 FQ95955 FQ96987
      Call ACTION_FCY([F:FAS]FCY,[F:FAS]CPY) From GLOFCYCPY

      # DEBUT FQ62830 : déplacement de l'initialisation ici
      # Lecture des dates des différents contextes de la société (cache pour ne faire la lecture que si nécéssaire)
      If [F:FAS]CPY <> GCPY_CURR
        Local Integer CDRET
        Call GET_CPY_DAT([F:FAS]CPY,L_STRFIYCOU,L_ENDFIYCOU,L_STRPERCOU,L_ENDPERCOU,CDRET) From GLOBIENS
        GCPY_CURR = [F:FAS]CPY
      Endif
      # FIN FQ62830

      If dim([L]RAZMSK)>0
       # [L]RAZMSK=1 : Raz [M:FASI], [M:FASV], [M:FASY]
       [L]RAZMSK=1 : Raz [M:FASI], [M:FASV] #, [M:PHYY] : # FQ65744
       If clalev([M:PHYY]) : Raz [M:PHYY] : Endif       : # FQ65744
       G_DERRVEISS = 0
      Endif
      # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
      G_NOUVEAU_BIEN = G_OUI
      # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

      # Initialisation de la classe [F:FASS] des informations de sortie FQ59450
      Raz [F:FASS]

      Local Char WPARAM

      # Lecture des paramètres de numérotation automatique
      Call PARAM([F:FAS]CPY,"AASAUTNUM",WPARAM) From ADOVAL
      GAASAUTNUM = val(WPARAM)
      If GPHY = G_OUI
        Call PARAM([F:FAS]CPY,"PHYAUTNUM",WPARAM) From ADOVAL
        GPHYAUTNUM = val(WPARAM)
      Endif

      # création du réferentiel (la localisation est traitée plus tard)
      If CREACGGRP=G_OUI : Gosub CREACGGRP_AUTO : Endif            : # Famille

      For L_I=0 To GOPTCANA-1                                      : # Sections analytiques
        If CRECCE(L_I)=G_OUI & [F:FAS]CCE(L_I) <> ""
          Call CRE_CCE([M:FPC]DIE(L_I),[F:FAS]CCE(L_I),GIMP(70+L_I)) From GLOFUNCIMP : # FQ64491
        Endif
      Next L_I

      # Lecture du paramètre Société REPDPRCUM
      Local Char WPARAM
      Call PARAM([F:FAS]CPY,"REPDPRCUM",WPARAM) From ADOVAL : # Chargement du paramètre de reprise du cumul d'amortissement
      If val(WPARAM) = 0
        REPDPRCUM = G_OUI
      Else
        REPDPRCUM = val(WPARAM)
      Endif

      # Lecture du paramètre Société REPENDDPE
      Local Char WPARAM
      Call PARAM([F:FAS]CPY,"REPENDDPE",WPARAM) From ADOVAL : # Chargement du paramètre de reprise de la dotation exercice
      If val(WPARAM) = 0
        REPENDDPE = G_NON
      Else
        REPENDDPE = val(WPARAM)
      Endif

# FQ109840, FQ109841
#      If GPHY = G_OUI : # FQ65744
#        # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
#        # Récupération des paramètres société
#        WPARAM = ""
#        Call PARAM([F:FAS]CPY,"PHYNUMBCO",WPARAM) From ADOVAL
#        GPHYNUMBCO = val(WPARAM)
#
#        WPARAM = ""
#        Call PARAM([F:FAS]CPY,"PHYFMTCOU",WPARAM) From ADOVAL
#        GPHYFMTCOU = WPARAM
#        # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
#      Endif

    When 2
      # Ligne de type "D" - Amortissmeents [F:DEP]
      Gosub ALI_FAS3

    When 3
      # Ligne de type "Y" - Elément Physique [F:PHY]

    When 4
      # Ligne de type "P" - Provision pour renouvellement [F:RPR]
      If (G_ACTCCN = G_OUI) Then
        Gosub ALI_FAS6
      Endif

    When Default
  Endcase
Return

####################################################################
# Déclenchement de traitements spécifiques lors du passage
# sur certaines zones
#
$IMP_ZONE
  Case IMPZON
    When "AASREF"
        Gosub ALI_FXDASSETS
        If GPHY=G_OUI Then
          # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien : pas en modif
          # [M:FAS8]NBPHY = 0
          If GREP = "C" Then
            [M:FAS8]NBPHY = 0
          Endif
          # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien : pas en modif
        Endif
    When "ENAFAS"
        If (GDISAFAS = G_OUI) and ([F:FAS]ISSDAT = [0/0/0])
          [M]ENAFAS = G_NON
        Else
          [M]ENAFAS = G_OUI
        Endif
        OK = 0
    When "AASQTY"
        If [F:FAS]AASQTY = 0 Then : [M]AASQTY = 1 : OK = 0 : Endif
    When "ACGETRNOT"
        IMPMOD = 1 : # Pour forcer l'execution de l'après-modif
    When "IVCVATAMT"
        If [F:FAS]IVCVATFLG <> G_OUI : OK = 0 : Endif : # FQ61340
        #-------- ALIMENTATIONS COMPLEMENTAIRES --------#
        Gosub ALI_FAS8   : # Déclenchement de la simulation de saisie des fenêtres complémentaires
        If [F:FAS]ISSDAT <> [0/0/0]
          Gosub ALI_SORTIE : # Alimentation des zones relatives à la sortie
        Endif
        #-----------------------------------------------#
    When "IVCVATAMTI"
        # FQ61340
        If [F:FAS]IVCVATFLGI <> G_OUI : OK = 0 : Endif
    When "DEDVATAMT"
        #If [F:FAS]DEDVATFLG  = G_NON : OK = 0 : Endif : # FQ86475
        If [F:FAS]DEDVATFLG  <> G_OUI : OK = 0 : Endif
    When "DEDVATAMTI"
        #If [F:FAS]DEDVATFLGI = G_NON : OK = 0 : Endif : # FQ86475
        If [F:FAS]DEDVATFLGI <> G_OUI : OK = 0 : Endif
    When "IASRATCUR"
        # On estime que IASRATCUR à 0 n'est pas significatif
        If [F:FAS]IASRATCUR = 0 : OK = 0 : Endif
# Issue X3-89781
#    When "LOC"
#        If ([F:FAS]LOC <> "") or (GIMP(1) <> "") : # FQ93198
#          Call TRAITE_LOC([F:FAS]LOC,CRELOC) From GLOFUNCIMP : # FQ68153
#        Endif
    When "BPR"
        If CREBPR = G_OUI and [F:FAS]BPR <> ""
          Call CRE_BPR([F:FAS]BPR,GIMP(7)) From GLOFUNCIMP
        Endif
    When "USRFLDA1","USRFLDA2","USRFLDA3","USRFLDA4","USRFLDA5","USRFLDA6","USRFLDA7","USRFLDA8","USRFLDA9","USRFLDA10"
      Local Char NZ
      NZ = right$(IMPZON,8)
      Call TRT_TABDIV(evalue("GABLIADI"+NZ),evalue("[F:FAS]USRFLDA"+NZ),GIMP(88+val(NZ)),"","",0,0) From GLOFUNCIMP
    When Default
  Endcase

  Gosub IMP_ZONE_ASSOC From GLOFUNCIMP : # FQ79283
Return

$IMP_TAB
   ##################
   # AMORTISSEMENTS #
   ##################
   # Les champs suivant sont alimentés par l'appel à SAI_NBLIG1 de W0FAS3 dans $ALI_FAS3
  Case IMPZON
    When "DPM"
        # FQ62916 + FQ59159 : le champ ENDDPE n'étant pas saisissable, on profite d'avoir la main sur
        # le champ DPM pour l'alimenter
        # Dotation exercice
        [M:FAS3]ENDDPE(indice)    = [F:DEP]ENDDPE
        # Flag de forçage de la dotation exercice
        [M:FAS3]ENDDPEFLG(indice) = REPENDDPE
    When "DPRBAS"
        # Base d'amortissement et base d'amortissement initiale
        [M:FAS3]DPRBAS(indice) = [F:DEP]DPRBAS
        [M:FAS3]BSEVAL(indice) = [F:DEP]DPRBAS
        OK = 0
    When "DPRRAT"
        # Taux d'amortissement
        If [F:DEP]DPRRAT <> 0
          [M:FAS3]DPRRATFLG(indice) = G_OUI
        Else
          [M:FAS3]DPRRATFLG(indice) = G_NON
          OK = 0
        Endif
#    FQ90644 : traité dans ALI_FAS3
#    When "DPRCUM"
#        # On positionne le flag de forçage du cumul d'amortissement à Oui pour les plans dont la date de début
#        # d'amortissement est antérieure à la date de début d'exercice si le paramètre de reprise de cumul
#        # d'amortissement est à Oui
#        If ( [M:FAS3]STRDPRDAT(indice) < [M:FAS3]FIYSTRDAT(indice) ) and ( REPDPRCUM = G_OUI )
#          [M:FAS3]DPRCUMFLG(indice)  = G_OUI
#        Else
#          [M:FAS3]DPRCUMFLG(indice)  = G_NON
#        Endif
    When Default
  Endcase

  Gosub IMP_ZONE_ASSOC From GLOFUNCIMP : # FQ79283
Return


####################################################################
# Initialisations du début de l'import d'un bien
#
$ALI_FXDASSETS
  # création du réferentiel (la localisation est traitée plus tard)
  If CREACGGRP=G_OUI : Gosub CREACGGRP_AUTO : Endif            : # Famille

  [M:FAS0]FISLIG = 1 # Affectation par défaut au comptable au cas où le fiscal n'existe pas
Return

####################################################################
#
# IMPORTS MANUELS
#
####################################################################

####################################################################
# Simulation de la saisie via les fenetres complementaires
# "Assurance", "Véhicule" et "Inventaire".
#
$ALI_FAS8

  [M:FAS8] = [F:FAS] : # Alimentation de l'onglet caché FAS8

  ###############################################
  # Alimentation de la fenetre "Assurance"
  Default Mask [M:FASI]

  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227 FQ75616

  Onerrgo ARRETE
  Gosub DEBUT_FASISR From =TRTSTD_ISR
  Onerrgo CONTINUE
  Gosub DEBUT_FASISR From =TRTSPE_ISR
  Onerrgo

  # On initialise le type d'assurance à "non assuré" si l'import ne donne pas cette information
  If [M]ISRTYP = 0 : [M]ISRTYP = 1 : Endif
  # Si un montant de valeur à neuf non nul est importé, la valeur a neuf forcée est a OUI
  If [M]RPLVAL > 0 : [M]RPLVALFLG = G_OUI : Else [M]RPLVALFLG = G_NON : Endif
  # Si un montant de valeur d'assurance non nul est importé, la valeur assurance forcée est a OUI
  If [M]ISRVAL > 0 : [M]ISRVALFLG = G_OUI : Else [M]ISRVALFLG = G_NON : Endif

  # Execution des actions liees aux champs de ce masque
  Call SAIMSK("FAS", "SET_IMPMOD", "SUBIMPOBJ") From W0FASISR
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASISR From =TRTSTD_ISR
  Onerrgo CONTINUE
  Gosub OK_FASISR From =TRTSPE_ISR
  Onerrgo

  Setmode                                                                            : # FQ82227 FQ75616

  ###############################################
  # Alimentation de la fenetre "Véhicule"
  Default Mask [M:FASV]

  # FQ41458 : pas d'info véhicule si le type VEHTYP n'est pas renseigné dans le fichier d'import
  If [M:FAS8]VEHTYP = "" Then
    Effzo [M:FAS8]2 : # Bloc "Véhicule" de l'écran FAS8
  Else
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227 FQ75616

    Onerrgo ARRETE
    Gosub DEBUT_FASVEH From =TRTSTD_VEH
    Onerrgo CONTINUE
    Gosub DEBUT_FASVEH From =TRTSPE_VEH
    Onerrgo

    # Execution des actions liees aux champs de ce masque
    Call SAIMSK("FAS", "SET_IMPMOD", "SUBIMPOBJ") From W0FASVEH
    If mkstat : GERR = 1 : End : Endif

    Default Mask [M:FAS8]

    Onerrgo ARRETE
    Gosub OK_FASVEH From =TRTSTD_VEH
    Onerrgo CONTINUE
    Gosub OK_FASVEH From =TRTSPE_VEH
    Onerrgo

    Setmode                                                                            : # FQ82227 FQ75616
  Endif

  Default Mask [M:FAS8]

  ###############################################
  # Initialisations specifiques
  If [F:FAS]IVCVATRAT > 0 : [M]IVCVATFLG = G_OUI : Else [M]IVCVATFLG = G_NON : Endif
  If [F:FAS]DEDVATRAT <> 100 and [F:FAS]DEDVATAMT : [M]DEDVATFLG = G_OUI : Else [M]DEDVATFLG = G_NON : Endif
  If [F:FAS]IVCVATRATI > 0 : [M]IVCVATFLGI = G_OUI : Else [M]IVCVATFLGI = G_NON : Endif
  If [F:FAS]DEDVATRATI <> 100 and [F:FAS]DEDVATAMTI : [M]DEDVATFLGI = G_OUI : Else [M]DEDVATFLGI = G_NON : Endif
Return

###############################################
# Alimentation de la fenetre "Valeur marché"
#
# Cette étiquette est appellée lors du contrôle
# "APRES_NBLIG1" de SUBFAS en import
#
$ALI_DEPREC
  Local Integer SAVE_NOLIGN

  SAVE_NOLIGN = nolign

  Default Mask [M:FASN]

  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227 FQ75616

  Onerrgo ARRETE
  Gosub DEBUT_FASNSP From =TRTSTD_NSP
  Onerrgo CONTINUE
  Gosub DEBUT_FASNSP From =TRTSPE_NSP
  Onerrgo

  # Execution des actions liees aux champs de ce masque
  Call SAIMSK("FASN", "SET_IMPMOD", "SUBIMPOBJ") From W0FASNSP
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASNSP From =TRTSTD_NSP
  Onerrgo CONTINUE
  Gosub OK_FASNSP From =TRTSPE_NSP
  Onerrgo

  Setmode                                                                            : # FQ82227 FQ75616

  Default Mask [M:FAS3]

  nolign = SAVE_NOLIGN
Return

####################################################################
# Arrêt du traitement en cas de problème
#
$ARRETE
  mkstat = 2 : GERR = 1 : End
Return

####################################################################
# On continue le traitement en cas de problème
#
$CONTINUE
  Resume
Return

####################################################################
# Alimentation des informations de sortie
#
$ALI_SORTIE
  # DEBUT FQ56478
  Local Shortint N_I, ISSANT

  ISSANT = G_NON

  # On regarde si le bien est sorti dans un exercice antérieur pour un des contextes
  For N_I = 1 To [M:FAS3]NBLIG1
    If [F:FAS]ISSDAT < L_STRFIYCOU([M:FAS3]CNX(N_I-1))
      ISSANT = G_OUI : # Il y a au moins un contexte pour lequel la sortie est antérieure à l'exercice courant
      Break
    Endif
  Next

  If ISSANT = G_NON
    # Si la sortie est dans l'exercice courant, on effectuera une sortie silencieuse à l'issue
    # de la création du bien. On stocke dans [F:FASS] les paramètres de sortie
    [F:FASS] = [F:FAS]
    Return
  Else
    # Alimentation des informations de sortie avec ce qui est dans le fichier d'import
    Raz [F:FASS]
  Endif
  # FIN FQ56478

  Call ECR_TRACE(mess(810,GML_MSGFAS,1)-":"-[F:FAS]AASREF-[F:FAS]AASDES1,0) From GESECRAN

  [M:FAS4]ISSDAT = [F:FAS]ISSDAT

  For N_I=1 To [M:FAS4]NBLIG4
    If [F:FAS]ISSAMT([M:FAS4]DPRPLN(N_I-1)-1) <> 0
      [M:FAS4]ISSAMT(N_I-1) = [F:FAS]ISSAMT([M:FAS4]DPRPLN(N_I-1)-1)
    Else
      [M:FAS4]ISSAMT(N_I-1) = [F:FAS]ISSAMT(0)
    Endif
    # Alimentation des +/- values pour les sorties antérieures à l'exercice courant
    [M:FAS4]GAL(N_I-1)       = [F:FAS]GAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]SHOGAL(N_I-1)    = [F:FAS]SHOGAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]LNGGAL(N_I-1)    = [F:FAS]LNGGAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]IMLRVEISS(N_I-1) = [F:FAS]IMLRVEISS([M:FAS4]DPRPLN(N_I-1)-1)
  Next

  If [F:FAS]ISSTYP = 0
    If [F:FAS]ISSAMT = 0
      [M:FAS4]ISSTYP = GVML_TSREBUT
    Else
      [M:FAS4]ISSTYP = GVML_TSVENTE
    Endif
  Else
    [M:FAS4]ISSTYP = [F:FAS]ISSTYP
  Endif

  If [F:FAS]PYBVATTYP = 0
    If [F:FAS]ISSVATAMT = 0
      [M:FAS4]PYBVATTYP = GVML_RVTVA00
    Else
      [M:FAS4]PYBVATTYP = GVML_RVTVAVT
    Endif
  Else
    [M:FAS4]PYBVATTYP = [F:FAS]PYBVATTYP
  Endif

  If [F:FAS]ISSDATRUL = 0
    [M:FAS4]ISSDATRUL = 1
  Else
    [M:FAS4]ISSDATRUL = [F:FAS]ISSDATRUL
  Endif

  [M:FAS4]ISSVATRAT = [F:FAS]ISSVATRAT
  [M:FAS4]ISSVATAMT = [F:FAS]ISSVATAMT
  [M:FAS4]BUY       = [F:FAS]BUY
  [M:FAS4]IVCSALISS = [F:FAS]IVCSALISS
  G_DERRVEISS       = [F:FAS]DERRVEISS

  # Alimentation du flag FLGUPDISS sur les DEPREC pour les biens sortis au-delà du début de l'exercice courant
  Local Integer N_I
  For N_I = 1 To [M:FAS3]NBLIG1
    If [M:FAS4]ISSDAT >= [M:FAS3]FIYSTRDAT(N_I-1)
      [M:FAS3]FLGUPDISS(N_I-1) = G_OUI
      [M:FAS4]FLGUPDISS        = G_OUI
    Endif
  Next N_I
Return

####################################################################
# Alimentation des informations de TVA
#
$ALI_TVA
  # FQ61340
  If [F:FAS]IVCVATFLG = G_OUI
    [M:FAS1]IVCVATFLG = [F:FAS]IVCVATFLG
    [M:FAS1]IVCVATRAT = [F:FAS]IVCVATRAT
    [M:FAS1]IVCVATAMT = [F:FAS]IVCVATAMT
    Call AM_IVCVATAMT([M:FAS1]IVCVATAMT) From SUBFAS
  Endif

  If G_ACTIAS = G_OUI and [F:FAS]IVCVATFLGI = G_OUI
    [M:FAS1]IVCVATFLGI = [F:FAS]IVCVATFLGI
    [M:FAS1]IVCVATRATI = [F:FAS]IVCVATRATI
    [M:FAS1]IVCVATAMTI = [F:FAS]IVCVATAMTI
    Call AM_IVCVATAMTI([M:FAS1]IVCVATAMTI) From SUBFAS
  Endif
  # FIN FQ61340

  If [F:FAS]DEDVATFLG = G_OUI
    [M:FAS1]DEDVATFLG = [F:FAS]DEDVATFLG
    [M:FAS1]DEDVATRAT = [F:FAS]DEDVATRAT
    [M:FAS1]DEDVATAMT = [F:FAS]DEDVATAMT
    Call AM_DEDVATAMT([M:FAS1]DEDVATAMT) From SUBFAS
  Endif

  If G_ACTIAS = G_OUI and [F:FAS]DEDVATFLGI = G_OUI
    [M:FAS1]DEDVATFLGI = [F:FAS]DEDVATFLGI
    [M:FAS1]DEDVATRATI = [F:FAS]DEDVATRATI
    [M:FAS1]DEDVATAMTI = [F:FAS]DEDVATAMTI
    Call AM_DEDVATAMTI([M:FAS1]DEDVATAMTI) From SUBFAS
  Endif
Return

####################################################################
# Création automatique de la famille comptable
#
$CREACGGRP_AUTO
  Call CRT_FAM([F:FAS]ACGGRP, GIMP(60)) From SUBFAM
#  Call TRT_TABDIV(611, [F:FAS]ACGGRP, GIMP(60), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

####################################################################
# Alimentation des différents plans
#
$ALI_FAS3
  Local Char SACTION : SACTION = ACTION

  # Recherche de la ligne dans le tableau correspondant au plan
  nolign = find([F:DEP]DPRPLN,[M:FAS3]DPRPLN)
  If !nolign
    # Les plans à importer ne correspondent pas à ceux de la société
    Call ECR_TRACE([M:FAS0]AASREF-":"-mess(164,7770,1)-[M:FAS0]CPY-"("+mess([F:DEP]DPRPLN,3101,1)+")",1) From GESECRAN
    GERR = 1 : mkstat = 2
    Return
  Endif

  # Exécution des contrôles et des actions pour la ligne d'amortissement
  indice = nolign-1
  Default Mask [FAS3]
  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ79242
  Call SAI_NBLIG1(IMPFIC,"IMP_TAB","SUBIMPOBJ") From W0FAS3
  # DEBUT FQ79242
  Setmode
  If mkstat
   #GREP = "" # Issue X3-63497 - 2017-11-23 by BEFOU : For error file
   Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ
  Endif
  Raz GERREUR
  # FIN FQ79242

  # Cumul d'amortissement début d'exercice
  [M:FAS3]DPRCUM(nolign-1)    = [F:DEP]DPRCUM

  # Cumul d'amortissement début de période FQ83143
#  FQ75616
#  [M:FAS3]PERCLOCUM(nolign-1)  = [F:DEP]PERCLOCUM
#  [M:FAS3]PERCLOCUMI(nolign-1) = [F:DEP]PERCLOCUM
#  [M:FAS3]PERCLOCUMT(nolign-1) = [F:DEP]PERCLOCUM

  ## On positionne le flag de forçage du cumul d'amortissement à Oui pour les plans dont la date de début
  ## d'amortissement est antérieure à la date de début d'exercice si le paramètre de reprise de cumul
  ## d'amortissement est à Oui
  #If ( [M:FAS3]STRDPRDAT(nolign-1) < [M:FAS3]FIYSTRDAT(nolign-1) ) and ( REPDPRCUM = G_OUI ) : # FQ90644
  If REPDPRCUM = G_OUI : # FQ90644
    [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI
  Else
    [M:FAS3]DPRCUMFLG(nolign-1) = G_NON
  Endif

  # FQ72796
  If ( abs([M:FAS3]DPRCUM(nolign-1)) > abs([M:FAS3]DPRVAL(nolign-1)) ) Then
    [M:FAS3]ENDDPE(nolign-1)    = [M:FAS3]DPRVAL(nolign-1) - [M:FAS3]DPRCUM(nolign-1)
    [M:FAS3]ENDDPEFLG(nolign-1) = G_OUI
    Call ECR_TRACE(mess(237,GML_MSGFAS,1),-1) From GESECRAN : # FQ96106
    Call ECR_TRACE(func GLOFUNC.SUBSTIT2(mess(841,GML_MSGFAS,1),
&                                        num$([M:FAS3]ENDDPE(nolign-1)),
&                                        mess([M:FAS3]DPRPLN(nolign-1),GML_NPLAN,1)),-1) From GESECRAN
    [M:FAS3]ENDDPEI(nolign-1) = [M:FAS3]ENDDPE(nolign-1)
    [M:FAS3]ENDDPET(nolign-1) = [M:FAS3]ENDDPE(nolign-1)
  Endif

  [M:FAS3]RATCUR(nolign-1)    = [F:DEP]RATCUR

  # Réintégration fiscale véhicule
  # Pour faire fonctionner l'import de la réintégration fiscale véhicule, il faut ajouter au modèle d'import la zone CRBCUM.
  # La règle ci-dessous initialise le flag de forçage à OUI si CRBCUM est différent de zéro, à NON sinon.
#  FQ75616
  #[M:FAS3]CRBCUM(nolign-1)      = [F:DEP]CRBCUM
  #If [F:DEP]CRBCUM <> 0
  If [M:FAS3]CRBCUM(nolign-1) <> 0
    [M:FAS3]CRBCUMFLG(nolign-1) = G_OUI
  Else
    [M:FAS3]CRBCUMFLG(nolign-1) = G_NON
  Endif

  [M:FAS3]CRBVEHCOD(nolign-1) = [F:DEP]CRBVEHCOD
  [M:FAS3]ALWCOD(nolign-1)    = [F:DEP]ALWCOD
  # FQ59783
  If [M:FAS3]ALWCOD(nolign-1) = 0
    [M:FAS3]ALWCOD(nolign-1)    = 1
  Endif

  [M:FAS3]NSPVAL(nolign-1)    = [F:DEP]NSPVAL : # Alimentation de la zone cachée NSPVAL

  [M:FAS3]LEG(nolign-1)       = [F:DEP]LEG
  #[M:FAS3]LEGCUM(nolign-1)    = [F:DEP]LEGCUM # FQ75616
  [M:FAS3]LEGRVE(nolign-1)    = [F:DEP]LEGRVE
  #[M:FAS3]LEGRVECUM(nolign-1) = [F:DEP]LEGRVECUM : # FQ75616
  #[M:FAS3]PERLEGCUM(nolign-1) = [F:DEP]PERLEGCUM : # FQ82293 FQ75616
  #[M:FAS3]PERLEGRVE(nolign-1) = [F:DEP]PERLEGRVE : # FQ82293

  [M:FAS3]EXCDPR(nolign-1)    = [F:DEP]EXCDPR
  [M:FAS3]NBV(nolign-1)       = [F:DEP]NBV


  ###############################################
  # Alimentation de la fenetre "Reprise" FQ75616

  Default Mask [M:FASA]

  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

  Onerrgo ARRETE
  Gosub DEBUT_FASADV From =TRTSTD_ADV
  Onerrgo CONTINUE
  Gosub DEBUT_FASADV From =TRTSPE_ADV
  Onerrgo

  Call SAIMSK("DEP", "IMP_ZONE", "SUBIMPOBJ") From W0FASADV
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASADV From =TRTSTD_ADV
  Onerrgo CONTINUE
  Gosub OK_FASADV From =TRTSPE_ADV
  Onerrgo

  Setmode
  ###############################################

  # FQ97181 : Après la saisie des informations avancées de reprise, autocorrection si PERREFCLCI ou PERREFCLCT = [0/0/0]
  If [M:FAS3]PERREFCLCI(nolign-1) = [0/0/0] : [M:FAS3]PERREFCLCI(nolign-1) = [M:FAS3]PERREFCLC(nolign-1) : Endif
  If [M:FAS3]PERREFCLCT(nolign-1) = [0/0/0] : [M:FAS3]PERREFCLCT(nolign-1) = [M:FAS3]PERREFCLC(nolign-1) : Endif

  ACTION = SACTION
Return


$ALI_FAS6

  ###############################################
  # Alimentation de la fenetre "Reprise" pour les informations de concessions FQ75616

  Default Mask [M:FASA]

  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

  Onerrgo ARRETE
  Gosub DEBUT_FASADV From =TRTSTD_ADV
  Onerrgo CONTINUE
  Gosub DEBUT_FASADV From =TRTSPE_ADV
  Onerrgo

  Call SAIMSK("RPR", "IMP_ZONE", "SUBIMPOBJ") From W0FASADV
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASADV From =TRTSTD_ADV
  Onerrgo CONTINUE
  Gosub OK_FASADV From =TRTSPE_ADV
  Onerrgo

  Setmode

  ###############################################
  # (*1) (*1) Origine apport
  If GIMP(1) <> "" Then  : [M:FAS6]CCNETRNAT = val(GIMP(1))  : Endif
  # (*2) Type apport
  If GIMP(2) <> "" Then  : [M:FAS6]CCNETRTYP = val(GIMP(2))  : Endif
  # (*3) Renouv. effectué
  If GIMP(3) <> "" Then  : [M:FAS6]RNWDONFLG = val(GIMP(3))  : Endif
  # (*4) Fonds initial
  If GIMP(4) <> "" Then  : [M:FAS6]CCNINICUM = func GLOFUNC.VALSEP(GIMP(4),GSEPDEC) : Endif
  # (*5) Ecart de caducité
  If GIMP(5) <> "" Then  : [M:FAS6]CCNCADDEV = func GLOFUNC.VALSEP(GIMP(5),GSEPDEC)  : Endif
  # (*6) Excédent caducité
  If GIMP(6) <> "" Then  : [M:FAS6]CCNCADEXC = func GLOFUNC.VALSEP(GIMP(6),GSEPDEC)  : Endif
  # (*7) Prov à reprendre
  If GIMP(7) <> "" Then  : [M:FAS6]RVERPRVAL = func GLOFUNC.VALSEP(GIMP(7),GSEPDEC)  : Endif
  # (*8) Remise avec paiement
  If GIMP(8) <> "" Then  : [M:FAS6]TPAFLG    = val(GIMP(8))  : Endif
  # (*9) Flag OCR
  If GIMP(9) <> "" Then  : [M:FAS6]OBYRNWCON = val(GIMP(9))  :  Endif
  # (*10) Date de renouvellement
  If GIMP(10) <> "" Then : Call STRING_TO_DATE(GIMP(10), [M:FAS6]RNWDAT) From GLOFUNC :    Endif
  # (*11) Code actualisation
  If GIMP(11) <> "" Then : [M:FAS6]CCNACTCOD = GIMP(11)      : Endif
  # (*12) Valeur renouvellement
  If GIMP(12) <> "" Then : [M:FAS6]RNWVAL    = func GLOFUNC.VALSEP(GIMP(12),GSEPDEC) : Endif
  # (*13) Bien renouvellant
  If GIMP(13) <> "" Then : [M:FAS6]RNWAASREF = GIMP(13)      : Endif
  # (*14) Fonds transmis
  If GIMP(14) <> "" Then : [M:FAS6]CCNTRFCUM = func GLOFUNC.VALSEP(GIMP(14),GSEPDEC) : Endif
  # (*15) Caducité transmise
  If GIMP(15) <> "" Then : [M:FAS6]CCNTRFCAD = func GLOFUNC.VALSEP(GIMP(15),GSEPDEC) : Endif
  # (*16) Subv. transmise
  If GIMP(16) <> "" Then : [M:FAS6]CCNTRFGRT = func GLOFUNC.VALSEP(GIMP(16),GSEPDEC) : Endif
  # (*17) Prov. transmise
  If GIMP(17) <> "" Then : [M:FAS6]CCNTRFRPR = func GLOFUNC.VALSEP(GIMP(17),GSEPDEC) : Endif
  # (*18) Type de bien (Hors réseau forcé par défaut)
  If GIMP(18) <> "" Then : [M:FAS6]CCNAASTYP = val(GIMP(18)) Else : [M:FAS6]CCNAASTYP = GML_CCNTBC : Endif
  # (*19) Fond de caducité (TRFCADCUM)
  If GIMP(19) <> "" Then : [M:FAS6]TRFCADCUM = func GLOFUNC.VALSEP(GIMP(19),GSEPDEC) : Endif
  # (*20) Fond de caducité (P_1CADCRB)
  If GIMP(20) <> "" Then : [M:FAS6]P_1CADCRB = func GLOFUNC.VALSEP(GIMP(20),GSEPDEC) : Endif

Return


####################################################################
# Alimentation des différents éléments physiques
#
$ALI_FASY

  If GPHY=G_OUI Then
    # Le site géographique est vide : la création de l'élément physique est impossible
    # La localisation est vide : la création de l'élément physique est impossible
    If [F:FAS]LOC='' Then
      GERR = 1 : mkstat = 2
      Call ECR_TRACE([F:FAS]AASREF-'-'-'BAC'-[F:PHY]BAC-'-'-mess(57,7775,1),1) From GESECRAN
      Return
    Endif

    # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
    # test sur le code à barre qui doit être unique
    Local Integer UNIQUE
    Call VERIF_UNICITE_BAC([F:PHY]BAC,[F:FAS]CPY,UNIQUE) From TRTPHYTOOL
    If UNIQUE = G_NON Then
      GERR= 1 : mkstat = 2
      Call ECR_TRACE([F:PHY]PHYREF-'-'-'BAC'-[F:PHY]BAC-'-'-mess(249,GML_MSGFAS,1),1) From GESECRAN
      Return
    Endif
    # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

    Default Mask [M:PHYY]

    # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
    # Appel du compteur de document
#    If [F:PHY]PHYREF='' Then
#      Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[M:FAS0]FCY,date$,[F:PHY]PHYREF,STAT) From GLOBIENS
#      If ( STAT ) Then : GOK = 0 : Return : Endif
#    Endif
    Gosub RECH_PHYREF
    If GOK = 0 Then Return Endif
    # fin 49517 (SYMEU) : Renumérotation des éléments physiques à partir du bien

    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227 FQ75616

     # FQ115274
#    Onerrgo ARRETE
#    Gosub DEBUT_PHYIVY From =TRTSTD_IVY
#    Onerrgo CONTINUE
#    Gosub DEBUT_PHYIVY From =TRTSPE_IVY
#    Onerrgo

     # FQ115274
#    # Execution des actions liees aux champs de ce masque
#    Call SAIMSK("PHY", "SET_IMPMOD", "SUBIMPOBJ") From W0PHYIVY
#    If mkstat : GERR = 1 : End : Endif
#
#    Onerrgo ARRETE
#    Gosub OK_PHYIVY From =TRTSTD_IVY
#    Onerrgo CONTINUE
#    Gosub OK_PHYIVY From =TRTSPE_IVY
#    Onerrgo

    Setmode                                                                            : # FQ82227 FQ75616

    If [F:PHY]PHYREF<>"" Then # 49517
      Default Mask [M:FAS8]

      # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
      # il n'y a pas d'éléments attachés
      # OU il y a des éléments mais pas celui en cours
      If [M:FAS8]NBPHY = 0
&     or ([M:FAS8]NBPHY > 0 and find([F:PHY]PHYREF,[M:FAS8]PHYREF(0..[M:FAS8]NBPHY-1)) = 0) Then
        If [M:FAS8]NBPHY < GPHN Then # il y a de la place dans FAS8 par rapport à sa taille maximum
        # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
          nolign = [M:FAS8]NBPHY+1

          # Alimentation de la ligne du tableau des élts phy de FAS8 à partir du fichier d'import
          [M:FAS8]IMP(nolign-1)     = G_OUI
          [M:FAS8]PHYREF(nolign-1)  = [F:PHY]PHYREF
          # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
          # [M:FAS8]PHYDES1(nolign-1) = [F:FAS]AASDES1
          If vireblc([F:PHY]PHYDES1,4) <> "" Then
             [M:FAS8]PHYDES1(nolign-1) = [F:PHY]PHYDES1
          Else
             [M:FAS8]PHYDES1(nolign-1) = [F:FAS]AASDES1
          Endif
          # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
          [M:FAS8]BAC(nolign-1)     = [F:PHY]BAC
          [M:FAS8]SRLNBR(nolign-1)  = [F:PHY]SRLNBR
          [M:FAS8]IVYDAT(nolign-1)  = [F:PHY]IVYDAT
          [M:FAS8]IVYTIM(nolign-1)  = [F:PHY]IVYTIM
          [M:FAS8]CURCND(nolign-1)  = [F:PHY]CURCND
          [M:FAS8]IVYRES(nolign-1)  = [F:PHY]IVYRES

          [M:FAS8]NBPHY +=1
        # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
        Else # il n'y a plus de place dans FAS8
          # Bien - PHYREF non importé : Le nombre d'éléments physiques rattachés au bien comptable est supérieur à la limite du code activité PHN de l'écran
          Call ECR_TRACE([F:FAS]AASREF-'-'-[F:PHY]PHYREF-mess(135,7775,1)-':'-mess(9,7775,1)-":"-num$(GPHN),1) From GESECRAN
        Endif
      Endif
      # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
    Endif # 49517
  Endif
Return

####################################################################
# 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
####################################################################
# Recherche du code de l'élément physique
####################################################################
$RECH_PHYREF
  Local Char L_PHYREF         # valeur de [F:PHY]PHYREF quand on arrive ici
  L_PHYREF = [F:PHY]PHYREF
  Local Integer TROUVE        # indique si l'élément est trouvé dans le champ PHYREFOLD d'un élément
  Local Char ELT_TROUVE       # indique dans quel élément l'élément en cours a été trouvé dans PHYREFOLD
  Local Char CODE_ELT         # prochain code de l'élément physique
  Local Integer LINDICE       # indice dans G_ELEMENTS du trou trouvé
  Local Integer NB_ELT        # nb d'éléments ayant un code élément
  Local Integer NB_ELT_PHY    # nb d'éléments ayant le code élément calculé

# FQ109840, FQ109841
#  If GPHYNUMBCO = G_OUI and vireblc([F:FAS]AASREF,4) <> "" Then
#    # Le paramètre PHYFMTCOU n'est pas renseigné : on ne va pas plus loin
#    If vireblc(GPHYFMTCOU,4) = "" Then
#       Call ERREUR_PHYFMTCOU([F:FAS]AASREF)
#       GOK = 0
#       Return
#    Endif
#  Endif

$RECH_PHYREF_2

  # Appel du compteur de document
  If [F:PHY]PHYREF='' Then
    If GPHYAUTNUM <> GVML_AUCUNE Then
     # FQ108840
#     If GPHYNUMBCO = G_OUI and vireblc([F:FAS]AASREF,4) <> "" Then
#         # On ne peut pas appeler la méthode GET_NUMEROPHY de GLOBIENS, car elle recherche le numéro d'élément
#         # dans PHYELT. Or, si on importe plusieurs éléments, il faut aussi tenir compte des numéros créés par
#         # l'import
#         Call CHERCHE_ELT([F:FAS]AASREF,STAT,[F:PHY]PHYREF) From TRTPHYTOOL
#      Else
#         #FQ95213 Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[M:FAS0]FCY,date$,[F:PHY]PHYREF,STAT) From GLOBIENS
#         Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,[F:PHY]PHYREF,STAT) From GLOBIENS
#      Endif
      Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,[F:PHY]PHYREF,STAT) From GLOBIENS
      If ( STAT ) Then : GOK = 0 : Return : Endif
    Endif
# FQ109840
#  Elsif GPHYAUTNUM = GVML_OBLIG and GPHYNUMBCO = G_OUI and vireblc([F:FAS]AASREF,4) <> "" Then
#    #--- Cas de la numérotation de la référence de l'élément en fonction de celle du bien ---
#    If G_NOUVEAU_BIEN = G_OUI Then
#       # Pour le premier élément physique d'un bien
#       Call ALIM_CODE_ELEMENT([F:FAS]AASREF) From TRTPHYTOOL
#       G_NOUVEAU_BIEN = G_NON
#    Endif
#    # Deux cas : soit l'élément physique existe déjà et on est en mise à jour,
#    # soit il n'existe pas et on doit vérifier sa référence
#    Call RECH_ELT([F:PHY]PHYREF,NB_ELT) From TRTPHYTOOL
#    If NB_ELT = 0 Then # l'élément physique n'existe pas
#       # Recherche du prochain numéro d'élément physique
#       Call GET_NUMERO_PROCH_ELT([F:FAS]AASREF,CODE_ELT,STAT,LINDICE) From TRTPHYTOOL
#       If STAT=0 Then # pas d'erreur
#          If CODE_ELT <> [F:PHY]PHYREF Then
#             # La référence de l'élément doit avoir la même structure que le format du compteur GPHYFMTCOU
#             # et il ne doit pas y avoir de trou dans la numérotation du numéro d'ordre : donc la référence de
#             # l'élément doit être égale à celle calculée
#            [F:PHY]PHYREF = CODE_ELT
#          Endif
#          # Ajout de l'élément dans la table G_ELEMENTS
#          G_ELEMENTS(LINDICE)=[F:PHY]PHYREF
#       Else
#          GOK = 0 : Return
#       Endif
#    Endif
  Endif

  # Quand on a le code de l'élément, on regarde s'il n'existe pas déjà dans le champ PHYREFOLD d'un élément
# FQ109840
#  If GPHYNUMBCO = G_OUI and [F:PHY]PHYREF <> "" and NB_ELT = 0 Then
#    Call EXIST_ELT_AVEC_PHYREFOLD([F:PHY]PHYREF,TROUVE,ELT_TROUVE) From TRTPHYTOOL
#    If TROUVE = G_OUI Then
#      If L_PHYREF = ""
#&     or (L_PHYREF <> "" and NB_ELT = 0) Then
#        # on est dans le cas où on calcule le code de l'élément, donc on calcule le numéro suivant
#        [F:PHY]PHYREF = L_PHYREF
#        Goto RECH_PHYREF_2
#      Endif
#    Endif
#    # Vérification que l'élément n'existe pas déjà, sinon on va chercher le prochain numéro
#    Call RECH_ELT([F:PHY]PHYREF,NB_ELT_PHY) From TRTPHYTOOL
#    If NB_ELT_PHY > 0 Then
#      [F:PHY]PHYREF = L_PHYREF
#      Goto RECH_PHYREF_2
#    Endif
#  Endif

Return

####################################################################
# 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
####################################################################
# Erreur quand PHYFMTCOU n'est pas renseigné
####################################################################
Subprog ERREUR_PHYFMTCOU(PREFBCO)
Value Char PREFBCO

  GERR = 1 : mkstat = 2
  # Le paramètre PHYFMTCOU n’est pas renseigné
  Call ECR_TRACE(PREFBCO-'-'-mess(101,7775,1),1) From GESECRAN
End

####################################################################
#
# DIVERS
#
####################################################################

##################################################
# Recherche des traitements standard et spécifique
# d'une action
#
Subprog CHERCHE_TRT_ACTION(P_ACTION, P_TRTSTD, P_TRTSPE)
Value Char P_ACTION ()
Variable Char P_TRTSTD ()
Variable Char P_TRTSPE ()

  Local File ACTION [ACT]

  Read [F:ACT]ACTION = P_ACTION

  If fstat = 0
    P_TRTSTD = [F:ACT]CODTRT
    P_TRTSPE = [F:ACT]SPETRT
  Endif

  Close Local File [F:ACT]
End

