#<AdxTL>@(#)3.0.0.0 $Revision$

######################################################
#  Traitement de vérification des documentations
#  départ des fonctions jusqu'aux champs
#  -----------------------------------
######################################################


#------------------------------------------------------------------------------------------------------------------------#


Subprog AVERIFDOCU (CHEMINTRA, DOSSIER, PMODULE, EXCLSUP,
&                 PORT, MACHINE, CHEMINTRAW, PLANGUE, NBERRTOT, NBWARTOT, PFCTSEL, PLIBVERIF, PNUMERRSEL)


Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Value Char PLANGUE
Variable Integer NBERRTOT, NBWARTOT
Value Char PFCTSEL, PLIBVERIF
Value Integer PNUMERRSEL


Local Char ZADXIFS, ZADXIRS


Local Char DOSSIER2(100), WTXTMODULE(50), WOBJET(15), WTEXTE(250)
Local Integer WBOK, I, NBTRAITES, NBERREUR, NBWARNING, WNBTROUVE, TERREUR(40), IB
Local Shortint SAUVEMODULE, WBERR

Local Integer NBMTCLEF, TNMTCLEF(500)
Local Char TLMTCLEF(20)(500), TECRCHP(250)(500), WAUTREECR(20), WTMASQUE(15)(5000), WSAUVEFCT(20)
Local Integer WNBMAS

ZADXIFS=adxifs
ZADXIRS=adxirs
adxifs=chr$(0)
adxirs=chr$(10)

If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif


If clalev ([F:AFC])
    Close File [AFC]
Endif
If clalev ([F:ADO])
    Close File [ADO]
Endif
If clalev ([F:ADH])
    Close File [ADH]
Endif
If clalev ([F:AWI])
    Close File [AWI]
Endif
If clalev ([F:ACT])
    Close File [ACT]
Endif
If clalev ([F:AOB])
    Close File [AOB]
Endif
If clalev ([F:AWT])
    Close File [AWT]
Endif
If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:AMC])
    Close File [AMC]
Endif
If clalev ([F:ADZ])
    Close File [ADZ]
Endif
If clalev ([F:AMK])
    Close File [AMK]
Endif

If clalev ([F:AST])
    Close File [AST]
Endif
If clalev ([F:AMA])
    Close File [AMA]
Endif
If clalev ([F:ATX])
    Close File [ATX]
Endif


Local File = DOSSIER2 + ".AFONCTION" [AFC]
Local File = DOSSIER2 + ".ADOCUMENT" [ADO]
Local File = DOSSIER2 + ".ADOCCLB" [ADH]
Local File = DOSSIER2 + ".AWINDOW" [AWI]
Local File = DOSSIER2 + ".ACTION" [ACT]
Local File = DOSSIER2 + ".AOBJET" [AOB]
Local File = DOSSIER2 + ".AWINBOUT" [AWT]
Local File = DOSSIER2 + ".AMSKZON" [AMZ]
Local File = DOSSIER2 + ".AMOTCLE" [AMC]
Local File = DOSSIER2 + ".ADOCFLD" [ADZ]
Local File = DOSSIER2 + ".AMSK" [AMK]

Local File = DOSSIER2 + ".APLSTD"  [AST]
Local File = DOSSIER2 + ".AMSKACT" [AMA]
Local File = DOSSIER2 + ".ATEXTE" [ATX]


Call TEMPON("Vérifications des documentations en cours...") From GESECRAN

SAUVEMODULE = -1


#Openo CHEMINTRAW, -1
#Wrseq "-------------------------### Vérification de" - PLIBVERIF + ". ###---------------------------"
#Wrseq
#Wrseq

#Openo

Openo CHEMINTRA, -1
Wrseq "-------------------------### Vérification de" - PLIBVERIF + ". ###---------------------------"
Wrseq
Wrseq





    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WNBMAS = 0
    Raz TERREUR
    Raz NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WTMASQUE, WSAUVEFCT

    If PFCTSEL = "" or PFCTSEL = "*"
        If PMODULE
            Filter [AFC] Where [F:AFC]MODULE = PMODULE and [F:AFC]TYPTRAIT = 1 and CODINT <> "GESARY" Order By [F:AFC]CODINT
        Else
            If EXCLSUP = 2
                Filter [AFC] Where [F:AFC]MODULE <> 1 and [F:AFC]TYPTRAIT = 1 and CODINT <> "GESARY" Order By [F:AFC]MODULE; [F:AFC]CODINT
            Else
                Filter [AFC] Where [F:AFC]TYPTRAIT = 1 and CODINT <> "GESARY" Order By [F:AFC]MODULE; [F:AFC]CODINT
            Endif
        Endif
    Else
        If PMODULE
            Filter [AFC] Where [F:AFC]MODULE = PMODULE and [F:AFC]TYPTRAIT = 1 and CODINT = PFCTSEL Order By [F:AFC]CODINT
        Else
            If EXCLSUP = 2
                Filter [AFC] Where [F:AFC]MODULE <> 1 and [F:AFC]TYPTRAIT = 1 and CODINT = PFCTSEL Order By [F:AFC]MODULE; [F:AFC]CODINT
            Else
                Filter [AFC] Where [F:AFC]TYPTRAIT = 1 and CODINT = PFCTSEL Order By [F:AFC]MODULE; [F:AFC]CODINT
            Endif
        Endif
    Endif

    For [AFC]
        NBTRAITES += 1
GTRECAPERR(GNUMMOUL, [F:AFC]MODULE, GNBERREUR(GNUMMOUL)) += 1
        WBERR = 0
        Read [ADO]ADO1 = PLANGUE; "AFC"; [F:AFC]CODINT; "PRE"
        If fstat
            Read [ADO]ADO0 = PLANGUE; "AFC"; [F:AFC]CODINT; 10; 20
        Endif
        If fstat
            Call ECRERRDOC( 1, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT,
&             "Documentation absente (paragraphe PRE)",
&             TERREUR, WSAUVEFCT, PNUMERRSEL)
        Else

            WBERR = 0
            Read [ADO]ADO1 = PLANGUE; "AFC"; [F:AFC]CODINT; "TIT"
            If fstat
                Read [ADO]ADO0 = PLANGUE; "AFC"; [F:AFC]CODINT; 10; 10
            Endif
            If fstat
                WBERR = 1
                WTEXTE = "Documentation absente (paragraphe TIT)"
            Else
                If [ADO]TIT = ""
                    WBERR = 1
                    WTEXTE = "Intitulé absent de la documentation (paragraphe TIT)"
                Endif
            Endif
            If WBERR
                Call ECRERRDOC(2, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT,
&                 WTEXTE, TERREUR, WSAUVEFCT, PNUMERRSEL)
            Endif


            # contrôle du clob
            WBERR = 0
            Read [ADH]ADH0 = PLANGUE; "AFC"; [F:AFC]CODINT; 10; 20
            If fstat
                WBERR = 1
            Else
                If [F:ADH]TEXTE = ""
                    WBERR = 1
                Endif
            Endif
            If WBERR
                Call ECRERRDOC(3, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT,
&                 "Texte non renseigné (paragraphe PRE)",
&                 TERREUR, WSAUVEFCT, PNUMERRSEL)
            Endif

            # contrôles de la fenêtre
            If [F:AFC]ACTION = "GOBJET"
                WOBJET = ""
                For I = 0 To 19
                    If [F:AFC]CODPAR(I) = "OBJET"
                        WOBJET = [F:AFC]VALPAR(I)
                        Break
                    Endif
                    I += 1
                Next I
                If WOBJET <> ""
                    WOBJET = left$(WOBJET, len(WOBJET) - 1)
                    WOBJET = right$(WOBJET, 2)

                    WNBTROUVE = 0
                    Filter [AWI] Where OBJ = WOBJET and WIN < "W"
                    For [AWI]AWI1(1)

                        WNBTROUVE += 1
                        Call CTLWIN([F:AWI]WIN, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT, PLANGUE, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, "", WTMASQUE, WNBMAS, WSAUVEFCT, PNUMERRSEL)
                    Next
                    Filter [AWI]

                Endif
            Elsif [F:AFC]ACTION <> ""
                Read [ACT]ACTION = [F:AFC]ACTION
                If fstat = 0

                    # fenêtre principale
                    If [F:ACT]PARAM2 <> ""

                        # lire d'abord PARAM4 (écran critère) pour gérer 2 écrans sur les paragraphes si il y a
                        WAUTREECR = ""
                        If [F:ACT]PARAM4 <> ""
                            Read [AWI]AWI0 = [F:ACT]PARAM4
                            If fstat = 0

                                If [F:AWI]MSKENT = ""
                                    WAUTREECR = [F:AWI]NOMMSK(0)
                                Else
                                    WAUTREECR = [F:AWI]MSKENT
                                Endif
                            Endif
                        Endif

                        Read [AWI]AWI0 = [F:ACT]PARAM2
                        If fstat = 0

                            Call CTLWIN( [F:ACT]PARAM2, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT, PLANGUE, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WAUTREECR, WTMASQUE, WNBMAS, WSAUVEFCT, PNUMERRSEL)
                        Endif
                    Endif

                    # fenêtre critère
                    If [F:ACT]PARAM4 <> ""

                        # lire d'abord PARAM2 (écran principal) pour gérer 2 écrans sur les paragraphes si il y a
                        WAUTREECR = ""
                        If [F:ACT]PARAM2 <> ""
                            Read [AWI]AWI0 = [F:ACT]PARAM2
                            If fstat = 0

                                If [F:AWI]MSKENT = ""
                                    WAUTREECR = [F:AWI]NOMMSK(0)
                                Else
                                    WAUTREECR = [F:AWI]MSKENT
                                Endif
                            Endif
                        Endif

                        Read [AWI]AWI0 = [F:ACT]PARAM4
                        If fstat = 0
                            Call CTLWIN( [F:ACT]PARAM4, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMODULE, NBERREUR, [F:AFC]CODINT, PLANGUE, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WAUTREECR, WTMASQUE, WNBMAS, WSAUVEFCT, PNUMERRSEL)
                        Endif
                    Endif
                Endif
            Endif

        Endif
    Next

    Filter [AFC]

    If PNUMERRSEL = 0 or PNUMERRSEL = 8
        Wrseq ""
        Wrseq ""
        Wrseq "Liste des mots clefs sans documentation :"
        Wrseq ""
        Wrseq num$(NBMTCLEF) - "mots clef trouvés (sans doc) sur" -num$(TERREUR(8)) - "champs en erreurs"
        Wrseq ""
        Wrseq "n°   nb champs trouvés    mot clef       écran/champ"
        Wrseq ""
        For I = 1 To NBMTCLEF
            WTEXTE = num$(I)
            If I > 99
                WTEXTE = WTEXTE + "         "
            Elsif I > 9
                WTEXTE = WTEXTE + "          "
            Else
                WTEXTE = WTEXTE + "           "
            Endif
            WTEXTE = WTEXTE + num$(TNMTCLEF(I))  + "               "
            Wrseq WTEXTE + TLMTCLEF(I) + string$(15 - len(TLMTCLEF(I)), " ") + TECRCHP(I)
        Next I
        Wrseq
    Endif

    Wrseq
    Wrseq
    Wrseq "Récapitulatif des erreurs :"
    Wrseq


    For I = 1 To GNBERREUR(GNUMMOUL)

        If I > 9
            WTEXTE = "Err  " + num$(I) + " Nombre :" - num$(TERREUR(I))
        Else
            WTEXTE = "Err" - num$(I) + "  Nombre :" - num$(TERREUR(I))
        Endif
        IB = len(WTEXTE)
        IB = 40 - IB

        If IB > 0
            WTEXTE = WTEXTE + string$(IB, " ")
        Endif

        Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, I)

    Next I
    Wrseq

    Call ECRFIN (NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT, PLIBVERIF)




    Call TEMPOFF From GESECRAN

    Close File [AFC]
    Close File [ADO]
    Close File [ADH]
    Close File [AWI]
    Close File [ACT]
    Close File [AOB]
    Close File [AWT]
    Close File [AMZ]
    Close File [AMC]
    Close File [ADZ]
    Close File [AMK]

    Close File [AST]
    Close File [AMA]
    Close File [ATX]

    Openo

End

Subprog ECRFIN (NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT, PLIBVERIF)
Value Integer NBERREUR, NBWARNING, NBTRAITES
Variable Integer NBERRTOT, NBWARTOT
Value Char PLIBVERIF

   If NBERREUR or NBWARNING
        Wrseq
        Wrseq num$(NBERREUR) - "erreurs trouvées sur" - num$(NBTRAITES) - "fonctions traitées"
        Wrseq
        Wrseq
        Wrseq "Fin de vérifications de" - PLIBVERIF + "." - time$
    Endif

    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING


    # rappel des règles d'accès aux tables de documentation :

    # Accès à la table ADOCUMENT. 2 façons possible :
    # soit en précisant la langue, le type, la fonction et le paragraphe
    # soit en précisant la langue, le type, la fonction, le niveau [et le sous niveau]
    # Accès à la table ADOCCLB
    # En précisant la langue, le type, la fonction, le niveau et le sous niveau
    # Accès à la table ADOCFLD
    # En précisant la langue et le mot clef


    # fonction :
    # [ADO]ADO1 = LANGUE; "AFC"; FONCTION; "PRE"   ou
    # [ADO]ADO0 = LANGUE; "AFC"; FONCTION; 10; 20

    # titre de la doc :
    # [ADO]ADO1 = LANGUE; "AFC"; FONCTION; "TIT"  ou
    # [ADO]ADO0 = LANGUE; "AFC"; FONCTION; 10; 10
    # présence du texte correspondant dans la table ADOCCLB
    # [ADH]ADH0 = LANGUE; "AFC"; FONCTION; 10; 20

    # lecture d'une fenêtre

      # masque entête
      # LANGUE; "AFC", FONCTION, 40, 100, "ENT"
      # onglets (attention : la doc va de 1 à n onglets tandis que [AWI] va de 0 à n-1)
      # LANGUE, "AFC", FONCTION, 40, 200 * n°Onglet, paragraphe
      # avec
      # paragraphe = "ON1 à ON9 puis ONA, ONB...
      # boutons (fct AFC BOU)
      # LANGUE, "AFC", FONCTION, 70, 10 * n° bouton(1..n), ""
      # menus (fct AFC BME)
      # PLANGUE, "AFC", PFONCTION, 80, 10 * n° menu, ""

      # zones d'un écran
      # si MOTCLE de la zone est renseigné :
      # [ADZ]ADZ0 = LANGUE; MOTCLE

      # vérif du clic droit sur les champs type bas de Tableau
      # LANGUE, "AFC", FONCTION, 40, 200 * PNUMONGLET + 5 * NBSUBLVL


End


Subprog CTLWIN(PFENETRE, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, PLANGUE, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, PAUTREECR, PTMASQUE, PNBMAS, PSAUVEFCT, PNUMERRSEL)
Value Char PFENETRE

Value Integer PMODULESEL, PMODULELU
Variable Char PTXTMODULE
Variable Shortint SAUVEMODULE
Variable Integer PNBERREUR
Value Char PFONCTION, PLANGUE
Variable Integer TERREUR(), NBMTCLEF, TNMTCLEF()
Variable Char TLMTCLEF(), TECRCHP()
Value Char PAUTREECR
Variable Char PTMASQUE()
Variable Integer PNBMAS
Variable Char PSAUVEFCT
Value Integer PNUMERRSEL



Local Integer I, WNBBOUT, WNBMENU, MAX_RG
Local Char WPARA(10), WRETOUR(5), WTXTBOUT(40), WECRDOC(10)

Local Char ONG_NOM(15)(1..16), WCHTMP(250)
Local Integer ONG_RG(1..16), ONG_NO(1..16)

    If PFENETRE = ""
        End
    Endif

    # titre de l'entête
    If [F:AWI]MSKENT <> ""
        Call LIREADOC(PLANGUE, "AFC", PFONCTION, 40, 100, "ENT", [F:AWI]MSKENT, WRETOUR, WECRDOC, PAUTREECR)
        If WRETOUR = "1"
            Call ECRERRDOC(4, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Entête" - [F:AWI]MSKENT - ":   Documentation absente",
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif

        If WRETOUR = "5"
            Call ECRERRDOC(10, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Entête" - [F:AWI]MSKENT - ":   Champ écran non renseigné dans la documentation (paragraphe ENT)",
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif
        If WRETOUR = "6"
            Call ECRERRDOC(11, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Entête" - [F:AWI]MSKENT - ":   Champ écran différent dans la documentation (paragraphe ENT) :" - WECRDOC,
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif
    Endif


    # liste des onglets     fct AFC ON1,2,3...  ADOCUMENT

    # Tri des différents onglets de la fenêtre dans l'ordre d'apparition

    MAX_RG = 0
    Raz ONG_RG, ONG_NOM, ONG_NO
    For I = 1 To [AWI]NBMSK
        ONG_NOM(I) = [AWI]NOMMSK(I-1)
        ONG_RG(I) = [AWI]ROWMSK(I-1)
        ONG_NO(I) = I
#If I > 1 and [AWI]ROWMSK(I-1) < ONG_RG(I - 1)
#Infbox num$(I) - num$([AWI]ROWMSK(I-1)) - num$(ONG_RG(I - 1)) - [AWI]NOMMSK(I-1) - ONG_NOM(I- 1)
#Endif
        If I > MAX_RG
            MAX_RG = I
        Endif
    #    ONG_ACT(II)=[AWI]ACTMSK(II-1)
    Next I

    Sorta [AWI]NBMSK ONG_RG, ONG_NOM, ONG_NO



    For I = 1 To [F:AWI]NBMSK

        If ONG_NO(I) > 9
            WPARA = "ON" + chr$(ONG_NO(I) + 55)
        Else
            WPARA = "ON" + num$(ONG_NO(I))
        Endif
#        If ONG_I > 9
#            WPARA = "ON" + chr$(I + 55)
#        Else
#            WPARA = "ON" + num$(I)
#        Endif
        Call LIREADOC(PLANGUE, "AFC", PFONCTION, 40, 200 * I, WPARA, ONG_NOM(ONG_NO(I)), WRETOUR, WECRDOC, PAUTREECR)

        If WRETOUR = "1" or left$(WRETOUR, 1) = "2"
            Call ECRERRDOC(4, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Ecran" - ONG_NOM(ONG_NO(I)) - ":   Documentation absente",
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif

        If WRETOUR = "5"
            Call ECRERRDOC(10, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Ecran" - ONG_NOM(ONG_NO(I)) - ":   Champ écran non renseigné dans la documentation (paragraphe ENT)",
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif
        If WRETOUR = "6"
            Call ECRERRDOC(11, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&             "Fenêtre" - PFENETRE - "Ecran" - ONG_NOM(ONG_NO(I)) - ":   Champ écran différent dans la documentation (paragraphe ENT) :" - WECRDOC,
&             TERREUR, PSAUVEFCT, PNUMERRSEL)
        Endif

            Call CTLMSQK (PFENETRE, ONG_NOM(ONG_NO(I)), I, PLANGUE, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WECRDOC, PTMASQUE, PNBMAS, PSAUVEFCT, PNUMERRSEL)

    Next I


    # boucle sur les docs d'onglets > à NBMASK (pour voir si il reste des docs correspondant à des onglets supprimés)
    For I = [F:AWI]NBMSK + 1 To 15
        If I > MAX_RG
            Read [ADO]ADO0 = PLANGUE; "AFC"; PFONCTION; 40; 200 * I

            If fstat = 0
                WCHTMP = "Fenêtre" - PFENETRE - "de" - num$([F:AWI]NBMSK) - "écrans :   La documentation existe pour l'écran n°" - num$(I) - "de paragraphe" - [ADO]PAR
                Call ECRERRDOC(12, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, WCHTMP,
&                    TERREUR, PSAUVEFCT, PNUMERRSEL)
            Endif
        Endif
    Next




    WNBBOUT = 1
    WNBMENU = 1
    For I = 0 To 19
        Read [AWT]AWT0(2) = [F:AWI]WIN; I
        If fstat = 0

            # boutons       fct AFC BOU
            If [F:AWT]TYPBOUT = 1
                WNBBOUT += 1
                Call LIREADOC(PLANGUE, "AFC", PFONCTION, 70, 10 * WNBBOUT, "", "", WRETOUR, WECRDOC, "")

                If WRETOUR <> ""
                    Read [ATX]NUMERO = PLANGUE; [F:AWT]TXTBOUT
                    If fstat
                        WTXTBOUT = ""
                    Else
                        WTXTBOUT = [F:ATX]TEXTE
                    Endif
                    Call ECRERRDOC(5, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&                     "Fenêtre" - PFENETRE - "Bouton" - WTXTBOUT + ":   Documentation absente",
&                     TERREUR, PSAUVEFCT, PNUMERRSEL)
                Endif

            # menus         fct AFC BME
            Elsif [F:AWT]TYPBOUT = 3
                WNBMENU += 1
                Call LIREADOC(PLANGUE, "AFC", PFONCTION, 80, 10 * WNBMENU, "", "", WRETOUR, WECRDOC, "")

                If WRETOUR <> ""
                    Read [ATX]NUMERO = PLANGUE; [F:AWT]TXTBOUT
                    If fstat
                        WTXTBOUT = ""
                    Else
                        WTXTBOUT = [F:ATX]TEXTE
                    Endif
                    Call ECRERRDOC(6, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&                     "Fenêtre" - PFENETRE - "Menu" - WTXTBOUT + ":   Documentation absente",
&                     TERREUR, PSAUVEFCT, PNUMERRSEL)
                Endif

            Endif
        Endif
    Next


    # masque entête
    If [F:AWI]MSKENT <> ""
        Call CTLMSQK (PFENETRE, [F:AWI]MSKENT, 0, PLANGUE, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WECRDOC, PTMASQUE, PNBMAS, PSAUVEFCT, PNUMERRSEL)
    Endif

    # boucle sur les écrans
#    For I = 1 To [F:AWI]NBMSK
#        If [F:AWI]NOMMSK(I - 1) <> ""
#            Call CTLMSQK (PFENETRE, [F:AWI]NOMMSK(I - 1), I, PLANGUE, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, TERREUR,
#& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WECRDOC, PTMASQUE, PNBMAS, PSAUVEFCT)
#        Endif
#    Next


#+ TARD, ON TRAITERA LES BOUTONS PRÉDÉFINIS DANS LES CAS DES FENÊTRES NON OBJETS

End


Subprog CTLMSQK(PFENETRE, PMASQUE, PNUMONGLET, PLANGUE, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION, TERREUR,
& NBMTCLEF, TNMTCLEF, TLMTCLEF, TECRCHP, WECRDOC, PTMASQUE, PNBMAS, PSAUVEFCT, PNUMERRSEL)
Value Char PFENETRE, PMASQUE
Value Integer PNUMONGLET    : # correspond à la position du rang (0 pour l'entête)
Value Char PLANGUE
Value Integer PMODULESEL, PMODULELU
Variable Char PTXTMODULE
Variable Shortint SAUVEMODULE
Variable Integer PNBERREUR
Value Char PFONCTION
Variable Integer TERREUR(), NBMTCLEF, TNMTCLEF()
Variable Char TLMTCLEF(), TECRCHP(), WECRDOC, PTMASQUE()
Variable Integer PNBMAS
Variable Char PSAUVEFCT
Value Integer PNUMERRSEL



Local Integer I, NBSUBLVL, WBACONTROLER
Local Char WRETOUR(5)


    # Issue 75246/7 - 2012-06-29 by VPO
    #Link [AMZ] With [F:AMK]CODMSK = CODMSK As [XTZ]
    Link [AMZ] With [F:AMK]CODMSK = [AMZ]CODMSK,[AMC]AMC0=2;[AMZ]CODMSK;[AMZ]CODZON As [XTZ]

    Filter [XTZ] Where [F:AMZ]CODMSK = PMASQUE and ([F:AMZ]SAIAFF = 1 or [F:AMZ]SAIAFF = 2)
&   Order By [F:AMK]RANG([F:AMZ]NUMBLOC - 1); [F:AMZ]SAIAFF; [F:AMZ]CODZON


    NBSUBLVL = 0

    If find(PMASQUE, PTMASQUE(1..PNBMAS))
        WBACONTROLER = 0
    Else
        WBACONTROLER = 1
        PNBMAS += 1
        PTMASQUE(PNBMAS) = PMASQUE
    Endif


    For [XTZ]

        If WBACONTROLER

            # Issue 75246/7 - 2012-06-29 by VPO
            #If [F:AMZ]MOTCLE = ""
            If [F:AMC]MOTCLE = ""
                # verifie que si le champ est sur un bloc de type liste et en saisie
                If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC - 1) = 2 and [F:AMZ]SAIAFF = 1
                    Call ECRERRDOC(7, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE,  PNBERREUR, PFONCTION,
&                       "Fenêtre" - PFENETRE - "écran" - PMASQUE -"champ" - [F:XTZ]CODZON - ":   mot clef d'aide absent",
&                       TERREUR, PSAUVEFCT, PNUMERRSEL)
                Endif
            Else
                # Issue 75246/7 - 2012-06-29 by VPO
                #Read [ADZ]ADZ0 = PLANGUE; [F:AMZ]MOTCLE
                Read [ADZ]ADZ0 = PLANGUE; [F:AMC]MOTCLE
                If fstat or (fstat = 0 and [F:ADZ]TEXTE = "")
                    Call ECRERRDOC(8, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&                        "Fenêtre" - PFENETRE - "écran" - PMASQUE -"champ" - [F:XTZ]CODZON - "mot clef" - [F:AMC]MOTCLE - ":   Aide sur champ absente",
&                        TERREUR, PSAUVEFCT, PNUMERRSEL)
                    # Issue 75246/7 - 2012-06-29 by VPO
                    I = find([F:AMC]MOTCLE, TLMTCLEF(1..NBMTCLEF))
                    If I
                        TNMTCLEF(I) +=1
                        TECRCHP(I) -= PMASQUE + "/" + [F:XTZ]CODZON
                    Else
                        NBMTCLEF += 1
                        TNMTCLEF(NBMTCLEF) = 1
                        # Issue 75246/7 - 2012-06-29 by VPO
                        #TLMTCLEF(NBMTCLEF) = [F:AMZ]MOTCLE
                        TLMTCLEF(NBMTCLEF) = [F:AMC]MOTCLE
                        TECRCHP(NBMTCLEF) = PMASQUE + "/" + [F:XTZ]CODZON
                    Endif
                Endif
            Endif
        Endif

        # vérif du clic droit sur champ bas de Tableau
        If PNUMONGLET and [F:AMZ]CODTYP = "ABS"

            Filter [AMA] Where CODAFF = PMASQUE and CODZON = [F:XTZ]CODZON and((TYPACT > 8 and TYPACT < 13) or (TYPACT > 14 and TYPACT < 31)) Order By TYPACT
            For [AMA]

                If [F:AMA]TYPACT > 8 and [F:AMA]TYPACT < 13
                    I = [F:AMA]TYPACT - 8
                Else
                    I = [F:AMA]TYPACT - 10
                Endif
                NBSUBLVL +=1
                Call LIREADOC(PLANGUE, "AFC", PFONCTION, 40, 200 * PNUMONGLET + 5 * NBSUBLVL, "", "", WRETOUR, WECRDOC, "")

                If WRETOUR <> ""
                    # menu 31
                    Call ECRERRDOC(9, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
&                     "Fenêtre" - PFENETRE - "Ecran" - PMASQUE - "champ" - [F:AMZ]CODZON - "bouton B" + num$(I) - ":   Documentation absente",
&                     TERREUR, PSAUVEFCT, PNUMERRSEL)
                Endif

            Next
            Filter [AMA]
        Endif
    Next

    Filter [XTZ]

End


Subprog LIREADOC(PLANGUE, PTYPE, PFONCTION, PLEVEL, PSUBLEV, PPARA, PECRAN, PRETOUR, WECRDOC, PAUTREECR)

Value Char PLANGUE, PTYPE, PFONCTION
Value Integer PLEVEL, PSUBLEV
Value Char PPARA, PECRAN
Variable Char PRETOUR, WECRDOC    : # écran différent trouvé dans ADOCUMENT
Value Char PAUTREECR              : # 2° écran ds le cas d'actions à 2 fenêtres (donc 2 écrans)


        PRETOUR = ""
        WECRDOC = ""

        If PPARA = ""
            If PSUBLEV
                Read [ADO]ADO0 = PLANGUE; PTYPE; PFONCTION; PLEVEL; PSUBLEV
            Else
                Read [ADO]ADO0(4) = PLANGUE; PTYPE; PFONCTION; PLEVEL
            Endif
        Else
            Read [ADO]ADO1 = PLANGUE; PTYPE; PFONCTION; PPARA
        Endif

        If fstat
            Filter [ADO] Where LAN = PLANGUE and TYP = PTYPE and COD = PFONCTION and LEV = PLEVEL and SUBLEV = PSUBLEV and (PAR = "INC" or PAR = "MIS")
            Read [ADO]ADO1 First
            Filter [ADO]

            If fstat
                PRETOUR = "1"
                End
            Endif
        Endif

        # si c'est un INClude, fin du contrôle ou code activité à FALse
        If [ADO]PAR = "INC" or [F:ADO]CODACT = "FAL"
            End
        Endif

        # pour l'entête et les onglets, l'écran doit être renseigné
        If ([F:ADO]PAR = "ENT" or left$([F:ADO]PAR, 2) = "ON") and [F:ADO]MSK = ""
            PRETOUR = "5"
            End
        Endif

        # pour l'entête et les onglets, l'écran doit être renseigné
        If ([F:ADO]PAR = "ENT" or left$([F:ADO]PAR, 2) = "ON") and ([F:ADO]MSK <> PECRAN and [F:ADO]MSK <> PAUTREECR)
            PRETOUR = "6"
            WECRDOC = [F:ADO]MSK
            End
        Endif
        # titre vide (sauf PAR = INC qui fait un include)
        If [ADO]TIT = ""
            PRETOUR = "2"
        Endif



        # contrôle du clob
        Read [ADH]ADH0 = PLANGUE; PTYPE; PFONCTION ; [F:ADO]LEV ; [F:ADO]SUBLEV
        If fstat
            PRETOUR = PRETOUR + "3"
            End
        Endif

        # texte vide
        If [F:ADH]TEXTE = ""
            PRETOUR = PRETOUR + "4"
            End
        Endif

 End


Subprog ECRERRDOC(PFLAG, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMODULE, PNBERREUR, PFONCTION,
& PTXTERR, TERREUR, PSAUVEFCT, PNUMERRSEL)
Value Integer PFLAG
Value Integer PMODULESEL, PMODULELU
Variable Char PTXTMODULE
Variable Shortint SAUVEMODULE
Variable Integer PNBERREUR
Value Char PFONCTION, PTXTERR
Variable Integer TERREUR()
Variable Char PSAUVEFCT
Value Integer PNUMERRSEL


Local Char WECR(250)
Local Integer IE

    If PNUMERRSEL and PNUMERRSEL <> PFLAG
        End
    Endif

    TERREUR(PFLAG) += 1
    PNBERREUR += 1
    GTRECAPERR(GNUMMOUL, PMODULELU, PFLAG) += 1

    If PMODULESEL = 0
        If PMODULELU <> SAUVEMODULE
            PTXTMODULE = "Module" - num$(PMODULELU) - func AVERIFSRC.LIBMODULE (PMODULELU, SAUVEMODULE)
            Wrseq ""
            Wrseq ""
            Wrseq PTXTMODULE

            IE = len(PTXTMODULE)
            If IE > 0
                PTXTMODULE = string$(IE, "-")
                Wrseq PTXTMODULE
            Endif

            Wrseq ""
        Endif
    Else
        PTXTMODULE = ""
    Endif

    If PFLAG > 9
        WECR = "(Err " + num$(PFLAG)
    Else
        WECR = "(Err  " + num$(PFLAG)
    Endif

    If PSAUVEFCT = PFONCTION
        WECR = WECR + ")           " + string$(15, " ")
    Else
        WECR = WECR + ")  Fonction " + PFONCTION

        IE = len(PFONCTION)
        WECR = WECR + string$(15 - IE, " ")

        PSAUVEFCT = PFONCTION
    Endif
    WECR = WECR + PTXTERR

    Wrseq WECR

End
