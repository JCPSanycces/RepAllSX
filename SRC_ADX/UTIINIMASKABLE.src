#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# X3-91078
# Initialize ISMASKABLE field in table AMSKZON
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("UTIINIMASKABLE - Init ISMASKABLE field from AMSKZON & ASHWEXPPRO") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog INI_ISMASKABLE(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER <>""
    If [L]DOSSIER=nomap
      Local File AMSKZON    [AMZ2]
      Local File ASHWEXPPRO [ASWR2]
    Else
      Local File =[L]DOSSIER+".AMSKZON"    [AMZ2]
      Local File =[L]DOSSIER+".ASHWEXPPRO" [ASWR2]
    Endif
  Else
    End
  Endif

  If dim([AMZ2]ISMASKABLE)>0
    Trbegin [AMZ2]
    Update [AMZ2] Where ISMASKABLE<1 With ISMASKABLE=1
    If !fstat
      Commit
      Call ECR_TIME ("Initialization of ISMASKABLE in AMSKZON done") From DOSSUB
    Else
      Rollback
      Call ECR_TIME ("Error during initialization of ISMASKABLE in AMSKZON") From DOSSUB
    Endif

    If dim([ASWR2]ISMASKABLE)>0
      Trbegin [ASWR2]
      Update [ASWR2] Where ISMASKABLE<1 With ISMASKABLE=1
      If !fstat
        Commit
        Call ECR_TIME ("Initialization of ISMASKABLE in ASHWEXPPRO done") From DOSSUB
      Else
        Rollback
        Call ECR_TIME ("Error during initialization of ISMASKABLE in ASHWEXPPRO") From DOSSUB
      Endif
    Endif
  Endif

  LogicClose File [AMZ2]
  LogicClose File [ASWR2]
End

########################################################################
# Automatic executed by patch
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
  Call INI_ISMASKABLE(DOSSIER)
End

#######################################################################
# Executed by dosmaj (folder validation)
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER
  Call INI_ISMASKABLE(DOSSIER)
End

