# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
$CTL_CTX_VAT_OPTIMIZED
If dim(GACTX)<0 : Gosub CTL_CTX_VAT From TRTX3 : Return : Endif

  WOK_CTX_VAT = 0
  Local Integer ZWINDEX_TVT,ZWINDEX_TRA,ZWFOUND,ZWINDEX
  Local Date    ZWSTRDAT

  ZWINDEX_TVT = fmet GACTX.ACACHE.TVT.AGETINDEX([F:TVC]VAT,WDOCCURLEG)
  If ZWINDEX_TVT=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).RECORD_EXIST=[V]CST_ANOTDEFINED)
    WOK_CTX_VAT=[V]CST_AERROR
  Endif
  If WOK_CTX_VAT=[V]CST_AERROR : ZWINDEX_TVT=[V]CST_ANOTDEFINED : Return : Endif

  ZWFOUND     = [V]CST_ANO
  #--Usage of sigma because of the STRDAT<=[F:TLK]DAT !!
  ZWINDEX_TRA = [V]CST_ANOTDEFINED

  ZWINDEX_TRA = sigma (indcum=1,maxtab(GACTX.ACACHE.TRA.ACOL),
&                         (GACTX.ACACHE.TRA.ACOL(indcum)<>null and
&                          GACTX.ACACHE.TRA.ACOL(indcum).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&                          GACTX.ACACHE.TRA.ACOL(indcum).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURCPY  = GSOCIETE and
&                          GACTX.ACACHE.TRA.ACOL(indcum).STRDAT <= [F:TLK]DAT))
  #infbox "CTL_CTX_VAT_OPTIMIZED SOC="+GSOCIETE-"Suffice to find at least one Sigma ZWINDEX_TRA="+num$(ZWINDEX_TRA)
  If ZWINDEX_TRA > 0
    #--One is enough in this case; no need to have the exactly index
    ZWFOUND = [V]CST_AYES
  Else
    ZWFOUND = [V]CST_ANO
  Endif
  If ZWFOUND <> [V]CST_AYES #--previous code
    # 101874 : V9 : Taxe code control
    # Contrôle des lignes de taux : On vérifie qu'il existe une ligne de taux valide pour la société et la date du document
    Filter [TRA] Where CPY=GSOCIETE & VAT=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT & STRDAT<=[F:TLK]DAT & (LEG=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG)
    Read [F:TRA] Last
    If fstat <= 2
      ZWFOUND=[V]CST_AYES
      #--We add the entry for the existing last key, thus the next search will be done on cached entries
      ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,WDOCCURLEG,
&                                                    GSOCIETE,[F:TRA]STRDAT)
      #infbox "CTL_CTX_VAT_OPTIMIZED Dans Filter TRA avec Read Last SOC="+GSOCIETE-"ZWINDEX_TRA="+num$(ZWINDEX_TRA)
    Else
      Filter [TRA] Where CPY="" & VAT=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT & STRDAT<=[F:TLK]DAT & (LEG=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG)
      Read [F:TRA] Last
      If fstat <= 2
        ZWFOUND=[V]CST_AYES
        #--We add the entry for the existing last key, thus the next search will be done on cached entries
        ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,WDOCCURLEG,
&                                                      GSOCIETE,[F:TRA]STRDAT) #"",[F:TRA]STRDAT)
#infbox "CTL_CTX_VAT_OPTIMIZED Dans Filter TRA avec Read Last SOC='' ZWINDEX_TRA="+num$(ZWINDEX_TRA)
      Endif
    Endif
    # Aucun taxe n'est applicable
    If ZWFOUND<>[V]CST_AYES
        WOK_CTX_VAT=[V]CST_AERROR
    Endif
    Filter [TRA]
  Endif
  # 101874

Return
#--------------------------------------------------------------------------------------------------
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
$CLC_TAXEPRI_OPTIMIZED

Local Integer ZWINDEX_TVT, ZWINDEX_TVB, ZWINDEX_TRA

For I=0 To 2
  If VAT(I) <> "" Then
    WRET=0
    # X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
    #--We don't need the F:TVT to be read, we need only to find the right VAT+LEG entry
    ZWINDEX_TVT = fmet GACTX.ACACHE.TVT.AGETINDEX(VAT(I),GCURLEG)
    If ZWINDEX_TVT=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).RECORD_EXIST=[V]CST_ANOTDEFINED)
      WRET=[V]CST_AERROR
    Endif
    If WRET : ZWINDEX_TVT=[V]CST_ANOTDEFINED : Endif
    If !WRET
      TAX=VAT(I) : Gosub LECTAX_OPTIMIZED
      If TXTAX<>0
        #----- Si taxe avec formule de calcul et no montant renseigné -----#
        If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATFOR<>"" & GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS<>1
          #----- Utilisation bases spéciales 1-7 en fonction du rang de la taxe -----#
          If WTRT=2
            TXTF(I)+=TXTAX/100
            If I=0
              TXTVA=TXTAX
            Endif
            If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA=2 & I<>0
              TXTF(I)+=(TXTAX/100)*(TXTVA/100)
            Endif
          #----- Utilisation bases spéciales 1-2 en fonction du paramétrage taxe -----#
          Else
            #----- Base = montant1 -----#
            If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS=2
              TXTF1+=TXTAX/100
              If I=0
                TXTVA=TXTAX
              Endif
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA=2 & I<>0
                TXTF1+=(TXTAX/100)*(TXTVA/100)
              Endif
            #----- Base = montant2 -----#
            Elsif GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS=3
              TXTF2+=TXTAX/100
              If I=0
                TXTVA=TXTAX
              Endif
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA=2 & I<>0
                TXTF2+=(TXTAX/100)*(TXTVA/100)
              Endif
            Endif
          Endif
        #----- Si taxe sans formule de calcul ou no montant non renseigné -----#
        Else
          TXTOT+=TXTAX/100
          If I=0
            TXTVA=TXTAX
          Endif
          If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA=2 & I<>0
            TXTOT+=(TXTAX/100)*(TXTVA/100)
          Endif
        Endif
      Endif
    Endif
  Endif
Next I
#-----
TXTOT+=1
If PRITYP=1
  PRIXCALC=PRIXBASE*TXTOT
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXCALC+=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXCALC+=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXCALC+=CLCAMT2*TXTF2/QTY : Endif
  Endif
  PRIXCALC=arr(PRIXCALC,10^-GDECPRI)
Else
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXBASE-=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXBASE-=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXBASE-=CLCAMT2*TXTF2/QTY : Endif
  Endif
  If WSVGPRIXBASE >= 0
      # Prix de base positif : Eviter un prix négatif
      PRIXCALC = max(0,PRIXBASE/TXTOT)
  Else
      # Prix de base négatif (par utilisation PE NEGPRI), c'est normal d'avoir un prix négatif
      PRIXCALC = PRIXBASE/TXTOT
  Endif
  PRIXCALC=arr(PRIXCALC,10^-GDECPRI)
Endif
Filter [TRA]
Return
#--------------------------------------------------------------------------------------------------
$LECTAX_OPTIMIZED
TXTAX=0
If dim(GACTX)<0 : Gosub LECTAX From TRTX3 : Return : Endif

  ZWFOUND     = [V]CST_ANO
  #--Usage of sigma because of the STRDAT<=[F:TLK]DAT !!
  ZWINDEX_TRA = [V]CST_ANOTDEFINED

  #--Possible problem when :
  #-- TRA : STRDAT=01/03/2017 RAT=21%
  #--       STRDAT=01/01/2017 RAT=20%
  #--Doc 1 : doc date 02/03/2017 => Filter with Read last will add into TRA.ACOL the entry STRDAT=01/03/2017 with 21%
  #--Doc 2 : doc date 28/02/2017 => Filter with Read last will add into TRA.ACOL the entry STRDAT=01/01/2017 with 20%
  #--If Doc 3 doc date 03/03/2017, the sigma will bring both STRDAT 01/01/2017 and 01/03/2017, as it is done for all ACOL.STRDAT <= DAT ==> NOK !!
  #--For this, we have to do 2 sigmas : first with (condition) => gives 0 (no entry, 1 1 entry true OK, >1 Multiple entries NOK)
  #--If 0 : go with former code Filter + Read last
  #--If 1 : do a second sigma with indcum*(condition) => gives the index for the right tax rate
  #--If >1 : do a for loop to find the latest date for the TRA key (in our case the 01/03/2017, and not the 01/01/2017)
  #--Hence, the following code after sigma...
  ZWINDEX_TRA = sigma (indcum=1,maxtab(GACTX.ACACHE.TRA.ACOL),
&                         (GACTX.ACACHE.TRA.ACOL(indcum)<>null and
&                          GACTX.ACACHE.TRA.ACOL(indcum).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&                          GACTX.ACACHE.TRA.ACOL(indcum).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURCPY  = SOC and
&                          GACTX.ACACHE.TRA.ACOL(indcum).STRDAT <= DAT))
  #infbox "LECTAX_OPTIMIZED SOC="+GSOCIETE-"First Sigma ZWINDEX_TRA="+num$(ZWINDEX_TRA)
  If ZWINDEX_TRA = 1
    #--Only one entry found, We'll take this one (A new sigma with indcum* will suffice to point to the right index)
    ZWINDEX_TRA = sigma (indcum=1,maxtab(GACTX.ACACHE.TRA.ACOL),indcum*
&                         (GACTX.ACACHE.TRA.ACOL(indcum)<>null and
&                          GACTX.ACACHE.TRA.ACOL(indcum).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&                          GACTX.ACACHE.TRA.ACOL(indcum).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURCPY  = SOC and
&                          GACTX.ACACHE.TRA.ACOL(indcum).STRDAT <= DAT))
    If ZWINDEX_TRA>0
      #--Great ! We have the right index
      ZWFOUND = [V]CST_AYES
    Else
      ZWFOUND = [V]CST_ANO
    Endif
  Elsif ZWINDEX_TRA > 1
    #--In this case, more than one entry is found (meaning that we do have in the context, tax rates for different STRDAT)
    #--We'll have to select the latest one according to the DAT date
    ZWSTRDAT = [0/0/0]
    ZWINDEX  = 0
    For ZWINDEX_TRA = 1 To maxtab(GACTX.ACACHE.TRA.ACOL)
      If GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA)<>null and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).CURCPY  = SOC and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT <= DAT

        If GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT >= ZWSTRDAT
          ZWSTRDAT = GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT
          ZWINDEX  = ZWINDEX_TRA
        Endif
      Endif
    Next
    If ZWSTRDAT<>[0/0/0] or ZWINDEX<>0
      ZWINDEX_TRA = ZWINDEX
      ZWFOUND = [V]CST_AYES
    Else
      ZWFOUND = [V]CST_ANO
    Endif
  Else
    ZWFOUND = [V]CST_ANO
  Endif

  If ZWFOUND = [V]CST_AYES
    #infbox "LECTAX_OPTIMIZED SOC="+GSOCIETE-"After first Sigma ZWINDEX_TRA="+num$(ZWINDEX_TRA)
    TXTAX = GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATRAT
    If VACBPR<>""

      ZWINDEX_TVB = fmet GACTX.ACACHE.TVB.AGETINDEX(VACBPR,GCURLEG)
      If ZWINDEX_TVB=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVB.ACOL(ZWINDEX_TVB).RECORD_EXIST=[V]CST_ANOTDEFINED)
        ZWFOUND = [V]CST_ANO
      Endif
      If ZWFOUND = [V]CST_AYES
        If GACTX.ACACHE.TVB.ACOL(ZWINDEX_TVB).REGVAC<>1 & dim(GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG)>0 & GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG=2
          TXTAX=0
        Endif
      Else
        Gosub LEC_TVB_OLDWAY
        If [F:TVB]REGVAC<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif
      Endif
    Endif

  Else #--previous code

    Filter [TRA] Where CPY=SOC & VAT=TAX & STRDAT<=DAT & LEG=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
    Read [TRA]TRA0 Last
    If fstat>2
      # sinon on se rabat sur le code dossier
       Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT & LEG=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
       Read [TRA]TRA0 Last
       If fstat>2
         STAT = 2 : Filter [F:TRA]
         Return
       Else
         #--We add the entry for the existing last key, thus the next search will be done on cached entries
         ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,GCURLEG,
&                                                      SOC,[F:TRA]STRDAT) #"",[F:TRA]STRDAT)
 #infbox "LECTAX_OPTIMIZED Dans Filter TRA avec Read Last SOC="+GSOCIETE-"ZWINDEX_TRA="+num$(ZWINDEX_TRA)
       Endif
    Else
       #--We add the entry for the existing last key, thus the next search will be done on cached entries
       ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,GCURLEG,
&                                                      SOC,[F:TRA]STRDAT)
       #infbox "LECTAX_OPTIMIZED Dans Filter TRA avec Read Last SOC="+GSOCIETE-"ZWINDEX_TRA="+num$(ZWINDEX_TRA)
    Endif

    TXTAX = [F:TRA]VATRAT

    If VACBPR<>""
      Gosub LEC_TVB_OLDWAY
      If [F:TVB]REGVAC<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif
    Endif

    Filter [TRA]
  Endif
Return
#--------------------------------------------------------------------------------------------------
$LEC_TVB_OLDWAY

  If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
  #--ususaly the TVB File is opened way before
  #--for performance purpose, and to avoid the call, i'll add a test on TVB
  If [F:TVB]VACBPR<>VACBPR | [F:TVB]LEG<>GCURLEG
    Local Integer WRET
    Call LEC_TVB_LEG(GCURLEG,VACBPR,WRET) From TRTLECLEG
    If WRET Raz [F:TVB] : Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
$CLC_TAXEMNT_OPTIMIZED
#Fq74432-Gbn-Ajout PE non documenté pour permettre aux US de court-circuiter lr calcul std des taxes au profit d'AVATAX
Raz GPE : GPOINT="CLCTAXMNT" : Gosub ENTREE From EXEFNC : If GPE : Return : Endif   #CHECK IGNORE_LINE

Local    Decimal TXTVA, TXTAX
Local    Decimal TXTOT
Local    Decimal TAXE1
Local    Decimal TAXE2
Local    Char    TAX(GLONVAT)
Local    Integer STAT : STAT = 0
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
Local Integer  ZWINDEX_TVT, ZWINDEX_TRA, ZWFOUND
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
#-----
If !clalev([F:TVT])  Local File TABVAT    [TVT] : Endif
If !clalev([F:TRA])  Local File TABRATVAT [TRA] : Endif
#-----
Raz TXTOT, TAXE1, TAXE2

# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
#--as the call is made for each tax in LECTAX, better to do it here
#--ususaly the TVB File is opened way before
#--for performance purpose, and to avoid the call, i'll add a test on TVB
#If VACBPR<>""
#  If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
#  If [F:TVB]VACBPR<>VACBPR | [F:TVB]LEG<>GCURLEG
#    Local Integer WRET
#    Call LEC_TVB_LEG(GCURLEG,VACBPR,WRET) From TRTLECLEG
#    If WRET Raz [F:TVB] : Endif
#  Endif
#Endif
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)

For I=0 To 2
  If VAT(I) <> "" Then
    # X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
    #--We don't need the F:TVT to be read, we need only to find the right VAT+LEG entry
    WRET=0

    ZWINDEX_TVT = fmet GACTX.ACACHE.TVT.AGETINDEX(VAT(I),GCURLEG)
    If ZWINDEX_TVT=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).RECORD_EXIST=[V]CST_ANOTDEFINED)
      WRET=[V]CST_AERROR
    Endif

    If WRET=0
      TAX=VAT(I) : Gosub LECTAX_OPTIMIZED
      #----- Si taux de taxe différent de 0 -----#
      If TXTAX<>0
        #----- Taxe avec formule de calcul -----#
        If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATFOR<>""
          #----- Utilisation bases spéciales 1-7 en fonction du rang de la taxe -----#
          If WTRT=2
            If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS>1
              TAXE1  += CLCAMT(I)*(TXTAX/100)
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA = 2 & I <> 0
                TAXE1 += CLCAMT(I)*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
          #----- Utilisation bases spéciales 1-2 en fonction du paramétrage taxe -----#
          Else
            If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS = 2
              TAXE1  += CLCAMT1*(TXTAX/100)
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA = 2 & I <> 0
                TAXE1 += CLCAMT1*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
            If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS = 3
              TAXE2  += CLCAMT2*(TXTAX/100)
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA = 2 & I <> 0
                TAXE2 += CLCAMT2*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
          Endif
        #----- Taxe classique sans formule -----#
        Else
          TXTOT += TXTAX/100
          If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA = 2 & I <> 0
            TXTOT += (TXTAX/100) * (TXTVA/100)
          Endif
        Endif
        #----- Récupération taux TVA pour taxes secondaires sousmises à TVA -----#
        If I = 0 : TXTVA = TXTAX : Endif
      Endif
    Endif
  Endif
Next I
TXTOT += 1
If PRITYP = 1
  MONTCALC = MONTBASE*TXTOT + TAXE1 + TAXE2
Else
  MONTCALC = max(0,(MONTBASE - TAXE1 - TAXE2) / TXTOT)
Endif
Filter [TRA]
Return
#--------------------------------------------------------------------------------------------------
$TRT_ALICLCAMT_OPTIMIZED
Local  Libelle  X : X=3+4*func TRTX3.ACTIV_PTX
#-----
Local    Libelle ALICLCAMT_FLG : # Pour test dans ALITLK (Origine du Gosub)
#-----
Local    Integer TRAIT
Local    Char    VAT(GLONVAT)(X)
Local    Integer I
Local    Decimal WTAXBAS
Local    Date    WDAT
Local    Char    WCUR(GLONCUR),  WVACITM(GLONTVI)(3)
Local    Integer WCHGTYP, WSTAT, WVATBAS
Local    Decimal COEFDEVISE    : COEFDEVISE = 1 : # coef.conv. devise
Local    Integer WRET
#-----
If WTRT=2  Raz WCLCAMT  Else  Raz WCLCAMT1, WCLCAMT2 : Endif
#-----
If !clalev([F:TFO])  Local File TABFOR [TFO] : Endif
If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
If !clalev([F:TCU])  Local File TABCUR [TCU] : Endif
#-----
Case ABREV
  When "CRM1", "CRM2", "CRM3", "CRM4", "CRM5", "CRM6"
    VAT (0) = [M:SPSW]VAT(0)
    VAT (1) = [M:SPSW]VAT(1)
    VAT (2) = [M:SPSW]VAT(2)
  When "SOH4"
    If NOLIG >= 0
      VAT (0) = [M:SOH4]VAT1(NOLIG)
      VAT (1) = [M:SOH4]VAT2(NOLIG)
      VAT (2) = [M:SOH4]VAT3(NOLIG)
    Endif
  When Default
    # TODO later : should get rid of the evalue (as done when ABREV="SOH4")
    If NOLIG >= 0
      VAT (0) = evalue("[M:"+ABREV+"]VAT1(NOLIG)")
      VAT (1) = evalue("[M:"+ABREV+"]VAT2(NOLIG)")
      VAT (2) = evalue("[M:"+ABREV+"]VAT3(NOLIG)")
      If X>3 & evalue("dim([M:"+ABREV+"]TAXRCP(NOLIG))")>0
        VAT (3) = evalue("[M:"+ABREV+"]TAXRCP (NOLIG)")
        VAT (4) = evalue("[M:"+ABREV+"]TAXISS (NOLIG)")
        VAT (5) = evalue("[M:"+ABREV+"]TAXOTH1(NOLIG)")
        VAT (6) = evalue("[M:"+ABREV+"]TAXOTH2(NOLIG)")
      Endif
    Else
      VAT (0) = evalue("[F:"+ABREV+"]VAT(0)")
      VAT (1) = evalue("[F:"+ABREV+"]VAT(1)")
      VAT (2) = evalue("[F:"+ABREV+"]VAT(2)")
      If X>3 & evalue("dim([F:"+ABREV+"]TAXRCP)")>0
        VAT (3) = evalue("[F:"+ABREV+"]TAXRCP")
        VAT (4) = evalue("[F:"+ABREV+"]TAXISS")
        VAT (5) = evalue("[F:"+ABREV+"]TAXOTH1")
        VAT (6) = evalue("[F:"+ABREV+"]TAXOTH2")
      Endif
    Endif
Endcase
#-----
For I=0 To X-1
  If VAT(I) <> "" Then
    ZWFOUND=[V]CST_AYES
    ZWINDEX_TVT = fmet GACTX.ACACHE.TVT.AGETINDEX(VAT(I),GCURLEG)
    If ZWINDEX_TVT=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).RECORD_EXIST=[V]CST_ANOTDEFINED)
      ZWFOUND=[V]CST_ANO
    Endif
    If ZWFOUND=[V]CST_AYES
      #----- Si taxe avec formule de calcul -----#
      If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATFOR <> ""
        Read [TFO] TFO0=1;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATFOR
        If !fstat
          #-----
          If !clalev([F:ITM])  Local File ITMMASTER [ITM] : Endif
          If !clalev([F:ITS])  Local File ITMSALES  [ITS] : Endif
          If !clalev([F:TLK])  Local File TAXLINK   [TLK] : Endif
          #-----
          If (instr(1,[F:TFO]FORFOR,"ITM]") | instr (1,[F:TFO]FORFOR,"ITMWEI")) & [F:ITM]ITMREF<>ART
            Read [ITM] ITM0=ART : If fstat  Raz [F:ITM] : Endif
          Endif
          If instr (1,[F:TFO]FORFOR,"ITS]") & [F:ITS]ITMREF<>ART
            Read [ITS] ITS0=ART : If fstat  Raz [F:ITS] : Endif
          Endif
          #-----
          WVATBAS=GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS : # Attention la classe [F:TVT] peut être altérée par l'ALITLK
          Gosub ALITLK From TRTX3
          #-----
          Onerrgo ERR_FORMULE From TRTX3
          #----- Chargement des 7 bases spéciales en fonction du rang de la taxe -----#
          If WTRT=2
            If WVATBAS>1
              WCLCAMT(I)=evalue([F:TFO]FORFOR)
              Call ARRDEV(WCLCAMT(I),WCUR) From TRTDIV
            Endif
          #----- Chargement bases spéciales 1 et 2 en fonction du paramétrage taxe -----#
          Else
            If WVATBAS=2
              WCLCAMT1=evalue([F:TFO]FORFOR)
              Call ARRDEV(WCLCAMT1,WCUR) From TRTDIV
            Else
              WCLCAMT2=evalue([F:TFO]FORFOR)
              Call ARRDEV(WCLCAMT2,WCUR) From TRTDIV
            Endif
          Endif
          #-----
          Onerrgo
        Endif
      Endif
    Endif
  Endif
Next
Return
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
#--------------------------------------------------------------------------------------------------

