#--Code used for copying on local laptop huge logs above 2 GO (they have to previously be zipped on server on /TRA /TMP folders)
Local Integer ZWRET

Local Char    ZWRESULT(250)(1..)
Local Integer ZWSTAT
Local Char    ZWORDSYS, MYLOG(250), LOGFILE(250)

Raz [L]ZWORDSYS, [L]ZWSTAT,[L]ZWRESULT
MYLOG = "x3diary_cpo_4071_2"
#build the fullpath on the server
LOGFILE = filpath("tmp",MYLOG,"tgz") #/folders/REPOSX3/TMP/x3diary_cpo_1120_3.tgz
Infbox LOGFILE-"filinfo(LOGFILE,0)="+num$(filinfo(LOGFILE,0))
#build the name of the destination file
MYLOG = MYLOG+".tra.tgz" #LOGFILE="x3diary_cpo_4071_2.tgz"
#copy the file from the server to the client browser
Call COPCLI(LOGFILE,MYLOG,ZWRET) From ORDSYS
Infbox "ZWRET="+num$(ZWRET)

