#<AdxTL>@(#)1.0.0.0 $Revision$
##############################################################################
## Génération du fichier PARAM.ini
##############################################################################
Call PATCH_X3(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
If clalev([F:ADA])=0 : Local File ADOSACT  [ADA] : Endif
If clalev([F:ADE])=0 : Local File ADOSDIM  [ADE] : Endif
If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>nomap
 Read [ADS]DOSSIER = nomap
Endif
Call CREPAR From DOSDIV
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
If clalev([F:ADA])=0 : Local File ADOSACT  [ADA] : Endif
If clalev([F:ADE])=0 : Local File ADOSDIM  [ADE] : Endif
If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>nomap
 Read [ADS]DOSSIER = nomap
Endif
Call CREPAR From DOSDIV
End

