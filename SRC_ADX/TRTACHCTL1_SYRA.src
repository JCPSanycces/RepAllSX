#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################################
# TRTACHCTL1_SYRA         Traitements de contrôle               Module ACHAT #
# Contrôle sur champs - Après modif sur champs -                             #
# -------------------------------------------------------------------------- #
# Actions sur champs :                                                       #
#   - C_ITMREF   : Contrôle référence article                                #
#   - C_FCY      : Contrôle paramétrage règle de signature                   #
#   - C_RCPFCY   : Contrôle site de réception et même société juridique      #
#   - C_INVFCY   : Contrôle site financier et même société juridique         #
#   - C_PRHFCY   : Contrôle article-site réception en DA et cde ouverte      #
#   - PCOUOM     : Contrôle d'une unité                                      #
#   - PCOVAT     : Contrôle correspondance régime taxe d'un code taxe        #
#                                                                            #
# Sous-programmes divers :                                                   #
#   - CTLITMBUY  : Contrôle qu'un article est géré par l'acheteur            #
#   - CTLITMFCY  : Contrôle existence d'un article-site                      #
#   - CTLPER     : Contrôle période comptable                                #
#   - CTRL_INTERSITE : S/P de contrôle et chargement zones pour inter-sites  #
#                                                                            #
# Actions sur champs :                                                       #
#   - AM_BPSNUM  : Après modif fournisseur                                   #
#   - AM_ITMREF  : Après modif référence article                             #
#   - PAMPRHFCY  : Après modif site de réception en DA et commande           #
#   - PAMQTYSCO  : Après modif quantité article sous-traitance               #
# -------------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                     #
#   - TRTPRHFCY  : Contrôle existence article-site et création si nécessaire #
#                                                                            #
# ACTIONS modélisation WEB (Affichages divers GACTION)                       #
#   - CTLPCOITMR : Contrôle référence article achat                          #
#   - CTLPRHFCY  : Contrôle du site de réception                             #
##############################################################################


$ACTION

Return

#########################################################################
# CTRL_INTERSITE : S/P de contrôle et chargement zones pour inter-sites #
#-----------------------------------------------------------------------#
# Subprog CTRL_INTERSITE                                  MBT 12/06/03  #
# --------------------------------------------------------------------- #
# Paramètres en entrée                                                  #
#   WPOHFCY : Site de commande                                          #
#   WBPSNUM : Fournisseur de la commande                                #
#   WTRAIT  : Code traitement 0-1=auto sans choix                       #
#                             2=interactif                              #
#                             3=interactif & blocage si fou inter-sites #
#   GRCPFCY : Site de réception si celui-ci est déjà connu !            #
# --------------------------------------------------------------------- #
# Paramètres en sortie                                                  #
#   WBETFCY : Indicateur inter-sites                                    #
#   WBETCPY : Indicateur inter-sociétés                                 #
#   WSALFCY : Site de vente                                             #
#   WSTOFCY : Site d'expédition                                         #
#   WBPCORD : Client commande                                           #
#   WINVFCY : Site de facturation                                       #
#   WBPCINV : Client  facture                                           #
#   WDME    : Livr. partielle (1=oui, 2=ligne complète, 3=cde complète) #
# Les globales suivantes sont chargées                                  #
#   GRCPFCY : Site de réception par défaut est chargé                   #
#   GLINBPD : Client livré à la ligne (1=non, 2=oui)                    #
#   GCPY    : Société de la commande de vente                           #
# Si anomalie GMESSAGE est chargé et mkstat positionné                  #
#########################################################################
Subprog CTRL_INTERSITE(WFONC1,WCPY,WPOHFCY,WBPSNUM,WTRAIT,WBETFCY,WBETCPY,WSALFCY,WSTOFCY,WBPCORD,WINVFCY,WBPCINV,GENERIC_OBJ,WDME,VRET)
Value    Char    WFONC1
Value    Char    WCPY ###
Value    Char    WPOHFCY
Value    Char    WBPSNUM
Value    Integer WTRAIT
Variable Tinyint WBETFCY
Variable Tinyint WBETCPY
Variable Char    WSALFCY
Variable Char    WSTOFCY
Variable Char    WBPCORD
Variable Char    WINVFCY
Variable Char    WBPCINV
Variable Instance GENERIC_OBJ Using OBJECT
Value Integer WDME
Variable Integer  VRET

 If GENERIC_OBJ = null : VRET =  [V]CST_AERROR : End : Endif

  VRET = [V]CST_AOK

Local Instance MYPARAM Using =GENERIC_OBJ.ObjectType

  MYPARAM = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

#Variable Integer WDME
#-----
Local    Char    WCHAR(10)
Local    Char    WBPCNUM(GLONBPC)
Local    Integer WBPCDME, I
Local    Integer WTRFPRI , WBIDI2   : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
Local Char WGRCPFCY(8)  # GRCPFCY replacement
Local Char WGSTOFCY(8)  # GSTOFCY


Local File BPARTNER  [BPR2]
Filter [BPR2] Where BPCFLG=2
Read [BPR2] BPR2(2)=2;WPOHFCY
If fstat  Raz [F:BPR2] : Endif
[G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut

#----- Lecture du Business Partner fournisseur si nécessaire -----#
Filter [BPR2]
Local File BPARTNER   [BPR]
If [F:BPR]BPRNUM<>WBPSNUM
  Read [BPR] BPR0=WBPSNUM
     #If fstat Raz [F:BPR] : [F:BPR]CUR=func SREPLACEGLOB_SYRA.GET_GLOCALDEV(WSALFCY,WCPY)  : [F:BPR]LAN=GACTX.LAN : Endif  #  107044.o
     If fstat Raz [F:BPR] : [F:BPR]CUR=func SREPLACEGLOB_SYRA.GET_GLOCALDEV(WSALFCY,WCPY) : [F:BPR]LAN=MYPARAM.ACTX.LAN : Endif #  107044.n
Endif

#----- le fournisseur ne doit pas être associé au même site que la commande -----#
If WPOHFCY=[F:BPR]FCY
  #GMESSAGE=WBPSNUM-WPOHFCY-mess(334,194,1) : mkstat=1 : End
  # GMESSAGE Razd in FUNACHPPSI #12 VRET = fmet MYPARAM.ASETERROR ("",WBPSNUM-WPOHFCY-mess(334,194,1), [V]CST_AERROR) : End
End
Endif
#-----
If [F:BPR2]FCY="" | [F:BPR]FCY=""
  Raz WSALFCY, WSTOFCY, WBPCORD, WBPCINV,WDME
  WBETFCY=1
  WBETCPY=1
  Call DEFRCPFCY(WPOHFCY,WGRCPFCY) From TRTACHDEF1_SYRA
Else
  #----- Le fournisseur inter-sites n'est pas autorisé -----#
  If WTRAIT=3 & WBETFCY=1
    VRET = fmet MYPARAM.ASETERROR ("",mess(276,194,1), [V]CST_AERROR) : End
  Endif
  #----- Le site associé au fournisseur (site de vente) doit exister -----#
  Local File FACILITY [FCY]
  Read [FCY]FCY0=[F:BPR]FCY
  If fstat
    Raz [F:FCY]
    VRET = fmet MYPARAM.ASETERROR ("",[F:BPR]FCY-mess(14,14,1), [V]CST_AERROR) : End
  Endif
  #----- Le flux automatique est-il autorisé ? -----#
  If WFONC1<>"GESPOC"  #GFONC1
    Call IS_FLUX (14,WPOHFCY,[F:BPR]FCY,WTRFPRI, WBIDI2) From FUNBCH_SYRA : # 26113  : Inter-site : Price recalculation (LD:06/07/15)
  Else
    WBIDI2=1 : # Flux automatique obligatoire pour les contrats !
  Endif
  #----- Inter-sites avec correspondance dans les ventes -----#
  If WBIDI2
    #----- Le module vente doit être actif -----#

    #If GMODU(5)<>2
    #If GACTX.AFOLD.AMODULE(5)<2 # 107044.o
    If MYPARAM.ACTX.AFOLD.AMODULE(5) = [V]CST_ANO  # 107044.n
      VRET = fmet MYPARAM.ASETERROR ("",mess(182,194,1), [V]CST_AERROR) : End
    Endif
    #----- Vérification que le tiers associé au site commande est client -----#
    If [F:BPR2]BPCFLG<>2
       VRET = fmet MYPARAM.ASETERROR ("",WPOHFCY-mess(258,194,1), [V]CST_AERROR) : End
    Endif
    #----- Vérification que le client est actif -----#
    Read [BPC] BPC0=[F:BPR2]BPRNUM : If fstat Raz [F:BPC] : Endif
    If [F:BPC]BPCSTA<>2
      VRET = fmet MYPARAM.ASETERROR ("",[F:BPR2]BPRNUM-":"-mess(4,119,1), [V]CST_AERROR) : End
    Endif
    [L]WBPCNUM=[F:BPC]BPCNUM
    [L]WBPCDME=[F:BPC]DME
    #----- Le client commande doit être autorisé pour la société du site de vente -----#
    Call CTLBPRCPY([L]WBPCNUM,[F:BPR]FCY) From CONTX3_SYRA
    If VRET = [V]CST_AERROR
      VRET = fmet MYPARAM.ASETERROR("",mess(29,104,1)-[F:FCY]LEGCPY,[V]CST_AERROR) : End
    Endif

    #----- Vérification si le site associé au fournisseur est vente -----#
    If [F:FCY]SALFLG<>2     : # Ce n'est pas un site de vente !
      VRET = fmet MYPARAM.ASETERROR("",mess(256,194,1),[V]CST_AERROR) : End
    Endif
    #-----
    WBETFCY=2
    Local Char XCPY(8)
    #GCPY=[F:FCY]LEGCPY
    XCPY=[F:FCY]LEGCPY
    #If GCPY<>GSOCIETE  WBETCPY=2 Else  WBETCPY=1 : Endif
    #If XCPY<>GSOCIETE  WBETCPY=2 Else  WBETCPY=1 : Endif
    If XCPY<>WCPY  WBETCPY=2 Else  WBETCPY=1 : Endif
    WSALFCY=[F:BPR]FCY
    WBPCORD=[L]WBPCNUM
    WDME=[L]WBPCDME
    #----- Chargement site de réception et site d'expédition par défaut -----#
     Call DEFBETRCPFCY(WCPY,[L]WBPCNUM,WGSTOFCY,WGRCPFCY) From TRTACHDEF1_SYRA
    If WGRCPFCY=""  # GRCPFCY
      #----- Aucun site de réception pour le client -----#
      VRET = fmet MYPARAM.ASETERROR("",mess(267,194,1)-[L]WBPCNUM,[V]CST_AERROR) : End
    Endif
    #----- Si inter-sites et site fournisseur = site de stockage différent du site cde -----#
    If WBETCPY=1 & [F:FCY]WRHFLG=2 & [F:FCY]FCY<>WPOHFCY
      WGSTOFCY=[F:FCY]FCY : # le site fournisseur (vente) devient le site d'expédition # GSTOFCY
      WSTOFCY=[F:FCY]FCY
    Else
      #----- Vérification site d'expédition -----#
      If WGSTOFCY<>""  # GSTOFCY
        #----- Le site expédition doit appartenir à la même société que le site vente -----#
        If find(WGSTOFCY,GSITE(1..GNBSITE)) & GSOCSITE(find(WGSTOFCY,GSITE(1..GNBSITE)))=GCPY
          WSTOFCY=WGSTOFCY
        Else
          Raz WGSTOFCY # GSTOFCY
        Endif
      Endif
      If WGSTOFCY="" & [F:FCY]WRHFLG=2 & ([F:FCY]FCY<>WPOHFCY | WBETCPY=1)
        #----- Si c'est possible le site de vente devient le site d'expédition -----#
        WGSTOFCY=[F:FCY]FCY : WSTOFCY=[F:FCY]FCY
      Elsif WGSTOFCY=""  # GSTOFCY
        Raz WSTOFCY
      Endif
    Endif
    #----- Le site d'expédition doit être différent du site de réception -----#
    If WGSTOFCY<>"" & WGSTOFCY=WGRCPFCY #GRCPFCY
      Raz WGSTOFCY, WSTOFCY
    Endif
    #----- Chargement globale GLINBPD (Client livré à la ligne) -----#
    GLINBPD = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,[F:BPR]FCY,"LINBPD")
    #----- Traitement client facture et site financier achats -----#
    #If WBETCPY=2
      Raz WINVFCY : # On efface le site financier
      If [F:BPC]BPCNUM<>WBPCORD
        Read [BPC] BPC0=WBPCORD : If fstat  Raz [F:BPC] : Endif
      Endif
      WBPCINV=[F:BPC]BPCINV
      #----- Contrôle automatique sans choix -----#
      If WTRAIT<2
        #----- Vérification que le client est actif -----#
        If [F:BPC]BPCNUM<>WBPCINV
          Read [BPC] BPC0=WBPCINV : If fstat  Raz [F:BPC] : Endif
          If [F:BPC]BPCSTA<>2
            VRET = fmet MYPARAM.ASETERROR("",WBPCINV-":"-mess(267,194,1),[V]CST_AERROR) : End
          Endif
        Endif
        #----- Le client commande doit être autorisé pour la société du site vente -----#
        Call CTLBPRCPY(WBPCINV,WSALFCY) From CONTX3_SYRA
        If VRET = [V]CST_AERROR
          VRET = fmet MYPARAM.ASETERROR("",mess(29,104,1)-GCPY,[V]CST_AERROR) : End
        Endif
      #----- Contrôle interactif avec choix possible -----#
      Else
        Call C_BPCINV(WBPCINV,WSALFCY) From TRTVENISOC_SYRA
        #If mkstat  End : Endif
        If VRET = [V]CST_AERROR End : Endif
      Endif
      #----- Recherche site financier associé au client facture -----#
      Read [BPR] BPR0=WBPCINV : If fstat  Raz [F:BPR] : Endif
      WINVFCY=[F:BPR]FCY
      If WINVFCY=""
      VRET = fmet MYPARAM.ASETERROR("",mess(316,194,1)-"("+WBPCINV+")",[V]CST_AERROR) : End : Endif
      Read [FCY] FCY0=WINVFCY
      If fstat
        VRET = fmet MYPARAM.ASETERROR("",mess(316,194,1)-"("+WBPCINV+"/"+WINVFCY+")",[V]CST_AERROR)
        Raz [F:FCY], WINVFCY : End
      Endif
      #If [F:FCY]LEGCPY<>GSOCIETE
      If [F:FCY]LEGCPY<>WCPY
        VRET = fmet MYPARAM.ASETERROR("",mess(298,194,1)-[F:FCY]LEGCPY-"<>"-WCPY,[V]CST_AERROR)
        Raz WBPCINV : End
      Endif
      # 26113  : Inter-site : Price recalculation (LD:06/07/15)
      # Si transfert des prix="Oui" il faut vérifier la cohérence Structure tarif fournisseur et Structure tarif site de vente
      If WTRFPRI=2
          If WFONC1<>"GESPOC"  #GFONC1
              VRET = func TRTVENISOC.CTLPLISTC(WBPSNUM,WSALFCY,WMSG)
              If VRET
                  VRET = fmet MYPARAM.ASETERROR("",WMSG,[V]CST_AERROR)
                  End
              Endif
          Endif
      Endif
      # 26113  : Inter-site : Price recalculation (LD:06/07/15)
  Else
    #----- Inter-sites sans correspondance dans les ventes -----#
    WBETFCY=2
    GCPY=[F:FCY]LEGCPY
    #If GCPY<>GSOCIETE  WBETCPY=2 Else  WBETCPY=1 : Endif
    If GCPY<>WCPY  WBETCPY=2 Else  WBETCPY=1 : Endif
    Raz WSALFCY, WBPCINV, WDME, WBPCORD
    #----- Chargement du client commande -----#
    #If GMODU(5)=2 & [F:BPR2]BPCFLG=2
    #If GACTX.AFOLD.AMODULE(5)<2 & [F:BPR2]BPCFLG=2 # 107044.o
    If MYPARAM.ACTX.AFOLD.AMODULE(5) = [V]CST_AYES  & [F:BPR2]BPCFLG=2 # 107044.n
      Read [BPC] BPC0=[F:BPR2]BPRNUM : If fstat Raz [F:BPC] : Endif
      If [F:BPC]BPCSTA=2
        Call CTLBPRCPY([F:BPC]BPCNUM,[F:BPR]FCY) From CONTX3_SYRA
        If VRET <> [V]CST_AERROR : WBPCORD=[F:BPC]BPCNUM  Else  Raz mkstat, WBPCORD : Endif
      Endif
    Endif
    #----- Chargement site de réception et site d'expédition par défaut -----#
    If WBPCORD<>""
      Call DEFBETRCPFCY(WCPY,WBPCORD,WGSTOFCY,WGRCPFCY) From TRTACHDEF1_SYRA
    Else
      Raz WGSTOFCY  # GSTOFCY
    Endif
    #----- Chargement site de réception par défaut si non chargé -----#
    If WGRCPFCY=""   Call DEFRCPFCY(WPOHFCY,WGRCPFCY) From TRTACHDEF1_SYRA : Endif
    #----- Si inter-sites et site fournisseur = site de stockage différent du site cde -----#
    If WBETCPY=1 & [F:FCY]WRHFLG=2 & [F:FCY]FCY<>WPOHFCY
      WGSTOFCY=[F:FCY]FCY : # le site fournisseur (vente) devient le site d'expédition
    Else
      #----- Vérification site d'expédition -----#
      If WGSTOFCY<>""
        #----- Le site expédition doit appartenir à la même société que le site vente -----#
        If find(WGSTOFCY,GSITE(1..GNBSITE)) & GSOCSITE(find(GSTOFCY,GSITE(1..GNBSITE)))=GCPY
          WSTOFCY=WGSTOFCY
        Else
          Raz WGSTOFCY
        Endif
      Endif
      If WGSTOFCY="" & [F:FCY]WRHFLG=2 & ([F:FCY]FCY<>WPOHFCY | WBETCPY=1)
        #----- Si c'est possible le site de vente devient le site d'expédition -----#
        WGSTOFCY=[F:FCY]FCY : WSTOFCY=[F:FCY]FCY
      Elsif WGSTOFCY=""
        Raz WSTOFCY
      Endif
    Endif
    #----- Le site d'expédition doit être différent du site de réception -----#
    If WGSTOFCY<>"" & WGSTOFCY=WGRCPFCY # GRCPFCY
      Raz WGSTOFCY, WSTOFCY
    Endif
    #-----
  Endif
Endif
End

#######################################################
# CTL_PRHFCY : Contrôle du site de réception            #
#            : controle que le site est un site de depot si l'article est géré en stock #
#            : controle que la sté du site est égale à la sté du document (ex GSOCIETE)
#            : controle que l'article site existe si l'article est renseigné
#######################################################
Funprog CTL_PRHFCY(CTX, PCPY, PFCY, PITMREF,PMSG)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PCPY     #société du document(ex GSOCIETE)
Value Char PFCY     #site du contrôle
Value Char PITMREF
Variable Char PMSG


Local File ITMMASTER [ITM]
Local File ITMFACILIT [ITF]
#Local Integer PRET

If PITMREF<> ""
   Read [ITM] ITM0=PITMREF
   If fstat<>[V]CST_AOK
    PMESSAGE = mess(134,100,1)
    End [V]CST_AERROR
   Endif
Endif

If PFCY=""
  PMSG = mess(10,123,1)
  End [V]CST_AERROR
Endif


#-------------------------------------------------------------------------#
#controle que le site est un site de depot si l'article est géré en stock #
#-------------------------------------------------------------------------#
If [F:ITM]STOMGTCOD<>1 & fmet CTX.ACACHE.AFCY.AGETVALNUM(PFCY,"WRHFLG")<>2
    PMSG = mess(58,199,1)
    End [V]CST_AERROR
Endif

#-------------------------------------------------------------------------#
#CONTROLE QUE LA STÉ DU SITE EST ÉGALE À LA STÉ DU DOCUMENT (EX GSOCIETE) #
#-------------------------------------------------------------------------#
If fmet CTX.ACACHE.AFCY.AGETVALCHAR(PFCY,"LEGCPY")<>PCPY
  PMSG = PFCY-mess(2,194,1)
  End [V]CST_AERROR
Endif

#-----------------------------------------------------------------#
#CONTROLE QUE L'article site existe si l'ARTICLE EST RENSEIGNÉ    #
#-----------------------------------------------------------------#
If [F:ITM]STOMGTCOD<>1
  Read [ITF] ITF0=PITMREF;PFCY
  If fstat <> [V]CST_AOK
    Raz [F:ITF]
    PMSG=mess(25,192,1)-PFCY
    End [V]CST_AERROR
   Endif
Endif

End [V]CST_AOK

########################################################################
# CTL_PLANNER_ITF : Contrôle de l'approvisionneur sur article-site     #
#             : appelé en DA                                           #
########################################################################
Funprog CTL_PLANNER_ITF(CTX,PFCY, PITMREF,PREQUSR, PMESSAGE)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PFCY
Value Char PITMREF
Value Char PREQUSR
Variable Char PMESSAGE

Local Char WGPLNFLT(3)
Local File ITMFACILIT [ITF]

#-----------------------------------------------#
#Si le site n'est pas renseigné => erreur       #
#-----------------------------------------------#
If PFCY=""
  PMESSAGE = mess(10,123,1)
  End [V]CST_AERROR
Endif

#-----------------------------------------------#
# Contrôle de l'approvisionneur (PLANNER) si DA #
#-----------------------------------------------#
Read [ITF] ITF0=PITMREF;PFCY
  If fstat <> [V]CST_AOK
    PMESSAGE = mess(139,197,1)
    End [V]CST_AERROR
  Endif


WGPLNFLT = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"GPLNFLT")

If [F:ITF]ITMREF<>""
    If WGPLNFLT="2" & ([F:ITF]PLANNER<>PREQUSR & [F:ITF]PLANNER<>"")
      PMESSAGE = mess(217,194,1)
      End [V]CST_AERROR
    Endif
    If WGPLNFLT="3" & [F:ITF]PLANNER<>PREQUSR
      PMESSAGE = mess(217,194,1)
      End [V]CST_AERROR
   Endif
Endif

End [V]CST_AOK


########################################################################
# CTL_PLANNER_ITM : Contrôle de l'approvisionneur sur article          #
#             : appelé en DA                                           #
########################################################################
Funprog CTL_PLANNER_ITM(CTX,PITMREF,PREQUSR, PMESSAGE)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PITMREF
Value Char PREQUSR
Variable Char PMESSAGE

Local Integer WGPLNFLT
Local File ITMMASTER [ITM]

#-----------------------------------------------#
# Contrôle de l'approvisionneur (PLANNER) si DA #
#-----------------------------------------------#
Read [ITM] ITM0=PITMREF
If fstat <> [V]CST_AOK
  PMESSAGE = mess(134,100,1)
  End [V]CST_AERROR
Endif

WGPLNFLT = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"GPLNFLT")

If (WGPLNFLT=2 & [F:ITM]PLANNER<>PREQUSR & [F:ITM]PLANNER<>"") |
&  (WGPLNFLT=3 & [F:ITM]PLANNER<>PREQUSR)
   PMESSAGE=mess(61,193,1)
   End [V]CST_AERROR
Endif


End [V]CST_AOK

########################################################################
# CTL_LIFENDDAT : Contrôle de la date de fin de vie de l'article       #
########################################################################
Funprog CTL_LIFENDDAT(PITMREF,PDATE, PMESSAGE)
Value Char PITMREF
Value Date PDATE
Variable Char PMESSAGE

Local File ITMMASTER [ITM]

Read [ITM] ITM0=PITMREF
If fstat <> [V]CST_AOK
  PMESSAGE = mess(134,100,1)
  End [V]CST_AERROR
Endif

If [F:ITM]LIFENDDAT<PDATE & [F:ITM]LIFENDDAT <> AVOID.ADATE
   PMESSAGE=mess(12,318,1)
   End [V]CST_AERROR
Endif

End [V]CST_AOK

#####################################################################################
# CTL_BPSNUM_FCY : Contrôle entre le site fournisseur et le site de la demande      #
#####################################################################################
Funprog CTL_BPSNUM_FCY(PBPSNUM,PFCY, PMESSAGE)
Value Char PBPSNUM
Value Char PFCY
Variable Char PMESSAGE

Local File BPARTNER [BPR]

Read [BPR] BPR0=PBPSNUM
If fstat<>[V]CST_AOK
  PMESSAGE=mess(541,199,1)
  End [V]CST_AERROR
Endif


If [F:BPR]FCY=PFCY
   PMESSAGE=mess(307,194,1)
   End [V]CST_AERROR
Endif


End [V]CST_AOK

#####################################################################################
# CTL_BPSNUM_ITMREF : Contrôle du couple article-fournisseur                        #
#####################################################################################
Funprog CTL_BPSNUM_ITMREF(PCTX,PBPSNUM,PITMREF, PPUU, PMESSAGE)
Value Instance PCTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PBPSNUM
Value Char PITMREF
Variable Char PPUU
Variable Char PMESSAGE

Local Integer WITMBPS

#----- Vérification couple article-fournisseur -----#
Local File ITMBPS [ITP]
Local File BPSUPPLIER[BPS]
Local File ITMMASTER[ITM]

Read [ITP] ITP0=PITMREF;PBPSNUM

If fstat = CST_AOK
  #----- Test du code blocage -----#
  If [F:ITP]DOUFLG=3
    PMESSAGE=mess(9,194,1) : End [V]CST_AERROR
  Elsif [F:ITP]DOUFLG=2
    PMESSAGE=mess(9,194,1) : End [V]CST_AWARNING
  Endif
  PPUU=[F:ITP]PUU
Else
  Read [BPS] BPS0=PBPSNUM : If fstat<>[V]CST_AOK : End [V]CST_AERROR : Endif
  Read [ITM] ITM0=PITMREF : If fstat<>[V]CST_AOK : End [V]CST_AERROR : Endif

  #----- Si fournisseur <> Divers -----#
  If [F:BPS]BPSTYP<>3
    #----- Si article non générique -----#
    If [F:ITM]GENFLG<>2
      WITMBPS = fmet PCTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,PCTX.AFOLDER,"ITMBPS")
      If WITMBPS=1
        PMESSAGE=mess(8,194,1) : End[V]CST_AERROR
      Elsif WITMBPS=2
        PMESSAGE = mess(8,194,1) : End [V]CST_AWARNING
      Endif
    Endif
  Endif
  PPUU=[F:ITM]PUU
Endif


End [V]CST_AOK




#########################################################################
# PCOUOM : S/P DE CONTRôLE D'UNE UNITé PARMI CELLES SE     MBT 20/03/98 #
#           TROUVANT DANS L'ARTICLE OU L'ARTICLE-FOURNISSEUR            #
#-----------------------------------------------------------------------#
# Subprog PCOUOM (UNITE,FOURN,REFART,INDFIC,INDUNI)                     #
#   UNITE  : UNITé à CONTROLER (zc)                                     #
#   FOURN  : NUMéRO DU FOURNISSEUR DONT LES UNITéS SONT à CONTRôLER     #
#   REFART : RéFéRENCE DE L'ARTICLE DONT LES UNITéS SONT à CONTRôLER    #
#   INDFIC : INDICATEUR FICHIERS à TRAITER                              #
#            1 = ARTICLE (ITMMASTER)                                    #
#            2 = ARTICLE-FOURNISSEUR (ITMBPS)                           #
#            3 = ARTICLE + ARTICLE-FOURNISSEUR (ITMMASTER+ITMBPS)       #
#   INDUNI : INDICATEUR UNITéS à TRAITER                                #
#            1 = UNITé D'ACHAT (UA)                                     #
#            2 = UNITé DE CONDITIONNEMENT (UC)                          #
#            3 = UNITé DE STOCK (US)                                    #
#            4 = UNITé D'ACHAT + UNITé DE CONDITIONNEMENT (UA+UC)       #
#            5 = LES TROIS UNITéS (UA+UC+US)                            #
#                                                                       #
# ATTENTION : CE S/P EST APPELé PAR UNE ACTION "CONTRôLE"               #
#             SI ERREUR mkstat=2                                        #
#########################################################################
Funprog PCOUOM (PUNITE,PFOURN,PREFART,PINDFIC,PINDUNI,PMESSAGE)
Value    Char    PUNITE
Value    Char    PFOURN
Value    Char    PREFART
Value    Integer PINDFIC
Value    Integer PINDUNI
Variable Char    PMESSAGE

#----- Variables locales -----#
Local File ITMMASTER [ITM]
Local File TABUNIT   [TUN]
Local    Char    TABCODE(3)(dim([F:ITM]PCU)+4)
Local    Integer I, J
#----- Si réf. article non renseignée contrôle si existe dans table des unités -----#
If PREFART=""
  Read [TUN] TUN0 = PUNITE
  If fstat Raz[F:TUN] : Endif
Endif
#----- Contrôle validité des indicateurs -----#
If PINDFIC=0 | PINDFIC>3 End : Endif
If PINDUNI=0 | PINDUNI>5 End : Endif
#----- Ouverture et lecture des fichiers si nécessaire -----#
If PINDFIC=1 | PINDFIC=3
#   Local File ITMMASTER [ITM]
   If [F:ITM]ITMREF<>PREFART
      Read [ITM] ITM0=PREFART
      If fstat Raz [F:ITM] : Endif
   Endif
Endif
If PINDFIC=2 | PINDFIC=3
   Local File ITMBPS    [ITP]
   Read [ITP] ITP0=PREFART;PFOURN
   If fstat<>[V]CST_AOK
    If fstat Raz [F:ITP] : Endif
   Endif
Endif

#----- CONTRôLE DE L'UNITé -----#
If PINDFIC=1 | PINDFIC=3
  If (PINDUNI=1 | PINDUNI=4 | PINDUNI=5) & [F:ITM]PUU<>""
                           TABCODE(I)=[F:ITM]PUU    : I+=1 : Endif
  If PINDUNI=2 | PINDUNI=4 | PINDUNI=5
    For J=0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(J)<>"" TABCODE(I)=[F:ITM]PCU(J) : I+=1 : Endif
    Next J
  Endif
  If (PINDUNI=3 | PINDUNI=5) & [F:ITM]STU<>""
                           TABCODE(I)=[F:ITM]STU    : I+=1 : Endif
Endif
If PINDFIC=2 | PINDFIC=3
   If (PINDUNI=1 | PINDUNI=4 | PINDUNI=5) & [F:ITP]PUU<>""
                           TABCODE(I)=[F:ITP]PUU    : I+=1 : Endif
   If (PINDUNI=2 | PINDUNI=4 | PINDUNI=5) & [F:ITP]PCU<>""
                           TABCODE(I)=[F:ITP]PCU    : I+=1 : Endif
Endif
If !find(PUNITE,TABCODE)
  PMESSAGE=mess(397,198,1)-'"'+PUNITE+'"'-mess(6,199,1)
  End [V]CST_AERROR
Endif

#If PINDFIC=1 | PINDFIC=3 : LogicClose File [ITM] : Endif
If PINDFIC=2 | PINDFIC=3 : LogicClose File [ITP] : Endif
LogicClose File [ITM]
LogicClose File [TUN]

End [V]CST_AOK

#########################################################################
# PCOVAT : S/P de contrôle correspondance régime de taxe   MBT 15/10/98 #
#          d'un code taxe + contrôle législation                        #
#-----------------------------------------------------------------------#
# Subprog PCOVAT (CODTAX,REGIME)                                        #
#   CODTAX : Code taxe à contrôler (zc)                                 #
#   REGIME : Régime de taxe pour contrôle                               #
#                                                                       #
# ATTENTION : Ce S/P est appelé par une action "Contrôle"               #
#             Le contrôle dépend de la valeur du paramètre GPCTLVAT     #
#             GPCTLVAT = 1 : Pas de contrôle                            #
#                        2 : Contrôle non bloquant (Choix)              #
#                        3 : Contrôle bloquant (Si erreur mkstat=2)     #
#########################################################################
Funprog PCOVAT (PCTX,PFCY,PLEG,PCODTAX,PREGIME, PMESSAGE)
Value Instance PCTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char     PFCY
Value Char     PLEG
Value    Char  PCODTAX
Value    Char  PREGIME
Variable Char  PMESSAGE

#Infbox ("passage dans PCOVAT")

Local Integer  WRET
Local Integer WPCTLVAT
Local File TABVAT [TVT]   #pour lecture dans LEC_TVT_LEG
Local Char WCURLEG(20)
#-----
WPCTLVAT = fmet PCTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,PCTX.AFOLDER,"PCTLVAT")
If PCODTAX="" | WPCTLVAT=1  End [V]CST_AOK : Endif
#-----
Call LEC_TVT_LEG(PCTX,PLEG,PCODTAX,WRET) From TRTLECLEG_SYRA
If WRET : Raz [F:TVT] : Endif

#-----
Local Libelle WERR : Raz WERR
#----- Contrôle et chargement code erreur -----#
If [F:TVT]VATVAC<>"" & [F:TVT]VATVAC<>PREGIME
  WERR+=1
Endif

WCURLEG = PCTX.AFOLD.ALEGCUR

If [F:TVT]LEG<>"" & WCURLEG<>"" & [F:TVT]LEG<>WCURLEG
  WERR+=2
Endif
If [F:TVT]GRP<>""
  Local File AGRPCPY [AGC]
  Look [AGC] AGC0=[F:TVT]GRP;PCTX.ACACHE.AFCY.AGETVALCHAR(PFCY,"LEGCPY")
  If fstat  WERR+=4 : Endif
Endif
#-----
If WERR=0  End [V]CST_AOK : Endif
#----- Chargement libellé de l'erreur -----#
Case WERR
  When 1 : PMESSAGE=mess(149,194,1)                     : # Régime de taxe incorrect !
  When 2 : PMESSAGE=mess(379,194,1)                     : # Législation incorrecte !
  When 3 : PMESSAGE=mess(149,194,1)+"\"+mess(379,194,1) : # Régime et Législation incorrects !
  When 4 : PMESSAGE=mess(382,194,1)                     : # Groupe de sociétés incorrect !
  When 5 : PMESSAGE=mess(149,194,1)+"\"+mess(382,194,1) : # Régime et groupe incorrects !
  When 6 : PMESSAGE=mess(379,194,1)+"\"+mess(382,194,1) : # Législation et groupe incorrects !
  When 7 : PMESSAGE=mess(149,194,1)+"\"+mess(379,194,1) : # Régime, législation et
           PMESSAGE+="\"+mess(382,194,1)                : # groupe incorrects !
Endcase
#----- Si import, il faut préciser le code taxe avant le message d'erreur -----#
PMESSAGE=mess(39,105,1)-PCODTAX-":"-PMESSAGE
#----- Avertissement ou blocage selon valeur du paramètre -----#
If WPCTLVAT=2
    End [V]CST_AWARNING
Else
    End [V]CST_AERROR
Endif
End [V]CST_AOK


###########################################
# C_BPSNUM : Contrôle fournisseur         #
# --------------------------------------- #
# Contrôle fournisseur douteux            #
###########################################
Funprog C_BPSNUM(PBPSNUM,PMESSAGE)
Value    Char PBPSNUM
Variable Char PMESSAGE
Local    Integer WRETOUR

#----- Contrôle fournisseur douteux -----#
Local File BPSUPPLIER [BPS]
Read [BPS] BPS0=PBPSNUM : If fstat<>[V]CST_AOK : End [V]CST_AERROR : Endif
If [F:BPS]DOUFLG=3
  PMESSAGE=mess(4,194,1)  : End [V]CST_AERROR
Elsif [F:BPS]DOUFLG=2
  PMESSAGE=mess(4,194,1) : : End [V]CST_AWARNING
Endif
End [V]CST_AOK

###########################################
# C_ITMREF : Contrôle article             #
# --------------------------------------- #
# Contrôle sur l'article                  #
###########################################
Funprog C_ITMREF(PITMREF,PFCY,PMESSAGE)
Value    Char PITMREF
Value    Char PFCY
Variable Char PMESSAGE

Local File ITMMASTER [ITM]
Local File ITMFACILIT [ITF]
Read [ITM] ITM0=PITMREF
If fstat<>[V]CST_AOK
 PMESSAGE = mess(583,177,1)
 End [V]CST_AERROR
Endif

#----- Contrôle article site existe------#
Read [ITF]ITF0=PITMREF;PFCY
If fstat<>[V]CST_AOK
 PMESSAGE = mess(139,197,1)
 End [V]CST_AERROR
Endif

#----- Contrôle fournisseur douteux -----#
If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
  PMESSAGE=mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
  End [V]CST_AERROR
Endif

# Article de type "Service" non autorisé
If [F:ITM]SCSFLG=2
  PMESSAGE = mess(164,199,1)
  End [V]CST_AERROR
Else
  #----- Article non acheté  non autorisé -----#
  If [F:ITM]PURFLG<>2
    PMESSAGE = mess(70,197,1)
    End [V]CST_AERROR
  Else
    #----- Article géré en stock : Article-site obligatoire ---#
    If [F:ITM]STOMGTCOD > 1
       Read [F:ITF]ITF0 = PITMREF;PFCY
       If fstat
        PMESSAGE = mess(139,197,1)
        End [V]CST_AERROR
       Endif
    Endif
  Endif
Endif
#----- Test article sous-traité -----#
If [F:ITM]SCPFLG=2 & [F:ITM]PURFLG<>2
  PMESSAGE=[F:ITM]ITMREF-":"-mess(70,197,1)  : mkstat=2 : End
Endif
#------Test article actif------------#
If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
      PMESSAGE-=mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
      End [V]CST_AERROR
Endif

End [V]CST_AOK

