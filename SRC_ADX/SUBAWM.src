#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet AWM
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AWM",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "OUVRE"       : Gosub OUVRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "STATUT"      : Gosub STATUT
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
Endcase
Return

#--------------------------------------- -----#
$OUVRE
Local File    AWRKLNK [AWM2]
Local File    AWRKTAB [AWK2]
Local File    AWRKTAB [AWK]
Local File    ATYPE   [ATY]
Local File    AOBJET  [AOB]
Local Mask    AFFCLOB [AFF]
Local Integer OKREQ
If func AFNC.ACTIV("ASEAR")>0 & filinfo(filpath("FIL","ASSCONF","fde",nomap),0)>0
 Local File ASSCONF [ASR]
 Local Char TABLE(GLONATB),CHAMP(GLONAVA),CODTYPE(GLONATY),MESSAGE(250)
 Local Integer DIME
 Local Char AABREV(10)
 Local Integer OKANU
Endif
Return

#--------------------------------------------#
$FILGAUCHE
Case currbox
 When "GAU_CHE2" : # Exalead
  FILGAUSUP = '[F:AWM]FLGAPH=2'
 When "GAU_CHE1" : # Workflow
  FILGAUSUP = '[F:AWM]FLGWRK=2'
 When "GAU_CHE3" : # Patch
  FILGAUSUP = '[F:AWM]FLGEXA=2'
 When "GAU_CHE" : # Modeles
  FILGAUCHE = '[F:AWM]FLGSTR<>2'
Endcase
Return

#--------------------------------------------#
$ANNULE
#If dim([M]FLGEXA)>0 & [M:AWM0]FLGEXA=2
# Call SUPP_CONNECTOR(CLECUR1,nomap,0,MESSAGE,OKANU)  From ATRTASRVAL
#Endif
Return

#--------------------------------------------#
$LIENS
Call TEXTE([M]INTITMOD,[M]ZINTIT) From OBJDIV

nolign = 0
For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & [AWK]TYPTAB<1
  nolign += 1
 [M:AWM1] = [F:AWK]
Next
[M:AWM1]NBRLNK = nolign

Read [ATB]CODFIC = [M]TABREF
[M]CONCATREF = format$("K:"+num$(GLONATB)+"X",[M]TABREF)+[F:ATB]ABRFIC
For I=1 To [M]NBRLNK
 If [M]ABRLNK(I-1)<>""
  [M]CONCATLNK(I-1) = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(I-1))+[M]ABRLNK(I-1)
 Else
  Read [ATB]CODFIC = [M]TABLNK(I-1)
  [M]CONCATLNK(I-1) = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(I-1))+[F:ATB]ABRFIC
 Endif
Next I

If dim([M]NBROPT)>0
 For I=0 To [M]NBROPT-1
  Call TEXTE([M]OPTLIB(I),[M]AZOPTLIB(I)) From OBJDIV
  Call TEXTE([M]OPTERR(I),[M]AZOPTERR(I)) From OBJDIV
 Next I
Endif

If func AFNC.ACTIV("ASEAR")=0 or filinfo(filpath("FIL","ASSCONF","fde",nomap),0)<0
 [M:AWM0]FLGEXA = 1
 Effzo [M:AWM0]FLGEXA
 Grizo [M:AWM0]FLGEXA
Endif
If [M:AWM0]FLGEXA=2 & dim([M:AWM3]SECURITY)>0 & clalev([F:ASR])>0
 Read [ASR]ASR0 = [M]MODELE
 If !fstat
  [M:AWM3] = [F:ASR]
  [M:AWM3]AASTP = func SUBADC.CNVMIL([F:ASR]ASTP)
  For I=0 To [M:AWM3]NBCATEG-1
   If [M:AWM3]AINTIT(I)>0  : [M:AWM3]AAINTIT(I)  = func AFNC.TEXTE([M:AWM3]AINTIT(I))  : Endif
  Next
  [M:AWM3]AREQ = GTYPDBA
  Case [M:AWM3]AREQ
   When 1 : [M:AWM3]WREQ = [M:AWM3]REQORA
   When 2 : [M:AWM3]WREQ = [M:AWM3]REQSQL
  Endcase
 Endif
Endif

Gosub GRISE_EXALEAD
Gosub GRISE_APH
Gosub GRISE_WRK
Return

#---------------------------------------------------#
$MODIF
Delete [AWK] Where MODELE=CLECUR1
If fstat=1
 GOK=-1 : Call RSTA("AWM",CLECUR1) From GLOCK : Return
Endif
If func AFNC.ACTIV("ASEAR")>0 & clalev([F:ASR])>0
 Delete [ASR] Where MODELE=CLECUR1
 If fstat=1
  GOK=-1 : Call RSTA("ASR",CLECUR1) From GLOCK : Return
 Endif
 #If dim([F:AWM]FLGEXA) & OKANU=2
 # Call SUPP_CONNECTOR(CLECUR1,nomap,0,MESSAGE,OKANU)  From ATRTASRVAL
 #Endif
Endif
Gosub CREATION
Return

#---------------------------------------------------#
$CREATION
If func AFNC.ACTIV("ASEAR")>0 & clalev([F:ASR])>0
 If [M:AWM0]FLGEXA=2
  [F:ASR] = [M:AWM3]
  [F:ASR] = [M:AWM0]
  Write [ASR]
  If fstat
   GOK=0 : Call FSTA("ASR") From GLOCK : Return
  Endif
 Endif
Endif
For nolign=1 To [M:AWM1]NBRLNK
 Raz [F:AWK]
 [F:AWK] = [M:AWM0]
 [F:AWK] = [M:AWM1]
 [F:AWK]NUMLIG = nolign
 [F:AWK]TYPTAB = 0
 Write [AWK]
 If fstat
  GOK=0 : Call FSTA("AWK") From GLOCK : Break
 Endif
Next
Return

#---------------------------#
$GRISE_EXALEAD
If func AFNC.ACTIV("ASEAR")>0 & [M]FLGEXA=2
 Actzo [M:AWM3]
Else
 If func AFNC.ACTIV("ASEAR")>0 & dim([M:AWM3]SECURITY)>0
  Effzo [M:AWM3]
  Grizo [M:AWM3]
  Actzo [M:AWM0]FLGEXA
 Else
  Grizo [M:AWM0]FLGEXA
 Endif
Endif
Return

#---------------------------#
$GRISE_APH
If [M]FLGAPH=2
 Actzo [M:AWM2]30
Else
 Effzo [M:AWM2]30
 Grizo [M:AWM2]30
Endif
Return

#---------------------------#
$GRISE_WRK
If [M]FLGWRK=2
 Actzo [M:AWM2]25
Else
 Effzo [M:AWM2]25
 Grizo [M:AWM2]25
Endif
Return

#--------------------------------------------#
$STATUT
Case BOUT
 When "5" :
  Local Clbfile REQUETE(8)
  Call REQUETES_MODELE([M]MODELE,nomap,0,REQUETE,OKREQ) From ATRTASRVAL
  If OKREQ
   [M:AFF]AFFCLB = REQUETE
   Call DIALWIN(OKREQ,mess(258,139,1),"AFFCLOB") From GESECRAN : # Visualisation source
  Endif
 When "6" :
  Call INFORMATION_MODELE([M]MODELE,nomap,0,MESSAGE,OKREQ) From ATRTASRVAL
  If MESSAGE<>""
   Call MESSAGE(MESSAGE) From GESECRAN
  Endif
Endcase
Return

#--------------------------------------------#
$EXEBOUT
Case REP
 When "V"
  Call OUINON(mess(205,100,1),GBIDI1) From GESECRAN #  : Voulez-vous continuer ?
  If GBIDI1=2
   Call VALIDATION([M:AWM0]MODELE,1,1,nomap,0,GBIDI1) From ATRTASRVAL
  Endif
Endcase
Return

#--------------------------------------------#
$VERIF_MOD
# 118178
#If dim([M]FLGEXA)>0 & ([F:AWM]FLGEXA<>[M]FLGEXA & [M]FLGEXA=1 & [F:AWM]FLGEXA<>0 & [M:AWM3]AASTP<>func SUBADC.CNVMIL('0'))
 # Etes-vous sûr de vouloir supprimer ce modèle utilisé dans le moteur de recherche ?
 #Call OUINON(mess(287,139,1),OKANU) From GESECRAN
 #If OKANU<>2 : OK=0 : Return : Endif
#Endif

Local Shortint DIMNIV : DIMNIV = 30
Local Char     NIV1(GLONATB+1+GLONABR)(1..DIMNIV) , NIV2(GLONATB+1+GLONABR)(1..DIMNIV) , NIV3(GLONATB+1+GLONABR)(1..DIMNIV)
Local Integer  BRA2(1..DIMNIV) , BRA3(1..DIMNIV)
Local Integer  NB1 , NB2 , NB3
Local Char     MESSA(250)
[F:AWM] = [M:AWM1]
[F:AWM] = [M:AWM2]
Call RECHERCHE_NIVEAU(NIV1,NIV2,NIV3,BRA2,BRA3,NB1,NB2,NB3,MESSA,OK) From SUBAWR
If !OK
 Call ERREUR(MESSA) From GESECRAN : Return
Endif
For [AWR] Where MODELE=[M:AWM0]MODELE
 If [F:AWR]TABLIG<>""
  I = find([F:AWR]TABLIG,[M]TABLNK)
  If !I or !find([M]TYPLNK(I-1),2,4)
   # Table ligne référencée dans la règle d'affectation
   Call ERREUR([F:AWR]TABLIG-":"-mess(130,75,1)-[F:AWR]REGLE) From GESECRAN
   OK = 0 : Break
  Endif
 Endif
 For I=0 To [F:AWR]NBRFLD-1
  J = find([F:AWR]TABFLD(I),[M]TABLNK,[M]TABREF)
  If !J
   # Table référencée dans la règle d'affectation
   Call ERREUR([F:AWR]TABFLD(I)-":"-mess(132,75,1)-[F:AWR]REGLE) From GESECRAN
   OK = 0 : Break 2
  Endif
 Next J
Next AWR
If !OK : Return : Endif
For [AWA] Where MODELE=[M:AWM0]MODELE
 If [F:AWA]TABLIG<>""
  I = find([F:AWA]TABLIG,[M]TABLNK)
  If !I or !find([M]TYPLNK(I-1),2,4)
   # Table ligne référencée dans la règle workflow
   Call ERREUR([F:AWA]TABLIG-":"-mess(131,75,1)-[F:AWA]CODE) From GESECRAN
   OK = 0 : Break
  Endif
 Endif
Next AWR
If !OK : Return : Endif
Return

#--------------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Changement de clé
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2V") From GOBJET
Endif
If (dim([M:AWM0]FLGEXA)>0 & [M:AWM0]FLGEXA<>2) or [M:AWM0]ENAFLG<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
CHMEN = "13"
If CLECUR=0 | REP="M" | !VERROU
 CHMEN = ""
Endif
If dim([M:AWM0]FLGEXA)>0 & [M:AWM0]FLGEXA=2
 CHMEN +="567"
Endif
Return


#-----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AWRKLNK  [AWM1]
 Local File AWRKTAB  [AWK1]
 Local File ATEXTE   [ATX1]
 If filinfo(filpath("FIL","ASSCONF","fde",nomap),0)>0
  Local File ASSCONF [ASR1]
 Endif
Else
 Local File =[M]DOSORG+".AWRKLNK"  [AWM1]
 Local File =[M]DOSORG+".AWRKTAB"  [AWK1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
 If filinfo(filpath("FIL","ASSCONF","fde",[M]DOSORG),0)>0
  Local File =[M]DOSORG+".ASSCONF" [ASR1]
 Endif
Endif
If [M]DOSDES=nomap
 Local File AWRKLNK  [AWM2]
 Local File AWRKTAB  [AWK2]
 Local File ATEXTE   [ATX2]
 If filinfo(filpath("FIL","ASSCONF","fde",nomap),0)>0
  Local File ASSCONF [ASR2]
 Endif
Else
 Local File =[M]DOSDES+".AWRKLNK"  [AWM2]
 Local File =[M]DOSDES+".AWRKTAB"  [AWK2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
 If filinfo(filpath("FIL","ASSCONF","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".ASSCONF" [ASR2]
 Endif
Endif
OK = 1
If GTRACE=""
 Read [AWM2]AWM0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AWM1] , [AWM2] , [AWK1] , [AWK2] , [ATX1] , [ATX2]
If clalev([F:ASR1])>0 & clalev([F:ASR2])>0
 Close Local File [ASR1] , [ASR2]
Endif
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [AWM2]
 Delete [AWM2] Where MODELE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWRKLNK" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWM2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AWK2] Where MODELE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWRKTAB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWK2","") From GLOCK : Goto AB_TR_COP
 Endif
 If clalev([F:ASR1])>0 & clalev([F:ASR2])>0
  Delete [ASR2] Where MODELE=TABLE
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASSCONF" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("ASR2","") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
 For [AWM1]AWM0 Where MODELE=TABLE
  [F:AWM2] = [F:AWM1]
  Call COPTEXTE([F:AWM1]INTITMOD,[F:AWM2]INTITMOD) From OBJDIV
  If dim([F:AWM2]UPDUSR)>0 : [F:AWM2]UPDUSR = GUSER : Endif
  If dim([F:AWM2]UPDDAT)>0 : [F:AWM2]UPDDAT = date$ : Endif
  Write [AWM2]
  If fstat
   GOK=0 : Call FSTA("AWM2") From GLOCK : Break
  Endif
 Next AWM1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWK1]AWK0 Where MODELE=TABLE
  [F:AWK2] = [F:AWK1]
  If dim([F:AWK2]UPDUSR)>0 : [F:AWK2]UPDUSR = GUSER : Endif
  If dim([F:AWK2]UPDDAT)>0 : [F:AWK2]UPDDAT = date$ : Endif
  Write [AWK2]
  If fstat
   GOK=0 : Call FSTA("AWK2") From GLOCK : Break
  Endif
 Next AWK1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 If clalev([F:ASR1])>0 & clalev([F:ASR2])>0
  For [ASR1]ASR0 Where MODELE=TABLE
   [F:ASR2] = [F:ASR1]
   Write [ASR2]
   If fstat
    GOK=0 : Call FSTA("ASR2") From GLOCK : Break
   Endif
  Next ASR1
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
End

#-------------------------------#
Subprog C_QUOTE(CHAINE)
Variable Char CHAINE()
If instr(1,CHAINE,'"')
 GMESSAGE = '"'-":"-mess(94,123,1) : # Caractère interdit
 mkstat=2 : End
Endif
End

#------------------------------------------------------------------#
# Contrôle de l'existence d'un champ
#------------------------------------------------------------------#

Subprog CONTROLE_FLD(TAB,ABR,FLD,TABLE,AABREV,CHAMP,CODTYPE,DIME,INTIT)
Value    Char    TAB()
Value    Char    ABR()
Variable Char    FLD
Variable Char    TABLE
Variable Char    AABREV
Variable Char    CHAMP
Variable Char    CODTYPE
Variable Integer DIME
Variable Integer INTIT
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Local Char ZONE(GLONAVA) , CHAINE(30)
Local Integer I , J , K
CHAINE = toupper(FLD)
I = instr(1,CHAINE,"[")
J = instr(1,CHAINE,"]")
Raz ZONE , AABREV
If I & J
 K = instr(1,CHAINE,":")
 If K
  AABREV = seg$(CHAINE,K+1,J-1)
 Else
  AABREV = seg$(CHAINE,I+1,J-1)
 Endif
 CHAINE = right$(CHAINE,J+1)
Endif
K = instr(1,CHAINE,"(")
If K
 ZONE = left$(CHAINE,K-1)
Else
 ZONE = CHAINE
Endif
CHAMP = ZONE
If AABREV="" | AABREV="F"
 If TAB<>""
  Filter [ATZ] Where CODZONE=ZONE & find(CODFIC,TAB)<>0
  Read [ATZ] First
  Filter [ATZ]
 Else
  Filter [ATZ] Where CODZONE=ZONE
  Read [ATZ] First
  Filter [ATZ]
 Endif
Elsif ABR=""
 Read [ATB]ABRFIC = AABREV
 If fstat
  GMESSAGE = AABREV-":"-mess(124,124,1) : # Table inexistante
  mkstat = 2 : End
 Else
  Filter [ATZ] Where CODZONE=ZONE & CODFIC=[F:ATB]CODFIC
  Read [ATZ] First
  Filter [ATZ]
 Endif
Else
 K = find(AABREV,ABR)
 If K
  Filter [ATZ] Where CODZONE=ZONE & CODFIC=TAB(K-1)
  Read [ATZ] First
  Filter [ATZ]
 Else
  GMESSAGE = AABREV-":"-mess(93,139,1) : # Table non référencée
  mkstat = 2 : End
 Endif
Endif
If fstat
 GMESSAGE = ""
 If AABREV<>""
  GMESSAGE = "["+AABREV+"]"
 Endif
 GMESSAGE += ZONE-":"-mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
CODTYPE = [F:ATZ]CODTYP
TABLE   = [F:ATZ]CODFIC
DIME    = [F:ATZ]DIME
INTIT   = [F:ATZ]NOCOURT
If AABREV=""
 K = find(TABLE,[L]TAB)
 AABREV =ABR(K-1)
Endif
K = 1
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If fstat | [F:ACV]FLACT<>2
  K = 0
 Endif
Endif
If !K
 GMESSAGE = ""
 If AABREV<>""
  GMESSAGE = "["+AABREV+"]"
 Endif
 GMESSAGE += ZONE-":"-[F:ATZ]CODACT-mess(24,176,1) : # Code activité inactif
 mkstat = 2 : End
Endif
If instr(1,FLD,"[F:")<=0
 FLD= "[F:"+AABREV+"]"+CHAMP
Endif
End

#-----------------------------------------------------------------------------#
Subprog AM_FLGAPH(VALEUR)
Variable Integer VALEUR
[M]FLGAPH= VALEUR
If [M]FLGAPH <> 2
    [M]FLGADLV = 1
Endif

Gosub GRISE_APH
End

Subprog AM_FLGWRK(VALEUR)
Variable Integer VALEUR
[M]FLGWRK= VALEUR
Gosub GRISE_WRK
End

Subprog AM_FLGADLV(VALEUR)
Variable Integer VALEUR
End

Subprog AS_FLGADLV(VALEUR)
Variable Integer VALEUR
# cg 2013
# on ne peut saisir ce flag que si modele de patch
If [M]FLGAPH <> 2
       mkstat =2
Endif

End

Subprog C_FLGADLV(VALEUR)
Variable Integer VALEUR
End






Subprog C_TABREF(VALEUR)
Variable Char VALEUR
[M]CONCATREF = format$("K:"+num$(GLONATB)+"X",[M]TABREF)+[F:ATB]ABRFIC
End

Subprog C_TABLNK(VALEUR)
Variable Char    VALEUR()
#Call UNICITE(VALEUR,[M]TABLNK) From OBJDIV
End


Subprog AS_FCT(VALEUR)
Variable Char    VALEUR()
#If [M]FCYSTR="" : mkstat=1 : Endif
End


Subprog C_ABRLNK(VALEUR)
Variable Char    VALEUR()
Local Char TABLE(GLONATB)
Local Integer NOL
NOL = nolign-1
TABLE = [M]TABLNK(nolign-1)
Gosub CONT_ABRLNK
End

$CONT_ABRLNK
Local Integer I
If VALEUR=""
 Read [ATB]CODFIC = TABLE
 [M]CONCATLNK(NOL) = format$("K:"+num$(GLONATB)+"X",TABLE)+[F:ATB]ABRFIC
Else
 [M]CONCATLNK(NOL) = format$("K:"+num$(GLONATB)+"X",TABLE)+VALEUR
Endif
I = find([M]CONCATLNK(NOL),[M]CONCATLNK(0..NOL-1),[M]CONCATLNK(NOL+1..dim([M]CONCATLNK)-1))
If I
 GMESSAGE = [M]CONCATLNK(NOL)-":"-mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat = 2 : Return
Elsif [M]CONCATLNK(NOL)=[M]CONCATREF
 GMESSAGE = mess(94,139,1) : # Déjà utilisé
 mkstat = 2 : Return
Endif
If VALEUR<>""
 Read [ATB]CODFIC = [M]TABREF
 If VALEUR=[F:ATB]ABRFIC
  GMESSAGE = VALEUR-":"-mess(94,139,1) : # Déjà utilisé
  mkstat = 2 : Return
 Else
  Call UNICITE(VALEUR,[M]ABRLNK) From OBJDIV
  If mkstat : Return : Endif
 Endif
Endif
Return

Subprog AS_TABORI(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABFIL
End

Subprog C_TABORI(VALEUR)
Variable Char    VALEUR()
Local Char TABLE (GLONATB)
TABLE = [M]TABLNK(nolign-1)
Gosub CONT_TABORI
End

$CONT_TABORI
If !find(VALEUR,[M]TABREF,[M]TABLNK)
 GMESSAGE = mess(93,139,1) : # Table non référencée
 mkstat = 2
Elsif VALEUR=TABLE
 GMESSAGE = mess(97,139,1) : # Lien impossible sur la même table
 mkstat = 2
Endif
Return

Subprog AS_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Char TABLE (GLONATB)
TABLE = [M]TABLNK(nolign-1)
Gosub ASCLELNK
End

$ASCLELNK
If VALEUR=""
 Read [ATI]NUMLIG = TABLE;1
 If !fstat
  VALEUR = [F:ATI]CODIND
 Endif
Endif
Return

Subprog AS_EXPLNK(VALEUR)
Variable Char    VALEUR()
Local Char    CHAINE(250) , ZONE(250) , ABR(GLONABR)
Local Integer NB , I
Local Integer OK , K
If VALEUR=""
 Read [ATI]CODIND = [M]TABLNK(nolign-1);[M]CLELNK(nolign-1)
 If !fstat & [M]CLELNK(nolign-1) = [F:ATI]CODIND
  Filter [ATZ] Where LIEN=[M]TABLNK(nolign-1) & CODFIC=[M]TABORI(nolign-1)
  Read [ATZ]LIEN First
  Filter [ATZ]
  If !fstat
   K = find([M]TABORI(nolign-1),[M]TABLNK)
   If K & [M]ABRLNK(K-1)<>""
    ABR = [M]ABRLNK(K-1)
   Else
    Read [ATB]CODFIC = [M]TABORI(nolign-1)
    ABR = [F:ATB]ABRFIC
   Endif
   Gosub ASEXPLNK
  Endif
 Endif
Endif
Gosub CHARGE_TABFIL
End

$CHARGE_TABFIL
Local Integer NB
Raz [M]TABFIL, ABRFIL
[M]TABFIL(0) = [M]TABREF
Read [ATB]CODFIC = [M]TABREF
[M]ABRFIL(0) = [F:ATB]ABRFIC
# Issue 37908 - 2017-09-29 by CCC : check with previous tables only to be able to generate the Link by using declaration order directly
#For I=1 To [M]NBRLNK
For I=1 To nolign-1
 If [M]TABLNK(I-1)<>[M]TABLNK(nolign-1)
  NB += 1
  [M]TABFIL(NB) = [M]TABLNK(I-1)
  If [M]ABRLNK(I-1)<>""
   [M]ABRFIL(NB) = [M]ABRLNK(I-1)
  Else
   Read [ATB]CODFIC = [M]TABLNK(I-1)
   [M]ABRFIL(NB) = [F:ATB]ABRFIC
  Endif
 Endif
Next I
Return

$ASEXPLNK
If [F:ATZ]EXPLIEN<>""
 CHAINE = vireblc(format$("KT:250X",[F:ATZ]EXPLIEN),2)
 VALEUR = ""
 Repeat
  K = instr(K,CHAINE,";")
  If K
   ZONE   = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   ZONE   = CHAINE
   CHAINE = ""
  Endif
  If VALEUR<>"" : VALEUR += ";" : Endif
  If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
   VALEUR += "[F:"+ABR+"]"+ZONE
  Else
   VALEUR += ZONE
  Endif
 Until CHAINE = ""
Else
 VALEUR = "[F:"+ABR+"]"+[F:ATZ]CODZONE
Endif
Return

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call CONTROLE_ABR([M]TABFIL,[M]ABRFIL,[M]TABORI(nolign-1),[M]TABLNK(nolign-1)
&                 ,[M]CLELNK(nolign-1),[M]TYPLNK(nolign-1),VALEUR) From LNKSUB
Endif
End

Subprog AS_FLDCPY(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TAB
End

Subprog C_FLDCPY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call CONTROLE_FLD([M]TABFIL,[M]ABRFIL,VALEUR) From LNKSUB
End

Subprog AS_FLDFCY(VALEUR)
