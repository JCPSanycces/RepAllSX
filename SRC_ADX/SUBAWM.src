Subprog AM_AREQ(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : [M:AWM3]WREQ = [M:AWM3]REQORA
 When 2 : [M:AWM3]WREQ = [M:AWM3]REQSQL
Endcase
End

Subprog C_WREQ(VALEUR)
Variable Clbfile VALEUR
If len(VALEUR)>=250
 GMESSAGE=mess(62,123,1) : # Expression trop longue
 mkstat = 2
 End
Endif
Case [M:AWM3]AREQ
 When 1 : [M:AWM3]REQORA = VALEUR
 When 2 : [M:AWM3]REQSQL = VALEUR
Endcase
End

Subprog AP_WREQ(VALEUR)
Variable Clbfile VALEUR
End

Subprog C_AZOPTLIB(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog D_OPTCOD(VALEUR)
Variable Char    VALEUR()
If nolign=1
 VALEUR="A"
Else
 VALEUR=chr$(ascii([M]OPTCOD(nolign-2))+1)
Endif
End

Subprog C_OPTCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]OPTCOD) From OBJDIV
End

Subprog AM_OPTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If GADONIX=2 & (VALEUR<"A" | VALEUR>"Z")
 Call AVERTIR(mess(230,133,1),OK) From GESECRAN : # Code réservé spécifique
 If OK<>2 : mkstat = 1 : Endif
Endif
End

Subprog C_OPTCND(VALEUR)
Variable Char    VALEUR()
Local Integer E
E = abs(parse(VALEUR))
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E)+"\"+errm : # Expression incorrecte
 mkstat = 2 : End
Endif
Call C_QUOTE(VALEUR)
End

Subprog C_AZOPTERR(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR)
End

