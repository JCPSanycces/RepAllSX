Gosub CHARGE_TAB
End

Subprog C_FLDFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call CONTROLE_FLD([M]TABFIL,[M]ABRFIL,VALEUR) From LNKSUB
End

Subprog AS_FLDLEG(VALEUR)
Variable Char    VALEUR()
Raz [M]TABFIL, ABRFIL
[M]TABFIL(0) = [M]TABREF
Read [ATB]CODFIC = [M]TABREF
[M]ABRFIL(0) = [F:ATB]ABRFIC
[M]HLPFOR(0) = "[F:"+[M]ABRFIL(0)+"]"+[M]TABFIL(0)
End

Subprog C_FLDLEG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call CONTROLE_FLD([M]TABFIL,[M]ABRFIL,VALEUR) From LNKSUB
End

$CHARGE_TAB
Local Integer NB , I
Raz [M]TABFIL, ABRFIL, NB
[M]TABFIL(0) = [M]TABREF
Read [ATB]CODFIC = [M]TABFIL(0)
[M]ABRFIL(0) = [F:ATB]ABRFIC
[M]HLPFOR(0) = "["+[M]ABRFIL(0)+"]"+[M]TABFIL(0)
For I=1 To [M]NBRLNK
 If find([M]TYPLNK(I-1),1,3) : # Lien 0,1/1,1
  NB += 1
  [M]TABFIL(NB) = [M]TABLNK(I-1)
  If [M]ABRLNK(I-1)<>""
   [M]ABRFIL(NB) = [M]ABRLNK(I-1)
  Else
   Read [ATB]CODFIC = [M]TABFIL(NB)
   [M]ABRFIL(NB) = [F:ATB]ABRFIC
  Endif
  [M]HLPFOR(NB) = "[F:"+[M]ABRFIL(NB)+"]"+[M]TABFIL(NB)
 Endif
Next I
Return

Subprog AS_EXPSEL(VALEUR)
Variable Char    VALEUR()
Raz [M]TABFIL, ABRFIL
[M]TABFIL(0) = [M]TABLNK(nolign-1)
If [M]ABRLNK(nolign-1)<>""
 [M]ABRFIL(0) = [M]ABRLNK(nolign-1)
Else
 Read [ATB]CODFIC = [M]TABFIL(0)
 [M]ABRFIL(0) = [F:ATB]ABRFIC
Endif
[M]HLPFOR(0) = "[F:"+[M]ABRFIL(0)+"]"+[M]TABFIL(0)
End

Subprog C_EXPSEL(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ABRORI(VALEUR)
Variable Char    VALEUR()
Local Integer OK
# cas table ref
If [M]TABORI(nolign-1) = [M]TABREF & VALEUR = ""  : End : Endif
If [M]TABORI(nolign-1) = [M]TABREF & AABREV <> ""
 Call LECTURE("ATB",[M]TABORI(nolign-1),"") From CONTOBJ
 If [ATB]ABRFIC = VALEUR : End : Endif
 GMESSAGE = AABREV-":"-mess(285,139,1)-TABLE : # Abréviation non paramétrée pour la table
 mkstat = 2 : End
Endif

# cas table ligne
OK = 0
For I=0 To [M]NBRLNK-1
 If [M]TABLNK(I)=[M]TABORI(nolign-1) & [M]ABRLNK(I)=VALEUR
  OK =1
  Break
 Endif
Next
If !OK
 GMESSAGE = VALEUR-":"-mess(285,139,1)-[M]TABORI(nolign-1): # Abréviation non paramétrée pour la table
 mkstat = 2 : End
Endif
End

Subprog AS_ABRORI(VALEUR)
Variable Char    VALEUR()
If [M]TABORI(nolign-1) = [M:AWM1]TABREF : VALEUR ="" : mkstat = 2 : Endif
End

#-------------------------------------------#
## écran AWM3  exalead
#-------------------------------------------#

$CHARGE_TABLE
Local Integer NB,I
Local Char TAB(GLONATB)(1..16),ABR(GLONABR)(1..16)
NB = 1
[L]TAB(NB) = [M]TABREF
Read [ATB]CODFIC = [L]TAB(NB)
[L]ABR(NB) = [F:ATB]ABRFIC
For I=1 To [M]NBRLNK
 NB += 1
 [L]TAB(NB) = [M]TABLNK(I-1)
 If [M]ABRLNK(I-1)<>""
  [L]ABR(NB) = [M]ABRLNK(I-1)
 Else
  Read [ATB]CODFIC = [L]TAB(NB)
  [L]ABR(NB) = [F:ATB]ABRFIC
 Endif
Next I
Return

Subprog C_AFLD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Char TABLE(GLONATB),CHAMP(GLONAVA),CODTYPE(GLONATY),AABREV(10)
Local Integer DIME,INTIT
Gosub CHARGE_TABLE
Call CONTROLE_FLD(TAB,ABR,VALEUR,TABLE,AABREV,CHAMP,CODTYPE,DIME,INTIT)
If mkstat : End : Endif
If [M:AWM3]ACATEG(nolign-1)=0 : [M:AWM3]ACATEG(nolign-1)       = 2 : Endif
If AINTIT(nolign-1)=0
 [M:AWM3]AINTIT(nolign-1)       = INTIT
 [M:AWM3]AAINTIT(nolign-1)      = func AFNC.TEXTE(INTIT)
 Affzo [M:AWM3]AAINTIT(nolign-1)
Endif
End

Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABLE
Read [AOB]ABREV = VALEUR
If !fstat
 If [AOB]NOMFIC=""
  # : Il faut une table liée pour ce type D'objet
  GMESSAGE = mess(055,133,1) -"("+VALEUR+")"
  mkstat=2 : End
 Endif
 If !find([F:AOB]NOMFIC,TAB(1..NB))
  GMESSAGE = [F:AOB]NOMFIC-":"-mess(17,123,1) : # Table non définie
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_OBJ(VALEUR)
Variable Char    VALEUR()
Local File AFONCTION [AFC]
Gosub CHARGE_TABLE
Read [AOB]ABREV = VALEUR
If !fstat
 Read [ATB]CODFIC = [F:AOB]NOMFIC
 If !fstat
  Read [F:ATI]NUMLIG = [F:AOB]NOMFIC;1
  If !fstat
   [M]CLE = [F:ATI]CODIND
   Affzo [M]CLE
  Endif
 Endif
 Read [AFC]CODINT = "GES"+VALEUR
 If !fstat
  [M:AWM3]FCTEXA = [AFC]CODINT
 Endif
 Local Integer I
 I = find([F:AOB]NOMFIC,[L]TAB(1..NB))
 If I
  [M]TABLIE = TAB(I)
  [M]ABRLIE = ABR(I)
  Affzo [M]TABLIE
  Affzo [M]ABRLIE
 Endif
Endif
End

Subprog C_NBCATEG
End

Subprog C_ACATEG(VALEUR)
Variable Integer VALEUR
If VALEUR =2
 Local Integer I,J

 For I=0 To [M]NBCATEG-1
  If I<>nolign-1 & [M]ACATEG(I)=2
   J +=1
  Endif
 Next
 If J=25
  GMESSAGE = mess(22,135,1)-"(25)" : # TROP de critères de tri
  mkstat = 2 : End
 Endif
Endif
End


Subprog AS_TABLIE(VALEUR)
Variable Char    VALEUR()
If [M]OBJ="" : mkstat=1 : Endif
End

Subprog C_TABLIE(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABLE
Read [AOB]ABREV = [M:AWM3]OBJ
If !fstat
 If [F:AOB]NOMFIC<>VALEUR
  GMESSAGE = mess(267,142,1)-":"-[F:AOB]NOMFIC : #  : Table LIéE
  mkstat=2 : End
 Endif
 If !find(VALEUR,TAB(1..NB))
  GMESSAGE = VALEUR-":"-mess(17,123,1) : # Table non définie
  mkstat=2 : End
 Endif
Endif
End

Subprog S_TABLIE(VALEUR)
Variable Char    VALEUR()
Local Char    TEX(GLONDES)(1..GDIMSIT+GDIMSOC,1..3) , TIT(GLONDES)(0..3)
Local Integer NBTBL,CHOI

NBTBL = 1
TEX(NBTBL,1) = [M]TABREF
Read [ATB]CODFIC = [M]TABFIL(0)
TEX(NBTBL,2) = [F:ATB]ABRFIC
TEX(NBTBL,3) = func AFNC.TEXTE([F:ATB]INTITFIC)

For I=1 To [M]NBRLNK
 NBTBL += 1
 TEX(NBTBL,1) = [M]TABLNK(I-1)
 Read [ATB]CODFIC = TEX(NBTBL,1)
 If [M]ABRLNK(I-1)<>""
  TEX(NBTBL,2) = [M]ABRLNK(I-1)
 Else
  TEX(NBTBL,2) = [F:ATB]ABRFIC
 Endif
 TEX(NBTBL,3) = func AFNC.TEXTE([F:ATB]INTITFIC)
Next I
CHOI = 0
TIT(0) = mess(91,126,1)  : # Choix d'une table liée
TIT(1) = mess(161,126,1) : # La table liée
TIT(2) = mess(1,16,1)    : # Abréviation
TIT(3) = mess(107,142,1) : #Intitulé TABLE
Call SAITEX_COL_MAX(NBTBL,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
 [M]ABRLIE = TEX(CHOI,2)
 Affzo [M]ABRLIE
Endif
End

Subprog AS_ABRLIE(VALEUR)
Variable Char    VALEUR()
If [M]OBJ="" : mkstat=1 : Endif
End

Subprog C_ABRLIE(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABLE
If !find(VALEUR,ABR(1..NB))
 GMESSAGE = mess(285,139,1)-[M]TABLIE : #  ABRéVIATION non paramétrée pour la TABLE
 mkstat=2 : End
Endif
End

