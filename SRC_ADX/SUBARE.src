#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ARE",GBIDC1,GBIDC2) From GOBJET 
End 

#--------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "DEBUT_MOD"   : Gosub DEBUT_MOD
 When "ANNULE"      : Gosub ANNULE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
Endcase
Return

#--------------------------------#
$OUVRE
Local Char    OACTION(20) , MESSA(250)
Gosub SET_PRGSTD From SUBARC
Return

#--------------------------------#
$APRES_CHOI
If REPONSE=GSTAANU
 OACTION = ACTION
 OK = 1
 ACTION = "CONTROL" : Gosub ACTION From ARCHIVE
 ACTION = OACTION
 If !OK : REPONSE = 0 : Return : Endif
Endif
Return

#--------------------------------#
$SETBOUT
If !instr(1,CHAINE,"A") : CHAINE += "A" : endif
Return

#--------------------------------#
$APRES_MODIF
# Interdire la modif s'il y a déjà des evènements archivés sur ce type+conteneur
If !find(GREP,"D","C")
 Case zoncou
  When "NBLIG"
   OACTION = ACTION
   OK = 1
   ACTION = "CONTROL" : Gosub ACTION From ARCHIVE
   ACTION = OACTION
 Endcase
Endif
Return

#--------------------------------#
$VERIF_CRE
$VERIF_MOD
# Envoi des paramètres au serveur d'archive
OACTION = ACTION
ACTION = "PARAM" : Gosub ACTION From ARCHIVE
ACTION = OACTION
Return

#--------------------------------#
$INICRE
[F:ARE]NUMLIG = nolign
Return

#--------------------------------#
$CREATION
Call MAJTEXTRA([M:ARE1]INTPAR(nolign-1),"ARCHPARE","INTPAR",[M:ARE1]TYPDOC,[M:ARE1]IDTVOL+"~"+[M:ARE1]CODPAR(nolign-1)) From ATEXTRA
Return

#--------------------------------#
$DEBUT_MOD
For [ARE] Where TYPDOC=[M:ARE1]TYPDOC & IDTVOL=[M:ARE1]IDTVOL
 If !find([F:ARE]CODPAR,[M:ARE1]CODPAR)
  Delete [AXX] Where CODFIC="ARCHPARE" & IDENT1=[F:ARE]TYPDOC & IDENT2=[F:ARE]IDTVOL+"~"+[F:ARE]CODPAR
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA("AXX",[F:ARE]TYPDOC-[F:ARE]IDTVOL-[F:ARE]CODPAR) From GLOCK : Break
  Endif
 Endif
Next ARE
If GOK<1 : Return : Endif
Return

#--------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ARCHPARE" & IDENT1=[L]CODE & left$(IDENT2,len([L]SUPP))=[L]SUPP
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE-[L]SUPP(1)) From GLOCK : Return
Endif
Local Char    OACTION(20)
Gosub SET_PRGSTD From SUBARC
OACTION = ACTION
ACTION = "DELETE" : Gosub ACTION From ARCHIVE
ACTION = OACTION
Return

#------------------------------------------------------------------#
# Pour les patches des transactions
#------------------------------------------------------------------#

Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------------#
# Pg de mise à jour globale
#------------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If clalev([M:ARE1])>0 : End : Endif
Local Mask ARE1 [ARE1]
Local File =APPLI+".ARCHPARE" [ARE]
Local File =APPLI+".ATEXTRA"  [AXX]
Gosub SET_PRGSTD From SUBARC
For [ARE]ARE0(2)
 Call ECR_TRACE([F:ARE]TYPDOC-[F:ARE]IDTVOL,0) From GESECRAN
 nolign = 0
 For [ARE]ARE0
  nolign += 1
  [M:ARE1] = [F:ARE]
 Next ARE
 [M:ARE1]NBLIG = nolign
 OK = 1
 #ACTION = "PARAM" : Gosub ACTION From ARCHIVE
Next ARE
Close Local Mask [ARE1]
Close Local File
End


#--------------------------------#
Subprog AS_TYPPAR(VALEUR)
Variable Integer VALEUR
GMENLOC(6) = 1 : # Clob
GMENLOC(7) = 1 : # Blob
GMENLOC(8) = 1 : # Structure
End

Subprog AS_ADRPAR(VALEUR)
Variable Integer  VALEUR
GMENLOC(3) = 1
End
