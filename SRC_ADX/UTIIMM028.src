#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GLE
# LE          : 21 Mars      2011 14:53:41
# Moulinette pour corriger les associations
# FQ72104
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM028: Correction des associations") From LECFIC
  Call EXE_UTIIMM028(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM028(APPLI)
 Value Char APPLI
  If clalev([F:RVA]) : Close Local File [RVA] : Endif
  Local File =APPLI+".RUBASSVAL" [RVA]
  If clalev([F:RVP]) : Close Local File [RVP] : Endif
  Local File =APPLI+".RUBASSVALP" [RVP]
  Call ECR_TRACE("UTIIMM028: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM028
  Call ECR_TRACE("UTIIMM028: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM028
  Local Char    LNUMASS
  Local Integer NBRWRT : NBRWRT = 0
  
  Trbegin [RVA], [RVP]
    
  For [RVA]RVA1 With Stability
    LNUMASS = sum(num$([F:RVA]REFOBJ),num$([F:RVA]DETAAS),[F:RVA]ACM,[F:RVA]CPY)
    If [F:RVA]NUMASS <> LNUMASS
      [F:RVA]NUMASS = LNUMASS
      Rewrite [RVA]
      If fstat
        Call ECR_TRACE("Error rewriting [F:RVA] :"-num$([F:RVA]REFOBJ)-num$([F:RVA]DETAAS)-[F:RVA]ACM-[F:RVA]CPY-[F:RVA]VALDETAAS,1) From GESECRAN
        GOK = 0
        Break
      Endif
      NBRWRT += 1
    Endif
  Next

  For [RVP]RVP1 With Stability
    LNUMASS = sum(num$([F:RVP]REFOBJ),num$([F:RVP]DETAAS),[F:RVP]ACM,[F:RVP]CPY)
    If [F:RVP]NUMASS <> LNUMASS
      [F:RVP]NUMASS = LNUMASS
      Rewrite [RVP]
      If fstat
        Call ECR_TRACE("Error rewriting [F:RVP] :"-num$([F:RVP]REFOBJ)-num$([F:RVP]DETAAS)-[F:RVP]ACM-[F:RVP]CPY-[F:RVP]VALDETAAS-num$(DPRPLN),1) From GESECRAN
        GOK = 0
        Break 2
      Endif
      NBRWRT += 1
    Endif
  Next

  If !GOK Then
    Goto AB_UTIIMM028
  Else
    Commit
    Call ECR_TRACE("Records updated :"-num$(NBRWRT),0) From GESECRAN
  Endif
Return

$AB_UTIIMM028
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  
  If filinfo(filpath("FIL","RUBASSVAL","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","RUBASSVALP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM028(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif

  If filinfo(filpath("FIL","RUBASSVAL","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","RUBASSVALP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM028(APPLI)
End
