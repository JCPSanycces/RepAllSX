#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre SITRAFIL

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:15:47"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"SITRAFIL",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="SITF;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:SITF])=0 : Local Mask SITRAFIL [SITF] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGSITRAFIL
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "SITRAFIL" From GFONCTION At A_STAMP With A_WINDPREV Mask [SITF]
& As [SITF]
Titled [SITF] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGSITRAFIL
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "SITRAFIL" From GFONCTION At A_STAMP With A_WINDPREV Mask [SITF]
& As [SITF]
Titled [SITF] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [SITF] 
Return

$SAISIE_BOITE
Boxinp [SITF] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [SITF]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(31724,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(1) = "SITRAFIL"     : ABMSK(1)  = "SITF"     : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 1 : If clalev([M:SITF])>0 : Default Mask [SITF] : Endif
Endcase
Return

$TITMASK
Case MA
 When 1 : If clalev([M:SITF])>0 : Gosub TITRES From W1SITRAFIL : Endif
Endcase
Return

$FERME_MASK
If clalev([M:SITF])>0 : Close Local Mask [SITF] : Endif
Return

$RAZMASK
Case MA
 When 1 : If clalev([M:SITF])>0 : Raz [M:SITF] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 1 : If clalev([M:SITF])>0 : Affzo [M:SITF] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = "09<>"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "3" : LBOUT(NBTEX) = 1801 : Call TEXTE(21801,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "2" : LBOUT(NBTEX) = 1102 : Call TEXTE(12413,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "0"
  FLGEXE = 1
  GACTION = "STD"
 When "9"
  FLGEXE = 1
  GACTION = "STD"
 When "<"
  FLGEXE = 1
  GACTION = "STD"
 When ">"
  FLGEXE = 1
  GACTION = "STD"
Endcase
GACTION = SAVACT
Return


