## Etiquette ajoutée par le superviseur (écran ATY2) 21/06/2012 11:03:52 (KUYAN)
######################################################################################
Subprog AS_NBRRUL
[M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(nolign-1))+"."+[M:ATY2]TRTRUL(nolign-1)+"."+[M:ATY2]PRGRUL(nolign-1)
Gosub L_ADD_PARAM_CODFLD
If L_NBRPAR>0
 Chgstl [M:ATY2]PRGRUL(nolign-1) With "AMKACT"
Else
 Chgstl [M:ATY2]PRGRUL(nolign-1) With ""
Endif
Chgstl [M:ATY2]TYPRUL With ""
Chgstl [M:ATY2]TYPRUL(nolign-1) With "AMKCUR"
End

Subprog APRES_NBRRUL
 Gosub L_UPDATE_WNBRPAR
End

Subprog APRES_NBRPAR
 If [M:ATY2]WCURRUL="" : End : Endif
 Local Integer IPAR
 # remove the old parameter for this sous-prog in [M:ATY2]45
 IPAR = 0

 While IPAR <= [M:ATY2]WNBRPAR-1
  If [M:ATY2]WPARRUL(IPAR) = [M:ATY2]WCURRUL and [M:ATY2]WPARORD(IPAR) = nolign
   Dela IPAR,1 [M:ATY2]WNBRPAR
   [M:ATY2]WNBRPAR-= 1
   Break
  Endif
  IPAR += 1
 Wend
 Affzo [M:ATY2]45
 # load the new parameter for this sous-prog from [M:ATY2]40 to [M:ATY2]45
  [M:ATY2]WPARORD(WNBRPAR) = nolign
  [M:ATY2]WPARRUL(WNBRPAR) = [M:ATY2]WCURRUL
  [M:ATY2]WPARCOD(WNBRPAR) = [M:ATY2]PARCOD(nolign-1)
  [M:ATY2]WPARTIT(WNBRPAR) = [M:ATY2]PARTIT(nolign-1)
  Call TEXTE([M]WPARTIT(WNBRPAR),[M]WZPARTIT(WNBRPAR)) From OBJDIV
  [M:ATY2]WPARTYP(WNBRPAR) = [M:ATY2]PARTYP(nolign-1)
  [M:ATY2]WPARCLA(WNBRPAR) = [M:ATY2]PARCLA(nolign-1)
  [M:ATY2]WPARDIM(WNBRPAR) = [M:ATY2]PARDIM(nolign-1)
  [M:ATY2]WPARMOD(WNBRPAR) = [M:ATY2]PARMOD(nolign-1)
  [M:ATY2]WPARCLE(WNBRPAR) = [M:ATY2]PARCLE(nolign-1)
  [M:ATY2]WNBRPAR += 1

 Sorta [M:ATY2]WNBRPAR [M:ATY2]WNBRPAR Order By [M:ATY2]WPARRUL(indice),[M:ATY2]WPARORD(indice)
 Affzo [M:ATY2]45
End

Subprog AS_TYPRUL(VALEUR)
Variable Integer VALEUR
If [M]TYPSELSYR<>3 | [M]SUPFLG=2
  GMENLOC(6)=1
  GMENLOC(7)=1
  GMENLOC(8)=1
  GMENLOC(9)=1
  GMENLOC(10)=1
  GMENLOC(11)=1
Endif
End

Subprog C_TYPRUL(VALEUR)
Variable Integer VALEUR
Call CHECK_TYPRUL(VALEUR)
If mkstat : End : Endif
If find(VALEUR,6,7,8,9,10,11)>0
 Call UNICITE(VALEUR,[M:ATY2]TYPRUL(0..[M:ATY2]NBRRUL-1)) From OBJDIV
 If mkstat : End : Endif
Endif
End

Subprog CHECK_TYPRUL(VALEUR)
Variable Integer VALEUR
If ([M]TYPSELSYR<>3 | [M]SUPFLG=2) & find(VALEUR,6,7,8,9,10,11)>0
    GMESSAGE=func AFNC.MES2(mess(162,143,1),
&             mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1)-mess(10,7961,1)-mess(11,7961,1),
&             mess(3,7881,1))
    GERR=1 : mkstat=2
    End
Endif
End

Subprog AM_TYPRUL(VALEUR)
Variable Integer VALEUR
 [M:ATY2]WCURRUL = num$(VALEUR)+"."+[M:ATY2]TRTRUL(nolign-1)+"."+[M:ATY2]PRGRUL(nolign-1)
End


Subprog AM_TRTRUL(VALEUR)
Variable Char    VALEUR()
 [M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(nolign-1))+"."+VALEUR+"."+[M:ATY2]PRGRUL(nolign-1)
 Raz [M:ATY2]PRGRUL(nolign-1)
 Effzo [M:ATY2]40
End


Subprog AM_PRGRUL(VALEUR)
Variable Char    VALEUR()
 Local Char FICHIER(GLONADC) , SOUPROG(GLONASU)
 [M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(nolign-1))+"."+[M:ATY2]TRTRUL(nolign-1)+"."+VALEUR
 Call L_READ_PARAM([M:ATY2]TRTRUL(nolign - 1), VALEUR, nolign-1)
End

Subprog AS_ORDRUL(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If nolign=1
 VALEUR=1000
Elsif nolign>=2
 VALEUR = [M]ORDRUL(nolign-2)+10
Endif
End


Subprog B1_NBRPAR
 Local Integer LND, L_TYP, IRUL
 Local Char L_FIL(30), L_PRG(30)
 IND = -1
 Call L_CURRUL_PASER([M:ATY2]WCURRUL, L_TYP, L_FIL, L_PRG)
 If L_TYP>0 and L_FIL<>"" and L_PRG<>""
  If L_TYP = 2 & L_FIL=func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP & L_PRG=[V]CST_ANAMCTLREF
   Gosub DEL_PARAM_RULES
   [M:ATY2]WCURRUL = "2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF
   Gosub ADD_ACTRLREF_PARAM
  Else
   For IRUL = 0 To [M:ATY2]NBRRUL-1
    If [M:ATY2]TYPRUL(IRUL) = L_TYP and [M:ATY2]TRTRUL(IRUL) = L_FIL and [M:ATY2]PRGRUL(IRUL) = L_PRG
     IND = IRUL : Break
    Endif
   Next
   Call L_READ_PARAM(L_FIL, L_PRG, IND)
   Gosub L_UPDATE_WNBRPAR
  Endif
 Endif
 mkstat=4
End


Subprog L_CURRUL_PASER(CURRUL, RES_TYP, RES_FIL, RES_PRG)
Value Char CURRUL
Variable Integer RES_TYP
Variable Char RES_FIL, RES_PRG
 Raz RES_TYP, RES_FIL, RES_PRG
 Local Integer I
 I = instr(1,CURRUL,".")
 If I>0
  RES_TYP = val(left$(CURRUL, I-1))
  CURRUL = right$(CURRUL, I+1)
  I = instr(1,CURRUL,".")
  If I>0
   RES_FIL = left$(CURRUL, I-1)
   RES_PRG = right$(CURRUL, I+1)
  Endif
 Endif
End


Subprog C_NBRRUL

Case status

 When 83  : # suppresion param dans tableau
  If nolign1=0 : nolign1 = nolign : Endif
  For NOL=nolign-1 To nolign1
   [M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(NOL))+"."+[M:ATY2]TRTRUL(NOL)+"."+[M:ATY2]PRGRUL(NOL)
   If [M:ATY2]WCURRUL = "2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF
    GMESSAGE =mess(00001,00115,1) : #SUPPRESSION IMPOSSIBLE
    mkstat=2 : Break
   Endif
   Gosub DEL_PARAM_RULES
  Next

 When 65 : # suppresion param dans tableau
  NOL=nolign-1
  [M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(NOL))+"."+[M:ATY2]TRTRUL(NOL)+"."+[M:ATY2]PRGRUL(NOL)
  If [M:ATY2]WCURRUL = "2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF
   GMESSAGE =mess(00001,00115,1) :# SUPPRESSION IMPOSSIBLE
   mkstat=2 : End
  Endif
  Gosub DEL_PARAM_RULES

 When 73  : # insertion
  Raz [M:ATY2]WCURRUL
  Effzo [M:ATY2]40
  Chgstl [M:ATY2]TYPRUL With ""
  Chgstl [M:ATY2]TYPRUL(nolign-1) With "AMKCUR"

Endcase
End

$DEL_PARAM_RULES
Local Integer I
I= find([M:ATY2]WCURRUL ,[M:ATY2]WPARRUL(0..[M:ATY2]WNBRPAR-1))
While I>0
 Dela I-1,1 [M:ATY2]WNBRPAR
 [M:ATY2]WNBRPAR-= 1
 I= find([M:ATY2]WCURRUL ,[M:ATY2]WPARRUL(0..[M:ATY2]WNBRPAR-1))
Wend
Raz [M:ATY2]WCURRUL
Affzo [M:ATY2]45
Affzo [M:ATY2]40
Return



######################################################################################

$L_LOAD_PARAM
 Local Integer IPAR
 Local Char L_RUL(80)
 For [ATYRP] Where CODTYP = [M:ATY0]CODTYP
  [M:ATY2]WPARORD(IPAR)    = [ATYRP]PARORD
  [M:ATY2]WPARRUL(IPAR)    = num$([ATYRP]TYPRUL)+"."+[ATYRP]TRTRUL+"."+[ATYRP]PRGRUL  # KUYAN
  [M:ATY2]WPARCOD(IPAR)    = [ATYRP]PARCOD
  [M:ATY2]WPARTIT(IPAR)    = [ATYRP]PARTIT
  Call TEXTE([M]WPARTIT(IPAR),[M]WZPARTIT(IPAR)) From OBJDIV
  [M:ATY2]WPARTYP(IPAR)    = [ATYRP]PARTYP
  [M:ATY2]WPARCLA(IPAR)    = [ATYRP]PARCLA
  [M:ATY2]WPARDIM(IPAR)    = [ATYRP]PARDIM
  [M:ATY2]WPARMOD(IPAR)    = [ATYRP]PARMOD
  [M:ATY2]WPARCLE(IPAR)    = [ATYRP]PARCLE
  IPAR += 1
 Next
 [M:ATY2]WNBRPAR = IPAR
 Sorta [M:ATY2]WNBRPAR [M:ATY2]WNBRPAR Order By [M:ATY2]WPARRUL(indice),[M:ATY2]WPARORD(indice)
 Affzo [M:ATY2]45
Return

$L_LOAD_RUL
Local Integer IRUL
Local Char L_RUL(80)
For [ATYR] Where CODTYP = [M:ATY0]CODTYP
 [M:ATY2]TYPRUL(IRUL)    = [ATYR]TYPRUL
 [M:ATY2]TRTRUL(IRUL)    = [ATYR]TRTRUL
 [M:ATY2]PRGRUL(IRUL)    = [ATYR]PRGRUL
 [M:ATY2]ORDRUL(IRUL)    = [ATYR]ORDRUL
 [M:ATY2]ACTRUL(IRUL)    = [ATYR]ACTRUL
 [M:ATY2]ENARUL(IRUL)    = [ATYR]ENARUL
 IRUL += 1
Next
[M:ATY2]NBRRUL = IRUL
Affzo [M:ATY2]30

Return


#---------------------- AS_NBRRUL internal use only ----------------------#
$L_ADD_PARAM_CODFLD
 Local Integer IPAR, L_NBRPAR
 L_NBRPAR = 0
 Effzo  [M:ATY2]40

 For IPAR=0 To [M:ATY2]WNBRPAR-1
  # Only the parameter/key related the current rule will be displayed
  If [M:ATY2]WPARRUL(IPAR) = [M:ATY2]WCURRUL & L_NBRPAR<dim([M:ATY2]PARCOD)
   [M:ATY2]PARCOD(L_NBRPAR) = [M:ATY2]WPARCOD(IPAR)
   [M:ATY2]PARTIT(L_NBRPAR) = [M:ATY2]WPARTIT(IPAR)
   [M:ATY2]ZPARTIT(L_NBRPAR) = [M:ATY2]WZPARTIT(IPAR)
   [M:ATY2]PARTYP(L_NBRPAR) = [M:ATY2]WPARTYP(IPAR)
   [M:ATY2]PARCLA(L_NBRPAR) = [M:ATY2]WPARCLA(IPAR)
   [M:ATY2]PARDIM(L_NBRPAR) = [M:ATY2]WPARDIM(IPAR)
   [M:ATY2]PARMOD(L_NBRPAR) = [M:ATY2]WPARMOD(IPAR)
   [M:ATY2]PARCLE(L_NBRPAR) = [M:ATY2]WPARCLE(IPAR)
   L_NBRPAR += 1
  Endif
 Next
 [M:ATY2]NBRPAR = L_NBRPAR
 Affzo [M:ATY2]40
Return

#------------ APRES_NBRRUL/B1_NBRPAR internal use only ------------#
$L_UPDATE_WNBRPAR
 If  [M:ATY2]WCURRUL="" : Return : Endif
 Local Integer IPAR, L_NBRPAR
 L_NBRPAR = 0

 # remove the old parameters for this sous-prog in [M:ATY2]45
 IPAR = 0
 While IPAR <= [M:ATY2]WNBRPAR-1
  If [M:ATY2]WPARRUL(IPAR) = [M:ATY2]WCURRUL
   Dela IPAR,1 [M:ATY2]WNBRPAR
   [M:ATY2]WNBRPAR-= 1
   IPAR-=1
  Endif
  IPAR += 1
 Wend

 # load the new parameters for this sous-prog from [M:ATY2]40 to [M:ATY2]45
 For IPAR=0 To [M:ATY2]NBRPAR-1
  [M:ATY2]WPARORD([M:ATY2]WNBRPAR) = IPAR+1
  [M:ATY2]WPARRUL([M:ATY2]WNBRPAR) = [M:ATY2]WCURRUL
  [M:ATY2]WPARCOD([M:ATY2]WNBRPAR) = [M:ATY2]PARCOD(IPAR)
  [M:ATY2]WPARTIT([M:ATY2]WNBRPAR) = [M:ATY2]PARTIT(IPAR)
  [M:ATY2]WZPARTIT([M:ATY2]WNBRPAR)= [M:ATY2]ZPARTIT(IPAR)
  [M:ATY2]WPARTYP([M:ATY2]WNBRPAR) = [M:ATY2]PARTYP(IPAR)
  [M:ATY2]WPARCLA([M:ATY2]WNBRPAR) = [M:ATY2]PARCLA(IPAR)
  [M:ATY2]WPARDIM([M:ATY2]WNBRPAR) = [M:ATY2]PARDIM(IPAR)
  [M:ATY2]WPARMOD([M:ATY2]WNBRPAR) = [M:ATY2]PARMOD(IPAR)
  [M:ATY2]WPARCLE([M:ATY2]WNBRPAR) = [M:ATY2]PARCLE(IPAR)
  [M:ATY2]WNBRPAR += 1
 Next

 Sorta [M:ATY2]WNBRPAR [M:ATY2]WNBRPAR Order By [M:ATY2]WPARRUL(indice),[M:ATY2]WPARORD(indice)
 Affzo [M:ATY2]40
 Affzo [M:ATY2]45
Return


#-------------- for SUBATY internal use only ----------------#
Subprog L_READ_PARAM(FICHIER, SOUPROG, RUL_IND)
Value Char FICHIER, SOUPROG
Value Integer RUL_IND

 Local Integer IRES,WNUM
 Local Integer RES_FCT, RES_NBP, RES_STA, RES_TYP(1..50), RES_ADR(1..50), RES_DIM(1..50)
 Local Char RES_PAR(30)(1..50), RES_CLA(GLONACLA)(1..50)
 Effzo [M:ATY2]40
 Call LOAD_PROG_PARAM(FICHIER, SOUPROG, RES_FCT, RES_NBP, RES_PAR, RES_TYP, RES_ADR, RES_DIM, RES_CLA, RES_STA) From AFNC
 If RES_STA = -1
  # Script inexistant
  Call ERREUR(mess(234,100,1)-FICHIER) From GESECRAN
  mkstat=2 : OK = 0 : End
 Elsif RES_STA = -3
    End : # adx existant
 Elsif RES_STA = -2
  If RES_FCT=0
   # Sous-programme inexistant
   Call ERREUR(mess(71,150,1)-SOUPROG) From GESECRAN
  Elsif RES_FCT=1
   # Sous-programme de type Funprog obligatoire
   Call ERREUR(mess(237,100,1)) From GESECRAN
  Endif
  mkstat=2 : OK = 0 : End

 Elsif RES_NBP>0
  [M:ATY2]NBRPAR = RES_NBP
  For IRES=1 To RES_NBP
   [M:ATY2]PARCOD(IRES-1)  = RES_PAR(IRES)
   [M:ATY2]PARTYP(IRES-1) = RES_TYP(IRES)
   [M:ATY2]PARMOD(IRES-1) = RES_ADR(IRES)
   [M:ATY2]PARDIM(IRES-1) = max(RES_DIM(IRES),1)
   [M:ATY2]PARCLA(IRES-1) = RES_CLA(IRES)
   [M:ATY2]PARCLE(IRES-1) = 1
   WNUM=0
   Case [M:ATY2]PARCOD(IRES-1)
    When "AINSTANCE" :
     #[M:ATY2]PARTIT(IRES-1)  = 28067 # Adresse de l'instance
     Call NUMEROFRA("Adresse de l'instance",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When "AEXIST"  :
     #[M:ATY2]PARTIT(IRES-1)  = 28068 # Nom de la propriété
     Call NUMEROFRA("Existe",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When "AVALCNT"  :
     #[M:ATY2]PARTIT(IRES-1)  = 28068 # Nom de la propriété
     Call NUMEROFRA("Content type",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When "APRONAME"  :
     #[M:ATY2]PARTIT(IRES-1)  = 28068 # Nom de la propriété
     Call NUMEROFRA("Nom de la propriété",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
#    When "APROIND"   :
#     #[M:ATY2]PARTIT(IRES-1)  = 28069 # Indice de la propriété
#     Call NUMEROFRA("Indice de la propriété",WNUM) From OBJDIV
#     [M:ATY2]PARTIT(IRES-1)=WNUM
#     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When "AVALUE"    :
     #[M:ATY2]PARTIT(IRES-1)  = 28070 # Valeur de la propriété
     Call NUMEROFRA("Valeur de la propriété",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When "AFORMAT"   :
     #[M:ATY2]PARTIT(IRES-1)  = 28073 # Valeur du format en retour
     Call NUMEROFRA("Valeur du format en retour",WNUM) From OBJDIV
     [M:ATY2]PARTIT(IRES-1)=WNUM
     Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
    When Default:
     #on recherche le code pour reprendre le texte
     WNUM=find(RES_PAR(IRES),[M:ATY2]WPARCOD)
     If WNUM>0
       [M:ATY2]PARTIT(IRES-1)=[M:ATY2]WPARTIT(WNUM-1)
       Call TEXTE([M:ATY2]PARTIT(IRES-1),[M:ATY2]ZPARTIT(IRES-1)) From OBJDIV
     Endif
   Endcase
  Next IRES
  If RUL_IND >= 0
   Chgstl [M:ATY2]PRGRUL(RUL_IND) With "AMKACT"
  Endif
  Affzo [M:ATY2]40
 Else
  If RUL_IND >= 0
   Chgstl [M:ATY2]PRGRUL(RUL_IND) With ""
  Endif
 Endif
End

#------------------------------------------------------------#
Subprog L_RULE_PARSER(CONCATENATED, RES_RUL, RES_TRT, RES_PRG)
Value Char CONCATENATED
Variable Char RES_RUL, RES_TRT, RES_PRG
Raz RES_RUL, RES_TRT, RES_PRG
 Local Integer INDEX
 INDEX = instr(1,CONCATENATED,".")
 If INDEX > 0
  RES_RUL = left$(CONCATENATED,INDEX-1)
  CONCATENATED = right$(CONCATENATED,INDEX+1)
  INDEX = instr(1,CONCATENATED,".")
  If INDEX > 0
   RES_TRT = left$(CONCATENATED,INDEX-1)
   RES_PRG = right$(CONCATENATED,INDEX+1)
  Endif
 Endif
End

######################################################################################
Subprog C_TYPSELSYR(VALEUR)
Variable Integer VALEUR
Call CHECK_TYPSELSYR(VALEUR)
If mkstat : End : Endif
End

Subprog CHECK_TYPSELSYR(VALEUR)
Variable Integer VALEUR
If VALEUR=3 & !find([M]TYPTYP,9,10)
  GMESSAGE=func AFNC.MES2(mess(156,143,1),mess(VALEUR,7881,1),mess([M]TYPTYP,30,1))
  GERR=1 : mkstat=2
  End
Elsif VALEUR<>3 & find([M]TYPTYP,9,10)
  GMESSAGE=func AFNC.MES2(mess(156,143,1),mess(VALEUR,7881,1),mess([M]TYPTYP,30,1))
  GERR=1 : mkstat=2
  End
Endif
End


Subprog AM_TYPSELSYR(VALEUR)
Variable Integer VALEUR
[M]TYPSELSYR =[L]VALEUR
Gosub GRISE_TYPSELSYR
Gosub DEL_ACTRLREF
End

$GRISE_TYPSELSYR
If [M]TYPSELSYR=2
  Actzo [M:ATY2]CODCLA
  Actzo [M:ATY2]DEFREPDES
  Actzo [M:ATY2]DEFREPMOB
  Actzo [M:ATY2]DEFREPTAB
Else
  Effzo [M:ATY2]CODCLA
  Grizo [M:ATY2]CODCLA
  Effzo [M:ATY2]DEFREPDES
  Effzo [M:ATY2]DEFREPMOB
  Effzo [M:ATY2]DEFREPTAB
  Grizo [M:ATY2]DEFREPDES
  Grizo [M:ATY2]DEFREPMOB
  Grizo [M:ATY2]DEFREPTAB
Endif
If [M]TYPSELSYR=3
  [M:ATY2]FMTPROSYR=1
  Affzo [M:ATY2]FMTPROSYR
  Grizo [M:ATY2]FMTPROSYR
  Actzo [M:ATY2]SUPFLG
Else
  If [M:ATY2]FMTPROSYR=0 : [M:ATY2]FMTPROSYR=1 : Endif
  Affzo [M:ATY2]FMTPROSYR
  Actzo [M:ATY2]FMTPROSYR
  [M:ATY2]SUPFLG=1
  Affzo [M:ATY2]SUPFLG
  Grizo [M:ATY2]SUPFLG
Endif
Return

######################################################################################
Subprog C_CODCLA(VALEUR)
Variable Char    VALEUR()

Call CHECK_CODCLA(VALEUR)
If mkstat : End : Endif
End

Subprog CHECK_CODCLA(VALEUR)
Variable Char    VALEUR()
If [M]TYPSELSYR=2 & VALEUR=""
 GMESSAGE=func AFNC.MES1(mess(161,143,1),mess(2,7881,1))
 GERR=1 : mkstat=2
 End
Endif
End

Subprog AS_ENARUL(VALEUR)
Variable Integer VALEUR
If [M:ATY2]PRGRUL(nolign-1)<>[V]CST_ANAMCTLREF
 VALEUR = 2 : mkstat = 2 : End
Else
 If GADONIX<>2
  mkstat = 2 : End
 Endif
Endif
End

Subprog B1_NBRRUL
Gosub DEL_ACTRLREF
Gosub ADD_ACTRLREF
mkstat = 4
End

Subprog AM_CODCLA(VALEUR)
Variable Char    VALEUR()
Gosub DEL_ACTRLREF
[M:ATY2]CODCLA = VALEUR
Gosub ADD_ACTRLREF
End

$DEL_ACTRLREF
Local Integer IPOS,IPOS2
IPOS2=-1
For IPOS=0 To [M]NBRRUL-1
 If [M]TYPRUL(IPOS)=2 & [M]TRTRUL(IPOS)=func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP & [M]PRGRUL(IPOS)=[V]CST_ANAMCTLREF
  IPOS2= IPOS : Break
 Endif
Next
If IPOS2>=0 & [M]NBRRUL>0
 Dela IPOS2 ,1 [M]NBRRUL
 [M]NBRRUL -= 1
 Affzo [M:ATY2]30
 Actzo [M:ATY2]30
Endif

[L]IPOS = find("2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF,[M:ATY2]WPARRUL(0..[M:ATY2]WNBRPAR-1))
If [L]IPOS>0
 If  [M:ATY2]WCURRUL = "2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF
  Effzo  [M:ATY2]40
 Endif
 [M:ATY2]WCURRUL = "2."+func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP+"."+[V]CST_ANAMCTLREF
 Gosub DEL_PARAM_RULES
Endif
Return

$ADD_ACTRLREF
Read [ACLA]ACLA0 = [M:ATY2]CODCLA
If fstat or  [F:ACLA]TYPCLA<>2
 Return
Endif

Insa 0,1,[M:ATY2]NBRRUL [M]NBRRUL
[M:ATY2]TYPRUL(0) = 2
[M:ATY2]TRTRUL(0) = func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[M]CODTYP
[M:ATY2]PRGRUL(0) = [V]CST_ANAMCTLREF
[M:ATY2]ORDRUL(0) = 0
[M:ATY2]ENARUL(0) = 2
[M]NBRRUL += 1

Affzo [M:ATY2]30
Grizo [M:ATY2]TYPRUL(0)
Grizo [M:ATY2]PRGRUL(0)
Grizo [M:ATY2]TRTRUL(0)
Grizo [M:ATY2]ORDRUL(0)
Grizo [M:ATY2]ACTRUL(0)


[M:ATY2]WCURRUL = num$([M:ATY2]TYPRUL(0))+"."+[M:ATY2]TRTRUL(0)+"."+[M:ATY2]PRGRUL(0)

$ADD_ACTRLREF_PARAM
# Add parameteres

Local Integer NUMTEXT
Effzo [M:ATY2]40

## AINSTANCE
[M:ATY2]PARCOD([M:ATY2]NBRPAR) = "AINSTANCE"
Call NUMEROFRA("Instance",[L]NUMTEXT) From OBJDIV
[M:ATY2]PARTIT([M:ATY2]NBRPAR) = [L]NUMTEXT
Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
[M:ATY2]PARTYP([M:ATY2]NBRPAR) = 13
[M:ATY2]PARCLA([M:ATY2]NBRPAR) = "OBJECT"
[M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
[M:ATY2]PARMOD([M:ATY2]NBRPAR) = 1
[M:ATY2]PARCLE([M:ATY2]NBRPAR) = 1
[M:ATY2]NBRPAR += 1
## APRONAME
[M:ATY2]PARCOD([M:ATY2]NBRPAR) = "APRONAME"
Call NUMEROFRA("Propriété",[L]NUMTEXT) From OBJDIV
[M:ATY2]PARTIT([M:ATY2]NBRPAR) = [L]NUMTEXT
Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
[M:ATY2]PARTYP([M:ATY2]NBRPAR) = 7
[M:ATY2]PARCLA([M:ATY2]NBRPAR) = ""
[M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
[M:ATY2]PARMOD([M:ATY2]NBRPAR) = 2
[M:ATY2]PARCLE([M:ATY2]NBRPAR) = 1
[M:ATY2]NBRPAR += 1
## AVALUE
[M:ATY2]PARCOD([M:ATY2]NBRPAR) = "AVALUE"
Call NUMEROFRA("Valeur",[L]NUMTEXT) From OBJDIV
[M:ATY2]PARTIT([M:ATY2]NBRPAR) = [L]NUMTEXT
Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
[M:ATY2]PARTYP([M:ATY2]NBRPAR) = [M]TYPTYP
[M:ATY2]PARCLA([M:ATY2]NBRPAR) = ""
[M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
[M:ATY2]PARMOD([M:ATY2]NBRPAR) = 1
[M:ATY2]PARCLE([M:ATY2]NBRPAR) = 1
[M:ATY2]NBRPAR += 1

Local Char CHAINE(250)
Read [ACLA]ACLA0 = [M:ATY2]CODCLA
If !fstat &  find([F:ACLA]TYPCLA,2)>0
 If [F:ACLA]TYPCLA=2
    # Issue X3-58309 - 2017-11-03 by CCC : read appropriate index (view or table)
    #Read [ATI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
    Read [AVI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
    If !fstat
       CHAINE = [F:AVI]DESCRIPT
    Endif
 Elsif [F:ACLA]TYPCLA=5
    CHAINE = [F:ACLA]KEYINT
 Endif
 If CHAINE <>""
  Gosub L_DEFCLE From SUBACLA
  For I=1 To NBCLE
   Read [ACLAF]ACLAF0 = [ACLA]CODCLA;[L]CLE(I)
   If !fstat
    Read [F:ATY]CODTYP = [ACLAF]CODTYP
    [M:ATY2]PARCOD([M:ATY2]NBRPAR) = [L]CLE(I)
    [M:ATY2]PARTIT([M:ATY2]NBRPAR) =[ACLAF]INTFLD
    Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
    [M:ATY2]PARTYP([M:ATY2]NBRPAR) = [F:ATY]TYPTYP
    [M:ATY2]PARCLA([M:ATY2]NBRPAR) = ""
    [M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
    [M:ATY2]PARMOD([M:ATY2]NBRPAR) = 2
    [M:ATY2]PARCLE([M:ATY2]NBRPAR) = 2
    [M:ATY2]NBRPAR +=1
   Endif
  Next
  Read [ACLAF]ACLAF0 = [ACLA]CODCLA;"ENAFLG"
  If !fstat
   Read [F:ATY]CODTYP = [ACLAF]CODTYP
   [M:ATY2]PARCOD([M:ATY2]NBRPAR) = "AENABLE"
   [M:ATY2]PARTIT([M:ATY2]NBRPAR) =[ACLAF]INTFLD
   Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
   [M:ATY2]PARTYP([M:ATY2]NBRPAR) = [F:ATY]TYPTYP
   [M:ATY2]PARCLA([M:ATY2]NBRPAR) = ""
   [M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
   [M:ATY2]PARMOD([M:ATY2]NBRPAR) = 2
   [M:ATY2]PARCLE([M:ATY2]NBRPAR) = 1
   [M:ATY2]NBRPAR +=1
  Endif
  [M:ATY2]PARCOD([M:ATY2]NBRPAR) = "AFILTER"
  Call NUMEROFRA("Filtre",[L]NUMTEXT) From OBJDIV
  [M:ATY2]PARTIT([M:ATY2]NBRPAR) = [L]NUMTEXT
  Call TEXTE([M:ATY2]PARTIT([M:ATY2]NBRPAR),[M:ATY2]ZPARTIT([M:ATY2]NBRPAR)) From OBJDIV
  [M:ATY2]PARTYP([M:ATY2]NBRPAR) = 7
  [M:ATY2]PARCLA([M:ATY2]NBRPAR) = ""
  [M:ATY2]PARDIM([M:ATY2]NBRPAR) = 1
  [M:ATY2]PARMOD([M:ATY2]NBRPAR) = 2
  [M:ATY2]PARCLE([M:ATY2]NBRPAR) = 1
  [M:ATY2]NBRPAR +=1
 Endif
Endif

Gosub L_UPDATE_WNBRPAR

Return

######################################################################################
Subprog S_TYPPROSYR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATYP"
PARMSK(2) = ""
Filter [ATYP] Where [F:ATYP]TYPTYP=[M]TYPTYP & ([M]NOLIB<>1 | [F:ATYP]COD='ATYPE0')
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Filter [ATYP]
End

Subprog C_TYPPROSYR(VALEUR)
Variable Char    VALEUR()
 Call CHECK_TYPPROSYR(VALEUR)
 If mkstat : End : Endif
End

Subprog CHECK_TYPPROSYR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [F:ATYP]ATYP0=VALEUR
 If !fstat
  If [F:ATYP]TYPTYP<>[M]TYPTYP
    GMESSAGE=func AFNC.MES2(mess(246,143,1),mess([F:ATYP]TYPTYP,30,1),mess([M]TYPTYP,30,1))
    GERR=1 : mkstat=2
    End
#  Elsif VALEUR="ATYPE0" & [M]NOLIB<>1
#    GMESSAGE=func AFNC.MES1(mess(247,143,1),VALEUR)
#    GERR=1 : mkstat=2
#    End
  Endif
 Endif
Elsif [M]TYPSELSYR<>3
 GMESSAGE=mess(250,143,1)
 GERR=1 : mkstat=2
 End
Endif
End

Subprog AM_TYPPROSYR(VALEUR)
Variable Char    VALEUR()
Read [F:ATYP]ATYP0=VALEUR
If fstat
  Effzo [M:ATY2]PROTYP
Else
  [M:ATY2]PROTYP=[F:ATYP]PROTYP
  Affzo [M:ATY2]PROTYP
Endif
End

######################################################################################
Subprog AS_FMTPROSYR(VALEUR)
Variable Integer VALEUR
If [M]TYPTYP<>7
  GMENLOC(2)=1
  GMENLOC(3)=1
  GMENLOC(6)=1
Endif
If [M]TYPTYP<>1
  GMENLOC(4)=1
  GMENLOC(5)=1
Endif
If [M]TYPTYP=7
 Read [ATYP]ATYP0=[M]TYPPROSYR
 If !fstat
  If [F:ATYP]PROTYP="application/x-time"
   GMENLOC(2) = 1
   GMENLOC(3) = 1
  Else
   GMENLOC(6) = 1
  Endif
 Endif
Endif
End


Subprog C_FMTPROSYR(VALEUR)
Variable Integer VALEUR
Call CHECK_FMTPROSYR(VALEUR)
If mkstat : End : Endif
End

Subprog CHECK_FMTPROSYR(VALEUR)
Variable Integer VALEUR
If ([M]TYPTYP<>7 & find(VALEUR,2,3)) |
&  ([M]TYPTYP<>1 & find(VALEUR,4,5))
  GMESSAGE=func AFNC.MES2(mess(160,143,1),mess(VALEUR,7880,1),mess([M]TYPTYP,30,1))
  GERR=1 : mkstat=2
  End
Endif
End

######################################################################################
Subprog C_SUPFLG(VALEUR)
Variable Integer VALEUR
Local Integer IRUL
[M]SUPFLG=VALEUR
For IRUL=0 To [M:ATY2]NBRRUL-1
 Call CHECK_TYPRUL([M:ATY2]TYPRUL(IRUL))
 If GERR : End : Endif
Next IRUL
End


######################################################################################
Subprog AS_ORDLNK(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If nolign=1
 VALEUR=1000
Elsif nolign>=2
 VALEUR = [M]ORDLNK(nolign-2)+10
Endif
End


######################################################################################

Subprog CHECK_REPDEF(VALEUR,LTYPMSKREP)
Variable Char    VALEUR()
Value Integer LTYPMSKREP

 Local File ASHW [ASW]

 If VALEUR = "" : End : Endif

 Read [ASW]ASW0 = VALEUR
 If fstat
  GMESSAGE = VALEUR-":"-mess(25,126,1) : # Code incorrect
  GERR=1 : mkstat = 2 : End
 Elsif !fstat & [F:ASW]CODCLA<>[M]CODCLA
  GMESSAGE = VALEUR-":"-mess(167,143,1) : # Représentation incompatible avec le type de donnée de cette propriété
  GERR=1 : mkstat = 2 : End
 Elsif !fstat & [F:ASW]TYPMSKREP<>LTYPMSKREP
  GMESSAGE = VALEUR-":"-mess(25,126,1) : # Code incorrect
  GERR=1 : mkstat = 2 : End
 Endif
End


Subprog SEL_REPDEF(VALEUR,LTYPMSKREP)
Variable Char    VALEUR()
Value Integer LTYPMSKREP

 Local Integer NBTEX, CHOI,I
 Local Char    TEX(GLONDES)(1..500,1..5) , TIT(GLONDES)(0..5) , CRITERE(250)
 Local File ASHW [ASW]

 Filter [ASW] Where CODCLA = [M]CODCLA & TYPMSKREP=LTYPMSKREP
 For [ASW]
  NBTEX+= 1
  TEX(NBTEX,1) = [F:ASW]CODREP
  Call TEXTE([F:ASW]INTREP,TEX(NBTEX,2)) From OBJDIV
  TEX(NBTEX,3) = [F:ASW]CODCLA
  TEX(NBTEX,4) = mess([F:ASW]MODULE,14,1)
  TEX(NBTEX,5) = [F:ASW]CODACT
 Next
 Filter [ASW]

 CHOI = 0
 TIT(0)=mess(8,31,1) # Sélection
 TIT(1)=func AMK_TOOL.GET_FIELD_LABEL("ASHW0", "CODREP") # Code représentation
 TIT(2)=func AMK_TOOL.GET_FIELD_LABEL("ASHW0", "AZINTREP") # Intitulé
 TIT(3)=func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODCLA") # Code classe
 TIT(4)=func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "MODULE") # Module
 TIT(5)=func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODACT") # Code activité

 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif

 Close Local File
End

Subprog C_DEFREPDES(VALEUR)
Variable Char    VALEUR()
Call CHECK_REPDEF(VALEUR,1)
End

Subprog S_DEFREPDES(VALEUR)
Variable Char    VALEUR()
Call SEL_REPDEF(VALEUR,1)
End

Subprog C_DEFREPMOB(VALEUR)
Variable Char    VALEUR()
Call CHECK_REPDEF(VALEUR,2)
End

Subprog S_DEFREPMOB(VALEUR)
Variable Char    VALEUR()
Call SEL_REPDEF(VALEUR,2)
End

Subprog C_DEFREPTAB(VALEUR)
Variable Char    VALEUR()
Call CHECK_REPDEF(VALEUR,3)
End

Subprog S_DEFREPTAB(VALEUR)
Variable Char    VALEUR()
Call SEL_REPDEF(VALEUR,3)
End

Subprog AS_PARCLE(VALEUR)
Variable Integer VALEUR
If [M]TYPSELSYR <>2 or [M]CODCLA="" : VALEUR = 1 : mkstat = 2 : End : Endif
Local Char CHAINE(250)
Read [ACLA]ACLA0 = [M:ATY2]CODCLA
If !fstat &  find([F:ACLA]TYPCLA,2)>0
 If [F:ACLA]TYPCLA=2
    # Issue X3-58309 - 2017-11-03 by CCC : read appropriate index (view or table)
    #Read [ATI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
    Read [AVI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
    If !fstat
       CHAINE = [F:AVI]DESCRIPT
    Endif
 Elsif [F:ACLA]TYPCLA=5
    CHAINE = [F:ACLA]KEYINT
 Endif
 If CHAINE <>""
  Gosub L_DEFCLE From SUBACLA
  If !find([M]PARCOD(nolign-1),CLE(1..NBCLE))
   VALEUR = 1 : mkstat = 2
   End
  Endif
 Endif
Endif
End

