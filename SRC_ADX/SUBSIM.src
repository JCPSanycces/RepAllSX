######################################################################
# Documents
$INI_DOC
Raz [M:SIM4]
Default Mask [SIM4]

Local Char    DATPIE(20) : Raz DATPIE
If [F:SPX]STRPER>[0/0/0]
    Case GTYPDBA
        When 1 : DATPIE = format$("D:DD[/]MMM[/]YYYY",[F:SPX]STRPER)
        When 2 : DATPIE = format$("D:YYYYMMDD",[F:SPX]STRPER)
    Endcase
Endif

If filinfo(filpath("FIL","XIEPV",      "fde",SI_DOSSIER),0) >= 0
    [M:SIM4]INTIT([M:SIM4]NBLIG) = mess(1,41,1)    #"Devis Clients"
    [M:SIM4]TRT([M:SIM4]NBLIG) = "SIXSQH"
    [M:SIM4]TBL([M:SIM4]NBLIG) = "XIEPV"
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = "TYPPIE_0='DV' and FLGMAJ_0<>'S'"+string$(DATPIE<>""," and DATPIE_0 >='"+DATPIE+"'")
    [M:SIM4]MES([M:SIM4]NBLIG) = func CALNBENR([M:SIM4]NBLIG)
    [M:SIM4]NBLIG+=1
Endif

If filinfo(filpath("FIL","XIEPV",      "fde",SI_DOSSIER),0) >= 0
