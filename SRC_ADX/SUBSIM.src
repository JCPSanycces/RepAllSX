#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "OUVRE"  : Gosub OUVRE
    When "DEBUT"  : Gosub DEBUT
Endcase
Return

######################################################################
$OUVRE
Gosub SI_CONTEXT From SIXFONCTION

If !clalev([F:SPX]) : Local File =SI_DOSSIER+".SIPARX3"   [SPX] : Endif
If !clalev([F:SPV]) : Local File =SI_DOSSIER+".SIPARVAC"  [SPV] : Endif
If !clalev([F:SVB]) : Local File =SI_DOSSIER+".SIPARVACB" [SVB] : Endif
If !clalev([F:SPJ]) : Local File =SI_DOSSIER+".SIPARJOU"  [SPJ] : Endif

Return

######################################################################
$DEBUT
Read [SPX] First
[M:SIM0] = [F:SPX]

Gosub INI_TC
Gosub INI_DB
Gosub INI_DATA
Gosub INI_DOC
Return


######################################################################
# Compte le nombre d'enregistrement restant à traiter
# et le nombre d'enregistrement à traiter au total
# Le filtre doit être exprimé avec la notation SQL
# car pour des raisons de performance on utilise le "For Form Sql"
######################################################################
Funprog CALNBENR(PIND)
Value Integer PIND
Local Char LMES(30), REQ(255)
Local Char LCRIT(250)
Local Integer OK
LCRIT = [M]FILTRE(PIND)
If [M]TBL(PIND)=""
    End "Error"
Endif

# Le calcul du nombre d'enregistrements à traiter est particulier pour :
# les tarifs ventes, les tarifs achats, les factures achats, les cours devises et les familles stat
If find([M]TRT(PIND),"SIXSPL","SIXPPL","SIXPIH","SIXTCH","SIXTS")
    Raz OK
    Call EXISTE_ADX(adxmac(0),nomap(0),[M]TRT(PIND),OK) From ORDSYS
    If !OK & nomap(0)<>nomap(1)
        Call EXISTE_ADX(adxmac(0),nomap(1),[M]TRT(PIND),OK) From ORDSYS
    Endif
    If !OK
        LMES = "Traitement"-[M]TRT(PIND)-"inexistant !!"
    Else
        LMES = evalue("func "+[M]TRT(PIND)+".CALNBENR(PIND)")
    Endif
    End LMES
Endif

#--- Nombre d'enregistrements restant à traiter ---#
REQ = "Select count(*) From "+[M]TBL(PIND)+" Where "
If instr(1,[M]TBL(PIND),",")=0
    Case [M]TBL(PIND)
        When "XICLT" : REQ += "FLGREP_0<3 and "
        When Default : REQ += "FLGREP_0<2 and "
    Endcase
Else
    Case [M]TRT(PIND)
        When "SIXSTK" : REQ += "ADP.FLGREP_0<2 and "
    Endcase
Endif
If LCRIT<>""
    REQ += LCRIT
Else
    REQ += "1=1"
Endif

For (Integer NBENR) From func SUBSIP.TYPBAS Sql REQ As [XNB]
    LMES = num$(num$([XNB]NBENR))
    [M]NB2TRT(PIND) = [XNB]NBENR
Next

LMES += " / "

#--- Nombre d'enregistrements à traiter au total ---#
REQ = "Select count(*) From "+[M]TBL(PIND)
If LCRIT<>""
    REQ += " Where "+LCRIT
Endif
For (Integer NBENR) From func SUBSIP.TYPBAS Sql REQ As [XNB]
    LMES += num$(num$([XNB]NBENR))
Next
End LMES


