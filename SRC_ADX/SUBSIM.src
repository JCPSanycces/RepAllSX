    [M:SIM4]TRT([M:SIM4]NBLIG) = "SIXGAS"
    [M:SIM4]TBL([M:SIM4]NBLIG) = "XIHISCBGNR"
    Local Char    DATANV(20)              : # Date de l'A-nouveaux à reprendre (le premier)
    Local Integer I
    If !clalev([F:XJRN]) : Local File =SI_DOSSIER+".XIJRN"     [XJRN] : Endif  # Journaux comptables
    If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"     [XSOC] : Endif  # Société Intégrale
    If !clalev([F:XSO1]) : Local File =SI_DOSSIER+".XISOCDIV1" [XSO1] : Endif  # Société Intégrale
    Case GTYPDBA
        When 1 : DATANV = format$("D:DD[/]MMM[/]YYYY",[F:SPX]STRPER)
        When 2 : DATANV = format$("D:YYYYMMDD",[F:SPX]STRPER)
    Endcase
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = "NUMECR_0<>0" : # NUMECR_0<>0 pour virer l'enreg vide....
    If [F:SPX]STRPER<>[0/0/0]
     [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and (X3DAT_0='"+[L]DATANV+"' or (X3DAT_0>'"+[L]DATANV+"' and ORGECR_0<>'A' and ORGECR_0<>'H' and ORGECR_0<>'Q'))"
    Endif
    [M:SIM4]MES([M:SIM4]NBLIG) = func CALNBENR([M:SIM4]NBLIG)
    [M:SIM4]NBLIG+=1
Endif
    
If filinfo(filpath("FIL","XIBROCBGNR",      "fde",SI_DOSSIER),0) >= 0
    [M:SIM4]INTIT([M:SIM4]NBLIG) = SI_MES(199) : # "Brouillard général et analytique"
    [M:SIM4]TRT([M:SIM4]NBLIG) = "SIXGASB"
    [M:SIM4]TBL([M:SIM4]NBLIG) = "XIBROCBGNR"
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = ""
    [M:SIM4]MES([M:SIM4]NBLIG) = func CALNBENR([M:SIM4]NBLIG) 
    [M:SIM4]NBLIG+=1
Endif

If [F:SPX]OPTANA=2 & filinfo(filpath("FIL","XIHISANA",      "fde",SI_DOSSIER),0) >= 0
    [M:SIM4]INTIT([M:SIM4]NBLIG) = SI_MES(196) : # "Historique analytique"
    [M:SIM4]TRT([M:SIM4]NBLIG) = "SIXGASA"
    [M:SIM4]TBL([M:SIM4]NBLIG) = "XIHISANA"
    If !clalev([F:XJRN]) : Local File =SI_DOSSIER+".XIJRN"     [XJRN] : Endif  # Journaux comptables
    Local Char    DATANV(20)              : # Date de l'A-nouveaux à reprendre (le premier)
    Local Integer I
    Local Integer NBJOUANA
    Local Char    TJOUANA(10)(1..10)
    Raz NBJOUANA, TJOUANA
    Case GTYPDBA
        When 1 : DATANV = format$("D:DD[/]MMM[/]YYYY",[F:SPX]STRPER)
        When 2 : DATANV = format$("D:YYYYMMDD",[F:SPX]STRPER)
    Endcase
    For [XJRN]IND0 Where TYPJRN='L'
     NBJOUANA += 1
     TJOUANA(NBJOUANA) = [F:XJRN]CODJRN
    Next
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = ""
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = "1=1"
    If [F:SPX]STRPER<>[0/0/0]
     For I=1 To NBJOUANA
      If I=NBJOUANA
       [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and CODJRN_0='"+TJOUANA(I)+"'" 
      Else
       [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and CODJRN_0='"+TJOUANA(I)+"'" 
      Endif
     Next
     [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and (X3DAT_0='"+[L]DATANV+"' or (X3DAT_0>'"+[L]DATANV+"'and X3CAT_0=1))"
    Endif
    [M:SIM4]MES([M:SIM4]NBLIG) = func CALNBENR([M:SIM4]NBLIG) 
    [M:SIM4]NBLIG+=1
Endif
    
If [F:SPX]OPTANA=2 & filinfo(filpath("FIL","XIBROCBANA",      "fde",SI_DOSSIER),0) >= 0

    [M:SIM4]INTIT([M:SIM4]NBLIG) = SI_MES(197) : # "Brouillard analytique"
    [M:SIM4]TRT([M:SIM4]NBLIG) = "SIXGASBA"
    [M:SIM4]TBL([M:SIM4]NBLIG) = "XIBROCBANA"
    [M:SIM4]FILTRE([M:SIM4]NBLIG) = "1=1"
    If [F:SPX]STRPER<>[0/0/0]
     For I=1 To NBJOUANA
      If I=NBJOUANA
       [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and CODJRN_0='"+TJOUANA(I)+"'" 
      Else
       [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and CODJRN_0='"+TJOUANA(I)+"'" 
      Endif
     Next
     [M:SIM4]FILTRE([M:SIM4]NBLIG) += " and (X3DAT_0='"+[L]DATANV+"' or (X3DAT_0>'"+[L]DATANV+"'and X3CAT_0=1))"
    Endif
    [M:SIM4]MES([M:SIM4]NBLIG) = func CALNBENR([M:SIM4]NBLIG) 
    [M:SIM4]NBLIG+=1
Endif
    
Affzo [M:SIM4]

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SIMIG1) 05/03/2007 11:24:10 (CCC)
######################################################################################
Subprog CL_EXEC(VALEUR)
Variable Char    VALEUR()

Local Integer I, LRET
Local Char    LMSG(250)
Global Integer X_NB, X_TIME
Local Char LMSKDEF(10)

LMSKDEF = func STKLIB.MSKDEF

Local Char LTIT(100)
LTIT = SI_MES(94)-"("
Raz X_NB
For I=0 To evalue(LMSKDEF+"NBLIG")-1
    If evalue(LMSKDEF+"VALID(I)") = 2
        LTIT += string$(X_NB>0,", ")+evalue(LMSKDEF+"INTIT(I)")
        X_NB+=1
    Endif
    If len(LTIT)>99
        LTIT=left$(LTIT,96)+"..."
        Break
    Endif
Next
LTIT=left$(LTIT,99)+")"

Call OUVRE_TRACE(LTIT) From LECFIC

If LMSKDEF = "[SIM4]"    # Documents
    #----- Vérification cohérence nbre d'axes définis dans "Intégrale" et code activité ANA -----#
    Call VARGLOBANA(LMSG,LRET) From SIXGAS
    If LRET>0
        Call ECR_TRACE(LMSG,1) From GESECRAN
    Endif
Endif

If LMSKDEF = "[SIM1]"    # Tables communes
    #----- Vérification cohérence de la date de début d'exercice -----#
    Call CTL_STRPER(LMSG,LRET) From SIXCPY
    If LRET>0
     Call ECR_TRACE(LMSG,1) From GESECRAN
    Endif
Endif

If !LRET
 SI_SIMU=evalue(LMSKDEF+"SIMFLG")
 For I=0 To evalue(LMSKDEF+"NBLIG")-1
    If evalue(LMSKDEF+"VALID(I)") = 2
        Call ECR_TRACE("*********"-evalue(LMSKDEF+"TBL(I)")-evalue(LMSKDEF+"TRT(I)")-"*********",0) From GESECRAN
        If evalue(LMSKDEF+"NB2TRT(I)")>0
            Call OUVRE_BOITE(evalue(LMSKDEF+"TBL(I)")-num$(evalue(LMSKDEF+"NB2TRT(I)")),evalue(LMSKDEF+"NB2TRT(I)")) From GESECRAN
        Endif
        Raz X_NB, X_TIME
        Call EXEC From =evalue(LMSKDEF+"TRT(I)")
        GIMPORT=0    # Par sécurité
        Default Mask LMSKDEF
        If evalue(LMSKDEF+"NB2TRT(I)")>0
            Call FERME_BOITE From GESECRAN
        Endif
        If evalue(LMSKDEF+"SIMFLG")<>2    # La simulation ne change pas le nombre d'enregistrements restant à traiter
            Assign LMSKDEF+"MES(I)" With func CALNBENR(I)
            Affzo [M]MES(I)
        Endif
    Endif
 Next
Endif

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Kill X_NB, X_TIME

End


######################################################################################
Subprog AFFBOITE(TEXTE)
Value Char TEXTE
Local Integer I
X_NB+=1
If time-X_TIME>1 | time-X_TIME<0
    X_TIME = time
    Call AFF_BOITE([L]TEXTE,X_NB,[L]I) From GESECRAN
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SIMIG4) 07/03/2007 08:52:20 (CCC)
######################################################################################
Subprog B2_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
    [M]VALID(I) = 2
Next
Affzo [M]VALID
End

Subprog B3_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
    [M]VALID(I) = 1
Next
Affzo [M]VALID
End


