#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Composants technique de gestion des correspondant                        Module CRM 10 avril 2006
##########################################################################################################
# DELCOR    : Sous-programme d'annulation d'un correspondant.
##########################################################################################################
Subprog TEST
Local Char SZCORNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  SZCORNUM = "000000000000014"
  Call DELCOR("SUBCORCA", 2, 2, SZCORNUM, LERRCOD) 
  GSYNCOUTLOOK = 0
End

##########################################################################################################
Subprog DELCOR(SZDELCORTRT, ITRACE, ILEC_TRACE, SZCORNUM, LERRCOD) 
Value Char SZDELCORTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char SZCORNUM
Variable Integer LERRCOD

Global Char GSZDELCORTRT
Global Integer GIDELCORTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  IBOPENTRACE = 0
  GSZDELCORTRT = SZDELCORTRT
  GIDELCORTRACE = ITRACE
  If GSZDELCORTRT = "" Then
    GSZDELCORTRT = "SUBCORCA"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Suppression d'un correspondant démarré à partir du contexte : GSZDELCORTRT
      Call OUVRE_TRACE (mess(273,177,1) - GSZDELCORTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif

#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char ACTION(20), ABREV(GLONABR) 
Local Char SAVGABREV(GLONABR)

  #--- declaration et chargement des variables objet 
  ABREV = "COR"
  SAVGABREV = GABREV
  GABREV = "COR"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES"+ABREV     # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION = "AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If !clalev([M:COR0]) : Local Mask COR0 [COR0] : Endif
  If !clalev([M:COR1]) : Local Mask COR1 [COR1] : Endif
  If !clalev([M:COR2]) : Local Mask COR2 [COR2] : Endif
  If !clalev([M:COR3]) : Local Mask COR3 [COR3] : Endif
  If !clalev([M:COR4]) : Local Mask COR4 [COR4] : Endif
  Raz [M:COR0], [M:COR1], [M:COR2], [M:COR3], [M:COR4]
  #--- ouverture des tables necessaires
  If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
  Gosub OUVRE From WOCOR 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOCOR"
  GREP = "A"
  Read [COR]COR0=SZCORNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture du correspondant+" : "+SZCORNUM
    GMESSIMP = "~" + mess(271,177,1) - SZCORNUM  # FGR 22/10/2010 : X3SUIVI68366
    Call ECR_TRACE(mess(271,177,1) - SZCORNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  [M:COR0] = [F:COR]
  [M:COR1] = [F:COR]
  [M:COR2] = [F:COR]
  [M:COR3] = [F:COR]
  [M:COR4] = [F:COR]
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  #------------------------------------------------------------------------  
  # chargement masques enregistrement entête tache
  Default Mask [COR0]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCA") From W0COR0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR1]
  Call SAIMSK("COR1","IMP_ZONE","SUBCORCA") From W0COR1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR1 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR2]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCA") From W0COR2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR2 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR3]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCA") From W0COR3
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR3  mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR4]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCA") From W0COR4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR4 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR4]
  Call SAIMSK("COP","IMP_TAB","SUBCORCA") From W0COR4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR4(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  GPOINT = "MSKUPDCOR" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKUPDCOR mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERF_ANU",0) From GESECRAN
  Endif
  ACTION = "VERF_ANU" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERF_ANU",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  Read [COR]COR0=SZCORNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture du correspondant+" : "+SZCORNUM
    GMESSIMP = "~" + mess(271,177,1) - SZCORNUM  # FGR 22/10/2010 : X3SUIVI68366
    Call ECR_TRACE(mess(271,177,1) - SZCORNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Readlock [COR]Curr
  If fstat <> 0 Then
    #Impossible de locker le correspondant+" : "+SZCORNUM
    GMESSIMP = "~" + mess(327,177,1) - ":" - SZCORNUM  # FGR 22/10/2010 : X3SUIVI68366
    Call ECR_TRACE(mess(327,177,1) - ":" - SZCORNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Raz [F:COR]
  Default File [F:COR]
  [F:COR] = [M:COR0]
  [F:COR] = [M:COR1]
  [F:COR] = [M:COR2]
  [F:COR] = [M:COR3]
  [F:COR] = [M:COR4]
  [F:COR]UPDUSR = GUSER
  [F:COR]UPDDAT = date$
  If ITRACE > 1 Then
    #Suppression [F:COR]  -  CORNUM=[F:COR]CORNUM
    Call ECR_TRACE(mess(274,177,1) - [F:COR]CORNUM,0) From GESECRAN
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [COR]
  Endif
  Delete [F:COR] Where [F:COR]CORNUM = SZCORNUM
  If fstat Then
    LERRCOD = 9
    GOK = 0
    Call FSTA("COR") From GLOCK
    #Erreur lors de la suppression du correspondant+" : "+SZCORNUM
    GMESSIMP = "~" + mess(283,177,1) - SZCORNUM  # FGR 22/10/2010 : X3SUIVI68366
    Call ECR_TRACE(mess(283,177,1) - SZCORNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=ANNULE",0) From GESECRAN
  Endif
  ACTION = "ANNULE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR ANNULE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE Then
    #"[F:COR] - CORNUM="+[F:COR]CORNUM+"  " supprimé
    Call ECR_TRACE("[F:COR] - CORNUM=" + [F:COR]CORNUM + "  " + mess(377,177,1),0) From GESECRAN
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AP_ANNULE",0) From GESECRAN
  Endif
  ACTION = "AP_ANNULE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR AP_ANNULE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  # FGR 06/04/2011 : X3SUIVI72587 : Restauration Gestion des autorisations
  Call AUTORIS From EXEFNC
  Kill GSZDELCORTRT 
  Kill GIDELCORTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If  evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GIDELCORTRACE > 1 Then
    Call ECR_TRACE("ACTION = " + ACTION - "IMPZON=" + IMPZON - "XOK=" + num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE
      Call ECR_TRACE("    " - mess(369,177,1) - ":" - SZVALBEFORE,0) From GESECRAN 
    Endif
  Endif
  Case ACTION 
     When "IMP_ZONE" : Gosub COR_SET_HEA_INFO From=GSZDELCORTRT
     When "IMP_TAB"  : Gosub COR_SET_DET_INFO From=GSZDELCORTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER = num$(evalue("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GIDELCORTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    " + mess(370,177,1) - ":" - SZVALAFTER,0) From GESECRAN 
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZDELCORTRT
  Kill GIDELCORTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la modification d'un correspondant. (exemple)
#############################################################################
$COR_SET_HEA_INFO
  Case IMPZON
    When "TTL"
      #Civilité
      [M:COR0]TTL = 1
    When "LNA"
      #Nom
      [M:COR0]LNA = "DUPUIS"
    When "FNA"
      #Prénom
      [M:COR0]FNA = "Jean Jacques"
    When "BPRLIB"
      #Libellé société
      [M:COR2]BPRLIB = "Ma petite société"
    When "FNCLIB"
      #Libellé fonction
      [M:COR2]FNCLIB = "Directeur"
    When "CPYBPADES"
      #Intitullé adresse professionnelle
      [M:COR2]CPYBPADES = "Mon adresse soc"
    When "CPYADD"
      Case indice
        When 0
          #Adresse 1 professionnelle
          [M:COR2]CPYADD(0) = "2 chemin du travail"
        When 1
          #Adresse 2 professionnelle
          [M:COR2]CPYADD(1) = "batiment 5"
        When 2
          #Adresse 3 professionnelle
          [M:COR2]CPYADD(2) = ""
      Endcase
    When "CPYCTY"
      #Ville professionnelle
      [M:COR2]CPYCTY = "Thones"
    When "CPYZIP"
      #Code postal professionnelle
      [M:COR2]CPYZIP = "74200"
    When "CPYCRYNAM"
      #Nom pays professionnelle
      [M:COR2]CPYCRYNAM = "France"
    When "CPYEML"
      #E-MAIL professionnelle
      [M:COR2]CPYEML = "monadresse@boite.fr"
    When "CPYTEL"
      #Téléphone professionnelle
      [M:COR2]CPYTEL = "0102567890"
    When "CPYFAX"
      #Fax professionnelle
      [M:COR2]CPYFAX = "0102567889"
    When "CPYMOB"
      #Portable professionnelle
      [M:COR2]CPYMOB = "0607085023"
  Endcase
Return
