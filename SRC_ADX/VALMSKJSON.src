#<AdxTL>@(#)8.0.0.0 $Revision$
#  VALMSKJSON       : Génération du prototype json d'un écran
# Issue #2599 sam 93375 : Exclusion des champs invisibles sauf si parametre graphic
# clob flash
# application/wid (BI) 17/01/2014
# TYP_BOC=4 (texte) ($editmod:false) 28/01/2014 (regeneration ecrans et fenetre contenant un bloc type texte) 96152
# 06/03/2014 97143 Submit a request - title of the task is missing (Zxxxxxx et xxxxxx)
# 31/03/2014 : white space x-vignette
Local Char MASQUE(GLONAMK),APPLI
Local Char LAN(GLONLAN)(1..5)
Local Integer OK
Local Integer ASPROP
#MASQUE = "ADLV6B"
MASQUE = "AUS1"
#MASQUE = "BPC1"
LAN(1) = "FRA"
APPLI=nomap
GTRACE = ""
#Dbgaff
Call VALID(MASQUE,APPLI,1,LAN,0,OK) From VALMSK
Gosub JSON_VISU
End
#  LIG_ZON(WE_NOBL,1)="EXPEXC"

$JSON
Local Char JSONPROP(250),JSONVALUE(250),JSONSAVE(250),VALL1(250),VALTEMP(250),WE_EXPRESSION(250)
Local Integer NBITEM,NBLAYOUT,NBLL,ECVIRG,LIDX,OPLIGBL,LIGFIX,TOTECR,RGBLOC,NOLIBEL,LIGCOU,NBMM,NBCOLFIX
Local Integer WE_ISRC,WE_SEL,WE_TUN,WE_ICO,NBL,WE_BLCRG(1..50),RIGHTCLICDONE,WE_V1,ISEXPEXC,WE_V2,WE_V3,WE_V4,WE_ISEXCLUD
Gosub JSON_INITLOC From VALWINJSON : HLOCAL="S-"+MASQUE+"-"


# Ouverture du fichier json
Call NAMEFIC(APPLI,"SCRNJ","",MASQUE,WE_NOMFIC) From INTRUTILA
Openo WE_NOMFIC,0 Using [JSO_]
Iomode adxifs "" Using [JSO_]
Iomode adxirs chr$(10) Using [JSO_]
Iomode adxium GUTF8 Using [JSO_]

# Ecriture entête
Wrseq'{'  Using [JSO_]

# Ecriture champs
Wrseq'"$properties": {'  Using [JSO_]
Gosub FIELDDESC
If TOTECR>0
  Wrseq "},"  Using [JSO_]
Else
  Wrseq ","  Using [JSO_]
Endif


# Ecriture Layout
Gosub LAYOUTJSON

# Ecritures des localisations
Gosub JSON_LOCALIZ From VALWINJSON
Gosub JSON_HLOCALIZMSK
Gosub JSON_HBLOCRANKMSK



# Fermeture fichier
Wrseq "}"  Using [JSO_]
Openo Using [JSO_]


Return


$JSON_HBLOCRANKMSK
  Wrseq ',"$hackBlockRank": {' Using [JSO_]
  VALL1="dummy"
  Wrseq '"dummy_$x$": "dummy"'  Using [JSO_]
  If(IRANK > 0)
    Gosub JSON_HBLOCRANKCONTENT From VALWINJSON
  Endif
  Wrseq '}' Using [JSO_]
Return

$JSON_HLOCALIZMSK
  Wrseq ',"$hackLocalization": {' Using [JSO_]
  VALL1="dummy"
  Wrseq '"dummy_$x$": "dummy"'  Using [JSO_]
  Gosub JSON_HLOCALIZCONTENT From VALWINJSON
  Wrseq '}' Using [JSO_]
Return


$FIELDDESC
#  On écrit tous les champs visibles et les champs invisibles transmis
#  On affecte l'ID champ à chaque champ qui sera retraité par le programme d'assemblage

#If(GUSER="LV")
#  Call ECR_TRACE("-------------$FIELDDESC--------------",0) From GESECRAN
#  Call ECR_TRACE("   BLC_TYP BLC_RNG BLC_RRX BLC_RRR WE_BLCR",0) From GESECRAN
#  For WE_J=1 To BLC_NBR
#   TR=""
#   TR+=num$(WE_J) + space$(3-len(num$(WE_J)))
#   TR+=num$(BLC_TYP(WE_J)) + space$(8-len(num$(BLC_TYP(WE_J))))
#   TR+=num$(BLC_RNG(WE_J)) + space$(8-len(num$(BLC_RNG(WE_J))))
#   TR+=num$(BLC_RRX(WE_J)) + space$(8-len(num$(BLC_RRX(WE_J))))
#   TR+=num$(BLC_RRR(WE_J)) + space$(8-len(num$(BLC_RRR(WE_J))))
#   TR+=num$(WE_BLCR(WE_J)) + space$(8-len(num$(WE_BLCR(WE_J))))
#   Call ECR_TRACE(TR,0) From GESECRAN
#  Next WE_J
#Endif


For WE_J=1 To BLC_NBR
 WE_NOBL=find(WE_BLCR(WE_J),BLC_RNG(1..BLC_NBR))
 ASPROP=1
 LIGFIX=0
 If BLC_INV(WE_NOBL)<>1
   RGBLOC+=1
   WE_BLCRG(WE_NOBL)=RGBLOC
   If BLC_TYP(WE_NOBL)=1

     ASPROP=func ASPROPERTIES(WE_NOBL,LIG_NBR(WE_NOBL),LIG_SAI,BLC_BAS(WE_NOBL),LIG_ZON)
     If(ASPROP=1)
       If NBLL>=1 : Wrseq "}," Using [JSO_] : NBLL=0 : Endif
       TOTECR+=1
       Wrseq '"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+'": {' Using [JSO_]
       JSONPROP="$type" : JSONVALUE="application/x-array" : Gosub ADDJSONPROPV
       WE_NTEXKEY="ARRAY_"+BLC_BAS(WE_NOBL)
       JSONPROP="$X3Name" :  JSONVALUE=ECRAN+"_"+WE_NTEXKEY : Gosub ADDJSONPROPV
       JSONVALUE="sort"
       If instr(1,BLC_OPT(WE_NOBL),"I")>0 : JSONVALUE+=",insert" : Endif
       If instr(1,BLC_OPT(WE_NOBL),"A")>0 : JSONVALUE+=",delete" : Endif
       If instr(1,BLC_OPT(WE_NOBL),"D")>0 : JSONVALUE+=",deleteAll" : Endif
       If (instr(1,BLC_OPT(WE_NOBL),"B") and instr(1,BLC_OPT(WE_NOBL),"C") >0) : JSONVALUE+=",copy" : Endif
       JSONVALUE+=",search"
       JSONPROP="$capabilities"  :  Gosub ADDJSONPROPV


        # S'il y a un menu contextuel on renseigne lazyload
       For WE_F=1 To LIG_NBR(WE_NOBL)
         If BLC_BAS(WE_NOBL)=LIG_ZON(WE_NOBL,WE_F)
           Break 1
         Endif
       Next WE_F
       Gosub WE_ISRCLIC From VALMSKWEB
       If LIG_SAI(WE_NOBL,WE_F)=2 # display only gird could not take focus -> no context menu
          JSONVALUE+="true"
         JSONPROP="$isReadOnly" : JSONVALUE="true" : Gosub ADDJSONPROPV
        WE_ISRC=0
       Endif
       If WE_ISRC=1
          Wrseq '"$links": {' Using [JSO_]
          Wrseq '"$lazyload": {} },' Using [JSO_]
       Endif
       Wrseq '"$item": {' Using [JSO_]
       If WE_ISRC=1
         Wrseq '"$links": {' Using [JSO_]
         Wrseq '"$lazyload": {}  },' Using [JSO_]
       Endif

       Wrseq '"$properties": {' Using [JSO_]
       For II=1 To len(BLC_OPT(WE_NOBL))
         If val(mid$(BLC_OPT(WE_NOBL),II,1))>0
           LIGFIX=val(mid$(BLC_OPT(WE_NOBL),II,1))
           Break 1
         Endif
       Next II
    Endif
   Endif
   Gosub ECRCHPBLOC
   If BLC_TYP(WE_NOBL)=1 and ASPROP=1
     If NBLL>0
       Wrseq '}}}' Using [JSO_]
     Else
       Wrseq '}}' Using [JSO_]
     Endif
   Endif

#    Insertion graphique
     If BLC_TYPT(WE_NOBL)>1  and BLC_TYPG(WE_NOBL)>=1 and BLC_TYPG(WE_NOBL)<=5
       Gosub GRAPHIC From VALMSKGRAPH
     Endif
 Endif

Next WE_J
Wrseq "}"  Using [JSO_]
Return


#  Tenir compte des champs invisibles
#

$ECRCHPBLOC
NBCOLFIX=0
If BLC_TYP(WE_NOBL)=1
  Gosub NBCOLFIX    : # Récupère le nombre de colonnes fixes du tableau
Endif
 For WE_F=1 To LIG_NBR(WE_NOBL)
  WE_ISEXCLUD=0
  # WE_NTEXKEY=""
  # zone invisible et pas lib de ref et pas dans tableau mappé graphique
  If LIG_SAI(WE_NOBL,WE_F)>2
    If BLC_TYPT(WE_NOBL)<2
      Goto END_WE_F  # tableau carractere
    Else
        # tableau + graphic exclusion uniquement si pas utilisée dans graphic.
      If(LIG_TRG(WE_NOBL,WE_F)="")
        Goto END_WE_F
      Else
        WE_ISEXCLUD=1
      Endif
    Endif
  Endif
  If LIG_IDX(WE_NOBL,WE_F)<>0 and (BLC_TYP(WE_NOBL)<>1 or BLC_BAS(WE_NOBL)<>LIG_ZON(WE_NOBL,WE_F))
    If NBLL>=1 :     Wrseq "},"  Using [JSO_] : Endif
    NBLL+=1
    TOTECR+=1
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    Wrseq '"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'": {' Using [JSO_]
    Case LIG_TYI(WE_NOBL,WE_F)
      When 1       : If LIG_LIB(WE_NOBL,WE_F)>0
                       If LIG_LIB(WE_NOBL,WE_F)=1
                         If LIG_GRA(WE_NOBL,WE_F) = 2
                          JSONVALUE="application/x-boolean"   : # Menu local
                         Else
                          JSONVALUE="application/x-choice"
                         Endif
                       Else
                         JSONVALUE="application/x-choice"   : # Menu local
                       Endif
                     Else
                       JSONVALUE="application/x-integer"  : # Integer
                     Endif
      When 2,3     : JSONVALUE="application/x-integer"    : # Entier court et long
      When 4       : JSONVALUE="application/x-decimal"    : # Décimal
      When 5       : JSONVALUE="application/x-real"       : # Flottant
      When 6       : JSONVALUE="application/x-real"       : # Double
      When 7       : JSONVALUE="application/x-string"     : # Alphanumérique
      When 8       : JSONVALUE="application/x-date"       : # Date
      When 9       : JSONVALUE="application/octet-stream" : # Blob
                     If  left$(LIG_FTY(WE_NOBL,WE_F),2)="KI"
                        JSONVALUE="image"
                     Endif
      When 10      :
                     JSONVALUE="application/octet-stream" : # Clob
                     If left$(LIG_FTY(WE_NOBL,WE_F),2)="KR"
                       JSONVALUE="text/rtf"
                       If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR2" : JSONVALUE="application/x-string" : Endif
                     Endif
                     If BLC_TYP(WE_NOBL)=8 #browser
                        JSONVALUE="application/x-vignette"
                     Endif
                     If BLC_TYP(WE_NOBL)=9
                       JSONVALUE="text/html"
                     Endif
                     If BLC_TYP(WE_NOBL)=11
                       JSONVALUE="application/wid"
                     Endif
                     If BLC_TYP(WE_NOBL)=6
                       JSONVALUE="application/x-shockwave-flash"
                     Endif

      When Default : JSONVALUE="application/x-string"
     Endcase
     If LIG_TYP(WE_NOBL,WE_F)="ATX"      : #  Pour traiter cas particulier des textes
       JSONVALUE="application/x-string"
     Elsif LIG_GRA(WE_NOBL,WE_F) = 13   : #  Pour traiter cas particulier des icônes
       JSONVALUE="application/x-icon"
     Endif
     If instr(1,LIG_OPT(WE_NOBL,WE_F),"X")<>0 : JSONVALUE="application/x-password" : Endif
   # If BLC_TYP(WE_NOBL)=2 and LIG_ZON(WE_NOBL,WE_F+1)="Z"+LIG_ZON(WE_NOBL,WE_F) and LIG_SAI(WE_NOBL,WE_F+1)<=2
    If BLC_TYP(WE_NOBL)=2 and LIG_LIE(WE_NOBL,WE_F)>1 and LIG_SAI(WE_NOBL,WE_F+1)<=2
      JSONSAVE=JSONVALUE
      JSONVALUE="application/x-reference"
    Endif

    If LIG_ZON(WE_NOBL,WE_F)="EXPEXC" and MASQUE="AEXP8" : ISEXPEXC=1 : Endif
    If ISEXPEXC=1 : JSONVALUE="application/x-document" : Endif
    JSONPROP="$type"  : Gosub ADDJSONPROPV
    #118962 121578
    If((LIG_TYI(WE_NOBL,WE_F)=10 or LIG_TYI(WE_NOBL,WE_F)=7) and (left$(LIG_FTY(WE_NOBL,WE_F),3)="KR2" or LIG_FLI(WE_NOBL,WE_F)>1))
        JSONPROP="$rows" : JSONVALUE=num$(LIG_FLI(WE_NOBL,WE_F)) : Gosub ADDJSONPROPNV
     Endif
    VALL1=""
    If WE_F>1
      VALL1=LIG_ZON(WE_NOBL,WE_F-1)
    Endif
    JSONVALUE=func ISEDITMODE(LIG_OPT(WE_NOBL,WE_F),LIG_SAI(WE_NOBL,WE_F),BLC_TYP(WE_NOBL),LIG_ZON(WE_NOBL,WE_F),VALL1,LIG_GRA(WE_NOBL,WE_F))
    If JSONVALUE<>""
      JSONPROP="$isEditMode"  : Gosub ADDJSONPROPV
    Endif
    If BLC_TYP(WE_NOBL)=1
       JSONVALUE=func VIEWSCOPE(LIG_MOD(WE_NOBL,WE_F))
       JSONPROP="$viewScope"  : Gosub ADDJSONPROPV
    Endif
    If NBCOLFIX<>0 and NBLL<=NBCOLFIX
      JSONPROP="$isFixed" : JSONVALUE="true" : Gosub ADDJSONPROPV
    Endif

   # If BLC_TYP(WE_NOBL)=1
   #   Case LIG_MOD(WE_NOBL,WE_F)
   #     When 1  : JSONVALUE="both"
   #     When 2  : JSONVALUE="card"
   #     When 3  : JSONVALUE="table"
   #   Endcase
   #   JSONPROP="$displayStatus" : Gosub ADDJSONPROPV
   # Endif

    If ISEXPEXC=1
      JSONPROP="$contentType" : JSONVALUE="application/x-exportxls" : Gosub ADDJSONPROPV : ISEXPEXC=0
    Endif
    If LIG_GRA(WE_NOBL,WE_F)=8      :#   Progress bar
      JSONPROP="$mode" : JSONVALUE="progress" : Gosub ADDJSONPROPV
    Endif
    RIGHTCLICDONE=0
    #If BLC_TYP(WE_NOBL)=2 and LIG_ZON(WE_NOBL,WE_F+1)="Z"+LIG_ZON(WE_NOBL,WE_F) and LIG_SAI(WE_NOBL,WE_F+1)<=2
    If BLC_TYP(WE_NOBL)=2 and LIG_LIE(WE_NOBL,WE_F)>1 and LIG_SAI(WE_NOBL,WE_F+1)<=2
      Wrseq'"$item": {'  Using [JSO_]

#      On inclut le type pour les champs références
     # If JSONVALUE="application/x-reference"
        JSONPROP="$value" : JSONVALUE="{code}" : Gosub ADDJSONPROPV
        JSONPROP="$key" : JSONVALUE="{code}" : Gosub ADDJSONPROPV
      #Endif

      Wrseq '"$properties" : {'   Using [JSO_]
      Wrseq '"code" : {'   Using [JSO_]
      Gosub ADDCHPFORMJ
      JSONPROP="$type"  : JSONVALUE=JSONSAVE : Gosub ADDJSONPROP
      Wrseq '},'  Using [JSO_]
#  ajout descriptif lien
      Wrseq   '"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX+1)+'":{'    Using [JSO_]
      WE_F+=1 : Gosub ADDCHPFORMJ : WE_F-=1
      JSONPROP="$type"  : JSONVALUE="application/x-string" : Gosub ADDJSONPROP
      Wrseq '}},'  Using [JSO_]

#
      VALL1= '"$title" : "{$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX+1)+'}"'
      Gosub WE_ISRCLICJSON
      If LIG_SAI(WE_NOBL,WE_F)=1 and (WE_ISRC>=1 or WE_SEL=1 or WE_TUN=1)
        VALL1+=","
        Wrseq VALL1  Using [JSO_]
        RIGHTCLICDONE=1
        Gosub SETRIGHTCLIC
      Else
        Wrseq VALL1  Using [JSO_]
      Endif
     Wrseq "},"  Using [JSO_]
    Endif
    If left$(LIG_FTY(WE_NOBL,WE_F),2)="KI"
      JSONPROP="$url"  : JSONVALUE="" : Gosub ADDJSONPROPV
    Endif
    JSONPROP="$X3Name" : JSONVALUE=ECRAN+"_"+LIG_ZON(WE_NOBL,WE_F)
    WE_NTEXKEY="F_"+JSONVALUE
    If BLC_TYP(WE_NOBL)=2 and LIG_DIM(WE_NOBL,WE_F)>1
      JSONVALUE+="_"+num$(max(1,LIG_DUP(WE_NOBL,WE_F)))
      WE_NTEXKEY+="_"+num$(max(1,LIG_DUP(WE_NOBL,WE_F)))
    Endif
    Gosub ADDJSONPROPV
    If BLC_TYP(WE_NOBL)=2 and LIG_DIM(WE_NOBL,WE_F)>1
      JSONPROP="$X3group" : JSONVALUE=ECRAN+"_"+LIG_ZON(WE_NOBL,WE_F)
      Gosub ADDJSONPROPV
    Endif
    If(LIG_AID(WE_NOBL,WE_F)<>"" and LIG_AID(WE_NOBL,WE_F)<>"ANONE"  and WE_ISEXCLUD<>1)
     JSONPROP="$keyword" : JSONVALUE=LIG_AID(WE_NOBL,WE_F)
     Gosub ADDJSONPROPV
    Endif
    If(WE_ISEXCLUD=1)
      JSONPROP="$isExcluded" : JSONVALUE="true"   : Gosub ADDJSONPROPV
    Endif
    If LIG_STY(WE_NOBL,WE_F)<>"" or LIG_STZ(WE_NOBL,WE_F)<>""
      If LIG_STY(WE_NOBL,WE_F)=LIG_STZ(WE_NOBL,WE_F)
        JSONPROP="$fieldStyle" : JSONVALUE=LIG_STY(WE_NOBL,WE_F)   : Gosub ADDJSONPROPV
      Else
        If LIG_STZ(WE_NOBL,WE_F)<>""
          JSONPROP="$valueStyle" : JSONVALUE=LIG_STZ(WE_NOBL,WE_F) : Gosub ADDJSONPROPV
        Endif
        If LIG_STY(WE_NOBL,WE_F)<>""
          JSONPROP="$titleStyle" : JSONVALUE=LIG_STY(WE_NOBL,WE_F) : Gosub ADDJSONPROPV
        Endif
      Endif
    Endif


If RIGHTCLICDONE=0
  Gosub SETRIGHTCLIC
Endif
# Intitulé du champ
#  On ne met pas le titre pour les champs en fond d'écran "W" ni sur les champs occursés en bloc liste
    NOLIBEL=0
    If BLC_TYP(WE_NOBL)=2 and LIG_DIM(WE_NOBL,WE_F)>1 and LIG_DUP(WE_NOBL,WE_F)>0
#  sauf si intitulé occursé
      If LIG_EVL(WE_NOBL,WE_F)="" or left$(LIG_EVL(WE_NOBL,WE_F),1)<>"#" or instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")=0
        NOLIBEL=1
      Endif
   Endif

    If NOLIBEL=0 : ####     Pour écrire libellé même si option W
#   If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")=0 and NOLIBEL=0
      WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) :  WE_LCH=WE_IND(WE_I)
      WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0
    If WE_NTEX=0 and  left$(LIG_EVL(WE_NOBL,WE_F),1)="#"
      If instr(1,WE_INTEV,"mess")>0 #113641
          WE_V1=instr(1,WE_INTEV,",")
          Local Char NOMESC : NOMESC=mid$(WE_INTEV,WE_V1+1,instr(WE_V1+1,WE_INTEV,",")-WE_V1)
          WE_V2=instr(1,LIG_EVL(WE_NOBL,WE_F),")")
          If instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")>0 and instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")<WE_V2
            # Fix sam 110105
            WE_V3=instr(1,LIG_EVL(WE_NOBL,WE_F),"(")
            WE_EXPRESSION= mid$(LIG_EVL(WE_NOBL,WE_F),WE_V3+1,instr(WE_V3,LIG_EVL(WE_NOBL,WE_F),",")-WE_V3-1)
            WE_V2=instr(1,WE_EXPRESSION,"indice")
            WE_V4=evalue(left$(WE_EXPRESSION,WE_V2-1)+num$(max(LIG_DUP(WE_NOBL,WE_F)-1,0))+right$(WE_EXPRESSION,WE_V2+6))
            WE_NTEX=-1000*val(NOMESC)- WE_V4
          Else
#  Remplace indice par LIG_DUP(WE_NOBL,WE_F)
            WE_V2=instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")
            If WE_V2>0
              WE_INTEV=left$(WE_INTEV,WE_V2-1)+num$(max(LIG_DUP(WE_NOBL,WE_F)-1,0))+right$(WE_INTEV,WE_V2+6)
            Endif
            WE_NTEX=0
    #        WE_V1=instr(1,WE_INTEV,"(")
    #        NOMESC=mid$(WE_INTEV,WE_V1+1,instr(WE_V1+1,WE_INTEV,",")-WE_V1)
    #        WE_NTEX-=val(NOMESC)
             Endif
#         WE_INTEV=left$(WE_INTEV,instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")-1)+num$(LIG_DUP(WE_NOBL,WE_F)-1)
#&                      +right$(WE_INTEV,instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")+6)
      Else #113641
        WE_NTEX=0
        WE_V2=instr(1,LIG_EVL(WE_NOBL,WE_F),"indice")
        If WE_V2>0
          WE_EXPRESSION=left$(WE_INTEV,WE_V2-1)+num$(max(LIG_DUP(WE_NOBL,WE_F)-1,0))+right$(WE_INTEV,WE_V2+6)
          WE_VALUE=evalue(right$(WE_EXPRESSION,2))
          WE_V3=-99
      Endif
      Endif
      Endif
      If(WE_V3 <> -99)#113641
      Gosub JSON_ADDNLOC From VALWINJSON
      Endif
      JSONPROP="$title" : JSONVALUE=WE_VALUE
      Gosub ADDJSONPROPV
    Endif
     If LIG_AIDBUL(WE_NOBL,WE_F)<>""
          WE_INTEV=LIG_AIDBUL(WE_NOBL,WE_F)
          Gosub JSON_ADDNLOCTOOLTIP From VALWINJSON
          JSONPROP="$tooltip" : JSONVALUE=WE_VALUE
          Gosub ADDJSONPROPV
     Endif
    JSONVALUE=""
    If BLC_TYP(WE_NOBL)=1 and LIGFIX>0 and NBLL<=LIGFIX
       JSONVALUE="frozen,"
    Endif
    If BLC_TYP(WE_NOBL)=1
      JSONVALUE+="sort,"
    Endif
    If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR"
      JSONVALUE+="raw"
    Endif
    If JSONVALUE<>""
      If right$(JSONVALUE,len(JSONVALUE))="," : JSONVALUE=left$(JSONVALUE,len(JSONVALUE)-1) : Endif
      JSONPROP="$capabilities" : Gosub ADDJSONPROPV
    Endif
    If LIG_LIB(WE_NOBL,WE_F)>= 1
      JSONPROP="$mnu" : JSONVALUE=num$(LIG_LIB(WE_NOBL,WE_F)) : Gosub ADDJSONPROPV
      JSONPROP="$format"
      Case LIG_GRA(WE_NOBL,WE_F)
        When 2 : JSONVALUE="$check"
        When 3 : JSONVALUE="$radios"    :#"radioVC"
        When 4 : JSONVALUE="$radios"    :#"radioVS"
        When 5 : JSONVALUE="$radios"    :#"radioHC"
        When 6 : JSONVALUE="$radios"    :#"radioHS"
        When Default : JSONVALUE="$combo"
      Endcase
      Gosub ADDJSONPROPV
    Else
      If LIG_TYI(WE_NOBL,WE_F)=10 and BLC_TYP(WE_NOBL)=6 #CLOB FLASH
        JSONPROP="$format": JSONVALUE="$safeV1" : Gosub ADDJSONPROPV
      Endif
      If LIG_TYI(WE_NOBL,WE_F)=10 and BLC_TYP(WE_NOBL)=8 #Clob browser
        JSONPROP="$format": JSONVALUE="$dhtml" : Gosub ADDJSONPROPV
        Gosub SECLEVEL From VALMSKGRAPH
     Endif
    Endif
    If( JSONVALUE="$combo")
       JSONPROP="$isAutoComplete" : JSONVALUE="false" : Gosub ADDJSONPROPV
    Endif
    If LIG_OBL(WE_NOBL,WE_F)=2
       JSONPROP="$isMandatory" : JSONVALUE="true" : Gosub ADDJSONPROPV
    Endif
    #X3-91078
    If LIG_MAS(WE_NOBL,WE_F)=2
       JSONPROP="$isMaskable" : JSONVALUE="true" : Gosub ADDJSONPROPV
    Endif
    ###
    # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
    If LIG_BRK(WE_NOBL,WE_F)=2
       JSONPROP="$breakAfter" : JSONVALUE="true" : Gosub ADDJSONPROPV
    Endif
    # End issue X3-110075
    If LIG_SAI(WE_NOBL,WE_F)=2 and  instr(1,LIG_OPT(WE_NOBL,WE_F),"W")=0 and LIG_GRA(WE_NOBL,WE_F)<>13
      JSONPROP="$isReadOnly" : JSONVALUE="true" : Gosub ADDJSONPROPV
  #  Elsif LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2
  #    JSONPROP="$isHidden" : JSONVALUE="true" : Gosub ADDJSONPROPV
  #JMK et pourquoi pas ...
  #exclusion des lib de champs ref
    Endif
    If  BLC_TYP(WE_NOBL)=2 and WE_F>1 and LIG_LIE(WE_NOBL,WE_F-1)>1
       JSONPROP="$isExcluded" : JSONVALUE="true" : Gosub ADDJSONPROPV
    Endif

#   On met provisoirement hidden les champs qui sont en mode fiche seulement
#    If BLC_TYP(WE_NOBL)=1 and LIG_MOD(WE_NOBL,WE_F)=2
#      JSONPROP="$isHidden" : JSONVALUE="true" : Gosub ADDJSONPROPV
#    Endif


    Gosub ADDCHPFORMJ


#    If LIG_GRA(WE_NOBL,WE_F)=13 and LIG_SAI(WE_NOBL,WE_F)=2
#      JSONPROP="$isDisabled" : JSONVALUE="true" : Gosub ADDJSONPROPV
#    Endif
    If LIG_LNG(WE_NOBL,WE_F)<>0
 #    Wrseq '"$constraints": {' Using [JSO_]
     If LIG_LNG(WE_NOBL,WE_F)<>0
       JSONPROP="$maxLength" : JSONVALUE=num$(LIG_LNG(WE_NOBL,WE_F))
#  Pour trouver la longueur si format n.p
       WE_4=LIG_LNG(WE_NOBL,WE_F)
       If WE_4<>LIG_LNG(WE_NOBL,WE_F)
         WE_3=LIG_LNG(WE_NOBL,WE_F)*10-WE_4*10
         WE_4+=WE_3+1
         JSONVALUE=num$(WE_4)
       Endif
       If LIG_TYI(WE_NOBL,WE_F)=10
         JSONVALUE=num$((512*2^LIG_LNG(WE_NOBL,WE_F))-2)
       Elsif LIG_TYI(WE_NOBL,WE_F)=9
          JSONPROP="$maxByteLength"
         JSONVALUE=num$((1024*2^LIG_LNG(WE_NOBL,WE_F))-2)
       Endif
       Gosub ADDJSONPROPNV
     Endif
 #    Wrseq '},' Using [JSO_]
     If LIG_LGR(WE_NOBL,WE_F)<>0 and LIG_LGR(WE_NOBL,WE_F)<>LIG_LNG(WE_NOBL,WE_F)
       JSONPROP="$displayLength" : JSONVALUE=num$(LIG_LGR(WE_NOBL,WE_F))
       Gosub ADDJSONPROPNV
     Endif

    Endif
#JMK
#     If BLC_TYP(WE_NOBL)=2 and LIG_ZON(WE_NOBL,WE_F)="Z"+LIG_ZON(WE_NOBL,WE_F-1)
#     If BLC_TYP(WE_NOBL)=2 and WE_F > 1 and LIG_ZON(WE_NOBL,WE_F)="Z"+LIG_ZON(WE_NOBL,WE_F-1)
#      JSONPROP="$isExcluded" : JSONVALUE="true" : Gosub ADDJSONPROPNV
#    Endif
   JSONPROP="$groupName" : JSONVALUE=mid$(WE_ALPHAB,RGBLOC,1) : Gosub ADDJSONPROP

   Endif

  $END_WE_F
  Next WE_F

  Return


$ADDCHPFORMJ
    If left$(LIG_FMT(WE_NOBL,WE_F),1)<>"="
      JSONVALUE=LIG_FMT(WE_NOBL,WE_F)
      If LIG_FMT(WE_NOBL,WE_F)="" and left$(LIG_FTY(WE_NOBL,WE_F),1)<>"="
        JSONVALUE=LIG_FTY(WE_NOBL,WE_F)+LIG_FOP(WE_NOBL,WE_F)+":"+LIG_FCH(WE_NOBL,WE_F)
        If JSONVALUE=":" : JSONVALUE="" : Endif
      Endif
      If JSONVALUE="" and LIG_FNU(WE_NOBL,WE_F)=TABLO
        JSONVALUE="N:4#"
        If BLC_LIG(WE_NOBL)>=10000 : JSONVALUE="N:5#" : Endif
      Endif
      If JSONVALUE<>""
        JSONPROP="$X3Fmt"  : Gosub ADDJSONPROPV
      Endif
    Endif
Return




$SETRIGHTCLIC
# Manage the right click
    Gosub WE_ISRCLICJSON
    If LIG_SAI(WE_NOBL,WE_F)=1 and (WE_ISRC>=1 or WE_SEL=1 or WE_TUN=1)
      Wrseq '"$links": {' Using [JSO_]
      If WE_SEL=1
        VALTEMP='"$lookup": {'
        #If()
        #VALTEMP='"$act":'+"'??'"
        ##Endif
        VALTEMP+="}"
        If WE_TUN+WE_ISRC>=1
          VALTEMP+=","
        Endif
        Wrseq VALTEMP Using [JSO_]
      Endif
      If WE_TUN=1
        If WE_ISRC>=1
          Wrseq '"$tunnel": {},' Using [JSO_]
        Else
          Wrseq '"$tunnel": {}' Using [JSO_]
        Endif
      Endif
      If WE_ISRC>=1
        Wrseq '"$lazyload": {}' Using [JSO_]
      Endif
      If RIGHTCLICDONE=1
        Wrseq ' }' Using [JSO_]
      Else
        Wrseq ' },' Using [JSO_]
      Endif
    Endif

    If LIG_GRA(WE_NOBL,WE_F) = 13 and WE_ICO=1
       Wrseq '"$links": {},' Using [JSO_]
    Endif
Return

$WE_ISRCLICJSON:
  WE_ISRC=0  :  WE_SEL=0  : WE_TUN=0 : WE_ICO=0
  If LIG_ACT(WE_NOBL,WE_F)=0 : Return : Endif
  For WE_AC=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
    If (ACT_TYP(WE_AC) >= 8 and ACT_TYP(WE_AC)<=12) or (ACT_TYP(WE_AC)>=15 and ACT_TYP(WE_AC)<=30) or
&       ACT_ACT(WE_AC)="%TABSEL" or ACT_ACT(WE_AC)="%SELOBJ" or
&       ACT_ACT(WE_AC)="%SELAVA" or ACT_ACT(WE_AC)="%PROOBJ" or ACT_ACT(WE_AC)="%TUNOBJ"
       WE_ISRC=+1
       If ACT_TYP(WE_AC)=8 or ACT_ACT(WE_AC)="%SELOBJ" : WE_SEL=1 : Endif
      # If ACT_TYP(WE_AC)=9 or ACT_ACT(WE_AC)="%TUNOBJ" : WE_TUN=1 : Endif
#       if ACT_ACT(WE_AC)="%TUNOBJ or (ACT_TYP(WE_AC)=9 and instr(0,ACT_ACT(WE_AC),"GOBJET")<>0)
       If ACT_ACT(WE_AC)="%TUNOBJ" : WE_TUN=1 : Endif
    Endif
    If ACT_TYP(WE_AC)=31 : WE_ICO=1 : Endif
  Next WE_AC
Return


$LAYOUTJSON
If MASQUE = "AASEL"
 #La génération du layout de l'écran AASEL sort du cadre standard:
 Gosub LAYOUTJSON_AASEL
Else
