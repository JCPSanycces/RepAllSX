$NBCOLFIX
  WE_T2=0
  For WE_T1=1 To len(BLC_OPT(WE_NOBL))
    WE_T2=val(mid$(BLC_OPT(WE_NOBL),WE_T1,1))
    If WE_T2<>0 : Break 1 : Endif
  Next WE_T1
  NBCOLFIX=WE_T2
Return

$LAYOUTJSON_OTHER
Gosub ADDLAYOUT       :# Ouverture layout général  L1
JSONPROP="$category" : JSONVALUE="section" : Gosub ADDJSONPROPV
If TET_TAI=5
  JSONPROP="$style"     : JSONVALUE="header"  : Gosub ADDJSONPROPV
Endif
JSONPROP="$XID"
JSONVALUE="$x$"
If TET_TAI=1 : JSONVALUE="c$x$" : Endif
Gosub ADDJSONPROPV
#JSONPROP="$x3bind"   : JSONVALUE="$x$"     : Gosub ADDJSONPROPV

#   On est sur le groupe de blocs
Gosub ADDLAYOUT      :# Ouverture layout groupe de blocs  L2
JSONPROP="$layoutType"   : JSONVALUE="stack"     : Gosub ADDJSONPROPV




#    Wrseq '{"$layoutType": "columns",' Using [JSO_]  ou   side, stack, tabs
#    Wrseq '"$layoutSubType": "25,75",' Using [JSO_]
#


#  Pilotage de l'écriture des blocs.
#  On les traite dans l'ordre en tenant compte de WE_BPOS qui donne la position
WE_BLICOU=0
RGBLOC=0

# Issue X3-101368 - 2018-08-13 by CCC : calculation of order was not good and now with responsive design we just need to respect sequence order of blocks
Local Integer WE_BPOSJS(1..MAXBLOC)
Local Integer WE_RANK(1..MAXBLOC)

If GPRODUIT<>2
    For WE_BL=1 To BLC_NBR
        If  WE_BPOS(WE_BL)=0 : Break : Endif
        WE_BPOSJS(WE_BL) = WE_BPOS(WE_BL)
        WE_RANK(WE_BL)   = BLC_RNG(WE_BPOS(WE_BL))
    Next
    # Then sort in function of the rank
    Sorta [L]WE_BL-1 WE_RANK, WE_BPOSJS
Else
    Local Integer WE_ALWREADYUSED(1..MAXBLOC),NOTALONE,IAINV,IC
    For WE_BL=1 To BLC_NBR
      WE_BPOSJS(WE_BL) = WE_BPOS(WE_BL)
    Next
    # Assign in WE_BPOSJS positions that have been calculated in WE_BPOS
    #  that is to say in function of positions (which is not important) and essentially in function of block's type (e.g. invisible)
    # Assign corresponding rank of each block
    For WE_BL=1 To BLC_NBR
    # Si un bloc sur une ligne inférieure, seul sur sa ligne et avant un bloc de rang inférieur seul sur sa ligne on inverse
      If  WE_BPOS(WE_BL)<>0 and BLC_NOC(WE_BL)>1
         NOTALONE=0
    # Bloc seul sur sa ligne et pas en première colonne ?
         For IC=1 To BLC_NBR
           If IC<>WE_BL and WE_BPOS(IC)<>0 and BLC_NOL(IC)=BLC_NOL(WE_BL)
             NOTALONE=1 #on en trouve un autre sur la meme ligne
             Break 1
           Endif
         Next IC
    # Si oui y-a-t-il un bloc de rang inférieur sur une ligne supérieure et avec une colonne inférieure ?
         If NOTALONE=0
           For IC= 1 To BLC_NBR
             If IC<>WE_BL and WE_BPOS(IC)<>0 and BLC_NOL(IC)>BLC_NOL(WE_BL)
&                   and BLC_RNG(IC)<BLC_RNG(WE_BL) and BLC_NOC(IC)<BLC_NOC(WE_BL)
              # On inverse
                If(WE_ALWREADYUSED(IC)=0) #107512
                  WE_ALWREADYUSED(IC)=BLC_RNG(WE_BPOSJS(WE_BL))
                  IAINV=WE_BPOS(WE_BL)
                  WE_BPOSJS(WE_BL)=WE_BPOS(IC)
                  WE_BPOSJS(IC)=IAINV
                  Break 1
      #          Else
      #            Call ECR_TRACE("Can't replace " + num$(BLC_RNG(WE_BPOSJS(WE_BL))) +", "+ num$(BLC_RNG(WE_BPOS(IC))) + " Alwready replace " + num$(WE_ALWREADYUSED(IC)) ,0) From GESECRAN
                Endif
             Endif
           Next IC
         Endif
      Endif
    Next WE_BL
Endif

Gosub ADDITEM        :# Ouverture item  groupe de blocs  LIT2

#If(GUSER="LV")
#  Call ECR_TRACE("-------------$LAYOUTJSON_OTHER--------------",0) From GESECRAN
#  Call ECR_TRACE("  BLC_TYP BLC_RNG BLC_RRR WE_BLCR WE_BPOSJS",0) From GESECRAN
#  For WE_J=1 To BLC_NBR
#   TR=""
#   TR+=num$(WE_J) + space$(3-len(num$(WE_J)))
#   TR+=num$(BLC_TYP(WE_J)) + space$(8-len(num$(BLC_TYP(WE_J))))
#   TR+=num$(BLC_RNG(WE_J)) + space$(8-len(num$(BLC_RNG(WE_J))))
#   TR+=num$(BLC_RRR(WE_J)) + space$(8-len(num$(BLC_RRR(WE_J))))
#   TR+=num$(WE_BLCR(WE_J)) + space$(8-len(num$(WE_BLCR(WE_J))))
#   TR+=num$(WE_BPOSJS(WE_J)) + space$(10-len(num$(WE_BPOSJS(WE_J))))
#   Call ECR_TRACE(TR,0) From GESECRAN
#  Next WE_J
#Endif

IRANK=0
Raz BLOCRANK

For WE_BL=1 To BLC_NBR
  WE_NOBL=WE_BPOSJS(WE_BL)
  #WE_NOBL=find(WE_BLCR(WE_BL),BLC_RNG(1..BLC_NBR))

  If WE_NOBL=0 : Break 1 : Endif
  If(BLC_RNG(WE_NOBL)<>BLC_RRR(WE_NOBL) and  BLC_TYP(WE_NOBL)<>1)
       IRANK=IRANK+1
       BLOCRANK(IRANK)='"B_'+MASQUE+ "_"+num$(BLC_RRR(WE_NOBL)) + '":"B_' + MASQUE+"_"+num$(BLC_RNG(WE_NOBL)) + '"'
  Endif
  If BLC_TYP(WE_NOBL)=0 or BLC_TYP(WE_NOBL)=5 or BLC_TYP(WE_NOBL)=10
   Goto WE_NEXTBLOC
  Endif
  #Call ECR_TRACE("Ok WE_NOBL:" + num$(WE_NOBL) + " BLC_TYP(WE_NOBL)" + num$(BLC_TYP(WE_NOBL)) ,0) From GESECRAN
  If BLC_NOL(WE_NOBL)<>WE_BLICOU
    If WE_BLICOU<>0
      Gosub CLOSELAYOUT    : #  Ferme le bloc en cours
      Gosub WECR_FLIGBLOCV : #  Ferme la ligne de blocs
    Endif
    WE_BLICOU=BLC_NOL(WE_NOBL)
    Gosub WECR_LIGBLOC     : #  Ouvre la ligne de blocs
  Else
    If RGBLOC>=1 :     Gosub CLOSELAYOUTV : Endif
  Endif
  RGBLOC+=1
  Wrseq "{"  Using [JSO_]
  Gosub ADDBLOCLAYOUT
$WE_NEXTBLOC
Next WE_BL
#If OPLIGBL>0 : Gosub WECR_FLIGBLOC : Endif     : # Ferme la ligne de blocs
If OPLIGBL>0      : # Pou comprendre
 Gosub CLOSELAYOUT
 Gosub CLOSEITEM
Endif
If(RGBLOC>0):Gosub CLOSELAYOUT:Endif  #105836 json malformed
Gosub CLOSEITEM       :# Fermeture item groupe de blocs  FLIT2

Gosub CLOSELAYOUT     :# Fermeture layout groupe de blocs  LF2
Gosub CLOSELAYOUTV    :# Fermeture layout général  LF1
Return

$WECR_FLIGBLOC
 OPLIGBL-=1
 Gosub CLOSEITEM
 Gosub CLOSELAYOUT
Return

$WECR_FLIGBLOCV
 OPLIGBL-=1
 Gosub CLOSEITEM
 Gosub CLOSELAYOUTV
Return


$WECR_LIGBLOC
 OPLIGBL+=1
 Wrseq '{"$layoutType": "row",' Using [JSO_]
 Gosub ADDITEM
Return



$ADDBLOCLAYOUT

    WE_NTEX=BLC_TIT(WE_NOBL)  : WE_CAPDEF=BLC_TXT(WE_NOBL) : WE_LCH=0
    WE_INTEV=BLC_EVL(WE_NOBL) : WE_FORCE=0
    WE_NTEXKEY="B_"+MASQUE
#     If(GUSER="LV")
#     Call ECR_TRACE("-------------$ADDBLOCLAYOUT--------------",0) From GESECRAN
#        Call ECR_TRACE("WE_BL WE_NOBL BLC_RNG BLC_RRR",0) From GESECRAN
#        Call ECR_TRACE(num$(WE_BL) + space$(6-len(num$(WE_BL))) + num$(WE_NOBL) + space$(8-len(num$(WE_NOBL)))+num$(BLC_RNG(WE_NOBL))+ space$(8-len(num$(BLC_RRR(WE_NOBL)))) +num$(BLC_RRR(WE_NOBL))
#& ,0)  From GESECRAN
#    Endif

    If( BLC_TYP(WE_NOBL)=1)
      WE_NTEXKEY+="_"+BLC_BAS(WE_NOBL)
    Else
      WE_NTEXKEY+="_"+num$(BLC_RNG(WE_NOBL))
    Endif
    Gosub JSON_ADDNLOC From VALWINJSON
    JSONPROP="$title"    : JSONVALUE=WE_VALUE  : Gosub ADDJSONPROPV
    JSONPROP="$XID" : JSONVALUE=WE_NTEXKEY : Gosub ADDJSONPROPV
    JSONPROP="$category" : JSONVALUE="block" : Gosub ADDJSONPROPV
#    If BLC_STY(WE_NOBL)<>""
#      JSONPROP="$titleStyle" : JSONVALUE=BLC_STY(WE_NOBL) : Gosub ADDJSONPROPV
#    Endif
#    JSONPROP="$x3bind"   : JSONVALUE="$x$"+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)     : Gosub ADDJSONPROPV
    Gosub ADDLAYOUT

    Gosub ADDFIELDLAYOUT

    Gosub CLOSELAYOUT
Return


$ADDFIELDLAYOUT
    Gosub ADDITEM

    If BLC_TYP(WE_NOBL)<>1
      NBLL=0 : LIGCOU=0

      For WE_F=1 To LIG_NBR(WE_NOBL)
       If LIG_SAI(WE_NOBL,WE_F)<=2 :#  Modif pour JMK  23/09/2013 1:Saisi, 2:Affiché, 3:Invisible
         If WE_F>1 and BLC_TYP(WE_NOBL)=2 and LIG_ZON(WE_NOBL,WE_F)="Z"+LIG_ZON(WE_NOBL,WE_F-1)
&           and LIG_LIE(WE_NOBL,WE_F-1)>1 and LIG_SAI(WE_NOBL,WE_F-1)<=2
           Goto NEXTFIELD
         Endif
         If LIG_IDX(WE_NOBL,WE_F)>0
           If NBLL=0
             Wrseq "{"  Using [JSO_]
           Elsif NBLL>=1
             If int(LIG_NUM(WE_NOBL,WE_F))<>LIGCOU
               Wrseq "}"  Using [JSO_]
             Else
               Wrseq "},"  Using [JSO_]
             Endif
           Endif
           NBLL+=1
           If int(LIG_NUM(WE_NOBL,WE_F))<>LIGCOU
             If LIGCOU<>0
               Gosub CLOSEITEM
               Gosub CLOSELAYOUTV
               Wrseq "{"  Using [JSO_]
             Endif
             LIGCOU=int(LIG_NUM(WE_NOBL,WE_F))
             JSONPROP="$layoutType"   : JSONVALUE="row"     : Gosub ADDJSONPROPV
             Gosub ADDITEM
           Endif
           Wrseq "{"  Using [JSO_]
           If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")=0 and LIG_GRA(WE_NOBL,WE_F)<>13
             If LIG_SAI(WE_NOBL,WE_F)=1
               #JSONPROP="$isEditMode" : JSONVALUE="true"
               #If  BLC_TYP(WE_NOBL) = 4 :JSONVALUE="false" Endif
               #Gosub ADDJSONPROPV
             Elsif  LIG_SAI(WE_NOBL,WE_F)=2
               If WE_F>1 and LIG_ZON(WE_NOBL,WE_F)="Z"+LIG_ZON(WE_NOBL,WE_F-1)
                 #JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROPV
                 JSONPROP="$isTitleHidden" : JSONVALUE="true" : Gosub ADDJSONPROPV
               Else
                 #If  BLC_TYP(WE_NOBL) = 4 : JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROPV Endif
                 JSONPROP="$isReadOnly" : JSONVALUE="true" : Gosub ADDJSONPROPV
               Endif
            Elsif LIG_SAI(WE_NOBL,WE_F)=3
              #If  BLC_TYP(WE_NOBL) = 4 : JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROPV Endif
               JSONPROP="$isHidden" : JSONVALUE="true" : Gosub ADDJSONPROPV
  #             JSONPROP="$isExcluded" : JSONVALUE="true" : Gosub ADDJSONPROPV
            Else
               #If  BLC_TYP(WE_NOBL) = 4 : JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROPV Endif
            Endif
           Else
             #JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROPV
             JSONPROP="$isTitleHidden" : JSONVALUE="true"
  #      S'il y a un intitulé sur le champ icône on met la propriété à false, à true sinon
             If LIG_GRA(WE_NOBL,WE_F)=13 and LIG_TIT(WE_NOBL,WE_F)<>0
               JSONVALUE="false"
             Endif
             If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")=1 : JSONVALUE="false" : Endif     :#  CC  22/04/2013
             Gosub ADDJSONPROPV
             If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")=1 :   #  CC  22/04/2013
               JSONPROP="$isTopLabelAlignment" : JSONVALUE="true" : Gosub ADDJSONPROPV
             Endif
           Endif
           LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
   #        If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR2"  : JSONPROP="$rows" : JSONVALUE=num$(LIG_FLI(WE_NOBL,WE_F)) : Gosub ADDJSONPROPNV : Endif
           #118962
           #If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR2" or LIG_FLI(WE_NOBL,WE_F)>1
           #  JSONPROP="$rows" : JSONVALUE=num$(LIG_FLI(WE_NOBL,WE_F)) : Gosub ADDJSONPROPNV
           #Endif
           If LIG_TYI(WE_NOBL,WE_F)=10 and BLC_TYP(WE_NOBL)=6 #CLOB FLASH
            JSONPROP="$renderer" : JSONVALUE="raw" : Gosub ADDJSONPROPV
           Endif
           JSONPROP="$bind"    : JSONVALUE="$x$"+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)+num$(LIDX)    : Gosub ADDJSONPROP
         Endif
       Endif :#  Modif pour JMK  23/09/2013
$NEXTFIELD
      Next WE_F
      If NBLL>0 : Wrseq "}"  Using [JSO_] : Gosub CLOSEITEML  : Endif
    Else
         ASPROP=1
         ASPROP=func ASPROPERTIES(WE_NOBL,LIG_NBR(WE_NOBL),LIG_SAI,BLC_BAS(WE_NOBL),LIG_ZON)
         If(ASPROP=1)
  #         Gosub NBCOLFIX    : # Récupère le nombre de colonnes fixes du tableau
           Wrseq "{"  Using [JSO_]
           #JSONPROP="$isEditMode" : JSONVALUE="true" : Gosub ADDJSONPROPV
           If(BLC_TYPG(WE_NOBL)=4 and BLC_TYPT(WE_NOBL)>1) # 114809 problems in Multilevel planning
              JSONVALUE="row"
           Else
             JSONVALUE="multi"
           Endif
           JSONPROP="$selectMode" : Gosub ADDJSONPROPV
  #         JSONPROP="$bind"    : JSONVALUE="$x$"+mid$(WE_ALPHAB,RGBLOC,1)   : Gosub ADDJSONPROPV
           JSONPROP="$bind"    : JSONVALUE="$x$"+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)   : Gosub ADDJSONPROPV
  #  Insertion paramètres si graphe
           If BLC_TYPG(WE_NOBL)=1 or BLC_TYPG(WE_NOBL)=2 or BLC_TYPG(WE_NOBL)=3  or  BLC_TYPG(WE_NOBL)=4 or BLC_TYPG(WE_NOBL)=5
               Case BLC_TYPT(WE_NOBL)
               When 1  :       JSONVALUE="list"
               When 2  :       JSONVALUE="both"
               When 3  :       JSONVALUE="both"
               When 4  :       JSONVALUE="graph"
               When Default :  JSONVALUE="list"
             Endcase
             JSONPROP="$graphMode" : Gosub ADDJSONPROPV

            If JSONVALUE="both"
               Case BLC_POSG(WE_NOBL)
                 When 1  :       JSONVALUE="right"
                 When 2  :       JSONVALUE="left"
                 When 3  :       JSONVALUE="top"
                 When 4  :       JSONVALUE="bottom"
                 When Default :  JSONVALUE=""
               Endcase
               If JSONVALUE=""
                 Case BLC_AFFD(WE_NOBL)
                 When 1  :       JSONVALUE="behind"
                 When 2  :       JSONVALUE="front"
                 When Default :
               Endcase
              Endif
              JSONPROP="$graphPosition" : Gosub ADDJSONPROPV
            Endif

           Endif
  #
           #le nombre de lignes est mis en dur pour l'instant
           # Valeurs possibles 5 10 15  20 25 50 75 100 150 200
           NBL=(1+int((BLC_NLI(WE_NOBL)-1)/5))*5
           If (BLC_LIG(WE_NOBL)<NBL or NBL<0) : NBL=(1+int((BLC_LIG(WE_NOBL)-1)/5))*5 : Endif
           If NBL>=25 and NBL<36      : NBL=25
           Elsif NBL>=36 and NBL<61   : NBL=50
           Elsif NBL>=61 and NBL<85   : NBL=75
           Elsif NBL>=85 and NBL<126  : NBL=100
           Elsif NBL>=126 and NBL<176 : NBL=150
           Elsif NBL>=176             : NBL=200
           Endif
           JSONVALUE=num$(NBL)
           JSONPROP="$itemsPerPage" : Gosub ADDJSONPROPV
           JSONPROP="$isRowIndexVisible" : JSONVALUE="true" : Gosub ADDJSONPROPV
   #         JSONPROP="$selectByRowIndex" : JSONVALUE="true" : Gosub ADDJSONPROP

  ##### Ajout mode cardview


           JSONPROP="$selectByRowIndex" : JSONVALUE="true" : Gosub ADDJSONPROPV
           Wrseq '"$layout":{'  Using [JSO_]
           Wrseq '"$items":['  Using [JSO_]
  # liste des champs tableau
           Local Integer NBLC,NBCARD,LISCARD(1..LIG_NBR(WE_NOBL))
           For WE_F=1 To LIG_NBR(WE_NOBL)
             If LIG_SAI(WE_NOBL,WE_F)<=2 :#  Modif pour JMK  23/09/2013 1:Saisi, 2:Affiché, 3:Invisible
               If LIG_IDX(WE_NOBL,WE_F)<>0 and  BLC_BAS(WE_NOBL)<>LIG_ZON(WE_NOBL,WE_F)
                 If LIG_MOD(WE_NOBL,WE_F)=1 or LIG_MOD(WE_NOBL,WE_F)=3
                   NBLC+=1
                   If NBLC>1 : Wrseq VALL1+","   Using [JSO_] : Endif
                   LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
     #              VALL1='{"$bind":"$x$'+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)+num$(LIDX)+'"}'
    # comparer NBLC et NBCOLFIX    ---- on déplace à l'extérieur d'article
    #               If NBCOLFIX<>0 and NBLC<=NBCOLFIX
    #                 VALL1='{"$bind":"$x$'+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)+num$(LIDX)+'", "$isFixed": true}'
    #               Else
                     VALL1='{"$bind":"$x$'+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)+num$(LIDX)+'"}'
    #               Endif
                   If LIG_MOD(WE_NOBL,WE_F)=1 : NBCARD+=1 : LISCARD(NBCARD)=WE_F : Endif
                 Elsif LIG_MOD(WE_NOBL,WE_F)=2
                   NBCARD+=1 : LISCARD(NBCARD)=WE_F
                 Endif
               Endif
            Endif
           Next WE_F

           Wrseq VALL1   Using [JSO_]
           If NBCARD=0
             Wrseq ']}'  Using [JSO_]
           Else
             Wrseq ']},'  Using [JSO_]

             Wrseq '"$cards":{'  Using [JSO_]
             Wrseq '"$position":"popup",'  Using [JSO_]
             Wrseq '"$layout":{'  Using [JSO_]
             Wrseq '"$items":['  Using [JSO_]
  # liste des champs fiche
             Local Integer NBLC,NBCOLF,NBELTCOL,WEG,NBROW,IG,IGIND
  #   Détermination du nombre de colonnes en fonction du nombre de champs (NBCARD)
  #   <= NBELTCOL         1 colonne
  #   <=2*NBELTCOL        2 colonnes
  #   <=3*NBELTCOL        3 colonnes
  #   >3*NBELTCOL         4 colonnes
             NBELTCOL=6
             NBCOLF=min(4,1+(NBCARD-1)/NBELTCOL)
             NBROW=1+(NBCARD-1)/NBCOLF
             NBELTCOL=1+(NBCARD-1)/NBCOLF

             For WEG=1 To NBROW
               Wrseq '{'  Using [JSO_]
               Wrseq '"$layoutType":"row",'  Using [JSO_]
               Wrseq '"$items":['  Using [JSO_]
               Raz VALL1
               For IG=1 To NBCOLF
                 IGIND=WEG+(IG-1)*NBELTCOL
                 If IGIND<=NBCARD
                   If VALL1<>"" : Wrseq VALL1+','  Using [JSO_] : Endif
                   LIDX=LIG_IDX(WE_NOBL,LISCARD(IGIND))-BLC_IDX(WE_NOBL)
                   VALL1='{"$bind":"$x$'+mid$(WE_ALPHAB,WE_BLCRG(WE_NOBL),1)+num$(LIDX)+'"}'
                 Else
                   If VALL1<>"" : Wrseq VALL1+','  Using [JSO_] : Endif
                   VALL1='{"$category":"space"}'
                 Endif
               Next IG
               If VALL1<>"" : Wrseq VALL1  Using [JSO_] : Endif
               If WEG=NBROW
                 Wrseq ']}'  Using [JSO_]
               Else
                 Wrseq ']},'  Using [JSO_]
               Endif
             Next WEG
            Wrseq "]}}"  Using [JSO_]
          Endif

           Wrseq "}"  Using [JSO_]
      Endif
    Endif
    Wrseq "]"  Using [JSO_]
Return









$ADDLAYOUT
NBLAYOUT+=1
Wrseq'"$layout": {'  Using [JSO_]
Return

$CLOSELAYOUT
NBLAYOUT-=1
Wrseq'}'  Using [JSO_]
Return

$CLOSELAYOUTV
NBLAYOUT-=1
Wrseq'},'  Using [JSO_]
Return

$ADDITEM
NBITEM+=1
Wrseq'"$items": ['  Using [JSO_]
Return

$CLOSEITEM
NBITEM-=1
Wrseq']'  Using [JSO_]
Return

$CLOSEITEML
NBITEM-=1
Wrseq']}'  Using [JSO_]
Return

$CLOSEITEMV
NBITEM-=1
Wrseq'],'  Using [JSO_]
Return




$ADDJSONPROP
 If JSONVALUE<>"true" and JSONVALUE<>"false"
    Wrseq '"'+JSONPROP+'": "'+JSONVALUE+'"'  Using [JSO_]
 Else
     Wrseq '"'+JSONPROP+'" :'+JSONVALUE  Using [JSO_]
 Endif
Return

$ADDJSONPROPV
  If JSONVALUE<>"true" and JSONVALUE<>"false"
    Wrseq '"'+JSONPROP+'": "'+JSONVALUE+'",'  Using [JSO_]
 Else
     Wrseq '"'+JSONPROP+'" :'+JSONVALUE+','  Using [JSO_]
 Endif
Return

$ADDJSONPROPN
  Wrseq '"'+JSONPROP+'": '+JSONVALUE  Using [JSO_]
Return

$ADDJSONPROPNV
    Wrseq '"'+JSONPROP+'": '+JSONVALUE+','  Using [JSO_]
Return



$JSON_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+"ALL"+AASEP+"SCRNJ"
  URL+=+AASEP+MASQUE+".json"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return

Funprog ISEDITMODE(OPT,SAI,TYP,CZON,CZONPREC,GRAPH)
  Value Char OPT #  options
  Value Integer SAI #  1:Enter, 2:Display, 3:Hidden
  Value Integer TYP # 1=tableau, 2=liste, 4=texte, 5=invisible
  Value Char CZON # field name
  Value Char CZONPREC # previous field name
  Value Integer GRAPH # graphic object
  Variable Char RESVAL
 # Variable Char TR
  RESVAL=""
  If instr(1,OPT,"W")=0 and GRAPH<>13
    If SAI=1
      RESVAL="true"
      If TYP = 4
        RESVAL="false"
      Endif
    Elsif  SAI=2
      If CZON="Z"+CZONPREC
        RESVAL="false"
      Elsif  TYP = 4
        RESVAL="false"
      Endif
    Elsif SAI=3
      If  TYP = 4
        RESVAL="false"
      Endif
    Else
      If  TYP = 4
        RESVAL="false"
      Endif
    Endif
  Else
    RESVAL="false"
  Endif
#    TR=CZON + " " +CZONPREC+ " OPT:" + OPT + " SAI:" + num$(SAI)+ " TYP:" + num$(GRAPH)+ " GRAPH:" + num$(GRAPH)
#    Call ECR_TRACE(TR,0) From GESECRAN
End RESVAL

Funprog VIEWSCOPE(SCOP)
  Value Integer SCOP # 1:Form and table, 2:Form, 3:Table
  Variable Char RESVAL
  Case SCOP
     When 1  : RESVAL="both"
     When 2  : RESVAL="popup"
     When 3  : RESVAL="grid"
  Endcase
End RESVAL

# grid as properties ? 106364 : empty grid due to block or field invisible or activity code not active
Funprog ASPROPERTIES(NOBL,NBLIG,LIGSAI,BASPAG,LIGZON)
  Value Integer NOBL
  Value Integer NBLIG
  Value Char BASPAG
  Value Libelle LIGSAI(1..,1..)
  Value Schar LIGZON()(1..,1..)
  Local Integer RESVAL
  RESVAL=0
  For I=1 To NBLIG
   # Call ECR_TRACE(num$(I) + " BASPAG:" + BASPAG + " ZON:" +LIGZON(NOBL,I) + " SAI:" + num$(LIGSAI(NOBL,I)) ,0) From GESECRAN
    If(LIGZON(NOBL,I)<>BASPAG and LIGSAI(NOBL,I)<=2)
      RESVAL=1
      Break 1
    Endif
  Next
End RESVAL

