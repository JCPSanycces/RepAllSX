###################################################################################################
# Objet PSO
###################################################################################################
$OUVRE
Global Integer GIPSOCHKTBL   # Issue X3-49776 - 2018-06-25 by FGR

  # -----------------------------
  # Set the status of the changed flag to no and the status of the enabled flag to no
  [M:PSO0]CHGFLG = [V]CST_ANO
  # -----------------------------
  # Issue X3-95000 - 2018-06-15 by FGR : BEGIN
  #If !clalev ([F:BPC])   : Local File BPCUSTOMER [BPC]    : Endif
  #If !clalev ([F:BPD])   : Local File BPDLVCUST  [BPD]    : Endif
  #If !clalev([F:FIY])    : Local File FISCALYEAR [FIY]    : Endif
  #If !clalev([F:PER])    : Local File PERIOD     [PER]    : Endif
  #If !clalev([F:PSPLD1]) : Local File PJMSALITMD [PSPLD1] : Endif
  #If !clalev([F:TCA])    : Local File TABCOUAFF  [TCA]    : Endif
  #If !clalev([F:TSQ])    : Local File TABSQHTYP  [TSQ]    : Endif
  #If !clalev([F:TSV])    : Local File TABSIVTYP  [TSV]    : Endif
  #If !clalev([F:TSV])    : Local File PJMSOLITMD [PSOH]   : Endif
  Local File BPARTNER   [BPR]
  Local File BPCUSTOMER [BPC]
  Local File BPDLVCUST  [BPD]
  Local File BPCUSTMVT  [MVC]
  Local File FISCALYEAR [FIY]
  Local File PERIOD     [PER]
  Local File PJMSALITMD [PSPLD1]
  Local File TABCOUAFF  [TCA]
  Local File TABSQHTYP  [TSQ]
  Local File TABSIVTYP  [TSV]
  # Issue X3-95000 - 2018-06-15 by FGR : END
  # Issue X3-49776 - 2018-06-25 by FGR : BEGIN
  Local File VPJMSOLITMD [VPSOD]
  Local File VPJMSOLITMH [VPSOH]
  Local File VPJMSOLITMO [VPSOO]
  GIPSOCHKTBL = [V]CST_AFALSE
  # Issue X3-49776 - 2018-06-25 by FGR : END
Return

###################################################################################################
$FERME
  # Issue X3-49776 - 2018-06-25 by FGR
  If dim(GIPSOCHKTBL) >= 0 Then
    Kill GIPSOCHKTBL
  Endif
Return

###################################################################################################
$FILTRE
  Default File [PSOH]
Return

###################################################################################################
$OUVRE_BOITE
Global Char GBOXPSO1(30)     # Issue X3-95000 - 2018-06-15 by FGR :  length to 30
Global Char GBOXPSO2(30)     # Issue X3-95000 - 2018-06-15 by FGR :  length to 30
Global Char GBOXPSO3(30)     # Issue X3-95000 - 2018-06-15 by FGR :  length to 30

  GBOXPSO1 = "GAU_CHE"+num$(find("PSO1",OBJLIS(1..10)))
  GBOXPSO2 = "GAU_CHE"+num$(find("PSO2",OBJLIS(1..10)))
  GBOXPSO3 = "GAU_CHE"+num$(find("PSO3",OBJLIS(1..10)))
Return

###################################################################################################
$APRES_MODIF
  If find(COUZON,"OPPNUM") Then
    If COUZON = "OPPNUM" Then
      [M:PSO0]OPPNUM = CZ
    Endif
  Endif
  Gosub TIROIR From SUBPSOC
Return

###################################################################################################
# Issue X3-95321 - 2018-08-08 by FGR : BEGIN
$SETBOUT
  # Issue X3-107683 - 2018-10-09 by FGR : BEGIN
  If GREP <> AVOID.ACHAR Then
    Call VIREBOUT(CHAINE,"2") From GOBJET        # Generate document
    Call VIREBOUT(CHAINE,"3") From GOBJET        # Revision management
  Else
    Call VIREBOUT(CHAINE, "1") From GOBJET       # Simulate button
  Endif
  # Issue X3-107683 - 2018-10-09 by FGR : END
  If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [M:PSO1]SALFCY, "PSOREV") = 1 Then
    Call VIREBOUT(CHAINE, "3") From GOBJET       # Disable Revision management
  Endif
  # If a document has been generated - disable all buttons (also diszo screens)
  Case [M:PSO0]DOCTYP
    When 1
      # Quote
      If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
        # If quote has been created : forbidden to modify [M:PSO0]DOCTYP
        If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [M:PSO1]SALFCY, "PSOREV") = 1 Then
          # Quote never updatable when document has been created and revisions not managed.
          Call VIREBOUT(CHAINE,"MA12") From GOBJET
        Else
          # Deletion not allowed
          Call VIREBOUT(CHAINE,"A") From GOBJET
          Call VIREBOUT(CHAINE,"2") From GOBJET  # Generate document # Issue X3-107683 - 2018-10-09 by FGR
        Endif
      Else
        # If at least, a quote has been created in revision
        If [M:PSO0]REVNUM > 0 Then
          Filter [VPSOH] Where [F:VPSOH]PSONUM = [M:PSO0]PSONUM and [F:VPSOH]HDOCNUM <> AVOID.ACHAR
          For [VPSOH]
            # When quote has been created, not possible to modify DOCTYP : will stay mandatory for a quote
            Call VIREBOUT(CHAINE,"A") From GOBJET
            Break
          Next
          Filter [VPSOH]
        Endif
      Endif
    When 2, 3
      # Sales order or sales invoice : Never updatable when a document has been created
      If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
        If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
          Call VIREBOUT(CHAINE,"MA12") From GOBJET
        Else
          If GREP = AVOID.ACHAR Then
            Call VIREBOUT(CHAINE, "1") From GOBJET     # Disable Simulate button
          Else
            Call VIREBOUT(CHAINE, "2") From GOBJET     # Disable Generate document button
            Call VIREBOUT(CHAINE, "3") From GOBJET     # Disable Revision management
          Endif
        Endif
      Endif
    Endcase
Return

