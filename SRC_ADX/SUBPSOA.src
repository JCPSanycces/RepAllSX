###################################################################################################
$AVANTBOUT
  Case BOUT
    When "1"
      Call APPLY_SPLD()      # Issue number - 2018-06-15 by FGR : GOSUB APPLY_SPLD
    When "2"
      Call GENERATE_DOCUMENT()
  Endcase
Return

###################################################################################################
$EXEBOUT
  Case BOUT
    When "2"
      Gosub RELIT From GOBJSUB
  Endcase
Return

###################################################################################################
# Issue X3-107683 - 2018-10-09 by FGR : BEGIN
$RAZCRE
  Raz [M:PSO1]
  Raz [M:PSO2]
  Raz [M:PSO3]
  If (dim(GWEBSERV) > 1 and GWEBSERV = 1) Then
    Effzo [M:PSO0]PSONUM
  Endif
  Diszo [M:PSO0]HDOCNUM
  # -----------------------------
  If GNAVIG(GPILNAV-1) <> "GESPJM" and GNAVIG(GPILNAV-1) <> "PJMACTTAS" and  GNAVIG(GPILNAV-1) <> "PJMACTBUD" Then
    [M:PSO1]SALFCY = GFCYDEF(9)
    [M:PSO1]STOFCY = GFCYDEF(7)
    #
    [M:PSO0]DOCTYP = 1
    Call CHANGEDOCTYP([M:PSO0]DOCTYP) From SUBPSO
    [M:PSO0]CHGFLG = [V]CST_AYES
  Else
    Call AM_OPPNUM([M:PSO0]OPPNUM) From SUBPSO
  Endif
  [M:PSO0]DOCDAT = date$
  # -----------------------------
  GFCY = [M:PSO1]SALFCY
  Call GETSOC(GFCY) From DEVSUB
  Call GETCPY(GFCY, "SLT", 1, GFLAG) From TRTX3CPT
  # -----------------------------
  Affzo [M:PSO0]1-99
  Affzo [M:PSO1]1-99
  # -----------------------------
  If [M:PSO0]OPPNUM <> AVOID.ACHAR Then
    Diszo [M:PSO0]OPPNUM
  Endif
  # -----------------------------
  Gosub REMPBOX From SUBPSOC
Return

