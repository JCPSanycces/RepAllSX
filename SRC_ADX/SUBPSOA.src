###################################################################################################
$RAZDUP
  Raz [M:PSO0]PSONUM
  Raz [M:PSO0]HDOCNUM
  [M:PSO0]DOCDAT = date$
  [M:PSO0]CHGFLG = [V]CST_AYES
  Raz [M:PSO0]REVNUM         # Issue X3-49776 - 2018-06-25 by FGR
  # -----------------------------
  Raz [M:PSO2]
  Raz [M:PSO3]
  # -----------------------------
  Affzo [M:PSO0]1-99
  Affzo [M:PSO2]1-99
  Affzo [M:PSO2]1-99
  # -----------------------------
  Gosub REMPBOX From SUBPSOC
Return

###################################################################################################
$INICRE
Local Char SCPY(GLONCPY)
Local Integer IERROR
Local Char SMESSAGE(250)
Local Integer IMANUAL
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(GLONPSO)
Local Integer STAT

  # Issue X3-95321 - 2018-08-10 by FGR : BEGIN
  If [M:PSO2]NBLIG2 <= 0 Then
    GMESSAGE = mess(396,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  # Issue X3-95321 - 2018-08-10 by FGR : END
  # -----------------------------
  SCPY = fmet GACTX.ACACHE.AFCY.AGETVALCHAR([M:PSO1]SALFCY, "LEGCPY")
  Call READ_COUNTER(GACTX, 9, 14, SCPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    GERR = 1
    GOK = 0
    GMESSAGE = SMESSAGE
    Return
  Endif
  If SCOMPTEUR <> AVOID.ACHAR Then
    # Get the counter for the PSO
    If IMANUAL <> [V]CST_AYES or (IMANUAL = [V]CST_AYES and vireblc([M:PSO0]PSONUM,2) = AVOID.ACHAR) Then
      Call NUMERO(SCOMPTEUR, [M:PSO1]SALFCY, [M:PSO0]DOCDAT, AVOID.ACHAR, SNUMERO, STAT) From SUBANM
      If GOK < 0 Then
        Return
      Endif
      #If GOK > 0 and STAT = 0 Then    # Issue X3-95321 - 2018-08-10 by FGR
      If STAT = 0 Then                 # Issue X3-95321 - 2018-08-10 by FGR
        [F:PSOH]PSONUM = SNUMERO
        [M:PSO0]PSONUM = SNUMERO
        Affzo [M:PSO0]PSONUM
      Else
        GMESSAGE = mess(60,199,1) - "(" + SCOMPTEUR + ") : "
        Gosub MESSAGE From SUBANM
        GMESSAGE -= MESSA   # MESSA is created in "Gosub MESSAGE From SUBANM"
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
  Else
    If [M:PSO0]PSONUM = AVOID.ACHAR Then
      GMESSAGE = mess(1,79,1)
      GERR = 1
      GOK = 0
      zonsui = "[M:PSO0]PSONUM"
      Return
    Endif
  Endif
  # -----------------------------
Return

###################################################################################################
$CREATION
Local Integer MY_STATUS

  # Issue X3-95321 - 2018-08-10 by FGR : BEGIN : moved in $INICRE
  #If [M:PSO2]NBLIG2 <= 0 Then
  #  GMESSAGE = mess(396,2260,1)
  #  GERR = 1
  #  GOK = 0
  #  Return
  #Endif
  # Issue X3-95321 - 2018-08-10 by FGR : END
  # -----------------------------
  If [M:PSO0]CHGFLG = [V]CST_AYES Then
    # Issue X3-95000 - 2018-06-15 by FGR : BEGIN
    #GMESSAGE = mess(397,2260,1)
    #GERR = 1
    #GOK = 0
    #Return
    Call APPLY_SPLD()
    If GERR = 1 Then
      Return
    Endif
    # Issue X3-95000 - 2018-06-15 by FGR : END
  Endif
  # -----------------------------
  # Update PJMSOLITMD and PJMSOLITMO tables
  Call UPDATE_DETAIL_TABLES()
  If GOK > 0 Then
    MY_STATUS = func SUBPSOH.UPDATE_PSPLD([V]CST_ANEW)
    If MY_STATUS >= [V]CST_AERROR Then
      Return
    Endif
  Endif
  # Issue X3-49776 - 2018-06-25 by FGR : BEGIN
  If func INIT_VPJMSOLITMH_RECORD([F:PSOH]SALFCY, [F:PSOH]PSONUM, [F:PSOH]REVNUM) >= [V]CST_AERROR Then
    GOK = 0
    Return
  Endif
  # Issue X3-49776 - 2018-06-25 by FGR : END
Return

###################################################################################################
$APRES_CRE
  Gosub RELIT From GOBJSUB
Return

###################################################################################################
$LIENS
Local Integer NOLINE

  Actzo [M:PSO0]5
  Actzo [M:PSO1]5
  Actzo [M:PSO2]10
  Actzo [M:PSO3]10
  Diszo [M:PSO0]HDOCNUM
  # -----------------------------
  Call GREY_DOCTYP([M:PSO0]DOCTYP) From SUBPSO
  # -----------------------------
  # Issue X3-95321 - 2018-08-08 by FGR : BEGIN
  #If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
  #  # -----------------------------
  #  # Disable screen fields if the document has been generated
  #  Diszo [M:PSO0]5
  #  Diszo [M:PSO1]5
  #  Diszo [M:PSO2]10
  #  Diszo [M:PSO3]10
  #  If [M:PSO0]DOCTYP <> 0 Then
  #    If [M:PSO0]DOCTYP = 1 Then
  #      [M:PSO0]TUNAOB = "SQH"
  #    Elsif [M:PSO0]DOCTYP = 2 Then
  #      [M:PSO0]TUNAOB = "SOH"
  #    Elsif [M:PSO0]DOCTYP = 3 Then
  #      [M:PSO0]TUNAOB = "SIH"
  #    Endif
  #  Endif
  #Else
  #  Diszo [M:PSO0]OPPNUM
  #  Diszo [M:PSO1]CUR
  #  Diszo [M:PSO1]SALFCY
  #Endif
  Call ACTZO_DISZO()
  # -----------------------------
  Raz [M:PSO0]TUNAOB
  If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
    If [M:PSO0]DOCTYP = 1 Then
      [M:PSO0]TUNAOB = "SQH"
    Elsif [M:PSO0]DOCTYP = 2 Then
      [M:PSO0]TUNAOB = "SOH"
    Elsif [M:PSO0]DOCTYP = 3 Then
      [M:PSO0]TUNAOB = "SIH"
    Endif
  Endif
  # Issue X3-95321 - 2018-08-08 by FGR : END
  # -----------------------------
  NOLINE = 0
  Filter [F:PSOO] Where [F:PSOO]PSONUM = [M:PSO0]PSONUM
  For [F:PSOO]
    NOLINE += 1
    nolign = NOLINE
    [M:PSO2] = [F:PSOO]
    [M:PSO2]UPDLIG(nolign-1) = [V]CST_ANO        # Issue X3-49776 - 2018-06-25 by FGR
    [M:PSO2]KEYCONCAT(nolign-1) = func SUBPSOA.GET_PSO2_KEYCONCAT([M:PSO2]PBUCOD(nolign-1), [M:PSO2]TASCOD(nolign-1), [M:PSO2]SEQNUM(nolign-1))      # Issue X3-49776 - 2018-06-25 by FGR
    # Issue X3-95322 - 2018-07-10 by FGR : BEGIN
    If [F:PSOO]TASCOD <> AVOID.ACHAR Then
      [M:PSO2]TASDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:PSOO]OPPNUM, [F:PSOO]TASCOD))
    Endif
    If [F:PSOO]PBUCOD <> AVOID.ACHAR Then
      [M:PSO2]PBUDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSOO]OPPNUM, [F:PSOO]PBUCOD))
    Endif
    # Issue X3-95322 - 2018-07-10 by FGR : END
  Next
  Filter [F:PSOO]
  [M:PSO2]NBLIG2 = NOLINE
  # -----------------------------
  NOLINE = 0
  Filter [F:PSOD] Where [F:PSOD]PSONUM = [M:PSO0]PSONUM
  For [F:PSOD]
    NOLINE += 1
    nolign = NOLINE
    [M:PSO3] = [F:PSOD]
  Next
  Filter [F:PSOD]
  [M:PSO3]NBLIG3 = NOLINE
  # -----------------------------
  Call LOAD_QUOTES()         # Issue X3-95321 - 2018-08-08 by FGR
  # -----------------------------
  Gosub TIROIR From SUBPSOC
  Gosub REMPBOX From SUBPSOC
  # -----------------------------
  [M:PSO0]CHGFLG = [V]CST_ANO
  Call DISPLAY_HIDE_REVNUM([M:PSO1]SALFCY) From SUBPSOA  # Issue X3-49776 - 2018-06-25 by FGR
  Raz [M:PSO0]PSOREV                                     # Issue X3-49776 - 2018-06-25 by FGR
Return

###################################################################################################
$MODIF
Local Integer MY_STATUS

  If [M:PSO2]NBLIG2 <= 0 Then
    GMESSAGE = mess(396,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  # -----------------------------
  If [M:PSO0]CHGFLG = [V]CST_AYES Then
    # Issue X3-95000 - 2018-06-15 by FGR : BEGIN
    #GMESSAGE = mess(397,2260,1)
    #GERR = 1
    #GOK = 0
    #Return
    Call APPLY_SPLD()
    If GERR = 1 Then
      Return
    Endif
    # Issue X3-95000 - 2018-06-15 by FGR : END
  Endif
  # -----------------------------
  # Issue X3-49776 - 2018-06-25 by FGR : BEGIN
  #Delete [F:PSOD] Where PSONUM = [M:PSO0]PSONUM
  #If fstat <> 0 Then
  #  GMESSAGE = mess(384,2260,1)
  #  GERR = 1
  #  GOK = 0
  #  Return
  #Endif
  # -----------------------------
  #Delete [F:PSOO] Where PSONUM = [M:PSO0]PSONUM
  #If fstat <> 0 Then
  #  GMESSAGE = mess(384,2260,1)
  #  GERR = 1
  #  GOK = 0
  #  Return
  #Endif
  # Issue X3-49776 - 2018-06-25 by FGR : END
  # -----------------------------
  Call UPDATE_DETAIL_TABLES()
  If GOK > 0 Then
    MY_STATUS = func SUBPSOH.UPDATE_PSPLD([V]CST_AUPD)
    If MY_STATUS >= [V]CST_AERROR Then
      Return
    Endif
  Endif
Return

###################################################################################################
$AVANT_MOD
  # Issue X3-49776 - 2018-06-25 by FGR
  Call REVISION_MANAGEMENT()
Return

###################################################################################################
$AVANT_MODFIC
  # Issue X3-49776 - 2018-06-25 by FGR
  If [M:PSO0]PSOREV = 2 Then
    Call INCREASE_VPJMSOLITMH_RECORD([F:PSOH]SALFCY, [F:PSOH]PSONUM, [F:PSOH]REVNUM, [M:PSO0]REVNUM)
    Call HISTO_REV("PSOH", "M")
  Endif
Return

###################################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
Return

###################################################################################################
$AV_ANNULE
  If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
    GMESSAGE = mess(386,2260,1)
    GERR = 1
    GOK = 0
  Endif
Return

###################################################################################################
$ANNULE
Local Integer MY_STATUS

  MY_STATUS = func SUBPSOH.UPDATE_PSPLD([V]CST_ADEL)
  If MY_STATUS >= [V]CST_AERROR Then
    Return
  Endif
  Delete [F:PSOD] Where [F:PSOD]PSONUM = [M:PSO0]PSONUM
  If fstat <> 0 Then
    GMESSAGE = mess(385,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Delete [F:PSOO] Where [F:PSOO]PSONUM = [M:PSO0]PSONUM
  If fstat <> 0 Then
    GMESSAGE = mess(385,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  # Issue X3-95321 - 2018-08-10 by FGR : BEGIN
  Delete [F:VPSOH] Where [F:VPSOH]PSONUM = [M:PSO0]PSONUM
  If fstat <> 0 Then
    GMESSAGE = mess(385,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Delete [F:VPSOO] Where [F:VPSOO]PSONUM = [M:PSO0]PSONUM
  If fstat <> 0 Then
    GMESSAGE = mess(385,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Delete [F:VPSOD] Where [F:VPSOD]PSONUM = [M:PSO0]PSONUM
  If fstat <> 0 Then
    GMESSAGE = mess(385,2260,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  # Issue X3-95321 - 2018-08-10 by FGR : END
Return

###################################################################################################
# SUBROUTINES
###################################################################################################
# Issue X3-95000 - 2018-06-15 by FGR : BEGIN
Subprog APPLY_SPLD()

Local Integer NI
Local Integer NE
Local Integer P3_LIN
Local Integer P3_NBLIG
Local Integer SOLDSEQNUM
Local Integer I_LINK

  # -----------------------------
  If [M:PSO2]NBLIG2 <= 0 Then
    GMESSAGE = mess(396,2260,1)
    GERR = 1
    GOK = 0
    End
  Endif
  # -----------------------------
  Effzo [M:PSO3]
  # -----------------------------
  # clear previous sold products line number
  For NI = 0 To [M:PSO2]NBLIG2-1
    [M:PSO2]UPDLIG(NI) = [V]CST_AYES
    Raz [M:PSO2]SOLDSEQNUM(NI)
  Next NI
  # -----------------------------
  # create new sold products line number (link)
  For NI = 0 To [M:PSO2]NBLIG2-1
    If [M:PSO2]SOLDSEQNUM(NI) = 0 Then
      SOLDSEQNUM += 1000
      [M:PSO2]SOLDSEQNUM(NI) = SOLDSEQNUM
    Endif
    For NE = NI+1 To [M:PSO2]NBLIG2-1
      If [M:PSO2]SOLDSEQNUM(NE) = 0 and
&        [M:PSO2]ITMREF(NI)     = [M:PSO2]ITMREF(NE) and
&        [M:PSO2]ECCVALMAJ(NI)  = [M:PSO2]ECCVALMAJ(NE) and
&        [M:PSO2]ECCVALMIN(NI)  = [M:PSO2]ECCVALMIN(NE) and
&        [M:PSO2]SAU(NI)        = [M:PSO2]SAU(NE) and
&        [M:PSO2]BASPRI(NI)     = [M:PSO2]BASPRI(NE) and
&        [M:PSO2]PRODGRPLVL(NI) = [M:PSO2]PRODGRPLVL(NE)
&     Then
        Gosub GET_PRJLINK_MATCH
      Endif
    Next NE
  Next NI
  # -----------------------------
  # Build PSO3 grid
  For NI = 0 To [M:PSO2]NBLIG2-1
    P3_LIN = [M:PSO2]SOLDSEQNUM(NI) / 1000
    If P3_LIN > P3_NBLIG Then
      P3_NBLIG = P3_LIN
    Endif
    If [M:PSO3]PSOLIN(P3_LIN-1) <= 0 Then
      [M:PSO3]CUSTOMER(P3_LIN-1)   = [M:PSO1]BPCORD
      [M:PSO3]PSOLIN(P3_LIN-1)     = P3_LIN * 10
      [M:PSO3]SEQNUM(P3_LIN-1)     = [M:PSO2]SOLDSEQNUM(NI)
      [M:PSO3]ITMREF(P3_LIN-1)     = [M:PSO2]ITMREF(NI)
      [M:PSO3]ITMDES(P3_LIN-1)     = [M:PSO2]ITMDES(NI)
      [M:PSO3]ECCVALMAJ(P3_LIN-1)  = [M:PSO2]ECCVALMAJ(NI)
      [M:PSO3]ECCVALMIN(P3_LIN-1)  = [M:PSO2]ECCVALMIN(NI)
      [M:PSO3]SAU(P3_LIN-1)        = [M:PSO2]SAU(NI)
      [M:PSO3]EXTUOM(P3_LIN-1)     = [M:PSO2]EXTUOM(NI)
      [M:PSO3]STU(P3_LIN-1)        = [M:PSO2]STU(NI)
      [M:PSO3]BASPRI(P3_LIN-1)     = [M:PSO2]BASPRI(NI)
      [M:PSO3]APPLYBPRI(P3_LIN-1)  = 1
      [M:PSO3]PBUCOD(P3_LIN-1)     = [M:PSO2]PBUCOD(NI)
      [M:PSO3]PBUDES(P3_LIN-1)     = [M:PSO2]PBUDES(NI)
      [M:PSO3]TASCOD(P3_LIN-1)     = [M:PSO2]TASCOD(NI)
      [M:PSO3]TASDES(P3_LIN-1)     = [M:PSO2]TASDES(NI)
      Gosub GET_PRJLINK
    Else
      # Issue X3-95000 - 2018-06-18 by FGR : BEGIN
      #If [M:PSO3]ITMDES(P3_LIN-1) <> AVOID.ACHAR Then
      #  If [M:PSO3]ITMDES(P3_LIN-1) <> [M:PSO2]ITMDES(NI) Then
      #    Call LECTEXTRA([M:PSO3]ITMDES(P3_LIN-1), "ITMMASTER", "DES1AXX", [M:PSO2]ITMREF(NI), AVOID.ACHAR) From ATEXTRA
      #  Endif
      #Endif
      If [M:PSO3]ITMDES(P3_LIN-1) <> AVOID.ACHAR Then
        Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [M:PSO2]ITMREF(NI), [M:PSO3]ITMDES(P3_LIN-1), "") From TRTX3
      Endif
      # Issue X3-95000 - 2018-06-18 by FGR : END
    Endif
    [M:PSO3]QTY(P3_LIN-1)    += [M:PSO2]QTY(NI)       # Document qty
    [M:PSO3]EXTQTY(P3_LIN-1) += [M:PSO2]EXTQTY(NI)    # Planned qty
    [M:PSO3]QTYSTU(P3_LIN-1) += [M:PSO2]QTYSTU(NI)    # Stocking qty - when on saleable grid recalculate
  Next NI
  [M:PSO3]NBLIG3 = P3_NBLIG
  # -----------------------------
  Affzo [M:PSO2]1-99
  Affzo [M:PSO3]1-99
  zonsui = "[M:PSO3]BASPRI"
  [M:PSO0]CHGFLG = [V]CST_ANO
  # -----------------------------
End

