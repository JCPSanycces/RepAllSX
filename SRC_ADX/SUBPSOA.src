###################################################################################################
$GET_PRJLINK_MATCH
  Case [M:PSO2]PRODGRPLVL(NI)
    When 2
      [M:PSO2]SOLDSEQNUM(NE) = [M:PSO2]SOLDSEQNUM(NI)
    When 3
      If [M:PSO2]PBUCOD(NI) = [M:PSO2]PBUCOD(NE)
        [M:PSO2]SOLDSEQNUM(NE) = [M:PSO2]SOLDSEQNUM(NI)
      Endif
    When 4
      If [M:PSO2]TASCOD(NI) = [M:PSO2]TASCOD(NE)
        [M:PSO2]SOLDSEQNUM(NE) = [M:PSO2]SOLDSEQNUM(NI)
      Endif
    When Default
  Endcase
Return

###################################################################################################
$GET_PRJLINK
  Case [M:PSO2]PRODGRPLVL(NI)
    When 1
      # Not grouped
      If [M:PSO2]TASCOD(NI) = AVOID.ACHAR and [M:PSO2]PBUCOD(NI) = AVOID.ACHAR Then
        # PJMOPP
        [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_PJM(GACTX, [M:PSO0]OPPNUM)
      Elsif [M:PSO2]TASCOD(NI) <> AVOID.ACHAR Then
        # PJMTASK
        [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [M:PSO0]OPPNUM, [M:PSO2]TASCOD(NI))
      Else
        # PJMBUDGET
        [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [M:PSO0]OPPNUM, [M:PSO2]PBUCOD(NI))
      Endif
    When 2
      # Project
      [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_PJM(GACTX, [M:PSO0]OPPNUM)
    When 3
      # Budget
      [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [M:PSO0]OPPNUM, [M:PSO2]PBUCOD(NI))
    When 4
      # Task
      [M:PSO3]PRJLINK(P3_LIN-1) = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [M:PSO0]OPPNUM, [M:PSO2]TASCOD(NI))
  Endcase
Return

###################################################################################################
Subprog GENERATE_DOCUMENT()

Local Char HDOCNUM(GLONVCR)

  # -----------------------------
  # Generate based on type:
  # 1=Quote; 2=Sales order; 3=Direct invoice
  [L]HDOCNUM = AVOID.ACHAR
  # -----------------------------
  If func CHECK_PJTSNGDOC_CONSISTENCY() = [V]CST_ANO Then
    GERR = 1
    GOK = 0
    GMESSAGE = mess(463,2260,1)
    End
  Endif
  # -----------------------------
  Trbegin [F:PSOH]
  Case [M:PSO0]DOCTYP
    When 1
      Call GENERATE_SQH(HDOCNUM)
    When 2
      Call GENERATE_SOH(HDOCNUM)
    When 3
      Call GENERATE_SIH(HDOCNUM)
  Endcase
  If GERR = 0 Then
    # Update PJMSOLITMH with DOCNUM
    [F:PSOH]HDOCNUM = HDOCNUM
    Rewrite [F:PSOH]
    If fstat Then
      GERR = 1
      GOK = 0
      GMESSAGE = func AFNC.MES1(mess(457,2260,1), [F:PSOH]PSONUM)
    Else
      # Update PJMSOLITMD with DOCNUM
      Filter [F:PSOD] Where PSONUM = [M:PSO0]PSONUM
      For [F:PSOD]
        [F:PSOD]DOCNUM = HDOCNUM
        Rewrite [F:PSOD]
        If fstat Then
          GERR = 1
          GOK = 0
          GMESSAGE = func AFNC.MES2(mess(458,2260,1), [F:PSOD]PSONUM, num$([F:PSOD]SEQNUM))
          Break
        Endif
      Next
      Filter [F:PSPLD]
    Endif
    If GOK = 0 Then
      Rollback
    Else
      Commit
    Endif
  Else
    Rollback
  Endif
End

###################################################################################################
Subprog GENERATE_SQH(HDOCNUM)
Variable Char HDOCNUM

  Call EXEC(HDOCNUM) From PJMSQH
End

###################################################################################################
Subprog GENERATE_SOH(HDOCNUM)
Variable Char HDOCNUM

  Call EXEC(HDOCNUM) From PJMSOH
End

###################################################################################################
Subprog GENERATE_SIH(HDOCNUM)
Variable Char HDOCNUM

  Call EXEC(HDOCNUM) From PJMSIH
End

###################################################################################################
# Issue X3-49776 - 2018-06-25 by FGR : BEGIN
Subprog UPDATE_DETAIL_TABLES()

  Call UPDATE_PSOO()
  If GERR = 0 Then
    Call UPDATE_PSOD()
  Endif
End

###################################################################################################
Subprog UPDATE_PSOO()

Local Integer NI
Local Char SKEYCONCAT(250)
Local Integer ILINE

  Local File PJMSOLITMO  [PSOO]
  Local File VPJMSOLITMO [VPSOO]
  # -------------------------------
  Filter [PSOO] Where [F:PSOO]PSONUM = [M:PSO0]PSONUM
  For [PSOO]
    SKEYCONCAT = func GET_PSO2_KEYCONCAT([F:PSOO]PBUCOD, [F:PSOO]TASCOD, [F:PSOO]SEQNUM)
    ILINE = find(SKEYCONCAT, [M:PSO2]KEYCONCAT(0..[M:PSO2]NBLIG2-1))
    If ILINE = 0 Then
      If [M:PSO0]PSOREV = 2 Then
        Call HISTO_REV("PSOO", "A")
      Endif
      Delete [F:PSOO]Curr
    Else
      If [M:PSO2]UPDLIG(ILINE-1) = [V]CST_AYES Then
        If [M:PSO0]PSOREV = 2 Then
          Call HISTO_REV("PSOO", "M")
        Endif
      Endif
    Endif
  Next
  Filter [PSOO]
  # -------------------------------
  For NI = 0 To [M:PSO2]NBLIG2-1
    If [M:PSO2]UPDLIG(NI) = [V]CST_AYES Then
      nolign = NI + 1
      Look [F:PSOO]PSOO0=[M:PSO0]PSONUM;[M:PSO0]OPPNUM;[M:PSO2]PBUCOD(nolign-1);[M:PSO2]TASCOD(nolign-1);[M:PSO2]SEQNUM(nolign-1)
      If fstat = [V]CST_AOK Then
        [F:PSOO] = [M:PSO0]  # Issue X3-95321 - 2018-08-10 by FGR : to increase revision number
        [F:PSOO] = [M:PSO2]
        [F:PSOO]PSOLIN = [M:PSO2]SOLDSEQNUM(NI)
        Rewrite [F:PSOO]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = mess(384,2260,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        Raz [F:PSOO]
        [F:PSOO] = [M:PSO0]
        [F:PSOO] = [M:PSO2]
        [F:PSOO]PSOLIN = [M:PSO2]SOLDSEQNUM(NI)
        Write [F:PSOO]
        If fstat <> [V]CST_AOK Then
          GMESSAGE = mess(384,2260,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

###################################################################################################
Subprog UPDATE_PSOD()

Local Integer NI
Local Char SKEYCONCAT(250)
Local Integer ILINE

  Local File PJMSOLITMD  [PSOD]
  Local File VPJMSOLITMD [VPSOD]
  # -------------------------------
  Filter [PSOD] Where [F:PSOD]PSONUM = [M:PSO0]PSONUM
  For [PSOD]
    If [M:PSO0]PSOREV = 2 Then
      Call HISTO_REV("PSOD", "A")
    Endif
    Delete [F:PSOD]Curr
  Next
  Filter [PSOD]
  #
  For NI = 0 To [M:PSO3]NBLIG3-1
    If [M:PSO3]SEQNUM(NI) > 0 Then
      nolign = NI + 1
      Raz [F:PSOD]
      [F:PSOD] = [M:PSO0]
      [F:PSOD] = [M:PSO3]
      [F:PSOD]CUSTOMER = [M:PSO1]BPCORD
      Write [F:PSOD]
      If fstat <> [V]CST_AOK Then
        GMESSAGE = mess(384,2260,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
End

