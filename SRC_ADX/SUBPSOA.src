###################################################################################################
Funprog CHECK_PJTSNGDOC_CONSISTENCY()

Local Integer I_LINK
Local Integer NI
Local Char L_CPY(GLONCPY)

  I_LINK = [V]CST_AYES
  L_CPY = fmet GACTX.ACACHE.AFCY.AGETVALCHAR([M:PSO1]SALFCY, "LEGCPY")
  If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, L_CPY, "PJTSNGDOC") = [V]CST_AYES Then
    For NI = 1 To [M:PSO3]NBLIG3-1
      If [M:PSO3]PRJLINK(NI) <> [M:PSO3]PRJLINK(NI-1) Then
        I_LINK = [V]CST_ANO
        Break
      Endif
    Next NI
  Endif
End I_LINK

###################################################################################################
Subprog DISPLAY_HIDE_REVNUM(SFCY)
Value Char SFCY

  # Issue X3-49776 - 2018-06-25 by FGR
  If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, SFCY, "PSOREV") = 1 Then
    # Not managed : REVNUM field is hidden
    Chgfmt [M:PSO0]REVNUM With "-N:4#"
  Else
    # Managed : REVNUM field is displayed
    Chgfmt [M:PSO0]REVNUM With "N:4#"
  Endif
End

###################################################################################################
Subprog REVISION_MANAGEMENT()

Local Integer WOK
Local Integer IPSOREV

  # Issue X3-49776 - 2018-06-25 by FGR
  If [M:PSO0]PSOREV <> 0 Then
    End
  Endif
  If find(GREP,"C","D") Then
    End
  Endif
  # --> Request for modification with or without endorsement
  IPSOREV = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [M:PSO1]SALFCY, "PSOREV")
  If IPSOREV = 2 Then
    If func CHECK_PSO_VPSO_TABLES() = [V]CST_AOK Then
      WOK = 1
      If !GIMPORT Then
        Call OUINON(mess(51,194,1), WOK) From GESECRAN
      Endif
      If WOK = 2 Then
        # Issue X3-95321 - 2018-08-08 by FGR : BEGIN
        #[M:PSO0]PSOREV = 2
        #[M:PSO0]REVNUM += 1
        Call INCREMENT_REVISION()
        # Issue X3-95321 - 2018-08-08 by FGR : END
      Endif
    Endif
  Elsif IPSOREV = 3 Then
    If func CHECK_PSO_VPSO_TABLES() = [V]CST_AOK Then
      # Issue X3-95321 - 2018-08-08 by FGR : BEGIN
      #[M:PSO0]PSOREV = 2
      #[M:PSO0]REVNUM += 1
      Call INCREMENT_REVISION()
      # Issue X3-95321 - 2018-08-08 by FGR : END
    Endif
  Else
    [M:PSO0]PSOREV = 1
  Endif
  # Issue X3-95321 - 2018-08-08 by FGR : BEGIN
  #Affzo [M:PSO0]REVNUM
  Affzo [M:PSO0]5
  # Issue X3-95321 - 2018-08-08 by FGR : END
End

###################################################################################################
Subprog INCREMENT_REVISION()

  # Issue X3-95321 - 2018-08-08 by FGR
  [M:PSO0]PSOREV = 2
  [M:PSO0]REVNUM += 1
  If [M:PSO0]DOCTYP = 1 Then
    Raz [M:PSO0]HDOCNUM
  Endif
End

###################################################################################################
Funprog CHECK_PSO_VPSO_TABLES()

Local Integer IARENDRE

  # Issue X3-49776 - 2018-06-25 by FGR
  If GIPSOCHKTBL = [V]CST_AFALSE Then
    # Optimization to do that only once when function is called
    IARENDRE = func CHECK_TABLES_CONSISTENCY("PJMSOLITMH", "VPJMSOLITMH", GMESSAGE)
    If IARENDRE = [V]CST_AERROR Then
      GOK = 0
      GERR = 1
    Else
      IARENDRE = func CHECK_TABLES_CONSISTENCY("PJMSOLITMD", "VPJMSOLITMD", GMESSAGE)
      If IARENDRE = [V]CST_AERROR Then
        GOK = 0
        GERR = 1
      Else
        IARENDRE = func CHECK_TABLES_CONSISTENCY("PJMSOLITMO", "VPJMSOLITMO", GMESSAGE)
        If IARENDRE = [V]CST_AERROR Then
          GOK = 0
          GERR = 1
        Else
          GIPSOCHKTBL =[V]CST_ATRUE
        Endif
      Endif
    Endif
  Endif
End IARENDRE

###################################################################################################
Funprog CHECK_TABLES_CONSISTENCY(SFROMTBL, STOTBL, SMESSAGE)
Value Char SFROMTBL
Value Char STOTBL
Variable Char SMESSAGE

Local Integer IARENDRE

  # Issue X3-49776 - 2018-06-25 by FGR
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # --------------------
  Local File ATABZON [ATZF]  # FROM
  Local File ATABZON [ATZT]  # TO
  # --------------------
  Filter [ATZF] Where [F:ATZF]CODFIC = SFROMTBL
  For [ATZF]
    Read [ATZT]CODZONE=STOTBL;[F:ATZF]CODZONE
    If fstat Then
      IARENDRE = [V]CST_AERROR
      SMESSAGE = func AFNC.MES3(mess(1063,2260,1), SFROMTBL, STOTBL, [F:ATZF]CODZONE)
      Break
    Endif
  Next
  Filter [ATZF]
End IARENDRE

###################################################################################################
Subprog HISTO_REV(ABFIC, TRAIT)
Value Char ABFIC
Value Char TRAIT

  # Issue X3-49776 - 2018-06-25 by FGR
  Case ABFIC
    When "PSOH"
      Call HISTO_PSOH(ABFIC, TRAIT)
    When "PSOO"
      Call HISTO_PSOO(ABFIC, TRAIT)
    When "PSOD"
      Call HISTO_PSOD(ABFIC, TRAIT)
    When Default
  Endcase
End

###################################################################################################
Subprog HISTO_PSOH(ABFIC, TRAIT)
Value Char ABFIC
Value Char TRAIT

  # Issue X3-49776 - 2018-06-25 by FGR
  [F:VPSOH] = [F:PSOH]
  [F:VPSOH]CURREVFLG = [V]CST_ANO
  [F:VPSOH]REVCOD = TRAIT
  Write [VPSOH]
  If fstat Then
    GOK = 0
    Call FSTA("VPSOH") From GLOCK
  Endif
End

###################################################################################################
Subprog HISTO_PSOO(ABFIC, TRAIT)
Value Char ABFIC
Value Char TRAIT

  # Issue X3-49776 - 2018-06-25 by FGR
  [F:VPSOO] = [F:PSOO]
  If TRAIT = "A" Then
    Call HISTO_PSOO(ABFIC, "M")
    [F:VPSOO]REVNUM = [M:PSO0]REVNUM
  Else
    [F:VPSOO]REVNUM = [M:PSO0]REVNUM - 1
  Endif
  [F:VPSOO]REVCOD = TRAIT
  Write [VPSOO]
  If fstat Then
    GOK = 0
    Call FSTA("VPSOO") From GLOCK
  Endif
End

###################################################################################################
Subprog HISTO_PSOD(ABFIC, TRAIT)
Value Char ABFIC
Value Char TRAIT

  # Issue X3-49776 - 2018-06-25 by FGR
  [F:VPSOD] = [F:PSOD]
  [F:VPSOO]REVNUM = [M:PSO0]REVNUM - 1
  [F:VPSOD]REVCOD = TRAIT
  Write [VPSOD]
  If fstat Then
    GOK = 0
    Call FSTA("VPSOD") From GLOCK
  Endif
End

###################################################################################################
Funprog INIT_VPJMSOLITMH_RECORD(SSALFCY, SPSONUM, IREVNUM)
Value Char SSALFCY
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer IPSOREV

  # Issue X3-49776 - 2018-06-25 by FGR
  IARENDRE = [V]CST_AOK
  # ----------------------
  IPSOREV = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, SSALFCY, "PSOREV")
  If IPSOREV = 2 or IPSOREV = 3 Then
    # ----------------------
    Local File VPJMSOLITMH [VPSOH]
    # ----------------------
    Look [VPSOH]VPSOH0=SPSONUM;IREVNUM
    If fstat <> [V]CST_AOK Then
      IADXLOG = (adxlog = 1)
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [F:VPSOH]
      Endif
      # ----------------------
      Raz [F:VPSOH]
      [F:VPSOH]PSONUM = SPSONUM
      [F:VPSOH]REVNUM = IREVNUM
      [F:VPSOH]SALFCY = SSALFCY
      [F:VPSOH]CURREVFLG = [V]CST_AYES
      Write [VPSOH]
      If fstat Then
        GERR = 1
        GMESSAGE = mess(1095,2260,1)
        IARENDRE = [V]CST_AERROR
      Endif
      # ----------------------
      If IADXLOG = [V]CST_AFALSE Then
        If IARENDRE < [V]CST_AERROR Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Else
      GERR = 1
      GMESSAGE = mess(1095,2260,1)
      IARENDRE = [V]CST_AERROR
    Endif
  Endif
End IARENDRE

###################################################################################################
Funprog INCREASE_VPJMSOLITMH_RECORD(SSALFCY, SPSONUM, IOLDREVNUM, INEWREVNUM)
Value Char SSALFCY
Value Char SPSONUM
Value Integer IOLDREVNUM
Value Integer INEWREVNUM

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer IPSOREV

  # Issue X3-49776 - 2018-06-25 by FGR
  IARENDRE = [V]CST_AOK
  # ----------------------
  IPSOREV = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, SSALFCY, "PSOREV")
  If IPSOREV = 2 or IPSOREV = 3 Then
    # ----------------------
    Local File VPJMSOLITMH [VPSOH]
    # ----------------------
    Read [VPSOH]VPSOH0=SPSONUM;IOLDREVNUM
    If fstat = [V]CST_AOK Then
      IADXLOG = (adxlog = 1)
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [F:VPSOH]
      Endif
      If [F:VPSOH]CURREVFLG = [V]CST_AYES Then
        [F:VPSOH]REVNUM = INEWREVNUM     # Increate the revision number
        Rewrite [VPSOH]
        If fstat Then
          GERR = 1
          GMESSAGE = mess(1095,2260,1)
        Endif
      Else
        # Revision line given doesn't "[F:VPSOH]CURREVFLG = [V]CST_AYES".
        # Wrong : we are going to try to fix that to avoid an error
        Filter [VPSOH] Where [F:VPSOH]PSONUM = SPSONUM and [F:VPSOH]CURREVFLG = [V]CST_AYES
        For [VPSOH]
          Delete [VPSOH]Curr
        Next
        Filter [VPSOH]
        IARENDRE = func INIT_VPJMSOLITMH_RECORD(SSALFCY, SPSONUM, INEWREVNUM)
      Endif
      If IADXLOG = [V]CST_AFALSE Then
        If IARENDRE < [V]CST_AERROR Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Else
      # Line is not existing : we are going to create it
      IARENDRE = func INIT_VPJMSOLITMH_RECORD(SSALFCY, SPSONUM, INEWREVNUM)
    Endif
  Endif
End IARENDRE

###################################################################################################
Funprog GET_PSO2_KEYCONCAT(SPBUCOD, STASCOD, ISEQNUM)
Value Char SPBUCOD
Value Char STASCOD
Value Integer ISEQNUM

Local Char SRENDRE(250)

  # Issue X3-49776 - 2018-06-25 by FGR
  SARENDRE = SPBUCOD + "~" + STASCOD + "~" + num$(ISEQNUM)
End SARENDRE

###################################################################################################
Subprog ACTZO_DISZO()

  # Issue X3-95321 - 2018-08-08 by FGR
  Local File VPJMSOLITMH [VPSOH]
  # ----------------------
  Diszo [M:PSO0]OPPNUM
  Diszo [M:PSO1]CUR
  Diszo [M:PSO1]SALFCY
  #
  Case [M:PSO0]DOCTYP
    When 1
      # Quote
      If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
        # If quote has been created : forbidden to modify [M:PSO0]DOCTYP
        If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [M:PSO1]SALFCY, "PSOREV") = 1 Then
          # Quote never updatable when document has been created and revisions not managed.
          Diszo [M:PSO0]5
          Diszo [M:PSO1]3
          Diszo [M:PSO1]5
          Diszo [M:PSO2]10
          Diszo [M:PSO3]10
        Else
          # When quote has been created, not possible to modify DOCTYP : will stay mandatory for a quote
          Diszo [M:PSO0]DOCTYP
        Endif
      Else
        # If at least, a quote has been created in revision
        If [M:PSO0]REVNUM > 0 Then
          Filter [VPSOH] Where [F:VPSOH]PSONUM = [M:PSO0]PSONUM and [F:VPSOH]HDOCNUM <> AVOID.ACHAR
          For [VPSOH]
            # When quote has been created, not possible to modify DOCTYP : will stay mandatory for a quote
            Diszo [M:PSO0]DOCTYP
            Break
          Next
          Filter [VPSOH]
        Endif
      Endif
    When 2, 3
      # Sales order or sales invoice : Never updatable when a document has been created
      If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
        Diszo [M:PSO0]5
        Diszo [M:PSO1]3
        Diszo [M:PSO1]5
        Diszo [M:PSO2]10
        Diszo [M:PSO3]10
      Endif
  Endcase
End

###################################################################################################
Subprog LOAD_QUOTES()

Local Char SICO(GLONICO)
Local Integer NI

  # Issue X3-95321 - 2018-08-08 by FGR
  Local File VPJMSOLITMH [VPSOH]
  # ----------------------
  Case [M:PSO0]DOCTYP
    When 1
      # Quote
      SICO = "55"
      Effzo [M:PSO4]
      nolign = 0
      If [M:PSO0]HDOCNUM <> AVOID.ACHAR Then
        nolign += 1
        [M:PSO4]QREVNUM(nolign-1) = [F:PSOH]REVNUM
        [M:PSO4]QHDOCNUM(nolign-1) = [F:PSOH]HDOCNUM
        [M:PSO4]QVLYDAT(nolign-1) = [F:PSOH]VLYDAT
        [M:PSO4]QDOCDAT(nolign-1) = [F:PSOH]DOCDAT
        [M:PSO4]CRRREV(nolign-1) = "51"
        Call LOAD_QUOTES_AMOUNTS([M:PSO4]QHDOCNUM(nolign-1))
        Raz SICO
      Endif
      Filter [VPSOH] Where [F:VPSOH]PSONUM = [M:PSO0]PSONUM and [F:VPSOH]HDOCNUM <> AVOID.ACHAR Order By Key KEY0=[F:VPSOH]PSONUM;[F:VPSOH]REVNUM Desc
      For [VPSOH]KEY0
        # When quote has been created, not possible to modify DOCTYP : will stay mandatory for a quote
        nolign += 1
        [M:PSO4]QREVNUM(nolign-1) = [F:VPSOH]REVNUM
        [M:PSO4]QHDOCNUM(nolign-1) = [F:VPSOH]HDOCNUM
        [M:PSO4]QVLYDAT(nolign-1) = [F:VPSOH]VLYDAT
        [M:PSO4]QDOCDAT(nolign-1) = [F:VPSOH]DOCDAT
        [M:PSO4]CRRREV(nolign-1) = SICO
        Call LOAD_QUOTES_AMOUNTS([M:PSO4]QHDOCNUM(nolign-1))
        Raz SICO
      Next
      Filter [VPSOH]
      [M:PSO4]NBLIG4 = nolign
      Affzo [M:PSO4]
      For NI = 0 To [M:PSO4]NBLIG4-1
        If [M:PSO4]CRRREV(NI) = func GET_ICON_BASKET() Then
          Chgstl [M:PSO4]QHDOCNUM(NI) With "PJMWARN1"
        Endif
      Next NI
      Affzo [M:PSO4]
    When 2, 3
      # Sales order or sales invoice
      Effzo [M:PSO4]
  Endcase
End

###################################################################################################
Subprog LOAD_QUOTES_AMOUNTS(SSQHNUM)
Value Char SSQHNUM

  # Issue X3-95321 - 2018-08-08 by FGR
  Local File SQUOTE [SQH]
  # ----------------------
  Read [SQH]SQH0=SSQHNUM
  If fstat = [V]CST_AOK Then
    [M:PSO4]QCUR(nolign-1) = [F:SQH]CUR
    [M:PSO4] = [F:SQH]
  Else
    [M:PSO4]CRRREV(nolign-1) = func GET_ICON_BASKET()
  Endif
End

###################################################################################################
Funprog GET_ICON_BASKET()

Local Char SARENDRE(GLONICO)

  # Issue X3-95321 - 2018-08-08 by FGR
  SARENDRE = "143"
End SARENDRE

