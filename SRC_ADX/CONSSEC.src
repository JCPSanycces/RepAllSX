Call CONSSEC("",0,"","","",[0/0/0],[0/0/0],"","","")
End

#####################################################################
## GH 03/09/99 Nouvelle consultation de section gérée par GCONSULT ##
#####################################################################
Subprog CONSSEC(CECRAN,CAXE,CSEC,CSOC,CSITE,CDEB,CFIN,CDEV,CFILTRE,COPT) 
Value Integer CAXE
Value Char    CECRAN
Value Char    CSEC
Value Char    CSOC
Value Char    CSITE
Value Date    CDEB
Value Date    CFIN
Value Char    CDEV
Value Char    CFILTRE
Value Char    COPT
Local Char    PARAM(250)(1..9)

PARAM(1) = num$(CAXE)
PARAM(2) = CSEC
PARAM(3) = CSITE
PARAM(4) = CSOC
PARAM(5) = CDEB
PARAM(6) = CFIN
PARAM(7) = CDEV
PARAM(8) = CFILTRE
PARAM(9) = COPT
Call GCONSULT("SEC",CECRAN,PARAM) From GCONSULT
End
