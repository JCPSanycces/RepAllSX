##########################################################################################################
#   Ajout d'un Tiers destinataire                                   Module CRM         01 décembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIBMAY3MODIF

  GIBMAY3MODIF = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIBMAY3MODIF = 1 Then
    Call LOADRESULT(1,1) From TRTMAI4
    Affzo [M:MAI4]1-99
  Endif
  #Nettoie l'écran avant de partir.
  Raz [M:MAY3]
  Kill GIBMAY3MODIF
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Integer ICURLIGNE

  ICURLIGNE = nolign-1
  Case BOUT
    When "A"
      Gosub ONCHECK
    When "C"
      Gosub ONLOAD From TRTMAY3
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONCHECK
Local Char SZMESS(250)
Local Integer IOKREP
Local Integer IBPRFOUND
Local Integer ILIGNE

  IOKREP = 0
  IBPRFOUND = 0
  If ICURLIGNE < 0 Then
    Return
  Endif
  If [M:MAY3]BPRNUM(ICURLIGNE) = "" Then
    GMESSAGE = mess(807,196,1) #Aucun tiers n'est sélectionné. Vérification abandonnée.
    GERR = 2
    Return
  Endif
  Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]RECNUM = [M:MAY3]BPRNUM(ICURLIGNE)
  For [SCL] SCL1
    IBPRFOUND = 1
    Break 
  Next
  Filter [SCL]
  If !IBPRFOUND Then
    If GNAVIG(GPILNAV) = "GESOMM" or GNAVIG(GPILNAV) = "GESOMP" Then
      #Ce tiers n'est pas inclus dans l'échantillon composant l'opération marketing.
      GMESSAGE = mess(675,182,1)
      GERR = 2
    Else
      #Ce tiers n'est pas inclus dans la sélection.
      #Souhaitez-vous l'ajouter à la sélection ?
      SZMESS = mess(798,196,1) - mess(799,196,1)
      Call OUINON(SZMESS, IOKREP) From GESECRAN
      If IOKREP = 2 Then
        Gosub ONADD
      Endif
    Endif
  Else
    If GNAVIG(GPILNAV) = "GESOMM" or GNAVIG(GPILNAV) = "GESOMP" Then
      #Ce tiers est inclus dans l'échantillon composant l'opération marketing.
      GMESSAGE = mess(676,182,1)
      GERR = 2
    Else
      #Ce tiers est déjà inclus dans la sélection.
      #Souhaitez-vous le supprimer de la sélection ?
      SZMESS = mess(358,196,1) - mess(800,196,1)
      Call OUINON(SZMESS, IOKREP) From GESECRAN
      If IOKREP = 2 Then
        Gosub ONDEL
      Endif
    Endif
  Endif
Return

##########################################################################################################
$ONADD
  GIBMAY3MODIF = 1
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  [F:SCL]OPGNUM = GSZOPGNUM
  [F:SCL]RECTYP = "BPR"
  [F:SCL]RECNUM = [M:MAY3]BPRNUM(ICURLIGNE)
  [F:SCL]BPRNUM = ""
  [F:SCL]BPAADD = ""
  Write [SCL]
  If fstat Then
    GMESSAGE = mess(100,141,1) #Erreur création
    GERR = 1
    Rollback
  Else
    Commit
  Endif
Return

##########################################################################################################
# Suppression d'un destinataire
###############################################################
$ONDEL
  GIBMAY3MODIF = 1
  If [M:MAY3]BPRNUM(ILIGNE) <> "" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]RECNUM = [M:MAY3]BPRNUM(ICURLIGNE)
    For [SCL]SCL1
      Call DEBTRANS From GLOCK
      Trbegin [SCL]
      Delete [SCL] Curr
      If fstat Then
        GMESSAGE = mess(425,196,1) #Erreur lors de la suppression du destinataire. Opération refusée.
        GERR = 1
        Rollback
        # FGR 09/02/2010 : X3SUIVI60986
        #Return
        Break
      Else
        Commit
      Endif
    Next
    Filter [SCL]
    If GERR Then
      # FGR 09/02/2010 : X3SUIVI60986
      Return
    Endif
  Else
    GMESSAGE = mess(802,196,1) #Aucun tiers n'est sélectionné. Suppression refusée.
    GERR = 2
  Endif
Return
