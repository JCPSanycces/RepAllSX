#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# UTIINDFIXR7 
# ---------------------------------------------------------------------- #
#      mise a jour du champs NUMP dans APATCH suite à la 2018R1    
# n etait pas a jour car on cumule en 2018R1 : patch 7 et patch 8
# pour la R6 la deniere mnt est 537 et pour patch 8 la premiere est 671
# il y a un trou car 2017R7 n a pas été livré chez les clients.
##########################################################################
Infbox "only update folder by patch"
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour aussi le dossier X3
#If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTIINDFIXR7 (APPLI)  
End



Subprog EXE_UTIINDFIXR7(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)

#-----
Call ECR_TRACE("UTIINDFIXR7: Update APATCH for Folder "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ZZZ]) =0  Local File =LDOSSIER+".APATCH"     [ZZZ] : Endif
If clalev([F:ZZR]) =0  Local File =LDOSSIER+".APATCH"     [ZZR] : Endif
If clalev([F:ZZW]) =0  Local File =LDOSSIER+".APATCH"     [ZZW] : Endif

#-----
$MISE_JOUR_APATCH
#-----------------------------#
#   mise a jour table APATCH  #
#-----------------------------#
Local Integer WNUM
WNUM= 0
#
Filter [ZZZ] 
Read [ZZZ]Last 
If fstat = 0
      WNUM = [F:ZZZ]NUM + 1
Endif
Filter [ZZZ]

Filter [ZZZ] Where TYP= "P" and FICRELABR= "R090"
# 
Read [ZZZ]Last 
If fstat = 0
      # controle que ce soit un record de la r6 
      # si pas le cas on ne fera rien
      If [F:ZZZ]PATNUM  <= 6
          Read [ZZR]APT0 = WNUM
          If fstat = 0
                Call ECR_TRACE("problem during recover the last record of APATCH ",0) From GESECRAN
          Else
                Trbegin [ZZW]
                     [F:ZZW]=[F:ZZZ]
                     [F:ZZW]NUM       = WNUM
                     [F:ZZW]NUMP      = 670
                     [F:ZZW]FICRELABR = "R090"
                     [F:ZZW]PATNUM    = 7 
                     [F:ZZW]RELEASE   = "R090.007"
                     Write [ZZW] 
                     If fstat 
                         Call ERREUR("APATCH",2) From DOSDIC 
                     Else
                         Call ECR_TRACE("Creation APATCH record "+num$(WNUM),0) From GESECRAN
                     Endif 
                 Commit
          Endif
      Endif
Endif

Filter [ZZZ]

#----- Fin du traitement -----#
$FIN_UTIINDFIXR7
WMSG ="UTIINDFIXR7: end of Update APATCH"
Call ECR_TRACE(WMSG,0) From GESECRAN

End




