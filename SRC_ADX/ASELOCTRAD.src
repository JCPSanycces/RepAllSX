#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# Action ASELOCTRAD : Sélection des Menus Locaux à Traduire              #
# ---------------------------------------------------------------------- #
# JPGA 05/02/2013                                                        #
# ---------------------------------------------------------------------- #
#   Parametre 1 : Langue de Traduction
#   Parametre 2 : Langue de Référence
#   Parametre 3 : Tous les Modules
#   Parametre 4 : Module
#   Parametre 5 : Tous les Opérateurs
#   Parametre 6 : Opérateur
# ---------------------------------------------------------------------- #
#   Branchement : Action sur Champs : Chapitre de Message                #
#   dans la fonction de Traduction des Menus locaux : ALOCTRAD           #
##########################################################################
#JPGA 06/02/2013 EXI-87047-1 : Création d'une Sélection des Menus Locaux et Messages A traduire
##########################################################################
$ACTION
Case ACTION
  When  "SEL_LISTE"    :  Gosub SEL_LISTE
  When  "VERF_LISTE"   :  Gosub VERF_LISTE
  When  "FIN_LISTE"    :  Gosub FIN_LISTE
  When  Default
Endcase
Return

$SEL_LISTE
  Case LISTE
    When "ASELOCTRAD" : Gosub SEL_ASELOCTRAD
  Endcase
Return

$VERF_LISTE
  Case LISTE
    When "ASELOCTRAD" : Gosub VERF_ASELOCTRAD
  Endcase
Return

$FIN_LISTE
  Case LISTE
    When "ASELOCTRAD" : Gosub FIN_ASELOCTRAD
  Endcase
Return

##########################################################################
# ACTIONS DU MODELE : SELECTION DANS LISTE                               #
##########################################################################
$SEL_ASELOCTRAD
  Local Integer NB_TEXTE : [L]NB_TEXTE=5  # ATTENTION : Saisir ici le nombre de colonnes à afficher dans la fenêtre de Sélection
  Local Char    TEX(10)(0..9999)
  Local Char    TEXTE(100)(1..9999,1..[L]NB_TEXTE)
  Local Integer I, J, K, TRADUISIBLE
  # Variable pour la Plage des Menus Locaux
  Local Integer CHAPITRE_ENTETE, CHAPITRE_DETAIL, WDEB_PLG (1..100), WFIN_PLG (1..100), WNBR_PLG, WIND_PLG
  Local Char    FILTRE_PLAGE(250), FILTRE_CRITERES(250), FILTRE_MESSAGES(250), OPECRE(GLONAUS), MESSAGE_TRADUIRE(200)

  # Variables stockant les différents Paramètres
  Local Char    PARAM_LAN(GLONLAN), PARAM_LANREF(GLONLAN), PARAM_CHPUSR(GLONAUS)
  Local Integer PARAM_MODULE      , PARAM_ALLMOD         , PARAM_ALLCHPUSR

  # Variable de sortie retournant la valeur sélectionnnée à l'objet appelant
  If dim([V]ASELOCTRAD_VALUE)<=0 : Global Integer ASELOCTRAD_VALUE : Endif

  If PARAM(1)="" | PARAM(2)="" | PARAM(3)="" | PARAM(5)=""
    GMESSAGE=LISTE-":"-mess(232,123,1)  : GERR=1 : Return  # Variable paramètre inexistante
  Else
    # Préparation des variables nécessaires
    [L]PARAM_LAN       = PARAM(1)
    [L]PARAM_LANREF    = PARAM(2)
    [L]PARAM_ALLMOD    = val(PARAM(3))
    [L]PARAM_MODULE    = val(PARAM(4))
    [L]PARAM_ALLCHPUSR = val(PARAM(5))
    [L]PARAM_CHPUSR    = PARAM(6)
    NBTEX = 0

    If !clalev([F:AST1])  :  Local File APLSTD  [AST1]  :  Endif
    If !clalev([F:AST2])  :  Local File APLSTD  [AST2]  :  Endif
    If !clalev([F:AST3])  :  Local File APLSTD  [AST3]  :  Endif
    If !clalev([F:AST4])  :  Local File APLSTD  [AST4]  :  Endif
    If !clalev([F:AML1])  :  Local File AMENLOC [AML1]  :  Endif
    If !clalev([F:AML2])  :  Local File AMENLOC [AML2]  :  Endif
    If !clalev([F:ACD])   :  Local File ACTLDEV [ACD]   :  Endif

    # Boucle de remplissage de la fenêtre de sélection
    Gosub CHARGE_MENUSLOCAUX

    # Boucle de remplissage du Titre des colonnes de la fenêtre de sélection
    Gosub CHARGE_TITRECOLONNES
  Endif
Return
##########################################################################

$CHARGE_MENUSLOCAUX

  # Mise en place des Filtres sur les Menus locaux pour : MODULE
  Gosub CHARGE_FILTRES

  # Si la Langue de TRAD est le FRA : On charge le SPE
  If [L]PARAM_LAN = GFRA
    [L]FILTRE_PLAGE=' 1=2 '
    # on charge ici le tableau
    Gosub CHARGE_SPE From ALOCTRAD
    # on boucle sur toutes les tranches autre que std
    If WNBR_PLG <> 0
      I=1  :  WIND_PLG=0
      While I = 1
        WIND_PLG+=1
        If WIND_PLG > WNBR_PLG
          I=2
        Else
          [L]FILTRE_PLAGE=' LANNUM>='      +num$(WDEB_PLG(WIND_PLG))+" & "+ ' LANNUM<='      +num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MENUS_0
          [L]FILTRE_PLAGE=' (LANNUM+200)>='+num$(WDEB_PLG(WIND_PLG))+" & "+ ' (LANNUM+200)<='+num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MENUS_200
          [L]FILTRE_PLAGE=' LANCHP>='      +num$(WDEB_PLG(WIND_PLG))+" & "+ ' LANCHP<='      +num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MESSAGES
        Endif
      Wend
    Endif
  Else
    # Si la Langue de TRAD n'est pas le FRA
    [L]FILTRE_PLAGE=' 1=1 '
    Gosub TRAITE_MENUS_0
    Gosub TRAITE_MENUS_200
    Gosub TRAITE_MESSAGES
  Endif
Return
##########################################################################

$TRAITE_MENUS_0
    ### ----------------------------------------###
    ### on charge les Menus locaux : Chapitre 0 ###
    ### ----------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANCHP=0   and LANNUM>0 and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANNUM           As [ASTZ] Where [AML1]MENLOCAL=2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANNUM
      Gosub CHARGE_ENTETE          # Traitement de l'intitulé du Menu local/Message : EN-TETE
      Gosub CHARGE_DETAIL          # Traitement des messages  du Menu local/Message : DETAIL
    Next ASTZ
    Filter [F:AST1]
Return

$TRAITE_MENUS_200
    ### ------------------------------------------###
    ### on charge les Menus locaux : Chapitre 200 ###
    ### ------------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANCHP=200 and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANNUM+200       As [ASTZ] Where [AML1]MENLOCAL=2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANNUM+200
      Gosub CHARGE_ENTETE          # Traitement de l'intitulé du Menu local/Message : EN-TETE
      Gosub CHARGE_DETAIL          # Traitement des messages  du Menu local/Message : DETAIL
    Next ASTZ
    Filter [F:AST1]
Return

$TRAITE_MESSAGES
    ### -----------------------------------------------###
    ### on charge les Messages : Chapitre 8900 à 30000 ###
    ### -----------------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANNUM=0   and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP           As [ASTZ] Where [AML1]MENLOCAL<>2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANCHP
      Gosub CHARGE_ENTETE          # Traitement de l'intitulé du Menu local/Message : EN-TETE
      Gosub CHARGE_DETAIL          # Traitement des messages  du Menu local/Message : DETAIL
    Next ASTZ
    Filter [F:AST1]
Return

$CHARGE_ENTETE
  # Mise en place des Filtres sur les messages pour : OPERATEUR
  Raz [L]FILTRE_MESSAGES
  [L]FILTRE_MESSAGES+=string$([L]CRITERES_USR1<>"", string$([L]FILTRE_MESSAGES<>"",' & ') + [L]CRITERES_USR1)
  [L]FILTRE_MESSAGES+=string$([L]FILTRE_MESSAGES=""," 1=1 ")
  If evalue([L]FILTRE_MESSAGES)
    [L]TRADUISIBLE=0
    [L]OPECRE=string$([F:AST1]UPDUSR<>"",[F:AST1]UPDUSR)+string$([F:AST1]UPDUSR="",[F:AST1]CREUSR)

    # Lecture du Menul local dans la langue pour savoir s'il est traduisible
    Read [AST2]CLE=[AST1]LANCHP;[AST1]LANNUM;[L]PARAM_LAN
    If !fstat
      [L]TRADUISIBLE=func ALOCTRAD.IS_TRADUISIBLE([AST2]LANMES, [AST1]LANMES, [AST2]LANORI, [AML1]NONTRA)
      If [L]TRADUISIBLE
        [L]MESSAGE_TRADUIRE=format$("N0:5",0)-"-"-[AST1]LANMES
        Gosub CHARGE_COLONNES
      Endif
    Else
        [L]MESSAGE_TRADUIRE=format$("N0:5",0)-"-"
        Gosub CHARGE_COLONNES
    Endif
  Endif
Return

$CHARGE_DETAIL
  # On ne fait la recherche dans les Messages
  Filter [AST3] Where LAN = [L]PARAM_LANREF and LANCHP=[L]CHAPITRE_ENTETE and LANNUM<>0
  Link   [AST3] With  [AML2]MENLOC=[L]CHAPITRE_ENTETE     As [ASTY]
  For [ASTY]
    Gosub CHARGE_MESSAGE
  Next ASTY
Return

$CHARGE_MESSAGE
  # Mise en place des Filtres sur les messages pour : OPERATEUR
  Raz [L]FILTRE_MESSAGES
  [L]FILTRE_MESSAGES+=string$([L]CRITERES_USR3<>"", string$([L]FILTRE_MESSAGES<>"",' & ') + [L]CRITERES_USR3)
  [L]FILTRE_MESSAGES+=string$([L]FILTRE_MESSAGES=""," 1=1 ")
  If evalue([L]FILTRE_MESSAGES)
    [L]TRADUISIBLE=0
    [L]OPECRE=string$([F:AST3]UPDUSR<>"",[F:AST3]UPDUSR)+string$([F:AST3]UPDUSR="",[F:AST3]CREUSR)

    # Lecture du Menul local dans la langue pour savoir s'il est traduisible
    Read [AST4]CLE=[AST3]LANCHP;[AST3]LANNUM;[L]PARAM_LAN
    If !fstat
      [L]TRADUISIBLE=func ALOCTRAD.IS_TRADUISIBLE([AST4]LANMES, [AST3]LANMES, [AST4]LANORI, [AML2]NONTRA)
      If [L]TRADUISIBLE
        [L]MESSAGE_TRADUIRE=format$("N0:5",num$([AST3]LANNUM))-"-"-[AST3]LANMES
        Gosub CHARGE_COLONNES
      Endif
    Else
        [L]MESSAGE_TRADUIRE=format$("N0:5",num$([AST3]LANNUM))-"-"
        Gosub CHARGE_COLONNES
    Endif
  Endif
Return

$CHARGE_FILTRES
  Raz [L]FILTRE_CRITERES

  Gosub INITIALISATION_FILTRES

  [L]FILTRE_CRITERES+=string$([L]CRITERES_MODULE<>"", string$([L]FILTRE_CRITERES<>"",' & ') + [L]CRITERES_MODULE)
  [L]FILTRE_CRITERES+=string$([L]FILTRE_CRITERES=""," 1=1 ")
Return

$INITIALISATION_FILTRES
  If dim([L]CRITERES_MODULE)<=0 | dim([L]CRITERES_CHPUSR)<=0 | dim([L]CRITERES_USR1)<=0 | dim([L]CRITERES_USR3)<=0
    Local Char CRITERES_MODULE(200), CRITERES_CHPUSR(200), CRITERES_USR1(200), CRITERES_USR3(200)
  Endif

  [L]CRITERES_MODULE =string$([L]PARAM_ALLMOD<>2   ,'([F:AML1]MODULE='+num$([L]PARAM_MODULE) +')')
  [L]CRITERES_CHPUSR =string$([L]PARAM_ALLCHPUSR<>2,'(([F:AML1]UPDUSR="" & [F:AML1]CREUSR="'+[L]PARAM_CHPUSR+'") | ([F:AML1]UPDUSR<>"" & [F:AML1]UPDUSR="'+[L]PARAM_CHPUSR+'"))')
  [L]CRITERES_USR1   =string$([L]PARAM_ALLCHPUSR<>2,'(([F:AST1]UPDUSR="" & [F:AST1]CREUSR="'+[L]PARAM_CHPUSR+'") | ([F:AST1]UPDUSR<>"" & [F:AST1]UPDUSR="'+[L]PARAM_CHPUSR+'"))')
  [L]CRITERES_USR3   =string$([L]PARAM_ALLCHPUSR<>2,'(([F:AST3]UPDUSR="" & [F:AST3]CREUSR="'+[L]PARAM_CHPUSR+'") | ([F:AST3]UPDUSR<>"" & [F:AST3]UPDUSR="'+[L]PARAM_CHPUSR+'"))')
Return

##########################################################################
# ETIQUETTES de chargement de la Fenêtre Sélection : Titres des colonnes et Contenus et Valeurs Résultat
##########################################################################
$CHARGE_TITRECOLONNES
  # Initialisation du Titre de la Fenêtre de sélection ainsi que du nom des Colonnes
  For I = 0 To [L]NB_TEXTE
    Case I
      When 0 : TIT(I) = mess(23,125,1)+"/"+mess(23,9021,1)-"-"-mess(57,176,1)-"("+num$(NBTEX)-mess(140,115,1)+")" # Titre de la liste : Menus locaux/Messages - A traduire
      When 1 : TIT(I) = mess(80,123,1)                # Titre de la colonne 1 : Chapitre          : 1
      When 2 : TIT(I) = mess(82,123,1)-mess(80,123,1) # Titre de la colonne 2 : Intitulé Chapitre : Oui/Non
      When 3 : TIT(I) = mess(10,144,1)                # Titre de la colonne 3 : Module            : 0
      When 4 : TIT(I) = mess(201,124,1)-"-"-mess(57,176,1) # Titre de la colonne 4 : Messages - A traduire
      When 5 : TIT(I) = mess(132,9139,1)              # Titre de la colonne 5 : Opérateur         : MB
      When Default : Raz TIT(I)
    Endcase
  Next I
Return

$CHARGE_COLONNES
    NBTEX += 1
    # Valeur du Champs de SORTIE : n° de Chapitre
    TEX(NBTEX) = format$("N:5#[ ]",[L]CHAPITRE_ENTETE)

    # Listes des valeurs des colonnes de la fenêtre de sélection
    #TEXTE(NBTEX,1) = num$([L]CHAPITRE_ENTETE)
    TEXTE(NBTEX,1) = format$("N0:5",[L]CHAPITRE_ENTETE)
    TEXTE(NBTEX,2) = [F:ASTZ]LANMES
    Read [AST2]CLE=14;[F:AML1]MODULE;[V]GLANGUE
    If fstat : Raz TEXTE(NBTEX,3) : Else : TEXTE(NBTEX,3) = [AST2]LANMES : Endif
    TEXTE(NBTEX,4) = [L]MESSAGE_TRADUIRE
    TEXTE(NBTEX,5) = [L]OPECRE
Return
##########################################################################

$VERF_ASELOCTRAD
  If NBTEX=1
    # Un seul Enregistrement Trouvé !
    Call AVERTIR(func AFNC.MES(mess(220,115,1),"1")-":"-TEX(NBTEX)-"-"-TEXTE(NBTEX,2),OK) From GESECRAN
    If OK<>2 : GERR=1 : Raz VALEUR : FIN = 1 : Return : Endif
  Endif
Return
##########################################################################

$FIN_ASELOCTRAD
  # Si l'objet Appelant le nécessite : on renseigne une globale permettant de retourner la valeur saisie.
  [V]ASELOCTRAD_VALUE=val(VALEUR)
Return
##########################################################################


##########################################################################
# SOUS-PROGRAMMES UTILISES                                               #
##########################################################################
#                :                                                       #
##########################################################################
##########################################################################


