#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GYM",GBIDC1,GBIDC2) From GOBJET
End

#######################################################################################
## Génération auto pyramide
#######################################################################################
$ACTION
Case ACTION
 When "INIT"           : Gosub INIT
 When "INIT_DIA"       : Gosub INIT_DIA
 When "CONTROLE"       : Gosub CONTROLE
 When "EXEC"           : Gosub EXEC
Endcase
Return

######################################################################################
$INIT
If clalev([F:GAC]) = 0 Local File GACCOUNT   [GAC] Endif
If clalev([F:GYM]) = 0 Local File GACCPYM    [GYM] Endif
TMP = 1
Return

$INIT_DIA
Local Integer I
Raz [M]
[M]PYM    = PARAM(2)
[M]COA    = PARAM(1)
[M]NRLEV = 5
[M]LENLEV(0) = 0 : [M]NIVEAU(0) = 10
[M]LENLEV(1) = 1 : [M]NIVEAU(1) = 20
[M]LENLEV(2) = 2 : [M]NIVEAU(2) = 30
[M]LENLEV(3) = 3 : [M]NIVEAU(3) = 40
[M]LENLEV(4) = 4 : [M]NIVEAU(4) = 50
Return

$CONTROLE
If [M]NRLEV<1
 GMESSAGE = mess(101,102,1) : # Il faut au moins une ligne
 GERR = 1 : SAI = 1 : Return
Else
 For I=2 To [M]NRLEV
  If [M]NIVEAU(I-1)<=[M]NIVEAU(I-2)
   GMESSAGE = mess(103,102,1)-num$(I-1) : # Niveau incorrect en ligne
   GERR = 1 : SAI = 1 : Break
  Elsif [M]LENLEV(I-1)<=[M]LENLEV(I-2)
   GMESSAGE = mess(102,102,1)-num$(I-1) : # Longueur incorrecte en ligne
   GERR = 1 : SAI = 1 : Break
  Endif
 Next I
Endif
Return

$EXEC
Call CREATEPYM([M]PYM,[M]NRLEV,[M]LENLEV,[M]NIVEAU,([M]JOK=2),([M]HOM=2))
Return

######################################################################################
## Ecran PYRMOD
######################################################################################
Subprog C_NIVEAU(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or (nolign>1 & VALEUR<=[M]NIVEAU(nolign-2))
 GMESSAGE = mess(98,102,1) : # Niveau incorrect
 mkstat = 2 : End
Endif
End

Subprog C_LENLEV(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 or (nolign>1 & VALEUR<=[M]LENLEV(nolign-2))
 GMESSAGE = mess(99,102,1) : # Longueur incorrecte
 mkstat = 2 : End
Endif
End

######################################################################################
# Subprogs to handle pyramid automatic creation according to account pattern
######################################################################################

Subprog CREATEPYM(PYRAMIDE,NBNIV,LONG,NIVEAU,JOK,HOMOGENE)
Value Char    PYRAMIDE
Value Integer NBNIV
Value Integer LONG(1..)
Value Integer NIVEAU(1..)
Value Integer JOK
Value Integer HOMOGENE

Local Char    PLAN(GLONCOA) , RACCUR(GLONGAC) , RACINE(GLONGAC)
Local Integer RANG , LIGNE
Local Char    HOMOG(10)

If clalev([F:GAC]) = 0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:GYM]) = 0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY]) = 0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GR2]) = 0 : Local File GACCGRUPYM [GR2] : Endif
If clalev([F:GYK]) = 0 : Local File GACCPYMLIK [GYK] : Endif
If clalev([F:GYP]) = 0 : Local File GACCPYMPRT [GYP] : Endif

HOMOG = string$(10,"X")
Read [GYM]GYM0 = PYRAMIDE
PLAN = [F:GYM]COA
Call EFFACE(PYRAMIDE,0) From PYRDEL
Call DEBTRANS From GLOCK

Gosub TR1
If GOK=1
 Call PYRAMPRT(PYRAMIDE,PLAN,nomap) From LIENPYRACC
 Call PYRAMLIK(PYRAMIDE,PLAN,nomap) From LIENPYRACC
Endif
End

$TR1
GOK = 1
Trbegin [GRY]

 For NIV=NBNIV To 1 Step -1
  #
  # Création des groupes liés aux racines de comptes
  #
  RACCUR = ""
  RANG   = 0
  If NIV=NBNIV
   If HOMOGENE
    Filter [GAC] Where COA=PLAN
   Else
    Filter [GAC] Where COA=PLAN & len([F:GAC]ACC)>=LONG(NIV)
   Endif
  Else
   Filter [GAC] Where COA=PLAN & len([F:GAC]ACC)>=LONG(NIV) & len([F:GAC]ACC)<LONG(NIV+1)
  Endif
  If !HOMOGENE or NIV=NBNIV
   For [GAC]GAC0
    RACINE = left$([F:GAC]ACC+HOMOG,LONG(NIV))
    If RACINE<>RACCUR or !(JOK & NIV=NBNIV)
     If RACINE<>RACCUR
      RACCUR = RACINE
      Filter [GRY] Where PYM=PYRAMIDE & GRU=RACINE
      Read [GRY]GRY0 Last
      Filter [GRY]
      If fstat<=2
       LIGNE = [F:GRY]LIN
      Else
       LIGNE  = 0
      Endif
      RANG  += 10
     Endif
     Raz [F:GRY]
     [F:GRY]COA    = PLAN
     [F:GRY]PYM    = PYRAMIDE
     [F:GRY]GRU    = RACCUR
     [F:GRY]LEV    = NIVEAU(NIV)
     Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GACCGRUPYM","DESTRA",PYRAMIDE,RACCUR) From ATEXTRA
     Call MAJTEXTRA(RACCUR,"GACCGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From ATEXTRA
     If dim([F:GRY]DES)>0
      [F:GRY]DES    = mess(100,102,1)-RACCUR : # Groupe
     Endif
     [F:GRY]PRNROW = RANG
     If JOK & NIV=NBNIV & len([F:GAC]ACC)>=LONG(NIV)
      [F:GRY]ACC    = left$([F:GAC]ACC,LONG(NIV))+"*"
     Else
      [F:GRY]ACC    = [F:GAC]ACC
     Endif
     LIGNE += 1
     [F:GRY]LIN    = LIGNE
     [F:GRY]CLSCOD = [F:GAC]CLSCOD
     [F:GRY]BUDTRK = [F:GAC]BUDTRK
     [F:GRY]TIMDSP = [F:GAC]TIMDSP
     [F:GRY]UOMDAC = [F:GAC]FLGUOM
     [F:GRY]UOM    = [F:GAC]UOM
     [F:GRY]DEFVAL = [F:GAC]VALUOM
     If dim([F:GRY]CREDAT)>0 : [F:GRY]CREDAT = date$ : Endif
     If dim([F:GRY]CREUSR)>0 : [F:GRY]CREUSR = GUSER : Endif
     If dim([F:GRY]CRETIM)>0 : [F:GRY]CRETIM = time  : Endif
     Write [GRY]
     If fstat
      GOK = 0 : Call FSTA("GRY") From GLOCK : Break
     Endif
    Endif
   Next
  Endif
  Filter [GAC]
  #
  # Groupes de cumuls du niveau inférieur
  #
  If NIV<NBNIV
   RACCUR = ""
   Filter [GRY] Where PYM=PYRAMIDE & LEV=NIVEAU(NIV+1) & LIN=1 Order By Key CLE=GRU
   For [GRY]CLE
    RACINE = left$([F:GRY]GRU+HOMOG,LONG(NIV))
    If RACINE=""
     RACINE = mess(115,102,1) : # TOTAL
    Endif
    If RACINE<>RACCUR
     Filter [GR2] Where PYM=PYRAMIDE & GRU=RACINE
     Read [GR2]GRY0 Last
     Filter [GR2]
     If fstat<=2
      LIGNE = [F:GR2]LIN
     Else
      LIGNE  = 0
     Endif
     RACCUR = RACINE
     RANG  += 10
     Raz [F:GR2]
     [F:GR2] = [F:GRY]
     [F:GR2]GRU    = RACCUR
     [F:GR2]LEV    = NIVEAU(NIV)
     Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GACCGRUPYM","DESTRA",PYRAMIDE,RACCUR) From ATEXTRA
     Call MAJTEXTRA(RACCUR,"GACCGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From ATEXTRA
     If dim([F:GR2]DES)>0
      [F:GR2]DES    = mess(100,102,1)-RACCUR : # Groupe
     Endif
     [F:GR2]PRNROW = RANG
     [F:GR2]SBBGRU = [F:GRY]GRU
     [F:GR2]ACC    = ""
    Else
     [F:GR2]SBBGRU = [F:GRY]GRU
    Endif
    LIGNE += 1
    [F:GR2]LIN = LIGNE
    If dim([F:GR2]CREDAT)>0 : [F:GR2]CREDAT = date$ : Endif
    If dim([F:GR2]CREUSR)>0 : [F:GR2]CREUSR = GUSER : Endif
    If dim([F:GR2]CRETIM)>0 : [F:GR2]CRETIM = time  : Endif
    Write [GR2]
    If fstat
     GOK = 0 : Call FSTA("GR2") From GLOCK : Break
    Endif
   Next
   Filter [GRY]
  Endif
 Next NIV
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran PYRMOD) 22-01-2006 10:30:01 (MB)
######################################################################################
Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
End

Subprog C_COA(VALEUR)
Variable Char    VALEUR()
End


