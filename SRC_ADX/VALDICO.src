Effzo DEBCNS , FINCNS
[M]VALCNS = VALEUR : Gosub GRISE_CNS
End

Subprog AM_VALMEN(VALEUR)
Variable Integer VALEUR
Effzo MENU
[M]VALMEN = VALEUR : Gosub GRISE_MEN
End

Subprog AS_MENU(VALEUR)
Variable Char VALEUR
If VALEUR<>"" : End : Endif
Local File =[M]APPLI+".ADOVAL" [ADW]
Read [ADW]ADW0 = "";"";"SUPDOS"
If [F:ADW]VALEUR<>[M]APPLI or GADONIX=2
 Read [ADW]ADW0 = "";"";"ADMUSR"
 VALEUR = [F:ADW]VALEUR+"*"
Endif
Close Local File [ADW]
End

Subprog C_MENU(VALEUR)
Variable Char VALEUR
VALEUR = toupper(VALEUR)
If !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?")
 Local File =[M]APPLI+".APROFIL" [APF]
 Read [APF]CODPRF = 0;VALEUR
 Close Local File [APF]
 If fstat
  GMESSAGE = VALEUR-":"-mess(84,141,1) : # Code inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_NEWLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]VALACLA = 2 : [M]DEBACLA = "" : [M]FINACLA = ""
 [M]VALASW = 2 : [M]DEBASW = "" : [M]FINASW = ""
 #
 [M]VALECR = 2 : [M]DEBECR = "" : [M]FINECR = ""
 [M]GENECR = 2
 [M]VALOBJ = 2 : [M]DEBOBJ = "" : [M]FINOBJ = ""
 [M]VALFEN = 2 : [M]DEBFEN = "" : [M]FINFEN = ""
 [M]GENFEN = 2
 [M]VALCNS = 2 : [M]DEBCNS = "" : [M]FINCNS = ""
 [M]VALMEN = 2 : [M]MENU = "*"
 Affzo
Endif
End

Subprog C_TYPVAL(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 2
  [M]VALTAB = 2 : [M]DEBTAB = "" : [M]FINTAB = ""
  [M]FORCE  = 1
  If dim([M]VALVUE)>0
   [M]VALVUE = 2 : [M]DEBVUE = "" : [M]FINVUE = ""
  Endif
  [M]GENCLATECH = 2
  [M]VALACLA = 2 : [M]DEBACLA = "" : [M]FINACLA = ""
  [M]GENASWLNK = 2
  [M]VALASW = 2 : [M]DEBASW = "" : [M]FINASW = ""
  [M]VALECR = 2 : [M]DEBECR = "" : [M]FINECR = ""
  [M]GENECR = 2
  [M]VALOBJ = 2 : [M]DEBOBJ = "" : [M]FINOBJ = ""
  [M]VALFEN = 2 : [M]DEBFEN = "" : [M]FINFEN = ""
  [M]GENFEN = 2
  [M]VALCNS = 2 : [M]DEBCNS = "" : [M]FINCNS = ""
  If dim([M]VALMEN)>0
   [M]VALMEN = 2 : [M]MENU = "*"
  Endif
  [M]TEST = 1
  Affzo [DIA]5-10
  Diszo VALTAB , DEBTAB , FINTAB
  Diszo FORCE
  If dim([M]VALVUE)>0
   Diszo VALVUE , DEBVUE , FINVUE
  Endif
  Diszo GENCLATECH, VALACLA , DEBACLA , FINACLA
  Diszo GENASWLNK, VALASW , DEBASW , FINASW
  Diszo VALECR , DEBECR , FINECR
  Diszo GENECR
  Diszo VALOBJ , DEBOBJ , FINOBJ
  Diszo VALFEN , DEBFEN , FINFEN
  Diszo GENFEN
  Diszo VALCNS , DEBCNS , FINCNS
  If dim([M]VALMEN)>0
   Diszo VALMEN , MENU
  Endif
  [M]CODACT =  ""
  [M]TYPDON = ""
  Affzo CODACT , TYPDON
  Diszo CODACT , TYPDON
 When 3
  [M]VALTAB = 1 : [M]DEBTAB = "" : [M]FINTAB = ""
  [M]FORCE  = 1
  If dim([M]VALVUE)>0
   [M]VALVUE = 1 : [M]DEBVUE = "" : [M]FINVUE = ""
  Endif
  [M]GENCLATECH = 2
  [M]VALACLA = 2 : [M]DEBACLA = "" : [M]FINACLA = ""
  [M]GENASWLNK = 2
  [M]VALASW = 2 : [M]DEBASW = "" : [M]FINASW = ""
  [M]VALECR = 2 : [M]DEBECR = "" : [M]FINECR = ""
  [M]GENECR = 2
  [M]VALOBJ = 2 : [M]DEBOBJ = "" : [M]FINOBJ = ""
  [M]VALFEN = 2 : [M]DEBFEN = "" : [M]FINFEN = ""
  [M]GENFEN = 2
  [M]VALCNS = 2 : [M]DEBCNS = "" : [M]FINCNS = ""
  If dim([M]VALMEN)>0
   [M]VALMEN = 2 : [M]MENU = "*"
  Endif
  Affzo [DIA]5-10
  Diszo VALTAB , DEBTAB , FINTAB
  Diszo FORCE
  If dim([M]VALVUE)>0
   Diszo VALVUE , DEBVUE , FINVUE
  Endif
  Diszo GENCLATECH, VALACLA , DEBACLA , FINACLA
  Diszo GENASWLNK, VALASW , DEBASW , FINASW
  Diszo VALECR , DEBECR , FINECR
  Diszo GENECR
  Diszo VALOBJ , DEBOBJ , FINOBJ
  Diszo VALFEN , DEBFEN , FINFEN
  Diszo GENFEN
  Diszo VALCNS , DEBCNS , FINCNS
  If dim([M]VALMEN)>0
   Diszo VALMEN , MENU
  Endif
  [M]CODACT =  ""
  [M]TYPDON = ""
  Affzo CODACT , TYPDON
  Diszo CODACT , TYPDON
 When Default
  Actzo [DIA]5
  Actzo [DIA]15
  Gosub GRISE_TAB
  If dim([M]VALVUE)>0
   Gosub GRISE_VUE
  Endif
  Actzo [M]GENCLATECH
  Gosub GRISE_ACLA
  Actzo [M]GENASWLNK
  Gosub GRISE_ASW
  Gosub GRISE_ECR
  Gosub GRISE_OBJ
  Gosub GRISE_FEN
  Gosub GRISE_CNS
  If dim([M]VALMEN)>0
   Gosub GRISE_MEN
  Endif
Endcase
End

$GRISE_TAB
If [M]VALTAB=1
 [M]DEBTAB = ""
 [M]FINTAB = ""
 Diszo DEBTAB , FINTAB
Else
 Actzo DEBTAB, FINTAB
Endif
Return

$GRISE_VUE
If [M]VALVUE=1
 [M]DEBVUE = ""
 [M]FINVUE = ""
 Diszo DEBVUE , FINVUE
Else
 Actzo DEBVUE, FINVUE
Endif
Return

$GRISE_ACLA
If [M]VALACLA=1
 [M]DEBACLA = ""
 [M]FINACLA = ""
 Diszo DEBACLA , FINACLA
Else
 Actzo DEBACLA, FINACLA
Endif
Return

$GRISE_ASW
If [M]VALASW=1
 [M]DEBASW = ""
 [M]FINASW = ""
 Diszo DEBASW , FINASW
Else
 Actzo DEBASW, FINASW
Endif
Return


$GRISE_ECR
If [M]VALECR=1
 [M]DEBECR = ""
 [M]FINECR = ""
 Diszo DEBECR , FINECR
Else
 Actzo DEBECR, FINECR
Endif
Return

$GRISE_OBJ
If [M]VALOBJ=1
 [M]DEBOBJ = ""
 [M]FINOBJ = ""
 Diszo DEBOBJ , FINOBJ
Else
 Actzo DEBOBJ, FINOBJ
Endif
Return

$GRISE_FEN
If [M]VALFEN=1
 [M]DEBFEN = ""
 [M]FINFEN = ""
 Diszo DEBFEN , FINFEN
Else
 Actzo DEBFEN, FINFEN
Endif
Return

$GRISE_CNS
If [M]VALCNS=1
 [M]DEBCNS = ""
 [M]FINCNS = ""
 Diszo DEBCNS , FINCNS
Else
 Actzo DEBCNS, FINCNS
Endif
Return

$GRISE_MEN
If [M]VALMEN=1
 [M]MENU = ""
 Diszo MENU
Else
 Actzo MENU
Endif
Return
