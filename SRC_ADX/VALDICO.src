Variable Integer VALEUR
Effzo DEBTAB , FINTAB
[M]VALTAB = VALEUR : Gosub GRISE_TAB
End

Subprog AM_VALVUE(VALEUR)
Variable Integer VALEUR
Effzo DEBVUE , FINVUE
[M]VALVUE = VALEUR : Gosub GRISE_VUE
End

Subprog AM_VALACLA(VALEUR)
Variable Integer VALEUR
Effzo DEBACLA , FINACLA
[M]VALACLA = VALEUR : Gosub GRISE_ACLA
End

