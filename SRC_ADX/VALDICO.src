#<AdxTL>@(#)4.0.0.0 $Revision$
Call VALDIC
End

Subprog VALDIC
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","VALDICO","VALDICO",3,"XYVALDICO") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####################
$INIT_DIA
Raz [M:DIA]
[M:DIA]NBMOD = len(mess(0,14,1))
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  [M:DIA]NBMOD = I-1
  Break
 Endif
 [M:DIA]VALMOD(I-1) = 2
Next I
Return

#####################
$EXEC
Local Char APPLI(10)
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
[L] = [M:DIA]
If !GSERVEUR
 Call TEMPON("V") From GESECRAN
 Call OUVRE_TRACE(mess(111,124,1)-APPLI) From LECFIC : # Validation dictionnaire
Else
 Call ECR_TRACE(mess(111,124,1)-APPLI,0) From GESECRAN
 Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
Endif
Call VALID_MSK
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
Endif
Return

###############
$TERMINE
TRA = 1
If [M:DIA]TEST=2 : SAI = 1 : Endif
Return

##################################################################################
Subprog VALID_DIF(APPLI,MAJ,TYPDON,CODACT,ACTION,MENU,DEBTAB,FINTAB,DEBECR,FINECR
&                ,DEBOBJ,FINOBJ,DEBFEN,FINFEN,DEBCNS,FINCNS,DEBVUE,FINVUE
&                ,DEBACLA,FINACLA,DEBASW,FINASW,VALMOD)
Value Char APPLI
Value Integer MAJ
Value Char TYPDON , CODACT , ACTION , MENU
Value Char DEBTAB , FINTAB , DEBECR , FINECR , DEBOBJ , FINOBJ
Value Char DEBFEN , FINFEN , DEBCNS , FINCNS , DEBVUE , FINVUE
Value Char DEBACLA , FINACLA , DEBASW , FINASW
Value Integer VALMOD(0..)
Local Integer VALIDDIF
VALIDDIF = 2
Goto VALID_SUB

##################################################################################
Subprog VALID_TRT(APPLI,MAJ,TYPDON,CODACT,ACTION,MENU,DEBTAB,FINTAB,DEBECR,FINECR
&                ,DEBOBJ,FINOBJ,DEBFEN,FINFEN,DEBCNS,FINCNS,DEBVUE,FINVUE
&                ,DEBACLA,FINACLA,DEBASW,FINASW,VALMOD)
Value Char APPLI
Value Integer MAJ
Value Char TYPDON , CODACT , ACTION , MENU
Value Char DEBTAB , FINTAB , DEBECR , FINECR , DEBOBJ , FINOBJ
Value Char DEBFEN , FINFEN , DEBCNS , FINCNS , DEBVUE , FINVUE
Value Char DEBACLA , FINACLA , DEBASW , FINASW
Value Integer VALMOD(0..)
Local Integer VALIDDIF
Goto VALID_SUB

#---------------------------#
$VALID_SUB
Local Integer TYPVAL,TYPAGE
Local Integer FORCE , TEST , GENECR , GENFEN , SILENCE, GENASWLNK,GENCLATECH
Local Integer VALTAB , VALECR , VALOBJ , VALFEN , VALCNS , VALVUE , VALMEN , VALACLA , VALASW
Local Integer OGSERVEUR
TYPVAL    = 1
FORCE     = 0
TEST      = 0
SILENCE   = 1
OGSERVEUR = GSERVEUR
GSERVEUR  = 1
If DEBTAB<>"" or FINTAB<>"" : VALTAB = 2 : Endif
If DEBECR<>"" or FINECR<>"" : VALECR = 2 : GENECR = 2 : Endif
If DEBOBJ<>"" or FINOBJ<>"" : VALOBJ = 2 : Endif
If DEBFEN<>"" or FINFEN<>"" : VALFEN = 2 : GENFEN = 2 : Endif
If DEBCNS<>"" or FINCNS<>"" : VALCNS = 2 : Endif
If DEBVUE<>"" or FINVUE<>"" : VALVUE = 2 : Endif
If DEBACLA<>"" or FINACLA<>"" : VALACLA = 2 : Endif
GENASWLNK=1
GENCLATECH=1
If DEBASW<>"" or FINASW<>"" : VALASW = 2 : Endif
If MENU<>"" : VALMEN = 2 : Endif
If GTRACE=""
 GTRACE = "Valid_"+nomap
 Openo filpath("TRA",GTRACE,"tra",0) , 0
 Openo
Endif
mkstat = 0
Call C_APPLI(APPLI)
If mkstat
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
 Gosub VALID
Endif
GSERVEUR = OGSERVEUR
End

#####################
Subprog VALID_MSK
Local Integer TYPVAL , MAJ, TYPAGE
Local Integer VALTAB , VALECR , VALOBJ , VALFEN , VALCNS , VALVUE , VALMEN, VALASW, VALACLA
Local Char    DEBTAB(15) , DEBECR(15) , DEBOBJ(15) , DEBACLA (30) , DEBASW(30)
Local Char    FINTAB(15) , FINECR(15) , FINOBJ(15) , FINACLA (30) , FINASW(30)
Local Char    DEBFEN(15) , FINFEN(15) , DEBCNS(15) , FINCNS(15)
Local Char    DEBVUE(15) , FINVUE(15)
Local Integer VALMOD(20) , FORCE , GENECR , GENFEN , SILENCE, GENASWLNK,GENCLATECH
Local Integer TEST , VALIDDIF
Local Char    APPLI(10) , TYPDON(15) , CODACT(15) , ACTION(15) , MENU(15)
[L] = [M:DIA]
MAJ    = 1
FORCE  = (FORCE=2)
TEST   = (TEST=2)
Gosub VALID
End

#####################
$VALID
Local Char    SYMBOLE(80) , CRITERE(250) , CRITER2(250)
Local Char    DOSX3(10)
Local Integer OKDOS , VALTRT
Local Integer I , OK , STAT , SAVGSERVEUR
Local Char    DEBDEB(15) , FINFIN(15) , TABLE(30) , DEBDOC(15) , FINDOC(15)
Local Integer SAVGVALIDDIF
If APPLI="" : APPLI = nomap : Endif
SAVGVALIDDIF=GVALIDDIFF
If [L]VALIDDIF=2
 GVALIDDIFF = 3
Else
 GVALIDDIFF = 1
Endif

If GVALIDDIFF=3
 # Validation différée activée
 Call ECR_TRACE(mess(281,125,1),0) From GESECRAN
Endif

Onerrgo RIEN
Local File =APPLI+".ADOVAL" [ADW]
Read [ADW]ADW0 = "";"";"SUPDOS"
If !fstat
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Onerrgo

If TEST
 Call ECR_TRACE("*****"-mess(194,124,1)-"*****",0) From GESECRAN : # Mode test
 Call ECR_TRACE("Open files:"-sigma(0,[S]dbglong(11),string$(filelev(indcum+1)<>0,[S]fileabre(indcum+1)+",")),0) From GESECRAN
Endif

# Création des répertoires X3_PUB s'il n'existent pas

If (VALECR=2 or VALFEN=2 or VALOBJ=2 or VALCNS=2) & [L]MAJ
 Call CREREPPUB(APPLI) From INTRUTILC
Endif

# Création des répertoires langues sous l'arborescence du dossier

If [L]TYPVAL=3
 Call CREREPAPP(APPLI) From DOSAPL
Endif

# Création de la liste des langues du dossier (connectx3langs)

If [L]MAJ
 Call CRELIBWEBD(APPLI) From INTRUTILC
Endif

# Mise à jour ATEXTE et APLSTD si rajout nouvelle langue

If [L]TYPVAL=3 & APPLI<>DOSX3
 Local File ADOSSIER [ADS] , =DOSX3+".TABLAN" [TLA]
 Read [ADS]DOSSIER = APPLI
 If !fstat
  If APPLI=nomap
   Local File ATEXTE [ATX]
  Else
   Local File =APPLI+".ATEXTE" [ATX]
  Endif
  Local File =DOSX3+".ATEXTE" [AT2]
  For I=0 To [F:ADS]NBRLAN-1
   Look [ATX]NUMERO(1)=[F:ADS]LAN(I)
   If fstat
    Read [TLA]TLA0 = [F:ADS]LAN(I)
    If !fstat & [F:TLA]LANSTD=2 : # On respecte les langues spécifiques
     Call ECR_TRACE(mess(3,7813,1)-[F:ADS]LAN(I)-mess(56,123,1)-"ATEXTE",0) From GESECRAN : # Ajout langue
     Trbegin [ATX]
      #115210/6
      For [AT2]NUMERO Where LAN=[F:ADS]LAN(I) & (NUMERO<GMAXTXTSTD | NUMERO>GNEWTXTSTD)
       [F:ATX] = [F:AT2]
       Write [ATX]
       If fstat
        Call ERREUR("ATEXTE",1) From DOSDIC
       Endif
      Next AT2
     Commit
    Endif
   Endif
  Next I
  Close Local File [ATX] , [AT2]
  If APPLI=nomap
   Local File APLSTD [AST]
  Else
   Local File =APPLI+".APLSTD" [AST]
  Endif
  Local File =DOSX3+".APLSTD" [AS2]
  For I=0 To [F:ADS]NBRLAN-1
   Look [AST]LAN(1)=[F:ADS]LAN(I)
   If fstat
    Read [TLA]TLA0 = [F:ADS]LAN(I)
    If !fstat & [F:TLA]LANSTD=2 : # On respecte les langues spécifiques
     Call ECR_TRACE(mess(3,7813,1)-[F:ADS]LAN(I)-mess(56,123,1)-"APLSTD",0) From GESECRAN : # Ajout langue
     Trbegin [AST]
      For [AS2]LAN Where LAN=[F:ADS]LAN(I)
       [F:AST] = [F:AS2]
       Write [AST]
       If fstat
        Call ERREUR("APLSTD",1) From DOSDIC
       Endif
      Next AS2
     Commit
    Endif
   Endif
  Next I
  Close Local File [AST] , [AS2]
 Endif
 Close Local File [ADS] , [TLA]
Endif

# Validation des menus locaux

SAVGSERVEUR = GSERVEUR
GSERVEUR = 1 : # Pour éviter l'affichage des boites de tempo

#If (VALECR=2 or VALFEN=2) & [L]MAJ
If (VALASW=2 or VALECR=2 or VALFEN=2) & [L]MAJ
 SYMBOLE = "APLSTD"
 If APPLI=nomap
  Lock =SYMBOLE With lockwait=0
 Else
  Lock =SYMBOLE From =APPLI With lockwait=0
 Endif
 If !fstat
  If [L]TYPVAL=3 : # Ajout de langue -> On valide dans toutes les langues
   Call GENMENU(APPLI,0,2,"") From GENMENULOC
  Else
   Call GENMENU(APPLI,0,1,GLANGUE) From GENMENULOC
  Endif
  If APPLI=nomap
   Unlock =SYMBOLE
  Else
   Unlock =SYMBOLE From =APPLI
  Endif
 Endif
Endif

GSERVEUR = SAVGSERVEUR

# Validation TEMPON

If [L]TYPVAL=3 & APPLI<>DOSX3 & !GSERVEUR
 Local File ADOSSIER [ADS]
 Read [ADS]DOSSIER = APPLI
 GVALIDDIFF = 1
 Call VALID("TEMPO",APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,STAT) From VALMSK
 Call VALID("TEMPON",APPLI,1,STAT) From VALWIN
 If [L]VALIDDIF=2
  GVALIDDIFF = 3
 Endif
 Close Local File [ADS]
Endif

# Validation des fichiers

If VALTAB=2
 Call TIM_TRACE(mess(110,124,1))
# Validation table
 If clalev([F:ATB2])=0 : Local File =APPLI+".ATABLE"  [ATB2] : Endif
 If clalev([F:ATZ2])=0 : Local File =APPLI+".ATABZON" [ATZ2] : Endif
 If clalev([F:ATI2])=0 : Local File =APPLI+".ATABIND" [ATI2] : Endif
 Gosub OUVTAB

 OKDOS = 0
 DEBDEB = DEBTAB
 FINFIN = FINTAB
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

 CRITERE  = 'CODFIC>="'+DEBDEB+'" & CODFIC<="'+FINFIN+'"'
 CRITERE += '& find(CODFIC,"ATABLE","ATABZON","ATABIND","ATEXTE","ATEXTRA")=0'
 CRITERE += '& find(CODFIC,"ATYPE","ACTIV","ADOSSIER","AINDEX")=0'

 If [L]CODACT<>""
  For [ATB2]CODFIC Where evalue(CRITERE) & (TYPFIC<>3 or (GADONIX=2 & [L]APPLI=[L]DOSX3))
   If [L]VALMOD(max([F:ATB2]MODULE-1,0))=2
    OK = [F:ATB2]CODACT=[L]CODACT
    If !OK
     Filter [ATZ2] Where CODFIC=[F:ATB2]CODFIC & CODACT=[L]CODACT
     Read [ATZ2]CODZONE First
     Filter [ATZ2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ATI2] Where CODFIC=[F:ATB2]CODFIC & CODACT=[L]CODACT
     Read [ATI2]CODIND First
     Filter [ATI2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Read [ATZ2]CODTYP(2) = TYPDON;[F:ATB2]CODFIC
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:ATB2]CODFIC
     Gosub VALFIC
    Endif
   Endif
  Next ATB2
 Elsif TYPDON<>""
  For [ATZ2]CODTYP(2) Where CODTYP=TYPDON & evalue(CRITERE)
   TABLE = [F:ATZ2]CODFIC
   Read [ATB2]CODFIC = TABLE
   If [F:ATB2]TYPFIC<>3 & [L]VALMOD(max([F:ATB2]MODULE-1,0))=2
    Gosub VALFIC
   Endif
  Next ATZ2
 Else
  For [ATB2]CODFIC Where evalue(CRITERE) & (TYPFIC<>3 or (GADONIX=2 & [L]APPLI=[L]DOSX3))
   If [L]VALMOD(max([F:ATB2]MODULE-1,0))=2
    TABLE = [F:ATB2]CODFIC
    Gosub VALFIC
   Endif
  Next ATB2
 Endif
 Close Local File

 For TABLE="ATABLE","ATABZON","ATABIND","ATEXTE","ATEXTRA","ATYPE","ACTIV","ADOSSIER","AINDEX"
  If (DEBDEB<=TABLE & FINFIN>=TABLE) & (GSOPHIA=0 or TABLE<>"ATEXTE")
   If clalev([F:ATB2])=0 : Local File =APPLI+".ATABLE"  [ATB2] : Endif
   If clalev([F:ATZ2])=0 : Local File =APPLI+".ATABZON" [ATZ2] : Endif
   If clalev([F:ATI2])=0 : Local File =APPLI+".ATABIND" [ATI2] : Endif
   Gosub OUVTAB
   OK = 1
   Read [ATB2]CODFIC = TABLE
   If fstat or ([F:ATB2]TYPFIC=3 and (GADONIX<>2 or [L]APPLI<>[L]DOSX3))
    OK = 0
   Elsif [L]VALMOD(max([F:ATB2]MODULE-1,0))<>2
    OK = 0
   Else
    OK = 0
    If [L]CODACT<>""
     OK = ([F:ATB2]CODACT=[L]CODACT)
     If !OK
      Filter [ATZ2] Where CODFIC=TABLE & CODACT=[L]CODACT
      Read [ATZ2]CODZONE First
      Filter [ATZ2]
      If fstat<=2 : OK = 1 : Endif
     Endif
     If !OK
      Filter [ATI2] Where CODFIC=TABLE & CODACT=[L]CODACT
      Read [ATI2]CODIND First
      Filter [ATI2]
      If fstat<=2 : OK = 1 : Endif
     Endif
     If OK & TYPDON<>""
      Read [ATZ2]CODTYP(2) = TYPDON;TABLE
      If fstat : OK = 0 : Endif
     Endif
    Elsif TYPDON<>""
     Filter [ATZ2] Where CODFIC=TABLE & CODTYP=TYPDON
     Read [ATZ2]CODTYP First
     Filter [ATZ2]
     If fstat<=2 : OK = 1 : Endif
    Else
     OK = 1
    Endif
   Endif
   If OK
    Gosub VALFIC
   Endif
   Close Local File
  Endif
 Next TABLE
 If VALVUE<>2 & filinfo(filpath("FIL","AVIEW","fde",APPLI),0)>0
  Gosub OUVTAB
  Call GENVUE(APPLI) From DOSVUE
  Close Local File
 Endif

 If APPLI=GDOSX3 & OKDOS
  If clalev([F:ADS])>0 : Close Local File [ADS] : Endif
  If clalev([F:ADD])>0 : Close Local File [ADD] : Endif
  If clalev([F:ADA])>0 : Close Local File [ADA] : Endif
  If clalev([F:ADE])>0 : Close Local File [ADE] : Endif
  Local File ADOSSIER [ADS] , ADOSACT [ADA] , ADOSDIM [ADE] , ADOSSOL [ADD]
  For [ADS]
   If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
    Onerrgo RIEN
    Call CREPAR From DOSDIV : # Régénération des fichiers PARAM.ini
    Onerrgo
   Endif
  Next ADS
  Close Local File [ADS] , [ADA] , [ADE] , [ADD]
 Endif

Endif

# Validation des vues

If VALVUE=2
 Call TIM_TRACE(mess(83,139,1))
# Validation vue
 If clalev([F:AVW2])=0 : Local File =APPLI+".AVIEW"  [AVW2] : Endif
 If clalev([F:AVD2])=0 : Local File =APPLI+".AVIEWD" [AVD2] : Endif
 If clalev([F:AVC2])=0 : Local File =APPLI+".AVIEWC" [AVC2] : Endif
 Gosub OUVTAB

 DEBDEB = DEBVUE
 FINFIN = FINVUE
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

 CRITERE  = 'CODVUE>="'+DEBDEB+'" & CODVUE<="'+FINFIN+'"'

 If [L]CODACT<>""
  For [AVW2]AVW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:AVW2]MODULE-1,0))=2
    OK = ([F:AVW2]CODACT=[L]CODACT)
    If !OK
     Filter [AVD2] Where CODVUE=[F:AVW2]CODVUE & FLDACT=[L]CODACT
     Read [AVD2]AVD2 First
     Filter [AVD2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [AVC2] Where CODVUE=[F:AVW2]CODVUE & CLEACT=[L]CODACT
     Read [AVC2]AVC0 First
     Filter [AVC2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Read [AVD2]AVD2(2) = TYPDON;[F:AVW2]CODVUE
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:AVW2]CODVUE
     Gosub VALVUE
    Endif
   Endif
  Next AVW2
 Elsif TYPDON<>""
  For [AVD2]AVD2(2) Where CODTYP=TYPDON & evalue(CRITERE)
   TABLE = [F:AVD2]CODVUE
   Read [AVW2]AVW0 = TABLE
   If [L]VALMOD(max([F:AVW2]MODULE-1,0))=2
    Gosub VALVUE
   Endif
  Next AVD2
 Else
  For [AVW2]AVW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:AVW2]MODULE-1,0))=2
    TABLE = [F:AVW2]CODVUE
    Gosub VALVUE
   Endif
  Next AVW2
 Endif
 Call GENVUE(APPLI) From DOSVUE
 Close Local File
Endif

# Validation des classes système
If GENCLATECH=2
Call TIM_TRACE(mess(47,140,1)-mess(4,7986,1))
Call VALID_ALL_CLA_TECH(APPLI) From ACLAVALTECH
Endif

# Validation des classes

If VALACLA=2
 Call TIM_TRACE(mess(47,140,1))
# Validation classe
 If clalev([F:ACLA2])=0 : Local File =APPLI+".ACLASSE"  [ACLA2] : Endif
 If clalev([F:ACLF2])=0 : Local File =APPLI+".ACLAFLD" [ACLF2] : Endif
 If clalev([F:ACLM2])=0 : Local File =APPLI+".ACLAMET" [ACLM2] : Endif
 If clalev([F:ACLT2])=0 : Local File =APPLI+".ACLAMETSTD" [ACLT2] : Endif
 If clalev([F:ACLO2])=0 : Local File =APPLI+".ACLAOPT" [ACLO2] : Endif
 If clalev([F:ACLC2])=0 : Local File =APPLI+".ACLACOL" [ACLC2] : Endif
 Gosub OUVTAB

 DEBDEB = DEBACLA
 FINFIN = FINACLA
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

 CRITERE  = 'CODCLA>="'+DEBDEB+'" & CODCLA<="'+FINFIN+'"'

 If [L]CODACT<>""
  For [ACLA2]ACLA0 Where evalue(CRITERE) & TYPCLA<>4
   If [L]VALMOD(max([F:ACLA2]MODULE-1,0))=2
    OK = ([F:ACLA2]CODACT=[L]CODACT)
    If !OK
     For I=0 To [F:ACLA2]NBRTRT-1
      If [F:ACLA2]ACTTRT(I)=[L]CODACT : OK = 1 : Break : Endif
     Next I
    Endif
    If !OK
     Filter [ACLF2] Where CODCLA=[F:ACLA2]CODCLA & ACTFLD=[L]CODACT
     Read [ACLF2]ACLAF0 First
     Filter [ACLF2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ACLM2] Where CODCLA=[F:ACLA2]CODCLA & ACTMET=[L]CODACT
     Read [ACLM2]ACLAM0 First
     Filter [ACLM2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ACLT2] Where CODCLA=[F:ACLA2]CODCLA & ACTMETSTD=[L]CODACT
     Read [ACLT2]ACLAT0 First
     Filter [ACLT2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ACLO2] Where CODCLA=[F:ACLA2]CODCLA & OPTACT=[L]CODACT
     Read [ACLO2]ACLAO0 First
     Filter [ACLO2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ACLC2] Where CODCLA=[F:ACLA2]CODCLA & ACTCOL=[L]CODACT
     Read [ACLC2]ACLAC0 First
     Filter [ACLC2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Filter [ACLF2] Where CODCLA=[F:ACLA2]CODCLA & CODTYP=[L]TYPDON
     Read [ACLF2]ACLAF0 First
     Filter [ACLF2]
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:ACLA2]CODCLA
     Gosub VALACLA
    Endif
   Endif
  Next ACLA2
 Elsif TYPDON<>""
  For [ACLF2]ACLAF0(1) Where CODTYP=TYPDON & evalue(CRITERE)
   TABLE = [F:ACLF2]CODCLA
   Read [ACLA2]ACLA0 = TABLE
   If [F:ACLA2]TYPCLA<>4 & [L]VALMOD(max([F:ACLA2]MODULE-1,0))=2
    Gosub VALACLA
   Endif
  Next ACLF2
 Else
  For [ACLA2]ACLA0 Where evalue(CRITERE) & TYPCLA<>4
   If [L]VALMOD(max([F:ACLA2]MODULE-1,0))=2
    TABLE = [F:ACLA2]CODCLA
    Gosub VALACLA
   Endif
  Next ACLA2
 Endif
 Close Local File
Endif

# Synchronisation des représentations
If VALASW=2
 Call TIM_TRACE(mess(277,143,1))
# Synchronisation des représentations
 If clalev([F:ASW2])=0 : Local File =APPLI+".ASHW"  [ASW2] : Endif
 If clalev([F:ASWF2])=0 : Local File =APPLI+".ASHWFLD" [ASWF2] : Endif
 If clalev([F:ASWR2])=0 : Local File =APPLI+".ASHWEXPPRO" [ASWR2] : Endif
 If clalev([F:ASWM2])=0 : Local File =APPLI+".ASHWMET" [ASWM2] : Endif
 If clalev([F:ASWK2])=0 : Local File =APPLI+".ASHWLNK" [ASWK2] : Endif
 If clalev([F:ASWC2])=0 : Local File =APPLI+".ASHWCOL" [ASWC2] : Endif
 If clalev([F:ASWS2])=0 : Local File =APPLI+".ASHWSEC" [ASWS2] : Endif
 If clalev([F:ASWB2])=0 : Local File =APPLI+".ASHWBLC" [ASWB2] : Endif
 Gosub OUVTAB

 DEBDEB = DEBASW
 FINFIN = FINASW
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

 CRITERE  = 'CODREP>="'+DEBDEB+'" & CODREP<="'+FINFIN+'"'

 If [L]CODACT<>""
  For [ASW2]ASW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
    OK = ([F:ASW2]CODACT=[L]CODACT)
    If !OK
     For I=0 To [F:ASW2]NBRTRT-1
      If [F:ASW2]ACTTRT(I)=[L]CODACT : OK = 1 : Break : Endif
     Next I
    Endif
    If !OK
     Filter [ASWF2] Where CODREP=[F:ASW2]CODREP & ACTFLD=[L]CODACT
     Read [ASWF2]ASWF0 First
     Filter [ASWF2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWM2] Where CODREP=[F:ASW2]CODREP & ACTMET=[L]CODACT
     Read [ASWM2]ASWM0 First
     Filter [ASWM2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWR2] Where CODREP=[F:ASW2]CODREP & ACTPRO=[L]CODACT
     Read [ASWR2]ASWR0 First
     Filter [ASWR2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWK2] Where CODREP=[F:ASW2]CODREP & ACVLNK=[L]CODACT
     Read [ASWK2]ASWK0 First
     Filter [ASWK2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWB2] Where CODREP=[F:ASW2]CODREP & ACTBLC=[L]CODACT
     Read [ASWB2]ASWB0 First
     Filter [ASWB2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWS2] Where CODREP=[F:ASW2]CODREP & ACTSEC=[L]CODACT
     Read [ASWS2]ASWS0 First
     Filter [ASWS2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWC2] Where CODREP=[F:ASW2]CODREP & ACTCOL=[L]CODACT
     Read [ASWC2]ASWC0 First
     Filter [ASWC2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Filter [ASWF2] Where CODREP=[F:ASW2]CODREP & CODTYP=[L]TYPDON
     Read [ASWF2]ASWF0 First
     Filter [ASWF2]
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:ASW2]CODREP
     #97530 synchronisation
     STAT=0
     #109594
     #Call _TRTMAJ_ASWFLD(0,1,APPLI,TABLE,STAT) From SUBASW_TOOL
     Call TRTMAJ_FILTER_ASWFLD(APPLI,2,TABLE,TABLE) From SUBASW_TOOL
    Endif
   Endif
  Next ASW2
 Elsif TYPDON<>""
  For [ASWF2]ASWF0(1) Where CODTYP=TYPDON & evalue(CRITERE)
   TABLE = [F:ASWF2]CODREP
   Read [ASW2]ASW0 = TABLE
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
     #97530 synchronisation
     STAT=0
     #109594
     #Call _TRTMAJ_ASWFLD(0,1,APPLI,TABLE,STAT) From SUBASW_TOOL
     Call TRTMAJ_FILTER_ASWFLD(APPLI,2,TABLE,TABLE) From SUBASW_TOOL
   Endif
  Next ASWF2
 Else
  For [ASW2]ASW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
    TABLE = [F:ASW2]CODREP
    #97530 synchronisation
    STAT=0
    #109594
    #Call _TRTMAJ_ASWFLD(0,1,APPLI,TABLE,STAT) From SUBASW_TOOL
    Call TRTMAJ_FILTER_ASWFLD(APPLI,2,TABLE,TABLE) From SUBASW_TOOL
   Endif
  Next ASW2
 Endif
 Close Local File
Endif

# Synchronisation des liens
If GENASWLNK=2
# Synchonisation des liens dss représentations
# avec validation différée avant les transactions
Call TRTMAJ_ALL_ASWLNK(APPLI,2) From SUBASW_TOOL
Endif
# Validation des représentations

If VALASW=2
 Call TIM_TRACE(mess(48,140,1))
# Validation représentation
 If clalev([F:ASW2])=0 : Local File =APPLI+".ASHW"  [ASW2] : Endif
 If clalev([F:ASWF2])=0 : Local File =APPLI+".ASHWFLD" [ASWF2] : Endif
 If clalev([F:ASWR2])=0 : Local File =APPLI+".ASHWEXPPRO" [ASWR2] : Endif
 If clalev([F:ASWM2])=0 : Local File =APPLI+".ASHWMET" [ASWM2] : Endif
 If clalev([F:ASWK2])=0 : Local File =APPLI+".ASHWLNK" [ASWK2] : Endif
 If clalev([F:ASWC2])=0 : Local File =APPLI+".ASHWCOL" [ASWC2] : Endif
 If clalev([F:ASWS2])=0 : Local File =APPLI+".ASHWSEC" [ASWS2] : Endif
 If clalev([F:ASWB2])=0 : Local File =APPLI+".ASHWBLC" [ASWB2] : Endif
 Gosub OUVTAB

 DEBDEB = DEBASW
 FINFIN = FINASW
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

 CRITERE  = 'CODREP>="'+DEBDEB+'" & CODREP<="'+FINFIN+'"'

 If [L]CODACT<>""
  For [ASW2]ASW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
    OK = ([F:ASW2]CODACT=[L]CODACT)
    If !OK
     For I=0 To [F:ASW2]NBRTRT-1
      If [F:ASW2]ACTTRT(I)=[L]CODACT : OK = 1 : Break : Endif
     Next I
    Endif
    If !OK
     Filter [ASWF2] Where CODREP=[F:ASW2]CODREP & ACTFLD=[L]CODACT
     Read [ASWF2]ASWF0 First
     Filter [ASWF2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWM2] Where CODREP=[F:ASW2]CODREP & ACTMET=[L]CODACT
     Read [ASWM2]ASWM0 First
     Filter [ASWM2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWR2] Where CODREP=[F:ASW2]CODREP & ACTPRO=[L]CODACT
     Read [ASWR2]ASWR0 First
     Filter [ASWR2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWK2] Where CODREP=[F:ASW2]CODREP & ACVLNK=[L]CODACT
     Read [ASWK2]ASWK0 First
     Filter [ASWK2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWB2] Where CODREP=[F:ASW2]CODREP & ACTBLC=[L]CODACT
     Read [ASWB2]ASWB0 First
     Filter [ASWB2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWS2] Where CODREP=[F:ASW2]CODREP & ACTSEC=[L]CODACT
     Read [ASWS2]ASWS0 First
     Filter [ASWS2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If !OK
     Filter [ASWC2] Where CODREP=[F:ASW2]CODREP & ACTCOL=[L]CODACT
     Read [ASWC2]ASWC0 First
     Filter [ASWC2]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Filter [ASWF2] Where CODREP=[F:ASW2]CODREP & CODTYP=[L]TYPDON
     Read [ASWF2]ASWF0 First
     Filter [ASWF2]
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:ASW2]CODREP
     Gosub VALASW
    Endif
   Endif
  Next ASW2
 Elsif TYPDON<>""
  For [ASWF2]ASWF0(1) Where CODTYP=TYPDON & evalue(CRITERE)
   TABLE = [F:ASWF2]CODREP
   Read [ASW2]ASW0 = TABLE
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
    Gosub VALASW
   Endif
  Next ASWF2
 Else
  For [ASW2]ASW0 Where evalue(CRITERE)
   If [L]VALMOD(max([F:ASW2]MODULE-1,0))=2
    TABLE = [F:ASW2]CODREP
    Gosub VALASW
   Endif
  Next ASW2
 Endif
 Close Local File
Endif

# Validation des écrans

If VALECR=2 or GENECR=2
 Call TIM_TRACE(mess(139,123,1))
 # Validation écran
 Gosub OUVTAB
 Gosub OUVFIC From VALMSKLEC
 If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"    [AMK2] : Endif
 If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON" [AMZ2] : Endif
 If clalev([F:AMZ9])=0 : Local File =APPLI+".AMSKZON" [AMZ9] : Endif
 If ACTION<>""
  If clalev([F:AMA9])=0 : Local File =APPLI+".AMSKACT" [AMA9] Order By Key ACTION=ACTION;TYPAFF;CODAFF;CODZON : Endif
 Endif
 Read [ADS]DOSSIER = APPLI
 DEBDEB = DEBECR
 FINFIN = FINECR
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif
 CRITERE = 'CODMSK>="'+DEBDEB+'" & CODMSK<="'+FINFIN+'"'
 CRITER2 = 'CODAFF>="'+DEBDEB+'" & CODAFF<="'+FINFIN+'"'
 If GENECR<>2
  CRITERE -= '& left$(CODMSK,1)<>"W"'
  CRITER2 -= '& left$(CODAFF,1)<>"W"'
 Elsif VALECR<>2
  CRITERE -= '& left$(CODMSK,1)="W"'
  CRITER2 -= '& left$(CODAFF,1)="W"'
 Endif

 If CODACT<>""
  For [AMK2]CODMSK Where evalue(CRITERE) & MDL<>2
   If [L]VALMOD(max([F:AMK2]MODULE-1,0))=2
    OK = ([F:AMK2]CODACT=CODACT) or find(CODACT,[F:AMK2]ACTBLOC(0..[F:AMK2]NBBLOC-1))
    If !OK
     Filter [AMZ9] Where CODMSK=[F:AMK2]CODMSK & CODACT=[L]CODACT
     Read [AMZ9]CODE First
     Filter [AMZ9]
     If fstat<=2 : OK = 1 : Endif
    Endif
    If OK & TYPDON<>""
     Read [AMZ9]CODTYP(2) = TYPDON;[F:AMK2]CODMSK
     If fstat : OK = 0 : Endif
    Endif
    If OK
     TABLE = [F:AMK2]CODMSK
     Gosub VALECR
    Endif
   Endif
  Next
 Elsif TYPDON<>""
  For [AMZ9]CODTYP(2) Where CODTYP=TYPDON & evalue(CRITERE)
   Read [AMK2]CODMSK = [F:AMZ9]CODMSK
   If [F:AMK2]MDL<>2
    If [L]VALMOD(max([F:AMK2]MODULE-1,0))=2
     TABLE = [F:AMK2]CODMSK
     Gosub VALECR
    Endif
   Endif
  Next
 Elsif ACTION<>""
  For [F:AMA9]ACTION(3) Where TYPAFF=1 & ACTION=[L]ACTION & evalue(CRITER2)
   Read [AMK2]CODMSK = [F:AMA9]CODAFF
   If !fstat & [F:AMK2]MDL<>2
    If [L]VALMOD(max([F:AMK2]MODULE-1,0))=2
     TABLE = [F:AMK2]CODMSK
     Gosub VALECR
    Endif
   Endif
  Next AMA9
 Else
  For [AMK2]CODMSK Where evalue(CRITERE) & MDL<>2
   If [L]VALMOD(max([F:AMK2]MODULE-1,0))=2
    TABLE = [F:AMK2]CODMSK
    Gosub VALECR
   Endif
  Next
 Endif
 Close Local File
Endif

# Validation des objets

If VALOBJ=2
 Call TIM_TRACE(mess(13,124,1))
# Validation objet
 Gosub OUVTAB
 Gosub OUVFIC From VALOBJLEC
 If clalev([F:AOB2])=0 : Local File =APPLI+".AOBJET"  [AOB2] : Endif
 If clalev([F:AOT2])=0 : Local File =APPLI+".AOBJTAB" [AOT2] : Endif
 If clalev([F:ATZ2])=0 : Local File =APPLI+".ATABZON" [ATZ2] : Endif
 DEBDEB = DEBOBJ
 FINFIN = FINOBJ
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif
 CRITERE = 'ABREV>="'+DEBDEB+'" & ABREV<="'+FINFIN+'"'
 CRITERE += '& ABREV<>"AOB"'

 For [AOB2]ABREV Where evalue(CRITERE)
  If [L]VALMOD(max([F:AOB2]MODULE-1,0))=2
   OK = 1
   If TYPDON<>""
    Read [ATZ2]CODTYP(2) = TYPDON;[F:AOB2]NOMFIC
    If fstat : OK = 0 : Endif
   Endif
   If OK & CODACT<>""
    If [F:AOB2]CODACT<>[L]CODACT
     OK = 0
     For [AOT2] Where ABREV=[F:AOB2]ABREV & TABACT=[L]CODACT
      OK = 1
     Next
    Endif
   Endif
   If OK
    TABLE = [F:AOB2]ABREV
    Gosub VALOBJ
   Endif
  Endif
 Next AOB2

 TABLE = "AOB"
 If (DEBDEB<=TABLE & FINFIN>=TABLE)
  Read [AOB2]ABREV=TABLE
  If [L]VALMOD(max([F:AOB2]MODULE-1,0))=2
   OK = 1
   If TYPDON<>""
    Read [ATZ2]CODTYP(2) = TYPDON;TABLE
    If fstat : OK = 0 : Endif
   Endif
   If OK & [L]CODACT<>""
    If [F:AOB2]CODACT<>[L]CODACT
     OK = 0
     For [AOT2] Where ABREV=[F:AOB2]ABREV & TABACT=[L]CODACT
      OK = 1
     Next AOT2
    Endif
   Endif
   If OK
    Gosub VALOBJ
   Endif
  Endif
 Endif

 Close Local File
Endif

# Validation des fenêtres

If VALFEN=2 or GENFEN=2
 Call TIM_TRACE(mess(28,126,1))
# Validation fenêtre
 Gosub OUVTAB
 Gosub OUVFIC From VALWINLEC
 If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"  [AWI2] : Endif
 If clalev([F:AMZ9])=0 : Local File =APPLI+".AMSKZON"  [AMZ9] : Endif
 If ACTION<>""
  If clalev([F:AMA9])=0 : Local File =APPLI+".AMSKACT" [AMA9] Order By Key ACTION=ACTION;TYPAFF;CODAFF;CODZON : Endif
 Endif
 If clalev([F:AWB2])=0 : Local File =APPLI+".AWINBRO"  [AWB2] : Endif
 If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT" [AWT2] : Endif
 DEBDEB = DEBFEN
 FINFIN = FINFEN
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif
 CRITERE = 'WIN>="'+DEBDEB+'" & WIN<="'+FINFIN+'"'
 If GENFEN<>2
  CRITERE -= '& left$(WIN,1)<>"W"'
 Elsif VALFEN<>2
  CRITERE -= '& left$(WIN,1)="W"'
 Endif

 For [AWI2]AWI0 Where evalue(CRITERE)
  If [L]VALMOD(max([F:AWI2]MODULE-1,0))=2
   OK = 1
   If TYPDON<>""
    OK = 0
    If [F:AWI2]MSKENT<>""
     Read [AMZ9]CODTYP(2) = TYPDON;[F:AWI2]MSKENT
     If !fstat : OK = 1 : Endif
    Endif
    If !OK
     For I=0 To [F:AWI2]NBMSK-1
      Read [AMZ9]CODTYP(2) = TYPDON;[F:AWI2]NOMMSK(I)
      If !fstat : OK = 1 : Break : Endif
     Next I
    Endif
   Endif
   If OK & CODACT<>""
    Read [AWB2]AWB0 = [F:AWI]WIN
    If [F:AWI2]CODACT<>[L]CODACT & !find([L]CODACT,[F:AWI2]ACTMSK(0..[F:AWI2]NBMSK-1))
& & !find([L]CODACT,[F:AWB2]ACTLIS(0..[F:AWB2]NBLIS-1))
     OK = 0
    Endif
    If !OK
     For [AWT2]AWT0 Where WIN=[F:AWI2]WIN & CODACTBOUT=[L]CODACT
      OK = 1 : Break
     Next
    Endif
   Endif
   If OK & ACTION<>""
    OK = 0
    If [F:AWI2]MSKENT<>""
     Read [AMA9]ACTION(3) = ACTION;1;[F:AWI2]MSKENT
     If !fstat : OK = 1 : Endif
    Endif
    If !OK
     For I=0 To [F:AWI2]NBMSK-1
      Read [AMA9]ACTION(3) = ACTION;1;[F:AWI2]NOMMSK(I)
      If !fstat : OK = 1 : Break : Endif
     Next I
    Endif
    If !OK
     For I=0 To dim([F:AWI2]ACTSTD)-1
      If [F:AWI2]ACTSTD(I)=ACTION
       OK = 1 : Break
      Endif
     Next I
    Endif
    If !OK
     For [AWT2]AWT0 Where WIN=[F:AWI2]WIN & ACTBOUT=[L]ACTION
      OK = 1 : Break
     Next
    Endif
   Endif
   If OK
    TABLE = [F:AWI2]WIN
    OBJET = [F:AWI2]OBJ
    Gosub VALFEN
   Endif
  Endif
 Next
 Close Local File
Endif

# Validation des consultations

If VALCNS=2
 Call TIM_TRACE(mess(29,126,1))
# Validation consultation
 Gosub OUVTAB
 If clalev([F:ACN2])=0 : Local File =APPLI+".ACONSULT"  [ACN2] : Endif
 DEBDEB = DEBCNS
 FINFIN = FINCNS
 If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif
 CRITERE = 'COD>="'+DEBDEB+'" & COD<="'+FINFIN+'"'
 If CODACT<>""
  CRITERE -= '& CODACT="'+[L]CODACT+'"'
 Endif
 For [ACN2]ACN0 Where evalue(CRITERE)
  If [L]VALMOD(max([F:ACN2]MODULE-1,0))=2
   OK = 1
   If OK
    TABLE = [F:ACN2]COD
    Gosub VALCNS
   Endif
  Endif
 Next
 Close Local File
Endif

# Validation des menus

If VALMEN=2
 Call TIM_TRACE(mess(192,139,1))
# Validation menu
 If TEST
  If clalev([F:APF2])=0 : Local File =APPLI+".APROFIL"  [APF2] : Endif
  If instr(1,[L]MENU,"*") | instr(1,[L]MENU,"?")
   For [APF2]CODPRF Where MODULE=0
    If pat([F:APF2]CODPRF,[L]MENU)
     Call ECR_TRACE(mess(192,139,1)-[F:APF2]CODPRF,0) From GESECRAN
    Endif
   Next APF2
  Else
   Call ECR_TRACE(mess(192,139,1)-[L]MENU,0) From GESECRAN
  Endif
  Close Local File
 Else
  Call VALMENU(MENU,APPLI) From VALMENU
 Endif
Endif

GVALIDDIFF=SAVGVALIDDIF
Return

##############################################################
$RIEN
Resume

##############################################################
Subprog TIM_TRACE(MESSA)
Value Char MESSA
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(format$("D:"+GFMDAT,date$)-time$-":"-MESSA,0) From GESECRAN
End

################################################################
$VALFIC
If TEST
 Call ECR_TRACE(mess(110,124,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(110,124,1)-TABLE) From GESECRAN
Endif
# Validation table
If APPLI=nomap
 Lock ="ATB"+TABLE With lockwait=0
Else
 Lock ="ATB"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 If find(TABLE,"ADOSSIER","ADOSACT","ADOSDIM")
  OKDOS = 1
 Endif
 Call MAJFIC(TABLE,APPLI,FORCE) From VALDIC
 Call MAJTRIG(TABLE,APPLI) From VALDIC
 If APPLI=nomap
  Unlock ="ATB"+TABLE With lockwait=0
 Else
  Unlock ="ATB"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALVUE
If TEST
 Call ECR_TRACE(mess(83,139,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(83,139,1)-TABLE) From GESECRAN
Endif
# Validation vue
If APPLI=nomap
 Lock ="AVW"+TABLE With lockwait=0
Else
 Lock ="AVW"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call MAJVUE(TABLE,APPLI) From DOSVUE
 If APPLI=nomap
  Unlock ="AVW"+TABLE With lockwait=0
 Else
  Unlock ="AVW"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALOBJ
If TEST
 Call ECR_TRACE(mess(13,124,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(13,124,1)-TABLE) From GESECRAN
Endif
# Validation objet
If APPLI=nomap
 Lock ="AOB"+TABLE With lockwait=0
Else
 Lock ="AOB"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call VALID(TABLE,APPLI,1,OK) From VALOBJ
 If APPLI=nomap
  Unlock ="AOB"+TABLE With lockwait=0
 Else
  Unlock ="AOB"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALFEN
If TEST
 Call ECR_TRACE(mess(28,126,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(28,126,1)-TABLE) From GESECRAN
Endif
# Validation fenêtre
If APPLI=nomap
 Lock ="AWI"+TABLE With lockwait=0
Else
 Lock ="AWI"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call VALID(TABLE,APPLI,1,OK) From VALWIN
 If APPLI=nomap
  Unlock ="AWI"+TABLE With lockwait=0
 Else
  Unlock ="AWI"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALCNS
Call ECR_TRACE(mess(29,126,1)-TABLE,0) From GESECRAN
If TEST : Return : Endif
If !SILENCE
 Call TEMPON(mess(29,126,1)-TABLE) From GESECRAN
Endif
# Validation consultation
If APPLI=nomap
 Lock ="ACN"+TABLE With lockwait=0
Else
 Lock ="ACN"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call GENTRT(APPLI,TABLE) From ACNTRT
 If APPLI=nomap
  Unlock ="ACN"+TABLE With lockwait=0
 Else
  Unlock ="ACN"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALECR
If TEST
 Call ECR_TRACE(mess(139,123,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(139,123,1)-TABLE) From GESECRAN
Endif
# Validation écrans
If APPLI=nomap
 Lock ="AMK"+TABLE With lockwait=0
Else
 Lock ="AMK"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call VALID(TABLE,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,STAT) From VALMSK
 If APPLI=nomap
  Unlock ="AMK"+TABLE With lockwait=0
 Else
  Unlock ="AMK"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

$VALACLA
If TEST
 Call ECR_TRACE(mess(47,140,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(47,140,1)-TABLE) From GESECRAN
Endif
#97530 synchronisation
STAT=0
#109594
#Call _TRTMAJ_ACLAFLD(0,1,APPLI,TABLE,STAT) From SUBACLA_TOOL
Call TRTMAJ_FILTER_ACLAFLD(APPLI,2,TABLE,TABLE) From SUBACLA_TOOL
# Validation classe
If APPLI=nomap
 Lock ="ACLA"+TABLE With lockwait=0
Else
 Lock ="ACLA"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 #Validation différée (à la volée)
 #Call VALIDATION(TEST,TABLE,APPLI,1,0,[L]TYPAGE,STAT) From ACLAVAL
 Call VALIDATION(TEST,APPLI,TABLE) From SUBACLA
 If APPLI=nomap
  Unlock ="ACLA"+TABLE With lockwait=0
 Else
  Unlock ="ACLA"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(47,140,1)-TABLE-":"-mess(10,100,1),1) From GESECRAN
Endif
Return

$VALASW
If TEST
 Call ECR_TRACE(mess(48,140,1)-TABLE,0) From GESECRAN
 Return
Endif
If !SILENCE
 Call TEMPON(mess(48,140,1)-TABLE) From GESECRAN
Endif
# Validation représentation
If APPLI=nomap
 Lock ="ASW"+TABLE With lockwait=0
Else
 Lock ="ASW"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 #Validation différée (à la volée)
 #Call VALIDATION(TEST,TABLE,APPLI,1,0,TYPAGE,STAT) From ASHWVAL
 Call VALIDATION(TEST,APPLI,TABLE) From SUBASW
 If APPLI=nomap
  Unlock ="ASW"+TABLE With lockwait=0
 Else
  Unlock ="ASW"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(48,140,1)-TABLE-":"-mess(10,100,1),1) From GESECRAN
Endif
Return

############################################################
$OUVTAB
If APPLI="" or APPLI=nomap
 Local File ACTIV   [ACV]
 Local File ATEXTE  [ATX]
 Local File ATEXTRA [AXX]
Else
 Local File =APPLI+".ACTIV"   [ACV]
 Local File =APPLI+".ATEXTE"  [ATX]
 Local File =APPLI+".ATEXTRA" [AXX]
Endif
Return

############################################################
Subprog D_APPLI(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_APPLI(VALEUR)
Variable Char    VALEUR()
Local Integer TYP
Call C_TYPVAL(TYP)
If VALEUR=""
 VALEUR = nomap
Endif
Setmok [M] With 0
End

Subprog C_APPLI(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If VALEUR="" : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",VALEUR),0)<0
 GMESSAGE = VALEUR-":"-mess(106,125,1) : # Dossier inaccessible
 mkstat = 2 : End
Else
 Onerrgo ERRDOS
 Local File =VALEUR+".ADOVAL" [AD__]
 Read [AD__]ADW0 = "";"";"TYPDOS"
 Onerrgo
 If ER
  GMESSAGE = VALEUR-":"-mess(142,100,1) : # Le numéro de version du dossier est incorrect
  mkstat = 2 : End
 Endif
 If !fstat & val([F:AD__]VALEUR)-1<>GPRODUIT
  # Ce dossier existe et n'est pas un dossier du produit courant
  GMESSAGE = VALEUR-":"-VALEUR-":"-mess(197,126,1)
  mkstat = 2 : End
 Endif
 Close Local File [AD__]
Endif
End

$ERRDOS
ER = errn
Resume

Subprog B2_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]VALMOD(I-1) = 2
Next I
Affzo 25
End

Subprog B3_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]VALMOD(I-1) = 1
Next I
Affzo 25
End

