#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque REVPSOH3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:16"
A_USER  = "DOC"
A_STAMP = "20181109230616"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG3"
  If [M]NBLIG3=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask REVPSOH3 [REVPSOH3]
Gosub HORODAT
Local Inpbox "REVPSOH3" From GFONCTION At A_STAMP With A_WINDPREV Mask [REVPSOH3] As [SIM_]
Grizo [REVPSOH3]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [REVPSOH3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=21
Return

$ON_ITMREF
Return

$ON_ITMDES
Onevent CONTROL Call C_ITMDES(zc) From W1REVPSOH3
Return

Subprog C_ITMDES(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ITMDES" : GZNUM = 282 : Endif
Gosub _AFF
End

$ON_ECCVALMIN
Return

$ON_SAU
Return

$ON_QTY
Onevent BEFORE_AREA Gosub AV_QTY From W1REVPSOH3
Return

$AV_QTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_BASPRI
Onevent BEFORE_AREA Gosub AV_BASPRI From W1REVPSOH3
Return

$AV_BASPRI
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find(GCUR,GDEVISE(1..GNBDEV)),1))
Chgfmt [M]BASPRI(indice) With "Nz3:"+GDEVFMT
Gosub _AFF
Return

$ON_APPLYBPRI
Onevent INIT_AREA Call D_APPLYBPRI(zc) From W1REVPSOH3
Onevent BEFORE_INPUT Call AS_APPLYBPRI(zc) From W1REVPSOH3
Return

Subprog D_APPLYBPRI(VALEUR)
Variable Integer VALEUR
If varinit([M]APPLYBPRI,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_APPLYBPRI(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PRJLINK
Return

$ON_EXTUOM
Return

$ON_EXTQTY
Onevent BEFORE_AREA Gosub AV_EXTQTY From W1REVPSOH3
Return

$AV_EXTQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]EXTQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_STU
Return

$ON_QTYSTU
Onevent BEFORE_AREA Gosub AV_QTYSTU From W1REVPSOH3
Return

$AV_QTYSTU
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTYSTU(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_CUSTOMER
Return

$ON_PBUCOD
Return

$ON_TASCOD
Return

$ON_DOCNUM
Return

$CHG_STY
Return


