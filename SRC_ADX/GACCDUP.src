#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "ZZK"
Call TRAITE_CHAR(VALEUR,PARAM,"","GACCDUP","GACCDUP",3,"") From GTRAITE
End

########################################################################################################
# Be informed that this tool should be used only during the folder creation.
# It enables to duplicate a chart of accounts to another folder or the same; with the condition that
# the charts of accounts should exist.
# Two cases :
# - account doesn't exist : write it
# - account exists : just rewrite it but do the same control as defined in the process GACCOP (function GESGAC)
########################################################################################################

#############################################################################
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
 When "FIN"      : Gosub FIN
Endcase
Return

#############################################################################
$INIT
Local Integer I , J , K
Local Char    CRITERE(250)

#Non traduit encore
#Duplication comptes en masse
TIT = mess(137,102,1)

zonsui = "COA"
Return

#############################################################################
$FIN
If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif

If FIN : Return : Endif
Return

#############################################################################
$EXEC
Local File =[M:DIA]DOSORG+".GCOA"      [COA1]
Local File =[M:DIA]DOSORG+".GACCOUNT"  [GAC1]
Local File =[M:DIA]DOSORG+".ATEXTRA"   [AXX1]
Local File =[M:DIA]DOSORG+".BPADDRESS" [BPA1]
Local File =[M:DIA]DOSORG+".BID"       [BID1]

Local File =[M:DIA]DOSDES+".GCOA"      [COA2]
Local File =[M:DIA]DOSDES+".GACCOUNT"  [GAC2]
Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
Local File =[M:DIA]DOSDES+".BPADDRESS" [BPA2]
Local File =[M:DIA]DOSDES+".BID"       [BID2]

Local File =[M:DIA]DOSDES+".COMPANY"   [CPY]
Local File =[M:DIA]DOSDES+".FACILITY"  [FCY]
Local File =[M:DIA]DOSDES+".TABCUR"    [TCU]
Local File =[M:DIA]DOSDES+".ATABDIV"   [ADI]
Local File =[M:DIA]DOSDES+".TABVAT"    [TVT]
Local File =[M:DIA]DOSDES+".GCOA"      [COA]
Local File =[M:DIA]DOSDES+".GDIE"      [DIE]
Local File =[M:DIA]DOSDES+".CACCE"     [CCE]
Local File =[M:DIA]DOSDES+".CADSP"     [DSP]
Local File =[M:DIA]DOSDES+".ACCCOD"    [ACS]
Local File =[M:DIA]DOSDES+".CADISTMP"  [DTP]
Local File =[M:DIA]DOSDES+".BPARTNER"  [BPR]
Local File =[M:DIA]DOSDES+".TABUNIT"   [TUN]

Local File =[M:DIA]DOSDES+".GACCPYMPRT" [GYP]
Local File =[M:DIA]DOSDES+".GACCGRUPYM" [GRY]
Local File =[M:DIA]DOSDES+".GACCGRUPYM" [GRY2]
Local File =[M:DIA]DOSDES+".GACCOUNT"   [GAC]
Local File =[M:DIA]DOSDES+".BALANA"     [BLA]
Local File =[M:DIA]DOSDES+".BALANCE"    [BAL]

Local Char OPLAN(GLONCOA) , NPLAN(GLONCOA),DESCOAO(30),DESCOAN(30),DESACC(30)
Local Integer FLGSAC,FLGVAT1,FLGTRK1,FLGTRK2
Local Char    BPA1(GLONBPA),BPA2(GLONBPA)
OPLAN = [M:DIA]COA
NPLAN = [M:DIA]NCOA

#Keep the "intitulé traduisible" of chart of accounts (old en new)
Call LECTEXTRA([L]DESCOAO,"GCOA","DESTRA",OPLAN,"") From ATEXTRA
Call LECTEXTRA([L]DESCOAN,"GCOA","DESTRA",NPLAN,"") From ATEXTRA

If GSERVEUR
 [M:DIA]TRC = 2
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(mess(138,102,1)-[M:DIA]COA-[L]DESCOAO-mess(140,102,1)-[M:DIA]DOSORG,0) From GESECRAN
 Call ECR_TRACE(mess(139,102,1)-[M:DIA]NCOA-[L]DESCOAN-mess(140,102,1)-[M:DIA]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

#Range of account numbers
CRITERE = 'COA = "'+[M:DIA]COA+'"'
If [M:DIA]STRACC <> ""
 CRITERE -= '& ACC >= "'+[M:DIA]STRACC+'"'
Endif
If [M:DIA]ENDACC <> ""
 CRITERE -= '& ACC <= "'+ [M:DIA]ENDACC+'"'
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Close Local File [GAC1], [GAC2]
Close Local File [AXX1], [AXX2]
Close Local File [BID1], [BID2]
Close Local File [BPA1], [BPA2]
If clalev([F:COA1])>0 : Close Local File [COA1] : Endif
If clalev([F:COA2])>0 : Close Local File [COA2] : Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

Return

#############################################################################
$TR1
GOK = 1
Trbegin [COA2],[GAC2],[BPA2],[BID2]
 Read [COA1]COA0 = OPLAN
 If fstat
  Goto AB_TR1
 Endif
 Read [COA2]COA0 = NPLAN
 If fstat
  Goto AB_TR1
 Endif

 #Is New chart of accounts "Collective accour" ?
 Raz FLGSAC
 If [F:COA1]AUX<>[F:COA2]AUX & [F:COA2]AUX<>2 : FLGSAC=1 : Endif
 #Is New chart of accounts "Tax Management" ?
 Raz FLGVAT1
 If [F:COA1]TAXMGT<>[F:COA2]TAXMGT & [F:COA2]TAXMGT<>2 : FLGVAT1=1 : Endif
 #Is New chart of accounts "General" ?
 If [F:COA1]GENTRK<>[F:COA2]GENTRK & [F:COA2]GENTRK<>2 : FLGTRK1=1 : Endif
 #Is New chart of accounts "Analytic Manager" ?
 If ([F:COA1]ANATRK=2 & [F:COA2]ANATRK<>2) & [F:COA2]GENTRK=2 : FLGTRK2=1 : Endif

 For [GAC1]GAC0 Where evalue(CRITERE)
  Read [GAC2]GAC0 = NPLAN;[F:GAC1]ACC
  # If account doesn't exist in the destination chart of accounts
  # create it
  If fstat<>0
   [F:GAC2] = [F:GAC1]
   [F:GAC2]COA = NPLAN

   #Keep the "intitulé traduisible" of account
   Call LECTEXTRA([L]DESACC,"GACCOUNT","DESTRA",[F:GAC1]COA,[F:GAC1]ACC) From ATEXTRA

   #Check if format of NPLAN is different , some fields need to be RAZ
   Gosub RAZFIELDNPLAN

   #But don't forget the controls, the same as the Copy function
   If [M:DIA]DOSORG<>[M:DIA]DOSDES
    Gosub CONTROLES
   Endif

   [F:GAC2]CREUSR= GUSER
   [F:GAC2]CREDAT= date$
   [F:GAC2]CRETIM= time
   Write [GAC2]
   If fstat
    GOK = 0 : Call FSTA("GAC2") From GLOCK : Break
   Endif
   Call COPTEXTRA("GACCOUNT","DESTRA",OPLAN,[F:GAC1]ACC,NPLAN,[F:GAC1]ACC)
   If GOK<1 : Break : Endif
   Call COPTEXTRA("GACCOUNT","SHOTRA",OPLAN,[F:GAC1]ACC,NPLAN,[F:GAC1]ACC)
   If GOK<1 : Break : Endif

   #Copy the Address and RIB
   Gosub COPY_RIB_ADD
   If GOK=0 : Break : Endif

   #non traduit
   # mess = Copie effectuée compte xxxx
   Call ECR_TRACE(mess(134,102,1)-mess(45,102,1)-[F:GAC1]ACC-[L]DESACC,0) From GESECRAN

  Else

  #if account exists just rewrite it in the destination chart of accounts
   [F:GAC2] = [F:GAC1]
   [F:GAC2]COA = NPLAN

   #Keep the "intitulé traduisible" of account
   Call LECTEXTRA([L]DESACC,"GACCOUNT","DESTRA",[F:GAC1]COA,[F:GAC1]ACC) From ATEXTRA

   #Check if account is existing in Balance, if yes just add a warning in the trace
   Gosub CONTMVT
   #Check if format of NPLAN is different , some fields need to be RAZ
   Gosub RAZFIELDNPLAN

   #But don't forget the controls, the same as the Copy function
   If [M:DIA]DOSORG<>[M:DIA]DOSDES
    Gosub CONTROLES
   Endif

   [F:GAC2]CREUSR= GUSER
   [F:GAC2]CREDAT= date$
   [F:GAC2]CRETIM= time
   Rewrite [GAC2]
   If fstat
    GOK = 0 : Call FSTA("GAC2") From GLOCK : Break
   Endif
   Call COPTEXTRA("GACCOUNT","DESTRA",OPLAN,[F:GAC1]ACC,NPLAN,[F:GAC1]ACC)
   If GOK<1 : Break : Endif
   Call COPTEXTRA("GACCOUNT","SHOTRA",OPLAN,[F:GAC1]ACC,NPLAN,[F:GAC1]ACC)
   If GOK<1 : Break : Endif

   #Update the Address and RIB
   Gosub UPD_RIB_ADD
   If GOK=0 : Break : Endif

   #The account is not mvt then message of update
   If OK
    # Non traduit
    # mess = Mise à jour effectuée compte xxxx
    Call ECR_TRACE(mess(135,102,1)-mess(45,102,1)-[F:GAC1]ACC-[L]DESACC,0) From GESECRAN
   Else
    # Non traduit
    # mess = Mise à jour effectuée compte xxxx
    Call ECR_TRACE(mess(135,102,1)-mess(45,102,1)-[F:GAC1]ACC-[L]DESACC,0) From GESECRAN
    # But add also the following message
    # Account present in one the balance then do not duplicate go to the next account
    Call ECR_TRACE(mess(146,102,1)-[F:GAC2]ACC-mess(145,102,1)-MESSA,0) From GESECRAN
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 Commit

 Call PYRAMPRT("",NPLAN,[M:DIA]DOSDES) From LIENPYRACC
 If [M:DIA]DOSDES=nomap
  Call GLOBVAR From SETGLBCOA
 Endif

Return

#############################################################################
$AB_TR1
Rollback
Return

#############################################################################
$CONTMVT
OK=1
Gosub CONTBALANA
If !OK : Return
Else
 Gosub CONTBALANCE
 If !OK : Return
 Endif
Endif
Return

#############################################################################
$CONTBALANA
Filter [BLA] Where [BLA]COA=[F:GAC2]COA & [BLA]ACC=[F:GAC2]ACC
Read [BLA]BLA0 First
Filter [BLA]
If fstat=0 : OK=0 : MESSA="BALANA" : Return : Endif
Return

$CONTBALANCE
Filter [BAL] Where [BAL]COA=[F:GAC2]COA & [BAL]ACC=[F:GAC2]ACC
Read [BAL]BAL0 First
Filter [BAL]
If fstat=0 : OK=0 : MESSA="BALANCE" : Return : Endif
Return

#############################################################################
$CONTROLES
If [F:GAC2]FCY<>""
 Read [CPY]CPY0 = [F:GAC2]FCY
 If fstat
  Read [FCY]FCY0 = [F:GAC2]FCY
  If fstat
   [F:GAC2]FCY = ""
  Endif
 Endif
Endif
If [F:GAC2]CUR<>""
 Read [TCU]TCU0 = [F:GAC2]CUR
 If fstat
  [F:GAC2]CUR = ""
 Endif
Endif

For I=0 To dim([F:GAC2]VAT)-1
 If [F:GAC2]VAT(I)<>""
  If [F:COA2]LEG<>""
   Call LEC_TVT_LEG([F:COA2]LEG,[F:GAC2]VAT(I)) From CPTLEC
  Else
   Read [TVT]TVT0(1) = [F:GAC2]VAT(I)
  Endif
  If fstat
   [F:GAC2]VAT(I) = ""
  Endif
 Endif
Next I

If [F:GAC2]AUZ<>""
 Read [ADI]CODE = 321;[F:GAC2]AUZ
 If fstat
  [F:GAC2]AUZ = ""
 Endif
Endif
I = 0
While I<=[F:GAC2]COANBR-1
 K = 1
 Read [COA]COA0 = [F:GAC2]OTHCOA(I)
 If fstat
  K = 0
 Elsif [F:GAC2]DEFACC(I)<>""
  Read [GAC]GAC0 = [F:GAC2]OTHCOA(I);[F:GAC2]DEFACC(I)
  If fstat
   K = 0
  Endif
 Endif
 If !K
  Dela I,1 [F:GAC2]OTHCOA,[F:GAC2]DEFACC,[F:GAC2]SCRACC,[F:GAC2]OBYIPT
  [F:GAC2]COANBR -= 1
 Else
  I += 1
 Endif
Wend
I = 0
While I<=[F:GAC2]DACDIENBR-1
 K = 1
 Read [DIE]DIE0 = [F:GAC2]DIE(I)
 If fstat
  K = 0
 Elsif [F:GAC2]CCEDEF(I)<>""
  Read [CCE]CCE0 = [F:GAC2]DIE(I);[F:GAC2]CCEDEF(I)
  If fstat
   K = 0
  Endif
 Endif
 If !K
  Dela I,1 [F:GAC2]DIE,[F:GAC2]CCEDEF
  [F:GAC2]DACDIENBR -= 1
 Else
  I += 1
 Endif
Wend
If [F:GAC2]DSP<>""
 Read [DSP]DSP0 = [F:GAC2]DSP
 If fstat
  [F:GAC2]DSP = ""
 Endif
Endif
If [F:GAC2]ACS<>""
 Read [ACS]ACS0 = [F:GAC2]ACS
 If fstat
  [F:GAC2]ACS = ""
 Endif
Endif
If [F:GAC2]TIMDSP<>""
 Read [DTP]DTP0 = [F:GAC2]TIMDSP
 If fstat
  [F:GAC2]TIMDSP = ""
 Endif
Endif
If [F:GAC2]SUBBPR<>""
 Read [BPR]BPR0 = [F:GAC2]SUBBPR
 If fstat
  [F:GAC2]SUBBPR = ""
  [F:GAC2]SUBACC = ""
 Endif
Endif
If [F:GAC2]UOM<>""
 Read [TUN]TUN0 = [F:GAC2]UOM
 If fstat
  [F:GAC2]FLGUOM = 1
  [F:GAC2]UOM    = ""
  [F:GAC2]VALUOM = 0
 Endif
Endif
If [F:GAC2]FLODEB<>""
 Read [ADI]CODE = 324;[F:GAC2]FLODEB
 If fstat
  [F:GAC2]FLODEB = ""
  [F:GAC2]CSLFLGFLW=1
 Endif
Endif
If [F:GAC2]FLOCDT<>""
Read [ADI]CODE = 324;[F:GAC2]FLOCDT
 If fstat
  [F:GAC2]FLOCDT = ""
  [F:GAC2]CSLFLGFLW=1
 Endif
Endif
Return

#############################################################################
$COPY_RIB_ADD
#Fill in BPANUM (as for example ZKK431000=COA+ACC)
#the same for RIB and ADD
Call BPA ([F:GAC1]COA,[F:GAC1]ACC,BPA1) From SUBGAC
Call BPA ([F:GAC2]COA,[F:GAC2]ACC,BPA2) From SUBGAC

#Copy Address
For [BPA1]BPA0 Where BPATYP=5 & BPANUM=BPA1
 [F:BPA2] = [F:BPA1]
 [F:BPA2]BPANUM = BPA2

 [F:BPA2]CREUSR= GUSER
 [F:BPA2]CREDAT= date$
 [F:BPA2]CRETIM= time
 Write [BPA2]
 If fstat
   GOK = 0 : Call FSTA("BPA2") From GLOCK : Break
 Endif
Next

#Copy RIB
For [BID1]BID0 Where BPATYP=5 & BPANUM=BPA1
 [F:BID2] = [F:BID1]
 [F:BID2]BPANUM = BPA2

 [F:BID2]CREUSR= GUSER
 [F:BID2]CREDAT= date$
 [F:BID2]CRETIM= time
 Write [BID2]
 If fstat
  GOK = 0 : Call FSTA("BID2") From GLOCK : Break
 Endif
Next

Return

#############################################################################
$UPD_RIB_ADD
#Fill in BPANUM (as for example ZKK431000=COA+ACC)
#the same for RIB and ADD
Call BPA ([F:GAC1]COA,[F:GAC1]ACC,BPA1) From SUBGAC
Call BPA ([F:GAC2]COA,[F:GAC2]ACC,BPA2) From SUBGAC

#Update Address
For [BPA1]BPA0 Where BPATYP=5 & BPANUM=BPA1
 Read [BPA2]BPA0 = 5;BPA2;[F:BPA1]BPAADD
 #Address doesn't exist create it
 If fstat<>0
  Raz [BPA2]
  [F:BPA2] = [F:BPA1]
  [F:BPA2]BPANUM = BPA2
  [F:BPA2]CREUSR= GUSER
  [F:BPA2]CREDAT= date$
  [F:BPA2]CRETIM= time
  Write [BPA2]
  If fstat
    GOK = 0 : Call FSTA("BPA2") From GLOCK : Break
  Endif
 #Address exists update it without control
 Else
  Raz [BPA2]
  [F:BPA2] = [F:BPA1]
  [F:BPA2]BPANUM = BPA2
  [F:BPA2]CREUSR= GUSER
  [F:BPA2]CREDAT= date$
  [F:BPA2]CRETIM= time
  Rewrite [BPA2]
  If fstat
    GOK = 0 : Call FSTA("BPA2") From GLOCK : Break
  Endif
 Endif
Next

#Update RIB
For [BID1]BID0 Where BPATYP=5 & BPANUM=BPA1
 Read [BID2]BID0 = 5;BPA2;[F:BID1]BIDNUM;[F:BID1]BPAADD
 #RIB doesn't exist create it
If fstat<>0
  Raz [BID2]
  [F:BID2]       = [F:BID1]
  [F:BID2]BPANUM = BPA2
  [F:BID2]CREUSR = GUSER
  [F:BID2]CREDAT = date$
  [F:BID2]CRETIM = time
  Write [BID2]
  If fstat
    GOK = 0 : Call FSTA("BID2") From GLOCK : Break
  Endif
 #RIB exists update it without control
 Else
  Raz [BID2]
  [F:BID2]       = [F:BID1]
  [F:BID2]BPANUM = BPA2
  [F:BID2]CREUSR = GUSER
  [F:BID2]CREDAT = date$
  [F:BID2]CRETIM = time
  Rewrite [BID2]
  If fstat
    GOK = 0 : Call FSTA("BID2") From GLOCK : Break
  Endif
 Endif
Next

Return

#############################################################################
$RAZFIELDNPLAN
If FLGSAC
 Raz [F:GAC2]SAC
 Raz [F:GAC2]AUZBPR
 Raz [F:GAC2]UPDBLC
 Raz [F:GAC2]FLGABL
Endif
If FLGVAT1
 Raz [F:GAC2]FLGVAT
 Raz [F:GAC2]VATIPT
 Raz [F:GAC2]VAT
 Raz [F:GAC2]ESDTRK
Endif
If FLGTRK1
 Raz [F:GAC2]DIFFLG
 Raz [F:GAC2]FLGEXPCRE
 Raz [F:GAC2]GACACN
 Raz [F:GAC2]DAS
 Raz [F:GAC2]DASTYP
 Raz [F:GAC2]FLGDEP
Endif
If FLGTRK2
 Raz [F:GAC2]FLGUOM
 Raz [F:GAC2]UOM
 Raz [F:GAC2]VALUOM
 Raz [F:GAC2]BUDTRK
 Raz [F:GAC2]TIMDSP
 Raz [F:GAC2]DSP
Endif
Return

#############################################################################
Subprog COPTEXTRA(FIC,CHP,OID1,OID2,NID1,NID2)
Value Char FIC
Value Char CHP
Value Char OID1
Value Char OID2
Value Char NID1
Value Char NID2
For [AXX1]AXX0 Where CODFIC=FIC & ZONE=CHP & IDENT1=OID1 & IDENT2=OID2
 Read [AXX2]AXX0 = FIC;CHP;[F:AXX1]LANGUE;NID1;NID2
 If fstat
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = NID1
  [F:AXX2]IDENT2 = NID2
  Write [AXX2]
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = NID1
  [F:AXX2]IDENT2 = NID2
  Rewrite [AXX2]
 Endif
 If fstat
  GOK = 0 : Call FSTA("AXX2") From GLOCK : Break
 Endif
Next
End


#############################################################################
## Ecran GACCDUP
#############################################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]DOSORG
Endif
End

Subprog C_NCOA(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]COA & [M]DOSORG=[M]DOSDES
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
# Vérif de cohérences
Local File =[M:DIA]DOSDES+".GCOA"      [COA5]
Read [F:COA5]COA0 = VALEUR
If fstat
 #Plan de comptes inexistant
 GMESSAGE=mess(110,102,1): mkstat=2 :End
Else
 Local File =[M:DIA]DOSORG+".GCOA"      [COA4]
 Read [F:COA4]COA0 = [M]COA
 If fstat
  #Plan de comptes incompatible
  GMESSAGE=mess(93,102,1): mkstat=2 : End
 Elsif [F:COA5]ACCFMT<>[F:COA4]ACCFMT
  #Formats de comptes incompatibles
  GMESSAGE = mess(142,102,1) : mkstat=2 :End
 Elsif GNBLEG>1
  If [F:COA5]LEGCLS<>[F:COA4]LEGCLS
   # Copie impossible : classe de législation différente
   GMESSAGE = mess(129,102,1) : mkstat=2 : End
  Endif
 Endif
Endif
Close Local File [COA5],[COA4]
End

Subprog C_STRACC(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ENDACC(VALEUR)
Variable Char    VALEUR()
End


#############################################################################

