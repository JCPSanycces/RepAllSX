#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table POSCOD pour initialiser POSCTYSEA
# FGR 05/03/2012 : X3SUIVI79830
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update POSCOD POSCTYSEA initialiation") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJPOSCOD
End

#-------------------#
$MAJPOSCOD
#CHECK IGNORE_BEGIN

  # ------------------------------
  Local File =DOSSIER+".POSCOD" [POS]
  # ------------------------------
  # Mise à jour de la table POSCOD
  Call ECR_TRACE(mess(81,125,1) - "POSCOD :" - time$,0) From GESECRAN
  If dim([F:POS]POSCTYSEA) >= 0 Then
    Trbegin [F:POS]
    Update [POS] Where POSCTYSEA = "" With POSCTYSEA = toupper(POSCTY)
    If fstat Then
      Call ERREUR("POSCOD  fstat=" - num$(fstat), 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif
  Close Local File [POS]
  #CHECK IGNORE_END
Return

# Issue SAM121863 - 2017-04-06 by FGR : Missing subroutine
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#
Gosub MAJPOSCOD
End

