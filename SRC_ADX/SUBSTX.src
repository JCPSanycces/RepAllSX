#<AdxTL>@(#)2.0.0.0 $Revision$

#
#--- Programme de mise a jour de la table STATION / Centrale de pesée
#

Call OBJET ("STX" , GBIDC1,GBIDC2) From GOBJET
End





$ACTION
Case ACTION
 When "LIENS"    : Gosub LIENS    
 When "RAZCRE"   : Gosub RAZCRE    
 When "RAZDUP"   : Gosub RAZCRE    
 When "ANNULE"   : Gosub ANNULE
 When "CREATION" : Gosub CREATION
 When "MODIF"    : Gosub MODIF
 When "CHANGE"   : Call CHANGE_AXX ("STATION", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#Chargement dans le tableau de tous les postes de charge
#rattachés à ce centre
$LIENS
Local Integer WMAX : WMAX = 299
nolign = 0
Filter [F:SBX] Where STI = [M:STX1]STI
# 03.05 Performances
For [F:SBX]SBX1
    If nolign +1 >= WMAX : Break : Endif
    nolign += 1
    [M:STX1] = [F:SBX]

#[M:STX1]FCY       = [F:SBX]FCY
#[M:STX1]BOX       = [F:SBX]BOX
#[M:STX1]DES       = [F:SBX]DES
#[M:STX1]BOXOPGPCR = [F:SBX]BOXOPGPCR 
#[M:STX1]WOREPYPCR = [F:SBX]WOREPYPCR 
#[M:STX1]PHAEPYPCR = [F:SBX]PHAEPYPCR 
If [F:SBX]BOXOPGFLG  = 2
   [M:STX1]WX (nolign-1)       = "*"
Else
   [M:STX1]WX  (nolign-1)      = ""
Endif

If [F:SBX]WOREPYFLG  = 2
   [M:STX1]W1X (nolign-1)      = "*"
Else
   [M:STX1]W1X  (nolign-1)     = ""

Endif

If [F:SBX]PHAEPYFLG   = 2
   [M:STX1]W2X  (nolign-1)      = "*"
Else
   [M:STX1]W2X (nolign-1)       = ""

Endif

Next
Filter [F:SBX]

[M:STX1]NBLIG = nolign
Sorta [M:STX1]NBLIG [M:STX1]NBLIG Order By [M:STX1]FCY(indice) , [M:STX1]BOX(indice)


Return

###########################################################
#En création ou duplication de centre, effacement du tableau
$RAZCRE
Raz [M:STX1]NBLIG
Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="STATION" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif

Return
#############################################################
$CREATION
Call MAJTEXTRA([M:STX1]STXDESAXX,"STATION","STXDESAXX",[M:STX1]STI,"") From ATEXTRA
Call MAJTEXTRA([M:STX1]STXSHOAXX,"STATION","STXSHOAXX",[M:STX1]STI,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M:STX1]STXDESAXX,"STATION","STXDESAXX",[M:STX1]STI,"") From ATEXTRA
Call MAJTEXTRA([M:STX1]STXSHOAXX,"STATION","STXSHOAXX",[M:STX1]STI,"") From ATEXTRA

Return
#############################################################
