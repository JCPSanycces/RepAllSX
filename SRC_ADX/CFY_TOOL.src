#<AdxTL>@(#)0.0.0.0 $Revision$
# Company/Facility functions

#**
#* CFY_GETNAME - retrieve company or facility name depending on which is sent
#*
#* @param CPYFCY - Either company or facility
#* @param NAME   - Company or facility name
#* @param MESSAGE- Error message if not found
#* MY_STATUS - Error value
#*  [V]CST_AOK - if company or facility found
#*  [V]CST_AERROR - if not found
#*!
Funprog CFY_GETNAME(CPYFCY,NAME,MESSAGE)
Value Char CPYFCY
Variable Char NAME
Variable Char MESSAGE

Local Integer MY_STATUS
Raz NAME,MESSAGE
[L]MY_STATUS = [V]CST_AOK

  Local Instance MY_FACILITY Using C_FACILITY
  MY_FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]MY_STATUS = fmet MY_FACILITY.AREAD([L]CPYFCY)
  If [L]MY_STATUS = [V]CST_AOK
    [L]NAME = MY_FACILITY.FCYNAM
  Else
    Local Instance MY_COMPANY Using C_COMPANY
    MY_COMPANY = NewInstance C_COMPANY AllocGroup null
    [L]MY_STATUS = fmet MY_COMPANY.AREAD([L]CPYFCY)

    If [L]MY_STATUS = [V]CST_AOK
      [L]NAME = MY_COMPANY.CPYNAM
    Endif
    FreeGroup MY_COMPANY
  Endif
  FreeGroup MY_FACILITY

  If [L]MY_STATUS<>[V]CST_AOK
    [L]MESSAGE = mess(61,133,1)
  Endif

End [L]MY_STATUS
