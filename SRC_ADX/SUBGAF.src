#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GAF",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "RAZDUP"     : Gosub RAZDUP
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "AVANTBOUT"  : Gosub AVANTBOUT
 When "BB1_REFNUM" : Gosub BB1_REFNUM
 When "STATUT"     : Gosub STATUT
 When "LIENS"      : Gosub LIENS
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "ANNULE"     : Gosub ANNULE
 When "RAZCRE"     : Gosub RAZCRE
 When "FIN"        : Gosub FIN
Endcase
Return

$OUVRE
Local Char CREL(1) , CSIM(1)
Local Integer SAVCONS
If clalev([F:HAE]) =0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE]) =0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:GTE]) =0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:GTE1])=0 : Local File GTYPACCENT [GTE1]: Endif
If clalev([F:JOU]) =0 : Local File GJOURNAL   [JOU] : Endif

If dim(GCURLEG)>0  : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GCURFCY)>0  : Local Char SAV_GCURFCY(GLONFCY) : SAV_GCURFCY = GCURFCY   : Endif
If dim(GSOCIETE)>0 : Local Char SAV_GCURCPY(GLONCPY) : SAV_GCURCPY = GSOCIETE  : Endif
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG  = SAV_GCURLEG : Endif
If dim(SAV_GCURFCY)>0 : GCURFCY  = SAV_GCURFCY : Endif
If dim(SAV_GCURCPY)>0 : GSOCIETE = SAV_GCURCPY : Endif
Return

$SETBOUT
If [M]LASNUM(0) <> ""  : CHMEN +="1" : Endif
If [M]LASNUM(1) <> ""  : CHMEN +="2" : Endif

#->KC Vinci
# Si user veut être conforme DGI alors FRADGI à oui (niveau société)
If func AFNC.PARAM("FRADGI",[F:HAE]CPY)="2"
#Si piéce générée réelle impossible de supprimer et modifer sauf le flag Actif
 If LASNUM(0) <> ""
  Call VIREBOUT(CHAINE,"A") From GOBJET  #supprimer
  Diszo [M:GAF0]DESTRA
  Diszo[GAF1]
  Diszo[GAF2]
#si piéce générée simulation impossible de supprimer mais fiche modifiable
 Elsif LASNUM(1) <> ""
  Call VIREBOUT(CHAINE,"A")  From GOBJET  #supprimer
  Actzo [GAF0]
  Actzo [GAF1]
  Actzo [GAF2]
#sinon tout autorisé !
 Elsif LASNUM(0)= "" & LASNUM(1)= ""
  Actzo [GAF0]
  Actzo [GAF1]
  Actzo [GAF2]
 Endif
Endif
Return
#<-KC Vinci

$AVANTBOUT
Local Integer NOPCE
Case BOUT
 When "1" : NOPCE = 0 : Gosub AV_TUNNEL
 When "2" : NOPCE = 1 : Gosub AV_TUNNEL
Endcase
Return

$AV_TUNNEL
Read [HAE]HAE0 = [M]LASTYP(NOPCE);[M]LASNUM(NOPCE)
If fstat
 OK = 0 : Return
Endif
SAVCONS  = GCONSULT
GCONSULT = 1
Return

$STATUT
Case BOUT
 When "1"       # après tunnel vers les pièces comptables
   GCONSULT = SAVCONS
 When "2"       # après tunnel vers les pièces comptables
   GCONSULT = SAVCONS
Endcase
Return

$RAZCRE
Raz GCURLEG, GCURFCY, GSOCIETE
If GREP="C"
 [M:GAF0]ENAFLG=2
 Affzo [GAF0]
Endif
Return

$RAZDUP
Raz GCURLEG, GCURFCY, GSOCIETE
Raz [M]AMTCUM, [M]LASTYP , [M]LASNUM , [M]LASDAT
If GREP="D"
 [M:GAF0]ENAFLG=2
 Affzo [GAF0]
Endif
Return

$INICRE
$INIMOD
If dim([F:GAF]DES)>0
 [F:GAF]DES = [M:GAF0]DESTRA
Endif
Return

$LIENS
If [F:GAF]TYP=1
 Grizo [GAF1]DSPTMP,AMT
 Actzo [GAF1]PERTYP
Else
 Actzo [GAF1]DSPTMP,AMT
 Diszo [GAF1]PERTYP
Endif
If [M]REFTYP<>""
 Read [HAE]HAE0 = [M]REFTYP;[M]REFNUM
 If !fstat
  [M]REFCUR = [F:HAE]CUR
  Call GETSOC([F:HAE]FCY) From DEVSUB
 Endif
Endif
Call LECTEXTRA([M:GAF0]DESTRA,"GACCFIX","DESTRA",[M:GAF0]COD,"") From ATEXTRA
Call LECTEXTRA([M:GAF1]SHOTRA,"GACCFIX","SHOTRA",[M:GAF0]COD,"") From ATEXTRA
Return

$BB1_REFNUM
If VALEUR<>""
 [M:GAF1]REFTYP = [F:HAE]TYP : Affzo REFTYP
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCFIX","DESTRA",CLECUR1,"","GACCFIX","DESTRA",[M:GAF0]COD,"")  From ATEXTRA
 Call DUPTEXTRA("GACCFIX","SHOTRA",CLECUR1,"","GACCFIX","SHOTRA",[M:GAF0]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:GAF0]DESTRA,"GACCFIX","DESTRA",[M:GAF0]COD,"") From ATEXTRA
Call MAJTEXTRA([M:GAF1]SHOTRA,"GACCFIX","SHOTRA",[M:GAF0]COD,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("GACCFIX","DESTRA",[M:GAF0]COD,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GACCFIX","SHOTRA",[M:GAF0]COD,"",NCODE,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GACCFIX","DESTRA",[M:GAF0]COD,"") From ATEXTRA
Call SUPTEXTRA("GACCFIX","SHOTRA",[M:GAF0]COD,"") From ATEXTRA
Return


###################################################################################
## Etiquettes masques GAF0, GAF1 et GAF2
###################################################################################
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Read [HAE]HAE0 = [M]REFTYP;VALEUR
If fstat
 GMESSAGE = mess(28,107,1)
 mkstat=2 : End
Else
 [M]REFCUR = [F:HAE]CUR
 If [M]ENDDAT<>[0/0/0]
  Call CONTDEV([F:HAE]CUR,[M]ENDDAT) From TRTDEV
  If mkstat : End : Endif
 Endif
Endif
Call GETSOC([F:HAE]FCY) From DEVSUB
End

Subprog C_TYP1(VALEUR)
Variable Char    VALEUR()
Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
Call CONTEXE([F:GTE]ACS) From CPTSUB : If mkstat : End : Endif
If [F:GTE]VCRREA<>2
 GMESSAGE = mess(33,107,1)
 mkstat = 2 : End
Elsif [F:GTE]COU=""
 GMESSAGE = mess(31,107,1)
 mkstat = 2 : End
Elsif [F:GTE]VLYSTR>[M]STRDAT
 GMESSAGE = mess(34,107,1)-format$("D:"+GFMDAT4,[F:GTE]VLYSTR)
 mkstat = 2 : End
Elsif [F:GTE]VLYEND<>[0/0/0] & [F:GTE]VLYEND<[M]ENDDAT
 GMESSAGE = mess(35,107,1)-format$("D:"+GFMDAT4,[F:GTE]VLYEND)
 mkstat = 2 : End
Endif
# Ctrl que le type de piéce doit avoir au moins les mêmes référentiels autorisés ou obligatoires
# que ceux de la piéce modéle (REFTYP) sélectionnée dans GAF1.
If [F:GTE1]TYP<>[M:GAF1]REFTYP | [F:GTE1]LEG<>GCURLEG
 Read [GTE1]GTE0 = [M:GAF1]REFTYP;GCURLEG
 If fstat
  Read [GTE1]GTE0 = [M:GAF1]REFTYP;""
 Endif
Endif
For J=0 To (len(mess(0,2644,1))-1)
 If [F:GTE1]AUZLED(J)= 2 or [F:GTE1]AUZLED(J)= 3
  If [F:GTE]AUZLED(J)=1
   GMESSAGE = mess(29,107,1)
   mkstat=2 : Break
  Endif
 Endif
Next
If mkstat=2 : End : Endif
End

Subprog D_JOU1(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GAS",[M]REFNUM,[M]REFTYP) From CONTOBJ
VALEUR = [F:HAE]JOU
End

Subprog C_JOU1(VALEUR)
Variable Char    VALEUR()
Call LEC_GTE_LEG(GCURLEG,[M]TYP1) From CPTLEC
Call CONTEXE([F:JOU]ACS) From CPTSUB : If mkstat : End : Endif
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = mess(51,106,1)
 mkstat = 2 : End
Endif
If [F:JOU]FCY<>""
 Call LECTURE("GAS",[M]REFNUM,[M]REFTYP) From CONTOBJ
 Call VERSOC([F:JOU]FCY,[F:HAE]CPY,[F:HAE]FCY,[F:JOU]JOU) From CFYSUB
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Call CONTDEV([M]REFCUR,VALEUR) From TRTDEV
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Call CONTDEV([M]REFCUR,VALEUR) From TRTDEV
End

Subprog AP_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : # Lissé -> Mois
 Actzo [GAF1]DSPTMP, AMT
 [M]PERTYP = 5 : If !GIMPORT : Affzo PERTYP : Diszo PERTYP : Endif
Else
 Grizo [GAF1]DSPTMP, AMT : Actzo PERTYP
Endif
End

Subprog AS_PERTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP=2
 VALEUR = 5
 mkstat = 2 : End
Endif
End

Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
If [M]TYP=2
 Call LECTURE("GAS",[M]REFNUM,[M]REFTYP) From CONTOBJ
 VALEUR = [F:HAE]CUR
Endif
End

Subprog AS_AMT(VALEUR)
Variable Decimal VALEUR
If [M]TYP=1
 mkstat = 1 : End
Endif
End

Subprog AS_DSPTMP(VALEUR)
Variable Char    VALEUR()
If [M]TYP=1
 mkstat = 1 : End
Endif
End

Subprog D_TYP1(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GAS",[M]REFNUM,[M]REFTYP) From CONTOBJ
VALEUR = [F:HAE]TYP
End

Subprog C_RVSDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]STRDAT
 GMESSAGE=mess(1,104,1)-"<"-format$("D:"+GFMDAT,[M]STRDAT)
 mkstat = 2 : End
Endif
End

#->KC Vinci : ajout du champ Actif écran GAF0
Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
End
#<-KC Vinci



######################################################################################
