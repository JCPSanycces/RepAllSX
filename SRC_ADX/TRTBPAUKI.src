Subprog UKI_FIELDS
#Open Company Tables
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif

#Getting data from Legal data
Read [F:CPY]CPY0 = [M:FCY1]LEGCPY
If !fstat
  If [F:CPY]LEG = "BRI" Then
    Call HIDE_FIELDS
  Else
    Call SHOW_FIELDS
  Endif
Endif

End

Subprog HIDE_FIELDS
  If dim([M:BIF]NBRIB)>0      : Raz [M:BIF]NBRIB      :   Chgfmt [M:BIF]NBRIB       With"-Nz:4"  : Endif
#JASMI - 2017-09-20 - X3-53094 - START
#  If dim([M:BIF]BIDCRY)>0     : Raz [M:BIF]BIDCRY     :   Chgfmt [M:BIF]BIDCRY      With"-K:3"   : Endif
