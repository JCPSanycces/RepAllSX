#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
    When Default
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELTAB"    : Gosub SELTAB
Endcase
Return

$SELTAB
Local Char MSK(250) : [L]MSK = ''

Case GFONCTION
  When "GESSDH" : [L]MSK = '[M:SDH3]GLBDOCTYP'
  When "GESSRH" : [L]MSK = '[M:SRH2]GLBDOCTYPR'
  When "GESSRL" : [L]MSK = '[M:SRL2]GLBDOCTYPR'
  When "GESSRS" : [L]MSK = '[M:SRS2]GLBDOCTYPR'
  When "GESTNH" : [L]MSK = '[M:TNH2]GLBDOCTYP'
Endcase

Case evalue([L]MSK)
  When 2
    If clalev([F:SDHS])=0 : Local File SDELIVERY [SDHS] : Endif
    Default File [SDHS]
    CRITERE = "GLBDOC=2 & CFMFLG=2"
    TIT(0) = mess(4,701,1)
    COL(1) = "SDHNUM"
    COL(2) = "SHIDAT"
    COL(3) = "BPCORD"
    START  = "SDHNUM"
  When 3
    If clalev([F:SRHS])=0 : Local File SRETURN   [SRHS] : Endif
    Default File [SRHS]
    CRITERE = "GLBDOCR=2 & SRHCFMFLG=2"
    TIT(0) = mess(22,701,1)
    COL(1) = "SRHNUM"
    COL(2) = "RTNDAT"
    COL(3) = "BPCORD"
    START  = "SRHNUM"
  When 10
    If clalev([F:TNHS])=0 : Local File TRANNOTEH   [TNHS] : Endif
    Default File [TNHS]
    CRITERE = "GLBDOC=2 & CFMFLG=2"
    TIT(0) = mess(22,701,1)
    COL(1) = "TNHNUM"
    COL(2) = "TRNDAT"
    COL(3) = "BPRNUM"
    START  = "TNHNUM"
  When Default
Endcase

NBCOL  = 3
TIT(1) = mess(2,176,1)
TIT(2) = mess(23,105,1)
TIT(3) = mess(2,76,1)
SIZLIG = 100
SIZCOL = 200 : # FQ 49950 avant 120
DEFPAG=1

Return
