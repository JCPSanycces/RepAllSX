#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PSO4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG4
mkstat = 0
zoncou = "NBLIG4"
indice = 0
status = 1
zoncou = "NBLIG4"
If varmode([M]NBLIG4,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG4" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG4
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG4 = nolign
   status = 75
   Call SAI_NBLIG4(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG4(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG4
mkstat = 0
zoncou = "NBLIG4"

## Zone PFMTOT
mkstat = 0
zoncou = "PFMTOT"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]PFMTOT(indice) : Endif

## Zone QUONOT
mkstat = 0
zoncou = "QUONOT"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]QUONOT(indice) : Endif

## Zone QUOATI
mkstat = 0
zoncou = "QUOATI"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]QUOATI(indice) : Endif

## Zone QUOINVNOT
mkstat = 0
zoncou = "QUOINVNOT"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]QUOINVNOT(indice) : Endif

## Zone QUOINVATI
mkstat = 0
zoncou = "QUOINVATI"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PSO4]QCUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]QUOINVATI(indice) : Endif

## Zone NBLIG4
mkstat = 0
zoncou = "NBLIG4"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PSO4"
Return

