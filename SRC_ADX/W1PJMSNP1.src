#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNP1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:52"
A_USER  = "DOC"
A_STAMP = "20181109230552"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMSNP1 [PSNP1]
Gosub HORODAT
Local Inpbox "PJMSNP1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PSNP1] As [SIM_]
Grizo [PSNP1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PSNP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMSNP1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBPJMSNP
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(12102,GBOUT1) From OBJDIV
Call TEXTE(1003780,GBOUT2) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMSNP1
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1PJMSNP1
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMFINOV0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMFINOV0"
 PARMSK(1) = [M:PSNP0]OPPNUM
 PARMSK(2) = ""
 PARMSK(3) = [M:PSNP1]KEYEXT(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMFINOV0","PJMFINOV0","") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMSNPCMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMSNPCMP"
 PARMSK(1) = [M:PSNP1]KEYEXT(nolign-1)
 PARMSK(2) = [M:PSNP0]OPPNUM
 PARMSK(3) = [M:PSNP0]SNPCOD
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMSNPCMP","PJMSNPCMP","SPESNPCMP") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_BTCMT
Onevent BEFORE_INPUT Call AS_BTCMT(zc) From W1PJMSNP1
Onevent INIT_AREA Call D_BTCMT(zc) From W1PJMSNP1
Return

Subprog D_BTCMT(VALEUR)
Variable Char    VALEUR()
If varinit([M]BTCMT,indice)=0
 VALEUR = 167
Endif
Gosub _AFF
End

Subprog AS_BTCMT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_BTCMT(zc) From W1PJMSNP1
Gosub _AFF
End

Subprog CL_BTCMT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PJMTXTCLA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMTXTCLA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "ACL_BTCMT" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMSNP1"
 PARMSK(2) = "PSNP1"
 PARMSK(3) = num$(nolign-1)
 PARMSK(4) = "CLOB"
 PARMSK(5) = "ACT"
 PARMSK(6) = [M:PSNP1]KEYEXT(nolign-1)
 Call SAISIE_CHAR(VALEUR,PARMSK,"PJMTXTCLA","SUBPJMCLA","") From GSAISIE
 ACTION = "BCL_BTCMT" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DDESAXX
Onevent INIT_AREA Call D_DDESAXX(zc) From W1PJMSNP1
Onevent BEFORE_INPUT Call AS_DDESAXX(zc) From W1PJMSNP1
Onevent CONTROL Call C_DDESAXX(zc) From W1PJMSNP1
Return

Subprog IB_DDESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DDESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]DDESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMSNPD","DDESAXX",[M:PSNP1]KEYEXT(nolign-1),"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DDESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DDESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DDESAXX(zc) From W1PJMSNP1
Gosub _AFF
End

Subprog C_DDESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DDESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DDESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DDESAXX" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMSNPD"
 PARMSK(2) = "DDESAXX"
 PARMSK(3) = [M:PSNP1]KEYEXT(nolign-1)
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DDESAXX" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_SNPDDTECRE
Onevent BEFORE_AREA Gosub AV_SNPDDTECRE From W1PJMSNP1
Return

$AV_SNPDDTECRE
Chgfmt [M]SNPDDTECRE(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_KEYEXT
Return

$CHG_STY
Return


