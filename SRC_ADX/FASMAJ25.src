###################################################################################
###################################################################################
###################################################################################

Subprog AMAJ

Onerrgo ERREUR From DOSMAJ


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

Local Char    WTITLE

  WTITLE = "FASMAJ25 - Fixed Assets module "
  Call ECR_TRACE("**********************************",0) From GESECRAN
  Call ECR_TRACE(WTITLE,0)                               From GESECRAN
  Call ECR_TRACE("**********************************",0) From GESECRAN
 
  Gosub CRT_GLOBALES 

  Call ECR_TIME(WTITLE+": EVExxx tables upgrade") From DOSSUB
  Call AMAJ_EVENT ([F:ADS]DOSSIER)      From FASMAJ25 

  Call ECR_TIME(WTITLE+": ASTYLE table upgrade") From DOSSUB
  Call AMAJ_ASTYLE ([F:ADS]DOSSIER)     From FASMAJ25 

  Call ECR_TIME(WTITLE+": AOBJET table upgrade") From DOSSUB
  Call AMAJ_AOBJET ([F:ADS]DOSSIER)    From FASMAJ25

  Call ECR_TIME(WTITLE+": AOBJEXT table upgrade") From DOSSUB
  Call AMAJ_AOBJEXT ([F:ADS]DOSSIER)    From FASMAJ25

  Call ECR_TIME(WTITLE+": AMSK table upgrade") From DOSSUB
  Call AMAJ_AMSK ([F:ADS]DOSSIER)       From FASMAJ25

  Call ECR_TIME(WTITLE+": DPRMOD table upgrade") From DOSSUB
  Call AMAJ_DPRMOD ([F:ADS]DOSSIER)     From FASMAJ25

  Call ECR_TIME(WTITLE+": RUBASSDEFP table upgrade") From DOSSUB
  Call AMAJ_RUBASSDEFP ([F:ADS]DOSSIER) From FASMAJ25

  Call ECR_TIME(WTITLE+": CONTEXT table upgrade") From DOSSUB
  Call AMAJ_CONTEXT ([F:ADS]DOSSIER)    From FASMAJ25

  Call ECR_TIME(WTITLE+": FISCYEAR table upgrade") From DOSSUB
  Call AMAJ_FISCYEAR ([F:ADS]DOSSIER)   From FASMAJ25

  Call ECR_TIME(WTITLE+": GACCCODLIG table upgrade") From DOSSUB
  Call AMAJ_GACCCODLIG ([F:ADS]DOSSIER)    From FASMAJ25

  Call ECR_TIME(WTITLE+": GAUTACE table upgrade") From DOSSUB
  Call AMAJ_GAUTACE ([F:ADS]DOSSIER)    From FASMAJ25

  Call ECR_TIME(WTITLE+": TYPACE table upgrade") From DOSSUB
  Call AMAJ_TYPACE ([F:ADS]DOSSIER)     From FASMAJ25

  If G_LEA_ACTIF Then
    Call ECR_TIME(WTITLE+": LEASE table upgrade") From DOSSUB
    Call AMAJ_LEASE ([F:ADS]DOSSIER)      From FASMAJ25
  Else
    Call ECR_TIME(WTITLE+": activity code LEA is set to No. LEASE table is not upgraded") From DOSSUB
  Endif

  If G_GRT_ACTIF Then
    Call ECR_TIME(WTITLE+": GRANTS table upgrade") From DOSSUB
    Call AMAJ_GRANTS ([F:ADS]DOSSIER)     From FASMAJ25
  Else
    Call ECR_TIME(WTITLE+": activity code GRT is set to No. GRANTS table is not upgraded") From DOSSUB
  Endif

  Call ECR_TIME(WTITLE+": FXDASSETS table upgrade") From DOSSUB
  Call AMAJ_FXDASSETS ([F:ADS]DOSSIER)  From FASMAJ25

  Call ECR_TIME(WTITLE+": DEPREC table upgrade") From DOSSUB
  Call AMAJ_DEPREC ([F:ADS]DOSSIER ) From FASMAJ25

  Call ECR_TIME(WTITLE+": FXDLIFL table upgrade") From DOSSUB
  Call AMAJ_FXDLIFL ([F:ADS]DOSSIER ) From FASMAJ25

  Gosub SUP_GLOBALES 
End

#--------------------------------------
$CRT_GLOBALES

  # Dimensionnement selon nombre de sociétés
  If clalev([CPY]) : Close File [CPY] : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY" [CPY]
  Local Integer  NBSOC : NBSOC = nbrecord([CPY])
  If NBSOC
   Global Integer G_PLNSUB      (1..NBSOC)
   Global Char    G_SOC(GLONCPY)(1..NBSOC)
  Endif
  Close File [CPY]


  # Indique si l'exécution se fait dans une transaction
  Global Integer G_TRANSAC : G_TRANSAC = adxlog

  # Lecture des codes activités AbelX3
  Global Integer G_IAS_ACTIF 
  Global Integer G_LEA_ACTIF 
  Global Integer G_GRT_ACTIF 

  Call ACTIV_DOS_AUTRE([F:ADS]DOSSIER, "IAS", G_IAS_ACTIF) From VERFDOS25
  Call ACTIV_DOS_AUTRE([F:ADS]DOSSIER, "LEA", G_LEA_ACTIF) From VERFDOS25
  Call ACTIV_DOS_AUTRE([F:ADS]DOSSIER, "GRT", G_GRT_ACTIF) From VERFDOS25

  Call ECR_TIME(WTITLE-"Activity code IAS :"-mess(G_IAS_ACTIF+1,1,1)) From DOSSUB
  Call ECR_TIME(WTITLE-"Activity code LEA :"-mess(G_LEA_ACTIF+1,1,1)) From DOSSUB
  Call ECR_TIME(WTITLE-"Activity code GRT :"-mess(G_GRT_ACTIF+1,1,1)) From DOSSUB
  Call ECR_TRACE("-----------------",0) From GESECRAN
Return

#--------------------------------------
$SUP_GLOBALES
  If (dim(G_PLNSUB)    >0) Then : Kill G_PLNSUB     : Endif
  If (dim(G_SOC)       >0) Then : Kill G_SOC        : Endif
  If (dim(G_IAS_ACTIF) >0) Then : Kill G_IAS_ACTIF  : Endif
  If (dim(G_LEA_ACTIF) >0) Then : Kill G_LEA_ACTIF  : Endif
  If (dim(G_GRT_ACTIF) >0) Then : Kill G_GRT_ACTIF  : Endif
  If (dim(G_TRANSAC)   >0) Then : Kill G_TRANSAC    : Endif
Return


###################################################################################
###################################################################################
###################################################################################

Subprog MAJ
#-------------------------------------#
#         Après mise à jour           #
#-------------------------------------#
Onerrgo ERREUR From DOSMAJ

  Local Integer TRANSAC : TRANSAC = adxlog

  # RAZ de la table diverse 539 et ajout du code X
  If clalev([F:WADI]) : Close File [WADI] : Endif
  Local File ="ATABDIV"            [WADI]

  If !TRANSAC : Trbegin [WADI] : Endif
  Delete [WADI] Where NUMTAB=539

  [F:WADI]NUMTAB=539
  [F:WADI]CREUSR=GUSER
  [F:WADI]CREDAT=date$
  [F:WADI]CRETIM=time
  [F:WADI]UPDUSR=GUSER
  [F:WADI]UPDDAT=date$
  [F:WADI]UPDTIM=time
  [F:WADI]CODE="X"
    
  Write [WADI]
  If !TRANSAC : Commit : Endif
  Close File [WADI]

  # Remise à "A définir" des paramètres de migration

  If clalev([F:WADV]) : Close File [WADV] : Endif
  Local File ="ADOVAL"             [WADV]
  GOK=1 : If !adxlog : Trbegin [F:WADV] : Local Integer LTRS : Endif
  Update [F:WADV] Where PARAM="KEEPEVT140" With VALEUR=num$(3)
  If fstat : Call ECR_TRACE("Error while updating KEEPEVT140 parameter - Update fstat="-num$(fstat),1) From GESECRAN : GOK=0 : Endif
  Update [F:WADV] Where PARAM="KEEPPARACE" With VALEUR=num$(3)
  If fstat : Call ECR_TRACE("Error while updating KEEPPARACE parameter - Update fstat="-num$(fstat),1) From GESECRAN : GOK=0 : Endif
  Update [F:WADV] Where PARAM="TYPPSTCURR" With VALEUR=num$(3)
  If fstat : Call ECR_TRACE("Error while updating TYPPSTCURR parameter - Update fstat="-num$(fstat),1) From GESECRAN : GOK=0 : Endif
  If dim(LTRS)>0
   If GOK
    Commit
   Else
    Rollback
   Endif
  Endif

End


###################################################################################
###################################################################################
###################################################################################
Subprog  AMAJ_ASTYLE (PDOSSIER)
#  
#  
# - Objet  : recopie des nouveaux styles AbelX3 dans le dossier applicatif
#
# - Règles : 
#            - copie des styles BACKRED, BACKGREEN, BACKYELLOW, BACKORANGE, BACKGREY
#
#            - si le style existe déjà, il est écrasé
# 

Value Char PDOSSIER

Local Integer NB_CRE  : NB_CRE = 0
Local Char    STYLE(10)

  If clalev([ASY])   : Close File [ASY]   : Endif
  If clalev([ASYM])  : Close File [ASYM]  : Endif
  Local File =PDOSSIER+".ASTYLE"     [ASY]
  Local File =adxmother(0)+".ASTYLE" [ASYM]

  If !G_TRANSAC : Trbegin [ASY] : Endif

  # BACKGREEN
  STYLE="BACKGREEN"
  Gosub COPIE_STYLE

  # BACKYELLOW
  STYLE="BACKYELLOW"
  Gosub COPIE_STYLE

  # BACKRED
  STYLE="BACKRED"
  Gosub COPIE_STYLE

  # BACKGREY
  STYLE="BACKGREY"
  Gosub COPIE_STYLE

  # BACKORANGE
  STYLE="BACKORANGE"
  Gosub COPIE_STYLE

  # Validation des styles
  Call GENSTYLE(PDOSSIER,"DEFAULT") From SUBASY

  If !G_TRANSAC : Commit : Endif

  Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED  ASTYLE" , 0) From GESECRAN

  Close File [ASY]
  Close File [ASYM]
End

$COPIE_STYLE
  Read [ASYM]ASY0=STYLE
  
  If fstat
    Call ECR_TRACE("ASTYLE :"-STYLE-"not found",1) From GESECRAN
    GERRDOS = 1
  Else
    Read [ASY]ASY0=STYLE

    If fstat
      [F:ASY] = [F:ASYM]
       Write [F:ASY]
    Else
      [F:ASY] = [F:ASYM]
      Rewrite [F:ASY] Curr
    Endif

    If fstat
      Call ECR_TRACE("ASTYLE : could not create"-STYLE-"error"-num$(fstat),1) From GESECRAN
    Else
      NB_CRE += 1
    Endif
  Endif
Return

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_ASTYLE -*
#*************************************
#*************************************

###################################################################################
Subprog  AMAJ_EVENT (PDOSSIER)
#  
#  
# - Objet  : 
#
# - Règles : 
#            - 
#
#            - 
# 

Value Char PDOSSIER

 Local Char    LPARAM
 Call  PARAM("","KEEPEVT140",LPARAM) From ADOVAL
 If val(LPARAM)=3
  Call ECR_TRACE( "Error  : You have to set the value of the KEEPEVT140 parameter (AAS Chapter / MIG group) before the migration process.", 1) From GESECRAN      
  GOK=0
  End
 Endif

 Local Integer NB_DEL_LOF
 Local Integer NB_DEL_FAS
 Local Integer NB_DEL_GRT
 Local Integer NB_DEL_LEA
 
 If clalev([F:ELF]) : Close File [ELF] : Endif
 If clalev([F:EFS]) : Close File [EFS] : Endif
 If G_GRT_ACTIF & clalev([F:EGT]) : Close File [EGT] : Endif
 If G_LEA_ACTIF & clalev([F:ELA]) : Close File [ELA] : Endif

 Local File =PDOSSIER+".EVELOF"     [ELF]
 Local File =PDOSSIER+".EVEFAS"     [EFS]
 If G_GRT_ACTIF : Local File =PDOSSIER+".EVEGRT"     [EGT] : Endif
 If G_LEA_ACTIF : Local File =PDOSSIER+".EVELEA"     [ELA] : Endif

 Gosub SET_FIRST From TRTFIRST

 If !adxlog : Trbegin [F:EFS] : Local Integer L_TRS : Endif

 Delete [F:ELF] Where (1=1)
 If fstat
  Call ECR_TRACE("EVELOF, Deleting events - "-PDOSSIER-" - File ERROR ="-num$(fstat),1) From GESECRAN
  GERRDOS = 1        
 Else
  NB_DEL_LOF = adxdlrec
 Endif

 Delete [F:EFS] Where (1=1)
 If fstat
  Call ECR_TRACE("EVEFAS, Deleting events - "-PDOSSIER-" - File ERROR ="-num$(fstat),1) From GESECRAN
  GERRDOS = 1        
 Else
  NB_DEL_FAS = adxdlrec
 Endif

 If G_LEA_ACTIF
  Delete [F:ELA] Where (1=1)
  If fstat
   Call ECR_TRACE("EVELEA, Deleting events - "-PDOSSIER-" - File ERROR ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1        
  Else
   NB_DEL_LEA = adxdlrec
  Endif
 Endif

 If G_GRT_ACTIF
  Delete [F:EGT] Where (1=1)
  If fstat
   Call ECR_TRACE("EVEGRT, Deleting events - "-PDOSSIER-" - File ERROR ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1        
  Else
   NB_DEL_GRT = adxdlrec
  Endif
 Endif

 If dim(L_TRS)>0
  If GERRDOS
   Rollback
  Else
   Commit
  Endif
 Endif

 Gosub UNSET_FIRST From TRTFIRST

 Call  ECR_TRACE ("    "-num$(NB_DEL_LOF)-" DELETED LAYOUTFAS V140 EVENTS" , 0) From GESECRAN
 Call  ECR_TRACE ("    "-num$(NB_DEL_FAS)-" DELETED FXDASSETS V140 EVENTS" , 0) From GESECRAN
 If G_LEA_ACTIF
  Call ECR_TRACE ("    "-num$(NB_DEL_LEA)-" DELETED LEASE     V140 EVENTS" , 0) From GESECRAN
 Endif
 If G_GRT_ACTIF
  Call ECR_TRACE ("    "-num$(NB_DEL_GRT)-" DELETED GRANTS    V140 EVENTS" , 0) From GESECRAN
 Endif

 If clalev([F:ELF]) : Close File [ELF] : Endif
 If clalev([F:EFS]) : Close File [EFS] : Endif
 If G_GRT_ACTIF & clalev([F:EGT]) : Close File [EGT] : Endif
 If G_LEA_ACTIF & clalev([F:ELA]) : Close File [ELA] : Endif

End

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_EVENT -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_AOBJET (PDOSSIER)
#  
# - Objet  : Copie complète de certains objets pour s'assurer que les paramètres de sélection
#            sont bien à jour
#
# - Règles : 
#             
# 
  # Objet FLU
  Call COPOBJ(adxmother(0), PDOSSIER, "AOB", "FLU", "", "", "") From ACOPIE
  If GERR
    Call ECR_TRACE("  Error while copying object FLU",1) From GESECRAN
    GERRDOS = 1     
  Else
    Call ECR_TRACE("  Object FLU copied",0) From GESECRAN
  Endif
End

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_AOBJET -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_AOBJEXT (PDOSSIER)
#  
# - Objet  : Mise à jour des tables AOBJEXT et AOBJEXTD (modèles d'import/export) 
#
# - Règles : On sauvegarde les modèles 140 en les renommant "V14xxx"
#            On copie du dossier racine les modèles standards
#             
# 

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

 Local Integer NB_MAJ
 Local Integer NB_CRE
 Local Integer NB_DEL

 Local Integer COMPTEUR

 If clalev([AAOE])  : Close File      [AAOE]  : Endif 
 Local File =adxmother(0)+".AOBJEXT"  [AAOE]  
 If clalev([AOE])   : Close File      [AOE]   : Endif 
 Local File =PDOSSIER+".AOBJEXT"      [AOE]  
 If clalev([AAOD])  : Close File      [AAOD]  : Endif 
 Local File =adxmother(0)+".AOBJEXTD" [AAOD]  
 If clalev([AOD])   : Close File      [AOD]   : Endif 
 Local File =PDOSSIER+".AOBJEXTD"     [AOD]  

 If clalev([WADS])   : Close File     [WADS]   : Endif 
 Local File =adxmother(0)+".ADOSSIER" [WADS]  
 If clalev([WAXX])   : Close File     [WAXX]   : Endif 
 Local File =PDOSSIER+".ATEXTRA"      [WAXX]  

 #> Lecture des paramètres du dossier pour avoir sa langue par défaut
 Read [WADS]DOSSIER=PDOSSIER
 If fstat
  Call ECR_TRACE("AOBJEXTD, Reading folder - "-PDOSSIER-" - File ERROR ="-num$(fstat),1) From GESECRAN
  GERRDOS = 1     
 Endif

 Gosub SET_FIRST From TRTFIRST

 If !adxlog : Trbegin [F:AOE], [F:AOD], [WAXX] : Local Integer L_TRS : Endif

 #> Conservation des modèles du dossier 140 en les renommant

 COMPTEUR = 0

 For [F:AOE]AOE0 With Stability
  COMPTEUR    += 1

  For [F:AOD]AOD0 Where EXT=[F:AOE]EXT With Stability
   [F:AOD]EXT="V14"+format$("N0:7", COMPTEUR)
   Rewrite [F:AOD] Curr
   If fstat
    Call ECR_TRACE("AOBJEXTD, Step 01 Rewrite - "-[F:AOD]EXT-" - File ERROR ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1  
   Endif
  Next

  [F:AOE]EXT    = "V14"+format$("N0:7", COMPTEUR)
  [F:AOE]ENAFLG = G_NON
  Rewrite [F:AOE] Curr
  If fstat
   Call ECR_TRACE("AOBJEXT, Step 02 Rewrite - "-[F:AOE]EXT-" - File ERROR ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1  
  Else
   NB_MAJ += 1
  Endif

  # Creation de l'intitulé dans la langue par défaut du dossier
  Raz [F:WAXX]
  [F:WAXX]CODFIC = "AOBJEXT"
  [F:WAXX]ZONE   = "INTIT"
  [F:WAXX]LANGUE = [F:WADS]LANDEF
  [F:WAXX]TEXTE  = [F:AOE]DES
  [F:WAXX]IDENT1 = [F:AOE]EXT
  [F:WAXX]IDENT2 = ""
  If dim([F:WAXX]CREDAT)>0 : [F:WAXX]CREDAT = date$ : Endif
  If dim([F:WAXX]CREUSR)>0 : [F:WAXX]CREUSR = GUSER : Endif
  Write [WAXX]
  If fstat
   Call ECR_TRACE("AOBJEXT, Step 03 Write - File ERROR ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1  
  Endif
 Next 

 If dim(L_TRS)
  If GERRDOS
   Rollback
  Else
   Commit
  Endif
 Endif

 #> Copie des modèles standards depuis le dossier racine

 For [F:AAOE]AOE0
  GOK = 1
  Call COPOBJ(adxmother(0), PDOSSIER, "AOE", [F:AAOE]EXT, "", "", "") From ACOPIE
  If GOK = 0
   Call ECR_TRACE("AOBJEXTD, Step 03 Write - "-[F:AAOE]EXT,1) From GESECRAN    
   GERRDOS = 1  
  Else
    NB_CRE += 1
  Endif
 Next

 #> Fin

 Gosub UNSET_FIRST From TRTFIRST

 Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED IMPORT/EXPORT" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED IMPORT/EXPORT" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_DEL)-" DELETED IMPORT/EXPORT" , 0) From GESECRAN

 Close Local File [AAOE] 
 Close Local File [AAOD] 
 Close Local File [AOE] 
 Close Local File [AOD] 
 Close Local File [WADS] 
 Close Local File [WAXX] 
End

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_AOBJEXT -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_AMSK (PDOSSIER)
#  
#  
# - Objet      : Permettre la mise à jour des paramètres nombre de lignes/colonnes des masque
#
# - Règles : 
#            - Pour les masques des modules immobilisation (5) et financement (4), sans code activité, mise à 0 des 
#              champs nombre de lignes/colonnes 
# 
Local Integer NB_CRE  : NB_CRE = 0
Local Integer NB_MAJ  : NB_MAJ = 0
Local Integer NB_DEL  : NB_DEL = 0

 If clalev([WAMK])  : Close File      [WAMK]  : Endif 
 Local File =PDOSSIER+".AMSK"    [WAMK]  
 If clalev([WAMZ])  : Close File      [WAMZ]  : Endif 
 Local File =PDOSSIER+".AMSKZON" [WAMZ]

 If !G_TRANSAC : Trbegin [WAMK] : Endif

 For [WAMK] Where (MODULE=4 or MODULE=5) and (CODACT="" or CODACT="LEA" or CODACT="GRT")
   Filter [WAMZ] Where CODMSK=[F:WAMK]CODMSK and (left$(CODACT,1)="X" or left$(CODACT,1)="Y" or left$(CODACT,1)="Z")
   If rowcount([F:WAMZ])=0    
     # Pas de code activité spécifique
     # On met à jour l'en-tête
     [F:WAMK]NBRLIG = 0
     [F:WAMK]NBRCOL = 0
     Rewrite [WAMK] Curr 
     If fstat Then 
       Call ECR_TRACE("AMSK"-[F:WAMK]CODMSK-", LEVEL 01 - File ERROR ="-num$(fstat),1) From GESECRAN
       GERRDOS = 1
     Endif
   Endif
   Filter [WAMZ]
 Next

 If !G_TRANSAC : Commit : Endif

 Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED  AMSK" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  AMSK" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_DEL)-" DELETED  AMSK" , 0) From GESECRAN

 Close Local File [WAMK]
 Close Local File [WAMZ]
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_AMSK -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_DPRMOD (PDOSSIER)
#  
#  
# - Objet      : Mise à jour de la tables des Modes d'amortissement
#
# - Règles : 
#            - Pour tous les modes d'amortissement libres
#                Division /100 pour les champs taux MINDPRRAT, MAXDPRRAT, EXCDPRRAT     
#                Suppression des options paramétrées sauf pour le mode IT
#
#            - Suppression des modes standards non reconduits
#
#            - Mise à jour des taux de la table DPRMODRAT RAT/100
# 

Value Char PDOSSIER

Local Integer NB_CRE  : NB_CRE = 0
Local Integer NB_MAJ  : NB_MAJ = 0
Local Integer NB_DEL  : NB_DEL = 0

Local Integer L_STRDATTYP
Local Char    L_CRY(25)

  If clalev([DPX3]) : Close File [DPX3] : Endif
  If clalev([DOX3]) : Close File [DOX3] : Endif
  If clalev([DRX3]) : Close File [DRX3] : Endif
  If clalev([DPM])  : Close File [DPM]  : Endif
  If clalev([DMO])  : Close File [DMO]  : Endif
  If clalev([DMR])  : Close File [DMR]  : Endif

  Local File =adxmother(0)+".DPRMOD"    [DPX3]
  Local File =adxmother(0)+".DPRMODOPT" [DOX3]
  Local File =adxmother(0)+".DPRMODRAT" [DRX3]
  Local File =PDOSSIER+".DPRMOD"        [DPM]
  Local File =PDOSSIER+".DPRMODOPT"     [DMO]
  Local File =PDOSSIER+".DPRMODRAT"     [DMR]

  ###############
  # MODES LIBRES 
  ###############

  If !G_TRANSAC : Trbegin [DPM], [DMO], [DMR] : Endif

  # Mise à jour des champs STRDATTYP des modes libres
  For [DPM] Where DPRMODTYP=1
    [F:DPM]MINDPRRAT = [F:DPM]MINDPRRAT / 100 
    [F:DPM]MAXDPRRAT = [F:DPM]MAXDPRRAT / 100 
    [F:DPM]EXCDPRRAT = [F:DPM]EXCDPRRAT / 100 
    [F:DPM]STRDATTYP = [F:DPM]STRDPRDAT
    Rewrite [F:DPM] Curr
    If fstat Then 
      Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 01 - File ERROR ="-num$(fstat),1) From GESECRAN
      GERRDOS = 1
    Endif

    # Suppression des options du mode libre
    Delete [DMO] Where STDDPM=[F:DPM]DPM & CPY=[F:DPM]CPY
    If fstat Then 
      Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 02 - File ERROR ="-num$(fstat),1) From GESECRAN
      GERRDOS = 1
    Endif

    # Mise à jour du taux dans la table des taux
    For [DMR] Where DPM=[F:DPM]DPM & CPY=[F:DPM]CPY
      [F:DMR]RAT = [F:DMR]RAT / 100   
      Rewrite [DMR] 
      If fstat Then 
        Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 03 - File ERROR ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif
    Next
  Next

  ##################
  # MODES STANDARDS 
  ##################

  # Parcours des modes standards du dossier 140 et comparaison avec ceux du dossier racine
  For [DPM] Where DPRMODTYP=2 With Stability
    # Le mode existe-t'il toujours ? On regarde dans les modes standards par défaut du dossier racine
    Read [F:DPX3]DPM0=[F:DPM]DPM;""

    If fstat
      # Le mode n'existe plus en V5, il est supprimé
      Delete [DPM] Curr
      If fstat Then 
        Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 04 - File ERROR ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif

      NB_DEL += 1

      # Et suppression également de ses options et de ses taux
      Delete [DMO] Where STDDPM=[F:DPM]DPM & CPY=[F:DPM]CPY
      Delete [DMR] Where DPM=[F:DPM]DPM & CPY=[F:DPM]CPY
    Else
      # Le mode existe en V5, on n'en conserve que les paramètres "Limité au pays" (CRY) 
      # et "Date début d'amort" (STRDPRDAT en 140, STRDATTYP en V5)
      L_CRY            = [F:DPM]CRY
      L_STRDATTYP      = [F:DPM]STRDPRDAT

      [F:DPM]          = [F:DPX3]

      [F:DPM]CRY       = L_CRY
      [F:DPM]STRDATTYP = L_STRDATTYP

      Rewrite Curr

      NB_MAJ += 1

      # On supprime ses options sauf s'il s'agit du mode "IT"
      If [F:DPM]DPM<>"IT"
        Delete [DMO] Where STDDPM=[F:DPM]DPM & CPY=[F:DPM]CPY
      Endif

      # On divise ses taux dans la table des taux par 100
      For [DMR] Where DPM=[F:DPM]DPM & CPY=[F:DPM]CPY
        [F:DMR]RAT = [F:DMR]RAT / 100.   
        Rewrite [DMR] 
        If fstat Then 
          Call ECR_TRACE("DPRMODRAT, Level 25 - File Error ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next
    Endif
  Next

  # Ajout des modes standards qui n'existaient pas en 140
  For [DPX3] Where CPY="" and DPRMODTYP=2
    # Ce mode existe-t'il ? 
    Read [F:DPM]DPM0=[F:DPX3]DPM;""

    If fstat
      # Le mode n'existait pas en 140, on le copie du dossier racine
      [F:DPM] = [F:DPX3]

      Write [DPM] 
      If fstat Then 
        Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 26 - File ERROR ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif

      NB_CRE += 1

      # Et copie également de ses options et de ses taux
      For [DOX3] Where STDDPM=[F:DPX3]DPM & CPY=[F:DPX3]CPY
        [F:DMO] = [F:DOX3]

        Write [DMO] 
        If fstat Then 
          Call ECR_TRACE("DPRMODOPT"-[F:DMO]STDDPM-", LEVEL 27 - File ERROR ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next

      For [DRX3] Where DPM=[F:DPX3]DPM & CPY=[F:DPX3]CPY
        [F:DMR] = [F:DRX3]

        Write [DMR] 
        If fstat Then 
          Call ECR_TRACE("DPRMODRAT"-[F:DMR]DPM-", LEVEL 28 - File ERROR ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next
    Endif
  Next

  If !G_TRANSAC : Commit : Endif

  Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED  DPRMOD" , 0) From GESECRAN
  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  DPRMOD" , 0) From GESECRAN
  Call ECR_TRACE ("    "-num$(NB_DEL)-" DELETED  DPRMOD" , 0) From GESECRAN

  Close File [DPX3]
  Close File [DOX3]
  Close File [DRX3]
  Close File [DPM]
  Close File [DMO] 
  Close File [DMR]  
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_DPRMOD -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_RUBASSDEFP(PDOSSIER)
# - Objet  : Mise à jour de la tables des rubriques par plan
#
# - Règles : 
#            - Intialisation des nouveaux champs :
#                Rubrique/plan n°6 =  PRATYP  -> Type de prorata  
#                Rubrique/plan n°7 =  ACLCOE  -> Coefficient d'accélération 
# 


Value Char PDOSSIER
Onerrgo ERREUR From DOSMAJ

  If clalev([F:RDP]) : Close File [RDP] : Endif
  Local File =PDOSSIER+".RUBASSDEFP" [RDP]

  If !G_TRANSAC Then : Trbegin [RDP] : Endif

  For [RDP] 
      If [F:RDP]RUBRASP(6)= "" or  [F:RDP]RUBRASP(7)="" or [F:RDP]NBRUBP <> 8
         [F:RDP]RUBRASP(6) = "PRATYP"
         [F:RDP]RUBRASP(7) = "ACLCOE"
         [F:RDP]NBRUBP = 8
         Rewrite [RDP]
         If fstat Then 
          Call ECR_TRACE("RUBASSDEFP, Level 02 - File Error ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Endif
  Next 

  If !G_TRANSAC Then : Commit: Endif
  #************
  Close Local File [RDP]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_RUBASSDEFP -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_CONTEXT (PDOSSIER)
#  
# - Objet  : Mise à jour de la tables des Contextes
#
# - Règles : 
#            - Intialisation des nouveaux champs :
#                LNKPLN     Lien entre plans         -> 0
#                FLGCNXUO   Gestion des UO           -> 1 "non"
#            - Intialisation du champs ORIBASDPR selon redimensionnement
#                Report de la valeur ORIBASDPR(0) sur les plans gérés
#            - Positionnement du plan de subvention
# 

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

  If clalev([CNX])  : Close File   [CNX]  : Endif 
  Local File =PDOSSIER+".CONTEXT"  [CNX]  
  If clalev([WCNX]) : Close File   [WCNX] : Endif 
  Local File =PDOSSIER+".CONTEXT"  [WCNX]
  If clalev([WADI]) : Close File   [WADI] : Endif
  Local File =PDOSSIER+".ATABDIV"  [WADI] Where [F:WADI]NUMTAB = 539
  If clalev([FIS])  : Close File   [FIS]  : Endif
  Local File =PDOSSIER+".FISCYEAR" [FIS] 
  If clalev([CPY])  : Close File   [CPY]  : Endif 
  Local File =PDOSSIER+".COMPANY"  [CPY]
  If clalev([WDEP]) : Close File   [WDEP] : Endif 
  Local File =PDOSSIER+".DEPREC"   [WDEP]

Local Integer I_PLN
Local Char    WPAYS

Local Char    WCPY    
Local Integer I_SOC : I_SOC = 0    

  If (dim(G_PLNSUB)>0) : Raz G_PLNSUB : Endif
  If (dim(G_SOC)   >0) : Raz G_SOC    : Endif
  #************
  If !G_TRANSAC Then : Trbegin [CNX], [FIS] : Endif
  # Contexte subvention
  For [CNX]CNX0
    If (WCPY <> [F:CNX]CPY) Then
      WCPY = [F:CNX]CPY
      I_SOC += 1
      G_SOC   (I_SOC) = [F:CNX]CPY
      G_PLNSUB(I_SOC) = 0
    Endif
    If ( [F:CNX]GRTFLG(0) = G_OUI ) Then     
      # Repérage plan de subvention  pour DEPREC
      G_PLNSUB(I_SOC) = [F:CNX]PLNCAA(0)
      # Suppression des fiscyear du contexte subvention
      #Fq-47038 Delete [FIS] Where [F:FIS]CNX=[F:CNX]CNX 
      Delete [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX 
      If (fstat) Then 
         Call ECR_TRACE("FISCYEAR, Level 01 - File Error ="-num$(fstat),1) From GESECRAN
         GERRDOS = 1
      Endif
      # Suppression du contexte subvention
      #Fq-47038 Delete Curr
      Delete [CNX] Curr
      If (fstat) Then 
        Call ECR_TRACE("CONTEXT, Level 01 - File Error ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif
    Endif
  Next CNX0

  
  # Pour chaque Contexte
  Local Integer WCNXUO : WCNXUO = 0
  WCPY = ""
  # <1 <<<<<<<<<<<
  For [CNX]CNX0
      #----------------
      If ( [F:CNX]CPY <> WCPY ) Then
        # Rupture première société
        WCPY = [F:CNX]CPY
        # Pays de la société
        Read[CPY]CPY0=[F:CNX]CPY 
        If fstat=0
           WPAYS = [F:CPY]CRY 
        Endif
        # Recherche du contexte pilotant les UO pour la société
        WCNXUO = 0
        Filter [WDEP] Where CPY= [F:CNX]CPY and DPM= "UO"
        Read [WDEP]DEP0 First
        Filter [WDEP]          
        If  (fstat = 0) Then
          # Mode UO utilisé
          If (find([F:WDEP]DPRPLN, G301CPT, G301FIS, G301MIN, G301ORI, G301R76) <> 0 ) Then
            # Mode UO utlisé par le contexte Comptable & fiscal 
            WCNXUO = G300CPFI
          Else
            # Mode UO utilisé par un contexte autre que le fiscal & comptable 
            WCNXUO = [F:WDEP]DPRPLN - 4
            # Ce contexte est-il à remonter dans le contexte Fiscal & Comptable            
            Filter [F:WADI] Where  A1=[F:CNX]CPY and N1= WCNXUO
            Read [F:WADI]First
            If (fstat = 0) Then
              WCNXUO = G300CPFI
            Endif
          Endif
        Endif
      Endif
      #----------------
      If ( [F:CNX]CNX = WCNXUO ) Then
        [F:CNX]FLGCNXUO = G_OUI
      Else
        [F:CNX]FLGCNXUO = G_NON
      Endif 
      [F:CNX]NBPLC = 0
      If [F:CNX]CNX = G300CPFI  # on traite le contexte Comptable et Fiscal
         For I_PLN = 1 To 5
            If ( [F:CNX]PLNPRO  ( I_PLN-1 )  =  G_OUI ) 
               [F:CNX]ORIBASDPR ( I_PLN-1 )  = [F:CNX]ORIBASDPR (0)
               [F:CNX]FLGPROACC ( I_PLN-1 )  = [F:CNX]FLGPROACC (0)
               [F:CNX]LNKPLN    ( I_PLN-1 )    = 0
               # si plan traité est dans la liste suivante et pays = "FR"
               # ==> norme = Standard          
               If ( [F:CNX]PLNCAA ( I_PLN-1 )   = G301FIS or
&                   [F:CNX]PLNCAA ( I_PLN-1 )   = G301MIN or   
&                   [F:CNX]PLNCAA ( I_PLN-1 )   = G301ORI or 
&                   [F:CNX]PLNCAA ( I_PLN-1 )   = G301R76 or  
&                   [F:CNX]PLNCAA ( I_PLN-1 )   = G301RET )  and
&               WPAYS = "FR"
                [F:CNX]PLNSTD   ( I_PLN-1 ) = GVML_NPSTD
               Endif   
              [F:CNX]NBPLC  +=1
            Else 
               [F:CNX]PLNCAA    ( I_PLN-1 )  = 0
               [F:CNX]ORIBASDPR ( I_PLN-1 )  = 0
               [F:CNX]PLNSTD    ( I_PLN-1 )  = 0
               [F:CNX]FLGPROACC ( I_PLN-1 )  = 0
               [F:CNX]LNKPLN    ( I_PLN-1 )  = 0
               [F:CNX]FLUTRATXS ( I_PLN-1 )  = ""
               [F:CNX]FLUTRAACC ( I_PLN-1 )  = 0
            Endif 
         Next I_PLN
         If ( G_PLNSUB(find([F:CNX]CPY, G_SOC)) <> 0 ) Then
            # Positionnement du plan de subvention
            [F:CNX]PLNCAA    ( [F:CNX]NBPLC ) = G301SUB
            [F:CNX]ORIBASDPR ( [F:CNX]NBPLC ) = GVML_OBSUB
            [F:CNX]FLGPROACC ( [F:CNX]NBPLC ) = [F:CNX]FLGPROACC (0)  
            [F:CNX]FLUTRATXS ( [F:CNX]NBPLC ) = [F:CNX]FLUTRATXS (0) 
            [F:CNX]FLUTRAACC ( [F:CNX]NBPLC ) = [F:CNX]FLUTRAACC (0)    
            [F:CNX]PLNSTD    ( [F:CNX]NBPLC ) = GVML_NPSTD 
            [F:CNX]LNKPLN    ( [F:CNX]NBPLC ) = [F:CNX]LNKPLN    (0) 
            [F:CNX]NBPLC  +=1
         Endif
         Rewrite [CNX] Curr
         If (fstat) Then 
           Call ECR_TRACE("CONTEXT, Level 02 - File Error ="-num$(fstat),1) From GESECRAN
           GERRDOS = 1
         Endif
      Else # on traite les autres contextes 
         [F:CNX]NBPLC = 1
         Filter [F:WADI] Where  A1=[F:CNX]CPY 
         Read [F:WADI]First
         If fstat
            [F:CNX]NBPLC = 1
         Endif
         #>>>>>>>>>
         For [F:WADI] Where  [F:WADI]N1 <> G300CPFI 
            # Contexte à migrer existe
            Read [F:WCNX]CNX0=[F:CNX]CPY;[F:WADI]N1
            If fstat = 0
               Read [F:CNX]CNX0= [F:CNX]CPY;G300CPFI
               # Positionnement du plan à migrer dans le contexte CPFI
               [F:CNX]PLNCAA    ( [F:CNX]NBPLC ) = [F:WCNX]PLNCAA    (0)
               [F:CNX]ORIBASDPR ( [F:CNX]NBPLC ) = [F:WCNX]ORIBASDPR (0)
               [F:CNX]FLGPROACC ( [F:CNX]NBPLC ) = [F:WCNX]FLGPROACC (0)  
               [F:CNX]FLUTRATXS ( [F:CNX]NBPLC ) = [F:WCNX]FLUTRATXS (0) 
               [F:CNX]FLUTRAACC ( [F:CNX]NBPLC ) = [F:WCNX]FLUTRAACC (0)    
               [F:CNX]PLNSTD    ( [F:CNX]NBPLC ) = [F:WCNX]PLNSTD    (0) 
               [F:CNX]LNKPLN    ( [F:CNX]NBPLC ) = [F:WCNX]LNKPLN    (0) 
               [F:CNX]NBPLC  +=1
               Rewrite [CNX] Curr
               If (fstat) Then 
                 Call ECR_TRACE("CONTEXT, Level 02 - File Error ="-num$(fstat),1) From GESECRAN
                 GERRDOS = 1
               Endif
               # Suppression du contexte migré dans le CPFI
               #Fq-47038 Delete [WCNX] Where [F:WCNX]CNX=[F:WADI]N1 
               Delete [WCNX] Where CPY=[F:CNX]CPY and CNX=[F:WADI]N1 
               If (fstat) Then 
                  Call ECR_TRACE("CONTEXT, Level 01 - File Error ="-num$(fstat),1) From GESECRAN
                  GERRDOS = 1
               Endif
               # Suppression des FISCYEAR correspondant au contexte supprimé  
               #Fq-47038 Delete [FIS] Where [F:FIS]CNX=[F:WADI]N1
               Delete [FIS] Where  CPY=[F:CNX]CPY and CNX=[F:WADI]N1 
               If (fstat) Then 
                  Call ECR_TRACE("FISCYEAR, Level 01 - File Error ="-num$(fstat),1) From GESECRAN
                  GERRDOS = 1
               Endif
            Else
               [F:CNX]NBPLC = 1
            Endif
         Next
         Filter [F:WADI] 
         Rewrite [CNX] Curr
         If (fstat) Then 
           Call ECR_TRACE("CONTEXT, Level 02 - File Error ="-num$(fstat),1) From GESECRAN
           GERRDOS = 1
         Endif
      Endif
  Next CNX0
  # <1 <<<<<<<<<<< 
  If (fstat) Then 
    Call ECR_TRACE("CONTEXT, Level 03 - File Error ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1
  Endif

  If !G_TRANSAC Then : Commit : Endif

  #************
  Close Local File [CNX]
  Close Local File [FIS]
  Close Local File [WCNX]
  Close Local File [WADI]
  Close Local File [WDEP]
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_CONTEXT -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_FISCYEAR (PDOSSIER)
#  
# - Objet  : Mise à jour de la tables des Exercices
#
# - Règles : 
#            - Intialisation du champ STAPER
#                Les périodes < période courante -> "Close"
#                La période courante             -> "Courante"     
#                les autres périodes             -> "Non ouverte"
#            - Si pas de période pour l'exercice
#                une période égale à l'exercice est créée
#            - Intialisation du champ TYPPST
#                Les périodes < période courante -> 0
#                Les périodes non-ouvertes       -> 0
#                La période courante  (en fonction du paramètre TYPPSTPRO du chapitre "AAS"/Groupe "MIG")    
#                les périodes ouvertes           -> "Provisoire"
#            - Initialisation des nouveaux champs
#                DFDTYP Type de différé          -> Aucun
#                DFDCOD Règle de différé         -> Aucune
#                DFDRAT Pourcentage de différé   -> 0
# 


Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

 Local Char LPARPST
Call  PARAM("","TYPPSTCURR",LPARPST)  From ADOVAL 

Local Integer NB_MAJ  : NB_MAJ = 0
Local Integer NB_MAX  : NB_MAX = 500

  If clalev([F:FIS]) : Close File  [FIS] : Endif 
  Local File =PDOSSIER+".FISCYEAR" [FIS]
  If clalev([F:CNX]) : Close File  [CNX] : Endif
  Local File =PDOSSIER+".CONTEXT"  [CNX]

  If !G_TRANSAC Then : Trbegin [FIS] : Endif
  # Pour chaque Contexte
  # <1 <<<<<<<<<<<
  For [CNX]CNX0
      # Pour chaque exercice du contexte
      # <2 <<<<<<<<<<<<<<<<<
      For [FIS]FIY0 Where [F:FIS]CPY=[F:CNX]CPY and [F:FIS]CNX=[F:CNX]CNX
      #************
        #
        # Si le périodique n'est pas géré, une période d'un exercice est auto générée
        If ( [F:FIS]DATSTRPER(0) = [0/0/0] and [F:FIS]DATENDPER(0) = [0/0/0] )  or
&          ( [F:FIS]FLGPER <>  G_OUI )          #*FQ-46989
              [F:FIS]DATSTRPER(0) = [F:FIS]DATSTRFIY
              [F:FIS]DATENDPER(0) = [F:FIS]DATENDFIY
              Local Decimal NB_YEAR
              Local Integer NB_DAY, NB_MONTH, NB_WEEK     
              Call CALCUL_NB_D_M_W_Y ([F:FIS]DATSTRPER(0), [F:FIS]DATENDPER(0),
&             NB_DAY, NB_MONTH , NB_WEEK, NB_YEAR) From GLOBIENS
              [F:FIS]NBRDAYPER(0) = NB_DAY
              [F:FIS]NBRMONPER(0) = NB_MONTH
              [F:FIS]NBRWEKPER(0) = NB_WEEK
              [F:FIS]CLOPER(0)    = G_NON  
              [F:FIS]NBRPER       = 1      
              [F:FIS]INDCURPER    = 1      
        Endif
        # 3 ---------------------------

        # <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
        For IPER = 1 To [F:FIS]NBRPER      
          # ================
          # Upgrade PERIODE
          # ================
          #-- Statut de la période - STAPER -
          #   "Courante" si Pér. cour. Ex. cour. "Close" Périodes antér. "Non ouverte" Périodes ultér.
          Case [F:FIS]STAFIY
            When GVML_TEPREC
              [F:FIS]STAPER(IPER-1) = GVML_SPCLOSE 
              [F:FIS]TYPPST(IPER-1) = 0            
            When GVML_TECOURA
              If ( IPER < INDCURPER  ) Then 
                [F:FIS]STAPER(IPER-1) = GVML_SPCLOSE
                [F:FIS]TYPPST(IPER-1) = 0   
              Else
                If ( IPER = INDCURPER ) Then
                  [F:FIS]STAPER(IPER-1) = GVML_SPCOURA
                  If val(LPARPST)=1
                     [F:FIS]TYPPST(IPER-1) = GVML_TPSTPRO                  
                  Else
                     [F:FIS]TYPPST(IPER-1) = GVML_TPSTDEF
                  Endif 
                Else
                  [F:FIS]STAPER(IPER-1) = GVML_SPFERME
                  [F:FIS]TYPPST(IPER-1) = 0  
                Endif
              Endif              
            When Default
              [F:FIS]STAPER(IPER-1) = GVML_SPFERME
              [F:FIS]TYPPST(IPER-1) = 0  
          Endcase 
        Next IPER
        # >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

        # <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
        For IPER = [F:FIS]NBRPER+1 To 24      
          # Remise en cohérence des périodes non définies
              [F:FIS]DATSTRPER(IPER-1) = [0/0/0]
              [F:FIS]DATENDPER(IPER-1) = [0/0/0]
              [F:FIS]NBRDAYPER(IPER-1) = 0
              [F:FIS]NBRMONPER(IPER-1) = 0
              [F:FIS]NBRWEKPER(IPER-1) = 0
              [F:FIS]CLOPER(IPER-1)    = G_NON          
        Next IPER
        # >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>      

        # ************************
        # Upgrade EXERCICE
        # ************************
        [F:FIS]DFDTYP = GVML_DFAUCUN                       # Type de différé
        [F:FIS]DFDCOD = GVML_RGAUCUN                       # Règle de différé
        [F:FIS]DFDRAT = 0                                  # Pourcentage de différé
        # ************************

        Rewrite [FIS]Curr
        If (fstat) Then 
          Call ECR_TRACE("FISCYEAR, Level 03 - File Error ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Else
          NB_MAJ += 1
          If ( NB_MAJ = NB_MAX ) Then : Commit : NB_MAJ = 0 : Endif 
        Endif
      #************
      Next
      # <2 <<<<<<<<<<<<<<<<<
      If (fstat) Then 
        Call ECR_TRACE("FISCYEAR, Level 02 - File Error ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif

    #************
  Next CNX0
  # <1 <<<<<<<<<<< 
  If !G_TRANSAC Then : Commit : Endif

  If (fstat) Then 
    Call ECR_TRACE("FISCYEAR, Level 01 - File Error ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1
  Endif

  Close Local File [FIS]
  Close Local File [CNX]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_FISCYEAR -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_GACCCODLIG (PDOSSIER)
#  
# - Objet  : Mise à jour de la tables des lignes des codes comptables
#
# - Règles : 
#            - Lignes 11 et 23 des codes comptables immo reçoivent les textes 44 et 45 (ML 853)
# 

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

 Local Integer NB_MAJ

 If clalev([CCL5])  : Close File      [CCL5]  : Endif 
 Local File =PDOSSIER+".GACCCODLIG"   [CCL5]  
  
 Gosub SET_FIRST From TRTFIRST

 If !G_TRANSAC : Trbegin [F:CCL5] : Endif

 #> Mise à jour des intitulé des lignes 11 et 23 des codes comptables de type immo
  
 Update [CCL5] Where TYP=5 & NUMLIG=11 With TXT=44
 If fstat
  Call ECR_TRACE("GACCCODLIG, Step 01 - File Error ="-num$(fstat),1) From GESECRAN
  GERRDOS = 1           
 Else
  NB_MAJ+=adxuprec 
 Endif  
 Update [CCL5] Where TYP=5 & NUMLIG=23 With TXT=45
 If fstat
  Call ECR_TRACE("GACCCODLIG, Step 02 - File Error ="-num$(fstat),1) From GESECRAN
  GERRDOS = 1      
 Else
  NB_MAJ+=adxuprec        
 Endif  

 #> Fin de la transaction

 If !G_TRANSAC
  If GERRDOS
   Rollback
  Else
   Commit
  Endif
 Endif
 Gosub UNSET_FIRST From TRTFIRST
 Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  ACCOUNT CODE LINES" , 0) From GESECRAN
 Close Local File [CCL5] 
 
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_GACCCODLIG -*
#*************************************
#*************************************


#########################################################
Subprog  AMAJ_GAUTACE (PDOSSIER)
#  
# - Objet  : Mise à jour de la tables des pièces automatiques
#
# - Règles : 
#            - Renommage des pièces auto standards 140
#            - Copie des nouvelles pièces V5 à partir
#              du dossier racine
# 

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

 Local Char LPARAM
 Call  PARAM("","KEEPPARACE",LPARAM) From ADOVAL
 If val(LPARAM)=3
  Call ECR_TRACE( "Error  : You have to set the value of the KEEPPARACE parameter (AAS Chapter / MIG group) before the migration process.", 1) From GESECRAN      
  GOK=0
  End
 Endif

 # Liste des pièces auto standards 140

 Local Integer NB_MAJ
 Local Integer NB_CRE
 Local Integer NB_DEL

 Local Char LISTE_GAU(5)(1..45)
 LISTE_GAU(01)="0SAMT" : LISTE_GAU(02)="CCAMT" : LISTE_GAU(03)="0SBVA" : LISTE_GAU(04)="CCBVA" : LISTE_GAU(05)="0SDCP"
 LISTE_GAU(06)="CCDCP" : LISTE_GAU(07)="0SDPR" : LISTE_GAU(08)="CCDPR" : LISTE_GAU(09)="0SDVA" : LISTE_GAU(10)="CCDVA"
 LISTE_GAU(11)="0SREV" : LISTE_GAU(12)="CCREV" : LISTE_GAU(13)="0SSOR" : LISTE_GAU(14)="CCSOR" : LISTE_GAU(15)="0SVIR"
 LISTE_GAU(16)="CCVIR" : LISTE_GAU(15)="0LACT" : LISTE_GAU(16)="LCACT" : LISTE_GAU(17)="0LCRT" : LISTE_GAU(18)="LCCRT"
 LISTE_GAU(19)="0LPAY" : LISTE_GAU(20)="LCPAY" : LISTE_GAU(21)="0LRPU" : LISTE_GAU(22)="LCRPU" : LISTE_GAU(23)="0LTRM"
 LISTE_GAU(24)="LCTRM" : LISTE_GAU(25)="0LPAY" : LISTE_GAU(26)="LCPAY" : LISTE_GAU(27)="0GFAS" : LISTE_GAU(28)="0GLOF"
 LISTE_GAU(29)="0GFAS" : LISTE_GAU(30)="CSAMT" : LISTE_GAU(31)="CSBVA" : LISTE_GAU(32)="CSDCP" : LISTE_GAU(33)="CSDPR"
 LISTE_GAU(34)="CSDVA" : LISTE_GAU(35)="CSRPU" : LISTE_GAU(36)="CSSOR" : LISTE_GAU(37)="CSVIR" : LISTE_GAU(38)="GSCRT"
 LISTE_GAU(39)="GCCRT" : LISTE_GAU(40)="GSCSH" : LISTE_GAU(41)="GCCSH" : LISTE_GAU(42)="GSREP" : LISTE_GAU(43)="GCREP"
 LISTE_GAU(44)="LSPAY" : LISTE_GAU(45)="LCPAY"

 If clalev([GU5])   : Close File      [GU5]  : Endif 
 Local File =PDOSSIER+".GAUTACE"      [GU5]  
 If clalev([GD5])   : Close File      [GD5]  : Endif 
 Local File =PDOSSIER+".GAUTACED"     [GD5]
 If clalev([GF5])   : Close File      [GF5]  : Endif 
 Local File =PDOSSIER+".GAUTACEF"     [GF5]
 If clalev([GAUR])  : Close File      [GAUR] : Endif
 Local File =adxmother(0)+".GAUTACE"  [GAUR]
 If clalev([GADR])  : Close File      [GADR] : Endif 
 Local File =adxmother(0)+".GAUTACED" [GADR]
 If clalev([GAFR])  : Close File      [GAFR] : Endif 
 Local File =adxmother(0)+".GAUTACEF" [GAFR]
  
 Gosub SET_FIRST From TRTFIRST

 If !G_TRANSAC : Trbegin [F:GU5], [F:GD5], [F:GF5] : Endif

 #> Suppression (1) ou Conservation (2) des pièces automatiques 140

 If val(LPARAM)=1
  Delete [F:GU5] Where (1=1)
  If fstat
   Call ECR_TRACE("GAUTACE,  Step 01 Delete - File Error ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1     
  Else
   NB_DEL+=adxdlrec
  Endif
  Delete [F:GD5] Where (1=1)
  If fstat
   Call ECR_TRACE("GAUTACED, Step 01 Delete - File Error ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1     
  Else
   NB_DEL+=adxdlrec      
  Endif
  Delete [F:GF5] Where (1=1)
  If fstat
   Call ECR_TRACE("GAUTACEF, Step 01 Delete - File Error ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1     
  Else
   NB_DEL+=adxdlrec      
  Endif
 Elsif val(LPARAM)=2
  For [F:GU5] 
   If find([F:GU5]COD,LISTE_GAU)
    For [F:GD5] Where COD=[F:GU5]COD   
     [F:GD5]COD=left$([F:GD5]COD,4)+"4"
     Rewrite [F:GD5]
     If fstat
      Call ECR_TRACE("GAUTACED, Step 01 Rewrite - File Error ="-num$(fstat),1) From GESECRAN
      GERRDOS = 1     
     Endif
    Next
    For [F:GF5] Where COD=[F:GU5]COD   
     [F:GF5]COD=left$([F:GF5]COD,4)+"4"
     Rewrite [F:GF5]
     If fstat
      Call ECR_TRACE("GAUTACEF, Step 01 Rewrite - File Error ="-num$(fstat),1) From GESECRAN
      GERRDOS = 1     
     Endif
    Next
    [F:GU5]COD=left$([F:GU5]COD,4)+"4"
    Rewrite [F:GU5]
    If fstat
     Call ECR_TRACE("GAUTACE, Step 01 Rewrite - File Error ="-num$(fstat),1) From GESECRAN
     GERRDOS = 1   
    Else
     NB_MAJ+=1  
    Endif   
   Endif
  Next
 Endif

 #> Copie des pièces automatiques V5 à partir du dossier racine

 For [F:GAUR]
  If find([F:GAUR]COD,LISTE_GAU)
   For [F:GADR] Where COD=[F:GAUR]COD
    [F:GD5]=[F:GADR]
    Write [F:GD5]
    If fstat
     Call ECR_TRACE("GAUTACED, Step 02 - File Error ="-num$(fstat),1) From GESECRAN
     GERRDOS = 1          
    Endif
   Next
   For [F:GAFR] Where COD=[F:GAUR]COD
    [F:GF5]=[F:GAFR]
    Write [F:GF5]
    If fstat
     Call ECR_TRACE("GAUTACEF, Step 02 - File Error ="-num$(fstat),1) From GESECRAN
     GERRDOS = 1          
    Endif
   Next
   [F:GU5]=[F:GAUR]
   Write [F:GU5]
   If fstat
    Call ECR_TRACE("GAUTACE, Step 02 - File Error ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1   
   Else
    NB_CRE+=1       
   Endif   
  Endif
 Next

 If !G_TRANSAC
  If GERRDOS
   Rollback
  Else
   Commit
  Endif
 Endif
 Gosub UNSET_FIRST From TRTFIRST
 Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  AUTOMATIC JOURNALS" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED  AUTOMATIC JOURNALS" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_DEL)-" DELETED  AUTOMATIC JOURNALS" , 0) From GESECRAN
 Close Local File [GU5] 
 Close Local File [GD5] 
 Close Local File [GF5] 
 Close Local File [GAUR] 
 Close Local File [GADR] 
 Close Local File [GAFR] 
 
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_GAUTACE -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_TYPACE (PDOSSIER)
#  
# - Objet  : Mise à jour de la table TYPACE 
#
# - Règles : 
#             
# 

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

 Local Char LPARAM
 Call  PARAM("","KEEPPARACE",LPARAM) From ADOVAL
 If val(LPARAM)=3
  Call ECR_TRACE( "Error  : You have to set the value of the KEEPPARACE parameter (AAS Chapter / MIG group) before the migration process.", 1) From GESECRAN      
  GOK=0
  End
 Endif

 Local Integer NB_MAJ
 Local Integer NB_CRE
 Local Integer NB_DEL

 If clalev([TP5])   : Close File      [TP5]  : Endif 
 Local File =PDOSSIER+".TYPACE"       [TP5]  
 If clalev([TPER])  : Close File      [TPER] : Endif
 Local File =adxmother(0)+".TYPACE"   [TPER]
 If clalev([WADI])  : Close File      [WADI] : Endif 
 Local File =PDOSSIER+".ATABDIV"      [WADI]  
 If clalev([GAU])  : Close File       [GAU] : Endif 
 Local File =PDOSSIER+".GAUTACE"      [GAU]  
 If clalev([GAD])  : Close File       [GAD] : Endif 
 Local File =PDOSSIER+".GAUTACED"     [GAD]  
 
 Gosub SET_FIRST From TRTFIRST

 If !adxlog : Trbegin [F:TP5], [F:TPER] : Local Integer L_TRS : Endif

 #> Suppression (1) ou Conservation (2) des types d'écriture 140 

 If val(LPARAM)=1 & PDOSSIER<>adxmother(0)
  Delete [F:TP5] Where (1=1)
  If fstat
   Call ECR_TRACE("TYPACE,  Step 01 Delete - File Error ="-num$(fstat),1) From GESECRAN
   GERRDOS = 1     
  Else
   NB_DEL+=adxdlrec
  Endif  
 Elsif val(LPARAM)=2
  For [F:TP5] With Stability #Where (1=1) 
   [F:TP5]ACETYP = "V14"+[F:TP5]CPY+num$([F:TP5]PLN1)+[F:TP5]ACETYP
   [F:TP5]ENAFLG = G_NON
   If [F:TP5]EVTTYP="FASDOT"
    [F:TP5]SRCTYP    = 2
    [F:TP5]EVTTYP    = ""
    [F:TP5]TABCPT    = "DEPREC"
    [F:TP5]TABOBJ    = "FXDASSETS"
    [F:TP5]EVTPLN    = G_OUI
    [F:TP5]PERCLOFLG = G_OUI
    [F:TP5]PERCOUFLG = G_OUI
    [F:TP5]PEROPEFLG = G_OUI
   Else
    [F:TP5]SRCTYP = 1
    [F:TP5]EVTTYP = [F:TP5]EVETYP
    Read [WADI]CODE=GTD_EVENT;[F:TP5]EVETYP # Table diverse 962
    If fstat
    Else
     [F:TP5]EVTPLN = [F:WADI]N1
     [F:TP5]TABCPT =[F:WADI]A2
     Case [F:WADI]N2
      When GVML_OMDEPEN
       [F:TP5]TABOBJ="LAYOUTFAS"
       If [F:TP5]AGRLVL<>5
        [F:TP5]NBCRIT=1 : [F:TP5]SORTFLDTAB(0)=[F:TP5]TABOBJ : [F:TP5]SORTFLD(0)   ="CODLOF" : [F:TP5]NBCRIT=1
       Endif
      When GVML_OMBIEN
       [F:TP5]TABOBJ="FXDASSETS"
       If [F:TP5]AGRLVL<>5
        [F:TP5]NBCRIT=1 : [F:TP5]SORTFLDTAB(0)=[F:TP5]TABOBJ : [F:TP5]SORTFLD(0)   ="AASREF" : [F:TP5]NBCRIT=1
       Endif
      When GVML_OMLOCFI
       [F:TP5]TABOBJ="LEASE"
       If [F:TP5]AGRLVL<>5
        [F:TP5]NBCRIT=1 : [F:TP5]SORTFLDTAB(0)=[F:TP5]TABOBJ : [F:TP5]SORTFLD(0)   ="LEAREF" : [F:TP5]NBCRIT=1
       Endif
      When GVML_OMSUBV
       [F:TP5]TABOBJ="GRANTS"
       If [F:TP5]AGRLVL<>5
        [F:TP5]NBCRIT=1 : [F:TP5]SORTFLDTAB(0)=[F:TP5]TABOBJ : [F:TP5]SORTFLD(0)   ="GRAREF" : [F:TP5]NBCRIT=1
       Endif
     Endcase     
     [F:TP5]PERCLOFLG = G_NON
     [F:TP5]PERCOUFLG = G_OUI
     [F:TP5]PEROPEFLG = G_NON
    Endif
   Endif 

   [F:TP5]DPRPLN    = [F:TP5]PLN1
   Read [F:GAU]GAU0=[F:TP5]GAUACE
   If fstat
    [F:TP5]GAU       = ""
   Elsif !fstat
    [F:TP5]GAU       = [F:TP5]GAUACE
    If [F:GAU]CODIAS<>""
     Filter [GAD] Where COD=[F:GAU]COD
     If rowcount([F:GAD])
      Read [F:GAU]GAU0=[F:GAU]CODIAS
      If fstat
       # Référentiel indéterminé
       [F:TP5]CPTREF=1
      Else
       Filter [GAD] Where COD=[F:GAU]COD
       If !rowcount([F:GAD])
        # Référentiel PCG
        [F:TP5]CPTREF=2
       Else
        # Référentiel indéterminé
        [F:TP5]CPTREF=1
       Endif
       Filter [GAD]
      Endif
     Else
      Read [F:GAU]GAU0=[F:GAU]CODIAS
      If fstat
       # Référentiel indéterminé
       [F:TP5]CPTREF=1
      Else
       Filter [GAD] Where COD=[F:GAU]COD
       If rowcount([F:GAD])
        # Référentiel IAS
        [F:TP5]CPTREF=3
       Endif
       Filter [GAD]
      Endif       
     Endif
     Filter [GAD]
    Endif
   Endif
   [F:TP5]SORTCCE   = G_NON
   [F:TP5]DIRCPTFLG = G_NON
   [F:TP5]DIRCPTTRA = G_NON
   Rewrite [F:TP5]
   If fstat
    Call ECR_TRACE("TYPACE, Step 02 Rewrite - File Error ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1   
   Else
    NB_MAJ += 1      
   Endif    
  Next
 Endif

 If !GERRDOS
  For [F:TPER] Where CPY=""
   [F:TP5]=[F:TPER]
   Write [F:TP5]
   If fstat
    Call ECR_TRACE("TYPACE, Step 03 - File Error ="-num$(fstat),1) From GESECRAN
    GERRDOS = 1   
   Else
    NB_CRE+=1       
   Endif
  Next
 Endif

 If dim(L_TRS)
  If GERRDOS
   Rollback
  Else
   Commit
  Endif
 Endif
 Gosub UNSET_FIRST From TRTFIRST
 Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED ACCOUNTING ENTRY TYP" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_CRE)-" CREATED ACCOUNTING ENTRY TYP" , 0) From GESECRAN
 Call ECR_TRACE ("    "-num$(NB_DEL)-" DELETED ACCOUNTING ENTRY TYP" , 0) From GESECRAN
 Close Local File [TP5] 
 Close Local File [TPER] 

$FIN_AMAJ_TYPACE

End

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_TYPACE -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_LEASE(PDOSSIER)
# - Objet  : Mise à jour de la tables des contrats de location financement
# -          Mise à jour de la tables des échéanciers des contrats de loc fin
#
# - Règles : 
#            - Intialisation des nouveaux champs : aucun ???

Value Char PDOSSIER
Onerrgo ERREUR From DOSMAJ

  If clalev([CPY]) : Close File [CPY] : Endif 
  Local File =PDOSSIER+".COMPANY"      [CPY]
  If clalev([LEA]) : Close File [LEA] : Endif 
  Local File =PDOSSIER+".LEASE"        [LEA]
  If clalev([LBB]) : Close File [LBB] : Endif 
  Local File =PDOSSIER+".LEABILBOOK"   [LBB]
 
 
  Local Integer NB_MAJ

  # Le traitement se fait par société
  For [CPY]   
    # Boucle sur les contrats 
    If !G_TRANSAC Then : Trbegin [LEA] , [LBB] : Endif
    For [LEA] Where CPY=[F:CPY]CPY
      # Boucle sur les échéances
      For [LBB] Where LEAREF=[F:LEA]LEAREF
        Rewrite [LBB] Curr
        If fstat
          Call ECR_TRACE ("ERROR WHILE UPDATING LEABILBOOK"-num$(fstat) , 1) From GESECRAN
        Else
          NB_MAJ += 1
        Endif
      Next
      Rewrite [LEA] Curr
    Next
    If !G_TRANSAC : Commit : Endif
  Next

  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  LEASE" , 0) From GESECRAN

  Close File [CPY]
  Close File [LEA]
  Close File [LBB]
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_LEASE -*
#*************************************
#*************************************

#########################################################
Subprog AMAJ_GRANTS(PDOSSIER)
# - Objet  : Mise à jour de la tables des subventions
# -          Mise à jour de la tables des encaissements liés aux subventions
#
# - Règles : 
#            - Intialisation des nouveaux champs : aucun ???

Value Char PDOSSIER
Onerrgo ERREUR From DOSMAJ

  If clalev([CPY]) : Close File   [CPY] : Endif 
  Local File =PDOSSIER+".COMPANY" [CPY]
  If clalev([GRT]) : Close File   [GRT] : Endif 
  Local File =PDOSSIER+".GRANTS"  [GRT]
  If clalev([CAS]) : CLOSE File   [CAS] : Endif 
  Local File =PDOSSIER+".CASHING" [CAS]

  Local Integer  NB_MAJ

  If !G_TRANSAC Then : Trbegin [GRT], [CAS]  : Endif

  # Le traitement se fait par société
  For [CPY]  
    # Boucle sur les subventions 
    For [GRT] Where CPY=[F:CPY]CPY
      # Boucle sur les encaissements 
      For [CAS] Where GRAREF=[F:GRT]GRAREF
        Rewrite [CAS] Curr
        If fstat
          Call ECR_TRACE ("ERROR WHILE UPDATING CASHING"-num$(fstat) , 1) From GESECRAN
        Else
          NB_MAJ += 1
        Endif
      Next
      Rewrite [GRT] Curr
    Next
  Next

  If !G_TRANSAC : Commit : Endif
  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  GRANTS" , 0) From GESECRAN

  Close File [CPY]
  Close File [GRT]
  Close File [CAS]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_GRANTS -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_FXDASSETS (PDOSSIER)
#  
# - OBJET  : MISE à JOUR DE LA TABLE FXDASSETS
#
#

Value Char PDOSSIER
Onerrgo ERREUR From DOSMAJ

  If clalev([F:WFMI]) : Close File  [WFMI] : Endif 
  Local File =PDOSSIER+".FXDASSMIG" [WFMI]
  If clalev([F:WCNX]) : Close File  [WCNX] : Endif 
  Local File =PDOSSIER+".CONTEXT"   [WCNX]
  If clalev([F:WFIS]) : Close File  [WFIS] : Endif 
  Local File =PDOSSIER+".FISCYEAR"  [WFIS]
  If clalev([F:WFAS]) : Close File  [WFAS] : Endif 
  Local File =PDOSSIER+".FXDASSETS" [WFAS]
  If clalev([F:WDEP]) : Close File  [WDEP] : Endif 
  Local File =PDOSSIER+".DEPREC"    [WDEP]

  Local Char     CLE1
  Local Integer  TRUE   : TRUE  = 1
  Local Integer  FALSE  : FALSE = 0 
  Local Integer  NB_REWRITE
  Local Integer  NB_MAJ
  Local Integer  B_REWRITE
  Local Char     CRITERE(250)

  Local Char    FIRCPY   : FIRCPY = ""


  Gosub SET_FIRST From TRTFIRST
  B_CONTINUE = FALSE
  Raz NB_MAJ 
 
 
  # Suppression des images avant migration
  Delete [WFMI] Where evalue("1=1")
  If (fstat) Then : GERRDOS = 1 :   Endif
 
  #>1 >>>>>>>>>>>>>>>>>>>>
  Repeat

    Raz NB_REWRITE 
    Trbegin [WFAS]
    If (B_CONTINUE) Then
      CRITERE = "AASREF > CLE1"
      B_CONTINUE = FALSE
    Else
      CRITERE = "1=1" : # 1ère fois
    Endif
    #>2 >>>>>>>>>>>>>>>>>>>>
    For [WFAS]FAS0 Where evalue(CRITERE) With Stability

      # Sauvegarde avant migration
      [F:WFMI] = [F:WFAS] 
      Write[WFMI]
      If (fstat) Then : GERRDOS = 1 :   Endif

      #--
      If ( [F:WFAS]CPY <> FIRCPY ) Then     
        # Rupture première société
        Gosub FAS_1ERE_SOCIETE
        FIRCPY = [F:WFAS]CPY    : # rupture première société
      Endif
      #--

      Gosub UPGRADE_FXDASSETS

      #-3 -----------------
      If (B_REWRITE) Then

        Rewrite [WFAS]
        If (fstat) Then : GERRDOS = 1 :   Endif
        NB_REWRITE += 1
        NB_MAJ     += 1
        If ( NB_REWRITE > GMAXUPDTRS ) Then
          CLE1 = [F:WFAS]AASREF
          B_CONTINUE = TRUE
          Break   
        Endif  
      Endif
      #-3 -----------------
    Next
    #<2 <<<<<<<<<<<<<<<<<<<< 
  Commit
  Until not B_CONTINUE
  #<1 <<<<<<<<<<<<<<<<<<<<

  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  FXDASSETS" , 0) From GESECRAN

  Gosub UNSET_FIRST From TRTFIRST

  Close Local File [WFAS]
  Close Local File [WDEP]
  Close Local File [WFMI]
  Close Local File [WFIS]
  Close Local File [WCNX]
    
End

#==========================
$FAS_1ERE_SOCIETE

Local Char    LPARAM
Local Integer B_DOTCOMASO
Local Integer B_PADDOTASO
Local Integer B_PADDOTJSO
 
  # Indicateur "Sortie fin d'exe courant"
  Call PARAM([F:WFAS]CPY,"DOTCOMASO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then : B_DOTCOMASO  = 0 : Else : B_DOTCOMASO  = val(LPARAM)-1 : Endif
  # Indicateur "Sortie fin d'exe précédent"
  Call PARAM([F:WFAS]CPY,"PADDOTASO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then : B_PADDOTASO  = 0 : Else : B_PADDOTASO  = val(LPARAM)-1 : Endif
  # Indicateur "Pas de dotation le jour de sortie"
  Call PARAM([F:WFAS]CPY,"PADDOTJSO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then : B_PADDOTJSO  = 0 : Else : B_PADDOTJSO  = val(LPARAM)-1 : Endif

  Local Integer B_PLN_EXIST(1..15) : Raz B_PLN_EXIST
  Local Integer L_CNT_DUPLN(1..15) : Raz L_CNT_DUPLN
  Local Integer B_CNT_EXIST(1..11) : Raz B_CNT_EXIST
  Local Date    L_CNT_DBEXE(1..11) : Raz L_CNT_DBEXE
  Local Date    L_CNT_FNEXE(1..11) : Raz L_CNT_FNEXE
  Local Date    L_CNT_DBPER(1..11) : Raz L_CNT_DBPER
  Local Date    L_CNT_FNPER(1..11) : Raz L_CNT_FNPER
  # Contextes
  For [WCNX]CNX0 Where [F:WCNX]CPY=[F:WFAS]CPY
    Local Integer I_PLN 
    # Plans du contexte
    For I_PLN = 1 To [F:WCNX]NBPLC
      If ( [F:WCNX]PLNCAA(I_PLN-1) <> 0 ) Then   
        B_PLN_EXIST ([F:WCNX]PLNCAA(I_PLN-1)) = 1
        L_CNT_DUPLN ([F:WCNX]PLNCAA(I_PLN-1)) = [F:WCNX]CNX
      Else
        Break
      Endif
    Next I_PLN

    # Exercice courant / Période courante
    Filter [WFIS] Where CPY=[F:WFAS]CPY and CNX=[F:WCNX]CNX and STAFIY=2  
    Read [WFIS] First
    Filter [WFIS]
    B_CNT_EXIST([F:WCNX]CNX) = 1
    L_CNT_DBEXE([F:WCNX]CNX) = [F:WFIS]DATSTRFIY
    L_CNT_FNEXE([F:WCNX]CNX) = [F:WFIS]DATENDFIY
    L_CNT_DBPER([F:WCNX]CNX) = [F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
    L_CNT_FNPER([F:WCNX]CNX) = [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)
  Next CNX0

Return


#==========================
$UPGRADE_FXDASSETS

  # Passer tout ce qui est WFAS en FAS
  Local Integer   L_ISSTYP


  # Mise à jour selon B_WRITE
  B_REWRITE = TRUE
  # Date de classement du bien comme détenu pour vente
  [F:WFAS]SALCLSDAT = [0/0/0]
  # Coeff de réévaluation 76 
  [F:WFAS]R76COE = 1.
  # Plan de production  
  [F:WFAS]PROPLN = ""
  # Unité
  If ( [F:WFAS]AASUOM = "UN" ) Then
    [F:WFAS]AASUOM = "Un" 
  Endif 
  # Statut du bien
  If ( [F:WFAS]CMPSTA = 5 ) Then
    # Composant complémentaire devient composant
    [F:WFAS]CMPSTA = 3
  Elsif ( [F:WFAS]CMPSTA = 6 ) Then
    # Composant complémentaire en attente de rattachement devient composant en attente de rattachement
    [F:WFAS]CMPSTA = 4
  Endif
  # Flag à recalculer
  Local Integer B_ACALCULER
  If ( [F:WFAS]ISSDAT = [0/0/0] or [F:WFAS]ISSDAT >= L_CNT_DBEXE(1) ) Then
    B_ACALCULER = 1
  Else
    B_ACALCULER = 0
  Endif
  If (B_ACALCULER) Then : [F:WFAS]FLGCLC = 2 : Else : [F:WFAS]FLGCLC = 1 : Endif
  Local Integer I_CNX
  For I_CNX = 1 To 11
    If (B_CNT_EXIST) Then
      If (B_ACALCULER) Then 
        [F:WFAS]FLGCNXCLC(I_CNX-1) = 2
      Else
        [F:WFAS]FLGCNXCLC(I_CNX-1) = 1
      Endif
    Else
      [F:WFAS]FLGCNXCLC(I_CNX-1) = 0
    Endif
  Next I_CNX


  Local Integer B_DPMUO : B_DPMUO = 0
  Local Integer I_PLN
  Local Integer L_PLN
  For I_PLN = 1 To 15   
    If (B_PLN_EXIST(I_PLN)) Then
      If (B_DPMUO = 0) Then
        # Lecture WDEP si mode "UO"     
        Filter [WDEP] Where AASREF= [F:WFAS]AASREF and DPM = "UO"
        Read [WDEP]DEP0 First
        If  not(fstat) Then
          B_DPMUO = 1
        Endif
        Filter [WDEP]
      Endif        
      
      If ([WFAS]ISSDAT <> [0/0/0]) Then
        If ( I_PLN = G_PLNSUB(find([F:WFAS]CPY, G_SOC)) ) Then
          L_PLN = G_PLNSUB(find([F:WFAS]CPY, G_SOC))
        Else 
          L_PLN = I_PLN
        Endif  

        [F:WFAS]ISSAMT(I_PLN-1) = [F:WFAS]ISSAMT
        # Positionnement du buffer WDEP sur le dernier enregistrement
        Filter [WDEP] Where AASREF= [F:WFAS]AASREF and DPRPLN = L_PLN
        Read [WDEP]DEP0 Last
        Filter [WDEP]        
        [F:WFAS]SHOGAL(I_PLN-1) = [F:WDEP]SHOGAL
        [F:WFAS]LNGGAL(I_PLN-1) = [F:WDEP]LNGGAL
        [F:WFAS]GAL   (I_PLN-1) = [F:WDEP]GAL
        If ( [F:WDEP]GRUGAL <> 0 ) Then
          [F:WFAS]GAL   (I_PLN-1) = [F:WDEP]GRUGAL
        Endif
        # Positionnement du buffer WDEP sur l'enregistrement ayant une reprise de dépréciation sur sortie 
        Filter [WDEP] Where AASREF= [F:WFAS]AASREF and DPRPLN = L_PLN and IMLRVEISS <> 0
        Read [WDEP]DEP0 Last
        Filter [WDEP]        
        If not(fstat) Then
          [F:WFAS]IMLRVEISS(I_PLN-1) = [F:WDEP]IMLRVEISS
        Endif
      Endif
    Endif
  Next I_PLN

  If (B_DPMUO) Then
    [F:WFAS]PROPLN = [F:WFAS]AASREF
  Endif

  #- 1 -----------------------------
  If ( [F:WFAS]ISSDAT <> [0/0/0] ) Then
    # Mise à jour  - Règle sur sortie
    Case [F:WFAS]PYBVATTYP
      When  3  : [F:WFAS]PYBVATTYP = 4
      When  5  : [F:WFAS]PYBVATTYP = 3
      When  6  : [F:WFAS]PYBVATTYP = 4
      When  7  : [F:WFAS]PYBVATTYP = 5
      When  8  : [F:WFAS]PYBVATTYP = 6
    Endcase
    #- 2 -----------------------------
    If ( B_PLN_EXIST(2) ) Then
      # Positionnement du buffer WDEP sur l'enregistrement ayant de la réintégration fiscale 
      Filter [WDEP] Where AASREF= [F:WFAS]AASREF and DPRPLN = 2 and ( LEG <> 0 or LEGRVE <> 0 ) 
      Read [WDEP]DEP0 Last
      Filter [WDEP]        
      Local Date L_DERN_REINT
      If (fstat) Then
        L_DERN_REINT = [0/0/0]
      Else
        L_DERN_REINT = [F:WDEP]PERSTRDAT
      Endif
 
      # Positionnement du buffer WDEP sur l'enregistrement ayant du dérogatoire 
      Filter [WDEP] Where AASREF= [F:WFAS]AASREF and DPRPLN = 1 and ( LEG <> 0 or LEGRVE <> 0 ) 
      Read [WDEP]DEP0 Last
      Filter [WDEP]        
      If not(fstat) Then
        If ( [F:WDEP]PERSTRDAT > L_DERN_REINT ) Then
          [F:WFAS]DERRVEISS = ( [F:WDEP]LEGCUM    + [F:WDEP]PERLEGCUM + [F:WDEP]LEG    ) -
&                            ( [F:WDEP]LEGRVECUM + [F:WDEP]PERRVECUM + [F:WDEP]LEGRVE )
        Endif
      Endif
    Endif         
    #- 2 -----------------------------
  Endif
  #- 1 -----------------------------

  #- 1 -----------------------------
  If ( [F:WFAS]ISSDAT >= L_CNT_DBEXE(1) ) Then
    # Alimentation - Règle sur sortie
    #- 2 -----------------------------
    If ( [F:WFAS]ISSTYP = 5 ) Then
      # Motif de sortie "Rebut avec amortissement exceptionnel" devient
      # Motif de sortie "Rebut" Type de sortie "Amort Except = V.Nette"
      L_ISSTYP           = 2
      [F:WFAS]ISSDATRUL   = 10
    #- 2 -----------------------------
    Elsif ( [F:WFAS]ISSTYP = 7 ) Then
      # Motif de sortie "1 er bien cédé de la concession" devient
      # Motif de sortie "Vente" Type de sortie "1er bien cédé de la concession"
      L_ISSTYP           = 1
      [F:WFAS]ISSDATRUL   = 9
    #- 2 -----------------------------
    Else
      If ( [F:WFAS]ISSTYP = 6 ) Then
        # Fin de contrat de crédit bail 6 passe à 5
        L_ISSTYP = 5
      Elsif ( [F:WFAS]ISSTYP > 4 ) Then
        # Décalage de 2 pour prendre en compte suppression de Rebut avec AE & 1er bien cédé de la concession
        L_ISSTYP = [F:WFAS]ISSTYP - 2
      Else
        # de 1 à 4 reste en l'état
        L_ISSTYP = [F:WFAS]ISSTYP
      Endif      
      #- 3 -----------------------------
      If (B_DOTCOMASO) Then
        # Sortie fin d'exercice courant
        [F:WFAS]ISSDATRUL = 5
      Elsif (B_PADDOTASO) Then
        # Sortie fin d'exercice précédent
        [F:WFAS]ISSDATRUL = 4
      Elsif (B_PADDOTJSO) Then
        # Pas de dotation le jour de sortie
        [F:WFAS]ISSDATRUL = 8
      Else 
        # Au jour précisé
        [F:WFAS]ISSDATRUL = 1
      Endif 
      #- 3 -----------------------------
    Endif
    #- 2 -----------------------------
    # Mise à jour du type de sortie
    [F:WFAS]ISSTYP = L_ISSTYP
  #- 1 -----------------------------
  Else   
    [F:WFAS]ISSDATRUL = 0
  Endif 
  #- 1 -----------------------------
 

Return
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_FXDASSETS -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_DEPREC (PDOSSIER)
#  
# - Origine : AMAJ_DEPREC de FASMAJ25  
#  
# - Objet  : Mise à jour de la table DEPREC
#
#

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

  If clalev([F:WPPH]) : Close File  [WPPH] : Endif 
  Local File =PDOSSIER+".PROPLNH"   [WPPH]
  If clalev([F:WPPL]) : Close File  [WPPL] : Endif 
  Local File =PDOSSIER+".PROPLN"    [WPPL]
  If clalev([F:WCNX]) : Close File  [WCNX] : Endif 
  Local File =PDOSSIER+".CONTEXT"   [WCNX]
  If clalev([F:WFIS]) : Close File  [WFIS] : Endif 
  Local File =PDOSSIER+".FISCYEAR"  [WFIS]
  If clalev([F:WDMI]) : Close File  [WDMI] : Endif 
  Local File =PDOSSIER+".DEPRECMIG" [WDMI]
  If clalev([F:WFAS]) : Close File  [WFAS] : Endif 
  Local File =PDOSSIER+".FXDASSETS" [WFAS]
  If clalev([F:XDEP]) : Close File  [XDEP] : Endif 
  Local File =PDOSSIER+".DEPREC"    [XDEP]
  If clalev([F:WDEP]) : Close File  [WDEP] : Endif 
  Local File =PDOSSIER+".DEPREC"    [WDEP]
  If clalev([F:WADV]) : Close File  [WADV] : Endif 
  Local File =PDOSSIER+".ADOVAL"    [WADV]

  Local Char     CLE1
  Local Integer  CLE2
  Local Char     CLE3
  Local Date     CLE4
  Local Date     CLE5
  Local Integer  TRUE   : TRUE  = 1
  Local Integer  FALSE  : FALSE = 0 
  Local Integer  B_CONTINUE
  Local Integer  NB_REWRITE
  Local Integer  NB_MAJ
  Local Integer  B_REWRITE
  Local Char     CRITERE(250)

  Local Char    FIRCPY   : FIRCPY = ""
  Local Integer FIRPLN   : FIRPLN = 0
  Local Char    FIRBCO   : FIRBCO = ""
  Local Integer B_PPL    : B_PPL = 0   
  Local Integer PLNSAV 

  Gosub SET_FIRST From TRTFIRST

  NB_MAJ     = 0
  B_CONTINUE = 0

  # Suppression des images avant migration
  Delete [WDMI] Where evalue("1=1")
  If (fstat) Then : GERRDOS = 1 :   Endif

  #>1 >>>>>>>>>>>>>>>>>>>>
  Repeat
    Raz NB_REWRITE

     
    Trbegin [WDEP]
    If (B_CONTINUE = 1 ) Then
      B_CONTINUE = 2
      CRITERE = "CPY = CLE1 and DPRPLN = CLE2 and AASREF = CLE3 and FIYENDDAT = CLE4 and PERENDDAT > CLE5"
    Elsif (B_CONTINUE = 2 ) Then
      B_CONTINUE = 3
      CRITERE = "CPY = CLE1 and DPRPLN = CLE2 and AASREF = CLE3 and FIYENDDAT > CLE4"
    Elsif (B_CONTINUE = 3 ) Then
      B_CONTINUE = 4
      CRITERE = "CPY = CLE1 and DPRPLN = CLE2 and AASREF > CLE3"
    Elsif (B_CONTINUE = 4 ) Then
      B_CONTINUE = 5
      CRITERE = "CPY = CLE1 and DPRPLN > CLE2"
    Elsif (B_CONTINUE = 5 ) Then
      B_CONTINUE = 0
      CRITERE = "CPY > CLE1"
    Else
      CRITERE = "1=1" : # 1ère fois
    Endif
    #>2 >>>>>>>>>>>>>>>>>>>>
    For [WDEP]DEP3 Where evalue(CRITERE) With Stability
      PLNSAV = [F:WDEP]DPRPLN
      # Sauvegarde avant migration
      [F:WDMI] = [F:WDEP] 
      Write[WDMI]
      If (fstat) Then : GERRDOS = 1 :   Endif

      #Call ECR_TRACE ("Lu. enr. à migrer    DEP"-[F:WDEP]CPY-[F:WDEP]AASREF-num$([F:WDEP]DPRPLN)-num$([F:WDEP]FIYSTRDAT)-num$([F:WDEP]PERSTRDAT), 0) From GESECRAN    

      #--
      If ( [F:WDEP]DPRPLN <> FIRPLN ) Then
        # Rupture première PLAN
        Gosub DEP_1ERE_PLAN
        FIRPLN = [F:WDEP]DPRPLN : # rupture plan
        FIRBCO = ""             : # rupture bien forcée
      Endif
      If ( [F:WDEP]AASREF <> FIRBCO ) Then
        # Rupture première BIEN
        Gosub DEP_1ERE_BIEN
        FIRBCO = [F:WDEP]AASREF : # rupture bien
      Endif
      #--

      Gosub UPGRADE_DEPREC

      #-3 -----------------
      If (B_REWRITE) Then      
        #Call ECR_TRACE ("Rewrite. enr. migrés DEP"-[F:WDEP]CPY-[F:WDEP]AASREF-num$([F:WDEP]DPRPLN)-num$([F:WDEP]FIYSTRDAT)-num$([F:WDEP]PERSTRDAT), 0) From GESECRAN    
 
        Rewrite [WDEP]
        If (fstat) Then : GERRDOS = 1 :   Endif
        NB_REWRITE += 1
        NB_MAJ     += 1
        If ( NB_REWRITE > GMAXUPDTRS ) Then
          CLE1 = [F:WDEP]CPY
          CLE2 = PLNSAV
          CLE3 = [F:WDEP]AASREF
          CLE4 = [F:WDEP]FIYENDDAT
          CLE5 = [F:WDEP]PERENDDAT
          B_CONTINUE = 1
          Break   
        Endif  
      Endif
      #-3 -----------------
    Next
    #<2 <<<<<<<<<<<<<<<<<<<< 
  Commit
  Until not B_CONTINUE
  #<1 <<<<<<<<<<<<<<<<<<<<
 
  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  DEPREC" , 0) From GESECRAN

  Gosub UNSET_FIRST From TRTFIRST

  Close Local File [WDEP]
  Close Local File [XDEP]
  Close Local File [WDMI]
  Close Local File [WFIS]
  Close Local File [WPPH]
  Close Local File [WPPL]
  Close Local File [WFAS]
  Close Local File [WCNX]
  Close Local File [WADV]
End

#==========================
$DEP_1ERE_PLAN

Local Integer I_PLN

Local Integer L_CNX
Local Integer L_CNX_NORM 
Local Date    L_CNX_DBEXE 
Local Date    L_CNX_FNEXE 
Local Date    L_CNX_DBPER 
Local Date    L_CNX_FNPER


  # Plan de subvention
  Local Integer L_PLN 
  If ( [F:WDEP]DPRPLN = G_PLNSUB(find([F:WDEP]CPY, G_SOC)) ) Then
    L_PLN = G301SUB
  Else 
    L_PLN = [F:WDEP]DPRPLN  
  Endif

  # Contextes
  For [WCNX]CNX0 Where [F:WCNX]CPY=[F:WDEP]CPY
    # Plans du contexte
    For I_PLN = 1 To [F:WCNX]NBPLC
      If ( [F:WCNX]PLNCAA(I_PLN-1) = L_PLN ) Then   
        L_CNX      = [F:WCNX]CNX
        L_CNX_NORM = [F:WCNX]PLNSTD(I_PLN-1)
        Break 2
      Endif            
    Next I_PLN
  Next CNX0
  Filter [WFIS] Where CPY=[F:WDEP]CPY and CNX= L_CNX and STAFIY= 2  
  Read [WFIS] First
  Filter [WFIS]
  L_CNX_DBEXE =[F:WFIS]DATSTRFIY
  L_CNX_FNEXE =[F:WFIS]DATENDFIY
  L_CNX_DBPER =[F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
  L_CNX_FNPER =[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)
  Filter [WFIS] Where CPY=[F:WDEP]CPY and CNX= L_CNX  
  Read [WFIS] FIY0 Last
  Filter [WFIS]
  L_FIN_FNPER =[F:WFIS]DATENDFIY
  #Call ECR_TRACE ("NOUVEAU PLAN"-num$([F:WDEP]DPRPLN)-num$(L_CNX_DBEXE)-num$(L_CNX_DBPER), 0) From GESECRAN

  Local Integer B_DEROENCOU : B_DEROENCOU = FALSE
  If ( [F:WDEP]DPRPLN = G301FIS ) Then
    Read [WADV]ADW1="DEROENCOUR";[F:WDEP]CPY;""
    If (fstat)  Then
      Read [WADV]ADW1="DEROENCOUR";"";""
      If (fstat) Then
        B_DEROENCOU = G_NON
      Else
        B_DEROENCOU = val([F:WADV]VALEUR)
      Endif
    Else 
      B_DEROENCOU = val([F:WADV]VALEUR)
    Endif
  Endif    
    
Return

#==========================
$DEP_1ERE_BIEN

  Local Decimal L_EXCCUM     : L_EXCCUM    = 0
  Local Char    L_DPM        : L_DPM       = ""
  Local Char    L_DPM140     : L_DPM140    = ""
  Local Char    L_DPM_P_1    : L_DPM_P_1   = ""
  Local Integer L_MTCTIATYP  : L_MTCTIATYP = 0
  Local Date    L_MTCTIADAT  : L_MTCTIADAT = [0/0/0]
  Local Decimal L_MTCDPEDEV  : L_MTCDPEDEV = 0.
  Local Integer L_MTCDEVADJ  : L_MTCDEVADJ = 0

  Local Date L_PERREFCLC  : L_PERREFCLC   = [0/0/0]
  Local Date L_PERREFCLCI : L_PERREFCLCI  = [0/0/0]
  Local Date L_PERREFCLCT : L_PERREFCLCT  = [0/0/0]

  Read [WFAS]FAS0=[F:WDEP]AASREF
  Local Decimal L_PERRVACUM  : L_PERRVACUM = 0
  Local Decimal L_RSDQTY  : L_RSDQTY = [F:WDEP]RSDQTY

  # Positionnement du buffer XDEP sur la période courante
  Read [XDEP]DEP0=[F:WDEP]AASREF;[F:WDEP]DPRPLN;L_CNX_FNEXE;L_CNX_FNPER        

  If ( [F:XDEP]DPM = "UO" ) Then
    # Approximation de la durée d'amortissement
    Local Date    L_DTFNAMT
    # Durée en années résiduelles = valeur entière de [UO résiduelle / UO exercice] 
    If ( [F:XDEP]FIYQTY <> 0 ) Then
      L_DTFNAMT = func GLOBI9.CAL_DAT_PLUS([F:XDEP]FIYSTRDAT, int([F:XDEP]RSDQTY/[F:XDEP]FIYQTY),"Y") -1
    Endif
  Endif

  B_PPL = 0
  Look [F:WPPH]PPH0=[F:WDEP]AASREF
  If not(fstat) Then :  B_PPL = 2 : Endif
         
Return

#==========================
$UPGRADE_DEPREC
 
  # Toujours - Date début & fin période 
  If ( [F:WDEP]PERSTRDAT = [0/0/0] ) Then  
    [F:WDEP]PERSTRDAT = [F:WDEP]FIYSTRDAT
    [F:WDEP]PERENDDAT = [F:WDEP]FIYENDDAT
  Endif

  # Les deprec antérieurs au début de l'exercice courant sont modifiés à "Minima"
  # Alimentation des nouveaux champs V5 dont la valeur peut être déduite par les champs 140.     
  If ( [F:WDEP]PERSTRDAT < L_CNX_DBEXE ) Then
    B_REWRITE = TRUE
    # Site
    [F:WDEP]FCY = [F:WFAS]FCY
    # Contexte
    [F:WDEP]CNX = L_CNX
    Return
  Endif

  # Les biens "En cours" ont le mode d'amortissement systématiquement passé à "SA"
  # si le paramètre DEROENCOUR est à Oui le mode du plan fiscal reste inchangé
  If ( [F:WFAS]GACACN = GVML_NIENCOU or [F:WFAS]IASACN = GVML_NIENCOU ) Then
    If ( ( [F:WDEP]DPRPLN <> G301FIS ) or ( [F:WDEP]DPRPLN = G301FIS and !B_DEROENCOU )  ) Then 
      [F:WDEP]DPM = "SA"
    Endif
  Endif


  # Mode UO
  # A mettre si nécessaire dans AMAJ_PROPLN
  If ([F:WDEP]DPM = "UO" and B_PPL = 0 ) Then
    
    B_PPL = 1
    # Création du plan de production
    [F:WPPH]PROPLN     = [F:WDEP]AASREF
    [F:WPPH]CNX        = L_CNX    
    [F:WPPH]CPY        = [F:WDEP]CPY    
    [F:WPPH]FCY        = [F:WFAS]FCY    
    [F:WPPH]ENAFLG     = G_OUI    
    [F:WPPH]PLNDES1    = [F:WFAS]AASDES1    
    [F:WPPH]PLNDES2    = ""
    [F:WPPH]UOM        = "Un"
    [F:WPPH]PPLENDDAT0 = [0/0/0]
    [F:WPPH]CREUSR     = GUSER
    [F:WPPH]CREDAT     = date$
    Write [WPPH]
    If (fstat) Then : GERRDOS = 1 :   Endif
  Endif

  If ([F:WDEP]DPM = "UO" and B_PPL = 1 and [F:WDEP]PERENDDAT <= L_FIN_FNPER) Then
    Read [F:WPPL]PPL0=[F:WDEP]AASREF;[F:WDEP]FIYENDDAT;[F:WDEP]PERENDDAT

    If (fstat) Then
      [F:WPPL]PROPLN    = [F:WDEP]AASREF
      [F:WPPL]FIYSTRDAT = [F:WDEP]FIYSTRDAT
      [F:WPPL]FIYENDDAT = [F:WDEP]FIYENDDAT
      [F:WPPL]PERSTRDAT = [F:WDEP]PERSTRDAT
      [F:WPPL]PERENDDAT = [F:WDEP]PERENDDAT
      [F:WPPL]PLNQTY    = L_RSDQTY
      [F:WPPL]RSDQTY    = [F:WDEP]RSDQTY
      [F:WPPL]EXTQTY    = [F:WDEP]PERQTY
      If ( [F:WDEP]PERSTRDAT < L_CNX_DBPER ) Then
        [F:WPPL]CPLQTY    = [F:WDEP]PERQTY
      Else
        [F:WPPL]CPLQTY    = 0
      Endif
      [F:WPPL]FIYQTY    = [F:WDEP]FIYQTY
      [F:WPPL]CREUSR    = GUSER
      [F:WPPL]CREDAT    = date$
      Write [WPPL]
      If (fstat) Then : GERRDOS = 1 :   Endif
    Endif  
  Endif

  #***********
  #Call ECR_TRACE ("Deprec migration  DEP"-num$(B_PPL)-[F:WDEP]DPM-[F:WDEP]CPY-[F:WDEP]AASREF-num$([F:WDEP]DPRPLN)-num$([F:WDEP]FIYSTRDAT)-num$([F:WDEP]PERSTRDAT), 0) From GESECRAN    

  If ( [F:XDEP]DPM = "UO" and [F:WDEP]DPM = "UO" and [F:WDEP]FIYENDDAT = L_CNX_FNEXE ) Then
    # Date de fin d'amortissement
    [F:WDEP]ENDDPRDAT = L_DTFNAMT
  Endif


  # Les deprec ultérieures à la période courante bien que supprimés sont toujours présents (with stability) 
  If ( [F:WDEP]PERSTRDAT > L_CNX_DBPER ) Then
    # Suppression des DEPREC ultérieurs à la période courante pour le plan du bien concerné  
    #Call ECR_TRACE ("Suppr. enr. ultérieurs DEP"-[F:WDEP]CPY-[F:WDEP]AASREF-num$([F:WDEP]DPRPLN)-num$([F:WDEP]FIYSTRDAT)-num$([F:WDEP]PERSTRDAT), 0) From GESECRAN    
    Delete [WDEP] Curr
    If (fstat) Then : GERRDOS = 1 :   Endif
    B_REWRITE = FALSE
    Return
  Endif

  # Mise à jour selon B_WRITE
  B_REWRITE = TRUE

  # Upgrade dans l'ordre de rubriques de DEPREC
  #----------------------------------------
  # Site
  [F:WDEP]FCY = [F:WFAS]FCY
  # Contexte
  [F:WDEP]CNX = L_CNX
  # Plan de subvention 
  If ( [F:WDEP]DPRPLN = G_PLNSUB(find([F:WDEP]CPY, G_SOC)) ) Then
    [F:WDEP]DPRPLN = G301SUB 
  Endif
  # Mode d'amortissement
  L_DPM_P_1 = L_DPM140
  L_DPM140  = [F:WDEP]DPM
  Case [F:WDEP]DPM
    When "AN"   [F:WDEP]DPM = "IT"          
    When "OR"   [F:WDEP]DPM = "IT"          
    When "D1"   [F:WDEP]DPM = "UD" : [F:WDEP]PRATYP = 2   : [F:WDEP]ACLCOE = 1.5          
    When "PI"   [F:WDEP]DPM = "SA"               
    When "PL"   [F:WDEP]DPM = "SA"               
    When "D2"   [F:WDEP]DPM = "UD" : [F:WDEP]PRATYP = 2   : [F:WDEP]ACLCOE = 2.0          
    When "DM"   [F:WDEP]DPM = "DB" : [F:WDEP]PRATYP = 2             
    When "PC"   [F:WDEP]DPM = "PC"              
    When "PD"   [F:WDEP]DPM = "PD"              
    When "L1"   [F:WDEP]DPM = "LP"              
    When "LC"   [F:WDEP]DPM = "CA"              
    When "LO"   [F:WDEP]DPM = "LP"              
    When "RC"   [F:WDEP]DPM = "CA"              
    When "SD"   [F:WDEP]DPM = "SA"               
    When "RJ"   [F:WDEP]DPM = "RE" : [F:WDEP]PRATYP = 1             
    When "RM"   [F:WDEP]DPM = "RE" : [F:WDEP]PRATYP = 2             
    When "RS"   [F:WDEP]DPM = "RE" : [F:WDEP]PRATYP = 3             
  Endcase
  
  # Mode d'amort. Théorique et Initial
  [F:WDEP]DPMT = [F:WDEP]DPM
  [F:WDEP]DPMI = [F:WDEP]DPM
  If ([F:WDEP]PERENDDAT =(L_CNX_DBPER-1) and [F:WDEP]IMLBLC =0 and ([F:WDEP]IML <>0 or [F:WDEP]IMLRVE <>0) ) Then
    # Si dépréciation dans la période précédant la migration
    L_DPM = [F:WDEP]DPM
  Endif
  If ([F:WDEP]PERSTRDAT = L_CNX_DBPER and L_DPM <> "") Then
    # Si période courante dépréciation dans la période précédant la migration
    [F:WDEP]DPMT = L_DPM
    [F:WDEP]DPMI = L_DPM  
  Endif
  # Si Réévaluation par valeur marché dans la période de migration
  If ([F:WDEP]PERSTRDAT = L_CNX_DBPER and [F:WDEP]RVAAMT <> 0 and [F:WDEP]DPMORI <> [F:WDEP]DPM) Then
    [F:WDEP]DPMI = [F:WDEP]DPMORI  
  Endif
  
  # Type de prorata ( alimenté lors de l'alimentation de DPM ou déterminé lors du prochain calcul )
  # Coéff. d'accélération ( alimenté lors de l'alimentation de DPM )
  # Prise d'effet de la réévaluation 
  If ( [F:WDEP]RVAAMT <> 0 and [F:WDEP]FIYSTRDAT >= L_CNX_DBEXE) Then
    # Prise d'effet début de période pour toute réévaluation à partir du début de l'exercice courant
    [F:WDEP]RVATIADAT = 2 
  Endif
  # Cumul P-1 réévaluation
  If ( [F:WDEP]PERSTRDAT >= L_CNX_DBEXE and [F:WDEP]PERSTRDAT <= L_CNX_DBPER ) Then
    [F:WDEP]PERRVACUM = L_PERRVACUM
    L_PERRVACUM += [F:WDEP]RVAAMT
  Else
    [F:WDEP]PERRVACUM = 0. 
  Endif
  # Unité
  If ( [F:WDEP]UOM = "UN" ) Then
    [F:WDEP]UOM = "Un" 
  Endif 
  # Flag à "Non calculé" sur période courante
  If ( [F:WDEP]PERSTRDAT = L_CNX_DBPER ) Then
    [F:WDEP]DEPSTA = 1 
  Endif 
  [F:WDEP]ETRPNT  = 0
  [F:WDEP]EXCDPRI = 0
  [F:WDEP]EXCDPRT = 0
  [F:WDEP]EXCCUMI = 0
  [F:WDEP]EXCCUMT = 0
  # Cumul amort. except. E-1 
  L_EXCCUM += [F:WDEP]EXCDPR 
  [F:WDEP]EXCCUM = L_EXCCUM - [F:WDEP]EXCDPR
  [F:WDEP]ENDDPEI = 0
  [F:WDEP]ENDDPET = 0
  # Règles particulières  
  Case [F:WDEP]ALWCOD
    When 4, 5, 6, 7, 8, 11, 12, 13
      # Non reconduits   AIDE 1983 - 1985
      #                  MINORATION 0.5 COEF DEGRESSIVITE
      #                  AMORTISSEMENT DEBUT D'EXERCICE
      #                  AMORTISSEMENT DEBUT SEMESTRE
      #                  MAJORATION 0.5 COEF DEGRESSIVITE
      #                  DEGRESSIF FRANCAIS DEROGATOIRE
      #                  1er JOUR DE L'EXERCICE SUIVANT
      #                  MINORATION 0.25 COEF DEGRESSIVITE
      [F:WDEP]ALWCOD = 1
    When 14
      [F:WDEP]ALWCOD = 6
  Endcase
  # Mise à jour du champ ALWCOD lié au mode d'amortissement primant sur les autres règles
  Case L_DPM140
    When "PC"   : [F:WDEP]ALWCOD = 16              
    When "PD"   : [F:WDEP]ALWCOD = 16              
    When "L1"   : [F:WDEP]ALWCOD = 12              
    When "LC"   : [F:WDEP]ALWCOD = 14              
    When "LO"   : [F:WDEP]ALWCOD = 13              
    When "RC"   : [F:WDEP]ALWCOD = 14              
  Endcase

  #-- Valeur nette

  #-- Lien  
  [F:WDEP]LNK       = 0.  
  [F:WDEP]PERLNKCUM = 0.  
  [F:WDEP]LNKCUM    = 0.

  # Cumul dépréciation  P-1 
  [F:WDEP]PERIMLCUM = [F:WDEP]IMLCUM    - [F:WDEP]EXEIMLCUM


  # Plafond de Reprise de Dépréciation à partir des valeurs nettes début de période
  Local Decimal L_NBVT, L_NBV
  L_NBV   = [F:WDEP]DPRBAS - [F:WDEP]DPRCUM -[F:WDEP]PERCLOCUM - [F:WDEP]IMLBLC
  L_NBVT  = [F:WDEP]DPRBAS - [F:WDEP]DPRCUM -[F:WDEP]PERCLOCUM
  If ( abs(L_NBVT) > abs(L_NBV) and [F:WDEP]IMLBLC <> 0 ) Then
    [F:WDEP]IMLRVELIM = [F:WDEP]NBVT - [F:WDEP]NBV
  Else
    [F:WDEP]IMLRVELIM = 0.
  Endif 

  # Cumul reprise dépr. P-1 
  [F:WDEP]PERRVECUM = [F:WDEP]IMLRVECUM - [F:WDEP]EXERVECUM

  # Repr. de Dépr. transférée en Amt. Exc. ( sera calculée avec éventuel rattrapage à partir des cumuls)
  [F:WDEP]IMLRVETRF  = 0.
  # Cumul reprise de dépréciation transférée en amort. except. P-1
  [F:WDEP]PERTRFCUM  = 0.
  # Cumul reprise de dépréciation transférée en amort. except. E-1
  [F:WDEP]EXETRFCUM  = 0.
  # Changement de méthode
  If ( [F:WDEP]MTCDPEDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_CNX_DBEXE and [F:WDEP]RVAAMT <> 0 ) Then
    # Ne pas prendre en compte le changement de méthode induit par la réévaluation
    [F:WDEP]MTCDPEDAT = [0/0/0]
  Endif
  If ( [F:WDEP]MTCDPEDAT <> [0/0/0]  and [F:WDEP]PERSTRDAT >= L_CNX_DBEXE ) Then
    L_MTCDPEDEV = [F:WDEP]MTCDPEDEV
    L_MTCDEVADJ = [F:WDEP]MTCDEVADJ
    If ( [F:WDEP]STRDPRDAT < L_CNX_DBEXE ) Then
      If ([F:WDEP]MTCDPEDEV <> 0 ) Then
        L_MTCTIATYP = 1
        L_MTCTIADAT = [F:WDEP]STRDPRDAT
      Else
        L_MTCTIATYP = 3
        L_MTCTIADAT = [F:WDEP]PERSTRDAT
      Endif
    Else
      If (L_DPM140 <> L_DPM_P_1 ) Then
        If ( [F:WDEP]STRDPRDAT >= [F:WDEP]PERSTRDAT and [F:WDEP]STRDPRDAT <= [F:WDEP]PERENDDAT ) Then 
          L_MTCTIATYP = 1
          L_MTCTIADAT = [F:WDEP]STRDPRDAT
       Else
         L_MTCTIATYP = 3
          L_MTCTIADAT = [F:WDEP]PERSTRDAT
        Endif
      Else
        L_MTCTIATYP = 1
        L_MTCTIADAT = [F:WDEP]STRDPRDAT
      Endif
    Endif
  Endif
  [F:WDEP]MTCTIATYP = L_MTCTIATYP
  [F:WDEP]MTCTIADAT = L_MTCTIADAT 
  [F:WDEP]MTCDPEDEV = L_MTCDPEDEV
  [F:WDEP]MTCDEVADJ = L_MTCDEVADJ 

  # Gestion de l'ecart E-1 suite chgt de méthode
  Case [F:WDEP]MTCDEVADJ
    When 1        : [F:WDEP]MTCDEVADJ = 4   : # Dotation exercice
    When 2,3,4,5  : [F:WDEP]MTCDEVADJ = 2
    When 6        : [F:WDEP]MTCDEVADJ = 5   : # Dotation période M.E.S -> Dotation période
  Endcase
      
  [F:WDEP]PERREFCLC  = [0/0/0]
  [F:WDEP]PERREFCLCI = [0/0/0]
  [F:WDEP]PERREFCLCT = [0/0/0]
  #- 1 ---------------------------------------
  If ( [F:WDEP]PERSTRDAT >= L_CNX_DBEXE ) Then
    If ( [F:WDEP]IML <> 0 or [F:WDEP]IMLRVE <> 0 ) Then
      If (L_DPM <> "" ) Then
        L_PERREFCLC      = [F:WDEP]PERSTRDAT      
      Else
        L_PERREFCLC      = [F:WDEP]PERSTRDAT      
        L_PERREFCLCT     = [F:WDEP]PERSTRDAT      
        L_PERREFCLCI     = [F:WDEP]PERSTRDAT
      Endif  
    Endif
    If ( [F:WDEP]RVAAMT <> 0 ) Then
      L_PERREFCLC      = [F:WDEP]PERSTRDAT      
      L_PERREFCLCT     = [F:WDEP]PERSTRDAT
      # Il faut le faire car le mode du suivi intial est aussi passé en résiduel
      L_PERREFCLCI     = [F:WDEP]PERSTRDAT
    Else      
      If ( [F:WDEP]MTCDPEDAT <> [0/0/0] ) Then
        If ( [F:WDEP]MTCTIATYP = 3 ) Then
          L_PERREFCLC      = [F:WDEP]MTCTIADAT      
          L_PERREFCLCI     = [F:WDEP]MTCTIADAT      
          L_PERREFCLCT     = [F:WDEP]MTCTIADAT
        Else
          If ( [F:WDEP]STRDPRDAT < L_CNX_DBEXE ) Then
            L_PERREFCLC      = [F:WDEP]STRDPRDAT 
            L_PERREFCLCI     = [F:WDEP]STRDPRDAT 
            L_PERREFCLCT     = [F:WDEP]STRDPRDAT
          Else
            L_PERREFCLC      = [F:WDEP]FIYSTRDAT      
            L_PERREFCLCI     = [F:WDEP]FIYSTRDAT
            L_PERREFCLCT     = [F:WDEP]FIYSTRDAT
          Endif
        Endif      
      Endif
    Endif
    #- 1 ---------------------------------------

    If (L_PERREFCLC  = [0/0/0]) Then :  L_PERREFCLC   = L_CNX_DBEXE : Endif  
    If (L_PERREFCLCT = [0/0/0]) Then :  L_PERREFCLCT  = L_CNX_DBEXE : Endif 
    If (L_PERREFCLCI = [0/0/0]) Then :  L_PERREFCLCI  = L_CNX_DBEXE : Endif

    [F:WDEP]PERREFCLC  = L_PERREFCLC
    [F:WDEP]PERREFCLCI = L_PERREFCLCI
    [F:WDEP]PERREFCLCT = L_PERREFCLCT
  Endif

  # suivi INITIAL & THEORIQUE
  # -- Initial               -- Théorique             -- Réel
  [F:WDEP]PEREXCDPRI = 0  : [F:WDEP]PEREXCDPRT = 0  : [F:WDEP]PEREXCDPR  = 0
  [F:WDEP]PERCLOEXCI = 0  : [F:WDEP]PERCLOEXCT = 0  : [F:WDEP]PERCLOEXC  = 0
  [F:WDEP]EXCDPRI    = 0  : [F:WDEP]EXCDPRT    = 0 
  [F:WDEP]MTCDPEDEVI = 0  : [F:WDEP]MTCDPEDEVT = 0 
  # Inchangé
  [F:WDEP]EXECLOCUMI = [F:WDEP]EXECLOCUMI  : [F:WDEP]EXECLOCUMT = [F:WDEP]EXECLOCUMT 
  [F:WDEP]PERCLOCUMI = [F:WDEP]PERCLOCUMI  : [F:WDEP]PERCLOCUMT = [F:WDEP]PERCLOCUMT  
  [F:WDEP]DPEI       = [F:WDEP]DPEI        : [F:WDEP]DPET       = [F:WDEP]DPET
  [F:WDEP]NBVI       = [F:WDEP]NBVI        : [F:WDEP]NBVT       = [F:WDEP]NBVT
  #- 1 ------------------------------
  If ( L_CNX_NORM = 1 or 
&      ( L_CNX_NORM <> 1 and
&        [F:XDEP]IMLCUM    = 0 and [F:XDEP]IML       = 0 and 
&        [F:XDEP]EXERVADEV = 0 and [F:XDEP]PERRVADEV = 0 and [F:XDEP]RVAAMT = 0 ) ) Then
    # Si Norme plan "Standard" ou ( "Normé" et pas de dépréciation et pas de réévaluation )
    # Alors suivis initial et théorique à l'identique du réel.
    # -- Initial                                 -- Théorique
    [F:WDEP]PERREFCLCI = [F:WDEP]PERREFCLC   : [F:WDEP]PERREFCLCT = [F:WDEP]PERREFCLC 
    [F:WDEP]PEREXCDPRI = [F:WDEP]PEREXCDPR   : [F:WDEP]PEREXCDPRT = [F:WDEP]PEREXCDPR 
    [F:WDEP]PERCLOEXCI = [F:WDEP]PERCLOEXC   : [F:WDEP]PERCLOEXCT = [F:WDEP]PERCLOEXC    
    [F:WDEP]EXCDPRI    = [F:WDEP]EXCDPR      : [F:WDEP]EXCDPRT    = [F:WDEP]EXCDPR  
    [F:WDEP]EXCCUMI    = [F:WDEP]EXCCUM      : [F:WDEP]EXCCUMT    = [F:WDEP]EXCCUM
    [F:WDEP]ENDDPEI    = [F:WDEP]ENDDPE      : [F:WDEP]ENDDPET    = [F:WDEP]ENDDPE
    [F:WDEP]MTCDPEDEVI = [F:WDEP]MTCDPEDEV   : [F:WDEP]MTCDPEDEVT = [F:WDEP]MTCDPEDEV
 
    [F:WDEP]EXECLOCUMI = [F:WDEP]DPRCUM      : [F:WDEP]EXECLOCUMT = [F:WDEP]DPRCUM 
    [F:WDEP]PERCLOCUMI = [F:WDEP]PERCLOCUM   : [F:WDEP]PERCLOCUMT = [F:WDEP]PERCLOCUM  
    [F:WDEP]DPEI       = [F:WDEP]PERENDDPE   : [F:WDEP]DPET       = [F:WDEP]PERENDDPE
    [F:WDEP]NBVI       = [F:WDEP]NBV         : [F:WDEP]NBVT       = [F:WDEP]NBV
  Endif
  #- 1 ------------------------------

  #-- A comptabiliser  
  [F:WDEP]FLGDEV    = 1  
  [F:WDEP]DPEDEV    = 0.  
  [F:WDEP]EXCDEV    = 0.  
  [F:WDEP]DERDEV    = 0.  
  [F:WDEP]DERRVEDEV = 0.  
  [F:WDEP]RVETRFDEV = 0.
  [F:WDEP]RVACRBDEV = 0.  

  #-- Comptabilisé  
  [F:WDEP]FLGPST     = 1
  [F:WDEP]PSTDPE     = 0.
  [F:WDEP]PSTEXC     = 0.
  [F:WDEP]PSTDER     = 0.
  [F:WDEP]PSTDERRVE  = 0.
  [F:WDEP]PSTRVETRF  = 0.
  [F:WDEP]PSTRVACRB  = 0.

  #-- Differé  
  [F:WDEP]DFDLIM    = 0.  
  [F:WDEP]DFD       = 0.  
  [F:WDEP]DFDRVE    = 0.  
  [F:WDEP]DFDBLC    = 0.

  [F:WDEP]FLGMIG = 2  
 
Return
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_DEPREC -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_FXDLIFL (PDOSSIER) 
#  
# - Origine : AMAJ_FXDLIFL de FASMAJ25  
#  
# - Objet  : Mise à jour de la table FXDLIFL
#
#

Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ

  If clalev([CPY]) : Close File     [CPY] : Endif 
  Local File =PDOSSIER+".COMPANY"   [CPY]
  If clalev([CNX]) : Close File     [CNX] : Endif 
  Local File =PDOSSIER+".CONTEXT"   [CNX]
  If clalev([FAS]) : Close File     [FAS] : Endif 
  Local File =PDOSSIER+".FXDASSETS" [FAS]
  If clalev([FLU]) : Close File     [FLU] : Endif 
  Local File =PDOSSIER+".FXDLIFL"   [FLU]
 
  Local Integer TABPLN(15), N_PLN, NB_MAJ

  If !G_TRANSAC : Trbegin [FLU] : Endif

  # Le traitement se fait par société
  For [CPY]
    # Chargement pour la société des couples contextes/plans
    For [CNX] Where CPY=[F:CPY]CPY
      For N_PLN = 0 To [F:CNX]NBPLC-1
        [L]TABPLN([F:CNX]PLNCAA(N_PLN)) = [F:CNX]CNX
      Next N_PLN
    Next    

    # Boucle sur les biens pour traiter les flux
    For [FAS] Where CPY=[F:CPY]CPY
      For [FLU] Where AASREF=[F:FAS]AASREF
        [F:FLU]INCFCY    = 0
        [F:FLU]INCDPRFCY = 0
        [F:FLU]DCRFCY    = 0
        [F:FLU]DCRDPRFCY = 0
  
        [F:FLU]FCY       = [F:FAS]FCY
        [F:FLU]FCYORI    = ""
        [F:FLU]CNX       = [L]TABPLN([F:FLU]DPRPLN)

        [F:FLU]BSEVALSTR = [F:FLU]BSEVAL

        If [F:FLU]DPRPLN = G301CPT
          [F:FLU]DERISS  = max(0,[F:FLU]DERISS-[F:FLU]DERRVE)
        Else
          [F:FLU]DERISS  = 0
        Endif

        If [F:FLU]TXSCATORI = [F:FLU]TXSCAT
          [F:FLU]TXSCATORI = ""
        Endif

        Rewrite [FLU] Curr

        If fstat
          Call ECR_TRACE ("ERROR WHILE UPDATING FXDLIFL"-num$(fstat) , 1) From GESECRAN
          GERRDOS = 1
        Else
          NB_MAJ += 1
        Endif
      Next
    Next
  Next

  If !G_TRANSAC : Commit : Endif

  Call ECR_TRACE ("    "-num$(NB_MAJ)-" UPDATED  FXDLIFL" , 0) From GESECRAN

  Close File [CPY]
  Close File [CNX]
  Close File [FAS]
  Close File [FLU]
End

#*************************************
#*************************************
# => POUR    *- AMAJ_FXDLIFL -*
#*************************************
#*************************************

