#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CLF",GBIDC1,"") From GOBJET
End

######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "INIMOD"     : Gosub INIMOD
 When "FERME"      : Gosub FERME
 When "RAZCRE"     : Gosub RAZCRE
Endcase

Return

$OUVRE
If !clalev([F:CLF]) : Local File CALENDAFF [CLF] : Endif
If !clalev([F:HRPOP]) : Local File POPUL     [HRPOP] : Endif
#LIPET - 21-10-2016 - X3PEOP-1242 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#Call MANAGE_LOCALISATION("OCLF") From DIVPAYE
#LIPET - 21-10-2016 - X3PEOP-1242 - END
Return

$STYLE
#LIPET - 21-10-2016 - X3PEOP-1242 - START
#Gosub DISPLAY_HIDE From SUBCLFLEG
#LIPET - 21-10-2016 - X3PEOP-1242 - END
Return

$RAZCRE
 GCURLEG = ""
Return

$LIENS
Gosub CHARGE_ECRAN

If dim([M:CLF]LEG)>0
  GCURLEG = [M:CLF]LEG
Endif
Return

#LIPET - 21-10-2016 - X3PEOP-1242 - START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#LIPET - 21-10-2016 - X3PEOP-1242 - END

$INIMOD
Gosub SAUVE_ECRAN
Return

$CHARGE_ECRAN
nolign=1
For [F:CLF]CLF1 Where TYPCLD=[F:CLD]TYPCLD & PERIOD=[F:CLD]PERIOD
 [M]=[F:CLF]
 nolign+=1
Next
[M]NBLIG=nolign-1
Affzo [M]10
Return

$SAUVE_ECRAN
Delete [F:CLF] Where TYPCLD=[M]TYPCLD & PERIOD=[M]PERIOD

If fstat=1
 GOK =-1 : GLOCK = "$CALENDAFF" : Return
Endif
For nolign=1 To [M]NBLIG
 [F:CLF]LEV    = [M]LEV(nolign-1)
 ###Population
 [F:CLF]POP    = [M]POP(nolign-1)
 [F:CLF]LEG    = [M]LEG(nolign-1)
 [F:CLF]CPY    = [M]CPY(nolign-1)
 [F:CLF]FCY    = [M]FCY(nolign-1)
 [F:CLF]SRV    = [M]SRV(nolign-1)
 [F:CLF]EMP    = [M]EMP(nolign-1)
 [F:CLF]CTR    = [M]CTR(nolign-1)

#Pour trier dans l'ordre de prise en compte des valeurs
Case [M]LEV(nolign-1)
 When 1 : [F:CLF]ORD = 1
 When 2 : [F:CLF]ORD = 2
 When 3 : [F:CLF]ORD = 3
 When 4 : [F:CLF]ORD = 4
 When 5 : [F:CLF]ORD = 6
 When 6 : [F:CLF]ORD = 7
 When 7 : [F:CLF]ORD = 5
Endcase

 [F:CLF]TYPCLD = [M]TYPCLD
 [F:CLF]PERIOD = [M]PERIOD
 Write [CLF]
 If fstat<>0
  GOK = 0 : Call FSTA("CLF") From GLOCK
 Endif
Next
Return

######################################################################################
######################################################################################
Subprog C_LEV(VALEUR)
Variable Integer VALEUR
# pas 2 fois la valeur dossier...
If VALEUR=1
 Call UNICITE(VALEUR,[M]LEV(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
 If nolign > 1 | [M:CLF1]NBLIG > 1
  GMESSAGE = mess(567,199,1) : # Calendrier déjà affecté à un niveau inférieur
  mkstat = 2
 Endif
Endif

If VALEUR <> 1 & [M:CLF1]TYPCLD = 1
 GMESSAGE = mess(221,10709,1) : # Vacances scolaires définies au niveau dossier uniquement
 mkstat = 2
Endif

End

###Population
Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>2 : mkstat=1 : End : Endif
End

###Population
Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
Read[HRPOP]POP0=VALEUR
[M]LIB=[F:HRPOP]DES
Affzo[M]LIB
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=2
 Call UNICITE(VALEUR,[M]POP(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>3 : mkstat=1 : End : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
# pas 2 fois la même valeur société...
If [M]LEV(nolign-1)=3
 Call UNICITE(VALEUR,[M]CPY(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Read[CPY]CPY0=VALEUR
[M]LIB=[F:CPY]CPYNAM
Affzo[M]LIB
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>4 : mkstat=1 : End : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=4
 Call UNICITE(VALEUR,[M]FCY(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Read[FCY]FCY0=VALEUR
[M]LIB=[F:FCY]FCYNAM
Affzo[M]LIB
End

Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>5 : mkstat=1 : End : Endif
End

Subprog C_EMP(VALEUR)
Variable Char    VALEUR()
# pas 2 fois la même valeur salarié...
If [M]LEV(nolign-1)=5
 Call UNICITE(VALEUR,[M]EMP(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
Read[ID]ID0=VALEUR
[M]LIB=[F:ID]NAM-[F:ID]SRN
Affzo[M]LIB
End

Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>6 : mkstat=1 : End : Endif
End

Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
# pas 2 fois la même valeur salarié...
If [M]LEV(nolign-1)=6
 Call UNICITE(VALEUR,[M]CTR(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
#72068
#Read[HRCTR]CTR0=VALEUR
Filter [HRCTR] Where CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#
If !fstat
 Read[ID]ID0=[F:HRCTR]REFNUM
 [M]LIB=[F:ID]NAM-[F:ID]SRN
Else
 Raz [L]LIB
Endif
Affzo[M]LIB
End

Subprog AS_SRV(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>7 : mkstat=1 : End : Endif
End

Subprog C_SRV(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=7
 Call UNICITE(VALEUR,[M]SRV(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_SRV(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]LIB,"SERVICE","DES",VALEUR,"") From ATEXTRA
Affzo[M]LIB
End

###Population
Subprog AS_NBLIG
Case [M]LEV(nolign-1)
 When 1 : Call AM_LEG([M]LEG(nolign-1))
 When 2 : Call AM_POP([M]POP(nolign-1))
 When 3 : Call AM_CPY([M]CPY(nolign-1))
 When 4 : Call AM_FCY([M]FCY(nolign-1))
 When 5 : Call AM_EMP([M]EMP(nolign-1))
 When 6 : Call AM_CTR([M]CTR(nolign-1))
 When 7 : Call AM_SRV([M]SRV(nolign-1))
 When Default : Raz[M]LIB : Affzo[M]LIB
Endcase
End

Subprog AM_NBLIG
Local Shortint I
I = find(1,[M:CLF1]LEV(0..NBLIG))
If I > 0 & I <> nolign
 GMESSAGE = mess(222,10709,1) : # Calendrier déjà affecté à un niveau supérieur
 mkstat = 2
Endif
End

#LIPET - 21-10-2016 - X3PEOP-2999 - START
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Read[FCY]FCY0=VALEUR
[M]LIB=[F:FCY]LEG
Affzo[M]LIB
Gosub STYLE
End
######################################################################################
## Section automatically added (screen CLF1) 10/21/2016 14:04:19 (LIPET)
######################################################################################
Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>1 : mkstat=1 : End : Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=1
 Call UNICITE(VALEUR,[M]FCY(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

#LIPET - 21-10-2016 - X3PEOP-2999 - END

