#<AdxTL>@(#)8.0.0.0 $Revision$
################################################################################################################
# Etape 1 de la définition d'un salon professionnel                       Module CRM          07 novembre 2000 #
################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer ISDIRTY

  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  ISDIRTY = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:OMN0]
  Raz [M:OMN1]
  If GSZOPGNUM = "" Then
    Gosub SETOPGNUM
  Else
    Gosub LOADOPG
  Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:OMN0]
  Raz [M:OMN1]
  Kill ISDIRTY
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCPT(GLONANM)

  SZCPT = ""
  Gosub CHECKDATA From SUBOMNB
  If OK = 0 Then
    FIN = 0
    Return
  Endif
  If GSZOPGNUM = "" Then
    # Récupération du compteur Activité commerciale
    # ----------------------------------------------------------
    # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
    #    If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
    #    Read [TCA]TCA0=13
    #    If fstat Then
    #      GERR = 1
    #      GMESSAGE = mess(64,199,1)
    #    Endif
    #    GMANCOU = [F:TCA]MANCOU(2)
    #    SZCPT = [F:TCA]CODNUM(2)
    Call READ_COUNTER([M:OMN0]FCY, 13, 2, GSOCIETE, GCURLEG, SZCPT, GMANCOU) From CRM_UTIL
    # FGR 20/12/2012 : X3SUIVI71937 (fin)
    # ----------------------------------------------------------
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMN0]FCY, SZCPT, date$, "", [M:OMN0]OMNNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        GSZOPGNUM = [M:OMN0]OMNNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        Return
      Endif
    Else
      GSZOPGNUM = [M:OMN0]OMNNUM
    Endif
  Endif
  #
  [M:OMN1]TYPFULOBJ = "OMN"
  [M:OMN1]NUMFULOBJ = [M:OMN0]OMNNUM
  Call DEBTRANS From GLOCK
  Trbegin [OMN]
  Readlock [OMN]OMN0=[M:OMN0]OMNNUM
  #Il s'agit d'un nouvel enregistrement
  If fstat Then
    [F:OMN]OMNNUM = [M:OMN0]OMNNUM
    [F:OMN]FCY = [M:OMN0]FCY
    [F:OMN]CMGNUM = [M:CMG0]NUM
    [F:OMN]DES = [M:OMN1]DES
    [F:OMN]OBJ = [M:OMN1]OBJ
    [F:OMN]MED = [M:OMN1]MED
    [F:OMN]DTB = [M:OMN1]DTB
    [F:OMN]OMNSTR = [M:OMN1]OMNSTR
    [F:OMN]OMNEND = [M:OMN1]OMNEND
    [F:OMN]BUD = [M:OMN1]BUD
    [F:OMN]CUR = [M:OMN1]CUR
    [F:OMN]CREDAT = date$
    [F:OMN]CREUSR = GUSER
    [F:OMN]UPDDAT = [00/00/00]
    [F:OMN]UPDUSR = ""
    [F:OMN]TYPFULOBJ = [M:OMN1]TYPFULOBJ
    [F:OMN]NUMFULOBJ = [M:OMN1]NUMFULOBJ
    [F:OMN]OBJFLG = [M:OMN1]OBJFLG
    Write [OMN]
    If fstat Then
      #L'enregistrement de la campagne presse a échoué.
      GMESSAGE = mess(889,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMNB
      If GOK < 1 Then
        #L'enregistrement de la campagne presse a échoué.
        GMESSAGE = mess(889,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Else
    # Il s'agit d'une modification
    [F:OMN]OMNNUM = [M:OMN0]OMNNUM
    [F:OMN]FCY = [M:OMN0]FCY
    [F:OMN]CMGNUM = [M:CMG0]NUM
    [F:OMN]DES = [M:OMN1]DES
    [F:OMN]OBJ = [M:OMN1]OBJ
    [F:OMN]MED = [M:OMN1]MED
    [F:OMN]DTB = [M:OMN1]DTB
    [F:OMN]OMNSTR = [M:OMN1]OMNSTR
    [F:OMN]OMNEND = [M:OMN1]OMNEND
    [F:OMN]BUD = [M:OMN1]BUD
    [F:OMN]CUR = [M:OMN1]CUR
    [F:OMN]TYPFULOBJ = [M:OMN1]TYPFULOBJ
    [F:OMN]NUMFULOBJ = [M:OMN1]NUMFULOBJ
    [F:OMN]OBJFLG = [M:OMN1]OBJFLG
    [F:OMN]UPDDAT = date$
    [F:OMN]UPDUSR = GUSER
    Rewrite [OMN]
    If fstat Then
      #L'enregistrement de la campagne presse a échoué.
      GMESSAGE = mess(889,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMNB
      If GOK < 1 Then
        #L'enregistrement de la campagne presse a échoué.
        GMESSAGE = mess(889,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
  ISDIRTY = 0
Return

##########################################################################################################
$SETOPGNUM
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  [M:OMN0]CMGNUM = [M:CMG0]NUM
  [M:OMN0]CMGTTR = [M:CMG0]TTR
  #Définit la devise par défaut.
  [M:OMN0]FCY = [M:CMG0]FCY
  [M:OMN1]CUR = GSYSCUR
  Call DEFVALADI(426, [M:OMN1]MED) From CRMUTIL140
  Call CMGINIDATES([M:OMN0]CMGNUM,[M:OMN1]OMNSTR,[M:OMN1]OMNEND,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN0]1-99
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
$LOADOPG
  Read [OMN]OMN0=GSZOPGNUM
  If fstat Then
    Return
  Endif
  Read [CMG]CMG0=[F:OMN]CMGNUM
  If fstat Then
    [M:OMN0]CMGTTR = ""
  Else
    [M:OMN0]CMGTTR = [F:CMG]TTR
  Endif
  [M:OMN0]CMGNUM = [F:OMN]CMGNUM
  [M:OMN0]OMNNUM = [F:OMN]OMNNUM
  [M:OMN0]FCY = [F:OMN]FCY
  [M:OMN1]DES = [F:OMN]DES
  [M:OMN1]OBJ = [F:OMN]OBJ
  [M:OMN1]MED = [F:OMN]MED
  [M:OMN1]DTB = [F:OMN]DTB
  [M:OMN1]OMNSTR = [F:OMN]OMNSTR
  [M:OMN1]OMNEND = [F:OMN]OMNEND
  [M:OMN1]BUD = [F:OMN]BUD
  [M:OMN1]CUR = [F:OMN]CUR
  [M:OMN1]TYPFULOBJ = [F:OMN]TYPFULOBJ
  [M:OMN1]NUMFULOBJ = [F:OMN]NUMFULOBJ
  [M:OMN1]OBJFLG = [F:OMN]OBJFLG
  Read [HD5]HD50=[F:OMN]NUMFULOBJ;[F:OMN]TYPFULOBJ
  If fstat Then
    Raz [M:OMN1]FULOBJ
  Else
    [M:OMN1]FULOBJ = [F:HD5]CLOB
  Endif
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN0]1-99
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
$CANCELSTEP
  Call DEBTRANS From GLOCK
  Trbegin [OMN]
  Readlock [OMN]OMN0=GSZOPGNUM
  If fstat Then
    Rollback
    Return
  Endif
  Delete [HD5] Where [F:HD5]NUM = [F:OMN]NUMFULOBJ and [F:HD5]TYP = [F:OMN]TYPFULOBJ
  If fstat Then
    Rollback
    Return
  Endif
  Delete [OMN]Curr
  If fstat Then
    Rollback
    Return
  Else
    Commit
  Endif
Return
