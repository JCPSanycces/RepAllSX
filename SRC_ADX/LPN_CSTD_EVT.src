#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe LPN : events


$AINIT
Local Char WSITE(GLONFCY)

this.LPNSTAT = 1
this.ENAFLG = [V]CST_AYES
this.PRTFLG = [V]CST_ANO
#recuperation du site par defaut
[L]ASTATUS = fmet this.ACTX.AGETPRFFCYDEF(this,7,WSITE)
this.STOFCY = WSITE

Return

######################################################################################
$AINSERT_BEFORE
Local Char WSEQ_CODE(25)
Local Char WMESSAGE(250)
Local  Instance WTABCONTAINER Using C_TABCONTAINER

#Lecture de TABCONTAINER pour récupérer le compteur
WTABCONTAINER = NewInstance C_TABCONTAINER AllocGroup null
WRET = fmet WTABCONTAINER.AREAD(this.TCTRNUM)
If WRET <> [V]CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("TABCONTAINER",mess(508,184,1),[V]CST_AERROR)
  FreeGroup WTABCONTAINER
  Return
Endif

If WTABCONTAINER.LPNREFCOU = AVOID.ACHAR & this.LPNNUM = AVOID.ACHAR
  [L]ASTATUS = fmet this.ASETERROR("",mess(552,184,1),[V]CST_AERROR)
  FreeGroup WTABCONTAINER
  Return
Endif
If WTABCONTAINER.LPNREFCOU <> AVOID.ACHAR
  #Appel du numéro
  [L]ASTATUS=func ANM_TOOL.NUMERO(this.ACTX,WTABCONTAINER.LPNREFCOU,this.STOFCY,date$,"",this.LPNNUM,WMESSAGE)
  If [L]ASTATUS>= [V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("LPNNUM", WMESSAGE, [V]CST_AERROR)
    FreeGroup WTABCONTAINER
    Return
  Endif
Endif

FreeGroup WTABCONTAINER

Return

######################################################################################

$AUPDATE_CONTROL_AFTER
Local Integer WSTK
Local Char WMESSAGE (250)
Local File STOCK [STO2]
#est ce que du stock est affecté ?
Filter [F:STO2] Where  [F:STO2]LPNNUM = this.LPNNUM
For [F:STO2]
  WSTK = CST_AYES
  Break
Next

Filter [F:STO2]

If WSTK = CST_AYES
  #monolot peut devenir multi lot
  If (this.snapshot.MONLOTFLG = CST_ANO and this.MONLOTFLG = CST_AYES)
    #erreur on ne peut pas passer de multilot à monolot
    WMESSAGE = mess(505,184,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If (this.snapshot.MONITMFLG = CST_ANO and this.MONITMFLG = CST_AYES)
    #erreur on ne peut pas passer de multiarticle à monoarticle
    WMESSAGE = mess(506,184,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.snapshot.ENAFLG = CST_AYES and this.ENAFLG = CST_ANO
    # erreur, le LPN ne peut pas dcevenir inactif
    WMESSAGE = mess(507,184,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.snapshot.LOC <> this.LOC
    # emplacement, modification impossible
    WMESSAGE = mess(8,144,1) + " - " + mess(9,123,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.snapshot.STOFCY <> this.STOFCY
    # site, modification impossible
    WMESSAGE = mess(3,45,1) + " - " + mess(9,123,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Endif
If this.TCTRNUM <> this.snapshot.TCTRNUM
   # erreur, le type ne peut pas être changé
   WMESSAGE = mess(59,100,1) + " - " + mess(9,123,1)
   [L]ASTATUS = fmet this.ASETERROR ("TCTRNUM", WMESSAGE, [V]CST_AERROR)
   Return
Endif
Return

