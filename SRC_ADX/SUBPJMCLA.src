#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Gestion du masque PJMTXTCLA : from clobs in classic
# Issue X3-74207 - 2018-01-26 by FGR
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "OK"                          : Gosub OK
    When "END"                         : Gosub DO_END
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If PARAM(1) <> "PJMSNP1" and PARAM(1) <> "PJMOPSNP1" Then
    GMESSAGE = mess(186,123,1)
    FIN = 1
    Return
  Endif
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

##########################################################################################################
$DEBUT
Local Char SCODMSK(type(PARAM)-10)     # Screen name
Local Char SABRSCR(type(PARAM)-10)     # Abbreviation screen to manage
Local Integer INUMLIG                  # line number in the grid (nolign-1)
Local Char SAZONE(GLONAVA)             # field to save the clob
Local Char SAFLD2(GLONAVA)             # field to save wath was done on the clob
Local Char SCLE1(GLONVPJ)              # key of the record in PJMCLOB table
Local Integer IACTION

  SCODMSK = PARAM(1)
  SABRSCR = PARAM(2)
  INUMLIG = val(PARAM(3))
  SAZONE = PARAM(4)
  SAFLD2 = PARAM(5)
  SCLE1 = PARAM(6)
  # -----------------------
  Local File PJMCLOB [PJCB]
  # -----------------------
  Gosub SHOW_TEXTS
Return

##########################################################################################################
$OK
  If IACTION = [V]CST_AUPD and [M:PJMA]DESTEX = "" Then
    # Ask to delete the text
    IACTION = [V]CST_ADEL
  Elsif IACTION = [V]CST_ANEW and [M:PJMA]DESTEX = "" Then
    # come on the screen for a not existing text, but created nothing
    IACTION = [V]CST_ALL
  Endif
  Assign "[M:" + SABRSCR + "]" + SAZONE + "(" + num$(INUMLIG) + ")" With [M:PJMA]DESTEX
  Assign "[M:" + SABRSCR + "]" + SAFLD2 + "(" + num$(INUMLIG) + ")" With IACTION
Return

##########################################################################################################
$DO_END
  Raz [M:PJMA]DESTEX
Return

##########################################################################################################
# Subroutines
##########################################################################################################
$SHOW_TEXTS
  If evalue("[M:" + SABRSCR + "]" + SAFLD2 + "(" + num$(INUMLIG) + ")") = [V]CST_ALL Then
    IACTION = [V]CST_ALL
    Read [PJCB]PJCB0=SCODMSK;SAZONE;SCLE1;"";""
    If !fstat Then
      [M:PJMA]DESTEX = [F:PJCB]CLOB
      IACTION = [V]CST_AUPD
    Else
      Raz [M:PJMA]DESTEX
      IACTION = [V]CST_ANEW
    Endif
  Else
    IACTION = evalue("[M:" + SABRSCR + "]" + SAFLD2 + "(" + num$(INUMLIG) + ")")
    [M:PJMA]DESTEX = evalue("[M:" + SABRSCR + "]" + SAZONE + "(" + num$(INUMLIG) + ")")
  Endif
  Affzo [M:PJMA]1-99
Return

##########################################################################################################
Funprog UPDATE_PJMCLOB_TABLE(SSCREN, SFIELD, SKEY, SCLOB, IACTION, SMESSAGE)
Value Char SSCREN
Value Char SFIELD
Value Char SKEY()(1..)
Value Clbfile SCLOB
Value Integer IACTION
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer NI
Local Char SLOCKEY(GLONVPJ)(1..3)

  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # -----------------------------
  Local File PJMCLOB [PJCB]
  # -----------------------------
  Raz SLOCKEY
  For NI = 1 To maxtab(SKEY)
    SLOCKEY(NI) = SKEY(NI)
  Next NI
  # -----------------------------
  Case IACTION
    When [V]CST_ANEW
      Raz [F:PJCB]
      [F:PJCB]CODBLB = SSCREN
      [F:PJCB]IDENT1 = SFIELD
      [F:PJCB]IDENT2 = SLOCKEY(1)
      [F:PJCB]IDENT3 = SLOCKEY(2)
      [F:PJCB]IDENT4 = SLOCKEY(3)
      [F:PJCB]CLOB = SCLOB
      Write [F:PJCB]
      If fstat Then
        SMESSAGE = func AFNC.MES1(mess(1043,2260,1), SLOCKEY(1) - SLOCKEY(2) - SLOCKEY(3))
        IARENDRE = [V]CST_AERROR
      Endif
    When [V]CST_AUPD
      Read [PJCB]PJCB0=SSCREN;SFIELD;SLOCKEY(1);SLOCKEY(2);SLOCKEY(3)
      [F:PJCB]CLOB = SCLOB
      Rewrite [F:PJCB]
      If fstat Then
        SMESSAGE = func AFNC.MES1(mess(1044,2260,1), SLOCKEY(1) - SLOCKEY(2) - SLOCKEY(3))
        IARENDRE = [V]CST_AERROR
      Endif
    When [V]CST_ADEL
      Delete [PJCB]PJCB0=SSCREN;SFIELD;SLOCKEY(1);SLOCKEY(2);SLOCKEY(3)
      If fstat Then
        SMESSAGE = func AFNC.MES1(mess(1045,2260,1), SLOCKEY(1) - SLOCKEY(2) - SLOCKEY(3))
        IARENDRE = [V]CST_AERROR
      Endif
  Endcase
End IARENDRE

##########################################################################################################
Funprog KEY_EXIST(SSCREN, SFIELD, SKEY)
Value Char SSCREN
Value Char SFIELD
Value Char SKEY()(1..)
Value Clbfile SCLOB

Local Integer IARENDRE
Local Char SLOCKEY(GLONVPJ)(1..4)

  IARENDRE = [V]CST_ATRUE
  # -----------------------------
  Local File PJMCLOB [PJCB]
  # -----------------------------
  Raz SLOCKEY
  For NI = 1 To maxtab(SKEY)
    SLOCKEY(NI) = SKEY(NI)
  Next NI
  # -----------------------------
  Look [PJCB]PJCB0=SSCREN;SFIELD;SLOCKEY(1);SLOCKEY(2);SLOCKEY(3)
  If fstat Then
    IARENDRE = [V]CST_AFALSE
  Endif
  # -----------------------------
End IARENDRE

