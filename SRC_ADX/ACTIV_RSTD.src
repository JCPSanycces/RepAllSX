#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation ACTIV


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "ACV"
    Case [L]AEVENT
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ACV.FLGSUP"     : Gosub FLGSUP
  When "ACV.DEP"        : Gosub DEP
  When "ACV.TYP"        : Gosub TYP
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



$AREAD_AFTER
  Gosub FLGSUP_PROPAGATE
  Gosub DEP_PROPAGATE
  Gosub TYP_PROPAGATE
 Return

$FLGSUP
  Case [L]ARULE
    When "PROPAGATE" : Gosub FLGSUP_PROPAGATE
  Endcase
Return

$DEP
  Case [L]ARULE
    When "PROPAGATE" : Gosub DEP_PROPAGATE

  Endcase
Return

$TYP
  Case [L]ARULE
    When "PROPAGATE" : Gosub TYP_PROPAGATE
  Endcase
Return


$FLGSUP_PROPAGATE
  Gosub FLGSUP_PROPERTY
Return

$DEP_PROPAGATE
  Gosub DEP_PROPERTY
  Gosub TYP_PROPAGATE
Return


$TYP_PROPAGATE
  #Enable sizing dimensions if type is Sizing
  If this.TYP = 2
    ASTATUS = fmet this.ASETATTRIBUTE("DIMFIL", "$isDisabled",  "false")
    ASTATUS = fmet this.ASETATTRIBUTE("DIMMAX", "$isDisabled",  "false")

    If this.DEP = 4
      ASTATUS = fmet this.ASETATTRIBUTE("DIME",   "$isDisabled",  "true")
    Else
      If this.DEP = 3 & this.ACTDEP<>""
        Local File ACTIV [ACV]
        # Read dependency activity code
        Read [ACV]CODACT = this.ACTDEP
        If fstat
          [L]ASTATUS=fmet this.ASETERROR("ACTDEP",mess(23,100,1),[V]CST_AERROR)
          Return
        Endif
        If [F:ACV]TYP=2
          # If formula based sizing activity code
          [L]ASTATUS = fmet this.ASETATTRIBUTE("DIME", "$isDisabled",  "true")
        Else
          [L]ASTATUS = fmet this.ASETATTRIBUTE("DIME", "$isDisabled",  "false")
        Endif
      Else
        [L]ASTATUS = fmet this.ASETATTRIBUTE("DIME",   "$isDisabled",  "false")
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETATTRIBUTE("DIMFIL", "$isDisabled",  "true")
    ASTATUS = fmet this.ASETATTRIBUTE("DIMMAX", "$isDisabled",  "true")
    ASTATUS = fmet this.ASETATTRIBUTE("DIME",   "$isDisabled",  "true")
  Endif
Return

##############################################################################################
$FLGSUP_PROPERTY
If dim(this.FLGSUP)>0
 If this.FLGSUP = [V]CST_AYES
   [L]ASTATUS = fmet this.ASETATTRIBUTE("ACTSUP", "$isDisabled",  "true")
 Else
   [L]ASTATUS = fmet this.ASETATTRIBUTE("ACTSUP", "$isDisabled",  "false")
 Endif
Endif
Return

##############################################################################################
$DEP_PROPERTY
Case this.DEP
  When 2,3
    # Reverse or sizing
    ASTATUS = fmet this.ASETATTRIBUTE("ACTDEP", "$isDisabled",  "false")
    ASTATUS = fmet this.ASETATTRIBUTE("ACTFOR", "$isDisabled",  "true")
  When 4
    # formula based
    ASTATUS = fmet this.ASETATTRIBUTE("ACTDEP", "$isDisabled",  "true")
    ASTATUS = fmet this.ASETATTRIBUTE("ACTFOR", "$isDisabled",  "false")
  When Default
    # none (no dependency)
    ASTATUS = fmet this.ASETATTRIBUTE("ACTFOR", "$isDisabled",  "true")
    ASTATUS = fmet this.ASETATTRIBUTE("ACTDEP", "$isDisabled",  "true")
Endcase
Return

