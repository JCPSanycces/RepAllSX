#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet PPP
#** V7 : Waiting Time Mangement **#
#*********************************#

######################################################################################
## Etiquette ajoutée par le superviseur (Objet PPP) 00/00/0000 00:00:00 (WGA)
######################################################################################
Call OBJET("PPP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "SETBOUT"  : Gosub SETBOUT
 When "LIENS"    : Gosub LIENS
Endcase

Return

###################################################################
############ actions standards ####################################
###################################################################
$OUVRE
Local Char WDOSX3(20)
Local File ADOVAL [ADW]
Read [ADW]ADW0 = "";"";"SUPDOS"
WDOSX3 = [F:ADW]VALEUR
If WDOSX3="" : WDOSX3 = "PAIE" : Endif

If !clalev([F:PPO]) : Local File PATCHPDPOBJ [PPO] : Endif
If !clalev([F:RUB]) : Local File RUBRIQUE    [RUB] : Endif
If !clalev([F:VRA]) : Local File VARIA       [VRA] : Endif
If !clalev([F:CUM]) : Local File CUMUL       [CUM] : Endif
If !clalev([F:EXO]) : Local File EXOPAY      [EXO] : Endif
If !clalev([F:DCH]) : Local File DECCHARGE   [DCH] : Endif
#JOJAC - 2016-03-22 - REQ114309 US81 - START
# Issue 113705 - 2016-01-12 by BRBAN : table is under KFR activity code
If func AFNC.ACTIV("KFR")>0
#JOJAC - 2016-03-22 - REQ114309 US81 - END
  If !clalev([F:FTD]) : Local File HRFILTDS      [FTD] : Endif
#JOJAC - 2016-03-22 - REQ114309 US81 - START
Endif
#JOJAC - 2016-03-22 - REQ114309 US81 - END

If !clalev([F:ADV]) : Local File ATABTAB     [ADV] : Endif
If !clalev([F:ADP]) : Local File ADOPAR      [ADP] : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If !clalev([F:TIM]) : Local File TIMCOD      [TIM] : Endif
#*!
If !clalev([F:TIM]) : Local File TIMCOD      [TIM] : Endif
#LIPET - 2017-05-20 - END

Local Shortint I
Local Integer  OKTRT

Return

$SETBOUT
If GADONIX<>2
 Call VIREBOUT(CHAINE,"CDMAH") From GOBJET
Endif
Return

#--------------------------------------------#
#--------------------------------------------#

$LIENS

I=0
For [PPO] Where NUM = [F:HRPPP]NUM
 I+=1
 If I > dim([M:PPP2]OBJ)
  I-=1
  Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 nolign = I
 [M:PPP2]  = [F:PPO]

 # libellé du code de la ligne
 If [F:PPO]OBJ <> ""
  Call LECTURE([F:PPO]OBJ,[F:PPO]COD,"") From CONTOBJ
  If !fstat
   Gosub NOMFIC From = "WO"+[F:PPO]OBJ
   If NOMINT<>""
    [M:PPP2]DES(nolign-1) = evalue("[F:"+[F:PPO]OBJ+"]"+NOMINT)
   Endif
  Endif
 Endif

Next
[M:PPP2]NBLIG = max(I,0)
Gosub NOMFIC From =PROGOBJ
Affzo [M:PPP2]

Return



######################################################################################

