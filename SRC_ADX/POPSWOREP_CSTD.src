#<AdxTL>@(#)0.0.0.0 $Revision$
# Class POPSWOREP


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "CHKDEL" : Gosub CHKDEL
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**----------------------------------------------------------------<br/>
#* CHKDEL : Check if objects sent to PS still exist. If not delete them in PS
#**<br/>----------------------------------------------------------------<br/>
#* @param FCY    = Site
#* @param CURTAB = current table
#* @param CURKEY = current key
#* @param NBREC  = number of records that can be added (-1 = no limit): return number of records that can still be added
#**<br/>----------------------------------------------------------------
#*!
$CHKDEL
Local File POPSOBJ    [PSOBJ]
Local File MFGHEAD    [MFG]
Local File ORDERS     [ORD]
Local File MTOLINK    [MLK]
Local File MFGOPE     [MFO]

Local Integer ILINE
Local Integer ILINE_WL
Local Integer LPOS
Local Char LTYP(type([F:PSOBJ]TYP)-10)
Local Char LID1(type([F:PSOBJ]IDENT1)-10)
Local Char LID2(type([F:PSOBJ]IDENT2)-10)
Local Integer LTRANSOPEN : LTRANSOPEN=0

Local Char    PARENT_ITM(GLONITF), CHILD_ITM(GLONITF)
Local Char    DEMNUM(GLONVCR), RESSNUM(GLONVCR)
Local Integer DEMLIN, RESSLIN
Local Integer DEMSEQ, RESSSEQ
Local Integer PARENT_OP, PARENT_SPL, CHILD_OP, CHILD_SPL
Local Integer OK

If [L]CURTAB = "" | [L]CURTAB = "POPSOBJ-WO"

    If adxlog=0
        Trbegin [PSOBJ]
        LTRANSOPEN=1
    Endif

    If [L]CURKEY<>""
        # X3-88941 - STWIL - left$ needs the length of the string before the
        # :, so we need to subtract 1
        LPOS = instr(1, [L]CURKEY, ":")
        LTYP = left$([L]CURKEY, LPOS - 1)
        [L]CURKEY = right$([L]CURKEY,LPOS + 1)
        LPOS = instr(1, [L]CURKEY, ":")
        LID1 = left$([L]CURKEY, LPOS - 1)
        LID2 = right$([L]CURKEY,LPOS + 1)
        CURKEY=""
        CURTAB=""
    Else
        Raz LTYP, LID1, LID2
    Endif

    Filter [PSOBJ] Where [PSOBJ]FCY=[L]FCY
&                      & find([PSOBJ]TYP,"MFG","WOS","MLK")<>0

    For [PSOBJ]PSOBJ0 From [L]FCY;LTYP;LID1;LID2 To [L]FCY;"~"
        If NBREC=0  # If NBREC<0, there is no limit
            [L]CURKEY = [F:PSOBJ]TYP+":"+[F:PSOBJ]IDENT1+":"+[F:PSOBJ]IDENT2
            [L]CURTAB = "POPSOBJ-WO"
            Break
        Endif
        LDEL=0
        Case [F:PSOBJ]TYP
            When "MFG" : # check if the work order MFG still exists
                        Filter [MFG] Where MFGNUM = [F:PSOBJ]IDENT1
&                                        & MFGSTA <> 4
&                                        & (OPTFLG = 2 | SCDFLG = 4)
                        Look [MFG]MFG0 First
                        Filter [MFG]
            When "WOS" : # check if the work order suggested in table ORDERS still exists
                        Filter [ORD] Where WIPTYP = 5
&                                        & WIPNUM = [F:PSOBJ]IDENT1
&                                        & ITMREF = [F:PSOBJ]IDENT2
&                                        & OPTFLG = 2
&                                        & WIPSTA = 3
                        Look [ORD]ORD0 First
                        Filter [ORD]
            # Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
            When "MLK" : # check if assignment exists and parent an child WO are still in PS
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_MTOLINK_KEY([F:PSOBJ]IDENT1 , [L]DEMNUM, [L]DEMLIN, [L]DEMSEQ) #, [L]ITMREF)
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_MTOLINK_KEY([F:PSOBJ]IDENT2 , [L]RESSNUM, [L]RESSLIN, [L]RESSSEQ) #, [L]ITMREF)
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_OP_KEY_ALL([F:PSOBJ]INF1, [L]DEMNUM, [L]PARENT_ITM, [L]PARENT_OP, [L]PARENT_SPL)
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_OP_KEY_ALL([F:PSOBJ]INF2, [L]RESSNUM, [L]CHILD_ITM, [L]CHILD_OP, [L]CHILD_SPL)

                        # look for record in MTOLINK
                        Filter [MLK] Where STOFCY = [F:PSOBJ]FCY
&                                        & ITMREF = [L]CHILD_ITM
&                                        & DEMTYP = 10
&                                        & DEMNUM = [L]DEMNUM
&                                        & DEMLIN = [L]DEMLIN
&                                        & DEMSEQ = [L]DEMSEQ
&                                        & RESSTYP = 10
&                                        & RESSNUM = [L]RESSNUM
&                                        & RESSLIN = [L]RESSLIN
&                                        & RESSSEQ = [L]RESSSEQ
                        Look [MLK]MLK0 First
                        If fstat = 0
                            # if MTO link exists, check if parent and child WO are still in PS
                            # check parent WO
                            Filter [MFG] Where MFGNUM = [L]DEMNUM
&                                            & MFGSTA <> 4
&                                            & (OPTFLG = 2 | SCDFLG = 4)
                            Look [MFG]MFG0 First
                            Filter [MFG]
                            # if parent WO is in PS --> check child WO
                            If fstat = 0
                                Filter [MFG] Where MFGNUM = [L]RESSNUM
&                                                & MFGSTA <> 4
&                                                & (OPTFLG = 2 | SCDFLG = 4)
                                Look [MFG]MFG0 First
                                # if also child WO is in PS --> check if linked OP from parent is still included in WO
                                If fstat = 0
                                    Filter [MFO] Where MFGNUM = [L]DEMNUM
&                                                    & OPENUM = [L]PARENT_OP
&                                                    & OPESPLNUM = [L]PARENT_SPL
&                                                    & OPESTA <> 6
                                    Look [MFO]MFO0 First
                                    # if all true --> chek if linked OP from child OP is still included in WO
                                    If fstat = 0
                                        Filter [MFO] Where MFGNUM = [L]RESSNUM
&                                                        & OPENUM = [L]CHILD_OP
&                                                        & OPESPLNUM = [L]CHILD_SPL
&                                                        & OPESTA <> 6
                                        Look [MFO]MFO0 First
                                    Endif
                                Endif
                                Filter [MFO]
                            Endif
                            Filter [MFG]
                        Endif
                        Filter [MLK]
                        # End issue X3-44547
        Endcase
        # If it doesn't exist => create a deletion instance in the collection WRKORDS, WOLNKS
        #         + delete the record in PSOBJ
        If fstat & ([F:PSOBJ]TYP = "MFG" | [F:PSOBJ]TYP = "WOS")
            # The record doesn't exist anymore => deletion
            [L]ILINE = fmet this.ADDLINE("WRKORDS", [V]CST_ALASTPOS)
            If [L]ILINE <> [V]CST_ANOTDEFINED
                # X3-22333 - STWIL - Need to add ITMREF as we now used this as the key sent to Production Scheduler
                this.WRKORDS([L]ILINE).MFGNUM = func POPSENV_CSTD.FORMAT_WO_KEY ([F:PSOBJ]IDENT1, [F:PSOBJ]IDENT2)
                this.WRKORDS([L]ILINE).DELETED = 1
                LDEL=1
            Endif
        # Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
        Elsif fstat & ([F:PSOBJ]TYP = "MLK")
            # The record doesn't exist anymore => deletion
            [L]ILINE_WL = fmet this.ADDLINE("WOLNKS", [V]CST_ALASTPOS)
            If [L]ILINE_WL <> [V]CST_ANOTDEFINED
                this.WOLNKS(ILINE_WL).PRVWOID = func POPSENV_CSTD.FORMAT_WO_KEY([L]RESSNUM, [L]CHILD_ITM)
                this.WOLNKS(ILINE_WL).PRVOPID = [F:PSOBJ]INF2
                this.WOLNKS(ILINE_WL).NXTWOID = func POPSENV_CSTD.FORMAT_WO_KEY([L]DEMNUM, [L]PARENT_ITM)
                this.WOLNKS(ILINE_WL).NXTOPID = [F:PSOBJ]INF1
                this.WOLNKS(ILINE_WL).DELETED = 1
                # Always set to blank (simple successor)
                this.WOLNKS(ILINE_WL).LNKTYP = ""
                LDEL=1
            Endif
        # End issue X3-44547
        Endif
        If LDEL # delete the record in PSOBJ
            Delete [PSOBJ] Curr
            If fstat
                Call FSTA("PSOBJ",this,[L]ARET_VALUE) From ASYRSUB
                Break
            Endif
            NBREC-=1
        Endif
    Next
    Filter [PSOBJ]
    If LTRANSOPEN
        If [L]ARET_VALUE=[V]CST_AOK
            Commit
        Else
            Rollback
        Endif
    Endif
Endif

Return

