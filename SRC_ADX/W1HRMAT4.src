#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:42"
A_USER  = "DOC"
A_STAMP = "20181109230442"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRHAB"
  If [M]NBRHAB=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT4 [EMP4]
Gosub HORODAT
Local Inpbox "HRMAT4" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP4] As [SIM_]
Grizo [EMP4]45
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=23
Return

$ON_NBRHAB
Onevent CONTROL Call C_NBRHAB From W1HRMAT4
Onevent AFTER_LINE Call APRES_NBRHAB From W1HRMAT4
Return

Subprog C_NBRHAB
Local Decimal BASPAG
## Action STD
Call C_NBRHAB From SUBEML2
If mkstat : GERR = 1 : GZONE = "NBRHAB" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog APRES_NBRHAB
Local Decimal BASPAG
## Action STD
Call APRES_NBRHAB From SUBEML2
If mkstat : End : Endif
Gosub _AFF
End

$ON_PJ
Onevent BEFORE_INPUT Call AS_PJ(zc) From W1HRMAT4
Return

Subprog AS_PJ(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
## Action STD
Call AS_PJ(VALEUR) From SUBEML2
If mkstat=2
 [M]PJ(INDIC) = VALEUR
 Affzo PJ(INDIC) : mkstat = 2
Endif
Onkey 178 Titled GBOUTI Call CL_PJ(zc) From W1HRMAT4
Gosub _AFF
End

Subprog CL_PJ(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_PJ(VALEUR) From SUBEML2
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CAT
Onevent AFTER_CHANGE Gosub AMM_CAT From W1HRMAT4
Onevent INIT_AREA Call D_CAT(zc) From W1HRMAT4
Onevent BEFORE_INPUT Call AS_CAT(zc) From W1HRMAT4
Return

Subprog D_CAT(VALEUR)
Variable Integer VALEUR
If varinit([M]CAT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CAT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_CAT
Call AM_CAT(zc)
If !mkstat & GOBJET
 zoncou = "CAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CAT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CAT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "CAT" : GZNUM = 707 : Endif
Gosub _AFF
End

$ON_HAB
Onevent BEFORE_INPUT Call AS_HAB(zc) From W1HRMAT4
Onevent CONTROL Call C_HAB(zc) From W1HRMAT4
Onevent AFTER_CHANGE Gosub AMM_HAB From W1HRMAT4
Return

Subprog AS_HAB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47613,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRLIC
Call DEFHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
If mkstat=2
 [M]HAB(INDIC) = VALEUR
 Affzo HAB(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_HAB(zc) From W1HRMAT4
Onkey   2 Titled GBOUTS Call S_HAB(zc) From W1HRMAT4
Onkey 144 Titled GBOUTP Call P_HAB(zc) From W1HRMAT4
Onkey 146 Titled GBOUTA Call SA_HAB(zc) From W1HRMAT4
Gosub _AFF
End

Subprog C_HAB(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
If !mkstat
 ## Action CONTHRLIC
 Call CONTHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
 If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_HAB
Call AM_HAB(zc)
If !mkstat & GOBJET
 zoncou = "HAB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HAB(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZHAB)")>indice
 [M]HAB(indice) = VALEUR
 Affzo ZHAB(indice)
Endif
Gosub _AFF
End

Subprog S_HAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRLIC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRLIC"
 PARMSK(1) = [V]GCURLEG
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRLIC","SUBHRLIC","SPEHRLIC") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_HAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRLIC
 Call TUNHRLIC(VALEUR,[V]GCURLEG,"") From SUBHRLIC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_HAB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRLIC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HAB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRLIC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZHAB
Onevent BEFORE_AREA Gosub AV_ZHAB From W1HRMAT4
Return

$AV_ZHAB
Call LECTEXTRA(zc,"HRLICAUT","DESAXX",num$([M]HAB(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PMTTYP
Onevent INIT_AREA Call D_PMTTYP(zc) From W1HRMAT4
Onevent BEFORE_INPUT Call AS_PMTTYP(zc) From W1HRMAT4
Return

Subprog D_PMTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]PMTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PMTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_HABSTR
Onevent BEFORE_AREA Gosub AV_HABSTR From W1HRMAT4
Return

$AV_HABSTR
Chgfmt [M]HABSTR(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

$ON_HABEND
Onevent BEFORE_INPUT Call AS_HABEND(zc) From W1HRMAT4
Onevent CONTROL Call C_HABEND(zc) From W1HRMAT4
Onevent BEFORE_AREA Gosub AV_HABEND From W1HRMAT4
Return

$AV_HABEND
Chgfmt [M]HABEND(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_HABEND(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_HABEND(VALEUR) From SUBEML2
If mkstat=2
 [M]HABEND(INDIC) = VALEUR
 Affzo HABEND(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_HABEND(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]HABSTR(nolign-1)) From EXEFNC
If mkstat : GERR = 1 : GZONE = "HABEND" : GZNUM = 5463 : Endif
Gosub _AFF
End

$ON_HABFLG
Onevent INIT_AREA Call D_HABFLG(zc) From W1HRMAT4
Onevent BEFORE_INPUT Call AS_HABFLG(zc) From W1HRMAT4
Return

Subprog D_HABFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]HABFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_HABFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ETRPITDAT
Onevent BEFORE_AREA Gosub AV_ETRPITDAT From W1HRMAT4
Return

$AV_ETRPITDAT
Chgfmt [M]ETRPITDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_ETRPITEXPDAT
Onevent BEFORE_AREA Gosub AV_ETRPITEXPDAT From W1HRMAT4
Return

$AV_ETRPITEXPDAT
Chgfmt [M]ETRPITEXPDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
