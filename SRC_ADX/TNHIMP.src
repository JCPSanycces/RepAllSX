#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AP_IMPORT" : Gosub AP_IMPORT
Endcase
Return

$AP_IMPORT
Local Integer STAT

Case IMPFIC
  When "TNH"
    Call LEC_TTN_LEG([F:FCY]LEG, [F:TNH]TNHTYP,STAT) From TRTLECLEG
    If [F:TTN]RECTYP<>4
      OK = 0
      Call ECR_TRACE('',1) From GESECRAN
    Endif
  When Default
Endcase
Return
