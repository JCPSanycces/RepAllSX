#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe FREFLD

###############
# METHODS
###############

$EVENTS
  Case AEVENT
      When "AREAD_AFTER"  : Gosub AREAD_AFTER
  Endcase
Return

$METHODS
Return

$PROPERTIES
Case [L]CURPRO
    When "ALPREF"       : Gosub ALPREF
Endcase
Return

$ALPREF
  Case ACTION
    When"PROPAGATE"  : Gosub LOAD_INTITADI
  Endcase
Return


$AREAD_AFTER
  Case CURPTH
      When "" : Gosub AREAD_AFTER_FREFLD
      When "XXX"
         Case [L]ACTION
             When "AREAD_AFTER" : Gosub AREAD_AFTER_FREFLD
         Endcase
  Endcase
Return

$LOAD_INTITADI
  Local Char XDES(30), XALPDES(30)

## loading ADI table designation
  Local Integer I_TDIV : I_TDIV = 1
     If this.ALPREF <>  AVOID.AINT
        Call LECTEXTRA(XDES,"ATABDIV","LNGDES",num$(this.ALPREF),"") From FREFLD_C_MPR
        If XDES <> AVOID_ACHAR
           this.INTITADI = XDES
        Endif
     Endif

Return


$AREAD_AFTER_FREFLD

Return

