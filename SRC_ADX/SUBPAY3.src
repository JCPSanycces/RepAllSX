#### Annulation
$VERF_ANU
If [F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2 | [F:PYH]STAFLG(8)=2
 GMESSAGE=mess(54,117,1) : OK=0 : # Règlement comptabilisé
Elsif [F:PYH]STA>=11
 GMESSAGE=mess(125,117,1) : OK=0 : # Règlement impayé
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:PYH]UMRNUM<>""

 If clalev([F:HMDT])  = 0 : Local File HISTOMDT  [HMDT]  : Endif
 If clalev([F:ADI])   = 0 : Local File ATABDIV   [ADI]   : Endif

 Local Char SEQFIRST, SEQFINAL, SEQACTUAL
 SEQACTUAL = right$([F:PYH]UMRSEQ,3)
 Call LEC_ADI_330(2,SEQFIRST) From PAYSDDLIB
 Call LEC_ADI_330(1,SEQFINAL) From PAYSDDLIB
 OK=1

 Link [HMDT] With [ADI] CODE = 330;[F:HMDT]SEQTYP
& As [LNK]
& Where [F:HMDT]CPY=[F:PYH]CPY &  [F:HMDT]UMRNUM=[F:PYH]UMRNUM

 If [L]SEQACTUAL=[L]SEQFIRST & rowcount([F:LNK])>1
  GMESSAGE=mess(296,117,1) : OK=0
 Elsif [L]SEQACTUAL=[L]SEQFINAL
  GMESSAGE=mess(297,117,1) : OK=0
 Else
  For [LNK]
   If [F:ADI]A1=[L]SEQFINAL
    GMESSAGE=mess(298,117,1)-[F:HMDT]PAYNUM : OK=0 : Break
   Endif
  Next
 Endif
 Filter [HMDT]
 If OK=0
  OK=2 : Call AVERTIR(mess(123,105,1)-"\"-GMESSAGE,OK) From GESECRAN : Raz GMESSAGE
  If OK<>2 : OK=0 :Else OK=1 : Endif
 Endif
Endif
Return

$AV_ANNULE
Local Libelle FLGLOT
FLGLOT = 0
Local Char LOTPYL(GLONVCR)
Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
If !fstat
 FLGLOT = ([F:TPY]DACPYL=2)   :# est-ce qu'on gère les lots de saisie
 Read [PYH]PYH0 = [L]CODE
 If fstat
  GOK=0 : Call RSTA("PYH",[L]CODE) From GLOCK : Return
 Endif
 [L]LOTPYL=[F:PYH]PAYLOT
Endif
Call AV_ANNULE2([L]CODE,FLGLOT)

