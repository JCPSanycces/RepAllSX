$FERME
GTUNCPT(8) = 0
# Evite les pbs d'affichage où les masques sont reparamétrés sur un autre poste
For I=1 To NBMASK
 Case I
  When 1 : If clalev([M:PAY1])>0 : Close Local Mask [PAY1] : Endif
  When 2 : If clalev([M:PAY2])>0 : Close Local Mask [PAY2] : Endif
 Endcase
Next I
GFONC1 = SVG_GFONC1
OK = 0
# Adaptation Multi-legislation on transaction
If dim(GFLAGLEG)>0 : Kill GFLAGLEG : Endif
If dim(GLEGPAY)>0
 Kill GNBLEGPAY,GLEGPAY
Endif
If dim(GFLEDI)>0
 Kill GFLEDI,GFLEDIEUR
Endif
If dim(SAV_GCURLEG)>0 : GCURLEG  = SAV_GCURLEG : Endif
If dim(SAV_GCURFCY)>0 : GCURFCY  = SAV_GCURFCY : Endif
If dim(SAV_GCURCPY)>0 : GSOCIETE = SAV_GCURCPY : Endif
If dim(SAV_GGRPFCY)>0 : GGRPFCY  = SAV_GGRPFCY : Endif

# Localization Switzerland, 2015-06-24 Bader
Local Integer SOK
Call EXISTE_ADX("","","SUBPAY3SWI",SOK) From ORDSYS
If SOK : Gosub FERME From SUBPAY3SWI : Endif
# End Localization Switzerland
Return

$FIN
#ISSUE 35549 – 2017-07-19  By MANOW
