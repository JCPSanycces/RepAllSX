Return

$DEFMSKLIG
Local Integer II
If dim([L]NBMASK)<0
 Local Integer NBMASK
 NBMASK=2
Endif
For II=1 To NBMASK
 Case II
  When 1 : If dim([M:PAY1]NBLIG)>0 : Default Mask [PAY1] : Endif
  When 2 : If dim([M:PAY2]NBLIG)>0 : Default Mask [PAY2] : Endif
 Endcase
Next I
Return

$LIENS
Local Integer IREF,IMOD,NBLED
[M]CURBAN=""
If [M]BAN<>""
 Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
 If fstat=0 : [M]CURBAN=[F:BAN]CUR : Endif
Endif
[M]CURCPY=""
Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
If dim([M:BIS1]NBRCCE)>0 : [M:BIS1]NBRCCE = GNBAXE : Endif
Call PARAM([F:PYH]FCY,"SEVBPRENT",OPT) From ADOVAL : [M]BPROPT=val(OPT) : # OD inter-tiers
Call PARAM([F:PYH]FCY,"SEVFCYENT",OPT) From ADOVAL : [M]FCYOPT=val(OPT) : # OD inter-sites
Call PARAM([F:PYH]FCY,"PRCAMTCNV",OPT) From ADOVAL : [M]PRCAMTCNV=val(OPT)
Call PARAM([F:FCY]LEGCPY,"SOICPT",OPT) From ADOVAL : [M]SOICPT=val(OPT)
Gosub INIMSK
Gosub DEFMSKLIG
Call PARAM([M]CPY,"BPCORDTYP",[L]BPCTYP) From ADOVAL : # CCL
Call PARAM([M]CPY,"BPSORDTYP",[L]BPSTYP) From ADOVAL : # CCF
If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Call PARAM([M]CPY,"BPSPROTYP",[L]PROTYP) From ADOVAL : # PRO
Endif   # Issue X3-107197
[M]BPCTYP=[L]BPCTYP
[M]BPSTYP=[L]BPSTYP
If dim([M]PROTYP)>0 : [M]PROTYP=[L]PROTYP : Endif
Call GETSOC([M]FCY) From DEVSUB
Call PARAM(GSOCIETE,"DEPMGTMOD",DEPMOD) From ADOVAL
GDEPMGTMOD=val(DEPMOD)
If dim(GSDDMGT)>0
 Call PARAM([M]CPY,"SDDMGT",OPT) From ADOVAL
 GSDDMGT=val(OPT)
Endif
Call LECLED(GSOCIETE,GTYPGEN,CODLED,[M]CURCPY) From CPTDIV
Raz [M]LSTLED, [M]LSTACC, [M]LSTAXE
Call SETGCM([M]CPY,MODELE) From CPTDIV
Call SETPLAN2(MODELE,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
[M]COA = GPLAN(1)
For AXE=1 To GNBAXE
 [M]DIE(AXE-1) = GAXE(AXE)
Next
GNBTYPLED = GNBPLAN

# Find the list of ledgers codes and used later on SETCHPLST2
IMOD= find(MODELE,GGCM(1..GGCMNBR))
If !IMOD
 Call GLOBVAR From SETGLBGCM
 IMOD   = find(MODELE,GGCM(1..GGCMNBR))
Endif
If IMOD
For IREF=1 To len(mess(0,2644,1))
  REF = evalue("GLED"+num$(IREF)+"("+num$(IMOD)+")")
  If REF<>"" & !find(REF,LEDCOD(1..NBLED))
   NBLED+=1
   LEDCOD(NBLED) = REF
  Endif
 Next
Endif
Raz LLED
For K=1 To NBLED
 LLED(K)= LEDCOD(K)
Next

Raz [M:VTL], [M:VT2]
LIGANA = 0
Call AFFCOL
Gosub SETCHPAXE
K=0 : NOL=-1
For [PYD]PYD0 Where NUM=[M]NUM
 NOL+=1
 nolign=NOL+1 : [M]=[F:PYD]
 [M]ACC = [F:PYH]ACC : # Car le transclasse [M]=[F:PYD] écrase le compte d'en-tête....
 [M]COA = GPLAN(1)
 Case [M]IPTTYP(NOL)
  When 1 : [M]VCRTYP(NOL)=[L]BPCTYP
  When 2 : [M]VCRTYP(NOL)=[L]BPSTYP
  When 4 : [M]VCRTYP(NOL)=[L]PROTYP
 Endcase
 For NLED=1 To GNBTYPLED
  Assign "[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")" With [F:PYD]ACC(GTYPLED(NLED)-1)
 Next

 Gosub SETCHPLST2 From SUBPAY3

 [M]CURLIN2(NOL)=[F:PYD]CURLIN
 [M]REGAMT2(NOL)=[F:PYD]AMTLIN2
 If dim([M]RITAMT)>0 : [M]REGAMT2(NOL)-=[F:PYD]RITAMT2 : Endif

 Gosub RECH_ACCANA

 If CPTANA<>""
  Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
  If [F:GAC]FLGUOM=2 : [M]UOM(NOL)=[F:GAC]UOM : Endif
 Endif

 # PRD05
 Raz [M]DISDAT(NOL)
 Read [DUD]DUD1 = [M]DUDNUM(NOL);[M]DUDLIG(NOL)
 If !fstat
  If [F:DUD]DEP <> '' # Issue X3-29143
    [M]DISDAT(NOL) = func PAYDEPLIB3.SETDISDAT([M:PAY1]ACCDAT)
  Endif # Issue X3-29143
  Affzo [M]DISDAT(NOL)
 Endif
 # PRD05

 # To initialize all the sections to empty and in order to avoid the call of D_CCEn by the supervisor
 # these calls are not necessary when you display an existing record.
 For AXE=1 To 20
  Assign "[M]CCE"+num$(AXE)+"("+num$(NOL)+")" With ""
 Next AXE

 If [F:PYD]DSP=""
  OK=0
  For [PYA]PYA0 Where NUM=[M]NUM & LIN=NOL+1
   LIGANA+=1 :
   If OK=0 : OK=LIGANA: Endif
   [M:VT2]TBAMT(LIGANA)=[F:PYA]AMTANA
   [M:VT2]TBQTY(LIGANA)=[F:PYA]QTYANA
   For AXE=1 To GNBAXE
    INDAXE = find(GAXE(AXE),[F:PYA]DIE(0..dim([F:PYA]DIE)-1))
    If INDAXE
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:PYA]CCE(INDAXE-1)
    Endif
   Next AXE
  Next : # [PYA]
  If OK
   If OK=LIGANA
    For I=1 To GNBAXE
     Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")")
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")" With ""
    Next I
    LIGANA -= 1
   Else
    [M]PTV(NOL)=OK
    [M]PTF(NOL)=LIGANA
    [M]DSP(NOL)="$"
    For I=1 To GNBAXE : # Pour initialiser les champs sections
     Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With ""
    Next I
   Endif
  Endif
 Endif
Next : # [PYD]
[M:VT2]PTVENT = LIGANA+1
[M]NBLIG=NOL+1
#--- Rafraichissement du tiroir Echeances
Gosub RAF_ECHE From SUBPAY4
#--- Rafraichissement de l'onglet Lot de saisie
If FLGLOT
 [L]LSTLOT = [F:PYH]PAYLOT
 [L]VALC1=[F:PYH]PAYLOT : Gosub CHARG_LOT From SUBPAY5
Endif
#--- Paramètre de saisie analytique
If dim([M]TOTIMPUT)>0
 [M]TOTIMPUT = sum([M]AMTLIN2)
 [M]DEVISE = [M]CUR
Endif
If dim([M]RSTIMPUT)>0
 [M]RSTIMPUT = [M]AMTCUR-[M]TOTIMPUT
Endif
If dim([M]TOTBQE)>0
 [M]TOTBQE = abs([F:PYH]BANPAYTPY)
 Affzo [M]TOTBQE
Endif

# #YYFIN_X3-4142/MDJ
If dim([M]SOLDE)>0
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,[M]ACC,[M]BPR,[M]FCY,[M]CUR,[M]ACCDAT,RSOLDE) From SUBPAY
 If dim([M:PAY2]SOLDE)>0
  [M:PAY2]SOLDE=RSOLDE : Affzo  [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo  [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

If [F:PYH]FRMNUM<>"" : Readlock [PYH]PYH0 = [F:PYH]NUM : Endif

If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_LIENS From CHKLIB
Endif

# Gestion des éditions
Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
If !fstat : [L]ADI304 = [F:TED]TRT Else [L]ADI304="" : Endif
Filter [ARX] # cf CHKLIB
If [L]ADI304<>""
 Read [ARX]ARX0(1) ="PAY"+[L]ADI304
 If fstat=0 : GFLEDI=1 : Endif
 Read [ARX]ARX0(1) ="PAY"+[L]ADI304+"EUR"
 If fstat=0 : GFLEDIEUR=1 : Endif
Else
 GFLEDI = 0
 GFLEDIEUR = 0
Endif

# SAM 81743: Deactivate [M:PAY1]BAN if progressive balance control
# is active in transaction and bank (mono entry)
# Load progressive balance control values after clicking cancel
Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
#If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif   #92953.o
#Call PARAM([F:TPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL #92953.o
Call PARAM([F:PYH]FCY,"PROBALCTL",P_PROBALCTL) From ADOVAL  #92953.n
If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
Read [BAN]BAN0 = [M:PAY1]BAN
If P_PROBALCTL = '2' and [F:TPY]LOTPROBALCTL = 2
& and [M:PAY0]PAYLOT <> '' and [BAN]BNKPROBALCTL = 2
  Grizo [M:PAY1]BAN
  Read [PYL]PYL0 = [M:PAY0]PAYLOT
  # load progressive balance control values
  If !fstat
    [M:PAY4]STRBAL = [F:PYL]STRBAL
    [M:PAY4]ENDBAL = [F:PYL]ENDBAL
    [M:PAY4]PROBAL = [F:PYL]PROBAL
    [M:PAY4]PRODIF = [F:PYL]PRODIF
  Endif
# ISSUE 39256 - 2017-09-08 MRDAB - Enter payments from BCREG
Elsif FROM_GESBCREG
  Diszo [M:PAY1]BAN
  Diszo [M:PAY1]FCY
# ISSUE END
Else
  Actzo [M:PAY1]BAN
Endif
Affzo [M:PAY1]BAN

Call BPRTYP([F:PYH]BPR,[L]BPRTYPBIS) From SUBAFR
If [L]BPRTYPBIS : [M]BPRNAM=[F:PYH]BPANAM : Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[F:PYH]CPY) = "2"
  If [F:PYH]CSHVATRGM=2 & ([F:PYH]VATSTA=3 | [F:PYH]STA=11)
    Grizo [M:PAY1]
    If clalev([M:PAY2]) : Grizo [M:PAY2] : Endif
    If clalev([M:PAY3]) : Grizo [M:PAY3] : Endif
  Else
    Actzo [M:PAY1] : Affzo [M:PAY1]
    If clalev([M:PAY2]) : Actzo [M:PAY2] : Affzo [M:PAY2] : Endif
    If clalev([M:PAY3]) : Actzo [M:PAY3] : Affzo [M:PAY3] : Endif
  Endif
Endif
#94635 RICAR 2014/04/21 - CASH VAT - END

# Localization Switzerland, 2015-06-24 Bader
Local Integer SOK
Call EXISTE_ADX("","","SUBPAY3SWI",SOK) From ORDSYS
If SOK : Gosub LIENS From SUBPAY3SWI : Endif
# End Localization Switzerland

# ISSUE 39256 - 2017-08-30 MRDAB - Enter payments from BCREG
Gosub GESBCREG_DISPLAY
# ISSUE END

# Issue X3-61594
Gosub SET_GFCY
# End issue X3-61594

# Issue X3-75998 by MRDAB
Gosub ACCDAT_AVAILABILITY
# Issue end

Return

$FILTRE
If GFONC1<>""
 FILTSUP="[F:PYH]PAYTYP='"+GFONC1+"'"

 #ENG: If the transaction selected has a legislation, then we can't display
 #     company payment with another legislation.
 #FRA: Si la transaction courante présente une législation, on ne doit pas afficher
 #     les règlements sur des sociétés de législations différentes
 #-----

 # US230 - La transaction de Règlement a une législation vide.
 # Si le code transaction est unique
 #     => X3 doit afficher tous les règlements
 # Si le code transaction n'est pas unique (c'est à dire, il existe pour un même code transaction, des enregistrements avec des législations)
 #     => X3 doit afficher les règlements liées à aucune des législations des autres transactions pour ce même code.
 If dim(GFLAGLEG)>0
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  If GFLAGLEG<>""
   FILTSUP-= "& [F:CPY]LEG='"+GFLAGLEG+"'"
  Else
   Filter [TPY2] Where PAYTYP=GFONC1 & LEG<>""
   If rowcount([TPY2])>=1
    Global Char GLEGPAY(GLONADI)(0..rowcount([TPY2]))
    Global Integer GNBLEGPAY : GNBLEGPAY=0
    For [TPY2]
     GLEGPAY(GNBLEGPAY) = [F:TPY2]LEG
     GNBLEGPAY+=1
    Next
    FILTSUP-= "& find([F:CPY]LEG,GLEGPAY(0..GNBLEGPAY-1))=0"
   Endif
   Filter [TPY2]
  Endif
 Endif
Endif

#ISSUE 35549 – 2017-07-26  By MANOW
If ((GFONCTION1 = 'GESBCREG') & (func AFNC.ACTIV("REGBC")))
  FILTSUP-= "& [F:PYH]REGNUM = '"+[M:BCREG0]REGNUM+"'"
Endif
#ISSUE end
Return

$SETBOUT
Raz OK
Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
If CLECUR & REP=""
 If [M]STA<3 & [F:TPY]STA3=2 & ([F:TPY]STA2<>2 | [M]STA>=2)
  OK=1
 Elsif [M]STA<9 & [F:TPY]STA9=2 & [F:PYH]BAN<>""
&    & [F:PYH]FRMNUM="" & [F:TPY]STA5<>2 & [F:TPY]STA7<>2
&    & ([F:TPY]STA3<>2 | [M]STA>=3)
&    & ([F:TPY]STA2<>2 | [M]STA>=2)
  OK=1
  If [F:PYH]SNS=1 & [F:TPY]EDTFLG=2 &
&     (([L]ADI304="CHE" & [F:PYH]CHQNUM="") | ([L]ADI304="TRE" & [F:PYH]EDTNUM=0))
   OK=0
  Endif
 Endif
Endif

If !OK or GCONSULT or !instr(1,[L]AUZFCY,"V") or ![L]ACCFCY
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
If REP<>"" or !CLECUR
 Call VIREBOUT(CHAINE,"U") From GOBJET
Endif
# On ne peut pas annuler un règlement comptabilisé ou impayé (STA=11)
If [M]STA>=11 | [F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2 | [F:PYH]STAFLG(8)=2
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif

# Issue X3-103268
#If func AFNC.PARAM("ARGDSC",[F:PYH]CPY)="2" : # Gestion esc/agio Argentine
If func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGDSC",[F:PYH]CPY)="2" : # Gestion esc/agio Argentine
 ## On dégrise le bouton <Esc/agio> s'il existe au moins une destination Cpt/tiers de type esc/agio pour laquelle
 ## la facture/ND/NC n'a pas été générée
 Local Integer OKDEP
 OKDEP = 0
 For [PYD]PYD0 Where NUM = [F:PYH]NUM & ACCTYP = 3 & NUMDEP = ""
   Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
  If [F:CDA]IPTDEP = 2 : OKDEP = 1 : Break : Endif
 Next
 If !OKDEP
  Call VIREBOUT(CHAINE,"G") From GOBJET
 Endif
Else
 ## On grise le bouton <Esc/agio> si on n'a pas la gestion des esc/agio Argentine
 Call VIREBOUT(CHAINE,"G") From GOBJET
Endif

## Si le règlement est endossé (champ FLGEND=2), on grise le bouton <Validation>
# Issue X3-103268
#If func AFNC.PARAM("ARGEND",[F:PYH]CPY)="2" : # Gestion esc/agio Argentine
If func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGEND",[F:PYH]CPY)="2" : # Gestion esc/agio Argentine
 If CLECUR & !find(GREP,"C","D")
  If [F:PYH]FLGEND = 2
   Call VIREBOUT(CHAINE,"V") From GOBJET
  Endif
 Endif
Endif

# bloquer la comptabilisation de la 1ière étape (bien uniquement par rapport à la zone n° de chèque,
# si elle est obligatoire et si le règlement est de sens Dépense et [si dans la transaction de règlement
# l’impression n’est pas obligatoire OU le code édition est vide]).
If [F:TPY]DACCHQNUM=1 & dim([M]CHQNUM)>0 & [M]CHQNUM="" & [F:TPY]SNS=1 & ([F:TPY]EDTFLG=2| [F:TPY]CODEDT="")
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif

Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR & GFLEDI                    :  [L]REPORT1 = "PAY"+[L]ADI304       : Endif
If CLECUR & [M]CUR="EUR" & GFLEDIEUR  :  [L]REPORT1 = "PAY"+[L]ADI304+"EUR" : Endif
If CLECUR & [M]CUR="EUR" & !GFLEDIEUR :  Raz [L]REPORT1                     : Endif

## Edition de facture d'acompte disponible sur un règlement comptabilisé et de sens recette,
## dont les lignes ont une destination comptable acompte et un schéma de compte Banque<=>Tiers
## et la même devise et le même code taxe
If [L]REPORT1<>""
 Filter [ARX] Where INTCOD=[L]REPORT1 & TYPCOD=1 & EXTCOD="INVACC" & (LAN="" | LAN=GLANGUE)
 Read [ARX]ARX0 First
 Filter [ARX]
 If !fstat
  If [F:PYH]SNS<>2 | ( ([F:TPY]STA3<>2 | [F:PYH]STAFLG(2)<>2) & ([F:TPY]STA8<>2 | [F:PYH]STAFLG(7)<>2)
&                    & ([F:TPY]STA9<>2 | [F:PYH]STAFLG(8)<>2 | [F:TPY]ACETYP91<>1 ) )
   Raz [L]REPORT1
  Else
   I = 0
   For [PYD]PYD0 Where NUM=[F:PYH]NUM
    If I=0
     I=1
     OLDVATLIN = [F:PYD]VATLIN
     OLDCURLIN = [F:PYD]CURLIN
    Endif
    If [F:PYD]ACCTYP<>1
     Raz [L]REPORT1 : Break
    Endif
     Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
    If fstat | [F:CDA]ACCBPR="" | [F:CDA]RPCVAT<>2
     Raz [L]REPORT1 : Break
    Endif
    If [F:PYD]VATLIN<>OLDVATLIN | [F:PYD]CURLIN<>OLDCURLIN
     Raz [L]REPORT1 : Break
    Endif
   Next
  Endif
 Endif
Endif

If [L]REPORT1<>""
 If !instr(1,CHAINE,"E") : CHAINE +="E" : Endif
Else
 Call VIREBOUT(CHAINE,"E") From GOBJET
Endif
## Menus déroulants
If [L]ACCFCY & instr(1,[L]AUZFCY,"T") : CHMEN += "3" : Endif  # Transaction
If CLECUR & GREP=""
 If GTUNCPT(5)=0 : CHMEN += "1" : Endif : # Pièce comptable
 If VERROU & instr(1,[L]AUZFCY,"A") & [F:PYH]STA<11
&   & find(2,[F:PYH]STAFLG(2),[F:PYH]STAFLG(7),[F:PYH]STAFLG(8)) & !CLOSED_BCREG
  CHMEN += "4"  # Annulation comptable
 Endif
Endif

If [M:PAY4]NBPAY & !CLECUR & GREP<>"C"
 Effzo [M:PAY4] : LOTCUR=""
Endif
AMA(4)=2

#--- Menus "Adresse règlement" dans la ToolBar -----#
If GREP<>"" | CLECUR
 CHMEN+="5"
Endif

# FGR 18/01/2012 : X3SUIVI71278 (début)
  If GREP = "" Then
    CHMEN += "N"
  Endif
# FGR 18/01/2012 : X3SUIVI71278 (fin)

# suppression des boutons : supprimer, enregistrer, créer + interdiction de duplication
If MONOCPY : Call VIREBOUT(CHAINE,"AMCD") From GOBJET : Endif

# Allow for Cheque void
If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_SETBOUT From CHKLIB
Endif

# 78411 Sage Exchange
If CLECUR & GREP="" & func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
  # If the payment method has Sage Exchange turned on - enable the menu
  If !instr(0,CHMEN,"E") : CHMEN += "E" : Endif
  # Disable accounting cancellation for Sage Exchange
  Call VIREBOUT(CHMEN,"4") From GOBJET
  # Disable the Delete button if captured amount exists
  If func SEPPLIB.GET_SEUAMT(50+mod([M]SNS,2),[M]NUM,6)>0
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
#p -> Specified information window
#4 -> Account cancelled
#A -> Delete
If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[F:PYH]CPY) = "2"
  If [F:PYH]SNS <> 2 : Return : Endif

  If [F:PYH]CSHVATRGM = 2
    CHMEN += "P"
  Endif

  If GREP <> 'C' & GREP <> 'D'
    If [F:PYH]VATSTA = 3
      Call VIREBOUT(CHMEN,"4") From GOBJET
      Call VIREBOUT(CHAINE,"A") From GOBJET
    #Elsif [F:PYH]VATSTA = 2
      #Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
  Endif

  #04/11/2013 - In some cases, fields are activated on setbout
#  If [F:PYH]CSHVATRGM=2 & ([F:PYH]VATSTA=3 | [F:PYH]STA=11)
#    Grizo [M:PAY1]
#    If clalev([M:PAY2]) : Grizo [M:PAY2] : Endif
#    If clalev([M:PAY3]) : Grizo [M:PAY3] : Endif
#  Endif

Endif

# ISSUE 39256 - 2017-07-18 MRDAB - Enter payments from BCREG
Gosub GESBCREG_SETBOUT
# ISSUE END

#94635 RICAR 2014/04/21 - CASH VAT - END
Raz GMESSAGE
Return

$AVANTBOUT
Case BOUT
 When "V"
  Gosub RE_VERROU : If !OK : Return : Endif
  If [M]STA<3 & [F:TPY]STA3=2 & ([F:TPY]STA2<>2 | [M]STA>=2)
   OK=3
  Elsif [M]STA<9 & [F:TPY]STA9=2 & [F:PYH]FRMNUM="" & [F:TPY]STA5<>2 & [F:TPY]STA7<>2
&     & ([F:TPY]STA3<>2 | [F:PYH]STA>=3) & ([F:TPY]STA2<>2 | [F:PYH]STA>=2)
&     & [F:PYH]BAN<>""
   If [F:PYH]SNS=1 & [F:TPY]EDTFLG=2 &
&      (([L]ADI304="CHE" & [F:PYH]CHQNUM="") | ([L]ADI304="TRE" & [F:PYH]EDTNUM=0))
    GERR=1 : GMESSAGE=mess(57,121,1) : # Impression obligatoire
    Return
   Endif
   OK=9
  Else OK=0
  Endif
  If OK
   # On ferme les fichiers
   # V140 (CP 20/06/03 ) lié 17966 & 18557 : on ne ferme plus les fichiers
    Gosub FERME_FIC
  Endif
 When "1" : # Pièce comptable
  SAVCONS=GCONSULT
 When "3" : # Transaction
  SAVCONS=GCONSULT : GCONSULT=1
 When "4" : # Annulation comptable
  # V140 (CP 20/06/03 ) lié 17966 & 18557
   Gosub FERME_FIC
 When "5" :# Adresse Règlement
  #Facture
  [L]ADRREG = [M:PAY1]BPAINV
  [L]BPRNAM = [M:PAY1]BPRNAM
  [L]BPAADDLIG(0) = [M:PAY1]BPAADDLIG(0)
  [L]BPAADDLIG(1) = [M:PAY1]BPAADDLIG(1)
  [L]BPAADDLIG(2) = [M:PAY1]BPAADDLIG(2)
  [L]CRY = [M:PAY1]CRY
  [L]CRYNAM = [M:PAY1]CRYNAM
  [L]SAT = [M:PAY1]SAT
  [L]POSCOD = [M:PAY1]POSCOD
  [L]CTY = [M:PAY1]CTY
Endcase
Return

$RE_VERROU
# on verrouille, si ce n'est pas déjà fait
If !VERROU
 Gosub VERROU From GOBJET
 If !VERROU
  # Modification en cours sur un autre poste
  GERR=1 : GMESSAGE=mess(10,100,1) : OK=0 : Return
 Endif
 AFFICHE=1 : Gosub RELIT From GOBJSUB
 Gosub SETBOUT
 If !ACTBOU(NUMBOUT) : # Opération impossible
  GERR=1 : GMESSAGE=mess(157,123,1) : OK=0 : Return
 Endif
Endif
Return

$EXEBOUT
Case REP
 When "V"
  # on ré-ouvre les fichiers
  Gosub OUVRE From =PROGOBJ
  Gosub OUVRE_FIC
  Gosub OUVOBJ From GOBJET
  Call LEC_TPY_LEG(GCURLEG,GFONC1) From CPTLEC
  AFFICHE=1 : Gosub RELIT From GOBJSUB
Endcase
Return

$AVANT_SUITE
If BOUT="1" :  # Pièce comptable
 I=instr(1,VALBOUT," ")
 If !I
  OK=0
 Else
  [L]VALC1="GAS" : [L]VALC3=left$(VALBOUT,I-1) : [L]VALC2=right$(VALBOUT,I+1)
 # In order to allow the modification of open items due when coming from Payment (Zoom , Btn Open Item)
  GCONSULT=0
 Endif
Endif
Return

$STATUT
Case BOUT
 When "1" : # Pièce comptable
  GCONSULT=SAVCONS
 When "3" : # Transation
  GCONSULT=SAVCONS
  If GFONC1<>[F:TPY]PAYTYP
   Call LEC_TPY_LEG(GCURLEG,GFONC1) From CPTLEC
  Endif
 When "4" : # Annulation comptable
  Gosub OUVRE From =PROGOBJ
  Gosub OUVRE_FIC
  Gosub OUVOBJ From GOBJET
  # Si on n'arrive pas à réouvrir les fichiers, on plante
  # car GOBJET ne permet pas d'enchainer sur $SORT en cas de pb
  GFLAG = GFONC1 #F56500/3
   Call LEC_TPY_LEG(GCURLEG,GFONC1) From CPTLEC
  AFFICHE=1 : Gosub RELIT From GOBJSUB
Endcase
Return

$AV_IMPRIME
[L]VALC1 = GDIV(0)
Read [PYH]PYH0 = [M:PAY0]NUM
If fstat=0 : GDIV(0) = num$([F:PYH]EDTNUM)
Else       : GDIV(0)=""
Endif

#94635 RICAR 2014/04/22 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO") & [F:PYH]CASHVATNUM='' & [F:PYH]SNS = 2 & [F:PYH]CSHVATRGM = 2
  Local Char    COUNTER2(GLONANM)
  Local Char    COMPTEUR(GLONVCR)
  Local Integer STAT

  If [F:PYH]CSHVATRGM = 2
    COUNTER2 = "PTCSH"
  Endif

  Trbegin [F:PYH]

  Call NUMERO (COUNTER2,[M:PAY1]FCY ,date$,"",COMPTEUR,STAT) From SUBANM

  If STAT = 0
    [F:PYH]CASHVATNUM = COMPTEUR
    [F:PYH]VATSTA = 2
    Rewrite [F:PYH]
    If !fstat
      Commit
    Else
      Call ECR_TRACE(mess(67,7711,1),1) From GESECRAN
      OK=0
      Rollback
    Endif
  Else
    Rollback
    Call ECR_TRACE(mess(60,199,1),1) From GESECRAN
  Endif

Endif
#94635 RICAR 2014/04/22 - CASH VAT - END

Return

$AP_IMPRIME
GDIV(0) = [L]VALC1
Gosub RELIT From GOBJSUB
Return

#### Création / Duplication
$RAZCRE
Raz [M:VTL]
If [M]FCY="" : Raz [M:VT2] : Endif
[M:VT2]PTVENT = 0
[L]VALC1=""
[M:PAY0]NUM=""
If varinit([M:PAY0]PAYTYP)=0
 [M:PAY0]PAYTYP = GFONC1
Endif
Gosub GRISE_CLE From =WINPROG
If FLGLOT
 If [L]LSTLOT="*"
  [M]PAYLOT="*" : Affzo [PAY0]PAYLOT
 Elsif [L]LSTLOT<>""
  [L]VALC1=[L]LSTLOT
  Call LECTURE("PYL",[L]LSTLOT,"") From CONTOBJ
  If fstat=0
   [M]PAYLOT=[F:PYL]COD
   [M]LOTDES=[F:PYL]DES
   Affzo [PAY0]PAYLOT,LOTDES
   [M]CPY=[F:PYL]CPY
  Endif
 Endif
 Gosub CHARG_LOT From SUBPAY5
 If ROK : Affzo [PAY4] : Endif
Endif
Gosub SET_SNS From SUBPAY

# Localization Switzerland, 2015-05-21 Bader
Local Integer SOK
If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 : # parameter "Swiss checks in payments" = yes?
  Call EXISTE_ADX("","","SUBPAY3SWI",SOK) From ORDSYS
  If SOK : Gosub RAZCRE From SUBPAY3SWI : Endif
Endif
# End Localization Switzerland

zonsui="FCY" # Issue X3-52623 - 2017-08-18 by BEFOU : Adding Focus on FCY
# ISSUE 39256 - 2017-07-25 MRDAB - Enter payments from BCREG
Gosub GESBCREG_RAZCRE
# ISSUE END
Return

$RAZDUP
Gosub RAZCRE
[M:PAY0]STA=0
[M]CHQNUM=""
Gosub DEFMSKLIG
If dim([M]TOTIMPUT)>0
 Effzo TOTIMPUT, DEVISE
Endif
If dim([M]RSTIMPUT)>0
 [M]RSTIMPUT = [M]AMTCUR
 Affzo [M]RSTIMPUT
Endif
If dim([M]TOTBQE)>0
 Effzo TOTBQE, DEVBQE
 Affzo TOTBQE, DEVBQE
Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 Raz [M]BID, [M]PAB1, [M]PAB2, [M]BIDCRY , [M]BPAINV, [M]BPAADDLIG(0),[M]BPAADDLIG(1),[M]BPAADDLIG(2)
 Raz [M]POSCOD, [M]SAT, [M]CTY
 If clalev([M:PYB]) : Raz [M:PYB] : Endif
Endif
If [M]NBLIG : Effzo 25 : Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
# ISSUE 39256 - 2017-09-08 MRDAB - Enter payments from BCREG - actzo cannot be when accessing GESPAY from GESBCREG
If GFONCTION1 <> 'GESBCREG'
  Actzo [M:PAY1]
  If clalev([M:PAY2]) : Actzo [M:PAY2] : Endif
  If clalev([M:PAY3]) : Actzo [M:PAY3] : Endif
Endif
# ISSUE 39256 - 2017-09-08 MRDAB - Enter payments from BCREG
#94635 RICAR 2014/04/21 - CASH VAT - END
Return

$ABANDON
Gosub RAF_ECHE From SUBPAY4
If REP="C" | REP="D"
 Gosub DEGRISE_CLE From =WINPROG
Endif
If clalev([M:PYB]) : # Virement international (code activité VII)
 [M:PYB]       = [F:PYH]
 [M:PYB]FLGMOD = 1
Endif
Return

$INICRE
COMPTREG = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 If [F:PYH]SNS=1
  COMPTREG = [F:TCA]CODNUM(0) : # Dépenses
 Else
  COMPTREG = [F:TCA]CODNUM(1) : # Recettes
 Endif
Endif
If COMPTREG="" : COMPTREG = "PY1" : Endif

If func PORLEGLIB.SEQNUMCORRECT([M]FCY, COMPTREG) = 0
  GOK = 0 : GERR = 1
  Return
Endif

Call NUMERO(COMPTREG,[M]FCY,[M]ACCDAT,[F:TPY]PAYTYP,[L]VALC1,STAT) From SUBANM
If STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 GMESSAGE = mess(60,199,1)-"("+COMPTREG+") : "+MESSA
 Return
Endif

[F:PYH]NUM = [L]VALC1
[F:PYH]STA=1 : [F:PYH]STAFLG(0)=2 : # Etat
[F:PYH]PST=1 : # Non Comptabilisé
Call CLIFOU([F:PYH]BPR,[F:PYH]COA,[F:PYH]ACC,[F:PYH]SNS,[F:PYH]BPRTYP) From PAYDIV
## (+ correction faite en C_BPR dans SUBPAY)
## [F:BPR]ACS est un 'Filtre accès état'. Il a uniquement pour objectif de faire ressortir ou pas le tiers
## dans les états en fonction du code accès. Dans l'état LISREG on exploite le champ [F:PYH]ACS. On va donc continuer
## à l'initialiser par [F:BPR]ACS mais ne plus faire le contrôle en C_BPR comme on faisait (d'ailleurs on ne faisait
## pas le contrôle en proposition auto, dans les factures tiers, etc...)
## L'initialisation de [PYH]ACS est faite ici pour éviter le contrôle fait dans GOBJSUB dans $SET_AUTOR sur le niveau d'accès...
Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
[F:PYH]ACS = [F:BPR]ACS
## <Fin PP>
If clalev([M:PYB]) : # Virement international (code activité VII)
 [F:PYH]       = [M:PYB]
 [M:PYB]FLGMOD = 1
Endif
If [F:PYH]BPAINV = ""
 Call INIADR([F:PYH]BPR,[F:PYH]BPAINV) From SUBPAY
Endif
If [F:PYH]BPR<>""
 Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
 If fstat<2
  [F:PYH]BPANAM=[F:BPR]BPRNAM
 Endif
Elsif [F:PYH]ACC<>""
 Call LECTURE("GAC",[F:PYH]ACC,GPLAN(1)) From CONTOBJ
 If fstat<=2
  Call LECTEXTRA([F:PYH]BPANAM,"GACCOUNT","DESTRA",GPLAN(1),[F:PYH]ACC) From ATEXTRA
 Endif
Endif

Call GETPERSOC([F:PYH]CPY,GTYPGEN,[F:PYH]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:PYH]FIY = EXERCICE
[F:PYH]PER = PERIODE

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]SNS=2
 Call CALSEQTYP([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]UMRSEQ) From PAYSDDLIB
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Gosub INI_COM

[F:PYH]VATSTA=1
#94635 RICAR 2014/04/21 - CASH VAT - END
#ISSUE 33455 – 2017-07-19  By MANOW
# Issue X3-103268
#If (func AFNC.PARAM("BCREG", GFLAGLEG) = "2" & func AFNC.ACTIV("REGBC") & GFONCTION1 = 'GESBCREG')
If (func AFNC.ACTIV("REGBC") & func AFNC.PARAM("BCREG", GFLAGLEG) = "2" & GFONCTION1 = 'GESBCREG')
  [F:PYH]REGNUM = [M:PAY0]REGNUM
Endif
#ISSUE end
Return

$INIMOD
Call CLIFOU([F:PYH]BPR,[F:PYH]COA,[F:PYH]ACC,[F:PYH]SNS,[F:PYH]BPRTYP) From PAYDIV
Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
[F:PYH]ACS = [F:BPR]ACS
If clalev([M:PYB]) : # Virement international (code activité VII)
 [F:PYH]       = [M:PYB]
 [M:PYB]FLGMOD = 1
Endif
If [F:PYH]BPAINV = ""
 Call INIADR([F:PYH]BPR,[F:PYH]BPAINV) From SUBPAY
Endif

If [F:PYH]BPR<>""
 Call BPRTYP([F:PYH]BPR,[L]BPRTYPBIS) From SUBAFR
 If [L]BPRTYPBIS & [M:PAY1]BPRNAM<>""
  [F:PYH]BPANAM=[M:PAY1]BPRNAM
 Else
  Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
  If fstat<2
   [F:PYH]BPANAM=[F:BPR]BPRNAM
  Endif
 Endif
Elsif [F:PYH]ACC<>""
 Call LECTURE("GAC",[F:PYH]ACC,GPLAN(1)) From CONTOBJ
 If fstat<=2
  Call LECTEXTRA([F:PYH]BPANAM,"GACCOUNT","DESTRA",GPLAN(1),[F:PYH]ACC) From ATEXTRA
 Endif
Endif

Call GETPERSOC([F:PYH]CPY,GTYPGEN,[F:PYH]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:PYH]FIY = EXERCICE
[F:PYH]PER = PERIODE

If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_INIMOD From CHKLIB
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]SNS=2 & [F:PYH]UMRSEQ=""
 Call CALSEQTYP([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]UMRSEQ) From PAYSDDLIB
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Gosub INI_COM
#94635 RICAR 2014/04/21 - CASH VAT - END
Return

$INITADR2
Local Integer I2
If [F:PYH]BPR<>""
 Read [BPA2]BPA0 = 1;[F:PYH]BPR;[F:PYH]BPAINV
Elsif [F:PYH]ACC<>""
 Read [BPA2]BPA0 = 5;[F:PYH]ACC;[F:PYH]BPAINV
Endif
If [F:BPA2]BPATYP=1
 Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
 [F:PYH]BPANAM = [F:BPR]BPRNAM
Elsif [F:BPA2]BPATYP=5
 Call LECTURE("GAC",[F:PYH]ACC,GPLAN(1)) From CONTOBJ
 Call LECTEXTRA([F:PYH]BPANAM,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Endif
For I2=0 To min(dim([F:PYH]BPAADDLIG),dim([F:BPA2]BPAADDLIG))-1
 [F:PYH]BPAADDLIG(I2) = [F:BPA2]BPAADDLIG(I2)
Next I
[F:PYH]SAT    = [F:BPA2]SAT
[F:PYH]POSCOD = [F:BPA2]POSCOD
[F:PYH]CTY    = [F:BPA2]CTY
[F:PYH]CRY    = [F:BPA2]CRY
If [F:BPA2]CRYNAM<>"" : [F:PYH]CRYNAM = [F:BPA2]CRYNAM
Else
 [F:PYH]CRYNAM=""
 Call INIPAYS([F:BPA2]CRY,[F:PYH]CRYNAM) From TRTDIV
Endif
Return

$CREATION
Gosub DEVIN
Gosub CRELIG : If GOK<1 : Return : Endif
[L]VALC1="" : Gosub MAJLOT From SUBPAY5

## Updates the empty receipt entry number with [PYH]NUM in all the amendments recordings corresponding to this mandate
If GOK<1 : Return : Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]SNS=2 & [F:PYH]UMRNUM<>""
 GOK = func PAYSDDLIB.UPDHAMNUM([F:PYH]CPY,[F:PYH]UMRNUM,"",[F:PYH]NUM)
 If GOK<1 : Return : Endif
Endif
Return

$APRES_CRE
[L]LSTLOT = [F:PYH]PAYLOT
Gosub DEGRISE_CLE From =WINPROG
AFFICHE=1 : Gosub RELIT From GOBJSUB

If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_CREATION From CHKLIB
Endif

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
  Call AUTH_CHK(50+mod([M]SNS,2),[F:PYH]NUM,GERR,GMESSAGE) From SEPPLIB
  If !func SEPPCDT.SEPP_OK(50+mod([M]SNS,2),[F:PYH]NUM,1)
    Call CALL_SEAUTH(50,[F:PYH]NUM) From TRTSEAUTH
  Endif
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Gosub APRES_COM
#94635 RICAR 2014/04/21 - CASH VAT - END
#ISSUE 39265 – 2017-08-23  By MADOR
Gosub UPDATE_REGLP
#ISSUE END
Return


#### Modification
$APRES_MODIF
# X3-76133 - BEFOU Force to have the good Payement charged
If([F:PYH]NUM<>[M]NUM)
  Read [PYH]PYH0 = [M]NUM
Endif

# X3-81475 BEGIN Enforce RAZCRE when user didn't click "New" before
If COUZON="NUM" and GREP = "" and zc = ""
   REP = "C" : GREP = "C"
   ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
Endif
# X3-81475 END

Raz FILSUITE
If COUZON="NBPAY" & GREP=""
 If GDIV(0)<>CLECUR1
  NEWCLE1=GDIV(0)
  Gosub EXISTE From GOBJSUB
  If !fstat
   If VERROU : Gosub DEVERROU From GOBJET : Endif
   Gosub LECTURE From GOBJSUB
   Gosub SETBOUT From GOBJSUB
  Endif
 Endif
 OK=-1
 Return
Elsif COUZON="PAYLOT" & [M]CODLOT<>CZ
 [L]VALC1=CZ : Gosub CHARG_LOT From SUBPAY5
 If ROK : Affzo [PAY4] : Endif
Endif
OK=1
If find(REP,"","M")
 If (([F:PYH]STA>=9 | [F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2)
&     & find(COUZON,"FCY","BPR","ACC","BPRSAC","AMTCUR","AMTBAN","CURRAT"))
&   | ([F:PYH]STA>=9 & [F:PYH]SNS=1 & [F:TPY]EDTFLG=2 & find(COUZON,"CHQNUM"))
&   | (COUZON="NBLIG" & GWEBSERV<>1 & ([F:PYH]STA>=9 | (([F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2)
&   &  status=75 & COUZON="NBLIG" & [M]DENCOD(nolign-1)<>"" & [M]ACCTYP(nolign-1)<>2)))
&   | (COUZON="BAN" & [F:PYH]BAN<>"" & ([F:PYH]STA>=9 | [F:PYH]STAFLG(5)=2 | [F:PYH]STAFLG(7)=2))
  # Modification impossible
  GMESSAGE=mess(9,123,1) : OK=0
 Elsif (find(COUZON,"FRMTYP","CHQTYP","BAN") & [F:PYH]FRMNUM<>"") | (find(COUZON,"DUDDAT","UMRNUM") & [F:TPY]EPACDTTRF=2 & [F:PYH]FRMNUM<>"")
  Case [F:PYH]FRMFLG
   When 1 : # Règlement sur le bordereau de remise FRMNUM - Modification impossible
    GMESSAGE=mess(114,117,1)-num$([F:PYH]FRMNUM)+"\"+mess(9,123,1)
   When 2 : # Règlement sur l'avis de domiciliation FRMNUM - Modification impossible
    GMESSAGE=mess(121,117,1)-num$([F:PYH]FRMNUM)+"\"+mess(9,123,1)
  Endcase
  OK=0
 Endif
Endif

If !OK & [M]OD1=-99
 Raz [M]OD1, [M]OVCR
Elsif OK & find(REP,"M","C","D")
 Gosub AVANT_MOD
Endif
Return

# Issue X3-61594
$SET_GFCY
  GFCY = [M:PAY1]FCY
Return
# End issue X3-61594

$AVANT_MOD
If [M]OD1=-99 : # Relevé
 Call P_REL(OK) From SUBPAY2
 If !OK : Return : Endif
 If find(COUZON,"FCY","BPR","UMRNUM") & ([M]BPR<>"")
  Gosub RAF_ECHE From SUBPAY4
 Endif
Elsif find(COUZON,"FCY","BPRSAC","BPR","SNS","UMRNUM") | (COUZON="PAYLOT" & [M]FCY="")
 If COUZON="SNS" : Assign "[M]"+COUZON With val(CZ)
 Else            : Assign "[M]"+COUZON With CZ
 Endif
 If COUZON="BPR" : Affzo BPRNAM : Endif
 If find(COUZON,"FCY","BPR","UMRNUM") & ([M]BPR<>"")
  Gosub RAF_ECHE From SUBPAY4
 Endif
Endif
If REP="" & [M]SNS=1 & COUZON<>"BPR" & COUZON<>"NUM" : # Dépense
 GMESSAGE="" : Call FOUBAP([M]BPR) From SUBPAY2
 If GMESSAGE<>"" : GERR=2 : Endif
Endif
Return

$AVANT_MODFIC
If   (([F:PYH]STA>=9 | [F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2)
&     & ([M]FCY<>[F:PYH]FCY | [M]BPR<>[F:PYH]BPR | [M]ACC<>[F:PYH]ACC | [M]BPRSAC<>[F:PYH]BPRSAC
&      | [M]AMTCUR<>[F:PYH]AMTCUR | ([M]AMTBAN<>[F:PYH]AMTBAN & [M]BAN=[F:PYH]BAN)))
&
&  | (([F:PYH]STA>=9 | [F:PYH]STAFLG(5)=2 | [F:PYH]STAFLG(7)=2)
&     & ([M]BAN<>[F:PYH]BAN & [F:PYH]BAN<>""))
&
&  | (([M]FRMTYP<>[F:PYH]FRMTYP | [M]CHQTYP<>[F:PYH]CHQTYP | [M]BAN<>[F:PYH]BAN)
&     & [F:PYH]FRMNUM<>"" & find([F:PYH]FRMFLG,1,2))
&
&  | (([M]DUDDAT<>[F:PYH]DUDDAT & [F:TPY]EPACDTTRF=2)
&     & [F:PYH]FRMNUM<>"" & find([F:PYH]FRMFLG,1,2))
  GMESSAGE=mess(9,123,1) : GOK=0  : # Modification impossible
  Return
Endif
If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_AVANT_MODFIC From CHKLIB  # GRNA
 If GOK<1 : Return : Endif
Endif
SIGN=-1
Gosub MAJBAN : If GOK<1 : Return : Endif
[L]VALC1=[F:PYH]PAYLOT

# Calcul du code motif économique
If dim([F:CPY]BDFECOCOD)>0 Then
 Local Char    ECOCOD
 Local Integer STAT
 If [M]BDFECOCOD<>"" Then
   Call CALC_BDFECOCOD(GFLAG,[M]BPR,[M]BID,[M:PAY1]BPAINV,[M:PAY1]AMTCUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) From SUBPAY
   If ECOCOD="" Then
     If STAT>0 Then
      [M]BDFECOCOD = ECOCOD
      If dim([M:PAY1]BDFECOCOD)>0 Then
       Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD
      Endif
      If dim([M:PAY2]BDFECOCOD)>0 Then
       Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD
      Endif
     Endif
   Endif
 Endif
Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:PYH]SNS=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]UMRNUM<>""
 Call UPDMDTPYH([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]DUDDAT,[F:PYH]NUM,[F:PYH]UMRSEQ,[F:PYH]AMTCUR,"","A") From PAYSDDLIB
 If GOK<1 : Return : Endif
 ## If the mandate number is modified in the payment
 ## then the receipt entry number of the amendments linked to this payment must be updated
 If [M]UMRNUM<>[F:PYH]UMRNUM
  ## Reset the receipt entry number of the amendments linked to the previous mandate number
  GOK = func PAYSDDLIB.UPDHAMNUM([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]NUM,"")
  If GOK<1 : Return : Endif
  ## Update the receipt entry number of the amendments linked to the new mandate number
  GOK = func PAYSDDLIB.UPDHAMNUM([M]CPY,[M]UMRNUM,"",[F:PYH]NUM)
  If GOK<1 : Return : Endif
 Endif
Endif
Return

$MODIF
Gosub DEVIN
Gosub DELLIG : If GOK<1 : Return : Endif
Gosub CRELIG : If GOK<1 : Return : Endif
Gosub MAJLOT From SUBPAY5
#ISSUE 39265 – 2017-08-23  By MADOR
Gosub UPDATE_REGLP
#ISSUE end
Return

