Subprog AV_ANNULE2(PYHNUM,FLGLOT)
Value Char PYHNUM()
Value Libelle FLGLOT
Local Integer SIGN, STAT, I
Local Char    LCK(30)
Onerrgo ERREUR From CONTROLE
Local File GACCDUDATE [DUD]
Local File PAYMENTH   [PYH]
Local File PAYMENTH   [PYHB]
Local File PAYMENTD   [PYD]
Local File PAYMENTA   [PYA]
Local File PAYFRM     [FRM]
Local File BANK       [BAN]
Local File AREPORTM   [ARM]
Local File PINVOICE   [PIH]
Local File TABCUR     [TCU]
Onerrgo
If GERREUR : GERREUR=0 : GOK=0 : End : Endif
Local Libelle BORDTYP
Local Char    BORDNUM(20)
Local Decimal MT, MT2
Local Decimal EXERCICE, PERIODE
Read [PYH]PYH0 = PYHNUM
If fstat
 GOK=0 : Call RSTA("PYH",PYHNUM) From GLOCK : End
Endif
BORNUM=[F:PYH]FRMNUM : BORTYP=[F:PYH]FRMFLG
Gosub DEVIN
GREP="A" : Gosub DELLIG : GREP="" : If GOK<1 : End : Endif
SIGN=-1 : Gosub MAJBAN : If GOK<1 : End : Endif
If [F:PYH]EDTNUM<>0
 Delete [ARM] Where NUMREQ=[F:PYH]EDTNUM & CLEA1=[F:PYH]NUM
 If fstat=1
  GOK=-1 :  GLOCK="$AREPORTM"-num$([F:PYH]EDTNUM)-[F:PYH]NUM : End
 Elsif fstat>5
  GOK=0 :  Call RSTA("ARM",num$([F:PYH]EDTNUM)-[F:PYH]NUM) From GLOCK : End
 Endif
Endif
Gosub SUPMAJLOT From SUBPAY5 : If GOK<1 : End : Endif
If [L]BORNUM<>""
 Filter [PYHB] Where NUM<>[L]PYHNUM & FRMFLG=[L]BORTYP & FRMNUM=[L]BORNUM
 Read [PYHB]PYH1(2) First
 Filter [PYHB]
 If fstat>2
  Delete [FRM]FRM0 = [L]BORTYP;[L]BORNUM
  If fstat=1
   GOK=-1 :  GLOCK="$PAYFRM"-num$([L]BORTYP)-[L]BORNUM : End
  Elsif fstat>5
   GOK=0 :  Call RSTA("FRM",num$([L]BORTYP)-[L]BORNUM) From GLOCK : End
  Endif
 Endif
Endif
## <ALLEMAGNE>
# Issue X3-103268
#If func AFNC.PARAM("GERBKF",[F:PYH]CPY)="2" : # Gestion fichiers bancaires pour l'Allemagne
If func AFNC.ACTIV("KDE") and func AFNC.PARAM("GERBKF",[F:PYH]CPY)="2" : # Gestion fichiers bancaires pour l'Allemagne
Endif
## <Fin ALLEMAGNE>

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
  Call VOID_ALL(50,[F:PYH]NUM,GERR,GMESSAGE) From SEPPLIB
  If GERR : Raz GOK : Return : Endif
Endif

If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_AV_ANNULE2 From CHKLIB
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]SNS=2 & [F:PYH]UMRNUM<>""
 Call UPDMDTPYH([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]DUDDAT,[F:PYH]NUM,[F:PYH]UMRSEQ,[F:PYH]AMTCUR,"","A") From PAYSDDLIB
 If GOK<1 : End : Endif
 GOK = func PAYSDDLIB.UPDHAMNUM([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]NUM,"")
 If GOK<1 : End : Endif
Endif
End

# SAM: 81743 MAGER
$AP_ANNULE
If [F:TPY]LOTPROBALCTL = 2
  Gosub SAVEPROBAL From SUBPAY5
  Rewrite [F:PYL]
Endif
#ISSUE 39265 – 2017-08-23  By MADOR
Gosub UPDATE_REGLP
#ISSUE end
Return

$APRES_ANNULE
If dim([F:PYL]STA)>0 & FLGLOT & [L]LOTPYL<>"" & [F:PYL]NBRPAY>0
[F:PYL]STA=func SUBPAY5.CALSTAPYL([L]LOTPYL)
Rewrite [PYL]
If fstat : GOK=0 : Call FSTA("PYL") From GLOCK : Return : Endif
Endif
Return

#### Sous-programmes
$MAJBAN
If [F:PYH]BAN<>"" & [F:PYH]BANPAYTPY<>0
 Readlock [BAN]BAN0 = [F:PYH]BAN
 If fstat=1 : GOK=-1 : GLOCK="$BANK"-[F:PYH]BAN
 Elsif fstat : GOK=2 : Call RSTA("BAN",[F:PYH]BAN) From GLOCK
 Elsif fstat=0
 [F:BAN]PAYTPY+=SIGN*[F:PYH]BANPAYTPY
 Rewrite [BAN]
 If fstat : GOK=0 : Call FSTA("BAN") From GLOCK : Endif
 Endif
Endif
Return

$DELLIG
SIGN=-1
For [PYD]PYD0 Where NUM=[F:PYH]NUM
 If [F:PYD]RITAMT<>0 & func AFNC.PARAM("ITARTZ",[F:PYH]CPY)="2"
  Update [PIH] Where NUM=[F:PYD]VCRNUM With RITPAY=""
  If fstat=1
   GOK=-1 : GLOCK="$PINVOICE"-[F:PYD]VCRNUM : Break
  Elsif fstat
   GOK=0 : Call RSTA("PIH",[F:PYD]VCRNUM) From GLOCK : Break
  Endif
 Endif
 If [F:PYD]DUDNUM<>0
  Case [F:PYD]IPTTYP
   When 1       : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\*SO"
   When 2       : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\*PO"
   When Default : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\"+num$([F:PYD]VCRTYP)
  Endcase
  Lock =LCK
  If fstat : GOK=-1 : GLOCK="%"+LCK : Break : Endif
  Readlock [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG) : Break
  Elsif fstat
   GOK=2 : Call RSTA("DUD",num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG)) From GLOCK
  Elsif find([F:DUD]TYP,"*SO","*PO") & [F:DUD]PAMTYP=1
   If [F:DUD]DINAMT=0
    Delete [DUD] Where ACCNUM=[F:PYD]DUDNUM & DUDLIG=[F:PYD]DUDLIG
    If fstat=1
     GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG) : Break
    Elsif fstat>5
     GOK=0 : Call RSTA("DUD",num$([F:PYD]DUDNUM)-num$([F:DUD]DUDLIG)) From GLOCK : Break
    Endif
    STAT=2
   Elsif GREP="A" : STAT=1
   Else STAT=1
    For I=0 To [M]NBLIG-1
     If [M]DUDNUM(I)=[F:DUD]ACCNUM & [M]DUDLIG(I)=[F:DUD]DUDLIG
      If [M]CURLIN(I)=[F:DUD]CUR & [M]FCYLIN(I)=[F:DUD]FCY
&      & [M]VCRNUM(I)=[F:DUD]NUM & [M]VATLIN(I)=[F:DUD]VAT
&      & (([M]IPTTYP(I)=1 & [F:DUD]TYP="*SO")
&      |  ([M]IPTTYP(I)=2 & [F:DUD]TYP="*PO"))
       Call SNSPAYECH([M]ACCSNS(I),[M]SNS,[F:DUD]SNS,STAT) From SUBPAY2
       If [M]AMTLIN(I)*STAT>=[F:DUD]DINAMT : STAT=0 : Else STAT=1 : Endif
      Endif
      Break
     Endif
    Next I
   Endif
   If STAT=1 : # (Ligne x) - cde cli/fou NUM - Acompte déduit de DINAMT CUR
    GOK=0 : GMESSAGE = "("+mess(47,116,1)-num$([F:PYD]LIN)+")\"+
&   mess([F:PYD]IPTTYP,659,1)-[F:DUD]NUM+"\"+
&   mess(59,117,1)-num$([F:DUD]DINAMT)-[F:DUD]CUR : Break
   Endif
  Else STAT=0
  Endif
  If STAT=0
   Gosub MAJ_MTDUD : If GOK<1 : Break : Endif
   Call SLDECH("DUD")From MODECHE
   Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
   [F:DUD]FIY = EXERCICE
   [F:DUD]PER = PERIODE
   Rewrite [DUD]
   If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
  Endif
 Endif
Next : # [PYD]
If GOK<1 : Return : Endif

Delete [PYD] Where NUM=[F:PYH]NUM
If fstat=1 : GOK=-1 : GLOCK="$PAYMENTD"-[F:PYH]NUM : Return
Elsif fstat>5 : GOK=0  : Call RSTA("PYD",[F:PYH]NUM) From GLOCK : Return
Endif

Delete [PYA] Where NUM=[F:PYH]NUM
If fstat=1 : GOK=-1 : GLOCK="$PAYMENTA"-[F:PYH]NUM : Return
Elsif fstat>5 : GOK=0  : Call RSTA("PYA",[F:PYH]NUM) From GLOCK : Return
Endif
Return

### Important notice !!!!!! ##########################################
# CRELIG is called from PAYIMPORT as well. So if you introduce new variables or do structural changes
# be aware to check if this is working for PAYIMPORT as well!!
### Important notice !!!!!! ##########################################
$CRELIG
If [F:PYH]AMTBAN<>0
 Call SIGN2(1,[F:PYH]SNS,0,0,0,K) From PAYDIV
 If [F:PYH]SNS=1 : K*=-1 : Endif
 [F:PYH]BANPAYTPY=K*[F:PYH]AMTBAN
Else
 [F:PYH]BANPAYTPY=0
Endif
If [F:TPY]DACDUDDAT=3 : [F:PYH]DUDDAT=[0/0/0] : Endif
If [F:TPY]DACVALDAT=3 : [F:PYH]VALDAT=[0/0/0] : Endif
If [F:TPY]DACDUDDAT=3 : [F:PYH]DUDDAT=[0/0/0] : Endif
If [F:TPY]DACVALDAT=3 : [F:PYH]VALDAT=[0/0/0] : Endif
##
SIGN=1
Gosub DEFMSKLIG
MT3=0

##COURS est le cours calculé entre le montant tiers saisi en devise de règlement et le montant forcé en devise banque
Local Decimal COURS
COURS = func FUNCDEV.ARRONDI([F:PYH]AMTCUR,[F:PYH]AMTBAN)

[L]TOTAMTBANFRC = 0
[L]TOTAMTBANFRC1 = 0

For NOL=0 To [M]NBLIG-1
 Raz [F:PYD]
 [F:PYD]=[F:PYH]
 nolign=NOL+1
 [F:PYD]=[M]
 [F:PYD]LIN=nolign
 Raz [F:PYD]COA, [F:PYD]ACC, [F:PYD]LED
 For NLED=1 To GNBTYPLED
  [F:PYD]COA(GTYPLED(NLED)-1) = evalue("GPLAN("+num$(NLED)+")")
  [F:PYD]ACC(GTYPLED(NLED)-1) = evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")
  TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
  [F:PYD]LED(GTYPLED(NLED)-1) = [L]LED
 Next
 If [F:PYD]DSP="$" : [F:PYD]DSP="" : Endif
 If [F:PYD]IPTTYP<>3 : [F:PYD]VCRTYP="" : Endif
 If [F:PYD]VCRNUM<>"" & [F:PYD]IPTTYP<>4
  If [F:PYD]DUDNUM<>0
   Case [F:PYD]IPTTYP
    When 1       : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\*SO"
    When 2       : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\*PO"
    When Default : LCK = "HAE"+num$([F:PYD]VCRNUM)+"\"+num$([F:PYD]VCRTYP)
   Endcase
   Lock =LCK
   If fstat : GOK=-1 : GLOCK="%"+LCK : Break : Endif
   Readlock [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
   If fstat=1
    GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG) : Break
   Elsif fstat=0
    Gosub MAJ_MTDUD : If GOK<1 : Break : Endif
    ## Si l'échéance est soldée FLGCLE=2 sinon FLGCLE=1.
    Call SLDECH("DUD")From MODECHE
    Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
    [F:DUD]FIY = EXERCICE
    [F:DUD]PER = PERIODE
    Rewrite [DUD]
    If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
   Elsif fstat & ([F:PYD]IPTTYP=1 | [F:PYD]IPTTYP=2)
    Gosub CREECHE : If GOK<1 : Break : Endif
    [F:PYD]BPRINV    = [F:DUD]BPR
    [F:PYD]BPRSACINV = [F:DUD]SAC
   Else
    GOK=0 : Call FSTA("DUD") From GLOCK : Break
   Endif
  Else
   If [F:PYD]IPTTYP=2
    Filter [DUD] Where TYP="*PO" & NUM=[F:PYD]VCRNUM & LIG=1
   Else
    Filter [DUD] Where TYP="*SO" & NUM=[F:PYD]VCRNUM & LIG=1
   Endif
   Read [DUD]DUD0 Last
   Filter [DUD]
   If fstat<=2
    [F:PYD]DUDNUM=[F:DUD]ACCNUM : [F:PYD]DUDLIG=[F:DUD]DUDLIG+1
   Else
    Call ACCNUM([F:PYD]DUDNUM) From SUBGAS : [F:PYD]DUDLIG=1
   Endif
   Gosub CREECHE : If GOK<1 : Break : Endif
   [F:PYD]BPRINV    = [F:DUD]BPR
   [F:PYD]BPRSACINV = [F:DUD]SAC
  Endif
  If GOK>0 & [F:TPY]DACDUDDAT=3 & [F:TPY]DUDFLG=2 & ([F:PYH]DUDDAT=[0/0/0] | [F:DUD]DUDDAT<[F:PYH]DUDDAT)
   [F:PYH]DUDDAT=[F:DUD]DUDDAT
  Endif
  # Issue X3-103268
  #If func AFNC.PARAM("SPADESVAL",[F:PYH]CPY)="2" & [F:TPY]DACDUDDAT=3
  If   func AFNC.ACTIV("KSP") and func AFNC.PARAM("SPADESVAL",[F:PYH]CPY)="2" & [F:TPY]DACDUDDAT=3
   If [F:PYH]DUDDAT=[0/0/0] : [F:PYH]DUDDAT=[F:DUD]DUDDAT
   Else                     : [F:PYH]DUDDAT=min([F:PYH]DUDDAT,[F:DUD]DUDDAT)
   Endif
  Endif
 Endif

 Call LECTURE("TCU",[M]CURBAN,"") From CONTOBJ
 Read [TCU2]TCU0 = [M]CUR

 If [F:PYH]AMTBAN<>0 & [M]CUR<>[M]CURBAN & ([F:TCU]EURFLG=1 | [F:TCU2]EURFLG=1)
&     & find([F:PYD]ACCTYP,1)
  If [M]CURBAN = [M]CURCPY
   MT5 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR : # [PYD]AMTBANFRC est en devise locale..
   Call ARRDEV(MT5,[M]CURCPY) From TRTDIV
   MT4 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
   Call ARRDEV(MT4,[M]CURCPY) From TRTDIV
   [F:PYD]AMTBANFRC  = MT5-MT4
   [F:PYD]AMTBANFRC1 = MT5-MT4
   MT3+=[F:PYD]AMTLIN2
  Elsif [M]CURCPY=[F:PYD]CURLIN
   # Montant forcé en devise de banque. La devise de règlement est la devise société
   # Pour calculé le montant forcé en devise société, on convertit le montant forcé en devise de banque
   # d'après le cours calculé COURS
   MT5 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR : # [PYD]AMTBANFRC est en devise de banque..
   Call ARRDEV(MT5,[M]CURBAN) From TRTDIV
   MT4 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
   Call ARRDEV(MT4,[M]CURBAN) From TRTDIV
   [F:PYD]AMTBANFRC  = MT5-MT4
   MT3+=[F:PYD]AMTLIN2
   Call CONVERT3([M]CURBAN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT
&               ,[F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC1,COURS,STAT) From CPTSUB
  Else
   MT5 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR :# [PYD]AMTBANFRC est en devise de banque
   Call ARRDEV(MT5,[M]CURBAN) From TRTDIV
   MT4 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
   Call ARRDEV(MT4,[M]CURBAN) From TRTDIV
   [F:PYD]AMTBANFRC = MT5-MT4 : MT3+=[F:PYD]AMTLIN2
   [L]TOTAMTBANFRC += [F:PYD]AMTBANFRC
   If NOL=[M]NBLIG-1 & [L]TOTAMTBANFRC<>[F:PYH]AMTBAN
    [F:PYD]AMTBANFRC += [F:PYH]AMTBAN-[L]TOTAMTBANFRC
   Endif
   #Issue 31729 – 2017-05-10  by MADOR - As a user I want to be able to compute
   #payments with the new rate currency field
   Call CONVERT4([M]CURBAN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT
&            ,[F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC1,STAT,[F:PYH]CURRAT) From TRTDEV
   #Issue end
   If STAT : # Pas de cours de devises [M]CURBAN -> [M]CURCPY (ACCDAT)
    GMESSAGE=mess(16,114,1)-[M]CURBAN-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
    GOK=0 : Break
   Endif
  Endif

  [L]TOTAMTBANFRC1 += [F:PYD]AMTBANFRC1
  If NOL=[M]NBLIG-1
   If [M]CUR = [M]CURCPY & [L]TOTAMTBANFRC1<>[F:PYH]AMTCUR
    [F:PYD]AMTBANFRC1+=[F:PYH]AMTCUR-[L]TOTAMTBANFRC1
   Endif
   If [M]CURBAN = [M]CURCPY & [L]TOTAMTBANFRC1<>[F:PYH]AMTBAN
    [F:PYD]AMTBANFRC1+=[F:PYH]AMTBAN-[L]TOTAMTBANFRC1
    [F:PYD]AMTBANFRC=[F:PYD]AMTBANFRC1
   Endif
  Endif
 Endif

 Write [PYD]
 If fstat : GOK=0 : Call FSTA("PYD") From GLOCK : Break : Endif


 If [F:PYD]RITAMT<>0 & func AFNC.PARAM("ITARTZ",[F:PYH]CPY)="2"
  Update [PIH] Where NUM=[F:PYD]VCRNUM With RITPAY=[F:PYD]NUM
  If fstat=1
   GOK=-1 : GLOCK="$PINVOICE"-[F:PYD]VCRNUM : Break
  Elsif fstat
   GOK=0 : Call RSTA("PIH",[F:PYD]VCRNUM) From GLOCK : Break
  Endif
 Endif

 LIGANA = 0
 Case [M]DSP(NOL)
  When "$"
   K=0
   For I=[M]PTV(NOL) To [M]PTF(NOL)
    LIGANA+=1 : Raz [F:PYA]
    [F:PYA]=[F:PYH]
    [F:PYA]=[F:PYD]
    [F:PYA]LINANA = LIGANA
    [F:PYA]AMTANA = [M:VT2]TBAMT(I) : [F:PYA]QTYANA = [M:VT2]TBQTY(I)
    For AXE=1 To GNBAXE
     If GAXE(AXE)<>""
      [F:PYA]DIE(AXE-1) = GAXE(AXE)
      [F:PYA]CCE(AXE-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(I)+")")
     Endif
    Next
    Write [PYA]
    If fstat : GOK=0 : Call FSTA("PYA") From GLOCK : Break (2) : Endif
   Next I
  When ""
   Raz [F:PYA]
   [F:PYA]=[F:PYH]
   [F:PYA]=[F:PYD]
   [F:PYA]LINANA = 1 : OK=0
   [F:PYA]AMTANA = [M]AMTLIN(NOL) : [F:PYA]QTYANA = [M]QTYLIN(NOL)
   For AXE=1 To GNBAXE
    If GAXE(AXE)<>""
     [F:PYA]DIE(AXE-1) = GAXE(AXE)
     [F:PYA]CCE(AXE-1) = evalue("[M]CCE"+num$(AXE)+"("+num$(NOL)+")")
    Endif
    If [F:PYA]CCE(AXE-1)<>"" : OK=1 : Endif
   Next
   If OK
    Write [PYA]
    If fstat : GOK=0 : Call FSTA("PYA") From GLOCK : Break : Endif
   Endif
  When Default
   [M:VTL]TOTREP=[M]AMTLIN(NOL) : [M:VTL]QTOTREP=[M]QTYLIN(NOL) : K=0
   Call LECTURE("TCU",[M]CURLIN(NOL),"") From CONTOBJ
   Gosub SETCHPLST From SUBPAY3
   Call CHARGE_VTE_STR([M]DSP(NOL),[M]UOM(NOL),[M]LSTLED(NOL),[M]LSTACC(NOL),[M]LSTAXE) From VENTILE
   For I=0 To [M:VTL]BAS-1
    LIGANA+=1 : Raz [F:PYA]
    [F:PYA]=[F:PYH]
    [F:PYA]=[F:PYD]
    [F:PYA]LINANA = LIGANA
    [F:PYA]AMTANA = [M:VTL]AMT(I)
    [F:PYA]QTYANA = [M:VTL]QTY(I)
    For AXE=1 To GNBAXE
     [F:PYA]CCE(AXE-1)=evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(I)+")")
     [F:PYA]DIE(AXE-1) = GAXE(AXE)
    Next
    Write [PYA]
    If fstat : GOK=0 : Call FSTA("PYA") From GLOCK : Break (2) : Endif
   Next I
 Endcase

 If [F:PYH]BAN<>"" & (([F:PYH]AMTBAN=0 & [F:PYD]ACCTYP=1) | [F:PYD]ACCTYP=2)
  If [F:PYD]AMTLIN=0
   MT=0
  Elsif [F:PYH]CUR=[M]CURBAN & [F:PYD]ACCTYP=1
   MT=sgn([F:PYD]AMTLIN)*abs([F:PYD]AMTLIN2-[F:PYD]RITAMT2)
  Elsif [F:PYD]CURLIN=[M]CURBAN
   MT=[F:PYD]AMTLIN
  Elsif [F:PYD]DUDNUM<>0 & [M]CURCPY=[M]CURBAN
   MT=sgn([F:PYD]AMTLIN)*abs([F:PYD]PAYLOCLIN)
  Else
   Call CONVERT([F:PYD]CURLIN,[M]CURBAN,[M]CURCPY,[F:TPY]RATTYP
&              ,[F:PYH]ACCDAT,[F:PYD]AMTLIN,MT,STAT) From TRTDEV
   If STAT : # Pas de cours de devises CURLIN -> CURBAN (ACCDAT)
    GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-[M]CURBAN-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
    GOK=0 : Break
   Endif
  Endif
  Call SIGN2([F:PYD]ACCSNS,[F:PYH]SNS,[F:PYD]DUDNUM,[F:PYD]DUDLIG,[F:PYD]IPTTYP,K) From PAYDIV
  If [F:PYH]SNS=1 : K*=-1 : Endif
  [F:PYH]BANPAYTPY+=MT*K


  If dim([M]RITAMT)>0 & [F:PYD]RITAMT<>0
   If func AFNC.PARAM("ITARTZ",[F:PYH]CPY)="2" : # Retenues Italiennes : on laisse comme avant..
    If [M]RTZCUR=[M]CURBAN
     MT=[F:PYD]RITAMT
    Elsif [F:PYH]CUR=[M]CURBAN
     MT=sgn([F:PYD]RITAMT)*abs([F:PYD]RITAMT2)
    Else
     Call CONVERT([M]RTZCUR,[M]CURBAN,[M]CURCPY,[F:TPY]RATTYP
&                ,[F:PYH]ACCDAT,[F:PYD]RITAMT,MT,STAT) From TRTDEV
     If STAT : # Pas de cours de devises RTZCUR -> CURBAN (ACCDAT)
      GMESSAGE=mess(16,114,1)-[M]RTZCUR-"->"-[M]CURBAN-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
      GOK=0 : Break
     Endif
    Endif
   Else : # Ret Arg. : RITAMT est en devise échéance (et non devise RTZCUR). RITAMT2 en dev règlement (comme en Italie)
    If [F:PYD]CURLIN=[M]CURBAN
     MT=[F:PYD]RITAMT
    Elsif [F:PYH]CUR=[M]CURBAN
     MT=sgn([F:PYD]RITAMT)*abs([F:PYD]RITAMT2)
    Else
     Call CONVERT([F:PYD]CURLIN,[M]CURBAN,[M]CURCPY,[F:TPY]RATTYP
&                ,[F:PYH]ACCDAT,[F:PYD]RITAMT,MT,STAT) From TRTDEV
     If STAT : # Pas de cours de devises RTZCUR -> CURBAN (ACCDAT)
      GMESSAGE=mess(16,114,1)-[M]RTZCUR-"->"-[M]CURBAN-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
      GOK=0 : Break
     Endif
    Endif
   Endif
   Call LECTURE("BIS",[F:PYD]VCRNUM,"") From CONTOBJ
   If find([F:PIH]INVTYP,2,4) : K=3 : Else K=2 : Endif
   Call SIGN2(K,[M]SNS,0,0,0,K) From PAYDIV
   If [F:PYH]SNS=1 : K*=-1 : Endif
   [F:PYH]BANPAYTPY+=MT*K

  Endif
 Endif
Next NOL
If GOK<1 : Return : Endif
MT =[F:PYH]BANPAYTPY
DAT=[F:PYH]DUDDAT : If DAT=[0/0/0] : DAT=[F:PYH]ACCDAT : Endif
Read [PYH]PYH0 = [F:PYH]NUM
If fstat=0 & (MT<>[F:PYH]BANPAYTPY | DAT<>[F:PYH]DUDDAT |
&             ([F:TPY]DACVALDAT=3 & DAT<>[F:PYH]VALDAT))
 [F:PYH]BANPAYTPY = MT
 [F:PYH]DUDDAT    = DAT
 If [F:TPY]DACVALDAT=3 : [F:PYH]VALDAT=[F:PYH]DUDDAT : Endif
 Rewrite [PYH]
Endif
If fstat
 GOK=0 : Call RSTA("PYH",[F:PYH]NUM) From GLOCK : Return
Endif
Gosub MAJBAN
If dim([M]TOTBQE)>0
  [M]TOTBQE =  abs([F:PYH]BANPAYTPY)
  Affzo TOTBQE
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:PYH]SNS=2 & [F:PYH]UMRNUM<>""
 If [F:PYH]STAFLG(10)=2
  Call UPDMDTPYH([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]DUDDAT,[F:PYH]NUM,[F:PYH]UMRSEQ,[F:PYH]AMTCUR,[F:PYH]FRMNUM,"I") From PAYSDDLIB
 Else
  Call UPDMDTPYH([F:PYH]CPY,[F:PYH]UMRNUM,[F:PYH]DUDDAT,[F:PYH]NUM,[F:PYH]UMRSEQ,[F:PYH]AMTCUR,[F:PYH]FRMNUM,"") From PAYSDDLIB
 Endif
Endif
Return

$CREECHE
Raz [F:DUD]
Local Char CODCPT(GLONCAC)
If [F:PYD]IPTTYP=2
 Call LECTURE("POH",[F:PYD]VCRNUM,"") From CONTOBJ
 If fstat
  GOK=0 : Call RSTA("POH",[F:PYD]VCRNUM) From GLOCK : Return
 Endif
 [F:DUD]TYP    = "*PO"
 [F:DUD]SNS    = -1
 [F:DUD]BPR    = [F:POH]BPSNUM
 [F:DUD]BPRPAY = [F:POH]BPRPAY
 [F:DUD]BPRTYP = 2 : # Fournisseur
 Call LECTURE("BPS",[F:DUD]BPR,"") From CONTOBJ
 Call INIT_COMPTE([F:DUD]BPR,[F:DUD]CPY,"F",CODCPT) From CPTSUB
 Call LECTURE("CAC",[L]CODCPT,"3~"+GPLAN(1)) From CONTOBJ
Else
 Call LECTURE("SOH",[F:PYD]VCRNUM,"") From CONTOBJ
 If fstat
  GOK=0 : Call RSTA("SOH",[F:PYD]VCRNUM) From GLOCK : Return
 Endif
 [F:DUD]TYP    = "*SO"
 [F:DUD]SNS    = 1
 [F:DUD]BPR    = [F:SOH]BPCINV
 [F:DUD]BPRPAY = [F:SOH]BPCPYR
 [F:DUD]BPRTYP = 1 : # Client
 Call LECTURE("BPC",[F:DUD]BPR,"") From CONTOBJ
 Call INIT_COMPTE([F:DUD]BPR,[F:DUD]CPY,"C",CODCPT) From CPTSUB
 Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
Endif
If fstat : # Fournisseur/Client BPR - Code comptable inexistant
 GMESSAGE="SAC='' ("+mess(47,116,1)-num$([F:PYD]LIN)+")\"
&        +mess([F:PYD]IPTTYP,242,1)-[F:DUD]BPR+"\"+mess(11,114,1)
 GOK=0 : Return
Endif
Read [GAC]GAC0 = GPLAN(1);[F:CAC]ACC(0)
If fstat=0 : [F:DUD]SAC=[F:GAC]ACCSHO : Endif
If [F:DUD]SAC=""
 GMESSAGE="SAC='' ("+mess(47,116,1)-num$([F:PYD]LIN)+")"
 GOK=0 : Return
Endif
[F:DUD]NUM     = [F:PYD]VCRNUM
[F:DUD]LIG     = 1
[F:DUD]PAMTYP  = 2 : # Acompte
[F:DUD]SOI     = 1 : # Relevé = Non
[F:DUD]DUDSTA  = 1 : # Provisoire
[F:DUD]SENINS  = 1 : # Non émis
[F:DUD]FLGFUP  = 1 : # A relancer=Non
[F:DUD]CPY     = [F:PYH]CPY
[F:DUD]PAM     = [F:PYH]PAM
[F:DUD]DUDDAT  = [F:PYH]ACCDAT
[F:DUD]FCY     = [F:PYD]FCYLIN
[F:DUD]CUR     = [F:PYD]CURLIN
[F:DUD]VAT     = [F:PYD]VATLIN
Gosub PAYMT : If GOK<1 : Return : Endif
[F:DUD]DUDLIG  = [F:PYD]DUDLIG
[F:DUD]ACCNUM  = [F:PYD]DUDNUM
If [F:PYD]PAYCURLIN<0
 [F:DUD]SNS*=-1
 [F:PYD]PAYCURLIN=-[F:PYD]PAYCURLIN
 [F:PYD]PAYLOCLIN=-[F:PYD]PAYLOCLIN
 #[F:PYD]PAYRPTLIN=-[F:PYD]PAYRPTLIN
Endif
If [F:DUD]SNS=-1 : [F:DUD]FLGPAZ = [L]MAXPAZ : Endif : # Bon à payer
[F:DUD]AMTCUR =[F:PYD]PAYCURLIN : [F:DUD]TMPCUR  =[F:DUD]AMTCUR
[F:DUD]AMTLOC =[F:PYD]PAYLOCLIN : [F:DUD]TMPLOC  =[F:DUD]AMTLOC
[F:DUD]IBDAMT = [F:DUD]AMTCUR
[F:DUD]TYPDUD = 1  : #Commande
Call KEYDUD("DUD") From MODECHE
Call SLDECH("DUD")From MODECHE
Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
[F:DUD]FIY = EXERCICE
[F:DUD]PER = PERIODE
Write [DUD]
If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Endif
Return

$MAJ_MTDUD
If SIGN=1
 Gosub PAYMT : If GOK<1 : Return : Endif
 J=([F:DUD]PAMTYP=1 & find([F:DUD]TYP,"*SO","*PO"))
 If !J
  For I=NOL+1 To [M]NBLIG-1
   If [F:PYD]DUDNUM=[M]DUDNUM(I) & [F:PYD]DUDLIG=[M]DUDLIG(I)
    J=I : Break
   Endif
  Next I
 Endif
 If !J
  ## Cas particulier des escomptes/agios en Argentine :
  ##    - Le règlement d'une facture avec escompte ne doit pas venir solder la facture.
  ##      On doit avoir le comportement d'un règlement partiel. C'est la validation de la facture
  ##      d'escompte (avoir) qui doit venir solder la facture => les TMP incluent le montant de l'escompte (< au AMTCUR)
  ##    - Le règlement d'une facture avec agio ne doit pas venir solder la facture.
  ##      On doit avoir le même comportement qu'un 'sur-règlement'. C'est la validation de la facture
  ##      d'agio qui viendra solder la facture => les TMP incluent le montant de l'agio (> au AMTCUR)

  #If [F:DUD]SNS=-1 & [F:PYD]PAYCURLIN+[F:DUD]TMPCUR+[F:DUD]PAYCUR=[F:DUD]AMTCUR
  # [F:DUD]FLGPAZ = [L]MAXPAZ
  #Elsif [F:DUD]AMTCUR*([F:PYD]PAYCURLIN+[F:DUD]TMPCUR+[F:DUD]PAYCUR-[F:DUD]AMTCUR)>0
   #GMESSAGE=mess(47,116,1)-num$(NOL+1)-":"-[M]VCRTYP(NOL)-[M]VCRNUM(NOL)+"\"+mess(56,117,1)
   #GOK=0 : Return : # Ligne X : TYP-NUM - Sur-règlement non autorisé
  #Endif
  Local Decimal AMTIMPUT
  Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
  # Issue X3-103268
  #If [F:PYD]ACCTYP = 3 & [F:CDA]IPTDEP = 2 & func AFNC.PARAM("ARGDSC",[F:PYH]CPY)="2"
  If [F:PYD]ACCTYP = 3 & [F:CDA]IPTDEP = 2 & func AFNC.ACTIV("KAG") & func AFNC.PARAM("ARGDSC",[F:PYH]CPY)="2"
   AMTIMPUT = 0
  Else
   AMTIMPUT = [F:PYD]PAYCURLIN
  Endif
  If [F:DUD]SNS=-1 & AMTIMPUT+[F:DUD]TMPCUR+[F:DUD]PAYCUR=[F:DUD]AMTCUR
   [F:DUD]FLGPAZ = [L]MAXPAZ
  Elsif [F:DUD]AMTCUR*(AMTIMPUT+[F:DUD]TMPCUR+[F:DUD]PAYCUR-[F:DUD]AMTCUR)>0
   GMESSAGE=mess(47,116,1)-num$(NOL+1)-":"-[M]VCRTYP(NOL)-[M]VCRNUM(NOL)+"\"+mess(56,117,1)
   GOK=0 : Return : # Ligne X : TYP-NUM - Sur-règlement non autorisé
  Endif
 Endif
Endif
[F:DUD]TMPCUR+=SIGN*[F:PYD]PAYCURLIN
[F:DUD]TMPLOC+=SIGN*[F:PYD]PAYLOCLIN
If [F:DUD]PAMTYP=1 & find([F:DUD]TYP,"*SO","*PO")
 MT=[F:DUD]AMTCUR-[F:DUD]DINAMT-[F:DUD]IBDAMT
 [F:DUD]AMTCUR=[F:DUD]TMPCUR
 [F:DUD]AMTLOC=[F:DUD]TMPLOC
 [F:DUD]IBDAMT=[F:DUD]AMTCUR-[F:DUD]DINAMT-MT
Endif
Return

$PAYMT
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV
Call SNSPAYECH([F:PYD]ACCSNS,[F:PYH]SNS,[F:DUD]SNS,I) From SUBPAY2
[F:PYD]PAYCURLIN=[F:PYD]AMTLIN*I

# En devise société
STATOK=0
If [M]CURCPY=[F:PYD]CURLIN
 [F:PYD]PAYLOCLIN=[F:PYD]PAYCURLIN
 STATOK=1

# Montant forcé imposé...
# Inversion des Elsif...
Elsif [M]CURCPY=[F:PYH]CUR & [F:PYD]ACCTYP=1
 [F:PYD]PAYLOCLIN=sgn([F:PYD]PAYCURLIN)*abs([F:PYD]AMTLIN2-[F:PYD]RITAMT2)
 STATOK=1

#Elsif [M]CUR<>[M]CURCPY & [M]CUR=[F:PYD]CURLIN & find([F:PYD]ACCTYP,1,3) & [F:PYD]VCRNUM<>""
Elsif [M]BAN<>"" & [M]CUR=[F:PYD]CURLIN & find([F:PYD]ACCTYP,1,3) & [F:PYD]VCRNUM<>""
 Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
 If [F:TPY]RATINV = 2 : # Application cours de la facture
  Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
  If [F:BAN]CUR=[M]CURCPY or [F:BAN]CUR=[M]CUR
   Read [HAE3]HAE0 = [F:PYD]VCRTYP ; [F:PYD]VCRNUM
   If !fstat
    STATOK = 1
    Call SETFLGDEV([F:HAE3]CUR,[F:PYH]CPY,[F:HAE3]RATDAT) From CPTDIV
    COURS  = [F:HAE3]RATMLT(GTYPGEN-1)/[F:HAE3]RATDIV(GTYPGEN-1)
    COURS  = arr(COURS,10^-GDECRCU) ## Issue $104848/$79877
    If COURS<>0
     Call CONVERT3([F:PYD]CURLIN,DEVLED,DEVLED,[F:HAE3]TYPRAT,[F:HAE3]RATDAT,[F:PYD]PAYCURLIN,[F:PYD]PAYLOCLIN,
&                   COURS,STAT) From CPTSUB
     If STAT
      # Pas de cours de devises CURLIN -> DEVLED (à la date de la facture)
      GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-DEVLED-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
      GOK=0 : Return
     Endif
    Else : # En 130, on ne stockait pas les cours et le cours n'a pas été prévu d'initialiser le cours dans le passage 130->140
     Call CONVERT([F:PYD]CURLIN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:HAE3]ACCDAT,[F:PYD]PAYCURLIN,[F:PYD]PAYLOCLIN,STAT) From TRTDEV
     If STAT : # Pas de cours de devises CURLIN -> CURCPY (à la date de la facture)
      GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
      GOK=0 : Return
     Endif
    Endif
   Endif
  Endif
 Endif

Elsif [F:DUD]ACCNUM<>0 & [F:DUD]AMTCUR=[F:DUD]PAYCUR+[F:DUD]TMPCUR+[F:PYD]PAYCURLIN & LOCIN
 Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ
 If [F:TCU]EURFLG=2
  [F:PYD]PAYLOCLIN=[F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC
  STATOK=1
 Endif
Endif

If !STATOK
  #Issue 31729 – 2017-05-26  by MADOR - As a user I want to be able to compute
  #payments with the new rate currency field
  If [M]CURBAN = [F:PYD]CURLIN or  [M]AMTBAN = 0
      Call CONVERT4([F:PYD]CURLIN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT,[F:PYD]PAYCURLIN,
&                  [F:PYD]PAYLOCLIN,STAT,[F:PYH]CURRAT) From TRTDEV
  Else
      Call CONVERT([F:PYD]CURLIN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT,[F:PYD]PAYCURLIN,
&                  [F:PYD]PAYLOCLIN,STAT) From TRTDEV
  Endif
  #Issue end
  If STAT : # Pas de cours de devises CURLIN -> CURCPY (ACCDAT)
  GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
  GOK=0 : Return
 Endif
Endif

#DBA le 21/08/03 : Suggestion 19253
GPOINT = "PAY_MT" : Gosub ENTREE From EXEFNC
Return


$DEVIN
I=find([F:PYH]CPY,GSOC(1..GNBSOC-1))
If I>0 : Call LECTURE("TCU",GDEVSOC(I),"") From CONTOBJ : LOCIN=([F:TCU]EURFLG=2)
Else   : LOCIN=0
Endif
Return



##################################################################################################
## Sous-programmes liés au multi-référentiels
##################################################################################################
Subprog AFFCOL
Local Char FMT(10)
Local Integer I
For I=1 To GNBPLAN
 Call LECTURE("COA",evalue("GPLAN("+num$(I)+")"),"") From CONTOBJ
 Call LECTEXTRA([M]INTCOA(I-1),"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
 Call INIACCFMT([F:COA]COA) From SETGLBCOA
 FMT = "K:"+GFMTACC
 Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
Next
For I=GNBPLAN+1 To dim([M]FMTCOA)
 FMT = "-K:10X"
 Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
Next
For I=1 To GNBAXE
 Call LECTURE("DIE",evalue("GAXE("+num$(I)+")"),"") From CONTOBJ
 Call LECTEXTRA([M]INTDIE(I-1),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
 Gosub INTIT_CCE
 Call INICCEFMT([F:DIE]DIE) From SETGLBDIE
 Call SAI_AMONT([M]CPY,GNBTYPLED,GTYPLED,evalue("GAXE("+num$(I)+")"),[M]SAIAXE(I-1)) From CPTDIV
 If [M]SAIAXE(I-1)=2
  FMT = "K:"+GCCEFMT
 Else
  FMT = "-K:"+GCCEFMT
 Endif
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
 If clalev([M:VT2])
  Assign "[M:VT2]TBDIE("+num$(I-1)+")" With GAXE(I)
 Endif
Next
For I=GNBAXE+1 To dim([M]FMTDIE)
 FMT = "-K:10X"
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
 If clalev([M:VT2])
  Assign "[M:VT2]TBDIE("+num$(I-1)+")" With ""
 Endif
Next
zoncou = "NBLIG"
[M]NBLIG=1
If GNBAXE>0
 Affzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
 Affzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
Endif
[M]NBLIG=0
If GNBAXE>0
 Effzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
 Effzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
Endif
End


$INTIT_CCE
Gosub DEFMSKLIG
Case I
 When 1  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE1
 When 2  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE2
 When 3  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE3
 When 4  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE4
 When 5  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE5
 When 6  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE6
 When 7  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE7
 When 8  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE8
 When 9  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE9
 When 10 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE10
 When 11 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE11
 When 12 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE12
 When 13 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE13
 When 14 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE14
 When 15 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE15
 When 16 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE16
 When 17 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE17
 When 18 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE18
 When 19 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE19
 When 20 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE20
Endcase
Return


$SETCHPLST
If NOL>=0
 Raz [M]LSTLED(NOL), [M]LSTACC(NOL), [M]LSTAXE
 Local Integer I, NLED, TLED
 For NLED=1 To GNBPLAN
  Gosub SETCHPLED
 Next
 Gosub SETCHPAXE
Endif
Return

$SETCHPLST2
If NOL>=0
 Raz [M]LSTLED(NOL), [M]LSTACC(NOL), [M]LSTAXE
 Local Integer I, NLED, TLED
 For NLED=1 To GNBPLAN
  Gosub SETCHPLED2
 Next
 Gosub SETCHPAXE
Endif
Return

$SETCHPLED
If NOL>=0
 TLED = GTYPLED(NLED) : Gosub LECLED
 If NLED>1
  [M]LSTLED(NOL) += ";" : [M]LSTACC(NOL) += ";"
 Endif
 [M]LSTLED(NOL) += [L]LED
 [M]LSTACC(NOL) += evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
Endif
Return

$SETCHPLED2
If NOL>=0
 If NLED>1
  [M]LSTLED(NOL) += ";" : [M]LSTACC(NOL) += ";"
 Endif
 [M]LSTLED(NOL) += LLED(NLED)
 [M]LSTACC(NOL) += evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
Endif
Return

$SETCHPAXE
For I=1 To GNBAXE
 [M]LSTAXE += GAXE(I) : [M]LSTAXE+=";"
Next
If GNBAXE>0
 [M]LSTAXE = left$([M]LSTAXE,len([M]LSTAXE)-1)
Endif
Return

$LECLED
Local Char LED(GLONLED)
Local Char DEV(GLONCUR)
Call LECLED([M]CPY,[L]TLED,LED,DEV) From CPTDIV
Call LECTURE("LED",[L]LED,"") From CONTOBJ
Return


$RECH_ACCANA
Local Char PLANA(GLONCOA), CPTANA(GLONGAC)
Local Char TPLAN(GLONCOA)(1..dim([M]FMTCOA)), TCOMPTEX(GLONGAC)(1..dim([M]FMTCOA))
Local Integer II
For II=1 To GNBPLAN
 TPLAN(II)   = GPLAN(II)
 TCOMPTEX(II) = evalue("[M]ACC"+num$(II)+"("+num$(NOL)+")")
Next
Call RECH_ACC(2,GSOCIETE,GTYPLED,GNBPLAN,TPLAN,TCOMPTEX,PLANA,CPTANA) From CPTDIV
Return

$SETNOL
Local Integer NOL
NOL=nolign-1
Return
###################################################################################################
###################################################################################################
$INI_COM
Gosub DEFMSKLIG From SUBPAY3

If func AFNC.ACTIV("KPO")
  For I=0 To [M]NBLIG-1
    If [M]VCRNUM(I)<>''
      [F:PYH]CSHVATRGM = func PORLEGLIB.CSHVATREG([F:PYH]BPR,[M]VCRNUM(I))
      Break
    Endif
  Next
Endif

If [F:PYH]CSHVATRGM = 0 : [F:PYH]CSHVATRGM = 1 : Endif

If [F:PYH]CSHVATRGM=2
  For I=0 To [M]NBLIG-1
    If [M]VCRNUM(I)=''
      Read [F:CDA]CDA0=[M]DENCOD(I)
      If !fstat
        If [F:CDA]ACCTYP=1
          GOK      = 0
          GMESSAGE = mess(68,7711,1)
          GERR     = 1
          Break
        Endif
      Endif
    Endif
  Next
Endif
Return
###################################################################################################
###################################################################################################
$APRES_COM
If func AFNC.ACTIV("KPO")
  If [F:PYH]SNS<>2 : Return : Endif
  If [F:PYH]CSHVATRGM=2
    Local Integer POK : POK = 0
    Call UPD_PYHV([F:PYH]NUM,1,POK)
    If POK = 0
      Call ECR_TRACE(mess(66,7711,1),1) From GESECRAN
    Endif
  Else
    Call DEL_PYHV([F:PYH]NUM)
  Endif
Endif
Return
###################################################################################################
###################################################################################################
$VERIF_CRE

Call VERIF_SAI(OK) From SUBPAY2
If zonsui<>"" : SUIZON=zonsui : Endif

Return
###################################################################################################
###################################################################################################
$VERIF_MOD

Call VERIF_SAI(OK) From SUBPAY2
If zonsui<>"" : SUIZON=zonsui : Endif

Return
###################################################################################################
###################################################################################################
Subprog UPD_PYHV(NUM,PAYMENTSTA,RET)
#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
#Open Variables
Value Char         NUM
Value Integer      PAYMENTSTA
#Exit variables
Variable  Integer  RET

#Open Tables
Local File PAYVAT     [PYHV]
Local File PAYMENTH   [PYH]
Local File PAYMENTD   [PYD]
Local File PAYMENTD   [PY2]
Local File SINVOICE   [SIH]
Local File SINVOICED  [SID]
Local File PINVOICE   [PIH]
Local File TABRATVAT  [TRA]
Local File TABCUR     [TCU]

#Variables
Local Decimal  ALFA                    : [L]ALFA         = 0
Local Decimal  TOTALPAGO               : [L]TOTALPAGO    = 0
Local Decimal  TOTALPAGOLOC            : [L]TOTALPAGOLOC = 0
Local Decimal  RATCUR                  : [L]RATCUR       = 0
Local Char     PREVDOC(GLONVCR)        : [L]PREVDOC      = ""
Local Shortint PADXLOG                 : [L]PADXLOG      = adxlog
Local Integer  PPYD                    : [L]PPYD         = 0
Local Integer  VATRATIDX               : [L]VATRATIDX    = 0
Local Integer  VATDIM                  : [L]VATDIM       = dim([F:PYHV]VATRAT)
Local Decimal  VATRATCTR([L]VATDIM)
Local Shortint VATRATZCTR              : [L]VATRATZCTR   = 0
Local Integer  I, J, K

Delete [F:PYHV] Where [F:PYHV]PAYNUM = [L]NUM & [F:PYHV]PAYMENTSTA = [L]PAYMENTSTA
#To avoid message in case there is no filled VCRNUM
[L]RET=-1

Link [F:PYD] With [F:PYH]PYH0=[F:PYD]NUM As [LPAY1]
&   Where [F:PYH]NUM=[L]NUM & [F:PYH]SNS=2 & [F:PYD]VCRNUM<>''
&   Order By [F:PYD]VCRNUM

For [LPAY1]
  If [L]PREVDOC <> "" & [L]PREVDOC <> [F:PYD]VCRNUM
    Gosub TRT_DOC
    Raz [L]TOTALPAGOLOC,[L]TOTALPAGO,[L]ALFA
  Endif

  [L]TOTALPAGO    += [F:PYD]AMTLIN
  [L]TOTALPAGOLOC += [F:PYD]PAYLOCLIN #Has value if VCRNUM <>''
  [L]PREVDOC       = [F:PYD]VCRNUM
  [L]PPYD          = [F:PYD]LIN
Next

Gosub TRT_DOC
Close File [F:LPAY1]

If [L]VATRATIDX > 1
  Gosub REORDER_VATRAT
Endif

End

$TRT_DOC

  Raz [F:PYHV]
  [F:PYHV]PAYLIN      = [L]PPYD
  [F:PYHV]PAYNUM      = [F:PYH]NUM
  [F:PYHV]INVNUM      = [L]PREVDOC
  [F:PYHV]PAYMENTSTA  = [L]PAYMENTSTA
  If [L]PAYMENTSTA = 2
    [F:PYHV]REVERSALDAT = date$
  Endif

  [F:PYHV]BPRNUM    = [F:PYH]BPR
  [F:PYHV]ACCDAT    = [F:PYH]ACCDAT

  Raz [F:TCU]

  #Sales Invoice
  Read [F:SIH]SIH0 = [L]PREVDOC
  If !fstat
    If [L]PADXLOG = 0
      Trbegin [F:PYHV]
    Endif

    [F:PYHV]SNS = [F:SIH]SNS
    [L]ALFA     = [L]TOTALPAGO/[F:SIH]AMTATI

    Read [F:TCU]TCU0 = [F:SIH]CUR

    For I=0 To dim([F:PYHV]AMTTAX)-1
      #[L]RATCUR = [F:SIH]RATMLT(I)
      [L]RATCUR = [L]TOTALPAGOLOC/[L]TOTALPAGO
      If [L]RATCUR = 0 : [L]RATCUR = 1 : Endif
      #[F:PYHV]AMTTAX(I) = [L]ALFA * [F:SIH]AMTTAX(I) * [L]RATCUR
      [F:PYHV]AMTTAX(I) = arr([L]ALFA * [F:SIH]AMTTAX(I) * [L]RATCUR,[F:TCU]CURRND)
      #[F:PYHV]BASTAX(I) = [L]ALFA * [F:SIH]BASTAX(I) * [L]RATCUR
      [F:PYHV]BASTAX(I) = arr([L]ALFA * [F:SIH]BASTAX(I) * [L]RATCUR,[F:TCU]CURRND)
      [F:PYHV]TAX(I)    = [F:SIH]TAX(I)

      Filter [F:TRA] Where VAT=[F:SIH]TAX(I) & CPY=[F:PYH]CPY & STRDAT<=[F:SIH]ACCDAT Order By [F:TRA]STRDAT Desc
      Read [F:TRA] First
      If fstat
        Filter [F:TRA] Where VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT Order By [F:TRA]STRDAT Desc
        Read [F:TRA] First
        If !fstat
           [F:PYHV]VATRAT(I) = [F:TRA]VATRAT
        Endif
      Else
        [F:PYHV]VATRAT(I) = [F:TRA]VATRAT
      Endif
      If !find([F:PYHV]VATRAT(I),VATRATCTR)
        [L]VATRATCTR([L]VATRATIDX) = [F:PYHV]VATRAT(I)
        [L]VATRATIDX += 1
        If [F:PYHV]VATRAT(I) = 0 & [F:PYHV]BASTAX(I) <> 0
          [L]VATRATZCTR = 1
        Endif
      Endif
    Next

    [F:PYHV]CREDAT = [F:PYH]CREDAT
    [F:PYHV]UPDDAT = [F:PYH]UPDDAT
    [F:PYHV]CREUSR = [F:PYH]CREUSR
    [F:PYHV]UPDUSR = [F:PYH]UPDUSR
    Write [F:PYHV]
    If !fstat
      If [L]PADXLOG = 0
        Commit
      Endif
      [L]RET = 1
    Else
      If [L]PADXLOG = 0
        [L]RET=0
        Rollback
      Else
        [L]RET=0
        [V]GOK=0
      Endif
    Endif
 Else
  #Purchase Invoice
  Read [F:PIH]PIH0 = [L]PREVDOC
    If !fstat
      If [L]PADXLOG = 0
        Trbegin [F:PYHV]
      Endif

      [F:PYHV]SNS         = -1 * [F:PIH]SNS

      [L]ALFA = [L]TOTALPAGO/[F:PIH]AMTATI

      Read [F:TCU]TCU0 = [F:PIH]CUR

      For I=0 To dim([F:PYHV]AMTTAX)-1
        #[L]RATCUR = [F:PIH]RATMLT(I)
        [L]RATCUR = [L]TOTALPAGOLOC/[L]TOTALPAGO
        If [L]RATCUR = 0 : [L]RATCUR = 1 : Endif
        #[F:PYHV]AMTTAX(I) = [L]ALFA * [F:PIH]AMTTAX(I) * [L]RATCUR
        [F:PYHV]AMTTAX(I) = arr([L]ALFA * [F:PIH]AMTTAX(I) * [L]RATCUR,[F:TCU]CURRND)
        #[F:PYHV]BASTAX(I) = [L]ALFA * [F:PIH]BASTAX(I) * [L]RATCUR
        [F:PYHV]BASTAX(I) = arr([L]ALFA * [F:PIH]BASTAX(I) * [L]RATCUR,[F:TCU]CURRND)
        [F:PYHV]TAX(I)    = [F:PIH]TAX(I)

        Filter [F:TRA] Where VAT=[F:PIH]TAX(I) & CPY=[F:PYH]CPY & STRDAT<=[F:PIH]ACCDAT Order By [F:TRA]STRDAT Desc
        Read [F:TRA] First
        If fstat
          Filter [F:TRA] Where VAT=[F:PIH]TAX(I) & STRDAT<=[F:PIH]ACCDAT Order By [F:TRA]STRDAT Desc
          Read [F:TRA] First
          If !fstat
            [F:PYHV]VATRAT(I) = [F:TRA]VATRAT
          Endif
        Else
          [F:PYHV]VATRAT(I) = [F:TRA]VATRAT
        Endif
        If !find([F:PYHV]VATRAT(I),VATRATCTR)
          [L]VATRATCTR([L]VATRATIDX) = [F:PYHV]VATRAT(I)
          [L]VATRATIDX += 1
          If [F:PYHV]VATRAT(I) = 0 & [F:PYHV]BASTAX(I) <> 0
            [L]VATRATZCTR = 1
          Endif
        Endif
      Next

      [F:PYHV]CREDAT = [F:PYH]CREDAT
      [F:PYHV]UPDDAT = [F:PYH]UPDDAT
      [F:PYHV]CREUSR = [F:PYH]CREUSR
      [F:PYHV]UPDUSR = [F:PYH]UPDUSR
      Write [F:PYHV]
      If !fstat
        If [L]PADXLOG = 0
          Commit
        Endif
        [L]RET = 1
      Else
        If [L]PADXLOG = 0
          [L]RET=0
          Rollback
        Else
          [L]RET=0
          [V]GOK=0
        Endif
      Endif
    Endif
 Endif

Return

Subprog DEL_PYHV(NUM)
#Open Variables
Value Char         NUM
#Exit Variables
Local File PAYVAT    [PYHV]

Delete [F:PYHV] Where [F:PYHV]PAYNUM = [L]NUM

End
#94635 RICAR 2014/04/21 - CASH VAT - END
###################################################################################################
###################################################################################################
$REORDER_VATRAT

Local Char    SAVTAX(GLONVAT)([L]VATDIM)
Local Decimal SAVVATRAT([L]VATDIM), SAVBASTAX([L]VATDIM), SAVAMTTAX([L]VATDIM)
Local Decimal PYHAMTCUR, GROSSTOTAL
Local Integer PYHVLINES, CURPYH, TAXFLG, LASTINDEX
Sorta [L]VATRATCTR

[L]CURPYH=0
[L]GROSSTOTAL = 0
For [F:PYHV] Where [F:PYHV]PAYNUM = [F:PYH]NUM & [F:PYHV]PAYMENTSTA = [L]PAYMENTSTA
  [L]CURPYH+=1
  For I = 0 To [L]VATDIM-1
    SAVTAX([L]I)    = [F:PYHV]TAX([L]I)    : Raz [F:PYHV]TAX([L]I)
    SAVVATRAT([L]I) = [F:PYHV]VATRAT([L]I) : Raz [F:PYHV]VATRAT([L]I)
    SAVBASTAX([L]I) = [F:PYHV]BASTAX([L]I) : Raz [F:PYHV]BASTAX([L]I)
    SAVAMTTAX([L]I) = [F:PYHV]AMTTAX([L]I) : Raz [F:PYHV]AMTTAX([L]I)

    [L]GROSSTOTAL += SAVBASTAX([L]I)+SAVAMTTAX([L]I)
  Next
  [L]J = 0
  For [L]I = 0 To [L]VATDIM-1
    If [L]I > 0 & ([L]VATRATCTR([L]I) = [L]VATRATCTR([L]I-1)) : Goto NEXTAX : Endif
     If [L]VATRATCTR([L]I)=0
      For [L]K = 0  To [L]VATDIM-1
        If SAVVATRAT([L]K) = [L]VATRATCTR([L]I) and SAVTAX([L]K) <> ''
          [F:PYHV]TAX([L]J)    = SAVTAX([L]K)
          [F:PYHV]VATRAT([L]J) = SAVVATRAT([L]K)
          [F:PYHV]BASTAX([L]J) = SAVBASTAX([L]K)
          [F:PYHV]AMTTAX([L]J) = SAVAMTTAX([L]K)
          [L]J+= 1
        Endif
      Next
     Else
     TAXFLG = 0
      For [L]K = 0  To [L]VATDIM-1
        If SAVVATRAT([L]K) = [L]VATRATCTR([L]I) and SAVTAX([L]K) <> ''
          [F:PYHV]TAX([L]J)    = SAVTAX([L]K)
          [F:PYHV]VATRAT([L]J) = SAVVATRAT([L]K)
          [F:PYHV]BASTAX([L]J) += SAVBASTAX([L]K)
          [F:PYHV]AMTTAX([L]J) += SAVAMTTAX([L]K)
        TAXFLG = 1
        Endif
      Next
      If TAXFLG : [L]J+= 1 : Endif
     Endif
    $NEXTAX
  Next

  If[L]GROSSTOTAL <> [L]TOTALPAGO
   [F:PYHV]AMTTAX([L]J-1) += ([L]TOTALPAGO-[L]GROSSTOTAL)
  Endif
  [L]GROSSTOTAL = 0
  Rewrite [F:PYHV]
Next
Return
###################################################################################################
###################################################################################################
$GESBCREG_DISPLAY

If func AFNC.ACTIV("REGBC")

  If GFONCTION1 = 'GESBCREG'
    Diszo [M:PAY1]FCY
    Diszo [M:PAY1]BAN
    Affzo [M:PAY1]
    Affzo [M:PAY0]REGNUM
    If [M:BCREG0]STA = 2
      Diszo [M:PAY0]
      Diszo [M:PAY1]
    Endif
  Endif

Endif

Return
###################################################################################################
###################################################################################################
$GESBCREG_SETBOUT

If CLOSED_BCREG
  Call VIREBOUT (CHAINE, "ACN") From GOBJET
Endif

Return
###################################################################################################
###################################################################################################
$GESBCREG_RAZCRE

If func AFNC.ACTIV("REGBC")

  If GFONCTION1 = 'GESBCREG'

    [M:PAY0]REGNUM = [M:BCREG0]REGNUM

    [M:PAY1]FCY = [M:BCREG0]FCY
    Call AS_FCY([M:PAY1]FCY) From SUBPAY
    Call AP_FCY([M:PAY1]FCY) From SUBPAY
    Call AM_FCY([M:PAY1]FCY) From SUBPAY

    [M:PAY1]BAN = [M:BCREG0]REGCOD
    Call C_BAN([M:PAY1]BAN) From SUBPAY
    Call AP_BAN([M:PAY1]BAN) From SUBPAY
    Call AM_BAN([M:PAY1]BAN) From CHKLIB

    [M:PAY1]ACCDAT = [M:BCREG0]FINDAT

    [M:PAY1]CUR = [M:BCREG0]CUR
    Call AS_CUR([M:PAY1]CUR) From SUBPAY
    Call C_CUR([M:PAY1]CUR) From SUBPAY
    Call AP_CUR([M:PAY1]CUR) From SUBPAY

    Gosub GESBCREG_DISPLAY

  Endif

Endif

Return
###################################################################################################
###################################################################################################
$REGNUM_DISPLAY

Local Char DISPLAY(1)

If func AFNC.ACTIV("REGBC")
  If GFONCTION1 = 'GESBCREG' | [F:PYH]REGNUM<>''
    DISPLAY = '+'
  Else
    DISPLAY = '-'
  Endif

  Chgfmt [M:PAY0]REGNUM  With DISPLAY+"K:20X"
  Affzo [M:PAY0]REGNUM
Endif

Return
###################################################################################################
###################################################################################################
$SET_FROM_GESBCREG

If func AFNC.ACTIV("REGBC")& GFONCTION1 = 'GESBCREG'
  FROM_GESBCREG = 1
Endif

Return
###################################################################################################
###################################################################################################
$SET_CREATION_MODE

If FROM_GESBCREG & SAVCLE1 = ''
  If [M:BCREG0]STA <> 2
    If clalev([F:PYHA])=0 : Local File PAYMENTH [PYHA] : Endif
    Filter [F:PYHA] Where [F:PYHA]REGNUM = [M:BCREG0]REGNUM & [F:PYHA]PAYTYP = GFLAG
    If (rowcount([F:PYHA])) = 0
      CREATION_MODE = 1
    Endif
    Filter [F:PYHA]
  Endif
Endif

Return
###################################################################################################
###################################################################################################
$SET_CLOSED_BCREG

If FROM_GESBCREG
  If [M:BCREG0]STA = 2
    CLOSED_BCREG = 1
  Endif
Endif

Return
###################################################################################################
###################################################################################################
$AVANT_CHOI

# ISSUE 39256 - 2017-08-30 MRDAB - Enter payments from BCREG
# creation mode when arriving from GESBCREG
If CREATION_MODE
  CREATION_MODE = 0
  REPONSE=GSTANEW
  Gosub NOUVEAU From GOBJSUB
  Gosub SETBOUT From GOBJSUB
Endif
# ISSUE END

Return
###################################################################################################
###################################################################################################
$UPDATE_REGLP

#ISSUE 39265 – 2017-08-23  By MADOR
# Issue X3-103268
#If (func AFNC.PARAM("BCREG", GFLAGLEG) = "2" & func AFNC.ACTIV("REGBC") & GFONCTION1 = 'GESBCREG')
If (func AFNC.ACTIV("REGBC") & func AFNC.PARAM("BCREG", GFLAGLEG) = "2" & GFONCTION1 = 'GESBCREG')
  Local Integer I : I = 1
  If clalev([F:PYH2])=0 : Local File PAYMENTH [PYH2] : Endif
  Filter [F:PYH2] Where [F:PYH2]REGNUM = [F:PYH]REGNUM Order By [F:PYH2]CREDATTIM
  For [F:PYH2]
    [F:PYH2]REGLP = I
    Rewrite [PYH2]
    I += 1
  Next
  Filter [F:PYH2]
Endif
#ISSUE end

Return
###################################################################################################
# Drives the ACCDAT modification ability on the payments based on GESTPY transaction settings
# and the status of the payment
###################################################################################################
$ACCDAT_AVAILABILITY
  Local Tinyint LTRESHOLD : [L]LTRESHOLD = 0

  If ([F:TPY]STA3 = 2)
    [L]LTRESHOLD = 3
  Elsif ([F:TPY]STA8 = 2)
    [L]LTRESHOLD = 8
  Elsif ([F:TPY]STA9 = 2)
    [L]LTRESHOLD = 9
  Endif

  If ([L]LTRESHOLD > 0 & [F:PYH]STA >= [L]LTRESHOLD)
    Diszo [M:PAY1]ACCDAT
  Endif

Return
