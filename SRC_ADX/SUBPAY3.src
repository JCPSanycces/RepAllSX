#<AdxTL>@(#)12.0.0.0 $Revision$
#***********************************************************************************************************************#
#    Modification                                                                                                       #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX                                                              #
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE
# CBO   08.08.2017 X3-47770  add BPARTNER table in link                                                                 #
# BEFOU 18.08.2017 X3-52623 GESPAY: after click on New message                                                          #
#                                      "Site" MANDATORY Field                                                           #
# MWA   28.09.2017 X3-56680  add GACCENTRYD table in link                                                               #
# FPE   14.11.2017 X3-61594 : Journal traceability displays wrong                                                       #
#                             company currency.                                                                         #
# Bader 2018-03-16 X3-81475 APRES_MODIF: When user didn't click "New" > enforce RAZCRE for correct initialization       #
# BEFOU 30.08.2018 X3-76133 Adding Load of classe F of PYH      before "APRES_MODIF"                                    #
#                                                                                                                       #
#########################################################################################################################

GFLAG=""
Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS
 When "VARIANTE"     : Gosub VARIANTE
 When "L_VARIANTE"   : Gosub L_VARIANTE
 When "P_VARIANTE"   : Gosub P_VARIANTE
 When "SETTRANS"     : Gosub SETTRANS
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "BOITE"        : Gosub BOITE
 When "TITRE"        : Gosub TIT
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "LIENS"        : Gosub LIENS
 When "FILTRE"       : Gosub FILTRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "STATUT"       : Gosub STATUT
 When "AVANT_SUITE"  : Gosub AVANT_SUITE
 When "AFFMASK"      : Gosub INIMSK
 When "EFFMASK"      : Gosub EFFMASK
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "ABANDON"      : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "AVANT_CHOI"   : Gosub AVANT_CHOI
 When "VERF_ANU"     : Gosub VERF_ANU
 When "AV_ANNULE"    : Gosub AV_ANNULE
 When "AV_IMPRIME"   : Gosub AV_IMPRIME
 When "AP_IMPRIME"   : Gosub AP_IMPRIME
 When "TIROIR"       : Gosub RAF_ECHE   From SUBPAY4
 When "GAUCHE"       : Gosub GAUCHE     From SUBPAY4
 When "FILGAUCHE"    : Gosub FILGAUCHE  From SUBPAY4
 When "PICKE"        : Gosub PICKE      From SUBPAY4
 When "DEPICK"       : Gosub DEPICK     From SUBPAY4
 When "FIN_PICK"     : Gosub FIN_PICK   From SUBPAY4
 When "FIN_ACTION"   : Gosub FIN_ACTION From SUBPAY4
 When "HINT"         : Gosub HINT_KEY   From SUBPAY4

 When "AB3_VCRNUM"   : Local Char VALC2(20) : [L]VALC2=VALEUR
                       Gosub AB3_FACCDE From SUBPAY2
 When "BB3_VCRNUM"   : Gosub BB3_FACCDE From SUBPAY2
 When "AB3_NBLIG"    : Local Char VALC2(20) : [L]VALC2=[M]VCRNUM(nolign-1)
                       Gosub AB3_FACCDE From SUBPAY2
 When "BB3_NBLIG"    : Gosub BB3_FACCDE From SUBPAY2
 When "EXEACT"       : Case BOUT
                        When "E","C" : Gosub AJUST From SUBPAY2
                       Endcase
 When "DROIT"        : AMA(4)=2
 When "AP_ANNULE"    : Gosub AP_ANNULE From SUBPAY3
 When "APRES_ANNULE" : Gosub APRES_ANNULE
Endcase
Return

$APRES_CHOI
Case REPONSE
 When GSTARET, GSTAENR, GSTACRE
  If [M]NBLIG=0 & [M]AMTCUR<>0 & [F:TPY]DENDEF<>""
   I=0
   Call LEC_CDA_LEG(GCURLEG,[F:TPY]DENDEF) From CPTLEC
   If fstat=0 & [F:CDA]ACCTYP=1 : # Banque<=>Tiers
    If dim([F:CDA]ACS)>0
     Call CONTEXE([F:CDA]ACS) From CPTSUB
     If mkstat : mkstat=0 : I=0 : Else I=1 : Endif
    Else I=1
    Endif
   Endif
   If I
    Raz [F:DUD]
    Call SIGN2([F:CDA]ACCSNS,[M]SNS,0,0,0,I) From PAYDIV
    Call CHARGE_LIG(I*[M]AMTCUR,0) From SUBPAY4
   Endif
  Endif
  [L]VALC1=""
  Gosub LEC_PAYRNDCDA
  If [L]PAYRNDCDA1<>"" & [L]PAYRNDCDA2<>"" & [M]NBLIG<>0 & [M]NBLIG+2<=dim([M]AMTLIN2)
&    & abs([M]AMTCUR-sum([M]AMTLIN2))<=[L]PAYRNDMAX
   For NOL=0 To [M]NBLIG-1
    If [M]ACCTYP(NOL)=1 & [M]CURLIN(NOL)<>[M]CUR : [L]VALC1="2" : Break : Endif
   Next NOL
  Endif
Endcase
Return

$LEC_PAYRNDCDA
Local Char    PAYRNDCDA1(GLONCDA), PAYRNDCDA2(GLONCDA)
Call PARAM([M]CPY,"PAYRNDCDA1",[L]PAYRNDCDA1) From ADOVAL
If [L]PAYRNDCDA1<>""
 Call LEC_CDA_LEG(GCURLEG,[L]PAYRNDCDA1) From CPTLEC
 If [F:CDA]ACCTYP<>1 | [F:CDA]ACCBPR<>"" : [L]PAYRNDCDA1=""
 Elsif dim([F:CDA]ENAFLG)>0 & [F:CDA]ENAFLG<>2 : [L]PAYRNDCDA1=""
 Elsif dim([F:CDA]ACS)>0 & [F:CDA]ACS<>""
  Call CONTEXE([F:CDA]ACS) From CPTSUB
  If mkstat : mkstat=0 : GMESSAGE="" : [L]PAYRNDCDA1="" : Endif
 Endif
Endif
Call PARAM([M]CPY,"PAYRNDCDA2",[L]PAYRNDCDA2) From ADOVAL
If [L]PAYRNDCDA2<>""
 Call LEC_CDA_LEG(GCURLEG,[L]PAYRNDCDA2) From CPTLEC
 If [F:CDA]ACCTYP<>3  : [L]PAYRNDCDA2=""
 Elsif dim([F:CDA]ENAFLG)>0 & [F:CDA]ENAFLG<>2 : [L]PAYRNDCDA2=""
 Elsif dim([F:CDA]ACS)>0 & [F:CDA]ACS<>""
  Call CONTEXE([F:CDA]ACS) From CPTSUB
  If mkstat : mkstat=0 : GMESSAGE="" : [L]PAYRNDCDA2="" : Endif
 Endif
Endif
Return

$OK_MODIF
OK=1
If GREP="" & CLECUR : # A-t-on droit à la modification ?
 If !ACTMOD | GCONSULT : OK=0
 Elsif !VERROU
  Gosub VERROU From GOBJET
  If !VERROU
   GMESSAGE=mess(10,100,1) : OK=0 : Return
  Else
   AFFICHE=0 : Gosub RELIT From GOBJSUB
   Gosub SETBOUT From GOBJSUB
   If !ACTMOD : OK=0 : Endif
  Endif
 Endif
 If !OK : # Modification impossible
  GMESSAGE=mess(9,123,1)
 Elsif [F:PYH]STA>=9 | [F:PYH]STAFLG(2)=2 | [F:PYH]STAFLG(7)=2
  # Règlement comptabilisé - Modification impossible
  GMESSAGE=mess(54,117,1)+"\"+mess(9,123,1) : OK=0 : Return
 Endif
Endif
Return

$DEFTRANS
# Variables utile pour gestion de la Transaction - avant $OUVRE
Local Char WINLEG(GLONADI),NEW_DES(100) :#j'ai mis 100 mais [F:AXX]TEXTE sur 80...
#

If GTUNCPT(8) : GMESSAGE = mess(247,199,1) : OK = 0 : Return : Endif

# Legislation of the current transaction (can be empty)
# Législation de la transaction courante (peut donc être vide)
Global Char GFLAGLEG(GLONADI)

If TUNNEL & SAVCLE1<>""
# When we come from a tunnel, we have to select the right transaction :
 # it means with the payment transaction's code, and concerning the right company legislation
 If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
 If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
 Global Char GPYHCPYLEG(GLONADI)
 Read [PYH]PYH0 = SAVCLE1
 If !fstat
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  GPYHCPYLEG = [F:CPY]LEG
  Raz [F:TPY]
  Call LEC_TPY_LEG(GPYHCPYLEG,[F:PYH]PAYTYP) From CPTLEC
  GFLAG    = [F:TPY]PAYTYP
  GFLAGLEG = [F:TPY]LEG
 Endif
Endif
If GFLAG=""
 Local Char USRTRN(GLONTPY),USRLEG(GLONADI)
 Raz USRTRN, USRLEG
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Call PARAMUTIL("TRANSREG",USRTRN,"","") From SUBAUS
 Call PARAMUTIL("LEGFIL",USRLEG,"","") From SUBAUS
 If USRTRN<>""
  Call LEC_TPY_LEG(USRLEG,USRTRN) From CPTLEC
  If !fstat
   If [F:TPY]ENAFLG<>2 : Raz GFLAG : Return : Endif
   If [F:TPY]ACS<>""
    If clalev([F:ACC])=0  : Local File ACCES  [ACC] : Endif
    Read [ACC] CODACC=GUSER;[F:TPY]ACS
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Return : Endif
   Endif
   GFLAG    = [F:TPY]PAYTYP
   GFLAGLEG = [F:TPY]LEG
  Endif
 Endif
Endif

# Initialization GBOITE + GSAVGFLAG
Global Char GSAVGFLAG(GLONTPY)
GSAVGFLAG = ""
Read [AWI]AWI0 = "WOPY"+GFLAG+GFLAGLEG
If !fstat & [F:AWI]ENAFLG=2
 GBOITE="WOPY"+GFLAG+GFLAGLEG
 GSAVGFLAG = GFLAG
 GFLAG=""
Endif
Return

$VARIANTE
# Initialization GFLAG when we come from a tunnel
If GBOITE<>"" & GSAVGFLAG<>""
 If GFLAG="" &  GBOITE=[F:AWI]WIN
  GFLAG = GSAVGFLAG
 Else
  OK=0
 Endif
 Return
Endif

WINLEG = right$([F:AWI]WIN,len("WYPO"+[F:AWI]TRN)+1)
If TUNNEL & dim(GPYHCPYLEG)>0 & GFLAG=""
 #On peut ici choisir de ne présenter que les transactions pour la législation de
 #société de la facture en cours et celles pour toutes législations
 If WINLEG<>"" & WINLEG<>GPYHCPYLEG
  OK=0
 Endif
Elsif GLEGFIL<>""
 If WINLEG<>"" & WINLEG<>GLEGFIL
  OK=0
 Elsif WINLEG=""
  Look [TPY]TPY0 = [F:AWI]TRN;GLEGFIL
  If !fstat
    OK=0
  Endif
 Endif
Endif

# ISSUE 39268 - 2017-06-13 MANOW - GESPAY - unable to select transaction dedicated to cash/bank register
  Read [F:TPY]TPY0 = [F:AWI]TRN;WINLEG
  If fstat
    OK=0
  Else
    #ISSUE 60081 - 2017-10-20 by MRDAB
    If func AFNC.ACTIV("REGBC")
      If [F:TPY]DACREGNUM = 2 & GFONCTION1 <> 'GESBCREG'
        OK = 0
      Elsif GFONCTION1 = 'GESBCREG'
        If ([F:TPY]BANCSH = [M:BCREG0]REGTYP and func AFNC.PARAM("BCREG", [F:TPY]LEG) = "2" )
          Filter [F:BAN] Where [F:BAN]INPAYTRA = [F:TPY]PAYTYP or [F:BAN]OUTPAYTRA = [F:TPY]PAYTYP
          Read [F:BAN]BAN0 = [M:BCREG0]REGCOD
          If fstat
            OK = 0
          Endif
          Filter [F:BAN]
        Else
          OK = 0
        Endif
      Endif
    Endif
    #ISSUE END
  Endif
# ISSUE END

Return

$L_VARIANTE
#ENG: Supervisor gives us a hand here to set rights titles in the translation's selectBox
#FRA: Le superviseur nous a donné la main ici pour disposer des bons intitulés
#dans la fenêtre de selection de transaction
WINLEG = right$([F:AWI]WIN,len("WYPO"+[F:AWI]TRN)+1)
Call LECTEXTRA(NEW_DES,"TABPAYTYP","DESTRA",[F:AWI]TRN,WINLEG) From ATEXTRA
VARITEX(VARINB) = format$("K:8X",[F:AWI]TRN)+format$("K:8X",WINLEG)+NEW_DES
Return

$P_VARIANTE
#If TUNNEL & SAVCLE1<>""
# GBOITE="WOPY"+GFLAG+GFLAGLEG
#Endif
Return

$TIT
Call LEC_TPY_LEG(GFLAGLEG,GFLAG) From CPTLEC
Call LECTEXTRA(TIT,"TABPAYTYP","DESTRA",GFLAG,GFLAGLEG) From ATEXTRA
Return

$SETTRANS
# GFLAG  Transaction Code Selected / Code de la transaction choisie
# GBOITE Window Name Selected / Nom de la fenêtre choisie
#   |-> We could know the code legislation associated to the Selected transaction due to the name of this one
#   |-> On peut connaitre le code LEG associé à la selection par le nom de celle-ci

#Destruction de cette globale qui ne sert que pour VARIANTE
If dim(GPYHCPYLEG)>0 : Kill GPYHCPYLEG : Endif
If dim(GSAVGFLAG)>0  : Kill GSAVGFLAG : Endif

If clalev ([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If GBOITE<>"" & GFLAG<>""
 GFLAGLEG = right$(GBOITE,len("WYPO"+GFLAG)+1)
 Read [TPY]TPY0 = GFLAG;GFLAGLEG
 GGRPFCY = [F:TPY]GFY
Endif
Return

$OUVRE
Local Integer OK_PICK
Local Char SVG_GFONC1 : SVG_GFONC1 = GFONC1
GTUNCPT(8) = 1
# Détermination du type de règlement
Onerrgo ERREUR From CONTROLE
If clalev([M:VTL])=0 : Local Mask VENTILE   [VTL]  : Endif
If clalev([M:VT2])=0 : Local Mask VENTILE2  [VT2]  : Endif
If !clalev([F:BPA2]) : Local File BPADDRESS [BPA2] : Endif
If !clalev([F:ARX])  : Local File AREPORTX  [ARX]  : Endif
Gosub OUVRE_FIC
Call ACTIV("VII",OK) From SUBACV
If OK & !clalev([M:PYB]) : Local Mask PAYBID[PYB] : Endif
OK=1
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif
Gosub SETMASK From GOBJET
GFONC1 = GFLAG
Local Integer I, J, K, NOL, STAT, SIGN, SAVCONS, STATOK, IND
Local Decimal MT, MT2, TOLER, PAYRNDMAX
Local Char    LCK(30), OPT(10), OFONC1(10)
Local Char    BPCTYP(GLONGTE), BPSTYP(GLONGTE), PROTYP(5), ADI304(20)
Local Char    OFILPICK(250)(3), FILPICK(250)(3)
Local Date    DAT, DAT2
Local Char    MODELE(GLONGCM)
Local Char    COMPTREG(GLONANM), RTZCUR(GLONCUR), REGCUR(GLONCUR)
Local Char    AUZFCY(15), LOTCUR(20), COMPTLOT(GLONANM), LSTLOT(20)
Local Char    VALC1(20), VALC2(20), VALC3(20)
Local Integer USRPAZ, MAXPAZ
Local Integer ACCFCY, FILTREG, ROK, ILISPYL, LOTLIGCUR
Local Integer ILISDU5, ILISDU6
Local Integer LIGANA
Local Libelle LOCIN, FLGLOT
Local Decimal AMTBAN, AMTFORCE
Local Decimal MT3, MT4, MT5
Local Integer MONOCPY
Local Decimal EXERCICE , PERIODE
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Char    LEDCOD(GLONLED)(1..len(mess(0,2644,1)))
Local Char    LLED(GLONLED)(1..len(mess(0,2644,1)))
Local Char    REF(GLONLED)
Local Integer AXE
Local Integer OKTCA
Local Char OLDVATLIN(GLONVAT), OLDCURLIN(GLONCUR)
Local Char    DEPMOD(10)
Local Integer DISPLAY_AFTPICK : # 1=Affzo in $FIN_PICK 0=Not Affzo in $FIN_PICK
Local Integer BPRTYPBIS
Local Decimal TOTAMTBANFRC1
Local Decimal TOTAMTBANFRC

#--- variable local pour gestion adresses -----#
Local Char    BPRNAM(GLONNAM)  #89957
Local Char    ADRREG(GLONADR)
Local Char    BPAADDLIG(GLONADL)(3)
Local Char    CRY(GLONCRY)
Local Char    CRYNAM(GLONNCY)
Local Char    SAT(GLONSAT)
Local Char    POSCOD(GLONPOS)
Local Char    CTY(GLONCTY)

Global Integer GNBTYPLED                             : #
Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels

Call PARAM("","PRCTOL",[L]OPT) From ADOVAL
[L]TOLER = val([L]OPT)
If [L]TOLER<=0 | [L]TOLER>100 : [L]TOLER=10 : Endif
#Call LECTURE("AUS",GUSER,"") From CONTOBJ
#[L]USRPAZ=[F:AUS]LEVPAZ
Local Char LLEVPAZ(3)
Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
[L]USRPAZ=val(LLEVPAZ)
[L]MAXPAZ=len(mess(0,510,1))
Local Char    OPTCTLBAP(1)
Call PARAMUTIL("CTLPAZ",[L]OPTCTLBAP,"","") From SUBAUS
Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL
INDGES=find("PYH2",[G:PYH]keyname(0..[G:PYH]nbind-1))
Call PARAM("","PAYRNDMAX",[L]OPT) From ADOVAL
[L]PAYRNDMAX=val([L]OPT)
If INDGES<1 : INDGES=1 : Endif
[L]LSTLOT="*"
OK=1

# Adaptation Multi-legislation on transaction
# GFLAGLEG is set in $SETTRANS
FLGLOT = 0
Read [TPY]TPY0 = GFLAG;GFLAGLEG
If !fstat
 FLGLOT = ([F:TPY]DACPYL=2)   :# est-ce qu'on gère les lots de saisie
Endif
Global Libelle GFLEDI, GFLEDIEUR
If dim(GCURLEG)>0  : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GCURFCY)>0  : Local Char SAV_GCURFCY(GLONFCY) : SAV_GCURFCY = GCURFCY   : Endif
If dim(GSOCIETE)>0 : Local Char SAV_GCURCPY(GLONCPY) : SAV_GCURCPY = GSOCIETE  : Endif
If dim(GGRPFCY)>0  : Local Char SAV_GGRPFCY(GLONAGF) : SAV_GGRPFCY = GGRPFCY   : Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Local Integer I
#94635 RICAR 2014/04/21 - CASH VAT - END

# Localization Switzerland, 2015-05-21 Bader
Local Integer SOK
Call EXISTE_ADX("","","SUBPAY3SWI",SOK) From ORDSYS
If SOK : Gosub OUVRE From SUBPAY3SWI : Endif
# End Localization Switzerland

# ISSUE 39256 - 2017-08-18 RICAR - Enter payments from BCREG
Local Integer FROM_GESBCREG : Gosub SET_FROM_GESBCREG
Local Integer CREATION_MODE : Gosub SET_CREATION_MODE
Local Integer CLOSED_BCREG  : Gosub SET_CLOSED_BCREG
# ISSUE END

Return

$OUVRE_BOITE
ILISPYL=find("PYL",OBJLIS)-1
For I=0 To dim(FILPICK)-1
 FILPICK(I)="1=1"
Next I
ILISDU5=find("DU5",OBJLIS)-1
ILISDU6=find("DU6",OBJLIS)-1
# Multi-legislation adptation on transaction
Call LEC_TPY_LEG(GFLAGLEG,GFLAG) From CPTLEC
Return

$BOITE
If GWEBSERV : Return : Endif
Gosub INIT_BOITE From =WINPROG

## New Link with view
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE] : Endif
If clalev([F:GTES])=0 : Local File LEGGTESEL  [GTES]: Endif
# X3-47770 add BPARTNER table + Link updates [BPR]BPR0=[F:DUD]BPRPAY
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]: Endif
# X3-56680 add GACCENTRYD table + Link updates [DAE]DAE2=[F:DUD]ACCNUM
If clalev([F:DAE])=0  : Local File GACCENTRYD   [DAE]: Endif

Link [DUD] With
& [HAE]HAE0=[F:DUD]TYP;[F:DUD]NUM,
& [BPR]BPR0=[F:DUD]BPRPAY,
& [DAE]DAE2=[F:DUD]ACCNUM,
& [GTES]GTE1(1)=[F:DUD]TYP,
& [GTE]GTE0=[F:GTES]TYP;[F:GTES]LEG
& As [DU1_]
& Order By Key DUD0

Link [DUD] With
& [HAE]HAE0=[F:DUD]TYP;[F:DUD]NUM,
& [BPR]BPR0=[F:DUD]BPRPAY,
& [DAE]DAE2=[F:DUD]ACCNUM,
& [GTES]GTE1(1)=[F:DUD]TYP,
& [GTE]GTE0=[F:GTES]TYP;[F:GTES]LEG
& As [DU2_]
& Order By Key DUD9

Gosub DEF_BOITE From =WINPROG
Gosub AFF_BOITE From =WINPROG
OK = 0 #inhiber le OUVRE_BOITE de la fenêtre, cf GOBJET
Return


$EFFMASK
If evalue("dim([M:PAY"+num$(MA)+"]INIVAR)>0")
 Gosub INIMSK
Endif
If clalev([M:PYB]) : Raz [M:PYB] : Endif
Return

$INIMSK
If [M]CUR<>"" : Call LECTURE("TCU",[M]CUR,"") From CONTOBJ
Else          : Call LECTURE("TCU",GLOCALDEV,"") From CONTOBJ
Endif
If fstat=0 : [M]DEVFMT=[F:TCU]CURFMT1 : Else [M]DEVFMT="11.2" : Endif
If ![M]INIVAR
 [M]MAXPAZ=[L]MAXPAZ
 [M]USRPAZ=[L]USRPAZ
 If dim([M]RTZCUR)>0 : [M]RTZCUR=[L]RTZCUR : Endif

 [L]COMPTLOT = ""
 Call GETSOC([M]FCY) From DEVSUB
 Call LECTCA(3,OKTCA) From SUBTCA
 If OKTCA
  [L]COMPTLOT = [F:TCA]CODNUM(6)
 Endif

 [M]COMPTLOT=[L]COMPTLOT
 [M]INIVAR=1
Endif
If clalev([M:PYB]) : [M:PYB]=[F:PYH] : [M:PYB]FLGMOD=1 : Endif

# ISSUE 39256 - 2017-08-30 MRDAB - Enter payments from BCREG
Gosub REGNUM_DISPLAY
# ISSUE END

# Issue X3-75998 by MRDAB
Actzo [M:PAY1]ACCDAT
# Issue end

Return

$OUVRE_FIC
If clalev([F:PYD])=0  : Local File PAYMENTD    [PYD] : Endif
If clalev([F:PYA])=0  : Local File PAYMENTA    [PYA] : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP   [TPY] : Endif
If clalev([F:CDA])=0  : Local File GACCDENCOD  [CDA] : Endif
