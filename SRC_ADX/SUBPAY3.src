If func AFNC.ACTIV("SEPP")
  If !clalev([F:SEU])  Local File SEAUTH [SEU] Endif
  If func SEPPLIB.SEPP_DOC_PAY()
    Call AUTH_CHK(50+mod([M]SNS,2),[F:PYH]NUM,GERR,GMESSAGE) From SEPPLIB
    If GERR
      If [F:SEU]MANAUT=2
        Call MESSAGE(mess(48,2092,1)) From GESECRAN
      Endif
      GOK=0 : Return
    Endif
    If !func SEPPCDT.SEPP_OK(50+mod([M]SNS,2),[F:PYH]NUM,1)
      Call CALL_SEAUTH(50+mod([M]SNS,2),[F:PYH]NUM) From TRTSEAUTH
    Endif
  Elsif func SEPPCDT.SEPP_OK(50+mod([M]SNS,2),[F:PYH]NUM,1)
    Local Integer SERR
    Local Char    SEMESSAGE(150)
    Call VOID_ALL(50,[F:PYH]NUM,SERR,SEMESSAGE) From SEPPLIB
    If SERR : Call ERREUR(SEMESSAGE) From GESECRAN : Endif
  Endif
Endif

If func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_APRES_MOD From CHKLIB
Endif

