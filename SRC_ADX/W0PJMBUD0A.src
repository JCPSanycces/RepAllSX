#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0A 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PBUFCY
mkstat = 0
zoncou = "PBUFCY"
indice = 0
WCHAR = [M]PBUFCY
If varmode([M]PBUFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUFCY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PBUFCY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]PBUFCY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","F",[M]PBUFCY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]PBUFCY or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_PBUFCY([M]PBUFCY) From SUBPJBU
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PBUPAE
mkstat = 0
zoncou = "PBUPAE"
indice = 0
WCHAR = [M]PBUPAE
If varmode([M]PBUPAE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUPAE" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]PBUPAE or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUPAE([M]PBUPAE) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUPAE" : GZNUM = 37740 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PBUCOD
mkstat = 0
zoncou = "PBUCOD"
indice = 0
WCHAR = [M]PBUCOD
If varmode([M]PBUCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PBUCOD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PBUCOD" : GZNUM = 6380 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]PBUCOD or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PBUCOD([M]PBUCOD) From SUBPJBU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PBUCOD" : GZNUM = 6380 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PBUDESAXX
mkstat = 0
zoncou = "PBUDESAXX"
indice = 0
WCHAR = [M]PBUDESAXX
If varinit([M]PBUDESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]PBUDESAXX,"PIMPL","PIMDESAXX",[M:PJBU0]KEYCONCAT,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PBUDESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PBUDESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]PBUDESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PBUDESAXX" : GZNUM = 282 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]PBUDESAXX or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_PBUDESAXX([M]PBUDESAXX) From SUBPJBU
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PBUDESAXX" : GZNUM = 282 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PBUDESAX1
mkstat = 0
zoncou = "PBUDESAX1"
indice = 0
WCHAR = [M]PBUDESAX1
If varinit([M]PBUDESAX1,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]PBUDESAX1,"PIMPL","PIMDESAX1",[M:PJBU0]KEYCONCAT,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PBUDESAX1,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PBUDESAX1" : Gosub ACTION From =IMPTRT
  Endif
  If WCHAR<>[M]PBUDESAX1 or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PBUDESAX1([M]PBUDESAX1) From SUBPJBU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PBUDESAX1" : GZNUM = 42416 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PBUIMP
mkstat = 0
zoncou = "PBUIMP"
indice = 0
IMPENT = [M]PBUIMP
WNUM = IMPENT
If varinit([M]PBUIMP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PBUIMP,indice)=0
 [M]PBUIMP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUIMP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PBUIMP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUIMP(IMPENT) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUIMP" : GZNUM = 3987 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PBUIMP = IMPENT

## Zone BTNDC
mkstat = 0
zoncou = "BTNDC"
indice = 0
If varinit([M]BTNDC,indice)=0
 [M]BTNDC = "138"
Endif
If varmode([M]BTNDC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTNDC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PBUSOR
mkstat = 0
zoncou = "PBUSOR"
indice = 0
WNUM = [M]PBUSOR
If varmode([M]PBUSOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUSOR" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]PBUSOR or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUSOR([M]PBUSOR) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUSOR" : GZNUM = 50781 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMBUD0A"
Return

