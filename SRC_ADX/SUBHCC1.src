#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque HCC1
########################################
Subprog AS_NBHCC
If nolign - 1 >= dim([M:HCC1]TYPCLA) - 1
    End
Endif
If nolign > 0
    GSZHBPREC = [M:HCC1]NUM(nolign - 1)
    GSZHBPTYP = [M:HCC1]TYP(nolign - 1)
Endif
End

########################################
Subprog C_NBHCC
If nolign - 1 >= dim([M:HCC1]TYPCLA) - 1
    End
Endif
If nolign > 0
    GSZHBPREC = [M:HCC1]NUM(nolign - 1)
    GSZHBPTYP = [M:HCC1]TYP(nolign - 1)
Endif
End

