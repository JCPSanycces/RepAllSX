#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog GLOBVAR
If clalev([F:COA]) = 0 : Local File GCOA     [COA] : Endif
Local Integer NBCOA
NBCOA = nbrecord([COA])
Global Integer  GCOANBR
Global Char     GCOACOD(GLONCOA)(1..NBCOA)
Global Char     GCOAFMT(10)(1..NBCOA)
Global Shortint GCOALEN(1..NBCOA)
Global Shortint GCOALEN2(1..NBCOA)

Call INIGLBCOA
End

Subprog INIGLBCOA
If clalev([F:COA]) = 0 : Local File GCOA     [COA] : Endif

GCOANBR = 0
For [COA]
 GCOANBR += 1
 GCOACOD(GCOANBR) = [F:COA]COA
 GCOAFMT(GCOANBR) = [F:COA]ACCFMT
 If [F:COA]FXDLEN=2
  GCOALEN(GCOANBR) = [F:COA]ACCLEN
 Else
  GCOALEN(GCOANBR) = 0
 Endif
 If dim(GCOALEN2)>0
  GCOALEN2(GCOANBR) = [F:COA]ACCLEN
 Endif
Next
End

Subprog INIACCFMT(COA)
Value Char COA

Global Char    GFMTACC(10)
# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
If COA="" : GFMTACC = "15c" : End : Endif
# End issue X3-38496
Local Integer K
K = find(COA,GCOACOD(1..GCOANBR))
If K<>0
 GFMTACC = GCOAFMT(K)
 If instr(1,GCOAFMT(K),"#") & dim(GCOALEN2)>0
  If GCOALEN2(K)<>0
   GFMTACC = num$(GCOALEN2(K))+"c"
  Elsif GCOALEN2(K)=0
   GFMTACC = mid$(GCOAFMT(K),1,len(GCOAFMT(K))-1)+"c"
  Endif
 Endif
Else
 GFMTACC = "15c"
Endif
End

