#<AdxTL>@(#)8.0.0.0 $Revision$

Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CLCCFG","CLCCFG",4,"") From GTRAITE  
End

#===============================================================================================
$ACTION

 Case ACTION
  When "BOUTON"   : Gosub BOUTON
  When "DEBUT"    : Gosub DEBUT
  When "TERMINE"  : Gosub TERMINE
  When Default
 Endcase

Return

#===============================================================================================
$DEBUT

 #> Recherche et chargement du fichier globbv5.cfg

 Local Char    FICHIER(255)
 Local Integer FILE_EXIST
 Local Integer STAT, I
 Local Char    ENREG(250)
 Local Char    LCLE
 Local Char    LVAL

 Local Char    L_SEP        : L_SEP=";"

 Raz [M:XCC]

 #> Ouverture, lecture fermeture du fichier

 FICHIER=filpath("tmp","globbv5","cfg",-1)

 #> Vérification de la présence du fichier

 If !(filinfo(FICHIER,0) < 0)
  FILE_EXIST=G_OUI
 Else
  FILE_EXIST=G_NON
 Endif

 #> Si le fichier existe chargement du contenu du fichier

 If FILE_EXIST=G_OUI
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openi FICHIER Using [XCFG]
  Repeat
   Rdseq LCLE,LVAL Using [XCFG]
   If LCLE="USR" : [M:XCC]XUSRDBG   = LVAL        : Endif
   If LCLE="TRT" : [M:XCC]XTSTNAM(I)= LVAL : I+=1 : Endif
  Until fstat>0
  Openi Using [XCFG]
 Endif
 
 #> Chargement des noms des traitements du module de calcul

 Local Integer I_TRT
 For I_TRT = 1 To G_CALTRTNBR
  [M:XCC]XSTDNAM(I_TRT-1)=G_CALTRTNAM(I_TRT-1)
 Next I_TRT

 #> Mise à jour de la colonne "En mémoire"

 Local Integer I_TRT
 For I_TRT = 1 To G_CALTRTNBR
  [M:XCC]XMEMNAM(I_TRT-1)=evalue(G_CALTRTGLO(I_TRT-1))
  Next I_TRT
 [M:XCC]NBTRT=I_TRT    

 Affzo [M:XCC]

 Gosub APPLIQUE_STYLE

Return

#===============================================================================================
$SETBOUT
Return

#===============================================================================================
$BOUTON
 Case BOUT
  When "A" : Gosub LOAD_GLOBALES
  When "G" : Gosub GENERE_FIC
  When "R" : Gosub RESTAURE
 Endcase
Return

#===============================================================================================
$GENERE_FIC
 Local Char    FICHIER(255)
 Local Integer FILE_EXIST
 Local Integer ROK
 Local Integer STAT
 Local Char    ENREG(250)

 Local Char    L_SEP        : L_SEP=";"

 #> Ouverture, lecture fermeture du fichier

 FICHIER=filpath("tmp","globbv5","cfg",-1)

 #> Vérification de la présence du fichier

 If !(filinfo(FICHIER,0) < 0)
  FILE_EXIST=G_OUI
 Else
  FILE_EXIST=G_NON
 Endif

 #> Si le fichier existe

 If FILE_EXIST=G_OUI
  Call AVERTIR("Voulez-vous modifier le fichier globbv5.cfg ?", ROK) From GESECRAN
  If ROK=G_NON
   Return
  Else
   Call EFFACE(FICHIER,STAT) From ORDSYS
  Endif
 Endif

 #> Création du fichier

Openo FICHIER,0 Using [XCFG] 
adxifs = ";"
adxirs = chr$(13)+chr$(10)
 Wrseq "USR", [M:XCC]XUSRDBG Using [XCFG]
 For I=1 To [M:XCC]NBTRT
  Wrseq "TRT", [M:XCC]XTSTNAM(I-1) Using [XCFG]
 Next I
Openo Using [XCFG]

 #> Fichier crée correctement
 
 Infbox "Génération du fichier globvv5.cfg OK."

Return

#===============================================================================================
$LOAD_GLOBALES
 Local Char L_NOMGLO
 For I=1 To G_CALTRTNBR
  If [M:XCC]XTSTNAM(I-1)<>""
   L_NOMGLO=G_CALTRTGLO(I-1) : Assign L_NOMGLO With [M:XCC]XTSTNAM(I-1) 
   [M:XCC]XMEMNAM(I-1) = evalue(G_CALTRTGLO(I-1))
  Endif
 Next I
 Affzo [M:XCC]XMEMNAM
 Gosub APPLIQUE_STYLE
Return

#===============================================================================================
$RESTAURE
 Local Char L_NOMGLO
 For I=1 To G_CALTRTNBR
  If [M:XCC]XTSTNAM(I-1)<>""
   L_NOMGLO=G_CALTRTGLO(I-1) : Assign L_NOMGLO With G_CALTRTNAM(I-1)
   [M:XCC]XMEMNAM(I-1) = evalue(G_CALTRTGLO(I-1))
  Endif
 Next I
 Affzo [M:XCC]XMEMNAM 
 Gosub APPLIQUE_STYLE
Return

#===============================================================================================
$TERMINE
Return

#===============================================================================================
$APPLIQUE_STYLE
 For nolign=1 To G_CALTRTNBR
  If [M:XCC]XMEMNAM(nolign-1)<>G_CALTRTNAM(nolign-1)
   Chgstl [M:XCC]XMEMNAM(nolign-1) With "BACKGREEN"
  Else
   Chgstl [M:XCC]XMEMNAM(nolign-1) With ""
  Endif
  Affzo  [M:XCC]XMEMNAM(nolign-1)
 Next nolign
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran CLCCFG) 08/10/2007 14:57:13 (GBO)
######################################################################################
Subprog AM_XUSRDBG(VALEUR)
Variable Char    VALEUR()
 Local Char    FICHIER(255)
 Local Integer FILE_EXIST
End





