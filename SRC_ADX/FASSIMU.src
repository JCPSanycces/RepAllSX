################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM

Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FASSIMU","DFASSIMU",3, "") From GTRAITE
End

################################################################################
$ACTION
  Case ACTION
    When "INIT"             : Gosub INIT
    When "INIT_DIA"         : Gosub INIT_DIA
    When "OUVRE"            : Gosub OUVRE
    When "OUVRE_BATCH"      : Gosub OUVRE_BATCH
    When "DEBUT"            : Gosub DEBUT
    When "CONTROLE"         : Gosub CONTROLE
    When "CONT_BATCH"       : Gosub CONT_BATCH
    When "EXEC"             : Gosub EXEC
    When "TERMINE"          : Gosub TERMINE
    When "AP_CHOIX"         : Gosub AP_CHOIX
    When "SETBOUT"          : Gosub SETBOUT
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "OK"               : Gosub OK            # FQ83094
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE_BATCH
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:CNX]) = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIY]) = 0 : Local File FISCYEAR    [FIY]  : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FAS]) = 0 : Local File FXDASSETS   [FAS]  : Endif

  # Ouverture de l'écran de sélection étendue
  PARAM(1) = "FAS"
  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  Gosub OUVRE From ASELOBJ

Return

#-------------------------------------------------------------------------------
$INIT_DIA
  # Action - Traitement ( Standard & Saisie et Execution - Batch)

  #-- Pour interactif
  Global Integer GCURCPY            : # -- Indice société cliquée
  Global Integer ABANDON_TRT        : # -- Flag alimenté à 1 quand on clique sur le bouton FIN

  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub CHARGE_MASQUE_G

  If [M:MHC]NBFCY=0 : End : Endif
  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:MHC] With 0

  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
  Default Mask [ASL]
  Gosub DEBUT From ASELOBJ
Return

#-------------------------------------------------------------------------------
$INIT
  # Action - ( Standard & Execution - Batch)
  # Vérification qu'au moins un contexte existe dans le sossier
  # ------------------
  If (func FASSIMU.CALCUL_POSSIBLE()) Then
    # Aucun contexte dans ce dossier
    Errbox mess(123, GML_MSGCAL, 1)
    # Arrêt du calcul
    FIN=1
    Return
  Endif

  # -- Ouverture des fichiers
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:CNX]) = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIY]) = 0 : Local File FISCYEAR    [FIY]  : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FAS]) = 0 : Local File FXDASSETS   [FAS]  : Endif

  Global Integer ABANDON_TRT   : # Flag alimenté à 1 quand on clique sur le bouton FIN

  Local Char DBGSTR_SAV(255)
  If clalev([M:MHC])=0
    DBGSTR_SAV=dbgstr(1)       : # sauvegarde de la liste des masques par défaut
    Local Mask MCFASCRI6 [MHC] : # ouverture de [MHC]
    Default Mask DBGSTR_SAV    : # restauration de la liste des masques
  Endif
  If clalev([M:FASI])=0
    DBGSTR_SAV=dbgstr(1)       : # sauvegarde de la liste des masques par défaut
    Local Mask FASSIMU [FASI]  : # ouverture de [FASI]
    Default Mask DBGSTR_SAV    : # restauration de la liste des masques
  Endif

  If GSERVEUR=1
    Gosub OUVRE From ASELOBJ
  Endif

Return

#-------------------------------------------------------------------------------
$OUVRE
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:CNX]) = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIY]) = 0 : Local File FISCYEAR    [FIY]  : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif

  If GBATCH=0
      # Ouverture de l'écran de sélection étendue
      PARAM(1) = "FAS"
      #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
      Gosub OUVRE From ASELOBJ
      If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
      Default Mask [ASL]
      Gosub DEBUT From ASELOBJ
  Endif
Return

#-------------------------------------------------------------------------------
$DEBUT
  # Action - Traitement ( Standard & Saisie et Execution - Batch)

  #-- Pour interactif
  Global Integer GCURCPY            : # -- Indice société cliquée

  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub CHARGE_MASQUE_G

  If [M:MHC]NBFCY=0 : End : Endif
  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:MHC] With 0

  #=> Raz de l'onglet supplémentaire
  Raz [M:ASL]FLD1, [M:ASL]VAL1
  Raz [M:ASL]FLD2, [M:ASL]VAL2
  Raz [M:ASL]FLD3, [M:ASL]VAL3
  Raz [M:ASL]FLD4, [M:ASL]VAL4
  Raz [M:ASL]FLD5, [M:ASL]VAL5

Return

#-------------------------------------------------------------------------------
$SETBOUT
  Grizo [M:ASL]TBL1
  Grizo [M:ASL]TBL2
  Grizo [M:ASL]TBL3
  Grizo [M:ASL]TBL4
  Grizo [M:ASL]TBL5
  Affzo [M:ASL]
Return

#-------------------------------------------------------------------------------
$CHARGE_MASQUE_G

Local Integer LAUTORISEE  : # Utilisateur habilité pour au moins un site de la société
Local Integer LCONTEXTE   : # Au moins un contexte défini pour la société
Local Integer N_S, N_E, N_C, N_E_DEB, N_C_DEB, N_P, N_I, N_P_DEB, N_CNX

  #------------------------------
  N_S = 1
  N_E = 1
  N_C = 1
  N_P = 1
  N_E_DEB = 1
  N_C_DEB = 1
  N_P_DEB = 1
  # >>>>>>>
  For [CPY]CPY0
    LAUTORISEE = 0
    #-1 -----------------------------
    # Société juridique
    If ( [F:CPY]CPYLEGFLG = 2 ) Then
      Read [CNX]CNX0=[F:CPY]CPY
      If ( fstat ) Then : LCONTEXTE = 0 :  Else : LCONTEXTE = 1 : Endif
      #-2 -----------------------------
      If (LCONTEXTE) Then
      # Au moins un contexte pour la société
        # Pour tous les Etablissements financier de la société
        Filter [FCY] Where ( LEGCPY = [F:CPY]CPY and FINFLG = G_OUI)
        # >>>>>>>
        For [FCY]FCY1
          # Utilisateur habilité à la fonction pour le site
          #-3 -----------------------------
          If ( GUSRFCY(1) = "\" or find([F:FCY]FCY, GUSRFCY(1..GNBAUZ)) ) Then
            LAUTORISEE = 1
            # -- Etablissement
            [M:MHC]FCYG       (N_E-1)  = [F:FCY]FCY
            [M:MHC]FLGCLCFCYG (N_E-1)  = G_NON
            N_E += 1
          Endif
          #-3 -----------------------------
        Next FCY1
        # >>>>>>>
        Filter [FCY]
        #-3 -----------------------------
        If ( LAUTORISEE ) Then
          # -- Contextes
          # >>>>>>
          N_CNX = 1
          For [CNX]CNX0 Where CPY=[F:CPY]CPY
            Filter [FIY] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
            Read [FIY]FIY0 First
            Filter [FIY]
            [M:FASI]FLGCLCCNXG(N_C-1)   = G_NON
            [M:FASI]DATSTRFIYG(N_C-1)   = [F:FIY]DATSTRFIY
            [M:FASI]CNXG(N_C-1)         = [F:CNX]CNX
            [M:FASI]DATSTRPERG(N_C-1)   = [F:FIY]DATSTRPER([F:FIY]INDCURPER-1)
            [M:FASI]HRSEXEG(N_C-1)      = [F:CNX]HRSEXE
            [M:FASI]HRSPERG(N_C-1)      = [F:CNX]HRSPER
            [M:FASI]FLGSIMDETG(N_C-1)   = [F:CNX]FLGSIMDET

            # -- Plans
            For N_I = 1 To [F:CNX]NBPLC
              [M:FASI]PLNCAAG(N_P-1)      = [F:CNX]PLNCAA(N_I-1)
              [M:FASI]FLGCLCPLNG(N_P-1)   = G_NON
              N_P += 1
            Next N_I
            [M:FASI]PLNCNXDEBG     (N_C-1) = N_CNX
            [M:FASI]PLNCNXFING     (N_C-1) = (N_CNX-1) + (N_I-1)
            N_C += 1
            N_CNX = (N_CNX-1) + N_I
          Next CNX0
          # >>>>>>

          # -- Société
          [M:MHC]FLGCLCCPY  (N_S-1) = G_NON
          [M:MHC]CPY        (N_S-1) = [F:CPY]CPY
          [M:MHC]FCYDEB     (N_S-1) = N_E_DEB
          [M:MHC]FCYFIN     (N_S-1) = N_E-1
          [M:MHC]CNXDEB     (N_S-1) = N_C_DEB
          [M:MHC]CNXFIN     (N_S-1) = N_C-1
          [M:MHC]PLNDEB     (N_S-1) = N_P_DEB
          [M:MHC]PLNFIN     (N_S-1) = N_P-1
          N_E_DEB = N_E
          N_C_DEB = N_C
          N_P_DEB = N_P

          N_S +=1
        Endif
        #-3 -----------------------------
      Endif
      #-2 -----------------------------
    Endif
    #-1 -----------------------------

  Next CPY0
  # >>>>>>>

  #------------------------------
  [M:MHC]NBCPY  = N_S-1
  [M:MHC]NBFCYG = N_E-1
  [M:FASI]NBCNXG = N_C-1
  [M:FASI]NBPLCG = N_P-1
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBCPY")  From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNXG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLCG") From GLOBIENS
  #------------------------------
  GCURCPY        = 1
  Call AFFICHE_G_EN_S (GCURCPY)
  #------------------------------
Return

#-------------------------------------------------------------------------------
$CONTROLE

  # Action - Traitement ( Standard & Execution - Batch)

  If GSERVEUR = 0
    If ABANDON_TRT=1 : Return : Endif

    Call AFFICHE_S_EN_G (GCURCPY)
    #-------------------------
    # Désélection des sociétés qui n'ont aucun site ou aucun contexte à calculer
    # Contrôle qu'au moins une société est à calculer
    Gosub CTRL_CALCUL
  Endif
Return

#-------------------------------------------------------------------------------
$CONT_BATCH

  # Action - Traitement ( Standard & Execution - Batch)

  If ABANDON_TRT=1 : Return : Endif

  Call AFFICHE_S_EN_G (GCURCPY)
  #-------------------------
  # Désélection des sociétés qui n'ont aucun site ou aucun contexte à calculer
  # Contrôle qu'au moins une société est à calculer
  Gosub CTRL_CALCUL

  #-------------------------
  If ( dim([M:MHC]NBCPY) > 0 ) Then
    If ( GERR = 0 ) Then
      # Suppression du masque de toutes les infos des sociétés non sélectionnées
      Gosub EPURATION_MASQUE_G
    Endif
  Endif

  # 1ere ligne
  Call AFFICHE_G_EN_S (1)

Return

#-------------------------------------------------------------------------------
$EXEC
  If ABANDON_TRT=1 : Return : Endif

#  [M:FASI] = [M:MHC]
  If GBATCH=0 and GSERVEUR=0
    Gosub OUVRE From ASELOBJ
  Endif
  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPON('C') From GESECRAN
  Gosub SIMULER_SOCIETES
  FIN = 1

Return

#-------------------------------------------------------------------------------
$AP_CHOIX
  Case REPONSE
    When GSTAOK   : ABANDON_TRT = 0
    When GSTAEND  : ABANDON_TRT = 1
  Endcase

Return

#-------------------------------------------------------------------------------
$APRES_MODIF
Local Integer N_P, N_C

 #> Comptage du nombre de société sélectionnées et stockage dans la variable G_NBR_SELCPY
 If COUZON = "FLGCLCPLN"
  If [M:FASI]FLGCLCPLN(nolign-1) = G_OUI
    For N_C = 1 To [M:FASI]NBCNX
      For N_P = [M:FASI]PLNCNXDEB(N_C-1) To [M:FASI]PLNCNXFIN(N_C-1)
        If [M:FASI]FLGCLCPLN(N_P-1)  = G_OUI and [M:FASI]FLGCLCCNX(N_C-1) = G_NON
          Call ERREUR ("Contexte non sélectionné pour ce plan") From GESECRAN
          mkstat=2
        Endif
      Next N_P
    Next N_C
  Endif
 Endif

Return

#-------------------------------------------------------------------------------
$TERMINE

  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPOFF() From GESECRAN

  # -- Interactif
  If (dim(GCURCPY)>0) Then : Kill GCURCPY : Endif  : # -- Indice société cliquée
  If (dim(ABANDON_TRT)>0)  : Kill ABANDON_TRT       : Endif

  If (clalev([M:MHC])) Then
    Close Mask [MHC]
  Endif

  If (clalev([M:FASI])) Then
    Close Mask [FASI]
  Endif

  If (clalev([M:ASL])) Then
    Close Mask [ASL]
  Endif
Return

#-------------------------------------------------------------------------------
$EPURATION_MASQUE_G

 # Recherche et suppression des informations de toutes les sociétés non sélectionnées
 # ???? Il faudrait pouvoir toujours conserver la première.

 Local Integer I_CPY, N_I
 Local Integer FINI
 Local Integer LNBFLD

 FINI=G_NON
 # >>>>
 Repeat
  I_CPY = find (G_NON,[M:MHC]FLGCLCCPY(1..[M:MHC]NBCPY))
  If ( I_CPY=0 ) Then
    FINI=G_OUI
  Else
    I_CPY +=1  : # A faire car on traite pas la 1ère société
    Gosub SUP_CPY
  Endif
 Until FINI=G_OUI
 # <<<<

Return

#-------------------------------------------------------------------------------
$SUP_CPY

 Local Integer NBCNXSUP
 Local Integer NBFCYSUP
 Local Integer NBPLNSUP

 #Infbox "Suppression de la société :"-[M:MHC]CPY(I_CPY-1)

 # Calcul du nombre de lignes Plan à supprimer dans G
 NBPLNSUP = [M:MHC]PLNFIN(I_CPY-1)- [M:MHC]PLNDEB(I_CPY-1) +1
 # Suppression des lignes Contextes dans  G
 Dela [M:MHC]PLNDEB(I_CPY-1)-1, NBPLNSUP, [M:FASI]NBPLCG-1 [M:FASI]NBPLCG
 [M:FASI]NBPLCG -= NBPLNSUP

 # Calcul du nombre de lignes Contexte à supprimer dans G
 NBCNXSUP = [M:MHC]CNXFIN(I_CPY-1)- [M:MHC]CNXDEB(I_CPY-1) +1
 # Suppression des lignes Contextes dans  G
 Dela [M:MHC]CNXDEB(I_CPY-1)-1, NBCNXSUP, [M:FASI]NBCNXG-1 [M:FASI]NBCNXG
 [M:FASI]NBCNXG -= NBCNXSUP


 # Calcul du nombre de lignes Sites à supprimer dans G
 NBFCYSUP = [M:MHC]FCYFIN(I_CPY-1)- [M:MHC]FCYDEB(I_CPY-1) +1
 # Suppression des lignes Sites dans  G
 Dela [M:MHC]FCYDEB(I_CPY-1)-1, NBFCYSUP, [M:MHC]NBFCYG-1 [M:MHC]NBFCYG
 [M:MHC]NBFCYG -= NBFCYSUP

 # Suppression dans le tableau Société
 # A faire impérativement après la suppression des sites et des contextes
 Dela I_CPY-1, 1, [M:MHC]NBCPY-1 [M:MHC]NBCPY
 [M:MHC]NBCPY -= 1

 # Mise à jour des CNXDEB,CNXFIN,FCYDEB,FCYFIN & PLNDEB,PLNFIN dans le tableau Société
 For N_I= I_CPY To [M:MHC]NBCPY
  [M:MHC]CNXDEB(N_I-1) -= NBCNXSUP
  [M:MHC]CNXFIN(N_I-1) -= NBCNXSUP
  [M:MHC]FCYDEB(N_I-1) -= NBFCYSUP
  [M:MHC]FCYFIN(N_I-1) -= NBFCYSUP
  [M:MHC]PLNDEB(N_I-1) -= NBPLNSUP
  [M:MHC]PLNFIN(N_I-1) -= NBPLNSUP
 Next N_I

Return

#-------------------------------------------------------------------------------
$CTRL_CALCUL

Local Integer N_S, N_I, NBCNXCLC, NBFCYCLC, NBCPYCLC, NBPLNCLC

  NBCPYCLC = 0

  # >>>>>>>>>>>>>>
  For N_S = 1 To [M:MHC]NBCPY
    #-1 ---------------------------
    If [M:MHC]FLGCLCCPY(N_S-1) = G_OUI Then
      NBPLNCLC = 0
      #For N_I = [M:FASI]PLNCNXDEB(N_S-1) To [M:FASI]PLNCNXFIN(N_S-1)
      For N_I = [M:MHC]PLNDEB(N_S-1) To [M:MHC]PLNFIN(N_S-1)
        If ( [M:FASI]FLGCLCPLNG(N_I-1) = G_OUI ) Then
          NBPLNCLC += 1
        Endif
      Next N_I
      #-2 ---------------------------
      If ( NBPLNCLC = 0 ) Then
        # 52 La société
        # 53 n'a pas de plan à calculer. Elle est désélectionnée.
        Call MESSAGE (func AFNC.MES1(mess(189, GML_MSGCAL, 1), num$([M:MHC]CPY(N_S-1)))) From GESECRAN
        [M:MHC]FLGCLCCPY (N_S-1) = G_NON
        Affzo [M:MHC]FLGCLCCPY (N_S-1)
      Else
      #-2 ---------------------------
        NBCNXCLC = 0
        For N_I = [M:MHC]CNXDEB(N_S-1) To [M:MHC]CNXFIN(N_S-1)
          If ( [M:FASI]FLGCLCCNXG(N_I-1) = G_OUI ) Then
            NBCNXCLC += 1
          Endif
        Next N_I
        #-3 ---------------------------
        If ( NBCNXCLC = 0 ) Then
          # 52 La société
          # 53 n'a pas de contexte à calculer. Elle est désélectionnée.
          Call MESSAGE (func AFNC.MES1(mess(190, GML_MSGCAL, 1), num$([M:MHC]CPY(N_S-1)))) From GESECRAN
          [M:MHC]FLGCLCCPY (N_S-1) = G_NON
          Affzo [M:MHC]FLGCLCCPY (N_S-1)
        Else
        #-3 ---------------------------
          NBFCYCLC = 0
          For N_I = [M:MHC]FCYDEB(N_S-1) To [M:MHC]FCYFIN(N_S-1)
            If ( [M:MHC]FLGCLCFCYG(N_I-1) = G_OUI ) Then
              NBFCYCLC += 1
            Endif
          Next N_I
          #-4 ---------------------------
          If ( NBFCYCLC = 0 ) Then
            # 52 La société
            # ?? n'a pas de site à calculer. Elle est désélectionnée.
            Call MESSAGE (func AFNC.MES1(mess(191, GML_MSGCAL, 1), num$([M:MHC]CPY(N_S-1)))) From GESECRAN
            [M:MHC]FLGCLCCPY (N_S-1) = G_NON
            Affzo [M:MHC]FLGCLCCPY (N_S-1)
          Else
          #-4 ---------------------------
            NBCPYCLC += 1
          Endif
          #-4 ---------------------------
        Endif
        #-3 ---------------------------
      Endif
      #-2 ---------------------------
    Endif
    #-1 ---------------------------
  Next N_S
  # >>>>>>>>>>>>>>

  #------------------------------
  If ( NBCPYCLC = 0 ) Then
    GMESSAGE = mess(54,GML_MSGCAL,1) : # Aucune société n'est à calculer !
    FIN      = 0
    GERR     = 1
  Endif
  #------------------------------

Return

#-------------------------------------------------------------------------------
$OK
Local Integer N_S, N_I

  # >>>>>>>>>>>>>>
  For N_S = 1 To [M:MHC]NBCPY
    #-1 ---------------------------
    If [M:MHC]FLGCLCCPY(N_S-1) = G_OUI Then
      #-2 ---------------------------
        For N_I = [M:MHC]CNXDEB(N_S-1) To [M:MHC]CNXFIN(N_S-1)
          If ( [M:FASI]FLGCLCCNXG(N_I-1) = G_OUI ) Then
            If [M:FASI]HRSEXEG(N_I-1) = 0 or [M:FASI]HRSPERG(N_I-1) = 0
                # 52 La société
                # 866 n'a pas d'horizon de simulation défini. Vérifier le contexte.
                GMESSAGE = func AFNC.MES1(mess(192, GML_MSGCAL, 1), num$([M:MHC]CPY(N_S-1)))
                FIN      = 0
                GERR     = 1
                Break 2
            Endif
          Endif
        Next N_I
    Endif
    #-1 ---------------------------
  Next N_S
  # >>>>>>>>>>>>>>

Return

#########################################################
Subprog EVALUE_NBFLD ( RNBFLD )

Variable Integer RNBFLD

Local Integer NBFLDCPY  : NBFLDCPY  = 0   : # Nombre de zones tableau sociétés
Local Integer NBFLDCNX  : NBFLDCNX  = 0   : # Nombre de zones tableau global contextes
Local Integer NBFLDFCY  : NBFLDFCY  = 0   : # Nombre de zones tableau global sites
Local Integer NBFLDPLN  : NBFLDPLN  = 0   : # Nombre de zones tableau global plans

Local Integer N_I, NBFIRST
Local Integer NCNX, NCNXG

    NCNX  = 5
    NCNXG = 4

  RNBFLD = 5 : # nombre de champs fixes
  # >>>>>>>>>>>
  For N_I = 1 To [M:MHC]NBCPY
    #-------------------------
    If ( [M:MHC]FLGCLCCPY(N_I-1) = G_OUI ) Then
      # Masque Société (visible)
      NBFLDCPY += 7
      If ( N_I = 1 ) Then
        # Masques  Sites & Contextes (visible)
        NBFLDCNX += (NCNX * ( [M:MHC]CNXFIN(N_I-1) - [M:MHC]CNXDEB(N_I-1) + 1))
        NBFLDFCY += (4    * ( [M:MHC]FCYFIN(N_I-1) - [M:MHC]FCYDEB(N_I-1) + 1))
      Endif
      # Masque générale (invisible)
      NBFLDCNX += (NCNXG * ( [M:MHC]CNXFIN(N_I-1) - [M:MHC]CNXDEB(N_I-1) + 1))
      NBFLDFCY += (2     * ( [M:MHC]FCYFIN(N_I-1) - [M:MHC]FCYDEB(N_I-1) + 1))
    Endif
    #-------------------------
  Next N_I
  # >>>>>>>>>>>

  # Totalisation du nombre de zones à mémoriser
  RNBFLD +=  NBFLDCPY + NBFLDFCY + NBFLDCNX + NBFLDPLN

End

#########################################################
Funprog CALCUL_POSSIBLE()
# - Objet  : Renvoie 1 si au moins un contexte est défini dans le dossier.
#
# - Entrée :
#
# - Sortie : 0 Pas de contexte défini
#            1 Au moins un contexte est défini dans le dossier
#
#

Local Integer CDRET  : CDRET =0
  If clalev([F:CNX]) = 0 : Local File CONTEXT [CNX]  : Endif
  Read [CNX]CNX0 First
  If ( fstat ) Then : CDRET = 1 : Endif
End CDRET

################################################################################
# Gestion du masque FASSIMU
# Ecran -- FASI --
################################################################################
Subprog AS_NBCPY
Local Integer N_I
Local Integer N_TROUVE

  Call AFFICHE_S_EN_G (GCURCPY)
  #------------------------------
  If ( nolign-1 < [M:MHC]NBCPY ) Then
    # On reçoit quelque chose lorqu'on passe la dernière ligne
    # Pas d'affectation quand on est sur la dernière ligne
    GCURCPY = nolign
    Call AFFICHE_G_EN_S (GCURCPY)
  Endif
  #------------------------------

End

########################################
Subprog B1_NBCPY
# Bouton "Toute la société"

  # Contrôle uniquement si le champ passe à G_OUI
  If ([M:MHC]FLGCLCCPY(GCURCPY-1) <> G_OUI ) Then
  Call C_FLGCLCCPY(G_OUI)
  Endif
  #------------------------------
  If (!GERR) Then
    Local Integer N_I
    # -------------
    # -- Société
    # -------------
    [M:MHC]FLGCLCCPY(nolign-1)  = G_OUI
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBCPY") From GLOBIENS
    # -------------
    # -- Sites
    # -------------
    # >>>>>>>
    For N_I = 1 To [M:MHC]NBFCY
      [M:MHC]FLGCLCFCY(N_I-1)  = G_OUI
    Next N_I
    # <<<<<<<
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCY") From GLOBIENS
    #------------------------------
    # -------------
    # -- Contextes
    # -------------
    # >>>>>>>
    For N_I = 1 To [M:FASI]NBCNX
      [M:FASI]FLGCLCCNX(N_I-1)  = G_OUI
      #[M:FASI]FLGSIMDET(N_I-1)  = G_OUI
    Next N_I
    # <<<<<<<
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNX") From GLOBIENS
    #------------------------------
    # -------------
    # -- Plans
    # -------------
    # >>>>>>>
    For N_I = 1 To [M:FASI]NBPLC
      [M:FASI]FLGCLCPLN(N_I-1)  = G_OUI
    Next N_I
    # <<<<<<<
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLC") From GLOBIENS
    #------------------------------
  Endif
  #------------------------------

  #--
  Call AFFICHE_S_EN_G (GCURCPY)

End

########################################
Subprog B2_NBCPY
# Bouton "La société et les suivantes"

Local Integer N_I, N_S, N_C, N_E, N_Z, N_P
Local Integer LNBFLD

  #------------------------- TOUTES SOCIETES
  #-- Sociétés
  # >>>>>>>>>>>>>>
  For N_S = GCURCPY To [M:MHC]NBCPY
    [M:MHC]FLGCLCCPY (N_S-1) = G_OUI
    # Calcul du nombre de champs si toutes sociétés calculées
    Call  EVALUE_NBFLD (LNBFLD)
    #------------------------------------
    #--  Sites
    For N_E = [M:MHC]FCYDEB (N_S-1) To [M:MHC]FCYFIN (N_S-1)
      [M:MHC]FLGCLCFCYG (N_E-1) = G_OUI
    Next N_E
    #-- Contextes
    For N_C = [M:MHC]CNXDEB (N_S-1) To [M:MHC]CNXFIN (N_S-1)
      [M:FASI]FLGCLCCNXG (N_C-1) = G_OUI
    Next N_C
    #-- Plans
    For N_P = [M:MHC]PLNDEB (N_S-1) To [M:MHC]PLNFIN (N_S-1)
      [M:FASI]FLGCLCPLNG (N_P-1) = G_OUI
    Next N_P
    #------------------------------------
  Next N_S
  # <<<<<<<<<<<<<<

  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBCPY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNXG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLCG") From GLOBIENS
  #------------------------------

  #------------------------- SOCIETE COURANTE
  Call AFFICHE_G_EN_S (GCURCPY)

End

########################################
Subprog B3_NBCPY
# Bouton "Toutes les sociétés"

Local Integer N_I, N_S, N_C, N_E, N_Z, N_P
Local Integer LNBFLDMAX
Local Integer LNBFLD

  #------------------------- TOUTES SOCIETES
  #-- Sociétés
  # >>>>>>>>>>>>>>
  For N_S = 1 To [M:MHC]NBCPY
    [M:MHC]FLGCLCCPY (N_S-1) = G_OUI
    #------------------------------------
    #--  Sites
    For N_E = [M:MHC]FCYDEB (N_S-1) To [M:MHC]FCYFIN (N_S-1)
      [M:MHC]FLGCLCFCYG (N_E-1) = G_OUI
    Next N_E
    #-- Contextes
    For N_C = [M:MHC]CNXDEB (N_S-1) To [M:MHC]CNXFIN (N_S-1)
      [M:FASI]FLGCLCCNXG (N_C-1) = G_OUI
    Next N_C
    #-- Plans
    For N_P = [M:MHC]PLNDEB (N_S-1) To [M:MHC]PLNFIN (N_S-1)
      [M:FASI]FLGCLCPLNG (N_P-1) = G_OUI
    Next N_P
  Next N_S
  # <<<<<<<<<<<<<<
  # Calcul du nombre de champs si toutes sociétés calculées
  Call  EVALUE_NBFLD (LNBFLD)

  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBCPY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNXG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLCG") From GLOBIENS
  #------------------------------

  #------------------------- SOCIETE COURANTE
  Call AFFICHE_G_EN_S (GCURCPY)

End

########################################
Subprog C_FLGCLCCPY(VALEUR)
Variable Integer VALEUR
   Local Integer NBCNX                       : # Nombre de contextes de la société
   Local Integer NBFCY                       : # Nombre de sites de la société

   Local Integer NBFLDFIX  : NBFLDFIX  = 5   : # Nombre de zones fixes
   Local Integer NBFLD                       : # Nombre de zones à mémoriser si la société était sélectionnée

   Local Integer NBFLDCPY  : NBFLDCPY  = 0   : # Nombre de zones tableau sociétés
   Local Integer NBFLDCNX  : NBFLDCNX  = 0   : # Nombre de zones tableau global contextes
   Local Integer NBFLDFCY  : NBFLDFCY  = 0   : # Nombre de zones tableau global sites
   Local Integer NBFLDPLN  : NBFLDPLN  = 0   : # Nombre de zones tableau global plans

   Local Integer N_I
 #--------------------
 If ( GBATCH = 1 and VALEUR = G_OUI ) Then
   # On est en saisie de requête et une société a été sélectionnée

   # >>>>>>>>>>>
   For N_I = 1 To [M:MHC]NBCPY
     #--------------------
     If ( [M:MHC]FLGCLCCPY(N_I-1) = G_OUI ) Then
       NBFLDCPY += 7
       NBCNX     = [M:MHC]CNXFIN(N_I-1) - [M:MHC]CNXDEB(N_I-1) + 1
       NBFLDCNX += (4 * NBCNX)
       NBFCY     = [M:MHC]FCYFIN(N_I-1) - [M:MHC]FCYDEB(N_I-1) + 1
       NBFLDFCY += (2 * NBFCY)
     Endif
     #--------------------
   Next N_I
   # >>>>>>>>>>>

   # Société que l'on vient de sélectionner
   # Masque Global
   NBFLDCPY += 7
   NBCNX     = [M:MHC]CNXFIN(nolign-1)-[M:MHC]CNXDEB(nolign-1)+1
   NBFLDCNX += (4 * NBCNX)
   NBFCY     = [M:MHC]FCYFIN(nolign-1)-[M:MHC]FCYDEB(nolign-1)+1
   NBFLDFCY += (2 * NBFCY)
   # Masque Société
   NBFLDCNX += (5 * NBCNX)
   NBFLDFCY += (4 * NBFCY)

   # Totalisation du nombre de zones à mémoriser
   NBFLD     = NBFLDFIX + NBFLDCPY + NBFLDFCY + NBFLDCNX + NBFLDPLN
 Endif
 #--------------------

End

########################################
Subprog AM_FLGCLCCPY(VALEUR)
Variable Integer VALEUR
Local Integer N_I

 #-------------------------------
 If ( VALEUR <> G_OUI ) Then
   # -------------
   # -- Sites
   # -------------
   # >>>>>>>
   For N_I = 1 To [M:MHC]NBFCY
     [M:MHC]FLGCLCFCY(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCY") From GLOBIENS
   #------------------------------
   # -------------
   # -- Contextes
   # -------------
   # >>>>>>>
   For N_I = 1 To [M:FASI]NBCNX
     [M:FASI]FLGCLCCNX(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNX") From GLOBIENS
   #------------------------------
   # -------------
   # -- Plans
   # -------------
   # >>>>>>>
   For N_I = 1 To [M:FASI]NBPLC
     [M:FASI]FLGCLCPLN(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLC") From GLOBIENS
   #------------------------------
 Endif
 #-------------------------------

 #--
 Call AFFICHE_S_EN_G (GCURCPY)

End

########################################
Subprog AM_FLGCLCCNX(VALEUR)
Variable Integer VALEUR
Local Integer N_I

 #-------------------------------
 If ( VALEUR <> G_OUI ) Then
   [M:FASI]FLGCLCCNX (nolign-1) = G_NON
   Grizo [M:FASI]HRSEXE(nolign-1)
   Grizo [M:FASI]HRSPER(nolign-1)
   Grizo [M:FASI]FLGSIMDET(nolign-1)
   # -------------
   # -- Plans
   # -------------
   # >>>>>>>
   For N_I = [M:FASI]PLNCNXDEB(nolign-1) To [M:FASI]PLNCNXFIN(nolign-1)
     [M:FASI]FLGCLCPLN(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLC") From GLOBIENS
   #------------------------------
 Else
   [M:FASI]FLGCLCCNX (nolign-1) = G_OUI
   Actzo [M:FASI]HRSEXE(nolign-1)
   Actzo [M:FASI]HRSPER(nolign-1)
   Actzo [M:FASI]FLGSIMDET(nolign-1)
   For N_I = [M:FASI]PLNCNXDEB(nolign-1) To [M:FASI]PLNCNXFIN(nolign-1)
     [M:FASI]FLGCLCPLN(N_I-1)  = G_OUI
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLC") From GLOBIENS
   #------------------------------
 Endif
 #-------------------------------

 #--
 Call AFFICHE_S_EN_G (GCURCPY)

End

########################################
Subprog AP_NBCPY
Local Integer N_I, SELCPY

Raz SELCPY
  If status=20
    For N_I = 1 To [M:MHC]NBCPY
      If [M:MHC]FLGCLCCPY(N_I-1) = G_OUI
        SELCPY += 1
      Endif
    Next
    If !SELCPY
      Call ERREUR ("Sélectionnez au moins une société") From GESECRAN
      mkstat=2
    Endif
  Endif
End

########################################
Subprog AM_FLGCLCPLN(VALEUR)
Variable Integer VALEUR
Local Integer N_P, N_C

  If VALEUR = G_OUI
    [M:FASI]FLGCLCPLN(nolign-1)  = G_OUI
    For N_C = 1 To [M:FASI]NBCNX
      For N_P = [M:FASI]PLNCNXDEB(N_C-1) To [M:FASI]PLNCNXFIN(N_C-1)
        If [M:FASI]FLGCLCPLN(N_P-1)  = G_OUI and [M:FASI]FLGCLCCNX(N_C-1) = G_NON
          Call ERREUR ("Contexte non sélectionné pour ce plan") From GESECRAN
          mkstat=2
        Endif
      Next N_P
    Next N_C

  Endif
End

########################################
Subprog AM_HRSEXE(VALEUR)
Variable Decimal VALEUR
  If( VALEUR < 2 ) Then
    # La valeur de ce champ doit être > 2
    GMESSAGE = mess(285, GML_MSGFASPR, 1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
  If ( VALEUR < [M:FASI]HRSPER(nolign-1) ) Then
    # Le nombre d'exercices avec périodes doit être inférieur ou égal au nombre d'exercices à calculer
    GMESSAGE = mess(286,GML_MSGFASPR,1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
End

########################################
Subprog AM_HRSPER(VALEUR)
Variable Decimal VALEUR
  If( VALEUR < 2 ) Then
    # La valeur de ce champ doit être > 2
    GMESSAGE = mess(285,GML_MSGFASPR,1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
  If ( VALEUR > [M:FASI]HRSEXE(nolign-1) ) Then
    # Le nombre d'exercices avec périodes doit être inférieur ou égal au nombre d'exercices à calculer
    GMESSAGE = mess(286,GML_MSGFASPR,1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
End

########################################
Subprog AFFICHE_G_EN_S (PIND)
# Affiche les sites et les contextes de la Société sélectionnée dans le tableau visible
#
Value Integer PIND
Local Integer N_I, N_C, N_E, N_P

  # -------------
  # -- Sites
  # -------------

  # -- Réinitialisation tableau Sites de la Société
  [M:MHC]NBFCY = 0
  Call ACTION_BLOCK (ACB_EFFZO, "MCFASCRI6", "NBFCY") From GLOBIENS

  N_E = 1

  #------------------------------
  #For N_I = 1 To [M:MHC]NBFCYG
  For N_I=[M:MHC]FCYDEB(PIND-1) To [M:MHC]FCYFIN(PIND-1)
    [M:MHC]FLGCLCFCY(N_E-1) = [M:MHC]FLGCLCFCYG  (N_I-1)
    [M:MHC]FCY      (N_E-1) = [M:MHC]FCYG        (N_I-1)
    [M:MHC]INDRETFCY(N_E-1) = N_I
    N_E += 1
  Next N_I
  #------------------------------
  [M:MHC]NBFCY = N_E-1
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCY") From GLOBIENS

  # -------------
  # -- Contextes
  # -------------
  # -- Réinitialisation tableau Contextes de la Société
  [M:FASI]NBCNX = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASSIMU", "NBCNX") From GLOBIENS

  N_C = 1
  #------------------------------
  For N_I = [M:MHC]CNXDEB(PIND-1) To [M:MHC]CNXFIN(PIND-1)
    [M:FASI]FLGCLCCNX(N_C-1) = [M:FASI]FLGCLCCNXG   (N_I-1)
    [M:FASI]CNX      (N_C-1) = [M:FASI]CNXG         (N_I-1)
    [M:FASI]DATSTRFIY(N_C-1) = [M:FASI]DATSTRFIYG   (N_I-1)
    [M:FASI]DATSTRPER(N_C-1) = [M:FASI]DATSTRPERG   (N_I-1)
    [M:FASI]HRSEXE(N_C-1)    = [M:FASI]HRSEXEG      (N_I-1)
    [M:FASI]HRSPER(N_C-1)    = [M:FASI]HRSPERG      (N_I-1)
    [M:FASI]INDRETCNX(N_C-1) = N_I
    [M:FASI]PLNCNXDEB(N_C-1) = [M:FASI]PLNCNXDEBG(N_I-1)
    [M:FASI]PLNCNXFIN(N_C-1) = [M:FASI]PLNCNXFING(N_I-1)
    [M:FASI]FLGSIMDET(N_C-1) = [M:FASI]FLGSIMDETG(N_I-1)
    N_C += 1
  Next N_I

  #------------------------------
  [M:FASI]NBCNX = N_C-1
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNX") From GLOBIENS
  #------------------------------

  # -------------
  # -- Plans
  # -------------
  # -- Réinitialisation tableau des plans de la Société
  [M:FASI]NBPLC = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASSIMU", "NBPLC") From GLOBIENS

  N_P = 1
  #------------------------------
  For N_I = [M:MHC]PLNDEB(PIND-1) To [M:MHC]PLNFIN(PIND-1)
    [M:FASI]PLNCAA   (N_P-1) = [M:FASI]PLNCAAG      (N_I-1)
    [M:FASI]FLGCLCPLN(N_P-1) = [M:FASI]FLGCLCPLNG   (N_I-1)
    [M:FASI]INDRETPLN(N_P-1) = N_I
    N_P += 1
  Next N_I
  #------------------------------
  [M:FASI]NBPLC = N_P-1
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLC") From GLOBIENS
  #------------------------------

End


########################################
Subprog AFFICHE_S_EN_G (PIND)
# renvoi les contextes et les sites modifiés de la société sélectionnée dans le tableau invisible

Value Integer PIND

Local Integer N_I, N_C, N_E, N_P

  # -------------
  # -- Sites
  # -------------
  # >>>>>>>
  For N_I = 1 To [M:MHC]NBFCY
    N_E = [M:MHC]INDRETFCY(N_I-1)
    [M:MHC]FLGCLCFCYG(N_E-1)  = [M:MHC]FLGCLCFCY(N_I-1)
  Next N_I
  # <<<<<<<
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "MCFASCRI6", "NBFCYG") From GLOBIENS
  #------------------------------
  # -------------
  # -- Contextes
  # -------------
  # >>>>>>>
  For N_I = 1 To [M:FASI]NBCNX
    N_C = [M:FASI]INDRETCNX(N_I-1)
    [M:FASI]FLGCLCCNXG(N_C-1)  = [M:FASI]FLGCLCCNX   (N_I-1)
    [M:FASI]HRSEXEG(N_C-1)     = [M:FASI]HRSEXE   (N_I-1)
    [M:FASI]HRSPERG(N_C-1)     = [M:FASI]HRSPER   (N_I-1)
    [M:FASI]FLGSIMDETG(N_C-1)  = [M:FASI]FLGSIMDET   (N_I-1)
  Next N_I
  # <<<<<<<
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBCNXG") From GLOBIENS
  #------------------------------
  # -------------
  # -- Plans
  # -------------
  # >>>>>>>
  For N_I = 1 To [M:FASI]NBPLC
    N_P = [M:FASI]INDRETPLN(N_I-1)
    [M:FASI]FLGCLCPLNG(N_P-1)  = [M:FASI]FLGCLCPLN   (N_I-1)
  Next N_I
  # <<<<<<<
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASSIMU", "NBPLCG") From GLOBIENS
  #------------------------------
End


######################################################################################

#-------------------------------------------------------------------------------
$SIMULER_SOCIETES

# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#  A maintenir en parallèle
#  SIMULER_SOCIETES de FASSIMU
#  CALCULER_SOCIETES de FASCALC
#  CALCULER_BIEN     de GLOBB0
#  SIMULER_CALCUL_BIEN  de GLOBB
#  SIMULER_VALEUR_NETTE de GLOBB
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

Local Integer N_I, N_S, N_E, N_C, N_J, N_P
Local Char    TABFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))  : # Tableau des sociétés
Local Integer TABCNT(0..G300MAX-1)                        : # Tableau des contextes
Local Integer TABPLN(1..G301MAX)                          : # Tableau des plans
Local Integer THZEXE(0..G300MAX-1)                        : # Tableau horizons exercice
Local Integer THZPER(0..G300MAX-1)                        : # Tableau horizons périodes
Local Integer TDETAI(0..G300MAX-1)                        : # Tableau indicteur détail
Local Char    CRITSUP(255)                                : # Sélection étendue
Local Decimal LERROR


Local Char    LCNBRTRY
Local Integer LNBRTRY
Local Decimal LCLCERR
Local Integer TCLCCPY(0..func AFNC.ACTIV("SOC"))
Local Integer TNBRTRY(0..func AFNC.ACTIV("SOC"))

Local Integer RTRN

  # Construction critère supplémentaire (onglet ASELOBJ)
    # FQ84645
  [M]NBTBL = 0
  Raz CRITSUP
  Gosub EXPRESSION From ASELOBJ
  If ( EXPRESSION <> "" ) Then
   CRITSUP=EXPRESSION
  Endif

  # Heure de démarrage
  Global Integer G_TIMD     : G_TIMD = time

  #-- Ouverture écran CALDIV
  If clalev([M:DIV]) =0  : Local Mask CALDIV     [DIV]   :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2    [DIV2]  :  Endif             : # Infos diverses FQ77877

  #--
  # Initialisation des constantes
  [M:DIV]CSTLVLMAX = 10
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ64639
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:DD[/]MM[/]YYYY"
  [M:DIV]TRTLVL    = 0                    : # -- Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]TRTDEM    = "CALDPS"             : # -- Traitement demandeur


  # Ouverture du Compte-rendu
  # si GSERVEUR c'est le traitement batch lui-même qui ouvre la trace
  If ( !(GSERVEUR) and GTRACE = "" ) Then
    # La trace n'est pas déjà ouverte
    Call OUVRE_TRACE(mess(1,GML_MSGCAL,1))  From LECFIC
  Endif
  Call ECR_TRACE(mess(178,GML_MSGCAL,1),0) From GLOBB0   : # COMPTE RENDU TRAITEMENT DE SIMULATION D'AMORTISSEMENTS

  #================
  # Gestionnaire d'erreurs
  Onerrgo KO From GLOBB0
  #================

  # Nombre d'essais
  Call PARAM("","NBESSCLC",LCNBRTRY) From ADOVAL
  LNBRTRY = val(LCNBRTRY)
  If ( LNBRTRY < 0 ) Then : LNBRTRY = 0 : Endif
  # Initialisation TBNRTY, TCLCCPY
  For N_S = 1 To [M:MHC]NBCPY
    TCLCCPY(N_S-1)=G_NON
    If ([M:MHC]FLGCLCCPY(N_S-1)= G_OUI) Then : TCLCCPY(N_S-1)= G_OUI : TNBRTRY(N_S-1)= LNBRTRY : Endif
  Next N_S

  LCLCERR     = 0
  # >>>>>>>>>>>>>>>>
  Repeat
    LRETENTECLC = 0
    LNBSLEEP    = 0
    # >>>>>>>>>>>>>>>>
    For N_S = 1 To [M:MHC]NBCPY
      #-1 -----------------
      # Si la société est à calculer
      If ( TCLCCPY(N_S-1) = G_OUI ) Then
        # Tableau des sites à calculer
        Raz TABFCY : N_I = 1
        For N_E = [M:MHC]FCYDEB(N_S-1) To [M:MHC]FCYFIN(N_S-1)
          If ([M:MHC]FLGCLCFCYG(N_E-1) = G_OUI) Then : TABFCY(N_I) = [M:MHC]FCYG(N_E-1)  : # N_I += 1 : Endif
            N_I += 1
            Endif
        Next N_E
        # Tableau des contextes à calculer
        Raz TABCNT : N_I = 0
        For N_C = [M:MHC]CNXDEB(N_S-1) To [M:MHC]CNXFIN(N_S-1)
          If ([M:FASI]FLGCLCCNXG(N_C-1) = G_OUI) Then : TABCNT(N_I) = [M:FASI]CNXG(N_C-1) : # N_I += 1 : Endif
            # Tableau des horizon exercice à calculer
            THZEXE(N_I) = [M:FASI]HRSEXEG(N_C-1)
            # Tableau des horizon périodes à calculer
            THZPER(N_I) = [M:FASI]HRSPERG(N_C-1)
            # Tableau des horizon exercice à calculer
            TDETAI(N_I) = [M:FASI]FLGSIMDETG(N_C-1)
            N_I += 1
          Endif
        Next N_C
        # -- Tableau des plans à calculer
        Raz TABPLN : N_I = 1
        For N_P = [M:MHC]PLNDEB(N_S-1) To [M:MHC]PLNFIN(N_S-1)
          If ([M:FASI]FLGCLCPLNG(N_P-1) = G_OUI)
            TABPLN(N_I) = [M:FASI]PLNCAAG(N_P-1)
            N_I += 1
          Endif
        Next N_P

        #-2 -----------------
        If ( LCLCERR = -3 and LNBSLEEP < 4  ) Then
          # Si précédemment le calcul a échoué parce qu'on n'a pas pu verrouillé FXDASSETS ou CONTEXT
          # temporisation d'une minute avant de tenter de recalculer.
          # Au cours d'un REPEAT, 3 temporisations maximum.
          Call TEMPON(mess(79,GML_MSGCAL,1)-[M:MHC]CPY(N_S-1)) From GESECRAN
          Sleep 5
          LNBSLEEP += 1
        Endif
        #-2 -----------------

        Call TEMPON(mess(78,GML_MSGCAL,1)-[M:MHC]CPY(N_S-1)) From GESECRAN
        # Calcul de la société
        #    **************
        Call SIMULER_SOCIETE ([M:MHC]CPY(N_S-1), TABFCY, TABCNT, TABPLN, THZEXE, THZPER, TDETAI, CRITSUP, LERROR) From GLOBB
        #    **************
        # Arrêt du traitement si dépassement du temps limite
        If ( LCLCERR = -2 ) Then : Break 2 : Endif
        TNBRTRY(N_S-1) -= 1
        If ( LCLCERR  = -3 and TNBRTRY(N_S-1) > 0 ) Then
          # Société non verrouillée & au moins un essai restant ( le calcul sera retenté pour cette société )
          LRETENTECLC = 1
        Elsif ( LCLCERR <> -3 or ( LCLCERR = -3 and TNBRTRY(N_S-1) = 0 ) ) Then
          # Société à ne plus calculer ( Calcul effectué ou Aucun essai restant ou en erreur)
          TCLCCPY(N_S-1) = G_NON
        Endif
      Endif
      #-1 -----------------
    Next N_S
    # >>>>>>>>>>>>>>>>
  Until LRETENTECLC = 0
  # >>>>>>>>>>>>>>>>
  #--

  Call ECR_TRACE(string$(80, '-'),0) From GLOBB0

  Call TEMPOFF() From GESECRAN

  # Fermeture du Compte-rendu
  If ( !(GSERVEUR) ) Then
    Call FERME_TRACE From LECFIC
  Endif

  # Visualisation du Compte-rendu
  If !( GSERVEUR ) Then : Call LEC_TRACE From LECFIC : Endif

  #--
  # Fermeture écran CALDIV
  If (clalev([M:DIV]))   Then : Close Local Mask [DIV]   : Endif : # Infos diverses
  If (clalev([M:DIV2]))  Then : Close Local Mask [DIV2]  : Endif : # Infos diverses FQ77877

  # Heure de début de calcul
  If (dim(G_TIMD)    >0) Then : Kill G_TIMD     : Endif

Return


######################################################################################
