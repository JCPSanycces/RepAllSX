#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

#######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR
Variable Char    PARAMETRE()()
Local Integer    IMPR

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

# BRBAN 25/11/2014 - 97101 - Printing requirements
[L]CRITERE = "1=1"
[L]CRITERE2 = "1=1"

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Call GETPARAM ([L]PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
#  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
    When "X3ETA"           : [L]ETAT = [L]VALEUR
    When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
    #--- alimentation des paramètres utilisateur
    When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
    When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
    When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
    When "euro"            : [L]PARAMETRE(I) = "euro="+GEURO
    # BRBAN 25/11/2014 - 97101 - Filter for SOH
    When "sitedeb"         : [L]CRITERE -= "& SALFCY>='"+[L]VALEUR+"'"
    When "sitefin"         : [L]CRITERE -= "& SALFCY<='"+[L]VALEUR+"'"
    When "clientdeb"       : [L]CRITERE -= "& BPCORD>='"+[L]VALEUR+"'"
    When "clientfin"       : [L]CRITERE -= "& BPCORD<='"+[L]VALEUR+"'"
    When "commandedeb"     : [L]CRITERE -= "& SOHNUM>='"+[L]VALEUR+"'"
    When "commandefin"     : [L]CRITERE -= "& SOHNUM<='"+[L]VALEUR+"'"
    When "avenantdeb"      : [L]CRITERE -= "& REVNUM>="+num$([L]VALEUR)
    When "avenantfin"      : [L]CRITERE -= "& REVNUM<="+num$([L]VALEUR)
    When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& ORDDAT >=["+format$(GFMD,[L]DATREF)+']'
    When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& ORDDAT <=["+format$(GFMD,[L]DATREF)+']'
    When "devdeb"          : [L]CRITERE2 -= "& CUR>='"+[L]VALEUR+"'"
    When "devfin"          : [L]CRITERE2 -= "& CUR<='"+[L]VALEUR+"'"
    When "typecommandedeb" : [L]CRITERE2 -= "& SOHTYP>='"+[L]VALEUR+"'"
    When "typecommandefin" : [L]CRITERE2 -= "& SOHTYP<='"+[L]VALEUR+"'"
  Endcase
 Endif
Next
[L]CRITERE -= "& SOHCAT="+num$(4) # BRBAN 25/11/2014 - Only Open orders

Filter [F:SOH] Where evalue([L]CRITERE) & evalue([L]CRITERE2)

Look [ARM]ARM0=[L]NUMREQ;GUSER;[F:ARP]RPTCOD;1   # FGR 22/10/2015 : X3SUIVI111379
If fstat Then                                    # FGR 22/10/2015 : X3SUIVI111379
  Filter [F:SOH] Where evalue([L]CRITERE) & evalue([L]CRITERE2)
  Gosub TRT_SOH
Endif

Filter [F:SOH]

End

###########################################################################
$TRT_SOH

Raz WNUMLIG, WNUMCOP
Default File [SOH]
For [F:SOH]SOH0
  Call DEBTRANS From GLOCK
  Raz WNUMCOP
  If [L]IMPR = 1  Gosub TR1  # impression
  Else            Gosub TR2  # re-impression
  Endif
Next
If CKPO = 1 & [L]CKPOELEM <> 1 : Call ECR_TRACE(mess(201,7711,1),1) From GESECRAN : GOK = 0  : Endif
Return
###########################################################################
$TR1
  Trbegin [SOH] , [ARM] , [TRPT]
  # Mise à jour table entête commande si demande d'impression
  If [L]IMPR = 1
    Readlock [F:SOH]SOH0 Curr
    If fstat = 1 : GOK = -1 : GLOCK = "$SORDER" : Goto ROLL_TR1
    Elsif fstat  : GOK = 0 : Call RSTA("SOH","*") From GLOCK : Goto AB_TR1
    Endif
    [F:SOH]OCNPRN = 2
    Rewrite [F:SOH]
    If fstat=1
      GOK=-1 : GLOCK="$SORDER"-[F:SOH]SOHNUM
      Goto ROLL_TR1
    Elsif fstat
      GOK=0 : Call RSTA("SORDER",[F:SOH]SOHNUM) From GLOCK : Goto AB_TR1
    Endif
  Endif
  #Création de l'enregistrement dans la table AREPORTM
  Local Integer INBCOP
  For INBCOP=1 To max(1,[M:RPT]NBRCPY)
    WNUMLIG      += 1
    WNUMCOP      += 1
    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]NUMCOP  = WNUMCOP
    [F:ARM]CLEA1   = [F:SOH]SOHNUM
    [F:ARM]CREDAT  = date$
    Write [F:ARM]
    If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
  Next INBCOP

  # Issue 110704 - 2016-01-04 by RICAR
  If CKPO = 1
    Gosub ALIM_TMPSRPT
    If GOK = 0 : Goto AB_TR1 : Endif
  Endif
  #

  Commit
Return

$ROLL_TR1
  Rollback : Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
  Rollback
Return
###########################################################################
$TR2
  Trbegin [ARM] , [TRPT]
  #Création de l'enregistrement dans la table AREPORTM
  Local Integer INBCOP
  For INBCOP=1 To max(1,[M:RPT]NBRCPY)
    WNUMLIG      += 1
    WNUMCOP      += 1
    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]NUMCOP  = WNUMCOP
    [F:ARM]CLEA1   = [F:SOH]SOHNUM
    [F:ARM]CREDAT  = date$
    Write [F:ARM]
    If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
  Next INBCOP

  # Issue 110704 - 2016-01-04 by RICAR
  If CKPO = 1
    Gosub ALIM_TMPSRPT
    If GOK = 0 : Goto AB_TR2 : Endif
  Endif
  #

  Commit
Return

$ROLL_TR2
  Rollback : Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
  Rollback
Return
###########################################################################
$OUVRE
# BRBAN 25/11/2014 - 97101
Local File TMPSRPT    [TRPT]
Local File AREPORTM   [ARM]
Local File SORDER     [SOH]
# Issue 110704 - 2016-01-04 by RICAR
Local Integer CKPO     : [L]CKPO     = 0
Local Integer CKPOELEM : [L]CKPOELEM = 0

Return

$DECLARE
#Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15)
#Local Integer WNUMLIG, NUMREQ

Local Char    CRITERE(250), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(15)
Local Integer WNUMLIG, WNUMCOP, NUMREQ, IMPR

# BRBAN 25/11/2014 - 97101
Local Integer CASENUMB(0..9) : Raz [L]CASENUMB
Local Char HDR(250)(0..3)    : Raz [L]HDR
Local Char FTR(250)          : Raz [L]FTR
#Local Char CRITERE2(255)     : [L]CRITERE2 = ""
Local Date  DATREF           : [L]DATREF=[0/0/0]
#Local Integer NUMREQ         : [L]NUMREQ=0

# Issue 110704 - 2016-01-04 by RICAR
If func AFNC.ACTIV('KPO')>0
  CKPO = 1
Endif

Return
#########################################################################
$ALIM_TMPSRPT

Raz [F:TRPT]

[F:TRPT]       = [F:ARM]
[F:TRPT]VCRNUM = [F:SOH]SOHNUM

Write [F:TRPT]
If fstat : GOK=0 : Call FSTA("TRPT") From GLOCK : Else : [L]CKPOELEM = 1 Endif

Return

