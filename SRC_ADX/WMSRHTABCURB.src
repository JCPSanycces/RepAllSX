$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 3383: RES='Table des Devises'
   When 323: RES='Devise'
   When 8: RES='Intitulé'
   When 4010: RES='Intitulé court'
  Endcase
 When "ENG":
  Case _ID
   When 3383: RES='Currency table'
   When 323: RES='Currency'
   When 8: RES='Description'
   When 4010: RES='Short description'
  Endcase
 When "ITA":
  Case _ID
   When 3383: RES='Tabella delle valute'
   When 323: RES='Valuta'
   When 8: RES='Descrizione'
   When 4010: RES='Descr. breve'
  Endcase
 When "POR":
  Case _ID
   When 3383: RES='Tabela das Divisas'
   When 323: RES='Divisa'
   When 8: RES='Descr.'
   When 4010: RES='Desc. curta'
  Endcase
 When "SPA":
  Case _ID
   When 3383: RES='Tabla de Divisas'
   When 323: RES='Divisa'
   When 8: RES='Descripción'
   When 4010: RES='Descrip. corta'
  Endcase
 When "BRI":
  Case _ID
   When 3383: RES='Currencies'
   When 323: RES='Currency'
   When 8: RES='Description'
   When 4010: RES='Short title'
  Endcase
 When "GER":
  Case _ID
   When 3383: RES='Währungstabelle'
   When 323: RES='Währung'
   When 8: RES='Bezeichnung'
   When 4010: RES='Kurzbezeichnung'
  Endcase
 When "POL":
  Case _ID
   When 3383: RES='Waluty'
   When 323: RES='Waluta'
   When 8: RES='Opis'
   When 4010: RES='Krótki tytuł'
  Endcase
 When "CHI":
  Case _ID
   When 3383: RES='货币'
   When 323: RES='货币'
   When 8: RES='标题'
   When 4010: RES='简称'
  Endcase
 When "ARB":
  Case _ID
   When 3383: RES='جدول العملات'
   When 323: RES='العملة'
   When 8: RES='العنوان'
   When 4010: RES='وصف قصير'
  Endcase
Endcase
Return
