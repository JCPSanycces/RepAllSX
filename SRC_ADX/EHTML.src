#<AdxTL>@(#)0.0.0.0 $Revision$ EHTML datatype management
############################################
# EHTML datatype management
############################################
#
# This datatype is designed to manage Embeded HTML
# dynamicaly in a representation
#
# The first parameter, VOLUME, gives the type of link
# The second parameter, NAME, give parameters depending on VOLUME
#
#    VOLUME       |      VALUE
# -----------------------------------
#   GOOGLE MAPS   | adress or GPS coordinates
#   OPENSTREETMAP | adress or GPS coordinates
############################################

#-------------------------------------------------------------#
Funprog GET_CLOBEXIST(AINSTANCE,APRONAME,AEXIST,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Tinyint  AEXIST
Value    Char     VOLUME
Value    Char     NAME

  [L]AEXIST=1

End 0

#-------------------------------------------------------------#
Funprog GET_CLOBFILE(AINSTANCE,APRONAME,AVALUE,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char    APRONAME
Variable Clbfile AVALUE
Value    Char    VOLUME
Value    Char    NAME

  Case VOLUME
    When "GOOGLE MAPS"
      Call GOOGLE_MAPS(AVALUE,NAME)
    When "OPENSTREETMAP"
      Call OPENSTREETMAP(AVALUE,NAME)
    When Default
      Setlob AVALUE With ""
  Endcase

End 0

#-------------------------------------------------------------#
Funprog GOOGLE_MAPS(CLOB, PARAM)
Variable Clbfile CLOB
Value    Char    PARAM

  # Voir le traitement TRTITI / LOAD_ITINERAIRE pour plus d'options

  Local Char TEXTE(250)(10)

  If PARAM <> AVOID.ACHAR
    TEXTE(0) = '<iframe width="640" height="480" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://www.google.fr/maps?t=m&amp;q='
    TEXTE(1) = PARAM
    TEXTE(2) = '&amp;output=embed"></iframe>'
    TEXTE(3) = '<br />'
    TEXTE(4) = '<small><a href="https://www.google.fr/maps?q='
    TEXTE(5) = PARAM
    TEXTE(6) = '" style="color:#0000FF;text-align:left" target="_blank">'+mess(12,7837,1)+'</a></small>'
  Endif

  Setlob CLOB With TEXTE
End

#-------------------------------------------------------------#
Funprog OPENSTREETMAP(CLOB, PARAM)
Variable Clbfile CLOB
Value    Char    PARAM

  Local Char TEXTE(250)(10)

  If PARAM <> AVOID.ACHAR
    TEXTE(0) = '<iframe width="640" height="480" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="http://nominatim.openstreetmap.org/search.php?q='
    TEXTE(1) = PARAM
    TEXTE(2) = '"</iframe>'
  Endif

  Setlob CLOB With TEXTE
End
