#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SDELIVERYD
#######################################################################################
End

#######################################################################################
$AINIT

  [L]ASTATUS = fmet this.INIT_TSICODADI()

Return
#######################################################################################
$INIT_TSICODADI
Local Integer DIM_STI
Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSICOD(NI).TSICODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK

Return
#######################################################################################
$AREAD_AFTER

  [L]ASTATUS = fmet this.INIT_TSICODADI()

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.LEG=""
    #--sinon il faut initialiser à partir de SALFCY
    #--Chargement de la LEG et de la devise société du document
    If this.STOFCY<>""
      Local File FACILITY [FCY]
      Local File COMPANY  [CPY]

      Read [F:FCY]FCY0=this.STOFCY
      If fstat Raz [F:FCY] Endif
      Read [F:CPY]CPY0=[F:FCY]LEGCPY
      If fstat Raz [F:CPY] : Endif

      this.LEG    = [F:CPY]LEG
    Endif
  Endif

Return
#######################################################################################
$AREAD_AFTER_C_VACITM

  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACITM, VAT
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.STOFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACITM_LEG(this.APARENT, this.VACITM, this.APARENT.CPY, this.APARENT.STOFCY, this.APARENT.LEG, this.VACITM_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
$AREAD_AFTER_C_VAT

  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACITM, VAT
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.STOFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.VAT, this.APARENT.CPY, this.APARENT.STOFCY, this.APARENT.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

