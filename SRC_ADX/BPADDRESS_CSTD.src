#<AdxTL>@(#)11.0.0.0 $Revision$
###############################################################################################
# CLASS BPADDRESS
###############################################################################################

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"                : Gosub AREAD_AFTER
      When "AINSERT_BEFORE"             : Gosub AINSERT_BEFORE
      When "AUPDATE_BEFORE"             : Gosub AUPDATE_BEFORE
      When "ACONTROL"                   : Gosub ACONTROL
      When "AINIT"                      : Gosub AINIT
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "POSCOD"         : Gosub POSCOD
  When "CTY"            : Gosub CTY
  When "CRY"            : Gosub CRY
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



###############################################################################################
$AREAD_AFTER
Gosub TRANS_COLUMN_CLASS
Return


###############################################################################################
$AINSERT_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

###############################################################################################
$AUPDATE_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

###############################################################################################
$ACONTROL
If dim(this.VLYSTR)>0 & this.VLYSTR<>AVOID.ADATE and this.VLYEND<>AVOID.ADATE
  If this.VLYSTR>this.VLYEND
    #La date de début est supérieure à la date de fin
    ASTATUS = fmet this.ASETERROR("VLYSTR",mess(265,133,1),[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$AINIT
Local Integer ITRANS
For ITRANS=1 To maxtab(this.COLTEL)
  this.COLTEL(ITRANS).TELTYP=ITRANS
Next
For ITRANS=1 To maxtab(this.COLTEL)
  this.COLWEB(ITRANS).WEBTYP=ITRANS
Next
Return

###############################################################################################
$TRANS_CLASS_COLUMN
Local Integer ITRANS

#name lines
If dim(this.NAM1)>0
  [F:BPA]NAM(0)=this.NAM1
  [F:BPA]NAM(1)=this.NAM2
Endif

#adress lines
[F:BPA]BPAADDLIG(0)=this.BPAADDLIG1
[F:BPA]BPAADDLIG(1)=this.BPAADDLIG2
[F:BPA]BPAADDLIG(2)=this.BPAADDLIG3
#Phone number

#**For ITRANS=1 To 5  :# When ritching a company with no address
For ITRANS=1 To maxtab(this.COLTEL)
If dim([F:BPA]TEL)>0
  [F:BPA]TEL(this.COLTEL(ITRANS).TELTYP -1)=this.COLTEL(ITRANS).TELNUM
  Endif
Next

#mail adress
#**using maxtab instead of 5
For ITRANS=1 To maxtab(this.COLWEB)
  [F:BPA]WEB(this.COLWEB(ITRANS).WEBTYP-1)=this.COLWEB(ITRANS).WEBADR
Next
Return

###############################################################################################
$TRANS_COLUMN_CLASS
Local Integer ITRANS
Local File BPADDRESS [BPA2]
Read [F:BPA2]BPA0 = this.BPATYP;this.BPANUM;this.BPAADD
If fstat= CST_AOK
 #name lines
 If dim(this.NAM1)>0
   this.NAM1=[F:BPA2]NAM(0)
   this.NAM2=[F:BPA2]NAM(1)
 Endif

 #adress lines
 this.BPAADDLIG1=[F:BPA2]BPAADDLIG(0)
 this.BPAADDLIG2=[F:BPA2]BPAADDLIG(1)
 this.BPAADDLIG3=[F:BPA2]BPAADDLIG(2)
 #Phone number
 #**For ITRANS=1 To 5  :# When ritching a company with no address
 For ITRANS=1 To maxtab(this.COLTEL)
   this.COLTEL(ITRANS).TELNUM=[F:BPA2]TEL(ITRANS-1)
   this.COLTEL(ITRANS).TELTYP=ITRANS
 Next
 #mail adress
 #** using maxtab instead of 5
 For ITRANS=1 To maxtab(this.COLWEB)
   this.COLWEB(ITRANS).WEBADR=[F:BPA2]WEB(ITRANS-1)
   this.COLWEB(ITRANS).WEBTYP=ITRANS
 Next
Endif
Return





###############################################################################################
$POSCOD
Case [L]ARULE
  When "PROPAGATE"      : Gosub POSCOD_PROPAGATE
Endcase
Return

$POSCOD_PROPAGATE
Gosub FILL_DATA
Return

###############################################################################################
$CTY
Case [L]ARULE
  When "PROPAGATE"      : Gosub CTY_PROPAGATE
Endcase
Return

$CTY_PROPAGATE
Gosub FILL_DATA
Return

###############################################################################################
$FILL_DATA
If this.CTY<>""
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"POSCODCTL")=[V]CST_AYES
    Local File POSCOD [POS]
    Read [POS]POS1 = this.CRY;toupper(this.CTY);this.POSCOD
    If fstat = [V]CST_AOK
      If dim(this.CODSEE)>0
        this.CODSEE = [F:POS]POSCTYCOD
      Endif
      this.SAT    = [F:POS]SATCOD
    Else
      Read [POS]POS0(2) = this.CRY;this.POSCOD
      If fstat = [V]CST_AOK
        If dim(this.CODSEE)>0
          this.CODSEE = [F:POS]POSCTYCOD
        Endif
        this.CTY    = [F:POS]POSCTY
        this.SAT    = [F:POS]SATCOD
      Else
        If dim(this.CODSEE)>0
          this.CODSEE = AVOID.ACHAR
        Endif
      Endif
    Endif
  Endif
Endif
Return

###############################################################################################
$CRY
Case [L]ARULE
  When "PROPAGATE"      : Gosub CRY_PROPAGATE
Endcase
Return

$CRY_PROPAGATE
If this.CRY<>""
  Local Instance MYCRY Using C_TABCOUNTRY
  MYCRY = NewInstance C_TABCOUNTRY AllocGroup null
  ASTATUS= fmet MYCRY.AREAD(this.CRY)
  If ASTATUS=CST_AOK
    this.CRYNAM=MYCRY.CRYDES
  Endif
  FreeGroup MYCRY
Endif
Return

###############################################################################################
Funprog CTRL_ADR( COLADR)
Variable Instance COLADR (1..) Using C_BPADDRESS
Local Integer ASTATUS

[L]ASTATUS =CST_AOK
#date control
Local Integer  I , J
Local Char MESSAGE (250)
Local Integer NDEFAULT
Local Integer NBADRESS

If dim(this.VLYSTR(0))>0 & dim(this.TYPADD(0))>0
  Local Date TMPVLYSTR (1..)
  Local Date TMPVLYEND (1..)
  Local Integer TMPTYPADD (1..)
  Local Char  TMPBPAADD (GLONADR) (1..)
  Local Integer TMPINDICE (1..)
  Local Integer TMPNB

  J=0
  For I=1 To maxtab(COLADR)
    If COLADR(I).ASTALIN <>CST_ADEL
      TMPVLYSTR(J)=COLADR(I).VLYSTR
      TMPVLYEND(J)=COLADR(I).VLYEND
      TMPTYPADD(J)=COLADR(I).TYPADD
      TMPBPAADD(J)=COLADR(I).BPAADD
      TMPINDICE(J)=I
      J=J+1
      TMPNB=J
    Endif
  Next I
  If TMPNB>2
    Sorta TMPTYPADD,TMPVLYSTR,TMPVLYEND, TMPBPAADD, TMPINDICE Order By TMPTYPADD([S]indice), TMPVLYSTR([S]indice)
    For I=0 To TMPNB-2
      For J=I+1 To TMPNB-1
        If TMPTYPADD(I)=TMPTYPADD(J)
          If (TMPVLYSTR(I)=[0/0/0] & TMPVLYEND(I)=[0/0/0])
&           | (TMPVLYSTR(J)=[0/0/0] & TMPVLYEND(J)=[0/0/0])
&           | (TMPVLYSTR(I)=[0/0/0] & TMPVLYSTR(J)<=TMPVLYEND(I))
&           | (TMPVLYSTR(J)=[0/0/0] & TMPVLYSTR(I)<=TMPVLYEND(J))
&           | (TMPVLYEND(I)=[0/0/0] & TMPVLYEND(J)>=TMPVLYSTRR(I))
&           | (TMPVLYEND(J)=[0/0/0] & TMPVLYEND(I)>=TMPVLYSTR(J))
&           | (TMPVLYSTR(I)<=TMPVLYEND(J) & TMPVLYEND(I)>=TMPVLYSTR(J))
&           | (TMPVLYSTR(J)<=TMPVLYEND(I) & TMPVLYEND(J)>=TMPVLYSTR(I))
            # Chevauchement de dates de validité des adresses
            #Call ERREUR(mess(175,133,1)-":"-[M]CODADR(I)-[M]CODADR(J)) From GESECRAN
            MESSAGE = mess(175,133,1)-":"-TMPBPAADD(I)-TMPBPAADD(J)
            [L]ASTATUS = fmet COLADR(J).ASETERROR("VLYSTR",MESSAGE,[V]CST_AERROR)
            Break 2
          Endif
        Endif
      Next J
    Next I
  Endif
Endif

#Nukmber of default values
For I=1 To maxtab(COLADR)
  If COLADR(I).BPAADD=AVOID.ACHAR
    Break
  Elsif find(COLADR(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=[V]CST_AFALSE
    NBADRESS=NBADRESS+1
    If COLADR(I).BPAADDFLG= 2
      NDEFAULT=NDEFAULT+1
      If NDEFAULT>1
        #One address should be set as a default
        [L]ASTATUS = fmet COLADR(I).ASETERROR("BPAADDFLG",mess(41,133,1),[V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next I
If NDEFAULT=0  and  NBADRESS>0
  #One address should be set as a default
  [L]ASTATUS = fmet COLADR(1).ASETERROR("BPAADDFLG",mess(41,133,1),[V]CST_AERROR)
Endif



#Unicity Control
Local File BPADDRESS [BPA]
For I=1 To maxtab(COLADR)
  If COLADR(I).BPAADD=AVOID.ACHAR
    Break
  Elsif COLADR(I).ASTALIN =[V]CST_ANEW
    For J=I+1 To maxtab(COLADR)
      If COLADR(I).BPAADD=COLADR(J).BPAADD
        If COLADR(J).ASTALIN <> CST_ADEL
          #Address code $1$ already exists.
          MESSAGE=func ASYRFNC.MES1(mess(263,133,1), COLADR(J).BPAADD )
          [L]ASTATUS = fmet COLADR(J).ASETERROR("BPAADD",MESSAGE,[V]CST_AERROR)
          Break
        Endif
      Endif
    Next J
    If [L]ASTATUS=CST_AOK
      Look [BPA] BPA0=COLADR(I).BPATYP;COLADR(I).BPANUM;COLADR(I).BPAADD
      If fstat = 0
        #Address code $1$ already exists..
        MESSAGE=func ASYRFNC.MES1(mess(263,133,1), COLADR(I).BPAADD )
        [L]ASTATUS = fmet COLADR(I).ASETERROR("BPAADD",MESSAGE,[V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next I

End [L]ASTATUS

