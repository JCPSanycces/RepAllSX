#If GERR & GMESSAGE = ""
# GMESSAGE="GETSUBORDONNESFLUX :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# #           Dimension des variables infûˋrieure û  $1$
#Endif
#
#GUSER   = SVUSER
#GPROFIL = SVPROFIL
#GUSRACS = SVUSRACS
#GREFNUM = SVREFNUM
#If CREAGLOB
# Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR
#Endif
#Onerrgo
#
#End
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnûˋs EMPSBD (ESB)
#-----------------------------------------------------------

Subprog GETSUBORDONNESFLUX(MATRICULE,FLUX,REFNUM,CTRNUM,DAT,NAM,SRN,NSRN
&                         ,DATFIN,SOCIETE,SITE,SERVICE,PRFCOD,POPULATION,GROUPE
&                          )
Value    Char    MATRICULE
Value    Char    FLUX()
Value    Date    DAT
Variable Char    REFNUM()(0..), CTRNUM()(0..), NAM()(0..), SRN()(0..), NSRN()(0..)
# Ajout critû´res de sûˋlection
Value    Date    DATFIN
Value    Char    SOCIETE(), SITE(), SERVICE(), PRFCOD(), POPULATION(), GROUPE()(0..)

Local Shortint   N
Local Libelle    I, J ,INDEX
Local Integer    OK
# SEGAY - 28/10/11 - FQ77414
# OKF =1 , on n'a pas besoin de lire par la table des subordonnûˋes
# OKF =0 , on lit par la table des subordonnûˋes
Local Integer    OKF
Local Char       CRITERE(150) , CRITERE1 (250) , CRITERE2 (250)
# SEGAY - 28/10/11 - FQ77414
# Critû´re sur la table des subordonnûˋes ou [CTR]REFNUM=MATRICULE(lui-mûˆme)
Local Char       CRITERE3(150)

Local Char       SVUSER(GLONAUS)
Local Char       SVPROFIL(GLONAFT)
Local Integer    SVUSRACS(GLONACS)
Local Char       SVREFNUM(GLONEML)

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]  : Endif
If !clalev([F:IDW1]) : Local File EMPLOID  [IDW1] : Endif
If !clalev([F:AUS])  : Local File AUTILIS  [AUS]  : Endif
If !clalev([F:AME])  : Local File AMETUTI  [AME]  : Endif
If !clalev([F:POAW]) : Local File POPULA   [POAW] : Endif
If !clalev([F:FCYW]) : Local File FACILITY [FCYW] : Endif
## Ouverture ESB
If !clalev([F:ESBW]) : Local File EMPSBD   [ESBW] : Endif
If !clalev([F:FJH])  : Local File FLXJOB   [FJH]  : Endif

SVUSER   = GUSER
SVPROFIL = GPROFIL
SVUSRACS = GUSRACS
SVREFNUM = GREFNUM
Onerrgo ERREUR

OK =1
# SEGAY - 11/10/11 - FQ76996
# On teste toujours car on peut avoir un dûˋphasage avec le Portail
#If [L]MATRICULE <>  GREFNUM    : # On charge le profil pour utiliser les habilitations
 OK = (func PORSUP.EMPUSR([L]MATRICULE,"") <> "")
 If !OK
  GMESSAGE = [L]MATRICULE-mess(99,10709,1) : # Le salariûˋ n'est pas rattachûˋ û  un utilisateur
  GERR = 1
 Else
  GUSER   = func PORSUP.EMPUSR([L]MATRICULE,"")
  GREFNUM = [L]MATRICULE
  Read [F:AUS]CODUSR = GUSER
  If [F:AUS]PRFFCT=""
   Read [F:AME]AME0 = [F:AUS]CODMET
   GPROFIL  = [F:AME]PRFFCT
  Else
   GPROFIL  = [F:AUS]PRFFCT
  Endif
  GUSRACS  = [F:AUS]ALLACS
  Call AUTSRV From GLOBPAY
 Endif
#Endif


# / 71093
Local Integer CREAGLOB
Gosub INIT_CHECK_SUBORD From DIVPAYE
#   71093 /
If OK

 If FLUX <> ""
  GFONCTION="PRH"+FLUX
 Else
  GFONCTION="GESEML"
 Endif
 Call AUTORIS From EXEFNC

 [L]CRITERE -="& [IDW1]ENAFLG=2"

 If [L]DAT <> [31/12/9999]

  If DAT = [00/00/0000]
   DAT = date$
   CRITERE -= "& [F:HRCTR]CTRDAT<="+"["+num$([L]DAT)+"]"
  Else
   CRITERE -= "& [F:HRCTR]CTRDAT<="+"["+num$([L]DATFIN)+"]"
  Endif

  CRITERE -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>="+"["+num$([L]DAT)+"])"

 Endif

 If [L]SOCIETE   >"" : [L]CRITERE1-="& [FCYW]LEGCPY='"+[L]SOCIETE   +"'" : Endif
 If [L]SITE      >"" : [L]CRITERE1-="& [HRCTR]ETRFCY='" +[L]SITE      +"'" : Endif
 If [L]SERVICE   >"" : [L]CRITERE1-="& [HRCTR]ETRSRV='" +[L]SERVICE   +"'" : Endif
 If [L]PRFCOD    >"" : [L]CRITERE1-="& [HRCTR]PROPRF='" +[L]PRFCOD    +"'" : Endif
 If [L]POPULATION>"" : [L]CRITERE2-="& [POAW]COD='"   +[L]POPULATION+"'" : Endif
 If [L]GROUPE    >"" : [L]CRITERE2-="& find([HRCTR]REFNUM,[L]GROUPE)"      : Endif

 If [L]CRITERE ="" : [L]CRITERE ="1=1" : Else [L]CRITERE =right$([L]CRITERE ,4) : Endif
 If [L]CRITERE1="" : [L]CRITERE1="1=1" : Else [L]CRITERE1=right$([L]CRITERE1,4) : Endif
 If [L]CRITERE2="" : [L]CRITERE2="1=1" : Else [L]CRITERE2=right$([L]CRITERE2,4) : Endif


# / 71093
# ADXFTL = 20 enlever la mise en commentaire aprû´s le moteur 213
# SEGAY - 11/10/11 - FQ76996
# Flux mûˋtier, on teste directement le paramû´tre car la globale peut ne pas ûˆtre en phase venant du portail
# Case [L]FLUX
#  When "DCG"    : [L]FLUX = [V]GFLXPORDCG
#  When "EXS"    : [L]FLUX = [V]GFLXPOREXS
#  When "DPI"    : [L]FLUX = [V]GFLXPORDPI
#  #75503
#  When "PPH"    : [L]FLUX = [V]GFLXPREPAI
#  When "PLA"    : [L]FLUX = [V]GFLXPORPLA
#  When "TPS"    : [L]FLUX = [V]GFLXPORTPS
#  When "DEM"    : [L]FLUX = [V]GFLXPORDEM
#  When "CAL"    : [L]FLUX = [V]GFLXPORCAL
#  When "CNGANN" : [L]FLUX = [V]GFLXCNGANN
#  #end 75503
# Endcase
 Case [L]FLUX
  When "DCG"    : Call PARAM("","FLXPORDCG",[L]FLUX) From ADOVAL
  When "EXS"    : Call PARAM("","FLXPOREXS",[L]FLUX) From ADOVAL
  When "DPI"    : Call PARAM("","FLXPORDPI",[L]FLUX) From ADOVAL
  When "PPH"    : Call PARAM("","FLXPREPAI",[L]FLUX) From ADOVAL
  When "PLA"    : Call PARAM("","FLXPORPLA",[L]FLUX) From ADOVAL
  When "TPS"    : Call PARAM("","FLXPORTPS",[L]FLUX) From ADOVAL
  When "DEM"    : Call PARAM("","FLXPORDEM",[L]FLUX) From ADOVAL
  When "CAL"    : Call PARAM("","FLXPORCAL",[L]FLUX) From ADOVAL
  When "CNGANN" : Call PARAM("","FLXCNGANN",[L]FLUX) From ADOVAL
 Endcase
# END - FQ76996
 Raz OKF
#If GPROFIL = func AFNC.PARAM("ADMUSR","")   : # Super profil = Pas de ctrl des flux : # WGA 01/2011 perf portail
 If GPROFIL = GSUPER
  OKF = 1
 Endif
# SEGAY - 28/10/11 - FQ77414
 If [L]FLUX <> [F:FJH]COD
  Read [F:FJH]FJH0 = GCURLEG;[L]FLUX
  If fstat : [L]FLUX = "DEFAULT" : Endif
 Endif
# END - FQ76996

# / 74222
 If [L]FLUX = ""
  [L]FLUX = "DEFAULT"
 Endif

 If [L]FLUX <> [F:FJH]COD
  Read [F:FJH]FJH0 = GCURLEG;[L]FLUX
  If fstat : OKF = 1 : Endif                 : # flux demandûˋ inexistant
 Endif

 # OKF =1 , on n'a pas besoin de lire par la table des subordonnûˋes
 # OKF =0 , on lit par la table des subordonnûˋes
#  On ne teste pas sur lui-mûˆme car le portail l'affiche d'office
#If !OKF
#  # On teste lui-mûˆme car il est rare qu'il soit subordonnûˋ de lui-mûˆme
#  CRITERE3 = "[F:HRCTR]REFNUM="-"'"+[L]MATRICULE+"'"
#
#  If [L]POPULATION>""
#   Link [HRCTR] With [IDW1] ID0    = [F:HRCTR]REFNUM
#&              , [FCYW]FCY0    = [F:HRCTR]ETRFCY
#&              , [POAW]POA1(1) = [F:HRCTR]REFNUM
#&             As [LCTR]
#   Columns [LCTR] ([F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
#  Else
#   Link [HRCTR] With [IDW1] ID0    = [F:HRCTR]REFNUM
#&              , [FCYW]FCY0    = [F:HRCTR]ETRFCY
#&             As [LCTR]
#   Columns [LCTR] ([F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
#  Endif
#  For [LCTR] Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
##  # Ne retourner qu'une ligne couple matricule/contrat
#   If !find([F:HRCTR]REFNUM,[L]REFNUM) or !find([F:HRCTR]CTRNUM,[L]CTRNUM)
#
#    mkstat = 0
#    Call CHECK_SUBORD_OKF([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FLUX,[F:HRCTR]CTRDAT) From DIVPAYE
#    If !mkstat
#     If N>=dim([L]REFNUM)
#      GERR=1
#      Break
#     Endif
#     [L]REFNUM(N)=[F:HRCTR]REFNUM
#     [L]CTRNUM(N)=[F:HRCTR]CTRNUM
#     [L]NAM   (N)=[F:IDW1]NAM
#     [L]SRN   (N)=[F:IDW1]SRN
#     [L]NSRN  (N)=[F:IDW1]NAM-[F:IDW1]SRN
#     N+=1
#    Else
#     Raz GMESSAGE
#    Endif
#    Endif
#  Next
# Endif

 If OKF
   If [L]POPULATION>""
     Link [HRCTR] With [IDW1] ID0    = [F:HRCTR]REFNUM
&              , [FCYW]FCY0    = [F:HRCTR]ETRFCY
&              , [POAW]POA1(1) = [F:HRCTR]REFNUM
&             As [LCTR]
&   Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2)
     Columns [LCTR] ([F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
   Else
     Link [HRCTR] With [IDW1] ID0    = [F:HRCTR]REFNUM
&              , [FCYW]FCY0    = [F:HRCTR]ETRFCY
&             As [LCTR]
&   Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2)
     Columns [LCTR] ([F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
   Endif
 Else
   [L]CRITERE3="1=1"
   If [L]MATRICULE <> ""
     [L]CRITERE3 -= "& [F:ESBW]CHEF="-"'"+[L]MATRICULE+"'"
   Endif
   If [L]POPULATION>""
    Link [F:ESBW] With
&      [F:HRCTR]CTR0 ~= [F:ESBW]REFNUM;[F:ESBW]CTRNUM;[F:ESBW]CTRDAT
&     ,[F:IDW1]ID0 = [F:HRCTR]REFNUM
&     ,[FCYW]FCY0    = [F:HRCTR]ETRFCY
&     ,[POAW]POA1(1) = [F:HRCTR]REFNUM
&      As    [LCTR]
&   Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
&   Order By Key CLE =[F:ESBW]CHEF;[F:ESBW]REFNUM;[F:ESBW]CTRNUM;[F:ESBW]CTRDAT
     Columns [LCTR] ([F:ESBW],[F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
   Else
    Link [F:ESBW] With
&      [F:HRCTR]CTR0 ~= [F:ESBW]REFNUM;[F:ESBW]CTRNUM;[F:ESBW]CTRDAT
&     ,[F:IDW1]ID0 = [F:HRCTR]REFNUM
&     ,[FCYW]FCY0    = [F:HRCTR]ETRFCY
&      As    [LCTR]
&   Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
&   Order By Key CLE =[F:ESBW]CHEF;[F:ESBW]REFNUM;[F:ESBW]CTRNUM;[F:ESBW]CTRDAT
     Columns [LCTR] ([F:ESBW],[F:HRCTR],[F:IDW1]NAM,[F:IDW1]SRN)
  Endif
 Endif

 For [LCTR]
#  # Ne retourner qu'une ligne couple matricule/contrat
  If !find([F:HRCTR]REFNUM,[L]REFNUM) or !find([F:HRCTR]CTRNUM,[L]CTRNUM)

    mkstat = 0
    Call CHECK_SUBORD_OKF([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FLUX,[F:HRCTR]CTRDAT,OKF) From DIVPAYE
    If !mkstat
     If N>=dim([L]REFNUM)
      GERR=1
      Break
     Endif
     [L]REFNUM(N)=[F:HRCTR]REFNUM
     [L]CTRNUM(N)=[F:HRCTR]CTRNUM
     [L]NAM   (N)=[F:IDW1]NAM
     [L]SRN   (N)=[F:IDW1]SRN
     [L]NSRN  (N)=[F:IDW1]NAM-[F:IDW1]SRN
     N+=1
    Else
     Raz GMESSAGE
    Endif
  Endif
 Next

# / 71093
# ADXFTL = 1 enlever la mise en commentaire aprû´s le moteur 213

Endif
# END FQ77414
If GERR & GMESSAGE = ""
 GMESSAGE="GETSUBORDONNESFLUX :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

GUSER   = SVUSER
GPROFIL = SVPROFIL
GUSRACS = SVUSRACS
GREFNUM = SVREFNUM
If CREAGLOB
 Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR
Endif
Onerrgo

End

$ERREUR
GUSER     = SVUSER
GPROFIL   = SVPROFIL
GUSRACS   = SVUSRACS
GREFNUM   = SVREFNUM
GMESSAGE -= mess(155,115,1) : # Erreur grave
GERR      = 1
If CREAGLOB
 Kill      GDONOTCLOSE , GSVFLUX , GTTYPMGR
Endif
End

################################################################################
#
# Renvoie les chefs d'un salariûˋ pour chacun de ses contrats
#
################################################################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnûˋs EMPSBD (ESB)
#-----------------------------------------------------------

Subprog GETCHEFCTR(MATRICULE,CHEF,TYP,CTRNUM)
Value    Char    MATRICULE
Variable Char    CHEF()(0..), CTRNUM()(0..)
Variable Integer TYP(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:AD])   : Local File EMPLOAD  [AD]   : Endif
If !clalev([F:HRCTR])  : Local File EMPLOCTR [HRCTR]  : Endif
If !clalev([F:CTR2]) : Local File EMPLOCTR [CTR2] : Endif
# Ouverture ESB
If !clalev([F:ESB])  : Local File EMPSBD [ESB]    : Endif

Local Shortint K, N
Local Libelle  L_I, D, L_J

D=min(dim([F:AD]CHEF),len(mess(0,50,1)))-1

Local Libelle PRIO(D+1)


Link [ESB] With
&     [F:HRCTR]CTR0 = [F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT
&     As   [LNK] Order By Key CLE =[F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT;[F:ESB]NIVEAU;[F:ESB]RANG;[F:ESB]CHEF

Raz [L]PRIO

For [LNK] Where [F:ESB]REFNUM=[L]MATRICULE & [F:HRCTR]CTRDAT<=date$ & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)
     If  !find([F:HRCTR]CTRNUM,[L]CTRNUM)
       Raz [L]PRIO
     Endif
     If [F:ESB]RANG
       L_I=[F:ESB]RANG-1
     Endif
     For [CTR2] Where CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
&                 & REFNUM=[F:ESB]CHEF
       If [F:ESB]RANG & (![L]PRIO(L_I) | [F:ESB]RANG<[L]PRIO(L_I))
         If [L]PRIO(L_I)
           For K=0 To N-1
             If [L]CTRNUM(K)=[F:HRCTR]CTRNUM & [L]TYP(K)=[F:ESB]RANG : Break : Endif
           Next
         Else
           K =N
           N+=1
         Endif
         [L]PRIO(L_I)=[F:ESB]RANG
         If K>=dim([L]CHEF)
           [V]GERR=1
         Else
           [L]CTRNUM(K)=[F:HRCTR]CTRNUM
           [L]CHEF  (K)=[F:CTR2]REFNUM
           [L]TYP   (K)=[F:ESB]RANG
         Endif
       Endif
     Next
Next

Sorta N [L]CTRNUM, [L]CHEF, [L]TYP
& Order By [L]CTRNUM(indice), [L]TYP(indice), [L]CHEF(indice)

If [V]GERR
 [V]GMESSAGE="GETCHEFCTR :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie le matricule du chef N d'un contrat
#
################################################################################

Subprog GETCHEFNCTR_NCTRL(CTR,NIV,CHEF)
Value Char    CTR
Value Integer NIV
Variable Char CHEF()
Gosub TRT_GETCHEFNCTR
End


Subprog GETCHEFNCTR(CTR,NIV,CHEF)
Value Char    CTR
Value Integer NIV
Variable Char CHEF()
Local Char SAV_FONC(30)
SAV_FONC=GFONCTION
If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif
[V]GFONCTION=SAV_FONC

Gosub TRT_GETCHEFNCTR
End

$TRT_GETCHEFNCTR
If !clalev([F:AD])    : Local File EMPLOAD  [AD]    : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:CTR2])  : Local File EMPLOCTR [CTR2]  : Endif
If !clalev([F:SRV])   : Local File SERVICE  [SRV]   : Endif
If !clalev([F:FCY])   : Local File FACILITY [FCY]   : Endif

#Filter [CTR2] Where CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat
#Filter [CTR2] Where CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
Filter [CTR2] Where (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] | XITDAT>=date$)
# Fin MABON
#
#72068
#Read[HRCTR]CTR0=[L]CTR
Filter [HRCTR] Where CTRNUM=[L]CTR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#
If [F:HRCTR]CHEFCTR([L]NIV-1)>""
 [L]CHEF=[F:HRCTR]CHEFCTR([L]NIV-1)
 Look [CTR2]CTR1(1)=[L]CHEF
 If !fstat : Filter [CTR2] : End : Endif
Endif

Read [AD]AD0=[F:HRCTR]REFNUM
If [F:AD]CHEF([L]NIV-1)>""

 [L]CHEF=[F:AD]CHEF([L]NIV-1)
 If !fstat : Filter [CTR2] : End [F:AD]CHEF([L]NIV-1) : Endif
Endif

Read [SRV]SRV0=[F:HRCTR]ETRSRV
If [F:SRV]CHEF([L]NIV-1)>""
 [L]CHEF=[F:SRV]CHEF([L]NIV-1)
 Look [CTR2]CTR1(1)=[L]CHEF
 If !fstat : Filter [CTR2] : End : Endif
Endif

Read [FCY]FCY0=[F:HRCTR]ETRFCY
If [F:FCY]CHEF([L]NIV-1)>""
 Look [CTR2]CTR1(1)=[L]CHEF
 If !fstat : Filter [CTR2] : End : Endif
Endif

[L]CHEF=""

Return

## / 71093 GETTEAMSUB
#
# Service GETTEAM optimisûˋ pour l'appel par le planning.
#
# Ne pas utiliser dans un autre flux sans vûˋrifier l'enchainement des appels du FrontOffice
# =========================================================================================
# Des contrûÇles sont absents car appelûˋs par ailleurs
# par le FrontOffice dans la cinûˋmatique d'ouverture du planning.
#
#
Subprog GETTEAMSUB(SOCIETE,SITE,SERVICE,POPULATION,GROUPE,DATDEB,DATFIN,
&                  REFNUM,CTRNUM,NAM,SRN,PLNTYP,COLREFNUM,COLCTRNUM,
&                  PRFCOD, AFCCOD
&                 )
Value    Char SOCIETE(), SITE(), SERVICE(), POPULATION(), GROUPE()(0..)
Value    Date DATDEB, DATFIN
Variable Char REFNUM()(0..), CTRNUM()(0..), NAM()(0..), SRN()(0..), PLNTYP()(0..)
Value    Char COLREFNUM()(0..), COLCTRNUM()(0..)
Value    Char PRFCOD(), AFCCOD()

#If [V]GFONCTION<>"GESEML"
# [V]GFONCTION="GESEML"
# Call AUTORIS From EXEFNC
#Endif
If [L]AFCCOD <> "" & [L]AFCCOD <> GFONCTION
       GFONCTION = [L]AFCCOD
       Call AUTORIS From EXEFNC
Elsif [V]GFONCTION<>"GESEML"
       [V]GFONCTION="GESEML"
       Call AUTORIS From EXEFNC
Endif

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:HRPOA])   : Local File POPULA   [HRPOA]   : Endif
If !clalev([F:ID ])   : Local File EMPLOID  [ID]    : Endif
If !clalev([F:FCY])   : Local File FACILITY [FCY]   : Endif : # 63315

# / 71093
# ADXFTL = 20 enlever la mise en commentaire aprû´s le moteur 213

Local Shortint N
Local Char     CRITERE(250)
Local Integer  OK

Local Integer NBSUBORD
NBSUBORD=find("",COLREFNUM)-1

If [L]SOCIETE   >"" : [L]CRITERE-="& [FCY]LEGCPY='" +[L]SOCIETE   +"'" : Endif : # 63315
If [L]SITE      >"" : [L]CRITERE-="& [HRCTR]ETRFCY='" +[L]SITE      +"'" : Endif
If [L]SERVICE   >"" : [L]CRITERE-="& [HRCTR]ETRSRV='" +[L]SERVICE   +"'" : Endif
If [L]POPULATION>"" : [L]CRITERE-="& [HRPOA]COD='"    +[L]POPULATION+"'" : Endif
If [L]GROUPE    >"" : [L]CRITERE-="& find([HRCTR]REFNUM,[L]GROUPE)"      : Endif
If [L]PRFCOD    >"" : [L]CRITERE-="& [HRCTR]PROPRF='" +[L]PRFCOD    +"'" : Endif

If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

Link [HRCTR] With [ID] ID0   = [F:HRCTR]REFNUM
&             , [FCY]FCY0    = [F:HRCTR]ETRFCY
&             , [HRPOA]POA1(1) = [F:HRCTR]REFNUM
&            As [LNK]

For [LNK]CTR0(2) Where CTRDAT<=[L]DATFIN & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB)
&                    & evalue([L]CRITERE) & [ID]ENAFLG=2

  If find([F:HRCTR]REFNUM,COLREFNUM)<>0
   [L]REFNUM(N)=[F:HRCTR]REFNUM
   [L]CTRNUM(N)=[F:HRCTR]CTRNUM
   [L]NAM   (N)=[F:ID]NAM
   [L]SRN   (N)=[F:ID]SRN

   If [F:HRCTR]PLNTYP="" : [L]PLNTYP(N)=[V]GPLANNING
   Else                  [L]PLNTYP(N)=[F:HRCTR]PLNTYP
   Endif

   N+=1

   If N>=NBSUBORD
    Break
   Elsif N>=dim([L]REFNUM)
    [V]GERR=1
    Break
   Endif

  Endif

Next

If [V]GERR
 [V]GMESSAGE="GETTEAMSUB :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

# / 71093
# ADXFTL = 1 enlever la mise en commentaire aprû´s le moteur 213

End

