################################################################################
#
# Renvoie les codes services
#
################################################################################
# Modification :
######################################################################################
# Modification :
#     SEGAY - 01/07/11 - FQ71093 -
# Performances lectures subordonnûˋs EMPSBD (ESB)
#     SEGAY - 04/08/11 - 75552 -
#     SEGAY - 11/10/11 - FQ76996
#     Flux mûˋtier, on teste directement le paramû´tre car la globale peut ne pas ûˆtre en phase venant du portail
#     SEGAY - 28/10/11 - FQ77414
#       Performances lectures subordonnûˋs EMPSBD (ESB) dans GETSUBORDONNESFLUX
#       link avec EMPSBD et test sur GSUPER et existence de flux avec l'appel
#       CHECK_SUBORD_OKF (test sur les chefs des flux sans relevture du contrat)
######################################################################################

Subprog GETLSTSRV(USER,COD,DES)
Value    Char USER()
Variable Char COD()(0..), DES()(0..)

If !clalev([F:SRV]) : Local File SERVICE [SRV] : Endif
# sba variable non dûˋclarûˋe
If dim(N)<1 :Local Integer N : N=0 :Endif

If [L]USER = "" : [L]USER = GUSER : Endif   : # 74955

Local Char UTILIS([V]GLONAUS)
[L]UTILIS=[V]GUSER
[V]GUSER =[L]USER
# / 74593
If dim(GUSR_SRVAUT) < 1
 Global Char    GUSR_SRVAUT(GLONAUS)
Endif
If GUSR_SRVAUT <> GUSER
 GUSR_SRVAUT = GUSER
 Call AUTSRV From GLOBPAY
Endif
#  74593 /
[V]GUSER=[L]UTILIS

For [SRV]SRV0 Where find(COD,[V]GAUTSRV)
 If N>=dim([L]COD)
  [V]GERR=1
  Break  : # 71093
 Else
  [L]COD(N)=[F:SRV]COD
  Call LECTEXTRA([L]DES(N),"SERVICE","DES",[F:SRV]COD,"") From ATEXTRA
 Endif
 N+=1
Next

If [V]GERR
 [V]GMESSAGE="GETLSTSRV :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les codes populations
#
################################################################################

Subprog GETLSTPOPU(COD,DES)
Variable Char COD()(0..), DES()(0..)

If !clalev([F:HRPOP]) : Local File POPUL [HRPOP] : Endif
# sba variable non dûˋclarûˋe
If dim(N)<1 :Local Integer N : N=0 :Endif

For [HRPOP]POP0 Where AUZPRH=2
 If N>=dim([L]COD)
  [V]GERR=1
  Break  : # 71093
 Else
  [L]COD(N)=[F:HRPOP]COD
  [L]DES(N)=[F:HRPOP]DES
 Endif
 N+=1
Next

If [V]GERR
 [V]GMESSAGE="GETLSTPOPU :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les matricules autorisûˋs d'une sociûˋtûˋ, site,...
#
################################################################################

Subprog GETTEAM(SOCIETE,SITE,SERVICE,POPULATION,GROUPE
&       ,DATDEB,DATFIN,REFNUM,CTRNUM,NAM,SRN,PLNTYP
&       ,PRFCOD,AFCCOD
&       )

Value    Char SOCIETE(), SITE(), SERVICE(), POPULATION(), GROUPE()(0..)
Value    Date DATDEB, DATFIN
Variable Char REFNUM()(0..), CTRNUM()(0..), NAM()(0..), SRN()(0..), PLNTYP()(0..)
Value    Char PRFCOD(), AFCCOD()

If [L]AFCCOD <> "" & [L]AFCCOD <> GFONCTION
 GFONCTION = [L]AFCCOD
 Call AUTORIS From EXEFNC
Elsif [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:HRPOA])   : Local File POPULA   [HRPOA]   : Endif
If !clalev([F:ID ])   : Local File EMPLOID  [ID]    : Endif
# 63315 If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
If !clalev([F:FCY])   : Local File FACILITY [FCY]   : Endif : # 63315

# / 71093
# ADXFTL = 20 enlever la mise en commentaire aprû´s le moteur 213

Local Shortint N
Local Char     CRITERE(250)
Local Integer  OK

If [L]SOCIETE   >"" : [L]CRITERE-="& [FCY]LEGCPY='" +[L]SOCIETE   +"'" : Endif : # 63315
If [L]SITE      >"" : [L]CRITERE-="& [HRCTR]ETRFCY='" +[L]SITE      +"'" : Endif
If [L]SERVICE   >"" : [L]CRITERE-="& [HRCTR]ETRSRV='" +[L]SERVICE   +"'" : Endif
If [L]POPULATION>"" : [L]CRITERE-="& [HRPOA]COD='"    +[L]POPULATION+"'" : Endif
If [L]GROUPE    >"" : [L]CRITERE-="& find([HRCTR]REFNUM,[L]GROUPE)"      : Endif
If [L]PRFCOD    >"" : [L]CRITERE-="& [HRCTR]PROPRF='" +[L]PRFCOD    +"'" : Endif

If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

Link [HRCTR] With [ID] ID0   = [F:HRCTR]REFNUM
&             , [FCY]FCY0    = [F:HRCTR]ETRFCY
&             , [HRPOA]POA1(1) = [F:HRCTR]REFNUM
&            As [LNK]

For [LNK]CTR0(2) Where CTRDAT<=[L]DATFIN & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB)
&                    & evalue([L]CRITERE) & [ID]ENAFLG=2
 Call CONTROLE( [F:HRCTR]REFNUM,max([L]DATDEB,[F:HRCTR]CTRDAT),[F:HRCTR]CTRNUM,"",[L]OK,1
&             ) From DIVPAYE
 If [L]OK
  If N>=dim([L]REFNUM)
   [V]GERR=1
   Break  : # 71093
  Else
   [L]REFNUM(N)=[F:HRCTR]REFNUM
   [L]CTRNUM(N)=[F:HRCTR]CTRNUM
   [L]NAM   (N)=[F:ID]NAM
   [L]SRN   (N)=[F:ID]SRN
   If [F:HRCTR]PLNTYP="" : [L]PLNTYP(N)=[V]GPLANNING
   Else                  [L]PLNTYP(N)=[F:HRCTR]PLNTYP
   Endif
  Endif
  N+=1
 Endif
Next

If [V]GERR
 [V]GMESSAGE="GETTEAM :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

# / 71093
# ADXFTL = 1 enlever la mise en commentaire aprû´s le moteur 213

End

################################################################################
#
# Renvoie les contrats d'un matricule
#
################################################################################

Subprog GETCONTRAT(MATRICULE,DAT,CTRNUM)
Value    Char MATRICULE()
Value    Date DAT
Variable Char CTRNUM()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif

Local Shortint N

For [HRCTR]CTR0(2) Where REFNUM=[L]MATRICULE & CTRDAT<=[L]DAT
&                    & (XITDAT=[0/0/0] | XITDAT>=[L]DAT)
 If N>=dim([L]CTRNUM)
  [V]GERR=1
  Break  : # 71093
 Else
  [L]CTRNUM(N)=[F:HRCTR]CTRNUM
  N+=1
 Endif
Next

If [V]GERR
 [V]GMESSAGE="GETCONTRAT :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les subordonnûˋs d'un salariûˋ d'aprû´s les champs [F:xxx]CHEF
#
################################################################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnûˋs EMPSBD (ESB)
#-----------------------------------------------------------
Subprog GETSUBORDONNES(MATRICULE,REFNUM,CTRNUM)
Value    Char MATRICULE
Variable Char REFNUM()(0..), CTRNUM()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif
# Ouverture ESB
If !clalev([F:ESB]) : Local File EMPSBD [ESB]   : Endif
If !clalev([F:ESB1]): Local File EMPSBD [ESB1]  : Endif

Local Shortint N
Local Libelle  L_I, L_J
Local Integer  OK

Link [ESB] With
&     [F:HRCTR]CTR0 = [F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT,
&     [ID]ID0=REFNUM
&     As   [LNK] Order By Key CLE =[F:ESB]CHEF;[F:ESB]RANG;[F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT;[F:ESB]NIVEAU

For [LNK] Where [F:ESB]CHEF=[L]MATRICULE & [F:HRCTR]CTRDAT<=date$ & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)
   L_J=1
  # Ne retourner qu'une ligne couple matricule/contrat
   If !find([F:HRCTR]REFNUM,[L]REFNUM) or !find([F:HRCTR]CTRNUM,[L]CTRNUM)
  # Test s'il n'existe pas un chef pour le mûˆme contrat û  un niveau infûˋririeur
     Filter [ESB1] Where [F:ESB1]RANG=[F:ESB]RANG & [F:ESB1]REFNUM=[F:HRCTR]REFNUM & [F:ESB1]CTRNUM=[F:HRCTR]CTRNUM & [F:ESB1]CTRDAT=[F:HRCTR]CTRDAT
&     & [F:ESB1]NIVEAU<[F:ESB]NIVEAU
     If rowcount([ESB1])<1
       Filter [ESB1]
     # WGA : ContrûÇle droit d'accû´s Salariûˋ / site /service
       Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,"",OK,1) From DIVPAYE

       If L_J & OK
        If N>=dim([L]REFNUM) : [V]GERR=1
        Else                   [L]REFNUM(N)=[F:HRCTR]REFNUM : [L]CTRNUM(N)=[F:HRCTR]CTRNUM
        Endif
        N+=1
       Endif
     Endif
     Filter [ESB1]
   Endif
Next

If [V]GERR
 [V]GMESSAGE="GETSUBORDONNES :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les subordonnûˋs d'un salariûˋ d'aprû´s les champs [F:xxx]CHEF pour des
# niveaux donnûˋs
# Paramû´tres :
# - MATRICULE : Salariûˋ
# - TABNIV    : Indices oû¿ l'on retrouve le salariûˋ dans les interlocuteurs
################################################################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnûˋs EMPSBD (ESB)
#-----------------------------------------------------------
Subprog GETSUBORDONNESNIVEAU(MATRICULE,TABNIV,REFNUM,CTRNUM)
Value    Char    MATRICULE
Value    Char    TABNIV()()
Variable Char    REFNUM()(0..), CTRNUM()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif
# Ouverture ESB
If !clalev([F:ESB]) : Local File EMPSBD [ESB]   : Endif
If !clalev([F:ESB1]): Local File EMPSBD [ESB1]  : Endif

# / 71093
If clalev([F:ACC]) =0 : Local File ACCES    [ACC]  : Endif
#  71093 /

Local Shortint N
Local Libelle  L_I, L_J ,INDEX, L_NIVEAU
Local Integer  OK

Link [ESB] With
&     [F:HRCTR]CTR0 = [F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT,
&     [ID]ID0=REFNUM
&     As   [LNK] Order By Key CLE =[F:ESB]CHEF;[F:ESB]RANG;[F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT;[F:ESB]NIVEAU


L_I=0

While TABNIV(L_I)<>""
 INDEX = val(TABNIV(L_I))+1
 If INDEX  <= len(mess(0,50,1))
  L_J=0

  For [LNK] Where [F:ESB]CHEF=[L]MATRICULE & [F:ESB]RANG=INDEX & [F:HRCTR]CTRDAT<=date$ & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)
   L_J=1
  # Ne retourner qu'une ligne couple matricule/contrat
   If !find([F:HRCTR]REFNUM,[L]REFNUM) or !find([F:HRCTR]CTRNUM,[L]CTRNUM)
  # Test s'il n'existe pas un chef pour le mûˆme contrat û  un niveau infûˋririeur
     Filter [ESB1] Where [F:ESB1]RANG=INDEX & [F:ESB1]REFNUM=[F:HRCTR]REFNUM & [F:ESB1]CTRNUM=[F:HRCTR]CTRNUM & [F:ESB1]CTRDAT=[F:HRCTR]CTRDAT
&     & [F:ESB1]NIVEAU<[F:ESB]NIVEAU
     If rowcount([ESB1])<1
       Filter [ESB1]
     # WGA : ContrûÇle droit d'accû´s Salariûˋ / site /service
       Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,"",OK,1) From DIVPAYE

       If L_J & OK
        If N>=dim([L]REFNUM) : [V]GERR=1
        Else                   [L]REFNUM(N)=[F:HRCTR]REFNUM : [L]CTRNUM(N)=[F:HRCTR]CTRNUM
        Endif
        N+=1
       Endif
     Endif
     Filter [ESB1]
    Endif
  Next
 Endif
 L_I+=1
Wend


If [V]GERR
 [V]GMESSAGE="GETSUBORDONNESNIVEAU :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End
################################################################################
