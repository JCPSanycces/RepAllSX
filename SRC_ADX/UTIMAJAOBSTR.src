#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour ASE    ASJ     ASX    AWM
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour AOB ADV") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##################################################
Subprog PATCH_X3(APPLI)
Value Char APPLI

Gosub MAJAOB
End
##################################################
Subprog PATCH(APPLI)
Value Char APPLI

Gosub MAJAOB
End

##################################################
$MAJAOB
Local Integer I,VALMOD(20)

For I=0 To dim(VALMOD)-1
 VALMOD(I)= 2
Next

Call MAJ_SEL(APPLI,"ASE") From PATCHAOB
#Call VALID_TRT(APPLI,0,"","","","","","","","","ASE","ASE","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(APPLI,0,"","","","","","","","","ASE","ASE","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(APPLI,"ASE") From SUBAOB

Call MAJ_SEL(APPLI,"ASJ") From PATCHAOB
#Call VALID_TRT(APPLI,0,"","","","","","","","","ASJ","ASJ","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(APPLI,0,"","","","","","","","","ASJ","ASJ","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(APPLI,"ASJ") From SUBAOB

Call MAJ_SEL(APPLI,"ASX") From PATCHAOB
#Call VALID_TRT(APPLI,0,"","","","","","","","","ASX","ASX","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(APPLI,0,"","","","","","","","","ASX","ASX","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(APPLI,"ASX") From SUBAOB

Call MAJ_SEL(APPLI,"AWM") From PATCHAOB
#Call VALID_TRT(APPLI,0,"","","","","","","","","AWM","AWM","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(APPLI,0,"","","","","","","","","AWM","AWM","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(APPLI,"AWM") From SUBAOB
Return
