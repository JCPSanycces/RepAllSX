#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJSLINK0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone RAZAUDTBL
mkstat = 0
zoncou = "RAZAUDTBL"
indice = 0
IMPENT = [M]RAZAUDTBL
If varinit([M]RAZAUDTBL,indice)=0
 IMPENT = 1
Endif
If varmode([M]RAZAUDTBL,indice)=0
 [M]RAZAUDTBL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RAZAUDTBL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RAZAUDTBL(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "RAZAUDTBL" : GZNUM = 44699 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]RAZAUDTBL = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBTAB
mkstat = 0
zoncou = "NBTAB"
indice = 0
status = 1
zoncou = "NBTAB"
If varmode([M]NBTAB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBTAB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBTAB
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBTAB = nolign
   status = 75
   Call SAI_NBTAB(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBTAB(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBTAB
mkstat = 0
zoncou = "NBTAB"

## Zone INILNK
mkstat = 0
zoncou = "INILNK"
IMPENT = [M]INILNK(indice)
If varinit([M]INILNK,indice)=0
 IMPENT = 1
Endif
If varmode([M]INILNK,indice)=0
 [M]INILNK(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INILNK" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INILNK(indice)
 Endif
Endif
[M]INILNK(indice) = IMPENT

## Zone NBTAB
mkstat = 0
zoncou = "NBTAB"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "AJSLINK0"
Return

