#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ workflow dans les modeles de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise a jour champ workflow dnas les modeles de données") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAWRK
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJAWRK
End

#-------------------#
$MAJAWRK
Local File =DOSSIER+".AOBJEXT"   [AOE]

If dim([F:AOE]ENAWRK)<0 : Return : Endif

# Mise à jour de la table AOBJEXT
Call ECR_TRACE(mess(81,125,1)-"AOBJEXT:"-time$,0) From GESECRAN
Trbegin [AOE]
 For [AOE]
  If [F:AOE]ENAWRK=0 & [F:AOE]IMPORT=2
   [F:AOE]ENAWRK = 2
   Rewrite [AOE]
   If fstat
    Call ERREUR("AOBJEXT"-[F:AOE]EXT,1) From DOSDIC
   Endif
  Endif
 Next AOE
Commit

Close Local File [AOE]

Return
