#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
#             TRAITEMENTS LIES aux COMMANDES dans les VENTES                          #
#                          SYRACUSE COMPATIBLE                                        #
#######################################################################################
# Issue X3-31898 - 2017-11-23 by FGR                                                  #
#######################################################################################
Funprog MAJSTASOH(CTX, SSOHNUM, SMESSAGE)
Variable Instance CTX Using OBJECT
Value Char SSOHNUM
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer WAALLLINNBR
Local Integer WALLLINNBR
Local Integer WLINNBR
Local Integer WDLVLINNBR
Local Integer WINVLINNBR
Local Integer WALLSTA
Local Integer WDLVSTA
Local Integer WINVSTA
Local Decimal WTOTQTY
Local Integer WADLVLINNBR

  # Issue X3-31898 - 2017-11-23 by FGR
  #-----------------------------------------------------------------------#
  # Recalcul des statuts de la commande (Syracuse compatible              #
  #-----------------------------------------------------------------------#
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # ----------------------------------
  Local File SORDER  [SOH]
  Local File SORDERQ [SOQ]
  # ----------------------------------
  Read [SOH]SOH0=SSOHNUM
  If fstat Then
    SMESSAGE = func AFNC.MES1(mess(550,192,1), SSOHNUM)
    IARENDRE = [V]CST_AERROR
  Endif
  If IARENDRE = [V]CST_AOK Then
    # ----------------------------------
    IADXLOG = (adxlog = 1)
    If IADXLOG = [V]CST_AFALSE Then
      Trbegin [SOH]
    Endif
    # ----------------------------------
    WALLSTA = 1
    WDLVSTA = 1
    WINVSTA = 1
    # ----------------------------------
    Filter [SOQ] Where [F:SOQ]SOHNUM = [F:SOH]SOHNUM
    For [SOQ]SOQ0
      If [F:SOQ]STOMGTCOD <> 1 and sum([F:SOQ]ALLQTY, [F:SOQ]OPRQTY, [F:SOQ]PREQTY) <> 0 Then
        WALLSTA = 2
      Endif
      If [F:SOH]SOHCAT = 3 or ([F:SOH]SOHCAT = 1 and [F:SOQ]DLVFLG = 1) Then
        # --> Commande à facturation directe
        # --> Commande normale et ligne non livrable
        # Calcul du statut livré
        # Ce cas là ne devrait jamais arriver ...
        If [F:SOQ]DLVQTY > 0 Then
          WDLVSTA = 2
        Endif
        # Calcul du statut facturé
        If [F:SOQ]INVQTY > 0 or [F:SOQ]ODLQTY > 0 Then
          WINVSTA = 2
        Endif
      Else
        # --> Commande normale/prêt et ligne livrable
        # Calcul du statut livré
        If [F:SOQ]DLVQTY > 0 or [F:SOQ]ODLQTY > 0 Then
          WDLVSTA = 2
        Endif
        # Calcul du statut facturé
        If [F:SOQ]INVQTY > 0 Then
          WINVSTA = 2
        Endif
      Endif
      #--- Recalcul du nbre de lignes à allouer
      #    Pour les lignes gérées en stock (donc livrables) et non soldées
      If [F:SOQ]STOMGTCOD <> 1 and [F:SOQ]SOQSTA <> 3 Then
        WLINNBR += 1
        WTOTQTY = sum([F:SOQ]ALLQTY, [F:SOQ]OPRQTY, [F:SOQ]PREQTY, [F:SOQ]ODLQTY)
        If [F:SOH]SOHCAT = 3 Then
          WTOTQTY += sum([F:SOQ]INVQTY)
        Else
          WTOTQTY += sum([F:SOQ]DLVQTY)
        Endif
        #--- Tout n'est pas alloué : Incrémentation du nbre de lignes restant a allouer
        If WTOTQTY < [F:SOQ]QTY or [F:SOQ]SHTQTY <> 0 Then
          WAALLLINNBR += 1
        Elsif WTOTQTY >= [F:SOQ]QTY and [F:SOQ]SHTQTY = 0 Then
          #--- Tout est alloué : Incrémentation du nbre de lignes allouées
          WALLLINNBR += 1
        Endif
      Endif
      If [F:SOH]SOHCAT <> 3 and [F:SOQ]DLVFLG = 2 Then
        # --> Commande normale/prêt et ligne livrable
        # Calcul du nombre de lignes livrables
        WADLVLINNBR += 1
        # Calcul du nombre de lignes livrées
        If [F:SOQ]DLVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY Then
          WDLVLINNBR += 1
        Endif
      Endif
      #--- Recalcul du nbre de lignes facturées
      If [F:SOQ]INVFLG = [V]CST_AYES Then
        WINVLINNBR += 1
      Endif
    Next
    Filter [SOQ]
    # ----------------------------------
    # Cde allouée ssi cde non soldée et les lignes gérées en stock et non soldées sont totalement allouées
    If [F:SOH]ORDSTA <> 2 and WLINNBR <> 0 and WALLLINNBR = WLINNBR Then
      WALLSTA = 3
    Endif
    # Cde livrée  ssi toutes les lignes livrables sont livrées
    If WADLVLINNBR > 0 and WDLVLINNBR >= WADLVLINNBR Then
      WDLVSTA = 3
    Endif
    # Cde facturée ssi toutes les lignes sont facturées
    If WINVLINNBR >= [F:SOH]LINNBR Then
      WINVSTA = 3
    Endif
    If WALLSTA <> [F:SOH]ALLSTA or WAALLLINNBR <> [F:SOH]ALLLINNBR or
&      WDLVSTA <> [F:SOH]DLVSTA or WDLVLINNBR <> [F:SOH]DLVLINNBR or
&      WINVSTA <> [F:SOH]INVSTA or WINVLINNBR <> [F:SOH]INVLINNBR
&   Then
      [F:SOH]ALLSTA = WALLSTA
      [F:SOH]ALLLINNBR = WAALLLINNBR
      [F:SOH]INVSTA = WINVSTA
      [F:SOH]DLVLINNBR = WDLVLINNBR
      [F:SOH]DLVSTA = WDLVSTA
      [F:SOH]INVLINNBR = WINVLINNBR
      Rewrite [SOH]
      If fstat Then
        SMESSAGE = func AFNC.MES1(mess(551,192,1), SSOHNUM)
        IARENDRE = [V]CST_AERROR
      Endif
    Endif
    # ----------------------------------
    If IADXLOG = [V]CST_AFALSE Then
      If IARENDRE < [V]CST_AERROR Then
        Commit
      Else
        Rollback
      Endif
    Endif
    # ----------------------------------
  Endif
End IARENDRE

