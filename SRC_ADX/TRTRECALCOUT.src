#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 23/02/11 bug 71818 Période de professionalisation
# Le traitement TRTRECALCOUT plante sur l'appel à CALC_MTT de  COUMAJ il manque un paramètre CPY.
# Rajout de l'appel CALC_FORM pour récupérer la table EMPLOID du Formateur.
# Rajout du paramètre CPY à "" dans l'appel CALC_FORM 
######################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTCALCOUT","TRTRECALCOUT",4,"XYTRTRECALCOUT") From GTRAITE
End



$ACTION

  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "DEBUT"     : Gosub DEBUT
    When "BOUTON"    : Gosub BOUTON
    When "AVANT_OK"  : Gosub AVANT_OK
    When "OK"        : Gosub OK
    When Default
  Endcase
Return

$OUVRE

  If clalev([F:HRSES])=0  : Local File SESSIONS  [HRSES]  : Endif
  If clalev([F:STG])=0    : Local File STAGE     [STG]    : Endif
  If clalev([F:ADI])=0    : Local File ATABDIV   [ADI]    : Endif
  If clalev([F:HRCOR])=0  : Local File COUTREEL  [HRCOR]  : Endif
#SEGAY 23/02/11  bug 71818
  If clalev([F:SESM])=0   : Local File SESSIONS [SESM]    : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]     : Endif
# END_bug 71818
  Gosub OUVRE From WPDEFTABLE
  Local Mask LISSES [LSES]
  Raz [M:LSES]
Return

Subprog FILL_LSES(IND)
Value Integer IND

  [M:LSES]SELFLG(IND) = 2
  [M:LSES]SES(IND)    = [F:HRSES]COD
  [M:LSES]STG(IND)    = [F:HRSES]STG
  [M:LSES]STRDAT(IND) = [F:HRSES]STRDAT
  [M:LSES]ENDDAT(IND) = [F:HRSES]ENDDAT
  [M:LSES]FRTINT(IND) = [F:HRSES]FRTINT
  [M:LSES]TCHEMP(IND) = [F:HRSES]TCHEMP
  [M:LSES]NATFIS(IND) = [F:HRSES]NATFIS
  [M:LSES]CATACN(IND) = [F:HRSES]CATACN
End

$DEBUT
Local Integer I

  I=0
  # FQ71040 - MABON 22/03/11 - Ajout test sur ORG et TCHNAM
  # Sessions non clôturées qui sont réalisées en interne, avec ou sans formateur interne précisé, et sans formateur externe
  For [F:HRSES] Where FLGCLO<>2 & ((FRTINT=2 | TCHEMP<>"") & ORG="" & TCHNAM="")
    If I<dim([M:LSES]SELFLG) Then
      Call FILL_LSES(I)
      I += 1
    Endif
  Next
  [M:LSES]NBSES=I
  Affzo [M:LSES]
Return

$BOUTON

  Case BOUT
    When "C" : For I=0 To [M:LSES]NBSES-1 : [M:LSES]SELFLG(I)=2 : Next : # Cocher toutes les cases
    When "D" : For I=0 To [M:LSES]NBSES-1 : [M:LSES]SELFLG(I)=1 : Next : # Décocher toutes les cases
  Endcase
  Affzo [M:LSES]
Return
      
$AVANT_OK
Local Integer I, OKSEL

  OKSEL=1
  For I=0 To [M:LSES]NBSES-1
    If [M:LSES]SELFLG(I)=2 Then
      OKSEL=2 : Break
    Endif
  Next 
  If OKSEL=1 Then
    GERR     = 1
    GMESSAGE = mess(217,10717,1): # Vous devez sélectionner au moins une session
    FIN      = 0
  Endif
Return

$OK
Local Char    TIT(50), FORMATEUR, CONTRAT
Local Integer NBENREG
Local Decimal MTTTOT, MTTIPT
# SEGAY 23/02/11  bug 71818
Local Char    CRITCPY(255), CRITFCY(255)
Local Integer FORM_OK
# END_bug 71818


  TIT = mess(127,10717,1) : # Mise à jour des coûts réels
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 

  Call ECR_TRACE(mess(135,10717,1),0) From GESECRAN : # Mise à jour coûts réels Formateurs calculés  
  NBENREG=0
  Trbegin [F:HRCOR] : GOK=0 

  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts formateur
  If GCALCOUFOR=2 Then
    # Mise à jour coûts réels sessions à partir des coûts prévisionnels du stage, relatifs au formateur
    For I=0 To [M:LSES]NBSES-1
      If [M:LSES]SELFLG(I)=2 Then
        Link [F:HRSES] With [F:STG]STG0=STG As [ST_] Where COD=[M:LSES]SES(I)
        For [F:ST_]
  #        FORMATEUR=[F:STG]TCHEMP : CONTRAT=[F:STG]CTRNUM
  #        If FORMATEUR="" Then FORMATEUR=[F:HRSES]TCHEMP : CONTRAT=[F:STG]CTRNUM Endif
         # SEGAY 23/02/11 bug 71818
          Raz CRITCPY, CRITFCY
          Read [F:SESM]SES0=[F:HRSES]COD
          Call CALC_FORM(CRITCPY, CRITFCY, FORMATEUR, CONTRAT, FORM_OK) From COUMAJ
          If FORM_OK=2 Then
         # END_bug 71818
            Filter [F:ADI] Where NUMTAB=10451 & N1<3 & N2=2  : # Coût calculé pour formateur interne
            For [F:ADI]
              # SEGAY 23/02/11 bug 71818
  #            Call CALC_MTT(FORMATEUR, CONTRAT, [F:HRSES]STRDAT, [F:HRSES]ENDDAT, [F:HRSES]NBRHOUIPT, MTTTOT, MTTIPT) From COUMAJ
              Call CALC_MTT(FORMATEUR, CONTRAT, [F:HRSES]STRDAT, [F:HRSES]ENDDAT, [F:HRSES]NBRHOUIPT,"", MTTTOT, MTTIPT) From COUMAJ
              # END_bug 71818
              If MTTIPT<>0 | MTTTOT<>0 Then
                Call ECR_TRACE("   "-mess(34,10717,1)-[F:HRSES]COD-";"-mess(136,10717,1)-FORMATEUR-";"-mess(133,10717,1)-[F:ADI]CODE,0) From GESECRAN : # Session ; Formateur ; Type de coût
                # Mise à jour coûts réels sessions
                Filter [F:HRCOR] Where TYPCOU=2 & SES=[F:HRSES]COD & TYPCRG2=[F:ADI]CODE
                If rowcount([F:HRCOR])>0 Then
                  For [F:HRCOR]
                    [F:HRCOR]CSTIPTIDV2=MTTIPT
                    [F:HRCOR]CSTTOTIDV2=MTTTOT
                    Rewrite [F:HRCOR]
                    If fstat Then GOK=1 : Break 3 : Endif
                    NBENREG += 1       
                  Next
                Else
                  Call CREATE_COR(2, [F:HRSES]COD, "", [F:ADI]CODE, [F:HRSES]TYPFRT, "", "") From COUMAJ
                  [F:HRCOR]CSTIPTIDV2=MTTIPT
                  [F:HRCOR]CSTTOTIDV2=MTTTOT
                  Write [F:HRCOR]
                  If fstat Then GOK=1 : Break 2 : Endif
                  NBENREG += 1       
                Endif
                Filter [F:HRCOR]
              Endif
            Next
            Filter [F:ADI]
          Endif # SEGAY 23/02/11 bug 71818
        Next
      Endif
    Next
  Endif  
  If GOK Then
    Rollback
  Else
    Commit
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
#    If NBENREG>0 Then
      Call ECR_TRACE(mess(131,10717,1)-":"-num$(NBENREG),0) From GESECRAN : # Nombre de coûts réels Formateurs calculés mis à jour
#    Endif 
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return
