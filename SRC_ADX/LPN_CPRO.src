#<AdxTL>@(#)0.0.0.0 $Revision$
$LOC_PROPAGATE
Local Instance WSTOLOC Using C_STOLOC
If this.LOC <> AVOID.ACHAR
  WSTOLOC = NewInstance C_STOLOC AllocGroup null
    WRET = fmet WSTOLOC.AREAD(this.STOFCY, this.LOC)
    If WRET <> [V]CST_AOK
       [L]ASTATUS = fmet this.ASETERROR("STOLOC",mess(125,184,1),[V]CST_AERROR)
    Else
      this.LOCTYP = WSTOLOC.LOCTYP
      this.WRH    = WSTOLOC.WRH
    Endif
   FreeGroup WSTOLOC
Else
  this.LOCTYP = AVOID.ACHAR
Endif
Return

$TCTRNUM_PROPAGATE
Local Char WMESSAGE(250)
Local  Instance WTABCONTAINER Using C_TABCONTAINER

#Lecture de TABCONTAINER pour récupérer le type de contenant
WTABCONTAINER = NewInstance C_TABCONTAINER AllocGroup null
WRET = fmet WTABCONTAINER.AREAD(this.TCTRNUM)
If WRET <> [V]CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("TABCONTAINER",mess(508,184,1),[V]CST_AERROR)
  FreeGroup WTABCONTAINER
  Return
Endif
this.TCTRTYP = WTABCONTAINER.TCTRTYP
this.LPNREFCOU = WTABCONTAINER.LPNREFCOU
this.MONITMFLG = WTABCONTAINER.MONITMFLG
this.MONLOTFLG = WTABCONTAINER.MONLOTFLG

FreeGroup WTABCONTAINER
Return

$MONLOTFLG_PROPAGATE
If this.MONLOTFLG = CST_AYES
  this.MONITMFLG = CST_AYES
Endif
Return

$MONITMFLG_PROPAGATE
If this.MONITMFLG<>CST_AYES
  this.MONLOTFLG = CST_ANO
Endif

Return

