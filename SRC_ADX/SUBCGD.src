#<AdxTL>@(#)4.0.0.0 $Revision$
Call OBJET ("CGD" , GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Call CHANGE_AXX ("CALIGUIDES", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase

Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="CALIGUIDES" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]CGDDESAXX,"CALIGUIDES","CGDDESAXX",[M]CGD,"") From ATEXTRA
Call MAJTEXTRA([M]CGDSHOAXX,"CALIGUIDES","CGDSHOAXX",[M]CGD,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]CGDDESAXX,"CALIGUIDES","CGDDESAXX",[M]CGD,"") From ATEXTRA
Call MAJTEXTRA([M]CGDSHOAXX,"CALIGUIDES","CGDSHOAXX",[M]CGD,"") From ATEXTRA

Return
#############################################################

Subprog AV_CGDLIG(VALEUR)
Variable Decimal VALEUR
VALEUR = nolign 
End

