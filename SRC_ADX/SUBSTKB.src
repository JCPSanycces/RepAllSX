  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif
End
###########################################################
Subprog C_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TSICODSTR(indice)
  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif
End
###########################################################
Subprog C_PLNEND(VALEUR)
