#<AdxTL>@(#)39.0.0.0 $Revision$
###########################################################
Subprog AV_REOLEVBAS(VALEUR)
Variable Integer  VALEUR
If [M]REOLEVCOD <> 2
  VALEUR = 0
Else
# FQ 44696 Pb de rechargement des mémos
# ne pas écraser la valeur choisie
  If VALEUR=0
     VALEUR = 1
  Endif
Endif
End
###########################################################
Subprog AS_REOLEVBAS(VALEUR)
Variable Integer  VALEUR
If [M]REOLEVCOD <> 2
  mkstat = 2
Endif
End
###########################################################
Subprog C_REOLEVBAS(VALEUR)
Variable Integer  VALEUR
If VALEUR > 1
  If clalev([F:STE]) = 0 : Local File STOPAR     [STE] : Endif
  Local Char WNJC, WNJO
  Call PARAM([M]STOFCY,"AVGDAY",WNJC) From ADOVAL
  Call PARAM([M]STOFCY,"AVGWRKDAY",WNJO) From ADOVAL
    If val(WNJC) = 0 | val(WNJO) = 0
      mkstat = 2
      GMESSAGE = mess(173,199,1)
    Endif
  Read [STE]STE0=[M]STOFCY;""
    If fstat
      mkstat = 2
      GMESSAGE = mess(174,199,1)
    Endif
Endif
End
###########################################################
Subprog AV_REOPERBAS(VALEUR)
Variable Integer  VALEUR
If [M]REOPERCOD <> 2
  VALEUR = 0
Else
# FQ 44696 Pb de rechargement des mémos
# ne pas écraser la valeur choisie
  If VALEUR=0
     VALEUR = 1
  Endif
Endif
End
###########################################################
Subprog AS_REOPERBAS(VALEUR)
Variable Integer  VALEUR
If [M]REOPERCOD <> 2
  mkstat = 2
Endif
End
###########################################################
Subprog AP_REOLEVBAS(VALEUR)
Variable Integer  VALEUR
If VALEUR = 1
  [M]REOTSDCLC = 1
  [M]SAFSTOCLC = 1
  [M]REOMINCLC = 1
Else
  [M]REOTSDCLC = 2
  [M]SAFSTOCLC = 2
  [M]REOMINCLC = 2
Endif
Affzo [M]REOTSDCLC
Affzo [M]SAFSTOCLC
Affzo [M]REOMINCLC
Affzo [M]MAXSTOCLC
End
###########################################################
Subprog AP_REOPERBAS(VALEUR)
Variable Integer  VALEUR
If VALEUR = 1
  [M]MAXSTOCLC = 1
Else
  [M]MAXSTOCLC = 2
Endif
Affzo [M]REOTSDCLC
Affzo [M]SAFSTOCLC
Affzo [M]REOMINCLC
Affzo [M]MAXSTOCLC
End
###########################################################
Subprog C_REOPERBAS(VALEUR)
Variable Integer VALEUR
If VALEUR > 1
  If clalev([F:STE]) = 0 : Local File STOPAR     [STE] : Endif
  Local Char WNJC, WNJO
  Call PARAM([M]STOFCY,"AVGDAY",WNJC) From ADOVAL
  Call PARAM([M]STOFCY,"AVGWRKDAY",WNJO) From ADOVAL
    If val(WNJC) = 0 | val(WNJO) = 0
      mkstat = 2
      GMESSAGE = mess(173,199,1)
    Endif
    Read [STE]STE0=[M]STOFCY;""
    If fstat
      mkstat = 2
      GMESSAGE = mess(174,199,1)
    Endif
Endif
End
###########################################################
Subprog AS_SAFSTOCLC(VALEUR)
Variable Integer VALEUR
If [M]REOLEVCOD = 3 | ([M]REOLEVCOD = 2 & [M]REOLEVBAS = 2)
  End
Else
  mkstat = 2
Endif
End
###########################################################
Subprog AS_REOTSDCLC(VALEUR)
Variable Integer VALEUR
If [M]REOLEVCOD = 3 | ([M]REOLEVCOD = 2 & [M]REOLEVBAS = 2)
  End
Else
  mkstat = 2
Endif
End
###########################################################
Subprog AS_REOMINCLC(VALEUR)
Variable Integer VALEUR
If [M]REOLEVCOD = 3 | ([M]REOLEVCOD = 2 & [M]REOLEVBAS = 2)
  End
Else
  mkstat = 2
Endif
End
###########################################################
Subprog AS_MAXSTOCLC(VALEUR)
Variable Integer VALEUR
If [M]REOPERCOD = 3 | ([M]REOPERCOD = 2 & [M]REOPERBAS = 2)
  End
Else
  mkstat = 2
Endif
End
###########################################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif  
End
###########################################################
Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
