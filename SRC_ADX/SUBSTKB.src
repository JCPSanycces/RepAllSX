End
###########################################################
Subprog C_ABCCLSEND(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]ABCCLSSTR
  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif
End
############################################################
Subprog AV_ITMREFSTR(VALEUR)
Variable Char     VALEUR
Affzo [M]REOTSDCLC
Affzo [M]SAFSTOCLC
Affzo [M]REOMINCLC
Affzo [M]MAXSTOCLC
End
############################################################
