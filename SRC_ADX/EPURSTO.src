#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################
# EPURSTO             Traitements des épurations                          Module STOCK #
# ------------------------------------------------------------------------------------ #
# Règles d'épuration :                                                    HCB 26/07/11 #
#   -SCHG : Epuration des changements stocks            (SCHGH/SCHGD)                  #
#   -SLOT : Epuration des modifications lot             (SLOTMH/SLOTMD)                #
#   -SMVT : Epuration des mouvements stocks (documents) (SMVTH/SMVTD)                  #
#   -SWCU : Epuration des impressions inventaires       (WCUNLISDET)                   #
#   -SSTJ : Epuration du journal des stocks             (STOJOU)                       #
#   -SSTR : Epuration de la tracabilité                 (STOTRK)                       #
#   -SINV : Epuration des inventaires                   (CUNSESSION/CUNLISTE/CUNLISDET #
#   -SSTQ : Epuration des demandes analyses             (STOQLYH/STOQLYD/STOQLYSMP)    #
#                                                       (QLYCRDASW)                    #
########################################################################################
$ACTION
Case ACTION
  When "OUVRE"
    #-----------------------------------------#
    # Ouvertures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "SCHG"   : Gosub OUVRE_SCHG
      When "SLOT"   : Gosub OUVRE_SLOT
      When "SMVT"   : Gosub OUVRE_SMVT
      When "SWCU"   : Gosub OUVRE_SWCU
      When "SSTJ"   : Gosub OUVRE_SSTJ
      When "SSTR"   : Gosub OUVRE_SSTR
      When "SINV"   : Gosub OUVRE_SINV
      When "SSTQ"   : Gosub OUVRE_SSTQ
    Endcase
  When "HISTO"
    #--------------------------------------------------------------------------#
    # Historisation enregistrements tables complémentaires non liées à l'objet #
    #--------------------------------------------------------------------------# 
    Case [F:AHI]COD
      When "SCHG"   : Gosub HISTO_EPURE_SCHG
      When "SLOT"   : Gosub HISTO_EPURE_SLOT
      When "SMVT"   : Gosub HISTO_EPURE_SMVT
      When "SWCU"   : Gosub HISTO_EPURE_SWCU
      When "SSTJ"   : Gosub HISTO_EPURE_SSTJ
      When "SSTR"   : Gosub HISTO_EPURE_SSTR
      When "SINV"   : Gosub HISTO_EPURE_SINV
      When "SSTQ"   : Gosub HISTO_EPURE_SSTQ
    Endcase
  When "EPURE"
    #-------------------------------------------------------------------------#
    # Suppressions enregistrements tables complémentaires non liées à l'objet #
    #-------------------------------------------------------------------------# 
    Case [F:AHI]COD
      When "SCHG"   : Gosub HISTO_EPURE_SCHG
      When "SLOT"   : Gosub HISTO_EPURE_SLOT
      When "SMVT"   : Gosub HISTO_EPURE_SMVT
      When "SWCU"   : Gosub HISTO_EPURE_SWCU
      When "SSTJ"   : Gosub HISTO_EPURE_SSTJ
      When "SSTR"   : Gosub HISTO_EPURE_SSTR
      When "SINV"   : Gosub HISTO_EPURE_SINV
      When "SSTQ"   : Gosub HISTO_EPURE_SSTQ
    Endcase
  When "FERME"
    #-----------------------------------------#
    # Fermetures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "SCHG"   : Gosub FERME_SCHG
      When "SLOT"   : Gosub FERME_SLOT
      When "SMVT"   : Gosub FERME_SMVT
      When "SWCU"   : Gosub FERME_SWCU
      When "SSTJ"   : Gosub FERME_SSTJ
      When "SSTR"   : Gosub FERME_SSTR
      When "SINV"   : Gosub FERME_SINV
      When "SSTQ"   : Gosub FERME_SSTQ
    Endcase
Endcase
Return


#############################################################################
# Epuration des changements stocks                                     SCHG #
# Formule d'épuration :  INVSGH<>2 | ( INVSGH=2 & INVFLG=2 )                      #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SCHG
Gosub DEFVAR
If !clalev([F:SGD])  Local File =[L]APPLI+".SCHGD" [SGD]  : Endif

#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
   If OKEPU
      If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN" [CAL]  : Endif
  #----- Historisation -----#
   Else
      If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
    #-----
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
   Endif
#----- Epuration sans historisation -----#
Else
   If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
Endif
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SCHG
WCLE=[F:F1]VCRNUM : WOK=1
If [L]TRACEDET
   Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

#----- Historisation-épuration comptes, sections et textes lignes article -----#

Columns [SGD] (VCRNUM, VCRLIN)
For [SGD] SGD0 Where VCRNUM=[F:F1]VCRNUM
    WABRFIC="SGD" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [SGD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SCHG
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Return

#############################################################################
# Epuration des modifications lot                                      SLOT #
# Formule d'épuration                                                       #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SLOT
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SLOT
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SLOT
Return

#############################################################################
# Epuration des mouvements stocks                                      SMVT #
# Formule d'épuration :                                                     #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SMVT
Gosub DEFVAR
If !clalev([F:SMD])  Local File =[L]APPLI+".SMVTD" [SMD]  : Endif

#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
     If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN" [CAL]  : Endif
  #----- Historisation -----#
  Else
     If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
    #-----
     TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
     If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
   If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
Endif
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SMVT
WCLE=[F:F1]VCRNUM : WOK=1
If [L]TRACEDET
   Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
#----- Historisation-épuration comptes, sections et textes lignes article -----#
Columns [SMD] (VCRTYP,VCRNUM,VCRLIN)
For [SMD] SMD0 Where VCRNUM=[F:F1]VCRNUM
    WABRFIC="SMD" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [SMD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SMVT
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Return

#############################################################################
# Epuration des impressions inventaire                                 SWCU #
# Formule d'épuration                                                       #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SWCU
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SWCU
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SWCU
Return

#############################################################################
# Epuration du journal stock                                           SSTJ #
# Formule d'épuration                                                       #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SSTJ
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SSTJ
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SSTJ
Return

#############################################################################
# Epuration des tracabilités                                           SSTR #
# Formule d'épuration                                                       #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SSTR
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SSTR
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SSTR
Return

#############################################################################
# Epuration des inventaires                                            SINV #
# Formule d'épuration                                                       #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SINV
Gosub DEFVAR
If !clalev([F:CUL])  Local File =[L]APPLI+".CUNLISTE"  [CUL]  : Endif
If !clalev([F:CUD])  Local File =[L]APPLI+".CUNLISDET" [CUD]  : Endif
#----- Historisation -----#
If HISTO
   TABLE="CUNLISTE"  : Gosub CRETAB_HISTO
   If !clalev([F:CUL1]) Local File =[L]HISAPL+".CUNLISTE"  [CUL1] : Endif
   TABLE="CUNLISDET" : Gosub CRETAB_HISTO
   If !clalev([F:CUD1]) Local File =[L]HISAPL+".CUNLISDET" [CUD1] : Endif
Endif

Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SINV
WSTOFCY = [F:F1]STOFCY
WCLE    = [F:F1]CUNSSSNUM

If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
WOK=1
Gosub HIS_EPU_CUL : If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
Gosub HIS_EPU_CUD : If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SINV
If clalev([F:CUL])  : Close Local File [CUL]  : Endif
If clalev([F:CUD])  : Close Local File [CUD]  : Endif
If clalev([F:CUL1]) : Close Local File [CUL1] : Endif
If clalev([F:CUD1]) : Close Local File [CUD1] : Endif

Return

#############################################################################
# Epuration des demandes analyses                                      SSTQ #
# Formule d'épuration :  VALFLG = 2                                         #
#############################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
#-------------------------------------------------#
$OUVRE_SSTQ
Gosub DEFVAR
If !clalev([F:QLA])  Local File =[L]APPLI+".QLYCRDASW" [QLA]  : Endif
If !clalev([F:QLD])  Local File =[L]APPLI+".STOQLYD"   [QLD]  : Endif
If !clalev([F:SMP])  Local File =[L]APPLI+".STOQLYSMP" [SMP]  : Endif
#----- Historisation -----#
If HISTO
   TABLE="QLYCRDASW"  : Gosub CRETAB_HISTO
   If !clalev([F:QLA1]) Local File =[L]HISAPL+".QLYCRDASW"  [QLA1] : Endif
Endif

Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #                                   
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
$HISTO_EPURE_SSTQ
WCLE    = [F:F1]VCRNUM

If [L]TRACEDET
   Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
WOK=1
Columns [QLD] (VCRTYP,VCRNUM,VCRLIN)
For [QLD] QLD0 Where VCRNUM=[F:F1]VCRNUM
    Gosub HIS_EPU_QLA
    If !WOK  Break : Endif
Next
Columns [QLD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_SSTQ
If clalev([F:QLA])  : Close Local File [QLA]  : Endif
If clalev([F:QLD])  : Close Local File [QLD]  : Endif
If clalev([F:SMP])  : Close Local File [SMP]  : Endif
If clalev([F:QLA1]) : Close Local File [QLA1] : Endif

Return

#---------------------------#
# Déclaration des variables #
#---------------------------#
$DEFVAR
Local Integer WOK
Local Char    WNUMTEX (12), WTYP(4), WMESSAGE(100), WCLE(GLONVCR)
Local Char    NEWTEX(250), OLDTEX(250)
Local Char    WCRITERE(100)
Local Char    WABRFIC(4)
Local Integer WVCRTYP,          WVCRTYP2
Local Char    WVCRNUM(GLONVCR), WVCRNUM2(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Integer WNBR
Local Char    WCPLCLE(30)
Local Char    WCLEFIC(50),      WCLEFIC2(50)
Local Char    WSTOFCY(GLONFCY)
Return

#---------------------------------------------------------#
# Création des tables historiques non liées si nécessaire #
#---------------------------------------------------------#
$CRETAB_HISTO
WOK=0
If filinfo(filpath("FIL",TABLE,"fde",HISAPL),0)<0         # hcb 105047
   WOK=1
Else
   Call VUE_OK(TABLE,HISAPL,"FIL",WOK) From DOSVUE        # hcb 105047
Endif
If WOK
   Call CRETABLE(APPLI,HISAPL,TYPDBA,TABLE,COEFF,0) From CREHISTO
Endif
WOK=1
Return

#--------------------------------------------------------------------------------#
# Historisation / Epuration des comptes et sections associés aux lignes document #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_CAL
#-----
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
#-----
Case WABRFIC
     When "SGD" : [L]WVCRNUM=[F:SGD]VCRNUM : [L]WVCRLIN=[F:SGD]VCRLIN
     When "SMD" : [L]WVCRTYP=[F:SMD]VCRTYP : [L]WVCRNUM=[F:SMD]VCRNUM : [L]WVCRLIN=[F:SMD]VCRLIN
Endcase
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
If OKHIS
   Read [CAL] CAL0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
   If !fstat & ![L]SIMUL
      [F:CAL1]=[F:CAL]
      If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
      If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
      Write [CAL1]
      If fstat
         Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
         WOK=0 : Return
      Endif
   Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
   Delete [CAL] Where ABRFIC=[L]WABRFIC
&                   & VCRTYP=[L]WVCRTYP
&                   & VCRNUM=[L]WVCRNUM
&                   & VCRLIN=[L]WVCRLIN
&                   & VCRSEQ=[L]WVCRSEQ
&                   & CPLCLE=[L]WCPLCLE
&                   & ANALIG=1
   If fstat
      Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
   Endif
Endif
#-----
If [L]TRACEDET
   Call ECR_TRACE("-- CPTANALIN"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#-------------------------------------------------------------------------------#
#    Historisation/epuration                                   CONTROLE QUALITE #
#-------------------------------------------------------------------------------#
#-------------------------------------------------------------------------------#
#    Historisation/epuration QLYCRDASW                                          #
#-------------------------------------------------------------------------------#
$HIS_EPU_QLA
Raz WNBR
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
[L]WVCRLIN = [F:QLD]VCRLIN

WCRITERE='QLYCTLDEM=WCLE & VCRLIN = [L]WVCRLIN'
If OKHIS & OKEPU=0
   For [QLA] Where evalue(WCRITERE)
       [F:QLA1] = [F:QLA]
       If dim([F:QLA1]CREHISDAT)>0 : [F:QLA1]CREHISDAT = date$    : Endif
       If dim([F:QLA1]CREHISUSR)>0 : [F:QLA1]CREHISUSR = [V]GUSER : Endif
       If !SIMUL
          Write [F:QLA1]
          If fstat
             WOK=0 : Call ECR_TRACE("$QLYCRDASW"-WCLE-mess(13,100,1),1) From GESECRAN : Break
          Endif
       Endif
   Next
   If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
   Filter [QLA]  Where evalue(WCRITERE) : WNBR = rowcount([QLA])
   Filter [QLA]
Endif

If !SIMUL
   Delete [QLA] Where evalue (WCRITERE)
   If fstat=1
      WOK=0 : Call ECR_TRACE("$QLYCRDASW"-WCLE-mess(10,100,1),1) From GESECRAN
   Endif
   If WOK=0 : Return : Endif
Endif
If [L]TRACEDET & WNBR <> 0
   Call ECR_TRACE ("-- QLYCRDASW"-WCLE-num$([L]WVCRLIN),0) From GESECRAN
Endif

Return

#-------------------------------------------------------------------------------#
#    Historisation/epuration                                         INVENTAIRE #
#-------------------------------------------------------------------------------#
#-------------------------------------------------------------------------------#
#    Historisation/epuration CUNLISTE                                           #
#-------------------------------------------------------------------------------#
$HIS_EPU_CUL
Raz WNBR
WCRITERE='CUNSSSNUM=WCLE & STOFCY = WSTOFCY'
If OKHIS & OKEPU=0
   For [CUL] Where evalue(WCRITERE)
       [F:CUL1] = [F:CUL]
       If dim([F:CUL1]CREHISDAT)>0 : [F:CUL1]CREHISDAT = date$    : Endif
       If dim([F:CUL1]CREHISUSR)>0 : [F:CUL1]CREHISUSR = [V]GUSER : Endif
       If !SIMUL
          Write [F:CUL1]
          If fstat
             WOK=0 : Call ECR_TRACE("$CUNLISTE"-WCLE-mess(13,100,1),1) From GESECRAN : Break
          Endif
      Endif
   Next
   If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
   Filter [CUL]  Where evalue(WCRITERE) : WNBR = rowcount([CUL])
   Filter [CUL]
Endif

If !SIMUL
   Delete [CUL] Where evalue (WCRITERE)
   If fstat=1
      WOK=0 : Call ECR_TRACE("$CUNLISTE"-WCLE-mess(10,100,1),1) From GESECRAN
   Endif
   If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
   Call ECR_TRACE ("-- CUNLISTE"-WCLE-"("+num$(WNBR)+")",0) From GESECRAN
Endif
Return

#-------------------------------------------------------------------------------#
#    Historisation/epuration CUNLISTE                                           #
#-------------------------------------------------------------------------------#
$HIS_EPU_CUD
Raz WNBR

WCRITERE='CUNSSSNUM=WCLE & STOFCY = WSTOFCY'
If OKHIS & OKEPU=0
    For [CUD] Where evalue(WCRITERE)
        [F:CUD1] = [F:CUD]
        If dim([F:CUD1]CREHISDAT)>0 : [F:CUD1]CREHISDAT = date$    : Endif
        If dim([F:CUD1]CREHISUSR)>0 : [F:CUD1]CREHISUSR = [V]GUSER : Endif
        If !SIMUL
           Write [F:CUD1]
           If fstat
              WOK=0 : Call ECR_TRACE("$CUNLISDET"-WCLE-mess(13,100,1),1) From GESECRAN : Break
           Endif
        Endif
    Next
    If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
   Filter [CUD]  Where evalue(WCRITERE) : WNBR = rowcount([CUD])
   Filter [CUD]
Endif

If !SIMUL
  Delete [CUD] Where evalue (WCRITERE)
  If fstat=1
      WOK=0 : Call ECR_TRACE("$CUNLISDET"-WCLE-mess(10,100,1),1) From GESECRAN
  Endif
  If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
    Call ECR_TRACE ("-- CUNLISDET"-WCLE-"("+num$(WNBR)+")",0) From GESECRAN
Endif

Return



