#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("TBU",GBIDC1,GBIDC2) From GOBJET
End

# Issue X3-70924 - 2018-01-15 - MDJ : Replace the call to VALID from VALMSK by a call to VALIDFULL from VALMSK

## BUDCAT=1 : Budget par pÃĐriode
## BUDCAT=2 : Budget par compte
## BUDCAT=3 : Budget par section

## On a un texte gÃĐnÃĐral pour les budgets par nature et par section TEX(50)
## On a un texte par pÃĐriodes pour les budget par pÃĐriode TEXPER(50)(0..PER)

## Nom colonne dans [M:BUD] = Type+numÃĐro de colonne

$ACTION
Case ACTION
 When "LIENS"      : Gosub LIENS
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "APRES_CRE"  : Gosub VALID
 When "APRES_MOD"  : Gosub VALID
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "ANNULE"     : Gosub ANNULE
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "CHANGE"     : Gosub CHANGE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
Endcase
Return

######################################################################################
# Fonction qui permet de rÃĐcupÃĐrer l'intitulÃĐ de colonne COLDESTRA dans la langue de
# connection de l'utilisateur
######################################################################################
Funprog GET_COLDESTRA(DES1,DES2)
Value Char DES1
Value Integer DES2
Local Char DESCOL(80)

DES3=num$(DES2)
Call LECTEXTRA(DESCOL,"TABBUDTYP","COLDESTRA",DES1,DES3) From ATEXTRA

End DESCOL


######################################################################################


$INICRE
$INIMOD
If func AFNC.ACTIV("LEG")=0 : [F:TBU]LEG = GDOSLEG(1) : Endif
If dim([F:TBU]DES)>0
 [F:TBU]DES = [M:TBU]DESTRA
Endif
# Field COLDES should be deleted from table TABBUDTYP, new field COLDESTRA (evaluated)
# leave it in table in case used by Users , Specific ...
If dim([F:TBU]COLDES)>0
 [F:TBU]COLDES = [M:TBU]COLDESTRA(nolign-1)
Endif
Return

$LIENS
[M]TYPSELCRI(nolign-1) = num$([M]COLTYP(nolign-1))+num$([M]LINSELCRI(nolign-1))
Call LECTEXTRA([M:TBU]DESTRA,"TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"") From ATEXTRA
Call LECTEXTRA([M:TBU]SHOTRA,"TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"") From ATEXTRA
Call LECTEXTRA([M:TBU]COLDESTRA(nolign-1),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$([M:TBU]COLNUM(nolign-1))) From ATEXTRA
Return

$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "V" : # Validation
  Gosub VALID
Endcase
Return

$CREATION
Gosub CTEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub MTEXTRA
Call MAJTEXTRA([M:TBU]DESTRA,"TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"") From ATEXTRA
Call MAJTEXTRA([M:TBU]SHOTRA,"TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"") From ATEXTRA
If GOK<1 : Return : Endif
Return

$CTEXTRA
If GREP="D"
 ## When we duplicate, we want to recover all the translatable titles.
 Call DUPTEXTRA("TABBUDTYP","DESTRA",CLECUR1,"","TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"")  From ATEXTRA
 Call DUPTEXTRA("TABBUDTYP","SHOTRA",CLECUR1,"","TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"")  From ATEXTRA
 Call DUPTEXTRA("TABBUDTYP","COLDESTRA",CLECUR1,num$([M:TBU]COLNUM(nolign-1)),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$([M:TBU]COLNUM(nolign-1))) From ATEXTRA
 If dim([F:TBU]DES)>0
  [F:TBU]DES = [M:TBU]DESTRA
 Endif
Endif
If GREP="C" | GREP="D"
 Call MAJTEXTRA([M:TBU]COLDESTRA(nolign-1),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$([M:TBU]COLNUM(nolign-1))) From ATEXTRA
 Call MAJTEXTRA([M:TBU]DESTRA,"TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"") From ATEXTRA
 Call MAJTEXTRA([M:TBU]SHOTRA,"TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"") From ATEXTRA
Endif
Return


$MTEXTRA
If GREP="M"
 # Updating the translatable titles of the column.

 # In insertion mode we go to MAJTEXTRABIS
 INSERT=0
 For I=0 To [M]NBLIG-1
  If [M:TBU]COLNUM(I)=[M:TBU]NBLIG
   INSERT= I : Break
  Endif
 Next

 # Not in insertion mode
 If INSERT = 0

  For I=0 To [M:TBU]NBLIG-1
   If [M:TBU]COLNUM(I) <> 0
    Call DUPTEXTRA("TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$([M:TBU]COLNUM(I)),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,chr$(255)+num$(I+1)) From ATEXTRA
   Endif
  Next I

  Delete [AXX] Where CODFIC = "TABBUDTYP" & ZONE = "COLDESTRA" & IDENT1 = [M:TBU]BUDTYP & left$(IDENT2,1) <> chr$(255)
  If fstat=1
   GOK=-1 : Call RSTA("AXX","TABBUDTYP"-[M:TBU]BUDTYP) From GLOCK : Return
  Endif
  Update [AXX] Where CODFIC = "TABBUDTYP" & ZONE = "COLDESTRA" & IDENT1 = [M:TBU]BUDTYP & left$(IDENT2,1) = chr$(255)
&              With [AXX]IDENT2 = right$([AXX]IDENT2,2)
  If fstat=1
   GOK=-1 : Call RSTA("AXX","TABBUDTYP"-[M:TBU]BUDTYP) From GLOCK : Return
  Endif

  For I=0 To [M:TBU]NBLIG-1
   Call MAJTEXTRA([M:TBU]COLDESTRA(I),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$(I+1)) From ATEXTRA
   [M:TBU]COLNUM(I) = I+1
  Next

 Else
  Gosub MTEXTRABIS

 Endif #INSERT
Endif  #GREP
Return

$MTEXTRABIS
# Updating the translatable titles when we add/insert lines in the array
For I=0 To [M:TBU]NBLIG-1
 Call DUPTEXTRA("TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$([M:TBU]COLNUM(I)),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,chr$(255)+num$(I+1)) From ATEXTRA
Next

Delete [AXX] Where CODFIC = "TABBUDTYP" & ZONE = "COLDESTRA" & IDENT1 = [M:TBU]BUDTYP & left$(IDENT2,1) <> chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","TABBUDTYP"-[M:TBU]BUDTYP) From GLOCK : Return
Endif
Update [AXX] Where CODFIC = "TABBUDTYP" & ZONE = "COLDESTRA" & IDENT1 = [M:TBU]BUDTYP & left$(IDENT2,1) = chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","TABBUDTYP"-[M:TBU]BUDTYP) From GLOCK : Return
Endif

For I=0 To [M:TBU]NBLIG-1
 Call MAJTEXTRA([M:TBU]COLDESTRA(I),"TABBUDTYP","COLDESTRA",[M:TBU]BUDTYP,num$(I+1)) From ATEXTRA
Next

#RenumÃĐroter le COLNUM correctement
For K=INSERT-1 To NBLIG
 T=K
 [M]COLNUM(T)=T+1
Next
Return


$AP_CHANGE
Call CHGTEXTRA("TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"",NCODE,"") From ATEXTRA
Return

$CHANGE
Update [AXX] Where CODFIC="TABBUDTYP" & ZONE = "COLDESTRA" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABBUDTYP"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif

Return

$ANNULE
Call SUPTEXTRA("TABBUDTYP","DESTRA",[M:TBU]BUDTYP,"") From ATEXTRA
Call SUPTEXTRA("TABBUDTYP","SHOTRA",[M:TBU]BUDTYP,"") From ATEXTRA
# Delete (when we click on the Delete transaction button) all the translatable titles COLDESTRA
For [TBU]TBU0 Where BUDTYP=[M:TBU]BUDTYP
 Call SUPTEXTRA("TABBUDTYP","COLDESTRA",[F:TBU]BUDTYP,num$([F:TBU]COLNUM)) From ATEXTRA
Next
# Annulation des ÃĐcrans
Local Char MASQUE(10)
Local Char NOMWIN(10)
MASQUE = "WMBUD"+[M:TBU]BUDTYP
Call DELMSK(MASQUE,nomap) From MSKDIV
If GOK<1 : Return : Endif
NOMWIN = "WFBUD"+[M:TBU]BUDTYP
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return

$AP_ANNULE
Call VALID("TBU",nomap,1,OK) From VALOBJ
Return



########################################
## Window creation
########################################
Subprog PATCH(APPLI)
Value Char APPLI()

If APPLI="X3" : End : Endif
Onerrgo CHUT From CONTROLE
Local File =APPLI+".ADOVAL" [ADW]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [ADW]ADW0 = "";"";"MODULE1"
If !fstat & ([F:ADW]VALEUR="" | mid$([F:ADW]VALEUR,2,1)="2") : # If accounting module
 Call GENDOS(APPLI)
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI()
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AOBJTAB"   [AOT]
Local File =APPLI+".AOBJLST"   [AOL]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".AMSK"      [AMK2]
Local File =APPLI+".AMSKZON"   [AMZ2]
Local File =APPLI+".AMSKACT"   [AMA2]
Local File =APPLI+".AMSKPAR"   [AMP2]
Local File =APPLI+".TABBUDTYP" [TBU]
Local File =APPLI+".TABBUDTYP" [TBU0]
Local File =APPLI+".TABBUDTYP" [TBU3]

For [TBU]TBU0(1) Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:TBU]BUDTYP,0) From GESECRAN : Endif
 Call VALIDATION([F:TBU]BUDTYP,APPLI)
 If GOK=0 : Break : Endif
Next
End

$VALID
If !GIMPORT
 Call VALIDATION([F:TBU]BUDTYP,nomap)
 If GOK=0 : Return : Endif
Endif
Return

######################################################################
## Validation
######################################################################

Subprog VALIDATION(COD,APPLI)
Value Char COD()
Value Char APPLI()

If clalev([F:ADS])=0  : Local File ADOSSIER  [ADS]  : Endif
If clalev([F:AWI])=0  : Local File AWINDOW   [AWI]  : Endif
If clalev([F:AWP])=0  : Local File AWINPAR   [AWP]  : Endif
If clalev([F:AWB])=0  : Local File AWINBRO   [AWB]  : Endif
If clalev([F:AWT])=0  : Local File AWINBOUT  [AWT]  : Endif
If clalev([F:AMK])=0  : Local File AMSK      [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON   [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File AMSKACT   [AMA]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR   [AMP]  : Endif
If clalev([F:AMK2])=0 : Local File AMSK      [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON   [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT   [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File AMSKPAR   [AMP2] : Endif
If clalev([F:TBU0])=0 : Local File TABBUDTYP [TBU0] : Endif
If clalev([F:TBU3])=0 : Local File TABBUDTYP [TBU3] : Endif

Local Char    MASKREF(10), MASKDES(10)
Local Char    WINREF(10), NOMWIN(10)
Local Char    SAVLAN(3), COLEXP(80)
Local Integer I, P, NOCOL, LANCUR, NUMCOL, OK, NOTABZON
Local Integer BLOC, NOBLOC(1..3)
Local Integer NBTOT(1..3) : # 3 types of different totals

Call TEMPON("V") From GESECRAN
MASKREF = "BUD"
MASKDES = "WMBUD"+[F:TBU]BUDTYP
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
  If [F:TBU]ENAFLG=2
    Read [ADS]DOSSIER = APPLI
    #*X3-70924 Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
    Call VALIDFULL(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Endif
Endif

If GOK=0 : End : Endif

WINREF  = "FBUD"
NOMWIN  = "WFBUD"+[F:TBU]BUDTYP
Call DEBTRANS From GLOCK
Gosub TR2
If GOK>0
 If [F:TBU]ENAFLG=2
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
  If !OK : GOK=0 : Endif
 Else
  Local Char TRTWIN(12)
  If NOMWIN<>"" : TRTWIN="WG"+NOMWIN : Endif
  Call EFFACE_ADX("",APPLI,TRTWIN,OK) From ORDSYS
  Call EFFACE(filpath("TRT",TRTWIN,"src",APPLI),OK) From ORDSYS
 Endif
Endif
Call TEMPOFF From GESECRAN
End

######################################################################
## GÃĐnÃĐration de l'ÃĐcran
######################################################################

$TR1
GOK = 1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2]

# Remove the previous screen
 Call DELMSK(MASKDES,APPLI) From MSKDIV
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

# Building of the screen
 If [F:TBU]ENAFLG=2
  Read [AMK]CODMSK = MASKREF
  [F:AMK2] = [F:AMK]
  [F:AMK2]CODMSK  = MASKDES
  [F:AMK2]INTMSK  = 0
  [F:AMK2]MDL     = 1
  # On paramÃĻtre les options du tableau
  Case [F:TBU]BUDCAT
   When 1 : # Budget entry carried out by period
    # Cancellation and adding lines are unauthorized. the screen is always ÃĐs. L'ÃĐcran est toujours preloaded
    [F:AMK2]OPTION(3)  = "K2"
   When 2: # Budget entry carried out by account
    [F:AMK2]OPTION(3) += "1"
   When 3 : # Budget entry carried out by dimension
    [F:AMK2]OPTION(3) += "3"
    [F:AMK2]INTBLOC(4) = "mess(52,108,1)" : # TOTAL PRODUITS
    [F:AMK2]INTBLOC(5) = "mess(53,108,1)" : # TOTAL CHARGES
  Endcase
  Gosub BLOC_VIDE
  Call CHG_NUMBLOC(8, [F:AMK2]NBBLOC)
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
  Endif

# Blocks 1 2 3 4
  For [AMZ]CODZON Where CODMSK=MASKREF & (NUMBLOC<=4 or NUMBLOC=8)
   COP = 0
   Case [F:AMZ]NUMBLOC
    When 1
     # DÃĐfilement et NBRLIN
     [F:AMZ2] = [F:AMZ]
     COP = 1
     If [F:AMZ2]CODZON="DEFIL"
      If [F:TBU]BUDCAT=1
       [F:AMZ2]DIME = [F:TBU]MAXDIENBR+1
      Else
       [F:AMZ2]DIME = [F:TBU]MAXDIENBR
      Endif
     Endif
    When 2,3
     # Data about account and dimension
     Case [F:AMZ]CODZON
      When "COA"
       [F:AMZ2] = [F:AMZ]
       COP = 1
       # In a budget entry carried out by dimension, the account is displayed in the first column not in the block list
       If [F:TBU]BUDCAT=3
        [F:AMZ2]SAIAFF=3        : # invisible
       Endif
      When "INTITACC","ACC","DESACC","DTP","UOMACC"
       # In a budget entry carried out by dimension, the account is displayed in the first column not in the block list
       If [F:TBU]BUDCAT<>3
        [F:AMZ2] = [F:AMZ]
        COP = 1
       Endif
      When "DIE1","INTITCCE1","CCE1","DESCCE1","DIE2","INTITCCE2","CCE2","DESCCE2","DIE3","INTITCCE3","CCE3","DESCCE3",
&          "DIE4","INTITCCE4","CCE4","DESCCE4","DIE5","INTITCCE5","CCE5","DESCCE5","DIE6","INTITCCE6","CCE6","DESCCE6",
&          "DIE7","INTITCCE7","CCE7","DESCCE7","DIE8","INTITCCE8","CCE8","DESCCE8","DIE9","INTITCCE9","CCE9","DESCCE9"
       [F:AMZ2] = [F:AMZ]
       COP = 1
       # Do not display the dimension types greater than the maximum defined by MAXDIENBR
       If val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))>[F:TBU]MAXDIENBR :# Last character
        [F:AMZ2]SAIAFF=3
       # Budget entry carried out by account=>The last dimension is diplayed in the first column not in the block list
       Elsif [F:TBU]BUDCAT=2 & val(right$([F:AMZ]CODZON,len([F:AMZ]CODZON)))=[F:TBU]MAXDIENBR
        [F:AMZ2]SAIAFF=3
       # Budget entry carried out by dimension=>The account is diplayed in the first column not in the block list
       Elsif [F:TBU]BUDCAT=3
        [F:AMZ2]NOZONE -=1
       Endif
      When "TEX"       : # Global text for dimension budget and account budget
       If [F:TBU]BUDCAT<>1
        [F:AMZ2] = [F:AMZ]
        [F:AMZ2]NOZONE = [F:TBU]MAXDIENBR+2
        COP = 1
       Endif
      When "LEDTYP"
       [F:AMZ2] = [F:AMZ]
       [F:AMZ2]NOZONE = [F:TBU]MAXDIENBR+2
       COP = 1
      When Default
       [F:AMZ2] = [F:AMZ]
       COP = 1
     Endcase
    When 4, 8
     # 2 premiÃĻres zones de tableau ou bloc 8
     If find([F:AMZ]CODZON,"NBLIG","NUMLIG") or [F:AMZ]NUMBLOC=8
      [F:AMZ2] = [F:AMZ]
      If [F:AMZ]NUMBLOC=8
       # on met les champs du bloc 8 dans le dernier bloc de l'ÃĐcran gÃĐnÃĐrÃĐ
       [F:AMZ2]NUMBLOC = [F:AMK2]NBBLOC
      Endif
      COP = 1
     Endif
   Endcase

   If COP = 1
    [F:AMZ2]CODMSK=MASKDES
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ]CODZON,0)
    If GOK<1 : Break  : Endif
   Endif
  Next

  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

# Bloc 4 : array
  NUMCOL = 1 : # NUMLIG et NBLIG sont en position 1
  Case [F:TBU]BUDCAT
   When 1 : # Period
    For NOMZ="FIYNUM","PERNUM","PERSTR","PEREND"
     Read [AMZ]CODE=MASKREF;NOMZ
     If !fstat
      NUMCOL +=1
      [F:AMZ2] = [F:AMZ]
      #[F:AMZ2]NOZONE  = NUMCOL : # Car nozone=1 pour nblig
      [F:AMZ2]NUMLIG  = NUMCOL
      [F:AMZ2]CODMSK  = MASKDES
      Write [AMZ2]
      If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
      Endif
      Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,0)
      If GOK<1 : Break : Endif
     Endif
    Next
    If   GOK<0 : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif

   When 2 : # Account
    For NOMZ="CODCCE3","FLGMOD"
     Read [AMZ]CODE=MASKREF;NOMZ
     If !fstat
      NUMCOL +=1
      [F:AMZ2] = [F:AMZ]
      If NOMZ="CODCCE3" : [F:AMZ2]NUMBLOC=4 : Endif
      #[F:AMZ2]NOZONE  = NUMCOL : # Car nozone=1 pour nblig
      [F:AMZ2]NUMLIG  = NUMCOL
      [F:AMZ2]CODMSK  = MASKDES
      Write [AMZ2]
      If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Goto AB_TR1
      Endif
      Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,0)
      If GOK<1 : Goto ROLL_TR1 : Endif
     Endif
    Next

   When 3 : # Dimension
    For NOMZ="CODACC","SENS","CODDTP","UOM","FLGMOD"
     Read [AMZ]CODE=MASKREF;NOMZ
     If !fstat
      NUMCOL +=1
      [F:AMZ2] = [F:AMZ]
      #[F:AMZ2]NOZONE  = NUMCOL : # Car nozone=1 pour nblig
      [F:AMZ2]NUMLIG  = NUMCOL
      [F:AMZ2]CODMSK  = MASKDES
      Write [AMZ2]
      If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Goto AB_TR1
      Endif
      Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,0)
      If GOK<1 : Goto ROLL_TR1 : Endif
     Endif
    Next
  Endcase


  GPOINT="TBUZONSPE" : Gosub ENTREE From EXEFNC :# 80135
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  # The following 4 lines came with PE 80135 in order
  # to choose the specific new filed's position...
  # The new field(s) and the standard ones (depending of category regarding what's previous #bloc 4 affectations)
  # will use there own NOZONE as defined in the mask
  # then fields defined in the transaction's table will follow and begin
  # with the biggest nozone defined in [M:BUD] bloc 4
  Filter [AMZ] Where CODMSK=MASKREF & NUMBLOC=4 Order By Key CLE=NOZONE;NUMBLOC;CODMSK;CODZON
  Read [AMZ]CLE Last
  NOTABZON=int([F:AMZ]NOZONE)
  Filter [AMZ]

  For [TBU0]TBU0 Where BUDTYP=[F:TBU]BUDTYP
   Read [AMZ]CODE=MASKREF;[F:TBU0]NOMZON
   If !fstat
    NUMCOL +=1
    NOTABZON +=1
    [F:AMZ2] = [F:AMZ]
#    [F:AMZ2]NOZONE  = NUMCOL
    [F:AMZ2]NOZONE  = NOTABZON
    [F:AMZ2]NUMLIG  = NUMCOL
    [F:AMZ2]CODMSK  = MASKDES
    [F:AMZ2]CODZON  = [F:TBU0]NOMZON+num$([F:TBU0]COLNUM)
    Raz [F:AMZ2]INTIT
    [F:AMZ2]INTEVAL = 'func SUBTBU.GET_COLDESTRA("'+[F:TBU0]BUDTYP+'",'+num$([F:TBU0]COLNUM)+')'
    [F:AMZ2]INTEVAL += "-[V]LIBBUD("+num$([F:TBU0]LINSELCRI)+")"    # Demande 23636

    If [F:TBU0]COLSAIAFF=1 : # Colonne non visible
     [F:AMZ2]SAIAFF  = 3 # invisible
    Endif
    Write [AMZ2]
    If fstat
     GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
    Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,[F:TBU0]COLNUM)
    If GOK<1 : Break : Endif

# Bloc 5 6 7 : Totaux
    If [F:TBU0]TOT=2
     Read [AMZ]CODE=MASKREF;"Y"+[F:TBU0]NOMZON
     If !fstat
      [F:AMZ2] = [F:AMZ]
      [F:AMZ2]CODMSK  = MASKDES
      [F:AMZ2]CODZON  = "Y"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)
      [F:AMZ2]VALDEF  = "*sum([M]"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)+"(0..max(nolign-1,[M]NBLIG-1)))"
      Raz [F:AMZ2]INTIT
      Case [F:TBU0]NOMZON
       When "QTY", "QTYREA", "QTYCMM", "QTYPRP"
        NBTOT(1)      +=1
        [F:AMZ2]NOZONE = NBTOT(1)
        [F:AMZ2]NUMLIG = NBTOT(1)
        If NOBLOC(1)<>0 : [F:AMZ2]NUMBLOC = NOBLOC(1) : Endif
       When "AMT", "AMTREA", "AMTCMM", "AMTPRP"
        NBTOT(2)      +=1
        [F:AMZ2]NOZONE = NBTOT(2)
        [F:AMZ2]NUMLIG = NBTOT(2)
        If [F:TBU]BUDCAT=3
         [F:AMZ2]CODZON = "C"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)
         [F:AMZ2]VALDEF = "*sigma(0,[M]NBLIG-1,[M]"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)+"(indcum)*([M]SENS(indcum)=1))"
        Endif
        If NOBLOC(2)<>0 : [F:AMZ2]NUMBLOC = NOBLOC(2) : Endif
       When "AMTFOR"
        NBTOT(3)      +=1
        [F:AMZ2]NOZONE = NBTOT(3)
        [F:AMZ2]NUMLIG = NBTOT(3)
        If NOBLOC(3)<>0 : [F:AMZ2]NUMBLOC = NOBLOC(3) : Endif
      Endcase

      Write [AMZ2]
      If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
      Endif
      Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,[F:TBU0]COLNUM)
      If GOK<1 : Break : Endif

     # Le bloc Total Produit remplace le bloc Total quantitÃĐ dans le budget par section car il
     # n'y a pas de totaux sur les quantitÃĐs dans le budget par section
      If [F:TBU]BUDCAT=3 & ([F:TBU0]NOMZON="AMT" | [F:TBU0]NOMZON="AMTREA" |
&                           [F:TBU0]NOMZON="AMTCMM" | [F:TBU0]NOMZON="AMTPRP")
       [F:AMZ2]CODZON  = "Y"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)
       [F:AMZ2]VALDEF  = "*sigma(0,[M]NBLIG-1,[M]"+[F:TBU0]NOMZON+num$([F:TBU0]COLNUM)+"(indcum)*([M]SENS(indcum)=2))"
       [F:AMZ2]NUMBLOC = [F:AMZ]NUMBLOC-1
       Write [AMZ2]
       If fstat
        GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
       Endif
       Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,[F:TBU0]COLNUM)
       If GOK<1 : Break : Endif
      Endif

      # Ajout de la zone CUR si AMT
      If [F:TBU0]NOMZON="AMT"
       Read [AMZ]CODE=MASKREF;"CUR"
       If !fstat
        [F:AMZ2]       = [F:AMZ]
        [F:AMZ2]CODZON = "CUR"+num$([F:TBU0]COLNUM)
        [F:AMZ2]CODMSK = MASKDES
        [F:AMZ2]NOZONE = NBTOT(2)+2/10
        [F:AMZ2]NUMLIG = NBTOT(2)+2/10
        [F:AMZ2]VALDEF = "[M:BCR]CUR("+num$([F:TBU0]LINSELCRI-1)+")"
        If NOBLOC(2)<>0 : [F:AMZ2]NUMBLOC = NOBLOC(2) : Endif
        Write [AMZ2]
        If fstat
         GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
        Endif
        Call COPIE_ACTION(MASKREF,MASKDES,[F:AMZ]CODZON,[F:AMZ2]CODZON,0)
        If GOK<1 : Break : Endif
       Endif
      Endif

     Endif
    Endif
   Endif
  Next


 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Endif : # [F:TBU]ENAFLG=2
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif



$BLOC_VIDE
For [TBU0]TBU0 Where BUDTYP=[F:TBU]BUDTYP
 If [F:TBU0]TOT=2
  Case [F:TBU0]COLTYP
   When 1,3,5,7
    # Bloc Total QuantitÃĐ
    If BLOC <100 : BLOC +=100 : Endif
   When 2,4,6,8
    # Bloc Total Montant
    If mid$(num$(format$("N0:3",BLOC)),2,1)<>"1" : BLOC +=10 : Endif
   When 9
    # Bloc Total Formule
    If right$(num$(format$("N0:3",BLOC)),3)<>"1" : BLOC +=1  : Endif
  Endcase
 Endif
Next

Case BLOC
 When 0   :# Aucun Bloc Total
  Call RAZ_BLOC(7)
  Call RAZ_BLOC(6)
  Call RAZ_BLOC(5)
 When 10  :# Bloc Total Montant
  If [F:TBU]BUDCAT<>3
   Call CHG_NUMBLOC(6,5)
   [F:AMK2]POSBLOC(5-1) = 4.1
   [F:AMK2]COLBLOC(5-1) = 5
   NOBLOC(2) = 5
   Call RAZ_BLOC(6)
  Endif
  Call RAZ_BLOC(7)
 When 100 :# Bloc Total QuantitÃĐ
  Call RAZ_BLOC(6)
  Call RAZ_BLOC(7)
  [F:AMK2]COLBLOC(5-1) = 5
 When 1   :# Bloc Total Formule
  Call CHG_NUMBLOC(7,5)
  [F:AMK2]POSBLOC(5-1) = 4.1
  [F:AMK2]COLBLOC(5-1) = 5
  NOBLOC(3) = 5
  Call RAZ_BLOC(6)
  Call RAZ_BLOC(7)
 When 101 :# Blocs Total QuantitÃĐ et Formule
  [F:AMK2]POSBLOC(5-1) = 4.1
  [F:AMK2]COLBLOC(5-1) = 3
  Call CHG_NUMBLOC(7,6)
  [F:AMK2]POSBLOC(6-1) = 4.4
  [F:AMK2]COLBLOC(6-1) = 2
  NOBLOC(3) = 6
  Call RAZ_BLOC(7)
 When 110 :# Blocs Total QuantitÃĐ et Montant
  Call RAZ_BLOC(7)
  [F:AMK2]COLBLOC(6-1) = 3
 When 11  :# Blocs Total Montant et Formule
  If [F:TBU]BUDCAT<>3
   Call CHG_NUMBLOC(6,5)
   Call CHG_NUMBLOC(7,6)
   [F:AMK2]POSBLOC(5-1) = 4.1
   [F:AMK2]COLBLOC(5-1) = 3
   [F:AMK2]POSBLOC(6-1) = 4.4
   [F:AMK2]COLBLOC(6-1) = 2
   NOBLOC(2) = 5
   NOBLOC(3) = 6
   Call RAZ_BLOC(7)
  Endif
 #NB: Case 111 - we don't change the model mask BUD
Endcase
Return

# remplace un bloc de l'ÃĐcran gÃĐnÃĐrÃĐ par un bloc de l'ÃĐcran modÃĻle
Subprog CHG_NUMBLOC(ORI,DEST)
Value Integer ORI
Value Integer DEST
[F:AMK2]LNGLIB(DEST-1)  = [F:AMK]LNGLIB(ORI-1)
[F:AMK2]POSBLOC(DEST-1) = [F:AMK]POSBLOC(ORI-1)
[F:AMK2]TYPBLOC(DEST-1) = [F:AMK]TYPBLOC(ORI-1)
[F:AMK2]TITBLOC(DEST-1) = [F:AMK]TITBLOC(ORI-1)
[F:AMK2]RANG(DEST-1)    = [F:AMK]RANG(ORI-1)
[F:AMK2]LINBLOC(DEST-1) = [F:AMK]LINBLOC(ORI-1)
[F:AMK2]INTBLOC(DEST-1) = [F:AMK]INTBLOC(ORI-1)
[F:AMK2]DETBLC(DEST-1)  = [F:AMK]DETBLC(ORI-1)
[F:AMK2]COLBLOC(DEST-1) = [F:AMK]COLBLOC(ORI-1)
[F:AMK2]OPTION(DEST-1)  = [F:AMK]OPTION(ORI-1)
[F:AMK2]NBLIGT(DEST-1)  = [F:AMK]NBLIGT(ORI-1)
[F:AMK2]ACTBLOC(DEST-1) = [F:AMK]ACTBLOC(ORI-1)
[F:AMK2]BASPAG(DEST-1)  = [F:AMK]BASPAG(ORI-1)
End

# supprime un bloc de l'ÃĐcran gÃĐnÃĐrÃĐ et diminue le nombre total de blocs de l'ÃĐcran
# Attention : Ã§a ne dÃĐcale pas les blocs situÃĐs aprÃĻs le bloc supprimÃĐ (Ã§a laisse des "trous")
Subprog RAZ_BLOC(DEST)
Value Integer DEST
Raz [F:AMK2]LNGLIB(DEST-1)
Raz [F:AMK2]POSBLOC(DEST-1)
Raz [F:AMK2]TYPBLOC(DEST-1)
Raz [F:AMK2]TITBLOC(DEST-1)
Raz [F:AMK2]RANG(DEST-1)
Raz [F:AMK2]LINBLOC(DEST-1)
Raz [F:AMK2]INTBLOC(DEST-1)
Raz [F:AMK2]DETBLC(DEST-1)
Raz [F:AMK2]COLBLOC(DEST-1)
Raz [F:AMK2]OPTION(DEST-1)
Raz [F:AMK2]NBLIGT(DEST-1)
Raz [F:AMK2]ACTBLOC(DEST-1)
Raz [F:AMK2]BASPAG(DEST-1)
[F:AMK2]NBBLOC -=1
End

######################################################################
## GÃĐnÃĐration de la fenÃŠtre
######################################################################

$TR2
GOK = 1
Trbegin [AWI], [AWP], [AWB], [AWT]
 Call DELWIN(NOMWIN,APPLI) From MSKDIV
 If GOK=-1 : Goto ROLL_TR2 : Endif

 If [F:TBU]ENAFLG=2
  Read [F:AWI]AWI0 = WINREF
  If !fstat
   [F:AWI]WIN       = NOMWIN
   [F:AWI]NOMMSK(0) = MASKDES
   [F:AWI]ENAFLG    = 2
   [F:AWI]MDL       = 1
   [F:AWI]TRN       = [F:TBU]BUDTYP
   [F:AWI]LIBEL     = [F:TBU]DES
   Write [AWI]
   If fstat
    GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR2
   Endif

   For [AWP] Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat
     GOK = 0 : Call FSTA("AWP") From GLOCK : Break
    Endif
   Next
   If GOK=0 : Goto AB_TR2 : Endif

   For [AWT] Where WIN=WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat
     GOK = 0 : Call FSTA("AWT") From GLOCK : Break
    Endif
   Next
   If GOK=0 : Goto AB_TR2 : Endif

   Read [F:AWB]AWB0 = WINREF
   If !fstat
    [F:AWB]WIN = NOMWIN
    Write [AWB]
    If fstat
     GOK = 0 : Call FSTA("AWB") From GLOCK : Goto AB_TR2
    Endif
   Endif

  Endif
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

######################################################################
## Transfert actions et paramÃĻtres
######################################################################

Subprog COPIE_ACTION(MASKORG,MASKDES,ZONE,ZONDES,I)
Value Char    MASKORG
Value Char    MASKDES
Value Char    ZONE
Value Char    ZONDES
Value Integer I
Local Integer K, FIN
Local Char C_EXP(250)

For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMA2] = [F:AMA]
 [F:AMA2]CODAFF = MASKDES
 [F:AMA2]CODZON = ZONDES
 Write [AMA2]
 If fstat
  GOK=0 : Call FSTA("AMA2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMP2] = [F:AMP]
 [F:AMP2]CODAFF = MASKDES
 [F:AMP2]CODZON = ZONDES
 # Le type de donnÃĐes MC1 a pour paramÃĻtre la devise du budget qui sera saisi sur la ligne
 # de sÃĐlection des critÃĻres LINSELCRI => [M:BCR]CUR([F:TBU]LINSELCRI)
 If left$([F:AMP]CODZON,3)="AMT" | left$([F:AMP]CODZON,4)="YAMT"
  [F:AMP2]VALPAR = evalue([F:AMP]VALPAR)
 Endif
 # On prend la devise de la premiÃĻre colonne trouvÃĐe dans la formule ?
 If left$([F:AMP]CODZON,6)="AMTFOR" | left$([F:AMP]CODZON,7)="YAMTFOR"
  C_EXP = [F:TBU0]COLEXP
  FIN = 0
  While !FIN
   K = instr(1,C_EXP,"C")
   If K=0 : Break : Endif
   K = val(right$(C_EXP,K+1))
   Read [TBU3]TBU0=[F:TBU0]BUDTYP;K
   If [F:TBU3]LINSELCRI<>0
    FIN=1 : Break
   Else
    C_EXP = [F:TBU3]COLEXP
   Endif
  Wend
  If FIN
   [F:AMP2]VALPAR = "[M:BCR]CUR("+num$([F:TBU3]LINSELCRI-1)+")"
  Else
   Call ERREUR(mess(9,108,1)) From GESECRAN : # Formule incorrecte
   GOK = 0 : Break
  Endif
 Endif
 # Le type de donnÃĐes QT1 a pour paramÃĻtre l'UOM de la nature qui sera saisi soit en entÃŠte
 # de l'ÃĐcran BUD, soit Ã  la ligne si c'est un budget par section
 If left$([F:AMP]CODZON,3)="QTY" | left$([F:AMP]CODZON,4)="YQTY"
  Case [F:TBU0]BUDCAT
   When 1,2 : [F:AMP2]VALPAR = "[M:BUD]UOMACC"
   When 3   : [F:AMP2]VALPAR = "[M:BUD]UOM(nolign-1)"
  Endcase
 Endif
 Write [AMP2]
 If fstat
  GOK=0 : Call FSTA("AMP2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
End

###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File TABBUDTYP  [TBU1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".TABBUDTYP"  [TBU1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABBUDTYP  [TBU2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".TABBUDTYP"  [TBU2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [TBU1], [TBU2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [TBU2]
 Delete [TBU2] Where BUDTYP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABBUDTYP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TBU2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TBU1] Where BUDTYP=TABLE
  [F:TBU2] = [F:TBU1]
  Call COPTEXTRA("TABBUDTYP","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("TABBUDTYP","SHOTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("TABBUDTYP","COLDESTRA",TABLE,num$([F:TBU1]COLNUM)) From ATEXTRA
    If dim([F:TBU2]UPDUSR)>0 : [F:TBU2]UPDUSR = GUSER : Endif
  If dim([F:TBU2]UPDDAT)>0 : [F:TBU2]UPDDAT = date$ : Endif
  Write [TBU2]
  If fstat
   GOK = 0 : Call FSTA("TBU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

################################################################################
## Etiquettes ÃĐcran TBU
################################################################################

Subprog AM_BUDCAT(VALEUR)
Variable Integer VALEUR
# Les pÃĐriodes sont toujours prÃĐchargÃĐes dans un budget par pÃĐriode
If VALEUR=1 : [M]LODFLG=2 : Endif
# Si on passe un budget en budget par section il faut que les quantitÃĐs soient non totalisÃĐes
If VALEUR<>3 : End: Endif
For I=0 To [M]NBLIG-1
 If find([M]COLTYP(I),1,3,5,7) & [M]TOT(I)=2
  [M]TOT(I) = 1
  Affzo [M]TOT(I)
 Endif
Next I
End

Subprog C_LODFLG(VALEUR)
Variable Integer VALEUR
If [M]BUDCAT=1 & VALEUR=1
 GMESSAGE = mess(57,108,1) : # PÃĐriodes toujours prÃĐ chargÃĐes dans un budget dÃĐtaillÃĐ
 mkstat = 2
Endif
End

Subprog AS_COLTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
# Le texte n'est affichÃĐ que pour les budget par pÃĐriode sinon il est grisÃĐ
If [M]BUDCAT<>1
 GMENLOC(10)=1
Endif
End

Subprog C_COLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=1 | VALEUR=2 | VALEUR=10
 [M]TYPSELCRI(nolign-1) = num$(VALEUR)+num$([M]LINSELCRI(nolign-1))
 Call UNICITE([M]TYPSELCRI(nolign-1),[M]TYPSELCRI) From OBJDIV
Endif
End

Subprog AS_COLEXP(VALEUR)
Variable Char     VALEUR
If [M]COLTYP(nolign-1)<>9 : # Expression saisissable uniquement si formule
 mkstat=1
Endif
End

Subprog C_COLEXP(VALEUR)
Variable Char    VALEUR()
Local    Integer J,K
Local    Char    CAR
If [M]COLTYP(nolign-1)=9 : # Formule
 If VALEUR=""
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat   = 2
  End
 Endif
 J=1
 While J<=len(VALEUR)
  CAR = mid$(VALEUR,J,1)
  If !instr(1,"0123456789C-*+/.() ",CAR)
   GMESSAGE = mess(9,108,1) : # Formule incorrecte
   mkstat   = 2
   Break
  Endif
  If CAR="C"
   K = val(right$(VALEUR,J+1))
   If K=0
    GMESSAGE = mess(37,124,1) : # Expression incorrecte
    mkstat = 2 : Break
   Elsif K>nolign-1
    GMESSAGE = mess(61,108,1) : # Les colonnes doivent prÃĐcÃĐder la colonne formule
    mkstat = 2 : Break
   Elsif [M]COLTYP(K-1)>9
    GMESSAGE = mess(62,108,1) : # Pas de colonne texte dans la formule
    mkstat = 2 : Break
   Elsif ([M]COLTYP(K-1)=9 & [M]COLSAIAFF(K-1)=1)
    GMESSAGE = mess(63,108,1) : # Pas de colonne formule invisible dans la formule
    mkstat = 2 : Break
   Else
    J +=1
    While J<=len(VALEUR) & instr(1,"0123456789",mid$(VALEUR,J,1))
     J +=1
    Wend
   Endif
  Else J +=1
  Endif
 Wend
Endif
End

Subprog AS_LINSELCRI(VALEUR)
Variable Decimal VALEUR
If [M]COLTYP(nolign-1)=9 : # Le type "Formule" ne fait pas rÃĐfÃĐrence Ã  un budget
 VALEUR = 0
 mkstat = 2
Endif
End

Subprog C_LINSELCRI(VALEUR)
Variable Decimal VALEUR
Local    Integer I
If VALEUR=0 & [M]COLTYP(nolign-1)<>9 : # LINSELCRI=0 uniquement si colonne de type Formule
 GMESSAGE = mess(10,123,1)           : # Zone obligatoire
 mkstat   = 2
 End
Endif
If [M]COLTYP(nolign-1)=1 | [M]COLTYP(nolign-1)=2 | [M]COLTYP(nolign-1)=10
 [M]TYPSELCRI(nolign-1) = num$([M]COLTYP(nolign-1))+num$(VALEUR)
 Call UNICITE([M]TYPSELCRI(nolign-1),[M]TYPSELCRI) From OBJDIV
 If mkstat=2 : End : Endif
Endif
For I=1 To VALEUR-1
 If !find(I,[M]LINSELCRI(0..[M]NBLIG-1))
  GMESSAGE = mess(89,108,1) : # Il ne doit pas y avoir de trous dans la numÃĐrotation des lignes
  mkstat = 2
  Break
 Endif
Next I
End

Subprog AS_TOT(VALEUR)
Variable Integer VALEUR
# Zones non susceptibles d'avoir des totaux : texte + QtÃĐ pour budget par section
If [M]COLTYP(nolign-1)=10 | ([M]BUDCAT=3 & find([M]COLTYP(nolign-1),1,3,5,7))
 VALEUR = 1
 mkstat = 2
Endif
End

Subprog C_TOT(VALEUR)
Variable Integer VALEUR
Local    Integer NB, J, K, L
# Pas plus de 4 totaux en bas d'ÃĐcran pour les quantitÃĐs, les montants, les formules
If VALEUR=2
 Case [M]COLTYP(nolign-1)
  When 1, 3, 5, 7 : K = 1  : # QuantitÃĐs
  When 2, 4, 6, 8 : K = 2  : # Montant
  When 9          : K = 9  : # Formules
 Endcase
 NB = 1
 For J=0 To [M]NBLIG-1
  Case [M]COLTYP(J)
   When 1, 3, 5, 7 : L = 1  : # QuantitÃĐs
   When 2, 4, 6, 8 : L = 2  : # Montant
   When 9          : L = 9  : # Formules
   When Default    : L = -1 : # il ne reste que Texte
  Endcase
  If K=L & [M]TOT(J)=2 & J<>nolign-1
   NB +=1
  Endif
 Next J
 If NB>4
  GMESSAGE = mess(69,108,1) : # 4 totaux au maximum
  mkstat = 2
  End
 Endif
Endif
End

Subprog AV_COLEXP2(VALEUR)
Variable Char    VALEUR()
Local Char COLEXPR(250)
Local Integer P,NOCOL
If [M]NOMZON(nolign-1)="AMTFOR"
 Raz P, NOCOL,COLEXPR
 While P<=dim([M]COLEXP(nolign-1))
  If mid$([M]COLEXP(nolign-1),P,1)="C"
   NOCOL  = val(right$([M]COLEXP(nolign-1),P+1))
   If NOCOL<>0
    COLEXPR += "[M]"+[M]NOMZON(NOCOL-1)+num$(NOCOL)+"(nolign-1)"
    If NOCOL>9 : P +=3 : Else : P +=2 : Endif
   Else
    COLEXPR +=mid$([M]COLEXP(nolign-1),P,1)
    P +=1
   Endif
  Else
   COLEXPR +=mid$([M]COLEXP(nolign-1),P,1)
   P +=1
  Endif
 Wend
 VALEUR = COLEXPR
Endif
End

Subprog AV_NOMZON(VALEUR)
Variable Char    VALEUR()
Case [M]COLTYP(nolign-1)
 When 1  : VALEUR = "QTY"     : # QtÃĐ
 When 2  : VALEUR = "AMT"     : # Mt
 When 3  : VALEUR = "QTYREA"  : # QtÃĐ rÃĐelle
 When 4  : VALEUR = "AMTREA"  : # Mt rÃĐel
 When 5  : VALEUR = "QTYCMM"  : # QtÃĐ engagÃĐe
 When 6  : VALEUR = "AMTCMM"  : # Mt engagÃĐ
 When 7  : VALEUR = "QTYPRP"  : # QtÃĐ prÃĐ engagÃĐÃĐ
 When 8  : VALEUR = "AMTPRP"  : # Mt prÃĐ engagÃĐÃĐ
 When 9  : VALEUR = "AMTFOR"  : # Formule
 When 10 : VALEUR = "TEXPER"  : # Texte
Endcase
End

# Mise Ã  jour du COLNUM en cas d'insertion de ligne ds le tableau
# pour bien gÃĐrer les intitulÃĐs traduisibles
Subprog AS_COLDESTRA(VALEUR)
Variable Char    VALEUR()
If [M]COLNUM(nolign-1)=0
 [M]COLNUM(nolign-1) = max([M]COLNUM)+1
Endif
End



#######################################################################################

Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)
If func AFNC.ACTIV("LEG")=0
 Call CNTCOHGRPLEG(VALEUR,GDOSLEG(1),STAT,MESSA) From CPTCNT
Else
 Call CNTCOHGRPLEG(VALEUR,[M]LEG,STAT,MESSA) From CPTCNT
Endif
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End


