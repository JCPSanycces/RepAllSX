Subprog C_NBRKIT
Local Integer I , OK
If find(status,68,65,83) : # Suppression ligne
 If nolign1=0 : nolign1 = nolign : Endif
 If find(2,[M]INSTAL(nolign-1..nolign1-1))
  GMESSAGE = mess(267,125,1) : # Kit impossible à supprimer
  mkstat = 1 : End
 Endif
Endif
End

Subprog IB_NBRKIT
If [M:ADS0]DOSSIER=GDOSX3
 Raz GBOUT2
Elsif nolign>0 & [M]ENAFLG(nolign-1)=2
 Raz GBOUT2
Endif
End

Subprog C_CODKIT(VALEUR)
Variable Char VALEUR
Local Integer ASTATUS , OK
Call UNICITE(VALEUR,[M]CODKIT(0..[M]NBRKIT-1)) From OBJDIV
If mkstat : End : Endif
If [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_KIT(VALEUR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le kit "$1$"
  GMESSAGE = func AFNC.MES1(mess(269,125,1),VALEUR)
  mkstat = 1 : End
 Endif
Endif
If [M:ADS0]DOSSIER<>GDOSX3 & [M:ADS1]DOSREF<>GDOSX3
 Read [ADK]ADK0=[M:ADS1]DOSREF;VALEUR
 If fstat
  # Kit non géré dans le dossier $1$
  Call AVERTIR(VALEUR+":"-func AFNC.MES1(mess(272,143,1),[M:ADS1]DOSREF),OK) From GESECRAN
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
Endif
End

Subprog AM_CODKIT(VALEUR)
Variable Char    VALEUR()
Local Integer I , J , ASTATUS
Local Char    TBLIV(GLONADLV)(1..10)
ASTATUS = func ASYRLICFOL.GETPOLICY(TBLIV)
For I=1 To dim(TBLIV)
 If TBLIV(I)<>""
  Read [ADLV]ADLV0=TBLIV(I)
  If !fstat
   J = find(VALEUR,[F:ADLV]ITYKIT)
   If J
    [M]ROWKIT(nolign-1) = [F:ADLV]ITYKITROW(J-1)
    Break
   Endif
  Endif
 Endif
Next I
End

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Char    VALPAR , PARAM(30)(1..3)
Local Integer OK , MAJ
If VALEUR=2 & nolign>0 & [M]ENAFLG(nolign-1)<>VALEUR & [M:ADS0]DOSSIER<>GDOSX3
 If [M:ADS1]DOSREF<>GDOSX3
  Read [ADK]ADK0=[M:ADS1]DOSREF;[M]CODKIT(nolign-1)
  If fstat or [F:ADK]INSTAL<>2
   # Kit non installé dans le dossier $1$
   Call AVERTIR([M]CODKIT(nolign-1)+":"-func AFNC.MES1(mess(272,143,1),[M:ADS1]DOSREF),OK) From GESECRAN
   If OK<>2 : mkstat = 1 : End : Endif
  Endif
 Endif
 Local Mask ADS005 [ADS55]
 MAJ = 0
 Call KITACVUPD([M:ADS5]CODKIT(nolign-1),[M:ADS0]DOSSIER,[M:ADS1]DOSREF,MAJ)
 If [M:ADS55]NBRDEF>0
  # L'activation de ce kit va modifier les valeurs des codes activités. Etes-vous sûr de continuer ?
  [M:ADS55]MESSAGE = mess(277,125,1)
  # Codes activités modifiés
  OK = 1 : Call DIALWIN(OK,mess(278,125,1),"OADS5") From GESECRAN
  If OK<>2 : VALEUR = 1 : mkstat = 1 : End : Endif
 Endif
Endif
If VALEUR=1 & nolign>0 & [M]ENAFLG(nolign-1)<>VALEUR
 OK = 1
 If [M:ADS0]DOSSIER=GDOSX3
  OK = 0
 Else
  Read [ADK]ADK0=[M:ADS0]DOSSIER;[M]CODKIT(nolign-1)
  If !fstat & [F:ADK]INSTAL=2
   OK = 0
  Endif
 Endif
 If !OK
  GMESSAGE = mess(267,125,1) : # Kit impossible à supprimer
  VALEUR = 2 : mkstat = 2 : End
 Endif
Endif
End

Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer OK , MAJ
Local Char    CODKIT(GLONADLK) , DOSSIER(GLONADS) , DOSREF(GLONADS)
If VALEUR=2 and nolign>0  and [M:ADS0]DOSSIER<>GDOSX3
 Local Mask ADS005 [ADS55]
 MAJ = 1
 Call KITACVUPD([M:ADS5]CODKIT(nolign-1),[M:ADS0]DOSSIER,[M:ADS1]DOSREF,MAJ)
 If [M:ADS55]NBRDEF>0
  Affzo [ADS6]
  Affzo [ADS2]
 Endif
Endif
End

