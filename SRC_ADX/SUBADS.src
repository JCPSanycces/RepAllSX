Subprog AS_FLACT1(VALEUR)
Variable Integer VALEUR
Local Char ACTION(30)
Local Integer K
Case [M]CODACT1(nolign-1)
 When "ABI"
 #87108
#  Call NOMBRA(12,K) From GLOCK
#  If mod(K,8)<4
#   VALEUR = 1 : mkstat = 2 : End
#  Endif
  If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("ABI")=[V]CST_AFALSE
   VALEUR = 1 : mkstat = 2 : End
  Endif
 When "LEG"
#87108
#  Call NOMBREB(2,K) From GLOCK
#  If !K
#   If [M:ADS4]NBLEG>1
#    Call OKDOS([M:ADS0]DOSSIER,[M:ADS1]VOLUME,K)
#    If K : # Le dossier existe
#     VALEUR = 2
#    Else
#     VALEUR = 1
#    Endif
#   Else
#    VALEUR = 1
#   Endif
#   mkstat = 2 : End
#  Endif
  If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("LEG")=[V]CST_ATRUE
   End
  Endif
  If [M:ADS4]NBLEG>1
   Call OKDOS([M:ADS0]DOSSIER,[M:ADS1]VOLUME,K)
   If K : # Le dossier existe
    VALEUR = 2
   Else
    VALEUR = 1
   Endif
  Else
   VALEUR = 1
  Endif
  mkstat = 2 : End
 When "APRX3"
#87108
#  Call NOMBRA(11,K) From GLOCK
#  If K=6 : # X2
#   VALEUR = 1 : mkstat = 2 : End
#  Else : # X3
#   VALEUR = 2 : mkstat = 2 : End
#  Endif
  If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("APRX3")=[V]CST_AFALSE
   VALEUR = 1 : mkstat = 2 : End
  Else
   VALEUR = 2 : mkstat = 2 : End
  Endif
 # FGR 08/01/2016 : X3SUIVI108843 (début) - ne plus faire
  # When "LTA"
  #  Local Integer KUS
  #  KUS = find("KUS",[M]CODACT2(0..[M]NBLIG2-1))
  #  If !KUS or [M]FLACT2(KUS-1)<>2
  #   VALEUR = 1 : mkstat =2 : End
  #  Endif
 # FGR 08/01/2016 : X3SUIVI108843 (fin) - ne plus faire
Endcase
ACTION = "AS_FLACT1" : Gosub BACTION
End

Subprog C_FLACT1(VALEUR)
Variable Integer VALEUR
Local Char ACTION(30)
Local Integer ASTATUS , K , NOL , DIME , VLR
If VALEUR=2 & [M:ADS1]DOSREF<>GDOSX3
 Read [ADA]ADA0 = [M:ADS1]DOSREF;[M]CODACT1(nolign-1)
 If fstat or [F:ADA]FLACT<>2
  Call ERREUR(mess(137,125,1)) From GESECRAN : # Code activité inactif dans le dossier de référence
  mkstat = 1 : End
 Endif
Endif
If VALEUR=1 & [M]CODACT1(nolign-1)="LEG" & [M:ADS4]NBLEG>1
 Call OKDOS([M:ADS0]DOSSIER,[M:ADS1]VOLUME,K)
 If K : # Le dossier existe
  Call ERREUR(mess(176,125,1)) From GESECRAN : # Trop de législations
  mkstat = 1 : End
 Endif
Endif
If VALEUR=2 & [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M]CODACT1(nolign-1),[M:ADS0]DOSSIER,[L]DIME,[L]VLR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  Call ERREUR(func AFNC.MES1(mess(270,125,1),[M]CODACT1(nolign-1))) From GESECRAN
  mkstat = 1 : End
 Endif
Endif
ACTION = "C_FLACT1" : Gosub BACTION
End

Subprog C_FLACT2(VALEUR)
Variable Integer VALEUR
Local Char ACTION(30)
Local Integer ASTATUS , DIME , VLR
If VALEUR=2 & [M:ADS1]DOSREF<>GDOSX3
 Read [ADA]ADA0 = [M:ADS1]DOSREF;[M]CODACT2(nolign-1)
 If fstat or [F:ADA]FLACT<>2
  Call ERREUR(mess(137,125,1)) From GESECRAN : # Code activité inactif dans le dossier de référence
  mkstat = 1 : End
 Endif
Endif
If VALEUR=2 & [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M]CODACT2(nolign-1),[M:ADS0]DOSSIER,[L]DIME,[L]VLR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  Call ERREUR(func AFNC.MES1(mess(270,125,1),[M]CODACT2(nolign-1))) From GESECRAN
  mkstat = 1 : End
 Endif
Endif
ACTION = "C_FLACT2" : Gosub BACTION
End

