Call CALLNG(VALEUR,[M]CLBTXT)
Affzo CLBTXT
End

Subprog CALLNG(LNG,TXT)
Value    Integer LNG
Variable Char    TXT()
Local Decimal TAILLE
TAILLE = 2^LNG
If TAILLE<1024
 TXT = num$(TAILLE)-"Ko"
Elsif TAILLE<1024*1024
 TXT = num$(TAILLE/1024)-"Mo"
Else
 TXT = num$(TAILLE/(1024*1024))-"Go"
Endif
TXT = "("+TXT+")"
End

