Subprog AS_NBRMOD
Local Integer I , ASTATUS , VLR , PRESENT
Local Char    ACTION(30)
If [ADS1]NBRMOD=0
 Read [ADS2]DOSSIER = [M:ADS1]DOSREF
 PRESENT = !fstat
 [M:ADS1]NBRMOD = len(mess(0,14,1))
 For I=1 To len(mess(0,14,1))
  If left$(mess(I,14,1),1)="#"
   [M:ADS1]NBRMOD = I-1
   Break
  Endif
  [M:ADS1]LIBMOD(I-1) = I
  If [M:ADS1]DOSREF=[M:ADS0]DOSSIER : # mb 14.4.2 bug 13921
   [M:ADS1]AUTMOD(I-1) = 2
   [M:ADS1]MODULE(I-1) = 2
  Else
   ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(I),VLR)
   If ASTATUS<>CST_ATRUE or !PRESENT or [F:ADS2]MODULE(I-1)<>2
    [M:ADS1]AUTMOD(I-1) = 1
    [M:ADS1]MODULE(I-1) = 1
   Else
    [M:ADS1]AUTMOD(I-1) = 2
    If VLR<>0
     [M:ADS1]MODULE(I-1) = VLR
    Else
     [M:ADS1]MODULE(I-1) = [F:ADS2]MODULE(I-1)
    Endif
   Endif
  Endif
 Next I
 For I=1 To len(mess(0,14,1))
  If left$(mess(I,14,1),1)="#"
   [M:ADS1]AUTMOD(I-1) = 1
   [M:ADS1]MODULE(I-1) = 1
  Endif
 Next I
 For I=min(len(mess(0,14,1)),dim([M:ADS1]MODULE))+1 To dim([M:ADS1]MODULE)
  [M:ADS1]AUTMOD(I-1) = 1
  [M:ADS1]MODULE(I-1) = 1
 Next I
 ACTION = "AS_MODULE" : Gosub BACTION
 Affzo [ADS1]LIBMOD , MODULE
Endif
End

Subprog C_MODULE(VALEUR)
Variable Integer VALEUR
Local Char ACTION(30)
If VALEUR=2 & [M]AUTMOD(nolign-1)<>2
 GMESSAGE = mess(58,125,1)-[M]DOSREF : # Module non implanté dans le dossier
 mkstat = 2 : End
Endif
Local Integer ASTATUS , VLR
If VALEUR=2 & [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(nolign),VLR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le module "$1$"
  GMESSAGE = func AFNC.MES1(mess(268,125,1),mess(nolign,14,1))
  mkstat = 1 : End
 Endif
Endif
ACTION = "C_MODULE" : Gosub BACTION
If VALEUR<>[M]MODULE(nolign-1) : GMODIF = 1 : Endif
End

Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
Local Char ACTION(20)
ACTION = "AVSAI_MODULE" : Gosub BACTION
End

