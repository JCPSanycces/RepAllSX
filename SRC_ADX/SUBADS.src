Subprog C_DOSLEG(VALEUR)
Variable Char    VALEUR()
Local Integer ASTATUS
Call UNICITE(VALEUR,[M]DOSLEG(0..[M]NBLEG-1)) From OBJDIV
If mkstat : End : Endif
If [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_LEGISLATION(VALEUR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la législation "$1$"
  GMESSAGE = func AFNC.MES1(mess(272,125,1),VALEUR)
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_NBLEG
Local Integer K , OK , ER , NBLEG
Local Char CHAINE(250) , TBLEG(GLONADI)(1..dim(GDOSLEG))
K = find("LEG",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If K>0 & [M:ADS6]FLACT1(K-1)<>2 & [M]NBLEG>=1
 If find(status,73,82) : # Insertion/Rajout
  mkstat = 1 : End
 Endif
Endif
If find(status,68,65,83) : # Couper/Suppressions
 If nolign1=0 : nolign1 = nolign : Endif
 OK = 1
 Call SETLEG([M]DOSSIER,TBLEG,NBLEG) From DOSCONT
 For K=1 To NBLEG
  If find(TBLEG(K),[M]DOSLEG(nolign-1..nolign1-1))
   OK = 0 : Break
  Endif
 Next K
 If !OK
  GMESSAGE = mess(177,125,1) : # Législation impossible à supprimer
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_CHGCOD(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR="" : End : Endif
VALEUR = toupper(VALEUR)
If [M:ADS1]DOSREF<>"" & filinfo(filpath("FIL","ACHANGE","fde",[M:ADS1]DOSREF),0)>0
 If [M:ADS1]DOSREF=nomap
  Local File ACHANGE [ACG]
 Else
  Local File =[M:ADS1]DOSREF+".ACHANGE" [ACG]
 Endif
 CRITERE = "ENAFLG=2"
 If instr(1,VALEUR,"?") or instr(1,VALEUR,"*")
  CRITERE -= '& pat(COD,"'+VALEUR+'")'
 Else
  CRITERE -= '& left$(COD,'+num$(len(VALEUR))+')="'+VALEUR+'"'
 Endif
 K = 0
 For [ACG] Where evalue(CRITERE)
  K += 1 : Break
 Next ACG
 If !K
  GMESSAGE = mess(232,115,1) : # Aucun code correspond à ce critère
  mkstat = 1 : End
 Endif
Endif
End

