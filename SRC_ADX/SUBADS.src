Subprog AS_NBLIG
If [M:ADS4]NBLIG=0
 [M:ADS4]NBLIG = len(mess(0,26,1))
 Local Integer I
 For I=0 To [M:ADS4]NBLIG-1
  [M:ADS4]LIBCOP(I) = I+1
  [M:ADS4]OPTINI(I) = 2
 Next I
 Affzo [ADS4]LIBCOP , OPTINI
Endif
End

Subprog AS_NBTR
Local Integer I , K
If [M:ADS4]NBTR=0
 [M:ADS4]NBTR = len(mess(0,14,1))
 For I=0 To [M:ADS4]NBTR-1
  [M:ADS4]MODTR(I) = I+1
  If [M:ADS1]MODULE(I)=2
   [M:ADS4]TRVAL(I) = 2
  Else
   [M:ADS4]TRVAL(I) = 1
  Endif
 Next I
 Affzo [ADS4]MODTR , TRVAL
Else
 K = 0
 For I=0 To [M:ADS4]NBTR-1
  If [M:ADS1]MODULE(I)<>2 & [M:ADS4]TRVAL(I)=2
   K = 1
   [M:ADS4]TRVAL(I) = 1
  Endif
 Next I
 If K
  Affzo [ADS4]TRVAL
 Endif
Endif
End

Subprog AS_TRVAL(VALEUR)
Variable Integer VALEUR
If [M:ADS1]MODULE(nolign-1)<>2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog C_OPTINI(VALEUR)
Variable Integer VALEUR
Local Char ACTION(30)
ACTION = "C_OPTINI" : Gosub BACTION
End

$SEL_OPTINI
Local Integer NOL
NOL = nolign
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
For [ATB] Where CRE=3 & OPT=NOL
 NBTEX += 1
 Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
 TEX(NBTEX) = [F:ATB]CODFIC-TEXTE
Next ATB
Close Local File [ATB]
Return

Subprog C_NBRLAN
Local Integer OK , I
If nolign>0 & find(status,68,65,83) : # Couper/Suppressions
 If nolign1=0 : nolign1 = nolign : Endif
 OK = 1
 For [ADS]DOSSIER Where DOSSIER<>[M:ADS0]DOSSIER & find([M:ADS0]DOSSIER,[F]DOSREF,[F]DOSCOP)<>0
  For I=nolign To nolign1
   If [M]LAN(I-1)<>"" & find([M]LAN(I-1),[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
    OK = 0 : Break 2
   Endif
  Next I
 Next ADS
 If !OK
  # La langue $1$ est utilisée dans le dossier fille $2$
  OK = 1
  Call AVERTIR(func AFNC.MES2(mess(237,125,1),[M]LAN(I-1),[F:ADS]DOSSIER),OK) From GESECRAN
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
Endif
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
Local Integer ASTATUS , OK
Call UNICITE(VALEUR,[M]LAN(0..[M]NBRLAN-1)) From OBJDIV
If mkstat : End : Endif
If [M:ADS0]DOSSIER<>GDOSX3
 Read [ADS]DOSSIER=[M:ADS1]DOSREF
 If !fstat & !find(VALEUR,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  # La langue $1$ n'existe pas dans le dossier de référence $2$
  Call AVERTIR(func AFNC.MES2(mess(235,125,1),VALEUR,[M:ADS1]DOSREF),OK) From GESECRAN
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
 Read [ADS]DOSSIER=[M:ADS1]DOSCOP
 If !fstat & !find(VALEUR,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  # La langue $1$ n'existe pas dans le dossier de copie $2$
  Call AVERTIR(func AFNC.MES2(mess(236,125,1),VALEUR,[M:ADS1]DOSCOP),OK) From GESECRAN
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
 ASTATUS = func ASYRLICFOL.ACTIVE_LANGUAGE(VALEUR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la langue "$1$"
  GMESSAGE = func AFNC.MES1(mess(271,125,1),VALEUR)
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_LANDEF(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M]LAN(0..[M]NBRLAN-1))
 GMESSAGE = mess(53,150,1) : # Langue non définie pour le dossier à générer
 mkstat = 2 : End
Endif
If [M:ADS1]DOSCOP=nomap | [M:ADS1]DOSCOP=""
 If clalev([F:TLA])=0 : Local File TABLAN [TLA] : Endif
Else
 Local File =[M:ADS1]DOSCOP+".TABLAN" [TLA]
Endif
Call CONTROLE("TLA","",VALEUR,"",mkstat) From CONTOBJ
Close Local File [TLA]
End

Subprog C_LANREF(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=2
  For [ADS]
    If [F:ADS]DOSSIER<>[M:ADS0]DOSSIER
      For I=0 To [F:ADS]NBRLAN-1
        If [F:ADS]LAN(I)=[M:ADS4]LAN(nolign-1) and [F:ADS]LANREF(I)=2
          # La langue $1$ est déjà la langue de référence dans le dossier $2$
          GMESSAGE = func AFNC.MES2(mess(276,123,1),[M:ADS4]LAN(nolign-1),[F:ADS]DOSSIER)
          mkstat = 2 : Break 2
        Endif
      Next I
    Endif
  Next
Endif
End

