Subprog AS_CODDBA(VALEUR)
Variable Integer VALEUR
End

Subprog C_CODDBA(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local File ADOSSIER [AD_]
Read [AD_]DOSSIER=GDOSX3
If !fstat
 If VALEUR<[F:AD_]CODDBA
  # Etes-vour sûr de vouloir créer ce dossier en format # ?
  Call AVERTIR(func AFNC.MES(mess(150,125,1),mess(1,930,1)),OK) From GESECRAN
  If OK<>2 : mkstat = 2 : Endif
 Endif
Endif
Close Local File [AD_]
End

