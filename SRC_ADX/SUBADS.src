#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion de dossier
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = "SUPERV"
Call OBJET("ADS",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBADSB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "AP_ANNULE"    : Gosub MAJFOLDA
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_CRE"    : Gosub APRES_CRE
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "EFFMASK"      : Gosub EFFMASK
 When "ABANDON"      : Gosub ABANDON
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "FERME"        : Gosub FERME
 When "STYLE"        : Gosub STYLE
 When "STATUT"       : Gosub STATUT
 When "TITRE"        : Gosub TIT
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "FIN_LISTE"    : Gosub FIN_LISTE
 When "TRT_DIV"      : Gosub TRT_DIV
 When Default
Endcase
If PSUBB
 Gosub ACTION From SUBADSB
Endif
Return

#-----------------------#
$BACTION
Local Integer OKTRT
Call EXISTE_ADX("","","SUBADSB",OKTRT) From ORDSYS
If OKTRT>0
 Gosub ACTION From SUBADSB
Endif
Return

#-----------------------------------------#
$OUVRE
Gosub DEFVAR
If clalev([F:ATX])=0   : Local File ATEXTE              [ATX]  : Endif
If clalev([F:ACV])=0   : Local File ACTIV               [ACV]  : Endif
If clalev([F:ADM])=0   : Local File ADIMENSION          [ADM]  : Endif
If clalev([F:ADA])=0   : Local File ADOSACT             [ADA]  : Endif
If clalev([F:ADE])=0   : Local File ADOSDIM             [ADE]  : Endif
If clalev([F:AC2])=0   : Local File =GDOSX3+".ACTIV"    [AC2]  : Endif
If clalev([F:AD2])=0   : Local File ADOSACT             [AD2]  : Endif
If clalev([F:ADS2])=0  : Local File ADOSSIER            [ADS2] : Endif
If clalev([F:ADD])=0   : Local File ADOSSOL             [ADD]  : Endif
If func APRODUCT.AGETRELEASESUP()>="17v.132"
 If clalev([F:ADK])=0  : Local File ADOSLIV             [ADK]  : Endif
 If clalev([F:ADLV])=0 : Local File =GDOSX3+".ADELIVER" [ADLV] : Endif
Endif
GMODIF = 0
Return

#-----------------------------------------#
$SETBOUT
If CLECUR=0 or REP="M" or !VERROU or nomap<>GDOSX3
 Call VIREBOUT(CHAINE,"V") From GOBJET
Elsif nomap=GDOSX3
 CHMEN = sum(CMEN) : # (1)Importer, (2)Trace, (3)Taille
Endif
If CLECUR1=GDOSX3 or CLECUR1=nomap
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If [M]TYPDBA<>GTYPDBA or CLECUR1=nomap
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
#If GPRODUIT=-1 & GUSER<>"MB" : # Validation de dossier trop galère en interactif -> batch, c'est mieux
If GPRODUIT=-1 & find(GUSER,"VPO","MB","SD","CCL")=0 : # Validation de dossier trop galère en interactif -> batch, c'est mieux
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
If [F:ADS]TRCFIL="" or filinfo(filpath("TRA",[F:ADS]TRCFIL,"tra",0),0)<0
 Call VIREBOUT(CHMEN,"2") From GOBJET
Endif
If [F:ADS]DOSHIS="" or [F:ADS]TRCFILHIS="" or filinfo(filpath("TRA",[F:ADS]TRCFILHIS,"tra",0),0)<0
 Call VIREBOUT(CHMEN,"6") From GOBJET
Endif
If filinfo(filpath("","","",CLECUR1,[M:ADS1]VOLUME),0)>=0 or nomap<>GDOSX3
 Call VIREBOUT(CHAINE,"H") From GOBJET
Endif
If instr(1,CHAINE,"V") or instr(1,CHAINE,"M")
 Call OKDOS(CLECUR1,[M:ADS1]VOLUME,K)
 If K<=0
  Call VIREBOUT(CHAINE,"VM") From GOBJET
 Endif
Endif
If instr(1,CHAINE,"M") & !GSOPHIA & CLECUR1=GDOSX3 & left$(CLECUR1,5)<>"REPOS"
 #Call VIREBOUT(CHAINE,"M") From GOBJET
Endif
If GDOSX3<>nomap
 Call VIREBOUT(CHMEN,"45") From GOBJET
Endif
If filinfo(filpath("","BATCH","tmp",GDOSX3,""),0)<0
 Call VIREBOUT(CHMEN,"4") From GOBJET
Endif
Return

#-----------------------------------------------#
$STYLE
If !GSOPHIA & CLECUR1=GDOSX3 & left$(CLECUR1,5)<>"REPOS"
    # X3-112339 due to a change in behavior (responsive design+ runtime focus)
    # we changed the grizo by diszo.
    # october 2018 for 2018R08
    # but no solution on tunnel .. the focus after the tunnel will be on a edit field.
    #
    Diszo [ADS1]1-99
    Diszo [ADS5]1-99
    Diszo [ADS6]1-99
    Diszo [ADS2]1-99
    Diszo [ADS3]1-99
    Diszo [ADS4]1-99
Else
    Actzo [ADS1]1-99
    Actzo [ADS5]1-99
    Actzo [ADS6]1-99
    Actzo [ADS2]1-99
    Actzo [ADS3]1-99
    Actzo [ADS4]1-99
    If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0 : # Dossier existant
        Gosub GRISE
    Else
        Gosub ACTZONE
        Call GRISE_TYPDBA([M:ADS1]TYPDBA)
    Endif
Endif
If [M:ADS0]DOSSIER=nomap or nomap=GDOSX3
     Actzo [ADS9]10-20
Else
     Grizo [ADS9]10-20
Endif
Return

#-----------------------------------------#
$AVANTBOUT
Case BOUT
 When "2"
    Read [ADS]DOSSIER = [M]DOSSIER
    If !fstat & [F:ADS]TRCFIL<>""
     Return
    Endif
    GERR=1
    GMESSAGE=mess(287,125,1)
    Return
 When "6"
    Read [ADS]DOSSIER = [M]DOSSIER
    If !fstat
     If [F:ADS]DOSHIS=""
      GERR=1
      GMESSAGE=mess(208,133,1)
      Return
     Elsif [F:ADS]TRCFILHIS<>""
      Return
     Endif
    Endif
    GERR=1
    GMESSAGE=mess(287,125,1)
    Return
 When "V"
  If clalev([F:AOX])>0 : Close Local File [AOX] : Endif
  If clalev([F:ALS])>0 : Close Local File [ALS] : Endif
  If clalev([F:AWI])>0 : Close Local File [AWI] : Endif
  If clalev([F:ACC])>0 : Close Local File [ACC] : Endif
  If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
  If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
Endcase
Return

#-----------------------------------------#
$EXEBOUT
Case BOUT
 When "V"
  If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
  If clalev([F:ALS])=0 : Local File ALSTRD   [ALS] : Endif
  If clalev([F:AWI])=0 : Local File AWINDOW  [AWI] : Endif
  If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
Endcase
Return

#-----------------------------------------#
Subprog OKDOS(DOSSIER,VOLUME,OK)
Value Char DOSSIER , VOLUME
Variable Integer OK
Local Integer ER
OK = 1
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER,VOLUME),0)>0
&| filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 Onerrgo ERRDOS
 Local File =DOSSIER+".ADOVAL" [AD__]
 Read [AD__]ADW0 = "";"";"TYPDOS"
 If ER
  OK = -1
 Elsif !fstat & val([F:AD__]VALEUR)-1<>GPRODUIT
  OK = 0
 Endif
 Close Local File [AD__]
 Onerrgo
Endif
End

$ERRDOS
ER = errn
Resume

#-----------------------------------------#
Subprog NEWACT(DOSSIER,NEWACT)
Value Char DOSSIER
Variable Integer NEWACT
Local Integer ER
Onerrgo ERRDOS
NEWACT = 0
Read [ADS2]DOSSIER=[L]DOSSIER
If fstat : End : Endif
For [AC2]
 If [F:ADS2]MODULE([F:AC2]MODULE-1)=2
  Read [AD2]ADA0 = [L]DOSSIER;[F:AC2]CODACT
  If fstat
   NEWACT = 1 : Break : # Nouveau code activité standard
  Endif
 Endif
Next AC2
If NEWACT : End : Endif
If filinfo(filpath("FIL","ACTIV","fde",[L]DOSSIER),0)>0
 Local File =[L]DOSSIER+".ACTIV" [ACX]
 For [ACX] Where CODACT>="X"
  If [F:ADS2]MODULE([F:ACX]MODULE-1)=2
   Read [AD2]ADA0 = [L]DOSSIER;[F:ACX]CODACT
   If fstat
    NEWACT = 1 : Break : # Nouveau code activité spécifique
   Endif
  Endif
 Next ACX
 Close Local File [ACX]
Endif
If ER : NEWACT = 0 : Endif
End

#-----------------------------------------#
$STATUT
Case BOUT
 When "1"
  Gosub RELIT From GOBJSUB
Endcase
Return

#-----------------------------------------#
$EFFMASK
Case ABMSK(MA)
 When "ADS1" : #[M:ADS1]NBRMOD = len(mess(0,14,1)) : Affzo [ADS1]
 When "ADS2" : #Gosub CHARGE_ACV : Affzo [ADS2]
 When "ADS3" : Gosub CHARGE_DIM : Gosub INIT_DIM : Affzo [ADS3]
 When "ADS4" : #Affzo [ADS4]
 When "ADS9" : #Gosub CHARGE_LIEN : Affzo [ADS9]
Endcase
Return

#-----------------------------------------#
$ABANDON
Actzo [ADS1]SIZDAT, SIZIDX , GRPFIL
Return

#----------------------#
$INICRE
If dim([F:ADS]CODORA)>0
 [F:ADS]CODORA = ""
Endif

#----------------------#
$INIMOD
## Paramètres systèmes
[F:ADS]SYSPAR(0) = [M:ADS8]MEM
[F:ADS]SYSPAR(1) = [M:ADS8]MPR
[F:ADS]SYSPAR(2) = [M:ADS8]MTO
[F:ADS]SYSPAR(3) = [M:ADS8]MSO
[F:ADS]SYSPAR(4) = [M:ADS8]MSA
[F:ADS]SYSPAR(5) = [M:ADS8]MST
Call GETPAR([M:ADS0]DOSSIER,"HISDOS",[F:ADS]DOSHIS)
Return

#-----------------------------------------#
Subprog GETPAR(DOSSIER,PARAM,VALEUR)
Value Char DOSSIER,PARAM
Variable Char VALEUR
Local Integer ER
If filinfo(filpath("FIL","ADOVAL","fde",[L]DOSSIER),0)>0
 Onerrgo ERRDOS
 If [L]DOSSIER="" or DOSSIER=nomap
  Local File ADOVAL [AD__]
 Else
  Local File =[L]DOSSIER+".ADOVAL" [AD__]
 Endif
 Read [AD__]ADW0 = "";"";[L]PARAM
 If ER or fstat or [F:AD__]VALEUR=""
  [L]VALEUR = ""
 Else
  [L]VALEUR = [F:AD__]VALEUR
 Endif
 Close Local File [AD__]
Else
 [L]VALEUR = ""
Endif
End

#-----------------------------------------#
Subprog GETPARHIS(DOSSIER,PARAM,VALEUR)
Value Char DOSSIER,PARAM
Variable Char VALEUR
Local Integer ER
If filinfo(filpath("FIL","ADOVALHIS","fde",[L]DOSSIER),0)>0
 Onerrgo ERRDOS
 If [L]DOSSIER="" or DOSSIER=nomap
  Local File ADOVALHIS [AH__]
 Else
  Local File =[L]DOSSIER+".ADOVALHIS" [AH__]
 Endif
 Read [AH__]AHW0 = "";"";[L]PARAM
 If ER or fstat or [F:AH__]VALEUR=""
  [L]VALEUR = ""
 Else
  [L]VALEUR = [F:AH__]VALEUR
 Endif
 Close Local File [AH__]
Else
 [L]VALEUR = ""
Endif
End


#-----------------------------------------#
$CREATION
# Liens hors solution
For nolign=1 To [M:ADS9]LNBLIEN
 Raz [F:ADD]
 [F:ADD] = [M:ADS9]
 [F:ADD]DOSSIER = [F:ADS]DOSSIER
 [F:ADD]NUMLIG  = nolign
 PWDDEC = [M:ADS9]LPWD1(nolign-1)
 Call CRYPTNEW(PWDDEC) From GESUSER
 [F:ADD]LPWD    = PWDDEC
 PWDDEC = [M:ADS9]LPWDJAV(nolign-1)
 Call CRYPTNEW(PWDDEC) From GESUSER
 [F:ADD]LPWDJAV = PWDDEC
 Write [ADD]
 If fstat
  GOK = 0 : Call FSTA("ADD") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif

# Mise à jour des livrables
If clalev([F:ADK])>0
 ASTATUS = func ASYRLICFOL.GETPOLICY([L]TBLIV)
 For I=1 To dim(TBLIV)
  If [L]TBLIV(I)<>""
   Read [ADK]ADK0=[F:ADS]DOSSIER;[L]TBLIV(I)
   If fstat
    Raz [F:ADK]
    [F:ADK]DOSSIER = [F:ADS]DOSSIER
    [F:ADK]COD     = [L]TBLIV(I)
    [F:ADK]INSTAL  = 1
    Write [ADK]
    If fstat
     GOK = 0 : Call FSTA("ADK") From GLOCK : Break
    Endif
   Endif
  Endif
 Next I
 For [ADK] Where DOSSIER=[F:ADS]DOSSIER & INSTAL<>2
  Read [ADLV]ADLV0=[F:ADK]COD
  If fstat or [F:ADLV]ADLVTYP=1 : # Livrable
   If !find([F:ADK]COD,TBLIV)
    Delete [ADK] Curr
    If fstat=1
     GOK=-1 : GLOCK="$ADOSLIV" : Break
    Elsif fstat
     GOK = 0 : Call FSTA("ADK") From GLOCK : Break
    Endif
   Endif
  Endif
 Next ADK
 If GOK<1 : Return : Endif
Endif

# Mise à jour des kits
If clalev([F:ADK])>0
 For nolign=1 To [M:ADS5]NBRKIT
  If [M:ADS5]ENAFLG(nolign-1)=2
   Read [ADK]ADK0=[F:ADS]DOSSIER;[M:ADS5]CODKIT(nolign-1)
   If fstat
    Raz [F:ADK]
    [F:ADK]DOSSIER = [F:ADS]DOSSIER
    [F:ADK]COD     = [M:ADS5]CODKIT(nolign-1)
    [F:ADK]INSTAL  = 1
    Write [ADK]
    If fstat
     GOK = 0 : Call FSTA("ADK") From GLOCK : Break
    Endif
   Endif
  Endif
 Next nolign
 If GOK<1 : Return : Endif
 For [ADK] Where DOSSIER=[F:ADS]DOSSIER & INSTAL<>2
  Read [ADLV]ADLV0=[F:ADK]COD
  If fstat or [F:ADLV]ADLVTYP=2 : # kit
   I = find([F:ADK]COD,[M:ADS5]CODKIT(0..[M:ADS5]NBRKIT-1))
   If !I or [M:ADS5]ENAFLG(I-1)<>2
    Delete [ADK] Curr
    If fstat=1
     GOK=-1 : GLOCK="$ADOSLIV" : Break
    Elsif fstat
     GOK = 0 : Call FSTA("ADK") From GLOCK : Break
    Endif
   Endif
  Endif
 Next ADK
 If GOK<1 : Return : Endif
Endif

## Mise à jour des codes activités
Call MAJ_ACV([F:ADS]DOSSIER,[F:ADS]DOSREF)

## Dimensionnement des tables
For nolign=1 To [M:ADS3]NBLIG5
 [F:ADE] = [M:ADS3]
 [F:ADE]DOSSIER = [F:ADS]DOSSIER
 Write [ADE]
 If fstat
  GOK = 0 : Call FSTA("ADE") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif

## Fichier de connexion
Call ECR_CONN([F:ADS]DOSSIER) From DOSDIV

## Mise à jour paramètre législation de dossier racine
If GADONIX=2 & [F:ADS]DOSSIER=GDOSX3
 Call MAJPAR("","DOSLEG",sigma(0,[F:ADS]NBLEG-1,string$(indcum>0,"~")+[F:ADS]DOSLEG(indcum)))
Endif
Return

#-----------------------------------------#
# Mise à jour des codes activités
#-----------------------------------------#

Subprog MAJ_ACV(DOSSIER,DOSREF)
Value Char DOSSIER,DOSREF

Local Integer I , K , PRESENT , ASTATUS , DIME , VLR

Delete [ADA] Where DOSSIER=[L]DOSSIER
If fstat=1
 GOK=-1 : GLOCK="$ADOSACT" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADA") From GLOCK : End
Endif

# Options fonctionnelles
For nolign=1 To [M:ADS6]NBLIG1
 Raz [F:ADA]
 [F:ADA]DOSSIER = [L]DOSSIER
 [F:ADA]CODACT  = [M:ADS6]CODACT1(nolign-1)
 [F:ADA]FLACT   = [M:ADS6]FLACT1(nolign-1)
 [F:ADA]MODULE  = [M:ADS6]MODULE1(nolign-1)
 Write [ADA]
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : End : Endif

# Localisations
For nolign=1 To [M:ADS6]NBLIG2
 Raz [F:ADA]
 [F:ADA]DOSSIER = [L]DOSSIER
 [F:ADA]CODACT  = [M:ADS6]CODACT2(nolign-1)
 [F:ADA]FLACT   = [M:ADS6]FLACT2(nolign-1)
 [F:ADA]MODULE  = [M:ADS6]MODULE2(nolign-1)
 Write [ADA]
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : End : Endif

# Dimensionnement
For nolign=1 To [M:ADS2]NBLIG3
 [F:ADA]CODACT = [M:ADS2]CODACT3(nolign-1)
 [F:ADA]DIME   = [M:ADS2]DIME3(nolign-1)
 [F:ADA]MODULE = [M:ADS2]MODULE3(nolign-1)
 [F:ADA]DOSSIER = [L]DOSSIER
 If DOSSIER<>GDOSX3
  # On ne peut pas faire de contrôle sur le flag "Actif" pour ces codes activités
  ASTATUS = func ASYRLICFOL.ACTIVE_CODE([F:ADA]CODACT,[F:ADA]DOSSIER,[L]DIME,[L]VLR)
  If ASTATUS<>CST_ATRUE
   [F:ADA]DIME = 0
  Endif
 Endif
 If [F:ADA]DIME<1
  [F:ADA]FLACT = 1
 Else
  [F:ADA]FLACT = 2
 Endif
 Write [ADA]
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : End : Endif

# Spécifiques
For nolign=1 To [M:ADS7]NBLIG4
 [F:ADA]CODACT  = [M:ADS7]CODACT4(nolign-1)
 [F:ADA]DIME    = [M:ADS7]DIME4(nolign-1)
 [F:ADA]FLACT   = [M:ADS7]FLACT4(nolign-1)
 [F:ADA]INTIT   = [M:ADS7]LIBACT4(nolign-1)
 [F:ADA]DOSSIER = [L]DOSSIER
 [F:ADA]MODULE  = [M:ADS7]MODULE4(nolign-1)
 [F:ADA]COP     = [M:ADS7]COP(nolign-1)
 Write [ADA]
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : End : Endif

# Dépendances
For [AC2]CODACT Where DEP>1 & DEP<4
 Gosub DEPNOR
 If GOK<1 : Break : Endif
Next AC2
If GOK<1 : End : Endif

# Dépendances avec formule
For [AC2]ACV2 Where DEP=4 & ACTFOR<>""
 Gosub DEPFOR
 If GOK<1 : Break : Endif
Next AC2
If GOK<1 : End : Endif

# Dépendances spécifique
If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
If clalev([F:AC4])>0 : Close Local File [AC4] : Endif
If filinfo(filpath("FIL","ACTIV","fde",[L]DOSSIER),0)>0
 GERREUR = 0
 Onerrgo ERRFIC
 Local File =[L]DOSSIER+".ACTIV" [AC3]
 Read [AC3] First
 Onerrgo
 If GERREUR
  If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
 Endif
Endif
If filinfo(filpath("FIL","ACTIV","fde",[L]DOSREF),0)>0
 GERREUR = 0
 Onerrgo ERRFIC
 Local File =[L]DOSREF+".ACTIV" [AC4]
 Read [AC4] First
 Onerrgo
 If GERREUR
  If clalev([F:AC4])>0 : Close Local File [AC4] : Endif
 Endif
Endif
If clalev([F:AC3])>0
 For [AC3]CODACT Where CODACT>="X" & DEP>1 & DEP<4
  [F:AC2] = [F:AC3]
  Gosub DEPNOR
  If GOK<1 : Break : Endif
 Next AC3
 If GOK<1 : End : Endif
Endif
If clalev([F:AC4])>0
 For [AC4]CODACT Where CODACT>="X" & DEP>1 & DEP<4
  [F:AC2] = [F:AC4]
  If clalev([F:AC3])>0
   Read [AC3]CODACT=[F:AC4]CODACT
   If !fstat : Raz [F:AC2] : Endif
  Endif
  If [F:AC2]CODACT<>""
   Gosub DEPNOR
   If GOK<1 : Break : Endif
  Endif
 Next AC4
 If GOK<1 : End : Endif
Endif

# Dépendances spécifiques avec formule
If clalev([F:AC3])>0
 For [AC3]CODACT Where CODACT>="X" & DEP=4 & ACTFOR<>""
  [F:AC2] = [F:AC3]
  Gosub DEPFOR
  If GOK<1 : Break : Endif
 Next AC2
 If GOK<1 : End : Endif
Endif
If clalev([F:AC4])>0
 For [AC4]CODACT Where CODACT>="X" & DEP=4 & ACTFOR<>""
  [F:AC2] = [F:AC4]
  If clalev([F:AC3])>0
   Read [AC3]CODACT=[F:AC4]CODACT
   If !fstat : Raz [F:AC2] : Endif
  Endif
  If [F:AC2]CODACT<>""
   Gosub DEPFOR
   If GOK<1 : Break : Endif
  Endif
 Next AC4
 If GOK<1 : End : Endif
Endif

# Codes imposés
For K=1 To dim(GCODACTX3)
 Read [ADA]ADA0=[L]DOSSIER;GCODACTX3(K)
 PRESENT = !fstat
 [F:ADA]MODULE  = 1
 Case K
  When 1 : [F:ADA]FLACT = 2
  When 2 : [F:ADA]FLACT = 1
 Endcase
 If PRESENT
  Rewrite [ADA]
 Else
  [F:ADA]CODACT = GCODACTX3(K)
  [F:ADA]DOSSIER = [L]DOSSIER
  Write [ADA]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Break
 Endif
Next K
End

#-----------------------------------------#
$DEPNOR
Read [ADA]ADA0 = [L]DOSSIER;[F:AC2]CODACT
PRESENT = !fstat : # mb 21.10.2 le code activité pouvait être déjà créé
Read [AD2]ADA0 = [L]DOSSIER;[F:AC2]ACTDEP
If !fstat
 Raz [F:ADA]
 [F:ADA]CODACT  = [F:AC2]CODACT
 [F:ADA]MODULE  = [F:AC2]MODULE
 [F:ADA]DOSSIER = [L]DOSSIER
 Case [F:AC2]DEP
  When 2
   If [F:AD2]FLACT=2 : [F:ADA]FLACT = 1 : Else : [F:ADA]FLACT = 2 : Endif
  When 3
   If [F:AC2]TYP<>2
    Local Char CC(1)
    CC = right$([F:AC2]CODACT,len([F:AC2]CODACT))
    If CC>="1" & CC<="9"
     K = val(CC)
    Elsif CC>="A" & CC<="Z"
     K = ascii(CC)-55
    Else
     K = 0
    Endif
    If K<=[F:AD2]DIME
     [F:ADA]FLACT = 2
    Else
     [F:ADA]FLACT = 1
    Endif
   Else
    [F:ADA]FLACT = [F:AD2]FLACT
    [F:ADA]DIME  = min(max([F:AC2]DIMFIL,[F:AD2]DIME),[F:AC2]DIMMAX)
    If [F:ADA]CODACT>="X"
     [F:ADA]COP = 2
    Else
     [F:ADA]COP = 1
    Endif
   Endif
 Endcase
 If PRESENT
  Rewrite [ADA]
 Else
  Write [ADA]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK
 Endif
Endif
Return

#--------------------#
$DEPFOR
Read [ADA]ADA0 = [L]DOSSIER;[F:AC2]CODACT
PRESENT = !fstat
Call FORMULE([L]DOSSIER,[F:AC2]ACTFOR,I,K)
If K
 If I>0
  [F:ADA]FLACT = 2
  If [F:AC2]TYP=2
   [F:ADA]DIME = min(max([F:AC2]DIMFIL,I),[F:AC2]DIMMAX)
  Else
   [F:ADA]DIME = 0
  Endif
 Else
  [F:ADA]FLACT = 1
  [F:ADA]DIME  = 0
 Endif
 If PRESENT
  Rewrite [ADA]
 Else
  [F:ADA]CODACT  = [F:AC2]CODACT
  [F:ADA]MODULE  = [F:AC2]MODULE
  [F:ADA]DOSSIER = [L]DOSSIER
  Write [ADA]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK
 Endif
Endif
Return

#-----------------------------------------#
Subprog MAJPAR(DOSSIER,PARAM,VALEUR)
Value Char DOSSIER,PARAM,VALEUR
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Elsif filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)<=0
 End
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
If !adxlog
 Trbegin [ADW_]
  Gosub MAJ_PAR
 Commit
Else
 Gosub MAJ_PAR
Endif
Close Local File [ADW_]
End

#-------------#
$MAJ_PAR
Read [ADW_]ADW0 = "";"";PARAM
If fstat
 Raz [F:ADW_]
 [F:ADW_]PARAM  = PARAM
 [F:ADW_]VALEUR = VALEUR
 Write [ADW_]
Else
 [F:ADW_]VALEUR = VALEUR
 Rewrite [ADW_]
Endif
If fstat
  GOK = 0 : Call FSTA("ADW_") From GLOCK
Endif
Return

#-----------------------------------------#
Subprog MAJPARHIS(DOSSIER,PARAM,VALEUR)
Value Char DOSSIER,PARAM,VALEUR
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVALHIS [AHW_]
Elsif filinfo(filpath("FIL","ADOVALHIS","fde",DOSSIER),0)<=0
 End
Else
 Local File =DOSSIER+".ADOVALHIS" [AHW_]
Endif
If !adxlog
 Trbegin [AHW_]
  Gosub MAJ_PARHIS
 Commit
Else
 Gosub MAJ_PARHIS
Endif
Close Local File [AHW_]
End

#-------------#
$MAJ_PARHIS
Read [AHW_]AHW0 = "";"";PARAM
If fstat
 Raz [F:AHW_]
 [F:AHW_]PARAM  = PARAM
 [F:AHW_]VALEUR = VALEUR
 Write [AHW_]
Else
 [F:AHW_]VALEUR = VALEUR
 Rewrite [AHW_]
Endif
If fstat
  GOK = 0 : Call FSTA("AHW_") From GLOCK
Endif
Return

#-----------------------------------------#
$AVANT_MODFIC
OKMODSOL = 0
For I=0 To [M:ADS9]NBSOL-1
 If [M:ADS9]SOLDOS(I)<>""
  J = find([M:ADS9]SOLDOS(I),[F:ADS]SOLDOS)
  If J & [M:ADS9]SOLAUZ(J-1)<>[F:ADS]SOLAUZ(J-1)
   OKMODSOL = 1 : Break
  Endif
 Endif
Next I
Return

#-----------------------------------------#
$MODIF
Delete [ADD] Where DOSSIER=CLECUR1
If fstat=1
 GOK=-1 : GLOCK="$ADOSSOL" : Return
Elsif fstat
 GOK = 0 : Call FSTA("ADD") From GLOCK : Return
Endif
Delete [ADE] Where DOSSIER=CLECUR1
If fstat=1
 GOK=-1 : GLOCK="$ADOSDIM" : Return
Elsif fstat
 GOK = 0 : Call FSTA("ADE") From GLOCK : Return
Endif
Gosub CREATION
# Exigence 65131
Raz T_INT
T_INT = [F:ADS]SPEFLG
Call MAJPAR(CLECUR1,"SPECIF",num$(T_INT))
T_INT = [F:ADS]TSTFLG
Call MAJPAR(CLECUR1,"TEST",num$(T_INT))
# End Exigence 65131
Return

#-----------------------------------------#
Subprog FORMULE(DOSSIER,EXPR,RESULT,OK)
Value    Char    DOSSIER , EXPR
Variable Integer RESULT, OK
Local Integer I_ , DEB_ , FIN_ , RES_
Local Char    ACT_(30) , CAR_(1) , EXP_(250) , MES_(250)
EXP_ = format$("KTv2:250X",EXPR)
DEB_ = 0
I_ = 1
While 1=1
 CAR_ = mid$(EXP_,I_,1)
 If (CAR_>="A" & CAR_<="Z") | (CAR_>="0" & CAR_<="9" & DEB_>0)
  If DEB_=0 : DEB_ = I_ : Endif
  FIN_ = I_
 Elsif DEB_
  Gosub REMP
 Endif
 I_ += 1
 If I_>len(EXP_) : Break : Endif
Wend
If DEB_
 Gosub REMP
Endif
OK = 1
Onerrgo ERRACT
RESULT = evalue(EXP_)
Onerrgo
End

#------------------#
$ERRACT
MES_ = mess(65,106,1)-"("+EXP_+") : "+errmes$(errn)-errm : # Erreur en évaluation de la formule
Call ECR_TRACE(MES_,1) From GESECRAN
OK = 0
Resume

#------------#
$REMP
ACT_ = seg$(EXP_,DEB_,FIN_)
If evalue("dim("+ACT_+")")<=0 & len(ACT_)<=GLONACV
 Read [AD2]ADA0 = [L]DOSSIER;ACT_
 If fstat | [F:AD2]FLACT<2
  RES_ = 0
 Elsif [F:AD2]DIME>0
  RES_ = [F:AD2]DIME
 Else
  RES_ = 1
 Endif
 EXP_ = left$(EXP_,DEB_-1)+num$(RES_)+right$(EXP_,FIN_+1)
 I_ = DEB_-1+len(num$(RES_))
Endif
DEB_ = 0
Return

#-----------------------------------------#
$APRES_CRE
# Fichier de paramètres si le dossier existe
If filinfo(filpath("","","",[M:ADS0]DOSSIER,[M:ADS1]VOLUME),0)>=0
 Call CREPAR From DOSDIV
Endif
Gosub MAJFOLD
Return

#-----------------------------------------#
$APRES_MOD
# Fichier de paramètres si le dossier existe
If filinfo(filpath("","","",[M:ADS0]DOSSIER,[M:ADS1]VOLUME),0)>=0
 Call CREPAR From DOSDIV
Endif
Gosub MAJFOLD
# Mise à jour des droits sur les dossiers de la solution
Gosub MAJ_DROITSOL
# Mise à jour du fichier APL.ini si le dossier existe
If filinfo(filpath("","","",[M:ADS0]DOSSIER,[M:ADS1]VOLUME),0)>=0
 Call MAJ_APLINI([M:ADS0]DOSSIER) From DOSAPL
Endif
If OKMODSOL
 # Vous avez modifié les droits d’accès à un dossier.
 # Ces modifications ne seront prises en compte qu’après reconnexion à ce dossier
 Call MESSAGE(mess(212,125,1)-mess(213,125,1)) From GESECRAN
Endif
Return

#-----------------------#
$MAJFOLD
Gosub MAJFOLDA
#  Si le dossier a déjà été généré (X3_PUB/"Dossier"/GEN existe)
#  on vérifie si  tous les répertoires "langues" existent, si non on les crée
#  CC   - Bug 37957     05/10/2006
Local Char NAMEFIC(200)
Call NAMEFIC([M:ADS0]DOSSIER,"GEN","","",NAMEFIC) From INTRUTILA
If filinfo(NAMEFIC,7)>0
  Global Integer GSILCREREP
  Call CREREPPUB([M:ADS0]DOSSIER) From INTRUTILC
  Kill GSILCREREP
Endif
Return

#-----------------#
$MAJFOLDA
# Mise à jour du fichier de description des dossiers
Call CREFOLDERS From VALCSTWEB
Return

#-----------------------------------------#
$LIENS
Call CHARGE_ACV([M:ADS0]DOSSIER,[M:ADS1]DOSREF,[M:ADS4]NBLEG,[M:ADS4]DOSLEG,[M:ADS1]MODULE)
GMODIF = 0
Gosub CHARGE_DIM
Gosub CHARGE_LIEN
Gosub CHARGE_DROITSOL
Gosub CHARGE_KIT
[M:ADS4]NBLIG  = len(mess(0,26,1))
[M:ADS1]NBRMOD = len(mess(0,14,1))
[M:ADS4]NBTR   = len(mess(0,14,1))
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  [M:ADS1]NBRMOD = I-1
  [M:ADS4]NBTR   = I-1
  Break
 Else
  #95969
  If [M:ADS1]MODULE(I-1)=0
   [M:ADS1]MODULE(I-1)=1
  Endif
 Endif
Next I
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  [M:ADS1]AUTMOD(I-1) = 1
  [M:ADS1]MODULE(I-1) = 1
 Endif
Next I
For I=min(len(mess(0,14,1)),dim([M:ADS1]MODULE))+1 To dim([M:ADS1]MODULE)
 [M:ADS1]AUTMOD(I-1) = 1
 [M:ADS1]MODULE(I-1) = 1
Next I
Read [ADS2]DOSSIER = [F:ADS]DOSREF
PRESENT = !fstat
For I=0 To [M:ADS1]NBRMOD-1
 If [F:ADS]DOSREF=[F:ADS]DOSSIER
  [M:ADS1]AUTMOD(I) = 2 : # mb 14.8.2 bug 15471
 Else
  ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(I+1),VLR)
  If ASTATUS<>CST_ATRUE or !PRESENT or [F:ADS2]MODULE(I)<>2
   [M:ADS1]AUTMOD(I) = 1
  Else
   [M:ADS1]AUTMOD(I) = [F:ADS2]MODULE(I)
  Endif
 Endif
 [M:ADS4]MODTR(I) = I
Next I
Call LEC_CONN([F:ADS]DOSSIER,[F:ADS]VOLUME) From DOSDIV
If !GIMPORT
 If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0 : # Dossier existant
  VOLUME = "0"
  For VOLU="A","B","C","D","E","F"
   If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER,VOLU),0)>=0
&   & filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER,VOLU)<>""
    VOLUME = VOLU : Break
   Endif
  Next VOLU
  If VOLUME<>[F:ADS]VOLUME
   Trbegin [ADS]
    [F:ADS]VOLUME=[L]VOLUME
    Rewrite [ADS]
    If fstat
     Call FSTA("ADS") From GLOCK
    Endif
   Commit
   [M:ADS1]VOLUME = VOLUME
  Endif
#  Gosub GRISE
 Else
#  Gosub ACTZONE
#  BASE = [F:ADS]TYPDBA
#  Call GRISE_TYPDBA(BASE)
 Endif
Endif
## Paramètres système
[M:ADS8]MEM = [F:ADS]SYSPAR(0)
[M:ADS8]MPR = [F:ADS]SYSPAR(1)
[M:ADS8]MTO = [F:ADS]SYSPAR(2)
[M:ADS8]MSO = [F:ADS]SYSPAR(3)
[M:ADS8]MSA = [F:ADS]SYSPAR(4)
[M:ADS8]MST = [F:ADS]SYSPAR(5)
If [M:ADS8]MSA=0   : [M:ADS8]MSA   = 16 : Endif
If [M:ADS8]MST=0   : [M:ADS8]MST   = 24 : Endif
If [F:ADS]BLBLNG=0 : [F:ADS]BLBLNG = 9  : [M:ADS1]BLBLNG = 9 : Endif
If [F:ADS]CLBLNG=0 : [F:ADS]CLBLNG = 6  : [M:ADS1]CLBLNG = 6 : Endif
Call CALLNG([F:ADS]BLBLNG,[M:ADS1]BLBTXT)
Call CALLNG([F:ADS]CLBLNG,[M:ADS1]CLBTXT)
#If [M:ADS0]DOSSIER=nomap or nomap=GDOSX3
# Actzo [ADS9]10-20
#Else
# Grizo [ADS9]10-20
#Endif
Return

#-----------------------------------------#
Subprog GRISE_TYPDBA(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : # Oracle
  Actzo [ADS1]SIZDAT, SIZIDX
  Grizo [ADS1]GRPFIL
 When 2 : # SQL
  Grizo [ADS1]SIZDAT, SIZIDX
  Actzo [ADS1]GRPFIL
 When 3 : # C-ISAM
  Grizo [ADS1]SIZDAT, SIZIDX
  Grizo [ADS1]GRPFIL
# --- Pascal 2/11/99 --- Le meme traitement est effectue sur la zone pour la saisi SQL et DB2
 When 4 : # DB2
  Actzo [ADS1]SIZDAT, SIZIDX
  Grizo [ADS1]GRPFIL
Endcase
End

#-----------------------------------------#
$CHARGE_LIEN
Local Char PWDDEC(24)
[M:ADS9]LNBLIEN = 0
For [ADD] Where DOSSIER=[F:ADS]DOSSIER
 [M:ADS9]LNBLIEN += 1
 [M:ADS9]LTYPLIEN([M:ADS9]LNBLIEN-1)  = [F:ADD]LTYPLIEN
 [M:ADS9]LLIENACT([M:ADS9]LNBLIEN-1)  = [F:ADD]LLIENACT
 If [M:ADS9]LLIENACT([M:ADS9]LNBLIEN-1)=2
  Local Integer EXISTL
  Call CONTEXLIEN([F:ADD]LMAC,[F:ADD]LSERV,[F:ADD]LREP,[M:ADS0]DOSSIER,[F:ADD]LTYPOS,EXISTL)
  If EXISTL=0
   [M:ADS9]LLIENACT([M:ADS9]LNBLIEN-1)  = 1
  Endif
 Endif
 [M:ADS9]LDOSTARG([M:ADS9]LNBLIEN-1)  = [F:ADD]LDOSTARG
 [M:ADS9]LMAC([M:ADS9]LNBLIEN-1)      = [F:ADD]LMAC
 [M:ADS9]LSERV([M:ADS9]LNBLIEN-1)     = [F:ADD]LSERV
 [M:ADS9]LREP([M:ADS9]LNBLIEN-1)      = [F:ADD]LREP
 [M:ADS9]LTYPOS([M:ADS9]LNBLIEN-1)    = [F:ADD]LTYPOS
 [M:ADS9]LSOL([M:ADS9]LNBLIEN-1)      = [F:ADD]LSOL
 [M:ADS9]LTYPDBA([M:ADS9]LNBLIEN-1)   = [F:ADD]LTYPDBA
 [M:ADS9]LDBA([M:ADS9]LNBLIEN-1)      = [F:ADD]LDBA
 [M:ADS9]LSRC([M:ADS9]LNBLIEN-1)      = [F:ADD]LSRC
 [M:ADS9]LUSR([M:ADS9]LNBLIEN-1)      = [F:ADD]LUSR
 [M:ADS9]LUSRJAV([M:ADS9]LNBLIEN-1)   = [F:ADD]LUSRJAV
 [M:ADS9]LPWDJAV([M:ADS9]LNBLIEN-1)   = [F:ADD]LPWDJAV
 PWDDEC = [F:ADD]LPWD
 If len(PWDDEC)=24
  Call VARPSE(PWDDEC) From GESUSER
 Endif
 [M:ADS9]LPWD1([M:ADS9]LNBLIEN-1)    = PWDDEC
 PWDDEC = [F:ADD]LPWDJAV
 If len(PWDDEC)=24
  Call VARPSE(PWDDEC) From GESUSER
 Endif
 [M:ADS9]LPWDJAV([M:ADS9]LNBLIEN-1)  = PWDDEC
Next ADD
Return

#-----------------------------------------#
$CHARGE_DROITSOL
Raz [M:ADS9]NBSOL , [M:ADS9]SOLDOS , ER
If [M:ADS0]DOSSIER<>"" & dim([F:ADS]SOLDOS)>0
 Read [ADS]DOSSIER=[M:ADS0]DOSSIER
 Onerrgo ERRDOS
 # Est-ce un vrai dossier ?
 If filinfo(filpath("FIL","ADOVAL","fde",[M:ADS0]DOSSIER),0)>0
  Local File =[M:ADS0]DOSSIER+".ADOVAL" [AD__]
  Read [AD__]ADW0 = "";"";"SUPDOS"
  If ER or fstat
   DOSSUP = ""
  Else
   DOSSUP = [F:AD__]VALEUR
   Read [AD__]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat
    DOSTYP = val([F:AD__]VALEUR)-1
   Endif
  Endif
  Close Local File [AD__]
  If DOSSUP<>""
   If filinfo(filpath("FIL","ADOSSIER","fde",DOSSUP),0)>0
    Local File =DOSSUP+".ADOSSIER" [AD__]
    For [AD__]
     If !find([F:AD__]DOSSIER,[M:ADS0]DOSSIER,DOSSUP,[M:ADS9]SOLDOS)
      ER = 0
      If filinfo(filpath("FIL","ADOVAL","fde",[F:AD__]DOSSIER),0)>0
       Local File =[F:AD__]DOSSIER+".ADOVAL" [AX__]
       Read [AX__]ADW0 = "";"";"TYPDOS"
       If !ER & !fstat & val([F:AX__]VALEUR)-1=DOSTYP
        Read [AX__]ADW0 = "";"";"SUPDOS"
        If !ER & !fstat & [F:AX__]VALEUR=DOSSUP & [M:ADS9]NBSOL<dim([M:ADS9]SOLDOS)-1
         [M:ADS9]NBSOL += 1
         [M:ADS9]SOLDOS([M:ADS9]NBSOL-1) = [F:AD__]DOSSIER
         K = find([M:ADS9]SOLDOS([M:ADS9]NBSOL-1),[F:ADS]SOLDOS)
         If K
          [M:ADS9]SOLAUZ([M:ADS9]NBSOL-1) = [F:ADS]SOLAUZ(K-1)
         Else
          [M:ADS9]SOLAUZ([M:ADS9]NBSOL-1) = 1
         Endif
        Endif
       Endif
      Endif
      Close Local File [AX__]
     Endif
    Next AD__
    Close Local File [AD__]
   Endif
  Endif
 Endif
 Onerrgo
Endif
Return

#------------------------------------------------------------#
# Mise à jour des droits sur les dossiers de la solution
#------------------------------------------------------------#

$MAJ_DROITSOL
If find(nomap(0),[M:ADS0]DOSSIER,GDOSX3) & filinfo(filpath("FIL","ADOVAL","fde",[M:ADS0]DOSSIER),0)>0
 Call TEMPON(mess(191,139,1)) From GESECRAN : # Mise à jour des droits dossier
 For I=0 To [M:ADS9]NBSOL-1
  If [M:ADS9]SOLDOS(I)<>""
   Read [ADS]DOSSIER=[M:ADS9]SOLDOS(I)
   If !fstat & filinfo(filpath("FIL","ADOVAL","fde",[M:ADS9]SOLDOS(I)),0)>0
    CHAINE = [F:ADS]DOSHIS
    Case [M:ADS9]SOLAUZ(I)
     When 1
      Call SUPP_DROITS([M:ADS0]DOSSIER,[M:ADS9]SOLDOS(I),"T",ER) From TRTGRANT
      Call SUPP_DROITS([M:ADS0]DOSSIER,[M:ADS9]SOLDOS(I),"L",ER) From TRTGRANT
      If CHAINE<>""
       Call SUPP_DROITS([M:ADS0]DOSSIER,CHAINE,"T",ER) From TRTGRANT
       Call SUPP_DROITS([M:ADS0]DOSSIER,CHAINE,"L",ER) From TRTGRANT
      Endif
     When 2
      Call SUPP_DROITS([M:ADS0]DOSSIER,[M:ADS9]SOLDOS(I),"T",ER) From TRTGRANT
      Call DONNE_DROITS([M:ADS0]DOSSIER,[M:ADS9]SOLDOS(I),"L",ER) From TRTGRANT
      If CHAINE<>""
       Call SUPP_DROITS([M:ADS0]DOSSIER,CHAINE,"T",ER) From TRTGRANT
       Call DONNE_DROITS([M:ADS0]DOSSIER,CHAINE,"L",ER) From TRTGRANT
      Endif
     When 3
      Call DONNE_DROITS([M:ADS0]DOSSIER,[M:ADS9]SOLDOS(I),"T",ER) From TRTGRANT
      If CHAINE<>""
       Call DONNE_DROITS([M:ADS0]DOSSIER,CHAINE,"T",ER) From TRTGRANT
      Endif
    Endcase
   Endif
  Endif
 Next I
 Call TEMPOFF From GESECRAN
Endif
Return

#---------------------------------------------------#
# Chargement des kits (pas des livrables)
#---------------------------------------------------#

$CHARGE_KIT
If clalev([F:ADK])>0
 [M:ADS5]NBRKIT = 0
 Gosub CHARGE_LIV
Endif
Return

#--------------------------#
$CHARGE_LIV
Local Integer ASTATUS , I , J
Local Char    TBLIV(GLONADLK)(1..50)
ASTATUS = func ASYRLICFOL.GETPOLICY(TBLIV)
For I=1 To dim(TBLIV)
 If TBLIV(I)<>""
  Read [ADLV]ADLV0=TBLIV(I)
  If !fstat
   For J=1 To dim([F:ADLV]ITYKIT)
    If [F:ADLV]ITYKIT(J-1)<>"" & !find([F:ADLV]ITYKIT(J-1),[M:ADS5]CODKIT(0..[M:ADS5]NBRKIT-1))
     Read [ADK]ADK0=[F:ADS]DOSSIER;[F:ADLV]ITYKIT(J-1)
     If !fstat
      [M:ADS5]NBRKIT += 1
      [M:ADS5]CODKIT([M:ADS5]NBRKIT-1) = [F:ADLV]ITYKIT(J-1)
      [M:ADS5]ROWKIT([M:ADS5]NBRKIT-1) = [F:ADLV]ITYKITROW(J-1)
      [M:ADS5]ENAFLG([M:ADS5]NBRKIT-1) = 2
      [M:ADS5]INSTAL([M:ADS5]NBRKIT-1) = [F:ADK]INSTAL
     Else
      ASTATUS = func ASYRLICFOL.ACTIVE_KIT([F:ADLV]ITYKIT(J-1))
      If ASTATUS=CST_ATRUE
       [M:ADS5]NBRKIT += 1
       [M:ADS5]CODKIT([M:ADS5]NBRKIT-1) = [F:ADLV]ITYKIT(J-1)
       [M:ADS5]ROWKIT([M:ADS5]NBRKIT-1) = [F:ADLV]ITYKITROW(J-1)
       If [F:ADS]DOSSIER=GDOSX3
        [M:ADS5]ENAFLG([M:ADS5]NBRKIT-1) = 2
        [M:ADS5]INSTAL([M:ADS5]NBRKIT-1) = 2
       Else
        [M:ADS5]ENAFLG([M:ADS5]NBRKIT-1) = 1
        [M:ADS5]INSTAL([M:ADS5]NBRKIT-1) = 1
       Endif
      Endif
     Endif
    Endif
   Next J
  Endif
 Endif
Next I
Return

#-----------------------------------------#
$RAZCRE
GMODIF = 1
Call AS_VOLUME([M:ADS1]VOLUME)
Call D_CODDBA([M:ADS1]CODDBA)
Affzo [M:ADS1]VOLUME , CODDBA
[M:ADS1]DOSREF = GDOSX3
[M:ADS1]DOSCOP = GDOSX3
Affzo [ADS1]DOSREF , DOSCOP
Call AS_NBRMOD
Call D_BLBLNG([M:ADS1]BLBLNG)
Call D_CLBLNG([M:ADS1]CLBLNG)
Affzo [M:ADS1]BLBLNG, CLBLNG
Gosub CHARGE_KIT
Affzo [M:ADS5]
Call AS_NBTR
Call AS_NBLIG
Call D_MEM([M:ADS8]MEM)
Call D_MSA([M:ADS8]MSA)
Call D_MPR([M:ADS8]MPR)
Call D_MTO([M:ADS8]MTO)
Call D_MSO([M:ADS8]MSO)
Call D_MST([M:ADS8]MST)
Affzo [M:ADS8]MEM , MSA , MPR , MTO , MSO , MST
Gosub AFF_ACV

#-----------------------------------------#
$RAZDUP
[M:ADS1]DOSHIS = "" : Affzo [M:ADS1]DOSHIS
If dim([M:ADS1]CODORA)>0
 [M:ADS1]CODORA = ""
Endif
Gosub ACTZONE
If nomap=GDOSX3
 Actzo [ADS9]10-20
Else
 Grizo [ADS9]10-20
Endif
For I=0 To [M:ADS4]NBRLAN-1
 [M:ADS4]LANREF(I) = 1 : Affzo [ADS4]LANREF(I)
Next I
Call INIT_TYPDBA([M:ADS1]TYPDBA)
Call GRISE_TYPDBA([M:ADS1]TYPDBA)
Return

#-----------------------------------------#
Subprog INIT_TYPDBA(VALEUR)
Variable Integer VALEUR
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
Read [ADW]ADW0 = "";"";"TYPDBA"
VALEUR = val([F:ADW]VALEUR)
End

#-----------------------------------------#
$VERIF_CRE
#110823
If func DOSBASE.ISBASE_RESERVED_WORDS([M:ADS0]DOSSIER)
 Call ERREUR(func AFNC.MES1(mess(272,133,1),[M:ADS0]DOSSIER)) From GESECRAN : # $1$ est un mot réservé aux bases de données
 OK = 0 : Return
Endif
If [M:ADS4]NBLEG=1
 I = find("LEG",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If I & [M:ADS6]FLACT1(I-1)=2
  Local Integer OKMONO
  # Vous n'avez renseigné qu'une seule législation. Voulez-vous désactiver l'option multi-législation sur ce dossier ?
  Call OUINON(mess(275,125,1),OKMONO) From GESECRAN
  If OKMONO=2
   [M:ADS6]FLACT1(I-1) = 1
   Affzo [M:ADS6]FLACT1(I-1)
  Endif
 Endif
Endif
Gosub VERIF

# Vérifications suivant la licence

If OK & [M:ADS0]DOSSIER<>GDOSX3
 Gosub VERIF_LICENCE
 If !OK : Return : Endif
Endif

Return

#-----------------------------------------#
$VERIF_MOD
Gosub VERIF

# Vérifications suivant la licence

If OK & [M:ADS0]DOSSIER<>GDOSX3
 Gosub VERIF_LICENCE
 If !OK : Return : Endif
Endif

Return

#-----------------------------------------#
$VERIF




# Pour forcer APRX3 à "Oui" pour X3 et à "Non" pour X2
Local Integer BIJ , BIK
BIJ = find("APRX3",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If BIJ
#87108
# Call NOMBRA(11,BIK) From GLOCK
# If BIK=6 : # X2
#  [M:ADS6]FLACT1(BIJ-1) = 1
# Else : # X3
#  [M:ADS6]FLACT1(BIJ-1) = 2
# Endif
 If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("APRX3")=[V]CST_AFALSE
  [M:ADS6]FLACT1(BIJ-1) = 1
 Else
  [M:ADS6]FLACT1(BIJ-1) = 2
 Endif
Endif
# Valeur trop petite
K = find("ADI",[M:ADS2]CODACT3(0..[M:ADS2]NBLIG3))
If K & [M:ADS2]DIME3(K-1)=0
 GMESSAGE = [M:ADS2]CODACT3(K-1)-":"-mess(8,133,1)-"("+num$([M:ADS2]DIME3(K-1))+")"
 OK = 0 : SUIZON = "[ADS2]NBLIG3" : Return
Endif
# Il doit y avoir au moins 1 langue
If [M:ADS4]NBRLAN<1
 GMESSAGE = mess(8,125,1)
 OK = 0 : SUIZON = "[ADS4]NBRLAN" : Return
Endif
# Il doit y avoir au moins 1 legislation
If [M:ADS4]NBLEG<1
 GMESSAGE = mess(241,133,1)
 OK = 0 : SUIZON = "[ADS4]NBLEG" : Return
Else
 K = find("LEG",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If [M:ADS6]FLACT1(K-1)<>2 & [M]NBLEG>1
  GMESSAGE = mess(176,125,1) : # Trop de législations
  OK = 0 : SUIZON = "[ADS4]NBLEG" : Return
 Endif
Endif

# Pour ne pas supprimer une législation
Local Integer NBLEG
Local Char    TBLEG(GLONADI)(1..dim(GDOSLEG))
Call SETLEG([M:ADS0]DOSSIER,TBLEG,NBLEG) From DOSCONT
For K=1 To NBLEG
 If !find(TBLEG(K),[M:ADS4]DOSLEG(0..[M:ADS4]NBLEG-1))
  OK = 0 : Break
 Endif
Next K
If !OK
 GMESSAGE = TBLEG(K)-":"-mess(177,125,1) : # Législation impossible à supprimer
 OK = 0 : SUIZON = "[ADS4]NBLEG" : Return
Endif

# Codes activés dans le dossier de référence
If [M:ADS1]DOSREF<>GDOSX3
 For I=1 To [M:ADS6]NBLIG1
  If [M:ADS6]FLACT1(I-1)=2
   Read [ADA]ADA0 = [M:ADS1]DOSREF;[M:ADS6]CODACT1(I-1)
   If fstat or [F:ADA]FLACT<>2
    GMESSAGE = [M:ADS6]CODACT1(I-1)-":"-mess(137,125,1) : # Code activité inactif dans le dossier de référence
    OK = 0 : SUIZON = "[ADS6]NBLIG1"  : Break
   Endif
  Endif
 Next I
 If !OK
  For I=1 To [M:ADS6]NBLIG2
   If [M:ADS6]FLACT2(I-1)=2
    Read [ADA]ADA0 = [M:ADS1]DOSREF;[M:ADS6]CODACT2(I-1)
    If fstat or [F:ADA]FLACT<>2
     GMESSAGE = [M:ADS6]CODACT2(I-1)-":"-mess(137,125,1) : # Code activité inactif dans le dossier de référence
     OK = 0 : SUIZON = "[ADS6]NBLIG2" : Break
    Endif
   Endif
  Next I
 Endif
 If !OK : Return : Endif
Endif

 # FGR 08/01/2016 : X3SUIVI108843 (début) - ne plus faire
  ## Code activité LTA
  #Local Integer KUS
  #KUS = find("LTA",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  #If KUS & [M:ADS6]FLACT1(KUS-1)=2
  # KUS = find("KUS",[M:ADS6]CODACT2(0..[M:ADS6]NBLIG2-1))
  # If !KUS or [M:ADS6]FLACT2(KUS-1)<>2
  #  # Le code activité $1$ ne peut pas être actif si le code activité $2$ est inactif
  #  GMESSAGE = func AFNC.MES2(mess(258,125,1),"LTA","KUS")
  #  OK = 0 : SUIZON = "[ADS6]NBLIG1" : Return
  # Endif
  #Endif
 # FGR 08/01/2016 : X3SUIVI108843 (fin) - ne plus faire

If dim(ACTION)>0
 Local Char OACTION(20)
 OACTION = ACTION
Else
 Local Char ACTION(20)
Endif
ACTION = "VERIF" : Gosub BACTION From SUBADS
If dim(OACTION)>0
 ACTION = OACTION
Endif

Return

#----------------------------------------#
$VERIF_LICENCE
Local Integer VLR , DIME , ASTATUS , OKTEST
ASTATUS = CST_ATRUE

OKTEST = 1
For I=1 To dim([M:ADS1]MODULE)
 If [M:ADS1]MODULE(I-1)=2 & left$(mess(I,14,1),1)<>"#"
  ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(I),VLR)
  If ASTATUS<>CST_ATRUE
   # La license actuelle ne permet pas d'activer le module "$1$"
   GMESSAGE = func AFNC.MES1(mess(268,125,1),mess(I,14,1))
   OKTEST = 0 : Break
  Endif
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS1]NBRMOD" : Return
Endif

For I=1 To [M:ADS5]NBRKIT
 ASTATUS = func ASYRLICFOL.ACTIVE_KIT([M:ADS5]CODKIT(I-1))
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le kit "$1$"
  GMESSAGE = func AFNC.MES1(mess(269,125,1),[M:ADS5]CODKIT(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS5]NBRKIT" : Return
Endif

For I=1 To [M:ADS6]NBLIG1
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M:ADS6]CODACT1(I-1),[M:ADS0]DOSSIER,[L]DIME,VLR)
 If ASTATUS<>CST_ATRUE & [M:ADS6]FLACT1(I-1)=2
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  GMESSAGE = func AFNC.MES1(mess(270,125,1),[M:ADS6]CODACT1(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS6]NBLIG1" : Return
Endif

For I=1 To [M:ADS6]NBLIG2
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M:ADS6]CODACT2(I-1),[M:ADS0]DOSSIER,[L]DIME,VLR)
 If ASTATUS<>CST_ATRUE & [M:ADS6]FLACT2(I-1)=2
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  GMESSAGE = func AFNC.MES1(mess(270,125,1),[M:ADS6]CODACT2(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS6]NBLIG2" : Return
Endif

For I=1 To [M:ADS7]NBLIG4
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M:ADS7]CODACT4(I-1),[M:ADS0]DOSSIER,[L]DIME,VLR)
 If ASTATUS<>CST_ATRUE & [M:ADS7]FLACT4(I-1)=2
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  GMESSAGE = func AFNC.MES1(mess(270,125,1),[M:ADS7]CODACT4(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS7]NBLIG4" : Return
Endif

For I=1 To [M:ADS4]NBRLAN
 ASTATUS = func ASYRLICFOL.ACTIVE_LANGUAGE([M:ADS4]LAN(I-1))
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la langue "$1$"
  GMESSAGE = func AFNC.MES1(mess(271,125,1),[M:ADS4]LAN(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS4]NBRLAN" : Return
Endif

For I=1 To [M:ADS4]NBLEG
 ASTATUS = func ASYRLICFOL.ACTIVE_LEGISLATION([M:ADS4]DOSLEG(I-1))
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la législation "$1$"
  GMESSAGE = func AFNC.MES1(mess(272,125,1),[M:ADS4]DOSLEG(I-1))
  OKTEST = 0 : Break
 Endif
Next I
If !OKTEST
 OK = 0 : SUIZON = "[ADS4]NBLEG" : Return
Endif

Return

#-----------------------------------------#
$GRISE
Diszo [ADS1]DOSREF, TYPDBA, VOLUME, STRDAT , CODDBA , RPTCUR
Diszo [ADS1]SIZDAT , SIZIDX , GRPFIL
Diszo [ADS4]MAJSRC
If dim([M:ADS4]CHGCOD)>0 : Diszo [ADS4]CHGCOD : Endif
Diszo [ADS9]CDOSSIER, CPATH
Return

#-----------------------------------------#
$ACTZONE
Actzo [ADS1]DOSREF, TYPDBA, VOLUME, STRDAT , CODDBA , RPTCUR
Actzo [ADS1]SIZDAT , SIZIDX , GRPFIL
Actzo [ADS4]MAJSRC
If dim([M:ADS4]CHGCOD)>0 : Actzo [ADS4]CHGCOD : Endif
Return

#-----------------------------------------#
$AFF_ACV
Call CHARGE_ACV([M:ADS0]DOSSIER,[M:ADS1]DOSREF,[M:ADS4]NBLEG,[M:ADS4]DOSLEG,[M:ADS1]MODULE)
GMODIF = 0
Affzo [ADS2]
Affzo [ADS6]
Affzo [ADS7]
Gosub CHARGE_DIM
Affzo [ADS3]
Return

#-----------------------------------------#
# Mise à jour des codes activités
#-----------------------------------------#

Subprog CHARGE_ACV(DOSSIER,DOSREF,NBLEG,DOSLEG,MODULE)
Value Char    DOSSIER , DOSREF
Value Integer NBLEG
Value Char    DOSLEG()()
Value Integer MODULE()

Local Char    ACTCOD(GLONACV) , ACTDOS(GLONACT) , ACTINT(30)
Local Integer ACTFLG , ACTDIM , ACTMIN , ACTMAX , ACTTYP , ACTMDU , ACTLIB , ACTNUM , ACTCOP
Local Integer PRESENT , K , STAT , DIMLIC , ACTLIC , LIC
Local Integer FINDINDX  # AKA X3-46874.sn: Define a new local variable

# AKA X3-46874.sn: Save initial option values of [M:ADS6] screen if in duplication mode.
If GREP = "D"
  Gosub SAVE_INITIAL_OPTION
Endif
# AKA X3-46874.en

Raz [M:ADS6]
Raz [M:ADS2]
Raz [M:ADS7]

## Codes activités de X3
Filter [AC2] Order By Key CLE=ORDRE;CODACT
For [AC2]CLE Where DEP<2
 ACTCOD = [F:AC2]CODACT
 ACTFLG = [F:AC2]FLACT
 ACTDIM = [F:AC2]DIME
 ACTMIN = [F:AC2]DIMFIL
 ACTMAX = [F:AC2]DIMMAX
 ACTTYP = [F:AC2]TYP
 ACTMDU = [F:AC2]MODULE
 ACTLIB = [F:AC2]LIBACT
 Call TEXTE(ACTLIB,ACTINT) From OBJDIV
 ACTNUM = 0
 Gosub SET_ACV
Next
Filter [AC2]

## Codes activités spécifiques du dossier
## ou du dossier de référence

ACTDOS = [L]DOSSIER
Gosub OUV_ACTIV

If PRESENT
 If dim([F:AC3]ORDRE)>0 : # Champ inexistant en 120
  Filter [AC3] Order By Key CLE=ORDRE;CODACT
 Else
  Filter [AC3] Order By Key CLE=CODACT
 Endif
 For [AC3]CLE Where CODACT>="X" & DEP<2
  ACTCOD = [F:AC3]CODACT
  ACTFLG = [F:AC3]FLACT
  ACTDIM = [F:AC3]DIME
  ACTMIN = 0
  ACTMAX = 0
  If dim([F:AC3]TYP)>0
   ACTTYP = [F:AC3]TYP
  Else
   ACTTYP = 0
  Endif
  If dim([F:AC3]MODULE)>0
   ACTMDU = [F:AC3]MODULE
  Else
   ACTMDU = 0
  Endif
  ACTLIB = [F:AC3]LIBACT
  Read [AT3]NUMERO = GLANGUE;ACTLIB
  If !fstat
   ACTINT = [F:AT3]TEXTE
  Else
   Read [ADA]ADA0 = [L]DOSSIER;ACTCOD
   ACTINT = [F:ADA]INTIT
  Endif
  ACTNUM = find(ACTCOD,[M:ADS7]CODACT4(0..[M:ADS7]NBLIG4-1))
  Gosub SET_ACV
 Next
 Filter [AC3]
Endif
Read [AD2]ADA0(1) = [L]DOSSIER
If !fstat
 ACTDOS = [L]DOSSIER
 Gosub OUV_ACTIV
 Gosub ACTIV_SPE
Endif
ACTDOS = [L]DOSREF
Gosub OUV_ACTIV
Gosub ACTIV_SPE
Gosub SET_BI
Gosub SET_X3
End

#---------------------------#
$SET_BI
Local Integer BIJ , BIK
BIJ = find("ABI",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If BIJ
#87108
# Call NOMBRA(12,BIK) From GLOCK
# If mod(BIK,8)<4
#  [M:ADS6]FLACT1(BIJ-1) = 1
# Endif
 If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("ABI")=[V]CST_AFALSE
  [M:ADS6]FLACT1(BIJ-1) = 1
  Return
 Endif
Endif
Return

#-------------------------#
$SET_X3
Local Integer BIJ , BIK
BIJ = find("APRX3",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If BIJ
#87108
# Call NOMBRA(11,BIK) From GLOCK
# If BIK=6 : # X2
#  [M:ADS6]FLACT1(BIJ-1) = 1
# Endif
 If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null & fmet GACTX.AGETLICACV("APRX3")=[V]CST_AFALSE
  [M:ADS6]FLACT1(BIJ-1) = 1
 Endif
Endif
Return

#----------------------------------------#
$ACTIV_SPE
For [AD2]ADA0 Where DOSSIER=ACTDOS & CODACT>="X"
 ACTNUM = find([F:AD2]CODACT,[M:ADS7]CODACT4(0..[M:ADS7]NBLIG4-1))
 If !ACTNUM
  ACTCOD = [F:AD2]CODACT
  ACTFLG = [F:AD2]FLACT
  ACTDIM = [F:AD2]DIME
  ACTMDU = [F:AD2]MODULE
  ACTINT = [F:AD2]INTIT
  ACTMAX = 0
  ACTMIN = 0
  If ACTDIM<>0
   ACTTYP = 2
  Endif
  K = 1
  If PRESENT
   Read [AC3]CODACT=[F:AD2]CODACT
   If !fstat
    If [F:AC3]DEP>1
     K = 0
    Else
     If dim([F:AC3]DIMMAX)<=0 : # En 130, ce champ n'existe pas
      ACTMAX = 0
     Else
      ACTMAX = [F:AC3]DIMMAX
     Endif
     ACTMIN = [F:AC3]DIMFIL
     ACTTYP = [F:AC3]TYP
    Endif
   Endif
  Endif
  If K
   Gosub SET_ACV
  Endif
 Endif
Next
Return

#-------------------------#
$OUV_ACTIV
PRESENT = 0
If filinfo(filpath("FIL","ACTIV","fde",ACTDOS),0)>0
 If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
 GERREUR = 0
 Onerrgo ERRFIC
 Local File =ACTDOS+".ACTIV" [AC3]
 Read [AC3]CODACT First
 Onerrgo
 If !GERREUR
  If clalev([F:AT3])>0 : Close Local File [AT3] : Endif
  Onerrgo ERRFIC
  Local File =ACTDOS+".ATEXTE" [AT3]
  Read [AT3]NUMERO First
  Onerrgo
  If !GERREUR
   PRESENT = 1
  Endif
 Endif
Endif
Return

#--------------#
# AKA X3-46874.sn: save initial option values routine
$SAVE_INITIAL_OPTION
For I=0 To [M:ADS6]NBLIG1-1
  ICODACTTAB(I) = [M:ADS6]CODACT1(I) # activity code
  IFLACTTAB(I)  = [M:ADS6]FLACT1(I)  # active flag
Next I
Return
# AKA X3-46874.en

#--------------#
$ERRFIC
GERREUR = errn
Resume

#-----------------------#
$SET_ACV
If ACTMDU<=0 : ACTMDU = 1 : Endif
If ACTTYP<=0 : ACTTYP = 2 : Endif
ACTCOP = 1
If ([L]MODULE(ACTMDU-1)=2 & !find(ACTCOD,GCODACTX3)) or ACTCOD>="X"
 LIC = 0
 DIMLIC = 0

# AKA X3-46874.sn comment out original. add duplication mode (GREP="D") logic
# Read [ADA]ADA0 = [L]DOSSIER;ACTCOD
# If !fstat
#  ACTFLG = [F:ADA]FLACT
#  ACTCOP = [F:ADA]COP
#  If ACTLIB=0 : ACTINT = [F:ADA]INTIT : Endif
# Else
 Case GREP
   When "D" #Duplication mode, use reference folder (DOSREF)
      Read [ADA]ADA0 = [L]DOSREF;ACTCOD
      If !fstat
        FINDINDX = find(ACTCOD, ICODACTTAB)
        If FINDINDX > 0
          ACTFLG = IFLACTTAB(FINDINDX - 1)
        Else
          ACTFLG = [F:ADA]FLACT
        Endif
      Endif
      ACTCOP = [F:ADA]COP
      If ACTLIB=0 : ACTINT = [F:ADA]INTIT : Endif
   When Default
      Read [ADA]ADA0 = [L]DOSSIER;ACTCOD
      If !fstat
        ACTFLG = [F:ADA]FLACT
        ACTCOP = [F:ADA]COP
        If ACTLIB=0 : ACTINT = [F:ADA]INTIT : Endif
      Endif
 Endcase
 If fstat
# AKA X3-46874.en

  LIC = 1
  ASTATUS = func ASYRLICFOL.ACTIVE_CODE(ACTCOD,[L]DOSSIER,[L]DIMLIC,[L]ACTLIC)
  If ASTATUS<>CST_ATRUE
   ACTFLG = 1
  Elsif [L]ACTLIC=2
   ACTFLG = [L]ACTLIC
  Else
   ACTFLG = -1
  Endif
  Read [ADA]ADA0 = [L]DOSREF;ACTCOD
  If !fstat
   ACTCOP = [F:ADA]COP
   If ACTLIB=0 : ACTINT = [F:ADA]INTIT : Endif
  Endif
  If ACTFLG=-1
   If !fstat
    ACTFLG = [F:ADA]FLACT
   Else
    ACTFLG = 1
   Endif
  Endif
 Endif
 STAT = fstat
 If ACTCOD>="X" : # Spécifique
  If [L]MODULE(ACTMDU-1)=2 or ACTCOP=2 : # On préserve les codes activités verticaux
   If !ACTNUM
    [M:ADS7]NBLIG4 += 1
    ACTNUM = [M:ADS7]NBLIG4
   Endif
   [M:ADS7]CODACT4(ACTNUM-1) = ACTCOD
   [M:ADS7]MODULE4(ACTNUM-1) = ACTMDU
   [M:ADS7]LIBACT4(ACTNUM-1) = ACTINT
   If [L]MODULE(ACTMDU-1)=2
    [M:ADS7]FLACT4(ACTNUM-1) = ACTFLG
   Else
    [M:ADS7]FLACT4(ACTNUM-1) = 1
   Endif
   If LIC & DIMLIC>0
    [M:ADS7]DIME4(ACTNUM-1)  = DIMLIC
   Elsif !STAT
    [M:ADS7]DIME4(ACTNUM-1)  = [F:ADA]DIME
   Else
    [M:ADS7]DIME4(ACTNUM-1)  = ACTDIM
   Endif
   [M:ADS7]TYP4(ACTNUM-1)    = ACTTYP
   [M:ADS7]COP(ACTNUM-1)     = ACTCOP
  Endif
 Else
  Case ACTTYP
   When 1 : # Fonctionnel
    [M:ADS6]CODACT1([M:ADS6]NBLIG1) = ACTCOD
    [M:ADS6]MODULE1([M:ADS6]NBLIG1) = ACTMDU
    [M:ADS6]LIBACT1([M:ADS6]NBLIG1) = ACTINT
    If !STAT
     [M:ADS6]FLACT1([M:ADS6]NBLIG1) = ACTFLG
    Else
     [M:ADS6]FLACT1([M:ADS6]NBLIG1) = 2
    Endif
    If dim(ACTION)>0
     Local Char OACTION(20)
     OACTION = ACTION
    Else
     Local Char ACTION(20)
    Endif
    ACTION = "SET_ACV" : Gosub BACTION
    If dim(OACTION)>0
     ACTION = OACTION
    Endif
    [M:ADS6]NBLIG1 += 1
   When 2 : # Dimensionnement
    [M:ADS2]CODACT3([M:ADS2]NBLIG3) = ACTCOD
    [M:ADS2]MODULE3([M:ADS2]NBLIG3) = ACTMDU
    [M:ADS2]DIMIN3([M:ADS2]NBLIG3)  = ACTMIN
    [M:ADS2]DIMAX3([M:ADS2]NBLIG3)  = ACTMAX
    [M:ADS2]LIBACT3([M:ADS2]NBLIG3) = ACTINT
    If LIC & DIMLIC>0
     [M:ADS2]DIME3([M:ADS2]NBLIG3) = DIMLIC
    Elsif !STAT
     [M:ADS2]DIME3([M:ADS2]NBLIG3) = [F:ADA]DIME
    Endif
    [M:ADS2]NBLIG3 += 1
   When 3 : # Localisation
    [M:ADS6]CODACT2([M:ADS6]NBLIG2) = ACTCOD
    [M:ADS6]MODULE2([M:ADS6]NBLIG2) = ACTMDU
    [M:ADS6]LIBACT2([M:ADS6]NBLIG2) = ACTINT
    [M:ADS6]FLACT2([M:ADS6]NBLIG2)  = ACTFLG
    [M:ADS6]NBLIG2 += 1
  Endcase
 Endif
Endif
Return

#-------------------------#
$CHARGE_DIM
Raz [M:ADS3]
nolign = 0
For [ADM]ADM1
 If [M:ADS1]MODULE([F:ADM]MODULE-1)=2
  nolign += 1
  [M:ADS3] = [F:ADM]
  [M:ADS3]DIMCOD(nolign-1)  = [F:ADM]COD
  [M:ADS3]MODULE5(nolign-1) = [F:ADM]MODULE
  Call TEXTE([F:ADM]DES,[M:ADS3]ZDIMCOD(nolign-1)) From OBJDIV
 Endif
Next
[M:ADS3]NBLIG5 = nolign
Look [ADS]DOSSIER=[M:ADS0]DOSSIER
If fstat
 For [ADE] Where DOSSIER=[M:ADS1]DOSREF
  K = find([F:ADE]DIMCOD,[M:ADS3]DIMCOD(0..[M:ADS3]NBLIG5-1))
  If K
   nolign = K
   [M:ADS3] = [F:ADE]
  Endif
 Next ADE
Else
 For [ADE] Where DOSSIER=[M:ADS0]DOSSIER
  K = find([F:ADE]DIMCOD,[M:ADS3]DIMCOD(0..[M:ADS3]NBLIG5-1))
  If K
   nolign = K
   [M:ADS3] = [F:ADE]
  Endif
 Next ADE
Endif
Return

#-----------------------#
$INIT_DIM
For [ADE] Where DOSSIER=[M:ADS1]DOSREF
 K = find([F:ADE]DIMCOD,[M:ADS3]DIMCOD(0..[M:ADS3]NBLIG5-1))
 If K & [M:ADS3]NBR(nolign-1)=0
  nolign = K
  [M:ADS3]NBR(nolign-1) = [F:ADE]NBR
 Endif
Next ADE
Return

#---------------------------#
$COP_ECRAN
Local Char WMSK(GLONAMK)(9)
Local Char WABR(GLONABR)(9)
WMSK(0) = "ADS0"
WMSK(1) = "ADS1"
WMSK(2) = "ADS6"
WMSK(3) = "ADS2"
WMSK(4) = "ADS3"
WMSK(5) = "ADS4"
WMSK(6) = "ADS05"
WMSK(7) = "ADS7"
WMSK(8) = "ADS8"
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return

#---------------------------#
$FERME
Call IMPSCR From ATRTX3
# AKA X3-46874.sn Release the global resources used to store initial option values in duplication mode
If dim(ICODACTTAB)>0
  Kill ICODACTTAB
Endif
If dim(IFLACTTAB)>0
  Kill IFLACTTAB
Endif
# AKA X3-46874.en
Return

#----------------------------#
$TIT
TIT = mess(1,125,1)-[F:ADS]DOSSIER : # Génération dossier
Return

#------------------------------------------------------------#
$DEFVAR
Local  Integer ER , BASE , PRESENT , DOSTYP , ARRET , OKMODSOL
Local  Char    REPERT(GDIMFIC) , REQTRACE(GDIMFIC) , SUPDOS(GLONADS)
Local  Char    VOLU(1) , VOLUME(1) , DOSSUP(GLONADS)
Local  Char    PWDDEC(24)
Local  Integer T_INT , ASTATUS , VLR
Global Char    GDOSX3(GLONADS) , GDOSIAP(GLONADS) , GDOSREF(GLONADS)
Global Char    GVOLX3(1)
#X3-76171
If dim(GMAXSPEACV)>=0 & GMAXSPEACV>0
  Global Char    GSPE(GLONACV)(1..GMAXSPEACV)
Else
  Global Char    GSPE(GLONACV)(1..300)
Endif
#X3-76171
Global Integer GNBSPE
Global Integer GCRE
Global Char    GCODACTX3(GLONACV)(1..2)
Global Integer GMAJTXTSTD(1..32766) , GMAJTXTSPE(1..32766)
Global Integer GNBRTXTSTD , GNBRTXTSPE , GDERTXTSTD , GDERTXTSPE
Global Integer GTSTDOS
Global Decimal GCOEFTAB
Global Char    DOSVERS(10), SUPVERS(10)
Global Integer GNBTBL , GNBMSK , GNBAOB , GNBWIN , GNBCNS , GNBACLA, GNBASW
Global Char    GXX(10)
Global Integer GERRDOS
Global Libelle GVALIDE(1..11)
Global Libelle GVALTRANS(1..30)
Local  Char    TBLIV(GLONADLV)(1..200) , TBKIT(GLONADLV)(1..200)
Local  Integer TBROW(1..200)

# AKA X3-46874.sn: Define two new global variables for list of initial activity codes and active flags
Global Char    ICODACTTAB(GLONACV)(300)
Global Integer IFLACTTAB(300)
# AKA X3-46874.en

Call PARAM("","NOSTOPERR",GBIDC1) From ADOVAL
ARRET = (GBIDC1<>"2")
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
If GDOSX3="" : GDOSX3 = "GX3APP" : Endif
Call PARAM("","SUPIAP",GDOSIAP) From ADOVAL
If GDOSIAP="" : GDOSIAP = "IAP" : Endif
Call PARAM("","SUPVOL",GVOLX3) From ADOVAL
If GVOLX3="" : GVOLX3 = "A" : Endif
GCODACTX3(1) = "TRU"
GCODACTX3(2) = "FAL"
If GADONIX=2
 GXX = "X"       : # Chez nous on s'arrête là
Else
 GXX = chr$(255) : # Chez le client on recopie les spécifiques
Endif
Return

#-----------------------------------------#
# Actions de sélection
#-----------------------------------------#

$SEL_LISTE
Case LISTE
 When "SELVOL"    : Gosub SEL_VOLUME
 When "OPTINI"    : Gosub SEL_OPTINI
 When "SELADS"    : Gosub SEL_ADS
Endcase
Return

#----------------------#
$FIN_LISTE
Case LISTE
 When "OPTINI"    : VALEUR = [M]OPTINI(nolign-1)
Endcase
Return

#--------------------------#
$SEL_ADS
Local Char TEXTE(150)(1..GNBSEL,1..3) , TEX(GLONADD)(1..GNBSEL)
Local Integer ER
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
If clalev([F:AD_])=0 : Local File ADOSSIER [AD_] : Endif
NBTEX = 0
For [AD_]
 mkstat = 0
 Call LECDOS([F:AD_]DOSSIER) From DOSCONT
 Raz GMESSAGE
 If !mkstat & NBTEX<dim(TEX)
  NBTEX += 1
  TEX(NBTEX) = [F:AD_]DOSSIER
  TEXTE(NBTEX,2) = [F:AD_]NOMDOS
  Call CTL_DROIT_DOSSIER([F:AD_]DOSSIER,"E") From DOSCONT
  If !mkstat
   TEXTE(NBTEX,3) = mess(3,7812,1) : # Toutes
  Else
   Call CTL_DROIT_DOSSIER([F:AD_]DOSSIER,"") From DOSCONT
   If !mkstat
    TEXTE(NBTEX,3) = mess(2,7812,1) : # Lecture
   Else
    TEXTE(NBTEX,3) = mess(1,7812,1) : # Aucune
   Endif
  Endif
 Endif
Next AD_
Read [ADS]DOSSIER=nomap
For [ADD] Where DOSSIER=[F:ADS]DOSSIER
 If [F:ADD]LLIENACT=2 & NBTEX<dim(TEX)
  NBTEX += 1
  TEX(NBTEX) = [F:ADD]LMAC+":"+num$([F:ADD]LSERV)+"@"
  If [F:ADD]LDOSTARG<>""
   TEX(NBTEX) += [F:ADD]LDOSTARG
  Else
   TEX(NBTEX) += [F:ADD]LUSR
  Endif
  If [F:ADD]LTYPLIEN>1
      TEXTE(NBTEX,2) = mess([F:ADD]LTYPLIEN,920,1)
  Else
       # add productname instead of aml 2902
       # link to jira 82177 switch to display name (case of renaming)
       TEXTE(NBTEX,2)= func APRODUCT._AGETPRODUCTNAME()
  Endif
  TEXTE(NBTEX,2) -= "("+mess([F:ADD]LTYPDBA,57,1)+"/"+mess([F:ADD]LTYPOS,946,1)+")"
  TEXTE(NBTEX,3) = ""
 Endif
Next I
TIT(0) = mess(85,115,1)  : # Dossier
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
TIT(3) = mess(146,125,1) : # Autorisations
Return

$ER
ER = errn
Resume

#----------------------------------------#
# Traitement divers
#----------------------------------------#

$TRT_DIV
Case TRAIT
 When "AFFNEWVAL" : Gosub AFFNEWVAL
Endcase
Return

#----------------------------------#
$AFFNEWVAL
Local Integer OK , MAJ
Local Char    CODKIT(GLONADLK) , DOSSIER(GLONADS) , DOSREF(GLONADS)
[L]CODKIT = PARAM(1)
If PARAM(2)<>""
 [L]DOSSIER = PARAM(2)
Else
 [L]DOSSIER = nomap
Endif
If PARAM(3)<>""
 [L]DOSREF = PARAM(3)
Else
 [L]DOSREF = GDOSX3
Endif
Local Mask ADS005 [ADS55]
MAJ = 0
Call KITACVUPD(CODKIT,DOSSIER,DOSREF,MAJ)
If [M:ADS55]NBRDEF>0
 [M:ADS55]MESSAGE = ""
 # Codes activités modifiés
 Call DIALWIN(OK,mess(278,125,1),"OADS5") From GESECRAN
Endif
Return

#-------------------------------------------------------------#
Subprog KITACVUPD(CODKIT,DOSSIER,DOSREF,MAJ)
Value Char CODKIT
Value Char DOSSIER
Value Char DOSREF
Value Integer MAJ
Local Integer I , J , K , AFF , TYP , OLDVAL
If clalev([F:ADLD])=0 : Local File =GDOSX3+".ADELIVERD" [ADLD] : Endif
If filinfo(filpath("FIL","ACTIV","fde",[L]DOSSIER),0)>0
 GERREUR = 0
 Onerrgo ERRFIC
 Local File =[L]DOSSIER+".ACTIV" [AC3]
 Read [AC3] First
 Onerrgo
 If GERREUR
  If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
 Endif
Endif
If filinfo(filpath("FIL","ACTIV","fde",[L]DOSREF),0)>0
 GERREUR = 0
 Onerrgo ERRFIC
 Local File =[L]DOSREF+".ACTIV" [AC4]
 Read [AC4] First
 Onerrgo
 If GERREUR
  If clalev([F:AC4])>0 : Close Local File [AC4] : Endif
 Endif
Endif
[M:ADS55]NBRDEF = 0
For [ADLD]ADLD0 Where COD=[L]CODKIT
 AFF = 0
 TYP = 0
 If clalev([F:AC3])>0
  Read [AC3]CODACT=[F:ADLD]CODACT
  If !fstat : TYP = [F:AC3]TYP : Endif
 Elsif clalev([F:AC4])>0
  Read [AC4]CODACT=[F:ADLD]CODACT
  If !fstat : TYP = [F:AC4]TYP : Endif
 Else
  Read [ACV]CODACT=[F:ADLD]CODACT
  If !fstat : TYP = [F:ACV]TYP : Endif
 Endif
 If [F:ADLD]CODACT>="X"
  K = find([F:ADLD]CODACT,[M:ADS7]CODACT4(0..[M:ADS7]NBLIG4-1))
  If K
   Case TYP
    When 1,3
     If [F:ADLD]FLGACT=2 & [M:ADS7]FLACT4(K-1)<>[F:ADLD]FLGACT
      [L]OLDVAL = [M:ADS7]FLACT4(K-1)
      If MAJ : [M:ADS7]FLACT4(K-1) = [F:ADLD]FLGACT : Endif
      AFF = 1
     Endif
    When 2
     If [M:ADS7]DIME4(K-1)<>[F:ADLD]DIMACT
      [L]OLDVAL = [M:ADS7]DIME4(K-1)
      If MAJ : [M:ADS7]DIME4(K-1) = [F:ADLD]DIMACT : Endif
      AFF = 1
     Endif
   Endcase
  Endif
 Else
  Case TYP
   When 1
    K = find([F:ADLD]CODACT,[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
    If K & [F:ADLD]FLGACT=2 & [M:ADS6]FLACT1(K-1)<>[F:ADLD]FLGACT
     [L]OLDVAL = [M:ADS6]FLACT1(K-1)
     If MAJ : [M:ADS6]FLACT1(K-1) = [F:ADLD]FLGACT : Endif
     AFF = 1
    Endif
   When 2
    K = find([F:ADLD]CODACT,[M:ADS2]CODACT3(0..[M:ADS2]NBLIG3-1))
    If K & [M:ADS2]DIME3(K-1)<>[F:ADLD]DIMACT
     [L]OLDVAL = [M:ADS2]DIME3(K-1)
     If MAJ : [M:ADS2]DIME3(K-1) = [F:ADLD]DIMACT : Endif
     AFF = 1
    Endif
   When 3
    K = find([F:ADLD]CODACT,[M:ADS6]CODACT2(0..[M:ADS6]NBLIG2-1))
    If K & [F:ADLD]FLGACT=2 & [M:ADS6]FLACT2(K-1)<>[F:ADLD]FLGACT
     [L]OLDVAL = [M:ADS6]FLACT2(K-1)
     If MAJ : [M:ADS6]FLACT2(K-1) = [F:ADLD]FLGACT : Endif
     AFF = 1
    Endif
  Endcase
 Endif
 If AFF
  [M:ADS55]NBRDEF += 1
  [M:ADS55]DEFACV([M:ADS55]NBRDEF-1) = [F:ADLD]CODACT
  If TYP=2
   [M:ADS55]OLDVAL([M:ADS55]NBRDEF-1) = num$([L]OLDVAL)
   [M:ADS55]DEFVAL([M:ADS55]NBRDEF-1) = num$([F:ADLD]DIMACT)
  Else
   [M:ADS55]OLDVAL([M:ADS55]NBRDEF-1) = mess([L]OLDVAL,1,1)
   [M:ADS55]DEFVAL([M:ADS55]NBRDEF-1) = mess(2,1,1) : # Oui
  Endif
 Endif
Next ADLD
End

#-----------------------------------------#
# ADS0
#-----------------------------------------#

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Integer    TYPDBA , OK
Local File ADOVAL [ADW_]
Read [ADW_]ADW0 = "";"";"TYPDBA"
TYPDBA = val([F:ADW_]VALEUR)
Close Local File [ADW_]
# Si le dossier est DB2 alors le nom ne doit pas depasser 8 caracteres
If len(VALEUR)>8 & TYPDBA=4
 GMESSAGE = mess(122,123,1) : # nom de dossier trop grand
 mkstat = 2 : End
Endif
# Si le dossier existe, il doit être de même type que le produit courant
Call VERFDOS(VALEUR,OK)
If !OK : mkstat = 2 : End : Endif
Look [ADS]DOSSIER=VALEUR
If fstat
 If nomap<>GDOSX3
  # La création d'un dossier n'est possible que depuis le dossier #
  GMESSAGE = func AFNC.MES(mess(186,125,1),GDOSX3)
  mkstat = 2 : End
 Elsif find(VALEUR,"PARAM","APL")
  GMESSAGE = VALEUR-":"-mess(205,133,1) : # Code réservé
  mkstat = 2 : End
 Endif
Endif
End

Subprog VERFDOS(DOSSIER,OK)
Value    Char    DOSSIER
Variable Integer OK
Local Integer ER
Onerrgo ERRDOS
OK = 1
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 Local File =DOSSIER+".ADOVAL" [ADW_]
 Read [ADW_]ADW0 = "";"";"TYPDOS"
 If !fstat & GPRODUIT>=0 & val([F:ADW_]VALEUR)-1<>GPRODUIT
  # Ce dossier existe et n'est pas un dossier du produit courant
  OK = 0 : GMESSAGE = DOSSIER-":"-mess(197,126,1)
 Endif
 Close Local File [ADW_]
Elsif filinfo(filpath("FIL","AX3DAT","fde",DOSSIER),0)>0
 # Ce nom de dossier est déjà utilisé pour un datawarehouse BO
 OK = 0 : GMESSAGE = DOSSIER-":"-mess(99,148,1)
Else
 Local File ADOSSIER [ADD_]
 For [ADD_]
  If filinfo(filpath("FIL","ABIDATWRH","fde",[F:ADD_]DOSSIER),0)>0
   Local File =[F:ADD_]DOSSIER+".ABIDATWRH" [ABW]
   Read [ABW]ABW0=DOSSIER
   If !fstat
    # Ce nom de dossier est déjà utilisé pour un datawarehouse BO
    OK = 0 : GMESSAGE = DOSSIER-":"-mess(99,148,1)
   Endif
   Close Local File [ABW]
   If !OK : Break : Endif
  Endif
 Next ADD_
 Close Local File [ADD_]
Endif
Onerrgo
End


#-----------------------------------------#
# ADS1
#-----------------------------------------#

Subprog D_TYPDBA(VALEUR)
Variable Integer VALEUR
Call INIT_TYPDBA(VALEUR)
End

Subprog AP_TYPDBA(VALEUR)
Variable Integer VALEUR
Call GRISE_TYPDBA(VALEUR)
End

Subprog AS_VOLUME(VALEUR)
Variable Char    VALEUR()
#Local Char FILVOL(250) , LIGNE(250)
#FILVOL = filpath("!","adxvolumes","")
#If filinfo(FILVOL,0)>=0
# Openi FILVOL
# adxifs = "" : adxirs = chr$(10)
# [M]NBVOL = 0
# fstat = 0
# Repeat
#  Rdseq LIGNE
#  LIGNE = vireblc(LIGNE,2)
#  If !fstat
#   If left$(LIGNE,1)<>"#"
#    [M]TBVOL([M]NBVOL) = left$(LIGNE,1)
#    [M]NBVOL += 1
#   Endif
#  Endif
# Until fstat
# Openi
# If VALEUR="" & [M]NBVOL>0 : VALEUR = [M]TBVOL(1) : Endif
#Else
# VALEUR = "0" : mkstat = 2
#Endif
Local Char FILVOL(250) , LIGNE(250), PATH(250),VOLU(250)
Local Clbfile DIRECTORIES
Local Integer WBPATH : WBPATH=0
Local Integer WBDIR : WBDIR=0
FILVOL = filpath("!cfg","configRuntime","json")
If filinfo(FILVOL,0)>=0
 Openi FILVOL Using [VOL_]
 Iomode adxifs "" Using [VOL_]
 Iomode adxirs chr$(10) Using [VOL_]
 Iomode adxium GASCII Using [VOL_]
 [M]NBVOL = 0
 fstat = 0
 Repeat
  Rdseq LIGNE Using [VOL_]
  LIGNE = vireblc(LIGNE,2)
  If !fstat
   If left$(LIGNE,1)<>"#"
    If instr(1,LIGNE,'"path"')<>0
     WBDIR=1
    Elsif WBDIR=1 and instr(1,LIGNE,'"path"')<>0
     WBPATH=1
    Elsif instr(1,LIGNE,'"volume"')<>0 and (WBDIR=1 or WBPATH=1)
     VOLU=right$(LIGNE,instr(1,LIGNE,':'))
     VOLU=vireblc(VOLU,2)
     VOLU=right$(VOLU,instr(1,VOLU,'"')+1)
     VOLU=left$(VOLU,1)
     If VOLU<>"0"
      PATH=filpath("","","","A",VOLU)
      PATH=left$(PATH,len(PATH)-2)
      [M]TBVOL([M]NBVOL) = VOLU+":"+PATH
      [M]NBVOL += 1
      If VALEUR="" & ascii(VOLU)>=ascii("A") : VALEUR = VOLU : Endif
     Endif
    Elsif instr(1,LIGNE,'}')<>0
     WBPATH=0
    Endif
   Endif
  Endif
 Until fstat
 Openi Using [VOL_]
Else
 VALEUR = "A" : mkstat = 2
Endif

End

Subprog C_VOLUME(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M]TBVOL(0..[M]NBVOL-1))
 GMESSAGE = mess(5,125,1) : mkstat = 2 : End
# Volume inexistant
Endif
Call LEC_CONN([M]DOSSIER,VALEUR) From DOSDIV
Affzo [ADS9]
End

$SEL_VOLUME
#Local Char    FILVOL(250) , LIGNE(250)
#Local Integer NUM
#FILVOL = filpath("!","adxvolumes","")
#If filinfo(FILVOL,0)>=0
# Openi FILVOL
# adxifs = "" : adxirs = chr$(10)
# fstat = 0
# NBTEX = 0
# Repeat
#  Rdseq LIGNE
#  LIGNE = vireblc(LIGNE,2)
#  If !fstat
#   If left$(LIGNE,1)<>"#"
#    NBTEX += 1
#    TEXTE(NBTEX) = LIGNE
#    TEX(NBTEX)   = left$(LIGNE,1)
#   Endif
#  Endif
# Until fstat
# Openi
#Endif

Local Char FILVOL(250) , LIGNE(250), PATH(250),VOLU(250)
Local Integer WBPATH : WBPATH=0
FILVOL = filpath("!cfg","configRuntime","json")
If filinfo(FILVOL,0)>=0
 Openi FILVOL Using [VOL_]
 Iomode adxifs "" Using [VOL_]
 Iomode adxirs chr$(10) Using [VOL_]
 Iomode adxium GASCII Using [VOL_]
 NBTEX = 0
 fstat = 0
 Repeat
  Rdseq LIGNE Using [VOL_]
  LIGNE = vireblc(LIGNE,2)
  If !fstat
   If left$(LIGNE,1)<>"#"
    If instr(1,LIGNE,'"path"')<>0
     WBPATH=1
    Elsif WBPATH=1 & instr(1,LIGNE,'"volume"')<>0
     VOLU=right$(LIGNE,instr(1,LIGNE,':'))
     VOLU=vireblc(VOLU,2)
     VOLU=right$(VOLU,instr(1,VOLU,'"')+1)
     VOLU=left$(VOLU,1)
     If VOLU<>"0"
      PATH=filpath("","","","A",VOLU)
      PATH=left$(PATH,len(PATH)-2)
      NBTEX += 1
      TEXTE(NBTEX) = VOLU+":"+PATH
      TEX(NBTEX)=VOLU
     Endif
    Elsif instr(1,LIGNE,'}')<>0
     WBPATH=0
    Endif
   Endif
  Endif
 Until fstat
 Openi Using [VOL_]
Endif
Return

Subprog C_DOSREF(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK , VLR , ASTATUS , PRESENT
If VALEUR<>GDOSX3
 If VALEUR=[M]DOSSIER
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 1 : End
 Endif
 Call CONTROLE("ADS","$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 If filinfo(filpath("","","",VALEUR),0)<0
  GMESSAGE = mess(7,125,1): # Dossier inexistant
  mkstat = 2 : End
 Endif
 Read [ADS2]DOSSIER = VALEUR
 PRESENT = !fstat
 If [F:ADS2]DOSREF<>GDOSX3
  # Ce dossier n'a pas pour référence le dossier #
  Call AVERTIR(func AFNC.MES(mess(145,125,1),GDOSX3),OK) From GESECRAN
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
 For I=1 To len(mess(0,14,1))
  ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(I),VLR)
  If ASTATUS<>CST_ATRUE or !PRESENT or [F:ADS2]MODULE(I-1)<>2
   [M]AUTMOD(I-1) = 1
  Else
   [M]AUTMOD(I-1) = [F:ADS2]MODULE(I-1)
  Endif
  Affzo MODULE(I-1)
 Next I
Endif
End

Subprog AS_DOSCOP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR = [M]DOSREF : Endif
End

Subprog C_DOSCOP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>GDOSX3
 If VALEUR=[M]DOSSIER
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 1 : End
 Endif
 Call CONTROLE("ADS","$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 If filinfo(filpath("","","",VALEUR),0)<0
  GMESSAGE = mess(7,125,1) : # Dossier inexistant
  mkstat = 2 : End
 Endif
Endif
End

