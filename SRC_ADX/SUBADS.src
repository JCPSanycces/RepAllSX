#-----------------------------------------#

Subprog B1_LNBLIEN
Local Integer OK
Call CREDOS([M:ADS9]LMAC(nolign-1),[M:ADS9]LTYPOS(nolign-1),[M:ADS9]LTYPDBA(nolign-1),[M:ADS9]LSERV(nolign-1)
&          ,[M:ADS9]LREP(nolign-1),[M:ADS9]LDBA(nolign-1),[M:ADS9]LSRC(nolign-1),[M:ADS9]LUSR(nolign-1)
&          ,[M:ADS9]LPWD1(nolign-1),[M:ADS0]DOSSIER,0,OK) From CPTX3
If OK>=1
  [M:ADS9]LLIENACT(nolign-1)=2
  Affzo LLIENACT(nolign-1)
  mkstat=4
Endif
If GMESSAGE<>""
  If OK=2
    Call MESSAGE(GMESSAGE) From GESECRAN
  Else
    Call ERREUR(GMESSAGE) From GESECRAN
  Endif
  Raz GMESSAGE
Endif
End

Subprog AP_LTYPLIEN(VALEUR)
Variable Integer VALEUR
End

Subprog AM_LREP(VALEUR)
Variable Char    VALEUR()
# On recherche les paramètres si il n'ont pas été saisis
If [M]LDBA(nolign-1)="" or [M]LSRC(nolign-1)="" or [M]LSOL(nolign-1)=""
  Local Char TBAS,NOMBAS,SQLINST,SOLUTION
  Local Integer VERSION,PLATFORM,TBAS
  Call RECHPAR([M]LMAC(nolign-1),[M]LSERV(nolign-1),VALEUR,VERSION,PLATFORM,TBAS,NOMBAS,SQLINST,SOLUTION)
  If VERSION >=140
    [M]LTYPOS(nolign-1)=PLATFORM
    [M]LTYPDBA(nolign-1)=TBAS
    [M]LDBA(nolign-1)=NOMBAS
    [M]LSRC(nolign-1)=SQLINST
    [M]LSOL(nolign-1)=SOLUTION
    Affzo LTYPOS(nolign-1),LTYPDBA(nolign-1),LDBA(nolign-1),LSRC(nolign-1),LSOL(nolign-1)
  Else
    # Fichier de définition non trouvé, confirmez que vous créez un lien vers un dossier 130 ?
    Local Integer OK
    Call OUINON(mess(138,125,1),OK) From GESECRAN
    If OK<>2
      mkstat=2
      End
    Endif
  Endif
  If [M]LUSR(nolign-1)="" and [M]LDOSTARG(nolign-1)<>""
    [M]LUSR(nolign-1)=[M]LDOSTARG(nolign-1)
    Affzo LUSR(nolign-1)
  Endif
Endif
End

Subprog IB_LNBLIEN
If [M]LLIENACT(nolign-1)<>2 or [M:ADS0]DOSSIER<>nomap or [M]LDOSTARG(nolign-1)=""
 GBOUT2=""
Endif
End

Subprog B2_LNBLIEN
Local Integer ERR
Local Char ADRTAB(100)
Onerrgo TESTLIEN
ADRTAB=[M:ADS9]LMAC(nolign-1)+":"+num$([M:ADS9]LSERV(nolign-1))+"@"+[M:ADS9]LDOSTARG(nolign-1)+".APLLCK"
Local File =ADRTAB [A_CK]
Onerrgo
# Accès à une table du dossier distant impossible
#  On prend la table APLLCK car elle existe même dans les dossiers historisés
If ERR=1 : Call ERREUR(mess(140,125,1)-ADRTAB) From GESECRAN : End : Endif
Call MESSAGE(mess(139,125,1)-ADRTAB) From GESECRAN : # Accès à une table du dossier distant vérifiée
End

$TESTLIEN:
ERR=1
Resume

#-----------------------------------------------------------------#
# Recherche des informations dans le fichier solution
#----------------------------------------------------------------#

Subprog RECHPAR(MACHINE,PORT,REP,VERSION,PLATFORM,TBAS,NOMBAS,SQLINST,SOLUTION)
Value Char MACHINE,REP
Value Integer PORT
Variable Char NOMBAS,SQLINST,SOLUTION
Variable Integer VERSION,PLATFORM,TBAS
Local Char NOMFIC(200),VALL1(200),VALL2(20),SQLODBC(100),FORCEDBLINK,DBLINK(100),NAMEMAIN(100)
Local Integer I1,I2,TYPD
Local Char SEP,AVERSION
Local Integer TBAS
SEP="/"
If instr(1,REP,"\")<>0 : SEP="\" : Endif
NOMFIC=MACHINE+":"+num$(PORT)+"@"+REP+SEP+"solution.xml"
If filinfo(NOMFIC,7)<0 : VERSION=130 : End : Endif
VERSION=140
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0

While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"<solution")<>0
    I1=instr(1,VALL1,"name")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Elsif instr(1,VALL1,"<module") and instr(1,VALL1,'family="RUNTIME"')<>0  and instr(1,VALL1,'type="MAIN"')<>0
    I1=instr(1,VALL1,"name=")
    I2=instr(I1+7,VALL1,'" ')
    If I2-I1-1>0
      NAMEMAIN=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Elsif instr(1,VALL1,"component.application.version")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      AVERSION=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
      If left$(AVERSION,1)="V"
        VERSION=val(right$(AVERSION,2))
      Elsif left$(AVERSION,1)<>"R"
        VERSION=val(AVERSION)
      Endif
    Endif
  Elsif instr(1,VALL1,"runtime.odbc.forcedblink")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      FORCEDBLINK=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"runtime.odbc.dblink")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      DBLINK=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"component.application.platform")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      VALL2=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
    Case toupper(VALL2)
      When "UNIX"          : PLATFORM=1
      When "WIN32","WIN64" : PLATFORM=2
      When "LINUX"         : PLATFORM=3
      When Default         : PLATFORM=1
    Endcase
  Elsif instr(1,VALL1,'family="DATABASE"')<>0
    I1=instr(1,VALL1,"type")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      VALL2=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
    Case VALL2
      When "ORACLE"    : TBAS=1
      When "SQLSERVER" : TBAS=2
    Endcase
  Elsif TBAS=1 and instr(1,VALL1,"database.adonix.orasid")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlbase")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlodbc")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      SQLINST=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Endif
Wend

Openi Using [CST_]

#   Bug 47847 : Détermination de la source de données ODBC si SQL serveur        - CC  21/01/2010
If TBAS=2 and SQLINST=""
  If (toupper(FORCEDBLINK)="ON" or toupper(FORCEDBLINK)="TRUE") and DBLINK<>""
    SQLINST=DBLINK
  Else
    SQLINST=NAMEMAIN
  Endif
Endif

End

$ERRLEC
Resume

Subprog AP_LTYPDBA(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Effzo LSRC(nolign-1)
 Grizo LSRC(nolign-1)
 Actzo LDBA(nolign-1)
Else
 Actzo LSRC(nolign-1)
 #Effzo LDBA(nolign-1) : # bug 72507
 #Affzo LDBA(nolign-1) : # bug 72507
Endif
End

Subprog C_LTYPLIEN(VALEUR)
Variable Integer VALEUR
If VALEUR>1 and [M:ADS9]LNBLIEN>=1
  For indice=0 To [M:ADS9]LNBLIEN
    If indice<>nolign-1 and [M:ADS9]LTYPLIEN(indice)=VALEUR
      GMESSAGE=mess(218,133,1)
      mkstat=2
      Break 1
    Endif
  Next indice
Endif
End

Subprog C_LDOSTARG(VALEUR)
Variable Char    VALEUR()
If [M]LTYPLIEN(nolign-1)<>1 and vireblc(VALEUR,2)=""
  GMESSAGE=mess(10,123,1) : # Zone obligatoire
  mkstat=2
  End
Endif
If vireblc(VALEUR,2)<>""
  Local Char CHEMIN(200),SEP
  Local Integer EXISTE
  Case [M:ADS9]LTYPOS(nolign-1)
   When 2       : SEP = "\"
   When Default : SEP = "/"
  Endcase
  CHEMIN = [M:ADS9]LMAC(nolign-1)+":"+num$([M:ADS9]LSERV(nolign-1))+"@"+[M:ADS9]LREP(nolign-1)
  CHEMIN+=SEP+VALEUR+SEP+"TRT"
  Call EXISTE(CHEMIN,EXISTE) From ORDSYS
#  on cherche si on trouve le répertoire TRT sur le dossier distant
  If !EXISTE
    GMESSAGE=mess(7,125,1)  : # Dossier inexistant
    mkstat=2
    End
  Endif
Endif
End

Subprog C_LDBA(VALEUR)
Variable Char    VALEUR()
End

Subprog C_LSRC(VALEUR)
Variable Char    VALEUR()
End

Subprog APRES_LNBLIEN
End

Subprog CONTEXLIEN(MAC,SERV,REP,DOSS,TYPOS,EXISTE)
Value Char MAC
Value Integer SERV
Value Char REP
Value Char DOSS
Value Integer TYPOS
Variable Integer EXISTE

Local Char SEP
Case TYPOS
  When 2       : SEP = "\"
  When Default : SEP = "/"
Endcase
CHEMIN = MAC+":"+num$(SERV)+"@"+REP+SEP+DOSS
Call EXISTE(MAC+":"+num$(SERV)+"@"+REP+SEP+DOSS,EXISTE) From ORDSYS
End

Subprog AVANT_LNBLIEN
#  On traite le cas de la suppression de lien
If status<>65 : End : Endif

# Est-ce un "pseudo-dossier"
Local Char CHEMIN(200),SEP,ORDER1(200)
Local Integer EXISTE,ECRASE,STAT
Case [M:ADS9]LTYPOS(nolign-1)
  When 2       : SEP = "\"
  When Default : SEP = "/"
Endcase
CHEMIN = [M:ADS9]LMAC(nolign-1)+":"+num$([M:ADS9]LSERV(nolign-1))+"@"+[M:ADS9]LREP(nolign-1)
CHEMIN+=SEP+[M:ADS0]DOSSIER+SEP+"TRT"
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
#  on cherche si on trouve le répertoire TRT sur le dossier distant
If EXISTE : End : Endif    : #   C'est un vrai dossier

#  C'est bien un "pseudo-dossier" on propose de supprimer les répertoires distants

# Voulez vous supprimer le répertoire distant ?
Call OUINON(mess(143,125,1),ECRASE) From GESECRAN
If ECRASE<>2 : End : Endif

ORDER1="ae_rmdir"-[M:ADS9]LREP(nolign-1)+SEP+[M:ADS0]DOSSIER
Call SYSTEME([M:ADS9]LMAC(nolign-1)+":"+num$([M:ADS9]LSERV(nolign-1)),ORDER1,"",STAT) From ORDSYS
End



