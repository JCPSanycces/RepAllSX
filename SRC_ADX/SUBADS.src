# ADS7
#-----------------------------------------#

Subprog AS_NBLIG4
If GMODIF : Gosub AFF_ACV : Endif
End

Subprog C_NBLIG4
Local Integer I , NOL , NOL1
If find(status,65,68)
 NOL = nolign-1
 If nolign1>0
  NOL1 = nolign1-1
 Else
  NOL1 = NOL
 Endif
 If filinfo(filpath("FIL","ACTIV","fde",[M:ADS0]DOSSIER),0)>=0
  If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
  Local File =[M:ADS0]DOSSIER+".ACTIV" [AC3]
  For I=NOL To NOL1
   Read [AC3]CODACT = [M]CODACT4(I)
   If !fstat : mkstat = 1 : Break : Endif
  Next I
  Close Local File [AC3]
 Endif
Endif
End

Subprog B1_NBLIG4
Hlpbox "ACV_"+[M]CODACT4(nolign-1)
End

Subprog C_CODACT4(VALEUR)
Variable Char    VALEUR()
Local Integer OK , ASTATUS , DIME , VLR
If VALEUR<"X"
 GMESSAGE = mess(56,125,1) : # Le code doit être supérieur à X
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]CODACT4(0..[M]NBLIG4-1)) From OBJDIV
If VALEUR<>[M]CODACT4(nolign-1)
 OK = 0
 If filinfo(filpath("FIL","ACTIV","fde",[M:ADS0]DOSSIER),0)>=0
  If clalev([F:AC3])>0 : Close Local File [AC3] : Endif
  Local File =[M:ADS0]DOSSIER+".ACTIV" [AC3]
  Read [AC3]CODACT = VALEUR
  If !fstat
   If [F:AC3]DEP>1
    Call ERREUR(mess(68,139,1)-mess([F:AC3]DEP,74,1)) From GESECRAN : # Code activité avec dépendance
    mkstat = 1 : End
   Endif
   [M]MODULE4(nolign-1) = [F:AC3]MODULE
   [M]FLACT4(nolign-1)  = [F:AC3]FLACT
   [M]TYP4(nolign-1)    = [F:AC3]TYP
   [M]DIME4(nolign-1)   = [F:AC3]DIME
   If [F:AC3]LIBACT=0
    [M]LIBACT4(nolign-1) = [F:AC3]INTIT
   Else
    Call TEXTE([F:AC3]LIBACT,[M]LIBACT4(nolign-1)) From OBJDIV
   Endif
   If [M:ADS0]DOSSIER=GDOSX3
    OK = 1
   Else
    ASTATUS = func ASYRLICFOL.ACTIVE_CODE(VALEUR,[M:ADS0]DOSSIER,[L]DIME,[L]VLR)
    If ASTATUS<>CST_ATRUE
     [M]FLACT4(nolign-1) = 1
     OK = 0
    Else
     OK = 1
    Endif
   Endif
  Endif
 Endif
 If !OK
  Read [AD2]ADA0 = [M:ADS0]DOSSIER ; VALEUR
  If !fstat
   [M]MODULE4(nolign-1) = [F:AD2]MODULE
   [M]FLACT4(nolign-1)  = [F:AD2]FLACT
   [M]DIME4(nolign-1)   = [F:AD2]DIME
   [M]LIBACT4(nolign-1) = [F:AD2]INTIT
   If [F:AD2]DIME<>0
    [M]TYP4(nolign-1)   = 2
   Else
    [M]TYP4(nolign-1)   = 1
   Endif
   OK = 1
  Endif
 Endif
 If !OK
  Read [AC2]CODACT = VALEUR
  If !fstat
   If [F:AC2]DEP>1
    Call ERREUR(mess(68,139,1)-mess([F:AC2]DEP,74,1)) From GESECRAN : # Code activité avec dépendance
    mkstat = 1 : End
   Endif
   [M]MODULE4(nolign-1) = [F:AC2]MODULE
   [M]FLACT4(nolign-1)  = [F:AC2]FLACT
   [M]TYP4(nolign-1)    = [F:AC2]TYP
   [M]DIME4(nolign-1)   = [F:AC2]DIME
   Call TEXTE([F:AC2]LIBACT,[M]LIBACT4(nolign-1)) From OBJDIV
   OK = 1
  Endif
 Endif
 If !OK
  [M]TYP4(nolign-1) = 2
 Endif
Endif
End

Subprog C_MODULE4(VALEUR)
Variable Integer  VALEUR
If [M:ADS1]MODULE(VALEUR-1)<>2 : mkstat = 2 : Endif
End

Subprog C_FLACT4(VALEUR)
Variable Integer VALEUR
Local Integer OK , ASTATUS , DIME , VLR
If VALEUR=2 & [M:ADS1]DOSREF<>GDOSX3
 Read [ADA]ADA0 = [M:ADS1]DOSREF;[M]CODACT4(nolign-1)
 If !fstat and [F:ADA]FLACT<>2
  Call AVERTIR(mess(137,125,1),OK) From GESECRAN : # Code activité inactif dans le dossier de référence
  If OK<>2 : mkstat = 1 : End : Endif
 Endif
Endif
If VALEUR=2 & [M:ADS0]DOSSIER<>GDOSX3
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([M]CODACT4(nolign-1),[M:ADS0]DOSSIER,[L]DIME,[L]VLR)
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  Call ERREUR(func AFNC.MES1(mess(270,125,1),[M]CODACT4(nolign-1))) From GESECRAN
  mkstat = 1 : End
 Endif
Endif
End

Subprog AM_FLACT4(VALEUR)
Variable Integer VALEUR
Local Integer ASTATUS , DIME , VLR
If VALEUR=2
 Read [ADA]ADA0 = [M:ADS1]DOSREF;[M:ADS7]CODACT4(nolign-1)
 If !fstat
  [M:ADS7]COP(nolign-1) = [F:ADA]COP
  [M:ADS7]DIME4(nolign-1) = [F:ADA]DIME
  Affzo [M:ADS7]COP(nolign-1) , DIME4(nolign-1)
 Endif
Endif
End

Subprog AS_DIME4(VALEUR)
Variable Decimal  VALEUR
If [M:ADS7]TYP4(nolign-1)<>2 | [M:ADS7]FLACT4(nolign-1)<>2 : mkstat = 1 : Endif
End

Subprog C_DIME4(VALEUR)
Variable Decimal  VALEUR
Local Shortint COURT
Local Integer  ER
Onerrgo ERR
COURT = VALEUR
Onerrgo
If ER
 GMESSAGE = mess(135,141,1) : # Valeur hors LIMITE
 mkstat = 2 : End
Endif
End

$ERR
ER = errn
Resume

Subprog AS_COP(VALEUR)
Variable Integer VALEUR
If [M]FLACT4(nolign-1)<>2
 mkstat = 2 : End
Endif
End

