Variable Decimal VALEUR
If [M]TYPDBA<>1 & [M]TYPDBA<>4 : mkstat = 1 : End : Endif
End

Subprog AS_SIZIDX(VALEUR)
Variable Decimal VALEUR
If [M]TYPDBA<>1 & [M]TYPDBA<>4 : mkstat = 1 : End : Endif
End

Subprog D_CODDBA(VALEUR)
