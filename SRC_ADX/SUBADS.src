Goto NBMAX

Subprog AM_MST(VALEUR)
Variable Decimal VALEUR
Local Integer K, L
K = 2048 : # Nombre maxi mémoire classes (MO)
L = 24   : # Nb mini
Goto NBMAX

$NBMAX
If VALEUR<>0
 If VALEUR>K
  GMESSAGE = mess(199,126,1)-num$(K) : # Valeur supérieure à
  mkstat = 2
 Elsif VALEUR<L
  GMESSAGE = mess(200,126,1)-num$(L) : # Valeur inférieure à
  mkstat = 2
 Endif
Endif
End

Subprog C_DOSSIER(VALEUR)
Value Char DOSSIER
If [M]DOSSIER=GDOSX3 & VALEUR<>[M]DOSSIER & GADONIX<>2
 Look [ADS]DOSSIER=VALEUR
 If fstat
  # Duplication du dossier $1$ impossible
  GMESSAGE = func AFNC.MES1(mess(282,125,1),[M]DOSSIER)
  mkstat = 2
  End
 Endif
Endif
#110823
If func DOSBASE.ISBASE_RESERVED_WORDS(VALEUR)
 Call MESSAGE(func AFNC.MES1(mess(272,133,1),VALEUR)) From GESECRAN : # $1$ est un mot réservé aux bases de données
Endif
End

