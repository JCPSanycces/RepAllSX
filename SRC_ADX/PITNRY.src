#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : Ecritures ENERGY
######################################################################

$OUVTAB_NRY
If !clalev([F:DAA]) Local File GACCENTRYA [DAA] Endif
If !clalev([F:DAE]) Local File GACCENTRYD [DAE] Endif
If !clalev([F:HAE]) Local File GACCENTRY  [HAE] Endif
If !clalev([F:BPR]) Local File BPARTNER   [BPR] Endif
If !clalev([F:FCY]) Local File FACILITY   [FCY] Endif
If !clalev([F:CPY]) Local File COMPANY    [CPY] Endif
If !clalev([F:GAC]) Local File GACCOUNT   [GAC] Endif
Return

######################################################################
Subprog TRT_NRY(ID,CLETRT,CODPIT,LTYP,COA,TABCPY,NBCPY,STRFCY,ENDFCY,STRDAT,ENDDAT,TABROT,NBROT,TABACC,NBACC,NBDAA,OK)
Value    Char       ID()              : # "NRY" For ENERGY Interface
Value    Char       CLETRT()          : # Identifier
Value    Char       CODPIT()          : # Pivot Code (By default : ENERGY)
Value    Integer    LTYP              : # Ledger Type
Value    Char       COA               : # Account Plan
Value    Char       TABCPY()(0..)     : # Companies Table
Value    Integer    NBCPY             : # Companies Number
Value    Char       STRFCY()          : # Start Site
Value    Char       ENDFCY()          : # End Site
Value    Date       STRDAT            : # Start Date
Value    Date       ENDDAT            : # End Date
Value    Char       TABROT()(0..)     : # Account Roots Table
Value    Integer    NBROT             : # Account Roots Number
Value    Char       TABACC()(0..)     : # Accounts Table
Value    Integer    NBACC             : # Accounts Number
Variable Integer    NBDAA             : # Generated Lines Number
Variable Integer    OK

Local Char    WFIL1(255), WFIL2(255), WFIL3(255)
Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GASCII
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT

Gosub OUVTAB_NRY
Gosub OUVREPIVOT From CONNECTFCT

## Revoir la dimension de TACC....
Local Integer DIM_TACC
Filter [GAC] Where COA = [L]COA
DIM_TACC = rowcount([F:GAC])
Filter [GAC]

Local Integer I, ICPY, IACC                  : # Miscellaneaous variables
Local Integer TOTACC                         : # Total number of accounts to be exported
Local Char    TACC(GLONGAC)(0..DIM_TACC-1)   : # Accounts tables to be exported
Local Char    FILTENT(250)(0..2)
Local Integer IFILE

Local Integer NBRDAA  : Raz NBRDAA
Local Integer WPRENRY : Raz WPRENRY
Local Char    OPTNRY(GDIMFIC)
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES
Local Integer WKHEATYP       : Raz WKHEATYP
Local Char    WKHEADMES (250): Raz WKHEADMES
OPTNRY = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitnry")

Call READPIT(CODPIT,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC

Call LOADPIVZON(CODPIT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(CODPIT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRENRY,OPTNRY) From CONNECTFCT

## The following Accounting Entries have to be take into account :
##  -  'Actual' Category (CAT=1)
##  -  'Final' Status (STA=2)
##  -  Associated to a Document Type attached to a 'Normal' Period ([HAE]PER<>0, knowing that the accounting entries associated to
##     a Document Type with 'Balance forward' or 'Closing' Period are created with the PER field equal to zero)

Raz FILTENT
Call ADDCRIT(FILTENT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LTYP)," & ") From GOBJSUB
If [L]STRDAT<>[0/0/0]
 Call ADDCRIT(FILTENT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,[L]STRDAT)+']'," & ") From GOBJSUB
Endif
If [L]ENDDAT<>[0/0/0]
 Call ADDCRIT(FILTENT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,[L]ENDDAT)+']'," & ") From GOBJSUB
Endif
If [L]STRFCY<>""
 Call ADDCRIT(FILTENT,IFILE,"FCYLIN",'[F:DAA]FCYLIN>="'+[L]STRFCY+'"'," & ") From GOBJSUB
Endif
If [L]ENDFCY<>""
 Call ADDCRIT(FILTENT,IFILE,"FCYLIN",'[F:DAA]FCYLIN<="'+[L]ENDFCY+'"'," & ") From GOBJSUB
Endif

Link [DAA] With [HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&               [DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTENT)
& Order By Key KEY1=[DAA]CPY;[DAA]FCYLIN;[DAA]ACC;[DAA]BPR;[DAA]ACCDAT

Gosub TAB_ACC

For ICPY=0 To [M]NBCPY-1
 If [L]TABCPY(ICPY) = "" : Break : Endif
 Call LEC_CPY([L]TABCPY(ICPY)) From CPTLEC

 For IACC=0 To TOTACC-1

  For [LNK]KEY1 Where CPY=[L]TABCPY(ICPY) & ACC=[L]TACC(IACC)
   If [F:HAE]CAT=1 & [F:HAE]STA=2 & [F:HAE]PER<>0
    Call LEC_FCY([F:DAA]FCYLIN) From CPTLEC
    Call LEC_BPR([F:DAE]OFFACC) From CPTLEC
    Gosub WR_DAA
   Endif
  Next

 Next
Next
NBDAA = NBRDAA

Call WRPIVOT_END(CODPIT,NBRDAA,WKNORECMES,WPRENRY,OPTNRY) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End


$TAB_ACC
Raz TOTACC, TACC
For I = 0 To [L]NBACC-1
 If !find([L]TABACC(I),[L]TACC(0..TOTACC))
  [L]TACC(TOTACC) = [L]TABACC(I)
  TOTACC += 1
 Endif
Next
For I = 0 To [L]NBROT-1
 For [GAC]GAC0 Where COA=[L]COA & left$(ACC,len([L]TABROT(I)))=[L]TABROT(I)
  If !find([F:GAC]ACC,[L]TACC(0..TOTACC))
   [L]TACC(TOTACC) = [F:GAC]ACC
   TOTACC += 1
  Endif
 Next
Next
Return


######################################################################
$WR_DAA
If WPRENRY = 0
 Openo OPTNRY,0 Using [FPIV]
 WPRENRY = 1
Else
 Openo OPTNRY Using [FPIV]
Endif
NBRDAA += 1
Call RAZVALPIVOT(CODPIT,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
Call EVALPIVOT(CODPIT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
Openo Using [FPIV]
Return
