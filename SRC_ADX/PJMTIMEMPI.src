#<AdxTL>@(#)0.0.0.0 $Revision$ 
#-----------------------------------------------------------
# GBN - 2017/03/01
# Project time entry import template.
#-----------------------------------------------------------
$ACTION
 Case ACTION
  When "AP_IMPORT" : Gosub AP_IMPORT
  When "IMP_FERME" : Gosub IMP_FERME
  When Default
 Endcase
Return

#-----------------------------------------------------------
# Called for each record in the imported file
#-----------------------------------------------------------
$AP_IMPORT

  Local Instance GZINSPJMTH Using C_PJMTIMEMPH
  Local Char     LCASE(10)
  Local Integer  MY_STATUS
  Local Integer  LIMPTRC : LIMPTRC=0

  If GZINSPJMTH <> null Then
    FreeGroup GZINSPJMTH
    Raz GZINSPJMTH
  Endif

  # ----------------------------------
  # Automatic initialization of fields
  # ----------------------------------
  [F:PTI]PIMPBUCOD = [F:PTI]OPPNUM+"!"+"!"+[F:PTI]PBUCOD
  [F:PTI]PIMTASCOD = [F:PTI]OPPNUM+"!"+[F:PTI]TASCOD

  If LIMPTRC
   Call ECR_TRACE("[F:PTI]PIMPBUCOD"-[F:PTI]PIMPBUCOD,0) From GESECRAN
   Call ECR_TRACE("[F:PTI]PIMTASCOD"-[F:PTI]PIMTASCOD,0) From GESECRAN
   Call ECR_TRACE("[F:PTI]TEXTE"-[F:PTI]TEXTE,0) From GESECRAN
  Endif

  # ----------------------------------
  # Import case determination :
  #    - CRECLB
  #    - UPDTIM
  #    - ADDTIM
  # ----------------------------------
  If GZINSPJMTH = null Then
    If!clalev([F:PTEH]) : Local File PJMTIMEMPH [PTEH] : Endif
    # ----------------------------------
    GZINSPJMTH = NewInstance C_PJMTIMEMPH AllocGroup null
    # ----------------------------------
    Read [PTEH]PTEH0=[F:PTI]CLB
    If fstat=5 Then
      # ----------------------------------
      # The user is not existing in time entries
      [L]MY_STATUS = fmet GZINSPJMTH.AINIT()
      # ----------------------------------
      If GZINSPJMTH.CLB <> [F:PTI]CLB Then
        GZINSPJMTH.CLB = [F:PTI]CLB
      Endif
      # ----------------------------------
      If LIMPTRC : Call ECR_TRACE("==> No collaborator record for this entry => Creation mode",0) From GESECRAN : Endif
      LCASE="CRECLB"
    Elsif fstat & fstat<>5
     Call ECR_TRACE("==> Importation error : Key"-[F:PTI]CLB-"Error="+num$(fstat),1) From GESECRAN
    Else
      # ----------------------------------
      # The user is existing in time entries
      [L]MY_STATUS  = fmet GZINSPJMTH.AREAD([F:PTI]CLB)
      If [L]MY_STATUS >= [V]CST_AERROR Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
        GOK = 0
        GERR = 1
        End
      Else
       If LIMPTRC : Call ECR_TRACE("==> Collaborator record found for this entry => Update mode",0) From GESECRAN : Endif
       If GZINSPJMTH.TIMENT<>null
        Local Integer NI, LFOUND, LINDEX
        For NI=1 To maxtab(GZINSPJMTH.TIMENT)
         If [F:PTI]PTEDAT=GZINSPJMTH.TIMENT(NI).PTEDAT & [F:PTI]PTESEQ=GZINSPJMTH.TIMENT(NI).PTESEQ
          LFOUND=1 : LINDEX=NI
         Endif
        Next NI
        If LFOUND
          If LIMPTRC
           Call ECR_TRACE(" <> Time already recorded for this collaborator (same PTESEQ/PTEDAT) - Index "-num$(LINDEX)-" => Modification ",0) From GESECRAN
           Call ECR_TRACE(GZINSPJMTH.TIMENT(LINDEX).PTEDAT+"/"+num$(GZINSPJMTH.TIMENT(LINDEX).PTESEQ),0) From GESECRAN
          Endif
          LCASE="UPDTIM"
        Else
          If LIMPTRC : Call ECR_TRACE(" <> Time entry not found for this collaborator => New item in the collection ",0) From GESECRAN : Endif
          LCASE="ADDTIM"
          LINDEX=1
        Endif
       Else
        If LIMPTRC : Call ECR_TRACE(" <> No time already recorded for this collaborator => Addline ",0) From GESECRAN : Endif
        LCASE="ADDTIM"
        LINDEX=1
       Endif
      Endif
      # ----------------------------------
    Endif
    # ----------------------------------
  Endif

  # ----------------------------------
  # Import case processing
  # ----------------------------------

  Case LCASE
   When "CRECLB" : Gosub CRECLB_CRETIM
   When "UPDTIM" : Gosub UPDCLB_UPDTIM
   When "ADDTIM" : Gosub UPDCLB_CRETIM
   When "CRETIM" : Gosub UPDCLB_CRETIM
   When Default
  Endcase

  If LIMPTRC
   Local Integer I_TIM
   If GZINSPJMTH.TIMENT<>null
    For I_TIM = 1 To maxtab(GZINSPJMTH.TIMENT)
     Call ECR_TRACE(num$(GZINSPJMTH.TIMENT(I_TIM).PTESTA),0) From GESECRAN
    Next I_TIM
   Endif
  Endif

  If LCASE="CRECLB"
    [L]MY_STATUS = fmet GZINSPJMTH.AINSERT()
    If LIMPTRC : Call ECR_TRACE("AINSERT"-num$([L]MY_STATUS),0) From GESECRAN : Endif
  Elsif LCASE="UPDTIM" or LCASE="CRETIM" or LCASE="ADDTIM"
    [L]MY_STATUS = fmet GZINSPJMTH.AUPDATE()
    If LIMPTRC: Call ECR_TRACE("AUPDATE"-num$([L]MY_STATUS),0) From GESECRAN : Endif
  Endif

  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(317,2260,1)
    Endif
  Endif


  #======================================================

  If GZINSPJMTH <> null Then
    FreeGroup GZINSPJMTH
  Endif
  # ----------------------------------
  Kill GZINSPJMTH

Return

#-----------------------------------------------------------
# Called at the end of the import process
# Erase the content of the PJMTIMEMPI temprorary table
#-----------------------------------------------------------
$IMP_FERME

 If LIMPTRC
   Call ECR_TRACE("==========================",0) From GESECRAN
   Call ECR_TRACE("Before erase table content",0) From GESECRAN
 Endif

 # Empty table content
 If !clalev([F:PTI]) : Local File PJMTIMEMPI [PTI] : Endif
 Trbegin [F:PTI]
 Delete [F:PTI] Where 1=1
 If !fstat
  Commit
  If LIMPTRC : Call ECR_TRACE("after erase table content successfull nb of deleted records"-num$(adxdlrec),0) From GESECRAN : Endif
 Else

  If LIMPTRC : Call ECR_TRACE("after erase table content error"-num$(fstat),1) From GESECRAN : Endif
  Rollback
 Endif
 If LIMPTRC : Call ECR_TRACE("==========================",0) From GESECRAN : Endif

Return

#-----------------------------------------------------------
# Create a new collaborator entry
#-----------------------------------------------------------
$CRECLB_CRETIM
 Local Integer ILINE
 Local Integer LSTAT
 GZINSPJMTH.CLB=[F:PTI]CLB
 ILINE = fmet GZINSPJMTH.ADDLINE("TIMENT",[V]CST_ALASTPOS)
 SetInstance GZINSPJMTH.TIMENT(ILINE) With [F:PTI]
 GZINSPJMTH.TIMENT(ILINE).PTESTA    = 1
 GZINSPJMTH.TIMENT(ILINE).OPENUM    = [F:PTI]OPENUM
 If 1=1
   If [F:PTI]OPESPLNUM=0
    GZINSPJMTH.TIMENT(ILINE).OPESPLNUM = 1
   Else
    GZINSPJMTH.TIMENT(ILINE).OPESPLNUM = [F:PTI]OPESPLNUM
   Endif
 Endif
 LSTAT=fmet GZINSPJMTH.TIMENT(ILINE).ASETTEXTRA("PTEDESAXX",[F:PTI]TEXTE)
Return

#-----------------------------------------------------------
# Modifying an existing collaborator - Updating existing time
#-----------------------------------------------------------
$UPDCLB_UPDTIM
 Local Integer LSTAT
 SetInstance GZINSPJMTH.TIMENT(LINDEX) With [F:PTI]
 GZINSPJMTH.TIMENT(LINDEX).PTESTA    = 1
 GZINSPJMTH.TIMENT(LINDEX).OPENUM    = [F:PTI]OPENUM
 If 1=1
   If [F:PTI]OPESPLNUM=0
    GZINSPJMTH.TIMENT(LINDEX).OPESPLNUM = 1
   Else
    GZINSPJMTH.TIMENT(LINDEX).OPESPLNUM = [F:PTI]OPESPLNUM
   Endif
 Endif
 LSTAT=fmet GZINSPJMTH.TIMENT(LINDEX).ASETTEXTRA("PTEDESAXX",[F:PTI]TEXTE)
Return

#-----------------------------------------------------------
# Modifying an existing collaborator - Adding new time
#-----------------------------------------------------------
$UPDCLB_CRETIM
 Local Integer ILINE
 Local Integer LSTAT
 ILINE = fmet GZINSPJMTH.ADDLINE("TIMENT",[V]CST_ALASTPOS)
 SetInstance GZINSPJMTH.TIMENT(ILINE) With [F:PTI]
 GZINSPJMTH.TIMENT(ILINE).OPENUM    = [F:PTI]OPENUM
 GZINSPJMTH.TIMENT(ILINE).PTESTA    = 1
 If 1=1
   If [F:PTI]OPESPLNUM=0
    GZINSPJMTH.TIMENT(ILINE).OPESPLNUM = 1
   Else
    GZINSPJMTH.TIMENT(ILINE).OPESPLNUM = [F:PTI]OPESPLNUM
   Endif
 Endif
 LSTAT=fmet GZINSPJMTH.TIMENT(ILINE).ASETTEXTRA("PTEDESAXX",[F:PTI]TEXTE)
Return

