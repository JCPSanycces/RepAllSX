#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML des familles de compétence                                                     Version 140
#   Module CRM                             
#
#   PBLINXML    : Extraction XML du planning marketing
#   
###############################################################################################################
###############################################################################################################
Subprog PBLINXML(SZREP, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZREP
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

Local Integer ISKILLFLG
Local Char SZAUSNAME(50)

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If SZREP <> "" Then
    Read [AUS]CODUSR=SZREP
    If fstat Then
      End
    Else
      SZAUSNAME = [F:AUS]NOMUSR
    Endif
  Endif
  Call TEMPON("L") From GESECRAN
  #Génération de la feuille de style si SZXSLSHEET = STD
  If toupper(SZXSLSHEET) = "STD" Then
    SZXSLSHEET = "PBLSTD"
    Call GENSTDPBLXSL(SZREP, SZXSLSHEET)
  Endif
  Call TEMPOFF From GESECRAN
  #Extraction XML
  Gosub XMLPART1 From CRMXML140
  If SZREP = "" Then
    #Arborescence des familles de compétences
    SZHTMLTITLE = mess(162,177,1)
  Else
    #Arborescence des compétences du collaborateur : (XXX) XXXXX
    SZHTMLTITLE = mess(164,177,1) - ": (" + SZREP + ")" - SZAUSNAME
  Endif
  SZSUBPROG = "PBLINXML"
  SZAOBABREV = "PBL"
  Gosub XMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

###############################################################
#Génération de la feuille de style standard
###############################################################
Subprog GENSTDPBLXSL(SZREP, SZXSLSHEET)
Value Char SZREP
Value Char SZXSLSHEET

Local Integer ITERLEVEL
Local Integer ITERLEVEL2
Local Integer IWHERE
Local Char SZHTMLTITLE(250)
Local Char SZLABELFORFILL(250)
Local Char SZDATAFORFILL(250)
Local Char SZBUFFTOFILL(250)(2)      #Buffers d'écriture
Local Char SZADXIFS                  #Séparateurs
Local Char SZADXIRS                  #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZSUBPROG
Local Char SZAOBABREV
#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)
Local Char SZCTAOB
Local Char SZCTAOBTITLE(100)
Local Char SZCTAOBNUM(100)
Local Char SZCTLEVEL
Local Char SZCTPARENTAOB
Local Char SZCTPARENTNUM
Local Char SZTABLEBORDER
Local Char SZHEADERTEXT
Local Char SZHEADERBACK
Local Char SZHEADERBORDER
Local Char SZLINETEXT
Local Char SZLINEBACK

  ITERLEVEL = 0
  ITERLEVEL2 = 0
  Gosub MAXLEVEL1
  SP = '_'
  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  Raz SZBUFFTOFILL
  Raz SZLABELFORFILL
  Raz SZDATAFORFILL
  IWHERE = 1
  SZCTAOB = ""
  SZCTAOBTITLE = ""
  SZCTAOBNUM = ""
  SZCTLEVEL = ""
  SZCTPARENTAOB = ""
  SZCTPARENTNUM = ""
  #Fichier XSL
  SZWFNAME = SZXSLSHEET
  SZXMLFILENAME = ""
  #Ouverture du fichier XSL
  Call BUILDFICNAME(IWHERE, SZWFNAME, "xsl", SZXMLFILENAME) From CRMXML140
  If SZXMLFILENAME = "" Then
    #Erreur lors de l'ouverture du fichier XML
    IERRINF = 95
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
  Endif
  SZLINEBACK = "#E6F0F5"
  SZLINETEXT = "#006699"
  SZHEADERBORDER = "#006699"
  SZHEADERBACK = "#FF9933"
  SZHEADERTEXT = "#006699"
  SZTABLEBORDER = "#006699"
  #Modification des couleurs standards par point d'entrée
  Gosub PE_MGGCOLXSL From TRTCRMPE
  Openo SZXMLFILENAME, 0 Using [FXSL]
  #<?xml version="1.0" encoding="ISO-8859-1" standalone="yes" ?>
  SZBUFFTOFILL(0) = A + "?xml version=" + VQ + "1.0" + VQ + " encoding=" + VQ  + "ISO-8859-1" + VQ + " standalone=" + VQ + "yes" + VQ + " ?" + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">
  SZBUFFTOFILL(0) = A + "xsl:stylesheet xmlns:xsl=" + VQ + "http://www.w3.org/1999/XSL/Transform" + VQ + " version=" + VQ + "1.0" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:output method="html"/><xsl:template match="/">
  SZBUFFTOFILL(0) = A + "xsl:output method=" + VQ + "html" + VQ + "/><xsl:template match=" + VQ + "/" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<HTML><HEAD><TITLE><xsl:value-of select="//XUTILITY/XTITLE"/></TITLE><STYLE>
  SZBUFFTOFILL(0) = A + "HTML" + D + A + "HEAD" + D + A + "TITLE" + D + A + "xsl:value-of select=" + VQ + "//XUTILITY/XTITLE" + VQ + "/></TITLE><STYLE>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TABLE.cX3TableTitle {BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1;FONT-SIZE:x-small;WIDTH:100%}
  SZBUFFTOFILL(0) = "TABLE.cX3TableTitle {BORDER-STYLE:solid;BORDER-COLOR:" + SZTABLEBORDER + ";BORDER-WIDTH:1;FONT-SIZE:x-small;WIDTH:100%}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1;FONT-SIZE:x-small}
  SZBUFFTOFILL(0) = "TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:#FFFFFF;BORDER-WIDTH:1;FONT-SIZE:x-small}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TD.cX3TDTitle {FONT-STYLE:NORMAL;FONT-WEIGHT:BOLD;TEXT-ALIGN:CENTER;COLOR:#006699;BACKGROUND-COLOR:#FF9933}
  SZBUFFTOFILL(0) = "TD.cX3TDTitle {FONT-STYLE:NORMAL;FONT-WEIGHT:BOLD;TEXT-ALIGN:CENTER;COLOR:" + SZHEADERTEXT + ";BACKGROUND-COLOR:" + SZHEADERBACK + "}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  If SZREP = "" Then
    #TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#E6F0F5;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
    SZBUFFTOFILL(0) = "TD.cX3TDLine {BORDER-STYLE:solid;BORDER-COLOR:" + SZLINETEXT + ";BORDER-WIDTH:1;FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:" + SZLINEBACK + "}"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  Else
    #TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#E6F0F5;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
    SZBUFFTOFILL(0) = "TD.cX3TDLine {BORDER-STYLE:solid;BORDER-COLOR:" + SZLINETEXT + ";BORDER-WIDTH:1;FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:#E6F0F5}"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #TD.cX3TDLineR {TEXT-DECORATION:LINE-THROUGH;FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#FA8062;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
    SZBUFFTOFILL(0) = "TD.cX3TDLineR {TEXT-DECORATION:LINE-THROUGH;BORDER-STYLE:solid;BORDER-COLOR:" + SZLINETEXT + ";BORDER-WIDTH:1;FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:#FA8062}"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #TD.cX3TDLineG {FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#98FB98;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
    SZBUFFTOFILL(0) = "TD.cX3TDLineG {BORDER-STYLE:solid;BORDER-COLOR:" + SZLINETEXT + ";BORDER-WIDTH:1;FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:#98FB98}"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  Endif
  #TD.cX3TDBlank {FONT-STYLE:NORMAL;COLOR:#FFFFFF}
  SZBUFFTOFILL(0) = "TD.cX3TDBlank {FONT-STYLE:NORMAL;COLOR:#FFFFFF}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TD.cX3TDArrow {FONT-STYLE:NORMAL;COLOR:#FFFFFF;BACKGROUND-COLOR:#FFFFFF;BORDER-LEFT-STYLE:solid;BORDER-LEFT-COLOR:#808080;BORDER-LEFT-WIDTH:1;BORDER-BOTTOM-STYLE:solid;BORDER-BOTTOM-COLOR:#808080;BORDER-BOTTOM-WIDTH:1}
  SZBUFFTOFILL(0) = "TD.cX3TDArrow {FONT-STYLE:NORMAL;COLOR:#FFFFFF;BACKGROUND-COLOR:#FFFFFF;BORDER-LEFT-STYLE:solid;BORDER-LEFT-COLOR:#808080;BORDER-LEFT-WIDTH:1;BORDER-BOTTOM-STYLE:solid;BORDER-BOTTOM-COLOR:#808080;BORDER-BOTTOM-WIDTH:1}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #</STYLE></HEAD><BODY><DIV STYLE="WIDTH:100%">
  SZBUFFTOFILL(0) = "</STYLE></HEAD><BODY><DIV STYLE=" + VQ + "WIDTH:100%" + VQ + ">"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<TABLE CELLSPACING="5" CELLPADDING="5" CLASS="cX3TableTitle">
  SZBUFFTOFILL(0) = A + "TABLE CELLSPACING=" + VQ + "5" + VQ + " CELLPADDING=" + VQ + "5" + VQ + " CLASS=" + VQ + "cX3TableTitle" + VQ + ">"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<TR><TD CLASS="cX3TDTitle"><xsl:value-of select="//XUTILITY/XTITLE"/></TD></TR></TABLE><P></P></DIV><DIV>
  SZBUFFTOFILL(0) = A + "TR" + D + A + "TD CLASS=" + VQ + "cX3TDTitle" + VQ + D + A + "xsl:value-of select=" + VQ + "//XUTILITY/XTITLE" + VQ + "/></TD></TR></TABLE><P></P></DIV><DIV>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<TABLE CELLSPACING="5" CELLPADDING="5" CLASS="cX3Table">
  SZBUFFTOFILL(0) = A + "TABLE CELLSPACING=" + VQ + "5" + VQ + " CELLPADDING=" + VQ + "5" + VQ + " CLASS=" + VQ + "cX3Table" + VQ + ">"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:apply-templates select="//XRECORD"/></TABLE></DIV></BODY></HTML></xsl:template>
  SZBUFFTOFILL(0) = "<xsl:apply-templates select=" + VQ + "//XRECORD" + VQ + "/></TABLE></DIV></BODY></HTML></xsl:template>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:template match="//XRECORD">
  SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XRECORD" + VQ + ">"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:choose><xsl:when test="@LEVEL = 0">
  SZBUFFTOFILL(0) = "<xsl:choose><xsl:when test=" + VQ + "@LEVEL = 0" + VQ + ">"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:choose>
  SZBUFFTOFILL(0) = "<xsl:choose>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:when test="@T = 'B'"><TR><TD COLSPAN="2" CLASS="cX3TDLine"><BR/><xsl:value-of select="./XFIELD"/><BR/><BR/></TD></TR></xsl:when>
  SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'B'" + VQ + "><TR><TD COLSPAN=" + VQ + "2" + VQ 
&                 + " CLASS=" + VQ + "cX3TDLine" + VQ + "><BR/><xsl:value-of select=" + VQ + "./XFIELD" + VQ
&                 + "/><BR/><BR/></TD></TR></xsl:when>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:when test="@T = 'R'"><TR><TD COLSPAN="2" CLASS="cX3TDLine"><BR/><xsl:value-of select="./XFIELD"/><BR/><BR/></TD></TR></xsl:when>
  SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'R'" + VQ + "><TR><TD COLSPAN=" + VQ + "2" + VQ 
&                 + " CLASS=" + VQ + "cX3TDLineR" + VQ + "><BR/><xsl:value-of select=" + VQ + "./XFIELD" + VQ
&                 + "/><BR/><BR/></TD></TR></xsl:when>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:when test="@T = 'G'"><TR><TD COLSPAN="2" CLASS="cX3TDLine"><BR/><xsl:value-of select="./XFIELD"/><BR/><BR/></TD></TR></xsl:when>
  SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'G'" + VQ + "><TR><TD COLSPAN=" + VQ + "2" + VQ 
&                 + " CLASS=" + VQ + "cX3TDLineG" + VQ + "><BR/><xsl:value-of select=" + VQ + "./XFIELD" + VQ
&                 + "/><BR/><BR/></TD></TR></xsl:when>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #</xsl:choose>
  SZBUFFTOFILL(0) = "</xsl:choose>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #</xsl:when>
  SZBUFFTOFILL(0) = "</xsl:when>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  For ITERLEVEL = 1 To IMAXLEVEL
    #<xsl:when test="@LEVEL = 1">
    SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@LEVEL = " + num$(ITERLEVEL) + VQ + "><TR>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    For ITERLEVEL2 = 1 To ITERLEVEL-1
      #<TD CLASS="cX3TDBlank"><xsl:text>-</xsl:text></TD>
      SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDBlank" + VQ + "><xsl:text>-</xsl:text></TD>"
      Wrseq SZBUFFTOFILL(0)  Using [FXSL]
      #<TD CLASS="cX3TDBlank"><xsl:text>-</xsl:text></TD>
      SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDBlank" + VQ + "><xsl:text>-</xsl:text></TD>"
      Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    Next
    #<TD CLASS="cX3TDBlank"><xsl:text>-</xsl:text></TD>
    SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDBlank" + VQ + "><xsl:text>-</xsl:text></TD>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #<TD CLASS="cX3TDArrow"><xsl:text>-</xsl:text></TD>
    SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDArrow" + VQ + "><xsl:text>-</xsl:text></TD>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #<xsl:choose>
    SZBUFFTOFILL(0) = "<xsl:choose>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #<xsl:when test="@T = 'B'"><TD ROWSPAN="2" COLSPAN="2" CLASS="cX3TDLine"><xsl:value-of select="./XFIELD"/></TD><TR></xsl:when>
    SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'B'" + VQ + "><TD ROWSPAN=" + VQ + "2" + VQ + " COLSPAN=" + VQ + "2" + VQ + " CLASS=" + VQ + "cX3TDLine" + VQ + "><xsl:value-of select=" + VQ + "./XFIELD" + VQ + "/></TD></xsl:when>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #<xsl:when test="@T = 'R'"><TD ROWSPAN="2" COLSPAN="2" CLASS="cX3TDLine"><xsl:value-of select="./XFIELD"/></TD><TR></xsl:when>
    SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'R'" + VQ + "><TD ROWSPAN=" + VQ + "2" + VQ + " COLSPAN=" + VQ + "2" + VQ + " CLASS=" + VQ + "cX3TDLineR" + VQ + "><xsl:value-of select=" + VQ + "./XFIELD" + VQ + "/></TD></xsl:when>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #<xsl:when test="@T = 'G'"><TD ROWSPAN="2" COLSPAN="2" CLASS="cX3TDLine"><xsl:value-of select="./XFIELD"/></TD><TR></xsl:when>
    SZBUFFTOFILL(0) = "<xsl:when test=" + VQ + "@T = 'G'" + VQ + "><TD ROWSPAN=" + VQ + "2" + VQ + " COLSPAN=" + VQ + "2" + VQ + " CLASS=" + VQ + "cX3TDLineG" + VQ + "><xsl:value-of select=" + VQ + "./XFIELD" + VQ + "/></TD></xsl:when>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    #</xsl:choose><TR>
    SZBUFFTOFILL(0) = "</xsl:choose><TR>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    For ITERLEVEL2 = 1 To ITERLEVEL
      #<TD CLASS="cX3TDBlank"><xsl:text>-</xsl:text></TD>
      SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDBlank" + VQ + "><xsl:text>-</xsl:text></TD>"
      Wrseq SZBUFFTOFILL(0)  Using [FXSL]
      #<TD CLASS="cX3TDBlank"><xsl:text>-</xsl:text></TD>
      SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDBlank" + VQ + "><xsl:text>-</xsl:text></TD>"
      Wrseq SZBUFFTOFILL(0)  Using [FXSL]
    Next
    #</TR></TR></xsl:when>
    SZBUFFTOFILL(0) = "</TR></TR></xsl:when>"
    Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  Next
  #</xsl:choose></xsl:template></xsl:stylesheet>
  SZBUFFTOFILL(0) = "</xsl:choose></xsl:template></xsl:stylesheet>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #On ferme le fichier XML
  Openo Using [FXSL]
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
End

###########################################################
$DOCOREXML
Local Char SZPBLTYPE
Local Char SZMASTERK
Local Char SZMASTERP
Local Char SZMASTERNUM
Local Char SZMASTERDES(200)
Local Integer IMASTERFOUND
Local Char SZTREEDES(200)
Local Integer ITREEFOUND
Local Integer ILEVEL
Local Integer ITERRAZ
Local Char SZLEVELK(30)(1000)
Local Char SZLEVELP(30)(1000)

  Raz SZLEVELP
  Raz SZLEVELK
  ILEVEL = 0
  ITERRAZ = 0
  SZMASTERK = ""
  While 1
    IMASTERFOUND = 0
    Filter [PBL] Where [F:PBL]PAEGRPNUM = "" and [F:PBL]NUM > SZMASTERK
    For [PBL]PBL1
      SZMASTERNUM = [F:PBL]NUM
      SZMASTERK = [F:PBL]NUM
      SZMASTERP = [F:PBL]PAEGRPNUM
      # FGR 23/09/2009 : X3SUIVI58024
      #SZMASTERDES = [F:PBL]GRPPBLDES
      Call LECTEXTRA(SZMASTERDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      IMASTERFOUND = 1
      Break
    Next
    Filter [PBL]
    If IMASTERFOUND = 0 Then
      Break
    Endif
    If SZREP = "" Then
      SZPBLTYPE = "B"
    Else
      ISKILLFLG = 0
      Filter [PBR] Where [F:PBR]GRPPBLNUM = SZMASTERK and [F:PBR]REPNUM = SZREP and [F:PBR]STTFLG = 0
      For [PBR]PBR2
        ISKILLFLG = 1
      Next
      Filter [PBR]
      If ISKILLFLG Then
        SZPBLTYPE = "G"
      Else
        SZPBLTYPE = "R"
      Endif
    Endif
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXRECORD + " LEVEL=" + VQ + num$(ILEVEL) + VQ + " T=" + VQ + SZPBLTYPE + VQ + " K=" + VQ + SZMASTERNUM + VQ + " P=" + VQ + SZMASTERP + VQ + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXFIELD + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZDATAFORFILL = SZMASTERDES
    Gosub WRITEXML3 From CRMXML140
    Raz SZLEVELP
    Raz SZLEVELK
    SZLEVELP(0) = SZMASTERK
    ILEVEL = 1
    Gosub EXTRACTPBL
  Wend
Return

################################
$EXTRACTPBL
  ITREEFOUND = 0
  Filter [PBL] Where [F:PBL]PAEGRPNUM = SZLEVELP(ILEVEL - 1) and [F:PBL]NUM > SZLEVELK(ILEVEL)
  For [PBL]PBL1
    SZLEVELK(ILEVEL) = [F:PBL]NUM
    SZLEVELP(ILEVEL) = [F:PBL]NUM
    # FGR 23/09/2009 : X3SUIVI58024
    #SZTREEDES = [F:PBL]GRPPBLDES
    Call LECTEXTRA(SZTREEDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    ITREEFOUND = 1
    Break
  Next
  Filter [PBL]
  If ITREEFOUND Then
    If SZREP = "" Then
      SZPBLTYPE = "B"
    Else
      ISKILLFLG = 0
      Filter [PBR] Where [F:PBR]GRPPBLNUM = SZLEVELK(ILEVEL) and [F:PBR]REPNUM = SZREP and [F:PBR]STTFLG = 0
      For [PBR]PBR2
        ISKILLFLG = 1
      Next
      Filter [PBR]
      If ISKILLFLG Then
        SZPBLTYPE = "G"
      Else
        SZPBLTYPE = "R"
      Endif
    Endif
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXRECORD + " LEVEL=" + VQ + num$(ILEVEL) + VQ + " T=" + VQ + SZPBLTYPE + VQ + " K=" + VQ + SZLEVELK(ILEVEL) + VQ + " P=" + VQ + SZLEVELP(ILEVEL - 1) + VQ + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXFIELD + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZDATAFORFILL = SZTREEDES
    Gosub WRITEXML3 From CRMXML140
    ILEVEL += 1
    Gosub EXTRACTPBL
  Else
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZXRECORD + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    ILEVEL -= 1
    If ILEVEL = 0 Then
      Return
    Else
      For ITERRAZ = ILEVEL + 1 To dim(SZLEVELK)-1
        SZLEVELK(ITERRAZ) = ""
      Next
      Gosub EXTRACTPBL
    Endif
  Endif
Return

###########################################################
$MAXLEVEL1
Local Integer IMAXLEVEL
Local Char SZMASTERK
Local Char SZMASTERP
Local Char SZMASTERNUM
Local Char SZMASTERDES(200)
Local Integer IMASTERFOUND
Local Char SZTREEDES(200)
Local Integer ITREEFOUND
Local Integer ILEVEL
Local Integer ITERRAZ
Local Char SZLEVELK(30)(1000)
Local Char SZLEVELP(30)(1000)

  Raz SZLEVELP
  Raz SZLEVELK
  ILEVEL = 0
  ITERRAZ = 0
  SZMASTERK = ""
  IMAXLEVEL = 0
  While 1
    IMASTERFOUND = 0
    Filter [PBL] Where [F:PBL]PAEGRPNUM = "" and [F:PBL]NUM > SZMASTERK
    For [PBL]PBL1
      SZMASTERNUM = [F:PBL]NUM
      SZMASTERK = [F:PBL]NUM
      SZMASTERP = [F:PBL]PAEGRPNUM
      # FGR 23/09/2009 : X3SUIVI58024
      #SZMASTERDES = [F:PBL]GRPPBLDES
      Call LECTEXTRA(SZMASTERDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      IMASTERFOUND = 1
      Break
    Next
    Filter [PBL]
    If IMASTERFOUND = 0 Then
      Break
    Endif
    Raz SZLEVELP
    Raz SZLEVELK
    SZLEVELP(0) = SZMASTERK
    ILEVEL = 1
    Gosub MAXLEVEL2
  Wend
Return

################################
$MAXLEVEL2
  ITREEFOUND = 0
  Filter [PBL] Where [F:PBL]PAEGRPNUM = SZLEVELP(ILEVEL - 1) and [F:PBL]NUM > SZLEVELK(ILEVEL)
  For [PBL]PBL1
    SZLEVELK(ILEVEL) = [F:PBL]NUM
    SZLEVELP(ILEVEL) = [F:PBL]NUM
    # FGR 23/09/2009 : X3SUIVI58024
    #SZTREEDES = [F:PBL]GRPPBLDES
    Call LECTEXTRA(SZTREEDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    ITREEFOUND = 1
    Break
  Next
  Filter [PBL]
  If ITREEFOUND Then
    ILEVEL += 1
    If ILEVEL > IMAXLEVEL Then
      IMAXLEVEL = ILEVEL
    Endif
    Gosub MAXLEVEL2
  Else
    ILEVEL -= 1
    If ILEVEL = 0 Then
      Return
    Else
      For ITERRAZ = ILEVEL + 1 To dim(SZLEVELK)-1
        SZLEVELK(ITERRAZ) = ""
      Next
      Gosub MAXLEVEL2
    Endif
  Endif
Return
