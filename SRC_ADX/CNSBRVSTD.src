#<AdxTL>@(#)1.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Consultation : BRV - consultation des révision budgétaire
#   Action       : CONSBRV
#   Fenêtres     : FCNSBRV / DCNSBRV
#   Ecrans concernés : CONSBRV1, CONSBRV2 / CRITBRV
#   Description : Consultations des révisions budgétaires
#
#--------------------------------------------------------------------------

Local Char PARAM(250)(1..10)
PARAM(1)  = "0"        :# Numéro de révision
PARAM(2)  = "1"        :# Type de révision (enveloppe/budget/ligne)
PARAM(3)  = "JHA"      :# Société
PARAM(4)  = "VSA"      :# Site
PARAM(5)  = "20080101" :# Date début
PARAM(6)  = "20091231" :# Date fin
PARAM(7)  = ""         :# Projet
PARAM(8)  = ""         :# Enveloppe
PARAM(9)  = ""         :# ACCNUM Numéro de ligne
PARAM(10) = ""         :# Compte
Call GCONSULT("BRV","",PARAM) From GCONSULT
End

#----- Pour Dmd 62872 ----#
Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(2)<>2 End Endif
Local File =APPLI+".ACTIV"    [ACV]
Read [ACV]CODACT="GDD"
If !fstat & [F:ACV]FLACT<>2 End Endif
Call VALGTC(APPLI,"BRV") From SUBGTC
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LECTURE"      : Gosub LECTURE
 When Default
Endcase
Return

$OUVRE
If !clalev([F:BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([F:BVD]) : Local File BUDREVDET  [BVD] : Endif
If !clalev([F:PRJ]) : Local File PROJET     [PRJ] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If !clalev([F:BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
#
If !clalev([F:ENV2]) : Local File ENVELOPPE [ENV2] : Endif
If !clalev([F:ENF2]) : Local File ENVFIY    [ENF2] : Endif
If !clalev([F:BUD2]) : Local File BUD       [BUD2] : Endif
#
Local Char CRITBRV(250),CRITENV(250),CRITENF(250),CRITBUD(250),INFO(250),WFIL(250)
Local Char SOCIETE(GLONCPY),SITE(GLONFCY)
Local Char LISTENV(GLONENV)(1..max(1,nbrecord([ENV])))
Local Integer OKTYP
Local Integer DOLIG,BR
Local Char    DEBNUM, FINNUM
Local Decimal REALISE
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3

Raz [M:BRV1],[M:BRV2]
Gosub DEFCRIT
Return

$DEFCRIT
# Valeurs par défaut
Default Mask [M:BRV1]
# Paramètres
For I=1 To dim(PARAM)
 Case I
  When 1 : #Numéro de révision
   If PARAM(I)<>""
    Call LECTURE("BRV",PARAM(I),"") From CONTOBJ
    [M:BRV1]SELNUM=PARAM(I)
   Endif
  When 2 : #Type révision
   If PARAM(I)<>""
    [M:BRV1]SELTYP=val(PARAM(I))
    [M:BRV1]ALLTYP=1
   Endif
  When 3 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BRV1]CPY = PARAM(I)
     If [M:BRV1]FCY<>""
      Call LECTURE("FCY",[M:BRV1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BRV1]CPY : [M:BRV1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 4 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BRV1]FCY = PARAM(I)
     [M:BRV1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
   ##
   If PARAM(8)<>"" :#Enveloppe
    Call LECTURE("ENV",PARAM(8),"") From CONTOBJ
    Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
    If [F:BUP]LEV=1
     [M:BRV1]FCY = ""
    Endif
   Endif
   ##
  When 5 : # Date début
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BRV1]DATDEB = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:BRV1]DATDEB = PARAM(I)
    Endif
    Call AS_DATDEB([M:BRV1]DATDEB)
    Call C_DATDEB([M:BRV1]DATDEB)
   Endif
  When 6 : # Date fin
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BRV1]DATFIN = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:BRV1]DATFIN = PARAM(I)
    Endif
    Call C_DATFIN([M:BRV1]DATFIN)
   Endif
  When 7 : # Projet
   If PARAM(I)<>""
    Call LECTURE("PRJ",PARAM(I),"") From CONTOBJ
    If !fstat : [M:BRV1]PRJ = PARAM(I) : Endif
   Endif
  When 8 : # Enveloppe
   If PARAM(I)<>""
    Call LECTURE("ENV",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BRV1]ENVSTR = PARAM(I)
     [M:BRV1]ENVEND = PARAM(I)
     Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
     [M:BRV1]COA=[F:BUP]COA
    Endif
   Endif
  When 9 : # ACCNUM Numéro de ligne
   If PARAM(I)<>""
    Read [BUD]BUD1 = val(PARAM(I))
    If !fstat
     [M:BRV1]SELACCNUM=val(PARAM(I))
    Endif
   Endif
  When 10 : # Compte
   If PARAM(I)<>""
    If [M:BRV1]ENVSTR<>""
     Read [GAC]GAC0 = [M:BRV1]COA;PARAM(I)
     If !fstat : [M:BRV1]SELACC=PARAM(I) : Endif
    Else
     J=0
     Filter [GAC] Where ACC=PARAM(I)
      For [GAC]GAC0
       J+=1 : Break
      Next
     Filter [GAC]
     If J : [M:BRV1]SELACC=PARAM(I) : Endif
    Endif
   Endif
 Endcase
Next I
Return

$LECTURE
CTLACS=1
If [M]CPY="" : Return : Endif

#Les filtres
Gosub LOAD_FILTRE
#-- dans les traitements standards uniquement :  appel au spécifique
If PROGSPE<>""
 ACTION="FILTRE" : Gosub ACTION From =PROGSPE
Endif

J=1
For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS = 0 : Endif
 Endif
 If OKACS=1
  LISTENV(J)=[F:ENV]ENV
  J+=1
 Endif
Next

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
 Filter [BRV] Where evalue(WFIL) & evalue(CRITBRV) Order By Key BRV0
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
 Filter [BRV] Where evalue(WFIL) & evalue(CRITBRV) Order By Key BRV0 Desc
Endif
#Raz du masque si 1ère ou dernière page
If CHGPAG<>2 & CHGPAG<>-2
 Raz [M:BRV2]
Endif

[M:BRV2]NBLIG =0
For [BRV]BRV0
  If find([F:BRV]ENV,LISTENV(1..(J-1)))
   OKTYP=0
   #---------------------
   #Il faut aussi afficher les révisions multiples qui compte les révisions du type demandé,
   #voir de l'objet demandé si l'on vient directement depuis l'objet
   If [F:BRV]TYP=4 & [M]ALLTYP=1 & [M]SELTYP<>4
    Filter [BVD] Where NUMREV=[F:BRV]NUM & TYP=[M]SELTYP
     For [BVD]BVD0
      Case [M]SELTYP
       When 1 : If [F:BVD]TYP=1 :  OKTYP=1 : Break : Endif
       When 2 : If [F:BVD]TYP=2 :  OKTYP=1 : Break : Endif
       When 3 : If [F:BVD]TYP=3 :  OKTYP=1 : Break : Endif
#85095
#       When 2 : If [F:BVD]FIY>=[M]DFIY & [F:BVD]FIY<=[M]FFIY :
#        OKTYP=1 : Break : Endif
#       When 3
#        If [M]SELACC<>""
#         If [F:BVD]ACC=[M]SELACC & [F:BVD]FIY>=[M]DFIY & [F:BVD]FIY<=[M]FFIY
#          OKTYP=1 : Break
#         Endif
#        Elsif [F:BVD]FIY>=[M]DFIY & [F:BVD]FIY<=[M]FFIY
#         OKTYP=1 : Break
#        Endif
#        If [M]SELACCNUM<>0
#         If [F:BVD]ACCNUM=[M]SELACCNUM : OKTYP=1 : Break : Endif
#        Endif
      Endcase
     Next
    Filter [BVD]
   Else
    OKTYP=1
   Endif
   #--------------------
   If OKTYP
    BR=0
    If NBLU=1
     NBLU=2
    Endif
    If CHGPAG>0
     If NOL>=MAXLIG-1 : SUITE = 2 : BR = 1 : Break : Endif
     NOL += 1
     If NOL=0
      DEBNUM = [F:BRV]NUM
     Endif
     FINNUM = [F:BRV]NUM
    Else
     If NOL<=0 : RETOUR = 2 : BR = 1 : Break : Endif
     NOL -= 1
     If NOL=MAXLIG-1
      FINNUM = [F:BRV]NUM
     Endif
     DEBNUM = [F:BRV]NUM
    Endif
    nolign = NOL+1
    Gosub REMPLIT
#85095
#    Case [F:BRV]TYP
#     When 1,4
#      INFO += [F:BRV]NUM+chr$(10)
#      Gosub REMPLIT
#     When 2
#      If [F:BRV]FIY>=[M]DFIY & [F:BRV]FIY<=[M]FFIY
#       INFO += [F:BRV]NUM+chr$(10)
#       Gosub REMPLIT
#      Endif
#     When 3
#      DOLIG=1
#      Read [BUD]BUD1 = [F:BRV]ACCNUM
#      If !fstat
#       If [M]DFIY>[F:BUD]FIY | [M]FFIY<[F:BUD]FIY
#        DOLIG=0
#       Endif
#       If [M]SELACC<>""
#        If [F:BUD]ACC<>[M]SELACC : DOLIG=0 : Endif
#       Endif
#       If DOLIG
#        INFO += [F:BRV]NUM+chr$(10)
#        Gosub REMPLIT
#       Endif
#      Endif
#    Endcase
   Endif
 Endif
Next
Filter [BRV]
If [M:BRV2]NBLIG=0
 #Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Else
 If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
 Gosub COLORIZE
Endif
Return

$COLORIZE
For I=0 To [M:BRV2]NBLIG-1
 Chgstl [M:BRV2]AMTASK(I) With "GDD2G"
 Affzo [M:BRV2]AMTASK(I)
Next
Return

$REMPLIT
[M:BRV2]NUM(nolign-1) = [F:BRV]NUM
[M:BRV2]TYP(nolign-1) = [F:BRV]TYP
[M:BRV2]ENV(nolign-1) = [F:BRV]ENV
[M:BRV2]FIY(nolign-1) = [F:BRV]FIY
Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;[F:BRV]FIY
If !fstat
 [M:BRV2]INTFIY(nolign-1) = [F:FIY]DESSHO
Endif
[M:BRV2]ACCNUM(nolign-1) = [F:BRV]ACCNUM
[M:BRV2]ACC(nolign-1)    = [F:BRV]ACC
[M:BRV2]AMT(nolign-1)    = [F:BRV]AMT
[M:BRV2]AMTASK(nolign-1) = [F:BRV]AMTASK
If [F:BRV]TYP<>4
 [M:BRV2]AMTPRS(nolign-1) = [F:BRV]AMTPRS
 [M:BRV2]AMTPNV(nolign-1) = [F:BRV]AMTPNV
 [M:BRV2]AMTRAL(nolign-1) = [F:BRV]AMTRAL

 Call LEC_ENV([F:BRV]ENV) From CPTLEC
 Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

 #Montant réalisé et solde
 Case [F:BRV]TYP
  When 1
   Call CAL_REALISE(1,[F:BRV]ENV,0,INDENV,"",REALISE) From SUBBRVR
   Read [ENV2]ENV0 = [F:BRV]ENV
   If !fstat
    [M:BRV2]SOLDE(nolign-1) = [F:ENV2]AMTENV-REALISE
   Endif
  When 2
   Call CAL_REALISE(2,[F:BRV]ENV,[F:BRV]FIY,INDENV,"",REALISE) From SUBBRVR
   Read [ENF2]ENF0 = [F:BRV]ENV;[F:BRV]FIY
   If ! fstat
    [M:BRV2]SOLDE(nolign-1) = [F:ENF2]AMTBUDFIY-REALISE
   Endif
  When 3
   Call CAL_REALISE(3,[F:BRV]ENV,[F:BRV]FIY,INDENV,[F:BRV]ACCNUM,REALISE) From SUBBRVR
   Read [BUD2]BUD1 = [F:BRV]ACCNUM
   If ! fstat
    [M:BRV2]SOLDE(nolign-1)  = [F:BUD2]AMT(0)-REALISE
   Endif
 Endcase
 [M:BRV2]REALISE(nolign-1)=[L]REALISE
Endif
[M:BRV2]ENT(nolign-1)    = [F:BRV]ENT
[M:BRV2]STA(nolign-1)    = [F:BRV]STA
[M:BRV2]RENTAB(nolign-1) = [F:BRV]RENTAB
[M:BRV2]RENTXT(nolign-1) = [F:BRV]RENTXT
[M:BRV2]CREDAT(nolign-1) = [F:BRV]CREDAT
[M:BRV2]CREUSR(nolign-1) = [F:BRV]CREUSR
[M:BRV2]UPDDAT(nolign-1) = [F:BRV]UPDDAT
[M:BRV2]UPDUSR(nolign-1) = [F:BRV]UPDUSR
[M:BRV2]NBLIG +=1
Return

$LOAD_FILTRE
WFIL="1=1"
Case CHGPAG
 When 3 : #Rafraichissement
  WFIL -='& NUM>="'+DEBNUM+'"'
 When 2 : #Suite
  WFIL -='& NUM>"'+FINNUM+'"'
 When -2 : #Retour
  WFIL -='& NUM<"'+DEBNUM+'"'
Endcase

CRITBRV="1=1"
CRITENV="1=1"
CRITBUD="1=1"
CRITLIG="1=1"

If [M]SELNUM<>""
 CRITBRV = 'NUM="'+[M]SELNUM+'"'
Endif

If [M]ALLTYP=1
 Case [M]SELTYP
  When 1,2,3 : CRITBRV -= '& (TYP='+num$([M]SELTYP)-'| TYP=4)'
  When 4     : CRITBRV -= '& TYP=4'
 Endcase
Endif

If [M]CPY<>""
 SOCIETE=[M]CPY
 If [M]FCY<>""
  CRITENV -='& FCY="'+[M]FCY+'"'
  SITE=[M]FCY
 Else
  Local Char LISTFCY(GLONFCY)(1..GNBSITE) #V7.1_92892
  Local Integer SOC,J
  SOC=find([M]CPY,GSOC(1..GNBSOC))
  J=1
  If SOC
   For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
    LISTFCY(J)=[F:FCY]FCY
    J+=1
   Next
  Endif
  CRITENV -='& (FCY="'+[M]CPY+'" | find(FCY,LISTFCY(1..'+num$(J-1)+')))'
  Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
  SITE=[F:CPY]MAIFCY
 Endif
Else
 SITE=[M]FCY
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE=[F:FCY]LEGCPY
 CRITENV -='& FCY="'+[M]FCY+'"'
Endif

If [M]DATDEB<>[0/0/0] & [M]DATFIN<>[0/0/0]
 CRITBRV -='& ((UPDDAT<>[0/0/0] & UPDDAT>=['+format$(GFMD,[M]DATDEB)+'] & UPDDAT<=['+format$(GFMD,[M]DATFIN)+'])'
 CRITBRV -='| (CREDAT>=['+format$(GFMD,[M]DATDEB)+'] & CREDAT<=['+format$(GFMD,[M]DATFIN)+']))'
Endif

If [M]PRJ<>""
 CRITENV -='& PRJ="'+[M]PRJ+'"'
Endif
If [M]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M]ENTMSTR+'" & ENTMNA<="'+[M]ENTMEND+'"'
Endif
If [M]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M]ENTASTR+'" & ENTAPP<="'+[M]ENTAEND+'"'
Endif
If [M]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif

If [M]SELACC<>""
 CRITLIG -='& [F:BUD]ACC="'+[M]ACC+'"'
Endif
If [M]SELACCNUM<>0
 CRITLIG -='& [F:BUD]ACCNUM='+num$([M]SELACCNUM)
Endif
Return

##-----------------------------------------##
## Etiquettes écrans CONSBRV1&2 & CRITBRV  ##
##-----------------------------------------##

Subprog IB_NBLIG
If [M]TYP(nolign-1)<>4
 Raz GBOUT1
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
Call C_CPY(VALEUR) From CONSSUB
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If [M]CPY<>""
 Local Libelle LEDTYPGEN,LEDTYPANA
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 [M]LEDTYP=LEDTYPANA
 Call LECPLAN([M]CPY,LEDTYPANA,[M]COA) From CPTDIV
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]DFIY=EXERCICE
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]FFIY=EXERCICE
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Grizo [M]SELTYP : Else : Actzo [M]SELTYP : Endif
End

Subprog AS_SELTYP(VALEUR)
Variable Integer VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : End : Endif
End

Subprog C_PRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call CONSACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If [M]FCY=""
   If [F:ENV]FCY<>[M]CPY
    Local Integer SOC,J
    Local Char LISTFCY(GLONFCY)(1..GNBSITE)
    SOC=find([M]CPY,GSOC(1..GNBSOC))
    J=1
    If SOC
     For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
      LISTFCY(J)=[F:FCY]FCY
      J+=1
     Next
    Endif
    If !find([F:ENV]FCY,LISTFCY(1..J))
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Else
   If [F:ENV]FCY<>[M]FCY
    Local Integer SITE
    SITE=find([M]FCY,GSITE(1..GNBSITE))
    If SITE
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
 Endif
Endif
End

Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If [M]FCY=""
   If [F:ENV]FCY<>[M]CPY
    Local Integer SOC,J
    Local Char LISTFCY(GLONFCY)(1..GNBSITE)
    SOC=find([M]CPY,GSOC(1..GNBSOC))
    J=1
    If SOC
     For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
      LISTFCY(J)=[F:FCY]FCY
      J+=1
     Next
    Endif
    If !find([F:ENV]FCY,LISTFCY(1..J))
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Else
   If [F:ENV]FCY<>[M]FCY
    Local Integer SITE
    SITE=find([M]FCY,GSITE(1..GNBSITE))
    If SITE
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif
 If VALEUR=[M]ENVSTR
  Call LECTURE("ENV",VALEUR,"") From CONTOBJ
  Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
  [M]COA=[F:BUP]COA
 Endif
Endif
End

