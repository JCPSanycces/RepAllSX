#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------
# TRTRETSAL : Préchargement salarié fiche de rétroactivité
#----------------------------------------------------------
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal VALEUR
SAVACT = GACTION : GACTION = "TRTRETSAL"
PARMSK(1) = ""
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = ""
PARMSK(5) = ""
PARMSK(6) = ""
PARMSK(7) = ""
PARMSK(8) = ""
PARMSK(9) = ""
PARMSK(10) = ""
PARMSK(11) = "2"
Call SAISIE_NUM([L]VALEUR, [L]PARMSK, "TRTRETSAL", "TRTRETSAL", "XYTRTRETSAL") From GSAISIE
GACTION = SAVACT
End

$ACTION
Case [L]ACTION
    When "OUVRE"  : Gosub OUVRE
    When "DEBUT"  : Gosub DEBUT
    When "SORTIE" : Gosub SORTIE
    When "OK"     : Gosub OK
Endcase
Return



$OUVRE
Local Integer I, TYP
Local Char NOMVAR(250)
Local Mask TRTRETSAL [DIA]
Raz [M:DIA]
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################################################
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

[L]I = 1    : # Pour sauter PARAM(1) = ORIGINE

For [L]NOMVAR = "CPY", "FCY", "SRV", "PRF", "MATDEB", "MATFIN", "POP", "CRITERE", "DATAVTEFF", "RETTYP"
    [L]I += 1
    If [L]PARAM([L]I) <> ""
        [L]TYP = evalue("type([M:DIA]"+[L]NOMVAR+")")
        Case [L]TYP
            When 1, 2, 4, 5, 6, 7, 9
                Assign "[M:DIA]"+[L]NOMVAR With val([L]PARAM([L]I))
            When 3
                Assign "[M:DIA]"+[L]NOMVAR With [L]PARAM([L]I)
            When Default
                Assign "[M:DIA]"+[L]NOMVAR With [L]PARAM([L]I)
        Endcase
    Endif
Next

[M:DIA]ALLCPY = 1 + ( [M:DIA]CPY = "" )
[M:DIA]ALLFCY = 1 + ( [M:DIA]FCY = "" )
[M:DIA]ALLSRV = 1 + ( [M:DIA]SRV = "" )
[M:DIA]ALLPRF = 1 + ( [M:DIA]PRF = "" )

Affzo [M:DIA]
Setmok [M:DIA] With 0

Call AS_DATAVTEFF([M]DATAVTEFF)

Return

$OK
[L]I = 1
[L]PARAM([L]I) = "OK"
For [L]NOMVAR = "CPY", "FCY", "SRV", "PRF", "MATDEB", "MATFIN", "POP", "CRITERE", "DATAVTEFF"
    [L]I += 1
    [L]PARAM([L]I) = evalue("[M:DIA]"+[L]NOMVAR)
Next
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTRETSAL) 26/11/2010 09:37:07 (FL)
######################################################################################
Subprog AS_DATAVTEFF(VALEUR)
Variable Date    VALEUR
If [M:DIA]RETTYP = 2
    Grizo [M:DIA]DATAVTEFF
Else
    Actzo [M:DIA]DATAVTEFF
Endif

# Cependant je préfère griser la date pour éviter un grand n'importe quoi dans les saisies :
# Fiche avec date d'effet au 01/09/10 sur laquelle on veut traiter des contrats en effet au 01/12/10
Grizo [M:DIA]DATAVTEFF

End
