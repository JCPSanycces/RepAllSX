####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0CACCEDEF_LISCCE
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_CCE1 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE2 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE3 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE4 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE5 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE6 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE7 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE8 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE9 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE10 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE11 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE12 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE13 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE14 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE15 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE16 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE17 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE18 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE19 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub INIT_CCE20 From WMC1CACCEDEF_LISCCE : Gosub TESTALLSTAT
Gosub AINIT From WMC0CACCEDEF_LISCCE : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0CACCEDEF_LISCCE
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0CACCEDEF_LISCCE
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



