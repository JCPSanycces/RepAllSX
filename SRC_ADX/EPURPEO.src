#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS EPURATION dans les Achats Ordres de sous-traitance   #
#                                                                       #
#    Le fichier maître est ouvert par le superviseur avec               #
#    l'abréviation "F1"                                                 #
#    Tous les fichiers liés (voir paramétrage) sont gérés par           #
#    le superviseur. Seuls les fichiers avec un lien direct             #
#    avec le fichier maître peuvent être liés dans le paramétrage       #
#-----------------------------------------------------------------------#
# Issue 90275 GA 07/2013 créé en V6
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE_EPURE
    When "HISTO"       : Gosub EPURE
    When "EPURE"       : Gosub EPURE
    When "FERME"       : Gosub FERME_EPURE
Endcase
Return
#################################################################################
#    OUVRE_EPURE                                                                #
#################################################################################
$OUVRE_EPURE
Case [F:AHI]COD
    When "SCO"    :    Gosub OUVRE_EPU_PEO
Endcase
Return

#################################################################################
#    EPURE                                                                      #
#################################################################################
$EPURE
Case [F:AHI]COD
    When "SCO"    :    Gosub EPURE_PEO
Endcase
Return
#################################################################################
#    FERME_EPURE                                                                #
#################################################################################
$FERME_EPURE
Case [F:AHI]COD
    When "SCO"    :    Gosub FERME_EPU_PEO
Endcase
Return

#################################################################################
#    Epuration des EO                                                           #
# Formule d'épuration PEO :      SCOSTA = 4 & SCOTRKFLG = 6                     #
# ------------------------------------------------------------------------------#
#    SCO : Actions liées à l'épuration des EO                                   #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_PEO
Gosub DCLVAR
If HISTO
    If OKEPU=0
      #-- Historisation
           If clalev([F:SCI])=0 : Local File =[L]APPLI+".SCOITM"      [SCI] : Endif  # Issue 90275 GA 07/2013
           If clalev([F:SCO])=0 : Local File =[L]APPLI+".SCOSRV"      [SCS] : Endif
           If clalev([F:SCM])=0 : Local File =[L]APPLI+".SCOMAT"      [SCM] : Endif
           #-----------------------#
           # Fichier historisation #
           #-----------------------#
          #----- Issue 90275 GA 07/2013 Historiser SCOTRK
            If filinfo(filpath("FIL","SCOTRK","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("SCOTRK",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="SCOTRK"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:SCK1])=0 : Local File =[L]HISAPL+".SCOTRK"    [SCK1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser CPTANALIN
            If filinfo(filpath("FIL","CPTANALIN","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("CPTANALIN",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:CAL1])=0 : Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
    Else
     #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
           If clalev([F:SCI])=0 : Local File =[L]HISAPL+".SCOITM"      [SCI] : Endif  # Issue 90275 GA 07/2013
           If clalev([F:SCO])=0 : Local File =[L]HISAPL+".SCOSRV"      [SCS] : Endif
           If clalev([F:SCM])=0 : Local File =[L]HISAPL+".SCOMAT"      [SCM] : Endif
           If clalev([F:TXC])=0 : Local File =[L]HISAPL+".TEXCLOB"     [TXC] : Endif
           If clalev([F:SCK])=0 : Local File =[L]HISAPL+".SCOTRK"      [SCK] : Endif  # Issue 90275 GA 07/2013
    Endif
Else
   #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SCI])=0 : Local File =[L]APPLI+".SCOITM"      [SCI] : Endif         # Issue 90275 GA 07/2013
    If clalev([F:SCO])=0 : Local File =[L]APPLI+".SCOSRV"      [SCS] : Endif
    If clalev([F:SCM])=0 : Local File =[L]APPLI+".SCOMAT"      [SCM] : Endif
    If clalev([F:SCK])=0 : Local File =[L]APPLI+".SCOTRK"      [SCK] : Endif         # Issue 90275 GA 07/2013
Endif

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub OUVRE_EPU_CST From EPURCST

Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un EO                                     #
#-------------------------------------------------------------------------------#
$EPURE_PEO

WCLE=[F:F1]SCONUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

# --- Supression des tables associées à l'EO

# --- Boucle de supression des tables associées aux articles lancés
Columns [SCI] (SCONUM, SCILIN)
For [F:SCI] Where SCONUM=[F:F1]SCONUM
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="SCI" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
  # Issue 90275 GA 07/2013 Suivis d'EO V6
    WABRFIC="SCI" : Gosub HISTO_EPURE_SCK
    If !WOK  Break : Endif
Next
Columns [SCI]
If WOK=0 : Return : Endif

# --- Boucle de supression des tables associées aux opérations
Columns [SCS] (SCONUM, SCILIN, SCSLIN, SCSTEX)
For [F:SCS] Where SCONUM=[F:F1]SCONUM
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="SCS" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
  # Issue 90275 GA 07/2013 Suivis d'EO V6
    WABRFIC="SCS" : Gosub HISTO_EPURE_SCK
    If !WOK  Break : Endif
Next
Columns [SCS]
If WOK=0 : Return : Endif

# --- Boucle de supression des tables associées aux matières
Columns [SCM] (SCONUM, SCILIN, SCMLIN, CPNITMREF, SCMTEX)
For [F:SCM] Where SCONUM=[F:F1]SCONUM
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="SCM" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
  # Issue 90275 GA 07/2013 Suivis d'EO V6
    WABRFIC="SCM" : Gosub HISTO_EPURE_SCK
    If !WOK  Break : Endif
Next
Columns [SCM]
If WOK=0 : Return : Endif

# Issue 90275 GA 07/2013 Historisation des tables de coûts liées à l'EO
Gosub HISTO_EPURE_SCONUM
If WOK=0 : Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_PEO
If clalev([F:SCI]) : Close Local File [SCI]  : Endif # Issue 90275 GA 07/2013
If clalev([F:SCO]) : Close Local File [SCS]  : Endif
If clalev([F:SCM]) : Close Local File [SCM]  : Endif

If clalev([F:SCK]) : Close Local File [SCK]  : Endif # Issue 90275 GA 07/2013
If clalev([F:SCK1]): Close Local File [SCK1] : Endif # Issue 90275 GA 07/2013

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub FERME_EPU_CST From EPURCST

Return


#-------------------------------------------------------#
# Positionnement du répertoire et déclaration variables #
#-------------------------------------------------------#
$DCLVAR
#----- Variables locales -----#
Local Char    WNUMTEX (12), WTYP(4), WMESSAGE(100), WCLE(GLONVCR)
Local Integer WCLEI
Local Char    NEWTEX(250), OLDTEX(250)
Local Integer WRETOUR
Local Integer WAPPRUL
  # Issue 90275 GA 07/2013 Sections analytiques V6
Local Integer WOK
Local Char    WCRITERE(100)
Local Char    WABRFIC(4)
Local Integer WVCRTYP,          WVCRTYP2
Local Char    WVCRNUM(GLONVCR), WVCRNUM2(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Char    WCPLCLE(30)
Local Char    WCLEFIC(50),      WCLEFIC2(50)
Local Integer WNBLNK
Return

#########################################################
$CRETAB_HISTO
#--- Création des tables non liées
NEWTAB = TABLE
Call CRETABLE(APPLI,HISAPL,TYPDBA,NEWTAB,COEFF,1) From CREHISTO
Return


#--------------------------------------------------------------------------------#
# Historisation / Epuration des tables associées aux lignes document VCRTYP=36   #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_SCONUM                                      # Issue 90275 GA 07/2013
#-----
Raz [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
[L]WVCRTYP=36 : [L]WVCRNUM=[F:F1]SCONUM
#-----

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub EPURE_CST From EPURCST

#-----
If [L]TRACEDET
  Call ECR_TRACE("-- WO - Tables VCRNUM"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#--------------------------------------------------------------------------------#
# Historisation / Epuration des comptes et sections associés aux lignes document #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_CAL                 # Issue 90275 GA 07/2013 Sections analytiques V6
#-----
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
#-----
[L]WVCRTYP = 36
Case WABRFIC
  When "SCI" : [L]WVCRNUM=[F:SCI]SCONUM    : [L]WVCRLIN=[F:SCI]SCILIN
  When "SCS":  [L]WVCRNUM=[F:SCO]SCONUM    : [L]WVCRLIN=[F:SCO]SCILIN
               [L]WVCRSEQ=[F:SCO]SCSLIN
  When "SCM" : [L]WVCRNUM=[F:SCM]SCONUM    : [L]WVCRLIN=[F:SCM]SCILIN
               [L]WVCRSEQ=[F:SCM]SCMLIN
Endcase
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
If OKHIS
  Read [CAL] CAL0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
  If !fstat & ![L]SIMUL
    [F:CAL1]=[F:CAL]
    If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
    If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
    Write [CAL1]
    If fstat
      Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [CAL] Where ABRFIC=[L]WABRFIC
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
&                  & VCRSEQ=[L]WVCRSEQ
&                  & CPLCLE=[L]WCPLCLE
&                  & ANALIG=1
  If fstat
    Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- CPTANALIN"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return


#--------------------------------------------------------------------------------#
# Historisation / Epuration des suivis associés aux lignes document              #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_SCK                 # Issue 90275 GA 07/2013 Suivis d'EO V6
#-----
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
#-----
[L]WVCRTYP = 36
Case WABRFIC
  When "SCI" : [L]WVCRNUM=[F:SCI]SCONUM    : [L]WVCRLIN=[F:SCI]SCILIN
  When "SCS":  [L]WVCRNUM=[F:SCO]SCONUM    : [L]WVCRLIN=[F:SCO]SCILIN
               [L]WVCRSEQ=[F:SCO]SCSLIN
  When "SCM" : [L]WVCRNUM=[F:SCM]SCONUM    : [L]WVCRLIN=[F:SCM]SCILIN
               [L]WVCRSEQ=[F:SCM]SCMLIN
Endcase
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
If OKHIS
  Read [SCK] SCK0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
  If !fstat & ![L]SIMUL
    [F:SCK1]=[F:SCK]
    If dim([F:SCK1]CREHISDAT)>0  [F:SCK1]CREHISDAT=date$    : Endif
    If dim([F:SCK1]CREHISUSR)>0  [F:SCK1]CREHISUSR=[V]GUSER : Endif
    Write [SCK1]
    If fstat
      Call ECR_TRACE("$SCOTRK"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [SCK] Where ABRFIC=[L]WABRFIC
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
&                  & VCRSEQ=[L]WVCRSEQ
  If fstat
    Call ECR_TRACE("$SCOTRK"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- SCOTRK"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return
