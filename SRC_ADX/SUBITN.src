##########################################################################################################
Subprog C_HDTMACSRE(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif

Local Integer IFOUND

  IFOUND = 0
  #Vérifie que le parc saisie correspond bien au contexte de la demande.
  Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRM]ITNGRU = [M:ITN0]MACGRU
  For [SRM]
    If [F:SRM]MACNUM = VALEUR Then
      IFOUND = 1
      Break
    Endif
  Next
  Filter [SRM]
  If !IFOUND Then
    #Le parc indiqué ne correspond pas aux caractéristiques de l'intervention. Saisie refusée.
    GMESSAGE = mess(241,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_HDTMACSRE(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF

  IERRINF = 0
  Read [MAC]MAC0=VALEUR
  If fstat Then
    Raz [F:MAC]                          # FGR 03/01/2012 : X3SUIVI78440
    [M:ITN8]HDTMACSET(nolign-1) = ""
  Else
    [M:ITN8]HDTMACSET(nolign-1) = [F:MAC]MACPDTCOD
  Endif
  [M:ITN8]HDTMACSRE(nolign-1) = VALEUR
  #Détermination du montant facturable par défaut
  Gosub MONTANT_FACT_DEFAUT  # FGR 29/01/2009 : X3SUIVI41698
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:ITN8]HDTMACSRE(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1), PITHDT(nolign-1)
  Affzo [M:ITN8]HDTMACSRE(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:ITN8]PITHDT(nolign-1)
  Endif
End

##########################################################################################################
Subprog AM_HDTCPN(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF

  IERRINF = 0
  [M:ITN8]HDTCPN(nolign-1) = VALEUR
  #Détermination du montant facturable par défaut
  Gosub MONTANT_FACT_DEFAUT  # FGR 29/01/2009 : X3SUIVI41698
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:ITN8]HDTCPN(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1), PITHDT(nolign-1)
  Affzo [M:ITN8]HDTCPN(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:ITN8]PITHDT(nolign-1)
  Endif
End

##########################################################################################################
Subprog C_HDTCPN(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif

Local Integer IFOUND

  IFOUND = 0
  Filter [SRN] Where [F:SRN]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRN]MACNUM = [M:ITN8]HDTMACSRE(nolign-1) and [F:SRN]TPYFLG = 0
  For [SRN]
    If [F:SRN]CPNITM = VALEUR Then
      IFOUND = 1
      Break
    Endif
  Next
  Filter [SRN]
  If !IFOUND Then
    #Le composant indiqué ne provient pas de l'onglet Parc concerné de la demande de service associée. Saisie refusée.
    GMESSAGE = mess(242,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AS_HDTTYP(VALEUR)
Variable Integer VALEUR

  If [M:ITN8]HDTITM(nolign-1) <> "" Then
    If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
      If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
        If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
          mkstat = 2
          End
        Endif
        If GITN8HDTISSISS(nolign-1) > 0 Then
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
  GMENLOC(1) = 1
  GMENLOC(5) = 1
  If [M:ITN8]HDTITM(nolign-1) <> "" Then
    End
  Endif
  If GDEFHDTTYP < 1 Then
    VALEUR = 2
    End
  Endif
  If GDEFHDTTYP > 3 Then
    VALEUR = 2
    End
  Endif
  VALEUR = GDEFHDTTYP + 1
End

##########################################################################################################
Subprog AM_HDTTYP(VALEUR)
Variable Integer VALEUR

  [M:ITN8]HDTITM(nolign-1) = ""
  [M:ITN8]HDTUOM(nolign-1) = ""
  [M:ITN8]HDTQTY(nolign-1) = 0
  [M:ITN8]HDTAVA(nolign-1) = 0
  [M:ITN8]HDTAVAUOM(nolign-1) = ""
  [M:ITN8]HDTINV(nolign-1) = 2
  [M:ITN8]HDTAMT(nolign-1) = 0
  If [M:ITN0]SRVDEMNUM = "" Then
    [M:ITN8]HDTCUR(nolign-1) = ""
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      [M:ITN8]HDTCUR(nolign-1) = ""
    Else
      [M:ITN8]HDTCUR(nolign-1) = [F:SRE]SRECUR
    Endif
  Endif
  [M:ITN8]HDTTYP(nolign-1) = VALEUR
  Affzo [M:ITN8]HDTITM(nolign-1), HDTUOM(nolign-1), HDTQTY(nolign-1), HDTAVA(nolign-1), HDTAVAUOM(nolign-1)
  Affzo [M:ITN8]HDTAMT(nolign-1), HDTCUR(nolign-1), HDTINV(nolign-1)
End

##########################################################################################################
Subprog C_HDTITM(VALEUR)
Variable Char    VALEUR()

Local Char SZHDTITM(GLONITM)
Local Char SZSTOFCY(GLONFCY)
Local Integer IITFOK

  If VALEUR <> "" Then
    If nolign > [M:ITN0]NBRSREHDT Then
      #Le nombre maximum de consommations saisissables pour une demande de service est atteint.
      GMESSAGE = mess(17,177,1)
      GERR = 2
      mkstat = 2
      End
    Endif
  Endif
  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Endif
  If [F:ITM]HDKITMTYP <> [M:ITN8]HDTTYP(nolign-1) Then
    #Cet article ne correspond au type indiqué. Saisie refusée.
    GMESSAGE = mess(198,182,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  If [M:ITN8]HDTTYP(nolign-1) <> 2 Then
    If [F:ITM]STOMGTCOD > 1 Then
      #Cet article est géré en stock. Saisie refusée.
      GMESSAGE = mess(189,177,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  # FGR 26/05/2010 : X3SUIVI64415 --> Etape n°3 : Contrôle du statut de l'article (début)
  If [F:ITM]ITMSTA > 1 Then
    GMESSAGE = mess(3,196,1) - "(" + mess([F:ITM]ITMSTA,246,1) + ")"
    If [F:ITM]ITMSTA = 6 Then
      mkstat = 2
      End
    Else
      GERR = 3
    Endif
  Endif
  # FGR 26/05/2010 : X3SUIVI64415 --> Etape n°3 : Contrôle du statut de l'article (fin)

  # FGR 15/10/2010 : X3SUIVI67190 (début) trop tôt
  #Contrôle de l'article site
  #SZHDTITM = VALEUR
  #Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  #If fstat Then
  #  SZSTOFCY = ""
  #Else
  #  SZSTOFCY = [F:SRE]STOFCY
  #Endif
  #IITFOK = 1
  #Gosub CHECKITF From SUBSREB4
  #If IITFOK = 0 Then
  #  End
  #Endif
  # FGR 15/10/2010 : X3SUIVI67190 (fin)
End

##########################################################################################################
Subprog AM_HDTITM(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Char    SECTION(type([M:ITN8]CCE1)-10)
Local Integer INOL
Local Integer J

  INOL = nolign-1
  IERRINF = 0
  #On complète le parc concerné si besoin
  If [M:ITN8]HDTMACSRE(nolign-1) = "" Then
    Gosub ADDHDTMAC From SUBITNB3
  Endif
  [M:ITN8]HDTSTOFCY(nolign-1) = ""
  Read [ITM]ITM0=VALEUR
  If fstat Then
    [M:ITN8]HDTUOM(nolign-1) = ""
    [M:ITN8]HDTSTU(nolign-1) = ""
  Else
    [M:ITN8]HDTUOM(nolign-1) = [F:ITM]SAU
    [M:ITN8]HDTSTU(nolign-1) = [F:ITM]STU
    [M:ITN8]STOMGTCOD(nolign-1) = [F:ITM]STOMGTCOD
  Endif
  [M:ITN8]HDTISSQTY(nolign-1) = 0
  [M:ITN8]HDTSTOISS(nolign-1) = 1
  [M:ITN8]HDTQTY(nolign-1) = 0
  [M:ITN8]HDTAVA(nolign-1) = 0
  [M:ITN8]HDTAVAUOM(nolign-1) = ""
  [M:ITN8]HDTINV(nolign-1) = 2
  [M:ITN8]HDTAMT(nolign-1) = 0
  If [M:ITN0]SRVDEMNUM = "" Then
    [M:ITN8]HDTCUR(nolign-1) = ""
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      [M:ITN8]HDTCUR(nolign-1) = ""
    Else
      [M:ITN8]HDTCUR(nolign-1) = [F:SRE]SRECUR
      If [M:ITN8]HDTTYP(nolign-1) = 2 Then
        If [M:ITN8]STOMGTCOD(nolign-1) > 1 Then
          [M:ITN8]HDTSTOFCY(nolign-1) = [F:SRE]STOFCY
          If [F:ITM]STOISSDEF = 2 Then
            [M:ITN8]HDTSTOISS(nolign-1) = 2
          Endif
        Endif
      Endif
    Endif
  Endif
  [M:ITN8]MANAMTFLG(nolign-1) = 1
  [M:ITN8]HDTITM(nolign-1) = VALEUR
  [M:ITN8]ITMREF(nolign-1) = [M:ITN8]HDTITM(nolign-1)
  # FGR 15/10/2010 : X3SUIVI67190 (début) c'est pas là
  #Sorties de stock
  #Call INIZONSOR("ITN8", [M:ITN8]HDTITM(nolign-1), [M:ITN8]HDTSTOFCY(nolign-1), INOL, 24, [M:ITN0]TRSCOD , "") From STKECR
  # FGR 15/10/2010 : X3SUIVI67190 (fin)
  #Sections analytiques à la ligne
  For J = 1 To GNBDIE
   GAXE = J
   Call INISEC(SECTION,"HDTITN",J) From TRTX3CPT
   Assign "[M:ITN8]CCE"+num$(J)+"(INOL)" With SECTION
  Next J
  #Détermination du montant facturable par défaut
  Gosub MONTANT_FACT_DEFAUT  # FGR 29/01/2009 : X3SUIVI41698
  Affzo [M:ITN8]HDTITM(nolign-1), HDTUOM(nolign-1), HDTQTY(nolign-1), HDTAVA(nolign-1), HDTAVAUOM(nolign-1)
  Affzo [M:ITN8]HDTAMT(nolign-1), HDTCUR(nolign-1), HDTSTOFCY(nolign-1)
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:ITN8]HDTAMTINV(nolign-1), PITHDT(nolign-1), HDTINV(nolign-1)
  Affzo [M:ITN8]HDTAMTINV(nolign-1), HDTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:ITN8]PITHDT(nolign-1)
  Endif
  Affzo [M:ITN8]HDTMACSRE(nolign-1)
End

##########################################################################################################
Subprog AM_HDTDONDAT(VALEUR)
Variable Date    VALEUR

Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT

  If VALEUR = [00/00/00] Then
    [M:ITN8]HDTDONHOU(nolign-1) = 0
    [M:ITN8]BHDTDONHOU(nolign-1) = "0000"
  Else
    [M:ITN8]HDTDONHOU(nolign-1) = time
    Call SECTOHOU([M:ITN8]HDTDONHOU(nolign-1), [M:ITN8]BHDTDONHOU(nolign-1)) From CRMUTIL140
    #Sortie de stock
    If [M:ITN8]HDTTYP(nolign-1) = 2 Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        [M:ITN8]HDTISSQTY(nolign-1) = [M:ITN8]HDTSTUQTY(nolign-1)
      Endif
    Endif
  Endif
  #Propose une durée réelle par défaut
  If [M:ITN8]HDTTYP(nolign-1) = 3 Then
    If [M:ITN8]SPGTIMHOU(nolign-1) = 0 Then
      If [M:ITN8]SPGTIMMNT(nolign-1) = 0 Then
        Call DEFSPGTIM([M:ITN0]BPC, [M:ITN8]HDTQTY(nolign-1), [M:ITN8]HDTUOM(nolign-1), [M:ITN8]HDTITM(nolign-1), ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
        [M:ITN8]SPGTIMHOU(nolign-1) = ISPGTIMHOU
        [M:ITN8]SPGTIMMNT(nolign-1) = ISPGTIMMNT
      Endif
    Endif
  Endif
  [M:ITN8]HDTDONDAT(nolign-1) = VALEUR
  Affzo [M:ITN8]HDTDONDAT(nolign-1), BHDTDONHOU(nolign-1), SPGTIMHOU(nolign-1), SPGTIMMNT(nolign-1)
End

##########################################################################################################
Subprog AM_BHDTDONHOU(VALEUR)
Variable Char    VALEUR()

Local Integer IHDTDONHOU

  IHDTDONHOU = 0
  If VALEUR = "0000" Then
    [M:ITN8]HDTDONHOU(nolign-1) = 0
  Else
    Call HOUTOSEC(val(left$(VALEUR, 2)), val(mid$(VALEUR, 3, 2)), IHDTDONHOU) From CRMUTIL140
    [M:ITN8]HDTDONHOU(nolign-1) = IHDTDONHOU
  Endif
  [M:ITN8]BHDTDONHOU(nolign-1) = VALEUR
  Affzo [M:ITN8]BHDTDONHOU(nolign-1)
End

##########################################################################################################
Subprog AM_HDTAMTINV(VALEUR)
Variable Decimal VALEUR

  [M:ITN8]MANAMTFLG(nolign-1) = 2
  [M:ITN8]HDTAMTINV(nolign-1) = VALEUR
  Affzo [M:ITN8]HDTAMTINV(nolign-1)
End

##########################################################################################################
Subprog AS_HDTQTY(VALEUR)
Variable Decimal VALEUR

  # FGR 13/10/2010 : X3SUIVI68214 : Non modifiable si sortie de stock faite
  Gosub NO_MODIF_SSTOK From SUBITNB3
End

##########################################################################################################
Subprog AM_HDTQTY(VALEUR)
Variable Decimal VALEUR

Local Integer IERRINF
Local Integer INOL

  INOL = nolign-1
  [M:ITN8]HDTQTY(INOL) = VALEUR
  IERRINF = 0
  Call RUNTARIF([M:ITN8]HDTITM(INOL), [M:ITN8]HDTQTY(INOL), [M:ITN8]HDTUOM(INOL), INOL) From SUBITNB2
  nolign = INOL + 1
  #Détermination du montant facturable par défaut
  Gosub MONTANT_FACT_DEFAUT  # FGR 29/01/2009 : X3SUIVI41698
  Affzo [M:ITN8]1-99
End

##########################################################################################################
Subprog AM_HDTUOM(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Integer INOL

  INOL = nolign-1
  [M:ITN8]HDTUOM(INOL) = VALEUR
  IERRINF = 0
  Call RUNTARIF([M:ITN8]HDTITM(INOL), [M:ITN8]HDTQTY(INOL), [M:ITN8]HDTUOM(INOL), INOL) From SUBITNB2
  nolign = INOL + 1
  If GERR Then
    End
  Endif
  #Détermination du montant facturable par défaut
  Gosub MONTANT_FACT_DEFAUT  # FGR 29/01/2009 : X3SUIVI41698
  Affzo [M:ITN8]1-99
End

##########################################################################################################
$MONTANT_FACT_DEFAUT
  # FGR 29/01/2009 : X3SUIVI41698
  #Détermination du montant facturable par défaut
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Call AMOUNT(1, "ITN8", nolign-1, [M:ITN8]HDTAMT(nolign-1), [M:ITN8]HDTINV(nolign-1), [M:ITN8]HDTAMTINV(nolign-1), [M:ITN8]PITHDT(nolign-1), [M:ITN8]INVPITFLG(nolign-1), IERRINF) From TRTAMOUNT
  Else
    Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
    Local Decimal INVPITFLG   # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

    IPITHDT = 0
    INVPITFLG = 0
    Call AMOUNT(1, "ITN8", nolign-1, [M:ITN8]HDTAMT(nolign-1), [M:ITN8]HDTINV(nolign-1), [M:ITN8]HDTAMTINV(nolign-1), IPITHDT, INVPITFLG, IERRINF) From TRTAMOUNT
  Endif
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
  Endif
Return

##########################################################################################################
Subprog C_SPGTIMMNT(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 59 Then
    #Le nombre de minutes ne peut pas être supérieur à 59. Saisie refusée.
    GMESSAGE = mess(248,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

