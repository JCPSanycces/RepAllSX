  Gosub AS_CCEX
End

##########################################################################################################
Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()

Local Integer AXE

  AXE = 20
  Gosub C_CCEX
End

##########################################################################################################
$D_CCEX
  #------------------------------------#
  # Initialisation commune aux 20 axes #
  #------------------------------------#
  If AXE > GNBDIE Then
    Return
  Endif
  Call INIT_CCE(VALEUR,AXE,"HDTITN","",0) From TRTX3CPT  # FGR 12/03/2014 : X3SUIVI97785 au lieu de "HDT"
Return

##########################################################################################################
$AS_CCEX
  #----------------------------------#
  # Avant saisie commune aux 20 axes #
  #----------------------------------#
  Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

##########################################################################################################
$C_CCEX
  #-----------------------------#
  # Contrôle commun aux 20 axes #
  #-----------------------------#
  Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:ITN1]DAT) From TRTX3CPT
Return

##########################################################################################################
Subprog IB_CCN

  If [M:ITN0]BPC = "" Then
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog B6_RER(VALEUR)
Variable Char    VALEUR()

Local Char    PARMSK(250)(1..20) , SAVACT(20)

  # FGR 24/07/2009 : X3SUIVI56702
  GBCRMFLGNEW = 1
  SAVACT = GACTION : GACTION = "GOBJETC1"
  Call OBJET_CHAR(VALEUR,"RRS","") From GOBJET
  GACTION = SAVACT
  mkstat = 4
End

######################################################################################
Subprog AV_SAT(VALEUR)
Variable Char    VALEUR()
 If GFMT<>"" Then
    Chgfmt [M:ITN3]SAT With "K:"+GFMT
  Else
    Chgfmt [M:ITN3]SAT With "-K:1X"
  Endif
End

##########################################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

##########################################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Integer NOL

  # FGR 10/04/2015 : X3SUIVI105605
  Local File SERREQUEST [SRE]
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  # La date de contrôle est toujours celle de la demande de service parce que ce sont les mêmes consommations,
  # d'un côté comme de l'autre.
  NOL = nolign-1
  Call CTLECCVAL(VALEUR, [M:ITN8]HDTSTOFCY(NOL), [M:ITN8]HDTITM(NOL), 4, "", [F:SRE]CREDAT, LRET) From STKSOR
  If LRET >= 1 Then
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

  # FGR 10/04/2015 : X3SUIVI105605
  Raz WECCVALMAJ
  Raz WECCVALMIN
  Raz PITM
  # si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:ITN8]HDTITM(nolign-1) Then
    Read [ITM]ITM0=[M:ITN8]HDTITM(nolign-1)
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:ITN8]ECCVALMIN(nolign-1) = WECCVALMIN
    Affzo [M:ITN8]ECCVALMIN(nolign-1)
  Elsif VALEUR = "" and [M:ITN8]ECCVALMIN(nolign-1) <> "" Then
    Raz [M:ITN8]ECCVALMIN(nolign-1)
    Affzo [M:ITN8]ECCVALMIN(nolign-1)
  Endif
End

##########################################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

##########################################################################################################
$ECCVALMAJMIN_ENABLE
  # FGR 01/04/2015 : X3SUIVI105605
  If [M:ITN8]HDTTYP(nolign-1) <> 2 Then
    mkstat = 2
  Endif
  If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
    mkstat = 2
  Endif
Return

