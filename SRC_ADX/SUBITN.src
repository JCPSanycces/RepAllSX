##########################################################################################################
Subprog AM_SPGTIMHOU(VALEUR)
Variable Decimal VALEUR

  If [M:ITN8]HDTDONDAT(nolign-1) = [00/00/00] Then
    [M:ITN8]HDTDONDAT(nolign-1) = date$
    [M:ITN8]HDTDONHOU(nolign-1) = time
    Call SECTOHOU([M:ITN8]HDTDONHOU(nolign-1), [M:ITN8]BHDTDONHOU(nolign-1)) From CRMUTIL140
  Endif
  [M:ITN8]SPGTIMHOU(nolign-1) = VALEUR
  Affzo [M:ITN8]SPGTIMHOU(nolign-1), HDTDONDAT(nolign-1), BHDTDONHOU(nolign-1)
End

##########################################################################################################
Subprog AM_SPGTIMMNT(VALEUR)
Variable Decimal VALEUR

  If [M:ITN8]HDTDONDAT(nolign-1) = [00/00/00] Then
    [M:ITN8]HDTDONDAT(nolign-1) = date$
    [M:ITN8]HDTDONHOU(nolign-1) = time
    Call SECTOHOU([M:ITN8]HDTDONHOU(nolign-1), [M:ITN8]BHDTDONHOU(nolign-1)) From CRMUTIL140
  Endif
  [M:ITN8]SPGTIMMNT(nolign-1) = VALEUR
  Affzo [M:ITN8]SPGTIMMNT(nolign-1), HDTDONDAT(nolign-1), BHDTDONHOU(nolign-1)
End

##########################################################################################################
Subprog AS_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    If [M:ITN8]HDTITM(nolign-1) <> "" Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
          If GITN8HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  If [M:ITN8]HDTITM(nolign-1) = "" Then
    mkstat = 2
    End
  Else
    If [M:ITN8]HDTTYP(nolign-1) = 2 Then
      If [M:ITN8]STOMGTCOD(nolign-1) = 1 Then
        mkstat = 2
        End
      Endif
    Else
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTSTOISS(VALEUR)
Variable Integer VALEUR

  If [M:ITN8]HDTITM(nolign-1) = "" Then
    mkstat = 2
  Else
    If [M:ITN8]HDTTYP(nolign-1) = 2 Then
      If [M:ITN8]STOMGTCOD(nolign-1) = 1 Then
        mkstat = 2
      Else
        # FGR 26/01/2011 : X3SUIVI70842 Test incomplet. Il ne faut pas se limiter à test le flag.
        #                  Il faut regarder aussi la quantité sortie (HDTISSISS). Si elle est supérieure à 0
        #                  on n'a pas le droit ; Il faut passer par le bouton "Modification sortie".
        #                  Sinon, rien n'a été fait avec les stocks. On peut décocher.
        # FGR 05/08/2010 : X3SUIVI66063 (début)
        #If [M:ITN8]HDTSTOISS(nolign-1) = 2 and [M:ITN8]SAVSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTSTOISS(nolign-1) = 2 and [M:ITN8]SAVSTOISS(nolign-1) = 2  and [M:ITN8]HDTISSISS(nolign-1) > 0 Then
          # Si la sortie de stock est déjà enregistrée on n'a pas le droit de cliquer ici
          mkstat = 2
        Endif
        # FGR 05/08/2010 : X3SUIVI66063 (fin)
      Endif
    Else
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_HDTSTOISS(VALEUR)
Variable Integer VALEUR

Local Integer ILIGNE
Local Integer LRET           # FGR 10/04/2015 : X3SUIVI105605

  # FGR 09/12/2010 : X3SUIVI69775
  ILIGNE = nolign-1
  Call CTL_HDTDONDAT_HDTSTOFCY([M:ITN8]HDTTYP(ILIGNE), VALEUR, [M:ITN8]HDTDONDAT(ILIGNE), [M:ITN8]HDTSTOFCY(ILIGNE)) From SUBSREB4
  If mkstat Then
    zonsui = "[M:ITN8]HDTDONDAT(nolign-1)"
    End
  Endif
  # FGR 10/04/2015 : X3SUIVI105605 (début)
  If dim([M:ITN8]ECCVALMAJ) >= 0 Then
    If [M:ITN8]HDTTYP(ILIGNE) = 2 Then
      Local File SERREQUEST [SRE]
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      # La date de contrôle est toujours celle de la demande de service parce que ce sont les mêmes consommations,
      # d'un côté comme de l'autre.
      NOL = nolign-1
      Call CTLECCVAL([M:ITN8]ECCVALMAJ(ILIGNE), [M:ITN8]HDTSTOFCY(ILIGNE), [M:ITN8]HDTITM(ILIGNE), 4, "", [F:SRE]CREDAT, LRET) From STKSOR
      If LRET >= 1 Then
        mkstat = 2
      Endif
    Endif
  Endif
  # FGR 10/04/2015 : X3SUIVI105605 (fin)
End

##########################################################################################################
Subprog AM_HDTSTOISS(VALEUR)
Variable Integer VALEUR

Local Integer NOL      # FGR 05/08/2010 : X3SUIVI66063
Local Integer WRET     # FGR 05/08/2010 : X3SUIVI66063

  NOL = nolign-1       # FGR 05/08/2010 : X3SUIVI66063
  If VALEUR = 2 Then
    If [M:ITN8]HDTTYP(NOL) = 2 Then                             # FGR 05/08/2010 : X3SUIVI66063 : Ca manquait
      If [M:ITN8]HDTDONDAT(NOL) <> [00/00/00] Then              # FGR 05/08/2010 : X3SUIVI66063 : Ca manquait
        [M:ITN8]HDTISSQTY(NOL) = [M:ITN8]HDTSTUQTY(NOL)
      Endif
    Endif
  Else
    # FGR 05/08/2010 : X3SUIVI66063 (début)
    #[M:ITN8]HDTISSQTY(nolign-1) = 0
    Call DELSTOSORW(NOL, NOL, "ITN8", [M:ITN8]HDTSTOFCY(NOL), WRET) From STKSOR
    If WRET <> 0 Then
      VALEUR = 2
      mkstat = 2
      GERR = 2
      End
    Endif
    Raz [M:ITN8]HDTISSQTY(NOL)    # FGR 05/08/2010 : X3SUIVI66063
    Raz [M:ITN8]HDTISSISS(NOL)    # FGR 05/08/2010 : X3SUIVI66063
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
  Endif
  [M:ITN8]HDTSTOISS(nolign-1) = VALEUR
  Affzo [M:ITN8]HDTSTOISS(nolign-1)
End

##########################################################################################################
Subprog C_NBLIG
Local Integer ISLOCKED
Local Integer IMESSREP
Local Integer INOL
Local Integer INOL2
Local Integer IERR
Local Integer NUMLIGNE

  If nolign >= dim([M:ITN8]HDTCPN) Then
    End
  Endif
  If status = 68 or status = 83 or status = 65 Then
    #La suppression de ligne de consommation est une possibilité désactivée.
    If GREP = "" Then
      #Vérification du lock superviseur
      ISLOCKED = 0
      Call ISAOBLOCKED([M:ITN0]ITNSYM, ISLOCKED) From CRMUTIL140
      If ISLOCKED Then
        #Modification en cours sur un autre poste.
        GMESSAGE = mess(10,100,1)
        GERR = 2
        mkstat = 2
        End
      Endif
      #Si la demande est lockée, on ne vas pas plus loin
      Gosub AVMCTLLOCKITN From SUBITNB3
      If !IUPDSRE Then
        mkstat = 2
        End
      Endif
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (début) : ça c'est pas bon
    #On vérifie que la consommation a supprimer ne comporte pas de sortie de stock
    #If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
    #  #Des sorties de stock ont été réalisées pour cette consommation. Suppression impossible.
    #  GMESSAGE = mess(171,177,1)
    #  GERR = 2
    #  mkstat = 2
    #  End
    #Endif
    #If GITN8HDTISSISS(nolign-1) > 0 Then
    #  #Des sorties de stock ont été réalisées pour cette consommation. Suppression impossible.
    #  GMESSAGE = mess(171,177,1)
    #  GERR = 2
    #  mkstat = 2
    #  End
    #Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin) : ça c'est pas bon
    # FGR 05/08/2010 : X3SUIVI66063 (début) : D'abord on controle qu'aucune sortie de stock n'est enregistrée
    If status = 65 Then
      INOL = nolign-1
      INOL2 = nolign-1
    Else
      INOL = nolign-1
      INOL2 = nolign1-1
    Endif
    For NUMLIG = INOL To INOL2
      If [M:ITN8]HDTSTOISS(NUMLIG) = 2 and [M:ITN8]SAVSTOISS(NUMLIG) = 2 Then
        If GMESSAGE = "" Then
          GMESSAGE = mess(651,177,1) - "("
        Endif
        GMESSAGE -= num$(NUMLIG+1)
        GERR = 2
      Endif
    Next NUMLIG
    If GERR = 2 Then
      GMESSAGE -= ")"
      mkstat = 2
      End   # FGR 05/11/2014 : X3SUIVI103827 pas Return
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
    IMESSREP = 0
    #Confirmez-vous la suppression des consommations sélectionnées ? Cette action ne peut pas être abandonnée.
    Call OUINON(mess(11,177,1), IMESSREP) From GESECRAN
    If IMESSREP <> 2 Then
      #La suppression des consommations est abandonnée.
      GMESSAGE = mess(12,177,1)
      GERR = 2
      mkstat = 2
      End
    Endif
  Endif
  #
  IERR = 0
  If status = 65 Then
    #Effacement d'une seule ligne
    If [M:ITN8]HDTSTOISS(INOL) = 2 and [M:ITN8]SAVSTOISS(INOL) <> 2 Then # 05/08/2010 : X3SUIVI66063 : Slt si sortie de stock non enregistrée
      # Sortie de stock
      Call DELSTOSORW(INOL, INOL2, "ITN8", [M:ITN8]HDTSTOFCY(nolign-1), IERR) From STKSOR
      If IERR Then
        mkstat = 2
        End
      Endif
    Endif
    #Suppression des débits de points complémentaires
    Call DELPIT("ITN8", INOL, IERR) From TRTAMOUNT
    If IERR Then
      #Erreur lors de la suppression des débits de points complémentaires.
      GMESSAGE = mess(554,182,1)
      GERR = 1
      mkstat = 2
      End
    Endif
    If [M:ITN8]HDTNUM(nolign-1) <> "" Then
      Read [HDT]HDT0=[M:ITN8]HDTNUM(nolign-1)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [HDT]
        Delete [HDT] Curr
        If fstat Then
          Rollback
          Affzo [M:ITN8]1-99
          End
        Else
          Commit
        Endif
      Endif
    Endif
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    # FGR 05/08/2010 : X3SUIVI66063 (début) ça manque un peu. Je fais la boucle parce que le site est sur chaque ligne
    # Sortie de stock
    For NUMLIG = INOL To INOL2
      If [M:ITN8]HDTSTOISS(NUMLIG) = 2 and [M:ITN8]SAVSTOISS(NUMLIG) <> 2 Then
        # 05/08/2010 : X3SUIVI66063 : Slt si sortie de stock non enregistrée
        Call DELSTOSORW(NUMLIG, NUMLIG, "ITN8", [M:ITN8]HDTSTOFCY(NUMLIG), IERR) From STKSOR
        If IERR Then
          Break
        Endif
      Endif
    Next NUMLIG
    If IERR Then
      mkstat = 2
      End
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
    For NUMLIGNE = nolign-1 To nolign1-1
      #Suppression des débits de points complémentaires
      Call DELPIT("ITN8", NUMLIGNE, IERR) From TRTAMOUNT
      If IERR Then
        #Erreur lors de la suppression des débits de points complémentaires.
        GMESSAGE = mess(554,182,1)
        GERR = 1
        mkstat = 2
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Endif
      If [M:ITN8]HDTNUM(NUMLIGNE) <> "" Then
        Read [HDT]HDT0=[M:ITN8]HDTNUM(NUMLIGNE)
        If fstat = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [HDT]
          Delete [HDT]Curr
          If fstat Then
            Rollback
            Affzo [M:ITN8]1-99
            #End   # FGR 02/02/2010 : X3SUIVI60986
            Break  # FGR 02/02/2010 : X3SUIVI60986
          Else
            Commit
          Endif
        Endif
      Endif
    Next
    If GERR Then
      # FGR 02/02/2010 : X3SUIVI60986
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AVANT_NBLIG
Local Integer INOL
Local Integer GMANCOU12      # FGR 13/10/2015 : X3SUIVI111665

  INOL = nolign-1
  Call READ_COUNTER([M:ITN0]SALFCY, 12, 11, GSOCIETE, GCURLEG, GSR2CITNCPT, GMANCOU12) From CRM_UTIL    # FGR 23/07/2015 : X3SUIVI109755
  Call LOADTIMHDT From SUBITNB1
  Affzo [M:ITN8]10
  # Sortie de stock
  Call INIZONSOR("ITN8", [M:ITN8]HDTITM(nolign-1), [M:ITN8]HDTSTOFCY(nolign-1), INOL, 24, [M:ITN0]TRSCOD , "") From STKECR
End

##########################################################################################################
Subprog APRES_NBLIG

  Call LOADTIMHDT From SUBITNB1
  Affzo [M:ITN8]10
  Grizo [M:ITN0]SALFCY
End

##########################################################################################################
Subprog IB_NBLIG

  #---------------------------------------------------#
  # Sortie de stock
  #---------------------------------------------------#
  Raz GBOUT1
  Raz GBOUT2
  If [M:ITN8]NBLIG > 0 Then
    If [M:ITN8]HDTTYP(nolign-1) = 2 Then
      If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
        If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
          If [M:ITN8]HDTISSQTY(nolign-1) > 0 Then
            If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
              If GREP <> "C" and GREP <> "D" Then
                If GREP = "" Then
                  #Modification sorties
                  Call TEXTE(23367, GBOUT2) From OBJDIV
                Endif
              Endif
            Else
              #Sorties stock
              Call TEXTE(5435, GBOUT1) From OBJDIV
            Endif
            GOUVSOR = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  Raz GBOUT3
  If [M:ITN8]NBLIG > 0 Then
    If GREP = "" Then
      If [M:ITN8]HDTITM(nolign-1) <> "" Then
        If [M:ITN8]HDTDONDAT(nolign-1) = [00/00/00] Then
          If GIITN8TIMFLG Then
            GBOUT3 = mess(183,182,1)
          Else
            GBOUT3 = mess(182,182,1)
          Endif
        Endif
      Endif
    Endif
  Endif
  If [M:ITN0]SRVDEMNUM = "" Then
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
  Else
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      Raz GBOUT1
      Raz GBOUT2
      Raz GBOUT3
    Else
      If [F:SRE]SREASS = 5 Then
        Raz GBOUT1
        Raz GBOUT2
        Raz GBOUT3
      Endif
    Endif
  Endif
  #Texte
  Call TEXTE(4685, GBOUT4) From OBJDIV
  If [M:ITN8]HDTNUM(nolign-1) = "" Then
    If [M:ITN8]HDTNUMSEQ(nolign-1) = "" Then
      Raz GBOUT4
    Endif
  Endif
   Call IB_NOTECHECK([M:ITN8]HDTITM(nolign-1),"ITM",7)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog B3_NBLIG
Local Integer INOL

  INOL = nolign-1
  Call MNGHORO([M:ITN0]NUM, GIITN8TIMHDTNUM, INOL, 1) From SUBITNB2
End

##########################################################################################################
Subprog C_PBLSOL(VALEUR)
Variable Integer VALEUR

Local Integer ITERSRE9
Local Integer ISTOOK

  ISTOOK = 1
  If VALEUR = 2 Then
    #Contrôle que toutes les sorties de stock prévuées ont été réalisées.
    #Contrôle dans l'écran
    For ITERSRE9 = 0 To [M:ITN8]NBLIG-1
      If [M:ITN8]HDTTYP(ITERSRE9) = 2 Then
        If [M:ITN8]HDTSTOISS(ITERSRE9) = 2 Then
          If [M:ITN8]HDTDONDAT(ITERSRE9) = [00/00/00] Then
            ISTOOK = 0
            Break
          Else
            If [M:ITN8]HDTISSISS(ITERSRE9) < [M:ITN8]HDTISSQTY(ITERSRE9) Then
              ISTOOK = 0
              Break
            Endif
          Endif
        Endif
      Endif
    Next
    If !ISTOOK Then
      #Des sorties de stock n'ont pas été enregistrées. La clôture de la demande associée n'est pas possible.
      GMESSAGE = mess(528,182,1)
      GERR = 1
      mkstat = 2
      End
    Endif
    #Contrôle dans le fichier
    Filter [HDT] Where [F:HDT]SRENUM = [M:ITN0]SRVDEMNUM and [F:HDT]ITNNUM <> [M:ITN0]NUM and [F:HDT]TPL <> 2
    For [HDT] HDT1
      If [F:HDT]HDTTYP = 2 Then
        If [F:HDT]HDTSTOISS = 2 Then
          If [F:HDT]HDTDONDAT = [00/00/00] Then
            ISTOOK = 0
            Break
          Else
            If [F:HDT]HDTISSISS < [F:HDT]HDTISSQTY Then
              ISTOOK = 0
              Break
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [HDT]
    If !ISTOOK Then
      #Des sorties de stock n'ont pas été enregistrées. La clôture de la demande associée n'est pas possible.
      GMESSAGE = mess(528,182,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog C_HDTINV(VALEUR)
Variable Integer VALEUR

  # FGR 26/01/2012 : X3SUIVI79673
  #    Une ITN couverte :
  #       - 1-Totalement couverte
  #       - 4-Couverte par contrat de service
  #       - 5-Couverte par commande de vente
  #       - 6-Couverte commercialement
  #       - 7-Couverte par facturation directe
  #    N'est pas facturable. On ne doit pas pouvoir cocher "Facturable"
  # ------------------------------------------------------------------------
  If VALEUR = G_OUI Then
    # FGR 20/12/2012 : X3SUIVI86670 (début)
    #If [F:SRE]OVRCOV = 1 or [F:SRE]OVRCOV = 4 or [F:SRE]OVRCOV = 5 or [F:SRE]OVRCOV = 6 or [F:SRE]OVRCOV = 7 Then
    #  GMESSAGE = mess(104,178,1) - '"' + mess([F:SRE]OVRCOV,3003,1) + '".' - mess(105,178,1)
    #  VALEUR = G_NON
    #  GERR = 1
    #Endif
    If func TRTCONH.COVERED_COMPONENT([F:SRE]CONSPT, [F:SRE]OVRCOV, [M:ITN8]HDTMACSRE(nolign-1), [M:ITN8]HDTITM(nolign-1)) = G_YES Then
      GMESSAGE = mess(104,178,1) - '"' + mess([F:SRE]OVRCOV,3003,1) + '".' - mess(105,178,1)
      VALEUR = G_NON
      GERR = 1
    Endif
    # FGR 20/12/2012 : X3SUIVI86670 (fin)
  Endif
End

##########################################################################################################
Subprog AM_HDTINV(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:ITN8]HDTAMTINV(nolign-1) <= 0 Then
      [M:ITN8]HDTAMTINV(nolign-1) = [M:ITN8]HDTAMT(nolign-1)
    Endif
  Else
    [M:ITN8]HDTAMTINV(nolign-1) = 0
  Endif
  [M:ITN8]HDTINV(nolign-1) = VALEUR
  Affzo [M:ITN8]HDTINV(nolign-1), HDTAMTINV(nolign-1)
  Call SET_HDTAMTINV_ENABLE_DISABLE([M:ITN8]HDTINV(nolign-1), nolign-1) From SUBITNA     # Issue SAM120376 - 2017-01-09 by FGR
End

