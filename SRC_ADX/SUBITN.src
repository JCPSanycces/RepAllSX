    When "DEFTRANS"      : Gosub DEFTRANS From SUBITNA
    When "VARIANTE"      : Gosub VARIANTE From SUBITNA
    When "SETTRANS"      : Gosub SETTRANS From SUBITNA
    When "AVANT_OUVRE"   : Gosub AVANT_OUVRE From SUBITNA
    When "OUVRE_BOITE"   : Gosub OUVRE_BOITE From SUBITNA
    When "OUVRE"         : Gosub OUVRE From SUBITNA
    When "FERME"         : Gosub FERME From SUBITNA
    When "FIN"           : Call  RAZSTOSORW From STKSOR
    When "SETBOUT"       : Gosub SETBOUT From SUBITNA
    When "AVANTBOUT"     : Gosub AVANTBOUT From SUBITNA     # FGR 04/06/2015 : X3SUIVI108602
    When "LIENS"         : Gosub LIENS From SUBITNA
    When "RAZCRE"        : Gosub RAZCRE From SUBITNA
    When "INICRE"        : Gosub INICRE From SUBITNA
    When "VERF_ANU"      : Gosub VERF_ANU From SUBITNA
    When "VERIF_CRE"     : Gosub VERIF_CRE From SUBITNA
    When "VERIF_MOD"     : Gosub VERIF_MOD From SUBITNA
    When "APRES_CRE"     : Gosub APRES_CRE From SUBITNA
    When "AVANT_MOD"     : Gosub AVANT_MOD From SUBITNA
    When "APRES_MOD"     : Gosub APRES_MOD From SUBITNA
    When "CREATION"      : Gosub CREATION From SUBITNA
    When "MODIF"         : Gosub MODIF From SUBITNA
    When "AB_MODIF"      : Gosub AB_MODIF From SUBITNA      # FGR 21/08/2009 : X3SUIVI57317
    When "AB_CREATION"   : Gosub AB_CREATION From SUBITNA   # FGR 21/08/2009 : X3SUIVI57317
    When "AV_ANNULE"     : Gosub AV_ANNULE From SUBITNA
    When "ANNULE"        : Gosub ANNULE From SUBITNA
   #When "AP_ANNULE"     : Gosub AP_ANNULE From SUBITNA     # FGR 12/08/2009 : X3SUIVI57005
    When "APRES_ANNULE"  : Gosub APRES_ANNULE From SUBITNA  # FGR 22/10/2009 : X3SUIVI57254
    When "FILTRE"        : Gosub FILTRE From SUBITNA
    When "FILGAUCHE"     : Gosub FILGAUCHE From SUBITNA
    When "ABANDON"       : Gosub ABANDON From SUBITNA
