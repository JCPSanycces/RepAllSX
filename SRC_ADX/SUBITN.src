    If !IFUNOPEN Then
      Call TEXTE(14603, GBOUT1) From OBJDIV      #Demande de service
    Endif
  Endif
End

##########################################################################################################
Subprog IB_BPC
Local Integer IFUNOPEN

  IFUNOPEN = 0
  Raz GBOUT1
  If [M:ITN0]BPC <> ""
    Call ISFUNOPEN("GESBPC", IFUNOPEN) From CRMUTIL140
    If !IFUNOPEN Then
      Call TEXTE(3662, GBOUT1) From OBJDIV      #Client
    Endif
  Endif
  Call IB_NOTECHECK([M:ITN0]BPC,"CRM",2)  From TRTNTSCTL # CRM notes
End

