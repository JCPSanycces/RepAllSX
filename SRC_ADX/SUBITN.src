Subprog C_HDTUOM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_HDTAMTINV(VALEUR)
Variable Decimal VALEUR

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    If VALEUR > 0 Then
      If [M:ITN8]INVPITFLG(nolign-1) > 0 Then
        #Cette consommation est facturée à travers un débit de points. Saisie refusée.
        GMESSAGE = mess(16,177,1)
        GERR = 2
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

