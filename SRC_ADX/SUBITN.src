    When "AB2_NBLIG"     : Gosub AB2_NBLIG From SUBITNA
    When "BB2_NBLIG"     : Gosub BB2_NBLIG From SUBITNA     # FGR 13/10/2010 : X3SUIVI68214
    When "AVANT_CHOI"    : Gosub AVANT_CHOI From SUBITNA
    When "BB6_ITNASS"    : Gosub BB6_ITNASS From SUBITNA    # FGR 01/03/2010 : X3SUIVI62972
    When Default
  Endcase
Return

##########################################################################################################
Subprog C_BPC(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    If [M:ITN0]SRVDEMNUM <> "" Then
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      If !fstat THE
        If [F:SRE]SREBPC <> VALEUR Then
          #Le client saisi sur cette intervention est différent de celui de la demande de service associée.
          #Saisie refusée.
          GMESSAGE = mess(329,182,1)
          GERR = 1
          mkstat = 2
          End  # FGR 15/02/2010 : X3SUIVI62427
        Endif
      Endif
    Endif
    # FGR 15/02/2010 : X3SUIVI62427 (début)
    If [F:BPC]OSTCTL = 3 Then
      SZMESS = VALEUR - ":" - mess(2,178,1)
      Call OUINON(SZMESS, IONREP) From GESECRAN
      If IONREP <> 2 Then
        VALEUR = ""
        mkstat = 2
        End
      Endif
      Call DISPICON_BPC([F:BPC]OSTCTL) From SUBITNB1
    Endif
    # FGR 15/02/2010 : X3SUIVI62427 (fin)
  Endif
End

##########################################################################################################
Subprog AM_BPC(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(GLONBPC)

  SZVALEUR = VALEUR
  Raz [M:ITN0]CCN
  Raz [M:ITN0]CCNCLA
  #Obtient le pays du client sélectionné
  Read [BPR]BPR0=SZVALEUR
  If !fstat Then
    [M:ITN3]CRY = [F:BPR]CRY
  Endif
  #Définit l'adresse par défaut de l'intervention
  Call SET_LIEU_ITN([M:ITN1]TYP, [M:ITN0]SALFCY, SZVALEUR, [M:ITN0]CCN) From SUBITNB1
  [M:ITN0]BPC = VALEUR
  Gosub DISPCCN From SUBITNB1
  Affzo [M:ITN0]1-99
  Affzo [M:ITN3]1-99
End

##########################################################################################################
Subprog AM_DAT(VALEUR)
Variable Date    VALEUR

  If VALEUR = [00/00/00] Then
    Raz [M:ITN1]HOU
  Else
    If [M:ITN1]HOU = ""  Then
      [M:ITN1]HOU = "0900"
    Endif
    Affzo [M:ITN1]HOU
    #Interdit la saisie d'une date inférieure à la date du jour si l'intervention n'est pas effectuée.
    If [M:ITN0]DON <> 2 Then
      If VALEUR < date$ Then
        VALEUR = date$
        [M:ITN1]DAT = VALEUR
        Affzo [M:ITN1]DAT
      Endif
    Endif
    #Met à jour le numéro de semaine avec la nouvelle date
    [M:ITN1]WEE = week(VALEUR)
    Affzo [M:ITN1]WEE
    #Met à jour la date correspondant au numéro de semaine pour une exploitation ultérieure.
    [M:ITN1]DATX = VALEUR
    #Met à jour la date de fin
    Call SETDEFPLN(VALEUR, [M:ITN1]HOU, [M:ITN8]HOUSVCPLN, [M:ITN8]MNTSVCPLN) From SUBITNB2
  Endif
  #Grizo [M:ITN1]DUR # FGR 05/09/2008 : X3SUIVI33081 : la durée reste toujours modifiable
  Affzo [M:ITN1]1-99
End

##########################################################################################################
Subprog AM_HOU(VALEUR)
Variable Char    VALEUR()

  If [M:ITN1]DAT <> [00/00/00] Then
    Call SETDEFPLN([M:ITN1]DAT, VALEUR, [M:ITN8]HOUSVCPLN, [M:ITN8]MNTSVCPLN) From SUBITNB2
  Endif
  [M:ITN1]HOU = VALEUR
  Affzo [M:ITN1]DUR
  Affzo [M:ITN1]HOU
  Affzo [M:ITN1]HOUEND
  #Réinitialise la case à cocher Journée entière
  [M:ITN1]FULDAY = 1
  Affzo [M:ITN1]1-99
  Affzo [M:ITN1]FULDAY
End

##########################################################################################################
Subprog AM_FULDAY(VALEUR)
Variable Integer VALEUR

  If !clalev([F:TWD]) : Local File TABWEEDIA [TWD] : Endif

Local Char SZDUR(type([M:ITN1]DUR)-10)  # FGR 23/07/2014 : X3SUIVI101618    # FGR 05/09/2008 : X3SUIVI33081
Local Integer ITYPE # FGR 05/09/2008 : X3SUIVI33081
Local Char SZDIAHOU(type([F:TWD]TWD)-10) # FGR 05/09/2008 : X3SUIVI33081
Local Integer NI    # FGR 05/09/2008 : X3SUIVI33081

  If VALEUR = 2 Then
    # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire
    If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
    If !clalev([F:DIH]) : Local File DIAHOU [DIH] : Endif
    #
    If [M:ITN1]SCO = 1 Then
      ITYPE = 1
    Else
      ITYPE = 0
    Endif
    If [M:ITN1]DAT = [00/00/00] Then
      [M:ITN1]DAT = date$
    Endif
    [M:ITN1]DATEND = [M:ITN1]DAT
    If ITYPE = 1 Then
      # User : [M:ITN1]REP
      # On récupère les horaires en fonction du schéma hebdomadaire
      Read [AUS]CODUSR=[M:ITN1]REP
      # Récupération du schéma horaire
      Call PARAMUTIL("AUSCRMH", SZDIAHOU, [M:ITN1]REP, "") From SUBAUS
      If SZDIAHOU = "" Then
        [M:ITN1]HOU = "0900"
        [M:ITN1]HOUEND = "1800"
      Else
        Read [TWD]TWD0=SZDIAHOU
        If fstat Then
          [M:ITN1]HOU = "0900"
          [M:ITN1]HOUEND = "1800"
        Else
          Read [DIH]DIH0=[F:TWD]DIAHOU(dayn([M:ITN1]DAT)-1)
          [M:ITN1]HOU = [F:DIH]STRHOU(0)
          If [F:TWD]DIAHOU(dayn([M:ITN1]DAT)-1) <> [F:TWD]DIAHOU(dayn([M:ITN1]DATEND)-1) and [F:TWD]DIAHOU(dayn([M:ITN1]DATEND)-1) <> "" Then
            # Si le schéma horaire de la date début est différent de celui de la fin, et que celui de la fin est renseigné (donc qu'il travaille)
            #  => il en résulte que si la date de fin est non travaillée, l'heure de fin sera la même ce que celle du schéma horaire de
            #     de la date début... sauf que GET_DUREE_DT_HO ne calculera pas de temps pour cette date.
            Read [DIH]DIH0=[F:TWD]DIAHOU(dayn([M:ITN1]DATEND)-1)
          Endif
          For NI = 0 To dim([F:DIH]ENDHOU)-1
            If [F:DIH]ENDHOU(NI) = "" Then
              Break
            Else
              [M:ITN1]HOUEND = [F:DIH]ENDHOU(NI)
            Endif
          Next NI
        Endif
      Endif
    Else
      [M:ITN1]HOU = "0900"
      [M:ITN1]HOUEND = "1800"
    Endif
    #Met à jour le numéro de semaine avec la nouvelle date
    [M:ITN1]WEE = week([M:ITN1]DAT)
    [M:ITN1]DATX =[M:ITN1]DAT
    # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire
    # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
    Call GET_DUREE_DT_HO(ITYPE, [M:ITN1]REP, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
    #
    [M:ITN1]DUR = SZDUR
    Affzo [M:ITN1]DAT, HOU, DATEND, HOUEND, DUR, WEE
  Endif
End

##########################################################################################################
Subprog AM_DATEND(VALEUR)
Variable Date    VALEUR

Local Char SZDUR(type([M:ITN1]DUR)-10)  # FGR 23/07/2014 : X3SUIVI101618
Local Integer ITYPE # FGR 05/09/2008 : X3SUIVI33081

  If VALEUR = [00/00/00] Then
    [M:ITN1]HOUEND = ""
  Else
    #La date de fin doit être postérieure ou égale à la date de début.
    If VALEUR < [M:ITN1]DAT Then
      VALEUR = [M:ITN1]DAT
    Endif
    [M:ITN1]DATEND = VALEUR
    #Met à jour la durée de l'intervention.
    SZDUR = ""
    # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire
    #Call GETDUR(nday([M:ITN1]DAT), [M:ITN1]HOU, nday(VALEUR), [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
    If [M:ITN1]SCO = 1 Then
      ITYPE = 1
    Else
      ITYPE = 0
    Endif
    # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
    Call GET_DUREE_DT_HO(ITYPE, [M:ITN1]REP, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
    #
    [M:ITN1]DUR = SZDUR
  Endif
  Affzo [M:ITN1]DUR
  Affzo [M:ITN1]HOUEND
  Affzo [M:ITN1]DATEND
End

##########################################################################################################
Subprog AM_HOUEND(VALEUR)
Variable Char    VALEUR()

Local Char SZDUR(type([M:ITN1]DUR)-10)  # FGR 23/07/2014 : X3SUIVI101618
Local Integer ITYPE # FGR 05/09/2008 : X3SUIVI33081

  #L'heure de fin d'une intervention d'une même journée doit être supérieure à l'heure de début.
  If [M:ITN1]DAT = [M:ITN1]DATEND Then
    #Cas ou les deux heures sont identiques. Entraine un contrôle des minutes.
    If val(left$(VALEUR, 2)) = val(left$([M:ITN1]HOU, 2)) Then
      If val(mid$(VALEUR, 3, 2)) < val(mid$([M:ITN1]HOU, 3, 2)) Then
        VALEUR = num$(val(left$([M:ITN1]HOU, 2))+1) + mid$([M:ITN1]HOU, 3, 2)
      Endif
    Endif
    #Cas où l'heure de fin est inférieure à l'heure de début
    If val(left$(VALEUR, 2)) < val(left$([M:ITN1]HOU, 2)) Then
      VALEUR = num$(val(left$([M:ITN1]HOU, 2))+1) + mid$([M:ITN1]HOU, 3, 2)
    Endif
  Endif
  #
  #Met à jour la durée du rendez-vous.
  SZDUR = ""
  # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire
  #Call GETDUR(nday([M:ITN1]DAT), [M:ITN1]HOU, nday([M:ITN1]DATEND), VALEUR, SZDUR) From CRM_UTIL
  If [M:ITN1]SCO = 1 Then
    ITYPE = 1
  Else
    ITYPE = 0
  Endif
  # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
  Call GET_DUREE_DT_HO(ITYPE, [M:ITN1]REP, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, VALEUR, SZDUR) From CRM_UTIL
  #
  [M:ITN1]DUR = SZDUR
  [M:ITN1]HOUEND = VALEUR
  Affzo [M:ITN1]DUR
  Affzo [M:ITN1]HOUEND
  #Réinitialise la case à cocher Journée entière
  [M:ITN1]FULDAY = 1
  Affzo [M:ITN1]FULDAY
End

##########################################################################################################
Subprog C_WEE(VALEUR)
Variable Decimal VALEUR

  #Contrôle de la validité du numéro de semaine
  If VALEUR < 0 or VALEUR > 53 Then
    GMESSAGE = mess(187,196,1)
    GERR = 3
    zonsui = "WEE"
  Endif
  If VALEUR <> [M:ITN1]WEE Then
    Raz [M:ITN1]DAT
    Raz [M:ITN1]HOU
    Raz [M:ITN1]DATEND
    Raz [M:ITN1]HOUEND
    Raz [M:ITN1]FULDAY
    [M:ITN1]DUR = "0200"
    Actzo [M:ITN1]DUR, DURX
    Affzo [M:ITN1]DAT, HOU, DATEND, HOUEND, FULDAY, DUR
  Endif
End

##########################################################################################################
Subprog AM_WEE(VALEUR)
Variable Decimal VALEUR
Local Integer INBDAY

  #Si le rdv est exprimé en semaine. La date correspondante doit toujours être un Lundi.
  INBDAY = dayn([M:ITN1]DATX)-1
  [M:ITN1]DATX = [M:ITN1]DATX - INBDAY
  If VALEUR > [M:ITN1]WEE Then
    [M:ITN1]DATX = [M:ITN1]DATX + ((VALEUR - [M:ITN1]WEE) * 7)
  Else
    [M:ITN1]DATX = [M:ITN1]DATX - (([M:ITN1]WEE - VALEUR) * 7)
  Endif
End

##########################################################################################################
Subprog AM_SRVDEMNUM(VALEUR)
Variable Char    VALEUR()

  [M:ITN0]SRVDEMNUM = VALEUR
  Call SETSREINF("AM") From SUBITNB1
  Affzo [M:ITN0]1-99
  Affzo [M:ITN1]1-99
  Affzo [M:ITN3]1-99
  Affzo [M:ITN8]1-99
End

##########################################################################################################
Subprog AM_TYP(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(type(VALEUR)-10)

  SZVALEUR = VALEUR
  Call SET_LIEU_ITN(SZVALEUR, [M:ITN0]SALFCY, [M:ITN0]BPC, [M:ITN0]CCN) From SUBITNB1
End

##########################################################################################################
Subprog AM_SCO(VALEUR)
Variable Integer VALEUR

  #Contrôle du grisage des champs
  [M:ITN1]REP = ""
  [M:ITN1]SCONUM = ""
  [M:ITN1]ITNASS = ""
  [M:ITN1]ITNASSCLA = ""
  [M:ITN1]CUR = ""
  [M:ITN1]SCOAMT = 0
  If VALEUR = 2 Then
    [M:ITN1]CUR = GSYSCUR
    Actzo [M:ITN1]SCOAMT
    Actzo [M:ITN1]CUR
  Else
    Grizo [M:ITN1]SCOAMT
    Grizo [M:ITN1]CUR
  Endif
  [M:ITN1]SCO = VALEUR
  Call SETTZN From SUBITNB3
  Affzo [M:ITN1]1-99
End

##########################################################################################################
Subprog AM_CCN(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(type(VALEUR)-10)

  SZVALEUR = VALEUR
  Call SET_LIEU_ITN([M:ITN1]TYP, [M:ITN0]SALFCY, [M:ITN0]BPC, SZVALEUR) From SUBITNB1
  [M:ITN0]CCN = VALEUR
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBITNB1
  Affzo [M:ITN0]1-99
  Affzo [M:ITN3]1-99
End

##########################################################################################################
Subprog IB_ADD
Local Char SZCODPLC(GLONDES)
Local Integer IMOREADD

  IMOREADD = 0
  SZCODPLC = func SUBITNB1.GET_LIEU_ITN([M:ITN1]TYP, 0)
  Call TEXTE(18271, GBOUT1) From OBJDIV      #Autres adresses
  If SZCODPLC = "" Then
    #Intervention nulle part
    Raz GBOUT1
  Elsif SZCODPLC = "OUT" Then
    #Intervention sur site
    #Vérifie s'il y a des adresses à aller chercher.
    Call CHKADD(1, IMOREADD) From TRTBAP6B
    If !IMOREADD Then
      Raz GBOUT1
    Endif
  Elsif SZCODPLC = "IN" Then
    #Intervention en nos locaux
    #Vérifie s'il y a des adresses à aller chercher.
    Call CHKADD(2, IMOREADD) From TRTBAP6B
    If !IMOREADD Then
      Raz GBOUT1
    Endif
  Endif
  If indice > 0 Then
    Raz GBOUT1
  Endif
End

##########################################################################################################
Subprog AM_MAC(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(type(VALEUR)-10)

  SZVALEUR = VALEUR
  Call SET_LIEU_ITN([M:ITN1]TYP, [M:ITN0]SALFCY, [M:ITN0]BPC, [M:ITN0]CCN) From SUBITNB1
  Affzo [M:ITN3]1-99
End

##########################################################################################################
Subprog IB_DTCKIL

  If !clalev([F:AFT]) : Local File AFCTFCT [AFT] : Endif
  Case GITN1REP
    When ""
      Read [AUS]CODUSR=GUSER
      If fstat Then
        Raz GBOUT1
        Raz GBOUT2
      Else
        If [F:AUS]PRFFCT = "" Then
          Raz GBOUT1
          Raz GBOUT2
        Else
          Read [AFT]AFT0=[F:AUS]PRFFCT
          If fstat Then
            Raz GBOUT1
            Raz GBOUT2
          Else
            If [F:AFT]ALLACS = 2 Then
              GBOUT1 = mess(611,196,1)
              GBOUT2 = mess(612,196,1)
            Else
              Raz GBOUT1
              Raz GBOUT2
            Endif
          Endif
        Endif
      Endif
    When "M", "C", "D"
      Raz GBOUT1
      Raz GBOUT2
    When Default
  Endcase
End

##########################################################################################################
Subprog B1_DTCKIL(VALEUR)
Variable Decimal VALEUR

Local Integer IDTC2

  #Conversion des kilomètres en Miles
  IDTC2 = [M:ITN3]DTCKIL
  Call CNVMILKLM([M:ITN0]NUM, 1, 2, IDTC2) From SUBITNB1
  [M:ITN3]DTCKIL = IDTC2
  Affzo [M:ITN3]DTCKIL
End

##########################################################################################################
Subprog B2_DTCKIL(VALEUR)
Variable Decimal VALEUR

Local Integer IDTC2

  #Conversion des Miles en Kilomètres
  IDTC2 = [M:ITN3]DTCKIL
  Call CNVMILKLM([M:ITN0]NUM, 2, 1, IDTC2) From SUBITNB1
  [M:ITN3]DTCKIL = IDTC2
  Affzo [M:ITN3]DTCKIL
End

##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(type(VALEUR)-10)

  SZVALEUR = VALEUR
  If GFCY <> VALEUR Then
    GFCY = VALEUR
    Call INIT_GLOBAL_CPT(VALEUR, "HTR", 3, GHDKTRSITN) From TRTX3CPT
  Endif
  Gosub AFF_TITCOL From SUBITNB1  #----- Affichage entêtes de colonnes variables -----
  Call SET_LIEU_ITN([M:ITN1]TYP, SZVALEUR, [M:ITN0]BPC, [M:ITN0]CCN) From SUBITNB1
  [M:ITN0]SALFCY = VALEUR
  Affzo [M:ITN0]SALFCY
End

