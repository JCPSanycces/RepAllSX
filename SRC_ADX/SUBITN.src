##########################################################################################################
Subprog C_ITNASS(VALEUR)
Variable Char    VALEUR()

Local Char SZHDKREP(GLONREP)
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  If VALEUR <> "" Then
    If [M:ITN1]SCO = 2 Then
      Read [BPR]BPR0=VALEUR
      If fstat Then
        #La valeur saisie ne correspond pas au code d'un Tiers existant.
        GMESSAGE = mess(153,182,1)
        GERR = 1
        mkstat = 2
      Else
        If [F:BPR]PRVFLG <> 2 Then
          #Le Tiers indiqué n'a pas été défini en tant que prestataire.
          GMESSAGE = mess(154,182,1)
          GERR = 2
        Endif
      Endif
    Else
      Read [AUS]CODUSR=VALEUR
      If fstat Then
        #La valeur saisie ne correspond pas à un utilisateur support client.
        GMESSAGE = mess(155,182,1)
        GERR = 1
        mkstat = 2
      Else
        Call PARAMUTIL("AUSHDKA", SZHDKREP, VALEUR, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP <> 2 Then
          #La valeur saisie ne correspond pas à un utilisateur support client.
          GMESSAGE = mess(155,182,1)
          GERR = 1
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_ITNASS(VALEUR)
Variable Char    VALEUR()

Local Char SZDUR(type([M:ITN1]DUR)-10)  # FGR 23/07/2014 : X3SUIVI101618    # FGR 05/09/2008 : X3SUIVI33081
Local Integer ITYPE # FGR 05/09/2008 : X3SUIVI33081

  [M:ITN1]SCONUM = ""
  [M:ITN1]REP = ""
  If [M:ITN1]SCO = 2 Then
    ITYPE = 0 # FGR 05/09/2008 : X3SUIVI33081
    Read [BPR]BPR0=VALEUR
    If fstat Then
      VALEUR = ""
      [M:ITN1]ITNASSCLA = ""
    Else
      [M:ITN1]ITNASSCLA = [F:BPR]BPRNAM
      [M:ITN1]SCONUM = [F:BPR]BPRNUM
    Endif
  Else
    ITYPE = 1 # FGR 05/09/2008 : X3SUIVI33081
    Read [AUS]CODUSR=VALEUR
    If fstat Then
      VALEUR = ""
      [M:ITN1]ITNASSCLA = ""
    Else
      [M:ITN1]ITNASSCLA = [F:AUS]NOMUSR
      [M:ITN1]REP = [F:AUS]USR
    Endif
    #LSE V150 09/08/2005
    #Utilisation ou non du site du représentant
    Call SITECRMINTREP("HDK", VALEUR, [M:ITN0]SALFCY) From CRM_UTIL
  Endif
  GFCY = [M:ITN0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:ITN1]ITNASSCLA
  Affzo [M:ITN0]SALFCY
  # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire (liée aussi à REP)
  # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
  Call GET_DUREE_DT_HO(ITYPE, [M:ITN1]REP, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
  [M:ITN1]DUR = SZDUR
  Affzo [M:ITN1]DUR
End

##########################################################################################################
Subprog AM_DON(VALEUR)
Variable Integer VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If VALEUR = 2 Then
    Call ITNCHECKSTO (IERRINF,ICHAPTER,IBRETOUR) From SUBITNB3
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      mkstat=1
      End
    Endif
    Call SETDONITNFLG(IERRINF,ICHAPTER,IBRETOUR) From SUBITNB2
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      mkstat=1
      End
    Endif
  Endif
  If [M:ITN0]NUM = "" Then
    If VALEUR = 2 Then
      Actzo [M:ITN4]PBLSOL
      Actzo [M:ITN4]HTOTTIMSPG
      Actzo [M:ITN4]MTOTTIMSPG
      Actzo [M:ITN8]HTIMSPG
      Actzo [M:ITN8]MTIMSPG
    Else
      Grizo [M:ITN4]PBLSOL
      Grizo [M:ITN4]HTOTTIMSPG
      Grizo [M:ITN4]MTOTTIMSPG
      Grizo [M:ITN8]HTIMSPG
      Grizo [M:ITN8]MTIMSPG
    Endif
  Endif
End

##########################################################################################################
Subprog C_NBRER
Local Integer NUMLIGNE
Local Integer ITER

  If status = 65 Then
    #Effacement d'une seule ligne
    If !find([M:ITN7]RER(nolign-1), [M:ITN0]RERDEL) Then
      For ITER = 0 To dim([M:ITN0]RERDEL)-1
        If [M:ITN0]RERDEL(ITER) = "" Then
          [M:ITN0]RERDEL(ITER) = [M:ITN7]RER(nolign-1)
          Break
        Endif
      Next
    Endif
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      If !find([M:ITN7]RER(NUMLIGNE), [M:ITN0]RERDEL) Then
        For ITER = 0 To dim([M:ITN0]RERDEL)-1
          If [M:ITN0]RERDEL(ITER) = "" Then
            [M:ITN0]RERDEL(ITER) = [M:ITN7]RER(NUMLIGNE)
            Break
          Endif
        Next
      Endif
    Next
  Endif
End

##########################################################################################################
Subprog C_RER(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  Read [RRS]RRS0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    End
  Else
    # FGR 24/07/2009 : X3SUIVI56702
    If [M:ITN0]SALFCY <> [F:RRS]SALFCY and [F:RRS]SALFCY <> "" Then
      GMESSAGE = mess(968,196,1)
      mkstat = 2
      End
    Endif
    If [F:RRS]RRSORI > 1 Then
      If [F:RRS]RRSORI = 3 Then
        If [F:RRS]RRSORIVCR <> [M:ITN0]NUM Then
          #Cette ressource est déjà utilisée pour une autre intervention.
          GMESSAGE = mess(171,182,1)
          GERR = 1
          mkstat = 2
        Endif
      Else
        #Cette ressource est déjà utilisée pour un rendez-vous.
        GMESSAGE = mess(169,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_RER(VALEUR)
Variable Char    VALEUR()

  Call LECTURE_RESRES (nolign-1, VALEUR) From SUBITNB1  # FGR 24/07/2009 : X3SUIVI56702
  [M:ITN7]RER(nolign-1) = VALEUR
  # FGR 30/11/2009 : X3SUIVI60504 : RSS n'existe plus
  #Affzo [M:ITN7]RSS(nolign-1), RER(nolign-1), RERSTRDAT(nolign-1), RERSTRHOU(nolign-1), RERENDDAT(nolign-1), RERENDHOU(nolign-1), RSSREP(nolign-1)
  Affzo RER(nolign-1), RERSTRDAT(nolign-1), RERSTRHOU(nolign-1), RERENDDAT(nolign-1), RERENDHOU(nolign-1), RSSREP(nolign-1)
End

