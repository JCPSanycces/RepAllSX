##########################################################################################################
Subprog C_HDTQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal QTY_UV  # FGR 26/05/2010 : X3SUIVI64914

  If VALEUR <= 0 Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
  Endif
  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    If [M:ITN8]HDTITM(nolign-1) <> "" Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
            # FGR 26/05/2010 : X3SUIVI64914 (début)
            If [M:ITN8]HDTUOM(nolign-1) <> [F:ITM]STU Then
              Call SCAL_QUV([M:ITN8]HDTISSISS(nolign-1), [M:ITN8]HDTITM(nolign-1), "", [F:ITM]STU, [M:ITN8]HDTUOM(nolign-1), QTY_UV, GBIDD1) From TRTVENQTE
            Else
              QTY_UV = [M:ITN8]HDTISSISS(nolign-1)
            Endif
            # FGR 26/05/2010 : X3SUIVI64914 (fin)
            #If VALEUR < [M:ITN8]HDTISSISS(nolign-1) Then    # FGR 26/05/2010 : X3SUIVI64914
            If VALEUR < QTY_UV Then                          # FGR 26/05/2010 : X3SUIVI64914
              #La quantité consommée ne peut pas être inférieure à la quantité sortie de stock.
              GMESSAGE = mess(170,177,1)
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
          If GITN8HDTISSISS(nolign-1) > 0 Then
            # FGR 26/05/2010 : X3SUIVI64914 (début)
            If [M:ITN8]HDTUOM(nolign-1) <> [F:ITM]STU Then
              Call SCAL_QUV(GITN8HDTISSISS(nolign-1), [M:ITN8]HDTITM(nolign-1), "", [F:ITM]STU, [M:ITN8]HDTUOM(nolign-1), QTY_UV, GBIDD1) From TRTVENQTE
            Else
              QTY_UV = GITN8HDTISSISS(nolign-1)
            Endif
            # FGR 26/05/2010 : X3SUIVI64914 (fin)
            #If VALEUR < GITN8HDTISSISS(nolign-1) Then       # FGR 26/05/2010 : X3SUIVI64914
            If VALEUR < QTY_UV Then                          # FGR 26/05/2010 : X3SUIVI64914
              #La quantité consommée ne peut pas être inférieure à la quantité sortie de stock.
              GMESSAGE = mess(170,177,1)
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

